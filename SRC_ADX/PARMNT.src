#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ
GBIDC1 = "ZZMB2"
Call OBJET("ATB",GBIDC1,GBIDC2) From GOBJET
End

####################################################################
# Action ASELZON  : Sélection zones de fichier
# Action ASAIOPT  : Saisie options de sélection
# Action ASAIPAR  : Saisie paramètres type de donnée
# Action ASAITAB  : Saisie dépendance pour table de contrôle
# Action ASAIFOR  : Saisie format
# Action AMKGRA   : Saisie paramètres graphiques
# Action AMKINT   : Saisie intitulé évalué
####################################################################

$ACTION
Case ACTION
 When "OUVRE"
  Case BOITE
   When "ASELZON"  : Gosub OUVRE_ZON
   When "ASAIOPT"  : Gosub OUVRE_OPT
   When "ASAIPAR"  : Gosub OUVRE_PAR
   When "ASAITAB"  : Gosub OUVRE_TAB
   When "ASAIFOR"  : Gosub OUVRE_FOR
   When "AMKGRA"   : Gosub OUVRE_GRA
  Endcase
 When "DEBUT"
  Case BOITE
   When "ASELZON"  : Gosub DEBUT_ZON
   When "ASAIOPT"  : Gosub DEBUT_OPT
   When "ASAIPAR"  : Gosub DEBUT_PAR
   When "ASAITAB"  : Gosub DEBUT_TAB
   When "ASAIFOR"  : Gosub DEBUT_FOR
   When "AMKGRA"   : Gosub DEBUT_GRA
   When "AMKINT"   : Gosub DEBUT_INT
   When "AMKINF"   : Gosub DEBUT_INF
  Endcase
 When "OK"
  Case BOITE
   When "ASELZON"  : Gosub OK_ZON
   When "ASAIOPT"  : Gosub OK_OPT
   When "ASAIPAR"  : Gosub OK_PAR
   When "ASAITAB"  : Gosub OK_TAB
   When "ASAIFOR"  : Gosub OK_FOR
   When "AMKGRA"   : Gosub OK_GRA
   When "AMKINT"   : Gosub OK_INT
   When "AMKINF"   : Gosub OK_INF
  Endcase
 When "APRES_MODIF"
  Case BOITE
   When "ASELZON"  : Gosub APRES_ZON
  Endcase
 When "ABA"
  Case BOITE
   When "ASELZON"  : Gosub ABANDON_ZON
  Endcase
Endcase
Return

#-----------------------------------------------------------#
$OUVRE_ZON
Local Integer NOL
NOL = nolign-1
Return

##########
$DEBUT_ZON
Local Mask SELZON [DIA2]
Raz [DIA2]
If [M:AMK1]FICREF(0)<>""
 [M:DIA2]FICHIER = [M:AMK1]FICREF(0)
 Gosub LIRE_ZON
Endif
Actzo FICHIER
Return

###############
$ABANDON_ZON
Actzo FICHIER
Gosub LIRE_ZON
Return

###############
$APRES_ZON
Case zoncou
 When "NBLIG"
  Diszo FICHIER
  REP = "M"
 When "FICHIER"
  Gosub LIRE_ZON
Endcase
Return

##########
$OK_ZON
nolign = NOL+1
Read [ATB]CODFIC = [M:DIA2]FICHIER
If !fstat
 For I=0 To [M:DIA2]NBLIG-1
  OK  = 1
  OK *= [M:DIA2]SELECT(I)=2
  OK *= !find([M:DIA2]CODZONE(I),[M:AMK2]CODZON(0..[M:AMK2]NBLIG-1))
  If OK
   Insa NOL,1,[M:AMK2]NBLIG [M:AMK2]NBLIG
   [M:AMK2]NBLIG += 1
   Read [ATZ]CODZONE = [M:DIA2]FICHIER ; [M:DIA2]CODZONE(I)
   Gosub CHARGE_ZON
   If GOK<1 : Break : Endif
   NOL += 1
  Endif
 Next
Endif
If GOK<1 : Return : Endif
NOL = [M:AMK2]NBLIG
For I=0 To [M:AMK1]NBBLOC-1
 If [M:AMK1]TYPBLOC(I)=1 & !find([M:AMK1]BASPAG(I),[M:AMK2]CODZON(0..[M:AMK2]NBLIG-1))
  [M:AMK2]CODZON(NOL)   = [M:AMK1]BASPAG(I)
  [M:AMK2]INTIT(NOL)    = 0
  [M:AMK2]CODTYP(NOL)   = "ABS"
  [M:AMK2]SAIAFF(NOL)   = 1
  [M:AMK2]NUMBLOC(NOL)  = I+1
  [M:AMK2]NOZONE(NOL)   = 1
  [M:AMK2]DIME(NOL)     = 0
  [M:AMK2]OBLIG(NOL)    = 1
  [M:AMK2]TYPGRAPH(NOL) = 1
  Gosub INI_CODTYP
  NOL += 1
 Endif
Next I
[M:AMK2]NBLIG = NOL
Affzo [M:AMK2]10
mkstat=2
Return

$LIRE_ZON
Effzo 10
nolign = 0
For [ATZ]NUMLIG Where CODFIC=[M]FICHIER
  Read [F:ATY]CODTYP = [F:ATZ]CODTYP
  If fstat = 0 and find([F:ATY]TYPTYP,11,12) = 0
    nolign += 1
    [M] = [F:ATZ]
    Call TEXTE([F:ATZ]NOCOURT,[M:DIA2]INTITCOURT(nolign-1)) From OBJDIV
    If find([F:ATZ]CODZONE,[M:AMK2]CODZON(0..[M:AMK2]NBLIG-1))
      [M:DIA2]SELECT(nolign-1) = 1
    Else
      [M:DIA2]SELECT(nolign-1) = 2
    Endif
  Endif
Next
[M]NBLIG = nolign
REP = ""
Affzo 10
Return

$CHARGE_ZON
Local Integer TX
[M:AMK2]CODZON(NOL)   = [F:ATZ]CODZONE
[M:AMK2]CODTYP(NOL)   = [F:ATZ]CODTYP
[M:AMK2]CODACT(NOL)   = [F:ATZ]CODACT
If [M:AMK2]CODACT(NOL)<>"" & [M:AMK2]CODACT(NOL)<"X" & GADONIX<>2
 [M:AMK2]CODACT(NOL) = ""
Endif
[M:AMK2]NOLIB(NOL)    = [F:ATZ]NOLIB
[M:AMK2]LONG(NOL)     = [F:ATZ]LONG
[M:AMK2]OPTSAI(NOL)   = [F:ATZ]OPTION
Gosub INI_NUMBLOC
[M:AMK2]NUMBLOC(NOL)  = NUM
Gosub INI_NOZONE
[M:AMK2]NOZONE(NOL)   = NUM
If [M:AMK2]CODZON(NOL)<>[M:AMK1]BASPAG([M:AMK2]NUMBLOC(NOL)-1)
 Case [M:AMK1]TYPBLOC([M:AMK2]NUMBLOC(NOL)-1)
  When 1 : # Tableau
   [M:AMK2]DIME(NOL)   = [M:AMK1]NBLIGT([M:AMK2]NUMBLOC(NOL)-1)
   [M:AMK2]SAIAFF(NOL) = 1
   [M:AMK2]OBLIG(NOL)  = [F:ATZ]OBLIG
  When 5 : # Invisible
   TX = [F:ATZ]DIME
   Call REPTAB([F:ATZ]CODACT,TX) From DOSSUB
   TX = max(1,abs(TX))
   [M:AMK2]DIME(NOL)   = TX
   [M:AMK2]SAIAFF(NOL) = 3
   [M:AMK2]OBLIG(NOL)  = 0
  When Default
   TX = [F:ATZ]DIME
   Call REPTAB([F:ATZ]CODACT,TX) From DOSSUB
   TX = max(1,max(TX))
   [M:AMK2]DIME(NOL)   = TX
   [M:AMK2]SAIAFF(NOL) = 1
   [M:AMK2]OBLIG(NOL)  = [F:ATZ]OBLIG
 Endcase
Else
 [M:AMK2]DIME(NOL) = 0
 [M:AMK2]SAIAFF(NOL) = 1
 [M:AMK2]OBLIG(NOL)  = [F:ATZ]OBLIG
Endif
TX = [F:ATZ]NOCOURT
Call TEXTE(TX,[M:AMK2]ZINTIT(NOL)) From OBJDIV
[M:AMK2]INTIT(NOL)    = TX
#[M:AMK2]INFBUL(NOL)   = 0
[M:AMK2]TYPGRAPH(NOL) = 1
#[M:AMK2]MOTCLE(NOL)   = [F:ATZ]MOTCLE
Gosub INI_CODTYP
Return

$INI_NOZONE
If NOL=0 | [M:AMK2]NUMBLOC(NOL)<>[M:AMK2]NUMBLOC(NOL-1)
 NUM = 1
Else
 NUM = int([M:AMK2]NOZONE(NOL-1)) + 1
Endif
Return

$INI_NUMBLOC
If NOL=0
 NUM = 1
Else
 NUM = [M:AMK2]NUMBLOC(NOL-1)
Endif
Return

$INI_DIME
If [M:AMK2]CODZON(NOL)=[M:AMK1]BASPAG([M:AMK2]NUMBLOC(NOL)-1) and [M:AMK1]TYPBLOC([M:AMK2]NUMBLOC(NOL)-1)=1
 NUM = 0
Elsif [M:AMK1]TYPBLOC([M:AMK2]NUMBLOC(NOL)-1)=1
 NUM = [M:AMK1]NBLIGT([M:AMK2]NUMBLOC(NOL)-1)
Elsif NUM = 0
 NUM = 1
Endif
Return

$INI_CODTYP
Call LECTURE("ATY",[M:AMK2]CODTYP(NOL),"") From CONTOBJ
If [F:ATY]OBJLIEN=""
 [M:AMK2]TUNNEL(NOL)   = 0
 [M:AMK2]LIEN(NOL)     = 0
 Gosub CRE_PARTYP
Else
 [M:AMK2]TUNNEL(NOL)   = 2
 If [M:AMK1]TYPBLOC([M:AMK2]NUMBLOC(NOL))=2
  [M:AMK2]LIEN(NOL)     = 2
 Else
  [M:AMK2]LIEN(NOL)     = 1
 Endif
 Gosub CRE_PARTYP
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0
  Gosub CRE_PAROBJ
 Endif
Endif
If [F:ATY]VALDEF<>"" & [M:AMK2]VALDEF(NOL)=""
 [M:AMK2]VALDEF(NOL) = [F:ATY]VALDEF : # MB 23/9/99
Endif
Return

$CRE_PARTYP
Local Integer L
L = mod(type([F:AMP]VALPAR)-10,256)
Local Char VACT(GLONACT), VPAR(L)
If [F:ATY]NBTYP>0
 GOK = 1
 Call DEBTRANS From GLOCK
 Trbegin [AMP]
  For KK=1 To [F:ATY]NBTYP
   VACT = [F:ATY]ACTION(KK-1)
   While VACT<>""
    Call LECTURE("ACT",VACT,"") From CONTOBJ
    For [ATR]NOPAR Where ACTION=VACT
     If [F:ACT]TYPACT=1 | [F:ATR]NOPAR<>1
      Look [AMP]CODPAR = 1;[M:AMK0]CODMSK;[M:AMK2]CODZON(NOL);[F:ATR]CODPAR
      If fstat
       VPAR = ""
       Read [AMP]CODPAR = 2;[F:ATZ]CODFIC;[M:AMK2]CODZON(NOL);[F:ATR]CODPAR
       If !fstat
        VPAR = [F:AMP]VALPAR
       Endif
       Raz [F:AMP]
       [F:AMP]TYPAFF = 1
       [F:AMP]CODAFF = [M:AMK0]CODMSK
       [F:AMP]CODZON = [M:AMK2]CODZON(NOL)
       [F:AMP]CODPAR = [F:ATR]CODPAR
       If VPAR<>""
        [F:AMP]VALPAR = VPAR
       Elsif [F:ATR]ADRVAL=2
        [F:AMP]VALPAR = '""'
       Endif
       Write [AMP]
       If fstat : GOK=0 : Call FSTA("AMP") From GLOCK : Break 2 : Endif
      Endif
     Endif
    Next ATR
    VACT = [F:ACT]ACTSUI
   Wend
  Next KK
  If GOK<1 : Rollback : Return : Endif
 Commit
Endif
Return

$CRE_PAROBJ
Call DEBTRANS From GLOCK
GOK=1
Trbegin [AMP]
 Look [AMP]CODPAR = 1;[M:AMK0]CODMSK;[M:AMK2]CODZON(NOL);[F:AOB]ABREV
 If fstat
  Raz [F:AMP]
  [F:AMP]TYPAFF = 1
  [F:AMP]CODAFF = [M:AMK0]CODMSK
  [F:AMP]CODZON = [M:AMK2]CODZON(NOL)
  [F:AMP]CODPAR = [F:AOB]ABREV
  [F:AMP]VALPAR = '""'
  Write [AMP]
  If fstat : GOK=0 : Call FSTA("AMP") From GLOCK : Endif
 Endif
 If GOK<1 : Rollback : Return : Endif
Commit
Return

#-----------------------------------------------------------#
$OUVRE_OPT
Local Char    COD(GLONATY) : # Type de donnée
Local Char    OPT(20)      : # Options
Local Integer OKSAI, I, IND, NOL
Local Char    OLDOPT(20)
Local Char    OPTS(7)       : # Affiche parametre (si OPTS = OPT alors stop)
Local Mask    AMKOBJ [DIA2]
COD  = VALEUR
OPT  = PARAM(1)
NOL  = nolign-1
OPTS = PARAM(2)
If COD=""
 FIN = 1 : Return
Endif
If  [L]OPTS = "OPT"
 FIN = 1 : Raz GBIDC2 :  Return
Endif
Call LECTURE("ATY",COD,"") From CONTOBJ
If [F:ATY]OBJLIEN=""
 FIN = 1 : Return
Endif
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
If [F:AOB]NBOPT=0
 FIN = 1 : Return
Endif
Return

#############
$DEBUT_OPT
IND = 0
For I=0 To [F:AOB]NBOPT-1
 Call TEXTE([F:AOB]OPTLIB(I),[M:DIA2]LIBOPT(IND)) From OBJDIV
 If instr(1,OPT,[F:AOB]OPTCOD(I))
  [M:DIA2]OKOPT(IND) = 2
 Else
  [M:DIA2]OKOPT(IND) = 1
 Endif
 IND += 1
Next I
[M:DIA2]NBOPT = IND
Affzo
Return

#############
$OK_OPT
OLDOPT = OPT
OPT = ""
nolign = NOL+1
For I=0 To [M:DIA2]NBOPT-1
 If [M:DIA2]OKOPT(I) = 2
  OPT += [F:AOB]OPTCOD(I)
 Endif
Next I
If OLDOPT<>OPT : mkstat=6 : Endif
PARAM(1) = OPT
GBIDC3 = "OPT"
Return

#-----------------------------------------------------------#
$OUVRE_PAR
Local Integer TYP          : # 1=écran, 2=table
Local Char    AFF(GLONAMK) : # Ecran/table
Local Char    ZON(GLONAVA) : # Zone
Local Char    COD(GLONATY) : # Code type
Local Char    PAR(7)       : # Affiche parametre (si PAR = 9999999 alors stop)
Local Mask    AMKPAR [DIA2]
COD = VALEUR
[L]TYP = val(PARAM(1))
[L]AFF = PARAM(2)
[L]ZON = PARAM(3)
[L]PAR = PARAM(4)
If !find([L]TYP,1,2) | [L]AFF="" | [L]ZON="" | [L]COD=""
 FIN = 1 : Return
Endif
If  [L]PAR = "PAR"
 FIN = 1 : Raz GBIDC1 :  Return
Endif
Call CHARGE_PAR([L]TYP,[L]AFF,[L]ZON,[L]COD)
If [M]NBPAR=0
 FIN = 1 : Return
Endif
Return


#############
$DEBUT_PAR
Call CHARGE_PAR([L]TYP,[L]AFF,[L]ZON,[L]COD)
Affzo
Return

#############
$OK_PAR
Call VALID_PAR([L]TYP,[L]AFF,[L]ZON)
Return

#-----------------------------------------------------------#
$OUVRE_TAB
Local Integer TYP          : # 1=écran, 2=table
Local Char    AFF(GLONAMK) : # Ecran/table
Local Char    ZON(GLONAVA) : # Zone
Local Char    COD(GLONAAR) : # Nom du paramètre dépendance
[L]TYP = val(PARAM(1))
[L]AFF = PARAM(2)
[L]ZON = PARAM(3)
[L]COD = "TABCONT"
If VALEUR="" | !find([L]TYP,1,2) | [L]AFF="" | [L]ZON=""
 FIN = 1 : Return
Endif
If clalev([F:ACL])=0 : Local File ACTL [ACL] : Endif
Read [ACL]ACL0 = VALEUR
If fstat | ([F:ACL]DEPCTL="" & [F:ACL]DEPCTL2="" & [F:ACL]DEPCTL3="")
 Call ANNULE_PAR([L]TYP,[L]AFF,[L]ZON,[L]COD)
 FIN = 1 : Return
Endif
Local Mask AMKPAR [DIA2]
Return

#############
$DEBUT_TAB
Raz [DIA2]
Call CHARGE_PARTAB([L]TYP,[L]AFF,[L]ZON,[L]COD)
Affzo
Return

#############
$OK_TAB
Call VALID_PAR([L]TYP,[L]AFF,[L]ZON)
Return

Subprog CHARGE_PARTAB(TYP,AFF,ZON,COD)
Value Integer TYP
Value Char    AFF
Value Char    ZON
Value Char    COD
Local Integer J
Gosub SETSEP
J = 0
Read [AAR]CODPAR = [L]COD
If !fstat
 J += 1
 [M]CODPAR(J-1) = [L]COD
 Call TEXTE([F:AAR]INTITPAR,[M]INFO(J-1)) From OBJDIV
 [M]INFO(J-1) += SEP + mess(1,33,1) : # Char
 [M]INFO(J-1) += SEP + mess(2,34,1) : # Par valeur
 Read [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[L]COD
 If fstat
  Call MAJPAR_VIDE([L]TYP,[L]AFF,[L]ZON,[L]COD)
 Endif
 [M]VALPAR(J-1) = [F:AMP]VALPAR
 [M]NBPAR = J
Endif
End

#-----------------------------------------------------------#
$OUVRE_FOR
Local Integer NOL
NOL = nolign-1
Return

############
$DEBUT_FOR
Local Integer OKSAI, I, IND , CHX
Gosub SETSPE From SUBAMK2
Local Mask AMKFOR [DIA2]
[M:DIA2]OPTFOR2 = [M:AMK2]OPTFOR(NOL)
Affzo
Return

###########
$OK_FOR
CHX = ([M:AMK2]OPTFOR(NOL)<>[M:DIA2]OPTFOR2)
[M:AMK2]OPTFOR(NOL) = [M:DIA2]OPTFOR2
If [M:DIA2]OPTFOR2<>""
 VALEUR = SPE
Else
 If VALEUR = SPE : VALEUR = "" : Endif
Endif
If CHX : mkstat=6 : Endif
Return

#-----------------------------------------------------------#
$OUVRE_GRA
If !find(VALEUR,8,9,10,11,12) : FIN = 1 : Return : Endif
Local Integer NOL , TYP
NOL = nolign-1
If [M:AMK2]CODTYP(NOL)<>""
 Read [ATY]CODTYP = [M:AMK2]CODTYP(NOL)
 If !fstat
  TYP = [F:ATY]TYPTYP
 Endif
Endif
Return

###########
$DEBUT_GRA
Local Integer OK
Local Mask AMKGRA [DIA2]
Actzo [DIA2]
Case VALEUR
 When 8 : # Barre
  [M:DIA2]PICTYP = 0
  [M:DIA2]TEXTYP = 0
  Grizo [DIA2]NBRLIG,PICTYP,TEXTYP
  [M:DIA2]NBRCOL = [M:AMK2]VAL2(NOL)
 When 9 : # Photo
  [M:DIA2]TEXTYP = 0
  Grizo [DIA2]TEXTYP
  [M:DIA2]NBRLIG = [M:AMK2]VAL1(NOL)
  [M:DIA2]NBRCOL = [M:AMK2]VAL2(NOL)
  [M:DIA2]PICTYP = [M:AMK2]VAL3(NOL)
 When 10,11,12 : # Multi-ligne, Textes KR & KH
  [M:DIA2]PICTYP = 0
  Grizo [DIA2]PICTYP
  [M:DIA2]NBRLIG = [M:AMK2]VAL1(NOL)
  [M:DIA2]NBRCOL = [M:AMK2]VAL2(NOL)
  Actzo [DIA2]TEXTYP
  [M:DIA2]TEXTYP = [M:AMK2]VAL3(NOL)
Endcase
Affzo [DIA2]
Return

###########
$OK_GRA
If find(VALEUR,10,11,12) & [M:DIA2]NBRLIG<4
 # Pour ce type d'objet graphique le nombre de lignes doit être au minimum de 4
 Call ERREUR(mess(218,139,1)) From GESECRAN
 FIN = 0 : Return
Endif
nolign = NOL+1
[M:AMK2]VAL1(NOL) = [M:DIA2]NBRLIG
[M:AMK2]VAL2(NOL) = [M:DIA2]NBRCOL
Case VALEUR
 When 9        : [M:AMK2]VAL3(NOL) = [M:DIA2]PICTYP
 When 10,11,12 : [M:AMK2]VAL3(NOL) = [M:DIA2]TEXTYP
Endcase
Return

#-----------------------------------------------------------#
$DEBUT_INT
Local Mask AMKINT [DIA2]
Local Integer NOL
NOL = nolign-1
[M:DIA2]INTEVAL = PARAM(1)
[M:DIA2]INTSTYL = PARAM(3)
If PARAM(4)<>"1"
 Grizo [M:DIA2]INTSTYL
Endif
Affzo [M:DIA2]
Return

###########
$OK_INT
nolign = NOL+1
If PARAM(1)<>[M:DIA2]INTEVAL
 mkstat = 4
 PARAM(1) = [M:DIA2]INTEVAL
 PARAM(2) = "0"
 If [M:DIA2]INTEVAL<>""
  VALEUR = "$"
 Else
  VALEUR = ""
 Endif
Endif
If PARAM(3)<>[M:DIA2]INTSTYL
 mkstat = 4
 PARAM(3) = [M:DIA2]INTSTYL
Endif
Return

#-----------------------------------------------------------#
$DEBUT_INF
#Local Mask AMKINF [DIA2]
#Local Integer NOL
#[M:DIA2]INFBUL = val(PARAM(1))
#Call TEXTE([M:DIA2]INFBUL,[M:DIA2]ZINFBUL) From OBJDIV
#Affzo [M:DIA2]
Return

###########
$OK_INF
nolign = NOL+1
#If val(PARAM(1))<>[M:DIA2]INFBUL
# mkstat = 4
# PARAM(1) = num$([M:DIA2]INFBUL)
#Endif
Return

#-----------------------------------------------------------#
Subprog VALID_ACT(AFF,ZON)
Value Char    AFF, ZON
Local Integer I, J, OK, NUMACT, TYP
Local Char    CRITERE(250)
TYP = 1
If AFF="" | ZON="" : End : Endif
Gosub SETSEP
Call DEBTRANS From GLOCK
Gosub TR_ACT
If GOK<1 : mkstat = 1 : Endif
End

$TR_ACT
GOK = 1
CRITERE = "TYPAFF=1 & CODAFF=AFF & CODZON=ZON"

Trbegin [AMA], [AMP]
 Delete [AMA] Where evalue(CRITERE)
 If fstat = 1
  GOK = -1 : GLOCK = "$AMSKACT"-AFF-ZON : Goto ROLL_ACT
 Endif

 Sorta [M]NBACT [M]NBACT Order By [M]TYPACT(indice), indice
 Affzo 15-20

 For nolign=1 To [M]NBACT
  Raz [F:AMA]
  [F:AMA] = [M]
  [F:AMA]TYPAFF = 1
  [F:AMA]CODAFF = AFF
  [F:AMA]CODZON = ZON
  [F:AMA]NOACT  = nolign
  Write [AMA]
  If fstat : GOK = 0 : Call FSTA("AMA") From GLOCK : Break : Endif
 Next nolign
 If GOK<1 : Goto AB_ACT : Endif
 Gosub MAJ_PAR
 If GOK<1 : Goto AB_ACT : Endif
Commit
Return

$ROLL_ACT
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ACT : Endif

$AB_ACT
Rollback
Return

#-----------------------------------------------------------#
Subprog CHARGE_ACT(AFF,ZON)
Value Char    AFF()
Value Char    ZON()
Local Integer I, J, TYP
TYP = 1
Local Char    CRITERE(250)
If AFF="" | ZON="" : End : Endif
CRITERE = "TYPAFF=1 & CODAFF=AFF & CODZON=ZON"
Filter [AMA] Where evalue(CRITERE)
Read [AMA]TYPAFF First
I = 0
For [AMA]NOACT
 If I>=dim([M]TYPACT)-1
  Call ECR_TRACE(mess(161,115,1),1) From GESECRAN : # Trop de lignes
  Break
 Endif
 I += 1
 [M]TYPACT(I-1)   = [F:AMA]TYPACT
 [M]ACTION(I-1)   = [F:AMA]ACTION
 [M]NOAC(I-1)     = [F:AMA]NOACT
 [M]INTITACT(I-1) = [F:AMA]INTITACT
 [M]EXEACT(I-1)   = [F:AMA]EXEACT
 [M]DISACT(I-1)   = [F:AMA]DISACT
 [M]COMBI(I-1)    = num$([F:AMA]TYPACT)+[F:AMA]ACTION
 If [F:AMA]INTITACT<>0
  Call TEXTE([F:AMA]INTITACT,[M]ZINTITACT(I-1)) From OBJDIV
 Else
  [M]ZINTITACT(I-1) = ""
  #If ([M]TYPACT(I-1)>=9 & [M]TYPACT(I-1)<=12) | [M]TYPACT(I-1)>=15
   Read [ACT]ACTION = [F:AMA]ACTION
   If !fstat
    If [F:ACT]INTITC<>0
     Call TEXTE([F:ACT]INTITC,[M]ZINTITACT(I-1)) From OBJDIV
    Else
     Call TEXTE([F:ACT]INTITA,[M]ZINTITACT(I-1)) From OBJDIV
    Endif
   Endif
  #Endif
 Endif
Next
[M]NBACT = I
Filter [AMA]
Affzo 15
Call CHARGE_PARACT(AFF,ZON)
End

#-----------------------------------------------------------#
Subprog CHARGE_PARACT(AFF,ZON)
Value Char    AFF()
Value Char    ZON()
Local Integer I, J, TYP
Local Char    ACTION(GLONACT)
TYP = 1
If AFF="" | ZON="" : End : Endif
Gosub SETSEP
Effzo 20
Raz J
For I=0 To [M]NBACT-1
 [L]ACTION = [M]ACTION(I)
 While [L]ACTION<>""
  Gosub CHARGE_PARAM
  [L]ACTION = [F:ACT]ACTSUI
 Wend
Next I
[M]NBPAR = J
Sorta [M]NBPAR [M]NBPAR Order By [M]CODPAR(indice)
Affzo 20
End

#-----------------------------------------------------------#
$CHARGE_PARAM
Call LECTURE("ACT",[L]ACTION,"") From CONTOBJ
For [ATR]NOPAR Where ACTION=[L]ACTION
 If !([F:ATR]NOPAR=1 & [F:ACT]TYPACT<>1)
  If !find([F:ATR]CODPAR,[M]CODPAR(0..J-1))
   J += 1
   [M]CODPAR(J-1) = [F:ATR]CODPAR
   Call TEXTE([F:ATR]INTITPAR,[M]INFO(J-1)) From OBJDIV
   [M]INFO(J-1)  += SEP + mess([F:ATR]TYPPAR,33,1)
   [M]INFO(J-1)  += SEP + mess([F:ATR]ADRVAL,34,1)
   Read [AMP]CODPAR = 1;AFF;ZON;[F:ATR]CODPAR
   If !fstat
    [M]VALPAR(J-1) = [F:AMP]VALPAR
   Elsif [F:ATR]ADRVAL=2 : # Par valeur
    Call MAJPAR_VIDE(1,AFF,ZON,[F:ATR]CODPAR)
    [M]VALPAR(J-1) = '""'
   Endif
  Endif
 Endif
Next
Return

#-----------------------------------------------------------#
Subprog CONTPAR(AFF,OK)
Value    Char    AFF
Variable Integer OK

Local    Char    ZON(GLONAVA), MESSA(100), ACT(GLONACT), ACTION(GLONACT), PAR(GLONAAR)
Local    Integer OK2, I, J, K, III, PLEIN, CONTYP, TYP
Local    Integer PPP(300)
Local    Char    COD(30)(1000), CCC(30)(300)

If !GIMPORT
 Call TEMPON("F") From GESECRAN : # Vérification
 MESSA = mess(147,123,1)-AFF : # Contrôle saisie des paramètres
 Call OUVRE_TRACE(MESSA) From LECFIC
Endif

If clalev([F:AP2])=0 : Local File AMSKPAR  [AP2] : Endif

TYP = 1
OK = 1
Raz COD, J, PLEIN
For I=0 To [M:AMK2]NBLIG-1
 Raz CCC, PPP, III
 ZON = [M:AMK2]CODZON(I)
 Gosub CONTACT : # Contrôle des paramètres des actions
 Gosub CONTTYP : # Contrôle des paramètres liés aux codes types
 Gosub CONTTAB : # Contrôle paramètre dépendance de la table de contrôle
Next I

# On en profite pour virer les paramètres inutiles si aucune anomalie

If !PLEIN & OK
 Filter [AP2] Where TYPAFF=1 & CODAFF=AFF
 For [AP2]
  If !find([F:AP2]CODZON+[F:AP2]CODPAR,COD(0..J-1))
   Gosub TR_ANNUPAR
  Endif
 Next
 Filter [AP2]
Endif
If !GIMPORT
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

$CONTACT
CONTYP = 0
Filter [AMA] Where TYPAFF=1 & CODAFF=AFF & CODZON=ZON
For [AMA]
 [L]ACTION = [F:AMA]ACTION
 While [L]ACTION<>""
  Gosub CONT_PAR
  [L]ACTION = [F:ACT]ACTSUI
 Wend
Next
Filter [AMA]
Return

$CONT_PAR
Call LECTURE("ACT",[L]ACTION,"") From CONTOBJ
For [ATR]NOPAR Where ACTION=[L]ACTION
 OK2  = 0
 OK2 += ([F:ATR]NOPAR=1 & [F:ACT]TYPACT<>1)
 If !OK2
  PAR = [F:ATR]CODPAR
  Gosub INC_PAR
 Endif
Next
Return

$CONTTYP
CONTYP = 1
Call LECTURE("ATY",[M:AMK2]CODTYP(I),"") From CONTOBJ
For KK=1 To [F:ATY]NBTYP
 ACT = [F:ATY]ACTION(KK-1)
 While ACT<>""
  Call LECTURE("ACT",ACT,"") From CONTOBJ
  For [ATR]NOPAR Where [F:ATR]ACTION=ACT
   If [F:ACT]TYPACT=1 | [F:ATR]NOPAR<>1
    PAR = [F:ATR]CODPAR
    Gosub INC_PAR
   Endif
  Next ATR
  ACT = [F:ACT]ACTSUI
 Wend
Next KK
If [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0
  PAR = [F:AOB]ABREV
  Gosub INC_PAR
  If GPRODUIT=4 : # Loan
   Gosub SETCLE From ="WO"+[F:AOB]ABREV
   If dim(CLESEC)>1 & CLESEC(1)<>""
    For KK=1 To dim(CLESEC)-1
     PAR = [F:AOB]ABREV+num$(KK)
     Gosub INC_PAR
    Next KK
   Endif
  Endif
 Endif
Endif
If [F:ATY]PARTAB<>""
 PAR = [F:ATY]PARTAB
 Gosub INC_PAR
Endif
Return

$CONTTAB
CONTYP = 3
If [M:AMK2]CODCTL(I)<>""
 Read [ACL]ACL0 = [M:AMK2]CODCTL(I)
 If !fstat & ([F:ACL]DEPCTL<>"" | [F:ACL]DEPCTL2<>"" | [F:ACL]DEPCTL3<>"")
  PAR = "TABCONT"
  Gosub INC_PAR
 Endif
Endif
Return

$INC_PAR
If PLEIN : Return : Endif
Raz MESSA
K = find(ZON+PAR,COD(0..J-1))
If !K
 J += 1
 If J>dim(COD)-1
  MESSA = mess(148,123,1) : # Contrôle impossible, trop de paramètres
  PLEIN = 1
 Else
  COD(J-1) = ZON+PAR
  Read [AMP]CODPAR = 1;AFF;ZON;PAR
  If fstat | [F:AMP]VALPAR=""
   MESSA  = mess(149,123,1)-ZON+":" : # Champs
   MESSA -= mess(171,133,1)-PAR : # Paramètre non renseigné
   Case CONTYP
    When 1 : MESSA -= "("-mess(59,100,1)-[M:AMK2]CODTYP(I)+")" : # Type
    When 2 : MESSA -= "("-mess(111,133,1)-[M:AMK2]CODCTL(I)+")" : # Table de contrôle
   Endcase
   If OK=1 : OK = 0 : Endif
  Endif
 Endif
 If MESSA<>"" :  Call ECR_TRACE(MESSA,1) From GESECRAN : Endif
Endif
Return

### Détection des paramètres utilisés simultanément dans le type de donnée ET les actions sur champ
Raz MESSA
K = find(ZON+PAR,CCC(0..III-1))
If !K
 III += 1
 If III>dim(CCC)-1
  MESSA = mess(148,123,1) : # Contrôle impossible, trop de paramètres
  PLEIN = 1
 Else
  CCC(III-1) = ZON+PAR
  PPP(III-1) = CONTYP
 Endif
Elsif CONTYP & !PPP(K-1)
 MESSA  = mess(149,123,1)+"/"+mess(21,115,1)-ZON+"/"+[M:AMK2]CODTYP(I)+":" : # Champs/type de données
 MESSA -= PAR-mess(144,126,1) : # Paramètre utilisé dans les actions
Endif
If MESSA<>"" :  Call ECR_TRACE(MESSA,0) From GESECRAN : Endif
Return

$TR_ANNUPAR
GOK=1
Trbegin [AMP]
 Delete [AMP] Where TYPAFF=[F:AP2]TYPAFF & CODAFF=[F:AP2]CODAFF
&                 & CODZON=[F:AP2]CODZON & CODPAR=[F:AP2]CODPAR
 If fstat = 1
  GOK = -1 : GLOCK = "$AMSKPAR"-[F:AP2]TYPAFF-[F:AP2]CODAFF-[F:AP2]CODZON
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_ANNUPAR : Endif
 Endif
Commit
Return

#-----------------------------------------------------------#
Subprog VERIF_ACT_ATB(AFF)
Value Char    AFF
Local Integer TYP
TYP = 2
Call DEBTRANS From GLOCK
Gosub TR_VERFACT_ATB
End

$TR_VERFACT_ATB
GOK = 1
Trbegin [AMP]
 Gosub VERFACT_ATB
 If GOK=0
  Rollback : Return
 Elsif GOK<1
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_VERFACT_ATB: Endif
 Endif
Commit
Return

$VERFACT_ATB
Filter [AP2] Where TYPAFF=2 & CODAFF=AFF
For [AP2]CODPAR(3)
 Look [ATZ]CODZONE = AFF ; [F:AP2]CODZON
 If fstat
  Delete [AMP] Where TYPAFF=2 & CODAFF=AFF & CODZON=[F:AP2]CODZON
  If fstat = 1
   GOK = -1 : GLOCK = "$AMSKPAR"-AFF-[F:AP2]CODZON : Break
  Endif
 Endif
Next
Filter [AP2]
Return

#-----------------------------------------------------------#
Subprog VERIF_ACT(AFF)
Value Char    AFF
Local Integer TYP
TYP = 1
Call DEBTRANS From GLOCK
Gosub TR_VERFACT
End

$TR_VERFACT
GOK = 1
Trbegin [AMA], [AMP]
 Gosub VERFACT
 If GOK=0
  Rollback : Return
 Elsif GOK<1
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_VERFACT : Endif
 Endif
Commit
Return

$VERFACT
Filter [AM2] Where TYPAFF=1 & CODAFF=AFF
For [AM2]TYPAFF(3)
 Look [AMZ]CODE = AFF ; [F:AM2]CODZON
 If fstat
  Delete [AMA] Where TYPAFF=1 & CODAFF=AFF & CODZON=[F:AM2]CODZON
  If fstat = 1
   GOK = -1 : GLOCK = "$AMSKACT"-AFF-[F:AM2]CODZON : Break
  Endif
 Endif
Next
Filter [AM2]
If GOK<1 : Return : Endif

Filter [AP2] Where TYPAFF=1 & CODAFF=AFF
For [AP2]CODPAR(3)
 Look [AMZ]CODE = AFF ; [F:AP2]CODZON
 If fstat
  Delete [AMP] Where TYPAFF=1 & CODAFF=AFF & CODZON=[F:AP2]CODZON
  If fstat = 1
   GOK = -1 : GLOCK = "$AMSKPAR"-AFF-[F:AP2]CODZON : Break
  Endif
 Endif
Next
Filter [AP2]
Return
#-----------------------------------------------------------#

$SETSEP
Local Char SEP(3)
SEP = ", "
Return

#-----------------------------------------------------------#
Subprog DUPLI_PAR(ORG,DEST)
Value Char    ORG
Value Char    DEST
Local Integer TYP
TYP = 2
Call DEBTRANS From GLOCK
Gosub TR_DUPLIPAR
End

$TR_DUPLIPAR
GOK = 1
Trbegin  [AMP]
 Gosub DUPLIPAR
 If GOK=0
  Rollback : Return
 Elsif GOK<1
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_DUPLIPAR : Endif
 Endif
Commit
Return

$DUPLIPAR
For [AP2]CODPAR Where TYPAFF=2 & CODAFF=ORG
 Look [AMP]CODPAR = 2;DEST;[F:AP2]CODZON;[F:AP2]CODPAR
 If fstat
  [F:AMP] = [F:AP2]
  [F:AMP]CODAFF = DEST
  Write [AMP]
  If fstat : GOK = 0 : Call FSTA("AMP") From GLOCK : Break : Endif
 Endif
Next
Return

#-----------------------------------------------------------#
Subprog DUPLI_ACT(ORG,DEST)
Value Char    ORG
Value Char    DEST
Local Integer TYP
TYP = 1
Call DEBTRANS From GLOCK
Gosub TR_DUPLIACT
End

$TR_DUPLIACT
GOK = 1
Trbegin [AMA], [AMP]
 Gosub DUPLIACT
 If GOK=0
  Rollback : Return
 Elsif GOK<1
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_DUPLIACT : Endif
 Endif
Commit
Return

$DUPLIACT
For [AM2]TYPAFF Where TYPAFF=1 & CODAFF=ORG
 Look [AMA]TYPAFF = 1;DEST;[F:AM2]CODZON;[F:AM2]TYPACT;[F:AM2]NOACT
 If fstat
  [F:AMA] = [F:AM2]
  [F:AMA]CODAFF = DEST
  Write [AMA]
  If fstat : GOK = 0 : Call FSTA("AMA") From GLOCK : Break : Endif
 Endif
Next
If GOK<1 : Return : Endif
For [AP2]CODPAR Where TYPAFF=1 & CODAFF=ORG
 Look [AMP]CODPAR = 1;DEST;[F:AP2]CODZON;[F:AP2]CODPAR
 If fstat
  [F:AMP] = [F:AP2]
  [F:AMP]CODAFF = DEST
  Write [AMP]
  If fstat : GOK = 0 : Call FSTA("AMP") From GLOCK : Break : Endif
 Endif
Next
Return

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

#-----------------------------------------------------------#
Subprog CHARGE_PAR(TYP,AFF,ZON,COD)
Value Integer TYP : # 1=écran, 2=table
Value Char    AFF : # Code écran/table
Value Char    ZON : # Code zone
Value Char    COD : # Code type
If !find([L]TYP,1,2) | [L]AFF="" | [L]ZON="" | [L]COD="" : End : Endif
Local Integer J
Raz [DIA2]
Gosub SETSEP
Call LECTURE("ATY",COD,"") From CONTOBJ
If [F:ATY]OBJLIEN=""
 Gosub CHARGE_PARTYP
Else
 Gosub CHARGE_PARTYP
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0
  Gosub CHARGE_PAROBJ
 Endif
Endif
[M]NBPAR=J
End

$CHARGE_PARTYP
If [F:ATY]PARTAB<>""
 If !find([F:ATY]PARTAB,[M]CODPAR(0..J-1))
  J += 1
  Read [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[F:ATY]PARTAB
  If fstat
   Call MAJPAR_VIDE([L]TYP,[L]AFF,[L]ZON,[F:ATY]PARTAB)
  Endif
  [M]VALPAR(J-1) = [F:AMP]VALPAR
  [M]CODPAR(J-1) = [F:ATY]PARTAB
  Read [AAR]CODPAR = [F:ATY]PARTAB
  Call TEXTE([F:AAR]INTITPAR,[M]INFO(J-1)) From OBJDIV
 Endif
Endif

For KK=1 To [F:ATY]NBTYP
 ACT = [F:ATY]ACTION(KK-1)
 While ACT<>""
  Call LECTURE("ACT",ACT,"") From CONTOBJ
  For [ATR]NOPAR Where [F:ATR]ACTION=ACT
   If [F:ACT]TYPACT=1 | [F:ATR]NOPAR<>1
    If !find([F:ATR]CODPAR,[M]CODPAR(0..J-1))
     J += 1
     Read [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[F:ATR]CODPAR
     If !fstat
      [M]VALPAR(J-1) = [F:AMP]VALPAR
     Elsif [F:ATR]ADRVAL=2 : # Par valeur
      Call MAJPAR_VIDE([L]TYP,[L]AFF,[L]ZON,[F:ATR]CODPAR)
      [M]VALPAR(J-1) = [F:AMP]VALPAR
     Endif
     [M]CODPAR(J-1)  = [F:ATR]CODPAR
     Call TEXTE([F:ATR]INTITPAR,[M]INFO(J-1)) From OBJDIV
     [M]INFO(J-1)    += SEP + mess([F:ATR]TYPPAR,33,1)
     [M]INFO(J-1)    += SEP + mess([F:ATR]ADRVAL,34,1)
    Endif
   Endif
  Next ATR
  ACT = [F:ACT]ACTSUI
 Wend
Next KK
Return

$CHARGE_PAROBJ
If !find([F:AOB]ABREV,[M]CODPAR(0..J-1))
 J += 1
 Read [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[F:AOB]ABREV
 If fstat
  Call MAJPAR_VIDE([L]TYP,[L]AFF,[L]ZON,[F:AOB]ABREV)
 Endif
 [M]VALPAR(J-1) = [F:AMP]VALPAR
 [M]CODPAR(J-1) = [F:AOB]ABREV
 Call TEXTE([F:AOB]LIBPAR,[M]INFO(J-1)) From OBJDIV
 [M]INFO(J-1)    += SEP + mess(1,33,1) : # Char
 [M]INFO(J-1)    += SEP + mess(2,34,1) : # Par valeur
Endif
If GPRODUIT=4 : # LOAN
 Gosub SETCLE From ="WO"+[F:AOB]ABREV
 If dim(CLESEC)>1 & CLESEC(1)<>""
  For KK=1 To dim(CLESEC)-1
   J += 1
   Read [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[F:AOB]ABREV+num$(KK)
   If fstat
    Call MAJPAR_VIDE([L]TYP,[L]AFF,[L]ZON,[F:AOB]ABREV+num$(KK))
   Endif
   [M]VALPAR(J-1) = [F:AMP]VALPAR
   [M]CODPAR(J-1) = [F:AOB]ABREV+num$(KK)
   Read [ATZ]CODZONE = [F:AOB]NOMFIC;CLESEC(KK)
   If !fstat
    Call TEXTE([F:ATZ]NOCOURT,[M]INFO(J-1)) From OBJDIV
   Else
    [M]INFO(J-1)    = CLESEC(KK)
   Endif
   [M]INFO(J-1)    += SEP + mess(1,33,1) : # Char
   [M]INFO(J-1)    += SEP + mess(2,34,1) : # Par valeur
  Next KK
 Endif
Endif
Return

#-----------------------------------------------------------#
Subprog VALID_PAR(TYP,AFF,ZON)
Value Integer TYP : # 1=écran, 2=table
Value Char    AFF : # Ecran/table
Value Char    ZON : # Zone
If !find([L]TYP,1,2) | [L]AFF="" | [L]ZON="" : End : Endif
Call DEBTRANS From GLOCK
Gosub TR_PAR
If GOK<1 : mkstat = 1 : End : Endif
End

$TR_PAR
GOK = 1
Trbegin [AMP]
 Gosub MAJ_PAR
 If GOK<1 : Rollback : Return : Endif
Commit
Return

$MAJ_PAR
For nolign=1 To [M]NBPAR
 Read [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[M]CODPAR(nolign-1)
 If fstat
  Raz [F:AMP]
  [F:AMP] = [M]
  [F:AMP]TYPAFF = [L]TYP
  [F:AMP]CODAFF = [L]AFF
  [F:AMP]CODZON = [L]ZON
  Write [AMP]
  If fstat : GOK = 0 : Call FSTA("AMP") From GLOCK : Break : Endif
 Else
  [F:AMP] = [M]
  [F:AMP]TYPAFF = [L]TYP
  [F:AMP]CODAFF = [L]AFF
  [F:AMP]CODZON = [L]ZON
  Rewrite [AMP]
  If fstat : GOK = 0 : Call FSTA("AMP") From GLOCK : Break : Endif
 Endif
Next nolign
Return

#-----------------------------------------------------------#
Subprog MAJPAR_VIDE(TYP,AFF,ZON,COD)
Value Integer TYP
Value Char    AFF
Value Char    ZON
Value Char    COD
If !adxlog
 Gosub TR_VIDE
Else
 Gosub MAJ_VIDE
Endif
End

$TR_VIDE
GOK=1
Trbegin [AMP]
 Gosub MAJ_VIDE
 If GOK=0 : Goto AB_VIDE : Endif
Commit
Return

$AB_VIDE
Rollback
Return

$MAJ_VIDE
Read [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[L]COD
If fstat
 Raz [F:AMP]
 [F:AMP]TYPAFF = [L]TYP
 [F:AMP]CODAFF = [L]AFF
 [F:AMP]CODZON = [L]ZON
 [F:AMP]CODPAR = [L]COD
 [F:AMP]VALPAR = '""'
 Write [AMP]
 If fstat : GOK = 0 : Call FSTA("AMP") From GLOCK : Endif
Endif
Return

#-----------------------------------------------------------#
Subprog ANNULE_PAR(TYP,AFF,ZON,COD)
Value Integer TYP
Value Char    AFF
Value Char    ZON
Value Char    COD
If !adxlog
 Gosub TR_ANUPAR
Else
 Gosub ANUPAR
Endif
End

$TR_ANUPAR
GOK=1
Trbegin [AMP]
 Gosub ANUPAR
 If GOK=0 : Goto AB_ANUPAR : Endif
Commit
Return

$AB_ANUPAR
Rollback
Return

$ANUPAR
Readlock [AMP]CODPAR = [L]TYP;[L]AFF;[L]ZON;[L]COD
If !fstat
 [F:AMP]VALPAR = '""'
 Rewrite [AMP]
 If fstat : GOK = 0 : Call FSTA("AMP") From GLOCK : Endif
Endif
Return

