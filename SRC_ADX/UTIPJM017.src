#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIPJM017 Update PJMTSKITM.CUR...
#
# Issue X3-26714 - 2017-04-07 by ALMON/FGR
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM017(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM017(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE

  #-----------------------------------#
  If filinfo(filpath("FIL","PJMTSKITM","fde",DOSSIER),0)<=0 : End : Endif
  If filinfo(filpath("FIL","OPPOR","fde",DOSSIER),0)<=0 : End : Endif
  #-----------------------------------#
  Call ECR_TRACE("UTIPJM017: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:PTKO]) = 0 : Local File =DOSSIER + ".PJMTSKITM"  [JTT] : Endif
  If clalev([F:OPP]) = 0  : Local File =DOSSIER + ".OPPOR"      [OPP] : Endif
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [JTT]
  Filter [JTT] Where [F:JTT]CUR = ""
  For [JTT]
    IUPDATE = 0
    If [F:JTT]CUR = "" Then
      Read [OPP]OPP0=[F:JTT]OPPNUM
      If !fstat Then
        [F:JTT]CUR = [F:OPP]CUR
        IUPDATE = 1
      Endif
    Endif
    # -----------------
    If IUPDATE = 1 Then
      COMPTEUR += 1
      Rewrite [JTT]
      If fstat Then
        Call ECR_TRACE("File PJMTSKITM" - [F:JTT]OPPNUM - [F:JTT]TASCOD - num$([F:JTT]ITTSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
      # -----------------
    Endif
  Next
  Filter [JTT]
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM017 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM017 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [JTT]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTSKITM") : End : Endif
  Call MAJ_UTIPJM017(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTSKITM") : End : Endif
  Call MAJ_UTIPJM017(APPLI)
End

