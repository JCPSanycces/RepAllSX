#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
## SData - Version 0005_S
#    Gestion table de synchronisation AJSSYNC 
#    (voir exemple AREQUETE)
#
#  Action AJS         --> GSaisie - Affichage infos table de synchronisation (basé sur AREQUETE)
#  Action AJSSELRES   --> GAction selection table - Liste ressources endpoint courant (basé sur CALCULETTE)
#
#  Remarques AJSSYNC - Table de synchro
#    LININF A ou AC:  Infos alias/endpoint
#           AD        Infos table d'audit SData
#           E ou EC:  Infos collection d'une ressource
#           R         Infos pour une ressource
#
#
######################################################################################

Raz GNBMASKOUV
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"AJS","AJSSYNC","") From GSAISIE
End 
 
#---------------------------------------------------#
$ACTION
#Infbox ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
 When "FIN"         : Inftxt "" At 2
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_TABLE"  : Gosub VERF_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

#--------------------------------------------------#
$OUVRE
Local File    AJSSYNC [AJS]

Local Char DBGHST(50)
Local Integer DBGPRT
#DBGHST="172.28.9.11" # @ip du pc
#DBGHST = "ecjullienc.sagefr.adinternal.com"   # dns
#DBGPRT=1789

Local Integer   A_ERRLEV              # Message: niveau erreur
Local Char      A_ERRID(20)           # Message: identifiant
Local Char      A_ERRMES(200)         # Message 

Local Mask      AJS0 [A0_S]
Local Mask      AJS1 [A1_S]

Return

#--------------------------------------------------#
$DEBUT
# Appel ss-prgrm 
Local Char         A_ACT(2)          #  Action 
Local Char         A_ALS(3)          #  Alias du serveur 
Local Char         A_URL(250)        #  
Local Shortint     A_PRT             # Priorité
#
Local Integer      A_NBALSEDP : A_NBALSEDP=dim([AJS1]ALS)+1
Local Char         AN_ALS(3)(1..A_NBALSEDP)            #  Alias du serveur 
Local Char         AN_URL(250)(1..A_NBALSEDP)    
Local Shortint     AN_PRT(1..A_NBALSEDP)    


# -- Endpoints
Call AJS_ALSEDPLST(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, AN_ALS, AN_URL, AN_PRT) From AJSSYNCA
If A_ERRLEV Then
    Call ERREUR(A_ERRMES-"("-A_ERRID-")") From GESECRAN
Else 
    Raz [AJS0],[AJS1],[AJS2]
    For WI=1 To A_NBALSEDP
        If AN_ALS(WI)="" : Break : Endif
        If AN_ALS(WI)="CUR"
            [AJS0]ALS       =AN_ALS(WI)
            [AJS0]PRIORITY  =AN_PRT(WI)
            [AJS0]URL       =AN_URL(WI)
        Else
            [AJS1]ALS([AJS1]NBENDP)       =AN_ALS(WI)
            [AJS1]PRIORITY([AJS1]NBENDP)  =AN_PRT(WI)
            [AJS1]URL([AJS1]NBENDP)       =AN_URL(WI)
            [AJS1]NBENDP    +=1
        Endif
    Next
Endif

#-- Numero sequence
Local Decimal A_SEQ
Call AJS_AUDINF(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, "R", A_SEQ) From AJSSYNCA
If A_ERRLEV Then
    If A_ERRID <> "AUDINF_115_154"        # Pas d'enreg.
        Call ERREUR(A_ERRMES-"("-A_ERRID-")") From GESECRAN
    Endif
Else 
    [AJS1]SEQ=A_SEQ
Endif

[A0_S]=[AJS0]
[A1_S]=[AJS1]
Affzo [AJS0]
Affzo [AJS1]
#Diszo [AJS1]NBENDP
Return

#--------------------------------------------------#
$APRES_MODIF
If maskcou="AJS0"
    REP="M" 
Elsif maskcou="AJS1"
    If COUZON<>"NBENDP"
        REP="M" 
    Endif
REP="M" 

Endif
Return

#--------------------------------------------------#
$SETBOUT
Return

#--------------------------------------------------#
$ABA
Raz [A0_S],[AJS0],[A1_S],[AJS1]
Gosub DEBUT
REP=""
Return

#--------------------------------------------------#
$ENR
# mask AJS0
Local Integer WFLG_AJS0
For WRUB="PRIORITY","URL"
    WFLG_AJS0 += evalue("[AJS0]"+WRUB+"<>[A0_S]"+WRUB) 
Next
If WFLG_AJS0
    If [A0_S]ALS<>"CUR" : A_ACT="C" : Else : A_ACT="U" : Endif
    A_ALS="CUR" : A_PRT=[AJS0]PRIORITY  # Chps num de type DCB...
    Call AJS_ALSEDP(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, A_ACT,  A_ALS, [AJS0]URL, A_PRT) From AJSSYNCA
    If A_ERRLEV : Call MESSAGE(A_ERRMES) From GESECRAN : Endif
Endif

# mask AJS1
Local Integer WFLG_AJS1
For WRUB="SEQ"
    WFLG_AJS1 += evalue("[AJS1]"+WRUB+"<>[A1_S]"+WRUB) 
Next
If WFLG_AJS1
    A_ACT="CU"
    Call AJS_AUDINF(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, A_ACT, [AJS1]SEQ) From AJSSYNCA
    If A_ERRLEV : Call MESSAGE(A_ERRMES) From GESECRAN : Endif
Endif

For WNL=0 To [AJS1]NBENDP-1
    A_ALS        =[AJS1]ALS(WNL)
    A_PRT        =[AJS1]PRIORITY(WNL)
    A_URL        =[AJS1]URL(WNL)
    WI=find([AJS1]ALS(WNL),[A1_S]ALS)
    If WI        # Modification
        A_ACT="U"
        WFLG_AJS1=0
        For WRUB="ALS","PRIORITY","URL"
            WFLG_AJS1 += evalue("[AJS1]"+WRUB+"(WNL)<>[A1_S]"+WRUB+"(WI-1)") 
        Next
    Else         # Creation
        A_ACT="C"
        WFLG_AJS1=1
    Endif
    If WFLG_AJS1
        Call AJS_ALSEDP(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, A_ACT,  A_ALS, A_URL, A_PRT) From AJSSYNCA
        If A_ERRLEV : Call MESSAGE(A_ERRMES) From GESECRAN : Endif
    Endif
Next

For WNL=0 To [A1_S]NBENDP-1
    WI=find([A1_S]ALS(WNL),[AJS1]ALS)
    If WI=0        # Suppression
        A_ACT="D"
        A_ALS        =[A1_S]ALS(WNL)
        Call AJS_ALSEDP(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, A_ACT,  A_ALS, A_URL, A_PRT) From AJSSYNCA
        If A_ERRLEV : Call MESSAGE(A_ERRMES) From GESECRAN : Endif
    Endif
Next


# Affichage
Gosub DEBUT
REP=""
Return

#
#
#--------------------------------------------------#
$SEL_TABLE
Case GACTION
When "AJSSELREST"
    If clalev([F:AJS])=0 : Local File AJSSYNC [AJS]  : Endif
    Default File [AJS]
    TIT(0) =  mess(52,143,1)  # Ressource SData
    NBCOL  = 0
    NBCOL += 1 : COL(NBCOL) = 'RESNAM' : TIT(NBCOL) =  mess(38,100,1)  # Nom
    CRITERE = 'LININF = "EC"'

When "AJSSELRES"
    # Param(1) - Nom de la ressource - Ex: TradingAccount
    If Param(1)<>""
        If clalev([F:AJS])=0 : Local File AJSSYNC [AJS]  : Endif
        Default File [AJS]
        TIT(0) = mess(52,143,1)-Param(1)  # Ressource SData
        NBCOL  = 0
        NBCOL += 1 : COL(NBCOL) = 'CLE' : TIT(NBCOL) = mess(55,123,1)  # Clé
        CRITERE = 'LININF = "R" and RESNAM ="'+toupper(PARAM(1))+'"'
    Else
        OK=0
    Endif
Endcase
#ORDRE = "LININF,RESNAM"
#Dbgaff
#START=""
Return

#--------------------------------------------------#
$VERF_TABLE
Return


#--------------------------------------------------#
$SEL_LISTE
Case LISTE
  When "AJSSELENDP" : Gosub SEL_ENDP
Endcase
Return

$SEL_ENDP
Local Integer   A_ERRLEV            # Message: niveau erreur
Local Char      A_ERRID             # Message: identifiant
Local Char      A_ERRMES            # Message 

Local Integer      A_NB : A_NB=10
Local Char         A_ALS(10)(1..A_NB)          #  Alias du serveur (CUR = courant)
Local Char         A_URL(250)(1..A_NB)    
Local Shortint     A_PRT(1..A_NB)    

Call AJS_ALSEDPLST("", 0, 0, A_ERRLEV, A_ERRID, A_ERRMES, A_ALS, A_URL, A_PRT) From AJSSYNCA

Local Char TEXTE(150)(1..A_NB,0..1)
TIT=mess(57,143,1)
TIT(1)=mess(46,9005,1)
TIT(2)=mess(146,151,2)
For WI=1 To A_NB
    If A_ALS(WI)="" : Break : Endif
    NBTEX+=1
    TEX(NBTEX)=A_ALS(WI)
    TEXTE(NBTEX,1)=A_URL(NBTEX)
    TEXTE(NBTEX,0)=A_ALS(WI)
Next
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran AJS2) 08/06/2010 17:41:58 (JPJ)
######################################################################################
Subprog AM_RESNAM(VALEUR)
Variable Char    VALEUR()

If vireblc(VALEUR,2)<>""
    Local Char DBGHST(50)
    Local Integer DBGPRT
    #DBGHST="172.28.9.11" # @ip du pc
    #DBGHST = "ecjullienc.sagefr.adinternal.com"   # dns
    #DBGPRT=1789
    
    Local Integer   A_ERRLEV              # Message: niveau erreur
    Local Char      A_ERRID(20)           # Message: identifiant
    Local Char      A_ERRMES(200)         # Message 

    Local Decimal   A_TCK
    Local Char      A_TIMSTP(15)

    [AJS2]NBLIG =0
   
    Call AJS_COLINF(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, "R", [AJS0]ALS, VALEUR, A_TCK, A_TIMSTP)  From AJSSYNCA
    If A_ERRLEV = 0
        [AJS2]ALS([AJS2]NBLIG)    = [AJS0]ALS
        [AJS2]TCK([AJS2]NBLIG)    = A_TCK
        [AJS2]NBLIG  +=1
    Endif
    For WI=0 To [AJS1]NBENDP-1    
        Call AJS_COLINF(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, "R", [AJS1]ALS(WI), VALEUR, A_TCK, A_TIMSTP)  From AJSSYNCA
        If A_ERRLEV = 0
            [AJS2]ALS([AJS2]NBLIG)    = [AJS1]ALS(WI)
            [AJS2]TCK([AJS2]NBLIG)    = A_TCK
            [AJS2]NBLIG  +=1
        Endif
    Next
    Affzo [AJS2]10
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AJS2) 09/06/2010 08:40:53 (JPJ)
######################################################################################
Subprog AM_RESUUID(VALEUR)
Variable Char    VALEUR()
Gosub RESINF_VAR
AN_KEYFLG(1) ="U"
AN_RESUUID(1)=VALEUR
Gosub RESINF_GET
If AN_ERRLEV<>0
    Effzo [AJS2]RESCLE
Endif
Affzo [AJS2]15
# Nom de la ressource
If AN_RESNAM(1) <> [AJS2]RESNAM
    [AJS2]RESNAM = AN_RESNAM(1)
    Affzo [AJS2]RESNAM
    Call AM_RESNAM([AJS2]RESNAM)
Endif
End

$RESINF_VAR
    Local Char DBGHST(50)
    Local Integer DBGPRT

    Local Integer    NBL : NBL=1
    Local Integer   AN_ERRLEV(1..NBL)            # Message: niveau erreur
    Local Char      AN_ERRID(20)(1..NBL)             # Message: identifiant
    Local Char      AN_ERRMES(200)(1..NBL)            # Message 
    
    # Par ligne
    Local Char      AN_ACT(2)(1..NBL)          #  Action C, U, R, D
    Local Char      AN_KEYFLG(1)(1..NBL)       #  Accès par:  Clé SafeX3=S  -  UUID=U  
    Local Char      AN_RESNAM(30)(1..NBL)       #  Ressource name
    Local Char      AN_KEYERP(150)(1..NBL)       
    Local Char      AN_RESUUID(40)(1..NBL)       
    Local Char      AN_ALS(3)(1..NBL)          #  Alias
    Local Decimal   AN_TCK(1..NBL)               
    Local Char      AN_RESTIMSTP(20)(1..NBL)    
    Local Decimal   AN_SEQ(1..NBL)    
    Local Char      AN_RESCREALS(3)(1..NBL)
    Local Decimal   AN_RESCRETCK(1..NBL)         
    Local Shortint  AN_RESFLGDEL(1..NBL)        
    Local Shortint  AN_RESFLGSYN(1..NBL)        
    Local Decimal   AN_RESCRC(1..NBL)        
    Local Shortint  A_FLGUPD 
Return

$RESINF_GET
    AN_ACT(1)    ="R"
    AN_RESNAM(1) =[AJS2]RESNAM
    Call AJS_RESINF(DBGHST, DBGPRT, 0, AN_ERRLEV, AN_ERRID, AN_ERRMES, AN_ACT, AN_KEYFLG, AN_RESNAM, AN_KEYERP, AN_RESUUID,
&              AN_ALS, AN_TCK, AN_RESTIMSTP, AN_SEQ, AN_RESCREALS, AN_RESCRETCK, AN_RESFLGDEL, AN_RESFLGSYN, AN_RESCRC, A_FLGUPD) From AJSSYNCA
    If AN_ERRLEV(1)=0
        [AJS2]RESCLE    =AN_KEYERP(1)
        [AJS2]RESUUID   =AN_RESUUID(1)
        [AJS2]RESALS    =AN_ALS(1)
        [AJS2]RESTCK    =AN_TCK(1)
        [AJS2]RESFLGDEL =AN_RESFLGDEL(1)
        [AJS2]RESFLGSYN =AN_RESFLGSYN(1)
        [AJS2]RESCRC    =AN_RESCRC(1)
        [AJS2]RESCREALS =AN_RESCREALS(1)
        [AJS2]RESCRETCK =AN_RESCRETCK(1)
        [AJS2]RESTIMSTP =AN_RESTIMSTP(1)
        [AJS2]RESSEQ    =AN_SEQ(1)
        [AJS2]RESMSG    =""
    Else
        Effzo [AJS2]RESALS,RESTCK,RESFLGDEL,RESFLGSYN,RESCRC,RESCREALS, RESCRETCK, RESTIMSTP, RESSEQ  
        [AJS2]RESMSG    =AN_ERRMES(1)
    Endif
#Infbox num$([AJS]RESCRC)-num$(AN_RESCRC(1))
Return

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AJS2) 09/06/2010 08:41:53 (JPJ)
######################################################################################
Subprog AM_RESCLE(VALEUR)
Variable Char    VALEUR()
Gosub RESINF_VAR
AN_KEYFLG(1) ="S"
AN_KEYERP(1)=VALEUR
Gosub RESINF_GET
If AN_ERRLEV<>0
    Effzo [AJS2]RESUUID
Endif
Affzo [AJS2]15
End


######################################################################################

