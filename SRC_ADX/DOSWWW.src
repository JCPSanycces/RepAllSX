Subprog AV_VALDIF(VALEUR)
Variable Integer VALEUR
If func AFNC.PARTSEP(ver$(0),2," ")<="16r.217"
  VALEUR=1
  mkstat=1
Endif
End

Subprog D_VALDIF(VALEUR)
Variable Integer VALEUR
VALEUR=2
If func AFNC.PARTSEP(ver$(0),2," ")<="16r.217"
  VALEUR=1
Endif
End

