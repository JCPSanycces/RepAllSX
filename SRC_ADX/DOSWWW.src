#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DOSWWW","ATRN3",3,"") From GTRAITE
End

#------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "CONTBATCH"  : Gosub CONTBATCH
 When "EXEC"       : Gosub EXEC
Endcase
Return

#------------------------------------------------------#
$INIT
Global Integer GVALTRANS(1..len(mess(0,14,1)))
Global Integer GCRE
Local  Integer OKTRT , TEST
Local  Char    TRTGEN(GLONADC+GLONADS+1)
For I=1 To len(mess(0,14,1))
 GVALTRANS(I) = 2
Next I
GCRE = 1
TMP = 1
TRA = 1
TEST = GSOPHIA
Return

$INIT_DIA
Raz [M:TRN]
For I=1 To len(mess(0,14,1))
 If mess(I,14,1)<>"" & left$(mess(I,14,1),1)<>"#"
  If dim([M:TRN]LIBMOD)>0
   [M:TRN]LIBMOD([M:TRN]NBLIG1) = mess(I,14,1)
  Endif
  [M:TRN]MODULE([M:TRN]NBLIG1) = I
  [M:TRN]SELMOD([M:TRN]NBLIG1) = 2
  [M:TRN]NBLIG1                += 1
 Endif
Next I
[M:TRN]APPLI = nomap
Call CHARGE
Return

Subprog CHARGE
Local Integer I , DIME , WNB
Local Char APPLI(GLONADS)
DIME = dim([M:TRN]COD)
Local Char WCOD(GLONATN)(1..DIME)
Local Shortint WSEL(1..DIME)
WNB = [M:TRN]NBLIG2
For I=1 To WNB
 WCOD(I) = [M:TRN]COD(I-1)
 WSEL(I) = [M:TRN]SEL(I-1)
Next I
APPLI = [M:TRN]APPLI
Local File =APPLI+".ATRANSAC" [ATN2]
Local File =APPLI+".ACTIV"    [ACV]
If clalev([F:ATX])>0 : Close Local File [ATX] : Endif
If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ATEXTRA"  [AXX]
Local File =APPLI+".AWINDOW"  [A_WI]
[M:TRN]NBLIG2 = 0
For [ATN2]ATN0 Where ENAFLG=2
 I = find([F:ATN2]MODULE,[M:TRN]MODULE(0..[M:TRN]NBLIG1-1))
 If I & [M:TRN]SELMOD(I-1)=2
  [M:TRN]COD([M:TRN]NBLIG2) = [F:ATN2]COD
  I = find([F:ATN2]COD,WCOD(1..WNB))
  If I
   [M:TRN]SEL([M:TRN]NBLIG2) = WSEL(I)
  Else
   [M:TRN]SEL([M:TRN]NBLIG2) = 2
  Endif
  [M:TRN]NBLIG2 += 1
 Endif
Next ATN
Close Local File
End

$CONTBATCH
$CONTROLE
Local Char APPLI(GLONADS)
APPLI = [M:TRN]APPLI
Local File =APPLI+".ATRANSAC" [ATN2]
Local File =APPLI+".ACTIV"    [ACV]
If clalev([F:ATX])>0 : Close Local File [ATX] : Endif
If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ATEXTRA"  [AXX]
Local File =APPLI+".AWINDOW"  [A_WI]
Return

#------------------------------------------------------#
$EXEC
If GSTATUT=GSTAOK
 If !GSERVEUR
  Call OUVRE_TRACE(mess(69,133,1)-APPLI) From LECFIC : # Validation des transactions
 Endif
 If TEST
  Call ECR_TRACE("*****"-mess(194,124,1)-APPLI-"*****",0) From GESECRAN : # Mode test
  Call ECR_TRACE("Open files:"-sigma(0,[S]dbglong(11),string$(filelev(indcum+1)<>0,[S]fileabre(indcum+1)+",")),0) From GESECRAN
 Endif

Local Integer SAVGVALID : SAVGVALID =GVALIDDIFF
If dim([M:TRN]VALDIF)>0 
  If [M:TRN]VALDIF=2 and func AFNC.PARTSEP(ver$(0),2," ")>"16r.217"
      GVALIDDIFF = 3     
  Else
      GVALIDDIFF=1
  Endif
Endif

 If GVALIDDIFF=3
  # Validation différée des écrans et fenêtres
  Call ECR_TRACE(mess(251,125,1),0) From GESECRAN
 Endif
 Local Integer IMK,OKMK
 For I=0 To [M:TRN]NBLIG2-1
  If [M:TRN]SEL(I)=2
   Read [ATN2]ATN0 = [M:TRN]COD(I)
   If !fstat & [F:ATN2]ENAFLG=2 & [F:ATN2]CODTRT<>""
    Call EXISTE_ADX("",APPLI,[F:ATN2]CODTRT,OKTRT) From ORDSYS
    If OKTRT
     TRTGEN = APPLI+"."+[F:ATN2]CODTRT
    Else
     Call EXISTE_ADX("","",[F:ATN2]CODTRT,OKTRT) From ORDSYS
     If OKTRT
# Appel de la validation directe des masques modèles si validation différée   -- débrayé le 27/10/2011  CC
     # If GVALIDDIFF=3 and [F:ATN2]OBJ<>""
     #   Read [A_WI]AWI0="O"+[F:ATN2]OBJ
     #   If fstat=0
     #     If [F:A_WI]MSKENT<>""
     #       Call VALIDDIRECT([F:A_WI]MSKENT,APPLI,1,GLANGUE,0,OKMK) From VALMSK
     #     Endif
     #     For IMK=1 To [F:A_WI]NBMSK
     #       Call VALIDDIRECT([F:A_WI]NOMMSK(IMK-1),APPLI,1,GLANGUE,0,OKMK) From VALMSK
     #     Next IMK
     #   Endif
     # Endif
      TRTGEN = [F:ATN2]CODTRT
     Endif
    Endif
    If OKTRT
     Call ECR_TIME(mess(200,125,1)-[F:ATN2]COD-func AFNC.TEXTE([F:ATN2]DES)) From DOSSUB : # Validation transaction
     Call GENDOS(APPLI) From =TRTGEN
     Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
    Endif
   Endif
  Endif
 Next I
 If dim(SAVGVALID)>0
  GVALIDDIFF=SAVGVALID
 Endif
 If !GSERVEUR
  Call FERME_TRACE From LECFIC
 Endif
Endif
Return

#------------------------------------------------------#
Subprog AS_APPLI(VALEUR)
Variable Char    VALEUR()
End

Subprog C_APPLI(VALEUR)
Variable Char    VALEUR()
Local Integer ER
If VALEUR="" : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",VALEUR),0)<0
 Call ERREUR(mess(106,125,1)) From GESECRAN : # Dossier inaccessible
 mkstat = 2 : End
Else
 Onerrgo ERRDOS
 Local File =VALEUR+".ADOVAL" [AD__]
 Read [AD__]ADW0 = "";"";"TYPDOS"
 Onerrgo
 If ER
  Call ERREUR(mess(142,100,1)) From GESECRAN : # Le numéro de version du dossier est incorrect
  mkstat = 2 : End
 Endif
 If !fstat & val([F:AD__]VALEUR)-1<>GPRODUIT
  # Ce dossier existe et n'est pas un dossier du produit courant
  Call ERREUR(VALEUR-":"-mess(197,126,1)) From GESECRAN
  mkstat = 2 : End
 Endif
 Close Local File [AD__]
Endif
End

Subprog AM_APPLI(VALEUR)
Variable Char    VALEUR()
Call CHARGE
Affzo 25
End

$ERRDOS
ER = errn
Resume

Subprog B2_NBLIG1
Local Integer I
For I=nolign To [M]NBLIG1
 [M]SELMOD(I-1) = 2
Next I
Affzo 20
Call CHARGE
Affzo 25
End

Subprog B3_NBLIG1
Local Integer I
For I=nolign To [M]NBLIG1
 [M]SELMOD(I-1) = 1
Next I
Affzo 20
Call CHARGE
Affzo 25
End

Subprog C_NBLIG1
If adxgtb=2
 Call CHARGE
 Affzo 25
Endif
End

Subprog B2_NBLIG2
Local Integer I
For I=nolign  To [M]NBLIG2
 [M]SEL(I-1) = 2
Next I
Affzo 25
End

Subprog B3_NBLIG2
Local Integer I
For I=nolign To [M]NBLIG2
 [M]SEL(I-1) = 1
Next I
Affzo 25
End


