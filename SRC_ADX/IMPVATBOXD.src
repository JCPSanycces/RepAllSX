#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
 When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 When "AP_IMPORT"     : Gosub AP_IMPORT
Endcase
Return

$IMP_OUVRE
If clalev([F:VTB])=0  : Local File VATBOX     [VTB]  : Endif
If clalev([F:TVT])=0  : Local File TABVAT     [TVT]  : Endif
If clalev([F:VTD1])=0 : Local File VATBOXD    [VTD1] : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
Return

$IMP_VERIF_CRE
GCLE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-num$([F:VTD]FLGVAT)-num$([F:VTD]VATIPT)-[F:VTD]VAT-[F:VTD]VCRTYP
& -format$("DD2",[F:VTD]VLYSTR)-format$("DD2",[F:VTD]VLYEND)
# Check the fields imported
Call LEC_VTB([F:VTD]VATFNC,[F:VTD]LEG,[F:VTD]VATBOX) From CPTLEC

# "VATBOX"
If fstat | ([F:VTB]TYPBOX<>2 & [F:VTB]TYPBOX<>4)
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(83,123,1)
 OK = 0 : Return
Endif

# "FLGVAT, "VATIPT", "VCRTYP", "SNS", "VLYSTR", "VLYEND"
If [F:VTB]TYPBOX=4
 Raz [F:VTD]FLGVAT
 Raz [F:VTD]VATIPT
 Raz [F:VTD]VCRTYP
 [F:VTD]SNS = 0
 Raz [F:VTD]VLYSTR
 Raz [F:VTD]VLYEND
Endif

# "FLGVAT"
If [F:VTD]FLGVAT=1
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(35,121,1)-mess(83,123,1)
 OK = 0 : Return
Endif

# "VAT"
If [F:VTD]VAT=""
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(840,197,1)-mess(10,123,1)
 OK = 0 : Return
Endif
Call CONTTVT([F:VTD]VAT,[F:VTD]LEG,"VATBOX2","VAT","","","") From SUBTVT
If mkstat
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(840,197,1)-GMESSAGE
 Raz mkstat
 OK = 0 : Return
Endif

If [F:VTD]VATFNC="DCLVATBEL"
 If [F:VTB]TYPBOX=2
  If [F:TVT]VATTYP<>1
   GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(840,197,1)-[F:VTD]VAT-mess(11,119,1)
   OK = 0 : Return
  Endif
  If [F:TVT]VATPAY<>1
   GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(840,197,1)-[F:VTD]VAT-mess(398,107,1)
   OK = 0 : Return
  Endif
 Endif
Endif

# "VCRTYP"
If [F:VTD]VCRTYP<>""
 Call CONTGTE([F:VTD]VCRTYP,[F:VTD]LEG,"") From SUBGTE
 If mkstat
  GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-GMESSAGE
  Raz mkstat
  OK = 0 : Return
 Endif
 If [F:TVT]VATPAY = 1
  If [F:GTE]VAT<>2
   GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(399,107,1)
   OK = 0 : Return
  Endif
 Endif
Endif

# "SNS"
If [F:VTB]TYPBOX<>4 & [F:VTD]SNS<>1 & [F:VTD]SNS<>-1
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-mess(35,105,1)-num$([F:VTD]SNS)-mess(83,123,1)
 OK = 0 : Return
Endif

# "VLYEND"
If [F:VTD]VLYEND<>[0/0/0] & [F:VTD]VLYEND<=[F:VTD]VLYSTR
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-num$([F:VTD]VLYEND)-mess(1,104,1)
 OK = 0 : Return
Endif

Filter [F:VTD1] Where VATFNC=[F:VTD]VATFNC & VATBOX=[F:VTD]VATBOX & LEG=[F:VTD]LEG & FLGVAT=[F:VTD]FLGVAT
& & VATIPT=[F:VTD]VATIPT & VAT=[F:VTD]VAT & VCRTYP=[F:VTD]VCRTYP & VLYSTR=[F:VTD]VLYSTR & VLYEND=[F:VTD]VLYEND
Read [VTD1] First
Filter [VTD1]
If !fstat
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-":"-mess(365,107,1)
 OK =0 : Return
Endif

Return


$IMP_VERIF_MOD
GCLE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-num$([F:VTD]FLGVAT)-num$([F:VTD]VATIPT)-[F:VTD]VAT-[F:VTD]VCRTYP
& -format$("DD2",[F:VTD]VLYSTR)-format$("DD2",[F:VTD]VLYEND)

Filter [F:VTD1] Where VATFNC=[F:VTD]VATFNC & VATBOX=[F:VTD]VATBOX & LEG=[F:VTD]LEG & FLGVAT=[F:VTD]FLGVAT
& & VATIPT=[F:VTD]VATIPT & VAT=[F:VTD]VAT & VCRTYP=[F:VTD]VCRTYP & VLYSTR=[F:VTD]VLYSTR & VLYEND=[F:VTD]VLYEND
Read [VTD1] First
Filter [VTD1]
If !fstat
 GMESSAGE = [F:VTD]VATFNC-[F:VTD]LEG-[F:VTD]VATBOX-":"-mess(365,107,1)
 OK =0 : Return
Endif

Return


$AP_IMPORT
# Deletion of all the detail when the first record is imported
If NBENR=1
Trbegin [VTD1]
 Delete [VTD1] Where VATFNC=[F:VTD]VATFNC & LEG=[F:VTD]LEG
Commit
Endif
# The LIN matches with the line of the vatbox in the VATBOX table
Call LEC_VTB([F:VTD]VATFNC,[F:VTD]LEG,[F:VTD]VATBOX) From CPTLEC
If ! fstat
 [F:VTD]LIN = [F:VTB]LIN
Endif
Return

