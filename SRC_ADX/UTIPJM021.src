#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM021
# Issue X3-33150 - 2017-06-21 by SINGC
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM021(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM021(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE

  Call ECR_TRACE("UTIPJM021: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:PJMRPT]) = 0 : Local File =DOSSIER + ".PJMFINOVRRPT"  [PJMRPT] : Endif
  If clalev([F:PJMCTO]) = 0 : Local File =DOSSIER + ".PJMFINCTORPT"  [PJMCTO] : Endif
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [PJMRPT]
  Filter [PJMRPT] Where [F:PJMRPT]KEYEXT = ""
  For [PJMRPT]
    IUPDATE = 0
    [F:PJMRPT]KEYEXT = "PJMRPTEXT"
    Rewrite [PJMRPT]
    COMPTEUR += 1
    If fstat Then
      Call ECR_TRACE("File PJMFINOVRRPT" - [F:PJMRPT]KEYEXT - [F:PJMRPT]SHOWGRP - [F:PJMRPT]OPPNUM - num$([F:PJMRPT]PSCSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [PJMRPT]
  # -----------------
  Filter [PJMCTO] Where [F:PJMCTO]KEYEXT = ""
  For [PJMCTO]
    IUPDATE = 0
    [F:PJMCTO]KEYEXT = "PJMRPTEXT"
    Rewrite [PJMCTO]
    COMPTEUR += 1
    If fstat Then
      Call ECR_TRACE("File PJMFINCTORPT" - [F:PJMCTO]KEYEXT - [F:PJMCTO]SHOWGRP - [F:PJMCTO]OPPNUM - num$([F:PJMCTO]PSCSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [PJMCTO]
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM021 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM021 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [PJMRPT]
  Close Local File [PJMCTO]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMFINOVRRPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMFINOVRRPT") : End : Endif
  If filinfo(filpath("FIL","PJMFINCTORPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMFINCTORPT") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM021(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMFINOVRRPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMFINOVRRPT") : End : Endif
  If filinfo(filpath("FIL","PJMFINCTORPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMFINCTORPT") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM021(APPLI)
End

