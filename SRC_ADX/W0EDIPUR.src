 Endif
Endif

## Zone PARCODDEB
mkstat = 0
zoncou = "PARCODDEB"
indice = 0
If varmode([M]PARCODDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARCODDEB" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("EPR","!",[M]PARCODDEB,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PARCODDEB" : GZNUM = 55008 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PARCODFIN
mkstat = 0
zoncou = "PARCODFIN"
indice = 0
If varmode([M]PARCODFIN,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PARCODFIN([M]PARCODFIN) From EDIPURSTD
