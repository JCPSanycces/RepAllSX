   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CATCODFIN" : GZNUM = 55011 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TESTFLGNO
mkstat = 0
zoncou = "TESTFLGNO"
indice = 0
IMPENT = [M]TESTFLGNO
If varinit([M]TESTFLGNO,indice)=0
 IMPENT = 1
Endif
If varmode([M]TESTFLGNO,indice)=0
 [M]TESTFLGNO(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TESTFLGNO" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TESTFLGNO(indice)
 Endif
Endif
[M]TESTFLGNO = IMPENT

## Zone TESTFLGYES
mkstat = 0
zoncou = "TESTFLGYES"
indice = 0
IMPENT = [M]TESTFLGYES
If varinit([M]TESTFLGYES,indice)=0
 IMPENT = 1
Endif
If varmode([M]TESTFLGYES,indice)=0
 [M]TESTFLGYES(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TESTFLGYES" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TESTFLGYES(indice)
 Endif
Endif
[M]TESTFLGYES = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone STA2
mkstat = 0
zoncou = "STA2"
indice = 0
IMPENT = [M]STA2
If varinit([M]STA2,indice)=0
 IMPENT = 1
Endif
If varmode([M]STA2,indice)=0
 [M]STA2(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "STA2" : Gosub ACTION From =IMPTRT
  IMPENT = [M]STA2(indice)
 Endif
Endif
[M]STA2 = IMPENT

## Zone STA3
mkstat = 0
zoncou = "STA3"
indice = 0
IMPENT = [M]STA3
If varinit([M]STA3,indice)=0
 IMPENT = 1
Endif
If varmode([M]STA3,indice)=0
 [M]STA3(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "STA3" : Gosub ACTION From =IMPTRT
  IMPENT = [M]STA3(indice)
 Endif
Endif
[M]STA3 = IMPENT

## Zone STA4
mkstat = 0
zoncou = "STA4"
indice = 0
IMPENT = [M]STA4
If varinit([M]STA4,indice)=0
 IMPENT = 1
Endif
If varmode([M]STA4,indice)=0
 [M]STA4(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "STA4" : Gosub ACTION From =IMPTRT
  IMPENT = [M]STA4(indice)
 Endif
Endif
[M]STA4 = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "EDIPUR"
Return

