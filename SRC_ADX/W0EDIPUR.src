# Superviseur
# Gestion du masque EDIPUR 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone NUMBATCHDEB
mkstat = 0
zoncou = "NUMBATCHDEB"
indice = 0
If varmode([M]NUMBATCHDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMBATCHDEB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NUMBATCHFIN
mkstat = 0
zoncou = "NUMBATCHFIN"
indice = 0
If varmode([M]NUMBATCHFIN,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NUMBATCHFIN([M]NUMBATCHFIN) From EDIPURSTD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NUMBATCHFIN : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMBATCHFIN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NUMBATCHFIN([M]NUMBATCHFIN) From EDIPURSTD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NUMBATCHFIN" : GZNUM = 54967 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CREDATDEB
mkstat = 0
zoncou = "CREDATDEB"
indice = 0
If varmode([M]CREDATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CREDATDEB" : Gosub ACTION From =IMPTRT
 Endif
Endif

