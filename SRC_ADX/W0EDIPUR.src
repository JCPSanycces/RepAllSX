  SAVACT = GACTION : GACTION = "STD"
  Call C_CREDATFIN([M]CREDATFIN) From EDIPURSTD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CREDATFIN" : GZNUM = 54969 : Endif
  Gosub AFF From GSAISIE
