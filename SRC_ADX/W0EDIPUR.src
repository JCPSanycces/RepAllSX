 If mkstat=1 : Raz [M]PARCODFIN : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PARCODFIN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("EPR","!",[M]PARCODFIN,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "PARCODFIN" : GZNUM = 55009 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_PARCODFIN([M]PARCODFIN) From EDIPURSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PARCODFIN" : GZNUM = 55009 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CATCODDEB
mkstat = 0
zoncou = "CATCODDEB"
indice = 0
If varmode([M]CATCODDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CATCODDEB" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ECA","!",[M]CATCODDEB,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CATCODDEB" : GZNUM = 55010 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CATCODFIN
mkstat = 0
zoncou = "CATCODFIN"
indice = 0
If varmode([M]CATCODFIN,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CATCODFIN([M]CATCODFIN) From EDIPURSTD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CATCODFIN : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CATCODFIN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("ECA","!",[M]CATCODFIN,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CATCODFIN" : GZNUM = 55011 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
