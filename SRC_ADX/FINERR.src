#<AdxTL>@(#)3.0.0.0 $Revision$

# 2017-10-16 - JPGA - Added DEBUT label to be called by END scripts such as FIN_BATCH
$DEBUT
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"
If GERREUR>0
 GMESSAGE -= errmes$(GERREUR)
Endif
GMESSAGE -= errm
Onerrgo ERR_FINERR
If dim(GSERVEUR) & GSERVEUR
 GERRBATCH=errn
 GMESSBATCH = mess(6,123,1)-num$(GERRBATCH)-":"
 If GERRBATCH>0
  GMESSBATCH -= errmes$(GERRBATCH)
 Endif
 GMESSBATCH -= errm
Endif
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Raz GMESSAGE
Call FLUSH_TRACE From GESECRAN
Onerrgo
End

$ERR_FINERR
Resume

