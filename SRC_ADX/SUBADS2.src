#<AdxTL>@(#)4.0.0.0 $Revision$
Call OBJET("ADS",GBIDC1,GBIDC2) From GOBJET
End

#---------------------------#
$ACTION
Case ACTION
 When "INIT"
  Case GACTION
   When "ADSVAL"
    Gosub DEFVAR From SUBADS
    If clalev([F:ADS])=0  : Local File ADOSSIER         [ADS]  : Endif
    If clalev([F:ADSH])=0  : Local File ADOSSIER        [ADSH]  : Endif
    If clalev([F:ATX])=0  : Local File ATEXTE           [ATX]  : Endif
    If clalev([F:ACV])=0  : Local File ACTIV            [ACV]  : Endif
    If clalev([F:ADM])=0  : Local File ADIMENSION       [ADM]  : Endif
    If clalev([F:ADD])=0  : Local File ADOSSOL          [ADD]  : Endif
    If clalev([F:ADA])=0  : Local File ADOSACT          [ADA]  : Endif
    If clalev([F:ADE])=0  : Local File ADOSDIM          [ADE]  : Endif
    If clalev([F:AC2])=0  : Local File =GDOSX3+".ACTIV" [AC2]  : Endif
    If clalev([F:AD2])=0  : Local File ADOSACT          [AD2]  : Endif
    If func APRODUCT.AGETRELEASESUP()>="17v.132"
     If clalev([F:ADK])=0 : Local File ADOSLIV          [ADK]  : Endif
    Endif
  Endcase
 When "INIT_DIA"
  Case GACTION
   When "ADSVAL"
    Raz [M:DIA] : #109171
    If [M:DIA]NBDOS=0 & PARAM(1)<>""
     [M:DIA]NBDOS = 1
     [M:DIA]DOSSIER(0) = PARAM(1)
    Endif
   When "ADSIMP"
    [M:DIA]DOSSIER = PARAM(1)
  Endcase
 When "CONT_BATCH"
  Case GFONCTION
   When "ADSVAL"
    If nomap<>GDOSX3
     # Cette tâche doit être activée depuis le dossier
     FIN = 1 : GERR = 1 : GMESSAGE = mess(39,134,1)-GDOSX3
    Endif
  Endcase
 When "CONTROLE"
  Case GACTION
   When "ADSIMP"
    If [M:DIA]DOSSIER=""
     SAI = 1 : Return
    Endif
    If filinfo(filpath("","PARAM","ini",[M:DIA]DOSSIER),0)<0
     GERR = 1 : GMESSAGE = [M:DIA]DOSSIER-":"-mess(7,125,1) : # Dossier inexistant
     SAI = 1 : Return
    Endif
   When "ADSTRA"
    Read [ADS]DOSSIER = PARAM(1)
    TRA = 8
    GTRACE = [F:ADS]TRCFIL
   When "ADSTRAHIS"
    Read [ADS]DOSSIER = PARAM(1)
    TRA = 8
    GTRACE = [F:ADS]TRCFILHIS
   When "ADSVAL"
    If nomap<>GDOSX3
     # Cette fonction doit être exécutée depuis le dossier #
     FIN = 1 : GERR = 1 : GMESSAGE = GACTION-":"-func AFNC.MES(mess(157,125,1),GDOSX3)
    Elsif [M:DIA]NBDOS=1
     TRA = 8
    Endif
  Endcase
 When "EXEC"
  Case GACTION
   When "ADSIMP"
    Call LECPAR([M:DIA]DOSSIER) From AINSTCONS
   When "ADSVAL"
    If GSERVEUR
     REQTRACE = GTRACE
    Endif
    Gosub VALIDATION
   When "AIMP1"
    If filinfo(filpath("FIL","ADOSSIER","fde",nomap),0)<0
     Local Char APPLI(GLONADS) , MERE(GLONADS) , MACHINE(GDIMFIC)
     Call MOTHER(nomap,APPLI,MERE,MACHINE) From ATEXTRA
     GMESSAGE = mess(33,135,1)-MERE : # Cet état doit être édité à partir du dossier
     Raz NBPAR , DIFFERE : ER = 1 : Return
    Endif
  Endcase
 When "SORTIE"
  Case GACTION
   When "ADSTRA"
    GTRACE = ""
   When "ADSTRAHIS"
    GTRACE = ""
   When "ADSVAL"
    If GSERVEUR : GTRACE = REQTRACE : Endif
  Endcase
 When "DEBUT"
  Case GBOITE
   When "ADSTAI"
    Call CALTAILLE(PARAM(1)) From DOSTAI
    Affzo
  Endcase
 When "EDI"
  Case GBOITE
   When "ADSTAI"
    Call PRTSCR("DOSTAI","DIA",mess(51,125,1),0,0) From ATRTX3 : # Simulation taille
    Call IMPSCR From ATRTX3
  Endcase
Endcase
Return

#----------------------------------------------------------------------#
## Validation de dossier
#----------------------------------------------------------------------#
## DOSAPL    Création répertoires et fichiers de base
## DOSBASE   Création utilisateur BDD
## DOSTAB    Maj Tables et copie des données
## DOSTXT    Maj des textes (ATEXTE et APLSTD)
## DOSDIC    MAJ dictionnaire
## DOSDICTAB Tables
## DOSDICMSK Ecrans
## DOSDICOBJ Objets
## DOSDICWIN Fenêtres
## DOSDICDIV Autres
## DOSVAL    Validations objets/fenêtres/écrans/consultations
## DOSMEN    Validation des menus
## DOSSUB    Sous-programmes
## DOSDIV    Traitements divers
## DOSMAJ    Changements de version
#----------------------------------------------------------------------#

$VALIDATION

Local Char    DOSCUR(GLONADS) , OGTRACE(GDIMFIC) , FICDIF(GDIMFIC)
Local Integer NBDOS , IDOS , OK , OGERRTRACE , OKBI , TRADIF , FORDIF , OUVADS
Local Integer NBCOP , MODLEG , STAT
Local Char    TBCOP(GLONATB)(1..2000) , SYMBOLE(30)

Local Integer SAVGVALID : SAVGVALID =GVALIDDIFF
If dim([M:DIA]VALDIF)>0
 If [M:DIA]VALDIF=2 and func AFNC.PARTSEP(ver$(0),2," ")>"16r.217"
  GVALIDDIFF = 3
 Else
  GVALIDDIFF=1
 Endif
Endif

If dim([M:DIA]TRADIF)<=0
 TRADIF = 0
Else
 TRADIF = ([M:DIA]TRADIF=2)
 If dim([M:DIA]FORDIF)<=0
  FORDIF = 1
 Else
  FORDIF = max(1,[M:DIA]FORDIF)
 Endif
Endif
OGTRACE = GTRACE
OGERRTRACE = 0
For IDOS=1 To [M:DIA]NBDOS
 DOSCUR = [M:DIA]DOSSIER(IDOS-1)
 # Ecriture dans la trace de la requête batch
 Call TRACE_SRV(REQTRACE,mess(1,125,1)-DOSCUR-format$("D:"+GFMDAT4,date$)-time$,0) : # Génération dossier
 GTRACE = OGTRACE
 Gosub VALDOS
 OGERRTRACE += GERRTRACE
 If GTRACE<>REQTRACE
  If GERRDOS
   # La validation du dossier # ne s'est pas terminée correctement
   Call TRACE_SRV(REQTRACE,func AFNC.MES(mess(193,139,1),[F:ADS]DOSSIER),1)
  Elsif GERRTRACE
   # La validation du dossier $1$ s'est terminée avec $2$ erreurs
   Call TRACE_SRV(REQTRACE,func AFNC.MES2(mess(151,125,1),[F:ADS]DOSSIER,num$(GERRTRACE)),1)
  Endif
  # Le détail de la validation est visible dans la trace $1$ du dossier $2$
  Call TRACE_SRV(REQTRACE,func AFNC.MES2(mess(279,125,1),GTRACE,GDOSX3),0)
 Endif
Next IDOS
GERRTRACE = OGERRTRACE
GVALIDDIFF=SAVGVALID
Return

#--------------------------------------------------#
Subprog TRACE_SRV(REQTRACE,MESSAGE,ERR)
Value Char REQTRACE, MESSAGE
Value Integer ERR
If REQTRACE<>""
 Openo filpath("TRA",REQTRACE,"tra") , -1 Using [TRA_]
 Iomode adxifs "" Using [TRA_]
 Iomode adxirs chr$(10) Using [TRA_]
 Iomode adxium GUTF8 Using [TRA_]
 If ERR<0
  Wrseq ">"+right$(num$(10000+mod(abs(ERR),10000)),2)+" "; Using [TRA_]
 Elsif ERR>0
  Wrseq "<"+right$(num$(10000+mod(ERR,10000)),2)+" "; Using [TRA_]
 Endif
 Wrseq MESSAGE Using [TRA_]
 Openo Using [TRA_]
Endif
End

#-------------------#
$VALDOS
# On ne valide pas le superviseur
If DOSCUR=GDOSX3
 If GTRACE="" : GTRACE = REQTRACE : Endif
 Call ECR_TRACE(DOSCUR-":"-mess(222,139,1),1) From GESECRAN : # Dossier racine
 Return
Endif

# En WEB on évite de valider un dossier à cause du timout dasn les boîtes de tempo

If GBROWS and toupper(GRELCLI)<"WEB.126"       : # Bug 81825    CC - 21/05/2012
 If dim(GFUSION)<=0 or !GFUSION : # mb 7.4.14 Autorisé en interactif sous convergence
  If GTRACE="" : GTRACE = REQTRACE : Endif
  Call ECR_TRACE(mess(52,139,1),1) From GESECRAN : # La validation de dossier ne peut s'effectuer que par une tâche batch
  Return
 Endif
Endif

Local Char FIC(20)(1..500)
Local Integer NBFIC
Local Char    MACHINE(GDIMFIC) , CHEMIN(GDIMFIC) , FICHIER(GDIMFIC) , ORDRE(250)

Local Char DOSPARENT(GLONADS)
Local Integer ISHISTFOLD : ISHISTFOLD=0
DOSPARENT=func DOSSUB.PARENTHISTFOLD(DOSCUR)
If DOSPARENT<>""
 #107271 cf FILL_ADS from DOSSUB
 Read [ADS]DOSSIER = DOSPARENT
 [F:ADSH]=[F:ADS]
 [F:ADSH]DOSHIS=""
 [F:ADSH]DOSREF=[F:ADS]DOSSIER
 [F:ADSH]DOSCOP=[F:ADS]DOSSIER
 [F:ADSH]DOSSIER=DOSCUR
 [F:ADS]=[F:ADSH]
 ISHISTFOLD=1
Else
 Read [ADS]DOSSIER = DOSCUR
 If fstat
 # En batch, on écrit dans la trace de la requête, sinon erreur à l'écran
  If GTRACE="" : GTRACE = REQTRACE : Endif
  Call ECR_TRACE(DOSCUR-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
  Return
 Endif
Endif

# Existence dossier de référence et du dossier de copie et du dossier racine

If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSREF),0)<0
 If GTRACE="" : GTRACE = REQTRACE : Endif
 Call ECR_TRACE([F:ADS]DOSREF-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
 Return
Endif
If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSCOP),0)<0
 If GTRACE="" : GTRACE = REQTRACE : Endif
 Call ECR_TRACE([F:ADS]DOSCOP-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
 Return
Endif
If filinfo(filpath("FIL","ADOVAL","fde",GDOSX3),0)<0
 If GTRACE="" : GTRACE = REQTRACE : Endif
 Call ECR_TRACE(GDOSX3-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
 Return
Endif

# Vérif de la langue de validation (sauf si batch chez nous)

## attention le 01/06/01 , en batch on ne controle pas la langue de validation dans
## l'environnement de dev car on n'est jamais ok

OK = (GSERVEUR and GSOPHIA)
OK += find(GLANGUE,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
If !OK
 If GTRACE="" : GTRACE = REQTRACE : Endif
 If GSERVEUR
  # Le serveur batch doit être démarré dans une des langues du dossier
  Call ECR_TRACE(mess(131,125,1)-DOSCUR,1) From GESECRAN
 Else
  # Il faut être connecté dans une des langues du dossier
  Call ECR_TRACE(mess(103,125,1)-DOSCUR,1) From GESECRAN
 Endif
 Return
Endif

# Existence du dossier

REPERT = filpath("","","",DOSCUR,[F:ADS]VOLUME,adxmac(0))
If filinfo(REPERT,0)<0
 #107271
 If ISHISTFOLD
  GCRE = 0
  # En batch, on écrit dans la trace de la requête, sinon erreur à l'écran
   If GTRACE="" : GTRACE = REQTRACE : Endif
   Call ECR_TRACE(DOSCUR-":"-mess(7,125,1),1) From GESECRAN : # Dossier inexistant
   Return
 Else
  GCRE = 1
  Call VERFDOS(DOSCUR,OK) From SUBADS
  If !OK
   If GTRACE="" : GTRACE = REQTRACE : Endif
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Return
  Endif
 Endif
Else
 GCRE = 0
Endif

# Multi-tiers

If adxmac(0)<>"" & GCRE
 If GTRACE="" : GTRACE = REQTRACE : Endif
 Call ECR_TRACE(mess(128,125,1),1) From GESECRAN : # Création de dossier impossible sur machine distante
 Return
Endif

# Dossier de référence

GDOSREF = [F:ADS]DOSREF

SYMBOLE = "ADS"+DOSCUR
Lock =SYMBOLE With lockwait=0
If fstat
 # Fiche dossier verrouillée
 Call ECR_TRACE(DOSCUR-":"-mess(204,125,1),1) From GESECRAN
 Return
Endif

If GCRE
 MESSA = mess(1,125,1)-[F:ADS]DOSSIER : # Génération dossier
Else
 MESSA = mess(265,125,1)-[F:ADS]DOSSIER : # Validation dossier
Endif
If GSOPHIA
 MESSA -= "("+adxmac(-1)+":"+num$(adxtcp)+")"
 MESSA -= string$(GSERVEUR<>0,mess(38,114,1)-GBATCHRQT) : # Requête numéro
Endif
Call OUVRE_TRACE(MESSA) From LECFIC

#107271
If ISHISTFOLD
 Trbegin [ADS]
  Read [ADS]DOSSIER=DOSPARENT
  If !fstat
   [F:ADS]TRCFILHIS = GTRACE
   If [F:ADS]DOSCOP="" : # Petite sécurité
    [F:ADS]DOSCOP = [F:ADS]DOSREF
   Endif
   Rewrite [ADS]
  Endif
 Commit
Else
 Trbegin [ADS]
  Read [ADS]DOSSIER=DOSCUR
  If !fstat
   [F:ADS]TRCFIL = GTRACE
   If [F:ADS]DOSCOP="" : # Petite sécurité
    [F:ADS]DOSCOP = [F:ADS]DOSREF
   Endif
   Rewrite [ADS]
  Endif
 Commit
Endif

#[F:ADS] ici on a le dossier ou dossier mere si dossier historisé

# Avant migration on demande à valider le dossier (demande 100077)
Call VERSION(GDOSREF,SUPVERS) From DOSSUB
If !GCRE
 Call VERSION(DOSCUR,DOSVERS) From DOSSUB
 If DOSVERS=""
  # Le numéro de version du dossier est incorrect
  Call ECR_TRACE(DOSCUR-mess(142,100,1),1) From GESECRAN
  Goto FIN_VALDOS
 Endif
Endif

#[F:ADS] ici on a le dossier ou dossier mere si dossier historisé
# mb 3.6.14 bug 100491 désactiver le test sur GPRODUIT + tard
# mb 31.12.14 demande 105056 pour HRM
If clalev([F:ADK])>0 & !GCRE & SUPVERS<>DOSVERS & find(GPRODUIT,0,2)
 ASTATUS = func ASYRLICFOL.GETPOLICY([L]TBLIV)
 If [L]TBLIV(1)<>""
   Read [ADK]ADK0=[F:ADS]DOSSIER;[L]TBLIV(1)
   If fstat
    # Il faut d'abord enregistrer la fiche dossier "$1$" avant de lancer la migration
    Call ECR_TRACE(func AFNC.MES1(mess(283,125,1),[F:ADS]DOSSIER),1) From GESECRAN
    Goto FIN_VALDOS
   Endif
 Endif
Endif

# Contrôles des codes activités

#[F:ADS] ici on a le dossier ou dossier mere si dossier historisé
If clalev([M:ADS0])=0
 Local Mask ADS0 [ADS0] , ADS1 [ADS1] , ADS2 [ADS2] , ADS4 [ADS4] , ADS6 [ADS6] , ADS7 [ADS7] , ADS05 [ADS5]
 Call CHARGE_ACV([F:ADS]DOSSIER,[F:ADS]DOSREF,[F:ADS]NBLEG,[F:ADS]DOSLEG,[F:ADS]MODULE) From SUBADS
 [M:ADS0] = [F:ADS]
 [M:ADS5] = [F:ADS]
 [M:ADS1] = [F:ADS]
 [M:ADS4] = [F:ADS]
 OUVADS = 1
Else
 OUVADS = 0
Endif
OK = 1
Onerrgo RIEN
Gosub VERIF From SUBADS
Onerrgo
If !OK
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 Goto FIN_VALDOS
Endif

#[F:ADS] ici on a le dossier ou dossier mere si dossier historisé
# Nouveaux codes activités
#107271
If !ISHISTFOLD
  OK = 1
  Local Char MESSA(255)
  Local Integer NBMAX , NB
  NB = 0
  NBMAX = int((255-len(mess(189,126,1))-len(mess(190,126,1))-len(DOSCUR)-10)/(GLONACV+1))
  For [AC2]
   If [F:ADS]MODULE([F:AC2]MODULE-1)=2
    Read [ADA]ADA0 = DOSCUR;[F:AC2]CODACT
    If fstat
     If NB<NBMAX
      NB += 1
      If MESSA<>""
       MESSA += " "
      Endif
      MESSA += [F:AC2]CODACT
     Endif
     OK = 0
    Endif
   Endif
  Next AC2
  If OK & filinfo(filpath("FIL","ACTIV","fde",DOSCUR),0)>0
   Local File =DOSCUR+".ACTIV" [ACX]
   For [ACX] Where CODACT>="X"
    If [F:ADS]MODULE([F:ACX]MODULE-1)=2
     Read [ADA]ADA0 = DOSCUR;[F:ACX]CODACT
     If fstat
      If NB<NBMAX
       NB += 1
       If MESSA<>""
        MESSA += " "
       Endif
       MESSA += [F:ACX]CODACT
      Endif
      OK = 0
     Endif
    Endif
   Next ACX
   Close Local File [ACX]
  Endif
  If !OK
   # Nouveaux codes activités détectés
   Call ECR_TRACE(mess(189,126,1)+"\("+MESSA+")",-1) From GESECRAN
  Endif

  # On recalcule les codes activités car on a pu les modifier dans l'action VERIF

  SYMBOLE = "ADS"+DOSCUR
  Lock =SYMBOLE With lockwait=0
  If fstat
   # Fiche dossier verrouillée
   Call ECR_TRACE(DOSCUR-":"-mess(204,125,1),1) From GESECRAN
   Goto FIN_VALDOS
  Else
   GOK = 1
   Trbegin [ADS]
    Readlock [ADS]DOSSIER=DOSCUR
    If fstat
     GOK = 0
    Else
     Call MAJ_ACV([F:ADS]DOSSIER,[F:ADS]DOSREF) From SUBADS
    Endif
   Commit
   Unlock =SYMBOLE
   If GOK=1
    If !OK
     # Nouveaux codes activités intégrés dans le dossier #
     Call ECR_TRACE(func AFNC.MES(mess(203,125,1),DOSCUR),0) From GESECRAN
     Call WORKFLOW(1,"DIV","NEWACT","") From AWRK
    Endif
   Else
    # Erreur d'écriture sur le fichier
    Call ECR_TRACE(mess(13,100,1)-"ADOSSIER",1) From GESECRAN
    Goto FIN_VALDOS
   Endif
  Endif

  # Activation BO

  OKBI = 0
  If filinfo(filpath("FIL","ACTIV","fde",DOSCUR),0)>0
   Local File =DOSCUR+".ACTIV" [ACX]
   Read [ACX]CODACT="ABI"
   If [F:ACX]FLACT<>2
    Read [ADA]ADA0 = DOSCUR;[F:ACX]CODACT
    If !fstat & [F:ADA]FLACT=2
     OKBI = 1
    Endif
   Endif
   Close Local File [ACX]
  Endif

Endif

If ISHISTFOLD
  [F:ADS]=[F:ADSH]
Endif : #107271

#[F:ADS] ici on a le dossier ou le dossier historisé

GTSTDOS  = 0     : #X3BY mettre 0
GCOEFTAB = 0.5   : #X3BY quel coefficient ?
Raz GMAJTXTSTD , GMAJTXTSPE , GDERTXTSTD , GDERTXTSPE , GNBRTXTSTD , GNBRTXTSPE

# Affichage boîte d'info ??
If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif

If GINFO
 Call OUVRE_VLC(mess(1,125,1)-[F:ADS]DOSSIER,"","") From GESECRAN : # Génération dossier
Endif

# Génération dossier

Call ECR_TRACE(mess(9,125,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN  : # Début de génération

# Autres vérifications

OK = 1
ACTION = "VERFDOS" : Gosub BACTION From SUBADS
If !OK
 # La validation de dossier ne peut pas se poursuivre
 Call ECR_TRACE(mess(206,125,1),-1) From GESECRAN
 Goto FIN_VALDOS
Endif
If ISHISTFOLD
  [F:ADS]=[F:ADSH]
Endif : #107271

# Où on en est des versions ?

If [F:ADS]DOSREF<>GDOSX3 & func DOSSUB.RELEASE([F:ADS]DOSREF)<> func DOSSUB.RELEASE(GDOSX3)
 # La version du dossier de référence ($1$) est différente du dossier racine $2$
 Call ECR_TRACE(func AFNC.MES2(mess(252,125,1),[F:ADS]DOSREF,GDOSX3),1) From GESECRAN
 Goto FIN_VALDOS
Endif

If [F:ADS]DOSCOP<>GDOSX3 & func DOSSUB.RELEASE([F:ADS]DOSCOP)<>func DOSSUB.RELEASE(GDOSX3)
 # La version du dossier de référence ($1$) est différente du dossier racine $2$
 Call ECR_TRACE(func AFNC.MES2(mess(252,125,1),[F:ADS]DOSCOP,GDOSX3),1) From GESECRAN
 Goto FIN_VALDOS
Endif

If ISHISTFOLD
 If func DOSVUE.ISVIEW([F:ADS]DOSSIER,"ADOVALHIS")
  #Niveau de patch du dossier $1$ incorrect. La table $2$ n'existe pas
  Call ECR_TRACE(func AFNC.MES2(mess(288,125,1),[F:ADS]DOSSIER,"ADOVALHIS"),1) From GESECRAN
  Goto FIN_VALDOS
 Endif
Endif : #107271

#111507
STAT=0
Call CHECK_ROLE_TRIGGER(nomap,STAT) From TRTGRANT
If STAT
  Goto FIN_VALDOS
Endif

Call VERSION(GDOSREF,SUPVERS) From DOSSUB
If !GCRE
 Call VERSION(DOSCUR,DOSVERS) From DOSSUB
 If DOSVERS=""
  # Le numéro de version du dossier est incorrect
  Call ECR_TRACE(DOSCUR-mess(142,100,1),1) From GESECRAN
  Goto FIN_VALDOS
 Endif
Endif

#107271
If ISHISTFOLD
 GNBSPE = 0
 For [ADA]ADA0 Where DOSSIER=DOSPARENT & CODACT>="X"
  If GDOSREF=GDOSX3 or [F:ADA]COP<>2
   GNBSPE += 1
   GSPE(GNBSPE) = [F:ADA]CODACT
  Endif
 Next ADA
Else
 GNBSPE = 0
 For [ADA]ADA0 Where DOSSIER=[F:ADS]DOSSIER & CODACT>="X"
  If GDOSREF=GDOSX3 or [F:ADA]COP<>2
   GNBSPE += 1
   GSPE(GNBSPE) = [F:ADA]CODACT
  Endif
 Next ADA
Endif

# Vérification type de données ADI

OK = 1
#107271
If !GCRE & val(DOSVERS)<30 & !ISHISTFOLD
 Onerrgo RIEN
 Local File =[F:ADS]DOSSIER+".ATYPE" [ATT_]
 Read [ATT_]CODTYP="ADJ"
 If !fstat & [F:ATT_]LNGTYP>GLONADI
  # La longueur des codes des tables diverses doit être limité à $1$ caractères. Elle est actuellement de $2$.
  Call ECR_TRACE(func AFNC.MES2(mess(199,125,1),num$(GLONADI),num$([F:ATT_]LNGTYP)),1) From GESECRAN
  OK = 0
 Endif
 Close Local File [ATT_]
 Onerrgo
Endif
If !OK : Goto FIN_VALDOS : Endif

# La dernière migration s'est-elle bien passée ?

Raz GERRDOS

If !GCRE & SUPVERS<>DOSVERS
 #107271
 If ISHISTFOLD
  Call GETPARHIS([F:ADS]DOSSIER,"AMIGVER",MESSA) From SUBADS
 Else
  Call GETPAR([F:ADS]DOSSIER,"AMIGVER",MESSA) From SUBADS
 Endif
 If MESSA<>""
  # La précédente migration (#) a échoué, la validation ne peut pas se poursuivre
  Call ECR_TRACE(func AFNC.MES(mess(182,125,1),MESSA),1) From GESECRAN
  Goto FIN_VALDOS
 Endif
Endif

# On vérifie qu'il n'y a personne sur l'appli

If !GCRE
 Call MONO([F:ADS]DOSSIER,OK) From DOSSUB
 If !OK
  # La validation de dossier ne peut pas se poursuivre
  Call ECR_TRACE(mess(206,125,1),-1) From GESECRAN
  Goto FIN_VALDOS
 Endif
Endif

# On vérifie qu'on tout ce qu'il faut les moulinettes de migration optimisées pour X3 ou HRM

Local Integer MOUOPTX3
#104020 add HRM V7 migration
#If !GCRE & SUPVERS<>DOSVERS & val(DOSVERS)<40 & GPRODUIT=0 : # Cas d'une migration majeure v7
If !GCRE & find(GPRODUIT,0,2)>0 & SUPVERS<>DOSVERS : # Migration X3 ou HRM
 If val(DOSVERS)<(int(val(SUPVERS)/10)*10) : # Cas d'une migration majeure
  If func AFNC.PARTSEP(ver$(0),2," ")<"16r.216"
   # La version $1$ actuelle du moteur n'est pas adaptée à cette migration. Il faut installer une version $2$ ou supérieure
   Call ECR_TRACE(func AFNC.MES2(mess(250,125,1),func AFNC.PARTSEP(ver$(0),2," "),"16r.216"),-1) From GESECRAN
   Goto FIN_VALDOS
  Else
   MOUOPTX3 = 1
  Endif
 Endif
Endif

# Début de génération

# mb 13.2.7 pour éviter les plantages dans la validation des transactions GPAO (30000)
# mb 18.7.7 pour éviter les plantages dans la validation des transactions VENTES (40000)

maxmem = max(int(maxmem/1024),40000)
Call ECR_TRACE("maxmem="+num$(maxmem),0) From GESECRAN

# Message d'alerte sur le paramètre NOSTOPERR

If (dim(ARRET)>0 & !ARRET) & SUPVERS<>DOSVERS
 # Le paramètre $1$ est à $2$
 # En cas d'erreur, la validation de dossier va se poursuivre, mais ce dossier ne pourra pas être exploité
 Call ECR_TRACE(func AFNC.MES2(mess(218,125,1),"NOSTOPERR",mess(2,1,1))+"\"+mess(219,125,1),-1) From GESECRAN
Endif

# Mise à jour éventuelle

Raz GVALIDE , GVALTRANS

# C'est AMAJ qui dira si on doit forcer une revalidation de quelque chose

For I=1 To len(mess(0,14,1))
 If [F:ADS]TRVAL(I-1)=2 or GCRE
  GVALTRANS(I) = 2
 Endif
Next I

# Raz des flags de validation
#107271
If !GCRE & !ISHISTFOLD
 Call FLGMSK   From DOSDIV
Endif

# Activation/désactivation législation

#107271
If !GCRE & !ISHISTFOLD
 Call DIFFACT(DOSCUR,"LEG",MODLEG) From DOSSUB
Endif

# Validation proprement dite

Raz GERRDOS
Raz GMESSAGE , GERREUR

#107271
If !ISHISTFOLD
 # Ajout de langue ?

 Local Integer ADDLAN
 ADDLAN = (!GCRE * func ADDLAN(DOSCUR))

 #93466
 Call CREAPL   From DOSAPL   : # Création des répertoires
 If GERRDOS : Goto FIN_VALDOS : Endif

 Call CREBASE  From DOSBASE  : # Création base de données
 If GERRDOS : Goto FIN_VALDOS : Endif

 If ADDLAN
  Call GENER_TEMPON
 Endif
Else
  #107271
  ## Création des répertoires
  Call CREAPL([F:ADS]DOSREF,[F:ADS]DOSSIER) From CREHISTO
  Call ECR_TIME(mess(148,125,1)-[F:ADS]DOSSIER) From DOSSUB : # Création des vues
  Call INSTALL_VUE([F:ADS]DOSREF,[F:ADS]DOSSIER,OK) From CREHISTO
  [F:ADS]=[F:ADSH]
  If !OK
   OK = 0 : Call ECR_TRACE(mess(6,123,1)-mess(148,125,1),0) From GESECRAN : # Erreur
   GERRDOS=1 : Goto FIN_VALDOS
  Endif
  Call ECR_TIME(mess(15,125,1)-[F:ADS]DOSSIER) From DOSSUB : # Création des vues
  Call INSTALL_DICO([F:ADS]DOSREF,[F:ADS]DOSSIER,OK) From CREHISTO
  If !OK
   OK = 0 : Call ECR_TRACE(mess(6,123,1)-mess(15,125,1),0) From GESECRAN : # Erreur
   GERRDOS=1 : Goto FIN_VALDOS
  Endif
  Local Char HISMEN(GLONAPM)
  Call GETPAR([F:ADS]DOSREF,"HISMEN",HISMEN) From SUBADS
  For I=0 To [F:ADS]NBRLAN-1
   FICORG = filpath("M"+[F:ADS]LAN(I),HISMEN,"mnu",[F:ADS]DOSREF)
   If filinfo(filpath("M"+[F:ADS]LAN(I),HISMEN,"mnu",[F:ADS]DOSREF),0)<0
    Call ECR_TRACE(HISMEN-mess(34,133,1),-1) From GESECRAN : # Warning
   Else
    FICDES = filpath("M"+[F:ADS]LAN(I),HISMEN,"mnu",[F:ADS]DOSSIER)
    Call COPIE(FICORG,FICDES,STAT) From ORDSYS
   Endif
  Next I

  ## Copie des fichiers menu* et textra*

  CHEMIN = filpath("","","",[F:ADS]DOSREF)
  Call MACHINE(CHEMIN,MACHINE,FICHIER) From ORDSYS
  ORDRE = 'lsadx -a'-[F:ADS]DOSREF-FICHIER
  Call SYSTEME2(MACHINE,ORDRE,'',NBFIC,FIC) From ORDSYS
  NBFIC = min(NBFIC,dim(FIC))
  For I=1 To NBFIC
   If left$(FIC(I),6)="textra" or left$(FIC(I),4)="menu"
    FICORG = filpath("",FIC(I),"",[F:ADS]DOSREF)
    FICDES = filpath("",FIC(I),"",[F:ADS]DOSSIER)
    Call COPIE(FICORG,FICDES,STAT) From ORDSYS
   Endif
  Next I

Endif

# Moulinettes X3
If MOUOPTX3
 Call TRTMIGRAZX3([F:ADS]DOSSIER) From TRTMIGRAZX3
 If GOK<1 : GERRDOS=1 : Goto FIN_VALDOS : Endif
 Call TRTMIGTABX3([F:ADS]DOSSIER) From TRTMIGTABX3
 If GOK<1 : GERRDOS=1 : Goto FIN_VALDOS : Endif
Endif

If !GCRE & SUPVERS<>DOSVERS
 #107271
 If ISHISTFOLD
 Call MAJPARHIS([F:ADS]DOSSIER,"AMIGVER",DOSVERS) From SUBADS
 Else
 Call MAJPAR([F:ADS]DOSSIER,"AMIGVER",DOSVERS) From SUBADS
 Endif
 Call AMAJ From DOSMAJ
 If GERRDOS & (dim(ARRET)<=0 or ARRET<>0)
  # Erreur dans les traitements de migration, la validation ne peut se poursuivre
  Call ECR_TRACE(mess(194,139,1),1) From GESECRAN
  Goto FIN_VALDOS
 Endif
Endif

Raz GMESSAGE , GERREUR

#107271
If ISHISTFOLD
  Goto MAJDOSHIS
Endif

# Chargement des codes livrables et kits

Raz TBLIV , TBKIT , NBCOP , TBCOP
If func APRODUCT.AGETRELEASESUP()>="17v.132"
 Local File ADELIVER [ADLV]
 ASTATUS = func ASYRLICFOL.GETPOLICY(TBLIV)
 If TBLIV(1)<>"" & !GCRE
  Read [ADK]ADK0=[F:ADS]DOSSIER;TBLIV(1)
  If fstat
   Trbegin [ADK]
    Raz [ADK]
    [F:ADK]DOSSIER = [F:ADS]DOSSIER
    [F:ADK]COD     = TBLIV(1)
    [F:ADK]INSTAL  = 2
    Write [ADK]
   Commit
  Endif
 Endif
 J = 0
 For [ADK] Where DOSSIER=[F:ADS]DOSSIER
  Read [ADLV]ADLV0=[F:ADK]COD
  If !fstat & [F:ADLV]ADLVTYP=2 : # Kit
   J += 1
   TBKIT(J) = [F:ADK]COD
   For I=1 To dim(TBLIV)
    If TBLIV(I)<>""
     Read [ADLV]ADLV0=TBLIV(I)
     If !fstat
      K = find([F:ADK]COD,[F:ADLV]ITYKIT)
      If K
       TBROW(J) = [F:ADLV]ITYKITROW(K-1)
       Break
      Endif
     Endif
    Endif
   Next I
  Endif
 Next ADK
 Close Local File [ADLV]
 Sorta J TBROW,TBKIT Order By TBROW(indice+1) Asc
 If GCRE
  # Installation des livrables $1$
  Call ECR_TRACE(func AFNC.MES1(mess(273,125,1),sigma(1,dim(TBLIV),string$(TBLIV(indcum)<>"",',"'+TBLIV(indcum)+'"'))),0) From GESECRAN
 Endif
 GMESSAGE = ""
 For I=1 To dim(TBKIT)
  If TBKIT(I)<>""
   Read [ADK]ADK0=[F:ADS]DOSSIER;TBKIT(I)
   If fstat or [F:ADK]INSTAL<>2
    If GMESSAGE<>"" : GMESSAGE += ',' : Endif
    GMESSAGE += TBKIT(I)
   Endif
  Endif
 Next I
 If GMESSAGE<>""
  # Installation des kits $1$
  Call ECR_TRACE(func AFNC.MES1(mess(274,125,1),GMESSAGE),0) From GESECRAN
  GMESSAGE = ""
 Endif
Endif

# Option de copie des données

Local Integer DETAIL , LEGNUL

DETAIL = 0 : # Trace détaillée
LEGNUL = 1 : # Copie législation vide

# Récupération des législations du dossier validé

Local Char    LEGREF(GLONADI)(0..dim(GDOSLEG))
Local Integer NBLEGREF

Call SETLEG([F:ADS]DOSSIER,LEGREF,NBLEGREF) From DOSCONT

Call DICO(TRADIF,FORDIF) From DOSDIC : # Création ou mise à jour du dictionnaire
If GERRDOS : Goto FIN_VALDOS : Endif

ACTION = "DICO" : Gosub BACTION From SUBADS

Call TABLE    From DOSTAB    : # Création ou mise à jour des tables
Call ANXTEXTRA  From DOSDIV   : # 112340 Creation des ATEXTRA des AINDEX si besoin

# Copie des données

Call COPY_PARAMETER([F:ADS]DOSSIER,[F:ADS]DOSCOP,[F:ADS]DOSREF,[F:ADS]DOSLEG,TBLIV,TBKIT,LEGNUL,DETAIL) From ADOSCOPDAT
Call COPY_TABDIV([F:ADS]DOSSIER,[F:ADS]DOSCOP,[F:ADS]DOSREF,[F:ADS]DOSLEG,TBLIV,TBKIT,LEGNUL,DETAIL) From ADOSCOPDAT
Call COPY_FILE([F:ADS]DOSSIER,[F:ADS]DOSCOP,[F:ADS]DOSREF,[F:ADS]OPTINI,[F:ADS]MODULE,[F:ADS]CRYDEF
&             ,LEGNUL,[F:ADS]DOSLEG,TBLIV,TBKIT,DETAIL,NBCOP,TBCOP) From ADOSCOPDAT
Call UPDATE_FOLDER_KIT([F:ADS]DOSSIER,TBLIV,TBKIT) From ADOSCOPDAT

#  Vérif des liens

If !MOUOPTX3
 Call CONTROL_LINKS([F:ADS]DOSSIER,DETAIL,NBCOP,TBCOP) From ADOSCOPDAT
Endif

# EXE for kit : lauch the SETUP subprog from the file linked to a kit (SETUP_<CODE KIT>)
#SAM 121196
If GCRE
  Local Integer OKTRT
  Local Char  SETUPNAME
  For [ADK] Where DOSSIER=[F:ADS]DOSSIER & INSTAL=2
    OKTRT=0
    SETUPFILE="SETUP_"+[F:ADK]COD
    Call EXISTE_ADX("","",SETUPFILE,OKTRT) From ORDSYS
    If OKTRT>0
      Call SETUP([F:ADS]DOSSIER) From = SETUPFILE
    Endif
  Next
Endif

If !GCRE & SUPVERS<>DOSVERS & dim(GVALIDE)>=11 & GVALIDE(11)=0 & GVALIDE(1)=0
 GVALIDE(11) = 1 : # mb 2.2.12 bug 78306 Pour forcer la validation de toutes les vues
Endif
Call VUE      From DOSVUE   : # Création ou mise à jour des vues

Call MENULOC  From DOSDIV   : # Génération du fichiers des menus locaux (avant validation des fenêtres)

If [F:ADS]CREMSK=2 or GCRE
 Call GENMSK  From DOSVAL   : # Création des écrans
Endif
If [F:ADS]CREOBJ=2 or GCRE
 Call GENOBJ  From DOSVAL   : # Création des objets
Endif
If [F:ADS]CREWIN=2 or GCRE
 Call GENWIN   From DOSVAL  : # Création des fenêtres
Endif
If [F:ADS]CRECNS=2
 Call GENCNS   From DOSVAL  : # Création des consultations
Endif
If GCRE
    # jira 65070 derived language  during creation folder
    # for glangue the records are retrived during copy in DOSTXT
    # here we have to do the same for a derived language
    Call GENDOS   From AVOCAB
Else
    # not only during creation folder
    # the code language can be added during valdiation
    If ADDLAN
       Call GENDOS   From AVOCAB
    Endif
Endif
If !GCRE & MODLEG
 Call GENLEG   From DOSVAL  : # Validation des objets + fenêtres liées aux législations
Endif
Goto MAJDOS

$MAJDOSHIS
#mise a jour dico des tables
Call TABLEHIS([F:ADS]DOSREF,[F:ADS]DOSSIER,1,0,"") From DOSTAB    : # Création ou mise à jour des tables
## Création des vues du dossier principal
Call COPIE_VUE([F:ADS]DOSREF,[F:ADS]DOSSIER,[F:ADS]TYPDBA,[F:ADS]CODDBA) From CREHISTO

$MAJDOS
# Mise à jour éventuelle
If !GCRE & SUPVERS<>DOSVERS
 Call MAJ From DOSMAJ
 If GERRDOS & (dim(ARRET)<=0 or ARRET<>0)
  # Erreur dans les traitements de migration, la validation ne peut se poursuivre
  Call ECR_TRACE(mess(194,139,1),1) From GESECRAN
  Goto FIN_VALDOS
 Endif
Endif

#107271
If !ISHISTFOLD
 # Synchonisation des liens dss représentations
 # avec validation différée avant les transactions
 Call GENDOS(nomap) From SUBACST
 #97530
 Call TRTMAJ_ALL_ACLAFLD([F:ADS]DOSSIER,2) From SUBACLA_TOOL
 Call TRTMAJ_ALL_ASWFLD([F:ADS]DOSSIER,2) From SUBASW_TOOL
 #
 Call TRTMAJ_ALL_ASWLNK([F:ADS]DOSSIER,2) From SUBASW_TOOL
Endif
ACTION = "VALDOS" : Gosub BACTION From SUBADS

#107271
If !ISHISTFOLD
 #If GSERVEUR : GVALIDDIFF=3 : Endif
 Call GENTRANS  From DOSVAL  : # Génération transactions
 #If GSERVEUR : GVALIDDIFF=0 : Endif

 If GCRE & dim([F:ADS]CHGCOD)>0 & [F:ADS]CHGCOD<>"" & [F:ADS]NBLEG=1
  # Changement de clé en masse en création d'un dossier mono-législation
  Call DOSCHGCOD([F:ADS]DOSSIER,[F:ADS]CHGCOD) From ACHANGE
 Endif

 Call DIVERS   From DOSDIV   : # Traitements divers
 Call GENMEN   From DOSMEN   : # Création des menus

 #112168 creation of all triggers
 #Call TRIGGER  From DOSTAB   : # Création des triggers
 Call TRIGGER_ALL  From DOSTAB   : # Création des triggers
 Call FLGMSK   From DOSDIV   : # Raz des flags UPDFLG

 If OKBI
  Call VERFBIAR From DOSDIV
 Endif
Else
  Call VALARCHIVE_HISTO(DOSPARENT) From ARCHGENTRT
Endif


ACTION = "FINDOS" : Gosub BACTION From SUBADS

# Fin des courses

# jira X3-85172
# execute uti on each folder (uti after validation or integration)
Local Char     SAV_GTRACE(GDIMFIC)
Local Integer  SAV_GERRTRACE

If !GCRE
      Call ECR_TIME("Call VALDOS.EXEC_PATCH_AFTER"-[F:ADS]DOSSIER) From DOSSUB
      # flush trace before call exe
      SAV_GTRACE    = GTRACE
      SAV_GERRTRACE = GERRTRACE
      Call FLUSH_TRACE From GESECRAN
      Call EXEC_PATCH_AFTER ([F:ADS]DOSSIER,SAV_GTRACE,"VALDOS") From SUBAUTI
      #
      GTRACE    = SAV_GTRACE
      GERRTRACE = SAV_GERRTRACE
      GLTRACE   = filinfo(GTRACE,7)
      Call ECR_TIME("VALDOS.EXEC_PATCH_AFTER"-mess(3,21,1)) From DOSSUB
Endif

#
If !GCRE
 #107271
 If ISHISTFOLD
  Call MAJPARHIS([F:ADS]DOSSIER,"AMAJDOSREF","0") From SUBADS
 Else
  #107271 le dossier histo devra être revalidé
  Local Char HISAPL(GLONADS)
  HISAPL=""
  Call GETPAR([F:ADS]DOSSIER,"HISDOS",HISAPL) From SUBADS
  If GPRODUIT<>1 & HISAPL<>""
   Call MAJPARHIS(HISAPL,"AMAJDOSREF","2") From SUBADS
   #Attention: le dossier de référence $1$ a été modifié
   #La validation de dossier doit être lancée sur le dossier $1$
   Call ECR_TRACE(func AFNC.MES1(mess(289,125,1),[F:ADS]DOSSIER),-1) From GESECRAN
   Call ECR_TRACE(func AFNC.MES1(mess(290,125,1),HISAPL),-1) From GESECRAN
  Endif
 Endif
 Call MULTI([F:ADS]DOSSIER) From DOSSUB
Endif

 #107271
If GSOPHIA & !ISHISTFOLD
 Local File =[F:ADS]DOSSIER+".ADOVAL" [AD__]
 Read [AD__]ADW0 = "";"";"MONO"
 If fstat or [F:AD__]VALEUR="0"
  Call ECR_TRACE(mess(50,125,1)-[F:ADS]DOSSIER,0) From GESECRAN : # Déverrou dossier
 Endif
 Close Local File [AD__]
Endif

If SUPVERS<>DOSVERS & GERRDOS=0
    Call ECR_TRACE([F:ADS]DOSSIER+" : "+mess(93,125,1)-SUPVERS,0) From GESECRAN : # Mise à jour en version
    # ISSUE X3-108947 supvers is already ok , so not necessary to use FORMAT_RELEASE
    #106969
    #108947 param is char and release is decimal .. use a fct to convert correctly the value
    If ISHISTFOLD
        Call MAJPARHIS([F:ADS]DOSSIER,"RELEASE",SUPVERS) From SUBADS
        Call MAJPARHIS([F:ADS]DOSSIER,"RELABR",func APRODUCT.AGETRELEASEABR(GDOSREF)) From SUBADS
    Else
        Call MAJPAR([F:ADS]DOSSIER,"RELEASE",SUPVERS) From SUBADS
        Call MAJPAR([F:ADS]DOSSIER,"RELABR",func APRODUCT.AGETRELEASEABR(GDOSREF)) From SUBADS
    Endif
    If !GCRE
    #107271
        If ISHISTFOLD
            Call MAJPARHIS([F:ADS]DOSSIER,"AMIGVER","") From SUBADS
        Else
            Call MAJPAR([F:ADS]DOSSIER,"AMIGVER","") From SUBADS
        Endif
    Endif
Endif


# Moulinettes exécutées en batch

If MOUOPTX3
 Local Char    PLAN(GLONADS)
 Local Integer NBTAC , STAT
 Local File ADOVAL [AD__]
 Read [AD__]ADW0 = "";"";"NBRTACSIM"
 If !fstat
  NBTAC = val([F:AD__]VALEUR)
 Else
  NBTAC = 2
 Endif
 Close Local File [AD__]

 # Activation du serveur batch s'il n'est pas lancé
 #109897
 #Call ACTAUTO From SERVEUR
 Raz GMESSAGE,GERR

 PLAN = [F:ADS]DOSSIER
 Call CREPLAN(PLAN,[F:ADS]DOSSIER,NBTAC,STAT) From SUBAM4
 If STAT
  # Lancement du plan $1$ de migration
  Call ECR_TRACE(func AFNC.MES1(mess(248,125,1),PLAN),0) From GESECRAN
  # La migration de votre dossier sera complète lorsque tous les traitements du plan de migration seront terminés sans erreur.
  Call ECR_TRACE(mess(292,123,1),-1) From GESECRAN
  # Suite à la migration complète de votre dossier, il faudra purger les tables de travail du dossier migré.
  Call ECR_TRACE(mess(293,123,1),-1) From GESECRAN
  # Pour cela, vous devrez lancer le traitement TRTMIGDEL via la fonction EXETRT et indiquer le nom du dossier migré.
  Call ECR_TRACE(mess(294,123,1),-1) From GESECRAN
 Else
  # Erreur $1$ dans le lancement du plan $2$
  Call ECR_TRACE(func AFNC.MES2(mess(249,125,1),num$(STAT),PLAN),0) From GESECRAN
 Endif
Endif

#--------------------------------------#
$FIN_VALDOS

# Fin de génération

#107271
If ISHISTFOLD
 # update ETag of the folder
 Call  UPDATE_RIGHTSETAG(DOSPARENT) From ASYRFNC
Else
 # update ETag of the folder
 Call  UPDATE_RIGHTSETAG(DOSCUR) From ASYRFNC
Endif

Call ECR_TRACE(mess(4,125,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
If GERRDOS>0
 # La validation du dossier # a échoué pour cause d'erreur grave
 Call ECR_TRACE(func AFNC.MES(mess(217,125,1),DOSCUR),1) From GESECRAN
Endif

Call FERME_TRACE From LECFIC

If OUVADS & clalev([M:ADS0])>0
 Close Local Mask [ADS0] , [ADS1] , [ADS2] , [ADS4] , [ADS5] , [ADS6] , [ADS7]
Endif
If GINFO
 Call FERME_VLC From GESECRAN
Endif
Return

$RIEN
Resume

#-----------------------------------------------#
Funprog ADDLAN(APPLI)
Value Char APPLI
Local Integer LANCUR , ERREUR , NEWLAN
Local Char    VOLUME(1) , MACHINE(GDIMFIC)
If clalev([F:ADS])=0 : Local File DOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>APPLI
 Read [ADS]DOSSIER=APPLI
Endif
NEWLAN  = 0
VOLUME  = [F:ADS]VOLUME
MACHINE = adxmac(0)
For LANCUR=0 To [F:ADS]NBRLAN-1
 If filinfo(filpath("REPORT",[F:ADS]LAN(LANCUR),"",[F:ADS]DOSSIER,VOLUME,MACHINE),0)<=0
  Call ECR_TRACE(mess(3,7813,1)-[F:ADS]LAN(LANCUR),0) From GESECRAN : # Ajout langue
  NEWLAN = 1 : Break
 Endif
Next LANCUR
End NEWLAN

#--------------------------------------------------------------------#
Subprog GENER_TEMPON
Local Integer I , ODIFF , OGSERVEUR , STAT
Local File =[F:ADS]DOSSIER+".APLSTD" [ASTD]
Local File =GDOSX3+".APLSTD" [ASTX]
Local File =GDOSX3+".TABLAN" [TLAX]
For I=0 To [F:ADS]NBRLAN-1
 Look [ASTD]LAN(1)=[F:ADS]LAN(I)
 If fstat
  Read [TLAX]TLA0 = [F:ADS]LAN(I)
  If !fstat & [F:TLAX]LANSTD=2 : # On respecte les langues spécifiques
   Trbegin [ASTD]
    For [ASTX]LAN Where LAN=[F:ADS]LAN(I)
     [F:ASTD] = [F:ASTX]
     Write [ASTD]
     If fstat
      Call ERREUR("APLSTD",1) From DOSDIC
     Endif
    Next ASTX
   Commit
  Endif
 Endif
Next I
Close Local File [ASTD] , [ASTX]

OGSERVEUR = GSERVEUR
GSERVEUR = 1 : # Pour éviter l'affichage des boites de tempo
Call GENMENU([F:ADS]DOSSIER,0,2,"") From GENMENULOC
GSERVEUR = OGSERVEUR

ODIFF = GVALIDDIFF
GVALIDDIFF = 1
Call VALID("TEMPO",[F:ADS]DOSSIER,[F:ADS]NBRLAN,[F:ADS]LAN,1,STAT) From VALMSK
Call VALID("TEMPON",[F:ADS]DOSSIER,1,STAT) From VALWIN
GVALIDDIFF = ODIFF
End

#------------------------------------------------------------------------------#
# Contrôle licence désactivé pour le moment (déjà fait en saisie de dossier)
#------------------------------------------------------------------------------#

$VERIF_LICENCE
Local Integer VLR , DIME

For I=1 To dim([F:ADS]MODULE)
 If [F:ADS]MODULE(I-1)=2 & left$(mess(I,14,1),1)<>"#"
  ASTATUS = func ASYRLICFOL.ACTIVE_MODULE(num$(I),VLR)
  If ASTATUS<>CST_ATRUE
   # La license actuelle ne permet pas d'activer le module "$1$"
   Call ECR_TRACE(func AFNC.MES1(mess(268,125,1),mess(I,14,1)),1) From GESECRAN
   Break
  Endif
 Endif
Next I
If ASTATUS<>CST_ATRUE : Return : Endif

For [ADK] Where DOSSIER=[F:ADS]DOSSIER
 Read [ADLV]ADLV0=[F:ADK]COD
 If !fstat & [F:ADLV]ADLVTYP=2 : # Kit
  ASTATUS = func ASYRLICFOL.ACTIVE_KIT([F:ADK]COD)
  If ASTATUS<>CST_ATRUE
   # La license actuelle ne permet pas d'activer le kit "$1$"
   Call ECR_TRACE(func AFNC.MES1(mess(269,125,1),[F:ADK]COD),1) From GESECRAN
   Break
  Endif
 Endif
Next ADK
If ASTATUS<>CST_ATRUE : Return : Endif

For [ADA] Where DOSSIER=[F:ADS]DOSSIER
 ASTATUS = func ASYRLICFOL.ACTIVE_CODE([F:ADA]CODACT,[F:ADA]DOSSIER,[L]DIME,[L]VLR)
 If ASTATUS<>CST_ATRUE & [F:ADA]FLACT=2
  # La license actuelle ne permet pas d'activer le code activité "$1$"
  Call ECR_TRACE(func AFNC.MES1(mess(270,125,1),[F:ADA]CODACT),1) From GESECRAN
  Break
 Endif
Next ADK
If ASTATUS<>CST_ATRUE : Return : Endif

For I=1 To [F:ADS]NBRLAN
 ASTATUS = func ASYRLICFOL.ACTIVE_LANGUAGE([F:ADS]LAN(I-1))
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer la langue "$1$"
  Call ECR_TRACE(func AFNC.MES1(mess(271,125,1),[F:ADS]LAN(I-1)),1) From GESECRAN
  Break
 Endif
Next I
If ASTATUS<>CST_ATRUE : Return : Endif

For I=1 To [F:ADS]NBLEG
 ASTATUS = func ASYRLICFOL.ACTIVE_LEGISLATION([F:ADS]DOSLEG(I-1))
 If ASTATUS<>CST_ATRUE
  # La license actuelle ne permet pas d'activer la législation "$1$"
  Call ECR_TRACE(func AFNC.MES1(mess(272,125,1),[F:ADS]DOSLEG(I-1)),1) From GESECRAN
  Break
 Endif
Next I
If ASTATUS<>CST_ATRUE : Return : Endif
Return

#---------------------------------------------#
# Ecran ADSVAL
#---------------------------------------------#

Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
If GABREV="ADS" & VALEUR=nomap
 GMESSAGE = mess(47,125,1) : # Dossier en cours d'utilisation
 mkstat = 2 : End
Endif
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=VALEUR
If fstat
 If func DOSSUB.ISHISTFOLD(VALEUR)=0
  GMESSAGE=mess(7,125,1)
  GERR=1
  mkstat=2
 Endif
Endif
End

Subprog AM_DOSSIER(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV & VALEUR<>""
 ## Action APASSWD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "APASSWD"
 PARMSK(1) = ""
 PARMSK(2) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"APASSWD","APASSWD","SPEPASSWD") From GSAISIE
 GACTION = SAVACT
Endif
End

Subprog S_DOSSIER(VALEUR)
Variable Char    VALEUR()
Gosub DEFSEL2
Local File ADOSSIER [ADS]
  For [ADS]
    NBTEX+= 1
    TEX(NBTEX,1) = [F:ADS]DOSSIER
    TEX(NBTEX,2) = [F:ADS]NOMDOS
    If [F:ADS]DOSHIS<>""
     NBTEX+= 1
     TEX(NBTEX,1) = [F:ADS]DOSHIS
     TEX(NBTEX,2) = mess(291,125,1)-[F:ADS]DOSSIER
    Endif
  Next
  CHOI = 0
  TIT(0) = mess(22,123,1) # Sélection
  TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ADS0", "DOSSIER")
  TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ADS0", "NOMDOS")
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,80) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
  Endif
End

$DEFSEL2
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES+10)(1..500,1..2) , TIT(GLONDES)(0..2) , CRITERE(250)
Return

######################################################################################


Subprog AV_NBDOS
Gosub GRISE_FORDIF
#109171
If GFONCTION="GESADS"
  Grizo [M:DIA]NBDOS
Endif
End

Subprog AM_TRADIF(VALEUR)
Variable Integer VALEUR
[M]TRADIF = VALEUR
Effzo FORDIF
Gosub GRISE_FORDIF
End

$GRISE_FORDIF
#109171 on teste TRADIF=2 en premier
If [M]TRADIF=2
 Actzo FORDIF
Else
 [M]FORDIF = 0
 Diszo FORDIF
Endif
Return

Subprog AV_VALDIF(VALEUR)
Variable Integer VALEUR
If func AFNC.PARTSEP(ver$(0),2," ")<="16r.217"
  VALEUR=1
  mkstat=1
Endif
End

Subprog D_VALDIF(VALEUR)
Variable Integer VALEUR
VALEUR=2
If func AFNC.PARTSEP(ver$(0),2," ")<="16r.217"
  VALEUR=1
Endif
End



