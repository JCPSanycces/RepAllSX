End

#-----------------------------------------------------------------------------------------#
# For manage file on autorized space directory ('tmp' directory of nomap)
# see func SPACE_PATH
#
# use this url
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/upload?fileName='[space]directory/file_name.ext'&type=T)
#
# T -> 1=PC, 2=server
#
# use PUT for upload a file on the server
# use GET for download a file from a server
# use DELETE for delete a file on the server
#
# The content file is in ASND.JSON property for GET
#                   & in ARCV.JSON property for PUT
#-----------------------------------------------------------------------------------------#
#**
#* Funprog HANDLER_GET_DATA()
#*!
Funprog HANDLER_GET_DATA(ACTX,ASWK,ARCV,PSYR,ASNB)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASNB Using C_ASYRSNDBLB
Local Integer   ERROR : ERROR = [V]CST_AOK

ERROR = func LOAD(ACTX,ASNB,PSYR,ARCV,PSYR.SELREP)
End ERROR

#**
#* Funprog HANDLER_PUT_DATA()
#*!
Funprog HANDLER_PUT_DATA(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO
Local Integer   ERROR : ERROR = [V]CST_AOK

ERROR = func NEW(ACTX,ASND,PSYR,ARCV,PSYR.SELREP)

End ERROR

#**
#* Funprog HANDLER_DELETE_DATA()
#*!
Funprog HANDLER_DELETE_DATA(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ERROR
ERROR= func  KIL(ACTX,ASND,PSYR,ARCV,PSYR.SELREP)
End ERROR


#--------------------------------------------------------------------------------#
Funprog NEW(ACTX,ASND,PSYR,PARCV,KEYS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASND  Using C_ASYRSND
Variable Instance PSYR  Using C_ASYR
Variable Instance PARCV Using C_ASYRRCV
Value    Char     KEYS

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Integer I , J , K
Local Integer ERR , NBR_FOLDERS , EXIST , MACHINE
Local Char    ERRTIT(250) , MESSAGE(250) , FOLDER_NAME(80)(1..10)
Local Char    CHAINE(250) , ORDSYS(250) , COMMAND(250)
Local Char    FILE_SPACE(250) , FILE_NAME(250) , FILE_FULL(250) , FILE_NOREP(250)

FILE_NAME = func GETFILENAME(PARCV,KEYS)

K = instr(1,FILE_NAME,"]")
If K
 J = find("type",PARCV.PARAMCOD)
 If J
  MACHINE = val(PARCV.PARAMVAL(J))
 Else
  MACHINE = 2
 Endif
 ERROR = func CTL_VOLFIL(ACTX,MACHINE,FILE_NAME,FILE_FULL)
 If ERROR<>CST_AOK
  End ERROR
 Else
  ERROR = func CTL_VOLFIL(ACTX,MACHINE,left$(FILE_NAME,K)+"/"+string$(10,"_"),FILE_SPACE)
  If ERROR  =CST_AOK
   FILE_SPACE = left$(FILE_SPACE,len(FILE_SPACE)-11)
   FILE_NOREP = func CONTROL_PATH(right$(FILE_NAME,K+1))
  Endif
 Endif
Else
 ERROR = func SPACE_PATH(ACTX,"TMP","",FILE_SPACE,MESSAGE)
 If ERROR  =CST_AOK
  FILE_NOREP = func CONTROL_PATH(FILE_NAME)
 Endif
Endif

If FILE_NOREP=""
 If len(PARCV.JSON)>0
  ERROR = func SPACE_PATH(ACTX,"TMP","",FILE_SPACE,MESSAGE)
  FILE_NOREP = "file"
 Else
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,mess(48,149,1))
  End ERROR
 Endif
Endif

Raz FOLDER_NAME , NBR_FOLDERS
CHAINE = FILE_NOREP
While CHAINE<>""
 NBR_FOLDERS += 1
 K = instr(1,CHAINE,"/")
 If K
  FOLDER_NAME(NBR_FOLDERS) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  FOLDER_NAME(NBR_FOLDERS) = CHAINE
  CHAINE = ""
 Endif
Wend
# the last is a file
FILE_NAME = FOLDER_NAME(NBR_FOLDERS)
FOLDER_NAME(NBR_FOLDERS) = ""
NBR_FOLDERS -= 1

# create folders if not exists
CHAINE = ""
For I=1 To NBR_FOLDERS
 If CHAINE=""
  CHAINE = FOLDER_NAME(I)
 Else
  CHAINE += "/"+FOLDER_NAME(I)
 Endif
 Call EXIST(FILE_SPACE+"/"+CHAINE,EXIST) From ASYRSYS
 Case EXIST
  When 2 : # ok
  When 1 : # this file is not a folder
   End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(52,149,1),CHAINE))
   Break
  When 0 : # this folder don't exist -> create this folder
   ORDSYS += 'ae_mkdir'-'"'+FILE_SPACE+"/"+CHAINE+'"'
   System COMMAND=ORDSYS
   Call EXIST(FILE_SPACE+"/"+CHAINE,EXIST) From ASYRSYS
   If EXIST<>2
    End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(53,149,1),CHAINE))
    Break
   Endif
 Endcase
Next I

CHAINE += "/"+FILE_NAME

#It the file already exists it is overwritte !
Onerrgo ERRORS
Openo FILE_SPACE+"/"+CHAINE,0 Using [_FILE]
Putseq 1,PARCV.JSON Using [_FILE]
Openo Using [_FILE]
Onerrgo
If ERR
 End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_INTERNAL,ERRTIT)
Else
 Call EXIST(FILE_SPACE+"/"+CHAINE,EXIST) From ASYRSYS
 If !EXIST
  End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(54,149,1),CHAINE))
 Endif
Endif

ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AINFO,[V]CST_AHTTP_OK,func ASYRFNC.MES1(mess(55,149,1),FILE_NAME))
ASND.URL      = PSYR.PREFIX+'/'+CST_AURLFILE
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+CST_AURLFILE
ASNB.HEADERCOD(1) = "Content-Disposition"
ASNB.HEADERVAL(1) = "attachement;filename="+FILE_NAME

End ERROR

#-----------------------------------------------------------------------#
Funprog LOAD(ACTX,ASNB,PSYR,PARCV,KEYS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASNB  Using C_ASYRSNDBLB
Variable Instance PSYR  Using C_ASYR
Variable Instance PARCV Using C_ASYRRCV
Value    Char     KEYS

Local Integer   ERROR : ERROR = [V]CST_AOK

Local Integer I , J , K
Local Integer ERR , NBR_FOLDERS , EXIST , MACHINE
Local Char    ERRTIT(250) , MESSAGE(250) , FOLDER_NAME(80)(1..10)
Local Char    CHAINE(250) , ORDSYS(250) , COMMAND(250)
Local Blbfile WBLOB(12)
Local Char    FILE_SPACE(250) , FILE_NAME(250) , FILE_FULL(250) , FILE_NOREP(250)

FILE_NAME = func GETFILENAME(PARCV,KEYS)
K = instr(1,FILE_NAME,"]")
If K
 J = find("type",PARCV.PARAMCOD)
 If J
  MACHINE = val(PARCV.PARAMVAL(J))
 Else
  MACHINE = 2
 Endif
 ASTATUS = func CTL_VOLFIL(ACTX,MACHINE,FILE_NAME,FILE_FULL)
 If ERROR <> CST_AOK
  End ERROR
 Else
  ERROR = func CTL_VOLFIL(ACTX,MACHINE,left$(FILE_NAME,K)+"/"+string$(10,"_"),FILE_SPACE)
  If ERROR = CST_AOK
   FILE_SPACE = left$(FILE_SPACE,len(FILE_SPACE)-11)
   FILE_NOREP = func CONTROL_PATH(right$(FILE_NAME,K+1))
  Endif
 Endif
Else
 ERROR = func SPACE_PATH(ACTX,"TMP","",FILE_SPACE,MESSAGE)
 FILE_NOREP = func CONTROL_PATH(FILE_NAME)
Endif

If FILE_NOREP=""
 End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(49,149,1),""))
Endif

Call EXIST(FILE_SPACE+"/"+FILE_NOREP,EXIST) From ASYRSYS
If !EXIST
 End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(49,149,1),FILE_NAME))
Else
 Onerrgo ERRORS
 Openi FILE_SPACE+"/"+FILE_NOREP,0 Using [_FILE]
 Getseq 1,WBLOB Using [_FILE]
 Openo Using [_FILE]
 Onerrgo
 If ERR
  End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_INTERNAL,ERRTIT)
 Endif
Endif

ASNB.DATA = WBLOB
ASNB.URL      = PSYR.PREFIX+'/'+CST_AURLFILE
ASNB.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+CST_AURLFILE
#SAM 109938
If ERROR=[V]CST_AOK
  ASNB.HEADERCOD(1) = 'content-disposition'
  ASNB.HEADERVAL(1) = 'attachement;filename="'+FILE_NAME+'"'
Endif
End ERROR

#---------------------------------------------------------------------#
Funprog KIL(ACTX,ASND,PSYR,PARCV,KEYS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASND  Using C_ASYRSND
Variable Instance PSYR  Using C_ASYR
Variable Instance PARCV Using C_ASYRRCV
Value    Char     KEYS

Local Integer   ERROR : ERROR = [V]CST_AOK

Local Integer I , J , K
Local Integer ERR , NBR_FOLDERS , EXIST , STAT , MACHINE
Local Char    ERRTIT(250) , MESSAGE(250) , FOLDER_NAME(80)(1..10)
Local Char    CHAINE(250) , ORDSYS(250) , COMMAND(250)
Local Char    FILE_SPACE(250) , FILE_NAME(250) , FILE_FULL(250) , FILE_NOREP(250)

FILE_NAME = func GETFILENAME(PARCV,KEYS)

K = instr(1,FILE_NAME,"]")
If K
 J = find("type",PARCV.PARAMCOD)
 If J
  MACHINE = val(PARCV.PARAMCOD(J))
 Else
  MACHINE = 2
 Endif
 ERROR = func CTL_VOLFIL(ACTX,MACHINE,FILE_NAME,FILE_FULL)
 If ERROR<>CST_AOK
  End ERROR
 Else
  ERROR = func CTL_VOLFIL(ACTX,MACHINE,left$(FILE_NAME,K)+"/"+string$(10,"_"),FILE_SPACE)
  If ERROR = CST_AOK
   FILE_SPACE = left$(FILE_SPACE,len(FILE_SPACE)-11)
   FILE_NOREP = func CONTROL_PATH(right$(FILE_NAME,K+1))
  Endif
 Endif
Else
 ERROR = func SPACE_PATH(ACTX,"TMP","",FILE_SPACE,MESSAGE)
 If ERROR = CST_AOK
  FILE_NOREP = func CONTROL_PATH(FILE_NAME)
 Endif
Endif

If FILE_NOREP=""
 End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(49,149,1),FILE_NAME))
Endif

Call EXIST(FILE_SPACE+"/"+FILE_NOREP,EXIST) From ASYRSYS
If !EXIST
 End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(49,149,1),FILE_NAME))
Else
 Call _EFFACE(FILE_SPACE+"/"+FILE_NOREP,STAT) From ASYRSYS
 If STAT
  End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(50,149,1),FILE_NAME))
 Else
  Call EXIST(FILE_SPACE+"/"+FILE_NOREP,EXIST) From ASYRSYS
  If EXIST
   End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(50,149,1),FILE_NAME))
  Endif
 Endif
Endif

ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AOK,[V]CST_AHTTP_OK,mess(51,149,1))
ASND.URL      = PSYR.PREFIX+'/'+CST_AURLFILE
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+CST_AURLFILE
End ERROR

#--------------------------------------#
# Errors management
#--------------------------------------#

$ERRORS
ERR = errn
ERRTIT = errmes$(errn)
Resume

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

#---------------------------------------------------------------#
# for delete / at the first and last character of the string
#---------------------------------------------------------------#

Funprog CONTROL_PATH(PATH)
Variable Char PATH

Local Char CHAINE(250)
CHAINE = ctrans(PATH,"\","/")
While left$(CHAINE,1)="/"
 CHAINE = right$(CHAINE,2)
Wend
While right$(CHAINE,len(CHAINE))="/"
 CHAINE = left$(CHAINE,len(CHAINE)-1)
Wend
End CHAINE

#-----------------------------------------------------------#
# The authorized directory for storing files
#-----------------------------------------------------------#

Funprog SPACE_PATH(ACTX,DIRECTORY,FILE_NAME,FILE_FULL,MESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char DIRECTORY , FILE_NAME
Variable Char FILE_FULL , MESSAGE

Local Integer ASTATUS
Local File AVOLUME [AVL]
Raz MESSAGE , FILE_FULL

ASTATUS = CST_AOK
Read [AVL]CODE=DIRECTORY
If fstat
 Read [AVL]CODE=toupper(DIRECTORY)
 If fstat
  Read [AVL]CODE=tolower(DIRECTORY)
 Endif
Endif
If fstat
 ASTATUS = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,mess(47,149,1))
Else
 Case DIRECTORY
  When "patch","PATCH" : FILE_FULL = filpath([F:AVL]ROOT,"","",func ASYRFOLDER.DOSX3(nomap))
  When Default         : FILE_FULL = filpath([F:AVL]ROOT,"","",nomap)
 Endcase
 If len(FILE_NAME)>0
  FILE_FULL += "/" + FILE_NAME
 Endif
Endif
Close Local File [AVL]
End ASTATUS

#------------------------------------------------------------------#
Funprog CTL_VOLFIL(ACTX,MACHINE,FILE_NAME,FILE_FULL)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Integer MACHINE
Value Char FILE_NAME
Variable Char FILE_FULL

Local Char MESSAGE(250),VOLUME(250)
Local Integer I , J , K , ASTATUS
ASTATUS = CST_AOK
If len(FILE_NAME) & pat(FILE_NAME,"[*]/*")
 I = instr(1,FILE_NAME,']/')
 ASTATUS = func SPACE_PATH(ACTX,mid$(FILE_NAME,2,I-2),right$(FILE_NAME,I+2),FILE_FULL,MESSAGE)
Elsif MACHINE=2 & len(FILE_NAME) & pat(FILE_NAME,"[*]")
 VOLUME =  mid$(FILE_NAME,2,len(FILE_NAME)-2)
 ASTATUS = func SPACE_PATH(ACTX,VOLUME,"",FILE_FULL,MESSAGE)
Else
 FILE_FULL = ""
 ASTATUS = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(35,126,1))
Endif
End ASTATUS

#------------------------#
Funprog PARAM(VALEUR)
Value Char VALEUR
If (left$(VALEUR,1)='"' & right$(VALEUR,len(VALEUR))='"') or (left$(VALEUR,1)="'" & right$(VALEUR,len(VALEUR))="'")
 VALEUR = seg$(VALEUR,2,len(VALEUR)-1)
Endif
End VALEUR

#**
#* GETFILENAME
#*
#* @param PARCV
#* @param FILENAM
#*!
Funprog GETFILENAME(PARCV,KEYS)
Variable Instance PARCV Using C_ASYRRCV
Value    Char     KEYS

Local Char FILE_NAME(250)
Local Integer K

K = find("fileName",PARCV.PARAMCOD)
If K
 FILE_NAME = PARCV.PARAMVAL(K)
Else
   K = find("x-file-name",PARCV.HEADERCOD)
   If K
    FILE_NAME = PARCV.HEADERVAL(K)
   Endif
Endif
If FILE_NAME=""
 FILE_NAME = KEYS
Endif
FILE_NAME = func PARAM(FILE_NAME)
End FILE_NAME

