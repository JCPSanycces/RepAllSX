Subprog AS_COMMENT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_COMMENT(VALEUR) From SUBNCSP
If mkstat=2
 [M]COMMENT(INDIC) = VALEUR
 Affzo COMMENT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

