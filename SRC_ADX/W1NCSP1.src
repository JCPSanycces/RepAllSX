Subprog D_LINESTATUS(VALEUR)
Variable Integer VALEUR
If varinit([M]LINESTATUS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LINESTATUS(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

