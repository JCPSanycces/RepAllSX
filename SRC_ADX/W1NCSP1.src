Onevent CONTROL Call C_ACTIONER(zc) From W1NCSP1
Onevent BEFORE_INPUT Call AS_ACTIONER(zc) From W1NCSP1
Return

Subprog AS_ACTIONER(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(485,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ACTIONER(zc) From W1NCSP1
Onkey   2 Titled GBOUTS Call S_ACTIONER(zc) From W1NCSP1
Onkey 144 Titled GBOUTP Call P_ACTIONER(zc) From W1NCSP1
Onkey 146 Titled GBOUTA Call SA_ACTIONER(zc) From W1NCSP1
Gosub _AFF
End

Subprog C_ACTIONER(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ACTIONER" : GZNUM = 52623 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("AUS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACTIONER" : GZNUM = 52623 : Endif
Endif
Gosub _AFF
End

$AMM_ACTIONER
Call AM_ACTIONER(zc)
If !mkstat & GOBJET
 zoncou = "ACTIONER" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ACTIONER(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_ACTIONER(VALEUR) From SUBNCSP
If mkstat : GERR = 1 : GZONE = "ACTIONER" : GZNUM = 52623 : Endif
Gosub _AFF
End

Subprog S_ACTIONER(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "AUS"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ACTIONER(VALEUR)
Variable Char    VALEUR()
Call OBJET("AUS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_ACTIONER(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "AUS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ACTIONER(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("AUS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

