$ON_PLANID
Return

$ON_TRANTYPE
Onevent INIT_AREA Call D_TRANTYPE(zc) From W1NCSP1
Onevent CONTROL Call C_TRANTYPE(zc) From W1NCSP1
Onevent AFTER_CHANGE Gosub AMM_TRANTYPE From W1NCSP1
Onevent BEFORE_INPUT Call AS_TRANTYPE(zc) From W1NCSP1
Return

Subprog D_TRANTYPE(VALEUR)
Variable Char    VALEUR()
If varinit([M]TRANTYPE,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"807","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_TRANTYPE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TRANTYPE(zc) From W1NCSP1
Onkey 144 Titled GBOUTP Call P_TRANTYPE(zc) From W1NCSP1
Onkey 146 Titled GBOUTA Call SA_TRANTYPE(zc) From W1NCSP1
If VALEUR="" : Call INIADI(VALEUR,"807") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_TRANTYPE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"807","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"807",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TRANTYPE
Call AM_TRANTYPE(zc)
If !mkstat & GOBJET
 zoncou = "TRANTYPE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TRANTYPE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TRANTYPE(VALEUR) From SUBNCSP
If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZTRANTYPE)")>indice
 [M]TRANTYPE(indice) = VALEUR
 Affzo ZTRANTYPE(indice)
Endif
Gosub _AFF
End

Subprog S_TRANTYPE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "807"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_TRANTYPE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "807"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TRANTYPE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "807"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTRANTYPE
Onevent BEFORE_AREA Gosub AV_ZTRANTYPE From W1NCSP1
Return

$AV_ZTRANTYPE
Call LECTEXTRA(zc,"ATABDIV","LNGDES","807",num$([M]TRANTYPE(indice))) From ATEXTRA
Gosub _AFF
Return

