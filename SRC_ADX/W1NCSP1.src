Subprog C_COMPLETEDATE(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COMPLETEDATE" : GZNUM = 24640 : Endif
Gosub _AFF
End

