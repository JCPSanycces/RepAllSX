#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSP1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:32"
A_USER  = "DOC"
A_STAMP = "20181109230532"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSP1 [NCSP1]
Gosub HORODAT
Local Inpbox "NCSP1" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSP1] As [SIM_]
Grizo [NCSP1]5
Grizo [NCSP1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSP1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=1
X1(1)=1 : X2(1)=74 : Y1(1)=2 : Y2(1)=25
Return

$ON_IMPLEMENT
Onevent INIT_AREA Call D_IMPLEMENT(zc) From W1NCSP1
Return

Subprog D_IMPLEMENT(VALEUR)
Variable Integer VALEUR
If varinit([M]IMPLEMENT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_NBLIG
Onevent CONTROL Call C_NBLIG From W1NCSP1
Onevent AFTER_AREA Call AP_NBLIG From W1NCSP1
Onevent BEFORE_INPUT Call AS_NBLIG From W1NCSP1
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From SUBNCSP
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(12580,GBOUT1) From OBJDIV
Call TEXTE(33080,GBOUT2) From OBJDIV
Call IB_NBLIG
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1NCSP1
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1NCSP1
Gosub _AFF
End

Subprog C_NBLIG
Local Decimal BASPAG
## Action STD
Call C_NBLIG From SUBNCSP
If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog AP_NBLIG
Local Decimal BASPAG
## Action STD
Call AP_NBLIG From SUBNCSP
If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action ACLOB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ACLOB"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBLIG" : PROGSUB = "SUBNCSP" : PROGSPE = "SPENCSP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:NCSP1]LINTEX(nolign-1)
 PARMSK(2) = "NCP"
 PARMSK(3) = "TRTX3TEX"
 PARMSK(4) = "NCSP1"
 PARMSK(5) = num$(nolign-1)
 PARMSK(6) = "1"
 Call TRAITE_NUM(BASPAG,PARMSK,"","ACLOB","ACLOB",3,"XYACLOB") From GTRAITE
 [M:NCSP1]LINTEX(nolign-1) = PARMSK(1)
 ACTION = "BB1_NBLIG" : PROGSUB = "SUBNCSP" : PROGSPE = "SPENCSP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action MCLOB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "MCLOB"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB2_NBLIG" : PROGSUB = "SUBNCSP" : PROGSPE = "SPENCSP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:NCSP1]LINTEX(nolign-1)
 Call TRAITE_NUM(BASPAG,PARMSK,"","MCLOB","MCLOB",3,"XYMCLOB") From GTRAITE
 [M:NCSP1]LINTEX(nolign-1) = PARMSK(1)
 ACTION = "BB2_NBLIG" : PROGSUB = "SUBNCSP" : PROGSPE = "SPENCSP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_TEXT
Onevent INIT_AREA Call D_TEXT(zc) From W1NCSP1
Return

Subprog D_TEXT(VALEUR)
Variable Integer VALEUR
If varinit([M]TEXT,indice)=0
 VALEUR = 1
Endif
