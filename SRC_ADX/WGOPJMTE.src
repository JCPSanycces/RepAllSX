#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OPJMTE

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:49"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OPJMTE",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="PTEH;PTED;PTEAFF;PTEDIE;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:PTEH])=0 : Local Mask PJMTIMH [PTEH] : Endif
If clalev([M:PTED])=0 : Local Mask PJMTIMD [PTED] : Endif
If clalev([M:PTEAFF])=0 : Local Mask PJMTIMDAFF [PTEAFF] : Endif
If clalev([M:PTEDIE])=0 : Local Mask PJMTIMDIE [PTEDIE] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOPJMTE
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMTE" From GFONCTION At A_STAMP With A_WINDPREV Mask [PTEH]
&   Folder Mask [PTED]
& , Folder Mask [PTEAFF]
& , Folder Mask [PTEDIE]
& As [PTED]
Titled [PTED] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOPJMTE
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPJMTE" From GFONCTION At A_STAMP With A_WINDPREV Mask [PTEH]
&   Folder Mask [PTED]
& , Folder Mask [PTEAFF]
& , Folder Mask [PTEDIE]
& As [PTED]
Titled [PTED] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [PTED] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [PTED] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [PTED]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(48408,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "PJMTIMH"      : ABMSK(0)  = "PTEH"     : AMA(0) = 1
NOMMSK(1) = "PJMTIMD"      : ABMSK(1)  = "PTED"     : AMA(1) = 1
NOMMSK(2) = "PJMTIMDAFF"   : ABMSK(2)  = "PTEAFF"   : AMA(2) = 1
NOMMSK(3) = "PJMTIMDIE"    : ABMSK(3)  = "PTEDIE"   : AMA(3) = 1
NBMASK = 3
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:PTEH])>0 : Default Mask [PTEH] : Endif
 When 1 : If clalev([M:PTED])>0 : Default Mask [PTED] : Endif
 When 2 : If clalev([M:PTEAFF])>0 : Default Mask [PTEAFF] : Endif
 When 3 : If clalev([M:PTEDIE])>0 : Default Mask [PTEDIE] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:PTEH])>0 : Gosub TITRES From W1PJMTIMH : Endif
 When 1 : If clalev([M:PTED])>0 : Gosub TITRES From W1PJMTIMD : Endif
 When 2 : If clalev([M:PTEAFF])>0 : Gosub TITRES From W1PJMTIMDAFF : Endif
 When 3 : If clalev([M:PTEDIE])>0 : Gosub TITRES From W1PJMTIMDIE : Endif
Endcase
Return

$FERME_MASK
If clalev([M:PTEH])>0 : Close Local Mask [PTEH] : Endif
If clalev([M:PTED])>0 : Close Local Mask [PTED] : Endif
If clalev([M:PTEAFF])>0 : Close Local Mask [PTEAFF] : Endif
If clalev([M:PTEDIE])>0 : Close Local Mask [PTEDIE] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:PTEH])>0 : Raz [M:PTEH] : Endif
 When 1 : If clalev([M:PTED])>0 : Raz [M:PTED] : Endif
 When 2 : If clalev([M:PTEAFF])>0 : Raz [M:PTEAFF] : Endif
 When 3 : If clalev([M:PTEDIE])>0 : Raz [M:PTEDIE] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:PTEH])>0 : Affzo [M:PTEH] : Endif
 When 1 : If clalev([M:PTED])>0 : Affzo [M:PTED] : Endif
 When 2 : If clalev([M:PTEAFF])>0 : Affzo [M:PTEAFF] : Endif
 When 3 : If clalev([M:PTEDIE])>0 : Affzo [M:PTEDIE] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Return

$CHARGEMSK
Return

$GRISE_CLE
Return

$DEGRISE_CLE
Return

$BOUTON
STDBOUT = "EA"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1101 : Call TEXTE(13580,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(6084,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "*" : LMEN(NBMEN) = 2001 : Call TEXTE(48408,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "*"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = num$("0")
  PARBOUT(4) = [00/00/0000]
  PARBOUT(5) = [M:PTEH]CLB
  FLGEXE = 1
  GACTION = "CONSPTE"
  Call CONSULT_CHAR(VALBOUT,"PTE",PARBOUT) From GCONSULT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


