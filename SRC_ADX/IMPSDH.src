#<AdxTL>@(#)9.0.0.0 $Revision$
#######################################################################
# IMPSDH : Export Standard des Livraisons
#          Import / Export textes : traitements appeles depuis IMPSDHS
#----------------------------------------------------------------------
#
#######################################################################
$ACTION

Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE  
 When "IMPORT"        : Gosub IMPORT 
 When "IMP_ZONE"      : Gosub IMP_ZONE 
 When "IMP_TAB"       : Gosub IMP_TAB 
 When "EXP_OUVRE"     : Gosub EXP_OUVRE  
 When "EXPORT"        : Gosub EXPORT 
 When "EXP_ZONE"      : Gosub EXP_ZONE 
Endcase

Return

#######################################################################
#                        IMPORT
#######################################################################

$IMP_OUVRE
Gosub OUVRE_TEXTE

Return

#---------------------------------------------------------------------
#   Appele depuis IMPSDHS
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1 
  When "EXP_OUVRE"    : G_EXPORT=1 
Endcase

#     entete *71 à *78 / pied *81 à *88 / ligne *91 à *98
#     les zones TSTCHAMP  1 à  8 determinent l'entete
#     les zones TSTCHAMP 11 à 18 determinent le pied
#     les zones TSTCHAMP 21 à 28 determinent le detail
# lignes entete
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="SDH*71" : TSTCHAMP(2) ="SDH*72" : TSTCHAMP(3) ="SDH*73" : TSTCHAMP(4) ="SDH*74"
TSTCHAMP(5) ="SDH*75" : TSTCHAMP(6) ="SDH*76" : TSTCHAMP(7) ="SDH*77" : TSTCHAMP(8) ="SDH*78"
# lignes pied
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="SDH*81" : TSTCHAMP(12)="SDH*82" : TSTCHAMP(13)="SDH*83" : TSTCHAMP(14)="SDH*84"
TSTCHAMP(15)="SDH*85" : TSTCHAMP(16)="SDH*86" : TSTCHAMP(17)="SDH*87" : TSTCHAMP(18)="SDH*88"
# lignes detail
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
TSTCHAMP(21)="SDD*91" : TSTCHAMP(22)="SDD*92" : TSTCHAMP(23)="SDD*93" : TSTCHAMP(24)="SDD*94"
TSTCHAMP(25)="SDD*95" : TSTCHAMP(26)="SDD*96" : TSTCHAMP(27)="SDD*97" : TSTCHAMP(28)="SDD*98"

Gosub OUVRE_TEXTE From TRTX3IMP
# --- 
Return

#######################################################################
#   Lecture d'un enregistrement

$IMPORT
Local Integer OKCHAMP
Local Integer I

Gosub IMPORT_TEXTE

Return

#----------------------------------------------------------------------
#   Appele depuis IMPSDHS
#---
$IMPORT_TEXTE
Raz G_NLDET

Case IMPFIC
  When "SDH" : 

    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1) 
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif 

    If G_PIE     : # --- Texte pied --- 
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif

  When "SDD"

    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif

Endcase

Return

#----------------------------------------------------------------------
#   Appele depuis IMPSDHS
#---
$AVANT_SCEE
If dim([M:SCEE]XEECNAT)>0 & dim([M:SDH0]EECNAT)>0    : [M:SCEE]XEECNAT = [M:SDH0]EECNAT : Endif
If dim([M:SCEE]XEECSCH)>0 & dim([M:SDH0]EECSCH)>0    : [M:SCEE]XEECSCH = [M:SDH0]EECSCH : Endif
If dim([M:SCEE]XEECLOC)>0 & dim([M:SDH0]EECLOC)>0    : [M:SCEE]XEECLOC = [M:SDH0]EECLOC : Endif 
If dim([M:SCEE]XEECTRN)>0 & dim([M:SDH0]EECTRN)>0    : [M:SCEE]XEECTRN = [M:SDH0]EECTRN : Endif 
If dim([M:SCEE]XEECICT)>0 & dim([M:SDH0]EECICT)>0    : [M:SCEE]XEECICT = [M:SDH0]EECICT : Endif 
If dim([M:SCEE]XICTCTY)>0 & dim([M:SDH0]ICTCTY)>0    : [M:SCEE]XICTCTY = [M:SDH0]ICTCTY : Endif 
If dim([M:SCEE]XFFWNUM)>0 & dim([M:SDH0]FFWNUM)>0    : [M:SCEE]XFFWNUM = [M:SDH0]FFWNUM : Endif 
If dim([M:SCEE]XFFWADD)>0 & dim([M:SDH0]FFWADD)>0    : [M:SCEE]XFFWADD = [M:SDH0]FFWADD : Endif 
If dim([M:SCEE]XEECNUM)>0 & dim([M:SDH0]BPIEECNUM)>0 : [M:SCEE]XEECNUM = [M:SDH0]BPIEECNUM : Endif 
Return

#----------------------------------------------------------------------
#   Appele depuis IMPSDHS
#---
$APRES_SCEE
If dim([M:SCEE]XEECNAT)>0 & dim([M:SDH0]EECNAT)>0    : [M:SDH0]EECNAT    = [M:SCEE]XEECNAT : Endif 
If dim([M:SCEE]XEECSCH)>0 & dim([M:SDH0]EECSCH)>0    : [M:SDH0]EECSCH    = [M:SCEE]XEECSCH : Endif 
If dim([M:SCEE]XEECLOC)>0 & dim([M:SDH0]EECLOC)>0    : [M:SDH0]EECLOC    = [M:SCEE]XEECLOC : Endif 
If dim([M:SCEE]XEECTRN)>0 & dim([M:SDH0]EECTRN)>0    : [M:SDH0]EECTRN    = [M:SCEE]XEECTRN : Endif 
If dim([M:SCEE]XEECICT)>0 & dim([M:SDH0]EECICT)>0    : [M:SDH0]EECICT    = [M:SCEE]XEECICT : Endif 
If dim([M:SCEE]XICTCTY)>0 & dim([M:SDH0]ICTCTY)>0    : [M:SDH0]ICTCTY    = [M:SCEE]XICTCTY : Endif 
If dim([M:SCEE]XFFWNUM)>0 & dim([M:SDH0]FFWNUM)>0    : [M:SDH0]FFWNUM    = [M:SCEE]XFFWNUM : Endif 
If dim([M:SCEE]XFFWADD)>0 & dim([M:SDH0]FFWADD)>0    : [M:SDH0]FFWADD    = [M:SCEE]XFFWADD : Endif 
If dim([M:SCEE]XEECNUM)>0 & dim([M:SDH0]BPIEECNUM)>0 : [M:SDH0]BPIEECNUM = [M:SCEE]XEECNUM : Endif 
Return

#######################################################################

$IMP_ZONE

Gosub IMP_ZONE_TEXTE

Return

#----------------------------------------------------------------------
#   Appele depuis IMPSDHS
#---
$IMP_ZONE_TEXTE

If IMPFIC="SDH"
#       Texte entete
   If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C"
      [M:SDH0]SDHTEX1=[M:ITC]T_CLE_CLOB(1)
   Endif 
#       Texte pied
   If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C"
      [M:SDH0]SDHTEX2=[M:ITC]T_CLE_CLOB(2)
   Endif
Endif

Return

#######################################################################

$IMP_TAB

Gosub IMP_TAB_TEXTE

Return

#----------------------------------------------------------------------
#   Appele depuis IMPSDHS
$IMP_TAB_TEXTE
If IMPFIC="SDD" 
#       Texte detail
    If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & GREP="C" 
       [M:SDH1]SDDTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
    Endif 
Endif

Return

#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE

Global Integer GDEVSOCRND  : # stockage code arrondi devise societe
Raz GIMP
If clalev([F:SIH])=0    : Local File SINVOICE   [SIH]   : Endif
If clalev([F:SIV])=0    : Local File SINVOICEV  [SIV]   : Endif 
If clalev([F:SVF])=0    : Local File SVCRFOOT   [SVF]   : Endif    
If clalev([F:SVV])=0    : Local File SVCRVAT    [SVV]   : Endif    

If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:TCU])=0    : Local File TABCUR     [TCU]   : Endif
If clalev([F:TCO])=0    : Local File TABCOEFF   [TCO]   : Endif

If clalev([F:BPR])=0    : Local File BPARTNER   [BPR]   : Endif
If clalev([F:BPC])=0    : Local File BPCUSTOMER [BPC]   : Endif
If clalev([F:BPD])=0    : Local File BPDLVCUST  [BPD]   : Endif
If clalev([F:BPT])=0    : Local File BPCARRIER  [BPT]   : Endif
If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif
If clalev([F:SOH])=0    : Local File SORDER     [SOH]   : Endif
If clalev([F:SOP])=0    : Local File SORDERP    [SOP]   : Endif
If clalev([F:SOQ])=0    : Local File SORDERQ    [SOQ]   : Endif

If clalev([F:ITM])=0    : Local File ITMMASTER  [ITM]   : Endif
If clalev([F:ITS])=0    : Local File ITMSALES   [ITS]   : Endif
If clalev([F:ITU])=0    : Local File ITMBPC     [ITU]   : Endif

If clalev([F:SDD1])=0   : Local File SDELIVERYD [SDD1]  : Endif

#-- pour les textes
Gosub OUVRE_TEXTE
#--

Return

#######################################################################

$EXPORT
Case EXPFIC
  When "SDH"
    GIMP(21)=num$(1)         : # initialisation coef. multi poids entête
    Raz [F:CPY], [F:FCY]
    Raz [F:BPR], [F:BPC], [F:BPD], [F:BPT], [F:BPA]
    Raz [F:SOH], [F:SOP], [F:SOQ]
    Raz [F:ITM], [F:ITS], [F:ITU]     
    Raz [F:SDD1]
#    # retrouver la société avec le site de vente
#    Read [FCY]FCY0=[F:SDH]SALFCY
#    If fstat : Raz [F:FCY] : Endif
    Read [CPY]CPY0=[F:SDH]CPY
    If fstat : Raz [F:CPY] : Endif
    If [F:CPY]ACCCUR<>[F:TCU]CUR
      Read [TCU]TCU0=[F:CPY]ACCCUR
      If fstat : Raz [F:TCU] : Endif
    Endif
    GDEVSOCRND=[F:TCU]CURRND 

    If G_ENT 
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:SDH]SDHTEX1)>0 & [F:SDH]SDHTEX1<>"" 
          G_CLE_CLOB=[F:SDH]SDHTEX1 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP 
       Endif
    Endif 
    If G_PIE 
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:SDH]SDHTEX2)>0 & [F:SDH]SDHTEX2<>""
          G_CLE_CLOB=[F:SDH]SDHTEX2 : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP 
       Endif
    Endif 

  When "SDD"
    GIMP(53)=num$(1)         : # initialisation coef. multi poids ligne
    Raz [F:ITM], [F:ITS], [F:ITU] 

    If G_DET 
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:SDD]SDDTEX)>0 & [F:SDD]SDDTEX<>""
          G_CLE_CLOB=[F:SDD]SDDTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP 
       Endif
    Endif 

Endcase

Return

#######################################################################

$EXP_ZONE
Case EXPZON
  When "GIMP(3)"    : Gosub E_GIMP3        : # Chgt adresse société
  When "GIMP(4)"    : Gosub E_GIMP4        : # Chgt site expedition (livraison)
  When "GIMP(5)"    : Gosub E_GIMP5        : # Chgt client facture
  When "GIMP(6)"    : Gosub E_GIMP6        : # Chgt client commande
  When "GIMP(7)"    : Gosub E_GIMP7        : # Chgt client payeur
  When "GIMP(8)"    : Gosub E_GIMP8        : # Chgt client livré
  When "GIMP(9)"    : Gosub E_GIMP9        : # Chgt transporteur

  When "GIMP(15)"   : Gosub E_GIMP15       : # Commande

  When "GIMP(21)"   : Gosub E_GIMP21       : # Coef. multi. poids en KG (entête)     
  When "GIMP(52)"   : Gosub E_GIMP52       : # Chgt article 
  When "GIMP(53)"   : Gosub E_GIMP53       : # Coef. multi. poids en KG (ligne)

  When Default

Endcase

Return

#----------------------------------------------------------------------
#   Société ( [F:CPY] + [F:BPA] société ) 
$E_GIMP3
Raz [F:BPA]
## retrouver la société avec le site de vente
#Read [FCY]FCY0=[F:SDH]SALFCY
#If fstat : Raz [F:FCY] : Endif
Read [CPY]CPY0=[F:SDH]CPY
If fstat : Raz [F:CPY] : Endif
Read [BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Site expedition ( [F:FCY] + [F:BPA] site expedition )
$E_GIMP4
If [F:FCY]FCY<>[F:SDH]STOFCY
  Read [FCY]FCY0=[F:SDH]STOFCY
    If fstat : Raz [F:FCY] : Endif
Endif
Read [BPA]BPA0=3;[F:SDH]STOFCY;[F:FCY]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client facture ( [F:BPR] + [F:BPC] + [F:BPA] client facture )
$E_GIMP5
If [F:BPC]BPCNUM<>[F:SDH]BPCINV
  Read [BPC]BPC0=[F:SDH]BPCINV 
  If fstat : Raz [F:BPC] : Endif
Endif
If [F:BPR]BPRNUM<>[F:SDH]BPCINV
  Read [BPR]BPR0=[F:SDH]BPCINV 
  If fstat : Raz [F:BPR] : Endif
Endif
Raz [F:BPA]

# -- test si adresse modifiée
If [F:SDH]BPINAM    <> "" | [F:SDH]BPIADDLIG <> "" |
&  [F:SDH]BPIPOSCOD <> "" | [F:SDH]BPICTY    <> "" |
&  [F:SDH]BPISAT    <> "" | 
&  [F:SDH]BPICRY    <> "" | [F:SDH]BPICRYNAM <> "" 
  [F:BPA]BPADES       = [F:SDH]BPINAM(0)
  [F:BPA]BPAADDLIG(0) = [F:SDH]BPIADDLIG(0)
  [F:BPA]BPAADDLIG(1) = [F:SDH]BPIADDLIG(1)
  [F:BPA]BPAADDLIG(2) = [F:SDH]BPIADDLIG(2)
  [F:BPA]POSCOD       = [F:SDH]BPIPOSCOD
  [F:BPA]CTY          = [F:SDH]BPICTY
  [F:BPA]SAT          = [F:SDH]BPISAT
  [F:BPA]CRY          = [F:SDH]BPICRY
  [F:BPA]CRYNAM       = [F:SDH]BPICRYNAM
Else
#  Read [BPA]BPA0=1;[F:SDH]BPCINV;[F:BPC]BPAINV
  Read [BPA]BPA0=1;[F:SDH]BPCINV;[F:SDH]BPAINV
  If fstat : Raz [F:BPA] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Client commande ( [F:BPC] + [F:BPA] client cde : adresse)
$E_GIMP6
If [F:BPC]BPCNUM<>[F:SDH]BPCORD
  Read [BPC]BPC0=[F:SDH]BPCORD 
  If fstat : Raz [F:BPC] : Endif
Endif
#   si client divers (prendre adresse de facture)
If [F:BPC]BPCTYP=2 : Gosub E_GIMP5 : Return : Endif
#   adresse par defaut
Raz [F:BPA]
Read [BPA]BPA0=1;[F:SDH]BPCORD;[F:BPC]BPAADD
  If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client payeur ( [F:BPC] + [F:BPA] client payeur : adresse )
$E_GIMP7
If [F:BPC]BPCNUM<>[F:SDH]BPCPYR
  Read [BPC]BPC0=[F:SDH]BPCPYR 
  If fstat : Raz [F:BPC] : Endif
Endif
#   si client divers (prendre adresse de facture)
If [F:BPC]BPCTYP=2 : Gosub E_GIMP5 : Return : Endif
#   adresse par defaut
Raz [F:BPA]
Read [BPA]BPA0=1;[F:SDH]BPCPYR;[F:BPC]BPAADD
If fstat : Raz [F:BPA] : Endif
Return

#----------------------------------------------------------------------
#   Client livré ( [F:BPD] + [F:BPA] )
$E_GIMP8
Raz [F:BPD], [F:BPA]
#   
Read [F:BPD]BPD0=[F:SDH]BPCORD; [F:SDH]BPAADD
If fstat : Raz [F:BPD] : Endif
# -- test si adresse modifiée
If [F:SDH]BPDNAM    <> ""   |  [F:SDH]BPDADDLIG <> ""  |
&  [F:SDH]BPDPOSCOD <> ""   |  [F:SDH]BPDCTY    <> ""  |
&  [F:SDH]BPDSAT    <> ""   | 
&  [F:SDH]BPDCRY    <> ""   |  [F:SDH]BPDCRYNAM <> "" 
  [F:BPA]BPADES       = [F:SDH]BPDNAM(0)
  [F:BPA]BPAADDLIG(0) = [F:SDH]BPDADDLIG(0)
  [F:BPA]BPAADDLIG(1) = [F:SDH]BPDADDLIG(1)
  [F:BPA]BPAADDLIG(2) = [F:SDH]BPDADDLIG(2)
  [F:BPA]POSCOD       = [F:SDH]BPDPOSCOD
  [F:BPA]CTY          = [F:SDH]BPDCTY
  [F:BPA]SAT          = [F:SDH]BPDSAT
  [F:BPA]CRY          = [F:SDH]BPDCRY
  [F:BPA]CRYNAM       = [F:SDH]BPDCRYNAM
Else
  Read [BPA]BPA0=1;[F:SDH]BPCORD;[F:SDH]BPAADD
  If fstat : Raz [F:BPA] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Transporteur ( [F:BPT] + [F:BPA] )
$E_GIMP9
Raz [F:BPT], [F:BPA]
Read [BPT]BPT0=[F:SDH]BPTNUM
If fstat : Raz [F:BPT] : Endif
Read [F:BPA]BPA0=1;[F:SDH]BPTNUM;[F:BPT]BPAADD
If fstat : Raz [F:BPA] : Endif 
Return

#----------------------------------------------------------------------
#   Commande (de 1ere ligne livraison si ligne entete)
$E_GIMP15

Case EXPFIC
  When "SDH"
    Raz [F:SOH]
#      lecture du 1er enr. détail de la livraison
    Filter [SDD1] Where SDHNUM=[F:SDH]SDHNUM 
    Read [SDD1]SDD0 First
    If !fstat & [F:SDD1]SDHNUM=[F:SDH]SDHNUM & [F:SDD1]SOHNUM<>""
      Read [F:SOH]SOH0=[F:SDD1]SOHNUM
      If fstat : Raz [F:SOH] : Endif
      Read [F:SOP]SOP0=[F:SDD1]SOHNUM;[F:SDD1]SOPLIN;[F:SDD1]SOPLIN
      If fstat : Raz [F:SOP] : Endif
      Read [F:SOQ]SOQ0=[F:SDD1]SOHNUM;[F:SDD1]SOPLIN;[F:SDD1]SOQSEQ
      If fstat : Raz [F:SOQ] : Endif
    Endif
    Filter [SDD1] 
  When "SDD"
    Raz [F:SOH]
    If [F:SDD]SOHNUM<>"" 
      Read [F:SOH]SOH0=[F:SDD]SOHNUM
      If fstat : Raz [F:SOH] : Endif
      Read [F:SOP]SOP0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOPLIN
      If fstat : Raz [F:SOP] : Endif
      Read [F:SOQ]SOQ0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
      If fstat : Raz [F:SOQ] : Endif
    Endif
Endcase
Return

#----------------------------------------------------------------------
#   Coef. multiplicateur du poids entête (pour obtenir des Kg)
$E_GIMP21
If toupper(left$([F:SDH]WEU,2))="KG"
  GIMP(21)=num$(1)
Else
  I=find("KG",GUNITE(1..GDIMUNT))
  If I=0 : I=find("Kg",GUNITE(1..GDIMUNT)) : Endif
  If I=0 : I=find("kg",GUNITE(1..GDIMUNT)) : Endif
  If I<>0
    Read [TCO]TCO0=[F:SDH]WEU;GUNITE(I)
    If !fstat GIMP(21)=num$([F:TCO]COEUOM) Endif
  Endif
Endif
Return

#----------------------------------------------------------------------
#   Chgt article ( [F:ITM] + [F:ITS] + [F:ITU] )
$E_GIMP52
Raz [F:ITM], [F:ITS], [F:ITU]
If [F:ITM]ITMREF<>[F:SDD]ITMREF
  Read [ITM]ITM0=[F:SDD]ITMREF 
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:SDD]ITMREF
  Read [ITS]ITS0=[F:SDD]ITMREF 
  If fstat : Raz [F:ITS] : Endif
Endif
If [F:ITU]ITMREF<>[F:SDD]ITMREF | [F:ITU]BPCNUM<>[F:SDH]BPCORD
  Read [ITU]ITU0=[F:SDD]ITMREF;[F:SDH]BPCORD 
  If fstat : Raz [F:ITU] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Coef. multiplicateur du poids ligne (pour obtenir des Kg)
$E_GIMP53
If toupper(left$([F:SDD]WEU,2))="KG"
  GIMP(53)=num$(1)
Else
  I=find("KG",GUNITE(1..GDIMUNT))
  If I=0 : I=find("Kg",GUNITE(1..GDIMUNT)) : Endif
  If I=0 : I=find("kg",GUNITE(1..GDIMUNT)) : Endif
  If I<>0
    Read [TCO]TCO0=[F:SDD]WEU;GUNITE(I)
    If !fstat GIMP(53)=num$([F:TCO]COEUOM) Endif
  Endif
 Endif

Return

#######################################################################

