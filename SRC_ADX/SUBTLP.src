#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du fichier TABLINCFG
$ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "LIENS"         : Gosub LIENS
  When "ANNULE"        : Gosub ANNULE
  When "SETBOUT"       : Gosub SETBOUT 
  When "EXEBOUT"       : Gosub EXEBOUT
  When "INICRE"        : Gosub MAJ_TABLE
  When "AVANT_MODFIC"  : Gosub MAJ_TABLE
  When "AV_IMPRIME"    : Gosub COP_ECRAN
                         OK = 0 
  When "AV_LISTE"      : Gosub LIS_TLP
                         OK = 0 
  When "FERME"         : Gosub FERME 
  When "VALID"         : # bouton :rien pour modifier le moins possible
  When "VISUM"         : # 2è bouton
  When "TRT_DIV"       # GACTION "VISUM"    vide pas modélisée
  When "CHANGE"        : Call CHANGE_AXX ("TABLINCFG", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return
###########################################################
$OUVRE
adxmbm = adxmbm
Return
###########################################################
$EXEBOUT 
Case REP 
  When "a" : 
    Gosub MAJ_TABLE
  When "b" : 
    If !GINTRA 
      Call VISUM("WUL"+CLECUR1) From SUBAMK 
    Endif 
Endcase
Return 
########################################################### 
$SETBOUT 
Call VIREBOUT(CHAINE,"H") From GOBJET :# chgt de clé désactivé
If [M:TLP0]CFGLIN = ""
  Call VIREBOUT(CHAINE,"ab") From GOBJET
Endif
Return 
###########################################################
$FERME
Call IMPSCR From ATRTX3
Return
###########################################################
$COP_ECRAN
Local Char WMSK(10)(2)
Local Char WABR(06)(2)
WMSK(0) = "TLP0"
WMSK(1) = "TLP1"
Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
Return
############################################################
$LIS_TLP
Local Integer W_I, W_J
Local Char    W_EV1(40)
Local Char    W_EV2(40)
Local Char    W_EV3(40)
Local Char    W_TXT(20)
#
If clalev([F:TLP1]) = 0 : Local File TABLINCFG [TLP1] : Endif
Local Mask TLP9 [TLP9]
#
Raz [M:TLP9]
Filter [TLP1]
For [TLP1]
  If [M:TLP9]NBLIG1 < dim([M:TLP9]CFGLIN)-2
    [M:TLP9]CFGLIN    ([M:TLP9]NBLIG1) = [F:TLP1]CFGLIN
    Call LECTEXTRA([M:TLP9]CFGLINAXX([M:TLP9]NBLIG1),"TABLINCFG","CFGLINAXX",[F:TLP1]CFGLIN,"") From ATEXTRA
    For W_I = 1 To 6
      W_EV1 = "[F:TLP1]CFGNUM"+num$(W_I)
      W_EV2 = "[F:TLP1]CFGNUMCOD"+num$(W_I)
      W_EV3 = "[F:TLP1]CFGNUMTCT"+num$(W_I)
      If evalue(W_EV1) <> 1
        W_J = evalue(W_EV1)
        Call ATT_TXT(W_J,W_TXT) From CFGLIB
        Assign "[M:TLP9]CFGNUM"+num$(W_I)+"([M:TLP9]NBLIG1)" With W_TXT
        W_TXT = mess(evalue(W_EV2),762,1)
        Assign "[M:TLP9]CFGNUM"+num$(W_I)+"([M:TLP9]NBLIG1+1)" With W_TXT-evalue(W_EV3)
      Endif
      W_EV1 = "[F:TLP1]CFGALP"+num$(W_I)
      W_EV2 = "[F:TLP1]CFGALPCOD"+num$(W_I)
      W_EV3 = "[F:TLP1]CFGALPTCT"+num$(W_I)
      If evalue(W_EV1) <> 1
        W_J = evalue(W_EV1)
        Call ATT_TXT(W_J,W_TXT) From CFGLIB
        Assign "[M:TLP9]CFGALP"+num$(W_I)+"([M:TLP9]NBLIG1)" With W_TXT
        W_TXT = mess(evalue(W_EV2),762,1)
        Assign "[M:TLP9]CFGALP"+num$(W_I)+"([M:TLP9]NBLIG1+1)" With W_TXT-evalue(W_EV3)
      Endif
    Next W_I
    [M:TLP9]NBLIG1 += 2
  Endif
  If [M:TLP9]NBLIG2 < dim([M:TLP9]CFGLIN1)-1
    [M:TLP9]CFGLIN1   ([M:TLP9]NBLIG2) = [F:TLP1]CFGLIN
    Call LECTEXTRA([M:TLP9]CFGLINAXX1([M:TLP9]NBLIG2),"TABLINCFG","CFGLINAXX",[F:TLP1]CFGLIN,"") From ATEXTRA
    For W_I = 1 To [F:TLP1]ITMFLDNBR
      Call FLD_TXT("ITMMASTER",[F:TLP1]ITMFLD(W_I-1),[F:TLP1]CFGLIN,W_TXT) From CFGLIB
      Assign "[M:TLP9]ITMFLD"+num$(W_I)+"([M:TLP9]NBLIG2)" With [F:TLP1]ITMFLD(W_I-1)-W_TXT
    Next W_I
    [M:TLP9]NBLIG2 += 1
  Endif 
Next
Filter [TLP1]
Call PRTSCR("TLP9","TLP9","",0,0) From ATRTX3
Close Local Mask [TLP9]
Return
###########################################################
$LIENS
Local Integer W_I
Local Char    W_EVA(40)
For W_I = 0 To dim([M]CFGNUM)-1
  W_EVA = "[F:TLP]CFGNUM"+num$(W_I+1)
  [M:TLP1]CFGNUM(W_I)    = evalue(W_EVA) 
  W_EVA = "[F:TLP]CFGNUMCOD"+num$(W_I+1)
  [M:TLP1]CFGNUMCOD(W_I) = evalue(W_EVA) 
  W_EVA = "[F:TLP]CFGNUMTCT"+num$(W_I+1)
  [M:TLP1]CFGNUMTCT(W_I) = evalue(W_EVA) 
Next W_I
For W_I = 0 To dim([M]CFGALP)-1
  W_EVA = "[F:TLP]CFGALP"+num$(W_I+1)
  [M:TLP1]CFGALP(W_I)    = evalue(W_EVA) 
  W_EVA = "[F:TLP]CFGALPCOD"+num$(W_I+1)
  [M:TLP1]CFGALPCOD(W_I) = evalue(W_EVA) 
  W_EVA = "[F:TLP]CFGALPTCT"+num$(W_I+1)
  [M:TLP1]CFGALPTCT(W_I) = evalue(W_EVA) 
Next W_I
[M:TLP1]NBLIG1 = dim([M]CFGNUM)
[M:TLP1]NBLIG2 = dim([M]CFGALP)
Affzo [M:TLP1]1-99
#
If clalev([M:TLP2]) > 0
  For W_I = 0 To [M:TLP2]ITMFLDNBR-1
    Call SYM_TXT([M:TLP2]ITMFLDTXT(W_I),13,[M:TLP2]ITMFLD(W_I),[M:TLP0]CFGLIN) From CFGLIB
  Next W_I
  Affzo [M:TLP2]1-99
Endif
Return
###########################################################
$MAJ_TABLE
Local Integer W_I
Local Char    W_EVA(40)
Local Char    W_APL 
For W_I = 0 To dim([M]CFGNUM)-1
  W_EVA = "[F:TLP]CFGNUM"+num$(W_I+1)
  Assign W_EVA With [M:TLP1]CFGNUM(W_I)  
  W_EVA = "[F:TLP]CFGNUMCOD"+num$(W_I+1)
  Assign W_EVA With [M:TLP1]CFGNUMCOD(W_I)
  W_EVA = "[F:TLP]CFGNUMTCT"+num$(W_I+1)
  Assign W_EVA With [M:TLP1]CFGNUMTCT(W_I)
Next W_I
For W_I = 0 To dim([M]CFGALP)-1
  W_EVA = "[F:TLP]CFGALP"+num$(W_I+1)
  Assign W_EVA With [M:TLP1]CFGALP(W_I) 
  W_EVA = "[F:TLP]CFGALPCOD"+num$(W_I+1)
  Assign W_EVA With [M:TLP1]CFGALPCOD(W_I)
  W_EVA = "[F:TLP]CFGALPTCT"+num$(W_I+1)
  Assign W_EVA With [M:TLP1]CFGALPTCT(W_I)
Next W_I
# Génération écran
Call TEMPON ("O") From GESECRAN
#
W_APL = nomap
If dim([M:TLP0]SCENUM) > 0
  Call GEN_LIN(W_APL,"CFGLIN","WUL"+[M:TLP0]CFGLIN,[M:TLP1]CFGNUM,[M:TLP1]CFGNUMCOD,
&              [M:TLP1]CFGNUMTCT,[M:TLP1]CFGALP,[M:TLP1]CFGALPCOD,[M:TLP1]CFGALPTCT)
&      From CFGLIBA
Else
  Call GEN_LIN(W_APL,"CFGLIN1","WUL"+[M:TLP0]CFGLIN,[M:TLP1]CFGNUM,[M:TLP1]CFGNUMCOD,
&              [M:TLP1]CFGNUMTCT,[M:TLP1]CFGALP,[M:TLP1]CFGALPCOD,[M:TLP1]CFGALPTCT)
&      From CFGLIBA
Endif  
Call TEMPOFF From GESECRAN
Call MAJTEXTRA([M:TLP0]CFGLINAXX,"TABLINCFG","CFGLINAXX",[M:TLP0]CFGLIN,"") From ATEXTRA
Return
###########################################################
$ANNULE
Delete [AXX] Where CODFIC="TABLINCFG" & ZONE="CFGLINAXX" & CLE1= [M:TLP0]CFGLIN
Call DEL_WIN(nomap,"WUL"+[M:TLP0]CFGLIN,"","") From CFGLIBA
Return
############################################################
Subprog AS_CFGLINAXX(VALEUR)
Variable Char    VALEUR()
If GREP = "C" 
  Local Integer W_I
  For W_I = 0 To dim([M]CFGNUM)-1
    [M:TLP1]CFGNUM(W_I)    = 1
    [M:TLP1]CFGNUMCOD(W_I) = 4
    [M:TLP1]CFGNUMTCT(W_I) = ""
  Next W_I
  For W_I = 0 To dim([M]CFGNUM)-1
    [M:TLP1]CFGALP(W_I)    = 1
    [M:TLP1]CFGALPCOD(W_I) = 4
    [M:TLP1]CFGALPTCT(W_I) = ""
  Next W_I
  [M:TLP1]NBLIG1 = dim([M]CFGNUM)
  [M:TLP1]NBLIG2 = dim([M]CFGALP)
  Affzo [M:TLP1]1-99 
Endif
End
############################################################
Subprog AM_CFGNUM(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:TLP1]CFGNUMCOD(nolign-1) = 4
  [M:TLP1]CFGNUMTCT(nolign-1) = ""
  Affzo [M:TLP1]CFGNUMCOD(nolign-1)
  Affzo [M:TLP1]CFGNUMTCT(nolign-1)
Endif
End
############################################################
Subprog AM_CFGALP(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:TLP1]CFGALPCOD(nolign-1) = 4
  [M:TLP1]CFGALPTCT(nolign-1) = ""
  Affzo [M:TLP1]CFGALPCOD(nolign-1)
  Affzo [M:TLP1]CFGALPTCT(nolign-1)
Endif
End
############################################################
Subprog AS_CFGNUMCOD(VALEUR)
Variable Integer VALEUR
If [M:TLP1]CFGNUM(nolign-1) = 1    
  VALEUR = 4    
  mkstat = 2
Else
  GMENLOC(4) = 1
Endif
End
############################################################
Subprog AP_CFGNUMCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
############################################################
Subprog AS_CFGALPCOD(VALEUR)
Variable Integer VALEUR
If [M:TLP1]CFGALP(nolign-1) = 1
  VALEUR = 4    
  mkstat = 2
Else
  GMENLOC(4) = 1
Endif
End
############################################################
Subprog AP_CFGALPCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
############################################################
Subprog AM_CFGNUMCOD(VALEUR)
Variable Integer VALEUR
If VALEUR > 2
  [M:TLP1]CFGNUMTCT(nolign-1) = ""
  Affzo [M:TLP1]CFGNUMTCT(nolign-1)
Endif
End
############################################################
Subprog AM_CFGALPCOD(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  [M:TLP1]CFGALPTCT(nolign-1) = ""
  Affzo [M:TLP1]CFGALPTCT(nolign-1) 
Endif
End
############################################################
Subprog AS_CFGNUM(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog C_CFGNUM(VALEUR)
Variable Integer VALEUR
Local Integer W_I, W_J
W_J = nolign
If VALEUR > 1
  Local Integer W_I
  For W_I = 0 To [M:TLP1]NBLIG1 -1
    If W_I <> nolign-1 
      If [M:TLP1]CFGNUM(W_I) = VALEUR
        GMESSAGE = mess(24,123,1)-num$(W_I+1) : # Code déjà existant en ligne
        mkstat=2 
        Break
      Endif
    Endif
  Next W_I 
  For W_I = 0 To [M:TLP1]NBLIG2 -1
    If [M:TLP1]CFGALP(W_I) = VALEUR
      GMESSAGE = mess(24,123,1)-num$(W_I+1) : # Code déjà existant en ligne
      mkstat=2 
      Break
    Endif
  Next W_I 
  If GMESSAGE = ""
    Call CTR_UTILIS(VALEUR,W_J)
  Endif 
Endif
End
############################################################
Subprog AS_CFGALP(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog C_CFGALP(VALEUR)
Variable Integer VALEUR
Local Integer W_I, W_J
W_J = nolign+6
If VALEUR > 1
  Local Integer W_I
  For W_I = 0 To [M:TLP1]NBLIG2 -1
    If W_I <> nolign-1 
      If [M:TLP1]CFGALP(W_I) = VALEUR
        GMESSAGE = mess(24,123,1)-num$(W_I+1) : # Code déjà existant en ligne
        mkstat=2 
        Break
      Endif
    Endif
  Next W_I 
  For W_I = 0 To [M:TLP1]NBLIG1 -1
    If [M:TLP1]CFGNUM(W_I) = VALEUR
      GMESSAGE = mess(24,123,1)-num$(W_I+1) : # Code déjà existant en ligne
      mkstat=2 
      Break
    Endif
  Next W_I 
  If GMESSAGE = ""
    Call CTR_UTILIS(VALEUR,W_J)
  Endif
Endif
End
############################################################
Subprog CTR_UTILIS(LVAL,LNOL)
Variable Integer  LVAL
Variable Integer  LNOL
#
# Aider au classement d'un même code attribut sur un même champs attributs. (e21458)

#
Local    Integer  W_I
If clalev([F:TLP1]) = 0 : Local File TABLINCFG   [TLP1] : Endif
Filter [TLP1] Where CFGLIN <> [M:TLP0]CFGLIN
&             Order By Key TLP0
For [TLP1]
   If LVAL = [F:TLP1]CFGNUM1 & LNOL <>  1 |
&     LVAL = [F:TLP1]CFGNUM2 & LNOL <>  2 |      
&     LVAL = [F:TLP1]CFGNUM3 & LNOL <>  3 |  
&     LVAL = [F:TLP1]CFGNUM4 & LNOL <>  4 |  
&     LVAL = [F:TLP1]CFGNUM5 & LNOL <>  5 |  
&     LVAL = [F:TLP1]CFGNUM6 & LNOL <>  6 |  
&     LVAL = [F:TLP1]CFGALP1 & LNOL <>  7 |
&     LVAL = [F:TLP1]CFGALP2 & LNOL <>  8 |      
&     LVAL = [F:TLP1]CFGALP3 & LNOL <>  9 |  
&     LVAL = [F:TLP1]CFGALP4 & LNOL <> 10 |  
&     LVAL = [F:TLP1]CFGALP5 & LNOL <> 11 |  
&     LVAL = [F:TLP1]CFGALP6 & LNOL <> 12
     If GMESSAGE = ""
       Call ATT_TXT(LVAL,GMESSAGE) From CFGLIB
       GMESSAGE += " : "+mess(20,188,1)+"\("
     Endif
     GMESSAGE += [F:TLP1]CFGLIN+" "
   Endif
Next
Filter [TLP1]
If GMESSAGE <> ""
  GMESSAGE += ")"
  W_I = 1
  Call AVERTIR(GMESSAGE,W_I) From GESECRAN
  If W_I = 1
    mkstat = 2
  Endif
Endif
End
############################################################
Subprog AS_CFGNUMTCT(VALEUR)
Variable Char    VALEUR()
If !([M:TLP1]CFGNUMCOD(nolign-1) = 1 | [M:TLP1]CFGNUMCOD(nolign-1) = 2)
  mkstat = 2
Endif
End
############################################################
Subprog AS_CFGALPTCT(VALEUR)
Variable Char    VALEUR()
If !([M:TLP1]CFGALPCOD(nolign-1) = 1 | [M:TLP1]CFGALPCOD(nolign-1) = 2)
  mkstat = 2
Endif
End
############################################################
Subprog C_CFGLIN(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,"/") 
  mkstat = 2
Endif
End
############################################################
Subprog C_ITMFLD(VALEUR)
Variable Char    VALEUR()
Read [ATZ]CODZONE="ITMMASTER";VALEUR
If fstat 
  mkstat = 2
  End
Endif 
If (VALEUR = "CFGFLDNUM1" & [M:TLP1]CFGNUM(0) = 1) |
&  (VALEUR = "CFGFLDNUM2" & [M:TLP1]CFGNUM(1) = 1) |
&  (VALEUR = "CFGFLDNUM3" & [M:TLP1]CFGNUM(2) = 1) |
&  (VALEUR = "CFGFLDNUM4" & [M:TLP1]CFGNUM(3) = 1) |
&  (VALEUR = "CFGFLDNUM5" & [M:TLP1]CFGNUM(4) = 1) |
&  (VALEUR = "CFGFLDNUM6" & [M:TLP1]CFGNUM(5) = 1) |
&  (VALEUR = "CFGFLDALP1" & [M:TLP1]CFGALP(0) = 1) |
&  (VALEUR = "CFGFLDALP2" & [M:TLP1]CFGALP(1) = 1) |
&  (VALEUR = "CFGFLDALP3" & [M:TLP1]CFGALP(2) = 1) |
&  (VALEUR = "CFGFLDALP4" & [M:TLP1]CFGALP(3) = 1) |
&  (VALEUR = "CFGFLDALP5" & [M:TLP1]CFGALP(4) = 1) |
&  (VALEUR = "CFGFLDALP6" & [M:TLP1]CFGALP(5) = 1) 
  GMESSAGE = VALEUR-mess(69,188,1)
  mkstat = 2
  End
Endif
Case VALEUR
  When "CFGFLDNUM1" : Call ATT_TXT([M:TLP1]CFGNUM(0),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDNUM2" : Call ATT_TXT([M:TLP1]CFGNUM(1),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDNUM3" : Call ATT_TXT([M:TLP1]CFGNUM(2),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDNUM4" : Call ATT_TXT([M:TLP1]CFGNUM(3),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDNUM5" : Call ATT_TXT([M:TLP1]CFGNUM(4),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDNUM6" : Call ATT_TXT([M:TLP1]CFGNUM(5),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDALP1" : Call ATT_TXT([M:TLP1]CFGALP(0),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDALP2" : Call ATT_TXT([M:TLP1]CFGALP(1),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDALP3" : Call ATT_TXT([M:TLP1]CFGALP(2),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDALP4" : Call ATT_TXT([M:TLP1]CFGALP(3),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDALP5" : Call ATT_TXT([M:TLP1]CFGALP(4),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When "CFGFLDALP6" : Call ATT_TXT([M:TLP1]CFGALP(5),[M]ITMFLDTXT(nolign-1)) From CFGLIB
  When Default      : Call SYM_TXT([M]ITMFLDTXT(nolign-1),13,VALEUR,[M:TLP0]CFGLIN) From CFGLIB
Endcase
Affzo [M]ITMFLDTXT(nolign-1)
End
