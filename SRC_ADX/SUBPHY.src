#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#                    GESTION DES ELEMENTS PHYSIQUES
#
#*********************************************************************
#    Création
#    STA MHB - 20/05/2008
#
#*********************************************************************
#    Modification
# Issue X3-109499 -2018-09-20 MDJ : RD - Events Icon in header
# CBO   17.02.2015 FQ100398/13: Liaison FXD PHY : ne garder que la visu
# MDJ   09.02.2015 FQ100398 : Suppression site géographique
# CBO   29.04.2014 FQ69690  : Suppresion de BACFLG
# GLE   12.03.2013 FQ88593  : Pas de message sur la quantité dans certains cas
# GLE   12.03.2013 FQ88168  : Plantage en import si le bien de rattachement n'est pas immatriculable
# MWA   31.10.2012 FQ85464  : Prise en compte de la legislation dans la numérotation automatique
# CBO   26.01.2012 FQ79442  : Numérotation automatique des codes barres
#*********************************************************************
#
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("PHY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

  Case ACTION
    When "SETTRANS"      : Local Integer LPHYTRS : Gosub SET_TRS_PARM From SUBTSH
    When "OUVRE"         : Gosub OUVRE
    When "LIENS"         : Gosub LIENS

    When "APRES_CHOI"    : Gosub GES_OBJ_METIER
    When "FIN"           : Gosub FIN

    When Default
  Endcase

Return
######################################################################################
# Initialisation des variables                                                       #
######################################################################################
$OUVRE

Global Integer G_TUNNEL_FAS
Global Integer G_SAV_CONSULT
Global Integer VERR_BIEN

# Numérotation des éléments physiques à partir du bien
If GPHY = G_OUI
  Global Char    G_ELEMENTS(GLONPHY)(1..999) # Va servir à stocker les éléments rattachés à un bien
Endif
Global Integer G_NOUVEAU_BIEN     # Mis à G_OUI quand on change de bien
G_NOUVEAU_BIEN = G_NON
# umérotation des éléments physiques à partir du bien

  # Pour récupérer les libellés des zones libres
  Gosub OUVRE From SUBFRZ
  # Afin de permettre la relecture des paramètres
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY

  If !clalev([F:ABB]) : Local File ABLOB [ABB] : Endif
  If dim(G_TRSSAV)>0 : Kill G_TRSSAV : Endif
  #=> Globale contenant le nom de la transaction en cours pour exploitation dans les actions métiers
  Global Char G_TRSSAV : G_TRSSAV=GBOITE
  # Alimentation de NAVIG par la fonction appelante pour savoir si on vient directement de la fonction ou par tunnel
  # NAVIG="GESPHY"

  # On déplace ici la sauvegarde du GCONSULT, car si on change d'élément,
  # on repasse dans $LIENS, et il est écrasé
  If GPHY=G_OUI
    If GPILNAV > 1
      If find(GNAVIG(GPILNAV-1),"GESFAS")
        G_SAV_CONSULT = GCONSULT
      Endif
    Endif
  Endif
Return

$INIT_LIENS
Local Integer I,J
Local Char STYLE

  # FQ100398/13
  If clalev([F:PMVT]) = 0
    Local File PHYMVT [PMVT]
  Endif : # Mouvements Eléments physiques

  I = 0
  For [PMVT]PMVT0 Where PHYREF = [F:PHY]PHYREF

    [M:PHY1]MVT(I) = [F:PMVT]MVT
    [M:PHY1]MVTDAT(I) = [F:PMVT]MVTDAT

    If [M:PHY1]MVT(I) = GVMLPMVISS
      [M:PHY1]MVTSORT(I)= [F:PMVT]MVTISSTYP
    Else
      [M:PHY1]MVTTRANS(I)= [F:PMVT]MVTTRANS

      [M:PHY1]MVTFCY(I)= [F:PMVT]MVTFCY
      [M:PHY1]MVTLCTCOD(I)= [F:PMVT]MVTLCTCOD
    Endif

    I += 1
  Next

  NBLIG = I
  # Diszo pour ne pas entrer en mode modif sur un tableau non saisissable lorsqu'on entre dessus
  Diszo [M:PHY1]NBLIG
  [M:PHY1]BPR = [F:PHY]BPS
  [M:PHY0]PHYDES1 = [F:PHY]PHYDES1
  [M:PHY0]PHYDES2 = [F:PHY]PHYDES2
  [M:PHY0]ENAPHY = [F:PHY]ENAFLG # FQ110245
#  [M:PHY9]CREDAT = [F:PHY]CREDATTIM # FQ110245
#  [M:PHY9]UPDDAT = [F:PHY]UPDDATTIM # FQ110245

  STYLE=""
  If [M:PHY1]ISSDAT<>[0/0/0]
    STYLE="ISSFIYPRE"
  Endif
  Chgstl [M:PHY0]PHYREF  With STYLE
  Chgstl [M:PHY0]PHYDES1 With STYLE
  Chgstl [M:PHY0]PHYDES2 With STYLE

  VERR_BIEN=G_NON
  If [M:PHY0]AASREF<>""
    LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([M:PHY0]AASREF)
    # On teste si lock logique du bien par l'objet
    If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [M:PHY0]CPY, LLOCK) <> 1 )
      VERR_BIEN=G_OUI
    Else
      # On teste si lock logique du bien par globiens(avec sépareur)
      # et lock par globiens (avec séparateur)
      If ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [M:PHY0]CPY, LLOCK,0) <> 1 )
        VERR_BIEN=G_OUI
      Endif
    Endif
  Endif
Return


######################################################################################
$LIENS                                                                               #
######################################################################################
Local Integer I
Local Char    LLOCK(200)
Local Integer OUVFIC

  Gosub INIT_LIENS

  Read [ABB]ABB0="ELTPHY";[F:PHY]PHYREF;""
  If !fstat
    [M:PHY2]PHOTO = [F:ABB]BLOB
  Endif

  # si tunnel depuis bien comptable (GESFAS) vers les éléments phy, il faut recharger les évts relatifs aux élts
  G_TUNNEL_FAS=G_NON
  If GPHY=G_OUI
    If GPILNAV > 1
      If find(GNAVIG(GPILNAV-1),"GESFAS")
        G_TUNNEL_FAS=G_OUI
        # La sauvegarde du GCONSULT est déplacée dans $OUVRE, car si on change d'élément,
        # on repasse dans $LIENS, et il est écrasé
        GCONSULT = 1
        Diszo [M:PHY0]
        Diszo [M:PHY1]
        Diszo [M:PHY2]
        Diszo [M:PHY9]
        # X3-109499 Actzo [M:PHY9] EVTLIST
        Actzo [M:PHY0]EVTLIST # on ré active le bouton de vision des évenements
        Grizo [M:PHY1]NBLIG  # on grise le tableau pour ne plus avoir accés au clic droit.
      Endif
    Endif
  Endif

  # Transfert de site financier : alimentation de la nouvelle zone FCY0
  [M:PHY0]FCY0 = [M:PHY0]FCY

Return

######################################################################################
$GES_OBJ_METIER
  Gosub ACTION From TRTOBJACT
  Local Integer TRTOBJ : Gosub ACTION From TRUPROACT : Kill TRTOBJ #=> Modèle action unitaire V2
Return

######################################################################################
# KILL sur les globales créées                                                       #
######################################################################################
$FIN

  If dim (G_SAV_CONSULT)>0 : GCONSULT = G_SAV_CONSULT : Kill G_SAV_CONSULT : Endif
  If dim (VERR_BIEN)>0     Kill VERR_BIEN Endif

  # Numérotation des éléments physiques à partir du bien
  If G_TUNNEL_FAS = G_NON
    If dim(G_ELEMENTS)>0     : Kill G_ELEMENTS     : Endif
    If dim(G_NOUVEAU_BIEN)>0 : Kill G_NOUVEAU_BIEN : Endif
  Endif

Return

######################################################################################
# Issue X3-109499 - RD - Events Icon in header
######################################################################################
Subprog CL_EVTLIST(VALEUR)
Variable Char    VALEUR()

 Call CL_EVTLIST(VALEUR) From SUBFRZ

End

######################################################################################

