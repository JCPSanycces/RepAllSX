#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRAFRCLS1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone LIGNUM
mkstat = 0
zoncou = "LIGNUM"
indice = 0
status = 1
zoncou = "LIGNUM"
If varmode([M]LIGNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LIGNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]LIGNUM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]LIGNUM = nolign
   status = 75
   Call SAI_LIGNUM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_LIGNUM(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone LIGNUM
mkstat = 0
zoncou = "LIGNUM"

## Zone PYRMON
mkstat = 0
zoncou = "PYRMON"
If varmode([M]PYRMON,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PYRMON" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PYRMON(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PYRMON" : GZNUM = 44798 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]FCY(indice)) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]FCY(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CPY
mkstat = 0
zoncou = "CPY"
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPY(indice)) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!",[M]CPY(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone EQUEMPTYP
mkstat = 0
zoncou = "EQUEMPTYP"
IMPENT = [M]EQUEMPTYP(indice)
If varinit([M]EQUEMPTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]EQUEMPTYP,indice)=0
 [M]EQUEMPTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EQUEMPTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EQUEMPTYP(indice)
 Endif
Endif
[M]EQUEMPTYP(indice) = IMPENT

## Zone OCPLEV
mkstat = 0
zoncou = "OCPLEV"
IMPENT = [M]OCPLEV(indice)
If varinit([M]OCPLEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]OCPLEV,indice)=0
 [M]OCPLEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OCPLEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OCPLEV(indice)
 Endif
Endif
[M]OCPLEV(indice) = IMPENT

## Zone RCEGRP
mkstat = 0
zoncou = "RCEGRP"
IMPENT = [M]RCEGRP(indice)
If varinit([M]RCEGRP,indice)=0
 IMPENT = 1
Endif
If varmode([M]RCEGRP,indice)=0
 [M]RCEGRP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RCEGRP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RCEGRP(indice)
 Endif
Endif
[M]RCEGRP(indice) = IMPENT

## Zone SEX
mkstat = 0
zoncou = "SEX"
IMPENT = [M]SEX(indice)
If varinit([M]SEX,indice)=0
 IMPENT = 1
Endif
If varmode([M]SEX,indice)=0
 [M]SEX(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEX" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SEX(indice)
 Endif
Endif
[M]SEX(indice) = IMPENT

## Zone OFOCOD
mkstat = 0
zoncou = "OFOCOD"
If varmode([M]OFOCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OFOCOD" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("HRSOFO1","!",[M]OFOCOD(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OFOCOD" : GZNUM = 55243 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone OCPBEFVAL
mkstat = 0
zoncou = "OCPBEFVAL"
If varmode([M]OCPBEFVAL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OCPBEFVAL" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone OCPAFTVAL
mkstat = 0
zoncou = "OCPAFTVAL"
If varmode([M]OCPAFTVAL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OCPAFTVAL" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone STG
mkstat = 0
zoncou = "STG"
IMPENT = [M]STG(indice)
If varinit([M]STG,indice)=0
 IMPENT = 1
Endif
If varmode([M]STG,indice)=0
 [M]STG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "STG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]STG(indice)
 Endif
Endif
[M]STG(indice) = IMPENT

## Zone HDCFLG
mkstat = 0
zoncou = "HDCFLG"
IMPENT = [M]HDCFLG(indice)
If varinit([M]HDCFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]HDCFLG,indice)=0
 [M]HDCFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HDCFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]HDCFLG(indice)
 Endif
Endif
[M]HDCFLG(indice) = IMPENT

## Zone CRY
mkstat = 0
zoncou = "CRY"
If varinit([M]CRY,indice)=0
 [M]CRY(indice) = func SUBHRACSA.GET_CRY()
Endif
If varmode([M]CRY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]CRY(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 263 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PRV
mkstat = 0
zoncou = "PRV"
If varmode([M]PRV,indice)=0
 SAVACT = GACTION : GACTION = "SAISAT"
 Call SAISAT(CRY,"") From TRTDIV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PRV(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRV" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CTLSAT"
  PARAM(1) = CRY
  PARAM(2) = ""
  Local Char    VALEUR(250)
  VALEUR = [M]PRV(indice)
  Call S_AFF_CHAR(VALEUR,PARAM,"CTLSAT","TRTDIV","") From GACTION
  [M]PRV(indice) = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRV" : GZNUM = 13511 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CHGCMT
mkstat = 0
zoncou = "CHGCMT"
If varmode([M]CHGCMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CHGCMT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_CHGCMT([M]CHGCMT(indice)) From SUBHRACSA
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHGCMT" : GZNUM = 821 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LIGNUM
mkstat = 0
zoncou = "LIGNUM"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRAFRCLS1"
Return

