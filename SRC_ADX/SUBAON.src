#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet AON
Raz GPILOBJ , GNBMASKOUV
GBIDC3 = "ZZM"
Call OBJET("AON",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAONB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "CHANGE"      : Gosub CHANGE
 When "SETBOUT"     : Gosub SETBOUT
 When "FILTRE"      : Gosub FILTRE
 When "STYLE"       : Gosub STYLE
 When "DEGRISE"     : Gosub DEGRISE
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "FIN"         : Gosub FIN
 When "BUREAU"      : Gosub BUREAU
 When "INICRE"      : Gosub INICRE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_TABLE"  : Gosub VERF_TABLE
Endcase
If PSUBB
 Gosub ACTION From SUBAONB
Endif
Return

#--------------------------------------------#
$OUVRE
Global Char GOBJAON(30)
GOBJAON = GBIDC3
Return

#--------------------------------------------#
$FIN
Kill GOBJAON
Return

#--------------------------------------------#
$FILTRE
If dim(GOBJAON)>0 and GOBJAON<>""
 FILTRE = 'ABREV="'+GOBJAON+'"'
Endif
Return

#--------------------------------------------#
$SETBOUT
If CLECUR<>0 & REP<>"M" and VERROU
 CHAINE += "AH"
Endif
Return

#--------------------------------------------#
# Pour éviter de perdre la saisie du clob
$DEGRISE
# Aztuze pour rendre l'écran invalide après création ou modif
$STYLE
# Aztuze pour rendre l'écran invalide après la lecture
Setmok [M] With 0
Return

#--------------------------------------------#
$RAZCRE
Gosub GRISE_LEG
Gosub INIT_TRN
Return

#--------------------------------------------#
$LIENS
Call LECTEXTRA([M]INTIT,"AOBJBURMOD","INTIT",[M]ABREV,[M]TRNCPYMOD) From ATEXTRA
Gosub GRISE_LEG
Gosub INIT_TRN
Return

#----------------#
$GRISE_LEG
If dim([M]LEG)>0
 If [M]CPY=""
  Actzo LEG
 Else
  Grizo LEG
 Endif
Endif
Return

#----------------#
$INIT_TRN
[M]CODTYP = "AT1"
[M]NOLIB = 0
[M]LONG = GLONAT1
Return

#----------------#
$INICRE
If [F:AON]LEG="" & !func AFNC.ACTIV("LEG")
 [F:AON]LEG = GDOSLEG
Endif
Return

#--------------------------------------------#
$MODIF
$CREATION
Call MAJTEXTRA([M]INTIT,"AOBJBURMOD","INTIT",[M]ABREV,[M]TRNCPYMOD) From ATEXTRA
Return

#--------------------------------------------#
$CHANGE
Update [AXX] Where CODFIC="AOBJBURMOD" & IDENT1=[L]OCODE & IDENT2=[L]SUPP With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AOBJBURMOD"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#--------------------------------------------#
$ANNULE
Call SUPTEXTRA("AOBJBURMOD","INTIT",[L]CODE,[L]SUPP) From ATEXTRA
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#--------------------------------------------#
$BUREAU
If clalev([F:ASB])=0 : Local File ABLBSYS [ASB] : Endif
Case [M]TYP
 When 5 : Read [ASB]ASB0="MIS";"WORD"       : If !fstat : [M]BLOB = [F:ASB]BLOB : Affzo BLOB : Endif
 When 6 : Read [ASB]ASB0="MIS";"EXCEL"      : If !fstat : [M]BLOB = [F:ASB]BLOB : Affzo BLOB : Endif
 When 7 : Read [ASB]ASB0="MIS";"POWERPOINT" : If !fstat : [M]BLOB = [F:ASB]BLOB : Affzo BLOB : Endif
Endcase
Return

#----------------------------------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ASELBUR"
  Local Char ZONCUR(30)
  If zoncou<>"" & indice>=0 & evalue("dim([M]"+zoncou+")")>0
   ZONCUR = "[M]"+zoncou+"("+num$(indice)+")"
  Endif
  If ZONCUR="" or evalue("len("+ZONCUR+")")<>0
   OK = 0 : Return
  Endif
  OBJET = "AON"
  If PARAM(1)<>"" : # Objet
   CRITERE = '(ABREV="" or ABREV="'+PARAM(1)+'")'
  Else
   CRITERE = 'ABREV=""'
  Endif
  If PARAM(2)<>"" : # Transaction
   CRITERE -= '& (TRN="" or TRN="'+PARAM(2)+'")'
  Else
   CRITERE -= '& TRN=""'
  Endif
  If PARAM(3)<>"" : # Société
   CRITERE -= '& (CPY="" or CPY="'+PARAM(3)+'")'
  Else
   CRITERE -= '& CPY=""'
  Endif
  If func AFNC.ACTIV("LEG") & dim([V]GCURLEG)>0 & GCURLEG<>""
   CRITERE -= '& (LEG="" or LEG="'+GCURLEG+'")'
  Endif
  If find(PARAM(4),"5","6","7") : # Word/Excel/PowerPoint
   CRITERE -= '& TYP='+num$(val(PARAM(4))) : # Type de doc
  Endif
  If clalev([F:AON])=0 : Local File AOBJBURMOD [AON] : Endif
  K = 0
  For [AON] Where evalue(CRITERE)
   K += 1
  Next AON
  If K=1
   # Issue 93240 - 2013-10-10 by VPO : zc must be affected , not [M]....
   #Assign ZONCUR With [F:AON]BLOB
   zc=[F:AON]BLOB
   OK = 0
  Elsif !K
   OK = 0
  Endif
Endcase
Return

$VERF_TABLE
Case TABLE
 When "ASELBUR"
  # Issue 93240 - 2013-10-10 by VPO : zc must be affected , not [M]....
  #Assign ZONCUR With [F:AON]BLOB
  zc=[F:AON]BLOB
Endcase
Return

#-----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AOBJBURMOD  [AON1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".AOBJBURMOD"  [AON1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AOBJBURMOD  [AON2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".AOBJBURMOD"  [AON2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Local Integer MONOLEG
Local Char DOSLEG(30)(1..30)
Local Integer NBLEG
Call SETLEG([M]DOSDES,DOSLEG,NBLEG) From DOSCONT
MONOLEG = !func AFNC.ACTIVDOS([M]DOSDES,"LEG")
OK = 1
If GTRACE=""
 For [AON1]AON0 Where ABREV=TABLE & TRN=TABLE2 & CPY=TABLE3 & MODELE=TABLE4
  If [F:AON1]LEG<>""& !find([F:AON1]LEG,DOSLEG)
   OK =0 : Call ERREUR([F:AON1]LEG-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
  Break
  Endif
 Next
 If OK
  Read [AON2]AON0 = TABLE;TABLE2;TABLE3;TABLE4
  If !fstat
   OK=1 : Call AVERTIR([M]DOSDES-TABLE-TABLE2-TABLE3-TABLE4-mess(22,100,1),OK) From GESECRAN
   If OK<>2 : OK = 0 : Endif
  Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AON1], [AON2] , [AXX1] , [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [AON2]
 OK = 1
 For [AON1]AON0 Where ABREV=TABLE & TRN=TABLE2 & CPY=TABLE3 & MODELE=TABLE4
  If [F:AON1]LEG<>""& !find([F:AON1]LEG,DOSLEG)
   OK =0
  Break
  Endif
 Next
 If OK
  Delete [AON2] Where ABREV=TABLE & TRN=TABLE2 & CPY=TABLE3 & MODELE=TABLE4
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".AOBJBURMOD" : Goto ROLL_TR_COP
  Elsif fstat>5
   GOK = 0 : Call RSTA("AON2","") From GLOCK : Goto AB_TR_COP
  Endif
  For [AON1]AON0 Where ABREV=TABLE & TRN=TABLE2 & CPY=TABLE3 & MODELE=TABLE4
   [F:AON2] = [F:AON1]
   Call COPTEXTRA("AOBJBURMOD","INTIT",[F:AON1]ABREV,[F:AON1]TRNCPYMOD) From ATEXTRA
   If GOK<>1 : Break : Endif
   If dim([F:AON2]UPDUSR)>0 : [F:AON2]UPDUSR = GUSER : Endif
   If dim([F:AON2]UPDDAT)>0 : [F:AON2]UPDDAT = date$ : Endif
   If dim([F:AON2]UPDTIM)>0 : [F:AON2]UPDTIM = time  : Endif
   If MONOLEG & [F:AON2]LEG="" : [F:AON2]LEG = DOSLEG(1) : Endif
   Write [AON2]
   If fstat
    GOK=0 : Call FSTA("AON2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------------------------------------------------------------------#
# Lecture d'un document bureautique modèle
#----------------------------------------------------------------------------------------------------#

Subprog LECBLOBMOD(ABREV,CLE1,CLE2,CLE3,TYP,DOC)
Value Char ABREV,CLE1,CLE2,CLE3
Variable Integer TYP
Variable Blbfile DOC
If ABREV="" : End : Endif
If clalev([F:AON])=0 : Local File AOBJBURMOD [AON] : Endif
Read [AON]AON0 = ABREV;CLE1;CLE2;CLE3
If fstat=0
 [L]TYP = [F:AON]TYP
 [L]DOC = [F:AON]BLOB
Else
 Raz [L]TYP , [L]DOC
Endif
End

#----------------------------------------------------------------------------------------------------#
# Lecture d'un document bureautique
#----------------------------------------------------------------------------------------------------#

Subprog LECBLOB(ABREV,CLE1,CLE2,CLE3,TYP,DOC)
Value Char ABREV,CLE1,CLE2,CLE3
Variable Integer TYP
Variable Blbfile DOC
Local Char CLEBIS(GLONID2)
If ABREV="" : End : Endif
Call SETCLE(ABREV,CLEBIS,CLE2) From GOBJTXT
If clalev([F:AOA])=0 : Local File AOBJBUR [AOA] : Endif
Read [AOA]AOA0 = ABREV;CLE1;CLEBIS;CLE3
If fstat=0
 [L]TYP = [F:AOA]TYP
 [L]DOC = [F:AOA]BLOB
Else
 Raz [L]TYP , [L]DOC
Endif
End

#----------------------------------------------------------------------------------------------------#
# Création ou modification d'un document bureautique
#----------------------------------------------------------------------------------------------------#

Subprog MAJBLOB(ABREV,CLE1,CLE2,CLE3,TYP,DOC)
Value Char ABREV,CLE1,CLE2,CLE3
Value Integer TYP
Value Blbfile DOC
Local Char CLEBIS(GLONID2) , ACTION(20)
If ABREV="" : End : Endif
Call SETCLE(ABREV,CLEBIS,CLE2) From GOBJTXT
If clalev([F:AOA])=0 : Local File AOBJBUR [AOA] : Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_MAJBLB
Else
 Gosub MAJBLB
Endif
End

$TR_MAJBLB
Trbegin [AOA]
 Gosub MAJBLB
 If GOK=-1 : Goto ROLL_MAJBLB
 Elsif GOK<1 : Goto AB_MAJBLB
 Endif
Commit
Return

$AB_MAJBLB
Rollback
Return

$ROLL_MAJBLB
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJBLB : Endif

$MAJBLB
Readlock [AOA]AOA0 = ABREV;CLE1;CLEBIS;CLE3
If fstat=1
 GOK=-1 : GLOCK="$AOBJBUR"
Elsif !fstat
 [F:AOA]TYP  = [L]TYP
 [F:AOA]BLOB = [L]DOC
 If dim([F:AOA]UPDDAT)>0 : [F:AOA]UPDDAT = date$ : Endif
 If dim([F:AOA]UPDUSR)>0 : [F:AOA]UPDUSR = GUSER : Endif
 If dim([F:AOA]UPDTIM)>0 : [F:AOA]UPDTIM = time : Endif

 ACTION = "MAJBLB" : Gosub ACTION

 Rewrite [AOA]
 If fstat
  GOK=0 : Call FSTA("AOA") From GLOCK
 Endif
Else
 Raz [F:AOA]
 [F:AOA]ABREV  = [L]ABREV
 [F:AOA]IDENT1 = [L]CLE1
 [F:AOA]IDENT2 = [L]CLEBIS
 [F:AOA]IDENT3 = [L]CLE3
 [F:AOA]TYP    = [L]TYP
 [F:AOA]BLOB   = [L]DOC
 If dim([F:AOA]CREDAT)>0 : [F:AOA]CREDAT = date$ : Endif
 If dim([F:AOA]CREUSR)>0 : [F:AOA]CREUSR = GUSER : Endif
 If dim([F:AOA]CRETIM)>0 : [F:AOA]CRETIM = time : Endif

 ACTION = "MAJBLB" : Gosub ACTION

 Write [AOA]
 If fstat
  GOK=0 : Call FSTA("AOA") From GLOCK
 Endif
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Suppression d'un document bureautique
#----------------------------------------------------------------------------------------------------#

Subprog SUPBLOB(ABREV,CLE1,CLE2,CLE3)
Value Char ABREV,CLE1,CLE2,CLE3
Local Char CLEBIS(GLONID2)
If ABREV="" : End : Endif
Call SETCLE(ABREV,CLEBIS,CLE2) From GOBJTXT
If clalev([F:AOA])=0 : Local File AOBJBUR [AOA] : Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_SUPBLB
Else
 Gosub SUPBLB
Endif
End

$TR_SUPBLB
Trbegin [AOA]
 Gosub SUPBLB
 If GOK=-1 : Goto ROLL_SUPBLB
 Elsif GOK<1 : Goto AB_SUPBLB
 Endif
Commit
Return

$AB_SUPBLB
Rollback
Return

$ROLL_SUPBLB
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_SUPBLB : Endif

$SUPBLB
Delete [AOA] Where ABREV=[L]ABREV & IDENT1=CLE1 & IDENT2=CLEBIS & IDENT3=CLE3
If fstat=1
 GOK=-1 : GLOCK="$AOBJBUR"
Elsif fstat
 GOK=0 : Call FSTA("AOA") From GLOCK
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Duplication d'un document bureautique
#----------------------------------------------------------------------------------------------------#

Subprog DUPBLOB(ABRORG,CLEORG1,CLEORG2,CLEORG3,ABRDES,CLEDES1,CLEDES2,CLEDES3)
Value    Char    ABRORG,CLEORG1,CLEORG2,CLEORG3,ABRDES,CLEDES1,CLEDES2,CLEDES3
Local Char BISORG(GLONID2) , BISDES(GLONID2)
If ABRORG=ABRDES & CLEORG1=CLEDES1 & CLEORG2=CLEDES2 & CLEORG3=CLEDES3
 End
Endif
Call SETCLE(ABRORG,BISORG,CLEORG2) From GOBJTXT
Call SETCLE(ABRDES,BISDES,CLEDES2) From GOBJTXT
If clalev([F:AOA])=0 : Local File AOBJBUR [AOA] : Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_DUPBLB
Else
 Gosub DUPBLB
Endif
End

$TR_DUPBLB
Trbegin [AOA]
 Gosub DUPBLB
 If GOK=-1 : Goto ROLL_DUPBLB
 Elsif GOK<1 : Goto AB_DUPBLB
 Endif
Commit
Return

$AB_DUPBLB
Rollback
Return

$ROLL_DUPBLB
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DUPBLB : Endif

$DUPBLB
Delete [AOA] Where ABREV=ABRDES & IDENT1=CLEDES1 & IDENT2=BISDES & IDENT3=CLEDES3
If fstat=1
 GOK=-1 : Call RSTA("AOA",ABRDES-CLEDES1-BISDES-CLEDES3) From GLOCK
Endif
Read [AOA]AOA0=ABRORG;CLEORG1;BISORG;CLEORG3
If !fstat
 [F:AOA]ABREV  = ABRDES
 [F:AOA]IDENT1 = CLEDES1
 [F:AOA]IDENT2 = BISDES
 [F:AOA]IDENT3 = CLEDES3
 If dim([F:AOA]CREDAT)>0 : [F:AOA]CREDAT = date$ : Endif
 If dim([F:AOA]CREUSR)>0 : [F:AOA]CREUSR = GUSER : Endif
 If dim([F:AOA]CRETIM)>0 : [F:AOA]CRETIM = time : Endif
 Write [AOA]
 If fstat
  GOK=0 : Call FSTA("AOA") From GLOCK
 Endif
Endif
Return

#-------------------------------------------------------------------------------------------------------#
# Copie d'un document bureautique
#-------------------------------------------------------------------------------------------------------#

Subprog COPBLOB(ABREV,CLE1,CLE2,CLE3)
Value    Char    ABREV,CLE1,CLE2,CLE3
Local Char CLEBIS(GLONID2)
Call SETCLE(ABREV,CLEBIS,CLE2) From GOBJTXT
If clalev([F:AOA])=0 : Local File AOBJBUR [AOA] : Endif
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_COPBLB
Else
 Gosub COPBLB
Endif
End

$TR_COPBLB
Trbegin [AOA]
 Gosub COPBLB
 If GOK=-1 : Goto ROLL_COPBLB
 Elsif GOK<1 : Goto AB_COPBLB
 Endif
Commit
Return

$AB_COPBLB
Rollback
Return

$ROLL_COPBLB
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COPBLB : Endif

$COPBLB
Read [AOA1]AOA0 = ABREV;CLE1;CLEBIS;CLE3
If !fstat
 Readlock [AOA2]AOA0 = ABREV;CLE1;CLEBIS;CLE3
 If fstat=1
  GOK=-1 : GLOCK="$AOBJBUR" : End
 Elsif !fstat
  [F:AOA2]BLOB = [F:AOA1]BLOB
  [F:AOA2]TYP  = [F:AOA1]TYP
  If dim([F:AOA2]UPDDAT)>0 : [F:AOA2]UPDDAT = date$ : Endif
  If dim([F:AOA2]UPDUSR)>0 : [F:AOA2]UPDUSR = GUSER : Endif
  If dim([F:AOA2]UPDTIM)>0 : [F:AOA2]UPDTIM = time  : Endif
  Rewrite [AOA2]
  If fstat
   GOK=0 : Call FSTA("AOA2") From GLOCK : End
  Endif
 Else
  [F:AOA2] = [F:AOA1]
  If dim([F:AOA2]CREDAT)>0 : [F:AOA2]CREDAT = date$ : Endif
  If dim([F:AOA2]CREUSR)>0 : [F:AOA2]CREUSR = GUSER : Endif
  If dim([F:AOA2]CRETIM)>0 : [F:AOA2]CRETIM = time : Endif
  If dim([F:AOA2]UPDDAT)>0 : [F:AOA2]UPDDAT = [0/0/0] : Endif
  If dim([F:AOA2]UPDUSR)>0 : [F:AOA2]UPDUSR = "" : Endif
  If dim([F:AOA2]UPDTIM)>0 : [F:AOA2]UPDTIM = 0 : Endif
  Write [AOA2]
  If fstat
   GOK=0 : Call FSTA("AOA2") From GLOCK : End
  Endif
 Endif
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Etiquettes AON1
#----------------------------------------------------------------------------------------------------#

Subprog AP_INTIT(VALEUR)
Variable  Char VALEUR
Look [AON]AON0=[M]ABREV;[M]TRN;[M]CPY;[M]MODELE
If !fstat : mkstat = 4 : Endif
End

Subprog AS_TYP(VALEUR)
Variable Integer  VALEUR
Local Integer I
For I=1 To 4
 GMENLOC(I) = 1
Next I
End

Subprog AM_TYP(VALEUR)
Variable Integer  VALEUR
Raz [M]BLOB
End

Subprog AS_BLOB
If len([M]BLOB)>0 : End : Endif
If clalev([F:ASB])=0 : Local File ABLBSYS [ASB] : Endif
Case [M]TYP
 When 5 : Read [ASB]ASB0="MIS";"WORD"       : If !fstat : [M]BLOB = [F:ASB]BLOB : Endif
 When 6 : Read [ASB]ASB0="MIS";"EXCEL"      : If !fstat : [M]BLOB = [F:ASB]BLOB : Endif
 When 7 : Read [ASB]ASB0="MIS";"POWERPOINT" : If !fstat : [M]BLOB = [F:ASB]BLOB : Endif
Endcase
End

Subprog S_TRN(VALEUR)
Variable Char    VALEUR()
End

Subprog C_MODELE(VALEUR)
Variable Char    VALEUR()
[M]TRNCPYMOD = [M]TRN+"~"+[M]CPY+"~"+[M]MODELE
End

Subprog AV_ABREV(VALEUR)
Variable Char    VALEUR()
If dim(GOBJAON)>0 and GOBJAON<>""
 VALEUR = GOBJAON : Grizo ABREV
Else
 Actzo ABREV
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
[M]CPY = VALEUR
Gosub GRISE_LEG
End
