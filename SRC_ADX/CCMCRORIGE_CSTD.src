# Data Class script: CCMCRORIGE_CSTD, Change Request - Originator External Collection

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase

Return

# --------------------------------------------------
# Increment collection row's line number (ORIGELN)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

      this.ORIGELN = 1 + max (this.APARENT.CCMCRORIGE(1..maxtab(this.APARENT.CCMCRORIGE)).ORIGELN)

Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Case CURPRO
  Endcase

Return


