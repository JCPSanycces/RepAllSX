#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry SET
#########################################################################
# CNSSETSTD : Sage Exchange transactions
# Document : SET
# INQUIRY  : SET
# SCREEN 1 (HEADER) : CONSSET1 [SET1]
# SCREEN 2 (LINES)  : CONSSET2 [SET2]
# CRIT SCREEN       : CRITSET  [CSET]
#
# TABLE 1 (HEADER) : SETXN [SEX] : order by key = SEX1
#
#########################################################################

$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
Endcase
Return

############################################################
$AUTORIS
Return

###################################################################
# Parameters analysis, initializations, opening & declarations    #
###################################################################
$OUVRE

NAVIG="CONSSET"
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    CREDATA
Local Integer WREAD, WINCR, WSKIP, WLIG
Local Integer TOTREC, CURREC
Local Integer ERR

Gosub DEFCRIT

If !clalev([F:SEX]) : Local File SETXN [SEX]   : Endif
If !clalev([F:AXX]) : Local File ATEXTRA [AXX] : Endif

#- Prevent X3 from launching automatically the inquiry -#
CHARGMT=1

#  Ensure that the prev, next and last buttons are disabled until a search is done
RETOUR = 1
SUITE = 1

Return

# --------------------------------------------------------------------------#
# Initialize Criteria fields                                                #
# --------------------------------------------------------------------------#
$DEFCRIT

If !find([M:SET1]PAYPRC,1,2,3): [M:SET1]PAYPRC = 3  : Endif #109235.n

# Default to checked unless already set
# Header fields
If !find([M:SET1]REQ,1,2)     : [M:SET1]REQ = 2     : Endif
If !find([M:SET1]RESP,1,2)    : [M:SET1]RESP = 2    : Endif

# Criteria screen
If !find([M:CSET]AUTH,1,2)     : [M:CSET]AUTH = 2     : Endif
If !find([M:CSET]CAP,1,2)      : [M:CSET]CAP = 2      : Endif
If !find([M:CSET]VOID,1,2)     : [M:CSET]VOID = 2     : Endif
If !find([M:CSET]CREDIT,1,2)   : [M:CSET]CREDIT = 2   : Endif
If !find([M:CSET]VAULTCRE,1,2) : [M:CSET]VAULTCRE = 2 : Endif
If !find([M:CSET]BATSET,1,2)   : [M:CSET]BATSET = 2   : Endif
If !find([M:CSET]TRI,1,2)      : [M:CSET]TRI = 1      : Endif

#----- Copy header screen SET1 to criteria screen CXPO -----#
Gosub CRITENT From =PROGCNS

Return

############################################################
$DEB_CRIT
  #109235.sn
  #Enable/Disable batch settlement checkbox
  If [M:CSET]PAYPRC = 2
    Grizo [M:CSET]BATSET
  Else
    Actzo [M:CSET]BATSET
  Endif
  #109235.sn
Return

############################################################
$LECTURE

#-- Load the requested mask from the criteria screen
Gosub CHANGE_MSK From GCONSULT

#-- Preparing filters
Gosub VALCRIT
If ERR = 1 : Return: Endif

Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

#Apply the filter
Filter [SEX] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SEX1

TOTREC = nbrecord([F:SEX])

# ------------------------------------------------------- #
# CHGPAG = 1    :    Search                               #
# ------ = 2    :    Next                                 #
#        = 3    :    F5 (Refresh current page)            #
# CHGPAG = -1   :    Last                                 #
# ------ = -2   :    Previous                             #
# ------------------------------------------------------- #

# WINC      : line increment
# WREAD = 0 : Read first
#         1 : Read next
#         2 : Read last
#         3 : read prev

#-- Clear the detail screen
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SET2] : Endif

If WREAD = 0 | CHGPAG = 1
    nolign = 1
    WREAD  = 0
    WINCR  = 1
    SUITE  = 0
    RETOUR = 1
    Gosub LOA_PAGE
Else
  Case CHGPAG
    When 2  :
      If WINCR = -1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = 1
      WREAD  = 1
      WINCR  = 1
      Gosub LOA_PAGE
      RETOUR = 0
    When -1 :
      nolign = MAXLIG
      WREAD  = 2
      WINCR  = -1
      WSKIP  = 0
      Gosub LOA_PAGE
      RETOUR = 0
      SUITE  = 1
    When -2 :
      If WINCR = 1
        WSKIP = WLIG
      Else
        WSKIP = 0
      Endif
      nolign = MAXLIG
      WINCR  = -1
      WREAD  = 3
      Gosub LOA_PAGE
      SUITE  = 0
      If CURREC <= 1
        RETOUR = 1
        CURREC = 1
      Else
        RETOUR = 0
      Endif
  Endcase

Endif

Return

#########################################################################
$LOA_PAGE

NBLU = 2
WLIG = 0
If WSKIP <> 0
  If WSKIP < 0
    While WSKIP <> -1
      Read [F:SEX] Next
      If fstat
        Break
      Endif
      WSKIP += 1
      CURREC += 1
    Wend
  Else
    While WSKIP <> 1
      Read [F:SEX] Prev
      If fstat
        Break
      Endif
      WSKIP -= 1
      CURREC -= 1
    Wend
  Endif
Endif

$LOA_PAGE1
If  nolign > MAXLIG | nolign < 1
  Goto LOA_PAGE_FIN
Endif
# choices
Case WREAD
  When 0 :
    WREAD = 1
    Read [F:SEX] First
    If fstat
      SUITE   = 1
      RETOUR  = 1
      Goto LOA_PAGE_FIN
    Endif
    CURREC = 1
  When 1 :
    Read [F:SEX] Next
    If fstat
      SUITE = 1
      Goto LOA_PAGE_FIN
    Endif
    CURREC += 1
  When 2 :
    WREAD = 3
    Read [F:SEX] Last
    If fstat
      RETOUR = 1
      Goto LOA_PAGE_FIN
    Endif
    CURREC = TOTREC
  When 3 :
    Read [F:SEX] Prev
    CURREC -= 1
Endcase

[M:SET2] = [F:SEX]
[M:SET2]CREDAT(nolign-1) = func GET_DATE(num$([F:SEX]CREDATTIM))
[M:SET2]ADDLIG(nolign-1) = [F:SEX]ADDLIG(0)-[F:SEX]ADDLIG(1)

#Here we will handle fields that need translating from a code to a description
[M:SET2]CRDTYPDES(nolign-1) = func AFNC.TEXTRA("ATABDIV","LNGDES","398",[F:SEX]CRDTYP)

#109235.sn
Case [M:SET2]PAYPRC(nolign-1)
  When 1
    [M:SET2]TXNTYPDES(nolign-1) = func AFNC.TEXTRA("ATABDIV","LNGDES","399",[F:SEX]TXNTYP)
  When 2
    [M:SET2]TXNTYPDES(nolign-1) = [F:SEX]SPTXNTYP
Endcase
#109235.en

[M:SET2]RESPDES(nolign-1)   = func AFNC.TEXTRA("ATABDIV","LNGDES","403",[F:SEX]RESP)

nolign += WINCR
NOL    += WINCR
WLIG   += WINCR

Goto LOA_PAGE1

$LOA_PAGE_FIN
Return

############################################################
#   Validate the search criteria                           #
############################################################
$VALCRIT

#Default to no error
ERR = 0

#Before we build the filter - check for certain requirements:
#Must select at least one of Request/Response
If [M:SET1]REQ = 1 and [M:SET1]RESP = 1
  Call ECR_TRACE(mess(29,2092,1),1) From GESECRAN
  ERR = 1
  Return
Endif

#Must select at least one transaction type
If [M:SET1]PAYPRC = 2
  #109235.sn
  #No need check for batch settlement tran type for Sage Pay transactions
  If [M:CSET]AUTH = 1 and [M:CSET]CAP = 1 and [M:CSET]VOID = 1 and [M:CSET]CREDIT = 1 and [M:CSET]VAULTCRE = 1
    Call ECR_TRACE(mess(30,2092,1),1) From GESECRAN
    ERR = 1
    Return
  Endif
  #109235.en
Else
  If [M:CSET]AUTH = 1 and [M:CSET]CAP = 1 and [M:CSET]VOID = 1 and [M:CSET]CREDIT = 1 and [M:CSET]VAULTCRE = 1 and [M:CSET]BATSET = 1
    Call ECR_TRACE(mess(30,2092,1),1) From GESECRAN
    ERR = 1
    Return
  Endif
Endif

Return

############################################################
#   Prepare the search filter                              #
############################################################
$LOAD_FILTER
Local Char TRNTYPLST(80)
Local Char SPTRNTYPLST(250)

WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

#Header fields - go into filter WFIL
# Document number - VCRNUMORI is called REF2 by SE
If [M:SET1]VCRNUMORI <> ""
   WFIL += "&[F:SEX]REF2=[M:SET1]VCRNUMORI"
Endif

# Customer Number
If [M:SET1]BPCNUM <> ""
   WFIL += "&[F:SEX]BPCNUM=[M:SET1]BPCNUM"
Endif

# Transction Date - Beg
If [M:SET1]TXNDATDEB <> [0/0/0]
   WFIL += "&[F:SEX]TXNDAT>=[M:SET1]TXNDATDEB"
Endif

# Transaction Date - End
If [M:SET1]TXNDATFIN <> [0/0/0]
   WFIL += "&[F:SEX]TXNDAT<=[M:SET1]TXNDATFIN"
Endif

# VAN Reference
If [M:SET1]VANREF <> ""
   WFIL += "&[F:SEX]VANREF=[M:SET1]VANREF"
Endif

# Request or Repsonse - Request = 1, Response = 2
# If only one or the other is selected, give jsut that one.
# If both or neither, no filter
If [M:SET1]REQ = 1 and [M:SET1]RESP = 2
  WFIL += "&[F:SEX]REQRSP=2"
Endif

If [M:SET1]REQ = 2 and [M:SET1]RESP = 1
  WFIL += "&[F:SEX]REQRSP=1"
Endif

#Criteria screen fields - go into WFIL1
# Original Document number - VCRNUM is called REF1 by SE
If [M:CSET]VCRNUM <> ""
   WFIL1 += "&[F:SEX]REF1=[M:CSET]VCRNUM"
Endif

# Account name
If [M:CSET]ACCNAM <> ""
   WFIL1 += "&[F:SEX]ACCNAM=[M:CSET]ACCNAM"
Endif

# Card TYpe - TODO - make the description show up - not the code
If [M:CSET]CRDTYP <> ""
   WFIL1 += "&[F:SEX]CRDTYP=[M:CSET]CRDTYP"
Endif

# Response Code
If [M:CSET]RSPCOD <> ""
   WFIL1 += "&[F:SEX]RSPCOD=[M:CSET]RSPCOD"
Endif

# Transaction ID
If [M:CSET]TXNID <> ""
   WFIL1 += "&[F:SEX]TXNID=[M:CSET]TXNID"
Endif

#Transaction Types
# Authorization
If [M:CSET]AUTH = 2
   TRNTYPLST += "'02','12',"
   SPTRNTYPLST += "'DEFERRED','DEFERRED_VERIFY'," #109235 Sage Pay Tran Type
Endif

# Capture
If [M:CSET]CAP = 2
   TRNTYPLST += "'03','13','05','15',"
   SPTRNTYPLST += "'RELEASE'," #109235 Sage Pay Tran Type
Endif

# VOID
If [M:CSET]VOID = 2
   TRNTYPLST += "'04',"
   SPTRNTYPLST += "'ABORT'," #109235 Sage Pay Tran Type
Endif

# Credit
If [M:CSET]CREDIT = 2
   TRNTYPLST += "'06','16','07','17',"
   SPTRNTYPLST += "'REFUND'," #109235 Sage Pay Tran Type
Endif

# Vault Creation and Vault Inquiry
If [M:CSET]VAULTCRE = 2
   TRNTYPLST += "'10','24',"
   SPTRNTYPLST += "'TOKEN','TOKEN_VERIFY','REMOVETOKEN'," #109235 Sage Pay Tran Type
Endif

# Batch Settlement
If [M:CSET]BATSET = 2
   TRNTYPLST += "'21',"
Endif

#109235.sn
#Payment Processor
Case [M:SET1]PAYPRC
  When 1
    WFIL += "&[F:SEX]PAYPRC=[M:SET1]PAYPRC"
    If len(TRNTYPLST) > 0
      TRNTYPLST = left$(TRNTYPLST,len(TRNTYPLST)-1)
      WFIL2 += "&find([F:SEX]TXNTYP,"+TRNTYPLST+")"
    Endif
  When 2
    WFIL += "&[F:SEX]PAYPRC=[M:SET1]PAYPRC"
    If len(SPTRNTYPLST) > 0
      SPTRNTYPLST = left$(SPTRNTYPLST,len(SPTRNTYPLST)-1)
      WFIL2 += "&find([F:SEX]SPTXNTYP,"+SPTRNTYPLST+")"
    Endif
  When 3
    WFIL += "&find([F:SEX]PAYPRC,1,2)"
    If len(TRNTYPLST) > 0
      TRNTYPLST +="'',"
      TRNTYPLST = left$(TRNTYPLST,len(TRNTYPLST)-1)
      WFIL2 += "&find([F:SEX]TXNTYP,"+TRNTYPLST+")"
    Endif

    If len(SPTRNTYPLST) > 0
      SPTRNTYPLST +="'',"
      SPTRNTYPLST = left$(SPTRNTYPLST,len(SPTRNTYPLST)-1)
      WFIL2 += "&find([F:SEX]SPTXNTYP,"+SPTRNTYPLST+")"
    Endif
Endcase
#109235.en

Return

############################################################################
#    Before closing the criteria screen & coming back to the main window   #
############################################################################
$FIN_CRIT
  #109235.sn
  #Ensure payment processsing entries are the same for both the header/criteria screens
  [M:SET1]PAYPRC = [M:CSET]PAYPRC
  #109235.en
Return

#########################################################################
# To execute inquiry validation when patching                           #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
#If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
#If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"SET") From SUBGTC
End


#109235.sn
#Enable/Disable batch settlement checkbox
######################################################################################
Subprog C_PAYPRC(VALEUR)
Variable Integer    VALEUR

Case maskcou
  When "CRITSET"
    If VALEUR = 2
      Grizo [M:CSET]BATSET
    Else
      Actzo [M:CSET]BATSET
    Endif
  Endcase
End
#109235.en

#109235.sn
#Ensure payment processsing entries are the same for both the header/criteria screens
######################################################################################
Subprog AM_PAYPRC(VALEUR)
Variable Integer    VALEUR

Case maskcou
  When "CONSSET1"
    [M:CSET]PAYPRC = VALEUR
  Endcase
End
#109235.en

######################################################################################
Subprog AM_TXNDATDEB(VALEUR)
Variable Date    VALEUR

Case maskcou
  When "CONSSET1"
    If [M:SET1]TXNDATFIN = [0/0/0] : [M:SET1]TXNDATFIN = VALEUR : Endif
  When "CRITSET"
    If [M:CSET]TXNDATFIN = [0/0/0] : [M:CSET]TXNDATFIN = VALEUR : Endif
Endcase

End

######################################################################################
# Convert string to date type
# Assume string coming in is in YYYY-MM-DDTHH:MM:SSZ
####################################################################################
Funprog GET_DATE(ISTR)
Value Char ISTR

If ISTR=""  End Endif

# cut off HMS (if they exist)
SP = instr(1,ISTR,"T")
If SP>0 : ISTR = left$(ISTR,SP-1) : Endif

# find position of slashes
S1 = instr(1,ISTR,"-")
S2 = instr(S1+1,ISTR,"-")
# build date based on slash positions
Y = left$(ISTR,S1-1)
M = seg$(ISTR,S1+1,S2)
D = right$(ISTR,S2+1)
End gdat$(val(D),val(M),val(Y))

