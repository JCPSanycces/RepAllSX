#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog DISPLAY_HIDE()


  If GCURLEG="POR"|GCURLEG=""
    If dim([M:VRA2]ABSTYP)>0 : Chgfmt [M:VRA2]ABSTYP With "LA:11556" : Endif
    If dim([M:VRA2]MOTSAUR)>0 : Chgfmt [M:VRA2]MOTSAUR With "K:15X" : Endif
  Else
    If dim([M:VRA2]ABSTYP)>0 : Chgfmt [M:VRA2]ABSTYP With "-LA:11556" : Raz [M:VRA2]ABSTYP : Endif
    If dim([M:VRA2]MOTSAUR)>0 : Chgfmt [M:VRA2]MOTSAUR With "-K:15X" : Raz [M:VRA2]MOTSAUR : Endif

  Endif

  If GCURLEG="FRA"|GCURLEG=""
    If dim([M:VRA2]FLGSEE)>0 : Chgfmt [M:VRA2]FLGSEE With "LA:1" : Endif
  Else
    If dim([M:VRA2]FLGSEE)>0 : Chgfmt [M:VRA2]FLGSEE With "-LA:1" : Raz [M:VRA2]FLGSEE : Endif

  Endif

##########
#refresh all screens
If clalev([M:VRA2])<>0
  Affzo [M:VRA2]
Endif
##########

End

