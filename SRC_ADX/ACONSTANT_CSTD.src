#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure ACONSTANT
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_AFTER"                    : Gosub AINSERT_AFTER
      When "AUPDATE_AFTER"                    : Gosub AUPDATE_AFTER
      When "ADELETE_AFTER"                    : Gosub ADELETE_AFTER
      When "VALIDATE"                         : Gosub VALIDATE
      When "AREAD_AFTER"                      : Gosub AREAD_AFTER
      When "ADELETE_CONTROL_AFTER"            : Gosub DELETE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CODVAR"  : Gosub CODVAR
  When "CATEG"   : Gosub CATEG
  When "TYPVAR"  : Gosub TYPVAR
  When "VALCHAR" : Gosub VALCHAR
  When "VALINT"  : Gosub VALINT
  When "VALDEC"  : Gosub VALDEC
  When "VALDAT"  : Gosub VALDAT
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

############################################################################
$AINSERT_AFTER
Gosub VALIDATE
Return

##############################################################################
$AUPDATE_AFTER
Gosub VALIDATE
Return

##############################################################################
$ADELETE_AFTER  # ACST table record has already been deleted
Gosub VALIDATE
Return

########################################################
$DELETE_AFTER
Return
# Delete ATEXTE
Local File ATEXTE [ATX]
Local Instance ATEXTE Using C_ATEXTE
For [F:ATX] Where NUMERO=this.INTIT
  ATEXTE = NewInstance C_ATEXTE AllocGroup null
  [L]ASTATUS = fmet ATEXTE.AREAD([F:ATX]LAN,[F:ATX]NUMERO)
  If [L]ASTATUS <> [V]CST_AOK
    [L]ASTATUS= fmet this.ASETERROR("","ATEXTE"-mess(15,143,1)-[F:ATX]LAN-[F:ATX]NUMERO,[V]CST_AERROR)
  Else
   [L]ASTATUS = fmet ATEXTE.ADELETE()
   If [L]ASTATUS <> [V]CST_AOK
     [L]ASTATUS= fmet this.ASETERROR("","ATEXTE"-mess(15,143,1)-[F:ATX]LAN-[F:ATX]NUMERO,[V]CST_AERROR)
   Endif
  Endif
  FreeGroup ATEXTE
  If [L]ASTATUS <> [V]CST_AOK : Break : Endif
Next
Return

###############################################################################
$VALIDATE
Local Integer MY_STATUS
Local Char MESSAGE(250)
[L]MY_STATUS = func VALIDATION(this.ACTX.AFOLDER,0,MESSAGE)
If [L]MY_STATUS <> [V]CST_AOK
  [L]ASTATUS = fmet this.ASETERROR("VALIDATE",mess(20,123,1)-MESSAGE,[V]CST_AERROR)
Endif
Return

###############################################################################
#$DELETE_AFTER
# Delete AGRPCPY
#Local File ATEXTE [ATX]
#Local Instance ATEXTE Using C_ATEXTE
#For [F:ATX] Where NUMERO=this.INTIT
#  ATEXTE = NewInstance C_ATEXTE AllocGroup null
  #SetInstance AGRPCPY With [F:AGC]
#  [L]ASTATUS = fmet ATEXTE.ADELETE()
#  If [L]ASTATUS <> [V]CST_AOK
#    [L]ASTATUS= fmet this.ASETERROR("ATEXTE","Delete error message",[V]CST_AERROR)
#  Endif
#  FreeGroup ATEXTE
#  If [L]ASTATUS <> [V]CST_AOK : Break : Endif
#Next
#If [L]ASTATUS <> [V]CST_AOK : Return : Endif

#Return


###############################################################################
$CODVAR
  Case [L]ARULE
    When "PROPAGATE" : Gosub CODVAR_PROPAGATE
  Endcase
Return

$CODVAR_PROPAGATE
Gosub ACONST_DEPENDENCY
Return


###############################################################################
$CATEG
  Case [L]ARULE
    When "CONTROL" : Gosub CATEG_CONTROL
  Endcase
Return

$CATEG_CONTROL
Local Char MESSAGE(250)
  If this.CATEG <> AVOID.ACHAR
    If func ASYRFNC.ACTIV("SUP")>0
      [L]ASTATUS= func ACD_TOOL.PLAGE(this.CODVAR,1,MESSAGE)
      If [L]ASTATUS<>[V]CST_AOK
        [L]ASTATUS = fmet this.ASETERROR("CATEG",MESSAGE,[L]ASTATUS)
      Endif
    Else
      If left$(this.CODVAR,1)<>"A" & left$(this.CATEG,1)="A"
        [L]ASTATUS = fmet this.ASETERROR("CATEG",mess(214,133,1),[V]CST_AERROR)
      Endif
    Endif
  Endif
Return

###############################################################################
$TYPVAR
  Case [L]ARULE
    When "PROPAGATE" : Gosub TYPVAR_PROPAGATE
  Endcase
Return

$TYPVAR_PROPAGATE
  # Enable/disable the value fields based on the selected type.
  Case this.TYPVAR
   When 1
    this.VALINT = AVOID.AINT
    this.VALDEC = AVOID.ADEC
    this.VALDAT = AVOID.ADATE
   When 2
    this.VALCHAR = AVOID.ACHAR
    this.VALDEC  = AVOID.ADEC
    this.VALDAT  = AVOID.ADATE
   When 3
    this.VALCHAR = AVOID.ACHAR
    this.VALINT  = AVOID.AINT
    this.VALDAT  = AVOID.ADATE
   When 4
    this.VALCHAR = AVOID.ACHAR
    this.VALINT  = AVOID.AINT
    this.VALDEC  = AVOID.ADEC
  Endcase
Return

###############################################################################
$VALCHAR
  Case [L]ARULE
    When "CONTROL" : Gosub VALCHAR_CONTROL
  Endcase
Return

$VALCHAR_CONTROL
  # If the type is not Character then do not allow this value to be set.
  If this.TYPVAR <> 1
    this.VALCHAR = AVOID.ACHAR
  Endif
Return

###############################################################################
$VALINT
  Case [L]ARULE
    When "CONTROL" : Gosub VALINT_CONTROL
  Endcase
Return

$VALINT_CONTROL
  # If the type is not Char then do not allow this value to be set.
  If this.TYPVAR <> 2
    this.VALINT = AVOID.AINT
  Endif
Return

###############################################################################
$VALDEC
  Case [L]ARULE
    When "CONTROL" : Gosub VALDEC_CONTROL
  Endcase
Return

$VALDEC_CONTROL
  # If the type is not Decimal then do not allow this value to be set.
  If this.TYPVAR <> 3
    this.VALDEC = AVOID.ADEC
  Endif
Return

###############################################################################
$VALDAT
  Case [L]ARULE
    When "CONTROL" : Gosub VALDAT_CONTROL
  Endcase
Return

$VALDAT_CONTROL
  # If the type is not Date then do not allow this value to be set.
  If this.TYPVAR <> 4
    this.VALDAT = AVOID.ADATE
  Endif
Return




##########################################################################
$AREAD_AFTER
  Gosub ACONST_DEPENDENCY
Return

$ACONST_DEPENDENCY
this.ACONST = func PREFIX_ACST+this.CODVAR
Return

##############################################################################
Funprog VALIDATION(DOSSIER,SILENCE,MESSAGE)
Value Char    DOSSIER
Value Integer SILENCE
Variable Char MESSAGE
Local Integer  MY_STATUS

#TODO: syracuzation of validation
End [L]MY_STATUS

Local Clbfile  CLOB(4)
Local Char     LIGNE(250)
Local Char     NOMTRT(GLONADC)
Local Char    FICTRT(GLONFIC) , FICOLD(GLONFIC) , FICLCK(GLONFIC) , FICNEW(GLONFIC)
Local Char    TETADO(80) , TEXTE(250) , CHAINE(250)
Local Integer STAT , I , K, N , M
Local Char    LIGNE(250)(1..200)
Local Char    MACHINE(GLONFIC) , APPLI(GLONFIC),TITLE(250)
Local Instance MY_ACONSTANT Using C_ACONSTANT
Local Instance MY_ALOG Using C_ALOG
MY_ALOG=NewInstance C_ALOG AllocGroup null

#Validation of constants
[L]MY_STATUS = fmet MY_ALOG.ABEGINLOG(mess(62,140,1))

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Local File =DOSSIER+".ACONSTANT" [ACST]

LIGNE = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$" : Gosub ADDCLB

[L]NOMTRT = func APREFIXTRT.GET_NAME_ACST
#TODO: temp-Remove temp  name and delete file lcksrc when validation is available.
[L]NOMTRT = "ZRCBT12" #temp
[L]MY_STATUS = func ASYRSYS.DELETEFILE(filpath("TRT",NOMTRT,"LCKsrc",APPLI,"",MACHINE),MESSAGE)
#TODO: temp-end todo

FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)
FICOLD = filpath("TRT",NOMTRT,"old",APPLI,"",MACHINE)
FICNEW = filpath("TRT",NOMTRT,"new",APPLI,"",MACHINE)
FICLCK = filpath("TRT",NOMTRT,"LCKsrc",APPLI,"",MACHINE)

Local Integer ISLOCKED
Call VERROU(DOSSIER,func APREFIXTRT.GET_NAME_ACST,10) From GLOCK
If fstat
 [L]ISLOCKED=0
Else
 [L]ISLOCKED=1
Endif

If filinfo(FICLCK,0)>0 | [L]ISLOCKED=0
 If  !SILENCE
  # Process locked
  [L]MY_STATUS = fmet MY_ALOG.APUTLINE(NOMTRT-":"-mess(13,139,1),1)
 Endif
 Goto FIN_VALID
Endif

If filinfo(FICNEW,0)>0
 Call _EFFACE(FICNEW,STAT) From ASYRSYS
Endif

Openo FICLCK,0 Using [ACSTLOCK]
Iomode adxifs "" Using [ACSTLOCK]
Iomode adxirs chr$(10) Using [ACSTLOCK]
Iomode adxium GUTF8 Using [ACSTLOCK]
Wrseq  adxmac(-2) Using [ACSTLOCK]
Wrseq  adxusr Using [ACSTLOCK]
Wrseq format$(fmet MY_ALOG.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, MY_ALOG.ACTX.AFOLDER, "FMTDAT"),date$)-"-"-time$ Using [ACSTLOCK]
Openo Using [ACSTLOCK]

[L]MY_STATUS=func ASYRSYS.COPYFILE(FICTRT,FICOLD,MESSAGE)

Gosub INTERLINE
LIGNE="#"-mess(1,47,1) : Gosub ADDCLB

LIGNE =  "Subprog DEFVAR" : Gosub ADDCLB
For [F:ACST]ACST1(1) Where FLGSUP<>[V]CST_AYES
 If !SILENCE
  [L]MY_STATUS = fmet MY_ALOG.APUTLINE([ACST]CATEG+":"-mess(1,100,1),0)
 Endif
 Gosub INTERLINE
 LIGNE =  "####"-mess(8,105,1)-[ACST]CATEG : Gosub ADDCLB
 For [ACST]ACST1
  [L]MY_ACONSTANT = NewInstance C_ACONSTANT AllocGroup null
  [L]MY_STATUS = fmet MY_ACONSTANT.AREAD([F:ACST]CODVAR)
  If [L]MY_STATUS = [V]CST_AOK
    LIGNE =  "#"-fmet MY_ACONSTANT.INTIT.AGETTEXT() : Gosub ADDCLB
    Case MY_ACONSTANT.TYPVAR
      When 1 :  TEXTE = "Global Char     "
      When 2 :  TEXTE = "Global Integer  "
      When 3 :  TEXTE = "Global Decimal  "
      When 4 :  TEXTE = "Global Date     "
    Endcase
    TEXTE += func PREFIX_ACST+MY_ACONSTANT.CODVAR
    Case [ACST]TYPVAR
      When 1 :  TEXTE += "("+num$(len(MY_ACONSTANT.VALCHAR))+")"
    Endcase
    TEXTE += " : [V]"+func PREFIX_ACST+MY_ACONSTANT.CODVAR-"="
    Case [ACST]TYPVAR
      When 1 :
        If instr(1,[F:ACST]VALCHAR,'"')>0
          TEXTE += "'"+MY_ACONSTANT.VALCHAR+"'"
        Else
          TEXTE += '"'+MY_ACONSTANT.VALCHAR+'"'
        Endif
      When 2 :  TEXTE += num$(MY_ACONSTANT.VALINT)
      When 3 :  TEXTE += num$(MY_ACONSTANT.VALDEC)
      When 4 :  TEXTE += "["+num$(MY_ACONSTANT.VALDAT)+"]"
    Endcase
    LIGNE =  TEXTE : Gosub ADDCLB
    FreeGroup MY_ACONSTANT
   Endif
 Next
 LIGNE =  "" : Gosub ADDCLB
Next
LIGNE =  "End" : Gosub ADDCLB

[L]MY_STATUS = func WRITE_TRT(CLOB,FICTRT,MESSAGE)
If [L]MY_STATUS<>[V]CST_AOK
  [L]MY_STATUS = fmet MY_ALOG.APUTLINE(MESSAGE,1)
  [L]MY_STATUS = fmet MY_ALOG.AENDLOG()
  [L]MY_STATUS = func ASYRSYS.DELETEFILE(FICLCK,MESSAGE)
  End [V]CST_AERROR
Else
  # Validation of document
  [L]MY_STATUS = fmet MY_ALOG.APUTLINE(mess(159,133,1)-NOMTRT,1)
#  Global Char GLANGUE(10): GLANGUE=GACTX.AFOLD.ALANGDEF
#  Global Integer GSERVEUR: GSERVEUR=0
#  Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
STAT=1  # temporary
  If !STAT
    # Restore original
    [L]MY_STATUS = func ASYRSYS.COPYFILE(FICTRT,FICNEW,MESSAGE)
    [L]MY_STATUS = func ASYRSYS.DELETEFILE(FICTRT,MESSAGE)
    [L]MY_STATUS = func ASYRSYS.COPYFILE(FICOLD,FICTRT,MESSAGE)
    # Error in process validation
    [L]MY_STATUS = fmet MY_ALOG.APUTLINE(mess(20,123,1)-"\|"+FICNEW+"|",0)
    # Validation of old processing
    [L]MY_STATUS = fmet MY_ALOG.APUTLINE(mess(226,133,1)-NOMTRT,0)
    Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
    [L]MY_STATUS = func ASYRSYS.DELETEFILE(FICOLD,MESSAGE)
    [L]MY_STATUS = func ASYRSYS.DELETEFILE(FICLCK,MESSAGE)
    [L]MY_STATUS=[V]CST_AERROR
  Endif
Endif
[L]MY_STATUS = func ASYRSYS.DELETEFILE(FICOLD,MESSAGE)
[L]MY_STATUS = func ASYRSYS.DELETEFILE(FICLCK,MESSAGE)
Call DEVERROU(DOSSIER,func APREFIXTRT.GET_NAME_ACST) From GLOCK

[L]MY_STATUS = fmet MY_ALOG.AENDLOG()
FreeGroup MY_ALOG

$FIN_VALID
If nomap=DOSSIER
  Gosub EXEC_DEFVAR
Endif
End [L]MY_STATUS

$ACST_DEFVAR
Resume

$EXEC_DEFVAR
 Call VERROU(nomap,func APREFIXTRT.GET_NAME_ACST,10) From GLOCK
 If fstat
  Call DEVERROU(nomap,func APREFIXTRT.GET_NAME_ACST) From GLOCK
  Return
 Endif
 Onerrgo ACST_DEFVAR
 Call DEFVAR From =func APREFIXTRT.GET_NAME_ACST
 Onerrgo
 Call DEVERROU(nomap,func APREFIXTRT.GET_NAME_ACST) From GLOCK
Return

############################################################################################
Funprog WRITE_TRT(CLOB,FICTRT,MESSAGE)
Variable Char CLOB
Value Char FICTRT
Variable Char MESSAGE

Local Integer MY_STATUS,ER
MY_STATUS = [V]CST_AOK
Onerrgo ERREUR
If MY_STATUS=[V]CST_AERROR
  MESSAGE = errmes$(ER)
Else
  Openo FICTRT , 0 Using [ACSTFIC]
  Iomode adxifs "" Using [ACSTFIC]
  Iomode adxirs chr$(10) Using [ACSTFIC]
  Iomode adxium GUTF8 Using [ACSTFIC]
  Wrseq CLOB Using [ACSTFIC]
  Wrseq Using [ACSTFIC]
  Openo Using [ACSTFIC]
Endif

End MY_STATUS

$ERREUR
ER = errn
MY_STATUS = [V]CST_AERROR
Resume


#############################################################################################
$INTERLINE
LIGNE = "####################################################################" : Gosub ADDCLB
Return

#############################################################################################
$ADDCLB
Append CLOB,LIGNE+chr$(10)
Return

#############################################################################################
Funprog PREFIX_ACST
End "[V]CST_"

