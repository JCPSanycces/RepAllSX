#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################
##############################################################################################
## Based on CPTEXT, can be used generically to reverse a given document
## At the moment only used to reverse FIFO rate convertion (GESFIFCV) generated documents
## But can be extended to other reversals
##############################################################################################
##############################################################################################
## Entry point not implemented
## Netting not implemented
## Fix assets expense not implemented
##############################################################################################
##############################################################################################
$ACTION

Case ACTION
  When "INIT_DIA" : Gosub INIT_DIA
  When "EXEC"     : Gosub EXEC
  When "SORTIE"   : Gosub SORTIE
Endcase

Return
##############################################################################################
##############################################################################################
$INIT_DIA

Raz [M:DIA] : Affzo [DIA]

Local Integer EXE

GOK = 1

Return
##############################################################################################
##############################################################################################
$EXEC

If PARAM(1) = "" | PARAM(2) = "" # Just to return the selected values by the user user
  PARAM(3) = num$([M:DIA]EXTSNS)
  PARAM(4) = [M:DIA]ACCDAT
  PARAM(5) = [M:DIA]DESVCR
Else
  #Can be used to call the revers_doc subprog
Endif

EXE = 1

Return
##############################################################################################
##############################################################################################
$SORTIE

If !EXE : GOK = 0 : Endif

Return
##############################################################################################
##############################################################################################
Subprog REVERSE_DOC(DOCNUM, DOCTYP, EXTSNS, RACCDAT, RDESVCR, RETCOD, RETMES)
Value Char       DOCNUM
Value Char       DOCTYP
Value Integer    EXTSNS
Value Date       RACCDAT
Value Char       RDESVCR
Variable Integer RETCOD
Variable Char    RETMES

Gosub DECLARE

Gosub CONTROLE

If RETCOD = 0
  Gosub REVERSE
Endif

End
##############################################################################################
##############################################################################################
$DECLARE

Local File GACCOUNT   [GAC],  GAJOUSTA   [JST]
&        , COMPANY    [CPY],  COMPANY    [CPY2]
&        , FACILITY   [FCY],  FACGROUP   [FGR]
&        , TABCUR     [TCU],  TABCHANGE  [TCH]
&        , GDIAENTRY  [GDE],  GDIAENTRYD [GDD]
&        , TABACCLIK  [TCK]
&        , GTYPACCENT [GTE],  CADSP      [DSP]
&        , GACCENTRY  [HAE]
&        , GACCENTRYD [DAE],  GACCENTRYA [DAA]
&        , AVALNUM    [AVN],  ACODNUM    [ANM]
&        , FISCALYEAR [FIY],  PERIOD     [PER]
&        , GJOURNAL   [JOU],  TABUNIT    [TUN]
&        , MTCBATCH   [MTB]
&        , GACCDUDATE [DUD],  GACM       [GCM]
&        , GJOURNAL   [JOU2]

If clalev([F:DAEX])=0 : Local File GACCENTRYD [DAEX] : Endif
If clalev([F:DATX])=0 : Local File GACCTMPD   [DATX] : Endif

Local Mask GACCENTFMT  [SVGF]        # To save the HAEF mask in the netting context before the unmatching
Local Mask GACCENTW    [SVGW]        # To save the HAEW mask in the netting context before the unmatching
Local Mask GACCENTFMT  [HAEF]        # Screen declaration to miscelaneous informations
Local Mask GACCENTW    [HAEW]        # Screen declaration to generate document lines
Local Mask SAICURLED   [SCL]         # Screen declaration to manage currencies
Local Mask GACCENT0 [HAE0],  GACCENT1 [HAE1],   GACCENT2 [HAE2]
&        , VENTILE  [VTL] ,  VENTILE2 [VT2] , GACCDUD [DUDD] # Pour les avoir par défaut

Local Integer I, J, K, OK, NOL,NOLI, GENEURO
Local Integer NBPCE
Local Integer STAT
Local Char    TIT(50)
Local Char    MESSA(250)
Local Char    SYMBOLE(50)
Local Char    TYP(GLONGTE) , NUM(GLONVCR)
Local Char    SOCIETE(GLONCPY)

Local Integer MAXLIG , MAXVTL , NBR_ECH , OKPCE
MAXLIG = dim([M:HAEW]ACC)
MAXVTL = dim([M:VTL]AMT)
NBR_ECH = dim([M:DUDD]DUDDAT)+1
Local Decimal AROLOC , ARORPT
Local Integer INDREF, NBLET , TBLET(1..NBR_ECH) , DUDLIG(1..NBR_ECH)
Local Decimal AMTIPT(1..NBR_ECH)
Local Char TYPORG(GLONGTE)
Local Char PCEORG(GLONVCR)
Local Char VLEG(GLONADI)

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
# Dossier mono-leg we force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

## For the netting
Local Decimal AMTIPT2(1..NBR_ECH)
Local Integer NET , FLGCURCPY
Local Char    CHKCUR(GLONCUR), SVGTYPPCE(GLONGTE), SVGNUMPCE(GLONVCR)

Return
##############################################################################################
##############################################################################################
$CONTROLE

Read [F:HAE]HAE0=DOCTYP;DOCNUM
If fstat
  RETCOD = 1
  RETMES = [F:HAE]TYP-[F:HAE]NUM-mess(28,107,1)
  Return
Endif

Read [F:JOU]JOU0=[F:HAE]JOU
Call CONTEXE([F:JOU]ACS) From CPTSUB
If mkstat
  RETCOD = 1
  RETMES = [F:JOU]JOU-GMESSAGE
  Return
Endif

Call CONTFCY([F:HAE]FCY) From CPTSUB
If mkstat
  RETCOD = 1
  RETMES = GMESSAGE
  Return
Endif

Return
##############################################################################################
##############################################################################################
$REVERSE

#Lock document
SYMBOLE = "HAE"+[F:HAE]NUM+"\"+[F:HAE]TYP
Lock =SYMBOLE With lockwait=0
If fstat=1
  RETCOD = 1
  RETMES = [F:HAE]TYP-[F:HAE]NUM-mess(10,100,1)
  Return
Endif

Local Tinyint TRANS_MAN : TRANS_MAN = 1

If adxlog
  TRANS_MAN = 0
Else
  Trbegin  [HAE], [DAE], [DAA], [AVN]
Endif

Readlock [HAE]HAE0=DOCTYP;DOCNUM
If fstat
  RETCOD = 1
  RETMES = [F:HAE]TYP-[F:HAE]NUM-mess(10,100,1)
  Goto END_REVERSE
Endif

# Screen loading
Raz [M:HAE0], [M:HAE1], [M:HAE2]

[M:HAE0] = [F:HAE]
[M:HAE1] = [F:HAE]

[M:HAE1]DESVCR = ""
If [L]RACCDAT<>[0/0/0] : [M:HAE0]ACCDAT=[L]RACCDAT : Endif
If [L]RDESVCR<>""      : [M:HAE1]DESVCR=[L]RDESVCR : Endif

TYP = [F:HAE]TYP
NUM = [F:HAE]NUM

Gosub LIENS From SUBGAS

#119323
Local Decimal  SAVACCNUM(1..dim([M:HAEW]ACCNUM))
Local Decimal  SAVLINREF(1..dim([M:HAEW]ACCNUM))
# For the line to reverse with IDTLIN=LIAIS, storage of [M:HAEW]accnum and [M:HAEW]linref
I = 0
Raz SAVACCNUM, SAVLINREF
For NOL=0 To [M:HAEW]NB-1
  If [M:HAEW]IDTLIN(NOL)="LIAIS"
    I +=1
    SAVACCNUM(I) = [M:HAEW]ACCNUM(NOL)
    SAVLINREF(I) = [M:HAEW]LINREF(NOL)
  Endif
Next

[M:HAE0]NUM = ""

[M:HAE1]RVSORITYP=TYP
[M:HAE1]RVSORINUM=NUM
[M:HAE1]ENTDAT = [M:HAE0]ACCDAT
[M:HAE1]DUDDAT = [M:HAE0]ACCDAT
[M:HAE1]VALDAT = [M:HAE0]ACCDAT
[M:HAE1]RVS = 1
[M:HAE1]RVSDAT = [0/0/0]
[M:HAE1]ORIMOD = 2

If [M:HAE1]DESVCR = ""
  #--- Reversal description : we replace the char '*' by TYP-NUM
  K = instr(1,mess(92,106,1),"*")
  If K
    #--- TYP NUM reversed
    [M:HAE1]DESVCR = left$(mess(92,106,1),K-1) + TYP-NUM + right$(mess(92,106,1),K+1)
  Endif
Endif

## For the management of the documents in currency IN /OUT
Raz GENEURO
If [M:HAE1]CUR<>GEURO
  Call LEC_TCU([M:HAE1]CUR) From CPTLEC
  # Validation date
  If [F:TCU]EURFLG=2 & [M:HAE0]ACCDAT>=[F:TCU]CURENDDAT
    Call LECLED([F:HAE]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
    If DEVLED = GEURO
      GENEURO = 1
      [M:HAE1]CUR = GEURO
    Else
      # The company is not converted to Euro
      MESSA = "("+[M:HAE0]CPY+")"-mess(99,106,1)
      RETCOD = 1
      RETMES = [F:HAE]TYP-[F:HAE]NUM-MESSA
      Goto END_REVERSE
    Endif
  Endif
Endif

Default Mask [M:HAE2]
For NOL=0 To [M:HAE2]NBLIG-1
  Case [L]EXTSNS
    When 1 : # Debit <=> credit
      If [M]DEB(NOL)<>0
        [M]CDT(NOL) = [M]DEB(NOL)
        [M]DEB(NOL) = 0
        If GENEURO : [M]CDT(NOL)=evalue("[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")") : Endif
      Elsif [M]CDT(NOL)<>0
        [M]DEB(NOL) = [M]CDT(NOL)
        [M]CDT(NOL) = 0
        If GENEURO : [M]DEB(NOL)=evalue("[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")") : Endif
      Endif
    When 2 : # Amount <=> amount <0
      [M]DEB(NOL) = -[M]DEB(NOL)
      [M]CDT(NOL) = -[M]CDT(NOL)

      If GENEURO
        [M]DEB(NOL) = -[M]AMTLED(NOL)
        [M]CDT(NOL) = -[M]AMTLED(NOL)
        Assign "[M]DEB("+num$(NOL)+")" With - evalue("[M]AMT"+num$([M]LEDTYP)+"("+num$(NOL)+")")
      Endif

      If dim([M]QTY)>0
        [M]QTY(NOL) = -[M]QTY(NOL)
      Endif
      If [M]DSP(NOL)="$"
        For I=[M]PTV(NOL) To [M]PTF(NOL)
          [M:VT2]TBAMT(I) = -[M:VT2]TBAMT(I)
          [M:VT2]TBQTY(I) = -[M:VT2]TBQTY(I)
        Next I
      Endif
  Endcase

  If ([M]DEB(NOL)=0 & [M]CDT(NOL)=0) or EXTSNS=2
    For I=1 To len(mess(0,2644,1))
      Assign "[M]AMT"+num$(I)+"("+num$(NOL)+")" With - evalue("[M]AMT"+num$(I)+"("+num$(NOL)+")")
      Assign "[M]AMTFRC"+num$(I)+"("+num$(NOL)+")" With - evalue("[M]AMTFRC"+num$(I)+"("+num$(NOL)+")")
    Next
  Endif

Next NOL

Raz [M:HAE2]ACCNUM, [M:HAE2]CHRNUM, [M:HAE2]CHK, [M:HAE2]CHKDAT
Raz [M:HAE2]MTC, [M:HAE2]MTCDAT, [M:HAE2]MTCDATMAX, [M:HAE2]MTCDATMIN
Raz [M:HAE2]AMTVAT

# Screen control
Local Mask [M:HAE0],[M:HAE1],[M:HAE2]
Call CONTROLE(STAT,MESSA) From CPTBATCH
If STAT
  Gosub MESSAGE From CPTAUTO
  RETCOD = 1
  RETMES = [F:HAE]TYP-[F:HAE]NUM-MESSA
  Goto END_REVERSE
Endif

# Update the original document
[F:HAE]RVS = 3   : # Reversed
TYPORG = [F:HAE]TYP : PCEORG = [F:HAE]NUM
Rewrite [HAE]
If fstat
  GOK=0 : Call FSTA("HAE") From GLOCK : Goto END_REVERSE
Endif

Call VALPIECE(RETCOD,RETMES)
If RETCOD : Goto END_REVERSE : Endif

# Matching with the original document
For NOL=0 To [M:HAEW]NB-1
  INDREF = [M:HAEW]LEDTYP(NOL)
  If [M:HAEF]GENC(INDREF-1) = 2 & [M:HAEF]MTC(INDREF-1) = 2
    Call LEC_GAC([M:HAEW]ACC(NOL),[M:HAEW]COA(NOL)) From CPTLEC
    If !fstat & [F:GAC]MTC=2
      NBLET = 2
      #119323
      If [M:HAEW]IDTLIN(NOL)="LIAIS"
        I = find([M:HAEW]LINREF(NOL),SAVLINREF)
        If I>0
          Read [DAEX]DAE2=SAVACCNUM(I)
        Endif
      Else
        Read [DAEX]DAE0 = [L]TYP;[L]NUM;[M:HAEW]LIN(NOL);INDREF
      Endif
      If !fstat
        TBLET(1)  = [F:DAEX]ACCNUM
        DUDLIG(1) = 1
        AMTIPT(1) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
      Else
        #119323
        If [M:HAEW]IDTLIN(NOL)="LIAIS"
          If I>0
            Read [DATX]DAT1 = SAVACCNUM(I)
          Endif
        Else
          Read [DATX]DAT0 = [L]TYP;[L]NUM;[M:HAEW]LIN(NOL);INDREF
        Endif
        If !fstat
          TBLET(1)  = [F:DATX]ACCNUM
          DUDLIG(1) = 1
          AMTIPT(1) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
        Endif
      Endif
      TBLET(2)  = [M:HAEW]ACCNUM(NOL)
      DUDLIG(2) = 1
      AMTIPT(2) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
      Call LETDIF(NBLET,TBLET,DUDLIG,AMTIPT,2) From CPTLET
      If GOK<1 : Break : Endif
    Endif
  Endif
Next NOL

If GOK<=0 : RETCOD = 1 : Goto END_REVERSE : Endif

Call ESPION("GACCENTRY",1,[F:HAE]TYP,[F:HAE]NUM) From ESPION

$END_REVERSE
Unlock =SYMBOLE

If TRANS_MAN
  If RETCOD = 0
    Commit
  Else
    Rollback
  Endif
Endif

Return
##############################################################################################
##############################################################################################
Subprog VALPIECE(RETCOD,RETMES)
Variable Integer RETCOD
Variable Char    RETMES

Local File GACCTMP [HAE] , GACCTMPD [DAE] , GACCTMPA [DAA]

Call VALPIECE(RETCOD,RETMES) From CPTBATCH

End
##############################################################################################
##############################################################################################

End

