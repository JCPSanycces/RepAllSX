#<AdxTL>@(#)8.0.0.0 $Revision$
#############################################################################
#  SIXFONCTION: pour les func de bascule Integrale --> X3                   #
#############################################################################
#                                                                           #
# $SI_CONTEXT                                                               #
#    Crée les variables globales utilisées dans le traitements SIX*         #
#                                                                           #
# Funprog SI_COR                                                            #
#   Correspondance d'un champ (concerne notamment les clés)                 #
#                                                                           #
# Funprog SI_CLOB                                                           #
#   Concerne les textes achats, ventes, et autres à définir                 #
#   Retourne la clé du clob à enregistrer dans la table                     #
#                                                                           #
# Subprog SI_INICCE                                                         #
#   Alimentation des sections analytiques lignes documents X3               #
#                                                                           #
# $SI_BEFWRI                                                                #
#   Point entrée commun à appeler avant création un enregistrement          #
#                                                                           #
#############################################################################

#############################################################################
# SI_CONTEXT : Crée les variables globales utilisées
#              dans le traitements SIX*
#############################################################################
$SI_CONTEXT
# variables utilisées en migration Intégrale --> X3
    Global Integer SI_PRODUIT
    Call NOMBRA(11,SI_PRODUIT) From GLOCK
    If SI_PRODUIT<>6    # Si <> X2
        SI_PRODUIT=1    # alors c'est X3
    Endif
    Global Char    SI_TABLE    (30)       # Nom de table : - lue après le PE SI_CRITSUP
                                          #                - écrite après le PE SI_BEFWRI
    Global Integer SI_SIMU                # 2=mode simulation
    Global Char    SI_DOSSIER  (30)  : SI_DOSSIER =nomap   : # Dossier ation
    Global Char    SI_SUBPRG   (30)       # Nom du sous-programme de migration (permet de positionner le contexte avant un PE)
    Global Char    SI_MES(250) (300)      # Liste des messages spécifiques à la migration Intégrale
    Global Char    SI_CRITERE  (250)      # Filtre supplémentaire
    Global Char    SI_CLOB     (100) (20) # Table de stockage du texte a ecrire en format clob

    Global Char    SI_CRITART(250)         # Critère de sélection des articles Intégrale
    SI_CRITART = '([F]NATPDT<>"TX"&[F]NATPDT<>"MO"&[F]NATPDT<>"OP")&([F]NAT=""|[F]NAT="CO"|[F]NAT="FR"|[F]NAT="PO"|[F]NAT="SE")'
    Global Char    SI_CRITART_0(250)         # Critère de sélection des articles Intégrale
    SI_CRITART_0 = "NATPDT_0 not in ('TX','MO','OP') and NAT_0 not in('SD','ST','TD','TP','TX')"

    Gosub SI_MESS   From SIXFONCTION
    Gosub SI_OUVTAB From SIXFONCTION

    # A l'importation des tables, la table XISOC n'existe pas
    If filinfo(filpath("FIL","XISOC", "fde",SI_DOSSIER),0)>=0
        If !clalev([XSOC]) : Local File XISOC [XSOC] : Endif
        Read [XSOC] First
        GDECPRI=[F:XSOC]NBRDMLPRX
    Endif
Return

$SI_OUVTAB
    If clalev ([F:KART])=0 & filinfo(filpath("FIL","XIART","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIART"       [KART] : Endif
    If clalev ([F:KACT])=0 & filinfo(filpath("FIL","XIARTCDT","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIARTCDT" [KACT] : Endif
    If clalev ([F:KCLT])=0 & filinfo(filpath("FIL","XICLT","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XICLT"       [KCLT] : Endif
    If clalev ([F:KDVS])=0 & filinfo(filpath("FIL","XIDVS","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIDVS"       [KDVS] : Endif
    If clalev ([F:KDPO])=0 & filinfo(filpath("FIL","XIDPO","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIDPO"       [KDPO] : Endif
    If clalev ([F:KFAM])=0 & filinfo(filpath("FIL","XIFAMART","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIFAMART" [KFAM] : Endif
    If clalev ([F:KFAC])=0 & filinfo(filpath("FIL","XIFAMCLT","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIFAMCLT" [KFAC] : Endif
    If clalev ([F:KFAF])=0 & filinfo(filpath("FIL","XIFAMFOU","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIFAMFOU" [KFAF] : Endif
    If clalev ([F:KFCT])=0 & filinfo(filpath("FIL","XIFCTAFT","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIFCTAFT" [KFCT] : Endif
    If clalev ([F:KFOU])=0 & filinfo(filpath("FIL","XIFOU","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIFOU"       [KFOU] : Endif
    If clalev ([F:KLAN])=0 & filinfo(filpath("FIL","XILAN","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XILAN"       [KLAN] : Endif
    If clalev ([F:KMEX])=0 & filinfo(filpath("FIL","XIMODEXD","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIMODEXD" [KMEX] : Endif
    If clalev ([F:KMTP])=0 & filinfo(filpath("FIL","XIMODTSP","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIMODTSP" [KMTP] : Endif
    If clalev ([F:KMGL])=0 & filinfo(filpath("FIL","XIMODRGL","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIMODRGL" [KMGL] : Endif
    If clalev ([F:KNLE])=0 & filinfo(filpath("FIL","XINSRLTENT","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XINSRLTENT" [KNLE] : Endif
    If clalev ([F:KNMC])=0 & filinfo(filpath("FIL","XINMC","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XINMC"       [KNMC] : Endif
    If clalev ([F:KNTC])=0 & filinfo(filpath("FIL","XINUMTNCLT","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XINUMTNCLT" [KNTC] : Endif
    If clalev ([F:KPAY])=0 & filinfo(filpath("FIL","XIPAY","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIPAY"       [KPAY] : Endif
    If clalev ([F:KREP])=0 & filinfo(filpath("FIL","XIREP","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIREP"       [KREP] : Endif
    If clalev ([F:KSOC])=0 & filinfo(filpath("FIL","XISOC","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XISOC"       [KSOC] : Endif
    If clalev ([F:KSFA])=0 & filinfo(filpath("FIL","XISOUFMART","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XISOUFMART" [KSFA] : Endif
    If clalev ([F:KSFC])=0 & filinfo(filpath("FIL","XISOUFMCLT","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XISOUFMCLT" [KSFC] : Endif
    If clalev ([F:KSFF])=0 & filinfo(filpath("FIL","XISOUFMFOU","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XISOUFMFOU" [KSFF] : Endif
    If clalev ([F:KTPF])=0 & filinfo(filpath("FIL","XITAXPFC","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XITAXPFC" [KTPF] : Endif
    If clalev ([F:KTVV])=0 & filinfo(filpath("FIL","XITVAVEN","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XITVAVEN" [KTVV] : Endif
    If clalev ([F:KTVA])=0 & filinfo(filpath("FIL","XITVAACH","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XITVAACH" [KTVA] : Endif
    If clalev ([F:KUNI])=0 & filinfo(filpath("FIL","XIUNIFAC","fde",SI_DOSSIER),0)>=0 : Local File =SI_DOSSIER+".XIUNIFAC" [KUNI] : Endif

    If !clalev([SVB]) : Local File SIPARVACB [SVB] : Endif

 Return

#############################################################################
# SI_COR :  Correspondance d'un champ (concerne notamment les clés)
#############################################################################
# Paramètres E: NOMFIC     = Table integrale sous la forme XIxxxx
#               OLDVALEURx = Valeur origine dans intégrale (sous forme num$)
#               NOMTBL     = table ou table diverse X3 dans laquelle on contrôle l'existence de la nlle valeur
#                            (si non renseigné il n'y a pas de controle)
#                            Si le caractère '#' se trouve dans NOMTBL, la non existence de l'enregistrement
#                            dans la table XI ne déclenchera pas d'erreur
#               MES        = Message
#############################################################################
Funprog SI_COR(NOMFIC,OLDVALEUR1,NOMTBL,MES)
Value Char NOMFIC ()             : # Table integrale XIxxxx
Value Char OLDVALEUR1 ()         : # Champ cle integrale
Value Char NOMTBL ()             : # Nom de la table X3 dans laquelle on contrôle l'existence de la nlle valeur ou n° table diverse (facultatif)
Value Char MES ()                : # Message en cas d'erreur du contrôle d'existence (facultatif)

Local Integer NBCLE
NBCLE=1
Goto SI_CORX

Funprog SI_COR2(NOMFIC,OLDVALEUR1,OLDVALEUR2,NOMTBL,MES)
Value Char NOMFIC ()             : # Table integrale XIxxxx
Value Char OLDVALEUR1 ()         : # 1er élement de clé integrale
Value Char OLDVALEUR2 ()         : # 2ème élement de clé integrale
Value Char NOMTBL ()             : # Nom de la table X3 dans laquelle on contrôle l'existence de la nlle valeur ou n° table diverse (facultatif)
Value Char MES ()                : # Message en cas d'erreur du contrôle d'existence (facultatif)

Local Integer NBCLE
NBCLE=2
Goto SI_CORX

Funprog SI_COR3(NOMFIC,OLDVALEUR1,OLDVALEUR2,OLDVALEUR3,NOMTBL,MES)
Value Char NOMFIC ()             : # Table integrale XIxxxx
Value Char OLDVALEUR1 ()         : # 1er élement de clé integrale
Value Char OLDVALEUR2 ()         : # 2ème élement de clé integrale
Value Char OLDVALEUR3 ()         : # 3ème élement de clé integrale
Value Char NOMTBL ()             : # Nom de la table X3 dans laquelle on contrôle l'existence de la nlle valeur ou n° table diverse (facultatif)
Value Char MES ()                : # Message en cas d'erreur du contrôle d'existence (facultatif)

Local Integer NBCLE
NBCLE=3
Goto SI_CORX

Funprog SI_COR4(NOMFIC,OLDVALEUR1,OLDVALEUR2,OLDVALEUR3,OLDVALEUR4,NOMTBL,MES)
Value Char NOMFIC ()             : # Table integrale XIxxxx
Value Char OLDVALEUR1 ()         : # 1er élement de clé integrale
Value Char OLDVALEUR2 ()         : # 2ème élement de clé integrale
Value Char OLDVALEUR3 ()         : # 3ème élement de clé integrale
Value Char OLDVALEUR4 ()         : # 4ème élement de clé integrale
Value Char NOMTBL ()             : # Nom de la table X3 dans laquelle on contrôle l'existence de la nlle valeur ou n° table diverse (facultatif)
Value Char MES ()                : # Message en cas d'erreur du contrôle d'existence (facultatif)
Local Integer NBCLE
NBCLE=4
Goto SI_CORX

$SI_CORX

If  OLDVALEUR1=""
& & (dim(OLDVALEUR2)<=0 | OLDVALEUR2="")
& & (dim(OLDVALEUR3)<=0 | OLDVALEUR3="")
& & (dim(OLDVALEUR4)<=0 | OLDVALEUR4="")
    End ""
Endif

Local Char NEWVALEUR (50)
Local Char NOMTABLE(50) : NOMTABLE = NOMTBL
Local Char TRA(250)

SAUV_DEFAULT=dbgstr(2)

# Législation - Migration Intégrale => une et une seule société.
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"      [CPY]   : Endif  # Sociétés
Read [CPY]CPY0 First
If !fstat
 GCURLEG = [F:CPY]LEG
Else
 GCURLEG = ""
Endif


Case NOMFIC

  When "XIART"
       If clalev ([F:KART])=0 : Local File =SI_DOSSIER+".XIART"      [KART] : Endif
       Default File [KART]

  When "XICLT"
       If clalev ([F:KCLT])=0 : Local File =SI_DOSSIER+".XICLT"      [KCLT] : Endif
       Default File [KCLT]

  When "XIDPO"
       If clalev ([F:KDPO])=0 : Local File =SI_DOSSIER+".XIDPO"      [KDPO] : Endif
       Default File [KDPO]

  When "XIDVS"
       If clalev ([F:KDVS])=0 : Local File =SI_DOSSIER+".XIDVS"      [KDVS] : Endif
       Default File [KDVS]

  When "XIFAMART"
       If clalev ([F:KFAM])=0 : Local File =SI_DOSSIER+".XIFAMART"   [KFAM] : Endif
       Default File [KFAM]

  When "XIFAMCLT"
       If clalev ([F:KFAC])=0 : Local File =SI_DOSSIER+".XIFAMCLT"   [KFAC] : Endif
       Default File [KFAC]

  When "XIFAMFOU"
       If clalev ([F:KFAF])=0 : Local File =SI_DOSSIER+".XIFAMFOU"   [KFAF] : Endif
       Default File [KFAF]

  When "XIFCTAFT"
       If clalev ([F:KFCT])=0 : Local File =SI_DOSSIER+".XIFCTAFT"   [KFCT] : Endif
       Default File [KFCT]

  When "XIFOU"
       If clalev ([F:KFOU])=0 : Local File =SI_DOSSIER+".XIFOU"      [KFOU] : Endif
       Default File [KFOU]

  When "XILAN"
       If clalev ([F:KLAN])=0 : Local File =SI_DOSSIER+".XILAN"      [KLAN] : Endif
       Default File [KLAN]

  When "XIMODEXD"
       If clalev ([F:KMEX])=0 : Local File =SI_DOSSIER+".XIMODEXD"   [KMEX] : Endif
       Default File [KMEX]

  When "XIMODRGL"
       If clalev ([F:KMGL])=0 : Local File =SI_DOSSIER+".XIMODRGL"   [KMGL] : Endif
       Default File [KMGL]

  When "XIMODTSP"
       If clalev ([F:KMTP])=0 : Local File =SI_DOSSIER+".XIMODTSP"   [KMTP] : Endif
       Default File [KMTP]

  When "XINMC"
       If clalev ([F:KNMC])=0 : Local File =SI_DOSSIER+".XINMC"      [KNMC] : Endif
       Default File [KNMC]

  When "XINSRLTENT"
       If clalev ([F:KNLE])=0 : Local File =SI_DOSSIER+".XINSRLTENT" [KNLE] : Endif
       Default File [KNLE]

  When "XINUMTNCLT"
       If clalev ([F:KNTC])=0 : Local File =SI_DOSSIER+".XINUMTNCLT" [KNTC] : Endif
       Default File [KNTC]

  When "XIPAY"
       If clalev ([F:KPAY])=0 : Local File =SI_DOSSIER+".XIPAY"      [KPAY] : Endif
       Default File [KPAY]

  When "XIREP"
       If clalev ([F:KREP])=0 : Local File =SI_DOSSIER+".XIREP"      [KREP] : Endif
       Default File [KREP]

  When "XISOC"
       If clalev ([F:KSOC])=0 : Local File =SI_DOSSIER+".XISOC"      [KSOC] : Endif
       Default File [KSOC]

  When "XISOUFMART"
       If clalev ([F:KSFA])=0 : Local File =SI_DOSSIER+".XISOUFMART" [KSFA] : Endif
       Default File [KSFA]

  When "XISOUFMCLT"
       If clalev ([F:KSFC])=0 : Local File =SI_DOSSIER+".XISOUFMCLT" [KSFC] : Endif
       Default File [KSFC]

  When "XISOUFMFOU"
       If clalev ([F:KSFF])=0 : Local File =SI_DOSSIER+".XISOUFMFOU" [KSFF] : Endif
       Default File [KSFF]

  When "XITAXPFC"
       If clalev ([F:KTPF])=0 : Local File =SI_DOSSIER+".XITAXPFC"   [KTPF] : Endif
       Default File [KTPF]

  When "XITVAVEN"
       If clalev ([F:KTVV])=0 : Local File =SI_DOSSIER+".XITVAVEN"   [KTVV] : Endif
       Default File [KTVV]

  When "XITVAACH"
       If clalev ([F:KTVA])=0 : Local File =SI_DOSSIER+".XITVAACH"   [KTVA] : Endif
       Default File [KTVA]

  When "XIUNIFAC"
       If clalev ([F:KUNI])=0 : Local File =SI_DOSSIER+".XIUNIFAC"   [KUNI] : Endif
       Default File [KUNI]

  When "XIPLACBGNR"
       If clalev ([F:KPCG])=0 : Local File =SI_DOSSIER+".XIPLACBGNR"   [KPCG] : Endif
       Default File [KPCG]

  When "XIPLACBAUX"
       If clalev ([F:KPCA])=0 : Local File =SI_DOSSIER+".XIPLACBAUX"   [KPCA] : Endif
       Default File [KPCA]

  When "XIJRN"
       If clalev ([F:KJRN])=0 : Local File =SI_DOSSIER+".XIJRN"   [KJRN] : Endif
       Default File [KJRN]

  When Default
       NEWVALEUR=OLDVALEUR1 : Goto FINCOR

Endcase

If dim([F]X3CLE)<=0 : NEWVALEUR=OLDVALEUR1 : Goto CTLCOR : Endif

Case NOMFIC

    When "XITAXPFC","XITVAVEN","XITVAACH" :
            Read [F]IND0=val(OLDVALEUR1);OLDVALEUR2            : # 1er element de cle numerique
    When "XINUMTNCLT", "XISOC" :
            Read [F]IND0=val(OLDVALEUR1)                       : # 1er element de cle numerique
    When "XINMC" :
            Read [F]IND0=OLDVALEUR1;OLDVALEUR2;val(OLDVALEUR3);val(OLDVALEUR4)
    When "XIART" :
            Read [F]IND0=OLDVALEUR1
            If fstat    # Si ce n'est pas un article, c'est peut-être un article conditionné
                If !clalev([F:KACT]) : Local File =SI_DOSSIER+".XIARTCDT" [KACT] : Endif
                Read [KACT]IND0=OLDVALEUR1
                If !fstat
                    Read [KART]IND0=[F:KACT]ARTPCP
                Endif
            Endif
    When Default
        Case NBCLE
            When 1:
                Read [F]IND0=OLDVALEUR1
            When 2:
                Read [F]IND0=OLDVALEUR1;OLDVALEUR2
            When 3:
                Read [F]IND0=OLDVALEUR1;OLDVALEUR2;OLDVALEUR3
            When 4:
                Read [F]IND0=OLDVALEUR1;OLDVALEUR2;OLDVALEUR3;OLDVALEUR4
       Endcase
Endcase


If fstat
    If instr(1,NOMTABLE,"#")<=0
      # Code inexistant (nom_table) :
        TRA  = MES-mess(10,112,1)+" ("+NOMFIC+"): "
        TRA -= SI_MES(39)-OLDVALEUR1
        If dim(OLDVALEUR2)>0
            TRA += ";"-OLDVALEUR2
            If dim(OLDVALEUR3)>0
                TRA += ";"-OLDVALEUR3
                If dim(OLDVALEUR4)>0
                    TRA += ";"-OLDVALEUR4
                Endif
            Endif
        Endif
        Call ECR_TRACE(TRA, 1) From GESECRAN
        Raz NEWVALEUR
    Endif
    Goto FINCOR
Endif

NOMTABLE = ctrans(NOMTABLE,"#","")

NEWVALEUR=num$([F]X3CLE)

$CTLCOR
If NOMTABLE <> ""
   Case NOMTABLE
        When "20", "21", "30", "31", "40", "41" :
             If !clalev([F:ADI]) : Local File =SI_DOSSIER+".ATABDIV" [ADI] : Endif
             Look [ADI]CODE=val(NOMTABLE);NEWVALEUR
             NOMTABLE="ATABDIV - "+NOMTABLE

        When "237", "409" :
             If mess(val(NEWVALEUR),val(NOMTABLE),1) = ""
                # Menu local xxx
                NOMTABLE = mess(4,11,1)-NOMTABLE
                fstat = 1
             Endif

        When "ACODNUM" :
             If !clalev([F:ANM]) : Local File =SI_DOSSIER+"."+NOMTABLE [ANM] : Endif
             Look [ANM]ANM0=NEWVALEUR

        When "AUTILIS" :
             If !clalev([F:AUS]) : Local File =SI_DOSSIER+"."+NOMTABLE [AUS] : Endif
             Look [AUS]CODUSR=NEWVALEUR

        When "BPCARRIER" :
             If !clalev([F:BPT]) : Local File =SI_DOSSIER+"."+NOMTABLE [BPT] : Endif
             Look [BPT]BPT0=NEWVALEUR

        When "BPCUSTOMER" :
             If !clalev([F:BPC]) : Local File =SI_DOSSIER+"."+NOMTABLE [BPC] : Endif
             Look [BPC]BPC0=NEWVALEUR

        When "BPSUPPLIER" :
             If !clalev([F:BPS]) : Local File =SI_DOSSIER+"."+NOMTABLE [BPS] : Endif
             Look [BPS]BPS0=NEWVALEUR

        When "COMPANY" :
             If !clalev([F:CPY]) : Local File =SI_DOSSIER+"."+NOMTABLE [CPY] : Endif
             Look [CPY]CPY0=NEWVALEUR

        When "FACILITY" :
             If !clalev([F:FCY]) : Local File =SI_DOSSIER+"."+NOMTABLE [FCY] : Endif
             Look [FCY]FCY0=NEWVALEUR

        When "FACTOR" :
             If !clalev([F:FCT]) : Local File =SI_DOSSIER+"."+NOMTABLE [FCT] : Endif
             Look [FCT]FCT0=NEWVALEUR

        When "ITMMASTER" :
             If !clalev([F:ITM]) : Local File =SI_DOSSIER+"."+NOMTABLE [ITM] : Endif
             Look [ITM]ITM0=NEWVALEUR

        When "SALESREP" :
             If !clalev([F:REP]) : Local File =SI_DOSSIER+"."+NOMTABLE [REP] : Endif
             Look [REP]REP0=NEWVALEUR

        When "TABCOUNTRY" :
             If !clalev([F:TCY]) : Local File =SI_DOSSIER+"."+NOMTABLE [TCY] : Endif
             Look [TCY]TCY0=NEWVALEUR

        When "TABCUR" :
             If !clalev([F:TCU]) : Local File =SI_DOSSIER+"."+NOMTABLE [TCU] : Endif
             Look [TCU]TCU0=NEWVALEUR

        When "TABLAN" :
             If !clalev([F:TLA]) : Local File =SI_DOSSIER+"."+NOMTABLE [TLA] : Endif
             Look [TLA]TLA0=NEWVALEUR

        When "TABMODELIV" :
             If !clalev([F:TMD]) : Local File =SI_DOSSIER+"."+NOMTABLE [TMD] : Endif
             Look [TMD]TMD0=NEWVALEUR

        When "TABUNIT" :
             If !clalev([F:TUN]) : Local File =SI_DOSSIER+"."+NOMTABLE [TUN] : Endif
             Look [TUN]TUN0=NEWVALEUR

        When "TABPAYTERM" :
             If !clalev([F:TPT]) : Local File =SI_DOSSIER+"."+NOMTABLE [TPT] : Endif
             Look [TPT]TPT0=NEWVALEUR;GCURLEG;1
             If fstat
              Look [TPT]TPT0=NEWVALEUR;"";1
             Endif

        When "TABVAT" :
             If !clalev([F:TVT]) : Local File =SI_DOSSIER+"."+NOMTABLE [TVT] : Endif
             #--CPO 71937 TVT et multi-lég
             #Look [TVT]TVT0=NEWVALEUR
             Look [TVT]TVT0=NEWVALEUR;GCURLEG
             If fstat
              Look [TVT]TVT0=NEWVALEUR;""
             Endif

        When "TABPAM" :
#             If !clalev([F:TAM]) : Local File =SI_DOSSIER+"."+NOMTABLE [TAM] : Endif
#             Look [TAM]TAM0=NEWVALEUR;GCURLEG

   Endcase
   If fstat
      # Code inexistant (nom_table) :
        TRA  = MES-mess(10,112,1)+" ("+NOMTABLE+"): "
        TRA += NEWVALEUR+string$(vireblc(NEWVALEUR,4)="","<"+toupper(mess(1,757,1))+">")-";"
        TRA -= SI_MES(39)-OLDVALEUR1
        If dim(OLDVALEUR2)>0
            TRA += ";"-OLDVALEUR2
            If dim(OLDVALEUR3)>0
                TRA += ";"-OLDVALEUR3
                If dim(OLDVALEUR4)>0
                    TRA += ";"-OLDVALEUR4
                Endif
            Endif
        Endif
        Call ECR_TRACE(TRA, 1) From GESECRAN
        Raz NEWVALEUR
   Endif
Endif

$FINCOR
Default File SAUV_DEFAULT
End NEWVALEUR

#########################################################
# Renvoie le régime de taxe client
#########################################################
# Paramètres E : PTYPBPR = "S":fournisseur ; "C":Client
#                PREGTVA = "O" : soumis
#                          "N" : exonéré
#                          "C" : CEE
#                          "E" : Export
#                          "I" : Import
#                PREGTPF = "O" : Oui ; "N" : Non
#                PTAXADD = "O" : Oui ; "N" : Non
#                PCODPAY = Code pays Integrale
#########################################################
Funprog SI_VACBPR(PTYPBPR,PREGTVA, PREGTPF, PTAXADD, PCODPAY)
Value Char PTYPBPR  # FGR 01/02/2010 : X3SUIVI60986
Value Char PREGTVA
Value Char PREGTPF
Value Char PTAXADD
Value Char PCODPAY

Raz [F:SVB]
Read [SVB]SVB0=[F:SPX]CLE;PTYPBPR;PREGTVA;PREGTPF;PTAXADD;PCODPAY
If fstat
    Read [SVB]SVB0=[F:SPX]CLE;PTYPBPR;PREGTVA;PREGTPF;PTAXADD;""
Endif

End [F:SVB]VACBPR


#######################################################################
# Renvoie le bon code taxe X3 (niveau 1)
#######################################################################
# Paramètres E : WTVADBTENC1 = Régime débit/encaissement entête pièce
#                WTVADBTENC2 = Régime débit/encaissement ligne pièce
#                WCODPAY     = Code pays (tiers ou ligne adresse)
#                WCODTVA     = Code tva ligne pièce Intégrale
#                WVACBPR     = Régime du tiers X3
#                WCODART     = Code article ligne pièce Intégrale
#######################################################################
Funprog SI_VAT1(WTVADBTENC1,WTVADBTENC2,WCODPAY,WCODTVA,WVACBPR,WCODART)
Value Char    WTVADBTENC1
Value Char    WTVADBTENC2
Value Char    WCODPAY
Value Integer WCODTVA
Value Char    WVACBPR
Value Char    WCODART
#-----
Local Char WVAT(GLONVAT)
Local Char WTVADBTENC
#----- Détermination du régime débit/encaissement -----#
If WTVADBTENC2=""
  If WTVADBTENC1<>"E"
    WTVADBTENC="D"
  Else
    WTVADBTENC="E"
  Endif
Else
  WTVADBTENC=WTVADBTENC2
Endif
#----- Lecture de l'article Intégrale si nécessaire -----#
If [F:XART]CODART<>WCODART
  Read [XART] IND0=WCODART
  If fstat
    #----- Article non trouvé, voir si article conditionné -----#
    Read [XACT] IND0=WCODART
    If !fstat
      Read [XART] IND0=[F:XACT]ARTPCP : If fstat  Raz [F:XART] : Endif
    Else
      Raz [F:XACT], [F:XART]
    Endif
    #-----
  Endif
Endif
#----- Recherche si le paramétrage taxe existe -----#
Read [SPV] SPV0=[F:SPX]CLE;[F:XART]CODTVAVEN;WCODTVA;WTVADBTENC;0
If fstat  Raz [F:SPV] : Endif
#----- Le paramétrage a été trouvé, on connait le niveau de taxe -----#
If [F:SPV]VACITM1<>""
  #----- Lecture table détermination des codes taxe si nécessaire -----#
  For [TVC] TVC2 Where VATTYP=1
&                    & ENAFLG=2
&                    & LEG<=GCURLEG
&                    & VACBPR=WVACBPR
&                    & VACITM=[F:SPV]VACITM1
    Raz fstat : Gosub CONTROLE_TVC From TRTX3 : If !fstat  WVAT=[F:TVC]VAT : Break : Endif
  Next
  #-----
Endif
#----- Aucun code taxe trouvé, on le recherche avec le transcodage -----#
If WVAT=""
  WVAT=func SIXFONCTION.SI_COR2("XITVAACH",num$(WCODTVA),WCODPAY,"TABVAT","")
Endif
#-----
End WVAT


#############################################################################
# SI_CLOB :  Creation d'un texte clob dans la table TEXCLOB
#############################################################################
# Prerequis : Garnir le texte dans la variable globale SI_CLOB(x)
#             a raison d une ligne par indice
#----------------------------------------------------------------------------
# Paramètres : ABRFIC = Abreviation de la table dont depend le clob
#----------------------------------------------------------------------------
# CLECLOB contient la clé de stockage a mettre dans la table
#############################################################################
Funprog SI_CLOB(ABRFIC)
Value Char ABRFIC ()             : # Abreviation table X3 (ex: "ITM")

Local Char CLECLOB (GLONTXC)

Local Integer IJ0
Local Integer J_CAR    : # indicateur fichier vide (0=vide)
Local Integer J_END    : # no derniere ligne a ecrire

#     variables pour recherche du numéro de texte
Local Integer WTEXSEQ
Local Integer WRETOUR
Local Char    WNUMTEX

If !clalev([F:TCC]) : Local File =SI_DOSSIER+".TEXCPT"     [TCC] : Endif
If !clalev([F:TXC]) : Local File =SI_DOSSIER+".TEXCLOB"    [TXC] : Endif

#   suppression des blancs en fin de ligne + recherche derniere ligne
#   (recherche de la derniere ligne en partant de la fin)
Raz J_CAR
J_END = dim(SI_CLOB)-1
For IJ0=dim(SI_CLOB)-1 To 0 Step -1
    SI_CLOB(IJ0)=vireblc(SI_CLOB(IJ0),1)
    If SI_CLOB(IJ0)<>"" : J_CAR=1 : Endif
    If !J_CAR : J_END=IJ0 : Endif
Next IJ0

If !J_CAR : Goto FIN_CLOB : Endif       : # pas de texte

#--- Ajout du crlf (0D0A) à chaque ligne sauf la derniere
For IJ0=0 To J_END-1
    If len(SI_CLOB(IJ0))<>99     : # Textes découpés pour des raisons techniques
       SI_CLOB(IJ0) += chr$(13)
       SI_CLOB(IJ0) += chr$(10)
    Endif
Next IJ0

#--- Ecrire le texte dans TEXCLOB
Call NUM_TXC(ABRFIC,WTEXSEQ,WRETOUR) From TRTX3TEX
CLECLOB=ABRFIC+"~"+format$("N0:8#",num$(WTEXSEQ))

WADXLOG=adxlog

If !WADXLOG : Trbegin [TXC] : Endif

Raz [F:TXC]
[F:TXC]CODE  =CLECLOB
[F:TXC]IDENT3=CLECLOB                   : # pour eviter trop de duplicate
Setlob [F:TXC]TEXTE With SI_CLOB
[F:TXC]CREUSR=GUSER
[F:TXC]CREDAT=date$
[F:TXC]CRETIM=time
Write [TXC]

If !WADXLOG : Commit        : Endif

# ----------
$FIN_CLOB
Raz SI_CLOB

End CLECLOB

#############################################################################
# SI_CTL :  Vérifie que la valeur est correcte pour le champ indiqué
#############################################################################
# Paramètres E: PFLD = Nom du champ X3 ou n° table diverse
#               PVAL = Valeur à mettre dans le champ X3
#            S: Renvoie 0 si incorrect
#                       1 si correct
#############################################################################
Funprog SI_CTL(PFLD,PVAL,PMES)
Value Char PFLD
Value Char PVAL
Value Char PMES

Local Integer LLNG, LADI

Case PFLD
    When "20", "21", "30", "31", "40", "41":    # Tables diverses
        If !clalev([F:ADV]) : Local File =SI_DOSSIER+".ATABTAB" [ADV] : Endif
        Read [ADV]CODE=val(PFLD)
        LLNG = [F:ADV]LNG
    When "ITMREF" : LLNG = GLONITM
    When "WST"    : LLNG = GLONWST
    When "BPCNUM" : LLNG = GLONBPC
    When "BPSNUM" : LLNG = GLONBPS
    When "REPNUM" : LLNG = GLONREP
    When "FCTCOD" : LLNG = GLONFCT
    When "CPY"    : LLNG = GLONCPY
    When "FCY"    : LLNG = GLONFCY
    When "ACC"    : LLNG = GLONGAC
    When "BPRACC" : LLNG = GLONBPR
    When "CNA"    : LLNG = GLONCNA
    When "JOU"    : LLNG = GLONJOU
    When "CCE"    : LLNG = GLONCCE
    When "BAN"    : LLNG = GLONBAN
    When "CUR"    : LLNG = GLONCUR
    When "CRY"    : LLNG = GLONCRY
    When "LAN"    : LLNG = GLONLAN
    When "AUS"    : LLNG = GLONAUS
    When "PTE"    : LLNG = 15
    When "UOM"    : LLNG = GLONUOM
    When "TAM"    : LLNG = GLONTAM
    When Default : Call ECR_TRACE("CAS NON TRAITE: SI_CTL, PFLD="+PFLD-"adxpno(1)="+adxpno(1),1) From GESECRAN
                   End
Endcase

# Format clé: majuscules + chiffres et sans espace
If PVAL<>format$("KV4:"+num$(min(len(PVAL),LLNG))+"c",ctrans(PVAL)) | PVAL =  ""
    # Transcodage incorrect
    Call ECR_TRACE(PMES-SI_MES(3)-":"-PVAL,1) From GESECRAN
    End 0
Endif

End 1


#############################################################################
# SI_INICCE : Alimentation des sections analytiques lignes documents X3
# ---------------------------------------------------------------------------
# Paramètres E: WNOMFIC = Table integrale sous la forme XIxxxx
#               WNUMORD = Numéro d'ordre du document intégrale
#               WLETRLQ = Lettre reliquat du document intégrale
#               WNUMLIG = Numéro de ligne du document intégrale
#               WNOMCCE = Préfixe du nom des sections analytiques (ex "[M:POH2]CCE")
#               WNOL    = Indice de la ligne (nolign-1)
# ---------------------------------------------------------------------------
# Principe de fonctionnement :
#   Prendre le code analytique intégrale qui a le poids le plus fort
#   sachant qu'il n'y a pas de gestion de répartition dans les documents X3
#   d'achat et de vente.
#############################################################################
Subprog SI_INICCE(WNOMFIC,WNUMORD,WLETRLQ,WNUMLIG,WNOMCCE,WNOL)
Value Char    WNOMFIC
Value Integer WNUMORD
Value Char    WLETRLQ
Value Integer WNUMLIG
Value Char    WNOMCCE
Value Integer WNOL
#-----
Local Char    WCODANA(13)
Local Decimal WTAUVTLANA
#----- Par sécurité pour éviter un plantage sur GNBAXE variable non déclarée -----#
If dim(GNBAXE)<1  Call VARGLOBANA(GBIDC3,GBIDI3) From SIXGAS : Endif
#-----
Raz WCODANA, WTAUVTLANA
Case WNOMFIC
  When "XILPAANA"
    #----- Sections analytiques lignes pièce achats -----#
    If !clalev([F:XLAN])  Local File =SI_DOSSIER+".XILPAANA"   [XLAN] : Endif
    For [XLAN] IND0 Where NUMORD=WNUMORD
&                       & LETRLQ=WLETRLQ
&                       & NUMLIG=WNUMLIG
&                       & TYPLIG="L"
      If WTAUVTLANA<[F:XLAN]TAUVTLANA
        WCODANA   =[F:XLAN]CODANA
        WTAUVTLANA=[F:XLAN]TAUVTLANA
      Endif
    Next
    #-----
  When "XILPAEMB"
    WCODANA=[F:XLEM]SECANAFRSEMB : # Emballage
  When "XILPAPOR"
    WCODANA=[F:XLPO]SECANAFRSPOR : # Port
  When "XILPAFADIV"
    WCODANA=[F:XLFD]SECANAFRSDIV : # Frais divers
  When "XILPAFAFIX"
    WCODANA=[F:XLFF]SECANAFRSFIX : # Frais fixe
  When "XILPAREM"
    WCODANA=[F:XLRE]SECANAFRSREM : # Remise
  When "XILPAFSPF1"
    WCODANA=[F:XLF1]SECANAFRS1   : # Frais spécifique 1
  When "XILPAFSPF2"
    WCODANA=[F:XLF2]SECANAFRS2   : # Frais spécifique 2
  When "XILPVANA"
    #----- Sections analytiques lignes pièces ventes -----#
    If !clalev([F:XVAN])  Local File =SI_DOSSIER+".XILPVANA"   [XVAN] : Endif
    For [XVAN] IND0 Where NUMORD=WNUMORD
&                       & LETRLQ=WLETRLQ
&                       & NUMLIG=WNUMLIG
&                       & TYPLIG="L"
      If WTAUVTLANA<[F:XVAN]TAUVTL
        WCODANA   =[F:XVAN]ANA
        WTAUVTLANA=[F:XVAN]TAUVTL
      Endif
    Next
    #-----
  When "XILPVPOR"
    WCODANA=[F:XVPO]SECANAFRAPOR : # Port
  When "XILPVFADIV"
    WCODANA=[F:XVFD]SECANAFRADIV : # Frais divers
  When "XILPVFAFIX"
    WCODANA=[F:XVFF]SECANAFRAFIX : # Frais fixe
Endcase
#-----
If WCODANA<>""
  Call INICCE(WCODANA,WNOMCCE,WNOL) From SIXGAS
Endif
#-----
End


#############################################################################
# Point d'entrée commun à appeler avant chaque création d'un enregistrement
# Renseigner la variable globale SI_TABLE avec le nom de la table qui va être écrite
#############################################################################
$SI_BEFWRI

    GPOINT = "SI_BEFWRI"
    Gosub ENTREE From EXEFNC

Return

#############################################################################
# Point d'entrée commun à appeler avant chaque boucle sur la table Intégrale
# Renseigner la variable globale SI_TABLE avec le nom de la table qui va être lue (XI...)
# Le PE peut alors renseigner SI_CRITERE pour positionner un filtre supplémentaire
#############################################################################
$SI_CRITSUP
    SI_CRITERE  = "1=1"
    GPOINT = "SI_CRITSUP"
    Gosub ENTREE From EXEFNC
    If SI_CRITERE  = ""
       SI_CRITERE  = "1=1"
    Endif
Return

#############################################################################
# Point d'entrée commun à appeler avant traitement d un fichier
# Permet d initialiser des rubriques communes à tous les enregistrements
# Renseigner la variable globale SI_TABLE avec le nom de la table qui va être écrite
#############################################################################
$SI_INIVALEUR
Case SI_TABLE

  When "BPCUSTOMER"
        # GPE = 0  ==> à la sortie du PE, transclasse [F:BPC] = [F:BCG]
        # GPE = 1  ==> à la sortie du PE, pas de transclasse

  When "BPSUPPLIER"
        # GPE = 0  ==> à la sortie du PE, transclasse [F:BPS] = [F:BSG]
        # GPE = 1  ==> à la sortie du PE, pas de transclasse

  When "ITMMASTER"
        # GPE = 0  ==> à la sortie du PE, transclasse [F:ITM] = [F:ITG]
        # GPE = 1  ==> à la sortie du PE, pas de transclasse
Endcase

GPOINT = "SI_VALEUR"
Gosub ENTREE From EXEFNC
Return

#############################################################################
# Renvoie le message associé à la valeur de fstat
#############################################################################
Funprog FSTATMSG(PFSTAT)
Value Integer PFSTAT   # FGR 01/02/2010 : X3SUIVI60986

Local Char LMES(250)
Raz LMES
Case PFSTAT
 When 0 : # Rien
 When 1 : LMES=mess(10,100,1) : # Modification en cours sur un autre poste
 When 3 : LMES=mess(22,100,1) : # Fiche déjà existante
 When 4 : LMES=mess(11,100,1) : # Début/Fin de fichier
 When 5 : LMES=mess(23,100,1) : # Fiche inexistante
 When Default
  LMES=mess(12,100,1)+"\(fstat="+num$(fstat)+")" : # Erreur d'accés sur le fichier
Endcase
End LMES

