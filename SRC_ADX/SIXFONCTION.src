#############################################################################
# Suppression des caracteres autres que numérique (0....9)
#             E :  LBEFORE rubrique à analyser
#             S :  LAFTER  rubrique apres analyse
#  ex :  LBEFORE = "04/50.10é88)19"  ===> LAFTER = "0450108819"
#############################################################################
Subprog NUMONLY (LBEFORE, LAFTER)
Value    Char    LBEFORE
Variable Char    LAFTER

Local Char LTRANS(250)

# suppression des accents  et mise en majuscule
LBEFORE = toupper(ctrans(LBEFORE))
# définition des caracteres à transformer
LTRANS = sigma(I=32,47,chr$(I))+sigma(I=58,127,chr$(I))
# transformation des caracteres par "nul"
LAFTER = ctrans(LBEFORE,LTRANS,"")

End

#dem 47375 deb
########################################################################
# Fait +1 sur numéro adresse
########################################################################
# Paramètres E : LDEB = Numéro à incrementer
#            S : LFIN = Numéro incrementé
#              : LRET = Code retour    :(0=OK / 1=Erreur)
########################################################################
Subprog PLUS_UN(LDEB,LFIN,LRET)
Value    Char     LDEB
Variable Char     LFIN
Variable Integer  LRET

Local    Char    WCHI(11) : WCHI = "01234567890"
Local    Integer I, J

LFIN = vireblc(LDEB,4)
LRET = 1
I    = len(LFIN)

For I = len(LFIN) To 1 Step -1
  J = instr(1,WCHI,mid$(LFIN,I,1))
  If J <> 0
    LFIN = left$(LFIN,I-1)+mid$(WCHI,J+1,1)+right$(LFIN,I+1)
    If mid$(WCHI,J,1) <> "9"
      LRET = 0
      Break
    Endif
  Endif
Next I

End
#dem 47375 fin
