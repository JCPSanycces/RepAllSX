#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# UTIGPA33  Module GPAO     Table WIPCOST,  Détail coûts des sous-produits        #
###################################################################################
Local Char DOSSIER(30)

DOSSIER = nomap
If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=[L]DOSSIER
If fstat Then
  Raz [F:ADS]
Endif
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIGPA33: Update xxxCST of WIPCOST table for sub-products") From LECFIC
Call MAJ_UTIGPA33(DOSSIER)
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##########################################################################
# Initialisation du champ [F:WGG]ENGCOD
##########################################################################
Subprog MAJ_UTIGPA33(DOSSIER)
Value Char DOSSIER

Local Integer LSJVFLG, LCALFLG, I, STOP, LSIMU
Local Char    LVCRNUM(GLONVCR)
Local Char    CRITSUP(250)

Raz LVCRNUM, LSIMU

Call ECR_TRACE("UTIGPA33: Process Start on : "+DOSSIER, 0) From GESECRAN

If filinfo(filpath("FIL","WIPCOST","fde",DOSSIER),0) <= 0     End Endif
If filinfo(filpath("FIL","MFGHEAD","fde",DOSSIER),0) <= 0     End Endif
#----- Ouverture des fichiers -----#
If clalev([F:MWIX])  =0  Local File =DOSSIER+".WIPCOST"      [MWIX] : Endif
If clalev([F:MFG])  =0  Local File =DOSSIER+".MFGHEAD"       [MFG] : Endif
If clalev([F:ITM])  =0  Local File =DOSSIER+".ITMMASTER"     [ITM] : Endif

If GACTDECCST & filinfo(filpath("FIL","STOJOUVAL","fde",DOSSIER),0) > 0
    LSJVFLG=1
    If clalev([F:SJV])  =0  Local File =DOSSIER+".STOJOUVAL"       [SJV] : Endif
    If clalev([F:STJ])  =0  Local File =DOSSIER+".STOJOU"          [STJ] : Endif
Else
    LSJVFLG=0
Endif

#CHECK IGNORE_BEGIN
CRITSUP="1=1"
GPOINT="UTIGPA33"
Gosub ENTREE From EXEFNC
#CHECK IGNORE_END

$LOOP_MWIX

Call DEBTRANS From GLOCK

Raz STOP

For [MWIX]MWI0(2) Where VCRTYP=10 & TXNTYP=14 & ITMTYP=2 & PRINAT=8
&             & VCRNUM>LVCRNUM
&             & evalue(CRITSUP)

  Raz LCALFLG
  Trbegin [MWIX]

  For [MWIX]MWI0
    If [F:MWIX]AMOUNT<>(sum([F:MWIX]MATCST)+sum([F:MWIX]MATCST)+sum([F:MWIX]MACCST)+sum([F:MWIX]LABCST)+[F:MWIX]SCOCST+[F:MWIX]INVDTACST
&                     +[F:MWIX]OVEMATCST+[F:MWIX]OVEMACCST+[F:MWIX]OVELABCST+[F:MWIX]OVESCOCST)
        LCALFLG=1
        If GSTOTRACE=4
            Call ECR_TRACE("Before *****************************************************",0) From GESECRAN
            Call ECRTRACE_MWI
        Endif

        If [F:ITM]ITMREF<>[F:MWIX]ITMREF
            Read [ITM]ITM0=[F:MWIX]ITMREF
        Endif
        Raz [F:MWIX]MATCST, [F:MWIX]MACCST, [F:MWIX]LABCST, [F:MWIX]SCOCST, [F:MWIX]INVDTACST
        Raz [F:MWIX]OVEMATCST, [F:MWIX]OVEMACCST, [F:MWIX]OVELABCST, [F:MWIX]OVESCOCST
        If !LSJVFLG
            [F:MWIX]MATCST(max(0,[F:ITM]BRDCOD-1)) = [F:MWIX]AMOUNT
        Else
            Link [SJV] With [STJ]STJ0~=[F:SJV]STOFCY;[F:SJV]UPDCOD;[F:SJV]ITMREF;[F:SJV]IPTDAT;[F:SJV]MVTSEQ;[F:SJV]MVTIND
&                      As [LNK]
&                      Where [F:STJ]STOFCY=[F:MWIX]MFGFCY
&                          & [F:STJ]UPDCOD=2
&                          & [F:STJ]ITMREF=[F:MWIX]ITMREF
&                          & [F:STJ]VCRTYP=15
&                          & [F:STJ]VCRNUM=[F:MWIX]MFGTRKNUM
&                          & [F:STJ]VCRLIN=[F:MWIX]MFGTRKLIN
&                      Order By IPTDAT Desc;MVTSEQ Asc
            Read [LNK] First
            If fstat
                [F:MWIX]MATCST(max(0,[F:ITM]BRDCOD-1)) = [F:MWIX]AMOUNT
            Else
                Local Decimal LTOT, LMAX, LTMP, LCOE
                Local Char LZON(100)
                LTOT = sum([F:SJV]VMATCST)+sum([F:SJV]VMACCST)+sum([F:SJV]VLABCST)+[F:SJV]VSCOTOT+[F:SJV]VINVDTATOT
&                    + [F:SJV]VOVEMATTOT+[F:SJV]VOVEMACTOT+[F:SJV]VOVELABTOT+[F:SJV]VOVESCOTOT
                If LTOT=0
                    [F:MWIX]MATCST(max(0,[F:ITM]BRDCOD-1)) = [F:MWIX]AMOUNT
                Else
                    LCOE = [F:MWIX]AMOUNT / LTOT
                    If GSTOTRACE=4
                        Call ECR_TRACE("STOJOUVAL **************",0) From GESECRAN
                        Call ECRTRACE_SJV
                        Call ECR_TRACE("coef = "+num$(LCOE),0) From GESECRAN
                    Endif
                    LTOT = 0
                    LMAX = 0
                    LZON = "[F:MWIX]MATCST(max(1,[F:ITM]BRDCOD)-1)"
                    For I=0 To GACTMAT-1
                        LTMP = arr([F:SJV]VMATCST(I)*LCOE,10^-GDECPRI)
                        [F:MWIX]MATCST(I) = LTMP
                        LTOT += LTMP
                        If abs(LTMP)>LMAX
                              LZON = "[F:MWIX]MATCST("+num$(I)+")"
                              LMAX = abs(LTMP)
                        Endif
                    Next

                    For I=0 To GACTMAC-1
                        LTMP = arr([F:SJV]VMACCST(I)*LCOE,10^-GDECPRI)
                        [F:MWIX]MACCST(I) = LTMP
                        LTOT += LTMP
                        If abs(LTMP)>LMAX
                              LZON = "[F:MWIX]MACCST("+num$(I)+")"
                              LMAX = abs(LTMP)
                        Endif
                    Next

                    For I=0 To GACTLAB-1
                        LTMP = arr([F:SJV]VLABCST(I)*LCOE,10^-GDECPRI)
                        [F:MWIX]LABCST(I) = LTMP
                        LTOT += LTMP
                        If abs(LTMP)>LMAX
                              LZON = "[F:MWIX]LABCST("+num$(I)+")"
                              LMAX = abs(LTMP)
                        Endif
                    Next

                    LTMP = arr([F:SJV]VSCOTOT*LCOE,10^-GDECPRI)
                    [F:MWIX]SCOCST    = LTMP
                    LTOT += LTMP
                    If abs(LTMP)>LMAX
                          LZON = "[F:MWIX]SCOCST"
                          LMAX = abs(LTMP)
                    Endif

                    LTMP = arr([F:SJV]VINVDTATOT*LCOE,10^-GDECPRI)
                    [F:MWIX]INVDTACST = LTMP
                    LTOT += LTMP
                    If abs(LTMP)>LMAX
                          LZON = "[F:MWIX]INVDTACST"
                          LMAX = abs(LTMP)
                    Endif

                    LTMP = arr([F:SJV]VOVEMATTOT*LCOE,10^-GDECPRI)
                    [F:MWIX]OVEMATCST = LTMP
                    LTOT += LTMP
                    If abs(LTMP)>LMAX
                          LZON = "[F:MWIX]OVEMATCST"
                          LMAX = abs(LTMP)
                    Endif

                    LTMP = arr([F:SJV]VOVEMACTOT*LCOE,10^-GDECPRI)
                    [F:MWIX]OVEMACCST = LTMP
                    LTOT += LTMP
                    If abs(LTMP)>LMAX
                          LZON = "[F:MWIX]OVEMACCST"
                          LMAX = abs(LTMP)
                    Endif

                    LTMP = arr([F:SJV]VOVELABTOT*LCOE,10^-GDECPRI)
                    [F:MWIX]OVELABCST = LTMP
                    LTOT += LTMP
                    If abs(LTMP)>LMAX
                          LZON = "[F:MWIX]OVELABCST"
                          LMAX = abs(LTMP)
                    Endif

                    LTMP = arr([F:SJV]VOVESCOTOT*LCOE,10^-GDECPRI)
                    [F:MWIX]OVESCOCST = LTMP
                    LTOT += LTMP
                    If abs(LTMP)>LMAX
                          LZON = "[F:MWIX]OVESCOCST"
                          LMAX = abs(LTMP)
                    Endif

                    Assign LZON With evalue(LZON) + [F:MWIX]AMOUNT-LTOT
                Endif
            Endif
        Endif

        Rewrite [MWIX]
        If fstat
            Call ECR_TRACE("File WIPCOST (MFGNUM, WIPSEQ)"-[F:MWIX]VCRNUM+","+num$([F:MWIX]WIPSEQ)+", ERROR ="-num$(fstat),1) From GESECRAN
        Elsif GSTOTRACE=4
            Call ECR_TRACE("After -------------",0) From GESECRAN
            Call ECRTRACE_MWI
        Endif
    Endif
  Next

  If LSIMU=1
      Rollback
  Else
      Commit
  Endif

  If LCALFLG
      Raz [MFG]
      Read [MFG]MFG0=[F:MWIX]VCRNUM
      If [F:MFG]MFGTRKFLG=6
          If GSTOTRACE=4 & LSIMU=1
              Call ECR_TRACE("CALMFC : "+[F:MWIX]VCRNUM,0) From GESECRAN
          Endif
          If LSIMU<>1
              Call CALMFC([F:MWIX]MFGFCY,[F:MWIX]VCRTYP,[F:MWIX]VCRNUM) From FUNWIPMFC
          Endif
      Endif
  Endif
  LVCRNUM=[F:MWIX]VCRNUM
  STOP=1
  Break
Next

If STOP
    Goto LOOP_MWIX
Endif

Close Local File [MWIX], [ITM]
If LSJVFLG
    Close Local File [STJ], [SJV]
Endif

Call ECR_TRACE("UTIGPA33 : End Process",0) From GESECRAN
End


Subprog ECRTRACE_MWI
Local Char LSTR(250)
Local Integer I
For I=0 To GACTMAT-1
    LSTR+=num$([F:MWIX]MATCST(I))+";"
Next
Call ECR_TRACE("[F:MWIX]MATCST="+LSTR,0) From GESECRAN
Raz LSTR
For I=0 To GACTMAC-1
    LSTR+=num$([F:MWIX]MACCST(I))+";"
Next
Call ECR_TRACE("[F:MWIX]MACCST="+LSTR,0) From GESECRAN
Raz LSTR
For I=0 To GACTLAB-1
    LSTR+=num$([F:MWIX]LABCST(I))+";"
Next
Call ECR_TRACE("[F:MWIX]LABCST="+LSTR,0) From GESECRAN
Raz LSTR
Call ECR_TRACE("[F:MWIX]SCOCST="+num$([F:MWIX]SCOCST),0) From GESECRAN
Call ECR_TRACE("[F:MWIX]INVDTACST="+num$([F:MWIX]INVDTACST),0) From GESECRAN
Call ECR_TRACE("[F:MWIX]OVExxxCST (mat/mac/lab/sco)="+num$([F:MWIX]OVEMATCST)+";"+num$([F:MWIX]OVEMACCST)+";"+num$([F:MWIX]OVELABCST)+";"+num$([F:MWIX]OVESCOCST),0) From GESECRAN
Call ECR_TRACE("[F:MWIX]AMOUNT="+num$([F:MWIX]AMOUNT),0) From GESECRAN
End

Subprog ECRTRACE_SJV
Local Char LSTR(250)
Local Integer I
For I=0 To GACTMAT-1
    LSTR+=num$([F:SJV]VMATCST(I))+";"
Next
Call ECR_TRACE("[F:SJV]VMATCST="+LSTR,0) From GESECRAN
Raz LSTR
For I=0 To GACTMAC-1
    LSTR+=num$([F:SJV]VMACCST(I))+";"
Next
Call ECR_TRACE("[F:SJV]VMACCST="+LSTR,0) From GESECRAN
Raz LSTR
For I=0 To GACTLAB-1
    LSTR+=num$([F:SJV]VLABCST(I))+";"
Next
Call ECR_TRACE("[F:SJV]VLABCST="+LSTR,0) From GESECRAN
Raz LSTR
Call ECR_TRACE("[F:SJV]VSCOTOT="+num$([F:SJV]VSCOTOT),0) From GESECRAN
Call ECR_TRACE("[F:SJV]VINVDTATOT="+num$([F:SJV]VINVDTATOT),0) From GESECRAN
Call ECR_TRACE("[F:SJV]VOVExxxTOT (mat/mac/lab/sco)="+num$([F:SJV]VOVEMATTOT)+";"+num$([F:SJV]VOVEMACTOT)+";"+num$([F:SJV]VOVELABTOT)+";"+num$([F:SJV]VOVESCOTOT),0) From GESECRAN
Call ECR_TRACE("[F:STJ]AMTORD="+num$([F:STJ]AMTORD),0) From GESECRAN
End
