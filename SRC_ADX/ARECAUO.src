#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GTEST = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","ARECAUO","",2,"") From GTRAITE
GTEST = 0
End

#--------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
Endcase
Return

#--------------#
$INIT
TIT = mess(197,125,1) : # Mise à jour des utilisateurs nommés
Return

#--------------#
$EXEC
If GTEST
 Call OUVRE_TRACE(TIT) From LECFIC
 TRA = 1
Endif
Call RECAUO
If GTEST
 Call FERME_TRACE From LECFIC
Endif
Return

#-----------------------------------------------------------------#
# Nombre d'utilisateurs nommés
#-----------------------------------------------------------------#

Funprog NBR_UTINOM
Local Integer NBMAX , LICENCE
If adxtyp=25 : # Syracuse
 NBMAX = 0
Else
#87108
# Call NOMBRA(12,LICENCE) From GLOCK
# If mod(LICENCE,16)>=8
#  Call NOMBRA(4,LICENCE) From GLOCK : # Sessions primaires
#  NBMAX = LICENCE
#  Call NOMBRA(8,LICENCE) From GLOCK : # Sessions VT
#  NBMAX += LICENCE
# Else
#  NBMAX = 0
# Endif
Endif
End NBMAX

#-------------------------------------------------------------------#
# Récup des utilisateurs nommés
#-------------------------------------------------------------------#

Subprog RECAUO

Local Integer NB , NBMAX , ER
Local Char    SYMBOLE(50) , DOSX3(20)

SYMBOLE = "RECAUO"

NBMAX = func NBR_UTINOM
If NBMAX=0
 End
Endif

Local File ADOSSIER [ADS]
Local File AUSRSOL  [AUO]
Local File ADOVAL   [ADW]

Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif

If DOSX3="" or nomap=DOSX3
 Lock =SYMBOLE
Else
 Lock =SYMBOLE From =DOSX3
Endif
If fstat
 End
Endif

Call DEBTRANS From GLOCK
Gosub EFFACE
NB = 0

Local File AUTILIS [AUS]
Gosub TR2
Close Local File [AUS]

For [ADS]
 If [F:ADS]DOSSIER<>DOSX3
  If !func ARECAUO.APPDEM([F:ADS]DOSSIER) & !func ARECAUO.APPRAC([F:ADS]DOSSIER)
   ER = 0
   Onerrgo ERFIC
   If filinfo(filpath("FIL","AUTILIS","fde",[F:ADS]DOSSIER),0)<0
    ER = 1
   Else
    Local File =[F:ADS]DOSSIER+".AUTILIS" [AUS]
    Read [AUS] First
   Endif
   Onerrgo
   If !ER
    Gosub TR1
    Close Local File [AUS]
   Endif
  Endif
 Endif
Next ADS

If DOSX3="" or nomap=DOSX3
 Unlock =SYMBOLE
Else
 Unlock =SYMBOLE From =DOSX3
Endif
End

#--------------#
$ERFIC
ER = errn
Resume

#--------------#
$EFFACE
GOK = 1
Trbegin [AUO]
 Delete [AUO] Where 1=1
Commit
Return

#--------------#
$TR1
GOK = 1
Trbegin [AUO]
 For [AUS] Where ENAFLG=2 & USRCONNECT=2
  If !func ARECAUO.USRSAG([F:AUS]USR)
   Look [AUO]AUO0=[F:AUS]USR
   If fstat
    If NB<NBMAX
     If GTEST
      Call ECR_TRACE("new"-[F:AUS]USR-"in"-[F:ADS]DOSSIER,0) From GESECRAN
     Endif
     [F:AUO] = [F:AUS]
     Write [AUO]
     NB += 1
    Else
     Readlock [AUS] Curr
     If !fstat
      If GTEST
       Call ECR_TRACE("off"-[F:AUS]USR-"in"-[F:ADS]DOSSIER,0) From GESECRAN
      Endif
      [F:AUS]ENAFLG = 1
      Rewrite [AUS]
     Endif
    Endif
   Endif
  Endif
 Next
Commit
Return

#--------------#
$TR2
GOK = 1
Trbegin [AUO]
 Read [AUS]CODUSR = GSUPER
 Read [AUO]AUO0 = GSUPER
 If fstat
  If GTEST
   Call ECR_TRACE("new"-GSUPER,0) From GESECRAN
  Endif
  [F:AUO] = [F:AUS]
  Write [AUO]
 Endif
Commit
NB += 1
Return

#-----------------------------------#
Funprog APPRAC(APPLI)
Value Char APPLI
Local Integer RACINE
If APPLI=GDOSX3 & GDOSX3<>"SUPERV"
 RACINE = 1
Endif
End RACINE

#-----------------------------------#
Funprog APPDEM(APPLI)
Value Char APPLI
Local Integer DEMO , ER
Onerrgo ERFIC
Local File =APPLI+".ADOVAL" [A_X]
Look [A_X]ADW0="";"";"ADEMO"
If !fstat
 DEMO = 1
Endif
Close Local File [A_X]
Onerrgo
If ER
 DEMO = 0
Endif
End DEMO

#-----------------------------------#
Funprog USRSAG(UTIL)
Value Char UTIL
Local Integer SAGE
SAGE = (GUSRNOMME & pat(UTIL,"SAGE#"))
End SAGE

#-------------------------------------------#
Subprog IMPORT(DOSSIER,STAT)
Value Char DOSSIER
Variable Integer STAT

Local Integer NB , NBMAX , LICENCE , ER
Local Char    SYMBOLE(50)

STAT = 1

If DOSSIER=GDOSX3
 End
Endif

NBMAX = func NBR_UTINOM
If NBMAX=0
 End
Endif

If func ARECAUO.APPDEM(DOSSIER) or func ARECAUO.APPRAC(DOSSIER)
 End
Endif

SYMBOLE = "RECAUO"
If nomap=GDOSX3
 Lock =SYMBOLE
Else
 Lock =SYMBOLE From =GDOSX3
Endif
If fstat
 STAT = 2 : End
Endif

Local File AUSRSOL [AUO]
NB = nbrecord([F:AUO])

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>[L]DOSSIER : Read [ADS]DOSSIER=[L]DOSSIER : Endif

Call DEBTRANS From GLOCK

ER = 0
Onerrgo ERFIC
If filinfo(filpath("FIL","AUTILIS","fde",DOSSIER),0)<0
 ER = 1
Else
 Local File =DOSSIER+".AUTILIS" [AUS]
 Read [AUS] First
Endif
If ER
 STAT = 3
Else
 Gosub TR1
Endif

Close Local File

Onerrgo

If nomap=GDOSX3
 Unlock =SYMBOLE
Else
 Unlock =SYMBOLE From =GDOSX3
Endif
End

#-------------------------------------#
Subprog AV_BID1(VALEUR)
Variable Char     VALEUR
VALEUR = mess(197,125,1) : # Mise à jour des utilisateurs nommés
End
