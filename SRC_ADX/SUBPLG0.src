#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque PLG0
##########################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

  [M:PLG0]CUR = VALEUR
  Raz [M:PLG0]TOTBUDEXT
  Raz [M:PLG0]TOTBUDCMM
  Call RAZ_PLG From TRTPLGB
  Gosub FLOADCMG From TRTPLG
End

##########################################################################
Subprog C_CUR(VALEUR)
Variable Char    VALEUR()

  #Une devise doit être indiquée
  If VALEUR = "" Then
    #Le planning marketing requiert la saisie d'une devise.
    GMESSAGE = mess(111,177,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  #La devise ne doit pas être interdite
  Read [TCU]TCU0=VALEUR
  If fstat Then
    GMESSAGE = mess(84,116,1) #Devise incorrecte.
    GERR = 1
    mkstat = 2
    End
  Else
    If [F:TCU]EURFLG = 2 Then
      If [F:TCU]CURENDDAT <> [00/00/00] Then
        If [F:TCU]CURENDDAT < date$ Then
          GMESSAGE = mess(84,116,1) #Devise incorrecte.
          GERR = 1
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif
End

