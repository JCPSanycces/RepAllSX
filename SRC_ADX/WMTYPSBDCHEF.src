#<AdxTL>@(#)0.0.0.0 $Revision$Class Subordinate
# Supervisor
## ATY-ATYPE ## SBDCHEF
# 2018-11-09 07:15:01 418

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,REFNUM,CTRNUM,CTRDAT,CHEF,NIVEAU,RANG,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char REFNUM
Value Char CTRNUM
Value Date CTRDAT
Value Char CHEF
Value Shortint NIVEAU
Value Shortint RANG
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EMPSBD [ESB]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EMPSBD" [ESB]
Endif

Default File [F:ESB]
Read [F:ESB]ESB0 = [L]REFNUM;[L]CTRNUM;[L]CTRDAT;[L]CHEF;[L]NIVEAU;[L]RANG
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]REFNUM)+"~"+num$([L]CTRNUM)+"~"+num$([L]CTRDAT)+"~"+num$([L]CHEF)+"~"+num$([L]NIVEAU)+"~"+num$([L]RANG)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]REFNUM)+"~"+num$([L]CTRNUM)+"~"+num$([L]CTRDAT)+"~"+num$([L]CHEF)+"~"+num$([L]NIVEAU)+"~"+num$([L]RANG)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


