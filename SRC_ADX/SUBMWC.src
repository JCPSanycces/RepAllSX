#<AdxTL>@(#)5.0.0.0 $Revision$
# Objet Section de valorisation
#################################################### 
$ACTION 
Case ACTION 
 When "LIENS"    :    Gosub LIENS 
 When "RAZCRE"   :    Gosub RAZCRE
 When "ANNULE"      : Gosub ANNULE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF 
 When Default 
Endcase 
Return 
#################################################### 
$LIENS 
#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#
If dim([M:MWC1]NBAXE)>0
    Call CHARG_DIE(16,"","MWC1","NBAXE") From TRTX3CPT
Endif

Return 
#################################################### 
$RAZCRE 
#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#
If dim([M:MWC1]NBAXE)>0
    Call INIT_DIE(16,"","MWC1","NBAXE") From TRTX3CPT
Endif

Affzo 20 
Return 
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="WORKCOST" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]SUPP(0)-[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]SUPP(0)-[L]CODE) From GLOCK : Return
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M]WCTDESAXX,"WORKCOST","WCTDESAXX",[M]VLTCCE,[M]VLTFCY) From ATEXTRA
Call MAJTEXTRA([M]WCTSHOAXX,"WORKCOST","WCTSHOAXX",[M]VLTCCE,[M]VLTFCY) From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]WCTDESAXX,"WORKCOST","WCTDESAXX",[M]VLTCCE,[M]VLTFCY) From ATEXTRA
Call MAJTEXTRA([M]WCTSHOAXX,"WORKCOST","WCTSHOAXX",[M]VLTCCE,[M]VLTFCY) From ATEXTRA

Return
######################################################################################
Subprog C_VLTFCY(VALEUR)
Variable Char    VALEUR()
   Local Integer     I 
   If dim([M]NBAXE) > 0
       For I=0 To [M]NBAXE-1 : # GH 02/06/2014 bug 96828 # For I=1 To [M]NBAXE
           Call SECTION([M]CCE(I),2,VALEUR,[0/0/0],[M]DIE(I)) From SUPCPT
           If mkstat : Break : Endif 
       Next 
    Endif
End
 
#################################################### 
Subprog AM_VLTFCY(VALEUR) 
Variable Char     VALEUR 
Local Integer     IND 
If VALEUR <> "" 
   IND=0 
   Call GETDEV(VALEUR) From DEVSUB 
   If [F:TCU]CUR <> "" & [F:TCU]CUR <> [M]XCUR 
      IND=1 
      [M]XCUR=[F:TCU]CUR 
      Affzo XCUR 
   Endif 
   If [M]STDSETCST <> 0 | [M]STDOPECST <> 0 | [M]CUTSETCST <> 0 | 
&     [M]CUTOPECST <> 0 | [M]BUDSETCST <> 0 | [M]BUDOPECST <> 0 
      If IND=1 : Call MESSAGE(mess(15,193,1)) From GESECRAN : Endif 
   Endif 
   IND=0 
Endif 
End 
 
########################################
Subprog C_OVECOD(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Call GETDEV([M]VLTFCY) From DEVSUB
  If [F:OVE]CUR <> "" & [F:OVE]CUR <> GLOCALDEV
     GMESSAGE = mess(69,193,1)
     mkstat = 2
  Endif
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 24/04/2003 11:15:40 (TB)
##########################################################################
Subprog AV_XCUR(VALEUR)
Variable Char    VALEUR()
VALEUR = GLOCALDEV
End

Subprog AV_CCEINT(VALEUR)
Variable Integer VALEUR
VALEUR = nolign
End


######################################################################################

