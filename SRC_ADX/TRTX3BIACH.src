End
###########################################################################################
# TRTX3BIACH  Fonctions pour la Business Intelligence    Module Achats                    #
# --------------------------------------------------------------------------------------- #
# GETLEG_PIVTYP  : Détermination de la législation retenue pour un type de facture achat  #
# --------------------------------------------------------------------------------------- #
###########################################################################################
#--------------------------------------------------------------------------------------------------
Funprog GETLEG_PIVTYP(PPIVTYP,PLEG)
Value Char PPIVTYP
Value Char PLEG

Local Char WLEG(GLONADI)
Raz WLEG

If PPIVTYP<>""

  If clalev([TPV])<=0 :#--CPO 92324 V7.1: BI modification for data by legislation
  	If GDOSSIER<>""
    	Local File =GDOSSIER+".TABPIVTYP" [TPV]
    Else
      Local File TABPIVTYP [TPV]
    Endif
  Endif

  #--Si dossier mono-lég, on retourne la
  #--CPO 92324 V7.1: BI modification for data by legislation
  #If func AFNC.ACTIV("LEG")=0
  If GLEGACT<>[V]CST_AYES
   WLEG = GDOSLEG
  Elsif PLEG<>""
   WLEG=PLEG
  Elsif WLEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
   WLEG = GCURLEG
  Endif

  fstat = 0 #--CPO 92324 V7.1: BI modification for data by legislation
  If WLEG<>""
   If [F:TPV]PIVTYP<>PPIVTYP and [F:TPV]LEG<>WLEG #--CPO 92324 V7.1: BI modification for data by legislation
     Read [TPV]TPV0=PPIVTYP;WLEG
     If fstat
      Read [TPV]TPV0=PPIVTYP;""
     Endif
   Endif
  Else
   If [F:TPV]PIVTYP<>PPIVTYP                      #--CPO 92324 V7.1: BI modification for data by legislation
     Read [TPV]TPV0(1)=PPIVTYP
   Endif
  Endif

  If !fstat
    WLEG = [F:TPV]LEG
  Else
    Raz WLEG
  Endif

Endif

$LEG_PIVTYP
End WLEG
