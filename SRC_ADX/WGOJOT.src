#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OJOT

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:20"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OJOT",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="JOT0;JOT1;JOT2;JOT3;JOT4;JOT5;JOT6;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "JOT"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "COD"
OBJLIS(1) = "JO0"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 2
DESLIS(1) = "UOMGRP+JOBGRP+COD"
If clalev([M:JOT0])=0 : Local Mask JOT0 [JOT0] : Endif
If clalev([M:JOT1])=0 : Local Mask JOT1 [JOT1] : Endif
If clalev([M:JOT2])=0 : Local Mask JOT2 [JOT2] : Endif
If clalev([M:JOT3])=0 : Local Mask JOT3 [JOT3] : Endif
If clalev([M:JOT4])=0 : Local Mask JOT4 [JOT4] : Endif
If clalev([M:JOT5])=0 : Local Mask JOT5 [JOT5] : Endif
If clalev([M:JOT6])=0 : Local Mask JOT6 [JOT6] : Endif
Gosub TIT
nolign = 1
If clalev([F:AXL])=0 : Local file ATEXTRA [AXL] : Endif
If clalev([F:AXK])=0 : Local file ATEXTRA [AXK] : Endif
If clalev([F:AXJ])=0 : Local file ATEXTRA [AXJ] : Endif
Link [JOT] With
& [AXL]AXX0="ATABDIV";"SHODES";GLANGUE;"10459";[F:JOT]UOMGRP,
& [AXK]AXX0="ATABDIV";"SHODES";GLANGUE;"10460";[F:JOT]JOBGRP,
& [AXJ]AXX0="JOBTYP";"DES";GLANGUE;[F:JOT]COD;""
& As [JOT_]
If clalev([F:JOT])=0 : Local file JOBTYP [JOT] : Endif
If clalev([F:AXQ])=0 : Local file ATEXTRA [AXQ] : Endif
Link [JOT] With
& [AXQ]AXX0="JOBTYP";"DES";GLANGUE;[F:JOT]COD;""
& As [JO0]
& Order By Key JOT1
Return

$DEF_BOITE
Gosub HORODAT From WGOJOT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OJOT" From GFONCTION At A_STAMP With A_WINDPREV Mask [JOT0]
&   Folder Mask [JOT1]
& , Folder Mask [JOT2]
& , Folder Mask [JOT3]
& , Folder Mask [JOT4]
& , Folder Mask [JOT5]
& , Folder Mask [JOT6]
&  Listbox [JOT_] GAU_CHE
&   [L]SAIRAP(1) = [F:JOT]COD Using "K:10c" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:AXJ]TEXTE Using "K:10X" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = [F:JOT]UOMGRP Using "K:20X" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = [F:AXL]TEXTE Using "K:10X" Titled TITSEL(4) ,
&   [L]SAIRAP(5) = [F:JOT]JOBGRP Using "K:20X" Titled TITSEL(5) ,
&   [L]SAIRAP(6) = [F:AXK]TEXTE Using "K:10X" Titled TITSEL(6) ,
&   [L]SAIRAP(7) = [F:JOT]DATSTRVLY Using "" Titled TITSEL(7) ,
&   [L]SAIRAP(8) = [F:JOT]DATENDVLY Using "" Titled TITSEL(8) ,
&   [L]SAIRAP(9) = string$([F:JOT]LEG<>'',[F:JOT]LEG)+string$([F:JOT]LEG='',mess(91,187,1)) Using "K:30X" Titled TITSEL(9)
&  Listbox [JOT9] GAU_CHE9
&   [L]SAIRAP(1) = [F:JOT9]A_TAB1 Using "K:10c" Titled TITSEL9(1)  ,
&   [L]SAIRAP(2) = [F:JOT9]A_TAB2 Using "K:10X" Titled TITSEL9(2) ,
&   [L]SAIRAP(3) = [F:JOT9]A_TAB3 Using "K:20X" Titled TITSEL9(3)  ,
&   [L]SAIRAP(4) = [F:JOT9]A_TAB4 Using "K:10X" Titled TITSEL9(4) ,
&   [L]SAIRAP(5) = [F:JOT9]A_TAB5 Using "K:20X" Titled TITSEL9(5)  ,
&   [L]SAIRAP(6) = [F:JOT9]A_TAB6 Using "K:10X" Titled TITSEL9(6) ,
&   [L]SAIRAP(7) = [F:JOT9]A_TAB7 Using "" Titled TITSEL9(7)  ,
&   [L]SAIRAP(8) = [F:JOT9]A_TAB8 Using "" Titled TITSEL9(8)  ,
&   [L]SAIRAP(9) = [F:JOT9]A_TAB9 Using "K:30X" Titled TITSEL9(9)
&  Treebox [JO0] GAU_CHE1
&   [F:JOT]UOMGRP Using "K:20X" Titled TITSEL1(1) ,
&   [F:JOT]JOBGRP Using "K:20X" Titled TITSEL1(2) ,
&   [F:JOT]COD
&   +" "+[F:AXQ]TEXTE
&   Titled ""
& As [JOT1]
Titled [JOT1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOJOT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OJOT" From GFONCTION At A_STAMP With A_WINDPREV Mask [JOT0]
&   Folder Mask [JOT1]
& , Folder Mask [JOT2]
& , Folder Mask [JOT3]
& , Folder Mask [JOT4]
& , Folder Mask [JOT5]
& , Folder Mask [JOT6]
& As [JOT1]
Titled [JOT1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [JOT1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [JOT1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [JOT1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(45765,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITLIS1(30)
Call TEXTE(48393,TITLIS1) From OBJDIV
Local Char TITSEL(30)(1..9)
Call TEXTE(45853,TITSEL(1)) From OBJDIV
Call TEXTE(8,TITSEL(2)) From OBJDIV
Call TEXTE(13912,TITSEL(3)) From OBJDIV
Call TEXTE(8,TITSEL(4)) From OBJDIV
Call TEXTE(46541,TITSEL(5)) From OBJDIV
Call TEXTE(8,TITSEL(6)) From OBJDIV
Call TEXTE(1805,TITSEL(7)) From OBJDIV
Call TEXTE(1806,TITSEL(8)) From OBJDIV
Call TEXTE(26213,TITSEL(9)) From OBJDIV
Local Char TITSEL9(30)(1..9)
Call TEXTE(45853,TITSEL9(1)) From OBJDIV
Call TEXTE(8,TITSEL9(2)) From OBJDIV
Call TEXTE(13912,TITSEL9(3)) From OBJDIV
Call TEXTE(8,TITSEL9(4)) From OBJDIV
Call TEXTE(46541,TITSEL9(5)) From OBJDIV
Call TEXTE(8,TITSEL9(6)) From OBJDIV
Call TEXTE(1805,TITSEL9(7)) From OBJDIV
Call TEXTE(1806,TITSEL9(8)) From OBJDIV
Call TEXTE(26213,TITSEL9(9)) From OBJDIV
Local Char TITSEL1(30)(1..4)
Call TEXTE(47565,TITSEL1(1)) From OBJDIV
Call TEXTE(46541,TITSEL1(2)) From OBJDIV
Call TEXTE(45853,TITSEL1(3)) From OBJDIV
Call TEXTE(8,TITSEL1(4)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(45765,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [JOT_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [JOT1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [JOT1] GAU_CHE
 Else
  Fillbox [JOT1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [JOT_]
Return

$REMPLIT_1
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [JO0] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order By Key JOT1
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(1)<>'' or NOHLIS(1)<>0
 Fillbox [JOT1] GAU_CHE1 Hint Key =HINTLIS(1)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [JOT1] GAU_CHE1
 Else
  Fillbox [JOT1] GAU_CHE1 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [JO0]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "COD"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_1
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 2
SNSLIS = 1
LENLIS = 3
GAUTRELIS = 2
CLELISTE = "UOMGRP;JOBGRP;COD"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [JOT_]
 When 1 : Default file [JO0]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [JOT_] Order With CLELISTE
  Setlbox [JOT1] GAU_CHE
  Filter [JOT_]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [JOT1] GAU_CHE9
 When "GAU_CHE1"
  Setlbox [JOT1] GAU_CHE1
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [JOT_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [JOT_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "JOT0"         : ABMSK(0)  = "JOT0"     : AMA(0) = 1
NOMMSK(1) = "JOT1"         : ABMSK(1)  = "JOT1"     : AMA(1) = 1
NOMMSK(2) = "JOT2"         : ABMSK(2)  = "JOT2"     : AMA(2) = 1
NOMMSK(3) = "JOT3"         : ABMSK(3)  = "JOT3"     : AMA(3) = 1
NOMMSK(4) = "JOT4"         : ABMSK(4)  = "JOT4"     : AMA(4) = 1
NOMMSK(5) = "JOT5"         : ABMSK(5)  = "JOT5"     : AMA(5) = 1
NOMMSK(6) = "JOT6"         : ABMSK(6)  = "JOT6"     : AMA(6) = 1
NBMASK = 6
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:JOT0])>0 : Default Mask [JOT0] : Endif
 When 1 : If clalev([M:JOT1])>0 : Default Mask [JOT1] : Endif
 When 2 : If clalev([M:JOT2])>0 : Default Mask [JOT2] : Endif
 When 3 : If clalev([M:JOT3])>0 : Default Mask [JOT3] : Endif
 When 4 : If clalev([M:JOT4])>0 : Default Mask [JOT4] : Endif
 When 5 : If clalev([M:JOT5])>0 : Default Mask [JOT5] : Endif
 When 6 : If clalev([M:JOT6])>0 : Default Mask [JOT6] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:JOT0])>0 : Gosub TITRES From W1JOT0 : Endif
 When 1 : If clalev([M:JOT1])>0 : Gosub TITRES From W1JOT1 : Endif
 When 2 : If clalev([M:JOT2])>0 : Gosub TITRES From W1JOT2 : Endif
 When 3 : If clalev([M:JOT3])>0 : Gosub TITRES From W1JOT3 : Endif
 When 4 : If clalev([M:JOT4])>0 : Gosub TITRES From W1JOT4 : Endif
 When 5 : If clalev([M:JOT5])>0 : Gosub TITRES From W1JOT5 : Endif
 When 6 : If clalev([M:JOT6])>0 : Gosub TITRES From W1JOT6 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:JOT0])>0 : Close Local Mask [JOT0] : Endif
If clalev([M:JOT1])>0 : Close Local Mask [JOT1] : Endif
If clalev([M:JOT2])>0 : Close Local Mask [JOT2] : Endif
If clalev([M:JOT3])>0 : Close Local Mask [JOT3] : Endif
If clalev([M:JOT4])>0 : Close Local Mask [JOT4] : Endif
If clalev([M:JOT5])>0 : Close Local Mask [JOT5] : Endif
If clalev([M:JOT6])>0 : Close Local Mask [JOT6] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:JOT0])>0 : Raz [M:JOT0] : Endif
 When 1 : If clalev([M:JOT1])>0 : Raz [M:JOT1] : Endif
 When 2 : If clalev([M:JOT2])>0 : Raz [M:JOT2] : Endif
 When 3 : If clalev([M:JOT3])>0 : Raz [M:JOT3] : Endif
 When 4 : If clalev([M:JOT4])>0 : Raz [M:JOT4] : Endif
 When 5 : If clalev([M:JOT5])>0 : Raz [M:JOT5] : Endif
 When 6 : If clalev([M:JOT6])>0 : Raz [M:JOT6] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:JOT0])>0 : Affzo [M:JOT0] : Endif
 When 1 : If clalev([M:JOT1])>0 : Affzo [M:JOT1] : Endif
 When 2 : If clalev([M:JOT2])>0 : Affzo [M:JOT2] : Endif
 When 3 : If clalev([M:JOT3])>0 : Affzo [M:JOT3] : Endif
 When 4 : If clalev([M:JOT4])>0 : Affzo [M:JOT4] : Endif
 When 5 : If clalev([M:JOT5])>0 : Affzo [M:JOT5] : Endif
 When 6 : If clalev([M:JOT6])>0 : Affzo [M:JOT6] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:JOT0])>0 : [F:JOT] = [M:JOT0] : Endif
 When 1 : If clalev([M:JOT1])>0 : [F:JOT] = [M:JOT1] : Endif
 When 2 : If clalev([M:JOT2])>0 : [F:JOT] = [M:JOT2] : Endif
 When 3 : If clalev([M:JOT3])>0 : [F:JOT] = [M:JOT3] : Endif
 When 4 : If clalev([M:JOT4])>0 : [F:JOT] = [M:JOT4] : Endif
 When 5 : If clalev([M:JOT5])>0 : [F:JOT] = [M:JOT5] : Endif
 When 6 : If clalev([M:JOT6])>0 : [F:JOT] = [M:JOT6] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:JOT0])>0 : [M:JOT0] = [F:JOT] : Endif
 When 1 : If clalev([M:JOT1])>0 : [M:JOT1] = [F:JOT] : Endif
 When 2 : If clalev([M:JOT2])>0 : [M:JOT2] = [F:JOT] : Endif
 When 3 : If clalev([M:JOT3])>0 : [M:JOT3] = [F:JOT] : Endif
 When 4 : If clalev([M:JOT4])>0 : [M:JOT4] = [F:JOT] : Endif
 When 5 : If clalev([M:JOT5])>0 : [M:JOT5] = [F:JOT] : Endif
 When 6 : If clalev([M:JOT6])>0 : [M:JOT6] = [F:JOT] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [JOT0]COD
Else
 Grizo [JOT1]COD
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [JOT0]COD
Else
 Actzo [JOT1]COD
Endif
Return

$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1801 : Call TEXTE(48384,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(1043,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "2" : LMEN(NBMEN) = 2001 : Call TEXTE(45545,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "3" : LMEN(NBMEN) = 2002 : Call TEXTE(51397,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "4" : LMEN(NBMEN) = 2003 : Call TEXTE(55071,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = GBIDC1
  PARBOUT(3) = GBIDC2
  PARBOUT(4) = [M:JOT0]COD
  PARBOUT(5) = num$(5)
  FLGEXE = 1
  GACTION = "CPCMAJ"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","CPCMAJ","",2,"XYCPCMAJ") From GTRAITE
 When "2"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:JOT0]COD
  PARBOUT(2) = num$(1)
  PARBOUT(3) = num$(2)
  FLGEXE = 1
  GACTION = "TRTSALMED"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTSALMED","TRTSALMED",4,"XYTRTSALMED") From GTRAITE
 When "3"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = ""
  PARBOUT(2) = ""
  PARBOUT(3) = [M:JOT0]COD
  PARBOUT(4) = [M:JOT0]LEG
  FLGEXE = 1
  GACTION = "CONSRJO"
  Call CONSULT_CHAR(VALBOUT,"RJO",PARBOUT) From GCONSULT
 When "4"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  FLGEXE = 1
  GACTION = "MAJMIS"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","SUBJOT","MAJMIS",3,"SPEJOT") From GTRAITE
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


