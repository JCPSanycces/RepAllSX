#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTIVERFCAL   Utilitaire de vérification des liens       MBT 26/04/2010 #
#              de la table CPTANALIN                                     #
# ---------------------------------------------------------------------- #
# - Phase 1 * Liens de CPTANALIN vers lignes de document                 #
# - Phase 2 * Liens des lignes de document vers le CPTANALIN             #
##########################################################################


Call MAJ_UTIVERFCAL
End


Subprog MAJ_UTIVERFCAL
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIVERFCAL - Vérification liens table CPTANALIN") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIVERFCAL : Vérification des liens de la table CPTANALIN") From LECFIC
  Call EXE_UTIVERFCAL(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIVERFCAL(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Integer WNBRCHK, WTOTCHK, WNBRERR, WTOTERR
Local Char    WMSG(100)
# Issue 108342 - 2015-11-06 by MAE : ABRFIC passage de 3 à 8
#Local Char    WABRFIC(4), WABRFIC2(4)
Local Char    WABRFIC(GLONABR), WABRFIC2(GLONABR)
Local Libelle WVCRTYP
Local Char    WVCRNUM(GLONVCR)
Local Integer WVCRLIN
Local Integer WVCRSEQ
Local Char    WCPLCLE(30)
Local Char    WNOMFICH(GLONATB)
Local Char    WFCY(GLONFCY)
Local Char    WCCEDEF(10)
Local Char    WCLE(50), WCLE2(70)
Local Integer I, J, K
Local Libelle WTRACE : WTRACE=1 : # 0=normale, 1=détaillée
Local Libelle WSIMUL : WSIMUL=1 : # 0=normale, 1=simulation (pas de màj)
#-----
Call ECR_TIME("UTIVERFCAL : Start folder's process"-DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If WSIMUL  WMSG="(** Simulation **)" : Endif
#-----
If filinfo(filpath("FIL","CPTANALIN","fde",DOSSIER),0)<0  Goto FIN_UTIVERFCAL : Endif
#-----
Local File =DOSSIER+".CPTANALIN"  [CAL]
#-----
Call ECR_TRACE("======= Phase 1 : Enregistrements CPTANALIN orphelins"-WMSG-"=======",0) From GESECRAN
Gosub PHASE_1
Call ECR_TRACE("======= Phase 2 : Enregistrements CPTANALIN manquants"-WMSG-"=======",0) From GESECRAN
Gosub PHASE_2
#----- Fin du traitement -----#
$FIN_UTIVERFCAL
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIVERFCAL : Process ended (Errors="+num$(WTOTERR)+"/"+num$(WTOTCHK)+")"
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [CAL]
End


#----------------------------------------------------------#
# Première phase : contrôle lien vers la ligne de document #
#----------------------------------------------------------#
$PHASE_1
WABRFIC2="???"
For [CAL] CAL0
  #----- Test rupture -----#
  If [F:CAL]ABRFIC<>WABRFIC
    Gosub TRT_RUPTURE
  Endif
  #-----
  Case [F:CAL]ABRFIC
    When "PQD"
      Look [PQD] PQD0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "PSD"
      Look [PSD] PSD0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "POP"
      Look [POP] POP0=[F:CAL]VCRNUM;[F:CAL]VCRLIN;[F:CAL]VCRSEQ
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "UOP"
      Look [UOP] POP0=[F:CAL]VCRNUM;val([F:CAL]CPLCLE);[F:CAL]VCRLIN;[F:CAL]VCRSEQ
      If fstat
        WCLE=[F:CAL]VCRNUM-[F:CAL]CPLCLE-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "PTD"
      Look [PTD] PTD0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "PND"
      Look [PND] PND0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "PID"
      Look [PID] PID0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "PVF"
      Look [PVF] PVF1=[F:CAL]VCRTYP;[F:CAL]VCRNUM;[F:CAL]VCRSEQ
      If fstat
        WCLE=num$([F:CAL]VCRTYP)-[F:CAL]VCRNUM-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "SQD"
      Look [SQD] SQD0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SOP"
      Look [SOP] SOP0=[F:CAL]VCRNUM;[F:CAL]VCRLIN;[F:CAL]VCRSEQ
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "VOP"
      Look [VOP] VOP0=[F:CAL]VCRNUM;val([F:CAL]CPLCLE);[F:CAL]VCRLIN;[F:CAL]VCRSEQ
      If fstat
        WCLE=[F:CAL]VCRNUM-[F:CAL]CPLCLE-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "SDD"
      Look [SDD] SDD0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SRD"
      Look [SRD] SRD0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SID" :
      Look [SID] SID0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SVF"
      Look [SVF] SVF1=[F:CAL]VCRTYP;[F:CAL]VCRNUM;[F:CAL]VCRSEQ
      If fstat
        WCLE=num$([F:CAL]VCRTYP)-[F:CAL]VCRNUM-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "MFI"
      Look [MFI] MFI0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "MFO"
      Look [MFO] MFO0=[F:CAL]VCRNUM;[F:CAL]VCRLIN;[F:CAL]VCRSEQ
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "MFM"
      Look [MFM] MFM0=[F:CAL]VCRNUM;[F:CAL]VCRLIN;[F:CAL]VCRSEQ;[F:CAL]CPLCLE
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ)-[F:CAL]CPLCLE : Gosub LIGNE_ABSENTE
      Endif
    When "MKI"
      Look [MKI] MKI0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "MKO"
      Look [MKO] MKO0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "MKM"
      Look [MKM] MKM0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SCI"
      Look [SCI] SCI0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SCM"
      Look [SCM] SCM0=[F:CAL]VCRNUM;[F:CAL]VCRLIN;[F:CAL]VCRSEQ
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "SCS"
      Look [SCS] SCS0=[F:CAL]VCRNUM;[F:CAL]VCRLIN;[F:CAL]VCRSEQ
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN)-num$([F:CAL]VCRSEQ) : Gosub LIGNE_ABSENTE
      Endif
    When "HDT"
      Look [HDT] HDT0=[F:CAL]VCRNUM
      If fstat
        WCLE=[F:CAL]VCRNUM : Gosub LIGNE_ABSENTE
      Endif
    When "HDI"
      Look [HDI] HDI0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SMD"
      Look [SMD] SMD0=[F:CAL]VCRTYP;[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=num$([F:CAL]VCRTYP)-[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When "SGD"
      Look [SGD] SGD0=[F:CAL]VCRNUM;[F:CAL]VCRLIN
      If fstat
        WCLE=[F:CAL]VCRNUM-num$([F:CAL]VCRLIN) : Gosub LIGNE_ABSENTE
      Endif
    When Default
      If [F:CAL]ABRFIC<>WABRFIC2
        Call ECR_TRACE ([F:CAL]ABRFIC-"Unknown abbreviation ? not processed !",1) From GESECRAN
        WABRFIC2=[F:CAL]ABRFIC
      Endif
  Endcase
  WNBRCHK+=1
Next
Raz [F:CAL] : Gosub TRT_RUPTURE
Return


#-------------------------------#
# Ligne du document non trouvée #
#-------------------------------#
$LIGNE_ABSENTE
WCLE2 =[F:CAL]ABRFIC-num$([F:CAL]VCRTYP)-[F:CAL]VCRNUM-num$([F:CAL]VCRLIN)
WCLE2-=num$([F:CAL]VCRSEQ)-[F:CAL]CPLCLE-num$([F:CAL]ANALIG)
Raz fstat
If WTRACE
  Call ECR_TRACE("File"-WNOMFICH+":"-WCLE-"Key not found !",1) From GESECRAN
Endif
If !WSIMUL
  Trbegin [CAL]
    Delete [CAL] Curr
    If fstat
      If WTRACE
        Call ECR_TRACE("File CPTANALIN.:"-WCLE2-"Delete Error="+num$(fstat),1) From GESECRAN
      Endif
    Else
      If WTRACE
        Call ECR_TRACE("File CPTANALIN.:"-WCLE2-"Record deleted",0) From GESECRAN
      Endif
    Endif
  Commit
Endif
WNBRERR+=1
Return


#--------------------------#
# Traitement de la rupture #
#--------------------------#
$TRT_RUPTURE
If WABRFIC<>"" & WNOMFICH<>""
  If WNBRERR<>0 & !WTRACE
    Call ECR_TRACE("File"-WNOMFICH-"Checked (Errors="+num$(WNBRERR)+"/"+num$(WNBRCHK)+")",1) From GESECRAN
  Else
    Call ECR_TRACE("File"-WNOMFICH-"Checked (Errors="+num$(WNBRERR)+"/"+num$(WNBRCHK)+")",0) From GESECRAN
  Endif
  WTOTCHK+=WNBRCHK
  WTOTERR+=WNBRERR
  Case WABRFIC
    When "PQD" : Close Local File [PQD]
    When "PSD" : Close Local File [PSD]
    When "POP" : Close Local File [POP]
    When "UOP" : Close Local File [UOP]
    When "PTD" : Close Local File [PTD]
    When "PND" : Close Local File [PND]
    When "PID" : Close Local File [PID]
    When "PVF" : Close Local File [PVF]
    When "SQD" : Close Local File [SQD]
    When "SOP" : Close Local File [SOP]
    When "VOP" : Close Local File [VOP]
    When "SDD" : Close Local File [SDD]
    When "SRD" : Close Local File [SRD]
    When "SID" : Close Local File [SID]
    When "SVF" : Close Local File [SVF]
    When "MFI" : Close Local File [MFI]
    When "MFO" : Close Local File [MFO]
    When "MFM" : Close Local File [MFM]
    When "MKI" : Close Local File [MKI]
    When "MKO" : Close Local File [MKO]
    When "MKM" : Close Local File [MKM]
    When "SCI" : Close Local File [SCI]
    When "SCM" : Close Local File [SCM]
    When "SCS" : Close Local File [SCS]
    When "HDT" : Close Local File [HDT]
    When "HDI" : Close Local File [HDI]
    When "SMD" : Close Local File [SMD]
    When "SGD" : Close Local File [SGD]
  Endcase
  Raz WABRFIC, WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE, WNOMFICH
Endif
If [F:CAL]ABRFIC<>""
  Raz WNOMFICH
  Case [F:CAL]ABRFIC
    When "PQD" : Local File =DOSSIER+".PQUOTATD"   [PQD] : WNOMFICH="PQUOTATD.."
    When "PSD" : Local File =DOSSIER+".PREQUISD"   [PSD] : WNOMFICH="PREQUISD.."
    When "POP" : Local File =DOSSIER+".PORDERP"    [POP] : WNOMFICH="PORDERP..."
    When "UOP" : Local File =DOSSIER+".UPORDERP"   [UOP] : WNOMFICH="UPORDERP.."
    When "PTD" : Local File =DOSSIER+".PRECEIPTD"  [PTD] : WNOMFICH="PRECEIPTD."
    When "PND" : Local File =DOSSIER+".PRETURND"   [PND] : WNOMFICH="PRETURND.."
    When "PID" : Local File =DOSSIER+".PINVOICED"  [PID] : WNOMFICH="PINVOICED."
    When "PVF" : Local File =DOSSIER+".PVCRFOOT"   [PVF] : WNOMFICH="PVCRFOOT.."
    When "SQD" : Local File =DOSSIER+".SQUOTED"    [SQD] : WNOMFICH="SQUOTED..."
    When "SOP" : Local File =DOSSIER+".SORDERP"    [SOP] : WNOMFICH="SORDERP..."
    When "VOP" : Local File =DOSSIER+".VSORDERP"   [VOP] : WNOMFICH="VSORDERP.."
    When "SDD" : Local File =DOSSIER+".SDELIVERYD" [SDD] : WNOMFICH="SDELIVERYD"
    When "SRD" : Local File =DOSSIER+".SRETURND"   [SRD] : WNOMFICH="SRETURND.."
    When "SID" : Local File =DOSSIER+".SINVOICED"  [SID] : WNOMFICH="SINVOICED."
    When "SVF" : Local File =DOSSIER+".SVCRFOOT"   [SVF] : WNOMFICH="SVCRFOOT.."
    When "MFI" : Local File =DOSSIER+".MFGITM"     [MFI] : WNOMFICH="MFGITM...."
    When "MFO" : Local File =DOSSIER+".MFGOPE"     [MFO] : WNOMFICH="MFGOPE...."
    When "MFM" : Local File =DOSSIER+".MFGMAT"     [MFM] : WNOMFICH="MFGMAT...."
    When "MKI" : Local File =DOSSIER+".MFGITMTRK"  [MKI] : WNOMFICH="MFGITMTRK."
    When "MKO" : Local File =DOSSIER+".MFGOPETRK"  [MKO] : WNOMFICH="MFGOPETRK."
    When "MKM" : Local File =DOSSIER+".MFGMATTRK"  [MKM] : WNOMFICH="MFGMATTRK."
    When "SCI" : Local File =DOSSIER+".SCOITM"     [SCI] : WNOMFICH="SCOITM...."
    When "SCM" : Local File =DOSSIER+".SCOMAT"     [SCM] : WNOMFICH="SCOMAT...."
    When "SCS" : Local File =DOSSIER+".SCOSRV"     [SCS] : WNOMFICH="SCOSRV...."
    When "HDT" : Local File =DOSSIER+".HDKTASK"    [HDT] : WNOMFICH="HDKTASK..."
    When "HDI" : Local File =DOSSIER+".HDKTASKINV" [HDI] : WNOMFICH="HDKTASLINV"
    When "SMD" : Local File =DOSSIER+".SMVTD"      [SMD] : WNOMFICH="SMVTD....."
    When "SGD" : Local File =DOSSIER+".SCHGD"      [SGD] : WNOMFICH="SCHGD....."
  Endcase
  WABRFIC=[F:CAL]ABRFIC
Endif
Raz WNBRCHK, WNBRERR
Return


#------------------------------------------------------------#
# Deuxième phase : contrôle lien depuis la ligne de document #
#------------------------------------------------------------#
$PHASE_2
#-----
WABRFIC="PQD"  : Gosub DEBUT_CPTANALIN
For [PQD] PQD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="PSD"  : Gosub DEBUT_CPTANALIN
For [PSD] PSD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="POP"  : Gosub DEBUT_CPTANALIN
For [POP] POP0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="UOP"  : Gosub DEBUT_CPTANALIN
For [UOP] POP0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="PTD"  : Gosub DEBUT_CPTANALIN
For [PTD] PTD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="PND"  : Gosub DEBUT_CPTANALIN
For [PND] PND0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="PID"  : Gosub DEBUT_CPTANALIN
For [PID] PID0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="PVF"  : Gosub DEBUT_CPTANALIN
For [PVF] PVF1 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SQD"  : Gosub DEBUT_CPTANALIN
For [SQD] SQD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SOP"  : Gosub DEBUT_CPTANALIN
For [SOP] SOP0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="VOP"  : Gosub DEBUT_CPTANALIN
For [VOP] VOP0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SDD"  : Gosub DEBUT_CPTANALIN
For [SDD] SDD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SRD"  : Gosub DEBUT_CPTANALIN
For [SRD] SRD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SID"  : Gosub DEBUT_CPTANALIN
For [SID] SID0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SVF"  : Gosub DEBUT_CPTANALIN
For [SVF] SVF1 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="MFI"  : Gosub DEBUT_CPTANALIN
For [MFI] MFI0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="MFO"  : Gosub DEBUT_CPTANALIN
For [MFO] MFO0 : Gosub VERIF_CPTANALIN : WABRFIC="MFO2" : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="MFM"  : Gosub DEBUT_CPTANALIN
For [MFM] MFM0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="MKI"  : Gosub DEBUT_CPTANALIN
For [MKI] MKI0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="MKO"  : Gosub DEBUT_CPTANALIN
For [MKO] MKO0 : Gosub VERIF_CPTANALIN : WABRFIC="MKO2" : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="MKM"  : Gosub DEBUT_CPTANALIN
For [MKM] MKM0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SCI"  : Gosub DEBUT_CPTANALIN
For [SCI] SCI0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SCM"  : Gosub DEBUT_CPTANALIN
For [SCM] SCM0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SCS"  : Gosub DEBUT_CPTANALIN
For [SCS] SCS0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="HDT"  : Gosub DEBUT_CPTANALIN
For [HDT] HDT0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="HDI"  : Gosub DEBUT_CPTANALIN
For [HDI] HDI0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SMD"  : Gosub DEBUT_CPTANALIN
For [SMD] SMD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
WABRFIC="SGD"  : Gosub DEBUT_CPTANALIN
For [SGD] SGD0 : Gosub VERIF_CPTANALIN : Next
Gosub FIN_CPTANALIN
#-----
Return


#---------------------------------------------------#
# Début de la vérification des lignes d'un document #
#---------------------------------------------------#
$DEBUT_CPTANALIN
Case WABRFIC
  When "PQD"
    Local File =DOSSIER+".PQUOTATD"   [PQD] : WNOMFICH="PQUOTATD.."
  When "PSD"
    Local File =DOSSIER+".PREQUISD"   [PSD] : WNOMFICH="PREQUISD.."
  When "POP"
    Local File =DOSSIER+".PORDERP"    [POP] : WNOMFICH="PORDERP..."
  When "UOP"
    Local File =DOSSIER+".UPORDERP"   [UOP] : WNOMFICH="UPORDERP.."
  When "PTD"
    Local File =DOSSIER+".PRECEIPTD"  [PTD] : WNOMFICH="PRECEIPTD."
  When "PND"
    Local File =DOSSIER+".PRETURND"   [PND] : WNOMFICH="PRETURND.."
  When "PID"
    Local File =DOSSIER+".PINVOICED"  [PID] : WNOMFICH="PINVOICED."
  When "PVF"
    Local File =DOSSIER+".PVCRFOOT"   [PVF] : WNOMFICH="PVCRFOOT.."
  When "SQD"
    Local File =DOSSIER+".SQUOTED"    [SQD] : WNOMFICH="SQUOTED..."
  When "SOP"
    Local File =DOSSIER+".SORDERP"    [SOP] : WNOMFICH="SORDERP..."
  When "VOP"
    Local File =DOSSIER+".VSORDERP"   [VOP] : WNOMFICH="VSORDERP.."
  When "SDD"
    Local File =DOSSIER+".SDELIVERYD" [SDD] : WNOMFICH="SDELIVERYD"
  When "SRD"
    Local File =DOSSIER+".SRETURND"   [SRD] : WNOMFICH="SRETURND.."
  When "SID"
    Local File =DOSSIER+".SINVOICED"  [SID] : WNOMFICH="SINVOICED."
  When "SVF"
    Local File =DOSSIER+".SVCRFOOT"   [SVF] : WNOMFICH="SVCRFOOT.."
  When "MFI"
    Local File =DOSSIER+".MFGITM"     [MFI] : WNOMFICH="MFGITM...."
  When "MFO"
    Local File =DOSSIER+".MFGOPE"     [MFO] : WNOMFICH="MFGOPE...."
  When "MFM"
    Local File =DOSSIER+".MFGMAT"     [MFM] : WNOMFICH="MFGMAT...."
  When "MKI"
    Local File =DOSSIER+".MFGITMTRK"  [MKI] : WNOMFICH="MFGITMTRK."
  When "MKO"
    Local File =DOSSIER+".MFGOPETRK"  [MKO] : WNOMFICH="MFGOPETRK."
  When "MKM"
    Local File =DOSSIER+".MFGMATTRK"  [MKM] : WNOMFICH="MFGMATTRK."
  When "SCI"
    Local File =DOSSIER+".SCOITM"     [SCI] : WNOMFICH="SCOITM...."
  When "SCM"
    Local File =DOSSIER+".SCOMAT"     [SCM] : WNOMFICH="SCOMAT...."
  When "SCS"
    Local File =DOSSIER+".SCOSRV"     [SCS] : WNOMFICH="SCOSRV...."
  When "HDT"
    Local File =DOSSIER+".HDKTASK"    [HDT] : WNOMFICH="HDKTASK..."
  When "HDI"
    Local File =DOSSIER+".HDKTASKINV" [HDI] : WNOMFICH="HDKTASLINV"
  When "SMD"
    Local File =DOSSIER+".ITMFACILIT" [ITF]
    Local File =DOSSIER+".SMVTH"      [SMH]
    Local File =DOSSIER+".SMVTD"      [SMD] : WNOMFICH="SMVTD....."
  When "SGD"
    Local File =DOSSIER+".SCHGH"      [SGH]
    Local File =DOSSIER+".SCHGD"      [SGD] : WNOMFICH="SCHGD....."
Endcase
Raz WNBRCHK, WNBRERR
Return


#-----------------------------------------------------------#
# Vérification existence d'un enregistrement dans CPTANALIN #
#-----------------------------------------------------------#
$VERIF_CPTANALIN
Raz WVCRTYP, WVCRNUM, WVCRLIN, WVCRSEQ, WCPLCLE, WFCY
Case WABRFIC
  When "PQD"
    WVCRNUM=[F:PQD]PQHNUM : WVCRLIN=[F:PQD]PQDLIN : WFCY=[F:PQD]PQHFCY
  When "PSD"
    WVCRNUM=[F:PSD]PSHNUM : WVCRLIN=[F:PSD]PSDLIN : WFCY=[F:PSD]PSHFCY
  When "POP"
    WVCRNUM=[F:POP]POHNUM : WVCRLIN=[F:POP]POPLIN : WVCRSEQ=[F:POP]POPSEQ : WFCY=[F:POP]PRHFCY
  When "UOP"
    WVCRNUM=[F:UOP]POHNUM : WVCRLIN=[F:UOP]POPLIN : WVCRSEQ=[F:UOP]POPSEQ : WCPLCLE=num$([F:UOP]LINREVNUM) : WFCY=[F:UOP]PRHFCY
  When "PTD"
    WVCRNUM=[F:PTD]PTHNUM : WVCRLIN=[F:PTD]PTDLIN : WFCY=[F:PTD]PRHFCY
  When "PND"
    WVCRNUM=[F:PND]PNHNUM : WVCRLIN=[F:PND]PNDLIN : WFCY=[F:PND]PNHFCY
  When "PID"
    WVCRNUM=[F:PID]NUM    : WVCRLIN=[F:PID]PIDLIN : WFCY=[F:PID]FCY
  When "PVF"
    WVCRTYP=[F:PVF]VCRTYP : WVCRNUM=[F:PVF]VCRNUM : WVCRSEQ=[F:PVF]IND
  When "SQD"
    WVCRNUM=[F:SQD]SQHNUM : WVCRLIN=[F:SQD]SQDLIN : WFCY=[F:SQD]SALFCY
  When "SOP"
    WVCRNUM=[F:SOP]SOHNUM : WVCRLIN=[F:SOP]SOPLIN : WVCRSEQ=[F:SOP]SOPSEQ : WFCY=[F:SOP]SALFCY
  When "VOP"
    WVCRNUM=[F:VOP]SOHNUM : WVCRLIN=[F:VOP]SOPLIN : WVCRSEQ=[F:VOP]SOPSEQ : WCPLCLE=num$([F:VOP]LINREVNUM) : WFCY=[F:VOP]SALFCY
  When "SDD"
    WVCRNUM=[F:SDD]SDHNUM : WVCRLIN=[F:SDD]SDDLIN : WFCY=[F:SDD]STOFCY
  When "SRD"
    WVCRNUM=[F:SRD]SRHNUM : WVCRLIN=[F:SRD]SRDLIN : WFCY=[F:SRD]STOFCY
  When "SID"
    WVCRNUM=[F:SID]NUM    : WVCRLIN=[F:SID]SIDLIN : WFCY=[F:SID]SALFCY
  When "SVF"
    WVCRTYP=[F:SVF]VCRTYP : WVCRNUM=[F:SVF]VCRNUM : WVCRSEQ=[F:SVF]DTA
  When "MFI"
    WVCRNUM=[F:MFI]MFGNUM : WVCRLIN=[F:MFI]MFGLIN : WFCY=[F:MFI]MFGFCY
  When "MFO"
    WVCRNUM=[F:MFO]MFGNUM : WVCRLIN=[F:MFO]OPENUM : WVCRSEQ=[F:MFO]OPESPLNUM  : WCPLCLE="EXTWST"  : WFCY=[F:MFO]MFGFCY
  When "MFO2"
    If [F:MFO]EXTLAB=""  Return : Endif
    WVCRNUM=[F:MFO]MFGNUM : WVCRLIN=[F:MFO]OPENUM : WVCRSEQ=[F:MFO]OPESPLNUM  : WCPLCLE="EXTLAB"  : WFCY=[F:MFO]MFGFCY
  When "MFM"
    If [F:MFM]ITMREF=""  Return : Endif
    WVCRNUM=[F:MFM]MFGNUM : WVCRLIN=[F:MFM]MFGLIN : WVCRSEQ=[F:MFM]BOMSEQ : WCPLCLE=[F:MFM]ITMREF : WFCY=[F:MFM]MFGFCY
  When "MKI"
    WVCRNUM=[F:MKI]MFGTRKNUM : WVCRLIN=[F:MKI]ITMTRKLIN : WFCY=[F:MKI]MFGFCY
  When "MKO"
    WVCRNUM=[F:MKO]MFGTRKNUM : WVCRLIN=[F:MKO]OPETRKLIN : WCPLCLE=[F:MKO]CPLWST : WFCY=[F:MKO]MFGFCY
  When "MKO2"
    If [F:MKO]CPLLAB=""  Return : Endif
    WVCRNUM=[F:MKO]MFGTRKNUM : WVCRLIN=[F:MKO]OPETRKLIN : WCPLCLE=[F:MKO]CPLLAB : WFCY=[F:MKO]MFGFCY
  When "MKM"
    WVCRNUM=[F:MKM]MFGTRKNUM : WVCRLIN=[F:MKM]MATTRKLIN : WFCY=[F:MKM]MFGFCY
  When "SCI"
    WVCRTYP=36 : WVCRNUM=[F:SCI]SCONUM : WVCRLIN=[F:SCI]SCILIN : WFCY=[F:SCI]PRHFCY
  When "SCM"
    If [F:SCM]ITMREF=""  Return : Endif
    WVCRTYP=36 : WVCRNUM=[F:SCM]SCONUM : WVCRLIN=[F:SCM]SCILIN : WVCRSEQ=[F:SCM]SCMLIN : WFCY=[F:SCM]MFGFCY
  When "SCS"
    WVCRTYP=36 : WVCRNUM=[F:SCS]SCONUM : WVCRLIN=[F:SCS]SCILIN : WVCRSEQ=[F:SCS]SCSLIN : WFCY=[F:SCS]PRHFCY
  When "HDT"
    WVCRNUM=[F:HDT]HDTNUM : WFCY=[F:HDT]HDTSTOFCY
  When "HDI"
    WVCRNUM=[F:HDI]SRENUM : WVCRLIN=[F:HDI]HDTORD
  When "SMD"
    Read [SMH] SMH0=[F:SMD]VCRTYP;[F:SMD]VCRNUM : If fstat  Raz [F:SMH] : Endif
    Read [ITF] ITF0=[F:SMD]ITMREF;[F:SMH]STOFCY : If fstat  Raz [F:ITF] : Endif
    If [F:ITF]STOMGTCOD<2  Return : Endif
    WVCRTYP=[F:SMD]VCRTYP : WVCRNUM=[F:SMD]VCRNUM : WVCRLIN=[F:SMD]VCRLIN : WFCY=[F:SMH]STOFCY
  When "SGD"
    Read [SGH] SGH0=[F:SGD]VCRNUM : If fstat  Raz [F:SGH] : Endif
    If [F:SGH]TRSTYP=34  Return : Endif
    WVCRTYP=29 : WVCRNUM=[F:SGD]VCRNUM : WVCRLIN=[F:SGD]VCRLIN : WFCY=[F:SGH]STOFCY
Endcase
If WABRFIC="MFO2"  WABRFIC="MFO" : Endif
If WABRFIC="MKO2"  WABRFIC="MKO" : Endif
Look [CAL] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
If fstat
  WCLE2 =WABRFIC-num$(WVCRTYP)-WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ)-WCPLCLE-"1"
  Raz fstat
  #----- Exceptions : Pas d'enregistrement pour les anciens documents -----#
  If WABRFIC="PVF" & find(WVCRTYP,3,5,6)   Return : Endif
  If WABRFIC="SVF" & find(VCRTYP,1,20,2)   Return : Endif
  If WABRFIC="SQD"                         Return : Endif
  #-----
  If WTRACE
    Call ECR_TRACE("File CPTANALIN.:"-WCLE2-"Key not found !",1) From GESECRAN
  Endif
  If !WSIMUL & WFCY<>""
    Trbegin [CAL]
      Raz [F:CAL]
      [F:CAL]ABRFIC=WABRFIC
      [F:CAL]VCRTYP=WVCRTYP
      [F:CAL]VCRNUM=WVCRNUM
      [F:CAL]VCRLIN=WVCRLIN
      [F:CAL]VCRSEQ=WVCRSEQ
      [F:CAL]CPLCLE=WCPLCLE
      [F:CAL]ANALIG=1
      #-----
      Call RECUP_GLOBAL_CPT(DOSSIER,WFCY) From TRTX3CPT
      #-----
      For I=1 To 10
        J=GTYPLED(I)
        If J
          [F:CAL]LED(J-1)=GLEDSOC(I)
          [F:CAL]COA(J-1)=GCOA(I)
        Endif
      Next I
      #-----
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:CAL]DIE(I-1)=GDIE(I)
        If WCCEDEF<>""
           Call INISEC([F:CAL]CCE(I-1),WCCEDEF,GDIE(I)) From SUBCDE
        Endif
      Next I
      #-----
      Write [CAL]
      If fstat
        If WTRACE
          Call ECR_TRACE("File CPTANALIN.:"-WCLE2-"Write Error="+num$(fstat),1) From GESECRAN
        Endif
      Else
        If WTRACE
          Call ECR_TRACE("File CPTANALIN.:"-WCLE2-"Record created",0) From GESECRAN
        Endif
      Endif
    Commit
  Endif
  WNBRERR+=1
Endif
WNBRCHK+=1
Return


#-------------------------------------------------#
# Fin de la vérification des lignes d'un document #
#-------------------------------------------------#
$FIN_CPTANALIN
If WNBRERR<>0 & !WTRACE
  Call ECR_TRACE("File"-WNOMFICH-"Checked (Errors="+num$(WNBRERR)+"/"+num$(WNBRCHK)+")",1) From GESECRAN
Else
  Call ECR_TRACE("File"-WNOMFICH-"Checked (Errors="+num$(WNBRERR)+"/"+num$(WNBRCHK)+")",0) From GESECRAN
Endif
WTOTCHK+=WNBRCHK
WTOTERR+=WNBRERR
Case WABRFIC
  When "PQD" : Close Local File [PQD]
  When "PSD" : Close Local File [PSD]
  When "POP" : Close Local File [POP]
  When "UOP" : Close Local File [UOP]
  When "PTD" : Close Local File [PTD]
  When "PND" : Close Local File [PND]
  When "PID" : Close Local File [PID]
  When "PVF" : Close Local File [PVF]
  When "SQD" : Close Local File [SQD]
  When "SOP" : Close Local File [SOP]
  When "VOP" : Close Local File [VOP]
  When "SDD" : Close Local File [SDD]
  When "SRD" : Close Local File [SRD]
  When "SID" : Close Local File [SID]
  When "SVF" : Close Local File [SVF]
  When "MFI" : Close Local File [MFI]
  When "MFO" : Close Local File [MFO]
  When "MFM" : Close Local File [MFM]
  When "MKI" : Close Local File [MKI]
  When "MKO" : Close Local File [MKO]
  When "MKM" : Close Local File [MKM]
  When "SCI" : Close Local File [SCI]
  When "SCM" : Close Local File [SCM]
  When "SCS" : Close Local File [SCS]
  When "HDT" : Close Local File [HDT]
  When "HDI" : Close Local File [HDI]
  When "SMD" : Close Local File [ITF], [SMH], [SMD]
  When "SGD" : Close Local File [SGH], [SGD]
Endcase
Raz WNBRCHK, WNBRERR
Return

# Issue 112530  - 2015-11-17 by MAE : ajout du sous pro patch
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call EXE_UTIVERFCAL(APPLI)
End

