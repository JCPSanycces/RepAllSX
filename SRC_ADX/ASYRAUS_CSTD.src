#<AdxTL>@(#)0.0.0.0 $Revision$
# Class ASYRAUS

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_BEFORE" : Gosub AUPDATE_CONTROL_BEFORE
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "AINSERT_AFTER"          : Gosub AINSERT_AFTER
        When "AUPDATE_BEFORE"         : Gosub AUPDATE_BEFORE
        When "AUPDATE_AFTER"          : Gosub AUPDATE_AFTER
      Endcase
  Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "USR"                        : Gosub USR
    When "LOGIN"                      : Gosub LOGIN
    When "PRENAME"                    : Gosub PRENAME
    When "SURNAME"                    : Gosub SURNAME
    When "ENAFLG"                     : Gosub ENAFLG
    When "USRCONNECT"                 : Gosub USRCONNECT
    When "USRCONXTD"                  : Gosub USRCONXTD
  Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

##############################################################################################################################
$AINSERT_CONTROL_BEFORE
  #Initialization
  If this.LOGIN=AVOID.ACHAR
    this.LOGIN=this.USR
  Endif

  this.PASSE   = "BAABAA"       # space
  this.PASSDAT = date$

  Gosub CONTROL_BEFORE
Return

##############################################################################################################################
$AINSERT_CONTROL_AFTER
  Gosub INTUSR_ASSIGN
  #Unicity of code
  Local File AUTILIS [AUS]
  Read [F:AUS]CODUSR=this.USR
  If fstat = CST_AOK
    #The record already exits
    [L]ASTATUS = fmet this.ASETERROR("USR",mess(22,100,1)-this.USR,[V]CST_AERROR)
  Else :#{SAM 119712
   #check the unicity of the login
   Read [F:AUS]LOGIN=this.LOGIN
   If fstat = CST_AOK
     #The record already exits
     [L]ASTATUS = fmet this.ASETERROR("LOGIN",mess(27,130,1)-this.LOGIN,[V]CST_AERROR)
   Endif
  Endif #SAM 119712}
  Gosub ALLACS_ASSIGN
Return

##############################################################################################################################
$AUPDATE_CONTROL_BEFORE
  #LSE 2016-12-29 SAM 120418
  # the classe is used in a web wervice => we msut save the received data, read the data from the data base
  #  and assign the received values if we don't want to erase the vales in the data base
  If fmet this.AGETMAXERRORALL = CST_AOK
    Gosub GET_VALUES_FROM_DB
    If ASTATUS =CST_AOK
      Gosub CONTROL_BEFORE
    Endif
  Endif
Return

##############################################################################################################################
$AUPDATE_CONTROL_AFTER
  Gosub INTUSR_ASSIGN
  If (this.CODMET<>this.snapshot.CODMET) or (this.PRFFCT<>this.snapshot.PRFFCT)
    Gosub ALLACS_ASSIGN
  Endif
Return

##############################################################################################################################
$GET_VALUES_FROM_DB
Local Char USR_SAV(GLONAUS)
Local Char LOGIN_SAV(GLONALO)
Local Integer ENAFLG_SAV
Local Char ADDEML_SAV(GLONMAI)
Local Char PRENAME_SAV (20) #FIRSTNAME
Local Char SURNAME_SAV(GLONNAM)  #LASTNAME
Local Integer  USRCONNECT_SAV
Local Char CODMET_SAV(GLONAME)
Local Char PRFFCT_SAV(GLONAFT) :#X3-47047
Local Integer ASTALIN_SAV :#X3-47047

  #SAVE receivd data

  [L]USR_SAV = this.USR
  [L]LOGIN_SAV = this.LOGIN
  [L]ENAFLG_SAV = this.ENAFLG
  [L]ADDEML_SAV = this.ADDEML
  [L]PRENAME_SAV = this.PRENAME
  [L]SURNAME_SAV = this.SURNAME
  [L]USRCONNECT_SAV = this.USRCONNECT
  [L]CODMET_SAV = this.CODMET
  [L]PRFFCT_SAV = this.PRFFCT :#X3-47047
  [L]ASTALIN_SAV = this.ASTALIN :#X3-47047

  [L]ASTATUS = fmet this.AREAD( USR_SAV)
  If [L]ASTATUS <> CST_AOK
  #CODE UTILISATEUR INEXISTANT
   [L]ASTATUS = fmet this.ASETERROR("",mess(141,100,1)-[L]USR_SAV,[V]CST_AERROR)
  Else
    this.LOGIN =[L]LOGIN_SAV
    this.ENAFLG = [L]ENAFLG_SAV
    this.ADDEML= [L]ADDEML_SAV
    this.PRENAME = [L]PRENAME_SAV
    this.SURNAME = [L]SURNAME_SAV
    this.USRCONNECT = [L]USRCONNECT_SAV
    this.CODMET = [L]CODMET_SAV
    this.PRFFCT = [L]PRFFCT_SAV :#X3-47047
    this.ASTALIN = [L]ASTALIN_SAV :#X3-47047
  Endif
Return

##############################################################################################################################
$CONTROL_BEFORE
  If this.CODMET=AVOID.ACHAR
    ASTATUS= fmet this.ASETATTRIBUTE("PRFMEN","$isMandatory","true")
    ASTATUS= fmet this.ASETATTRIBUTE("PRFFCT","$isMandatory","true")
  Else
    ASTATUS= fmet this.ASETATTRIBUTE("PRFMEN","$isMandatory","false")
    ASTATUS= fmet this.ASETATTRIBUTE("PRFFCT","$isMandatory","false")
  Endif
Return

##############################################################################################################################
$AINSERT_AFTER
  Gosub DEFINE_USRACCESS
  If ASTATUS=CST_AOK
    Gosub DEFINE_PARAM
  Endif
Return

##############################################################################################################################
$AUPDATE_BEFORE
  If (this.CODMET<>this.snapshot.CODMET) or (this.PRFFCT<>this.snapshot.PRFFCT)
    Gosub DELETE_USRACCESS
    If ASTATUS=CST_AOK
      Gosub DELETE_PARAM
    Endif
  Endif
  #X3-47047
  Read [F:AUS]CODUSR=this.USR
  If fstat
    [L]ASTATUS = fmet this.ASETERROR("",mess(141,100,1)-this.USR,[V]CST_AERROR)
  Endif
  #end X3-47047
Return

##############################################################################################################################
$AUPDATE_AFTER
  If (this.CODMET<>this.snapshot.CODMET) or (this.PRFFCT<>this.snapshot.PRFFCT)
    Gosub DEFINE_USRACCESS
    If ASTATUS=CST_AOK
      Gosub DEFINE_PARAM
    Endif
  Endif
Return

##############################################################################################################################
$USR
  Case [L]ARULE
    When "CONTROL"                  : Gosub USR_CONTROL
  Endcase
Return

$USR_CONTROL
Return

##############################################################################################################################
$LOGIN
  Case [L]ARULE
    When "CONTROL"                  : Gosub LOGIN_CONTROL
  Endcase
Return

$LOGIN_CONTROL
  If this.LOGIN<>AVOID.ACHAR and this.USR<> AVOID.ACHAR
    # Issue X3-56120: X3 users import error when special character in login
    # 2018-07-20: TOGAN
    this.LOGIN = toupper(this.LOGIN)
    If this.LOGIN <> vireblc(this.LOGIN, 4) or this.LOGIN <> ctrans(this.LOGIN, "'", "") or this.LOGIN <> ctrans(this.LOGIN, '"', "") Then
      [L]ASTATUS = fmet this.ASETERROR("LOGIN", mess(109,130,1), [V]CST_AERROR)
    Endif
    # End issue X3-56120
    Local File AUTILIS [AUS]
    For [AUS] Where LOGIN=this.USR
      If this.USR <> [F:AUS]USR
        [L]ASTATUS = fmet this.ASETERROR("LOGIN",mess(27,130,1)-this.USR,[V]CST_AERROR)
      Endif
    Next
  Endif
Return

##############################################################################################################################
$PRENAME
  Case [L]ARULE
    When "PROPAGATE"                  : Gosub PRENAME_PROPAGATE
  Endcase
Return

$PRENAME_PROPAGATE
  Gosub NOMUSR_ASSIGN
  #Gosub INTUSR_ASSIGN
Return

##############################################################################################################################
$SURNAME
  Case [L]ARULE
    When "PROPAGATE"                  : Gosub SURNAME_PROPAGATE
  Endcase
Return

$SURNAME_PROPAGATE
  Gosub NOMUSR_ASSIGN
  #Gosub INTUSR_ASSIGN
Return

##############################################################################################################################
$ENAFLG
  Case [L]ARULE
    When "INIT"                       : Gosub ENAFLG_INIT
  Endcase
Return

$ENAFLG_INIT
  this.ENAFLG = [V]CST_AYES
Return

##############################################################################################################################
$USRCONNECT
  Case [L]ARULE
    When "INIT"                       : Gosub USRCONNECT_INIT
  Endcase
Return

$USRCONNECT_INIT
  this.USRCONNECT = [V]CST_AYES
Return

##############################################################################################################################
$USRCONXTD
  Case [L]ARULE
    When "INIT"                       : Gosub USRCONXTD_INIT
  Endcase
Return

$USRCONXTD_INIT
  this.USRCONXTD = [V]CST_ANO
Return

##############################################################################################################################
$INTUSR_ASSIGN
  #this.INTUSR = this.PRENAME-this.SURNAME
  this.INTUSR=this.NOMUSR
  #SAM 122018
  Local Integer LINDICE
  Local Integer LSTATUS
  Local File ADOSSIER [ADS]
  Read [ADS]DOSSIER= this.ACTX.AFOLDER
  If fstat=0
    For LINDICE=0 To [F:ADS]NBRLAN-1
      LSTATUS = fmet this.INTUSR.ASETTEXTLAN(this.NOMUSR, [F:ADS]LAN(LINDICE))
    Next
  Endif
Return

##############################################################################################################################
$NOMUSR_ASSIGN
  this.NOMUSR = this.PRENAME-this.SURNAME
Return

##############################################################################################################################
$ALLACS_ASSIGN
Local Integer MY_STATUS
Local Char MY_PRFFCT(GLONAFT)
Local File AFCTFCT [AFT]
  this.ALLACS = [V]CST_ANO
  If this.PRFFCT<> AVOID.ACHAR
    MY_PRFFCT=this.PRFFCT
  Elsif this.CODMET <> AVOID.ACHAR
    Local Instance MY_ASYRMET Using C_ASYRMET
    MY_ASYRMET = NewInstance C_ASYRMET AllocGroup null
    [L]MY_STATUS = fmet MY_ASYRMET.AREAD(this.CODMET)
    If [L]MY_STATUS = [V]CST_AOK
      MY_PRFFCT=MY_ASYRMET.PRFFCT
    Endif
    FreeGroup MY_ASYRMET
  Endif
  If MY_PRFFCT<>AVOID.ACHAR
    Read [F:AFT]AFT0=MY_PRFFCT
    If fstat=CST_AOK
      this.ALLACS = [F:AFT]ALLACS
    Endif
  Endif
Return

##############################################################################################################################
$DEFINE_USRACCESS
Local File ACCCOD [ACS]
Local File ACCES [ACC]
Local File ACCES [ACC1]
Local Char MY_PRFFCT(GLONAFT)

  If this.ALLACS <> [V]CST_AYES
    If this.PRFFCT<> AVOID.ACHAR
      MY_PRFFCT= this.PRFFCT
    Elsif this.CODMET<> AVOID.ACHAR
      Local Instance MY_ASYRMET Using C_ASYRMET
      MY_ASYRMET = NewInstance C_ASYRMET AllocGroup null
      If fmet MY_ASYRMET.AREAD(this.CODMET) = [V]CST_AOK
        MY_PRFFCT= MY_ASYRMET.PRFFCT
      Endif
      FreeGroup MY_ASYRMET
    Endif
    For [ACC] Where PRFCOD= MY_PRFFCT
      If [ACC]CODACC<> AVOID.ACHAR
        Raz [F:ACC1]
        [F:ACC1]       = [F:ACC]
        [F:ACC1]USR    = this.USR
        [F:ACC1]PRFCOD = AVOID.ACHAR
        [F:ACC1]CREUSR = this.CREUSR
        [F:ACC1]UPDUSR = [F:ACC1]CREUSR
        [F:ACC1]CREDATTIM=datetime$
        [F:ACC1]UPDDATTIM=datetime$
        Write [ACC1]
        If fstat<> CST_AOK
          [L]ASTATUS = fmet this.ASETERROR("ACCES",func ASYRFNC.MES1(mess(88,130,1),this.USR-[F:ACC1]CODACC),[V]CST_AERROR)
        Endif
       Endif
    Next
  Else : #108083
    For [ACS]ACS0
      Raz [F:ACC1]
      [F:ACC1]       = [F:ACS]
      [F:ACC1]CONSUL = 2
      [F:ACC1]EXEC   = 2
      [F:ACC1]MODIF  = 2
      [F:ACC1]USR    = this.USR
      [F:ACC1]PRFCOD = AVOID.ACHAR
      [F:ACC1]CREUSR = this.CREUSR
      [F:ACC1]UPDUSR = [F:ACC1]CREUSR
      [F:ACC1]CREDATTIM=datetime$
      [F:ACC1]UPDDATTIM=datetime$
      Write [ACC1]
      If fstat<> CST_AOK
        [L]ASTATUS = fmet this.ASETERROR("ACCES",func ASYRFNC.MES1(mess(88,130,1),this.USR-[F:ACC1]CODACC),[V]CST_AERROR)
      Endif
    Next
  Endif
  If  [L]ASTATUS=CST_AOK
    Raz [F:ACC1]
    [F:ACC1]CONSUL = 2
    [F:ACC1]EXEC   = 2
    [F:ACC1]MODIF  = 2
    [F:ACC1]USR    = this.USR
    [F:ACC1]PRFCOD = AVOID.ACHAR
    [F:ACC1]CODACC = AVOID.ACHAR : # Code accès vide pour Crystal Report
    [F:ACC1]CREUSR = this.CREUSR
    [F:ACC1]UPDUSR = [F:ACC1]CREUSR
    [F:ACC1]CREDATTIM=datetime$
    [F:ACC1]UPDDATTIM=datetime$
    Write [ACC1]
    If fstat<> CST_AOK
      [L]ASTATUS = fmet this.ASETERROR("ACCES",func ASYRFNC.MES1(mess(88,130,1),this.USR-[F:ACC1]CODACC),[V]CST_AERROR)
    Endif
  Endif

  LogicClose File [ACC],[ACC1],[ACS]
Return

##############################################################################################################################
$DELETE_USRACCESS
Local File ACCES [ACC]

  Delete [ACC] Where [F:ACC]USR = this.USR
  If fstat<> CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("ACCES",func ASYRFNC.MES1(mess(107,130,1),this.USR),[V]CST_AERROR)
  Endif

  LogicClose File [ACC]
Return

##############################################################################################################################
#**
#* PARAM_PROPERTY - Determine user properties and default values based on trade code
#*!
$DEFINE_PARAM
Local Instance MY_ASYRMET Using C_ASYRMET
Local Instance MY_ADOVALAUS Using C_ADOVALAUS
Local File ADOPAR     [ADP]
Local File ADOVAL     [ADW]
Local File AFCTFCT    [AFT]
Local File ACCES      [ACC]
Local Char MY_PRFFCT(GLONAFT)
Local Char SITE(GLONFCY),SOCIETE(GLONCPY),LEG(GLONCPY),TYP(GLONATY)
Local Integer MY_STATUS,AFFOK

  #Load Trade profile  -
  If this.PRFFCT <> AVOID.ACHAR
    MY_PRFFCT= this.PRFFCT
  Elsif this.CODMET<> AVOID.ACHAR
    MY_ASYRMET = NewInstance C_ASYRMET AllocGroup null
    [L]ASTATUS = fmet MY_ASYRMET.AREAD(this.CODMET)
    If [L]ASTATUS >= [V]CST_AERROR
      [L]ASTATUS = fmet this.ASETERRROR("CODMET",mess(231,124,1)-this.CODMET,[V]CST_AERROR)
    Else
      MY_PRFFCT= MY_ASYRMET.PRFFCT
    Endif
    FreeGroup MY_ASYRMET
  Endif
  #LOAD FUNCTION PROFILE –
  Read [AFT]AFT0= MY_PRFFCT
  If fstat<> CST_AOK
    [L]ASTATUS = fmet this.ASETERRROR("AFCTFCT",mess(206,139,1)-MY_ASYRMET.PRFFCT,[V]CST_AERROR)
  Endif
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  #Loop thru ADOPAR table for user parameters that modifiable (NIVDEF=4 & MODIF=[V]CST_AYES)
  For [ADP]ADP5 Where NIVDEF=4 & MODIF=[V]CST_AYES
   [L]SITE = ""
   [L]SOCIETE = ""
   [L]LEG = ""

   # Only non-blank chapters in user parameters
   If [F:ADP]CHAPITRE<>""
    AFFOK = [V]CST_ATRUE
    # Check access codes
    If [F:ADP]ACS<>"" & this.ACTX.ALLACS<>[V]CST_AYES
     Read [ACC]CODACC = this.ACTX.USER;[F:ADP]ACS
     If fstat or [F:ACC]MODIF<>[V]CST_AYES : AFFOK = [V]CST_AFALSE : Endif
    Endif

    If AFFOK=[V]CST_ATRUE
     # Parameter is a user parameter and is defined at the folder level
     If [F:ADP]VALDEF=[V]CST_AYES
      # Determine default site by chapter and module
      AFFOK= func DFLCHAP(this,[F:ADP]CHAPITRE,[L]SITE,[F:AFT]PRFCOD)

      # Determine societe and legislation from site
      If AFFOK
       If [L]SITE<>AVOID.ACHAR & find([L]SITE,this.ACTX.APARAM.LIST_FCY(1..maxtab(this.ACTX.APARAM.LIST_FCY)))>0
        [L]SOCIETE = this.ACTX.APARAM.LIST_CPY(find([L]SITE,this.ACTX.APARAM.LIST_FCY(1..maxtab(this.ACTX.APARAM.LIST_FCY))))
        [L]LEG = this.ACTX.APARAM.LIST_CPY(find([L]SOCIETE,this.ACTX.APARAM.LIST_CPY(1..maxtab(this.ACTX.APARAM.LIST_CPY))))
       Endif
      Endif
     Endif

     # If not a folder defined paraemter
     If [F:ADP]VALDEF=[V]CST_ANO
       # Get data type
       Call DATA_TYPE([F:ADP]TYPVAL,[F:ADP]OBJET,[L]TYP)

       # Load user parameters
       MY_ADOVALAUS = NewInstance C_ADOVALAUS AllocGroup null
       [L]ASTATUS = fmet MY_ADOVALAUS.AINIT
       If [L]ASTATUS <> [V]CST_AOK
        [L]ASTATUS = fmet this.ASETERROR("AINIT", mess(91,143,1)-"ADOVALAUS",[V]CST_AERROR)
        FreeGroup MY_ADOVALAUS
        Break
       Endif
        # Determine ADOVALAUS values from ADOVAL
        MY_ADOVALAUS.CODUSR         = this.USR
        MY_ADOVALAUS.PARAM          = [F:ADP]PARAM

        Read [F:ADW]ADW0="";"";[F:ADP]PARAM
        If fstat
          MY_ADOVALAUS.JEU            = AVOID.ACHAR
          MY_ADOVALAUS.VALEUR         = AVOID.ACHAR
        Else
          MY_ADOVALAUS.JEU            = [F:ADW]JEU
          MY_ADOVALAUS.VALEUR         = [F:ADW]VALEUR
        Endif

        # Set valeur to correct value by data type
        Call CHARGE([L]TYP,[F:ADP]NOLIB,MY_ADOVALAUS.VALEUR)
        [L]ASTATUS = fmet MY_ADOVALAUS.AINSERT()
        If [L]ASTATUS <> [V]CST_AOK
          [L]ASTATUS = fmet this.ASETERROR("ADOVALAUS",func ASYRFNC.MES1(mess(54,159,1),this.USR-MY_ADOVALAUS.PARAM),[V]CST_AERROR)
          FreeGroup MY_ADOVALAUS
          Break
        Endif
        FreeGroup MY_ADOVALAUS
      Endif
    Endif
   Endif
  Next ADP
Return

##############################################################################################################################
#**
#* DELETE_PROPERTY - Delete all the user properties and default values
#*!
$DELETE_PARAM
Local File ADOVALAUS [ADU]

  Delete [ADU] Where [F:ADU]CODUSR = this.USR
  If fstat<> CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("ADOVALAUS",func ASYRFNC.MES1(mess(108,130,1),this.USR),[V]CST_AERROR)
  Endif

  LogicClose File [ADU]
Return

#**
#* DFLCHAP
#*
#* @param CHAPITRE
#* @param SITE
#* @param OK
#*!
Funprog DFLCHAP(MY_OBJECT,CHAPITRE,SITE,PROFILE)
Variable Instance MY_OBJECT Using OBJECT
Value    Char    CHAPITRE
Variable Char    SITE
Value    Char    PROFILE
Local Integer OK : OK=[V]CST_AFALSE
Local Integer MODULE

  If dim(MY_OBJECT.ACTX.AFOLD.AMODULE)<0 : End : Endif

  #?? Dropping old logic#Local Char ACTION(20)

  #If [L]MODULE<=0
  # old logic : hard coded correspondance
  # Case CHAPITRE
  #  When "SUP" : [L]SITE =([F:AFT]FCYDEF(0))  : If GMODU(1)=2 : OK=1 : Endif
  #  When Default
  #   ACTION = "CHPDEF" : Gosub ACTION
  #   OK = 1
  # Endcase
  #Else

  # new logic : correspondance defined in "table diverse" 901
  # get Module from Chapter
  [L]MODULE = func GET_MODULE_FROM_CHP(MY_OBJECT.ACTX.AFOLDER,CHAPITRE)
  [L]SITE = func GET_SITE_FROM_MDL(MY_OBJECT.ACTX.AFOLDER,[L]MODULE,[L]PROFILE)
  # Verify module is in range of module array
  If [L]MODULE > 0 and [L]MODULE <= dim(MY_OBJECT.ACTX.AFOLD.AMODULE)
    If MY_OBJECT.ACTX.AFOLD.AMODULE([L]MODULE)=[V]CST_AYES :
      [L]OK=[V]CST_ATRUE
    Endif
  Endif
End [L]OK

#**
#* GET_MODULE_FROM_CHP - get module from chapter
#*
#* @param DOSSIER - folder
#* @param CODCHP  - chapter from parameters
#*!
Funprog GET_MODULE_FROM_CHP(DOSSIER,CODCHP)
Value Char DOSSIER, CODCHP
Local Integer NUM_MODULE : [L]NUM_MODULE=0
Local File =[L]DOSSIER+".ATABDIV"  [ADI]
  Read [ADI]CODE = 901;[L]CODCHP
  If !fstat
    [L]NUM_MODULE = [ADI]N1
  Endif
  Close Local File [ADI]
End [L]NUM_MODULE

#**
#* GET_SITE_FROM_MDL =  Get the default site for a given Module from the function profile
#*
#* @param DOSSIER
#* @param NUMMDL
#* @param PROFILE
#*!
Funprog GET_SITE_FROM_MDL(DOSSIER,NUMMDL,PROFILE)
Value Char DOSSIER
Value Integer NUMMDL
Value Char PROFILE
Local Char SITE(GLONFCY)
Local File =DOSSIER+".AFCTFCT"  [AFT]
  Read [AFT]AFT0 = PROFILE
  If !fstat and NUMMDL>0 and NUMMDL<=20
    [L]SITE = [AFT]FCYDEF(NUMMDL-1)
  Endif
  Close Local File [AFT]
End SITE

#**
#* CHARGE
#*
#* @param TYP
#* @param LIB
#* @param VALINT
#*!
Subprog CHARGE(TYP,LIB,VALINT)
Value    Char     TYP
Value    Shortint LIB
Variable Char     VALINT
Local File ATYPE [ATY]

  If [F:ATY]CODTYP<>TYP
   Read [ATY]CODTYP = TYP
   If fstat
    Read [ATY]CODTYP = "A"
   Endif
  Endif

  Case [F:ATY]TYPTYP
   When 1 : # Menu local
    Local Integer VALNUM
    VALNUM = val([L]VALINT)
     If LIB=0      : VALNUM = 1   : Endif
     If VALNUM<1   : VALNUM = 1   : Endif
     If VALNUM>255 : VALNUM = 255 : Endif
     VALINT = num$(VALNUM)

   When 2,3,4,5,6 : # Numérique
    If [L]VALINT=AVOID.ACHAR
      [L]VALINT="0"
    Endif

   When 7 : # Alpha

   When 8 : # Date
    If [L]VALINT=AVOID.ACHAR
      [L]VALINT="00000000"
    Endif

  Endcase
  LogicClose File [ATY]
End

Subprog DATA_TYPE(TYPVAL,OBJET,TYP)
Value Shortint TYPVAL
Value Char     OBJET
Variable Char  TYP
Local Integer K
Local File ATYPE [ATY]

  Case [L]TYPVAL
    When 1 : [L]TYP = "A"
    When 2 : [L]TYP = "DCB"
    When 3 : [L]TYP = "D"
    When 4 : [L]TYP = "M"
  Endcase

  # Find datatype based on object
  If [F:ADP]OBJET<>""
    Filter [ATY] Where OBJLIEN=[L]OBJET
    K = 0
    For [ATY]
      K += 1 : If K>1 : Break : Endif
    Next ATY
    Filter [ATY]
    If K=1 & left$([F:ATY]FORTYP,1)<>"="
      [L]TYP = [F:ATY]CODTYP
    Endif
  Endif
  LogicClose File [ATY]
End

