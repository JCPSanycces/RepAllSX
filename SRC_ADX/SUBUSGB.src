#################################################################################################################
#  Sous programmes pour la gestion des groupes d'utilisateurs                  Module CRM     26 novembre 2002  #
#################################################################################################################
#                                                                                                               #
#  LOADGRUAUS    : Charge les utilisateurs du groupe.                                                           #
#  LOADGRURSE    : Charge les ressources du groupe.                                                             #
#  SAVEGRUAUS    : Enregistre les utilisateurs du groupe.                                                       #
#  SAVEGRURSE    : Enregistre les ressources d'un groupe.                                                       #
#                                                                                                               #
#################################################################################################################

#################################################################################################################
#  LOADGRUAUS    : Charge les utilisateurs du groupe.                                                           #
#################################################################################################################
Subprog LOADGRUAUS(SZAUSGRUCOD)
Value Char SZAUSGRUCOD

Local Integer INBAUS
INBAUS = 0

#Utilisateurs
Raz [M:USG1]NBAUS
Raz [M:USG1]GRUAUS

Filter [USD] Where [F:USD]AUSGRUCOD = SZAUSGRUCOD Order By [F:USD]GRUAUS Asc

For [USD]
    [M:USG1]GRUAUS(INBAUS) = [F:USD]GRUAUS
    INBAUS += 1
Next

Filter [USD]

[M:USG1]NBAUS = INBAUS

Affzo [M:USG1]
End

#################################################################################################################
#  LOADGRURSE    : Charge les ressources d'un groupe.                                                           #
#################################################################################################################
Subprog LOADGRURSE(SZAUSGRUCOD)
Value Char SZAUSGRUCOD

Local Integer INBRSE
INBRSE = 0

#Ressources
Raz [M:USG2]NBRSE
Raz [M:USG2]GRURSE

Filter [USR] Where [F:USR]AUSGRUCOD = SZAUSGRUCOD Order By [F:USR]GRURSE Asc

For [USR]
    [M:USG2]GRURSE(INBRSE) = [F:USR]GRURSE
    INBRSE += 1
Next

Filter [USR]

[M:USG2]NBRSE = INBRSE

Affzo [M:USG2]
End

#################################################################################################################
#  SAVEGRUAUS   : Enregistre les utilisateurs du groupe.                                                        #
#################################################################################################################
Subprog SAVEGRUAUS(SZAUSGRUCOD, ISOK)
Value Char SZAUSGRUCOD
Variable Integer ISOK

Local Integer ITER
ITER = 0
ISOK = 1

Call DEBTRANS From GLOCK
Trbegin [USD]
Delete [USD] Where [F:USD]AUSGRUCOD = SZAUSGRUCOD
If fstat
    Rollback
    ISOK = 0
    End
Else
    Commit
Endif

Call DEBTRANS From GLOCK
Trbegin [USD]
For ITER = 0 To [M:USG1]NBAUS - 1
    If [M:USG1]GRUAUS(ITER) <> ""
        [F:USD]AUSGRUCOD = SZAUSGRUCOD
        [F:USD]GRUAUS = [M:USG1]GRUAUS(ITER)
        Write [USD]
        If fstat
            Rollback
            ISOK = 0
            Break
        Endif
    Endif
Next

If ISOK
    Commit
Endif

End

#################################################################################################################
#  SAVEGRURSE   : Enregistre les ressources d'un groupe.                                                        #
#################################################################################################################
Subprog SAVEGRURSE(SZAUSGRUCOD, ISOK)
Value Char SZAUSGRUCOD
Variable Integer ISOK

Local Integer ITER
ITER = 0
ISOK = 1

Call DEBTRANS From GLOCK
Trbegin [USR]
Delete [USR] Where [F:USR]AUSGRUCOD = SZAUSGRUCOD
If fstat
    Rollback
    ISOK = 0
    End
Else
    Commit
Endif

Call DEBTRANS From GLOCK
Trbegin [USR]
For ITER = 0 To [M:USG2]NBRSE - 1
    If [M:USG2]GRURSE(ITER) <> ""
        [F:USR]AUSGRUCOD = SZAUSGRUCOD
        [F:USR]GRURSE = [M:USG2]GRURSE(ITER)
        Write [USR]
        If fstat
            Rollback
            ISOK = 0
            Break
        Endif
    Endif
Next

If ISOK
    Commit
Endif

End

