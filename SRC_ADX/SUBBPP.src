#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du fichier BPCUSTOMER
########################################################################
#    GESTION DES PROSPECTS                                 SUBBPP      #
#                                                      19 JUILLET 2000 #
########################################################################
$ACTION
# Pour gestion multi-société
# Gosub ACTION From GSOCIETE
Case ACTION
 When "OUVRE"         : Gosub OUVRE        From SUBBPPA
 When "AFFMASK"       : Gosub AFFMASK      From SUBBPPA
 When "FERME"         : Gosub FERME        From SUBBPPA
 When "SETBOUT"       : Gosub SETBOUT      From SUBBPPA
 When "EXEBOUT"       : Gosub EXEBOUT      From SUBBPPA
 When "STATUT"        : Gosub STATUT       From SUBBPPA
 When "AVANTBOUT"     : Gosub AVANTBOUT    From SUBBPPA
 When "LIENS"         : Gosub LIENS        From SUBBPPA
 When "RAZCRE"        : Gosub RAZCRE       From SUBBPPA
 When "RAZDUP"        : Gosub RAZDUP       From SUBBPPA
 When "VERIF_CRE"     : Gosub VERIFCRE_MOD From SUBBPPA
 When "INICRE"        : Gosub INICRE       From SUBBPPA
 When "CREATION"      : Gosub CREATION     From SUBBPPA
 When "VERIF_MOD"     : Gosub VERIFCRE_MOD From SUBBPPA
 When "INIMOD"        : Gosub INIMOD       From SUBBPPA
 When "MODIF"         : Gosub MODIF        From SUBBPPA
 When "FIN_MOD"       : Gosub FINMODIF     From SUBBPPA
 When "ANNULE"        : Gosub ANNULE       From SUBBPPA
 When "VERROU"        : Gosub VERROU       From SUBBPPA
 When "DEVERROU"      : Gosub FINMODIF     From SUBBPPA
 When "ABANDON"       : Gosub ABANDON      From SUBBPPA
 When "FILTRE"        : Gosub FILTRE       From SUBBPPA
 When "FILGAUCHE"     : Gosub FILGAUCHE    From SUBBPPA
 When "APRES_CRE"     : Gosub APRES_CRE    From SUBBPPA
 When "APRES_MOD"     : Gosub APRES_MOD    From SUBBPPA
 When "AP_ANNULE"     : Gosub AP_ANNULE    From SUBBPPA
 When "APRES_MODIF"   : Gosub APRES_MODIF  From SUBBPPA
 When "AVANT_CHOI"    : Gosub AVANT_CHOI   From SUBBPPA


 When Default
Endcase
Return

########################################
Subprog C_BPCNUM(VALEUR)
Variable Char    VALEUR()

Local Integer IERR
Local Char SMESSAGE(type(GMESSAGE)-10)

  If [M:BPP0]REFCOU="" & VALEUR=""
     mkstat=2
     End
  Endif
  # FGR 02/04/2015 : X3SUIVI109045 (début)
  Local File BPARTNER [BPR1]
  Read [BPR1]BPR0=VALEUR
  If !fstat Then
    Call CTRL_TRSF_BPR_BPEXCEPT(VALEUR, IERR, SMESSAGE) From TRTVENSDD
    If IERR <> 0 Then
      GMESSAGE = SMESSAGE
      mkstat = 2
      End
    Endif
  Endif
  # FGR 02/04/2015 : X3SUIVI109045 (fin)
End

########################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()

GIBPPEXIST = 0
# Pb en import
# Il ne faut pas écraser [F:BPR] qui peut être chargé avec des champs à importer (Ex import de la raison sociale)
# ==> Lecture du tiers sous une autre abréviation
Read [BPR1]BPR0 = VALEUR
If fstat = 0
#    Le tiers existe : alimentation des zones venant de la fiche tiers
    If [F:BPR1]PPTFLG <> 2 & [F:BPR1]BPCFLG = 2 & GFONC1 = "GESBPP" : End : Endif
    [M:BPRP] = [F:BPR1]
    [M:BPP0]BPCNAM = [F:BPR1]BPRNAM
    [M:BPP1]BPCTYP = 4
    [M:BPRP]PPTFLG = 2
    Affzo [M:BPP0]BPCNAM
    Affzo [M:BPRP]1-99
    Default Mask [BPAP]
    Call CHARG_BPA(1,VALEUR,[F:BPR1]BPAADD) From TRTBPA
    Default Mask [CNTP]
    Call CHARG_CNT(1,VALEUR,[F:BPR1]CNTNAM) From TRTBPA
    Default Mask [BPP0]

    Affzo [M:BPAP]1-99
    Affzo [M:CNTP]1-99

    GIBPPEXIST = 1

    #-------------------------------------#
    # il faut verrouiller symbole BPR     #
    # si pas deja fait dans action verrou #
    #-------------------------------------#
    If GNAVIG(GPILNAV-1) <> "GESBPR" or (GNAVIG(GPILNAV-1) = "GESBPR" and [M:BPR0]BPRNUM <> VALEUR) Then # FGR 16/04/2012 : X3SUIVI81335
      SYMBOLE2 = "BPR"+num$(VALEUR)
      Lock = SYMBOLE2 With lockwait = 0
      If fstat
        If GREP = "C" or GREP = "D"
          GMESSAGE = mess(10,100,1)
          GERR = 1
          mkstat = 2
        Endif
      Else
        # FGR 16/04/2012 : X3SUIVI81335
        Global Integer GILOCKBPR

        GILOCKBPR = 1
      Endif
    Endif
Else
#   Le tiers n'existe pas
#   On a besoin de connaitre la devise pour charger les elements de facturation
  If [M:BPRP]CUR = "" #MAE, bg 102090
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    If [F:TCY]CRY <> GPAYS
        Read [TCY]TCY0 = GPAYS
        If fstat Raz [F:TCY] Endif
        [M:BPRP]CUR = [F:TCY]CUR
    Endif
  Endif
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPP0) 07/06/2013 10:49:14 (MAE)
######################################################################################
Subprog C_BCGCOD(VALEUR)
Variable Char    VALEUR()
# Catégorie obligatoire
If find(GREP,"C","D") & VALEUR=""
   mkstat=2
Endif
End

Subprog AM_BCGCOD(VALEUR)
Variable Char    VALEUR()
If find(GREP,"C","D")
   Call INI_BCGCATEG(VALEUR)
   # FGR 27/04/2016 : X3SUIVI116131 (début)
   Local Integer IGBCRMFLGNEW

   IGBCRMFLGNEW = GBCRMFLGNEW
   Gosub RAZCRE_CRM From TRTBPCRM
   # FGR 27/04/2016 : X3SUIVI116131 (fin)
   Affzo [M:BPRP]1-99
   Affzo [M:BPP1]1-99
Endif
End

Subprog AS_BPCNUM(VALEUR)
Variable Char    VALEUR()
If [M:BPP0]REFCOU<>"" & find(GREP,"C","D")
   mkstat = 2
Endif
If GNAVIG(max(GPILNAV-1,1)) = "GESBPR" & (GREP = "" | GREP="C") and !GIMPORT Then
    If [M:BPR0]BPRNUM <> "" & [M:BPP0]BPCNUM =""
      VALEUR = [M:BPR0]BPRNUM
      Call AM_BPCNUM(VALEUR)
    Endif
Endif

End

########################################
Subprog INI_BCGCATEG(COD)
Variable Char    COD
If COD="" End Endif
Read [BCG]BCG0=COD
If fstat  End Endif
#MAE/TS, bg 50894 init du nolign a 1 pour le transclasse d'un champ dimensionné (REP)
nolign = 1

[M:BPRP]CUR = GCUR
[M:BPP0]=[F:BCG]
[M:BPRP]=[F:BCG]
[M:BPP1]=[F:BCG]

End

