#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SCA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 47035 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "HRSCA"
  Local Char    VALEUR(250)
  VALEUR = [M]COD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]COD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 47035 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LEG or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LEG([M]LEG) From SUBHRSCA
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varmode([M]DES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone MAXSCALEV
mkstat = 0
zoncou = "MAXSCALEV"
indice = 0
If varmode([M]MAXSCALEV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MAXSCALEV" : Gosub ACTION From =IMPTRT
 Endif
 If [M]MAXSCALEV=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "MAXSCALEV" : GZNUM = 32620 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"
indice = 0
status = 1
zoncou = "NBRLIG"
SAVACT = GACTION : GACTION = "STD"
Call AV_NBRLIG From SUBHRSCA
GACTION = SAVACT
If mkstat=1 : Raz [M]NBRLIG : Endif
If !mkstat
 If varmode([M]NBRLIG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NBRLIG" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   NBLIG = [M]NBRLIG
   For nolign=1 To NBLIG
    indice = nolign-1
    [M]NBRLIG = nolign
    status = 75
    Call SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
    If mkstat : Break : Endif
   Next nolign
   If mkstat : End : Endif
   indice = 0
  Endif
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone AFF_LEVDES
mkstat = 0
zoncou = "AFF_LEVDES"
indice = 0
WCLOB = [M]AFF_LEVDES
If varmode([M]AFF_LEVDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AFF_LEVDES" : Gosub ACTION From =IMPTRT
 Endif
 If WCLOB<>[M]AFF_LEVDES or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_AFF_LEVDES([M]AFF_LEVDES) From SUBHRSCA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "AFF_LEVDES" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

## Zone LEV
mkstat = 0
zoncou = "LEV"
If varmode([M]LEV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEV" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]LEV(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_LEV([M]LEV(indice)) From SUBHRSCA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone LEVREF
mkstat = 0
zoncou = "LEVREF"
If varmode([M]LEVREF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEVREF" : Gosub ACTION From =IMPTRT
 Endif
 If [M]LEVREF(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LEVREF" : GZNUM = 1371 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_LEVREF([M]LEVREF(indice)) From SUBHRSCA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEVREF" : GZNUM = 1371 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SCA"
Return

