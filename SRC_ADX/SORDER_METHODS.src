#######################################################################################
$LOCK_UNLOCK
  # Fmethod Verrouille / déverrouille
  #Fmethod LOCK_UNLOCK(SOHNUM,PACTION,PCASE)
  #Value Char SOHNUM ()
  #Value TINYINT PACTION
  #Value Char PCASE ()
  #Local Integer ARET_VALUE
  #Gosub LOCK_UNLOCK From WMC0SORDER
  #End [L]ARET_VALUE
  # -----------------------------------------------------------------------------------
  # PACTION=1 => Lock
  # PACTION=2 => Unlock
  # PCASE="CREDIT LIMIT"
  # PCASE="MANUAL"
  # PCASE="UN-PAYMENT"
  # -----------------------------------------------------------------------------------
Local Integer  WLOG          : WLOG=[V]CST_ANO    #: WLOG=[V]CST_AYES
Local Char     WERR(255)
Local Integer  WRET

Local Char SZCREDITLIMIT(20) : SZCREDITLIMIT = "CREDITLIMIT"
Local Char SZMANUAL(20)      : SZMANUAL = "MANUAL"
Local Char SZUNPAYMENT(20)   : SZUNPAYMENT = "UN-PAYMENT"

  # ------------------------------------------------------------------------------------
  #> Diagnosis log opening
  #  ---------------------
  If WLOG = [V]CST_AYES Then
    Local Integer ALOG_RET
    Local Instance ALOG Using C_ALOG

    ALOG = NewInstance With C_ALOG
    ALOG_RET = fmet ALOG.ASETNAME("OREAD" + "_" + this.ACTX.USER + "_" + num$(adxuid(2)))
    ALOG_RET = fmet ALOG.ABEGINLOG("Order log - OREAD Operation")
  Endif
  # ------------------------------------------------------------------------------------
  # Contrôles préliminaires (tout ce qui peut être vérifié avant de déclencher la lecture de la commande)
  If PACTION <> 1 and PACTION <> 2 Then
    # Action inconnue (cas de bug programme)
    WERR = mess(1013,196,1)
    Gosub LOCK_UNLOCK_ERROR
  Endif
  If PCASE <> SZCREDITLIMIT and PCASE <> SZMANUAL and PCASE <> SZUNPAYMENT Then
    # Situation inconnue (cas de bug programme)
    WERR = "'" + PCASE + "' :" - mess(380,192,1)
    Gosub LOCK_UNLOCK_ERROR
  Endif
  If PACTION = 1 and (PCASE = SZCREDITLIMIT or PCASE = SZUNPAYMENT) Then
    # Verouillage impossibles. Elles sont déterminées par la situation
    WERR = "'" + PCASE + "' :" - mess(381,192,1)
    Gosub LOCK_UNLOCK_ERROR
  Endif
  # ------ Verrouillage manuel de la commande prévu, mais pas implémenté. Ce test sera a supprimer lorsque ça existera
  # ------ qu'on aura mis le code pour le faire.
  If PACTION = 1 and (PCASE = SZMANUAL) Then
    # Verouillage impossibles. Elles sont déterminées par la situation
    WERR = "'" + PCASE + "' :" - mess(381,192,1)
    Gosub LOCK_UNLOCK_ERROR
  Endif
  If SOHNUM = "" Then
    # Référence commande obligatoire
    WERR = mess(379,192,1)
    Gosub LOCK_UNLOCK_ERROR
  Endif
  WRET = fmet this.ACTX.APARAM.AGETUSERVALNUM("SCDTUNL")
  If WRET <> [V]CST_AYES Then
    # Utilisateur non habilité à réaliser cette action
    WERR = mess(17,137,1) - num$(WRET)
    Gosub LOCK_UNLOCK_ERROR
  Endif
  # ------------------------------------------------------------------------------------
  If ARET_VALUE <> [V]CST_AERROR Then
    # ------------------------------------------------------------------------------------
    WRET = [V]CST_AOK
    WRET = fmet this.AREAD(SOHNUM)
    If WRET <> [V]CST_AOK Then
      WERR = "[SORDER-LOCK_UNLOCK] Error this.AREAD: Key" - SOHNUM
      ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
      ARET_VALUE = [V]CST_AERROR
    Else
      # C'est là que ça se passe
      # --------------------------
      # Contôles liés à la commande
      If PACTION = 1 Then
        # Lock
        # -----------------------
        If PCASE = SZMANUAL Then
          Gosub LOCK_MANUAL
        Endif
      Else
        # Unlock
        # -----------------------
        Case PCASE
          When SZCREDITLIMIT
            Gosub UNLOCK_CREDITLIMIT
          When SZMANUAL
            Gosub UNLOCK_MANUAL
          When SZUNPAYMENT
            Gosub UNLOCK_UNPAYMENT
        Endcase
      Endif
      # ------------------------------------------------------------------------------------
      If WRET = [V]CST_AOK Then
        # ------------------------------------------------------------------------------------
        # Mise à jour de la commande
        WRET = fmet this.AUPDATE
        If WRET <> [V]CST_AOK Then
          WERR = "[SORDER-LOCK_UNLOCK] Error this.AUPDATE: Key" - this.SOHNUM
          ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
          ARET_VALUE = [V]CST_AERROR
        Endif
        If WRET = 0 Then
          Case PACTION
            When 1
              WERR = mess(332,182,1) - this.SOHNUM - ":" - mess(181,187,1)
            When 2
              WERR = mess(332,182,1) - this.SOHNUM - ":" - mess(182,187,1)
          Endcase
          ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AINFO)
          ARET_VALUE = [V]CST_AOK
        Endif
      Endif
    Endif
  Endif
  # ----------------------------------------------------------------
  #> log closing
  #  -----------
  If WLOG = [V]CST_AYES Then
    ALOG_RET = fmet ALOG.APUTINSTERRS(this)
    ALOG_RET = fmet ALOG.AENDLOG()
  Endif
Return

#######################################################################################
$LOCK_MANUAL
  # A faire
Return

#######################################################################################
$UNLOCK_MANUAL
  Local File ATABDIV [ADI]
  Local File ACCES [ACC]
  #
  Raz [F:ADI]
  If this.HLDCOD <> "" Then
    Read [ADI]CODE=204;this.HLDCOD
    If fstat Then
      WERR = mess(2,492,1) - this.HLDCOD
      WRET = 1
      Return
    Endif
  Endif
  #
  If this.HLDSTA < 2 Then
    WERR = mess(23,492,1)
    WRET = 1
    Return
  Else
    # Already on Hold - simply release with pop-up.
    If [F:ADI]A1 <> "" and this.ACTX.USRACS <> 2 and this.ACTX.USER <> this.HLDUSR Then
      # access code check
      Read [ACC]CODACC=this.ACTX.USER;[F:ADI]A1
      If fstat Then
        WERR = mess(22,492,1)
        WRET = 1
        Return
      Endif
    Endif
    #
    If this.HLDCOD <> "" Then
      this.HLDCODP = this.HLDCOD
      this.HLDUSRP = this.HLDUSR
      this.HLDDATP = this.HLDDAT
      this.HLDTIMP = this.HLDTIM
      this.HLDDAT  = date$          # to capture release date
      this.HLDTIM  = time$          # to capture release time
      this.HLDUSR  = this.ACTX.USER # to capture release user
    Endif
    Raz this.HLDCOD                 # blank
    this.HLDSTA = 1                 # OK
  Endif
Return

#######################################################################################
$UNLOCK_CREDITLIMIT
  #If this.CDTSTA <> 3 Then
  If this.SOHCAT <> 4 and this.ORDSTA = 1 and this.UNL = 1 Then
    Gosub UNLOCK_SORDER
  Else
    WERR = mess(24,492,1)
    WRET = 1
    Return
  Endif
Return

#######################################################################################
$UNLOCK_UNPAYMENT
  If this.CDTSTA <> 4 Then
    WERR = mess(25,492,1)
    WRET = 1
    Return
  Else
    Gosub UNLOCK_SORDER
  Endif
Return

#######################################################################################
$UNLOCK_SORDER
Local Decimal NOST
Local Decimal NOSTAUZ

  this.CDTSTAP = this.CDTSTA
  this.CDTSTA = 1
  this.UNL = 2
  Call SDCDTSTA(this, this.ACTX, this.CPY, "", this.BPCORD, this.CHGTYP, 0, this.CUR, this.ORDDAT, 2, 1, this.CDTSTA, NOST, NOSTAUZ) From TRTVENCDT_SYRA
Return

#**************************************************************************************
#* Error management : Information
#**************************************************************************************!
$LOCK_UNLOCK_INFO
  ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AINFO)
  ARET_VALUE = [V]CST_AINFO
Return

#**************************************************************************************
#* Error management : Warning
#**************************************************************************************!
$LOCK_UNLOCK_WARNING
  ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)
  ARET_VALUE = [V]CST_AWARNING
Return

#**************************************************************************************
#* Error management : Error
#**************************************************************************************!
$LOCK_UNLOCK_ERROR
  ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
  ARET_VALUE = [V]CST_AERROR
Return

#######################################################################################
$INIT_TSCCODADI
Local Integer DIM_STC
Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STC")
  # -------------------
  For NI = 1 To DIM_STC
    this.C_TSCCOD(NI).TSCCODADI = NI + 30
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return
