#######################################################################################
$AREAD_AFTER
Local Integer WI

  [L]ASTATUS = fmet this.INIT_TSCCODADI()
  #
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.CPYCUR = [F:CPY]ACCCUR
  Endif

  # -----------------------------------
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACBPR, DEP, PTE, SOHTYP, SDHTYP, INVCND
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SOHTYP_LEG(this, this.SOHTYP, this.CPY, this.SALFCY, this.LEG, this.SOHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SDHTYP_LEG(this, this.SDHTYP, this.CPY, this.SALFCY, this.LEG, this.SDHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEP, this.CPY, this.SALFCY, this.LEG, this.DEP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPR, this.CPY, this.SALFCY, this.LEG, this.VACBPR_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PTE_LEG(this, this.PTE, this.CPY, this.SALFCY, this.LEG, this.PTE_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_INVCND_LEG(this, this.INVCND, this.CPY, this.SALFCY, this.LEG, this.INVCND_LEG) # 107890 : Scheduled invoices
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  # -----------------------------------
  If this.BPCADD(1) = null Then
    [L]ASTATUS = fmet this.ADDLINE("BPCADD",[V]CST_AFIRSTPOS)
  Endif
  If this.BPIADD(1) = null Then
    [L]ASTATUS = fmet this.ADDLINE("BPIADD",[V]CST_AFIRSTPOS)
  Endif
  If this.BPDADD(1) = null Then
    [L]ASTATUS = fmet this.ADDLINE("BPDADD",[V]CST_AFIRSTPOS)
  Endif
  # -----------------------------------
  [L]ASTATUS = fmet this.BPCADD(1).INIT_SALADDRESS("SOHBPC", this.BPCORD, this.BPAORD, this.CNTNAM)
  [L]ASTATUS = fmet this.BPIADD(1).INIT_SALADDRESS("SOHBPI", this.BPCINV, this.BPAINV, this.CNINAM)
  [L]ASTATUS = fmet this.BPDADD(1).INIT_SALADDRESS("SOHBPD", this.BPCORD, this.BPAADD, this.CNDNAM)
  #  For WI = 1 To maxtab(this.C_INVDTAAMT)
  #      If this.C_INVDTAAMT(WI) <> null
  #          # INVCDTA = INVDTA en alpha (Pour le passage des paramètres de SHOAXX)
  #          this.C_INVDTAAMT(WI).INVCDTA = num$(this.C_INVDTAAMT(WI).INVDTA)
  #      Endif
  #  Next
 Return

