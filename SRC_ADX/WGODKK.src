#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre ODKK

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:13:30"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"ODKK",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="DKK1;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "DKK"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "KEYCODE+KEYVER"
If clalev([M:DKK1])=0 : Local Mask DKK1 [DKK1] : Endif
Gosub TIT
nolign = 1
If clalev([F:AXX])=0 : Local file ATEXTRA [AXX] : Endif
Link [DKK] With
& [AXX]AXX0="DKSKEY";"KEYDES";GLANGUE;[F:DKK]KEYCODE;num$([F:DKK]KEYVER)
& As [DKK_]
Return

$DEF_BOITE
Gosub HORODAT From WGODKK
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "ODKK" From GFONCTION At A_STAMP With A_WINDPREV Mask [DKK1]
&  Listbox [DKK_] GAU_CHE
&   [L]SAIRAP(1) = [F:DKK]KEYCODE Using "K:20X" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:AXX]TEXTE Using "K:80X" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = [F:DKK]KEYVER Using "N:4#" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = [F:DKK]STRDAT Using "" Titled TITSEL(4)
& As [DKK1]
Titled [DKK1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGODKK
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "ODKK" From GFONCTION At A_STAMP With A_WINDPREV Mask [DKK1]
& As [DKK1]
Titled [DKK1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [DKK1] 
Return

$SAISIE_BOITE
Boxinp [DKK1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [DKK1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(42798,TITLIS) From OBJDIV
Local Char TITSEL(30)(1..4)
Call TEXTE(5296,TITSEL(1)) From OBJDIV
Call TEXTE(6468,TITSEL(2)) From OBJDIV
Call TEXTE(1281,TITSEL(3)) From OBJDIV
Call TEXTE(828,TITSEL(4)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(42798,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [DKK_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [DKK1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [DKK1] GAU_CHE
 Else
  Fillbox [DKK1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [DKK_]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 2
GAUTRELIS = 1
CLELISTE = "KEYCODE;KEYVER"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [DKK_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [DKK_] Order With CLELISTE
  Setlbox [DKK1] GAU_CHE
  Filter [DKK_]
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [DKK_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [DKK_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(1) = "DKK1"         : ABMSK(1)  = "DKK1"     : AMA(1) = 1
NBMASK = 1
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 1 : If clalev([M:DKK1])>0 : Default Mask [DKK1] : Endif
Endcase
Return

$TITMASK
Case MA
 When 1 : If clalev([M:DKK1])>0 : Gosub TITRES From W1DKK1 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:DKK1])>0 : Close Local Mask [DKK1] : Endif
Return

$RAZMASK
Case MA
 When 1 : If clalev([M:DKK1])>0 : Raz [M:DKK1] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 1 : If clalev([M:DKK1])>0 : Affzo [M:DKK1] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 1 : If clalev([M:DKK1])>0 : [F:DKK] = [M:DKK1] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 1 : If clalev([M:DKK1])>0 : [M:DKK1] = [F:DKK] : Endif
Endcase
Return

$GRISE_CLE
Grizo [DKK1]KEYVER,KEYCODE
Return

$DEGRISE_CLE
Actzo [DKK1]KEYVER,KEYCODE
Return

$BOUTON
STDBOUT = "EAN09<>RHILJMP"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


