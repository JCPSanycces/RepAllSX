#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  If !clalev([F:ARM])  : Local File AREPORTM   [ARM]  : Endif
  
  Local Integer I, NUMREQ, DIFTRG, TYPSTG
  Local Char    PARAM(30), ETAT([V]GLONARP), CPY([V]GLONCPY), POP([V]GLONPOP)
  Local Char    CATTRGDEB, CATTRGFIN, CPYTRGDEB, CPYTRGFIN, FCYTRGDEB, FCYTRGFIN, JOTTRGDEB, JOTTRGFIN
  Local Char    POTTRGDEB, POTTRGFIN, POPTRGDEB, POPTRGFIN, HABTRGDEB, HABTRGFIN
  Local Char    CRITERE(250)
  Local Date    DATFIN, DATDEB
  
  Call GETPARAM("__REQUETE",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  [L]NUMREQ=val([L]PARAM)
  Call SETPARAM("numedt",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  
  Call GETPARAM("X3ETA",[L]NBPAR,[L]PARAMETRE,[L]ETAT) From ETAT
  
  [L]PARAM=[M:SBF1]YEAPLF : Call SETPARAM("yeaplf",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  [L]PARAM=[M:SBF1]CPYPLF : Call SETPARAM("cpy",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  [L]PARAM=[M:SBF1]FCYPLF : Call SETPARAM("fcy",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  [L]PARAM=num$([M:SBF1]MONREA) : Call SETPARAM("monrea",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  [L]PARAM=num$([M:SBF1]CRIDSY) : Call SETPARAM("cridsy",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  
  Call DEBTRANS From GLOCK
  $TR_EDIT
  [V]GOK=1
  Trbegin [ARM]
  Delete [F:ARM] Where USR=[V]GUSER & RPTCOD=[L]ETAT
  Gosub EDIT
  If [V]GOK=-1 Then
    Rollback
    Call ROLL From GLOCK
    If [V]GROLL : End : Else Goto TR_EDIT : Endif
  Elsif ![V]GOK Then
    Rollback
    End
  Endif
  Commit
End

$EDIT
Local Integer OK_TRG, IND
If dim(GTRG)<0 Then Global Char GTRG(5)(1..50) : Endif 

  Raz [F:ARM]
  [F:ARM]NUMREQ=[L]NUMREQ
  [F:ARM]USR   =[V]GUSER
  [F:ARM]RPTCOD=[L]ETAT
  [F:ARM]CREDAT=date$

  For nolign=1 To [M:SBF2]NBLIG
    If [M:SBF2]NUMCRID(nolign-1)<>"" Then
      [F:ARM]SEQREQ = 1
      If [M:SBF1]CRIDSY<>5 Then
        [F:ARM]CLEA1  = [M:SBF2]NUMCRID(nolign-1)
      Else
        [F:ARM]CLEA1  = [M:SBF2]CRIDSYA(nolign-1)
      Endif
      [F:ARM]CLEMD1 = [M:SBF2]AMTBUDREF(nolign-1)
      [F:ARM]CLEMD2 = [M:SBF2]AMTREA(nolign-1)
      [F:ARM]NUMLIG+=1
      Write [ARM]
      If fstat
        [V]GOK=0
        Call FSTA("ARM") From GLOCK
        Break
      Endif
    Else
      Break
    Endif
  Next

  For nolign=1 To [M:SBF3]NBLIG
    If [M:SBF3]NUMCRID(nolign-1)<>"" Then
      [F:ARM]SEQREQ = 2
      If [M:SBF1]CRIDSY<>5 Then
        [F:ARM]CLEA1  = [M:SBF3]NUMCRID(nolign-1)
      Else
        [F:ARM]CLEA1  = [M:SBF3]CRIDSYA(nolign-1)
      Endif
      [F:ARM]CLEMD1 = [M:SBF3]AMTBUDREF(nolign-1)
      [F:ARM]CLEMD2 = [M:SBF3]AMTREA(nolign-1)
      [F:ARM]NUMLIG+=1
      Write [ARM]
      If fstat
        [V]GOK=0
        Call FSTA("ARM") From GLOCK
        Break
      Endif
    Else
      Break
    Endif
  Next
Return

