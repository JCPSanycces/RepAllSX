#<AdxTL>@(#)5.0.0.0 $Revision$
 If (GADONIX=2 | (GADONIX<>2 & GDEBUG))
  Raz GPILOBJ
  Call OBJET("CDG",GBIDC1,GBIDC2) From GOBJET
 Else
  Infbox "GESCDG :"-mess(1,123,1)+"."-mess(460,9900,1)
 Endif

End
###################################################################
$ACTION
 Case ACTION
  When "OUVRE"  : Gosub OUVRE
  When "LIENS0" : Gosub LIENS0
  When "LIENS2" : Gosub LIENS2
  When "FERME"  : Gosub FERME
  When "SEL_LISTE"
    Case LISTE
      When "SELBRKPT"  : Gosub SELBRKPT
    Endcase
  When default
 Endcase
Return

#-------------------------------------------------------------------
$OUVRE
 Gosub DEF_BRKPTLST From GCALDEBUG
Return

#-------------------------------------------------------------------
$LIENS0
Return

#-------------------------------------------------------------------
$LIENS2
 Sorta [M:CDG0]NBBKPT [M:CDG0]NBBKPT Order By [M:CDG0]BRKNORD([S]indice) 
Return

#-------------------------------------------------------------------
$FERME
 Gosub $KILL_BRKPTLIST From GCALDEBUG
Return

#-------------------------------------------------------------------
$SELBRKPT
 Local Integer I_BRKPT
 NBTEX=0  
 For I_BRKPT=1 To dim(GLSTBRKPNT)
  If !find(GLSTBRKPNT(I_BRKPT),[M]BRKPTNAM)
   NBTEX       += 1
   TEX(NBTEX)   = GLSTBRKPNT(I_BRKPT)
   TEXTE(NBTEX) = num$(GLSTBRKNUM(I_BRKPT))-GLSTBRKPNT(I_BRKPT)-GLSTBRKDES(I_BRKPT)
  Endif
 Next I_BRKPT
Return

######################################################################################
## GESTION DU MASQUE CDG
######################################################################################
Subprog C_BRKPTNAM(VALEUR)
Variable Char    VALEUR()
 #> Contrôle unicité
 Local Integer I_OCC, I_PT
 I_OCC = find(VALEUR,[M]BRKPTNAM)
 If I_OCC>0 & I_OCC<>nolign 
  GERR=1 : GMESSAGE = "Code déjà existant en ligne"-num$(I_OCC)
  mkstat=2
 Else
  I_PT  = find(VALEUR,GLSTBRKPNT)
  If I_PT=0
   GERR=1 : GMESSAGE = "Point d'entrée inexistant"
   mkstat=2   
  Else
   [M:CDG0]BRKNORD(nolign-1) = GLSTBRKNUM(I_PT) : Affzo [M:CDG0]BRKNORD(nolign-1)
   [M:CDG0]BRKPTTRT(nolign-1)= GLSTBRKTRT(I_PT) : Affzo [M:CDG0]BRKPTTRT(nolign-1)
   [M:CDG0]BRKPTDES(nolign-1)= GLSTBRKDES(I_PT) : Affzo [M:CDG0]BRKPTDES(nolign-1)
  Endif
 Endif
End

#=====================================================================================
Subprog AS_BRKPTPLN(VALEUR)
Variable Integer VALEUR
 Local Integer I
 For I=1 To [M]NBBKPT
  If I<>nolign
   If [M]BRKPTFLG(I-1)=G_OUI
    GBOUT(2)=""
   Else
    GBOUT(1)=""
   Endif
   Break
  Else
   If VALEUR=G_OUI
    GBOUT(2)=""
   Else
    GBOUT(1)=""
   Endif
   Break
  Endif
 Next I
End

#=====================================================================================
# Tous sélectionner
#=====================================================================================
Subprog B1_BRKPTPLN(VALEUR)
Variable Integer VALEUR
 Local Integer I
 For I=nolign To [M:CDG0]NBBKPT
  [M:CDG0]BRKPTPLN(I-1)=VALEUR
 Next I
 Affzo [M:CDG0]
End

#=====================================================================================
# Appliquer à tous
#=====================================================================================
Subprog B1_BRKPTFLG(VALEUR)
Variable Integer VALEUR
 Local Integer I
 For I=nolign To [M:CDG0]NBBKPT
  [M:CDG0]BRKPTFLG(I-1)=VALEUR
 Next I
 Affzo [M:CDG0]
End




