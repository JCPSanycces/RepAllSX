#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour champ FLIBAN
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour champ FLIBAN") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub IBAN
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub IBAN
End

#-------------------#
$IBAN

Local File =DOSSIER+".TABCOUNTRY" [TCY] 

If dim([F:TCY]FLIBAN)<0
 Close Local File [TCY]
 Return 
Endif

# Mise à jour de la table TABCOUNTRY
Call ECR_TRACE(mess(81,125,1)-"TABCOUNTRY:"-time$,0) From GESECRAN
Trbegin [TCY]
 For [TCY]TCY0
  If [F:TCY]FLIBAN=0
   [F:TCY]FLIBAN = 1
   Rewrite [TCY]
  Endif
 Next
Commit

Close Local File [TCY]

Return
