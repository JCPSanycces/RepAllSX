#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# Traitement liée à la fenêtre de répartition d'une semaine en jours    #
#########################################################################
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
Endcase

Return

#########################################################################
# Actions sur la fenêtre de saisie                                      #
#########################################################################
$DEBUT
# Action SAIREPART / Fenêtre IREPARTI
If GACTION = "SAIREPART"
   [M]XLU = [M:SOI1]DSPPRC(0)
   [M]XMA = [M:SOI1]DSPPRC(1)
   [M]XME = [M:SOI1]DSPPRC(2)
   [M]XJE = [M:SOI1]DSPPRC(3)
   [M]XVE = [M:SOI1]DSPPRC(4)
   [M]XSA = [M:SOI1]DSPPRC(5)
   [M]XDI = [M:SOI1]DSPPRC(6)
   Affzo [M:RPTI]
Endif
Return

$OK
# Action SAIREPART / Fenêtre IREPARTI
If GACTION = "SAIREPART"
   [M:SOI1]DSPPRC(0) = [M]XLU
   [M:SOI1]DSPPRC(1) = [M]XMA
   [M:SOI1]DSPPRC(2) = [M]XME
   [M:SOI1]DSPPRC(3) = [M]XJE
   [M:SOI1]DSPPRC(4) = [M]XVE
   [M:SOI1]DSPPRC(5) = [M]XSA
   [M:SOI1]DSPPRC(6) = [M]XDI
   mkstat = 4  
   FIN=1
Endif
Return

