#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INICRE"   Gosub INICRE
 When "INIMOD"   Gosub INICRE
 When "ANNULE"   Gosub ANNULE
 When "CHANGE" : Call CHANGE_AXX ("TABREOPOL", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return
 
$INICRE
    Call MAJTEXTRA([M:TRP1]TRPAXX,"TABREOPOL","TRPAXX",[M:TRP1]REOPOL,"") From ATEXTRA
    Call MAJTEXTRA([M:TRP1]TRPSHOAXX,"TABREOPOL","TRPSHOAXX",[M:TRP1]REOPOL,"") From ATEXTRA
Return

$ANNULE
    Delete [AXX] Where CODFIC="TABREOPOL" & ZONE="TRPAXX" & CLE1= [M:TRP1]REOPOL
    Delete [AXX] Where CODFIC="TABREOPOL" & ZONE="TRPSHOAXX" & CLE1= [M:TRP1]REOPOL
Return
