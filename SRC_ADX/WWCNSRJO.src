#<AdxTL>@(#)%I%
# Supervisor
# Inquiry RJO

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:17"
A_USER  = "ADMIN"
A_STAMP = "20181109081117"
Return

$DEFAUT
Default File [POT]
Return

$OUVFIC
Local File POSTE [POT]
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1003226,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSRJOSTD"
PROGSPE    = "SPECNSRJO"
BOITE      = "FCNSRJO"
NOMMSK(0)  = "CONSRJO1"
ABMSK(0)   = "RJO1"
NOMMSK(1)  = "CONSRJO2"
ABMSK(1)   = "RJO2"
NOMFIC     = "POSTE"
ABFIC      = "POT"
OBJDERLU   = "POT"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "POT0"
NBCMP = 1
CLECMP(0) = "COD"
CLEMSK(0) = "JOBPOTE"
Return

$OUVRE
If clalev([F:POT])=0 : Local File POSTE        [POT] : Endif
If clalev([F:POT])=0 : Local File POSTE        [POT] : Endif
Return

$OUVRE_MSK
Case MA
 When  0 : Local Mask =NOMMSK(0) [RJO1]
 When  1 : Local Mask =NOMMSK(1) [RJO2]
Endcase
Return

$GRISE_MSK
Case MA
 When  0 : Grizo [RJO1]
 When  1 : Grizo [RJO2]
Endcase
Return

$GRISE_CLE
Case MA
 When  0 : If dim([M:RJO1]JOBPOTE)>0 : Grizo [RJO1]JOBPOTE : Endif
Endcase
Return

$GRISE_CRIT
Return

$FERME_MSK
Case MA
 When  0 : If clalev([M:RJO1])>0 : Close Local Mask [RJO1] : Endif
 When  1 : If clalev([M:RJO2])>0 : Close Local Mask [RJO2] : Endif
Endcase
Return

$SETMASK
Case MA
 When  0 : Default Mask [RJO1]
 When  1 : Default Mask [RJO2]
Endcase
Return

$RAZMASK
Case MA
 When  0 : Raz [M:RJO1]
 When  1 : Raz [M:RJO2]
Endcase
Return

$CRITENT
Return

$ENTCRIT
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSRJO2"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "RJO"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "RJO"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT3<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT3
 VALBOUT(NBBOUT) = "RJO"
 VALBOUT(NBBOUT) += "~B3"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]JOBPOT(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("JOT","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT4<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT4
 VALBOUT(NBBOUT) = "RJO"
 VALBOUT(NBBOUT) += "~B4"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]COD(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("POT","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT7<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT7
 VALBOUT(NBBOUT) = "RJO"
 VALBOUT(NBBOUT) += "~B7"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]UOMGRP(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]JOBGRP(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M]JOBPOT(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([M]LEV(nolign-1)),"~","¨")
 Onerrgo
Endif
If GBOUT10<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT10
 VALBOUT(NBBOUT) = "RJO"
 VALBOUT(NBBOUT) += "~B10"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]LEV(nolign-1),"~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[M]LEV(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CONSRJO2"
 When "B2"
  Onerrgo RIEN
  Assign "[M]LEV(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B2_NBLIG From ="W1CONSRJO2"
 When "B3"
  Onerrgo RIEN
  Assign "[M]JOBPOT(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B3_NBLIG From ="W1CONSRJO2"
 When "B4"
  Onerrgo RIEN
  Assign "[M]COD(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B4_NBLIG From ="W1CONSRJO2"
 When "B7"
  Onerrgo RIEN
  Assign "[M]UOMGRP(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "[M]JOBGRP(nolign-1)" With ctrans(func AFNC.PART(INFO,4),"¨","~")
  Assign "[M]JOBPOT(nolign-1)" With ctrans(func AFNC.PART(INFO,6),"¨","~")
  Assign "[M]LEV(nolign-1)" With val(ctrans(func AFNC.PART(INFO,7),"¨","~"))
  Onerrgo
  Call B7_NBLIG From ="W1CONSRJO2"
 When "B10"
  Onerrgo RIEN
  Assign "[M]LEV(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B10_NBLIG From ="W1CONSRJO2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


