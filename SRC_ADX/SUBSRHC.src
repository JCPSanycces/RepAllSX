#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
# SUBSRHC : GESTION DES RETOURS                                         #
#-----------------------------------------------------------------------#
# Mars 2004                                                      LD     #
#########################################################################
#########################################################################
# TRAITEMENTS LIES AUX PICKINGS                                         #
#########################################################################
#########################################################################
# Actions de l'objet                                                    #
#########################################################################
#########################################################################
# TRAITEMENTS LIES AU PICKING                                           #
#########################################################################
#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
$HINT_KEY
#-----------------------------------------------------------#
# Clé pour optimisation du remplissage des listes de gauche #
#-----------------------------------------------------------#
Case currbox
 When GBOXSD2  : HINTLIS(val(right$(GBOXSD2,8)))="SDD3"
 When GBOXSD5  : HINTLIS(val(right$(GBOXSD5,8)))="SDD3"     # X3-1152 : Non invoiceable deliveries
 When GBOXPN1  : HINTLIS(val(right$(GBOXPN1,8)))="PND2"
 When Default  : Return
Endcase
Return
#########################################################################
$TIROIR

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$REMP_DERLU

# Pas de dernier lu
If GFONC1 <> "GESSRH"
   adxmxl=0
Endif
Return

#########################################################################
$FILGAUCHE

If GFONC1 <> "GESSRH"
   If ILIS=0 adxmxl=0 Endif
Endif

Case currbox
 When GBOXSD2 : Gosub FILGAUCHE1
 When GBOXSD5 : Gosub FILGAUCHE1    # X3-1152 : Non invoiceable deliveries
 When GBOXPN1 : Gosub FILGAUCHE2
 When Default : Return
Endcase

Return
#########################################################################
$FILGAUCHE1
#-----------------------------------------------------------------------#
# Filtre des enregistrements pour picking des livraisons                #
#-----------------------------------------------------------------------#

#If !find(currbox,GBOXSD2) Return Endif
# X3-1152 : Non invoiceable deliveries
If !find(currbox,GBOXSD2,GBOXSD5) Return Endif
# X3-1152 : Non invoiceable deliveries

#-----------------------------------------------------------------------------------------#
# On désactive le picking si pas en cours de traitement et aucun enregistrement
#                         ou si on a déjà pické une ligne de retour fournisseur
#-----------------------------------------------------------------------------------------#
If (GREP="" & !CLECUR) | sum([M:SRH1]PNHNUM)<>""
   FILGAUSUP(0)='[F:SDD]BPCORD=""&[F:SDD]BPAADD=""&[F:SDD]ITMREF=""'
   FILGAUSUP(1)=""
   Return
Endif

#-----------------------------------------------------------------------------------------#
# Pour optimiser, on filtre sur le client même si celui-ci n'est pas renseigné
# --> on ne pourra picker un retour que lorsque le client aura été saisi
##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON = "BPCORD"
##   FILGAUSUP(0) ='[F:SDD]BPCORD=CZ'
##Else
##   FILGAUSUP(0) ='[F:SDD]BPCORD=[M:SRH0]BPCORD'
##Endif
#-----------------------------------------------------------------------------------------#
FILGAUSUP(0) ='[F:SDD]BPCORD=[M:SRH0]BPCORD'

#-----------------------------------------------------------------------------------------#
# Pb : Bien que COUZON="BPAADD" CZ contient toujours la valeur du dernier champs saisi
#      BPAADD est chargé directement à partir du client, s'il n'est pas modifié CZ=[M:SRH0]BPCORD
#      CZ n'est bon que si on saisit BPAADD
#If COUZON = "BPAADD"
#   If CZ <> ""              FILGAUSUP(0)+='&[F:SDD]BPAADD=CZ'                Endif
#Else
#   If [M:SRH0]BPAADD <> ""  FILGAUSUP(0)+='&[F:SDD]BPAADD=[M:SRH0]BPAADD'    Endif
#Endif
#-----------------------------------------------------------------------------------------#
If [M:SRH0]BPAADD <> ""  FILGAUSUP(0)+='&[F:SDD]BPAADD=[M:SRH0]BPAADD'    Endif

# FGR 17/01/2014 : X3SUIVI94428 : [F:FCY]LEGCPY n'est pas toujours là
#- X3Suivi 70687 : Liste gauche livraisons avec société incompatible --#
#If [M:SRH0]STOFCY <> ""  : FILGAUSUP(0)+='&[F:SDD]CPY=[F:FCY]LEGCPY'      : Endif
If [M:SRH0]STOFCY <> ""  : FILGAUSUP(0)+='&[F:SDD]CPY=GSOCIETE'      : Endif

#-----------------------------------------------------------------------------------------#
#If COUZON = "ITMREFSEL"
#   If CZ <> ""              FILGAUSUP(0)+='&[F:SDD]ITMREF=CZ'                Endif
#Else
#   If [M:SRH1]ITMREFSEL<>"" FILGAUSUP(0)+='&[F:SDD]ITMREF=[M:SRH1]ITMREFSEL' Endif
#Endif
#-----------------------------------------------------------------------------------------#

# Les livraisons doivent être validées et pas des prêts et pas sous-traitance
FILGAUSUP(1) ='&[F:SDH]CFMFLG=2 & [F:SDH]LND<>2 & [F:SDH]SCO<>2'
# Les livraisons inter-site ne doivent pas être receptionnées
FILGAUSUP(1)+='& [F:SDD]RCPFLG<>2'

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SRH0]CRIITMREF<>""      FILGAUSUP(1)+=' & [F:SDD]ITMREF =[M:SRH0]CRIITMREF' Endif
If [M:SRH0]CRISDHNUM<>""      FILGAUSUP(1)+=' & [F:SDH]SDHNUM =[M:SRH0]CRISDHNUM' Endif
If [M:SRH0]CRIDLVDAT<>[0/0/0] FILGAUSUP(1)+=' & [F:SDH]DLVDAT>=[M:SRH0]CRIDLVDAT' Endif

#FILGAUSUP(1)+='&[F:SDD]QTY>[F:SDD]RTNQTY'

FILGAUSUP(1)+='&[F:SDD]QTYSTU>([F:SDD]RTNQTYSTU+[F:SDD]RCPQTYSTU)'

#If COUZON = "DATSEL"
#   If val(CZ) <> 0            FILGAUSUP(1)+='&val([F:SDH]DLVDAT)>=val(CZ)'   Endif
#Else
#   If [M:SRH1]DATSEL<>[0/0/0] FILGAUSUP(1)+='&[F:SDH]DLVDAT>=[M:SRH1]DATSEL' Endif
#Endif

If [M:SRH1]BPCINV <> ""       FILGAUSUP(3)+='&[F:SDH]BPCINV=[M:SRH1]BPCINV'  Endif
If [M:SRH0]SALFCY <> ""       FILGAUSUP(3)+='&[F:SDH]SALFCY=[M:SRH0]SALFCY'  Endif

# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SDH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(2)= "& " + GBIDC3 : Endif
#Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SDH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
  If GPJTSNGDOC = G_OUI Then
    FILGAUSUP(3)+='& [F:SDH]PJT=[M]PJT'
  Endif
Endif
#--/CPO
#--CPO 75115 Nouveaux champs SRHTYP et SRHCAT
If  [M]SRHCAT>0 & [M]SRHCAT<4
  # X3-1152 : Non invoiceable deliveries
  #    FILGAUSUP(3)+='& [F:SDH]SDHCAT=[M]SRHCAT'
  If currbox=GBOXSD2
    FILGAUSUP(3)+='& [F:SDH]SDHCAT=[M]SRHCAT'
  Else
    FILGAUSUP(3)+='& [F:SDH]SDHCAT=4'
  Endif
  # X3-1152 : Non invoiceable deliveries
Endif
#--/CPO

Return

#########################################################################
#-----------------------------------------------------------------------#
# Filtre des enregistrements pour picking des retours fsseurs           #
#-----------------------------------------------------------------------#
$FILGAUCHE2

If !find(currbox,GBOXPN1) Return Endif

# On désactive le picking si pas en cours de traitement et aucun enregistrement
#                         ou si on est pas inter-site ou si on a pas de site de réception
#                         ou si on a déjà pické une ligne de livraison
If (GREP="" & !CLECUR) | [M:SRH1]BETFCY<>2 | [M:SRH0]PNHFCY="" | (sum([M:SRH1]DETSDHNUM)<>"" & sum([M:SRH1]PNHNUM)="")
   FILGAUSUP(0)='[F:PND]BPSNUM=""&[F:PND]ITMREF=""'
   FILGAUSUP(1)=""
   Return
Endif

FILGAUSUP(0)='[F:PND]PNHFCY=[M:SRH0]PNHFCY'

#If COUZON = "ITMREFSEL"
#   If CZ <> ""              FILGAUSUP(0)+='&[F:PND]ITMREF=CZ'                Endif
#Else
#   If [M:SRH1]ITMREFSEL<>"" FILGAUSUP(0)+='&[F:PND]ITMREF=[M:SRH1]ITMREFSEL' Endif
#Endif
# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SRH0]CRIITMREF<>""      FILGAUSUP(0)+=' & [F:PND]ITMREF =[M:SRH0]CRIITMREF' Endif
If [M:SRH0]CRIPNHNUM<>""      FILGAUSUP(0)+=' & [F:PNH]PNHNUM =[M:SRH0]CRIPNHNUM' Endif
If [M:SRH0]CRIRTNDAT<>[0/0/0] FILGAUSUP(0)+=' & [F:PNH]RTNDAT>=[M:SRH0]CRIRTNDAT' Endif

# Les retours fournisseurs doivent être inter-sites et validés
FILGAUSUP(1) ='&[F:PNH]BETFCY=2 & [F:PNH]CFMFLG=2'

# Les lignes de retours fournisseurs ne doivent pas être déjà retournées
FILGAUSUP(1)+='&[F:PND]QTYSTU >[F:PND]SRDQTYSTU'

# Les lignes de retours fournisseurs doivent être issues d'un flux automatique
# Bug 55748
# Les lignes de retours fournisseurs peuvent être issues d'un flux manuel ssi il s'agit d'un retour direct
# (Sinon il faut picker la liv)
FILGAUSUP(1)+='&([F:PND]LINAUTFLG<>1 | [F:PND]PTHNUM="")'

#If [M:SRH0]SALFCY <> ""       FILGAUSUP(1)+='&[F:SDH]SALFCY=[M:SRH0]SALFCY'  Endif
# Un retour concerne un seul site de vente donc un seul fournisseur
If [M:SRH0]BPSNUM <> ""       FILGAUSUP(3)+='&[F:PNH]BPSNUM=[M:SRH0]BPSNUM' Endif

#les lignes de retour fournisseur ne doivent pas être de catégorie "pour sous-traitance"
FILGAUSUP(3)+='&[F:PND]LINCAT = 1'


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("PNH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(2)= "& " + GBIDC3 : Endif
# Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"PNH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


Return

#########################################################################
$AP_FILGAUCHE
Case currbox
 When GBOXSD2,GBOXPN1 : WPICK=2 : Gosub RAFFRAICHI
 When GBOXSD5         : WPICK=2 : Gosub RAFFRAICHI : # X3-1152 : Non invoiceable deliveries
 When Default
Endcase
Return
#########################################################################
$DEB_PICK
Local Integer I, J, NOL
Local Char    SYMBOLE2(50)
Return
#########################################################################
$PICKE

If REP=""
   If !CLECUR | !VERROU | !ACTMOD | GCONSULT OK=0
      Return
   Endif
Endif

Case currbox
 When GBOXSD2 : Gosub SEL1
 When GBOXSD5 : Gosub SEL1      : # X3-1152 : Non invoiceable deliveries
 When GBOXPN1 : Gosub SEL2
 When Default
Endcase
Return
#########################################################################
$DEPICK
Case currbox
 When GBOXSD2 : Gosub DESEL1
 When GBOXSD5 : Gosub DESEL1    : # X3-1152 : Non invoiceable deliveries
 When GBOXPN1 : Gosub DESEL2
 When Default
Endcase
Return
#########################################################################
$FIN_PICK

#--CPO 71065 Code affaire
Call PJT_INFO_MSG From TRTPJT

If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

#    If dim(I)<0 Local Shortint I : Endif
#    Local Integer WRET
#    For I=0 To [M:SRH1]NBLIG-1
#        If [M:SRH1]STOMGTCOD(I)>1 & [M:SRH1]WSTOFLG(I)=0
#            If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=6;GFLAG
#                                    If fstat Raz [F:SLT] Endif
#                                    Endif
#            # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
#            Call STJSTOENTW("SRH1",12,13,[M:SRH1]DETRTNDAT(I),I,[M:SRH1]NBLIG,"SLT",0,WRET) From STKENT
#            If WRET=1 | WRET=2
#                # Aucun mvt n'a pu être récupéré : La ligne peut être créée mais il n'y a aucun préchargement
#                Call MESSAGE(mess(152,191,1)) From GESECRAN
#
#                # Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
#                Dela I,1,[M:SRH1]NBLIG-1 [M:SRH1]NBLIG : [M:SRH1]NBLIG-=1
#                If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV  Endif
#                GERR=1 : OK=0 : Return
#            Elsif WRET=2
#                # Aucun mvt n'a pu être récupéré : La ligne peut être créée mais il n'y a aucun préchargement
#                Call MESSAGE(mess(152,191,1)) From GESECRAN
#            Endif
#        Endif
#    Next I


Case currbox
    When GBOXSD2,GBOXSD5 , GBOXPN1 :    # X3-1152 : Non invoiceable deliveries
#    When GBOXSD2, GBOXPN1 :            # X3-1152 : Non invoiceable deliveries
        Affzo [M:SRH0]1-99 : Affzo [M:SRH1]1-99 : Affzo [M:SRH2]1-99
        Gosub ATT_ECRAN
        zonsui = "[M:SRH1]NBLIG("+num$(NOL)+")"
    When Default
Endcase

Return
#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$ATT_ECRAN
If [M:SRH1]NBLIG = 0
   Actzo [M:SRH0]STOFCY, BPCORD, BPAADD
   Actzo [M:SRH0]SRHTYP                   :#--CPO 75115
   Actzo [M:SRH2]AUZUSR
Else
   Diszo [M:SRH0]STOFCY, BPCORD, BPAADD
   Diszo [M:SRH0]SRHTYP                   :#--CPO 75115
   Diszo [M:SRH2]AUZUSR
Endif
#If sum([M]PNDLIN)<>0
#    Grizo [M:SRH1]DATSEL
#Else
#    Actzo [M:SRH1]DATSEL
#Endif
Return

#########################################################################
$REMPBOX

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB

Return

#########################################################################
$SEL1
#-----------------------------------------------------------------------#
# Sélection d'une ligne de livraison à retourner                        #
#-----------------------------------------------------------------------#

Local Decimal WQTYSAU, LQTYSTU, WTOTEXTQTYSTU
Local Char SECTION (GLONCDE)
Local Char WSVG_STOFCY(GLONFCY) : # Bug 64852
Local Char WSVG_ENTCOD(GLONGAU) : # Bug 67050
#--- Bug 78668
Local Char WWRH(GLONWRH)
Local Char SWPJTMSG(250)        : # 71065 : PJT

Read [SDD]SDD0=[F:SDD]SDHNUM;[F:SDD]SDDLIN
If fstat
   Call RSTA("RSTA",[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK : OK=0 : Return
Endif
# Vérif. si la ligne n'a pas été retournée depuis le dernier raffraichissement de la liste de picking
If [F:SDD]QTY <= [F:SDD]RTNQTY
    GMESSAGE = [F:SDD]SDHNUM-":"-mess(27,159,1)-[F:SDD]ITMREF-":"-mess(251,192,1) : OK=0 : Return
Endif
# Vérif. si la ligne n'a pas fait l'objet de retour dt la qté retour prévue n'est pas retournée
Gosub CTL_EXTQTY
If WTOTEXTQTYSTU<>[F:SDD]RTNQTYSTU
    GMESSAGE=[F:SDD]SDHNUM-":"-mess(27,159,1)-[F:SDD]ITMREF-"\"-mess(164,191,1)-":"
    GMESSAGE-=[F:SRD]SRHNUM-num$([F:SRD]SRDLIN)-"\"-mess(602,197,1)-format$("N:15F",[F:SRD]EXTQTY)
    GMESSAGE-=mess(603,197,1)-format$("N:15F",[F:SRD]QTY)-[F:SRD]SAU
    Local Integer WOK
    Call AVERTIR(GMESSAGE, WOK) From GESECRAN : Raz GMESSAGE : If WOK=1 OK=0 : Return : Endif
Endif
Read [SDH]SDH0=[F:SDD]SDHNUM
If fstat Call RSTA("RSTA",[F:SDD]SDHNUM) From GLOCK : OK=0 : Return : Endif

# Date de expédition > date de retour
If [F:SDH]SHIDAT > [M]ENTRTNDAT    : # ACA - 48197 - date liv->date expé
   GMESSAGE = mess(328,192,1) : OK=0 : Return
Endif

# Si 1ère ligne, alimentation des zones d'entête
If [M]NBLIG = 0
   Read [FCY]FCY0=[F:SDH]SALFCY
   #- X3Suivi 70687 : Liste gauche livraisons avec société incompatible --#
   #If [F:FCY]LEGCPY <> GSOCIETE
   #   GERR=1 : GMESSAGE=[F:SDH]SDHNUM+"\"+mess(2,194,1) : OK=0   : Return
   #Endif

   # Bug 64852 : Sauvegarde du site de réception qui ne doit pas être écrasé avec le site d'expé. de la livraison
   WSVG_STOFCY=[M:SRH0]STOFCY
   WSVG_ENTCOD=[M:SRH0]ENTCOD
   WSLTTRSCOD =[M:SRH0]TRSCOD : # Bug 80677
   [M:SRH0]=[F:SDH]
   [M:SRH0]STOFCY=WSVG_STOFCY : # Bug 64852
   [M:SRH0]ENTCOD=WSVG_ENTCOD : # Bug 67050
   [M:SRH0]TRSCOD=WSLTTRSCOD  : # Bug 80677
   [M:SRH1]BPCINV = [F:SDH]BPCINV
   Call GLOBVAR([M:SRH0]SALFCY,"VEN") From TRTX3

   #--CPO 71065 Code affaire sur les retours
   #--Pour ce qui est du PJT de l'en-tête
   [M:SRH2]PJT=[F:SDH]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:SDH]PJT, "[M:SRH2]PJT",SWPJTMSG) = G_NON Then
     Raz [M:SRH2]PJT
     Call PJT_ADD_MSG([F:SDH]PJT,SWPJTMSG) From TRTPJT
   Endif
   #--Contôle du PJT de la première ligne pickée
   #--Selon mail CH : ne pas contrôler
   #--/CPO

#  [M]BPCORD = [F:SDH]BPCORD
#   [M]BPAADD = [F:SDH]BPAADD
#   [M]SALFCY = [F:SDH]SALFCY
#   If dim([M]EECLOC)>0
#       [M]EECLOC = [F:SDH]EECLOC
#       [M]EECTRN = [F:SDH]EECTRN
#   Endif
#   [M]EECICT = [F:SDH]EECICT

   # --- adresse livraison
   [M:ADB2]ADBBPR       = [F:SDH]BPCORD
   [M:ADB2]BPRNAM(0)    = [F:SDH]BPDNAM(0)
   [M:ADB2]BPRNAM(1)    = [F:SDH]BPDNAM(1)
   [M:ADB2]BPAADDLIG(0) = [F:SDH]BPDADDLIG(0)
   [M:ADB2]BPAADDLIG(1) = [F:SDH]BPDADDLIG(1)
   [M:ADB2]BPAADDLIG(2) = [F:SDH]BPDADDLIG(2)
   [M:ADB2]POSCOD       = [F:SDH]BPDPOSCOD
   [M:ADB2]CTY          = [F:SDH]BPDCTY
   [M:ADB2]SAT          = [F:SDH]BPDSAT
   [M:ADB2]CRY          = [F:SDH]BPDCRY
   [M:ADB2]CRYNAM       = [F:SDH]BPDCRYNAM
   [M:ADB2]CNTNAM       = [F:SDH]CNDNAM
   If [M:ADB2]BPRNAM <> "" |  [M:ADB2]BPAADDLIG <> "" |
&      [M:ADB2]POSCOD <> "" |  [M:ADB2]CTY <> "" |
&      [M:ADB2]SAT    <> "" |
&      [M:ADB2]CRY    <> "" |  [M:ADB2]CRYNAM <> ""
        [M:ADB2]ADBFLG = 3
   Else
        [M:ADB2]ADBFLG = 0
   Endif
   # Chargement des sections analytiques entête du retour à partir de l'entête de la livraison
   Call CHARG_CCEH("SRH2","NBAXE","SDH") From TRTX3CPT
    # On complète les sections vides
    If dim([M:SRH2]NBAXE)>0
      [M:SRH2]NBAXE=GNBDIE
      For I=1 To GNBDIE
        If [M:SRH2]CCE(I-1)=""
          [M:SRH2]DIE(I-1)=GDIE(I)
          Call INISEC(SECTION,"SRH",GDIE(I)) From SUBCDE
          [M:SRH2]CCE(I-1)=SECTION
        Endif
      Next I
    Endif
  # Point d'entrée pour alimenter l'écran entête retour en picking livraison
  GPOINT="ALISDHSRH" : Gosub ENTREE From EXEFNC
Else
  # On contrôle si on peut modifier le retour
    Gosub AVANT_MOD From SUBSRHA : If GERR=1 Return : Endif
  # Contrôle des conditions des regroupement
   Gosub CTL_LIV
   If OK=0 Return Endif
   If [M]BPCINV = "" [M]BPCINV = [F:SDH]BPCINV Endif
   If [M]SALFCY = ""
       [M]SALFCY = [F:SDH]SALFCY
       Call GLOBVAR([M:SRH0]SALFCY,"VEN") From TRTX3
   Endif
Endif
# --> Commande inter-site : Avertissement si le client est aussi le site de vente (correspond au fsseur)
If [M:SRH1]BETFCY=2
    # Recherche si le tiers est inter-site
    If [F:BPR]BPRNUM<>[M:SRH0]BPCORD
        Read [BPR]BPR0 = [M:SRH0]BPCORD
        If fstat Raz [F:BPR] Endif
    Endif
    If [F:BPR]FCY=[M:SRH0]SALFCY
        Local Integer WOK : WOK=1
        Call AVERTIR (mess(151,191,1), WOK)From GESECRAN
        If WOK=1  GERR=1 : OK=0 : Return : Endif
    Endif
Endif
# Contrôle de l'insertion
If [M]NBLIG+1 >= dim([M]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SDH]SDHNUM-":"-mess(10,100,1)
   OK=0   : Return
Endif

#--- Sélection correcte

# Ouverture de la ligne
nolign = [M]NBLIG
Insa nolign,1,[M]NBLIG [M]NBLIG
[M]NBLIG += 1
nolign = [M]NBLIG
NOL = nolign-1
status = 0
Call LINNUM("SRDLIN") From TABLEAUX

#-- Initialisation des zones de stock et ctrl si l'article est ok
Default Mask [SRH1]
Call INIZONENT([F:SDD]ITMREF,"SRH1",[M]STOFCY,[M]BPCORD,2,"U",NOL,12,[M]TRSCOD,[M]SRHNUM,3,0) From STKECR
If mkstat
    Dela NOL,1,[M:SRH1]NBLIG-1 [M:SRH1]NBLIG : [M:SRH1]NBLIG-=1
    If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV  Endif
    Unlock = SYMBOLE2 : OK=0 : GERR=1 : Return :
Endif

# -- alimentation du masque
[M]DETSDHNUM(NOL) = [F:SDH]SDHNUM

#--- Bug 78668
If dim([M:SRH1]WRH)>0 WWRH=[M:SRH1]WRH(NOL) Endif
[M:SRH1] = [F:SDD]
#--- Bug 78668
If dim([M:SRH1]WRH)>0 [M:SRH1]WRH(NOL)=WWRH Endif

#--CPO 71065 Code affaire sur les retours
[M:SRH1]DPJT(NOL)=[F:SDD]PJT
#--/CPO

If [F:SDH]ORIFCY<>"" [M]ORIFCY = [F:SDH]ORIFCY : Endif

[M]DETSALFCY(NOL) = [F:SDH]SALFCY
[M]DETBPCINV(NOL) = [F:SDH]BPCINV

[M]SIHNUMFAC(NOL) = [F:SDH]SIHNUM

#[M]QTY(NOL)       = [F:SDD]QTY - [F:SDD]RTNQTY
# -- calcul quantité retour en US : Qté livrée - Qté retour prévue
#LQTYSTU           = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
LQTYSTU           = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU - [F:SDD]RCPQTYSTU
[M]QTYSTU(NOL)    = LQTYSTU

# Bug 77101
If LQTYSTU=[F:SDD]QTYSTU
  # Qté à retourner=Qté livrée
  # -- Qté retour en UV = Qté livrée en UV
  [M:SRH1]QTY(NOL)=[F:SDD]QTY
Else
  # Qté à retourner<Qté livrée
  # -- Recalcul de la qté retour en UV à partir de l'US
  # Si on tombe sur un chiffre rond ok sinon on met tout en US
  # Calcul de la qté en UV
  WQTYSAU=LQTYSTU / [M:SRH1]SAUSTUCOE(NOL)
  WQTY=WQTYSAU
  Call QTEARR(WQTY,[M:SRH1]SAU(NOL)) From TRTDIV
  # Point d'entrée pour ajuster la qté retour calculée
  GPOINT="REAJUST" : Gosub ENTREE From EXEFNC
  If WQTYSAU=WQTY
      # On tombe sur un chiffre rond : ok
      [M:SRH1]QTY(NOL)=WQTYSAU
  Else
      # On ne tombe pas sur un chiffre rond : on met tout en US
      [M:SRH1]SAU(NOL)=[M:SRH1]STU (NOL)
      [M:SRH1]QTY(NOL)=LQTYSTU
      [M:SRH1]SAUSTUCOE(NOL)=1
  Endif
Endif

If [M]ENTRTNDAT=[0/0/0] | ([M]ENTRTNDAT<date$ & GREP<>"C")
   [M]DETRTNDAT(NOL) = date$
Else
   [M]DETRTNDAT(NOL) = [M]ENTRTNDAT
Endif

# -- Lecture article
If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM]ITM0=[M]ITMREF(NOL)
    If fstat Call RSTA ("ITM",[M]ITMREF(NOL))  From GLOCK : Raz [F:ITM] : Endif
Endif
If [F:ITM]ITMREF<>[F:SRD]ITMREF | [F:ITU]BPCNUM<>[F:SRH]BPCORD
    Read [ITU]ITU0=[F:SRD]ITMREF;[F:SRH]BPCORD
    If fstat Raz [F:ITU] : Endif
Endif
Gosub ALI_DACSAUCOE From SUBSRHA

[M]CUR(NOL)       = [F:SDH]CUR
[M]EXTQTY(NOL)    = [M]QTY(NOL)
[M]EXTQTYSTU(NOL) = [M]QTYSTU(NOL)
# -- Calcul de la qté livrée
If [F:SDD]RCPQTYSTU=0
    [M]DLVQTY(NOL)    = [M]QTY(NOL)
    [M]DLVQTYSTU(NOL) = [M]QTYSTU(NOL)
Else
    LQTYSTU = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
    [M]DLVQTYSTU(NOL) = LQTYSTU
    If [M]SAU(NOL)<>[M]STU(NOL)
        WQTY=LQTYSTU / [M:SRH1]SAUSTUCOE(NOL)
        Call QTEARR(WQTY,[M:SRH1]SAU(NOL)) From TRTDIV
        [M]DLVQTY(NOL)= WQTY
    Else
        [M]DLVQTY(NOL)= LQTYSTU
    Endif
Endif

If [M]SIHNUMFAC(NOL) = ""
    # La livraison n'est pas facturée
    If GDLVRTNCNO=1
       # Pas d'avoir si la livraison n'est pas facturée, ce sera déduit de la facture
       [M]RTNCNOFLG(NOL) = 1
       [M]RTNINVUPD(NOL) = 2
    Else
       # Avoir si la livraison n'est pas facturée, ce ne sera pas déduit de la facture
       [M]RTNCNOFLG(NOL) = 2
       [M]RTNINVUPD(NOL) = 1
    Endif
Else
    # La livraison est facturée
   [M]RTNINVUPD(NOL) = 1
   [M]RTNCNOFLG(NOL) = 1
Endif



# Si l'article est géré en stock : on force la mise à jour des stocks
If [M]STOMGTCOD(NOL) > 1
   [M]RTNSTOUPD(NOL) = 2
Else
   [M]RTNSTOUPD(NOL) = 1
   [M]WSTOFLG(NOL)=2 : # Article non géré en stock
Endif

If [F:SDD]SOHNUM<>""
    # -- Lecture détail commande
    Read [SOP] SOP0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
    If fstat Raz [F:SOP] : [F:SOP]SAUSTUCOE=1 : Endif
    [M]SOHSAU(NOL)   =[F:SOP]SAU
    [M]SOHSAUCOE(NOL)=[F:SOP]SAUSTUCOE
Endif

# Bug 45401 : A faire une seule fois
# -- Réalimentation paramètres liés au site de vente
#If [M]DETSALFCY(NOL) <> GFCY
#    GFCY = [M]DETSALFCY(NOL)
#    #Call GETDEV(GFCY)  From DEVSUB
#    # Chargement globales référenciels, comptes et sections de la société
#    Gosub CHARG_PARAM From SUBSRHA
#    Call GLOBVAR(GFCY) From WWGLOBVEN
#Endif

# Chargement sections analytiques
Call CHARG_ACCCCE(NOL,"","","[M:SRH1]CCE",
&                    "SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"") From TRTX3CPT
# -- Initialisation des sections analytiques vides
Local Integer I
Local Char    SECTION
# A cause de l'INISEC "SRD" qui peut être paramétré avec [F:PND]
If GMODU(6)=2 & GNBDIE>0 Raz [F:PND] : Endif
For I=1 To GNBDIE
    If evalue("dim([M:SRH1]CCE"+num$(I)+"(NOL))") >0 & evalue("[M:SRH1]CCE"+num$(I)+"(NOL)")=""
        Call INISEC(SECTION, "SRD", I) From TRTX3CPT
        Assign "[M:SRH1]CCE"+num$(I)+"(NOL)" With SECTION
    Endif
Next
Gosub CHARG_STOENTW
# Point d'entrée pour compléter l'alimentation de l'écran détail retour
GPOINT="ALIPICSRH" : Gosub ENTREE From EXEFNC

#Affzo [M:SRH1]1-99

#--- Bug 62980
#--- Contrôle date entrée par rapport aux dates mouvements en attente
If [M]STOMGTCOD(NOL)>1
  Local Date    LDATRUP
  Local Decimal LQTYRUP
  Call CTLRUP([M]STOFCY,[M]ITMREF(NOL),[M]DETRTNDAT(NOL),1,LDATRUP,LQTYRUP) From STKLIB
Endif
#---
#X3-1152 : Nonbillable deliveries
If [F:SDD]SDHCAT=4
   [M]RTNINVUPD(NOL) = 1
   [M]RTNCNOFLG(NOL) = 1
   [M]ORDUPD(NOL)=1
Endif

Return

####################################################################################################
# Recherche si la ligne a fait l'objet d'un retour dt la qté retour prévue n'est pas retournée     #
#           car la qté retour de la ligne de livraison ne tient pas compte de cette qté            #
####################################################################################################
$CTL_EXTQTY
Raz WTOTEXTQTYSTU

For [SRD]SRD0 Hint Key SRD1 Where SDHNUM=[F:SDD]SDHNUM & SDDLIN=[F:SDD]SDDLIN
    WTOTEXTQTYSTU +=[F:SRD]EXTQTYSTU
Next

Return
#########################################################################################
$CHARG_STOENTW
Local Integer WRET
If [M:SRH1]STOMGTCOD(NOL)>1 & [M:SRH1]WSTOFLG(NOL)=0
    If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=6;GFLAG
                            If fstat Raz [F:SLT] Endif
                            Endif
    # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
    Call STJSTOENTW("SRH1",12,13,[M:SRH1]DETRTNDAT(NOL),NOL,[M:SRH1]NBLIG,"SLT",0,WRET) From STKENT
    # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
    # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer (avoir sur facture)
    # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
    # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
    If WRET=4
        Call MESSAGE([M:SRH1]DETSDHNUM(NOL)-":"-[M:SRH1]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
    Elsif WRET<>0
        If WRET=6
            Call ERREUR([M:SRH1]DETSDHNUM(NOL)-":"-[M:SRH1]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
        Elsif WRET=2
            Call ERREUR([M:SRH1]DETSDHNUM(NOL)-":"-[M:SRH1]ITMREF(NOL)-":"-mess(102,198,1)-mess(73,191,1)) From GESECRAN
        Endif
        Dela NOL,1,[M:SRH1]NBLIG-1 [M:SRH1]NBLIG : [M:SRH1]NBLIG-=1
        If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV  Endif
        Case currbox
            When GBOXSD2 : SYMBOLE2 = "SDH"+[F:SDD]SDHNUM
                           Unlock = SYMBOLE2
            When GBOXSD5 : SYMBOLE2 = "SDH"+[F:SDD]SDHNUM   : # X3-1152 : Non invoiceable deliveries
                           Unlock = SYMBOLE2
            When GBOXPN1 : SYMBOLE2 = "PNH"+[F:PNH]PNHNUM
                           Unlock = SYMBOLE2
                           If [F:SDH]SDHNUM<>""
                               SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
                               Unlock = SYMBOLE2
                           Endif
        Endcase
        GERR=1 : OK=0 : Return
    Endif
    Call RECPRISTJ([M:SRH0]STOFCY,4,[M:SRH1]DETSDHNUM(NOL),[M:SRH1]SDDLIN(NOL),[M:SRH1]PRIORD(NOL)) From STKENT
Endif
Return
#########################################################################################
$CTL_LIV
Local Char SWPJTMSG(250)  : # 7165 / PJT
#---------------------------------------------------------------------------------------#
# Contrôle de la ligne livraison sélectionnée                                           #
# Elle doit être cohérente par rapport aux autres lignes sélectionnées                  #
#---------------------------------------------------------------------------------------#
If [F:SDH]BPCORD<>[M]BPCORD | [F:SDH]BPAADD<>[M]BPAADD
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(224,192,1)
   Return
Endif
If [F:SDH]BPCINV<>[M]BPCINV & [M]BPCINV <> ""
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(101,191,1)
   Return
Endif
If [F:SDH]SALFCY<>[M]SALFCY & [M]SALFCY <> ""
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(103,192,1)
   Return
Endif
If [F:SDH]PLISTC<>[M]PLISTC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SOHNUM-mess(27,159,1)-[F:SDD]ITMREF+"\"+mess(187,192,1)+"\"+mess(305,192,1)
   Return
Endif
If [F:SDH]BETFCY<>[M]BETFCY | [F:SDH]BETCPY<>[M]BETCPY
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF-format$(GFMDAT,[F:SDD]SHIDAT)
&           +"\"+mess(187,192,1)+"\"+mess(102,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
#--- CPO 72237 Le champ BPIEECNUM est soumis à code activité
#If [F:SDH]BPIEECNUM<>[M]BPIEECNUM | [F:SDH]EECICT<>[M]EECICT
If (dim([M]BPIEECNUM)>0 & [F:SDH]BPIEECNUM<>[M]BPIEECNUM) | [F:SDH]EECICT<>[M]EECICT
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF-format$(GFMDAT,[F:SDD]SHIDAT)
&           +"\"+mess(187,192,1)+"\"+mess(303,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
If dim([M]EECLOC)>0 & [F:SDH]EECLOC<>[M]EECLOC
   OK=0 : GERR=1
   GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF-format$(GFMDAT,[F:SDD]SHIDAT)
&           +"\"+mess(187,192,1)+"\"+mess(304,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
# Retour inter-sociétés
If [M]BETFCY=2
    # Pas de liv issues cdes créées manuellement avec liv directe ou liv issues de cdes créées automatiquement
    If [F:SDH]ORIFCY=[F:SDH]SALFCY & [M]ORIFCY<>[M]SALFCY
        OK=0 : GERR=1
        GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF-format$(GFMDAT,[F:SDD]SHIDAT)
&                +"\"+mess(175,191,1)+":\"+mess(185,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
        Return
    Endif
    # Pas de liv directe avec liv issues de cdes créées manuellement
    If [F:SDH]ORIFCY<>[F:SDH]SALFCY & [F:SDH]ORIFCY="" & [M]ORIFCY=[M]SALFCY & [M]ORIFCY<>""
        OK=0 : GERR=1
        GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF-format$(GFMDAT,[F:SDD]SHIDAT)
&                +"\"+mess(179,191,1)+":\"+mess(186,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
        Return
    Endif
    # Pas de liv issues cdes créées automatiquement avec liv issues de cdes créées manuellement
    If [F:SDH]ORIFCY<>[F:SDH]SALFCY & [M]ORIFCY=[M]SALFCY & [M]ORIFCY<>""
        OK=0 : GERR=1
        GMESSAGE=[F:SDH]SDHNUM-mess(27,159,1)-[F:SDD]ITMREF-format$(GFMDAT,[F:SDD]SHIDAT)
&                +"\"+mess(173,191,1)+":\"+mess(186,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
        Return
    Endif
Endif
#--CPO 71065 - Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
If func TRTPJT.IS_PJT_AVAILABLE([F:SDD]PJT, "[M:SRH1]DPJT",SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SDD]PJT,SWPJTMSG) From TRTPJT
  OK = 0
  Return
Endif
#--/CPO
Return

#########################################################################
$SEL2
#-----------------------------------------------------------------------#
# Sélection d'une ligne de retour fsseur                                #
#-----------------------------------------------------------------------#

Local Decimal WCOEF, WQTY, WQTYSAU, LQTYSTU
#MAE, GNBCDE n'existe pas Local Char SECTION (GNBCDE)
Local Char SECTION (GLONCDE)

Read [PND]PND0=[F:PND]PNHNUM;[F:PND]PNDLIN
If fstat
   Call RSTA("RSTA",[F:PND]PNHNUM-num$([F:PND]PNDLIN)) From GLOCK : OK=0 : Return
Endif
# Vérif. si la ligne n'a pas été retournée depuis le dernier raffraichissement de la liste de picking
If [F:PND]QTYSTU <= [F:PND]SRDQTYSTU
    GMESSAGE = [F:PND]PNHNUM-":"-mess(27,159,1)-[F:PND]ITMREF-":"-mess(271,192,1) : OK=0 : Return
Endif
Read [PNH]PNH0=[F:PND]PNHNUM
If fstat
   Call RSTA("RSTA",[F:PND]PNHNUM) From GLOCK : OK=0 : Return
Endif

# Date de livraison > date de retour
If [F:PNH]RTNDAT > [M]ENTRTNDAT
   GMESSAGE = mess(326,192,1) : OK=0 : Return
Endif

# Si 1ère ligne, alimentation des zones d'entête
If [M]NBLIG = 0
    # On Vérifie que le client n'est pas le site de vente (correspond au fsseur)
    If [M:SRH0]BPCORD=[F:PNH]BPSNUM
        Local Integer WOK : WOK=1
        Call AVERTIR (mess(151,191,1), WOK)From GESECRAN
        If WOK=1  GERR=1 : OK=0 : Return : Endif
    Endif
    # Récupération du site lié au fournisseur
    # Ce doit être un site de vente sur la même soc. juridique que le site de réception
    If [F:BPR]BPRNUM<>[F:PNH]BPSNUM
        Read [BPR]BPR0=[F:PNH]BPSNUM : If fstat Raz [F:BPR] Endif
    Endif
    If [F:BPR]FCY<>""
        If [F:FCY]FCY<>[F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY : If fstat Raz [F:FCY] Endif
        Endif
        If [F:FCY]SALFLG=2
            If [F:FCY]LEGCPY <> GSOCIETE
                GERR=1 : GMESSAGE=[F:PNH]PNHNUM+"\"+mess(272,192,1) : OK=0   : Return
            Endif
        Endif
    Endif
    If [F:BPR]FCY="" | [F:FCY]SALFLG<>2
        GERR=1 : GMESSAGE=[F:PNH]PNHNUM-":"-mess(8,701,1)-mess(256,194,1)
    Endif
    [M:SRH0]BPSNUM=[F:PNH]BPSNUM
    [M:SRH0]SALFCY=[F:BPR]FCY
    Call GLOBVAR([M:SRH0]SALFCY,"VEN") From TRTX3
Else
  # On contrôle si on peut modifier le retour
    Gosub AVANT_MOD From SUBSRHA : If GERR=1 Return : Endif
  # Contrôle des conditions des regroupement
   Gosub CTL_PND
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M]NBLIG+1 >= dim([M]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

# Si retour de réception on lit la réception pour voir si elle liée à une livraison
Raz [F:SDH], [F:SDD]
If [F:PND]PTHNUM<>"" & [F:PND]PTDLIN<>0
    Read [PTD]PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN
    If fstat
       Call RSTA("RSTA",[F:PND]PTHNUM-num$([F:PND]PTDLIN)) From GLOCK : OK=0 : Return
    Endif
    If [F:PTD]SDHNUM<>""
        Read [SDH]SDH0=[F:PTD]SDHNUM
        If fstat
           Call RSTA("RSTA",[F:PTD]SDHNUM) From GLOCK : OK=0 : Return
        Endif
        If [F:PTD]SDDLIN<>0
            Read [SDD]SDD0=[F:PTD]SDHNUM;[F:PTD]SDDLIN
            If fstat
               Call RSTA("RSTA",[F:PTD]SDHNUM-num$([F:PTD]SDDLIN)) From GLOCK : OK=0 : Return
            Endif
        Endif
    Endif
Endif

SYMBOLE2 = "PNH"+[F:PNH]PNHNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:PNH]PNHNUM-":"-mess(10,100,1)
   OK=0   : Return
Endif
If [F:SDH]SDHNUM<>""
    SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
    Lock = SYMBOLE2
    If fstat
       # modification en cours sur un autre poste
       GERR=1 : GMESSAGE=[F:SDH]SDHNUM-":"-mess(10,100,1)
       OK=0   : Return
    Endif
Endif

# ---------------------------------------
# FGR 18/07/2014 : X3SUIVI91606 (début) : Il n'y a pas de trans-classe depuis [F:PNH], donc je le fais champ par champ
[M:SRH2]LICPLATER    = [F:PNH]LICPLATER
[M:SRH2]TRLLICPLATER = [F:PNH]TRLLICPLATER
[M:SRH2]DPEDATR      = [F:PNH]DPEDATR
[M:SRH2]ETDR         = [F:PNH]ETDR
[M:SRH2]ARVDATR      = [F:PNH]ARVDATR
[M:SRH2]ETAR         = [F:PNH]ETAR
# FGR 18/07/2014 : X3SUIVI91606 (fin)
# ---------------------------------------

#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
#Initialisation des sections en-tête déplacée avant l'incrémentation de NBLIG
# Si retour de réception issu d'une livraison, alimentation du retour en fonction de la livraison
If [M]NBLIG=0 :# Lors de la première ligne de détail
    If [F:SDD]SDHNUM<>"" & [F:SDD]SDDLIN<>0
        # -- Chargement des sections analytiques entête du document
        Call CHARG_CCEH("SRH2","NBAXE","SDH") From TRTX3CPT
    Endif
    # 95742 : PJT en inter société/inter site : (LD:22/04/16)
    If [M:SRH1]BETFCY=2
        If [M:SRH1]BETCPY=1
            # En intersite    on prend le PJT du retour fournisseur
            [M:SRH2]PJT=[F:PNH]PJTH
        Else
            # En intersociété on prend le PJT de la livraison
            [M:SRH2]PJT=[F:SDH]PJT
        Endif
    Endif
    # 95742 : PJT en inter société/inter site : (LD:22/04/16)
Endif
#fin FQ 65292
#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
#Pavé déplacé avant l'incrémentation de NBLIG
If [F:SDD]SDHNUM<>""
    If [M]NBLIG=0
        [M:SRH0]ICTCTY=[F:SDH]ICTCTY
        [M:SRH0]FFWNUM=[F:SDH]FFWNUM
        [M:SRH0]FFWADD=[F:SDH]FFWADD
        [M:SRH0]EECICT=[F:SDH]EECICT
        If dim([M]EECLOC)>0
           [M:SRH0]EECLOC    = [F:SDH]EECLOC
           [M:SRH0]BPIEECNUM = [F:SDH]BPIEECNUM
           [M:SRH0]EECTRN    = [F:SDH]EECTRN
        Endif
    Endif
Endif
#fin FQ 65292
#--- Sélection correcte

# Ouverture de la ligne
nolign = [M]NBLIG
Insa nolign,1,[M]NBLIG [M]NBLIG
[M]NBLIG += 1
nolign = [M]NBLIG
NOL = nolign-1
status = 0
Call LINNUM("SRDLIN") From TABLEAUX

#-- Initialisation des zones de stock et ctrl si l'article est ok
Default Mask [SRH1]
Call INIZONENT([F:PND]ITMREF,"SRH1",[M]STOFCY,[M]BPCORD,2,"U",NOL,12,[M]TRSCOD,[M]SRHNUM,3,0) From STKECR
If mkstat
   Dela NOL,1,[M:SRH1]NBLIG-1 [M:SRH1]NBLIG : [M:SRH1]NBLIG-=1
   If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV  Endif
   SYMBOLE2 = "PNH"+[F:PNH]PNHNUM
   Unlock = SYMBOLE2
   If [F:SDH]SDHNUM<>""
       SYMBOLE2 = "SDH"+[F:SDH]SDHNUM
       Unlock = SYMBOLE2
   Endif
   OK=0 : GERR=1 : Return
Endif

#FQ 65292
#CPO - Problème découvert lors de la correction de cette fiche
#Initialisation des sections en-tête déplacée avant l'incrémentation de NBLIG
# Si retour de réception issu d'une livraison, alimentation du retour en fonction de la livraison
If [F:SDD]SDHNUM<>"" & [F:SDD]SDDLIN<>0
    [M:SRH1]=[F:SDD]
    [M]DETSDHNUM(NOL)=[F:SDH]SDHNUM
    #If [M:SRH1]NBLIG=0    # Chargement des sections analytiques entête du document
    #    Call CHARG_CCEH("SRH2","NBAXE","SDH") From TRTX3CPT
    #Endif
#FQ 65292
#Dans ce cas précis, c'est le code section par défaut qui sera utilisé
#Entité - "Document d'origine"
#Else
#    If [M:SRH1]NBLIG=0    # Chargement des sections analytiques entête du document
#        Call CHARG_CCEH("SRH2","NBAXE","PNH") From TRTX3CPT
#    Endif
Endif
Local Integer I
Local Char    SECTION
#fin FQ 65292
# -- Initialisation des sections analytiques vides
If dim([M:SRH2]NBAXE)>0
    [M:SRH2]NBAXE=GNBDIE
    For I=1 To GNBDIE
      If [M:SRH2]CCE(I-1)=""
        [M:SRH2]DIE(I-1)=GDIE(I)
        Call INISEC(SECTION,"SRH",GDIE(I)) From SUBCDE
        [M:SRH2]CCE(I-1)=SECTION
      Endif
    Next I
Endif

# -- alimentation du masque
[M]ITMREF(NOL)    = [F:PND]ITMREF
[M]RTNREN(NOL)    = [F:PND]RTNREN
#[M]DETRTNDAT(NOL) = [F:PND]RTNDAT
[M]STU(NOL)       = [F:PND]STU
[M]DETSALFCY(NOL) = [M:SRH0]SALFCY
[M]DETBPCINV(NOL) = [M:SRH1]BPCINV
[M]PNHNUM(NOL)    = [F:PND]PNHNUM
[M]PNDLIN(NOL)    = [F:PND]PNDLIN

# 95742 : PJT en inter société/inter site : (LD:22/04/16)
If [M:SRH1]BETFCY=2
    If [M:SRH1]BETCPY=1
        # En intersite    on prend le PJT du retour fournisseur
        [M:SRH1]DPJT(NOL)=[F:PND]PJT
    Else
        # En intersociété on prend le PJT de la livraison
        [M:SRH1]DPJT(NOL)=[F:SDD]PJT
    Endif
Endif
# 95742 : PJT en inter société/inter site : (LD:20/04/16)

# On vérifie si l'unité du retour est une unité de vente
# Si oui, on la prend
# Si non et on a une livraison, on prend l'unité de vente de la livraison
# Si on a pas de livraison, l'unité de vente sera l'unité de stock
If [F:PND]UOM<>[F:PND]STU
    Call CTLUOM([M:SRH1]ITMREF(NOL),2,[M:SRH0]BPCORD,[F:PND]UOM,WCOEF,GBIDC1,GBIDC2,
&               [M:SRH1]DACSAUCOE(NOL)) From STKACT
    If mkstat=0
        [M:SRH1]SAU(NOL)      =[F:PND]UOM
        [M:SRH1]SAUSTUCOE(NOL)=[F:PND]UOMSTUCOE
    Elsif [F:SDD]SAU<>""
        Raz GMESSAGE
        [M:SRH1]SAU(NOL)      =[F:SDD]SAU
        [M:SRH1]SAUSTUCOE(NOL)=[F:SDD]SAUSTUCOE
    Else
        Raz GMESSAGE
        [M:SRH1]SAU(NOL)      =[F:PND]STU
        [M:SRH1]SAUSTUCOE(NOL)=1
    Endif
Else
    [M:SRH1]SAU(NOL)      =[F:PND]STU
    [M:SRH1]SAUSTUCOE(NOL)=1
Endif

# -- calcul quantité en US
LQTYSTU           = [F:PND]QTYSTU - [F:PND]SRDQTYSTU
[M]QTYSTU(NOL)    = LQTYSTU
# -- Recalcul de la qté retour en UV à partir de l'US
# Si on tombe sur un chiffre rond ok sinon on met tout en US
# Calcul de la qté en UV
WQTYSAU=LQTYSTU / [M:SRH1]SAUSTUCOE(NOL)
WQTY=WQTYSAU
Call QTEARR(WQTY,[M:SRH1]SAU(NOL)) From TRTDIV
If WQTYSAU=WQTY
    # On tombe sur un chiffre rond : ok
    [M:SRH1]QTY(NOL)=WQTYSAU
Else
    # On ne tombe pas sur un chiffre rond : on met tout en US
    [M:SRH1]SAU(NOL)=[M:SRH1]STU (NOL)
    [M:SRH1]QTY(NOL)=LQTYSTU
    [M:SRH1]SAUSTUCOE(NOL)=1
Endif
[M]EXTQTY(NOL)    = [M]QTY(NOL)
[M]EXTQTYSTU(NOL) = [M]QTYSTU(NOL)
[M]PNDQTYSTU(NOL) = [M]QTYSTU(NOL)

# -- Lecture article
If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM]ITM0=[M]ITMREF(NOL)
    If fstat Call RSTA ("ITM",[M]ITMREF(NOL))  From GLOCK : Raz [F:ITM] : Endif
Endif
# -- Alimentation du flag coef modifiable
If [M]SAU(NOL)=[M]STU(NOL)
    [M]DACSAUCOE(NOL)=1
Elsif [M]SAU(NOL)=[F:ITM]SAU
    [M]DACSAUCOE(NOL)=[F:ITM]DACSAUCOE
Else
    Local Integer I    : # L'unité est une unité de conditionnement
    For I=0 To dim([F:ITM]PCU)-1
       If find([F:ITM]PCU(I),[M]SAU(NOL))
          [M]DACSAUCOE(NOL)=[F:ITM]DACPCUCOE(I)
          Break
       Endif
    Next I
Endif

If [M]ENTRTNDAT=[0/0/0] | ([M]ENTRTNDAT<date$ & GREP<>"C")
   [M]DETRTNDAT(NOL) = date$
Else
   [M]DETRTNDAT(NOL) = [M]ENTRTNDAT
Endif

[M]RTNINVUPD(NOL) = 1
If [F:SDD]SDHNUM=""
    # ----------------------------------------------------- #
    # On a aucune livraison                                 #
    # ----------------------------------------------------- #
    # On récupère la désignation standard du retour fsseur
    [M]ITMDES1(NOL)   = [F:PND]ITMDES1
    # On recherche la désignation traduite dans la langue du client
    #Call CHARGE_ITMDES("DES1AXX", [M:SRH0]LAN,[M:SRH1]ITMREF(NOL),[M:SRH1]ITMDES(NOL)) From TRTX3
    #If [M:SRH1]ITMDES(NOL) = "" [M:SRH1]ITMDES(NOL) = [M:SRH1]ITMDES1(NOL) Endif
    Call CHARGE_DEFITMDES("DES1AXX", [M:SRH0]LAN,[M:SRH1]ITMREF(NOL),[M:SRH1]ITMDES(NOL), "[F:PND]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

    # Récupération du prix net du retour et conversion
    If [M:SRH1]SAU(NOL)=[F:PND]UOM             : # retour client et retour fsseur st ds la même unité
        [M]NETPRI(NOL) = [F:PND]NETPRI
    Else                                       : # retour client et retour fsseur ne st pas ds la même unité
        Local Decimal WPRIX
        If [M:SRH1]SAU(NOL)=[F:PND]STU         : # retour client en US, retour fsseur ds une autre unité
            WPRIX=[F:PND]NETPRI/[F:PND]UOMSTUCOE
        Elsif [F:PND]UOM=[F:PND]STU            : # retour fsseur en US, retour client ds une autre unité
            WPRIX=[F:PND]NETPRI*[M:SRH1]SAUSTUCOE(NOL)
        Else                                   : # retour client et retour fsseur ds une autre unité que l'US
            WPRIX=[F:PND]NETPRI/[F:PND]UOMSTUCOE
            WPRIX=WPRIX*[M:SRH1]SAUSTUCOE(NOL)
        Endif
        WPRIX=arr(WPRIX,10^-GDECPRI) : [M:SRH1]NETPRI(NOL)=WPRIX
    Endif
    # Dans les retours achat le prix est tjs en HT, donc on calcule le prix TTC
    [M]NETPRINOT(NOL) = [M:SRH1]NETPRI(NOL)
    [M]CUR(NOL)       = [F:PND]NETCUR
    # -- Lecture client pour récup régime de taxe
    If [F:BPC]BPCNUM<>[M]BPCORD
        Read [BPC]BPC0=[M]BPCORD
        If fstat Call RSTA ("BPC",[M]BPCORD)  From GLOCK : Raz [F:BPC] : Endif
    Endif
    Call CLCTAXEPRIV([M]NETPRINOT(NOL),[F:PND]VAT,1,GSOCIETE,[M]DETRTNDAT(NOL),[M]QTY(NOL),[F:BPC]BPCNUM,[F:PND]CLCAMT1,[F:PND]CLCAMT2,
&                   [M]NETPRIATI(NOL)) From TRTX3
    [M]STOMGTCOD(NOL) = [F:PND]STOMGTCOD
Else
    # ----------------------------------------------------- #
    # On a une livraison : On récupère tout de la livraison #
    # ----------------------------------------------------- #
    If [F:SDH]ORIFCY<>"" [M]ORIFCY = [F:SDH]ORIFCY : Endif

    [M]CUR(NOL)       = [F:SDH]CUR
    # Récupération du prix net de la livraison et conversion
    If [M:SRH1]SAU(NOL)<>[F:SDD]SAU            : # retour client et livraison ne st pas ds la même unité
        Local Decimal WPRIX
        If [M:SRH1]SAU(NOL)=[F:SDD]STU         : # retour client en US, livraison ds une autre unité
            WPRIX=[F:SDD]NETPRINOT/[F:SDD]SAUSTUCOE : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRH1]NETPRINOT(NOL)=WPRIX
            WPRIX=[F:SDD]NETPRIATI/[F:SDD]SAUSTUCOE : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRH1]NETPRIATI(NOL)=WPRIX
        Elsif [F:SDD]SAU=[F:SDD]STU            : # livraison en US, retour client ds une autre unité
            WPRIX=[F:SDD]NETPRINOT*[M:SRH1]SAUSTUCOE(NOL) : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRH1]NETPRINOT(NOL)=WPRIX
            WPRIX=[F:SDD]NETPRIATI*[M:SRH1]SAUSTUCOE(NOL) : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRH1]NETPRIATI(NOL)=WPRIX
        Else                                   : # retour client et livraison ds une autre unité que l'US
            WPRIX=[F:SDD]NETPRINOT/[F:SDD]SAUSTUCOE
            WPRIX=WPRIX*[M:SRH1]SAUSTUCOE(NOL)  : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRH1]NETPRINOT(NOL)=WPRIX
            WPRIX=[F:SDD]NETPRIATI/[F:SDD]SAUSTUCOE
            WPRIX=WPRIX*[M:SRH1]SAUSTUCOE(NOL)  : WPRIX=arr(WPRIX,10^-GDECPRI)
            [M:SRH1]NETPRIATI(NOL)=WPRIX
        Endif
        If [F:SDH]PRITYP=1
            [M:SRH1]NETPRI(NOL)=[M:SRH1]NETPRINOT(NOL)
        Else
            [M:SRH1]NETPRI(NOL)=[M:SRH1]NETPRIATI(NOL)
        Endif
    Endif
    #FQ 65292
    #CPO - Problème découvert lors de la correction de cette fiche
    #Pavé déplacé avant l'incrémentation de NBLIG
    #If [M]NBLIG=0
    #    [M:SRH0]ICTCTY=[F:SDH]ICTCTY
    #    [M:SRH0]FFWNUM=[F:SDH]FFWNUM
    #    [M:SRH0]FFWADD=[F:SDH]FFWADD
    #    [M:SRH0]EECICT=[F:SDH]EECICT
    #    If dim([M]EECLOC)>0
    #       [M:SRH0]EECLOC    = [F:SDH]EECLOC
    #       [M:SRH0]BPIEECNUM = [F:SDH]BPIEECNUM
    #       [M:SRH0]EECTRN    = [F:SDH]EECTRN
    #    Endif
    #Endif
    #fin FQ 65292

    [M]SIHNUMFAC(NOL) = [F:SDH]SIHNUM

    # Calcul de la qté livrée en US : Qté livrée - Qté retournée
    LQTYSTU           = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
    [M]DLVQTYSTU(NOL)    = LQTYSTU
    # Affichage de la qté livrée dans l'unité de vente du retour
    If [M]SAU(NOL)<>[M]STU(NOL)
        WQTY=LQTYSTU / [M:SRH1]SAUSTUCOE(NOL)
        Call QTEARR(WQTY,[M:SRH1]SAU(NOL)) From TRTDIV
        [M]DLVQTY(NOL)= WQTY
    Else
        [M]DLVQTY(NOL)= LQTYSTU
    Endif
#    [M]DLVQTY(NOL)    = [M]QTY(NOL)
#    [M]DLVQTYSTU(NOL) = [M]QTYSTU(NOL)

    If [M]SIHNUMFAC(NOL) = "" [M]RTNINVUPD(NOL)=2 Endif
Endif
# Si le retour d'achat est en attente d'avoir on fera un avoir (sf si on pas encore facturé)
If [F:PND]LININVFLG=1 & [M]RTNINVUPD(NOL)=1 [M]RTNCNOFLG(NOL)=2 Endif
# Si l'article est géré en stock : on force la mise à jour des stocks
If [M]STOMGTCOD(NOL) > 1
   [M]RTNSTOUPD(NOL) = 2
Else
   [M]RTNSTOUPD(NOL) = 1
   [M]WSTOFLG(NOL)=2 : # Article non géré en stock
Endif
[M]ORDUPD(NOL)=1

# Bug 45401 : A faire une seule fois
# -- Réalimentation paramètres liés au site de vente
#If [M]DETSALFCY(NOL) <> GFCY
#    GFCY = [M]DETSALFCY(NOL)
#    #Call GETDEV(GFCY)  From DEVSUB
#    # Chargement globales référenciels, comptes et sections de la société
#    Gosub CHARG_PARAM From SUBSRHA
#    Call GLOBVAR(GFCY) From WWGLOBVEN
#Endif

# Chargement sections analytiques
If [F:SDD]SDHNUM<>""
    Call CHARG_ACCCCE(NOL,"","","[M:SRH1]CCE",
&                        "SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"") From TRTX3CPT
#FQ 65292
#Dans ce cas précis, c'est le code section par défaut qui sera utilisé
#Entité - "Document d'origine"
#Else
#    Call CHARG_ACCCCE(NOL,"","","[M:SRH1]CCE",
#&                        "PND",0,[F:PND]PNHNUM,[F:PND]PNDLIN,0,"") From TRTX3CPT
#fin FQ 65292
Endif
# -- Initialisation des sections analytiques vides
Local Integer I
Local Char    SECTION
For I=1 To GNBDIE
    If evalue("dim([M:SRH1]CCE"+num$(I)+"(NOL))") >0 & evalue("[M:SRH1]CCE"+num$(I)+"(NOL)")=""
        Call INISEC(SECTION, "SRD", I) From TRTX3CPT
        Assign "[M:SRH1]CCE"+num$(I)+"(NOL)" With SECTION
    Endif
Next

Gosub CHARG_STOENTW
# Point d'entrée pour compléter l'alimentation de l'écran détail retour
GPOINT="ALIPICSRH" : Gosub ENTREE From EXEFNC

#Affzo [M:SRH1]1-99

Return
#########################################################################
$CTL_PND
#---------------------------------------------------------------------------------------#
# Contrôle de la ligne retour fsseur sélectionnée                                       #
# Elle doit être cohérente par rapport aux autres lignes sélectionnées                  #
#---------------------------------------------------------------------------------------#
If [F:PNH]BPSNUM<>[M]BPSNUM
   OK=0 : GERR=1
   GMESSAGE=[F:PNH]PNHNUM-":"-mess(26,159,1)-":"-[F:PNH]BPSNUM-"\"-mess(274,192,1)-"("-mess(26,159,1)-"="-[M:SRH0]BPSNUM-")"
   Return
Endif
Return
#########################################################################
$DESEL1
Local Integer I, J, SNOL
Raz I, J, SNOL
OK = 0
If [M]NBLIG <> 0
   While OK <> 1
      I = find([F:SDD]SDHNUM,[M]DETSDHNUM(J..[M]NBLIG-1))
      If !I Break Endif
      If [M]CREFLG(J+I-1)=0 & [F:SDD]SDDLIN=[M]SDDLIN(J+I-1)
         SNOL = J+I-1
         Dela SNOL,1,[M]NBLIG-1 [M]NBLIG
         [M]NBLIG -= 1
         If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV  Endif
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur cette livraison, il faut la débloquer
Raz I,J
OK = 2
If [M:SRH1]NBLIG <> 0
   While OK <> 1
      I = find([F:SDD]SDHNUM,[M:SRH1]DETSDHNUM(J..[M:SRH1]NBLIG-1))
      If !I Break Endif
      If [M:SRH1]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête livraison
   SYMBOLE2 = "SDH"+[F:SDD]SDHNUM
   Unlock = SYMBOLE2
Endif

Return
#########################################################################
$DESEL2
Local Integer I, J, SNOL
Local Char    WSDHNUM
Raz I, J, SNOL
OK = 0
If [M]NBLIG <> 0
   While OK <> 1
      I = find([F:PND]PNHNUM,[M]PNHNUM(J..[M]NBLIG-1))
      If !I Break Endif
      If [M]CREFLG(J+I-1)=0 & [F:PND]PNDLIN=[M]PNDLIN(J+I-1)
         WSDHNUM=[M]DETSDHNUM(SNOL)
         SNOL = J+I-1
         Dela SNOL,1,[M]NBLIG-1 [M]NBLIG
         [M]NBLIG -= 1
         If [M]NBLIG=0 Raz [M]SALFCY, [M]BPCINV, [M]BPSNUM  Endif
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur ce retour, il faut le débloquer
Raz I,J
OK = 2
If [M:SRH1]NBLIG <> 0
   While OK <> 1
      I = find([F:PND]PNHNUM,[M:SRH1]PNHNUM(J..[M:SRH1]NBLIG-1))
      If !I Break Endif
      If [M:SRH1]CREFLG(J+I-1)=0
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif
If OK = 2
   # Unlock entête retour
   SYMBOLE2 = "PNH"+[F:PND]PNHNUM
   Unlock = SYMBOLE2
   If WSDHNUM<>""
       # Unlock entête livraison
       SYMBOLE2 = "SDH"+WSDHNUM
       Unlock = SYMBOLE2
   Endif
Endif

Return
#########################################################################
$RAFFRAICHI

#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
Case currbox
 When GBOXSD2,GBOXSD5 : If sum([M:SRH1]SDDLIN)<>0 & sum([M:SRH1]PNDLIN)=0 : # X3-1152 : Non invoiceable deliveries
# When GBOXSD2 : If sum([M:SRH1]SDDLIN)<>0 & sum([M:SRH1]PNDLIN)=0        : # X3-1152 : Non invoiceable deliveries
                   For I=0 To [M:SRH1]NBLIG-1
                      # Ligne issue d'un picking livraison réalisé au cours de cette transaction
                      If [M:SRH1]DETSDHNUM(I)<>"" & [M:SRH1]CREFLG(I)=0
                         Read [SDD]SDD0=[M:SRH1]DETSDHNUM(I);[M:SRH1]SDDLIN(I)
                         If    WPICK=1 Gosub DEPICK From GOBJSUB
                         Elsif WPICK=2 Gosub REPICK From GOBJSUB
                         Endif
                      Endif
                   Next I
                Endif
 When GBOXPN1 : If sum([M:SRH1]PNDLIN)<>0
                   For I=0 To [M:SRH1]NBLIG-1
                      # Ligne issue d'un picking retour fsseur réalisé au cours de cette transaction
                      If [M:SRH1]PNHNUM(I)<>"" & [M:SRH1]CREFLG(I)=0
                         Read [PND]PND0=[M:SRH1]PNHNUM(I);[M:SRH1]PNDLIN(I)
                         If    WPICK=1 Gosub DEPICK From GOBJSUB
                         Elsif WPICK=2 Gosub REPICK From GOBJSUB
                         Endif
                      Endif
                   Next I
                Endif
 When Default
Endcase

Return
##########################################################################

