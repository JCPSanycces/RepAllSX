#<AdxTL>@(#)3.0.0.0 $Revision$
Subprog MODSER(LECR,WTYP,LRET)
Value    Integer LECR
Value    Integer WTYP
Variable Integer LRET

Local Integer ETABOU(1..GNBBOU)
Local Integer SAVOBJET, REPONSE, J, K, WNB, WSEQNUM
Local Char    SAVPROG

Local Dlgbox Mask [SERR]
&     Button mess(64,123,1), mess(5,123,1)
&     With left$(mess(64,123,1),1), left$(mess(5,123,1),1)
&     Coded GSTAOK, GSTAFIN   
&     Titled mess(178,198,1) As [SERR]

SAVGOBJET = GOBJET
SAVPROG   = GPROGRAMME
Call SAVBOUT From GESECRAN
GOBJET = 0

Boxact [SERR] 
ETABOU(GVALI) = 1 : # Ok
ETABOU(GABAN) = 1 : # Abandon
Call SETBOUT(ETABOU) From GESECRAN

$SAIDEB
Affzo  [SERR] 
Boxinp [SERR] Using REPONSE 
K = 0
Case REPONSE
   When GSTAOK : For J=0 To [M]NBLIG-1
                    If    [M]XQTYSTU(J)<>0 & J=K
                       WNB=0
                    Elsif [M]XQTYSTU(J)<>0 & J<>K
                       If WNB <> [M]XQTYSTU(K)
                          Call ERREUR(mess(246,199,1)) From GESECRAN
                          Break
                       Else
                          K=J
                          WNB=0
                       Endif
                    Endif      
                    If [M]XOUINON(J)=2 WNB += 1 Endif
                 Next J
                 If WNB <> [M]XQTYSTU(K)
                    Call ERREUR(mess(246,199,1)) From GESECRAN
                    Goto SAIDEB
                 Else
                    Goto SAIFIN
                 Endif
   When GSTAFIN, GSTAESC : GOK=0 : LRET = 88 : Goto SAIFIN
   When Default
Endcase
Goto SAIDEB

$SAIFIN
If GOK=0 Goto SAIEND Endif

Raz WSEQNUM
For J=0 To [M]NBLIG-1
   If [M]XOUINON(J)=1 
      [F:STY]PRONUM    = adxuid(1)
      [F:STY]LINNUM    = LECR
      If [F:STY]SCRLINNUM = [M]XLIGORI(J)
         WSEQNUM += 1 
      Else
         Raz WSEQNUM
      Endif
      [F:STY]SCRLINNUM = [M]XLIGORI(J) 
      [F:STY]SEQNUM    = WSEQNUM 
      [F:STY]SERNUM    = [M]XSERNUM(J) 
      [F:STY]VCRTYP    = WTYP   
      Write [STY]
      If fstat
         GOK=0 : LRET=89
         Call FSTA("STY") From GLOCK
         Break
      Endif
   Endif   
Next J

$SAIEND  
Boxclr [SERR]
Call RESTBOUT From GESECRAN
GOBJET     = SAVGOBJET
GPROGRAMME = SAVPROG

End

########################################
Subprog C_NBLIG
End

########################################
Subprog APRES_NBLIG
End

########################################
Subprog C_XQTYSTU(VALEUR)
Variable Decimal VALEUR
End

