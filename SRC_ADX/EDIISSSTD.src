#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################
#  Author : RBA                                 ##
#  Direct EDI Issue  # 112138 US2               ##
##################################################
#pour tests :
#commande de vente :
#CDE-2015-5015 -> Send & receive
#CDE-2015-5010 -> Receive
#CDE-2015-5014 -> Pas d'echange EDI

$ACTION
  Case ACTION
    When "DEBUT"      : Gosub DEBUT
    When "AP_CHOIX"   : Gosub AP_CHOIX
    When "BOUTON"     : Gosub BOUTON
    When "FIN"        : Gosub FIN
    When Default
  Endcase
Return



$DEBUT
  If PARAM(1) = "" and PARAM(2) = "" and PARAM(3) = "" and PARAM(4) = ""
    PARAM(1) = "FCSPA0114VEN00000060" #"FCSPA0114VEN00000060" #"FJM1101404VEN0015" # "YMO40110O0000000001"
    PARAM(2) = "2"
    PARAM(3) = "1"
    PARAM(4) = "2"
  Endif

  If PARAM(1) <> "" and PARAM(2) <> "" and PARAM(3) <> ""
    [M:EIS0]DOCID     = PARAM(1)
    [M:EIS0]CATTYP    = val(PARAM(2))
    [M:EIS0]CATACT    = val(PARAM(3))
    [M:EIS0]CATOPE    = val(PARAM(4))
#    [M:EIS0]PARCOD    = "EDICOM" #pour le test
  Endif
  [M:EIS0]TESTFLG      = [V]CST_ANO
  [M:EIS0]DUPLICATEFLG = [V]CST_ANO

  ANOWRITE = 1
  Global Instance MYEXECEDIRUN Using C_EDIRUN
Return

######################################################################

$AP_CHOIX
  Local Integer I
  I=find(REPONSE,LBOUT)
  If I<1 : Return : Endif
  Case CBOUT(I-1)
      When "A"
        Gosub RUN_PROCESS
  Endcase
Return

######################################################################

$RUN_PROCESS
  #rechercher toutes les catégories valides qui contient le CATTYP, CATOPE et le CATACT = send
  #recuperer les identifiants des champs BPANUM et CPY
  Local Integer WOK
  Local Integer K

  Local Integer WPARTYP      : WPARTYP      = 0

  Local Char WCATCOD(30)     : WCATCOD      = ""
  Local Char WCATTRGTAB(30)  : WCATTRGTAB   = ""
  Local Char WKEY(100)       : WKEY         = ""

  Local Integer WERROR_FLG   : WERROR_FLG   = [V]CST_ANO
  Local Integer WFOUND_FLG   : WFOUND_FLG   = [V]CST_AFALSE
  Local Integer WRUN_NEW_FLG : WRUN_NEW_FLG = [V]CST_AYES
  Local Integer WRUN         : WRUN         = 0

  Local Char WBPANUM_VAL(30) : WBPANUM_VAL  = ""
  Local Char WBPANUM_FLD(30) : WBPANUM_FLD  = ""

  Local Char WCPY_VAL(30)    : WCPY_VAL     = ""
  Local Char WCPY_FLD(30)    : WCPY_FLD     = ""

  Local Char WFLOCOD(20)     : WFLOCOD      = ""
  Local Char WFLOREL(5)      : WFLOREL      = ""

  If WERROR_FLG = [V]CST_ANO
    Gosub GET_CATEGORY
  Endif

  If WERROR_FLG = [V]CST_ANO
    Gosub GET_CATEGORY_PROPERTIES
  Endif

  If WERROR_FLG = [V]CST_ANO
    Gosub GET_CATEGORY_FIELDS
  Endif

  If WERROR_FLG = [V]CST_AYES
    GMESSAGE = GMESSAGE-mess(161,2006,1) #Flow unvailable
    GOK = 0 : GERR = 1
  Endif
Return

######################################################################

$GET_CATEGORY
  If clalev ([F:EPRD]) = 0 : Local File EDIPARTNERD [EPRD] : Endif
  Read [EPRD]EPRD3 = [M:EIS0]PARCOD;[M:EIS0]CATTYP;[M:EIS0]CATOPE
  If fstat = [V]CST_AOK
    WCATCOD = [F:EPRD]CATCOD
    WERROR_FLG = [V]CST_ANO
  Else
    WERROR_FLG = [V]CST_AYES
  Endif

  WPARTYP = fmet GACTX.ACACHE.EPR.AGETVALNUM([M:EIS0]PARCOD,"PARTYP")
  # 1 : CPY controls
  # 2 : CPY & BPR controls
  # 3 : no controls
Return

######################################################################

$GET_CATEGORY_PROPERTIES
  #looking for CPY and BPANUM fields
  If clalev ([F:ECA])  = 0 : Local File EDICAT [ECA]   : Endif
  Read [ECA]ECA0 = WCATCOD
  If fstat <> [V]CST_AOK
    GMESSAGE   = mess(64,2006,1) #Category nonexistent
    WERROR_FLG = [V]CST_AYES
  Elsif [ECA]VALID <> [V]CST_AYES
    GMESSAGE   = "Category unvalid"
    WERROR_FLG = [V]CST_AYES
  Elsif [ECA]CATACT = 2
    GMESSAGE   = mess(77,2006,1)  #Sense does not match action
    WERROR_FLG = [V]CST_AYES      #eNDX3-69665 Issuing a Sales Order with EDI (JUCON:01/11/2018)
  Endif
  Close File [ECA]

  If WERROR_FLG <> [V]CST_AYES
    WCATTRGTAB  = func SEARCH_ECA_FLD(WCATCOD,[M:EIS0]PARCOD,"CATTRGTAB")
    WKEY        = func SEARCH_ECA_FLD(WCATCOD,[M:EIS0]PARCOD,"DESCRIPT")
    WCPY_FLD    = func SEARCH_ECAK_FLD(WCATCOD,[M:EIS0]PARCOD,"CPY")
    WBPANUM_FLD = func SEARCH_ECAK_FLD(WCATCOD,[M:EIS0]PARCOD,"BPANUM")
  Endif
Return

######################################################################

Funprog SEARCH_ECA_FLD(WCATCOD,WPARCOD,WFLD)
Value Char WCATCOD
Value Char WPARCOD
Value Char WFLD

  Local Char WFLD_FOUND(50)
  If clalev ([F:ECA]) = 0 : Local File EDICAT [ECA] : Endif
  Read [ECA]ECA0 = WCATCOD
  If fstat = [V]CST_AOK
    If WPARCOD = "FACTURAE" #specificities for FACTURAE
      If WFLD = "CATTRGTAB" : WFLD_FOUND = "SINVOICEV"    : Endif
      If WFLD = "DESCRIPT"  : WFLD_FOUND = "NUM"          : Endif
    Else
      If WFLD = "CATTRGTAB" : WFLD_FOUND = [ECA]CATTRGTAB : Endif
      If WFLD = "DESCRIPT"  : WFLD_FOUND = [ECA]DESCRIPT  : Endif
    Endif
  Else
    WFLD_FOUND = ""
  Endif
  Close File [ECA]
End WFLD_FOUND

######################################################################

Funprog SEARCH_ECAK_FLD(WCATCOD,WPARCOD,WFLD)
Value Char WCATCOD
Value Char WPARCOD
Value Char WFLD

  Local Char WFLD_FOUND(50)
  If clalev ([F:ECAK]) = 0 : Local File EDICATK [ECAK] : Endif
  Read [ECAK]ECAK2 = WCATCOD;WFLD
  If fstat = [V]CST_AOK
    If WPARCOD = "FACTURAE" #specificities for FACTURAE
      If WFLD = "BPANUM" : WFLD_FOUND = "BPCINV" : Endif
    Else
      WFLD_FOUND = [ECAK]FLD
    Endif
  Else
    WFLD_FOUND = ""
  Endif
  Close File [ECAK]
End WFLD_FOUND

######################################################################

$GET_CATEGORY_FIELDS
  #récuperer les valeurs des champs utilisés pour BPANUM et CPY dans la table correspondante du document
  Local Char    WTAB_KEY_FLD(30)(1..) : Call PARSE_KEY_FLD(WKEY, WTAB_KEY_FLD)
  Local Char    WTAB_KEY_VAL(30)(1..) : Call PARSE_KEY_VAL([M:EIS0]DOCID, WTAB_KEY_VAL)

  Local Integer WTAB_KEY_TYPE(1..)
  Local Char    WTAB_KEY_CODTYP(8)(1..)
  Local Integer WTAB_KEY_NOLIB(1..)

  Local Char    CRITERE(250) : CRITERE = "1=1"

  If clalev ([F:ATZ]) = 0 : Local File ATABZON [ATZ] : Endif
  If clalev ([F:ATY]) = 0 : Local File ATYPE [ATY] : Endif
  If clalev ([F:ATX]) = 0 : Local File ATEXTE [ATX] : Endif

  For K = 1 To maxtab(WTAB_KEY_FLD)
    #check zone
    Read [ATZ]CODZONE = WCATTRGTAB;WTAB_KEY_FLD(K)
    If !fstat
      #get type
      Read [ATY]CODTYP = [F:ATZ]CODTYP
      If !fstat
        WTAB_KEY_TYPE(K) = [F:ATY]TYPTYP
      Endif
      WTAB_KEY_CODTYP(K) = [F:ATZ]CODTYP
      WTAB_KEY_NOLIB(K)  = [F:ATZ]NOLIB
    Endif

    Case WTAB_KEY_TYPE(K)
      When 1,2,3,4,5,6 #1 - MENU Local #2 - ENTIER COURT #3 - ENTIER LONG #4 - DÉCIMAL #5 - FLOTTANT #6 - Double
          CRITERE -= '&' - WTAB_KEY_FLD(K)-'='+num$(WTAB_KEY_VAL(K))
      When 7 #7 - ALPHANUMÉRIQUE
          CRITERE -= '&' - WTAB_KEY_FLD(K)-'="'+WTAB_KEY_VAL(K)+'"'
      When Default #8 - Date #9 - BLOB #10 - CLOB #11 - UUID #12 - Datetime A REVOIR...
          CRITERE -= '&' - WTAB_KEY_FLD(K)-'="'+WTAB_KEY_VAL(K)+'"'
    Endcase
  Next

#  WERROR_FLG = [V]CST_AYES
#  Local File =WCATTRGTAB [TRG]
#  Filter [TRG] Where evalue(CRITERE)
#  For [TRG]
#    WERROR_FLG = [V]CST_ANO
#    If WBPANUM_FLD = "" #case of INTRASAT for example, no BPANUM
#      WCPY_VAL    = evalue("[TRG]"+WCPY_FLD)
#      WBPANUM_VAL = ""
#    Else
#      WCPY_VAL    = evalue("[TRG]"+WCPY_FLD)
#      WBPANUM_VAL = evalue("[TRG]"+WBPANUM_FLD)
#    Endif
#    WERROR_FLG = [V]CST_ANO
#    Break
#  Next
#  Close File [TRG]

  WERROR_FLG = [V]CST_AYES
  Local File =WCATTRGTAB [TRG]
  Filter [TRG] Where evalue(CRITERE)
  For [TRG]
    WERROR_FLG = [V]CST_ANO
    If WCPY_FLD    <> "" : WCPY_VAL    = evalue("[TRG]"+WCPY_FLD)    : Else : WCPY_VAL    : Endif
    If WBPANUM_FLD <> "" : WBPANUM_VAL = evalue("[TRG]"+WBPANUM_FLD) : Else : WBPANUM_VAL : Endif
    WERROR_FLG = [V]CST_ANO
    Break
  Next
  Close File [TRG]

  Case WPARTYP
    When 1 : Gosub GET_FLO_PARTYP_1
    When 2 : Gosub GET_FLO_PARTYP_2
    When 3 : Gosub GET_FLO_PARTYP_3
  Endcase

Return

######################################################################

$GET_FLO_PARTYP_1
  #case of INTRASAT for example, no BPANUM
  #here we only know the CPY field, so to find the associated flow, check into EDICPYPARFLO

  #Boucle sur chaque EDICPYPARFLO possible pour trouver celui qui match
  If clalev ([F:ECP])     = 0 : Local File EDICPYPAR [ECP]       : Endif
  If clalev ([F:ECPDF])   = 0 : Local File EDICPYPARFLO [ECPDF]  : Endif
  Link [ECPDF] With [ECP]ECP0 ~= [ECPDF]CPY; [ECPDF]PARCOD As [MYREQ]
&       Where [ECPDF]CATACT = [M:EIS0]CATACT
&         and [ECPDF]CATTYP = [M:EIS0]CATTYP
&         and [ECPDF]CATCOD = WCATCOD
&         and [ECP]PARCOD   = [M:EIS0]PARCOD
&         and [ECPDF]CATOPE = [M:EIS0]CATOPE
&         and [ECP]CPY      = WCPY_VAL
  For [MYREQ]
    ###############################
    #Recherche du WFLOCOD et WFLOREL dans EDICPYPARFLO
    WFLOCOD = [MYREQ]FLOCOD
    WFLOREL = [MYREQ]FLOREL
    Gosub EDIRUN_PROCESS
    If WFOUND_FLG = [V]CST_ATRUE
      Break
    Endif
    ###############################
  Next
  If clalev ([F:ECP])     <> 0 : LogicClose File [ECPDF] : Endif
  If clalev ([F:ECPDF])   <> 0 : LogicClose File [ECP]   : Endif
Return

######################################################################

$GET_FLO_PARTYP_2
  #Boucle sur chaque EDIBPRCPYD possible pour trouver celui qui match
  If clalev ([F:EBC])  = 0 : Local File EDIBPRCPY [EBC]   : Endif
  If clalev ([F:EBCD]) = 0 : Local File EDIBPRCPYD [EBCD] : Endif
  Link [EBCD] With [EBC]EBC0 ~= [EBCD]BPRNUM; [EBCD]CPY; [EBCD]PARCOD As [MYREQ]
&       Where [EBCD]CATACT = [M:EIS0]CATACT
&         and [EBCD]CATTYP = [M:EIS0]CATTYP
&         and [EBCD]CATCOD = WCATCOD
&         and [EBC]PARCOD  = [M:EIS0]PARCOD
&         and [EBCD]CATOPE = [M:EIS0]CATOPE
&         and [EBC]BPRNUM  = WBPANUM_VAL
&         and [EBC]CPY     = WCPY_VAL
  For [MYREQ]
    ###############################
    #Recherche du WFLOCOD et WFLOREL dans EDIBPRCPYD
    WFLOCOD = [MYREQ]FLOCOD
    WFLOREL = [MYREQ]FLOREL
    Gosub EDIRUN_PROCESS
    If WFOUND_FLG = [V]CST_ATRUE
      Break #on ne recherche pas de ligne de EDIBPRCPY suivante (il ne doit y en avoir qu'une au max)
    Endif
    ###############################
  Next
  Close File [EBCD]
  Close File [EBC]
Return

######################################################################

$GET_FLO_PARTYP_3
  #trouver une method pour récuperer un flux sans CPY ni BPR ni categorie ??...
Return

######################################################################

$EDIRUN_PROCESS
  #verifier si un EDIRUN existe, si oui -> l'utiliser, sinon -> le creer
  WFOUND_FLG = [V]CST_AFALSE
  WRUN       = 0

  Gosub EDIRUN_RECOVER

  #on crée un nouveau process s'il n'en existe pas
  If WFOUND_FLG = [V]CST_AFALSE # and WRUN = 0 #not found
    Gosub EDIRUN_CREATE
  Endif

  #on execute le process trouvé ou celui tout juste créé
  If WFOUND_FLG = [V]CST_ATRUE # and WRUN <> 0
    Gosub EDIRUN_EXECUTE
    #on ne recherche pas de ligne de EDIBPRCPY suivante (il ne doit y en avoir qu'une au max)
  Endif
Return

######################################################################

$EDIRUN_RECOVER
  WRUN_NEW_FLG = [V]CST_AYES
  If clalev ([F:EDR]) = 0 : Local File EDIRUN [EDR] : Endif
  Filter [EDR] Where
&       [EDR]DIRECTFLG    = [V]CST_AYES
&   and [EDR]FLOCOD       = WFLOCOD
&   and [EDR]FLOREL       = WFLOREL
&   and [EDR]CATCOD       = WCATCOD
&   and [EDR]CATTYP       = [M:EIS0]CATTYP
&   and [EDR]CATOPE       = [M:EIS0]CATOPE
&   and [EDR]PARCOD       = [M:EIS0]PARCOD
&   and [EDR]TESTFLG      = [M:EIS0]TESTFLG
&   and [EDR]DUPLICATEFLG = [M:EIS0]DUPLICATEFLG
  For [EDR]
    WFOUND_FLG   = [V]CST_ATRUE
    WRUN_NEW_FLG = [V]CST_ANO
    WRUN         = [EDR]NUM
    Break #"Process found, using the direct process #"+num$(WRUN)
  Next
  Filter [EDR]
  Close File [EDR]
Return

######################################################################

$EDIRUN_CREATE
  WRUN_NEW_FLG = [V]CST_AYES
  #creation d'un nouveau process
  Local Integer WPOS
  Local Instance MYEDIRUN Using C_EDIRUN
  MYEDIRUN = NewInstance C_EDIRUN AllocGroup null
  WOK = fmet MYEDIRUN.AINIT()

  MYEDIRUN.CATACT       = 1
  MYEDIRUN.DIRECTFLG    = 2
  MYEDIRUN.RUNDES       = "Direct"-WFLOCOD+"~"+WFLOREL
  MYEDIRUN.PARCOD       = [M:EIS0]PARCOD
  MYEDIRUN.CATCOD       = WCATCOD
  MYEDIRUN.FLOCOD       = WFLOCOD
  MYEDIRUN.FLOREL       = WFLOREL
  MYEDIRUN.DUPLICATEFLG = [M:EIS0]DUPLICATEFLG
  MYEDIRUN.TESTFLG      = [M:EIS0]TESTFLG

  Call DELETELINES(MYEDIRUN, "EDRD") From EDILIBA

  K = 0
  Local File EDICATD [ECAD]
  Filter [ECAD] Where [ECAD]CATCOD = WCATCOD and [EPRD]CATTYP = [M:EIS0]CATTYP
  For [ECAD]
    K = K + 1
    WPOS = fmet MYEDIRUN.ADDLINE('EDRD', [V]CST_ALASTPOS)
    MYEDIRUN.EDRD(WPOS).FLD            = WTAB_KEY_FLD(K)
    MYEDIRUN.EDRD(WPOS).MANDATORY      = 2
    MYEDIRUN.EDRD(WPOS).OPERATOR       = 2
    MYEDIRUN.EDRD(WPOS).FLDVAL1        = WTAB_KEY_VAL(K)
    MYEDIRUN.EDRD(WPOS).REPFLDVAL1     = WTAB_KEY_VAL(K)
    MYEDIRUN.EDRD(WPOS).FLDVAL2        = ""
    MYEDIRUN.EDRD(WPOS).REPFLDVAL2     = ""
    MYEDIRUN.EDRD(WPOS).FLDTYPTYP      = WTAB_KEY_TYPE(K)
    MYEDIRUN.EDRD(WPOS).FLDCODTYP      = WTAB_KEY_CODTYP(K)
    MYEDIRUN.EDRD(WPOS).FLDNOLIB       = WTAB_KEY_NOLIB(K)
  Next
  LogicClose File [ECAD]

  WOK = fmet MYEDIRUN.AINSERT()
  #tester l'erreur sur INSERT?
  FreeGroup MYEDIRUN

  #récuperer l'id du process créé
  If clalev ([F:EDR]) = 0 : Local File EDIRUN [EDR] : Endif
  Filter [EDR] Where
&       [EDR]DIRECTFLG = [V]CST_AYES
&   and [EDR]FLOCOD    = WFLOCOD
&   and [EDR]FLOREL    = WFLOREL
&   and [EDR]CATCOD    = WCATCOD
&   and [EDR]CATTYP    = [M:EIS0]CATTYP
&   and [EDR]CATOPE    = [M:EIS0]CATOPE
&   and [EDR]PARCOD    = [M:EIS0]PARCOD
&   and [EDR]NUM       <> WRUN
  For [EDR]
    WFOUND_FLG = [V]CST_ATRUE #2
    WRUN       = [EDR]NUM #id du process créé
    Break #"Process not found, creating and using the direct process #"+num$(WRUN)
  Next
  Filter [EDR]
  Close File [EDR]
Return

######################################################################

$EDIRUN_EXECUTE
  Local Integer WI, WJ
  #utilisation de WRUN
  If (MYEXECEDIRUN <> null) : FreeGroup MYEXECEDIRUN : Endif
  MYEXECEDIRUN = NewInstance C_EDIRUN AllocGroup null
  WOK = fmet MYEXECEDIRUN.AREAD(WRUN)
  If WRUN_NEW_FLG = [V]CST_ANO
#    MYEXECEDIRUN.EDRD(1).FLDVAL1        = [M:EIS0]DOCID #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
    For WI = 1 To maxtab(MYEXECEDIRUN.EDRD)
      For WJ = 1 To maxtab(WTAB_KEY_FLD)
        If WTAB_KEY_FLD(WJ) = MYEXECEDIRUN.EDRD(WI).FLD
          MYEXECEDIRUN.EDRD(WI).FLDVAL1 = WTAB_KEY_VAL(WJ)
          Break
        Endif
      Next
    Next
    WOK = fmet MYEXECEDIRUN.AUPDATE()
  Endif
  Local Char WNUMBATCH(50)
  WOK = fmet MYEXECEDIRUN.MET_RUN_PROCESS_DIRECT(WNUMBATCH)
  If WNUMBATCH <> ""
    If WOK <> [V]CST_AOK
      Errbox(mess(7,2017,1)-":"-mess(9,2007,1)+"/"-mess(50,2006,1)-":"-WNUMBATCH+".tra") #failed / log file
    Else
      Infbox(mess(7,2017,1)-":"-mess(7,2007,1)+"/"-mess(50,2006,1)-":"-WNUMBATCH+".tra") #suceed / log file
    Endif
    Call LECFIC(filpath("","","","","")+"/"+"TRA",WNUMBATCH,"tra") From LECFIC
  Else
    If WOK <> [V]CST_AOK
      Infbox(mess(7,2017,1)-":"-mess(9,2007,1)+"/"-mess(114,116,1)) #failed / no log file
    Else
      Infbox(mess(7,2017,1)-":"-mess(7,2007,1)+"/"-mess(114,116,1)) #success / no log file
    Endif
  Endif
Return

######################################################################

$BOUTON
  If BOUT = "A"
    FIN=1
  Endif
Return

######################################################################

$FIN
  If (MYEXECEDIRUN <> null) : FreeGroup MYEXECEDIRUN : Endif
  Kill MYEXECEDIRUN
Return

######################################################################

Subprog PARSE_KEY_FLD(WSTR, WTAB_KEY_FLD)
Value Char WSTR
Variable Char WTAB_KEY_FLD()(1..)
#  Local Char WSTR(100) #: WSTR = "KEY1+KEY2+KEY13"
  Local Integer K, L, WDEB, WFIN
  L = 0
  WDEB = 1
  For K = 1 To len(WSTR)
    If mid$(WSTR, K, 1) = "+"
      L = L + 1
      WFIN = K
      WTAB_KEY_FLD(L) = mid$(WSTR, WDEB, WFIN-WDEB)
      WDEB = WFIN + 1
    Endif
  Next K
  L = L + 1
  WFIN = K
  WTAB_KEY_FLD(L) = mid$(WSTR, WDEB, WFIN-WDEB)
End
End

######################################################################

Subprog PARSE_KEY_VAL(WSTR, WTAB_KEY_VAL)
Value Char WSTR
Variable Char WTAB_KEY_VAL()(1..)
#  Local Char WSTR(100) #: WSTR = "VAL1!VAL2!VAL3
  Local Integer K, L, WDEB, WFIN
  L = 0
  WDEB = 1
  For K = 1 To len(WSTR)
    If mid$(WSTR, K, 1) = "!"
      L = L + 1
      WFIN = K
      WTAB_KEY_VAL(L) = mid$(WSTR, WDEB, WFIN-WDEB)
      WDEB = WFIN + 1
    Endif
  Next K
  L = L + 1
  WFIN = K
  WTAB_KEY_VAL(L) = mid$(WSTR, WDEB, WFIN-WDEB)
End




