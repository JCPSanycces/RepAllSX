#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AMK",GBIDC1,GBIDC2) From GOBJET
End

Call EXECUTE()
End

######################################################################################
Subprog EXECUTE()
Local Char PARAM(10)(1..1) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"ASELPAR","ASELPAR","SPESELPAR") From GSAISIE
End
######################################################################################

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "OK"        : Gosub OK
 When "END"       : Gosub ENDS
 When Default
Endcase
Return

########################################
$OUVRE
If !clalev([M:ASL]) : # Mask de selection non ouvert
 FIN = 1
 Return
Endif
Return

########################################
########################################
$DEBUT
Raz [M:ASP]
[M:ASP] = [M:ASL]
If [M:ASL]FLD1 <> ""
 If [M:ASL]DES1="" : Call INTIT_ATZ([M:ASL]TBL1,[M:ASL]FLD1,[M:ASP]INTIT1) : Else : [M:ASP]INTIT1 = [M:ASL]DES1 : Endif
 MA = 1 : Gosub TITMASK From ="WG"+GBOITE
 Affzo [M]OPE1
 If [M:ASL]PAR1 <> 2
  Grizo [M:ASP]VAL1
 Endif
Else
 Chgfmt [M:ASP]INTIT1   With "-K:X"
 Chgfmt [M:ASP]OPE1     With "-K:X"
 Chgfmt [M:ASP]VAL1     With "-K:X"
Endif
If [M:ASL]FLD2 <> ""
 If [M:ASL]DES2="" : Call INTIT_ATZ([M:ASL]TBL2,[M:ASL]FLD2,[M:ASP]INTIT2) : Else : [M:ASP]INTIT2 = [M:ASL]DES2 : Endif
 MA = 1 : Gosub TITMASK From ="WG"+GBOITE
 Affzo [M]OPE2
 If [M:ASL]PAR2 <> 2
  Grizo [M:ASP]VAL2
 Endif
Else
 Chgfmt [M:ASP]INTIT2   With "-K:X"
 Chgfmt [M:ASP]OPE2     With "-K:X"
 Chgfmt [M:ASP]VAL2     With "-K:X"
 Chgfmt [M:ASP]ANDOR2   With "-K:X"
Endif
If [M:ASL]FLD3 <> ""
 If [M:ASL]DES3="" : Call INTIT_ATZ([M:ASL]TBL3,[M:ASL]FLD3,[M:ASP]INTIT3) : Else : [M:ASP]INTIT3 = [M:ASL]DES3 : Endif
 MA = 1 : Gosub TITMASK From ="WG"+GBOITE
 Affzo [M]OPE3
 If [M:ASL]PAR3 <> 2
  Grizo [M:ASP]VAL3
 Endif
Else
 Chgfmt [M:ASP]INTIT3   With "-K:X"
 Chgfmt [M:ASP]OPE3     With "-K:X"
 Chgfmt [M:ASP]VAL3     With "-K:X"
 Chgfmt [M:ASP]ANDOR3   With "-K:X"
Endif
If [M:ASL]FLD4 <> ""
 If [M:ASL]DES4="" : Call INTIT_ATZ([M:ASL]TBL4,[M:ASL]FLD4,[M:ASP]INTIT4) : Else : [M:ASP]INTIT4 = [M:ASL]DES4 : Endif
 MA = 1 : Gosub TITMASK From ="WG"+GBOITE
 Affzo [M]OPE4
 If [M:ASL]PAR4 <> 2
  Grizo [M:ASP]VAL4
 Endif
Else
 Chgfmt [M:ASP]INTIT4   With "-K:X"
 Chgfmt [M:ASP]OPE4     With "-K:X"
 Chgfmt [M:ASP]VAL4     With "-K:X"
 Chgfmt [M:ASP]ANDOR4   With "-K:X"
Endif
If [M:ASL]FLD5 <> ""
 If [M:ASL]DES5="" : Call INTIT_ATZ([M:ASL]TBL5,[M:ASL]FLD5,[M:ASP]INTIT5) : Else : [M:ASP]INTIT5 = [M:ASL]DES5 : Endif
 MA = 1 : Gosub TITMASK From ="WG"+GBOITE
 Affzo [M]OPE5
 If [M:ASL]PAR5 <> 2
  Grizo [M:ASP]VAL5
 Endif
Else
 Chgfmt [M:ASP]INTIT5   With "-K:X"
 Chgfmt [M:ASP]OPE5     With "-K:X"
 Chgfmt [M:ASP]VAL5     With "-K:X"
 Chgfmt [M:ASP]ANDOR5   With "-K:X"
Endif
If [M:ASL]EXP1<> "" & [M:ASL]PAREXP = 2
#101830
# [M:ASP]INTITEXP = [M:ASL]EXP1
# [M:ASP]VALEXP = [M:ASL]PAREXP
 [M:ASP]INTITEXP = mess(5,79,1)
 [M:ASP]VALEXP = [M:ASL]EXP1
Else
 Chgfmt [M:ASP]VALEXP  With "-K:X"
Endif

Affzo [M:ASP]
Return

########################################
$OK
[M:ASL] = [M:ASP]
#101830
[M:ASL]EXP1=[M:ASP]VALEXP
PARAM(1) = ""
Return

$ENDS
PARAM(1) = "1"
Return

########################################################################################################################
########################################################################################################################
Subprog INTIT_ATZ(TABLE,CHAMP,INTIT)
Value Char    TABLE
Value Char    CHAMP
Variable Char INTIT
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
Read [F:ATZ]CODZONE = TABLE;CHAMP
If !fstat
 If [F:ATZ]NOLONG > 0
  INTIT -= func AFNC.TEXTE([F:ATZ]NOLONG)
 Elsif [F:ATZ]NOCOURT > 0
  INTIT -= func AFNC.TEXTE([F:ATZ]NOCOURT)
 Elsif [F:ATZ]NOABREG > 0
  INTIT -= func AFNC.TEXTE([F:ATZ]NOABREG)
 Endif
Endif
End
