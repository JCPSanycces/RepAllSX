##########################################################################################################
Subprog IB_FULRPO

  Raz GBOUT1
  If [M:CRMG]FULRPO<> "" Then
    If len([M:CRMG]FULRPO) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULRPO (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:CRMG]FULRPO, VALEUR, [M:CRMG]RPO) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:CRMG]FULRPO = VALEUR
  Gosub DISPICON From TRTCRM7
  Affzo [M:CRMG]1-99
End
