#<AdxTL>@(#)%I%
# Supervisor
# Inquiry GDD

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:08"
A_USER  = "ADMIN"
A_STAMP = "20181109081108"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(37196,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSGDDSTD"
PROGSPE    = "SPEGDDSTD"
CBOITE     = "DCNSGDD"
BOITE      = "FCNSGDD"
NOMMSK(0)  = "CONSGDD1"
ABMSK(0)   = "GDD1"
NOMMSK(1)  = "CONSGDD2"
ABMSK(1)   = "GDD2"
CMEMO      = "buo"
CNOMMSK    = "CRITGDD"
CABMSK     = "CGDD"
CODMSKDEF  = "STD"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:PRJ])=0 : Local File PROJET       [PRJ] : Endif
If clalev([F:ENV])=0 : Local File ENVELOPPE    [ENV] : Endif
If clalev([F:ENF])=0 : Local File ENVFIY       [ENF] : Endif
If clalev([F:BUD])=0 : Local File BUD          [BUD] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY      [AGC] : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY      [AGF] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP     [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY      [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
If clalev([F:ENT])=0 : Local File ENTITE       [ENT] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CGDD]
 When  0 : Local Mask =NOMMSK(0) [GDD1]
 When  1 : Local Mask =NOMMSK(1) [GDD2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CGDD]
 When  0 : Grizo [GDD1]
 When  1 : Grizo [GDD2]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:CGDD]CPY)>0
 Grizo [CGDD]CPY
Endif
If dim([M:CGDD]FCY)>0
 Grizo [CGDD]FCY
Endif
If dim([M:CGDD]DATDEB)>0
 Grizo [CGDD]DATDEB
Endif
If dim([M:CGDD]DATFIN)>0
 Grizo [CGDD]DATFIN
Endif
If dim([M:CGDD]CRIPRJ)>0
 Grizo [CGDD]CRIPRJ
Endif
If dim([M:CGDD]ENTMSTR)>0
 Grizo [CGDD]ENTMSTR
Endif
If dim([M:CGDD]ENTMEND)>0
 Grizo [CGDD]ENTMEND
Endif
If dim([M:CGDD]ENTASTR)>0
 Grizo [CGDD]ENTASTR
Endif
If dim([M:CGDD]ENTAEND)>0
 Grizo [CGDD]ENTAEND
Endif
If dim([M:CGDD]ENVSTR)>0
 Grizo [CGDD]ENVSTR
Endif
If dim([M:CGDD]ENVEND)>0
 Grizo [CGDD]ENVEND
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CGDD])>0 : Close Local Mask [CGDD] : Endif
 When  0 : If clalev([M:GDD1])>0 : Close Local Mask [GDD1] : Endif
 When  1 : If clalev([M:GDD2])>0 : Close Local Mask [GDD2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CGDD]
 When  0 : Default Mask [GDD1]
 When  1 : Default Mask [GDD2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CGDD]
 When  0 : Raz [M:GDD1]
 When  1 : Raz [M:GDD2]
Endcase
Return

$CRITENT
If dim([M:CGDD]CPY)>0 & dim([M:GDD1]CPY)>0
 [M:CGDD]CPY = [M:GDD1]CPY
Endif
If dim([M:CGDD]FCY)>0 & dim([M:GDD1]FCY)>0
 [M:CGDD]FCY = [M:GDD1]FCY
Endif
If dim([M:CGDD]DATDEB)>0 & dim([M:GDD1]DATDEB)>0
 [M:CGDD]DATDEB = [M:GDD1]DATDEB
Endif
If dim([M:CGDD]DATFIN)>0 & dim([M:GDD1]DATFIN)>0
 [M:CGDD]DATFIN = [M:GDD1]DATFIN
Endif
If dim([M:CGDD]CRIPRJ)>0 & dim([M:GDD1]CRIPRJ)>0
 [M:CGDD]CRIPRJ = [M:GDD1]CRIPRJ
Endif
If dim([M:CGDD]ENTMSTR)>0 & dim([M:GDD1]ENTMSTR)>0
 [M:CGDD]ENTMSTR = [M:GDD1]ENTMSTR
Endif
If dim([M:CGDD]ENTMEND)>0 & dim([M:GDD1]ENTMEND)>0
 [M:CGDD]ENTMEND = [M:GDD1]ENTMEND
Endif
If dim([M:CGDD]ENTASTR)>0 & dim([M:GDD1]ENTASTR)>0
 [M:CGDD]ENTASTR = [M:GDD1]ENTASTR
Endif
If dim([M:CGDD]ENTAEND)>0 & dim([M:GDD1]ENTAEND)>0
 [M:CGDD]ENTAEND = [M:GDD1]ENTAEND
Endif
If dim([M:CGDD]ENVSTR)>0 & dim([M:GDD1]ENVSTR)>0
 [M:CGDD]ENVSTR = [M:GDD1]ENVSTR
Endif
If dim([M:CGDD]ENVEND)>0 & dim([M:GDD1]ENVEND)>0
 [M:CGDD]ENVEND = [M:GDD1]ENVEND
Endif
Return

$ENTCRIT
If dim([M:CGDD]CPY)>0 & dim([M:GDD1]CPY)>0
[M:GDD1]CPY = [M:CGDD]CPY
Endif
If dim([M:CGDD]FCY)>0 & dim([M:GDD1]FCY)>0
[M:GDD1]FCY = [M:CGDD]FCY
Endif
If dim([M:CGDD]DATDEB)>0 & dim([M:GDD1]DATDEB)>0
[M:GDD1]DATDEB = [M:CGDD]DATDEB
Endif
If dim([M:CGDD]DATFIN)>0 & dim([M:GDD1]DATFIN)>0
[M:GDD1]DATFIN = [M:CGDD]DATFIN
Endif
If dim([M:CGDD]CRIPRJ)>0 & dim([M:GDD1]CRIPRJ)>0
[M:GDD1]CRIPRJ = [M:CGDD]CRIPRJ
Endif
If dim([M:CGDD]ENTMSTR)>0 & dim([M:GDD1]ENTMSTR)>0
[M:GDD1]ENTMSTR = [M:CGDD]ENTMSTR
Endif
If dim([M:CGDD]ENTMEND)>0 & dim([M:GDD1]ENTMEND)>0
[M:GDD1]ENTMEND = [M:CGDD]ENTMEND
Endif
If dim([M:CGDD]ENTASTR)>0 & dim([M:GDD1]ENTASTR)>0
[M:GDD1]ENTASTR = [M:CGDD]ENTASTR
Endif
If dim([M:CGDD]ENTAEND)>0 & dim([M:GDD1]ENTAEND)>0
[M:GDD1]ENTAEND = [M:CGDD]ENTAEND
Endif
If dim([M:CGDD]ENVSTR)>0 & dim([M:GDD1]ENVSTR)>0
[M:GDD1]ENVSTR = [M:CGDD]ENVSTR
Endif
If dim([M:CGDD]ENVEND)>0 & dim([M:GDD1]ENVEND)>0
[M:GDD1]ENVEND = [M:CGDD]ENVEND
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
CRITAFF(1) = "ECRAN" : CRITAFF2(1) = ""
NBCA = 1
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSGDD2"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "GDD"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M]REF(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("ENV","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "GDD"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M:GDD1]CLEENV,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("ENV","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT3<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT3
 VALBOUT(NBBOUT) = "GDD"
 VALBOUT(NBBOUT) += "~B3"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M:GDD1]CLEENV,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([M]FIY(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([M]REF(nolign-1)),"~","¨")
 Onerrgo
Endif
If GBOUT4<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT4
 VALBOUT(NBBOUT) = "GDD"
 VALBOUT(NBBOUT) += "~B4"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M:GDD1]CLEENV,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([M]FIY(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([M:GDD1]CLELIG),"~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[M]REF(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CONSGDD2"
 When "B2"
  Onerrgo RIEN
  Assign "[M:GDD1]CLEENV" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B2_NBLIG From ="W1CONSGDD2"
 When "B3"
  Onerrgo RIEN
  Assign "[M:GDD1]CLEENV" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "[M]FIY(nolign-1)" With val(ctrans(func AFNC.PART(INFO,4),"¨","~"))
  Assign "[M]REF(nolign-1)" With val(ctrans(func AFNC.PART(INFO,5),"¨","~"))
  Onerrgo
  Call B3_NBLIG From ="W1CONSGDD2"
 When "B4"
  Onerrgo RIEN
  Assign "[M:GDD1]CLEENV" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "[M]FIY(nolign-1)" With val(ctrans(func AFNC.PART(INFO,4),"¨","~"))
  Assign "[M:GDD1]CLELIG" With val(ctrans(func AFNC.PART(INFO,5),"¨","~"))
  Onerrgo
  Call B4_NBLIG From ="W1CONSGDD2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


