#<AdxTL>@(#)12.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
#########################################################################
#                                                                       #
#      TRAITEMENTS DIVERS pour les fournisseurs                         #
#                                                                       #
#########################################################################
#-----------------------------------------------------------------------#
# Traitements e_commerce                                                #
#-----------------------------------------------------------------------#
# ACTIONS                                                               #
# ------------------                                                    #
# Saisie de fenêtre                                                     #
# ------------------                                                    #
# VISUMVTBPS : Visualisation des mouvements dossiers                    #
#                                                                       #
#########################################################################
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE"      : 
     Case GACTION
         When "VISUMVTBPS"  : Gosub OUV_VISUMVTBPS 
     Endcase
 When "DEBUT"      : 
     Case GACTION
         When "VISUMVTBPS"  : Gosub DEB_VISUMVTBPS : Affzo [M:MVS2]1-99
     Endcase
 When "BOUTON"      : 
     Case GACTION
         When "VISUMVTBPS"  : Gosub BOUT_VISUMVTBPS
     Endcase
 When "SETBOUT"      : 
     Case GACTION
         When "VISUMVTBPS"  : Gosub SETB_VISUMVTBPS
     Endcase
Endcase
Return
#########################################################################
# DETAIL DES ACTIONS                                                    #
#########################################################################
#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
#########################################################################
# VISUMVTDOS : Visu des mouvements dossiers                             #
#########################################################################
$OUV_VISUMVTBPS

Local Char    WFINRSPFCY
Local Integer SPSTAT
Local Decimal WCOURS    : # variable pour le cours de devise
Local Decimal WMONTANT  : # montant aprés conversion
Local Char    WCUR (3)  : # devise destinatrice
#--------------------------------------#
# affichage des montants               #
# waffmnt = 1 --> devise affichage     #
# waffmnt = 2 --> devise reporting     #
#--------------------------------------#
Local Shortint WAFFMNT

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY]  : Endif

Return
#########################################################################
$DEB_VISUMVTBPS

#--------------------------------------------------#
# on selectionne tous les enregistrements          #
# du fichier mouvement pour le fournisseur affiché #
#--------------------------------------------------#
#If GUSRACC (2) <> 0
       Filter [MVS] Where BPSNUM = [M:BPS0]BPSNUM
#Else   Filter [MVS] Where BPSNUM = [M:BPS0]BPSNUM & FINRSPFCY = WFINRSPFCY
#Endif
#-----------------------------------------------------#
# chargement des elements                             #
# en entree affichage en fonction devise environnment #
# = devise du site comptable défini par défaut dans le#
#   USER pour le module TRONC COMMUN                  #
#-----------------------------------------------------#
WAFFMNT = 2
Gosub CUMUL_DOSSIER 

Return
#########################################################################
$BOUT_VISUMVTBPS

Case BOUT
    When "1"  :  # Devise dossier
        WAFFMNT  = 1
        WCUR  = GSYSCUR
        Gosub AFFICHAGE_DEVISE 
    When "2"  :  # Devise affichage
        WAFFMNT  = 2    
        WCUR  = GCUR
        Gosub AFFICHAGE_DEVISE 
Endcase
Return
#########################################################################
$SETB_VISUMVTBPS

If WAFFMNT = 1
#    Mouvement dossier : On active mouvement affichage
#    ETABOU (GSPE1) = 0 : # Devise dossier
#    ETABOU (GSPE2) = 1 : # Devise affichage
    Call VIREBOUT(CHMEN, "1") From GOBJET    : # Devise dossier
Else
#    Mouvement affichage  : On active mouvement dossier
#    ETABOU (GSPE1) = 1 : # Devise dossier 
#    ETABOU (GSPE2) = 0 : # Devise affichage
    Call VIREBOUT(CHMEN, "2") From GOBJET    : # Devise affichage
Endif
Return
######################################################################################## 
$CUMUL_DOSSIER
 
#------------------------------------------------#
# lecture de tous les mouvements                 #
# affichage des montants en devise environnement #
#------------------------------------------------#
WCOURS    = 1
WMONTANT  = 0

Raz [MVS2]
[M:MVS2]WCUR = GCUR

#---------------------------------------------------#
# pas besoin de positionner la clé ou une condition #
# une instruction FILTER est faite avant            #
#---------------------------------------------------#
For [MVS]
  #------------------------------#
  # Date derniere cde et facture #
  #------------------------------#
  If [M:MVS2]LASORDDAT < [F:MVS]LASORDDAT
    [M:MVS2]LASORDDAT = [F:MVS]LASORDDAT
  Endif
  If [M:MVS2]LASINVDAT < [F:MVS]LASINVDAT
    [M:MVS2]LASINVDAT = [F:MVS]LASINVDAT
  Endif
  #----------------------------------------------------#
  # Conversion des montants dans la devise site defaut #
  #----------------------------------------------------#
  Local Decimal WMONTDES
  Call CONVERT([F:MVS]ACCCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:MVS]ORDAMT,WMONTDES,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:MVS2]ORDAMT   +=WMONTDES
  Else
    [M:MVS2]ORDAMT   +=[F:MVS]ORDAMT
  Endif
  Call CONVERT([F:MVS]ACCCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:MVS]RCPAMT,WMONTDES,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:MVS2]RCPAMT   +=WMONTDES
  Else
    [M:MVS2]RCPAMT   +=[F:MVS]RCPAMT
  Endif
  Call CONVERT([F:MVS]ACCCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:MVS]INVAMT,WMONTDES,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:MVS2]INVAMT   +=WMONTDES
  Else
    [M:MVS2]INVAMT   +=[F:MVS]INVAMT
  Endif
  Call CONVERT([F:MVS]ACCCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:MVS]BILAMT(0),WMONTDES,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:MVS2]BILAMT(0)+=WMONTDES
  Else
    [M:MVS2]BILAMT(0)+=[F:MVS]BILAMT(0)
  Endif
  Call CONVERT([F:MVS]ACCCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:MVS]BILAMT(1),WMONTDES,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:MVS2]BILAMT(1)+=WMONTDES
  Else
    [M:MVS2]BILAMT(1)+=[F:MVS]BILAMT(1)
  Endif
  Call CONVERT([F:MVS]ACCCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:MVS]BILAMT(2),WMONTDES,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:MVS2]BILAMT(2)+=WMONTDES
  Else
    [M:MVS2]BILAMT(2)+=[F:MVS]BILAMT(2)
  Endif
  Call CONVERT([F:MVS]ACCCUR,GCUR,GCUR,GCHGTYP,datesyst,[F:MVS]BLCAMT,WMONTDES,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:MVS2]BLCAMT   +=WMONTDES
  Else
    [M:MVS2]BLCAMT   +=[F:MVS]BLCAMT
  Endif
Next

[M:MVS2]TOTAMT=[M:MVS2]ORDAMT+[M:MVS2]RCPAMT+[M:MVS2]INVAMT+[M:MVS2]BILAMT(0)+[M:MVS2]BILAMT(1)+
&              [M:MVS2]BILAMT(2)+[M:MVS2]BLCAMT
 
[M:MVS2]WOSTCTL = [M:BPS4]OSTCTL 
#--- conversion du montant encours autorisé   
Call CONVERT(GSYSCUR,[M:MVS2]WCUR,GCUR,GCHGTYP,datesyst,[F:BPS]OSTAUZAMT,[M:MVS2]WOSTAUZ,SPSTAT) From TRTDEV   

Affzo [MVS2] 
Return
###################################################################
$AFFICHAGE_DEVISE
Local Char    ANC_CUR (3)  : # ancienne devise
Local Integer SPSTAT

ANC_CUR = [M:MVS2]WCUR

#If WAFFMNT = 1
#        WAFFMNT = 2
#        WCUR    = GCUR
#Else    WAFFMNT = 1
#        WCUR    = GSYSCUR
#Endif
#------------------------------------------#
# recherche du cours conversion            #
# entre ancienne devise et devise demandée #
#------------------------------------------#
#If ANC_CUR <> WCUR
#     Call COURDEV(ANC_CUR,WCUR,GCHGTYP,GHIDATE,WCOURS,SPSTAT) From TRTDIV
#Else WCOURS = 1
#Endif
#------------------------------------------#
# conversion des montants                  #
# entre ancienne devise et devise demandée #
#------------------------------------------#

Local Decimal WMONTORG (0..7)
Local Decimal WMONTDES (0..7) 
WMONTORG (0) = [M:MVS2]ORDAMT
WMONTORG (1) = [M:MVS2]RCPAMT
WMONTORG (2) = [M:MVS2]INVAMT
WMONTORG (3) = [M:MVS2]BILAMT (0)
WMONTORG (4) = [M:MVS2]BILAMT (1)
WMONTORG (5) = [M:MVS2]BILAMT (2)
WMONTORG (6) = [M:MVS2]BLCAMT 
WMONTORG (7) = [M:MVS2]WOSTAUZ 
 
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(0),WMONTDES(0),SPSTAT) From TRTDEV
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(1),WMONTDES(1),SPSTAT) From TRTDEV
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(2),WMONTDES(2),SPSTAT) From TRTDEV
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(3),WMONTDES(3),SPSTAT) From TRTDEV
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(4),WMONTDES(4),SPSTAT) From TRTDEV
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(5),WMONTDES(5),SPSTAT) From TRTDEV
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(6),WMONTDES(6),SPSTAT) From TRTDEV
Call CONVERT(ANC_CUR,WCUR,GCUR,GCHGTYP,datesyst,WMONTORG(7),WMONTDES(7),SPSTAT) From TRTDEV
 
[M:MVS2]ORDAMT     = WMONTDES (0)
[M:MVS2]RCPAMT     = WMONTDES (1)
[M:MVS2]INVAMT     = WMONTDES (2)
[M:MVS2]BILAMT (0) = WMONTDES (3)
[M:MVS2]BILAMT (1) = WMONTDES (4)
[M:MVS2]BILAMT (2) = WMONTDES (5)
[M:MVS2]BLCAMT     = WMONTDES (6)
[M:MVS2]WOSTAUZ    = WMONTDES (7) 

[M:MVS2]TOTAMT=[M:MVS2]ORDAMT+[M:MVS2]RCPAMT+[M:MVS2]INVAMT+[M:MVS2]BILAMT(0)+[M:MVS2]BILAMT(1)+
&              [M:MVS2]BILAMT(2)+[M:MVS2]BLCAMT

[M:MVS2]WCUR = WCUR

Affzo [M:MVS2]1-99 
Return
