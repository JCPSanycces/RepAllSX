#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################################
# IMPBAPTXT : Import Standard des rendez-vous avec zones textes
#             Export Standard des rendez-vous avec zones textes
#----------------------------------------------------------------------
#######################################################################
$ACTION
Case ACTION 
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_TAB
 When "EXP_OUVRE"     : Gosub EXP_OUVRE  
 When "EXPORT"        : Gosub EXPORT 
 When "EXP_ZONE"      : Gosub EXP_ZONE 
Endcase

Return

##########################################################################################################
#                        IMPORT
#######################################################################

$IMP_OUVRE
If !clalev([F:HD4]) : Local File HD4CLOB [HD4] : Endif
If !clalev([F:HD6]) : Local File HD6CLOB [HD6] : Endif


Gosub OUVRE_TEXTE

Return

##########################################################################################################
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1 
  When "EXP_OUVRE"    : G_EXPORT=1 
Endcase

#     entete *71 à *78 / pied *81 à *88 / ligne *91 à *98
#     les zones TSTCHAMP  1 à  8 determinent description
#     les zones TSTCHAMP 11 à 18 compte rendu
#     les zones TSTCHAMP 21 à 28 determinent le detail
# lignes description (BAP)
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="BAP*71" : TSTCHAMP(2) ="BAP*72" : TSTCHAMP(3) ="BAP*73" : TSTCHAMP(4) ="BAP*74"
TSTCHAMP(5) ="BAP*75" : TSTCHAMP(6) ="BAP*76" : TSTCHAMP(7) ="BAP*77" : TSTCHAMP(8) ="BAP*78"

# lignes compte rendu
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="BAP*81" : TSTCHAMP(12)="BAP*82" : TSTCHAMP(13)="BAP*83" : TSTCHAMP(14)="BAP*84"
TSTCHAMP(15)="BAP*85" : TSTCHAMP(16)="BAP*86" : TSTCHAMP(17)="BAP*87" : TSTCHAMP(18)="BAP*88"

Gosub  OUVRE_TEXTE From TRTX3IMP

Return

##########################################################################################################
#   Lecture d'un enregistrement

$IMPORT
Local Integer OKCHAMP
Local Integer I

Gosub IMPORT_TEXTE

#
Case IMPFIC
    When "BAP"
        If GREP="C"
            [M:BAP1]APTORITYP=4
        Endif
Endcase

Return

#----------------------------------------------------------------------
$IMPORT_TEXTE

Case IMPFIC
  When "BAP"

       G_ZON_CLOB ="[M:BAP1]FULOBJ"
       Raz [M:ITC]T_CLE_CLOB(1) 
       [M:ITC]LIGGIMP(0)=GIMP(71) : [M:ITC]LIGGIMP(1)=GIMP(72) : [M:ITC]LIGGIMP(2)=GIMP(73)
       [M:ITC]LIGGIMP(3)=GIMP(74) : [M:ITC]LIGGIMP(4)=GIMP(75) : [M:ITC]LIGGIMP(5)=GIMP(76)
       [M:ITC]LIGGIMP(6)=GIMP(77) : [M:ITC]LIGGIMP(7)=GIMP(78) 
       [M:ITC]NBGIMP=8
       Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
       Gosub ECR_TEXTE From TRTX3IMP
  
       G_ZON_CLOB ="[M:BAP4]FULRPO"
       Raz [M:ITC]T_CLE_CLOB(1) 
       [M:ITC]LIGGIMP(0)=GIMP(81) : [M:ITC]LIGGIMP(1)=GIMP(82) : [M:ITC]LIGGIMP(2)=GIMP(83)
       [M:ITC]LIGGIMP(3)=GIMP(84) : [M:ITC]LIGGIMP(4)=GIMP(85) : [M:ITC]LIGGIMP(5)=GIMP(86)
       [M:ITC]LIGGIMP(6)=GIMP(87) : [M:ITC]LIGGIMP(7)=GIMP(88) 
       [M:ITC]NBGIMP=8
       Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
       Gosub ECR_TEXTE From TRTX3IMP

 

Endcase

Return

#######################################################################

$IMP_ZONE
#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
Gosub TRT_IMP_ZONE

Return

#######################################################################

$IMP_TAB
#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
Return

#------------------------------------------------------------------
# Traitements de IMP_ZONE et IMP_TAB 
#------------------------------------------------------------------
$TRT_IMP_ZONE
Case IMPFIC
  When ""
    #----------------------------------------------------------#
Endcase
Return





##########################################################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE
If !clalev([F:HD4]) : Local File HD4CLOB [HD4] : Endif
If !clalev([F:HD6]) : Local File HD6CLOB [HD6] : Endif


#--- pour les textes
Gosub OUVRE_TEXTE
#---

Return

#######################################################################

$EXPORT
Case EXPFIC

  When "BAP"
    Read [HD6] HD60 = [F:BAP]NUMFULOBJ;"BAPOBJ"
    If fstat=0
       If [F:HD6]CLOB<>""
            G_ZON_CLOB="[F:HD6]CLOB"
            Raz G_CLE_CLOB
            Gosub EXP_TEXTE From TRTX3IMP 
            GIMP(71)=[M:ITC]LIGGIMP(0) : GIMP(72)=[M:ITC]LIGGIMP(1) : GIMP(73)=[M:ITC]LIGGIMP(2)
            GIMP(74)=[M:ITC]LIGGIMP(3) : GIMP(75)=[M:ITC]LIGGIMP(4) : GIMP(76)=[M:ITC]LIGGIMP(5) 
            GIMP(77)=[M:ITC]LIGGIMP(6) : GIMP(78)=[M:ITC]LIGGIMP(7) 
       Endif
    Endif 

    Read [HD4] HD40 = [F:BAP]NUMFULRPO;"BAPRPO"
    If fstat=0
       If [F:HD4]CLOB<>""
            G_ZON_CLOB="[F:HD4]CLOB"
            Raz G_CLE_CLOB
            Gosub EXP_TEXTE From TRTX3IMP 
            GIMP(81)=[M:ITC]LIGGIMP(0) : GIMP(82)=[M:ITC]LIGGIMP(1) : GIMP(83)=[M:ITC]LIGGIMP(2)
            GIMP(84)=[M:ITC]LIGGIMP(3) : GIMP(85)=[M:ITC]LIGGIMP(4) : GIMP(86)=[M:ITC]LIGGIMP(5) 
            GIMP(87)=[M:ITC]LIGGIMP(6) : GIMP(88)=[M:ITC]LIGGIMP(7) 
       Endif
    Endif 


Endcase

Return

#######################################################################

$EXP_ZONE

Case EXPZON
  When "GIMP(3)"
  When Default

Endcase

Return


#######################################################################


