#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
#######################################################################################
$GENERALLEDGER

#Issue 21158 – 2017-03-27  by MADOR - As an accountant I want to export correctly
#Issue X3-31864 - 2017-04-27 by MRDAB: default values changed
#the data regarding taxonomy codes
Case [F:LED]LEDTYPE
     When 1 : [L]GLEDTYPE = "NA"
     When 2 : [L]GLEDTYPE = "S"
     When 3 : [L]GLEDTYPE = "N"
     When 4 : [L]GLEDTYPE = "M"
     When 5 : [L]GLEDTYPE = "O"
     When Default : [L]GLEDTYPE = "NA"
Endcase
#Issue end

[L]FISCALYEAR = [L]EXE

[L]GLTCRIT = '[F:BAL]LEDTYP=[L]LEDT & [F:BAL]CPY=[L]SOC & [F:BAL]FCY="" & [F:BAL]FIY=[L]FISCALYEAR & [F:BAL]BPR=""'

# Issue X3-27059 - 2017-03-29 by MANOW
If [L]SAFTDET = 2
[L]GLTCRIT_DET2 = '[F:BAL]LEDTYP=[L]LEDT & [F:BAL]CPY=[L]SOC & [F:BAL]FCY="" & [F:BAL]FIY=[L]FISCALYEAR'
Else
[L]GLTCRIT_DET2 = '[F:BAL]LEDTYP=[L]LEDT & [F:BAL]CPY=[L]SOC & [F:BAL]FCY="" & [F:BAL]FIY=[L]FISCALYEAR & [F:BAL]BPR=""'
Endif
# End Issue X3-27059

Call GETPERSOC([L]SOC,[L]LEDT,[L]ENDDATE,[L]EXE ,[L]GLTPER) From CPTSUB
Call DATEXE([L]SOC,[L]LEDT,[L]EXE,[L]STRFYDAT,[L]ENDFYDAT) From CPTSUB
Call GETPERSOC([L]SOC,[L]LEDT,[L]ENDFYDAT,[L]GLTLASTEXE,[L]GLTLASTPER) From CPTSUB

[L]GLTC1 = ""

If [L]ISSAFTVERCURRENT = 1
  Wrseq '<GeneralLedgerAccounts>'  Using [SAFT]
  AUXTAGNAM = 'TaxonomyReference'  : AUXTAGVAL = [L]GLEDTYPE  : Gosub WRITETAG From SAFTGENPORTG
Endif

Filter [F:GRY] Where [F:GRY]PYM =  [L]PYR Order By [F:GRY]GRU Asc
For [F:GRY]
    [L]GLTDET = 0

# Issue X3-27059 - 2017-03-29 by MANOW
  If [L]GLTC1 <> [F:GRY]GRU
    [L]GLTC2 = [F:GRY]GRU
    [L]GLTGRCAT= ""

    #Trata as contas de detalhe propriamente ditas, selecionado todas as contas entre o grupo anterior e o actual
    #[ENG - by MANOW] Handles actual accounts with details, selecting all accounts between the previous and current group
    Gosub CONTAS_DET2

    Read [GAC]GAC0=[L]COA;[L]GLTC2
    If fstat
      Gosub CONTA_ACUM
    Else
      #para quando o grupo está definido até ao nível da conta. Não será o mais normal, mas pode acontecer.
      #Neste caso o grupo tem de ser tratado como conta e não como grupo
      #[ENG - by MANOW] When group is set to account level. It will not be normal thing but it happen.
      #[ENG - by MANOW] In this case group has to be treated as account, not as group.
      Gosub CONTAS_DET
    Endif

    [L]GLTC1 = [F:GRY]GRU
  Endif
# End While doing Issue X3-27059

Next
Filter [F:GRY]

Gosub CONTAS_DET2

If [L]ISSAFTVERCURRENT = 1 : Wrseq '</GeneralLedgerAccounts>' Using [SAFT]  : Endif

Return
#######################################################################################
#######################################################################################
$CONTA_ACUM_SUB1
  #Inicio do periodo
  #[ENG - by MANOW] Period beginning.
  If [L]GLTACCDEB > [L]GLTACCCRE
   [L]GLTACCDEB = [L]GLTACCDEB - [L]GLTACCCRE
   [L]GLTACCCRE = 0
  Else
   [L]GLTACCCRE = [L]GLTACCCRE - [L]GLTACCDEB
   [L]GLTACCDEB = 0
  Endif
  [L]GLTOPDEBBALA += [L]GLTACCDEB
  [L]GLTOPCREBALA += [L]GLTACCCRE

  #Fim do periodo de extracao
  #[ENG - by MANOW] End of period extract .
  If [L]GLTACCCLDEB > [L]GLTACCCLCRE
   [L]GLTACCCLDEB = [L]GLTACCCLDEB - [L]GLTACCCLCRE
   [L]GLTACCCLCRE = 0
  Else
   [L]GLTACCCLCRE = [L]GLTACCCLCRE - [L]GLTACCCLDEB
   [L]GLTACCCLDEB = 0
  Endif
  [L]GLTCLDEBBALA += [L]GLTACCCLDEB
  [L]GLTCLCREBALA += [L]GLTACCCLCRE
Return
#######################################################################################
#######################################################################################
$CONTA_ACUM_SUM_CLO_PER
  #Soma dos periodos até ao periodo da data fim
  #[ENG - by MANOW] Sum of periods until period end date.
  For I=0 To [L]GLTPER
    [L]GLTACCCLDEB   += [F:BAL]DEBLED(I)
    [L]GLTACCCLCRE   += [F:BAL]CDTLED(I)
  Next

  #Se a data fim for o ultimo periodo, acrecenta o periodo do apuramento de resultados
  #[ENG - by MANOW] If the end date was the last period, add RAZ the period of results tabulation
  If [L]ENDDATE=[L]ENDFYDAT
    [L]GLTACCCLDEB   += [F:BAL]DEBLED([L]GLTLASTPER+1)
    [L]GLTACCCLCRE   += [F:BAL]CDTLED([L]GLTLASTPER+1)
  Endif
Return
#######################################################################################
#######################################################################################
$CONTA_ACUM_SUM_CLO_PER2
  #Sum of the periods until end date period
  For I=0 To [L]GLTPER
    [L]GLTCLDEBBALA   += [F:BAL]DEBLED(I)
    [L]GLTCLCREBALA   += [F:BAL]CDTLED(I)
  Next

  #If end date = last period, add RAS
  If [L]ENDDATE=[L]ENDFYDAT
    [L]GLTCLDEBBALA   += [F:BAL]DEBLED([L]GLTLASTPER+1)
    [L]GLTCLCREBALA   += [F:BAL]CDTLED([L]GLTLASTPER+1)
  Endif
Return
#######################################################################################
#######################################################################################
$CONTA_ACUM_SUB2
# Contas de detalhe - Apenas pretendemos o Saldo
#[ENG - by MANOW] Detail Accounts - Only balance wanted.
If [L]GLTOPDEBBALA > [L]GLTOPCREBALA
  [L]GLTOPDEBBALA = [L]GLTOPDEBBALA - [L]GLTOPCREBALA
  [L]GLTOPCREBALA = 0
Else
  [L]GLTOPCREBALA = [L]GLTOPCREBALA - [L]GLTOPDEBBALA
  [L]GLTOPDEBBALA = 0
Endif

If [L]GLTCLDEBBALA > [L]GLTCLCREBALA
  [L]GLTCLDEBBALA = [L]GLTCLDEBBALA - [L]GLTCLCREBALA
  [L]GLTCLCREBALA = 0
Else
  [L]GLTCLCREBALA = [L]GLTCLCREBALA - [L]GLTCLDEBBALA
  [L]GLTCLDEBBALA = 0
Endif
Return
#######################################################################################
#######################################################################################
$CONTA_ACUM
Gosub RAZ_GLT From SAFTGENPOR

[L]GLTDET         = 0 #Not detail account
[L]GLTACCOUNTID = [L]GLTC2

# Issue X3-27059 - 2017-03-29 by MANOW
[L]GLTACCOUNTID_GROUP = [L]GLTC2
# End Issue X3-27059

#VAVIL * 28062017 * colocar a respetiva piramide
#Call LECTEXTRA([L]GLTACCODESCR,"GACCGRUPYM","DESTRA","POR",[L]GLTACCOUNTID) From ATEXTRA
# Issue X3-99026 by MRDAB
Call LECTEXTRA_POR([L]GLTACCODESCR,"GACCGRUPYM","DESTRA",[L]PYR,[L]GLTACCOUNTID) From SAFTGENPOR
# Issue X3-99026 end

For [F:BAL] Where pat([F:BAL]ACC,[L]GLTC2+"*") & evalue([L]GLTCRIT)
  [L]GLTACC = [F:BAL]ACC
  If [L]GLTACC <> [L]GLTACCPRV & [L]GLTACCPRV <> ""
    Gosub CONTA_ACUM_SUB1

    [L]GLTACCDEB     = [F:BAL]DEBLED(0)
    [L]GLTACCCRE     = [F:BAL]CDTLED(0)

    #inicializar estas variáveis quando passamos de conta
    #[ENG - by MANOW] Initialize variables below for each account.
    [L]GLTACCCLDEB   = 0
    [L]GLTACCCLCRE   = 0

    Gosub CONTA_ACUM_SUM_CLO_PER

  Else
    [L]GLTACCDEB     += [F:BAL]DEBLED(0)
    [L]GLTACCCRE     += [F:BAL]CDTLED(0)

    Gosub CONTA_ACUM_SUM_CLO_PER

  Endif

  [L]GLTACCPRV   = [L]GLTACC
Next

#Ultimo registo da BALANCE para o inicio do Perido
#Ultimo registo da BALANCE para o fim do Perido
#[ENG - by MANOW] Last registration of BALANCE for period beginning.
#[ENG - by MANOW] Last registration of BALANCE for period end.
Gosub CONTA_ACUM_SUB1

Gosub GROUP_VALUES
#Issue X3-91507 by MRDAB
Gosub VALIDATE_VALUES
#Issue end
Gosub WRITE_GENLED

Return
#######################################################################################
#######################################################################################
$CONTAS_DET

Gosub RAZ_GLT From SAFTGENPOR
#é conta de detalhe
#[ENG - by MANOW] It is detail account.
[L]GLTDET         = 1
[L]GLTACCOUNTID = [L]GLTC2

# Issue X3-27059 - 2017-03-29 by MANOW
[L]GLTACCOUNTID_GROUP  = [L]GLTC2
# End issue X3-27059

#VAVIL * 28062017 * colocar o respetivo plano
#Call LECTEXTRA([L]GLTACCODESCR,"GACCOUNT","DESTRA","POR",[L]GLTACCOUNTID) From ATEXTRA
# Issue X3-99026 by MRDAB
Call LECTEXTRA_POR([L]GLTACCODESCR,"GACCOUNT","DESTRA",[L]COA,[L]GLTACCOUNTID) From SAFTGENPOR
# Issue X3-99026 end

For [F:BAL] Where pat([F:BAL]ACC,GLTC2+"*") & evalue([L]GLTCRIT)

  [L]GLTOPDEBBALA += [F:BAL]DEBLED(0)
  [L]GLTOPCREBALA += [F:BAL]CDTLED(0)

  Gosub CONTA_ACUM_SUM_CLO_PER2
Next

Gosub CONTA_ACUM_SUB2

Gosub GROUP_VALUES
#Issue X3-91507 by MRDAB
Gosub VALIDATE_VALUES
#Issue end
Gosub WRITE_GENLED

Return
#######################################################################################
#######################################################################################
$CONTAS_DET2
Link [F:GAC] With [F:CL2]CLS0=[F:CPY]LEG;[F:GAC]CLSCOD As [LNK2]
& Where [F:GAC]ACC > [L]GLTC1 & [F:GAC]ACC < GLTC2 & [F:GAC]COA =[L]COA & [F:CL2]TYP=1

For [F:LNK2]
  Gosub RAZ_GLT From SAFTGENPOR
  #é conta de detalhe
  #[ENG - by MANOW] It is detail account.
  [L]GLTDET         = 1
  [L]GLTACCOUNTID = [F:GAC]ACC

  #Issue X3-40802 – 2017-07-12  by VAVIL - Entry point allow by specific to use another fields to get the taxonomy codes
  [L]GTAXONCODE    = ""
  GPOINT  = "SAFTPTTAXON" : Gosub ENTREE      From EXEFNC
  If [L]GTAXONCODE = ""
    [L]GTAXONCODE = [F:GAC]RPTCODDEB(0)
    If [F:GAC]RPTCODDEB(0) <> [F:GAC]RPTCODCDT(0)
        Call ECR_TRACE(func AFNC.MES1(mess(235,7711,1),[L]GLTACCOUNTID), 1) From GESECRAN
    Endif
  Endif
  #End issue X3-40802

  # Issue X3-27059 - 2017-03-29 by MANOW
  [L]GLTACCOUNTID_GROUP = [F:GAC]ACC
  # End Issue X3-27059

  #VAVIL * 28062017 * colocar o respetivo plano
  #Call LECTEXTRA([L]GLTACCODESCR,"GACCOUNT","DESTRA","POR",[L]GLTACCOUNTID) From ATEXTRA
  # Issue X3-99026 by MRDAB
  Call LECTEXTRA_POR([L]GLTACCODESCR,"GACCOUNT","DESTRA",[L]COA,[L]GLTACCOUNTID) From SAFTGENPOR
  # Issue X3-99026 end

  # Issue X3-27059 - 2017-04-03 by MANOW/MRDAB
  [L]BALBPRDET = 0
  Filter [F:BAL] Where [F:BAL]ACC= [L]GLTACCOUNTID & evalue([L]GLTCRIT_DET2) Order By [F:BAL]BPR Asc
  [L]BALBPRPREV = "Not Assigned"

  For [F:BAL]
      If [F:BAL]BPR <> [L]BALBPRPREV & [L]BALBPRPREV <> "Not Assigned"

        If [L]BALBPRPREV <> ""
          Gosub GROUP_VALUES
          #Issue X3-91507 by MRDAB
          Gosub VALIDATE_VALUES
          #Issue end
          Gosub WRITE_GENLED
        Endif

        If [F:BAL]BPR <> [L]BALBPRPREV
          [L]GLTOPDEBBALA = 0
          [L]GLTOPCREBALA = 0
          [L]GLTCLDEBBALA = 0
          [L]GLTCLCREBALA = 0
        Endif

      Endif

      If [L]SAFTDET = 2  and [F:BAL]BPR <> ""
        Gosub CONTAS_DET2_BP_DETAILS
      Elsif [L]BALBPRDET = 0
        Gosub CONTAS_DET2_GENERAL
      Endif
      [L]BALBPRPREV = [F:BAL]BPR
  Next

  Gosub CONTA_ACUM_SUB2

  If [L]BALBPRDET = 0 | [F:BAL]BPR <> ""
    Gosub GROUP_VALUES
    #Issue X3-91507 by MRDAB
    Gosub VALIDATE_VALUES
    #Issue end
    Gosub WRITE_GENLED
  Endif

  Filter [F:BAL]
  # End Issue X3-27059
Next

Gosub RAZ_GLT From SAFTGENPOR
Close File [LNK2]
Return
#######################################################################################
#######################################################################################
# Issue X3-27059 - 2017-04-03 by MANOW/MRDAB
$CONTAS_DET2_BP_DETAILS
  [L]BALBPRDET = 1
  [L]GLTACCOUNTID = [F:GAC]ACC + [F:BAL]BPR
  [L]GLTACCOUNTID_GROUP = [F:GAC]ACC
  #é conta de detalhe
  #[ENG - by MANOW] It is detail account.
  [L]GLTDET = 1

  Gosub CONTA_ACUM_SUM_CLO_PER2

  Gosub CONTA_ACUM_SUB2
Return
# End Issue X3-27059
#######################################################################################
#######################################################################################
# Issue X3-27059 - 2017-03-29 by MANOW
$CONTAS_DET2_GENERAL
  [L]GLTOPDEBBALA += [F:BAL]DEBLED(0)
  [L]GLTOPCREBALA += [F:BAL]CDTLED(0)

  Gosub CONTA_ACUM_SUM_CLO_PER2
Return
# End Issue X3-27059
#######################################################################################
#######################################################################################
$GROUP_VALUES
# Verificacao e escrita do GroupingCategory
#[ENG - by MANOW] Check and write GroupingCategory
# Issue X3-27059 - 2017-03-29 by MANOW
Read [GAC]GAC0=[L]COA;[L]GLTACCOUNTID_GROUP
# End Issue X3-27059
If fstat
  [L]GLTGRCAT="GA"
  If len([L]GLTACCOUNTID)=2
    [L]GLTGRCAT="GR"
  Endif
Else
    [L]GLTGRCAT="GM"

    [L]GTAXONCODE =""
    #Issue X3-40802 – 2017-07-12  by VAVIL - Entry point allow by specific to use another fields to get the taxonomy codes
    GPOINT  = "SAFTPTTAXON" : Gosub ENTREE     From EXEFNC
    #End issue X3-40802
    If [L]GTAXONCODE = ""
      [L]GTAXONCODE = [F:GAC]RPTCODDEB(0)
      If [F:GAC]RPTCODDEB(0) <> [F:GAC]RPTCODCDT(0)
        Call ECR_TRACE(func AFNC.MES1(mess(235,7711,1),[L]GLTACCOUNTID), 1) From GESECRAN
      Endif
    Endif
Endif

# Issue X3-27059 - 2017-03-29 by MANOW
If len([L]GLTACCOUNTID_GROUP)=1
# End Issue X3-27059
    [L]GLTGRCAT="GR"
Endif

#Verificacao e escrita do GroupingCode
#[ENG - by MANOW] Check and write GroupingCode
# Issue X3-27059 - 2017-03-29 by MANOW
If len([L]GLTACCOUNTID_GROUP)<>1
  Read [F:GR2]GRY2=[L]PYR;[L]GLTACCOUNTID_GROUP
# End Issue X3-27059
  If !fstat
    [L]GLTGRGRP = [F:GR2]GRU
  Else
    # Issue X3-27059 - 2017-03-29 by MANOW
    Filter [F:GYK] Where PYM=[L]PYR & ACC=[L]GLTACCOUNTID_GROUP
    # End Issue X3-27059
    Read [F:GYK]GYK0 Last
    If !fstat
      [L]GLTGRGRP = [F:GYK]GRU
    Else
      [L]GLTGRGRP = ""
    Endif
    Filter [F:GYK]
  Endif
Else
  [L]GLTGRGRP = ""
Endif

Return
#######################################################################################
#######################################################################################
$WRITE_GENLED
#Issue 21158 – 2017-03-27  by MADOR - As an accountant I want to export correctly
#the data regarding taxonomy codes
If [L]ISSAFTVERCURRENT <> 1

    Wrseq '<GeneralLedger>' Using [SAFT]
    AUXTAGNAM = 'AccountID'               : AUXTAGVAL = [L]GLTACCOUNTID  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'AccountDescription'      : AUXTAGVAL = [L]GLTACCODESCR  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'OpeningDebitBalance'     : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTOPDEBBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'OpeningCreditBalance'    : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTOPCREBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'ClosingDebitBalance'     : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTCLDEBBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'ClosingCreditBalance'    : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTCLCREBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'GroupingCategory' : AUXTAGVAL = [L]GLTGRCAT  : Gosub WRITETAG From SAFTGENPORTG
    If [L]GLTGRGRP <> ""
      AUXTAGNAM = 'GroupingCode'     : AUXTAGVAL = [L]GLTGRGRP  : Gosub WRITETAG From SAFTGENPORTG
    Endif

    Wrseq '</GeneralLedger>' Using [SAFT]
    [L]RECSWRI += 1

Else
  #Issue X3-31864 - 2017-04-27 by MRDAB: section to be written only when account at least 2 digigts length
  #Issue X3-90548 - Account TOTAL removed from extract - we allow only number accounts
  If len([L]GLTACCOUNTID) > 1 & pat([L]GLTACCOUNTID, string$(len([L]GLTACCOUNTID), "#"))
  #Issue X3-90548 end
    Wrseq '<Account>' Using [SAFT]
    AUXTAGNAM = 'AccountID'               : AUXTAGVAL = [L]GLTACCOUNTID  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'AccountDescription'      : AUXTAGVAL = [L]GLTACCODESCR  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'OpeningDebitBalance'     : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTOPDEBBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'OpeningCreditBalance'    : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTOPCREBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'ClosingDebitBalance'     : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTCLDEBBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'ClosingCreditBalance'    : AUXTAGVAL = ctrans(vireblc(format$("N20.2", ar2([L]GLTCLCREBALA)),4),",",".")  : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = 'GroupingCategory' : AUXTAGVAL = [L]GLTGRCAT  : Gosub WRITETAG From SAFTGENPORTG
    If [L]GLTGRGRP <> "" & len([L]GLTGRGRP)> 1
      AUXTAGNAM = 'GroupingCode'     : AUXTAGVAL = [L]GLTGRGRP  : Gosub WRITETAG From SAFTGENPORTG
    Endif
    #Issue X3-31864 - 2017-04-27 by MRDAB: when not empty and GroupingCategory equals GM
    If [L]GTAXONCODE <> "" & [L]GLTGRCAT = "GM"
      AUXTAGNAM = 'TaxonomyCode' : AUXTAGVAL = [L]GTAXONCODE  : Gosub WRITETAG From SAFTGENPORTG
    Endif
    #End issue X3-31864

    Wrseq '</Account>' Using [SAFT]
    [L]RECSWRI += 1
  Endif
  #End issue X3-31864
Endif
#Issue end

Return
#######################################################################################
#######################################################################################
$VALIDATE_VALUES

#Issue X3-91507 by MRDAB - checks for actual accounts
If [L]GLTGRCAT = "GM"

  # Check of the taxonomy code
  If [L]GTAXONCODE = ""
    Call ECR_TRACE(func AFNC.MES1(mess(241,7711,1), [L]GLTACCOUNTID), 1) From GESECRAN
  Endif

  # Check of the nature of balance
  If ([F:GAC]SNSBLC = 1 & ([L]GLTOPCREBALA > 0 | [L]GLTCLCREBALA > 0)) | ([F:GAC]SNSBLC = 2 & ([L]GLTOPDEBBALA > 0 | [L]GLTCLDEBBALA > 0))
    Call ECR_TRACE(func AFNC.MES1(mess(242,7711,1), [L]GLTACCOUNTID), 1) From GESECRAN
  Endif

Endif
#Issue end

Return
#######################################################################################
#######################################################################################

