# FGR 16/11/2009 : X3SUIVI57491 (début)
#----------------------------------------------------------------------------------------
$DYN_TRTSTKBTRS
Local Char SZWIN(GLONFEN)
Local Char SZABRFIC(GLONABR)
Local Char SZONGLET(250)

  SZABRFIC = 'BTS'
  # 51
  SZWIN = 'OMGL'
  SZONGLET = '"[MGL0]","[MGL1]","[MGL2]","[MGL3]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ51, IREQ51) From FUNSALTRS
  # 52
  SZWIN = 'OMDL'
  SZONGLET = '"[MDL0]","[MDL1]","[MDL2]","[MDL3]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ52, IREQ52) From FUNSALTRS
  # 53
  SZWIN = 'OMRL'
  SZONGLET = '"[MRL0]","[MRL1]","[MRL2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ53, IREQ53) From FUNSALTRS
Return

#----------------------------------------------------------------------------------------
$GEN_TRTSTKBTRS
Local Char SZADXIFS
Local Char SZADXIRS
Local Integer IVALIDOK
Local Integer IEXIST
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer NI
# 20 lignes
#  5 colonnes :
#               (0) = Complément "Close Local Mask" et "Default Mask"
#               (1) = Listes des autres Mask à ouvrir
#               (2) = Complément affectation classe [F] dans classe [M]
Local Char SZREQ51(250)(20,5)
Local Char SZREQ52(250)(20,5)
Local Char SZREQ53(250)(20,5)
Local Integer IREQ51
Local Integer IREQ52
Local Integer IREQ53
  #------------------------------------------
  Raz SZREQ51
  Raz SZREQ52
  Raz SZREQ53
  IREQ51 = 0
  IREQ52 = 0
  IREQ53 = 0
  #------------------------------------------
  Gosub DYN_TRTSTKBTRS
  #------------------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #------------------------------------------
  SZPROGNAME = "WSTKB" + num$(adxpid)
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", APPLI)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", APPLI)
  #------------------------------------------
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [TRS_]
  #------------------------------------------
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"  Using [TRS_]
  Wrseq "#Traitement généré pour les transactions STK-B en masse"  Using [TRS_]
  Wrseq "$TRANSAC_STKB"  Using [TRS_]
  Wrseq 'For [BTS] Where' - CRITERES  Using [TRS_]
  Wrseq '    If [F:BTS]BTSTYP <> WTYP'  Using [TRS_]
  Wrseq '        Case WTYP'  Using [TRS_]
  Wrseq '            When 51 : Close Local Mask [MGL0],[MGL1],[MGL2],[MGL3]' + SZREQ51(0,0)  Using [TRS_]
  Wrseq '            When 52 : Close Local Mask [MDL0],[MDL1],[MDL2],[MDL3]' + SZREQ52(0,0)  Using [TRS_]
  Wrseq '            When 53 : Close Local Mask [MRL0],[MRL1],[MRL2]' + SZREQ53(0,0)  Using [TRS_]
  Wrseq '        Endcase'  Using [TRS_]
  Wrseq '        Case [F:BTS]BTSTYP'  Using [TRS_]
  Wrseq '            When 51: If clalev ([M:MGL0])<=0 : Local Mask =APPLI+".MGL0" [MGL0] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MGL1])<=0 : Local Mask =APPLI+".MGL1" [MGL1] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MGL2])<=0 : Local Mask =APPLI+".MGL2" [MGL2] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MGL3])<=0 : Local Mask =APPLI+".MGL3" [MGL3] : Endif'  Using [TRS_]
  For NI = 0 To IREQ51-1
    Wrseq '                ' + SZREQ51(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 52: If clalev ([M:MDL0])<=0 : Local Mask =APPLI+".MDL0" [MDL0] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MDL1])<=0 : Local Mask =APPLI+".MDL1" [MDL1] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MDL2])<=0 : Local Mask =APPLI+".MDL2" [MDL2] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MDL3])<=0 : Local Mask =APPLI+".MDL3" [MDL3] : Endif'  Using [TRS_]
  For NI = 0 To IREQ52-1
    Wrseq '                ' + SZREQ52(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 53: If clalev ([M:MRL0])<=0 : Local Mask =APPLI+".MRL0" [MRL0] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MRL1])<=0 : Local Mask =APPLI+".MRL1" [MRL1] : Endif'  Using [TRS_]
  Wrseq '                     If clalev ([M:MRL2])<=0 : Local Mask =APPLI+".MRL2" [MRL2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ53-1
    Wrseq '                ' + SZREQ53(NI,1)  Using [TRS_]
  Next NI
  Wrseq '         Endcase'  Using [TRS_]
  Wrseq '         WTYP=[F:BTS]BTSTYP'  Using [TRS_]
  Wrseq '    Endif'  Using [TRS_]
  Wrseq '    Call DEBTRANS From GLOCK'  Using [TRS_]
  Wrseq '    Trbegin [BTS]'  Using [TRS_]
  Wrseq '        Case [F:BTS]BTSTYP'  Using [TRS_]
  Wrseq '            When 51: [M:MGL0]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MGL1]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MGL2]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MGL3]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ51(0,2)  Using [TRS_]
  Wrseq '                     MASKREF = "MFGBENCH"'  Using [TRS_]
  Wrseq '                     Gosub TRT_ECRAN From SUBMGL'  Using [TRS_]
  Wrseq '            When 52: [M:MDL0]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MDL1]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MDL2]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MDL3]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ52(0,2)  Using [TRS_]
  Wrseq '                     MASKREF = "MFGBENCHD"'  Using [TRS_]
  Wrseq '                     Gosub TRT_ECRAN From SUBMDL'  Using [TRS_]
  Wrseq '            When 53: [M:MRL0]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MRL1]=[F:BTS]'  Using [TRS_]
  Wrseq '                     [M:MRL2]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ53(0,2)  Using [TRS_]
  Wrseq '                     If [F:BTS]PLANNER = 2                     : [M:MRL1]USRPRF = 1 : MASKREF = "MFGPICK"  : Endif'  Using [TRS_]
  Wrseq '                     If [F:BTS]APPBUY  = 2 | [F:BTS]APPBUY = 2 : [M:MRL1]USRPRF = 2 : MASKREF = "MFGPICKA" : Endif'  Using [TRS_]
  Wrseq '                     If [F:BTS]BUYER   = 2 | [F:BTS]INTBUY = 2 : [M:MRL1]USRPRF = 3 : MASKREF = "MFGPICKA" : Endif'  Using [TRS_]
  Wrseq '                     If [F:BTS]PLANNER = 2 & [F:BTS]BUYER=2    : [M:MRL1]USRPRF = 4 : MASKREF = "MFGPICK"  : Endif'  Using [TRS_]
  Wrseq '                     Gosub TRT_ECRAN From SUBMRL'  Using [TRS_]
  Wrseq '        Endcase'  Using [TRS_]
  Wrseq '        If GOK < 1'  Using [TRS_]
  Wrseq '            Call ECR_TRACE(mess(21,123,1)-mess([F:BTS]BTSTYP-50,753,1)-[F:BTS]BTSNUM,1) From GESECRAN'  Using [TRS_]
  Wrseq '            Rollback'  Using [TRS_]
  Wrseq '        Else'  Using [TRS_]
  Wrseq '            Call ECR_TRACE(mess(14,123,1)-mess([F:BTS]BTSTYP-50,753,1)-[F:BTS]BTSNUM,0) From GESECRAN'  Using [TRS_]
  Wrseq '            Commit'  Using [TRS_]
  Wrseq '        Endif'  Using [TRS_]
  Wrseq 'Next'  Using [TRS_]
  Wrseq 'Return'  Using [TRS_]
  Wrseq ''  Using [TRS_]
  Openo Using [TRS_]
  #------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #------------------------------------------
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, APPLI, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur lors de la génération : on appelle l'ancien pour que ça fonctionne au moins en standard
    # Je ne l'efface pas. Ca permettrait de trouver ce qui ne va pas
    #IEXIST = 1
    #Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Call OLD_VAL_STKTRSB(TYP,NUM,APPLI)
    Return
  Endif
  #------------------------------------------
  Gosub TRANSAC_STKB From =APPLI + "." + SZPROGNAME
  #------------------------------------------
  # A mettre dans l'appelant
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
Return
# FGR 16/11/2009 : X3SUIVI57491 (fin)
#========================================================================================

##############################################################################
# VAL_STKTRS : S/P Validation en masse des transactions stock + plans        #
# -------------------------------------------------------------------------- #
# Subprog VAL_STKTRS (TYP,NUM,APPLI)                                         #
#    TYP  : Type des transactions à valider (1n)                             #
#           0    = Toutes                                                    #
#           1-13 = Transations de stock                                      #
#           51-53= Transactions plans                                        #
#    NUM  : Code de la transaction à valider (3c)                            #
#           "" = Toutes                                                      #
#    APPLI: Nom de l'application à mettre à jour                             #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:SRT]STKTRS   Table des transactions stock                      #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_STKTRS(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI

If TYP = 0 | (TYP >= 1  & TYP <= 13)            : Call VAL_STKTRSA(TYP,NUM,APPLI) : Endif
If TYP = 0 | (TYP >= 51 & TYP <= 53)            : Call VAL_STKTRSB(TYP,NUM,APPLI) : Endif

End

##############################################################################
# VAL_STKTRSA : S/P Validation en masse des transactions de saisie Stock     #
# -------------------------------------------------------------------------- #
# Subprog VAL_STKTRSA (TYP,NUM,APPLI)                                        #
#    TYP  : Type des transactions à valider (1n)                             #
#           0    = Toutes                                                    #
#           1-13 = Transations de stock                                      #
#    NUM  : Code de la transaction à valider (3c)                            #
#           "" = Toutes                                                      #
#    APPLI: Nom de l'application à mettre à jour                             #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:SRT]STKTRS   Table des transactions stock                      #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_STKTRSA(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local Char      WDIE_ABRFIC(3) : WDIE_ABRFIC="PTR"
Local Integer   WDIE_DTRTYP
Local Char      WMODU(3)
Local Integer   WNUM(2)
Local Char      WNOMOBJ(GLONAOB)
Local Char      WNOMTRS(GLONTRS)
Local Shortint  WENAFLG
Local Char      WACSCOD(GLONACS)
Local Char      WLIBEL(30)
Local Integer   LOTACTIV

ACTION="MASSE"
Case TYP
    When 0 :         CRITERES = "1=1"
    When 1 :         CRITERES = "SRTTYP=1"
    When 2 :         CRITERES = "SRTTYP=2"
    When 3 :         CRITERES = "SRTTYP=3"
    When 4 :         CRITERES = "SRTTYP=4"
    When 5 :         CRITERES = "SRTTYP=5"
    When 6 :         CRITERES = "SRTTYP=6"
    When 7 :         CRITERES = "SRTTYP=7"
    When 8 :         CRITERES = "SRTTYP=8"
    When 9 :         CRITERES = "SRTTYP=9"
    When 10:         CRITERES = "SRTTYP=10"
    When 11:         CRITERES = "SRTTYP=11"
    When 12:         CRITERES = "SRTTYP=12"
    When 13:         CRITERES = "SRTTYP=13"
    When Default :   CRITERES = ""
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & SRTNUM=NUM" : Endif
If clalev([F:SRT]) <= 0 : Local File = APPLI+".STKTRS"    [SRT] : Endif
If clalev([F:ACV]) <= 0 : Local File = APPLI+".ACTIV"     [ACV] : Endif
If clalev([F:TST]) <= 0 : Local File = APPLI+".TABSTASTO" [TST] : Endif
Read [ACV] CODACT = "LOT"
If !fstat & [F:ACV]FLACT=2
   LOTACTIV=2
Else
   LOTACTIV=1
Endif

  Gosub GEN_TRTSTKATRS
End

#====================================
Subprog OLD_VAL_STKTRSA(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local Char      WDIE_ABRFIC(3) : WDIE_ABRFIC="PTR"
Local Integer   WDIE_DTRTYP
Local Char      WMODU(3)
Local Integer   WNUM(2)
Local Char      WNOMOBJ(GLONAOB)
Local Char      WNOMTRS(GLONTRS)
Local Shortint  WENAFLG
Local Char      WACSCOD(GLONACS)
Local Char      WLIBEL(30)
Local Integer   LOTACTIV

ACTION="MASSE"
Case TYP
    When 0 :         CRITERES = "1=1"
    When 1 :         CRITERES = "SRTTYP=1"
    When 2 :         CRITERES = "SRTTYP=2"
    When 3 :         CRITERES = "SRTTYP=3"
    When 4 :         CRITERES = "SRTTYP=4"
    When 5 :         CRITERES = "SRTTYP=5"
    When 6 :         CRITERES = "SRTTYP=6"
    When 7 :         CRITERES = "SRTTYP=7"
    When 8 :         CRITERES = "SRTTYP=8"
    When 9 :         CRITERES = "SRTTYP=9"
    When 10:         CRITERES = "SRTTYP=10"
    When 11:         CRITERES = "SRTTYP=11"
    When 12:         CRITERES = "SRTTYP=12"
    When 13:         CRITERES = "SRTTYP=13"
    When Default :   CRITERES = ""
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & SRTNUM=NUM" : Endif
If clalev([F:SRT]) <= 0 : Local File = APPLI+".STKTRS"    [SRT] : Endif
If clalev([F:ACV]) <= 0 : Local File = APPLI+".ACTIV"     [ACV] : Endif
If clalev([F:TST]) <= 0 : Local File = APPLI+".TABSTASTO" [TST] : Endif
Read [ACV] CODACT = "LOT"
If !fstat & [F:ACV]FLACT=2
   LOTACTIV=2
Else
   LOTACTIV=1
Endif

For [SRT] Where evalue(CRITERES)
    If [F:SRT]SRTTYP <> WTYP
        Raz WMODU
        Raz WNOMOBJ
        Case [F:SRT]SRTTYP
            When 1 :
                If WTYP <> 0
#                    Close Local Mask [SRT0],[SRT1],[ETR2]
                Endif
                If clalev ([M:SRT0])<=0 : Local Mask =APPLI+".SRT0" [SRT0] : Endif
                If clalev ([M:SRT1])<=0 : Local Mask =APPLI+".SRT1" [SRT1] : Endif
                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif
            When 2 :
                If WTYP <> 0
#                    Close Local Mask [SOT0],[SOT1]
                Endif
                If clalev ([M:SOT0])<=0 : Local Mask =APPLI+".SOT0" [SOT0] : Endif
                If clalev ([M:SOT1])<=0 : Local Mask =APPLI+".SOT1" [SOT1] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif

            When 3 :
                If WTYP <> 0
#                    Close Local Mask [SCT0],[SCT1],[SCT2]
                Endif
                If clalev ([M:SCT0])<=0 : Local Mask =APPLI+".SCT0" [SCT0] : Endif
                If clalev ([M:SCT1])<=0 : Local Mask =APPLI+".SCT1" [SCT1] : Endif
                If clalev ([M:SCT2])<=0 : Local Mask =APPLI+".SCT2" [SCT2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif

            When 4 :
                If LOTACTIV=2
                    If clalev ([M:SLT0])<=0 : Local Mask =APPLI+".SLT0" [SLT0] : Endif
                    If clalev ([M:SLT1])<=0 : Local Mask =APPLI+".SLT1" [SLT1] : Endif
                    If clalev ([M:SLT2])<=0 : Local Mask =APPLI+".SLT2" [SLT2] : Endif
                Endif
            When 5 :
                If WTYP <> 0
#                    Close Local Mask [SRG0],[SRG2],[ETR2]
                Endif
                If clalev ([M:SRG0])<=0 : Local Mask =APPLI+".SRG0" [SRG0] : Endif
                If clalev ([M:SRG2])<=0 : Local Mask =APPLI+".SRG2" [SRG2] : Endif
                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif

            When 6 :
                If WTYP <> 0
#                    Close Local Mask [SNP0],[SNP1],[SNP2]
                Endif
                If clalev ([M:SNP0])<=0 : Local Mask =APPLI+".SNP0" [SNP0] : Endif
                If clalev ([M:SNP1])<=0 : Local Mask =APPLI+".SNP1" [SNP1] : Endif
                If clalev ([M:SNP2])<=0 : Local Mask =APPLI+".SNP2" [SNP2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif

            When 7:
                If WTYP <> 0
#                    Close Local Mask [PBY0],[PBY1],[ETR2]
                Endif
                If clalev ([M:PBY0])<=0 : Local Mask =APPLI+".PBY0" [PBY0] : Endif
                If clalev ([M:PBY1])<=0 : Local Mask =APPLI+".PBY1" [PBY1] : Endif
                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif

            When 8 :
                If WTYP <> 0
#                    Close Local Mask [SQT0],[SQT1]
                Endif
                If clalev ([M:SQT0])<=0 : Local Mask =APPLI+".SQT0" [SQT0] : Endif
                If clalev ([M:SQT1])<=0 : Local Mask =APPLI+".SQT1" [SQT1] : Endif
            When 9:
                If WTYP <> 0
#                    Close Local Mask [SRO0],[SRO1]
                Endif
                If clalev ([M:SRO0])<=0 : Local Mask =APPLI+".SRO0" [SRO0] : Endif
                If clalev ([M:SRO1])<=0 : Local Mask =APPLI+".SRO1" [SRO1] : Endif
            When 10:
                If WTYP <> 0
#                    Close Local Mask [PRE0],[PRE1]
                Endif
                If clalev ([M:PRE0])<=0 : Local Mask =APPLI+".PRE0" [PRE0] : Endif
                If clalev ([M:PRE1])<=0 : Local Mask =APPLI+".PRE1" [PRE1] : Endif
            When 11:
                If WTYP <> 0
#                    Close Local Mask [SPK0],[SPK1]
                Endif
                If clalev ([M:SPK0])<=0 : Local Mask =APPLI+".SPK0" [SPK0] : Endif
                If clalev ([M:SPK1])<=0 : Local Mask =APPLI+".SPK1" [SPK1] : Endif
            When 12:
                If WTYP <> 0
#                    Close Local Mask [PRT0],[PRT1]
                Endif
                If clalev ([M:PRT0])<=0 : Local Mask =APPLI+".PRT0" [PRT0] : Endif
                If clalev ([M:PRT1])<=0 : Local Mask =APPLI+".PRT1" [PRT1] : Endif


        Endcase
        WTYP=[F:SRT]SRTTYP
    Endif

    WDIE_DTRTYP=[F:SRT]SRTTYP
    Local Char SAVACTION                      # hcb 100298
    SAVACTION = ACTION                        # hcb 100298
    ACTION="OUVRE" : Gosub TRT_DIETRS From SUBDST
    ACTION = SAVACTION                        # hcb 100298
    Call DEBTRANS From GLOCK
    Trbegin [SRT]
        Local Char WAPPLI : WAPPLI = APPLI
        Case [F:SRT]SRTTYP
            When 1:    # Entrées diverses
                [M:SRT0]=[F:SRT]
                [M:SRT1]=[F:SRT]
                [M:ETR2]=[F:SRT]
                WNOMTRS = [M:SRT0]SRTNUM
                WENAFLG = [M:SRT0]ENAFLG
                WACSCOD = [M:SRT0]ACSCOD
                WLIBEL =[M:SRT0]DESAXX
                Gosub TRT_ECRAN From SUBSRT
            When 2  :    # Sorties diverse
                [M:SOT0]=[F:SRT]
                [M:SOT1]=[F:SRT]
                WNOMTRS = [M:SOT0]SRTNUM
                WENAFLG = [M:SOT0]ENAFLG
                WACSCOD = [M:SOT0]ACSCOD
                WLIBEL  = [M:SOT0]DESAXX
                Gosub TRT_ECRAN From SUBSOT
            When 3  :    # Changements stock
                [M:SCT0]=[F:SRT]
                [M:SCT1]=[F:SRT]
                [M:SCT2]=[F:SRT]
                WNOMTRS = [M:SCT0]SRTNUM
                WENAFLG = [M:SCT0]ENAFLG
                WACSCOD = [M:SCT0]ACSCOD
                WLIBEL  = [M:SCT0]DESAXX
                Gosub TRT_ECRAN From SUBSCT
            When 4  :    # Modification lots
                If LOTACTIV=2
                    [M:SLT0]=[F:SRT]
                    [M:SLT1]=[F:SRT]
                    [M:SLT2]=[F:SRT]
                    WNOMTRS = [M:SLT0]SRTNUM
                    WENAFLG = [M:SLT0]ENAFLG
                    WACSCOD = [M:SLT0]ACSCOD
                    WLIBEL  = [M:SLT0]DESAXX
                    Gosub TRT_ECRAN From SUBSLT
                Endif
            When 5 :     # Plan de rangement
                [M:SRG0]=[F:SRT]
                [M:SRG2]=[F:SRT]
                [M:ETR2]=[F:SRT]
                WNOMTRS = [M:SRG0]SRTNUM
                WENAFLG = [M:SRG0]ENAFLG
                WACSCOD = [M:SRG0]ACSCOD
                WLIBEL  = [M:SRG0]DESAXX
                Gosub TRT_ECRAN From SUBSRG

            When 6 :     # Inventaires
                [M:SNP0]=[F:SRT]
                [M:SNP1]=[F:SRT]
                [M:SNP2]=[F:SRT]
                WNOMTRS = [M:SNP0]SRTNUM
                WENAFLG = [M:SNP0]ENAFLG
                WACSCOD = [M:SNP0]ACSCOD
                WLIBEL  = [M:SNP0]DESAXX
                Gosub TRT_ECRAN From SUBSNP

            When 7:
                [M:PBY0]=[F:SRT]
                [M:PBY1]=[F:SRT]
                [M:ETR2]=[F:SRT]
                WNOMTRS = [M:PBY0]SRTNUM
                WENAFLG = [M:PBY0]ENAFLG
                WACSCOD = [M:PBY0]ACSCOD
                WLIBEL  = [M:PBY0]DESAXX
                Gosub TRT_ECRAN From SUBPBY

            When 8 :         # Contrôle qualité
                [M:SQT0]=[F:SRT]
                [M:SQT1]=[F:SRT]
                WNOMTRS = [M:SQT0]SRTNUM
                WENAFLG = [M:SQT0]ENAFLG
                WACSCOD = [M:SQT0]ACSCOD
                WLIBEL  = [M:SQT0]DESAXX
                Gosub TRT_ECRAN From SUBSQT
            When 9 :     # Plan de reapprovisionnement
                [M:SRO0]=[F:SRT]
                [M:SRO1]=[F:SRT]
                WNOMTRS = [M:SRO0]SRTNUM
                WENAFLG = [M:SRO0]ENAFLG
                WACSCOD = [M:SRO0]ACSCOD
                WLIBEL  = [M:SRO0]DESAXX
                Gosub TRT_ECRAN From SUBSRO
            When 10 :    # Plan de préparation
                [M:PRE0]=[F:SRT]
                [M:PRE1]=[F:SRT]
                WNOMTRS = [M:PRE0]SRTNUM
                WENAFLG = [M:PRE0]ENAFLG
                WACSCOD = [M:PRE0]ACSCOD
                WLIBEL  = [M:PRE0]DESAXX
                Gosub TRT_ECRAN From SUBPRE
            When 11 :    # Colisage
                [M:SPK0]=[F:SRT]
                [M:SPK1]=[F:SRT]
                WNOMTRS = [M:SPK0]SRTNUM
                WENAFLG = [M:SPK0]ENAFLG
                WACSCOD = [M:SPK0]ACSCOD
                WLIBEL  = [M:SPK0]DESAXX
                Gosub TRT_ECRAN From SUBSPK
            When 12 :    # Plan de préparation
                [M:PRT0]=[F:SRT]
                [M:PRT1]=[F:SRT]
                WNOMTRS = [M:PRT0]SRTNUM
                WENAFLG = [M:PRT0]ENAFLG
                WACSCOD = [M:PRT0]ACSCOD
                WLIBEL  = [M:PRT0]DESAXX
                Gosub TRT_ECRAN From SUBPRT
        Endcase
        If GOK < 1
            Call ECR_TRACE(mess(21,123,1)-mess([F:SRT]SRTTYP,2721,1)-[F:SRT]SRTNUM,1) From GESECRAN
            Rollback
        Else
            Call ECR_TRACE(mess(14,123,1)-mess([F:SRT]SRTTYP,2721,1)-[F:SRT]SRTNUM,0) From GESECRAN
            Commit
        Endif
Next
End

##############################################################################
# VAL_STKTRSB : S/P Validation en masse des transactions plans               #
# -------------------------------------------------------------------------- #
# Subprog VAL_STKTRSB (TYP,NUM,APPLI)                                        #
#    TYP  : Type des transactions à valider (1n)                             #
#           0    = Toutes                                                    #
#           51   = Planning global de production                             #
#           52   = Plan de travail                                           #
#           53   = Regroupements                                             #
#    NUM  : Code de la transaction à valider (3c)                            #
#           "" = Toutes                                                      #
#    APPLI: Nom de l'application à mettre à jour                             #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:BTS]BENCHTRS Table des transactions planning                   #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_STKTRSB(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local  Char     LIBEL(30) , MASKREF(GLONAMK), MASKDES(GLONAMK)
Local  Integer  ER
Local  Integer  OK

ACTION="MASSE"
Case TYP
    When 0 :         CRITERES = "BTSTYP<60"
    When 51 :        CRITERES = "BTSTYP=51"
    When 52 :        CRITERES = "BTSTYP=52"
    When 53 :        CRITERES = "BTSTYP=53"
    When Default :   CRITERES = "BTSTYP<60"
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & BTSNUM=NUM" : Endif
If clalev([F:BTS]) <= 0 : Local File = APPLI+".BENCHTRS" [BTS] : Endif

  Gosub GEN_TRTSTKBTRS
End

#====================================
Subprog OLD_VAL_STKTRSB(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local  Char     LIBEL(30) , MASKREF(GLONAMK), MASKDES(GLONAMK)
Local  Integer  ER
Local  Integer  OK

ACTION="MASSE"
Case TYP
    When 0 :         CRITERES = "BTSTYP<60"
    When 51 :        CRITERES = "BTSTYP=51"
    When 52 :        CRITERES = "BTSTYP=52"
    When 53 :        CRITERES = "BTSTYP=53"
    When Default :   CRITERES = "BTSTYP<60"
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & BTSNUM=NUM" : Endif
If clalev([F:BTS]) <= 0 : Local File = APPLI+".BENCHTRS" [BTS] : Endif
For [BTS] Where evalue(CRITERES)
    If [F:BTS]BTSTYP <> WTYP
        Case WTYP
            When 51 : Close Local Mask [MGL0],[MGL1],[MGL2],[MGL3]
            When 52 : Close Local Mask [MDL0],[MDL1],[MDL2],[MDL3]
            When 53 : Close Local Mask [MRL0],[MRL1],[MRL2]
        Endcase
        Case [F:BTS]BTSTYP
            When 51: If clalev ([M:MGL0])<=0 : Local Mask =APPLI+".MGL0" [MGL0] : Endif
                     If clalev ([M:MGL1])<=0 : Local Mask =APPLI+".MGL1" [MGL1] : Endif
                     If clalev ([M:MGL2])<=0 : Local Mask =APPLI+".MGL2" [MGL2] : Endif
                     If clalev ([M:MGL3])<=0 : Local Mask =APPLI+".MGL3" [MGL3] : Endif
            When 52: If clalev ([M:MDL0])<=0 : Local Mask =APPLI+".MDL0" [MDL0] : Endif
                     If clalev ([M:MDL1])<=0 : Local Mask =APPLI+".MDL1" [MDL1] : Endif
                     If clalev ([M:MDL2])<=0 : Local Mask =APPLI+".MDL2" [MDL2] : Endif
                     If clalev ([M:MDL3])<=0 : Local Mask =APPLI+".MDL3" [MDL3] : Endif
            When 53: If clalev ([M:MRL0])<=0 : Local Mask =APPLI+".MRL0" [MRL0] : Endif
                     If clalev ([M:MRL1])<=0 : Local Mask =APPLI+".MRL1" [MRL1] : Endif
                     If clalev ([M:MRL2])<=0 : Local Mask =APPLI+".MRL2" [MRL2] : Endif
         Endcase
         WTYP=[F:BTS]BTSTYP
    Endif
    Call DEBTRANS From GLOCK
    Trbegin [BTS]
        Case [F:BTS]BTSTYP
            When 51: [M:MGL0]=[F:BTS]
                     [M:MGL1]=[F:BTS]
                     [M:MGL2]=[F:BTS]
                     [M:MGL3]=[F:BTS]
                     MASKREF = "MFGBENCH"
                     Gosub TRT_ECRAN From SUBMGL
            When 52: [M:MDL0]=[F:BTS]
                     [M:MDL1]=[F:BTS]
                     [M:MDL2]=[F:BTS]
                     [M:MDL3]=[F:BTS]
                     MASKREF = "MFGBENCHD"
                     #MASKREFK = "MTOLINKB" : # GA 02/2008 les 2 autres écrans sont traités dans SUBMDL
                     Gosub TRT_ECRAN From SUBMDL
            When 53: [M:MRL0]=[F:BTS]
                     [M:MRL1]=[F:BTS]
                     [M:MRL2]=[F:BTS]
                     If [F:BTS]PLANNER = 2                     : [M:MRL1]USRPRF = 1 : MASKREF = "MFGPICK"  : Endif
                     If [F:BTS]APPBUY  = 2 | [F:BTS]APPBUY = 2 : [M:MRL1]USRPRF = 2 : MASKREF = "MFGPICKA" : Endif
                     If [F:BTS]BUYER   = 2 | [F:BTS]INTBUY = 2 : [M:MRL1]USRPRF = 3 : MASKREF = "MFGPICKA" : Endif
                     If [F:BTS]PLANNER = 2 & [F:BTS]BUYER=2    : [M:MRL1]USRPRF = 4 : MASKREF = "MFGPICK"  : Endif

                     Gosub TRT_ECRAN From SUBMRL
        Endcase
        If GOK < 1
            Call ECR_TRACE(mess(21,123,1)-mess([F:BTS]BTSTYP-50,753,1)-[F:BTS]BTSNUM,1) From GESECRAN
            Rollback
        Else
            Call ECR_TRACE(mess(14,123,1)-mess([F:BTS]BTSTYP-50,753,1)-[F:BTS]BTSNUM,0) From GESECRAN
            Commit
        Endif
Next
End

Subprog AS_TRSTYP(VALEUR)
Variable Integer VALEUR
#---- Ouverture table code activité
If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
Read [ACV] CODACT = "LOT"
If !fstat & [F:ACV]FLACT<>2
    GMENLOC(4) = 1
Endif
End

Subprog AM_TRSTYPALL(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
   Grizo [M]TRSTYP
   Grizo [M]TRSNUM
   Raz   [M]TRSNUM
   Raz   [M]TRSDES
   Affzo [M]TRSNUM
   Affzo [M]TRSDES
  [M]TRSTYP = 0
Else
  [M]TRSTYP = 1
   Actzo [M]TRSTYP
   Actzo [M]TRSNUM
Endif

End

