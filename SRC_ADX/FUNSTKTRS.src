#<AdxTL>@(#)12.0.0.0 $Revision$


##############################################################################
# FUNSTKTRS : Contient                                          LLC    10/99 #
#     - Le S/P de validation des transactions de saisie du module STOCK      #
#     - Le traitement permettant de lancer manuellemnt le S/P de validation  #
##############################################################################
Local Integer OK
Gosub OPEN_FILES
Call DIALWIN(OK,mess(100,196,1),"ISRTV") From GESECRAN
If OK=2
    Gosub EXEC
Endif
End

$ACTION
Case ACTION
    When "OUVRE_BATCH"  : Gosub OPEN_FILES
    When "INIT"         : Gosub OPEN_FILES
    When "EXEC","OK"    : Gosub EXEC
    When "TERMINE"      : Gosub TERMINE
    When "INIT_DIA"     : Gosub INIT_DIA
    When "FERME" : Gosub FERME
Endcase
Return

$OPEN_FILES
If clalev ([F:AMZ]) <= 0  : Local File AMSKZON [AMZ] : Endif
If clalev ([F:AMK])  = 0  : Local File AMSK    [AMK] : Endif
If clalev ([F:AMA])  = 0  : Local File AMSKACT [AMA] : Endif
If clalev ([F:AMP])  = 0  : Local File AMSKPAR [AMP] : Endif
# FGR 20/11/2009 : X3SUIVI60151
If !clalev ([F:AWI]) : Local File AWINDOW    [AWI] : Endif
If !clalev ([F:AWP]) : Local File AWINPAR    [AWP] : Endif
If !clalev ([F:AWB]) : Local File AWINBRO    [AWB] : Endif
If !clalev ([F:AWT]) : Local File AWINBOUT   [AWT] : Endif
If !clalev ([F:ATY]) : Local File ATYPE      [ATY] : Endif
If !clalev ([F:ACT]) : Local File ACTION     [ACT] : Endif
If !clalev ([F:ATR]) : Local File ACTPAR     [ATR] : Endif
If !clalev ([F:AAR]) : Local File ACTCODPAR  [AAR] : Endif
If !clalev ([F:ATB]) : Local File ATABLE     [ATB] : Endif
If !clalev ([F:ATZ]) : Local File ATABZON    [ATZ] : Endif
If !clalev ([F:ACV]) : Local File ACTIV      [ACV] : Endif
If !clalev ([F:AOB]) : Local File AOBJET     [AOB] : Endif
If !clalev ([F:ATX]) : Local File ATEXTE     [ATX] : Endif
If !clalev ([F:ADV]) : Local File ATABTAB    [ADV] : Endif

Local File    STKTRS [SRT]
Local File    BENCHTRS [BTS]
Local Mask    SRTV [DIA] : Raz [M:DIA]
Return

$EXEC
    If GSERVEUR
      Onerrgo ERRBATCH
      Call ECR_TRACE(mess(100,196,1),0) From GESECRAN
    Else
      Call OUVRE_TRACE(mess(100,196,1)) From LECFIC
      Call ECR_TRACE(mess(100,196,1),0) From GESECRAN
    Endif
    Call VAL_STKTRS([M]TRSTYP,[M]TRSNUM,nomap)
Return
###########################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
Return

$TERMINE
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return

$INIT_DIA
Raz [M:DIA]
# [M:DIA]TRSTYP=0              # hcb 010205  25150
Affzo [M:DIA]1-99
Return

$FERME
Close Local File [SRT]
Close Local File [BTS]
Close Local Mask [DIA]
Return


Subprog AV_TRSDES(VALEUR)
Variable Char    VALEUR()
If [M]TRSNUM = "" : End : Endif
If [M]TRSTYP < 51
    Read [SRT]SRT0=[M]TRSTYP;[M]TRSNUM
    If fstat : Raz [F:SRT] : Endif
    VALEUR=[F:SRT]SRTDES
    End
Else
    Read [BTS]BTS0=[M]TRSTYP;[M]TRSNUM
    If fstat : Raz [F:BTS] : Endif
    VALEUR=[F:BTS]BTSDES
    End
Endif
End
End


Subprog GENDOS(TYP, APPLI)
Value Integer  TYP
Value Char APPLI
Local Char    TABFEN(GLONFEN)(0..2), TABECR(GLONAMK)(0..10)
Local Integer I, TOK(1..20)
Raz TOK
If clalev([F:SRT])<=0 : Local File =APPLI+".STKTRS"      [SRT] : Endif
If clalev([F:BTS])<=0 : Local File =APPLI+".BENCHTRS"    [BTS] : Endif
Local File =APPLI+".AWINDOW"    [AWI]      # déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINPAR"    [AWP]      # déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBRO"    [AWB]      # déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBOUT"   [AWT]      # déjà ouvert en local, le réouvrir !
#If clalev([F:AMK])<=0 : Local File =APPLI+".AMSK"      [AMK] : Endif
#If clalev([F:AMZ])<=0 : Local File =APPLI+".AMSKZON"   [AMZ] : Endif
#If clalev([F:AMA])<=0 : Local File =APPLI+".AMSKACT"   [AMA] : Endif
#If clalev([F:AMP])<=0 : Local File =APPLI+".AMSKPAR"   [AMP] : Endif
#If clalev([F:ATY])<=0 : Local File =APPLI+".ATYPE"     [ATY] : Endif
#If clalev([F:ACT])<=0 : Local File =APPLI+".ACTION"    [ACT] : Endif
#If clalev([F:ATR])<=0 : Local File =APPLI+".ACTPAR"    [ATR] : Endif
#If clalev([F:AAR])<=0 : Local File =APPLI+".ACTCODPAR" [AAR] : Endif
#If clalev([F:ATB])<=0 : Local File =APPLI+".ATABLE"    [ATB] : Endif
#If clalev([F:ATZ])<=0 : Local File =APPLI+".ATABZON"   [ATZ] : Endif
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]

# déjà ouvert en local, le réouvrir !
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
#
#If clalev([F:ATX])<=0 : Local File =APPLI+".ATEXTE"    [ATX] : Endif
#If clalev([F:ADV])<=0 : Local File =APPLI+".ATABTAB"   [ADV] : Endif
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]

If dim(GVALTRANS)>0 & GVALTRANS(7)=2
   # pour les plans (types 51, 52, 53) on utilise les indices 13, 14 et 15
   # pour ne pas avoir à créer un tableau TOK surdimensionné
   If TYP < 51 : TOK(TYP) = 1 : Else : TOK(TYP - 38) = 1 : Endif             # hcb 39038
Else
   Raz TABECR
   Case TYP
       When 1 : # Entrées diverses
           TABECR(0)="SMR0":TABECR(1)="SMR1"
           TABFEN(0)="OSMR"
       When 2 : # Sorties diverses
           TABECR(0)="SMO0":TABECR(1)="SMO1"
           TABFEN(0)="OSMO"
       When 3 : # Changement stock
           TABECR(0)="SCS1"
           TABFEN(0)="OSCS"
       When 4 : # Modification lots
           TABECR(0)="SLM1"
           TABFEN(0)="OSLM"
       When 5 : # Plan de rangement
           TABECR(0)="SSL1"
           TABFEN(0)="ISSL"
       When 6 : # Inventaires
           TABECR(0)="SNL0":TABECR(1)="SNL1"
           TABFEN(0)="ISNL0"
           TABFEN(1)="ISNL1"
       When 7 : # Assemblage/Desassemblage
           TABECR(0)="BBY0":TABECR(1)="BBY1"
           TABFEN(0)="OBBY"
       When 8: # Controle qualité
           TABECR(0)="STQ0":TABECR(1)="STQ1":TABECR(2)="STQ2"
           TABFEN(0)="OSTQ"
       When 9 : # Plan de réapprovisionnement
           TABECR(0)="REO1"
           TABFEN(0)="IREO"
       When 10 : # Plan de préparation
           TABECR(0)="PREPLAN"
           TABFEN(0)="IPREP"
       When 11 : # Colisage
           TABECR(0)="PKD0":TABECR(1)="PKD1"
           TABFEN(0)="OPKD"
       When 12 : # Bons de préparation
           TABECR(0)="PRH0":TABECR(1)="PRH1"
           TABFEN(0)="OPRH"

       When 51: # planning global
           TABECR(0)="MFGBENCH"
           TABFEN(0)="FMFGB"
       When 52: # plan de travail
           TABECR(0)="MFGBENCHD"
           TABECR(1)="MTOLINKB"   : # V6 LLC plan d'affectations
           TABECR(2)="MTOBENCH"   : # V6 GA  planification à la commande
           TABFEN(0)="FMFGD"
           TABFEN(1)="FMLKB"      : # V6 LLC plan d'affectations
           TABFEN(2)="FMTOB"      : # V6 GA  planification à la commande
       When 53: # regroupements
           TABECR(0)="MFGPICK"
           TABECR(1)="MFGPICKA"
           TABFEN(0)="FMFGR"
           TABFEN(1)="FMFGRA"
    Endcase
   I=0
   # hcb 41037
   #While I<2 & TABFEN(I)<>""
   While I<3 & TABFEN(I)<>""
       Read [AWI]AWI0 = TABFEN(I)
       If fstat Raz [F:AWI] : Endif
       If TYP < 51 : TOK(TYP) = 1 : Else : TOK(TYP - 38) = 1 : Endif       # hcb 39038
       If [F:AWI]UPDFLG = 1
           Break
       Endif
       I+=1
   Wend

   # hcb  39038
   If (TYP < 51 & TOK(TYP)<>1) | (TYP >= 51 & TOK(TYP-38)<>1)
       I=0
 # hcb 41037
       While  I<10 &  TABECR(I)<>""
           Read [AMK]CODMSK = TABECR(I)
           If fstat Raz [F:AMK] : Endif
           If TYP < 51 : TOK(TYP) = 1 : Else : TOK(TYP - 38) = 1 : Endif
           If [F:AMK]UPDFLG = 1
              Break
           Endif
           I+=1
       Wend
   Endif
Endif

If sum(TOK(1..12)) = 12 & sum(TOK(13..15)) = 3
   Call VAL_STKTRS(0,"",APPLI)
Else
   If TOK(1) = 1 : Call VAL_STKTRS(1,"",APPLI) : Endif
   If TOK(2) = 1 : Call VAL_STKTRS(2,"",APPLI) : Endif
   If TOK(3) = 1 : Call VAL_STKTRS(3,"",APPLI) : Endif
   If TOK(4) = 1 : Call VAL_STKTRS(4,"",APPLI) : Endif
   If TOK(5) = 1 : Call VAL_STKTRS(5,"",APPLI) : Endif
   If TOK(6) = 1 : Call VAL_STKTRS(6,"",APPLI) : Endif
   If TOK(7) = 1 : Call VAL_STKTRS(7,"",APPLI) : Endif
   If TOK(8) = 1 : Call VAL_STKTRS(8,"",APPLI) : Endif
   If TOK(9) = 1 : Call VAL_STKTRS(9,"",APPLI) : Endif
   If TOK(10)= 1 : Call VAL_STKTRS(10,"",APPLI) : Endif
   If TOK(11)= 1 : Call VAL_STKTRS(11,"",APPLI) : Endif
   If TOK(12)= 1 : Call VAL_STKTRS(12,"",APPLI) : Endif
   If TOK(13)= 1 : Call VAL_STKTRS(51,"",APPLI) : Endif
   If TOK(14)= 1 : Call VAL_STKTRS(52,"",APPLI) : Endif
   If TOK(15)= 1 : Call VAL_STKTRS(53,"",APPLI) : Endif
Endif

End

##############################################################################
#    Programme appelé dans SUBSRT  #
#    Pour éxécution validation transaction en gestion de patch               #
##############################################################################
Subprog GENPATCH(TYP,APPLI)
Value Integer  TYP
Value Char     APPLI
If clalev([F:SRT])<=0 : Local File =APPLI+".STKTRS"    [SRT] : Endif
If clalev([F:BTS])<=0 : Local File =APPLI+".BENCHTRS"  [BTS] : Endif
Local File =APPLI+".AWINDOW"   [AWI] :                                 # déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINPAR"   [AWP] :                                 # déjà ouvert en local, le réouvrir !
#If clalev([F:AMK])<=0 : Local File =APPLI+".AMSK"      [AMK] : Endif
#If clalev([F:AMZ])<=0 : Local File =APPLI+".AMSKZON"   [AMZ] : Endif
#If clalev([F:AMA])<=0 : Local File =APPLI+".AMSKACT"   [AMA] : Endif
#If clalev([F:AMP])<=0 : Local File =APPLI+".AMSKPAR"   [AMP] : Endif
#If clalev([F:ATY])<=0 : Local File =APPLI+".ATYPE"     [ATY] : Endif
#If clalev([F:ACT])<=0 : Local File =APPLI+".ACTION"    [ACT] : Endif
#If clalev([F:ATR])<=0 : Local File =APPLI+".ACTPAR"    [ATR] : Endif
#If clalev([F:AAR])<=0 : Local File =APPLI+".ACTCODPAR" [AAR] : Endif
#If clalev([F:ATB])<=0 : Local File =APPLI+".ATABLE"    [ATB] : Endif
#If clalev([F:ATZ])<=0 : Local File =APPLI+".ATABZON"   [ATZ] : Endif
#If clalev([F:ACV])<=0 : Local File =APPLI+".ACTIV"     [ACV] : Endif
#If clalev([F:AOB])<=0 : Local File =APPLI+".AOBJET"    [AOB] : Endif
#If clalev([F:ATX])<=0 : Local File =APPLI+".ATEXTE"    [ATX] : Endif
#If clalev([F:ADV])<=0 : Local File =APPLI+".ATABTAB"   [ADV] : Endif
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]

# Issue 95405 - 2018-06-12 by MAE : si sur X3 : rien à faire
If APPLI="X3" End Endif

Call VAL_STKTRS(TYP,"",APPLI)

End

#========================================================================================
# FGR 16/11/2009 : X3SUIVI57491 (début)
#----------------------------------------------------------------------------------------
$DYN_TRTSTKATRS
Local Char SZWIN(GLONFEN)
Local Char SZABRFIC(GLONABR)
Local Char SZONGLET(250)

  SZABRFIC = 'SRT'
  # 1
  SZWIN = 'OSRT'
  SZONGLET = '"[SRT0]","[SRT1]","[ETR2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ1, IREQ1) From FUNSALTRS
  # 2
  SZWIN = 'OSOT'
  SZONGLET = '"[SOT0]","[SOT1]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ2, IREQ2) From FUNSALTRS
  # 3
  SZWIN = 'OSCT'
  SZONGLET = '"[SCT0]","[SCT1]","[SCT2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ3, IREQ3) From FUNSALTRS
  # 4
  SZWIN = 'OSLT'
  SZONGLET = '"[SLT0]","[SLT1]","[SLT2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ4, IREQ4) From FUNSALTRS
  # 5
  SZWIN = 'OSRG'
  SZONGLET = '"[SRG0]","[SRG2]","[ETR2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ5, IREQ5) From FUNSALTRS
  # 6
  SZWIN = 'OSNP'
  SZONGLET = '"[SNP0]","[SNP1]","[SNP2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ6, IREQ6) From FUNSALTRS
  # 7
  SZWIN = 'OPBY'
  SZONGLET = '"[PBY0]","[PBY1]","[ETR2]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ7, IREQ7) From FUNSALTRS
  # 8
  SZWIN = 'OSQT'
  SZONGLET = '"[SQT0]","[SQT1]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ8, IREQ8) From FUNSALTRS
  # 9
  SZWIN = 'OSRO'
  SZONGLET = '"[SRO0]","[SRO1]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ9, IREQ9) From FUNSALTRS
  # 10
  SZWIN = 'OPRE'
  SZONGLET = '"[PRE0]","[PRE1]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ10, IREQ10) From FUNSALTRS
  # 11
  SZWIN = 'OSPK'
  SZONGLET = '"[SPK0]","[SPK1]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ11, IREQ11) From FUNSALTRS
  # 12
  SZWIN = 'OPRT'
  SZONGLET = '"[PRT0]","[PRT1]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ12, IREQ12) From FUNSALTRS
Return

#----------------------------------------------------------------------------------------
$GEN_TRTSTKATRS
Local Char SZADXIFS
Local Char SZADXIRS
Local Integer IVALIDOK
Local Integer IEXIST
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer NI
# 20 lignes
#  5 colonnes :
#               (0) = Complément "Close Local Mask" et "Default Mask"
#               (1) = Listes des autres Mask à ouvrir
#               (2) = Complément affectation classe [F] dans classe [M]
Local Char SZREQ1(250)(20,5)
Local Char SZREQ2(250)(20,5)
Local Char SZREQ3(250)(20,5)
Local Char SZREQ4(250)(20,5)
Local Char SZREQ5(250)(20,5)
Local Char SZREQ6(250)(20,5)
Local Char SZREQ7(250)(20,5)
Local Char SZREQ8(250)(20,5)
Local Char SZREQ9(250)(20,5)
Local Char SZREQ10(250)(20,5)
Local Char SZREQ11(250)(20,5)
Local Char SZREQ12(250)(20,5)
Local Integer IREQ1
Local Integer IREQ2
Local Integer IREQ3
Local Integer IREQ4
Local Integer IREQ5
Local Integer IREQ6
Local Integer IREQ7
Local Integer IREQ8
Local Integer IREQ9
Local Integer IREQ10
Local Integer IREQ11
Local Integer IREQ12
  #------------------------------------------
  Raz SZREQ1
  Raz SZREQ2
  Raz SZREQ3
  Raz SZREQ4
  Raz SZREQ5
  Raz SZREQ6
  Raz SZREQ7
  Raz SZREQ8
  Raz SZREQ9
  Raz SZREQ10
  Raz SZREQ11
  Raz SZREQ12
  IREQ1 = 0
  IREQ2 = 0
  IREQ3 = 0
  IREQ4 = 0
  IREQ5 = 0
  IREQ6 = 0
  IREQ7 = 0
  IREQ8 = 0
  IREQ9 = 0
  IREQ10 = 0
  IREQ11 = 0
  IREQ12 = 0
  #------------------------------------------
  Gosub DYN_TRTSTKATRS
  #------------------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #------------------------------------------
  SZPROGNAME = "WSTKA" + num$(adxpid)
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", APPLI)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", APPLI)
  #------------------------------------------
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [TRS_]
  #------------------------------------------
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"  Using [TRS_]
  Wrseq "#Traitement généré pour les transactions STK-A en masse"  Using [TRS_]
  Wrseq "$TRANSAC_STKA"  Using [TRS_]
  Wrseq 'For [SRT] Where' - CRITERES  Using [TRS_]
  Wrseq '    If [F:SRT]SRTTYP <> WTYP'  Using [TRS_]
  Wrseq '        Raz WMODU'  Using [TRS_]
  Wrseq '        Raz WNOMOBJ'  Using [TRS_]
  Wrseq '        Case [F:SRT]SRTTYP'  Using [TRS_]
  Wrseq '            When 1 :'  Using [TRS_]
  Wrseq '                If clalev ([M:SRT0])<=0 : Local Mask =APPLI+".SRT0" [SRT0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SRT1])<=0 : Local Mask =APPLI+".SRT1" [SRT1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ1-1
    Wrseq '                ' + SZREQ1(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 2 :'  Using [TRS_]
  Wrseq '                If clalev ([M:SOT0])<=0 : Local Mask =APPLI+".SOT0" [SOT0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SOT1])<=0 : Local Mask =APPLI+".SOT1" [SOT1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ2-1
    Wrseq '                ' + SZREQ2(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 3 :'  Using [TRS_]
  Wrseq '                If clalev ([M:SCT0])<=0 : Local Mask =APPLI+".SCT0" [SCT0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SCT1])<=0 : Local Mask =APPLI+".SCT1" [SCT1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SCT2])<=0 : Local Mask =APPLI+".SCT2" [SCT2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ3-1
    Wrseq '                ' + SZREQ3(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 4 :'  Using [TRS_]
  Wrseq '                If LOTACTIV=2'  Using [TRS_]
  Wrseq '                    If clalev ([M:SLT0])<=0 : Local Mask =APPLI+".SLT0" [SLT0] : Endif'  Using [TRS_]
  Wrseq '                    If clalev ([M:SLT1])<=0 : Local Mask =APPLI+".SLT1" [SLT1] : Endif'  Using [TRS_]
  Wrseq '                    If clalev ([M:SLT2])<=0 : Local Mask =APPLI+".SLT2" [SLT2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ4-1
    Wrseq '                ' + SZREQ4(NI,1)  Using [TRS_]
  Next NI
  Wrseq '                Endif'  Using [TRS_]
  Wrseq '            When 5 :'  Using [TRS_]
  Wrseq '                If clalev ([M:SRG0])<=0 : Local Mask =APPLI+".SRG0" [SRG0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SRG2])<=0 : Local Mask =APPLI+".SRG2" [SRG2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ5-1
    Wrseq '                ' + SZREQ5(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 6 :'  Using [TRS_]
  Wrseq '                If clalev ([M:SNP0])<=0 : Local Mask =APPLI+".SNP0" [SNP0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SNP1])<=0 : Local Mask =APPLI+".SNP1" [SNP1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SNP2])<=0 : Local Mask =APPLI+".SNP2" [SNP2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ6-1
    Wrseq '                ' + SZREQ6(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 7:'  Using [TRS_]
  Wrseq '                If clalev ([M:PBY0])<=0 : Local Mask =APPLI+".PBY0" [PBY0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:PBY1])<=0 : Local Mask =APPLI+".PBY1" [PBY1] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:DST]) <=0 : Local Mask =APPLI+".DIESCRTRS" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ7-1
    Wrseq '                ' + SZREQ7(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 8 :'  Using [TRS_]
  Wrseq '                If clalev ([M:SQT0])<=0 : Local Mask =APPLI+".SQT0" [SQT0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SQT1])<=0 : Local Mask =APPLI+".SQT1" [SQT1] : Endif'  Using [TRS_]
  For NI = 0 To IREQ8-1
    Wrseq '                ' + SZREQ8(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 9:'  Using [TRS_]
  Wrseq '                If clalev ([M:SRO0])<=0 : Local Mask =APPLI+".SRO0" [SRO0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SRO1])<=0 : Local Mask =APPLI+".SRO1" [SRO1] : Endif'  Using [TRS_]
  For NI = 0 To IREQ9-1
    Wrseq '                ' + SZREQ9(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 10:'  Using [TRS_]
  Wrseq '                If clalev ([M:PRE0])<=0 : Local Mask =APPLI+".PRE0" [PRE0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:PRE1])<=0 : Local Mask =APPLI+".PRE1" [PRE1] : Endif'  Using [TRS_]
  For NI = 0 To IREQ10-1
    Wrseq '                ' + SZREQ10(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 11:'  Using [TRS_]
  Wrseq '                If clalev ([M:SPK0])<=0 : Local Mask =APPLI+".SPK0" [SPK0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:SPK1])<=0 : Local Mask =APPLI+".SPK1" [SPK1] : Endif'  Using [TRS_]
  For NI = 0 To IREQ11-1
    Wrseq '                ' + SZREQ11(NI,1)  Using [TRS_]
  Next NI
  Wrseq '            When 12:'  Using [TRS_]
  Wrseq '                If clalev ([M:PRT0])<=0 : Local Mask =APPLI+".PRT0" [PRT0] : Endif'  Using [TRS_]
  Wrseq '                If clalev ([M:PRT1])<=0 : Local Mask =APPLI+".PRT1" [PRT1] : Endif'  Using [TRS_]
  For NI = 0 To IREQ12-1
    Wrseq '                ' + SZREQ12(NI,1)  Using [TRS_]
  Next NI
  Wrseq '        Endcase'  Using [TRS_]
  Wrseq '        WTYP=[F:SRT]SRTTYP'  Using [TRS_]
  Wrseq '    Endif'  Using [TRS_]
  Wrseq '    WDIE_DTRTYP=[F:SRT]SRTTYP'  Using [TRS_]
  Wrseq '    ACTION="OUVRE" : Gosub TRT_DIETRS From SUBDST'  Using [TRS_]
  Wrseq '    Call DEBTRANS From GLOCK'  Using [TRS_]
  Wrseq '    Trbegin [SRT]'  Using [TRS_]
  Wrseq '        Local Char WAPPLI : WAPPLI = APPLI'  Using [TRS_]
  Wrseq '        Case [F:SRT]SRTTYP'  Using [TRS_]
  Wrseq '            When 1:    # Entrées diverses'  Using [TRS_]
  Wrseq '                [M:SRT0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SRT1]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:ETR2]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ1(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SRT0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SRT0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SRT0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL =[M:SRT0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSRT'  Using [TRS_]
  Wrseq '            When 2  :    # Sorties diverse'  Using [TRS_]
  Wrseq '                [M:SOT0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SOT1]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ2(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SOT0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SOT0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SOT0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:SOT0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSOT'  Using [TRS_]
  Wrseq '            When 3  :    # Changements stock'  Using [TRS_]
  Wrseq '                [M:SCT0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SCT1]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SCT2]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ3(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SCT0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SCT0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SCT0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:SCT0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSCT'  Using [TRS_]
  Wrseq '            When 4  :    # Modification lots'  Using [TRS_]
  Wrseq '                If LOTACTIV=2'  Using [TRS_]
  Wrseq '                    [M:SLT0]=[F:SRT]'  Using [TRS_]
  Wrseq '                    [M:SLT1]=[F:SRT]'  Using [TRS_]
  Wrseq '                    [M:SLT2]=[F:SRT]'  Using [TRS_]
  Wrseq '                    ' + SZREQ4(0,2)  Using [TRS_]
  Wrseq '                    WNOMTRS = [M:SLT0]SRTNUM'  Using [TRS_]
  Wrseq '                    WENAFLG = [M:SLT0]ENAFLG'  Using [TRS_]
  Wrseq '                    WACSCOD = [M:SLT0]ACSCOD'  Using [TRS_]
  Wrseq '                    WLIBEL  = [M:SLT0]DESAXX'  Using [TRS_]
  Wrseq '                    Gosub TRT_ECRAN From SUBSLT'  Using [TRS_]
  Wrseq '                Endif'  Using [TRS_]
  Wrseq '            When 5 :     # Plan de rangement '  Using [TRS_]
  Wrseq '                [M:SRG0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SRG2]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:ETR2]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ5(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SRG0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SRG0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SRG0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:SRG0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSRG'  Using [TRS_]
  Wrseq '            When 6 :     # Inventaires      '  Using [TRS_]
  Wrseq '                [M:SNP0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SNP1]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SNP2]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ6(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SNP0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SNP0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SNP0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:SNP0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSNP'  Using [TRS_]
  Wrseq '            When 7:'  Using [TRS_]
  Wrseq '                [M:PBY0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:PBY1]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:ETR2]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ7(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:PBY0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:PBY0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:PBY0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:PBY0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBPBY'  Using [TRS_]
  Wrseq '            When 8 :         # Contrôle qualité'  Using [TRS_]
  Wrseq '                [M:SQT0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SQT1]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ8(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SQT0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SQT0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SQT0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:SQT0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSQT'  Using [TRS_]
  Wrseq '            When 9 :     # Plan de reapprovisionnement'  Using [TRS_]
  Wrseq '                [M:SRO0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SRO1]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ9(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SRO0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SRO0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SRO0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:SRO0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSRO'  Using [TRS_]
  Wrseq '            When 10 :    # Plan de préparation'  Using [TRS_]
  Wrseq '                [M:PRE0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:PRE1]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ10(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:PRE0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:PRE0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:PRE0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:PRE0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBPRE'  Using [TRS_]
  Wrseq '            When 11 :    # Colisage           '  Using [TRS_]
  Wrseq '                [M:SPK0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:SPK1]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ11(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:SPK0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:SPK0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:SPK0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:SPK0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBSPK'  Using [TRS_]
  Wrseq '            When 12 :    # Plan de préparation'  Using [TRS_]
  Wrseq '                [M:PRT0]=[F:SRT]'  Using [TRS_]
  Wrseq '                [M:PRT1]=[F:SRT]'  Using [TRS_]
  Wrseq '             ' + SZREQ12(0,2)  Using [TRS_]
  Wrseq '                WNOMTRS = [M:PRT0]SRTNUM'  Using [TRS_]
  Wrseq '                WENAFLG = [M:PRT0]ENAFLG'  Using [TRS_]
  Wrseq '                WACSCOD = [M:PRT0]ACSCOD'  Using [TRS_]
  Wrseq '                WLIBEL  = [M:PRT0]DESAXX'  Using [TRS_]
  Wrseq '                Gosub TRT_ECRAN From SUBPRT'  Using [TRS_]
  Wrseq '        Endcase'  Using [TRS_]
  Wrseq '        If GOK < 1'  Using [TRS_]
  Wrseq '            Call ECR_TRACE(mess(21,123,1)-mess([F:SRT]SRTTYP,2721,1)-[F:SRT]SRTNUM,1) From GESECRAN'  Using [TRS_]
  Wrseq '            Rollback'  Using [TRS_]
  Wrseq '        Else'  Using [TRS_]
  Wrseq '            Call ECR_TRACE(mess(14,123,1)-mess([F:SRT]SRTTYP,2721,1)-[F:SRT]SRTNUM,0) From GESECRAN'  Using [TRS_]
  Wrseq '            Commit'  Using [TRS_]
  Wrseq '        Endif'  Using [TRS_]
  Wrseq 'Next'  Using [TRS_]
  Wrseq 'Return'  Using [TRS_]
  Wrseq ''  Using [TRS_]
  Openo Using [TRS_]
  #------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #------------------------------------------
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, APPLI, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur lors de la génération : on appelle l'ancien pour que ça fonctionne au moins en standard
    # Je ne l'efface pas. Ca permettrait de trouver ce qui ne va pas
    #IEXIST = 1
    #Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Call OLD_VAL_STKTRSA(TYP,NUM,APPLI)
    Return
  Endif
  #------------------------------------------
  Gosub TRANSAC_STKA From =APPLI + "." + SZPROGNAME
  #------------------------------------------
  # A mettre dans l'appelant
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
Return
# FGR 16/11/2009 : X3SUIVI57491 (fin)
