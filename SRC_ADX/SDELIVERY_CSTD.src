#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SDELIVERY
End
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER              From SDELIVERY_CSTD_METHODS
        When "AINIT"           : Gosub AINIT                    From SDELIVERY_CSTD_METHODS
        When Default
      Endcase
    # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
    When "SDD"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SDD         From SDELIVERY_CSTD_METHODS
        When Default
      Endcase
    When "SVV"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SVV         From SDELIVERY_CSTD_METHODS
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVV          From SDELIVERY_CSTD_METHODS
        When Default
      Endcase
    When "SVF"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SVF         From SDELIVERY_CSTD_METHODS
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF          From SDELIVERY_CSTD_METHODS
        When Default
      Endcase
    When "SVF.C_DTAVAT"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF_C_DTAVAT From SQUOTE_METHODS
        When Default
      Endcase
    When Default
  Endcase

Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSCCODADI"  : Gosub INIT_TSCCODADI               From SDELIVERY_CSTD_METHODS
  Endcase
Return
#--------------------------------------
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES

  Case CURPRO
    When "CPY"              :  Gosub CPY                        From SDELIVERY_CSTD_PROPERTIES
    When Default
  Endcase

Return
#######################################################################################

