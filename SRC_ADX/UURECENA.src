#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Rajout du flag N dans les habilitations fonctionnelles
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update AFCTPRF file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ENAFLG
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub ENAFLG
End

#-------------------#
$ENAFLG

Local File =DOSSIER+".AFCTPRF" [AFP] , =DOSSIER+".AOBJET"  [AOB] , =DOSSIER+".AFONCTION"  [AFC]

Local Char    OBJET(GLONAOB)
Local Integer ER , K , NBMAX , NBFCT , TEST

TEST = 0

NBMAX = 0
For [AFC]CODINT Where left$(CODINT,3)="GES"
 NBMAX += 1
Next AFC

Local Char TBFCT(GLONAFC)(1..NBMAX)

NBFCT = 0
For [AFC]CODINT Where left$(CODINT,3)="GES"
 If len([F:AFC]CODINT)=6
  OBJET = right$([F:AFC]CODINT,4)
  Read [AOB]ABREV=OBJET
  If !fstat & [F:AOB]NOMFIC<>""
   ER = 0
   Onerrgo ER
   Local File =[F:AOB]NOMFIC [XXX]
   K = (dim([F:XXX]ENAFLG)>0)
   Close Local File [XXX]
   Onerrgo
   If !ER & K
    NBFCT += 1
    TBFCT(NBFCT) = [F:AFC]CODINT
   Endif
  Endif
 Endif
Next AFC

# Mise à jour de la table AFCTPRF
Call ECR_TRACE(mess(81,125,1)-"AFCTPRF:"-time$,0) From GESECRAN
Trbegin [AFP]
 For [AFP]AFP0 Where left$(FNC,3)="GES"
  K = find([F:AFP]FNC,TBFCT(1..NBFCT))
  If K
   K = instr(1,[F:AFP]OPT,"M")
   K *= instr(1,[F:AFP]OPT,"C")
   If K & !instr(1,[F:AFP]OPT,"N")
    If TEST
     Call ECR_TRACE([F:AFP]PRFCOD-[F:AFP]FNC-[F:AFP]FCYGRU,0) From GESECRAN
    Else
     [F:AFP]OPT += "N"
     Rewrite [AFP]
     If fstat
      Call ERREUR("AFCTPRF"-[F:AFP]CODINT,2) From DOSDIC
     Endif
    Endif
   Endif
  Endif
 Next AFP
Commit

Close Local File [AFP],[AOB],[AFC]

Return

$ER
ER = errn
Resume
