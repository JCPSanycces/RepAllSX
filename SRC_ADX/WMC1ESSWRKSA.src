[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_ADDTYP
[L]CURPRO = "ADDTYP"
Return

$PROPAGATE_ADDTYP
this.isReadonly = 0
[L]CURPRO = "ADDTYP"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_ADDTYP
Gosub DECLARE_VAR From WMC0ESSWRKSA
[L]CURPRO = "ADDTYP"
$_LNKPRO_ADDTYP
Return


