$_LNKPRO_BUSTEL
Local Char AFORMAT(50)
[L]ASTATUS =  func ASYRTRTATY.GETFORMATTEL(this,"BUSTEL",this.BUSTEL,[L]AFORMAT,this.PASCRY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]AFORMAT<>''
[L]AFORMAT='"'+[L]AFORMAT+'"'
[L]ASTATUS = fmet this.ASETATTRIBUTE("BUSTEL","$x3Format",[L]AFORMAT)
Endif
Return




