$INIT_ADDTYP
Gosub DECLARE_VAR From WMC0ESSWRKSA
[L]CURPRO = "ADDTYP"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.ADDTYP=0 and fmet this.AGETATTRIBUTE("ADDTYP","$isMandatory")="true"
 this.ADDTYP = 1
Endif
Return
 
$CONTROL_ADDTYP
Gosub DECLARE_VAR From WMC0ESSWRKSA
[L]CURPRO = "ADDTYP"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
