#<AdxTL>@(#)6.0.0.0 $Revision$
#------------------------------------------------------------#
$VALSTD

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

K = 0
For I=1 To PRESENT.NBRTRT
 If PRESENT.TYPTRT(I)=1 : # Standard
  If PRESENT.CODTRT(I)<>""
   K = I : Break
  Endif
 Endif
Next I
If !K : Return : Endif

If APPLI=nomap
 FICSRC = filpath("TRT",PRESENT.CODTRT(K),"src")
Else
 FICSRC = filpath("TRT",PRESENT.CODTRT(K),"src",APPLI)
 If filinfo(FICSRC,0)<0
  Gosub LEC_MERE
  For J=1 To NBMERE
   FICSRC = filpath("TRT",PRESENT.CODTRT(K),"src",TBMERE(J))
   If filinfo(FICSRC,0)>=0 : Break : Endif
  Next J
 Endif
Endif

If filinfo(FICSRC,0)<0
 FLVAL = 0
 If APPLI=nomap
  Call EXISTE_ADX("","",PRESENT.CODTRT(K),OKTRT) From ASYRSYS
 Else
  Call EXISTE_ADX("",APPLI,PRESENT.CODTRT(K),OKTRT) From ASYRSYS
  If !OKTRT
   Gosub LEC_MERE
   For J=1 To NBMERE
    Call EXISTE_ADX("",TBMERE(J),PRESENT.CODTRT(K),OKTRT) From ASYRSYS
    If OKTRT>0 : Break : Endif
   Next J
  Endif
 Endif
 If !OKTRT
  FLVAL = 2
 Endif
Else
 FLVAL = 1
 Openi FICSRC Using [FSRC]
 Rdseq LIGNE Using [FSRC]
 While fstat=0
  If left$(vireblc(LIGNE,2),7)="$ACTION"
   FLVAL = 0 : Break
  Endif
  Rdseq LIGNE Using [FSRC]
 Wend
 Openi Using [FSRC]
Endif

If FLVAL
 FICNEW = filpath("TRT",CODTRT(K),"new",APPLI)
 Openo FICNEW , 0
 If FLVAL=2
  Wrseq TITETA
  Wrseq "#"-mess(207,124,1)-mess(23,140,1)-PRESENT.NOMSTC : # Sous-programmes/Présentation
  Wrseq
  Gosub ACTION
 Else
  Openi FICSRC Using [FSRC]
  Rdseq LIGNE Using [FSRC]
  While fstat=0
   Wrseq LIGNE
   Rdseq LIGNE Using [FSRC]
  Wend
  Openi Using [FSRC]
  Gosub ACTION
 Endif
 Openo
 FICSRC = filpath("TRT",PRESENT.CODTRT(K),"src",APPLI)
 Call _MOVE(FICNEW,FICSRC,STAT) From ASYRSYS
 If STAT
  Call ECR_TRACE(mess(6,123,1)+num$(STAT)-"MOVE"+"\|"+FICNEW+"\|"+FICSRC,1) From GESECRAN : # Erreur
 Endif
 Call MAJDICTRT(PRESENT.CODTRT(K),APPLI,PRESENT.COMMENT,PRESENT.MODULE,PRESENT.ACTIV) From SUBADC
 Call VALID("TRT",PRESENT.CODTRT(K),APPLI,OK) From ASTRVALSUB
Endif

Return

#------------------------------------------------#
$ACTION
Wrseq "$ACTION"
Wrseq "Case ACTION"
Wrseq " When default"
Wrseq "Endcase"
Wrseq "Return"
Wrseq
Return

#----------------------------------------------#
$LEC_MERE
If NBMERE=0
 FICAPL = filpath("","APL","ini",APPLI)
 If filinfo(FICAPL,0)>=0
  Openi FICAPL Using [FAPL]
  Rdseq LIGNE Using [FAPL]
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If left$(LIGNE,10)="adxmother("
    J = instr(1,LIGNE,"=")
    If J
     LIGNE = vireblc(right$(LIGNE,J+1),2)
     LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
     If LIGNE<>APPLI & !find(LIGNE,TBMERE(1..NBMERE)) & filinfo(filpath("","","",LIGNE),0)>=0
      NBMERE += 1
      TBMERE(NBMERE) = LIGNE
     Endif
    Endif
   Endif
   Rdseq LIGNE Using [FAPL]
  Wend
  Openi Using [FAPL]
 Endif
Endif
Return
