#<AdxTL>@(#)0.0.0.0 $Revision$ Resynchronisation stocks
############################################################
# Resynchronisation stocks action SAISTOR
#                 Resynchronisation sites et allocations
#                 Resynchronisation lots
#                 Contrôle fichier couts FIFO
############################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_SYNSTO
  When "TERMINE"        : Gosub TERMINE_SYNSTO
  When "INIT"           : Gosub INIT_DIA_SYNSTO
  When "OK"             : Gosub OK_SYNSTO
  When "END"            : Gosub END_SYNSTO
Endcase
Return
#############################################################
$EXEC_SYNSTO
#Inter 1
Gosub TRT_INI
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE(mess(105,196,1),0) From GESECRAN
Else
  Call OUVRE_TRACE(mess(105,196,1)) From LECFIC
Endif

WMSG = mess(105,196,1)-[M:STOR]STOFCY
Call ECR_TRACE(WMSG,0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("STOR","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN
# La resynchro doit commencer par la resynchro des lignes de stock
# => resynchro des lots en dernier
If [M:STOR]FCYALL=2
    Local File FACILITY [FCY]
    Filter [FCY] Where WRHFLG = 2
&                Order By Key FCY0
    For [FCY]
        [M:STOR]STOFCY = [F:FCY]FCY
        Gosub TRT_FCY
    Next
    Filter [FCY]
    Close Local File [FCY]
Else
    Gosub TRT_FCY
Endif
Return
#############################################################
$TERMINE_SYNSTO
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Call IMPSCR From ATRTX3

Endif

If dim(GSTOZERO) > 0
   Kill GSTOZERO
Endif
Return

#############################################################
$INIT_DIA_SYNSTO
Local Mask STOR [STOR]
Raz [M:STOR]
[M:STOR]STOFCY = GFCYDEF(0)
Return
#############################################################
$OK_SYNSTO
FIN  = 1
Return
#############################################################
$END_SYNSTO
Raz [M:STOR]
FIN = 1
Return
#############################################################
$TRT_FCY
    If [M:STOR]SYNSTO = 2 : Call SYNSTO([M:STOR]STOFCY) : Endif
    If [M:STOR]SYNITV = 2 : Call SYNITV([M:STOR]STOFCY) : Endif
    If [M:STOR]SYNQLY = 2 : Call SYNQLY([M:STOR]STOFCY) : Endif
    If [M:STOR]SYNCUN = 2 : Call SYNCUN([M:STOR]STOFCY) : Endif
    If [M:STOR]CSTCTL = 2 : Call CTLSTP([M:STOR]STOFCY) : Endif
    If [M:STOR]SERCTL = 2 : Call SYNSER([M:STOR]STOFCY) : Endif
    If [M:STOR]SYNBBY = 2 : Call SYNBBY                 : Endif
    If [M:STOR]SYNLOT = 2 : Call SYNLOT([M:STOR]STOFCY) : Endif
    If [M:STOR]RAZFRE = 2 : Call RAZFRE([M:STOR]STOFCY) : Endif              # hcb V6CQ
    If [M:STOR]FEACTL = 2 : Call FEACTL                 : Endif              # hcb unicite
    If [M:STOR]LPNCTL = 2 : Call LPNCTL([M:STOR]STOFCY) : Endif              # hcb x3-86682
Return
############################################################
$TRT_INI
If !clalev([TUN])  : Local File TABUNIT    [TUN] : Endif
If !clalev([ITM])  : Local File ITMMASTER  [ITM] : Endif
If !clalev([ITF])  : Local File ITMFACILIT [ITF] : Endif
If !clalev([ITV])  : Local File ITMMVT     [ITV] : Endif
If !clalev([STL])  : Local File STOLOT     [STL] : Endif
If !clalev([SLF])  : Local File STOLOTFCY  [SLF] : Endif
If !clalev([STO])  : Local File STOCK      [STO] : Endif
If !clalev([STO1]) : Local File STOCK      [STO1]: Endif
If !clalev([STC])  : Local File STOLOC     [STC] : Endif
If !clalev([STJ])  : Local File STOJOU     [STJ] : Endif
If !clalev([STS])  : Local File STOSER     [STS] : Endif
If !clalev([STP])  : Local File STOCOST    [STP] : Endif
If !clalev([QLH])  : Local File STOQLYH    [QLH] : Endif
If !clalev([QLD])  : Local File STOQLYD    [QLD] : Endif
If !clalev([QLD1]) : Local File STOQLYD    [QLD1]: Endif
If !clalev([STA])  : Local File STOALL     [STA] : Endif
If !clalev([ORD])  : Local File ORDERS     [ORD] : Endif
If !clalev([SDD])  : Local File SDELIVERYD [SDD] : Endif
If !clalev([SDH])  : Local File SDELIVERY  [SDH] : Endif
If !clalev([CUD])  : Local File CUNLISDET  [CUD] : Endif

If !clalev([CUL])  : Local File CUNLISTE   [CUL] : Endif
If !clalev([CUN])  : Local File CUNSESSION [CUN] : Endif

If !clalev([SMD])  : Local File SMVTD      [SMD] : Endif
If !clalev([SMH])  : Local File SMVTH      [SMH] : Endif
If !clalev([ITP])  : Local File ITMBPS     [ITP] : Endif
If !clalev([STL1]) : Local File STOLOT     [STL1] : Endif              # hcb unicite
#--- Bug 73392
If !clalev([PND])  : Local File PRETURND   [PND] : Endif
If !clalev([PNH])  : Local File PRETURN    [PNH] : Endif
#---
#--- Issue 110327
If !clalev([STS1]) : Local File STOSER    [STS1] : Endif
#--- Issue X3-53322
If !clalev([LPN])  : Local File LPN       [LPN]  : Endif
If !clalev([LPN1]) : Local File LPN       [LPN1] : Endif              # hcb x3-86682
Return

########################################################
Subprog SYNSTO(PFCY)
Value Char PFCY

Local Decimal LQTYSTU
Local Decimal LQTYSTUACT
Local Decimal LQTYPCU
Local Decimal LPCUSTUCOE
Local Integer WRET
Local Char    WCRIT(250) : Raz WCRIT
Local Integer LNB, LINTER
Local Decimal WCUMALLQTA, WCUMALLQTY    # sr 12.06
WCRIT="1=1"
If [M:STOR]ITMREFEND<>""
    If [M:STOR]ITMREFSTR<>""
        WCRIT += "&[STO]ITMREF>=[M:STOR]ITMREFSTR"
    Endif
    WCRIT += "&[STO]ITMREF<=[M:STOR]ITMREFEND"
Endif
If [M:STOR]TCLCODEND<>""
    If [M:STOR]TCLCODSTR<>""
        WCRIT += "&[F:ITM]TCLCOD>=[M:STOR]TCLCODSTR"
    Endif
    WCRIT += "&[F:ITM]TCLCOD<=[M:STOR]TCLCODEND"
Endif

# On fait toujours un link car on a tout le temps besoin de la classe ITM
#--- Issue 91102 by TS
#Link [STO] With [ITM]ITM0=[STO]ITMREF
#&            As [LNK]
#Raz LNB
#For [LNK] Where STOFCY=PFCY
#&             & evalue(WCRIT)
#    LNB+=1
#Next
Link [STO] With  [ITM]ITM0=[STO]ITMREF  As [LNK]
&          Where STOFCY=PFCY & evalue(WCRIT)
LNB = rowcount([LNK])
#---

Call OUVRE_BOITE(PFCY-mess(96,184,1),LNB) From GESECRAN
Raz LNB

Call ECR_TRACE(PFCY-mess(96,184,1),0) From GESECRAN
#--- Issue 91102 by TS
#For [LNK] Where STOFCY=PFCY
#&             & evalue(WCRIT)
For [LNK]
#---
    LNB += 1
    Read [STO]STO0=[LNK]STOFCY;[LNK]STOCOU
    Call AFF_BOITE([F:STO]STOFCY-num$([F:STO]STOCOU),LNB,LINTER) From GESECRAN

    If [F:STO]QTYSTU < 0
        Readlock [STO] Curr
        If fstat = 0
            [F:STO]QTYSTU = 0
            Call REWSTO("",WRET) From STKLIB
            Case WRET
                When 1,2
                    GOK = 0
                    Call RSTA("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
                    Break
                When 3
                    GOK = 0
                    Call FSTA("STO") From GLOCK
                    Break
            Endcase
        Endif
    Else
        #--------- Calcul cumul allocations détaillées ----------#
        Look [STA]STA0(3)=[STO]STOFCY;[STO]ITMREF;[STO]STOCOU
        [G:STA]currlen=0
        If !fstat | [F:STO]CUMALLQTY<>0 | [F:STO]CUMALLQTA<>0
            Trbegin [STO]
            Columns [STO] (CUMALLQTY,CUMALLQTA)
            Readlock [STO] Curr
            If !fstat
                Raz [F:STO]CUMALLQTY,[F:STO]CUMALLQTA
                Columns [STA] (QTYSTU,QTYSTUACT)
                For [STA] Where STOFCY = [STO]STOFCY
&                             & ITMREF = [STO]ITMREF
&                             & STOCOU = [STO]STOCOU
                    [F:STO]CUMALLQTY += [STA]QTYSTU
                    [F:STO]CUMALLQTA += [STA]QTYSTUACT
                Next

                WCUMALLQTA = [F:STO]CUMALLQTA                    # sr 12.06
                WCUMALLQTY = [F:STO]CUMALLQTY                    # sr 12.06
                Call QTEARR(WCUMALLQTA,[F:ITM]STU) From TRTDIV   # sr 12.06
                Call QTEARR(WCUMALLQTY,[F:ITM]STU) From TRTDIV   # sr 12.06

                # Par sécurité...
#                If [F:STO]CUMALLQTA>[F:STO]QTYSTUACT | [F:STO]CUMALLQTY>[F:STO]QTYSTU        # sr 12.06
                If WCUMALLQTA>[F:STO]QTYSTUACT | WCUMALLQTY>[F:STO]QTYSTU                     # sr 12.06
                   Call ECR_TRACE( [STO]STOFCY-[STO]ITMREF-num$([STO]STOCOU)-":"-mess(35,191,1)-">"-mess(146,184,1),1) From GESECRAN
                   #[F:STO]CUMALLQTY = min ([F:STO]CUMALLQTY, [F:STO]QTYSTU)
                   #[F:STO]CUMALLQTA = min ([F:STO]CUMALLQTA, [F:STO]QTYSTUACT)
                Endif
                Columns [STA]
                Rewrite [STO]
            Endif
            Columns [STO]
            #--------- Vérification quantité ligne de stock avec n° série ---------#
            If [F:STO]SERNUM<>"" & [F:STO]CUMALLQTY>1
                Call ECR_TRACE( [STO]STOFCY-[STO]ITMREF-[STO]SERNUM-mess(33,105,1)-">1 & "+mess(35,191,1)-">1",1) From GESECRAN
            Endif
            Commit
        Endif
        #--------- Vérification quantité ligne de stock ---------#
        LQTYSTU    = [F:STO]QTYSTU
        LQTYSTUACT = [F:STO]QTYSTUACT
        LQTYPCU    = [F:STO]QTYPCU
        LPCUSTUCOE = [F:STO]PCUSTUCOE
        If [F:STO]SERNUM<>"" & [F:STO]QTYSTU>1
            Call ECR_TRACE(  [STO]STOFCY-[STO]ITMREF-[STO]SERNUM-mess(33,105,1)-">1 ",1) From GESECRAN
            LQTYSTU = 1
        Endif
        Gosub MODQTYACT
        If [F:STO]PCUSTUCOE<=0
            LPCUSTUCOE=1
        Else
            LPCUSTUCOE=[F:STO]PCUSTUCOE
        Endif
        #--- Bug 63963
        If LQTYSTU<>LQTYPCU | LPCUSTUCOE<>1
            LQTYPCU = [F:STO]QTYSTU/LPCUSTUCOE
            Call QTEARR(LQTYPCU,[STO]PCU) From TRTDIV
        #--- Bug 63963
        #--- Bug 63963
        Endif
        If LQTYSTU   <>[F:STO]QTYSTU
&        | LQTYSTUACT<>[F:STO]QTYSTUACT
&        | LQTYPCU   <>[F:STO]QTYPCU
&        | LPCUSTUCOE<>[F:STO]PCUSTUCOE
&        | [F:STO]OWNER = ""
            Trbegin [STO]
            Columns [STO] (QTYSTU,QTYSTUACT,QTYPCU,PCUSTUCOE,OWNER)
            If LQTYSTU   <>[F:STO]QTYSTU
&            | LQTYSTUACT<>[F:STO]QTYSTUACT
&            | LQTYPCU   <>[F:STO]QTYPCU
&            | LPCUSTUCOE<>[F:STO]PCUSTUCOE
               [F:STO]QTYSTU    = LQTYSTU
               [F:STO]QTYSTUACT = LQTYSTUACT
               [F:STO]QTYPCU    = LQTYPCU
               [F:STO]PCUSTUCOE = LPCUSTUCOE
               Call ECR_TRACE([STO]STOFCY-num$([STO]STOCOU)-[STO]ITMREF-[STO]SERNUM-mess(105,184,1)+":"
&                            -num$([F:STO]QTYSTU)-num$([F:STO]QTYSTUACT)-num$([F:STO]QTYPCU)-num$([F:STO]PCUSTUCOE),1) From GESECRAN
            Endif
            If [F:STO]OWNER = ""
               [F:STO]OWNER = [F:STO]STOFCY
               Call ECR_TRACE([STO]STOFCY-num$([STO]STOCOU)-[STO]ITMREF-[STO]SERNUM-mess(516,199,1),1) From GESECRAN
            Endif
            Rewrite [STO]
            Columns [STO]
            Commit
        Endif
        If [F:STO]PCU=""
            Call ECR_TRACE(  [STO]STOFCY-[STO]ITMREF-num$([STO]STOCOU)-":"-mess(331,184,1)-"[F:STO]PCU=''",1) From GESECRAN
        Endif
    Endif
Next

Call FERME_BOITE From GESECRAN

Call  STOZERO([M:STOR]STOFCY)

End

#####################
# Recalcule la quantité active en fonction de la quantité physique
$MODQTYACT
#lecture ITMFACILIT  pour recuperer STOMGTCOD
If [F:ITF]STOFCY <> [F:STO]STOFCY | [F:ITF]ITMREF <> [F:STO]ITMREF
   Read [ITF]ITF0 = [F:STO]ITMREF;[F:STO]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

    LQTYSTUACT=LQTYSTU
    If [F:STO]LOT<>"" & [F:ITF]STOMGTCOD>2
        If [STL]SLO   <>[STO]SLO
&        | [STL]LOT   <>[STO]LOT
&        | [STL]ITMREF<>[STO]ITMREF
            Read [STL]STL0=[STO]ITMREF;[STO]LOT;[STO]SLO
        Endif
        LQTYSTUACT=LQTYSTU*[F:STL]POT/100
        Call QTEARR(LQTYSTUACT,[ITM]STU) From TRTDIV
    Endif
Return

######################################################
#Resynchronisation du fichier ITV
Subprog SYNITV( PFCY )
Value Char PFCY

# Issue 80461 - 2012-03-14 by CCC : resynchro détail PMP
If dim(GDIMCST)<=0 : Global Integer GDIMCST : Endif
GDIMCST = GACTMAT+GACTMAC+GACTLAB+2+4     # = dim mat + dim mac + dim lab + sco + invdta + fg mat + fg mac + fg lab + fg sco
Local Char    TRUB(80)(31+GDIMCST*2)
Local Integer IRUB
Local Char    WINT(15)
Local Decimal WALL, WQTY
Local Char    WITM(GLONITM) : Raz WITM
Local Integer LNBREC, LMAX
Local Char    WCRIT(250)
Local Integer LNB, LINTER
Local Integer LSTOEXI

LMAX = 50

Raz WCRIT
WCRIT = "[F:ITF]ITMREF >= [M:STOR]ITMREFSTR"
If [M:STOR]ITMREFEND<>""
    WCRIT += "&[F:ITF]ITMREF <= [M:STOR]ITMREFEND"
Endif
If [M:STOR]TCLCODEND<>""
    WCRIT += "&[F:ITM]TCLCOD >= [M:STOR]TCLCODSTR"
    WCRIT += "&[F:ITM]TCLCOD <= [M:STOR]TCLCODEND"
Endif

Raz LNB
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&          As [LNK]
&          Where STOFCY        = PFCY
&              & [F:ITF]ITMREF > WITM
&              & [F:ITF]STOMGTCOD > 1
&              & evalue(WCRIT)
&          Order By Key ITF1
#--- Issue 91102 by TS
#For [LNK]
#    LNB+=1
#Next
LNB = rowcount([LNK])
#---
Call OUVRE_BOITE(PFCY-mess(405,197,1),LNB) From GESECRAN
Raz LNB
Call ECR_TRACE(PFCY-mess(405,197,1),0) From GESECRAN

$SYN_ITV1
Raz LNBREC
Trbegin [ITV]
Call DEBTRANS From GLOCK

Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&          As [LNK]
&          Where STOFCY        = PFCY
&              & [F:ITF]ITMREF > WITM
&              & [F:ITF]STOMGTCOD > 1
&              & evalue(WCRIT)
&          Order By Key ITF1
For [LNK]
  LNB += 1
  Call AFF_BOITE([F:ITF]ITMREF,LNB,LINTER) From GESECRAN
  WITM = [F:ITF]ITMREF
  Readlock [ITM]ITM0=[F:ITF]ITMREF
  Case fstat
    When 1 :
      Call ECR_TRACE(mess(20,100,1)+" : "+[F:ITM]ITMREF,1) From GESECRAN
      fstat = 0
    When 0 :
      If [F:ITF]STOMGTCOD > 1
         Filter [STO] Where ITMREF=[F:ITF]ITMREF & STOFCY=[F:ITF]STOFCY
&                     Order By Key STO3
         Look [STO] First
         Filter [STO]
         LSTOEXI = !fstat
         Readlock [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
         If fstat = 5 & !LSTOEXI
            Raz [F:ITV]
            [F:ITV]ITMREF=[F:ITF]ITMREF
            [F:ITV]STOFCY=[F:ITF]STOFCY
            [F:ITV]CREDAT = date$             # hcb 61120
            [F:ITV]CREUSR = GUSER             # hcb 61120
            [F:ITV]EXPNUM = [C]EXPORT         # hcb 61120
            Write [ITV]
            Call ECR_TRACE("ITV : "+mess(154,115,1)+" : "+[F:ITF]ITMREF+"/"+[F:ITF]STOFCY-"-->"-mess(51,197,1),0) From GESECRAN
            Readlock [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
         Endif
      Endif
      Case fstat
        When 1 :
          Call ECR_TRACE(mess(20,100,1)+" : [ITV]"+[F:ITM]ITMREF+";"+[F:ITF]STOFCY,1) From GESECRAN
        When 0 :
          GOK = 1
          Gosub MAJ_ITV
          If GOK = 0
            Call ECR_TRACE(mess(20,100,1)+" : "+[F:ITM]ITMREF,1) From GESECRAN
          Else
              LNBREC += 1
          Endif
        When Default :
          Call ECR_TRACE("ITV:"+[F:ITF]ITMREF+"/"+[F:ITF]STOFCY-"fstat="+num$(fstat),1) From GESECRAN
      Endcase
      fstat = 0
    When 5 : Call ECR_TRACE("ITM : "+mess(154,115,1)+" : "+[F:ITF]ITMREF,1) From GESECRAN
    When Default :
      Call ECR_TRACE("ITM:"+[F:ITF]ITMREF-"fstat="+num$(fstat),1) From GESECRAN
  Endcase
  fstat = 0
  If LNBREC > LMAX
    Break
  Endif
Next
Commit
If LNBREC > LMAX
    Goto SYN_ITV1
Endif
#
Call FERME_BOITE From GESECRAN
Call ECR_TRACE(mess(35,196,1),0) From GESECRAN
End

###########################################################
$MAJ_ITV
# Issue 80461 - 2012-03-14 by CCC : resynchro détail PMP
Local Decimal LAMTDET(1+GDIMCST*GACTDECCST)
Local Integer I
Local Char    W_FLD(20)(32+GDIMCST*2*GACTDECCST)
Local Integer W_START : W_START=5
Local Integer W_LEN : W_LEN=11
Local Decimal W_OLDCUM(dim(W_FLD))
Local Char    W_EVA(40)
Local Decimal W_CUM, W_VAL
Local Integer WRET
Local Char    WMSG(250)(5)
#--- Issue 101492 by TS
Local Decimal WRCPRET
# Issue 80993 - 2012-05-10 by CCC
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("ITMMVT","AVCBASAMT") From STKVALECR
#--- Issue 116722
GPOINT = "MOD_RNDVAL" : Gosub ENTREE From EXEFNC
#
W_FLD(00) = "sA1 PHYSTO    "
W_FLD(01) = "sQ1 CTLSTO    "
W_FLD(02) = "sR1 REJSTO    "
W_FLD(03) = "sA2 PLFPHYSTO "
W_FLD(04) = "sQ2 PLFCTLSTO "
W_FLD(05) = "sR2 PLFREJSTO "
W_FLD(06) = "sA3 BPRPHYSTO "
W_FLD(07) = "sQ3 BPRCTLSTO "
W_FLD(08) = "sR3 BPRREJSTO "
W_FLD(09) = "sA4 SCOPHYSTO "
W_FLD(10) = "sQ4 SCOCTLSTO "
W_FLD(11) = "sR4 SCOREJSTO "
W_FLD(12) = "aA12PHYALL    "
W_FLD(13) = "aQ12CTLALL    "
W_FLD(14) = "aR12REJALL    "
W_FLD(15) = "aA4 SCOPHYALL "
W_FLD(16) = "aQ4 SCOCTLALL "
W_FLD(17) = "aR4 SCOREJALL "
W_FLD(18) = "    DETSHT    "
W_FLD(19) = "    GLOALL    "
W_FLD(20) = "    GLOSHT    "
W_FLD(21) = "    TRFSTO    "
W_FLD(22) = "    TRASTO    "
W_FLD(23) = "    ORDSTO    "
W_FLD(24) = "    SALSTO    "
W_FLD(25) = "    WAISTO    "
W_FLD(26) = "l   AVCBASQTY "    # Issue 80461 - 2012-03-14 by CCC : "l" sert à préciser qu'il ne faut pas mettre la valeur à 0
W_FLD(27) = "    SCCLNDSTO "
W_FLD(28) = "    SCCALL    "
W_FLD(29) = "    TRAAMT    "
# Issue 80461 - 2012-03-14 by CCC : resynchro détail PMP
W_FLD(30) = "l   AVCBASAMT "
W_FLD(31) = "l   AVC       "
I=32
If GACTDECCST
    For J=0 To GACTMAT-1
        W_FLD(I) =  "l   AMATCST    ("+num$(J)+")"
        I+=1
        W_FLD(I) =  "l   AMATAVC    ("+num$(J)+")"
        I+=1
    Next
    For J=0 To GACTMAC-1
        W_FLD(I) =  "l   AMACCST    ("+num$(J)+")"
        I+=1
        W_FLD(I) =  "l   AMACAVC    ("+num$(J)+")"
        I+=1
    Next
    For J=0 To GACTLAB-1
        W_FLD(I) =  "l   ALABCST    ("+num$(J)+")"
        I+=1
        W_FLD(I) =  "l   ALABAVC    ("+num$(J)+")"
        I+=1
    Next
    W_FLD(I) =  "l   ASCOCST"
    I+=1
    W_FLD(I) =  "l   ASCOAVC"
    I+=1
    W_FLD(I) =  "l   AINVDTACST"
    I+=1
    W_FLD(I) =  "l   AINVDTAAVC"
    I+=1
    W_FLD(I) =  "l   AOVEMATCST"
    I+=1
    W_FLD(I) =  "l   AOVEMATAVC"
    I+=1
    W_FLD(I) =  "l   AOVEMACCST"
    I+=1
    W_FLD(I) =  "l   AOVEMACAVC"
    I+=1
    W_FLD(I) =  "l   AOVELABCST"
    I+=1
    W_FLD(I) =  "l   AOVELABAVC"
    I+=1
    W_FLD(I) =  "l   AOVESCOCST"
    I+=1
    W_FLD(I) =  "l   AOVESCOAVC"
Endif

#
# Effacement anciens cumuls et stockage ancienne valeur
#
For I = 0 To dim(W_FLD)-1
  If W_FLD(I)<>""
      W_EVA = "[F:ITV]"+mid$(W_FLD(I),W_START,len(W_FLD(I))-W_START+1)
      W_OLDCUM(I) = evalue(W_EVA)
      If left$(W_FLD(I),1)<>"l"
          Assign W_EVA With 0
      Endif
  Endif
Next I
Read [TUN]TUN0=[F:ITM]STU
If fstat
  Raz [F:TUN]
Endif
#
# Recalcul stocks
#
Filter [STO]
#--- Issue 91102 by TS
Columns [STO] (LOCCAT,QTYSTUACT,CUMALLQTA,OWNER,STOFCY,STA)
#---
For [STO]STO3 Hint Key STO3 Where ITMREF=[F:ITV]ITMREF & STOFCY=[F:ITV]STOFCY & QTYSTU>0
  If [F:STO]LOCCAT = 0
    [F:STO]LOCCAT = 1
  Endif
  WQTY = [F:STO]QTYSTUACT
  WALL = [F:STO]CUMALLQTA
  If [F:STO]OWNER<>[F:STO]STOFCY
    [F:ITV]SCCLNDSTO += WQTY
    [F:ITV]SCCALL    += WALL
  Else
    For I = 0 To dim(W_FLD)-1
      If W_FLD(I)<>""
          If left$(W_FLD(I),1) = "s" | left$(W_FLD(I),1) = "a"
            If left$([F:STO]STA,1) = mid$(W_FLD(I),2,1)
              If find([F:STO]LOCCAT,val(mid$(W_FLD(I),3,1)),val(mid$(W_FLD(I),4,1)))
                W_EVA = "[F:ITV]"+vireblc(mid$(W_FLD(I),W_START,len(W_FLD(I))-W_START+1),4)
                W_CUM = evalue(W_EVA)
                If left$(W_FLD(I),1) = "s"
                  W_CUM += WQTY
                Else
                  W_CUM += WALL
                Endif
                Assign W_EVA With W_CUM
              Endif
            Endif
          Endif
      Endif
    Next I
  Endif
Next
#--- Issue 91102 by TS
Columns [STO]
#---
# Recalcul bases quantité et montant PMP
WQTY=[F:ITV]AVCBASQTY
[F:ITV]AVCBASQTY = [F:ITV]PHYSTO + [F:ITV]PLFPHYSTO + [F:ITV]BPRPHYSTO + [F:ITV]SCOPHYSTO
&                + [F:ITV]CTLSTO + [F:ITV]PLFCTLSTO + [F:ITV]BPRCTLSTO + [F:ITV]SCOCTLSTO
&                + [F:ITV]REJSTO + [F:ITV]PLFREJSTO + [F:ITV]BPRREJSTO + [F:ITV]SCOREJSTO
# Issue 80277 - 2012-02-29 by CCC : On privilégie la conservation du PMP
# Issue 80461 - 2012-03-14 by CCC : resynchro détail PMP
#     car si la qté est désynchro, le montant doit certainement l'être aussi
#                                                            (1) Copie de AVC dans AMT      |     (2) Copie de AMT dans AVC
# AVCBASAMT       AVC       Détail AMT   Détail AVC  -->    Dét AVC(1)        Dét AMT (1)   |    Dét AMT (2)        Dét AVC(2)
#     0            0             0            0      -->        0           Dét AVC * QTY   |       0                  0
#     0            0             0           <>0     -->        0           Dét AVC * QTY   |       0                  0
#     0            0            <>0           0      -->        0           Dét AVC * QTY   |       0                  0
#     0            0            <>0          <>0     -->        0           Dét AVC * QTY   |       0                  0
#     0           <>0            0            0      -->  AMATAVC = AVC     Dét AVC * QTY   |       0             AMATAVC = AVC
#     0           <>0            0           <>0     -->      *= C1         Dét AVC * QTY   |       0                *= C1
#     0           <>0           <>0           0      -->  AMATAVC = AVC     Dét AVC * QTY   |       0             AMATAVC = AVC
#     0           <>0           <>0          <>0     -->      *= C1         Dét AVC * QTY   |       0                *= C1
#    <>0           0             0            0      -->        0           Dét AVC * QTY   |  AMATCST = AMT      Dét AMT * C3
#    <>0           0             0           <>0     -->        0           Dét AVC * QTY   |  AMATCST = AMT      Dét AMT * C3
#    <>0           0            <>0           0      -->        0           Dét AVC * QTY   |     *= C2           Dét AMT * C3
#    <>0           0            <>0          <>0     -->        0           Dét AVC * QTY   |     *= C2           Dét AMT * C3
#    <>0          <>0            0            0      -->  AMATAVC = AVC     Dét AVC * QTY   |  AMATCST = AMT      Dét AMT * C3
#    <>0          <>0            0           <>0     -->      *= C1         Dét AVC * QTY   |  AMATCST = AMT      Dét AMT * C3
#    <>0          <>0           <>0           0      -->  AMATAVC = AVC     Dét AVC * QTY   |     *= C2           Dét AMT * C3
#    <>0          <>0           <>0          <>0     -->      *= C1         Dét AVC * QTY   |     *= C2           Dét AMT * C3
# C1 = AVC/sum détail AVC
# C2 = AMT/sum détail AMT
# C3 = AVC/sum détail AMT

# (1) : We can't count on quantity AVCBASQTY
If WQTY<>[F:ITV]AVCBASQTY | [F:ITV]AVCBASQTY=0
    [F:ITV]AVC = arr([F:ITV]AVC,GRNDVAL)    # Issue 97144 - 2014-08-07 by CCC
    [F:ITV]AVCBASAMT = arr([F:ITV]AVC*[F:ITV]AVCBASQTY,GRNDVAL)
    # Issue 81960 - 2012-07-02 by CCC
    If GACTDECCST
        If [F:ITV]AVC=0
            Raz LAMTDET
            # Détail AVC --> reset
            Call LOADFIC("[F:ITV]",LAMTDET, "A", "AVC", 0, 0) From STKVALECR
        Else
            Call LOADVAR2(LAMTDET,"[F:ITV]", 0, "A", "AVC", 1, 0, GRNDVAL) From STKVALECR
            Call REPVAL([F:ITV]AVC,LAMTDET,GRNDVAL,LAMTDET) From STKVALECR
            If sum(LAMTDET)=0
                [F:ITV]AMATAVC(max(1,[F:ITM]BRDCOD)-1) = [F:ITV]AVC
            Else
                Call LOADFIC("[F:ITV]",LAMTDET, "A", "AVC", 1, 0) From STKVALECR
            Endif
        Endif
        # Resynchro détail AMT selon répartition de AVC
        Call LOADVAR2(LAMTDET,"[F:ITV]", 0, "A", "AVC", 1, 0, GRNDVAL) From STKVALECR
        Call REPVAL([F:ITV]AVCBASAMT,LAMTDET,GRNDVAL,LAMTDET) From STKVALECR
        Call LOADFIC("[F:ITV]",LAMTDET, "A", "CST", 1, 0) From STKVALECR
    Endif

# Bug 37024 - TS le 14.09.06
Elsif [F:ITV]AVCBASQTY>0
# (2) : We can count on quantity AVCBASQTY
    [F:ITV]AVCBASAMT = arr([F:ITV]AVCBASAMT,GRNDVAL)    # Issue 97144 - 2014-08-07 by CCC
    [F:ITV]AVC = arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,GRNDVAL)
    # Issue 81960 - 2012-07-02 by CCC
    If GACTDECCST
        # Resynchro détail base montant
        If [F:ITV]AVCBASAMT=0
            Raz LAMTDET
            # Détail AMT --> reset
            Call LOADFIC("[F:ITV]",LAMTDET, "A", "CST", 0, 0) From STKVALECR
        Else
            Call LOADVAR2(LAMTDET,"[F:ITV]", 0, "A", "CST", 1, 0, GRNDVAL) From STKVALECR
            Call REPVAL([F:ITV]AVCBASAMT,LAMTDET,GRNDVAL,LAMTDET) From STKVALECR
            If sum(LAMTDET)=0
                [F:ITV]AMATCST(max(1,[F:ITM]BRDCOD)-1) = [F:ITV]AVCBASAMT
            Else
                Call LOADFIC("[F:ITV]",LAMTDET, "A", "CST", 1, 0) From STKVALECR
            Endif
        Endif

        # Resynchro détail AVC
        If [F:ITV]AVCBASAMT=0 & [F:ITV]AVC<>0
            Call LOADVAR2(LAMTDET,"[F:ITV]", 0, "A", "AVC", 1, 0, GRNDVAL) From STKVALECR
            Call REPVAL([F:ITV]AVC,LAMTDET,GRNDVAL,LAMTDET) From STKVALECR
            If sum(LAMTDET)=0
                [F:ITV]AMATAVC(max(1,[F:ITM]BRDCOD)-1) = [F:ITV]AVC
            Else
                Call LOADFIC("[F:ITV]",LAMTDET, "A", "AVC", 1, 0) From STKVALECR
            Endif
        Else
            Call LOADVAR2(LAMTDET,"[F:ITV]", 0, "A", "CST", 1, 0, GRNDVAL) From STKVALECR
            Call REPVAL([F:ITV]AVC,LAMTDET,GRNDVAL,LAMTDET) From STKVALECR
            If sum(LAMTDET)=0
                Raz LAMTDET
                Call LOADFIC("[F:ITV]",LAMTDET, "A", "AVC", 0, 0) From STKVALECR
            Else
                Call LOADFIC("[F:ITV]",LAMTDET, "A", "AVC", [F:ITV]AVC/sum(LAMTDET), 0) From STKVALECR
            Endif
        Endif
    Endif
Endif
#
# Calcul sorties en attente
#
#--- Issue 91102 by TS
Columns [STJ] (QTYSTU,STOFCY,ITMREF,UPDCOD,REGFLG)
#---
For [STJ]STJ0 Where STOFCY=[F:ITV]STOFCY & UPDCOD =1 &
&                   ITMREF=[F:ITV]ITMREF & REGFLG<>2
  [F:ITV]WAISTO -= [F:STJ]QTYSTU
Next
#--- Issue 91102 by TS
Columns [STJ]
#---
If GOK = 0
  Return
Endif
#
# Recalcul stock transfert, allocations globale, manquants
#
#--- Issue 91102 by TS
Columns [STA] (ITMREF,STOFCY,ALLTYP,QTYSTUACT)
#---
For [STA]STA0 Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF
  Case [F:STA]ALLTYP
    When 1 : [F:ITV]GLOALL += [F:STA]QTYSTUACT
    When 4 : [F:ITV]DETSHT += [F:STA]QTYSTUACT
    When 5 : [F:ITV]GLOSHT += [F:STA]QTYSTUACT
  Endcase
Next
#--- Issue 91102 by TS
Columns [STA]
#---
#
# Recalcul quantité en commande et cdes clients fermes
#
#--- Issue 91102 by TS
Columns [ORD] (ITMREF,STOFCY,WIPTYP,WIPSTA,RMNEXTQTY)
#---
For [ORD]ORD1 Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF &
&                   WIPSTA=1 & find(WIPTYP,1,2,5,7,8,9)
  If find([F:ORD]WIPTYP,1,8)
    [F:ITV]SALSTO += [F:ORD]RMNEXTQTY
  Else
    [F:ITV]ORDSTO += [F:ORD]RMNEXTQTY
  Endif
Next
#--- Issue 91102 by TS
Columns [ORD]
#---
#
# Maj stock transféré et en transit pour livraisons inter-sites
#
# hcb 85992   rajout controle sur [F:SDH]SCO
Link [SDD] With [SDH]SDH0=SDHNUM As [SDL]
For [SDL]SDD2 Where [F:SDD]ITMREF=[F:ITV]ITMREF &
&                   [F:SDH]BETFCY=2 & [F:SDH]CFMFLG=2 & [F:SDH]SCO<>2 &
&                  ([F:SDH]STOFCY=[F:ITV]STOFCY | [F:SDH]PRHFCY=[F:ITV]STOFCY)
  #--- Bug 69038
  If [F:SDD]RCPFLG=2 & [F:SDD]RCPQTYSTU=0
     [F:SDD]RCPQTYSTU=[F:SDD]QTYSTU
     Rewrite [SDD]
  Endif
  #---

  #--- Issue 101492 by TS
  #If [F:SDH]STOFCY=[F:ITV]STOFCY
  #  [F:ITV]TRASTO += [F:SDD]QTYSTU-([F:SDD]RCPQTYSTU+[F:SDD]RTNQTYSTU) # hcb 77187
     # Issue 73085 - 2011-04-08 by CCC : resynchro du montant transféré
  #  If ([F:SDD]QTYSTU-([F:SDD]RCPQTYSTU+[F:SDD]RTNQTYSTU))<>0 & [F:SDD]QTYSTU<>0
  #      Raz W_VAL
  #      Call VALVCR([F:ITV]STOFCY, 4, [F:SDD]SDHNUM, [F:SDD]SDDLIN, W_VAL, WRET) From STKVAL
# Issue 79312 - 2012-01-16 by CCC
#        [F:ITV]TRAAMT += W_VAL*([F:SDD]QTYSTU-([F:SDD]RCPQTYSTU+[F:SDD]RTNQTYSTU))/[F:SDD]QTYSTU
  #      [F:ITV]TRAAMT -= W_VAL*([F:SDD]QTYSTU-([F:SDD]RCPQTYSTU+[F:SDD]RTNQTYSTU))/[F:SDD]QTYSTU
  #  Endif
  #Else
  #  [F:ITV]TRFSTO += [F:SDD]QTYSTU-([F:SDD]RCPQTYSTU+[F:SDD]RTNQTYSTU) # hcb 77187
  #Endif
  If [F:SDD]RCPQTYSTU<>0
     WRCPRET = [F:SDD]RCPQTYSTU
  Elsif [F:SDD]RTNQTYSTU<>0
     WRCPRET = [F:SDD]RTNQTYSTU
  Else
     WRCPRET = 0
  Endif
  If [F:SDH]STOFCY=[F:ITV]STOFCY
    [F:ITV]TRASTO += [F:SDD]QTYSTU-WRCPRET
    If ([F:SDD]QTYSTU-WRCPRET)<>0 & [F:SDD]QTYSTU<>0
        Raz W_VAL
        Call VALVCR([F:ITV]STOFCY, 4, [F:SDD]SDHNUM, [F:SDD]SDDLIN, W_VAL, WRET) From STKVAL
        [F:ITV]TRAAMT -= W_VAL*([F:SDD]QTYSTU-WRCPRET)/[F:SDD]QTYSTU
    Endif
  Else
    [F:ITV]TRFSTO += [F:SDD]QTYSTU-WRCPRET
  Endif
  #---

Next

#--- Bug 73392
Link [PND] With [PNH]PNH0=PNHNUM As [PNL]
For [PNL] Where [F:PND]ITMREF=[F:ITV]ITMREF &
&               [F:PNH]BETFCY=2 & [F:PNH]CFMFLG=2 &
&               ([F:PNH]PNHFCY=[F:ITV]STOFCY | [F:PND]LINSTOFCY=[F:ITV]STOFCY)

  If [F:PNH]PNHFCY=[F:ITV]STOFCY
    [F:ITV]TRASTO += [F:PND]QTYSTU-[F:PND]SRDQTYSTU
    # Issue 73085 - 2011-04-08 by CCC : resynchro du montant transféré
    If ([F:PND]QTYSTU-[F:PND]SRDQTYSTU)<>0 & [F:PND]QTYSTU<>0
        Raz W_VAL
        Call VALVCR([F:ITV]STOFCY, 8, [F:PND]PNHNUM, [F:PND]PNDLIN, W_VAL, WRET) From STKVAL
# Issue 79312 - 2012-01-16 by CCC
#        [F:ITV]TRAAMT += W_VAL*([F:PND]QTYSTU-[F:PND]SRDQTYSTU)/[F:PND]QTYSTU
        [F:ITV]TRAAMT -= W_VAL*([F:PND]QTYSTU-[F:PND]SRDQTYSTU)/[F:PND]QTYSTU
    Endif
  Else
    [F:ITV]TRFSTO += [F:PND]QTYSTU-[F:PND]SRDQTYSTU
  Endif
Next
#---

# Si les cumuls trf sont négatif, on les raz
If [F:ITV]TRASTO<0 [F:ITV]TRASTO=0 Endif
If [F:ITV]TRASTO=0 [F:ITV]TRAAMT=0 Endif
If [F:ITV]TRFSTO<0 [F:ITV]TRFSTO=0 Endif

# hcb 62726
GPOINT = "BEFREWITV"
Gosub ENTREE From EXEFNC


# Pas de mise à jour si cumuls identiques
Raz TRUB, IRUB
#
For I = 0 To dim(W_FLD)-1
  If W_FLD(I)<>""
      W_EVA = "[F:ITV]"+vireblc(mid$(W_FLD(I),W_START,len(W_FLD(I))-W_START+1),4)
      W_CUM = evalue(W_EVA)
      If W_OLDCUM(I) <>  W_CUM
        W_EVA = vireblc(mid$(W_FLD(I),W_START,W_LEN),4)
        Call TEXTFIC("ITMMVT",W_EVA,2,WINT) From OBJDIV
        TRUB(IRUB) = WINT+" : "+num$(W_OLDCUM(I))+"-->"+num$(W_CUM)
        IRUB += 1
      Endif
  Endif
Next I
If IRUB <> 0
  Rewrite [ITV]
  If fstat
    GOK = 0
    Call FSTA("ITV") From GLOCK
    Return
  Else
    WMSG = [F:ITV]ITMREF+" "+[F:ITV]STOFCY+" "+mess(27,196,1)+"-->"
&         +mess(23,196,1)
    I=0
    For J = 0 To IRUB-1
        If I=dim(WMSG)-1 & len(WMSG(I)+"\"+TRUB(J))>=type(WMSG)-10
            Break
        Endif
        Call ADDCRIT(WMSG, I, "", "\"+TRUB(J), "") From GOBJSUB
        If left$(WMSG(I),1)="\"
            WMSG(I)=right$(WMSG(I),2)
        Endif
      #WMSG = WMSG+"\"+TRUB(J)
    Next J
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
Endif
Raz WMSG
Return

###########################################################
#Resynchronisation du fichier LOT
Subprog SYNLOT(PFCY)
Value Char PFCY

Call TEMPON(mess(404,197,1)) From GESECRAN
Call ECR_TRACE(mess(404,197,1),0) From GESECRAN

Local Char    TRUB(50)(30)
Local Integer IRUB
Local Char    WINT(15)
Local Decimal WPHY, WCTL, WREJ, WAVC
Local Char    WITM(GLONITM) : Raz WITM
Local Integer LNBREC, LMAX
Local Char    WCRIT(250)
Raz LNBREC
LMAX = 50

WCRIT="1=1"
If [M:STOR]ITMREFEND<>""
    If [M:STOR]ITMREFSTR<>""
        WCRIT+="&ITMREF>=[M:STOR]ITMREFSTR"
    Endif
    WCRIT+="&ITMREF<=[M:STOR]ITMREFEND"
Endif
If [M:STOR]TCLCODEND<>""
    If [M:STOR]TCLCODSTR<>""
        WCRIT+="&[F:ITM]TCLCOD>=[M:STOR]TCLCODSTR"
    Endif
    WCRIT+="&[F:ITM]TCLCOD<=[M:STOR]TCLCODEND"
Endif

$SYN_LOT1
Trbegin [SLF]
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&          As [LNK]
&          Where STOFCY        = PFCY
&              & [F:ITF]ITMREF > WITM
&              & evalue(WCRIT)
&          Order By Key ITF1
For [LNK]
  Readlock [ITM]ITM0=[F:ITF]ITMREF
  Case fstat
    When 1 :
      Call ECR_TRACE(mess(20,100,1)+" : "+[F:ITM]ITMREF,1) From GESECRAN
      fstat = 0
    When 0 :
      Readlock [ITF]ITF0=[F:ITM]ITMREF;PFCY
      Case fstat
        When 1 :
          Call ECR_TRACE(mess(20,100,1)+" : "+[F:ITF]ITMREF,1) From GESECRAN
          fstat = 0
        When 0 :       #--- Issue 121438 add STOFCY=PFCY
          Filter [SLF] Where ITMREF = [F:ITF]ITMREF & STOFCY=PFCY
&                      Order By Key SLF0
          For [SLF]
            Readlock [SLF] Curr
            Readlock [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO
            Case fstat
              When 1 :
                Call ECR_TRACE(mess(20,100,1)+" : [STL]"+[F:ITF]ITMREF+";"+[F:SLF]LOT+";"+[F:SLF]SLO,1) From GESECRAN
              When 0 :
                GOK = 1
                Gosub MAJ_LOT
                If GOK = 0
                    Call ECR_TRACE(mess(20,100,1)+" : [STL]"+[F:ITF]ITMREF+";"+[F:SLF]LOT+";"+[F:SLF]SLO,1) From GESECRAN
                Else
                    LNBREC += 1
                Endif
              When Default :
                Call ECR_TRACE("fstat="+num$(fstat)+" : [STL]"+[F:ITF]ITMREF+";"+[F:SLF]LOT+";"+[F:SLF]SLO,1) From GESECRAN
            Endcase
          Next
          Filter [SLF]
        When Default :
          Call FSTA("ITF") From GLOCK
      Endcase
    When Default :
        Call ECR_TRACE("fstat="+num$(fstat)+" : [ITM]"+[F:ITF]ITMREF,1) From GESECRAN
  Endcase
  fstat = 0
  WITM = [F:ITM]ITMREF
  If LNBREC > LMAX
    Break
  Endif
Next
Commit
If LNBREC > LMAX
  LNBREC = 0
  Goto SYN_LOT1
Endif
#
Call TEMPOFF From GESECRAN
Call ECR_TRACE(mess(36,196,1),0) From GESECRAN
End
###########################################################
$MAJ_LOT
Local Integer WRET

# Pour UPDLOTAVC
Local Integer I
# Issue 80993 - 2012-05-10 by CCC
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("STOLOTFCY","AVC") From STKVALECR

WPHY = [F:SLF]AAACUMQTY
WCTL = [F:SLF]QQQCUMQTY
WREJ = [F:SLF]RRRCUMQTY
WAVC = [F:SLF]AVCBASQTY
[F:SLF]AAACUMQTY = 0
[F:SLF]QQQCUMQTY = 0
[F:SLF]RRRCUMQTY = 0
[F:SLF]AVCBASQTY = 0
Filter [STO] Where ITMREF = [F:SLF]ITMREF &
&                  STOFCY = [F:SLF]STOFCY &
&                  LOT    = [F:SLF]LOT    &
&                  SLO    = [F:SLF]SLO    &
&                  QTYSTU > 0
For [STO]STO3
  If left$([F:STO]STA,1)="A"    [F:SLF]AAACUMQTY+=[F:STO]QTYSTU    Endif
  If left$([F:STO]STA,1)="Q"    [F:SLF]QQQCUMQTY+=[F:STO]QTYSTU    Endif
  If left$([F:STO]STA,1)="R"    [F:SLF]RRRCUMQTY+=[F:STO]QTYSTU    Endif
  If [F:STO]STOFCY=[F:STO]OWNER [F:SLF]AVCBASQTY+=[F:STO]QTYSTUACT Endif
Next
Filter [STO]
If GOK <> 1
  Return
Endif
Raz TRUB, IRUB
If [F:SLF]AAACUMQTY <> WPHY
  Call TEXTFIC("STOLOTFCY","AAACUMQTY",2,WINT) From OBJDIV
  TRUB(IRUB) = WINT+" : "+num$([F:SLF]AAACUMQTY-WPHY)
  IRUB += 1
Endif
If [F:SLF]QQQCUMQTY <> WCTL
  Call TEXTFIC("STOLOTFCY","QQQCUMQTY",2,WINT) From OBJDIV
  TRUB(IRUB) = WINT+" : "+num$([F:SLF]QQQCUMQTY-WCTL)
  IRUB += 1
Endif
If [F:SLF]RRRCUMQTY <> WREJ
  Call TEXTFIC("STOLOTFCY","RRRCUMQTY",2,WINT) From OBJDIV
  TRUB(IRUB) = WINT+" : "+num$([F:SLF]RRRCUMQTY-WREJ)
  IRUB += 1
Endif
If [F:SLF]AVCBASQTY <> WAVC
  Call TEXTFIC("STOLOTFCY","AVCBASQTY",2,WINT) From OBJDIV
  TRUB(IRUB) = WINT+" : "+num$([F:SLF]AVCBASQTY-WAVC)
  IRUB += 1
  Gosub UPDLOTAVC From STKVALMAJ2
Endif
If [F:STL]SHLDAT = [0/0/0]
  [F:STL]SHLDAT    = [31/12/2999]
  Call REWSTL From STKLIB
  If fstat
    Call ECR_TRACE("fstat="+num$(fstat)+" : [SLF]"+[F:ITF]ITMREF+";"+[F:SLF]LOT+";"+[F:SLF]SLO+";"+[F:SLF]STOFCY,1) From GESECRAN
    GOK = 0
    Return
  Endif
Endif
If IRUB <> 0
  Call REWSLF From STKLIB
  If fstat
    Call FSTA("SLF") From GLOCK
    GOK = 0
    Return
  Endif
  WMSG = [F:SLF]ITMREF+" "+[F:SLF]LOT+" "+mess(26,196,1)+"-->"+mess(23,196,1)
  For J = 0 To IRUB-1
    WMSG = WMSG+"\"+TRUB(J)
  Next J
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Unlock [SLF]
  Unlock [STL]
Endif
Return

################################################################
# Resynchro des demandes d'analyses
################################################################
# Algo:
# 1- Boucle sur QLD:
#        existance QLH | existance STO |         action
#        --------------+---------------+-----------------------------------------
#              0       |       0       | suppression QLD
#              0       |       1       | création QLH
#              1       |       0       | [QLH]VALFLG=2 si existance STJ, sinon suppression QLD
#              1       |       1       | rien + [QLH]VALFLG=1 + réajustement qté ssi lien 1:1 entre STO et QLD
#
# 2- Boucle sur STO (avec n° de demande):
#        existance QLD | existance QLH |         action
#        --------------+---------------+-----------------------------------------
#              0       |       0       | Raz QLYCTLDEM
#              0       |       1       | création QLD
#              1       |       0       | création QLH + ctrl quantité [STO]/[QLD]
#              1       |       1       | rien + ctrl quantité [STO]/[QLD]
#
# 3- Boucle sur [QLH]
#     si pas de QLD associé => suppression de QLH
#
################################################################
Subprog SYNQLY(PFCY)
Value Char PFCY

Local Integer LNBREC, LMAX
Local Char WNUM(GLONVCR)
Local Decimal WCOU
Local Integer WLIN
Local Integer LEXIQLH, LEXIQLD
Local Integer LNB, LINTER
Local Char WWSG(250), WTXT(50)
Local Decimal LQTYPCU, LQTYSTU
Local Integer LQLHVAL

LMAX = 50
Raz WNUM,WLIN

#---------------------------------#
#------------ 1ère étape ---------#
#---------------------------------#
If [M:STOR]TCLCODEND<>""
    WCRIT = "[QLD]ITMREF >= [M:STOR]ITMREFSTR"
    If [M:STOR]ITMREFEND<>""
        WCRIT += "&[QLD]ITMREF <= [M:STOR]ITMREFEND"
    Endif
    WCRIT += "&[F:ITM]TCLCOD >= [M:STOR]TCLCODSTR"
    WCRIT += "&[F:ITM]TCLCOD <= [M:STOR]TCLCODEND"
    # On fait toujours un link car on a tout le temps besoin de la classe ITM
    Link [QLD] With [ITM]ITM0=[QLD]ITMREF
&            As [LNK]
Else
    WCRIT = "[LNK]ITMREF >= [M:STOR]ITMREFSTR"
    If [M:STOR]ITMREFEND<>""
        WCRIT += "&[LNK]ITMREF <= [M:STOR]ITMREFEND"
    Endif
    Local File STOQLYD [LNK]
Endif

Raz LNB
For [LNK] Where STOFCY=PFCY
&             & QTYSTU>0
&             & evalue(WCRIT)
    LNB+=1
Next
Call OUVRE_BOITE(PFCY-mess(97,184,1)-mess(120,117,1)+":1",LNB) From GESECRAN
Raz LNB

Call ECR_TRACE(mess(97,184,1),0) From GESECRAN

$QLD_LOOP
Raz LNBREC
Trbegin [QLD]
For [LNK] Where STOFCY=PFCY
&             & ( VCRTYP=28 & VCRNUM=WNUM & VCRLIN>WLIN
&                |VCRTYP=28 & VCRNUM>WNUM )
&             & QTYSTU>0
&             & evalue(WCRIT)
    If [F:QLD]VCRNUM<>WNUM
        If WNUM<>"" & LQLHVAL=2
            Readlock [QLH]QLH0=28;WNUM
            [F:QLH]VALFLG = 2
            Rewrite [QLH]
        Endif
        LQLHVAL = 2
    Endif
    Read [QLD]QLD0=28;[LNK]VCRNUM;[LNK]VCRLIN
    LNB +=1
    Call AFF_BOITE([QLD]VCRNUM-num$([QLD]VCRLIN),LNB,LINTER) From GESECRAN
    WNUM = [QLD]VCRNUM
    WLIN = [QLD]VCRLIN
    Filter [STO] Where ITMREF   =[F:QLD]ITMREF
&                    & STOFCY   =[F:QLD]STOFCY
&                    & LOT      =[F:QLD]LOT
&                    & SLO      =[F:QLD]SLO
&                    & LOC      =[F:QLD]LOC
&                    & STA      =[F:QLD]STA
&                    & SERNUM   =[F:QLD]SERNUM
&                    & PCU      =[F:QLD]PCU
&                    & PCUSTUCOE=[F:QLD]PCUSTUCOE
&                    & PALNUM   =[F:QLD]PALNUM
&                    & CTRNUM   =[F:QLD]CTRNUM
&                    & OWNER    =[F:QLD]OWNER
&                    & QLYCTLDEM=[F:QLD]VCRNUM
&                    & STOFLD1  =[F:QLD]STOFLD1
&                    & STOFLD2  =[F:QLD]STOFLD2
    Look [STO]STO3 First
    If fstat
        Read [QLH]QLH0=28;[QLD]VCRNUM
        If fstat
            Call ECR_TRACE(mess(98,184,1)-[QLD]VCRNUM-num$([QLD]VCRLIN)-[QLD]STOFCY-[QLD]ITMREF-"-->"-mess(127,195,1),1) From GESECRAN
            Readlock [QLD] Curr
            Delete [QLD] Curr
            LNBREC+=1
        Else
            If [QLH]VALFLG=1
                Look [STJ]STJ1=PFCY;[QLD]VCRTYP;[QLD]VCRNUM;[QLD]VCRLIN
                If fstat
                    Call ECR_TRACE(mess(98,184,1)-[QLD]VCRNUM-num$([QLD]VCRLIN)-[QLD]STOFCY-[QLD]ITMREF-"-->"-mess(127,195,1),1) From GESECRAN
                    Readlock [QLD] Curr
                    Delete [QLD] Curr
                    LNBREC+=1
                Endif
            Endif
        Endif
    Else
        LQLHVAL = 1
        Read [STO]STO3 First
        Read [QLH]QLH0=28;[QLD]VCRNUM
        If fstat
            Gosub CREQLH
            LNBREC +=1
        Else
            If [QLH]VALFLG=2
                Call ECR_TRACE(mess(99,184,1)+"-->"+mess(100,184,1)+":"+[F:QLH]VCRNUM,1) From GESECRAN
                Columns [QLH] (VALFLG)
                Readlock [QLH]Curr
                [QLH]VALFLG=1
                Rewrite [QLH]
                LNBREC+=1
                Columns [QLH]
            Endif
        Endif
        #--- vérification correspondance de la quantité ----#
        #--- cela ne se fait que s'il n'y a qu'une seule ligne de QC avec les mêmes caractéristiques ---#
        Filter [QLD1] Where VCRTYP   =[QLD]VCRTYP
&                         & VCRNUM   =[QLD]VCRNUM
&                         & VCRLIN  <>[QLD]VCRLIN
&                         & ITMREF   =[F:QLD]ITMREF
&                         & STOFCY   =[F:QLD]STOFCY
&                         & LOT      =[F:QLD]LOT
&                         & SLO      =[F:QLD]SLO
&                         & LOC      =[F:QLD]LOC
&                         & STA      =[F:QLD]STA
&                         & SERNUM   =[F:QLD]SERNUM
&                         & PCU      =[F:QLD]PCU
&                         & PCUSTUCOE=[F:QLD]PCUSTUCOE
&                         & PALNUM   =[F:QLD]PALNUM
&                         & CTRNUM   =[F:QLD]CTRNUM
&                         & OWNER    =[F:QLD]OWNER
&                         & STOFLD1  =[F:QLD]STOFLD1
&                         & STOFLD2  =[F:QLD]STOFLD2
        Look [QLD1] First
        Filter [QLD1]
        If fstat & ( [F:STO]QTYSTU > [F:QLD]QTYSTU
&                   |[F:STO]QTYPCU > [F:QLD]QTYPCU )
            Call ECR_TRACE([F:QLD]VCRNUM-num$([F:QLD]VCRLIN)-":"-mess(240,194,1),1) From GESECRAN
            Readlock [STO] Curr
            [F:QLD]QTYSTU = [F:STO]QTYSTU
            [F:QLD]QTYPCU = [F:STO]QTYPCU
            Rewrite [QLD]
            LNBREC +=1
        Endif
    Endif
    Filter [STO]
    If LNBREC>LMAX
        Break
    Endif
Next
If LNBREC>LMAX
    Commit
    Goto QLD_LOOP
Endif
If WNUM<>"" & LQLHVAL=2
    Readlock [QLH]QLH0=28;WNUM
    [F:QLH]VALFLG = 2
    Rewrite [QLH]
Endif
Commit

Call FERME_BOITE From GESECRAN
If clalev([LNK]) : Close Local File [LNK] : Endif

#---------------------------------#
#------------ 2nde étape ---------#
#---------------------------------#
If [M:STOR]TCLCODEND<>""
    WCRIT = "[STO]ITMREF >= [M:STOR]ITMREFSTR"
    If [M:STOR]ITMREFEND<>""
        WCRIT += "&[STO]ITMREF <= [M:STOR]ITMREFEND"
    Endif
    WCRIT += "&[F:ITM]TCLCOD >= [M:STOR]TCLCODSTR"
    WCRIT += "&[F:ITM]TCLCOD <= [M:STOR]TCLCODEND"
    # On fait toujours un link car on a tout le temps besoin de la classe ITM
    Link [STO] With [ITM]ITM0=[STO]ITMREF
&            As [LNK]
Else
    WCRIT = "[LNK]ITMREF >= [M:STOR]ITMREFSTR"
    If [M:STOR]ITMREFEND<>""
        WCRIT += "&[LNK]ITMREF <= [M:STOR]ITMREFEND"
    Endif
    Local File STOCK [LNK]
Endif

Raz LNB
For [LNK] Where STOFCY=PFCY
&             & QLYCTLDEM <> ""
&             & evalue(WCRIT)
    LNB+=1
Next
Call OUVRE_BOITE(PFCY-mess(97,184,1)-mess(120,117,1)+":2",LNB) From GESECRAN
Raz LNB



Raz WNUM
$STO_LOOP
Raz LNBREC
Trbegin [QLH]
For [LNK] Where STOFCY=PFCY
&             & STOCOU>WCOU
&             & QLYCTLDEM <> ""
&             & evalue (WCRIT)
    Read [STO]STO0=[LNK]STOFCY;[LNK]STOCOU
    LNB+=1
    Call AFF_BOITE([STO]STOFCY-num$([STO]STOCOU),LNB,LINTER) From GESECRAN
    Raz LEXIQLH, LEXIQLD
    WCOU = [F:STO]STOCOU
   Look [QLH]QLH0=28;[F:STO]QLYCTLDEM
    If !fstat : LEXIQLH = 1 : Endif

    #--- Issue 110327
    If [F:ITM]ITMREF<>[F:STO]ITMREF
       Read [ITM]ITM0=[F:STO]ITMREF
    Endif
    #---
#                                                              hcb V6CQ deb
    If [F:ITF]ITMREF<>[F:STO]ITMREF | [F:ITF]STOFCY<>[F:STO]STOFCY
       Read [ITF]ITF0=[F:STO]ITMREF;[F:STO]STOFCY
       If fstat
          Raz [F:ITF]
       Endif
    Endif
#                                                              hcb V6CQ fin
    Filter [QLD] Where ITMREF   =[F:STO]ITMREF
&                    & STOFCY   =[F:STO]STOFCY
&                    & LOT      =[F:STO]LOT
&                    & SLO      =[F:STO]SLO
&                    & LOC      =[F:STO]LOC
&                    & STA      =[F:STO]STA
&                    & SERNUM   =[F:STO]SERNUM
&                    & PCU      =[F:STO]PCU
&                    & PCUSTUCOE=[F:STO]PCUSTUCOE
&                    & PALNUM   =[F:STO]PALNUM
&                    & CTRNUM   =[F:STO]CTRNUM
&                    & OWNER    =[F:STO]OWNER
&                    & VCRNUM   =[F:STO]QLYCTLDEM
&                    & STOFLD1  =[F:STO]STOFLD1
&                    & STOFLD2  =[F:STO]STOFLD2
    Columns [QLD] (QTYSTU,QTYPCU)
    Raz LQTYSTU,LQTYPCU
    For [QLD]QLD1
        LEXIQLD = 1
        LQTYSTU += [QLD]QTYSTU
        LQTYPCU += [QLD]QTYPCU
    Next
    Columns [QLD]
    Filter [QLD]
    If !LEXIQLD
        If LEXIQLH
            Gosub CREQLD
            LNBREC +=1
        Else
            If [F:STO]SERNUM=""
                Gosub AGREG_STO
            Else
                Readlock [STO] Curr
                [STO]QLYCTLDEM=""
                Rewrite [STO]
            Endif
            LNBREC +=1
        Endif
    Else    #--- Contrôle des quantités ---#
        If !LEXIQLH
            LEXIQLH = 1
            Gosub CREQLH
            LNBREC +=1
        Endif
        If [F:STO]QTYSTU > LQTYSTU
&        | [F:STO]QTYPCU > LQTYPCU
            # On vérifie qu'il n'y a pas plus de chose à contrôler dans la ligne de stock que dans les lignes de QC
            WMSG = [F:STO]STOFCY-num$([F:STO]STOCOU)-":"-mess(110,184,1)+"("
            Call TEXTE(6242,WTXT) From OBJDIV
            WMSG+= WTXT+"="
            If [F:STO]QTYSTU > LQTYSTU
                If [ITM]ITMREF<>[F:STO]ITMREF
                    Read [ITM]ITM0=[F:STO]ITMREF
                Endif
                WMSG+= num$([F:STO]QTYSTU)+" "+[F:ITM]STU
            Else
                WMSG+= num$([F:STO]QTYPCU)+" "+[F:STO]PCU
            Endif
            Call TEXTE(3275,WTXT) From OBJDIV
            WMSG+= " "+WTXT+"="
            If [F:STO]QTYSTU > LQTYSTU
                WMSG+= num$(LQTYSTU)+" "+[F:ITM]STU
            Else
                WMSG+= num$(LQTYPCU)+" "+[F:STO]PCU
            Endif
            WMSG += ")"
            Call ECR_TRACE(WMSG,1) From GESECRAN
        Endif
    Endif

    If left$([F:STO]STA,1) = "A" &  [F:STO]QLYCTLDEM <> ""   # hcb 38149 deb
       If [F:STO]SERNUM=""
          Gosub AGREG_STO
       Else
           Readlock [STO] Curr
           [STO]QLYCTLDEM=""
           Rewrite [STO]
       Endif
    Endif                                                    # hcb 38149 fin

    If LNBREC>LMAX
        Break
    Endif
Next

Commit


If LNBREC>LMAX
    Goto STO_LOOP
Endif
Call FERME_BOITE From GESECRAN
If clalev([LNK]) : Close Local File [LNK] : Endif

#------------ 3ème étape ---------#
If [M:STOR]TCLCODEND<>""
    WCRIT = "[QLH]ITMREF >= [M:STOR]ITMREFSTR"
    If [M:STOR]ITMREFEND<>""
        WCRIT += "&[QLH]ITMREF <= [M:STOR]ITMREFEND"
    Endif
    WCRIT += "&[F:ITM]TCLCOD >= [M:STOR]TCLCODSTR"
    WCRIT += "&[F:ITM]TCLCOD <= [M:STOR]TCLCODEND"
    Link [QLH] With [ITM]ITM0=[QLH]ITMREF
&            As [LNK]
Else
    WCRIT = "[LNK]ITMREF >= [M:STOR]ITMREFSTR"
    If [M:STOR]ITMREFEND<>""
        WCRIT += "&[LNK]ITMREF <= [M:STOR]ITMREFEND"
    Endif
    Local File STOQLYH [LNK]
Endif

Raz LNB
For [LNK] Where STOFCY=PFCY
&             & evalue(WCRIT)
    LNB+=1
Next
Call OUVRE_BOITE(PFCY-mess(97,184,1)-mess(120,117,1)+":3",LNB) From GESECRAN
Raz LNB

Trbegin [QLH]
For [LNK] Where STOFCY=PFCY
&             & evalue(WCRIT)
    LNB+=1
    Call AFF_BOITE([QLH]STOFCY-[QLH]VCRNUM,LNB,LINTER) From GESECRAN
    Look [QLD]QLD0(2)=[LNK]VCRTYP;[LNK]VCRNUM
    [G:QLD]currlen=0
    If fstat
        Readlock [QLH]QLH0=[LNK]VCRTYP;[LNK]VCRNUM
        Delete [QLH] Curr
        Call ECR_TRACE(mess(111,184,1)-[QLH]VCRNUM-[QLH]STOFCY-[QLH]ITMREF-"-->"-mess(127,195,1),1) From GESECRAN
    Endif
Next
Commit
Call FERME_BOITE From GESECRAN
If clalev([LNK]) : Close Local File [LNK] : Endif

End

######################################################
# Crée un en-tête de demande d'analyse à partir d'une ligne de stock
$CREQLH
Raz [F:QLH]
[F:QLH] = [F:STO]
[F:QLH]VCRTYP   = 28
[F:QLH]VCRNUM   = [F:STO]QLYCTLDEM
[F:QLH]STOFCY   = [F:STO]STOFCY
[F:QLH]ITMREF   = [F:STO]ITMREF
[F:QLH]VCRTYPORI= 0
[F:QLH]VCRNUMORI= ""
[F:QLH]TRSCOD   = ""
[F:QLH]ENDCTLDAT= date$+[F:ITF]QUALTI : # Voir s/p dans le futur !
#[F:QLH]QLYCRD   = [F:ITM]QLYCRD         # hcb V6CQ
[F:QLH]VALFLG   = 1

Call ECRQLH From STKLIB
If fstat
    Call FSTA("QLH") From GLOCK
Else
    Call ECR_TRACE(mess(469,197,1)-"28"-[F:QLH]VCRNUM-[F:QLH]STOFCY-[F:QLH]ITMREF-mess(224,197,1),1) From GESECRAN
Endif
Return

######################################################
# Crée une ligne de demande d'anlyse à partir d'une ligne de stock
$CREQLD
Raz [F:QLD]
[F:QLD] = [F:STO]
[F:QLD]VCRTYP   = 28
[F:QLD]VCRNUM   = [F:STO]QLYCTLDEM
[F:QLD]STOFCY   = [F:STO]STOFCY
[F:QLD]ITMREF   = [F:STO]ITMREF
[F:QLD]VCRLINORI= 0
[F:QLD]QTYPCU   = [F:STO]QTYPCU
[F:QLD]QTYSTU   = [F:STO]QTYSTU
#          determination Fiche qualite           hcb V6CQ deb
# dans le cas de la resynchro ont ne tiens pas compte du cas de la reception
# (voir gestion dans STKMAJ) en effet il faudrait lire le STOJOU pour récuperer
# le BPSNUM , avec pour conséquence d'alourdir considérablement les temps de reponses
[F:QLD]QLYCRD   = [F:ITF]QLYCRD   # hcb V6CQ

Call ECRQLD From STKLIB
If fstat
    Call FSTA("QLD") From GLOCK
Else
    Call ECR_TRACE(num$([F:QLD]VCRTYP)-[F:QLD]VCRNUM-num$([F:QLD]VCRLIN)-[F:QLD]STOFCY-[F:QLD]ITMREF-mess(224,197,1),1) From GESECRAN
Endif
Return

######################################################
# agrégation d'une ligne de stock sur une autre
# La ligne de stock à supprimer étant en QC,
# elle ne peut pas avoir d'alloc => pas de mise à jour des cumuls alloués
#                                                                            # hcb X3-86682  rajout lpnnum
$AGREG_STO
    Filter [STO1] Where ITMREF   =[F:STO]ITMREF
&                     & STOFCY   =[F:STO]STOFCY
&                     & LOT      =[F:STO]LOT
&                     & SLO      =[F:STO]SLO
&                     & LOC      =[F:STO]LOC
&                     & STA      =[F:STO]STA
&                     & PCU      =[F:STO]PCU
&                     & PCUSTUCOE=[F:STO]PCUSTUCOE
&                     & PALNUM   =[F:STO]PALNUM
&                     & CTRNUM   =[F:STO]CTRNUM
&                     & OWNER    =[F:STO]OWNER
&                     & LPNNUM   =[F:STO]LPNNUM
&                     & QLYCTLDEM=""
&                     & STOFLD1  =[F:STO]STOFLD1
&                     & STOFLD2  =[F:STO]STOFLD2
    Readlock [STO1]STO3 First
    Case fstat
        When 0 :
            [F:STO1]QTYPCU    += [F:STO]QTYPCU
            [F:STO1]QTYSTU    += [F:STO]QTYSTU
            [F:STO1]QTYSTUACT += [F:STO]QTYSTUACT
            Rewrite [STO1]
            #--- Issue 110327
            If [F:ITM]SERMGTCOD=4
              Update [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU With STOCOU=[F:STO1]STOCOU
            Endif
            #---
            Delete [STO] Curr
            Raz [F:STO]
        When 1 :
            Call FSTA("STO1") From GLOCK
        When Default
            Readlock [STO] Curr
            Raz [F:STO]QLYCTLDEM                                                 #
            Rewrite [STO]
       Endcase
    Filter [STO1]
Return

######################################################
Subprog SYNCUN(PFCY)
Value Char PFCY
Local Integer LNBREC, LMAX
Local Decimal WCOU
Local Char WITM(GLONITM)
Local Char WLOC(GLONLOC)
LMAX = 500
Raz WITM
Raz WLOC
Call TEMPON(mess(139,184,1)) From GESECRAN
Call ECR_TRACE(PFCY-mess(139,184,1),0) From GESECRAN

#-------------------- Vérification ligne de stock bloquée pour inventaire ----------#
$STOCUD_LOOP
Trbegin [STO]
Raz LNBREC

For [STO]STO0 Where STOFCY=PFCY & STOCOU>WCOU & CUNLISNUM <> "" & QTYSTU <> 0
    WCOU = [F:STO]STOCOU
    Filter [CUD] Where STOFCY     =PFCY
&                    & ITMREF     =[F:STO]ITMREF
&                    & CUNLISNUM  =[F:STO]CUNLISNUM
&                    & STOCOU     =[F:STO]STOCOU

#   look [CUD]CUD1 First
    Read [CUD]CUD1 First

# si CUD n existe pas ou validé ou abandonné alors on libere le STO

    If fstat | [F:CUD]CUNLISSTA > 2
        Readlock [STO]
        If !fstat
           [F:STO]CUNLOKFLG = 1
           [F:STO]CUNLISNUM = ""
           Call ECR_TRACE ([STO]STOFCY-num$([STO]STOCOU)-[STO]ITMREF-mess(136,184,1),1) From GESECRAN
           Rewrite [STO]
           LNBREC+=1
        Endif
    Else
# si cunlokflg different on recrit le STO

        If [F:STO]CUNLOKFLG <> [F:CUD]CUNLOKFLG
           Readlock [STO]
           If !fstat
               [F:STO]CUNLOKFLG =  [F:CUD]CUNLOKFLG
               Call ECR_TRACE ([STO]STOFCY-num$([STO]STOCOU)-[STO]ITMREF-mess(136,184,1),1) From GESECRAN
               Rewrite [STO]
              LNBREC+=1
           Endif
        Endif
    Endif
    Filter [CUD]
    If LNBREC >LMAX
        Break
    Endif
Next
Commit
If LNBREC >LMAX
    Goto STOCUD_LOOP
Endif
#-------------------- Vérification article site bloqué pour inventaire ----------#
$ITFCUD_LOOP
Trbegin [ITF]
Raz LNBREC
For [ITF] Where ITMREF > WITM
&             & STOFCY = PFCY
&             & CUNFLG = 2
    WITM = [F:ITF]ITMREF
    Filter [CUD]  Where STOFCY     = PFCY              &
&                    ITMREF     = WITM              &
&                    CUNLISSTA <  3
&              Order By Key CUD1
    Look [CUD]CUD1 First
    If fstat
        Readlock [ITF]
        [ITF]CUNFLG = 1
        [ITF]CUNLISNUM = ""
        Call ECR_TRACE ([ITF]STOFCY-[ITF]ITMREF-mess(137,184,1),1) From GESECRAN

        Rewrite [ITF]
        LNBREC+=1
    Endif
    Filter [CUD]
    If LNBREC >LMAX
        Break
    Endif
Next
Commit
If LNBREC >LMAX
    Goto ITFCUD_LOOP
Endif

#-------------------- Vérification emplacement bloqué pour inventaire ----------#
$STCCUD_LOOP
Trbegin [STC]
Raz LNBREC
For [STC] Where STOFCY    = PFCY
&             & LOC       > WLOC
&             & CUNLOKFLG = 2
    WLOC = [F:STC]LOC
    Filter [CUD] Where STOFCY=PFCY
&                    & LOC   =[STC]LOC  &
&                    CUNLISSTA <  3
&              Order By Key CUD1

    Look [CUD]CUD1 First
    If fstat
        Readlock [STC]
        [STC]CUNLOKFLG = 1
        Call ECR_TRACE ([STC]STOFCY-[STC]LOC-mess(138,184,1),1) From GESECRAN

        Rewrite [STC]
        LNBREC+=1
    Endif
    Filter [CUD]
    If LNBREC >LMAX
        Break
    Endif
Next
Commit
If LNBREC >LMAX
    Goto STCCUD_LOOP
Endif



#-------------------- Vérification statut (CUNLISSTA) du fichier CUNLISTE ----------#
$STOCUL_LOOP
Trbegin [CUL]
Local Integer WACOMPTER
Local Integer WCOMPTER
Local Integer WABANDON
Local Integer WVALIDER
Local Integer WSTATUT
Local Integer WREW
Local Integer WOLD
Local Integer WOLDL
Local Integer WNBRLIG

For [CUL]CUL1 Where STOFCY = PFCY
    Raz WACOMPTER
    Raz WCOMPTER
    Raz WABANDON
    Raz WVALIDER
    Raz WSTATUT
    Raz WREW
    Raz WOLD
    Raz WOLDL
    Raz WNBRLIG

    Filter [CUD] Where CUNSSSNUM  =[F:CUL]CUNSSSNUM
&                    & CUNLISNUM  =[F:CUL]CUNLISNUM
&                    & STOFCY     =PFCY
           For [CUD]CUD0
               WNBRLIG += 1
               Case [F:CUD]CUNLISSTA
                      When 1 :
                            WACOMPTER = 2
                      When 2 :
                            WCOMPTER  = 4
                      When 3 :
                            WABANDON  = 0
                      When 4 :
                            WVALIDER  = 8
                Endcase
           Next
    Filter [CUD]

    WSTATUT = WSTATUT + WACOMPTER + WCOMPTER + WVALIDER + WABANDON

    Readlock [CUL] Curr
    If fstat
       Call FSTA("CUL") From GLOCK

    Else
       WOLD  = [F:CUL]CUNLISSTA
       WOLDL = [F:CUL]NBRLIG
       If WSTATUT = 0
          Goto NEXTTST
       Endif
       If WSTATUT = 8 &  [F:CUL]CUNLISSTA > 4
          Goto NEXTTST
       Endif
       If WSTATUT = 8 &  [F:CUL]CUNLISSTA < 5
         [F:CUL]CUNLISSTA = 5
          WREW = 1
       Endif
       If WSTATUT > 8 &  [F:CUL]CUNLISSTA <> 4
         [F:CUL]CUNLISSTA = 4
          WREW = 1
       Endif
       If WSTATUT <  8 &  [F:CUL]CUNLISSTA <> 1
         [F:CUL]CUNLISSTA = 1
         WREW = 1
       Endif
       If [F:CUL]CUNLISSTA = 6
          [F:CUL]CUNLOKFLG = 1
          WREW = 1
       Endif
$NEXTTST
       If WNBRLIG <> [F:CUL]NBRLIG
          [F:CUL]NBRLIG = WNBRLIG
          WREW = 1
       Endif
       If WREW = 1
          Rewrite  [CUL]
          If fstat
             Call FSTA("CUL") From GLOCK
          Else
             Call ECR_TRACE(mess(2523,200,1)-" "-[F:CUL]CUNSSSNUM-" "-[F:CUL]CUNLISNUM-mess(223,197,1)-
&            " : "-num$(WOLD)-" -> "-num$([F:CUL]CUNLISSTA)-" / "-num$(WOLDL)-" -> "-num$([F:CUL]NBRLIG),1) From GESECRAN
          Endif
       Endif
    Endif
$NEXTCUL
Next
Commit


#-------------------- Vérification statut (CUNLOKFLG) du fichier CUNLISTE ----------#
$STOCUL1_LOOP
Trbegin [CUL]
Local Integer WREW

For [CUL]CUL1 Where STOFCY = PFCY
    Raz WREW

    Readlock [CUL] Curr
    If fstat
       Call FSTA("CUL") From GLOCK
    Else
       If [F:CUL]CUNLISSTA = 6 & [F:CUL]CUNLOKFLG <> 1
          [F:CUL]CUNLOKFLG = 1
          WREW = 1
       Endif

       If WREW = 1
          Rewrite  [CUL]
          If fstat
             Call FSTA("CUL") From GLOCK
          Else
             Call ECR_TRACE(mess(2524,200,1)-" "-[F:CUL]CUNSSSNUM-" "-[F:CUL]CUNLISNUM-mess(223,197,1),1) From GESECRAN
          Endif
       Endif
    Endif
$NEXTCUL1
Next
Commit


#-------------------- Vérification statut (CUNSSSSTA) du fichier CUNSESSION ----------#
$STOCUN_LOOP
Trbegin [CUN]
Local Integer WPASCLOS
Local Integer WCLOS
Local Integer WSTATUT
Local Integer WREW
Local Integer WOLD

For [CUN]CUN1 Where STOFCY = PFCY
    Raz WPASCLOS
    Raz WCLOS
    Raz WSTATUT
    Raz WREW
    Raz WOLD
    Filter [CUL] Where STOFCY     =PFCY
&                    & CUNSSSNUM  =[F:CUN]CUNSSSNUM

           For [CUL]CUL1
               Case [F:CUL]CUNLISSTA
                      When 1 ,2 , 3, 4 , 5 :
                            WPASCLOS = 2
                      When 6 :
                            WCLOS    = 8
                Endcase
           Next
    Filter [CUL]

    WSTATUT = WSTATUT + WPASCLOS + WCLOS

    Readlock [CUN] Curr
    If fstat
       Call FSTA("CUN") From GLOCK

    Else
       If WSTATUT = 0 &  [F:CUN]CUNSSSSTA =  1
          Goto NEXTCUN
       Endif
       If WSTATUT = 0 &  [F:CUN]CUNSSSSTA <> 1
          WOLD = [F:CUN]CUNSSSSTA
          [F:CUN]CUNSSSSTA = 1
          WREW = 1
       Endif
       If WREW = 0
          If WSTATUT  <> 8 &  [F:CUN]CUNSSSSTA <> 2
             WOLD = [F:CUN]CUNSSSSTA
            [F:CUN]CUNSSSSTA = 2
            WREW = 1
          Endif
          If WSTATUT = 8 &  [F:CUN]CUNSSSSTA <> 3
             WOLD = [F:CUN]CUNSSSSTA
            [F:CUN]CUNSSSSTA = 3
            WREW = 1
          Endif
       Endif
       If WREW = 1
          Rewrite  [CUN]
          If fstat
             Call FSTA("CUN") From GLOCK
          Else
             Call ECR_TRACE(mess(14,721,1)-" "-[F:CUN]CUNSSSNUM-mess(223,197,1)-
&                          " : "-num$(WOLD)-" -> "-num$([F:CUN]CUNSSSSTA),1) From GESECRAN
          Endif
       Endif
    Endif
$NEXTCUN
Next
Filter [CUN]
Commit

#-------------------- Vérification presence enregistrement bidon STOJOU ----------#
Local Integer WRET
Local Char    WITMREF(GLONITM)    # hcb 121825
Local Char    WLIS
Raz WITMREF
Raz WLIS
Raz WRET
Trbegin [STJ]

If !clalev([F:STJ1])  Local File STOJOU     [STJ1] : Endif
If !clalev([F:STJ])   Local File STOJOU     [STJ]  : Endif
If !clalev([F:ITG])   Local File ITMCATEG   [ITG]  : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif


Filter [CUD] Where STOFCY    = PFCY                   &
&                  CUNLISSTA < 3
&            Order By Key CUD3
For [CUD]
  If WITMREF <> [F:CUD]ITMREF | WLIS <>  [F:CUD]CUNLISNUM
     WITMREF =  [F:CUD]ITMREF
     WLIS    =  [F:CUD]CUNLISNUM
     Read [CUL]CUL0=[F:CUD]CUNSSSNUM;[F:CUD]CUNLISNUM
     If !fstat
        Columns [STJ] (MVTSEQ)
        Filter  [STJ] Where STOFCY   = [F:CUD]STOFCY
&                         & UPDCOD   = 2
&                         & ITMREF   = [F:CUD]ITMREF
&                         & IPTDAT   = [F:CUL]IPTDAT
&                         & MVTIND   = 0
&                         & VCRTYP   = 9
&                         & VCRNUM   = [F:CUD]CUNLISNUM
&                         & VCRNUMORI= [F:CUD]CUNSSSNUM
&                         & REGFLG   = 2

        Read [STJ] STJ0 First
        Filter  [STJ]
        Columns [STJ]
        If fstat
           Raz [F:STJ]
           [F:STJ]STOFCY    = [F:CUD]STOFCY
           [F:STJ]OWNER     = [F:CUD]OWNER
           [F:STJ]UPDCOD    = 2
           [F:STJ]REGFLG    = 2
           [F:STJ]ITMREF    = [F:CUD]ITMREF
           [F:STJ]VCRTYP    = 9
           [F:STJ]VCRNUM    = [F:CUD]CUNLISNUM
           [F:STJ]VCRNUMORI = [F:CUD]CUNSSSNUM
           [F:STJ]IPTDAT    = [F:CUL]IPTDAT
           If [F:ITM]ITMREF<>[F:CUD]ITMREF
              Read [ITM]ITM0=[F:CUD]ITMREF
              If fstat
                 Raz [F:ITM]
              Endif
           Endif
#----- Création du mouvement de stock -----#
          Call ECRSTJ(0,WRET) From STKLIB
           If WRET <> 0
              GOK = 0
           Else
              Call ECR_TRACE(mess(59,123,1)-" "-[F:CUD]STOFCY-" : "-[F:CUD]CUNSSSNUM-" : "-[F:CUD]CUNLISNUM-" : "-[F:CUD]ITMREF,1) From GESECRAN
           Endif
        Endif
     Endif
  Endif
  If GOK < 1
     Break
  Endif
Next
Filter [CUD]
Commit

Call  STOZERO(PFCY)

Call TEMPOFF From GESECRAN

End


Subprog SYNBBY

Call TEMPON(mess(230,184,1)) From GESECRAN

Call ECR_TRACE(mess(230,184,1),0) From GESECRAN

#-------------------- Assemblage -#
$STOSMD_LOOP
Trbegin [SMD]
Local Integer NB_SMD_L
Local Integer NB_SMD_R
Local Integer NB_SMH_R
Raz NB_SMD_L
Raz NB_SMD_R
Raz NB_SMH_R
Local Integer I

Filter [SMD] Where VCRTYP = 31
For [SMD]
    Readlock [SMD] Curr
    If fstat
       Call FSTA("SMD") From GLOCK
       Break
    Endif
    NB_SMD_L +=1

    Raz I
    If [F:SMD]QTYPCUORI = 0 & [F:SMD]VCRTYPORI = 0
       [F:SMD]QTYPCUORI = [F:SMD]QTYPCU
       I = 1
    Endif
    If [F:SMD]QTYSTUORI = 0 & [F:SMD]VCRTYPORI = 0
       [F:SMD]QTYSTUORI = [F:SMD]QTYSTU
       I = 1
    Endif
    If I = 1
       Rewrite [SMD]
       NB_SMD_R +=1
    Endif
    If [F:SMD]VCRLIN = 1
       If ([F:SMD]VCRTYPORI = 32 & [F:SMD]QTYSTUORI = 0) | ([F:SMD]VCRTYPORI = 32 & [F:SMD]QTYPCUORI = 0)
           Readlock [SMH]SMH0=[F:SMD]VCRTYP;[F:SMD]VCRNUM
           If fstat = 1
              GLOCK = "$SMVTH"-[F:SMD]VCRNUM
              Break
           Elsif fstat
              Call RSTA ("SMH",[F:SMD]VCRNUM) From GLOCK
              Break
           Endif
           If ([F:SMD]QTYSTUORI = 0 & [F:SMD]VCRTYPORI = 32) | ([F:SMD]QTYPCUORI = 0 & [F:SMD]VCRTYPORI = 32)
              If [F:SMH]DBYFLG <> 2
                 [F:SMH]DBYFLG = 2
                 Rewrite [SMH]
                 NB_SMH_R +=1
              Endif
           Endif
       Endif
    Endif
Next

Filter [SMD]
Commit

Call TEMPOFF From GESECRAN

End

###########################################################
#Controle fichier des prix FIFO en quantité
Subprog CTLSTP( PFCY )
Value Char PFCY

Local Decimal WQTYSTP
Local Decimal WQTYSTO
Local Char    WMSG(250)

Call TEMPON(PFCY-mess(407,197,1)) From GESECRAN
Call ECR_TRACE(PFCY-mess(407,197,1),0) From GESECRAN

#   hcb 91102 deb
Local Char    WCRIT(250)

WCRIT="1=1"
If [M:STOR]ITMREFEND<>""
    If [M:STOR]ITMREFSTR<>""
        WCRIT+="&ITMREF>=[M:STOR]ITMREFSTR"
    Endif
    WCRIT+="&ITMREF<=[M:STOR]ITMREFEND"
Endif
If [M:STOR]TCLCODEND<>""
    If [M:STOR]TCLCODSTR<>""
        WCRIT+="&[F:ITM]TCLCOD>=[M:STOR]TCLCODSTR"
    Endif
    WCRIT+="&[F:ITM]TCLCOD<=[M:STOR]TCLCODEND"
Endif

Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&          As [LNK]
&          Where STOFCY        = PFCY
&              & evalue(WCRIT)
&          Order By Key ITF1

#Link [ITM] With [ITF]ITF0=[ITM]ITMREF;PFCY
#&          As [LNK]
#&          Where ITMREF >= [M:STOR]ITMREFSTR
#&              & (ITMREF <= [M:STOR]ITMREFEND | [M:STOR]ITMREFEND="")
#&              & TCLCOD >= [M:STOR]TCLCODSTR
#&              & (TCLCOD <= [M:STOR]TCLCODEND | [M:STOR]TCLCODEND="")

#   hcb 91102 fin

# hcb 96444 rajout [F:ITM]STU

Columns [LNK] (ITMREF,[F:ITM]STU)
For [LNK]
    If [F:TUN]UOM<>[F:ITM]STU               # hcb 91102
        Read [TUN]TUN0=[F:ITM]STU         # hcb 91102
        If fstat : Raz [F:TUN] : Endif
    Endif

    WQTYSTP = 0
    WQTYSTO = 0
    Columns [STO] (QTYSTUACT)

# Issue 96576 - 2014-02-06 by CCC
#    For [STO]STO3 Where ITMREF = [F:LNK]ITMREF & STOFCY = PFCY
    For [STO]STO3 Where ITMREF = [F:LNK]ITMREF
&                     & STOFCY = PFCY & find(OWNER,PFCY,"")<>0
# Issue 97591 - 2014-03-24 by CCC
#&                       |STOFCY <> PFCY & OWNER=PFCY)
      WQTYSTO += arr([F:STO]QTYSTUACT,10^-[F:TUN]UOMDEC)    # hcb 104643
    Next
    Columns [STO]
    Columns [STP] (QTYSTUACT)
    For [STP] Where ITMREF = [F:LNK]ITMREF & STOFCY = PFCY
      WQTYSTP += arr([F:STP]QTYSTUACT,10^-[F:TUN]UOMDEC)
    Next
    Columns [STP]

    # GH 28/10/2014 dm 99315, si le stock est nul, on raze la pile FIFO
    If WQTYSTP <> WQTYSTO & WQTYSTO=0
       GOK=1
       Trbegin [STP]
         Delete [STP] Where ITMREF = [F:LNK]ITMREF & STOFCY = PFCY
       If fstat=1 | fstat>5 : GOK=0 : Rollback : Else Commit : Endif
       If GOK=1
         Call ECR_TRACE(PFCY+" "+[F:LNK]ITMREF+" : "
&                      +mess(34,196,1)+" STO:"+num$(WQTYSTO)+" / STP:"+num$(WQTYSTP)
&                      -"-->"-mess(127,195,1)-"STP",1) From GESECRAN
         WQTYSTP=0
       Endif
    Endif

    If WQTYSTP <> WQTYSTO
      WMSG = PFCY+" "+[F:LNK]ITMREF+" : "+
&            mess(34,196,1)+" STO:"+num$(WQTYSTO)+" / STP:"+num$(WQTYSTP)
      Call ECR_TRACE(WMSG,1) From GESECRAN
    Endif
Next
Columns [LNK]
#
Call ECR_TRACE(mess(37,196,1),0) From GESECRAN
Call TEMPOFF From GESECRAN
End
###########################################################
#  numéros de série
Subprog SYNSER(PFCY)
Value Char PFCY

Local Integer LNBREC, LMAX
Local Char WSER(GLONSER)
Local Char WMSG(250)
LMAX = 50
Call TEMPON(PFCY-mess(408,197,1)) From GESECRAN

#--- Issue 110327
#Call ECR_TRACE(PFCY-mess(408,197,1),0) From GESECRAN
Call ECR_TRACE(PFCY-mess(484,184,1),0) From GESECRAN
#---
#
#   hcb 91102 deb
Local Char    WCRIT(250)

WCRIT="1=1"
If [M:STOR]ITMREFEND<>""
    If [M:STOR]ITMREFSTR<>""
        WCRIT+="&ITMREF>=[M:STOR]ITMREFSTR"
    Endif
    WCRIT+="&ITMREF<=[M:STOR]ITMREFEND"
Endif
If [M:STOR]TCLCODEND<>""
    If [M:STOR]TCLCODSTR<>""
        WCRIT+="&[F:ITM]TCLCOD>=[M:STOR]TCLCODSTR"
    Endif
    WCRIT+="&[F:ITM]TCLCOD<=[M:STOR]TCLCODEND"
Endif

Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&          As [LNK]
&          Where STOFCY        = PFCY
&              & evalue(WCRIT)
&              & find([F:ITM]SERMGTCOD,2,3)
&          Order By Key ITF1
#
#Link [ITM] With [ITF]ITF0=[ITM]ITMREF;PFCY
#&          As [LNK]
#&          Where ITMREF >= [M:STOR]ITMREFSTR
#&              & (ITMREF <= [M:STOR]ITMREFEND | [M:STOR]ITMREFEND="")
#&              & TCLCOD >= [M:STOR]TCLCODSTR
#&              & (TCLCOD <= [M:STOR]TCLCODEND | [M:STOR]TCLCODEND="")
#&              & find([F:ITM]SERMGTCOD,2,3)
#   hcb 91102 fin
Raz WSER
For [LNK]
    Raz WSER
    $STOLOOP
    #------ Si no série présent en stock, mais avec date sortie renseignée, suppression des infos de sortie ----#
    Raz LNBREC
    Trbegin [STS]
    For [STO] Hint Key STO5
&             Where ITMREF = [F:LNK]ITMREF
&                 & SERNUM > WSER
&                 & STOFCY = PFCY
&                 & QTYSTU > 0

        WSER= [STO]SERNUM
        Read [STS]STS0=[F:STO]ITMREF;[F:STO]SERNUM
        If !fstat
            If [F:STS]ISSDAT <> [0/0/0]
                Columns [STS] (ISSDAT,SDHNUM,SDHTYP,SDDLIN)
                Readlock [STS] Curr
                If !fstat
                    WMSG = PFCY-[F:ITM]ITMREF-[STO]SERNUM-mess(73,187,1)+"("+[STS]ISSDAT+")"-string$([F:STS]SDHNUM<>"","&"-mess(72,187,1)+"("+[STS]SDHNUM+")")
                    Call ECR_TRACE(WMSG,1) From GESECRAN
                    Raz [STS]ISSDAT,[STS]SDHNUM,[STS]SDHTYP,[STS]SDDLIN
                    Rewrite [STS]
                    LNBREC += 1
                    If LNBREC>LMAX
                        Break
                    Endif
                Endif
                Columns [STS]
            Endif
        Endif
    Next
    Commit
    If LNBREC>LMAX
        Goto $STOLOOP
    Endif
    #---- Suppression des n° de série non sortis et plus en stock -----#
    $STSLOOP
    Raz LNBREC
    Trbegin [STS]
    For [STS] Where ITMREF=[F:ITF]ITMREF
&                 & [F:STS]ISSDAT = [0/0/0]
        Look [STO]STO5=[STS]ITMREF;[STS]SERNUM
        If fstat
            Readlock [STS] Curr
            Delete [STS] Curr
            Call ECR_TRACE([F:STS]ITMREF-[F:STS]SERNUM-mess(112,184,1)-"-->"-mess(127,195,1),1) From GESECRAN
            LNBREC += 1
        Endif
        If LNBREC>LMAX
            Break
        Endif
    Next
    Commit
    If LNBREC>LMAX
        Goto $STSLOOP
    Endif
Next

#--- Issue 110327
Local Integer NBSTO, WSTOCOU, WNBSER, WNB, I
Local Decimal WQTYSTU

Call ECR_TRACE(PFCY-mess(485,184,1),0) From GESECRAN

Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&          As [LNK4]
&          Where STOFCY=PFCY & evalue(WCRIT) & [F:ITM]SERMGTCOD=4
&          Order By Key ITF1

For [LNK4]
  #---
  # No séries ayant un chrono stock
  #---
  Trbegin [STS]
  For [STS]STS3 Where ITMREF=[F:ITM]ITMREF & STOCOU<>0 & STOFCY=PFCY
    # Il y a une date de sortie
    If [F:STS]ISSDAT<>[0/0/0]
      Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
      # Le stock n'existe pas, raz du chrono stock
      If fstat
        Raz [F:STS]STOCOU
        Rewrite [STS]
        Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(465,184,1),1) From GESECRAN
        Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(479,184,1),1) From GESECRAN
      # Le stock existe
      Else
        Filter [STS1] Where ITMREF=[F:ITM]ITMREF & STOCOU=[F:STS]STOCOU & ISSDAT=[0/0/0] Order By Key STS3
        # La quantité de la ligne de stock est égale au nb de no série présents sur ce stock, raz du chrono stock
        If [F:STO]QTYSTU = nbrecord([F:STS1])
          Raz [F:STS]STOCOU
          Rewrite [STS]
          Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(466,184,1),1) From GESECRAN
          Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(479,184,1),1) From GESECRAN
        # La quantité de la ligne de stock est différente du nb de no série présents sur ce stock
        Else
          Filter [STJ] Where STOFCY=[F:STS]STOFCY & VCRTYP=[F:STS]SDHTYP & VCRNUM=[F:STS]SDHNUM & VCRLIN=[F:STS]SDDLIN & REGFLG<>2
&                      Order By Key STJ1
          Read [STJ] First
          If !fstat
            # Il existe un mvt stock pour la pièce de sortie du no série, raz du chrono stock
            Raz [F:STS]STOCOU
            Rewrite [STS]
            Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(466,184,1),1) From GESECRAN
            Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(479,184,1),1) From GESECRAN
          Else
            # Il n'existe pas de mvt stock pour la pièce de sortie du no série, raz des infos de sortie
            Raz [F:STS]ISSDAT, [F:STS]SDHTYP, [F:STS]SDHNUM, [F:STS]SDDLIN
            Rewrite [STS]
            Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(467,184,1),1) From GESECRAN
            Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(480,184,1),1) From GESECRAN
          Endif
          Filter [STJ]
        Endif
        Filter [STS1]
      Endif
    # Il n'y a pas de date de sortie
    Else
      Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
      If fstat
        # Le stock n'existe pas
        Raz [F:STS]STOCOU
        Rewrite [STS]
        Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(468,184,1),1) From GESECRAN
        Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(479,184,1),1) From GESECRAN
        Call ECR_TRACE ("    -->"-mess(478,184,1)-"="-mess(476,184,1),1) From GESECRAN
      Endif
    Endif
  Next
  Commit

  #---
  # No séries sans chrono stock
  #---
  Trbegin [STS]
  For [STS]STS3 Where ITMREF=[F:ITM]ITMREF & STOCOU=0 & STOFCY=PFCY
    # Il n'y a pas de date de sortie
    If [F:STS]ISSDAT=[0/0/0]
      Read [STO]STO5=[F:STS]ITMREF;[F:STS]SERNUM
      # Une ligne de stock de qte=1 existe avec ce no série, alimentation du chrono stock
      If !fstat & [F:STO]QTYSTU=1
        [F:STS]STOCOU = [F:STO]STOCOU
        Rewrite [STS]
        Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(469,184,1),1) From GESECRAN
        Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(481,184,1),1) From GESECRAN
      # Il n'y a pas de ligne de stock avec ce no série
      Else
        # Il n'y a pas de pièce de sortie
        If [F:STS]SDHNUM=""
          Delete [STS]
          Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(470,184,1),1) From GESECRAN
          Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(482,184,1),1) From GESECRAN
        # Il y a une pièce de sortie
        Else
           Filter [STA] Where VCRTYP=[F:STS]VCRTYP & VCRNUM=[F:STS]VCRNUM & VCRLIN=[F:STS]VCRLIN & ALLTYP=2 & SERNUM=[F:STS]SERNUM
&                       Order By Key STA1
           Read [STA] First
           # Il y a une allocation pour ce no série, alimentation du chrono stock
           If !fstat
             [F:STS]STOCOU = [F:STA]STOCOU
             Rewrite [STS]
             Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(471,184,1),1) From GESECRAN
             Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(481,184,1),1) From GESECRAN
           Else
             Delete [STS]
             Call ECR_TRACE ("***"-[F:STS]SERNUM-mess(472,184,1),1) From GESECRAN
             Call ECR_TRACE ("    -->"-mess(477,184,1)-"="-mess(482,184,1),1) From GESECRAN
           Endif
           Filter [STA]
        Endif
      Endif
    Endif
  Next
  Commit


  #---
  # Contrôle de cohérence entre le stock d'un article et son nombre de no séries
  # Les stocks en attente de rangement sont exclus car ils n'ont pas toujours des no série
  #---
  Raz WQTYSTU
  Filter [STO] Where ITMREF=[F:ITM]ITMREF & STOFCY=PFCY & LOCCAT<>2
  For [STO]
    WQTYSTU += [F:STO]QTYSTU
  Next
  Filter [STO]

  Link [STS] With  [STO]STO0=[STS]STOFCY;[STS]STOCOU  As [LNK]
  Filter [LNK] Where ITMREF=[F:ITM]ITMREF & [F:STS]ISSDAT=[0/0/0] & STOFCY=PFCY & [F:STO]LOCCAT<>2
  If rowcount([LNK])<>WQTYSTU
    #Call ECR_TRACE ("*** Affichage du stock article et du nombre de no série associés",0) From GESECRAN
    Call ECR_TRACE (mess(133,187,1)-[F:ITM]ITMREF-mess(146,184,1)-"="-num$(WQTYSTU)-mess(483,184,1)-"="-num$(rowcount([F:LNK])),1) From GESECRAN
  Endif
  Filter [LNK]

  #---
  # Contrôle de cohérence entre la quantité d'une ligne de stock et son nombre de no séries
  # Pas de contrôle pour les stocks en attente de rangement
  #---
  I=0
  NBSTO=0
  WNBSER=0
  For [STO]STO3 Where ITMREF=[F:ITM]ITMREF & STOFCY=PFCY & LOCCAT<>2
    Filter [STS] Where ITMREF=[F:ITM]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
#&                Order By [STS3]
    If rowcount([F:STS])<>[F:STO]QTYSTUACT
      If  I=0
        #Call ECR_TRACE ("*** Affichage des lignes de stock avec un nombre de no série associés incorrect",0) From GESECRAN
      Endif
      Call ECR_TRACE (mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTUACT)-mess(483,184,1)-"="-num$(rowcount([F:STS])),1) From GESECRAN
      NBSTO+=1
      If NBSTO=1
        WSTOCOU=[F:STO]STOCOU
        WNBSER=[F:STO]QTYSTUACT-rowcount([F:STS])
      Else
        Raz WSTOCOU
      Endif
    Endif
    I+=1
    Filter [STS]
  Next

  If NBSTO=1 & WSTOCOU<>0 & WNBSER>0
    Raz WNB
    Filter [STS] Where ITMREF=[F:ITM]ITMREF & STOCOU=0 & ISSDAT=[0/0/0] & STOFCY=PFCY
    Trbegin [STS]
    For [STS]STS0
      If WNB=0
        Call ECR_TRACE ("***"-mess(473,184,1),1) From GESECRAN
      Endif
      [F:STS]STOCOU=WSTOCOU
      Rewrite [STS]
      WNB+=1
      Call ECR_TRACE ("    -->"-[F:STS]STOSER-mess(477,184,1)-"="-mess(481,184,1)+num$([F:STS]STOCOU),1) From GESECRAN
      If WNB>=WNBSER Break Endif
    Next
    Commit
    Filter [STS]
  Endif

  I=0
  For [STS]STS3 Where ITMREF=[F:ITM]ITMREF & STOCOU=0 & ISSDAT=[0/0/0] & STOFCY=PFCY
    If I=0
      Call ECR_TRACE ("  ",0) From GESECRAN
      Call ECR_TRACE ("***"-mess(475,184,1),1) From GESECRAN
    Endif
    Call ECR_TRACE ("   -->"-[F:STS]SERNUM-mess(474,184,1),1) From GESECRAN
    I=+1
  Next
Next
#--- End issue 110327

Call TEMPOFF From GESECRAN
End
###########################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End


######################################################
Subprog STOZERO(PFCY)
Value Char PFCY
Local Integer LNBREC, LMAX
Local Decimal WCOU
LMAX = 500

If dim(GSTOZERO) > 0
   End
Else
   Global Integer GSTOZERO
Endif

#--- Suppression lignes de stock nulles et
#--- vérification ligne de stock bloquée pour inventaire
$STOZERO_LOOP

Trbegin [STO]
Raz LNBREC
For [STO]STO0 Where STOFCY=PFCY & STOCOU>WCOU & (QTYSTU=0 | QTYSTUACT=0)   : #--- Issue 114287 ajout QTYSTUACT=0
    WCOU = [F:STO]STOCOU
    #--- Issue 114287
    Filter [STA] Where STOCOU=[F:STO]STOCOU
    Read [STA]First
    If fstat
    #---
      # Ligne de stock nulle liée à une liste d'inventaire --> suppression ou non
      If [F:STO]CUNLISNUM<>""
         Filter [CUD] Where STOFCY     =PFCY
&                         & ITMREF     =[F:STO]ITMREF
&                         & CUNLISNUM  =[F:STO]CUNLISNUM
&                         & STOCOU     =[F:STO]STOCOU
         Read [CUD]CUD1 First
         # si CUD n existe pas ou validé ou abandonné on supprime le STO
         If fstat | [F:CUD]CUNLISSTA > 2
            Readlock [STO] Curr
            If !fstat
               Call ECR_TRACE ([STO]STOFCY-num$([STO]STOCOU)-[STO]ITMREF-mess(32,196,1),1) From GESECRAN
               Delete [STO]
               LNBREC+=1
            Endif
         Endif
         Filter [CUD]
      # Ligne de stock nulle --> suppression
      Else
         Readlock [STO] Curr
         If !fstat
            Call ECR_TRACE ([STO]STOFCY-num$([STO]STOCOU)-[STO]ITMREF-mess(32,196,1),1) From GESECRAN
            Delete [STO]
            LNBREC+=1
         Endif
      Endif
      If LNBREC >LMAX
         Break
      Endif
    #--- Issue 114287
    Endif
    Filter [STA]
    #---
Next
Commit
If LNBREC >LMAX
    Goto STOZERO_LOOP
Endif

End




###########################################################
#  Raz verrous fréquence Controle qualité
Subprog RAZFRE(PFCY)
Value Char PFCY

Local Integer LNBREC
Local Char WMSG(250)

Local Integer STAT
#Local Char    ORDSYS(250)
#Local Char    RESULT(250)(1..1000)
#Local Integer I , Y , LTET
#ORDSYS = "psadx -a -l"-GLANGUE
#Call SYSTEME2(adxmac(0),ORDSYS,"",STAT,RESULT) From ORDSYS#

#LTET  = instr(0,RESULT(2)," ")
#Local Integer WADXUID(STAT)
#Raz Y
#For I = 3 To STAT
#    If adxuid(1) <> val(left$(RESULT(I),LTET-1))
#       WADXUID(Y) = val(left$(RESULT(I),LTET-1))
#       Y +=1
#    Endif
#Next
Local Integer WADXUID(1..500)
Call UIDADX(WADXUID,STAT) From TRTX3

Call TEMPON(PFCY-mess(716,197,1)) From GESECRAN
Call ECR_TRACE(PFCY-mess(716,197,1),0) From GESECRAN

Trbegin [ITF]
For [ITF]ITF1 Where STOFCY = PFCY & QUAFLG = 4 & QUANUMUID <> 0
    Readlock [ITF] Curr
    If fstat
       Call FSTA("ITF") From GLOCK
    Else
       If !find([F:ITF]QUAADXUID,WADXUID(1..500))
          Raz [F:ITF]QUANUMUID
          Raz [F:ITF]QUAADXUID
          Rewrite  [ITF]
          If fstat
             Call FSTA("ITF") From GLOCK
          Else
             Call ECR_TRACE(mess(87,116)-" "-"ITF :"-[F:ITF]STOFCY-" "-[F:ITF]ITMREF-mess(223,197,1),1) From GESECRAN
          Endif
       Else
          Call ECR_TRACE(mess(87,116)-" "-"ITF :"-[F:ITF]STOFCY-" "-[F:ITF]ITMREF-mess(717,197,1)-num$([F:ITF]QUAADXUID),1) From GESECRAN

       Endif
    Endif
Next
Commit

Call TEMPOFF From GESECRAN

Trbegin [ITP]

For [ITP]ITP0 Where QUAFLG = 4 & QUANUMUID <> 0

    Readlock [ITP] Curr
    If fstat
       Call FSTA("ITP") From GLOCK
    Else
       If !find([F:ITP]QUAADXUID,WADXUID(1..500))
          Raz [F:ITP]QUANUMUID
          Raz [F:ITP]QUAADXUID
          Rewrite  [ITP]
          If fstat
             Call FSTA("ITP") From GLOCK
          Else
             Call ECR_TRACE(mess(87,116)-" "-"ITP :"-[F:ITP]ITMREF-" "-[F:ITP]BPSNUM-mess(223,197,1),1) From GESECRAN
          Endif
       Else
          Call ECR_TRACE(mess(87,116)-" "-"ITP :"-[F:ITP]ITMREF-" "-[F:ITP]BPSNUM-mess(717,197,1)-num$([F:ITP]QUAADXUID),1) From GESECRAN
       Endif
    Endif
Next
Commit

Call TEMPOFF From GESECRAN
End


###########################################################
#  Controle unicite lot si le parametre GEALOTLEV = 2
Subprog FEACTL

Call TEMPON(mess(755,197,1)) From GESECRAN
Call ECR_TRACE(mess(755,197,1),0) From GESECRAN
Local Char WRUPLEC(GLONITM+GLONLOT)
Local Char WRUPTST(GLONITM+GLONLOT)

For [STL]STL0
    If [F:ITM]ITMREF   <> [F:STL]ITMREF
       Read [F:ITM]ITM0=  [F:STL]ITMREF
       If fstat
          Raz [F:ITM]
       Endif
    Endif
    If [F:ITM]LOTMGTCOD=4
       WRUPLEC =  [F:STL]ITMREF+[F:STL]LOT
       If WRUPTST <> WRUPLEC
          WRUPTST = WRUPLEC
          For [STL1]STL0 Where ITMREF = [F:STL]ITMREF & LOT = [F:STL]LOT
              If [F:STL]POT       <> [F:STL1]POT       |
&                [F:STL]REFPER    <> [F:STL1]REFPER    |
&                [F:STL]SHL       <> [F:STL1]SHL       |
&                [F:STL]SHLDAT    <> [F:STL1]SHLDAT    |
&                [F:STL]SHLUOM    <> [F:STL1]SHLUOM    |
&                [F:STL]DLU       <> [F:STL1]DLU       |
&                [F:STL]DLUDAT    <> [F:STL1]DLUDAT    |
&                [F:STL]SHLLTI    <> [F:STL1]SHLLTI    |
&                [F:STL]SHLLTIUOM <> [F:STL1]SHLLTIUOM |
&                [F:STL]NEWLTIDAT <> [F:STL1]NEWLTIDAT |
&                [F:STL]USRFLD1   <> [F:STL1]USRFLD1   |
&                [F:STL]USRFLD2   <> [F:STL1]USRFLD2   |
&                [F:STL]USRFLD3   <> [F:STL1]USRFLD3   |
&                [F:STL]USRFLD4   <> [F:STL1]USRFLD4
                 Call ECR_TRACE(mess(87,116)-" "-"STOLOT :"-[F:STL]ITMREF-" "-[F:STL]LOT,1) From GESECRAN
                 Break
              Endif
          Next
       Endif
    Endif
Next
Call TEMPOFF From GESECRAN
End

#                                                                                        # hcb x3-86682 deb
###########################################################
#  Controle contenant
###########################################################
Subprog LPNCTL(PFCY)
Value Char PFCY
Local Integer LRET
Local Integer WREW
Local Char WLOT
Local Char WLOC
Local Char WPCU
Local Char WSTA
Local Char CRITERE(250)

Call TEXTFIC("STOCK","LOT",3,WLOT) From OBJDIV
Call TEXTFIC("STOCK","LOC",3,WLOC) From OBJDIV
Call TEXTFIC("STOCK","PCU",3,WPCU) From OBJDIV
Call TEXTFIC("STOCK","STA",3,WSTA) From OBJDIV
Call TEMPON(mess(896,197,1)) From GESECRAN
Call ECR_TRACE(mess(896,197,1)-"STOCK",0) From GESECRAN

# phase 1 : vérification de la table STOCK
#           premiere boucle pour verifier l absence de LPN sur emplacement de type client  ou sous-traitant
Filter [STO] Where  STOFCY   = PFCY
&                 & LPNNUM   <> ""
&                 & find (LOCCAT,3,4)
For [STO]
    # Emplacement non autorise
    Call ECR_TRACE(mess(241,184,1)-":"-[STO]STOFCY-[STO]ITMREF-WLOT-":"-[STO]LOT
&                 -WLOC-":"-[STO]LOC-WPCU-":"-[STO]PCU-WSTA-":"-[STO]STA-"("-[STO]LPNNUM-")",1) From GESECRAN
    If [F:STO]SERNUM=""
       Gosub AGREG_STO1
    Else
       Readlock [STO] Curr
       Raz [F:STO]LPNNUMM
       Rewrite [STO]
   Endif
Next
Filter [STO]

#           deuxieme boucle pour verifier l absence de LPN ligne de stock en attente de rangement et stock incomplet
#               LRET  1  : LOT/SOUS-LOT NON RENSEIGNÉ
#                     2  : no série non renseigné
#                     3  : lot/sous-lot & no série non renseignés
#                     99 : Article inexistant
Filter [STO] Where  STOFCY   = PFCY
&                 & LPNNUM   <> ""
&                 & find (LOCCAT,2)
For [STO]
    Call CTLPLFLOC([F:STO]ITMREF,"",LRET) From STKSOR
    If LRET<>0
    # ligne de stock incomplete
       Call ECR_TRACE(mess(377,199,1)-":"-num$(LRET)-[STO]STOFCY-[STO]ITMREF-WLOT-":"-[STO]LOT
&                    -WLOC-":"-[STO]LOC-WPCU-":"-[STO]PCU-WSTA-":"-[STO]STA-"("-[STO]LPNNUM-")",1) From GESECRAN
       If [F:STO]SERNUM=""
          Gosub AGREG_STO1
       Else
          Readlock [STO] Curr
          Raz [F:STO]LPNNUM
          Rewrite [STO]
      Endif
   Endif
Next
Filter [STO]

Call ECR_TRACE(mess(896,197,1)-"LPN",0) From GESECRAN

# phase 2 : vérification de la table LPN
Filter [LPN] Where  STOFCY   = PFCY
For [LPN]
    Raz WREW
    [F:LPN1] = [F:LPN]
    If [F:LPN]LOC <> ""
       Read  [STC]STC0=[F:LPN]STOFCY;[F:LPN]LOC
       If find([F:STC]LOCCAT,3,4)
          Raz [F:LPN1]LOCTYP
          Raz [F:LPN1]LOC
          WREW = 2
          # Emplacement non autorise
          Call ECR_TRACE([F:LPN]LPNNUM-mess(241,184,1),1) From GESECRAN
       Else
          If [F:LPN]LOCTYP = "" | [F:LPN]LOCTYP <> [F:STC]LOCTYP
             [F:LPN1]LOCTYP = [F:STC]LOCTYP
             # incohérence emplacement avec type emplacement --> mise à jour type emplacement
             Call ECR_TRACE([F:LPN]LPNNUM-mess(548,184,1),1) From GESECRAN
             WREW = 2
          Endif
       Endif
       #      Controle emplacement
       Filter [STO] Where LPNNUM   = [F:LPN]LPNNUM & LOC<>[F:LPN]LOC
       Read [STO]STO6 First
       If !fstat
       # du stock n'est pas dans le meme emplacement
           Call ECR_TRACE([F:LPN]LPNNUM-mess(549,184,1)-":"-[F:LPN]LOC-","-[F:STO]LOC,1) From GESECRAN
       Endif
       Filter [STO]
       If [F:LPN]WRH <> ""
             #      Controle depot
           Filter [STO] Where LPNNUM   = [F:LPN]LPNNUM & LOC = [F:LPN]LOC &  WRH <> "" & WRH <> [F:LPN]WRH
           Read [STO]STO6 First
           If !fstat
              # du stock n'est pas dans le meme depot
              Call ECR_TRACE([F:LPN]LPNNUM-mess(550,184,1)-":"-[F:LPN]WRH-","-[F:STO]WRH,1) From GESECRAN
           Endif
           Filter [STO]
       Endif

    Else
       If [F:LPN]LOCTYP <> ""
          Raz [F:LPN1]LOCTYP
          # incohérence emplacement avec type emplacement --> mise à jour type emplacement
          Call ECR_TRACE([F:LPN]LPNNUM-mess(548,184,1),1) From GESECRAN
          WREW = 2
       Endif
    Endif
    Filter [STO] Where LPNNUM   = [F:LPN]LPNNUM
    Read [STO]STO6 First
    If fstat
       If [F:LPN]LPNSTAT = 2           # En stock
          [F:LPN1]LPNSTAT = 1
          # est "en stock" alors qu'il n'est pas associé à du stock --> mise à jour du statut
          Call ECR_TRACE([F:LPN]LPNNUM-mess(547,184,1),1) From GESECRAN
          WREW = 2
       Endif
    Else
       If [F:LPN]LPNSTAT = 1           # Libre
          [F:LPN1]LPNSTAT = 2
          #  est "libre" alors qu'il est associé à du stock --> mise à jour du statut
          Call ECR_TRACE([F:LPN]LPNNUM-mess(546,184,1),1) From GESECRAN
          WREW = 2
       Endif
       #   controle mono lot et mono article
       Raz CRITERE
       If [F:LPN]MONITMFLG=2
          CRITERE+="ITMREF<>[F:STO]ITMREF"
       Endif
       If [F:LPN]MONLOTFLG=2 & [F:STO]LOT <> ""
          If CRITERE<>""
             CRITERE+="|"
          Endif
          CRITERE+="LOT<>[F:STO]LOT"
       Endif
       If CRITERE<>""
          Filter [STO1] Where LPNNUM=[F:LPN]LPNNUM  & evalue(CRITERE)
          Read [STO1]STO6 First
          If !fstat
             If [F:LPN]MONLOTFLG=2
             #  est mono-lot et contient plusieurs lots ou articles
                Call ECR_TRACE([F:LPN]LPNNUM-mess(544,184,1)-":"-[F:STO]LOT-","-[F:STO1]LOT,1) From GESECRAN
             Else
             #  est mono-article et contient plusieurs articles
                Call ECR_TRACE([F:LPN]LPNNUM-mess(545,184,1)-":"-[F:STO]ITMREF-","-[F:STO1]ITMREF,1) From GESECRAN
             Endif
          Endif
          Filter [STO1]
       Endif
    Endif
    Filter [STO]
    If WREW = 2
       Readlock [LPN] Curr
       [F:LPN] = [F:LPN1]
       Rewrite [LPN]
    Endif
Next

Filter [LPN]

Call TEMPOFF From GESECRAN
End

######################################################
# agrégation d'une ligne de stock sur une autre
$AGREG_STO1
    Filter [STO1] Where ITMREF   =[F:STO]ITMREF
&                     & STOFCY   =[F:STO]STOFCY
&                     & LOT      =[F:STO]LOT
&                     & SLO      =[F:STO]SLO
&                     & LOC      =[F:STO]LOC
&                     & STA      =[F:STO]STA
&                     & PCU      =[F:STO]PCU
&                     & PCUSTUCOE=[F:STO]PCUSTUCOE
&                     & PALNUM   =[F:STO]PALNUM
&                     & CTRNUM   =[F:STO]CTRNUM
&                     & OWNER    =[F:STO]OWNER
&                     & LPNNUM   =""
&                     & QLYCTLDEM=[F:STO]QLYCTLDEM
&                     & STOFLD1  =[F:STO]STOFLD1
&                     & STOFLD2  =[F:STO]STOFLD2
    Readlock [STO1]STO3 First
    Case fstat
        When 0 :
            [F:STO1]QTYPCU    += [F:STO]QTYPCU
            [F:STO1]QTYSTU    += [F:STO]QTYSTU
            [F:STO1]QTYSTUACT += [F:STO]QTYSTUACT
            [F:STO1]CUMALLQTY += [F:STO]CUMALLQTY
            [F:STO1]CUMALLQTA += [F:STO]CUMALLQTA
            Rewrite [STO1]
            If [F:ITM]SERMGTCOD=4
              Update [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU With STOCOU=[F:STO1]STOCOU
            Endif
            #---
           # Delete [STO] Curr
            Raz [F:STO]
        When 1 :
            Call FSTA("STO1") From GLOCK
        When Default
            Readlock [STO] Curr
            Raz [F:STO]LPNNUM                                               #
            Rewrite [STO]
       Endcase
    Filter [STO1]
Return
#                                                                                        # hcb x3-86682 deb

