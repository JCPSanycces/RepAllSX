#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################
# UTICPT91 : Removal of obsolete report files GERVATxxxxxx.rpt  #
#            Module =  Financials  (2)                          #
#            JIRA X3-32965                                      #
#################################################################
    Local Char WDOSSIER(30) : WDOSSIER = nomap

    Call SAIDOSHIS( WDOSSIER, "" ) From SAIDOSHIS
    If WDOSSIER <> ""
        If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
        If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

#        # Check Common Data Module
#        If [F:ADS]MODULE(8)<>2 : End : Endif

        Call TEMPON("O") From GESECRAN
        Call OUVRE_TRACE( "Delete GERVATxxxxxx.rpt files in reports directories." ) From LECFIC

        Call MAJ_UTICPT91(WDOSSIER)

        Call TEMPOFF     From GESECRAN
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif

    Close Local File
End

##########################################################################
Subprog MAJ_UTICPT91(DOSSIER)
Value Char DOSSIER

    Call ECR_TRACE("UTICPT91: Start of process on : " + DOSSIER, 0 ) From GESECRAN

    Call DELETE_RPT( DOSSIER, "GERVATVALACC", "BRI" )
    Call DELETE_RPT( DOSSIER, "GERVATVALJOU", "BRI" )
    Call DELETE_RPT( DOSSIER, "GERVATVALRPL", "BRI" )
    Call DELETE_RPT( DOSSIER, "GERVATVALTAX", "BRI" )

    Call DELETE_RPT( DOSSIER, "GERVATVALACC", "ENG" )
    Call DELETE_RPT( DOSSIER, "GERVATVALJOU", "ENG" )
    Call DELETE_RPT( DOSSIER, "GERVATVALRPL", "ENG" )
    Call DELETE_RPT( DOSSIER, "GERVATVALTAX", "ENG" )

    Call DELETE_RPT( DOSSIER, "GERVATVALACC", "FRA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALJOU", "FRA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALRPL", "FRA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALTAX", "FRA" )

    Call DELETE_RPT( DOSSIER, "GERVATVALACC", "GER" )
    Call DELETE_RPT( DOSSIER, "GERVATVALJOU", "GER" )
    Call DELETE_RPT( DOSSIER, "GERVATVALRPL", "GER" )
    Call DELETE_RPT( DOSSIER, "GERVATVALTAX", "GER" )

    Call DELETE_RPT( DOSSIER, "GERVATVALACC", "ITA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALJOU", "ITA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALRPL", "ITA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALTAX", "ITA" )

    Call DELETE_RPT( DOSSIER, "GERVATVALACC", "POR" )
    Call DELETE_RPT( DOSSIER, "GERVATVALJOU", "POR" )
    Call DELETE_RPT( DOSSIER, "GERVATVALRPL", "POR" )
    Call DELETE_RPT( DOSSIER, "GERVATVALTAX", "POR" )

    Call DELETE_RPT( DOSSIER, "GERVATVALACC", "SPA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALJOU", "SPA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALRPL", "SPA" )
    Call DELETE_RPT( DOSSIER, "GERVATVALTAX", "SPA" )
    Call ECR_TRACE( "UTICPT91: End of process on : " + DOSSIER, 0 ) From GESECRAN
End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT91 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#    If APPLI=GDOSX3 : End : Endif
    If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
#    If [F:ADS]MODULE(8)<>2 : End : Endif
    Call MAJ_UTICPT91(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

#    If APPLI=GDOSX3: End : Endif
#    If [F:ADS]MODULE(8)<>2 : End : Endif
    Call MAJ_UTICPT91(APPLI)
End


Subprog DELETE_RPT( FOLDERNAME, RPTNAM, LAN )
Value Char FOLDERNAME()
Value Char RPTNAM()
Value Char LAN()

    Local Char FILPAT(255)
    Local Integer STA

    FILPAT = filpath( "REPORT/" + LAN, RPTNAM, "rpt", FOLDERNAME )
#    Call ECR_TRACE( "Deleting file '" + FILPAT + "'" ,0) From GESECRAN
    STA = Delfile( FILPAT )
#    If STA
#        Call ECR_TRACE( "Cannot delete file '" + FILPAT + "'. It might not exist." , 0 ) From GESECRAN
#    Endif
End

