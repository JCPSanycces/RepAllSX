#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################
# Action ACONTACL utilisée dans le type de donnée AVV
###############################################################
Subprog CONTACL(AINSTANCE,VALINT,CODTYP,TABCONT,DEPCOD)
Variable Instance AINSTANCE Using OBJECT
Value    Char    VALINT
Value    Char    CODTYP
Value    Char    TABCONT
Value    Char    DEPCOD
If CODTYP="" | TABCONT="" : End : Endif
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
Read [ATY]CODTYP = CODTYP
If !fstat
 Case [F:ATY]TYPTYP
  When 1
   Local Integer VALPAR
   VALPAR = val(VALINT)
   Call CONTACL_LIB(AINSTANCE,TABCONT,DEPCOD,VALPAR)
  When 2,3,4,5,6
   Local Decimal VALPAR
   VALPAR = val(VALINT)
   Call CONTACL_NUM(AINSTANCE,TABCONT,DEPCOD,VALPAR)
  When 7
   Local Char VALPAR(250)
   VALPAR = VALINT
   Call CONTACL_CHAR(AINSTANCE,TABCONT,DEPCOD,VALPAR)
  When 8
   Local Date VALPAR
   VALPAR = gdat$(VALINT)
   Call CONTACL_DAT(AINSTANCE,TABCONT,DEPCOD,VALPAR)
 Endcase
Endif
End [V]CST_AOK

##################################################################
#  Contrôle d'une zone par rapport à un code contrôle            #
##################################################################
Funprog CONTACL_CHAR(AINSTANCE,CODE,DEPCOD,VALEUR)
Variable Instance AINSTANCE Using OBJECT
Value    Char    CODE
Value    Char    DEPCOD
Variable Char    VALEUR
Goto CONTACL_

Funprog CONTACL_NUM(AINSTANCE,CODE,DEPCOD,VALEUR)
Variable Instance AINSTANCE Using OBJECT
Value    Char    CODE
Value    Char    DEPCOD
Variable Decimal VALEUR
Goto CONTACL_

Funprog CONTACL_DAT(AINSTANCE,CODE,DEPCOD,VALEUR)
Variable Instance AINSTANCE Using OBJECT
Value    Char    CODE
Value    Char    DEPCOD
Variable Date    VALEUR
Goto CONTACL_

Funprog CONTACL_LIB(AINSTANCE,CODE,DEPCOD,VALEUR)
Variable Instance AINSTANCE Using OBJECT
Value    Char    CODE
Value    Char    DEPCOD
Variable Integer VALEUR
Goto CONTACL_

$CONTACL_
Local Integer OK
Local Integer ERR , NUL , OBLIG
Local Char    MESSAGE(250) , FORMULE(250) , TABLE(10)
If clalev([F:ACL])=0 : Local File ACTL [ACL] : Endif
Read [F:ACL]ACL0 = [L]CODE
## Test zone obligatoire
OK  = 1
NUL = 0
Case type(VALEUR)
 When 1,2,4,5,6,7,8,9
  If VALEUR=0 : NUL = 1 : Endif
 When 3
  If VALEUR=[0/0/0] : NUL = 1 : Endif
 When Default
  If VALEUR="" : NUL = 1  : Endif
Endcase
If NUL
 If [F:ACL]OBL<>2
  OBLIG = 0
 Elsif [F:ACL]CTLOBL=""
  OBLIG = 1
 Else
  Onerrgo ERR
  OBLIG = evalue([F:ACL]CTLOBL)
  Onerrgo
  If ERR
   OBLIG = 1
  Endif
 Endif
 If OBLIG
  MESSAGE = mess(10,123,1) : # Zone obligatoire
  Goto ERR_CTL
 Else
  End [V]CST_AOK
 Endif
Endif

## Vérif zones obligatoire et interdites et bornes
If find([F:ACL]TYPCTL,1,2,3)
 MESSAGE = [F:ACL]MSG
 Call VERIF_CTL([F:ACL]TYPCTL,[F:ACL]LSTVAL,[F:ACL]NBRVAL,[F:ACL]FRM,MESSAGE,OK,DEPCOD,[F:ACL]DEPVAL,VALEUR)
 If !OK : Goto ERR_CTL : Endif
Endif
If find([F:ACL]TYPCTL2,1,2,3)
 MESSAGE = [F:ACL]MSG2
 Call VERIF_CTL([F:ACL]TYPCTL2,[F:ACL]LSTVAL2,[F:ACL]NBRVAL2,[F:ACL]FRM2,MESSAGE,OK,DEPCOD,[F:ACL]DEPVAL2
& ,VALEUR)
 If !OK : Goto ERR_CTL : Endif
Endif
If find([F:ACL]TYPCTL3,1,2,3)
 MESSAGE = [F:ACL]MSG3
 Call VERIF_CTL([F:ACL]TYPCTL3,[F:ACL]LSTVAL3,[F:ACL]NBRVAL3,[F:ACL]FRM3,MESSAGE,OK,DEPCOD,[F:ACL]DEPVAL3
& ,VALEUR)
 If !OK : Goto ERR_CTL : Endif
Endif

## Vérifs tables liées

If [F:ACL]TYPCTL=4
 TABLE = [F:ACL]LSTVAL(0) : MESSAGE = [F:ACL]MSG : Gosub LIEN_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL2=4
 TABLE = [F:ACL]LSTVAL2(0) : MESSAGE = [F:ACL]MSG2 : Gosub LIEN_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL3=4
 TABLE = [F:ACL]LSTVAL3(0) : MESSAGE = [F:ACL]MSG3 : Gosub LIEN_CTL
 If !OK : Goto ERR_CTL : Endif
Endif

## Vérif formules

If [F:ACL]TYPCTL=5
 FORMULE = [F:ACL]FRM : MESSAGE = [F:ACL]MSG : Gosub FRM_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL2=5
 FORMULE = [F:ACL]FRM2 : MESSAGE = [F:ACL]MSG2 : Gosub FRM_CTL
 If !OK : Goto ERR_CTL : Endif
Endif
If [F:ACL]TYPCTL3=5
 FORMULE = [F:ACL]FRM3 : MESSAGE = [F:ACL]MSG3 : Gosub FRM_CTL
 If !OK : Goto ERR_CTL : Endif
Endif

End [V]CST_AOK

$ERR_CTL
Local Char MESSAGE2(250)
ERR = 0
Onerrgo ERR
MESSAGE2 = evalue(MESSAGE)
Onerrgo
If ERR
 MESSAGE2 = MESSAGE
Endif
End fmet AINSTANCE.ASETERROR("",MESSAGE2,[V]CST_AERROR)


$LIEN_CTL
If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
Read [ATB]CODFIC = TABLE
If fstat
 MESSAGE = TABLE-":"-mess(124,124,1) : # Table inexistante
 OK = 0 : Return
Endif
Call LEC_TABLE(TABLE,[F:ATB]ABRFIC,VALEUR,ERR)
If ERR
 MESSAGE = mess(162,115,1)+"\"+TABLE : # Lien incorrect
 OK = 0
Elsif fstat
 If MESSAGE=""
  MESSAGE = mess(23,100,1) : # Fiche inexistante
 Endif
 OK = 0
Endif
Return

Subprog LEC_TABLE(TABLE,ABREV,VALEUR,ERR)
Variable Integer ERR
Local Integer I , J
I = type(VALEUR)
J = func TYPKEY(TABLE)
Case J
 When 1,2,4,5,6,7,8,9
  Local Integer VALKEY
  If find(I,1,2,4,5,6,7,8,9)
   VALKEY = VALEUR
  Else
   VALKEY = val(VALEUR)
  Endif
 When 3
  Local Date VALKEY
  VALKEY = VALEUR
 When Default
  Local Char VALKEY(250)
  If find(I,1,2,4,5,6,7,8,9)
   VALKEY = num$(VALEUR)
  Else
   VALKEY = VALEUR
  Endif
Endcase
Local File =TABLE
Assign "[G:"+ABREV+"]currind" With 1
Assign "[G:"+ABREV+"]currlen" With 1
ERR = 0
Onerrgo ERR
Read [F] = VALKEY
Onerrgo
End

