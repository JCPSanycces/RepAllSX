# Classe LEASE


$METHODS
Case ACTION
 When "LOAD"         : Gosub LOAD
 When "AREAD_AFTER"  : Gosub AREAD_AFTER
Endcase
Return

$AREAD_AFTER
  Case CURPTH
      When "" : Gosub AREAD_AFTER_LEASE
  Endcase
Return


$AREAD_AFTER_LEASE
Return

$LOAD
Return

$PROPERTIES
  Case CURPRO
    When "LEACUR2"    : Gosub LEACUR2
  Endcase
Return

$LEACUR2
  Case ACTION
    When "GET"    : Gosub LEACUR2_GET
  Endcase
Return

$LEACUR2_GET
  this.LEACUR2 = this.LEA.LEACUR
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

