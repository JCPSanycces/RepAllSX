#<AdxTL>@(#)3.0.0.0 $Revision$
#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Interface Xtend
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTINT    [AYI1]
 Local File ATEXTE    [ATX1]
 Local File AYTLINES  [AYN1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTINT"  [AYI1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".AYTLINES"   [AYN1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTINT     [AYI2]
 Local File ATEXTE     [ATX2]
 Local File AYTLINES   [AYN2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTINT"  [AYI2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".AYTLINES"   [AYN2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYI1]AYI0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYI",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYI2]AYI0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYI2]INTCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYI1], [ATX1], [AYN1] , [AXX1]
&              , [AYI2], [ATX2], [AYN2] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYI2] , [ATX2], [AYN2]
 Delete [AYN2] Where FCYCOD=[L]FCYDES  & LINCODTYP=6 & LINCOD=toupper([L]ELTCOD)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLIN" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AYI2] Where FCYCOD=[L]FCYDES & INTCOD=[L]ELTCOD
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTINT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYI2","") From GLOCK : Goto AB_TR_COP
 Endif

 For [AYI1]AYI0 Where FCYCOD=[L]FCYORG & INTCOD=[L]ELTCOD
  [F:AYI2] = [F:AYI1]
  [F:AYI2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTINT","INTIT",[F:AYI1]FCYCOD,[F:AYI1]INTCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYI2]UPDUSR = GUSER
  [F:AYI2]UPDDAT = date$
  # [F:AYI2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYI2") From AYTCOP # 93575
  [F:AYI2]BRWX3  = [F:AYI2]FCYCOD+"_"+[F:AYI2]INTCOD
#*  [F:AYI2]CODACT = [L]ELTCODACT
  Write [AYI2]
  If fstat
   GOK=0 : Call FSTA("AYI2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 #
 For [AYN1]AYN0 Where FCYCOD=[L]FCYORG & LINCODTYP=6 & LINCOD=toupper([L]ELTCOD)
  [F:AYN2] = [F:AYN1]
  [F:AYN2]FCYCOD = [L]FCYDES
  Write [AYN2]
  If fstat
   GOK=0 : Call FSTA("AYN2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
