# Class POPSCALREP


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "CHKDEL" : Gosub CHKDEL
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**----------------------------------------------------------------<br/>
#* CHKDEL : Check if objects sent to PS still exist. If not delete them in PS
#**<br/>----------------------------------------------------------------<br/>
#* @param FCY    = Site
#* @param CURTAB = current table
#* @param CURKEY = current key
#* @param NBREC  = number of records that can be added (-1 = no limit) : return number of records that can still be added
#**<br/>----------------------------------------------------------------
#*!
$CHKDEL
Local File POPSOBJ    [PSOBJ]
Local File DIAHOU     [DIH]
Local File TABWEEDIA  [TWD]

Local Integer ILINE
Local Integer LPOS
Local Char LTYP(type([F:PSOBJ]TYP)-10)
Local Char LID1(type([F:PSOBJ]IDENT1)-10)
Local Char LID2(type([F:PSOBJ]IDENT2)-10)
Local Integer LTRANSOPEN : LTRANSOPEN=0

If [L]CURTAB = "" | [L]CURTAB = "POPSOBJ-CAL"

    If adxlog=0
        Trbegin [PSOBJ]
        LTRANSOPEN=1
    Endif

    If [L]CURKEY<>""
        # X3-88941 - STWIL - left$ needs the length of the string before the
        # :, so we need to subtract 1
        LPOS = instr(1, [L]CURKEY, ":")
        LTYP = left$([L]CURKEY, LPOS - 1)
        [L]CURKEY = right$([L]CURKEY,LPOS + 1)
        LPOS = instr(1, [L]CURKEY, ":")
        LID1 = left$([L]CURKEY, LPOS - 1)
        LID2 = right$([L]CURKEY,LPOS + 1)
        CURKEY=""
        CURTAB=""
    Else
        Raz LTYP, LID1, LID2
    Endif

    Filter [PSOBJ] Where [PSOBJ]FCY=[L]FCY
&                      & find([PSOBJ]TYP,"DIH","TWD")<>0

    For [PSOBJ]PSOBJ0 From [L]FCY;LTYP;LID1;LID2 To [L]FCY;"~"
        If NBREC=0  # If NBREC<0, there is no limit
            [L]CURKEY = [F:PSOBJ]TYP+":"+[F:PSOBJ]IDENT1+":"+[F:PSOBJ]IDENT2
            [L]CURTAB = "POPSOBJ-CAL"
            Break
        Endif
        LDEL=0
        Case [F:PSOBJ]TYP
            When "DIH" : # check if the time schema DIH still exists
                         # If not => create a deletion instance in the collection DAYTEMP
                         #         + delete the record in PSOBJ
                        Look [DIH]DIH0=[F:PSOBJ]IDENT1
                        If fstat
                            # The record doesn't exist anymore => deletion
                            [L]ILINE = fmet this.ADDLINE("DAYTEMP", [V]CST_ALASTPOS)
                            If [L]ILINE <> [V]CST_ANOTDEFINED
                                this.DAYTEMP([L]ILINE).NUM = [F:PSOBJ]IDENT1
                                this.DAYTEMP([L]ILINE).DELETED = 1
                                LDEL=1
                            Endif
                        Endif
            When "TWD" : # check if the weekly structure TWD still exists
                         # If not => create a deletion instance in the collection WEEKTEMP
                         #         + delete the record in PSOBJ
                        Look [TWD]TWD0=[F:PSOBJ]IDENT1
                        If fstat
                            # The record doesn't exist anymore => deletion
                            [L]ILINE = fmet this.ADDLINE("WEEKTEMP", [V]CST_ALASTPOS)
                            If [L]ILINE <> [V]CST_ANOTDEFINED
                                this.WEEKTEMP([L]ILINE).TWD = [F:PSOBJ]IDENT1
                                this.WEEKTEMP([L]ILINE).DELETED = 1
                                LDEL=1
                            Endif
                        Endif
        Endcase
        If LDEL
            Delete [PSOBJ] Curr
            If fstat
                Call FSTA("PSOBJ",this,[L]ARET_VALUE) From ASYRSUB
                Break
            Endif
            NBREC-=1
        Endif
    Next
    Filter [PSOBJ]

    If LTRANSOPEN
        If [L]ARET_VALUE=[V]CST_AOK
            Commit
        Else
            Rollback
        Endif
    Endif
Endif

Return

