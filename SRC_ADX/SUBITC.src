Subprog AP_ITMREF(VALEUR)
Variable Char     VALEUR
#Call LECTURE("ITM",VALEUR,"") From CONTOBJ
#Call FMTQTY([F:ITM]STU) From TRTDIV # rajouté 25/06/01
#[M:ITC1]FMTLIG(7) = "Nz:" + GFMTQTY
End

Subprog AS_ITMREF(VALEUR)
Variable Char     VALEUR
If GFLTITM <> ""
    If VALEUR<>GFLTITM
        VALEUR = GFLTITM
        If !func LOADITC([M:ITC0]STOFCY,VALEUR,[M:ITC0]DATREF)
            Effzo [M:ITC1]
            Effzo [M:ITC2]
            Effzo [M:ITC3]
            Effzo [M:ITC4]
        Else
            Call CHARG_ITC([M:ITC0]DATREF)
        Endif
    Endif
    mkstat = 2
    Call LECTURE("ITM",GFLTITM,"") From CONTOBJ
#    Call FMTQTY([F:ITM]STU) FROM TRTDIV
#    [M:ITC1]FMTLIG(7) = "Nz:" + GFMTQTY # rajouté 25/06/01(car AP_ pas fait)
Endif
End

Subprog AM_ITMREF(VALEUR)
Variable Char     VALEUR
# en création ou en duplication
If [F:ITM]ITMREF <> VALEUR
     Read [ITM]ITM0=VALEUR
Endif
[M:ITC0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
If [M:ITC0]STOFCY <> ""
     Read [ITF]ITF0=VALEUR;[M:ITC0]STOFCY
     # alimenter les zones reprises de ITF
     If !fstat
         [M:ITC0] = [F:ITF]
     Endif
Endif
Affzo [M:ITC0]10,15

End


