######################################################################################

##################################################################
# PABR = "ITC1" ou "ITC2"
# PTYPCST = "STD", "REV", "BDG", "SIM"
##################################################################
Subprog DET2MITC(PABR,PTYPCST)
Value Char PABR
Value Char PTYPCST

Local Integer TOTALS

Case PABR
    When "ITC1"
        Assign "[M:ITC1]"+PTYPCST+"CST(2)" With num$(sum([F:ITC]MATCST)) : # Material
        Assign "[M:ITC1]"+PTYPCST+"CST(3)" With num$(sum([F:ITC]MACCST)) : # Machine
        Assign "[M:ITC1]"+PTYPCST+"CST(4)" With num$(sum([F:ITC]LABCST)) : # Labor
        Assign "[M:ITC1]"+PTYPCST+"CST(5)" With num$(    [F:ITC]SCOTOT ) : # Subcontract
        Assign "[M:ITC1]"+PTYPCST+"CST(6)" With num$(    [F:ITC]OVEMATCST+[F:ITC]OVEMACCST+[F:ITC]OVELABCST+[F:ITC]OVESCOCST)   : # Overhead

        TOTALS = 0
        For I = 2 To 5
          TOTALS += evalue(evalue("[M:ITC1]"+PTYPCST+"CST("+num$(I)+")" ))
        Next
        Assign "[M:ITC1]"+PTYPCST+"CST(7)" With num$(TOTALS)   : # Total without overhead
        Assign "[M:ITC1]"+PTYPCST+"CST(8)" With num$(TOTALS + evalue(evalue("[M:ITC1]"+PTYPCST+"CST(6)")) )   : # Total with overhead

    When "ITC2"
        Assign "[M:ITC2]"+PTYPCST+"CST(2)" With num$(sum([F:ITC]MATLEVCST)) : # Material
        Assign "[M:ITC2]"+PTYPCST+"CST(3)" With num$(sum([F:ITC]MACLEVCST)) : # Machine
        Assign "[M:ITC2]"+PTYPCST+"CST(4)" With num$(sum([F:ITC]LABLEVCST)) : # Labor
        Assign "[M:ITC2]"+PTYPCST+"CST(5)" With num$(    [F:ITC]SCOLEVCST ) : # Subcontract
        Assign "[M:ITC2]"+PTYPCST+"CST(6)" With num$(    [F:ITC]OVEMATLEV+[F:ITC]OVEMACLEV+[F:ITC]OVELABLEV+[F:ITC]OVESCOLEV)   : # Overhead

        TOTALS = 0
        For I = 2 To 5
          TOTALS += evalue(evalue("[M:ITC2]"+PTYPCST+"CST("+num$(I)+")" ))
        Next
        Assign "[M:ITC2]"+PTYPCST+"CST(7)" With num$(TOTALS)   : # Total without overhead
        Assign "[M:ITC2]"+PTYPCST+"CST(8)" With num$(TOTALS + evalue(evalue("[M:ITC2]"+PTYPCST+"CST(6)")) )   : # Total with overhead
Endcase

End


######################################################################################
Subprog CL_CLCSTD(VALEUR)
Variable Char    VALEUR()

Local Char LTYPCST(3)(1..4)
Local Mask ITCCLC0 [DIA]

LTYPCST(1)="STD"
LTYPCST(2)="CUT"
LTYPCST(3)="BUD"
LTYPCST(4)="SIM"

If clalev([M:ICD0])>0
    [M:DIA]STOFCY    = [M:ICD0]STOFCY
    [M:DIA]ITMREF    = [M:ICD0]ITMREF
    [M:DIA]FIYNUM    = [M:ICD0]FIYNUM
    [M:DIA]ITCSTRDAT = [M:ICD0]ITCSTRDAT
    [M:DIA]ITCENDDAT = [M:ICD0]ITCENDDAT
    [M:DIA]CSTTYP    = [M:ICD0]CSTTYP
    If dim([M:DIA]ECCVALMAJ)>0
        [M:DIA]ECCVALMAJ = [M:ICD0]ECCVALMAJ
        [M:DIA]ECCVALMIN = [M:ICD0]ECCVALMIN
    Endif
Elsif clalev([M:ICA0])>0
    [M:DIA]STOFCY    = [M:ICA0]STOFCY
    [M:DIA]ITMREF    = [M:ICA0]ITMREF
    [M:DIA]ITCSTRDAT = [M:ICA0]ITCSTRDAT
    [M:DIA]ITCENDDAT = [M:ICA0]ITCENDDAT
    [M:DIA]CSTTYP    = [M:ICA0]CSTTYP
    If dim([M:DIA]ECCVALMAJ)>0
        [M:DIA]ECCVALMAJ = [M:ICA0]ECCVALMAJ
        [M:DIA]ECCVALMIN = [M:ICA0]ECCVALMIN
    Endif
Endif
[M:DIA]TOUS      = 1
[M:DIA]CSTTYPA   = LTYPCST([M:DIA]CSTTYP)
If [M:ICD1]CLCQTY<>0
    [M:DIA]CLCQTY    = [M:ICD1]CLCQTY
Else
    [M:DIA]CLCQTY    = 1
Endif
[M:DIA]ITCDAT    = date$
[M:DIA]MAJ = 3    # Mise à jour immédiate
[M:DIA]RPLPRVCST = 2
[M:DIA] = [M:ICD3]

Call CLCCST()

mkstat=4
End

################################################################
# CLCCST : Lance le calcul du coût standard à partir des paramètres dans l'écran ITC3
################################################################
# Paramètre E : écran ITCCLC0 [DIA]
################################################################
Subprog CLCCST

Gosub INIT From SUBICC
Gosub CONTROLE From SUBICC
If !mkstat
    Call OUVRE_TRACE(mess(74+[M:DIA]CSTTYP,195,1)) From LECFIC
    Gosub EXEC From SUBICC
    Call LEC_TRACE From LECFIC
Endif
Gosub UNLCK_SYM From SUBICC

End

######################################################################################

