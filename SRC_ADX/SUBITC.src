Subprog AS_STOFCY(VALEUR)
Variable Char     VALEUR
If GFLTFCY <> ""
    mkstat = 2
    If VALEUR<>GFLTFCY
        VALEUR = GFLTFCY
        If !func LOADITC(VALEUR,[M:ITC0]ITMREF,[M:ITC0]DATREF)
            Effzo [M:ITC1]
            Effzo [M:ITC2]
            Effzo [M:ITC3]
            Effzo [M:ITC4]
        Else
            Call CHARG_ITC([M:ITC0]DATREF)
        Endif
    Endif
Endif
End

