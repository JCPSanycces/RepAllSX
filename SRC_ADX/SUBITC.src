#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion des coûts standard - standard actualisé - budget - simulé
# ------------------------------------------------------------------------------------------#
# Colonne 1 (coût standard) Table principale de l'objet    Zone STDCST
# Colonne 2 (coût actualisé)                               Zone ACTCST
# Colonne 3 (coût budget)                                  Zone BUDCST
# Colonne 4 (coût simulé)                                  Zone SIMCST

$ACTION
Case ACTION
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "DEBUT"       : Gosub DEBUT
 When "OUVRE"       : Gosub OUVRE
 When "APRES_MODIF" : Gosub APRES_MODIF

 When "TIR"         : Gosub TIR
 When "GAU"         : Gosub GAU
 When "RAF"         : Gosub RAF

 When "FIN"         : Gosub FIN

 When "FILGAUCHE"   : Gosub FILGAUCHE#X3-53745.n
 When "CLE_GAUCHE"  : Gosub CLE_GAUCHE
Endcase

Return

$CLE_GAUCHE
INDLIS = 1
SNSLIS = 1
LENLIS = 1
CLELISTE = "ITMREF;STOFCY"
Return

#X3-53745.n Used to filter left list while paging left/right
$FILGAUCHE
#  Gosub FILTER_CRIT
  FILGAUSUP(0) = LCRIT0
Return


Subprog CHARG_ITC(PDATREF)
Variable Date PDATREF
    Raz [M:ITC0],[M:ITC1],[M:ITC2],[M:ITC3]
    [M:ITC0]=[F:ITC]
    [M:ITC1]=[F:ITC]
    [M:ITC2]=[F:ITC]
    [M:ITC3]=[F:ITC]
    Call LECTURE(PDATREF)
    Affzo [M:ITC0]
    Affzo [M:ITC1]
    Affzo [M:ITC2]
    Affzo [M:ITC3]

End

$SETBOUT

If GCONSULT
    Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$AVANTBOUT
# positionner les var globales que si on vient du menu Couts standard
If BOUT = "1" & GFONC1 = "FUNITC"
   GFLTITM = [M:ITC0]ITMREF  # pour historique
   GFLTFCY = [M:ITC0]STOFCY
Endif
Return

$EXEBOUT
Case BOUT
  When "1"
      If GFONC1 = "GESITC"
        GFLTITM = ""
        GFLTFCY = ""
      Endif
Endcase
Return

$OUVRE
Local Integer I, IMAT, CREE_OK
Local Integer ICN_UPD  # mise à jour détail nature après modif FG Bug 20372 (04/12/03)

Local Char    LTYP(3)
Local Integer WRETOUR

Local Date    LDATREF
Local Integer LFIND

If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU]  : Endif
If clalev([F:OVE])=0 : Local File OVERHEAD   [OVE]  : Endif
If clalev([F:ITG])=0 : Local File ITMCATEG   [ITG]  : Endif
If clalev([F:ONA])=0 : Local File OVENAT     [ONA]  : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY    [AFF]  : Endif
If !clalev([F:ITC])  : Local File ITMCOST    [ITC]  : Endif
If !clalev([F:ITC2]) : Local File ITMCOST    [ITC2] : Endif
If !clalev([F:ITCW]) : Local File ITFITC     [ITCW] : Endif

Local Integer SAV_GCONS
SAV_GCONS = GCONSULT
GCONSULT=1

#X3-38195.sn MJH  25-OCT-2017
Local Char SAV_GFONCTION(len(GFONCTION))
SAV_GFONCTION = GFONCTION
GFONCTION = "FUNITC" : Call AUTORIS From EXEFNC


Local Char LCRIT(250), LCRIT0(250)

# Liste gauche
#Local Integer LNBITF
#If !clalev([F:ITC]) : Local File ITMCOST    [ITC] : Endif
#If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif

LCRIT  = "1=1"
LCRIT0 = "1=1"

Gosub FILTER_CRIT#X3-53745.n
Filter [ITCW] Where evalue(LCRIT0)

#X3-53745.so
#Raz GBIDI1

#If GFLTITM<>""
#    Call ADDCRIT(LCRIT,GBIDI1,"","[ITC]ITMREF=GFLTITM","&") From GOBJSUB
#    LCRIT_0 += " and ITMCOST.ITMREF_0='"+GFLTITM+"'"
#Endif
#If GFLTFCY<>""
#    Call ADDCRIT(LCRIT,GBIDI1,"","[ITC]STOFCY=GFLTFCY","&") From GOBJSUB
#    LCRIT_0 += " and ITMCOST.STOFCY_0='"+GFLTFCY+"'"
#Endif#X3-53745.eo

Return

$DEBUT
Global Char BOXITF(10)
BOXITF = "GAU_CHE"+num$(find("ICC",OBJLIS(1..dim(OBJLIS)-1)))

# Lecture du 1er
[M:ITC0]DATREF = date$

# Issue 78276 - 2012-02-10 by CCC : Si le filtre n'est pas positionné, il n'y a pas d'intérêt à charger le 1er coût venu
If LCRIT<>"1=1"
    Raz [F:ITC] ##X3-53745.n MJH
    Filter [ITC] Where ITCSTRDAT<=[M:ITC0]DATREF & [M:ITC0]DATREF<=ITCENDDAT & evalue(LCRIT) Order By ITMREF;STOFCY
    Read [ITC] First
    Filter [ITC]
    If fstat
        If GFLTITM<>"" | GFLTFCY<>""
            Filter [ITC] Where evalue(LCRIT) Order By ITMREF;STOFCY
            Read [ITC] First
            Filter [ITC]
            [F:ITC]ITMREF=GFLTITM
            [F:ITC]STOFCY=GFLTFCY
        Else
            Read [ITC] First
        Endif
    Endif
Endif
LDATREF=[M:ITC0]DATREF    # Utilisée dans LECTURE pour conserver la date saisie
Call CHARG_ITC(LDATREF)

# Remplissage de la liste gauche
Gosub REMPLIT


Return

#X3-38195.sn MJH  25-OCT-2017
$FILTER_CRIT
  #Filter left list to focus product/site when needed
  If GFLTITM <> ""
    LCRIT   -= " and [ITC]ITMREF = GFLTITM "
    LCRIT0  -= " and [ITCW]ITMREF = GFLTITM "
  Endif
  If GFLTFCY <> ""
    LCRIT   -= "and [ITC]STOFCY =  GFLTFCY "
    LCRIT0  -= "and [ITCW]STOFCY =  GFLTFCY "

    If GNBAUZ<>GNBSITE and !find(GFLTFCY,GUSRFCY(1..GNBAUZ)) and  GUSRFCY(1) <> "/"
      LCRIT   -= " and 1=2"
      LCRIT0  -= " and 1=2"
    Endif
    Raz fstat
  Endif #X3-38195.en

  #X3-53745.sn MJH  25-OCT-2017 Filter left list to restrict based on functional authorization
  If GUSRFCY(1) <> ""  and GUSRFCY(1) <> "/" and GNBAUZ<>GNBSITE
    LCRIT   -=" and find([ITC]STOFCY,GUSRFCY(1..GNBAUZ))"
    LCRIT0  -=" and find([ITCW]STOFCY,GUSRFCY(1..GNBAUZ))"
  Endif

Return

#--------------------------------------------------------#
$TIR
If currbox<>BOXCURR
 Gosub REMPLIT
Endif
Return

#--------------------------------------------------------#
$RAF
Gosub REMPLIT
Call LECTURE(LDATREF)
Affzo
FOK = 0
Return

#--------------------------------------------------------#
$GAU
LFIND = 0
[M:ITC0]STOFCY=[F:ITCW]STOFCY
[M:ITC0]ITMREF=[F:ITCW]ITMREF
LDATREF=[M:ITC0]DATREF    # Utilisée dans LECTURE pour conserver la date saisie
If !func LOADITC([M:ITC0]STOFCY,[M:ITC0]ITMREF,[M:ITC0]DATREF)
    Filter [ITC] Where STOFCY = [M:ITC0]STOFCY
&                    & ITMREF = [M:ITC0]ITMREF
&                    & UID=0
    Read [ITC]ITC0 First
    Filter [ITC]
    If !fstat : LFIND=1 : Endif
Else
    LFIND=1
Endif

If LFIND
    Call CHARG_ITC(LDATREF)
Endif
Return

#----------------------------#
$REMPLIT
  Case currbox
    When "GAU_CHE1" : Fillbox [ITC1] GAU_CHE1
  Endcase
Return


#--------------------------------------------------------#
$FIN
If dim(BOXITF)>0
 Kill BOXITF
Endif

GCONSULT=SAV_GCONS

#X3-38195.sn MJH  26-OCT-2017
GFONCTION = SAV_GFONCTION : Call AUTORIS From EXEFNC

Return

#--------------------------------------------------------#
Subprog LECTURE(PDATREF)
Variable Date PDATREF

Local Decimal LPRI
Local Integer LRET

# Affectation de la date de référence
If [M:ITC0]DATREF=[0/0/0] & PDATREF=[0/0/0]
    If [F:ITC]ITCSTRDAT<>[0/0/0]
        [M:ITC0]DATREF = [F:ITC]ITCSTRDAT
    Elsif [F:ITC]ITCENDDAT>date$
        [M:ITC0]DATREF = date$
    Else
        [M:ITC0]DATREF = [F:ITC]ITCENDDAT
    Endif
    PDATREF=[M:ITC0]DATREF
Else
    If PDATREF<[F:ITC]ITCSTRDAT
        [M:ITC0]DATREF=[F:ITC]ITCSTRDAT
    Elsif PDATREF>[F:ITC]ITCENDDAT
        [M:ITC0]DATREF=[F:ITC]ITCENDDAT
    Else
        [M:ITC0]DATREF=PDATREF
    Endif
Endif

Read [ITM]ITM0 = [F:ITC]ITMREF
[M:ITC0]=[F:ITM]

Read [ITF]ITF0 = [F:ITC]ITMREF;[F:ITC]STOFCY
If !fstat
    # alimenter codes màj coûts
    [M:ITC0] = [F:ITF]
Endif
# Affectation du Format des numériques selon ligne : 7 montants puis qté
Call GETDEV([M:ITC0]STOFCY) From DEVSUB  # charge GLOCALDEV
#For nolign =1 To 7
#    [M:ITC1]FMTLIG(nolign-1) = "N3z:11."+num$(GDECPRI) # Utilisation de GDECPRI
#Next
#Call FMTQTY([F:ITM]STU) From TRTDIV
#[M:ITC1]FMTLIG(7) = "Nz:" + GFMTQTY

[F:ITC2] = [F:ITC]    # sauvegarde de la clé
#Dbgaff
For LTYP="STD","ACT","BUD","SIM"
    Raz [F:ITC]
    Call GETPRISTD([M:ITC0]ITMREF,"","",[M:ITC0]STOFCY,[M:ITC0]DATREF,0,find(LTYP,"STD","ACT","BUD","SIM"),LPRI,LRET) From STKVAL
#    Filter [ITC] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF
#&                    & CSTTYP=find(LTYP,"STD","ACT","BUD","SIM")
#&                    & ITCSTRDAT<=[M:ITC0]DATREF & [M:ITC0]DATREF<=ITCENDDAT
#&                    & UID = 0
#&                Order By Key XITC=ITMREF;STOFCY;CSTTYP;ITCSEQ Desc;UID
#    Read [ITC]XITC First
#    Filter [ITC]
    If !LRET & [F:ITC]ITMREF<>"" & [F:ITC]ITCSTRDAT<=[M:ITC0]DATREF & [M:ITC0]DATREF<=[F:ITC]ITCENDDAT

        #X3-101193 MJH. 8/9/2018
        [M:ITC1]NBLIG = 10
        [M:ITC1]LINE(0)     = mess(1,138,1)
        [M:ITC1]LINE(1)     = mess(3,138,1)
        For I=2 To 10
          [M:ITC1]LINE(I)     = mess(54+I,197,1)
        Next
        Local Char DATEFORMAT(20)
        DATEFORMAT = GFMDAT

        Assign "[M:ITC1]"+LTYP+"CST(0)"    With format$("D:"+DATEFORMAT,[F:ITC]ITCSTRDAT)
        Assign "[M:ITC1]"+LTYP+"CST(1)"    With format$("D:"+DATEFORMAT,[F:ITC]ITCENDDAT)
        Assign "[M:ITC1]"+LTYP+"SEQ"       With [F:ITC]ITCSEQ
        Call DET2MITC("ITC1",LTYP)
        Assign "[M:ITC1]"+LTYP+"CST(9)"   With num$([F:ITC]CLCQTY)

        [M:ITC2]NBLIG = 10
        [M:ITC2]LINE(0)     = mess(1,138,1)
        [M:ITC2]LINE(1)     = mess(3,138,1)
        For I=2 To 10
          [M:ITC2]LINE(I)     = mess(54+I,197,1)
        Next

        Assign "[M:ITC2]"+LTYP+"CST(0)"    With format$("D:"+DATEFORMAT,[F:ITC]ITCSTRDAT)
        Assign "[M:ITC2]"+LTYP+"CST(1)"    With format$("D:"+DATEFORMAT,[F:ITC]ITCENDDAT)
        Call DET2MITC("ITC2",LTYP)
        Assign "[M:ITC2]"+LTYP+"CST(9)"   With num$([F:ITC]CLCQTY)

        [M:ITC3]NBLIG  = 8
        Call TEXTE(1881,  [M:ITC3]LINE(0)) From OBJDIV #Date Calculated
        Call TEXTE(1528,  [M:ITC3]LINE(1)) From OBJDIV #Routing code
        Call TEXTE(5166,  [M:ITC3]LINE(2)) From OBJDIV #BOM code
        Call TEXTE(1892,  [M:ITC3]LINE(3)) From OBJDIV #Material cost
        Call TEXTE(54133, [M:ITC3]LINE(4)) From OBJDIV #Dimension rate
        Call TEXTE(8409,  [M:ITC3]LINE(5)) From OBJDIV #Fixed costs distribution
        Call TEXTE(54134, [M:ITC3]LINE(6)) From OBJDIV #Overhead column
        Call TEXTE(15111, [M:ITC3]LINE(7)) From OBJDIV #Multilevel

        Assign "[M:ITC3]"+LTYP+"CST(0)" With format$("D:"+DATEFORMAT,[F:ITC]ITCDAT)
        Assign "[M:ITC3]"+LTYP+"CST(1)" With num$([F:ITC]ROUALT)
        Assign "[M:ITC3]"+LTYP+"CST(2)" With num$([F:ITC]BOMALT)
        Assign "[M:ITC3]"+LTYP+"CST(3)" With mess([F:ITC]SLTMATCST,328 ,1)
        Assign "[M:ITC3]"+LTYP+"CST(4)" With mess([F:ITC]VLTCCERAT,324 ,1)
        Assign "[M:ITC3]"+LTYP+"CST(5)" With mess([F:ITC]FXDCSTDSP,323 ,1)
        Assign "[M:ITC3]"+LTYP+"CST(6)" With mess([F:ITC]SLTOVECOL,320 ,1)
        Assign "[M:ITC3]"+LTYP+"CST(7)" With mess([F:ITC]DESCEND,1 ,1)

    Endif
Next

Read [ITC]ITC0=[F:ITC2]STOFCY;[F:ITC2]ITMREF;[F:ITC2]CSTTYP;[F:ITC2]ITCSEQ;[F:ITC2]UID

Gosub CHARG_GRAPH From SUBITCG
Affzo [M:ITC4]

End

#######################################################
$APRES_MODIF
# colonne modifiée et flag EXI=0 <=> création : xxx_UPD = 2
# flag pour std inutile car si l'on passe dans cette étiquette, c'est que l'on est
# en mode Modif, et donc que l'enreg cout std existe déjà
  ## >> en modif art ou site pour duplic : recharger les infos issues de ITM et ITF ??
# en création de coût on alimente la date

Case COUZON
    When "STOFCY"
        If !func LOADITC(CZ,[M:ITC0]ITMREF,[M:ITC0]DATREF)
            Effzo [M:ITC1]
            Effzo [M:ITC2]
            Effzo [M:ITC3]
            Effzo [M:ITC4]
        Else
            Call CHARG_ITC(LDATREF)
        Endif
    When "ITMREF"
        If !func LOADITC([M:ITC0]STOFCY,CZ,[M:ITC0]DATREF)
            Effzo [M:ITC1]
            Effzo [M:ITC2]
            Effzo [M:ITC3]
            Effzo [M:ITC4]
        Else
            Call CHARG_ITC(LDATREF)
        Endif
    When "DATREF"
        LDATREF=CZ
        If func LOADITC([M:ITC0]STOFCY,[M:ITC0]ITMREF,CZ)
            [M:ITC0]ITCSEQ = [F:ITC]ITCSEQ
            COUZON = "ITCSEQ"
            CZ = num$([M:ITC0]ITCSEQ)
            [M:ITC0]DATREF = LDATREF
            Affzo [M:ITC0]DATREF
            Call CHARG_ITC(LDATREF)
        Else
            GERR=1
            GMESSAGE = mess(88,187,1)
        Endif
Endcase
Return

##############################################
Funprog LOADITC(PFCY, PITM, PDAT)
Value Char PFCY
Value Char PITM
Value Date PDAT

Local Integer LOK
Local Integer LCSTTYP

LOK = 0
If PFCY<>"" & PITM<>"" & PDAT<>[0/0/0]
    For LCSTTYP=1 To 4
        Filter [ITC] Where STOFCY= PFCY
&                        & ITMREF= PITM
&                        & CSTTYP= LCSTTYP
&                        & UID   = 0
&                        & ITCSTRDAT<=PDAT & PDAT<=ITCENDDAT
        For [ITC]
            [M:ITC0]ITCSEQ = [F:ITC]ITCSEQ
            LOK = 1
            Break 2
        Next
    Next
    Filter [ITC]
Endif
End LOK


