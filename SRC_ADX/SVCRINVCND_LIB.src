#<AdxTL>@(#)0.0.0.0 $Revision$
#--Testing code
Local Integer WRET
Local Char    SAV_GTRACE(250)

SAV_GTRACE=GTRACE : Raz GTRACE

WRET = func SVCRINVCND_LIB_TEST.TEST_GET_PERFROM_PERTO()

WRET = func SVCRINVCND_LIB_TEST.TEST_SVCRINVCND()

If GTRACE<>""
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

GTRACE=SAV_GTRACE
End
#--------------------------------------
#--PSTARTDATE has to be filled with the date to start from
#**
#* Funprog CALDATE is used calculate a starting date according to the invoice conditionning properties
#* It returns [V]CST_AERROR or [V]CST_AOK
#* @param CTX           a pointer to the caller's context (if null then GACTX is used)
#* @param IN_PSTARTDATE a starting date if any
#* @param IN_INVCND     Invoice conditionning code
#* @param IN_LEG        Invoice conditionning legislation part of the key
#* @param IN_INVCNDLIN  Invoice conditionning line number
#* @param IN_SALFCY     Facility
#* @param IN_FCY_UVYCOD Facility's unavailable code if any
#* @param OUT_DAT       The calculated date
#* @param OUT_MESSAGE   Error/Info message if any
#*!
Funprog CALDATE(CTX,IN_PSTARTDATE,IN_INVCND,IN_LEG,IN_INVCNDLIN,IN_SALFCY,IN_FCY_UVYCOD,OUT_DAT,OUT_MESSAGE)
Value Instance CTX Using C_WMACONTEXT
Value Date     IN_PSTARTDATE
Value Char     IN_INVCND
Value Char     IN_LEG
Value Integer  IN_INVCNDLIN
Value Char     IN_SALFCY()
Value Char     IN_FCY_UVYCOD
Variable Date  OUT_DAT
Variable Char  OUT_MESSAGE

Local Integer WRET
WRET=[V]CST_AOK

OUT_MESSAGE = AVOID.ACHAR

#--Check input values
If IN_INVCND=AVOID.ACHAR
  WRET=[V]CST_AERROR
  OUT_MESSAGE = mess(456,192,1)
  End WRET
Endif
If IN_PSTARTDATE= [0/0/0] : IN_PSTARTDATE = date$ : Endif
If OUT_DAT      = [0/0/0] : OUT_DAT=IN_PSTARTDATE : Endif
If CTX=null : CTX=GACTX : Endif
#--

Local Integer JSEM(1..7) , JFER
Local Integer QT , I , QUANT
Local Date    DAT1
Local Integer STAT, DATMOD      :# indicateur modif de date calculée
Local Integer MOIS
Local Integer NBDAYFEB, DYEAR

Local File TABINVCND    [INVCND]
Local File TABINVCNDLIN [INVCNDD]
Local File TABUNAVAIL   [TUV]

  If IN_FCY_UVYCOD<>""
    Read [TUV]UVY0 = IN_FCY_UVYCOD
    If fstat : Raz [F:TUV] : Endif
  Else
    Raz [F:TUV]
  Endif

  Read [F:INVCND]INVCND0=IN_INVCND;IN_LEG
  If fstat
    Raz [F:INVCND]
  Endif
  Read [F:INVCNDD]INVCNDD0=IN_INVCND;IN_LEG;IN_INVCNDLIN
  If fstat
    Raz [F:INVCNDD]
  Endif

  For I=1 To 7
    JSEM(I)=[F:INVCND]INVFBDDAYFLG(I-1)
  Next
  JFER=[F:INVCND]INVFBDHLYFLG

  Gosub _CALDATE

End WRET
#--------------------------------------------------------------------------------------------------
$_CALDATE

  #--Fin de mois avant
  If [F:INVCNDD]INVMONTHEND=3 : OUT_DAT=eomonth(OUT_DAT) : Endif

  #--Ajout des mois et des jours
  If [F:INVCND]INVCNDTYP<>3
    OUT_DAT=addmonth(OUT_DAT,[F:INVCNDD]INVNBMONTHS)+[F:INVCNDD]INVNBDAYS
  Else
    #--According to [F:INVCND]INVDAY
    If    [F:INVCND]INVDAY<>0
      If    [F:INVCND]INVMETH=1
        If [F:INVCND]INVDAY<=day(OUT_DAT)
          OUT_DAT=gdat$(min([F:INVCND]INVDAY,day(eomonth(OUT_DAT)),day(OUT_DAT)),month(OUT_DAT),year(OUT_DAT))
        Else
          #--[F:INVCND]INVDAY>day(OUT_DAT)
          If     month(OUT_DAT)=1
            OUT_DAT=gdat$([F:INVCND]INVDAY,12,year(OUT_DAT)-1)
          Else
            If [F:INVCND]INVDAY=31
              #--This means : end of month
              #--In this case : end of previous month
              If day(OUT_DAT)=day(eomonth(OUT_DAT)) #and month(OUT_DAT)<>2
                # We are at the end of the month => nothing to do
              Else
                OUT_DAT=gdat$(day(eomonth(gdat$(28,month(OUT_DAT)-1,year(OUT_DAT)))),month(OUT_DAT)-1,year(OUT_DAT))
              Endif
            Else
              OUT_DAT=gdat$(min([F:INVCND]INVDAY,day(eomonth(gdat$(28,month(OUT_DAT)-1,year(OUT_DAT))))),month(OUT_DAT)-1,year(OUT_DAT))
            Endif
          Endif
        Endif
      Elsif [F:INVCND]INVMETH=2
        If [F:INVCND]INVDAY>=day(OUT_DAT)
          OUT_DAT=gdat$(min([F:INVCND]INVDAY,day(eomonth(OUT_DAT))),month(OUT_DAT),year(OUT_DAT))
        Else
          #--[F:INVCND]INVDAY<day(OUT_DAT)
          If month(OUT_DAT)=12
            OUT_DAT=gdat$([F:INVCND]INVDAY,1,year(OUT_DAT)+1)
          Else
            OUT_DAT=gdat$(min([F:INVCND]INVDAY,day(eomonth(gdat$(28,month(OUT_DAT)+1,year(OUT_DAT))))),month(OUT_DAT)+1,year(OUT_DAT))
          Endif
        Endif
      Endif
    Endif
  Endif

  #--Fin de mois après
  If [F:INVCNDD]INVMONTHEND=2 : OUT_DAT=eomonth(OUT_DAT) : Endif

  #--Quantièmes
  QUANT = day(OUT_DAT)
  #--Si mois de février et jour de paiement > 29, on passe au jour de paiement suivant
  MOIS  = month(OUT_DAT)
  #--
  DYEAR = year(OUT_DAT)

  #--Si année bissextile, mois de février a 29 jours
   If ((int(DYEAR/4)=DYEAR/4) and (int(DYEAR/100)<>DYEAR/100))
&   or (int(DYEAR/400)=DYEAR/400) Then
      WNBDAYFEB = 29
   Else
     WNBDAYFEB = 28
   Endif
  If [F:INVCNDD]INVDAYMON(0)<>0
    If MOIS <> 2
      If      QUANT<=[F:INVCNDD]INVDAYMON(0) QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
        Elsif QUANT<=[F:INVCNDD]INVDAYMON(1) QT=[F:INVCNDD]INVDAYMON(1) : Gosub _QUANTIEME
        Elsif QUANT<=[F:INVCNDD]INVDAYMON(2) QT=[F:INVCNDD]INVDAYMON(2) : Gosub _QUANTIEME
        Elsif QUANT<=[F:INVCNDD]INVDAYMON(3) QT=[F:INVCNDD]INVDAYMON(3) : Gosub _QUANTIEME
        Elsif QUANT<=[F:INVCNDD]INVDAYMON(4) QT=[F:INVCNDD]INVDAYMON(4) : Gosub _QUANTIEME
        Elsif QUANT<=[F:INVCNDD]INVDAYMON(5) QT=[F:INVCNDD]INVDAYMON(5) : Gosub _QUANTIEME
        Else                                 QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
      Endif
    Else
      If    (QUANT<=[F:INVCNDD]INVDAYMON(0) & [F:INVCNDD]INVDAYMON(0)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(0)=99)
         QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
      Elsif (QUANT<=[F:INVCNDD]INVDAYMON(1) & [F:INVCNDD]INVDAYMON(1)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(1)=99)
         QT=[F:INVCNDD]INVDAYMON(1) : Gosub _QUANTIEME
      Elsif (QUANT<=[F:INVCNDD]INVDAYMON(2) & [F:INVCNDD]INVDAYMON(2)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(2)=99)
         QT=[F:INVCNDD]INVDAYMON(2) : Gosub _QUANTIEME
      Elsif (QUANT<=[F:INVCNDD]INVDAYMON(3) & [F:INVCNDD]INVDAYMON(3)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(3)=99)
         QT=[F:INVCNDD]INVDAYMON(3) : Gosub _QUANTIEME
      Elsif (QUANT<=[F:INVCNDD]INVDAYMON(4) & [F:INVCNDD]INVDAYMON(4)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(4)=99)
         QT=[F:INVCNDD]INVDAYMON(4) : Gosub _QUANTIEME
      Elsif (QUANT<=[F:INVCNDD]INVDAYMON(5) & [F:INVCNDD]INVDAYMON(5)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(5)=99)
         QT=[F:INVCNDD]INVDAYMON(5) : Gosub _QUANTIEME
      Else
         QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
      Endif
    Endif
  Endif

  #--04/07/12 Payment days in customer function SAM #82280
  Gosub _UNAVAILABLE

  #--Traitement des jours interdits
  While JSEM(dayn(OUT_DAT))=2
   OUT_DAT += 1
  Wend

  $_FERIES
  If JFER = 2 :#--exclusion des jours fériés

   #--controle sur les 24 périodes d'indisponibilité
   DATMOD = 0
   If IN_FCY_UVYCOD <> ""
    If [F:TUV]UVYCOD<>IN_FCY_UVYCOD
      Read [TUV]UVY0 = IN_FCY_UVYCOD
      If fstat : Raz [TUV] : Endif
    Endif
    For I=0 To [F:TUV]UVYNBR-1
      If OUT_DAT >= [F:TUV]UVYSTRDAT(I) & OUT_DAT <= [F:TUV]UVYENDDAT(I)
          OUT_DAT = [F:TUV]UVYENDDAT(I) + 1
          DATMOD = 1
      Endif
    Next I
   Endif
   If DATMOD = 1
      DATMOD = 0  : #--retester les jours interdits !
      While JSEM(dayn(OUT_DAT))=2
          OUT_DAT += 1 : DATMOD = 1
      Wend
      If DATMOD = 1 Goto _FERIES Endif
   Endif
  Endif

  Gosub _INI_CAL

Return
#--------------------------------------
$_QUANTIEME
  #--Le quantième 99 correspond à la fin de mois
  If QT=99
   OUT_DAT = eomonth(OUT_DAT)
  Elsif day(OUT_DAT)<=QT
    #--si on veut le 29,30 ou 31 et qu'on est en février, on rajoute 1 mois
    If QT>28 & month(OUT_DAT)=2
      OUT_DAT=gdat$(QT,month(OUT_DAT)+1,year(OUT_DAT))
    Else
      OUT_DAT=gdat$(QT,month(OUT_DAT),year(OUT_DAT))
    Endif
  Else
    #--si on veut le 29,30 ou 31 et qu'on est en janvier, on rajoute 2 mois
    If QT>28 & month(OUT_DAT)=1
      OUT_DAT=gdat$(QT,month(OUT_DAT)+2,year(OUT_DAT))
    Else
      OUT_DAT=gdat$(QT,month(OUT_DAT)+1,year(OUT_DAT))
    Endif
  Endif
Return
#--------------------------------------
$_UNAVAILABLE
Local Integer WPARAM_VALUE
Local Date    DAT1

  If IN_FCY_UVYCOD<>""
   $_INI_CAL
     DATMOD = 0
     DAT1=OUT_DAT
     If IN_FCY_UVYCOD<>""
       If [F:TUV]UVYCOD<>IN_FCY_UVYCOD
         Read [TUV]UVY0 = IN_FCY_UVYCOD
         If fstat : Raz [F:TUV] : Endif
       Endif
     Endif
     If !fstat and [F:TUV]UVYPER=2  #--The _UNAVAILABLE periods are periodic (for all the years)
       For I=0 To [F:TUV]UVYNBR-1
         If year([F:TUV]UVYSTRDAT(I))=year([F:TUV]UVYENDDAT(I))
           If OUT_DAT >= gdat$(day([F:TUV]UVYSTRDAT(I)),month([F:TUV]UVYSTRDAT(I)),year(OUT_DAT)) &
&             OUT_DAT <= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(OUT_DAT))
              OUT_DAT= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(OUT_DAT))+1
              DATMOD = 1
              Break
           Endif
         Else
          If month(OUT_DAT) > month([F:TUV]UVYENDDAT(I))
           If OUT_DAT >= gdat$(day([F:TUV]UVYSTRDAT(I)),month([F:TUV]UVYSTRDAT(I)),year(OUT_DAT)) &
&             OUT_DAT <= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(OUT_DAT)+1)
              OUT_DAT= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(OUT_DAT)+1)+1
              DATMOD = 1
              Break
           Endif
          Else
           If OUT_DAT >= gdat$(day([F:TUV]UVYSTRDAT(I)),month([F:TUV]UVYSTRDAT(I)),year(OUT_DAT)-1) &
&             OUT_DAT <= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(OUT_DAT))
              OUT_DAT= gdat$(day([F:TUV]UVYENDDAT(I)),month([F:TUV]UVYENDDAT(I)),year(OUT_DAT))+1
              DATMOD = 1
              Break
           Endif
         Endif
        Endif
       Next I
     Else
       For I=0 To [F:TUV]UVYNBR-1
         If OUT_DAT >= [F:TUV]UVYSTRDAT(I) & OUT_DAT <= [F:TUV]UVYENDDAT(I)
            OUT_DAT= [F:TUV]UVYENDDAT(I)+1
            DATMOD = 1
            Break
         Endif
       Next I
     Endif
     If DATMOD=1  #--We look for the following authorized day
        QUANT=day(OUT_DAT)
        MOIS = month(OUT_DAT)
        DYEAR = year(OUT_DAT)
        If ((int(DYEAR/4)=DYEAR/4) and (int(DYEAR/100)<>DYEAR/100))
&       or  (int(DYEAR/400)=DYEAR/400) Then
           WNBDAYFEB = 29
        Else
           WNBDAYFEB = 28
        Endif
        DAT1=OUT_DAT
        If [F:INVCNDD]INVDAYMON(0)<>0
          If MOIS <> 2
            If      QUANT<=[F:INVCNDD]INVDAYMON(0) QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
              Elsif QUANT<=[F:INVCNDD]INVDAYMON(1) QT=[F:INVCNDD]INVDAYMON(1) : Gosub _QUANTIEME
              Elsif QUANT<=[F:INVCNDD]INVDAYMON(2) QT=[F:INVCNDD]INVDAYMON(2) : Gosub _QUANTIEME
              Elsif QUANT<=[F:INVCNDD]INVDAYMON(3) QT=[F:INVCNDD]INVDAYMON(3) : Gosub _QUANTIEME
              Elsif QUANT<=[F:INVCNDD]INVDAYMON(4) QT=[F:INVCNDD]INVDAYMON(4) : Gosub _QUANTIEME
              Elsif QUANT<=[F:INVCNDD]INVDAYMON(5) QT=[F:INVCNDD]INVDAYMON(5) : Gosub _QUANTIEME
              Else                          QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
            Endif
          Else
            If    (QUANT<=[F:INVCNDD]INVDAYMON(0) & [F:INVCNDD]INVDAYMON(0)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(0)=99)
               QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
            Elsif (QUANT<=[F:INVCNDD]INVDAYMON(1) & [F:INVCNDD]INVDAYMON(1)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(1)=99)
               QT=[F:INVCNDD]INVDAYMON(1) : Gosub _QUANTIEME
            Elsif (QUANT<=[F:INVCNDD]INVDAYMON(2) & [F:INVCNDD]INVDAYMON(2)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(2)=99)
               QT=[F:INVCNDD]INVDAYMON(2) : Gosub _QUANTIEME
            Elsif (QUANT<=[F:INVCNDD]INVDAYMON(3) & [F:INVCNDD]INVDAYMON(3)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(3)=99)
               QT=[F:INVCNDD]INVDAYMON(3) : Gosub _QUANTIEME
            Elsif (QUANT<=[F:INVCNDD]INVDAYMON(4) & [F:INVCNDD]INVDAYMON(4)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(4)=99)
               QT=[F:INVCNDD]INVDAYMON(4) : Gosub _QUANTIEME
            Elsif (QUANT<=[F:INVCNDD]INVDAYMON(5) & [F:INVCNDD]INVDAYMON(5)<=WNBDAYFEB)|([F:INVCNDD]INVDAYMON(5)=99)
               QT=[F:INVCNDD]INVDAYMON(5) : Gosub _QUANTIEME
            Else
               QT=[F:INVCNDD]INVDAYMON(0) : Gosub _QUANTIEME
            Endif
          Endif
        Endif
     Endif
     If DAT1<>OUT_DAT: Goto _INI_CAL: Endif #--We test again if the calculated date is in a forbidden period
  Endif

Return
#--------------------------------------
$_DAYMONTH
  Local Integer INIDAY, PAYDAY(6)
  INIDAY=day(OUT_DAT)
  Raz PAYDAY

  If[F:INVCNDD]INVDAYMON(0)<>0
    For I=0 To 5
      PAYDAY(I)=[F:INVCNDD]INVDAYMON(I)
    Next
  Endif

  If PAYDAY(0)=0 or INIDAY=PAYDAY(0): Return: Endif

  If INIDAY<PAYDAY(0)
    OUT_DAT=OUT_DAT-INIDAY
    For I=5 To 0 Step-1
      If PAYDAY(I)<>0 and PAYDAY(I)<>99
        OUT_DAT=gdat$(PAYDAY(I),month(OUT_DAT),year(OUT_DAT)): Break
      Elsif PAYDAY(I)=99
        Break
      Endif
    Next
  Else
    For I=5 To 1 Step-1
      If PAYDAY(I)=0 and INIDAY>PAYDAY(I-1) and PAYDAY(I-1)<>0
        OUT_DAT=gdat$(PAYDAY(I-1),month(OUT_DAT),year(OUT_DAT)): Break
      Endif
      If PAYDAY(I)<>0
        If INIDAY=PAYDAY(I)
           Break
        Endif
        If INIDAY<PAYDAY(I) and INIDAY>PAYDAY(I-1)
          OUT_DAT=gdat$(PAYDAY(I-1),month(OUT_DAT),year(OUT_DAT)): Break
        Endif
      Endif
    Next
  Endif
Return
#----------------------------------------------------------------------------------------
#**
#* Funprog GET_PERFROM_PERTO is used calculate a starting date and a final date for a periodicity type invoice conditionning
#* It returns [V]CST_AERROR or [V]CST_AOK
#* Associated QLF : func QLF_SAL_SVCRINVCND_LIB.testsuite (run it before and after doing a modification)
#* @param IN_INVPER     The type of periodicity - local menu 2231 (day/month/year etc.)
#* @param IN_STARTDATE  A starting date if any (if empty then the IN_PREV_PERTO is mandatory)
#* @param IN_PREV_PERTO The previous period's end date if any (if empty then the IN_STARTDATE is mandatory)
#* @param OUT_PERFROM   The calculated start date
#* @param OUT_PERTO     The calculated end date
#* @param OUT_MESSAGE   Error/Info message if any
#*!
Funprog GET_PERFROM_PERTO(IN_INVPER,IN_STARTDATE,IN_PREV_PERTO,OUT_PERFROM,OUT_PERTO,OUT_MESSAGE)
Value Integer IN_INVPER
Value    Date IN_STARTDATE
Value    Date IN_PREV_PERTO
Variable Date OUT_PERFROM
Variable Date OUT_PERTO
Variable Char OUT_MESSAGE
Local Integer WRET

  WRET        = [V]CST_AOK
  OUT_MESSAGE = AVOID.ACHAR

  #--Testing if right values
  If IN_INVPER=0
    WRET = [V]CST_AERROR
    OUT_MESSAGE = mess(491,192,1)
    End WRET
  Endif
  #--At least one starting date
  If IN_STARTDATE=[0/0/0] and IN_PREV_PERTO=[0/0/0]
    WRET = [V]CST_AERROR
    OUT_MESSAGE = mess(492,192,1)
    End WRET
  Endif
  #--
  #--If previous end of period filled, then the start of actual period is previous end plus 1 day
  If IN_PREV_PERTO<>[0/0/0]
    OUT_PERFROM = IN_PREV_PERTO + 1
  Else
    OUT_PERFROM = IN_STARTDATE
  Endif

  Case IN_INVPER
    When 1 : #--JOUR
             OUT_PERTO=OUT_PERFROM   #--1 day : Start day= End day
    When 2 : #--SEMAINE
             OUT_PERTO=OUT_PERFROM+6 #--7 days : Start N-1 : Monday 05/10 => Start day N : Monday 12/10 Start day of week N-1 = Same start day for week N
    When 3 : #--QUINZAINE
             OUT_PERTO=OUT_PERFROM+14
    When 4 : #--MOIS
             Gosub _GET_PERFROM_PERTO_RANGE_MONTH
    When 5 : #--TRIMESTRE
             Gosub _GET_PERFROM_PERTO_RANGE_QUARTERYEAR
    When 6 : #--SEMESTRE
             Gosub _GET_PERFROM_PERTO_RANGE_HALFYEAR
    When 7 : #--ANNÉE
             Gosub _GET_PERFROM_PERTO_RANGE_YEAR
    When 8 : #--DÉCADE                                 # SAM 121987
             OUT_PERTO=OUT_PERFROM+9                   # SAM 121987
    When Default :   WRET = [V]CST_AERROR
                     OUT_MESSAGE = func AFNC.MES1(mess(493,192,1),"["+num$(IN_INVPER)+"]")
  Endcase

  If OUT_PERTO=[0/0/0]
    WRET = [V]CST_AERROR
    OUT_MESSAGE = mess(494,192,1)
    End WRET
  Endif
End WRET
#------------------------------------------------
$_GET_PERFROM_PERTO_RANGE_MONTH
Local Integer DDAY,DMONTH,DYEAR,DDAY_IN_PREV_PERFROM
  #--Results of addmonth :
  #--------------------------
  #=>addmonth([15/01/2016],1) #20160215
  #=>addmonth([15/01/2015],1) #20150215
  #--------------------------
  #=>addmonth([28/01/2015],1) #20150228
  #=>addmonth([28/01/2016],1) #20160228
  #--------------------------
  #=>addmonth([29/01/2015],1) #20150228
  #=>addmonth([29/01/2016],1) #20160229
  #--------------------------
  #=>addmonth([30/01/2015],1) #20150228
  #=>addmonth([30/01/2016],1) #20160229
  #--------------------------
  #=>addmonth([31/01/2015],1) #20150228
  #=>addmonth([31/01/2016],1) #20160229
  #--------------------------
  #=>addmonth([28/02/2015],1) #20150328
  #=>addmonth([28/02/2016],1) #20160328
  #--------------------------
  #=>addmonth([29/02/2016],1) #20160329

  OUT_PERTO = addmonth(OUT_PERFROM,1)

  DDAY_IN_PREV_PERFROM = day(IN_STARTDATE)

  DDAY   = day  (OUT_PERTO)
  DMONTH = month(OUT_PERTO)

  If  DMONTH=3
      DYEAR  = year (OUT_PERTO)
      Case DDAY_IN_PREV_PERFROM
        When 29,30,31:
                       If (((int(DYEAR/4  )= DYEAR/4  ) and
&                           (int(DYEAR/100)<>DYEAR/100))
&                        or (int(DYEAR/400)= DYEAR/400))=1
                         #--bisextile
                         OUT_PERTO += DDAY_IN_PREV_PERFROM-30
                       Else
                         OUT_PERTO += DDAY_IN_PREV_PERFROM-29
                       Endif
        When Default : OUT_PERTO -= 1
      Endcase
  Else
    If DDAY_IN_PREV_PERFROM<>31 or find(DMONTH,5,7,10,12)=0
      OUT_PERTO -= 1
    Endif
  Endif

Return
#------------------------------------------------
$_GET_PERFROM_PERTO_RANGE_QUARTERYEAR
Local Integer DDAY,DMONTH,DYEAR,DDAY_IN_PREV_PERFROM
  #--Results of addmonth :
  #--------------------------
  #=>addmonth([28/11/2015],3) #20160228
  #=>addmonth([28/11/2016],3) #20170228
  #--------------------------
  #=>addmonth([29/11/2015],3) #20160229
  #=>addmonth([29/11/2016],3) #20170228
  #--------------------------
  #=>addmonth([30/11/2015],3) #20160229
  #=>addmonth([30/11/2016],3) #20170228
  #--------------------------
  #=>addmonth([31/11/2015],3) #20160229
  #=>addmonth([31/11/2016],3) #20170228
  #--------------------------
  #=>addmonth([30/12/2015],3) #20160330
  #=>addmonth([30/12/2016],3) #20170330
  #--------------------------
  #=>addmonth([31/12/2015],3) #20160331
  #=>addmonth([31/12/2016],3) #20170331
  #--------------------------
  #=>addmonth([31/01/2015],3) #20150430
  #=>addmonth([31/01/2016],3) #20160430
  #--------------------------
  #=>addmonth([28/02/2015],3) #20150328
  #=>addmonth([28/02/2016],3) #20160328
  #--------------------------
  #=>addmonth([29/02/2016],3) #20160529
  OUT_PERTO=addmonth(OUT_PERFROM,3)

  DDAY_IN_PREV_PERFROM = day(IN_STARTDATE)

  DDAY   = day  (OUT_PERTO)
  DMONTH = month(OUT_PERTO)

  If  DMONTH=5
      DYEAR  = year (OUT_PERTO)
      Case DDAY_IN_PREV_PERFROM
        When 29,30,31:
                       If (((int(DYEAR/4  )= DYEAR/4  ) and
&                           (int(DYEAR/100)<>DYEAR/100))
&                        or (int(DYEAR/400)= DYEAR/400))=1
                         #--bisextile
                         OUT_PERTO += DDAY_IN_PREV_PERFROM-30
                       Else
                         OUT_PERTO += DDAY_IN_PREV_PERFROM-29
                       Endif
        When Default : OUT_PERTO -= 1
      Endcase
  Else
    If DDAY_IN_PREV_PERFROM<>31 or find(DMONTH,5,7,12)=0 #--find because starting and ending are 31 days months
      OUT_PERTO -= 1
    Endif
  Endif

Return
#------------------------------------------------
$_GET_PERFROM_PERTO_RANGE_HALFYEAR
Local Integer DDAY,DMONTH,DYEAR,DDAY_IN_PREV_PERFROM

  OUT_PERTO=addmonth(OUT_PERFROM,6)

  DDAY_IN_PREV_PERFROM = day(IN_STARTDATE)

  DDAY   = day  (OUT_PERTO)
  DMONTH = month(OUT_PERTO)

  If  DMONTH=8
      DYEAR  = year (OUT_PERTO)
      Case DDAY_IN_PREV_PERFROM
        When 29,30,31:
                       If (((int(DYEAR/4  )= DYEAR/4  ) and
&                           (int(DYEAR/100)<>DYEAR/100))
&                        or (int(DYEAR/400)= DYEAR/400))=1
                         #--bisextile
                         OUT_PERTO += DDAY_IN_PREV_PERFROM-30
                       Else
                         OUT_PERTO += DDAY_IN_PREV_PERFROM-29
                       Endif
        When Default : OUT_PERTO -= 1
      Endcase
  Else
    If DDAY_IN_PREV_PERFROM<>31 or find(DMONTH,3,5,8,10,12)=0  #--find because starting and ending are 31 days months
      OUT_PERTO -= 1
    Endif
  Endif
Return
#------------------------------------------------
$_GET_PERFROM_PERTO_RANGE_YEAR
Local Integer DDAY,DMONTH,DYEAR,DDAY_IN_PREV_PERFROM

  OUT_PERTO=addmonth(OUT_PERFROM,12)


  DDAY_IN_PREV_PERFROM = day(IN_STARTDATE)

  DDAY   = day  (OUT_PERTO)
  DMONTH = month(OUT_PERTO)

  If  DMONTH=2 and DDAY_IN_PREV_PERFROM=29
      DYEAR  = year (OUT_PERTO)
      If (((int(DYEAR/4  )= DYEAR/4  ) and
&          (int(DYEAR/100)<>DYEAR/100))
&       or (int(DYEAR/400)= DYEAR/400))=0
        #--only bisextyle year
        OUT_PERTO -= 1
      Else
        #--if start day equal 29 and got from non bisextyle to a bisextyle one, we have to leave 28 as end day
        #--void
      Endif
  Else
    If DDAY_IN_PREV_PERFROM<>31 or find(DMONTH,1,3,5,7,8,10,12)>0  #--find because starting and ending are 31 days months
      OUT_PERTO -= 1
    Endif
  Endif
Return
#------------------------------------------------

