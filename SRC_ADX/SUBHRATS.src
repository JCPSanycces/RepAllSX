################################################################################
#                                MASK [ASS0]
################################################################################
Subprog C_XITDAT(VALEUR)
Variable Date    VALEUR
# A faire : Ajouter GLEGFIL en + comme critère de sélection ?
# si on tient compte de GLEGFIL ici on ne pourrra traiter des fiches concernant une autre leg
# si on n'en tient pas compte, on pourra voir des fiches de leg différentes


  If [F:ID]FLGMULCTR=2
   Call SELCTR([M:HRASS0]REFNUM,VALEUR,VALEUR,[M:HRASS0]CTRNUM) From DIVPAYE
   If GMESSAGE<>""
    mkstat = 2 : End
   Endif
   Filter [F:HRATS] Where REFNUM=[M:HRASS0]REFNUM & CTRNUM=[M:HRASS0]CTRNUM & XITDAT<=VALEUR
  Else
   Filter [F:HRATS] Where REFNUM=[M:HRASS0]REFNUM & XITDAT<=VALEUR
  Endif
  Read [F:HRATS]ATS0 Last
  Filter [HRATS]
  If fstat<=2
   VALEUR = [F:HRATS]XITDAT
   [M:HRASS0]CTRNUM=[F:HRATS]CTRNUM :#MABOS-04/06/2013-FQ81084-US1641-
   #correct to display good record when emp mono contract & several successive chrono contracts
  Else
  # FICHE inexistante
    GMESSAGE = mess(23,100,1)
    mkstat = 2 : End
  Endif
End

#New 10/05
########################################
Subprog C_NUMORD(VALEUR)
Variable Decimal VALEUR
If VALEUR
 If clalev([F:HRATS2])=0 : Local File TASSEDIC  [HRATS2] : Endif
 For [F:HRATS2]ATS0 Where REFNUM<>[M:HRASS0]REFNUM & XITDAT<>[M:HRASS0]XITDAT & CTRNUM<>[M:HRASS0]CTRNUM & FCYSGE=[M:HRASS2]FCYSGE
  If VALEUR=[F:HRATS2]NUMORD
   GMESSAGE="N° déjà attribué" : mkstat=2 : Break
  Endif
 Next
Endif
End

