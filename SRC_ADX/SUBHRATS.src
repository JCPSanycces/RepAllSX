End

#61798+64157
###########################
Subprog AM_NBRDIF(VALEUR)
Variable Decimal VALEUR
If !VALEUR
 Effzo [M:HRASS7]AMTDIF
 Grizo [M:HRASS7]AMTDIF
 If !func AFNC.ACTIV("FRT")
  Effzo [M:HRASS7]ORGDIF1
  Grizo [M:HRASS7]ORGDIF1
 Else
  Effzo [M:HRASS7]ORGDIF2
  Grizo [M:HRASS7]ORGDIF2
 Endif
Else
 Actzo [M:HRASS7]AMTDIF
 If !func AFNC.ACTIV("FRT")
  Actzo [M:HRASS7]ORGDIF1
 Else
  Actzo [M:HRASS7]ORGDIF2
 Endif
Endif
End

#JOJAC - 2016-08-05 - X3PEOP-975 - START
#US3751 108474 Stagiaire
Subprog AM_NBRWEE(VALEUR)
Variable Decimal VALEUR
Local Integer L_OK
If VALEUR <> 0 & [M]NBRMON<>0
    #La durée totale en nombre de mois sera supprimée
    Call OUINON (mess(243,10703,1), L_OK) From GESECRAN
    If L_OK=2
      [M]NBRMON=0
      Affzo NBRMON
    Else
      mkstat=2
#      VALEUR=[M]NBRWEE
#      Affzo NBRWEE
    Endif
Endif
End

#US3751 108474 Stagiaire
Subprog AM_NBRMON(VALEUR)
Variable Decimal VALEUR
Local Integer L_OK
If VALEUR <> 0 & [M]NBRWEE<>0
    #La durée totale en nombre de semaines sera supprimée
    Call OUINON (mess(244,10703,1), L_OK) From GESECRAN
    If L_OK=2
      [M]NBRWEE=0
      Affzo NBRWEE
    Else
      mkstat=2
    Endif
Endif
End


