Raz GPILOBJ
Call OBJET("HRATS",GBIDC1,"") From GOBJET
End


########################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "INIMOD"       : Gosub INIMOD
 When "FILTRE"       : Gosub FILTRE
# When "FILGAUCHE"    : Gosub FILGAUCHE :#mis puis enlever par MABOS-04/06/13-FQ81084-US1641
 When "VERF_ANU"     : Gosub VERF_ANU
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "APRES_CHOI"   : Gosub APRES_CHOI
 When "AVANT_CHOI"   : Gosub AVANT_CHOI
 When "FERME"        : Gosub FERME
 When "STYLE"        : Gosub STYLE
 #JOJAC - 2016-08-05 - X3PEOP-975 - START
 When "STATUT"       : Gosub STATUT    :# V01X07 - Zoom sur données salarié AED
 #JOJAC - 2016-08-05 - X3PEOP-975 - END
Endcase

#JOJAC - 2016-08-05 - X3PEOP-975 - START
#JASMI - 2015-07-23 - Requirement 108579 - US 3790 - START

#JOJAC - 2016-08-05 - X3PEOP-975 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#JOJAC - 2016-08-05 - X3PEOP-975 - END
  If func DIVPAYE.EXISTE_KXX("SUBHRATSKSA") Then
    #JOJAC - 2016-08-05 - X3PEOP-975 - START
    #Gosub ACTION From SUBATSKSA
    Gosub ACTION From SUBHRATSKSA
    #JOJAC - 2016-08-05 - X3PEOP-975 - START
  Endif
Endif
#JASMI - 2015-07-20 - Requirement 108579 - US 3790 - END
 #JOJAC - 2016-08-05 - X3PEOP-975 - END

Return

$STYLE
Call DISPLAY_HIDE From SUBHRATSLEG
#JOJAC - 2016-08-05 - X3PEOP-975 - START
#Already showed and hidden in SUBHRATSLEG
#Case GCURLEG
# When "FRA",""
# Chgfmt [M:HRASS2]DATADH      With "D:"+GFMDAT
