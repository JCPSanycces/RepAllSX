# Chgfmt [M:HRASS5]LSTDAYWRK   With "-D:"+GFMDAT
# Endcase
#JOJAC - 2016-08-05 - X3PEOP-975 - END
Return

$OUVRE
Local Char CRITHRATS(250)
Local Char    WNUMLIB(30)
#JOJAC - 2016-08-05 - X3PEOP-975 - START
# V01X07 - Zoom sur données salarié AED
Local Char S_GFLAG(type([V]GFLAG)-10), VOIDCLE1(250), VOIDCLE2(250)
#JOJAC - 2016-08-05 - X3PEOP-975 - END

If clalev([F:HRATS])=0 : Local File TASSEDIC [HRATS] : Endif
#New 10/05
If clalev([F:HRAT2])=0 : Local File TASSEDIC2 [HRAT2] : Endif
#If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
If clalev([F:HRXGD])=0  : Local File HRXITGRD [HRXGD]  : Endif
# FQ81085 - 23/04/13 - Lecture HRCTR pour les numéros de sécu
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

#MIPEA - 2016-08-10 - X3PEOP-975 - START
If clalev([F:AT3])=0 : Local File TASSEDIC3 [AT3] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
#MIPEA - 2016-08-10 - X3PEOP-975 - END

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Local Char CRITHRATS(250)
# FQ81085 - US 1553 02/05/13 - Civility LEG
#MIPEA - 2016-10-10 - X3PEOP-751 - START
Call MANAGE_LOCALISATION("OHRATS") From DIVPAYE
#MIPEA - 2016-10-10 - X3PEOP-751 - START
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$FILTRE
If GUSRACS<>2
FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
FILTSUP = "1=1"
Endif
##enlever puis remis puis MABOS-04/06/13-FQ81084-US1641- manage separately the left list
If FILTSUP<>"" : FILTSUP += " & " : Endif
#FILTSUP += "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0) | [F:FCY]LEG='' | GLEGFIL=''"
FILTSUP += "(([F:CPY]LEG<>'' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | [F:CPY]LEG='' | GLEGFIL='')"
##end MABOS
Return

#MABOS-04/06/13-FQ81084-US1641- manage separately the left list
$FILGAUCHE
  FILGAUCHE += "(([F:CPY]LEG<>'' & (find([F:CPY]LEG,'"+GLEGFIL+"','')>0)) | [F:CPY]LEG='' | GLEGFIL='')"
Return


$SETBOUT    #pour désactiver le bouton "creer" et chgt clé
Call VIREBOUT (CHAINE,"CDH") From GOBJET
#39925
If GREP<>"" | GHISTO=1
 #pour désactiver le bouton "nouveau" et "extraction"
 Call VIREBOUT (CHAINE,"BG") From GOBJET
Endif
#Objet à 4 éléments de clé : ajout du btn suppression
If CLECUR  CHAINE+="A"  Endif
#JOJAC - 2016-08-05 - X3PEOP-975 - START
#V01X07 - Zoom sur données AED
[L]CHAINE += "M"
If CLECUR
    [L]CHMEN += "1"
Endif
Gosub SET_BOUT_SPE From GSAISIE
#JOJAC - 2016-08-05 - X3PEOP-975 - END

#JOJAC - 2016-08-05 - X3PEOP-975 - START
If !func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
  Call VIREBOUT (CHAINE,"1") From GOBJET
Endif
If !func DIVPAYE.IS_KZA(GCURLEG)
  Call VIREBOUT (CHAINE,"2") From GOBJET
Endif
If !func DIVPAYE.IS_KAE_LEG(GCURLEG)
  Call VIREBOUT (CHAINE,"3") From GOBJET
Endif
If !func DIVPAYE.IS_KSAU_LEG(GCURLEG)
  Call VIREBOUT (CHAINE,"4") From GOBJET
Endif
If !func DIVPAYE.IS_KQA_LEG(GCURLEG)
  Call VIREBOUT (CHAINE,"5") From GOBJET
Endif
If !func DIVPAYE.IS_KBH_LEG(GCURLEG)
  Call VIREBOUT (CHAINE,"6") From GOBJET
Endif
#JOJAC - 2016-08-05 - X3PEOP-975 - END
#THRAM - 2017-04-07 - X3PEOP-27062 - START
If !func DIVPAYE.IS_KUK_LEG(GCURLEG)
  Call VIREBOUT (CHAINE,"7") From GOBJET
Endif
#THRAM - 2017-04-07 - X3PEOP-27062 - END

Return

$EXEBOUT
Case BOUT
 When "B"
 [F:HRATS]REFNUM = [M:HRASS0]REFNUM
 [F:HRATS]CTRNUM = [M:HRASS0]CTRNUM
 [F:HRATS]XITDAT = [M:HRASS0]XITDAT
  Gosub LECTURE From GOBJSUB
  Gosub REMP_LISGAU From GOBJSUB
  Affzo
Endcase

Return

#JOJAC - 2016-08-05 - X3PEOP-975 - START
$STATUT
#V01X07 - Zoom sur données salarié AED - Prévoir un moyen de filtrer ?
Case BOUT
    When "1"
        [L]S_GFLAG = [V]GFLAG
        [V]GFLAG = "2"
        Call OBJET("DAE", [L]VOIDCLE1, [L]VOIDCLE2) From GOBJET
        [V]GFLAG = [L]S_GFLAG
Endcase
Return
 #JOJAC - 2016-08-05 - X3PEOP-975 - END


$LIENS
# Multi_leg & multi_société
Call LECTURE("FCY",[F:HRATS]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
Local Char WLASTLEG(GLONADI) :#MABOS-04/06/2013-FQ81084-US1641-
[L]WLASTLEG=GCURLEG:#MABOS-04/06/2013-FQ81084-US1641-
GCURLEG=[F:CPY]LEG

Gosub CHARGE_INDEMNITES
Gosub CHARGE_PRIMES
#New 10/05
Gosub CHARGE_SALAIRE

#61798
If !func AFNC.ACTIV("FRT")
 [M:HRASS7]ORGDIF1=[F:HRATS]ORGDIF
Else
 [M:HRASS7]ORGDIF2=[F:HRATS]ORGDIF
Endif
#MIPEA - 2016-08-10 - X3PEOP-975 - START
Gosub CHARGE_CONTRAT
#MIPEA - 2016-08-10 - X3PEOP-975 - END
Call AM_FLGLIKFAM ([M:HRASS1]FLGLIKFAM)
Call AM_ORGASS    ([M:HRASS2]ORGASS)
Call AM_FLGCVT    ([M:HRASS2]FLGCVT)
Call AM_FLGRVC    ([M:HRASS2]FLGRVC)
#MIPEA - 2016-08-10 - X3PEOP-975 - START
Call AM_FLGPRV    ([M:HRASS3]FLGPRV)
#Call AM_FLGPRV    ([M:HRASS3]FLGPRV)
#MIPEA - 2016-08-10 - X3PEOP-975 - START
Call AM_EMPCTR    ([M:HRASS3]EMPCTR)
Call AM_EMPSTA    ([M:HRASS3]EMPSTA)
Call AM_EMPSYSSSC ([M:HRASS3]EMPSYSSSC)
Call AM_EMPQLY    ([M:HRASS3]EMPQLY)
Call AM_GRDXIT    ([M:HRASS4]GRDXIT)
Call AM_PLNSOC    ([M:HRASS4]PLNSOC)
Call AM_FLGALCTOT ([M:HRASS4]FLGALCTOT)
Call AM_FLGALC    ([M:HRASS4]FLGALC)
Call AM_FCYHRSWEK ([M:HRASS4]FCYHRSWEK)
Call AM_EMPHRSWEK ([M:HRASS4]EMPHRSWEK)
Call AM_FCYHRSYEA ([M:HRASS4]FCYHRSYEA)
Call AM_EMPHRSYEA ([M:HRASS4]EMPHRSYEA)
Call AM_GRDHRSWEK ([M:HRASS4]GRDHRSWEK)
Call AM_FLGFNG1   ([M:HRASS4]FLGFNG1)
Call AM_FLGFNG2   ([M:HRASS4]FLGFNG2)
Call AM_FCYRPBFNC ([M:HRASS7]FCYRPBFNC)
#61798
Call AM_NBRDIF([M:HRASS7]NBRDIF)
#MIPEA - 2016-08-11 - X3PEOP-975 - START
Gosub GRISE_DIF
#MIPEA - 2016-08-11 - X3PEOP-975 - END

# To display or to hide fields based on legilation code
If [L]WLASTLEG<>GCURLEG :#MABOS-04/06/2013-FQ81084-US1641-
  Call DISPLAY_HIDE() From SUBHRATSLEG
Endif :#MABOS-04/06/2013-FQ81084-US1641-
# FQ81085 - 23/04/13 - Lecture HRCTR pour les numéros de sécu
Filter [HRCTR] Where REFNUM=[M:HRASS0]REFNUM & CTRNUM=[M:HRASS0]CTRNUM & CTRDAT<=[M:HRASS0]XITDAT
Read [HRCTR]CTR0 Last
Filter [HRCTR]
# FQ81085 - US 1553 02/05/13 - Civility LEG
If !fstat
  Call PARAM([F:HRCTR]ETRFCY,"CIVIL",WNUMLIB) From ADOVAL
  [M:HRASS0]CIV=[F:HRCTR]CIVCTR
Else
  Call PARAM([F:ID]FCYORI,"CIVIL",WNUMLIB) From ADOVAL
  [M:HRASS0]CIV=[F:ID]CIV
Endif
[M:HRASS0]NOLIB=val(WNUMLIB)
If [M:HRASS0]CIV>0 Then [M:HRASS0]CIVA=mess([M:HRASS0]CIV,val(WNUMLIB),1) : Endif
# END FQ81085 - US 1553

#JOJAC - 2016-08-05 - X3PEOP-975 - START
#JASMI - 2015-10-12 - Requirement 108579 - US 3990 - START
Call SETAMLLEG(0,"","",[M:HRASS0]CIV)
#JASMI - 2015-10-12 - Requirement 108579 - US 3990 - END
#JOJAC - 2016-08-05 - X3PEOP-975 - END

Return

$CHARGE_INDEMNITES
[M:HRASS6]AMTALC1=[F:HRATS]AMTALC(0)
[M:HRASS6]AMTALC2=[F:HRATS]AMTALC(1)
[M:HRASS6]AMTALC3=[F:HRATS]AMTALC(2)
[M:HRASS6]AMTALC4=[F:HRATS]AMTALC(3)
[M:HRASS6]AMTALC5=[F:HRATS]AMTALC(4)
[M:HRASS6]AMTALC6=[F:HRATS]AMTALC(5)
[M:HRASS6]AMTALC7=[F:HRATS]AMTALC(6)
[M:HRASS6]AMTALC8=[F:HRATS]AMTALC(7)
[M:HRASS6]AMTALC9=[F:HRATS]AMTALC(8)
[M:HRASS6]AMTALC10=[F:HRATS]AMTALC(9)
[M:HRASS6]AMTALC11=[F:HRATS]AMTALC(10)
[M:HRASS6]AMTALC12=[F:HRATS]AMTALC(11)
[M:HRASS6]AMTALC13=[F:HRATS]AMTALC(12)
[M:HRASS6]AMTALC14=[F:HRATS]AMTALC(13)
[M:HRASS6]AMTALC15=[F:HRATS]AMTALC(14)
[M:HRASS6]AMTALC16=[F:HRATS]AMTALC(15)
[M:HRASS6]AMTALC17=[F:HRATS]AMTALC(16)
[M:HRASS6]AMTALC18=[F:HRATS]AMTALC(17)
#49335
[M:HRASS6]AMTALC19=[F:HRATS]AMTALC(18)
Return

$CHARGE_PRIMES
For nolign=1 To dim([F:HRATS]DESBNS)-1
 If [F:HRATS]DESBNS(nolign-1)<>""
  [M:HRASS5]DESBNS(nolign-1)    = [F:HRATS]DESBNS(nolign-1)
  [M:HRASS5]STRDATBNS(nolign-1) = [F:HRATS]STRDATBNS(nolign-1)
  [M:HRASS5]ENDDATBNS(nolign-1) = [F:HRATS]ENDDATBNS(nolign-1)
  [M:HRASS5]DATBNS(nolign-1)    = [F:HRATS]DATBNS(nolign-1)
  [M:HRASS5]AMTBNS(nolign-1)    = [F:HRATS]AMTBNS(nolign-1)
 Else
  Break
 Endif
Next
[M:HRASS5]BPAG2=nolign-1
Return

#New 10/05
$CHARGE_SALAIRE
nolign=0
For [F:HRAT2]AT20 Where REFNUM=[F:HRATS]REFNUM & CTRNUM=[F:HRATS]CTRNUM & XITDAT=[F:HRATS]XITDAT
 nolign+=1
 [M:HRASS5]=[F:HRAT2]
Next
[M:HRASS5]NBRLIG=nolign
Return
#MIPEA - 2016-08-10 - X3PEOP-975 - START
$CHARGE_CONTRAT
nolign=0
For [F:AT3]AT30 Where REFNUM=[F:HRATS]REFNUM & CTRNUM=[F:HRATS]CTRNUM & XITDAT=[F:HRATS]XITDAT
 nolign+=1
 [M:HRASS8]=[F:AT3]
Next
[M:HRASS8]NBRCTR=nolign
Return
#MIPEA - 2016-08-10 - X3PEOP-975 - END
$INIMOD
Gosub SAUVE_INDEMNITES
Gosub SAUVE_PRIMES
#New 10/05
Gosub SAUVE_SALAIRES
#61798+64157
If !func AFNC.ACTIV("FRT")
 [F:HRATS]ORGDIF=[M:HRASS7]ORGDIF1
Else
 [F:HRATS]ORGDIF=[M:HRASS7]ORGDIF2
Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - START
Gosub SAUVE_CONTRATS
#MIPEA - 2016-08-11 - X3PEOP-975 - END
Return

$SAUVE_INDEMNITES
[F:HRATS]AMTALC(0)=[M:HRASS6]AMTALC1
[F:HRATS]AMTALC(1)=[M:HRASS6]AMTALC2
[F:HRATS]AMTALC(2)=[M:HRASS6]AMTALC3
[F:HRATS]AMTALC(3)=[M:HRASS6]AMTALC4
[F:HRATS]AMTALC(4)=[M:HRASS6]AMTALC5
[F:HRATS]AMTALC(5)=[M:HRASS6]AMTALC6
[F:HRATS]AMTALC(6)=[M:HRASS6]AMTALC7
[F:HRATS]AMTALC(7)=[M:HRASS6]AMTALC8
[F:HRATS]AMTALC(8)=[M:HRASS6]AMTALC9
[F:HRATS]AMTALC(9)=[M:HRASS6]AMTALC10
[F:HRATS]AMTALC(10)=[M:HRASS6]AMTALC11
[F:HRATS]AMTALC(11)=[M:HRASS6]AMTALC12
[F:HRATS]AMTALC(12)=[M:HRASS6]AMTALC13
[F:HRATS]AMTALC(13)=[M:HRASS6]AMTALC14
[F:HRATS]AMTALC(14)=[M:HRASS6]AMTALC15
[F:HRATS]AMTALC(15)=[M:HRASS6]AMTALC16
[F:HRATS]AMTALC(16)=[M:HRASS6]AMTALC17
[F:HRATS]AMTALC(17)=[M:HRASS6]AMTALC18
#49335
[F:HRATS]AMTALC(18)=[M:HRASS6]AMTALC19
Return


$SAUVE_PRIMES
For nolign=1 To [M:HRASS5]BPAG2-1
 [F:HRATS]DESBNS(nolign-1)    = [M:HRASS5]DESBNS(nolign-1)
 [F:HRATS]STRDATBNS(nolign-1) = [M:HRASS5]STRDATBNS(nolign-1)
 [F:HRATS]ENDDATBNS(nolign-1) = [M:HRASS5]ENDDATBNS(nolign-1)
 [F:HRATS]DATBNS(nolign-1)    = [M:HRASS5]DATBNS(nolign-1)
 [F:HRATS]AMTBNS(nolign-1)    = [M:HRASS5]AMTBNS(nolign-1)
Next
Return

#New 10/05
$SAUVE_SALAIRES
Delete [F:HRAT2] Where REFNUM=[F:HRATS]REFNUM & CTRNUM=[F:HRATS]CTRNUM & XITDAT=[F:HRATS]XITDAT
If fstat=1
 GOK =-1 : GLOCK = "$TASSEDIC2" : Return
Endif
For nolign=1 To [M:HRASS5]NBRLIG
 [F:HRAT2]       = [M:HRASS5]
 [F:HRAT2]REFNUM = [F:HRATS]REFNUM
 [F:HRAT2]CTRNUM = [F:HRATS]CTRNUM
 [F:HRAT2]XITDAT = [F:HRATS]XITDAT
 [F:HRAT2]NUMLIG = nolign
 Write [F:HRAT2]
 If fstat<>0
  GOK = 0 : Call FSTA("HRAT2") From GLOCK : Break
 Endif
Next
Return
#MIPEA - 2016-08-11 - X3PEOP-975 - START
$SAUVE_CONTRATS
Delete [F:AT3] Where REFNUM=[F:HRATS]REFNUM & CTRNUM=[F:HRATS]CTRNUM & XITDAT=[F:HRATS]XITDAT
If fstat=1
 GOK =-1 : GLOCK = "$TASSEDIC3" : Return
Endif
For nolign=1 To [M:HRASS8]NBRCTR
 [F:AT3]       = [M:HRASS8]
 [F:AT3]REFNUM = [F:HRATS]REFNUM
 [F:AT3]CTRNUM = [F:HRATS]CTRNUM
 [F:AT3]XITDAT = [F:HRATS]XITDAT
 [F:AT3]NUMLIG = nolign
 Write [F:AT3]
 If fstat<>0
  GOK = 0 : Call FSTA("AT3") From GLOCK : Break
 Endif
Next
Return
#MIPEA - 2016-08-11 - X3PEOP-975 - END
$VERF_ANU
Trbegin [HRAT2], [HRATS]
 Delete [F:HRAT2] Where REFNUM=[M:HRASS0]REFNUM & CTRNUM=[M:HRASS0]CTRNUM & XITDAT=[M:HRASS0]XITDAT
 If fstat=1
  GOK =-1 : GLOCK = "$TASSEDIC2" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [F:HRATS] Where REFNUM=[M:HRASS0]REFNUM & CTRNUM=[M:HRASS0]CTRNUM & XITDAT=[M:HRASS0]XITDAT
#MIPEA - 2016-08-11 - X3PEOP-975 - START
 If fstat=1
  GOK =-1 : GLOCK = "$TASSEDIC3" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [F:HRATS] Where REFNUM=[M:HRASS0]REFNUM & CTRNUM=[M:HRASS0]CTRNUM & XITDAT=[M:HRASS0]XITDAT
#MIPEA - 2016-08-11 - X3PEOP-975 - END
 If fstat=1
  GOK =-1 : GLOCK = "$TASSEDIC" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

$AB_ANN
Rollback
Return

$APRES_MODIF
# A developper pour charger la fiche si modif de xitdat
Return

# FQ81085 - MABON 25/06/12 - Navigate in the records, taking into account GLEGFIL
$FILHRATS

  CRITHRATS="1=1"
  If GLEGFIL<>""
    If CRITHRATS<>"" Then CRITHRATS-="&" : Endif
    CRITHRATS -= "(find([F:CPY]LEG,'"+GLEGFIL+"','')>0)"
  Endif
  Filter [HRATS_] Where evalue(CRITHRATS)
Return

$APRES_CHOI

  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILHRATS
      If REPONSE=GSTASUI Then Read [HRATS_]ATS1 > [M:HRASS0]XITDAT;[M:HRASS0]REFNUM;[M:HRASS0]CTRNUM  : Endif
      If REPONSE=GSTAPRE Then Read [HRATS_]ATS1 < [M:HRASS0]XITDAT;[M:HRASS0]REFNUM;[M:HRASS0]CTRNUM  : Endif
      If REPONSE=GSTAFIR Then Read [HRATS_]ATS1 First                                                 : Endif
      If REPONSE=GSTALAS Then Read [HRATS_]ATS1 Last                                                  : Endif
      Filter [HRATS_]
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End MABON

# FQ81085 - US1554 - 13/05/13
$AVANT_CHOI

  If [F:ID]REFNUM<>[F:HRATS]REFNUM & [F:HRATS]REFNUM<>"" Then
    Read [F:ID]ID0=[F:HRATS]REFNUM
  Endif
Return

#JOJAC - 2016-08-05 - X3PEOP-975 - START
$GRISE_DIF
Local Date DAT_END_DIF
DAT_END_DIF=gdat$(1,1,2015)
If [M:HRASS0]XITDAT>=[L]DAT_END_DIF
 Grizo [M:HRASS7]NBRDIF
 Grizo [M:HRASS7]AMTDIF
 If !func AFNC.ACTIV("FRT")
  Grizo [M:HRASS7]ORGDIF1
 Else
  Grizo [M:HRASS7]ORGDIF2
 Endif
Else
 Actzo [M:HRASS7]NBRDIF
 Call AM_NBRDIF([M:HRASS7]NBRDIF)
Endif
Return

#JASMI - 2015-10-12 - Requirement 108579 - US 3990 - START
#* Find the good local menu for the title, depending on the MonoLEG
#* @param PINI : 1= Initialisation (Create Employee)
#* @param PLEG : LEG not for V7 (MonoLEG)
#* @param PFCY : Site not for V7 (MonoLEG)
#* @param PITEMML : Numéric Item ML Field "Civility" or other (Item of ML)
#*!
Subprog SETAMLLEG(PINI,PLEG,PFCY,PITEMML)
Value Integer PINI
Value Char PLEG()
Value Char PFCY()
Value Integer PITEMML
Local Integer WCIVI
Local Integer PNOLIB,OKPAR

WCIVI=[M:HRASS0]CIV
Call VERIF_AML_EML(WCIVI,1,"CIVIL",PNOLIB,OKPAR)
[M:HRASS0]NOLIB=PNOLIB
If !OKPAR
   mkstat=2 : End
Endif
[M:HRASS0]CIVA=mess([M:HRASS0]CIV,[M:HRASS0]NOLIB,1)
Affzo [M:HRASS0]CIVA

End

#* Find the good local menu for the title, depending on the site
#* @param PFCY : Site not for V7 (MonoLEG)
#* @param PNUMCIV : Numéric Field Civility (Item of ML)
#* @param DISPMSG : Display mesage if dispmsg <> 0
#* @param LPARAM : Code of parameter
#* @param PNOLIB : Numéric Field ML Civility (ML)
#* @param PLEGI : LEG linkeg to the site of the employee
#* @param PLEGC : LEG linkeg to PFCY
#* @return OKPAR : is good(1) isn't good(0)
#*!
Subprog VERIF_AML_EML(PNUMCIV,DISPMSG,LPARAM,PNOLIB,OKPAR)
Value    Char    LPARAM
Value    Integer PNUMCIV
Variable Integer PNOLIB,OKPAR

Value Integer    DISPMSG
Local    Char    NUMLIB(10)

  OKPAR=0
  Call PARAM("",LPARAM,NUMLIB) From ADOVAL
  If NUMLIB<>"0" Then
    PNOLIB=val(NUMLIB)
    If PNUMCIV <> 0 & mess(PNUMCIV,val(NUMLIB),1)="" Then
      If DISPMSG
       #LIPET - 2017-03-30 - START
#       Call MESSAGE(func AFNC.MES1(mess(132,701,1), LPARAM)) From GESECRAN : # Le menu local du paramètre $1$ n'est pas correctement renseigné
        Call MESSAGE(func AFNC.MES1(mess(132,10701,1), LPARAM)) From GESECRAN : # Le menu local du paramètre $1$ n'est pas correctement renseigné
       #LIPET - 2017-03-30 - END
       Endif
    Else
      If mess(1,val(NUMLIB),1)="" Then
        If DISPMSG
           #LIPET - 2017-03-30 - START
           #Call MESSAGE(func AFNC.MES1(mess(132,701,1), LPARAM)) From GESECRAN : # Le menu local du paramètre $1$ n'est pas correctement renseigné
            Call MESSAGE(func AFNC.MES1(mess(132,10701,1), LPARAM)) From GESECRAN : # Le menu local du paramètre $1$ n'est pas correctement renseigné
           #LIPET - 2017-03-30 - END
        Endif
      Else
        OKPAR=1
      Endif
    Endif
  Else
   If DISPMSG
      #LIPET - 2017-03-30 - START
#     Call MESSAGE(func AFNC.MES1(mess(132,701,1), LPARAM)) From GESECRAN : # Le paramètre $1$ n'est pas correctement renseigné
      Call MESSAGE(func AFNC.MES1(mess(132,10701,1), LPARAM)) From GESECRAN : # Le paramètre $1$ n'est pas correctement renseigné
      #LIPET - 2017-03-30 - END
     Endif
  Endif

End
#JASMI - 2015-10-12 - Requirement 108579 - US 3990 - END

#US3751 108474 Stagiaire
Subprog GRISE_STG(PNATCON)
Value Char PNATCON()
Local Char WSIGN(1)
Local Char WNAMEBLCK(36)

If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
Read [F:AMKW]CODMSK = "ASSEDIC7"

If func DIVPAYE.ISTRAINEE([L]PNATCON) #US3751 108474 Stagiaire
 WSIGN=""
 WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(3))
# Actzo [M:HRASS3]NBRPERSTG : Actzo[M:HRASS3]PERSTG : Actzo[M:HRASS7]NBRMON : Actzo[M:HRASS7]NBRWEE
Else
 WSIGN="-"
# Effzo [M:HRASS3]NBRPERSTG : Raz[M:HRASS3]PERSTG : Effzo[M:HRASS7]NBRMON : Effzo[M:HRASS7]NBRWEE
# Grizo [M:HRASS3]NBRPERSTG : Grizo[M:HRASS3]PERSTG : Grizo[M:HRASS7]NBRMON : Grizo[M:HRASS7]NBRWEE
Endif
Chgtbk [M:HRASS7]20  With WNAMEBLCK
Chgfmt [M:HRASS1]TYPSCH       With WSIGN+"K:50X"
Chgfmt [M:HRASS1]SCHNAM       With WSIGN+"K:50X"
Chgfmt [M:HRASS3]NBRPERSTG    With WSIGN+"N:4"
Chgfmt [M:HRASS3]PERSTG       With WSIGN+"LA:313"
Chgfmt [M:HRASS7]NBRMON       With WSIGN+"N:9.2"
Chgfmt [M:HRASS7]NBRWEE       With WSIGN+"N:9.2"
Chgfmt [M:HRASS7]BNSSTG       With WSIGN+"N:9.2"
If WSIGN=""
  Affzo [M:HRASS1]TYPSCH,SCHNAM
  Affzo [M:HRASS3]PERSTG,NBRPERSTG
  Affzo [M:HRASS7]NBRMON,NBRWEE,BNSSTG
Else
  Raz [M:HRASS1]TYPSCH : Raz [M:HRASS1]SCHNAM : Raz [M:HRASS3]NBRPERSTG : Raz [M:HRASS3]PERSTG : Raz [M:HRASS7]NBRMON : Raz [M:HRASS7]NBRWEE
  Raz [M:HRASS7]BNSSTG
Endif
End
#JOJAC - 2016-08-05 - X3PEOP-975 - END

