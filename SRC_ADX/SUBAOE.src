Subprog AS_BAL(VALEUR)
Variable Char     VALEUR
If [M:AOE1]TYPFIL<>5 : mkstat = 1 : End : Endif
End

Subprog D_BAL(VALEUR)
Variable Char    VALEUR()
Local Integer K , DIME
Local Char    FLD(30) , BAL(30)
Case left$([M:AOE2]FLD(nolign-1),1)
 When "/","*","=","'",'"',""
  BAL = [M:AOE2]TYP(nolign-1)+"__"+num$(nolign)
 When Default
  FLD = [M:AOE2]FLD(nolign-1)
  K = instr(1,FLD,"(")
  If K
   DIME = val(right$(FLD,K+1))
   FLD = left$(FLD,K-1)
   BAL = FLD+"_"+num$(DIME)
  Else
   BAL = FLD
  Endif
Endcase
Read [ATB]CODFIC=[M:AOE2]FIL(nolign-1)
VALEUR = [F:ATB]ABRFIC+"_"+BAL
End

Subprog C_BAL(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 1 : End
Elsif find(VALEUR,"EXP","FLD","PAR","CRI")
 GMESSAGE = mess(149,141,1) : # Indicateur réservé
 mkstat = 1 : End
Elsif left$(VALEUR,1)>="0" & left$(VALEUR,1)<="9"
 GMESSAGE = mess(161,141,1) : # Codification interdite en HTML
 mkstat = 1 : End
Elsif VALEUR<>"" & find(VALEUR,[M:AOE1]FLGREC)
 GMESSAGE = mess(1,141,1) : # Indicateur déjà utilisé
 mkstat = 1 : End
Endif
Call UNICITE(VALEUR,[M]BAL) From OBJDIV
If mkstat : End : Endif
End

Subprog AS_CODDBA(VALEUR)
Variable Integer  VALEUR
GMENLOC(3) = 1 : # rdseq ne gère pas l'ucs2
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Call GRISE_TYPEXP(VALEUR)
End


