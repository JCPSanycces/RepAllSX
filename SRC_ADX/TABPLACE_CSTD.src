##############################################################################################
#$PROPERTIES
#Case [L]CURPTH
#    When ""
#      Case CURPRO
#        When "TPC"        : Gosub TPC
#        When "BPSNUM"     : Gosub BPSNUM
#        When "BPA.BPAADD"     : Gosub BPA_BPAADD
#      Endcase
#    Endcase
#Return

##############################################################################################
$TPC
Case [L]ARULE
 When "PROPAGATE"   : Gosub TPC_PROPAGATE
 When "CONTROL"     : Gosub TPC_CONTROL
Endcase
Return
##############################################################################################
$TPC_PROPAGATE
Local File FACILITY [FCY]
Local File BPSUPPLIER [BPS]
If this.TPCTYP = 7
  Read [F:FCY]FCY0 = this.TPC
  If !fstat
    this.DESAXX = [F:FCY]FCYNAM
    this.DESSHO = [F:FCY]FCYSHO
  Endif
Elsif this.TPCTYP=6
  Read [F:BPS]BPS0 = this.TPC
  If !fstat
    this.DESAXX = [F:BPS]BPSNAM
    this.DESSHO = [F:BPS]BPSSHO
  Endif
Endif
LogicClose File [FCY]
Return
##############################################################################################
$TPC_CONTROL
this.TPC=toupper(this.TPC)
Return

##############################################################################################
$BPSNUM
Case [L]ARULE
  When "CONTROL"     : Gosub BPSNUM_CONTROL
Endcase
Return
##############################################################################################
$BPSNUM_CONTROL
this.BPSNUM=toupper(this.BPSNUM)
Return
##############################################################################################
$TPCTYP
Case [L]ARULE
 When "PROPAGATE" : Gosub TPC_PROPAGATE
Endcase
Return
##############################################################################################
$BPA_BPAADD
Case [L]ARULE
 When "PROPAGATE"   : Gosub BPAADD_PROPAGATE
Endcase
Return

##############################################################################################
$BPAADD_PROPAGATE
Local Integer WRET,WBPATYP
Local Char WBPAERR(250)
Local Char WBPANUM(GLONBPS)
Local Integer I
Local File BPADDRESS [BPA]

If this.APARENT.FCY<> "" & this.APARENT.TPCTYP = 6
  WBPATYP = 3
  WBPANUM = this.APARENT.FCY
  WBPAERR = "FCY"
Elsif this.APARENT.BPSNUM<> "" & this.APARENT.TPCTYP = 7
  WBPATYP = 1
  WBPANUM = this.APARENT.BPSNUM
  WBPAERR = "BPSNUM"
# Issue 110502 - 2015-08-24 by MUARN : l'adresse n'est pas stockée correctement sinon
Else
  this.BPATYP = 8
Endif
##si l'adresse existe, remplissage des champs
Read [F:BPA]BPA0 = WBPATYP;WBPANUM;this.BPAADD
If !fstat
  Gosub REMP_ADR
Endif
Return

######################################################################################
$AINIT
this.ENAFLG = [V]CST_AYES
Return

##############################################################################################
$AINSERT_BEFORE
Local Char WSEQ_CODE(25)
Local Integer WMANUAL
Local Char WMESSAGE(250)
#gestion du compteur
If this.TPC=AVOID.ACHAR
  If func TCA_TOOL.LECTCA(this.ACTX, 9, fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY"), fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEG"),11, WSEQ_CODE, WMANUAL, WMESSAGE) = [V]
& CST_AFALSE
      [L]ASTATUS = fmet this.ASETERROR ("TPC", mess(64,199,1), [V]CST_AERROR)
  Endif
  If this.TPC = AVOID.ACHAR
    #Appel du numéro
    [L]ASTATUS=func ANM_TOOL.NUMERO(this.ACTX,WSEQ_CODE,this.FCY,this.CREDATTIM,"",this.CTRNUM,WMESSAGE)
    If [L]ASTATUS>= [V]CST_AERROR
       [L]ASTATUS = fmet this.ASETERROR ("TPC", WMESSAGE, [V]CST_AERROR)
    Endif
  Endif
Endif
If this.TPC = AVOID.ACHAR
  [L]ASTATUS = fmet this.ASETERROR ("TPC", mess(10,123,1), [V]CST_AERROR)
Endif
Return

##############################################################################################
$AINSERT_CONTROL_AFTER
Local Char WMESSAGE(250)
Local Integer WNUMLIN
#Zones obligatoires
If this.TPC = AVOID.ACHAR
  WMESSAGE =  mess(10,123,1)
  [L]ASTATUS = fmet this.ASETERROR ("TPC", WMESSAGE, [V]CST_AERROR)
  Return
Endif

#fournisseur
If this.TPCTYP = 7 & this.BPSNUM =""
  WMESSAGE = mess(17,7,1) +" : "+ mess(10,123,1)
  [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AERROR)
  Return
Endif
#site
If this.TPCTYP = 6 & this.FCY =""
  WMESSAGE = mess(7,47,1) +" : "+ mess(10,123,1)
  [L]ASTATUS = fmet this.ASETERROR ("FCY", WMESSAGE, [V]CST_AERROR)
  Return
Endif
#désignation
If this.DESAXX = AVOID.ACHAR
  WMESSAGE = mess(10,123,1)
  [L]ASTATUS = fmet this.ASETERROR ("DESAXX", WMESSAGE, [V]CST_AERROR)
  Return
Endif

If this.BPA(1).CRY = AVOID.ACHAR
  WMESSAGE = mess(164,100,1)
  [L]ASTATUS = fmet this.ASETERROR ("CRY", WMESSAGE, [V]CST_AERROR)
  Return
Endif
WNUMLIN = 0
For I=1 To maxtab(this.BPA)
  If this.BPA(I) <> null & find (this.BPA(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
    WNUMLIN += 1
  Endif
Next
If WNUMLIN > 1 | WNUMLIN = 0
  WMESSAGE = mess(481,194,1)
  [L]ASTATUS = fmet this.ASETERROR ("BPA", WMESSAGE, [V]CST_AERROR)
  Return
Endif

Return
##############################################################################################
$AINSERT_CONTROL_BEFORE
Local Char WMESSAGE(250)
Local Integer WNUMLIN

WNUMLIN = 0
For I=1 To maxtab(this.BPA)
  If this.BPA(I) <> null & find (this.BPA(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
    WNUMLIN += 1
  Endif
Next
If WNUMLIN > 1 | WNUMLIN = 0
  WMESSAGE = mess(481,194,1)
  [L]ASTATUS = fmet this.ASETERROR ("BPA", WMESSAGE, [V]CST_AERROR)
  Return
Endif

Return

##############################################################################################
$AUPDATE_CONTROL_AFTER
Local Integer WNUMLIN
#Une seule ligne d'adresse
WNUMLIN = 0
For I=1 To maxtab(this.BPA)
  If this.BPA(I) <> null & find (this.BPA(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0
    WNUMLIN += 1
  Endif
Next
If WNUMLIN > 1 | WNUMLIN = 0
  WMESSAGE = mess(481,194,1)
  [L]ASTATUS = fmet this.ASETERROR ("BPA", WMESSAGE, [V]CST_AERROR)
  Return
Endif
#Zones non modifiables
#Type de lieu
If this.TPCTYP <> this.snapshot.TPCTYP & this.TPCTYP<> AVOID.ADEC & this.snapshot.TPCTYP <> AVOID.ADEC
        WMESSAGE = mess(1880,200,1) + " : " + mess(9,123,1)
        [L]ASTATUS = fmet this.ASETERROR ("TPCTYP", WMESSAGE, [V]CST_AERROR)
        Return
Endif

#Fournisseur
If this.BPSNUM <> this.snapshot.BPSNUM & this.BPSNUM<> ""
        WMESSAGE = mess(17,7,1) + " : " + mess(9,123,1)
        [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AERROR)
        Return
Endif
#Site
If this.FCY <> this.snapshot.FCY & this.FCY<> ""
        WMESSAGE = mess(7,47,1) + " : " + mess(9,123,1)
        [L]ASTATUS = fmet this.ASETERROR ("FCY", WMESSAGE, [V]CST_AERROR)
        Return
Endif
#Mandatory zones
If this.BPA(1).CRY = AVOID.ACHAR
  WMESSAGE = mess(164,100,1)
  [L]ASTATUS = fmet this.ASETERROR ("CRY", WMESSAGE, [V]CST_AERROR)
  Return
Endif
#désignation
If this.DESAXX = AVOID.ACHAR
  WMESSAGE = mess(10,123,1)
  [L]ASTATUS = fmet this.ASETERROR ("DESAXX", WMESSAGE, [V]CST_AERROR)
  Return
Endif

Return
##############################################################################################
$BPA_ADDLINE_AFTER
Local Integer WRET,WBPATYP
Local Char WBPAERR(250)
Local Char WBPANUM(GLONBPS)
Local Integer I
Local File BPADDRESS [BPA]
#
If this.APARENT.FCY<> "" & this.APARENT.TPCTYP = 6
  WBPATYP = 3
  WBPANUM = this.APARENT.FCY
  WBPAERR = "FCY"
Elsif this.APARENT.BPSNUM<> "" & this.APARENT.TPCTYP = 7
  WBPATYP = 1
  WBPANUM = this.APARENT.BPSNUM
  WBPAERR = "BPSNUM"
Endif
###remplissage avec l'adresse par defaut (site ou fournisseur)
Filter [F:BPA] Where BPATYP=WBPATYP & BPANUM = WBPANUM & BPAADDFLG = [V]CST_AYES
Read [F:BPA] First
If !fstat
  Gosub REMP_ADR
Endif

Return
##############################################################################################
$BPA_AINSERT_BEFORE
If this.BPANUM=AVOID.ACHAR
  this.BPANUM = this.APARENT.TPC
Endif
Return
##############################################################################################
$BPA_AINSERT_CONTROL_BEFORE
If this.BPANUM=AVOID.ACHAR
  this.BPANUM = this.APARENT.TPC
Endif
Return
##############################################################################################
$REMP_ADR
this.BPATYP = 8
this.BPAADD = [F:BPA]BPAADD
this.BPADES = [F:BPA]BPADES
this.CRY = [F:BPA]CRY
this.CRYNAM = [F:BPA]CRYNAM
this.BPAADDLIG1 = [F:BPA]BPAADDLIG(0)
this.BPAADDLIG2 = [F:BPA]BPAADDLIG(1)
this.BPAADDLIG3 = [F:BPA]BPAADDLIG(2)
this.POSCOD = [F:BPA]POSCOD
this.CTY = [F:BPA]CTY
this.SAT = [F:BPA]SAT
this.MOB = [F:BPA]MOB
this.FCYWEB = [F:BPA]FCYWEB
Return
##############################################################################################
$DEL_ADR
this.BPATYP = 8
this.BPADES = AVOID.ACHAR
this.CRY = AVOID.ACHAR
this.CRYNAM = AVOID.ACHAR
this.BPAADDLIG1 = AVOID.ACHAR
this.BPAADDLIG2 = AVOID.ACHAR
this.BPAADDLIG3 = AVOID.ACHAR
#this.POSCOD = AVOID.ACHAR
this.CTY = AVOID.ACHAR
this.SAT = AVOID.ACHAR
this.MOB = AVOID.ACHAR
this.FCYWEB = AVOID.ACHAR
Return
##############################################################################################
$AREAD_AFTER
[L]ASTATUS = fmet this.ASETATTRIBUTE("TPCTYP","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("FCY","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("BPSNUM","$isDisabled", "true")

Return

