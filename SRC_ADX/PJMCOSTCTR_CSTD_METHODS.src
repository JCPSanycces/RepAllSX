#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMCOSTCTR
###################################################################################################
# METHODS
###################################################################################################
$DATRATE_COUNT
Local Integer NI

  # -----------------------------
  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.DATRATE)
    # -----------------------------
    If this.DATRATE(NI) <> null and find(this.DATRATE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
    # -----------------------------
  Next NI
Return

###################################################################################################
$DATRATE_CONVERT
Local Integer NI
Local Decimal DPCCCST
Local Integer ISTAT

  # -----------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.ASTALIN = [V]CST_AUPD Then
    If this.snapshot.PCCU <> this.PCCU and this.snapshot.PCCU <> AVOID.ACHAR or
&      this.snapshot.PCCCUR <> this.PCCCUR and this.snapshot.PCCCUR <> AVOID.ACHAR Then
      For NI = 1 To maxtab(this.DATRATE)
        If this.DATRATE(NI) <> null and find(this.DATRATE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.DATRATE(NI).TCHFORCST = [V]CST_ANO Then
            DPCCCST = this.DATRATE(NI).snapshot.PCCCST
            ISTAT = 0
            # -----------------------------
            If this.snapshot.PCCU <> this.PCCU and this.snapshot.PCCU <> AVOID.ACHAR Then
              #Call CONVERT_QTY(this.ACTX, this.snapshot.PCCU, this.PCCU, DPCCCST) From TRTX3_SYRA # Issue X3-29779/122141 - 2017-03-22 by FGR
              Call CONVERT_QTY(this.ACTX, this.PCCU, this.snapshot.PCCU, DPCCCST) From TRTX3_SYRA  # Issue X3-29779/122141 - 2017-03-22 by FGR
            Endif
            # -----------------------------
            If this.snapshot.PCCCUR <> this.PCCCUR and this.snapshot.PCCCUR <> AVOID.ACHAR Then
              # -----------------------------
              Call CONVERT(this.ACTX, this.snapshot.PCCCUR, this.PCCCUR, this.PCCCUR, 1, this.DATRATE(NI).PCCDATCST, DPCCCST, DPCCCST, ISTAT) From TRTDEV_SYRA
              # -----------------------------
              If ISTAT <> 0 Then
                [L]ASTATUS = fmet this.ASETERROR("PCCCUR", mess(236,2260,1), [V]CST_AERROR)
              Endif
              # -----------------------------
            Endif
            # -----------------------------
            If ISTAT = 0 Then
              this.DATRATE(NI).PCCCST = DPCCCST
            Endif
            # -----------------------------
          Endif
        Endif
      Next NI
    Endif
  Endif
  # -----------------------------
Return

###################################################################################################
# Issue X3-7591/120520 - 2016-12-20 by FGR : BEGIN
$CDIE_INIT
Local Integer I_DIE
Local Integer I_FCY
Local Char    L_CPY(GLONCPY)
Local Integer RNBRLED
Local Tinyint RLEDTYP(1..len(mess(0,2644,1)))
Local Char    RLEDCOD(GLONLED)(1..len(mess(0,2644,1)))
Local Char    RLEDCUR(GLONCUR)(1..len(mess(0,2644,1)))
Local Char    RCOA(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    RCOAFMT(15)(1..len(mess(0,2644,1)))
Local Char    RCOACOLHEA(15)(1..len(mess(0,2644,1)))
Local Integer RNBRDIE
Local Char    RDIE(GLONDIE)(1..max(1,GOPTCANA))
Local Char    RDIEFMT(15)(1..max(1,GOPTCANA))
Local Char    RDIECOLHEA(15)(1..max(1,GOPTCANA))
Local Integer RDIEOBYFLG(1..max(1,GOPTCANA))
Local Char    RERRMES(250)
Local Integer ILINE
Local Integer NI
Local Integer IRET
Local Integer BFND

  # Issue X3-4848/119127 - 2016-10-14 by FGR
  # -----------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Local File GDIE [DIE]
  Local File GLED [LED]
  # ---------------------------------------
  If this.PCCFCY <> AVOID.ACHAR Then
    # ---------------------------------------
    # A partir du site récupération du modèle, référentiels,...
    I_FCY = fmet this.ACTX.ACACHE.AFCY.AGETINDEX(this.PCCFCY)
    If I_FCY <> [V]CST_ANOTDEFINED Then
      L_CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PCCFCY,"LEGCPY")
    Endif
    # ---------------------------------------
    If func FINACM_SYRA.GET_FINSTC(this.ACTX, L_CPY, 2, RNBRLED, RLEDTYP, RLEDCOD, RLEDCUR, RCOA, RCOAFMT, RCOACOLHEA, RNBRDIE, RDIE, RDIEFMT, RDIECOLHEA, RDIEOBYFLG, RERRMES) = [V]CST_AOK Then
      # Récupération du référentiel Gérée à l'affaire
      # Issue X3-7591/120502 - 2017-02-01 by FGR : BEGIN
      #BFND = [V]CST_AFALSE
      #For I_LED = 1 To RNBRLED
      #  Call LEC_LED(RLEDCOD(I_LED)) From CPTLEC
      #  If [F:LED]PJMFLG = [V]CST_AYES Then
      #    BFND = [V]CST_ATRUE          # Référentiel Flagué Gestion à l'affaire
      #    Break
      #  Endif
      #Next I_LED
      #If BFND = [V]CST_ATRUE Then
      #  # Récupération des axes de la société
      #  For I_DIE = 1 To RNBRDIE
      #    Call LEC_DIE(RDIE(I_DIE)) From CPTLEC
      #    If [F:DIE]PCCFLG = [V]CST_AYES Then
      #      ILINE = fmet this.ADDLINE("CDIE", [V]CST_ALASTPOS)
      #      # ---------------------------------------
      #      If ILINE <> [V]CST_ANOTDEFINED Then
      #        this.CDIE(ILINE).DIE = RDIE(I_DIE)
      #      Endif
      #      # ---------------------------------------
      #    Endif
      #    # ---------------------------------------
      #  Next I_DIE
      #  # End issue 109158-11
      #Endif
      For I_DIE = 1 To RNBRDIE
        Call LEC_DIE(RDIE(I_DIE)) From CPTLEC
        If [F:DIE]PCCFLG = [V]CST_AYES Then
          For I_LED = 1 To RNBRLED
            Call LEC_LED(RLEDCOD(I_LED)) From CPTLEC
            If [F:LED]PJMFLG = [V]CST_AYES Then
              For NI = 0 To dim([F:LED]DIE)-1
                If [F:LED]DIE(NI) = RDIE(I_DIE) Then
                  ILINE = fmet this.ADDLINE("CDIE", [V]CST_ALASTPOS)
                  If ILINE <> [V]CST_ANOTDEFINED Then
                    this.CDIE(ILINE).DIE = RDIE(I_DIE)
                  Endif
                  Break
                Endif
              Next NI
            Endif
          Next I_LED
        Endif
      Next I_DIE
      # Issue X3-7591/120502 - 2017-02-01 by FGR : END
    Else
      [L]ARET_VALUE = fmet this.ASETERROR("", RERRMES, IRET)
    Endif
    # ---------------------------------------
  Else
    # ---------------------------------------
    Filter [DIE] Where PCCFLG = [V]CST_AYES
    For [DIE]
      BFND = [V]CST_AFALSE
      Filter [LED] Where PJMFLG = [V]CST_AYES and find([F:DIE]DIE, [F:LED]DIE(0..dim([F:LED]DIE)-1))
      For [LED]
        BFND = [V]CST_ATRUE
        Break
      Next
      Filter [LED]
      If BFND = [V]CST_ATRUE Then
        # At least on ledger which is using this [F:DIE]DIE is flagged PJMFLG = [V]CST_AYES
        If fmet this.CDIE_COUNT() < fmet this.AGETDIM("CDIE") Then
          ILINE = fmet this.ADDLINE("CDIE", [V]CST_ALASTPOS)
          # ---------------------------------------
          If ILINE <> [V]CST_ANOTDEFINED Then
            this.CDIE(ILINE).DIE = [F:DIE]DIE
          Else
            Break
          Endif
        Else
          [L]ARET_VALUE = fmet this.ASETERROR("CDIE", mess(432,2260,1), [V]CST_AWARNING)
          Break
        Endif
      Endif
      # ---------------------------------------
    Next
    Filter [DIE]
    # ---------------------------------------
  Endif
Return

