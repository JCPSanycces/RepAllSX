###################################################################################################
$CDIE_COUNT
Local Integer NI

  # Issue X3-4848/119127 - 2016-10-14 by FGR
  # -----------------------------
  [L]ARET_VALUE = 0
  # -----------------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

###################################################################################################
$CDIE_ERASE_COLLECTION
Local Integer NI

  # Issue X3-4848/119127 - 2016-10-14 by FGR
  # -----------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ILINE = fmet this.ADELLINE("CDIE", this.CDIE(NI).AORDER)
      If ILINE = [V]CST_ANOTDEFINED Then
        Break
      Endif
    Endif
  Next NI
Return

###################################################################################################
$CDIE_INSERT
Local Integer NI
Local Integer IRET

  # Issue X3-4848/119127 - 2016-10-14 by FGR
  # -----------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.TCHREPDIECCE = [V]CST_AYES Then
    # -------------------
    For NI = 1 To maxtab(this.CDIE)
      IRET = fmet this.CDIE_INSERT_INDEX(NI)
      [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
    Next NI
    # -------------------
  Else
    For NI = 1 To maxtab(this.CDIE)
      If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.CDIE(NI).CHX = [V]CST_AYES Then
          this.CDIE(NI).CHX = [V]CST_ANO
        Endif
      Endif
    Next NI
  Endif
Return

###################################################################################################
$CDIE_INSERT_INDEX
#Variable Integer INDEX
#Local Integer ARET_VALUE

Local Integer MAXFLD
Local Char RERRMES(250)
Local Integer L_UPDFCYCCE
Local Char L_FCY(GLONFCY)
Local Integer I_FCY
Local Integer IRET

  MAXFLD = 5

Local Char LCODFLD(GLONAVA)(1..MAXFLD)
Local Char LVALFLD(type(this.DESAXX)-10)(1..MAXFLD)

  # Issue X3-4848/119127 - 2016-10-14 by FGR
  # -----------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  If this.CDIE(INDEX) <> null and find(this.CDIE(INDEX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
    If this.CDIE(INDEX).CHX = [V]CST_AYES Then
      # -----------------------------
      Local File GLED [LED]
      Local File GDIE [DIE]
      Local File CACCE [CCE]
      # -----------------------------
      If this.PCCFCY <> AVOID.ACHAR Then
        L_UPDFCYCCE = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "UPDFCYCCE")
        If find(L_UPDFCYCCE,[V]CST_ANO,[V]CST_AYES) = 0 Then
          L_UPDFCYCCE = [V]CST_AYES  # Oui par défaut
        Endif
        L_FCY = ""
        If L_UPDFCYCCE = [V]CST_AYES Then
          I_FCY = fmet this.ACTX.ACACHE.AFCY.AGETINDEX(this.PCCFCY)
          If I_FCY <> [V]CST_ANOTDEFINED Then
            L_FCY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PCCFCY, "FINRSPFCY")
          Endif
        Endif
      Else
        Raz L_FCY
      Endif
      # -----------------------------
      Call LEC_DIE(this.CDIE(INDEX).DIE) From CPTLEC
      Call LEC_CCE(this.PCCCOD, this.CDIE(INDEX).DIE) From CPTLEC
      If fstat Then
        If this.PCCCOD = vireblc(format$([F:DIE]CCEFMT,this.PCCCOD),1) Then
          Raz LCODFLD
          Raz LVALFLD
          LCODFLD(1) = "DES"
         #LVALFLD(1) = this.SHOAXX     # Issue X3-3310/119127 - 2016-11-04 by FGR :  always short desc. Not THIS.DESAXX
          LVALFLD(1) = this.DESAXX     # Issue X3-7620/121322 - 2017-02-02 by FGR : Now again THIS.DESAXX !
          LCODFLD(2) = "FCY"
          LVALFLD(2) = L_FCY
          LCODFLD(3) = "ENAFLG"
          LVALFLD(3) = num$(2)
          LCODFLD(4) = "DESSHO"
          LVALFLD(4) = this.SHOAXX
          LCODFLD(5) = "IPT"
          LVALFLD(5) = num$(2)
          IRET = func FINCCE_SYRA.CRE_CCE(this.ACTX, "C", this.CDIE(INDEX).DIE, this.PCCCOD, LCODFLD, LVALFLD, RERRMES)
          If IRET <> [V]CST_AOK Then
            [L]ARET_VALUE = fmet this.ASETERROR("CCE", this.CDIE(INDEX).DIE - ":" - RERRMES, IRET)
          Else
            this.CDIE(INDEX).CCE = this.PCCCOD
          Endif
        Else
          this.CDIE(INDEX).CHX = [V]CST_ANO
          [L]ARET_VALUE = fmet this.ASETERROR("CCE", func AFNC.MES2(mess(442,2260,1), this.CDIE(INDEX).DIE, this.PCCCOD), [V]CST_AWARNING) # Issue X3-3271/119489 - 2016-10-28 by FGR
        Endif
      Endif
    Endif
  Endif
Return

###################################################################################################
$CDIE_UPDATE
Local Integer NI
Local Integer MAXFLD
Local Char RERRMES(250)
Local Integer L_UPDFCYCCE
Local Char L_FCY(GLONFCY)
Local Integer I_FCY

  MAXFLD = 5

Local Char LCODFLD(GLONAVA)(1..MAXFLD)
Local Char LVALFLD(type(this.DESAXX)-10)(1..MAXFLD)
Local Integer IRET

  # Issue X3-4848/119127 - 2016-10-14 by FGR
  # -----------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Local File GDIE [DIE]
  Local File CACCE [CCE]
  # -------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.CDIE(NI).CHX = [V]CST_AYES Then
        Call LEC_DIE(this.CDIE(NI).DIE) From CPTLEC
        # Axe flagué Gestion à l'affaire
        If this.CDIE(NI).snapshot.CHX = [V]CST_AYES Then
          # Update an existing record.
          Raz LCODFLD
          Raz LVALFLD
          LCODFLD(1) = "DES"
         #LVALFLD(1) = this.SHOAXX     # Issue X3-3310/119127 - 2016-11-04 by FGR :  always short desc. Not THIS.DESAXX
          LVALFLD(1) = this.DESAXX     # Issue X3-7620/121322 - 2017-02-02 by FGR : Now again THIS.DESAXX !
          LCODFLD(2) = "DESSHO"
          LVALFLD(2) = this.SHOAXX
          IRET = func FINCCE_SYRA.CRE_CCE(this.ACTX, "U", this.CDIE(NI).DIE, this.PCCCOD, LCODFLD, LVALFLD, RERRMES)
          If IRET <> [V]CST_AOK Then
            [L]ARET_VALUE = fmet this.ASETERROR("CCE", this.CDIE(NI).DIE - ":" - RERRMES, IRET)
          Endif
        Else
          # Need to create a new CCE
          IRET = fmet this.CDIE_INSERT_INDEX(NI)
          [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
        Endif
      Endif
    Endif
  Next NI
Return

###################################################################################################
$CDIE_DELETE
Local Integer NI
Local Integer NE
Local Integer IOKANU

  # -----------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
If 0=1 Then        # TODO FLORENT ICI fiche superviseur pour avoir ces VERIF et ANNULATION en Syracuse compatible
  NE = 0
  Local File GDIE [DIE]
  # -------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) = 0 Then
      Call LEC_DIE(this.CDIE(NI).DIE) From CPTLEC
      If [F:DIE]PJMFLG = [V]CST_AYES Then
        # Axe flagué Gestion à l'affaire
        # Préparation de la suppression de la section portée par l'axe géré à l'affaire
        NE = NI
        Break
      Endif
    Endif
  Next NI
  If NE > 0 Then
    # Suppression de la section
    Call VERIF(this.ACTX.AFOLDER, "CCE", this.CDIE(NE).CCE, this.CDIE(NE).DIE, IOKANU) From ANUCOD         # FLORENT ICI Appeler les syracuse compatibles
    If IOKANU = [V]CST_ATRUE Then
      Call ANNULATION(this.ACTX.AFOLDER, "CCE", this.CDIE(NE).CCE, this.CDIE(NE).DIE) From ANUCOD          # FLORENT ICI Appeler les syracuse compatibles
    Endif
  Endif
Endif
Return

