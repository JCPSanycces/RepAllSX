#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : site
#                             cf AML 2240 : 20
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables FCYWPIV devient WK, CRIFCYWPIV devient CRIWK
######################################################################
$OUVTAB_FCY
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If !clalev([F:FCY]) Local File FACILITY[FCY] Endif
If !clalev([F:CPY]) Local File COMPANY [CPY] Endif
If !clalev([F:BPR]) Local File BPARTNER  [BPR] Endif
If !clalev([F:BPC]) Local File BPCUSTOMER[BPC] Endif
Raz [F:FCY],[F:CPY],[F:BPR],[F:BPC]
Return

######################################################################
Subprog TRT_FCY(ID,CLETRT,PITFCY,P_CRITERE,PITCRIFCY,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITFCY () 
Value Char P_CRITERE() 
Value Char PITCRIFCY () 
Variable Integer OK

If PITFCY ="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID="SCMA"
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_FCY
Gosub OUVREPIVOT From CONNECTFCT

If PITFCY<>""
    Local Integer WPREFCY : Raz WPREFCY
    Local Integer WNBFCY : Raz WNBFCY 
    Local Char    OPTFCY(GDIMFIC)
    OPTFCY = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitfcy")
    Local Integer WKNBZON : Raz WKNBZON
    Local Char WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP : Raz WKHEATYP 
    Local Char WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITFCY,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITFCY,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITFCY,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREFCY,OPTFCY) From CONNECTFCT
Endif

If PITCRIFCY<>""
    Local Integer WPRECRIFCY : Raz WPRECRIFCY
    Local Integer WNBCRIFCY : Raz WNBCRIFCY 
    Local Char    OPTCRIFCY(GDIMFIC)
    OPTCRIFCY = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitcrifcy")
    Local Integer CRIWKNBZON : Raz CRIWKNBZON
    Local Char CRIWKNORECMES (50): Raz CRIWKNORECMES 
    Local Integer CRIWKHEATYP : Raz CRIWKHEATYP 
    Local Char CRIWKHEADMES (250): Raz CRIWKHEADMES 
    
    Call READPIT(PITCRIFCY,CRIWKNBZON,CRIWKNORECMES,CRIWKHEATYP ,CRIWKHEADMES ) From CONNECTFCT
    Local Char CRIWKTABZON(GLONATB+GLONAVA+2)(1..CRIWKNBZON) : Raz CRIWKTABZON
    Local Char CRIWKTABABR(GLONABR)(1..CRIWKNBZON) : Raz CRIWKTABABR
    Local Char CRIWKZON(GLONAVA)(1..CRIWKNBZON) : Raz CRIWKTABZON
    Local Char CRIWKFRM(150)(1..CRIWKNBZON) : Raz CRIWKFRM
    Local Integer CRIWKWRK(1..CRIWKNBZON) : Raz CRIWKWRK
    Local Char CRIWKVAL(255)(1..CRIWKNBZON) : Raz CRIWKVAL
    Local Char CRIWKVALFIC(GLONAVA)(1..CRIWKNBZON) : Raz CRIWKVALFIC
    Call LOADPIVZON(PITCRIFCY,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK) From CONNECTFCT
    If ID="SCMA"
        If [M:DIA]CRYFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPARTNER"+"/"+"CRY",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]BCGCODFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"BCGCOD",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD0FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD0",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD1FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD1",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD2FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD2",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD3FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD3",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]TSCCOD4FLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"WTSCCOD4",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]BPCINVFLG  = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"BPCINV",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
        If [M:DIA]BPCGRUFLG = 1 : # on doit enlever la colonne du pivot
            IPOS=find("BPCUSTOMER"+"/"+"BPCGRU",CRIWKTABZON(1..CRIWKNBZON))
            If IPOS>0 : CRIWKWRK(IPOS)=2 : Endif
        Endif
    Endif
    Call WRPIVOT_HEAD(PITCRIFCY,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKWRK,CRIWKHEATYP,CRIWKHEADMES,WPRECRIFCY,OPTCRIFCY) From CONNECTFCT
Endif

#######
For [FCY] Where evalue(P_CRITERE)
    Gosub WR_FCY
    Gosub WR_CRIFCY
Next
#######

If ID<>"SCMA"
    If PITFCY<>"" : Call WRPIVOT_END(PITFCY ,WNBFCY ,WKNORECMES ,WPREFCY ,OPTFCY) From CONNECTFCT : Endif
    If PITCRIFCY<>"" : Call WRPIVOT_END(PITCRIFCY ,WNBCRIFCY ,CRIWKNORECMES ,WPRECRIFCY ,OPTCRIFCY) From CONNECTFCT : Endif
Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_FCY
If PITFCY<>""
    ################################
    # fichiers FCY
    ################################
    #     Ouverture du fichier OPTFCY en écriture
    If WPREFCY = 0
      Openo OPTFCY,0 Using [FPIV]
      WPREFCY = 1
    Else
      Openo OPTFCY Using [FPIV]
    Endif
    
    WNBFCY += 1
    Call RAZVALPIVOT(PITFCY,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITFCY,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return

######################################################################
$WR_CRIFCY
If PITCRIFCY<>""
    ################################
    # fichiers CRIFCY
    ################################
    #     Ouverture du fichier OPTCRIFCY en écriture
    If WPRECRIFCY = 0
      Openo OPTCRIFCY,0 Using [FPIV]
      WPRECRIFCY = 1
    Else
      Openo OPTCRIFCY Using [FPIV]
    Endif
    
    WNBCRIFCY += 1
    Call RAZVALPIVOT(PITCRIFCY,CRIWKNBZON,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITCRIFCY,CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    Call WRPIVOT(CRIWKNBZON,CRIWKTABZON,CRIWKTABABR,CRIWKZON,CRIWKFRM,CRIWKWRK,CRIWKVAL,CRIWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return

######################################################################
#############################################################################
Funprog FCY_GETFCYNAM(FCY)
Value Char FCY

If !clalev([F:FCY]) Local File FACILITY [FCY] Endif
If [F:FCY]FCY<>FCY
    Read [FCY]FCY0=FCY
    If fstat : End "" : Endif
Endif
End [F:FCY]FCYNAM
End ""

######################################################################
#############################################################################
Funprog FCY_GETACCCUR(FCY)
Value Char FCY
If !clalev([F:FCY]) Local File FACILITY [FCY] Endif
If [F:FCY]FCY<>FCY
    Read [FCY]FCY0=FCY
    If fstat : End "EUR" : Endif
Endif
If !clalev([F:CPY]) Local File COMPANY [CPY] Endif
If [F:FCY]LEGCPY<>[F:CPY]CPY
    Read [CPY]CPY0=[F:FCY]LEGCPY
    If fstat : End "EUR" : Endif
Endif
If [F:CPY]ACCCUR<>"" : End [F:CPY]ACCCUR : Endif
End "EUR"


######################################################################

