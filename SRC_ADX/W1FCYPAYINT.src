#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FCYPAYINT 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:17"
A_USER  = "DOC"
A_STAMP = "20181109230417"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask FCYPAYINT [FCYI]
Gosub HORODAT
Local Inpbox "FCYPAYINT" From GFONCTION At A_STAMP With A_WINDPREV Mask [FCYI] As [SIM_]
Grizo [FCYI]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [FCYI]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=24
Return

$ON_FLGLIC
Onevent CONTROL Call C_FLGLIC(zc) From W1FCYPAYINT
Onevent INIT_AREA Call D_FLGLIC(zc) From W1FCYPAYINT
Onevent BEFORE_INPUT Call AS_FLGLIC(zc) From W1FCYPAYINT
Return

Subprog D_FLGLIC(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGLIC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGLIC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FLGLIC(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_FLGLIC(VALEUR) From SUBFCYB
If mkstat : GERR = 1 : GZONE = "FLGLIC" : GZNUM = 47427 : Endif
Gosub _AFF
End

