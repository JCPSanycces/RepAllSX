$ON_AEMFCY
Onevent CONTROL Call C_AEMFCY(zc) From W1FCYPAYINT
Onevent BEFORE_INPUT Call AS_AEMFCY(zc) From W1FCYPAYINT
Onevent AFTER_CHANGE Gosub AMM_AEMFCY From W1FCYPAYINT
Return

Subprog AS_AEMFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_AEMFCY(zc) From W1FCYPAYINT
Onkey 144 Titled GBOUTP Call P_AEMFCY(zc) From W1FCYPAYINT
Onkey 146 Titled GBOUTA Call SA_AEMFCY(zc) From W1FCYPAYINT
Gosub _AFF
End

Subprog C_AEMFCY(VALEUR)
Variable Char    VALEUR()
## Action ACONTFCY
Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "AEMFCY" : GZNUM = 47545 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!$",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "AEMFCY" : GZNUM = 47545 : Endif
 If !mkstat
  ## Action STD
  Call C_AEMFCY(VALEUR) From SUBFCYB
  If mkstat : GERR = 1 : GZONE = "AEMFCY" : GZNUM = 47545 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_AEMFCY
Call AM_AEMFCY(zc)
If !mkstat & GOBJET
 zoncou = "AEMFCY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_AEMFCY(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZAEMFCY)")>indice
 [M]AEMFCY(indice) = VALEUR
 Affzo ZAEMFCY(indice)
Endif
Gosub _AFF
End

Subprog S_AEMFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "!$"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_AEMFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_AEMFCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZAEMFCY
Onevent BEFORE_AREA Gosub AV_ZAEMFCY From W1FCYPAYINT
Return

$AV_ZAEMFCY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Local File FACILITY [F_] 
[F:F_]=[F:FCY]
Call LECTURE("FCY",num$([M]AEMFCY(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
[F:FCY]=[F:F_]
Close Local File [F_]
Gosub _AFF
Return

