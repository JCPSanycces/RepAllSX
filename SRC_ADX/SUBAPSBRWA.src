#<AdxTL>@(#)8.0.0.0 $Revision$
# ------------------------------------------------------------
# SUBAPSBRWA
# Version 0002
#    Fournisseurs de données Browser : Evaluation critére et données en format XML
#     La classe F:AP2 est disponible
#     Variables:
#        M_ACTION : demande sur la liste gauche
#        B_LSTNUM : numero de la liste à traiter
#        B_FILPAG : Filtre associé à la demande
#
#        Nota: montage fait à partir de SELOBJA et GOBJSUB
# ------------------------------------------------------------

#---- Initialisation des données (classe [F])
$B_DATAINIT
# Déclarations
Local Char ABREV, OPTIONS        # objet browser et options
Local Integer B_NBMAX, B_NB      # nombre maxi de résultats et compteur
Local Integer B_ORDTRI           # Ordre du tri et cle du tri
Local Char B_COL(50)(1..20)        # expression à évaluer pour avoir le contenu d'une colonne
Local Char B_COLLINK(3)(1..20)     # indique une colonne avec lien si <> ""

Local Char BW_STR1(200)
Local Char BW_URL(100)
Local Integer BW_I
Local Integer OKTRT

ABREV=[AP2]OBJ(B_LSTNUM-1) : OPTIONS=[AP2]OBJSEL(B_LSTNUM-1)
B_ORDTRI=[AP2]ORDTRI(B_LSTNUM-1) : B_NBMAX=[AP2]NBREC(B_LSTNUM-1)
U_TRAMES= "Begining of B_GETDATA from SUBAPSBRWA - X3 Objet: " + ABREV : Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif

GPROGRAMME="GOBJET"

# init fait en std en debut de GOBJET
GABREV=ABREV
GFONCTION="GES"+GABREV : Call AUTORIS From EXEFNC    # Gestion autorisation std
If GNBAUZ=0
    U_MESCODE="X3FNCNOTAUTHORIZE" : U_MESP1=GFONCTION : U_MESP2="" : U_ERR=UC_ERRG
    Gosub U_MESPUT From SUBAPSUTI : Return
Endif
Local Char    NAVIG(GLONANG), NAVCUR(GLONANG)

# init var fait en std par fonction DEFVAR de GOBJET
Gosub DEFVAR From GOBJET    # sur conseil de MB 20031107, à la place de la suite
        #Local Char    CLECUR1(30) , CLECUR2(30)(0..8)
        #Local Integer TPCLE1 , TPCLE2(0..8)
        #Local Char    FILTRE(240) , FILTSUP(240) , CRITERE(250)
        #Local Integer IFILTRE , IFILTSUP , ICRITERE
        #Local Char    FILGAUCHE(240)(0..8) , FILGAUSUP(240)(0..2) , FILROLE(250)(0..2) , FILSUITE(250)(0..5)
        #Local Integer IFILGAUCHE , IFILGAUSUP , IFILROLE , IFILSUITE
        #Local Char    FILACC(250) , NOMINT(10)
        #PROGOBJ = "WO"+ABREV
        #PROGSUB = "SUB"+ABREV
        #PROGSPE = "SPE"+ABREV

WINPROG = "WGO"+ABREV
Call EXISTE_ADX("","",PROGOBJ,OKTRT) From ORDSYS
If !OKTRT
    U_MESCODE="X3OBJUNKNOWN" : U_MESP1=PROGOBJ : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
Endif

# init fait en std par call SUIGAUCHE de GOBJSUB
Local Char    VALC(80)(1..16)
Local Char    CLELIS(20)(1..16) , CRITRI(80)
Local Char    BW_CLELISTYP(5)(1..16)
Local Integer IFILPREV
Local Integer NBCLE

# init fait en std par call SUIGAUCHE de GOBJACT (jpj 22/03/04)
DIMS = dim(FILSUITE)-1
DIMB = max(dim(FILGAUSUP),dim(FILROLE))
Local Char    CRITBUF(250)(0..DIMB)
Local Char    FILSAV(250)(0..DIMS) , FILPREV(250)(0..DIMS)


# init fait par SELOBJA
# - - - - - - - - - - - - - - - - - - - - - - - -
    Local Char CRITFIX(240)
    Gosub NOMFIC From =PROGOBJ
    If evalue("clalev([F:" + ABFIC + "]) <=0") : Gosub OUVFIC From =PROGOBJ : Endif
    # Gosub DEFAUT From =PROGOBJ    fait par DEFVAR de GOBJET
    # Gosub SETCLE  From =PROGOBJ   fait par DEFVAR de GOBJET    # Cles de l'objet (table principale)
    Gosub FIL_ROLE From GOBJSUB


# Calculs des critères par CRITGAU dans GOBJSUB
# - - - - - - - - - - - - - - - - - - - - - - - -
    #    Raz CRITERE, FILTSUP
    #    ACTION = "FILTRE" : Gosub ACTION  (sub -> dans FILTSUP et spe -> CRITERE)
    #    Filtre sur sites autorisés(+ -> CRITERE) - Filtre sur codes d'accès(-> FILACC)
    #    ACTION = "FILGAUCHE" : Gosub ACTION From GOBJET (sub FILGAUCHE +-> CRITERE et spe -> dans CRITERE ? (att concatenation))
    #    si existe FILRAP +-> dans CRITERE
    #    si existe FILACC +-> dans CRITERE

    # JPJ E32331 -> rempmlacement CritGau par séquence GOBJSUB pour éviter le FILGAUCHE
    # Gosub CRITGAU From GOBJSUB
    Gosub CRITGAU


    # Remarques
    #    GESxxx utilise les variables CRITERE, FILTSUP, FILROLE et FILSUITE pour le filtre
    #      FILTSUP   filtre du développeur (pt entrée FILTRE)
    #      CRITERE   somme de plusieurs filtres et dans pt entrée FILTRE et entrée FILGAUCHE)
    #                    contient:  Filtre sur sites autorisés, Filtre sur droit d'accès (FILACC de GOBJSUB)
    #      FILGAUCHE filtre du développeur (pt entrée FILGAUCHE)
    #      FILGAUSUP(0..1) pour les listes gauche supplémentaires
    #      FILROLE   filtre Role ($FILROLE de GOBJSUB)
    #      FILSUITE  filtre pagination
    #      FILREG=0  annulation filtre superviseur (pt entrée FILGAUCHE)
    #      FILRAP    filtre rapide


# Critères issues de la fiche browser - Code repris de SELOBJA
# - - - - - - - - - - - - - - - - - - - - - - - -
    CRITFIX = ""
    If OPTIONS<>""
        Gosub OPTIONS From =PROGOBJ
        For I=1 To NBCOND
            If instr(1,OPTIONS,OPT(I))
                If CRITFIX<>"" : CRITFIX -= "&" : Endif
                CRITFIX -= "(" + CONDIT(I) + ")"
            Endif
        Next I
    Endif
    If TYPGES=3 & evalue("type([F:"+ABFIC+"]"+CLELIG+")")<10
&                &  evalue("type([F:"+ABFIC+"]"+CLELIG+")")<>3
        # If CRITERE<>"" : CRITERE -= "&" : ENDIF
        CRITFIX -= CLELIG+"=1"
    Endif
    If CRITFIX ="" : CRITFIX ="1=1" : Endif # annulation filtre

    Gosub OUVRE_LISTE From =PROGOBJ    # caractéristiques liste

        # Browser: Recherche colonnes pour gérer le débranchement
        #  ne pas déplacer après DEFAUT_LISTE (affectation classe F par défaut)
        Gosub B_SETLINKS
        If GERR : Return : Endif

    # ex:Winprog="WGOITM"  Progobj="WOITM"
    Gosub TIT From =PROGOBJ            # titres
    Gosub DEFAUT_LISTE From =PROGOBJ       # Classe F à utiliser
    #
    # nota pour la suite:
    #     CLELISTE sous la forme "AXI;CCE Desc"
    #     CLELIS   sous la forme CLELIS(0)="AXI" , CLELIS(1)="CCE"
    If TYPGES=4    # objet browser (déclaration équivalente SETCLE_)
        Local Char    CLELISTE(250)
        Local Integer INDLIS , SNSLIS , LENLIS
        INDLIS = 1
        SNSLIS = SELORD
        LENLIS = 1
        If SELIND<>""            # un index est spécifié sur le bloc sélection de l'objet
            CLELISTE=SELIND
        Else
            CLELISTE = CLEPRIM
            For I=0 To dim(CLESEC)-1
                If CLESEC(I)<>""
                    LENLIS+=1
                    CLELISTE+=";"+CLESEC(I)
                Endif
            Next
        Endif
    Else    # objet classsique
#  69823   - Bug paie sur objet EML qui ne publie pas sa propre liste gauche     - cc 05/01/2011
        Onerrgo SUITOBJMUL
        Local Integer CHECKOBJM
        Gosub SETCLE_ From =WINPROG           # Clés de la liste employées par la $FILSUITE de GOBJSUB (filtre suivant)
        Onerrgo
        If CHECKOBJM=1 : Gosub SETCLE_1 From =WINPROG : Endif
        CLELISTE = CLEPRIM
        For I=0 To dim(CLESEC)-1
            If CLESEC(I)<>""
                LENLIS+=1
                CLELISTE+=";"+CLESEC(I)
            Endif
        Next
    Endif

    # jpj 20030620 - pb filtre suivant
    # Récupération nelle partie GOBJSUB
    Raz CLELIS, NBCLE, BW_CLELISTYP
    CHAINE = CLELISTE
    While CHAINE<>""
     I = instr(1,CHAINE,";")
     NBCLE += 1
     If I
      CLELIS(NBCLE) = vireblc(left$(CHAINE,I-1),2)
      CHAINE = right$(CHAINE,I+1)
     Else
      CLELIS(NBCLE) = vireblc(CHAINE,2)
      CHAINE = ""
     Endif
     For ASCDES = "Desc" , "desc", "Asc", "asc"
      I = instr(1,CLELIS(NBCLE),ASCDES)
      If I
       CLELIS(NBCLE) = vireblc(left$(CLELIS(NBCLE),I-1),2)
       BW_CLELISTYP(NBCLE)=ASCDES
      Endif
     Next ASCDES
    Wend
    # jpj 20030620 fin

    #  Invertion sens si besoin
    SNSLIS=B_ORDTRI                      # Sens du tri pour cette fct (ascendant: 1)
    If SNSLIS=2       # descendant
        Raz CLELISTE
        I=1
        CLELISTE=CLELIS(I)
        If find(BW_CLELISTYP(I), "","Asc","asc") : CLELISTE-="Desc" : Endif
        For I=2 To NBCLE
            CLELISTE+=";"+CLELIS(I)
        If find(BW_CLELISTYP(I), "","Asc","asc") : CLELISTE-="Desc" : Endif
        Next
    Endif
#    Inftxt CLELISTE At 1

    # Cle du tri
    B_CRITRI = CLELISTE

# Critére de pagination
If B_FILPAG="" : B_FILPAG="1=1" : Endif     # annulation filtre
# trace
U_TRAMES= "Critere: " + CRITERE + " Filtsup: " + FILTSUP : Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif
U_TRAMES= "Filrole: " + FILROLE + " Critfix: " + CRITFIX :  Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif
U_TRAMES= "Filpag: " + B_FILPAG : Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif

Onerrgo B_ERREVAL
        Filter [F] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(CRITFIX) & evalue(B_FILPAG)
& Order With B_CRITRI
Onerrgo
If U_ERR=UC_ERRG : Return : Endif


# Origine des données
For I=1 To NBSEL
  If SELEXP(I)<>""
       B_COL(I) = SELEXP(I)
  Else
       B_COL(I) = SELZON(I)
  Endif
  If left$(SELFMT(I),2)="LA"
   K = 1
   If left$(B_COL(I),4+len(ABFIC))="[F:"+ABFIC+"]"
    If find(right$(B_COL(I),5+len(ABFIC)),CLEPRIM,CLESEC(0..dim(CLESEC)-1))
     K = 0
    Endif
   Endif
   If K
    B_COL(I) = "mess("+B_COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
   Endif
  Endif
  U_TRAMES= "Colonne :" + num$(I) + " = " + B_COL(I) :  Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif
Next I
NBCOL = NBSEL

Return


$SUITOBJMUL
CHECKOBJM=1
Resume




#---- Ecriture des données
$B_DATAPUT
U_SEQPUT='<Data NbCol="' + num$(NBSEL) + '" >' : Gosub B_SEQPUTDEC
B_NBREC=0
Local Integer BRKLOOP
For [F]
    B_NBREC+=1
    # gestion pagination
    If B_NBREC > B_NBMAX     # flag pour précédent
        If M_ACTION=PQ_ACTNEXT & B_FILPAG<>"1=1"
            U_TECMES="<HasPrev/>" : Gosub U_TECPUT From SUBAPSUTI
            Gosub FILSUITE_OLD From GOBJACT    # charge FILSUITE et FILPREV jpj 20030701 (évol v140 b)
            U_HEXTOTXT=FILPREV : Gosub U_TXTTOHEX From SUBAPSUTI
            U_SEQPUT='<PrevFilter><![CDATA[' + U_TXTTOHEX + ']]></PrevFilter>' : Gosub B_SEQPUTDEC
        Endif
    Endif
    If B_NBREC = B_NBMAX     # filtre pour suivant
        # Ecriture filtre pour suivant
        Gosub FILSUITE_OLD From GOBJACT    # charge FILSUITE et FILPREV jpj 20030701 (évol v140 b)
        U_HEXTOTXT=FILSUITE : Gosub U_TXTTOHEX From SUBAPSUTI
        If dim(GRAPHBLOC)<0
   #       U_SEQPUT='<NextFilter><![CDATA[' + U_TXTTOHEX + ']]></NextFilter>' : Gosub B_SEQPUTDEC
          U_SEQPUT='<NextFilter><![CDATA['  : Gosub B_SEQPUTDEC  : # Bug 58974  Filtre trop long    CC  18/10/2009
          U_SEQPUT=FILSUITE  : Gosub B1_SEQPUTDEC
          U_SEQPUT=']]></NextFilter>' : Gosub B1_SEQPUTDEC
        Else
          U_SEQPUT='<NextFilter>' : Gosub B_SEQPUTDEC
          U_SEQPUT=U_TXTTOHEX : Gosub B1_SEQPUTDEC
          U_SEQPUT='</NextFilter>' : Gosub B1_SEQPUTDEC
        Endif
        U_TRAMES= "NextFilter :" + U_TXTTOHEX :  Gosub U_TRAPUT From SUBAPSUTI
        If GERR : BRKLOOP=1 : Break 1 : Endif
    Endif
    If B_NBREC > B_NBMAX     # flag pour suivant
         U_SEQPUT="<HasNext/>" : Gosub B_SEQPUTDEC
         Break
    Endif
    # gestion d'une ligne
    U_SEQPUT=' <Line>' : Gosub B_SEQPUTDEC
    For B_WI=1 To NBSEL
        U_HEXTOTXT=num$(evalue(B_COL(B_WI))) : Gosub U_TXTTOHEX From SUBAPSUTI : BW_STR1=U_TXTTOHEX

        # Gestion des colonnes avec lien
        If B_COLLINK(B_WI)<>""    #   lien
             Call GETURL(B_COLLINK(B_WI), CLEPRIM, CLESEC, M_MODE, BW_URL) From SUBAPSOBJ
             U_HEXTOTXT=BW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
             U_SEQPUT='  <Col X3Link="' + U_TXTTOHEX + '">' : Gosub B_SEQPUTDEC
             U_SEQPUT='     ' + BW_STR1 : Gosub B_SEQPUTDEC
             U_SEQPUT='  </Col>' : Gosub B_SEQPUTDEC
        Else    #    sans lien
             U_SEQPUT='  <Col>' + BW_STR1 + '</Col>' : Gosub B_SEQPUTDEC
        Endif
    Next
    U_SEQPUT=' </Line>' : Gosub B_SEQPUTDEC


Next
If BRKLOOP=1 : Return : Endif
U_SEQPUT='</Data>' : Gosub B_SEQPUTDEC

U_TRAMES= "Nombres de lignes écrites: " + num$(B_NBREC-1) :  Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif


# Raz filtre
Filter [F]

Return


$B_ERREVAL
U_TRAMES="Impossible d'évaluer le filtre." : U_ERR=UC_ERRG : Gosub U_TRAPUT From SUBAPSUTI
U_TRAMES= "Critere: " + CRITERE + " Filtsup: " + FILTSUP : Gosub U_TRAPUT From SUBAPSUTI
U_TRAMES= "Filrole: " + FILROLE + " Critfix: " + CRITFIX :  Gosub U_TRAPUT From SUBAPSUTI
U_TECMES= "Filpag: " + B_FILPAG : Gosub U_TECPUT From SUBAPSUTI
U_MESCODE="X3FILTERROR" : U_MESP1=ABREV : U_MESP2= "" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI
Resume
Return

#---- Recherche objet lié et colonne pour gérer le débranchement
$B_SETLINKS
 #Objet lié
    If clalev([F:VAOB])  = 0 : Local File AOBJET [VAOB] : Endif    # Table objet pour gestion des liens
    Read [F:VAOB]ABREV = [L]ABREV
    If fstat <> 0
        U_MESCODE="X3OBJUNKNOWN" : U_MESP1=ABREV : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
    Endif

    Case [F:VAOB]TYPGES
    When 1    # objet std avec liste gauche
    When 4    # objet browser : recherche objet principal
        Raz [F:VAOB]
        Filter [F:VAOB] Where NOMFIC=[L]NOMFIC & TYPGES=1
        Read [F:VAOB] First
        If fstat <> 0
            U_MESCODE="X3OBJLKUNKNOWN" : U_MESP1= NOMFIC : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
        Endif
        Filter [F:VAOB]
    When Default
        U_MESCODE="X3OBJNOTBRW" : U_MESP1=[F:VAOB]ABREV : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
    Endcase

 #Colonnes clés -> gestion des liens
    For BW_I=1 To NBSEL
        If SELEXP(BW_I)<>""
            BW_STR1 = SELEXP(BW_I)
        Else
            BW_STR1 = SELZON(BW_I)
        Endif
        If left$(BW_STR1,4+len(ABFIC))="[F:"+ABFIC+"]"
            If find(right$(BW_STR1,5+len(ABFIC)),CLEPRIM,CLESEC(0..dim(CLESEC)-1))
             U_TRAMES= "Colonne avec lien:" + num$(BW_I) + " = " + BW_STR1 + " Objet: " + [F:VAOB]ABREV :  Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif
             B_COLLINK(BW_I)=[F:VAOB]ABREV
            Endif
        Endif
    Next I

Return



# ------------------------------------------------------------
#  Accès aux titres des colonnes
# ------------------------------------------------------------

#---- Initialisation pour titres
$B_TITINIT

# Déclarations
Local Char ABREV        # objet

ABREV=[AP2]OBJ(B_LSTNUM-1) : OPTIONS=[AP2]OBJSEL(B_LSTNUM-1)
B_ORDTRI=[AP2]ORDTRI(B_LSTNUM-1) : B_NBMAX=[AP2]NBREC(B_LSTNUM-1)
U_TRAMES= "Begining of B_GETTIT from SUBAPSBRWA - X3 Objet: " + ABREV : Gosub U_TRAPUT From SUBAPSUTI : If GERR : Return : Endif

PROGOBJ = "WO"+ABREV
Call EXISTE_ADX("","",PROGOBJ,OKTRT) From ORDSYS
If !OKTRT
    U_MESCODE="X3OBJUNKNOWN" : U_MESP1=PROGOBJ : U_MESP2="" : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI : Return
Endif

# Recup des titres TITSEL NBSEL et SELLIB(I)
Gosub TIT From =PROGOBJ
Gosub OUVRE_LISTE From =PROGOBJ
Return

#---- Ecriture
$B_TITPUT
U_SEQPUT='<Titles NbCol="' + num$(NBSEL) + '" >' : Gosub B_SEQPUTDEC
U_SEQPUT=' <ListTitle>' + TIT + '</ListTitle>' : Gosub B_SEQPUTDEC
For EW_I=1 To NBSEL
    U_HEXTOTXT=SELLIB(EW_I) : Gosub U_TXTTOHEX From SUBAPSUTI
#    U_SEQPUT=' <ColTitle' + num$(EW_I) + '>' + U_TXTTOHEX + '</ColTitle' + num$(EW_I) + '>' : Gosub B_SEQPUTDEC
    U_SEQPUT=' <ColTitle>' + U_TXTTOHEX + '</ColTitle>' : Gosub B_SEQPUTDEC
Next
U_SEQPUT='</Titles>' : Gosub B_SEQPUTDEC
Return


# ------------------------------------------------------------
#  Commun
# ------------------------------------------------------------
#-- Ecriture output avec decalage
$B_SEQPUTDEC
  U_SEQPUT=space$(4)+U_SEQPUT :  Gosub U_PUT From SUBAPSUTI
Return

$B1_SEQPUTDEC
  Gosub U_PUT From SUBAPSUTI
Return


# JPJ E32331 - Reprise de la sequence standard de GOBJSUB sans
# l'appel à FILGAUCHE   (exemple sur produit Abel)
#  On ne connait pas sur un browser de type 4
#   - la fenetre sur un browser de type 4 (ex: FAS -> WGOFAS)
#   - pas de notion de tiroir (currbox) pour aiguillage dans FilGauche
#   - ne connaissant pas la fenêtre, on ne connait pas l'objet
#     portant le code FilGauche:
#     ex: objet FAS --> SUBFAS, pb avec le browser FA2 --> SUBFA2 (aucun code dedans)
# ------------------------------------------------------------
$CRITGAU
Gosub CRITERE From GOBJSUB
If CRITERE<>"" : CRITERE = "("+CRITERE+")" : Endif
ILIS = 0 : FILTREG = 1
adxmxl = GNBGAUCHE
# ACTION = "FILGAUCHE" : Gosub ACTION From GOBJET         # JPJ E32331
#If FILGAUCHE<>""
# Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+FILGAUCHE+")","&")
#Endif
If dim(FILRAP)>0 & FILRAP<>""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+FILRAP+")","&") From GOBJSUB
Endif
If FILACC<>"" & FILACC<>"1=1"
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+FILACC+")","&") From GOBJSUB
Endif
Gosub DEFAUT From =PROGOBJ
If CRITERE="" : CRITERE = "1=1" : Endif
If FILTSUP="" : FILTSUP = "1=1" : Endif
Return
