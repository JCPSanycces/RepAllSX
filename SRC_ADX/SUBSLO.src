#<AdxTL>@(#)186.0.0.0 $Revision$
Call OBJET ("SLO",GBIDC1,GBIDC2) From GOBJET
#End
#######################################################################
# SUBSLO : Transactions de saisie des commandes ouvertes EB  03/12/97 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SLQ]SALTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                                                                     #
# Génération de 2 écrans de saisie à partir des écrans de base SOR1   #
#                                                              SOI1   #
#                                                                     #
# Nom des écrans générés : WKxyyyz                                    #
#                            x = type de la transaction (STRTYP)      #
#                                1 -    devis                         #
#                                2 -    commandes                     #
#                                3 -    commandes ouvertes            #
#                                                                     #
#                          yyy = no de la transaction   (STRNUM)      #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 et 2 devis                         #
#                                1 et 2 cde ouverte                   #
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Gosub OUVRE From SUBSLX
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=3
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "EFFMASK"     : [M]STRTYP = 3
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
                      Gosub LIENS From SUBSLX
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="SLT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
                      Gosub ANNULE From SUBSLX
 When "APRES_MODIF" : Gosub APRES_MODIF From SUBSLX
 When "INICRE"      : Gosub INICRE From SUBSLX
 When "INIMOD"      : Gosub INICRE From SUBSLX
 When Default
Endcase
Return

#-------------------------------------------------------#
#                                                       #
#-------------------------------------------------------#
$OUVRE
Local Char APPLI
APPLI=nomap
Return

#-------------------------------------------------------#
# Ne traiter que les transactions de type commande ouv. #
#-------------------------------------------------------#
$FILTRE
FILTSUP="STRTYP=3"
Return

#---------------------------------#
# Désactivation bouton validation #
#---------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case BOUT
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#-------------------------------------------------------------#
# Initialisation des codes de saisie des sections analytiques #
#-------------------------------------------------------------#
$LIENS
#If dim([M]NBAXE)>0
#  If [M:SLO1]NBAXE=0 : [M:SLO1]NBAXE=GOPTCANA : Endif
#Endif
Return

#-------------------------------------------------------------#
# Initialisation des codes de saisie des sections analytiques #
#-------------------------------------------------------------#
$RAZCRE
[M:SLO0]ENAFLG = 2
#If dim([M]NBAXE)>0
#  If [M:SLO1]NBAXE=0 : [M:SLO1]NBAXE=GOPTCANA : Endif
#Endif
#For indice=0 To GOPTCANA-1
#  If CCECODD(indice) = 0 : CCECODD(indice) = 1 : Endif
#Next indice
#Affzo [M:SLO1] 10
Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC(15)
Local Char    TZONE(GLONAVA)(200)
Local Integer TMOD(200)
Local Char    TINT(1)(200)
Local Char    TTAB(1)(1)
Local Char    TFLD(1)(1)
Local Integer OPT1, OPT2, OPT3, RETOUR
Local Integer IZON, I, FLAG
# Local Char    BOUTONS(10)(4), TEXTE(40), LISTE(3), REPONS(1)

#------------------------- écran SOR1 -------------------------#
#If (dim([M:SLO1]CCECOD)>0 & [M:SLO1]CCECOD=3) | dim([M:SLO1]CCECOD)<1
# Gosub MODIF_ECRAN : If GOK<1 Return : Endif
#Endif

MFROM="SOR1"
MTO="WK"+num$([M:SLO0]STRTYP)+[M:SLO0]STRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If   ACTION <> "ANNULE"
     #---- inter-sites
     If   [M:SLO1]BETFCYCOD = 1 TZONE(IZON)="BETFCY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- inter-sociétés
     If   [M:SLO1]BETCPYCOD = 1 TZONE(IZON)="BETCPY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #--CPO 75115 Type de livraison
     #---- type de livraison
     If   [M:SLO1]SDHTYPCOD = 1 TZONE(IZON)="SDHTYP"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- client groupe
     If   [M:SLO2]BPCGRUCOD > 1 TZONE(IZON)="BPCGRU"
                                TMOD(IZON) =[M:SLO2]BPCGRUCOD
                                IZON+=1
     Endif
     #---- client payeur
     If   [M:SLO2]BPCPYRCOD > 1 TZONE(IZON)="BPCPYR"
                                TMOD(IZON) =[M:SLO2]BPCPYRCOD
                                IZON+=1
     Endif
     # 71065 : PJT
     #---- affaire
     If   [M:SLO2]PJTCOD > 1    TZONE(IZON)="PJT"
                                TMOD(IZON) =[M:SLO2]PJTCOD
                                IZON+=1
     Endif
     # 71065 : PJT
     # V6.2 : 60763 Settlements Discounts
     #---- Escompte
     If   [M:SLO2]DEPCOD > 1    TZONE(IZON)="DEP"
                                TMOD(IZON) =[M:SLO2]DEPCOD
                                IZON+=1
     Endif
     # V6.2 : 60763 Settlements Discounts
     #---- état commande (Etat signature)
     If   [M:SLO1]STACOD = 1    TZONE(IZON)="CDTSTA"
                                TMOD(IZON) =3
                                IZON+=1
                                TZONE(IZON)="APPFLG"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- régime de taxe
     If   [M:SLO2]VACBPRCOD > 1 TZONE(IZON)="VACBPR"
                                TMOD(IZON) =[M:SLO2]VACBPRCOD
                                IZON+=1
     Endif
     #---- type cours
     If   [M:SLO2]CHGCOD > 1    TZONE(IZON)="CHGTYP"
                                TMOD(IZON) =[M:SLO2]CHGCOD
                                IZON+=1
     Endif
     #---- prix HT/TTC
     If   [M:SLO2]PRITYPCOD > 1 TZONE(IZON)="PRITYP"
                                TMOD(IZON) =[M:SLO2]PRITYPCOD
                                IZON+=1
     Endif
#     #---- Sections analytiques d'entête
#     #------- Test si toutes les sections d'entête sont affichées --------#
#     If dim([M:SLO1]CCECOD)>0
#         If [M:SLO1]CCECOD=2    TZONE(IZON)="CCE"
#                                TMOD(IZON)=2
#                                TBLOC(5)=2
#                                IZON+=1
#         Endif
#     Endif
#     #------- Test si toutes les sections sont invisibles --------#
#     If (dim([M:SLO1]CCECOD)>0 & [M:SLO1]CCECOD=3) | dim([M:SLO1]CCECOD)<1
#         TBLOC(5)=1
#     Endif
     #----- Test si les sections d'entête sont affichées -----#
     If dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=2
        TZONE(IZON)="CCE"
        TMOD(IZON)=2
        #TBLOC(5)=2 ## X3-95974 Product pop up message for mandatory field in Sales transactions (lcc 20/06/18)
        IZON+=1
     Endif
     #----- Test si les sections d'entête sont invisibles -----#
     If (dim([M:DST]HEACCECOD)>0 & [M:DST]HEACCECOD=3) | dim([M:DST]HEACCECOD)<1
        TBLOC(5)=1
     Endif
     #---- type allocation
     If   [M:SLO2]ALLTYPCOD > 1 TZONE(IZON)="ALLTYP"
                                TMOD(IZON) =[M:SLO2]ALLTYPCOD
                                IZON+=1
     Endif

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

     #---- visualisation du masque généré
     OPT1 = 2
#     If ACTION<>"MASSE"
#        BOUTONS(1)=mess(2,1,1)    : # Oui
#        BOUTONS(2)=mess(1,1,1)    : # Non
#        BOUTONS(3)=mess(71,198,1) : # Abandon
#        TEXTE= " "+mess(1,196,1)  : LISTE="ONA" : REPONS="N"
#        Call CHOIXM(BOUTONS,TEXTE,LISTE,REPONS) From TRTX3
#        If REPONS="A" GOK=0  : Return : Endif
#        If REPONS="O" OPT2=1 : Endif
#     Endif
     #---- suppression du masque
Else OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

#------------------------- écran SOI1 -------------------------#
Local Char    ZT : # nom de zone dans table transaction
Local Char    ZM : # nom de zone dans le masque
Local Integer ZI : # pour les zones indicées
MFROM="SOI1"
MTO="WK"+num$([M:SLO0]STRTYP)+[M:SLO0]STRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
     #---- inter-sites
     If   [M:SLO1]BETFCYCOD = 1 TZONE(IZON)="BETFCY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- inter-sociétés
     If   [M:SLO1]BETCPYCOD = 1 TZONE(IZON)="BETCPY"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- marge détail
     If   [M:SLO1]PFMCOD    = 1 TZONE(IZON)="PFM"
                                TMOD(IZON) =3
                                IZON+=1
     Else
        ZT="PFMSCR" : ZM="PFM" : Gosub TABLEAU_FICHE From SUBSLX
     Endif
     # FGR 02/04/2015 : X3SUIVI105605 (début)
     If func AFNC.ACTIV("ECC") Then
       #---- version majeure
       If   [M:SLO3]ECCCOD > 1    TZONE(IZON)="ECCVALMAJ"
                                  TMOD(IZON) =[M:SLO3]ECCCOD
                                  IZON+=1
       Endif
       #---- version majeure
       If   [M:SLO3]ECCCODMIN > 1 TZONE(IZON)="ECCVALMIN"
                                  TMOD(IZON) =[M:SLO3]ECCCODMIN
                                  IZON+=1
       Endif
     Endif
     # FGR 02/04/2015 : X3SUIVI105605 (fin)
     #---- lieu consommation
     If   [M:SLO3]USEPLCCOD > 1 TZONE(IZON)="USEPLC"
                                TMOD(IZON) =[M:SLO3]USEPLCCOD
                                IZON+=1
     Endif
     # 71065 : PJT
     #---- affaire
     If   [M:SLO3]PJTCODD > 1   TZONE(IZON)="DPJT"
                                TMOD(IZON) =[M:SLO3]PJTCODD
                                IZON+=1
     Endif
     # 71065 : PJT
     #---- unité de vente
     If   [M:SLO3]SAUCOD    > 1 TZONE(IZON)="SAU"
                                TMOD(IZON) =[M:SLO3]SAUCOD
                                IZON+=1
     Endif
     #---- coef UV-US
     If   [M:SLO3]SAUCOECOD > 1 TZONE(IZON)="SAUSTUCOE"
                                TMOD(IZON) =[M:SLO3]SAUCOECOD
                                IZON+=1
     Endif
     #---- unité de stock
     If   [M:SLO1]STUCOD    = 1 TZONE(IZON)="STU"
                                TMOD(IZON) =3
                                IZON+=1
     Endif
     #---- niveau article
     If   [M:SLO3]VACITMCOD > 1 TZONE(IZON)="VACITM1"
                                TMOD(IZON) =[M:SLO3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM2"
                                TMOD(IZON) =[M:SLO3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="VACITM3"
                                TMOD(IZON) =[M:SLO3]VACITMCOD
                                IZON+=1
                                TZONE(IZON)="SSTCOD"           # 101380.n
                                TMOD(IZON) =[M:SLO3]VACITMCOD  # 101380.n
                                IZON+=1                        # 101380.n
     Endif
     #---- CPO 65018
     #---- Incoterm et ville Incoterm
     If   [M:SLO3]EECICTCOD > 1 TZONE(IZON)="EECICT"
                                TMOD(IZON) =[M:SLO3]EECICTCOD
                                IZON+=1
                                TZONE(IZON)="ICTCTY"
                                TMOD(IZON) =[M:SLO3]EECICTCOD
                                IZON+=1
     Endif
     #---- quantité prévue
     If   [M:SLO3]EXTQTYCOD > 1 TZONE(IZON)="EXTQTY"
                                TMOD(IZON) =[M:SLO3]EXTQTYCOD
                                IZON+=1
     Endif
     #---- montant prévue
     If   [M:SLO3]EXTAMTCOD > 1 TZONE(IZON)="EXTAMT"
                                TMOD(IZON) =[M:SLO3]EXTAMTCOD
                                IZON+=1
     Endif
     #---- montant réalisé
     If   [M:SLO3]CPLAMTCOD > 1 TZONE(IZON)="CPLAMT"
                                TMOD(IZON) =[M:SLO3]CPLAMTCOD
                                IZON+=1
     Endif
     #---- code tarif
     If   [M:SLO3]PLICOD    > 1 TZONE(IZON)="PLI"
                                TMOD(IZON) =[M:SLO3]PLICOD
                                IZON+=1
     Endif
     #---- régime de taxe
     If   [M:SLO3]VACBPRCODD> 1 TZONE(IZON)="VACBPR"
                                TMOD(IZON) =[M:SLO3]VACBPRCODD
                                IZON+=1
     Endif
     #---- représentant, taux commission, coeff.
     If   [M:SLO3]REPCODD   > 1 TZONE(IZON)="REP1"
                                TMOD(IZON) =[M:SLO3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REP2"
                                TMOD(IZON) =[M:SLO3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT1"
                                TMOD(IZON) =[M:SLO3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPRAT2"
                                TMOD(IZON) =[M:SLO3]REPCODD
                                IZON+=1
                                TZONE(IZON)="REPCOE"
                                TMOD(IZON) =[M:SLO3]REPCODD
                                IZON+=1
     Endif
     If   [M:SLO3]REPCODD = 1 | [M:SLO3]REPCODD = 2
        ZT="REPSCRD" : ZM="REP1" : Gosub TABLEAU_FICHE From SUBSLX
     Endif

     #---- valeur1 remise/frais
     If   dim([M:SLX1]DISCRGCOD1) > 0
          If  [M:SLX1]DISCRGCOD1 > 1 TZONE(IZON)="DISCRGVAL1"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD1
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD1 = 1 | [M:SLX1]DISCRGCOD1 = 2
             ZT="DISCRGSCR1" : ZM="DISCRGVAL1" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur2 remise/frais
     If   dim([M:SLX1]DISCRGCOD2) > 0
          If  [M:SLX1]DISCRGCOD2 > 1 TZONE(IZON)="DISCRGVAL2"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD2
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD2 = 1 | [M:SLX1]DISCRGCOD2 = 2
             ZT="DISCRGSCR2" : ZM="DISCRGVAL2" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur3 remise/frais
     If   dim([M:SLX1]DISCRGCOD3) > 0
          If  [M:SLX1]DISCRGCOD3 > 1 TZONE(IZON)="DISCRGVAL3"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD3
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD3 = 1 | [M:SLX1]DISCRGCOD3 = 2
             ZT="DISCRGSCR3" : ZM="DISCRGVAL3" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur4 remise/frais
     If   dim([M:SLX1]DISCRGCOD4) > 0
          If  [M:SLX1]DISCRGCOD4 > 1 TZONE(IZON)="DISCRGVAL4"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD4
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD4 = 1 | [M:SLX1]DISCRGCOD4 = 2
             ZT="DISCRGSCR4" : ZM="DISCRGVAL4" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

    #---- valeur5 remise/frais
     If   dim([M:SLX1]DISCRGCOD5) > 0
          If  [M:SLX1]DISCRGCOD5 > 1 TZONE(IZON)="DISCRGVAL5"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD5
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD5 = 1 | [M:SLX1]DISCRGCOD5 = 2
             ZT="DISCRGSCR5" : ZM="DISCRGVAL5" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur6 remise/frais
     If   dim([M:SLX1]DISCRGCOD6) > 0
          If  [M:SLX1]DISCRGCOD6 > 1 TZONE(IZON)="DISCRGVAL6"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD6
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD6 = 1 | [M:SLX1]DISCRGCOD6 = 2
             ZT="DISCRGSCR6" : ZM="DISCRGVAL6" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur7 remise/frais
     If   dim([M:SLX1]DISCRGCOD7) > 0
          If  [M:SLX1]DISCRGCOD7 > 1 TZONE(IZON)="DISCRGVAL7"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD7
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD7 = 1 | [M:SLX1]DISCRGCOD7 = 2
             ZT="DISCRGSCR7" : ZM="DISCRGVAL7" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur8 remise/frais
     If   dim([M:SLX1]DISCRGCOD8) > 0
          If  [M:SLX1]DISCRGCOD8 > 1 TZONE(IZON)="DISCRGVAL8"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD8
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD8 = 1 | [M:SLX1]DISCRGCOD8 = 2
             ZT="DISCRGSCR8" : ZM="DISCRGVAL8" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

     #---- valeur9 remise/frais
     If   dim([M:SLX1]DISCRGCOD9) > 0
          If  [M:SLX1]DISCRGCOD9 > 1 TZONE(IZON)="DISCRGVAL9"
                                     TMOD(IZON) =[M:SLX1]DISCRGCOD9
                                     IZON+=1
          Endif
          If   [M:SLX1]DISCRGCOD9 = 1 | [M:SLX1]DISCRGCOD9 = 2
             ZT="DISCRGSCR9" : ZM="DISCRGVAL9" : Gosub TABLEAU_FICHE From SUBSLX
          Endif
     Endif

#     #---- sections analytiques
#     For I=0 To dim([M:SLO1]CCECODD)-1
#         If   [M:SLO1]CCECODD(I) > 1 TZONE(IZON)="CCE"+num$(I+1)
#                                    TMOD(IZON) =[M:SLO1]CCECODD(I)
#                                    IZON+=1
#         Endif
#         If   [M:SLO1]CCECODD(I) = 1 | [M:SLO1]CCECODD(I) = 2
#            ZT="CCESCRD" : ZM="CCE"+num$(I+1) : ZI=I : Gosub TABLEAU_FICHE From SUBSLX
#         Endif
#     Next I
     If [M:DST]CCESCR>1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:DST]CCESCR)
         IZON+=1
       Next I
     Endif

     #---- Appel pour point entrée
     Gosub PE_SALTRS From SUBSLX

Endif

## 8 dans param WCTLFCY de l'écran de base SOI1
## si section ana en mode fiche uniquement (contrôle non bloquant)
#Gosub PARAM_CTRL_CCE_AV
#If GOK<1 : Return : Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
#---- erreur
If RETOUR<>0 GOK=0 : Return : Endif

## Restitution de l'écran de base SOI1 (3 dans param WCTLFCY)
## si section ana en mode fiche uniquement (contrôle non bloquant)
#Gosub PARAM_CTRL_CCE_AP
#If GOK<1 : Return : Endif

#---- suppression ou génération fenêtre AWINDOW
If ACTION="ANNULE"
  Gosub TRT_SUP_FEN From SUBSLX
Else
  Gosub TRT_GEN_FEN From SUBSLX
Endif
If GOK<1 : Return : Endif
#----
#If (dim([M:SLO1]CCECOD)>0 & [M:SLO1]CCECOD=3) | dim([M:SLO1]CCECOD)<1
#   Gosub RESTAUR_ECRAN : If GOK<1 Return : Endif
#Endif
Return

########################################
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End

########################################
Subprog AS_CCESCRD(VALEUR)
Variable Integer VALEUR
If [M]CCECODD(nolign-1)=3 : mkstat=2 : Endif
End

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

# Validation transactions commandes ouvertes depuis génération des patchs
Call GENPATCH(3,APPLI) From FUNSALTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions vente à partir du dico des types de transaction
Call GENDOS(3,APPLI) From FUNSALTRS

End

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=5
Local Integer TYP       : TYP=3
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return

