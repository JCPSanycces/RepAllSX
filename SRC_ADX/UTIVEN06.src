#<AdxTL>@(#)11.0.0.0 $Revision$
#############################################################################
# UTIVEN06 :                                                Module Vente    #
#            Utilitaire de maj des lignes de prix des contrats :            #
#            Maj date fin validité de la dernière ligne de prix avec la     #
#            date fin de validité de la ligne article                       #  
# ------------------------------------------------------------------------- #
# Problème à résoudre :  Bug 39216                                          #
#   La modification de la date de fin de validité d'une ligne article d'un  #
#      contrat n'était pas reportée sur la date de fin de validité de la    #
#      dernière ligne de prix                                               #
#   L'utilitaire a pour but :                                               #
#        - De mettre à jour la date de fin de validité de la dernière ligne #
#          de prix avec la date de fin de validité de la ligne article      #
#############################################################################

Call MAJ_UTIVEN06
End

##################################
Subprog MAJ_UTIVEN06
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
   Call EXE_UTIVEN06(DOSSIER)
Endif
End

##################################
Subprog EXE_UTIVEN06(DOSSIER)
Value Char DOSSIER

#Local Integer WSIMFLG : WSIMFLG=2
#Call OUINON(mess(6,115,1),WSIMFLG) From GESECRAN

Local Integer I

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIVEN06 : Liste des contrats mis à jour") From LECFIC  
Call ECR_TRACE("UTIVEN06 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:SOC])=0  Local File =DOSSIER+".SORDERC"    [SOC]  Endif
If clalev([F:SOP])=0  Local File =DOSSIER+".SORDERP"    [SOP]  Endif

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Mise à jour de la date fin validité de la dernière ligne de prix d'un contrat",0) From GESECRAN 
#If WSIMFLG=2 Call ECR_TRACE(mess(6,115,1),0) From GESECRAN Endif
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I

#Dbgaff

Call DEBTRANS From GLOCK
Trbegin [SOP]
# --> Lecture des lignes articles n'ayant pas de code tarif (et par conséquent ayant des lignes de prix)
For [SOC]SOC0 Where PLI=""
  # --> Recherche de la dernière ligne de prix 
  Filter [SOP]  Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN Order By Key NEWCLE=[F:SOP]ENDDAT
  Read [SOP]NEWCLE Last
  If fstat=0
    If [F:SOP]ENDDAT<[F:SOC]VLYDATITM 
      Readlock [SOP] Curr
      If fstat 
        Call ECR_TRACE("File SORDERP"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
      Else
        Call ECR_TRACE("*** Ligne article :"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-[F:SOP]ITMREF-"Date fin validité :"-format$(GFMDAT,[F:SOC]VLYDATITM),0) From GESECRAN
        Call ECR_TRACE("    Ligne prix    :"-format$(GFMDAT,[F:SOP]STRDAT)-"-"-format$(GFMDAT,[F:SOP]ENDDAT)-"Prix brut :"-format$("N3:15F[ ]",[F:SOP]GROPRI),0) From GESECRAN
        [F:SOP]ENDDAT=[F:SOC]VLYDATITM
        Rewrite [SOP]
        If fstat
          Call ECR_TRACE("File SORDERP"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
        Else
          I+=1
        Endif
      Endif                    
    Endif
  Endif           
  Filter [SOP]
Next
Commit 

If I>0
   Call ECR_TRACE("Nbre de lignes traitées : "-num$(I),0) From GESECRAN
Endif

$FIN_UTIVEN06
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


