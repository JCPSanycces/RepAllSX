#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ENTSAL2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRCTR
mkstat = 0
zoncou = "NBRCTR"
indice = 0
status = 1
zoncou = "NBRCTR"
If varmode([M]NBRCTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRCTR From SUBHRENT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRCTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCTR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCTR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCTR = nolign
   status = 75
   Call SAI_NBRCTR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBRCTR From SUBHRENT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRCTR" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

