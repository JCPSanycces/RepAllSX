  SAVACT = GACTION : GACTION = "STD"
  Call AM_WEXOSTR4([M]WEXOSTR4) From SUBHRENT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WEXOSTR4" : GZNUM = 1355 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone WEXOEND4
mkstat = 0
zoncou = "WEXOEND4"
indice = 0
WDATE = [M]WEXOEND4
If varmode([M]WEXOEND4,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEXOEND4" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DATDEBFIN"
 Call DATDEBFIN([M]WEXOEND4,[M]EXOSTR4) From EXEFNC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WEXOEND4" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WDATE<>[M]WEXOEND4 or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_WEXOEND4([M]WEXOEND4) From SUBHRENT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WEXOEND4" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 6
####################################
IMPTBL = 0

####################################
## Bloc liste 7
####################################
IMPTBL = 0

####################################
## Bloc tableau 8
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBRDLTCTR"
If !mkstat
 NBLIG = [M]NBRDLTCTR
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRDLTCTR = nolign
  status = 75
  Call SAI_NBRDLTCTR(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

mkstat = 0

End

