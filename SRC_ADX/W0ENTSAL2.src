## Zone WETRFCY
mkstat = 0
zoncou = "WETRFCY"
indice = 0
WCHAR = [M]WETRFCY
If varmode([M]WETRFCY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WETRFCY([M]WETRFCY) From SUBHRENT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WETRFCY : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WETRFCY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]WETRFCY,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTFCY"
   Call CONTSITE([M]WETRFCY) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("FCY","P",[M]WETRFCY,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_WETRFCY([M]WETRFCY) From SUBHRENT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "CTLFCYAUZ"
      Local Char    VALEUR(250)
      VALEUR = [M]WETRFCY
      Call S_AFF_CHAR(VALEUR,PARAM,"CTLFCYAUZ","CONTX3","") From GACTION
      [M]WETRFCY = VALEUR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       If WCHAR<>[M]WETRFCY or IMPMOD
        SAVACT = GACTION : GACTION = "STD"
        Call AM_WETRFCY([M]WETRFCY) From SUBHRENT
        GACTION = SAVACT
        If mkstat : GERR = 1 : GZONE = "WETRFCY" : GZNUM = 1344 : Endif
        Gosub AFF From GSAISIE
        If mkstat : End : Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

