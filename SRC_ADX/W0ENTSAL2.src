If varmode([M]WCTRDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WCTRDAT([M]WCTRDAT) From SUBHRENT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WCTRDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WCTRDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]WCTRDAT=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WCTRDAT" : GZNUM = 25968 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_WCTRDAT([M]WCTRDAT) From SUBHRENT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WCTRDAT" : GZNUM = 25968 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WDATE<>[M]WCTRDAT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_WCTRDAT([M]WCTRDAT) From SUBHRENT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WCTRDAT" : GZNUM = 25968 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

