#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
#    When "IMPORT"        : Gosub IMPORT
#    When "IMP_ZONE"      : Gosub IMP_ZONE
#    When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
Case ACTION
    When "IMP_OUVRE"     : Gosub OUVRE
    When "IMP_FERME"     : Gosub FERME
    When "EXPORT"        : Gosub EXPORT
Endcase
Return

$OUVRE
Global Char INTCOD
Return
# l'action EXPORT est la SEULE appellée à chaque record en export
# il n'y en a pas d'autre
$EXPORT
Local Char TRT  : TRT="4"
Local Char ACT  : ACT="1"
Local Char LANG : LANG=[F:ATC]LAN
If LANG=""
    LANG="FRA"
Endif
If [M:EXP2]NOMEXP <> ""
    Call MAJTRADX(LANG,TRT,ACT,[M:EXP2]NOMEXP) From MAJTRAD
    [M:EXP2]NOMEXP=""
Endif
Return

# Mise à jour suivi des traductions
# TRT=0 traitement de ATEXTE
# TRT=1 traitement de APLSTD
# TRT=2 traitement de AREPORT
# TRT=3 traitement de AREPORTX
# TRT=4 traitement de ATRACOD
# ACT=0 import
# ACT=1 export
$FERME
Local Char TRT  : TRT="4"
Local Char ACT  : ACT="0"
Local Char LANG : LANG=[F:ATC]LAN
If LANG=""
    LANG="FRA"
Endif
Call MAJTRADX(LANG,TRT,ACT,[M:IMP2]NOMIMP) From MAJTRAD
Return

$IMP_ZONE
Case IMPZON
When "INTCOD"    
    [M:ATC1]INTCOD=[F:ZZZ]INTCOD
    IMPMOD=0
    OK=0
When "TYP"
    [M:ATC1]TYP=[F:ZZZ]TYP
    IMPMOD=0
    OK=0
When "EXTCOD"
    [M:ATC1]EXTCOD=[F:ZZZ]EXTCOD
    IMPMOD=0
    OK=0
When "LAN"
    [M:ATC1]LAN=[F:ZZZ]LAN
    Read [F:ATC]ATC0=[F:ZZZ]TYP;[F:ZZZ]LAN;[F:ZZZ]INTCOD
    If fstat GREP="C"
    Else     GREP="M"
    Endif 
    IMPMOD=0
    OK=0
Endcase
Return


$IMP_VERIF_MOD
OK=1
Return

$IMPORT
OK=1
Return
