#<AdxTL>@(#)2.0.0.0 $Revision$
# Gestion du masque TCHCRIT
$ACTION
Case ACTION
 When "DEBUT"    : Gosub DEBUT
 When "AVANT_OK" : Gosub AVANT_OK
Endcase
Return

$DEBUT
Affzo [M:TCHC]
Return

$AVANT_OK
# copie des valeurs des critères dans le masque [TCH0] et dans les champs invisibles du masque [TCH2]
[M:TCH0] = [M:TCHC]
[M:TCH2] = [M:TCHC]

Gosub UPDCUR From FUNCDEV

Affzo [M:TCH0]
Affzo [M:TCH2]
Return

######################################################################################
Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR, [M]CUR) From OBJDIV
If GERR : End : Endif

If VALEUR = [M:TCHC]CURDEN
 mkstat=2 : GERR = 1 : GMESSAGE = mess(51,133,1)  : # Pas de cours pour la devise locale
 End
Endif
End


######################################################################################
