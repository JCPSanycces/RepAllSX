###################################################################################################
# Classe PIMPL
###################################################################################################
# Methods
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-51863 - 2017-08-07 by FGR
  If this.PIMTYP = 1 or  this.PIMTYP = 2 or this.PIMTYP = 3 Then
    SLEVEL = func AFNC.MES1(mess(939,2260,1), this.OPPNUM)
  Elsif this.PIMTYP = 4 Then
    SLEVEL = func AFNC.MES2(mess(940,2260,1), this.OPPNUM, this.PBUCOD)
  Else
    SLEVEL = func AFNC.MES2(mess(941,2260,1), this.OPPNUM, this.TASCOD)
  Endif
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$IS_USED_IN_ERP
  # Issue X3-4071/119443 - 2016-10-27 by FGR
  # -------------------------
  [L]ARET_VALUE = func PIMPL_CSTD_PROGS.IS_USED_IN_ERP(this.PIMNUM)
  # -------------------------
Return

