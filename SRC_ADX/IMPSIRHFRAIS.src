#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# IMPSIRHFRAIS
# Modifications :
#     MABOS-10/07/13-FQ89268-US1728- appel SEARCH_CTR
#     MABOS-19/09/13-FQ89268-US1928- suite
###################################################################################
Call IMPORTATION("SIRHFRAIS") From GIMPOBJ
End
################################################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "AP_IMPORT"     : Gosub AP_IMPORT
 When "IMP_VERIF_CRE" : Gosub VERIF
 When "IMP_VERIF_MOD" : Gosub VERIF
Endcase
Return

################################################################################################

$IMP_OUVRE
Local Char    CPY(GLONCPY),CPYCUR(GLONCUR), RPTCUR(GLONCUR)
Local Decimal RATCUR, RATRPT
Local Integer STAT, I
If clalev([F:ID])=0    : Local File EMPLOID          [ID]    : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR         [HRCTR] : Endif
If clalev([F:CPY])=0   : Local File COMPANY          [CPY]   : Endif
If clalev([F:EXS1])=0  : Local File HREXPENSES       [EXS1]  : Endif
If clalev([F:HRTES])=0 : Local File HRTABEXPENS      [HRTES]   : Endif
If clalev([F:CCE])=0   : Local File =GTABCPT+"CACCE" [CCE]   : Endif  ## FQ 105501
If clalev([F:ADI])=0   : Local File ATABDIV          [ADI]   : Endif
If clalev([F:ADU])=0   : Local File ADOVALAUS        [ADU]   : Endif

Return

################################################################################################

$AP_IMPORT
## CCE
## 105501
#For I=0 To GOPTCANA-1
# [F:HREXS]CCE(I) = vireblc(GIMP(I+3),4)
#Next



If [F:HREXS]PAYCUR<0
 [F:HREXS]PAYCUR *=-1
Endif

#MABOS-10/07/13-FQ89268-US1728- Modif pour multi-contrats
#Filter [HRCTR] Where REFNUM=[F:HREXS]REFNUM & CTRDAT<=[F:HREXS]DATEXS
#&     Order By Key CLE=CTRDAT Desc
#Read [HRCTR] First
#Filter [HRCTR]

Local Date DT
[L]DT=[0/0/0]
Local Char WMESS(250)
Call SEARCH_CTR([F:HREXS]REFNUM, [F:HREXS]CTRNUM, [L]DT,[F:HREXS]DATEXS,  [F:HREXS]DATEXS, [L]WMESS) From DIVPAYE
#MABOS-FQ89268-US1928
# affectation uniquement ici- Controle dans VERIF
If [L]WMESS<>"" Then
#
#  Call TRACE(2, [L]WMESS From SUBIMPOBJ
  Return
Endif
#end MABOS-FQ89268-US1928
#end MABOS-10/07/13-FQ89268-US1728- Modif pour multi-contrats

## FCY & CTRNUM
[F:HREXS]FCY    = [F:HRCTR]ETRFCY
[F:HREXS]CTRNUM = [F:HRCTR]CTRNUM

## CPY
[L]CPY    = GSOCSITE(find([F:HRCTR]ETRFCY,GSITE(1..GNBSITE)))
Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
[F:HREXS]CPY    = [L]CPY

## DIE ## FQ 105501
For I=0 To dim([F:HREXS]DIE)-1
  [F:HREXS]DIE(I)=[F:CPY]DIE(I)
Next

## CUR
[F:HREXS]CUR    = GDEVSOC(find([L]CPY,GSOC(1..GNBSOC)))
If [F:HREXS]CUR=""
 [F:HREXS]CUR   = GCURSHR
Endif

## TYPRAT
[F:HREXS]TYPRAT = 1

## RFUCUR
[F:HREXS]RFUCUR = [F:HREXS]PAYCUR

## DES
[F:HREXS]DES    = GIMP(1)-GIMP(2) : # Commentaire + Justificatif

## STA
[F:HREXS]STA    = 1               : # Non comptabilisé

## EXSTA
[F:HREXS]EXSSTA  = 2              :# Request   fq 105501

## RATCPY, RATRPT
Gosub INIDEV

## PAYSHR
Call CONVERT3( [F:HREXS]CUR,GCURSHR,[F:CPY]ACCCUR,[F:HREXS]TYPRAT,[F:HREXS]DATEXS,[F:HREXS]PAYCUR
&            , [F:HREXS]PAYSHR,[F:HREXS]RATCPY,STAT) From CPTSUB

## RFUSHR
Call CONVERT3( [F:HREXS]CUR,GCURSHR,[F:CPY]ACCCUR,[F:HREXS]TYPRAT,[F:HREXS]DATEXS,[F:HREXS]RFUCUR
&            , [F:HREXS]RFUSHR,[F:HREXS]RATCPY,[L]STAT) From CPTSUB

## VAT, TAXCUR, DEDCUR
####   105501
#If [F:HREXS]VATCUR=0
# [F:HREXS]VAT = "004"
# Raz [F:HREXS]TAXCUR, [F:HREXS]DEDCUR
#Else
# TXTVA = ([F:HREXS]VATCUR/([F:HREXS]PAYCUR-[F:HREXS]VATCUR))*100
# Filter [ADI] Where NUMTAB=552 & N1=TXTVA
# Read[ADI]CODE First
# Filter [ADI]
# If !fstat
#  [F:HREXS]VAT    = [F:ADI]CODE
# Else
#  Filter [ADI] Where NUMTAB=552 & DEFVAL=2
#  Read[ADI]CODE First
#  Filter [ADI]
#  If !fstat
#   [F:HREXS]VAT   = [F:ADI]CODE
#  Endif
# Endif
# [F:HREXS]TAXCUR = [F:HREXS]VATCUR
# [F:HREXS]DEDCUR = [F:HREXS]VATCUR
#Endif
## 105501
If [F:HREXS]VAT=""
  Read [F:HRTES]HRTES0=[F:HREXS]CODEXP
  If !fstat
     [F:HREXS]VAT=[F:HRTES]VAT
  Endif
Endif
If [F:HREXS]VAT<>""
  If !clalev([TRA]): Local File =GTABCPT+"TABRATVAT" : Endif
  Filter [F:TRA] Where VAT=[F:HREXS]VAT & CPY=[F:HREXS]CPY & STRDAT<=[F:HREXS]DATEXS
  Read [F:TRA]TRA1 Last
  If fstat
    Filter [F:TRA] Where VAT=[F:HREXS]VAT & CPY="" & STRDAT<=[F:HREXS]DATEXS
    Read [F:TRA]TRA1 Last
  Endif
  Filter [TRA]

  If [F:HREXS]VATCUR=0
     [F:HREXS]VATCUR=[F:HREXS]PAYCUR/(1+(100/[F:TRA]VATRAT))
     Call ARRDEV([F:HREXS]VATCUR,[F:HREXS]CUR)From TRTDIV
  Endif

  If [F:HREXS]RFUCUR<[F:HREXS]PAYCUR : [F:HREXS]TAXCUR=[F:HREXS]VATCUR*[F:HREXS]RFUCUR/[F:HREXS]PAYCUR
    Else                 [F:HREXS]TAXCUR=[F:HREXS]VATCUR
  Endif
  Call ARRDEV([F:HREXS]RFUCUR,[F:HREXS]CUR)From TRTDIV

  [F:HREXS]DEDCUR=[F:TRA]DEDRAT*0.01*[F:HREXS]TAXCUR
  Call ARRDEV([F:HREXS]DEDCUR,[F:HREXS]CUR) From TRTDIV
Endif
##### fIN FQ 105501

## QTY
If [F:HREXS]QTY=0
 [F:HREXS]QTY = 1
Endif

Filter [EXS1] Where IMPNUM=[F:HREXS]IMPNUM Order By Key CLE=LIN Desc
Read [EXS1] First
Filter [EXS1]

If !fstat
 [F:HREXS]UPDUSR = GIMP(9)
 [F:HREXS]UPDDAT = gdat$(val(left$(GIMP(10),2)),val(mid$(GIMP(10),3,2)),val(right$(GIMP(10),5)))
 [F:HREXS]UPDTIM = 3600*val(left$(GIMP(11),2))+60*val(mid$(GIMP(11),4,2))+val(right$(GIMP(11),7))
 [F:HREXS]LIN    = [F:EXS1]LIN+1
 [F:HREXS]EXSNUM = [F:EXS1]EXSNUM


 If [F:EXS1]STRDAT<>[0/0/0]  ## FQ 105501
    [F:HREXS]STRDAT = min([F:EXS1]STRDAT,[F:HREXS]STRDAT)
 Endif                       ## FQ 105501
 [F:HREXS]ENDDAT = max([F:EXS1]ENDDAT,[F:HREXS]ENDDAT)

 If [F:HREXS]STRDAT<>[F:EXS1]STRDAT | [F:HREXS]ENDDAT<>[F:EXS1]ENDDAT
  Update [EXS1] Where IMPNUM=[F:HREXS]IMPNUM
&                With STRDAT=[F:HREXS]STRDAT
&                   , ENDDAT=[F:HREXS]ENDDAT
 Endif
Else
 [F:HREXS]LIN    = 1
 [F:HREXS]EXSNUM = uniqid([HREXS])
 [F:HREXS]ENDDAT = [F:HREXS]DATEXS
 [F:HREXS]STRDAT = [F:HREXS]DATEXS
 [F:HREXS]CREUSR = GIMP(9)
 [F:HREXS]CREDAT = gdat$(val(left$(GIMP(10),2)),val(mid$(GIMP(10),3,2)),val(right$(GIMP(10),5)))
 [F:HREXS]CRETIM = 3600*val(left$(GIMP(11),2))+60*val(mid$(GIMP(11),4,2))+val(right$(GIMP(11),7))
Endif
Return

################################################################################################

$INIDEV
##Call SETFLGDEV([F:HREXS]CUR,[L]CPY,[F:HREXS]DATEXS) From SUBGA0 : # Positionne GCURFLG GCPYFLG GRPTFLG
Call SETFLGDEV([F:HREXS]CUR,[L]CPY,[F:HREXS]DATEXS) From CPTDIV : # Positionne GCURFLG GCPYFLG GRPTFLG  FQ105501

GDEVORI1=[F:HREXS]CUR
GDEVORI2=[F:HREXS]CUR

If GCURFLG=2 & [F:HREXS]CUR<>GEURO
 If GCPYFLG=1 : GDEVORI1 = GEURO : Endif
 If GRPTFLG=1 : GDEVORI2 = GEURO : Endif
Endif

CPYCUR = [F:CPY]ACCCUR
RPTCUR = GSYSCUR
If GCURFLG=1
 If GCPYFLG=2 & GSYSCUR<>GEURO : CPYCUR = GEURO : Endif
 If GRPTFLG=2 & CPYCUR <>GEURO : RPTCUR = GEURO : Endif
Endif

# Calcul du taux théorique
Call CONVERT(GDEVORI1,CPYCUR,[F:CPY]ACCCUR,[F:HREXS]TYPRAT,[F:HREXS]DATEXS,10^GDECRCU,RATCUR,STAT) From TRTDEV
If !STAT
 RATCUR = arr(RATCUR*10^-GDECRCU,10^-GDECRCU)
Endif
Call CONVERT(GDEVORI2,RPTCUR,[F:CPY]ACCCUR,[F:HREXS]TYPRAT,[F:HREXS]DATEXS,10^GDECRCU,RATRPT,STAT) From TRTDEV
If !STAT
 RATRPT = arr(RATRPT*10^-GDECRCU,10^-GDECRCU)
Endif

If [F:HREXS]CUR=CPYCUR
 [F:HREXS]RATCPY = 1
Else
 [F:HREXS]RATCPY = RATCUR
Endif
Case RPTCUR
 When [F:HREXS]CUR : [F:HREXS]RATRPT = 1
 When CPYCUR     : [F:HREXS]RATRPT = RATCUR
 When Default    : [F:HREXS]RATRPT = RATRPT
Endcase
Return

################################################################################################

$VERIF
Call LECTURE("EML",[F:HREXS]REFNUM,"") From CONTOBJ
If fstat
 # Matricule inexistant :
 Call TRACE(2,mess(83,10702,1)-":"-[F:HREXS]REFNUM) From SUBIMPOBJ
 OK=0 : Return
Endif

#MABOS-FQ89268-US1928
# controle du CTRNUM
Local Date DT
Local Char WMESS(250)
Local Integer J
[L]DT=[0/0/0]
Call SEARCH_CTR([F:HREXS]REFNUM, [F:HREXS]CTRNUM, [L]DT,[F:HREXS]DATEXS,  [F:HREXS]DATEXS, [L]WMESS) From DIVPAYE
If [L]WMESS<>"" Then
  Call TRACE(2,[L]WMESS) From SUBIMPOBJ
  OK=0
  Return
Endif
#end #MABOS-FQ89268-US1928- Modif pour multi-contrats

Call LECTURE("HRTES",[F:HREXS]CODEXP,[F:CPY]LEG) From CONTOBJ
If fstat
 # Code frais inexistant
 Call TRACE(2,mess(21,10718,1)-":"-[F:HREXS]CODEXP) From SUBIMPOBJ
 OK=0 : Return
Endif

## CCE
## fQ 105501
For I=0 To GOPTCANA-1
# [F:HREXS]CCE(I) = vireblc(GIMP(I+3),4)
  If [F:HREXS]DIE(I)="": [F:HREXS]CCE(I)="": Endif
  If [F:HREXS]DIE(I)<>""
    Call LECTURE("HRTES",[F:HREXS]CODEXP,[F:CPY]LEG) From CONTOBJ
    J=find([F:HREXS]DIE(I),[F:HRTES]DIE())
    If J
      If [F:HRTES]CCE(J-1)<>"" and [F:HREXS]CCE(I)=""
        [F:HREXS]CCE(I)=[F:HRTES]CCE(J-1)
      Endif
      If [F:HRTES]CCEDAC(J-1)=2 and [F:HREXS]CCE(I)=""
        CALL TRACE(2, mess(46,106,1)-[F:HREXS]DIE(I)) FROM SUBIMPOBJ : # Mandatory dimension on dimension type'
        OK=0: Break
      Endif
    Endif

    If [F:HREXS]CCE(I)<>""
#  Call LECTURE("CCE",[F:HREXS]CCE(I),num$(I)) From CONTOBJ
#  If fstat
#   # Section inexistante
#   Call TRACE(2,mess(35,106,1)-":"-GIMP(I+3)) From SUBIMPOBJ
#   OK=0 : Break
#  Endi


      Call LECTURE("CCE",[F:HREXS]CCE(I),[F:HREXS]DIE(I)) From CONTOBJ
      If fstat
        Call TRACE(2,mess(35,106,1)-":"-[F:HREXS]CCE(I))  From SUBIMPOBJ : # Nonexistent dimension value
        OK=0: Break
      Endif

      Call VERIF([F:CCE]FCY,[F:HREXS]FCY,[F:HREXS]CCE(I)) From CFYSUB
      If mkstat : OK=0: Break : Endif

      If dim([F:CCE]IPT)>0 & [F:CCE]IPT<>2
        Call TRACE(2,[F:HREXS]CCE(I)-mess(24,106,1)) From SUBIMPOBJ: # Dimension is not chargeable
        OK=0: Break
      Endif
    Endif
  Endif
Next
If OK=0 : Return : Endif




## Code TVA
If [F:HREXS]VAT = ""
 # Code TVA obligatoire :
 Call TRACE(2,mess(138,117,1)-":"-[F:HREXS]REFNUM) From SUBIMPOBJ  ## FQ 105501
 OK=0 : Return
Endif

##fq 105501
If !clalev([TVT]): Local File =GTABCPT+"TABVAT" : Endif
Call LEC_CPY([F:HREXS]CPY) From CPTLEC
Read [TVT]TVT0 = [F:HREXS]VAT;[F:CPY]LEG
If fstat
   Read [TVT]TVT0 = [F:HREXS]VAT;""
   If fstat
      Call TRACE(2,mess(37,119,1)-":"-[F:HREXS]VAT) From SUBIMPOBJ  ## FQ 105501
      OK=0 : Return
   Endif
Endif


## FQ 105501


If GIMP(8)<>""
 Filter [ADU] Where PARAM="REFNUM" & VALEUR=GIMP(8)
 Read [ADU]ADU1 First
 Filter [ADU]
 If !fstat
  [F:HREXS]STAFLG = [F:ADU]CODUSR
 Else
  # Le matricule visant les frais ne fait pas référence à un utilisateur
  Call TRACE(2,mess(22,10718,1)-":"-GIMP(8)) From SUBIMPOBJ
  OK=0 : Return
 Endif
Endif
Return

