Subprog LOAD_ACTIONS(ASWACTIONS)
Variable Instance ASWACTIONS(1..) Using C_ASWACTION
Local Integer I
Gosub DEF_INTIT_LNK
Gosub LNK_RESERVED From SUBASW
#115007/1 For I=1 To 19
For I=1 To 22
    ASWACTIONS(I) = NewInstance C_ASWACTION AllocGroup ASWACTIONS
    ASWACTIONS(I).COD = I
    ASWACTIONS(I).CODMES = mess(I,7971,1)
    Case I
    When 1  : # Créer une fiche
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(1)
      ASWACTIONS(I).INTLNK=[L]INTCRE
      ASWACTIONS(I).LNKTAR="$edit"
      ASWACTIONS(I).PROLNK="$create"
      ASWACTIONS(I).ORDLNK=150
      ASWACTIONS(I).SAV=2
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET="POST"
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET=""
    When 2  : # Afficher détail
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(2)
      ASWACTIONS(I).INTLNK=[L]INTDET
      ASWACTIONS(I).LNKTAR="$details"
      ASWACTIONS(I).PROLNK="$details"
      ASWACTIONS(I).ORDLNK=200
      ASWACTIONS(I).SAV=2
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET=""
    When 3  : # Modifier une fiche
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(3)
      ASWACTIONS(I).INTLNK=[L]INTMOD
      ASWACTIONS(I).LNKTAR="$edit"
      ASWACTIONS(I).PROLNK="$edit"
      ASWACTIONS(I).ORDLNK=250
      ASWACTIONS(I).SAV=2
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET="POST"
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET=""
    When 4  : # Supprimer une fiche
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(4)
      ASWACTIONS(I).INTLNK=[L]INTSUP
      ASWACTIONS(I).LNKTAR="$query"
      ASWACTIONS(I).PROLNK="$delete"
      ASWACTIONS(I).ORDLNK=350
      ASWACTIONS(I).SAV=2
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET="DELETE"
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET=""
    When 5  : # Afficher liste
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(5)
      ASWACTIONS(I).INTLNK=[L]INTLIST
      ASWACTIONS(I).LNKTAR="$query"
      ASWACTIONS(I).PROLNK="$query"
      ASWACTIONS(I).ORDLNK=500
      ASWACTIONS(I).SAV=2
      ASWACTIONS(I).DEL=2
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET=""
    When 6  : # Dupliquer une fiche
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(14)
      ASWACTIONS(I).INTLNK=[L]INTDUP
      ASWACTIONS(I).LNKTAR="$edit"
      ASWACTIONS(I).PROLNK="$duplicate"
      ASWACTIONS(I).ORDLNK=300
      ASWACTIONS(I).SAV=2
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET="POST"
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET=""
    When 7  : # Afficher dans Excel
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(9)
      ASWACTIONS(I).INTLNK=[L]INTEXL
      ASWACTIONS(I).LNKTAR="$details"
      ASWACTIONS(I).PROLNK="$excel"
      ASWACTIONS(I).ORDLNK=600
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/syracuse-excel-worksheet"
      ASWACTIONS(I).TARGET="Excel"
    When 8  : # Lister dans Excel
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(9)
      ASWACTIONS(I).INTLNK=[L]INTEXL
      ASWACTIONS(I).LNKTAR="$query"
      ASWACTIONS(I).PROLNK="$excel"
      ASWACTIONS(I).ORDLNK=650
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/syracuse-excel-worksheet"
      ASWACTIONS(I).TARGET="Excel"
    When 9  : # Sélection
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(6)
      ASWACTIONS(I).INTLNK=[L]INTSEL
      ASWACTIONS(I).LNKTAR="$lookup"
      ASWACTIONS(I).PROLNK="$lookup"
      ASWACTIONS(I).ORDLNK=400
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET="popup"
    When 10 : # Afficher résumé
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(7)
      ASWACTIONS(I).INTLNK=[L]INTSUM
      ASWACTIONS(I).LNKTAR="$summary"
      ASWACTIONS(I).PROLNK="$summary"
      ASWACTIONS(I).ORDLNK=450
      ASWACTIONS(I).SAV=2
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/json;vnd.sage=syracuse"
      ASWACTIONS(I).TARGET="popup"
    When 11 : # Afficher en PDF
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(8)
      ASWACTIONS(I).INTLNK=[L]INTPRINT
      ASWACTIONS(I).LNKTAR="$details"
      ASWACTIONS(I).PROLNK="$print"
      ASWACTIONS(I).ORDLNK=700
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/pdf"
      ASWACTIONS(I).TARGET="blank"
    When 12 : # Lister en PDF
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(8)
      ASWACTIONS(I).INTLNK=[L]INTPRINT
      ASWACTIONS(I).LNKTAR="$query"
      ASWACTIONS(I).PROLNK="$print"
      ASWACTIONS(I).ORDLNK=750
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/pdf"
      ASWACTIONS(I).TARGET="blank"
    When 13 : # Afficher dans Word
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(10)
      ASWACTIONS(I).INTLNK=[L]INTWORD
      ASWACTIONS(I).LNKTAR="$details"
      ASWACTIONS(I).PROLNK="$wordreport"
      ASWACTIONS(I).ORDLNK=800
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/syracuse-word-report"
      ASWACTIONS(I).TARGET="Word"
    When 14 : # Lister dans Word
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(10)
      ASWACTIONS(I).INTLNK=[L]INTWORD
      ASWACTIONS(I).LNKTAR="$query"
      ASWACTIONS(I).PROLNK="$wordreport"
      ASWACTIONS(I).ORDLNK=850
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/syracuse-word-report"
      ASWACTIONS(I).TARGET="Word"
    When 15 : # Publiposter fiche
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(11)
      ASWACTIONS(I).INTLNK=[L]INTMAIL
      ASWACTIONS(I).LNKTAR="$query"
      ASWACTIONS(I).PROLNK="$wordmailmerge"
      ASWACTIONS(I).ORDLNK=900
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/syracuse-word-mailmerge"
      ASWACTIONS(I).TARGET="Wordmailmerge"
    When 16 : # Publiposter liste
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(11)
      ASWACTIONS(I).INTLNK=[L]INTMAIL
      ASWACTIONS(I).LNKTAR="$query"
      ASWACTIONS(I).PROLNK="$wordmailmerge"
      ASWACTIONS(I).ORDLNK=950
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="application/syracuse-word-mailmerge"
      ASWACTIONS(I).TARGET="Wordmailmerge"
    When 17 : # Enregistrer
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(13)
      ASWACTIONS(I).INTLNK=[L]INTSAV
      ASWACTIONS(I).LNKTAR=""
      ASWACTIONS(I).PROLNK="$save"
      ASWACTIONS(I).ORDLNK=50
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA=""
      ASWACTIONS(I).TARGET=""
    When 18 : # Abandon
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(12)
      ASWACTIONS(I).INTLNK=[L]INTAB
      ASWACTIONS(I).LNKTAR=""
      ASWACTIONS(I).PROLNK="$abort"
      ASWACTIONS(I).ORDLNK=100
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA=""
      ASWACTIONS(I).TARGET=""
    When 19 : # Gestion LOB
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(15)
      ASWACTIONS(I).INTLNK=[L]INTLOB
      ASWACTIONS(I).LNKTAR=""
      ASWACTIONS(I).PROLNK=""
      ASWACTIONS(I).ORDLNK=100
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA=""
      ASWACTIONS(I).TARGET=""
    When 22 : # Aide 115007/1
      ASWACTIONS(I).CODLNK=CODLNK_RESERVED(16)
      ASWACTIONS(I).INTLNK=[L]INTHELP
      ASWACTIONS(I).LNKTAR="help"
      ASWACTIONS(I).PROLNK="$help"
      ASWACTIONS(I).ORDLNK=550
      ASWACTIONS(I).SAV=1
      ASWACTIONS(I).DEL=1
      ASWACTIONS(I).MET=""
      ASWACTIONS(I).MEDIA="text/html"
      ASWACTIONS(I).TARGET=""
    Endcase
    ASWACTIONS(I).INTITLNK=func ASYRFNC.TEXTE(ASWACTIONS(I).INTLNK)
Next I
End

#-------------------------------------------------------------------#
# Properties synchronization
#-------------------------------------------------------------------#
Subprog TRTMAJ_FILTER_ASWFLD(PDOSSIER,PVALDIF,DEBASW,FINASW)
Value Char PDOSSIER
Value Integer PVALDIF
Value Char DEBASW,FINASW
Gosub _TRTMAJ_ALL_ASWFLD
End

#-------------------------------------------------------------------#
Subprog TRTMAJ_ALL_ASWFLD(PDOSSIER,PVALDIF)
Value Char PDOSSIER
Value Integer PVALDIF
Local Char DEBASW(GLONASW),FINASW(GLONASW)
Gosub _TRTMAJ_ALL_ASWFLD
End

#################################################################################################
$_TRTMAJ_ALL_ASWFLD
Local Integer ERR,SAVGVALID,INTERRUPT,COUNT,N
Local Char CRITERE(250)

#Validation différée (à la volée)
[L]SAVGVALID=GVALIDDIFF
If [L]PVALDIF=2
  GVALIDDIFF=3
Else
  GVALIDDIFF=1
Endif

If GTRACE<>"" & ([L]DEBASW="" | [L]FINASW="")
 Call ECR_TIME(mess(277,143,1)-"-"-mess(3,23,1)-[L]PDOSSIER) From DOSSUB
Endif

Local File =[L]PDOSSIER+".ASHW" [ASWZ]

DEBDEB = DEBASW
FINFIN = FINASW
If FINFIN="" : FINFIN = "ZZZZZZZZZZ" : Endif

Raz [L]CRITERE
If [L]DEBASW<>""
 [L]CRITERE = 'CODREP>="'+[L]DEBASW+'"'
Endif
If [L]FINASW<>""
 If [L]CRITERE<>"" : [L]CRITERE -= '&' : Endif
 [L]CRITERE -= 'CODREP<="'+[L]FINASW+'"'
Endif
If CRITERE<>""
 Filter [ASWZ] Where evalue([L]CRITERE)
Endif
COUNT=rowcount([F:ASWZ])

If !GSERVEUR
 Call OUVRE_BOITE(mess(277,143,1),COUNT) From GESECRAN
Endif
N=0
For [ASWZ]
  If !GSERVEUR
   Call AFF_BOITE(mess(23,140,1)-[F:ASWZ]CODREP,N,INTERRUPT) From GESECRAN
  Endif
  If GTRACE<>"" & ([L]DEBASW<>"" | [L]FINASW<>"")
    Call ECR_TRACE(mess(291,123,1)-':'-mess(23,140,1)-[F:ASWZ]CODREP,0) From GESECRAN
  Endif
  Call _TRTMAJ_ASWFLD(0,1,[L]PDOSSIER,[F:ASWZ]CODREP,ERR)
  N+=1
Next

Filter [ASWZ]
If !GSERVEUR
 Call FERME_BOITE From GESECRAN
Endif

GVALIDDIFF=[L]SAVGVALID

Return

#----------------------------------------------------------#
Subprog _TRTMAJ_ASWFLD(TEST,SILENCE,DOSSIER,CODREP,ERR)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODREP
Variable    Integer  ERR

Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer OK, ISASWLOCK : [L]ISASWLOCK=1
Gosub OPEN_FILE  From ASHWVALLEC

If TEST : Call ECR_TRACE("-"-mess(23,140,1)-[L]CODREP,0) From GESECRAN : Endif

If [L]DOSSIER=nomap
 Lock ="ASW"+[L]CODREP With lockwait=0
Else
 Lock ="ASW"+[L]CODREP From =[L]DOSSIER With lockwait=0
Endif
If fstat
 [L]ISASWLOCK=0
 If GTRACE<>""
  Call ECR_TRACE([L]CODREP-mess(10,100,1)-":"-mess(258,143,1),-1) From GESECRAN
 Endif
 Goto FIN_TRTMAJ_ASWFLD
Else
 [L]ISASWLOCK=1
Endif

Read [ASW]ASW0=[L]CODREP
If fstat
 If GTRACE<>"" : Call ECR_TRACE([L]CODREP-mess(15,140,1),1) From GESECRAN : Endif
 Goto FIN_TRTMAJ_ASWFLD
Endif

If filinfo(filpath("ECR","ASHW0","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ASHW0",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ASHW0",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ASHW0",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif
If filinfo(filpath("ECR","ASHW1","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ASHW1",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ASHW1",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ASHW1",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif
If filinfo(filpath("ECR","ASHW9","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ASHW9",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ASHW9",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ASHW9",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif
If filinfo(filpath("ECR","ASHW5","msk",DOSSIER),7)<=0
  If dim(GACTX.LAN)>0 & GACTX.LAN<>""
  Call VALIDDIRECT ("ASHW5",DOSSIER,1,GACTX.LAN,1,OK) From VALMSK
  Elsif dim(GLANGUE)>0 & GLANGUE<>""
  Call VALIDDIRECT ("ASHW5",DOSSIER,1,GLANGUE,1,OK) From VALMSK
  Else
  Call VALIDDIRECT ("ASHW5",DOSSIER,1,"FRA",1,OK) From VALMSK
  Endif
Endif

Local Mask =[L]DOSSIER+".ASHW0" [ASW0]
Local Mask =[L]DOSSIER+".ASHW1" [ASW1]
Local Mask =[L]DOSSIER+".ASHW9" [ASW9]
Local Mask =[L]DOSSIER+".ASHW5" [ASW5]
Local Integer I,MAJPRO,MAJPAR,MAJASWF,EXISTINVLNK
Raz [M:ASW0]
Raz [M:ASW1]
Raz [M:ASW9]
Raz [M:ASW5]

#Mise a jour des param + write/rewrite des parametres
[M:ASW0]=[F:ASW]
[M:ASW1]=[F:ASW]

ERR=0
Onerrgo ERR_TRTMAJ_ASWFLD
Trbegin [ASWP],[ASWR]

#98369
If DOSSIER<>GDOSX3
 For [ASWF]ASWF1 Where CODREP=[M:ASW0]CODREP & ACTFLD<>""
  Read [ACV]CODACT=[F:ASWF]ACTFLD
  If fstat or [F:ACV]FLACT<>2
   MAJASWF=1
   Delete [ASWP] Where CODREP=[F:ASWF]CODREP & (TYPPAR=1 | TYPPAR=2) & CODFLD=[F:ASWF]CODFLD
   Delete [ASWF]
  Endif
 Next
Endif

If !ERR
Gosub LOAD_ASWF
Endif

If !ERR
MAJPAR=find(2,[M:ASW5]STDNEW(0..[M:ASW5]NBRPAR-1))
If TEST : Call ECR_TRACE("              MAJPAR  :"-num$([L]MAJPAR),0) From GESECRAN : Endif
If !ERR & MAJPAR & [L]ISASWLOCK=1
 Gosub SAVE_ASWF
Endif
Endif

If !ERR
 For [ASWR]ASWR0 Where CODREP=[L]CODREP
  If DOSSIER<>GDOSX3 & func OK_DECODEPRO(DOSSIER,[F:ASW]CODREP,[F:ASW]ABRCLA,[F:ASW]CODCLA,[F:ASWR]CODPRO)=0
   MAJPRO=1
   Delete [ASWR]
  Endif
 Next
Endif

If ERR | [L]ISASWLOCK<>1 | (MAJPAR=0 & MAJPRO=0 & MAJASWF=0)
Rollback
Else
Commit
Endif

If !ERR & (MAJPAR | MAJPRO | MAJASWF) & [L]ISASWLOCK<>1
  If GTRACE<>""
   Call ECR_TRACE([L]CODREP-mess(10,100,1)-":"-mess(258,143,1),-1) From GESECRAN
  Endif
Elsif !ERR & (MAJPAR | MAJPRO |MAJASWF)
  If GTRACE<>""
    Call ECR_TRACE("-"-mess(23,140,1)-[L]CODREP,0) From GESECRAN
  Endif
  If MAJASWF
    Call ECR_TRACE(mess(281,143,1),0) From GESECRAN
  Endif
  If MAJPAR
    Call ECR_TRACE(mess(208,143,1),0) From GESECRAN
  Endif
  If MAJPRO
    Call ECR_TRACE(mess(280,143,1),0) From GESECRAN
  Endif
  Call VALIDATION(0,[L]DOSSIER,[L]CODREP) From SUBASW
  If nomap=[L]DOSSIER : Call TRACE_COR("ASW", [L]CODREP,"","m") From GOBJET :  Endif : # X3PLAT-2115
Endif

Onerrgo

Close Local Mask

$FIN_TRTMAJ_ASWFLD
If [L]DOSSIER=nomap
 Unlock ="ASW"+[L]CODREP With lockwait=0
Else
 Unlock ="ASW"+[L]CODREP From =[L]DOSSIER With lockwait=0
Endif
Gosub CLOSE_FILE From ASHWVALLEC
If TEST : Call ECR_TRACE("              ERR  :"-num$([L]ERR),0) From GESECRAN : Endif
nolign=SAVNOLIGN
End

$ERR_TRTMAJ_ASWFLD
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
ERR=1
Resume

#------------------------------#
$LOAD_ASWF
Local Integer I,J,K,L,M,N
Local Integer SAVNOLIGN : SAVNOLIGN=nolign

# Champ rep
nolign = 0 : I=0
For [ASWF]ASWF1 Where CODREP=[M:ASW0]CODREP
 nolign += 1
 [M:ASW9] = [F:ASWF]
# Call TEXTE([F:ASWF]INTFLD,[M:ASW9]AZINTFLD(nolign-1)) From OBJDIV
# Call TEXTE([F:ASWF]INTSHTFLD,[M:ASW9]AZINTSHTFLD(nolign-1)) From OBJDIV
## Call TEXTE([F:ASWF]INFBUL,[M:ASW9]INTITBUL(nolign-1)) From OBJDIV
 Read [ATY]CODTYP = [F:ASWF]CODTYP
 If !fstat & [F:ATY]TYPSELSYR=2
  [M:ASW9]FLDCUR = [ASWF]CODFLD
  If [ASWF]LOBTAB=""
   [M:ASW9]CODTYPCUR = [ASWF]CODTYP
  Else
   [M:ASW9]CODTYPCUR  = [ASWF]CODTYP + "." + [ASWF]LOBTAB + "." + [ASWF]LOBFLD
  Endif
  For [ASWP]ASWP0 Where CODREP=[M:ASW0]CODREP & TYPPAR=2 & TYPKEY=1 & CODFLD=[F:ASWF]CODFLD
   J=[M:ASW5]NBRPAR
   [M:ASW5]NBRPAR  +=1
   [M:ASW5]STDNEW(J)    = 1
   [M:ASW5]CODTYP(J)    = [F:ASWF]CODTYP
   [M:ASW5]CODPAR(J)    = [F:ASWP]CODPAR
   [M:ASW5]TYPPAR(J)    = [F:ASWP]TYPPAR
   [M:ASW5]CODFLD(J)    = [F:ASWP]CODFLD
   [M:ASW5]CODLNK(J)    = [F:ASWP]CODLNK
   [M:ASW5]AFFLNK(J)    = [F:ASWP]AFFLNK
   [M:ASW5]TYPKEY(J)    = [F:ASWP]TYPKEY
   [M:ASW5]VALEUR(J)    = [F:ASWP]VALEUR
   [M:ASW5]NUMPAR(J)    = [F:ASWP]NUMPAR
   [M:ASW5]TYPINTPAR(J) = [F:ASWP]TYPINT
   [M:ASW5]IDENT2(J)=func SUBASW_TOOL.BUILD_ASW5_IDENT2([M:ASW5]TYPPAR(J),[M:ASW5]AFFLNK(J),[M:ASW5]TYPKEY(J),[M:ASW5]CODLNK(J),[M:ASW5]CODFLD(J),[M:ASW5]CODPAR(J))
  Next
  Call L_LOAD_PARAM_ATY(nomap, [M:ASW0]CODREP, [F:ATY]CODTYP, [ASW9]FLDCUR, 1, 1) From SUBASW2
  If [ATY]CODCLA<>""
   Gosub L_LOAD_KEY From SUBASW2
  Endif
  #109594
  J=0
  For I=0 To [M:ASW5]NBRPAR-1
   If [M:ASW5]CODFLD(I)=[M:ASW9]FLDCUR & [M:ASW5]TYPKEY(I)=2 & [M:ASW5]CODTYP(I)=[M:ASW9]CODTYPCUR
    J+=1
    K=I
   Endif
  Next
  If J=1 & [M:ASW5]VALEUR(K)=""
   [M:ASW5]VALEUR(K) = [M:ASW9]FLDGRP(nolign-1)+string$([M:ASW9]FLDGRP(nolign-1)<>"",".")+[M:ASW9]FLDCUR
#    [M:ASW9]VALCLE(0) = [M:ASW5]VALEUR(K)
#    Affzo [M:ASW9]VALCLE(0)
  Endif
  #
  If [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
   Gosub L_LOAD_MEDIA From SUBASW2
  Endif
  [M:ASW9]FLDCUR = ""
  [M:ASW9]CODTYPCUR = ""
 Endif
Next ASF
[M:ASW9]NBRFLD = nolign

nolign=SAVNOLIGN
#Call AS_NBRFLD From SUBASW2
Return


$SAVE_ASWF
Local Integer I,J,K,L,M,N
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Integer NOLPAR,J,WCPT
Local Integer OKLIS
# Champs rep
For J=0 To [M:ASW9]NBRFLD-1
  Raz [F:ASWF]
  nolign=J+1
  [F:ASWF] = [M:ASW9]
  [F:ASWF]CODREP = [M:ASW0]CODREP
#  Write [ASWF]
#  If fstat
#   GOK = 0 : Call FSTA("ASWF") From GLOCK : Break
#  Endif
  [L]WCPT=0
  [L]OKLIS=0
  Read [ATY]CODTYP=[F:ASWF]CODTYP
  If !fstat & [F:ATY]TYPSELSYR=2
   If !fstat & [F:ATY]TYPPROSYR<>""
    Read [ATYP]ATYP0=[F:ATY]TYPPROSYR
    If !fstat & [F:ATYP]LISFLG=2
     [L]OKLIS=1
    Endif
   Endif
   ####
   Delete [ASWP] Where CODREP=[F:ASWF]CODREP & TYPPAR=1 & CODFLD=[F:ASWF]CODFLD
   Delete [ASWP] Where CODREP=[F:ASWF]CODREP & TYPPAR=2 & CODFLD=[F:ASWF]CODFLD
   ####
   For NOLPAR=0 To [M:ASW5]NBRPAR-1
    If [M:ASW5]TYPPAR(NOLPAR)=1 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(NOLPAR) & [M:ASW5]ISKEY(NOLPAR)<>2
     Raz [F:ASWP]
     [L]WCPT+=1
     nolign=NOLPAR+1
     [F:ASWP]       = [M:ASW5]
     [F:ASWP]CODREP = [M:ASW0]CODREP
     [F:ASWP]NUMPAR = [L]WCPT
     [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(NOLPAR)
     If [F:ASWP]PARENT=0 : [F:ASWP]PARENT=1 : Endif
     If [F:ASWP]PARFIL=0 : [F:ASWP]PARFIL=1 : Endif
     Write [F:ASWP]
     If fstat
      GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
     Endif
    Elsif [L]OKLIS & [M:ASW5]TYPPAR(NOLPAR)=2 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(NOLPAR) & [M:ASW5]CODTYP(NOLPAR)=[F:ASWF]CODTYP
     Raz [F:ASWP]
     nolign=NOLPAR+1
     [F:ASWP]       = [M:ASW5]
     [F:ASWP]CODREP = [M:ASW0]CODREP
     [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(NOLPAR)
     Write [F:ASWP]
     If fstat
      GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
     Endif
    Endif
   Next
   For NOLPAR=0 To [M:ASW5]NBRPAR-1
    If [M:ASW5]TYPPAR(NOLPAR)=1 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(NOLPAR) & [M:ASW5]ISKEY(NOLPAR)=2
     Raz N
     For M=0 To [M:ASW5]NBRPAR-1
      If [M:ASW5]TYPPAR(M)=1 & [F:ASWF]CODFLD=[M:ASW5]CODFLD(M) & [M:ASW5]TYPKEY(M)=2
&     &  [M:ASW5]CODPAR(NOLPAR) = [M:ASW5]CODPAR(M)
       N = M
      Endif
     Next
     If N>0
      Raz [F:ASWP]
      [L]WCPT+=1
      nolign=N+1
      [F:ASWP]       = [M:ASW5]
      [F:ASWP]CODREP = [M:ASW0]CODREP
      [F:ASWP]TYPKEY = 1
      [F:ASWP]NUMPAR = [L]WCPT
      [F:ASWP]TYPINT = [M:ASW5]TYPINTPAR(N)
      If [F:ASWP]PARENT=0 : [F:ASWP]PARENT=1 : Endif
      If [F:ASWP]PARFIL=0 : [F:ASWP]PARFIL=1 : Endif
      Write [F:ASWP]
      If fstat
       GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
      Endif
     Endif
    Endif
   Next
  Endif
Next nolign
nolign=SAVNOLIGN
Return

Funprog OK_DECODEPRO(DOSSIER,CODREP,ABRCLA,CODCLA,CODPRO)
Value Char DOSSIER,CODREP,ABRCLA,CODCLA,CODPRO

 Local File =[L]DOSSIER+".ACLAFLD"      [ACLAF]
 Local File =[L]DOSSIER+".ASHW"         [ASW]
 Local File =[L]DOSSIER+".ASHWFLD"      [ASWF]
 Local File =[L]DOSSIER+".ACLASSE"      [ACLA]
 Local File =[L]DOSSIER+".ACLACOL"      [ACLAC]

 Local File =[L]DOSSIER+".ACONTEXT"     [ACTX]
 Local File =[L]DOSSIER+".ACONTEXT"     [ACTX2]

 Local Char TABCLA(80)(1..50),TABPTR(80)(1..50),PRO(50)
 Local Integer NBCLA,ISACTX
 Local Integer OK : OK=0

 Call DECODE_PRO([L]CODPRO,0,"PRO",[L]DOSSIER,[L]CODREP,[L]ABRCLA,[L]CODCLA,TABPTR,TABCLA,PRO,ISACTX,NBCLA) From SUBASW
 If NBCLA>0
  If TABCLA(NBCLA)=""
   If !ISACTX
    Read [ASWF]ASWF0 = [L]CODREP;PRO
    If !fstat
     [L]OK=1 : Goto FIN_OK_DECODEPRO
     End 1
    Endif
   Else
    Read [F:ACTX]ACTX0 = PRO
    If !fstat
     [L]OK=1 : Goto FIN_OK_DECODEPRO
    Endif
   Endif
  Else
   Read [ACLAF]ACLAF0 = TABCLA(NBCLA);PRO
   If !fstat
    [L]OK=1 : Goto FIN_OK_DECODEPRO
   Endif
  Endif
 Endif
$FIN_OK_DECODEPRO
LogicClose File [ACLAF],[ASW],[ASWF],[ACLA],[ACLAC]
LogicClose File [ACTX],[ACTX2]
End [L]OK

#-------------------------------------------------------------------#
# Links synchronization
#-------------------------------------------------------------------#
Subprog TRTMAJ_FILTER_ASWLNK(DOSSIER,PVALDIF,DEBASW,FINASW)
Value Char DOSSIER
Value Integer PVALDIF
Value Char DEBASW,FINASW
Gosub _TRTMAJ_ALL_ASWLNK From SUBASWLNK
End

#-------------------------------------------------------------------#
Subprog TRTMAJ_ALL_ASWLNK(DOSSIER,PVALDIF)
Value Char DOSSIER
Value Integer PVALDIF
Local Char DEBASW(GLONASW),FINASW(GLONASW)
Gosub _TRTMAJ_ALL_ASWLNK From SUBASWLNK
End

