#<AdxTL>@(#)0.0.0.0 $Revision$
# Here group all the utility functions used for GESASW
######################################################################################



#-------- SUBASW2.C_VALEUR/C_VALCLE/C_VALPARLNK/C_VALCLELNK/ SUBASW$VERIF_CRE/ ASHWCONTROL.VERIF_VALID_REP internal use only --------#
Funprog L_CHECK_PARAMETER(FLD,FLDTYP,PARCOD,PARACT,PARVAL, PARTYP, PARMOD, PARCOL, REPCOD, MODE, IS_LINK,CMPLNK,LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM, EMPTY_ALLOWED, ERROR_MSG)
Value Char FLD,FLDTYP,PARCOD,PARACT
Variable Char    PARVAL()
Value Integer PARTYP, PARMOD
Value Char PARCOL
Value Char REPCOD
Value Integer MODE # 1: check on using the data from screen;    2: check on using the data from table
Value Integer IS_LINK # 0: if it's parameter for property;   1: if it's parameter for link
Value Integer CMPLNK
Value Integer LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM : #facette of the link
Value Integer EMPTY_ALLOWED # 2: empty allowed; else: cannot be empty
Variable Char ERROR_MSG
Local Integer RES_OK

# Local File ATYPE   [ATY]
# Local File ACLASSE [ACLA]
# Local File ACLACOL [ACLAC]
# Local File ACLAFLD [ACLAF]
# Local File ASHWFLD [ASWF]
# Local File ASHWCOL [ASWC]
# Local File ASHW    [ASW]
# Local File ASHWEXPPRO [ASWR2]

 Local Char VALEUR(255), T_CLACOD(100), L_VAL(250), T_VAL(250), T_CHAINE(250), T_COLCOD(GLONAVC), T_DIM(250), L_AVOID_COD(250) #DIM , L_VAL_WITHOUT_DIM(250)
 Local Integer I,INDEX_DOT, INDEX_DOT_STD, INDEX_DIM, T_COLDIM, L_AVOID_TYP
 Local Integer FLG_FINISH # flag to indicate if the analyse of path is reaching the end(the section after the last ".")
 Local Integer FLG_OK # flag to indicate if the interpretation of path is going well
 Local Integer FLG_MOD_PROPERTY # flag to indicate if user is tring to enter a proprety (instead of a constante)
 Local Integer FLG_ENTER_CLASS # flag to indicate if the property should be found in the class linked to the representation.
 Local Integer FLG_MOD_DIM # flag to indicate if an index (n) is found in the path
 Local Integer FLG_IS_NUM # flag to indicate if using a formula =num$(...)
 Local Integer FLG_IS_VAL # flag to indicate if using a formula =val(...)
 Local Integer L_NOASW4,L_OLDNOASW4,L_BASW4

 RES_OK = 1
 FLG_OK = 1
 [L]VALEUR = PARVAL # c la
 T_CLACOD = REPCOD
 Raz ERROR_MSG

 If MODE <> 1 and MODE <> 2
  RES_OK = 0 : End RES_OK
 Endif

 # 0 : check not empty
 If PARCOD="AFILTER" & PARTYP=7 & (PARVAL = "" | PARVAL='""')
  End RES_OK
 Elsif PARVAL = ""
  If EMPTY_ALLOWED = 2
   RES_OK = 1 : End RES_OK
  Else
   ERROR_MSG = mess(10,123,1) : #ZONE OBLIGATOIRE
   RES_OK = 0 : End RES_OK
  Endif
 Endif

 # 1.1 : in case Class itself : THIS : check if type parameter is Class
 If toupper(PARVAL) = "THIS"
  If PARTYP <> 13
   ERROR_MSG = mess(128,143,1) # Type de propriété incompatible.
   RES_OK = 0 : End RES_OK
  Else
   PARVAL = "this"
   End RES_OK
  Endif
 Endif

 # 1.2 : check AVOID
 If toupper(left$(PARVAL,6)) = CST_INSTANCE_AISNULL_NAME+"." # "AVOID."
  L_AVOID_COD = right$(PARVAL, 7)
  If L_AVOID_COD = "" or !func SUBACLA2.CHECK_AVOID_CODE_EXIST(L_AVOID_COD)
   ERROR_MSG = mess(126,143,1) # Valeur invalide.
   RES_OK = 0 : End RES_OK
  Else
   L_AVOID_TYP = func SUBACLA2.GET_AVOID_CODE_TYPE(L_AVOID_COD)
   If L_AVOID_TYP > 0 and L_AVOID_TYP<>PARTYP : # j'ai inversé
    ERROR_MSG = mess(155,143,1) # Type incompatible.
    RES_OK = 0 : End RES_OK
   Else
    PARVAL = toupper(PARVAL) : RES_OK = 1 : End RES_OK
   Endif
  Endif
 Endif

 # 2.1: check formula =num$()
 If left$([L]VALEUR,6) = "=num$(" and seg$([L]VALEUR,len([L]VALEUR),len([L]VALEUR)) = ")"
  If PARMOD = 1
   ERROR_MSG = mess(152,143,1) # Formule non applicable.
   RES_OK = 0 : End RES_OK
  Elsif PARTYP <> 7
   ERROR_MSG = mess(149,143,1) # Type incompatible.
   RES_OK = 0 : End RES_OK
  Else
   FLG_MOD_PROPERTY = 1
   FLG_IS_NUM = 1
   [L]VALEUR = seg$([L]VALEUR,7,len([L]VALEUR)-1)
  Endif
 Endif

 # 2.2: check formula =val()
 If left$([L]VALEUR,5) = "=val(" and seg$([L]VALEUR,len([L]VALEUR),len([L]VALEUR)) = ")"
  If PARMOD = 1
   ERROR_MSG = mess(152,143,1) # Formule non applicable.
   RES_OK = 0 : End RES_OK
  Elsif !find(PARTYP, 1,2,3,4,5,6)
   ERROR_MSG = mess(149,143,1) # Type incompatible.
   RES_OK = 0 : End RES_OK
  Else
   FLG_MOD_PROPERTY = 1
   FLG_IS_VAL = 1
   [L]VALEUR = seg$([L]VALEUR,6,len([L]VALEUR)-1)
  Endif
 Endif

 # 2.3 : check "this."
 If toupper(left$([L]VALEUR,5)) = "THIS."
  If MODE = 1
   [L]VALEUR = right$([L]VALEUR,6)
   FLG_MOD_PROPERTY = 1
  Else
   ERROR_MSG = mess(154,143,1) # "this." non nécessaire à la saisie du paramètre.
   RES_OK = 0 : End RES_OK
  Endif
 Endif

 # 3: in case Property code : check the property type
 L_VAL = [L]VALEUR
 T_VAL = L_VAL
 # analyse the value of format:  AAA.BBB.CCC.DDD...
 While FLG_OK and !FLG_FINISH

  If T_VAL = ""
   FLG_OK = 0
   If FLG_MOD_PROPERTY
    ERROR_MSG = mess(126,143,1) # Valeur invalide.
   Endif
  Else

  INDEX_DOT = instr(1,T_VAL,".")
  INDEX_DOT_STD += INDEX_DOT
  FLG_MOD_DIM = 0
  # 3.1 there's no more "."
  If INDEX_DOT = 0
   FLG_FINISH = 1
   # 3.1.1 it's ACTX
   If toupper(T_VAL) = "ACTX"
    FLG_MOD_PROPERTY = 1
    If T_COLCOD <> "" # and T_COLDIM = 0
     ERROR_MSG = mess(126,143,1)-T_COLCOD+".ACTX" # Valeur invalide.
#    ERROR_MSG = func AFNC.MES1(mess(142,143,1),T_COLCOD) # Manque d'indice pour la collection "$1$"
     FLG_OK = 0
    Elsif PARTYP <> 13
     ERROR_MSG = mess(128,143,1) # Type de propriété incompatible.
     FLG_OK = 0
    Endif

   Else

    # 3.1.2 dimension check
    If seg$(T_VAL,len(T_VAL),len(T_VAL)) = ")"
     FLG_OK = 0
     INDEX_DIM = instr(1,T_VAL,"(")
     If INDEX_DIM>0
      T_DIM = seg$(T_VAL,INDEX_DIM+1, len(T_VAL)-1)
      If num$(val(T_DIM))= T_DIM and val(T_DIM)>0
       If FLG_MOD_PROPERTY
        ERROR_MSG = mess(143,143,1)-":"-T_VAL # Mauvais utilisation d'indice
       Else
        FLG_MOD_PROPERTY = 1
        ERROR_MSG = mess(126,143,1) # Valeur invalide.
       Endif
      Else
       If FLG_MOD_PROPERTY
        ERROR_MSG = mess(126,143,1)-":"-T_VAL # Valeur invalide.
       Endif
      Endif
     Else
      If FLG_MOD_PROPERTY
       ERROR_MSG = mess(126,143,1) # Valeur invalide.
      Endif
     Endif
    Endif

    If FLG_OK
     # 3.1.3 it's a property of current representation
     If T_CLACOD = REPCOD and !FLG_ENTER_CLASS
      Case MODE
       When 1:
        Gosub L_CHECK_PROPERTY_SCREEN
       When 2:
        Gosub L_CHECK_PROPERTY_DB
      Endcase
     # 3.1.4 it's a property of child class
     Else
      Gosub L_CHECK_INSTANCE_PROPERTY_DB
     Endif
    Endif
   Endif

   # 3.1.5 in case of link, need to check if the property is exposed
   If FLG_OK & IS_LINK & (left$(toupper(L_VAL),5)<>"ACTX." | [L]CMPLNK<>19)
    #DIM L_VAL_WITHOUT_DIM = func L_REMOVE_DIM(L_VAL)
    Case MODE
     When 1:
      L_BASW4=0
      #DIM If !find(toupper(L_VAL_WITHOUT_DIM), [M:ASW4]CODPRO)
      L_OLDNOASW4=0
      L_NOASW4=find(toupper(L_VAL), [M:ASW4]CODPRO(L_OLDNOASW4..[M:ASW4]NBRPRO-1))
      While L_NOASW4>0
        L_BASW4=1
        L_NOASW4=L_NOASW4+L_OLDNOASW4
        #Check that property is exposed on link's facettes
        #LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM
        If func AFNC.ACTIV(PARACT) & [M:ASW4]ACTPRO(L_NOASW4-1)<>"" & !func AFNC.ACTIV([M:ASW4]ACTPRO(L_NOASW4-1))
         ERROR_MSG = mess(24,176,1)-"("+[M:ASW4]ACTPRO(L_NOASW4-1)+")"-":"-[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL) # Code activité inactif
         FLG_OK = 0
        Elsif LK_DET=2 & [M:ASW4]DETPRO(L_NOASW4-1)<>2
         #La propriété $1$ n'est pas exposée sur la facette $2$ alors que le lien l'est
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(1,7964,1))
         FLG_OK = 0
        Elsif LK_QRY=2 & [M:ASW4]QRYPRO(L_NOASW4-1)<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(3,7964,1))
         FLG_OK = 0
        Elsif LK_EDI=2 & [M:ASW4]EDIPRO(L_NOASW4-1)<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(2,7964,1))
         FLG_OK = 0
        Elsif LK_LOK=2 & [M:ASW4]LOKPRO(L_NOASW4-1)<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(4,7964,1))
         FLG_OK = 0
        Elsif LK_SUM=2 & [M:ASW4]SUMPRO(L_NOASW4-1)<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(5,7964,1))
         FLG_OK = 0
        Endif
        L_OLDNOASW4=L_NOASW4
        L_NOASW4=find(toupper(L_VAL), [M:ASW4]CODPRO(L_OLDNOASW4..[M:ASW4]NBRPRO-1))
      Wend
      If L_BASW4=0
       ERROR_MSG = mess(119,143,1) # Propriété n'est pas exposée.
       FLG_OK = 0
      Endif
     When 2:
      L_BASW4=0
      #DIM Read [ASWR2]ASWR0 = REPCOD;toupper(L_VAL_WITHOUT_DIM)
      For [ASWR2]ASWR3 Where CODREP=REPCOD and CODPRO=toupper(L_VAL)
        L_BASW4=1
        #Check that property is exposed on link's facettes
        #LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM
        If func AFNC.ACTIV(PARACT) & [F:ASWR2]ACTPRO<>"" & !func AFNC.ACTIV([F:ASWR2]ACTPRO)
         ERROR_MSG = mess(24,176,1)-"("+[F:ASWR2]ACTPRO+")"-":"-[F:ASWR2]ALIAS+"/"+toupper(L_VAL) # Code activité inactif
         FLG_OK = 0
        Elsif LK_DET=2 & [F:ASWR2]DETPRO<>2
         #La propriété $1$ n'est pas exposée sur la facette $2$ alors que le lien l'est
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(1,7964,1))
         FLG_OK = 0
        Elsif LK_QRY=2 & [F:ASWR2]QRYPRO<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(3,7964,1))
         FLG_OK = 0
        Elsif LK_EDI=2 & [F:ASWR2]EDIPRO<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(2,7964,1))
         FLG_OK = 0
        Elsif LK_LOK=2 & [F:ASWR2]LOKPRO<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(4,7964,1))
         FLG_OK = 0
        Elsif LK_SUM=2 & [F:ASWR2]SUMPRO<>2
         ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(5,7964,1))
         FLG_OK = 0
        Endif
      Next
      If L_BASW4=0
       ERROR_MSG = mess(119,143,1) # Propriété n'est pas exposée.
       FLG_OK = 0
      Endif
    Endcase
   Endif

  # 3.2 there's still more "." found
  Else
   T_CHAINE = left$(T_VAL,INDEX_DOT-1)
   If T_CHAINE = ""
    FLG_OK = 0
    If FLG_MOD_PROPERTY
     ERROR_MSG = mess(126,143,1) # Valeur invalide.
    Endif
   Else

   # 3.2.1 it's ACTX (context code or AVARNULL)
   If toupper(T_CHAINE) = "ACTX"
    FLG_MOD_PROPERTY = 1
    If T_COLCOD <> "" # and T_COLDIM = 0
     ERROR_MSG = mess(126,143,1)-T_COLCOD+".ACTX" # Valeur invalide.
 #   ERROR_MSG = func AFNC.MES1(mess(142,143,1),T_COLCOD) # Manque d'indice pour la collection "$1$"
     FLG_OK = 0
    Elsif !func ACTX_TOOL.CHECK_ACTX_PROPERTY(right$(T_VAL, INDEX_DOT+1))
     ERROR_MSG = mess(289,139,1)-":"-T_VAL # Code contexte inexistant
     FLG_OK = 0
    Else
     Local Integer L_ACTX_TYPCOD
     L_ACTX_TYPCOD = func ACTX_TOOL.GET_ACTX_TYPCOD(right$(T_VAL, INDEX_DOT+1))
     If FLG_IS_NUM
      If !func ATY_TOOL.CHECK_TYPE_FORMULE_NUM(L_ACTX_TYPCOD)
       ERROR_MSG = mess(149,143,1) # Type incompatible.
       FLG_OK = 0
      Endif
     Elsif FLG_IS_VAL
      If !func ATY_TOOL.CHECK_TYPE_FORMULE_VAL(L_ACTX_TYPCOD)
       ERROR_MSG = mess(149,143,1) # Type incompatible.
       FLG_OK = 0
      Endif
     Elsif L_ACTX_TYPCOD<>PARTYP
      ERROR_MSG = mess(127,143,1)-":"-T_VAL # Type de code contexte incompatible.
      FLG_OK = 0
     Endif
    Endif
    FLG_FINISH = 1
    # in case of link, need to check if the code contexte is exposed
    If FLG_OK & IS_LINK & (left$(toupper(L_VAL),5)<>"ACTX." | [L]CMPLNK<>19)
     Case MODE
      When 1:
       L_BASW4=0
       #DIM If !find(toupper(L_VAL_WITHOUT_DIM), [M:ASW4]CODPRO)
       L_OLDNOASW4=0
       L_NOASW4=find(toupper(L_VAL), [M:ASW4]CODPRO(L_OLDNOASW4..[M:ASW4]NBRPRO-1))
       While L_NOASW4>0
         L_BASW4=1
         L_NOASW4=L_NOASW4+L_OLDNOASW4
         #Check that property is exposed on link's facettes
         #LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM
         If func AFNC.ACTIV(PARACT) & [M:ASW4]ACTPRO(L_NOASW4-1)<>"" & !func AFNC.ACTIV([M:ASW4]ACTPRO(L_NOASW4-1))
          ERROR_MSG = mess(24,176,1)-"("+[M:ASW4]ACTPRO(L_NOASW4-1)+")"-":"-[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL) # Code activité inactif
          FLG_OK = 0
         Elsif LK_DET=2 & [M:ASW4]DETPRO(L_NOASW4-1)<>2
          #La propriété $1$ n'est pas exposée sur la facette $2$ alors que le lien l'est
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(1,7964,1))
          FLG_OK = 0
         Elsif LK_QRY=2 & [M:ASW4]QRYPRO(L_NOASW4-1)<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(3,7964,1))
          FLG_OK = 0
         Elsif LK_EDI=2 & [M:ASW4]EDIPRO(L_NOASW4-1)<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(2,7964,1))
          FLG_OK = 0
         Elsif LK_LOK=2 & [M:ASW4]LOKPRO(L_NOASW4-1)<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(4,7964,1))
          FLG_OK = 0
         Elsif LK_SUM=2 & [M:ASW4]SUMPRO(L_NOASW4-1)<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[M:ASW4]ALIAS(L_NOASW4-1)+"/"+toupper(L_VAL),mess(5,7964,1))
          FLG_OK = 0
         Endif
         L_OLDNOASW4=L_NOASW4
         L_NOASW4=find(toupper(L_VAL), [M:ASW4]CODPRO(L_OLDNOASW4..[M:ASW4]NBRPRO-1))
       Wend
       If L_BASW4=0
        ERROR_MSG = mess(119,143,1) # Propriété n'est pas exposée.
        FLG_OK = 0
       Endif
      When 2:
       L_BASW4=0
       #DIM Read [ASWR2]ASWR0 = REPCOD;toupper(L_VAL_WITHOUT_DIM)
       For [ASWR2]ASWR3 Where CODREP=REPCOD and CODPRO=toupper(L_VAL)
         L_BASW4=1
         #Check that property is exposed on link's facettes
         #LK_DET,LK_QRY,LK_EDI,LK_LOK,LK_SUM
         If func AFNC.ACTIV(PARACT) & [F:ASWR2]ACTPRO<>"" & !func AFNC.ACTIV([F:ASWR2]ACTPRO)
          ERROR_MSG = mess(24,176,1)-"("+[F:ASWR2]ACTPRO+")"-":"-[F:ASWR2]ALIAS+"/"+toupper(L_VAL) # Code activité inactif
          FLG_OK = 0
         Elsif LK_DET=2 & [F:ASWR2]DETPRO<>2
          #La propriété $1$ n'est pas exposée sur la facette $2$ alors que le lien l'est
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(1,7964,1))
          FLG_OK = 0
         Elsif LK_QRY=2 & [F:ASWR2]QRYPRO<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(3,7964,1))
          FLG_OK = 0
         Elsif LK_EDI=2 & [F:ASWR2]EDIPRO<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(2,7964,1))
          FLG_OK = 0
         Elsif LK_LOK=2 & [F:ASWR2]LOKPRO<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(4,7964,1))
          FLG_OK = 0
         Elsif LK_SUM=2 & [F:ASWR2]SUMPRO<>2
          ERROR_MSG = func AFNC.MES2(mess(220,143,1),[F:ASWR2]ALIAS+"/"+toupper(L_VAL),mess(5,7964,1))
          FLG_OK = 0
         Endif
       Next
       If L_BASW4=0
        ERROR_MSG = mess(119,143,1) # Propriété n'est pas exposée.
        FLG_OK = 0
       Endif
     Endcase
    Endif

   Else

    # 3.2.2 dimension check
    If seg$(T_CHAINE,len(T_CHAINE),len(T_CHAINE)) = ")"
     FLG_OK = 0
     INDEX_DIM = instr(1,T_CHAINE,"(")
     If INDEX_DIM>0
      T_DIM = seg$(T_CHAINE,INDEX_DIM+1, len(T_CHAINE)-1)
      If num$(val(T_DIM))= T_DIM and val(T_DIM)> 0
       If FLG_MOD_PROPERTY
        ERROR_MSG = mess(143,143,1)-":"-T_CHAINE # Mauvais utilisation d'indice
       Else
        FLG_MOD_PROPERTY = 1
        ERROR_MSG = mess(126,143,1) # Valeur invalide.
       Endif
      Else
       If FLG_MOD_PROPERTY
        ERROR_MSG =  mess(126,143,1)-":"-T_CHAINE # Valeur invalide.
       Endif
      Endif
     Else
      If FLG_MOD_PROPERTY
       ERROR_MSG = mess(126,143,1) # Valeur invalide.
      Endif
     Endif
    Endif

    If FLG_OK
     # 3.2.3 it's a child class of current class
     If T_CLACOD = REPCOD and !FLG_ENTER_CLASS
      Case MODE
       When 1:
        Gosub L_CHECK_CHILD_CLASS_SCREEN
       When 2:
        Gosub L_CHECK_CHILD_CLASS_DB
      Endcase
     # 3.2.4 it's a child class of child class
     Else
      Gosub L_CHECK_INSTANCE_CHILD_CLASS_DB
     Endif
    Endif
   Endif

   Endif
   T_VAL = right$(T_VAL,INDEX_DOT+1)
  Endif

  Endif
 Wend

 If FLG_OK # means a valid proprety is found
  [L]VALEUR = toupper([L]VALEUR)
  If FLG_IS_NUM
   PARVAL = "=num$("+[L]VALEUR+")"
  Elsif FLG_IS_VAL
   PARVAL = "=val("+[L]VALEUR+")"
  Else
   PARVAL = [L]VALEUR
  Endif
 Endif

 If !FLG_OK
  If FLG_MOD_PROPERTY
   RES_OK = 0 : End RES_OK
  Endif

  # If parameter is of type Clob/Blob/Class/Uuid/Datetime, or by address, value can only be a valid property
  If find(PARTYP,9,10,11,12,13) or PARMOD = 1
   ERROR_MSG = mess(129,143,1) # Veuillez mettre une propriété compatible.
   RES_OK = 0 : End RES_OK
  Endif

 # 4: in case direct value : check the format
  If [L]PARTYP = 8
   [L]VALEUR = func ATY_TOOL.FORMAT_DATE([L]VALEUR) # format the Date
   [L]PARVAL = [L]VALEUR
  Endif
  #If adxmac(-2)="pc018948.sagefr.adinternal.com" : Dbgaff : Endif
  If [L]PARTYP = 7
   If !func ATY_TOOL.CHECK_TYPADX_CHAR_BIS([L]VALEUR) # for type char, need to use the specific check
    ERROR_MSG = mess(126,143,1) # Type de valeur incompatible.
    RES_OK = 0 : End RES_OK
   Endif
  Elsif find([L]PARTYP,1,2,3,4,5,6)>0
   If [L]VALEUR<>num$(val([L]VALEUR))
    ERROR_MSG = mess(126,143,1) # Type de valeur incompatible.
    RES_OK = 0 : End RES_OK
   Endif
  Elsif PARVAL<>[L]VALEUR
   ERROR_MSG = mess(126,143,1) # Type de valeur incompatible.
   RES_OK = 0 : End RES_OK
  Endif
 Endif

 # Special check for AFILTER,AENABLE
 If PARCOD="AFILTER" & PARTYP=7
  If len(PARVAL)<2 & left$(PARVAL,1)<>'"'
    ERROR_MSG = mess(126,143,1) # Valeur invalide.
    RES_OK = 0 : End RES_OK
  Endif
  If [L]FLDTYP<>""
   Read [ATY]CODTYP = [L]FLDTYP
   If fstat
    ERROR_MSG = mess(126,143,1) # Valeur invalide.
    RES_OK = 0 : End RES_OK
   Elsif [ATY]CODCLA=""
    ERROR_MSG = mess(126,143,1) # Valeur invalide.
    RES_OK = 0 : End RES_OK
   Else
    [L]VALEUR=right$(left$([L]PARVAL,len([L]PARVAL)-1),2)
    Filter [ACLAO] Where CODCLA=[ATY]CODCLA & [ACLAO]OPTCOD=[L]VALEUR
    Read [ACLAO] First
    Filter [ACLAO]
    If fstat
     ERROR_MSG = func AFNC.MES2(mess(147,143,1),PARVAL,[ATY]CODCLA)
     RES_OK = 0 : End RES_OK
    Endif
   Endif
  Endif
 Elsif PARCOD="AENABLE" & find([L]PARVAL,"1","2")=0
   ERROR_MSG = mess(126,143,1) # Valeur invalide.
   RES_OK = 0 : End RES_OK
 Endif

# Close Local File [ATY], [ACLA],[ACLAC], [ACLAF], [ASWF], [ASW], [ASWR2]

End RES_OK


#-------------------------- L_CHECK_PARAMETER internal use only -------------------------------#
$L_CHECK_PROPERTY_SCREEN

 I = 0


 # 2. in case it's a code of property
 I = find(toupper(T_VAL),[M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
 If I > 0
  FLG_MOD_PROPERTY = 1

#DIM  If IS_LINK and [M:ASW9]FLDGRP(I-1) <> ""
#   ERROR_MSG = "pas de champs dimensionné pour les liens"
#   FLG_OK = 0
#  Elsif T_COLCOD <> "" or [M:ASW9]FLDGRP(I-1) <> ""
  If T_COLCOD <> "" or [M:ASW9]FLDGRP(I-1) <> ""
   If T_COLCOD = "" or [M:ASW9]FLDGRP(I-1) <> toupper(left$([L]VALEUR,INDEX_DOT_STD-1))
    ERROR_MSG = func AFNC.MES1(mess(145,143,1), T_VAL) # Manque de collection ou mauvaise collection pour la propriété "$1$"
    FLG_OK = 0
   Else
    T_COLCOD = ""
#DIM    T_COLDIM = 0
   Endif
  Endif

  If FLG_OK
   If func AFNC.ACTIV(PARACT) & [M:ASW9]ACTFLD(I-1)<>""
    If !func AFNC.ACTIV([M:ASW9]ACTFLD(I-1))
     ERROR_MSG = mess(24,176,1)-"("+[M:ASW9]ACTFLD(I-1)+")"-":"-toupper(T_VAL) # Code activité inactif
     FLG_OK = 0
    Endif
   Endif
  Endif

  If FLG_OK
   Read [ATY]CODTYP = [M:ASW9]CODTYP(I-1)
   If fstat
    ERROR_MSG = mess(130,143,1)-":"-T_VAL # Type de propriété invalide.
    FLG_OK = 0
   Elsif FLG_IS_NUM
    If !func ATY_TOOL.CHECK_TYPE_FORMULE_NUM([ATY]TYPTYP)
     ERROR_MSG = mess(149,143,1) # Type incompatible.
     FLG_OK = 0
    Endif
   Elsif FLG_IS_VAL
    If !func ATY_TOOL.CHECK_TYPE_FORMULE_VAL([ATY]TYPTYP)
     ERROR_MSG = mess(149,143,1) # Type incompatible.
     FLG_OK = 0
    Endif
   Elsif [ATY]TYPTYP<>PARTYP
    ERROR_MSG = mess(128,143,1)-":"-T_VAL # Type de propriété incompatible.
    FLG_OK = 0
   Endif
  Endif

 Elsif toupper(T_VAL) = [M:ASW1]ABRCLA
  FLG_MOD_PROPERTY = 1
  If T_COLCOD <> ""
   ERROR_MSG = mess(33,140,1)-":"-T_COLCOD+"."+T_VAL # Propriété inexistante
   FLG_OK = 0
  Elsif FLG_IS_NUM or FLG_IS_VAL
   ERROR_MSG = mess(149,143,1) # Type incompatible.
   FLG_OK = 0
  Elsif PARTYP <> 13 # only parameter of type Class can take directly a class
   ERROR_MSG = mess(128,143,1)-":"-T_VAL # Type de propriété incompatible.
   FLG_OK = 0
  Endif

 Else
  FLG_OK = 0
  If FLG_MOD_PROPERTY
   ERROR_MSG = mess(33,140,1)-":"-T_VAL # Propriété inexistante
  Endif
 Endif
Return


#-------------------------- L_CHECK_PARAMETER internal use only -------------------------------#
$L_CHECK_PROPERTY_DB

 I = 0


 # 2. in case it's a code of property
 Read [ASWF2]ASWF0 = REPCOD;toupper(T_VAL)
 If !fstat
  FLG_MOD_PROPERTY = 1

#DIM  If IS_LINK and [F:ASWF2]FLDGRP <> ""
#   ERROR_MSG = "pas de champs dimensionné pour les liens"
#   FLG_OK = 0
#  Elsif T_COLCOD <> "" or [F:ASWF2]FLDGRP <> ""
  If T_COLCOD <> "" or [F:ASWF2]FLDGRP <> ""
   If T_COLCOD = "" or [F:ASWF2]FLDGRP <> toupper(left$([L]VALEUR,INDEX_DOT_STD-1))
    ERROR_MSG = func AFNC.MES1(mess(145,143,1), T_VAL) # Manque de collection ou mauvaise collection pour la propriété "$1$"
    FLG_OK = 0
   Else
    T_COLCOD = ""
#DIM    T_COLDIM = 0
   Endif
  Endif

  If FLG_OK
   If func AFNC.ACTIV(PARACT) & [F:ASWF2]ACTFLD<>""
    If !func AFNC.ACTIV([F:ASWF2]ACTFLD)
     ERROR_MSG = mess(24,176,1)-"("+[F:ASWF2]ACTFLD+")"-":"-toupper(T_VAL) # Code activité inactif
     FLG_OK = 0
    Endif
   Endif
  Endif

  If FLG_OK
   Read [ATY]CODTYP = [F:ASWF2]CODTYP
   If fstat
    ERROR_MSG = mess(130,143,1)-":"-T_VAL # Type de propriété invalide.
    FLG_OK = 0
   Elsif FLG_IS_NUM
    If !func ATY_TOOL.CHECK_TYPE_FORMULE_NUM([ATY]TYPTYP)
     ERROR_MSG = mess(149,143,1) # Type incompatible.
     FLG_OK = 0
    Endif
   Elsif FLG_IS_VAL
    If !func ATY_TOOL.CHECK_TYPE_FORMULE_VAL([ATY]TYPTYP)
     ERROR_MSG = mess(149,143,1) # Type incompatible.
     FLG_OK = 0
    Endif
   Elsif [ATY]TYPTYP<>PARTYP
    ERROR_MSG = mess(128,143,1)-":"-T_VAL # Type de propriété incompatible.
    FLG_OK = 0
   Endif
  Endif

 Else
  Read [ASW]ASW0 = T_CLACOD
  If !fstat and toupper(T_VAL) = [F:ASW]ABRCLA
   FLG_MOD_PROPERTY = 1
   If T_COLCOD <> ""
    ERROR_MSG = mess(33,140,1)-":"-T_COLCOD+"."+T_VAL # Propriété inexistante
    FLG_OK = 0
   Elsif FLG_IS_NUM or FLG_IS_VAL
    ERROR_MSG = mess(149,143,1) # Type incompatible.
    FLG_OK = 0
   Elsif PARTYP <> 13 # only parameter of type Class can take directly a class
    ERROR_MSG = mess(128,143,1)-":"-T_VAL # Type de propriété incompatible.
    FLG_OK = 0
   Endif
  Else
   FLG_OK = 0
   If FLG_MOD_PROPERTY
    ERROR_MSG = mess(33,140,1)-":"-T_VAL # Propriété inexistante
   Endif
  Endif
 Endif
Return


#-------------------------- L_CHECK_PARAMETER internal use only -------------------------------#
$L_CHECK_INSTANCE_PROPERTY_DB

 I = 0


 # 2. in case it's a property code of the classe of representation
 Read [ACLAF2]ACLAF0 = T_CLACOD;toupper(T_VAL)
 If fstat
  # it could be a property of representation which is added to the colleciton of the class
  If T_COLCOD <> ""
   If MODE = 1
    Gosub L_CHECK_PROPERTY_SCREEN
   Else
    Gosub L_CHECK_PROPERTY_DB
   Endif
   Return
  Else
   FLG_OK = 0
   If FLG_MOD_PROPERTY
    ERROR_MSG = mess(33,140,1)-":"-T_VAL # Propriété inexistante
   Endif
  Endif
 Else
  FLG_MOD_PROPERTY = 1

  If FLG_OK
   If func AFNC.ACTIV(PARACT) & [F:ACLAF2]ACTFLD<>""
    If !func AFNC.ACTIV([F:ACLAF2]ACTFLD)
     ERROR_MSG = mess(24,176,1)-"("+[F:ACLAF2]ACTFLD+")"-":"-toupper(T_VAL) # Code activité inactif
     FLG_OK = 0
    Endif
   Endif
  Endif

  If FLG_OK
#DIM  If IS_LINK and [F:ACLAF2]FLDGRP <> ""
#   ERROR_MSG = "pas de champs dimensionné pour les liens"
#   FLG_OK = 0
#  Elsif [F:ACLAF2]LNKCLA<>""
   If [F:ACLAF2]LNKCLA<>""
    If T_COLCOD <> ""
     ERROR_MSG = mess(148,143,1) # Pas de collection devant une classe
     FLG_OK = 0
    Elsif FLG_IS_NUM or FLG_IS_VAL
     ERROR_MSG = mess(149,143,1) # Type incompatible.
     FLG_OK = 0
    Elsif PARTYP <> 13 # only parameter of type Class can take a directly a class
     ERROR_MSG = mess(128,143,1)-":"-T_VAL # Type de propriété incompatible.
     FLG_OK = 0
 #DIM   Elsif [F:ACLAF2]FLDGRP <> ""
 #    ERROR_MSG = func AFNC.MES1(mess(147,143,1),T_VAL) # Manque d'indice pour la classe "$1$"
 #    FLG_OK = 0
 #   Endif
    Elsif [F:ACLAF2]FLDGRP <> "" and !func IS_COLLECTION_ACCESSIBLE([L]PARCOL, toupper(left$([L]VALEUR,INDEX_DOT_STD-1)))# [L]PARCOL <> [F:ACLAF2]FLDGRP # ??? in case collection of class !!!
     ERROR_MSG = func AFNC.MES1(mess(142,143,1),T_CHAINE) # Collection "$1$" non accessible ici
     FLG_OK = 0
    Endif

   Else
    If T_COLCOD <> "" or [F:ACLAF2]FLDGRP <> ""
     If [F:ACLAF2]FLDGRP <> T_COLCOD
      ERROR_MSG = func AFNC.MES1(mess(145,143,1), T_VAL) # Manque de collection ou mauvaise collection pour la propriété "$1$"
      FLG_OK = 0
     Else
      T_COLCOD = ""
 #DIM     T_COLDIM = 0
     Endif
    Endif

    If FLG_OK
     Read [ATY]CODTYP = [F:ACLAF2]CODTYP
     If fstat
      ERROR_MSG = mess(130,143,1)-":"-T_VAL # Type de propriété invalide.
      FLG_OK = 0
     Elsif FLG_IS_NUM
      If !func ATY_TOOL.CHECK_TYPE_FORMULE_NUM([ATY]TYPTYP)
       ERROR_MSG = mess(149,143,1) # Type incompatible.
       FLG_OK = 0
      Endif
     Elsif FLG_IS_VAL
      If !func ATY_TOOL.CHECK_TYPE_FORMULE_VAL([ATY]TYPTYP)
       ERROR_MSG = mess(149,143,1) # Type incompatible.
       FLG_OK = 0
      Endif
     Elsif [ATY]TYPTYP<> PARTYP
      ERROR_MSG = mess(128,143,1)-":"-T_VAL # Type de propriété incompatible.
      FLG_OK = 0
     Endif
    Endif

   Endif
  Endif
 Endif
Return


#-------------------------- L_CHECK_PARAMETER internal use only -------------------------------#
$L_CHECK_CHILD_CLASS_SCREEN

 I = 0


 # 2. in case it's a collection code
 If T_COLCOD = ""
  I = find(toupper(T_CHAINE),[M:ASW1]CODCOL(0..[M:ASW1]NBRCOL-1))
  If I > 0
   FLG_MOD_PROPERTY = 1
   If !func IS_COLLECTION_ACCESSIBLE([L]PARCOL, toupper(left$([L]VALEUR,INDEX_DOT_STD-1)))# (PARCOL <> toupper(T_CHAINE))
    FLG_OK = 0
    ERROR_MSG = func AFNC.MES1(mess(142,143,1),T_CHAINE) # Collection "$1$" non accessible ici
   Else
    T_COLCOD = toupper(T_CHAINE)
   Endif
   Return
  Endif
 Endif

 # 3. in case it's the classe of representation
 If toupper(T_CHAINE) = [M:ASW1]ABRCLA
  FLG_MOD_PROPERTY = 1
  FLG_ENTER_CLASS = 1
  T_CLACOD = [M:ASW1]CODCLA
 Else
  FLG_OK = 0
  If FLG_MOD_PROPERTY
   ERROR_MSG = mess(33,140,1) # Propriété inexistante
  Endif
 Endif
Return

