$L_CHECK_CHILD_CLASS_DB

 I = 0

 Read [ASW]ASW0 = T_CLACOD
 If fstat : Return : Endif

 # 2. in case it's a collection code
 If T_COLCOD = ""
  Read [ASWC]ASWC0=T_CLACOD;toupper(T_CHAINE)
  If !fstat
   FLG_MOD_PROPERTY = 1
   If !func IS_COLLECTION_ACCESSIBLE(PARCOL, toupper(left$([L]VALEUR,INDEX_DOT_STD-1))) #(PARCOL <> toupper(T_CHAINE))
    FLG_OK = 0
    ERROR_MSG = func AFNC.MES1(mess(142,143,1),T_CHAINE) # Collection "$1$" non accessible ici
   Else
    T_COLCOD = toupper(T_CHAINE)
   Endif
   Return
  Endif
 Endif

 # 3. in case it's the classe of representation
 #Read [ASW]ASW0 = T_CLACOD
 If toupper(T_CHAINE) = [F:ASW]ABRCLA
  FLG_MOD_PROPERTY = 1
  FLG_ENTER_CLASS = 1
  T_CLACOD = [F:ASW]CODCLA
 Else
  FLG_OK = 0
  If FLG_MOD_PROPERTY
   ERROR_MSG = mess(33,140,1) # Propriété inexistante
  Endif
 Endif
Return

#-------------------------- L_CHECK_PARAMETER internal use only -------------------------------#
$L_CHECK_INSTANCE_CHILD_CLASS_DB


 I = 0

 Read [ACLA]ACLA0 = T_CLACOD
 If fstat : Return : Endif


 # 2. in case it's a collection code
 If T_COLCOD = ""
  Read [ACLAC]ACLAC0=T_CLACOD;toupper(T_CHAINE)
  If !fstat
   FLG_MOD_PROPERTY = 1
   # ??? in case collection of class !!!
   If !func IS_COLLECTION_ACCESSIBLE(PARCOL, toupper(left$([L]VALEUR,INDEX_DOT_STD-1))) #PARCOL <> toupper(T_CHAINE)
    FLG_OK = 0
    ERROR_MSG = func AFNC.MES1(mess(142,143,1),T_CHAINE) # Collection "$1$" non accessible ici
    Return
   Else
    # check if it's not a property code
    Read [ACLAF2]ACLAF0 = T_CLACOD;toupper(T_CHAINE)
    If fstat
     T_COLCOD = toupper(T_CHAINE)
     Return
    Endif
   Endif
  Endif
 Endif


 # 3. in case it's a property code of the classe of representation
 Read [ACLAF2]ACLAF0 = T_CLACOD;toupper(T_CHAINE)
 If !fstat
  FLG_MOD_PROPERTY = 1
  If FLG_OK
   If func AFNC.ACTIV(PARACT) & [F:ACLAF2]ACTFLD<>""
    If !func AFNC.ACTIV([F:ACLAF2]ACTFLD)
     ERROR_MSG = mess(24,176,1)-"("+[F:ACLAF2]ACTFLD+")"-":"-toupper(T_CHAINE) # Code activité inactif
     FLG_OK = 0
    Endif
   Endif
  Endif
  If FLG_OK
   If [F:ACLAF2]LNKCLA <> ""
    If T_COLCOD <> ""
     ERROR_MSG = mess(148,143,1) # Pas de collection devant une classe
     FLG_OK = 0
    # ??? in case collection of class !!!
    Elsif [F:ACLAF2]FLDGRP <> "" and !func IS_COLLECTION_ACCESSIBLE(PARCOL, toupper(left$([L]VALEUR,INDEX_DOT_STD-1))) # PARCOL <> [F:ACLAF2]FLDGRP
     ERROR_MSG = func AFNC.MES1(mess(142,143,1),T_CHAINE) # Collection "$1$" non accessible ici
     FLG_OK = 0
    Else
     T_CLACOD = [F:ACLAF2]LNKCLA
    Endif
   Else
    ERROR_MSG = mess(33,140,1)-":"-T_CHAINE # Propriété inexistante
    FLG_OK = 0
   Endif
  Endif
 Else
  FLG_OK = 0
  If FLG_MOD_PROPERTY
   ERROR_MSG = mess(33,140,1)-":"-T_CHAINE # Propriété inexistante
  Endif
 Endif

Return


#----------------- SUBASW, SUBASW2 internal use only ------------------#
Funprog GET_COL_FROM_PRO_PATH_SCREEN(PRO_PATH,L_EXACT)
Value Char PRO_PATH
Value Integer L_EXACT
Local Char RES_COL(GLONAVC)

 Local Char L_STR_RIGHT(255), L_STR_CUR(255), L_CURCLA(GLONACLA)
 Local Integer INDEX_DOT, INDEX_DOT_STD, FLG_CONTINUE

  FLG_CONTINUE = 1
  L_STR_RIGHT = toupper(PRO_PATH)
  INDEX_DOT=instr(1,L_STR_RIGHT,".")
  INDEX_DOT_STD = INDEX_DOT
  While INDEX_DOT>0 and FLG_CONTINUE
   L_STR_CUR = left$(L_STR_RIGHT,INDEX_DOT-1)
   # 1. enter the loop for the first time
   If L_CURCLA = ""
    # 1.1 in case it's a collection code of the representation
    If find(L_STR_CUR, [M:ASW1]CODCOL(0..[M:ASW1]NBRCOL-1))
     RES_COL = L_STR_CUR
     FLG_CONTINUE = 0
    # 1.2 in case it's the instance code of the representation
    Elsif L_STR_CUR = [M:ASW1]ABRCLA
     L_CURCLA = [M:ASW1]CODCLA
    # 1.3 otherwise, given ALIAS is not in a collection
    Else
     FLG_CONTINUE = 0
    Endif
   # 2. enter the loop with given L_CURCLA
   Else
    Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
    # 2.1 in case it's a child class of L_CURCLA
    If !fstat
     If [F:ACLAF]LNKCLA <> ""
      L_CURCLA = [F:ACLAF]LNKCLA
      If [F:ACLAF]FLDGRP<>""
       If L_EXACT
        RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
       Else
        Read [ACLAC]ACLAC0 =  [F:ACLAF]CODCLA;[F:ACLAF]FLDGRP
        If !fstat
         If [ACLAC]MINCOL<>2 or  [ACLAC]MAXCOL<>1
          RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
         Endif
        Endif
       Endif
      Endif
     Else
      FLG_CONTINUE = 0
     Endif
    Else
     Read [ACLAC]ACLAC0 = L_CURCLA;L_STR_CUR
     # 2.2 in case it's a collection code of L_CURCLA
     If !fstat
      If L_EXACT
       RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
       FLG_CONTINUE = 0
      Else
       If [ACLAC]MINCOL<>2 or[ACLAC]MAXCOL<>1
        RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
        FLG_CONTINUE = 0
       Endif
      Endif
     Else
      FLG_CONTINUE = 0
     Endif
    Endif
   Endif

   If FLG_CONTINUE
    L_STR_RIGHT = right$(L_STR_RIGHT,INDEX_DOT+1)
    INDEX_DOT=instr(1,L_STR_RIGHT,".")
    INDEX_DOT_STD += INDEX_DOT
   Endif
  Wend

End RES_COL

#---------------------------------------------------------#
Funprog GET_COL_FROM_PRO_PATH_DOSS(DOSSIER,REP_COD,REP_CLA,REP_ABRCLA,PRO_PATH,L_EXACT)
Value Char DOSSIER,REP_COD,PRO_PATH,REP_CLA,REP_ABRCLA
Value Integer L_EXACT
Local Char RES_COL(GLONAVC)

 Local File =[L]DOSSIER+".ACLAFLD" [ACLAF]
 Local File =[L]DOSSIER+".ACLACOL" [ACLAC]
 Local File =[L]DOSSIER+".ASHWCOL" [ASWC]

 RES_COL=func GET_COL_FROM_PRO_PATH(REP_COD,REP_CLA,REP_ABRCLA,PRO_PATH,L_EXACT)

 #Close Local File [ACLAF],[ACLAC],[ASWC]
End RES_COL


#---------------------------------------------------------#
Funprog GET_COL_FROM_PRO_PATH(REP_COD,REP_CLA,REP_ABRCLA,PRO_PATH,L_EXACT)
Value Char REP_COD,PRO_PATH,REP_CLA,REP_ABRCLA
Value Integer L_EXACT

Local Char RES_COL(GLONAVC)

 Local Char L_STR_RIGHT(255), L_STR_CUR(255), L_CURCLA(GLONACLA)
 Local Integer INDEX_DOT, INDEX_DOT_STD, FLG_CONTINUE

 FLG_CONTINUE = 1
 L_STR_RIGHT = toupper(PRO_PATH)
 INDEX_DOT=instr(1,L_STR_RIGHT,".")
 INDEX_DOT_STD = INDEX_DOT
 While INDEX_DOT>0 and FLG_CONTINUE
  L_STR_CUR = left$(L_STR_RIGHT,INDEX_DOT-1)
  # 1. enter the loop for the first time
  If L_CURCLA = ""
   # 1.1 in case it's a collection code of the representation
   Read [ASWC]ASWC0=REP_COD;L_STR_CUR
   If !fstat
    RES_COL = L_STR_CUR
    FLG_CONTINUE = 0
   # 1.2 in case it's the instance code of the representation
   Elsif L_STR_CUR = [L]REP_ABRCLA
    L_CURCLA = [L]REP_CLA
   # 1.3 otherwise, given ALIAS is not in a collection
   Else
    FLG_CONTINUE = 0
   Endif
  # 2. enter the loop with given L_CURCLA
  Else
   Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
   # 2.1 in case it's a child class of L_CURCLA
   If !fstat
    If [F:ACLAF]LNKCLA <> ""
     L_CURCLA = [F:ACLAF]LNKCLA
     If [F:ACLAF]FLDGRP<>""
      If L_EXACT
       RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
      Else
       Read [ACLAC]ACLAC0 =  [F:ACLAF]CODCLA;[F:ACLAF]FLDGRP
       If !fstat
        If [ACLAC]MINCOL<>2 or  [ACLAC]MAXCOL<>1
         RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
        Endif
       Endif
      Endif
     Endif
    Else
     FLG_CONTINUE = 0
    Endif
   Else
    Read [ACLAC]ACLAC0 = L_CURCLA;L_STR_CUR
    # 2.2 in case it's a collection code of L_CURCLA
    If !fstat
     If L_EXACT
      RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
      FLG_CONTINUE = 0
     Else
      If [ACLAC]MINCOL<>2 or[ACLAC]MAXCOL<>1
       RES_COL = left$(toupper(PRO_PATH),INDEX_DOT_STD-1)
       FLG_CONTINUE = 0
      Endif
     Endif
    Else
     FLG_CONTINUE = 0
    Endif
   Endif
  Endif

  If FLG_CONTINUE
   L_STR_RIGHT = right$(L_STR_RIGHT,INDEX_DOT+1)
   INDEX_DOT=instr(1,L_STR_RIGHT,".")
   INDEX_DOT_STD += INDEX_DOT
  Endif
 Wend

End RES_COL


#------------ SUBASW, SUBASW2 internal use only -----------#
Funprog GET_TYP_FROM_PRO_PATH_SCREEN(PRO_PATH)
Value Char PRO_PATH
Local Char RES_TYP(GLONATY)

 Local Char L_STR_RIGHT(255), L_STR_CUR(255), L_CURCLA(GLONACLA)
 Local Integer I, INDEX_DOT

 L_STR_RIGHT = toupper(PRO_PATH)

 While L_STR_RIGHT <> ""
  INDEX_DOT=instr(1,L_STR_RIGHT,".")
  If INDEX_DOT>0
   L_STR_CUR = left$(L_STR_RIGHT,INDEX_DOT-1)
   L_STR_RIGHT = right$(L_STR_RIGHT,INDEX_DOT+1)
  Else
   L_STR_CUR = L_STR_RIGHT
   L_STR_RIGHT = ""
  Endif

  # 1. reach the last section of the path
  If L_STR_RIGHT = ""
   If L_CURCLA = ""
    I = find(L_STR_CUR, [M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
    If I > 0
     RES_TYP = [M:ASW9]CODTYP(I-1)
    Endif
   Else
    Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
    If !fstat
     RES_TYP = [F:ACLAF]CODTYP
    Endif
   Endif

  # 2. still in the middle of the path
  Else
   If L_CURCLA = ""
    If L_STR_CUR = [M:ASW1]ABRCLA
     L_CURCLA = [M:ASW1]CODCLA
    Endif
   Else
    Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
    If !fstat and [F:ACLAF]LNKCLA <> ""
     L_CURCLA = [F:ACLAF]LNKCLA
    Endif
   Endif
  Endif

 Wend

End RES_TYP


#-------------------------------------------------#
Funprog GET_TYP_FROM_PRO_PATH_DOSS(DOSSIER,REP_COD, PRO_PATH)
Value Char DOSSIER,REP_COD
Value Char PRO_PATH
Local Char RES_TYP(GLONATY)

 Local File =[L]DOSSIER+".ASHW"    [ASW]
 Local File =[L]DOSSIER+".ASHWFLD" [ASWF]
 Local File =[L]DOSSIER+".ACLAFLD" [ACLAF]
 Local File =[L]DOSSIER+".ACLASSE" [ACLA]
 Local Char L_STR_RIGHT(255), L_STR_CUR(255), L_CURCLA(GLONACLA)
 Local Integer I, INDEX_DOT

 Read [ASW]ASW0 = REP_COD
 If fstat : End RES_TYP: Endif

 L_STR_RIGHT = toupper(PRO_PATH)

 While L_STR_RIGHT <> ""
  INDEX_DOT=instr(1,L_STR_RIGHT,".")
  If INDEX_DOT>0
   L_STR_CUR = left$(L_STR_RIGHT,INDEX_DOT-1)
   L_STR_RIGHT = right$(L_STR_RIGHT,INDEX_DOT+1)
  Else
   L_STR_CUR = L_STR_RIGHT
   L_STR_RIGHT = ""
  Endif

  # 1. reach the last section of the path
  If L_STR_RIGHT = ""
   If L_CURCLA = ""
    Read [ASWF]ASWF0 = REP_COD;L_STR_CUR
    If !fstat
     RES_TYP = [ASWF]CODTYP
    Endif
   Else
    Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
    If !fstat
     RES_TYP = [F:ACLAF]CODTYP
    Endif
   Endif

  # 2. still in the middle of the path
  Else
   If L_CURCLA = ""
    If L_STR_CUR = [F:ASW]ABRCLA
     L_CURCLA = [F:ASW]CODCLA
    Endif
   Else
    Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
    If !fstat and [F:ACLAF]LNKCLA <> ""
     L_CURCLA = [F:ACLAF]LNKCLA
    Endif
   Endif
  Endif

 Wend

 #Close Local File [ASW],[ASWF],[ACLAF],[ACLA]

End RES_TYP

Funprog GET_ACV_FROM_PRO_PATH_SCREEN(PRO_PATH)
Value Char PRO_PATH
Local Char RES_ACV(GLONACV)

 Local Char L_STR_RIGHT(255), L_STR_CUR(255), L_CURCLA(GLONACLA)
 Local Integer I, INDEX_DOT

 L_STR_RIGHT = toupper(PRO_PATH)

 While L_STR_RIGHT <> ""
  INDEX_DOT=instr(1,L_STR_RIGHT,".")
  If INDEX_DOT>0
   L_STR_CUR = left$(L_STR_RIGHT,INDEX_DOT-1)
   L_STR_RIGHT = right$(L_STR_RIGHT,INDEX_DOT+1)
  Else
   L_STR_CUR = L_STR_RIGHT
   L_STR_RIGHT = ""
  Endif

  # 1. reach the last section of the path
  If L_STR_RIGHT = ""
   If L_CURCLA = ""
    I = find(L_STR_CUR, [M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
    If I > 0
     RES_ACV = [M:ASW9]ACTFLD(I-1)
    Endif
   Else
    Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
    If !fstat
     RES_ACV = [F:ACLAF]ACTFLD
    Endif
   Endif

  # 2. still in the middle of the path
  Else
   If L_CURCLA = ""
    If L_STR_CUR = [M:ASW1]ABRCLA
     L_CURCLA = [M:ASW1]CODCLA
    Endif
   Else
    Read [ACLAF]ACLAF0 = L_CURCLA;L_STR_CUR
    If !fstat and [F:ACLAF]LNKCLA <> ""
     L_CURCLA = [F:ACLAF]LNKCLA
    Endif
   Endif
  Endif

 Wend

End RES_ACV

#---------------------------------------------------------#
# load the parameters of the given link into the debug table in screen ASW1
Subprog LOAD_PARLNK_ASW5(RECHDB,DOSSIER,CODREP,CODCLA,CMPLNK,LNK_AFF, LNK_ANC, LNK_COD, LNK_TYP, LNK_CLA, LNK_REP, LNK_CLAPTR, LNK_MET, LNK_FNC)
Value Integer RECHDB
Value Char DOSSIER,CODREP,CODCLA
Value Integer CMPLNK,LNK_AFF
Value Char LNK_ANC
Value Char LNK_COD
Value Integer LNK_TYP
Value Char LNK_CLA, LNK_REP, LNK_CLAPTR, LNK_MET, LNK_FNC

 Gosub DEF_TAB_PARLNK
 #pas de paramètre pour les liste de reporting ccl
 If find([L]CMPLNK,8,12,14,16,17,18)<>0 : End : Endif

 Gosub LOAD_PARLNK
 Call FILL_PARAM_ASW5([L]RECHDB,[L]DOSSIER,[L]CODREP,LNK_AFF, LNK_ANC,LNK_COD,3,"",WWCODPAR,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWISKEY,
&       WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
&       WWPARFIL,WWPARENT,WWVALPAR,WWNBRPARALL)
End

$DEF_TAB_PARLNK
 Local Char    WWCODPAR(80)(0..),WWCODCLAPAR(GLONACLA)(0..),WWCODCUR(80)(0..),WWFLDCLE(250)(0..), WWINTITPAR(80)(0..), WWVALPAR(250)(0..)
 Local Integer WWTYPINTPAR(0..), WWADRVAL(0..), WWTYPKEY(0..), WWNUMPAR(0..),WWTYPPAR(0..),WWNOLIB(0..),WWLNG(0..),WWTYPAFF(0..)
 Local Integer WWPARFIL(0..),WWPARENT(0..),WWISKEY(0..)
 Local Integer WWNBRPARALL
Return

$DEF_PARLNK
   Local Char CODCLA(GLONACLA) : [L]CODCLA=[F:ASWK]CLALNK
   Local Integer CMPLNK : [L]CMPLNK=[F:ASWK]CMPLNK
   Local Integer LNK_AFF : [L]LNK_AFF=[F:ASWK]AFFLNK
   Local Char LNK_ANC(GLONAVC) : [L]LNK_ANC=[F:ASWK]ANCLNK
   Local Char LNK_COD(GLONAVA) : [L]LNK_COD=[F:ASWK]CODLNK
   Local Integer LNK_TYP : [L]LNK_TYP=[F:ASWK]TYPLNK
   Local Char LNK_CLA(GLONACLA) : [L]LNK_CLA=[F:ASWK]CLALNK
   Local Char LNK_REP(GLONASW) : [L]LNK_REP=[F:ASWK]REPLNK
   Local Char LNK_CLAPTR(GLONAVC) : [L]LNK_CLAPTR=[F:ASWK]CLAPTRLNK
   #104754/3
   Local Char LNK_MET(GLONASM) : [L]LNK_MET=[F:ASWK]CODMETLNK+[F:ASWK]CODOPELNK+[F:ASWK]RPTCOD
   Local Char LNK_FNC(GLONAFC) : [L]LNK_FNC=[F:ASWK]CODFNCLNK
Return

$LOAD_PARLNK
#115007/1 If find([L]CMPLNK,8,12,14,16,17,18)<>0 : Return : Endif
If find([L]CMPLNK,8,12,14,16,17,18,22)<>0 : Return : Endif
If [L]CMPLNK=19
 Gosub LOAD_PARLNK_LOB
Else
 Case LNK_TYP
  When 1 : # Representation
   #pas de clé pour Créer, Liste
   If find([L]CMPLNK,1,5)=0
   Call CHARGE_CLA_ATI_CLE([L]DOSSIER,LNK_CLA,LNK_COD,3,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
&       WWNBRPARALL) From SUBACLA
   Endif
   #pas de param pour affichage reporting
   If find([L]CMPLNK,7,11,13,15)=0
   Call LOAD_REPRESENTATION_PARAM([L]DOSSIER,LNK_REP,0,LNK_COD,3,
&       WWCODPAR,WWCODCUR,WWTYPPAR,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
&       WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWPARFIL,WWPARENT,
&       WWNBRPARALL)
   Endif

 When 2 : # Methode
  Call CHARGE_PARAM_MET([L]DOSSIER,LNK_CLAPTR,LNK_CLA,LNK_MET,[L]CODREP,[L]CODCLA,LNK_COD,3,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,
&       WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBASW

 When 3 : # operation
  Call CHARGE_PARAM_MET([L]DOSSIER,LNK_CLAPTR,LNK_CLA,LNK_MET,[L]CODREP,[L]CODCLA,LNK_COD,3,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,
&       WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBASW

 When 4 : # X3 Convergence
   Call CHARGE_AFC_CLE([L]DOSSIER,LNK_FNC,LNK_COD,3,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
&       WWPARFIL,WWPARENT,WWVALPAR,WWNBRPARALL) From SUBASW

 When 6 : # Etat Crystal  #104754/3
   Call CHARGE_CLA_ATI_CLE([L]DOSSIER,LNK_CLA,LNK_COD,3,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
&       WWNBRPARALL) From SUBACLA
   If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]CODREP
     For I=0 To [L]WWNBRPARALL-1
       For J=0 To [M:ASW4]NBRPRO-1
        If [M:ASW1]ABRCLA+"."+WWCODPAR(I)=[M:ASW4]CODPRO(J)
         WWVALPAR(I)=[M:ASW4]CODPRO(J)
        Endif
      Next
     Next
   Endif
   Call CHARGE_ARP_PARAM([L]DOSSIER,LNK_MET,LNK_COD,3,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
&       WWPARFIL,WWPARENT,WWVALPAR,WWNBRPARALL) From SUBASW

 Endcase
Endif
Return

$LOAD_PARLNK_LOB
 Local Integer TEST,WNUM
 Local Char TABCLA(80)(1..50),TABPTR(80)(1..50),CODOBJ(50),CODCLA(80)
 Local Integer NBCLA,ISACTX,I
 If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]CODREP
  Call DECODE_PRO(LNK_ANC,2,"PRO",[L]DOSSIER,[L]CODREP,[M:ASW1]ABRCLA,[M:ASW1]CODCLA,TABPTR,TABCLA,CODOBJ,ISACTX,NBCLA) From SUBASW
 Else
  Call DECODE_PRO(LNK_ANC,0,"PRO",[L]DOSSIER,[L]CODREP,[F:ASW]ABRCLA,[F:ASW]CODCLA,TABPTR,TABCLA,CODOBJ,ISACTX,NBCLA) From SUBASW
 Endif
 If NBCLA>0
   CODCLA=TABCLA(NBCLA)
 Else
   CODCLA=""
 Endif
 Gosub RECH_ACLAF
 [L]WWVALPAR([L]WWNBRPARALL)=""
Return

$RECH_ACLAF
Local Integer J,K,TYPCLA
Local Char CLAPRO(60), DEFREP (60)
K=1
If NBCLA>0
 If [L]CODCLA=""
  If !ISACTX
   If clalev([M:ASW0])>0 & clalev([M:ASW9])>0 & [M:ASW0]CODREP=[L]CODREP
     J=find([L]CODOBJ,[M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
     If J>0
       For I=0 To [M:ASW5]NBRPAR-1
        If [M:ASW5]CODFLD(I)=[L]CODOBJ & [M:ASW5]TYPPAR(I)=1
           WNUM+=1
           [L]WWCODPAR([L]WWNBRPARALL) = [M:ASW5]CODPAR(I)
           [L]WWINTITPAR([L]WWNBRPARALL)= [M:ASW5]INTITPAR(I)
           [L]WWTYPINTPAR([L]WWNBRPARALL) = [M:ASW5]TYPINTPAR(I)
           [L]WWADRVAL([L]WWNBRPARALL) = [M:ASW5]ADRVAL(I)
           [L]WWTYPKEY([L]WWNBRPARALL) = [M:ASW5]TYPKEY(I)
           [L]WWNUMPAR([L]WWNBRPARALL)    = [M:ASW5]NUMPAR(I)
           [L]WWVALPAR([L]WWNBRPARALL)    = [M:ASW5]VALEUR(I)
           [L]WWNBRPARALL+=1
        Endif
       Next
     Endif
   Else
    Read [ASWF]ASWF0=[L]CODREP;[L]CODOBJ
    If !fstat
       For [ASWP] Where CODREP=[L]CODREP & TYPPAR=1 & CODFLD=[L]CODOBJ
         WNUM+=1
         [L]WWCODPAR([L]WWNBRPARALL) = [F:ASWP]CODPAR
         #[L]WWINTITPAR([L]WWNBRPARALL)= [F:ASWP]INTITPAR
         [L]WWTYPINTPAR([L]WWNBRPARALL) = [F:ASWP]TYPINT
         [L]WWADRVAL([L]WWNBRPARALL) = [F:ASWP]ADRVAL
         [L]WWTYPKEY([L]WWNBRPARALL) = [F:ASWP]TYPKEY
         [L]WWNUMPAR([L]WWNBRPARALL)    = [F:ASWP]NUMPAR
         [L]WWVALPAR([L]WWNBRPARALL)    = [F:ASWP]VALEUR
         [L]WWNBRPARALL+=1
       Next
    Endif
   Endif
  Endif
 Else
  Read [ACLA]ACLA0 = [L]CODCLA
  If !fstat & find([F:ACLA]TYPCLA,3,4)
      Return
  Endif
  Read [ACLAF]ACLAF0 = [L]CODCLA;[L]CODOBJ
  If !fstat
    #on doit faire la recherche pour les intitulés (pas dans ACLFP)
    If [F:ACLAF]LOBTAB<>""
    Read [ATI]NUMLIG = [F:ACLAF]LOBTAB;1
    If !fstat
     Call CHARGE_CLE([ATI]CODFIC,[F:ATI]DESCRIPT,DOSSIER,"","",3,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBACLA
    Endif
    Endif

    For [ATYR]ATYR0 Where CODTYP=[F:ACLAF]CODTYP & ENARUL=2
     If func AFNC.ACTIV([ATYR]ACTRUL)>0
      For [ATYRP]ATYRP1 Where CODTYP=[ATYR]CODTYP &  TYPRUL=[ATYR]TYPRUL & TRTRUL=[ATYR]TRTRUL  & PRGRUL=[ATYR]PRGRUL
       If !find([ATYRP]PARCOD,"AINSTANCE","APRONAME","AVALUE","AVALCNT","AEXIST","AFORMAT") & !find([ATYRP]PARCOD,[L]WWCODPAR(0..WWNBRPARALL-1)) : # & [ATYRP]PARCLE<>2
        [L]WWCODPAR([L]WWNBRPARALL)     = [ATYRP]PARCOD
        [L]WWNUMPAR([L]WWNBRPARALL)     = [L]WWNBRPARALL+1
        [L]WWTYPKEY([L]WWNBRPARALL)     = 1
        [L]WWINTITPAR([L]WWNBRPARALL)   = func ASYRFNC.TEXTE([ATYRP]PARTIT)
        [L]WWTYPINTPAR([L]WWNBRPARALL)  = [ATYRP]PARTYP
        [L]WWADRVAL([L]WWNBRPARALL)     = [ATYRP]PARMOD
        [L]WWCODCLAPAR([L]WWNBRPARALL)  = [ATYRP]PARCLA
        [L]WWISKEY([L]WWNBRPARALL)      = [ATYRP]PARCLE
        [L]WWNBRPARALL+=1
       Endif
      Next
     Endif
    Next

  Endif
 Endif
Endif
Return
#----------------------------------------------------------#
# load the given parameters into the debug table in screen ASW1
Subprog FILL_PARAM_ASW5(RECHDB,DOSSIER,ACODREP,LNK_AFF, FLDCUR, LNK_COD,TYPPAR,
& CODTYPCUR,WCODPAR,
& WINTITPAR,WTYPINTPAR,WADRVAL,
& WTYPKEY,WISKEY,
& WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WPARFIL,WPARENT,
& WVALPAR,WNBRPARALL)
Value Integer RECHDB
Value Char    DOSSIER
Value Char    ACODREP
Value Integer LNK_AFF
Value Char    FLDCUR
Value Char    LNK_COD
Value Integer TYPPAR
Value Char    CODTYPCUR
Variable Char    WCODPAR()(0..)
Variable Char    WINTITPAR()(0..)
Variable Integer WTYPINTPAR(0..)
Variable Integer WADRVAL(0..)
Variable Integer WTYPKEY(0..)
Variable Integer WISKEY(0..)
Variable Char    WCODCLAPAR()(0..)
Variable Integer WNUMPAR(0..)
Variable Integer WNOLIB(0..)
Variable Integer WLNG(0..)
Variable Integer WTYPAFF(0..)
Variable Integer WPARFIL(0..)
Variable Integer WPARENT(0..)
Variable Char    WVALPAR()(0..)
Variable Integer WNBRPARALL

Local Integer I,J,ISNEW

For I=0 To [L]WNBRPARALL-1
 #pas de clé pour les liens convergence en page ssi STD (AEDIT)
 If TYPPAR=3 & [L]LNK_COD="AEDIT" & [L]LNK_AFF=4 & [L]WTYPKEY(I)=2
  Goto SUIV_ASW5
 Endif
 If TYPPAR=1 & find([L]WCODPAR(I),"AINSTANCE","APRONAME","AEXIST","AVALCNT","AVALUE","AFORMAT")
  Goto SUIV_ASW5
 Endif

 If [L]WPARFIL(I)=0 : [L]WPARFIL(I)=1 : Endif
 If [L]WPARENT(I)=0 : [L]WPARENT(I)=1 : Endif
 J=find(func BUILD_ASW5_IDENT2([L]TYPPAR,[L]LNK_AFF,[L]WTYPKEY(I),[L]LNK_COD,[L]FLDCUR,[L]WCODPAR(I)),[M:ASW5]IDENT2(0..[M:ASW5]NBRPAR-1))
 If J>0
   [L]ISNEW=1
   J=J-1
   If [M:ASW5]STDNEW(J)<>2
    [M:ASW5]STDNEW(J)    = [L]ISNEW
   Endif
   If [M:ASW5]PARFIL(J)<>[L]WPARFIL(I)
&   | [M:ASW5]PARENT(J)<>[L]WPARENT(I)
        [M:ASW5]STDNEW(J)=2
   Endif
 Else
   [L]ISNEW=2
   J=[M:ASW5]NBRPAR
   [M:ASW5]NBRPAR  +=1
   [M:ASW5]STDNEW(J)    = [L]ISNEW
   [M:ASW5]ADRVAL(J)    = [L]WADRVAL(I)
   [M:ASW5]NOLIB(J)     = [L]WNOLIB(I)
   [M:ASW5]LNG(J)       = [L]WLNG(I)
   [M:ASW5]TYPAFF(J)    = [L]WTYPAFF(I)
 Endif
 [M:ASW5]CODTYP(J)    = [L]CODTYPCUR
 [M:ASW5]CODPAR(J)    = [L]WCODPAR(I)
 [M:ASW5]TYPPAR(J)    = [L]TYPPAR
 [M:ASW5]CODFLD(J)    = [L]FLDCUR
 [M:ASW5]CODLNK(J)    = [L]LNK_COD
 [M:ASW5]AFFLNK(J)    = [L]LNK_AFF
 If [M:ASW5]AFFLNK(J)=0 : [M:ASW5]AFFLNK(J)=1 : Endif
 [M:ASW5]INTITPAR(J)  = [L]WINTITPAR(I)
 [M:ASW5]TYPINTPAR(J) = [L]WTYPINTPAR(I)
 [M:ASW5]TYPKEY(J)    = [L]WTYPKEY(I)
 [M:ASW5]ISKEY(J)    = [L]WISKEY(I)
 If [M:ASW5]ISKEY(J)=0 : [M:ASW5]ISKEY(J)  = 1 : Endif
 [M:ASW5]CODCLAPAR(J) = [L]WCODCLAPAR(I)
 [M:ASW5]NUMPAR(J)    = [L]WNUMPAR(I)
 [M:ASW5]PARFIL(J)    = [L]WPARFIL(I)
 [M:ASW5]PARENT(J)    = [L]WPARENT(I)
 [M:ASW5]IDENT2(J)=func BUILD_ASW5_IDENT2([M:ASW5]TYPPAR(J),[M:ASW5]AFFLNK(J),[M:ASW5]TYPKEY(J),[M:ASW5]CODLNK(J),[M:ASW5]CODFLD(J),[M:ASW5]CODPAR(J))


 If [L]ISNEW=2
   If maxtab([L]WVALPAR)>=I : # maxtab([L]WVALPAR)>I
      [M:ASW5]INTVAL(J)    = [L]WVALPAR(I)
      [M:ASW5]VALEUR(J)    = [L]WVALPAR(I)
   Endif
   If [L]RECHDB
    Read [ASWP]ASWP0 = [L]ACODREP;[M:ASW5]TYPPAR(J);[M:ASW5]TYPKEY(J);[M:ASW5]CODFLD(J);[M:ASW5]CODLNK(J);[M:ASW5]AFFLNK(J);[M:ASW5]CODPAR(J)
    If !fstat
      [M:ASW5]STDNEW(J)    = 1 : #ici on n'est plus sur un nouveau param
      If [M:ASW5]PARFIL(J)<>[F:ASWP]PARFIL
&      | [M:ASW5]PARENT(J)<>[F:ASWP]PARENT
        [M:ASW5]STDNEW(J)=2
      Endif
      If [M:ASW5]PARENT(J)=0 : [M:ASW5]PARENT(J)=1 : Endif
      If [M:ASW5]PARFIL(J)=0 : [M:ASW5]PARFIL(J)=1 : Endif
      [M:ASW5]INTVAL(J)    = [ASWP]INTVAL
      [M:ASW5]VALEUR(J)    = [ASWP]VALEUR
      [M:ASW5]NOLIB(J)     = [ASWP]NOLIB
      [M:ASW5]TYPAFF(J)    = [ASWP]TYPAFF
      [M:ASW5]LNG(J)       = [ASWP]LNG
#      If [M:ASW5]TYPKEY(J) = 2 and [ASWP]ADRVAL <> 0 # in case of key for link, the ADRVAL could be redefined
#       [M:ASW5]ADRVAL(J)    = [ASWP]ADRVAL
#      Endif
      If [ASWP]ADRVAL <> 0
       [M:ASW5]ADRVAL(J)    = [ASWP]ADRVAL
      Endif
    Endif
   Endif
   If [M:ASW5]CODPAR(J) = "AENABLE" & [M:ASW5]VALEUR(J)=""
    [M:ASW5]VALEUR(J) = "2"
    [M:ASW5]STDNEW(J)=2
   Endif
 Endif
$SUIV_ASW5
Next

End

#----------------------------------------------------------#
# build the field [F:ASWK]ORDTECLNK
Funprog BUILD_ASWK_ORDTECLNK
Local Integer ORDTECLNK
[L]ORDTECLNK=[F:ASWK]ORDLNK
If [F:ASWK]ORDLNK<=0 : [L]ORDTECLNK=9999 : Endif
If [F:ASWK]AFFLNK=2 : [L]ORDTECLNK+=10000 : Endif
If [F:ASWK]AFFLNK=3 : [L]ORDTECLNK+=20000 : Endif
End [L]ORDTECLNK

#----------------------------------------------------------#
# build the field ASW5.IDENT2
Funprog BUILD_ASW5_IDENT2(TYPPAR,AFFLNK,TYPKEY,CODLNK,CODFLD,CODPAR)
Value Integer TYPPAR,AFFLNK,TYPKEY
Value Char CODLNK,CODFLD,CODPAR
End num$([L]TYPPAR)+"~"+num$([L]AFFLNK)+"~"+[L]CODFLD+"~"+[L]CODLNK+"~"+num$([L]TYPKEY)+"~"+[L]CODPAR

#----------------------------------------------------------#
# build the field ASW6.IDENT2
Funprog BUILD_ASW6_IDENT2(AFFLNK,ANCLNK,CODLNK)
Value Integer AFFLNK
Value Char ANCLNK,CODLNK
End num$([L]AFFLNK)+"~"+[L]ANCLNK+"~"+[L]CODLNK

#----------------------------------------------------------#
# remove the given parameters from the debug table in screen ASW1
Subprog REMOVE_PARAM_ASW5(PAR_AFF,PAR_ANC,PAR_LNK,PAR_TYP)
Value Integer PAR_AFF
Value Char PAR_ANC
Value Char PAR_LNK
Value Integer PAR_TYP # ML59:  1-property parameter  2-exposed pro parameter  3-link parameter
 Local Integer I
 For I=0 To [M:ASW5]NBRPAR-1
  If [M:ASW5]TYPPAR(I)=PAR_TYP & [M:ASW5]AFFLNK(I)=PAR_AFF & [M:ASW5]CODFLD(I)=PAR_ANC & [M:ASW5]CODLNK(I)=PAR_LNK
    Dela I,1 [M:ASW5]NBRPAR
    [M:ASW5]NBRPAR -= 1
    I-=1
  Endif
 Next I
End

#----------------------------------------#
Subprog VERIF_PARAM_ASW5(ACTIONVERIF,REP_COD,FLD,LNK,ERRMES,ERRFLG)
Value Integer ACTIONVERIF
Value Char REP_COD
Value Integer FLD,LNK
Variable Char ERRMES()(1..)
Variable Integer ERRFLG (1..)

Local Integer I,J,NOLASW6
Local Integer ONOLASW6,AS_LOKREFANC, IS_LNKOK
Local Char L_ERR_MSG(250), L_PARCOL(GLONAVC)
Local Char VALEUR(255),PARACT(GLONACV)
#Local Char OLDCODFLD(255)
#Local Char OLDFLDGRP(255)
#Local Integer REF_CODFLD,AS_REFKEY
Gosub SORTA_ASW5 From SUBASW
# verify that each parameter/key related to the properties has a value that is coherent with the type
For I=0 To [M:ASW5]NBRPAR-1
  L_PARCOL = ""
  If [M:ASW5]TYPPAR(I)=1 & FLD & [M:ASW5]ISKEY(I)<>2

#  If [L]OLDCODFLD<>"" & [L]OLDCODFLD<>[M:ASW5]CODFLD(I)
#    If [L]REF_CODFLD=0 & [L]AS_REFKEY=1
#      If [L]OLDFLDGRP=""
#        L_ERR_MSG = mess(34,140,1)-'"'+[L]OLDCODFLD+'"'-func AFNC.MES1(mess(217,143,1),[L]OLDCODFLD)
#      Else
#        L_ERR_MSG = mess(34,140,1)-'"'+[L]OLDCODFLD+'"'-func AFNC.MES1(mess(217,143,1),[L]OLDFLDGRP+"."+[L]OLDCODFLD)
#      Endif
#      Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
#    Endif
#    [L]REF_CODFLD=0
#    [L]AS_REFKEY=0
#  Endif
  #If [M:ASW5]CODPAR(I)<>"AFILTER"
   J = find([M:ASW5]CODFLD(I), [M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
   If J > 0
    L_PARCOL = [M:ASW9]FLDGRP(J-1)
    [L]VALEUR=[M:ASW5]VALEUR(I)
    If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW9]CODFLD(J-1),[M:ASW9]CODTYP(J-1),[M:ASW5]CODPAR(I),[M:ASW9]ACTFLD(J-1),[L]VALEUR, [M:ASW5]TYPINTPAR(I), [M:ASW5]ADRVAL(I), L_PARCOL,
& [L]REP_COD, 1,0,0,
& 0,0,0,0,0, [M:ASW5]TYPAFF(I), L_ERR_MSG)
     If ACTIONVERIF
      If [M:ASW5]TYPKEY(I) = 2
       L_ERR_MSG = mess(34,140,1)-'"'+[M:ASW5]CODFLD(I)+'"'-mess(51,140,1)-'"'+[M:ASW5]CODPAR(I)+'" : '+L_ERR_MSG
      Else
       L_ERR_MSG = mess(34,140,1)-'"'+[M:ASW5]CODFLD(I)+'"'-mess(50,140,1)-'"'+[M:ASW5]CODPAR(I)+'" : '+L_ERR_MSG
      Endif
      Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG) From SUBASW
     Endif
    Endif
   Endif
  #Endif
#  If [M:ASW5]TYPKEY(I)=2 & [M:ASW9]LOBTAB(J-1)=""
#    [L]AS_REFKEY=1
#    If [M:ASW9]FLDGRP(J-1)=""
#      If find([M:ASW5]VALEUR(I),[M:ASW5]CODFLD(I),"=num$("+[M:ASW5]CODFLD(I)+")","=val("+[M:ASW5]CODFLD(I)+")")
#        [L]REF_CODFLD=1
#      Endif
#    Else
#      If find([M:ASW5]VALEUR(I),[M:ASW9]FLDGRP(J-1)+"."+[M:ASW5]CODFLD(I),"=num$("+[M:ASW9]FLDGRP(J-1)+"."+[M:ASW5]CODFLD(I)+")","=val("+[M:ASW9]FLDGRP(J-1)+"."+[M:ASW5]CODFLD(I)+")")
#        [L]REF_CODFLD=1
#      Endif
#    Endif
#  Endif
#  [L]OLDCODFLD=[M:ASW5]CODFLD(I)
#  [L]OLDFLDGRP=[M:ASW9]FLDGRP(J-1)

 Elsif [M:ASW5]TYPPAR(I)=3 & LNK & [M:ASW5]STDNEW(I)<>0

  NOLASW6=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW5]AFFLNK(I),[M:ASW5]CODFLD(I),[M:ASW5]CODLNK(I)),[M:ASW6]IDENT2(0..[M:ASW6]NBRLNK-1))
  If NOLASW6>0 & [M:ASW6]STDNEW(NOLASW6-1)<>0 & [M:ASW6]ENALNK(NOLASW6-1)=2 & [M:ASW6]REMSTDLNK(NOLASW6-1)=""

   If ONOLASW6<>NOLASW6
    If ONOLASW6<>0 & [M:ASW6]CMPLNK(ONOLASW6-1)=9 & [L]AS_LOKREFANC=0
     If ACTIONVERIF
      L_ERR_MSG = func AFNC.MES2(mess(209,143,1),[M:ASW6]CODLNK(ONOLASW6-1),mess([M:ASW6]AFFLNK(ONOLASW6-1),7965,1)-[M:ASW6]ANCLNK(ONOLASW6-1))-':'-func AFNC.MES1(mess(224,143,1),mess(1,34,1))
      Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG) From SUBASW
     Endif
     Call _LNK_INVALID_ASW6(ACTIONVERIF,ONOLASW6-1)
    Endif
    [L]AS_LOKREFANC=0
    If [M:ASW6]INVLNK(NOLASW6-1)=2 : [M:ASW6]INVLNK(NOLASW6-1)=1 : Endif
   Endif

   Case [M:ASW5]AFFLNK(I)
    When 1: #property
     If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]REP_COD
     L_PARCOL = func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW5]CODFLD(I),1)
     Else
     L_PARCOL = func SUBASW_TOOL.GET_COL_FROM_PRO_PATH([F:ASW]CODREP,[F:ASW]CODCLA,[F:ASW]ABRCLA,[M:ASW5]CODFLD(I),1)
     Endif
    When 2: #collection line
      L_PARCOL = [M:ASW5]CODFLD(I)
   Endcase

   [L]VALEUR=[M:ASW5]VALEUR(I)
   If [M:ASW5]AFFLNK(I)=1: #property
     If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]REP_COD
      For J=0 To [M:ASW4]NBRPRO-1
       If [M:ASW4]CODPRO(J)=[M:ASW5]CODFLD(I)
        If func AFNC.ACTIV([M:ASW6]ACVLNK(NOLASW6-1))
         PARACT=[M:ASW4]ACTPRO(J)
        Else
         PARACT=[M:ASW6]ACVLNK(NOLASW6-1)
        Endif
        Gosub _VERIF_PARAM_ASWK
       Endif
      Next
     Else
      For [ASWR]ASWR0 Where CODREP = [L]REP_COD and CODPRO=[M:ASW5]CODFLD(I)
       If func AFNC.ACTIV([M:ASW6]ACVLNK(NOLASW6-1))
        PARACT=[F:ASWR]ACTPRO
       Else
        PARACT=[M:ASW6]ACVLNK(NOLASW6-1)
       Endif
       Gosub _VERIF_PARAM_ASWK
      Next
     Endif
   Else
    PARACT=[M:ASW6]ACVLNK(NOLASW6-1)
    Gosub _VERIF_PARAM_ASWK
   Endif
   If [M:ASW6]CMPLNK(NOLASW6-1)=9 & [M:ASW5]TYPKEY(I)=2 & [M:ASW5]ADRVAL(I)=1 & [M:ASW5]VALEUR(I)=[M:ASW6]ANCLNK(NOLASW6-1)
    [L]AS_LOKREFANC=1
   Endif
   ONOLASW6=NOLASW6
  Endif
 Endif

Next
#If [L]OLDCODFLD<>""
#  If [L]REF_CODFLD=0 & [L]AS_REFKEY=1
#    If [L]OLDFLDGRP=""
#      L_ERR_MSG = mess(34,140,1)-'"'+[L]OLDCODFLD+'"'-func AFNC.MES1(mess(217,143,1),[L]OLDCODFLD)
#    Else
#      L_ERR_MSG = mess(34,140,1)-'"'+[L]OLDCODFLD+'"'-func AFNC.MES1(mess(217,143,1),[L]OLDFLDGRP+"."+[L]OLDCODFLD)
#    Endif
#    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG)
#  Endif
#Endif
If ONOLASW6<>0
  If [M:ASW6]CMPLNK(ONOLASW6-1)=9 & [L]AS_LOKREFANC=0
   If ACTIONVERIF
    L_ERR_MSG = func AFNC.MES2(mess(209,143,1),[M:ASW6]CODLNK(ONOLASW6-1),mess([M:ASW6]AFFLNK(ONOLASW6-1),7965,1)-[M:ASW6]ANCLNK(ONOLASW6-1))-':'-func AFNC.MES1(mess(224,143,1),mess(1,34,1))
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG) From SUBASW
   Endif
   Call _LNK_INVALID_ASW6(ACTIONVERIF,ONOLASW6-1)
  Endif
Endif
End

$_VERIF_PARAM_ASWK
    If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW5]CODFLD(I),"",[M:ASW5]CODPAR(I),PARACT,[L]VALEUR, [M:ASW5]TYPINTPAR(I), [M:ASW5]ADRVAL(I), L_PARCOL,
&         [L]REP_COD, 2-ACTIONVERIF,1,[M:ASW6]CMPLNK(NOLASW6-1),
&         [M:ASW6]DETLNK(NOLASW6-1),[M:ASW6]QRYLNK(NOLASW6-1),[M:ASW6]EDILNK(NOLASW6-1),[M:ASW6]LOKLNK(NOLASW6-1),[M:ASW6]SUMLNK(NOLASW6-1),
&         max([M:ASW5]TYPAFF(I),[M:ASW5]PARFIL(I),[M:ASW5]PARENT(I)),
&         L_ERR_MSG)
     If ACTIONVERIF
      If [M:ASW5]TYPKEY(I) = 2
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW5]CODLNK(I), mess([M:ASW5]AFFLNK(I),7965,1)-[M:ASW5]CODFLD(I))+' : '+mess(51,140,1)-'"'+[M:ASW5]CODPAR(I)+'" : '+L_ERR_MSG
      Else
       L_ERR_MSG = func AFNC.MES2( mess(209,143,1),[M:ASW5]CODLNK(I), mess([M:ASW5]AFFLNK(I),7965,1)-[M:ASW5]CODFLD(I))+' : '+mess(50,140,1)-'"'+[M:ASW5]CODPAR(I)+'" : '+L_ERR_MSG
      Endif
      Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG) From SUBASW
     Endif
     Call _LNK_INVALID_ASW6(ACTIONVERIF,NOLASW6-1)
    Endif
Return
#----------------------------------------#
Subprog _LNK_INVALID_ASW6(ACTIONVERIF,NOL)
Value Integer ACTIONVERIF,NOL
If [M:ASW6]INVLNK(NOL)<>2
  [M:ASW6]INVLNK(NOL)=2
Endif
If !ACTIONVERIF & [M:ASW6]FLGSTDLNK(NOL)=2
  If [M:ASW6]ENALNK(NOL)=2
    [M:ASW6]ENALNK(NOL)=1
  Endif
  If [M:ASW6]STDNEW(NOL)<>2
    [M:ASW6]STDNEW(NOL)=2
  Endif
Endif
End

#Use in SUBASW3/AM_xxxx
$AM_ASWP_INVLNK
Local Integer I,J
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2(0..[M:ASW6]NBRLNK-1))
If I>0 & [M:ASW6]FLGSTDLNK(I-1)=2 & [M:ASW6]ENALNK(I-1)<>2 & [M:ASW6]INVLNK(I-1)=2
  [M:ASW6]ENALNK(I-1)=2 : Affzo [M:ASW6]ENALNK(I-1)
  [M:ASW6]INVLNK(I-1)=1 : Affzo [M:ASW6]INVLNK(I-1)
  For J=0 To [M:ASW7]WNBLNK-1
   If [M:ASW6]IDENT2(I-1)=func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]WAFFLNK(J),[M:ASW7]WANCLNK(J),[M:ASW7]WCODLNK(J))
    [M:ASW7]WENALNK(J)=2 : Affzo [M:ASW7]WENALNK(J)
    [M:ASW7]WINVLNK(J)=1 : Affzo [M:ASW7]WINVLNK(J)
    Break
   Endif
  Next
Endif
Return

#----------------------------------------------------------#
# display the parameters/links for the current selected link in screen ASWH7
Subprog DISPLAY_PARLNK_ASW7(LNK_AFF,LNK_ANC,LNK_COD)
Value Integer LNK_AFF
Value Char LNK_ANC
Value Char LNK_COD

Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2(LNK_AFF,LNK_ANC,LNK_COD),[M:ASW6]IDENT2(0..[M:ASW6]NBRLNK-1))

Local Integer J,K

Gosub SORTA_ASW5 From SUBASW
Gosub AFFZO_ASW5 From SUBASW

[M:ASW7]NBRPARLNK = 0
[M:ASW7]NBCLELNK = 0

For J=0 To [M:ASW5]NBRPAR-1
 If [M:ASW5]TYPPAR(J)=3 & [M:ASW5]AFFLNK(J)=LNK_AFF & [M:ASW5]CODFLD(J)=LNK_ANC & [M:ASW5]CODLNK(J)=LNK_COD
  If [M:ASW5]TYPKEY(J)=2
   [M:ASW7]CODCLELNK([M:ASW7]NBCLELNK) = [M:ASW5]CODPAR(J)
   [M:ASW7]INTCLELNK([M:ASW7]NBCLELNK) = [M:ASW5]INTITPAR(J)
   [M:ASW7]TYPCLELNK([M:ASW7]NBCLELNK) = [M:ASW5]TYPINTPAR(J)
   [M:ASW7]MODCLELNK([M:ASW7]NBCLELNK) = [M:ASW5]ADRVAL(J)
   [M:ASW7]VALCLELNK([M:ASW7]NBCLELNK) = [M:ASW5]VALEUR(J)
   [M:ASW7]NBCLELNK += 1
  Elsif [M:ASW5]TYPKEY(J)=3
  #104754/3
  #le typkey=1 est déjà dans le tableau
    For K=0 To [M:ASW7]NBRPARLNK-1
     If [M:ASW7]CODPARLNK(K)   = [M:ASW5]CODPAR(J) & [M:ASW7]AFFPARLNK(K)=2
       [M:ASW7]VALPARFINLNK(K)   = [M:ASW5]VALEUR(J)
     Endif
    Next
  Else
   [M:ASW7]CODPARLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]CODPAR(J)
   [M:ASW7]DESPARLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]INTITPAR(J)
   [M:ASW7]TYPPARLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]TYPINTPAR(J)
   [M:ASW7]MODPARLNK([M:ASW7]NBRPARLNK)  =  [M:ASW5]ADRVAL(J)
   If [M:ASW6]TYPLNK(I-1)=6   #104754/3
    [M:ASW7]VALPARDEBLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]VALEUR(J)
   Else
    [M:ASW7]VALPARLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]VALEUR(J)
   Endif
   [M:ASW7]MNLPARLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]NOLIB(J)
   [M:ASW7]AFFPARLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]TYPAFF(J)
   #Saisie
   If [M:ASW7]AFFPARLNK([M:ASW7]NBRPARLNK)=0 : [M:ASW7]AFFPARLNK([M:ASW7]NBRPARLNK)=1 : Endif
   [M:ASW7]PARFILLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]PARFIL(J)
   [M:ASW7]PARENTLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]PARENT(J)
   [M:ASW7]LNGPARLNK([M:ASW7]NBRPARLNK)   = [M:ASW5]LNG(J)
   [M:ASW7]NBRPARLNK += 1
  Endif
 Endif
Next
Affzo [M:ASW7]10
Affzo [M:ASW7]15
# Suppresion colonnes
Case [M:ASW6]TYPLNK(I-1)
 When 6
  Chgfmt [M:ASW7]VALPARFINLNK With "K:250X"
  Chgfmt [M:ASW7]VALPARDEBLNK With "K:250X"
  Chgfmt [M:ASW7]VALPARLNK With "-K:250X"
  Chgfmt [M:ASW7]PARFILLNK With "-K:250X"
  Chgfmt [M:ASW7]PARENTLNK With "-K:250X"
  Chgfmt [M:ASW7]MODPARLNK With "-K:X"
 When Default
  Chgfmt [M:ASW7]VALPARFINLNK With "-K:250X"
  Chgfmt [M:ASW7]VALPARDEBLNK With "-K:250X"
  Chgfmt [M:ASW7]VALPARLNK With "K:250X"
  Chgfmt [M:ASW7]PARFILLNK With "K:250X"
  Chgfmt [M:ASW7]PARENTLNK With "K:250X"
  Chgfmt [M:ASW7]MODPARLNK With "K:X"
Endcase
For J=0 To [M:ASW7]NBRPARLNK-1
  #104754/3
  If [M:ASW6]TYPLNK(I-1)=6 | [M:ASW6]TYPLNK(I-1)=4 | [M:ASW6]TYPLNK(I-1)=3 | [M:ASW6]CMPLNK(I-1)=19
    Grizo [M:ASW7]AFFPARLNK(J)
    Grizo [M:ASW7]MNLPARLNK(J)
    Grizo [M:ASW7]LNGPARLNK(J)
  Elsif [M:ASW7]PARFILLNK(J)=2 | [M:ASW7]PARENTLNK(J)=2
    Grizo [M:ASW7]AFFPARLNK(J)
    Actzo [M:ASW7]MNLPARLNK(J)
    Actzo [M:ASW7]LNGPARLNK(J)
  Else
    Actzo [M:ASW7]AFFPARLNK(J)
    Actzo [M:ASW7]MNLPARLNK(J)
    Actzo [M:ASW7]LNGPARLNK(J)
  Endif
  #104754/3
  If [M:ASW6]TYPLNK(I-1)=6
    Grizo [M:ASW7]VALPARLNK(J)
    Actzo [M:ASW7]VALPARDEBLNK(J)
    If [M:ASW7]AFFPARLNK(J)=2
     Actzo [M:ASW7]VALPARFINLNK(J)
    Else
     Grizo [M:ASW7]VALPARFINLNK(J)
    Endif
  Elsif [M:ASW6]CMPLNK(I-1)=19
    Grizo [M:ASW7]VALPARLNK(J)
    Grizo [M:ASW7]VALPARDEBLNK(J)
    Grizo [M:ASW7]VALPARFINLNK(J)
  Else
    Actzo [M:ASW7]VALPARLNK(J)
    Grizo [M:ASW7]VALPARDEBLNK(J)
    Grizo [M:ASW7]VALPARFINLNK(J)
  Endif
Next
For J=0 To [M:ASW7]NBCLELNK-1
  If [M:ASW6]CMPLNK(I-1)=19
    Grizo [M:ASW7]MODCLELNK(J)
    Grizo [M:ASW7]VALCLELNK(J)
  Else
    Actzo [M:ASW7]MODCLELNK(J)
    Actzo [M:ASW7]VALCLELNK(J)
  Endif
Next
End


#----------------------------------------------------------#
# display the links for the current selected link anchor type and anchor
Subprog DISPLAY_LNK_ASW7(STYLE,LNK_AFF, LNK_ANC, LNK_STD, LNK_INV)
Value Integer STYLE
Value Integer LNK_AFF
Value Char LNK_ANC
Value Integer LNK_STD,LNK_INV

Local Integer J
GBIDI1=LNK_INV
GBIDI2=LNK_STD
GBIDI3=LNK_AFF
GBIDC3=LNK_ANC
GBIDC2=[M:ASW0]CODREP


#Effzo [M:ASW7]10 : #paramètres
#Effzo [M:ASW7]15 : #clés
#Effzo [M:ASW7]30 : #liens
#Raz [M:ASW7]ANCLNKCUR
#Raz [M:ASW7]AFFLNKCUR
#Raz [M:ASW7]CODLNKCUR
#Raz [M:ASW7]TYPLNKCUR

Raz [M:ASW7]
Chgstl [M:ASW7]WNBLNK With ""
Actzo [M:ASW7]WNBLNK
[M:ASW7]TYPANCLNK=LNK_AFF
[M:ASW7]CODANCLNK=LNK_ANC
[M:ASW7]OPTSTDLNK=LNK_STD
[M:ASW7]OPTINVLNK=LNK_INV

Gosub SORTA_ASW6 From SUBASW
Gosub AFFZO_ASW6 From SUBASW

[M:ASW7]WNBLNK = 0
Affzo [M:ASW7]3

For J=0 To [M:ASW6]NBRLNK-1
 If [M:ASW6]AFFLNK(J) = LNK_AFF & (LNK_ANC = "" or [M:ASW6]ANCLNK(J)=LNK_ANC)
  If (LNK_STD=2 | [M:ASW6]FLGSTDLNK(J)<>2) & (LNK_INV=1 | [M:ASW6]INVLNK(J)=2)
    [M:ASW7]WCODLNK([M:ASW7]WNBLNK) = [M:ASW6]CODLNK(J)
    [M:ASW7]WINTITLNK([M:ASW7]WNBLNK) = [M:ASW6]INTITLNK(J)
    [M:ASW7]WINTLNK([M:ASW7]WNBLNK) = [M:ASW6]INTLNK(J)
    [M:ASW7]WTYPLNK([M:ASW7]WNBLNK) = [M:ASW6]TYPLNK(J)
    [M:ASW7]WREPLNK([M:ASW7]WNBLNK) = [M:ASW6]REPLNK(J)
    [M:ASW7]WCMPLNK([M:ASW7]WNBLNK) = [M:ASW6]CMPLNK(J)
    [M:ASW7]WTARLNK([M:ASW7]WNBLNK) = [M:ASW6]TARLNK(J)
    If [M:ASW7]WTARLNK([M:ASW7]WNBLNK)=0 : [M:ASW7]WTARLNK([M:ASW7]WNBLNK)=1 : Endif
    [M:ASW7]WCLAPTRLNK([M:ASW7]WNBLNK) = [M:ASW6]CLAPTRLNK(J)
    [M:ASW7]WCLALNK([M:ASW7]WNBLNK) = [M:ASW6]CLALNK(J)
    [M:ASW7]WMETLNK([M:ASW7]WNBLNK) = [M:ASW6]METLNK(J)
    [M:ASW7]WFLGASYLNK([M:ASW7]WNBLNK) = [M:ASW6]FLGASYLNK(J)
    [M:ASW7]WCODFNCLNK([M:ASW7]WNBLNK) = [M:ASW6]CODFNCLNK(J)
    [M:ASW7]WFREELNK([M:ASW7]WNBLNK) = [M:ASW6]FREELNK(J)
    [M:ASW7]WRPTCOD([M:ASW7]WNBLNK) = [M:ASW6]RPTCOD(J):#104754/3
    [M:ASW7]WMENLNK([M:ASW7]WNBLNK) = [M:ASW6]MENLNK(J)
    [M:ASW7]WORDLNK([M:ASW7]WNBLNK) = [M:ASW6]ORDLNK(J)
    [M:ASW7]WAFFLNK([M:ASW7]WNBLNK) = [M:ASW6]AFFLNK(J)
    [M:ASW7]WANCLNK([M:ASW7]WNBLNK) = [M:ASW6]ANCLNK(J)
    [M:ASW7]WATTLNK([M:ASW7]WNBLNK) = [M:ASW6]ATTLNK(J)
    If [M:ASW7]WATTLNK([M:ASW7]WNBLNK)=0 : [M:ASW7]WATTLNK([M:ASW7]WNBLNK)=1 : Endif
    [M:ASW7]WFLGSTDLNK([M:ASW7]WNBLNK) = [M:ASW6]FLGSTDLNK(J)
    [M:ASW7]WREMSTDLNK([M:ASW7]WNBLNK) = [M:ASW6]REMSTDLNK(J)
    [M:ASW7]WACVLNK([M:ASW7]WNBLNK) = [M:ASW6]ACVLNK(J)
    [M:ASW7]WDETLNK([M:ASW7]WNBLNK) = [M:ASW6]DETLNK(J)
    [M:ASW7]WQRYLNK([M:ASW7]WNBLNK) = [M:ASW6]QRYLNK(J)
    [M:ASW7]WEDILNK([M:ASW7]WNBLNK) = [M:ASW6]EDILNK(J)
    [M:ASW7]WLOKLNK([M:ASW7]WNBLNK) = [M:ASW6]LOKLNK(J)
    [M:ASW7]WSUMLNK([M:ASW7]WNBLNK) = [M:ASW6]SUMLNK(J)
    [M:ASW7]WENALNK([M:ASW7]WNBLNK) = [M:ASW6]ENALNK(J)
    [M:ASW7]WINVLNK([M:ASW7]WNBLNK) = [M:ASW6]INVLNK(J)
    [M:ASW7]WNBLNK += 1
  Endif
 Endif
Next J
Affzo [M:ASW7]30
If [L]STYLE
  For J=0 To [M:ASW7]WNBLNK-1
    Call ACTZO_ASW7(J)
  Next J
Endif
End

Subprog ACTZO_ASW7(NOL)
Value Integer NOL
End
If [M:ASW7]WFLGSTDLNK(NOL)=2
  Grizo [M:ASW7]WCODLNK(NOL)
  Grizo [M:ASW7]WINTITLNK(NOL)
  Grizo [M:ASW7]WINTLNK(NOL)
  Grizo [M:ASW7]WTYPLNK(NOL)
  Grizo [M:ASW7]WREPLNK(NOL)
  Grizo [M:ASW7]WCMPLNK(NOL)
  Grizo [M:ASW7]WCLAPTRLNK(NOL)
  Grizo [M:ASW7]WCLALNK(NOL)
