  Grizo [M:ASW7]WAFFLNK(NOL)
  Grizo [M:ASW7]WANCLNK(NOL)
  Grizo [M:ASW7]WATTLNK(NOL)
  Grizo [M:ASW7]WFLGSTDLNK(NOL)
 #Grizo [M:ASW7]WREMSTDLNK(NOL)
 #Grizo [M:ASW7]WACVLNK(NOL)
  Grizo [M:ASW7]WDETLNK(NOL)
  Grizo [M:ASW7]WQRYLNK(NOL)
  Grizo [M:ASW7]WEDILNK(NOL)
  Grizo [M:ASW7]WLOKLNK(NOL)
  Grizo [M:ASW7]WSUMLNK(NOL)
 #Grizo [M:ASW7]WENALNK(NOL)
 #Grizo [M:ASW7]WINVLNK(NOL)
Else
  Actzo [M:ASW7]WCODLNK(NOL)
  Actzo [M:ASW7]WINTITLNK(NOL)
  Actzo [M:ASW7]WINTLNK(NOL)
  Actzo [M:ASW7]WTYPLNK(NOL)
  Actzo [M:ASW7]WREPLNK(NOL)
  Actzo [M:ASW7]WCMPLNK(NOL)
  Actzo [M:ASW7]WCLAPTRLNK(NOL)
  Actzo [M:ASW7]WCLALNK(NOL)
  Actzo [M:ASW7]WMETLNK(NOL)
  Actzo [M:ASW7]WFLGASYLNK(NOL)
  Actzo [M:ASW7]WCODFNCLNK(NOL)
  Actzo [M:ASW7]WFREELNK(NOL)
  Actzo [M:ASW7]WRPTCOD(NOL):#104754/3
 #Actzo [M:ASW7]WMENLNK(NOL)
 #Actzo [M:ASW7]WORDLNK(NOL)
  Actzo [M:ASW7]WAFFLNK(NOL)
  Actzo [M:ASW7]WANCLNK(NOL)
  Actzo [M:ASW7]WATTLNK(NOL)
  Actzo [M:ASW7]WFLGSTDLNK(NOL)
 #Actzo [M:ASW7]WREMSTDLNK(NOL)
 #Actzo [M:ASW7]WACVLNK(NOL)
  Actzo [M:ASW7]WDETLNK(NOL)
  Actzo [M:ASW7]WQRYLNK(NOL)
  Actzo [M:ASW7]WEDILNK(NOL)
  Actzo [M:ASW7]WLOKLNK(NOL)
  Actzo [M:ASW7]WSUMLNK(NOL)
 #Actzo [M:ASW7]WENALNK(NOL)
 #Actzo [M:ASW7]WINVLNK(NOL)
Endif
End

#**
#* example:
#* - case 1: AAA.BBB.CCC is accessible from AAA.BBB.CCC because there're the same
#* - case 2: AAA.BBB is accessible from AAA.BBB.CCC because AAA.BBB.CCC begins with AAA.BBB.
#* - case 3: AAA.BBB.CCC is NOT accessible from AAA.BBB because it does not satisfy the conditions given in case 1&2
#* @param COL_CUR
#* @param COL_TO_ACCESS
#*!
Funprog IS_COLLECTION_ACCESSIBLE(COL_CUR, COL_TO_ACCESS)
Value Char COL_CUR, COL_TO_ACCESS
Local Integer RES_OK
 If toupper(COL_CUR) = toupper(COL_TO_ACCESS)
  RES_OK = 1
 Elsif toupper(left$(COL_CUR,len(COL_TO_ACCESS)+1)) = toupper(COL_TO_ACCESS) + "."
  RES_OK = 1
 Endif
End RES_OK

Funprog IS_CLA_KEY(LNK_ANC,PROATY,CODCLA,ABRCLA)
Value Char LNK_ANC,PROATY,CODCLA,ABRCLA

Read [ATY]CODTYP=PROATY
If fstat : End 0 : Endif
If [F:ATY]CODCLA<>CODCLA : End 0 : Endif

Local Integer PROCLE,I
Local Instance  ACLA Using C_ACLA
Local Instance AERR(1..)  Using C_AERROR


ACLA  = NewInstance C_ACLA AllocGroup null
Read [ACLA]ACLA0=[L]CODCLA
SetInstance ACLA With [F:ACLA]
Call CHARGE_ACLE([L]CODCLA,ACLA,AERR) From ACLAVALLEC
If maxtab(AERR)>0  : Goto FIN_CLA_KEY : Endif

#indic dernière cle
For I=1 To ACLA.NBCLEREF
  Read [ACLAF]ACLAF0 = [L]CODCLA;ACLA.ACLAI(I).CLEREF
  If !fstat & [F:ACLAF]FLDGRP<>""
    If [L]ABRCLA+"."+[F:ACLAF]FLDGRP+"."+ACLA.ACLAI(I).CLEREF=[L]LNK_ANC
      [L]PROCLE=1
      Break
    Endif
  Else
    If [L]ABRCLA+"."+ACLA.ACLAI(I).CLEREF=[L]LNK_ANC
      [L]PROCLE=1
      Break
    Endif
  Endif
Next

$FIN_CLA_KEY
If ACLA<>null
  FreeGroup ACLA
Endif
If AERR<>null
  FreeGroup AERR
Endif
End [L]PROCLE
#----------------------------------------------------------#
Subprog LOAD_FLDGRP(CODCLA,ABR,TAB_COD,TAB_MIN,TAB_MAX,TAB_CLA,TAB_NB)
Value Char CODCLA
Value Char ABR
Variable Char TAB_COD()(1..)
Variable Char TAB_MIN()(1..)
Variable Char TAB_MAX()(1..)
Variable Char TAB_CLA()(1..)
Variable Integer TAB_NB

Local Char L_CODCLA(GLONACLA)
Local Char L_CLA_ABR(200)(1..100)
Local Char L_CLA_COD(GLONACLA)(1..100)
Local Integer L_CLA_NB, I


Read [F:ACLA2]ACLA0 = [L]CODCLA
If !fstat
 L_CODCLA = [F:ACLA2]CODCLA
 For [ACLAC2] Where CODCLA=L_CODCLA
  If TAB_NB = dim(TAB_COD)
   Break
  Endif
  TAB_NB += 1
  TAB_COD(TAB_NB)  = [L]ABR+"."+[ACLAC2]CODCOL
  TAB_MIN(TAB_NB)  = mess([ACLAC2]MINCOL,7966,1)
  TAB_MAX(TAB_NB)  = num$([ACLAC2]MAXCOL)
  TAB_CLA(TAB_NB)  = [F:ACLA2]CODCLA
 Next
Endif
If TAB_NB = dim(TAB_COD)
 End
Endif

If L_CODCLA <> ""
 For [ACLAF2]ACLAF1 Where CODCLA=L_CODCLA & LNKCLA<>""
  L_CLA_NB+=1
  L_CLA_ABR(L_CLA_NB) = ABR+"."+[ACLAF2]FLDCLA
  L_CLA_COD(L_CLA_NB) = [ACLAF2]LNKCLA
 Next
 For I = 1 To L_CLA_NB
  Call LOAD_FLDGRP(L_CLA_COD(I),L_CLA_ABR(I),TAB_COD,TAB_MIN,TAB_MAX,TAB_CLA,TAB_NB)
 Next
Endif

End


#----------------------------------------------------------#
Subprog LOAD_FLDGRP_COMPLETE(CODCLA,ABR,TAB_COD,TAB_LIB,TAB_MIN,TAB_ACT,TAB_MAX,TAB_COM,TAB_INS,TAB_SUP,TAB_TRI,TAB_APD,TAB_CLA,TAB_NB)
Value Char CODCLA
Value Char ABR
Variable Char TAB_COD()(1..)
Variable Char TAB_LIB()(1..)
Variable Integer TAB_MIN(1..)
Variable Char TAB_ACT()(1..)
Variable Integer TAB_MAX(1..)
Variable Char TAB_COM()(1..)
Variable Integer TAB_INS(1..)
Variable Integer TAB_SUP(1..)
Variable Integer TAB_TRI(1..)
Variable Integer TAB_APD(1..)
Variable Char TAB_CLA()(1..)
Variable Integer TAB_NB

Local Char L_CODCLA(GLONACLA)
Local Char L_CLA_ABR(250)(1..100)
Local Char L_CLA_COD(GLONACLA)(1..100)
Local Integer L_CLA_NB, I
Read [F:ACLA2]ACLA0 = [L]CODCLA
If !fstat
 L_CODCLA = [F:ACLA2]CODCLA
 For [ACLAC2] Where CODCLA=L_CODCLA
  If TAB_NB = dim(TAB_COD)
   Break
  Endif
  TAB_NB += 1
  TAB_COD(TAB_NB)  = [L]ABR+"."+[ACLAC2]CODCOL
  TAB_LIB(TAB_NB)= func ASYRFNC.TEXTE([F:ACLAC2]INTCOL)
  TAB_MIN(TAB_NB)  = [ACLAC2]MINCOL
  TAB_ACT(TAB_NB)  = [ACLAC2]ACTCOL
  TAB_MAX(TAB_NB)  = [ACLAC2]MAXCOL
  If [ACLAC2]PROCOL<>""
   TAB_COM(TAB_NB)  = [L]ABR+"."+[ACLAC2]PROCOL
  Endif
  TAB_INS(TAB_NB)  = [ACLAC2]FLGINSCOL
  TAB_SUP(TAB_NB)  = [ACLAC2]FLGSUPCOL
  TAB_TRI(TAB_NB)  = [ACLAC2]FLGTRICOL
  TAB_APD(TAB_NB)  = [ACLAC2]FLGAPDCOL
  TAB_CLA(TAB_NB)  = [F:ACLA2]CODCLA
 Next
Endif
If TAB_NB = dim(TAB_COD)
 End
Endif

If L_CODCLA <> ""
 For [ACLAF2]ACLAF1 Where CODCLA=L_CODCLA & LNKCLA<>""
  L_CLA_NB+=1
  L_CLA_ABR(L_CLA_NB) = ABR+"."+[ACLAF2]FLDCLA
  L_CLA_COD(L_CLA_NB) = [ACLAF2]LNKCLA
 Next
 For I = 1 To L_CLA_NB
  Call LOAD_FLDGRP_COMPLETE(L_CLA_COD(I),L_CLA_ABR(I),TAB_COD,TAB_LIB,TAB_MIN,TAB_ACT,TAB_MAX,TAB_COM,TAB_INS,TAB_SUP,TAB_TRI,TAB_APD,TAB_CLA,TAB_NB)
 Next
Endif

End


#----------------------------------------------------------#
Subprog LOAD_CHILD_CLASSES(CODCLA,ABR,TAB_COD,TAB_CLA,TAB_NB)
Value Char CODCLA
Value Char ABR
Variable Char TAB_COD()(1..)
Variable Char TAB_CLA()(1..)
Variable Integer TAB_NB

Local Char L_CODCLA(GLONACLA)
Local Char L_CLA_ABR(250)(1..100)
Local Char L_CLA_COD(GLONACLA)(1..100)
Local Integer L_CLA_NB, I

If [L]CODCLA <> "" and TAB_NB < dim(TAB_COD)
 TAB_NB += 1
 TAB_COD(TAB_NB) = [L]ABR
 TAB_CLA(TAB_NB) = [L]CODCLA
 For [ACLAF2]ACLAF1 Where CODCLA=[L]CODCLA & LNKCLA<>""
  L_CLA_NB+=1
  L_CLA_ABR(L_CLA_NB) = ABR+"."+[ACLAF2]FLDCLA
  L_CLA_COD(L_CLA_NB) = [ACLAF2]LNKCLA
 Next
 For I = 1 To L_CLA_NB
  Call LOAD_CHILD_CLASSES(L_CLA_COD(I),L_CLA_ABR(I),TAB_COD,TAB_CLA,TAB_NB)
 Next
Endif

End


#----------------------------------------------------------#
Subprog LOAD_REPRESENTATION_PARAM(DOSSIER,REP_COD,REP_PARAM_TYP,LNK_COD,PAR_TYP,RES_LIST_CODPAR,RES_LIST_CODCUR,RES_LIST_TYPPAR,RES_LIST_TIT,RES_LIST_INT_TYP,
& RES_LIST_ADRVAL,RES_LIST_TYPKEY,RES_LIST_NUMPAR,RES_LIST_NOLIB,RES_LIST_LNG,RES_LIST_TYPAFF,
& RES_LIST_PARFIL,RES_LIST_PARENT,RES_NBRPARALL)
Value Char    DOSSIER
Value Char    REP_COD # representation code
Value Integer REP_PARAM_TYP # 0-both   1-P.Filtre   2-P.Entrée
Value Char    LNK_COD # current link code
Value Integer PAR_TYP # ML59:  1-property parameter  2-exposed pro parameter  3-link parameter
Variable Char    RES_LIST_CODPAR()(0..)# parameter code
Variable Char    RES_LIST_CODCUR()(0..)# = LNK_COD : current link code
Variable Integer RES_LIST_TYPPAR(0..)  # = PAR_TYP : ML59:  1-property parameter  2-exposed pro parameter  3-link parameter
Variable Char    RES_LIST_TIT()(0..)   # title
Variable Integer RES_LIST_INT_TYP(0..) # ML 33 : parameter type
Variable Integer RES_LIST_ADRVAL(0..)  # ML 34 : 1-by adresse   2-by value    3-constant
Variable Integer RES_LIST_TYPKEY(0..)  # 1-is not key     2 -is key
Variable Integer RES_LIST_NUMPAR(0..)
Variable Integer RES_LIST_NOLIB(0..)   # local menu number
Variable Integer RES_LIST_LNG(0..)     # lenth
Variable Integer RES_LIST_TYPAFF(0..)  # input
Variable Integer RES_LIST_PARFIL(0..)  # P.filtre
Variable Integer RES_LIST_PARENT(0..)  # P. Entrée
Variable Integer RES_NBRPARALL

Local Char L_CRITERIA(100), L_ATY_TYPE(GLONATY)
Local Integer L_NUMPAR, L_TYPE_ML30,I

If clalev([M:ASW0])>0 & clalev([M:ASW4])>0 & [M:ASW0]CODREP=[L]REP_COD
  # prepare loading criterias
  Case REP_PARAM_TYP
   When 0:
    L_CRITERIA = "([M:ASW4]PARFILPRO(I)=2 or [M:ASW4]PARENTPRO(I)=2)"
   When 1:
    L_CRITERIA = "[M:ASW4]PARFILPRO(I)=2"
   When 2:
    L_CRITERIA = "[M:ASW4]PARENTPRO(I)=2"
  Endcase
  For I=0 To [M:ASW4]NBRPRO-1
    If evalue(L_CRITERIA)
     L_NUMPAR += 1
     [L]RES_LIST_CODPAR([L]RES_NBRPARALL) = [M:ASW4]ALIAS(I) # taking the ALIAS as parameter code to be sure it's unique
     [L]RES_LIST_CODCUR([L]RES_NBRPARALL) = [L]LNK_COD
     [L]RES_LIST_TYPPAR([L]RES_NBRPARALL) = [L]PAR_TYP
     [L]RES_LIST_TIT([L]RES_NBRPARALL)= func ASYRFNC.TEXTE([M:ASW4]INTPRO(I))
     If toupper(left$([M:ASW4]CODPRO(I),5)) = "ACTX." # to be reviewed, not sure ACTX can be selected as parameter
      L_TYPE_ML30 = func ACTX_TOOL.GET_ACTX_TYPCOD(right$([M:ASW4]CODPRO(I), 6))
      [L]RES_LIST_INT_TYP([L]RES_NBRPARALL) = L_TYPE_ML30
     Else
      L_ATY_TYPE = func GET_TYP_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(I))
      Read [ATY]CODTYP = L_ATY_TYPE
      [L]RES_LIST_INT_TYP([L]RES_NBRPARALL) = [F:ATY]TYPTYP
     Endif
     [L]RES_LIST_ADRVAL([L]RES_NBRPARALL) = 2
     [L]RES_LIST_TYPKEY([L]RES_NBRPARALL) = 1
     [L]RES_LIST_NUMPAR([L]RES_NBRPARALL) = L_NUMPAR
     [L]RES_LIST_NOLIB([L]RES_NBRPARALL)  = 0  # default value
     [L]RES_LIST_LNG([L]RES_NBRPARALL)    = 0  # default value
     [L]RES_LIST_TYPAFF([L]RES_NBRPARALL) = 1  # default value
     [L]RES_LIST_PARFIL([L]RES_NBRPARALL) = [M:ASW4]PARFILPRO(I)
     [L]RES_LIST_PARENT([L]RES_NBRPARALL) = [M:ASW4]PARENTPRO(I)
     [L]RES_NBRPARALL+=1
    Endif
  Next I
Else
  # prepare loading criterias
  Case REP_PARAM_TYP
   When 0:
    L_CRITERIA = "(PARFILPRO=2 or PARENTPRO=2)"
   When 1:
    L_CRITERIA = "PARFILPRO=2"
   When 2:
    L_CRITERIA = "PARENTPRO=2"
  Endcase

  # load parameters
  For [ASWR2]ASWR0 Where CODREP=[L]REP_COD & evalue(L_CRITERIA)
   L_NUMPAR += 1
   [L]RES_LIST_CODPAR([L]RES_NBRPARALL) = [F:ASWR2]ALIAS # taking the ALIAS as parameter code to be sure it's unique
   [L]RES_LIST_CODCUR([L]RES_NBRPARALL) = [L]LNK_COD
   [L]RES_LIST_TYPPAR([L]RES_NBRPARALL) = [L]PAR_TYP
   [L]RES_LIST_TIT([L]RES_NBRPARALL)= func ASYRFNC.TEXTE([F:ASWR2]INTPRO)
   If toupper(left$([F:ASWR2]CODPRO,5)) = "ACTX." # to be reviewed, not sure ACTX can be selected as parameter
    L_TYPE_ML30 = func ACTX_TOOL.GET_ACTX_TYPCOD(right$([F:ASWR2]CODPRO, 6))
    [L]RES_LIST_INT_TYP([L]RES_NBRPARALL) = L_TYPE_ML30
   Else
    L_ATY_TYPE = func GET_TYP_FROM_PRO_PATH_DOSS(DOSSIER,[L]REP_COD, [F:ASWR2]CODPRO)
    Read [ATY]CODTYP = L_ATY_TYPE
    [L]RES_LIST_INT_TYP([L]RES_NBRPARALL) = [F:ATY]TYPTYP
   Endif
   [L]RES_LIST_ADRVAL([L]RES_NBRPARALL) = 2
   [L]RES_LIST_TYPKEY([L]RES_NBRPARALL) = 1
   [L]RES_LIST_NUMPAR([L]RES_NBRPARALL) = L_NUMPAR
   [L]RES_LIST_NOLIB([L]RES_NBRPARALL)  = 0  # default value
   [L]RES_LIST_LNG([L]RES_NBRPARALL)    = 0  # default value
   [L]RES_LIST_TYPAFF([L]RES_NBRPARALL) = 1  # default value
   [L]RES_LIST_PARFIL([L]RES_NBRPARALL) = [F:ASWR2]PARFILPRO
   [L]RES_LIST_PARENT([L]RES_NBRPARALL) = [F:ASWR2]PARENTPRO
   [L]RES_NBRPARALL+=1
  Next
Endif
End


#----------------------------------------------------------#
Funprog CHECK_METHODS_EXIST(CLA_COD, FLG_OPE)
Value Char CLA_COD
Value Integer FLG_OPE # 0 : Method, 1: Operation
Local Integer RES_FOUND

 Read [ACLA]ACLA0 = CLA_COD
 If !fstat
  Local Integer I
  If FLG_OPE<>1 # Method #[M:ASW6]TYPLNK=2
   For [F:ACLAM] Where CODCLA = [F:ACLA]CODCLA and FLGOPE <> 2
    I += 1
    Break
   Next
   If I>0
    RES_FOUND = 1
   Endif
  Else # Operation
   For [F:ACLAM] Where CODCLA = [F:ACLA]CODCLA and FLGOPE = 2
    I += 1
    Break
   Next
   If I>0
    RES_FOUND = 1
   Endif
  Endif
 Endif
End RES_FOUND


#----------------------------------------------------------#
Subprog SEL_METHOD(REP_COD, VALEUR)
Value Char REP_COD
Variable Char    VALEUR()

 Gosub DEFLIST_METH
 Gosub LIST_METH
 CHOI = 0
 TIT(0)=mess(8,31,1) # Sélection
 TIT(1)=func AMK_TOOL.GET_FIELD_LABEL("ACLA2", "CODMET") # Code
 TIT(2)=func AMK_TOOL.GET_FIELD_LABEL("ACLA2", "INTITMET") # Libellé
 TIT(3)=func AMK_TOOL.GET_FIELD_LABEL("ACLA2", "DONMET") # Retour

 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0 : [L]VALEUR = TEX(CHOI,1) : Endif
End

$DEFLIST_METH
 Local Char    TEX(max(GLONDES,GLONASM))(1..500,1..3) , TIT(GLONDES)(0..3) , CRITERE(250)
Return

$LIST_METH
Local Integer NBTEX, CHOI,IMET,JPARMET,WMETHOK
If clalev([M:ASW0])>0 & clalev([M:ASW3])>0 & [M:ASW0]CODREP=[L]REP_COD
 For IMET=0 To [M:ASW3]NBRMET-1
  WMETHOK=1
  For JPARMET=0 To [M:ASW3]WNBRPARMET-1
    #112277 [M:ASW3]WTYPPARMET(JPARMET)=8
    If [M:ASW3]CODMET(IMET)=[M:ASW3]WCODMET(JPARMET) & [M:ASW3]WTYPPARMET(JPARMET)=13 : #Instance
      WMETHOK=0
    Endif
  Next JPARMET
  If WMETHOK
    NBTEX+= 1
    TEX(NBTEX,1) = [M:ASW3]CODMET(IMET)
    TEX(NBTEX,2) = [M:ASW3]INTITMET(IMET)
    TEX(NBTEX,3) = mess([M:ASW3]DONMET(IMET),7843,1)
  Endif
 Next IMET
Else
 For [ASWM] Where CODREP=[L]REP_COD
  WMETHOK=1
  #112277 TYPPARMET=8
  For [ASWMP] Where CODREP=[L]REP_COD & CODMET=[F:ASWM]CODMET & TYPPARMET=13
    WMETHOK=0
  Next
  If WMETHOK
    NBTEX+= 1
    TEX(NBTEX,1) = [F:ASWM]CODMET
    Call TEXTE([F:ASWM]INTMET,TEX(NBTEX,2)) From OBJDIV
    TEX(NBTEX,3) = mess([F:ASWM]DONMET,7843,1)
  Endif
 Next
Endif
Return

#---------------------------------------------------------#
Subprog SEL_EXPRO_ASW4(VALEUR,IS_ATY_UNIT)
Variable Char    VALEUR()
Value Integer IS_ATY_UNIT
 Local Integer NBTEX, CHOI,I,J
 Local Char    TEX(GLONAVC)(1..500,1..5) , TIT(GLONDES)(0..5)

 For I=0 To [M:ASW4]NBRPRO-1
  If IS_ATY_UNIT=0
   J=1
  Else
   J=func SUBASW.IS_ATY_UNIT([M:ASW4]CODPROATY(I))
  Endif
  If J
   NBTEX+= 1
   TEX(NBTEX,1) = [M:ASW4]ALIAS(I)
   TEX(NBTEX,2) = [M:ASW4]CODPRO(I)
   TEX(NBTEX,3) = [M:ASW4]AZINTPRO(I)
   TEX(NBTEX,4) = [M:ASW4]FLDGRPPRO(I)
   If IS_ATY_UNIT
    TEX(NBTEX,5) = [M:ASW4]CODPROATY(I)
   Else
    TEX(NBTEX,5) = mess(1,1,1)
    For J=0 To [M:ASW6]NBRLNK-1
      If [M:ASW6]AFFLNK(J)=1 & [M:ASW6]ANCLNK(J)=[M:ASW4]CODPRO(I)
       TEX(NBTEX,5) = mess(2,1,1)
       Break
      Endif
    Next J
   Endif
  Endif
 Next I

 CHOI = 0
 TIT(0) = mess(22,123,1) # Selection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "ALIAS") # Alias
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "CODPRO") # Propriété
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "AZINTPRO") # Libellé
 TIT(4) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "FLDGRPPRO") # Collection
 If IS_ATY_UNIT
  TIT(5) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "CODPROATY") # Type de données
 Else
  TIT(5) = mess(186,100,1)  # Liens
 Endif

# If NBTEX=1
#  [L]VALEUR = TEX(1,2)
# ELS
 If NBTEX>0
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   [L]VALEUR = TEX(CHOI,2)
  Endif
 Endif

End


#---------------------------------------------------------#
Subprog SEL_COL_ASW1(VALEUR, LNK_TYP)
Variable Char  VALEUR()
Value Integer  LNK_TYP # 2: Ligne de collection, 3: Collection
 Local Integer NBTEX, CHOI,I,J
 Local Char    TEX(GLONAVC)(1..500,1..4) , TIT(GLONDES)(0..4)


 For I=0 To [M:ASW1]NBRCOL-1
  NBTEX+= 1
  TEX(NBTEX,1) = [M:ASW1]ALIASCOL(I)
  TEX(NBTEX,2) = [M:ASW1]CODCOL(I)
  TEX(NBTEX,3) = [M:ASW1]INTITCOL(I)
  TEX(NBTEX,4) = mess(1,1,1)
  For J=0 To [M:ASW6]NBRLNK-1
    If [M:ASW6]AFFLNK(J)=LNK_TYP & [M:ASW6]ANCLNK(J)=[M:ASW1]CODCOL(I)
     TEX(NBTEX,4) = mess(2,1,1)
     Break
    Endif
  Next J
 Next

 CHOI = 0
 TIT(0) = mess(22,123,1) # Selection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "ALIASCOL") # Alias
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "CODCOL")   # Code
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "INTITCOL") # Libellé
 TIT(4) = mess(186,100,1)  # Liens

# If NBTEX=1
#  [L]VALEUR = TEX(1,2)
# ELS
 If NBTEX>0
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   [L]VALEUR = TEX(CHOI,2)
  Endif
 Endif

End

#---------------------------------------------------------#
Subprog SEL_REMSTDLNK_ASW6(VALEUR, NOL)
Variable Char  VALEUR()
Value Integer  NOL

 Local Integer NBTEX, CHOI,I,J
 Local Char    TEX(GLONAVC)(1..500,1..5) , TIT(GLONDES)(0..5)


 For J=0 To [M:ASW6]NBRLNK-1
  If [M:ASW6]AFFLNK(J)=[M:ASW7]WAFFLNK(NOL) & [M:ASW6]ANCLNK(J)=[M:ASW7]WANCLNK(NOL)
&  & [M:ASW6]CODLNK(J)<>[M:ASW7]WCODLNK(NOL) & [M:ASW6]FLGSTDLNK(J)<>2 & [M:ASW6]ENALNK(J)=2
&  & ( ([M:ASW6]TYPLNK(J)=[M:ASW7]WTYPLNK(NOL) & [M:ASW6]CMPLNK(J)=[M:ASW7]WCMPLNK(NOL))
&      |([M:ASW7]WTYPLNK(NOL)=1 & [M:ASW6]TYPLNK(J)=4)
&      |([M:ASW7]WTYPLNK(NOL)=4 & [M:ASW6]TYPLNK(J)=1))
  NBTEX+= 1
  TEX(NBTEX,1) = [M:ASW6]CODLNK(J)
  TEX(NBTEX,2) = [M:ASW6]INTITLNK(J)
  TEX(NBTEX,3) = mess([M:ASW6]TYPLNK(J),7974,1)
  TEX(NBTEX,4) = [M:ASW6]REPLNK(J)-[M:ASW6]CODFNCLNK(J)
  TEX(NBTEX,5) = [M:ASW6]ACVLNK(J)
  Endif
 Next

 CHOI = 0
 TIT(0) = mess(22,123,1) # Sélection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WCODLNK") # Code
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WINTITLNK") # Libellé
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WTYPLNK") # Type
 TIT(4) = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WREPLNK")+"/"+func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WCODFNCLNK") # Représentation/Fonction
 TIT(5) = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WACVLNK") # Code activité

  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   [L]VALEUR = TEX(CHOI,1)
  Endif
End

