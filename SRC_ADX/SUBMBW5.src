Subprog AV_DIFFSTO(VALEUR)
Variable Decimal VALEUR
Local Integer L : L = nolign-1
If VALEUR < 0
  pcolor = GCOUL(1)
Else 
  pcolor = GCOUL(0)
Endif
End

