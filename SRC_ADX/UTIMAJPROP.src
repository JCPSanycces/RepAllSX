#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Supression du paramétrage de la propriété d'une fenêtre
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Delete properties parameter of window") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DELAOP
End

#-------------------#
$DELAOP
#CHECK IGNORE_BEGIN

Local Integer I , OKDEL
Local Char    PRO(20)

Local File =DOSSIER+".AOBJPROP"   [AOP] 

# Mise à jour de la table 
Call ECR_TRACE(mess(81,125,1)-"AOBJPROP:"-time$,0) From GESECRAN

PRO ="AWI"

Trbegin [AOP]

 OKDEL = 0
 For [AOP]AOP0 Where OBJ=[L]PRO
  If instr(1,[F:AOP]FRM,"UPDTIM")
   OKDEL = 1 : Break
  Endif
 Next AOP
 If OKDEL
  Delete [AOP] Where OBJ=[L]PRO
  If fstat
   Call ERREUR("AOBJPROP"-[F:AOP]OBJ+num$([F:AOP]NUM),2) From DOSDIC
  Endif 
 Endif

Commit

Close Local File [AOP]
#CHECK IGNORE_END

Return
