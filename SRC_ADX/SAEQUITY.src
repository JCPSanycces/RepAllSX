#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("SA-EQU-EEA2","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20) ,CRITERE(250),CRITERE1(250),CRITERE2(250),CRITERE3(250) ,CRITERE4(250)
Local Char    CPY(GLONCPY), FCY(GLONFCY), SRV(GLONSRV)
Local Date    DATEDEB , DATEFIN
Local Char RPTTYP(1),SNR(25)
Local Integer OCC_LEVEL  ,MALE_A  ,MALE_C ,MALE_I  ,MALE_W  ,FEMALE_A ,FEMALE_C  ,FEMALE_I  ,FEMALE_W ,FOREIGN_M ,FOREIGN_F,EMPTYP, CNTTWICE
Local Decimal MALE_A_REM  ,MALE_C_REM ,MALE_I_REM  ,MALE_W_REM  ,FEMALE_A_REM ,FEMALE_C_REM  ,FEMALE_I_REM  ,FEMALE_W_REM ,FOREIGN_M_REM ,FOREIGN_F_REM


If clalev([F:SAEQU])=0    : Local File HRSAEQU  [SAEQU]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]: Endif
If clalev([F:HRAFRCL])=0  : Local File HRAFRCLASS  [HRAFRCL]: Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:INS])=0    : Local File INSCRIPT  [INS]  : Endif
If clalev([F:HRSES])=0    : Local File SESSIONS  [HRSES]  : Endif
If clalev([F:HRTPER])=0    : Local File HRSTRAINPER  [HRTPER]  : Endif
If clalev([F:ETR])=0    : Local File EMPLOTAXREC  [ETR]  : Endif
If clalev([F:HSP])=0    : Local File HISTOPAYE  [HSP]  : Endif
If clalev([F:VEP])=0        : Local File VALEMP        [VEP]             : Endif

Call GETPARAM("cpy",NBPAR,PARAMETRE,CPY)
Call GETPARAM("fcy",NBPAR,PARAMETRE,FCY)
Call GETPARAM("srv",NBPAR,PARAMETRE,SRV)
Call GETPARAM("snr",NBPAR,PARAMETRE,SNR)
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM

CRITERE = "1=1"
If CPY<>"" : CRITERE -= "& [F:FGR]CPY='"+CPY+"'"    : Endif
If FCY<>"" : CRITERE -= "& [F:HRCTR]ETRFCY='"+FCY+"'"    : Endif
If SRV<>"" : CRITERE -= "& [F:HRCTR]ETRSRV='"+SRV+"'"    : Endif

  CRITERE -= "& [F:HRCTR]CTRDAT<=["+format$(GFMD,DATEFIN)+"]"

  CRITERE4 -= " [F:HRCTR]XITDAT > ["+format$(GFMD,DATEFIN)+"]"

  CRITERE2 -= " [F:HRCTR]XITDAT >= ["+format$(GFMD,DATEDEB)+"] & [F:HRCTR]XITDAT <= ["+format$(GFMD,DATEFIN)+"]"

If SNR = "1" Then
 CRITERE1 -= " [F:HRCTR]DATANC >= ["+format$(GFMD,DATEDEB)+"] & [F:HRCTR]DATANC <= ["+format$(GFMD,DATEFIN)+"]"
Elsif SNR = "2" Then
 CRITERE1 -= " [F:HRCTR]DATCPY >= ["+format$(GFMD,DATEDEB)+"] & [F:HRCTR]DATCPY <= ["+format$(GFMD,DATEFIN)+"]"
Elsif SNR = "3" Then
 CRITERE1 -= " [F:HRCTR]DATFCY >= ["+format$(GFMD,DATEDEB)+"] & [F:HRCTR]DATFCY <= ["+format$(GFMD,DATEFIN)+"]"
Endif

Gosub CLEARTABLE

  Link [HRCTR] With
& [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE)  & [F:HRCTR]FLGVAR <> 2 & ( [F:HRCTR]XITFNL <> 2  | ([F:HRCTR]XITFNL = 2 & evalue(CRITERE4)))
& Order By [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc
#
# RPTTYP
# 1 = Part 1.1
# 2 = Part 1.2
# 3 = Part 2
# 4 = Part 3
# 5 = Part 4
# 6 = Part 5

RPTTYP = "1"
CNTTWICE = 1 # 1 = No ; 2 = Yes
Gosub GETDATA

RPTTYP = "2"
CNTTWICE = 1
Gosub GETDATA_DIS

RPTTYP = "4"
CNTTWICE = 2
Gosub GETDATA_PROMOTION

RPTTYP = "6"
CNTTWICE = 1
Gosub GETDATA_SKILLS


  Link [HRCTR] With
&  [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE1) & [F:HRCTR]FLGVAR <> 2
& Order By [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc

RPTTYP = "3"
CNTTWICE = 1
Gosub GETDATA


  Link [HRCTR] With
&  [FGR]FGR1(1) = [F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITERE2) &[F:HRCTR]FLGVAR <> 2 & [F:HRCTR]XITFNL = 2
& Order By [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT Asc

RPTTYP = "5"
CNTTWICE = 1
Gosub GETDATA


End

$GETDATA
For OCC_LEVEL=1 To 7
  For [LNK]
    Filter [ETR] Where [F:ETR]REFNUM = [F:HRCTR]REFNUM and [F:ETR]CTRNUM = [F:HRCTR]CTRNUM and [F:ETR]CTRDAT = [F:HRCTR]CTRDAT  and [F:ETR]TAXSTA <> 8
    If rowcount([ETR]) > 0 Then
      If OCC_LEVEL < 7 Then
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 1  and [HRAFRCL]PYRMON<= DATEFIN
&       Order By [HRAFRCL]PYRMON Desc
      Else
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 2  and [HRAFRCL]PYRMON<= DATEFIN
&       Order By [HRAFRCL]PYRMON Desc
      Endif
      Gosub COUNTDATA
    Endif
  Next
  Gosub WRITE_RECORD
  Gosub CLEAR_VARIABLES
Next OCC_LEVEL
Return

$GETDATA_DIS
For OCC_LEVEL=1 To 7
  For [LNK]
    Filter [ETR] Where [F:ETR]REFNUM = [F:HRCTR]REFNUM and [F:ETR]CTRNUM = [F:HRCTR]CTRNUM and [F:ETR]CTRDAT = [F:HRCTR]CTRDAT  and [F:ETR]TAXSTA <> 8
    If rowcount([ETR]) > 0 Then
      If OCC_LEVEL < 7 Then
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 1  and [HRAFRCL]PYRMON<= DATEFIN and [HRAFRCL]HDCFLG = 2
&       Order By [HRAFRCL]PYRMON Desc
      Else
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 2 and [HRAFRCL]PYRMON<= DATEFIN and [HRAFRCL]HDCFLG = 2
&       Order By [HRAFRCL]PYRMON Desc
      Endif
      Gosub COUNTDATA
    Endif
  Next
  Gosub WRITE_RECORD
  Gosub CLEAR_VARIABLES
Next OCC_LEVEL
Return

$GETDATA_PROMOTION
For OCC_LEVEL=1 To 7
  For [LNK]
    Filter [ETR] Where [F:ETR]REFNUM = [F:HRCTR]REFNUM and [F:ETR]CTRNUM = [F:HRCTR]CTRNUM and [F:ETR]CTRDAT = [F:HRCTR]CTRDAT  and [F:ETR]TAXSTA <> 8
    If rowcount([ETR]) > 0 Then
      If OCC_LEVEL < 7 Then
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 1  and [HRAFRCL]PYRMON>= DATEDEB and [HRAFRCL]PYRMON<= DATEFIN and [HRAFRCL]OCPAFTVAL  < [HRAFRCL]OCPBEFVAL
&       Order By [HRAFRCL]PYRMON Desc
      Else
        Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [HRCTR]REFNUM and [HRAFRCL]CTRNUM = [HRCTR]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&       and [HRAFRCL]EQUEMPTYP = 2  and [HRAFRCL]PYRMON>= DATEDEB  and [HRAFRCL]PYRMON<= DATEFIN  and [HRAFRCL]OCPAFTVAL  < [HRAFRCL]OCPBEFVAL
&       Order By [HRAFRCL]PYRMON Desc
      Endif
      Gosub COUNTDATA
    Endif
  Next
  Gosub WRITE_RECORD
  Gosub CLEAR_VARIABLES
Next OCC_LEVEL
Return



$GETDATA_SKILLS
For OCC_LEVEL=1 To 7
  For [LNK]
    Filter [ETR] Where [F:ETR]REFNUM = [F:HRCTR]REFNUM and [F:ETR]CTRNUM = [F:HRCTR]CTRNUM and [F:ETR]CTRDAT = [F:HRCTR]CTRDAT  and [F:ETR]TAXSTA <> 8
    If rowcount([ETR]) > 0 Then
        Link [INS] With
&         [HRSES]SES0 = [F:INS]SES
&       , [HRTPER]HRTPER0 = [F:INS]STG
&       As [LNKDATA]
&       Where [INS]REFNUM = [F:HRCTR]REFNUM and [INS]CTRNUM = [F:HRCTR]CTRNUM  & ([INS]STA = 3 | [INS]STA = 6) & [HRTPER]TNGPSE = 5 &  ([F:HRSES]ENDDAT >= DATEDEB & [F:HRSES]ENDDAT <= DATEFIN)

      For [LNKDATA]
        If OCC_LEVEL < 7 Then
          Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [LNKDATA]REFNUM and [HRAFRCL]CTRNUM = [LNKDATA]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&         and [HRAFRCL]EQUEMPTYP = 1  and [HRAFRCL]PYRMON>= DATEDEB and [HRAFRCL]PYRMON<= DATEFIN
&         Order By [HRAFRCL]PYRMON Desc
        Else
          Filter [HRAFRCL] Where [HRAFRCL]REFNUM = [LNKDATA]REFNUM and [HRAFRCL]CTRNUM = [LNKDATA]CTRNUM and [HRAFRCL]CTRDAT = [HRCTR]CTRDAT and [HRAFRCL]CPY = CPY
&         and [HRAFRCL]EQUEMPTYP = 2  and [HRAFRCL]PYRMON>= DATEDEB  and [HRAFRCL]PYRMON<= DATEFIN
&         Order By [HRAFRCL]PYRMON Desc
        Endif
        Gosub COUNTDATA
        Break 1
      Next
    Endif
  Next
  Gosub WRITE_RECORD
  Gosub CLEAR_VARIABLES
Next OCC_LEVEL
Return

$CLEAR_VARIABLES
MALE_A=0
MALE_C=0
MALE_I=0
MALE_W=0
FEMALE_A=0
FEMALE_C=0
FEMALE_I=0
FEMALE_W=0
FOREIGN_M=0
FOREIGN_F=0
MALE_A_REM=0
MALE_C_REM=0
MALE_I_REM=0
MALE_W_REM=0
FEMALE_A_REM=0
FEMALE_C_REM=0
FEMALE_I_REM=0
FEMALE_W_REM=0
FOREIGN_M_REM=0
FOREIGN_F_REM=0



Return

$WRITE_RECORD
Trbegin [SAEQU]
  Raz [F:SAEQU]
  [F:SAEQU]CPY = CPY
  [F:SAEQU]USR = GUSER
  [F:SAEQU]RPT = 'EEA2'
  [F:SAEQU]TYP = RPTTYP
  [F:SAEQU]OCCLEV = OCC_LEVEL
  [F:SAEQU]MALEA = MALE_A
  [F:SAEQU]MALEC = MALE_C
  [F:SAEQU]MALEI = MALE_I
  [F:SAEQU]MALEW = MALE_W
  [F:SAEQU]FEMALEA = FEMALE_A
  [F:SAEQU]FEMALEC = FEMALE_C
  [F:SAEQU]FEMALEI = FEMALE_I
  [F:SAEQU]FEMALEW = FEMALE_W
  [F:SAEQU]FOREIGNM = FOREIGN_M
  [F:SAEQU]FOREIGNF  = FOREIGN_F
  [F:SAEQU]MALEAREM = MALE_A_REM
  [F:SAEQU]MALECREM = MALE_C_REM
  [F:SAEQU]MALEIREM = MALE_I_REM
  [F:SAEQU]MALEWREM = MALE_W_REM
  [F:SAEQU]FEMALEAREM = FEMALE_A_REM
  [F:SAEQU]FEMALECREM = FEMALE_C_REM
  [F:SAEQU]FEMALEIREM = FEMALE_I_REM
  [F:SAEQU]FEMALEWREM = FEMALE_W_REM
  [F:SAEQU]FOREIGNMREM = FOREIGN_M_REM
  [F:SAEQU]FOREIGNFREM  = FOREIGN_F_REM

  Write [F:SAEQU]
  If fstat=0
    Commit
  Else
  Infbox num$(fstat)
    Rollback
  Endif

Return

$COUNTDATA
Local Char UNQEMP(30)
UNQEMP = "EMPTY"
  For [HRAFRCL]
    If UNQEMP <> [HRAFRCL]REFNUM Then
      If OCC_LEVEL < 7 Then
        If [HRAFRCL]OCPLEV = OCC_LEVEL Then
          If RPTTYP = "1" Then
            Gosub CDATAREM
          Endif
          Gosub CDATA
        Endif
      Else
        If RPTTYP = "1" Then
          Gosub CDATAREM
        Endif
        Gosub CDATA
      Endif
    Endif
    If CNTTWICE = 2 Then # 1 = No ; 2 = Yes
      UNQEMP = "EMPTY"
    Else
      UNQEMP = [HRAFRCL]REFNUM
    Endif
  Next
Return

$CDATA
If [HRAFRCL]STG = 1 Then
  If [HRAFRCL]SEX = 1 Then
    Case [HRAFRCL]RCEGRP
      When 1: MALE_A+=1
      When 2: MALE_C+=1
      When 3: MALE_I+=1
      When 4: MALE_W+=1
    Endcase
  Elsif [HRAFRCL]SEX = 2 Then
    Case [HRAFRCL]RCEGRP
      When 1: FEMALE_A+=1
      When 2: FEMALE_C+=1
      When 3: FEMALE_I+=1
      When 4: FEMALE_W+=1
    Endcase
  Endif
Elsif [HRAFRCL]STG = 2 Then
  If [HRAFRCL]SEX = 1 Then
    FOREIGN_M+=1
  Elsif [HRAFRCL]SEX = 2 Then
    FOREIGN_F+=1
  Endif
Endif
Return

$CDATAREM
Local Char LASTBUL(20)
Local Decimal REMAMT
Filter [VEP] Where CTRNUM = [F:HRAFRCL]CTRNUM & EMP = [F:HRAFRCL]REFNUM & CTRDAT = [F:HRAFRCL]CTRDAT Order By Key VEP5 Asc
If rowcount([F:VEP])<=0 : Return : Endif
Columns [VEP](BUL)
For [VEP]
  LASTBUL = [VEP]BUL
Next

Filter [HSP] Where EMP = [F:HRAFRCL]REFNUM and CTRNUM = [F:HRAFRCL]CTRNUM and BUL = LASTBUL and RUB = 'EQUITY_PRO' and TYP = 6
If rowcount([F:HSP])<=0 : Return : Endif
Columns [HSP](AMT)
For [HSP]
  REMAMT = [HSP]AMT
Next

If [HRAFRCL]STG = 1 Then
  If [HRAFRCL]SEX = 1 Then
    Case [HRAFRCL]RCEGRP
      When 1: MALE_A_REM+=REMAMT
      When 2: MALE_C_REM+=REMAMT
      When 3: MALE_I_REM+=REMAMT
      When 4: MALE_W_REM+=REMAMT
    Endcase
  Elsif [HRAFRCL]SEX = 2 Then
    Case [HRAFRCL]RCEGRP
      When 1: FEMALE_A_REM+=REMAMT
      When 2: FEMALE_C_REM+=REMAMT
      When 3: FEMALE_I_REM+=REMAMT
      When 4: FEMALE_W_REM+=REMAMT
    Endcase
  Endif
Elsif [HRAFRCL]STG = 2 Then
  If [HRAFRCL]SEX = 1 Then
    FOREIGN_M_REM+=REMAMT
  Elsif [HRAFRCL]SEX = 2 Then
    FOREIGN_F_REM+=REMAMT
  Endif
Endif
Return

$CLEARTABLE
Trbegin [SAEQU]
 Delete [SAEQU] Where USR=GUSER
Commit
Return


Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

