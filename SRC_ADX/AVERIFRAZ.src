#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################
#
# Vérification, lorsqu'un lien a lieu vers une table remise à zéro, que le lien l'est également
# Moulinette de vérif écrite par Dominique Bopp le 2 Aout 2002 et transmise à Solon pour intégration
# (C) 2002 ADONIX
#
######################################################

#------------------------------------------------------------------------------------------------------------------------#

Subprog AVERIFRAZ(CHEMIN,DOSSIER, PORT, MACHINE, PMODULE, NBERRTOT, NBWARTOT, PLIBVERIF)

Value Char CHEMIN       :  # Chemin où seront créés les fichiers de trace
Value Char DOSSIER      :  # Si non patch, dossier analysé
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Integer PMODULE    :  # Si travail sur sources d'un module particulier
Variable Integer NBERRTOT, NBWARTOT
Value Char PLIBVERIF

Local Integer MAX_NBFIC
MAX_NBFIC = 1200

Local Char TABZERO(20)(1..MAX_NBFIC), DOSSIER2(100), WTITRE2(100)
Local Integer NBTABZERO,NBERR, NBLU
Local Shortint SAUVEMENU

If MACHINE = ""
    DOSSIER2 = DOSSIER
Else
    DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
Endif

If clalev ([F:ATB])
    Close File [ATB]
Endif
If clalev ([F:ATZ])
    Close File [ATZ]
Endif
If clalev ([F:AST])
    Close File [AST]
Endif

Local File = DOSSIER2 + ".ATABLE"  [ATB]
Local File = DOSSIER2 + ".ATABZON" [ATZ]
Local File = DOSSIER2 + ".APLSTD"  [AST]

Call TEMPON("Vérifications des" - PLIBVERIF) From GESECRAN

#----------------#
#Fichier de trace
#----------------#
Openo CHEMIN, -1

For [ATB]CODFIC Where ZERO = 2
  NBTABZERO += 1
  TABZERO(NBTABZERO) = [F:ATB]CODFIC
Next


Wrseq
Wrseq
Wrseq
Wrseq "-------------------------### Vérification des" - PLIBVERIF + ". ###---------------------------"
Wrseq

If PMODULE
    Link [ATZ] With [ATB]CODFIC=[ATZ]CODFIC As [AZZ] Where [ATB]ZERO=1 & [ATZ]LIEN<>"" & [ATZ]ZERO=1 & [ATZ]OBLIG=2 and  [ATB]MODULE = PMODULE
Else
    Link [ATZ] With [ATB]CODFIC=[ATZ]CODFIC As [AZZ] Where [ATB]ZERO=1 & [ATZ]LIEN<>"" & [ATZ]ZERO=1 & [ATZ]OBLIG=2
Endif

For [AZZ]CODZONE
  NBLU += 1
  If find([ATZ]LIEN, TABZERO(1..NBTABZERO))
      If PMODULE
          WTITRE2 = ""
      Else
          WTITRE2 = "   (module" - num$([F:ATB]MODULE) - "(" - func AVERIFSRC.LIBMODULE ([F:ATB]MODULE, SAUVEMENU) - ")" 
      Endif

      Wrseq "Zone" - [ATZ]CODZONE - "de la table " - [ATB]CODFIC - "(sans remise à zéro) :"
&          - "Il y a un lien vers" - [ATZ]LIEN - "qui est une table avec remise à zéro" - WTITRE2
#      If [ATZ]OBLIG=2
#          Wrseq "Table : "-[ATB]CODFIC-num$([ATB]ZERO)-"zone"-[ATZ]CODZONE -
#&          "lien vers"-[ATZ]LIEN-"incohérent car obligatoire" - WTITRE2
#      Else
#          Wrseq "Table : "-[ATB]CODFIC-num$([ATB]ZERO)-"zone"-[ATZ]CODZONE -
#&          "lien vers"-[ATZ]LIEN-"incorrect" - WTITRE2
#      Endif
      NBERR+=1
      GTRECAPERR(GNUMMOUL, [F:ATB]MODULE, 1) += NBERR
  Endif
Next
Wrseq

If NBERR
    Wrseq num$(NBERR) -"erreur(s) trouvée(s) sur" - num$(NBLU) - "enregistrements lus"
Else
    Wrseq "Aucune erreur trouvée sur" - num$(NBLU) - "enregistrements lus"
Endif
Wrseq
Wrseq "Fin de vérifications des" - PLIBVERIF + "." - time$
Wrseq
Openo
Call TEMPOFF From GESECRAN

    NBERRTOT += NBERR
    
    Close File [ATB]
    Close File [ATZ]


End
