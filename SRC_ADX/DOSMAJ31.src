#<AdxTL>@(#)7.0.0.0 $Revision$
##################################################################################
# DOSMAJ31 : Mises à jour à effectuer lors du passage à la version 160 (Release 30)
# moulinette avant la version V6.1
#################################################################################
# moulinette avant la Release 31 si necessaire
##################################################################################
Subprog AMAJ
#----------------------------------------#
#       Avant mise à jour                #
#----------------------------------------#
Onerrgo ERREUR

# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH
WPATCH = 0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  # Issue 86740 - 2012-12-18 by SR : Tester si PATCH < 3 en AMAJ et non en MAJ (trop tard)
  If WPATCH < 3
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC02
  Endif
Endif

###########################################
# module tiers
# moulinette UUTITRS01 du P5 uniquement sur la v6.0 vers v6.1 --
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(2)= 2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
          If WPATCH < 5
              Call UTI_MOUL([F:ADS]DOSSIER) From UUTITRS01
          Endif
      Endif
  Endif
Endif

Onerrgo
End

###################################################################################
Subprog MAJ
#----------------------------------------#
# Après mise à jour
#----------------------------------------#

Onerrgo ERREUR
# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH, ZOK
WPATCH = 0
ZOK=0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

If left$(WVERSION,3) = "1.3"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.4"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.5"
    WPATCH =0
Endif


###########################################
# module tronc commun
# moulinette UTITC26 du P5  + les uatres a faire quleque soit version
# moulinette UTITC22 du P4 sur les v6 uniquement
###########################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If WPATCH < 4
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC03
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC06
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC07
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC08
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC09
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC10
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC11
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC12
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC13
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC14
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC15
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC16
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC17
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC18
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC19
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC20
  Endif
  If WPATCH < 5
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC25
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC27
  Endif
  If left$(WVERSION,3) = "1.6"
      If WPATCH < 4
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC22
      Endif
      If WPATCH < 5
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITC26
      Endif
  Endif
Endif

###########################################
# module immos
# moulinette UTIIMM008 du P4
############################################
If [F:ADS]MODULE(13) = 2
    If WPATCH < 4
        Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM008
    Endif
Endif


###########################################
# module achats
# moulinette UUACHV61 du P5 uniquement sur la v6.0 vers v6.1 -- moulinette faite sur autre dosmaj
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(5) = 2
          If WPATCH < 5
              Call UTI_MOUL([F:ADS]DOSSIER) From UUACHV61
          Endif
      Endif
  Endif
Endif

###########################################
# module ventes
# moulinette UUVENV61 du P5 uniquement sur la v6.0 vers v6.1 -- moulinette faite sur autre dosmaj
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(4)= 2
          If WPATCH < 5
              Call UTI_MOUL([F:ADS]DOSSIER) From UUVENV61
          Endif
      Endif
  Endif
Endif

###########################################
# module stock
# moulinette UUTC023 du P5 uniquement sur la v6.0 vers v6.1 -- moulinette faite sur autre dosmaj
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
     If WPATCH < 5
         Call MAJ_UUTC023([F:ADS]DOSSIER) From UUTC023
     Endif
  Endif
Endif

###########################################
# module tiers
# moulinette UUCPTCMM60TO61 du P5 uniquement sur la v6.0 vers v6.1 -- moulinette faite sur autre dosmaj
############################################
If left$(WVERSION,3) = "1.6"
    If [F:ADS]MODULE(2)= 2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        If WPATCH < 5
            Call UTI_MOUL([F:ADS]DOSSIER) From UUCPTCMM60TO61
            Call UTI_MOUL([F:ADS]DOSSIER) From UUTITRS02
        Endif
    Endif
Endif

###########################################
# module compta mais test de module TC car table sur TC
# moulinette UTICP11 idem
############################################
If left$(WVERSION,3) = "1.6"
    If [F:ADS]MODULE(8)= 2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        If WPATCH < 5
            Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT11
        Endif
    Endif
Endif

###########################################
# module action co
# moulinette UUCRM006 du P3 uniquement sur la v6.0 vers v6.1
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(12)= 2
          If WPATCH < 3
              Local Integer IERR
              Call CRMSTEP6([F:ADS]DOSSIER, IERR) From CRMMAJ30
         Endif
      Endif
  Endif
Endif


Onerrgo
End
###################################################################################
###################################################################################
###################################################################################
$ERREUR
Call ECR_TRACE(errp-"("+num$(errl)+")"-mess(6,123,1)-":"-num$(errn)-errmes$(errn)-errm,1) From GESECRAN
# Erreur
Resume

