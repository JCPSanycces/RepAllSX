#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour code activité AUD suivant la valeur du code activité AUDIT
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update activity cod AUD") From LECFIC

Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub UPDACV
End

#------------------------------------------------------------------------------------#
#  Moulinette à ne pas déclencher en validation de dossier
#  Moulinette à déclencher dans le patch ou manuellement à partir du dossier X3
#------------------------------------------------------------------------------------#

#-------------------#
$UPDACV

If DOSSIER<>GDOSX3 : Return : Endif

Local Integer FLG , FLGAUDIT

Local File ADOSACT  [ADA2] , ADOSACT [ADA3]
Local File ADOSSIER [ADS2]
Local File =GDOSX3+".ACTIV" [ACVY]

Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN

Trbegin [ADA3]
 For [ADA2] Where CODACT="AUDIT"
  Read [ADA3]ADA0=[F:ADA2]DOSSIER;"AUD"
  If fstat
   [F:ADA3] = [F:ADA2]
   [F:ADA3]CODACT = "AUD"
   Write [ADA3]
   If fstat
    Call ERREUR("ADOSACT"-[F:ADA3]DOSSIER-[F:ADA3]CODACT,1) From DOSDIC
   Else
    Call ECR_TRACE("Create activity code AUD ("+[F:ADA2]DOSSIER+")",0) From GESECRAN
   Endif
  Elsif [F:ADA2]FLACT<>[F:ADA3]FLACT
   Read [ACVY]CODACT="AUDIT"
   If !fstat
    Local File =[F:ADA2]DOSSIER+".ACTIV" [ACVX]
    Read [ACVX]CODACT="AUDIT"
    If !fstat & [F:ACVX]DEP<>[F:ACVY]DEP
     [F:ADA3]FLACT = [F:ADA2]FLACT
     Rewrite [ADA3]
     If fstat
      Call ERREUR("ADOSACT"-[F:ADA3]DOSSIER-[F:ADA3]CODACT,2) From DOSDIC
     Else
      Call ECR_TRACE("Update activity code AUD ("+[F:ADA2]DOSSIER+")",0) From GESECRAN
     Endif
    Endif
    Close Local File [ACVX]
   Endif
  Endif
 Next ADA2 
 For [ADS2] Where DOSSIER<>GDOSX3
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Local File =[F:ADS2]DOSSIER+".ACTIV" [ACVX]
   Read [ACVX]CODACT="AUD"
   If fstat
    Read [ACVX]CODACT="AUDIT"
    If !fstat
     FLG = [F:ACVX]FLACT
     Read [ACVY]CODACT="AUD"
     [F:ACVX] = [F:ACVY]
     [F:ACVX]FLACT = FLG
     Write [ACVX]
     If fstat
      Call ERREUR("ACTIV"-[F:ACVX]CODACT,1) From DOSDIC
     Else
      Call ECR_TRACE("Create activity code AUD",0) From GESECRAN
     Endif 
    Endif
   Else
    FLG = [F:ACVX]FLACT
    Read [ACVY]CODACT="AUDIT"
    If !fstat
     Read [ACVX]CODACT="AUDIT"
     If !fstat
      FLGAUDIT = [F:ACVX]FLACT
      If [F:ACVX]DEP<>[F:ACVY]DEP
       [F:ACVX] = [F:ACVY]
       [F:ACVX]FLACT = FLGAUDIT
       Rewrite [ACVX]
       If fstat
        Call ERREUR("ACTIV"-[F:ACVX]CODACT,2) From DOSDIC
       Else
        Call ECR_TRACE("Update activity code AUDIT",0) From GESECRAN
       Endif 
      Endif
      If FLGAUDIT<>FLG
       Read [ACVX]CODACT="AUD"
       [F:ACVX]FLACT = FLGAUDIT
       Rewrite [ACVX]
       If fstat
        Call ERREUR("ACTIV"-[F:ACVX]CODACT,2) From DOSDIC
       Else
        Call ECR_TRACE("Update activity code AUD",0) From GESECRAN
       Endif 
      Endif
     Endif
    Endif
   Endif
   Close Local File [ACVX]
  Endif
 Next ADS2
Commit

Close Local File

Return
