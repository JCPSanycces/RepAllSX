#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet MGR
Call OBJET("MGR",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "SEL_LISTE" : Gosub SEL_LISTE
 When Default
Endcase
Return

$LIENS
Return

$CREATION
Gosub MODIF
Return

$MODIF
Return

#59527 Sélection d'une grille MS
$SEL_LISTE
  Case LISTE
    When "SELGRI"   : Gosub S_SELGRI
  Endcase
Return

$S_SELGRI
Local Char    TEXTE(GLONDES)(1..dim(TEX),1..2)
TIT = mess(8,31,1) : # Sélection

If clalev([F:MGR1])=0 : Local File MSGRIL [MGR1] : Endif
If clalev([F:GRI1])=0 : Local File GRILLE [GRI1] : Endif

Raz NBTEX

For [MGR1]MGR0
  NBTEX += 1
  TEXTE(NBTEX,1)  = [F:MGR1]COD
  TEXTE(NBTEX,2)  = [F:MGR1]DES
  TEX(NBTEX) = [F:MGR1]COD
Next

For [GRI1]GRI0
  Look [MGR1]MGR0 = [GRI1]COD
  If fstat
    NBTEX += 1
    TEXTE(NBTEX,1)  = [F:GRI1]COD
    TEXTE(NBTEX,2)  = [F:GRI1]DES
    TEX(NBTEX) = [F:GRI1]COD    
  Endif 
Next
TIT(1) = mess(48,10722,1) : #Code grille
TIT(2) = mess(82,123,1)   : #Intitulé
Return
#end 59527


Subprog AS_PIO(VALEUR)
Variable Integer  VALEUR
If [M]VALMAX<>2 | [M]VALMIN<>2
 mkstat = 2 : End
Endif
End
