#<AdxTL>@(#)3.0.0.0 $Revision$
###############################################################
# UTICPT59   UTI process                           Module TC  #
#  Delete IDENT2 to ATEXTRA for CADSP                         #
###############################################################

If clalev([F:ADS])=0
 Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
   Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT59(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT59(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTICPT59 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:DSP])=0  : Local File =DOSSIER+".CADSP"   [DSP] : Endif
If clalev([F:AXX])=0  : Local File =DOSSIER+".ATEXTRA" [AXX] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [AXX]

 For [DSP]DSP0

  If dim([F:DSP]DES)>0
   Call MAJTEXTRA([F:DSP]DES,"CADSP","DESTRA",[F:DSP]DSP,"") From ATEXTRA
  Endif
  If dim([F:DSP]DESSHO)> 0
   Call MAJTEXTRA([F:DSP]DESSHO,"CADSP","SHOTRA",[F:DSP]DSP,"") From ATEXTRA
  Endif

  WCOMPTEUR +=1

 Next

Commit

Close Local File [DSP], [AXX]
Call ECR_TRACE("UTICPT59 : "+num$(WCOMPTEUR)+" ATEXTRA for CADSP record updated",0) From GESECRAN
End


########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT59 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
#If [F:ADS]MODULE(2)<>2 : End : Endif  # CADSP = Tronc commun
Call MAJ_UTICPT59(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
#If [F:ADS]MODULE(2)<>2 : End : Endif   # CADSP = Tronc commun
Call MAJ_UTICPT59(APPLI)
End

