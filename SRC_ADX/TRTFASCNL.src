#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES BIENS - SUPPRESSION : FENETRE DE GESTION DES EXTOURNES 
# ==================================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
# 
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
# - GBO - 07.10.2010 - Fq 65071 - Génération d'un événement d'annulation même s'il n'y pas de dotation +
#                                 Alimentation des nouveaux champs TYPANN et ACCCODORI
# - MDJ - 09.08.2010 - Fq 64312 - Détachement du contrat de location lors de la suppression du bien
# - GBO - 07.05.2010 - Fq 64544 - Gestion des écarts entre plans d'amortissement
# - GBO - 04.03.2010 - Fq 63049 - Gestion des dépenses en suppression de bien
########################################################################################################################
 Local Char PARAM(30)(1..2)
 Local Char VALEUR
 PARAM(1) = "ICC20910026"
 PARAM(2) = "CC2"
 GCOUSOC  = PARAM(2)
 GSOCIETE = GCOUSOC
 
 Call CHARGE_ENVIRONNEMENT () From GLOFCYCPY
 Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASCNL","FASCNL",4,"") From GTRAITE   
 #Infbox num$(dim(FASCNLEND))
 #If dim(FASCNLEND)>0 : Kill FASCNLEND : Endif 
End

#------------------------
$ACTION
 Case ACTION
  When "DEBUT"     : Gosub DEBUT
  When "SETBOUT"   : Gosub SETBOUT
  When "BOUTON"    : Gosub BOUTON
  When "END"       : Gosub END_FCT
  When Default
 Endcase
Return

#------------------------
$DEBUT

 If dim(FASCNLEND)>0 : Kill FASCNLEND : Endif

 Global Integer GFLGPLN(1..G301MAX-1)
 Global Integer GFLGPLNMNG(1..G301MAX-1) #Fq65071-Plan géré
 Global Integer GFLGPLNLNK(1..G301MAX-1)
 Global Char    GTITDIE(20)(1..9)
 Global Char    GMSKORI                  #Fq65071-Onglet actif lors de l'appel à FASCNLCCE
 
 [M:FC0]AASREF = PARAM(1)
 [M:FC0]CPY    = PARAM(2)

 Effzo [M:FC1]
 If G_ACTCCN=G_OUI
  Effzo [M:FC2]
 Endif
 Effzo [M:FC3]
 If G_ACTLNK=G_OUI
  Effzo [M:FC4]
 Endif
  
 If clalev([F:FAS])=0  : Local File FXDASSETS [FAS]  : Endif
 If clalev([F:LOF])=0  : Local File LAYOUTFAS [LOF]  : Endif
 If clalev([F:CNX])=0  : Local File CONTEXT   [CNX]  : Endif
 If clalev([F:FIYC])=0 : Local File FISCYEAR  [FIYC] : Endif
 If clalev([F:FIYS])=0 : Local File FISCYEAR  [FIYS] : Endif
 If clalev([F:DEP])=0  : Local File DEPREC    [DEP]  : Endif
 If G_ACTCCN=G_OUI
  If clalev([F:RPR])=0 : Local File CCNRPR    [RPR]  : Endif
 Endif
  If G_ACTLEA=G_OUI #Fq-64312
  If clalev([F:LEA])=0 : Local File LEASE    [LEA]  : Endif
 Endif

 Call GETCPY([M:FAS0]FCY,"",0,"") From TRTX3CPT

 ####> Chargement du bien 
 #     ==================

 If [M:FC0]AASREF<>[F:FAS]AASREF
  Read [F:FAS]FAS0=[M:FC0]AASREF
 Endif

 [M:FC0]FCY     = [F:FAS]FCY
 [M:FC0]AASDES1 = [F:FAS]AASDES1
 
 ####> Chargement des onglets 
 #     ======================

 Gosub LOAD_PSTAMT From TRTFASCNLDOT ####> Chargement du tableau des dotations
 Gosub LOAD_PSTLNK From TRTFASCNLLNK ####> Chargement du tableau des écarts entre plans @fq64544 
 Gosub LOAD_EVENT                    ####> Chargement du tableau des événements  
 Gosub LOAD_PSTRPR From TRTFASCNLRPR ####> Chargement du tableau des provisions pour renouvellement
 Gosub LOAD_LOF    From TRTFASCNLLOF ####> Chargement du tableau des dépenses
     #- FQ-64312  --------------------------
  If ( G_ACTLEA = G_OUI ) 
    Gosub LOAD_LEA    From TRTFASCNLLEA ####> Chargement de la référence du contrat de location #Fq-64312
  Endif

 If 1=0 & (dim(NOAMT)>0 & NOAMT) & 
&   (dim(NOEVT)>0 & NOEVT) &
&   (dim(NORPR)>0 & NORPR)  
  FIN=1
  Return
 Endif

Return

#------------------------
$SETBOUT
 If find(G_OUI,[M:FC3]LOCKED)
  Call VIREBOUT (CHBOU,"O") From GOBJET
 Endif
Return

#------------------------
$BOUTON
 If BOUT="b"
 Global Integer FASCNLEND
  FIN=1
 Endif
Return

#------------------------
$END_FCT
 Global Integer FASCNLEND
 FIN=1 
Return


######################################################################################
# ROUTINES
######################################################################################

#----------------------------------------
# CHARGEMENT DE L'ONGLET EVENEMENTS
#----------------------------------------
$LOAD_EVENT
If 1=1
 Local Integer NOEVT
 NOEVT=1
Endif
Return

######################################################################################
# SOUS-PROGRAMMES
######################################################################################







