#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBNRYINT","NRYINT",4,"SPENRYINT") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE : # Batch mode
 When "INIT"         : Gosub OUVRE : # Interactive mode
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase
Return

$OUVRE
If clalev([F:CPY])  = 0 : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])  = 0 : Local File GACM       [GCM]  : Endif
If clalev([F:LED])  = 0 : Local File GLED       [LED]  : Endif
If clalev([F:COA])  = 0 : Local File GCOA       [COA]  : Endif
If clalev ([F:NRY]) = 0 : Local File NRYPAR     [NRY] : Endif

Local Char    TIT(200)
Local Char    PATH(GDIMFIC)
Local Char    FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , MACFIC(GDIMFIC)
Local Integer NBRLIN, OK, STAT

# ENERGY Interface
TIT  = mess(233,107,1)

Local Mask NRYINT [DIA]
Raz [M:DIA]

Call GET_DERLU([M:DIA]IDT,"NRY","")
If [M:DIA]IDT<>""
 Call AP_IDT([M:DIA]IDT)
Endif
[M:DIA]TRC=2
Return

$DEBUT
If [M]NBCPY>1
 Effzo STRFCY, ENDFCY
 Grizo STRFCY, ENDFCY
Else
 Actzo STRFCY, ENDFCY
Endif
If [M:DIA]IDT<>""
 Call AM_TYPEXP([M:DIA]TYPEXP)
Endif
Affzo [M:DIA]
Return

$CONTROLE
If GSTATUT=7
 FIN = 1
 Return
Endif
If !GSERVEUR
 TMP = 1
Endif
If [M]NBACC=0 & [M]NBROT=0
 GERR=1 : SAI=1
 GMESSAGE=mess(234,107,1)
 Return
Endif
If [M]NBCPY=0
 GERR=1 : SAI=1
 GMESSAGE=mess(47,7779,1)
 Return
Endif
Return

$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Call TRACE_MASQUE("NRYINT","DIA",nomap) From GTRAITE
Call ECR_TRACE(string$(100,"="),0) From GESECRAN

# Reading in progress...
Call TEMPON(mess(3,100,1)) From GESECRAN

Call TRT_NRY('NRY',[M]IDT,[M]CODPVT,[M]LEDTYP,[M]COA,[M]CPY,[M]NBCPY,[M]STRFCY,[M]ENDFCY,[M]STRDAT,[M]ENDDAT,[M]ACCROT,[M]NBROT,[M]ACC,[M]NBACC,NBRLIN,OK) From PITNRY

Gosub TRF_FILES

If !STAT
 Call ECR_TRACE(mess(39,2243,1)-":"-num$(NBRLIN),0) From GESECRAN
Endif

Call TEMPOFF From GESECRAN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$TRF_FILES
Call MACHINE([M:DIA]DRTWRK,MACHINE,MACFIC) From ORDSYS

## PATH contains the path of the expenses file generated temporarly in the current application,
## in the 'tmp' Directory and with the 'pitnry' Extension
PATH = filpath("tmp",tolower([M:DIA]IDT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitnry")
## FICHIER contains the path of the definive 'Energy_expenses' file that has to be stored in the directory defined in the
## launching screen ([M:DIA]DRTWRK)
FICHIER = filpath([M:DIA]DRTWRK,"Energy_expenses","csv","","",MACHINE)

If [M:DIA]TYPEXP=1
 If left$(FICHIER,2)="#@"
  FICHIER = right$(FICHIER,3)
 Endif
 Call COPCLI(PATH,FICHIER,STAT) From ORDSYS
Elsif [M:DIA]TYPEXP=2
 Call MOVE_EMPTY(PATH,FICHIER,STAT) From ORDSYS
Endif
Return

$TERMINE
If !GSERVEUR & [M:DIA]TRC=2
 TRA = 1
Else
 TRA = 0
Endif
Return

######################################################################################
## Etiquettes masque NRYINT - Lancement Interface ENERGY
######################################################################################
Subprog C_IDT(VALEUR)
Variable Char    VALEUR()
Read [NRY]NRY0=VALEUR
If fstat
 GMESSAGE=mess(13,7710,1)-"("+VALEUR+")"
 mkstat = 2 : End
Endif
End

Subprog AP_IDT(VALEUR)
Variable Char    VALEUR()

Read [NRY]NRY0=VALEUR
If !fstat
 [M:DIA]=[F:NRY]
 Gosub LOAD_TAB From SUBNRY
 If [M:DIA]VOLFIL<>"" & left$([M:DIA]VOLFIL,1)="["
  [M:DIA]TYPEXP = 2 : # Server
 Else
  If GBATCH
   [M:DIA]TYPEXP = 2
  Else
   [M:DIA]TYPEXP = 1
  Endif
 Endif
 Call AM_TYPEXP([M:DIA]TYPEXP)
 If [F:NRY]PERFRY=1 : # Every day
  [M]STRDAT = date$-1
  [M]ENDDAT = date$-1
 Elsif [F:NRY]PERFRY=2 : # Every week
  [M]STRDAT = aweek(week(date$)-1,year(date$))
  [M]ENDDAT = aweek(week(date$)-1,year(date$))+6
 Else : # Every month
  [M]STRDAT = gdat$(1,month(date$)-1,year(date$))
  [M]ENDDAT = eomonth([M]STRDAT)
 Endif
 Affzo [M:DIA]
 Call SET_DERLU("NRY",VALEUR)
Endif
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
 Else Raz [M]VOLFIL : Grizo [M]VOLFIL
 Endif
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

Subprog AM_CPYGRU(VALEUR)
Variable Char    VALEUR()
Call AM_CPYGRU(VALEUR) From SUBNRY
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call AS_LEDTYP(VALEUR) From SUBNRY
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From SUBNRY
End

Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR
Call AM_LEDTYP(VALEUR) From SUBNRY
End

Subprog C_NBCPY
Call C_NBCPY From SUBNRY
End

Subprog AM_NBCPY
Call AM_NBCPY From SUBNRY
End

Subprog APRES_NBCPY
Call APRES_NBCPY From SUBNRY
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From SUBNRY
End

Subprog C_STRFCY(VALEUR)
Variable Char    VALEUR()
Call C_STRFCY(VALEUR) From SUBNRY
End

Subprog C_ENDFCY(VALEUR)
Variable Char    VALEUR()
Call C_ENDFCY(VALEUR) From SUBNRY
End

Subprog C_ACCROT(VALEUR)
Variable Char    VALEUR()
Call C_ACCROT(VALEUR) From SUBNRY
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
Call C_ACC(VALEUR) From SUBNRY
End

#----------------------------------------------#
Subprog GET_DERLU(VALEUR,ABREV,CRITERE)
Variable Char VALEUR
Value Char ABREV,CRITERE
Onerrgo RIEN
Local File ALSTRD [ALS]
Local Char CLE(GLONID1) , PROGOBJ(GLONADC)
PROGOBJ = "WO"+ABREV
Gosub NOMFIC From =PROGOBJ
Local File =NOMFIC [A__]
If CRITERE="" : CRITERE = "1=1" : Endif
Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
For [ALS]ALS0
 CLE = [F:ALS]CLES
 K = instr(1,CLE,"~")
 If K
  CLE = left$(CLE,K-1)
 Endif
 Read [A__] = CLE
 If !fstat & evalue(CRITERE)
  VALEUR = CLE : Break
 Endif
Next ALS
Close Local File [ALS] , [A__]
End

#----------------------------------------------#
Subprog SET_DERLU(ABREV,CLE)
Value Char ABREV,CLE
Local File ALSTRD [ALS]
Local Integer I , K , OK
Trbegin [ALS]
 Gosub ECR_DERLU
Commit
Close Local File [ALS]
End


#----------------------------------------------#
$ECR_DERLU
Filter [ALS] Where USR=GUSER & OBJ=ABREV
Read [ALS]ALS0 Last
If fstat<=2
 If [F:ALS]LIG>=32000
  Delete [ALS] Where USR=GUSER & OBJ=ABREV
  K = 1
 Else
  K = [F:ALS]LIG+1
 Endif
Else
 K = 1
Endif
Raz I, OK
For [ALS]ALS0
 If [F:ALS]CLES=CLE : OK = 1 : Break : Endif
 If dim(CLEVALEUR)<0
  I+=1
 Else : ## GEODE
  OK=1
  Local Integer I1, I2, I3
  If CLEFCY<>""
   I2=0
   J=find(CLEFCY,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If I2 & GFCY<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If CLEDEP<>""
   I2=0
   J=find(CLEDEP,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If GDEP<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If OK : I+=1 : OK=0 : Endif
 Endif
Next
Filter [ALS]
If OK
 [F:ALS]LIG = K
 Rewrite [ALS]
Else
 If I>=GNBDERNIER
  Read [ALS]ALS0(2) = GUSER ; ABREV
  If fstat<=2 : OK = 1 : Endif
 Endif
 Raz [F:ALS]
 [F:ALS]USR  = GUSER
 [F:ALS]OBJ  = ABREV
 [F:ALS]LIG  = K
 [F:ALS]CLES = CLE
 If !OK
  Write [ALS]
 Else
  Rewrite [ALS]
 Endif
Endif
Return

$RIEN
Resume

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End
