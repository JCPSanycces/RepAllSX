#<AdxTL>@(#)10.0.0.0 $Revision$
#######################################################################
#                                                                     #
#    VISUALISATION des CARACTERISTIQUES                               #
#    de la REGLE de GESTION de STOCK ACTIVE                           #
#                                                                     #
#######################################################################
#                                                                     #
# Action VISUSRUV                                                     #
#                                                                     #
#######################################################################
$ACTION
Case ACTION
 When "DEBUT"      : Gosub DEBUT
Endcase

Return

$DEBUT

[M:SRUV] = [F:SRU]

[M:SRUV]STOFCY = PARAM(1)
[M:SRUV]ITMREF = PARAM(2)
[M:SRUV]TRSTYP = val(PARAM(3))
[M:SRUV]TRSCOD = PARAM(4)

If [F:ITM]ITMREF<>[M:SRUV]ITMREF 
   Read [ITM]ITM0=[M:SRUV]ITMREF
   If fstat Raz [F:ITM] Endif
Endif
[M:SRUV]TCLCOD = [F:ITM]TCLCOD 

[M:SRUV]NIVEAU = 1 
If [F:SRU]TCLCOD<>""
   If [F:SRU]STOFCY<>""
      If [F:SRU]TRSCOD<>""
         [M:SRUV]NIVEAU = 5 
      Else
         [M:SRUV]NIVEAU = 4
      Endif
   Else 
      If [F:SRU]TRSCOD<>""
         [M:SRUV]NIVEAU = 3 
      Else
         [M:SRUV]NIVEAU = 2
      Endif
   Endif
Endif

Affzo [M:SRUV]1,99

Return
