#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITCMATCH1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:57"
A_USER  = "DOC"
A_STAMP = "20181109230457"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
 When "NBLIG1"
  If [M]NBLIG1=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ITCMATCH1 [ICM1]
Gosub HORODAT
Local Inpbox "ITCMATCH1" From GFONCTION At A_STAMP With A_WINDPREV Mask [ICM1] As [SIM_]
Grizo [ICM1]5
Grizo [ICM1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ICM1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=9
X1(4)=1 : X2(4)=112 : Y1(4)=10 : Y2(4)=18
Return

$ON_COST1
Onevent BEFORE_AREA Gosub AV_COST1 From W1ITCMATCH1
Return

$AV_COST1
## Action PARDEV
Gosub _AFF
Return

$ON_COST2
Onevent BEFORE_AREA Gosub AV_COST2 From W1ITCMATCH1
Return

$AV_COST2
## Action PARDEV
Gosub _AFF
Return

$ON_VARCST
Onevent BEFORE_AREA Gosub AV_VARCST From W1ITCMATCH1
Return

$AV_VARCST
## Action PARDEV
Gosub _AFF
Return

$ON_INVDTA1
Onevent BEFORE_AREA Gosub AV_INVDTA1 From W1ITCMATCH1
Return

$AV_INVDTA1
## Action PARDEV
Gosub _AFF
Return

$ON_CSTTOT1
Onevent BEFORE_AREA Gosub AV_CSTTOT1 From W1ITCMATCH1
Return

$AV_CSTTOT1
## Action PARDEV
Gosub _AFF
Return

$ON_STU1
Return

$ON_INVDTA2
Onevent BEFORE_AREA Gosub AV_INVDTA2 From W1ITCMATCH1
Return

$AV_INVDTA2
## Action PARDEV
Gosub _AFF
Return

$ON_CSTTOT2
Onevent BEFORE_AREA Gosub AV_CSTTOT2 From W1ITCMATCH1
Return

$AV_CSTTOT2
## Action PARDEV
Gosub _AFF
Return

$CHG_STY
Return


