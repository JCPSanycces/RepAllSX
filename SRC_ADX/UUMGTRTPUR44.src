#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
# UUMGTRTPUR44   Reprise des signatures/Suppression écran et fenetres   Module Achats#
######################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
     Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR44") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR44(DOSSIER)
  Call MAJ_UUMGTRTPUR44(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR44(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

##2 - On vide les fichiers selon le cas
#######################################


##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR44",ERR) From TRTMIG

End

##############################################################################################
##############################################################################################
Subprog MAJ_UUMGTRTPUR44(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-16 by SR : Adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR
Local Integer TOTNBR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#

If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################
Gosub MIG_OUVRE From TRTMIG

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",2,ERR) From TRTMIG : #2=En cours
Call MIGGETTOTNBR (DOSSIER,"PAPPCONF",TOTNBR,ERR) From TRTMIG : #gerer nb lignes a traiter
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGTRTPUR44",TOTNBR,ERR) From TRTMIG
Commit

###################

Call ECR_TIME("UUMGTRTPUR44 Deletion of unused screens-windows Process : Delete AWINDOW") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR44 : Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:PACM]) = 0 : Local File =DOSSIER+"."+WNAMPACM   [PACM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR09DEL

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR44",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  FILTER -----#
Filter [PACM] Order By Key CLE=[F:PACM]APPRUL;[F:PACM]CPY

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR44" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Gosub SET_FIRST From TRTFIRST

$LOOP_DEL00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PACM]APPRUL=val(TABMIGKEY(1)) & [F:PACM]CPY>TABMIGKEY(2) "
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PACM]APPRUL>val(TABMIGKEY(1))"
Else
 CRITERE = "1=1"
Endif

GOK = 1

For [PACM]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR44" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLEDEL : Endif
  Endif

  #Appel proc de migration
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    #----- Suppression écran WCxxxy1 -----#
    MTO   ="WC"+[F:PACM]CPY+num$([F:PACM]APPRUL)+"1"
    Call GENECR(DOSSIER,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,9,0,0,WRET) From GENECR
    #----- Suppression fenêtre WCxxxy -----#
    NOMWIN="WOPAP" +[F:PACM]CPY+num$([F:PACM]APPRUL)
    Call DELWIN(NOMWIN,DOSSIER) From MSKDIV
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:PACM]APPRUL)
    TABMIGKEY(2) = [F:PACM]CPY
    STOP=1
    Break
  Endif
$SUITE_BOUCLEDEL
Next

$FIN_BOUCLEDEL
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR44",7,ERR) From TRTMIG : #7=Erreur
Else
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Trbegin [AMY]
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR44",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEDEL
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR44",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_DEL00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Filter [PACM]
Close Local File [PACM]
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR44") From TRTMIG
Call ECR_TIME("UUMGTRTPUR44 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


##########################################################################
$OUVRE_PUR09DEL
Local File =DOSSIER+".AWINDOW"   [AWI]
Local File =DOSSIER+".AWINPAR"   [AWP]
Local File =DOSSIER+".AWINBRO"   [AWB]
Local File =DOSSIER+".AWINBOUT"  [AWT]
#-----
Local Char     NOMWIN(GLONFEN)
Local Char     MFROM (GLONAMK)
Local Char     MTO   (GLONAMK)
Local Integer  TBLOC (15)
Local Char     TZONE (GLONAVA)(200)
Local Integer  TMOD  (200)
Local Char     TINT  (30)(200)
Local Char     TTAB  (GLONATB)(200)
Local Char     TFLD  (GLONAVA)(200)
Local Integer  WRET, WNBR
Local Integer  IBLO, IZON
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR44(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR44(APPLI)
End

