######################################################################################
## Etiquette ajoutée par le superviseur (écran MTK2) 24/09/2009 17:15:36 (TS)
######################################################################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:MTK0]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:MTK0]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:MTK2]WRH(nolign-1)<>""
   Raz [M:MTK2]LOC(nolign-1)
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MTK2) 31/03/2011 14:26:36 (TS)
######################################################################################
#--- Bug 72649
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
If [M:MTK2]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:MTK2]LOC(nolign-1),[M:MTK2]WLOCSEQ(nolign-1)) From STKACT
Endif
End
