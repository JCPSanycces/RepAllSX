#<AdxTL>@(#)7.0.0.0 $Revision$
# SUBMTK2
#Actions sur champs pour masques MTK2
#                                               sr Janvier 1999
################################################################
# Issue X3-102712 - 2018-07-31 by BAKHA : Disable Non-conformance create button in Create/Amend mode

$ACTION
Case ACTION
     When "AAPRES_NBITM" : Gosub AAPRES_NBITM
     When "AB3_NBITM"    : Gosub AB3_NBITM
     When "BB3_NBITM"    : Gosub BB3_NBITM
     When "AB6_NBITM"    : Gosub AB6_NBITM
     When "BB6_NBITM"    : Gosub BB6_NBITM
     When "AB11_NBITM"   : Gosub AB11_NBITM
     When "AB1_LOC"      : Gosub AB1_LOC
     When "BB1_LOC"      : Gosub BB1_LOC
     When Default
Endcase
Return


$AAPRES_NBITM
#-------------------------------------------------#
# Appelé avant l'action SAISTOENT                 #
#-------------------------------------------------#
Local Shortint WRET
Local Char     LSUP(1)
Local Shortint NOL : NOL=nolign-1

If [M:MTK2]UOMCPLQTY(NOL) = 0 : Return : Endif


If [F:ITM]ITMREF<>[M:MTK2]ITMREF(NOL)
  Read [ITM]ITM0=[M:MTK2]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
Diszo [M:MTK2]ITMREF(nolign-1)

Call OUVENT([M:MTK0]MFGFCY,"MTK2",5,[M:MTK0]TRSCOD,"",15,[M:MTK0]MFGTRKDAT,nolign-1,NBITM,"MTS","",WRET) From STKENT
Call AV_ITMREF([M:MTK2]ITMREF(nolign-1))
Affzo [M:MTK2]ITMREF(nolign-1)
Return


$AB3_NBITM
#------------------------------------------------------#
# Avant exécution du bouton Tunnel OF                  #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONVCR)
Local Char     WCLE2(GLONVCR)
WOBJET="MFG"
WCLE1 =[M:MTK2]MFGNUMIT (NOL)
Return

$BB3_NBITM
#------------------------------------------------------#
# Après exécution du bouton Tunnel OF                  #
#------------------------------------------------------#
nolign=NOL+1
#----- Relecture transaction de saisie -----#
Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
Return

$AB6_NBITM
#--------------------#
# Avant modif de qté #
#--------------------#
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Raz GBIDI2
GFCY=[M:MTK0]MFGFCY
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVENT=0
   Return
Endif
# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
If func MFGLIB.CHKMFGLOCK([M:MTK2]MFGNUMIT(nolign-1),1)
    Call ERREUR(mess(280,193,1)) From GESECRAN
    GOUVENT = 0
    Return
Endif
# Issue 90462 - 2013-06-13 by CCC
GSAVMFGNUM = [M:MTK2]MFGNUMIT(nolign-1)

GOUVENT=2
Return

$BB6_NBITM
#------------------------#
# Apres action modif qté #
#------------------------#
# Issue 90462 - 2013-06-13 by CCC
#Unlock ="MFG"+[M:MTK2]MFGNUMIT(nolign-1)
Unlock ="MFG"+GSAVMFGNUM
If GRELITMTK=1
  mkstat = 4
Endif
Return


$AB11_NBITM
Local Integer  NBTBO
Local Char     WCLE1(15)
Local Char     WCLE2(15)
#
If clalev([F:TBO]) <= 0 : Local File TABBOMALT [TBO] : Endif
WCLE1=[M:MTK2]ITMREF(nolign-1)
#   sélectionner les alt. de nomenclature compatibles avec site de prod
Filter [TBO] Where ([F:TBO]FCY=[M:MTK0]MFGFCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=2
For [TBO]TBO0
     GBOMALT (NBTBO) = [F:TBO]BOMALT
     NBTBO += 1
Next
#
Filter [TBO]
#  FILTRE sur article parent
Local File BOM [BOH] Where find(BOMALT, GBOMALT) & ITMREF=[M:MTK2]ITMREF(nolign-1) & BOMALTTYP = 2
#
WCLE2 = num$([M:MTK2]BOMALT(nolign-1))
GFONBOD="BOMP"
GDATEREF=[M:MTK0]MFGTRKDAT
Return




$AB1_LOC
#--------------#
# avant tunnel #
#--------------#
GLOCSEL = "LOCTYP='"+[M:MTK2]LOCTYP(nolign-1)+"'"
Return

$BB1_LOC
#--------------#
# apres tunnel #
#--------------#
Raz GLOCSEL
Return




#-------------------- Action sur écran MTK2 -------------------------------#
########################################
Subprog AS_QTESUIVITM(VALEUR)
Variable Decimal VALEUR
If [F:MFG]TRKFIRST = [0/0/0] & VALEUR = 0
    Case [F:MFG]ITMLINNBR
        When 1       : VALEUR = [F:MFI]RMNEXTQTY / [F:MFI]UOMSTUCOE
                       Call QTEARR(VALEUR,[F:MFI]UOM) From TRTDIV
        When Default : VALEUR = [F:MFG]RMNEXTQTY
    Endcase
Endif
End

########################################
Subprog AP_QTESUIVITM(VALEUR)
Variable Decimal VALEUR
Local Integer WVALEUR, WRET
Local Decimal WCOEFF
If GREP <> "C" : End : Endif

If [M:MTK2]QTESUIVITM <> VALEUR | [M:MTK2]NBITM = 0
   If [M:MTK0]ITMTRKFLG = 2
        Call DELSTOENTW(-1,-1,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
        Effzo [M:MTK2]10
        # 05.03 demande 18080
        If [M:MTK2]QTESUIVITM = 0 & VALEUR = 0
            Call CHARG_ITM([M:MTK0]MFGNUM,VALEUR,1) From SUBMTKB
        Else
            Call CHARG_ITM([M:MTK0]MFGNUM,VALEUR,2) From SUBMTKB
        Endif
        Affzo [M:MTK2]10
    Endif

# 09.02 demande 15834
    If [M:MTK0]MATTRKFLG = 2 : [M:MTK3]WOPE2 = 9999
#                               [M:MTK3]STOCOD  = 3
                               [M:MTK3]FILTMAT = [F:MTS]FILTDEF
                               If VALEUR <> 0
                                   Case [F:MFG]ITMLINNBR
                                        When 1       : # Issue 78551 - 2011-12-12 by CCC : [MFI] peut-être positionné sur le sous-produit
                                                       Filter [MFI] Where MFGNUM=[M:MTK0]MFGNUM
                                                       Read [MFI]MFI0 First
                                                       Filter [MFI]
                                                       WCOEFF = VALEUR / [F:MFI]UOMEXTQTY
                                        When Default : WCOEFF = VALEUR / [F:MFG]EXTQTY
                                   Endcase
                               Elsif [M:MTK3]NBMAT=0 : [L]WCOEFF=-1 : # GH 16/10/12 bug 81005
                               Endif
                               # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
                               # Ce sont les quantités qui sont arrondies
                               ## 01.02 demande 12597
                               ## 02.03 demande 17092
                               #WCOEFF = arr(WCOEFF,0.00000001)
# 04.02 demande 13793
#                               If WCOEFF = 0 : WCOEFF = 1 : Endif
                               [M:MTK3]QTESUIVMAT = VALEUR
                               Effzo [M:MTK3]15
                               Call DELSTOSORW(-1,0,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
                               Call CHARG_MAT([M:MTK0]MFGNUM,[M:MTK3]FILTMAT,WCOEFF,VALEUR) From SUBMTKB
                               Grizo [M:MTK3]5
                               Affzo [M:MTK3]
    Endif
    If [M:MTK2]NBITM = 0 : Call MESSAGE(mess(99,100,1)) From GESECRAN : Endif
Endif
End


########################################
Subprog B4_NBITM
#Activation,suppression article
Local Integer NOL : NOL = nolign-1
# 07.02 demande 14910
Local Integer I, WRETOUR
Local Decimal WCOEFF
Local Integer WMFGLIN : WMFGLIN = [M:MTK2]MFGLIN(NOL)
Case[M:MTK2]MODIFLG(NOL)
    When 0 : [M:MTK2]UOMCPLQTY(NOL)  = 0
             [M:MTK2]CPLQTY(NOL)  = 0
             [M:MTK2]MODIFLG(NOL) = 1
             WCOEFF = 0
             Call DELSTOENTW(NOL,NOL,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
    When 1 : [M:MTK2]UOMCPLQTY(NOL)  = [M:MTK2]WANCQTY(NOL)
             [M:MTK2]CPLQTY(NOL)     = [M:MTK2]UOMCPLQTY(NOL) * [M:MTK2]UOMSTUCOE(NOL)
             Call QTEARR([M:MTK2]CPLQTY(NOL),[M:MTK2]STU(NOL)) From TRTDIV
             [M:MTK2]MODIFLG(NOL) = 0
             WCOEFF = 1
             status=0
             Call STJSTOENTW("MTK2",5,15,[M:MTK0]MFGTRKDAT,NOL,NBITM,"MTS",3,WRETOUR) From STKENT

Endcase
# Issue 87766 - 2013-02-21 by CCC
If [M:MTK2]WSTOSEQ(NOL)=0 | !find([M:MTK2]WSTOSEQ(NOL),[M:ENTW]WSTOSEQ)
    Raz [M:MTK2]WLOCSEQ(NOL)
Endif

# 07.02 si exclusion d'un article lancé recalcul des conso matière demande 14910
# Si le suivi opératoire est présent, seules les matières sans numéro d'opé seront réajustées (contrôle fait dans REAJUST_ITMMAT)
#  idem si réactivation
# llc 07.02 15291
If [F:MTS]MATTRKFLG = 2
    I = nolign
    Gosub REAJUST_ITMMAT From SUBMTKB
    Affzo [M:MTK3]15
Endif
Affzo [M:MTK2]10
mkstat = 4
End

########################################
Subprog B5_NBITM
GOUVENT = 16384 # =2^14
End

########################################
Subprog C_NBITM
#Si ligne exclue modif impossible
# 07.02 demande 14910
GMODIF = 2
If status = 75
   If [M:MTK2]MODIFLG(nolign-1) = 1 : GMESSAGE = mess(83,193,1)
      GMODIF = 1
      mkstat = 1
      End
   Endif
   # Issue 38672 GH 26/07/2017 - store qty before modification
   [M:MTK2]OCPLQTY(nolign-1) =  [M:MTK2]CPLQTY(nolign-1)
Endif
#si reprise
If status = 82 : mkstat=2 : Endif
End

########################################
Subprog AM_UOMCPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer I,OK
Local Decimal WCOEFF, WCPLQTY
Local Integer LLIN : LLIN = [M:MTK2]ITMTRKLIN(nolign-1)

WCPLQTY = VALEUR * [M:MTK2]UOMSTUCOE(nolign-1)

# Issue 64229 - 2010-05-20 by CCC : remplacement de UOMEXTQTY par EXTQTY dans les tests
If (GREP = "C" & WCPLQTY > [M:MTK2]EXTQTY(nolign-1)) |
&  (GREP <> "C" & WCPLQTY - [M:MTK2]CPLQTY(nolign-1) > [M:MTK2]EXTQTY(nolign-1))
        Call AVERTIR(mess(54,190,1),OK) From GESECRAN
        If OK = 1 : mkstat = 1 : End : Endif
Endif

#--- Contrôle si la quantité UC génère une qté US arrondie
Local Integer LRET
If [M:MTK2]UOM(nolign-1)<>[M:MTK2]STU(nolign-1)
   Call STKCTRCOE(VALEUR,[M:MTK2]UOMSTUCOE(nolign-1),[M:MTK2]STU(nolign-1),LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

[M:MTK2]CPLQTY(nolign-1)= VALEUR * [M:MTK2]UOMSTUCOE(nolign-1)
Call QTEARR([M:MTK2]CPLQTY(nolign-1),[M:MTK2]STU(nolign-1)) From TRTDIV
If VALEUR < [M:MTK2]UOMEXTQTY(nolign-1)
            [M:MTK2]CLEFLG(nolign-1) = 1
Else        [M:MTK2]CLEFLG(nolign-1) = 2
Endif
Affzo [M:MTK2]CPLQTY(nolign-1), CLEFLG(nolign-1)
If [M:MTK2]CPLQTY(nolign-1) = 0
   Call DELSTOENTW(nolign-1,nolign-1,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
    # Issue 87766 - 2013-02-21 by CCC
    If [M:MTK2]WSTOSEQ(nolign-1)=0 | !find([M:MTK2]WSTOSEQ(nolign-1),[M:ENTW]WSTOSEQ)
        Raz [M:MTK2]WLOCSEQ(nolign-1)
    Endif
Else
    # Issue 87766 - 2013-02-21 by CCC
    If [M:MTK2]WLOCSEQ(nolign-1) = 0
        Call STKWLOCSEQ("MTK2", nolign-1, OK) From STKECR
        If OK=1
            mkstat=2
            End
        Endif
    Endif
Endif
#
#Lignes suivantes rajoutées pour gérer les sous-produits  05 00
If [M:MTK2]UOMEXTQTY(nolign-1) <> 0
    If VALEUR <> 0
        WCOEFF =  [M:MTK2]UOMEXTQTY(nolign-1) / VALEUR
        # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
        # Ce sont les quantités qui sont arrondies
        ## 01.02 demande 12597
        ## 02.03 demande 17092
        #WCOEFF = arr(WCOEFF,0.00000001)
    Else
        WCOEFF = 0
    Endif
    #recalcul éventuel de la qté réalisée des sous-produits associés ssi pas au forfait
    For I = nolign To [M:MTK2]NBITM-1
        If [M:MTK2]ITMLIN(I) = [M:MTK2]MFGLIN(nolign-1) & [M:MTK2]ITMTYP(I) = 2 & [M:MTK2]LIKQTYCOD(I) <> 2
           If WCOEFF <> 0
               [M:MTK2]UOMCPLQTY(I) = [M:MTK2]UOMEXTQTY(I) / WCOEFF
           Else
               Raz [M:MTK2]UOMCPLQTY(I)
           Endif
           Call QTEARR([M:MTK2]UOMCPLQTY(I),[M:MTK2]UOM(I)) From TRTDIV
           [M:MTK2]CPLQTY(I)= [M:MTK2]UOMCPLQTY(I) * [M:MTK2]UOMSTUCOE(I)
           Call QTEARR([M:MTK2]CPLQTY(I),[M:MTK2]STU(I)) From TRTDIV
           If [M:MTK2]UOMCPLQTY(I) < [M:MTK2]WANCQTY(I)
                       [M:MTK2]CLEFLG(I) = 1
           Else        [M:MTK2]CLEFLG(I) = 2
           Endif
           Affzo [M:MTK2]UOMCPLQTY(I),CPLQTY(I), CLEFLG(I)
           If [M:MTK2]CPLQTY(I) = 0
               Call DELSTOENTW(I,I,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
                # Issue 87766 - 2013-02-21 by CCC
                If [M:MTK2]WSTOSEQ(I)=0 | !find([M:MTK2]WSTOSEQ(I),[M:ENTW]WSTOSEQ)
                    Raz [M:MTK2]WLOCSEQ(I)
                Endif
            Else
               [M:MTK2]WSTOFLG(I) = 0
               Call AV_ITMREF([M:MTK2]ITMREF(I))
               Affzo [M:MTK2]ITMREF(I)
                # Issue 87766 - 2013-02-21 by CCC
                If [M:MTK2]WLOCSEQ(I) = 0
                    Call STKWLOCSEQ("MTK2", I, OK) From STKECR
                    If OK=1
                        mkstat=2
                        Break
                    Endif
                Endif
           Endif
        Endif
    Next I
Endif
#
[M:MTK2]UOMCPLQTY(nolign-1) = VALEUR
End

########################################
Subprog AS_CLEFLG(VALEUR)
Variable Integer VALEUR
If [M:MTK2]UOMCPLQTY(nolign-1) = 0
   mkstat = 2
Endif
End

############################################################
Subprog AS_LOT(VALEUR)
Variable Char     VALEUR
mkstat = 0
#---------------------------------------------------------------------------------#
#Si lot retenu à la création de l'OF, alors pas de saisie                         #
#---------------------------------------------------------------------------------#
Read [F:MFI]MFI0 = [M:MTK2]MFGNUMIT(nolign-1);[M:MTK2]MFGLIN(nolign-1)
If fstat : Raz [F:MFI] : Endif
If VALEUR <> "" & VALEUR = [F:MFI]LOT : mkstat = 2 : End : Endif
End


########################################
Subprog AV_ITMTYP(VALEUR)
Variable Integer VALEUR
# mise en relief sous-produit
If VALEUR = 2
    pcolor = GCOUL(3)
Else
    pcolor = GCOUL(0)
Endif

End

########################################
Subprog APRES_NBITM
# Issue 38672 GH 26/07/2017 - material update only when quantity is changed
If [M:MTK2]CPLQTY(nolign-1) <> [M:MTK2]OCPLQTY(nolign-1)
   Call UPDMATQTY(nolign-1)
Endif
End

########################################
# Met à jour les quantités sur l'écran MTK3
Subprog UPDMATQTY(PIND)
Value Integer PIND

Local Decimal WCOEFF
# 08.01
Local Integer WMFGLIN : WMFGLIN = [M:MTK2]MFGLIN(PIND)
# 12.01 demande 11823
If [F:MFI]MFGNUM <> [M:MTK2]MFGNUMIT(PIND) | [F:MFI]MFGLIN <> [M:MTK2]MFGLIN(PIND)
    Read [F:MFI]MFI0 = [M:MTK2]MFGNUMIT(PIND);[M:MTK2]MFGLIN(PIND)
    If fstat : Raz [F:MFI] : Endif
Endif

#Si les 3 suivis s'enchainent, seules les matières sans numéro d'opé sont réajustées (contrôle dans REAJUST_ITMMAT)
#On ne réajuste pas si OF multi article  et cumul au suivi  08.01 demande 10269
# 01.06 demande 34487 remplacer UOMCPLQTY et UOMEXTQTY par CPLQTY et EXTQTY
If [M:MTK0]MATTRKFLG = 2 & (GCUMMAT <> 3 | [F:MFG]ITMLINNBR = 1)
    # 09.02 demande 15834
    [M:MTK3]WOPE2 = 9999
    [M:MTK3]FILTMAT = [F:MTS]FILTDEF
    # Issue 88117 - 2013-02-20 by CCC : Si qté prévue nulle (sous-produit par ex) => pas de réajustement)
    If [F:MFI]EXTQTY<>0
        If [M:MTK2]CPLQTY(PIND) <> 0
                WCOEFF = [M:MTK2]CPLQTY(PIND) / [F:MFI]EXTQTY
                # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
                # Ce sont les quantités qui sont arrondies
                #WCOEFF = arr(WCOEFF,0.00000001)
        Endif
    # 01.06
    #    [M:MTK3]QTESUIVMAT = [M:MTK2]CPLQTY(PIND)
    # 08.01
         I = nolign
         Gosub REAJUST_ITMMAT From SUBMTKB
         Affzo [M:MTK3]15
         # Issue 38672 GH 26/07/2017 - When a material is not readjusted, we return on the field
         #                             Tracked qty of the production line, in order to interrupt
         #                             the creation process especially when the message appears
         #                             after clicking on button Create
         If WNO_REAJUST=1
            zonsui="[M:MTK2]UOMCPLQTY("+num$(PIND)+")"
         Endif
     Endif
Else
    Grizo [M:MTK3]5
    Affzo [M:MTK3]1-99
Endif

End

########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()

If [M:MTK2]WSTOFLG(nolign-1) = 0 & [M:MTK2]CREFLG(nolign-1)=0
    pcolor = GCOUL(1)
Else
    pcolor = GCOUL(0)
Endif
End

########################################
Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()

Local Char LUSCAV(5)
Local Char LFMT(GLONARP)
Local Integer LMODIF
Local Integer NOL : NOL = nolign-1


Call CTLUOM ([M:MTK2]ITMREF(NOL),3,"", VALEUR,[M:MTK2]UOMSTUCOE(NOL), LUSCAV, LFMT, LMODIF) From STKACT
If LUSCAV <> "S"
   If LUSCAV <> "C"
      mkstat = 2
      End
   Endif
Endif
If LMODIF = 1
  Affzo [MTK2]UOMSTUCOE(NOL) : # pb diszo
  Diszo [MTK2]UOMSTUCOE(NOL)
  Affzo [MTK2]UOMSTUCOE(NOL) : # pb diszo
  [M:MTK2]WSTOSAI(NOL)=left$([M:MTK2]WSTOSAI(NOL),2)+"2"+right$([M:MTK2]WSTOSAI(NOL),4)
Else
  Affzo [MTK2]UOMSTUCOE(NOL) : # pb diszo
  Actzo [MTK2]UOMSTUCOE(NOL)
  Affzo [MTK2]UOMSTUCOE(NOL) : # pb diszo
  [M:MTK2]WSTOSAI(NOL)=left$([M:MTK2]WSTOSAI(NOL),2)+"0"+right$([M:MTK2]WSTOSAI(NOL),4)
Endif

# Recalcul de la quantité en UOM et de la quantité restante en UOM
[M:MTK2]UOMEXTQTY(NOL) = [M:MTK2]MFIRMNQTY(NOL) / [M:MTK2]UOMSTUCOE(NOL)
[M:MTK2]UOMCPLQTY(NOL) = [M:MTK2]CPLQTY(NOL) / [M:MTK2]UOMSTUCOE(NOL)
Call QTEARR([M:MTK2]UOMCPLQTY(NOL),VALEUR) From TRTDIV
If [M:MTK2]UOMCPLQTY(NOL) = 0
   # si le résultat de la conversion et arrondi donne 0 , on met 0 dans la qté en US
   [M:MTK2]CPLQTY(NOL) = 0
Else # GH 08/12/14 bug 98683
   [M:MTK2]CPLQTY(NOL)= [M:MTK2]UOMCPLQTY(NOL) * [M:MTK2]UOMSTUCOE(NOL)
   Call QTEARR([M:MTK2]CPLQTY(NOL),[M:MTK2]STU(NOL)) From TRTDIV
Endif

Affzo [MTK2]UOMSTUCOE(NOL), UOMCPLQTY(NOL), CPLQTY(NOL)
End

########################################
Subprog AM_NBSLO(VALEUR)
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
Call STKCTRNBSLO(VALEUR, [M:MTK2]UOM(NOL), [M:MTK2]UOMCPLQTY(NOL)) From STKACT
End

########################################
Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
#-------------------------------------------#
# Contrôle sous-lot et positionnement SLOTF #
#-------------------------------------------#
Local Shortint NOL : NOL=nolign-1
Local Char WBPSLOT(GLONLOT)
If VALEUR<>""
      Call STKCTRSLO(VALEUR, [M:MTK2]NBSLO(NOL), [M:MTK2]LOT(NOL),
&                   [M:MTK2]ITMREF(NOL),WBPSLOT,[M:MTK2]GESLOT(NOL),"", 0, 0, 0,
&                   [M:MTK0]MFGFCY, [M:MTK2]SLOF(NOL)) From STKACT
      Affzo [M:MTK2]SLOF(NOL)
Endif
End

########################################
Subprog AM_UOMSTUCOE(VALEUR)
Variable Decimal VALEUR

#--- Contrôle si le coef UC/US génère une qté US arrondie
Local Integer LRET
If [M:MTK2]UOM(nolign-1)<>[M:MTK2]STU(nolign-1)
   Call STKCTRCOE([M:MTK2]UOMCPLQTY(nolign-1),VALEUR,[M:MTK2]STU(nolign-1),LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

[M:MTK2]CPLQTY(nolign-1) = [M:MTK2]UOMCPLQTY(nolign-1) * VALEUR
Affzo [M:MTK2]CPLQTY(nolign-1)
End

########################################
# GBOUT1  : détail suivi
# GBOUT2  : détail article
# GBOUT3  : tunnel OF
# GBOUT4  : Suivre / ne pas suivre
# GBOUT5  : Saisie détail quantité
# GBOUT6  : modification des mvts
# GBOUT7  : infos lot
# GBOUT8  : complément lot
# GBOUT9  :
# GBOUT10 : Stock par lot (consultation)
# GBOUT11 : Tunnel nomenclature
# GBOUT12 : Consultation des mouvements
# GBOUT13 : Create Non-conformance

Subprog IB_NBITM
Local Integer NOL : NOL = nolign-1

If GREP <> "C"
   If [F:MKI]MFGTRKNUM <> [M:MTK0]MFGTRKNUM | [F:MKI]ITMTRKLIN <> [M:MTK2]ITMTRKLIN(NOL)
      Read [F:MKI]MKI0 = [M:MTK0]MFGTRKNUM;[M:MTK2]ITMTRKLIN(NOL)
      If fstat : Raz [F:MKI] : Endif
   Endif
   # 11.01 demande 11580
   If [M:MTK2]ITMTYP(NOL) = 1 & [F:MFG]MFGNUM <> [M:MTK2]MFGNUMIT(NOL)
      Read [F:MFG]MFG0 = [M:MTK2]MFGNUMIT(NOL)
      If fstat : Raz [F:MFG] : Endif
   Endif
Endif

#  Bouton détail suivi et bouton détail article
If [M:MTK2]PRODTYP(NOL) <> 1
   Raz GBOUT1,GBOUT2,GBOUT3
Else
   Raz GBOUT11
Endif

If GREP = "C"
   #  Bouton Ne pas suivre et réactiver
   Case [M:MTK2]MODIFLG(NOL)
        When 0 : GBOUT4 = mess(415,198,1)
        When 1 : GBOUT4 = mess(185,198,1)
   Endcase
   Raz GBOUT12
Else
        Raz GBOUT4
Endif

# Issue X3-94198 - 2018-07-03 by ALSHE : Activate Non-conformance creation button
If func AFNC.ACTIV("NCS") and !find (GREP, "C","D","M","A") # Issue X3-102712
     GBOUT13 = mess(508,198,1) # Create Non-conformance
Else
     Raz GBOUT13
Endif
# End issue X3-94198

# Issue 83491 - 2012-08-21 by CCC
Call STKCTRIPT( [M:MTK0]MFGTRKDAT,[M:MTK0]MFGFCY, "1") From STKLIB
If find(GERR,1,2)
    Raz GBOUT5, GBOUT6
    Raz GERR, GMESSAGE, mkstat
Endif

#  Bouton saisie détail quantités
Call STKINIBTN( 5, 6, 7, 8, "MTK2", "MTS", [M:MTK2]ITMREF(NOL) , [M:MTK0]MFGFCY ) From STKENT
# ces boutons sont re géré ici car soumis à des contrôles particuliers

# si ligne excue du suivi on ne peut pas aller dans le moteur de saisie
If GREP = "C"
   Raz GBOUT6
   If  [M:MTK2]MODIFLG(NOL) = 1 : Raz GBOUT5 : Endif
   End
Endif


#Activation du bouton modif des mvts de stock seulement si pas en création
If [M:MTK0]MFGNUM = "" & [M:MTK2]PRODTYP(NOL) = 1
    Read [F:MFG]MFG0 = [M:MTK2]MFGNUMIT(NOL)
    If fstat : Raz [F:MFG] : Endif
Endif

If   [F:MTK]PTHNUM <> "" | [F:MKI]QUARTNFLG = 2 |
&    ([M:MTK2]PRODTYP(NOL) = 1 & [F:MFG]MFGSTA = 4)
        Raz GBOUT6
Endif
# si code activité lot à non, ne pas proposer la consultation des lots
If dim([M:MTK2]LOT) < 1 : Raz GBOUT10 : Endif

End

########################################
Subprog B7_NBITM
Call INFOLOT("MTK2", nolign-1) From STKENT
End

########################################
Subprog B8_NBITM
GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0)
GOUVENT = 1                         # permet de passer le test de l'ouverture de la fenetre complément lot
End


