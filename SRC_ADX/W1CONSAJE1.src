#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CONSAJE1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:19"
A_USER  = "DOC"
A_STAMP = "20181109230319"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CONSAJE1 [AJE1]
Gosub HORODAT
Local Inpbox "CONSAJE1" From GFONCTION At A_STAMP With A_WINDPREV Mask [AJE1] As [SIM_]
Grizo [AJE1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [AJE1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=3
Return

$ON_RESNAM
Onevent BEFORE_INPUT Call AS_RESNAM(zc) From W1CONSAJE1
Return

Subprog AS_RESNAM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_RESNAM(zc) From W1CONSAJE1
Gosub _AFF
End

Subprog S_RESNAM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AJSSELREST
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AJSSELREST"
 Call S_TAB_CHAR(VALEUR,PARMSK,"AJSSELREST","AJSSYNC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_ALS
Onevent BEFORE_INPUT Call AS_ALS(zc) From W1CONSAJE1
Return

Subprog AS_ALS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ALS(zc) From W1CONSAJE1
Gosub _AFF
End

Subprog S_ALS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AJSSELENDP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AJSSELENDP"
 Call S_LIS_CHAR(VALEUR,PARMSK,"AJSSELENDP","AJSSYNC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_CLESTR
Onevent BEFORE_INPUT Call AS_CLESTR(zc) From W1CONSAJE1
Return

Subprog AS_CLESTR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CLESTR(zc) From W1CONSAJE1
Gosub _AFF
End

Subprog S_CLESTR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AJSSELRES
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AJSSELRES"
 PARMSK(1) = [AJE1]RESNAM
 Call S_TAB_CHAR(VALEUR,PARMSK,"AJSSELRES","AJSSYNC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$CHG_STY
Return


