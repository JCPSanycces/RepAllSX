# Supervisor
## ACLA-CLASSE ## EDIXMLFILXSD
# 2018-11-06 07:05:20 054

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIXMLFILXSD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_MSGCOD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_MSGREL From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_MSGFILNOR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_NUMLIN From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_SORT From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_CODE From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_UUIDXSD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_NAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_FILNAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_FILDES From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIXMLFILXSD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIXMLFILXSD
Gosub _ALOADATTRIBUTE_MSGCOD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGREL From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFILNOR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NUMLIN From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_SORT From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_UUIDXSD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FILNAM From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIXMLFILXSD
Gosub LNKPRO_MSGCOD From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub LNKPRO_MSGFILNOR From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Gosub LNKPRO_CODE From WMC1EDIXMLFILXSD : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



