#<AdxTL>@(#)0.0.0.0 $Revision$
Local Mask AMK0 [AMK0]
Local File AMSK [AMK]
GBIDC1 = "AOB0"
Read [AMK]CODMSK = GBIDC1
[M] = [F]
GTEST=1
Call WORKFLOW(2,"AMK","M",GBIDC1) From AWRK
GTEST=0
End

$ACTION
Case [L]ACTION
 When "USER" : Gosub USER
Endcase
Return

################################################################################
$USER
Case [F:AWH]TYPDES(I-1)
When 3 : # Salarié
 If [L]CHAINE="" : Return : Endif
 If !clalev([F:AD2])  : Local File EMPLOAD   [AD2]  : Endif
 If !clalev([F:ADU2]) : Local File ADOVALAUS [ADU2] : Endif

 # on a l'email, on cherche le code utilisateur
 If pat([L]CHAINE,"*@*.*")
  [L]EMAIL=[L]CHAINE

  Filter [AD2] Where PFLEML=[L]EMAIL
  For [AD2]
   Filter [AUS2] Where ADDEML=[L]EMAIL
   Read [AUS2]CODUSR First
   Filter [AUS2]
   If !fstat : [L]DEST=[F:AUS2]USR : Break : Endif

   Filter [ADU2] Where PARAM="REFNUM" & VALEUR=[F:AD2]REFNUM
   Read [ADU2]ADU1 First
   Filter [ADU2]
   If !fstat : [L]DEST=[F:ADU2]CODUSR : Break : Endif
  Next
  Filter [AD2]

  If [L]DEST=""
   Filter [AUS2] Where ADDEML=[L]EMAIL
   Read [AUS2]CODUSR First
   Filter [AUS2]
   If !fstat : [L]DEST=[F:AUS2]USR : Endif
  Endif

 # on a le matricule, on cherche l'email et le code utilisateur
 Else

  Filter [ADU2] Where PARAM="REFNUM" & VALEUR=[L]CHAINE
  Read [ADU2]ADU1 First
  Filter [ADU2]
  If !fstat : [L]DEST=[F:ADU2]CODUSR : Endif

  Read [AD2]AD0 = [L]CHAINE
  [L]EMAIL = [F:AD2]PFLEML

  If [L]EMAIL="" & [L]DEST>""
   Read [AUS2]CODUSR=[L]DEST
   If !fstat : [L]EMAIL=[F:AUS2]ADDEML : Endif
  Endif
 Endif

When 4 : # Chef

 Local Char    CHEF(len([L]CHAINE)), STRUCTURE(3)
 Local Integer NIVEAU

 [L]NIVEAU   =val([L]CHAINE)                             : # menu local 50
 [L]STRUCTURE=mid$([L]CHAINE,1+instr(1,[L]CHAINE,"~"),3) : # "MAT" ou "CTR"
 [L]CHEF     =right$([L]CHAINE,1+instr(6,[L]CHAINE,"~")) : # Matricule du salarié
 Call CHEF([L]NIVEAU,[L]STRUCTURE,[L]CHEF,[L]DEST,[L]EMAIL)

When 5 : # Circuit hiérarchique ---------------------------------------------------------

#If !clalev([F:CEW]) : 64406 c'est ici qu'on semble avoir un soucis avec les
#répartitions par supérieur hierarchique
  If !clalev([F:CEW]) : Local File CHEFWRK [CEW] : Endif

#61614  Local File EMPLOAD [AD2]
  If !clalev([F:AD2])  : Local File EMPLOAD   [AD2]  : Endif

  Local Char    CHEF([V]GLONAUS)(dim([F:CEW]RESPO))
  Local Integer ICHEF, ONBRUSR
#----------------------------------------------------------------------------------------
# Récupération de la liste des interlocuteurs du salarié ([L]CHEF)
# MAT ou CTR suivant le niveau de départ de la recherche + clé + code wrkf
  [L]ONBRUSR=[L]NBRUSR
  If [L]TYPEVT=9 : # signature
   Call CIRCUIT(left$([L]CHAINE,3),right$([L]CHAINE,5),[F:AWA2]CODE,[L]CHEF) From SUBCEW
  Else
   Call CIRCUIT(left$([L]CHAINE,3),right$([L]CHAINE,5),[F:AWA]CODE,[L]CHEF) From SUBCEW
  Endif

#----------------------------------------------------------------------------------------
  # /62704
  Local Char LIST1(250) , LIST2(250)
  LIST1 = sigma(1,dim(USER),USER(indcum))
  LIST2 = sigma(0,dim(CHEF)-1,CHEF(indcum))
  If TYPEVT <> 9 & LIST1 <> LIST2
   # FQ76614 - MABON 29/09/11 - Ajout Raz [L]USER, sinon si deux lignes dans une demande, on raz le NBRUSR, mais on ne
   # va jamais dans la boucle For [L]ICHEF=0 To [F:CEW]NBDEST-1 suivante, car [L]USER est déjà renseigné avec les bonnes valeurs
   Raz NBRUSR, [L]USER
  Endif
  #  62704/

# décompte+récupération des interlocuteurs signataires d'après le param du circuit
  If ![L]NBRUSR
   For [L]ICHEF=0 To [F:CEW]NBDEST-1
    If [L]CHEF([L]ICHEF)>"" & [F:CEW]SUIVI([L]ICHEF)=3 & !find([L]CHEF([L]ICHEF),[L]USER)

     [L]NBRUSR         +=1

     [L]USER([L]NBRUSR) =[L]CHEF([L]ICHEF) :#à destination de USRSIGn
    Endif
   Next

   #64406 On ne doit pas initialiser si on est déjà en cours de VISa
   # FQ85052 - MABON 24/01/13 - Ajout test sur EVACRE
   If [L]OPERAT <> "VIS" & [F:CEW]CODWRK<>"EVACRE"
    [L]LEVSIG=0
   Endif

  Endif

#----------------------------------------------------------------------------------------
# On reporte la condition du destinataire sur la liste des signataires trouvée... si elle contient nbrusr?
  If ![L]ONBRUSR
   For J=I To min(dim([L]COND),[F:AWH]NBDEST)
    If [L]COND(J) & instr(1,[F:AWH]CNDDES(J-1),"NBRUSR")
     [L]COND(J)=evalue(format$("KTv2:255X",[F:AWH]CNDDES(J-1)))
    Endif
   Next
  Endif
#Endif 64406

#----------------------------------------------------------------------------------------
 If (find([F:AWH]CODE,"EVAVALM","EVAVALF")>0 & [L]LEVSIG <= [L]NBRUSR) | [L]LEVSIG < [L]NBRUSR
  # alimentation du destinataire=signataire suivant dans la liste
  # FQ85052 - MABON 24/01/13 - Ajout test sur EVAVALM car le 1er signataire (le collaborateur) ne fait pas partie du circuit de signature
  # Il ne faut donc pas décaler la recherche du USER dans le tableau
  If find([F:AWH]CODE,"EVAVALM","EVAVALF")>0 & [L]LEVSIG>0 Then
    [L]DEST =[L]USER([L]LEVSIG)
    [L]ICHEF=[L]LEVSIG-1
  Else
    [L]DEST =[L]USER([L]LEVSIG+1)
    [L]ICHEF=[L]LEVSIG
  Endif
  [L]EMAIL=func USERMAIL([L]DEST)
  Gosub INIPAR

# Else : # dernière signature, on envoie un mail d'information aux destinataires suivants
 Elsif [L]NBRUSR>0 : # dernière signature, on envoie un mail d'information aux destinataires suivants, SI on a au moins un destinataire
  Local Integer IC,IMAX
  If find([F:AWH]CODE,"EVAVALM","EVAVALF")>0 Then
   IMAX=[F:CEW]NBDEST
  Else
   IMAX=[F:CEW]NBDEST-1
  Endif
#  For [L]ICHEF=[L]LEVSIG To [F:CEW]NBDEST-1
  For IC=[L]LEVSIG To IMAX
   If find([F:AWH]CODE,"EVAVALM","EVAVALF")>0 & [L]IC>0 Then
    If [L]LEVSIG=2 Then
      [L]ICHEF=IC
    Else
      [L]ICHEF=IC-1
    Endif
   Else
    [L]ICHEF=IC
   Endif
   If [L]CHEF([L]ICHEF)>"" & ([F:CEW]SUIVI([L]ICHEF)=2 | [F:CEW]ENVOI([L]ICHEF)>1)
    [L]DEST =[L]CHEF([L]ICHEF)
    [L]EMAIL=func USERMAIL([L]DEST)

    [F:CEW]SUIVI ([L]ICHEF) = 2 : # 64300 on force à suivi pour lecture après la dernière signature

    Gosub INIPAR
    If sum([L]CHEF([L]ICHEF+1..[F:CEW]NBDEST-1))>""
     Gosub TRT_USER From AWRK
    Endif
   Endif
  Next
 Endif
Endcase
Return

#-------------------------------------------------------------------------------
Subprog CHEF(NIVEAU,STRUCTURE,CLE,DEST,EMAIL)
Value    Integer NIVEAU
Value    Char    STRUCTURE, CLE
Variable Char    DEST, EMAIL

If !clalev([F:AD2]) : Local File EMPLOAD [AD2] : Endif

Local Char REFNUM([V]GLONEML), SRV([V]GLONSRV), FCY([V]GLONFCY)

Raz [L]DEST, [L]EMAIL, [F:AD2]

Case [L]STRUCTURE
When "CTR"
 Local File EMPLOCTR [CTR1]
 Filter [CTR1] Where CTRNUM=[L]CLE & CTRDAT<=date$ Order By Key CLE=CTRDAT Desc : # 63639
 Read [CTR1] First
 Filter [CTR1]
 [F:AD2]REFNUM=[F:CTR1]CHEFCTR([L]NIVEAU)
 [L]REFNUM    =[F:CTR1]REFNUM
 [L]SRV       =[F:CTR1]ETRSRV
 [L]FCY       =[F:CTR1]ETRFCY

When "MAT"
 If !clalev([F:ID]) | [F:ID]REFNUM<>[L]CLE
  Local File EMPLOID [ID]
  Read [ID]ID0=[L]CLE
  If fstat : End : Endif
 Endif
 [L]REFNUM=[F:ID]REFNUM
 [L]SRV   =[F:ID]SRV
 [L]FCY   =[F:ID]FCY
Endcase

If [F:AD2]REFNUM=""
 If !clalev([F:AD]) | [F:AD]REFNUM<>[L]REFNUM
  Local File EMPLOAD [AD]
  Read [AD]AD0=[L]REFNUM
 Endif
 [F:AD2]REFNUM=[F:AD]CHEF([L]NIVEAU)
Endif

If [F:AD2]REFNUM=""
 If !clalev([F:SRV]) | [F:SRV]COD<>[L]SRV
  Local File SERVICE [SRV]
  Read [SRV]SRV0=[L]SRV
 Endif
 [F:AD2]REFNUM=[F:SRV]CHEF([L]NIVEAU)
Endif

If [F:AD2]REFNUM=""
 If !clalev([F:FCY]) | [F:FCY]FCY<>[L]FCY
  Local File FACILITY [FCY]
  Read [FCY]FCY0=[L]FCY
 Endif
 [F:AD2]REFNUM=[F:FCY]CHEF([L]NIVEAU)
Endif

If [F:AD2]REFNUM="" : End : Endif

Read [AD2]AD0 =
#[L]EMAIL=[F:AD]PFLEML : # 64406
[L]EMAIL=[F:AD2]PFLEML

If !clalev([F:ADU2]) : Local File ADOVALAUS [ADU2] : Endif

Filter [ADU2] Where PARAM="REFNUM" & VALEUR=[F:AD2]REFNUM
Read [ADU2]ADU1 First
Filter [ADU2]
If !fstat : [L]DEST=[F:ADU2]CODUSR : Endif

If [L]EMAIL="" & [L]DEST>""
 If !clalev([F:AUS2]) : Local File AUTILIS [AUS2] : Endif
 Read [AUS2]CODUSR=[L]DEST
 If !fstat : [L]EMAIL=[F:AUS2]ADDEML : Endif
Endif

End

#-------------------------------------------------------------------------------
Funprog USERMAIL(USER)
Value Char USER


If !clalev([F:AD2])  : Local File EMPLOAD   [AD2]  : Endif
If !clalev([F:ADU2]) : Local File ADOVALAUS [ADU2] : Endif

Read [ADU2]ADU0=[L]USER;"REFNUM"
If !fstat : Read [AD2]AD0=[F:ADU2]VALEUR : Endif
If !fstat and [AD2]PFLEML>"" : End [AD2]PFLEML : Endif


If !clalev([F:AUS2]) : Local File AUTILIS [AUS2] : Endif
Read [AUS2]CODUSR=[L]USER
If [F:AUS2]ADDEML>"" : End [F:AUS2]ADDEML : Endif

End ""



Funprog USERMAIL_AUS(USER)
Value Char USER

If !clalev([F:AUS2]) : Local File AUTILIS [AUS2] : Endif

Read [AUS2]CODUSR=[L]USER
If [F:AUS2]ADDEML>"" : End [F:AUS2]ADDEML : Endif

If !clalev([F:AD2])  : Local File EMPLOAD   [AD2]  : Endif
If !clalev([F:ADU2]) : Local File ADOVALAUS [ADU2] : Endif

Read [ADU2]ADU0=[L]USER;"REFNUM"
If !fstat : Read [AD2]AD0=[F:ADU2]VALEUR : Endif
If !fstat : End [AD2]PFLEML : Endif

End ""

#-------------------------------------------------------------------------------
$INIPAR
[F:AWH]ENVOI (I-1)=[F:CEW]ENVOI ([L]ICHEF)
[F:AWH]SUIVI (I-1)=[F:CEW]SUIVI ([L]ICHEF)
[F:AWH]NATURE(I-1)=[F:CEW]NATURE([L]ICHEF)
[F:AWH]OPTDEL(I-1)=[F:CEW]OPTDEL([L]ICHEF)
Return

