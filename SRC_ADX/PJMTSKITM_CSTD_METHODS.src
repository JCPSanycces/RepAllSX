#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSKITM   (Task - Items)
###################################################################################################
# METHODS
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  SLEVEL = func AFNC.MES3(mess(944,2260,1), this.OPPNUM, this.TASCOD, num$(this.ITTSEQ))
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$COPY
#Variable Instance TARGET Using C_PJMTSKITM : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # -------------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

###################################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ITMREF", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD_AXX("ITMDES1", AVOID.ACHAR, "PJMTSKITM", "ITMDES1", "KEYCONCAT", AVOID.ACHAR))
  If func ASYRFNC.ACTIV("ECC") = [V]CST_ATRUE Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ECCVALMAJ", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ECCVALMIN", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("BOMALT", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ITMPLANNUM", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ITMPLANVER", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("UOM", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ITTQTY", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("SALITM", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("CSMTYP", AVOID.ACHAR))
  If TECCLA.TASPRDAT = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("REQDAT", AVOID.ACHAR))
  Endif
  # Copy all descriptions (CLOB)
  If TECCLA.TASPRDES = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ITTDESTEX", AVOID.ACHAR))
  Endif
  # Copy all comments (CLOB)
  If TECCLA.TASPRCOM = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("ITTCOMTEX", AVOID.ACHAR))
  Endif
Return

###################################################################################################
$WIP
#Variable Instance TECORDERS Using C_TECORDERS : #
#Local Integer ARET_VALUE

Local Instance ORDERS Using C_ORDERS

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------------
  Local File ITMMASTER [ITM]
  # -------------------------
  Read [ITM]ITM0=this.ITMREF
  If [F:ITM]STOMGTCOD = 2 Then
    ORDERS = NewInstance C_ORDERS AllocGroup null
    [L]ARET_VALUE = fmet ORDERS.ORDERS_FROM_PJM(14, this.WIPNUM, this.ITMREF, this, TECORDERS)
    FreeGroup ORDERS
  Endif
Return

###################################################################################################
$SUM_SOQ_QTYSTU
#Value Char SKEYCONCAT
#Value Char SITMREF
#Local Decimal ARET_VALUE

  [L]ARET_VALUE = 0
  # -------------------------
  Local File SORDERQ [SOQ]
  # -------------------------
  Filter [SOQ] Where [F:SOQ]PJT = SKEYCONCAT and [F:SOQ]ITMREF = SITMREF
  For [SOQ]SOQPJM1
    [L]ARET_VALUE += [F:SOQ]QTYSTU
  Next
  Filter [SOQ]
Return

###################################################################################################
$SET_COSTMETS
#Value Char PARFCY
#Value Char PARTCLCOD
#Value Char PARITM
#Variable Integer PARPRIMET
#Variable Integer PARSECMET
#Variable Integer PARPURF
#Local Integer ARET_VALUE

Local Char VLTCOD (GLONTCM)

  [L]ARET_VALUE = [V]CST_AYES
  # ---------------------------
  Local File ITMMASTER  [ITM]
  Local File ITMFACILIT [ITF]
  Local File ITMCATEG   [ITG]
  Local File TABCOSTMET [TCM]
  # ---------------------------
  # if Product Category Not passed get it from ITMMASTER
  If PARTCLCOD = AVOID.ACHAR Then
    Read [ITM]ITM0=PARITM
    If fstat <> 0 Then
      [L]ARET_VALUE = [V]CST_ANO
      PARPURF = [V]CST_ANO   # Issue X3-102045 - 2018-07-25 by FGR : use constant not direct value 1
      Return
    Endif
    PARTCLCOD = [F:ITM]TCLCOD
  Endif
  Filter [ITF] Where [F:ITF]ITMREF = PARITM and [F:ITF]STOFCY = PARFCY
  Read [ITF]First
  If fstat <> 0 Then
    Filter [ITF]
    [L]ARET_VALUE = [V]CST_ANO
    Return
  Endif
  Filter [ITF]
  #
  PARPURF = [V]CST_ANO       # Issue X3-102045 - 2018-07-25 by FGR : use constant not direct value 1
  Filter [ITG] Where [F:ITG]TCLCOD = PARTCLCOD and [F:ITG]STOFCY = AVOID.ACHAR
  Read [ITG]First
  If fstat <> 0 Then
    Filter [ITG]
    [L]ARET_VALUE = [V]CST_ANO
    Return
  Endif
  Filter [ITG]
  PARPURF = [F:ITG]PURFLG
  #
  Filter [TCM] Where [F:TCM]VLTCOD = [F:ITF]VLTCOD
  Read [TCM]First
  If fstat <> 0 Then
    Filter [TCM]
    [L]ARET_VALUE = [V]CST_ANO
    Return
  Endif
  Filter [TCM]
  If [F:TCM]PJMBUDMAN = [V]CST_ANO Then
    [L]ARET_VALUE = [V]CST_ANO
    Return
  Endif
  PARPRIMET = [F:TCM]PJMBUDVLTCOD
  PARSECMET = [F:TCM]PJMBUDVLT2
Return

###################################################################################################
$FRCDLTALLFLG_UPDATABLE
#Local Integer ARET_VALUE

  # Issue X3-105748 - 2018-08-30 by FGR
  [L]ARET_VALUE = [V]CST_AYES
  # -------------------------
  If this.ASTALIN = [V]CST_AUPD Then
    If this.FRCDLTALLFLG = [V]CST_AYES Then
      If this.STOFCY <> this.snapshot.STOFCY Then
        [L]ARET_VALUE = [V]CST_ANO
      Elsif this.ITMREF <> this.snapshot.ITMREF Then
        [L]ARET_VALUE = [V]CST_ANO
      Elsif dim(this.ECCVALMAJ) >= 0 and this.ECCVALMAJ <> this.snapshot.ECCVALMAJ Then
        [L]ARET_VALUE = [V]CST_ANO
      Elsif dim(this.ECCVALMIN) >= 0 and this.ECCVALMIN <> this.snapshot.ECCVALMIN Then
        [L]ARET_VALUE = [V]CST_ANO
      Elsif this.ITTQTY <> this.snapshot.ITTQTY Then
        [L]ARET_VALUE = [V]CST_ANO
      Elsif this.REQDAT <> this.snapshot.REQDAT Then
        [L]ARET_VALUE = [V]CST_ANO
      Endif
    Endif
  Endif
Return

