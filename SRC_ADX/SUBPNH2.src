########################################################################
# SUBPNH2 : Saisie des complÃĐments retours fournisseurs                #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisÃĐ par l'action       #
# SAIPNHCOM "saisie des complÃĐments" et ne sert qu'Ã  gÃĐrer le          #
# masque ÃĐcran "PNH2 [PNH2]".                                          #
########################################################################


Subprog C_BPSINV(VALEUR)
#--------------------------------#
# ContrÃīle fournisseur facturant #
#--------------------------------#
Variable Char    VALEUR()
#----- VÃĐrification que la structure soit identique -----#
If [F:BPS]PLISTC<>GPLISTC
  GMESSAGE=mess(141,199,1)-"("+[F:BPS]PLISTC-"<>"-GPLISTC+")"
  mkstat=1 : End
Endif
End


Subprog AM_BPSINV(VALEUR)
#---------------------------------------------#
# AprÃĻs modification du fournisseur facturant #
#---------------------------------------------#
Variable Char    VALEUR()
If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2] : Endif
Read [BPS2] BPS0=[M:PNH1]BPSNUM : If fstat  Raz [F:BPS2] : Endif
If [F:BPS2]BPSINV=VALEUR
  [M:PNH2]BPAINV=[F:BPS2]BPAINV
Elsif [F:BPS]BPSINV=VALEUR
  [M:PNH2]BPAINV=[F:BPS]BPAINV
Else
  [M:PNH2]BPAINV=[F:BPS]BPAADD
Endif
If !GIMPORT  Affzo [PNH2]BPAINV : Endif
End


Subprog C_BPAINV(VALEUR)
#---------------------------------------------#
# ContrÃīle code adresse fournisseur facturant #
#---------------------------------------------#
Variable Char    VALEUR()
Look [BPA] BPA0=1;[M:PNH2]BPSINV;VALEUR
If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : End : Endif
End


Subprog AM_BPRPAY(VALEUR)
#---------------------------#
# AprÃĻs modif du tiers payÃĐ #
#---------------------------#
Variable Char    VALEUR()
If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2] : Endif
Read [BPS2] BPS0=[M:PNH1]BPSNUM : If fstat  Raz [F:BPS2] : Endif
If [F:BPS2]BPRPAY=VALEUR
  [M:PNH2]BPAPAY=[F:BPS2]BPAPAY
Else
  If [F:BPS2]BPSNUM<>VALEUR
    Read [BPS2] BPS0=VALEUR : If fstat  Raz [F:BPS2] : Endif
  Endif
  If [F:BPS2]BPRPAY=VALEUR
    [M:PNH2]BPAPAY=[F:BPS2]BPAPAY
  Elsif [F:BPS2]BPAADD<>""
    [M:PNH2]BPAPAY=[F:BPS2]BPAADD
  Else
    If [F:BPR]BPRNUM<>VALEUR
      Read [BPR] BPR0=VALEUR : If fstat  Raz [F:BPR] : Endif
    Endif
    [M:PNH2]BPAPAY=[F:BPR]BPAADD
    #----- Rechargement du  business partner commande si nÃĐcessaire -----#
    If [F:BPR]BPRNUM<>[M:PNH1]BPSNUM
      Read [BPR] BPR0=[M:PNH1]BPSNUM : If fstat  Raz [F:BPR] : Endif
    Endif
  Endif
Endif
If !GIMPORT  Affzo [PNH2]BPAPAY : Endif
End


Subprog C_BPAPAY(VALEUR)
#----------------------------------#
# ContrÃīle code adresse tiers payÃĐ #
#----------------------------------#
Variable Char    VALEUR()
Look [BPA] BPA0=1;[M:PNH2]BPRPAY;VALEUR
If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : End : Endif
End


Subprog C_WEU(VALEUR)
#----------------------------------------------------------#
# ContrÃīle unitÃĐ de poids : Obligatoire si poids renseignÃĐ #
#----------------------------------------------------------#
Variable Char    VALEUR()
If [M:PNH2]TOTGROWEI<>0 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif

Local Integer    OK
#101090 - Verify changes if BOL attached
If VALEUR<>[M:PNH2]WEU
  Call VERIF_BOLMOD(OK) From SUBPNHA
  If OK<>2 : mkstat=1 : Endif
Endif

End


Subprog C_VOU(VALEUR)
#------------------------------------------------------------#
# ContrÃīle unitÃĐ de volume : Obligatoire si volume renseignÃĐ #
#------------------------------------------------------------#
Variable Char    VALEUR()
If [M:PNH2]TOTVOL<>0 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif

Local Integer    OK
#101090 - Verify changes if BOL attached
If VALEUR<>[M:PNH2]VOU
  Call VERIF_BOLMOD(OK) From SUBPNHA
  If OK<>2 : mkstat=1 : Endif
Endif

End
