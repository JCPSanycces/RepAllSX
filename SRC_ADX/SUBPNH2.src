Subprog C_MANDOCR(VALEUR)
Variable Char    VALEUR()
Call  C_MANDOC(VALEUR) From TRNDOC
End
######################################################################################
Subprog C_DPEDATR(VALEUR)
Variable Date    VALEUR

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0
  Local File TABPNHTYP [TPN]
  Local Integer RET : [L]RET = 0
  Call LEC_TPN_LEG([F:FCY]LEG,[M:PNH1]PNHTYP,RET) From TRTLECLEG
  If func PORLEGLIB.DIGSIGN([M:PNH1]PNHFCY,'')=1
    End
  Endif
Endif

  # FGR 18/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If VALEUR > [M:PNH1]RTNDAT Then
      GMESSAGE = mess(475,194,1) - format$(GFMDAT, VALEUR) - ">" - format$(GFMDAT, [M:PNH1]RTNDAT)
      mkstat = 2
      End
    Endif
  Endif
End

######################################################################################
Subprog AM_DPEDATR(VALEUR)
Variable Date    VALEUR

  # FGR 18/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:PNH2]ARVDATR = [0/0/0] or ([M:PNH2]ARVDATR <> [0/0/0] and (VALEUR > [M:PNH2]ARVDATR or [M:PNH2]DPEDATR = [M:PNH2]ARVDATR)) Then
      [M:PNH2]ARVDATR = VALEUR
      Affzo [M:PNH2]ARVDATR
    Endif
  Endif
End

######################################################################################
Subprog C_ARVDATR(VALEUR)
Variable Date    VALEUR

If func AFNC.ACTIV('KPO')>0
  Local File TABPNHTYP [TPN]
  Local Integer RET : [L]RET = 0
  Call LEC_TPN_LEG([F:FCY]LEG,[F:PNH]PNHTYP,RET) From TRTLECLEG
  # BRBAN 01/09/2014 #93745
  If func PORLEGLIB.DIGSIGN([M:PNH1]PNHFCY,'')=1
    End
  Endif
Endif

  # FGR 18/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:PNH2]DPEDATR <> [0/0/0] and VALEUR < [M:PNH2]DPEDATR Then
      GMESSAGE = mess(401,192,1) - format$(GFMDAT, [M:PNH2]DPEDATR) - ">" - format$(GFMDAT, VALEUR)
      mkstat = 2
      End
    Endif
  Endif
End
######################################################################################
Subprog C_ETAR(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000" : End : Endif
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:PNH1]PNHFCY,'')=1
  If [M:PNH2]DPEDATR<>[0/0/0] & [M:PNH2]ARVDATR<>[0/0/0]
    If [M:PNH2]DPEDATR=[M:PNH2]ARVDATR & VALEUR<=[M:PNH2]ETDR
       Call ERREUR(mess(69,134,1)) From GESECRAN
       mkstat=2
    Endif
  Endif
Endif
End
