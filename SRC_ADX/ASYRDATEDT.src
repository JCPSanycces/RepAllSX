#<AdxTL>@(#)10.0.0.0 $Revision$
#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------#
# JSON détail/edit generation
#----------------------------------------------------------------#

#**
#* This Sub program is working on Fusion Session Client AND Syracuse Session Client.
#* It permit to export in a Clob the data detail of a representation.
#* @see
#*<code>
#*  ASTATUS = func ASYREIP.EXPORT_DATA_DETAIL(this,[V]CST_ANO,JSONDET)
#* </CODE>
#* @param REP  : Instance  :Instance of a description of the representation
#* @param WREP : Instance : Instance of the representation
#* @param PSYR : Instance : Instance of Syracuse
#* @param CLOB : Clbfile : Clob who contains the data detail
#*
#*!
Subprog DETAIL_JSON(REP,WREP,PSYR,WCLOB)
Variable Instance  REP       Using C_AREPENT
Variable Instance  WREP      Using OBJECT
Variable Instance  PSYR      Using C_ASYR
Variable Clbfile   WCLOB

Call DETAIL_JSON_FULL(REP,WREP,PSYR,[V]CST_AFALSE,WCLOB)

End

# Issue X3-74605 - 2018-06-14 by CCC : export the content of the clob => add WITHCLOB parameter
#**
#* This Sub program is working on Fusion Session Client AND Syracuse Session Client.
#* It permit to export in a Clob the data detail of a representation.
#* @see
#*<code>
#*  ASTATUS = func ASYREIP.EXPORT_DATA_DETAIL(this,[V]CST_ANO,JSONDET)
#* </CODE>
#* @param REP  : Instance  :Instance of a description of the representation
#* @param WREP : Instance : Instance of the representation
#* @param PSYR : Instance : Instance of Syracuse
#* @param WITHCLOB : Integer : Flag to say if the content of Clob must be inserted into the result
#* @param CLOB : Clbfile : Clob who contains the data detail
#*
#*!
Subprog DETAIL_JSON_FULL(REP,WREP,PSYR,WITHCLOB,WCLOB)
Variable Instance  REP       Using C_AREPENT
Variable Instance  WREP      Using OBJECT
Variable Instance  PSYR      Using C_ASYR
Value Integer      WITHCLOB
Variable Clbfile   WCLOB

Local Instance  JSO(1..) Using C_ASYRJSO

Local Char    WINF(250) , WREF(250)
Local Integer I , J , R , M , NBR , PLK , ONE
Local Integer MAXGRI
MAXGRI = maxtab(REP.COL)+1
Local Integer TBGRI(1..MAXGRI)

Gosub INIVAR From ASYRJSO

# Search active group

For R=1 To maxtab(REP.PRO)
 If (REP.PRO(R).DET=2 & REP.FCT="$details") or (REP.PRO(R).EDT=2 & REP.FCT="$edit") or (REP.PRO(R).SRY=2 & REP.FCT="$summary")
  I = find(REP.PRO(R).GRI,REP.COL(1..maxtab(REP.COL)).GRI)
  If I & TBGRI(I)=0
   TBGRI(I) = 1
  Endif
 Endif
Next R
# Active group without active properties but with instances with active properties
M = 1
While M=1
 M = 0
 For R=1 To maxtab(REP.COL)
  If REP.COL(R)<>null & TBGRI(R)=0
   For I=1 To maxtab(REP.COL)
    If REP.COL(I)<>null & REP.COL(I).GRI<>REP.COL(R).GRI & left$(REP.COL(I).GRI,len(REP.COL(R).GRI))=REP.COL(R).GRI & TBGRI(I)=1
     TBGRI(R) = 1 : M = 1
    Endif
   Next I
  Endif
 Next R
Wend

WREF = "WREP"
WINF = "WREP."+REP.ICL

Call COLLECTION_INS(REP,WREP,PSYR,JSO,TBNIV,NIV,TBGRI,PROENT,ONE,NBR,PLK,WREF,WINF,"",[L]WITHCLOB)

Call GENERATE_JSON(TBNIV(1),WCLOB) From ASYRJSO
End

#---------------------------------------------------------------------------------------------#
Subprog COLLECTION_INS(REP,WREP,PSYR,JSO,TBNIV,NIV,TBGRI,PROENT,ONE,NBR,PLK,WREF,WINF,WCOL,WITHCLOB)
Variable Instance  REP      Using C_AREPENT
Variable Instance  WREP     Using OBJECT
Variable Instance  PSYR     Using C_ASYR
Variable Instance  JSO(1..) Using C_ASYRJSO
Variable Instance   TBNIV(1..) Using C_ASYRJSO
Variable Integer    NIV , TBGRI(1..)
Value    Char      PROENT()(1..)
Value    Integer   ONE , NBR , PLK
Value    Char      WREF , WINF , WCOL
Value    Integer   WITHCLOB    # Issue X3-74605 - 2018-06-14 by CCC : export the content of the clob => add WITHCLOB parameter


Local Clbfile  NODESVAL : #109762

Local Integer I , J ,F,  K , P , A , M , N , D , OK
Local Char    INS(250) , INM(250) , PRO(250)
Local Char    NAM(30) , DES(30) , COLSYR(50)
Local Uuident UID
Local Integer IND , TYP , NBG , ENT
Local Clbfile CLOB
Local Char    VRA(250) , VRB(250) , VRC(250) , VRK(80)
Local Char    WCHAINE(250) , WGRI(250) , WINS(250)
Local Clbfile   WVALUE
Local Integer VRO , VRI
Local Uuident VRU , VRF
Local Integer NBC , GRN , DIME , PRE , ENT
Local Integer ENTCOL , OKCOL , NBRPRO , PLKPRO , ONEINS
Local Integer BRA , NBJ , RIGHTACCESS
Local Integer MAXKEY
MAXKEY = 20
Local Char    TBLOO(30)(1..MAXKEY) , TBLNK(30)(1..MAXKEY)

Local Integer ACTXCOUNT,ACTXI
Local Char ACTXJSONAME(20)(1..)
Local Char ACTXX3NAME(50)(1..)

Local Instance PJSOPROPERTIES Using C_ASYRJSO :# PJSOPROPERTIES = null
Local Integer F_ADDJSO : F_ADDJSO=0
Local Integer F_FIRST
Local Integer OKPRO
OKPRO = (dim(PSYR.NOATT)<=0 or PSYR.NOATT<>CST_AYES)

Local Char AATTINTERNAL(20)(1..)
Call AGETLISTATTINTERNAL(AATTINTERNAL) From ASYRSUB
Local Char AATTOKREF(20)(1..)
Call AGETLISTATTOKREF(AATTOKREF) From ASYRSUB

Local Instance PINSTANCE Using OBJECT

Gosub SYSTEM_INSTANCES From ASYRUID
Gosub DEFVAR From ASYRJSO

M = evalue('maxtab('+WREF+')')
ENT = 0
F_FIRST=1
If M>1
 For N=1 To M
  WINS = WREF+'('+num$(N)+')'
  PINSTANCE = evalue(WINS)
  If F_FIRST
   F_FIRST = 0
   Gosub INIT_APROPERTIES
  Endif
  PJSOPROPERTIES = null
  Gosub COLLECTION_UPD
 Next N
Else
 WINS = WREF
 PINSTANCE = evalue(WINS)
 PJSOPROPERTIES = null
 Gosub INIT_APROPERTIES
 Gosub COLLECTION_UPD
Endif

If WINS<>"WREP" & !ONE & ENT
 Gosub ENDNIV From ASYRJSO
Endif

# Attributes of properties of instance

If REP.FCT<>"$summary" & NBR=1 & PLK<>2 & OKPRO
 NAT = 0
 For P=1 To APROCOUNT
  PRO = APRONAM(P)
  If APROTYP(P)<>524
   If APROFCT(P)
    #If (REP.PRO(APROREP(P)).DET=2 & REP.FCT="$details") or (REP.PRO(APROREP(P)).EDT=2 & REP.FCT="$edit")
     NBA = 0
     VRI = APROREP(P) : # Indice in dictionary
     VRA = REP.PRO(APROREP(P)).PRO
     VRC = VRA

     Gosub ATTRIBUTE_EX
     If NBA
      Gosub ENDNIV From ASYRJSO
     Endif
    Endif
    #Endif
   Endif
 Next P
 If NAT=1
  Gosub ENDNIV From ASYRJSO
 Endif
Endif

If WINS="WREP" and REP.FCT="$details" : # managment so link in detail facet, isDisabled only
 J = evalue("maxtab("+WINS+"._ASTADETLNK)")
 If J>0
  K = 0
  For I=1 To J
   If evalue(WINS+"._ASTADETLNK("+num$(I)+")")<>null
    If evalue(WINS+"._ASTADETLNK("+num$(I)+").ISDISABLED")=[V]CST_AYES
     If !K
      NODEPRO = '"$links"'
      Gosub ADDOBJECT From ASYRJSO
     Endif
     NODEPRO =   '"'+evalue(WINS+"._ASTADETLNK("+num$(I)+").CODLNK")+'"'
     Gosub ADDOBJECT From ASYRJSO
     NODEPRO =   '"$isDisabled"'
     NODESVAL =   '"true"'
     Gosub ADDSTRING From ASYRJSO
     Gosub ENDNIV From ASYRJSO
     K=1
    Endif
   Endif
  Next
  If K
   Gosub ENDNIV From ASYRJSO
  Endif
 Endif
Endif
End

#------------------------------#
$COLLECTION_UPD

If PINSTANCE=null
 Return
Endif

If WINS="WREP" : # Head of json
 NIV = 1
 NODEPRO = ''
 Gosub ADDOBJECT From ASYRJSO

 Gosub HEADER

 Call LOAD_ACTX_PROPERTIES([L]ACTXCOUNT,[L]ACTXJSONAME,[L]ACTXX3NAME) From ASHWJSO
 For ACTXI=1 To ACTXCOUNT
  NODEPRO =   '"'+ [L]ACTXJSONAME(ACTXI) +  '"'
  If instr(1,[L]ACTXX3NAME(ACTXI),"num$(")
   NODESVAL = '"'+ evalue("num$(WREP." + seg$([L]ACTXX3NAME(ACTXI),6,len([L]ACTXX3NAME(ACTXI))-1) +')' ) +'"'
  Else
   NODESVAL = '"'+ evalue("WREP." + [L]ACTXX3NAME(ACTXI) ) +'"'
  Endif
  Gosub ADDSTRING From ASYRJSO

 Next ACTXI
Elsif !ONE : # Not link 1,1
 If NBR=1 : # Collection with one property
  If !ENT : # First instance
   Gosub HEADER_ARRAY
##  Elsif F_ADDJSO
##   NODEPRO=''
##   Gosub ADDOBJECT From ASYRJSO
  Endif
 Elsif !ENT
  Gosub HEADER_COL
 Else
  Gosub HEADER_LIN
 Endif
Else
 NBJ = NBJ
Endif


ENT = 1
WGRI = func VIRE_NUMBER(WINS)

# Properties of instances

For P=1 To APROCOUNT
 PRO = APRONAM(P)
 If APROTYP(P)=524
  Call COLSYR(REP,WINS+"."+PRO,COLSYR,ONEINS) From ASYRDELSRV
  Gosub OKCOL
  If OKCOL
   Call COLLECTION_INS(REP,WREP,PSYR,JSO,TBNIV,NIV,TBGRI,PROENT,ONEINS,NBRPRO,PLKPRO,WINS+'.'+PRO,WINF,COLSYR,[L]WITHCLOB)
  Endif
 Else
  If APROFCT(P)
   #If (REP.PRO(APROREP(P)).DET=2 & REP.FCT="$details") or (REP.PRO(APROREP(P)).EDT=2 & REP.FCT="$edit") or (REP.PRO(APROREP(P)).SRY=2 & REP.FCT="$summary")
    VRI = APROREP(P) : # Indice in dictionary
    [L]RIGHTACCESS = 1
    If REP.PRO(VRI).ACS<>"" and  fmet PINSTANCE.AGETATTRIBUTE(PRO,[V]CST_ARIGHTACCESS) = "false"
     [L]RIGHTACCESS = 0
    Endif
    If RIGHTACCESS>0
     If NBR=1
      Gosub ARRAY
      F_ADDJSO=1
     Else
       Case REP.PRO(VRI).PLK
        When 2       : Gosub REF
        When Default : Gosub PRO
       Endcase
      Endif
    Endif
   #Endif
  Endif
 Endif
Next P

# Attributes of properties of instance

If REP.FCT<>"$summary" & NBR<>1 & OKPRO
 NAT = 0
 For P=1 To APROCOUNT
  PRO = APRONAM(P)
  If APROTYP(P)<>524
   If APROFCT(P)
    #If (REP.PRO(APROREP(P)).DET=2 & REP.FCT="$details") or (REP.PRO(APROREP(P)).EDT=2 & REP.FCT="$edit")
     NBA = 0
     VRI = APROREP(P) : # Indice in dictionary
     VRA = REP.PRO(APROREP(P)).PRO
     VRC = VRA
     Gosub ATTRIBUTE_EX
     If NBA
      Gosub ENDNIV From ASYRJSO
     Endif
    Endif
   #Endif
   Endif
 Next P
 If NAT=1
  Gosub ENDNIV From ASYRJSO
 Endif
Endif

If WINS<>"WREP" & !ONE & NBR<>1
 Gosub ENDNIV From ASYRJSO
Endif

Return

#--------------------------#
$OKCOL
Raz OKCOL , NBRPRO , PLKPRO
J = evalue("maxtab("+WINS+'.'+PRO+")")
If J=1
 If evalue(WINS+"."+PRO)<>null
  OKCOL = 1
 Endif
Else
 For I=1 To J
  If evalue(WINS+"."+PRO+"("+num$(I)+")")<>null
   OKCOL = 1 : Break
  Endif
 Next I
Endif
If OKCOL
 For I=1 To maxtab(REP.COL)
  If REP.COL(I)<>null & ctrans(REP.COL(I).GRI,".","")=COLSYR
   If TBGRI(I)=0
    OKCOL = 0 : Break
   Else
    NBRPRO = REP.COL(I).NBR
    If NBRPRO=1
     K = find(REP.COL(I).GRI,REP.PRO(1..maxtab(REP.PRO)).GRI)
     If K & REP.PRO(K).PLK=2
      PLKPRO = 2
     Endif
    Endif
   Endif
  Endif
 Next I
Endif
Return

#---------------------------------------------#
Funprog VIRE_NUMBER(INS)
Value Char INS
Local Char GRI(80)
Local Integer I , J
GRI = INS
I = instr(1,GRI,"(")
While I
 J = instr(I,GRI,")")
 GRI = left$(GRI,I-1)+right$(GRI,J+1)
 I = instr(1,GRI,"(")
Wend
End GRI

#-----------------------------------#
$HEADER_COL
NODEPRO = '"'+WCOL+'"'
Gosub ADDARRAY From ASYRJSO

NODEPRO = ''
Gosub ADDOBJECT From ASYRJSO

TYP = 7
VRA = PROENT(1)
VRC = "$uuid"
VRB = WINS+"."+VRA
Gosub CODPRO_VALUE
NODEPRO = '"'+VRC+'"'
NODESVAL = WVALUE
Gosub ADDSTRING From ASYRJSO
Return

#-----------------------------------#
$HEADER_LIN
Local Char NODEPRO(250)
NODEPRO = ''
Gosub ADDOBJECT From ASYRJSO

TYP = 7
VRA = PROENT(1)
VRC = "$uuid"
VRB = WINS+"."+VRA
Gosub CODPRO_VALUE

Local Char     NODEPRO(50) :#Undeclared variable ?

NODEPRO = '"'+VRC+'"'
NODESVAL = WVALUE
Gosub ADDSTRING From ASYRJSO
Return

#-----------------------------------#
$HEADER_ARRAY
NODEPRO = '"'+WCOL+'"'
Gosub ADDARRAY From ASYRJSO

##NODEPRO = ''
##Gosub ADDOBJECT From ASYRJSO

Return

#--------------------#
$HEADER
TYP=7
VRA = PROENT(1)
VRC = "$uuid"
Gosub HEADER_PRO
TYP = 11
VRA = PROENT(2)
VRC = "$etag"
Gosub HEADER_PRO
TYP = 2
VRA = PROENT(4)
VRC = "$index"
Gosub HEADER_PRO
Return

#----------------------------------------------------------------------#
$HEADER_PRO
# Propertie
VRB = WINF+"."+VRA
Gosub CODPRO_VALUE
# If update date is null, try with create date
If VRA=PROENT(2) & WVALUE=func ASYRSUB.SYR_NULL
 VRA = PROENT(3)
 Goto HEADER_PRO
Endif
If VRA=PROENT(4) & WVALUE="0"
 Return
Endif
If evalue("dim("+VRB+")")>0
 NODEPRO = '"'+VRC+'"'
 NODESVAL = WVALUE
 Gosub ADDSTRING From ASYRJSO
Endif
Return

#--------------------------------------#
$PRO
TYP = REP.PRO(VRI).TYP
VRB = WINS+"."+PRO
VRA = REP.PRO(VRI).PRO
VRC = VRA  : # Name of property in json
Gosub VALUES
Return

#----------------------------------#
$REF
TYP = REP.PRO(VRI).TYP
VRB = WINS+"."+PRO
VRA = REP.PRO(VRI).PRO
VRC = VRA
NODEPRO = '"'+VRC+'"'
Gosub CODPRO_VALUE
NODESVAL = WVALUE
Gosub ADDSTRING From ASYRJSO
NBA = 0
Gosub DESCRIPTION
If NBA
 Gosub ENDNIV From ASYRJSO
Endif
Return

#-----------------------------------------------#
$DESCRIPTION
Local Char ATT(250)
Local Integer AAM,AAI,ATTTYP
Local Char LISTATTREF(20)(1..)
Local  Instance PATTRIBUTES Using C_ATTRIBUTES
Local Integer FTITLE : FTITLE=0
If func ASYRSUB.AGETPROATTRIBUTES(PINSTANCE,PRO,PATTRIBUTES)
 AAM = func ASYRSUB.AGETLISTATTOKREF(LISTATTREF)
 For AAI=1 To AAM
  WCODE = LISTATTREF(AAI)
  If func ASYRSUB.AGETPROATTRIBUTE(PATTRIBUTES,WCODE,ATT,ATTTYP)
   If NBA=0
    NBA = 1
    NODEPRO = '"'+VRC+func ASYRJSO.REF+'"'
    Gosub ADDOBJECT From ASYRJSO
   Endif
   If WCODE = "$title" : FTITLE=1 :Endif
   Gosub ADDJSO From ASYRJSO
   Call SETATTRIBUTE(PJSON,WCODE,ATTTYP,ATT) From ASYRJSO
  Endif
 Next AAI
Endif
##********
# $title is Mandatory for property reference
If !FTITLE
 If NBA=0
  NBA = 1
  NODEPRO = '"'+VRC+func ASYRJSO.REF+'"'
  Gosub ADDOBJECT From ASYRJSO
 Endif

 NODEPRO = '"$title"'
 NODESVAL = '""'
 Gosub ADDSTRING From ASYRJSO
Endif
Return

#----------------------------------#
$VALUES
If VRC<>""
 NODEPRO = '"'+VRC+'"'
Else
 NODEPRO = ''
Endif
Gosub CODPRO_VALUE
NODESVAL = WVALUE
Gosub ADDSTRING From ASYRJSO
Return

#----------------------------------#
$ARRAY
VRU = evalue(WINS+".AUUID")
If VRU<>NullUuid
 If REP.PRO(VRI).PLK<>2
  TYP = REP.PRO(VRI).TYP
  VRB = WINS+"."+PRO
  VRA = REP.PRO(VRI).PRO
  VRC = ""
  Gosub CODPRO_VALUE
  NODEPRO = ''
  NODESVAL = WVALUE
  Gosub ADDSTRING From ASYRJSO

 Else
  NODEPRO = ''
  Gosub ADDOBJECT From ASYRJSO
  LOU = find("$lookup",REP.PRO(VRI).LNK(1..maxtab(REP.PRO(VRI).LNK)).COD)
  If LOU
   Gosub LOOKUP_KEYS
   If CURPRO<>""
    NODEPRO = '"'+CURPRO+'"'
   Else
    NODEPRO = '"'+VRC+'"'
   Endif
  Else
   NODEPRO = '"'+VRC+'"'
  Endif
  TYP = REP.PRO(VRI).TYP
  VRB = WINS+"."+PRO
  VRA = REP.PRO(VRI).PRO
  VRC = ""
  Gosub CODPRO_VALUE
  NODESVAL = WVALUE
  NBA = 1
  Gosub ADDSTRING From ASYRJSO
  Gosub DESCRIPTION
  Gosub ATTRIBUTE_REF
  Gosub ENDNIV From ASYRJSO
 Endif
Endif
Return

#----------------------------------#
$ATTRIBUTE_REF
Local Char ATT(250)
Local Integer AAI,AAI,ATTTYP
Local Char LISTATTJSON(20)(1..)
Local  Instance PATTRIBUTES Using C_ATTRIBUTES

If func ASYRSUB.AGETPROATTRIBUTES(PINSTANCE,PRO,PATTRIBUTES)
 AAM = func ASYRSUB.AGETLISTATTOKJSON(LISTATTJSON)
 For AAI=1 To AAM
  OK = 1
  WCODE = LISTATTJSON(AAI)
  If func ASYRSUB.AGETPROATTRIBUTE(PATTRIBUTES,WCODE,ATT,ATTTYP)
   OK *= (REP.FCT<>"$details" or !find(WCODE,"$isMandatory")) : # Mandatory
   If OK
    Gosub ADDJSO From ASYRJSO
    Call SETATTRIBUTE(PJSON,WCODE,ATTTYP,ATT) From ASYRJSO
   Endif
  Endif
 Next AAI
Endif
Return

#------------------------------------------------------#
$ASSIGN_KEYS_LOOKUP
For C=1 To NBK
 CHAINE = seg$(TBLOO(C),2,len(TBLOO(C))-1)
 If CHAINE<>CURPRO
  If find(left$(TBLNK(C),1),'"',"'")
   NODEPRO = '"'+CHAINE+'"'
   NODESVAL = '"'+seg$(TBLNK(C),2,len(TBLNK(C))-1)+'"'
   Gosub ADDSTRING From ASYRJSO
  Else
   WCHAINE = seg$(TBLNK(C),2,len(TBLNK(C))-1)
   K = find(WCHAINE,REP.PRO(1..maxtab(REP.PRO)).PRO)
   If K
    NODEPRO = '"'+CHAINE+'"'
    TYP = REP.PRO(K).TYP
    VRB = func PATH_PROPERTY(INSPAR,REP.PRO(K).PTH)
    Gosub CODPRO_VALUE
    NODESVAL = WVALUE
    Gosub ADDSTRING From ASYRJSO
   Endif
  Endif
 Endif
Next C
Return

#------------------------#
$LOOKUP_KEYS
NBK = 0
CURPRO = ""
For C=1 To maxtab(REP.PRO(VRI).LNK(LOU).CLE)
 If REP.PRO(VRI).LNK(LOU).CLE(C)<>null
  NBK += 1
  If REP.PRO(VRI).LNK(LOU).CLE(C).LOO<>""
   TBLOO(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).LOO+'}'
  Elsif find(left$(REP.PRO(VRI).LNK(LOU).CLE(C).VPR,1),"'",'"')
   TBLOO(NBK) = func ASYRJSO.PARAM(REP.PRO(VRI).LNK(LOU).CLE(C).VPR)
  Else
   TBLOO(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).PAR+'}'
  Endif
  If REP.PRO(VRI).LNK(LOU).CLE(C).PRO<>""
   TBLNK(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).PRO+'}'
  Elsif find(left$(REP.PRO(VRI).LNK(LOU).CLE(C).VPR,1),"'",'"')
   TBLNK(NBK) = func ASYRJSO.PARAM(REP.PRO(VRI).LNK(LOU).CLE(C).VPR)
  Else
   TBLNK(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).VPR+'}'
  Endif
  If CURPRO=""
   If REP.PRO(VRI).LNK(LOU).CLE(C).PRO<>""
    If REP.PRO(VRI).LNK(LOU).CLE(C).PRO=REP.PRO(VRI).PRO
     CURPRO = seg$(TBLOO(NBK),2,len(TBLOO(NBK))-1)
    Endif
   Elsif REP.PRO(VRI).LNK(LOU).CLE(C).VPR=REP.PRO(VRI).PRO
    CURPRO = seg$(TBLOO(NBK),2,len(TBLOO(NBK))-1)
   Endif
  Endif
 Endif
Next C
If CURPRO=""
 CURPRO = TBLOO(1)
Endif
Return

#-----------------------------------#
# Find default value
#-----------------------------------#

$DEF_VALUE
DEF = 0
Onerrgo RIEN
Case TYP
 When 1 : # Boolean
  DEF = (evalue(VRB)<>2)
 When 2,3,4 : # Integer/Decimal/Real
  DEF = (evalue(VRB)=0)
 When 5 : # Date
  DEF = (format$("D:YYYY[-]MM[-]DD",evalue(VRB))="    -  -  ")
 When 6 : # Time
  DEF = (format$("K:##[:]##[:]##",num$(evalue(VRB)))="  :  :  ")
 When 7 : # String
  DEF = (func ASYRJSO.TRANS(num$(evalue(VRB)))="")
 When 8,9 : # Clob/Blob
  DEF = (len(evalue(VRB))=0)
 When 10 : # Menu local
  DEF = (evalue(VRB)=0)
 When 11 : # Datetime
  DEF = (evalue(VRB)="1970-01-01T00:00:00Z")
 When Default
  DEF = (evalue(VRB)="")
Endcase
Onerrgo
Return

$RIEN
Resume

#----------------------------------------#
# Encoding parameters in strings value
#----------------------------------------#

Funprog ENCODE_PARAMETERS(PARAM)
Value Char PARAM
Local Char WVALUE(250)
Onerrgo ERROR_ENCODE
WVALUE = num$(evalue(PARAM))
Onerrgo
End WVALUE

#---------------------------#
$ERROR_ENCODE
WVALUE = '"'+"'{"+WVALUE+"}'"+'<error'-errmes$(errn)+'>"'
Resume

#---------------------------#
# Value typed Syracuse
#---------------------------#

Funprog VALUE_PROPERTY(WREP,TYP,VRB,PRO)
Variable Instance WREP Using OBJECT
Value Integer TYP
Value Char    VRB , PRO
Gosub CODPRO_VALUE
End WVALUE

#-------------------#
$CODPRO_VALUE
Local Char WCNT(100)
Onerrgo ERROR_VALUE
# TYP AML 7875
Case TYP
 When 1       : WVALUE = func ASYRSUB.BOOLEAN_TO_SYR(evalue(VRB))
 When 2,3,4   : WVALUE = num$(evalue(VRB))
 When 5       : WVALUE = '"'+func ASYRSUB.DATE_TO_SYR(evalue(VRB))+'"'
 When 6       : WVALUE = '"'+func ASYRSUB.TIME_TO_SYR(evalue(VRB))+'"'
 When 7       : WVALUE = '"'+func ASYRSUB.STRING_TO_SYR(num$(evalue(VRB)))+'"' : # Strings & uuid
 When 8,9     : WVALUE = '{}' : #WVALUE = '{ "$contentType":"text/plain" }'
                WCNT=evalue('fmet '+WINS+'.AGETATTRIBUTE("'+PRO+'","$isLobFound")')
                #106100
                #If WCNT="false" | evalue('fmet '+WINS+'.AGETATTRIBUTE("'+PRO+'","$isHidden")')="true"
                If WCNT="false"
                 WVALUE = func ASYRSUB.SYR_NULL
                Else
                 # Issue X3-74605 - 2018-06-14 by CCC : export the content of the clob
                 If TYP=8 & dim([L]WITHCLOB)>0 & [L]WITHCLOB=[V]CST_ATRUE
                     WVALUE = '"'+func ASYRSUB.STRING_TO_SYR(num$(evalue(VRB)))+'"'
                 Else
                     WCNT=evalue('fmet '+WINS+'.AGETATTRIBUTE("'+PRO+'","$contentType")')
                     If WCNT<>"" : WVALUE = '{ "$contentType":"'+WCNT+'" }' : Endif
                 Endif
                Endif
 When 10      : WVALUE = num$(max(val(num$(evalue(VRB))),0)) : # Combos
 When 11      : WVALUE = '"'+func ASYRSUB.DATETIME_TO_SYR(evalue(VRB))+'"'
 When 25      : WVALUE = '"'+func ASYRSUB.STRING_TO_SYR(evalue('fmet '+VRB+'.AGETTEXT'))+'"' : # String for ATEXTE
 When 26      : WVALUE = '"'+func ASYRSUB.STRING_TO_SYR(num$(evalue(VRB)))+'"' : # String for ATEXTRA
Endcase
If WVALUE='"'+func ASYRSUB.SYR_NULL+'"'
 WVALUE = func ASYRSUB.SYR_NULL
Endif
Onerrgo
Return

#---------------------------#
$ERROR_VALUE

WVALUE = '"'+"'{"+PRO-VRB+"}'"+'<error'-errmes$(errn)+'>"'
Resume


$ATTRIBUTE_EX
Local Instance PJSOPROFAT Using C_ASYRJSO
Local Instance PJSOPRO Using C_ASYRJSO : PJSOPRO = null
Local Instance PJSOPROATT Using C_ASYRJSO : PJSOPROATT = null
Local Instance PJSONCUR Using C_ASYRJSO

#Save the current PSJON
If PJSON = null : Return : Endif
PJSONCUR = PJSON
PJSOPROFAT = PJSON.FAT

Local Char ATT(250)
Local Integer AAM,AAI,ATTTYP

Local  Instance PATTRIBUTES Using C_ATTRIBUTES

Local Integer AATTCOUNT
Local Char AATTCOD(20)(1..)
Local Integer  AATTTYP(1..)
Local Char AATTOPT(250)(1..)

If func ASYRSUB.AGETPROATTRIBUTESEX(PINSTANCE,PRO,AAM,AATTCOD,AATTOPT,AATTTYP)

 For AAI=1 To AAM
  If !find(AATTCOD(AAI), AATTINTERNAL) & !find(AATTCOD(AAI), AATTOKREF)
   If PJSOPROATT = null
    If PJSOPROPERTIES =  null
     PJSOPRO = PJSOPROFAT.SUB
     While PJSOPRO <> null
      If  PJSOPRO.PRO = '"$properties"'
       PJSOPROPERTIES = PJSOPRO
       Break
      Endif
      Break (PJSOPRO.NEX = null)
      PJSOPRO = PJSOPRO.NEX
     Wend
    Endif
    If PJSOPROPERTIES =  null
     Gosub ADDPRO From ASYRJSO
     PJSON.PRO =  '"$properties"'
     PJSON.TYP = 1
     PJSOPROPERTIES = PJSON
     PJSOPROPERTIES.FAT = PJSOPROFAT
     PJSOPRO.NEX = PJSOPROPERTIES
    Endif
    Gosub ALLOCJSO From ASYRJSO
    PJSON.PRO = '"'+VRC+'"'
    PJSON.TYP = 1
    PJSOPROATT = PJSON
    If PJSOPROPERTIES.SUB = null
     PJSOPROPERTIES.SUB = PJSOPROATT
    Else
     PJSOPROATT.NEX = PJSOPROPERTIES.SUB
     PJSOPROPERTIES.SUB = PJSOPROATT
    Endif
   Endif
   Gosub ALLOCJSO From ASYRJSO
   Call SETATTRIBUTE(PJSON,AATTCOD(AAI),AATTTYP(AAI),AATTOPT(AAI)) From ASYRJSO
   PJSON.TYP =  3
   PJSON.NEX = null
   If PJSOPROATT.SUB = null
    PJSOPROATT.SUB  = PJSON
   Else
    PJSON.NEX = PJSOPROATT.SUB
    PJSOPROATT.SUB = PJSON
   Endif
  Endif
 Next AAI
Endif
#Restore the current PSJON
PJSON = PJSONCUR
Return

$INIT_APROPERTIES
Local Char APRONAM(250)(1..)
Local Integer APROTYP(1..)
Local Integer APROCOUNT
Local Integer APROIDX
Local Integer APROREP(1..)
Local Integer APROFCT(1..)
Local Integer APROREPIDX

WGRI = func VIRE_NUMBER(WINS)
If PINSTANCE<>null
 For APROIDX=1 To PINSTANCE.ObjectNbs
  PRO = PINSTANCE.ObjectVar(APROIDX)
  If !find(PRO,NAMSYS(1..NBRSYS))
   APROREPIDX = find(right$(WGRI+"."+PRO,6),REP.PRO(1..maxtab(REP.PRO)).PTH)
   APROCOUNT += 1
   APRONAM(APROCOUNT) = PRO
   APROTYP(APROCOUNT) = evalue('type('+WINS+'.'+PRO+')')
   APROREP(APROCOUNT)  = APROREPIDX
   APROFCT(APROCOUNT)  = 0
   If APROREPIDX
    APROFCT(APROCOUNT)  = (REP.PRO(APROREPIDX).DET=2 & REP.FCT="$details") or (REP.PRO(APROREPIDX).EDT=2 & REP.FCT="$edit") or (REP.PRO(APROREPIDX).SRY=2 & REP.FCT="$summary")
   Endif
  Endif
 Next APROIDX
Endif
Return

