#----------------------------------------------------------------------------------------------------------#
# This operation is used for about version
#
# use this url
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/about
#
# Representation
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/ABOUT('A')?representation=ABOUT.$details
# use GET for get about informations
#
#----------------------------------------------------------------------------------------------------------#

Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Char SOL(250) , DIR(250) , TRT(80) , APP(80)
Local Char VERX3(30) , VERSUP(30) , VERRUN(30) , REL(30) , NOP(30)

Call ABOUT_CONNECT(SOL,DIR,TRT,APP) From ABOUT_CSTD
Call ABOUT_X3(ACTX.AFOLDER,VERX3,VERSUP,VERRUN,REL,NOP) From ABOUT_CSTD
Call JSON_ABOUT(PSYR,SOL,DIR,TRT,APP,VERX3,VERSUP,VERRUN,REL,NOP,ASND.DATA)

ASND.URL      = PSYR.PREFIX+'/about'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".about"
End ERROR

#------------------------------------------#
# JSON who contains about informations
#------------------------------------------#

Subprog JSON_ABOUT(PSYR,SOL,DIR,TRT,APP,VERX3,VERSUP,VERRUN,REL,NOP,WCLOB)
Variable Instance PSYR  Using C_ASYR
Variable Char SOL
Variable Char DIR
Variable Char TRT
Variable Char APP
Variable Char VERX3
Variable Char VERSUP
Variable Char VERRUN
Variable Char REL
Variable Char NOP
Variable Clbfile  WCLOB
Local Instance  JSO(1..) Using C_ASYRJSO
Gosub INIVAR From ASYRJSO
NIV = 1
NODEPRO = ''
Gosub ADDOBJECT From ASYRJSO

NODEPRO = '"solutionName"'
NODESVAL = '"'+SOL+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"solutionHttpUrl"'
NODESVAL = '"'+DIR+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"processServer"'
NODESVAL = '"'+TRT+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"applicationServer"'
NODESVAL = '"'+APP+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"folder"'
NODESVAL = '"'+nomap+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"port"'
NODESVAL = '"'+num$(adxtcp)+'"'
Gosub ADDSTRING From ASYRJSO
#106969 ajout x3Vercom
NODEPRO = '"x3Vercom"'
NODESVAL = '"'+func APRODUCT.AGETVERSION()+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"x3Version"'
NODESVAL = '"'+func ABOUT_CSTD.NEWVER(VERX3,NOP)+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"supervisorVersion"'
NODESVAL = '"'+VERSUP+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"runtimeVersion"'
NODESVAL = '"'+VERRUN+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"x3Release"'
NODESVAL = '"'+REL+'"'
Gosub ADDSTRING From ASYRJSO
NODEPRO = '"patchNumber"'
NODESVAL = '"'+NOP+'"'
Gosub ADDSTRING From ASYRJSO

Gosub ENDNIV From ASYRJSO
Call GENERATE_JSON(TBNIV(1),WCLOB) From ASYRJSO
End

