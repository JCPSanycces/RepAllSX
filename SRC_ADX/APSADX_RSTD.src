#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe APSADX
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return





$AQUERY_OPEN_AFTER
If PQRY.QWHERE<>"" : PQRY.QWHERE -= 'and' : Endif
PQRY.QWHERE -= 'ID gt ""'

Local Char QUERY_ID (10) : QUERY_ID=""
Gosub CHARGE_TAB From APSADX_CSTD

Local File    (
&   Char    ID             (100),
&   Char    CLIENT         (100),
&   Char    USER           (100),
&   Char    DOSSIER        (100),
&   Integer MODULE              ,
&   Char    FONCTION       (100),
&   Char    LOGIN          (100),
&   Char    PORT           (100),
&   Date    DATCON              ,
&   Char    HRECON         (100),
&   Char    DATTIME        (100),
&   Char    CPU            (100),
&   Integer TYP                 ,
&   Char    UID            (100),
&   Char    ADRESSE        (100),
&   Char    IPCLI        (100),
&   Integer NATURE           )
&             From Variable
&   TID,TCLIENT,TUSER,TDOSSIER,TMODULE,TFONCTION,TLOGIN,TPORT,
&   TDATCON,THRECON,TDATTIME,TCPU,TTYP,TUID,TADRESSE,TIPCLI,TNATURE As [LNK_]

Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

$AQUERY_TRANS_AFTER
this.APSADX.ID        = [LNK_]ID
this.APSADX.CLIENT    = [LNK_]CLIENT
this.APSADX.USER      = [LNK_]USER
this.APSADX.DOSSIER   = [LNK_]DOSSIER
this.APSADX.MODULE    = [LNK_]MODULE
this.APSADX.FONCTION  = [LNK_]FONCTION
this.APSADX.LOGIN     = [LNK_]LOGIN
this.APSADX.PORT      = [LNK_]PORT
this.APSADX.DATCON    = [LNK_]DATCON
this.APSADX.HRECON    = [LNK_]HRECON
this.APSADX.DATTIME   = [LNK_]DATTIME # X3-105217 17.09.2018
this.APSADX.CPU       = [LNK_]CPU
this.APSADX.TYP       = [LNK_]TYP
this.APSADX.UID       = [LNK_]UID
this.APSADX.ADRESSE   = [LNK_]ADRESSE
this.APSADX.IPCLI     = [LNK_]IPCLI
this.APSADX.NATURE     = [LNK_]NATURE
Return

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1 : TBPRO(NBPRO) = "ID"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.ID"
             TBFIL(NBPRO) = "[LNK_]ID"
NBPRO += 1 : TBPRO(NBPRO) = "CLIENT"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.CLIENT"
             TBFIL(NBPRO) = "[LNK_]CLIENT"
NBPRO += 1 : TBPRO(NBPRO) = "USER"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.USER"
             TBFIL(NBPRO) = "[LNK_]USER"
NBPRO += 1 : TBPRO(NBPRO) = "DOSSIER"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.DOSSIER"
             TBFIL(NBPRO) = "[LNK_]DOSSIER"
NBPRO += 1 : TBPRO(NBPRO) = "MODULE"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "APSADX.MODULE"
             TBFIL(NBPRO) = "[LNK_]MODULE"
NBPRO += 1 : TBPRO(NBPRO) = "FONCTION"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.FONCTION"
             TBFIL(NBPRO) = "[LNK_]FONCTION"
NBPRO += 1 : TBPRO(NBPRO) = "LOGIN"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.LOGIN"
             TBFIL(NBPRO) = "[LNK_]LOGIN"
NBPRO += 1 : TBPRO(NBPRO) = "PORT"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.PORT"
             TBFIL(NBPRO) = "[LNK_]PORT"
NBPRO += 1 : TBPRO(NBPRO) = "DATCON"
           : TBTYP(NBPRO) = 11 : TBPTH(NBPRO) = "APSADX.DATCON"
             TBFIL(NBPRO) = "[LNK_]DATCON"
NBPRO += 1 : TBPRO(NBPRO) = "HRECON"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.HRECON"
             TBFIL(NBPRO) = "[LNK_]HRECON"
NBPRO += 1 : TBPRO(NBPRO) = "DATTIME" # X3-105217 17.09.2018
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.DATTIME"
             TBFIL(NBPRO) = "[LNK_]DATTIME"
NBPRO += 1 : TBPRO(NBPRO) = "CPU"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.CPU"
             TBFIL(NBPRO) = "[LNK_]CPU"
NBPRO += 1 : TBPRO(NBPRO) = "TYP"
           : TBTYP(NBPRO) = 27 : TBPTH(NBPRO) = "APSADX.TYP"
             TBFIL(NBPRO) = "[LNK_]TYP"
NBPRO += 1 : TBPRO(NBPRO) = "UID"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.UID"
             TBFIL(NBPRO) = "[LNK_]UID"
NBPRO += 1 : TBPRO(NBPRO) = "ADRESSE"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.ADRESSE"
             TBFIL(NBPRO) = "[LNK_]ADRESSE"
NBPRO += 1 : TBPRO(NBPRO) = "IPCLI"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.IPCLI"
             TBFIL(NBPRO) = "[LNK_]IPCLI"
NBPRO += 1 : TBPRO(NBPRO) = "NATURE"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.NATURE"
             TBFIL(NBPRO) = "[LNK_]NATURE"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]ID "
Return

