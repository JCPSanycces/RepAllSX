#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRCCV0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 11208 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
If varinit([M]LEG,indice)=0
 [M]LEG = GLEGFIL
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call AP_LEG([M]LEG) From SUBHRCCV
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varinit([M]DES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DES,"CLASSCONV","DES",[M]COD,GCURLEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DES,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DES,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DES" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone DESSHO
mkstat = 0
zoncou = "DESSHO"
indice = 0
If varinit([M]DESSHO,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESSHO,"CLASSCONV","DESSHO",[M]COD,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESSHO,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESSHO" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone GRA
mkstat = 0
zoncou = "GRA"
indice = 0
If varmode([M]GRA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRA" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone COE
mkstat = 0
zoncou = "COE"
indice = 0
If varmode([M]COE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone IND
mkstat = 0
zoncou = "IND"
indice = 0
If varmode([M]IND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "IND" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CATCSP
mkstat = 0
zoncou = "CATCSP"
indice = 0
If varmode([M]CATCSP,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRCSP"
 Call DEFHRCSP([M]CATCSP,GCURLEG,GSOCIETE) From SUBHRCSP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CATCSP : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CATCSP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRCSP"
  Call CONTHRCSP([M]CATCSP,GCURLEG,GSOCIETE) From SUBHRCSP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]CATCSP
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]CATCSP = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone OCPLEV
mkstat = 0
zoncou = "OCPLEV"
indice = 0
IMPENT = [M]OCPLEV
If varinit([M]OCPLEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]OCPLEV,indice)=0
 [M]OCPLEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OCPLEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OCPLEV(indice)
 Endif
Endif
[M]OCPLEV = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone SALMIN
mkstat = 0
zoncou = "SALMIN"
indice = 0
If varmode([M]SALMIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SALMIN" : Gosub ACTION From =IMPTRT
 Endif
 If [M]SALMIN<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SALMIN" : GZNUM = 859 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone SALMAX
mkstat = 0
zoncou = "SALMAX"
indice = 0
If varmode([M]SALMAX,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SALMAX([M]SALMAX) From SUBHRCCV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]SALMAX : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "SALMAX" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]SALMAX<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SALMAX" : GZNUM = 860 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_SALMAX([M]SALMAX) From SUBHRCCV
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SALMAX" : GZNUM = 860 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRCCV0"
Return

