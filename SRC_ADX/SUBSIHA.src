###########################################################################################
#    Avant l'execution des boutons et des menus                                           #
###########################################################################################
$AVANTBOUT
Local Char     WFONC1(30)
Local Char     WTYP(4), WTEX(12), WANCTEX(12)
Local Integer  WCOD
Local Integer  WMODULE    :    WMODULE = 5
#fq66051-gbn
Local  Integer  SAV_GCONSULT : SAV_GCONSULT=GCONSULT
Local  Integer  SAV_GCONSDIA : SAV_GCONSDIA=GCONSDIA

# Visu des textes si aucun droit de modif (Bug 39742)
#If !ACTMOD GCONSDIA=1 Endif : # Bug 42904
If (find(GREP,"C","D") & !ACTCRE) | (GREP="M" & !ACTMOD) GCONSDIA=2 Endif : # Bug 42904
If GREP="" & dim(ACTMOD)>0 & !ACTMOD  GCONSDIA=2 : Endif : # Bug 53726

  # FGR 19/05/2015 : X3SUIVI106158 (début)
  If find(BOUT, "E", "F", "H", "J", "Q") Then
    If [M:SIH0]BPCINV = "" Then
      GERR = 1
      GMESSAGE = mess(427,192,1)
      Return
    Endif
  Endif
  # FGR 19/05/2015 : X3SUIVI106158 (fin)

# Pour etre sur qu'il soit bien chargé
GFCY=[M]SALFCY
Case BOUT
    When "E"     :                                  : # Saisie du texte entete
                    If [M]NUM = "" & GREP <> "C" & GREP <> "D"
#                       GMESSAGE est à blc, il faut positionner ERR
                        GERR = 1 : GMESSAGE= "" : Return
                    Endif
    When "F"     :                                  : # Saisie du texte pied
                    If [M]NUM = "" & GREP <> "C" & GREP <> "D"
#                       GMESSAGE est à blc, il faut positionner ERR
                        GERR = 1 : GMESSAGE= "" : Return
                    Endif
    When "H"      : [M]CNTNAM=[M:ADB3]CNTNAM        : # Adresse facture
#                    #RMA * 82772
#                    If func AFNC.ACTIV("KPO")
#                      If dim([M]EECNUM)>0
#                        [M]EECNUM=[M:ADB3]EECNUMX
#                      Endif
#                    Endif
#                    If dim([M]EECNUM)>0
#                       [M]EECNUM=[M:ADB3]EECNUM
#                    Endif
    When "J"      : [M]CNTNAM=[M:ADB2]CNTNAM        : # Adresse livraison
    When "Q"      : [M]CNTNAM=[M:ADI4]CNTNAM        : # Adresse règlement - tiers payeur
    When "G"      : Gosub AVTBOUT_GAS               : # Tunnel pièce comptable
    When "1"      :
#                   Ctrl autorisation bouton echeance
                    GBIDC2="E": Gosub AUTORIS_OPT From CONTX3
                    If !GBIDI2  GERR = 1 : GMESSAGE = mess(2,104,1) : Return : Endif
    When "2"      :
#                   Ctrl autorisation bouton reglement
                    GBIDC2="R": Gosub AUTORIS_OPT From CONTX3
                    If !GBIDI2  GERR = 1 : GMESSAGE = mess(2,104,1) : Return : Endif
    When "3"      :
#                   Ctrl autorisation bouton validation
                    GBIDC2="V": Gosub AUTORIS_OPT From CONTX3
                    If !GBIDI2  GERR = 1 : GMESSAGE = mess(2,104,1) : Return : Endif
##                   Si facture directe avec mouvement de stock, ctrl du client       : # 87923
#                    If [M:SIH0]INVTYP=1 & [M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2     : # 87923
                    Gosub AVTBOUT_VAL
                    If GERR=1 Return Endif
#                    Endif                                                            : # 87923
    When "O"      : Gosub AVANTBOUT_VAL From LIBZAF #NIBOW ZAF LEGISLATION JIRA# X3-1579
                    If GERR=1 : Return : Endif
    When Default
Endcase

#Fq66051-Gbn
Case BOUT
 When "E", "F", "H","J", "Q", "K" : If GREP="" & (!ACTMOD | !VERROU)  GCONSULT=1 : GCONSDIA=2  : Endif
 When Default
Endcase
Return
###########################################################################################
###########################################################################################
#    Avant execution du bouton validation                                                 #
###########################################################################################
$AVTBOUT_VAL
Local Integer CDTSTA

# Si facture directe avec mouvement de stock, ctrl du client      : # 87923
If [M:SIH0]INVTYP=1 & [M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2      : # 87923
    Raz GERR, GMESSAGE
    # Contrôle client
    Call SDCDTSTA ("",[M:SIH1]BPCORD,[M:SIH0]CHGTYP,0,"",[M:SIH0]INVDAT,0,1,CDTSTA,GBIDD1,GBIDD1)
&    From TRTVENCDT
    Case CDTSTA
     When 2 : # Client bloqué
              GERR=1 : GMESSAGE = mess(151,199,1) : Return
     When 3 : # Dépassement d'en cours
              GMESSAGE = mess(29,192,1)
              # Si déblocage crédit non autorisé on bloque
              If GCDTUNL=1
                 GERR=1 : Return
              Else
                 Call AVERTIR(GMESSAGE,OK) From GESECRAN
                 Raz GMESSAGE
                 If OK=1 OK=0 : GERR=1 : Return : Endif
              Endif
     When Default
    Endcase
Endif                                                             : # 87923

# 87923 : Gestion des prélèvements SDD
If dim(GSDDMGT)>0 & GSDDMGT=2
  # Si la société gère les SDD
  If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif
  If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
  For [DUD]DUD0 Where TYP=[M:SIH0]GTE & NUM=[M:SIH0]NUM
   # On vérifie le n°mandat sur chaque échéance dt le mode règlement est SDD
   Call LEC_TAM(GCURLEG,[F:DUD]PAM) From CPTLEC
   If !fstat & [F:TAM]SDDFLG=2 & [F:DUD]UMRNUM=""
        # Le n°mandat doit être renseigné
        GMESSAGE=mess(389,192,1) : GERR=1 : Break
   Elsif [F:TAM]SDDFLG=2
        # Si le n°mandat est renseigné mais qu'il n'est validé, on affiche un message d'info
        If clalev([F:MDT])=0    : Local File MANDATE [MDT] : Endif
        If [F:MDT]UMRNUM<>[F:DUD]UMRNUM | [F:MDT]CPY<>GSOCIETE
          Read [MDT]MDT0 = GSOCIETE;[F:DUD]UMRNUM
        Endif
        If [F:MDT]STA<>2
            Call MESSAGE ([F:DUD]UMRNUM-":"-mess(382,192,1)-"("-mess([F:MDT]STA,3631,1)-")") From GESECRAN
        Endif
    Endif
  Next
  Default File [SIV]
  If GERR=1 : Return : Endif
Endif
# 87923

# Issue 115715 - 2016-04-05 by RICAR : POR Leg.: debit notes without reference period
# Issue 115715
If func AFNC.ACTIV("KPO")
#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
#If find([F:SIH]INVTYP,2,4) & func AFNC.ACTIV("KPO")
# End issue 115715
  If func PORLEGLIB.DIGSIGN([M:SIH0]SALFCY, "")
    Gosub VLD_CREDIT_NOTE_SIH From PORLEGLIB
    If OK = 0 : Return : Endif
  Endif
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

Return
###########################################################################################
#    Avant execution du zoom pièce comptable                                              #
###########################################################################################
$AVTBOUT_GAS
#-----------------#
# Pièce comptable #
#-----------------#
Local Integer OUVFICFLG : Raz OUVFICFLG
Local Integer SAVGCONSULT
#FQ 69448 - la variable est prefixée avec WK (car SAVGFLAG est utilisée dans GOBJET)
Local Char    WKSAVGFLAG(10)
SAVGCONSULT=GCONSULT : WKSAVGFLAG=GFLAG
If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : OUVFICFLG=1 : Endif
Read [HAE] HAE0=[M:SIH0]GTE;[M:SIH0]NUM
If !fstat
  GFLAG   =[F:HAE]DACDIA
  GBIDC2  =[M:SIH0]NUM
  GBIDC3  =[M:SIH0]GTE
  GCONSULT=1
Else
  OK=0
  If OUVFICFLG=1 Close Local File [HAE] : Raz OUVFICFLG : Endif
Endif
Return
###########################################################################################
#    Après execution du zoom pièce comptable                                              #
###########################################################################################
$AVANT_SUITE
#---------------------------------------------------------------------#
# Après exécution d'une action et avant l'exécution de l'action suite #
#---------------------------------------------------------------------#
Case BOUT
  When "G" :  # Pièces comptables
    Gosub AVANT_SUITE From GASTRC    : # Dde 59109 : Localisation Polonaise
  When "H","J","K" :  # 79705 : V7 : SAT in SPRICLINK
    # After execution Adresse and before execution recalculate prices
    # Not trigger recalculate prices if globale not informed
    If (dim(GADDACTMOD)<0 | GADDACTMOD<>"1") OK=0 Endif
Endcase
Return
##########################################################################
#    Après execution des boutons                                         #
##########################################################################
$EXEBOUT
#-----------------------------------------------------------#
# Exécution des boutons                                     #
# 3=Validation                                              #
#-----------------------------------------------------------#
 Case BOUT
    When "3" : If GMODU(12)=2
                  If [M:SIH0]INVTYP=1 & ([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2) |
&                    [M:SIH1]SIHORI=2 | [M:SIH1]SIHORI=3
                     Call PRINTFLYER(2,[M:SIH0]NUM,[M:SIH0]NUM,RETOUR) From TRTMACRULE
                  Endif
               Endif
               Gosub RELIT From GOBJSUB
Endcase

Return
#########################################################################
$SETBOUT

# ------------------------------------------------------------------------------------- #
# Suppression des boutons                                                               #
# ------------------------------------------------------------------------------------- #
#     H : Changement de code                                                            #
#     A : Supprimer  : Si fac ou avoir validé ou si SIVSUP=1 (Suppression facture=Non)  #
#     1 : Echéances  : Si en cours de traitement ou aucun enr.                          #
#                      Si ce n'est ni une fac, ni un avoir                              #
#     2 : Règlement  : Si en cours de traitement ou aucun enr.                          #
#                      Si ce n'est pas une fac, ou fac non validée                      #
#                      Si module tiers non présent                                      #
#                      Si aucune échéance non soldée                                    #
#                      Si facture verrouillée par autre utilisateur                     #
#     3 : Validation : Si en cours de traitement ou aucun enr.                          #
#                      Si proforma ou fac déjà validée                                  #
#                      Si facture non imprimée et impression obligatoire                #
#                      Si on vient d'ailleurs                                           #
#                      Si facture verrouillée par autre utilisateur                     #
# ------------------------------------------------------------------------------------- #
GUNVERROU=VERROU
# Si l'on vient des devis, commandes ou livraison suppression de presque tout
#MAE, accès à tout si on vient des clients
#If GFONC1 <> "GESSIH"
#--CPO 75453 Erreur indice
#If GFONC1 <> "GESSIH" & GNAVIG(GPILNAV-1) <> "GESBPC"
#   Call VIREBOUT(CHAINE,"RCDH<>S09") From GOBJET
#Endif
If GFONC1 <> "GESSIH"
  If GPILNAV>1
    If !find(GNAVIG(GPILNAV-1),"GESBPC")
      Call VIREBOUT(CHAINE,"RCDH<>S09") From GOBJET
    Endif
  Else
    Call VIREBOUT(CHAINE,"RCDH<>S09") From GOBJET
  Endif
Endif
#--CPO fin
# Bug 39742 : Si mode consultation, il faut désactiver les boutons
If GCONSULT Call VIREBOUT(CHAINE,"3") From GOBJET Endif
# Bug 53726
# Si l'on vient des retours, pas de modif/suppression possible à cause des stocks (Pb avec Ecran STOENTW entre autre)
If dim(GPILNAV)>0 & dim(GNAVIG)>0 & find("GESSRH",GNAVIG(1..GPILNAV))
   Call VIREBOUT(CHAINE,"MA") From GOBJET
Endif
Call VIREBOUT (CHAINE,"H") From GOBJET
# V6.2 : Certification : Si SIVSUP=1, pas de suppression
# Issue X3-81805 - 2018-04-06 by VAVIL : Is possible delete documents that go to SAF-T
If func PORLEGLIB.PORLEG([M:SIH0]SALFCY,"") :  Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
# End issue X3-81805
If  [M]INVTYP <> 5 & ([M]INVSTA = 3 | GSIVSUP=1) Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
# hb le 23/12/98 : les échéances existent même si l'on n'a pas les tiers
If GREP <> "" | !CLECUR | [M]INVTYP > 2 Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
If GREP <> "" | !CLECUR | [M]INVTYP <> 1 | [M]INVSTA <> 3 | GMODU(3) = 1
    Call VIREBOUT(CHAINE,"2") From GOBJET
Else
  If clalev([F:DUD])<=0 : Local File GACCDUDATE [DUD] : Endif
  # Recherche de la 1ère échéance non réglée de la facture
  ## DBA le 15/01/03 : Optimisation recherche des échéances non soldées FLGCLE=1
  #Filter [DUD] Where TYP=[M:SIH0]GTE & NUM=[M:SIH0]NUM & LIG=1 & [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR>0
  Filter [DUD] Where TYP=[M:SIH0]GTE & NUM=[M:SIH0]NUM & LIG=1 & FLGCLE=1
  Read [DUD]DUD0 First
  If fstat Call VIREBOUT(CHAINE,"2") From GOBJET : Endif
  Filter [DUD]
# Close Local File [DUD]
  Default File [SIV]
Endif
#If GREP <> "" | !CLECUR | [M]INVTYP=5 | [M]INVSTA=3 | ([M]INVSTA=1 & GSIVCFM=2)
If GREP <> "" | !CLECUR | [M]INVTYP=5 | [M]INVSTA=3 | ([M]STARPT<>2 & GSIVCFM=2)
   Call VIREBOUT(CHAINE,"3") From GOBJET
Endif

#If GFONC1 <> "GESSIH"
#   Call VIREBOUT(CHAINE,"3") From GOBJET
#Endif

If !VERROU : Call VIREBOUT(CHAINE,"23") From GOBJET : Endif

# ---------------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                             #
# ---------------------------------------------------------------------------------------------- #
#     E,F : Texte          : Actif si fac.en ligne ou création ou duplication                    #
#   H,J,Q : Adresse        : Actif si fac.en ligne ou création ou duplication                    #
#       M : Crit. picking  : Actif si fac/avoir non validé, client et site renseignés            #
#                            l'origine n'est pas direct,devis,transfert                          #
#                            si modif, il faut avoir des droits de modif                         #
#       K : Info douanières: Actif si fac/avoir en ligne                                         #
#       L : Stock lot      : Actif si fac.en ligne et rien en cours, facture gérée en stock      #
#                            #des lignes gérées en stock, pas facture de livraison,              #
#                            #Si directe, doit être gérée en stock,                              #
#                            des lignes gérées en stock                                          #
#                            facture directe ou de cde ou de liv avec des lignes directes        #
#       R : Transaction                                                                          #
#       G : Pièce cptable  : Actif si module compta, fac ou avo en ligne, validée, rien en cours #
#       N : Traçabilité pièces ventes                                           SYMEU 09/12/2008 #
#       O : Sage sales tax : LTA Activity
# ---------------------------------------------------------------------------------------------- #
If find ([M]INVTYP,1,2) & [M]INVSTA<>3 & [M]BPCINV<>"" & [M]SALFCY<>"" &
&        ([M]NBLIG=0 | ([M]NBLIG>0 & !find([M]SIHORI,5,9)))
        If GREP<>"C"
            GBIDC2="M": GFCY=[M]SALFCY : Gosub AUTORIS_OPT From CONTX3
            If GBIDI2 CHMEN+="M" Endif
        Else
            CHMEN+="M"
        Endif
Endif
If GREP="C" | GREP="D" | CLECUR
    CHMEN += "EF"
    CHMEN += "HJQ"
Endif
If CLECUR
    CHMEN += "K"
Endif
#If CLECUR & GREP="" & [M]INVTYP=1 & sum([M]STOMGTCOD)>[M]NBLIG & [M]SIHORI<>3 &
#&  ([M]SIHORI<>1 | ([M]SIHORI=1 & [M]STOMVTFLG=2))
If CLECUR & GREP="" & [M]INVTYP=1 & [M]STOMVTFLG=2 & sum([M]STOMGTCOD)>[M]NBLIG &
&  (find([M]SIHORI,1,2) | ([M]SIHORI=3 & find("", [M]SDHNUM(0..[M]NBLIG-1))))
    CHMEN += "L"
Endif
CHMEN += "R"
If GMODU(2)=2 & CLECUR & GREP="" & find([M]INVTYP,1,2) & [M]INVSTA=3 CHMEN+="G" Endif
# SYMEU 09/12/2008 : branchement traçabilité pièces
# FGR 07/08/2014 : X3SUIVI102004 (début)
#If !find(GREP,"C","D") and !find("CONSPIV",GNAVIG(1..GPILNAV)) and [M:SIH0]INVTYP<=2 Then CHMEN += "N" Endif
If !find(GREP,"C","D") and !find("CONSPIV",GNAVIG(1..GPILNAV)) and ([M:SIH0]INVTYP<=2 or [M:SIH0]INVTYP=5) Then
  CHMEN += "N"
Endif
# FGR 07/08/2014 : X3SUIVI102004 (fin)

# CHMEN += "O" #SST Tax   # 106867.o  #This menu option does not exist for v7 and above
###VVV
###on restaure pour les tunnels
#GNBGAUCHE = WNBGAUCHE

# 78411 Sage Exchange
If CLECUR & GREP="" & func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([M:SIH2]PTE) & [M]INVTYP <> 5
  #If the payment method has Sage Exchange turned on - enable the menu
  If !instr(0,CHMEN,"S") : CHMEN += "S" : Endif
Endif

# BRBAN 105200#US2 - Deactivate Payment and Open items button
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
   Call VIREBOUT(CHAINE,"1") From GOBJET
   Call VIREBOUT(CHAINE,"2") From GOBJET
  Endif
  # Issue 110570 - 2015-09-02 by BRBAN : Able the NUM field and block the duplication
  If [F:SLT]INVCAN=2 | (func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2)
    Call VIREBOUT(CHAINE,"D") From GOBJET
  Endif
  # -
Endif
#RBA 110811/US2
If func AFNC.ACTIV("EDIX3") <> 0
  If func CNSEDKSTD.GET_EDI_CATACT([M]NUM, 2) <> 0
    CHMEN += "V" #Historic
  Endif
#CJ 110811/US9
  GFCY=[M:SIH0]SALFCY : GBIDC2="I" : Gosub AUTORIS_OPT From CONTX3
  If GBIDI2 and ([M:SIH1]INVSTA <> 1 and [M:SIH1]INVSTA <> 2)
    #/RBA 112138/US2
    CHMEN += "U" #Run EDI Issue
  Else
    Call VIREBOUT(CHMEN,"U") From GOBJET # No EDI Issue
  Endif
#/CJ 110811/US9
Endif
#/RBA

If func AFNC.ACTIV("ELINV") & [M]BPCINV<>AVOID.ACHAR & [M]SALFCY<>AVOID.ACHAR & [M]NUM <> AVOID.ACHAR & GCURLEG = "ZAF" #NIBOW ZAF LEGISLATION JIRA# X3-1579
  Local Char KZACPY(GLONCPY) : KZACPY = func ADP_TOOL.GET_CPY_FROM_SITE(nomap(0), [M]SALFCY)
  Local Char RSASIGN(1) : RSASIGN = func ADP_TOOL.GET_PARAM(nomap(0), 2, KZACPY, "RSASIGN") # Issue X3-35896/122746 - 2017-05-04 By NIBOW
  If RSASIGN <> "2": Call VIREBOUT(CHMEN,"O") From GOBJET : Else : CHMEN += "O" : Endif
Else
  Call VIREBOUT(CHMEN,"O") From GOBJET
Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

####################################################################
$ABANDON
#----- suppression des textes si abandon en dupli ou creation --#
Local Integer WRETOUR : WRETOUR = 0
Local Char    WNUMTEX (12)
Local Integer NOL

# FGR 11/02/2013 : X3SUIVI87630 (début)
  If dim(GSPCKCON) >= 0 Then
    Kill GSPCKCON
  Endif
# FGR 11/02/2013 : X3SUIVI87630 (fin)

Gosub DEVERROU_PICKING
#MAE, bg 77405
Gosub DEVERROU_HAE

# Si facture directe avec maj stock
# ou facture de commande
# ou facture de livraison
If [M:SIH0]INVTYP=1 & (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2) |
&                       [M:SIH1]SIHORI=2 | [M:SIH1]SIHORI=3)
    For NOL=0 To [M]NBLIG-1
        Call DELSTOSORW(NOL,NOL,"SIH4",[M:SIH4]DSTOFCY(NOL),WRETOUR) From STKSOR
        If WRETOUR<>0 Break Endif
    Next
Endif

# Si avoir avec mouvement de stock
If   [M:SIH0]INVTYP=2 & [M:SIH1]STOMVTFLG=2
    # Remise à 0 de l'écran STOENTW
    Call DELSTOENTW (-1,-1,"SIH4",1,1,[M:SIH1]STOFCY,1,"") From STKENT
Endif

Local Integer I, WRET

If GREP="D"
   If left$([M:SIH0]SIHTEX1,3)="SIV"
      Call SUP_CLOB([M:SIH0]SIHTEX1,WRET) From TRTX3TEX
   Endif
   If left$([M:SIH0]SIHTEX2,3)="SIV"
      Call SUP_CLOB([M:SIH0]SIHTEX2,WRET) From TRTX3TEX
   Endif
Endif
# Abandon de dupli ou de picking : Suppression des textes qu'on avait dupliqué
If GREP="D" | [M:SIH1]SIHORI<>1
   For I=0 To [M]NBLIG-1
      If GREP="D" |
&       (sum([M]SQHNUM(I),[M]SOHNUM(I),[M]SDHNUM(I),[M]CONNUM(I),[M]SRENUM(I),[M]XSIHORINUM(I),[M]SRHNUM(I))<>"" &
&        [M:SIH4]CREFLG(I)=0)
          If left$([M:SIH4]SIDTEX(I),3)="SID"
             Call SUP_CLOB([M:SIH4]SIDTEX(I),WRET) From TRTX3TEX
          Endif
      Endif
   Next I
Endif

Call RAZ_CLOB From ACLOB

Actzo [M:SIH0]NUM

If GREP="C" & BOUT="A"
   Raz GREP
   Gosub REMPBOX From SUBSIHC
Endif

  Gosub PJM_OPPOR_PSO_FREEGROUP From SUBSOHA1      # Issue X3-8085/121537 - 2017-02-15 by FGR
Return

#########################################################################
$BOITE
#########################################################################

# Si l'on vient des devis, commandes ou livraisons suppression de la liste gauche
#If GFONC1 <> "GESSIH" GNBGAUCHE = 0 Endif
###VVV
#If GFONC1<>"GESSIH"
#   If GPILNAV>1
#      If !find(GNAVIG(GPILNAV-1),"GESBPC","FUNCMG3")
#         GNBGAUCHE =0
#      Endif
#   Else
#      GNBGAUCHE =0
#   Endif
#Endif
Return

#########################################################################
$FILTRE
Default File [SIV]
# Le filtre ne doit pas être positionné si l'on sélectionne une facture en création d'avoir
If GSELFAC <> 1
   # La facture doit être autorisée par transaction
   # FGR 01/02/2010 : X3SUIVI62114 (début)
   #FILTSUP = "((GFACTYP=1&INVTYP=1) | (GFACTYP=2&INVTYP=2) | (GFACTYP=3&INVTYP=5) | (GFACTYP=4&find(INVTYP,1,5)) | (GFACTYP=5))"
   Case GFACTYP
     When 1
       FILTSUP = "INVTYP=1"
     When 2
       FILTSUP = "INVTYP=2"
     When 3
       FILTSUP = "INVTYP=5"
     When 4
       FILTSUP = "find(INVTYP,1,5)"
     When 5
       FILTSUP = ""
     When Default
       FILTSUP = ""
   Endcase
   # FGR 01/02/2010 : X3SUIVI62114 (fin)
Endif
Return

#########################################################################
$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
# Critère de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# Abréviation du fichier  (ABLIG)  #
# Zone numéro de ligne    (ZONLIG) #
#----------------------------------#
Default Mask [SIH4]
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (début)
#Default File [SID]
#Default File [LSID]
If dim(SAVACT) >= 0 and find(SAVACT,"MODIF","CREATION","ANNULE") Then
  Default File [SID]
Else
  Default File [LSID]
Endif
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (fin)

CRIT = 'NUM="'+[M:SIH0]NUM+'"'
FICLIG = "SINVOICED" : ABLIG = "SID"
ZONLIG = "SIDLIN"

Return

#########################################################################
$AFFMASK
Local Integer I, J, WORI, WRETOUR
If GCREPARBOU = 1
   Case GFONC1
    When "GESSQH" : #GFCY = [M:SQH0]SALFCY                    : # Bug 60948
                    ## Alimentation site fin.(GFINRSP), soc.(GSOCIETE), dev.soc.(GLOCALDEV)
                    #Call GETDEV(GFCY) From DEVSUB
                    # Récupération des paramètres vente du site / de la société
                    #Call GLOBVAR(GFCY,"VEN") From TRTX3      : # Bug 60948
                    # Chargement globales référenciels, comptes et sections de la société
                    #Gosub CHARG_PARAM                        : # Bug 60948
                    ##--- Suppression factures non validées
                    #Call PARAM(GFCY,"SIVSUP",WPARAM) From ADOVAL
                    #GSIVSUP = val(WPARAM)
                    ##--- Ligne à 0 interdites
                    #Call PARAM(GFCY,"SIVNULL",WPARAM) From ADOVAL
                    #GSIVNULL = val(WPARAM)
                    WORI = 1
                    Gosub GEN_FAC From SUBSIHB
                    #Call GEN_FAC(NBSEL,WSLTTRSNUM1,WSLTTRSNUM2,1) From SUBSIHB
                    CLE1 = [F:SIV]NUM
    When "GESSOH" : #GFCY = [M:SOH0]SALFCY                    : # Bug 60948
                    ## Alimentation site fin.(GFINRSP), soc.(GSOCIETE), dev.soc.(GLOCALDEV)
                    #Call GETDEV(GFCY) From DEVSUB
                    # Récupération des paramètres vente du site / de la société
                    #Call GLOBVAR(GFCY,"VEN") From TRTX3      : # Bug 60948
                    # Chargement globales référenciels, comptes et sections de la société
                    #Gosub CHARG_PARAM                        : # Bug 60948
                    ##--- Suppression factures non validées
                    #Call PARAM(GFCY,"SIVSUP",WPARAM) From ADOVAL
                    #GSIVSUP = val(WPARAM)
                    ##--- Ligne à 0 interdites
                    #Call PARAM(GFCY,"SIVNULL",WPARAM) From ADOVAL
                    #GSIVNULL = val(WPARAM)
                    If [M:SOH0]SOHCAT=3 # Issue 107888 - 2016-08-19 by CPO : Scheduling invoice - Invoice button from Orders
                      WORI = 2
                      Gosub GEN_FAC From SUBSIHB
                      #Call GEN_FAC(NBSEL,WSLTTRSNUM1,WSLTTRSNUM2,2) From SUBSIHB
                      CLE1 = [F:SIV]NUM
                      If GOK<1
                         For I=0 To [M:SIH4]NBLIG-1
                            Call DELSTOSORW(I,I,"SIH4",[M:SIH4]DSTOFCY(I),WRETOUR) From STKSOR
                            If WRETOUR<>0 Break Endif
                         Next
                         Raz GOK
                      Endif
                    # Issue 107888 - 2016-08-19 by CPO : Scheduling invoice - Invoice button from Orders
                    Elsif [M:SOH0]SOHCAT=1
                      If GINVTYP<>5  # Ini 107888/120404 - US X3-7606 (JUCON 14/12/2016): Proforma buttom in Scheduling invoice
                        WORI=6
                      Else
                        WORI=2
                      Endif          # End 107888/120404 - US X3-7606 (JUCON 14/12/2016): Proforma buttom  in Scheduling invoice
                      Gosub GEN_FAC From SUBSIHB
                      CLE1 = [F:SIV]NUM
                    # End issue 107888
                    Endif
                    # End issue 107888
    When "GESSDH" : #GFCY = [M:SDH0]SALFCY                    : # Bug 60948
                    ## Alimentation site fin.(GFINRSP), soc.(GSOCIETE), dev.soc.(GLOCALDEV)
                    #Call GETDEV(GFCY) From DEVSUB
                    # Récupération des paramètres vente du site / de la société
                    #Call GLOBVAR(GFCY,"VEN") From TRTX3      : # Bug 60948
                    # Chargement globales référenciels, comptes et sections de la société
                    #Gosub CHARG_PARAM                        : # Bug 60948
                    ##--- Suppression factures non validées
                    #Call PARAM(GFCY,"SIVSUP",WPARAM) From ADOVAL
                    #GSIVSUP = val(WPARAM)
                    ##--- Ligne à 0 interdites
                    #Call PARAM(GFCY,"SIVNULL",WPARAM) From ADOVAL
                    #GSIVNULL = val(WPARAM)
                    WORI = 3
                    Gosub GEN_FAC From SUBSIHB
                    #Call GEN_FAC(NBSEL,WSLTTRSNUM1,WSLTTRSNUM2,3) From SUBSIHB
                    CLE1 = [F:SIV]NUM
    When "GESSRE"
                    # FGR 10/07/2008 : X3SUIVI48011 (DEBUT)
                    WORI = 4
                    Gosub CREFAC_IDEM_PICKE From SUBSIHC
                    CLE1 = [F:SIV]NUM
                    # FGR 10/07/2008 : X3SUIVI48011 (FIN)
    When "GESCON"
                    # FGR 11/07/2008 : X3SUIVI48011 (DEBUT)
                    WORI = 5
                    Gosub CREFAC_IDEM_PICKE From SUBSIHC
                    CLE1 = [F:SIV]NUM
                    # FGR 11/07/2008 : X3SUIVI48011 (FIN)
   Endcase
   Raz GCREPARBOU, GINVTYP
   # Pas de saisie si l'on vient des devis, commandes ou livraisons
   # FGR 10/07/2008 : X3SUIVI48011 Ajout de "SUBSRE", "SUBCON"
   #--CPO 87923 Gestion des prélèvements SDD - pb découvert lors du traitement de cette demande de modif
   #--Dans les Ddes de services et Contrats de service le GFONC1 vaut GESSRE, respectivement GESCON...
   #If find(GFONC1,"GESSQH","GESSOH","GESSDH", "SUBSRE", "SUBCON")
   If find(GFONC1,"GESSQH","GESSOH","GESSDH", "GESSRE", "GESCON")
   #--/
      Diszo [M:SIH0]NUM
   Else
      Actzo [M:SIH0]NUM
   Endif
Endif
Return

#########################################################################
$APRES_MODIF

# Pour l'activation/désactivation de l'option critère picking
If find([M:SIH0]INVTYP,1,2) & find (COUZON,"SALFCY","BPCINV") Gosub SETBOUT From GOBJSUB : Endif

# On vient de modifier une ligne d'avoir avec mvt de stock
If GRELITSIH = 1
   Raz GRELITSIH
   Gosub RELIT From GOBJSUB
   OK=0
   Return
Endif
If find(COUZON,"SIVTYP","SALFCY","BPCINV","BPRPAY","BPCGRU","CUR","PRITYP","VACBPR","STOMVTFLG","BPRFCT","BPRSAC")
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   If COUZON="SALFCY" [M]SALFCY=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPCINV" [M]BPCINV=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPRPAY" [M]BPRPAY=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPCGRU" [M]BPCGRU=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="CUR" [M]CUR=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="PTE" [M]PTE=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="PRITYP" [M]PRITYP=val(CZ) Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="VACBPR" [M]VACBPR=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPRFCT" [M]BPRFCT=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPRSAC" [M]BPRSAC=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="STOMVTFLG" [M]STOMVTFLG=val(CZ) Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   Gosub TIROIR From SUBSIHC
Endif

# V6.2 : Certification
# Si ctrl date documents : Dans FILGAUCHE, Filtre des documents d'origine sur la date
If COUZON="INVDAT"
    [M:SIH0]INVDAT=CZ
    Gosub TIROIR From SUBSIHC
Endif

#--CPO 79560 Si on est sur une liste de picking livr ou cde il faut la vider si conditions remplies
If COUZON="ITMREF" and [M:SIH4]NBLIG=0 and [M:SIH1]SIHORI=1 and [M:SIH1]STOMVTFLG<>2
    [M]ITMREF(0)= CZ
    Gosub TIROIR From SUBSIHC
Endif
#--/CPO

#--CPO 87923 Gestion des prélèvements SDD
If COUZON="UMRNUM"
  [M]UMRNUM=CZ
  Gosub TIROIR From SUBSIHC
Endif
#--/
# Issue 110570 - 2015-09-02 by BRBAN : Able the NUM field and block the duplication
If func AFNC.ACTIV("INVCA")>0
  If ((func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2) | [F:SLT]INVCAN=2 ) & COUZON='NUM'
    Gosub SETBOUT From GOBJSUB
  Endif
Endif
# -
#X3-107954 (LCC-19/09/18) Add an icon on sales invoices Valuation tab
If GREP="M"
 If GSIHVALLIG=2
   Chgfmt [M:SIHV]VALUATION With "-K:3X"
 Else
   Chgfmt [M:SIHV]VALUATION With "K:3X"
 Endif
Endif
Affzo [M:SIHV]VALUATION
#End X3-107954 (LCC-19/09/18) Add an icon on sales invoices Valuation tab
Return

#########################################################################
$LIENS
#########################################################################
Local Integer RF
Local Integer STAT, JL
Local Char    WTRANSAC(GLONGAU)

If !GIMPORT
    If [M:SIH0]INVTYP=1
        # Si facture remise à zéro de l'écran de travail STOSORW
        Call RAZSTOSORW From STKSOR
    Elsif [M:SIH0]INVTYP=2
        # Si avoir remise à zéro du masque STOENTW
        Call DELSTOENTW (-1,-1,"SIH4",1,1,[M:SIH1]STOFCY,1,"") From STKENT
    Endif
Endif

Raz SVGSOHNUM
#--- Lecture des données complémentaires entete facture
#    enr. de la table SINVOICE
#    la table principale des ventes est SINVOICEV
Gosub LEC_SIH
If OK = 0 Return : Endif

[M:SIH0] = [F:SIH]
[M:SIH0]CHGTYP = [F:SIH]CURTYP
[M:SIH1] = [F:SIH]
[M:SIH1]VACBPR = [F:SIH]VAC
Gosub NEW_REGIME From TRTVENFACC
[M:SIH2] = [F:SIH]

# Récup.de la pièce auto stock de la txn facture ou avoir (pr les lignes directes) (Bug 39408 et 42366)
[M:SIH0]ENTCOD = GSLTENTCOD

#------------------------------------------------------------------------#
# Récupération des paramètres vente du site / de la société              #
# Chargement globales référenciels, comptes et sections de la société    #
# Chargement des sections analytiques entête du document                 #
# Réalimentation du cours devise dossier/devise cde                      #
# -----------------------------------------------------------------------#
GFCY = [F:SIV]SALFCY
#Call GETDEV(GFCY)  From DEVSUB
Call GLOBVAR(GFCY,"VEN") From TRTX3
Gosub CHARG_PARAM : Raz GERR : Raz GMESSAGE
Call CHARG_CCEH("SIH2","NBAXE","SIH") From TRTX3CPT

#----------------------------------------------------#
# Chargement libellés et formats colonnes tarif      #
#----------------------------------------------------#
#If GACTMUL=2
# Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
Call ALICOLREM (1,5,GFLAG,"SIH4",[M:SIH2]CUR,0,[M:SIH0]PLISTC) From TRTPRICE
#Else
#    # Alimentation du format des colonnes frais/remise
#    Call ALIFORREM (5, GFLAG, "SIH4", 0, [M:SIH2]CUR) From TRTPRICE
#Endif

# Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
#--this trigger the differents AV_ from generated screens w1WK5xxxx and W2WK5xxxx
#--as there is a test on NBLIG, I moved this call after loading the lines (further below, after Gosub LIENS From TABLEAUX)
#--hence, we avoid calling systematically twice the AV_ from every property
# -----------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
# -----------------------------------------------------------------------#
#Gosub AFF_TITCOL
# End issue X3-38496

# Alimentation pièce auto (pour alim. cpte et nature ana sur nouvelles lignes)
If [M:SIH0]INVTYP <> 5
   #- X3Suivi 71937 Multi-législation -#
   #Read [TSV]TSV0=[M:SIH0]SIVTYP
   #If !fstat [M:SIH0]COD = [F:TSV]COD Endif
   Local Integer WRET
   Call LEC_TSV_LEG(GCURLEG,[M:SIH0]SIVTYP,WRET) From TRTLECLEG
   If WRET : Raz [F:TSV]COD : Endif
   [M:SIH0]COD = [F:TSV]COD

   WTRANSAC=[M:SIH0]COD
   If WTRANSAC <> ""
      Read [GAU]GAU0=WTRANSAC
      If fstat Raz WTRANSAC Endif
   Endif
   If WTRANSAC=""
      Case [F:SIV]INVTYP
       When 1 : WTRANSAC="SIHI"     : # facture
       When 2 : WTRANSAC="SIHC"     : # avoir
                Read [GAU]GAU0=WTRANSAC
                If fstat WTRANSAC="SIHI" Endif
      Endcase
   Endif
Endif

# V6.2 : Certification
#----- Récupération code compteur -----#
If !clalev([F:ANM])  Local File ACODNUM [ANM] : Endif
If [F:TCA]MODULE<>5 | [F:TCA]CPY<>GSOCIETE
    Local Integer WOK
    Call LECTCA(5,WOK) From SUBTCA
    If fstat | !WOK  Raz [F:TCA] : Endif
Endif
Case [M:SIH0]INVTYP
    When 1    : # Facture
        GMANCOU = [F:TCA]MANCOU(3) : GCPT = [F:TCA]CODNUM(3)
    When 2    : # Avoir
        GMANCOU = [F:TCA]MANCOU(4) : GCPT = [F:TCA]CODNUM(4)
    When 5    : # Proforma
        GMANCOU = [F:TCA]MANCOU(5) : GCPT = [F:TCA]CODNUM(5)
Endcase
If [F:GTE]TYP<>[M:SIH0]GTE
    # 71937 : Multilégislation
    #Read [GTE] GTE0=[M:SIH0]GTE : If fstat Raz [F:GTE] : Endif
    Local Integer WRET
    Call LEC_GTE_LEG(GCURLEG,[M:SIH0]GTE,WRET) From TRTLECLEG
    If WRET : Raz [F:GTE] : Endif
    # 71937
Endif
If [F:GTE]COU<>""
    GMANCOU=[F:GTE]MANNUM : GCPT=[F:GTE]COU
Endif
# 71937

#--- Init. nbre de postes des elements de facturation
#    Init. du tableau     des elements de facturation
Read [F:BPR]BPR0 = [M]BPCINV
If fstat
   Raz [F:BPR] : Call RSTA("BPR",[M]BPCINV) From GLOCK
Endif
##--- Alimentation nb axes analytiques
#If dim([M]NBAXE) > 0 [M]NBAXE = GOPTCANA : Endif

#--- Récupération du format de saisie des frais/remises
#Call FMTREM("SIH4",[M]CUR) From TRTPRICE

#--- Lecture du site d'expedition
If [F:SIV]STOFCY <> "" & [F:FCY]FCY <> [F:SIV]STOFCY
    Read [F:FCY]FCY0 = [F:SIV]STOFCY
    If fstat Raz [F:FCY] : Call RSTA("FCY", [F:SIV]STOFCY) From GLOCK : Endif
Endif
#--- Lecture Client facture : Alimentation du nom client
#                             Alimentation de l'en-cours
Read [BPC]BPC0 = [F:SIV]BPCINV
If fstat
   Raz [F:BPC]
   Call RSTA("BPC",[F:SIV]BPCINV) From GLOCK
   [F:BPC]CUR = GLOCALDEV
Endif

# Alimentation à partir du modèle d'édition
If [M]INVTYP=2
   Call ALI_PRTMOD("SIH0",6) From TRTX3
   If [M:SIH0]COPNBE=0 [M:SIH0]COPNBE=1 Endif
Else
   Call ALI_PRTMOD("SIH0",5) From TRTX3
   If [M:SIH0]COPNBR=0 [M:SIH0]COPNBR=1 Endif
Endif

Local Integer NBPOSTE : NBPOSTE=dim([M:SIH2]INVDTA)
Call SAISFOOT (8,"SIH2",NBPOSTE,[F:SIH]CURTYP,[F:BPC]CUR,
&              [F:SIH]CUR,"NON") From SUBSFIT
[M:SIH2]NBFAC = NBPOSTE

If [F:SIH]BPRNAM(0) <> "" [M:SIH0]BPINAM = [F:SIH]BPRNAM(0)
                     Else [M:SIH0]BPINAM = [F:BPC]BPCNAM    : Endif

#--- Chargement des zones cours devise -----#
Call CHARG_RATCUR("SIH2","SIH") From TRTX3CPT

#--- Alimentation cours pour conversion en-cours de dev.soc vers dev.facture (Utilisé si ctrl en-cours au niveau soc)
Local Decimal WCOURS : WCOURS=0 : If [M]RAT2<>0 WCOURS=arr([M]RAT1/[M]RAT2, 10^-GDECRCU) : Endif
Call ALIOST([F:SIV]BPCINV, [F:SIV]CUR, [M]INVDAT, [M]CHGTYP, WCOURS, [M]OST, [M]OSTAUZ) From TRTVENCDT

#--- Lecture client commande
#--- Alimentation de la raison sociale du client commande
#    --  Si facture ou proforma cde : on récupère directement de la commande
Read [BPC]BPC0 = [F:SIV]BPCORD
If fstat
   Raz [F:BPC]
   Call RSTA("BPC",[F:SIV]BPCORD) From GLOCK
Endif
# Bug 50503
#--- Init. mode de facturation : Vient de la commande/livraison d'origine si possible sinon vient du client
Raz [M:SIH0]IME
#--- On récupère le mode de facturation de la commande ou de la livraison si c'est possible
If ([F:SIV]SIHORI=2 & [F:SIV]SIHORINUM <> "")
& |([F:SIV]SIHORI=10 & [F:SIV]SIHORINUM<>"" & [F:SIV]SIHORITYP=10) # 107888 : Scheduled invoices : (LD:10/05/16)
    If [F:SOH]SOHNUM <> [F:SIV]SIHORINUM
        Read [SOH]SOH0 = [F:SIV]SIHORINUM
        If fstat
#           Si proforma la commande a pu être supprimée sinon pb
            Raz [F:SOH] : If [F:SIV]INVTYP <> 5 Call RSTA("SOH",[F:SIV]SIHORINUM) From GLOCK Endif
        Endif
    Endif
    If [F:SOH]BPCNAM <> "" [M:SIH1]BPCNAM  = [F:SOH]BPCNAM Endif
    [M:SIH0]IME=[F:SOH]IME
Elsif [F:SIV]SIHORI=3 & [F:SIV]SIHORINUM <> ""
    If [F:SDH]SOHNUM <> [F:SIV]SIHORINUM
        Read [SDH]SDH0 = [F:SIV]SIHORINUM
        If fstat
#          Si proforma la commande a pu être supprimée sinon pb
           Raz [F:SDH] : If [F:SIV]INVTYP <> 5 Call RSTA("SDH",[F:SIV]SIHORINUM) From GLOCK Endif
        Endif
    Endif
    [M:SIH0]IME=[F:SDH]IME
Endif
# Bug 50503
# 107888 : Scheduled invoices : (LD:10/05/16)
# Alimentation de la raison sociale du client commande
#If ([F:SIV]SIHORI=2 & [F:SIV]SIHORINUM<>"" & [M:SIH1]BPCNAM="") | [F:SIV]BPCORD<>[F:SIV]BPCINV
If ([F:SIV]SIHORI=2  & [F:SIV]SIHORINUM<>"" & [M:SIH1]BPCNAM="") |
&  ([F:SIV]SIHORI=10 & [F:SIV]SIHORITYP=10 & [F:SIV]SIHORINUM<>"" & [M:SIH1]BPCNAM="") |
&  [F:SIV]BPCORD<>[F:SIV]BPCINV
# 107888 : Scheduled invoices : (LD:10/05/16)
    [M:SIH1]BPCNAM = [F:BPC]BPCNAM
Elsif [M:SIH1]BPCNAM = ""
    [M:SIH1]BPCNAM = [M:SIH0]BPINAM
Endif
#--- Lecture Client livré   : Alimentation du nom client
If [F:SIV]BPAADD <> ""
   If [F:BPD]BPCNUM<>[F:SIV]BPCORD | [F:BPD]BPAADD<>[F:SIV]BPAADD
       Read [BPD]BPD0 = [F:SIV]BPCORD;[F:SIV]BPAADD
#      Si origine devis, ce peut être un prospect qui n'a pas d'adresse de livraison
       If fstat & [F:SIV]SIHORI<>5
           Raz [F:BPD] : Call RSTA("BPD",[F:SIV]BPCORD) From GLOCK
       Endif
   Endif
Else Raz [F:BPD] : Endif
If [F:SIV]BPDNAM(0) <> "" [M:SIH1]BPDNAM = [F:SIV]BPDNAM(0)
                     Else [M:SIH1]BPDNAM = [F:BPD]BPDNAM    : Endif
GBPCNUM = [F:SIV]BPCORD
# --- adresse client facture
Raz [M:ADB2], [M:ADB3], [M:ADI4]
[M:ADB3]BPAADD       = [F:SIH]BPAINV
[M:ADB3]ADBBPR       = [F:SIH]BPR
[M:ADB3]BPRNAM(0)    = [F:SIH]BPRNAM(0)
[M:ADB3]BPRNAM(1)    = [F:SIH]BPRNAM(1)
[M:ADB3]BPAADDLIG(0) = [F:SIH]BPAADDLIG(0)
[M:ADB3]BPAADDLIG(1) = [F:SIH]BPAADDLIG(1)
[M:ADB3]BPAADDLIG(2) = [F:SIH]BPAADDLIG(2)
[M:ADB3]POSCOD       = [F:SIH]POSCOD
[M:ADB3]CTY          = [F:SIH]CTY
[M:ADB3]SAT          = [F:SIH]SAT
[M:ADB3]CRY          = [F:SIH]CRY
[M:ADB3]CRYNAM       = [F:SIH]CRYNAM
[M:ADB3]CNTNAM       = [F:SIV]CNINAM
#RMA * 82772
If dim([M:ADB3]EECNUMX)>0
   [M:ADB3]EECNUMX    = [F:SIV]BPIEECNUM
Endif
#If dim([M:ADB3]EECNUM)>0
#   [M:ADB3]EECNUM    = [F:SIV]BPIEECNUM
#Endif
If [M:ADB3]BPRNAM <> "" |  [M:ADB3]BPAADDLIG <> "" |
&  [M:ADB3]POSCOD <> "" |  [M:ADB3]CTY <> "" |
&  [M:ADB3]SAT    <> "" |
&  [M:ADB3]CRY    <> "" |  [M:ADB3]CRYNAM <> ""
    [M:ADB3]ADBFLG = 3
Else
    [M:ADB3]ADBFLG = 0
Endif

# --- adresse livraison
# Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
If dim([M:ADB2]BPAADD) > 0
    [M:ADB2]BPAADD   = [F:SIV]BPAADD
Endif
[M:ADB2]ADBBPR       = [F:SIV]BPCORD
[M:ADB2]BPRNAM(0)    = [F:SIV]BPDNAM(0)
[M:ADB2]BPRNAM(1)    = [F:SIV]BPDNAM(1)
[M:ADB2]BPAADDLIG(0) = [F:SIV]BPDADDLIG(0)
[M:ADB2]BPAADDLIG(1) = [F:SIV]BPDADDLIG(1)
[M:ADB2]BPAADDLIG(2) = [F:SIV]BPDADDLIG(2)
[M:ADB2]POSCOD       = [F:SIV]BPDPOSCOD
[M:ADB2]CTY          = [F:SIV]BPDCTY
[M:ADB2]SAT          = [F:SIV]BPDSAT
[M:ADB2]CRY          = [F:SIV]BPDCRY
[M:ADB2]CRYNAM       = [F:SIV]BPDCRYNAM
[M:ADB2]CNTNAM       = [F:SIV]CNDNAM
#If [F:SIV]BPCORD=[F:SIH]BPR & dim([M:ADB2]EECNUM)>0
#   [M:ADB2]EECNUM = [F:SIV]BPIEECNUM
#Endif
If [M:ADB2]BPRNAM <> "" |  [M:ADB2]BPAADDLIG <> "" |
&  [M:ADB2]POSCOD <> "" |  [M:ADB2]CTY <> "" |
&  [M:ADB2]SAT    <> "" |
&  [M:ADB2]CRY    <> "" |  [M:ADB2]CRYNAM <> ""
    [M:ADB2]ADBFLG = 3
Else
    [M:ADB2]ADBFLG = 0
Endif

#LTA.sn
If dim([M:ADB2]ADRVAL) > 0 and dim([F:SIV]ADRVAL) > 0
    [M:ADB2]ADRVAL = [F:SIV]ADRVAL
Endif
Gosub SHOW_HIDE_ENTCOD From TRTADRLIB
#LTA.en

[M:ADI4]BPAADD       = [F:SIH]BPAPAY
[M:ADI4]ADBBPR       = [F:SIH]BPRPAY
[M:ADI4]BPRNAM(0)    = [F:SIH]BPYNAM(0)
[M:ADI4]BPRNAM(1)    = [F:SIH]BPYNAM(1)
[M:ADI4]BPAADDLIG(0) = [F:SIH]BPYADDLIG(0)
[M:ADI4]BPAADDLIG(1) = [F:SIH]BPYADDLIG(1)
[M:ADI4]BPAADDLIG(2) = [F:SIH]BPYADDLIG(2)
[M:ADI4]POSCOD       = [F:SIH]BPYPOSCOD
[M:ADI4]CTY          = [F:SIH]BPYCTY
[M:ADI4]SAT          = [F:SIH]BPYSAT
[M:ADI4]CRY          = [F:SIH]BPYCRY
[M:ADI4]CRYNAM       = [F:SIH]BPYCRYNAM
# [M:ADI4]CNTNAM       = [F:SIV]CNINAM
If [M:ADI4]BPRNAM <> "" |  [M:ADI4]BPAADDLIG <> "" |
&  [M:ADI4]POSCOD <> "" |  [M:ADI4]CTY <> "" |
&  [M:ADI4]SAT    <> "" |
&  [M:ADI4]CRY    <> "" |  [M:ADI4]CRYNAM <> ""
    [M:ADI4]ADBFLG = 3
Else
    [M:ADI4]ADBFLG = 0
Endif

# Alimentation pays client livré pour affichage et ctrl n°identification CEE
If [M:ADB2]CRY<>""
    [M:SIH0]EECNUMCRY=[M:ADB2]CRY
Else
    If !clalev ([F:BPA]) : Local File BPADDRESS [BPA] : Endif
    If [F:BPA]BPATYP<>1| [F:BPA]BPANUM<>[F:SIV]BPCORD | [F:BPA]BPAADD<>[F:SIV]BPAADD
        Read [BPA]BPA0=1;[F:SIV]BPCORD;[F:SIV]BPAADD
        If fstat Raz [F:BPA] Endif
    Endif
    [M:SIH0]EECNUMCRY=[F:BPA]CRY
Endif
# X3-101236 (LCC-23/07/18) Control "EU VAT no"
# The country can be the country of the ship to customer or the country of the bill to customer
Local Char WDUMMY(20)
Call INIEECNUM ([M:SIH1]BPCORD,[M:SIH1]BPAADD,[M:SIH0]BPCINV,WDUMMY,[M:SIH0]EECNUMCRY) From TRTVENDIV
# end X3-101236 (LCC-23/07/18) Control "EU VAT no"

Raz GTARFLG

# Le client facturé a t'il un no d'identification CEE
GETATCEE=2
Read [BPR]BPR0=[F:SIV]BPCINV
If fstat | [F:BPR]EECNUM="" GETATCEE=1 Endif

# --- chargement de SIHV
Raz [M:SIHV]

If dim([M:SIHX]VCUR)>0 : [M:SIHX]VCUR=[F:SIV]CUR : Endif
If dim([M:SIHV]VCUR)>0 : [M:SIHV]VCUR=[F:SIV]CUR : Endif
[M:SIHV]BASDEP = [F:SIH]BASDEP #gbn-81683

# --- chargement de l'écran [M:SIHV]
Gosub CHARGE_SIHV
#[M:SIHV]NUM=[F:SIH]SIHNUM : [M:SIHV]VCRTYP=4
Gosub LIENS_DIE_FOOT From SUBSIHV

If clalev([F:SFI]) <> 0 Close Local File [SFI] : Endif

#     les totaux
#[M:SIHV]INVNOT=[F:SIH]AMTNOT : [M:SIHV]INVATI=[F:SIH]AMTATI
#  garnissage des zones de cumul et zones euro
[M:SIHV]INVNOT = sum([M:SIHV]XVNOT)+sum([M:SIHV]XFNOT)
[M:SIHV]INVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)

[M:SIHV]DEVRPT1 = GLOCALDEV : [M:SIHV]DEVRPT2 = GLOCALDEV : # Bug 68345
If [M:SIHV]INVNOT<>[F:SIH]AMTNOT | [M:SIHV]INVATI<>[F:SIH]AMTATI
    # CH mail 29/09 : Pour Béryl exprimer ces montants en devise société
    If [M]CUR<>GLOCALDEV
        Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT1<>0 WCOURS=arr([M:SIH2]RAT2/[M:SIH2]RAT1, 10^-GDECRCU) : Endif
        Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&                    [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,WCOURS,STAT) From TRTDEV
        Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&                    [M:SIHV]INVATI,[M:SIHV]INVATIRPT,WCOURS,STAT) From TRTDEV
    Else
        [M:SIHV]INVNOTRPT=[M:SIHV]INVNOT
        [M:SIHV]INVATIRPT=[M:SIHV]INVATI
    Endif
Else
    [M:SIHV]INVNOTRPT=[F:SIH]AMTNOTL
    [M:SIHV]INVATIRPT=[F:SIH]AMTATIL
Endif

[M:SIH4]INVNOT = [M:SIHV]INVNOT
[M:SIH4]INVATI = [M:SIHV]INVATI
Raz [M:SIH4]PFMTOT
Raz [M:SIH0]DSPTOTWEI, [M:SIH0]DSPTOTVOL, [M:SIH0]DSPTOTQTY

If GFONC1="GESSIH" Call RAZ_CLOB From ACLOB Endif
# Pour visu des textes si facture validée
If [F:SIV]INVSTA=3
   GCONSDIA=2
Else
   GCONSDIA=0
Endif

# Raz des champs critères picking
Raz [M:SIH0]CRISRENUM, [M:SIH0]CRICONNUM, [M:SIH0]CRISOHNUM, [M:SIH0]CRISDHNUM
Raz [M:SIH0]CRISIHNUM, [M:SIH0]CRISRHNUM, [M:SIH0]CRIITMREF
If dim([M:SIH0]CRIUMRNUM)>0 : Raz [M:SIH0]CRIUMRNUM : Endif  :#--CPO 87923 Gestion des prélèvements SDD

# ACA On ne Raz que si le masque de travail SFITRF est en ligne (Pour inter-site)
If dim([M:SFIT]LIGQTYPRO)>0
  Raz [M:SFIT]LIGQTYPRO
  Raz [M:SFIT]LIGAMTPRO
  Raz [M:SFIT]LIGWEIPRO
  Raz [M:SFIT]LIGVOLPRO
Endif

# Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX
If [M:SIH0]IME=0
    Read [BPC]BPC0 = [F:SIV]BPCORD
    If fstat
       Raz [F:BPC]
       Call RSTA("BPC",[F:SIV]BPCORD) From GLOCK
    Endif
    [M:SIH0]IME=[F:BPC]IME
Endif

# Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
#--this trigger the differents AV_ from generated screens w1WK5xxxx and W2WK5xxxx
#--as there is a test on NBLIG, I moved this call after loading the lines (further below, after Gosub LIENS From TABLEAUX)
#--hence, we avoid calling systematically twice the AV_ from every property
# -----------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
# -----------------------------------------------------------------------#
Gosub AFF_TITCOL
# End issue X3-38496

#If GIMPORT : Return : Endif

#------------------------#
# affichage icone texte  #
#------------------------#
If [M:SIH0]SIHTEX1 <> "" | [M:SIH0]SIHTEX2 <> ""
    Call SET_IMAGE (4) From GESECRAN
Else
    Call RESET_IMAGE (4) From GESECRAN
Endif

# 87923 : Gestion des prélèvements SDD
If dim([M:SIH2]UMRNUM)>0
    If GSDDMGT=2 & find([M:SIH0]INVTYP, 1,2)
        [M:SIH2]SDDFLG=func TRTVENSDD.IS_PTE_SDD([M:SIH2]PTE,GSOCIETE)
    Else
        [M:SIH2]SDDFLG=1
    Endif
Endif
# 87923

# Gestion de l'état des zones
Local Char    WSVGGREP(1)
WSVGGREP = GREP : Raz GREP
Gosub GRIZE_LIENS
GREP = WSVGGREP

If [M:SIH4]NBLIG <> 0
   For I=0 To [M:SIH4]NBLIG-1
      If [M:SIH4]SOHNUM(I) <> ""
         YSOHNUM = [M:SIH4]SOHNUM(I)
         Break
      Endif
   Next I
Endif

# Si avoir, il faut sauvegarder la clé
# ==> on pointe sur les mêmes fichiers ds picking des factures et la clé est cassée
If [M:SIH0]INVTYP=2
    Local Char WNUM : WNUM= [M:SIH0]NUM
Endif
# Remplissage des boites de picking
Gosub REMPBOX From SUBSIHC

If [M:SIH0]INVTYP=2
    [M:SIH0]NUM = WNUM
    OK=1
    Read [SIV] SIV0=[M:SIH0]NUM
    If fstat OK = 0 : Return Endif
    Gosub LEC_SIH
Endif

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

Raz GSIHSUPPLIGDSP :#--CPO 79343

#Localisation Belge --str
If func AFNC.ACTIV("KBE") Then
  If [M:SIH0]INVTYP=5
    Call DISPLAY_VCS("SIH1","",3,-1)  From INVVCSLIB  :#-- hide VCS field for proforma
  Else
    Call DISPLAY_VCS("SIH1","",3,0)  From INVVCSLIB
  Endif
Endif
#Localisation Belge --end

Gosub SHDCLEECNUM From SUBSIHB

Call FLD4041DIS([M:SIH1]VACBPR, [M:SIH0]SIVTYP) From SUBSIH

If dim([M:SIH0]ORIDOCNUM) > 0
  Call SHOW_HIDE_ORIDOCNUM([M:SIH0]SALFCY,[M:SIH0]SIVTYP,"SIH0") From PORLEGLIB
Endif

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE, [M:SIH2]CUR) From SUBSIHSWI
Endif
# SAM 110033 END

Gosub LIENS From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
# -

Return
################################################################################################
################################################################################################
#------------------------------------------------------------------------
# Chargement de l'écran [M:SIHV] à partir des tables SVCRVAT et SVCRFOOT
#
$CHARGE_SIHV
Local Decimal WDTAVATAMT
Local Integer WRET :#--CPO 71937 TVT et multi-lég
Local Integer JCPO,JCPOI :#--CPO 92252

#     le tableau des taxes
For [SVV]SVV1 Where VCRTYP=4 & VCRNUM=[M:SIH0]NUM

  # Issue X3-87559
  # GSVVNULLIG=2 --> Lines with basis amount=0 are stored in SVCRVAT
  #If [F:SVV]VAT<>"" & [F:SVV]VATNET<>0
  If [F:SVV]VAT<>"" & ([F:SVV]VATNET<>0 | GSVVNULLIG=2)
  # Issue X3-87559
  #--CPO 71937 TVT et multi-lég
  Call LEC_TVT_LEG(GCURLEG,[F:SVV]VAT,WRET) From TRTLECLEG
    #Read [F:TVT]TVT0=[F:SVV]VAT
    #If fstat : Raz [F:TVT] : Endif
    If WRET : Raz [F:TVT] : Endif
    #--/CPO
    [M:SIHV]XVTAX([M:SIHV]NBVAT) = [F:SVV]VAT
    [M:SIHV]XVTYP([M:SIHV]NBVAT) = [F:TVT]VATTYP : [M:SIHV]XVBAS([M:SIHV]NBVAT) = [F:TVT]VATBAS
    Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO([M:SIHV]NBVAT)) From TRTX3TEX
    [M:SIHV]XVNOT([M:SIHV]NBVAT) = [F:SVV]VATGRO
    [M:SIHV]XVSMI([M:SIHV]NBVAT) = [F:SVV]VATNET
    [M:SIHV]XVRAT([M:SIHV]NBVAT) = [F:SVV]VATRAT
    [M:SIHV]XVAMT([M:SIHV]NBVAT) = [F:SVV]VATAMT
    [M:SIHV]XVSUP([M:SIHV]NBVAT) = [F:SVV]VATSUPAMT
    If [F:TVT]VATTYP=1                        : # colonne TTC uniquement si taxe principale
      [M:SIHV]XVATI([M:SIHV]NBVAT) = [F:SVV]VATGRO+[F:SVV]VATAMT+[F:SVV]VATSUPAMT
    Endif

#    If func AFNC.ACTIV("KAB")
       If [F:SVV]VATTYP>3                  : # colonne TTC car les taxes annexes (globales facture)
          [M:SIHV]XVATI([M:SIHV]NBVAT) = [F:SVV]VATAMT : # ne sont pas répercutées sur les lignes taxes principales
       Endif                               : # liées aux produits
#    Endif

    [M:SIHV]NBVAT += 1
  Endif
Next

# Issue 110830 - 2016-01-27 by CPO : Spanish legislation
If [M:SIHV]NBVAT=0 and GCURLEG="SPA" and func AFNC.ACTIV("KSP") and [F:SIH]TAX(0)<>""
  [M:SIHV]XVTAX(0)=[F:SIH]TAX(0)
  Call LEC_TVT_LEG(GCURLEG,[F:SIH]TAX(0),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO([M:SIHV]NBVAT)) From TRTX3TEX
  [M:SIHV]NBVAT += 1
Endif
# End issue 110830

#     le tableau des elements
For [SVF]SVF2 Where VCRTYP=4 & VCRNUM=[M:SIH0]NUM
  If [F:SVF]DTA<>0
     RF = find([F:SVF]DTA,[M:SIHX]XFNUM(0..dim([M:SIHX]XFNUM)-1))
     If RF
       [M:SIHV]XFSHO([M:SIHV]NBFOOT) = [M:SIHX]XFSHO(RF-1)
       [M:SIHV]DSPLIN([M:SIHV]NBFOOT)= [M:SIHX]DSPLIN(RF-1) : # Bug 84075 : Pb calcul des élts répartis sur les lignes
     Else
       Gosub OPEN_SFI From TRTX3CPY : #If clalev([F:SFI])=0 : Local File SFOOTINV   [SFI] : Endif
#       Read [SFI]SFI0=GSOCIETE;[F:SVF]DTA
       Read [SFI]SFI0=[F:SVF]DTA
       If !fstat
         Read [AXX]AXX0="SFOOTINV";"SHOAXX";GLANGUE;num$([F:SFI]SFINUM);""
         If !fstat : [M:SIHV]XFSHO([M:SIHV]NBFOOT) = [F:AXX]TEXTE : Endif
         [M:SIHV]DSPLIN([M:SIHV]NBFOOT)   = [F:SFI]DSPLIN : # Bug 84075 : Pb calcul des élts répartis sur les lignes
       Endif
     Endif
     [M:SIHV]XFNUM([M:SIHV]NBFOOT)    = [F:SVF]DTA
     [M:SIHV]XFNOT([M:SIHV]NBFOOT)    = [F:SVF]DTANOT
#     [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT

     Raz [M:SIHV]XFSMI([M:SIHV]NBFOOT)
     Raz [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)

     Raz JCPO,JCPOI :#--CPO 92252
     For I=0 To dim([F:SVF]DTANET)-1
         #--CPO 92252 Cas d'une facture ayant le prix de la première ligne à 0
         #--Ici, dans notre cas le DTAVAT(0)="" et DTAVAT(1)<>"" du coup on ne charge pas la deuxième taxe
         #--On sort de la boucle uniquement si les autres éléments du tableau ne sont pas renseignés
         #If [F:SVF]DTAVAT(I)="" Break Endif
         If [F:SVF]DTAVAT(I)=""
           If I>= dim([F:SVF]DTANET)-1
             #--Si dernier élément, break direct car sigma retourne 0, incompatible avec le test = "" !!
             Break
           Elsif sigma(I+1,dim([F:SVF]DTANET)-1,[F:SVF]DTAVAT(indcum)) = ""
             #--Cela veut dire qu'il n'y a plus de taxe dans le tableau
             Break
           Else
             #--On continue, il y a encore des taxes à charger
           Endif
         Else
           JCPO  = JCPO + 1
           JCPOI = I
         Endif
         #--/

         Assign "[M:SIHV]DTANOT"  +format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATNOT(I)
         Assign "[M:SIHV]DTANET"  +format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTANET(I)
         Assign "[M:SIHV]DTAVAT"  +format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVAT(I)
         Assign "[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATRAT(I)
         Assign "[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATAMT(I)
         # 102423 : Belgium Early discounts
         Assign "[M:SIHV]DTADEP"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATDEP(I)
         # 102423
         [M:SIHV]XFSMI([M:SIHV]NBFOOT)   +=[F:SVF]DTANET(I)
         [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)+=[F:SVF]DTAVATAMT(I)
     Next
     #--CPO 92252 Cas d'une facture ayant le prix de la première ligne à 0
     #--CPO : explication du test I=1 :
     #--Dans ce cas, nous avons une seule taxe, et donc, on l'affiche,
     #--sinon il faut passer par le clic droite "Taxes" depuis l'écran de Valorisation, afin d'avoir le détail des taxes...
     #If I=1
#         [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANET(I-1)
     #    [M:SIHV]XFTAX([M:SIHV]NBFOOT)    = [F:SVF]DTAVAT(I-1)
     #    [M:SIHV]XFRAT([M:SIHV]NBFOOT)    = [F:SVF]DTAVATRAT(I-1)
     If JCPO=1
         [M:SIHV]XFTAX([M:SIHV]NBFOOT)    = [F:SVF]DTAVAT(JCPOI)
         [M:SIHV]XFRAT([M:SIHV]NBFOOT)    = [F:SVF]DTAVATRAT(JCPOI)
     #--/
     Endif
     # 102423 : Belgium Early discounts
     [M:SIHV]DTADEP([M:SIHV]NBFOOT)   = [F:SVF]DTADEP
     # 102423
     [M:SIHV]DTADEPFLG([M:SIHV]NBFOOT)= [F:SVF]DTADEPFLG #gbn-81683
     [M:SIHV]XFDTAAMT([M:SIHV]NBFOOT) = [F:SVF]DTAAMT
     [M:SIHV]XFATI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT+[M:SIHV]XFVATAMT([M:SIHV]NBFOOT)

     [M:SIHV]AMTCOD([M:SIHV]NBFOOT)    = [F:SVF]AMTCOD : # 85259 : AMTCOD erroné ds SVCRFOOT
     [M:SIHV]CLCBAS([M:SIHV]NBFOOT)    = [F:SVF]DTATYP : # 85259
     [M:SIHV]CLCORD([M:SIHV]NBFOOT)    = [F:SVF]CLCORD : # 85259
     [M:SIHV]NBFOOT += 1
  Endif
Next

[M:SIHV]NUM=[M:SIH0]NUM : [M:SIHV]VCRTYP=4
[M:SIHV]DAT=[M:SIH0]INVDAT # Issue 114057 - 2016-01-29 by CPO : Error message on analytical section with correct date
Return

#########################################################################
# A SUPPRIMER
#########################################################################
