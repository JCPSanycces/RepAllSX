#[M]JOU    = [F:TSV]JOU
#[M]COD    = [F:TSV]COD

# Pour l'instant on ne créé que des factures/ proforma directes
[M]SIHORI = 1

Default File [SIV]
#Case [M:SIH0]INVTYP
#    When 1    : # Facture
#        GMANCOU = [F:TCA]MANCOU(3) : GCPT = [F:TCA]CODNUM(3)
