Call SHOW_HIDE_PERDEB_PERFIN([M:SIH0]SALFCY,[M:SIH0]SIVTYP,"SIH1") From PORLEGLIB
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END
# End issue 115715

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
Call SHOW_HIDE_BVRFIELDS([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE, [M:SIH2]CUR) From SUBSIHSWI
# SAM 110033 END

Gosub RAZCRE From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management

Return

#####################################################################################
# Bug 60948 : Partie de l'étiquette RAZCRE qui ne doit appelée lors du bouton Facture
#####################################################################################
$RAZCRE_BOUTON
#########################################################################

[M:SIH0]INVDAT=datesyst   : # Bug 60948
[M:SIH0]INVCLCFLG=2       : # positionnement du flag calcul facture à Oui  : # Bug 60948

[M]INVTYP=GFACTYP
If GFACTYP=3         : [M]INVTYP=5 : Endif
If find(GFACTYP,4,5) : [M]INVTYP=1 : Endif

Case [M:SIH0]INVTYP
    When 1    : # Facture
        GMANCOU = [F:TCA]MANCOU(3) : GCPT = [F:TCA]CODNUM(3)
    When 2    : # Avoir
        GMANCOU = [F:TCA]MANCOU(4) : GCPT = [F:TCA]CODNUM(4)
    When 5    : # Proforma
        GMANCOU = [F:TCA]MANCOU(5) : GCPT = [F:TCA]CODNUM(5)
Endcase

# -- gestion des textes
Call RAZ_CLOB From ACLOB
GCONSDIA=0

Raz [M:SIH0]SIHTEX1, [M:SIH0]SIHTEX2

Call RESET_IMAGE (4) From GESECRAN

# Alimentation code mouvement, pièce auto, section par défaut stock
[M:SIH0]TRSCOD = WSLTTRSCOD
[M:SIH0]ENTCOD = GSLTENTCOD
#[M:SIH0]CCEDEF = GSLTCCEDEF
# Alimentation famille mouvement
[M:SIH1]TRSFAM = WSLTTRSFAM

#--- Effacement des masques adresse
Raz GGENAVO
Raz GTARFLG
Raz [M:ADB3], [M:ADB2], [M:ADI4]
#If dim([M]NBAXE) > 0
#  [M]NBAXE=GOPTCANA
#  For nolign=1 To GOPTCANA
#    [M]CCEINT(nolign-1)=nolign
#  Next nolign
#Endif
#[M:SIH1]INVSTA = 1 : [M:SIH1]STOMVTFLG = 1
[M:SIH1]INVSTA = 1 : [M:SIH1]STARPT = 1 : [M:SIH1]STOMVTFLG = 1
#--- initialisation du tableau de calcul
Gosub NEW_FACTURE From TRTVENFACC

# Raz écran stockage sortie de stock si facture directe
If [M:SIH0]INVTYP=1 Call RAZSTOSORW From STKSOR Endif
#If !GIMPORT & [M:SIH0]INVTYP=1 Call RAZSTOSORW From STKSOR Endif

#------------------------------------------------------------#
# Renseignement des unités de répartition                    #
#------------------------------------------------------------#
[M:SIH0]DSPWEU = GSALDSPWEU
[M:SIH0]DSPVOU = GSALDSPVOU

# -- ACA
# --- Ouverture du tableau de stockage des éléments facture
Local Char SFIT_OBJ : SFIT_OBJ="SIH"
Gosub INIT_SFIT From SUBSFIT

Return
#########################################################################
$RAZDUP
#-----------------------------------------------#
# Réinitialisation des champs avant duplication #
#-----------------------------------------------#
Local Shortint I
[M:SIH0]INVCLCFLG=2        : # positionnement du flag calcul facture à Oui

#------------------------------------------------------------------------#
# Récupération des paramètres vente du site / de la société              #
# Chargement globales référenciels, comptes et sections de la société    #
# -----------------------------------------------------------------------#
GFCY = [M:SIH0]SALFCY
#Call GETDEV(GFCY) From DEVSUB
Call GLOBVAR(GFCY,"VEN") From TRTX3
Gosub CHARG_PARAM : If GERR=1 OK=0 : Return Endif
## Suppression factures non validées
#Call PARAM(GFCY,"SIVSUP",WPARAM) From ADOVAL
#GSIVSUP = val(WPARAM)
## Ligne à 0 interdites
#Call PARAM(GFCY,"SIVNULL",WPARAM) From ADOVAL
#GSIVNULL = val(WPARAM)

#-- gestion des textes                          ---#
Local Integer WRET
Call RAZ_CLOB From ACLOB
GCONSDIA=0

If left$([M:SIH0]SIHTEX1,3)="SIV"
   Call DUP_CLOB("SIV",[M:SIH0]SIHTEX1,WRET) From TRTX3TEX
   If WRET<1 Raz [M:SIH0]SIHTEX1 Endif
Endif
If left$([M:SIH0]SIHTEX2,3)="SIV"
   Call DUP_CLOB("SIV",[M:SIH0]SIHTEX2,WRET) From TRTX3TEX
   If WRET<1 Raz [M:SIH0]SIHTEX2 Endif
Endif

# A SUPPRIMER
#--- sauvegarde des compteurs texte à dupliquer ---#
#-- pour entete et pied                         ---#
#[M:SIH0]ANCSIHTEX1 = [M:SIH0]SIHTEX1
#[M:SIH0]ANCSIHTEX2 = [M:SIH0]SIHTEX2

Raz GTARFLG

# Pour l'instant on ne créé que des factures/ proforma directes
[M]SIHORI = 1
Default File [SIV]
Case [M:SIH0]INVTYP
    When 1    : # Facture
        GMANCOU = [F:TCA]MANCOU(3) : GCPT = [F:TCA]CODNUM(3)
    When 2    : # Avoir
        GMANCOU = [F:TCA]MANCOU(4) : GCPT = [F:TCA]CODNUM(4)
    When 5    : # Proforma
        GMANCOU = [F:TCA]MANCOU(5) : GCPT = [F:TCA]CODNUM(5)
Endcase
# Lecture du type de facture
#If [F:TSV]SIVTYP <> [M:SIH0]SIVTYP                                  # FGR 05/10/2015 : X3SUIVI113195
If [F:TSV]SIVTYP <> [M:SIH0]SIVTYP | find([F:TSV]LEG,GCURLEG)<1      # FGR 05/10/2015 : X3SUIVI113195
    #Read [TSV]TSV0=[M:SIH0]SIVTYP
    Call LEC_TSV_LEG(GCURLEG,[M:SIH0]SIVTYP,WRET) From TRTLECLEG
    If WRET : GERR=1 : GMESSAGE=mess(185,192,1) : Return : Endif
Endif
# Alimentation catégorie facture, type pièce, code journal
[M]INVTYP = [F:TSV]INVTYP
[M]GTE    = [F:TSV]GTE
[M]JOU    = [F:TSV]JOU
[M]COD    = [F:TSV]COD
If [M]INVTYP <> 5 & [M]GTE <> ""
   # Lecture type pièce
   #If [F:GTE]TYP <> [M]GTE                                          # FGR 05/10/2015 : X3SUIVI113195
   If [F:GTE]TYP <> [M]GTE | find([F:GTE]LEG,GCURLEG)<1              # FGR 05/10/2015 : X3SUIVI113195
      # 71937 : Multilégislation
      #Read [GTE]GTE0=[M]GTE : If fstat Raz [F:GTE] : Endif
      Call LEC_GTE_LEG(GCURLEG,[M]GTE,WRET) From TRTLECLEG
      If WRET : Raz [F:GTE] : Endif
      # 71937
   Endif
   # Type de pièce inexistant
   If [F:GTE]TYP="" GERR=1 : GMESSAGE = [M]GTE-mess(17,114,1)  : Return : Endif
   # Type de pièce inactive
   If [F:GTE]ENAFLG<>2 GERR=1 : GMESSAGE = [M]GTE-mess(274,199,1) : Return : Endif
   # Type de pièce non réel
   If [F:GTE]VCRREA<>2 GERR=1 : GMESSAGE = [M]GTE-mess(59,119,1) : Return : Endif
   # Vous n'avez pas les droits d'exécution
   If [F:GTE]ACS<>""
      Call CONTEXE([F:GTE]ACS) From CPTSUB
      If mkstat GERR=1:GMESSAGE=[F:GTE]ACS-GMESSAGE : Return : Endif
   Endif
   # Récupération des infos compteur à partir du type de pièce
   If [F:GTE]COU<>""
      GMANCOU=[F:GTE]MANNUM : GCPT=[F:GTE]COU
   Endif
Endif

[M:SIH0]INVDAT=datesyst
#--CPO 83457 Duplication facture et ré-initialisation du cours devises
If [M:SIH2]CUR<>"" & (find([M:SIH0]INVTYP, 1,5) | ([M:SIH0]INVTYP=2 & [M:SIH1]SIHORI<>4))
    Call INI_COURS("SIH2",GSOCIETE,[M:SIH2]CUR,[M:SIH0]INVDAT,[M:SIH2]CURTYP) From SUBBICS
Endif
#--/CPO
[M:SIH2]STRDUDDAT=datesyst
#--CPO 81988 En duplication VATDAT ré-initialisé avec la date de la nouvelle facture/avoir
#--Correction qui tient compte du
#--Bug 70183 et Dde 51781 : Init. de la date d'application de la taxe sur une facture de livraison
If dim([M:SIH2]VATDAT)>0
  Raz [M:SIH2]VATDAT :#--par précaution
  #--Init pour les Avoirs
  If [M:SIH0]INVTYP=2
    [M:SIH2]VATDAT=[M:SIH0]INVDAT
  Endif
Endif
#--/CPO
Raz [M:SIH0]NUM
Raz [M:SIH1]SIHORI
Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT, [M:SIH1]PIHNUM
# 107888 : Scheduled invoices : (LD:10/05/16)
Raz [M:SIH1]SIHORITYP
# 107888 : Scheduled invoices : (LD:10/05/16)

Raz [M:SIH1]ORIFCY    : # 107605 : Duplication facture intersite issue de cde ou de livraison

#[M:SIH1]INVSTA = 1
[M:SIH1]INVSTA = 1 : [M:SIH1]STARPT = 1
[M:SIH1]STOMVTFLG = 1

# Alimentation code mouvement, pièce auto, section par défaut stock
[M:SIH0]TRSCOD  = WSLTTRSCOD
[M:SIH0]ENTCOD  = GSLTENTCOD
#[M:SIH0]CCEDEF = GSLTCCEDEF
# Alimentation famille mouvement
[M:SIH1]TRSFAM  = WSLTTRSFAM

#--CPO 71065 - Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Duplication avec paramètre à OUI => si le code affaire de la ligne est <> de celui de l'en-tête, on reprend l'en-tête
Call TRAITE_DUPLICATION("[M:SIH1]PJT") From TRTPJT
#--/CPO

# -------------------------------------------------
# Issue X3-25616/121617 - 2017-02-21 by FGR : BEGIN
Local Integer IACTPJM

  IACTPJM = func ASYRFNC.ACTIV("PJM")
# Issue X3-25616/121617 - 2017-02-21 by FGR : END
# -------------------------------------------------

For I = 0 To [M]NBLIG-1
   Raz [M:SIH4]SOHNUM(I), [M:SIH4]SOPLIN(I), [M:SIH4]SOQSEQ(I)
   Raz [M:SIH4]SDHNUM(I), [M:SIH4]SDDLIN(I)
   Raz [M:SIH4]CONNUM(I), [M:SIH4]SRENUM(I), [M:SIH4]SGHNUM(I)
   Raz [M:SIH4]XSIHORINUM(I), [M:SIH4]SIDORILIN(I), [M:SIH4]SRHNUM(I), [M:SIH4]SRDLIN(I)

   # 107888 : Scheduled invoices : (LD:10/05/16)
   Raz [M:SIH4]SIDORI(I), [M:SIH4]VCRINVCNDTYP(I), [M:SIH4]VCRINVCNDLIN(I), [M:SIH4]SVICUUID(I),[M:SIH4]INVPRC(I)
   # 107888 : Scheduled invoices : (LD:10/05/16)

   Raz [M:SIH4]YINVQTY(I)
   Raz [M:SIH4]YALLQTY(I)

   If left$([M:SIH4]SIDTEX(I),3)="SID"
       Call DUP_CLOB("SID",[M:SIH4]SIDTEX(I),WRET) From TRTX3TEX
       If WRET<1 Raz [M:SIH4]SIDTEX(I) Endif
   Endif

   # Si Duplication de facture, STOMVTFLG est remis à 1 donc on raz les champs stock
   If [M:SIH0]INVTYP=1
       If dim([M:SIH4]LOT(I))>0     Raz [M:SIH4]LOT(I) Endif
       If dim([M:SIH4]SLO(I))>0     Raz [M:SIH4]SLO(I) Endif
       If dim([M:SIH4]LOC(I))>0     Raz [M:SIH4]LOC(I) Endif
       If dim([M:SIH4]STA(I))>0     Raz [M:SIH4]STA(I) Endif
       If dim([M:SIH4]SERNUM(I))>0  Raz [M:SIH4]SERNUM(I) Endif
       If dim([M:SIH4]SERNUMF(I))>0 Raz [M:SIH4]SERNUMF(I) Endif
       If dim([M:SIH4]PALNUM(I))>0  Raz [M:SIH4]PALNUM(I) Endif
       If dim([M:SIH4]CTRNUM(I))>0  Raz [M:SIH4]CTRNUM(I) Endif
       If dim([M:SIH4]MVTDES(I))>0  Raz [M:SIH4]MVTDES(I) Endif
   Endif
   # -------------------------------------------------
   # Issue X3-25616/121617 - 2017-02-21 by FGR : BEGIN
   If IACTPJM Then
     Raz [M:SIH4]SIDPSONUM(I)
     Raz [M:SIH4]SIDSEQNUM(I)
   Endif
   # Issue X3-25616/121617 - 2017-02-21 by FGR : END
   # -------------------------------------------------
   Raz [M:SIH4]CREFLG(I)
   Raz [M:SIH4]UPDFLG(I)
Next I

# Si dupplication, on force l'origine à 'direct'
[M]SIHORI = 1 : Raz [M]AMTMIN, [M]AMTTMP

# Raz écran stockage sortie de stock si facture directe
If [M:SIH0]INVTYP=1  Call RAZSTOSORW From STKSOR : Endif
#If !GIMPORT & [M:SIH0]INVTYP=1  Call RAZSTOSORW From STKSOR : Endif

# ----- #
# avoir #
# ----- #
If   [M:SIH0]INVTYP=2
#    Remise à 0 des champs stock
    Gosub RAZ_TABL_STOCK From SUBSIHB
    Raz [M:SIH4]GESLOT
Endif

# Raz des champs critères picking
Raz [M:SIH0]CRISRENUM, [M:SIH0]CRICONNUM, [M:SIH0]CRISOHNUM, [M:SIH0]CRISDHNUM
Raz [M:SIH0]CRISIHNUM, [M:SIH0]CRISRHNUM, [M:SIH0]CRIITMREF
If dim([M:SIH0]CRIUMRNUM)>0 : Raz [M:SIH0]CRIUMRNUM : Endif :#--CPO 87923 Gestion des prélèvements SDD

#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#
Gosub GRIZE_LIENS

Raz YSOHNUM

#------------------------------------------------------------#
# Renseignement des unités de répartition                    #
#------------------------------------------------------------#
[M:SIH0]DSPWEU = GSALDSPWEU
[M:SIH0]DSPVOU = GSALDSPVOU

Call NTSDUP([M:SIH0]BPCINV,"BPCORD") From TRTNTSCTL   # customer notes

# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

Affzo [M:SIH0]1-99
Affzo [M:SIH1]1-99
Affzo [M:SIH4]1-99
Affzo [M:SIH2]RAT1, LABEL, RAT2, CURMLT :#--CPO 83457

Raz GSIHSUPPLIGDSP :#--CPO 79343

#Localisation Belge --str
If func AFNC.ACTIV("KBE") Then
 Raz [M:SIH1]BELVCS
 If !GIMPORT : Affzo [M:SIH1]BELVCS : Endif
Endif
#Localisation Belge --end

# Issue 115715 - 2016-04-22 by RICAR : POR Leg.: debit notes without reference period
If func AFNC.ACTIV("KPO")
  #Call SHOW_HIDE_PERDEB_PERFIN([M:SIH0]SALFCY,[M:SIH0]SIVTYP,"SIH1") From PORLEGLIB
  If (dim([M:SIH1]PERDEB) > 0) | dim([M:SIH1]PERFIN) > 0
    Raz [M:SIH1]PERDEB, [M:SIH1]PERFIN
    If !GIMPORT
      Affzo [M:SIH1]PERDEB
      Affzo [M:SIH1]PERFIN
    Endif
  Endif
Endif
# End issue 115715

# SAM 110033: Swiss localization: clear field BVRREFNUM
If func AFNC.ACTIV("KSW") Then
    If dim([M:SIH2]BVRREFNUM) > 0
       Raz [M:SIH2]BVRREFNUM              # clear field
       If !GIMPORT Affzo [M:SIH2]BVRREFNUM : Endif
    Endif
Endif
# SAM 110033 END

Gosub RAZDUP From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management

Return

#########################################################################
$INICRE
#########################################################################
Local Integer I, SPSTAT
Local Char    WTRANSAC(GLONGAU), WIDENT(GLONGTE), WJOURNAL(GLONJOU)
Local Decimal COURS

Raz WTRANSAC, WIDENT, WJOURNAL

Raz [F:SIH]

# ---------------------------------------#
#     Alimentation zone SINVOICEV        #
# ---------------------------------------#
[F:SIV]INVCNOSTA = 1
Gosub CHARG_ENTETE

# Alimentation dépôt entête si mono-dépôt
If dim([M:SIH1]WRHE)>0 & GWRHOBY=2 & [M:SIH1]STOFCY<>""
  [F:SIH]WRHE = [M:SIH1]WRHE
Else
  [F:SIH]WRHE = ""
Endif

# Initialisation Nature et Régime CEE
#  supprimer le contenu sauf si import
If !GIMPORT
    Raz [F:SIV]EECNAT  : Raz [F:SIV]EECSCH
    Raz [F:SIV]EECNATR : Raz [F:SIV]EECSCHR
Endif
#If dim([F:SIV]EECNAT)>0 : # Bug 73295
If GACTDEB=2             : # Bug 73295
   If sum([F:SIV]EECNAT,[F:SIV]EECSCH)="" and sum([F:SIV]EECNATR,[F:SIV]EECSCHR)=""
      Call INICRE_EEC("SIV",GBIDI2,[F:SIV]EECNAT,[F:SIV]EECSCH,GBIDI3,[F:SIV]EECNATR,[F:SIV]EECSCHR) From FUNDEBA
   Endif
Endif

Raz [F:SIH]UPDUSR
Raz [F:SIH]UPDDAT

# Facture ou avoir : récupération du type de pièce et du code journal
If [F:SIV]INVTYP<>5
   WTRANSAC=[M]COD
   If WTRANSAC <> ""
      Read [GAU]GAU0=WTRANSAC
      If fstat Raz WTRANSAC Endif
   Endif
   If WTRANSAC=""
      Case [F:SIV]INVTYP
       When 1 : WTRANSAC="SIHI"     : # facture
       When 2 : WTRANSAC="SIHC"     : # avoir
                Read [GAU]GAU0=WTRANSAC
                If fstat WTRANSAC="SIHI" Endif
      Endcase
   Endif

   # Si le type de pièce n'était pas dans le type de facture, évaluation de la pièce auto
   If [M]GTE = ""
      Call EVALAUTO(WTRANSAC,"GTE",WIDENT) From TRTVENFAC
   Else
      WIDENT = [M]GTE
   Endif
   # 71937 : Multilégislation
   #Read [GTE]GTE0=WIDENT
   #If fstat Raz [F:GTE] Endif
   Local Integer WRET
   Call LEC_GTE_LEG(GCURLEG,WIDENT,WRET) From TRTLECLEG
   If WRET : Raz [F:GTE] : Endif
   # 71937

   # Contrôle sur le type de pièce
   Gosub CONTROLE_GTE From TRTVENFAC
   If GOK = 0 Return Endif

   [F:SIH]GTE = WIDENT
   # Récupération des infos compteur à partir du type de pièce
   If [F:GTE]COU<>""
      GMANCOU=[F:GTE]MANNUM : GCPT=[F:GTE]COU
   Endif

   # Si le code journal n'était pas dans le type de facture, évaluation de la pièce auto
   If [M]JOU = ""
      Call EVALAUTO(WTRANSAC,"JOU",WJOURNAL) From TRTVENFAC
      # Si pas de code journal dans la pièce auto, alimentation avec le code journal du type de pièce
      If WJOURNAL = "" WJOURNAL = [F:GTE]DEFJOU Endif
   Else
      WJOURNAL = [M]JOU
   Endif
   If GMODU(2)=2                :  # 105566 : Ajout test présence module compta
       If !clalev([F:JOU]) Local File GJOURNAL [JOU] Endif
       # 71937 : Multilégislation
       #Read [JOU]JOU0=WJOURNAL
       Local Integer WRET
       Call LEC_JOU_LEG(GCURLEG,WJOURNAL,WRET) From TRTLECLEG
       If WRET
       #If fstat
          Raz [F:JOU] : GOK=0 : Call RSTA("JOU",WJOURNAL) From GLOCK : Return
       Endif
       # 71937
       [F:SIH]JOU = WJOURNAL

       # Contrôle sur le code journal
       Gosub CONTROLE_JOU From TRTVENFAC
       Close Local File [JOU]
       If GOK = 0 Return Endif
   Else                         :  # 105566
       [F:SIH]JOU = WJOURNAL    :  # 105566
   Endif                        :  # 105566
Endif
Default File [SIV]

#85785 * RMA
If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[M:SIH0]SALFCY)="2"
  Call LEC_TSV_LEG("POR",[M:SIH0]SIVTYP,WRET) From TRTLECLEG
  If GMANCOU = 2 & [F:TSV]RECTYP <> 4 & [F:TSV]INVTYP <> 5
    GOK = 0 : GERR = 1
    GMESSAGE = mess(84,7711,1)
    Return
  Endif
Endif

If vireblc([M:SIH0]NUM,2)="" | GMANCOU<>2
   If GLOCARGNUM=2 & [M]INVTYP<>5
       # ----------------------------------------------------------- #
       #                 Localisation argentine                      #1
       # Numérotation spécifique pour l'argentine                    #
       # Appel du sous-prog NUMEROARG From SUBANMARG à la place      #
       #       du sous-prog NUMERO From SUBANM standard              #
       # Recherche du numéro                                         #
       # Récupération du numéro CAI et de la date de validité CAI    #
       # ----------------------------------------------------------- #
       Local Char    WA_CAI
       Local Date    WA_DATVLYCAI
       Call NUMEROARG(GCPT,[M]SALFCY,GARGFACTYP,2,[M]INVDAT,[M]VACBPR,GNUM,WA_CAI,WA_DATVLYCAI,STAT) From SUBANMARG
       If GOK<0 Return Endif
       If STAT=0
           [F:SIH]CAI=WA_CAI : [F:SIH]DATVLYCAI=WA_DATVLYCAI
       Else
           Local Char MESSA(80)
           GMESSAGE=mess(104,117,1)-"("+GCPT+") : "
           Gosub MESSAGE From SUBANMARG
           GMESSAGE-=MESSA : GERR=1 : GOK=0 : Return
       Endif
   Else
       # Issue X3-43209 by MRDAB
       If func PORLEGLIB.SEQNUMCORRECT([M:SIH0]SALFCY, GCPT) = 0
        GOK = 0 : GERR = 1
        Return
       Endif
       # Issue end
       Call NUMERO (GCPT,[M]SALFCY,[M]INVDAT,WJOURNAL,GNUM,STAT) From SUBANM
       If GOK<0 Return Endif
       If STAT <> 0
          # Probleme lors de la recuperation du compteur
          GERR=1:GMESSAGE = mess(60,199,1) : GOK = 0 : Return
       Else
           # ----------------------------------------------------------- #
           # Digital signature                                           #
           # ----------------------------------------------------------- #
           If func AFNC.ACTIV("DKS")
               Local Char DKSORIG : DKSORIG = "SIH0"
               Local Integer DKSRET : DKSRET  = 1
               Gosub DKS_INICRE_TRIGGER From DKSLIB
               If DKSRET = 0 : Return : Endif
           Endif
           # ----------------------------------------------------------- #
       Endif
   Endif
   If STAT = 0
       # Si compteur manuel et le no n'a pas ete renseigne
       If GMANCOU=2 & vireblc([M:SIH0]NUM,2)=""
           GERR=2 : GMESSAGE=mess(265,199,1)
       Endif
       [F:SIH]NUM  = GNUM
       [F:SIV]NUM  = GNUM
       [M:SIH0]NUM = GNUM
       Affzo [M:SIH0]NUM
   Endif
Else
   # ----------------------------------------------------------- #
   # Digital signature                                           #
   # ----------------------------------------------------------- #
   If func AFNC.ACTIV("DKS")
       Local Char DKSORIG : DKSORIG = "SIH0"
       Local Integer DKSRET : DKSRET  = 1
       Gosub DKS_INICRE_TRIGGER From DKSLIB
       If DKSRET = 0 : Return : Endif
   Endif
   # ----------------------------------------------------------- #
Endif

# Lecture compteur pour test si chronologie activée
If [F:ANM]CODNUM<>GCPT
   Read [ANM]ANM0=GCPT
   If fstat
      Call RSTA("ANM",GCPT) From GLOCK : GOK=0 : Return
   Endif
Endif
If [F:ANM]CTLCHR=2
   Gosub CTRL_CHRONOLOGIE From TRTVENFAC
   Default File [SIV]
   If GOK=0 Return Endif
Endif

# ---------------------------------------#
#     Alimentation zone SINVOICE         #
# ---------------------------------------#
If [F:SIV]INVTYP = 1 [F:SIH]INVTYP = 1 : [F:SIH]SNS = + 1 : Endif
If [F:SIV]INVTYP = 2 [F:SIH]INVTYP = 2 : [F:SIH]SNS = - 1 : Endif
If [F:SIV]INVTYP = 5 [F:SIH]INVTYP = 5 : [F:SIH]SNS = + 1 : Endif
# --- Avoir sur facture : Renseignement n° document origine
If [F:SIV]INVTYP = 2
    [F:SIH]BPRVCR = [F:SIV]SIHORINUM
Else
    Raz [F:SIH]BPRVCR
Endif
[F:SIH]DIRINVFLG = 1
# ---> Facture directe
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 1 [F:SIH]DIRINVFLG = 2 : Endif

[F:SIH]ORIMOD    = 5

#90370  Cash VAT SPA
Gosub CASH_VAT

#X3-108671 (LCC 18/09/18) Field PJTH ine table SINVOICE not populated by sales invoices
If dim([F:SIH]PJTH)>0: [F:SIH]PJTH = [F:SIV]PJT: Endif

If !GIMPORT | (dim(GWCREINV)>0 & GWCREINV=2)
  Call ACCNUM([F:SIH]ACCNUM) From SUBGAS : # recuperation du no. interne
Endif

Gosub MOD_DATE_ECHE From TRTVENFACC

# affectation des acomptes
If [F:SIV]INVTYP = 1 Call AFF_ACOMPTES (1) From TRTVENFACC : Endif

# Facture : Récupération du paramêtre stock : MARGE alerte péremption jours (pour l'allocation)
If [F:SIH]INVTYP=1
    Call GLOBSTOFCY([F:SIV]STOFCY) From TRTVENGLOB
Endif

# 101380 - need to reset SFISSTCOD when creating from another document
If GCREPARBOU=1
  Call RELOAD_SFISST
Endif

# ACA (2009-09-22) Lot S03
# 81878 : Ajout borne pour ne pas trier le tableau complet
#Sorta [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
# 81878
Local Integer PVCRTYP
# Issue 121835
# [M:SFIT]C_ORIVCR (ML476) : Origin document - PVCRTYP (ML701)
#  1 : Quote                                    1
#  2 : Delivery                                 2
# 10 : Normal order                             20
# 12 : Direct invoice order                     20
#If [M:SFIT]C_ORIVCR=12
If find([M:SFIT]C_ORIVCR, 10,12)
# End issue 121835
  PVCRTYP=20
Else
  PVCRTYP=[M:SFIT]C_ORIVCR
Endif
Call CHARG_CCE_MULTI(PVCRTYP,"[M:SFIT]VCRENT","[M:SFIT]DTA","[M:SIHV]XFNUM","[M:SIHV]SFICCE","[M:SIHV]DSP") From TRTX3CPT

# Issue 117130 - 2016-06-20 by ERMIL : Move WS calls outside of database transactions
# Detail local tax data - Invoice number  must be assigned  prior to calling Sage Sales Tax
# If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
#If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
#  Gosub INICREMOD_SIH From TRTTAXSST   # 106867.n
## Gosub INICREMOD_SIH From TRTTAXUSA   # 106867.o
#  If !GOK : Return: Endif # 106867.n MJH 8/21/15
#Endif

# Législation Belge : VCS Sequencing number --str
If func AFNC.ACTIV("KBE") Then
 Case [F:SIH]INVTYP
  When 1,3
    # Pour les factures et Notes de débit
    # Récupération du compteur VCS
    If !GIMPORT or [M:SIH1]BELVCS=""
      Local Char MESSA(255)
      Call BELSETVCS([F:SIH]FCY,[F:SIH]ACCDAT,[F:SIH]BELVCS,STAT,MESSA) From INVVCSLIB
      If GOK<0  Then Return : Endif
      If STAT <> 0 | GOK<1
       GMESSAGE=MESSA : GERR=1 : GOK=0 : Return
      Else
       [M:SIH1]BELVCS=[F:SIH]BELVCS
       If !GIMPORT : Affzo [M:SIH1]BELVCS : Endif
      Endif
    Endif
  When 2,4
    #--credit note --> load VCS number with VCS number of initial invoice
    If func AFNC.PARAM("BELVCS",GSOCIETE)="2"
      Raz [M:SIH1]BELVCS
      If  [M:SIH1]SIHORI=4 and [M:SIH1]SIHORINUM <> ""
       If !clalev([F:SIH1]) :  Local File SINVOICE  [SIH1] : Endif
       If [F:SIH1]NUM<>[M:SIH1]SIHORINUM
        Read [F:SIH1]SIH0=[M:SIH1]SIHORINUM
        If fstat : Raz [F:SIH1] : Endif
       Endif
        [M:SIH1]BELVCS=[F:SIH1]BELVCS
      Endif
      [F:SIH]BELVCS =[M:SIH1]BELVCS
      If !GIMPORT : Affzo [M:SIH1]BELVCS : Endif
      Default File [SIV]
    Endif
  When Default
 Endcase
Endif
#Localisation Belge --end

# SAM 110033: Swiss localization: calculate BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_BVRFIELDS([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE, [M:SIH1]BPRPAY, [M:SIH2]CUR) From SUBSIHSWI
  If not GOK : Return : Endif
Endif
# SAM 110033 END
Return

#------------------------------------------------------------------------
$CHARG_ENTETE
#------------------------------------------------------------------------
Local Integer I, WRET

If dim([F:SIV]CPY)>0 : [F:SIV]CPY=GSOCIETE : Endif

If [M:SIH0]SIHTEX1<>""
   If left$([M:SIH0]SIHTEX1,3)="SIV"
      Call CRE_CLOB([M:SIH0]SIHTEX1,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif left$([M:SIH0]SIHTEX1,3)<>"BPC"
      Call DUP_CLOB("SIV",[M:SIH0]SIHTEX1,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SIV]SIHTEX1 = [M:SIH0]SIHTEX1
Endif
If [M:SIH0]SIHTEX2<>""
   If left$([M:SIH0]SIHTEX2,3)="SIV"
      Call CRE_CLOB([M:SIH0]SIHTEX2,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif left$([M:SIH0]SIHTEX2,3)<>"BPC"
      Call DUP_CLOB("SIV",[M:SIH0]SIHTEX2,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SIV]SIHTEX2 = [M:SIH0]SIHTEX2
Endif

# --- enregistrement SINVOICEV
[F:SIV]=[M:SIH0] : [F:SIV]=[M:SIH1] : [F:SIV]=[M:SIH2]

[F:SIV]CNINAM       = [M:ADB3]CNTNAM
#If dim([M:ADB3]EECNUM)>0 [F:SIV]BPIEECNUM = [M:ADB3]EECNUM Endif
##RMA * 82772
#If dim([M:ADB3]EECNUMX)>0 [F:SIV]BPIEECNUM = [M:ADB3]EECNUMX Endif

#     chargement du nbre exemplaires facture
If [F:BPC]BPCNUM<>[M]BPCINV
   Read [BPC]BPC0 = [M]BPCINV
   If fstat Raz [F:BPC] : Endif
Endif
#[F:SIV]COPNBR=[F:BPC]COPNBR

# --- chargement de l'adresse livraison
[F:SIV]CNDNAM       = [M:ADB2]CNTNAM
# If (GACTSAD=2 or GLOCUSATAX) & find([M:ADB2]ADBFLG,0,1) Call CHARGE_ADRMSK("ADB2", [F:SIV]BPCORD) From TRTVENDIV : Endif   # 106867.o
If (GACTSAD=2 or (func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2)) & find([M:ADB2]ADBFLG,0,1) Call CHARGE_ADRMSK("ADB2", [F:SIV]BPCORD) From TRTVENDIV : Endif   # 106867.n

Gosub CHARGE_ADRBPD From SUBSIHB
For I = 1 To dim([F:SIV]DISCRGTYP)
  [F:SIV]DISCRGTYP (I-1) = GDISCRGTYP (I-1) : # type frais/remises lignes
  [F:SIV]INVDTALIN (I-1) = GINVDTALIN (I-1) : # no. element ligne
Next I
[F:SIV]LINNBR       = [M:SIH4]NBLIG

# --- enregistrement SINVOICE
[F:SIH]=[M:SIH0] : [F:SIH]=[M:SIH1] : [F:SIH]=[M:SIH2]

[F:SIH]BPR          = [F:SIV]BPCINV
[F:SIH]CPY          = GSOCIETE
[F:SIH]FCY          = [F:SIV]SALFCY
[F:SIH]ACCDAT       = [F:SIV]INVDAT
[F:SIH]BPRDAT       = [F:SIV]INVDAT
[F:SIH]RATDAT       = [F:SIV]INVDAT
[F:SIH]CURTYP       = [M:SIH0]CHGTYP
[F:SIH]VAC          = [M]VACBPR
[F:SIH]STA          = [F:SIV]INVSTA
If [M]INVTYP = 2
    [F:SIH]INVNUM = [M]SIHORINUM
Else
    Raz [F:SIH]INVNUM
Endif

[F:SIH]BPAINV       = [M:SIH0]BPAINV
# --- chargement de l'adresse facture
If GACTSAD=2 & find([M:ADB3]ADBFLG,0,1) Call CHARGE_ADRMSK("ADB3", [F:SIV]BPCINV) From TRTVENDIV : Endif
Gosub CHARGE_ADRBPI From SUBSIHB

# Issue 122327
# [F:SIV]BPCINV and [F:SIH]BPR are the same so the name is the same also
#If [F:SIH]BPRNAM(0) <> "" [F:SIV]BPINAM = [F:SIH]BPRNAM Endif
[F:SIV]BPINAM(0) = [F:SIH]BPRNAM(0)
[F:SIV]BPINAM(1) = [F:SIH]BPRNAM(1)
# End issue 122327

# --- chargement de l'adresse règlement - tiers payeur
If GACTSAD=2 & find([M:ADI4]ADBFLG,0,1) Call CHARGE_ADRMSK("ADI4", [F:SIV]BPRPAY) From TRTVENDIV : Endif
Gosub CHARGE_ADRBPY From SUBSIHB

# --- chargement a partir tableau de calcul
Gosub CHARGE_SIH From TRTVENFACC

# Alimentation des montants en devise société
#Local Decimal WCOURS : WCOURS=0 : If [M]RAT1<>0 WCOURS=arr([M]RAT2/[M]RAT1, 10^-GDECRCU) : Endif
#Call COURMNT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]RATDAT,1,
#&            [F:SIH]AMTNOT,[F:SIH]AMTNOTL,WCOURS,WRET) From TRTDEV
#Call COURMNT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]RATDAT,1,
#&            [F:SIH]AMTATI,[F:SIH]AMTATIL,WCOURS,WRET) From TRTDEV

# --- Calcul de la repartition ligne dans SIHV
Global Integer G_CLCDSPLIN : G_CLCDSPLIN=1
Gosub CLC_DSPLIN From TRTVENFACC

Return

#########################################################################
$INICRE_LIG
#########################################################################
Local Shortint NOL        : NOL=nolign-1

# FGR 11/02/2013 : X3SUIVI87630 (début)
  If dim(GSPCKCON) >= 0 Then
    Read [F:CON]CON0=[M:SIH4]CONNUM(NOL)  # FGR 08/04/2013 : X3SUIVI89164
    GSPCKCON = "INICRE_LIG"
    Gosub MAJ_STRDAT_ENDDAT From TRTSIHCON
    Affzo [M]STRDAT(NOL)
    Affzo [M]ENDDAT(NOL)
  Endif
# FGR 11/02/2013 : X3SUIVI87630 (fin)

#--------------------------------#
# Avant le Write de la ligne SID #
#--------------------------------#
[F:SID]NUM    =  [M:SIH0]NUM

Gosub CHARG_DETAIL

# Alimentation dépôt ligne si renseigné
If dim([M:SIH4]WRH)>0 & [M:SIH1]STOFCY<>"" & [M:SIH4]WRH(NOL)<>""
  [F:SID]WRH = [M:SIH4]WRH(NOL)
Else
  [F:SID]WRH = ""
Endif

# Calcul des commissions représentants
Call CALC_COMREP() From TRTVENFAC

## Alimentation du compte et de la nature analytique
# Exécuté dans VALLIG : Appel $MAJSID_CPTANALIN
#Local Char COMPTE, NATURE
#Call CPTE_NATURE(WTRANSAC, COMPTE, NATURE) From TRTVENFAC
#If [F:SID]LINACC = "" [F:SID]LINACC = COMPTE Endif
#If [F:SID]LINCNA = "" [F:SID]LINCNA = NATURE Endif

If [M:SIH4]QTY(NOL)<>0 [F:SID]AMTLIN=0 Endif

# Avoir avec mouvement de stock
# Recalcul du prix de revient si base de calcul de marge=prix moyen lot
If [M:SIH0]INVTYP=2 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]QTY(NOL)<>0 Gosub RECALC_CPRPRI Endif

[F:SID]DSPWEU = [M:SIH0]DSPWEU
[F:SID]DSPVOU = [M:SIH0]DSPVOU

Return


# --------------------------------------------------------------- #
# Avoir avec mvt de stock :                                       #
# Recalcul prix de revient si base calcul de marge=prix moyen lot #
# Dépend exactement des lots retournés                            #
# --------------------------------------------------------------- #
$RECALC_CPRPRI
Local    Integer WRET
Local    Char    WTCM(GLONTCM)
#-----
Raz WRET
#----- Lecture article-site si nécessaire -----#
If [F:ITF]ITMREF<>[M:SIH4]ITMREF(NOL) | [F:ITF]STOFCY<>[M:SIH4]DSTOFCY(NOL)
  Read [ITF] ITF0=[M:SIH4]ITMREF(NOL);[M:SIH4]DSTOFCY(NOL)
  If fstat  Raz [F:ITF] : Return : Endif
Endif
#----- Lecture table méthode de valorisation -----#
Call GETTCM([M:SIH4]ITMREF(NOL), [M:SIH4]DSTOFCY(NOL), WTCM, WRET) From STKVAL
If WRET | WTCM="" Return : Endif
If [F:TCM]PFMCLCBAS<>6 Return Endif
#----- Base calcul de marge = Prix moyen lot, recalcul du prix de revient et de la marge
Local Integer WLIN : WLIN=NOL
Gosub MARGE From TRTVENFAC
[M:SIH4]CPRPRI(NOL)=[F:SID]CPRPRI
[M:SIH4]PFM(NOL)=[F:SID]PFM
Return

#------------------------------------------------------------------------
$CHARG_DETAIL
#------------------------------------------------------------------------
# FGR 11/02/2013 : X3SUIVI87630 (début)
  If dim(GSPCKCON) >= 0 and GSPCKCON = "INICRE_LIG" Then
    [F:SID]STRDAT = [M]STRDAT(NOL)
    [F:SID]ENDDAT = [M]ENDDAT(NOL)
  Endif
# FGR 11/02/2013 : X3SUIVI87630 (fin)

If dim([F:SID]CPY)>0 : [F:SID]CPY=GSOCIETE : Endif
[F:SID]SALFCY = [F:SIV]SALFCY
[F:SID]INVDAT = [F:SIV]INVDAT
[F:SID]BPCINV = [F:SIV]BPCINV

If [F:SID]REP1 = "" Raz [F:SID]REPBAS1, [F:SID]REPAMT1 : Endif
If [F:SID]REP2 = "" Raz [F:SID]REPBAS2, [F:SID]REPAMT2 : Endif

[F:SID]BASTAXLIN(0) = [M:SIH4]BASTAXLIN1(NOL)
[F:SID]BASTAXLIN(1) = [M:SIH4]BASTAXLIN2(NOL)
[F:SID]BASTAXLIN(2) = [M:SIH4]BASTAXLIN3(NOL)
[F:SID]BASTAXLIN(3) = [M:SIH4]BASTAXLIN4(NOL)
[F:SID]BASTAXLIN(4) = [M:SIH4]BASTAXLIN5(NOL)
[F:SID]BASTAXLIN(5) = [M:SIH4]BASTAXLIN6(NOL)

[F:SID]AMTTAXLIN(0) = [M:SIH4]AMTTAXLIN1(NOL)
[F:SID]AMTTAXLIN(1) = [M:SIH4]AMTTAXLIN2(NOL)
[F:SID]AMTTAXLIN(2) = [M:SIH4]AMTTAXLIN3(NOL)

[F:SID]VACITM(0)    = [M:SIH4]VACITM1(NOL)
[F:SID]VACITM(1)    = [M:SIH4]VACITM2(NOL)
[F:SID]VACITM(2)    = [M:SIH4]VACITM3(NOL)
[F:SID]VAT(0)       = [M:SIH4]VAT1(NOL)
[F:SID]VAT(1)       = [M:SIH4]VAT2(NOL)
[F:SID]VAT(2)       = [M:SIH4]VAT3(NOL)

[F:SID]STOFCY       = [M:SIH4]DSTOFCY(NOL)
[F:SID]SIHORINUM    = [M:SIH4]XSIHORINUM(NOL)

[F:SID]LOT          = [M:SIH4]LOTFIL(NOL)
[F:SID]STA          = [M:SIH4]STAFIL(NOL)
[F:SID]LOC          = [M:SIH4]LOCFIL(NOL)

[F:SID]PJT          = [M:SIH4]DPJT(NOL)   : # 71065 : PJT

If dim([M:SIH4]TSICOD1)>0: [F:SID]TSICOD(0) = [M:SIH4]TSICOD1(NOL):Endif
If dim([M:SIH4]TSICOD2)>0: [F:SID]TSICOD(1) = [M:SIH4]TSICOD2(NOL):Endif
If dim([M:SIH4]TSICOD3)>0: [F:SID]TSICOD(2) = [M:SIH4]TSICOD3(NOL):Endif
If dim([M:SIH4]TSICOD4)>0: [F:SID]TSICOD(3) = [M:SIH4]TSICOD4(NOL):Endif
If dim([M:SIH4]TSICOD5)>0: [F:SID]TSICOD(4) = [M:SIH4]TSICOD5(NOL):Endif

If [M:SIH4]SIDTEX(NOL)<>""
   If left$([M:SIH4]SIDTEX(NOL),3)="SID"
      Call CRE_CLOB([M:SIH4]SIDTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif !find(left$([M:SIH4]SIDTEX(NOL),3),"ITU","ITS")
      Call DUP_CLOB("SID",[M:SIH4]SIDTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SID]SIDTEX = [M:SIH4]SIDTEX(NOL)
Endif

# --- Stockage a la ligne des elt de facturation
Call UPD_DSPLIN("SID",NOL) From TRTVENFACC

Return

#########################################################################
$INIMOD
#########################################################################
Local Integer WOK

# Issue 117130 - 2016-06-20 by ERMIL : Move WS calls outside of database transactions
# Call SST
# If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
#If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
#  Gosub INICREMOD_SIH From TRTTAXSST   # 106867.n
## Gosub INICREMOD_SIH From TRTTAXUSA   # 106867.o
#Endif

#Localisation Belge --str
#--credit note --> update VCS number with VCS number of initial invoice
# !! if direct suppression of invoice lines, the fields [M:SIH1]SIHORIxxx are refreshed too late
If func AFNC.ACTIV("KBE")
 If find([F:SIH]INVTYP,2,4)
  If func AFNC.PARAM("BELVCS",GSOCIETE)="2"
    Local Integer I
    Raz [M:SIH1]BELVCS
    If find([M:SIH1]SIHORI,1,4)
      For I=0 To [M:SIH4]NBLIG-1
       If [M:SIH4]XSIHORINUM(I)<>""
         If !clalev([F:SIH1]) :  Local File SINVOICE  [SIH1] : Endif
         If [F:SIH1]NUM<>[M:SIH4]XSIHORINUM(I)
            Read [F:SIH1]SIH0=[M:SIH4]XSIHORINUM(I)
            If fstat : Raz [F:SIH1] : Endif
         Endif
         [M:SIH1]BELVCS=[F:SIH1]BELVCS
         Break
       Endif
      Next I
    Endif
    If !GIMPORT : Affzo [M:SIH1]BELVCS : Endif
  Endif
 Endif
Endif
#Localisation Belge --end

Gosub CHARG_ENTETE

# Si la facture était positionnée à imprimée, elle redevient non imprimée
#If [F:SIV]INVSTA=2
#   [F:SIV]INVSTA=1 : [F:SIH]STA=1 : [M:SIH1]INVSTA=1
#Endif
# Issue 110946
#If [F:SIV]STARPT=2
If [F:SIV]STARPT=2 & [F:SIV]INVSTA<>3
   [F:SIV]STARPT=1 : [F:SIH]STARPT=1 : [M:SIH1]STARPT=1
Endif
# End issue 110946

# Si la date a été modifié et que la facture a un code journal, contrôle de la chronologie
If MODDAT = 1
   If [F:SIH]JOU <> ""
      Call LECTCA(5,WOK) From SUBTCA
      If fstat | !WOK
          GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : Return
      Endif
      Default File [SIV]
      Case [M:SIH0]INVTYP
       When 1    : GCPT = [F:TCA]CODNUM(3)
       When 2    : GCPT = [F:TCA]CODNUM(4)
       When 5    : GCPT = [F:TCA]CODNUM(5)
      Endcase
      # 71937 : Multilégislation
      #Read [GTE]GTE0=[M:SIH0]GTE
      #If fstat Raz [F:GTE] Endif
      Local Integer WRET
      Call LEC_GTE_LEG(GCURLEG,[M:SIH0]GTE,WRET) From TRTLECLEG
      If WRET Raz [F:GTE] Endif
      # 71937
      # Récupération des infos compteur à partir du type de pièce
      If [F:GTE]COU<>""
         GCPT=[F:GTE]COU
      Endif
      # Lecture compteur pour test si chronologie activée
      If [F:ANM]CODNUM<>GCPT
         Read [ANM]ANM0=GCPT
         If fstat
            Call RSTA("ANM",GCPT) From GLOCK : GOK=0 : Return
         Endif
      Endif
      If [F:ANM]CTLCHR=2
         Gosub CTRL_CHRONOLOGIE From TRTVENFAC
         Default File [SIV]
         If GOK=0
            [M:SIH0]INVDAT=SVGINVDAT
            Affzo [M:SIH0]INVDAT
            Return
         Endif
      Endif
   Endif
Endif

#90370 Cash VAT SPA
Gosub CASH_VAT

#X3-108671 (LCC 18/09/18) Field PJTH ine table SINVOICE not populated by sales invoices
If dim([F:SIH]PJTH)>0: [F:SIH]PJTH = [F:SIV]PJT: Endif

# affectation des acomptes
If [F:SIV]INVTYP = 1 Call AFF_ACOMPTES (1) From TRTVENFACC : Endif

# Déplacé en $MODIF après maj des lignes (on test SIHORI ds VALLIG s'il est déjà remis à 1 on est eu !)
# alimentation no origine
#Call RECH_ORINUM From SUBSIHB
##If [M:SIH1]SIHORINUM="" [M:SIH1]SIHORI=1 Endif
#[F:SIV]SIHORINUM=[M:SIH1]SIHORINUM
#[F:SIV]SIHORI=[M:SIH1]SIHORI
#CPO 66740 -- Problème découvert lors de la correction de cette fiche
# -- La correction est bonne dans le cas des suppréssions mais pose problèmes lors de la création
# -- les pièces d'origine ne sont pas mises à jour comme étant facturées.
# -- Annulation de la correction 62408 (voir $VALIGANN pour la solution)
#[F:SIV]SIHORINUM=WSVG_SIHORINUM : # Bug 62408
#[F:SIV]SIHORI=WSVG_SIHORI       : # Bug 62408

# Bug 84075 : Calcul déjà effectué dans CHARG_ENTETE
## --- Calcul de la repartition ligne dans SIHV
#Global Integer G_CLCDSPLIN : G_CLCDSPLIN=1
#Gosub CLC_DSPLIN From TRTVENFACC

# SAM 110033: Swiss localization: calculate BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_BVRFIELDS([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE, [M:SIH1]BPRPAY, [M:SIH2]CUR) From SUBSIHSWI
  If not GOK : Return : Endif
Endif
# SAM 110033 END

Return
#########################################################################
$INIMOD_LIG
#########################################################################
Local Shortint NOL : NOL=nolign-1

Gosub CHARG_DETAIL
# Calcul des commissions représentants
Call CALC_COMREP() From TRTVENFAC

Return

#########################################################################
$VALLIG
#########################################################################
#----------------------------------------------------------------#
# En création     : TRTLIG = "C" et SIGN = +1 (après le write)   #
# En modification : TRTLIG = "M" et SIGN = -1 (avant le rewrite) #
#                                   SIGN = +1 (après le rewrite) #
# En annulation   : TRTLIG = "A" et SIGN = -1 (avant le delete)  #
#----------------------------------------------------------------#
Local Date    WDAT, WDTE
Local Char    WMAJ, WNUM, WFCY(GLONFCY)
Local Integer WOPT, WWIN, WRET, WTYP, I
Local Decimal WQTE, WQTY, WSHT, WSHTQTY, WLIN, WSEQ
Local Integer NOL
Local Decimal DELTAQTY     : # Delta de la quantité livrée (en + ou -)
Local Decimal DELTAQTYSTU  : # Delta de la quantité livrée US (en + ou -)
Local Decimal ECARTQTY     : # Ecart entre qte cde et qte liv (en + ou -)
Local Decimal SVGSHTQTY    : # Sauvegarde qté cde rupture
Local Integer WCHANGED_SIV_SIHORI :#--CPO 108164

# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
Local Decimal WOLDEXTQTY_NP, WOLDEXTQTY_P
Local Decimal WNEWEXTQTY_NP, WNEWEXTQTY_P
Raz WOLDEXTQTY_NP, WOLDEXTQTY_P
Raz WNEWEXTQTY_NP, WNEWEXTQTY_P
Local Integer WRET
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)

NOL  = nolign-1
WMAJ = "C"        : # Création allocation
WWIN = 0          : # Inutilisé
WRET = 0          : # Code retour

If [M:SIH1]INVSTA=3 Return Endif

#--CPO 108164
#--Le WSVG_SIHORI est uniquement déclaré dans $AVANT_MODFIC, il faut quand même vérifier
#--variable inexistante lors de la création, par exp.
[L]WCHANGED_SIV_SIHORI = 0
If dim(WSVG2_SIHORI)>0 and GREP="M"
  If    TRTLIG="A" and [L]WSVG2_SIHORI <> 1 and [F:SIV]SIHORI=1
    #--dans ce cas, il faut, pour les lignes supprimées, partir sur l'ancienne valeur, afin de faire la mise à jour des doc ori
    [F:SIV]SIHORI    = [L]WSVG2_SIHORI
    [F:SIV]SIHORINUM = [L]WSVG2_SIHORINUM
    [L]WCHANGED_SIV_SIHORI = 1
  Elsif TRTLIG="A" and [L]WSVG2_SIHORI <> 1 and [F:SIV]SIHORI<>[L]WSVG2_SIHORI
    #--Identique au premier, mais prévu pour mémoire...
    #--Exemple de cas possible :
    #--Avoir sur retour avec une ligne directe sur l'avoir
    #--1) suppression de la ligne origine retour => [M]SIHORI reste à 6 (origine Retour)
    #--2) pick d'une ligne retour
    #--3) depick de la ligne retour              => [M]SIHORI se remets à 1 (origne Directe)
    #--4) pick d'une ligne de facture            => [M]SIHORI prends la valeur 4
    [F:SIV]SIHORI    = [L]WSVG2_SIHORI
    [F:SIV]SIHORINUM = [L]WSVG2_SIHORINUM
    [L]WCHANGED_SIV_SIHORI = 1
  Endif
Endif
#--/
#----------------------------------------------------------------#
# Traitement sur un avoir sur facture                            #
#----------------------------------------------------------------#
If (TRTLIG="C" | TRTLIG="A") & [F:SIV]INVTYP=2 & [F:SIV]SIHORI = 4 & [F:SID]SIHORINUM <> ""
    Call MAJ_FACORI(TRTLIG)
Endif
#----------------------------------------------------------------#
# Traitement sur un avoir sur retour                             #
#----------------------------------------------------------------#
If (TRTLIG="C" | TRTLIG="A") & [F:SIV]INVTYP=2 & [F:SIV]SIHORI = 6
    If [F:SID]SRHNUM <> "" Call MAJ_RETORI(TRTLIG) Endif
    If [F:SID]SIHORINUM <> "" Call MAJ_FACORI(TRTLIG) Endif
Endif
#----------------------------------------------------------------#
# Traitement sur une proforma sur devis, commande ou livraison   #
#----------------------------------------------------------------#
If [F:SIV]INVTYP=5 & find([F:SIV]SIHORI,5,2,3)
#   Suppression de proforma ou suppression de ligne : raz du n°prf dans le doc origine
    If GREP="A" | (TRTLIG="A" &
&                 ([F:SIV]SIHORI=2 & !find([F:SIV]SIHORINUM, [M:SIH4]SOHNUM(0..[M:SIH4]NBLIG-1))) |
&                 ([F:SIV]SIHORI=3 & !find([F:SIV]SIHORINUM, [M:SIH4]SDHNUM(0..[M:SIH4]NBLIG-1))))
        Call MAJ_ORIPRF(TRTLIG, [F:SIV]SIHORI, [F:SIV]SIHORINUM, [F:SIV]NUM) From SUBSIHB
        If GOK < 1 : Return : Endif
    Endif
Endif
#----------------------------------------------------------------#
# Traitement sur factures et avoirs                              #
#----------------------------------------------------------------#
If [F:SIV]INVTYP < 3
    If TRTLIG = "C"  Gosub VALLIGCRE Endif
    If TRTLIG = "M"  Gosub VALLIGMOD Endif
    If TRTLIG = "A"  Gosub VALLIGANN Endif
    If GOK < 1 Return : Endif
Endif

# --> Annulation
If SIGN = -1 & TRTLIG = "A"
    If left$([F:SID]SIDTEX,3)="SID"
        Call SUP_CLOB([F:SID]SIDTEX,WRET) From TRTX3TEX
    Endif
    #----- Suppression comptes et sections de la ligne de facture -----#
    Call ENREG_ACCCCE(0,"","","","SID",0,[F:SID]NUM,[F:SID]SIDLIN,0,"","A") From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Elsif TRTLIG="M" & SIGN=-1
    # Cas particulier où on modifie le texte en le supprimant
    Local Integer WRET
    If [M:SIH4]SIDTEX(NOL)="" & left$([F:SID]SIDTEX,3)="SID"
        Call SUP_CLOB([F:SID]SIDTEX,WRET) From TRTX3TEX
    Endif
# --> Création et Modification
Elsif SIGN = +1
    #If TRTLIG="C" #Gbn-83192
    If TRTLIG="C" | (TRTLIG="M" & [M:SIH4]INIACCFLG(NOL)=2)
        #----- Ecriture des comptes et sections de la ligne de facture -----#
        Local   Char   TPLAN   (GLONCOA)(10) : # L'indice doit commencer à 0
        Raz GTCOMPTE                         : # C'est une globale et l'indice doit commencer à 0
        #----- Alimentation des comptes par évaluation de la pièce automatique -----#
        Call INIT_ACC(WTRANSAC,"SID",0,TPLAN,GTCOMPTE) From TRTVENFAC
        For I=1 To 10
            Assign "[M:SIH4]LINACC"+num$(I)+"(NOL)" With GTCOMPTE(I-1)
        Next I
    Endif
    #----- Ecriture des comptes et sections dans la table CPTANALIN -----#
#    Call ENREG_ACCCCE(nolign-1,"[V]GTCOMPTE(","","[M:SIH4]CCE","SID",
    Call ENREG_ACCCCE(nolign-1,"[M:SIH4]LINACC","","[M:SIH4]CCE","SID",
&                     0,[F:SID]NUM,[F:SID]SIDLIN,0,"",TRTLIG) From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Endif
# Maj des statistiques
#Call VALSTA("SID",SIGN) From SUBPS2
#If GOK < 1 : Return : Endif

  # -------------------------------------------------
  # Issue X3-8085/121537 - 2017-02-15 by FGR : BEGIN
  If func ASYRFNC.ACTIV("PJM") Then
    Local Integer IPJMRET

    If GREP = "M" and TRTLIG = "A" and SIGN = -1 Then
      # Only for deleted lines.
      If dim(ZPJMPSO) < 0 Then
        Local Instance ZPJMPSO Using C_TECPSO
      Endif
      If ZPJMPSO = null Then
        ZPJMPSO = NewInstance C_TECPSO AllocGroup null
      Endif
      IPJMRET = fmet ZPJMPSO.PSO_ADD_LINE("SIH", [M:SIH0]NUM, [F:SID]SIDPSONUM, [F:SID]SIDSEQNUM)
      If IPJMRET >= [V]CST_AERROR Then
        # TODO FLORENT ICI prevoir gestion erreur
      Endif
    Endif
  Endif
  # Issue X3-8085/121537 - 2017-02-15 by FGR : END
  # -------------------------------------------------

#--CPO 108164
#--On remet [F:SIV]SIHORI à la valeur du masque [M:SIH1]SIHORI
If [L]WCHANGED_SIV_SIHORI = 1
  [F:SIV]SIHORI    = [M:SIH1]SIHORI
  [F:SIV]SIHORINUM = [M:SIH1]SIHORINUM
Endif
#--/
Return


#########################################################################
#-----------------------------------------------------------------------#
# Traitement en VALLIG pour un avoir sur facture                        #
# --> Mise à jour de la facture d'origine                               #
#-----------------------------------------------------------------------#
Subprog MAJ_FACORI(TRTLIG)
Value Char    TRTLIG
Local Integer WINVCNO

If clalev([F:SIV1])=0 Local File SINVOICEV [SIV1] Endif
# --> Annulation de la ligne d'avoir : Voir si on a d'autres avoirs sur cette facture
If TRTLIG = "A"
    Gosub RECH_AVOSIV
Elsif TRTLIG="C"
    WINVCNO = 2
Endif
Readlock [SIV1] SIV0=[F:SID]SIHORINUM
If fstat = 1 GOK = -1
    GLOCK = "$SINVOICEV"-[F:SID]SIHORINUM
    Close Local File [SIV1]  : End
Elsif fstat  GOK =  0
    Call RSTA ("SIV1",[F:SID]SIHORINUM) From GLOCK
    Close Local File [SIV1]  : End
Endif
[F:SIV1]INVCNOSTA = WINVCNO
Rewrite [SIV1]
If fstat : GOK = 0 : Call FSTA("SIV1") From GLOCK : End : Endif
Close Local File [SIV1]
End
#########################################################################
#--------------------------------------------------------------------#
# Recherche si la facture d'origine a d'autres avoirs                #
#--------------------------------------------------------------------#
$RECH_AVOSIV
Local Shortint WOK
If clalev([F:SID1])=0 Local File SINVOICED [SID1] Endif

Local Char CRITERE(250)
CRITERE="BPCINV=[F:SID]BPCINV & SALFCY=[F:SID]SALFCY & SIHORINUM=[F:SID]SIHORINUM"
# En suppression avoir, on peut exclure les lignes de l'avoir en cours de suppression
If GREP="A" CRITERE -= "& NUM<>[F:SID]NUM" Endif

#Filter [SID1] Where BPCINV=[F:SID]BPCINV & SALFCY=[F:SID]SALFCY &
#&                   SIHORINUM=[F:SID]SIHORINUM
#&                   Order By Key SID1

Filter [SID1] Where evalue(CRITERE) Order By Key SID1

WOK = 1
Read [SID1]SID1 First
If fstat
# --- Plus de ligne d'avoir pour cette facture
   WOK = 0
   Goto RECH_FIN
Endif
# L'avoir lu est celui que l'on est entrain de traiter
While [F:SID1]NUM = [F:SID]NUM
   If GREP = "A"
# --- Suppression de l'avoir : on ne prend pas la ligne on lit la suivante
      Read [SID1]SID1 Next
# --- La ligne trouvée a été suprimée : on ne prend pas la ligne : on lit la suivante
#   Elsif !find([F:SID1]SIDLIN,[M:SIH4]SIDORILIN(0..[M:SIH4]NBLIG-1))
   Elsif !find([F:SID1]SIDLIN,[M:SIH4]SIDLIN(0..[M:SIH4]NBLIG-1))
      Read [SID1]SID1 Next
   Else
# --- La ligne trouvée existe toujours : on la prend
      WOK = 1 : Break
   Endif
# --- Plus de ligne pour cette avoir
   If fstat
      WOK = 0 : Break
   Endif
Wend

$RECH_FIN
If WOK = 1
    WINVCNO = 2
Else
    WINVCNO = 1
Endif

Filter [SID1]
Close Local File [SID1]

Return
#########################################################################
#-----------------------------------------------------------------------#
# Traitement en VALLIG pour un avoir sur retour                         #
# --> Mise à jour du retour d'origine                                   #
#-----------------------------------------------------------------------#
Subprog MAJ_RETORI(TRTLIG)
Value Char    TRTLIG

Readlock [SRD] SRD0=[F:SID]SRHNUM;[F:SID]SRDLIN
If fstat = 1 GOK = -1
    GLOCK = "$SRETURND"-[F:SID]SRHNUM : End
Elsif fstat  GOK =  0
    Call RSTA ("SRH",[F:SID]SRHNUM) From GLOCK : End
Endif
If TRTLIG = "A"
    Raz [F:SRD]SIHNUM, [F:SRD]SIDLIN
Elsif TRTLIG="C"
    [F:SRD]SIHNUM=[F:SID]NUM
    [F:SRD]SIDLIN=[F:SID]SIDLIN
Endif
Rewrite [SRD]
If fstat : GOK = 0 : Call FSTA("SRD") From GLOCK : End : Endif
End

#########################################################################
$VALLIGCRE
#----------------------------------#
# Traitement de VALLIG en création #
#----------------------------------#
DELTAQTY    = [F:SID]QTY
DELTAQTYSTU = [F:SID]QTYSTU

# Réalimentation du no ligne avoir pour maj stock
[M:SIH4]SIDLIN(NOL) = [F:SID]SIDLIN

If [F:SID]STOMGTCOD<>1
   # Si facture
   If [F:SIV]INVTYP=1
      If ([F:SIV]SIHORI=1 & [F:SIV]STOMVTFLG=2) | [F:SIV]SIHORI=2 |
&        ([F:SIV]SIHORI=3 & [F:SID]SDHNUM="")
         Gosub GESALL
         If GOK <= 0  Return  Endif
      Endif
   Endif
   # Si avoir avec mvt stock
   If [F:SIV]INVTYP=2 & [F:SIV]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(NOL)=2 & (find([F:SIV]SIHORI,1,4)|([F:SIV]SIHORI=6 & [F:SID]SRHNUM=""))
#&   ([F:SIV]SIHORI=1 | ([F:SIV]SIHORI=4 & [F:SID]XSIHORINUM=""))
         Gosub MAJ_STOCK From SUBSIHB
         If GOK<1 | WRET<>0 Return Endif
   Endif
Endif

# Si facture de commande et no cde renseigné
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 2 & [F:SID]SOHNUM <> ""
   Gosub MAJLIGCDE
   If GOK <= 0  Return  Endif
Endif
# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10 & [F:SID]VCRINVCNDLIN>0

   # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
   # Search extrafacturation for the update of customer balances : "on order" customer amount (ORDBPIATI,NOT in BPCUSTMVT) and line invoice update
   #                         for the update of the order linked to the schedule invoice line that is invoiced
   # This concerns old extrafacturation qtys (before the update) (read directly the table because the class is already updated)
   Call RECEXTQTY ([F:SIV]SIHORI,[F:SID]SOHNUM,[F:SID]SOPLIN,[F:SID]SOQSEQ,0,WOLDEXTQTY_NP,WOLDEXTQTY_P,WRET) From LIBSAL_INVCND_SIH
   # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)

   #--Update schedule invoice line
   Gosub MAJLIGSVIC_C From LIBSAL_INVCND_SIH

   #--Update schedule invoice line's orignal order line
   If [F:SID]VCRINVCNDTYP=10 #--Sales order line as origin of the schedule invoice line
     # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
     Gosub MAJLIGCDE_SVIC From LIBSAL_INVCND_SIH
     # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
     If GOK <= 0  Return  Endif
   Endif
Endif

# Issue 107888 - 2016-08-02 by CPO : US220 Credit note management with origin scheduled invoice invoices
If [F:SIV]INVTYP = 2 & [F:SIV]SIHORI = 4 & [F:SID]SIDORI=10 & [F:SID]VCRINVCNDTYP>0
   #--Update schedule invoice line
   Gosub MAJLIGSVIC_CN_C From LIBSAL_INVCND_SIH
Endif
# End issue 107888

# Si facture de livraison et no liv renseigné
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 3 & [F:SID]SDHNUM <> ""
   Gosub MAJLIGLIV
   If GOK <= 0  Return  Endif
Endif
Return

#########################################################################
$VALLIGMOD

#--------------------------------------------------#
# Traitement de VALLIG en modification             #
#--------------------------------------------------#
Case SIGN
 When -1 : DELTAQTY    = [M]QTY(NOL)    - [F:SID]QTY
           DELTAQTYSTU = [M]QTYSTU(NOL) - [F:SID]QTYSTU
           # Article géré en stock
           If [F:SID]STOMGTCOD<>1
              If [F:SIV]INVTYP=1
                 If ([F:SIV]SIHORI=1&[F:SIV]STOMVTFLG=2) | [F:SIV]SIHORI=2 | ([F:SIV]SIHORI=3&[F:SID]SDHNUM="")
                    Gosub GESALL
                    If GOK <= 0  Return  Endif
                 Endif
              Endif
           Endif
          # Issue 107888 - 2016-08-02 by CPO : US220 Credit note management with origin scheduled invoice invoices
          If [F:SIV]INVTYP = 2 & [F:SIV]SIHORI = 4 & [F:SID]SIDORI=10 & [F:SID]VCRINVCNDTYP>0
             #--Update schedule invoice line
             Gosub MAJLIGSVIC_CN_M_AVANT From LIBSAL_INVCND_SIH
          Endif
          # End issue 107888
 When +1 : DELTAQTY    = [M]QTY(NOL) - [M]YQTY(NOL)
           DELTAQTYSTU = [M]QTYSTU(NOL) - [M]YQTYSTU(NOL)

           If [F:SID]STOMGTCOD<>1 & DELTAQTYSTU<>0
              # Si avoir avec mvt stock (direct ou sur facture)
              If [F:SIV]INVTYP=2 & [F:SIV]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(NOL)=2 & (find([F:SIV]SIHORI,1,4)|([F:SIV]SIHORI=6 & [F:SID]SRHNUM=""))
#&               ([F:SIV]SIHORI=1 | ([F:SIV]SIHORI=4 & [F:SID]XSIHORINUM=""))
                    Gosub MAJ_STOCK From SUBSIHB
                    If GOK<1 | WRETOUR<>0 Return Endif
              Endif
           Endif

           # Si facture de commande et no cde renseigné
           If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 2 & [F:SID]SOHNUM <> ""
              If DELTAQTY <> 0
                 Gosub MAJLIGCDE
                 If GOK <= 0  Return  Endif
              Endif
           Endif
          # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
          If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10 & [F:SID]VCRINVCNDLIN>0
             # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
             # Search extrafacturation for the update of customer balances : "on order" customer amount (ORDBPIATI,NOT in BPCUSTMVT) and line invoice update
             #                         for the update of the order linked to the schedule invoice line that is invoiced
             # This concerns old extrafacturation qtys (before the update) (read directly the table because the class is already updated)
             Call RECEXTQTY ([F:SIV]SIHORI,[F:SID]SOHNUM,[F:SID]SOPLIN,[F:SID]SOQSEQ,0,WOLDEXTQTY_NP,WOLDEXTQTY_P,WRET) From LIBSAL_INVCND_SIH
             # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)

             #--Update schedule invoice line
             #TODO 107888 CPO
             Gosub MAJLIGSVIC_M From LIBSAL_INVCND_SIH

             #--Update schedule invoice line's orignal order line
             If DELTAQTY <> 0 and [F:SID]VCRINVCNDTYP=10 #--Sales order line as origin of the schedule invoice line
               # 107888 : Scheduled invoices : X3-4558 (LD:09/11/16)
               Gosub MAJLIGCDE_SVIC From LIBSAL_INVCND_SIH
               # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
               If GOK <= 0  Return  Endif
             Endif
          Endif
          # Issue 107888 - 2016-08-02 by CPO : US220 Credit note management with origin scheduled invoice invoices
          If [F:SIV]INVTYP = 2 & [F:SIV]SIHORI = 4 & [F:SID]SIDORI=10 & [F:SID]VCRINVCNDTYP>0
             #--Update schedule invoice line
             Gosub MAJLIGSVIC_CN_M From LIBSAL_INVCND_SIH
          Endif
          # End issue 107888
Endcase

Return

#########################################################################
$VALLIGANN

#--------------------------------------#
# Traitement de VALLIG en suppression  #
#--------------------------------------#
# Issue 107888 - 2016-08-02 by CPO : US220 Credit note management with origin scheduled invoice invoices
If [F:SIV]INVTYP = 2 & [F:SIV]SIHORI = 4 & [F:SID]SIDORI=10 & [F:SID]VCRINVCNDTYP>0
   #--Update schedule invoice line
   Gosub MAJLIGSVIC_CN_A From LIBSAL_INVCND_SIH
Endif
# End issue 107888

If [F:SIV]INVTYP<>1 Return Endif

DELTAQTY    = -1 * [F:SID]QTY
DELTAQTYSTU = -1 * [F:SID]QTYSTU

If [F:SID]STOMGTCOD<>1
   If [F:SIV]INVTYP=1
      If ([F:SIV]SIHORI=1 & [F:SIV]STOMVTFLG=2) | [F:SIV]SIHORI=2 |
&        ([F:SIV]SIHORI=3 & [F:SID]SDHNUM="")
         Gosub GESALL
         If GOK <= 0  Return  Endif
      Endif
   Endif
Endif

# Si facture de commande et no cde renseigné
#CPO 66740 -- Problème découvert lors de la correction de cette fiche
# -- (cas ligne fact sur cde, suppression ligne puis rajout ligne directe => Enregistrer)
# -- (la cde n'était pas mise à jour)
#If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 2 & [F:SID]SOHNUM <> ""
# 107888 : Scheduled invoices : (LD:16/06/16)
#If [F:SIV]INVTYP = 1 & [F:SID]SOHNUM <> "" & [F:SID]SDHNUM = ""
If [F:SIV]INVTYP = 1 & [F:SID]SOHNUM <> "" & [F:SID]SDHNUM = "" & [F:SIV]SIHORI<>10
# 107888 : Scheduled invoices : (LD:16/06/16)
   Gosub MAJLIGCDE
   If GOK <= 0  Return  Endif
Endif

# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10 & [F:SID]VCRINVCNDLIN>0

   # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
   # Search extrafacturation for the update of customer balances : "on order" customer amount (ORDBPIATI,NOT in BPCUSTMVT) and line invoice update
   #                         for the update of the order linked to the schedule invoice line that is invoiced
   # This concerns old extrafacturation qtys (before the update) (read directly the table because the class is already updated)
   Call RECEXTQTY ([F:SIV]SIHORI,[F:SID]SOHNUM,[F:SID]SOPLIN,[F:SID]SOQSEQ,0,WOLDEXTQTY_NP,WOLDEXTQTY_P,WRET) From LIBSAL_INVCND_SIH
   # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)

   #--Update schedule invoice line
   #TODO 107888 CPO
   Gosub MAJLIGSVIC_A From LIBSAL_INVCND_SIH

   #--Update schedule invoice line's orignal order line
   If [F:SID]VCRINVCNDTYP=10 #--Sales order line as origin of the schedule invoice line

     # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
     Gosub MAJLIGCDE_SVIC From LIBSAL_INVCND_SIH
     # 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
     If GOK <= 0  Return  Endif
   Endif
Endif


# Si facture de livraison et no liv renseigné
#CPO 66740 -- Problème découvert lors de la correction de cette fiche
# -- (cas ligne fact sur livr, suppression ligne puis rajout ligne directe => Enregistrer)
# -- (la livraison n'était pas mise à jour)
#If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 3 & [F:SID]SDHNUM <> ""
If [F:SIV]INVTYP = 1 & [F:SID]SDHNUM <> ""
   Gosub MAJLIGLIV
   If GOK <= 0  Return  Endif
Endif

# Dde 38132
# Si facture de contrat de service et no contrat renseigné et non suppression de la facture (car fait dans $ANNULE)
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 7 & [F:SID]CONNUM <> "" & GREP<>"A"
    Local Integer OKREP : OKREP = 1
    Call INVDELCON([F:SID]CONNUM, OKREP) From SUBCONB1
    If !OKREP
        GMESSAGE = mess(356, 196, 2) + [F:SID]CONNUM
        #Erreur lors de la mise à jour du contrat de service n° XXX.
        GERR = 1
        GOK=0 : Return
    Endif
Endif
# Dde 38132

Return

#########################################################################
$GESALL
#-------------------------#
# Gestion des allocations #
#-------------------------#
Local Integer WTRT, WRET, WALLTYP

# Lecture de l'article si nécessaire
If [F:ITM]ITMREF <> [F:SID]ITMREF
   Read [ITM] ITM0=[F:SID]ITMREF
   If fstat = 1 GOK = -1
      GLOCK = "$ITMMASTER"-[F:SID]ITMREF
      Return
   Elsif fstat  GOK =  0
      Call RSTA ("ITM",[F:SID]ITMREF) From GLOCK
      Return
   Endif
Endif

# Alimentation type allocation commande
WALLTYP = GALLTYP

If [F:SIV]SIHORI=2 & [F:SID]SOHNUM <> ""
   Read [SOQ] SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
   If fstat = 1 GOK = -1
      GLOCK = "$SORDERQ"-[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)
      Return
   Elsif fstat  GOK =  0
      Call RSTA ("SOQ",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
      Return
   Endif
   WALLTYP = [F:SOQ]ALLTYP
Endif

[M:ALP]VCRTYP     = 5
[M:ALP]VCRNUM     = [F:SIH]NUM
[M:ALP]VCRLIN     = [F:SID]SIDLIN
[M:ALP]VCRSEQ     = 0
[M:ALP]STOFCY     = [F:SID]STOFCY
[M:ALP]ITMREF     = [F:SID]ITMREF
# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  [M:ALP]ECCVALMAJ    = [F:SID]ECCVALMAJ
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
[M:ALP]TYPQTY     = 2
[M:ALP]BESDAT     = [F:SIV]INVDAT
Raz [M:ALP]ALLDAT, [M:ALP]DESQTY, [M:ALP]ALLQTY

Case TRTLIG
 When "C" : If [F:SIV]SIHORI=2 & [F:SID]SOHNUM <> ""
               # Avec désallocation commande origine
               WTRT = 1
               [M:ALP]VCRTYPORI  = 2
               [M:ALP]VCRNUMORI  = [F:SID]SOHNUM
               [M:ALP]VCRLINORI  = [F:SID]SOPLIN
               [M:ALP]VCRSEQORI  = [F:SID]SOQSEQ
               [M:ALP]ALLTYPORI  = WALLTYP
            Else
               # Sans désallocation commande origine
               WTRT = 0
               Raz [M:ALP]VCRTYPORI,[M:ALP]VCRNUMORI,[M:ALP]VCRLINORI
               Raz [M:ALP]VCRSEQORI,[M:ALP]ALLTYPORI
            Endif
            [M:ALP]QTY    = [F:SID]QTYSTU
            [M:ALP]MVTDES = [M:SIH4]MVTDES(NOL)
            # Mise à jour des allocations à partir de l'écran de travail STOSORW
            Call ENRSTOALL([M:SIH4]WSTOSEQ(NOL),WTRT,WRET) From STKALL
            If WRET<>0
               If GMESSAGE = "" Then             # FGR 22/08/2014 : X3SUIVI85190
                 GMESSAGE = mess(261,191,1)      # FGR 22/08/2014 : X3SUIVI85190
               Endif                             # FGR 22/08/2014 : X3SUIVI85190
               Raz GOK : Return
            Endif
 When "M" : # Sans réallocation cde origine (non traité dans cdes à fac directe)
            WTRT=0
            Raz [M:ALP]VCRTYPORI,[M:ALP]VCRNUMORI,[M:ALP]VCRLINORI
            Raz [M:ALP]VCRSEQORI,[M:ALP]ALLTYPORI
            If [F:SID]SOHNUM<>""
               If DELTAQTYSTU>0
                  # Désallocation commande origine
                  WTRT = 1
                  [M:ALP]VCRTYPORI  = 2
                  [M:ALP]VCRNUMORI  = [F:SID]SOHNUM
                  [M:ALP]VCRLINORI  = [F:SID]SOPLIN
                  [M:ALP]VCRSEQORI  = [F:SID]SOQSEQ
                  [M:ALP]ALLTYPORI  = WALLTYP
                  [M:ALP]DESQTY     = [F:SID]QTYSTU
               Endif
            Endif
            [M:ALP]QTY    = [M:SIH4]QTYSTU(NOL)
            [M:ALP]MVTDES = [M:SIH4]MVTDES(NOL)
            # Mise à jour des allocations à partir de l'écran de travail STOSORW
            Call ENRSTOALL([M:SIH4]WSTOSEQ(NOL),WTRT,WRET) From STKALL
            If WRET<>0
               If GMESSAGE = "" Then             # FGR 22/08/2014 : X3SUIVI85190
                 GMESSAGE = mess(261,191,1)      # FGR 22/08/2014 : X3SUIVI85190
               Endif                             # FGR 22/08/2014 : X3SUIVI85190
               Raz GOK : Return
            Endif
 When "A" : # Sans réallocation cde origine (non traité dans cdes à fac directe)
            WTRT = 0
            Raz [M:ALP]VCRTYPORI,[M:ALP]VCRNUMORI,[M:ALP]VCRLINORI
            Raz [M:ALP]VCRSEQORI,[M:ALP]ALLTYPORI
            [M:ALP]QTY    = 0
            [M:ALP]MVTDES = ""
            # Mise à jour des allocations à partir de l'écran de travail STOSORW
            Call ENRSTOALL(0,WTRT,WRET) From STKALL
            If WRET<>0
               If GMESSAGE = "" Then             # FGR 22/08/2014 : X3SUIVI85190
                 GMESSAGE = mess(261,191,1)      # FGR 22/08/2014 : X3SUIVI85190
               Endif                             # FGR 22/08/2014 : X3SUIVI85190
               Raz GOK : Return
            Endif
 When Default :
            Return
Endcase

Return

#########################################################################
$MAJLIGCDE
#-------------------------#
# Maj lignes de commandes #
#-------------------------#
Local  Integer  STAT, WSOQSTA
Local  Decimal  WDIFF, WALLQTY, WALLQTYSTU
Local  Decimal  WSTUSAUCOE
Local  Char     WSAU(GLONUOM)
Local  Integer  STAT, WRMN

Readlock [SOQ] SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
If fstat = 1 GOK = -1
   GLOCK = "$SORDERQ"-[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SOQ",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
   Return
Endif

Readlock [SOP] SOP0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
If fstat = 1 GOK = -1
   GLOCK = "$SORDERP"-[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SOP",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
   Return
Endif
WSAU = [F:SOP]SAU
If [F:SOP]SAUSTUCOE=0 [F:SOP]SAUSTUCOE=1 Endif
WSTUSAUCOE = 1/[F:SOP]SAUSTUCOE

# Sauvegarde de la diff. entre qte cde et fac pour maj de l'en_cde client
Raz WDIFF
WDIFF = [F:SOQ]QTY - ([F:SOQ]ODLQTY + [F:SOQ]INVQTY)

# Sauvegarde état ligne commande
WSOQSTA    = [F:SOQ]SOQSTA
# Sauvegarde qtés allouées commande
WALLQTY    = [F:SOQ]ALLQTY
WALLQTYSTU = [F:SOQ]ALLQTYSTU

# Maj quantités allouées, ruptures, à livrer
# recalcul suite à désallocation commande
If TRTLIG = "C"
   # 107888 : Scheduled invoices : (LD:10/05/16)
   If [F:SIV]SIHORI=2
   # 107888 : Scheduled invoices : (LD:10/05/16)
   # Article géré en stock
       If [F:SOQ]STOMGTCOD<>1
          [F:SOQ]ALLQTYSTU -= [M:ALP]DESQTY
          [F:SOQ]SHTQTYSTU -= [M:ALP]DESQTYSHT
       # Composé kit/sous-traité non géré en stock
       Elsif find([F:SOP]LINTYP,2,10)
          [F:SOQ]ALLQTYSTU -= min([F:SOQ]ALLQTYSTU,[M:SIH4]QTYSTU(NOL))
          [F:SOQ]SHTQTYSTU  = 0
       Endif
       Call CNVQTY([F:SOQ]ALLQTYSTU,WSTUSAUCOE,WSAU,[F:SOQ]ALLQTY) From TRTVENQTE
       Call CNVQTY([F:SOQ]SHTQTYSTU,WSTUSAUCOE,WSAU,[F:SOQ]SHTQTY) From TRTVENQTE
   # 107888 : Scheduled invoices : (LD:10/05/16)
   Else
       Raz [F:SOQ]ALLQTY, [F:SOQ]ALLQTYSTU, [F:SOQ]SHTQTY, [F:SOQ]SHTQTYSTU
   Endif
   # 107888 : Scheduled invoices : (LD:10/05/16)
   Raz [F:SOQ]TDLQTY
   Raz [F:SOQ]TDLQTYSTU
Endif

# Maj quantités allouées, ruptures
If TRTLIG="A" | TRTLIG="M"
   # 107888 : Scheduled invoices : (LD:10/05/16)
   If [F:SIV]SIHORI=2
   # 107888 : Scheduled invoices : (LD:10/05/16)
       # Si augmentation de la qté livrée d'une commande
       # recalcul suite à désallocation commande
       If DELTAQTYSTU>0
          # Article géré en stock
          If [F:SOQ]STOMGTCOD<>1
             [F:SOQ]ALLQTYSTU -= [M:ALP]DESQTY
             [F:SOQ]SHTQTYSTU -= [M:ALP]DESQTYSHT
          # Composé kit/sous-traité non géré en stock
          Elsif find([F:SOP]LINTYP,2,10)
             [F:SOQ]ALLQTYSTU -= min([F:SOQ]ALLQTYSTU,DELTAQTYSTU)
             [F:SOQ]SHTQTYSTU  = 0
          Endif
       Endif
       Call CNVQTY([F:SOQ]ALLQTYSTU,WSTUSAUCOE,WSAU,[F:SOQ]ALLQTY) From TRTVENQTE
       Call CNVQTY([F:SOQ]SHTQTYSTU,WSTUSAUCOE,WSAU,[F:SOQ]SHTQTY) From TRTVENQTE
   # 107888 : Scheduled invoices : (LD:10/05/16)
   Endif
   # 107888 : Scheduled invoices : (LD:10/05/16)
Endif

[F:SOQ]SOQSTA = 1
[F:SOQ]INVFLG = 1
# Positionnement état ligne avant maj entête
If [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU+DELTAQTYSTU >= [F:SOQ]QTYSTU
   [F:SOQ]INVFLG = 2
Endif

# Bug 52442 : Si composant kit, le statut de solde doit être le même que celui du composé
If !find([F:SOP]LINTYP,3,4,5)
    If [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU+DELTAQTYSTU >= [F:SOQ]QTYSTU
       [F:SOQ]SOQSTA = 3
    Else
       WQTY = [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU+DELTAQTYSTU
       If WQTY>0
           Call SCAL_RMN ([F:SOQ]QTYSTU, WQTY, [F:SOQ]ITMREF, WRMN, STAT) From TRTVENQTE
           If WRMN=1 [F:SOQ]SOQSTA=3 Endif
       Endif
    Endif
    If [F:SOP]LINTYP=2 WCPE_SOQSTA=[F:SOQ]SOQSTA Endif
Else
    [F:SOQ]SOQSTA=WCPE_SOQSTA
Endif

# maj entête commande (avant maj détail cde)
Gosub MAJENTCDE
If GOK = 0  Return  Endif

# Si facture validée
If [F:SIV]INVSTA = 3
   [F:SOQ]INVQTY    += DELTAQTY
   [F:SOQ]INVQTYSTU += DELTAQTYSTU
Else
   [F:SOQ]ODLQTY    += DELTAQTY
   [F:SOQ]ODLQTYSTU += DELTAQTYSTU
Endif

# Si ligne commande soldée suite à modif facture
If [F:SOQ]SOQSTA = 3
#  S'il existe encore des allocations ou des ruptures, on les suppriment
   If [F:SOQ]ALLQTY <> 0 | [F:SOQ]SHTQTY <> 0
      Call DELALL(2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,[F:SOQ]ITMREF,
&                 0,WQTY,WSHT,WRET) From STKALL
      [F:SOQ]ALLQTY    = 0
      [F:SOQ]ALLQTYSTU = 0
      [F:SOQ]SHTQTY    = 0
      [F:SOQ]SHTQTYSTU = 0
   Endif
Endif

# Récriture du détail commande (SOP)
[F:SOP]SOQSTA = [F:SOQ]SOQSTA
Rewrite [SOP]
If fstat : GOK = 0 : Call FSTA("SOP") From GLOCK : Return : Endif

# Récriture du détail commande (SOQ)
Rewrite [SOQ]
If fstat : GOK = 0 : Call FSTA("SOQ") From GLOCK : Return : Endif

#----------------------------------------------------------#
# Maj de l'en-cours pour qte allouée, en rupture et livrée #
#        [SOP] a été lu dans MAJENTCDE                     #
#----------------------------------------------------------#
If [F:SOQ]STOMGTCOD = 1 Return : Endif
Local  Decimal  WCPLQTY
Local  Char     WTRTORD : WTRTORD = "M"

## Gestion des signatures : Si la cde n'est pas si signée et pas de maj des encours si cde non signée
## Qté prévue = Reste à livrer et non la qté cdée
#If [F:SOH]APPFLG=1 & GSOHAPPORD=1 WTRTORD = "S" Endif

If [F:SOH]SOHCAT = 3
    WCPLQTY = [F:SOQ]INVQTYSTU
Else
#    WCPLQTY = [F:SOQ]ODLQTYSTU + [F:SOQ]DLVQTYSTU
    WCPLQTY = [F:SOQ]DLVQTYSTU
Endif
Gosub APPELWIP From TRTVENMAJ
If GOK<1 Return Endif

# v6 affectations
Gosub MAJ_MTO_SOQ From SALMTOLIB

#--------------
# Gestion des signatures : Si la cde n'est pas si signée et pas de maj des encours si cde non signée
# --> Il faut diminuer l'encde
If [F:SOH]APPFLG=1 & GSOHAPPORD=1 & DELTAQTYSTU<>0
    #----------------------------------------------------#
    # Maj de l'en-cde client dans les mouvements article #
    #----------------------------------------------------#
    #--- Bug 31537
    Local Char    WSENS : WSENS = "+"
    Local Decimal WSALSTOSTU :  WSALSTOSTU=DELTAQTYSTU
    If WSALSTOSTU<0
        WSALSTOSTU = WSALSTOSTU*(-1)
        WSENS   = "-"
    Endif
    Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, WSALSTOSTU, WSENS, "S", WRET) From TRTVENMAJ
    If GOK<=0  Return : Endif
Endif
#--------------

Return

#########################################################################
$MAJENTCDE
#---------------------------------------------#
# Maj entête de commande (traitement général) #
#---------------------------------------------#
Local  Char     WSENS
Local  Decimal  MNTCALC, QTECALC
Local  Decimal  WCDETTC, WCDEHT

# La ligne de commande qui est en ligne n'est pas encore maj
# (sauf [F:SOQ]SOQSTA,INVFLG,ALLQTY,ALLQTYSTU,SHTQTY,SHTQTYSTU,TDLQTY,TDLQTYSTU)

# Lecture avec lock de l'entête commande
Readlock [SOH] SOH0=[F:SID]SOHNUM
If fstat = 1 GOK = -1
   GLOCK = "$SORDER"-[F:SID]SOHNUM
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SOH",[F:SID]SOHNUM) From GLOCK
   Return
Endif
# 107888 : Scheduled invoices : X3-4558 (LD:21/11/16)
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10 & [F:SID]VCRINVCNDLIN>0
    Case TRTLIG
       When "C" : Gosub MAJENTCDE_CRE_SVIC From LIBSAL_INVCND_SIH
       When "M" : Gosub MAJENTCDE_MOD_SVIC From LIBSAL_INVCND_SIH
       When "A" : Gosub MAJENTCDE_ANN_SVIC From LIBSAL_INVCND_SIH
    Endcase
Else
    Case TRTLIG
       When "C" : Gosub MAJENTCDE_CRE
       When "M" : Gosub MAJENTCDE_MOD
       When "A" : Gosub MAJENTCDE_ANN
    Endcase
Endif
# 107888 : Scheduled invoices : X3-4558 (LD:21/11/16)

# Récriture de l'entête commande (SOH)
Rewrite [SOH]
If fstat : GOK = 0 : Call FSTA("SOH") From GLOCK : Return : Endif

# Maj mouvement client (en commande)
WSENS = "+"
If WCDETTC < 0
   WCDETTC = WCDETTC*(-1)
   WCDEHT  = WCDEHT *(-1)
   WSENS   = "-"
Endif

# 107888 : Scheduled invoices : X3-4558 (LD:09/11/16)
If WCDEHT<>0 | WCDETTC<>0
    # Maj si cde signée ou Si Paramètre maj encours client cde non signée à "Oui" et cde non intra-société
    If ([F:SOH]APPFLG>2 | GSOHAPPOST=2) & !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1)
        Call MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&                    WCDEHT, WCDETTC, WSENS, "F", "", [F:SOH]SOHCAT) From TRTBPMVT
        If GOK<1 Return Endif
    Endif
Endif
# 107888 : Scheduled invoices : X3-4558 (LD:09/11/16)

Raz WCDETTC, WCDEHT

Return

#########################################################################
$MAJENTCDE_CRE
#-------------------------------------------------#
# Maj entête de commande en création de ligne     #
#-------------------------------------------------#
# La ligne de commande qui est en ligne n'est pas encore maj
# (sauf [F:SOQ]SOQSTA,INVFLG,ALLQTY,ALLQTYSTU,SHTQTY,SHTQTYSTU,TDLQTY,TDLQTYSTU)

#-------------------------------------------------#
# Recalcul état solde                             #
#-------------------------------------------------#
# La ligne de commande n'était pas soldée, et elle le devient
If WSOQSTA <> 3 & [F:SOQ]SOQSTA = 3
   [F:SOH]CLELINNBR += 1
   If [F:SOH]CLELINNBR >= [F:SOH]LINNBR
      [F:SOH]ORDSTA = 2
   Endif
Endif

#-------------------------------------------------#
# Recalcul état allocation                        #
#-------------------------------------------------#
# Ancien cumul (alloué + en facturation + facturé)
QTECALC = WALLQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU

# 107888 : Scheduled invoices : (LD:10/05/16)
If [F:SIV]SIHORI=2
# 107888 : Scheduled invoices : (LD:10/05/16)
    If [F:SOQ]STOMGTCOD <> 1
       # Il restait quelque chose à allouer sur la ligne de commande
       If QTECALC < [F:SOQ]QTYSTU
          # Le cumul doit tenir compte de la nouvelle quantité allouée
          QTECALC = [F:SOQ]ALLQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU
          # Il n'y a plus rien à allouer sur la ligne de commande
          If QTECALC + DELTAQTYSTU >= [F:SOQ]QTYSTU
             [F:SOH]ALLLINNBR -= 1
             If [F:SOH]ALLLINNBR=0
                # La cde devient allouée
                [F:SOH]ALLSTA = 3
             Else
                # La cde devient partiellement allouée
                [F:SOH]ALLSTA = 2
             Endif
          Endif
       Endif
    Endif
# 107888 : Scheduled invoices : (LD:10/05/16)
Endif
# 107888 : Scheduled invoices : (LD:10/05/16)

# Bug 49166 : Une commande soldée est considérée comme non allouée
If [F:SOH]ORDSTA = 2 [F:SOH]ALLSTA=1 : [F:SOH]ALLLINNBR=0 Endif

#-------------------------------------------------#
# Recalcul état facturation                       #
#-------------------------------------------------#
# Ancien cumul (en facturation + facturé)
QTECALC = [F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU

If [F:SOH]INVSTA<>3 [F:SOH]INVSTA=2 Endif
# La ligne de commande n'était pas facturée
If QTECALC < [F:SOQ]QTYSTU
   # La ligne de commande devient facturée
   If QTECALC + DELTAQTYSTU >= [F:SOQ]QTYSTU
      [F:SOH]INVLINNBR += 1
      # La cde devient facturée
      If [F:SOH]INVLINNBR >= [F:SOH]LINNBR
         [F:SOH]INVSTA = 3
      Endif
   Endif
Endif

#-------------------------------------------------#
# Maj des montants à facturer HT et TTC           #
#-------------------------------------------------#
If [F:SOH]ORDSTA = 2
   [F:SOH]DLRNOT = 0
   [F:SOH]DLRATI = 0
Else
   QTECALC = [F:SID]QTY
   MNTCALC = QTECALC * [F:SOP]NETPRINOT
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]DLRNOT -= MNTCALC
   MNTCALC = QTECALC * [F:SOP]NETPRIATI
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]DLRATI -= MNTCALC
Endif
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:16/12/16)
# For direct invoice order, To invoice amounts are managed as To deliver amounts
[F:SOH]INRNOT = [F:SOH]DLRNOT
[F:SOH]INRATI = [F:SOH]DLRATI
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:16/12/16)

#-------------------------------------------------#
# Maj de l'en commande client                     #
#-------------------------------------------------#
Raz WCDEHT, WCDETTC

# Si Qté facturé > Ce qu'il restait à facturé
# alors on décrémente l'en cde de ce qu'il restait à facturer
If DELTAQTY > WDIFF
   WCDETTC = (WDIFF*[F:SOP]NETPRIATI)*(-1)
   WCDEHT  = (WDIFF*[F:SOP]NETPRINOT)*(-1)
# Si Qté facturé <= Ce qu'il restait à facturer
# alors on décrémente l'en cde de la quantité facturer
Else
   WCDETTC = (DELTAQTY*[F:SOP]NETPRIATI)*(-1)
   WCDEHT  = (DELTAQTY*[F:SOP]NETPRINOT)*(-1)
Endif

# Maj dernier no facture
[F:SOH]LASINVNUM = [F:SIV]NUM
[F:SOH]LASINVDAT = [F:SIV]INVDAT

Return

#########################################################################
$MAJENTCDE_MOD
#-------------------------------------------------#
# Maj entête de commande en modification de ligne #
#-------------------------------------------------#
# La ligne de commande qui est en ligne n'est pas encore maj
# (sauf [F:SOQ]SOQSTA,INVFLG,ALLQTY,ALLQTYSTU,SHTQTY,SHTQTYSTU,TDLQTY,TDLQTYSTU)

#-------------------------------------------------#
# Recalcul de l'état solde                        #
#-------------------------------------------------#
# La ligne de commande était soldée, et elle ne l'est plus
If WSOQSTA = 3 & [F:SOQ]SOQSTA <> 3
   [F:SOH]CLELINNBR -= 1
   [F:SOH]ORDSTA     = 1
Endif
# La ligne de commande n'était pas soldée, et elle le devient
If WSOQSTA <> 3 & [F:SOQ]SOQSTA = 3
   [F:SOH]CLELINNBR += 1
   If [F:SOH]CLELINNBR >= [F:SOH]LINNBR
      [F:SOH]ORDSTA = 2
   Endif
Endif

#-------------------------------------------------#
# Recalcul de l'état allocation                   #
#-------------------------------------------------#
QTECALC = WALLQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU

# 107888 : Scheduled invoices : (LD:10/05/16)
If [F:SIV]SIHORI=2
# 107888 : Scheduled invoices : (LD:10/05/16)
    If [F:SOQ]STOMGTCOD <> 1
       # Il n'y avait plus rien à allouer sur la ligne de commande
       If QTECALC >= [F:SOQ]QTYSTU
          # Le cumul doit tenir compte de la nouvelle quantité allouée
          QTECALC = [F:SOQ]ALLQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU
          # Il n'y a toujours rien à alloué
          If QTECALC + DELTAQTYSTU >= [F:SOQ]QTYSTU
             If [F:SOH]ALLLINNBR=0
                # La cde reste allouée
                [F:SOH]ALLSTA = 3
             Else
                # La cde reste partiellement allouée
                [F:SOH]ALLSTA = 2
             Endif
          # Il y a maintenant une quantité à allouer sur la ligne de commande
          Else
             [F:SOH]ALLLINNBR += 1
             If [F:SOH]ALLLINNBR>=[F:SOH]LINNBR
                # La cde devient non allouée
                [F:SOH]ALLSTA = 1
             Else
                # La cde devient partiellement allouée
                # On ne sait pas déterminer si la cde devient partiellement allouée ou non allouée
                # (Si aucune autre ligne gérée en stock, la cde est non allouée)
                [F:SOH]ALLSTA = 2
             Endif
          Endif
       # Il restait quelque chose à allouer sur la ligne de commande
       Else
          # Le cumul doit tenir compte de la nouvelle quantité allouée
          QTECALC = [F:SOQ]ALLQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU
          # Il reste toujours une quantité à allouer
          If QTECALC + DELTAQTYSTU < [F:SOQ]QTYSTU
             If [F:SOH]ALLLINNBR>=[F:SOH]LINNBR
                # La cde reste non allouée
                [F:SOH]ALLSTA = 1
             Else
                # La cde reste partiellement allouée
                [F:SOH]ALLSTA = 2
             Endif
          # Il n'y a plus rien à allouer sur la ligne de commande
          Else
             [F:SOH]ALLLINNBR -= 1
             If [F:SOH]ALLLINNBR=0
                # La cde devient allouée
                [F:SOH]ALLSTA = 3
             Else
                # La cde devient partiellement allouée
                [F:SOH]ALLSTA = 2
             Endif
          Endif
       Endif
    Endif
# 107888 : Scheduled invoices : (LD:10/05/16)
Endif
# 107888 : Scheduled invoices : (LD:10/05/16)

# Bug 49166 : Une commande soldée est considérée comme non allouée
If [F:SOH]ORDSTA = 2 [F:SOH]ALLSTA=1 : [F:SOH]ALLLINNBR=0 Endif

#-------------------------------------------------#
# Recalcul de l'état facture                      #
#-------------------------------------------------#
# Ancien cumul (en facturation + facturé)
QTECALC = [F:SOQ]ODLQTYSTU + [F:SOQ]INVQTYSTU

# La ligne de commande était facturée
If QTECALC >= [F:SOQ]QTYSTU
   # La ligne de commande n'est plus facturée
   If QTECALC + DELTAQTYSTU < [F:SOQ]QTYSTU
      [F:SOH]INVLINNBR -= 1
      If [F:SOH]INVLINNBR=0
         # La cde devient non facturée
         [F:SOH]INVSTA = 1
      Else
         # La cde devient partiellement facturée
         [F:SOH]INVSTA = 2
      Endif
   Endif
   # Si plus de lignes facturées en totalité, y en a t-il qui le sont partiellement?
   # Permet de recalculer l'état de la commande (partiellement facturée)
   If [F:SOH]INVLINNBR = 0
      For [SID1]SID1 Where BPCINV=[F:SOH]BPCINV & SALFCY=[F:SOH]SALFCY & SOHNUM=[F:SOQ]SOHNUM
         If [F:SID1]NUM<>[F:SID]NUM | [F:SID1]SIDLIN<>[F:SID]SIDLIN
            [F:SOH]INVSTA=2 : Break
         Endif
      Next
   Endif
# La ligne de commande n'était pas facturée
Else
   # La ligne de commande devient facturée
   If QTECALC + DELTAQTYSTU >= [F:SOQ]QTYSTU
      [F:SOH]INVLINNBR += 1
      If [F:SOH]INVLINNBR>=[F:SOH]LINNBR
         # La cde devient facturée
         [F:SOH]INVSTA = 3
      Else
         # La cde devient partiellement facturée
         [F:SOH]INVSTA = 2
      Endif
   Endif
Endif

#-------------------------------------------------#
# Maj des montants à livrer HT et TTC             #
#-------------------------------------------------#
# Ecart entre qte cde et qte facture de la ligne cde
ECARTQTY = [F:SOQ]QTY - ([F:SOQ]INVQTY + [F:SOQ]ODLQTY)
If [F:SOH]ORDSTA = 2
   [F:SOH]DLRNOT = 0
   [F:SOH]DLRATI = 0
Else
   If ECARTQTY > 0
      If DELTAQTY < ECARTQTY
         QTECALC = DELTAQTY
      Else
         QTECALC = ECARTQTY
      Endif
   Else
      If DELTAQTY < ECARTQTY
         QTECALC = DELTAQTY-ECARTQTY
      Else
         QTECALC = 0
      Endif
   Endif
   MNTCALC = QTECALC * [F:SOP]NETPRINOT
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]DLRNOT -= MNTCALC
   MNTCALC = QTECALC * [F:SOP]NETPRIATI
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]DLRATI -= MNTCALC
Endif
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:16/12/16)
# For direct invoice order, To invoice amounts are managed as To deliver amounts
[F:SOH]INRNOT = [F:SOH]DLRNOT
[F:SOH]INRATI = [F:SOH]DLRATI
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:16/12/16)

#-------------------------------------------------#
# Maj de l'en commande client                     #
#-------------------------------------------------#
Raz WCDEHT, WCDETTC

# Diminution de la qte facturée
If DELTAQTY < 0
   # Si la ligne cde n'était pas soldée, on annule ce qu'il restait à facturer
   If WSOQSTA <> 3  WDIFF = 0  Endif
   # Si diminution qte facturée < (qte fac-qte cde) de la cde, pas de maj
   If WDIFF > 0 | (WDIFF <= 0 & [F:SID]QTY > WDIFF*(-1))
      # Augmentation de l'en cde
      If (WDIFF - DELTAQTY) > 0
         WCDETTC = (WDIFF-DELTAQTY) * [F:SOP]NETPRIATI
         WCDEHT  = (WDIFF-DELTAQTY) * [F:SOP]NETPRINOT
      Endif
   Endif
# Augmentation de la qte facturée
Else
   # La ligne cde n'était pas soldée (pas de maj si la ligne était soldée)
   If WSOQSTA <> 3
      # Si Qté facturée en plus > Ce qu'il restait à facturer
      # alors on décrémente l'en cde de ce qu'il restait à facturer
      If DELTAQTY > WDIFF
         WCDETTC = (WDIFF*[F:SOP]NETPRIATI)*(-1)
         WCDEHT  = (WDIFF*[F:SOP]NETPRINOT)*(-1)
      # Si Qté facturée en plus <= Ce qu'il restait à facturer
      # alors on décrémente l'en cde de la quantité facturée en plus
      Else
         WCDETTC = (DELTAQTY*[F:SOP]NETPRIATI)*(-1)
         WCDEHT  = (DELTAQTY*[F:SOP]NETPRINOT)*(-1)
      Endif
   Endif
Endif
Return

#########################################################################
$MAJENTCDE_ANN
#-------------------------------------------------#
# Maj entête de commande en annulation de ligne   #
#-------------------------------------------------#
# La ligne de commande qui est en ligne n'est pas encore maj
# (sauf [F:SOQ]SOQSTA,INVFLG,ALLQTY,ALLQTYSTU,SHTQTY,SHTQTYSTU,TDLQTY,TDLQTYSTU)

#-------------------------------------------------#
# Recalcul de l'état solde                        #
#-------------------------------------------------#
# La ligne de commande était soldée, et elle ne l'est plus
If WSOQSTA = 3 & [F:SOQ]SOQSTA <> 3
   [F:SOH]CLELINNBR -= 1
   [F:SOH]ORDSTA     = 1
Endif

#-------------------------------------------------#
# Recalcul de l'état allocation                   #
#-------------------------------------------------#
# Ancien cumul (alloué + en facturation + facturé)
QTECALC = WALLQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU

# 107888 : Scheduled invoices : (LD:10/05/16)
If [F:SIV]SIHORI=2
# 107888 : Scheduled invoices : (LD:10/05/16)
    If [F:SOQ]STOMGTCOD <> 1
       # Il n'y avait plus rien à allouer sur la ligne de commande
       If QTECALC >= [F:SOQ]QTYSTU
          # Le cumul doit tenir compte de la nouvelle quantité allouée
          QTECALC = [F:SOQ]ALLQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU
          # Il n'y a toujours rien à alloué
          If QTECALC + DELTAQTYSTU >= [F:SOQ]QTYSTU
             If [F:SOH]ALLLINNBR=0
                # La cde reste allouée
                [F:SOH]ALLSTA = 3
             Else
                # La cde reste partiellement allouée
                [F:SOH]ALLSTA = 2
             Endif
          # Il y a maintenant une quantité à allouer sur la ligne de commande
          Else
             [F:SOH]ALLLINNBR += 1
             If [F:SOH]ALLLINNBR>=[F:SOH]LINNBR
                # La cde devient non allouée
                [F:SOH]ALLSTA = 1
             Else
                # La cde devient partiellement allouée
                # On ne sait pas déterminer si la cde devient partiellement allouée ou non allouée
                # (Si aucune autre ligne gérée en stock, la cde est non allouée)
                [F:SOH]ALLSTA = 2
             Endif
          Endif
       Endif
    Endif
# 107888 : Scheduled invoices : (LD:10/05/16)
Endif
# 107888 : Scheduled invoices : (LD:10/05/16)

#-------------------------------------------------#
# Recalcul de l'état facture                      #
#-------------------------------------------------#
# Ancien cumul (en facturation + facturé)
QTECALC = [F:SOQ]ODLQTYSTU + [F:SOQ]INVQTYSTU
# La ligne de commande était facturée
If QTECALC >= [F:SOQ]QTYSTU
   # La ligne de commande n'est plus facturée
   If QTECALC + DELTAQTYSTU < [F:SOQ]QTYSTU
      [F:SOH]INVLINNBR -= 1
      If [F:SOH]INVLINNBR=0
         # La cde devient non facturée
         [F:SOH]INVSTA = 1
      Else
         # La cde devient partiellement facturée
         [F:SOH]INVSTA = 2
      Endif
   Endif
Endif

# Si plus de lignes facturées en totalité, y en a t-il qui le sont partiellement?
# Permet de recalculer l'état de la commande (partiellement facturées)
If [F:SOH]INVLINNBR = 0
   For [SID1]SID1 Where BPCINV=[F:SOH]BPCINV & SALFCY=[F:SOH]SALFCY &
&                       SOHNUM=[F:SOQ]SOHNUM
      If [F:SID1]NUM<>[F:SID]NUM | [F:SID1]SIDLIN<>[F:SID]SIDLIN
         [F:SOH]INVSTA=2 : Break
      Endif
   Next
Endif

#-------------------------------------------------#
# Maj des montants à livrer HT et TTC             #
#-------------------------------------------------#
If [F:SOH]ORDSTA = 2
   [F:SOH]DLRNOT =0
   [F:SOH]DLRATI =0
Else
   QTECALC = [F:SID]QTY
   If ([F:SOQ]INVQTY + [F:SOQ]ODLQTY) > [F:SOQ]QTY
      QTECALC = QTECALC - ([F:SOQ]INVQTY+[F:SOQ]ODLQTY-[F:SOQ]QTY)
   Endif
   MNTCALC = QTECALC * [F:SOP]NETPRINOT
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]DLRNOT += MNTCALC
   MNTCALC = QTECALC * [F:SOP]NETPRIATI
   Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
   [F:SOH]DLRATI += MNTCALC
Endif
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:16/12/16)
# For direct invoice order, To invoice amounts are managed as To deliver amounts
[F:SOH]INRNOT = [F:SOH]DLRNOT
[F:SOH]INRATI = [F:SOH]DLRATI
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:16/12/16)

#-------------------------------------------------#
# Maj de l'en commande client                     #
#-------------------------------------------------#
Raz WCDEHT, WCDETTC

If WSOQSTA <> 3  WDIFF = 0  Endif

# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
## Si qte facturée supprimée < (qte fac-qte cde) de la cde, pas de maj
#If WDIFF > 0 | (WDIFF <= 0 & [F:SID]QTY > WDIFF*(-1))
#   WCDETTC = ([F:SID]QTY + WDIFF) * [F:SOP]NETPRIATI
#   WCDEHT  = ([F:SID]QTY + WDIFF) * [F:SOP]NETPRINOT
#Endif
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10 & [F:SID]VCRINVCNDLIN>0
    # Si qte facturée supprimée < (qte fac-qte cde) de la cde, pas de maj
    # For Scheduled invoice [F:SID]QTY may contain extra facturation
    # We can't take into account this one to update credit customer so we take DELTAQTY (which doesn't contain extra facturation)
    If WDIFF > 0 | (WDIFF <= 0 & DELTAQTY*(-1) > WDIFF*(-1))
       WCDETTC = (DELTAQTY*(-1) + WDIFF) * [F:SOP]NETPRIATI
       WCDEHT  = (DELTAQTY*(-1) + WDIFF) * [F:SOP]NETPRINOT
    Endif
Else
    # Si qte facturée supprimée < (qte fac-qte cde) de la cde, pas de maj
    If WDIFF > 0 | (WDIFF <= 0 & [F:SID]QTY > WDIFF*(-1))
       WCDETTC = ([F:SID]QTY + WDIFF) * [F:SOP]NETPRIATI
       WCDEHT  = ([F:SID]QTY + WDIFF) * [F:SOP]NETPRINOT
    Endif
Endif
# 107888 : Scheduled invoices : X3-4558 (LD:22/11/16)
#-------------------------------------------------#
# Recherche dernière facture de la commande       #
#-------------------------------------------------#
If GREP<>"A" | (GREP="A" & [F:SOH]SOHNUM<>SVGSOHNUM)
   SVGSOHNUM=[F:SOH]SOHNUM
   Call RECH_DERFACSOH() From SUBSIHB
Endif

Return

#########################################################################
$MAJLIGLIV
Local Integer NOL : NOL = nolign-1
Local Decimal WLIVTTC : Raz WLIVTTC    : # Bug 73534

#-------------------------------------------------#
# Facture de livraison                            #
#-------------------------------------------------#
Read [SDD] SDD0=[F:SID]SDHNUM;[F:SID]SDDLIN
If fstat = 1 GOK = -1
   GLOCK = "$SDELIVERYD"-[F:SID]SDHNUM-num$([F:SID]SDDLIN)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SDD",[F:SID]SDHNUM-num$([F:SID]SIDLIN)) From GLOCK
   Return
Endif

WLIVTTC = [F:SID]QTY * [F:SDD]NETPRIATI

# Bug 73534
# --> Maj mouvement client (livré non facturé)
# Si livraisons de prêt, on facture ce qui n'est pas retourné
# Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
# --> On facture Qté livrée-Qté retournée : Calcul livré non facturé et Maj à la ligne
If TRTLIG="C"
    If [F:SDH]LND=2 | GDLVRTNCNO=1
        Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&                   0, WLIVTTC, "-", "D", "",  [F:SDH]LND) From TRTBPMVT
        If GOK<1 Return Endif
    Endif
Endif
# Bug 73534

#CPO 66740 -- Pb découvert lors du traitement de cette fiche
# -- La mise à jour de l'entête de la livraison facturée doit se faire uniquement en cas de suppression
# -- En création de ligne, la mise à jour est faite dans $CREATION (le code ci-dessous écrasait cette dernière)
If TRTLIG="A" :#CPO 66740
   # Mise à jour Livraison (6.2)
  Readlock [SDH]SDH0=[F:SID]SDHNUM
  If fstat = 1 : GOK = -1
     GLOCK = "$SDELIVERY"-[F:SID]SDHNUM
  Elsif fstat : GOK =  0
     Call RSTA ("SDH",[F:SID]SDHNUM) From GLOCK
  Else
    [F:SDH]INVFLG = 1
    Raz [F:SDH]SIHNUM
    Raz [F:SDH]INVORN
    # --> Maj mouvement client (livré non facturé)
    # Bug 46937
    # Si livraisons de prêt, on facture ce qui n'est pas retourné
    # Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
    # --> On facture Qté livrée-Qté retournée : Calcul livré non facturé à la ligne
    # Si livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
    # --> On facture tte la Qté livrée        :
    # --> Calcul et maj à l'entête si suppression facture  (dans $ANNULE)
    # --> Calcul et maj à la ligne si modification facture avec suppression liv (impossible dans $MODIF)
    If (GREP="A" & ([F:SDH]LND=2 | GDLVRTNCNO=1)) | GREP="M"                         : # Bug 73534
      If [F:SDH]LND=1 & GDLVRTNCNO=2 WLIVTTC = [F:SDD]QTY * [F:SDD]NETPRIATI Endif   : # Bug 73534
      Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&                   0, WLIVTTC, "+", "D", "",  [F:SDH]LND) From TRTBPMVT
    Endif                                                                            : # Bug 73534
    Rewrite [SDH]
    If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK :  Endif
  Endif
Endif

If [F:SID]SOHNUM="" | ![F:SID]SOPLIN | ![F:SID]SOQSEQ
   Return
Endif

#-------------------------------------------------#
# Maj ligne commande si livraison non directe     #
#-------------------------------------------------#
Readlock [SOQ] SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
If fstat = 1 GOK = -1
   GLOCK = "$SORDERQ"-[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SOQ",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
   Return
Endif

WINVFLG = [F:SOQ]INVFLG
[F:SOQ]INVQTY    += DELTAQTY
[F:SOQ]INVQTYSTU += DELTAQTYSTU

# Maj de l'état de la ligne
If [F:SOQ]INVQTY < [F:SOQ]DLVQTY
   [F:SOQ]INVFLG = 1
# Elle est soldée et tout ce qui est livré est facturé : Elle devient facturée
Elsif [F:SOQ]SOQSTA=3 & [F:SOQ]INVQTY>=([F:SOQ]DLVQTY + [F:SOQ]ODLQTY)
   [F:SOQ]INVFLG = 2
Endif

#-------------------------------------------------------------------#
# MAJ entête cde ssi cde normale                                    #
# Si toutes les zones sont à 0    : C'est une cde normale           #
# Si Au - une zone est renseignée : On verifie la catégorie de cde  #
#-------------------------------------------------------------------#
If (![F:SOQ]YEA & ![F:SOQ]MON & ![F:SOQ]DLVDAY & ![F:SOQ]WEE) |
&  ([F:SOQ]YEA | [F:SOQ]MON | [F:SOQ]DLVDAY | [F:SOQ]WEE)
    Gosub MAJENTCDELIV
Endif

# Récriture du détail commande (SOQ)
Rewrite [SOQ]
If fstat : GOK = 0 : Call FSTA("SOQ") From GLOCK : Return : Endif
Return

#########################################################################
$MAJENTCDELIV
#-------------------------------------------------------------------#
# Maj entête commande si pas cde ouverte (avant maj détail cde)     #
#-------------------------------------------------------------------#
# Lecture avec lock de l'entête commande
Readlock [SOH] SOH0=[F:SID]SOHNUM
If fstat = 1 GOK = -1
   GLOCK = "$SORDER"-[F:SID]SOHNUM
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SOH",[F:SID]SOHNUM) From GLOCK
   Return
Endif
If [F:SOH]SOHCAT = 4 Unlock [SOH] : Return : Endif

# La ligne de commande était facturée
If WINVFLG = 2
   # Elle ne l'est plus
   If [F:SOQ]INVFLG <> 2
      [F:SOH]INVLINNBR -= 1
      If [F:SOH]INVLINNBR = 0
         #CPO 66740 -- NOK à partir d'ici car le invlinnbr ne tient pas compte des factures partielles !!!
         # -- Avant de remettre INVSTA à 1 il faut voir s'il n'y a pas d'autres factures partielles
         #[F:SOH]INVSTA = 1
         #Raz [F:SOH]LASINVNUM
         #Raz [F:SOH]LASINVDAT
         If GREP<>"A" | (GREP="A" & [F:SOH]SOHNUM<>SVGSOHNUM)
           SVGSOHNUM=[F:SOH]SOHNUM
           Call RECH_DERFACSOH From SUBSIHB
         Endif
         # -- Si pas d'autres factures partielles (ou sur d'autres lignes de la cdes...)
         If [F:SOH]LASINVNUM<>""
           [F:SOH]INVSTA = 2
         Else
           # -- Pas d'autres factures sur la commande
           [F:SOH]INVSTA = 1
           Raz [F:SOH]LASINVDAT
         Endif
         #fin CPO
      Else
         [F:SOH]INVSTA = 2
      Endif
   Endif
# La ligne de commande n'était pas facturée, maintenant elle l'est
Elsif [F:SOQ]INVFLG = 2
   [F:SOH]INVLINNBR += 1
   If [F:SOH]INVLINNBR >= [F:SOH]LINNBR
      [F:SOH]INVSTA = 3
   Else
      [F:SOH]INVSTA = 2
   Endif
#CPO 66740
# -- La ligne de cde n'était pas facturée, et elle ne l'est,PEUT-ETRE, tjs pas COMPLETEMENT  !!!
Else
  # -- Le comportement est différent selon que l'on soit en Modification/Annulation ou pas
  If GREP="M" | GREP="A"
    If ([F:SOH]SOHNUM<>SVGSOHNUM)
      SVGSOHNUM=[F:SOH]SOHNUM
      Call RECH_DERFACSOH From SUBSIHB
    Endif
    # -- Si pas d'autres factures partielles (ou totales portant sur d'autres lignes de la cdes...)
    If [F:SOH]LASINVNUM<>""
      [F:SOH]INVSTA = 2
    Else
      # -- Pas d'autres factures sur la commande
      [F:SOH]INVSTA = 1
      Raz [F:SOH]LASINVDAT
    Endif
  Else
    # -- Nous sommes dans le cas d'une ligne qui n'était pas facturée (totalement) et ne l'est tjs pas
    # (le INVSTA est soit Oui soit Non, donc il faut envisager une facturation partielle)
    [F:SOH]INVSTA=2
  Endif
#fin CPO
Endif

If [F:SOH]INVSTA <> 1
   #CPO 66740 -- après suppression d'un fact d'une ligne de cde livrée partiellement, la maj n'est pas faite...
   #If GREP<>"A" | (GREP="A" & [F:SOH]SOHNUM=SVGSOHNUM) :# CPO : Pourquoi le code ici est <> de celui MAJENTCDE_ANN ???
   If GREP<>"A" | (GREP="A" & [F:SOH]SOHNUM<>SVGSOHNUM)
      SVGSOHNUM=[F:SOH]SOHNUM :#CPO 66740 -- l'idée est de ne pas refaire l'appel si on est sur la même cde ?
      Call RECH_DERFACSOH From SUBSIHB
   Endif
Endif

# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15772 (LD:20/12/16)
If [F:SOH]SOHCAT <> 2
    If [F:SOH]INVSTA = 3
        #  --> La commande est facturée
        [F:SOH]INRNOT = 0
        [F:SOH]INRATI = 0
    Else
        # Décrémentation du reste à facturer
        Local Decimal WQTY, WMNTCALC : # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15772 (LD:20/12/16)

        Read [SOP] SOP0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
        If fstat
           GOK =  0
           Call RSTA ("SOP",[F:SID]SOHNUM-num$([F:SID]SOPLIN)-num$([F:SID]SOQSEQ)) From GLOCK
           Return
        Endif
        If GDLVRTNCNO=1
            # Pas de facturation des qtés retournées
            # Le reste à facturer doit également être décrémenté de ce qui a été retourné
            WQTY= [F:SID]QTY+[F:SDD]RTNQTY
        Else
            # Facturation des qtés retournées
            WQTY= [F:SID]QTY
        Endif
        If TRTLIG="A" | GREP="A"
            If [F:SOQ]INVQTY=0
                # Cas de surlivraison et donc de surfacturation
                # Suppression dernière facture : Ne pas tenir compte de la qté surfacturé
                WQTY = WQTY - ([F:SOQ]ODLQTY+[F:SOQ]DLVQTY-[F:SOQ]QTY)
            Endif
            WQTY = -1 * WQTY
        Endif
        WMNTCALC  =  WQTY * [F:SOP]NETPRINOT
        Call ARRDEV (WMNTCALC, [F:SOH]CUR) From TRTDIV
        [F:SOH]INRNOT -= WMNTCALC
        WMNTCALC  =  WQTY * [F:SOP]NETPRIATI
        Call ARRDEV (WMNTCALC, [F:SOH]CUR) From TRTDIV
        [F:SOH]INRATI -= WMNTCALC
        # Cas de surlivraison et donc de surfacturation
        # Le reste à facturer ne doit pas passer en négatif ou être < reste à facturer échéancier
        If [F:SOH]INRNOT < [F:SOH]INRSCHNOT [F:SOH]INRNOT=[F:SOH]INRSCHNOT Endif
        If [F:SOH]INRATI < [F:SOH]INRSCHATI [F:SOH]INRATI=[F:SOH]INRSCHATI Endif
    Endif
Endif
# 107888 : Scheduled invoices : New fields 'To invoice' - X3-15772 (LD:20/12/16)


# Récriture de l'entête commande (SOH)
Rewrite [SOH]
If fstat : GOK = 0 : Call FSTA("SOH") From GLOCK : Return : Endif

Return

#########################################################################
$VERIF_CRE
#########################################################################
If OK=0 Return Endif : # Bug 49634 : Si positionné par le spécifique, inutile de continuer
Gosub VERIF
Return

#########################################################################
$CREATION
#########################################################################
Local Integer RELANCE, I, WINVORN
Local Char    TYPACT(1), WSDHNUM(GLONVCR)
Local Decimal WLIVTTC : Raz WLIVTTC
Local Integer WRET

#----------------------------------------------------------------#
# French anti-fraud law - last check                             #
#----------------------------------------------------------------#
If find(GREP,"C","D") & [F:SIV]INVSTA = 3 & func FRADSILIB.DSFRA("SIH", [F:SIV]CPY)
  GMESSAGE = mess(560,192,1)
  GOK = 0
Endif
#----------------------------------------------------------------#
#----------------------------------------------------------------#
# Création de l'enregistrement SIH                               #
#----------------------------------------------------------------#
# BRBAN 105200#US2 Updating invoice
If func AFNC.ACTIV("INVCA")>0
  If [F:TSV]INVCAN=2
    If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0
      Readlock [F:ISIH]SIH0 = [F:SIV]SIHORINUM
      If !fstat
        [F:ISIH]REVCANSTA = 1
        Rewrite [F:ISIH]
        If fstat>0 : Call FSTA("ISIH") From GLOCK : GOK=0 : Endif
      Else
        GMESSAGE=mess(7,7712,1)
        GOK=0
      Endif
      Unlock [F:ISIH]
      [F:SIH]REVCANSTA=2
    Endif
  Endif
Endif
If GOK < 1 : Return : Endif
#-

Gosub CRE_SIH
If GOK < 1 : Return : Endif
#----------------------------------------------------------------#
# Création des enregistrements sans SVCRVAT et SVCRFOOT          #
#----------------------------------------------------------------#
Call UPD_VALORISATION ("C","SIH") From TRTVENFACC
If GOK < 1 : Return : Endif
#----------------------------------------------------------------#
# Creation des lignes de facture                                 #
#----------------------------------------------------------------#
Gosub CREATION From TABLEAUX
If GOK < 1 : Return : Endif
#----------------------------------------------------------------#
# Creation des enr. analytiques des elts de facturation          #
#----------------------------------------------------------------#
# ACA
[M:SIHV]VCRTYP=4 : [M:SIHV]NUM = [M:SIH0]NUM
Gosub CREMOD_DIE_FOOT From SUBSIHV
If GOK < 1 : Return : Endif

# Issue 117773 - 2016-07-27 by ERMIL : Check for valid invoice elements for SST prior to commit and making calls
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  Call VALIDATE_INV_ELEM From TRTTAXUSA
  If GERR=1 : GOK = 0 : Return : Endif
Endif

#----------------------------------------------------------------#
# Creation des echeances pour les factures                       #
#----------------------------------------------------------------#
# A voir pour les imports
If ([F:SIV]INVTYP <> 5 & !GIMPORT) | (dim(GWLECH)>0 & GWLECH=2)
    Call CRE_ECHEANCES From TRTVENFACC
    If GOK < 1 : Return : Endif
Endif

# Issue 117130 - 2016-06-22 by ERMIL : Move webservice calls out of transactions
# 78411 Sage Exchange
#If !GIMPORT & [M:SIH1]SIHORI<>1 & [M:SIH0]INVTYP<>5
#  If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([M:SIH2]PTE)
#    Local Integer OLDVCRTYP,NEWVCRTYP
#    Case [F:SIV]SIHORI
#      When 2 : OLDVCRTYP = 2 : NEWVCRTYP=5   # Order
#      When 3 : OLDVCRTYP = 4 : NEWVCRTYP=5   # Shipment
#      When 4 : OLDVCRTYP = 5 : NEWVCRTYP=18  # Invoice
#      When 6 : OLDVCRTYP = 6 : NEWVCRTYP=18  # Return
#    Endcase
#    If OLDVCRTYP>0
#      Call TRANSFER(OLDVCRTYP,[F:SIV]SIHORINUM,NEWVCRTYP,[F:SIV]NUM,WRET) From SEPPLIB
#      If WRET : Raz GOK : Return : Endif
#    Endif
#  Endif
#Endif

#----------------------------------------------------------------#
# Maj des livraisons de la facture                               #
#----------------------------------------------------------------#
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 3
   For I=0 To [M]NBLIG-1
      # --> Mise à jour de l'entête livraison si elle existe et si non traitée
      If [M:SIH4]SDHNUM(I) <> "" & [M:SIH4]SDHNUM(I) <> WSDHNUM
         Readlock [SDH] SDH0=[M:SIH4]SDHNUM(I)
         If fstat = 1 GOK = -1
            GLOCK = "$SDELIVERY"-[M:SIH4]SDHNUM(I)
            Break
         Elsif fstat  GOK =  0
            Call RSTA ("SDH",[M:SIH4]SDHNUM(I)) From GLOCK
            Break
         Endif
         [F:SDH]INVFLG = 2
         [F:SDH]SIHNUM = [F:SIV]NUM
         WINVORN      += 1
         [F:SDH]INVORN = WINVORN
         # --> Maj mouvement client (livré non facturé)
         # Bug 46937
         # Si livraisons de prêt, on facture ce qui n'est pas retourné
         # Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
         # --> On facture Qté livrée-Qté retournée : Calcul livré non facturé et Maj mouvement client (Bug 73534) à la ligne
         # Si livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
         # --> On facture tte la Qté livrée        : Livré non facturé = Montant de la livraison : Maj à l'entête
         If [F:SDH]LND=1 & GDLVRTNCNO=2     : # Bug 73534
            WLIVTTC=[F:SDH]DLVATI           : # Bug 73534
            Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&                         0, WLIVTTC, "-", "D", "", [F:SDH]LND) From TRTBPMVT
            If GOK<1 Break Endif
         Endif                              : # Bug 73534
         Rewrite [SDH]
         If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK : Break : Endif
         WSDHNUM = [M:SIH4]SDHNUM(I)
      Endif
   Next
Endif
#----------------------------------------------------------------#
# Pour les proforma : Maj du n° prf ds devis, cdes, liv          #
#----------------------------------------------------------------#
If [F:SIV]INVTYP = 5 & [F:SIV]SIHORINUM <> ""
    TYPACT="C" : Call MAJ_ORIPRF(TYPACT, [F:SIV]SIHORI, [F:SIV]SIHORINUM, [F:SIV]NUM) From SUBSIHB
    If GOK < 1 : Return : Endif
Endif
#----------------------------------------------------------------#
# Mise à jour des mouvements clients pour factures et avoirs     #
# --> Montant facturé non comptabilisé                           #
#----------------------------------------------------------------#
Local Char    SENS(1)
Local Char    WTYPMVC(1) # FGR 06/08/2009 : X3SUIVI57009
Local Date    WDATMVT
## VPO 02/07/09 49168 pb sur generation auto des factures de ddes de services qui simule import
##              les maj doivent se faire dans $CREATION de SUBSIHA
##If !GIMPORT
If [F:SIV]INVSTA<3
  If [F:SIV]INVTYP <> 5
      WDATMVT = [F:SIV]INVDAT
      If [F:SIV]INVTYP = 1
          SENS = "+"  :    # Facture
          WTYPMVC = "I"    # FGR 06/08/2009 : X3SUIVI57009 Facture
      Else            :
          SENS = "-"  :    # Avoir
          WTYPMVC = "N"    # FGR 06/08/2009 : X3SUIVI57009 Avoir
          If [F:SIV]SIHORI = 4 WDATMVT = [F:SIV]SIHORIDAT : Endif
      Endif
      Local Decimal WCOURS : WCOURS=0
      If [F:SIH]RATDIV(GTYPGEN-1)<>0 WCOURS=arr([F:SIH]RATMLT(GTYPGEN-1)/[F:SIH]RATDIV(GTYPGEN-1), 10^-GDECRCU) : Endif
#      Call  MAJMVC ([F:SIV]BPCINV, [F:SIV]CUR, [F:SIH]CURTYP, WCOURS, WDATMVT, [F:SIV]NUM, [F:SIV]SALFCY,
#&                   0, [F:SIH]AMTATI, SENS,  "I", "", 0) From TRTBPMVT
      Call  MAJMVC ([F:SIV]BPCINV, [F:SIV]CUR, [F:SIH]CURTYP, WCOURS, WDATMVT, [F:SIV]NUM, [F:SIV]SALFCY,
&                   0, [F:SIH]AMTATI, SENS,  WTYPMVC, "", 0) From TRTBPMVT   # FGR 06/08/2009 : X3SUIVI57009

      If GOK<1 Return Endif
  Endif
Endif
# Maj des statistiques
#Call VALSTA("SIH",1) From SUBPS2
#If GOK < 1 : Return : Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) c'est mieux dans la transaction
