        GERR=1:GMESSAGE=mess(76,192,1): OK=0 : Return
    Endif
Endif
#-----------------------------------------#
# Chargement des elements de controle     #
# suivant reglements effectues en compta. #
#-----------------------------------------#
# hb le 23/12/98 : les échéances existent même si l'on n'a pas les tiers
# If [F:SIV]INVTYP = 1 & GMODU(3)=2
If [F:SIV]INVTYP <> 5
    Call INFOECHE(1,[F:SIH]NUM,[M:SIH0]AMTMIN,[M:SIH0]AMTTMP) From SUBBIH
Endif

Gosub LEC_SIH
If OK = 0 Return : Endif
Gosub NEW_FACTURE From TRTVENFACC
Gosub NEW_REGIME  From TRTVENFACC
If [M:SIH4]NBLIG>0
  For NOL=1 To [M:SIH4]NBLIG
    [M:SIHX]LIGNE=NOL : Gosub PLUS_LIGNE From TRTVENFACC
  Next NOL
Endif
If [F:SIV]INVTYP = 1
    [M:SIH0]OST -= [F:SIH]AMTATI
Elsif [F:SIV]INVTYP = 2
    [M:SIH0]OST += [F:SIH]AMTATI
Endif
Return

#########################################################################
$AVANT_MODFIC
#########################################################################
Local Char    SENS(1)
Local Char    WTYPMVC(1) # FGR 06/08/2009 : X3SUIVI57009
Local Date    WDATMVT
Local Integer SPSTAT
Local Decimal COURS

  # Lecture SINVOICE pour être bien repositionné et pour maj l'enregistrement
  Readlock [SIH] SIH0=[M:SIH0]NUM
  If fstat=1  GOK=-1 : GLOCK="$SINVOICE"-[M:SIH0]NUM : Return
  Elsif fstat GOK=0  : Call RSTA("SIH",[M:SIH0]NUM) From GLOCK : Return : Endif

  If [M:SIH1]INVSTA <> 3 Then  # X3SUIVI102034 : Ne le faire que sur un document non validé
    MODFAC=9
    If [F:SIV]INVTYP <> 5 & [F:SIV]INVTYP <> 3
      #    ----------------------------------------------------#
      #    Traitement avant modification                       #
      #     --> Déduction des mouvements clients               #
      #         Déduction du montant facturé non comptabilisé  #
      #    ----------------------------------------------------#
      WDATMVT = [F:SIV]INVDAT
      If [F:SIV]INVTYP = 1
        SENS = "-"  :    # Facture
        WTYPMVC = "I"    # FGR 06/08/2009 : X3SUIVI57009 Facture
      Else
        SENS = "+"  :    # Avoir
        WTYPMVC = "N"    # FGR 06/08/2009 : X3SUIVI57009 Avoir
        If [F:SIV]SIHORI = 4 WDATMVT = [F:SIV]SIHORIDAT : Endif
      Endif
      Local Decimal WCOURS : WCOURS=0
      If [F:SIH]RATDIV(GTYPGEN-1)<>0 WCOURS=arr([F:SIH]RATMLT(GTYPGEN-1)/[F:SIH]RATDIV(GTYPGEN-1), 10^-GDECRCU) : Endif
      #    Call  MAJMVC ([F:SIV]BPCINV, [F:SIV]CUR, [F:SIH]CURTYP, WCOURS, WDATMVT, [F:SIV]NUM, [F:SIV]SALFCY,
      #&                 0, [F:SIH]AMTATI, SENS,  "I", "", 0) From TRTBPMVT
      Call  MAJMVC ([F:SIV]BPCINV, [F:SIV]CUR, [F:SIH]CURTYP, WCOURS, WDATMVT, [F:SIV]NUM, [F:SIV]SALFCY,
&                 0, [F:SIH]AMTATI, SENS,  WTYPMVC, "", 0) From TRTBPMVT   # FGR 06/08/2009 : X3SUIVI57009
      If GOK<1 Return Endif
      #   ----------------------------------------------------#
      #   Recherche du type de modifications                  #
      #   effectuées sur la facture pour echeances            #
      #   ----------------------------------------------------#
      If  [M:SIH1]BPRPAY<>[F:SIH]BPRPAY | [M:SIH0]BPCINV<>[F:SIH]BPR
&     | [M:SIH2]BPRSAC<>[F:SIH]BPRSAC | [M:SIH0]CUR<>[F:SIH]CUR
&     | [M:SIH2]STRDUDDAT<>[F:SIH]STRDUDDAT | [M:SIH2]PTE<>[F:SIH]PTE
&     | [M:SIH0]SALFCY<>[F:SIH]FCY
&     | (dim([M:SIH2]BPRFCT) > 0 & [M:SIH2]BPRFCT<>[F:SIH]BPRFCT)
&     | [F:SIH]AMTATI <> [M:SIHV]INVATI
&     | [F:SIH]DEP <> [M:SIH2]DEP | [F:SIH]RATDIV(0) <> [M :SIH2]RATDIV(0) | [F:SIH]RATMLT(0) <> [M :SIH2]RATMLT(0)
&     | (dim([M:SIH2]UMRNUM)>0 & [M:SIH2]UMRNUM <> [F:SIH]UMRNUM)  : # 87923 : Gestion des prélèvements SDD
        #&     | [F:SIH]DEP <> [M:SIH2]DEP | [F:SIH]RATDIV(0) <> [M :SIH2]RATDIV(0) | [F:SIH]RATMLT(0) <> [M :SIH2]RATMLT(0) # FGR 25/01/2010 : X3SUIVI61823
        MODFAC = 1
        #    Elsif [F:SIH]AMTATI <> [M:SIHV]INVATI             : # Bug 25805
        #      MODFAC = 0                                      : # Bug 25805
      Else
        MODFAC = 9
      Endif
    Endif

    Raz MODDAT
    If [M:SIH0]INVDAT<>[F:SIV]INVDAT
      MODDAT=1
      SVGINVDAT=[F:SIV]INVDAT
    Endif

    # Maj des statistiques
    #Call VALSTA("SIH",-1) From SUBPS2
    #If GOK < 1 : Return : Endif

    # Si modification de la date, forcage de la modif sur les lignes
    If !find(GREP,"C","D") & [F:SIV]INVDAT <> [M:SIH0]INVDAT
      Local Integer NLIG
      For NLIG=0 To [M]NBLIG-1
        [M]UPDFLG(NLIG) = 1
      Next NLIG
    Endif
    #----- Suppression des échéances de la facture si modif rubrique majeure -----#
    If MODFAC=1
      If clalev([F:DUD])<=0 : Local File GACCDUDATE [DUD] : Endif
      Local Char CRITSUPPR (250)
      CRITSUPPR="TYP='"+[F:SIH]GTE+"' & NUM='"+[F:SIH]NUM+"'"
      Call HISTOSUPPR (CRITSUPPR) From MODECHE : If GOK<1  Return : Endif
      Delete [DUD] Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM
      If fstat=1  GOK=-1 : GLOCK="$GACCDUDATE"-[F:SIH]GTE-[F:SIH]NUM : Return : Endif
      # Close Local File [DUD]
    Endif
    Default File [SIV]

    # Cas particulier où on modifie le texte en le supprimant
    Local Integer WRET
    If [M:SIH0]SIHTEX1="" & left$([F:SIV]SIHTEX1,3)="SIV"
      Call SUP_CLOB([F:SIV]SIHTEX1,WRET) From TRTX3TEX
    Endif
    If [M:SIH0]SIHTEX2="" & left$([F:SIV]SIHTEX2,3)="SIV"
      Call SUP_CLOB([F:SIV]SIHTEX2,WRET) From TRTX3TEX
    Endif
  Endif

  If dim([M:SIH1]WRHE)>0
     [M:SIH1]WRHE = [F:SIH]WRHE
  Endif

  #CPO 66740 -- Problème découvert lors de la correction de cette fiche
  # -- voir commentaires de $INIMOD
  #Local Integer WSVG_SIHORI    : WSVG_SIHORI=[F:SIV]SIHORI : # Bug 62408
  #Local Char    WSVG_SIHORINUM(GLONVCR) : WSVG_SIHORINUM=[F:SIV]SIHORINUM : # Bug 62408

  #--CPO 108164
  #--Lors de la correction du 66740, j'avais géré le cas SIHORI=1 vers SIHORI<>1, mais cela a induit un effet de bord sur
  #--le cas du 108164 : SIHORI<>1 vers SIHORI=1
  #--Dans $VALLIG : Il faut positionner le [SIV]SIHORI avec le WSVG2_SIHORI, dans certains cas seulement
  #--,étant donné que VALLIG vient après le INIMOD et que le [F:SIV]=[M:SIHx] est fait à ce moment
  #--Nous avons quand même besoin des anciennes valeurs, même si pas sytématiquement utilisées...(voir VALLIG)
  #--Nous sommes en modification. Cas possibles :
  #--Passage d'un SIHORI<> 1 à un SIHORI = 1 (cas du bug 108164)
  #--Passage d'un SIHORI = 1 à un SIHORI<> 1 (cas du bug 66740 il faut mettre à jour les doc ori, mais si utilisation de la SVG, cela ne se fait plus!!)
  #--Passage d'un SIHORI<> 1 à un SIHORI<> 1 (mais différents : avoir sur fact qui devient avoir sur retour..peu probable car listes picking bien gérées)
  Local Integer WSVG2_SIHORI             : WSVG2_SIHORI    = [F:SIV]SIHORI
  Local Char    WSVG2_SIHORINUM(GLONVCR) : WSVG2_SIHORINUM = [F:SIV]SIHORINUM
  #--/
Return

#########################################################################
$VERIF_MOD
#########################################################################
#-----------------------#
# Verification en modif #
#-----------------------#
If OK=0 Return Endif : # Bug 49634 : Si positionné par le spécifique, inutile de continuer
# Si modif d'un avoir il faut relire l'enregistrement
# ==> on pointe sur les mêmes fichiers ds picking des factures et la clé peut être cassée
If [M:SIH0]INVTYP=2
    Read [SIV] SIV0=[M:SIH0]NUM
    If fstat OK = 0
    Else     OK = 1
    Endif
    Gosub LEC_SIH
    If OK = 0 Return : Endif
Endif
Gosub VERIF
Return
#########################################################################
$ANNULELIV
Local Char WSDHNUM(GLONVCR)
Local Integer I
#-------------------------------------------------------#
# Traitement particulier pour les factures de livraison #
#-------------------------------------------------------#
For I=0 To [M]NBLIG-1
# --> Mise à jour de l'entête livraison si elle existe et si non traitée
    If [M:SIH4]SDHNUM(I) <> "" & [M:SIH4]SDHNUM (I) <> WSDHNUM
        Readlock [SDH] SDH0=[M:SIH4]SDHNUM(I)
        If fstat = 1 GOK = -1
           GLOCK = "$SDELIVERY"-[M:SIH4]SDHNUM(I)
           Break
        Elsif fstat  GOK =  0
           Call RSTA ("SDH",[M:SIH4]SDHNUM(I)) From GLOCK
           Break
        Endif
        [F:SDH]INVFLG = 1
        Raz [F:SDH]SIHNUM
        Raz [F:SDH]INVORN
        # --> Maj mouvement client (livré non facturé)
        # Bug 46937
        # Si livraisons de prêt, on facture ce qui n'est pas retourné
        # Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
        # --> On facture Qté livrée-Qté retournée : Calcul livré non facturé à la ligne
        # Si livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
        # --> On facture tte la Qté livrée        : Livré non facturé = Montant de la livraison : Maj à l'entête
        If [F:SDH]LND=1 & GDLVRTNCNO=2        : # Bug 73534
            WLIVTTC=[F:SDH]DLVATI             : # Bug 73534
            Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&                        0, WLIVTTC, "+", "D", "",  [F:SDH]LND) From TRTBPMVT
            If GOK<1 Break Endif
        Endif                                 : # Bug 73534
        Rewrite [SDH]
        If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK : Break : Endif
        WSDHNUM = [M:SIH4]SDHNUM(I)
    Endif
Next
Return
#########################################################################
#########################################################################
$MODIF
#########################################################################
Local Integer I
Local Char    WSDHNUM(GLONVCR)
Local Decimal WLIVTTC : Raz WLIVTTC

#----------------------------------------------------------------#
# Modification de l'enregistrement SIH                           #
#----------------------------------------------------------------#
Gosub MOD_SIH
If GOK < 1 : Return : Endif

If [M:SIH1]INVSTA <> 3
    #----------------------------------------------------------------#
    # Modification des enregistrements sans SVCRVAT et SVCRFOOT      #
    #----------------------------------------------------------------#
    Call UPD_VALORISATION ("M","SIH") From TRTVENFACC
    If GOK<1 Return Endif
    #----------------------------------------------------------------#
    # Maj des livraisons de la facture                               #
    #----------------------------------------------------------------#
    If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 3
       For I=0 To [M]NBLIG-1
          If [M:SIH4]CREFLG(I)=0
             # --> Mise à jour de l'entête livraison si elle existe et si non traitée
             If [M:SIH4]SDHNUM(I) <> "" & [M:SIH4]SDHNUM(I) <> WSDHNUM
                Readlock [SDH] SDH0=[M:SIH4]SDHNUM(I)
                If fstat = 1 GOK = -1
                   GLOCK = "$SDELIVERY"-[M:SIH4]SDHNUM(I)
                   Break
                Elsif fstat  GOK =  0
                   Call RSTA ("SDH",[M:SIH4]SDHNUM(I)) From GLOCK
                   Break
                Endif
                [F:SDH]INVFLG = 2
                [F:SDH]SIHNUM = [F:SIV]NUM
#               [F:SDH]INVORN = on ne sait pas le gérer
                # Bug 73534
                # --> Maj mouvement client (livré non facturé)
                # Si livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
                # --> On facture tte la Qté livrée        : Livré non facturé = Montant de la livraison : Maj à l'entête
                If [F:SDH]LND=1 & GDLVRTNCNO=2     : # Bug 73534
                    Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&                                 0, [F:SDH]DLVATI, "-", "D", "", [F:SDH]LND) From TRTBPMVT
                    If GOK<1 Break Endif
                Endif                              : # Bug 73534
                Rewrite [SDH]
                If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK : Break : Endif
                WSDHNUM = [M:SIH4]SDHNUM(I)
             Endif
          Endif
       Next
    Endif
Endif

#----------------------------------------------------------------#
# Modification des lignes de factures                            #
#----------------------------------------------------------------#
Gosub MODIF From TABLEAUX
If GOK < 1 : Return : Endif

If [M:SIH1]INVSTA=3 Return Endif

# Réalimentation origine et no origine
# recalculé après la maj des lignes (on test SIHORI ds VALLIG s'il est déjà remis à 1 on est eu !)
Call RECH_ORINUM From SUBSIHB
Update [SIV] Where NUM=[M:SIH0]NUM With SIHORINUM=[M:SIH1]SIHORINUM, SIHORI=[M:SIH1]SIHORI, SIHORIDAT=[M:SIH1]SIHORIDAT
If fstat GOK=0 : Call FSTA("SIV") From GLOCK : Endif
#----------------------------------------------------------------#
# Modification des enr. analytiques des elts de facturation      #
#----------------------------------------------------------------#
[M:SIHV]VCRTYP=4 : [M:SIHV]NUM = [M:SIH0]NUM # ACA
Gosub CREMOD_DIE_FOOT From SUBSIHV
If GOK < 1 : Return : Endif

# Issue 117773 - 2016-07-27 by ERMIL : Check for valid invoice elements for SST prior to commit and making calls
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2
  Call VALIDATE_INV_ELEM From TRTTAXUSA
  If GERR=1 : GOK = 0 : Return : Endif
Endif

#----------------------------------------------------------------#
# Modification des echeances pour les factures                   #
#----------------------------------------------------------------#
# hb le 23/12/98 : les échéances existent même si l'on n'a pas les tiers
# If [F:SIV]INVTYP = 1 & GMODU(3) = 2
# Voir pour les imports
If [F:SIV]INVTYP <> 5
#   --- Ajustement des échéances en fonction des modifications effectuées -----#
    If MODFAC<>9
      If clalev([F:DUD])<=0 : Local File GACCDUDATE [DUD] : Endif
      Filter [DUD] Where TYP=[M:SIH0]GTE & NUM=[M:SIH0]NUM
      Read [DUD]DUD0 First : If fstat Raz [F:DUD] : Endif
      Filter [DUD]
      If [F:DUD]TYP="" & [F:DUD]NUM=""
        Call CRE_ECHEANCES From TRTVENFACC
        If GOK<1 Return : Endif
      Else
        Call MODECHE(1,[F:SIH]NUM,[F:SIH]AMTATI,MODFAC,MODECH) From SUBBIH
        If GOK<1 Return : Endif
      Endif
#     Close Local File [DUD]
      Default File [SIV]
    Endif
Endif

Local Char SENS(1)
Local Char WTYPMVC(1) # FGR 06/08/2009 : X3SUIVI57009
Local Date WDATMVT
If [F:SIV]INVTYP <> 5
#   ----------------------------------------------------------------#
#   Mise à jour des mouvements clients pour factures et avoirs     #
#   --> Montant facturé non comptabilisé                           #
#   ----------------------------------------------------------------#
    WDATMVT = [F:SIV]INVDAT
    If [F:SIV]INVTYP = 1
        SENS = "+"    :    # Facture
        WTYPMVC = "I"      # FGR 06/08/2009 : X3SUIVI57009 Facture
    Else
        SENS = "-"    :    # Avoir
        WTYPMVC = "N"      # FGR 06/08/2009 : X3SUIVI57009 Avoir
        If [F:SIV]SIHORI = 4 WDATMVT = [F:SIV]SIHORIDAT : Endif
    Endif
    Local Decimal WCOURS : WCOURS=0
    If [F:SIH]RATDIV(GTYPGEN-1)<>0 WCOURS=arr([F:SIH]RATMLT(GTYPGEN-1)/[F:SIH]RATDIV(GTYPGEN-1), 10^-GDECRCU) : Endif
#    Call  MAJMVC ([F:SIV]BPCINV, [F:SIH]CUR, [F:SIH]CURTYP, WCOURS, WDATMVT, [F:SIV]NUM, [F:SIV]SALFCY,
#&           0, [F:SIH]AMTATI, SENS,  "I", "", 0) From TRTBPMVT
    Call  MAJMVC ([F:SIV]BPCINV, [F:SIH]CUR, [F:SIH]CURTYP, WCOURS, WDATMVT, [F:SIV]NUM, [F:SIV]SALFCY,
&           0, [F:SIH]AMTATI, SENS,  WTYPMVC, "", 0) From TRTBPMVT   # FGR 06/08/2009 : X3SUIVI57009
    If GOK<1 Return Endif
Endif

# Maj des statistiques
#Call VALSTA("SIH",1) From SUBPS2
#If GOK < 1 : Return : Endif

Gosub DEVERROU_PICKING

#--CPO 79343
If GSIHSUPPLIGDSP>0
  Call MESSAGE(mess(251,191,1)) From GESECRAN
  Raz GSIHSUPPLIGDSP
Endif
#--/CPO

# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
If [F:SIV]INVTYP = 1 & [F:SIV]SIHORI = 10
   #--Update schedule invoice line
   #TODO 107888 CPO
   Gosub MODIF_UPDATE_SVIC From LIBSAL_INVCND_SIH
Endif
# End issue 107888

# Issue 107888 - 2016-08-02 by CPO : US220 Credit note management with origin scheduled invoice invoices
If [F:SIV]INVTYP = 2 & [F:SIV]SIHORI = 4
   #--Update schedule invoice line
   Gosub MODIF_CN_UPDATE_SVIC From LIBSAL_INVCND_SIH
Endif
# End issue 107888

  # -------------------------------------
  # FGR 22/08/2014 : X3SUIVI71986 (début)
  Call UPDATE_SOH_LASINV From SUBSIHA1
  If GOK < 1 Then
    Return
  Endif
  # FGR 22/08/2014 : X3SUIVI71986 (fin)
  # -------------------------------------
  # -------------------------------------------------
  # Issue X3-8085/121537 - 2017-02-15 by FGR : BEGIN
  Gosub PJM_OPPOR_PSO From SUBSOHA1
  # Issue X3-8085/121537 - 2017-02-15 by FGR : END
  # -------------------------------------------------
Return

#########################################################################
$APRES_MOD
#########################################################################
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

# Dde 38132
If !GIMPORT
    #MAE, bg 77405
    Gosub VERROU_HAE
    #-----------------------------------------------------------------------#
    # Mise à jour du contrat de service associé à la facture CRM 24-11-2000 #
    #-----------------------------------------------------------------------#
    If [M:SIH0]INVTYP=1 & [M:SIH1]SIHORI=7
       Local Integer ICON
       Local Integer OKREP : OKREP = 1
       For ICON = 0 To [M:SIH4]NBLIG - 1
          If [M:SIH4]CONNUM(ICON) <> "" & [M:SIH4]CREFLG(ICON)=0
             Call INVCPTCON([M:SIH4]CONNUM(ICON), 0, OKREP) From SUBCONB1
             If !OKREP
                #Erreur lors de la mise à jour du contrat de service n° XXX.
                GMESSAGE = mess(356, 196, 2) + [M:SIH4]CONNUM(ICON)
                GERR = 1 : Return
             Endif
          Endif
       Next
    Endif
Endif
# Dde 38132

#-----impression de la facture -----#
#If !GIMPORT
If !GIMPORT and !GWEBSERV Then         # FGR 12/02/2015 : X3SUIVI105667
   If WSLTDOCFLG=2 & [F:SIH]STA<2
      Gosub SET_CLE From GOBJSUB
      CLECUR = 1
      If [M:SIH0]DOCNAM<>""
         [L]REPORT1=[M:SIH0]DOCNAM
      Elsif WSLTDOCNAM<>""
         [L]REPORT1=WSLTDOCNAM
      Endif
      Call ETAT([L]REPORT1,"GESSIH",TBPAR,TBVAL) From ETAT
   Endif
Endif

#--------------------------------------------------------------------#
# Gestion des points                                  CRM 24.09.2003 #
#--------------------------------------------------------------------#
Local Integer IERRINF
#LSE 21/03/2005 rajout 2 paramètres
Local Integer ICHAPTER
Local Integer IBRETOUR
IERRINF = 0
ICHAPTER= 0
IBRETOUR= 1

# FGR 11/10/2007 : X3SUIVI43412 ajout de l'appelant
Call INVPOINT("SUBSIHA", [M:SIH0]NUM, IERRINF, ICHAPTER, IBRETOUR ) From TRTPOINT
If IERRINF
    GMESSAGE = mess(IERRINF, ICHAPTER, 2)
    GERR = 1
Endif

# Si avoir avec mouvement de stock
If  !GIMPORT & [M:SIH0]INVTYP=2 & [M:SIH1]STOMVTFLG=2 & sum([M:SIH4]RTNSTOUPD) > [M:SIH4]NBLIG
    # Vide la table de travail de la gestion des emplacements
    Local Integer WRET
    Call STKDELRES(0,[M:SIH1]STOFCY,"",WRET) From STKLOC
    # -- Impression des étiquettes -----#
    If GSLTPRNCOD1>1
        Local Char WPARAM(GLONVCR)(1..3) , WVALEUR(10)
        WPARAM(1) = [M:SIH1]STOFCY
        WPARAM(2) = num$(18)
        WPARAM(3) = [M:SIH0]NUM
        Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Endif
Endif

If !GIMPORT
# Maintenant, on fait toujours un gosub RELIT
    Gosub RELIT From GOBJSUB
    [M:SIH0]NUM = [F:SIV]NUM
Else
    Raz [M:SIH4]PFMTOT
    Raz [M:SIH0]DSPTOTWEI, [M:SIH0]DSPTOTVOL, [M:SIH0]DSPTOTQTY
    Gosub LIENS From TABLEAUX
Endif

# Issue 117130 - 2016-06-20 by ERMIL : Move WS calls outside of database transactions
Gosub RECALC_SST

# 78411 Sage Exchange
Gosub SEPP_SIH_MOD From SEPPLIB2 #122614 - JOBRO

#122614 - JOBRO
#If func AFNC.ACTIV("SEPP") & [M:SIH0]INVTYP<>5
#  Local Integer SEVCRTYP
#  If !clalev([F:SEU]) : Local File SEAUTH [SEU] : Endif
#  If find([M:SIH0]INVTYP,2,4) : SEVCRTYP = 18 : Else : SEVCRTYP = 5 : Endif
#  If func SEPPLIB.SEPP_DOC([M:SIH2]PTE)
#    Call AUTH_CHK(SEVCRTYP,[F:SIV]NUM,GERR,GMESSAGE) From SEPPLIB
#    If GERR
#      If [F:SEU]MANAUT=2 : Call MESSAGE(mess(48,2092,1)) From GESECRAN : Endif
#      GOK=0 : Return
#    Endif
#    If !func SEPPCDT.SEPP_OK(SEVCRTYP,[F:SIV]NUM,1)
#      Call CALL_SEAUTH(SEVCRTYP,[F:SIV]NUM) From TRTSEAUTH
#    Endif
#  Elsif func SEPPCDT.SEPP_OK(5,[F:SIV]NUM,1)
#    Local Integer SERR
#    Local Char    SEMESSAGE(150)
#    Call VOID_ALL(SEVCRTYP,[F:SIV]NUM,SERR,SEMESSAGE) From SEPPLIB
#    If SERR : Call ERREUR (SEMESSAGE) From GESECRAN : Endif
#  Endif
#Endif
#122614 - JOBRO

#-----------------------------#
# Suivant modif de la facture #
# retour sur les echeances    #
#-----------------------------#
# hb le 23/12/98 : les échéances existent même si l'on n'a pas les tiers
# If [F:SIV]INVTYP = 1 & MODECH=2 & GMODU(3)=2
# A voir pour les imports
If [F:SIV]INVTYP = 1 & MODECH=2
   If !GIMPORT
       Call ECHEANCE(1,[F:SIH]NUM,OK) From SUBBIH
   Else
      # Attention les échéances ont été modifiées
      # Veuillez les valider par le bouton Echéances
      Call MESSAGE(mess(62,119,1)+"\"+mess(63,119,1)) From GESECRAN
   Endif
Endif
Affzo [M:SIH4]1-99


Return

