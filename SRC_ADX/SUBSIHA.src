##########################################################################################################
#--------------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la facture                 #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramètres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char    PARAM2(GLONADP)
Local  Integer WOK
# --- Chargement des globales référenciels, comptes et sections de la société  #
Call GETCPY(GFCY,"SLT",5,GFLAG) From TRTX3CPT
# 106867.sn
If func AFNC.ACTIV("LTA")
  Gosub GET_CPY_SSTTAXACT From TRTTAXSST
Endif
# 106867.en
# --- Si changement société -----#
If GSOC_UPDFLG
    # --- Chargement des paramètres de localisation
    # --- Etalement des prestations
    If func AFNC.ACTIV("KIT")
       Call PARAML(GFCY,"ITAPRE",PARAM2) From ADOVAL
        GLOCITAPRE=val(PARAM2)
        If GLOCITAPRE>0  GLOCITAPRE-=1 : Endif
    Else
        Raz GLOCITAPRE
    Endif
    #-----
    If func AFNC.ACTIV("SVC") | GLOCITAPRE
      #----- Dates et période prestation ligne -----#
      If GSLTSVCDATCODD=1
        #----- Saisi -----#
        If GLOCITAPRE
          If [M:SIH1]INVSTA=3 : # Facture validée     : Dates et Périodicité affichées
            GSIH_FMTPER(0)="DZzP:"+GFMDAT
            GSIH_FMTPER(1)="DZzP:"+GFMDAT
            GSIH_FMTPER(2)="NP+:4#"
            GSIH_FMTPER(3)="NP:1#"
          Else                : # Facture non validée : Dates et Périodicité saisissables
            GSIH_FMTPER(0)="DZz:"+GFMDAT
            GSIH_FMTPER(1)="DZz:"+GFMDAT
            GSIH_FMTPER(2)="N+:4#"
            GSIH_FMTPER(3)="N:1#"
          Endif
        Else
          GSIH_FMTPER(0)="DZz:"+GFMDAT : # Dates saisissables
          GSIH_FMTPER(1)="DZz:"+GFMDAT
          GSIH_FMTPER(2)="-N+:4#"      : # Périodicité invisible
          GSIH_FMTPER(3)="-N:1#"
        Endif
      Elsif GSLTSVCDATCODD=2
        #----- Affiché -----#
        GSIH_FMTPER(0)="DZzP:"+GFMDAT : # Dates affichées
        GSIH_FMTPER(1)="DZzP:"+GFMDAT
        #-----
        If GLOCITAPRE
          GSIH_FMTPER(2)="NP+:4#"     : # Périodicité affichée
          GSIH_FMTPER(3)="NP:1#"
        Else
          GSIH_FMTPER(2)="-N+:4#"     : # Périodicité invisible
          GSIH_FMTPER(3)="-N:1#"
        Endif
      Else
        #----- Invisible -----#
        GSIH_FMTPER(0)="-DZz:"+GFMDAT : # Dates et Périodicité invisibles
        GSIH_FMTPER(1)="-DZz:"+GFMDAT
        GSIH_FMTPER(2)="-N+:4#"
        GSIH_FMTPER(3)="-N:1#"
      Endif
      #----- Dates prestation entête -----#
      If dim([M:SIH2]STRDATSVC)>0
        #----- Saisi -----#
        If !GLOCITAPRE & GSLTSVCDATCOD=1    : # Dates saisies
          GSIH_FMTPER(4)="DZz:"+GFMDAT
          GSIH_FMTPER(5)="DZz:"+GFMDAT
        #----- Affiché -----#
        Elsif !GLOCITAPRE & GSLTSVCDATCOD=2 : # Dates affichées
          GSIH_FMTPER(4)="DZzP:"+GFMDAT
          GSIH_FMTPER(5)="DZzP:"+GFMDAT
        #----- Invisible -----#
        Else                             : # Dates invisibles
          GSIH_FMTPER(4)="-DZz:"+GFMDAT
          GSIH_FMTPER(5)="-DZz:"+GFMDAT
        Endif
        Affzo [SIH2]STRDATSVC, ENDDATSVC
      Endif
    Else                                 : # Dates et périodicités invisibles
      GSIH_FMTPER(0)="-DZz:"+GFMDAT
      GSIH_FMTPER(1)="-DZz:"+GFMDAT
      GSIH_FMTPER(2)="-N+:4#"
      GSIH_FMTPER(3)="-N:1#"
      #-----
      If dim([M:SIH2]STRDATSVC)>0
        GSIH_FMTPER(4)="-DZz:"+GFMDAT
        GSIH_FMTPER(5)="-DZz:"+GFMDAT
        Affzo [SIH2]STRDATSVC, ENDDATSVC
      Endif
    Endif
    # --- Numérotation Argentine
    If func AFNC.ACTIV("KAG")
        Call PARAML(GFCY,"ARGNUM",PARAM2) From ADOVAL
        GLOCARGNUM=val(PARAM2)
        If GLOCARGNUM>0  GLOCARGNUM-=1 : Endif
    Else
      Raz GLOCARGNUM
    Endif
    # --- Utilisation systeme de taxe
# 106867.so
#    If func AFNC.ACTIV("KUS")
#        Call PARAML(GFCY,"USATAX",PARAM2) From ADOVAL
#        GLOCUSATAX=val(PARAM2)
#        If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
#    Else
#      Raz GLOCUSATAX
#    Endif
# 106867.eo

    # 87923 : Gestion des prélèvements SDD
    If func AFNC.ACTIV("SDD")
        Call PARAML(GFCY,"SDDMGT",PARAM2) From ADOVAL
        GSDDMGT=val(PARAM2)
    Endif
    # 87923 : Gestion des prélèvements SDD

    # Localisation argentine : Pour la numérotation, recherche du type de document lié aux factures/avoirs
    If GLOCARGNUM Gosub REC_ARGNUM_TYPDOC From TRTVENFAC : If GERR=1 Return Endif : Endif

    # --- Lecture de la table des compteurs
    Call LECTCA(5,WOK) From SUBTCA
    If fstat | !WOK
        GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : Return
    Endif
Endif
#--- Suppression factures non validées
Call PARAML(GFCY,"SIVSUP",PARAM2) From ADOVAL
GSIVSUP = val(PARAM2)
#--- Ligne à 0 interdites
Call PARAML(GFCY,"SIVNULL",PARAM2) From ADOVAL
GSIVNULL = val(PARAM2)
#--- Code taxe exonéré
Call PARAML(GFCY,"EXETAX",PARAM2) From ADOVAL
GEXETAX  = PARAM2
#--- Arrondi de TVA
Call PARAML(GFCY,"VATRND",PARAM2) From ADOVAL
GVATRND  = val(PARAM2)
#--- Suppression factures non validées
Call PARAML(GFCY,"SIVCFM",PARAM2) From ADOVAL
GSIVCFM = val(PARAM2)
# V6.2 : Certification
#--- Contrôle date documents
Call PARAML(GFCY,"CTLDATORI",PARAM2)    From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GCTLDATORI=val(PARAM2)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif
#--- Prix / Montant HT/TTC                    : # 82808 : Modification champ PRITYP
Call PARAML(GFCY,"NOTATI",PARAM2) From ADOVAL : # 82808
GNOTATI = val(PARAM2)                         : # 82808

# 87923 : Gestion des prélèvements SDD
If func AFNC.ACTIV("SDD")
    Call DISPLAY_UMRNUM ([M:SIH0]INVTYP) From TRTVENSDD
Endif
# 87923 : Gestion des prélèvements SDD

  # FGR 28/11/2011 : X3SUIVI71065
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)

If func AFNC.ACTIV("KSP")  # SAM 112149 Spanish XML signature -Hide or not METCOR field
  Gosub CTL_METCOR From SUBSIHA1
Endif                      #End SAM 112149

#X3-107954 (LCC-19/09/18) Add an icon on sales invoices Valuation tab
#If GSIHVALLIG=2 or ACTION="LIENS"#X3-112251 (LCC-10/10/18) Variable NON-EXISTENT ACTION
If GSIHVALLIG=2 or (dim(ACTION)>0 & ACTION="LIENS")
  Chgfmt [M:SIHV]VALUATION With "-K:3X"
Else
  Chgfmt [M:SIHV]VALUATION With "K:3X"
Endif
Affzo [M:SIHV]VALUATION
#End X3-107954 (LCC-19/09/18) Add an icon on sales invoices Valuation tab

Return
##########################################################################################################
#--------------------------------------------------------------------------#
# Chargement divers fonction de la Société et du Site de la facture        #
# ------------------------------------------------------------------------ #
# En fonction de la société                                                #
# --> Chargement des globales liées au compteur                            #
# En fonction du site de vente                                             #
# --> Chargement du type de facture                                        #
# ------------------------------------------------------------------------ #
$CHARG_DIVER

# Aucun type de facture renseigné : On l'initialise
Local Char WSIVTYP(GLONTSV)
Gosub INIT_SIVTYP From SUBSIHB
If GERR=1 Return Endif
[M:SIH0]SIVTYP=WSIVTYP

Case [M:SIH0]INVTYP
 When 1    : # Facture
     GMANCOU = [F:TCA]MANCOU(3) : GCPT = [F:TCA]CODNUM(3)
 When 2    : # Avoir
     GMANCOU = [F:TCA]MANCOU(4) : GCPT = [F:TCA]CODNUM(4)
 When 5    : # Proforma
     GMANCOU = [F:TCA]MANCOU(5) : GCPT = [F:TCA]CODNUM(5)
Endcase

Return
##########################################################################################################
#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & dim([M:SIH4]CCE1)>0 & GFLAG<>""
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WK5"+GFLAG+"4"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SIH4]NBLIG=0
    [M:SIH4]NBLIG=1 : Affzo [SIH4]5 : Effzo [SIH4]5
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Gosub AFF_TITCOL From SUBSIHV
Return



#########################################################################
#MAE, écran des factures en création et alimenté par le client et le site via les navigations
$AVANT_CHOI
  If GCREFONC=1
    Local Char VALEUR
    REPONSE=GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    # FGR 18/02/2014 : X3SUIVI96940 ne pas faire le diszo : ça désactive les actions sur champ (contrôle, AM...)
    #Diszo [M:SIH0]BPCINV
    # FGR 18/02/2014 : X3SUIVI96940 empêche l'exécution du AM_BPCORD
    #GCREFONC = 0
    GCREFONC = 2
  Endif
