#########################################################################
# Actions fichier SINVOICE
#########################################################################
$LEC_SIH
Read [SIH] SIH0=[F:SIV]NUM
If fstat OK = 0
Else     OK = 1
Endif
Return

$CRE_SIH
Raz [F:SIH]EECNUMDEB
If evalue("dim([F:SIH]CREDAT)")>0
 Assign "[F:SIH]CREDAT" With date$
Endif
If evalue("dim([F:SIH]CREUSR)")>0
 Assign "[F:SIH]CREUSR" With GUSER
Endif
If evalue("dim([F:SIH]EXPNUM)")>0
 Assign "[F:SIH]EXPNUM" With [C]EXPORT
Endif

Write [SIH]
If fstat   GOK=0 : Call FSTA("SIH") From GLOCK : Endif
Return

$MOD_SIH
If evalue("dim([F:SIH]UPDDAT)")>0
 Assign "[F:SIH]UPDDAT" With  date$
Endif
If evalue("dim([F:SIH]UPDUSR)")>0
 Assign "[F:SIH]UPDUSR" With GUSER
Endif
If evalue("dim([F:SIH]EXPNUM)")>0
 Assign "[F:SIH]EXPNUM" With [C]EXPORT
Endif

Rewrite [SIH]
If fstat   GOK=0 : Call FSTA("SIH") From GLOCK : Endif
Return

$SUP_SIH
Readlock [SIH] SIH0=[F:SIV]NUM
# --> Enregistrement locké
If fstat = 1 : GOK=-1 : GLOCK="$SINVOICE" : Return : Endif
Delete [SIH]
If fstat = 1 : GOK=-1 : GLOCK="$SINVOICE" : Endif
Return

#########################################################################
$DEVERROU_PICKING

Local Integer I
Local Char    SYMBOLE2(50)
# Déblocage des documents en cours de picking
For I=0 To [M:SIH4]NBLIG-1
   If [M:SIH4]CREFLG(I)=0
      If [M:SIH4]SOHNUM(I)<>""
         SYMBOLE2 = "SOH"+[M:SIH4]SOHNUM(I)
         Unlock = SYMBOLE2
         # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
         If [M:SIH1]SIHORI=10 and dim([M:SIH4]VCRINVCNDTYP)>0 and [M:SIH4]VCRINVCNDTYP(I)=10 and [M:SIH4]VCRINVCNDLIN(I)>0
           ##--Unlocking SOQ
           #SYMBOLE2 = "SOQ"+[M:SIH4]SOHNUM(I)+"\"+num$([M:SIH4]SOPLIN(I))+"\"+num$([M:SIH4]SOQSEQ(I))
           #Unlock = SYMBOLE2
           ##--Unlocking SOP
           #SYMBOLE2 = "SOP"+[M:SIH4]SOHNUM(I)+"\"+num$([M:SIH4]SOPLIN(I))+"\"+num$([M:SIH4]SOQSEQ(I))
           #Unlock = SYMBOLE2
           #--Unlocking SVIC
           SYMBOLE2 = "SVIC"+"~"+[M:SIH4]SOHNUM(I)+"\"+"10"+"\"+num$([M:SIH4]SOPLIN(I))+"\"+num$([M:SIH4]SOQSEQ(I))
           Unlock = SYMBOLE2
         Endif
         # End issue 107888
      Endif
      If [M:SIH4]SDHNUM(I)<>""
         SYMBOLE2 = "SDH"+[M:SIH4]SDHNUM(I)
         Unlock = SYMBOLE2
      Endif
      If [M:SIH4]CONNUM(I)<>""
         SYMBOLE2 = "CON"+[M:SIH4]CONNUM(I)
         Unlock = SYMBOLE2
      Endif
      If [M:SIH4]XSIHORINUM(I)<>""
         SYMBOLE2 = "SIV"+[M:SIH4]XSIHORINUM(I)
         Unlock = SYMBOLE2
      Endif
      If [M:SIH4]SRHNUM(I)<>""
         SYMBOLE2 = "SRH"+[M:SIH4]SRHNUM(I)
         Unlock = SYMBOLE2
      Endif
      If [M:SIH4]SRENUM(I)<>""
         SYMBOLE2 = "SRE"+[M:SIH4]SRENUM(I)
         Unlock = SYMBOLE2
      Endif
   Endif
Next I

Return

