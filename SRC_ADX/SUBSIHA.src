#########################################################################
# FGR 11/10/2007 : X3SUIVI43412                                     CRM #
#########################################################################
# FGR 11/10/2007 : X3SUIVI43412 ajout de l'appelant
#########################################################################
# Affectation des valeurs pour la crÃ©ation d'un contrat de service.
#########################################################################
$SET_HEA_INFO
  Case IMPZON
    When "CONNUM"  #[M:CON0]
    When "CPY"
      [M:CON0]CPY = [F:SIH]CPY
    When "SALFCY"
      [M:CON0]SALFCY = [F:SIH]FCY
    When "CONBPC"
      [M:CON0]CONBPC = [F:BPC]BPCNUM
      [M:CON1]CONORI = 7
      [M:CON1]CONORIVCR = ""
      [M:CON1]CONORIVCRL = 0
    When "CUR"
      [M:CON0]CUR = [F:SIH]CUR
    When "CONCCN"

    ######################################
    #[M:CON1]
    When "CONNAM"
      [M:CON1]CONNAM = [F:SIH]NUM
    When "CONTYP"
    When "CONCAT"
    When "EVRPBL"
    When "EVRMAC"
    When "CRSCOVSAM"
    When "SALREP"
      #[M:CON1]SALREP = [F:SIH]REP
    When "CONORIVCR"
      # fait dans CONBPC
    When "CONORI"
      # fait dans CONBPC
    When "CONCOT"
      [M:CON1]CONCOT = GSZDEFCOTCHX

    ######################################
    #[M:CON4]
    When "SIUDAT"
      [M:CON4]SIUDAT = date$
    When "CONSTRDAT"
    When "CONENDDAT"
    When "REWFRY"
    When "REWFRYBAS"
    When "CONREW"
    When "MANREWFLG"
    When "CONAMT"
      [M:CON4]CONAMT = 0
    When "PITCDT"
      [M:CON4]PITCDT = GCON4PITCDT
    When "RVAFRY"
    When "RVAFRYBAS"
    When "RVAMET"
    When "RVASSP"
    When "CONBASIDX"
    When "LASVALIDX"
    When "LASIDXDAT"
    When "CONBASFOR"
    When "RSILTI"
    When "RSILTIBAS"
    When "PITTOL"

    ######################################
    #[M:CON8]
    When "INVFRY"
    When "INVFRYBAS"
    When "INVMET"
    When "INVFRYCOE"
    When "INVLTI"
    When "INVLTIBAS"
    When "PTE"
      [M:CON8]PTE = [F:SIH]PTE
    When "NBDPT"  # variable bas de tableau
    When "NBAXE"  # variable bas de tableau
      # mais pour les axes ne rien faire, c'est a priori bon !
    When "CCE"
      [M:CON8]CCE(indice) = [F:SIH]CCE(indice)

    ######################################
    #[M:CONG]
    When "CONBPCINV"
    When "CONBPCPYR"
    When "CONBPCGRU"
    When "CONPJT"
    When "CONCHGTYP"
    When "ITMREF"
    When "CONPRITYP"
    When "CONVACBPR"
      [M:CONG]CONVACBPR = [F:BPC]VACBPR
    When "NBFAC"  # variable bas de tableau

    ######################################
    #[M:CON2]
    When "NBINV"  # variable bas de tableau
    When "NBDUD"  # variable bas de tableau
    When "NBPAY"  # variable bas de tableau

    ######################################
    #[M:CON5]
    When "NBAMT"  # variable bas de tableau
    When "NBREW"  # variable bas de tableau
    When "RSIFLG"
    When "RSIREN"
      # Note FGR : je ne sais pas pourquoi, mais un ADI est initialisé à  "000"
      # Du coup ensuite ça plante parce que le code d'existe pas dans la table !
      [M:CON5]RSIREN = ""
    When "FDDFLG"
    When "RSIDAT"
    When "PRERSIFLG"

    ######################################
    When Default
  Endcase
Return

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SIH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   If [M]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT

If GWRHACT<>2 Return Endif
If [M]STOFCY=""
  Grizo [M:SIH1]WRHE
  Grizo [M:SIH4]WRH
  Return
Endif
If [M]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES=2
   If [M]STOMVTFLG=2
      If find(GREP,"C","D")
         Actzo [M:SIH1]WRHE
         If GWRHOBY=2
            Diszo [M:SIH4]WRH
         Else
            Actzo [M:SIH4]WRH
         Endif
      Elsif [M:SIH1]WRHE<>""
         Diszo [M:SIH1]WRHE
         Diszo [M:SIH4]WRH
      Else
         Actzo [M:SIH1]WRHE
         Actzo [M:SIH4]WRH
      Endif
   Else
      Raz   [M:SIH1]WRHE
      Grizo [M:SIH1]WRHE
      Grizo [M:SIH4]WRH
   Endif
Else
  Raz   [M:SIH1]WRHE
  Grizo [M:SIH1]WRHE
  Grizo [M:SIH4]WRH
Endif
Return

#MAE, bg 77405
$VERROU_HAE
#--CPO 84337
If [F:SIH]NUM<>[F:SIV]NUM
  Read [F:SIH]SIH0=[F:SIV]NUM
  If fstat : Raz [F:SIH] : Return Endif
Endif
#--/
[L]SYMBHAE = "HAE"+[F:SIH]NUM+"\"+[F:SIH]GTE
Lock =SYMBHAE With lockwait=0
If fstat
 Unlock =SYMBOLE
 [L]OK=0
Endif
Return

$DEVERROU_HAE
Unlock =SYMBHAE
Return

#90370 Cash VAT SPA
$CASH_VAT
If func AFNC.ACTIV("KSP")
   Local Char SPACSHVAT(1)
   Call PARAML([F:SIH]CPY,"SPACSHVAT",SPACSHVAT) From ADOVAL
   If SPACSHVAT="2"
     Local Char WCPY(GLONCRY)
     Local Integer CSHVAT
     Call CSHVATBPC([F:SIH]ACCDAT,[F:BPR]CRY,[F:SIH]VAC,[F:SIH]CPY,[F:SIH]TAX(),CSHVAT) From DCLVATSPA
     [F:SIH]CSHVAT=CSHVAT
   Endif
Endif
#90370

Return

#########################################################################
# 101380 - Setup SST Override related fields
#########################################################################
Subprog SETUP_SSTFIELDS

Local Integer I
# If GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  Grizo [M:SIH4]VACITM1,VACITM2,VACITM3
  If dim([M:SIH4]SSTCOD)>0 :
    Chgfmt [M:SIH4]SSTCOD     With "K:"   + num$(type([M:SIH4]SSTCOD)-10)     + "B"     # Show enterable
    Chgfmt [M:SIH2]SFISSTCOD  With "K:"   + num$(type([M:SIH2]SFISSTCOD)-10)  + "B"     # Show enterable
    Actzo [M:SIH4]SSTCOD
  Endif
Else
  Actzo [M:SIH4]VACITM1,VACITM2,VACITM3
  If dim([M:SIH4]SSTCOD)>0
    Chgfmt [M:SIH4]SSTCOD     With "-K:"  + num$(type([M:SIH4]SSTCOD)-10)     + "B"     # Hide
    Chgfmt [M:SIH2]SFISSTCOD  With "-K:"  + num$(type([M:SIH2]SFISSTCOD)-10)  + "B"     # Hide
  Endif
Endif

End

#########################################################################
# 101380 - Retrieve SST Code from source doc when copying from earlier document
# Invoicing elements can be re-ordered or dropped due to transfer rules.
#########################################################################
Subprog RELOAD_SFISST
Local Integer NEWELEM, SRCELEM, INBFAC
Local Char    SRCFILE
# Should never get here as a Direct invoice, but just in case
# If [M:SIH1]SIHORI=1 | !GLOCUSATAX : End : Endif   # 106867.o
If [M:SIH1]SIHORI=1 | !(func AFNC.ACTIV("LTA")) | [F:CPY]SSTTAXACT <> 2 : End : Endif   # 106867.n

INBFAC=dim([M:SIH2]INVDTA)

Local Char    OGSSTCOD(8) (INBFAC)
Local Integer OGINVDTA    (INBFAC)

Case [M:SIH1]SIHORI
  When 2 : SRCFILE="SOH"
  When 3 : SRCFILE="SDH"
  When 5 : SRCFILE="SQH"
  When 7 : SRCFILE="CON"
  When 8 : SRCFILE="SRE"
            # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) #
            # SIHORI=10 Schedule invoice with direct line
            #TODO 107888 CPO CPO Add also the SIHORI=10 ?
  When Default : End
Endcase

If [M:SIH1]SIHORI = 7 & [F:SID]CONNUM<>[F:CON]CONNUM : Read [CON]CON0=[F:SID]CONNUM : Endif

#Get the elements from the order and store in local variables
For SRCELEM=0 To INBFAC-1
  [L]OGINVDTA(SRCELEM) = evalue("[F:"+SRCFILE+"]INVDTA(SRCELEM)")
  [L]OGSSTCOD(SRCELEM) = evalue("[F:"+SRCFILE+"]SFISSTCOD(SRCELEM)")
Next I

#Find the correct inv element on the SDH header and update the SSTCOD
For NEWELEM=0 To INBFAC-1
  If find(GFONCTION,'FUNAUTINVC','FUNAUTINVS')
    SRCELEM = find([M:SIH2]INVDTA(NEWELEM), [L]OGINVDTA(0..INBFAC-1))
    If SRCELEM>0
      [M:SIH2]SFISSTCOD(NEWELEM)=[L]OGSSTCOD(SRCELEM-1)
    Endif
  Else
  SRCELEM = find([F:SIV]INVDTA(NEWELEM), [L]OGINVDTA(0..INBFAC-1))
  If SRCELEM>0
    [F:SIV]SFISSTCOD(NEWELEM)=[L]OGSSTCOD(SRCELEM-1)
  Endif
  Endif
Next SRCELEM

End

#########################################################################
Funprog GET_ECCVALMAJ_FIELD

Local Char SARENDRE(GLONAVA)

  # FGR 24/04/2015 : X3SUIVI105605
  # Note : Permet de renvoyer "" quand on ne veut pas gérer les versions.
  #        C'est le cas sur les proforma, et les factures ss mouvement de stock
  Raz SARENDRE
  If [M:SIH0]INVTYP = 1 Then
    If [M:SIH1]STOMVTFLG = [V]CST_AYES Then
      SARENDRE = "ECCVALMAJ"
    Endif
  Endif
End SARENDRE

