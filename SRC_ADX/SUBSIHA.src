#########################################################################
# A SUPPRIMER
#########################################################################

####################################################################
$GRIZE_LIENS
#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#
# FGR 23/11/2011 : X3SUIVI71065 (début)
If GPJTSNGDOC = G_NON Then
  Call PJT_MODFCY([M:SIH0]SALFCY, "[M:SIH4]DPJT") From TRTPJT
Endif
# FGR 23/11/2011 : X3SUIVI71065 (fin)

[L]INVCFLG  = 0
If GLBINVCA_ON = 2
  Local Integer WRET
  Call LEC_TSV_LEG(GCURLEG,[M]SIVTYP,WRET) From TRTLECLEG
  If func TRTINVCAN.INVCAN(GCURLEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    INVCFLG = 1
  Else
    INVCFLG = 0
  Endif
Endif

If [M:SIH1]INVSTA = 3 | (INVCFLG = 1 & GREP <> "C")
   Diszo [M:SIH0]1-99
   Diszo [M:SIH1]1-99
   Diszo [M:SIH2]5,10,15,25
   # ACA (2009-06-30) Bug 55895 : Périodes de prestation et validation facture de vente
   Diszo [M:SIH2]20
   #Actzo [M:SIH2]STRDATSVC : Actzo [M:SIH2]ENDDATSVC
   #If dim ([M:SIH2]CEE) > 0
   #    Diszo [M:SIH2]CCE
   #Endif
   # V6.1 : Si facture validée, Période prestation accessible ssi SVC actif
   If dim([M:SIH2]STRDATSVC)>0 & !GLOCITAPRE
       Actzo [SIH2]STRDATSVC, ENDDATSVC
       # Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
       #--avoid triggering twice the AV_ code from generated script (Affzo done by supervisor in GOBJSUB after $LIENS action, if AFFICHE seted)
       #Affzo [M:SIH4]1-99
       If !AFFICHE : Affzo [M:SIH4]1-99 : Endif
       # End issue X3-38496
       Actzo [M:SIH4]1-99
   Else
       Diszo [M:SIH4]1-99
   Endif
   Diszo [M:SIHV]15       : # Bug 72024
   Actzo [M:SIH0]NUM
   Call SETUP_SSTFIELDS      # 101380.n
   Goto TERMINE_GRIZE_LIENS  # FGR 07/12/2011 : X3SUIVI71065    Return
Else
   Actzo [M:SIH0]1-99
   Actzo [M:SIH1]1-99
   Actzo [M:SIH2]1-99
   # Issue X3-38496 - 2017-06-30 by CPO : 121098_PERF_Issue_in_Sales_Invoices (visualization of invoices with many lines)
   #--avoid triggering twice the AV_ code from generated script (Affzo done by supervisor in GOBJSUB after $LIENS action, if AFFICHE seted)
   #Affzo [M:SIH4]1-99
   If !AFFICHE : Affzo [M:SIH4]1-99 : Endif
   # End issue X3-38496
   Actzo [M:SIH4]1-99
   Diszo [M:SIHV]15       : # Bug 72024
   Call SETUP_SSTFIELDS      # 101380.n
Endif

If GMANCOU=1 & find(GREP,"C","D") Diszo [M:SIH0]NUM Endif
If GREP <> "C" Diszo [M:SIH0]SIVTYP, SALFCY, BPCINV : Diszo [M:SIH1]BPCORD Endif

#Diszo [M:SIH1]BPCORD
Diszo [M:SIH1]SIHORINUM
Diszo [M:SIH1]PIHNUM
If [M:SIH0]INVTYP>2
   Grizo [M:SIH1]STOMVTFLG
   Grizo [M:SIH1]STOFCY
   If dim([M:SIH1]WRHE)>0 Grizo [M:SIH1]WRHE Endif
Else
   # Facture ou Avoir
   If [M:SIH1]STOMVTFLG <> 2
      Grizo [M:SIH1]STOFCY
      If dim([M:SIH1]WRHE)>0      Grizo [M:SIH1]WRHE      Endif
      If dim([M:SIH1]SRGLOCDEF)>0 Grizo [M:SIH1]SRGLOCDEF Endif
      Grizo [M:SIH1]TRSFAM
   Elsif !find(GREP,"C","D")
#      Diszo [M:SIH1]STOFCY, SRGLOCDEF, TRSFAM
      Diszo [M:SIH1]STOFCY
      If dim([M:SIH1]WRHE)>0 Diszo [M:SIH1]WRHE Endif
   Endif
   # Flag mvt de stock non accessible :
   # En modification
   # En créa/dupli s'il y a des lignes et si STOFCY="" car STOFCY est non modifiable s'il y a des lignes
   If !find(GREP,"C","D") | ([M:SIH4]NBLIG<>0 & [M:SIH1]STOFCY="") Diszo [M:SIH1]STOMVTFLG Endif
Endif
If !find (GREP, "C", "D")
    Diszo [M:SIH1]BPAADD
#    Diszo [M:SIH1]VACBPR     : # bug 13356
Endif
If !find(GREP,"C","D") | GNOTATI=1 Diszo [M:SIH1]PRITYP Endif

If [M]INVTYP<>2
    Grizo [M:SIH1]CNOREN
Endif
If !find (GREP, "C", "D")
    Diszo [M:SIH2]CUR
    Diszo [M:SIH2]CURTYP
Elsif GUPDCUR=1
    Call CONTDEV([M:SIH2]CUR,[M:SIH0]INVDAT) From TRTDEV
    If !mkstat Diszo [M:SIH2]CUR : Diszo [M:SIH2]CURTYP : Endif
    Raz GMESSAGE : mkstat=0
Endif
If !find (GREP, "C", "D")
#    Grizo [M:SIH2]RATCUR, RATRPT
    Grizo [M:SIH2]RAT1, RAT2
#    Diszo [M:SIH2]LABEL, RATCUR0, CPYCUR, LABEL1, RATRPT0, RPTCUR
    Diszo [M:SIH2]LABEL, CURMLT
Endif
If GLINREP=1
    If dim([M:SIH4]REP1) > 0 Diszo [M:SIH4]REP1, REPRAT1  Endif
    If dim([M:SIH4]REP2) > 0 Diszo [M:SIH4]REP2, REPRAT2 Endif
Endif

#----------------------------------------------------------------#
# Activation/Desactivation des zones en fonction des codes acces #
#----------------------------------------------------------------#
If GPRIMOD=1
    Diszo [M:SIH4]GROPRI
    If dim([M:SIH4]DISCRGVAL1) > 0 Diszo [M:SIH4]DISCRGVAL1 Endif
    If dim([M:SIH4]DISCRGVAL2) > 0 Diszo [M:SIH4]DISCRGVAL2 Endif
    If dim([M:SIH4]DISCRGVAL3) > 0 Diszo [M:SIH4]DISCRGVAL3 Endif
    If dim([M:SIH4]DISCRGVAL4) > 0 Diszo [M:SIH4]DISCRGVAL4 Endif
    If dim([M:SIH4]DISCRGVAL5) > 0 Diszo [M:SIH4]DISCRGVAL5 Endif
    If dim([M:SIH4]DISCRGVAL6) > 0 Diszo [M:SIH4]DISCRGVAL6 Endif
    If dim([M:SIH4]DISCRGVAL7) > 0 Diszo [M:SIH4]DISCRGVAL7 Endif
    If dim([M:SIH4]DISCRGVAL8) > 0 Diszo [M:SIH4]DISCRGVAL8 Endif
    If dim([M:SIH4]DISCRGVAL9) > 0 Diszo [M:SIH4]DISCRGVAL9 Endif
Endif

#----------------------------------------------------------------#
# Activation/Desactivation des champs stock                      #
#----------------------------------------------------------------#
# Si proforma ou facture ss mvt stock (facture directe, de contrat de service, de dde de service)
# grizo des champs stock
If [M:SIH0]INVTYP=5 | ([M:SIH0]INVTYP=1 & [M:SIH1]STOMVTFLG<>2)
#& ([M:SIH0]INVTYP=1 & ([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG<>2)
    Call GRIZONSOR("SIH4") From STKECR
# Sinon si facture, diszo des champs stock
Elsif [M:SIH0]INVTYP=1
    Call ETAZONSOR("SIH4") From STKECR
#Elsif [M:SIH0]INVTYP=2 & ([M:SIH1]STOMVTFLG<>2 | ([M:SIH1]SIHORI=6 & [M:SIH1]STOMVTFLG=2))
Elsif [M:SIH0]INVTYP=2 & [M:SIH1]STOMVTFLG<>2
    # Avoir sans mouvement de stock
    # Force l'affichage afin que les Grizo
    # appelés ensuite fonctionnent
    Affzo [M:SIH4]5
    # Grize toutes les colonnes stock
    Call STKGRICOL("SIH4",[M]NBLIG) From STKECR
Elsif [M:SIH0]INVTYP=2
    # Avoir avec mouvement de stock
    # Force l'affichage afin que les Diszo
    # appelés ensuite fonctionnent
    Affzo [M:SIH4]5
    # Rend insaisissables toutes les colonnes, puis...
    # ( Diszo du tableau empêche la réactivation)
    # ...rend saisissable la dernière ligne (la ligne vide)
    Call STKDISCOL("SIH4",[M]NBLIG) From STKECR
    Diszo [M:SIH4]SAU, SAUSTUCOE, PRIORD, MVTDES
    Actzo [M:SIH4]SAU([M]NBLIG), SAUSTUCOE([M]NBLIG),PRIORD([M]NBLIG),MVTDES([M]NBLIG)
Endif

Gosub SHOW_HIDE_ENTCOD From TRTADRLIB   #LTA.n

# 87923 : Gestion des prélèvements SDD
If func AFNC.ACTIV("SDD")
  Gosub GRIZO_UMRNUM From TRTVENSDD
Endif
# 87923 : Gestion des prélèvements SDD

# FGR 23/11/2011 : X3SUIVI71065 (début)
$TERMINE_GRIZE_LIENS
  If GPJTSNGDOC = G_OUI Then
    Call PJT_MODFCY([M:SIH0]SALFCY, "[M:SIH4]DPJT") From TRTPJT
  Endif
Return
# FGR 23/11/2011 : X3SUIVI71065 (fin)

#########################################################################
$LIENS_LIG
#########################################################################
Local Integer  WTRT, WRET
Local Shortint NOL
NOL = nolign-1

#---------------------------------------------------------#
# Lecture article pour chargement gestion no séries       #
#---------------------------------------------------------#
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (début)
#If [F:ITM]ITMREF <> [F:SID]ITMREF
#     Read [F:ITM]ITM0 = [F:SID]ITMREF
#     If fstat  Raz [F:ITM] : Call RSTA ("ITM",[F:SID]ITMREF) From GLOCK : Endif
#Endif
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (fin)

[M]XSERMGTCOD(NOL) = [F:ITM]SERMGTCOD
#---------------------------------------------------------#
# Lecture article-vente pour chargement base calcul marge #
#---------------------------------------------------------#
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (début)
#If [F:ITS]ITMREF <> [F:SID]ITMREF
#     Read [F:ITS]ITS0 = [F:SID]ITMREF
#     If fstat  Raz [F:ITS] : Call RSTA ("ITS",[F:SID]ITMREF) From GLOCK : Endif
#Endif
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (fin)
# FGR 10/11/2015 : X3SUIVI108078 (début) TEST [ITS]
If [F:ITS]ITMREF <> [F:SID]ITMREF Then
  Call MESSAGE(func AFNC.MES1(mess(435,192,1), [F:SID]ITMREF)) From GESECRAN
Endif
# FGR 10/11/2015 : X3SUIVI108078 (fin) TEST [ITS]

#-----------------------------------------------------------#
# Facture de commande    :                                  #
# Facture d'échéance de commande  :                         # 107888 : Scheduled invoices : (LD:10/05/16)
# Lecture détail commande pour alim. qté restant à facturer #
#                                 et qté allouée            #
#-----------------------------------------------------------#
[M]YINVQTY(NOL) = 0
[M]YALLQTY(NOL) = 0
# 107888 : Scheduled invoices : (LD:10/05/16)
#If [M]INVTYP = 1 & [M]SIHORI = 2
If [M]INVTYP = 1 & ([M]SIHORI = 2 | ([M]SIHORI = 10 & [M]SIHORITYP=10))
# 107888 : Scheduled invoices : (LD:10/05/16)
    If [F:SID]SOHNUM <> ""
       If [F:SOQ]SOHNUM <> [F:SID]SOHNUM | [F:SOQ]SOPLIN <> [F:SID]SOPLIN
&       | [F:SOQ]SOQSEQ <> [F:SID]SOQSEQ
          Read [SOQ]SOQ0 = [F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
          If fstat Raz [F:SOQ] Endif
       Endif
#       [M]YINVQTY(NOL) = [F:SOQ]QTY-[F:SOQ]INVQTY+[F:SID]QTY
       [M]YINVQTY(NOL) = [F:SOQ]QTY-[F:SOQ]INVQTY-[F:SOQ]ODLQTY+[F:SID]QTY
       [M]YALLQTY(NOL) = [F:SOQ]ALLQTY+[F:SID]QTY
    Endif
Endif
# Si proforma issu d'un devis, alim. no devis dans lignes écran pour tunnel
If [M]INVTYP = 5 & [M]SIHORI = 5
   [M]SQHNUM(NOL) = [M]SIHORINUM
Endif
#-----------------------------------------------#
# Alimentation de l'écran à partir de SINVOICED #
#-----------------------------------------------#
[M]VAT1(NOL)     =  [F:SID]VAT(0)
[M]VAT2(NOL)     =  [F:SID]VAT(1)
[M]VAT3(NOL)     =  [F:SID]VAT(2)
[M]VACITM1(NOL)  =  [F:SID]VACITM(0)
[M]VACITM2(NOL)  =  [F:SID]VACITM(1)
[M]VACITM3(NOL)  =  [F:SID]VACITM(2)
[M]LOTFIL(NOL)   =  [F:SID]LOT
[M]STAFIL(NOL)   =  [F:SID]STA
[M]LOCFIL(NOL)   =  [F:SID]LOC
If dim([M]TSICOD1(NOL))>0: [M]TSICOD1(NOL) = [F:SID]TSICOD(0):Endif
If dim([M]TSICOD2(NOL))>0: [M]TSICOD2(NOL) = [F:SID]TSICOD(1):Endif
If dim([M]TSICOD3(NOL))>0: [M]TSICOD3(NOL) = [F:SID]TSICOD(2):Endif
If dim([M]TSICOD4(NOL))>0: [M]TSICOD4(NOL) = [F:SID]TSICOD(3):Endif
If dim([M]TSICOD5(NOL))>0: [M]TSICOD5(NOL) = [F:SID]TSICOD(4):Endif
[M]BASTAXLIN1(NOL) = [F:SID]BASTAXLIN(0)
[M]BASTAXLIN2(NOL) = [F:SID]BASTAXLIN(1)
[M]BASTAXLIN3(NOL) = [F:SID]BASTAXLIN(2)
[M]BASTAXLIN4(NOL) = [F:SID]BASTAXLIN(3)
[M]BASTAXLIN5(NOL) = [F:SID]BASTAXLIN(4)
[M]BASTAXLIN6(NOL) = [F:SID]BASTAXLIN(5)
[M]AMTTAXLIN1(NOL) = [F:SID]AMTTAXLIN(0)
[M]AMTTAXLIN2(NOL) = [F:SID]AMTTAXLIN(1)
[M]AMTTAXLIN3(NOL) = [F:SID]AMTTAXLIN(2)

[M]DSTOFCY(NOL)    = [F:SID]STOFCY
[M]XSIHORINUM(NOL) = [F:SID]SIHORINUM

[M]DPJT(NOL)       = [F:SID]PJT     : # 71065 : PJT

If dim([M:SIH4]SSTCOD(NOL))>0 : [M:SIH4]SSTCOD(NOL)=[F:SID]SSTCOD : Endif #101380.n

#----- Chargement sections analytiques -----#
#Call CHARG_CCE("SIH4",NOL,"SID",0,[F:SID]NUM,[F:SID]SIDLIN,0,"") From TRTX3CPT
#----- Chargement comptes et sections analytiques -----#
Call CHARG_ACCCCE(NOL,"[M:SIH4]LINACC","","[M:SIH4]CCE",
&                "SID",0,[F:SID]NUM,[F:SID]SIDLIN,0,"") From TRTX3CPT
#---------------------------------------------#
# chgt des zones servant de test en VALLIG    #
#---------------------------------------------#
[M]YQTY(NOL)     = [M]QTY(NOL)
[M]YQTYSTU(NOL)  = [M]QTYSTU(NOL)
# Chargement de la quantité pour calcul de qté en nomenclature
[M]CQTY(NOL)     = [M]QTY(NOL)
Call ADD_TOT(NOL) From SUBSIHB

# Si facture directe avec maj stock
# ou facture de commande
# ou facture de livraison mais ligne sans no liv
# et article géré en stock
If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&  (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&   ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
   # Alimentation des zones stock de la ligne document
   Raz WRET
   If [M:SIH1]INVSTA=3
      WTRT=1
   Else
      WTRT=2
   Endif
   # Alimentation des zones stock de la ligne facture
   # à partir de STOJOU ou STOALL
   Call RECSTOSOR (WTRT,"SIH4",NOL,[M:SIH4]DSTOFCY(NOL),[M:SIH4]ITMREF(NOL),5,
&                  [M:SIH0]NUM,[M:SIH4]SIDLIN(NOL),"",WRET) From STKECR
Endif

# Chargement indicateur maj stock effectuée
[M:SIH4]RTNSTOUPD(NOL)=1
# Si avoir avec mvt de stock
If [M:SIH0]INVTYP=2 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH4]QTY(NOL)<>0
    # Si avoir direct ou avoir sur retour et ligne directe : maj des stocks
    If [M:SIH1]SIHORI=1 | ([M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL)="") | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)="")
        [M:SIH4]RTNSTOUPD(NOL)=2
    Endif
    # Si avoir sur facture : recherche origine de cette facture pour savoir s'il y a une maj des stocks
    If [M:SIH1]SIHORI=4
        If [F:SIV1]NUM<>[M:SIH4]XSIHORINUM(NOL)
            Read [F:SIV1]SIV0=[M:SIH4]XSIHORINUM(NOL)
            If fstat  Raz [F:SIV1] : Endif
        Endif
        # maj des stock ssi facture directe ou facture de commande
        If find([F:SIV1]SIHORI,1,2) [M:SIH4]RTNSTOUPD(NOL)=2 Endif
        If [F:SIV1]SIHORI=3
            If [F:SID1]NUM<>[M:SIH4]XSIHORINUM(NOL) | [F:SID1]SIDLIN<>[M:SIH4]SIDORILIN(NOL)
                Read [F:SID1]SID0=[M:SIH4]XSIHORINUM(NOL);[M:SIH4]SIDORILIN(NOL)
                If fstat  Raz [F:SIV1] : Endif
            Endif
            # maj des stock ssi facture de livraison et ligne directe
            If [F:SID1]SDHNUM="" [M:SIH4]RTNSTOUPD(NOL)=2 Endif
        Endif
    Endif
Endif
# Si avoir direct
# ou avoir sur facture
# ou ligne directe d'un avoir sur retour
# avec mouvement de stock et article géré en stock
If   [M:SIH0]INVTYP=2 & [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(NOL)=2 &
&    (find([M:SIH1]SIHORI,1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
#&   ([M:SIH1]SIHORI=1 | ([M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL)=""))
    # Recherche du contenu des zones stock d'une ligne document dans le fichier STOJOU
    Call RECSTO_F ("SIH4", [M:SIH4]DSTOFCY(NOL), 18,
&                  [M:SIH0]NUM, [M:SIH4]SIDLIN(NOL), NOL, "") From STKECR
    [M:SIH4]WSTOFLG(NOL)=1
Else
    Raz [M:SIH4]WSTOFLG(NOL)
Endif

If [M:SIH0]INVTYP=2
    If [F:ITU]ITMREF<>[F:SID]ITMREF | [F:ITU]BPCNUM<>[F:SIV]BPCORD
         Read [F:ITU]ITU0=[F:SID]ITMREF;[F:SIV]BPCORD
         If fstat  Raz [F:ITU] : Endif
    Endif
    # ------------------------------------ #
    # Alimentation du flag coef modifiable #
    # ------------------------------------ #
    If [M]SAU(NOL)=[M]STU(NOL)
        [M]DACSAUCOE(NOL)=1
    Elsif [M]SAU(NOL)=[F:ITM]SAU
        [M]DACSAUCOE(NOL)=[F:ITM]DACSAUCOE
    Elsif [M]SAU(NOL)=[F:ITU]SAU | [M]SAU(NOL)=[F:ITU]PCU1 | [M]SAU(NOL)=[F:ITU]PCU2
        [M]DACSAUCOE(NOL)=1
    Else
        Local Integer I    : # L'unité est une unité de conditionnement
        For I=0 To dim([F:ITM]PCU)-1
           If find([F:ITM]PCU(I),[M]SAU(NOL))
              [M]DACSAUCOE(NOL)=[F:ITM]DACPCUCOE(I)
              Break
           Endif
        Next I
    Endif
Endif

#--- On récupère le mode de facturation de la commande ou de la livraison si c'est possible
If [M:SIH0]IME=0
    If [M:SIH1]SIHORI=2 & [M:SIH1]SIHORINUM="" & [M:SIH4]SOHNUM(NOL)<>""
&    | ([M:SIH1]SIHORI=10 & [M:SIH1]SIHORINUM<>"" & [M:SIH1]SIHORITYP=10 & [M:SIH4]SOHNUM(NOL)<>"") # 107888 : Scheduled invoices : (LD:10/05/16)
        If [F:SOH]SOHNUM <> [M:SIH4]SOHNUM(NOL)
            Read [SOH]SOH0 = [M:SIH4]SOHNUM(NOL)
            If fstat
#               Si proforma la commande a pu être supprimée sinon pb
                Raz [F:SOH] : If [F:SIV]INVTYP <> 5 Call RSTA("SOH",[M:SIH4]SOHNUM(NOL)) From GLOCK Endif
            Endif
        Endif
        [M:SIH0]IME=[F:SOH]IME
    Elsif [M:SIH1]SIHORI=3 & [M:SIH1]SIHORINUM="" & [M:SIH4]SDHNUM(NOL)<>""
        If [F:SDH]SOHNUM <> [M:SIH4]SDHNUM(NOL)
            Read [SDH]SDH0 = [M:SIH4]SDHNUM(NOL)
            If fstat
#              Si proforma la commande a pu être supprimée sinon pb
               Raz [F:SDH] : If [F:SIV]INVTYP <> 5 Call RSTA("SDH",[M:SIH4]SDHNUM(NOL)) From GLOCK Endif
            Endif
        Endif
        [M:SIH0]IME=[F:SDH]IME
    Endif
Endif

NLIG=NOL : Gosub CALC_INV From SUBSIHB

Return
