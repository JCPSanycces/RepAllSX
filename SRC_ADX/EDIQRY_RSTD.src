#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDIQRY                                                       #
# Author : RBA                                                                #
###############################################################################

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
        When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
        When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
        When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
        When "AREAD_AFTER"                  : Gosub AREAD_AFTER
      Endcase
  Endcase
Return

###############
# METHODS
###############
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

###############
# PROPERTIES
###############
$PROPERTIES
#  Case [L]CURPRO
#     Case [L]ARULE
#     Endcase
#  Endcase
Return

###############################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_PARCOD"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.PARCOD"     : TBFIL(NBPRO) = "[LNK_]PARCOD"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_EPR_FLGACT" : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.EPR_FLGACT" : TBFIL(NBPRO) = "[LNK_]EPR_FLGACT"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_CPY"        : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ_CPY"        : TBFIL(NBPRO) = "[LNK_]CPY"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_ECP_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.ECP_VALID"  : TBFIL(NBPRO) = "[LNK_]ECP_VALID"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_FCY"        : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.FCY"        : TBFIL(NBPRO) = "[LNK_]FCY"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_EFP_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.EFP_VALID"  : TBFIL(NBPRO) = "[LNK_]EFP_VALID"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_BPRNUM"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.BPRNUM"     : TBFIL(NBPRO) = "[LNK_]BPRNUM"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_BPAADD"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.BPAADD"     : TBFIL(NBPRO) = "[LNK_]BPAADD"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_EBP_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.EBP_VALID"  : TBFIL(NBPRO) = "[LNK_]EBP_VALID"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_CATCOD"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.CATCOD"     : TBFIL(NBPRO) = "[LNK_]CATCOD"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_ECA_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.ECA_VALID"  : TBFIL(NBPRO) = "[LNK_]ECA_VALID"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_PTCCOD"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.PTCCOD"     : TBFIL(NBPRO) = "[LNK_]PTCCOD"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_EPT_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.EPT_VALID"  : TBFIL(NBPRO) = "[LNK_]EPT_VALID"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_FLOCOD"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.FLOCOD"     : TBFIL(NBPRO) = "[LNK_]FLOCOD"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_FLOREL"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.FLOREL"     : TBFIL(NBPRO) = "[LNK_]FLOREL"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_EFL_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.EFL_VALID"  : TBFIL(NBPRO) = "[LNK_]EFL_VALID"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_EFL_FLGACT" : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.EFL_FLGACT" : TBFIL(NBPRO) = "[LNK_]EFL_FLGACT"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_MSGCOD"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.MSGCOD"     : TBFIL(NBPRO) = "[LNK_]MSGCOD"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_MSGREL"     : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.MSGREL"     : TBFIL(NBPRO) = "[LNK_]MSGREL"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_EMS_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.EMS_VALID"  : TBFIL(NBPRO) = "[LNK_]EMS_VALID"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_MSGFILNOR"  : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDQ.MSGFILNOR"  : TBFIL(NBPRO) = "[LNK_]MSGFILNOR"
  NBPRO += 1 : TBPRO(NBPRO) = "EDQ_ESF_VALID"  : TBTYP(NBPRO) = 3 : TBPTH(NBPRO) = "EDQ.ESF_VALID"  : TBFIL(NBPRO) = "[LNK_]ESF_VALID"
Return

###############################################################################

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = ""
  ASTDKEY = ASTDKEY + "[LNK_]PARCOD;"
  ASTDKEY = ASTDKEY + "[LNK_]CPY;"
  ASTDKEY = ASTDKEY + "[LNK_]FCY;"
  ASTDKEY = ASTDKEY + "[LNK_]BPRNUM;"
  ASTDKEY = ASTDKEY + "[LNK_]BPAADD;"
  ASTDKEY = ASTDKEY + "[LNK_]CATCOD;"
  ASTDKEY = ASTDKEY + "[LNK_]PTCCOD;"
  ASTDKEY = ASTDKEY + "[LNK_]FLOCOD;"
  ASTDKEY = ASTDKEY + "[LNK_]FLOREL;"
Return

###############################################################################

$AQUERY_OPEN_AFTER
  #Declare temp variables
  Local Integer I, J
  Local Char    WPARCOD(30)(1..)
  Local Integer WEPR_FLGACT(1..)
  Local Char    WCPY(5)(1..)
  Local Integer WECP_VALID(1..)
  Local Char    WFCY(5)(1..)
  Local Integer WEFP_VALID(1..)
  Local Char    WBPRNUM(15)(1..)
  Local Char    WBPAADD(10)(1..)
  Local Integer WEBP_VALID(1..)
  Local Char    WCATCOD(20)(1..)
  Local Integer WECA_VALID(1..)
  Local Char    WPTCCOD(20)(1..)
  Local Integer WEPT_VALID(1..)
  Local Char    WFLOCOD(20)(1..)
  Local Char    WFLOREL(5)(1..)
  Local Integer WEFL_VALID(1..)
  Local Integer WEFL_FLGACT(1..)
  Local Char    WMSGCOD(20)(1..)
  Local Char    WMSGREL(5)(1..)
  Local Integer WEMS_VALID(1..)
  Local Char    WMSGFILNOR(20)(1..)
  Local Integer WESF_VALID(1..)

  #Query
  Local File EDIPARTNER [EPR]
  Local File EDIBPRCPYD [EBCD]
  Local File EDIBPRPAR [EBP]
  Local File EDICPYPAR [ECP]
  Local File EDIFCYPAR [EFP]
  Local File FACILITY [FCY]
  Local File EDIFLO [EFL]
  Local File EDIFLOD [EFLD]
  Local File EDIMSG [EMS]
  Local File EDISEQFIL [ESF]
  Local File EDICAT [ECA]
  Local File EDIPTC [EPT]
  Local File EDIXMLFIL [EXF]

  I = 0
  Link [EBCD] With   [EBP]EBP1    ~= [EBCD]PARCOD;1;[EBCD]BPRNUM,
&                    [EPR]EPR0    ~= [EBCD]PARCOD,
&                    [EFL]EFL0    ~= [EBCD]FLOCOD;[EBCD]FLOREL,
&                    [EFLD]EFLD0  ~= [EFL]FLOCOD;[EFL]FLOREL,
&                    [ECP]ECP0    ~= [EBCD]CPY;[EBCD]PARCOD,
&                    [FCY]FCY1    ~= [EBCD]CPY,
&                    [EFP]EFP0    ~= [FCY]FCY;[EPR]PARCOD,
&                    [EMS]EMS0    ~= [EFLD]MSGCOD;[EFLD]MSGREL,
&                    [ESF]ESF0    ~= [EFLD]MSGCOD;[EFLD]MSGREL;[EFLD]MSGFILNOR,
&                    [ECA]ECA0    ~= [EFL]CATCOD,
&                    [EPT]EPT0    ~= [EFL]PTCCOD
&    As [LIEN] Where [EBCD]PARCOD = [EPR]PARCOD
&           Order By [EPR]PARCOD;
&                    [EBCD]CPY;
&                    [EFP]FCY;
&                    [EBP]BPANUM;
&                    [EBP]BPAADD;
&                    [EBCD]CATCOD;
&                    [EBCD]FLOCOD;
&                    [EBCD]FLOREL;
&                    [EFLD]MSGCOD;
&                    [EFLD]MSGREL;
&                    [EFLD]MSGFILNOR

  For [LIEN]
      I = I + 1
      WPARCOD(I)     = [EPR]PARCOD
      WEPR_FLGACT(I) = [EPR]FLGACT
      WCPY(I)        = [EBCD]CPY
      WECP_VALID(I)  = [ECP]VALID
      WFCY(I)        = [EFP]FCY
      WEFP_VALID(I)  = [EFP]VALID
      WBPRNUM(I)     = [EBCD]BPRNUM
      WBPAADD(I)     = [EBP]BPAADD
      WEBP_VALID(I)  = [EBP]VALID
      WCATCOD(I)     = [EBCD]CATCOD
      WECA_VALID(I)  = [ECA]VALID
      WPTCCOD(I)     = [EFL]PTCCOD
      WEPT_VALID(I)  = [EPT]VALID
      WFLOCOD(I)     = [EBCD]FLOCOD
      WFLOREL(I)     = [EBCD]FLOREL
      WEFL_VALID(I)  = [EFL]VALID
      WEFL_FLGACT(I) = [EFL]FLGACT
      WMSGCOD(I)     = [EFLD]MSGCOD
      WMSGREL(I)     = [EFLD]MSGREL
      WEMS_VALID(I)  = [EMS]VALID
      WMSGFILNOR(I)  = [EFLD]MSGFILNOR
      WESF_VALID(I)  = [ESF]VALID
    Next
#INI SAM 122567 (JUCON 17/04/2017)
  Link [EBCD] With   [EBP]EBP1    ~= [EBCD]PARCOD;1;[EBCD]BPRNUM,
&                    [EPR]EPR0    ~= [EBCD]PARCOD,
&                    [EFL]EFL0    ~= [EBCD]FLOCOD;[EBCD]FLOREL,
&                    [EFLD]EFLD0  ~= [EFL]FLOCOD;[EFL]FLOREL,
&                    [ECP]ECP0    ~= [EBCD]CPY;[EBCD]PARCOD,
&                    [FCY]FCY1    ~= [EBCD]CPY,
&                    [EFP]EFP0    ~= [FCY]FCY;[EPR]PARCOD,
&                    [EMS]EMS0    ~= [EFLD]MSGCOD;[EFLD]MSGREL,
&                    [EXF]EXF0    ~= [EFLD]MSGCOD;[EFLD]MSGREL;[EFLD]MSGFILNOR,
&                    [ECA]ECA0    ~= [EFL]CATCOD,
&                    [EPT]EPT0    ~= [EFL]PTCCOD
&    As [LIEN] Where [EBCD]PARCOD = [EPR]PARCOD
&           Order By [EPR]PARCOD;
&                    [EBCD]CPY;
&                    [EFP]FCY;
&                    [EBP]BPANUM;
&                    [EBP]BPAADD;
&                    [EBCD]CATCOD;
&                    [EBCD]FLOCOD;
&                    [EBCD]FLOREL;
&                    [EFLD]MSGCOD;
&                    [EFLD]MSGREL;
&                    [EFLD]MSGFILNOR

    For [LIEN]
      I = I + 1
      WPARCOD(I)     = [EPR]PARCOD
      WEPR_FLGACT(I) = [EPR]FLGACT
      WCPY(I)        = [EBCD]CPY
      WECP_VALID(I)  = [ECP]VALID
      WFCY(I)        = [EFP]FCY
      WEFP_VALID(I)  = [EFP]VALID
      WBPRNUM(I)     = [EBCD]BPRNUM
      WBPAADD(I)     = [EBP]BPAADD
      WEBP_VALID(I)  = [EBP]VALID
      WCATCOD(I)     = [EBCD]CATCOD
      WECA_VALID(I)  = [ECA]VALID
      WPTCCOD(I)     = [EFL]PTCCOD
      WEPT_VALID(I)  = [EPT]VALID
      WFLOCOD(I)     = [EBCD]FLOCOD
      WFLOREL(I)     = [EBCD]FLOREL
      WEFL_VALID(I)  = [EFL]VALID
      WEFL_FLGACT(I) = [EFL]FLGACT
      WMSGCOD(I)     = [EFLD]MSGCOD
      WMSGREL(I)     = [EFLD]MSGREL
      WEMS_VALID(I)  = [EMS]VALID
      WMSGFILNOR(I)  = [EFLD]MSGFILNOR
      WESF_VALID(I)  = [EXF]VALID
    Next

  LogicClose File [EXF]
  #END SAM 122567 (JUCON 17/04/2017)
  LogicClose File [ESF]
  LogicClose File [EMS]
  LogicClose File [EFLD]
  LogicClose File [EFL]
  LogicClose File [FCY]
  LogicClose File [EFP]
  LogicClose File [ECP]
  LogicClose File [EBP]
  LogicClose File [EBCD]
  LogicClose File [EPR]

  #Transfert into temp table
  Local File
& (
&    Char    PARCOD(30),
&    Integer EPR_FLGACT,
&    Char    CPY(5),
&    Integer ECP_VALID,
&    Char    FCY(5),
&    Integer EFP_VALID,
&    Char    BPRNUM(15),
&    Char    BPAADD(10),
&    Integer EBP_VALID,
&    Char    CATCOD(20),
&    Integer ECA_VALID,
&    Char    PTCCOD(20),
&    Integer EPT_VALID,
&    Char    FLOCOD(20),
&    Char    FLOREL(5),
&    Integer EFL_VALID,
&    Integer EFL_FLGACT,
&    Char    MSGCOD(20),
&    Char    MSGREL(5),
&    Integer EMS_VALID,
&    Char    MSGFILNOR(20),
&    Integer ESF_VALID
& )
&  From Variable
&            WPARCOD,
&            WEPR_FLGACT,
&            WCPY,
&            WECP_VALID,
&            WFCY,
&            WEFP_VALID,
&            WBPRNUM,
&            WBPAADD,
&            WEBP_VALID,
&            WCATCOD,
&            WECA_VALID,
&            WPTCCOD,
&            WEPT_VALID,
&            WFLOCOD,
&            WFLOREL,
&            WEFL_VALID,
&            WEFL_FLGACT,
&            WMSGCOD,
&            WMSGREL,
&            WEMS_VALID,
&            WMSGFILNOR,
&            WESF_VALID
&   As [LNK_]
Return

###############################################################################

$AQUERY_TRANS_AFTER
  this.EDQ.PARCOD     = [LNK_]PARCOD
  this.EDQ.EPR_FLGACT = [LNK_]EPR_FLGACT
  this.EDQ.CPY        = [LNK_]CPY
  this.EDQ.ECP_VALID  = [LNK_]ECP_VALID
  this.EDQ.FCY        = [LNK_]FCY
  this.EDQ.EFP_VALID  = [LNK_]EFP_VALID
  this.EDQ.BPRNUM     = [LNK_]BPRNUM
  this.EDQ.BPAADD     = [LNK_]BPAADD
  this.EDQ.EBP_VALID  = [LNK_]EBP_VALID
  this.EDQ.CATCOD     = [LNK_]CATCOD
  this.EDQ.ECA_VALID  = [LNK_]ECA_VALID
  this.EDQ.PTCCOD     = [LNK_]PTCCOD
  this.EDQ.EPT_VALID  = [LNK_]EPT_VALID
  this.EDQ.FLOCOD     = [LNK_]FLOCOD
  this.EDQ.FLOREL     = [LNK_]FLOREL
  this.EDQ.EFL_VALID  = [LNK_]EFL_VALID
  this.EDQ.EFL_FLGACT = [LNK_]EFL_FLGACT
  this.EDQ.MSGCOD     = [LNK_]MSGCOD
  this.EDQ.MSGREL     = [LNK_]MSGREL
  this.EDQ.EMS_VALID  = [LNK_]EMS_VALID
  this.EDQ.MSGFILNOR  = [LNK_]MSGFILNOR
  this.EDQ.ESF_VALID  = [LNK_]ESF_VALID
Return

###############################################################################

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

###############################################################################

$AREAD_AFTER
  #Load the Detail facet

  #EDI partner
  If this.EDQ.PARCOD <> ""
    Local File EDIPARTNER [EPR]
    Read [EPR]EPR0 = this.EDQ.PARCOD
    If !fstat
      this.EDQ.EPR_FLGACT = [EPR]FLGACT
    Endif
    LogicClose File [EPR]
  Endif

  #Company
  If this.EDQ.PARCOD <> "" and this.EDQ.CPY <> ""
    Local File EDICPYPAR [ECP]
    Read [ECP]ECP0 = this.EDQ.CPY;this.EDQ.PARCOD
    If !fstat
      this.EDQ.ECP_EDICOD = [ECP]EXCEDICOD
      this.EDQ.ECP_VALID  = [ECP]VALID
    Endif
    LogicClose File [ECP]
  Endif

  #Site
  If this.EDQ.PARCOD <> "" and this.EDQ.FCY <> ""
    Local File EDIFCYPAR [EFP]
    Read [EFP]EFP0 = this.EDQ.FCY;this.EDQ.PARCOD
    If !fstat
      this.EDQ.EFP_EDICOD = [EFP]EXCEDICOD
      this.EDQ.EFP_VALID  = [EFP]VALID
    Endif
    LogicClose File [EFP]
  Endif

  #BP
  If this.EDQ.PARCOD <> "" and this.EDQ.BPRNUM <> "" and this.EDQ.BPAADD <> ""
    Local File EDIBPRPAR [EBP]
    Read [EBP]EBP0 = 1;this.EDQ.BPRNUM;this.EDQ.BPAADD;this.EDQ.PARCOD
    If !fstat
      this.EDQ.EBP_EDICOD = [EBP]EXCEDICOD
      this.EDQ.EBP_VALID  = [EBP]VALID
    Endif
    LogicClose File [EBP]
  Endif

  #Category
  If this.EDQ.CATCOD <> ""
    Local File EDICAT [ECA]
    Read [ECA]ECA0 = this.EDQ.CATCOD
    If !fstat
      this.EDQ.CATACT    = [ECA]CATACT
      this.EDQ.CATTYP    = [ECA]CATTYP
      this.EDQ.CATTRGTAB = [ECA]CATTRGTAB
      this.EDQ.ECA_VALID = [ECA]VALID
    Endif
    LogicClose File [ECA]
  Endif

  #Flow by BP/partner
  If this.EDQ.BPRNUM <> "" and this.EDQ.CPY <> "" and this.EDQ.PARCOD <> ""
    Local File EDIBPRCPY [EBC]
    Read [EBC]EBC0 = this.EDQ.BPRNUM;this.EDQ.CPY;this.EDQ.PARCOD
    If !fstat
      this.EBC_VALID = [EBC]VALID
    Endif
    LogicClose File [EBC]
  Endif

  #Flow
  If this.EDQ.FLOCOD <> "" and this.EDQ.FLOREL <> ""
    Local File EDIFLO [EFL]
    Read [EFL]EFL0 = this.EDQ.FLOCOD;this.EDQ.FLOREL
    If !fstat
      this.EDQ.EFL_VALID  = [EFL]VALID
      this.EDQ.EFL_FLGACT = [EFL]FLGACT
    Endif
    LogicClose File [EFL]
  Endif

  #Protocol
  If this.EDQ.PTCCOD <> ""
    Local File EDIPTC [EPT]
    Read [EPT]EPT0 = this.EDQ.PTCCOD
    If !fstat
      this.EDQ.PTCTYP    = [EPT]PTCTYP
      this.EDQ.EPT_VALID = [EPT]VALID
    Endif
    LogicClose File [EPT]
  Endif

  #Message maping + sequential file
  If this.EDQ.FLOCOD <> "" and this.EDQ.FLOREL <> ""
    Local Integer WPOS
    Local File EDIFLOD [EFLD]
    Local File EDIMSG [EMS]
    Local File EDISEQFIL [ESF]
    Local File EDIXMLFIL [EXF]  #SAM 122567 (JUCON 17/04/2017)
    Filter [EFLD] Where FLOCOD = this.EDQ.FLOCOD and FLOREL = this.EDQ.FLOREL
    For [EFLD]
      WPOS = fmet this.EDQ.ADDLINE('EDIQRYM', [V]CST_ALASTPOS)
      this.EDQ.EDIQRYM(WPOS).FLOCOD    = [EFLD]FLOCOD
      this.EDQ.EDIQRYM(WPOS).FLOREL    = [EFLD]FLOREL
      this.EDQ.EDIQRYM(WPOS).MSGCOD    = [EFLD]MSGCOD
      this.EDQ.EDIQRYM(WPOS).MSGREL    = [EFLD]MSGREL
      this.EDQ.EDIQRYM(WPOS).MSGDIR    = [EFLD]MSGDIR
      this.EDQ.EDIQRYM(WPOS).MSGOPE    = [EFLD]MSGOPE
      this.EDQ.EDIQRYM(WPOS).MSGTYP    = [EFLD]MSGTYP
      this.EDQ.EDIQRYM(WPOS).MSGFOR    = [EFLD]MSGFOR
      Read [EMS]EMS0 = [EFLD]MSGCOD;[EFLD]MSGREL
      If !fstat
        this.EDQ.EDIQRYM(WPOS).MSGTRGTAB = [EMS]MSGTRGTAB
        this.EDQ.EDIQRYM(WPOS).REPCOD    = [EMS]REPCOD
        this.EDQ.EDIQRYM(WPOS).MSGTPL    = [EMS]MSGTPL
        this.EDQ.EDIQRYM(WPOS).EMS_VALID = [EMS]VALID
      Endif
      this.EDQ.EDIQRYM(WPOS).MSGFILNOR = [EFLD]MSGFILNOR
      If [EFLD]MSGFOR=1 #SAM 122567 (JUCON 17/04/2017)
        Read [ESF]ESF0 = [EFLD]MSGCOD;[EFLD]MSGREL;[EFLD]MSGFILNOR
        If !fstat
          this.EDQ.EDIQRYM(WPOS).FILDES    = [ESF]FILDES
          this.EDQ.EDIQRYM(WPOS).TYPFIL    = [ESF]TYPFIL
          this.EDQ.EDIQRYM(WPOS).CODDBA    = [ESF]CODDBA
          this.EDQ.EDIQRYM(WPOS).ESF_VALID = [ESF]VALID
        Endif
      Else  #SAM 122567 (JUCON 17/04/2017)
        Read [EXF]EXF0 = [EFLD]MSGCOD;[EFLD]MSGREL;[EFLD]MSGFILNOR
        If !fstat
          this.EDQ.EDIQRYM(WPOS).FILDES    = [EXF]FILDES
          this.EDQ.EDIQRYM(WPOS).TYPFIL    = [EXF]TYPFIL
#          this.EDQ.EDIQRYM(WPOS).CODDBA    = [EXF]CODDBA # X3-60422 (JUCON 18/10/2017)
          this.EDQ.EDIQRYM(WPOS).ESF_VALID = [EXF]VALID
        Endif #SAM 122567 (JUCON 17/04/2017)
      Endif
    Next
    LogicClose File [ESF]
    LogicClose File [EXF] #SAM 122567 (JUCON 17/04/2017)
    LogicClose File [EMS]
    LogicClose File [EFLD]
  Endif

Return

