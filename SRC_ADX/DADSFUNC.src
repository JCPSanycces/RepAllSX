End

Funprog MENU(NOMZONE)
Value Char NOMZONE()
Local Char VARIA (20), RESULTAT(255)
Local Integer IMESS
Case NOMZONE
 When "[F:DFC]TAXWAG" :
  Case evalue(NOMZONE)
   When 1 : RESULTAT="02"
   When 2 : RESULTAT="01"
   When Default : RESULTAT="02"
  Endcase
 When "[M:DIA]TEST"
  Case evalue(NOMZONE)
  When 1,2 : RESULTAT="0"+ num$(3-evalue(NOMZONE))
  When Default : RESULTAT="01"
  Endcase
 When "[F:PRM]DENCODCOM"
  If [F:FCD]CRN<>""
   Case evalue(NOMZONE)
    When 1 : RESULTAT="03"
    When 2 : RESULTAT="05"
    When Default : RESULTAT=""
   Endcase
  Endif
 When "[M:DIA]CNTCODCOM"
  Case evalue(NOMZONE)
   When 1,2,3,4,5 : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT=""
  Endcase
 When Default:
   RESULTAT=""
Endcase
End RESULTAT

#########################################

Funprog TABLE(VARIA, NOMZONE)
Value Char VARIA ()
Value Char NOMZONE ()
Local Char VALZONE (50)
Local Integer I,NUMTAB
Local Char RESULTAT (100)
NUMTAB = evalue(VARIA)
VALZONE= evalue(NOMZONE)
If VALZONE<>""
 Read [ADI]CODE=NUMTAB;VALZONE
 If fstat<>0
# Erreur de lecture sur le fichier
  Call ECR_TRACE(mess(70,122,1)-"ATABDIV [ADI]",0) From GESECRAN
 Else
  RESULTAT=[F:ADI]A1
 Endif
Endif
End RESULTAT

