#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("ADV",GBIDC1,GBIDC2) From GOBJET
End

#---------------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBADVB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "INIMOD"      : Gosub INIMOD
 When "INICRE"      : Gosub INICRE
 When "OUVRE"       : Gosub OUVRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "CREATION"    : Gosub MAJ
 When "MODIF"       : Gosub MAJ
 When "LIENS"       : Gosub LIENS
 When "ANNULE"      : Gosub ANNULE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "SETBOUT"     : Gosub SETBOUT

 When "INIT"        : Gosub INIT    : # Action ADIVAL
 When "EXEC"        : Gosub EXEC

Endcase
If PSUBB
 Gosub ACTION From SUBADVB
Endif
Return

#------------------------------------#
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
Return

#------------------------------------#
$LIENS
NOTAB = [F:ADV]NUMTAB
OLDDEPNUM = num$([M]DEPNUM)
Call GRISE_DES
Call GRISE_LEG([F]NUMTAB)
Call GRISE_SOC([F]NUMTAB)
Return

#------------------------------------#
$RAZDUP
$RAZCRE
Call GRISE_LEG(0)
Call GRISE_SOC(0)
Return

#------------------------------------#
Subprog GRISE_LEG(NUM)
Value Integer NUM
### Si Dossier mono alors on grise le fhamp FLGLEG
If !func AFNC.ACTIV("LEG") or NUM=909
 Grizo FLGLEG
 If dim(OBLLEG)>0
  Grizo OBLLEG
 Endif
Else
 Actzo FLGLEG
 If dim(OBLLEG)>0
  Actzo OBLLEG
 Endif
Endif
End

#------------------------------------#
Subprog GRISE_SOC(NUM)
Value Integer NUM
If NUM=909
 Grizo FLGSOC
Else
 Actzo FLGSOC
Endif
End

#------------------------------------#
Subprog GRISE_DES
Local Char    ACTION(20)
Local Integer NUMTAB , OK , OKTRT
Call EXISTE_ADX("","","SUBADVB",OKTRT) From ORDSYS
If OKTRT>0
 NUMTAB = [M]NUMTAB
 OK     = 1
 ACTION = "AS_LIBEL"
 Gosub ACTION From SUBADVB
 If !OK
  Call LECTEXTRA([M]LNGDES,"ATABTAB","LNGDES",num$([M]NUMTAB),"") From ATEXTRA
  Diszo LNGDES
 Else
  Actzo LNGDES
 Endif
Endif
End

#------------------------------------#
$INICRE
[F:ADV]NUMCAR = num$([F:ADV]NUMTAB)
Return

$INIMOD
Return

#------------------------------------#
$OUVRE
Local Char    OLDDEPNUM(10)
Local Char    DESIG(GLONDES)
Local Integer NOTAB
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If clalev([F:ADI])=0  : Local File ATABDIV [ADI]  : Endif
Return

#------------------------------------#
$SET_TBLAN
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN
Raz NBLAN , TBLAN
For [AXX]AXX1(1) Where CODFIC="ATABDIV" & IDENT1="901" & LANGUE<>"" & LANGUE<>"imp" & LANGUE<>GLANGUE
 NBLAN += 1
 TBLAN(NBLAN) = [F:AXX]LANGUE
Next AXX
Return

#------------------------------------#
$APRES_MODIF
Case COUZON
 When "NUMTAB"
  OLDDEPNUM=""
Endcase
Return

#------------------------------------#
$MAJ
Call MAJTEXTRA([M]LNGDES,"ATABTAB","LNGDES",num$([M]NUMTAB),"") From ATEXTRA
Call MAJTEXTRA([M]SHODES,"ATABTAB","SHODES",num$([M]NUMTAB),"") From ATEXTRA

#Exigence 53267
For I=0 To dim([F:ADV]COLALPTYP)-1
  Call MAJTEXTRA([M]COLALPDES(I),"ATABTAB","COLALPDES",num$([M]NUMTAB),num$(I)) From ATEXTRA
Next I
For I=0 To dim([F:ADV]COLNUMTYP)-1
  Call MAJTEXTRA([M]COLNUMDES(I),"ATABTAB","COLNUMDES",num$([M]NUMTAB),num$(I)) From ATEXTRA
Next I

If dim([F:AXX]LANORI)>0
 If dim(TBLAN)<0 : Gosub SET_TBLAN : Endif
 #Exigence 53267
 For I=0 To dim([F:ADV]COLALPTYP)-1
   Call MAJTEXADV([M]COLALPDES(I),"ATABTAB","COLALPDES",num$([M]NUMTAB),num$(I),TBLAN,NBLAN)
 Next I
 For I=0 To dim([F:ADV]COLNUMTYP)-1
   Call MAJTEXADV([M]COLNUMDES(I),"ATABTAB","COLNUMDES",num$([M]NUMTAB),num$(I),TBLAN,NBLAN)
 Next I
 Call MAJTEXADV([M]LNGDES,"ATABTAB","LNGDES",num$([M]NUMTAB),"",TBLAN,NBLAN)
 Call MAJTEXADV([M]SHODES,"ATABTAB","SHODES",num$([M]NUMTAB),"",TBLAN,NBLAN)
Endif
Return

#------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="ATABTAB" & IDENT1=num$([L]CODE)
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",num$([L]CODE)) From GLOCK : Return
Endif
Return

#------------------------------------#
$VERIF_MOD

# BUG 77148
Local Integer T_OLD_LNG
Local Integer T_NEW_LNG
Local Integer VERIFOK

VERIFOK = 1

Read [F:ADV]CODE = [M]NUMTAB
If !fstat
 T_OLD_LNG = [F:ADV]LNG
 T_NEW_LNG = [M]LNG
 # in case user decrease the max length of code,
 # need to check in ATABDIV if there's already a code longer than the new length
 If T_NEW_LNG < T_OLD_LNG
  For [ADI]CODE Where NUMTAB = [M]NUMTAB
   If len([F:ADI]CODE)> T_NEW_LNG
    VERIFOK = 0
    Break
   Endif
  Next
 Endif
Endif

If !VERIFOK
 Call ERREUR(func AFNC.MES1(mess(87,143,1), [F:ADI]CODE)) From GESECRAN
 OK = 0
 Return
Endif

If ([M]DEPNUM <> val(OLDDEPNUM)) and [M]DEPNUM <> 0
 If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
 If clalev([F:AMP])=0 : Local File AMSKPAR [AMP] : Endif
 Filter [ATZ] Where CODTYP = "ADI"
 For[ATZ]
  Read[AMP]CODPAR =2;[F:ATZ]CODFIC;[F:ATZ]CODZONE;"ADI"
  If !fstat
   If [AMP]VALPAR = OLDDEPNUM
    VERIFOK = 0
    Break
   Endif
  Endif
 Next
 Filter [ATZ]
Endif
If !VERIFOK
 # Vous aller modifier une dépendance utilisé par
 Call AVERTIR(mess(100,133,1)-[F:ATZ]CODFIC,OK) From GESECRAN
 If OK<>2
  OK = 0
 Else
  OK = 1
 Endif
Endif
Return

#------------------------------------#
$INIT
Local File AMSKZON [AMZ9]
Local Integer NUMADI , OKMSK
Local Char    PARADI(80) , MASQUE(GLONAMK) , TYPADI(GLONATY)
Local Char    APPLI(GLONADS)
TYPADI = "ADI"
TIT = mess(144,133,1) : # Revalidation des écrans
TMP = 1
Return

#------------------------------------#
$EXEC
Call OUVRE_TRACE(TIT) From LECFIC
APPLI = nomap
Gosub OUVFIC From VALMSKLEC
For [AMZ9]CODTYP(2) Where CODTYP=TYPADI
 MASQUE = [F:AMZ9]CODMSK
 OKMSK  = 0
 For [AMZ9]CODTYP
  Read [AMP]CODPAR = 1;MASQUE;[F:AMZ9]CODZON;TYPADI
  If !fstat
   PARADI = [F:AMP]VALPAR
   If find(left$(PARADI,1),'"',"'")
    PARADI = seg$(PARADI,2,len(PARADI)-1)
   Endif
   NUMADI = val(PARADI)
   If NUMADI=[M:ADV1]NUMTAB
    OKMSK = 1 : Break
   Endif
  Endif
 Next
 If OKMSK
  Call VALID(MASQUE,APPLI,1,GLANGUE,1,OK) From VALMSK
 Endif
Next
Call FERME_TRACE From LECFIC
FIN = 1
TRA = 1
Return

#------------------------------------------------------------------------------#
# Il faut que les intitulés soient créés dans toutes les langues du dossier
# pour éviter d'avoir des titres de colonnes vides quand on se connecte dans
# langue différente de la langue de création.
#------------------------------------------------------------------------------#

Subprog MAJTEXADV(VALEUR,TABLE,CHAMP,CLE1,CLE2,TBLAN,NBLAN)
Value    Char    VALEUR, TABLE, CHAMP, CLE1, CLE2, TBLAN()(1..)
Value    Integer NBLAN

Local Integer NOLAN

If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_MAJTEX
Else
 Gosub MAJTEX
Endif
End

$TR_MAJTEX
Trbegin [AXX]
 Gosub MAJTEX
 If GOK=-1 : Goto ROLL_MAJTEX
 Elsif GOK<1 : Goto AB_MAJTEX
 Endif
Commit
Return

$AB_MAJTEX
Rollback
Return

$ROLL_MAJTEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJTEX : Endif

$MAJTEX
If pat(nomap,"X3REF*")
 Readlock [AXX]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
 If fstat=1
  GOK=-1 : GLOCK="$ATEXTRA"-TABLE-CHAMP-GLANGUE-CLE1-CLE2
 Elsif fstat
  Raz [F:AXX]
  [F:AXX]CODFIC = TABLE
  [F:AXX]ZONE   = CHAMP
  [F:AXX]LANGUE = GLANGUE
  [F:AXX]TEXTE  = VALEUR
  [F:AXX]LANORI = GLANGUE
  [F:AXX]IDENT1 = CLE1
  [F:AXX]IDENT2 = CLE2
  Call FLDCRE("AXX") From OBJDIV
  Write [AXX]
  If fstat
   GOK=0 : Call FSTA("AXX") From GLOCK
  Endif
 Endif
Else
 For NOLAN=1 To NBLAN
  Readlock [AXX]AXX0 = TABLE;CHAMP;TBLAN(NOLAN);CLE1;CLE2
  If fstat=1
   GOK=-1 : GLOCK="$ATEXTRA"-TABLE-CHAMP-TBLAN(NOLAN)-CLE1-CLE2 : Break
  Elsif fstat
   Raz [F:AXX]
   [F:AXX]CODFIC = TABLE
   [F:AXX]ZONE   = CHAMP
   [F:AXX]LANGUE = TBLAN(NOLAN)
   [F:AXX]TEXTE  = VALEUR
   [F:AXX]LANORI = GLANGUE
   [F:AXX]IDENT1 = CLE1
   [F:AXX]IDENT2 = CLE2
   Call FLDCRE("AXX") From OBJDIV
   Write [AXX]
   If fstat
    GOK=0 : Call FSTA("AXX") From GLOCK : Break
   Endif
  Endif
 Next NOLAN
Endif
Return

#-----------------------------------------------------------------#
# Utilisé pour BERYL - Non utilisé sur bouton "copie"
#-----------------------------------------------------------------#

$TRTCOP
If [M]DOSORG=nomap
 Local File ATABTAB  [ADV1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".ATABTAB"  [ADV1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File ATABTAB  [ADV2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".ATABTAB"  [ADV2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ADV1], [AXX1], [ADV2], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [ADV2]
 Delete [ADV2] Where NUMTAB=val(TABLE)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATABTAB" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADV2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ADV1]CODE Where NUMTAB=val(TABLE)
  [F:ADV2] = [F:ADV1]

  If dim([F:AXX2]LANORI)>0
   If dim(TBLAN)<=0 : Gosub SET_TBLAN2 : Endif
   Call COPTEXADV("ATABTAB","LNGDES",TABLE,"",TBLAN,NBLAN)
   Call COPTEXADV("ATABTAB","SHODES",TABLE,"",TBLAN,NBLAN)
   #Exigence 53267
   For I=0 To dim([F:ADV1]COLALPTYP)-1
    Call COPTEXADV("ATABTAB","COLALPDES",TABLE,num$(I),TBLAN,NBLAN)
   Next I
   For I=0 To dim([F:ADV1]COLNUMTYP)-1
    Call COPTEXADV("ATABTAB","COLNUMDES",TABLE,num$(I),TBLAN,NBLAN)
   Next I
  Endif

  Call COPTEXTRA("ATABTAB","LNGDES",TABLE,"") From ATEXTRA
  Call COPTEXTRA("ATABTAB","SHODES",TABLE,"") From ATEXTRA

  #Exigence 53267
  For I=0 To dim([F:ADV1]COLALPTYP)-1
   Call COPTEXTRA("ATABTAB","COLALPDES",TABLE,num$(I)) From ATEXTRA
  Next I
  For I=0 To dim([F:ADV1]COLNUMTYP)-1
   Call COPTEXTRA("ATABTAB","COLNUMDES",TABLE,num$(I)) From ATEXTRA
  Next I


  If dim([F:ADV2]UPDUSR)>0 : [F:ADV2]UPDUSR = GUSER : Endif
  If dim([F:ADV2]UPDDAT)>0 : [F:ADV2]UPDDAT = date$ : Endif
  If dim([F:ADV2]UPDTIM)>0 : [F:ADV2]UPDTIM = time  : Endif
  Write [ADV2]
  If fstat
   GOK=0 : Call FSTA("ADV2") From GLOCK : Break
  Endif
 Next ADV1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#---------------------------------#
$SET_TBLAN2
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN
Raz NBLAN , TBLAN
For [AXX2]AXX1(1) Where CODFIC="ATABDIV" & IDENT1="901" & LANGUE<>"" & LANGUE<>"imp" & LANGUE<>GLANGUE
 NBLAN += 1
 TBLAN(NBLAN) = [F:AXX2]LANGUE
Next AXX2
Return

#----------------------------------------------------------------------#
Subprog COPTEXADV(TABLE,CHAMP,CLE1,CLE2,TBLAN,NBLAN)
Value    Char    TABLE, CHAMP, CLE1, CLE2, TBLAN()(1..)
Value Integer NBLAN

Local Integer NOLAN
Read[AXX1]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If !fstat
For NOLAN=1 To NBLAN
 Readlock [AXX2]AXX0 = TABLE;CHAMP;TBLAN(NOLAN);CLE1;CLE2
 If fstat=1
  GOK=-1 : GLOCK="$ATEXTRA"-TABLE-CHAMP-TBLAN(NOLAN)-CLE1-CLE2 : Break
 Elsif fstat
  Raz [F:AXX2]
  [F:AXX2]CODFIC = TABLE
  [F:AXX2]ZONE   = CHAMP
  [F:AXX2]LANGUE = TBLAN(NOLAN)
  [F:AXX2]TEXTE  = [F:AXX1]TEXTE
  [F:AXX2]LANORI = GLANGUE
  [F:AXX2]IDENT1 = CLE1
  [F:AXX2]IDENT2 = CLE2
  Call FLDCRE("AXX2") From OBJDIV
  Write [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Elsif [F:AXX2]LANORI<>""
  [F:AXX2]TEXTE  = [F:AXX1]TEXTE
  Call FLDUPD("AXX2") From OBJDIV
  Rewrite [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Endif
Next NOLAN
Endif
End

#-------------------------------------------------------------------------------#
Subprog MAJADV(COD,APPLI)
Value Char COD , APPLI
Local Integer NUMTAB , OK , ANU , AUG
NUM = val(COD)
If NUM=0 : End : Endif
If clalev([F:ADS])=0
 Local File ADOSSIER [ADS]
 Read [ADS]DOSSIER=APPLI
Endif
If [F:ADS]DOSREF<>""
 Local File =[F:ADS]DOSREF+".ATABTAB" [ADV]
Else
 Local File ATABTAB [ADV]
Endif
Local File =APPLI+".ATABTAB" [DADV] , =APPLI+".ATABDIV" [DADI]
Trbegin [DADV]
 Read [ADV]CODE=NUM
 If !fstat
  Read [DADV]CODE=NUM
  If !fstat
   AUG = 0
   ANU = 0
   OK = 1
   If [F:DADV]LNG<[F:ADV]LNG
    AUG = 1
   Elsif [F:DADV]LNG>[F:ADV]LNG
    OK = 0
   Endif
   If ([F:DADV]DEPNUM=0 & [F:ADV]DEPNUM<>0) or ([F:DADV]DEPNUM<>0 & [F:ADV]DEPNUM<>0 & [F:DADV]DEPNUM<>[F:ADV]DEPNUM)
    OK = 0
   Elsif [F:DADV]DEPNUM<>0 & [F:ADV]DEPNUM=0
    ANU = 1
   Endif
   If OK
    If ANU or AUG
     [F:DADV]LNG = [F:ADV]LNG
     [F:DADV]DEPNUM = [F:ADV]DEPNUM
     Rewrite [DADV]
     If fstat
      Call ERREUR("ATABTAB",2) From DOSDIC
     Else
      If ANU
       Update [DADI] Where NUMTAB=[L]NUM With DEPCOD=""
       If fstat
        Call ERREUR("ATABDIV",2) From DOSDIC
       Endif
      Endif
      # Le paramètrage de la table diverse # a été mis à jour
      Call ECR_TRACE(func AFNC.MES(mess(195,125,1),COD),0) From GESECRAN
     Endif
    Endif
   Else
    # Le paramètrage de la table diverse # doit être mis à jour manuellement
    Call ECR_TRACE(func AFNC.MES(mess(196,125,1),COD),-1) From GESECRAN
   Endif
  Endif
 Endif
Commit
Close Local File [ADV] , [DADV] , [DADI]
End

#-------------------------------------------------------------------------------#
Subprog C_NUMTAB(VALEUR)
Variable Decimal VALEUR
Local Integer MAXVAL
MAXVAL = 29999
If VALEUR>MAXVAL
 GMESSAGE = func AFNC.MES(mess(115,75,1),num$(MAXVAL)) : # Valeur trop grande (maximum #)
 mkstat = 2 : End
Endif
End

Subprog AM_NUMTAB(VALEUR)
Variable Decimal VALEUR
End

Subprog IB_NUMTAB
End

Subprog B1_NUMTAB(VALEUR)
Variable Decimal VALEUR
End

Subprog C_DEPNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
 End
Endif
If [M]NUMTAB = VALEUR
 GMESSAGE = mess(45,105,1) : # Lien impossible
 mkstat = 2
Else
 Call LECTURE("ADV",num$(VALEUR),"") From CONTOBJ
 If fstat>0
  GMESSAGE = mess(32,133,1) : # Table inexistante
  mkstat = 2
 Else
  If [F:ADV]ACS<>"" & GUSRACS<>2
   Read [ACC]CODACC = [F:ADV]ACS
   If fstat or [F:ACC]MODIF<>2
    GMESSAGE = mess(94,133,1) : # Table non accessible
    mkstat = 2
   Endif
  Endif
 Endif
 Call LECTURE("ADV",num$([M]NUMTAB),"") From CONTOBJ
Endif
End

$C_ALPHA
If VALEUR<>""
 Call LECTURE("ATY",VALEUR,"") From CONTOBJ
 If [F:ATY]TYPTYP<>7 & [F:ATY]TYPTYP<>8
  GMESSAGE = mess(14,133,1) : # Type de données incorrect
  mkstat = 2 : Return
 Endif
 If VALEUR="ADI"
   OKSUP = 1
 Elsif [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OKSUP = 1 : Endif
 Endif
Endif
Return

$C_NUM
If VALEUR<>""
 Call LECTURE("ATY",VALEUR,"") From CONTOBJ
 If find([F:ATY]TYPTYP,7,8,9,10)
  GMESSAGE = mess(14,133,1) : # Type de données incorrect
  mkstat = 2 : Return
 Endif
 If [F:ATY]TYPTYP=1
  OKSUP = 1
 Elsif [F:ATY]OBJLIEN<>""
  Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
  If [F:AOB]LIBPAR<>0 : OKSUP = 1 : Endif
 Endif
Endif
Return

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
If VALEUR>GLONADI
 GMESSAGE = mess(122,123,1)-"("+num$(GLONADI)+")" : # Longueur trop grande
 mkstat = 2 : End
Endif
End

Subprog AS_LNGDES(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_SHODES(VALEUR)
Variable Char    VALEUR()
End

Subprog IB_NBCOL
End

Subprog AS_COLALPTYP(VALEUR)
Variable Char    VALEUR()
If [M]COLALPDES(nolign-1)="" : mkstat = 1 : End : Endif
End

Subprog C_COLALPTYP(VALEUR)
 Variable Char    VALEUR()
 Local Integer OKSUP
 Gosub C_ALPHA
 If mkstat : End : Endif
 If !OKSUP
  Effzo [M]COLALPSUP(nolign-1)
  Grizo [M]COLALPSUP(nolign-1)
 Else
  Actzo [M]COLALPSUP(nolign-1)
 Endif
End

Subprog AS_COLALPSUP(VALEUR)
Variable Char    VALEUR()
Local Integer OKSUP
Call LECTURE("ATY",[M]COLALPTYP(nolign-1),"") From CONTOBJ
If [M]COLALPTYP(nolign-1)="ADI"
 OKSUP = 1
Elsif [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OKSUP = 1 : Endif
Endif
If !OKSUP : mkstat = 1 : End : Endif
End

Subprog AS_COLNUMTYP(VALEUR)
Variable Char    VALEUR()
If [M]COLNUMDES(nolign-1)="" : mkstat = 1 : End : Endif
End

Subprog C_COLNUMTYP(VALEUR)
 Variable Char    VALEUR()
 Local Integer OKSUP
 Gosub C_NUM
 If mkstat : End : Endif
  If !OKSUP
  Effzo [M]COLNUMSUP(nolign-1)
  Grizo [M]COLNUMSUP(nolign-1)
 Else
  Actzo [M]COLNUMSUP(nolign-1)
 Endif
End

Subprog AS_COLNUMSUP(VALEUR)
Variable Char    VALEUR()
Local Integer OKSUP
Call LECTURE("ATY",[M]COLNUMTYP(nolign-1),"") From CONTOBJ
If [F:ATY]TYPTYP=1 or [M]COLNUMTYP(nolign-1)="ADI"
 OKSUP = 1
Elsif [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OKSUP = 1 : Endif
Endif
If !OKSUP : mkstat = 1 : End : Endif
End

Subprog C_COLALPDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Effzo [M]COLALPTYP(nolign-1)
 Effzo [M]COLALPSUP(nolign-1)
Endif
End

Subprog C_COLNUMDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Effzo [M]COLNUMTYP(nolign-1)
 Effzo [M]COLNUMSUP(nolign-1)
Endif
End
