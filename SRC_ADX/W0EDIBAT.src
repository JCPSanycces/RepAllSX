#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EDIBAT 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone NUM
mkstat = 0
zoncou = "NUM"
indice = 0
WNUM = [M]NUM
If varmode([M]NUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUM" : Gosub ACTION From =IMPTRT
 Endif
 If [M]NUM=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NUM" : GZNUM = 41947 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NUM([M]NUM) From EDIBATSTD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NUM" : GZNUM = 41947 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]NUM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_NUM([M]NUM) From EDIBATSTD
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "NUM" : GZNUM = 41947 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CATTYP
mkstat = 0
zoncou = "CATTYP"
indice = 0
IMPENT = [M]CATTYP
If varinit([M]CATTYP,indice)=0
 IMPENT = 1
Endif
[M]CATTYP = IMPENT

## Zone CATACT
mkstat = 0
zoncou = "CATACT"
indice = 0
IMPENT = [M]CATACT
If varinit([M]CATACT,indice)=0
 IMPENT = 1
Endif
[M]CATACT = IMPENT

## Zone ALLFLO
mkstat = 0
zoncou = "ALLFLO"
indice = 0
IMPENT = [M]ALLFLO
If varinit([M]ALLFLO,indice)=0
 IMPENT = 1
Endif
[M]ALLFLO = IMPENT

## Zone DUPLICATEFLG
mkstat = 0
zoncou = "DUPLICATEFLG"
indice = 0
IMPENT = [M]DUPLICATEFLG
If varinit([M]DUPLICATEFLG,indice)=0
 IMPENT = 1
Endif
[M]DUPLICATEFLG = IMPENT

## Zone TESTFLG
mkstat = 0
zoncou = "TESTFLG"
indice = 0
IMPENT = [M]TESTFLG
If varinit([M]TESTFLG,indice)=0
 IMPENT = 1
Endif
[M]TESTFLG = IMPENT

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone FLG
mkstat = 0
zoncou = "FLG"
IMPENT = [M]FLG(indice)
WNUM = IMPENT
If varinit([M]FLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLG,indice)=0
 [M]FLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLG(IMPENT) From EDIBATSTD
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLG" : GZNUM = 51308 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_FLG(IMPENT) From EDIBATSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FLG" : GZNUM = 51308 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]FLG(indice) = IMPENT

## Zone OPERATOR
mkstat = 0
zoncou = "OPERATOR"
IMPENT = [M]OPERATOR(indice)
If varinit([M]OPERATOR,indice)=0
 IMPENT = 1
Endif
[M]OPERATOR(indice) = IMPENT

## Zone FLDTYPTYP
mkstat = 0
zoncou = "FLDTYPTYP"
IMPENT = [M]FLDTYPTYP(indice)
If varinit([M]FLDTYPTYP,indice)=0
 IMPENT = 1
Endif
[M]FLDTYPTYP(indice) = IMPENT

## Zone MANDATORY
mkstat = 0
zoncou = "MANDATORY"
IMPENT = [M]MANDATORY(indice)
If varinit([M]MANDATORY,indice)=0
 IMPENT = 1
Endif
[M]MANDATORY(indice) = IMPENT

## Zone REPFLDVAL1
mkstat = 0
zoncou = "REPFLDVAL1"
WCHAR = [M]REPFLDVAL1(indice)
If varmode([M]REPFLDVAL1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REPFLDVAL1" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_REPFLDVAL1([M]REPFLDVAL1(indice)) From EDIBATSTD
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "REPFLDVAL1" : GZNUM = 828 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]REPFLDVAL1(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_REPFLDVAL1([M]REPFLDVAL1(indice)) From EDIBATSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "REPFLDVAL1" : GZNUM = 828 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone REPFLDVAL2
mkstat = 0
zoncou = "REPFLDVAL2"
WCHAR = [M]REPFLDVAL2(indice)
If varmode([M]REPFLDVAL2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REPFLDVAL2" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_REPFLDVAL2([M]REPFLDVAL2(indice)) From EDIBATSTD
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "REPFLDVAL2" : GZNUM = 829 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]REPFLDVAL2(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_REPFLDVAL2([M]REPFLDVAL2(indice)) From EDIBATSTD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "REPFLDVAL2" : GZNUM = 829 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "EDIBAT"
Return

