$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(40)(0..GNBDERNIER)
Local Char     A_BUF2(40)(0..GNBDERNIER)
Local Char     A_BUF3(20)(0..GNBDERNIER)
Local Char     A_BUF4(30)(0..GNBDERNIER)
Local Char     A_BUF5(30)(0..GNBDERNIER)
Local Date     A_BUF6(0..GNBDERNIER)
Local Integer  A_BUF7(0..GNBDERNIER)
Local Char     A_BUF8(20)(0..GNBDERNIER)
Local Char     A_BUF9(3)(0..GNBDERNIER)
Local Char     A_BUF10(3)(0..GNBDERNIER)
If clalev([F:PSNPD9])>0 : Close Local File [PSNPD9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(40),
& Char     A_TAB2(40),
& Char     A_TAB3(20),
& Char     A_TAB4(30),
& Char     A_TAB5(30),
& Date     A_TAB6,
& Integer  A_TAB7,
& Char     A_TAB8(20),
& Char     A_TAB9(3),
& Char     A_TAB10(3)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8,A_BUF9,A_BUF10
& As [PSNPD9]
Return

$LEC_DERLU
Read [AX3]AXX0="PJMSNPH";"DESAXX";GLANGUE;[F:PSNPD]SNPCOD;""
If fstat : Raz [F:AX3] : Endif
Read [AX4]AXX0="PJMSNPD";"DDESAXX";GLANGUE;[F:PSNPD]KEYEXT;""
If fstat : Raz [F:AX4] : Endif
Read [SNPH]PSNPH0=[F:PSNPD]SNPCOD
If fstat : Raz [F:SNPH] : Endif
Return

$CHARGE_DERLU
If clalev([F:PSNPD9])>0
 Read [PSNPD9] = [F:PSNPD9]A_TABI
 [L]CLE = [F:PSNPD9]A_TABC
Endif
Return

$REMP_DERLU
Return

$CLE_DERLU
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:PSNPD]KEYEXT"
Call TEXTE(1377,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PSNPD]KEYEXT"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SNPH]OPPNUM"
Call TEXTE(18260,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SNPH]OPPNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:PSNPD]SNPCOD"
Call TEXTE(5296,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PSNPD]SNPCOD"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(4)"
SELEXP(NBSEL) = "[F:AX3]TEXTE"
Call TEXTE(6468,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(5)"
SELEXP(NBSEL) = "[F:AX4]TEXTE"
Call TEXTE(282,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:PSNPD]SNPDDTECRE"
Call TEXTE(212,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "DZz:"+GFMDAT4+""
SELFOR(NBSEL) = "DZz:"+GFMDAT4
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PSNPD]SNPDDTECRE"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:PSNPD]SNPSEQ"
Call TEXTE(747,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 3
SELFMT(NBSEL) = "N:8F"
SELFOR(NBSEL) = "N:8#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PSNPD]SNPSEQ"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SNPH]SHOWGRP"
Call TEXTE(12102,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SNPH]SHOWGRP"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SNPH]UOM"
Call TEXTE(2685,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:3X"
SELFOR(NBSEL) = "K:3X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:SNPH]UOM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:SNPH]CUR"
Call TEXTE(501,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:3X"
SELFOR(NBSEL) = "K:3c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:SNPH]CUR"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:PSNPD_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AX3])=0 : Local file ATEXTRA [AX3] : Endif
If clalev([F:AX4])=0 : Local file ATEXTRA [AX4] : Endif
If clalev([F:SNPH])=0 : Local file PJMSNPH [SNPH] : Endif
Link [PSNPD] With
& [AX3]AXX0="PJMSNPH";"DESAXX";GLANGUE;[F:PSNPD]SNPCOD;"",
& [AX4]AXX0="PJMSNPD";"DDESAXX";GLANGUE;[F:PSNPD]KEYEXT;"",
& [SNPH]PSNPH0=[F:PSNPD]SNPCOD
& As [PSNPD_]
Return

$DEFAUT_LISTE
Default file [PSNPD_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1"
Local Char     A_BUFJ1(40)(1..GNBSEL)
Local Char     A_BUFJ2(15)(1..GNBSEL)
Local Char     A_BUFJ3(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(40),
& Char     A_TABJ2(15),
& Char     A_TABJ3(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..3)
Call TEXTE(1377,TITJOI(1)) From OBJDIV
TITJOI(2) = mess(59,100,1) : # Type
TITJOI(3) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:30X>10X"
LG = 0
TIT = ""
End

$LIENS
