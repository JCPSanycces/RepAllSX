If fstat : Raz [F:AX3] : Endif
Read [AX4]AXX0 = "PJMSNPD";"DDESAXX";GLANGUE;[F:PSNPD]KEYEXT;""
If fstat : Raz [F:AX4] : Endif
Read [SNPH]PSNPH0 = [F:PSNPD]SNPCOD
If fstat : Raz [F:SNPH] : Endif
Return

