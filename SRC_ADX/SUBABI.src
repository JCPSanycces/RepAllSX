Subprog AS_ZDIMINT(VALEUR)
Variable Char    VALEUR()
If [M]TYPFLD(nolign-1)<>3 : mkstat = 1 : End : Endif
If VALEUR = ""
 Read [ABI]ABI0 = [M:ABI2]DIMFAT(nolign-1)
 If !fstat
  [M:ABI2]DIMINT(nolign-1)    = [F:ABI]INTIT
  [M:ABI2]DIMVALINT(nolign-1) = [F:ABI]INTEVAL
  If [M:ABI2]DIMVALINT(nolign-1)<>"" : VALEUR = "$" : Endif
 Endif
Endif
End

Subprog C_ZDIMINT(VALEUR)
Variable Char    VALEUR()
End

Subprog C_INDLEC(VALEUR)
