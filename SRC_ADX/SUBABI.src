Call C_INDLEC(VALEUR) From SUBABV
End

Subprog AS_NBRDOS
If [M]TYPMAJ<>3 : mkstat=1 : Endif
End

Subprog AS_MULDOS(VALEUR)
Variable Integer VALEUR
If [M]TYPMAJ=3 : mkstat=1 : Endif
End

