#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet ABI
Raz GPILOBJ,GNBMASKOUV
#
# test merge
Call OBJET("ABI",GBIDC1,GBIDC2) From GOBJET
End


#-------------------------------------------------------------------#
$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_LISTE"  : Gosub VERF_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

#-------------------------------------------------------------------#
$OUVRE
If clalev([F:ABI2])=0 : Local File ABIDIM   [ABI2] : Endif
If clalev([F:ATX])=0  : Local File ATEXTE   [ATX]  : Endif
If clalev([F:AHH])=0  : Local File ABIHIERA [AHH]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET   [AOB]  : Endif
If filinfo(filpath("FIL","AVIEWTAB","fde"),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde"),0)<0
 Local File ATABLE  [AVWT]
 Local File ATABZON [AVWF]
 Local File ATABIND  [AVWI]
Else
 Local File AVIEWTAB [AVWT]
 Local File AVIEWFLD [AVWF]
 Local File AVIEWIND [AVWI]
Endif
Local Char TABFAT(GLONABI)(0..30)
Local Integer NBTABFAT
Local File AVIEW [AVW]
Return

#-------------------------------------------------------------------#
$LIENS
Call TEXTE([M:ABI0]INTIT,[M:ABI0]ZINTIT) From OBJDIV
Raz nolign
For [ABJ]ABJ0 Where CODDIM=[M]CODDIM
 nolign += 1
 [M:ABI2] = [F:ABJ]
 Call TEXTE([M:ABI2]INTDIM(nolign-1),[M:ABI2]ZINTDIM(nolign-1)) From OBJDIV
 Call TEXTE([M:ABI2]AUTO(nolign-1),[M:ABI2]ZAUTO(nolign-1)) From OBJDIV
 Call TEXTE([M:ABI2]DIMINT(nolign-1),[M:ABI2]ZDIMINT(nolign-1)) From OBJDIV
Next ABJ
[M:ABI2]NBRFLD = nolign
For nolign=1 To [M]NBRLNK
 [M]SUMLNK(nolign-1) = [M]TABLNK(nolign-1)+"~"+[M]ABRLNK(nolign-1)
Next nolign
For nolign =1 To [M:ABI2]NBRFLD
 Gosub GRISE_TUNNEL
Next nolign
Raz TABFAT,NBTABFAT
Return


#---------------------------#
$CREATION
For nolign=1 To [M:ABI2]NBRFLD
 Raz [F:ABJ]
 [F:ABJ] = [M:ABI0]
 [F:ABJ] = [M:ABI2]
 [F:ABJ]NUMDIM = nolign
 Write [ABJ]
 If fstat
  GOK=0 : Call FSTA("ABJ") From GLOCK : Break
 Endif
Next nolign
Return

#---------------------------#
$MODIF
Delete [ABJ] Where CODDIM=[M]CODDIM
If fstat=1 : GOK=-1 : GLOCK="$ABIDIMFLD" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ABJ") From GLOCK : Return
Endif
Gosub CREATION
Return

#---------------------------#
$APRES_MODIF
If ( zoncou = "FLDDIM" | status = 65 ) & [M]FLDDIM(nolign-1) <> ""
 OK =1
 For [AHH]AHH0
  For I=0 To [AHH]NBAHH-1
   If ([AHH]CODDIM1(I) = [M]CODDIM  & [AHH]FLDDIM1(I) = [M]FLDDIM(nolign-1))|
&     ([AHH]CODDIM2(I) = [M]CODDIM  & [AHH]FLDDIM2(I) = [M]FLDDIM(nolign-1))|
&     ([AHH]CODDIM3(I) = [M]CODDIM  & [AHH]FLDDIM3(I) = [M]FLDDIM(nolign-1))|
&     ([AHH]CODDIM4(I) = [M]CODDIM  & [AHH]FLDDIM4(I) = [M]FLDDIM(nolign-1))|
&     ([AHH]CODDIM5(I) = [M]CODDIM  & [AHH]FLDDIM5(I) = [M]FLDDIM(nolign-1))|
&     ([AHH]CODDIM6(I) = [M]CODDIM  & [AHH]FLDDIM6(I) = [M]FLDDIM(nolign-1))
    GMESSAGE = func AFNC.TEXTE([F:AHH]DES)
    GMESSAGE = func AFNC.MES2(mess(68,148,1),[M]FLDDIM(nolign-1),[F:AHH]COD-"("+GMESSAGE+")")
    OK = 0  : Break
   Endif
  Next I
 Next AHH
Endif
Return

#--------------------------#
$VERIF_CRE
$VERIF_MOD
Local Integer OKD , NBDIM , FLINFO
Local Char    TBDIM(GLONABI)(1..50) , DIMDEF(GLONAVA)
Local Char    CLE(GLONAVA)(1..16)
Local Integer NBCLE

GMESSAGE = ""
If [M]NBRFLD=0
 GMESSAGE = mess(52,148,1) : # Il doit y avoir au moins un champ
 zonsui = "[ABI2]NBRFLD"
 OK = 0 : Return
Endif
If [M]TYPMAJ=1  # Incremental
 I = find(2,[M:ABI1]FLDDAT(0..[M:ABI1]NBRLNK))
 If !I
  Read [AVWF]CODZONE = [M]TABORG;"CREDAT"
  If fstat : GMESSAGE -= "CREDAT" : Endif
  Read [AVWF]CODZONE = [M]TABORG;"UPDDAT"
  If fstat : GMESSAGE -= "UPDDAT" : Endif
  If GMESSAGE<>""
   GMESSAGE = func AFNC.MES1(mess(37,148,1),[M]TABORG)-":"-GMESSAGE : # La table XXX ne comporte pas le champ
   OK = 0 : zonsui = "[ABI1]TABORG" : Return
  Endif
 Else
  Read [AVWF]CODZONE = [M]TABLNK(I-1);"CREDAT"
  If fstat : GMESSAGE -= "CREDAT" : Endif
  Read [AVWF]CODZONE = [M]TABLNK(I-1);"UPDDAT"
  If fstat : GMESSAGE -= "UPDDAT" : Endif
  If GMESSAGE<>""
   GMESSAGE = func AFNC.MES1(mess(37,148,1),[M]TABLNK(I-1))-":"-GMESSAGE : # La table XXX ne comporte pas le champ
   OK = 0 : zonsui = "[ABI1]TABORG" : Return
  Endif
 Endif
Endif
If find([M]TYPMAJ,1,3) # Incremental or Incremental audit
    If func CHECK_INCUPD(nomap, [M:ABI1]TABORG, [M:ABI1]INDLEC, [M:ABI2]FLDDIM, [M:ABI2]FLDORG, [M:ABI2]NBRFLD, [M:ABI2]CLE, GMESSAGE)<>[V]CST_AOK
        # From V12 we block if the setup is not correct
        GMESSAGE = mess(169,148,1)+chr$(13)+GMESSAGE
        OK=0
        Return
    Endif
Endif

For I=0 To [M:ABI2]NBRFLD-1
 If [M:ABI2]DIMFAT(I)<>"" & !find([M:ABI2]DIMFAT(I),TBDIM(1..NBDIM))
  NBDIM += 1
  TBDIM(NBDIM) = [M:ABI2]DIMFAT(I)
 Endif
 If [M:ABI2]TYPFLD(I)=2
  FLINFO = 1
 Elsif [M:ABI2]TYPFLD(I)=1 & DIMDEF=""
  DIMDEF = [M:ABI2]FLDDIM(I)
 Endif
Next I
If FLINFO & DIMDEF=""
 GMESSAGE = mess(65,148,1) : # Il doit y avoir au moins un champ de type dimension
 zonsui = "[ABI2]NBRFLD"
 OK = 0 : Return
Endif
For I=0 To [M:ABI2]NBRFLD-1
 If [M:ABI2]TYPFLD(I)=2
  If [M:ABI2]FLDLIE(I)=""
   [M:ABI2]FLDLIE(I) = DIMDEF : Affzo [ABI2]FLDLIE(I)
  Else
   K = find([M:ABI2]FLDLIE(I),[M:ABI2]FLDDIM(0..[M:ABI2]NBRFLD-1))
   If !K or [M:ABI2]TYPFLD(K-1)<>1
    [M:ABI2]FLDLIE(I) = DIMDEF : Affzo [ABI2]FLDLIE(I)
   Endif
  Endif
 Endif
Next I
#For I=1 To NBDIM
# Read [ABI2]ABI0 = TBDIM(I)
# CHAINE = [F:ABI2]CLE
# Gosub DEFCLE
# For K=1 To NBCLE
#  OKD = 0
#  For J=0 To [M:ABI2]NBRFLD-1
#   If [M:ABI2]DIMFAT(J)=TBDIM(I) & [M:ABI2]DIMFLD(J)=CLE(K) & !find(TBDIM(I),TABFAT(0..30))
#    OKD = 1 : Break
#   Endif
#  Next J
#  If !OKD
#   GMESSAGE = mess(24,148,1)-":"-TBDIM(I)+"\"+CLE(K)+":"+mess(25,148,1) : # Dimension..Champ non défini
#   zonsui = "[ABI2]NBRFLD"
#   Call OUINON(GMESSAGE,OK) From GESECRAN
#   Raz GMESSAGE
#   If OK <> 2
#    OK = 0 : Break 2
#   Endif
#   TABFAT(NBTABFAT) = TBDIM(I)
#   NBTABFAT +=1
#  Endif
# Next K
#Next I
If !OK : Return : Endif
For I=0 To [M]NBRFLD-1
 If [M:ABI2]FLDLIE(I)<>"" & !find([M:ABI2]FLDLIE(I),[M]FLDDIM(0..[M]NBRFLD-1))
  GMESSAGE = mess(61,100,1)-num$(I+1)+"\"+[M:ABI2]FLDLIE(I)-":"-mess(26,148,1) : # Ligne..Objet inexistant
  zonsui = "[ABI2]FLDLIE("+num$(I)+")"
  OK = 0 : Break
 Endif
Next I
If !OK : Return : Endif
CHAINE = [M:ABI2]CLE
Gosub DEFCLE
For I=1 To NBCLE
 K = find(CLE(I),[M:ABI2]FLDDIM(0..[M:ABI2]NBRFLD-1))
 If K & [M:ABI2]ACTDIM(K-1)<>""
  GMESSAGE = mess(35,148,1)-"("+CLE(I)+")" : # Les champs de clé ne peuvent avoir de code activité
  zonsui = "[M:ABI2]ACTDIM("+num$(K-1)+")"
  OK = 0 : Break
 Endif
Next I
If !OK : Return : Endif
Return

#**
#* Check if incremental update is possible
#*
#* @param DOSSIER: folder name
#* @param TABORG : Origin table of dimension
#* @param INDLEC : index used to read TABORG
#* @param FLDDIM : array of dimension's fields
#* @param FLDORG : array of "loading formula" corresponding to FLDDIM
#* @param NBFLD  : number of elements in FLDDIM & FLDORG
#* @param KEYDIM : Key defined in the dimension
#* @param MSGERR : returned message if an error occurs
#* @return [V]CST_AOK if no error detected - [V]CST_AERROR if an error has been detected
#*!
Funprog CHECK_INCUPD(DOSSIER, TABORG, INDLEC, FLDDIM, FLDORG, NBFLD, KEYDIM, MSGERR)
Value Char    DOSSIER
Value Char    TABORG
Value Char    INDLEC
Value Char    FLDDIM()()
Value Char    FLDORG()()
Value Integer NBFLD
Value Char    KEYDIM
Variable Char MSGERR

Local File =DOSSIER+".ATABLE"    [AVWT]
Local File =DOSSIER+".ATABIND"   [AVWI]
Local File =DOSSIER+".ABIDIM"    [ABI]
Local File =DOSSIER+".ABIDIMFLD" [ABJ]

Local Char    CLE(GLONAVA)(1..16)
Local Integer NBCLE
Local Char    FLT(255)
Local Char    WRNFLD(255), ERRFLD(255)
Local Integer LRET
LRET = [V]CST_AOK
Raz MSGERR

# To facilitate search, transform a key like "FLD1-FLD2-FLD3+FLD4" to "+FLD1+FLD2+FLD3+FLD4+"
KEYDIM = "+" + ctrans(KEYDIM,"-","+") + "+"


# all elements of the key must be present in fields of the dimension
# if not, only "Cancels and replaces" is authorized
# 1- get fields of the key
If [L]INDLEC<>""
    Filter [AVWI] Where CODFIC=[L]TABORG & HOMONYM=1 & CODIND=[L]INDLEC
Else
    Filter [AVWI] Where CODFIC=[L]TABORG & HOMONYM=1
Endif
Read [AVWI]NUMLIG First
Filter [AVWI]
If fstat
    MSGERR = func AFNC.MES1(mess(171,148,1), [L]TABORG) # Key without homonym not found in table $1$
    LRET = [V]CST_AERROR
Else
    # 2- check if each element is used in dimension loading
    Read [AVWT]CODFIC=[L]TABORG
    Call SETCLE(NBCLE,CLE,[F:AVWI]DESCRIPT) From LNKSUB
    For I=1 To NBCLE
        I1 = find("["+[F:AVWT]ABRFIC+"]"+CLE(I),[L]FLDORG)              # Look for [xxx]field
        I1 = max(I1,find("[F:"+[F:AVWT]ABRFIC+"]"+CLE(I),[L]FLDORG))    # Look for [F:xxx]field
        If !I1 | !instr(1,KEYDIM,FLDDIM(I1-1))
            ERRFLD -= "[F:"+[F:AVWT]ABRFIC+"]"+CLE(I)
            LRET = [V]CST_AERROR
        Endif
    Next
    # Build the message to return with fields that must be checked
    If ERRFLD<>""
        # Following fields must assign directly the dimension (without formula) and be used in the key : $1$
        MSGERR = func AFNC.MES1(mess(170,148,1),ERRFLD)
    Endif
Endif


LogicClose File [AVWI]
LogicClose File [AVWT]
LogicClose File [ABI]
LogicClose File [ABJ]


End LRET

#--------------------------#
$APRES_MOD
Gosub APRES_CRE
Return

#--------------------------#
$APRES_CRE
If [M]CODDIM<>""
 Call VALIDATION([M]CODDIM,nomap,0)
Endif
Return

#----------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V1") From GOBJET
Endif
Return

#----------------------------------#
$EXEBOUT
Case BOUT
 When "V" : Call VALIDATION([M]CODDIM,nomap,0)
Endcase
Return

#--------------------------#
$AP_ANNULE
Local Char PREF(4)
Local Integer STAT
Call SET_PREF([L]CODE,PREF)
If filinfo(filpath("TRT",PREF+[L]CODE,"src",0),0)>0
 Call EFFACE(filpath("TRT",PREF+[L]CODE,"src",0),STAT) From ORDSYS
 Call EFFACE_ADX("","",PREF+[L]CODE,STAT) From ORDSYS
Endif
Return

#---------------------------#
$SEL_TABLE
OBJET = "ABJ"
OPTIONS = "|"
If PARAM(1)<>""
 CRITERE  = 'CODDIM = "'+PARAM(1)+'"'
 ORDRE = 'FLDDIM'
Else
 CRITERE = '1=1'
 ORDRE = 'CODDIM;FLDDIM'
Endif
START = 'FLDDIM'
Return

#----------------------------------#
Subprog SET_PREF(CODE,PREF)
Value Char CODE
Variable Char PREF
If len(CODE)=10 & GLONADC=12
 PREF = "WM"
Else
 PREF = "WMD"
Endif
End

#########################################################
## Pour les patches des transactions
#########################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------#
# Appelé en validation dossier
#------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","ABIDIM","fde",APPLI),0)<=0 : End : Endif
If clalev([F:AB2])=0 : Local File =APPLI+".ABIDIM"    [AB2] : Endif
For [AB2]
 Call ECR_TRACE([F:AB2]CODDIM,0) From GESECRAN
 Call VALIDATION([F:AB2]CODDIM,APPLI,1)
Next AB2
End

#---------------------------------------------------------#
# Pour synchroniser les dimensions
#---------------------------------------------------------#

Subprog VALIDATION(CODE,DOSSIER,SILENCE)
Value    Char    CODE
Value    Char    DOSSIER
Value    Integer SILENCE

Local Char     NOMPROG(GLONADC) , FICSRC(GDIMFIC)
Local Char     SAVIFS(10) , SAVIRS(10) , IDENT(20)
Local Integer  SAVIUM
Local Integer  I , J , K , L , OK , NBCLE , NBLNK , NBVAR , NBTAB
Local Char     CHAINE(250) , CHAINE2(250) , MAGIC(80) , PREF(4) , FILTRE(250)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Char     CLE(GLONAVA)(1..16)
Local Char     TBCLE(GLONANX)(1..16)
Local Char     TBLNK(250)(1..16) , TBTAB(GLONATB)(1..16) , TBABR(GLONABR)(1..16)
Local Char     TCLE(GLONANX)(1..16),TBTYPLNK(2)(0..16)
Local Integer  TBTYP(1..16),TTYP(1..16)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:ABI])>0 : Close Local File [ABI] : Endif
If clalev([F:ABJ])>0 : Close Local File [ABJ] : Endif
If clalev([F:ATY])>0 : Close Local File [ATY] : Endif

If clalev([F:AVWT])>0 : Close Local File [AVWT] : Endif
If clalev([F:AVWF])>0 : Close Local File [AVWF] : Endif
If clalev([F:AVWI])>0 : Close Local File [AVWI] : Endif
If clalev([F:AVW])>0 : Close Local File [AVW] : Endif

If clalev([F:ABI])=0 : Local File =DOSSIER+".ABIDIM"    [ABI] : Endif
If clalev([F:ABJ])=0 : Local File =DOSSIER+".ABIDIMFLD" [ABJ] : Endif
If clalev([F:ATY])=0 : Local File =DOSSIER+".ATYPE"     [ATY] : Endif
If clalev([F:ABZ])=0 : Local File =DOSSIER+".AVIEW" [AVW] : Endif

If filinfo(filpath("FIL","AVIEWTAB","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 Local File =DOSSIER+".ATABLE"   [AVWT]
 Local File =DOSSIER+".ATABZON"  [AVWF]
 Local File =DOSSIER+".ATABIND"  [AVWI]
Else
 Local File =DOSSIER+".AVIEWTAB" [AVWT]
 Local File =DOSSIER+".AVIEWFLD" [AVWF]
 Local File =DOSSIER+".AVIEWIND" [AVWI]
Endif

MAGIC   = mess(77,133,1) : # Superviseur Adonix
Call SET_PREF(CODE,PREF)
NOMPROG = PREF+CODE
IDENT   = "## BI-DIMENSION ##"

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

Read [ABI]ABI0=CODE
If !fstat
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If I<=1
  OK = 1
 Elsif !OK
  # Ce traitement est déjà utilisé par un autre paramètrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(10,148,1)-CODE : # Règle d'alimentation
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#-------------------------------------------------------#
$ETIQ
If [F:ABI]NBRLNK>0
 Raz NBLNK , NBVAR , NBTAB
 For L=1 To [F:ABI]NBRLNK
  If [F:ABI]TABLNK(L-1)<>""
   K = 1
   If [F:ABI]ABRLNK(L-1)="" or instr(1,format$("KTv2:250X",[F:ABI]EXPLNK(L-1)),'func')
    Look [AVWT]CODFIC=[F:ABI]TABLNK(L-1)
    If fstat : K = 0 : Endif
   Endif
   If K
    NBLNK += 1
    If [F:ABI]EXPLNK(L-1)=""
     NBTAB += 1 : TBLNK(NBLNK) = ""
    Else
     TBLNK(NBLNK) = format$("KTv2:250X",[F:ABI]EXPLNK(L-1))
    Endif
    TBTAB(NBLNK) = [F:ABI]TABLNK(L-1)
    TBCLE(NBLNK) = [F:ABI]CLELNK(L-1)
    If [F:ABI]TYPLNK(L-1)=3
     [L]TBTYPLNK(NBLNK) = "~="
    Else
     [L]TBTYPLNK(NBLNK) = "="
    Endif
    If [F:ABI]ABRLNK(L-1)<>""
     TBABR(NBLNK) = [F:ABI]ABRLNK(L-1)
    Else
     Read [AVWT]CODFIC=[F:ABI]TABLNK(L-1)
     TBABR(NBLNK) = [F:AVWT]ABRFIC
    Endif
    Read [AVWT]CODFIC = TBTAB(NBLNK)
    If !fstat : TBTYP(NBLNK) = [F:AVWT]TYPFIC : Endif
    # Pour remplacer le func dans un lien par une variable au préalable évaluée d'après le func
    If instr(1,TBLNK(NBLNK),'func')
     Read [AVWI]CODIND=[F:ABI]TABLNK(L-1);[F:ABI]CLELNK(L-1)
     Call SETCLE(NBCLE,CLE,[F:AVWI]DESCRIPT) From LNKSUB
     CHAINE = TBLNK(NBLNK)
     Raz TBLNK(NBLNK) , NBCLE
     While CHAINE<>""
      NBCLE += 1
      K = instr(1,CHAINE,";")
      If K
       CHAINE2 = left$(CHAINE,K-1)
       CHAINE = right$(CHAINE,K+1)
      Else
       CHAINE2 = CHAINE
       CHAINE = ""
      Endif
      If instr(1,CHAINE2,'func')
       Read [AVWF]CODZONE=[F:ABI]TABLNK(L-1);CLE(NBCLE)
       Read [ATY]CODTYP=[F:AVWF]CODTYP
       NBVAR += 1
       Case [F:ATY]TYPTYP
        When 1,2,3   : Wrseq 'Local Integer AVAR'+num$(NBVAR)
        When 4,5,6   : Wrseq 'Local Decimal AVAR'+num$(NBVAR)
        When 8       : Wrseq 'Local Date    AVAR'+num$(NBVAR)
        When Default : Wrseq 'Local Char    AVAR'+num$(NBVAR)+'(30)'
       Endcase
       Wrseq 'AVAR'+num$(NBVAR)+' = '+CHAINE2
       CHAINE2 = 'AVAR'+num$(NBVAR)
      Endif
      If TBLNK(NBLNK)<>""
       TBLNK(NBLNK) += ";"
      Endif
      TBLNK(NBLNK) += CHAINE2
     Wend
    Endif
   Endif
  Endif
 Next L
Endif
Wrseq '$OUVRE'
Wrseq 'Local Char FILTRE(250)'
Read [AVWT]CODFIC=[F:ABI]TABORG
If !fstat
 If [F:AVWT]TYPFIC<>3
  Wrseq 'OUVTAB = GDOSSIER+".'+[F:ABI]TABORG+'" : ';
 Else
  Wrseq 'OUVTAB = "'+[F:ABI]TABORG+'" : ';
 Endif
 Wrseq 'If clalev([F:'+[F:AVWT]ABRFIC+'])=0 : Local File =OUVTAB ['+[F:AVWT]ABRFIC+'] : Endif'
 For I=1 To NBLNK
  If TBTYP(I)<>3
   Wrseq 'OUVTAB = GDOSSIER+".'+TBTAB(I)+'" : ';
  Else
   Wrseq 'OUVTAB = "'+TBTAB(I)+'" : ';
  Endif
  Wrseq 'If clalev([F:'+TBABR(I)+'])=0 : Local File =OUVTAB ['+TBABR(I)+'] : Endif'
 Next I
 If NBLNK=NBTAB
  If [F:AVWT]TYPFIC<>3
   Wrseq 'OUVTAB = GDOSSIER+".'+[F:ABI]TABORG+'" : ';
  Else
   Wrseq 'OUVTAB = "'+[F:ABI]TABORG+'" : ';
  Endif
  Wrseq 'If clalev([F:A_])=0 : Local File =OUVTAB [A_] : Endif'
 Endif
 Wrseq 'OUVTAB = "Link ['+[F:AVWT]ABRFIC+']"'
 Wrseq "Link ["+[F:AVWT]ABRFIC+"] With"
 K = 0
 For I=1 To NBLNK
  If K=0
   K = 1
  Else
   Wrseq ","
  Endif
  Wrseq "& ["+TBABR(I)+"]"+TBCLE(I)-[L]TBTYPLNK(I)-TBLNK(I);
 Next I
 If K : Wrseq : Endif
 If NBLNK=NBTAB
  Read [AVWI]NUMLIG=[F:ABI]TABORG;1
  Call SETCLE(NBCLE,CLE,[F:AVWI]DESCRIPT) From LNKSUB
  Wrseq "& [A_]"+[F:AVWI]CODIND+"=";
  For I=1 To NBCLE
   If I>1 : Wrseq ";"; : Endif
   Wrseq "["+[F:AVWT]ABRFIC+"]"+CLE(I);
  Next I
  Wrseq
 Endif
 Wrseq "& As [LNK_]"
 ## ajout du order by
 If [F:ABI]INDLEC<>""
  Read [AVWI]CODIND = [F:ABI]TABORG;[F:ABI]INDLEC
 Else
  Read [AVWI]NUMLIG=[F:ABI]TABORG;1
 Endif
 Call SETCLE(NBCLE,CLE,[F:AVWI]DESCRIPT) From LNKSUB
 # Si le filtre contient l'instruction func on ne le rajoute pas dans le link
 FILTRE = format$("KTv2:250X",[F:ABI]FILTRE)
 If FILTRE<>"" & !instr(1,FILTRE,"func")
  Wrseq "& Where"-FILTRE
  FILTRE = ""
 Endif
 Wrseq "& Order By Key CLE = " ;
 For I=1 To NBCLE
  If I>1 : Wrseq ";"; : Endif
  Wrseq "["+[F:AVWT]ABRFIC+"]"+CLE(I);
 Next I
 Wrseq ""
Endif
If instr(1,FILTRE,'"')
 Wrseq "FILTRE = '"+FILTRE+"'"
Else
 Wrseq 'FILTRE = "'+FILTRE+'"'
Endif
Wrseq "Return"
Wrseq
Wrseq "$FERME"
Read [AVWT]CODFIC=[F:ABI]TABORG
If !fstat
 Wrseq "If clalev([F:"+[F:AVWT]ABRFIC+"]) : Close local File ["+[F:AVWT]ABRFIC+"] : Endif"
Endif
For I=1 To NBLNK
 Wrseq "If clalev([F:"+TBABR(I)+"]) : Close local File ["+TBABR(I)+"] : Endif"
Next I
If NBLNK=NBTAB
 Wrseq "If clalev([F:A_]) : Close local File [A_] : Endif"
Endif
Wrseq "Return"
Wrseq

Local Char FORMULE(250)
Gosub CHARGE_FLD

Wrseq "$DCLE"
Call SETCLE(NBCLE,CLE,[F:ABI]CLE) From LNKSUB
 For I=1 To NBCLE
  Read [F:AVWF]CODZONE = [F:ABI]TABORG;CLE(I)
  If !fstat
   Read [ATY]CODTYP = [F:AVWF]CODTYP
   If !fstat
    TTYP(I) = [F:ATY]TYPTYP
   Endif
  Endif
  If TTYP(I)=0 : TTYP(I) = 7 : Endif
 Next
Wrseq 'Local Char    DCLE(GLONAVA)(1..'+num$(NBCLE)+')'
Wrseq 'Local Integer DTYP(1..'+num$(NBCLE)+')'
Wrseq 'Local Integer NBDCLE'
Wrseq 'NBDCLE = '+num$(NBCLE)
For I=1 To NBCLE
 Wrseq 'DCLE('+num$(I)+') = "'+CLE(I)+'"'
 Wrseq 'DTYP('+num$(I)+') =  '+num$(TTYP(I))
Next I
Wrseq "Return"
Wrseq

Wrseq "$CHARGE_CLE"
For I=1 To NBCLE
 K =1
 FORMULE = TBFOR(find(CLE(I),TBFLD(1..NBFLD)))
 If FORMULE<>""
  Wrseq "If dim([F:AAA_]"+CLE(I)+")>0"
  #If !instr(1,FORMULE,'"')
  # Wrseq space$(1)+'FORMULE = "'+FORMULE+'"'
  #Elsif !instr(1,FORMULE,"'")
  # Wrseq space$(1)+"FORMULE = '"+FORMULE+"'"
  #Else
  # K=0
  #Endif
  If K
   #Wrseq space$(1)+"[F:AAA_]"+CLE(I)-"= evalue(FORMULE)"
   Wrseq space$(1)+"[F:AAA_]"+CLE(I)-"="-FORMULE
  Endif
  Wrseq "Endif"
 Else
  #
 Endif
Next I
Wrseq "Return"
Wrseq


Wrseq "########################################################################"
Wrseq "# Return the filter necessary for incremental delete in synchroonization"
Wrseq "Subprog GET_FLTDELINC(PFLT)"
Wrseq "Variable Clbfile PFLT"
Read [AVWT]CODFIC=[F:ABI]TABORG
If [F:ABI]INDLEC<>""
  Read [AVWI]CODIND = [F:ABI]TABORG;[F:ABI]INDLEC
Else
  Read [AVWI]NUMLIG=[F:ABI]TABORG;1
Endif
Call SETCLE(NBTCLE,TCLE,[F:AVWI]DESCRIPT) From LNKSUB
Local Clbfile FLT(0)
FLT = 'PFLT = "1=1"'+adxirs
For I=1 To NBTCLE
 K =1
 I1 = find("["+[F:AVWT]ABRFIC+"]"+TCLE(I),[L]TBFOR)             # Look for [xxx]field
 I1 = max(I1,find("[F:"+[F:AVWT]ABRFIC+"]"+TCLE(I),[L]TBFOR))    # Look for [F:xxx]field
 If I1 & find(TBFLD(I1),CLE)>0
  Append FLT, 'Append PFLT, " & [F:AAA_]'+TBFLD(I1)+'='+[L]TBFOR(I1)+'"'+adxirs
 Else
  FLT = 'Raz PFLT   # Key is not complete => impossible to define a filter for incrementale deletion'
  Break
 Endif
Next I
Wrseq FLT
Wrseq "End"
Wrseq

Wrseq "$MAJFLD"
For I=1 To NBFLD
 Wrseq "### "-TBFLD(I)
 Wrseq '[L]FLD="'+TBFLD(I)+'"'
 If instr(1,TBFOR(I),"'")
  Wrseq '[L]FORMULE="'+TBFOR(I)+'"'
 Else
  Wrseq "[L]FORMULE='"+TBFOR(I)+"'"
 Endif
 Wrseq "If dim([F:AAA_]"+TBFLD(I)+")>0"
 FORMULE = TBFOR(I)
 K = instr(1,FORMULE,"[F]")
 While K
  FORMULE= left$(FORMULE,K+1)+":AAA_"+right$(FORMULE,K+2)
  K = instr(K,FORMULE,"[F]")
 Wend
 K=1
 If FORMULE<>"" & FORMULE<>'""' & FORMULE<>"''"
  #If !instr(1,FORMULE,'"')
  # Wrseq space$(1)+'FORMULE = "'+FORMULE+'"'
  #Elsif !instr(1,FORMULE,"'")
  # Wrseq space$(1)+"FORMULE = '"+FORMULE+"'"
  #Else
  # K =0
  #Endif
  If K
   If TBMES(I) : # Mesure
    #Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= evalue(FORMULE)"
    Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"="-TBFOR(I)
   Elsif TBNUM(I)<>""
    If left$(TBNUM(I),3)="ADI"
     Wrseq space$(1)+"GBIDC1 = evalue(FORMULE)"
     Wrseq 'Call LECTEXTRA([AAA_]'+TBFLD(I)+',"ATABDIV","LNGDES","'+right$(TBNUM(I),4)+'",GBIDC1) From ATEXTRA'
    Else
     #Wrseq space$(1)+"K   = max(1,val(num$(evalue(FORMULE))))"
     Wrseq space$(1)+"K   = max(1,val(num$("+TBFOR(I)+")))"
     Case TBTYP(I)
      When 1       : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= K"
      When Default : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= mess(K,"+right$(TBNUM(I),2)+",1)"
     Endcase
    Endif
   Else
    #Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= evalue(FORMULE)"
    Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"="-TBFOR(I)
   Endif
  Endif
 Else
  Wrseq "FORMULE = ''"
  Case TBTYP(I)
   When 1,2,3,4,5,6 : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= 0"
   When 8           : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= [0/0/0]"
   When Default     : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= ''"
  Endcase
 Endif
 Wrseq "Endif"
 Wrseq ""
Next I
Wrseq ""
Wrseq "Return"
Return


$CHARGE_FLD
Local Integer  NBFLD
Local Integer  MAXFLD  : MAXFLD= 250
Local Char     TBFLD(GLONAVA)(1..MAXFLD) , TBFOR(250)(1..MAXFLD) , TBNUM(10)(1..MAXFLD)
Local Integer  TBMES(1..MAXFLD) , TBTYP(1..MAXFLD)
Local Integer  NBTCLE
Local Char     TCLE(GLONAVA)(1..16),ABR_TABORG(GLONABR)

Raz NBFLD
For [ABJ] Where CODDIM=[F:ABI]CODDIM
 If [F:ABJ]FLDDIM<>""
  NBFLD += 1
  TBFLD(NBFLD) = [F:ABJ]FLDDIM
  TBFOR(NBFLD) = [F:ABJ]FLDORG
  TBNUM(NBFLD) = ""
  Read [ATY]CODTYP=[F:ABJ]CODTYP
  If [F:ATY]CODTYP=[F:ABJ]CODTYP
   If find([F:ATY]CODTYP,"AXX","ATX")
    TBTYP(NBFLD) = GLONDES
   Elsif [F:ATY]CODTYP="ADI" & [F:ABJ]TYPFLD=2 : # Information
    TBTYP(NBFLD) = GLONDES
    TBNUM(NBFLD) = "ADI"+num$([F:ABJ]TABDIV)
   Elsif [F:ABJ]TYPFLD=2 & [F:ATY]TYPTYP=1 : # Information et menu local
    TBTYP(NBFLD) = GLONDES
    TBNUM(NBFLD) = "M"+num$([F:ABJ]MENLOC)
   Else
    TBTYP(NBFLD) = [F:ATY]TYPTYP
   Endif
  Else
   TBTYP(NBFLD) = 11
  Endif
 Endif
Next ABJ

For I=1 To NBFLD
 K = instr(1,TBFOR(I),"[F]")
 While K
  TBFOR(I) = left$(TBFOR(I),K+1)+":AAA_"+right$(TBFOR(I),K+2)
  K = instr(K,TBFOR(I),"[F]")
 Wend
Next I

Return

#-------------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "FLDLIE"
  Local Char    TEX(15)(1..200) , TEXTE(30)(1..200,1..2)
  Local Integer NBTEX
  NBTEX = 0
  For I=0 To [M]NBRFLD-1
   If [M]TYPFLD(I)= 1
    NBTEX += 1 : TEX(NBTEX) = [M]FLDDIM(I) : TEXTE(NBTEX,2) = [M]ZINTDIM(I)
   Endif
  Next I
  TIT(1) = mess(37,100,1) : # Code
  TIT(2) = mess(30,109,1) : # Intitulé
 When "LISTYPDAT"
  Local Char TIT(30)(0..2) , OVALEUR(10)
  TIT(1) = mess(37,100,1) : # Code
  TIT(2) = mess(30,109,1) : # Intitulé
  Gosub SET_TYPDAT
  OVALEUR = VALEUR
Endcase
Return

$SET_TYPDAT
Local Char    TEX(1)(1..200) , TEXTE(30)(1..200,1..2)
Local Integer NBTEX
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = "D" : TEXTE(NBTEX,2) = mess(1,7825,1)  : # Jour
NBTEX += 1 : TEX(NBTEX) = "W" : TEXTE(NBTEX,2) = mess(2,7825,1)  : # Semaine
NBTEX += 1 : TEX(NBTEX) = "T" : TEXTE(NBTEX,2) = mess(3,7825,1)  : # Décade
NBTEX += 1 : TEX(NBTEX) = "F" : TEXTE(NBTEX,2) = mess(4,7825,1)  : # Quinzaine
NBTEX += 1 : TEX(NBTEX) = "M" : TEXTE(NBTEX,2) = mess(5,7825,1)  : # Mois
NBTEX += 1 : TEX(NBTEX) = "Q" : TEXTE(NBTEX,2) = mess(6,7825,1)  : # Trimestre
NBTEX += 1 : TEX(NBTEX) = "S" : TEXTE(NBTEX,2) = mess(7,7825,1)  : # Semestre
NBTEX += 1 : TEX(NBTEX) = "Y" : TEXTE(NBTEX,2) = mess(8,7825,1)  : # Année
NBTEX += 1 : TEX(NBTEX) = "C" : TEXTE(NBTEX,2) = mess(124,148,1) : # Création hiérachie de dates
# NBTEX += 1 : TEX(NBTEX) = "R" : TEXTE(NBTEX,2) = "Jointure externe"  : # Jointure Externe
Return

#------------------------------#
$VERF_LISTE
Case LISTE
 When "LISTYPDAT"
  If !instr(1,OVALEUR,VALEUR)
   VALEUR = OVALEUR+VALEUR
  Else
   VALEUR = OVALEUR
  Endif
  mkstat = 2
Endcase
Return

#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ABIDIM    [ABI1]
 Local File ABIDIMFLD [ABJ1]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".ABIDIM"    [ABI1]
 Local File =[M]DOSORG+".ABIDIMFLD" [ABJ1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ABIDIM    [ABI2]
 Local File ABIDIMFLD [ABJ2]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".ABIDIM"    [ABI2]
 Local File =[M]DOSDES+".ABIDIMFLD" [ABJ2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ABI1] , [ABJ1], [ATX1] , [ABJ2] , [ABI2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ABI2], [ABJ2] , [ATX2]
 Delete [ABI2] Where CODDIM=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABIDIM" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABI2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ABJ2] Where CODDIM=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABIDIMFLD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABJ2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ABI1] Where CODDIM=TABLE
  [F:ABI2] = [F:ABI1]
  Call COPTEXTE([F:ABI1]INTIT,[F:ABI2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ABI2]
  If fstat
   GOK = 0 : Call FSTA("ABI2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ABJ1] Where CODDIM=TABLE
  [F:ABJ2] = [F:ABJ1]
  Call COPTEXTE([F:ABJ1]INTDIM,[F:ABJ2]INTDIM) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ABJ2]
  If fstat
   GOK = 0 : Call FSTA("ABJ2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-------------------------------------------------------------------#
Subprog AM_FLDDIM(VALEUR)
Variable Char VALEUR()
Local Integer NBTEX , NUM
Local Char    TEX(50)(0..50) , INTIT(30)
NBTEX = 0
For [ABJ]DICO Where FLDDIM = VALEUR
 NBTEX += 1
 Call TEXTE([F:ABJ]INTDIM,INTIT) From OBJDIV
 TEX(NBTEX) =  format$("K:11X",[F:ABJ]CODDIM)+format$("K:4X",[F:ABJ]CODTYP)
 TEX(NBTEX) += format$("Nz:5F",[F:ABJ]LNG)+" "+INTIT
 If NBTEX>=dim(TEX)-1 : Break : Endif
Next
If NBTEX
 Call SAITEX(NBTEX,TEX,NUM,mess(108,123,1)-VALEUR) From GESECRAN
 If NUM<>0 & status<>7
  Read [ABI]ABI0 = vireblc(left$(TEX(NUM),10),2)
  Read [ABJ]ABJ1 = [F:ABI]CODDIM;VALEUR
  [M] = [F:ABJ]
  Call TEXTE([F:ABJ]INTDIM,[M:ABI2]ZINTDIM(nolign-1)) From OBJDIV
 Endif
Endif
End

$ERR
# pour bonnet a cause du patch en avance de phase. il existe pas encore ce subprog dans contobj
Resume

Subprog C_FLDDIM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]FLDDIM(nolign-1)
 Onerrgo ERR
 Call PLAGE_ZON([M]CODDIM,VALEUR) From CONTOBJ
 If mkstat : End : Endif
 Onerrgo
Endif
End

Subprog AVANT_NBRFLD
GBIDC1 = [M]FLDDIM(nolign-1)
End

Subprog APRES_NBRFLD
Local Integer I , J , NOL
Local Char    CHAINE(80)
NOL = nolign-1
If status<>6 & GBIDC1<>"" & [M]FLDDIM(NOL)<>GBIDC1
 For I=0 To [M]NBRFLD-1
  If [M]FLDLIE(I)=GBIDC1
   [M]FLDLIE(I) = [M]FLDDIM(NOL) : Affzo FLDLIE(I)
  Endif
 Next I
 CHAINE = [M]CLE
 I = 0
 While I<=len(CHAINE)
  J = instr(I+1,CHAINE,"+")
  If J=0 : J=len(CHAINE)+1 : Endif
  If seg$(CHAINE,I+1,J-1)=GBIDC1
   CHAINE = left$(CHAINE,I)+[M]FLDDIM(NOL)+right$(CHAINE,J)
  Endif
  I = J
 Wend
 If CHAINE<>[M]CLE
  [M]CLE = CHAINE : Affzo CLE
 Endif
Endif
End

Subprog C_NBRFLD
Local Integer I , J , NOL
Local Char    CHAINE(80) , NCLE(80) , CHAMP(GLONAVA)
If status=83 or status=68
 For NOL=nolign-1 To nolign1-1
  Gosub ANUCOD
 Next NOL
Elsif status=65
 NOL = nolign-1
 Gosub ANUCOD
Endif
End

$ANUCOD
For I=0 To [M]NBRFLD-1
 If [M]FLDLIE(I)=[M]FLDDIM(NOL)
  [M]FLDLIE(I) = "" : Affzo FLDLIE(I)
 Endif
Next I
CHAINE = [M]CLE
NCLE   = ""
While CHAINE<>""
 J = instr(1,CHAINE,"+")
 If J
  CHAMP  = left$(CHAINE,J-1)
  CHAINE = right$(CHAINE,J+1)
 Else
  CHAMP  = CHAINE
  CHAINE = ""
 Endif
 If CHAMP<>[M]FLDDIM(NOL)
  If NCLE<>"" : NCLE += "+" : Endif
  NCLE += CHAMP
 Endif
Wend
If NCLE<>[M]CLE
 [M]CLE = NCLE : Affzo CLE
Endif
Return

Subprog C_INTEVAL(VALEUR)
Variable Char    VALEUR()
Local Integer    ERN
Local Char       INTITULE(80)
If VALEUR = "" & [M:ABI0]ZINTIT = ""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
If VALEUR = "" : End : Endif
Onerrgo ERCALC
INTITULE = evalue(VALEUR)
If ERN : GMESSAGE = mess(65,106,1)-":"-errmes$(ERN) : mkstat = 2 : End : Endif
If instr(1,evalue(VALEUR),",")
 GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
 mkstat = 2 : End
Endif
End

$ERCALC
ERN = errn
Resume

Subprog C_ZINTDIM(VALEUR)
Variable Char    VALEUR()
Local Char       INTITULE(80)
Local Integer    I,ERN
If VALEUR <> "$"
 If instr(1,VALEUR,",")
  GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
 INTITULE = VALEUR
 [M:ABI2]INTVALDIM(nolign-1) = ""
Else
 If [M:ABI2]INTVALDIM(nolign-1) <> ""
  Onerrgo ERCALC
  INTITULE = evalue([M:ABI2]INTVALDIM(nolign-1))
  If ERN : Errbox mess(65,106,1)-":"-errmes$(ERN) : mkstat = 2 : End : Endif
  If instr(1,INTITULE,",")
   GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
   mkstat = 2 : End
  Endif
 Else
  GMESSAGE = "$"-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
Endif
For I=0 To dim([M:ABI2]ZINTDIM)-1
 If I <> nolign-1
  If [M:ABI2]ZINTDIM(I) <> "$"
   If INTITULE = [M:ABI2]ZINTDIM(I)
    GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : Break
   Endif
  Else
   If INTITULE = evalue([M:ABI2]INTVALDIM(I))
    GMESSAGE = mess(131,123,1)-":"-mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : Break
   Endif
  Endif
 Endif
Next I
End

Subprog C_TYPMAJ(VALEUR)
Variable Integer VALEUR
#bug BI : ABIMAJBAS is wrong with 2 fact tables 107560
#If VALEUR <> 3 & dim([M]NBRDOS)>0
# Effzo [M]NBRDOS,ADXDOS
#Else
# If dim([M]MULDOS)>0 : Effzo MULDOS : Endif
#Endif
End

Subprog C_CODTYP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
If find([F:ATY]TYPTYP,9,10) or find(VALEUR,"AXX","AX1","AX2","AX3","ATX") : # Pas de blob/clob, textes trad
 GMESSAGE = mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : End
Elsif VALEUR="ACS"
 K = find("ACS",[M]CODTYP(0..nolign-2),[M]CODTYP(nolign..[M]NBRFLD-1))
 If K
  GMESSAGE = mess(51,148,1) : # Il ne peut y avoir qu'un seul code d'accès
  mkstat = 2 : End
 Endif
Endif
[M:ABI2]CODTYP(nolign-1) = VALEUR : Gosub GRISE_TUNNEL
End

Subprog AS_MENLOC(VALEUR)
Variable Decimal VALEUR
If [M]CODTYP(nolign-1) = "ADI" : mkstat =1 : End : Endif
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If ([F:ATY]TYPTYP<>1 | [F:ATY]NOLIB<>0) & [F:ATY]OBJLIEN<>"ADI" : mkstat=1 : End : Endif
End

Subprog AS_TABDIV(VALEUR)
Variable Decimal VALEUR
If [M]CODTYP(nolign-1) <> "ADI" : mkstat =1 : End : Endif
End

Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [F:ATY]FORTYP<>"" | [F:ATY]LNGTYP<>0 | [F:ATY]TYPTYP=1 | [F:ATY]TYPTYP=8 | find([F:ATY]TYPTYP,11,12)  : mkstat=1 : End : Endif : # 119483 add Uuid/Datetime
End

Subprog D_LNG(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If !fstat & ([F:ATY]FORTYP="" | [F:ATY]LNGTYP=0) : # S'il s'agit d'un type de donnée standard
 Case [F:ATY]TYPTYP
  When 1       : VALEUR = 15  : # Libellé
  When 2       : VALEUR = 4   : # Entier Court
  When 3       : VALEUR = 8   : # Entier Long
  When 4       : VALEUR = 9.2 : # Décimal
  When 7       : VALEUR = 10  : # Alphanumérique
 Endcase
Endif
End

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
Local Decimal ENTIER , DECIM
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 1 : If DECIM<>0 | ENTIER>20 : mkstat=1 : Endif : # Libellé
 When 2 : If DECIM<>0 | ENTIER>4 : mkstat=1 : Endif  : # Entier court
 When 3 : If DECIM<>0 | ENTIER>8 : mkstat=1 : Endif  : # Entier long
 When 4 : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat=1 : Endif : # DCB
 When 7 : If DECIM<>0 | ENTIER>250 : mkstat=1 : Endif             : # Char
 When 8 : If DECIM<>0 | !find(ENTIER,4,6,8) : mkstat=1 : Endif   : # Date
Endcase
If mkstat : GMESSAGE = mess(111,123,1) : Endif : # Longueur incorrecte
End

Subprog AS_TYPDAT(VALEUR)
Variable Char    VALEUR()
Read [ATY]CODTYP=[M]CODTYP(nolign-1)
If [F:ATY]TYPTYP<>8 : mkstat = 1 : Endif
# If VALEUR="" : VALEUR = "YMQ" : Endif
End

Subprog C_TYPDAT(VALEUR)
Variable Char    VALEUR()
Gosub CTL_TYPDAT
End

$CTL_TYPDAT
Local Integer I
Local Char    C(1)
VALEUR = toupper(VALEUR)
If VALEUR<>""
 Gosub SET_TYPDAT
 I = 1
 While I<=len(VALEUR)
  C = mid$(VALEUR,I,1)
  If instr(1,left$(VALEUR,I-1),C)
   VALEUR = left$(VALEUR,I-1)+right$(VALEUR,I+1)
  Else
   If !find(C,TEX(1..NBTEX))
    Call ERREUR(mid$(VALEUR,I,1)-":"-mess(99,123,1)) From GESECRAN : # Option incorrecte
    mkstat = 1 : Break
   Endif
   I += 1
  Endif
 Wend
Endif
Return

Subprog D_TYPFLD(VALEUR)
Variable Integer VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [F:ATY]CODTYP="ADI" or find([F:ATY]TYPTYP,1,8)
 VALEUR = 1
Else
 VALEUR = 2
Endif
End

Subprog AS_TYPFLD(VALEUR)
Variable Integer VALEUR
If [M]CODTYP(nolign-1)="ACS" : # Code d'accès => technique
 VALEUR = 4 : mkstat = 2
Elsif find([M]CODTYP(nolign-1),"ADS","ADI") : # Dossier, tabdiv => dimension
 VALEUR = 1 : mkstat = 2
Endif
End

Subprog C_TYPFLD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
 If [F:ATY]TYPTYP=8
  Effzo TYPDAT(nolign-1)
 Endif
Endif
End

Subprog AS_ZAUTO(VALEUR)
Variable Char VALEUR
If [M]TYPFLD(nolign-1) <> 1
 mkstat = 1
Endif
End

Subprog C_ZAUTO(VALEUR)
Variable Char VALEUR
If [M]TYPFLD(nolign-1) <> 1 & VALEUR <> ""
 GMESSAGE = mess(27,148,1) : # Type d'objet incorrect
 mkstat =2 : End
Endif
If VALEUR <> "$"
 If instr(1,VALEUR,",")
  GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
 [M:ABI2]AUTOEVAL(nolign-1) = ""
Else
 If [M:ABI2]AUTOEVAL(nolign-1) <> ""
  Onerrgo ERCALC
  GBIDC1 = evalue([M:ABI2]AUTOEVAL(nolign-1))
  If ERN : Errbox mess(65,106,1)-":"-errmes$(ERN) : mkstat = 2 : End : Endif
  If instr(1,GBIDC1 ,",")
   GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
   mkstat = 2 : End
  Endif
 Else
  GMESSAGE = "$"-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_FLDLIE(VALEUR)
Variable Char    VALEUR()
If [M]TYPFLD(nolign-1)<>2 : mkstat = 1 : Endif
If VALEUR=""
 Local Integer I
 For I=nolign-2 To 0 Step-1
  If [M]TYPFLD(I)=1
   VALEUR = [M]FLDDIM(I) : Break
  Endif
 Next I
Endif
End

Subprog C_FLDLIE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 K = find(VALEUR,[M]FLDDIM(0..[M]NBRFLD-1))
 If !K
  GMESSAGE = mess(64,148,1) : # Dimension inexistante
  mkstat = 2 : End
 Elsif [M]TYPFLD(K-1)<>1
  GMESSAGE = mess(27,148,1) : # Type d'objet incorrect
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_DIMFAT(VALEUR)
Variable Char    VALEUR()
If [M]TYPFLD(nolign-1)<>3 : mkstat = 1 : Endif
End

Subprog C_DIMFAT(VALEUR)
Variable Char    VALEUR()
If VALEUR  = [M:ABI0]CODDIM
 GMESSAGE = mess(83,123,1) : #Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog AS_DIMFLD(VALEUR)
Variable Char    VALEUR()
If [M]TYPFLD(nolign-1)<>3  : mkstat = 1 : End : Endif
Read [ABI2]ABI0 = [M]DIMFAT(nolign-1)
If !instr(1,[F:ABI2]CLE,"+")
 VALEUR = [F:ABI2]CLE
 mkstat = 2 : End
Endif
End

Subprog C_DIMFLD(VALEUR)
Variable Char    VALEUR()
Local Integer I
Gosub SETCLE
If !find(VALEUR,CLE(1..NBCLE))
 GMESSAGE = mess(28,148,1) : # Champ de clé inexistant
 mkstat = 2 : End
Endif
End

$SETCLE
Local Char    CHAINE(250)
CHAINE = [F:ABI2]CLE

$DEFCLE
Local Integer NBCLE , K , L
Local Char    CLE(GLONAVA)(1..16)
NBCLE = 0
While CHAINE<>""
 K = instr(1,CHAINE,"+")
 L = instr(1,CHAINE,"-")
 If K & L
  K = min(K,L)
 Elsif L & !K
  K = L
 Endif
 NBCLE += 1
 If K
  CLE(NBCLE) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

Subprog S_DIMFLD(VALEUR)
Variable Char    VALEUR()
Local Integer I , NUMERO
Local Char    TBLIB(50)(0..16) , TEXTE(50)
Gosub SETCLE
For I=1 To NBCLE
 Read [ABJ]ABJ1 = [M]DIMFAT(nolign-1);CLE(I)
 Call TEXTE([F:ABJ]INTDIM,TEXTE) From OBJDIV
 TBLIB(I) = CLE(I)-TEXTE
Next I
Call SAITEX(NBCLE,TBLIB,NUMERO,mess(109,124,1)) From GESECRAN
If NUMERO
 VALEUR = CLE(NUMERO)
Endif
End

Subprog AS_FLDORG(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Read [AVWF]CODZONE = [M:ABI1]TABORG;[M]FLDDIM(nolign-1)
 If !fstat
  Read [AVWT]CODFIC = [M:ABI1]TABORG
  VALEUR = "[F:"+[F:AVWT]ABRFIC+"]"+[M]FLDDIM(nolign-1)
 Endif
Endif
End

Subprog C_CLE(VALEUR)
Variable Char    VALEUR()
CHAINE = VALEUR
Gosub DEFCLE
For I=1 To NBCLE
 If !find(CLE(I),[M]FLDDIM(0..[M]NBRFLD-1))
  GMESSAGE = CLE(I)-":"-mess(41,100,1) : # Champ inexistant
  mkstat = 2 : Break
 Endif
Next I
End

Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ABRLNK(VALEUR)
Variable Char    VALEUR()
[M]SUMLNK(nolign-1) = [M]TABLNK(nolign-1)+"~"+VALEUR
Call UNICITE2([M]SUMLNK(nolign-1),[M]NBRLNK,[M]SUMLNK) From OBJDIV
If mkstat : End : Endif
Call UNICITE2(VALEUR,[M]NBRLNK,[M]ABRLNK) From OBJDIV
If mkstat : End : Endif
End

$GRISE_TUNNEL
Local Integer OKK
Read [F:ATY]CODTYP = [M:ABI2]CODTYP(nolign-1)
If !fstat & [F:ATY]OBJLIEN <> ""
  Read [AOB]ABREV = [F:ATY]OBJLIEN
  If !fstat & [F:AOB]NOMFIC <> ""
   Read [AVWI]NUMLIG = [F:AOB]NOMFIC;1
   If !fstat & instr(1,[F:AVWI]DESCRIPT,"+")=0
    OKK = 1
   Endif
  Endif
Endif
GPE = 0
GPOINT = "ABITUNNEL" : Gosub ENTREE From EXEFNC
If !OKK
 [M:ABI2]TUNNEL(nolign-1) = 1
 Affzo [M:ABI2]TUNNEL(nolign-1)
 Grizo [M:ABI2]TUNNEL(nolign-1)
Else
 Actzo [M:ABI2]TUNNEL(nolign-1)
Endif
Return

Subprog AV_NAMCLE(VALEUR)
Variable Char    VALEUR()
If [M:ABI0]ABRDIM<>""
 VALEUR = "("+[M:ABI0]ABRDIM+"0)"
Else
 VALEUR = ""
Endif
End

Subprog AS_OPTJNT(VALEUR)
Variable Integer VALEUR
Local Integer I
If [M]TYPFLD(nolign-1)<>3 : VALEUR = 0 : mkstat = 1  : Endif
I = find([M]DIMFAT(nolign-1),[M]DIMFAT(0..[M]NBRFLD-1))
If nolign>I & I
 VALEUR = [M]OPTJNT(I-1)
 mkstat = 2
Endif
End

Subprog C_OPTJNT(VALEUR)
Variable Integer VALEUR
End

Subprog AM_OPTJNT(VALEUR)
Variable Integer VALEUR
Local Integer I
For I= 0 To [M]NBRFLD-1
 If [M]DIMFAT(I)=[M]DIMFAT(nolign-1) & I<>nolign-1
  [M]OPTJNT(I) = VALEUR
  Affzo [M]OPTJNT(I)
 Endif
Next I

End

Subprog B1_OPTJNT(VALEUR)
Variable Integer VALEUR
Local Char MESSA(250)
Case VALEUR
 When 1  : MESSA = [M:ABI0]CODDIM-":"-[M:ABI2]DIMFAT(nolign-1)
 When 2  : MESSA = [M:ABI0]CODDIM-"*:"-[M:ABI2]DIMFAT(nolign-1)
 When 3  : MESSA = [M:ABI0]CODDIM-":*"-[M:ABI2]DIMFAT(nolign-1)
Endcase
If MESSA<> ""
 Call MESSAGE(MESSA) From GESECRAN
Endif
End

Subprog AM_DIMFAT(VALEUR)
Variable Char    VALEUR()
Read [F:ABI]ABI0 = VALEUR
If !fstat & instr(1,[F:ABI]CLE,"+")>0 & !find(VALEUR,[M]DIMFAT(0..NBRFLD-1))
 Call MESSAGE(mess(120,148,1)-":"-[F:ABI]CLE) From GESECRAN
Endif
End

Subprog C_FLDDAT(VALEUR)
Variable Integer VALEUR
If mkstat : End : Endif
If VALEUR = 2
 Read [AVWF]CODZONE = [M]TABLNK(nolign-1);"CREDAT"
 If fstat : GMESSAGE -= "CREDAT" : Endif
 Read [AVWF]CODZONE = [M]TABLNK(nolign-1);"UPDDAT"
 If fstat : GMESSAGE -= "UPDDAT" : Endif
 If GMESSAGE<>""
  GMESSAGE = func AFNC.MES1(mess(37,148,1),[M]TABLNK(nolign-1))-":"-GMESSAGE : # La table XXX ne comporte pas le champ
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_FLDDAT(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2
 If find(2,[M:ABI1]FLDDAT(0..[M:ABI1]NBRLNK-1))
  mkstat = 1
 Endif
Endif
End

