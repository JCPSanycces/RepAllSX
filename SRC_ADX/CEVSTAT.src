#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestion du masque CEVSTAT
# Création
#     MABOS - 12/03/13 - FQ 88316 - US 1420 - Us 1528
#              - Campagnes d'entretiens - Suivi
######################################################################################


GACTION = "CEVSTAT"
PARAM(1) = ""
PARAM(2) = ""
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"CEVSTAT2","CEVSTAT","CEVSTAT",4,"") From GTRAITE
End



$ACTION
  Case ACTION
    When "INIT"       : Gosub INIT
    When "OUVRE"      : Gosub OUVRE
    When "CONTROLE"   : Gosub CONTROLE
    When "DEBUT"      : Gosub DEBUT
    When "BOUTON"     : Gosub BOUTON
    When "EXEC"       : Gosub EXEC
    When "FIN"        : Gosub FIN
    When "SORTIE"     : Gosub SORTIE
    When "TERMINE"    : Gosub TERMINE
  Endcase
Return

#**#####################################################################################
#*
#*!
$INIT
Global Integer WG_INI, GW_PRHACTIF
[V]WG_INI = 0
[V]GW_PRHACTIF = func IS_PRHACTIF
#[V]GW_PRHACTIF = 0
Return

$OUVRE
  # Ouverture des tables utilisées
  If clalev([F:FCY])=0    : Local File FACILITY    [FCY]    : Endif
  If clalev([F:CPY])=0    : Local File COMPANY     [CPY]    : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA      [HRPOA]  : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR    [HRCTR]  : Endif
  If clalev([F:ID])=0     : Local File EMPLOID     [ID]     : Endif
  If clalev([F:AD])=0     : Local File EMPLOAD     [AD]     : Endif
  If clalev([F:CPT])=0    : Local File EMPLOCPT    [CPT]    : Endif
  If clalev([F:RIB])=0    : Local File EMPLORIB    [RIB]    : Endif
  If clalev([F:MED])=0    : Local File EMPLOMED    [MED]    : Endif
  If clalev([F:CEV])=0    : Local File COMPEVAL    [CEV]    : Endif
  If clalev([F:EVE])=0    : Local File EVAEMP      [EVE]    : Endif
  If clalev([F:EVE2])=0   : Local File EVAEMP      [EVE2]   : Endif
  If clalev([F:EVC])=0    : Local File EVAEMPCPC   [EVC]    : Endif
  If clalev([F:EVD])=0    : Local File EVAEMPDET   [EVD]    : Endif
  If clalev([F:EVD2])=0   : Local File EVAEMPDET   [EVD2]   : Endif
  If clalev([F:EPO])=0    : Local File EMPLOPOT    [EPO]    : Endif
  If clalev([F:POT])=0    : Local File POSTE       [POT]    : Endif
  If clalev([F:JOT])=0    : Local File JOBTYP      [JOT]    : Endif
  If clalev([F:CPC])=0    : Local File COMPETENCE  [CPC]    : Endif
  If clalev([F:SCA])=0    : Local File SCALE       [SCA]    : Endif
  If clalev([F:CPE])=0    : Local File CPCEMP      [CPE]    : Endif
  If clalev([M:CVS2]) = 0 : Local Mask CEVSTAT2    [CVS2]   : Endif
  If clalev([M:DIA]) = 0  : Local Mask CEVSTAT     [DIA]    : Endif
  If clalev([F:ADI])=0    : Local File ATABDIV     [ADI]    : Endif

Return

#####################################
$CONTROLE
Case BOITE
When "CEVSTAT"
  If GSTATUT<>GSTAOK or OK=0 Then
    FIN = 1
  Else
    TMP = 1
    TRA = 0
  Endif

When "CEVSTAT2"
  If GSTATUT<>GSTAOK or OK=0 Then
    FIN = 1
  Else
    TMP = 0
    TRA = 0
  Endif

Endcase

Return

#**
#* Calcul des critères de sélection
#*!
$CALC_CRIT
  Gosub CALC_CRIT1 From GENCEV
  Gosub CALC_CRIT2 From GENCEV
  CRITERE3  = "1=1"
  CRITERE3 +=" & [F:EVE]CEV ='"+ [M:DIA]CODCEV+"'"
  CRITERE3 +=" & [F:EVE]EVATYP ='"+ [M:DIA]EVATYP+"'"
#LIPET - 2017-10-24 - X3-29324 - START
  If [M:DIA]PREEVA <>2
  CRITERE3 +=" & [F:EVE]EVADATSTR = [M:DIA]STRDAT"
  CRITERE3 +=" & [F:EVE]EVADATEND = [M:DIA]ENDDAT"
  Endif
#LIPET - 2017-10-24 - X3-29324 - END
Return

#**#####################################################################################
#* Exécution de l'action
#*!
$EXEC

Return

$BOUTON
If BOUT="O" : # Bouton Critères
 FIN = 1
Endif

Return

$TERMINE
If GSTATUT=GSTAESC : # Bouton Fin
 FIN = 1 : Return
Endif
If GSTATUT=GSTABOU2+1 : # Bouton critères
 SAI = 1
Endif
Return


$DEBUT

Case BOITE
    When "CEVSTAT"
      If [V]WG_INI=0 Then
         [V]WG_INI=1
         Raz [M:DIA]
        Gosub INI_FLDS_CRIT From GENCEV
      Endif
      If dim([M:DIA]LEG)>0 Then GCURLEG = [M:DIA]LEG : Endif
      Affzo [M:DIA]

    When "CEVSTAT2"
      #sba pb avec grp de société
      Local Clbfile CRITERE1(2)
      Local Char  CRITERE2(250), CRITERE3(250), CRITERE4(250), FLDNAME(50)
      Local Char WMATLIB(50), WMAT([V]GLONEML)
      Local Char    WFCY([V]GLONFCY), WCPY([V]GLONCPY), WTIT(50)
      Local Integer I, OKENR, L_IJ, K, NBVAL, WI, NBSTAT
      Local Integer LOK, WMESS
      Local Integer W_DIMTAB : W_DIMTAB=dim([M:CVS2]EVAMAT)
        Raz [M:CVS2]
        [M:CVS2]CODCEV = [F:CEV]COD
        [M:CVS2]EVATYP = [F:CEV]EVATYP
        [M:CVS2]STRDAT = [F:CEV]STRDAT
        [M:CVS2]ENDDAT = [F:CEV]ENDDAT
        Gosub CALC_CRIT

        If [M:DIA]POP<>"" Then
          Link [F:EVE] With [F:ID]ID0=[F:EVE]REFNUM, [F:HRCTR]CTR0=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]CTRDAT, [F:FCY]FCY0=[F:HRCTR]ETRFCY, [F:HRPOA]POA0=[M:DIA]POP;[F:ID]REFNUM As [EVE_]
        Else
          Link [F:EVE] With [F:ID]ID0=[F:EVE]REFNUM, [F:HRCTR]CTR0=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]CTRDAT, [F:FCY]FCY0=[F:HRCTR]ETRFCY As [EVE_]
        Endif

        Filter [F:EVE_] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)  #Order By Key NEW=[F:EVE]EVAMAT; [F:EVE]EVALIB;[F:EVE]REFNUM; [F:EVE]CTRNUM

        # titre colonnes / menu local des Cycles de validation/statuts
        [L]WMESS=10947
        [L]NBSTAT=len(mess(0,[L]WMESS,1)) : # Nb Cycles de validation / statuts
        For [L]I = 1 To [L]NBSTAT
#          If [L]I  <= [L]NBSTAT Then [L]WTIT = mess([L]I,[L]WMESS,1) Else [L]WTIT="" : Endif
          If ![V]GW_PRHACTIF & ([L]I=2 | [L]I=3 ) Then
           [L]WTIT=""
          Else
           [L]WTIT = mess([L]I,[L]WMESS,1)
          Endif

          Case [L]I
            When 1 : Titcol [M:CVS2]NBVISIB [L]WTIT For NBVALVIS1
            When 2 : Titcol [M:CVS2]NBVISIB [L]WTIT For NBVALVIS2
            When 3 : Titcol [M:CVS2]NBVISIB [L]WTIT For NBVALVIS3
            When 4 : Titcol [M:CVS2]NBVISIB [L]WTIT For NBVALVIS4
            When 5 : Titcol [M:CVS2]NBVISIB [L]WTIT For NBVALVIS5
          Endcase
        Next
         If ![V]GW_PRHACTIF Then
            Chgfmt [M:CVS2]NBVALVIS2 With "-N:4#"
            Chgfmt [M:CVS2]NBVALVIS3 With "-N:4#"
        Endif
#LIPET - 2017-10-24 - X3-29324 - START
        If [M:DIA]PREEVA =2
          Chgtzn[M:CVS2]STRDAT With mess(156,10720,1) : # "Prochain entretien déb."
          #TODO pas en V6
          Chgtzn[M:CVS2]ENDDAT With mess(157,10720,1) : # "Prochain entretien fin" T
        Endif
#LIPET - 2017-10-24 - X3-29324 - END
        For [F:EVE_]
          OKENR=1
          If [M:DIA]CRI<>"" Then
            # Lecture des enregistrements des tables EMPLOxxx pour évaluation de [M:DIA]CRI
            Read [F:AD]AD0=[F:ID]REFNUM
            Read [F:CPT]CPT0=[F:ID]REFNUM
            Filter [F:RIB] Where REFNUM=[F:ID]REFNUM : Read [F:RIB] Last : Filter [F:RIB]
            Filter [F:MED] Where REFNUM=[F:ID]REFNUM : Read [F:MED] Last : Filter [F:MED]
            Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:DIA]CRI,OKENR,0) From DIVPAYE
          Endif
          If OKENR  & (![V]GW_PRHACTIF & ( ([F:EVE]EVAVAL)=2 |  ([F:EVE]EVAVAL) =3 )) Then
            OKENR = 0
          Endif
          If OKENR Then
            GOK=1

            # Nom des évaluateurs
            If [F:EVE]EVAVAL = [L]NBSTAT : #  = valide N+2 - Evaluateur 2
              [L]WMAT=[F:EVE]EVAMAT2
              [L]WMATLIB = [F:EVE]EVALIB2
            Else      :                         # Evaluateur 1
              [L]WMAT=[F:EVE]EVAMAT
              [L]WMATLIB = [F:EVE]EVALIB
            Endif
            If [L]WMAT<>"" Then
              Read [F:ID]ID0=[L]WMAT
              If !fstat Then
                [L]WMATLIB = [F:ID]NAM-[F:ID]SRN
              Endif
            Else
              [L]WMAT=" "
            Endif
            [L]WMAT+=space$(GLONEML-len([L]WMAT))

            [L]L_IJ = find("1"+"~"+[L]WMAT+"~"+[L]WMATLIB,[M:CVS2]EVACLE1(0..[M:CVS2]NBRVAR-1))
            If ([M:CVS2]NBRVAR<dim([M:CVS2]EVAMAT)-(1 + ![L]L_IJ) )
            # si l'évaluateur est déjà dans le tableau - il doit rester au moins une ligne, sinon 2 lignes
              If ![L]L_IJ Then
                 #création nouvelle ligne évaluateur dans tableau
                 [M:CVS2]EVAMAT([M:CVS2]NBRVAR) = [L]WMAT
                 [M:CVS2]EVALIB([M:CVS2]NBRVAR) = [L]WMATLIB
                 [M:CVS2]EVACLE([M:CVS2]NBRVAR) = [L]WMAT+"~"+[L]WMATLIB
                 [M:CVS2]LEV([M:CVS2]NBRVAR) = 1
                 [M:CVS2]EVACLE1([M:CVS2]NBRVAR) = "1"+"~"+[M:CVS2]EVACLE([M:CVS2]NBRVAR)
                 [M:CVS2]PLIER([M:CVS2]NBRVAR) = 1
                 [M:CVS2]PARIND([M:CVS2]NBRVAR) = [M:CVS2]NBRVAR
                 [M:CVS2]NBRVAR += 1
                 [L]L_IJ=[M:CVS2]NBRVAR
              Endif

              # MAJ du nombre d'entretiens / cycle de validation
              [L]FLDNAME="[M:CVS2]NBVAL"+num$([F:EVE]EVAVAL)+"([L]L_IJ-1)"
              Assign ([L]FLDNAME) With evalue([L]FLDNAME)+1
              # MAJ du total de la ligne
              [M:CVS2]TOTH(L_IJ-1)  += 1 :# total ligne
  #           Endif
              # création ligne fille - entretien / refnum + contrat
              [M:CVS2]EVAMAT([M:CVS2]NBRVAR) = [F:EVE]REFNUM
              Read [F:ID]ID0 = [F:EVE]REFNUM
              If fstat = 0
                [M:CVS2]EVALIB([M:CVS2]NBRVAR) = [F:ID]NAM - [F:ID]SRN
              Else
                [M:CVS2]EVALIB([M:CVS2]NBRVAR) ="*******"
              Endif
             [M:CVS2]CTRNUM([M:CVS2]NBRVAR) = [F:EVE]CTRNUM
             [M:CVS2]CTRDAT([M:CVS2]NBRVAR) = [F:EVE]CTRDAT
#LIPET - 2017-10-24 - X3-29324 - START
              [M:CVS2]EVADATSTR([M:CVS2]NBRVAR) = [F:EVE]EVADATSTR
              [M:CVS2]EVADATEND([M:CVS2]NBRVAR) = [F:EVE]EVADATEND
#LIPET - 2017-10-24 - X3-29324 - END
             [M:CVS2]EVACLE([M:CVS2]NBRVAR) = [L]WMAT+"~"+[L]WMATLIB
             [M:CVS2]LEV([M:CVS2]NBRVAR) = 2
             [M:CVS2]PLIER([M:CVS2]NBRVAR) = 1
             [M:CVS2]EVACLE1([M:CVS2]NBRVAR) = ""
             [L]FLDNAME="[M:CVS2]NBVAL"+num$([F:EVE]EVAVAL)+"([M:CVS2]NBRVAR)"
             Assign ([L]FLDNAME) With 1
             [M:CVS2]PARIND([M:CVS2]NBRVAR) = [L]L_IJ-1
             [M:CVS2]NBRVAR += 1
           Else
                # Tableau plein
                Call ERREUR(func AFNC.MES1(mess(131,10720,1),num$(W_DIMTAB))) From GESECRAN
                # 'Le nombre de lignes du tableau dépasse la limite autorisée ($1$). Veuillez restreindre votre population'
                Break
           Endif
         Endif
        Next
        Sorta  [M:CVS2]NBRVAR [M:CVS2]NBRVAR Order By  EVACLE([S]indice), LEV([S]indice), EVAMAT([S]indice), CTRNUM([S]indice)
        # dernière ligne du tableau
        [M:CVS2]EVAMAT([M:CVS2]NBRVAR) = func TOOLSHRLEG.LIB_FIELD("CEVSTAT2", "CODCEV"): #Campagne
        [M:CVS2]EVALIB([M:CVS2]NBRVAR) = [M:CVS2]CODCEV
        [M:CVS2]TOTH([M:CVS2]NBRVAR) = 0
        [M:CVS2]EVACLE([M:CVS2]NBRVAR) = "~"
        [M:CVS2]LEV([M:CVS2]NBRVAR) = 3
        [M:CVS2]EVACLE1([M:CVS2]NBRVAR) = "0"
        [M:CVS2]PLIER([M:CVS2]NBRVAR) = 1
        [M:CVS2]PARIND([M:CVS2]NBRVAR) = [M:CVS2]NBRVAR
        [L]WI=0
        For [L]K =1 To [L]NBSTAT : # Cycles de validation
          If [V]GW_PRHACTIF | [L]K=1 | [L]K >3 Then
#            #Tableau: total 1 colonne/Cycle de validation
            [L]NBVAL=evalue("sum([M:CVS2]NBVAL"+num$([L]K)+"(0..[M:CVS2]NBRVAR))/2")
            [L]FLDNAME="[M:CVS2]NBVAL"+num$([L]K)+"([M:CVS2]NBRVAR)"
            Assign [L]FLDNAME With [L]NBVAL

            [M:CVS2]TOTH([M:CVS2]NBRVAR)  += [L]NBVAL :# total ligne

            #Graphe- 1 ligne/Cycle de validation
            [M:CVS2]CYCLE([L]WI)=evalue("mess("+num$([L]K)+","+num$([L]WMESS)+",1)")
            [M:CVS2]TOTCYCL([L]WI)=[L]NBVAL
            [L]WI+=1
          Endif
         Next [L]K
        [M:CVS2]NBRVAR+=1
        If [V]GW_PRHACTIF Then [M:CVS2]NBCYCL= 6 Else [M:CVS2]NBCYCL=4 :Endif
        # we add  1 to the number of status to have an echelle correct in the case with one entretien in each statut
        Call DEPLIER_PLIER("") : # afficher le tableau visible tout replié
        Affzo [M:CVS2]
        zonsui="[M:CVS2]ICONE([M:CVS2]NBVISIB-1)" :# se positionner sur ligne Campagne (dernière du tableau)
  Endcase

Return


$FIN
FIN=1

Return

$SORTIE
If dim([V]WG_INI)>0 Then Kill [V]WG_INI : Endif
If dim([V]GW_PRHACTIF)>0 Then Kill [V]GW_PRHACTIF : Endif
Case BOITE
  When "CEVSTAT2"
    #repositionnement sur la fiche de GESCEV
    If GFONCTION="GESCEV" Then
      Read [F:CEV]CEV0=[M:CEV0]COD
    Endif
Endcase

Return

######################################################################################
## Gestion des champs de l'écran CEVSTAT2
######################################################################################

Subprog AS_NBVISIB
   Call REFRESH_GRAPH2(nolign-1) : # valeur de la ligne du tableau
End

Subprog REFRESH_GRAPH2(WNOLIG)
Value Integer WNOLIG
Local Integer K, WI, NBSTAT
    [L]WI=0
    [L]NBSTAT = len(mess(0,10947,1))
   For [L]K =1 To [L]NBSTAT : # Cycles de validation
      If [V]GW_PRHACTIF | [L]K=1 | [L]K >3 Then
        [M:CVS2]TOTCYCL([L]WI)=evalue("[M:CVS2]NBVALVIS"+num$([L]K)+"([L]WNOLIG)")
        [L]WI+=1
      Endif
   Next [L]K
#   [M:CVS2]NBCYCL=[L]WI +1  :# we add  1 to have an echelle correct in the case with one entretien in each statut
#   Affzo [M:CVS2]20
   Affzo [M:CVS2]NBCYCL, CYCLE, TOTCYCL
End

Subprog CL_ICONE(VALEUR)
Variable Char    VALEUR()
Local Integer PLIER
  If [M:CVS2]LEV([M:CVS2]IND_INV(nolign-1))=1 Then
    Call DEPLIER_PLIER([M:CVS2]EVACLEVIS(nolign-1))
    VALEUR= [M:CVS2]NOICO(nolign-1)
  Endif
End

Subprog DEPLIER_PLIER (CLE_VISIBLE)
Value Char CLE_VISIBLE()
Local Integer I,VAL_ICO, WICO_REF

  # 48 - 49 : loupe + / -
  # 53 - 54 : livre  bleu fermé / ouvert
  [L]WICO_REF = 53

  Effzo [M:CVS2]ICONE:  #  Effzo [M:CVS2]15 : US2040 : Convergence adjustement
  [M:CVS2]NBVISIB=0
  For [L]I=0 To [M:CVS2]NBRVAR-1

      If [L]CLE_VISIBLE = [M:CVS2]EVACLE([L]I) Then
        Case [M:CVS2]PLIER([L]I)
          When 1 : [M:CVS2]PLIER([L]I)=2
          When 2 : [M:CVS2]PLIER([L]I)=1
        Endcase
      Endif
      Affzo [M:CVS2]10

      If [M:CVS2]LEV([L]I)<>2 |  [M:CVS2]PLIER([L]I)=2 Then
        If [M:CVS2]EVACLE([L]I) ="~"  Then
     #   If GUSER="MABOS" : Infbox ([M:CVS2]EVACLE([L]I)-"plier:"+num$([M:CVS2]PLIER([L]I))-"lev:"+num$([M:CVS2]LEV([L]I))) : Endif
        Endif
        [M:CVS2]CODE([M:CVS2]NBVISIB) = [M:CVS2]EVAMAT([L]I)
        [M:CVS2]NOM([M:CVS2]NBVISIB) = [M:CVS2]EVALIB([L]I)
#        If [M:CVS2]NOM([M:CVS2]NBVISIB)="" Then [M:CVS2]NOM([M:CVS2]NBVISIB)="..." :Endif : #FQ 92896-US2135
        [M:CVS2]IND_INV([M:CVS2]NBVISIB)=[L]I
        [M:CVS2]EVACLEVIS([M:CVS2]NBVISIB) = [M:CVS2]EVACLE([L]I)
        [M:CVS2]CTRNUMVIS([M:CVS2]NBVISIB) = [M:CVS2]CTRNUM([L]I)
        [M:CVS2]CTRDATVIS([M:CVS2]NBVISIB) = [M:CVS2]CTRDAT([L]I)
#LIPET - 2017-10-24 - X3-29324 - START
        [M:CVS2]EVADATSTRVIS([M:CVS2]NBRVAR) = [M:CVS2]EVADATSTR([L]I)
        [M:CVS2]EVADATENDVIS([M:CVS2]NBRVAR) = [M:CVS2]EVADATEND([L]I)
#LIPET - 2017-10-24 - X3-29324 - END
        [M:CVS2]NBVALVIS1([M:CVS2]NBVISIB) = [M:CVS2]NBVAL1([L]I)
        [M:CVS2]NBVALVIS2([M:CVS2]NBVISIB) = [M:CVS2]NBVAL2([L]I)
        [M:CVS2]NBVALVIS3([M:CVS2]NBVISIB) = [M:CVS2]NBVAL3([L]I)
        [M:CVS2]NBVALVIS4([M:CVS2]NBVISIB) = [M:CVS2]NBVAL4([L]I)
        [M:CVS2]NBVALVIS5([M:CVS2]NBVISIB) = [M:CVS2]NBVAL5([L]I)
        [M:CVS2]TOTVISH([M:CVS2]NBVISIB)   = [M:CVS2]TOTH([L]I)
        [M:CVS2]LEVVIS([M:CVS2]NBVISIB)   = [M:CVS2]LEV([L]I)
        # Icone : si niveau évaluateur &  (si plier = 1 + [L]WICO_REF  ou  si déplier : [L]WICO_REF )
        [L]VAL_ICO = ( [M:CVS2]LEV([L]I)=1 ) *  ( ( ( [M:CVS2]PLIER([L]I)=2 ) * 1 ) + [L]WICO_REF )
        If [L]VAL_ICO > 0 Then
          [M:CVS2]ICONE([M:CVS2]NBVISIB) = num$([L]VAL_ICO )
          [M:CVS2]NOICO([M:CVS2]NBVISIB) = num$([L]VAL_ICO ) : # permet de récupérer la valeur de l'icone sur CL_ICONE sinon décalage
        Endif
        [M:CVS2]NBVISIB+=1
      Endif
  Next I
  Sorta  [M:CVS2]NBVISIB [M:CVS2]NBVISIB Order By  EVACLEVIS([S]indice),LEVVIS([S]indice), CODE([S]indice), CTRNUMVIS([S]indice),CTRDATVIS([S]indice)
#   si il y a au moins un evaluateur déplié
  If find (num$([L]WICO_REF +1),[M:CVS2]NOICO(00..[M:CVS2]NBVISIB))
    Titcol [M:CVS2]NBVISIB  "",func TOOLSHRLEG.LIB_FIELD("CEVSTAT2", "EVAMAT")+"/"+mess(00003,00076,1) : # Evaluateur/ salarié
  Else
    Titcol [M:CVS2]NBVISIB  "",func TOOLSHRLEG.LIB_FIELD("CEVSTAT2", "EVAMAT") :# Evaluateur
  Endif

  Affzo [M:CVS2]15

  For K=0 To [M:CVS2]NBVISIB-1
      [L]I=[M:CVS2]IND_INV([L]K) : # indice correspondant dans le tableau invisible
      Case [M:CVS2]LEV([L]I)
        When 3 :  Chgstl [M:CVS2]NBVISIB(([L]K)) With "GDD1" : # campagne
        When 1 :  Chgstl [M:CVS2]NBVISIB(([L]K)) With "MTOLINKC": # evaluateur
        When 2 :  Chgstl [M:CVS2]NBVISIB(([L]K)) With ""
      Endcase
  Next

End


Subprog IB_NBVISIB
# 2 boutons : 1 au singulier et 1 au pluriel
If [M:CVS2]CTRNUMVIS(nolign-1)="" : # les lignes sans contrat
 Raz GBOUT1 :# bouton "Entretien"
Endif
If [M:CVS2]LEV([M:CVS2]IND_INV(nolign-1))<3 : # toutes les lignes sauf Campagne
  Raz GBOUT2 : # bouton "Entretiens"
Endif
End

Subprog B1_NBVISIB
  Gosub TUNNEL_EVE
End

Subprog B2_NBVISIB
  Gosub TUNNEL_EVE
End

$TUNNEL_EVE

 If !GWEBSERV
 ## Action GOBJETC0
#dbgmode=1 : Dbgaff
 Local Char    PARMSK(250)(1..20) , SAVACT(20), SAVFLAG(20)
 SAVACT = GACTION : GACTION = "GOBJETC0" : SAVFLAG = GFLAG
 Local Char    OBJCLE(30)
 Local Char    WCLE1(30)
 Local Char    WCLE2(30)
 Local Char    WCLE3(30)
 Local Char    WCLE4(30)

 If [M:CVS2]CTRNUMVIS(nolign-1) <> ""
    OBJCLE = [M:CVS2]CTRNUMVIS(nolign-1) : # vide si ligne campagne
    WCLE1 = [M:CVS2]CODE(nolign-1)
  Endif
 WCLE2 = [M:CVS2]STRDAT
 WCLE3 = [M:CVS2]ENDDAT
 WCLE4 = [M:CVS2]EVATYP
 Call OBJET_CHAR(OBJCLE,"EVA",WCLE1+"~"+WCLE2+"~"+WCLE3+"~"+WCLE4) From GOBJET
 GACTION = SAVACT : GFLAG = SAVFLAG
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub AFF From GSAISIE
End


