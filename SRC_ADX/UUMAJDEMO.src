#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# Création du paramètre DEMO sur le dossier DEMO (utilisateurs nommés)
##########################################################################
Call OUVRE_TRACE("Update DEMO") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ

Local Char    DOSX3(GLONADS) , APPLI(GLONADS) , MACHINE(GLONAMC)
Local Integer OK , ER

Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif
Close Local File [ADW]
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If MACHINE="" or DOSX3=""
 Local File ADOSSIER [ADX2]
Else
 Local File =MACHINE+"@"+DOSX3+".ADOSSIER" [ADX2]
Endif
OK = 0
For [ADX2]
 ER = 0
 Onerrgo ERFIC
 If MACHINE<>""
  Local File =MACHINE+"@"+[F:ADX2]DOSSIER+".ADOVAL" [ADW]
 Else
  Local File =[F:ADX2]DOSSIER+".ADOVAL" [ADW]
 Endif
 Look [ADW]ADW0="";"";"ADEMO"
 Onerrgo
 If !ER
  If !fstat : OK = 1 : Endif
  Close Local File [ADW]
  If OK : Break : Endif
 Endif
Next ADX2
If !OK
 For [ADX2] Where pat(DOSSIER,"*DEMO*")
  ER = 0
  Onerrgo ERFIC
  If MACHINE<>""
   Local File =MACHINE+"@"+[F:ADX2]DOSSIER+".ADOVAL" [ADW]
  Else
   Local File =[F:ADX2]DOSSIER+".ADOVAL" [ADW]
  Endif
  If !ER
   Trbegin [ADW]
    Raz [F:ADW]
    [F:ADW]PARAM = "ADEMO"
    [F:ADW]CREUSR = GUSER
    [F:ADW]CREDAT = date$
    [F:ADW]CRETIM = time
    Write [ADW]
    If fstat
     Call ERREUR("ADW ADEMO",1) From DOSDIC
    Endif
   Commit
   Close Local File [ADW]
   If !ER : Break : Endif
  Endif
  Onerrgo
 Next ADX2
Endif
Close Local File
Return

$ERFIC
ER = errn
Resume
