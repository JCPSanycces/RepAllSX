#<AdxTL>@(#)4.0.0.0 $Revision$
    adxmbm=adxmbm
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  FLGEXE = 1
  GACTION = "AYFTABSEL"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"AYFTABSEL","SUBAYFTABSEL","",1,"SPEAYF") From GTRAITE
End
######################################################################################
## Xtend:  Gestion des Elements champs
#          Aide à la création des champs à partir d'une table ou vue X3
#                                                ou d'une interface Xtend
#  Version 0001
#
#    PARAM(1)      # Site
#    PARAM(2)      # Flag origine - convention:    1: Interface  2: Table  3: Vue   0: tous
#    PARAM(3)      # Code origine (table, vue...)
######################################################################################

$ACTION
Case ACTION
    When "INIT"     : Gosub INIT
    When "EXEC"     : Gosub EXEC
    When "SORTIE"   : Gosub SORTIE
    # Saisie fenêtre
      When "AVANT_OK" : Gosub AVANT_OK
      When "DEBUT"  : Gosub DEBUT
Endcase
Return

$INIT
If clalev([F:AYI])=0 : Local File AYTINT      [AYI] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON     [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE       [ATY] : Endif
If clalev([F:AVD])=0 : Local File AVIEWD      [AVD] : Endif
If clalev([F:ACV])=0 : Local File ACTIV       [ACV] : Endif
If clalev([F:AYF])=0 : Local File AYTELTFLD   [AYF] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA     [AXX] : Endif
Local Mask AYFTABSEL [DIA]
Local Integer WOK
Return


$EXEC
If GSTATUT<>GSTAOK : Return : Endif        # A gérer soi-même car fenêtre

Gosub UPDFLD
Return

$SORTIE
Close Local Mask [DIA]
Return


######################################################################################
$UPDFLD
Call DEBTRANS From GLOCK
Gosub TR_COP

$FINALLY
Return

$TR_COP
Local Integer NOL, NIND
Local Char WCODE(GLONAYF)
GOK = 1
Trbegin [AYF]
For NOL=0 To [M:DIA]NBZONE-1
  If [M:DIA]FIECOD(NOL)<>""
    If [M:DIA]DIME(NOL)=1
        WCODE = [M:DIA]FIECOD(NOL) : Gosub COPRUB
        If GOK<1 : Break : Endif
    Else
        Case [M:DIA]INDCHX(NOL)
        When 1    # aucun
             WCODE = [M:DIA]FIECOD(NOL) : Gosub COPRUB
        When 2    # tous
            For NIND=1 To [M:DIA]DIME(NOL)
              WCODE = [M:DIA]FIECOD(NOL)+num$(NIND-1) : Gosub COPRUB
              If GOK<1 : Break : Endif
            Next
        When 3    # Un
            WCODE = [M:DIA]FIECOD(NOL)+num$([M:DIA]IND(NOL)) : Gosub COPRUB
        Endcase
       If GOK<1 : Break : Endif
    Endif
  Endif
Next
If   GOK<0 : Goto ROLL_TR_COP
Elsif !GOK : Goto AB_TR_COP
Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

$COPRUB
[F:AYF]UPDUSR = GUSER
[F:AYF]UPDDAT = date$
# [F:AYF]UPDTIM = time  - 93575
Call SET_UPDTIM("AYF") From AYTCOP # 93575
[F:AYF]FCYCOD = [M:DIA]FCYCOD
[F:AYF]FIECOD = WCODE
[F:AYF]TYP    = [M:DIA]TYPXT(NOL)
[F:AYF]NOLIB  = [M:DIA]NOLIB(NOL)
[F:AYF]CODACT = [M:DIA]FCYCODACT
[F:AYF]BRWX3  = [F:AYF]FCYCOD+"_"+[F:AYF]FIECOD
[F:AYF]VALDEF = 1
Write [AYF]
If fstat
 GOK=0 : Call FSTA("AYF") From GLOCK  : Return
Endif
Call MAJTEXTRA(func AFNC.TEXTE([M:DIA]NOCOURT(NOL)),"AYTELTFLD","INTIT",[F:AYF]FCYCOD,[F:AYF]FIECOD) From  ATEXTRA
Return


######################################################################################
# Modèle saisie fenêtre AYFTABSEL
######################################################################################
$DEBUT
[M:DIA]FCYCOD = PARAM(1)  # Site
Gosub INICTLFCY From SUBAYS
Gosub DSYFCY From SUBAYS
[M]FCYCODACT=WFCY_CODACT        # Code activité site

# Gestion suivant Flag origine
Case PARAM(2)
When "1"    # Interface
    [M:DIA]INTCOD = PARAM(3)
    Call AM_INTCOD([M:DIA]INTCOD)
    Grizo [M:DIA]CODFIC, CODVUE
    zonsui="[M]NBZONE"
When "2"    # Table
    [M:DIA]CODFIC = PARAM(3)
    Call AM_CODFIC([M:DIA]CODFIC)
    Grizo [M:DIA]INTCOD, CODVUE
When "3"    # Vue
    [M:DIA]CODVUE = PARAM(3)
    Call AM_CODVUE([M:DIA]CODVUE)
    Grizo [M:DIA]CODFIC, INTCOD
When Default
Endcase
Return

$AVANT_OK
#Ctl - Utile car l'utilisateur peut sortir du mode saisie avec une erreur et faire Ok
WOK=1
For nolign =1 To [M:DIA]NBZONE
    Gosub COD_VER
    If !WOK
        zonsui="[M]FIECOD("+num$(NOL)+")" : FOK=0 : GERR=1
        FIN=0    # Invalider la sortie de fenêtre
        Break
    Endif
Next
Return

######################################################################################
# Utilitaires
######################################################################################
Subprog TYPX3UPD(X3CODTYP, XTTYP)    # Conversion Type X3 (menu 30 - table ATYPE) vers Type Xtend (menu 7931)
Value Char       X3CODTYP
Variable Integer XTTYP

If left$(X3CODTYP,2)="MD"    # devise
    XTTYP=4
Else
    Call LECTURE("ATY",X3CODTYP,"") From CONTOBJ
    Case [F:ATY]TYPTYP
     When 1          # Menu
        XTTYP=8
     When 2,3        # Entier court et long
        XTTYP=2
     When 4,5,6      # Décimal
        XTTYP=3
     When 7          # Texte
        XTTYP=1
     When 10         # Clob (Accès P.J.)
        XTTYP=7
     When 8          # Date
        XTTYP=5
     When 9
        XTTYP=6       # Blob (Accès image)
    Endcase
Endif
End

Subprog TYPWSUPD(WSTYP, XTTYP)    # Conversion Type Web Service (menu 33) vers Type Xtend (menu 7931)
Value    Integer WSTYP
Variable Integer XTTYP
Case WSTYP
 When 2,5          # Entier, Libelle
    XTTYP=2
 When 3            # Décimal
    XTTYP=3
 When 1            # Texte
    XTTYP=1
 When 6            # Clob (Accès P.J.)
    XTTYP=7
 When 4            # Date
    XTTYP=5
 When 7
    XTTYP=6        # Blob (Accès image)
Endcase
End

######################################################################################
# Gestion du masque AYSTABSEL
######################################################################################

Subprog C_IND(VALEUR)
Variable Decimal VALEUR
If (VALEUR > DIME(nolign-1) or VALEUR < 0)
 mkstat=2
 GMESSAGE=mess(83,123,1)
Endif
End


# Chargement du tableau dans le cas d'une table X3
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog AM_CODFIC(VALEUR)
Variable Char    VALEUR()

Local Integer WACTOK

If VALEUR="" : End : Endif
Effzo [M:DIA]WEBSRCCOD
Effzo [DIA]10
For [F:ATZ] Where CODFIC=VALEUR
 [M:DIA]CODZONE([M:DIA]NBZONE)=[F:ATZ]CODZONE

 [M:DIA]DIME([M:DIA]NBZONE)=[F:ATZ]DIME
 If [M:DIA]DIME([M:DIA]NBZONE)=0     # Info portée par le code activité
    Call ACTIV([F:ATZ]CODACT, WACTOK) From SUBACV
    If WACTOK : [M:DIA]DIME([M:DIA]NBZONE)=[ACV]DIME : Else : [M:DIA]DIME([M:DIA]NBZONE)=1 : Endif
 Endif

 [M:DIA]CODTYP([M:DIA]NBZONE)=[F:ATZ]CODTYP
 Call TYPX3UPD([M:DIA]CODTYP([M:DIA]NBZONE),[M:DIA]TYPXT([M:DIA]NBZONE))
 [M:DIA]NOCOURT([M:DIA]NBZONE)=[F:ATZ]NOCOURT
 Call TEXTE([F:ATZ]NOCOURT,[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
 [M:DIA]NOLIB([M:DIA]NBZONE)=[F:ATZ]NOLIB
 [M:DIA]NBZONE+=1
Next
Affzo [DIA]10
End

# Chargement du tableau dans le cas d'une vue X3
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog AM_CODVUE(VALEUR)
Variable Char    VALEUR()

Local Integer WACTOK

If VALEUR="" : End : Endif
Effzo [M:DIA]WEBSRCCOD
Effzo [DIA]10
For [F:AVD] Where CODVUE=VALEUR
 [M:DIA]CODZONE([M:DIA]NBZONE)=[F:AVD]FLDVUE

 [M:DIA]DIME([M:DIA]NBZONE)=[F:AVD]DIME
 If [M:DIA]DIME([M:DIA]NBZONE)=0     # Info portée par le code activité
    Call ACTIV([F:AVD]FLDACT, WACTOK) From SUBACV
    If WACTOK : [M:DIA]DIME([M:DIA]NBZONE)=[ACV]DIME : Else : [M:DIA]DIME([M:DIA]NBZONE)=1 : Endif
 Endif

 [M:DIA]CODTYP([M:DIA]NBZONE)=[F:AVD]CODTYP
 Call TYPX3UPD([M:DIA]CODTYP([M:DIA]NBZONE),[M:DIA]TYPXT([M:DIA]NBZONE))
 [M:DIA]NOCOURT([M:DIA]NBZONE)=[F:AVD]FLDINT
 Call TEXTE([F:AVD]FLDINT,[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
 [M:DIA]NOLIB([M:DIA]NBZONE)=[F:AVD]NOLIB
 [M:DIA]NBZONE+=1
Next
Affzo [DIA]10
End

# Chargement du tableau dans le cas d'une interface
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog AM_INTCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif

Gosub GETWS_VAR From SUBAYIACT     # Variables pour GETWS_INF
WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD
[M:DIA]WEBSRCCOD = WS_WSRCOD

Gosub GETWS_INF From SUBAYIACT : If WS_RET : GERR=1 : GMESSAGE=WS_MES : End: Endif

Effzo [DIA]10
Case [F:AYI]TYP
When 1,2,4   # Accès sous-programme généré accès sur table ou vue
             # Accès sous-programme utilisateur
    For WI=0 To RUBNBR-1
        #If left$(RUBCOD(WI),2)<>"AX"    # Ne pas afficher les rubriques techniques
        If !find(RUBGRP(WI),"AX_PAR","AX_WHR","AX_ORD")

            [M:DIA]CODZONE([M:DIA]NBZONE)    = RUBCOD(WI)
            [M:DIA]TYPWS([M:DIA]NBZONE)      = val(RUBTYP(WI))
            Call TYPWSUPD([M:DIA]TYPWS([M:DIA]NBZONE),[M:DIA]TYPXT([M:DIA]NBZONE))
            [M:DIA]DIME([M:DIA]NBZONE)       = 1
            [M:DIA]NOCOURT([M:DIA]NBZONE)    = RUBINTIT(WI)
            Call TEXTE(RUBINTIT(WI),[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
            [M:DIA]NBZONE+=1
        Endif
    Next
#
When 20      # Action sous-programme utilisateur
        For WI=0 To RUBNBR-1
            [M:DIA]CODZONE([M:DIA]NBZONE)    = RUBCOD(WI)
            [M:DIA]TYPWS([M:DIA]NBZONE)      = val(RUBTYP(WI))
            Call TYPWSUPD([M:DIA]TYPWS([M:DIA]NBZONE),[M:DIA]TYPXT([M:DIA]NBZONE))
            [M:DIA]DIME([M:DIA]NBZONE)       = RUBDIM(WI)
            [M:DIA]NOCOURT([M:DIA]NBZONE)    = RUBINTIT(WI)
            Call TEXTE(RUBINTIT(WI),[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
            [M:DIA]NBZONE+=1
        Next
#
When 3     # Accès liste gauche
        For WI=0 To RUBNBR-1
           [M:DIA]CODZONE([M:DIA]NBZONE)    = RUBCOD(WI)
           [M:DIA]CODTYP([M:DIA]NBZONE)     = RUBTYP(WI)
           Call TYPX3UPD([M:DIA]CODTYP([M:DIA]NBZONE),[M:DIA]TYPXT([M:DIA]NBZONE))
           [M:DIA]DIME([M:DIA]NBZONE)       = 1
           [M:DIA]NOCOURT([M:DIA]NBZONE)    = RUBINTIT(WI)
           Call TEXTE(RUBINTIT(WI),[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
           [M:DIA]NOLIB([M:DIA]NBZONE)      = RUBMNL(WI)    #
           [M:DIA]NBZONE+=1
        Next
#
When 21    # Action objet
        For WI=0 To RUBNBR-1
           [M:DIA]CODZONE([M:DIA]NBZONE)    = RUBCOD(WI)
           [M:DIA]CODTYP([M:DIA]NBZONE)     = RUBTYP(WI)
           Call TYPX3UPD([M:DIA]CODTYP([M:DIA]NBZONE),[M:DIA]TYPXT([M:DIA]NBZONE))
           [M:DIA]DIME([M:DIA]NBZONE)       = RUBDIM(WI)
           [M:DIA]NOCOURT([M:DIA]NBZONE)    = RUBINTIT(WI)
           Call TEXTE(RUBINTIT(WI),[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
           [M:DIA]NOLIB([M:DIA]NBZONE)      = RUBMNL(WI)    #
           [M:DIA]NBZONE+=1
        Next
#
When Default
    GERR=1 : GMESSAGE="Xtend - Interface type unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)
    End
Endcase

Gosub SET_WEXIST

Affzo [DIA]10
End

$SETDATA_E
GERR=2
GMESSAGE=mess(44,7900,1)-[L]WEBSRCCOD
Resume

# Mise à jour flag rub déjà existante
$SET_WEXIST
Local Shortint FLG
For WI=0 To [M:DIA]NBZONE-1
    Call CONTROLE("AYF", "", [M:DIA]CODZONE(WI) ,[M:DIA]FCYCOD ,FLG) From CONTOBJ
    If FLG=0 : [M:DIA]WEXIST(WI)=2 : Else : [M:DIA]WEXIST(WI)=1 : Endif
Next
Return

Subprog AM_WSEL(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 FIECOD(nolign-1)=CODZONE(nolign-1)
 If DIME(nolign-1)>1 : INDCHX(nolign-1)=1 : Endif
 zonsui="FIECOD("+num$(nolign-1)+")"
Else
 FIECOD(nolign-1)=""
Endif
End

#Subprog AM_INDCHX(VALEUR)
#Variable Integer  VALEUR
#If VALEUR<>2
 #zonsui="IND("+num$(nolign-1)+")"
#Else
# IND(nolign-1)=0
#Endif
#End

Subprog APRES_NBZONE
# mkstat=0 : pour afficher l'erreur (NBZONE est un chp bas de tableau)
Local Char WCODE(GLONAYF)
Local Integer NOL, WOK
WOK=1
Gosub COD_VER
If !WOK
    zonsui="[M]FIECOD("+num$(NOL)+")"
    mkstat=0
Endif
End

$COD_VER
NOL=nolign-1
If [M:DIA]FIECOD(NOL)<>""
    Call UNICITE([M]FIECOD(nolign-1),[M]FIECOD) From OBJDIV
    If mkstat : zonsui="[M]FIECOD("+num$(NOL)+")" : WOK=0 : Endif

    If [M:DIA]DIME(NOL)=1
        WCODE = [M:DIA]FIECOD(NOL) : Gosub COD_LEC
    Else
        Case [M:DIA]INDCHX(NOL)
        When 1    # aucun
          WCODE = [M:DIA]FIECOD(NOL) : Gosub COD_LEC
        When 2    # tous
          For NIND=1 To [M:DIA]DIME(NOL)
            WCODE = [M:DIA]FIECOD(NOL)+num$(NIND-1) : Gosub COD_LEC
            If !WOK : Break : Endif
          Next
        When 3    # Un
                WCODE = [M:DIA]FIECOD(NOL)+num$([M:DIA]IND(NOL)) : Gosub COD_LEC
        Endcase
    Endif
Endif
Return

$COD_LEC
Read [AYF]AYF0 = [M:DIA]FCYCOD; toupper(WCODE)
If fstat=0
    GMESSAGE = mess(43,7900,1)-[AYF]FIECOD
    GERR=1
    WOK=0
Endif
Return

# ---
Subprog B1_NBZONE
Local Integer FLGSEL : FLGSEL=2
Gosub SEL_NBZONE
End

Subprog B2_NBZONE
Local Integer FLGSEL : FLGSEL=1
Gosub SEL_NBZONE
End

$SEL_NBZONE
Local Integer WI
Local Integer  SAVNOL
Local Shortint FLG
SAVNOL=nolign
Local Integer WNEW
For WI=SAVNOL-1 To [M:DIA]NBZONE-1
    Call CONTROLE("AYF", "", [M:DIA]CODZONE(WI) ,[M:DIA]FCYCOD ,FLG) From CONTOBJ
    If FLG
     WNEW=1
     [M:DIA]WSEL(WI)=FLGSEL  : nolign=WI+1 : Call AM_WSEL([M:DIA]WSEL(WI))
     GMESSAGE="" # suite ctl
    Endif
Next
nolign=SAVNOL

If WNEW
 Affzo [M:DIA]10
Else
 GERR=2 : GMESSAGE=mess(92,7900,1)
Endif
Return
# ---


Subprog AM_TYPXT(VALEUR)
Variable Integer VALEUR
If !(VALEUR=8)     # pas un mnl
    [M:DIA]NOLIB(nolign-1)=0
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran AYFTABSEL) 18/09/2007 16:29:32 (JPJ)
######################################################################################
Subprog C_FIECOD(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
Local Integer NOL : NOL = nolign-1

If [M:DIA]DIME(NOL)=1   # Sinon ctl en après ligne
    WCODE = VALEUR : Gosub COD_LEC
    If GERR : mkstat=2 : Endif
Endif
End


