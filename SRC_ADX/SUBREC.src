##########################################################################
## $C_FLD : Fonction de Controle sur la saisie des rubriques            ##
##########################################################################
$C_FLD

Local Integer K , DIME , DIMMAX
Local Char    ZONE(20)

Local Char    WCHAR(15)          : # Contient le nom du champ de sélection moins un éventuel indiçage FQ93941
Local Integer NCHAR              : # Rang dans la chaine de la première parenthèse ouvrante           FQ93941

VALEUR = toupper(VALEUR)
ZONE = VALEUR

##---- Lecture afin de voir si la rubrique existe dans la table ---------  ##

# FQ93941 : on enlève un éventuel indiçage pour le contrôle de la présence du champ dans la table
NCHAR = instr(1,ZONE,"(")
If NCHAR
  WCHAR = seg$(ZONE, 1, NCHAR-1)
Else
  WCHAR = ZONE
Endif

#Read [ATZ]CODZONE = evalue("[M]TBL"+num$(I));ZONE : # FQ93941
Read [ATZ]CODZONE = evalue("[M]TBL"+num$(I));WCHAR
If fstat
   GMESSAGE = mess(9,124,1) : # Champ inexistant
   mkstat = 2 : End
Endif

If [F:ATZ]CODTYP="AXX"
   GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de donnée incorrect
   mkstat = 2 : End
Endif

Read [ATY]CODTYP = [F:ATZ]CODTYP
If !fstat
   If  [F:ATY]TYPTYP>8
       GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de donnée incorrect
       mkstat = 2 : End
   Else
       WITYP = [F:ATY]TYPTYP
   Endif
Endif

VALEUR = ZONE

Return
