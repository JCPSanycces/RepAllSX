Variable Char    VALEUR()
[M:RC2]VAL3 =  VALEUR
Gosub CRE_REQUETE
End

Subprog AM_VAL3(VALEUR)
Variable Char    VALEUR()
[M:RC2]VAL3 =  VALEUR
Gosub CRE_REQUETE
End

Subprog AM_VAL4(VALEUR)
Variable Char    VALEUR()
[M:RC2]VAL4 =  VALEUR
Gosub CRE_REQUETE
End

Subprog AM_VAL5(VALEUR)
Variable Char    VALEUR()
[M:RC2]VAL5 =  VALEUR
Gosub CRE_REQUETE
End
##########################################################################
## $CRE_REQUETE : Création de la requete                                ##
##########################################################################
$CRE_REQUETE

Local Char WCREQUETE (255)
Local Char WCOBJET

Local Integer WIANDORPREC
Local Integer WIANDORSUIV
Local Integer WIANDOR
Local Integer WIOPE
Local Integer WIPAR

Local Char WCOBJETLG
Local Char WCRUB
Local Char WCVAL
Local Char WCANDOR
Local Char WCOPE
Local Char WCPAR1
Local Char WCPAR2

WCREQUETE   = ""
WCPAR1      = ""
WCPAR2      = ""
WIANDORPREC = 0
WIANDORSUIV = 0
WIPAR       = G_NON
WCOBJETLG   = ""

WCOBJET  = ' [F:OBC]'
WCVAL = VALEUR
#---------- Transformation des opérateurs  --------------------------*
#---------- Transformation des and-or      --------------------------*
#---------- Alimentation requete           --------------------------*
WCOBJETLG   = [M:RC2]TBL1
WIOPE       = [M:RC2]OPE1
WIANDOR     = 0
WCRUB       = [M:RC2]FLD1
WCVAL       = [M:RC2]VAL1
WIANDORSUIV = [M:RC2]ANDOR2
Gosub RECH_OPE
Gosub RECH_ANDOR
Gosub ALIM_REQUETE

WCOBJETLG   = [M:RC2]TBL2
WIOPE       = [M:RC2]OPE2
WIANDOR     = [M:RC2]ANDOR2
WCRUB       = [M:RC2]FLD2
WCVAL       = [M:RC2]VAL2
WIANDORSUIV = [M:RC2]ANDOR3
Gosub RECH_OPE
Gosub RECH_ANDOR
Gosub ALIM_REQUETE

WCOBJETLG   = [M:RC2]TBL3
WIOPE       = [M:RC2]OPE3
WIANDOR     = [M:RC2]ANDOR3
WCRUB       = [M:RC2]FLD3
WCVAL       = [M:RC2]VAL3
WIANDORSUIV = [M:RC2]ANDOR4
Gosub RECH_OPE
Gosub RECH_ANDOR
Gosub ALIM_REQUETE

WCOBJETLG   = [M:RC2]TBL4
WIOPE       = [M:RC2]OPE4
WIANDOR     = [M:RC2]ANDOR4
WCRUB       = [M:RC2]FLD4
WCVAL       = [M:RC2]VAL4
WIANDORSUIV = [M:RC2]ANDOR5
Gosub RECH_OPE
Gosub RECH_ANDOR
Gosub ALIM_REQUETE

WCOBJETLG   = [M:RC2]TBL5
WIOPE       = [M:RC2]OPE5
WIANDOR     = [M:RC2]ANDOR5
WCRUB       = [M:RC2]FLD5
WCVAL       = [M:RC2]VAL5
WIANDORSUIV = 1
Gosub RECH_OPE
Gosub RECH_ANDOR
Gosub ALIM_REQUETE

[M:RC2]REQUETE = WCREQUETE
Affzo [RC2]

Return
#---------- Recherche AND/OR  --------------------------*
$RECH_ANDOR

WCANDOR = ""

#-- Parentheses ( si on traite un 'et' qui sera suivi d'un 'ou' --------------------------*
If WIANDORSUIV = 2  and WIANDORSUIV <> WIANDOR
   WCPAR1    = '('
   WIPAR       = G_OUI
Else
   WCPAR1    = ''
Endif

#-- Parentheses ( si on traite un 'et' qui a été précédé d'un 'ou' -----------------------*
If WIANDORSUIV = 1  and WIPAR       = G_OUI
   WCPAR2    = ')'
   WIPAR       = G_NON
Else
   WCPAR2    = ''
Endif

If WIANDOR = 1
  WCANDOR = " and "
Elsif WIANDOR = 2
  WCANDOR = " or "
Endif

WIANDORPREC = WIANDOR

Return
#---------- Recherche opérateur  --------------------------*
$RECH_OPE

WCOPE = ""

If WIOPE = 2
  WCOPE = "="
Elsif WIOPE = 3
  WCOPE = "<>"
Elsif WIOPE = 4
  WCOPE = ">"
Elsif WIOPE = 5
  WCOPE = ">="
Elsif WIOPE = 6
  WCOPE = "<"
Elsif WIOPE = 7
  WCOPE = "<= "
Endif

Return
#---------- Alimentation de la requete   --------------------------*
#-- TYPTYP=7 -> alpha, TYPTYP=8 -> date, TYPTYP=autre -> Num ------*
$ALIM_REQUETE
Local Char WCQUOTE
Local Char EXPR
Local Char    WCHAR(15)          : # Contient le nom du champ de sélection moins un éventuel indiçage FQ93941
Local Integer NCHAR              : # Rang dans la chaine de la première parenthèse ouvrante           FQ93941
WCQUOTE = "'"

##---- Lecture afin de voir si la rubrique existe dans la table ---------  ##

If WCVAL  <> ""
   # FQ93941 : on enlève un éventuel indiçage pour le contrôle de la présence du champ dans la table
   NCHAR = instr(1,WCRUB,"(")
   If NCHAR
     WCHAR = seg$(WCRUB, 1, NCHAR-1)
   Else
    WCHAR = WCRUB
   Endif
   #Read [ATZ]CODZONE = WCOBJETLG   ;WCRUB  # FQ93941
   Read [ATZ]CODZONE = WCOBJETLG   ;WCHAR
   If !fstat
      Read [ATY]CODTYP = [F:ATZ]CODTYP
      If !fstat
          If  [F:ATY]TYPTYP = 7
              WCQUOTE = "'"
              WCREQUETE = WCREQUETE  + WCANDOR + WCPAR1  + WCOBJET  + WCRUB - WCOPE - WCQUOTE  + WCVAL + WCQUOTE  + WCPAR2
          Elsif   [F:ATY]TYPTYP = 8
              EXPR += '['+format$(GFMD,gdat$(WCVAL))+']'
              WCREQUETE = WCREQUETE  + WCANDOR + WCPAR1  + WCOBJET  + WCRUB - WCOPE - EXPR  -  WCPAR2
          Else
              WCQUOTE = ""
              WCREQUETE = WCREQUETE  + WCANDOR + WCPAR1  + WCOBJET  + WCRUB - WCOPE - WCQUOTE  + WCVAL + WCQUOTE  + WCPAR2
          Endif
       Endif
   Endif

Endif

Return
##################################################
##FQ-87418  Contrôle du site / groupe de sites
#           autorisés pour une section
##################################################
Subprog CONTSITE(GROUP,PSOC, RCCEOK)
Value    Char    GROUP
Value    Char    PSOC
Variable Integer RCCEOK

RCCEOK=G_OUI

If GROUP<>"" & PSOC <>""
    If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
    If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
    Look [FGR]FGR1 = GROUP;PSOC
    If fstat
       For [FCY]FCY1 Where LEGCPY= PSOC
          Look  [FGR]FGR0 = GROUP;[F:FCY]FCY
          If fstat
             RCCEOK = G_NON
          Else
             RCCEOK = G_OUI
             Break
          Endif
       Next
    Endif
Endif

End

