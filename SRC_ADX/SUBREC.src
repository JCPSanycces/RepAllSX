Subprog C_ANDOR2(VALEUR)
Variable Integer VALEUR
Local Integer WIRBANDOR
WIRBANDOR= VALEUR

If WIRBANDOR= 2 and  [M]FLD2 <> "" and [M]FLD2 <> [M]FLD1
    GMESSAGE = mess(78,GML_MSGREC,1)  : GERR=1
    End
Endif
If WIRBANDOR= 1 and  [M]FLD2 <> "" and [M]FLD2 = [M]FLD1
    GMESSAGE = mess(79,GML_MSGREC,1)  : GERR=1
