##########################################################################
## Gestion de la sélection des sociétés et des sites
##########################################################################
#=> Avant zone de la variable de bas de tableau du tableau des sites

Subprog AV_NBFCY
 If G_FCYTAB_DISABLE=G_OUI
  Grizo [M:RC1]15
 Endif
End

#=> Après modif du flag CPY

Subprog AM_FLGCPY(VALEUR)
Variable Integer VALEUR

Local Integer I_FCY, I_CPY
Local Integer WIVALEUR

# Répercussions d'un changement d'état d'une société sur ses sites
WIVALEUR = VALEUR

If VALEUR    = G_OUI
  # On sélectionne la société
  # On coche tous les sites correspondants à la société qui vient d'être cochée
  For I_FCY=1 To [M:RC1]NBFCY
   If [M:RC1]FCYCPY(I_FCY-1)=[M:RC1]CPY(nolign-1) & [M:RC1]FLGFCY(I_FCY-1)=G_NON
    [M:RC1]FLGFCY(I_FCY-1)=G_OUI
   Endif
  Next I_FCY
  # On charge l'environnement correspondant à la société :
  Call ACTION_CPY ([M:RC1]CPY(nolign-1)) From GLOFCYCPY
Elsif VALEUR = G_NON
  # On désélectionne la société
  Raz I_FCY
  For I_FCY=1 To [M:RC1]NBFCY
   If [M:RC1]FCYCPY(I_FCY-1)=[M:RC1]CPY(nolign-1) & [M:RC1]FLGFCY(I_FCY-1)=G_OUI
    [M:RC1]FLGFCY(I_FCY-1)=G_NON
   Endif
  Next I_FCY
Endif

[M:RC1]FLGCPY (nolign-1) = VALEUR

Affzo [M:RC1]

End

#=> Après modif du flag FCY
Subprog AM_FLGFCY(VALEUR)
Variable Integer VALEUR

Local Integer I_CPY, I_FCY, ROK

If VALEUR= G_OUI
   For I_CPY=1 To [M:RC1]NBCPY
    If [M:RC1]CPY(I_CPY-1)=[M:RC1]FCYCPY(nolign-1) & [M:RC1]FLGCPY(I_CPY-1)=G_NON
     [M:RC1]FLGCPY(I_CPY-1)=G_OUI
    Endif
   Next I_CPY
Elsif VALEUR=G_NON
  Local Integer FIND_FCY : Raz FIND_FCY
  For I_FCY=1 To [M:RC1]NBFCY
   If !(I_FCY=nolign)
    If [M:RC1]FCYCPY(I_FCY-1)=[M:RC1]FCYCPY(nolign-1) & [M:RC1]FLGFCY(I_FCY-1)=G_OUI
     FIND_FCY=1
    Endif
   Endif
  Next I_FCY
  If !FIND_FCY
   For I_CPY=1 To [M:RC1]NBCPY
    If [M:RC1]FCYCPY(nolign-1)=[M:RC1]CPY(I_CPY-1) & [M:RC1]FLGCPY(I_CPY-1)=G_OUI
     [M:RC1]FLGCPY(I_CPY-1)=G_NON
    Endif
   Next I_CPY
  Endif
Endif

[M:RC1]FLGFCY (nolign-1)= VALEUR

Affzo [M:RC1]

End
##------------------------------------------------------------------------------------------------##
## Avant-saisie de la variable bas de tableau qui contient la définition des bouton click droit   ##
## click droit grisé si Anciens codes = Supprimés ou si statut = A traiter (Cession intra groupe) ##
##------------------------------------------------------------------------------------------------##
Subprog AS_NBCPY
If [M:RC0]PROSTA   = GVML_RECATRC or [M:RC0]STAOLDCOD   = GVML_RECSUP
    GBOUT1=""
    GBOUT2=""
Endif

End

Subprog AS_NBFCY

If [M:RC0]PROSTA   = GVML_RECATRC or [M:RC0]STAOLDCOD   = GVML_RECSUP
    GBOUT1=""
    GBOUT2=""
Endif

End

#=> Click droit : Sélection Toutes sociétés
Subprog B1_NBCPY
  Gosub SELTOUT
End

#=> Click droit : Sélection Tous sites
Subprog B1_NBFCY
  Gosub SELTOUT
End

#=> Click droit : Aucune Sélection
Subprog B2_NBCPY
 Gosub SELRIEN
End

#=> Click droit : Sélection
Subprog B2_NBFCY
 Gosub SELRIEN
End

#=> Click droit : Sélection Tous sites
$SELTOUT
 Local Integer I_CPY, I_FCY
 For I_CPY=1 To [M:RC1]NBCPY
  [M:RC1]FLGCPY(I_CPY-1)=G_OUI
 Next I_CPY
 Affzo [M:RC1]
 For I_FCY=1 To [M:RC1]NBFCY
  [M:RC1]FLGFCY(I_FCY-1)=G_OUI
 Next I_FCY
 Affzo [M:RC1]

 mkstat=0

Return

#=>  Click droit : Tout déselectionner
$SELRIEN

 Local Integer I_CPY, I_FCY
 For I_CPY=1 To [M:RC1]NBCPY
  [M:RC1]FLGCPY(I_CPY-1)=G_NON
 Next I_CPY
 Affzo [M:RC1]
 For I_FCY=1 To [M:RC1]NBFCY
  [M:RC1]FLGFCY(I_FCY-1)=G_NON
 Next I_FCY
 Affzo [M:RC1]

 mkstat=0

Return
