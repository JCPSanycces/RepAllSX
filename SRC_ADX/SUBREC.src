#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
##         Source : SUBREC                                                                        ##
##         Auteur : JDE/MDJ                                                                       ##
##         Date création : 171004                                                                 ##
##         Traitement de parametrage de la recodification                                         ##
####################################################################################################
#  MDJ  02.03.2017 FQ 121808  : Titres fenêtre Choix en fonction de la  table traitée
#  MDJ  26.01.2017 FQ 121110  : Remplacement du Case [M:RC0]TABNAM par des if...else car message erreur sur CCE
#  MDJ  04.05.2015  FQ107562  : Recodification des familles (table FASFAM au lieu de TDIV611).
#  GLE  27/11/2013  FQ 93941  : Possibilité de préciser des champs indicés dans l'onglet de sélection
#  GLE  26/08/2013  FQ 90330  : Sélection en erreur si nombre d'axes > 200
#  MDJ  29/05/2013  FQ 90165  : Test portant s/WCGTABCPT réactivé:possible saisir section inexistante (sera ensuite créée lors du TRTRECOD)
#  MDJ  20/02/2013  FQ 87418  : Contrôle liens groupe de société/sites et sections analytiques
#  MDJ  19.02.2013  FQ 86469  : Possibilité de recodifier 1 site financier non-déclaré comme site d'inventaire
#  MDJ  28.12.2012  FQ 86480  : CIG : Ajout contrôle sur site cible
#  MDJ  17.08.2012  FQ 83418  : Alerte et blocage recodif en CIG
#  MDJ  10.08.2012  FQ 84009  : Chargement tableau des sections en fonction de la société source
#  MDJ  07.11.2011  FQ 77460  : Intitulés codes cible erronés
#  MDJ  14.10.2011  FQ 77109  : Ajout de contrôles portant sur les codes activités
#  MDJ  20/10/2010 (FQ-68218) : CIG: Autoriser les suppressions/modif dans tableau + possibilité de tout recharger
#  MDJ  06/08/2010 (FQ-56222) : Recodifications CIG et options saisissables à tort
#  MDJ  03/08/2010 (FQ-42964) : Recodifications tables diverses des Zones libres
#  MDJ  03/08/2010 (FQ-52344) : Recodifications table CCE
#  MDJ  28/07/2010 (FQ-56122) : Recodifications CIG : options saisissables à tort
#  MDJ  28/07/2010 (FQ-65873) : N°mess remplacés par globales
#  MWA  nn.nn.2009 (FQ-54343) : Gestion des concessions
## MDJ  09/10/2008 (FQ 49644) : Problème sur tunnel vers objet recodification
## MDJ  08/01/2008 (*V5)      : Aménagement pour V5
####################################################################################################
##------------------------------------------------------------------------------------------------##
##  La fonction GESREC permet d'inserer l'action GOBJET avec le parametre REC dans le menu
##  L'action GOBJET appelle :
##       - La fenètre OREC qui appelle les écrans REC0 (entête), REC1 (sélection recodif)
##         REC2 (sélection étendue)
##       - Le traitement SUBREC
##------------------------------------------------------------------------------------------------##
## PRINCIPALES ETIQUETTES UTILISEES                                                               ##
##   $OUVRE                  : Avant ouverture de l'écran                                         ##
##   $LIENS                  : Après lecture d'un enregistrement                                  ##
##   $AFFICHE_NOMTABDES      : Affichage du libelle de la table                                   ##
##   $SEL_LISTE              : Affichage d'une boite de selection avec liste tables recodifiables ##
##   $AFF_COL_NEWDES         : Colonnes VALNEWDES grisée si l'on insert pas de code dans la table ##
##   $CHARGE_SOC_SITE_NEW    : Alimentation des sociétés et site                                  ##
##   $CHARGE_TABLEAU_CDC     : Alimentation du tableau des postes à partir de la table CDC        ##
##   $CHARGE_TABLEAU_NEW     : Chargement du tableau des postes de table à recodifier en création ##
##   $CHARGE_TABLEAU_CDS_CDY : Chargement du tableau des sociétés depuis CDS et Sites depuis CDY  ##
##   $CONTROLE-SAISIE        : Controle de cohérence de la saisie                                 ##
##   $ECRIT_TABLE_CDC        : Ecriture des postes du tableau dans la table CDC                   ##
##   $ECRIT_TABLE_CDS_CDY    : Ecriture des postes du tableau des soc. dans CDS et Sites dans CDY ##
##------------------------------------------------------------------------------------------------##

## Gestion du masque REC
Raz GPILOBJ
Call OBJET("REC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
#Infbox "subrec : ACTION = "-num$(ACTION)

Case ACTION
 When "VARIANTE"    : Gosub VARIANTE
 When "OUVRE"       : Gosub OUVRE       : # Après ouverture des écrans
 When "AFFMASK"     : Gosub AFFMASK     : # Au 1er affichage de l'ecran
 When "FILTRE"      : Gosub FILTRE
 When "OK"          : Gosub OK
 When "AVANT_OK"    : Gosub AVANT_OK
 When "END"         : Gosub FIN
 When "FERME"       : Gosub FERME
 When "SEL_LISTE"   : Gosub SEL_LISTE   : # selection des tables par click droit
 When "SEL_TABLE"   : Gosub SEL_TABLE   : # selection des tables par click droit
 When "CREATION"    : Gosub CREATION    : # Durant l'action de création
 When "RAZCRE"      : Gosub RAZCRE      : # Losqu'on va créer une nouvelle fiche
 When "RAZDUP"      : Gosub RAZDUP      : # Losqu'on va dupliquer une nouvelle fiche
 When "VERIF_CRE"   : Gosub VERIF_CRE   : # Avant la transaction de création de l'enregistrement
 When "APRES_CRE"   : Gosub APRES_CRE   : # Aprés la crÃ©ation de l'enregistrement
 When "INI_CRE"     : Gosub INI_CRE     : # Avant la transaction de création de l'enregistrement
 When "APRES_MOD"   : Gosub APRES_MOD   : # Après la modification de l'enregistrement
 When "AP_ANNULE"   : Gosub AP_ANNULE   : # Après l'annulation de l'enregistrement
 When "VERIF_MOD"   : Gosub VERIF_MOD   : # Avant la modification de l'enregistrement
 When "INI_MOD"     : Gosub INI_MOD     : # Alimentation de la classe [F]
 When "LIENS"       : Gosub LIENS       : # Après lecture d'un enregistrement
 When "EXEBOUT"     : Gosub EXEBOUT     : # Boutons : B : Lancement du traitement
 When "SETBOUT"     : Gosub SETBOUT     : # Gestion des boutons
 When Default
Endcase
Return
########################################################################
$VARIANTE

Return
####################################################################################################
## $OUVRE: avant ouverture de l'écran                                                             ##
####################################################################################################
$OUVRE

Global  Char WCGTABCPT
Global  Char GREFCDF
Global  Char GREFCIG

WCGTABCPT  = GTABCPT

If clalev([F:ADI])  =0 : Local File ATABDIV   [ADI]           : Endif : # Tables diverses
If clalev([F:ADV])  =0 : Local File ATABTAB   [ADV]           : Endif : # Parametres Tables diverses
If clalev([F:ATB])  =0 : Local File ATABLE    [ATB]           : Endif : # Table des Tables
If clalev([F:CPY])  =0 : Local File COMPANY   [CPY]           : Endif : # Table des Sociétés
If clalev([F:FCY])  =0 : Local File FACILITY  [FCY]           : Endif : # Table des Sites
If clalev([F:FAM])  =0 : Local File FASFAM    [FAM]           : Endif : # Table des Familles #FQ107562
If clalev([F:ATX2]) =0 : Local File ATEXTE    [ATX2]          : Endif : # Table des textes
If clalev([F:CDC])  =0 : Local File CDFCOD    [CDC]           : Endif : # Table des nouveaux codes
If clalev([F:CDS])  =0 : Local File CDFCPY    [CDS]           : Endif : # Table des Sociétés à recodifier
If clalev([F:CDY])  =0 : Local File CDFFCY    [CDY]           : Endif : # Table des Sites    à recodifier
If clalev([F:APL])  =0 : Local File APLSTD    [APL]           : Endif : # Table des menus locaux
If clalev([F:ATZ])  =0 : Local File ATABZON   [ATZ]           : Endif : # Dictionnaire des champs
If clalev([F:ATY])  =0 : Local File ATYPE     [ATY]           : Endif : # Type de données
If clalev([F:ACV])  =0 : Local File ACTIV     [ACV]           : Endif : # Code activité

# Ouverture des table LEASE et GRANTS ici plutôt quand dans l'écran REC0 FQ68932
If G_ACTLEA = G_OUI
  If clalev([F:LEA])  =0 : Local File LEASE   [LEA]           : Endif : # Contrats location financement
Endif

If G_ACTGRT = G_OUI
  If clalev([F:GRT])  =0 : Local File GRANTS  [GRT]           : Endif : # Subventions
Endif

If G_ACTCIG = G_OUI
  If clalev([F:CIG])  =0 : Local File CIGDEF  [CIG]           : Endif : # Définition cession intra-groupe
Endif

# Pour les sections :  Ajout du prefixe GTABCPT car la table est partagée avec d'autres produits de X3
If clalev([F:CCE])  =0 : Local File = GTABCPT+"CACCE"   [CCE] : Endif : # Table des Sections
If clalev([F:FGR])  =0 : Local File  FACGROUP [FGR] : Endif  : #Fq-VINCI Regroupement de sites

# Sauvegarde du contexte - variables globales
If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif

Local Mask REC0 [RC0]
Local Mask REC1 [RC1]
Local Mask REC2 [RC2]
Raz [M:RC0]
Raz [M:RC1]
Raz [M:RC2]

Local Integer WICTRLOK
Local Integer MAXLIG
Local Char    WGCIGCOD
WICTRLOK = G_OUI

# Entrée par tunnel
If TUNNEL
  GREFCDF = ""
  GREFCIG = GCIGCOD
  [M:RC0]CPYDES = GCSOCDES #*Fq-86480
  [M:RC0]CPYSRC = GCSOCSRC #*Fq-86480
  Affzo [M:RC0]CPYDES      #*Fq-86480
  Affzo [M:RC0]CPYSRC      #*Fq-86480
Endif

CLE2 = ""

Return
####################################################################################################
## $AFFMASK : Au 1er ecran affiché                                                                ##
####################################################################################################
$AFFMASK

  If GREFCIG <>  ""
    Raz [M:RC0]
    [M:RC0]REFCDF = ""
    [M:RC0]REFTRFCMP = GREFCIG
    Read [F:CIG]CIG0 = GREFCIG
    If [S]fstat = 0
       [M:RC0]CPYDES   = [M:CIG0]CPYDES(0)
       [M:RC0]DESTRFCMP= [M:CIG0]DES
    Else  #*Fq-86480 cas où l'on est en cours de création de CIG
         [M:RC0]CPYDES   = GCSOCDES
         [M:RC0]CPYSRC   = GCSOCSRC
    Endif  #*Fq-86480
    [M:RC0]PROSTA=GVML_RECATRC     :      Affzo [M:RC0]PROSTA
    GREP="C"
  Else
    Gosub REINIT_ECRAN
    If [M:RC0]PROSTA <> GVML_RECATRC
      ##---- REND INVISIBLE CERTAINS CHAMPS -----------------------------------------------------------##
      Chgfmt [M:RC0]REFTRFCMP  With "-K:1X"
      Chgfmt [M:RC0]DESTRFCMP  With "-K:1X"
    Else  #Fq-56122
      [M:RC0] FLGUPDASS  = G_NON     : Affzo  [M:RC0] FLGUPDASS : Diszo  [M:RC0] FLGUPDASS
      [M:RC0] FLGTRCEDT  = G_NON     : Affzo  [M:RC0] FLGTRCEDT : Diszo  [M:RC0] FLGTRCEDT
      [M:RC0] FLGSIM     = G_NON     : Affzo  [M:RC0] FLGSIM    : Diszo  [M:RC0] FLGSIM
    Endif
  Endif

  Affzo [M:RC0]

Return
#********************************************************************
$FILTRE

If dim(GREFCIG)>0
    FILTSUP += "REFTRFCMP =GREFCIG "
Endif

Return
####################################################################################################
####################################################################################################
## PARTIE : SAISIE ET ENREGISTREMENT DU PARAMETRAGE                                               ##
####################################################################################################
####################################################################################################
$SETBOUT

If GREP = 'C' or GREP = 'D' or GREP = 'M' or GREP = 'A' or [M:RC0]PROSTA <> GVML_RECATR
  Call VIREBOUT(CHAINE,"B") From GOBJET
Else
  # On affiche le bouton B : Traitement
  CHAINE+="B"
Endif

Return
####################################################################################################
## $EXEBOUT                                                                                       ##
####################################################################################################
$EXEBOUT
Local Integer WITRTREC
Local Integer WIRETOUROK

Case BOUT
 When "B" :
        Call TRT_RECODIF([M:RC0]REFCDF, "" , [M:RC0]FLGSIM, WIRETOUROK)  From TRTRECOD
        Read [F:CDP] = [M:RC0]REFCDF
        If [S]fstat = 0
            [M:RC0]PROSTA    = [F:CDP]PROSTA
            [M:RC0]PRODAT    = [F:CDP]PRODAT
            [M:RC0]PROUSR    = [F:CDP]PROUSR
            #Fq-56122 If [M:RC0]PROSTA   = GVML_RECTRT or  [M:RC0]PROSTA = GVML_RECTRTC
            If [M:RC0]PROSTA   = GVML_RECTRT or  [M:RC0]PROSTA = GVML_RECTRTC or [M:RC0]PROSTA = GVML_RECATRC
               Grizo [M:RC0]REFDES
               Grizo [M:RC0]PROSTA
               Grizo [M:RC0]TABNAM
               Grizo [M:RC0]CCEDIE      #Fq-52344
               Grizo [M:RC0]STAOLDCOD
               Diszo [M:RC0]FLGUPDASS
               Diszo [M:RC0]FLGSIM
               Grizo [M:RC0]PRODAT
               Grizo [M:RC0]PROUSR
               Diszo [M:RC0]FLGTRCEDT
               Grizo [M:RC1]OBCLDR
               Grizo [M:RC1]OBCPCDFAS
               Grizo [M:RC1]OBCPCDLOF
               Grizo [M:RC1]OBCPCDLEA
               Grizo [M:RC1]OBCPCDGRT
               Grizo [M:RC1]OBCPCDPHY
               Grizo [M:RC0]DATENDACT
               If [M:RC0]PROSTA <> GVML_RECATRC    #*Fq-68218
                Grizo [M:RC1]NBSTA
               Endif   #*Fq-68218
               Grizo [M:RC1]FLGFCY
               Grizo [M:RC1]FLGCPY
               Gosub GRISER_RC2
            Endif
            Affzo [M:RC0]
            Affzo [M:RC1]
            Affzo [M:RC2]
        Endif
        Gosub FIN
Endcase

Return
####################################################################################################
## $VERIF_CRE                                                                                     ##
####################################################################################################
$VERIF_CRE
Gosub VERIF
Return
####################################################################################################
## $VERIF_MOD                                                                                     ##
####################################################################################################
$VERIF_MOD
Gosub VERIF
Return
####################################################################################################
## $INI_CRE                                                                                     ##
####################################################################################################
$INI_CRE
Gosub INI
Return
####################################################################################################
## $INI_MOD                                                                                     ##
####################################################################################################
$INI_MOD
Gosub INI
Return
####################################################################################################
## $INI                                                                                     ##
####################################################################################################
$INI

If dim(GCSOCSRC)>0
  If GSOCSRC <> ""
    [F:CDP]CPYSRC = GCSOCSRC
  Endif
Endif

If dim(GCSOCDES)>0
  If GCSOCDES<> ""
    [F:CDP]CPYDES = GCSOCDES
  Endif
Endif

Return
####################################################################################################
## $APRES_CRE                                                                                     ##
####################################################################################################
$APRES_CRE

Gosub ECRIT_TABLE_CDC
Gosub ECRIT_TABLE_CDS_CDY
Enable GSTAOK

Return
####################################################################################################
## $APRES_MOD                                                                                     ##
####################################################################################################
$APRES_MOD

Gosub ECRIT_TABLE_CDC
Gosub ECRIT_TABLE_CDS_CDY
Enable GSTAOK

Return
####################################################################################################
## $AP_ANNULE                                                                                     ##
####################################################################################################
$AP_ANNULE

Delete [F:CDC] Where   [F:CDC]REFCDF    = [M:RC0]REFCDF
Delete [F:CDS] Where   [F:CDS]REFCDF    = [M:RC0]REFCDF
Delete [F:CDY] Where   [F:CDY]REFCDF    = [M:RC0]REFCDF

Return
####################################################################################################
## $VERIF : Verification des cohérences de l'écran                                                ##
####################################################################################################
$VERIF

   WICTRLOK = G_OUI
   Gosub CONTROLE_SAISIE
   If WICTRLOK = G_NON
       OK = 0
       FIN = 1
       GOK = 0
   Endif

Return
####################################################################################################
## $RAZCRE : Réinit pour création                                                                 ##
####################################################################################################
$RAZCRE

    Gosub REINIT_ECRAN
    Actzo [M:RC0]TABNAM

Return
####################################################################################################
## $CREATION : Pendant la création                                                                ##
####################################################################################################
$CREATION

    Grizo [M:RC0]TABNAM

Return
####################################################################################################
## $RAZDUP : Réinit pour duplication                                                              ##
####################################################################################################
$RAZDUP

    Gosub REINIT_ECRAN
    Actzo [M:RC0]TABNAM

Return
####################################################################################################
## $REINIT_ECRAN : Reinitialisation de l'écran                                                    ##
####################################################################################################
$REINIT_ECRAN

    Effzo [M:RC0] REFDES
    Effzo [M:RC0] TABNAM
    Effzo [M:RC0] PRODAT
    Effzo [M:RC0] PROUSR
    Effzo [M:RC0] REFTRFCMP
    Effzo [M:RC0] DESTRFCMP
    Effzo [M:RC0] TABNAMDES
    Effzo [M:RC0] CCEDIE      #Fq-52344
    Effzo [M:RC0] DATENDACT
    Effzo [M:RC1] VALOLDCOD
    Effzo [M:RC1] VALOLDDES
    Effzo [M:RC1] VALNEWCOD
    Effzo [M:RC1] VALNEWDES
    Effzo [M:RC1] FLGCPY
    Effzo [M:RC1] CPY
    Effzo [M:RC1] FLGFCY
    Effzo [M:RC1] FCY

    If !TUNNEL
      Chgfmt [M:RC0]REFTRFCMP  With "-K:1X"
      Chgfmt [M:RC0]DESTRFCMP  With "-K:1X"
    Else
      [M:RC0] REFTRFCMP=GREFCIG
      [M:RC0]CPYDES =GCSOCDES    #*Fq-86480
      [M:RC0]CPYSRC =GCSOCSRC    #*Fq-86480
      Read [F:CIG] = [M:RC0]REFTRFCMP
      If [S]fstat = 0
         [M:RC0]DESTRFCMP= [F:CIG]DES
      Endif
    Endif

    Actzo [M:RC1]OBCLDR
    Actzo [M:RC1]OBCPCDFAS
    Actzo [M:RC1]OBCPCDLOF
    If G_ACTLEA = G_OUI : Actzo [M:RC1]OBCPCDLEA   : Else : Diszo [M:RC1]OBCPCDLEA : Endif #Fq-77109
    If G_ACTGRT = G_OUI : Actzo [M:RC1]OBCPCDGRT   : Else : Diszo [M:RC1]OBCPCDGRT : Endif #Fq-77109
    If GPHY     = G_OUI : Actzo [M:RC1]OBCPCDPHY   : Else : Diszo [M:RC1]OBCPCDPHY : Endif #Fq-77109
    Actzo [M:RC1]FLGCPY
    Actzo [M:RC1]FLGFCY

    Actzo [M:RC0]FLGTRCEDT

    If  [M:RC0]PROSTA <> GVML_RECTRTC and [M:RC0]PROSTA <> GVML_RECATRC   #Fq-56122
    Actzo [M:RC0]DATENDACT
    Actzo [M:RC0]FLGSIM
    Actzo [M:RC0]FLGUPDASS
    Else
      [M:RC0] FLGUPDASS  = G_NON     : Diszo  [M:RC0] FLGUPDASS  #Fq-56122
      [M:RC0] FLGTRCEDT  = G_NON     : Diszo  [M:RC0] FLGTRCEDT  #Fq-56122
      [M:RC0] FLGSIM     = G_NON     : Diszo  [M:RC0] FLGSIM     #Fq-56122
       Diszo  [M:RC0] DATENDACT     #Fq-56122
    Endif  #Fq-56122

    Actzo [M:RC0]STAOLDCOD
    Actzo [M:RC0]REFDES
    Actzo [M:RC1]VALNEWCOD
    Actzo [M:RC1]VALNEWDES
    Actzo [M:RC1]NBSTA

    Gosub CHARGE_SOC_SITE_NEW
    Gosub VAL_DEF
    Gosub ALIM_RC2

Return
####################################################################################################
## $VAL_DEF : Maj de valeur par défaut                                                            ##
####################################################################################################
$VAL_DEF
    Actzo [M:RC0] PROSTA
    Affzo [M:RC0] REFCDF
    [M:RC0] REFDES     = mess(31,GML_MSGREC,1) - [M:RC0] REFCDF
    If GREFCIG <> ""
        [M:RC0] PROSTA     = GVML_RECATRC
        [M:RC0] REFTRFCMP  = GREFCIG
        Read [F:CIG]CIG0   = GREFCIG
        If fstat = 0
           [M:RC0]DESTRFCMP = [F:CIG]DES
        Endif
        Affzo [M:RC0]
    Else
        [M:RC0] PROSTA     = GVML_RECATR
        [M:RC0] STAOLDCOD  = GVML_RECCON
    Endif
    If  [M:RC0]PROSTA <> GVML_RECTRTC and [M:RC0]PROSTA <> GVML_RECATRC #Fq-56122
      Actzo [M:RC0]DATENDACT
      Actzo [M:RC0]FLGSIM
      Actzo [M:RC0]FLGUPDASS
    Else
      [M:RC0] FLGUPDASS  = G_NON     : Diszo  [M:RC0] FLGUPDASS  #Fq-56122
      [M:RC0] FLGTRCEDT  = G_NON     : Diszo  [M:RC0] FLGTRCEDT  #Fq-56122
      [M:RC0] FLGSIM     = G_NON     : Diszo  [M:RC0] FLGSIM     #Fq-56122
       Diszo  [M:RC0] DATENDACT     #Fq-56122
    Endif  #Fq-56122

    [M:RC1] OBCLDR     = GVML_OMBIEN
    If  [M:RC0]PROSTA = GVML_RECATRC    #Fq-56222
      [M:RC1] OBCPCDFAS  = G_OUI    : Diszo  [M:RC1] OBCPCDFAS
      [M:RC1] OBCPCDLOF  = G_OUI    : Diszo  [M:RC1] OBCPCDLOF
      If G_ACTLEA = G_OUI  : [M:RC1] OBCPCDLEA  = G_OUI    : Diszo  [M:RC1] OBCPCDLEA  : Endif #Fq-77109
      If G_ACTGRT = G_OUI  :  [M:RC1] OBCPCDGRT  = G_OUI   : Diszo  [M:RC1] OBCPCDGRT  : Endif   #Fq-77109
      If GPHY   = G_OUI    :  [M:RC1] OBCPCDPHY  = G_OUI   : Diszo  [M:RC1] OBCPCDPHY  : Endif   #Fq-77109
      Diszo [M:RC1] OBCLDR
      Gosub GRISER_RC2
    Else    #Fq-56222
      [M:RC1] OBCPCDFAS  = G_OUI
      [M:RC1] OBCPCDLOF  = G_NON
      [M:RC1] OBCPCDLEA  = G_NON
      [M:RC1] OBCPCDGRT  = G_NON
      [M:RC1] OBCPCDPHY  = G_NON
      Gosub DEGRISER_RC2
    Endif
    Gosub VIDER_RC2

Return
####################################################################################################
## $CHARGE_SOC_SITE_NEW :  Alimentation des sociétés et site                                      ##
####################################################################################################
$CHARGE_SOC_SITE_NEW

 #> Chargement du tableau des sites
 Raz nolign
 For [FCY]FCY1
  # Contrôle si l'utilisateur est habilité pour ce site
  Call CONTFCY([F:FCY]FCY) From SUPCPT
  If !mkstat
   nolign+=1
   [M:RC1]FCYCPY(nolign-1) = [F:FCY]LEGCPY
   [M:RC1]FCY(nolign-1)    = [F:FCY]FCY
   If TUNNEL
      [M:RC1]FLGFCY(nolign-1)  = G_OUI
      Grizo [M:RC1]FLGFCY
   Endif
  Endif
 Next
 [M:RC1]NBFCY=nolign

 #> Chargement du tableau des sociétés
 Local Integer I_FCY
 Local Char    CUR_FCYCPY
 Raz CUR_FCYCPY, nolign
 For I_FCY=1 To [M:RC1]NBFCY
  If CUR_FCYCPY<>[M:RC1]FCYCPY(I_FCY-1)
   CUR_FCYCPY=[M:RC1]FCYCPY(I_FCY-1)
   nolign+=1
   [M:RC1]CPY(nolign-1)=CUR_FCYCPY
   If TUNNEL
      [M:RC1]FLGCPY(nolign-1)  = G_OUI
      Grizo [M:RC1]FLGCPY
   Endif
  Endif
 Next I_FCY
 [M:RC1]NBCPY=nolign

Return
####################################################################################################
## $LIENS : Après lecture d'un enregistrement                                                    ##
####################################################################################################
$LIENS

If [M:RC0]PROSTA   = GVML_RECATRC or [M:RC0]PROSTA   = GVML_RECATR
   Actzo [M:RC1]VALNEWCOD
   Actzo [M:RC1]VALNEWDES
   Actzo [M:RC0]REFDES
   Actzo [M:RC0]FLGSIM
   Actzo [M:RC0]FLGTRCEDT
   Actzo [M:RC1]5
   Gosub DEGRISER_RC2
Endif

#Fq-56122 If [M:RC0]STAOLDCOD   <> GVML_RECSUP and  [M:RC0]PROSTA <> GVML_RECTRTC
If [M:RC0]STAOLDCOD   <> GVML_RECSUP and  [M:RC0]PROSTA <> GVML_RECTRTC and  [M:RC0]PROSTA <> GVML_RECATRC
   Actzo [M:RC0]FLGUPDASS
   Actzo [M:RC1]OBCLDR
   Actzo [M:RC1]OBCPCDFAS
   Actzo [M:RC1]OBCPCDLOF
   If G_ACTLEA = G_OUI : Actzo [M:RC1]OBCPCDLEA  : Endif #Fq-77109
   If G_ACTGRT = G_OUI : Actzo [M:RC1]OBCPCDGRT  : Endif #Fq-77109
   If GPHY     = G_OUI : Actzo [M:RC1]OBCPCDPHY  : Endif #Fq-77109
   Actzo [M:RC1]FLGCPY
   Actzo [M:RC1]FLGFCY
   Gosub DEGRISER_RC2
Endif

If [M:RC0]PROSTA   <> GVML_RECATRC
    Actzo [M:RC0]STAOLDCOD
    Actzo [M:RC1]OBCLDR
    Actzo [M:RC1]OBCPCDFAS
    Actzo [M:RC0]PROSTA
Endif
#--------------------------------------------------------------------------------------------------#
#  Si Statut = 'A traiter Cession IG'--> Zones non modifiables (statut, Objet, sélection objet     #
#--------------------------------------------------------------------------------------------------#
If [M:RC0]PROSTA   = GVML_RECATRC
    Grizo [M:RC0]STAOLDCOD
    Grizo [M:RC1]OBCLDR
    Grizo [M:RC1]OBCPCDFAS
    Gosub GRISER_RC2
    Grizo [M:RC1]FLGCPY
    Grizo [M:RC1]FLGFCY
    Actzo [M:RC0]REFTRFCMP
    Gosub SELTOUT
Endif

If [M:RC0]STAOLDCOD   = GVML_RECSUP
    Grizo [M:RC1]FLGCPY
    Grizo [M:RC1]FLGFCY
    Gosub SELTOUT
    Gosub GRISER_RC2

Endif
#--------------------------------------------------------------------------------------------------#
#  Si Statut = 'Traité' ou 'Traité Cession IG'--> Zones non modifiables (statut, nom table, .. )   #
#--------------------------------------------------------------------------------------------------#
Actzo [M:RC1]NBSTA

#Fq-56122  If [M:RC0]PROSTA   = GVML_RECTRT or  [M:RC0]PROSTA = GVML_RECTRTC
If [M:RC0]PROSTA   = GVML_RECTRT or  [M:RC0]PROSTA = GVML_RECTRTC or [M:RC0]PROSTA = GVML_RECATRC
      Grizo [M:RC0]REFDES
      Grizo [M:RC0]PROSTA
      Grizo [M:RC0]TABNAM
      Diszo [M:RC0]CCEDIE         #Fq-52344
      Grizo [M:RC0]STAOLDCOD
      Grizo [M:RC0]REFTRFCMP
      Grizo [M:RC0]FLGUPDASS
      Grizo [M:RC0]FLGSIM
      Grizo [M:RC0]PRODAT
      Grizo [M:RC0]PROUSR
      Grizo [M:RC1]OBCLDR
      Grizo [M:RC1]OBCPCDFAS
      Grizo [M:RC1]OBCPCDLOF
      Grizo [M:RC1]OBCPCDLEA
      Grizo [M:RC1]OBCPCDGRT
      Grizo [M:RC1]OBCPCDPHY
      Grizo [M:RC0]FLGTRCEDT
      Grizo [M:RC0]DATENDACT
      #Fq-68218   Grizo [M:RC1]NBSTA
      Grizo [M:RC1]FLGFCY
      Grizo [M:RC1]FLGCPY
      Gosub GRISER_RC2
Endif

If [M:RC0]STAOLDCOD   = GVML_RECSUP
   Grizo [M:RC0]FLGUPDASS
   Grizo [M:RC1]OBCLDR
   Grizo [M:RC1]OBCPCDFAS
   Grizo [M:RC1]OBCPCDLOF
   Grizo [M:RC1]OBCPCDLEA
   Grizo [M:RC1]OBCPCDGRT
   Grizo [M:RC1]OBCPCDPHY
   Grizo [M:RC1]FLGCPY
   Grizo [M:RC1]FLGFCY
   Gosub SELTOUT
   Gosub GRISER_RC2
Endif

If [M:RC0]PROSTA   = GVML_RECATRC
   Gosub SELTOUT
Endif

If [M:RC0]PROSTA <> GVML_RECATRC and  [M:RC0]PROSTA <> GVML_RECTRTC
  Chgfmt [M:RC0]REFTRFCMP With "-K:1X"
  Chgfmt [M:RC0]DESTRFCMP With "-K:1X"
Else
  Chgfmt [M:RC0]REFTRFCMP With "K:10X"
  Chgfmt [M:RC0]DESTRFCMP With "KP:20X"
Endif

Gosub AFF_COL_NEWDES

If G_ACTCIG = G_OUI
  Read [F:CIG] = [M:RC0]REFTRFCMP
  If [S]fstat = 0
     [M:RC0]CPYSRC= [F:CIG]CPYSRC(0)
     [M:RC0]CPYDES= [F:CIG]CPYDES(0)
     [M:RC0]DESTRFCMP= [F:CIG]DES
  Endif
Endif

Gosub AFFICHE_NOMTABDES
Grizo [M:RC0]TABNAM
Gosub CHARGE_TABLEAU_CDC
Gosub CHARGE_TABLEAU_CDS_CDY
Gosub ALIM_RC2

##--- Chargement du format des champs VAL en fonction de chaque  rubrique  ----##
I = 1 : Gosub AV_VAL : Chgfmt [M:RC2]VAL1 With FORMA
I = 2 : Gosub AV_VAL : Chgfmt [M:RC2]VAL2 With FORMA
I = 3 : Gosub AV_VAL : Chgfmt [M:RC2]VAL3 With FORMA
I = 4 : Gosub AV_VAL : Chgfmt [M:RC2]VAL4 With FORMA
I = 5 : Gosub AV_VAL : Chgfmt [M:RC2]VAL5 With FORMA

 If ( [M:RC0]PROSTA <> GVML_RECATRC ) and  ( [M:RC0]PROSTA <>  GVML_RECATR ) #*Fq-68218
  Grizo [M:RC1]NBSTA
 Endif   #*Fq-68218

#Fq-52344
If  left$ ([F:CDP]TABNAM,3) = 'CCE'
  [M:RC0]CCEDIE = [F:CDP]CCEDIE
  If [M:RC0]PROSTA   = GVML_RECTRT or  [M:RC0]PROSTA = GVML_RECTRTC or [M:RC0]PROSTA = GVML_RECATRC
      Diszo [M:RC0]CCEDIE         #Fq-52344
Endif
Endif #Fq-52344

Affzo [M:RC0]
Affzo [M:RC1]
Affzo [M:RC2]

Return
####################################################################################################
## $AFFICHE_NOMTABDES : Affichage du libelle de la table                                           ##
####################################################################################################
$AFFICHE_NOMTABDES
Local Char    WCTABNAMDES
Local Integer WINUMTEXTE
Local Char    WTABNAM  #Fq-77460

 #Fq-77460 : suppression des caractères blanc en fin de nom de table
 WTABNAM= vireblc([M:RC0]TABNAM,1)
[M:RC0]TABNAM=WTABNAM

Raz [M:RC0]CCEDIE   #Fq-52344
Chgfmt [M:RC0]CCEDIE  With "-K:3X" #Fq-52344

If  [M:RC0]TABNAM = 'FCY' or   [M:RC0]TABNAM = 'FAM'
      WINUMTEXTE = 0
      Read [F:ATB]ABRFIC = [M:RC0]TABNAM
      If [S]fstat = 0
         WINUMTEXTE = [F:ATB]INTITFIC
         Read [F:ATX2]= GLANGUE;WINUMTEXTE
         If [S]fstat = 0
            [M:RC0]TABNAMDES = [F:ATX2]TEXTE
         Endif
      Endif
Elsif left$ ([M:RC0]TABNAM,3) = 'CCE'
#*Fq-83418      Read [F:APL] = GML_AXEANAL; val(mid$([M:RC0]TABNAM,4,1));GLANGUE
#*Fq-83418       If [S]fstat = 0
#*Fq-83418           ##Fq-52344 [M:RC0]TABNAMDES = mess(46,GML_MSGREC,1) + [F:APL]LANMES + ')'
#*Fq-83418            [M:RC0]TABNAMDES =  [F:APL]LANMES
           Chgfmt [M:RC0]CCEDIE  With "K:3X"
           Affzo  [M:RC0]CCEDIE : Actzo [M:RC0]CCEDIE #Fq-52344
           [M:RC0]TABNAMDES=mess(val(mid$([M:RC0]TABNAM,4,1))+1,3290,1)  #*FQ-83418
#*Fq-83418       Endif
Elsif [M:RC0]TABNAM <> ''
      Call LECTEXTRA(WCTABNAMDES,"ATABTAB","LNGDES",num$([M:RC0]TABNAM), "" ) From ATEXTRA
      [M:RC0]TABNAMDES = WCTABNAMDES
Endif
     Affzo [M:RC0]TABNAMDES
Return
####################################################################################################
##  Actions Objet  --> SOUS PROGRAMME --> Etiquette                                               ##
####################################################################################################
####################################################################################################
## $AVANT_OK : Controle avant demarrage du traitement                                             ##
####################################################################################################
$AVANT_OK

Return
####################################################################################################
## $OK : Controle avant demarrage du traitement                                                   ##
####################################################################################################
$OK

FIN = 0
GOK = 1

Return
####################################################################################################
## $FIN :                                                                                         ##
####################################################################################################
$FIN

FIN = 1 : GOK = 0

Return
####################################################################################################
## $FERME:                                                                                         ##
####################################################################################################
$FERME

  #----------------------------------------------------------------------#
  # Si on est venu par tunnel il faut restaurer les variables globales   #
  #----------------------------------------------------------------------#
  If TUNNEL
    Gosub RESTAURE_GLOBAL_SV From GLOBIMM
  Endif

Return
####################################################################################################
## $SEL_LISTE: Affichage d'une boite de selection contenant                                       ##
##              la liste des tables recodifiables                                                 ##
####################################################################################################
##------------------------------------------------------------------------------------------------##
## Le champ TABNAM posséde une sélection appelant l'action SELNOMTAB                              ##
## L'action SELNOMTAB (modele standard SEL_LISTE) appelle le traitement standard SUBREC           ##
##------------------------------------------------------------------------------------------------##
$SEL_LISTE
  Case LISTE
    When "SELTABNAM"    : Gosub SET_TABNAM
    When "SELCIGNAM"    : Gosub SET_CIGNAM
    When "SELTABREC"    : Gosub SELTABREC2
    When "SELTABREC2"   : Gosub SELTABREC2
    When "SELGEOREC"    : Gosub SELGEOREC
  Endcase
Return
####################################################################################################
## $SEL_TABLE: Affichage d'une boite de selection contenant                                       ##
##              la liste des tables recodifiables                                                 ##
####################################################################################################
##------------------------------------------------------------------------------------------------##
$SEL_TABLE
  Case TABLE
    When "SELTABREC"     : Gosub SELTABREC2
    When "SELTABREC2"    : Gosub SELTABREC2
  Endcase
Return
####################################################################################################
## $SELTABREC: Affichage d'une boite de selection des nom de tables                              ##
####################################################################################################
$SELTABREC
  Local Char    WTABNAMDIV
  Local Char    WTABNAM
  Local Char    WCLIB
  Local Integer WINUMTEXTE
  Local Integer I

WTABNAM=[M:RC0]TABNAM

I = 1
While WTABNAMAUT (I) <> ""
  WCLIB      = ""
  WINUMTEXTE = 0
  Read [F:ATB]ABRFIC = WTABNAMAUT (I)
  If [S]fstat = 0
    WINUMTEXTE = [F:ATB]INTITFIC
    Read [F:ATX2]= GLANGUE;WINUMTEXTE
    If [S]fstat = 0
       WCLIB = [F:ATX2]TEXTE
    Endif
    TEX(I)   = format$("Kb:5X",WTABNAMAUT (I))
    TEXTE(I) = format$("Kb:20X",mess(23,GML_MSGREC,1))  - TEX(I)+ " "+ WCLIB
  Endif
  I    += 1
Wend

I = I - 1
  NBTEX = I

Return
####################################################################################################
$SELGEOREC
####################################################################################################
# ******  Liste des sites géographique d'une société   *************
Local Shortint I
Local Char     LCPY
Local Char     LTABNAM(3)
Local Integer  RCCEDOK     #FQ-87418
Local Char     SIVYFCY

  If  [M:RC0]CPYDES <> ""
    LCPY= [M:RC0]CPYDES
  Else
    #Fq-56122 LCPY    = [M:CIG0]CPYDES(0)        # PARAM(1) : # Récupération paramètre société
    LCPY    = PARAM(1) : # Récupération paramètre société
  Endif
  LTABNAM = PARAM(2) : # Récupération paramètre table à recodifier

  If clalev([F:WFCY])=0 : Local File FACILITY  [WFCY] : Endif
  If clalev([F:XFCY])=0 : Local File FACILITY  [XFCY] : Endif
  If clalev([F:XCCE])=0 : Local File CACCE     [XCCE] : Endif  #Fq-87418
  If clalev([F:XFAM])=0 : Local File FASFAM    [XFAM] : Endif  #FQ107562

  Local Char CRITSELFCY(255) : CRITSELFCY="1=1"

  NBTEX = 0
  TIT = mess(42,GML_MSGFAS,1)

  # On sélectionne tous les sites de le société qui sont sites d'inventaire
  If LCPY<>"" & LTABNAM="FCY"
   CRITSELFCY="LEGCPY=LCPY"
  Endif

  If LCPY<>"" & LTABNAM="FCY"
    # FQ90330 : anticipation d'une erreur potentielle si le nombre de sites est supérieur à 200
    Local Integer L_NBFCY
    Filter [F:WFCY] Where LEGCPY=LCPY
    L_NBFCY = rowcount([F:WFCY])
    If (L_NBFCY > 200 ) Then
      Local Char TEX(50)(0..L_NBFCY), TEXTE(80)(0..L_NBFCY)
    Endif
    Filter [F:WFCY]

    For [WFCY]FCY0 Where LEGCPY=LCPY
      #*Fq-54438 If [F:WFCY]IVYFCY<>SIVYFCY
      NBTEX       += 1
      #Fq-86469  On prend tous les sites de la société et non pas seulement les sites déclarés site d'inventaire
      #Fq-86469 SIVYFCY = [F:WFCY]IVYFCY
      SIVYFCY = [F:WFCY]FCY
      TEX(NBTEX)   = SIVYFCY
      TEXTE(NBTEX) = SIVYFCY
      Read [XFCY]FCY0=SIVYFCY
      If !fstat
        TEXTE(NBTEX)  -= [F:XFCY]FCYNAM
      Endif
      #*Fq-54438 Endif
    Next
  Endif


#FQ107562
  If LCPY<>"" & LTABNAM="FAM"
    TIT = mess(38,GML_MSGFASPR,1) #Fq-121808
    Local Char WFAMDES(60)
    For [FAM]FAM0
      NBTEX       += 1
      TEX(NBTEX)     = [F:FAM]FAMREF
      TEXTE(NBTEX)   = [F:FAM]FAMREF
       Call LECTEXTRA(WFAMDES,"FASFAM","FAMDES",[F:FAM]FAMREF,"") From ATEXTRA
      TEXTE(NBTEX)  -= WFAMDES
    Next
  Endif

  #Fq-87418
  If mid$(LTABNAM,1,3) ="CCE"
    TIT = mess(179,111,1)   #Fq-121808
    # FQ90330
    Local Integer NBCCE
    Filter [F:CCE] Where DIE = [M:RC0]CCEDIE
    NBCCE = rowcount([F:CCE])
    If (NBCCE > 200 ) Then
      Local Char TEX(50)(0..NBCCE), TEXTE(80)(0..NBCCE)
    Endif
    Filter [F:CCE]

    NBTEX = 0
    For[CCE] Where (DIE = [M:RC0]CCEDIE)
      If ([F:CCE]FCY<> "")
        Call CONTSITE([F:CCE]FCY,[M:RC0]CPYDES,RCCEDOK)
        #----- Section compatible avec le site/société -----#
        If RCCEDOK <>  G_OUI : Goto NEXTCCESEL : Endif
      Endif
      NBTEX       += 1
      TEX(NBTEX)   =  [F:CCE]CCE
      TEXTE(NBTEX) = [F:CCE]CCE
      Read [XCCE]CCE0=[F:CCE]DIE;[F:CCE]CCE
      If !fstat
        TEXTE(NBTEX)  -= [F:XCCE]DES
      Endif
      $NEXTCCESEL
    Next
  Endif #Fq-87418

Return
####################################################################################################
## $SELTABREC2: Affichage d'une boite de selection des nom de tables                              ##
####################################################################################################
$SELTABREC2
Local Char  PTABNAM

PTABNAM=PARAM(1)

#FQ107562 Ajout "FAM"
Case PTABNAM
  When "FCY"
    OBJET = "FCY"
   When "FAM"
    OBJET = "FAM"
  When Default
    PARAM(1)=PTABNAM
    PARAM(2)=""
    Gosub SELADI From SUBADI
Endcase
PARAM(1)=num$(PTABNAM)

Return
####################################################################################################
## $SET_TABNAM: Affichage d'une boite de selection des nom de tables                              ##
####################################################################################################
$SET_TABNAM
  Local Char    WTABNAMDIV
  Local Char    WTABNAMAUT (20) (5)
  Local Char    WCLIB
  Local Integer WINUMTEXTE
  Local Integer I

  I = 0
##------------------------------------------------------------------------------------------------##
## Selection tables Sites et Familles                                                                 ##
##------------------------------------------------------------------------------------------------##
WTABNAMAUT     = ""
    WTABNAMAUT (1) = "FCY"
    WTABNAMAUT (2) = "FAM"  #*FQ107562

I = 1
While WTABNAMAUT (I) <> ""
  WCLIB      = ""
  WINUMTEXTE = 0
  Read [F:ATB]ABRFIC = WTABNAMAUT (I)
  If [S]fstat = 0
    WINUMTEXTE = [F:ATB]INTITFIC
    Read [F:ATX2]= GLANGUE;WINUMTEXTE
    If [S]fstat = 0
       WCLIB = [F:ATX2]TEXTE
    Endif
    TEX(I)   = format$("Kb:5X",WTABNAMAUT (I))
    TEXTE(I) = format$("Kb:20X",mess(23,GML_MSGREC,1))  - TEX(I)+ " "+ WCLIB
  Endif
  I    += 1
Wend

I = I - 1
##----------------------------------------- ------------------------------------------------------##
## Selection table des sections analytiques                                                       ##
##------------------------------------------------------------------------------------------------##
  Filter [APL] Where (LANCHP = GML_AXEANAL and LAN = GLANGUE and LANNUM > 0)
  For [APL]
      I    += 1
      TEX(I)= 'CCE' + num$([F:APL]LANNUM)
      TEXTE(I) = format$("Kb:20X",mess(23,GML_MSGREC,1))  - TEX(I) + " " + mess(46,GML_MSGREC,1) + [F:APL]LANMES + ')'
  Next
  Filter [APL]
##------------------------------------------------------------------------------------------------##
## Selection table diverses                                                                       ##
##------------------------------------------------------------------------------------------------##
  Filter [ADV] Where (UPDFLG = G_OUI and MODULE = 14)
  For [ADV]
      I    += 1
      TABNAMDIV = num$([F:ADV]NUMTAB)
      Call LECTEXTRA(TEXTE(I),"ATABTAB","LNGDES",TABNAMDIV  , "" ) From ATEXTRA
      TEX(I)   = format$("Kb:6X",TABNAMDIV)
      TEXTE(I) = format$("Kb:20X",mess(22,GML_MSGREC,1))  - TEX(I) + " " + TEXTE(I)
  Next
  Filter [ADV]

  TIT = mess(18,GML_MSGREC,1)
  NBTEX = I

Return
####################################################################################################
## $SET_CIGNAM: Affichage d'une boite de selection des cessions intra-groupe                      ##
####################################################################################################
$SET_CIGNAM
Local Integer I

  I = 0
##------------------------------------------------------------------------------------------------##
## Selection des cessions intra-groupe                                                            ##
##------------------------------------------------------------------------------------------------##
Filter [CIG] Where (CIGSTA = GVML_CIGSTAP)
For [CIG]
      I    += 1
      TEX(I)   = [F:CIG]CIGCOD
      TEXTE(I) = mess(83,GML_MSGREC,1) + ' : ' + format$("Kb:15X",[F:CIG]CIGCOD) + [F:CIG]DES
Next
Filter [CIG]

TIT = mess(83,GML_MSGREC,1)
NBTEX = I

Return
######################################################################################
## CONTROLE GENERALE                                                                ##
######################################################################################
#------------------------------------------------------------------------------------#
# $CONTROLE-SAISIE: Controle de cohérence de la saisie                               #
#------------------------------------------------------------------------------------#
$CONTROLE_SAISIE

Local Integer LOK
Local Integer WI
Local Integer WICOCHE

Affzo [M:RC0]
Affzo [M:RC1]
Affzo [M:RC2]
#--------------------------------------------------------------------------------------------------#
# Si Statut = 'A Traiter Cession IG' --> Référence cession intra-groupe obligatoire                #
#                                    --> Ancien code = 'Conservés' obligatoire et non modifiable   #
#                                    --> Maj association = 'Non'  et non modifiable                #
#                                    --> FAS,LOF,lea,.. coché obligatoirement                      #
#--------------------------------------------------------------------------------------------------#
#If [M:RC0]PROSTA   = GVML_RECATRC and [M:RC0]REFTRFCMP = ""
#    WICTRLOK = G_NON
#    GMESSAGE = mess(26,GML_MSGREC,1) + '\' +  mess(30,GML_MSGREC,1)  : GERR=1
#    mkstat=2
#    Return
#Endif

If [M:RC0]PROSTA   = GVML_RECATRC
    [M:RC0]STAOLDCOD = GVML_RECCON
    [M:RC0]FLGUPDASS = G_NON
    [M:RC0]FLGSIM    = G_NON
    [M:RC0]FLGTRCEDT = G_NON
    [M:RC1]OBCPCDFAS   = G_OUI
    [M:RC1]OBCPCDLOF   = G_OUI
    If G_ACTLEA = G_OUI : [M:RC1]OBCPCDLEA  = G_OUI : Endif #Fq-77109
    If G_ACTGRT = G_OUI : [M:RC1]OBCPCDGRT  = G_OUI : Endif #Fq-77109
    If GPHY     = G_OUI : [M:RC1]OBCPCDPHY  = G_OUI : Endif #Fq-77109
    Grizo [M:RC1]OBCPCDGRT
    Grizo [M:RC1]OBCPCDLOF
    Grizo [M:RC1]OBCPCDLEA
    Grizo [M:RC1]OBCPCDGRT
    Grizo [M:RC1]OBCPCDPHY
    #
    Diszo [M:RC0]STAOLDCOD
    Diszo [M:RC0]FLGUPDASS
    Diszo [M:RC0]FLGSIM
    Diszo [M:RC0]FLGTRCEDT

Elsif [M:RC0]PROSTA <> GVML_RECTRTC
    Actzo [M:RC0]STAOLDCOD
    Actzo [M:RC0]FLGUPDASS
    Actzo [M:RC0]FLGSIM
    Actzo [M:RC0]FLGTRCEDT
Endif

Affzo [M:RC0]

If [M:RC0]PROSTA   = GVML_RECATRC and [M:RC0]REFTRFCMP = ""
    WICTRLOK = G_NON
    GMESSAGE = mess(26,GML_MSGREC,1) + '\' +  mess(30,GML_MSGREC,1)  : GERR=1
    mkstat=2
    Return
Endif
#--------------------------------------------------------------------------------------------------#
#  Controle cohérence entre statut et nom de la table                                              #
#--------------------------------------------------------------------------------------------------#
# Si Statut =  'A Traiter'                                                                         #
#                          --> Table Site         non recodifiable                                 #
#--------------------------------------------------------------------------------------------------#
If [M:RC0]PROSTA= GVML_RECATR and [M:RC0]TABNAM = "FCY"
    GMESSAGE= mess(25,GML_MSGREC,1)
    GERR=1
    WICTRLOK = G_NON
    Return
Endif
#--------------------------------------------------------------------------------------------------#
#  Controle cohérence entre nom de la table et statut ancien code                                  #
#--------------------------------------------------------------------------------------------------#
# Statut 'Inactif' et 'Supprimé' impossible si table = CCE  partagées avec d'autres applications   #
# Statut 'Supprimé' impossible si table FCY                                             #
#--------------------------------------------------------------------------------------------------#
If  (left$ ([M:RC0]TABNAM,3) =  'CCE' and  WCGTABCPT  <> "") and ([M:RC0]STAOLDCOD = GVML_RECINA or [M:RC0]STAOLDCOD = GVML_RECSUP)
    GMESSAGE= mess(53,GML_MSGREC,1)
    GERR=1
    WICTRLOK = G_NON
    Return
Endif

If ([M:RC0]TABNAM = "" or [M:RC0]TABNAM = 'FCY' ) and ([M:RC0]STAOLDCOD = GVML_RECINA or [M:RC0]STAOLDCOD = GVML_RECSUP)
    GMESSAGE= mess(56,GML_MSGREC,1)
    GERR=1
    WICTRLOK = G_NON
    Return
Endif
#--------------------------------------------------------------------------------------------------#
#  Controle cohérence entre objet maitre et Objet traité                                           #
#--------------------------------------------------------------------------------------------------#
If   ([M:RC1]OBCLDR = GVML_OMBIEN    and [M:RC1]OBCPCDFAS   = G_NON)
& or ([M:RC1]OBCLDR = GVML_OMDEPEN   and [M:RC1]OBCPCDLOF   = G_NON)
& or ([M:RC1]OBCLDR = GVML_OMLOCFI   and [M:RC1]OBCPCDLEA   = G_NON)
& or ([M:RC1]OBCLDR = GVML_OMSUBV    and [M:RC1]OBCPCDGRT   = G_NON)
    GMESSAGE= mess(40,GML_MSGREC,1)
    GERR=1
    WICTRLOK = G_NON
    Return
Endif

Affzo [M:RC1]
Affzo [M:RC2]
#--------------------------------------------------------------------------------------------------#
#  Controle qu'au moins une société est cochée                                                     #
#  (si statut <> A traiter (Cession intra groupe) et si Anciens codes <> Supprimés )               #
#--------------------------------------------------------------------------------------------------#
If [M:RC0]PROSTA   <> GVML_RECATRC and [M:RC0]STAOLDCOD   <> GVML_RECSUP
    WICOCHE = G_NON
    ##------------------------------------------------------------------------------------------------##
    ## - Lecture du tableau                                                                           ##
    ##------------------------------------------------------------------------------------------------##
    For WI = 0 To [M:RC1]NBCPY - 1
           If [M:RC1]FLGCPY (WI) = G_OUI
               WICOCHE = G_OUI
           Endif
    Next
    If WICOCHE = G_NON
        GMESSAGE= mess(47,GML_MSGREC,1)
        GERR=1
        WICTRLOK = G_NON
        Return
    Endif
    ##------------------------------------------------------------------------------------------------##
    ## - Lecture du tableau                                                                           ##
    ##------------------------------------------------------------------------------------------------##
    WICOCHE = G_NON
    For WI = 0 To [M:RC1]NBFCY - 1
           If [M:RC1]FLGFCY (WI) = G_OUI
               WICOCHE = G_OUI
           Endif
    Next
    If WICOCHE = G_NON
        GMESSAGE= mess(48,GML_MSGREC,1)
        GERR=1
        WICTRLOK = G_NON
        Return
    Endif
Endif
#--------------------------------------------------------------------------------------------------#
#  Controle que si inactif , une date de validité doit être saisie                                 #
#--------------------------------------------------------------------------------------------------#
If [M:RC0]STAOLDCOD   = GVML_RECINA and [M:RC0]DATENDACT  =  [0/0/0]
       GMESSAGE = mess(27,GML_MSGREC,1)
       GERR=1
       WICTRLOK = G_NON
Endif

Return
####################################################################################################
## $CHARGE_TABLEAU_NEW: Chargement du tableau des postes de table à recodifier en création        ##
####################################################################################################
$CHARGE_TABLEAU_NEW
Local Integer I
Local Integer WI
Local Char    WCDES
Local Char    WTABNAM  #Fq-77460
Local Integer RCCEOK

Effzo [M:RC1] VALOLDCOD
Effzo [M:RC1] VALOLDDES
Effzo [M:RC1] VALNEWCOD
Effzo [M:RC1] VALNEWDES

MAXLIG    = dim([M:RC1]VALOLDCOD)
nolign = 0
##------------------------------------------------------------------------------------------------##
## - Remplissage du tableau                                                                       ##
##------------------------------------------------------------------------------------------------##
#>>>>>>>>>>>>>> Fq-84009 ..............
Local Char FCY
If left$([M:RC0]TABNAM,3) = 'CCE'
   #-Fq-87418   If dim (GCSOCSRC) > 0
   #-Fq-87418      # Ajout du filtre sur les sites financiers
   #-Fq-87418      Link [FGR] With [F:FCY]FCY0=[F:FGR]FCY
   #-Fq-87418&      As [LFGR]
   #-Fq-87418&      Where   [FGR]CPY=GCSOCSRC
   #-Fq-87418      For [LFGR]
   #-Fq-87418         Filter[CCE] Where (DIE = [M:RC0]CCEDIE) and ( FCY="" or FCY=[F:LFGR]FCY or FCY=[F:LFGR]CPY)
   #-Fq-87418        For [CCE]CCE0
   #-Fq-87418            If nolign < MAXLIG
   #-Fq-87418               I=find([F:CCE]CCE,[M:RC1]VALOLDCOD(0..nolign) )
   #-Fq-87418               If I = 0
   #-Fq-87418        nolign +=1
   #-Fq-87418        [M:RC1]VALOLDCOD (nolign-1 ) = [F:CCE]CCE
   #-Fq-87418        [M:RC1]VALOLDDES(nolign-1 )  = [F:CCE]DES
   #-Fq-87418               Endif
   #-Fq-87418            Endif
   #-Fq-87418         Next  #CCE
   #-Fq-87418         Filter[CCE]
   #-Fq-87418      Next #LFGR
   #*Fq-87418

   If [M:RC0]CPYSRC <> ""
      Filter[CCE] Where (DIE = [M:RC0]CCEDIE)
         For [CCE]CCE0
         If ([F:CCE]FCY<> "")
            Call CONTSITE([F:CCE]FCY,[M:RC0]CPYSRC,RCCEOK)
            #----- Section compatible avec le site/société -----#
            If RCCEOK <>  G_OUI : Goto NEXTCCE : Endif
         Endif
            If nolign < MAXLIG
               I=find([F:CCE]CCE,[M:RC1]VALOLDCOD(0..nolign) )
               If I = 0
        nolign +=1
        [M:RC1]VALOLDCOD (nolign-1 ) = [F:CCE]CCE
        [M:RC1]VALOLDDES(nolign-1 )  = [F:CCE]DES
               Endif
            Endif
         $NEXTCCE
         Next  #CCE
      Filter[CCE]  #*Fq-87418

   Else # on ne vient pas d'une CIG
  #Fq-83418 Filter[F:CCE] Where DIE = val(mid$([M:RC0]TABNAM,4,1))
  Filter[F:CCE] Where DIE = [M:RC0]CCEDIE
      For [F:CCE] CCE0
         If nolign < MAXLIG
        nolign +=1
        [M:RC1]VALOLDCOD (nolign-1 ) = [F:CCE]CCE
        [M:RC1]VALOLDDES(nolign-1 )  = [F:CCE]DES
         Endif
      Next # CCE
  Filter[F:CCE]
   Endif

Elsif left$([M:RC0]TABNAM,3) = 'FCY'
  If [M:RC0]REFTRFCMP <> ""
    #***FQ 32456
    If dim (GCSOCSRC) > 0
       If GCSOCSRC  <> ""
          #***FQ-52344 Filter[F:FCY] Where IVYFCY = FCY  or (LEGCPY=GCSOCSRC )
          Filter[F:FCY] Where ( LEGCPY=GCSOCSRC )
       Endif
    Endif
  Else
    Filter[F:FCY] Where IVYFCY = FCY
  Endif
  For [F:FCY]
    nolign +=1
    [M:RC1]VALOLDCOD (nolign-1)  = [F:FCY]FCY
    [M:RC1]VALOLDDES(nolign-1)   = [F:FCY]FCYNAM
    #Fq-86469 On ne présente plus les sites d'inventaire si l'on est
    #  dans le paramétrage de recodification pour une CIG
    If [M:RC0]REFTRFCMP = ""  #Fq-86469
    If [F:FCY]IVYFCY <> "" and [F:FCY]IVYFCY<> [F:FCY]FCY
        nolign +=1
        [M:RC1]VALOLDCOD (nolign-1)  =  [F:FCY]IVYFCY
        Read[FCY]FCY0=  [F:FCY]IVYFCY
        [M:RC1]VALOLDDES(nolign-1)   = [F:FCY]FCYNAM
    Endif
    Endif #Fq-86469
  Next
  Filter[F:FCY]

#FQ107562
Elsif left$([M:RC0]TABNAM,3) = 'FAM'
  For [F:FAM]
    nolign +=1
    [M:RC1]VALOLDCOD (nolign-1 ) = [F:FAM]FAMREF
    Call LECTEXTRA([M:RC1]VALOLDDES(nolign-1),"FASFAM","FAMDES",[F:FAM]FAMREF,"") From ATEXTRA
  Next #FQ107562/

Elsif  [M:RC0]TABNAM <> ''
   #Fq-77460 : suppression des caractères blanc en fin de nom de table
   WTABNAM= vireblc([M:RC0]TABNAM,1)
   [M:RC0]TABNAM=WTABNAM
  Filter[F:ADI] Where ([F:ADI]NUMTAB =  val([M:RC0]TABNAM))
   For [F:ADI]CODE
        nolign +=1
        [M:RC1]VALOLDCOD (nolign-1)  =[F:ADI]CODE
        WCDES = ""
        Call LECTEXTRA(WCDES,"ATABDIV","LNGDES",[M:RC0]TABNAM,[F:ADI]CODE) From ATEXTRA
        If  WCDES = ""
             Call LECTEXTRA(WCDES,"ATABDIV","SHODES",[M:RC0]TABNAM,[F:ADI]CODE) From ATEXTRA
        Endif
        [M:RC1]VALOLDDES(nolign-1)   = WCDES
  Next
  Filter[F:ADI]
Endif
##------------------------------------------------------------------------------------------------##
## Dimensionnement du tableau : Alimentation variable de bas de tableau                           ##
##------------------------------------------------------------------------------------------------##
If nolign <> 0
    [M:RC1]NBSTA = nolign-1
Endif

Return
####################################################################################################
## $ECRIT_TABLE_CDC: Ecriture des postes du tableau dans la table CDC                             ##
####################################################################################################
$ECRIT_TABLE_CDC
Local Integer WI
##------------------------------------------------------------------------------------------------##
## - Lecture du tableau                                                                           ##
##------------------------------------------------------------------------------------------------##
Delete [F:CDC] Where   [F:CDC]REFCDF    = [M:RC0]REFCDF

Affzo [M:RC0]

For WI = 0 To [M:RC1]NBSTA - 1
         If [M:RC1]VALOLDCOD(WI) <> ""
             [F:CDC]REFCDF    = [M:RC0]REFCDF
             [F:CDC]VALOLDCOD = [M:RC1]VALOLDCOD(WI)
             [F:CDC]VALNEWCOD = [M:RC1]VALNEWCOD(WI)
             [F:CDC]VALNEWDES = [M:RC1]VALNEWDES(WI)
             Write [F:CDC]
         Endif
Next

Return
####################################################################################################
## $ECRIT_TABLE_CDS_CDY : Ecriture des postes du tableau des sociétés dans CDS et Sites dans CDY  ##
####################################################################################################
ECRIT_TABLE_CDS_CDY

Local Integer WI

Delete [F:CDY] Where   [F:CDY]REFCDF    = [M:RC0]REFCDF
Delete [F:CDS] Where   [F:CDS]REFCDF    = [M:RC0]REFCDF

Affzo [M:RC1]
Affzo [M:RC2]
##------------------------------------------------------------------------------------------------##
## - Lecture du tableau                                                                           ##
##------------------------------------------------------------------------------------------------##
WI = 0
For WI = 0 To [M:RC1]NBCPY - 1
       [F:CDS]REFCDF = [M:RC0]REFCDF
       [F:CDS]FLGCPY = [M:RC1]FLGCPY (WI)
       [F:CDS]CPY    = [M:RC1]CPY    (WI)
       Write [F:CDS]
Next
##------------------------------------------------------------------------------------------------##
## - Lecture du tableau                                                                           ##
##------------------------------------------------------------------------------------------------##
WI = 0
For WI = 0 To [M:RC1]NBFCY - 1
       [F:CDY]REFCDF = [M:RC0]REFCDF
       [F:CDY]FLGFCY = [M:RC1]FLGFCY (WI)
       [F:CDY]FCYCPY = [M:RC1]FCYCPY (WI)
       [F:CDY]FCY    = [M:RC1]FCY    (WI)
       Write [F:CDY]
Next

Return
####################################################################################################
## $CHARGE_TABLEAU_CDC: Alimentation du tableau des postes à partir de la table CDC               ##
####################################################################################################
$CHARGE_TABLEAU_CDC
Local Integer I
Local Integer WI
Local Char    WCLIB
Local Char    WTABNAM  #Fq-77460

Effzo [M:RC1] VALOLDCOD
Effzo [M:RC1] VALOLDDES
Effzo [M:RC1] VALNEWCOD
Effzo [M:RC1] VALNEWDES

Chgfmt [M:RC1]VALNEWDES  With "K:40X"

WI= 0
##------------------------------------------------------------------------------------------------##
## - Remplissage du tableau                                                                       ##
##------------------------------------------------------------------------------------------------##
## La 1ère alimentée est la ligne avec l'indice = 0                                               ##
## La variable de bas de tableau doit avoir le nombre de ligne (indice +1)                        ##
##------------------------------------------------------------------------------------------------##
Filter[F:CDC]
For [F:CDC] Where [F:CDC]REFCDF=[M:RC0]REFCDF

    [M:RC1]VALOLDCOD(WI)  = [F:CDC]VALOLDCOD
    [M:RC1]VALNEWCOD(WI)  = [F:CDC]VALNEWCOD
    [M:RC1]VALNEWDES(WI)  = [F:CDC]VALNEWDES
    ##------------------------------------------------------------------------------------------------##
    ## Recherche du libellé qui n'est pas dans la table CDC                                           ##
    ##------------------------------------------------------------------------------------------------##
    If [M:RC0]TABNAM = 'FCY'
         Read [F:FCY] = [F:CDC]VALOLDCOD
         [M:RC1]VALOLDDES(WI)  = [F:FCY]FCYNAM
    #FQ107562
    Elsif left$([M:RC0]TABNAM,3) = 'FAM'
        Read [F:FAM]FAM0 = [F:CDC]VALOLDCOD
        Call LECTEXTRA( [M:RC1]VALOLDDES(WI),"FASFAM","FAMDES",[F:FAM]FAMREF,"") From ATEXTRA #FQ107562/
    Elsif left$([M:RC0]TABNAM,3) = 'CCE'
         #Fq-83418 Read [F:CCE]CCE0 = [M:RC0]CCEDIE;[F:CDC]VALOLDCOD
         Read [F:CCE]CCE0 = [F:CDP]CCEDIE;[F:CDC]VALOLDCOD
         [M:RC1]VALOLDDES(WI)  = [F:CCE]DES
         Affzo  [M:RC1]VALOLDDES(WI)
    Elsif [M:RC0]TABNAM <> ''
       #Fq-77460 : suppression des caractères blanc en fin de nom de table
       WTABNAM= vireblc([M:RC0]TABNAM,1)
       [M:RC0]TABNAM=WTABNAM
        Call LECTEXTRA(WCLIB,"ATABDIV","LNGDES",[M:RC0]TABNAM, [F:CDC]VALOLDCOD ) From ATEXTRA
        If  WCLIB = ""
             Call LECTEXTRA(WCLIB,"ATABDIV","SHODES",[M:RC0]TABNAM, [F:CDC]VALOLDCOD ) From ATEXTRA
        Endif
        [M:RC1]VALOLDDES(WI)  = WCLIB
    Endif
    WI +=1
Next
Filter[F:CDC]
##------------------------------------------------------------------------------------------------##
## Dimensionnement du tableau : Alimentation variable de bas de tableau                           ##
##------------------------------------------------------------------------------------------------##
If WI <> 0
    [M:RC1]NBSTA = WI
Endif

Return
####################################################################################################
## $CHARGE_TABLEAU_CDS_CDY : Charge tableau des sociétés depuis CDS et Sites depuis CDY           ##
####################################################################################################
CHARGE_TABLEAU_CDS_CDY

Effzo [M:RC1] FLGCPY
Effzo [M:RC1] CPY
Effzo [M:RC1] FLGFCY
Effzo [M:RC1] FCYCPY
Effzo [M:RC1] FCY
##------------------------------------------------------------------------------------------------##
## - Remplissage du tableau des sociétés                                                          ##
##------------------------------------------------------------------------------------------------##
## La 1ère alimentée est la ligne avec l'indice = 0                                               ##
## La variable de bas de tableau doit avoir le nombre de ligne (indice +1)                        ##
##------------------------------------------------------------------------------------------------##
Filter[F:CDS]
WI= 0
For [F:CDS] Where [F:CDS]REFCDF=[M:RC0]REFCDF

    [M:RC1]FLGCPY (WI)  = [F:CDS]FLGCPY
    [M:RC1]CPY    (WI)  = [F:CDS]CPY
    WI +=1
Next
Filter[F:CDS]

## Dimensionnement du tableau : Alimentation variable de bas de tableau                           ##
If WI <> 0
    [M:RC1]NBCPY = WI
Endif
Affzo [M:RC1]
##------------------------------------------------------------------------------------------------##
## - Remplissage du tableau des sites                                                             ##
##------------------------------------------------------------------------------------------------##
Filter[F:CDY]
WI= 0
For [F:CDY] Where [F:CDY]REFCDF=[M:RC0]REFCDF

    [M:RC1]FLGFCY (WI)  = [F:CDY]FLGFCY
    [M:RC1]FCYCPY (WI)  = [F:CDY]FCYCPY
    [M:RC1]FCY    (WI)  = [F:CDY]FCY
    WI +=1
Next
Filter[F:CDY]
## Dimensionnement du tableau : Alimentation variable de bas de tableau                           ##
If WI <> 0
    [M:RC1]NBFCY = WI
Endif

Affzo [M:RC1]

Return
####################################################################################################
## $AFF_COL_NEWDES: Colonnes VALNEWDES grisée si l'on insert pas de code dans la table            ##
####################################################################################################
$AFF_COL_NEWDES
If [M:RC0]TABNAM = 'FCY' or (left$([M:RC0]TABNAM,3) =  "CCE" and WCGTABCPT  <> "" )
   Grizo [M:RC1]VALNEWDES
Endif

Return
######################################################################################
######################################################################################
## ACTION SUR LES RUBRIQUES                                                         ##
######################################################################################
######################################################################################
######################################################################################
## GESTION DE LA RUBRIQUE REFCDF : Référence recodification                         ##
######################################################################################
#------------------------------------------------------------------------------------#
# Sous-programme APRES_MODIF                                                         #
#------------------------------------------------------------------------------------#
Subprog AM_REFCDF(VALEUR)
Variable Char    VALEUR()

[M:RC0]REFCDF = VALEUR

If [M:RC0]PROSTA= 0
    [M:RC0]PROSTA = GVML_RECATRC
Endif
Affzo  [M:RC0]PROSTA

End
######################################################################################
## GESTION DE LA RUBRIQUE PROSTA : Statut du traitement                             ##
######################################################################################
#------------------------------------------------------------------------------------#
# Sous-programme AVANT_SAISIE                                                        #
#------------------------------------------------------------------------------------#
Subprog AS_PROSTA(VALEUR)
Variable Integer VALEUR
#--------------------------------------------------------------------------------------------------#
# Si Statut =  'A Traiter' ou  'A Traiter Cession IG'  --> Suppression des 2 postes traités        #
#--------------------------------------------------------------------------------------------------#
If [M:RC0]PROSTA   = GVML_RECATR or  [M:RC0]PROSTA = GVML_RECATRC
  Raz GMENLOC
  GMENLOC(3)=1
  GMENLOC(4)=1
Endif

If G_ACTCIG <> G_OUI
  GMENLOC(2)=1
Endif

End
#------------------------------------------------------------------------------------#
#  Sous-programme CONTROLE                                                           #
#------------------------------------------------------------------------------------#
Subprog C_PROSTA(VALEUR)
Variable Integer VALEUR

End
#------------------------------------------------------------------------------------#
#  Sous-programme APRES_MODIF                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_PROSTA(VALEUR)
Variable Integer VALEUR

WIPROSTA = VALEUR
#--------------------------------------------------------------------------------------------------#
# Si Statut diff de 'A Traiter Cession IG' et 'Traité Cession IG'  -->                             #
#                    La reférence Cession Intra-groupe est rendue invisible                        #
#--------------------------------------------------------------------------------------------------#

If WIPROSTA    <> GVML_RECATRC and  WIPROSTA  <> GVML_RECTRTC
  Chgfmt [M:RC0]REFTRFCMP  With "-K:1X"
  Chgfmt [M:RC0]DESTRFCMP  With "-K:1X"
Else
  Chgfmt [M:RC0]REFTRFCMP With "K:10X"
  Chgfmt [M:RC0]DESTRFCMP With "KP:20X"
Endif

If WIPROSTA     = GVML_RECATRC
    [M:RC0]STAOLDCOD   = GVML_RECCON
    [M:RC0]TABNAM      =   "FCY"
    Gosub AFFICHE_NOMTABDES
    [M:RC0]DATENDACT   = [0/0/0]
    [M:RC0]FLGUPDASS   = G_NON
    [M:RC0]FLGSIM      = G_NON
    [M:RC0]FLGTRCEDT   = G_NON
    [M:RC1]OBCLDR      = GVML_OMBIEN
    Grizo [M:RC0]STAOLDCOD
    Diszo [M:RC0]FLGUPDASS
    Diszo [M:RC0]FLGSIM
    Diszo [M:RC0]FLGTRCEDT
    Diszo [M:RC1]OBCLDR
    Grizo [M:RC1]OBCPCDFAS
    Grizo [M:RC1]OBCPCDLOF
    Grizo [M:RC1]OBCPCDLEA
    Grizo [M:RC1]OBCPCDGRT
    Grizo [M:RC1]OBCPCDPHY
    Grizo [M:RC1]FLGCPY
    Grizo [M:RC1]FLGFCY
    Actzo [M:RC0]REFTRFCMP
    Gosub SELTOUT
    Gosub GRISER_RC2
Else
    Actzo [M:RC0]STAOLDCOD
    Actzo [M:RC0]FLGUPDASS
    Actzo [M:RC0]FLGSIM
    Actzo [M:RC0]FLGTRCEDT
    Actzo [M:RC1]OBCLDR
    Actzo [M:RC1]OBCPCDFAS
    Actzo [M:RC1]OBCPCDLOF
    If G_ACTLEA = G_OUI : Actzo [M:RC1]OBCPCDLEA  : Endif #Fq-77109
    If G_ACTGRT = G_OUI : Actzo [M:RC1]OBCPCDGRT  : Endif #Fq-77109
    If GPHY     = G_OUI : Actzo [M:RC1]OBCPCDPHY  : Endif #Fq-77109

    If [M:RC0]STAOLDCOD <> GVML_RECSUP
       Actzo [M:RC1]FLGCPY
       Actzo [M:RC1]FLGFCY
    Endif
    Gosub DEGRISER_RC2
Endif

Affzo [M:RC0]
Affzo [M:RC1]
Affzo [M:RC2]
Gosub AFFICHE_NOMTABDES

End
######################################################################################
## GESTION DE LA RUBRIQUE TABNAM : Table à recodifier                               ##
######################################################################################
#------------------------------------------------------------------------------------#
## Sous-programme CONTROLE                                                           #
#------------------------------------------------------------------------------------#
Subprog C_TABNAM(VALEUR)
Variable Char VALEUR()
Local Integer WITABDIV
Local Char    WCTABDIV
Local Char    WTABNAM    #Fq-77460
Local Char    WCLIB

 #Fq-77460 : suppression des caractères blanc en fin de nom de table
 WTABNAM  =  vireblc(VALEUR,1)
 WITABDIV  = val(WTABNAM)
 WCTABDIV  = WTABNAM
WCLIB     = ""

If left$(WCTABDIV ,3) =  "FCY"
   WCTABDIV =  "FCY"
   #FQ 32070
   VALEUR   =  "FCY"
Endif
#FQ107562
If left$(WCTABDIV ,3) =  "FAM"
   WCTABDIV =  "FAM"
   VALEUR   =  "FAM"
Endif
#--------------------------------------------------------------------------------------------------#
# Tables autorisées : LOC , SITE, CCE, Tables diverses modifiables (modules immos ou dépenses)     #
#--------------------------------------------------------------------------------------------------#
#FQ107562 If WCTABDIV  <> "LOC" and WCTABDIV  <> "FCY" and left$(WCTABDIV ,3) <> "CCE"
If WCTABDIV  <> "FCY" and  WCTABDIV  <> "FAM" and left$(WCTABDIV ,3) <> "CCE"
  Read [F:ADV]CODE = WITABDIV
  If [S]fstat <> 0
    GMESSAGE = mess(19,GML_MSGREC,1)  : GERR=1
    mkstat=2
    End
  Elsif  [F:ADV]MODULE <> 14
    GMESSAGE = mess(21,GML_MSGREC,1)  : GERR=1
    mkstat=2
    End
  Elsif [F:ADV]UPDFLG = G_NON
    GMESSAGE = mess(20,GML_MSGREC,1)  : GERR=1
    mkstat=2
    End
  Else
    Call LECTEXTRA (WCLIB ,"ATABTAB","LNGDES",num$(WITABDIV)   ,"") From ATEXTRA
  Endif
Endif

If left$(WCTABDIV ,3) =  "CCE"
    If mid$(WCTABDIV,4,1) = "" or mid$(WCTABDIV,4,1) = '0'
          GMESSAGE = mess(54,GML_MSGREC,1) + '\' + mess(55,GML_MSGREC,1)  : GERR=1
          mkstat=2
          End
    Else
      Read [F:APL] = GML_AXEANAL; val(mid$(WCTABDIV,4,1));GLANGUE
      If [S]fstat <> 0
          GMESSAGE = mess(54,GML_MSGREC,1) + '\' + mess(55,GML_MSGREC,1)  : GERR=1
          mkstat=2
          End
      Endif
    Endif
Endif

If WCLIB  <> ""
     [M:RC0]TABNAMDES = WCLIB
     Affzo [M:RC0]TABNAMDES
Endif

WIPROSTA = [M:RC0]PROSTA
WCTABNAM  = WCTABDIV
WICTRLOK  = G_OUI

End
#------------------------------------------------------------------------------------#
## Sous-programme APRES_MODIF                                                        #
#------------------------------------------------------------------------------------#
Subprog AM_TABNAM(VALEUR)
Variable Char    VALEUR()
Local Char      WCTABDIV

WCTABDIV      = VALEUR
[M:RC0]TABNAM = VALEUR

Actzo [M:RC1]VALNEWDES

Gosub AFFICHE_NOMTABDES

Call TEMPON("R") From GESECRAN
Gosub CHARGE_TABLEAU_NEW

[M]NBSTA = nolign

Call TEMPOFF From GESECRAN

If [M]NBSTA = 0
  If ( left$ ([M:RC0]TABNAM,3) <> "CCE" )
  GERR = 2 : GMESSAGE = mess(29,GML_MSGREC,1) : #Aucun poste de table sélectionné
   Else
      If ([M:RC0]CCEDIE = "" )
         mkstat= 2 : GERR = 1 : GMESSAGE = mess(92,GML_MSGREC,1) : # Vous devez préciser un axe analytique.
         zonsui ="[M:RC0]CCEDIE"
      Endif
Endif
Endif

Gosub AFF_COL_NEWDES

#FQ107562 Ajout "FAM"
#FQ121110 : remplacement par des if...then...
#Case ([M:RC0]TABNAM)
#  When "FCY"  :    Titcol[M:RC1]NBSTA "Site source", "Intitulé",  "Site cible", "Intitulé"
#  When "FAM"  :    Titcol[M:RC1]NBSTA "Famille source", "Intitulé", "Famille cible", "Intitulé"
#  When (left$ ([F:CDP]TABNAM,3) = "CCE")  :    Titcol[M:RC1]NBSTA "Section source", "Intitulé", "Section cible", "Intitulé"
#  When Default :   Titcol[M:RC1]NBSTA "Code source", "Intitulé",  "Code cible", "Intitulé"
# Endcase

#*FQ-121110
If [M:RC0]TABNAM = "FCY"
 Titcol[M:RC1]NBSTA "Site source", "Intitulé",  "Site cible", "Intitulé"
Else
  If [M:RC0]TABNAM = "FAM"
    Titcol[M:RC1]NBSTA "Famille source", "Intitulé", "Famille cible", "Intitulé"
  Else
    If  (left$([M:RC0]TABNAM,3) = "CCE")
      Titcol[M:RC1]NBSTA "Section source", "Intitulé", "Section cible", "Intitulé"
    Else
      Titcol[M:RC1]NBSTA "Code source", "Intitulé",  "Code cible", "Intitulé"
    Endif
  Endif
Endif #FQ-121110 End

Affzo [M:RC0]
Affzo [M:RC1]
Affzo [M:RC2]

End
#Fq-52344
Subprog AM_CCEDIE(VALEUR)
Variable Char    VALEUR()


#Fq-52344
If VALEUR <> [M:RC0]CCEDIE and mid$([M:RC0]TABNAM,1,3) = "CCE"
  [M:RC0]CCEDIE = VALEUR : Affzo [M:RC0]CCEDIE
  Gosub CHARGE_TABLEAU_NEW
Endif #Fq-52344

[M]NBSTA = nolign

Call TEMPOFF From GESECRAN

If [M]NBSTA = 0
  If ( left$ ([M:RC0]TABNAM,3) <> "CCE" )
  GERR = 2 : GMESSAGE = mess(29,GML_MSGREC,1) : #Aucun poste de table sélectionné
   Else
      If ([M:RC0]CCEDIE = "" )
         mkstat= 2 : GERR = 1 : GMESSAGE = mess(92,GML_MSGREC,1) : # Vous devez préciser un axe analytique.
         zonsui ="[M:RC0]CCEDIE"
      Endif
Endif
Endif

Gosub AFF_COL_NEWDES

#FQ121110  Titcol[M:RC1]NBSTA "Section source", "Intitulé",  " ",  "Section cible",  "Intitulé"
Titcol[M:RC1]NBSTA "Section source", "Intitulé",  "Section cible",  "Intitulé"

Affzo [M:RC0]
Affzo [M:RC1]
Affzo [M:RC2]


End
######################################################################################
## GESTION DE LA RUBRIQUE REFTRFCMP: Référence cession intra-groupe                 ##
######################################################################################
#*** Fq-37134
Subprog AS_REFTRFCMP(VALEUR)
Variable Char    VALEUR()

Call AM_REFTRFCMP(VALEUR)   #**Fq-33499 : réactivation de l'appel au sous-pro

End
#------------------------------------------------------------------------------------#
## Sous-programme APRES_MODIF                                                        #
#------------------------------------------------------------------------------------#

Subprog AM_REFTRFCMP(VALEUR)
Variable Char    VALEUR()
[M:RC0]REFTRFCMP= VALEUR

If VALEUR <> ""
  Read [F:CIG]CIG0 = VALEUR
  If fstat = 0
     [M:RC0]DESTRFCMP = [F:CIG]DES
     [M:RC0]CPYSRC    = [F:CIG]CPYSRC(0)
     [M:RC0]CPYDES    = [F:CIG]CPYDES(0)
      Affzo [M:RC0]DESTRFCMP
   Else
    #**Fq-39677 If  [M:RC0]TABNAM = "FCY"
    If  [M:RC0]TABNAM = "FCY" & GREFCIG = ""
       #** Fq-38006 : si recodification de sites il faut que la cession intra-groupe existe
       # Recodification de Sites : la Cession intra-groupe doit exister
       GERR = 1 : GMESSAGE = mess(90,GML_MSGREC,1) : mkstat = 2 : End
    Endif
  Endif

  Gosub CHARGE_TABLEAU_NEW
  [M]NBSTA = nolign
  Call TEMPOFF From GESECRAN

  If [M]NBSTA = 0
  If ( left$ ([M:RC0]TABNAM,3) <> "CCE" )
    GERR = 2 : GMESSAGE = mess(29,GML_MSGREC,1) : #Aucun poste de table sélectionné
   Else
     If ([M:RC0]CCEDIE = "" )
       mkstat= 2 : GERR = 1 : GMESSAGE = mess(92,GML_MSGREC,1) : # Vous devez préciser un axe analytique.
       zonsui ="[M:RC0]CCEDIE"
     Endif
   Endif
Endif

  Gosub AFF_COL_NEWDES

  Affzo [M:RC0]
  Affzo [M:RC1]
  Affzo [M:RC2]

 Endif

End
######################################################################################
## GESTION DE LA RUBRIQUE STAOLDCOD : Statut anciens codes                          ##
######################################################################################
Subprog AS_STAOLDCOD(VALEUR)
Variable Integer VALEUR
#----------------------------------------------------------------------------------------------#
# Le poste 'Inactif' est proposé uniquement pour la table de section analytiques si elle est   #
# non partagée.   Dans le futur, le poste Inactif' sera également proposé pour les  tables     #
# diverses lorsque leur structure aura une date fin validité                                   #
#----------------------------------------------------------------------------------------------#
Raz GMENLOC

If  (left$ ([M:RC0]TABNAM,3) <>  'CCE' or  WCGTABCPT  <> "")
  GMENLOC(2)=1
Endif

#Fq-52344 If [M:RC0]TABNAM = "" or [M:RC0]TABNAM = "LOC" or [M:RC0]TABNAM = 'FCY' or  (left$ ([M:RC0]TABNAM,3) = 'CCE' and WCGTABCPT  <> "")
#FQ107562 Ajout "FAM"
If [M:RC0]TABNAM = "" or [M:RC0]TABNAM = 'FCY'  or [M:RC0]TABNAM = 'FAM' or (left$ ([M:RC0]TABNAM,3) = 'CCE' )
  GMENLOC(3)=1
Endif

End
#------------------------------------------------------------------------------------#
# Sous-programme APRES_MODIF                                                         #
#------------------------------------------------------------------------------------#
Subprog AM_STAOLDCOD(VALEUR)
Variable Integer VALEUR

Local Integer LOK

WISTAOLDCOD = VALEUR
WICTRLOK    = G_OUI
WDDATENDACT = [M:RC0]DATENDACT
WIFLGUPDASS = [M:RC0]FLGUPDASS

# Si table CCE: La rubrique  'Anciens codes' = 'Inactif' ou 'Supprimé'  uniquement
#  si table Sections non partagée
If left$ ([M:RC0]TABNAM,3) = 'CCE' and WCGTABCPT  <> "" and (WISTAOLDCOD   = GVML_RECINA or WISTAOLDCOD   = GVML_RECSUP )
       WICTRLOK = G_NON
       GMESSAGE = mess(53,GML_MSGREC,1)  : GERR = 2
Elsif WISTAOLDCOD   = GVML_RECINA and WDDATENDACT  =  [0/0/0]
       GMESSAGE = mess(27,GML_MSGREC,1)  : GERR = 2
       WDDATENDACT  = date$
Elsif WISTAOLDCOD   = GVML_RECCON or WISTAOLDCOD   = GVML_RECSUP
    WDDATENDACT  =  [0/0/0]
Endif

If WICTRLOK = G_NON
   [S]mkstat=2
   End
Endif
#--------------------------------------------------------------------------------------------------#
# Si Ancien code =    'Inactif'  --> Date de fin de validité obligatoire                           #
# Si Ancien code diff 'Inactif'  --> Date de fin de validité interdite , non modifiable            #
# Si Ancien code =    'Supprimés'--> Maj association obligatoire                                   #
#--------------------------------------------------------------------------------------------------#
If WISTAOLDCOD   = GVML_RECSUP
   WIFLGUPDASS        = G_OUI
   [M:RC1] OBCLDR     = 0          : # affichage a vide de la combo si anciens codes = supprimés
   [M:RC1] OBCPCDFAS  = G_OUI
   [M:RC1] OBCPCDLOF  = G_OUI
   If G_ACTLEA = G_OUI : [M:RC1]OBCPCDLEA  = G_OUI : Endif #Fq-77109
   If G_ACTGRT = G_OUI : [M:RC1]OBCPCDGRT  = G_OUI : Endif #Fq-77109
   If GPHY     = G_OUI : [M:RC1]OBCPCDPHY  = G_OUI : Endif #Fq-77109
   Grizo [M:RC0]FLGUPDASS
   Grizo [M:RC1]OBCLDR
   Grizo [M:RC1]OBCPCDFAS
   Grizo [M:RC1]OBCPCDLOF
   Grizo [M:RC1]OBCPCDLEA
   Grizo [M:RC1]OBCPCDGRT
   Grizo [M:RC1]OBCPCDPHY
   Grizo [M:RC1]FLGCPY
   Grizo [M:RC1]FLGFCY
   Gosub SELTOUT
   Gosub GRISER_RC2
   Gosub VIDER_RC2
Else
   If    [M:RC1] OBCLDR     = 0
      [M:RC1] OBCLDR     = GVML_OMBIEN
   Endif

   If [M:RC0]PROSTA <> GVML_RECATRC   #FQ-56222
   Actzo [M:RC0]FLGUPDASS
   Actzo [M:RC1]OBCLDR
   Actzo [M:RC1]OBCPCDFAS
   Actzo [M:RC1]OBCPCDLOF
   If G_ACTLEA = G_OUI : Actzo [M:RC1]OBCPCDLEA : Endif #Fq-77109
   If G_ACTGRT = G_OUI : Actzo [M:RC1]OBCPCDGRT : Endif #Fq-77109
   If GPHY     = G_OUI : Actzo [M:RC1]OBCPCDPHY : Endif #Fq-77109
     Gosub DEGRISER_RC2
    Else
       Actzo [M:RC1]FLGCPY
       Actzo [M:RC1]FLGFCY
       Gosub GRISER_RC2
   Endif
  Endif   #FQ-56222

[M:RC0]DATENDACT = WDDATENDACT
[M:RC0]FLGUPDASS = WIFLGUPDASS

Affzo [M:RC0]
Affzo [M:RC1]
Affzo [M:RC2]

End
######################################################################################
## GESTION DE LA RUBRIQUE VALNEWCOD : Valeur du nouveau code                        ##
######################################################################################
Subprog AM_VALNEWCOD(VALEUR)
Variable Char    VALEUR()
Local Char       WTABNAM  #Fq-77460
Local Char       WCLIB
Local Integer    RCCEDOK  #Fq-87418

 If VALEUR  = ""
   [M:RC1]VALNEWDES (nolign-1) = ""
   [M:RC1]VALNEWCOD (nolign-1)= VALEUR
   Affzo [M:RC0]
   End
 Endif
 # la valeur du nouveau code doit déjà exister dans la table si l'on gére la table FCY ou "FAM"
 # ou CCE si la table des sections est partagée
 If  [M:RC0]TABNAM = 'FCY'
   mkstat   = 0
  Read [F:FCY]FCY0 = VALEUR
  If [S]fstat = 0
     #<<<Fq-86480
     If [M:RC0]PROSTA   = GVML_RECATRC
         If [F:FCY]LEGCPY <> [M:RC0]CPYDES
           # Ce site n'est pas un site de la société cible
           # Site invalide
           GMESSAGE = mess(93,GML_MSGREC,1)
           GERR     = 1
           mkstat   = 2
           End
        Endif
      Endif     #<<<Fq-86480
      #*Fq-86469   If [F:FCY]IVYFCY <> VALEUR
      #*Fq-86469      # Ce site n'est pas un site géographique
      #*Fq-86469      GMESSAGE = mess(35,GML_MSGREC,1)
      #*Fq-86469      GERR     = 1
      #*Fq-86469      mkstat   = 2
      #*Fq-86469      End
      #*Fq-86469   Endif
  Else
     # Site inexistant
      If  [M:RC0]TABNAM = 'FCY'
          GMESSAGE = mess(36,GML_MSGREC,1)
      Else
          GMESSAGE = mess(36,GML_MSGREC,1) + '\' + mess(49,GML_MSGREC,1)
      Endif
      GERR     = 1
      mkstat   = 2
      End
  Endif
  #Fq-90165 Elsif left$ ([M:RC0]TABNAM,3) = 'CCE'
 Elsif left$ ([M:RC0]TABNAM,3) = 'CCE' and WCGTABCPT  <> ""
    Read [F:CCE] = [M:RC0]CCEDIE;VALEUR
    If [S]fstat <> 0
       # Section inexistante
       GMESSAGE = mess(51,GML_MSGREC,1) + '\' + mess(52,GML_MSGREC,1)
       GERR     = 1
       mkstat   = 2
       End
    Else
       #Fq-87418 Contrôle de la section saisie par rapport au groupe de société/site
       If ([F:CCE]FCY<> "")
          Call CONTSITE([F:CCE]FCY,[M:RC0]CPYDES,RCCEDOK)
          #----- Section incompatible avec le site/société -----#
          If RCCEDOK <>  G_OUI
             GMESSAGE = [F:CCE]CCE-":"-mess(66,133,1)-[F:CCE]FCY : # réservé au groupe de site
             GERR     = 1
             mkstat   = 2
             End
          Endif
       Endif
    Endif
 Endif

# Alimentation du nouveau libellé
If [M:RC0]TABNAM = 'FCY'
      # Si table FCY  --> affichage du libellé
      Read [F:FCY] = VALEUR
      If [S]fstat = 0
          [M:RC1]VALNEWDES (nolign-1) = [F:FCY]FCYNAM
      Endif
#FQ107562 Si table FAM  --> affichage du libellé
Elsif [M:RC0]TABNAM = 'FAM'

  Read [F:FAM]FAM0 = VALEUR
  If fstat=0
     Call LECTEXTRA([M:RC1]VALNEWDES(nolign-1),"FASFAM","FAMDES",[F:FAM]FAMREF,"") From ATEXTRA
  Endif
Elsif left$ ([M:RC0]TABNAM,3) = 'CCE'
    For [CCE]CCE0 Where DIE = [M:RC0]CCEDIE and CCE=VALEUR  #Fq-52344
      Read[CCE]First
        If [S]fstat = 0
         [M:RC1]VALNEWDES (nolign-1) = [F:CCE]DES
         Break
        Endif
    Next  #*FQ-52344
Else
    #Fq-77460 : suppression des caractères blanc en fin de nom de table
    WTABNAM  =  vireblc([M:RC0]TABNAM,1)
    [M:RC0]TABNAM = WTABNAM
    If [M:RC1]VALNEWDES (nolign-1) = ""
       Call LECTEXTRA(WCLIB,"ATABDIV","LNGDES",[M:RC0]TABNAM, VALEUR ) From ATEXTRA
       If  WCLIB = ""
          Call LECTEXTRA(WCLIB,"ATABDIV","SHODES",[M:RC0]TABNAM, VALEUR ) From ATEXTRA
       Endif
       If WCLIB = ""
        [M:RC1]VALNEWDES (nolign-1) = [M:RC1]VALOLDDES (nolign-1)
       Else
          [M:RC1]VALNEWDES (nolign-1) = WCLIB
       Endif
    Endif  #FQ-77460
Endif

[M:RC1]VALNEWCOD (nolign-1)= VALEUR

Affzo [M:RC0]
Affzo  [M:RC1]VALNEWDES (nolign-1)

End
######################################################################################
## GESTION DE LA RUBRIQUE VALNEWDES : Valeur de la nouvelle désignation             ##
######################################################################################
Subprog AM_VALNEWDES(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" and [M:RC1]VALNEWCOD (nolign-1) = ""
      # Le nouveau libellé n'est pas saisissable si le nouveau code n'est pas renseigné
      GMESSAGE = mess(39,GML_MSGREC,1)
      GERR     = 1
      mkstat   = 2
      End
Endif

[M:RC1]VALNEWDES (nolign-1) = VALEUR
Affzo [M:RC0]

End
######################################################################################
## GESTION DE LA RUBRIQUE NBSTA : Variable bas de tableau                          ##
######################################################################################
Subprog AS_NBSTA
##------------------------------------------------------------------------------------------------##
## Avant-saisie de la variable bas de tableau qui contient la définition des bouton click droit   ##
## Rendre grisé le click droit  si le nom de table <> FCY (site)                                  ##
##------------------------------------------------------------------------------------------------##

If [M:RC0]TABNAM <> 'FCY'
  GBOUT1=""
Endif

If ([M:RC0]PROSTA   <>  GVML_RECATRC )
   GBOUT2="" #Fq-68218
Else
  If dim (GCSOCSRC) > 0
    If GCSOCSRC  = ""
      GBOUT2="" #Fq-68218
    Else
     Enable GSTABOU+2
    Endif
  Else
    Enable GSTABOU+2
  Endif
Endif

End
##------------------------------------------------------------------------------------------------##
## Bouton 1  sur la variable de bas de tableau                                                    ##
## Click droit sur la ligne d'un site                                                             ##
##------------------------------------------------------------------------------------------------##
Subprog B1_NBSTA
Local Integer LOK
Local Char    WCFCYSAV
Local Char    WCFCYDESSAV
Local Integer WI
Local Integer WJ
Local Integer WINBLIG

WINBLIG = [M:RC1]NBSTA

# Tableau des anciennes valeurs et nouvelles valeurs pour les codes de la table
Local Char    WCVALOLDCOD (20) (WINBLIG)
Local Char    WCVALOLDDES (40) (WINBLIG)
Local Char    WCVALNEWCOD (20) (WINBLIG)
Local Char    WCVALNEWDES (40) (WINBLIG)

# Message de confirmation de demande de recodification des localisations
Call OUINON(mess(32,GML_MSGREC,1) - [M:RC1]VALOLDCOD (nolign-1) - '\' - mess(33,GML_MSGREC,1) , LOK) From GESECRAN
If ( LOK = G_OUI)
  Chgfmt [M:RC1]VALNEWDES  With "-K:1X"
Endif

# Save du site dont les localisations sont à afficher
WCFCYSAV    = [M:RC1]VALOLDCOD (nolign-1)
WCFCYDESSAV = [M:RC1]VALOLDDES (nolign-1)

# Save du tableau en mémoire
For WI = 0 To [M:RC1]NBSTA - 1
     WCVALOLDCOD (WI) = [M:RC1]VALOLDCOD(WI)
     WCVALOLDDES (WI) = [M:RC1]VALOLDDES(WI)
     WCVALNEWCOD (WI) = [M:RC1]VALNEWCOD(WI)
     WCVALNEWDES (WI) = [M:RC1]VALNEWDES(WI)
Next

# Vidage du tableau de l'écran
Effzo [M:RC1] VALOLDCOD
Effzo [M:RC1] VALOLDDES
Effzo [M:RC1] VALNEWCOD
Effzo [M:RC1] VALNEWDES

# Remplissage du début du tableau de l'écran
# Si site en mémoire , lecture des localisations du site et remplissage tableau
# Remplissage de la fin du tableau de l'écran
WJ = 0

For WI = 0 To WINBLIG -1
   If WCVALOLDCOD (WI) = WCFCYSAV
   Else
      [M:RC1]VALOLDCOD(WJ) = WCVALOLDCOD (WI)
      [M:RC1]VALOLDDES(WJ) = WCVALOLDDES (WI)
      [M:RC1]VALNEWCOD(WJ) = WCVALNEWCOD (WI)
      [M:RC1]VALNEWDES(WJ) = WCVALNEWDES (WI)
      WJ +=1
   Endif
Next
End
##------------------------------------------------------------------------------------------------##
##  #Fq-68218
# Bouton 2 sur la variable de bas de tableau                                                      ##
## Rechargement des sites                                                                         ##
##------------------------------------------------------------------------------------------------##
Subprog B2_NBSTA

Gosub CHARGE_TABLEAU_NEW

[M]NBSTA = nolign

Call TEMPOFF From GESECRAN

If [M]NBSTA = 0
  If ( left$ ([M:RC0]TABNAM,3) <> "CCE" )
  GERR = 2 : GMESSAGE = mess(29,GML_MSGREC,1) : #Aucun poste de table sélectionné
   Else
      If ([M:RC0]CCEDIE = "" )
         mkstat= 2 : GERR = 1 : GMESSAGE = mess(92,GML_MSGREC,1) : # Vous devez préciser un axe analytique.
         zonsui ="[M:RC0]CCEDIE"
Endif
   Endif
Endif

Gosub AFF_COL_NEWDES

Case ([M:RC0]TABNAM)
  When "FCY"  :    Titcol[M:RC1]NBSTA "Site source", "Intitulé",  "Site cible", "Intitulé"
  When "FAM"  :    Titcol[M:RC1]NBSTA "Famille source", "Intitulé", "Famille cible", "Intitulé"
  When (left$ ([F:CDP]TABNAM,3) = "CCE")  :    Titcol[M:RC1]NBSTA "Section source", "Intitulé", "Section cible", "Intitulé"
  When Default :   Titcol[M:RC1]NBSTA "Code source", "Intitulé",  "Code cible", "Intitulé"
 Endcase

Affzo [M:RC0]
Affzo [M:RC1]
Affzo [M:RC2]


End
######################################################################################
## GESTION DE LA RUBRIQUE OBCLDR: Objet maitre                                      ##
######################################################################################
#---- Avant saisie -----------------------------------------------------------------##
Subprog AS_OBCLDR(VALEUR)
Variable Integer VALEUR

Raz GMENLOC

# Le poste 'Relevés d'inventaire' n'est pas proposé
GMENLOC(5)=1
# Le poste 'Eléments physiques' n'est pas proposé
GMENLOC(6)=1
# FQ54343
# Le poste 'Concession' n'est pas proposé
GMENLOC(7)=1
End
#---- Après modif ------------------------------------------------------------------##
Subprog AM_OBCLDR(VALEUR)
Variable Integer VALEUR
If [M:RC1]OBCLDR <> VALEUR
    [M:RC1]OBCLDR = VALEUR
    Gosub INIT_RC2
    Gosub ALIM_RC2
Endif

If [M:RC1]OBCLDR = GVML_OMBIEN
    [M:RC1] OBCPCDFAS  = G_OUI
Elsif [M:RC1]OBCLDR = GVML_OMDEPEN
  [M:RC1] OBCPCDLOF  = G_OUI
Elsif [M:RC1]OBCLDR = GVML_OMLOCFI
    [M:RC1] OBCPCDLEA  = G_OUI
Elsif [M:RC1]OBCLDR = GVML_OMSUBV
    [M:RC1] OBCPCDGRT  = G_OUI
Endif

Affzo [M:RC1]
Affzo [M:RC2]

End
##########################################################################
## $ALIM_RC2 : Alimentation de l'ecran RC2                              ##
##########################################################################
$ALIM_RC2

If [M:RC1]OBCLDR = GVML_OMBIEN
    [M:RC2]OBJNAM  = 'FAS'
    [M:RC2]TBL1    = 'FXDASSETS'
    [M:RC2]OBJDES  =  mess(GVML_OMBIEN,GML_OBJMETIE,1)
Elsif [M:RC1]OBCLDR = GVML_OMDEPEN
    [M:RC2]OBJNAM  = 'LOF'
    [M:RC2]TBL1    = 'LAYOUTFAS'
    [M:RC2]OBJDES  =  mess(GVML_OMDEPEN ,GML_OBJMETIE,1)

Elsif [M:RC1]OBCLDR = GVML_OMLOCFI
    [M:RC2]OBJNAM  = 'LEA'
    [M:RC2]TBL1    = 'LEASE'
    [M:RC2]OBJDES  =  mess(GVML_OMLOCFI,GML_OBJMETIE,1)
Elsif [M:RC1]OBCLDR = GVML_OMSUBV
    [M:RC2]OBJNAM  = 'GRT'
    [M:RC2]TBL1    = 'GRANTS'
    [M:RC2]OBJDES  =  mess(GVML_OMSUBV,GML_OBJMETIE,1)
Endif

[M:RC2]TBL2    = [M:RC2]TBL1
[M:RC2]TBL3    = [M:RC2]TBL1
[M:RC2]TBL4    = [M:RC2]TBL1
[M:RC2]TBL5    = [M:RC2]TBL1
Return
##########################################################################
## $GRISER_RC2 : Rendre disable l'ecran RC2                              ##
##########################################################################
$GRISER_RC2

Diszo [M:RC2]ANDOR2
Diszo [M:RC2]ANDOR3
Diszo [M:RC2]ANDOR4
Diszo [M:RC2]ANDOR5

Diszo [M:RC2]FLD1
Diszo [M:RC2]FLD2
Diszo [M:RC2]FLD3
Diszo [M:RC2]FLD4
Diszo [M:RC2]FLD5

Diszo [M:RC2]OPE1
Diszo [M:RC2]OPE2
Diszo [M:RC2]OPE3
Diszo [M:RC2]OPE4
Diszo [M:RC2]OPE5

Diszo [M:RC2]VAL1
Diszo [M:RC2]VAL2
Diszo [M:RC2]VAL3
Diszo [M:RC2]VAL4
Diszo [M:RC2]VAL5

Return
##########################################################################
## $VIDER_RC2 : Vider l'ecran RC2                                       ##
