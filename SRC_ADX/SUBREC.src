##########################################################################
## $AV_VAL : Fonction appelée par l'avant zone de la rubrique VALEUR    ##
##########################################################################
$AV_VAL

Local Char    CHAMP(20) , TABLE(10) , FORMA(30) , CAR(1) , OPTION(10) , ZONE(10)
Local Integer NOLIB , K , LONG , TABDIV

Case I
 When 1 : CHAMP = [M]FLD1 : TABLE = [M]TBL1
 When 2 : CHAMP = [M]FLD2 : TABLE = [M]TBL2
 When 3 : CHAMP = [M]FLD3 : TABLE = [M]TBL3
 When 4 : CHAMP = [M]FLD4 : TABLE = [M]TBL4
 When 5 : CHAMP = [M]FLD5 : TABLE = [M]TBL5
Endcase

K = instr(1,CHAMP,"(")
If K
   ZONE = left$(CHAMP,K-1)
Else
   ZONE = CHAMP
Endif

If ZONE=""
   FORMA = "Kf:15X"
Else
   Read [ATZ]CODZONE = TABLE;ZONE
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   NOLIB  = 0
   TABDIV = 0

   Case [F:ATY]TYPTYP
      When 1
           If [F:ATY]NOLIB<>0
            NOLIB = [F:ATY]NOLIB
           Else
            NOLIB = [F:ATZ]NOLIB
           Endif
           FORMA = "Nf:2#"
      When 2,3
           If [F:ATY]LNGTYP<>0
            LONG = [F:ATY]LNGTYP
           Else
            LONG = [F:ATZ]LONG
           Endif
           FORMA = "Nf:"+num$(LONG)+"#"
      When 4
           If [F:ATY]LNGTYP<>0
            LONG = [F:ATY]LNGTYP
           Else
            LONG = [F:ATZ]LONG
           Endif
           FORMA = "Nf:15F"
      When 7
           If [F:ATY]LNGTYP<>0
            LONG = [F:ATY]LNGTYP
           Else
            LONG = [F:ATZ]LONG
           Endif
           If LONG>20 : LONG = 20 : Endif
           OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
           If instr(1,OPTION,"C")
            CAR = "d"
           Elsif instr(1,OPTION,"A")
            CAR = "d"
           Else
            CAR = "X"
           Endif
           FORMA = "Kf:"+num$(LONG)+CAR
           If [F:ATY]OBJLIEN="ADI"
            TABDIV = val([F:ATZ]EXPLIEN)
           Endif
      When 8
           FORMA = "Df:"+GFMDAT
    Endcase
Endif

Return
