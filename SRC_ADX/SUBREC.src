##---- C_XXX : Controle       ------------------------------------------##
##---- C_FLD1                 ------------------------------------------##
Subprog C_FLD1(VALEUR)
Variable Char VALEUR()
Local Integer WITYP
Local Integer I
I = 1
If VALEUR = ""
   WCREQUETE = ""
   [M:RC2]REQUETE = WCREQUETE
   Affzo [RC2]
   [M]VAL1 = ""
   Affzo [M]VAL1
   End
Endif
Gosub C_FLD
End

##---- C_FLD2                 ------------------------------------------##
Subprog C_FLD2(VALEUR)
Variable Char VALEUR()
Local Integer WITYP
Local Integer I

If VALEUR = ""
   [M]VAL2 = ""
   Affzo [M]VAL2
   End
Elsif [M]ANDOR2 = 2  and  VALEUR <> [M]FLD1
    GMESSAGE = mess(78,GML_MSGREC,1)  : GERR=1
    mkstat=2
    End
Elsif [M]ANDOR2 = 1  and  VALEUR = [M]FLD1
    GMESSAGE = mess(79,GML_MSGREC,1)  : GERR=1
    mkstat=2
    End
Endif

I = 2
Gosub C_FLD

End

