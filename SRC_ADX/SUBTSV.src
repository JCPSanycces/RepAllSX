######################################################################################
## Etiquette ajoutée par le superviseur (écran TSV1) 20/04/2012 10:53:16 (CPO)
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:TSV1]SIVTYP,"TSV",WMESS)    From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End
######################################################################################
Subprog AM_GFY(VALEUR)
#------------------------------------------------#
# Après modification du groupe de sociétés/sites #
# ---------------------------------------------- #
# Il faut vérifier si le type de pièce est bien  #
# sur le même groupe                             #
# Nota: On ne peut pas contrôler le code journal #
# Car la notion de groupe est différente         #
#------------------------------------------------#
Variable Char    VALEUR()
GGRPFCY = VALEUR :#--CPO 71937
If [M:TSV1]GTE<>""
  If [F:GTE]TYP<>[M:TSV1]GTE
    #Read [GTE] GTE0=[M:TSV1]GTE;[M:TSV1]LEG : If fstat  Raz [F:GTE] : Endif
    Local Integer WRET
    Call LEC_GTE_LEG([M:TSV1]LEG,[M:TSV1]GTE,WRET) From TRTLECLEG : If WRET  Raz [F:GTE] : Endif
  Endif
  If ([F:GTE]GFY<>"" | VALEUR="") & [F:GTE]GFY<>VALEUR
    GMESSAGE=mess(10,105,1)-[M:TSV1]GTE-mess(92,187,1)-"("
    If VALEUR<>""
      GMESSAGE+=VALEUR-"<>"-[F:GTE]GFY+")"
    Else
      GMESSAGE+=mess(220,117,1)-"<>"-[F:GTE]GFY+")"
    Endif
    mkstat=1 : End
  Endif
Endif
End

