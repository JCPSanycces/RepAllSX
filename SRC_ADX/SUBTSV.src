Subprog AS_SAFTINVTYP(VALEUR)
Variable Integer VALEUR

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
Raz GMENLOC

GMENLOC(5) = 1
GMENLOC(6) = 1

If [M:TSV1]RECTYP <> 4 : GMENLOC(7) = 1 : Endif

Case [M:TSV1]INVTYP
  When 1 : GMENLOC(4)=1 : GMENLOC(8)=1 : GMENLOC(9)=1 : #GMENLOC(5)=1 : GMENLOC(6)=1 #If VALEUR = 0 : VALEUR = 1 : Endif
  When 2 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(8)=1 : GMENLOC(9)=1  #GMENLOC(5)=1 : GMENLOC(6)=1 #If VALEUR = 0 : VALEUR = 4 : Endif
  When 3 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(4)=1 : GMENLOC(8)=1 : GMENLOC(9)=1  #GMENLOC(5)=1 : GMENLOC(6)=1 #If VALEUR = 0 : VALEUR = 3 : Endif
  When 4 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(8)=1 : GMENLOC(9)=1  #GMENLOC(5)=1 : GMENLOC(6)=1 #If VALEUR = 0 : VALEUR = 4 : Endif
  When 5 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(4)=1 : GMENLOC(7)=1  #GMENLOC(5)=1 : GMENLOC(6)=1 #If VALEUR = 0 : VALEUR = 1 : Endif
Endcase
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End

