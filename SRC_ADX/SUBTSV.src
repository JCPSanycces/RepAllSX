######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le type facture
######################################################################################
Subprog CONTTSV(SIVTYP,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY )
Value    Char    SIVTYP()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer WNBTOT, WI, WNO_ERR,  WENROK
Local Char    WSIVTYP, WLEG(GLONADI), WMESS1(120), WMESS2(120), WMESS3(120)
Local Integer CAS
Local Char    OPTIONS(30)

  If left$(GFONCTION,6) = "GESTSV" |[L]SIVTYP="" Then
    End
  Endif

  If GFONCTION="ADPVAL"
    WSIVTYP =[L]SIVTYP
  Endif

  # --------------------------------------------------------------------------
  If clalev([F:TSV])  = 0 : Local File TABSIVTYP  [TSV]  : Endif
  If clalev([F:TSVZ]) = 0 : Local File LEGTSVZGRP [TSVZ] : Endif
  If clalev([F:AMZZ]) = 0 : Local File AMSKZON    [AMZZ] : Endif
  If clalev([F:CPY])  = 0 : Local File COMPANY    [CPY]  : Endif :#--CPO 71937
  If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif :#--CPO 71937
  # --------------------------------------------------------------------------
  If func AFNC.ACTIV("LEG") = 0 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then : # GCURLEG positionné par programme
    LEG = GCURLEG
  Endif
  # --------------------------------------------------------------------------
  CAS = 1  #--Legislation is empty

  #--CPO 71937
  #--Cas particulier : pas de GCURLEG mais société ou site en ligne
  If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
    If [L]FCY<>""
      If [F:FCY]FCY<>[L]FCY
       Read [F:FCY]FCY0=[L]FCY
       If fstat : Raz [F:FCY] Endif
      Endif
      If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
    Endif
    If [L]CPY<>""
      If [F:CPY]CPY<>[L]CPY
       Read [F:CPY]CPY0=[L]CPY
       If fstat : Raz [F:CPY] Endif
      Endif
      [L]LEG=[F:CPY]LEG
    Endif
  Endif
  #--/CPO

  If LEG <> "" Then
    Read [TSV]TSV0=[L]SIVTYP;[L]LEG
    If fstat Then
      Read [TSV]TSV0=[L]SIVTYP;""
    Else
      CAS = 2  #--Legislation isn't empty
    Endif
  Else
    Read [TSV]TSV0(1)=[L]SIVTYP
    If !fstat Then
      LEG = [F:TSV]LEG
      CAS = 2
    Endif
  Endif
  If fstat Then
    Filter [TSV] Where SIVTYP=[L]SIVTYP
    Look [TSV]TSV1 First
    If !fstat Then
      # "Fiche inexistante pour la législation courante"
      # "No existing record for the curent legislation"
      GMESSAGE = [L]SIVTYP - ":" - mess(232,107,1) - "[" + [L]LEG + "]"
    Else
      # "Fiche inexistante"
      # "Record does not exist"
      GMESSAGE = [L]SIVTYP - ":" - mess(23,100,1)
    Endif
    Filter [TSV]
    mkstat = 2
    End
  Endif

  # BRBAN 105200 US1
  If func AFNC.ACTIV("INVCA") > 0
    # BRBAN 105200#US4 Can't pick a cancellation invoice type when importing a document
    If GIMPORT<>0 & [F:TSV]INVCAN=2
      GMESSAGE = mess(4,7712,1)
      mkstat = 2
      End
    Endif
    # -

    If GFONCTION="GESSIH"
      Case [F:SLT]INVCAN
        When 2
          If  func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0
            If find([F:TSV]INVTYP,2,4) & [F:TSV]INVCAN<>2
              GMESSAGE = mess(106,100,1)
              mkstat = 2
              End
            Endif
          Else
            GMESSAGE =mess(106,100,1)
            mkstat = 2
            End
          Endif
        When Default
          If [F:TSV]INVCAN=2
            GMESSAGE =mess(106,100,1)
            mkstat = 2
            End
          Endif
      Endcase
    Endif
  Endif
  #-
  WSIVTYP            =[L]SIVTYP

  # --------------------------------------------------------------------------
  #--Filtrage par groupe de société
  #--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
  #--Du fait du type de donné AGF sur le champ GFY de TABSIVTYP, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TSV]GFY<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TSV]GFY
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TSV]GFY<>[L]CPY
          GMESSAGE += [L]SIVTYP+"\"+mess(63,127,1)-":"-[F:TSV]GFY : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TSV]GFY;[L]CPY
        If fstat
          GMESSAGE += [L]SIVTYP+"\"+mess(63,127,1)-":"-[F:TSV]GFY : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

  #--Contrôle de cohérence entre le groupe de la taxe et la législation
  If [F:TSV]GFY <> "" and LEG <> "" Then
    Call CTLGFYLEG([F:TSV]GFY, LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  #--Contrôle de cohérence entre le groupe passé en paramètre et la législation du type de livraison à contrôler
  If GROUPE<>"" and [F:TSV]LEG<>""
    Call CTLGFYLEG(GROUPE,[F:TSV]LEG,"","") From TRTVENCTL
    If mkstat : End : Endif
  Endif
  # --Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
  # --uniquement si le groupe passé est renseigné
  # --uniquement si pas de contexte site ou société !
  If GROUPE <> "" Then
    If CPY = "" and FCY = "" and [F:TSV]GFY <> "" and [F:TSV]GFY <> GROUPE Then
      #--Les groupes doivent avoir au moins une société en commun
      Gosub CTLGFYGRP
      If mkstat Then
        End
      Endif
    Endif
  Endif
  # --------------------------------------------------------------------------
  #--On charge les options définies sur le type de données du champ du masque
  OPTIONS = ""
  If CODMSK<>"" & CHAMPCOD<>""
    Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
    If fstat=0 Then
      OPTIONS=[F:AMZZ]OPTOBJ
    Endif
  Endif

  # BRBAN 105200#US2
  If func AFNC.ACTIV("INVCA")
    If  func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
      OPTIONS=ctrans(OPTIONS,"C","")
    Endif
  Endif

  If CAS = 2 Then
    Call CONTROLE("TSV", OPTIONS, LEG,[L]SIVTYP, mkstat) From CONTOBJ
  Else
    Call CONTROLE("TSV", OPTIONS, "",[L]SIVTYP, mkstat) From CONTOBJ
  Endif

	#--CPO 71937 Contrôle global de cohérence avant enregistrement
  If mkstat > 0 End Endif

	If [F:TSV]JOU<>""
  	#--Cohérence [TSV]JOU et paramètres
  	If clalev([F:JOU])=0 : Local File GJOURNAL   [JOU] : Endif

    If [L]FCY<>""
    	Call CONTJOU([TSV]JOU, [L]LEG, [L]FCY) From SUBJOU
    Elsif [L]CPY<>""
    	Call CONTJOU([TSV]JOU, [L]LEG, [L]CPY) From SUBJOU
    Elsif [L]GROUPE<>""
    	Call CONTJOU([TSV]JOU, [L]LEG, [L]GROUPE) From SUBJOU
  	Endif
  	If mkstat
  		If [L]LEG=""
  			GMESSAGE = [L]SIVTYP-":"-GMESSAGE
  		Else
  			GMESSAGE = [L]SIVTYP-"["+[L]LEG+"]"-":"-GMESSAGE
  		Endif
  		End
  	Endif
  Endif

	If [F:TSV]GTE<>""
  	#--Cohérence [TSV]GTE et paramètres
  	If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif

    If [L]FCY<>""
    	Call CONTGTE([TSV]GTE, LEG, [L]FCY) From SUBGTE
    Elsif [L]CPY<>""
    	Call CONTGTE([TSV]GTE, LEG, [L]CPY) From SUBGTE
    Elsif [L]GROUPE<>""
    	Call CONTGTE([TSV]GTE, LEG, [L]GROUPE) From SUBGTE
  	Endif
  	If mkstat
  		If [L]LEG=""
  			GMESSAGE = [L]SIVTYP-":"-GMESSAGE
  		Else
  			GMESSAGE = [L]SIVTYP-"["+[L]LEG+"]"-":"-GMESSAGE
  		Endif
  		End
  	Endif
  Endif

End

#########################
# $ANCIENJDE : a supprimer
#########################
$ANCIENJDE

  # --------------------------------------------------------------------------
  #------------------------------------------------------------------------------#
  #-- Test s'il existe un enregistrement 'Type facture'                       ---#
  #------------------------------------------------------------------------------#
  WI=0
  If WLEG = ''
    Filter [TSV] Where SIVTYP=WSIVTYP                                      Order By Key CLE=[F:TSV]SIVTYP; [F:TSV]LEG
  Else
    Filter [TSV] Where SIVTYP=WSIVTYP & ([F:TSV]LEG='' or [F:TSV]LEG=WLEG) Order By Key CLE=[F:TSV]SIVTYP; [F:TSV]LEG Desc
  Endif
  For [TSV]CLE(1)
    WNO_ERR= 0
    WI     = 0
    Raz WMESS1, WMESS2, WMESS3, GMESSAGE
    For [TSV]CLE
      WENROK = 2
      If WLEG = '' or [F:TSV]LEG=WLEG or (WLEG<>'' & [F:TSV]LEG='')
        WI+=1
        If [L]CPY <> '' or [L]FCY <> '' Then
          Gosub CTRL_GFY
          Endif   : #-- Rend ENROK=1 (et WNO_ERR=1) ou 2 --#
        If WENROK = 2  &  GROUPE<>'' Then
          Gosub CTRL_GROUPE
        Endif   : #-- Rend ENROK=1 (et WNO_ERR=2) ou 2 --#
        If  [F:TSV]LEG=WLEG or WENROK = 2 Then
          Break
        Endif : #--- si on a trouvé la WLEG (ou si WLEG='' et on est sur la derniere LEG) : On sort
      Endif
    Next
  Next
  Filter [TSV]
  If WI=0
    #-- Mess : Type facture XXX & Législation YYY : Fiche inexistante
    GMESSAGE = mess(67,200,1)- WSIVTYP - '&'- mess(218,107,1)
    If [L]WLEG <> ''
      GMESSAGE -=  "'"+[L]WLEG+ "'" - mess(377,192,1)
    Endif
    GMESSAGE -=  mess(376,192,1) - ":"-mess(23,100,1)
    mkstat = 2
    End
  Endif
  If WNO_ERR = 2
    GMESSAGE = WMESS1 - "'" + WMESS2 + "'" - WMESS3                : #-- Mess: Type facture xxx: Groupes soc/sit différents  yy<>zz
    mkstat = 2
    End
  Endif
  If WNO_ERR = 1
    GMESSAGE= WMESS1 - "'" + WMESS2 + "'" - WMESS3                 : #-- Mess : Réservé au groupe de société
    mkstat=1
    End
  Endif
Return

#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  If [F:TSV]LEG = "" Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSVZGRP"
      Local File =SZVIEW [TSVZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TSVZ]TSTZ0=[L]GROUPE;[F:TSV]SIVTYP;[F:TSV]GFY;[F:TSV]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TSV]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSVYGRP"
      Local File =SZVIEW [TSVY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TSVY]TSVY0=[L]GROUPE;[F:TSV]SIVTYP;[F:TSV]GFY;[F:TSV]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TSV]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Endif
Return

###############################################
# $CTRL_GFY
###############################################
$CTRL_GFY
 If [L]CPY<>""
  If [F:TSV]GFY<>""

   #-- Filtrage par Société : Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
   #-- Du fait du type de donné AGF sur le champ GFY de TABSIVTYP, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
   If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
   Look [AGC]AGC0 = [F:TSV]GFY;[L]CPY
   If fstat
     WENROK = 1
     WNO_ERR= 1
     If WLEG = '' or [F:TSV]LEG=WLEG
      #-- Mess : Type facture XXX & Législation YYY \ Réservé au groupe de société ZZZ ---#
      WMESS1 = mess(67,200,1)-WSIVTYP- '&'- mess(218,107,1)
      If WMESS2 = '' : If [F:TSV]LEG <> '' : WMESS2 -=  [F:TSV]LEG : Else : WMESS2 -= mess(91,187,1) : Endif  :  Endif
      WMESS3 =  ":"+"\"+mess(63,127,1)-[F:TSV]GFY
     Endif
   Endif
 Endif
Endif
Return

###############################################
# $CTRL_GROUPE
###############################################
$CTRL_GROUPE
  #--Contrôle cohérence entre Groupe passé et Groupe du Type facture courant (uniquement si pas de contexte site ou société) --#
  If CPY="" & FCY="" & [F:TSV]GFY<>"" & [F:TSV]GFY<>GROUPE
      WENROK = 1
      WNO_ERR= 2
      If WLEG=''  or [F:TSV]LEG=WLEG or [F:TSV]LEG=''
       #-- Mess : Type facture XXX & Législation YYY \ Groupes sociétés/sites différents (WWW<>ZZZ)---#
       WMESS1 = mess(67,200,1)-WSIVTYP - '&'- mess(218,107,1)
       If WMESS2 = ''
         If [F:TSV]LEG <> '' : WMESS2 -=  [F:TSV]LEG : Else : WMESS2 -= mess(91,187,1) : Endif
       Endif
       WMESS3 =  ':' +"\"+mess(92,187,1)-"("
       WMESS3 +=[F:TSV]GFY-"<>"-GROUPE+")"
      Endif
  Endif
Return

######################################################################################
#-- X3SUIVI 71937 : Données par législation pour le Type facture
######################################################################################
## Tunnel Type facture
######################################################################################
Subprog TUNTSV(SIVTYP,LEG)
Variable Char    SIVTYP()
Value    Char    LEG()

Global Char VCOD(GLONTSV)
Local Char  VLEG(GLONADI)

  # To update the TSV code after the tunnel order
  VCOD =[L]SIVTYP
  VLEG = LEG
  If clalev([F:TSV])=0 : Local File TABSIVTYP [TSV] : Endif
  If func AFNC.ACTIV("LEG")=0 : VLEG = GDOSLEG : Endif

  Read [TSV]TSV0 = VCOD;VLEG
  If fstat : VLEG = "" : Endif
  Call OBJET("TSV",VLEG,VCOD) From GOBJET
 [L]SIVTYP = VCOD
  Kill VCOD
End

####################################################################################################
## $SELTSV : X3SUIVI 71937 : Données par législation pour le Type facture                         ##
##       --> Si [L]LEG<>""                           --> Utilisation de la vue LEGTSVSEL  (TSVS)  ##
##       --> Si [L]LEG=""                            --> Utilisation de la vue LEGTSVPAR  (TSVP)  ##
##       --> Si [L]LEG=<>"" OU (LEG="" & GROUPE<>'') --> Utilisation de la vue LEGTSVCPY  (TSVC)  ##
##   FACGROUP --> Table de lien Groupe et site                                                    ##
##   AGRPCPY  --> Table de lien Groupe et société                                                 ##
####################################################################################################
$SELTSV
  #--------------------------------------------------------------------------------------------------
  If clalev([F:TSV]) =0 : Local File TABSIVTYP [TSV]  : Endif
  If clalev([F:FCY]) =0 : Local File FACILITY  [FCY]  : Endif
  If clalev([F:CPY]) =0 : Local File COMPANY   [CPY]  : Endif
  If clalev([F:FGR]) =0 : Local File FACGROUP  [FGR]  : Endif
  If clalev([F:AXX]) =0 : Local File ATEXTRA   [AXX]  : Endif
  If clalev([F:AGF]) =0 : Local File AGRPFCY   [AGF]  : Endif
  If clalev([F:AGF]) =0 : Local File AGRPFCY   [AGF]  : Endif
  If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
  #--------------------------------------------------------------------------------------------------

  Local Char    FCY(GLONFCY), CPY(GLONCPY), LEG(GLONADI), GFY(GLONAGC), CRIT1(120)
  Local Integer WNOL, ERR
  Local Integer ERR
  Local Char    AUTRE_CRIT(250)
  Local Char    SZVIEW(GLONAVW)
  Local Char CODMSK(GLONAMK)
  Local Char CHAMPCOD(GLONAVA)

  If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif #--CPO 71937 Pour déterminer les options de sélection
  Local Char CODMSK   (GLONAMK)  #--CPO 71937 Pour déterminer les options de sélection
  Local Char CHAMPCOD (GLONAVA)  #--CPO 71937 Pour déterminer les options de sélection

  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #  #--On charge les options définies sur le type de données du champ du masque
  #  OPTIONS = ""
  #  If CODMSK <> "" and CHAMPCOD <> "" Then
  #    Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
  #    If fstat = 0 Then
  #      OPTIONS = [F:AMZZ]OPTOBJ
  #    Endif
  #  Endif
  #--------------------------------------------------------------------------------------------------
  AUTRE_CRIT = '1=1'
  #--------------------------------------------------------------------------------------------------
  # Récupération des paramètres
  #--------------------------------------------------------------------------------------------------
  If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PST2
    If dim([M:ADWP]LEG)>0
      LEG = [M:ADWP]LEG
    Endif
    FCY      = [M:ADWP]FCY
    CPY      = [M:ADWP]CMP
  Else
    LEG      = PARAM(1)
    CRIT1    = PARAM(2)
    FCY      = PARAM(3)
    GFY      = PARAM(4)
    CPY      = PARAM(5)
    CODMSK   = PARAM(6)
    CHAMPCOD = PARAM(7)
    #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
    #--On charge les options définies sur le type de données du champ du masque
    OPTIONS = ""
    If CODMSK <> "" and CHAMPCOD <> "" Then
      Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
      If fstat = 0 Then
        OPTIONS = [F:AMZZ]OPTOBJ
      Endif
    Endif
  Endif
  #--/CPO

  #--------------------------------------------------------------------------------------------------
  If left$(GFONCTION,6) = "GESTSV" Then
    # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
    OBJET = "TSV"
    Return
  Endif

  #--------------------------------------------------------------------------------------------------
  #-- Initialisation de législation
  If func AFNC.ACTIV("LEG")=0
    [L]LEG = GDOSLEG
  Endif

  If [L]LEG=""
   If [L]FCY<>""
    Call LEC_FCY([L]FCY) From CPTLEC
    Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
    [L]LEG = [F:CPY]LEG
   Elsif [L]CPY<>""
    Call LEC_CPY([L]CPY) From CPTLEC
    [L]LEG = [F:CPY]LEG
   Endif
  Endif

  If [L]LEG="" :  [L]LEG = GCURLEG : Endif

  #--------------------------------------------------------------------------------------------------
  ## Position et taille de la fenêtre
  #--------------------------------------------------------------------------------------------------
  Gosub OUVRE_LISTE From WOTSV
  For I=1 To NBSEL
   If SELEXP(I)<>""
    COL(I) = SELEXP(I)
   Else
    COL(I) = SELZON(I)
   Endif
   TIT(I)  = SELLIB(I)
   If left$(SELFMT(I),2)="LA"
    COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
   Endif
  Next I
  #
  NBCOL   = NBSEL
  SIZCOL  = 240
  SIZLIG  = 100
  TIT(0)  = mess(12,123,1)  # Choix
  Call TITOBJ("TSV","",TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  START   = "[F:TSV]SIVTYP"
  ORDRE   = "[F:TSV]SIVTYP;[F:TSV]LEG"
  OBJET   = ""
  #--------------------------------------------------------------------------------------------------
  ## Critères pour la sélection standard
  #--------------------------------------------------------------------------------------------------
  CRITERE(1) = '1=1 '

  #--Groupe de soc/sites
  If FCY="" & CPY="" & GFY<>""
    Read [F:AGF]AGF0=[L]GFY
    If !fstat
     If [F:AGF]FLGLEG=2 : [L]CPY=[L]GFY : Endif
    Endif
  Endif

  #BRBAN 105200 - If is an invoice cancell. it must only show invoice cancell. types
  If func AFNC.ACTIV("INVCA") > 0 & clalev([F:SLT]) > 0
    If [F:SLT]INVCAN=2 & [F:SLT]INVTYP=2
      CRITERE(1)+= " & find([F:TSV]INVTYP,2,4) & [F:TSV]INVCAN=2"
    Else
      CRITERE(1)+= " & [F:TSV]INVCAN<>2"
    Endif
  Endif
  #-

  #- PARAM2 remplace CRIT="(GFACTYP=1&INVTYP=1) |(GFACTYP=2&INVTYP=2) |(GFACTYP=3&INVTYP=5) | .." # du $S_SIVTYP du TRTVENSEL
  If PARAM(2) <> '' : #-- Parametre de sélection CRIT
    CRITERE(1)+=' & ' + [L]CRIT1
  Endif
  If    [L]FCY<>""   : CRITERE(1) -= '& ([F:TSV]GFY="" | ([F:TSV]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'             : #--Site
  Elsif [L]CPY<>""   : CRITERE(1) -= '& ([F:TSV]GFY="" | ([F:TSV]GFY<>"" & [F:TSVC]LEGCPY="'+[L]CPY+'"))' : Endif : #--Société
  #--CPO 71937 NOK (voir plus haut)
  #If FCY="" & CPY="" & GFY<>"" : CRITERE(1) -= '& ([F:TSV]GFY="'+GFY+'" or [F:TSV]GFY="")'                : Endif : #--Groupe soc/sites

  If LEG<>""         : CRITERE(2) -= '& ([F:TSV]LEG="'+[L]LEG+'" | [F:TSV]LEG="")'                        : Endif : #--Législation
  If dim(SELCAR)>0 & SELCAR<>0
    CRITERE(2) -= '& left$([F:TSV]SIVTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
  Endif

  ICRITERE = 3

#MGG X3-38593 Row level permission
  #Call FILROLE(OBJET,FILROLE) From SUBARL
  Call FILROLE("TSV",FILROLE) From SUBARL
#END MGG X3-38593 Row level permission

  If FILROLE<>"" & FILROLE<>"1=1"
   For I=0 To dim(FILROLE)-1
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
   Next I
  Endif

  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue LEGTSVCPY selectionnant les Type facture avec groupe soc/site
  #--------------------------------------------------------------------------------------------------
  If [L]CPY = "" and [L]FCY = "" and [L]GFY <> "" Then
  If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSVYGRP"
      Local File =SZVIEW [TSVY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSV"
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSVZGRP"
      Local File =SZVIEW [TSVZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSV"
      Return
    Endif
  Endif
  Endif

  #--------------------------------------------------------------------------------------------------
  If 1=1 Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSVCPY"
      Local File =SZVIEW [TSVC]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSV"
      Return
    Endif

    If [L]LEG<>""
      ##############################################################################################################
      ## Cas avec [L]LEG<>"" :  Appel à la vue LEGTSVSEL selectionnant les Type facture avec LEG en parametre
      ##                             et la vue LEGTSVCPY  (TSVC) pour le groupe
      ##############################################################################################################
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSVSEL"
        Local File =SZVIEW [TSVS]
        Onerrgo
      Until ERR <> -1
      If ERR : OBJET = "TSV" : Return : Endif    :   #-- Si problème, on se déroute sur le select standard

      #-- Vue de Type facture avec un groupe
      If [L]CPY = "" and [L]FCY = "" and [L]GFY <> "" Then
        Link [TSV] With [F:AXX]AXX0    = "TABSIVTYP";"DESAXX";GLANGUE;[F:TSV]SIVTYP;[F:TSV]LEG,
&                       [F:TSVY]TSVY0 ~= [L]GFY;[F:TSV]SIVTYP;[F:TSV]GFY;[F:TSV]LEG,
&                       [F:TSVS]TSV0  ~= [F:TSV]SIVTYP;[F:TSV]LEG;[L]LEG
&                   As [LTSV]

      Else
        Link [TSV] With [F:AXX]AXX0    = "TABSIVTYP";"DESAXX";GLANGUE;[F:TSV]SIVTYP;[F:TSV]LEG,
&                       [F:FGR]FGR1    = [L]FCY;[F:TSV]GFY,
&                       [F:TSVC]TSV0   = [F:TSV]SIVTYP;[F:TSV]LEG;[F:TSV]GFY;[L]CPY,
&                       [F:TSVS]TSV0  ~= [F:TSV]SIVTYP;[F:TSV]LEG;[L]LEG
&                   As [LTSV]
      Endif
    Else
      ##############################################################################################################
      ## Cas avec [L]LEG="" :  Appel à la vue LEGTSVPAR selectionnant les Type facture sans LEG
      ##                            et la vue LEGTSVCPY  (TSVC) pour le groupe si  GROUPE ou CPY ou FCY <>''
      ##############################################################################################################
      ERR = 0
      Onerrgo ERRVUE
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSVPAR"
        Local File =SZVIEW [TSVP]
        Onerrgo
      Until ERR <> -1
      If ERR : OBJET = "TSV" : Return : Endif :  #-- Si problème, on se déroute sur le select standard
      If FCY="" & CPY="" & GFY<>""
        Link [TSV] With [F:AXX]AXX0    = "TABSIVTYP";"DESAXX";GLANGUE;[F:TSV]SIVTYP;[F:TSV]LEG,
&                       [F:TSVZ]TSVZ0 ~= [L]GFY;[F:TSV]SIVTYP;[F:TSV]GFY;[F:TSV]LEG
&                    As [LTSV]
      Else
        #------ Règle R2.3 : Une fois la sélection sur la LEG effectuée, si nous sommes sur un élément n’ayant pas de  groupe
        #------                   (ou contexte déterminant un groupe) -> on retient l’enregistrement quel que soit le groupe
        #------                   (que l’enregistrement ait un groupe ou  Tous Groupes).
        Link [TSV] With [F:AXX]AXX0 = "TABSIVTYP";"DESAXX";GLANGUE;[F:TSV]SIVTYP;[F:TSV]LEG,
&                       [F:FGR]FGR1   = [L]FCY;[F:TSV]GFY,
&                       [F:TSVC]TSV0  = [F:TSV]SIVTYP;[F:TSV]LEG;[F:TSV]GFY;[L]CPY,
&                       [F:TSVP]TSV0 ~= [F:TSV]SIVTYP;[F:TSV]LEG
&                    As [LTSV]
      Endif
    Endif
  Endif
  #--------------------------------------------------------------------------------------------------
  # Options de sélection
  If OPTIONS <> "" Then
    Gosub OPTIONS From WOTSV
    ICRITERE += 1
    For I = 1 To NBCOND
      If instr(1,OPTIONS,OPT(I)) Then
        # BRBAN #105200 US2 - Need to hide option C([F:TSV]COD2<>'') if legislation have invoice cancellation
        If func AFNC.ACTIV("INVCA")>0
          Local Char WINVCAN(50)

          Call PARAM([F:FCY]LEG, "INVCAN", [L]WINVCAN) From ADOVAL
          If val([L]WINVCAN)=2 & OPT(I)='C'
            Goto SKIP_OPTN
          Endif
        Endif
        # -
        Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", "("+CONDIT(I)+")", "&") From GOBJSUB
      Endif
      $SKIP_OPTN
    Next I
  Endif
  #--------------------------------------------------------------------------------------------------
  Default File [LTSV]
  DEFPAG = 1
Return

################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume


##################################################
Subprog SELTSVA(SIVTYP,LEG,FCY,GROUPE,CPY,CODMSK,CHAMPCOD)
Variable Char    SIVTYP()
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Value    Char    CODMSK()
Value    Char    CHAMPCOD()

Local Char PARMSK(30)(1..10)
PARMSK(1)=[L]LEG
PARMSK(2)=""
PARMSK(3)=[L]FCY
PARMSK(4)=[L]GROUPE
PARMSK(5)=[L]CPY
PARMSK(6)=[L]CODMSK
PARMSK(7)=[L]CHAMPCOD

If clalev([F:TSV])=0 : Local File TABSIVTYP [TSV] : Endif
Call S_TAB_CHAR(SIVTYP,PARMSK,"SELTSV","SUBTSV","") From GACTION

End

###########################################################################
# $TRTCOP
###########################################################################
$TRTCOP

#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'une retenue                      #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
   Local File TABSIVTYP [TSV1]
   Local File ATEXTRA   [AXX1]

Else
   Local File =[M]DOSORG+".TABSIVTYP" [TSV1]
   Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
   Local File TABSIVTYP [TSV2]
   Local File ATEXTRA   [AXX2]
   Local File ACTIV     [ACV2]
Else
   Local File =[M]DOSDES+".TABSIVTYP" [TSV2]
   Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
   Local File =[M]DOSDES+".ATABDIV"   [ADI2]
   Local File =[M]DOSDES+".ACTIV"     [ACV2]
   Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TRT_COPIE

Close Local File [TSV1], [TSV2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

######################################################################################
# $TRT_COPIE
######################################################################################
$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'un type de facture        #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK=1

#If TABLE2<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; TABLE2
#  If fstat
#   Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
#
#  LG = instr(1, [M]DOSDES, "@")
#  If LG = 0 Then
#    SZDOSSIER = [M]DOSDES
#  Else
#    SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
#  Endif
#  Read [ADS2]DOSSIER=SZDOSSIER
#    If !fstat Then
#      If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
#        Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
#        Return
#      Endif
#  Endif
#
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TSV2]TSV0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Trbegin [TSV2]
  Delete [TSV2] Where SIVTYP=TABLE & LEG = LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABSIVTYP"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("TSV2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  If !fstat
         #--- copie des données
         For [TSV1]Where SIVTYP=TABLE & LEG = TABLE2
             [F:TSV2]=[F:TSV1]
             [F:TSV2]LEG = LEGDES
             If TABLE2=LEGDES
                 Call COPTEXTRA("TABSIVTYP","DESAXX",TABLE,TABLE2) From ATEXTRA
                 Call COPTEXTRA("TABSIVTYP","SHOAXX",TABLE,TABLE2) From ATEXTRA
             Else
                 Call COPTEXTRA1("TABSIVTYP","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
                 Call COPTEXTRA1("TABSIVTYP","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
             Endif
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             If dim([F:TSV2]UPDUSR)>0 : [F:TSV2]UPDUSR = GUSER : Endif
             If dim([F:TSV2]UPDDAT)>0 : [F:TSV2]UPDDAT = date$ : Endif
             Write [TSV2]
             If fstat
                GOK = 0 : Call FSTA("TSV2") From GLOCK : Break
             Endif
         Next
      Endif
      If   GOK<0    : Goto ROLL_COPIE
         Elsif !GOK : Goto AB_COPIE
      Endif
Commit

Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback

Return

#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran TSV1) 19/12/2012 15:07:18 (CPO)
######################################################################################
Subprog C_GFY(VALEUR)
Variable Char    VALEUR()
GGRPFCY = VALEUR :#--CPO 71937
End

######################################################################################
Subprog VERF_PARAM(PPARAM,PVALEUR,POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

If PVALEUR="" End Endif

If clalev([F:TSV])=0 : Local File TABSIVTYP [TSV] : Endif

Local Char    FCY(GLONFCY),SAVE_GCURFCY( GLONFCY)
Local Char    CPY(GLONCPY),SAVE_GSOCIETE(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer WNOL
Local Integer ERR

[L]SAVE_GCURFCY = GCURFCY
[L]SAVE_GSOCIETE= GSOCIETE

If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PGT
  FCY  = [M:ADWP]FCY : GCURFCY = FCY
  CPY  = [M:ADWP]CMP : GSOCIETE= CPY
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Else
    LEG = GDOSLEG
  Endif

  WNOL = nolign-1
  #--Initialisation de législation
  If [L]LEG=""
    If [L]FCY<>""
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      GSOCIETE = [F:FCY]LEGCPY
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY<>""
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG=""
    [L]LEG = GCURLEG
  Endif
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #Call CONTTSV(PVALEUR,LEG,"","",FCY,"",CPY)
  Call CONTTSV(PVALEUR,LEG,"MULTILEGADP",PPARAM,FCY,"",CPY)
  #If mkstat : POK=0 : Endif
    If mkstat
    POK = 0
  Else
    #85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
    If func AFNC.ACTIV("KPO")
      Filter [TSV] Where [F:TSV]SIVTYP = PVALEUR & ([F:TSV]SAFTINVTYP = 2 | [F:TSV]AUTINV = 2)
      Read [TSV] First
      If fstat = 0 : POK = 0 : mkstat = 2 : GMESSAGE = mess(116,7711,1) : Endif
      Filter [TSV]
    Endif
    #85803 RICAR 2014/05/20 - Portuguese legal requirements - END
  Endif
Endif

GCURFCY = [L]SAVE_GCURFCY
GSOCIETE= [L]SAVE_GSOCIETE

End
###################################################################################################
##--CPO 71937 Contrôle global de cohérence avant enregistrement
$CONTROLE_COHERENCE

  Local Integer WSTAT
  Local Char    WMESSA(250)
  Local Char  	WCODE
  Local Char    WLEG
  Local Char    WCTX_CPY
  Local Char    WCTX_FCY
  Local Char    WCTX_LEG

	WCODE=[M:TSV1]SIVTYP
	WLEG =[M:TSV1]LEG

  Call CTL_ML_CONSISTENCY("TSV", "NON", WCODE, WLEG , WCTX_CPY, WCTX_FCY, WCTX_LEG, WSTAT, WMESSA) From TRTVENCTL
  If WSTAT>0 or WMESSA<>""
  	GMESSAGE = WMESSA : GOK=0 : GERR=1 #--Si on ne veux pas bloquer..GERR=2
  Endif

Return
#--------------------------------------------------------------------------------------------------
$CHECK_CONSISTENCY
	Local Integer WRET

	If clalev([F:TSV])=0 : Local File TABSIVTYP [TSV] : Endif

  #--Vérification de la compatibilité des sous-données déclinées elles aussi

	#--  P_CODE<>"" and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and PACTUAL_LEG<>"" and P_LEG<>PACTUAL_LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-PACTUAL_LEG :# "Législations différentes"
		Return
	Endif

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTSV il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If left$(GFONCTION,6) <> "GESTSV"
  	#--Cohérence [TSV] et paramètres
  	Call CONTTSV(P_CODE,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSV
  	If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
  #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
  Else #Endif
    #--Cohérence [TSV]JOU et paramètres
    If PACTUAL_FCY<>""
    	Call CONTJOU([TSV]JOU, PACTUAL_LEG, PACTUAL_FCY) From SUBJOU
    Else
    	Call CONTJOU([TSV]JOU, PACTUAL_LEG, PACTUAL_CPY) From SUBJOU
  	Endif
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

    #--Cohérence [TSV]GTE et paramètres
    If PACTUAL_FCY<>""
    	Call CONTGTE([TSV]GTE, PACTUAL_LEG, PACTUAL_FCY) From SUBGTE
    Else
    	Call CONTGTE([TSV]GTE, PACTUAL_LEG, PACTUAL_CPY) From SUBGTE
  	Endif
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CONTEXT
	Local Integer I,IJ
	Local Integer RET,I
	Local Integer CAS
	Local Char LEGS(GLONADI)(1..)
	Local Integer COHERENCE_OK

	If clalev([F:TSV])=0 : Local File TABSIVTYP  [TSV] : Endif
	If clalev([F:JOU])=0 : Local File GJOURNAL   [JOU] : Endif
	If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif

	Local Instance GROUPES Using C_GRPCOLL

	#--On connait la détermination
	#--On cherche un contexte compatible
	#--Si pas de contexte compatible, alors la donnée multi-lég est mal paramétrée

	#-- P_CODE<>"" and (PACTUAL_CPY="" and PACTUAL_FCY=""and PACTUAL_LEG="")

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTSV il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If left$(GFONCTION,6) <>"GESTSV" and ( [F:TSV]SIVTYP<>P_CODE | find([F:TSV]LEG,P_LEG,"")=0 )
    If P_LEG<>""
     Read [TSV]TSV0=P_CODE;P_LEG
     If fstat
      Read [TSV]TSV0=P_CODE;""
     Else
      CAS = 2 : # P_LEGislation isn't empty
     Endif
    Else
     Read [TSV]TSV0(1)=P_CODE
     If !fstat
      P_LEG = [F:TSV]LEG
      CAS = 2
     Endif
    Endif
    If fstat
     Filter [TSV] Where SIVTYP=P_CODE
     Look [TSV]TSV0 First
     If !fstat
      # Fiche inexistante pour la législation courante
      VMESSAGE = P_CODE-":"-mess(232,107,1)-"["+P_LEG+"]"
     Else
      # Fiche inexistante
      VMESSAGE = P_CODE-":"-mess(23,100,1)
     Endif
     Filter [TSV]
     VSTATUS=99 : Return
    Endif
  Endif

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and [F:TSV]LEG<>"" and P_LEG<>[F:TSV]LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-[F:TSV]LEG :# "Législations différentes"
		Return
	Endif

  P_LEG=[F:TSV]LEG
  LEGS(1)=P_LEG

  If P_LEG=""
		#--Le code retenu est toutes législations
		#--Il faut d'abord trouver une législation commune
		#--Puis pour cette législation, il faut déterminer une société commune aux groupes, sinon on renvoye ""
		I = 2

		If [F:TSV]JOU<>""
  		For [JOU] Where JOU=[F:TSV]JOU
  			If [F:JOU]LEG<>"" and find([F:JOU]LEG,LEGS)=0
  				LEGS(I) = [F:JOU]LEG
  				I += 1
  			Endif
  		Next
  	Endif

		If [F:TSV]GTE<>""
  		For [GTE] Where TYP=[F:TSV]GTE
  			If [F:GTE]LEG<>"" and find([F:GTE]LEG,LEGS)=0
  				LEGS(I) = [F:GTE]LEG
  				I += 1
  			Endif
  		Next
  	Endif

	Endif

	For I=1 To maxtab(LEGS)

  	#--Le code retenu contient une législation en particulier
  	#--Cette législation sera renvoyée
  	#--Reste à déterminer une société commune aux groupes, sinon on renvoye ""

  	#--On commence par lire les sous-données déclinées

  	#--Lecture du Régime de taxes
  	If [F:TSV]JOU<>""
    	Call LEC_JOU_LEG(LEGS(I),[F:TSV]JOU,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:JOU]
    Endif

  	#--Lecture de la Nature de taxes
  	If [F:TSV]GTE<>""
    	Call LEC_GTE_LEG(LEGS(I),[F:TSV]GTE,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:GTE]
    Endif

  	#--Il reste à trouver une société commune aux différents groupes
  	#--La société doit être de la législation retenue

		If [F:TSV]GFY<>"" or [F:JOU]FCY <>"" or [F:GTE]GFY<>""

      GROUPES = NewInstance [GRPTSV] With C_GRPCOLL


      RET= fmet GROUPES.GROUPADD([F:TSV]GFY)
      RET= fmet GROUPES.GROUPADD([F:JOU]FCY)
      RET= fmet GROUPES.GROUPADD([F:GTE]GFY)

    	For IJ = 1 To maxtab(GROUPES.L_FCY)
      	If GROUPES.L_FCY(IJ)<>null and find(GROUPES.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      	  If LEGS(I)="" | GROUPES.L_FCY(IJ).FCYCPYLEG = LEGS(I)

        		PACTUAL_FCY = GROUPES.L_FCY(IJ).FCY
        		PACTUAL_CPY = GROUPES.L_FCY(IJ).FCYCPY
        		PACTUAL_LEG = GROUPES.L_FCY(IJ).FCYCPYLEG

        		FreeInstance =GROUPES.AllocGrp

        		COHERENCE_OK = 1
        		Break 2

      		Endif
      	Endif
    	Next IJ

      #--On libère proprement...
      FreeInstance =GROUPES.AllocGrp

		Else
			#--On a trouvé une lég, et il n'y a pas de groupes
			#--C'est bon...
    	#--Les lectures ont abouti
    	#--On peut renvoyer le legs(i) comme législation du contexte
    	PACTUAL_LEG = LEGS(I)
    	COHERENCE_OK = 1
    	Break

		Endif

   	$NEXT_LEGS
	Next I

	#--On positionne le VSTATUS si rien trouvé
  If COHERENCE_OK <>1
  	VMESSAGE = mess(799,197,1)
  	VSTATUS  = 1 : Return
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CODE
	If clalev([F:TSV])=0 : Local File TABSIVTYP [TSV] : Endif
  #--On connait le contexte
  #--On cherche une détermination compatible

  #--  P_CODE=""  and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

	#--Filtre sur la législation ou "toutes législations"
  Filter [F:TSV] Where find(LEG,"",PACTUAL_LEG)>0

	For [F:TSV]

		Raz VSTATUS : Raz VMESSAGE

    #--Cohérence [TSV] et paramètres
    Call CONTTSV([F:TSV]SIVTYP, PACTUAL_LEG, "","", PACTUAL_FCY, "", PACTUAL_CPY) From SUBTSV
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif

    #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
    #  	If VSTATUS=0
    #      #--Cohérence [TSV]JOU et paramètres
    #      If PACTUAL_FCY<>""
    #      	Call CONTJOU([TSV]JOU, PACTUAL_LEG, PACTUAL_FCY) From SUBJOU
    #      Else
    #      	Call CONTJOU([TSV]JOU, PACTUAL_LEG, PACTUAL_CPY) From SUBJOU
    #			Endif
    #      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
    #  	Endif
    #
    #  	If VSTATUS=0
    #      #--Cohérence [TSV]GTE et paramètres
    #      If PACTUAL_FCY<>""
    #      	Call CONTGTE([TSV]GTE, PACTUAL_LEG, PACTUAL_FCY) From SUBGTE
    #      Else
    #      	Call CONTGTE([TSV]GTE, PACTUAL_LEG, PACTUAL_CPY) From SUBGTE
    #			Endif
    #      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
    #  	Endif

    If VSTATUS=0
    	#--Le code trouvé est cohérent avec le contexte
    	P_CODE=[F:TSV]SIVTYP
			P_LEG =[F:TSV]LEG
			Break
		Endif

	Next

	Filter [F:TSV]

	If VSTATUS>0 | P_CODE=""
		VMESSAGE = mess(798,197,1)-":"-mess(218,107,1)-PACTUAL_LEG+","-mess(2,45,1)-PACTUAL_CPY
	Endif

Return

End
