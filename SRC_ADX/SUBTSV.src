Subprog C_GTE(VALEUR)
#----------------------------------#
# Contrôle type de pièce comptable #
#----------------------------------#
Variable Char    VALEUR()

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find([M:TSV1]LEG,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_FINAL(VALEUR,[M:TSV1]LEG,[M:TSV1]SIVTYP,"TSV",WMESS) From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif

