#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier TABSIVTYP
######################################################################
# SUBTSV : Gestion des types de factures vente                       #
######################################################################
#tsv
Call OBJET("TSV",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT           # FGR 20/12/2012 : X3SUIVI71937
 When "AFFMASK"      : Gosub AFFMASK
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INICRE
 When "ANNULE"       : Gosub ANNULE
 When "VERIF_CRE"    : Gosub VERIF
 When "VERIF_MOD"    : Gosub VERIF
 #-- X3Suivi 71937 : Données par législation pour le type facture
 #When "CHANGE"       : #--CPO 71937 Prise en compte de LEG, ajout de SUPP
 #                      Call CHANGE_AXX ("TABSIVTYP", [L]SUPP(0), [L]OCODE, [L]SUPP(0), [L]NCODE) From TRTX3TEX
 #When "SEL_TABLE"    : Case TABLE :    When "SELTSV"    : Gosub SELTSV :    Endcase
 When "SEL_TABLE"   :                         # FGR 11/12/2012 : X3SUIVI71937
   Case TABLE
      When "SELTSV"
        Gosub SELTSV
      When Default
        Gosub SEL_TABLE
   Endcase
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "FERME"        : Gosub FERME    :#--CPO 71937
 When "CHGCOD"       : Gosub CHGCOD
 When Default
Endcase
Return

#############################################################################
$OUVRE
#------------------------------------#
# Sauvegarder des variables globales #
#------------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
#--CPO 71937
#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
#If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#--/CPO

GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto

#BRBAN 08/10/2014 - Document types control
If !clalev([F:TSV3]) : Local File TABSIVTYP [TSV3] : Endif
#-

Return
#############################################################################
$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Gosub GRIJOU
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [TSV1]LEG
  [M:TSV1]LEG=GDOSLEG(1)
  Affzo [TSV1]LEG : If dim([M:TSV1]ZLEG)>0  Affzo [TSV1]ZLEG : Endif
Endif
Return

$GRIJOU
If GMODU(2)<>2
  Grizo JOU
Endif
Return
#############################################################################
$VERIF
#BRBAN 08/10/2014 - Document types control
If func AFNC.ACTIV("KPO") > 0
  Case [M:TSV1]LEG
    When ""
      Read [F:TSV3]TSV0=[M:TSV1]SIVTYP;"POR"
      If !fstat
        If [M:TSV1]RECTYP <> [F:TSV3]RECTYP
          Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TSV3]SIVTYP,[F:TSV3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TSV1]SAFTINVTYP <> [F:TSV3]SAFTINVTYP
          Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TSV3]SIVTYP,[F:TSV3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TSV1]AUTINV <> [F:TSV3]AUTINV
          Call ECR_TRACE(func AFNC.MES2(mess(138,7711,1),[F:TSV3]SIVTYP,[F:TSV3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
      Endif
    When "POR"
      Read [F:TSV3]TSV0=[M:TSV1]SIVTYP;""
      If !fstat
        If [M:TSV1]RECTYP <> [F:TSV3]RECTYP
          Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TSV3]SIVTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TSV1]SAFTINVTYP <> [F:TSV3]SAFTINVTYP
          Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TSV3]SIVTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TSV1]AUTINV <> [F:TSV3]AUTINV
          Call ECR_TRACE(func AFNC.MES2(mess(138,7711,1),[F:TSV3]SIVTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
      Endif
  Endcase

  If find([M:TSV1]LEG,"","POR") & [M:TSV1]RECTYP <> 4 & [M:TSV1]AUTINV = 2
    Call ECR_TRACE(mess(143,7711,1),2) From GESECRAN
    OK = 0 : Return
  Endif

Endif
#-
# Issue 109713 - 2015-07-22 by BRBAN
If func AFNC.ACTIV("INVCA")>0
  If [M:TSV1]JOU='' & [M:TSV1]INVCAN=2
    GMESSAGE= mess(53,141,1)
    OK=  0  : Return
  Endif
Endif
# -
Return
#################################################################################
$CHGCOD
  # X3Suivi 71937
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return
#---------------------------------------------------------------------
# Traitement zones dépendant de la catégorie "Proforma"
#---------------------------------------------------------------------
$RAZCRE
Actzo [M:TSV1]COD, COD2, JOU, GTE
Gosub GRILEG
Gosub GRIJOU

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TSV([M:TSV1]LEG) From PORLEGLIB
Endif

Return

$RAZDUP

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TSV([M:TSV1]LEG) From PORLEGLIB
Endif

Return

#---------------------------------------------------------------------
# Grisage dégrisage zones dépendant de la catégorie "Proforma"
#---------------------------------------------------------------------
$LIENS

#--CPO 71937
GCURLEG = [F:TSV]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

If [M:TSV1]INVTYP<>5
  Actzo [M:TSV1]COD, COD2, JOU, GTE
Else
  Grizo [M:TSV1]COD, COD2, JOU, GTE
Endif
GGRPFCY = [M:TSV1]GFY :#--CPO 71937

Gosub GRIJOU

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TSV([M:TSV1]LEG) From PORLEGLIB
Endif

# BRBAN #105200 US1
If func AFNC.ACTIV("INVCA") > 0
  Gosub ACTION From TRTINVCAN
Endif
# -

# Issue X3-143 - 2016-10-03 by RICAR : 107966 - Change the field actions on RECTYP, SAFTTRNTYP and COMAT
# Issue X3-143
If func AFNC.ACTIV("KPO") > 0
  Gosub DISABLE_TSV_FIELDS From PORLEGLIB
Endif
# End issue X3-143

Return

######################################################################
$SETBOUT
  # FGR 20/12/2012 : X3SUIVI71937
  #------------------------------#
  # Désactivation bouton "Copie" #
  #------------------------------#
  If GREP <> "" | !CLECUR Then
    Call VIREBOUT(CHAINE, "2") From GOBJET
  Endif
Return

#---------------------------------------------------------------------
$INICRE
#--- Creation / Modif de ATEXTRA
#--CPO 71937 Prise en compte de LEG, ajout de [M:TSV1]LEG
Call MAJTEXTRA ([M:TSV1]DESAXX,"TABSIVTYP","DESAXX",[M:TSV1]SIVTYP,[M:TSV1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TSV1]SHOAXX,"TABSIVTYP","SHOAXX",[M:TSV1]SIVTYP,[M:TSV1]LEG) From ATEXTRA

#    SOS libellés
If dim([F:TSV]LANDESSHO)>0
   [F:TSV]LANDESSHO=GLANGUE+"~"+[M:TSV1]DESAXX+"~"+[M:TSV1]SHOAXX
Endif

#--CPO 71937 Contrôle global de cohérence avant enregistrement
Gosub CONTROLE_COHERENCE

# BRBAN #105200 US1
If func AFNC.ACTIV("INVCA") > 0
  Gosub ACTION From TRTINVCAN
Endif
# -
Return

######################################################################
# $AP_CHANGE
######################################################################
$AP_CHANGE
 Call CHGTEXTRA("TABSIVTYP","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
 Call CHGTEXTRA("TABSIVTYP","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return


#---------------------------------------------------------------------
$ANNULE
#--CPO 71937 Prise en compte de LEG, ajout de [F:TSV]LEG
Delete [AXX] Where CODFIC="TABSIVTYP" & IDENT1=[F:TSV]SIVTYP & IDENT2=[F:TSV]LEG

Return

$FERME
#--CPO 71937
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTSV) : Endif

VCOD = CLE2

Return
######################################################################

$SEL_TABLE
#---------------------#
# Sélection sur champ #
#---------------------#
Case COUZON
 When "COD"   : # Pièce auto Vente
  OBJET="GAU"
  CRITERE="TBL='SINVOICEV'"
 When "COD2"  : # Pièce auto Tiers
  OBJET="GAU"
  CRITERE="TBL='SINVOICE'"
Endcase
Return

######################################################################

Subprog AM_INVTYP(VALEUR)
#--------------------------------------------#
# Après modification de la catégorie facture #
#--------------------------------------------#
Variable Integer VALEUR
If VALEUR=5
  Effzo [M:TSV1]COD, COD2, JOU, GTE
  Grizo [M:TSV1]COD, COD2, JOU, GTE
Else
  Actzo [M:TSV1]COD, COD2, JOU, GTE
Endif
Gosub GRIJOU

# BRBAN #105200 US1
If func AFNC.ACTIV("INVCA") > 0
  Call AM_INVTYP(VALEUR) From TRTINVCAN

  If [M:TSV1]INVCAN=2
    [M:TSV1]COD  = ''
    [M:TSV1]COD2 = ''
    Diszo [M:TSV1]COD,COD2
    Affzo [M:TSV1]COD,COD2
  Else
    Actzo [M:TSV1]COD,COD2
    Affzo [M:TSV1]COD,COD2
  Endif

Endif
# -
End

Subprog C_COD(VALEUR)
#--------------------------------#
# Contrôle code pièce auto vente #
#--------------------------------#
Variable Char    VALEUR()
If VALEUR<>""
 Read [GAU]GAU0 = VALEUR
 If !fstat
  If [F:GAU]TBL <> 'SINVOICEV'
   GMESSAGE = mess(61,119,1)-'SINVOICEV'    # La table déclenchante n'est pas SINVOICEV
   mkstat=2 : End
  Endif
 Endif
Endif
End

Subprog C_COD2(VALEUR)
#--------------------------------#
# Contrôle code pièce auto tiers #
#--------------------------------#
Variable Char    VALEUR()
If VALEUR<>""
 Read [GAU]GAU0 = VALEUR
 If !fstat
  If [F:GAU]TBL<>'SINVOICE'
   GMESSAGE = mess(61,119,1)-'SINVOICE'    # La table déclenchante n'est pas SINVOICE
   mkstat=2 : End
  Endif
 Endif
Endif
End

