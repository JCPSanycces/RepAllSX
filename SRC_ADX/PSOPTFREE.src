#<AdxTL>@(#)0.0.0.0 $Revision$
# PSOPTFREE

# Remove work orders and/or suggestions from scheduling, allowing
# work orders to be amended.


$ACTION
#---Actions liées à la saisie fenêtre
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When Default
Endcase

Return
#######################################################################
$OUVRE
Call FIND_GFCYDEF(8) From TRTX3       # FQ 54218
Gosub CHARG_PARAM                 # mm 12.02

Return

#######################################################################
$DEBUT
Raz [M:PSOPF]
Call FIND_GFCYDEF(8) From TRTX3       # FQ 54218
[M:PSOPF]MFGFCY = GFCY
Affzo [M:PSOPF]
Return

#######################################################################
$OK
Call PSFREEMFG([M:PSOPF]MFGFCY, [M:PSOPF]MFGNUMDEB, [M:PSOPF]MFGNUMFIN, [M:PSOPF]ITMREFDEB, [M:PSOPF]ITMREFDEB, 1)
Return

########################################################################
# Chargement variables globales
$CHARG_PARAM

Call GLOBVAR(GFCY)    From WWGLOBSTO

# Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

Return
######################################################################################
## Section automatically added (screen PSOPTFREE) 08/04/2016 15:59:37 (STWIL)
######################################################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02

End


######################################################################################
# Using the supplied parameters, read through all work orders and work order suggestions
# and set the optflg to 1 to 'remove from scheduling'.
Subprog PSFREEMFG(LFCY, LMFGDEB, LMFGFIN, LITMDEB, LITMFIN, LTRC)
    Value Char LFCY
    Value Char LMFGDEB
    Value Char LMFGFIN
    Value Char LITMDEB
    Value Char LITMFIN
    Value Integer LTRC

    Local Integer  NBOF : NBOF = 0
    Local Char     WTEX(80)
    Local Char FILTEXT(250)
    Local Char FILTEXTSUG(250)

    Call TEMPON("") From GESECRAN

    If clalev([F:MFG])  = 0 : Local File MFGHEAD   [MFG]  : Endif
    If clalev([F:MFI])  = 0 : Local File MFGITM    [MFI]  : Endif
    If clalev([F:ORD])  = 0 : Local File ORDERS    [ORD]  : Endif

    # ouverture trace
    WTEX = mess(288,197,1)-"("+LFCY+")"
    If LTRC <> 0
        Call OUVRE_TRACE(WTEX) From LECFIC
    Endif

    # Add range values to filters
    # Issue X3-85711 - YARAM : Remove the work order in status 'Optimised'
    FILTEXT = "([F:MFG]OPTFLG=2 | [F:MFG]SCDFLG=4)"
    FILTEXTSUG = "[F:ORD]OPTFLG=2 & [F:ORD]WIPSTA = 3 & [F:ORD]WIPTYP = 5"
    If LFCY <> ""
        Append FILTEXT, " & [F:MFG]MFGFCY = LFCY"
        Append FILTEXTSUG, " & [F:ORD]ORIFCY = LFCY"
    Endif
    If LMFGDEB <> ""
        Append FILTEXT, " & [F:MFI]MFGNUM >= LMFGDEB"
        Append FILTEXTSUG, " & [F:ORD]WIPNUM >= LMFGDEB"
    Endif
    If LMFGFIN <> ""
        Append FILTEXT, " & [F:MFI]MFGNUM <= LMFGFIN"
        Append FILTEXTSUG, " & [F:ORD]WIPNUM <= LMFGFIN"
    Endif
    If LITMDEB <> ""
        Append FILTEXT, " & [F:MFI]ITMREF >= LITMDEB"
        Append FILTEXTSUG, " & [F:ORD]ITMREF >= LITMDEB"
    Endif
    If LITMFIN <> ""
        Append FILTEXT, " & [F:MFI]ITMREF <= LITMFIN"
        Append FILTEXTSUG, " & [F:ORD]ITMREF <= LITMFIN"
    Endif

    Call DEBTRANS From GLOCK
    Trbegin [MFG], [ORD]

    # Remove any selected work orders from scheduling
    Link [MFI] With
&       [MFG]MFG0~=[MFI]MFGNUM
&   As [WOR_] Where evalue(FILTEXT)
    For [WOR_]
        Readlock [MFG] MFG0 = [F:MFI]MFGNUM
        If fstat = [V]CST_AOK
            [F:MFG]OPTFLG = 1
            # If WO is optimised release it.
            If [F:MFG]SCDFLG = 4
                [F:MFG]SCDFLG = 2
            Endif
            Rewrite [MFG]

            # Issue X3-29698 - 2017-04-07 by CCC : Remove forced dates set by PS & all pins
            Call REMOVE_PS_INFO([F:MFG]MFGNUM) From PSOPTFREE

            WMESS   = mess(156,197,1)-[F:MFG]MFGNUM-mess(289,197,1)
            NBOF += 1
        Else
            WMESS   = mess(156,197,1)-[F:MFG]MFGNUM-mess(890,197,1)
        Endif
        If LTRC <> 0
            Call ECR_TRACE(WMESS,0) From GESECRAN
        Endif
    Next

    # Remove any selected suggestions from scheduling
    For [ORD]ORD1 Where evalue(FILTEXTSUG)
        Readlock [ORD] Curr
        If fstat = [V]CST_AOK
            [F:ORD]OPTFLG = 1
            Rewrite [ORD]
            WMESS   = mess(235,197,1)-[F:ORD]WIPNUM-mess(289,197,1)
            NBOF += 1
        Else
            WMESS   = mess(235,197,1)-[F:MFG]WIPNUM-mess(890,197,1)
        Endif
        If LTRC <> 0
            Call ECR_TRACE(WMESS,0) From GESECRAN
        Endif
    Next

    # Only commit transaction if we have updated at least one record.
    If NBOF > 0
        Commit
    Else
        Rollback
    Endif
    Call TEMPOFF From GESECRAN
    If LTRC <> 0
        If NBOF = 0
            Call ECR_TRACE(mess(88,193,1),0) From GESECRAN
        Endif
        # fermeture trace
        Call FERME_TRACE From LECFIC
        # lecture trace
        Call LEC_TRACE From LECFIC
    Endif
End

#**
#* Remove pins+linked forced dates added by Production scheduler
#*
#* @param PMFGNUM : WO number
#*!
Subprog REMOVE_PS_INFO(PMFGNUM)
Value Char PMFGNUM

# Issue X3-29698 - 2017-04-07 by CCC : Remove forced dates set by PS & all pins

If clalev([F:PIN])=0 : Local File POPSPIN [PIN] : Endif
If clalev([F:MFO])=0 : Local File MFGOPE  [MFO] : Endif

Local Integer LTRANS
If adxlog=0
    LTRANS=1
    Call DEBTRANS From GLOCK
    Trbegin [PIN]
Endif

Link [PIN] With [MFO]MFO0~=[F:PIN]MFGNUM;[F:PIN]OPENUM;[F:PIN]OPESPLNUM
&                      As [LNK]
&                      Where [PIN]MFGNUM=[F:MFG]MFGNUM
For [LNK]
    If find([PIN]PINTYP,1,2)<>0
        Read [MFO]MFO0 =
        Raz [F:MFO]FRCSTRDAT, [F:MFO]FRCSTRHOU
        Rewrite [MFO]
        If fstat : GOK=0 : Endif
    Endif
    Delete [PIN] =
    If fstat : GOK=0 : Endif
    If GOK=0 : Break : Endif
Next

If LTRANS=1
    If GOK=1
        Commit
    Else
        Rollback
    Endif
Endif
End

