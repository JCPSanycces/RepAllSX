## Section automatically added (screen HRBAN1) 05/18/2017 09:26:28 (HEGES)
######################################################################################
Subprog AV_SRTCOD(VALEUR)
Variable Char    VALEUR()
End

Subprog C_SRTCOD(VALEUR)
Variable Char    VALEUR()

#HEGES - 2017-06-06 - X3-43776- START
#HEGES - 2017-06-20 - X3-45409- START
Local Char LEG
Filter [CPY] Where CPY = [M:HRBAN2]CPY
Read [CPY] First
If !fstat
 LEG = [F:CPY]LEG
Endif
Filter [CPY]
If VALEUR <> ""
Local Char SUBSTR, SUBCHR
  For I = 0 To len(VALEUR)
    SUBCHR = mid$ (VALEUR,I,1)
    If SUBCHR <> '-'
      SUBSTR += SUBCHR
    Endif
  Next I
  If len(SUBSTR) > 0 Then
    If len(SUBSTR) > 6 | len(SUBSTR) < 6 Then
      GERR=1
      GMESSAGE = mess(00013,11800,1)
      mkstat=2 : End
    Endif
  Else
    VALEUR = ""
  Endif
Else
  If LEG = "BRI"
    GERR=1
    GMESSAGE = mess(00013,11800,1)
    mkstat=2 : End
  Endif
Endif
#HEGES - 2017-06-20 - X3-45409- END
#HEGES - 2017-06-06 - X3-43776- END
End

Subprog AM_SRTCOD(VALEUR)
Variable Char    VALEUR()
Local Char FTWO(5), STWO(5), STR(8)
FTWO = left$(VALEUR,2) : FTWO = FTWO+"-"
STWO = right$(left$(VALEUR,4),3) : STWO = STWO+"-"
STR = FTWO+STWO+right$(VALEUR,5)

VALEUR = STR
If VALEUR = "--" : VALEUR = "" : Endif
Affzo [M:HRBAN1]SRTCOD(nolign-1)

End


