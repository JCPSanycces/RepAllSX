Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  Call FIND_COA(VALEUR)
  Call ALTER_FIELDS(VALEUR)
End

Subprog ALTER_FIELDS(VALCPY)
Value    Char VALCPY()
Local Char LEG
Filter [CPY] Where CPY = VALCPY
Read [CPY] First
If !fstat
 LEG = [F:CPY]LEG
Endif
Filter [CPY]
#HEGES - 2017-06-06 - X3-43654- START
If LEG <> 'BRI'
  If dim([M:HRBAN1]TRECOD)>0  : Chgfmt [M:HRBAN1]TRECOD   With "+A:12X"     : Endif
  If dim([M:HRBAN1]SENNUM)>0  : Chgfmt [M:HRBAN1]SENNUM   With "+A:10X"     : Endif
  If dim([M:HRBAN1]PAB1)>0    : Chgfmt [M:HRBAN1]PAB1     With "+A:30X"     : Endif
  If dim([M:HRBAN1]PAB2)>0    : Chgfmt [M:HRBAN1]PAB2     With "+A:30X"     : Endif
  If dim([M:HRBAN1]ROLLNUM)>0 : Chgfmt [M:HRBAN1]ROLLNUM  With "-A:30X"     : Endif
  If dim([M:HRBAN1]SRTCOD)>0  : Chgfmt [M:HRBAN1]SRTCOD   With "-A:8X"     : Endif
  If dim([M:HRBAN1]BACS)>0    : Chgfmt [M:HRBAN1]BACS     With "-A:30X"     : Endif
  If dim([M:HRBAN1]SUN)>0    : Chgfmt [M:HRBAN1]SUN     With "-A:6X"     : Endif
  If dim([M:HRBAN1]HMRC)>0    : Chgfmt [M:HRBAN1]HMRC     With "-M:4X"     : Endif
Else
  If dim([M:HRBAN1]TRECOD)>0  : Chgfmt [M:HRBAN1]TRECOD   With "-A:12X"     : Endif
  If dim([M:HRBAN1]SENNUM)>0  : Chgfmt [M:HRBAN1]SENNUM   With "-A:10X"     : Endif
  If dim([M:HRBAN1]PAB1)>0    : Chgfmt [M:HRBAN1]PAB1     With "-A:30X"     : Endif
  If dim([M:HRBAN1]PAB2)>0    : Chgfmt [M:HRBAN1]PAB2     With "-A:30X"     : Endif
  If dim([M:HRBAN1]ROLLNUM)>0 : Chgfmt [M:HRBAN1]ROLLNUM  With "+A:30X"     : Endif
  If dim([M:HRBAN1]SRTCOD)>0  : Chgfmt [M:HRBAN1]SRTCOD   With "+A:8X"     : Endif
  If dim([M:HRBAN1]BACS)>0    : Chgfmt [M:HRBAN1]BACS     With "+A:30X"     : Endif
  If dim([M:HRBAN1]SUN)>0    : Chgfmt [M:HRBAN1]SUN     With "+A:6X"     : Endif
  If dim([M:HRBAN1]HMRC)>0    : Chgfmt [M:HRBAN1]HMRC     With "+M:4X"     : Endif
Endif
#HEGES - 2017-06-06 - X3-43654- END
#MIPEA - 2017-07-07- US X3-47284- START
If GFONCTION = "GESHRBAN"
  Affzo [M:HRBAN1]
Endif
#Affzo [M:HRBAN1]
#MIPEA - 2017-07-07- US X3-47284- END
End

Subprog FIND_COA(CPY)
Value    Char CPY()
Local    Integer I

  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
  If clalev([F:GCM])=0 : Local File =GTABCPT+"GACM"  [GCM] : Endif
  If clalev([F:LED])=0 : Local File =GTABCPT+"GLED"  [LED] : Endif

  Call LEC_CPY(CPY) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC

  [M]COA=""
  For I=0 To dim([F:GCM]LED)-1
    Call LEC_LED([F:GCM]LED(I)) From CPTLEC
    If [F:LED]GEN=2 Then
      [M]COA=[F:LED]COA
      Break
    Endif
  Next
End

Subprog AM_BANACC(VALEUR)
Variable Char    VALEUR()

  Call LECTEXTRA([M]BANACCDES, "GACCOUNT","DESTRA", [M]COA,VALEUR) From ATEXTRA
End

Subprog C_FILEXT(VALEUR)
Variable Char    VALEUR()
#If len([M]BAN)>3 and VALEUR="" : GMESSAGE=mess(10,123,1) : mkstat=2 : Endif : # Zone obligatoire
End


