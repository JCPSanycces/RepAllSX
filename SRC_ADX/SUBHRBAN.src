#DIRAS - JIRA X3-24128 - 2017/02/14 - START
Call OBJET("HRBAN",GBIDC1,GBIDC2) From GOBJET
#Call OBJET("BAN",GBIDC1,GBIDC2) From GOBJET
#DIRAS - JIRA X3-24128 - 2017/02/14 - END
End

$ACTION
Case ACTION
 When "FILTRE"
  FILTSUP = "[F:BAN]BANCSH=1"
 When "OUVRE"      : Gosub OUVRE     :#92876-US2590
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "LIENS"      : Gosub LIENS
 When "STYLE"      : Gosub STYLE
Endcase
Return

$STYLE
Call ALTER_FIELDS([M:HRBAN2]CPY)
Return

$OUVRE
  #DIRAS - JIRA X3-24128 - 2017/02/14 - START
  If clalev([F:HRBAN2])=0 : Local File BANK [BAN2] : Endif
  #If clalev([F:BAN2])=0 : Local File BANK [BAN2] : Endif
  #DIRAS - JIRA X3-24128 - 2017/02/14 - END

  #92876-US2590
  If clalev([F:CAC])=0 : Local File GACCCODE        [CAC] : Endif
    If clalev([F:COA])=0 : Local File =GTABCPT+"GCOA"  [COA]  : Endif
Return

$VERIF_CRE
Read [F:BAN2]BAN0=[M]BAN
If !fstat
 #Banque /caisse : Code déjà éxistant !
 GMESSAGE = mess(453,200,1)-":"-mess(33,137,1)
 OK=0 : Return
Endif
Return

###########################################
## Etiquette des écrans BAN0, BAN1, BAN2 ##
###########################################

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If VALEUR="" & [M]CPY<>""
 Call CONTALLFCY([M]CPY) From CPTSUB
Endif
End

Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Call LECMAINPLAN(1,[F:FCY]LEGCPY,[M]COA) From CPTDIV
If VALEUR<>"" : Call GETSOC(VALEUR) From DEVSUB : Endif
End

Subprog AM_FCY(VALEUR)
Variable Char     VALEUR
[M]CPY = ""
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]FCY<>""
 VALEUR = [F:FCY]LEGCPY
 Call FIND_COA(VALEUR)
 mkstat = 2
Else
 Call CONTACCCFY(VALEUR,"") From CFYSUB : # Accès refusé si pas accès à tous les sites de la société
Endif
End

Subprog C_CPY(VALEUR)
Variable Char     VALEUR
Call CONTALLFCY(VALEUR) From CPTSUB

#MIPEA - 2017-02-27- X3-12041- START
Call LEC_GAC([M]BANACC,[M]COA) From CPTLEC
 If [F:GAC]CUR<>""
  [M]CUR = [F:GAC]CUR
 Else
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  [M]CUR = [F:CPY]ACCCUR
 Endif

Affzo [M]CUR
#MIPEA - 2017-02-27- X3-12041- END

End

Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
#92876-2689
#If [M]BANACC<>""
# Call LECTURE("GAC",[M]BANACC,"") From CONTOBJ
If [M]BANACC<>"" & [M]COA<>""
 Call LEC_GAC([M]BANACC,[M]COA) From CPTLEC
 If [F:GAC]CUR<>""
  VALEUR = [F:GAC]CUR
 Else
  Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
  VALEUR = [F:CPY]ACCCUR
 Endif
 mkstat=2
Endif
End

Subprog AS_CHGTYP(VALEUR)
Variable Integer  VALEUR
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [M]CUR = [F:CPY]ACCCUR
 mkstat=1
Endif
End

Subprog AM_BAN(VALEUR)
Variable Char    VALEUR()
Read [BAN2]BAN0=VALEUR
If fstat=0 & [F:BAN2]BANCSH=2  :# Caisse
 GMESSAGE=mess(2,653,1)
 mkstat=2
Endif
End

Subprog C_JOU(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & GDOSCPT<>""
 Local File =GTABCPT+"GJOURNAL" [JOU]
 #92876
 Read [JOU]JOU0=VALEUR;GDOSLEG
 If fstat
  Read [JOU]JOU0=VALEUR;""
  If fstat
    GMESSAGE = mess(53,141,1) : # Journal non défini
    mkstat = 2
  Endif
 Endif
 #end 92876
Endif
End

Subprog AS_IBACOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]BIDNUM<>"" & [M]CRY<>""
 Call CRE_IBAN(VALEUR,[M]CRY,"",[M]BIDNUM) From SUBBID
Endif
End

Subprog C_IBACOD(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR<>""
 Call C_IBACOD(VALEUR) From SUBBID
Endif
End
