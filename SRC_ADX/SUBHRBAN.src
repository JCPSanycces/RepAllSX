Subprog AM_BIDNUM(VALEUR)
Variable Char    VALEUR()

Filter [F:CPY] Where CPY=[M:HRBAN2]CPY
Read [F:CPY]CPY0 First
If fstat=0
  If [F:CPY]LEG = 'BRI' and len(VALEUR) > 8
    GERR=1
    GMESSAGE = mess(00076,00126,1) + " 8"
    mkstat=2 : End
  Endif
Endif
Filter [F:CPY]
End


