#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe OPPOR
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER                     From OPPOR_CSTD_EVENTS
       #When "AREAD"                   : Gosub AREAD                           From OPPOR_CSTD_EVENTs        # track for optimization if necessary
        When "ACONTROL"                : Gosub ACONTROL                        From OPPOR_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From OPPOR_CSTD_EVENTS
        When "AINSERT_AFTER"           : Gosub AINSERT_AFTER                   From OPPOR_CSTD_EVENTS
        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER                   From OPPOR_CSTD_EVENTS
        When "ADELETE_CONTROL_AFTER"   : Gosub ADELETE_CONTROL_AFTER           From OPPOR_CSTD_EVENTS
        When "ADELETE_AFTER"           : Gosub ADELETE_AFTER                   From OPPOR_CSTD_EVENTS
      Endcase
    When "CRM"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub CRM_ACONTROL                    From OPPOR_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub CRM_ADDLINE_AFTER               From OPPOR_CSTD_EVENTS
      Endcase
    When "CRM.STPSTB"
      Case [L]AEVENT
        When "ADELLINE_BEFORE"         : Gosub CRM_STPSTB_ADELLINE_BEFORE      From OPPOR_CSTD_EVENTS
      Endcase
    When "PJM"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub PJM_ACONTROL                    From OPPOR_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub PJM_ADDLINE_BEFORE              From OPPOR_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub PJM_ADDLINE_AFTER               From OPPOR_CSTD_EVENTS
      Endcase
    When "CPP"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub CPP_ACONTROL                    From OPPOR_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub CPP_ADDLINE_AFTER               From OPPOR_CSTD_EVENTS
        When "AREAD_AFTER"             : Gosub CPP_AREAD_AFTER                 From OPPOR_CSTD_EVENTS
      Endcase
    When "PIMPL"
      Case [L]AEVENT
        When "ACONTROL"                : Gosub PIMPL_ACONTROL                  From OPPOR_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD   # Méthodes communes
    When "SETERROR"                : Gosub SETERROR                        From OPPOR_CSTD_METHODS
    When "RESET_ERRORS"            : Gosub RESET_ERRORS                    From OPPOR_CSTD_METHODS           # Issue X3-96497 - 2018-06-28 by FGR
    When "COM_MANAGE_LCM_CREATE"   : Gosub COM_MANAGE_LCM_CREATE           From OPPOR_CSTD_METHODS_COM
    When "COM_MANAGE_LCM_UPDATE"   : Gosub COM_MANAGE_LCM_UPDATE           From OPPOR_CSTD_METHODS_COM
    When "COM_MANAGE_LCM_DELETE"   : Gosub COM_MANAGE_LCM_DELETE           From OPPOR_CSTD_METHODS_COM
    When "COM_PROMOTE_CRM"         : Gosub COM_PROMOTE_CRM                 From OPPOR_CSTD_METHODS_COM
    When "COM_PROMOTE_PJM"         : Gosub COM_PROMOTE_PJM                 From OPPOR_CSTD_METHODS_COM
    When "COM_IS_CRM_OPPOR"        : Gosub COM_IS_CRM_OPPOR                From OPPOR_CSTD_METHODS_COM
    When "COM_IS_PJM_OPPOR"        : Gosub COM_IS_PJM_OPPOR                From OPPOR_CSTD_METHODS_COM
    When "COM_LOAD_OPPMCNNAM"      : Gosub COM_LOAD_OPPMCNNAM              From OPPOR_CSTD_METHODS_COM       # Issue X3-80586 - 2018-04-11 by FGR
                    # Méthodes CRM
    When "CRM_RESET_ERRORS"        : Gosub CRM_RESET_ERRORS                From OPPOR_CSTD_METHODS_CRM       # Issue X3-96497 - 2018-06-28 by FGR
    When "CRM_INIT_TECH_PROP"      : Gosub CRM_INIT_TECH_PROP              From OPPOR_CSTD_METHODS_CRM
    When "CRM_INIT_OPPOR_FROM_SRE" : Gosub CRM_INIT_OPPOR_FROM_SRE         From OPPOR_CSTD_METHODS_CRM
    When "_CRM_ADD_STEPB"          : Gosub _CRM_ADD_STEPB                  From OPPOR_CSTD_METHODS_CRM
    When "_CRM_ADD_STEPB_DATA"     : Gosub _CRM_ADD_STEPB_DATA             From OPPOR_CSTD_METHODS_CRM
    When "_CRM_DEL_STEPB"          : Gosub _CRM_DEL_STEPB                  From OPPOR_CSTD_METHODS_CRM
                    # Méthodes PJM
    When "PJM_PROPAGATE_TECH_PROP" : Gosub PJM_PROPAGATE_TECH_PROP         From OPPOR_CSTD_METHODS_PJM
    When "PJM_RESET_ERRORS"        : Gosub PJM_RESET_ERRORS                From OPPOR_CSTD_METHODS_PJM
    When "PJM_INIT_TECH_PROP"      : Gosub PJM_INIT_TECH_PROP              From OPPOR_CSTD_METHODS_PJM
    When "PJM_COPY"                : Gosub PJM_COPY                        From OPPOR_CSTD_METHODS_PJM
    When "_PJM_COPY"               : Gosub _PJM_COPY                       From OPPOR_CSTD_METHODS_PJM
    When "PJM_COPY_LOAD_PROPERTIES": Gosub PJM_COPY_LOAD_PROPERTIES        From OPPOR_CSTD_METHODS_PJM
                    # Methods CPP
    When "CPP_GET_INDEX"           : Gosub CPP_GET_INDEX                   From OPPOR_CSTD_METHODS
                    # Methods SBB
    When "SBB_GET_INDEX"           : Gosub SBB_GET_INDEX                   From OPPOR_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION    # CRM
    When "CRM_ADD_STEPB"                    : Gosub CRM_ADD_STEPB                   From OPPOR_CSTD_OPERATIONS_CRM
    When "CRM_DEL_STEPB"                    : Gosub CRM_DEL_STEPB                   From OPPOR_CSTD_OPERATIONS_CRM
                        # PJM
    # Tools
    When "PJM_KEY_SPLIT"                    : Gosub PJM_KEY_SPLIT                   From OPPOR_CSTD_OPERATIONS_PJM
    # Project
    When "PJM_PROJECT_LAUNCH"               : Gosub PJM_PROJECT_LAUNCH              From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_PROJECT_DELIVERY"             : Gosub PJM_PROJECT_DELIVERY            From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_PROJECT_CLOSING"              : Gosub PJM_PROJECT_CLOSING             From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_PROJECT_SUSPENSION"           : Gosub PJM_PROJECT_SUSPENSION          From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_PROJECT_REACTIVATE"           : Gosub PJM_PROJECT_REACTIVATE          From OPPOR_CSTD_OPERATIONS_PJM
    # Budgets
    When "PJM_BUDGET_AUTOMATION"            : Gosub PJM_BUDGET_AUTOMATION           From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_BUDGET_DELIVERY"              : Gosub PJM_BUDGET_DELIVERY             From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_BUDGET_CLOSING"               : Gosub PJM_BUDGET_CLOSING              From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_BUDGET_SUSPENSION"            : Gosub PJM_BUDGET_SUSPENSION           From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_BUDGET_REACTIVATE"            : Gosub PJM_BUDGET_REACTIVATE           From OPPOR_CSTD_OPERATIONS_PJM
    # Tasks
    When "PJM_TASK_PLANNED"                 : Gosub PJM_TASK_PLANNED                From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_LAUNCH"                  : Gosub PJM_TASK_LAUNCH                 From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_CLOSING"                 : Gosub PJM_TASK_CLOSING                From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_SUSPENSION"              : Gosub PJM_TASK_SUSPENSION             From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_REACTIVATE"              : Gosub PJM_TASK_REACTIVATE             From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_TIMEENTRY"               : Gosub PJM_TASK_TIMEENTRY              From OPPOR_CSTD_OPERATIONS_PJM
    # Tasks - Operation
    When "PJM_TASK_RTKO_CLOSING"            : Gosub PJM_TASK_RTKO_CLOSING           From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_RTKO_SUSPENSION"         : Gosub PJM_TASK_RTKO_SUSPENSION        From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_RTKO_REACTIVATE"         : Gosub PJM_TASK_RTKO_REACTIVATE        From OPPOR_CSTD_OPERATIONS_PJM
    # Tasks - Products
    When "PJM_TASK_RITT_SOQQTY"             : Gosub PJM_TASK_RITT_SOQQTY            From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_TASK_RITT_ALLOCATION"         : Gosub PJM_TASK_RITT_ALLOCATION        From OPPOR_CSTD_OPERATIONS_PJM
    # Sellable Products Automation
    When "PJM_SPLD_AUTOMATION"              : Gosub PJM_SPLD_AUTOMATION             From OPPOR_CSTD_OPERATIONS_PJM
    When "PJM_SPLD_SOLD"                    : Gosub PJM_SPLD_SOLD                   From OPPOR_CSTD_OPERATIONS_PJM
                        # COMMON
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "TCHIMPORT"                   : Gosub TCHIMPORT                       From OPPOR_CSTD_PROPERTIES
    When "TCHMODULE"                   : Gosub TCHMODULE                       From OPPOR_CSTD_PROPERTIES
    When "TCHTOREAD"                   : Gosub TCHTOREAD                       From OPPOR_CSTD_PROPERTIES
    When "TCHISPJM"                    : Gosub TCHISPJM                        From OPPOR_CSTD_PROPERTIES
    When "OPPNUM"                      : Gosub OPPNUM                          From OPPOR_CSTD_PROPERTIES
    When "SALFCY"                      : Gosub SALFCY                          From OPPOR_CSTD_PROPERTIES
    When "CPY"                         : Gosub CPY                             From OPPOR_CSTD_PROPERTIES
    When "CUR"                         : Gosub CUR                             From OPPOR_CSTD_PROPERTIES
    When "OPPCMP"                      : Gosub OPPCMP                          From OPPOR_CSTD_PROPERTIES
    When "OPPMCN"                      : Gosub OPPMCN                          From OPPOR_CSTD_PROPERTIES
    When "CHGTYP"                      : Gosub CHGTYP                          From OPPOR_CSTD_PROPERTIES
    When "OPPCLO"                      : Gosub OPPCLO                          From OPPOR_CSTD_PROPERTIES
    When "OPPTYP"                      : Gosub OPPTYP                          From OPPOR_CSTD_PROPERTIES
    When "OPPREP"                      : Gosub OPPREP                          From OPPOR_CSTD_PROPERTIES
    When "OPPDATOPN"                   : Gosub OPPDATOPN                       From OPPOR_CSTD_PROPERTIES
    When "OPPORI"                      : Gosub OPPORI                          From OPPOR_CSTD_PROPERTIES
    When "OPPORITYP"                   : Gosub OPPORITYP                       From OPPOR_CSTD_PROPERTIES
    #
    When "PJM.OPPSTATE"                : Gosub PJM_OPPSTATE                    From OPPOR_CSTD_PROPERTIES    # Issue X3-107401 - 2018-09-06 by FGR
  Endcase
Return

