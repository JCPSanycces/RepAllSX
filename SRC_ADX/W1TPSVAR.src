#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TPSVAR 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:51"
A_USER  = "DOC"
A_STAMP = "20181109230651"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TPSVAR [TPV]
Gosub HORODAT
Local Inpbox "TPSVAR" From GFONCTION At A_STAMP With A_WINDPREV Mask [TPV] As [SIM_]
Grizo [TPV]5
Grizo [TPV]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TPV]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=112 : Y1(1)=3 : Y2(1)=28
Return

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1TPSVAR
Onevent CONTROL Call C_LEG(zc) From W1TPSVAR
Onevent AFTER_CHANGE Gosub AMM_LEG From W1TPSVAR
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1TPSVAR
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1TPSVAR
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1TPSVAR
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1TPSVAR
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1TPSVAR
If VALEUR="" : Call INIADI(VALEUR,"909") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"909","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"909",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From MAJVAR
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1TPSVAR
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_VARCOD
Onevent CONTROL Call C_VARCOD(zc) From W1TPSVAR
Onevent BEFORE_INPUT Call AS_VARCOD(zc) From W1TPSVAR
Return

Subprog AS_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(124,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_VARCOD(zc) From W1TPSVAR
Onkey   2 Titled GBOUTS Call S_VARCOD(zc) From W1TPSVAR
Onkey 144 Titled GBOUTP Call P_VARCOD(zc) From W1TPSVAR
Onkey 146 Titled GBOUTA Call SA_VARCOD(zc) From W1TPSVAR
Gosub _AFF
End

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
If !mkstat
 ## Action CONTVRA
 Call CONTVRA(VALEUR) From SUBVRA
 If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
  If !mkstat
   ## Action STD
   Call C_VARCOD(VALEUR) From MAJVAR
   If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "VRA"
PARMSK(2) = "P"
PARMSK(3) = num$(GCURLEG)
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_VARCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("VRA",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "VRA"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("VRA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_TYPMAJ
Onevent BEFORE_INPUT Call AS_TYPMAJ(zc) From W1TPSVAR
Onevent CONTROL Call C_TYPMAJ(zc) From W1TPSVAR
Onevent INIT_AREA Call D_TYPMAJ(zc) From W1TPSVAR
Return

Subprog D_TYPMAJ(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPMAJ,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPMAJ(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_TYPMAJ(VALEUR) From MAJVAR
If mkstat=2
 [M]TYPMAJ(INDIC) = VALEUR
 Affzo TYPMAJ(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TYPMAJ(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_TYPMAJ(VALEUR) From MAJVAR
If mkstat : GERR = 1 : GZONE = "TYPMAJ" : GZNUM = 3770 : Endif
Gosub _AFF
End

