$ON_FORVAR
Onevent BEFORE_INPUT Call AS_FORVAR(zc) From W1TPSVAR
Onevent CONTROL Call C_FORVAR(zc) From W1TPSVAR
Return

Subprog IB_FORVAR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call IB_FORVAR From MAJVAR
Gosub _AFF
End

Subprog AS_FORVAR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
Call TEXTE(5620,GBOUT4) From OBJDIV
Call IB_FORVAR(VALEUR)
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]FORVAR(INDIC) = VALEUR
  Affzo FORVAR(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_FORVAR(zc) From W1TPSVAR
Onkey 130 Titled GBOUT2 Call B2_FORVAR(zc) From W1TPSVAR
Onkey 131 Titled GBOUT3 Call B3_FORVAR(zc) From W1TPSVAR
Onkey 132 Titled GBOUT4 Call B4_FORVAR(zc) From W1TPSVAR
Gosub _AFF
End

Subprog C_FORVAR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FORVAR" : GZNUM = 4574 : Endif
If !GWEBSERV
 If !mkstat
  ## Action AFRCONT
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "AFRCONT"
  PARMSK(1) = ""
  Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FORVAR" : GZNUM = 4574 : Endif
 Endif
Endif
If !mkstat
 ## Action STD
 Call C_FORVAR(VALEUR) From MAJVAR
 If mkstat : GERR = 1 : GZONE = "FORVAR" : GZNUM = 4574 : Endif
Endif
Gosub _AFF
End

Subprog B1_FORVAR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"","","","","") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_FORVAR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
 Call AFFMESS From AFORMULE
