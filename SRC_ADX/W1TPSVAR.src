Call AS_TIMVAR(VALEUR) From MAJVAR
If mkstat=2
 [M]TIMVAR(INDIC) = VALEUR
 Affzo TIMVAR(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_TIMVAR(zc) From W1TPSVAR
Gosub _AFF
End

Subprog C_TIMVAR(VALEUR)
