#<AdxTL>@(#)1.0.0.0 $Revision$
# Issue X3-59028 - 2018-04-18 by CBO : Changes of accounting task for mindo


Local Char PARAM(30)(1..2) , VALEUR(30)
PARAM(1)= "ODG"
PARAM(2)= "GBA200600000516"
Call SAISIE_CHAR(VALEUR,PARAM,"GACCAB","TRTGACCAB","") From GSAISIE
End

#-------------------------------------------------------------------------------------
$ACTION
 Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "TERMINE"     : Gosub TERMINE
  When Default
 Endcase
Return

#-------------------------------------------------------------------------------------
$OUVRE
 Local Char    LTYP
 Local Char    LNUM
 Local Integer LREF
 Local Integer I_LIGNE, I_CCE, LNBLIGANA
 Local Decimal TOTDEB
 Local Decimal TOTCDT

 LTYP    = PARAM(1)
 LNUM    = PARAM(2)
 LREF    = val(PARAM(3))

 Global Char    GLIBDEFTAB(30)
 Global Integer GCPTBAT
 Global Integer GTMPTAB          : GTMPTAB=1

 If GTABCPT=""
  GLIBDEFTAB=mess(111,7778,1)
 Else
  GLIBDEFTAB=mess(109,7778,1)
 Endif

# Issue 59028
# If GTABCPT<>""
#  Local Char GTABCPTX3 : GTABCPTX3=left$(GTABCPT,instr(1,GTABCPT,"@"))+"X3."
#  If !clalev([F:ABT]) : Local File =GTABCPTX3+"ABATRQT" [ABT] : Endif
#  Filter [F:ABT]Where FLAG=2 & TACHE="ACCBATCH"
#  Read [F:ABT]First
#  If fstat
#   GCPTBAT = 0
#  Else
#   GCPTBAT = 1
#  Endif
#  Filter [F:ABT]
# Endif

Local Integer WTSK_STA_IS_STOPPED
Call PRESENCE(WTSK_STA_IS_STOPPED) From CPTBATCH
If WTSK_STA_IS_STOPPED
  GCPTBAT = 0
Else
  GCPTBAT = 1
Endif
# End issue 59028
Return

#-------------------------------------------------------------------------------------
$DEBUT
 If LREF=2 : Gosub LOAD_PCG_PCE : Endif
 If LREF=3 : Gosub LOAD_IAS_PCE : Endif
Return

#-------------------------------------------------------------------------------------
$LOAD_PCG_PCE

 If clalev([F:HAT])  : Close Local File [F:HAT] : Endif
 If clalev([F:DAT])  : Close Local File [F:DAT] : Endif
 If clalev([F:DAA])  : Close Local File [F:DAA] : Endif
 If !clalev([F:HAT]) : Local File =GTABCPT+"GACCTMP"  [HAT] : Endif
 If !clalev([F:DAT]) : Local File =GTABCPT+"GACCTMPD" [DAT] : Endif
 If !clalev([F:DAA]) : Local File =GTABCPT+"GACCTMPA" [DAA] : Endif

 Read [F:HAT]HAT0=LTYP;LNUM
 If fstat=5 #& GTABCPT<>""
  If clalev([F:HAT])  : Close Local File [F:HAT] : Endif
  If clalev([F:DAT])  : Close Local File [F:DAT] : Endif
  If clalev([F:DAA])  : Close Local File [F:DAA] : Endif
  If !clalev([F:HAT]) : Local File =GTABCPT+"GACCENTRY"   [HAT] : Endif
  If !clalev([F:DAT]) : Local File =GTABCPT+"GACCENTRYD"  [DAT] : Endif
  If !clalev([F:DAA]) : Local File =GTABCPT+"GACCENTRYA"  [DAA] : Endif
  Read [F:HAT]HAE0=LTYP;LNUM
  If !fstat
   GTMPTAB=0
  Endif
 Else
  If [F:HAT]EXPNUM=[C]EXPORT
   GTMPTAB=0
  Endif
 Endif

 If !fstat
  [M:HAE0]=[F:HAT]

  #CHECK IGNORE_BEGIN
  If GTMPTAB=1
   [M:HAE0]TMPTAB="128"
   [M:HAE0]DEFTAB="127"
  Else
   [M:HAE0]TMPTAB="128"
   [M:HAE0]DEFTAB="128"
  Endif

# If GTABCPT<>""
   If GCPTBAT
    [M:HAE0]CPTBAT = mess(113,7778,1) #"Tâche comptable active"
   Else
    [M:HAE0]CPTBAT = mess(114,7778,1) #"Tâche comptable inactive"
   Endif
# Endif
  #CHECK IGNORE_END

  [M:HAE1]=[F:HAT]
  [M:HAE2]=[F:HAT]
  For [F:DAT] Where TYP=[F:HAT]TYP & NUM=[F:HAT]NUM & LED="FRA" & LEDTYP=1
   I_LIGNE+=1
   nolign = I_LIGNE
   [M:HAE2]=[F:DAT]
   If [F:DAT]SNS>0
    [M:HAE2]DEB(nolign-1)=[F:DAT]AMTCUR : TOTDEB += [F:DAT]AMTCUR
   Else
    [M:HAE2]CDT(nolign-1)=[F:DAT]AMTCUR : TOTCDT += [F:DAT]AMTCUR
   Endif
   Filter [F:DAA] Where TYP=[F:DAT]TYP & NUM=[F:DAT]NUM & LIN=[F:DAT]LIN
   LNBLIGANA=rowcount([F:DAA])
   If LNBLIGANA=1
    For [F:DAA]
     For I_CCE=1 To GOPTCANA
      Case I_CCE
       When 1 : [M:HAE2]CCE1(nolign-1)=[F:DAA]CCE(0)
       When 2 : [M:HAE2]CCE2(nolign-1)=[F:DAA]CCE(1)
       When 3 : [M:HAE2]CCE3(nolign-1)=[F:DAA]CCE(2)
       When 4 : [M:HAE2]CCE4(nolign-1)=[F:DAA]CCE(3)
       When 5 : [M:HAE2]CCE5(nolign-1)=[F:DAA]CCE(4)
       When 6 : [M:HAE2]CCE6(nolign-1)=[F:DAA]CCE(5)
       When 7 : [M:HAE2]CCE7(nolign-1)=[F:DAA]CCE(6)
       When 8 : [M:HAE2]CCE8(nolign-1)=[F:DAA]CCE(7)
       When 9 : [M:HAE2]CCE9(nolign-1)=[F:DAA]CCE(8)
      Endcase
     Next I_CEE
    Next
   Elsif LNBLIGANA>1 | [M:HAE2]DSP(nolign-1)<>""
    [M:HAE2]CCE1(nolign-1)="$"
   Endif
   Filter [F:DAA]
  Next
  [M:HAE2]NBLIG=I_LIGNE
 Endif
 [M:HAE2]TOTDEB = TOTDEB
 [M:HAE2]TOTCDT = TOTCDT
 [M:HAE2]SOLDE  = TOTDEB-TOTCDT

 Affzo [M:HAE0]
 Affzo [M:HAE1]
 Affzo [M:HAE2]

Return

#-------------------------------------------------------------------------------------
$LOAD_IAS_PCE

 If clalev([F:HIA])  : Close Local File [F:HIA] : Endif
 If clalev([F:DIA])  : Close Local File [F:DIA] : Endif
 If !clalev([F:HIA]) : Local File =GTABCPT+"GACIASTMP"  [HIA] : Endif
 If !clalev([F:DIA]) : Local File =GTABCPT+"GACIASTMPD" [DIA] : Endif

 Read [F:HIA]HIT0=LTYP;LNUM
 If fstat=5 & GTABCPT<>""
  If clalev([F:HIA])  : Close Local File [F:HIA] : Endif
  If clalev([F:DIA])  : Close Local File [F:DIA] : Endif
  If !clalev([F:HIA]) : Local File =GTABCPT+"GACEIAS"   [HIA] : Endif
  If !clalev([F:DIA]) : Local File =GTABCPT+"GACEIASD"  [DIA] : Endif
  Read [F:HIA]HIA0=LTYP;LNUM
  If !fstat
   GTMPTAB=0
  Endif
 Else
  If 1=1 #[F:HIA]EXPNUM=[C]EXPNUM
   GTMPTAB=0
  Endif
 Endif

 If !fstat
  [M:HIA0]=[F:HIA]

  If GTMPTAB=1
   [M:HIA0]TMPTAB="128"
   [M:HIA0]DEFTAB="127"
  Else
   [M:HIA0]TMPTAB="127"
   [M:HIA0]DEFTAB="128"
  Endif

  If GTABCPT<>""
   If GCPTBAT
    [M:HIA0]CPTBAT = mess(113,7778,1) #"Tâche comptable active"
   Else
    [M:HIA0]CPTBAT = mess(114,7778,1) #"Tâche comptable inactive"
   Endif
  Endif

  [M:HIA1]=[F:HIA]

  For [F:DIA] Where TYP=[F:HIA]TYP & NUM=[F:HIA]NUM
   I_LIGNE+=1
   nolign = I_LIGNE
   [M:HIA1]=[F:DIA]
   If [F:DIA]SNS>0
    [M:HIA1]DEB(nolign-1)=[F:DIA]AMTLOC : TOTDEB += [F:DIA]AMTLOC
   Else
    [M:HIA1]CDT(nolign-1)=[F:DIA]AMTLOC : TOTCDT += [F:DIA]AMTLOC
   Endif
  Next
  [M:HIA1]NBLIG=I_LIGNE
 Endif
 [M:HIA1]TOTDEB = TOTDEB
 [M:HIA1]TOTCDT = TOTCDT

 Affzo [M:HIA0]
 Affzo [M:HIA1]

Return

$TERMINE
 If dim(GLIBDEFTAB)>0 : Kill GLIBDEFTAB : Endif
 If dim(GCPTBAT)>0    : Kill GCPTBAT    : Endif
 If dim(GTMPTAB)>0    : Kill GTMPTAB    : Endif
Return

######################################################################################
## Gestion de l'écran GACCAB0
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran GACCAB2) 11/03/2008 09:18:57 (GBO)
######################################################################################
Subprog AS_NBLIG
 If [M:HAE2]CCE1(nolign-1)<>"$"
  GBOUT1=""
 Endif
End


######################################################################################

