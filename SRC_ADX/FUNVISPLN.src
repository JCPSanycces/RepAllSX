################################################################################
#    VISU PLAN D'AMORTISSEMENT
#    FGR
#    Création le : 03/09/2003
#    Modification le : 05/05/2004
################################################################################
################################################################################
# Mon petit bazar jusqu'à ce que je le connaisse par coeur
#     Infbox "ligne = "-num$(nolign)
#     Dbgaff
################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION
  #Infbox "ACTION="-num$(ACTION)
  Case ACTION
    When "DEBUT"          : Gosub DEBUT
    When "FIN"            : Gosub FIN
    When "AVANT_BOUTON"   : Gosub AVANT_BOUTON       : # Controle bouton
    When "BOUTON"         : Gosub BOUTON             : # Exécution bouton
  Endcase
Return

################################################################################
#-------------------------------------------------------------------------------
$DEBUT
# --------------------------
# Création des tableaux contenant les résultats de calcul
Global Integer GVP_EXOPER              : # Calcul exercice ou périodique
Global Integer GVP_NBLIGN1             : # Nombre de lignes à afficher 1
Global Integer GVP_CNX1                : # Contexte 1
Global Integer GVP_PLN1                : # Plan 1
Global Date GVP_DATFIY1(GMXYEAVISU)    : # Date Exercice 1
Global Date GVP_DATPER1(GMXYEAVISU)    : # Date Période 1
Global Decimal GVP_MNTBAS1(GMXYEAVISU) : # Montant base 1
Global Decimal GVP_MNTCUM1(GMXYEAVISU) : # Montant cumul 1
Global Decimal GVP_MNTDOT1(GMXYEAVISU) : # Montant dotation 1
Global Decimal GVP_SOLIML1(GMXYEAVISU) : # Solde dépréciation 1
Global Decimal GVP_MNTIML1(GMXYEAVISU) : # Dépréciation 1
Global Decimal GVP_IMLRVE1(GMXYEAVISU) : # Reprise 1
Global Decimal GVP_VNEEND1(GMXYEAVISU) : # Valeur nette fin 1
Global Decimal GVP_EXCDPR1(GMXYEAVISU) : # Amortissement exceptionnel (ou anticipato si mode IT)

Global Integer GVP_NBLIGN2             : # Nombre de lignes à afficher 2
Global Integer GVP_CNX2                : # Contexte 2
Global Integer GVP_PLN2                : # Plan 2
Global Date GVP_DATFIY2(GMXYEAVISU)    : # Date Exercice 2
Global Date GVP_DATPER2(GMXYEAVISU)    : # Date Période 2
Global Decimal GVP_MNTBAS2(GMXYEAVISU) : # Montant base 2
Global Decimal GVP_MNTCUM2(GMXYEAVISU) : # Montant cumul 2
Global Decimal GVP_MNTDOT2(GMXYEAVISU) : # Montant dotation 2
Global Decimal GVP_SOLIML2(GMXYEAVISU) : # Solde dépréciation 2
Global Decimal GVP_MNTIML2(GMXYEAVISU) : # Dépréciation 2
Global Decimal GVP_IMLRVE2(GMXYEAVISU) : # Reprise 2
Global Decimal GVP_VNEEND2(GMXYEAVISU) : # Valeur nette fin 2
Global Decimal GVP_EXCDPR2(GMXYEAVISU) : # Amortissement exceptionnel (ou anticipato si mode IT)

Global Integer GBOOL_EXOPER
  # --------------------------
  If clalev([F:CNX])   = 0 : Local File CONTEXT     [CNX]   : Endif : # Contextes
  If clalev([F:CNX1])  = 0 : Local File CONTEXT     [CNX1]  : Endif : # Contextes
  If clalev([F:CNX2])  = 0 : Local File CONTEXT     [CNX2]  : Endif : # Contextes
  If clalev([F:FIS1])  = 0 : Local File FISCYEAR    [FIS1]  : Endif : # Exercices
  If clalev([F:FIS3])  = 0 : Local File FISCYEAR    [FIS3]  : Endif : # Exercices
  If clalev([F:FIS2])  = 0 : Local File FISCYEAR    [FIS2]  : Endif : # Exercices
  If clalev([F:FIS4])  = 0 : Local File FISCYEAR    [FIS4]  : Endif : # Exercices
  # --------------------------
  [M:FVP0]CPY     = [M:FAS0]CPY
  [M:FVP0]AASREF  = [M:FAS0]AASREF
  [M:FVP0]AASDES1 = [M:FAS0]AASDES1
  [M:FVP0]OTHPLN  = G_NON
  [M:FVP0]CNX1    = G300CPFI
  [M:FVP0]PLN1    = G301CPT
  [M:FVP0]FIYPER  = GVML_EPEXERC
  Affzo [M:FVP0]CPY
  Affzo [M:FVP0]AASREF
  Affzo [M:FVP0]AASDES1
  Affzo [M:FVP0]OTHPLN

  Affzo [M:FVP0]CNX1
  Call AP_CNX1([M:FVP0]CNX1)

  Affzo [M:FVP0]PLN1

  Affzo [M:FVP0]FIYPER
  Call AP_OTHPLN([M:FVP0]OTHPLN)
  # --------------------------
Return

#-------------------------------------------------------------------------------
$FIN
# --------------------------
# Destruction des tableaux contenant les résultats de calcul
  Kill GVP_EXOPER             : # Calcul exercice ou périodique
  Kill GVP_NBLIGN1            : # Nombre de lignes à afficher 1
  Kill GVP_CNX1               : # Contexte 1
  Kill GVP_PLN1               : # Plan 1
  Kill GVP_DATFIY1            : # Date Exercice 1
  Kill GVP_DATPER1            : # Date Période 1
  Kill GVP_MNTBAS1            : # Montant base 1
  Kill GVP_MNTCUM1            : # Montant cumul 1
  Kill GVP_MNTDOT1            : # Montant dotation 1
  Kill GVP_SOLIML1            : # Solde dépréciation 1
  Kill GVP_MNTIML1            : # Dépréciation 1
  Kill GVP_IMLRVE1            : # Reprise 1
  Kill GVP_VNEEND1            : # Valeur nette fin 1
  #Gbn-050905-Fq 31619-Ajout dotation exceptionnelle sur l'écran de simu
  Kill GVP_EXCDPR1            : # Amortissement exceptionnel (ou anticipato si mode IT)

  Kill GVP_NBLIGN2            : # Nombre de lignes à afficher 2
  Kill GVP_CNX2               : # Contexte 2
  Kill GVP_PLN2               : # Plan 2
  Kill GVP_DATFIY2            : # Date Exercice 2
  Kill GVP_DATPER2            : # Date Période 2
  Kill GVP_MNTBAS2            : # Montant base 2
  Kill GVP_MNTCUM2            : # Montant cumul 2
  Kill GVP_MNTDOT2            : # Montant dotation 2
  Kill GVP_SOLIML2            : # Solde dépréciation 2
  Kill GVP_MNTIML2            : # Dépréciation 2
  Kill GVP_IMLRVE2            : # Reprise 2
  Kill GVP_VNEEND2            : # Valeur nette fin 2
  Kill GVP_EXCDPR2            : # Amortissement exceptionnel (ou anticipato si mode IT)

Return

#-------------------------------------------------------------------------------
$AVANT_BOUTON
  Case BOUT
    When "1"        : # Calculer
      # Voir pour mettre quelques contrôles ici !
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$BOUTON
  Case BOUT
    When "1"        : # Calculer
      Gosub SIMULATION_PLAN
      FIN = 0
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$SIMULATION_PLAN
Local Integer LERROR
Local Integer N_I

  # --------------------------
  # Remise à zéro des tableaux
  GVP_NBLIGN1 = 0
  Raz GVP_DATFIY1
  Raz GVP_DATPER1
  Raz GVP_MNTBAS1
  Raz GVP_MNTCUM1
  Raz GVP_MNTDOT1
  Raz GVP_SOLIML1            : # Solde dépréciation 1
  Raz GVP_MNTIML1            : # Dépréciation 1
  Raz GVP_IMLRVE1            : # Reprise 1
  Raz GVP_VNEEND1            : # Valeur nette fin 1
  Raz GVP_EXCDPR1            : # Dotation exceptionnelle

  GVP_NBLIGN2 = 0
  Raz GVP_DATFIY2
  Raz GVP_DATPER2
  Raz GVP_MNTBAS2
  Raz GVP_MNTCUM2
  Raz GVP_MNTDOT2
  Raz GVP_SOLIML2            : # Solde dépréciation 2
  Raz GVP_MNTIML2            : # Dépréciation 2
  Raz GVP_IMLRVE2            : # Reprise 2
  Raz GVP_VNEEND2            : # Valeur nette fin 2
  Raz GVP_EXCDPR2            : # Dotation exceptionnelle
  # --------------------------
  # Appel du calcul
  GVP_EXOPER  = [M:FVP0]FIYPER
  GVP_CNX1    = [M:FVP0]CNX1
  GVP_PLN1    = [M:FVP0]PLN1
  GVP_CNX2    = [M:FVP0]CNX2
  GVP_PLN2    = [M:FVP0]PLN2
  # --------------------------
  Call SIMULER_CALCUL_BIEN
&      ( [M:FVP0]CPY, [M:FVP0]AASREF, [M:FVP0]PLN1, [M:FVP0]PLN2, [M:FVP0]FIYPER ) From =G_GLOB

Return

################################################################################
# ECRAN : FASVISPLN0
################################################################################
########################################
Subprog AUTORISE_CHOIX_PERIODE (PAUTORISE)
Value Integer PAUTORISE

  If PAUTORISE = G_NON Then
    [M:FVP0]FIYPER = GVML_EPEXERC
    Affzo [M:FVP0]FIYPER
    Diszo [M:FVP0]FIYPER
    GBOOL_EXOPER = G_NON
  Else
    Actzo [M:FVP0]FIYPER
    GBOOL_EXOPER = G_OUI
  Endif
End


########################################
Subprog AS_CNX1(VALEUR)
Variable Integer VALEUR

  # Faut virer tous les contextes non gérés
  Call VIRE_CNX_NON_GERES ([M:FVP0]CPY) From GLOBIENS
End

########################################
Subprog AP_CNX1(VALEUR)
Variable Integer VALEUR

  Filter [CNX1] Where CPY=[M:FVP0]CPY and CNX=VALEUR
  Read [CNX1]CNX0 First
  Filter [CNX1]
  # --------------------------
  Filter [FIS1] Where CPY=[M:FVP0]CPY and CNX=[F:CNX1]CNX and STAFIY=GVML_TECOURA
  Read [FIS1]FIY0 First
  Filter [FIS1]
  # --------------------------
  Filter [FIS3] Where CPY=[M:FVP0]CPY and CNX=[F:CNX1]CNX and STAFIY=GVML_TESUIV
  Read [FIS3]FIY0 First
  Filter [FIS3]
  # --------------------------
End

########################################
Subprog AS_PLN1(VALEUR)
Variable Integer VALEUR
Local Integer LCNX

  # Faut virer tous les plans non gérés ou ne correspondant pas au contexte
  LCNX = [M:FVP0]CNX1
  Call VIRE_PLN_NON_GERES ([M:FVP0]CPY, [M:FVP0]CNX1) From GLOBIENS
End

########################################
Subprog AP_OTHPLN(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_OUI Then
    Actzo [M:FVP0]CNX2
    Actzo [M:FVP0]PLN2
  Else
    Raz [M:FVP0]CNX2
    Raz [M:FVP0]PLN2
    Diszo [M:FVP0]CNX2
    Diszo [M:FVP0]PLN2
    Affzo [M:FVP0]CNX2
    Affzo [M:FVP0]PLN2
  Endif
End

########################################
Subprog AS_CNX2(VALEUR)
Variable Integer VALEUR

Local Integer N_I, N_E, L_ON_GARDE

  # Faut virer tous les contextes non gérés
  Call VIRE_CNX_NON_GERES ([M:FVP0]CPY) From GLOBIENS
  # --------------------------
# FQ114947
#  If [M:FVP0]CNX1 <> G300CPFI Then
#    # Si le contexte n'est pas le comptable et fiscal, on ne peut pas rechoisir le même contexte
#    GMENLOC([M:FVP0]CNX1) = 1
#  Endif
  # --------------------------
  # Il faut virer de CNX2, tous les contextes ne répondant pas aux conditions suivantes :
  #  - Même devise que CNX1
  #  - Même découpage exercice "courant" et "suivant" que CNX1
  #  - Même découpage périodique "courant" et "suivant" que sur CNX1 si choix d'affichage périodique
  #  - Si CNX1 est "Comptable et fiscal", et qu'un seul plan est géré sur lui
  If ( [M:FVP0]CNX1 = G300CPFI and [F:CNX1]NBPLC = 1 ) Then
      GMENLOC([M:FVP0]CNX1) = 1
  Endif
  #
  For N_I = 1 To G300MAX
    If GMENLOC(N_I) = 0 and N_I <> [M:FVP0]CNX1 Then
      # Travail à faire que sur ceux qui restent
      # Si le CNX1 et "comptable et fiscal" il va forcément être bon, donc on reteste pas !
      # A°) on test les devises
      Filter [CNX2] Where CPY=[M:FVP0]CPY and CNX=N_I
      Read [CNX2]CNX0 First
      Filter [CNX2]
      If [F:CNX1]CUR <> [F:CNX2]CUR Then
        # c'est pas la même devise on peut pas le choisir
        GMENLOC(N_I) = 1
      Else
        # --------------------------
        Filter [FIS2] Where CPY=[M:FVP0]CPY and CNX=[F:CNX2]CNX and STAFIY=GVML_TECOURA
        Read [FIS2]FIY0 First
        Filter [FIS2]
        # --------------------------
        Filter [FIS4] Where CPY=[M:FVP0]CPY and CNX=[F:CNX2]CNX and STAFIY=GVML_TESUIV
        Read [FIS4]FIY0 First
        Filter [FIS4]
        # --------------------------
        If day([F:FIS1]DATSTRFIY) <> day([F:FIS2]DATSTRFIY) or month([F:FIS1]DATSTRFIY) <> month([F:FIS2]DATSTRFIY) Then
          # Si les jour/mois début et fin d'exercice courant sont différentes
          # des jour/mois début et fin d'exercice courant du contexte N_I,
          # On fait le même test par rapport à l'exercice suivant du contexte N_I
          If day([F:FIS1]DATSTRFIY) <> day([F:FIS4]DATSTRFIY) or month([F:FIS1]DATSTRFIY) <> month([F:FIS4]DATSTRFIY) Then
            # Si les jour/mois début et fin d'exercice courant sont différentes
            # des jour/mois début et fin d'exercice courant du contexte N_I
            L_ON_GARDE = 0
          Else
            L_ON_GARDE = 2
          Endif
        Else
          L_ON_GARDE = 1
        Endif
        If L_ON_GARDE = 0 Then
          # Si les jour/mois début et fin d'exercice courant du contexte 1 sont différentes
          # des jour/mois début et fin d'exercice courant et suivant du contexte N_I,
          # on ne peut pas choisir le contexte N_I
          GMENLOC(N_I) = 1
        Endif
        # --------------------------
      Endif
    Endif
    # --------------------------
    # Suite de la boucle
  Next N_I
  # --------------------------
  N_E = -1
  For N_I = 1 To G300MAX
    If GMENLOC(N_I) = 0 Then
      N_E = N_I
      Break
    Endif
    # --------------------------
    # Suite de la boucle
  Next N_I
  If N_E = -1 Then
    [M:FVP0]OTHPLN = G_NON
    Affzo [M:FVP0]OTHPLN
    Call AP_OTHPLN([M:FVP0]OTHPLN)
  Endif
  # --------------------------
End

########################################
Subprog AP_CNX2(VALEUR)
Variable Integer VALEUR

Local Integer N_I

  Filter [CNX2] Where CPY=[M:FVP0]CPY and CNX=VALEUR
  Read [CNX2]CNX0 First
  Filter [CNX2]
  # --------------------------
  Filter [FIS2] Where CPY=[M:FVP0]CPY and CNX=[F:CNX2]CNX and STAFIY=GVML_TECOURA
  Read [FIS2]FIY0 First
  Filter [FIS2]
  # --------------------------
  Filter [FIS4] Where CPY=[M:FVP0]CPY and CNX=[F:CNX2]CNX and STAFIY=GVML_TESUIV
  Read [FIS4]FIY0 First
  Filter [FIS4]
  # --------------------------
  Call AUTORISE_CHOIX_PERIODE (G_OUI)
  # --------------------------
  # Contrôler que toutes les périodes sont identiques
  If [F:FIS1]NBRPER <> [F:FIS2]NBRPER Then
    # S'il n'y a pas le même nombre de périodes, c'est déjà pas bon pour faire du périodique
    Call AUTORISE_CHOIX_PERIODE (G_NON)
  Else
    For N_I =  1 To [F:FIS1]NBRPER
      If [F:FIS1]DATSTRPER(N_I) <> [F:FIS2]DATSTRPER(N_I) or [F:FIS1]DATENDPER(N_I) <> [F:FIS2]DATENDPER(N_I) Then
        # Si la date début ou fin de chq période entre le CNX1 et CNX2 et différente on peut pas faire de périodique
        Call AUTORISE_CHOIX_PERIODE (G_NON)
        Break
      Endif
      # --------------------------
      # Suite de la boucle
    Next N_I
  Endif
End

########################################
Subprog AS_PLN2(VALEUR)
Variable Integer VALEUR
Local Integer LCNX

  # Faut virer tous les plans non gérés ou ne correspondant pas au contexte
  LCNX = [M:FVP0]CNX2
  Call VIRE_PLN_NON_GERES ([M:FVP0]CPY, [M:FVP0]CNX2) From GLOBIENS

  If [M:FVP0]CNX1 = G300CPFI Then
    # Si le contexte est le comptable et fiscal, on ne peut pas rechoisir le même plan
    GMENLOC([M:FVP0]PLN1) = 1
  Endif
End

########################################
Subprog AS_FIYPER(VALEUR)
Variable Integer VALEUR

  If GBOOL_EXOPER = G_NON Then
    # FGR "bidouille" inexplicable pour traiter la fiche qualité 24010
    mkstat = 2
  Endif
End

