#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTITRS10   UTI process                                    Module TRS   #
#           Array of ATABDIV 304 to TABCODEDT
##########################################################################

If clalev([F:ADS])=0  
    Local File ADOSSIER [ADS] 
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER 
  If fstat <> 0 
        Raz [F:ADS] 
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTITRS10(WDOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS10(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Local Char DESIG1(GLONDES) , DESIG2(GLONSHO)

Call ECR_TRACE("UTITRS10 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:AXX])  = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
If clalev([F:TED])  = 0 : Local File =DOSSIER+".TABCODEDT"   [TED] : Endif
If nbrecord([F:TED]) : Goto THE_END : Endif

If clalev([F:ADI])  =0  Local File =DOSSIER+".ATABDIV"  [ADI] : Endif
Filter [ADI] Where NUMTAB=304

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [TED]
For [ADI]

 [F:TED]CODEDT = [F:ADI]CODE
 [F:TED]LEG    = [F:ADI]LEG
 [F:TED]TRT    = [F:ADI]A1

 # Libellés
 DESIG1 = ""
 Call LECTEXTRA (DESIG1,"ATABDIV","LNGDES","304",[F:ADI]CODE) From ATEXTRA
 Call MAJTEXTRA (DESIG1,"TABCODEDT","DESAXX",[F:TED]CODEDT,[F:TED]LEG) From ATEXTRA
 DESIG2 = ""
 Call LECTEXTRA (DESIG2,"ATABDIV","SHODES","304",[F:ADI]CODE) From ATEXTRA
 Call MAJTEXTRA (DESIG2,"TABCODEDT","SHOAXX",[F:TED]CODEDT,[F:TED]LEG) From ATEXTRA

 [F:TED]UPDUSR = ""
 [F:TED]UPDDAT = [0/0/0]
 [F:TED]CREUSR=GUSER
 [F:TED]CREDAT=date$

 Write [F:TED]
 If !fstat : WCOMPTEUR += 1 : Endif

Next
Commit

Close Local File [TED]


$THE_END
Call ECR_TRACE("UTITRS10 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN
Trbegin [AXX]
Delete [AXX]  Where CODFIC="ATABDIV" & IDENT1="304"
If fstat
 Call ERREUR("ATEXTRA-304",3) From DOSDIC
Else
 Call ECR_TRACE("UTITRS10 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif
Commit

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS10 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 
If filinfo(filpath("FIL","TABCODEDT","fde",APPLI),0)<=0 : End : Endif 
Call MAJ_UTITRS10(APPLI)        
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","TABCODEDT","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS10(APPLI)        
End


