#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################
# TRTSHTCOM : Traitement communs pour régularisation des manquants
###############################################################################
# INIT_SHT : Ouverture des fichiers nécessaires à la régularisation
###############################################################################

Subprog SHTTRACE( PTXT, PERR )
Value    Char    PTXT
Value    Integer PERR

    #----- Si pas de trace d'erreur => pas de trace du tout -----#
    If dim([M:SSC]ERRFLG)>=0 & [M:SSC]ERRFLG=1
        End
    Endif
    #----- Si on a une erreur ou que la trace de régul n'est pas interdite (via [SSC]) ----#
    If PERR=1 | !(dim([M:SSC]REGFLG)>=0 & [M:SSC]REGFLG<>2)
        Call ECR_TRACE( PTXT, PERR ) From GESECRAN
        If dim(GPURTRACE)>0 & GPURTRACE=1 : GPURTRACE=2 : Endif
    Endif
End


###############################################################################
# INIT_SHT : Ouverture des fichiers nécessaires à la régularisation
###############################################################################
$INIT_SHT
    # Ouvertures des tables nécessaires
    If !clalev([F:ITG]) : Local File ITMCATEG  [ITG] : Endif
    If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
    If !clalev([F:ITF]) : Local File ITMFACILIT[ITF] : Endif
    If !clalev([F:STO]) : Local File STOCK     [STO] : Endif
    If !clalev([F:SRU]) : Local File TABSTORUL [SRU] : Endif
    If !clalev([F:TRU]) : Local File TABALLRUL [TRU] : Endif
    If !clalev([F:STL]) : Local File STOLOT    [STL] : Endif
    If !clalev([F:STE]) : Local File STOPAR    [STE] : Endif
    If !clalev([F:ITV]) : Local File ITMMVT    [ITV] : Endif
    #--- Bug 82333
    If !clalev([F:STC]) : Local File STOLOC    [STC] : Endif

    If !clalev([F:STJ]) : Local File STOJOU    [STJ] : Endif
    If !clalev([F:STA]) : Local File STOALL    [STA] : Endif

    # Ouvertures des masques de travail
    If !clalev([M:SHTR]) : Local Mask STKSHTREG [SHTR] : Endif
    If !clalev([M:ALP])  : Local Mask ALLPAR    [ALP]  : Endif
    If !clalev([M:STW])  : Local Mask STOWORK   [STW]  : Endif
    If !clalev([M:SVW])  : Local Mask STOVALWORK [SVW] : Endif
    If !clalev([M:SVWD]) : Local Mask STOVALWORK [SVWD] : Endif    # hcb 71448

    If !clalev([M:SDPA]) : Local Mask SAIDECPRI [SDPA] : Endif  # Issue 65099 - 2010-06-02 by CCC : Pour régul sortie assemblage

    # affectations
    Gosub OPEN_MTO From MTOLINKLIB
Return


###############################################################################
# ALIM_ALP : Alimentation des paramètres d'allocation
###############################################################################
# Paramètres E : Masque STKSHTSEL [SHTS]
#            S : Masque ALLPAR    [ALP]
#                Code retour      LRET OK si 0, erreur sinon
###############################################################################
#--- Bug 72943
#Subprog ALIM_ALP( PNOL, LMODALL)
Subprog ALIM_ALP( PNOL, LMODALL, LRET)
Value    Integer PNOL
Variable Integer LMODALL
Variable Integer LRET : Raz LRET  : #--- Bug 72943
    Raz [M:ALP]
    # Si préparation ou livraison, alimentation du type de transaction
    If [M:SHTS]TRSTYP(PNOL)=0 & find([M:SHTS]VCRTYP(PNOL),3,4)
       Call GET_TRSTYP([M:SHTS]VCRTYP(PNOL),[M:SHTS]VCRNUM(PNOL)," ",[M:SHTS]TRSTYP(PNOL)) From STKLIB
    Endif
    [M:ALP]TRSTYP    = [M:SHTS]TRSTYP(PNOL)
    [M:ALP]TRSCOD    = [M:SHTS]TRSCOD(PNOL)
    [M:ALP]VCRTYP    = [M:SHTS]VCRTYP(PNOL)
    [M:ALP]VCRNUM    = [M:SHTS]VCRNUM(PNOL)
    [M:ALP]VCRLIN    = [M:SHTS]VCRLIN(PNOL)
    [M:ALP]VCRSEQ    = [M:SHTS]VCRSEQ(PNOL)
    [M:ALP]STOFCY    = [M:SHTS]STOFCY
    [M:ALP]ITMREF    = [M:SHTS]ITMREF(PNOL)
    [M:ALP]PCU       = [M:SHTS]STU(PNOL)
    [M:ALP]PCUSTUCOE = 1
    [M:ALP]QTY       = [M:SHTS]QTYSTUACT(PNOL)
    [M:ALP]TYPQTY    = 2
    [M:ALP]BESDAT    = [M:SHTS]BESDAT(PNOL)
    [M:ALP]DLVDAT    = [M:SHTS]BESDAT(PNOL)
    Raz [M:ALP]ALLDAT
    [M:ALP]PECRER    = 1
    [M:ALP]VCRRER    = ""
    [M:ALP]STOLOC    = ""
    [M:ALP]FILSTO    = ""
    If dim([M:SHTS]LOT)>0
        [M:ALP]LOT   = [M:SHTS]LOT(PNOL)
    Endif
    #--- TS 106217
    If dim([M:SHTS]ECCVALMAJ)>0
       [M:ALP]ECCVALMAJ = [M:SHTS]ECCVALMAJ(PNOL)
    Endif
    #---
    If dim([M:SHTS]WRH)>0
        [M:ALP]WRH   = [M:SHTS]WRH(PNOL)
    Endif
    If dim([M:SHTS]LOC)>0
        [M:ALP]LOC   = [M:SHTS]LOC(PNOL)
    Endif
    [M:ALP]STA       = [M:SHTS]STA(PNOL)
    [M:ALP]PECINTLOC = 2
    [M:ALP]PECSCOLOC = 1
    [M:ALP]PECPLFLOC = 2
    [M:ALP]PECCUNLOK = 1
    [M:ALP]PECQLYCTL = 1

    #--- Issue 88931 by TS
    If [M:SHTS]VCRTYP(PNOL)=12
      [M:ALP]VCRTYPORI = [M:SHTS]VCRTYPORI(PNOL)
      [M:ALP]VCRNUMORI = [M:SHTS]VCRNUMORI(PNOL)
      [M:ALP]VCRLINORI = [M:SHTS]VCRLINORI(PNOL)
      [M:ALP]VCRSEQORI = [M:SHTS]VCRSEQORI(PNOL)
    Endif
    #---

    Gosub ALIM_ALP_DOC    # Alimentation du masque ALLPAR[ALP] en fonction du document

End


###############################################################################
# SAVE_ERR : Gestion des erreurs pour SAVE_REGSTJ et SAVE_REGALL
#    Si une erreur est détectée => "End"
###############################################################################
$SAVE_ERR
    If !GOK | GMESSAGE<>"" | LSAV_RET<>0
        GOK=0
        If GMESSAGE=""
            GMESSAGE = mess(15, 180, 1)
        Endif
        End # Ce "End" est normal
    Endif
Return

###############################################################################
# SAVE_REGALL: Enregistrement d'une régularisation d'allocation
###############################################################################
# Paramètres E : LMODALL (mode allocation 1=globale 2=détaillée)
#                Masque [SHTR] renseigné
#            S : Si erreur GOK et/ou GMESSAGE positionnés
###############################################################################
Subprog SAVE_REGALL( LMODALL )
Value Integer LMODALL

Local Integer LSAV_RET
Local Date    LALLDAT
Local Decimal LALLQTYSHT
Local Char    WWRHSAI(GLONWRH)

    Raz GMESSAGE
    Raz LSAV_RET
    LALLDAT= [31/12/2999]

    Call SUPALL([M:SHTR]STOFCY, [M:SHTR]ITMREF, 0, [M:SHTR]SEQ, LSAV_RET) From STKALL
    Gosub SAVE_ERR

    #---- Alimentation du bloc 3 de ALLPAR [ALP] pour création des allocations -----#
    [M:ALP]ALLQTY    = [M:SHTR]PECQTYACT
    [M:ALP]ALLQTYSHT = [M:SHTR]QTYACT-[M:SHTR]PECQTYACT
    [M:ALP]PECRERQTY = 0
    #---- Création des allocations -------------#
    For I=0 To [M:SHTR]NBLIG-1
        If [M:SHTR]QTYSTU(I)<>0
            #--- TS 106217 ajout paramètre LECC (avant dernier)
            Call CREALL(([M:SHTR]ALLTYP=5)+([M:SHTR]ALLTYP=4)*2,[M:SHTR]STOFCY,
&                       [M:SHTR]ITMREF,[M:SHTR]STOCOU(I),LALLDAT,
&                       [M:SHTR]QTYSTU(I),[M:SHTR]QTYSTUACT(I),[M:SHTR]VCRTYP,
&                       [M:SHTR]VCRNUM,[M:SHTR]VCRLIN,[M:SHTR]VCRSEQ,"",
&                       [M:SHTR]IPTDAT,"","","","","","",0,0,"","",
&                       [M:SHTR]BPRNUM,[M:SHTR]BPAADD,[M:SHTR]PECSCOLOC,"",
&                       LSAV_RET) From STKALL
            If LSAV_RET<>0
                Raz [M:ALP]ALLQTY, [M:ALP]ALLQTYSHT
                Break
            Endif
        Endif
    Next I
    Gosub SAVE_ERR

    LALLQTYSHT = [M:SHTR]QTYACT - [M:SHTR]PECQTYACT

    #--- Création d'une allocation de rupture si nécessaire ------#
    If LALLQTYSHT>0
        Local Char    LTABSER(GLONSER)(LALLQTYSHT)
        Local Decimal LTABQTY(LALLQTYSHT)
        Local Integer LNBSER, J
        Local Char    LSERTMP(GLONSER)
        Raz LTABSER
        Raz LTABQTY
        Raz LNBSER
        #--- Recherche des groupes de n° de série en rupture ---------#
        If [M:SHTR]SERSAI<>""
            LSERTMP = [M:SHTR]SERSAI
            Raz J, K
            #---  Récupération de tous les n° de série non régularisés ------#
            #---  et calcul du nombre de numéros de série contigus     ------#
            #---    ex: --> LTABSER="S01";"S03";"S04"                  ------#
            #---        --> LTABQTY=  1  ;  2  ;  0                    ------#
            For I=0 To [M:SHTR]QTYACT-1
                If find(LSERTMP,[M:SHTR]SERNUM)=0
                    LTABSER(J) = LSERTMP
                    LTABQTY(K)+=1
                    J +=1
                Else
                    K=J
                Endif
                Call PLUS_UN(LSERTMP, LSERTMP, LSAV_RET) From STKLIB
                If LSAV_RET
                    Break
                Endif
            Next I
        Else
            LTABQTY(0)=LALLQTYSHT    # !!!! WHILE !!!!
        Endif

        Gosub SAVE_ERR

        Raz I

        If dim([M:SHTR]WRHSAI) > 0
           WWRHSAI=[M:SHTR]WRHSAI
        Else
           WWRHSAI=""
        Endif
        While I<LALLQTYSHT
            #--- TS 106217 ajout paramètre LECC (avant dernier)
            Call CREALL([M:SHTR]ALLTYP,[M:SHTR]STOFCY,[M:SHTR]ITMREF,0,LALLDAT ,
&                       0,LTABQTY(I),[M:SHTR]VCRTYP,[M:SHTR]VCRNUM,
&                       [M:SHTR]VCRLIN,[M:SHTR]VCRSEQ,"",[M:SHTR]IPTDAT,
&                       [M:SHTR]LOTSAI,[M:SHTR]SLOSAI,[M:SHTR]STASAI,
&                       [M:SHTR]LOCSAI,LTABSER(I),WWRHSAI,0,0,"","",[M:SHTR]BPRNUM,
&                       [M:SHTR]BPAADD,[M:SHTR]PECSCOLOC,[M:SHTR]ECCSAI,LSAV_RET) From STKALL
            If LSAV_RET<>0 | LTABQTY(I)<=0
                Raz [M:ALP]ALLQTY, [M:ALP]ALLQTYSHT
                Break
            Endif
            I+=LTABQTY(I)
        Wend
    Endif

    Gosub SAVE_ERR

    [M:ALP]ALLQTY    = [M:SHTR]PECQTYACT
    [M:ALP]ALLQTYSHT = LALLQTYSHT

    Gosub MAJ_DOC
    Gosub SAVE_ERR

End

###############################################################################
# SAVE_REGSTJ : Enregistrement d'une régularisation de mouvement
###############################################################################
# Paramètres E : Masque [SHTR] renseigné
#            S : Si erreur GMESSAGE positionné
###############################################################################
Subprog SAVE_REGSTJ

Local Decimal LSAV_QTA
Local Decimal LSAV_SHT
Local Integer LSAV_RET
Local Integer LNBR, LNBJ

Raz GMESSAGE

Raz [M:STW]

# Initialisation de l'en-tête
[M:STW]STOFCY     = [M:SHTR]STOFCY      # Site
[M:STW]TRSTYP     = [M:SHTR]TRSTYP      # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:SHTR]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [M:SHTR]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = [M:SHTR]VCRLIN      # Numero ligne pièce
[M:STW]VCRTYPORI  = [M:SHTR]VCRTYPORI   # Type pièce (M.701)
[M:STW]VCRNUMORI  = [M:SHTR]VCRNUMORI   # Numéro pièce ori
[M:STW]VCRLINORI  = [M:SHTR]VCRLINORI   # Numero ligne pièce ori
[M:STW]VCRSEQORI  = [M:SHTR]VCRSEQORI   # Numero sequence ligne pièce ori
[M:STW]SEQ        = [M:SHTR]SEQ         # Numero séquence mvt
[M:STW]ITMREF     = [M:SHTR]ITMREF      # Article
[M:STW]MVTDES     = [M:SHTR]MVTDES      # Désignation mouvement
[M:STW]ENTCOD     = [M:SHTR]ENTCOD      # Code pièce auto
[M:STW]PJT        = [M:SHTR]PJT         # Affaire
[M:STW]TRSFAM     = [M:SHTR]TRSFAM      # Famille mouvement
[M:STW]IPTDAT     = [M:SHTR]IPTDAT      # Date imputation
[M:STW]PRIORDH    = 0                   # Prix de l'ordre
#--- Bug 63305
[M:STW]BPRNUM     = [M:SHTR]BPRNUM      # Tiers

Gosub ALIM_STW_DOC
Call ALISTOWORK( 6, 0, LSAV_QTA, LSAV_SHT, LNBR, LNBJ, LSAV_RET ) From STKINT
Gosub SAVE_ERR

If GTRACE<>""
    [M:STW]TRAFLG=4
Else
    [M:STW]TRAFLG=0
Endif
Raz GMESSAGE
Call MAJ_STOCK From STKMAJ
Gosub SAVE_ERR

Gosub MAJ_DOC
Gosub SAVE_ERR

End



###############################################################################
# ALIM_ALP_DOC : Alimentation des champs de ALP particuliers à chaque document
#
# Il reste à alimenter les champs suivants (selon les cas):
#
#      champs      val.defaut.
# [M:ALP]PCU        (=STU)    # Unité de conditionnement
# [M:ALP]PCUSTUCOE  (1)       # Coefficient UC/US
# [M:ALP]DLVDAT     (=BESDAT) # Date livraison
# [M:ALP]ALLDAT     ([0/0/0]) # Date fin réservation client
# [M:ALP]PECINTLOC  (2)       # Prise en compte emplacement interne
# [M:ALP]PECSCOLOC  (1)       # Prise en compte emp sous-traitant
#                               mettre à 2 si :
#                               - OF,EO (régul matière sous-traitance)
#                               - Suivi matière (régul matière sous-traitance)
# [M:ALP]BPRNUM               # Tiers
#                               à alimenter si :
#                               - OF,EO (régul matière sous-traitance)
#                               - Livraison, Facture
# [M:ALP]BPAADD               # Adresse de livraison
#                               à alimenter si :
#                               - OF,EO (régul matière sous-traitance)
# [M:ALP]STOLOC     ("")      # Emplacement poste de charge à renseigner si OF ou suivi OF
# [M:ALP]PECRER     (1)       # Consommation des réservations client (m.1)
# [M:ALP]VCRRER     ("")      # Identifiant réservation pour consommation
# [M:ALP]PECCUNLOK  (1)       # Prise en compte stock en cours d'inventaire
# [M:ALP]PECPLFLOC  (2)       # Prise en compte emplacement quai
# [M:ALP]TRSTYP               # Si allocation commande ou cde prêt (4 ou 17)
#                             # Si ordre de sous-traitance (29)
# [M:ALP]PECOWNER             # Filtre propriétaire du stock
#                               à renseigner si régularisation du stock d'un tiers :
#                               - OF ou suivi OF (régul matière sous-traitance chez le s-traitant)
#                               - retour réception sous-traitance (sauf intra-société)
#
# et la variable LMODALL  = Type d'allocation (1=globale, 2=détaillée)
###############################################################################
$ALIM_ALP_DOC

    Case [M:SHTS]TYPREG(PNOL)
        When 2 : #------------ Mouvement de sortie en attente ---------------#
                Case [M:ALP]VCRTYP
                    When 4  : # Livraison
                              Gosub CHARGE_PARAM_SD From TRTSHTCOMA
                    When 5  : # Facture vente
                              Gosub CHARGE_PARAM_SI From TRTSHTCOMA
                    When 6  : # Réception de sous-traitance
                              Gosub CHARGE_PARAM_SCM From TRTSHTCOMA
                    When 8  : # Retour fournisseur
                              Gosub CHARGE_PARAM_PRT From TRTSHTCOMA
                    When 12 : # Sortie matières
                              Gosub CHARGE_PARAM_TK From TRTSHTCOMA # sr 08.05 demande 31597
                    When 20 : # Sorties diverses
                              Gosub CHARGE_PARAM_SMO From TRTSHTCOMA
                Endcase
        When 3 : #------------ Allocations doc de sortie    ---------------#
                LMODALL = 2
                Case [M:ALP]VCRTYP
                    When 3  : # Préparation
                              Gosub CHARGE_PARAM_PR From TRTSHTCOMA
                    When 4  : # Livraison
                              Gosub CHARGE_PARAM_SD From TRTSHTCOMA
                    When 5  : # Facture vente
                              Gosub CHARGE_PARAM_SI From TRTSHTCOMA
                    When 6  : # Réception de sous-traitance
                              Gosub CHARGE_PARAM_SCM From TRTSHTCOMA
                    When 8  : # Retour fournisseur
                              Gosub CHARGE_PARAM_PRT From TRTSHTCOMA
                    When 20 : # Sorties diverses
                              Gosub CHARGE_PARAM_SMO From TRTSHTCOMA
                Endcase
        When 4 : #------------- Allocations OF, EO et commandes vente -------------#
                # On autorise l'allocation sur des emplacements en inventaire
                # et sur du stock en cours d'analyse
                [M:ALP]PECCUNLOK = 2
                [M:ALP]PECQLYCTL = 2
                LMODALL = 2
                Case [M:ALP]VCRTYP
                    When 2  : # Commande de vente
                              Gosub CHARGE_PARAM_SO From TRTSHTCOMA
                    When 10 : # Ordre de fabrication
                              Gosub CHARGE_PARAM_GP From TRTSHTCOMA
                    When 36 : # Ordre de sous-traitance
                              Gosub CHARGE_PARAM_EO From TRTSHTCOMA
                    When 40 : # Affaire                                : #--- Issue X3-4501
                              Gosub CHARGE_PARAM_PJM From TRTSHTCOMA   : #--- Issue X3-4501
                Endcase

    Endcase

Return


###############################################################################
# ALIM_STW_DOC : Alimentation des champs de STW particuliers à chaque document
#
# Il reste à alimenter les champs suivants (selon les cas):
#
# [M:STW]TRFFCY ("") # Site de destination (liv. inter-site)
# [M:STW]LOCENT ("") # Emplacement destination (liv. prêt, /s-trait. et chgt emplacement)
# [M:STW]TRSCOD ("") # Code mouvement
###############################################################################
$ALIM_STW_DOC

Case [M:STW]VCRTYP
    When  4 : # Livraison
            If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif
            If [F:SDH]SDHNUM<>[M:ALP]VCRNUM
                Read [SDH]SDH0=[M:ALP]VCRNUM
            Endif
            [M:STW]LOCENT     = [F:SDH]BPCLOC

    When  5 : # Facture vente  / rien à faire

    When  6 : # Réception d'ordre de sous-traitance
            If !clalev([F:PTH]) : Local File PRECEIPT  [PTH] : Endif
            If !clalev([F:PTD]) : Local File PRECEIPTD [PTD] : Endif
            If !clalev([F:SCM]) : Local File SCOMAT    [SCM] : Endif

            If [F:PTH]PTHNUM<>[M:ALP]VCRNUM
                Read [PTH]PTH0=[M:ALP]VCRNUM
                If fstat : Raz [F:PTH] : Return : Endif
            Endif
            If [F:PTD]PTHNUM<>[M:ALP]VCRNUM | [F:PTD]PTDLIN<>[M:ALP]VCRLIN
                Read [PTD]PTD0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
                If fstat : Raz [F:PTD] : Return : Endif
            Endif
            If [F:PTD]VCRTYPORI=36
                If [F:SCM]SCONUM<>[M:SHTR]VCRNUMORI | [F:SCM]SCILIN<>[M:SHTR]VCRLINORI | [F:SCM]SCMLIN<>[M:SHTR]VCRSEQORI
                    Read [SCM]SCM0=[M:SHTR]VCRNUMORI;[M:SHTR]VCRLINORI;[M:SHTR]VCRSEQORI
                    If fstat : Raz [F:SCM] : Return : Endif
                Endif
            Endif

    When  12: # Suivi matière
            If !clalev([F:MTK]) : Local File MFGHEADTRK [MTK] : Endif
            If !clalev([F:MKM]) : Local File MFGMATTRK  [MKM] : Endif
            If [F:MTK]MFGTRKNUM<>[M:ALP]VCRNUM
                Read [MTK]MTK0=[M:ALP]VCRNUM
                If fstat : Raz [F:MTK] : Endif
            Endif
            [M:STW]TRSCOD     = [F:MTK]TRSCOD
            If [F:MKM]MFGTRKNUM <> [M:ALP]VCRNUM | [F:MKM]MATTRKLIN <> [M:ALP]VCRLIN
                Read [F:MKM]MKM0 = [M:ALP]VCRNUM;[M:ALP]VCRLIN
                If fstat : Raz [F:MKM] : Endif
            Endif
            [M:STW]LOCENT     = [F:MKM]LOCPREF

    When 20 : # Sortie diverse
            If !clalev([F:SMH]) : Local File SMVTH [SMH] : Endif
            If [F:SMH]VCRNUM <> [M:STW]VCRNUM | [F:SMH]VCRTYP <> [M:STW]VCRTYP
                Read [SMH]SMH0=[M:STW]VCRTYP;[M:STW]VCRNUM
            Endif
            [M:STW]TRSCOD     = [F:SMH]TRSCOD

Endcase

Return



###############################################################################
# MAJ_DOC : "Point d'entrée" pour les documents, afin d'effectuer leur màj
#           suite à la régularisation
###############################################################################
# Paramètres E : le masque [M:ALP] contient toutes les informations nécessaires
#
#            S : En cas d'erreur positionner GOK et GMESSAGE
###############################################################################
$MAJ_DOC
Local Integer WRET
Local Decimal WALLQTY, WSHTQTY
#--- Bug 73027
#Call SHTTRACE( mess(17, 180, 1), 0 ) From TRTSHTCOM
If dim([M:ALP]ALLQTY)>0
  If [M:ALP]ALLQTY>0 Call SHTTRACE( mess(17, 180, 1), 0 ) From TRTSHTCOM Endif
Endif
#---
Case [M:ALP]VCRTYP
  When  2 : #-- Commande
      If !clalev([F:SOQ]) : Local File SORDERQ [SOQ] : Endif
      If [F:SOQ]SOHNUM<>[M:ALP]VCRNUM | [F:SOQ]SOPLIN<>[M:ALP]VCRLIN | [F:SOQ]SOQSEQ<>[M:ALP]VCRSEQ
        Read [SOQ]SOQ0=[M:ALP]VCRNUM;[M:ALP]VCRLIN;[M:ALP]VCRSEQ
        If fstat Raz [F:SOQ] Endif
      Endif
      WALLQTY = [F:SOQ]ALLQTYSTU+[M:ALP]ALLQTY
      WSHTQTY = max([F:SOQ]SHTQTYSTU-[M:ALP]ALLQTY,0)
      Call MAJALLORD([M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,LMODALL,1,WALLQTY,WSHTQTY,WRET) From TRTVENALL
      If WRET <> 0 : GOK=0 : Endif

  When  3 : #-- Préparation           : #--- Bug 63758
      If !clalev([F:PRE]) : Local File STOPRED [PRE] : Endif
      Readlock [PRE]PRE0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
      If fstat Raz [F:PRE] Endif
      [F:PRE]ALLQTY += [M:ALP]ALLQTY
      [F:PRE]SHTQTY  = max([F:PRE]SHTQTY-[M:ALP]ALLQTY,0)
      Rewrite [PRE]
      If fstat : GOK=0 : Endif        : #--- End 63758
      #--- Issue 100459 by TS
      If [F:PRE]ORITYP<3
        If !clalev([F:SOQ]) : Local File SORDERQ [SOQ] : Endif
          If [F:SOQ]SOHNUM<>[F:PRE]ORINUM | [F:SOQ]SOPLIN<>[F:PRE]ORILIN | [F:SOQ]SOQSEQ<>[F:PRE]ORISEQ
          Read [SOQ]SOQ0=[F:PRE]ORINUM;[F:PRE]ORILIN;[F:PRE]ORISEQ
          If fstat Raz [F:SOQ] Endif
        Endif
        WALLQTY = [F:SOQ]ALLQTYSTU
        WSHTQTY = [F:SOQ]SHTQTYSTU
        #--- Issue 102945
        #Call MAJALLORD([M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,LMODALL,1,WALLQTY,WSHTQTY,WRET) From TRTVENALL
        Call MAJALLORD([F:PRE]ORINUM,[F:PRE]ORILIN,[F:PRE]ORISEQ,LMODALL,1,WALLQTY,WSHTQTY,WRET) From TRTVENALL
        #----
        If WRET <> 0 : GOK=0 : Endif
      Endif
      #---
  When  4 : #-- Livraison
      # Bug 72167 : Recalcul du prix de revient et de la marge si la livraison est validée
      If !clalev([F:SDH]) : Local File SDELIVERY  [SDH] : Endif
      If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
      If [F:SDH]SDHNUM<>[M:ALP]VCRNUM
          Read [SDH]SDH0=[M:ALP]VCRNUM
          If fstat GOK=0 : Call RSTA("SDH", [M:ALP]VCRNUM) From GLOCK Endif
      Endif
      If [F:SDH]CFMFLG=2 & GOK=1
          Readlock [SDD]SDD0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
          If fstat GOK=0 : Call RSTA("SDD", [M:ALP]VCRNUM-num$([M:ALP]VCRLIN)) From GLOCK
          Else
              Call GETDEV([F:SDH]SALFCY)  From DEVSUB
              Gosub MARGE From TRTVENLIV
              Rewrite [SDD]
              If fstat GOK=0 : Call FSTA("SDD") From GLOCK : Endif
          Endif
          If [F:SDH]INVFLG=2
              If !clalev([F:SID]) : Local File SINVOICED [SID] : Endif
              If [F:SID]SDHNUM<>[F:SDD]SDHNUM | [F:SID]SDDLIN<>[F:SDD]SDDLIN
                Readlock [SID]SID3=[F:SDD]SDHNUM;[F:SDD]SDDLIN
                # 96580 : Ne pas tomber en erreur s'il n'y a pas de facture (Pr spécifique)
                #If fstat GOK=0 : Call RSTA("SID", [F:SDD]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK
                #Else
                # --> Enregistrement locké
                If fstat = 1 GOK=0 : Call RSTA("SID", [F:SDD]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK
                Elsif !fstat
                # 96580
                    [F:SID]CPRPRI=[F:SDD]CPRPRI
                    [F:SID]PFM   =[F:SDD]PFM
                    Rewrite [SID]
                    If fstat GOK=0 : Call FSTA("SID") From GLOCK : Endif
                Endif
              Endif
          Endif
      # Issue X3-69499 - 2018-06-01 by TS
      Elsif GOK=1
          Readlock [SDD]SDD0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
          If fstat GOK=0 : Call RSTA("SDD", [M:ALP]VCRNUM-num$([M:ALP]VCRLIN)) From GLOCK
          Elsif [F:SDD]LINCFMFLG=2
              Call GETDEV([F:SDH]SALFCY)  From DEVSUB
              Gosub MARGE From TRTVENLIV
              Rewrite [SDD]
              If fstat GOK=0 : Call FSTA("SDD") From GLOCK : Endif
          Else
              Unlock [SDD]
          Endif
      # End issue X3-69499
      Endif
      # Bug 72167
  When  5 : #-- Facture vente
      # Bug 72167 : Recalcul du prix de revient et de la marge si la facture est validée
      If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif
      If !clalev([F:SIV]) : Local File SINVOICEV  [SIV] : Endif
      If !clalev([F:SID]) : Local File SINVOICED  [SID] : Endif
      If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
      If !clalev([F:ITS]) : Local File ITMSALES   [ITS] : Endif
      If [F:SIH]NUM<>[M:ALP]VCRNUM
          Read [SIH]SIH0=[M:ALP]VCRNUM
          If fstat GOK=0 : Call RSTA("SIH", [M:ALP]VCRNUM) From GLOCK Endif
      Endif
      If [F:SIH]STA=3 & GOK=1
          If [F:SIV]NUM<>[M:ALP]VCRNUM
              Read [SIV]SIV0=[M:ALP]VCRNUM
              If fstat GOK=0 : Call RSTA("SIV", [M:ALP]VCRNUM) From GLOCK Endif
          Endif
          If GOK=1
              Readlock [SID]SID0=[M:ALP]VCRNUM;[M:ALP]VCRLIN
              If fstat GOK=0 : Call RSTA("SID", [M:ALP]VCRNUM-num$([M:ALP]VCRLIN)) From GLOCK
              Else
                  Call GETDEV([F:SIV]SALFCY)  From DEVSUB
                  Gosub MARGE From TRTVENFAC
                  Rewrite [SID]
                  If fstat GOK=0 : Call FSTA("SID") From GLOCK : Endif
              Endif
          Endif
      Endif
      # Bug 72167
  When 10 : #-- Ordre de fabrication
      If !clalev([F:MFM]) : Local File MFGMAT [MFM] : Endif
      If [F:MFM]MFGNUM<>[M:ALP]VCRNUM | [F:MFM]MFGLIN<>[M:ALP]VCRLIN | [F:MFM]BOMSEQ<>[M:ALP]VCRSEQ | [F:MFM]ITMREF<>[M:ALP]ITMREF
        Read [MFM]MFM0=[M:ALP]VCRNUM;[M:ALP]VCRLIN;[M:ALP]VCRSEQ;[M:ALP]ITMREF
        If fstat : Raz [F:MFM] : Endif
      Endif
      WALLQTY = [F:MFM]ALLQTY+[M:ALP]ALLQTY
      WSHTQTY = max([F:MFM]SHTQTY-[M:ALP]ALLQTY,0)
      Call MAJALLMAT([M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,[M:ALP]ITMREF,WALLQTY,WSHTQTY,LMODALL,WRET) From MFGALL
      If WRET <> 0 : GOK = 0 : Endif

  When 12 : #-- Suivi matière
              # sr 10.03 rien à faire

  When 20 : #-- Sortie diverse

  When 36 : #-- Ordre de sous-traitance
      If !clalev([F:SCM]) : Local File SCOMAT [SCM] : Endif
      If [F:SCM]SCONUM<>[M:ALP]VCRNUM | [F:SCM]SCILIN<>[M:ALP]VCRLIN | [F:SCM]SCMLIN<>[M:ALP]VCRSEQ | [F:SCM]CPNITMREF<>[M:ALP]ITMREF
        Read [SCM]SCM0=[M:ALP]VCRNUM;[M:ALP]VCRLIN;[M:ALP]VCRSEQ
        If fstat : Raz [F:SCM] : Endif
      Endif
      WALLQTY = [F:SCM]ALLQTY+[M:ALP]ALLQTY
      WSHTQTY = max([F:SCM]SHTQTY-[M:ALP]ALLQTY,0)
      Call MAJALLMAT([M:ALP]VCRNUM,[M:ALP]VCRLIN,[M:ALP]VCRSEQ,[M:ALP]ITMREF,WALLQTY,WSHTQTY,LMODALL,WRET) From SCOALL
      If WRET <> 0 : GOK = 0 : Endif

  When 40 : # Affaire                    : #--- Issue X3-4501

Endcase

Return

###############################################################################
# REGFROMENT : Régularisation automatique suite à enregistrement document d'entrées
###############################################################################
# Paramètres E : PMF     : 0=Mask / 1=File(doit être ouvert)
#                          Attention si PMF=1, le fichier passé en paramètre devient
#                          les fichier par défaut
#                PABR    : Abréviation nom du masque contenant les noms d'articles
#                PFILTRE : Filtre optionnel (Pour un masque, l'indice I peut-être utilisé)
#                            ex:   "[F:STJ]VCRNUM=XXX & VCRLIN>=YY"
#                               ou "[M:MSK]CREFLG(I)=0"
#                PZONITM : Nom de la zone contenant les noms des articles entrés
#                PFCY    : Site
#
#
# Si une trace est ouverte, la trace de la régularisation est activée
###############################################################################
Subprog REGFROMENT(PMF,PABR,PFILTRE,PZONITM,PFCY)
Value Integer PMF
Value Char    PABR
Value Char    PFILTRE
Value Char    PZONITM
Value Char    PFCY
Local Char    LMABR
Local Integer I, J, K
Local Integer LRET
Local Integer WDIM

If clalev([F:ACV])=0 Local File ACTIV      [ACV]  Endif
If dim(GCOD_SLS)<1  Global Integer GCOD_SLS : Endif
Read [ACV] CODACT="SLS" : If !fstat GCOD_SLS=[F:ACV]DIME  : Endif

If dim(GSUITE)  <1  Global Integer GSUITE   : Endif
Raz GSUITE

    Local Mask STKSHTCRIT [SSC]
    Local Mask STKSHTSEL  [SHTS]
    Local Mask STKSHTREG  [SHTR]
    Gosub INIT_SHT From TRTSHTCOM

    If PMF=0
        LMABR="[M:"+PABR+"]"
        WDIM = evalue("dim("+LMABR+PZONITM+")")
    Else
        LMABR="[F:"+PABR+"]"
        Default File "[F:"+PABR+"]"
        Filter [F] Where evalue(PFILTRE)
        WDIM = rowcount([F])
        Filter [F]
    Endif
    # Champs inexistant ([M]) ou pas de mvt stock ([F])
    If WDIM<=0 End Endif

    Local Char LTABITM(GLONITM)(WDIM)    # Articles déjà régularisés

    #---------- Initialisation des critères -----------#
    Raz [M:SSC]
    [M:SSC]STOFCY    = PFCY
    [M:SSC]MONOITMFLG= 1
    [M:SSC]PRIDEFFLG = 2
    If GTRACE<>""
        [M:SSC]REGFLG    = 2
        [M:SSC]ERRFLG    = 2
    Else
        [M:SSC]REGFLG    = 1
        [M:SSC]ERRFLG    = 1
    Endif

    GPOINT="INI_SSC" : Gosub ENTREE From EXEFNC

    Raz J
    If PMF=0
        LNBITM = evalue("dim("+LMABR+PZONITM+")")-1
        LNBITM = sigma(0, LNBITM, (evalue(LMABR+PZONITM+"(LNBITM-indcum)")="") | sigma(LNBITM,LNBITM,1))
        LNBITM = evalue("dim("+LMABR+PZONITM+")")-LNBITM
        If PFILTRE=""
            PFILTRE="1=1"
        Endif
        For I=0 To LNBITM
            [M:SSC]ITMREFSTR = evalue(LMABR+PZONITM+"(I)")
            If find([M:SSC]ITMREFSTR,LTABITM)=0 & evalue(PFILTRE)
                Gosub REG_ITM
            Endif
        Next I
    Else
        If PFILTRE=""
            PFILTRE="1=1"
        Endif
        For [F] Where evalue(PFILTRE)
            [M:SSC]ITMREFSTR = evalue(LMABR+PZONITM)
            If find([M:SSC]ITMREFSTR,LTABITM)=0
                Gosub REG_ITM
            Endif
        Next
    Endif
#--- Bug 60219
Raz [M:SHTS]

End

#-----------------------------------------------------------------------------#
# REG_ITM : 1- alimente SHTS en fonction de l'article dans [M:SSC]ITMREFSTR
#           2- sélectionne tout ce qui peut être régularisé automatiquement
#           3- régularise tout ce qui est sélectionné
# Partie commune au sous programme REGFROMENT quant l'origine est un écran ou un fichier
#-----------------------------------------------------------------------------#
$REG_ITM
    If [F:ITM]ITMREF <> [M:SSC]ITMREFSTR
        Read [F:ITM]ITM0=[M:SSC]ITMREFSTR
        If fstat : Return : Endif
    Endif
    If [F:ITM]STOMGTCOD<2
        Return
    Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
    If [F:ITF]STOFCY <> [M:SSC]STOFCY | [F:ITF]ITMREF <> [M:SSC]ITMREFSTR
       Read [ITF]ITF0 = [M:SSC]ITMREFSTR;[M:SSC]STOFCY
       If fstat
          Return
       Endif
    Endif

    If [F:ITF]STOMGTCOD<2
        Return
    Endif

    LTABITM(J) = [M:SSC]ITMREFSTR
    J+=1
    [M:SSC]ITMREFEND = [M:SSC]ITMREFSTR

    #--- Bug 62256
    Raz [M:SHTS]

    Transmask [M:SSC] To [M:SHTS] # Issue 25606_Transmask [M:SHTS] = [M:SSC]
    Call ALIM_SHTS(1,0) From TRTSHTA
    Call SELECT_ALL(2) From TRTSHTA


    For K=0 To [M:SHTS]NBLIG-1
        Call REGAUTO(K, LRET) From TRTSHTAUTO
    Next K
Return

