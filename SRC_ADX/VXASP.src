#<AdxTL>@(#)5.0.0.0 $Revision$
####################################################################################
# Program Name: VXASP
# Description : ADC Saisie des destination étiquettes et documents
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VXASP","VXASP","XWVXASP") From GSAISIE
End


########################################################
$ACTION
Case ACTION
    When "DEBUT"    : Gosub DEBUT
    When "OK"       : Gosub OK
Endcase

Return


########################################################
$DEBUT
Raz [M:XASP]
[M:XASP]ETIPRN = GVTETI
[M:XASP]DOCPRN = GVTDOC

Affzo [M:XASP]ETITIT
Affzo [M:XASP]DOCTIT
Affzo [M:XASP]ETIPRN
Affzo [M:XASP]DOCPRN

Return

########################################################
$OK

GVTETI = [M:XASP]ETIPRN
GVTDOC = [M:XASP]DOCPRN

Return

