#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPRESAL04   Pre-migration historique commandes          Module Ventes #
# Gestion des adresses                                                     #
# Gestion des infos douanières                                             #
############################################################################
# Issue X3-90233 - 20180807 by LD : Error in processes UUMGPRESALxx

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRESAL04") From LECFIC
  Endif
  Call MAJ_UUMGPRESAL04(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGPRESAL04(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

#----- Récupération du n° de version
# Issue X3-90233
#Local Char VERSION
#Call VERSION (DOSSIER,VERSION) From DOSSUB
#If val(VERSION)=0
#  # N° de version incorrecte
#  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL02",7,ERR) From TRTMIG : #7=Erreur
#  End
#Endif
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL04",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
# End issue X3-90233

Call ECR_TIME("UUMGPRESAL04 Sales Order Process : Update VSORDER") From DOSSUB
Call ECR_TRACE("UUMGPRESAL04 : Process Start on : "+DOSSIER,0) From GESECRAN

Gosub MIG_OUVRE From TRTMIG

Local Integer EXE_SQL
#EXE_SQL = 1

# Passage en V6
If VERSION<GMIGX3VER60
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table VOH
  # ----------------------------------------
  Gosub ADDCOL60
  If ERR : Goto FIN_VOP : Endif
Endif

If EXE_SQL

  Gosub TRT_SQL_VOH
Else

  Gosub TRT_X3_VOH
Endif

# Passage en V6
If VERSION<GMIGX3VER60
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"VSORDER",ERR) From TRTMIG
  If ERR : Goto FIN_VOP : Endif
Endif

$FIN_VOP
Call ECR_TIME("UUMGPRESAL04 Sales Order Process END.") From DOSSUB
End

##########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V6
# ----------------------------------------
# 1- ajouter les colonnes dans la table VOH
# 2- ajouter un index unique
# ----------------------------------------
$ADDCOL60

# 1- ajouter les colonnes dans la table VOH
# ----------------------------------------
# Ajout du champ BPAORD : Adresse client commande
Call MIGADDCOL (DOSSIER,"VSORDER","BPAORD","A",5,1,ERR) From TRTMIG
If ERR : Return : Endif

# Ajout du champ BPAINV : Adresse client facture
Call MIGADDCOL (DOSSIER,"VSORDER","BPAINV","A",5,1,ERR) From TRTMIG
If ERR : Return : Endif

If GACTDEB=2
  Call MIGADDCOL (DOSSIER,"VSORDER","EECLOC","C",2,1,ERR) From TRTMIG
  If ERR : Return : Endif
Endif

# Ajout du champ EECICT : Incoterm
Call MIGADDCOL (DOSSIER,"VSORDER","EECICT","A",20,1,ERR) From TRTMIG
If ERR : Return : Endif

#2- ajouter un index unique
#--------------- INDEX ADDITION  ----------#
Call MIGINDCRE (DOSSIER,"VSORDER","BPCORD+BPAADD+SOHNUM+REVNUM","","",0,ERR) From TRTMIG
If ERR : Return : Endif

Return

########################################################################
$TRT_X3_VOH

# Passage en V6
If VERSION<GMIGX3VER60
  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_VOH_60
Endif

Return

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête commande  : VSORDER                                               #
# ---------------------                                                    #
# Gestion des adresses                                                     #
# Gestion des infos douanières                                             #
############################################################################
$TRT_X3_VOH_60

# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------

#----- Ouverture des fichiers -----#
If clalev([F:VOH]) : Close File [VOH] : Endif
If clalev([F:VOH])  = 0 : Local File =DOSSIER+".VSORDER"     [VOH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer COMPTEUR
Local Integer STOP, NB
Local Char    CRITERE(250)
Local Char    ACLE1, ACLE2, ACLE3
Local Integer ACLE4
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_VOP
Raz NB
If STOP=1
 STOP = 2
 CRITERE  = "[F:VOH]BPCORD=ACLE1 & [F:VOH]BPAADD=ACLE2 & [F:VOH]SOHNUM=ACLE3 & [F:VOH]REVNUM>ACLE4"
Elsif STOP=2
 STOP = 3
 CRITERE  = "[F:VOH]BPCORD=ACLE1 & [F:VOH]BPAADD=ACLE2 & [F:VOH]SOHNUM>ACLE3"
Elsif STOP=3
 STOP = 4
 CRITERE  = "[F:VOH]BPCORD=ACLE1 & [F:VOH]BPAADD>ACLE2 "
Elsif STOP=4
 STOP = 0
 CRITERE  = "[F:VOH]BPCORD>ACLE1"
Else
 CRITERE  = "1=1"
Endif

Trbegin [VOH]
GOK = 1

For [VOH]MIG Where evalue(CRITERE)

  If [F:VOH]BPAORD<>''  & [F:VOH]BPAINV<>'' & [F:VOH]EECICT<>'' & (dim([F:VOH]EECLOC)<0 | [F:VOH]EECLOC<>0)
      Goto SUITE_LOOP_VOP
  Endif

  # --- alimentation des champs
  Gosub RECUP_BPR
  # --- alimentation des champs
  If [F:VOH]SOHCAT<>4
    Gosub RECUP_BPD_VOH
  Endif

  Rewrite [F:VOH]
  If fstat
    Call ECR_TRACE("File VSORDER(SOHNUM)"-[F:VOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:VOH]BPCORD
    ACLE2 = [F:VOH]BPAADD
    ACLE3 = [F:VOH]SOHNUM
    ACLE4 = [F:VOH]REVNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP_VOP
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_VOP
  Endif
Endif

$FIN_X3_VOH
Gosub UNSET_FIRST From TRTFIRST

Close Local File [VOH], [BPR], [BPC], [BPD]

Call ECR_TIME("UUMGPRESAL04 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB

Return

########################################################################
$RECUP_BPR

    If [F:VOH]BPAORD="" | [F:VOH]BPAINV=""
      If [F:BPC]BPCNUM<>[F:VOH]BPCORD
        Read [BPC]BPC0=[F:VOH]BPCORD
        If fstat Raz [F:BPC] Endif
      Endif
    Endif

    If [F:VOH]BPAORD=""
      If dim([F:BPC]BPAADD)>0 & [F:BPC]BPAADD<>""
          [F:VOH]BPAORD=[F:BPC]BPAADD
      Else
          If [F:BPR]BPRNUM<>[F:BPC]BPCNUM
              Read [BPR]BPR0=[F:BPC]BPCNUM : If fstat Raz [F:BPR] Endif
          Endif
          [F:VOH]BPAORD=[F:BPR]BPAADD
      Endif
    Endif

    If [F:VOH]BPAINV=""
      If [F:VOH]BPCINV=[F:BPC]BPCINV
          [F:VOH]BPAINV=[F:BPC]BPAINV
      Else
          If [F:BPR]BPRNUM<>[F:VOH]BPCINV
              Read [BPR]BPR0=[F:VOH]BPCINV
              If fstat Raz [F:BPR] Endif
          Endif
          [F:VOH]BPAINV=[F:BPR]BPAADD
      Endif
    Endif

Return

########################################################################
$RECUP_BPD_VOH

     If ([F:VOH]EECICT="" | (GACTDEB=2 & [F:VOH]EECLOC=0))
         # Si ce n'est pas une cde ouverte, alimentation incoterm et lieu de transport CEE
         # Si c'est une cde ouverte, l'alimentation se fera dans VSORDERC
         If [F:BPD]BPCNUM<>[F:VOH]BPCORD | [F:BPD]BPAADD<>[F:VOH]BPAADD
             Read [F:BPD]BPD0 = [F:VOH]BPCORD;[F:VOH]BPAADD : If fstat Raz [BPD] Endif
         Endif
         If [F:VOH]EECICT="" [F:VOH]EECICT=[F:BPD]EECICT Endif
         If GACTDEB=2 & [F:VOH]EECLOC=0 [F:VOH]EECLOC=[F:BPD]EECLOC Endif
     Endif

Return

########################################################################
$TRT_SQL_VOH

#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:VOH]) : Close File [VOH] : Endif
If clalev([F:VOH])  = 0 : Local File =DOSSIER+".VSORDER"     [VOH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [VOH]
GOK = 1

Gosub TRT_SQL1_VOH

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [VOH]
Return
########################################################################
$TRT_SQL1_VOH
Return

