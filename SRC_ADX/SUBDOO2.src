#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque DOO2
########################################
Subprog AM_DOONUM(VALEUR)
Variable Char    VALEUR()

  #Affiche le nom en clair du donneur d'ordre.
  Read [BPR]BPR0=VALEUR
  If !fstat Then
    [M:DOO2]DOONUMX(nolign-1) = [F:BPR]BPRNAM
  Endif
  #Affiche le code postal et la ville du donneur d'ordre
  Read [BPA]BPA0=1;VALEUR;[F:BPR]BPAADD
  If !fstat Then
    [M:DOO2]DOOZIP(nolign-1) = [F:BPA]POSCOD
    [M:DOO2]DOOCTY(nolign-1) = [F:BPA]CTY
  Endif
  Affzo [M:DOO2]DOONUMX(nolign-1)
  Affzo [M:DOO2]DOOZIP(nolign-1)
  Affzo [M:DOO2]DOOCTY(nolign-1)
End

######################################################################################
Subprog C_DOONUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
    End
  Else
    Read [BPR]BPR0=VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
      End
    Else
      If [F:BPR]DOOFLG <> 2 Then
        #Le tiers indiqué n'est pas un donneur d'ordres.
        GMESSAGE = mess(141,177,1)
        GERR = 1
        mkstat = 2
        End
      Endif
    Endif    
  Endif
End
