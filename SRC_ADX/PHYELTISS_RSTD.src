#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe PHYELTISS

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub AREAD_AFTER
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
      Endcase
  Endcase
Return

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
      Endcase
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return


# -------------------------------------
# PHYELTISS standard representation methods
# -------------------------------------

#------------------------
$AREAD_AFTER
#  # Useful to test statement syntax through debug
Local Char    MSG(100)
Local Char    ERRMSG(140)
Local Integer RET

  # ISSACT - evaluation
  If (fmet this.PHYISS.IS_LINKED_ASSET() = [V]CST_AFALSE)
    # NOT Linked to a fixed asset
    If (fmet this.PHYISS.IS_DISPOSAL() = [V]CST_AFALSE)
      # No defined disposal date
      this.ISSACT = [V]CST_IAISS
    Endif
    If (fmet this.PHYISS.IS_DISPOSAL() = [V]CST_ATRUE)
      # A disposal date exists
      this.ISSACT = [V]CST_IACNLISS
    Endif
  Endif
  If (fmet this.PHYISS.IS_LINKED_ASSET() = [V]CST_ATRUE)
    Local Integer IND
    # Linked to a fixed asset
    If (fmet this.PHYISS.IS_DISPOSAL() = [V]CST_AFALSE)
      # No disposal date
      If (fmet this.PHYISS.GET_MOVEMENT_DISPOSAL([L]IND) = [V]CST_AFALSE)
        # No disposal pending movement =>
        # Physical element can be disposed
        this.ISSACT = [V]CST_IAISS
      Endif
      If (fmet this.PHYISS.GET_MOVEMENT_DISPOSAL([L]IND) = [V]CST_ATRUE)
        # A disposal pending movement exists =>
        # Disposal can be cancelled
        this.ISSACT = [V]CST_IACNLISS
      Endif
    Endif
    If (fmet this.PHYISS.IS_DISPOSAL() = [V]CST_ATRUE)
      # A disposal date exists
      If (fmet this.PHYISS.GET_MOVEMENT_DISPOSAL_CANCEL([L]IND) = [V]CST_AFALSE)
        # No cancellation of disposal movement =>
        # Disposal of the physical element can be cancelled
        this.ISSACT = [V]CST_IACNLISS
      Endif
      If (fmet this.PHYISS.GET_MOVEMENT_DISPOSAL_CANCEL([L]IND) = [V]CST_ATRUE)
        # A cancellation of disposal movement exists =>
        # Disposal cancellation can be abandonned
        this.ISSACT = [V]CST_IADELMVT
      Endif
    Endif
  Endif

  # Issue number 111114
  # ISSACT - Cannot be modified
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ISSACT","$isDisabled","true")

  If find (this.P_ISSTYP, [V]CST_PDIVYISS, [V]CST_PDNOTISS, [V]CST_PDSALES, [V]CST_PDSCRAP, [V]CST_PDSTOLDI  ) = 0
    this.P_ISSTYP = [V]CST_PDNOTISS
  Endif
  # End issue number 111114


  # Issue number 112188
  this.P_ISSDAT = date$
  If (this.ISSACT = [V]CST_IAISS)
    this.P_ISSTYP = [V]CST_PDIVYISS
  Endif
  # End issue number 112188

Return

#------------------------
$AUPDATE_CONTROL_BEFORE
Local Char  ERRMSG(140)

  # PHYELTISS Data Class
  Local Instance PARAM Using C_PHYELTISS
  PARAM = NewInstance C_PHYELTISS AllocGroup null

  PARAM.FASFLG = [V]CST_ANO
  Case this.ISSACT
    When [V]CST_IAISS
      # Disposal
      PARAM.ISSDAT = this.P_ISSDAT
      PARAM.ISSTYP = this.P_ISSTYP
      If not (fmet this.PHYISS._PHYELT_ISSUE(PARAM) = [V]CST_AOK)
        [L]ASTATUS = fmet this.PHYISS.AGETMAXERROR("")
      Endif
    When [V]CST_IACNLISS
      # Disposal cancellation
      If not (fmet this.PHYISS._PHYELT_CNL_ISSUE(PARAM) = [V]CST_AOK)
        [L]ASTATUS = fmet this.PHYISS.AGETMAXERROR("")
      Endif
    When [V]CST_IADELMVT
      # Abandon disposal cancellation
      If not (fmet this.PHYISS._PHYELT_ISSUE_CNL_LST_MVT() = [V]CST_AOK)
        [L]ASTATUS = fmet this.PHYISS.AGETMAXERROR("")
      Endif
  Endcase

  FreeGroup PARAM

Return

