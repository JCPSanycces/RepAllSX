#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################################################
# Picking des demandes de service dans les factures   Module CRM          29/12/2003
###########################################################################################
#    pour GENSIH composant calcul facture
#    chargement masques SIH0 SIH1 SIH2 SIH4
###########################################################################################
$ACTION_GS
  Case GWACTION_GS
    When "READ_DETAIL"
      Gosub READ_DETAIL
    When "MSK_ENTETE"
      Gosub MSK_ENTETE
    When "MSK_DETAIL"
      Gosub MSK_DETAIL
    When "ERREUR"
      Gosub ERREUR
  Endcase
Return

###########################################################################################
$MSK_ENTETE
  Case IMPZON
    When "INVDAT"
      IMPMOD=1
      If dim([M:DIA]INVDATINV) > 0 Then
        # Facturation auto : Date facture=Date de référence ou date d'affectation
        If [M:DIA]INVDATFLG = 1 Then
          [M]INVDAT=[M:DIA]INVDATINV
        Else
          [M]INVDAT=[F:SRE]SREDATASS
        Endif
      Else
        [M]INVDAT = date$
      Endif
    When "SIVTYP"
      IMPMOD = 1
      If dim([M:DIA]SIVTYP) > 0 Then
        [M]SIVTYP = [M:DIA]SIVTYP
      Endif
    When "SALFCY"
      IMPMOD = 1
      [M]SALFCY = [F:SRE]SALFCY
    When "PJT"
      If [M:SIH4]NBLIG = 0 Then
        # FGR 02/01/2012 : X3SUIVI71065 Seulement pour la première ligne
        IMPMOD = 1
        [M]PJT = [F:SRE]SREPJT
      Endif
    When "BPCINV"
      Gosub SETBPCINFOS
    When "CUR"
      Gosub SETCURINFOS
    When "PTE"
      IMPMOD = 1
      [M]PTE = [F:SRE]SREPTE
    When "DEP"
      IMPMOD = 1
      [M]DEP = [F:SRE]SREDEP
    When "VACBPR"
      IMPMOD = 1
      [M]VACBPR = [F:SRE]SREVACBPR
    When "PRITYP"
      IMPMOD = 1
      [M]PRITYP = [F:SRE]SREPRITYP
    When "REP"
      Case indice
        When 0
          [M]REP(0)=[F:SRE]SREREP(0)
        When 1
          [M]REP(1)=[F:SRE]SREREP(1)
      Endcase
    When "INVDTAAMT"
      Gosub SETINVDTA
    When "BPCORD"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCORD = [F:SRE]SREBPC
    When "BPCGRU"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCGRU = [F:SRE]SREBPCGRU
    When "BPRPAY"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPRPAY = [F:SRE]SREBPCPYR
    When "CCE"
      #FQ68364 Axes lignes DS vers facture
      #Chargement des sections analytiques entête facture à partir de la demande de service
      Call CHARG_CCEH("SIH2","NBAXE","SRE") From TRTX3CPT
      #Initialisation sections analytiques vides
      If dim([M:SIH2]NBAXE)>0
          Local Char SECTION
          For I=1 To GNBDIE
              #If [F:SIH]CCE(I-1)=""
              If [M:SIH2]CCE(I-1)=""
                  [F:SIH]DIE(I-1)=GDIE(I)
                  [M:SIH2]DIE(I-1)=GDIE(I)
                  Call INISEC(SECTION,"SIH",GDIE(I)) From SUBCDE
                  [F:SIH]CCE(I-1) = SECTION
                  [M:SIH2]CCE(I-1) = SECTION
              Endif
          Next I
      Endif
      #fin FQ68364
  Endcase
Return

###########################################################################################
$SETBPCINFOS
  IMPMOD = 1
  [M]BPCINV = [F:SRE]SREBPCINV
  [M]SIHORI = 8
  [M]SIHORINUM = [F:SRE]SRENUM

  # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
  #[M]BPCORD = [F:SRE]SREBPC    # a faire sur GX3APP mais pas en 140 et v5
  #[M]BPCGRU = [F:SRE]SREBPCGRU
  #[M]BPRPAY = [F:SRE]SREBPCPYR
Return

###########################################################################################
$SETCURINFOS
  IMPMOD = 1
  [M]CUR = [F:SRE]SRECUR
  [M]CURTYP = [F:SRE]SRECHGTYP
Return

###########################################################################################
$SETINVDTA
Local Integer ITERSRE

  Gosub OPEN_SFI From TRTX3CPY : #If !clalev([F:SFI]) : Local File SFOOTINV [SFI] : Endif
  ITERSRE = 0
  For ITERSRE = 0 To dim([F:SRE]INVDTA) - 1
    If [F:SRE]INVDTA(ITERSRE) <> 0 Then
      If [F:SRE]INVDTA(ITERSRE) = [M]INVDTA(indice) Then
        #Read [SFI] SFI0 = GSOCIETE;[M]INVDTA(indice)
        Read [SFI] SFI0 = [M]INVDTA(indice)
        If !fstat Then
          [M]INVDTAAMT(indice) = [F:SRE]INVDTAAMT(ITERSRE)
        Endif
        Break
      Endif
    Endif
  Next
Return

###########################################################################################
#-----------------------------------------------------------------------
# Lecture des enregistrements details
# - le filter des lignes doit être actif
# - on ne fait que de la création de lignes
#-----------------------------------------------------------------------
$READ_DETAIL
  nolign = 0
  LIG_DETAIL = "C" # uniquement de la creation
  If LEC_DETAIL = 0 Then
    Read [HDI]First
  Else
    Read [HDI]Next
  Endif
  If !fstat Then
    # lecture ok
    LEC_DETAIL = 1
  Elsif fstat = 4 Then
    # fin lecture
    LEC_DETAIL = 2
  Else
   # erreur
   LEC_DETAIL = 3
  Endif
Return

###########################################################################################
$MSK_DETAIL
  Case IMPZON
    When "ITMREF"
      Gosub SETITMREF
    When "SAU"
      IMPMOD = 1
      [M]SAU(nolign-1) = [F:HDI]HDTUOM
    When "QTY"
      Gosub SETITMQTY
    When "SAUSTUCOE"
      IMPMOD = 1
      [M]SAUSTUCOE(nolign-1) = [F:HDI]SAUSTUCOE
    When "GROPRI"
      Gosub SETGROPRI
    When "CCE1"
      #FQ68364
      # Chargement sections analytiques
      Call CHARG_ACCCCE(nolign-1,"","","[M:SIH4]CCE",
&                       "HDI",0,[F:HDI]SRENUM,[F:HDI]HDTORD,0,"") From TRTX3CPT
      # Initialisation des sections analytiques vides
      Local Integer I
      Local Char    SECTION
      For I=1 To GNBDIE
          If evalue("dim([M]CCE"+num$(I)+"(nolign-1))") >0 & evalue("[M]CCE"+num$(I)+"(nolign-1)")=""
              Call INISEC(SECTION, "SID", I) From TRTX3CPT
              Assign "[M]CCE"+num$(I)+"(nolign-1)" With SECTION
          Endif
      Next
      #fin FQ68364
    When "DPJT"
      # FGR 28/11/2011 : X3SUIVI71065
      IMPMOD = 1
      [M]DPJT(nolign-1) = [F:SRE]SREPJT
Endcase
Return

###########################################################################################
$SETITMREF
  IMPMOD = 1
  [M]ITMREF(nolign-1) = [F:HDI]HDTITM
  [M]SRENUM(nolign-1) = [F:HDI]SRENUM
  Gosub SETGROPRI
Return

###########################################################################################
$SETITMQTY
Local Integer T_OK
Local Integer ISOMETEXT
Local Clbfile SZHDICLBFILE(6)
Local Integer ITEXSEQNUM
Local Char SZTEXSEQNUM(GLONTXC)

  ISOMETEXT = 0
  IMPMOD = 1
  [M]QTY(nolign-1) = [F:HDI]HDTQTY
  #-- texte ligne facture --
  If [F:HDI]HDTSALTEX = "" Then
    If [F:HDI]HDTTEX <> "" Then
      Setlob SZHDICLBFILE With [F:HDI]HDTTEX
      ISOMETEXT = 1
    Endif
  Else
    If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif  # FGR 30/03/2011 : X3SUIVI72784
    Read [TXC]TXC0=[F:HDI]HDTSALTEX
    If !fstat Then
      SZHDICLBFILE = [F:TXC]TEXTE
      ISOMETEXT = 1
    Endif
  Endif
  #
  If ISOMETEXT Then
    [M:SIH4]SIDTEX(nolign-1) = "SID"
  Endif
  #
  If [M:SIH4]SIDTEX(nolign-1) = "SID" Then
    # On enregistre le clob
    Call NUM_TXC("SID", ITEXSEQNUM, T_OK) From TRTX3TEX
    #SZTEXSEQNUM = "SID~" + num$(ITEXSEQNUM)
    SZTEXSEQNUM = "SID~" + format$("N0:8#",num$(ITEXSEQNUM))
    [M:SIH4]SIDTEX(nolign-1) = SZTEXSEQNUM
    Call RANGE_CLOB(SZHDICLBFILE, SZTEXSEQNUM, T_OK) From ACLOB
  Endif
Return

###########################################################################################
$OLDSETITMQTY
Local Integer T_OK
Local Integer ISOMETEXT

  ISOMETEXT = 0
  IMPMOD = 1
  [M]QTY(nolign-1) = [F:HDI]HDTQTY
  #-- texte ligne facture --
  If [F:HDI]HDTSALTEX = "" Then
    If [F:HDI]HDTTEX <> "" Then
      Setlob [M:ACL]CLOB With [F:HDI]HDTTEX
      ISOMETEXT = 1
    Endif
  Else
    Read [TXC] TXC0 = [F:HDI]HDTSALTEX
    If !fstat Then
      [M:ACL]CLOB = [F:TXC]TEXTE
      ISOMETEXT = 1
    Endif
  Endif
  #
  If ISOMETEXT Then
    [M:SIH4]SIDTEX(nolign-1) = "SID"
  Endif
  #
  If [M:SIH4]SIDTEX(nolign-1) = "SID" Then
    Call CRE_CLOB_ACL ("[M:SIH4]SIDTEX(nolign-1)", T_OK) From TRTX3TEX
  Endif
Return

