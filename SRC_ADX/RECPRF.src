 Titcol [M:RPRF]NBRID func GETNAMCOL(3,1,W_TABLIB) For CRIT3   :     Titcol [M:RPRF]NBRID func GETNAMCOL(3,2,W_TABLIB) For COEF3
 Titcol [M:RPRF]NBRID func GETNAMCOL(3,LABNIV,W_TABLIB) For NIV3
