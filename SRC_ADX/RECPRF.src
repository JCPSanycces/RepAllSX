###################################################################################################################################
# JML 28/07/10 LOT P02
# SEGAY - 25/11/10 - BUG bug 69399 LOT P02 Echelle globale(0 à 100%) sur le niveaux de compétence (5 niveaux ML 480)
# SEGAY - 20/05/11 - Dem 72838 Note globale par salariés
# SBA   - 21/08/2013 US 1835 : 91298 suppression des maskcou dans ini_byleg
###################################################################################################################################
# Gestion du masque RECPRF
## GPROG    = Traitement
## GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
## GWINDOW  = Ecran de saisie
## GWINCRIT = Ecran de critères###################################################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"RECPRF","RECPRF","DRECPRF",4,"XYRECPRF") From GTRAITE
End
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "END"      : FIN = 1
 When "OK"       : Gosub BOUTON_OK :#MABOS-FQ81085-US1833
 When "CONTROLE" : Gosub CONTROLE
 When "AVANT_BOUTON"   : Gosub AVANT_BOUTON : #MABOS-FQ81085-US1833 - manage mémo
 When "BOUTON"   : Gosub BOUTON
 When "TERMINE"  : Gosub TERMINE
 When Default
Endcase
Return


$INIT
Local Mask RECPRFLIS [RPRF]
Local Mask RECPRF    [DIA]
If BCRIT<>"" : Raz [M:DIA] :Endif
Call INI_LEG From DIVPAYE :#MABOS:06/08/13-FQ81085-US1833-affectation de GCURLEG
Return

$OUVRE
If clalev([F:CPE1])=0   : Local File CPCEMP     [CPE1]  : Endif
If clalev([F:CPE])=0    : Local File CPCEMP     [CPE]   : Endif
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:FGR])=0    : Local File FACGROUP   [FGR]   : Endif
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:ECT])=0    : Local File EMPCTR     [ECT]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
#SBA 13/03/2013 US 1439
If clalev([F:AGC])=0    : Local File AGRPCPY       [AGC]    : Endif
If clalev([F:AGF])=0    : Local File AGRPFCY       [AGF]    : Endif
#Raz [M:DIA]
###################################################################################################################################
# JML 28/07/10 LOT P02 New method, with a link and a filter, always based on CTR
Link [ECT]  With  [ID]ID0=[F:ECT]REFNUM
&             , [FCY]FCY0=[F:ECT]FCY
&             , [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
&          As [LECT]
&          Where [F:ID]ENAFLG=2 #& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>date$)


Local Integer I, J, K, CTL
Local Decimal PDSMAT
Local Decimal PDSREF
#SEGAY 25/11/10 bug 69399
Local Decimal COEFPDSMAT : # Coefficient
Local Decimal PDSMATCOEF : # Application du coef sur le niveau
Local Decimal PCTMATCOEF : # Application du pourcentage
Local Char    MATRI(GLONEML)
Local Char    L_CRITERE(GDIMFIC)
Local Integer L_IJ
#SEGAY 17/05/11 Dem 72838
Local Decimal NOTEMAX : # Note maxi

If dim([M]LEG)> 0 : GCURLEG=[M]LEG :Endif:  #MABOS-FQ81085-US1833
Return

$DEBUT
Case BOITE
 When "DRECPRF"
  If [M:DIA]NBRCPC=0
   Call LECMEMO("STD","[M:DIA]","prf") From GMEMO
   Call AFF_MEMO2(1) From DIVPAYE :#81085:#MABOS-FQ81085-US1833 - manage memo
  Endif
  If [M:DIA]JOT<>""
   Actzo [M:DIA]JOT
   Effzo [M:DIA]POT
   Grizo [M:DIA]POT
  Endif
  If [M:DIA]POT<>""
   Actzo [M:DIA]POT
   Effzo [M:DIA]JOT
   Grizo [M:DIA]JOT
  Endif
  #SBA 13/03/2013 US 1439
 # If GCURLEG = "" Then GCURLEG = GLEGFIL : Endif
  If([M:DIA]CPY="") : Effzo [M:DIA]FCY :Grizo [M:DIA]FCY :Endif

  #US 1835 : 91298
  #pas de groupe de société
  If(dim([M:DIA]LEG)>0)
    If([M:DIA]CPY<>"" or [M:DIA]FCY<>"") : Diszo [M]LEG :Endif
    GCURLEG = [M:DIA]LEG
  Else
    GCURLEG = GDOSLEG
  Endif
  Affzo [M:DIA]
 When "RECPRF"
  Raz [M:RPRF]
  Raz [M:DIA]NBSAL : # JML 06/08/10 LOT P02
  Local Integer W_TABCOL(0..100) #SBA
  Local Char W_TABLIB(60)(0..100) #SBA
  Gosub CHARGE
  Gosub HIDE_COLS
  Sorta [M:RPRF]NBRID [M:RPRF]NBRID Order By -WEI([S]indice),REFNUM([S]indice) Asc
  If [M:DIA]NBR<>0 & [M:RPRF]NBRID>[M:DIA]NBR
   K = [M:RPRF]NBRID-[M:DIA]NBR
   J = [M:RPRF]NBRID-K
   Dela J,K [M:RPRF]NBRID
   [M:RPRF]NBRID -= K
  Endif
  Affzo [M:RPRF]
  If [M:RPRF]NBRID>0
   REPORT1="PRTSCR"
  Endif
Endcase
Return

###################################################################################################################################
#
# Cache les colonnes #SBA
#


###################################################################################################################################
$CHARGE
#################################################################################
# JML 28/07/10 LOT P02 New method, with a link and a filter, always based on CTR
#SEGAY 25/11/10 bug 69399
#COEFPDSMAT = 4 : # Coefficient
COEFPDSMAT = func CALCSCALE : # Coefficient
Local Integer I
Local Char  LIS_CPY(GLONCPY)(0..100)
L_CRITERE="1=1"
If [M:DIA]CPY<>""
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      L_CRITERE -= "&find([F:FCY]LEGCPY,"
      For K=0 To I-1
        L_CRITERE += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then L_CRITERE += "," : Endif
      Next
      L_CRITERE += ")>0"
    Endif
 #L_CRITERE += "&[F:FCY]LEGCPY='"+[M:DIA]CPY+"'"
Endif
If [M:DIA]FCY<>""
 L_CRITERE -= "&[F:FCY]FCY='"+[M:DIA]FCY+"'"
Endif
#SBA 13/03/2013 US:1439
If [M:DIA]LEG<>""
 L_CRITERE -= "&[F:FCY]LEG='"+[M:DIA]LEG+"'"
Endif
If [M:DIA]FLGCTR=2
L_CRITERE -="&([F:HRCTR]XITDAT=[0/0/0]|[F:HRCTR]XITDAT>date$) & [F:HRCTR]CTRDAT<=date$ "
Endif


# JML 17/09/10 CG Don't use it, just to Load
#If [M:DIA]JOT<>""
# L_CRITERE += "&[F:HRCTR]JOBPOT='"+[M:DIA]JOT+"'"
#Endif
#If [M:DIA]POT<>""
# L_CRITERE += "&[F:HRCTR]POT='"+[M:DIA]POT+"'"
#Endif

#L_CRITERE = right$(L_CRITERE,2)
#If L_CRITERE=""
# L_CRITERE = "1=1"
#Endif
#################################################################################
#SEGAY 17/05/11 Dem 72838
NOTEMAX=0 : # Note maxi
Local Integer COMPOBLI
COMPOBLI=[M:DIA]FLGKEY=2
#SBA exi:88763
Local Integer MAX_REC
MAX_REC=[M:DIA]TYPCAL=2
Local Decimal MAX_VAL_REC(0..100)
#SBA fin
For I=0 To func GET_DIMTAB-1  #[M:DIA]NBRCPC-1
  # Calcul de la pondération
  #If(!COMPOBLI or [M:DIA]OBGFLG(I)=2 ) #SBA
    Call LECTURE("CPC",[M:DIA]CPC(I),"") From CONTOBJ
    Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
    PDSREF = 0
#  J = find([F:CPE]LEVCPC,[F:HRSCA]LEV)
#  If J>0
#   For L_IJ=0 To dim([F:HRSCA]LEVREF)-1
#    If [F:HRSCA]LEVREF(L_IJ)<>0
#     PDSREF = [F:HRSCA]LEVREF(L_IJ)*[M:DIA]WEI(I)
#    Endif
#   Next L_IJ
#  Endif
    For L_IJ=0 To dim([F:HRSCA]LEVREF)-1
      If [F:HRSCA]LEVREF(L_IJ)<>0
        PDSREF = [F:HRSCA]LEVREF(L_IJ)*[M:DIA]WEI(I)
      Endif
      #SBA exi:88763
      If(MAX_REC and [M:DIA]LEV(I)=[F:HRSCA]LEV(L_IJ))
        Break
      Endif
      #SBA fin
    Next L_IJ
    #SBA exi:88763
    MAX_VAL_REC(I)=PDSREF
    #SBA fin
    NOTEMAX+=PDSREF
    W_TABLIB(I)=string$([M]OBGFLG(I)=2,"*")+[M:DIA]ZCPC(I)
    W_TABCOL(I)=1
  #Endif #SBA
Next I
#END Dem 72838

For [CPE1]CPE0(1)
 Gosub VERIFMAT
 If OK=1
  OK    = 0
  For I=0 To func GET_DIMTAB-1  #[M:DIA]NBRCPC-1
   If func ISCOLDISPLAY(I+1,W_TABCOL)
    Filter [CPE] Where REFNUM=[F:CPE1]REFNUM & CPC=[M:DIA]CPC(I) & CPCDAT<>[0/0/0]
    Read [CPE]CPE1 Last : # On prend la compétence la plus récente
    Filter [CPE]
    If fstat & [M:DIA]OBGFLG(I)=2
      # Compétence obligatoire que le salarié n'a pas, on passe au salarié suivant
       OK = 0 : Break
    Elsif !fstat
      OK = 1
      # Calcul de la pondération
      Call LECTURE("CPC",[M:DIA]CPC(I),"") From CONTOBJ
      Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
      J = find([F:CPE]LEVCPC,[F:HRSCA]LEV)
      If J=0
        PDSMAT = 0
        PDSREF = 0
      Else
        #SBA exi:88763
#        PDSMAT = [F:HRSCA]LEVREF(J-1)*[M:DIA]WEI(I)
#        For L_IJ=0 To dim([F:HRSCA]LEVREF)-1
#          If [F:HRSCA]LEVREF(L_IJ)<>0
#            PDSREF = [F:HRSCA]LEVREF(L_IJ)*[M:DIA]WEI(I)
#          Endif
#        Next L_IJ
        PDSREF=MAX_VAL_REC(I)
        PDSMAT = min([F:HRSCA]LEVREF(J-1)*[M:DIA]WEI(I),PDSREF)
        #Infbox (num$(MAX_VAL_REC(I))-"--"-num$([F:HRSCA]LEVREF(J-1)*[M:DIA]WEI(I))-"---"-num$(PDSMAT))
        #SBA fin

      Endif
      If MATRI<>[F:CPE1]REFNUM
        If [M:RPRF]NBRID>=dim([M:RPRF]REFNUM)-1
          Call ERREUR(mess(26,100,1)) From GESECRAN : Break 2
          #### num$(PDSMAT)
        Endif
        MATRI = [F:CPE1]REFNUM
        [M:RPRF]NBRID +=1
        nolign = [M:RPRF]NBRID    : # JML 28/07/10 LOT P02
        [M:RPRF] = [F:HRCTR]        : # JML 28/07/10 LOT P02
        [M:RPRF]REFNUM([M:RPRF]NBRID-1) = MATRI
        Call LECTURE("EML",MATRI,"") From CONTOBJ
        [M:RPRF]NAM([M:RPRF]NBRID-1) = [F:ID]NAM-[F:ID]SRN
      Endif
      # JML 06/08/10 Welcome to XXI century !
      If evalue("dim([M:RPRF]CRIT"+num$(I+1)+"([M:RPRF]NBRID-1))")>0
     #SEGAY 25/11/10 bug 69399
#     Assign "[M:RPRF]CRIT"+num$(I+1)+"([M:RPRF]NBRID-1)"  With PDSMAT
        PDSMATCOEF=0
        PCTMATCOEF=0
        If PDSREF > 0
           PDSMATCOEF=ar2((PDSMAT/PDSREF)*COEFPDSMAT)
          PCTMATCOEF=ar2((PDSMAT/PDSREF)*100)
        Endif
        Assign "[M:RPRF]CRIT"+num$(I+1)+"([M:RPRF]NBRID-1)"  With PCTMATCOEF
        Assign "[M:RPRF]COEF"+num$(I+1)+"([M:RPRF]NBRID-1)"  With PDSMATCOEF
        Assign "[M:RPRF]WEI"+num$(I+1)+"([M:RPRF]NBRID-1)"  With PDSMAT
        If PDSMAT
          Assign "[M:RPRF]NIV"+num$(I+1)+"([M:RPRF]NBRID-1)"  With num$(PDSMAT)+"/"+num$(PDSREF)
        Endif
        [M:DIA]NBSAL(I) += 1 : # JML 06/08/10 LOT P02 S'il manque une compétence Obligatoire, on ne verra pas qui c'est ....
      Endif : # If evalue
    Endif
    Endif
  Next I
  If OK=0 & MATRI=[F:CPE1]REFNUM
   # Une compétence obligatoire que le salarié n'a pas
   Dela [M:RPRF]NBRID-1,1 [M:RPRF]NBRID
   [M:RPRF]NBRID -=1
  Endif
  If OK=1
   # JML 06/08/10 Welcome to XXI century !
   [M:RPRF]WEI([M:RPRF]NBRID-1) = 0
   For L_IJ=1 To func GET_DIMTAB  #[M:DIA]NBRCPC
    If evalue("dim([M:RPRF]CRIT"+num$(L_IJ)+"([M:RPRF]NBRID-1))")<=0
     Break
    Endif
    #SEGAY 25/11/10 bug 69399
#    [M:RPRF]WEI([M:RPRF]NBRID-1) += evalue("[M:RPRF]CRIT"+num$(L_IJ)+"([M:RPRF]NBRID-1)")
    [M:RPRF]WEI([M:RPRF]NBRID-1) += evalue("[M:RPRF]WEI"+num$(L_IJ)+"([M:RPRF]NBRID-1)")
   Next L_IJ
   #SEGAY 17/05/11 dem 72838
   If NOTEMAX>0 Then
    [M:RPRF]NOTE([M:RPRF]NBRID-1) = num$(ar2([M:RPRF]WEI([M:RPRF]NBRID-1)/NOTEMAX)*100)+"/"+num$(100)
   Endif
   #END dem 72838
  Endif
 Endif
Next
Return


$HIDE_COLS
Local Char FMTCRIT(10),FMTCOEF(10),FMTWEI(10),FMTNIV(10)
FMTCRIT="-Nz+:4.2#"
FMTCOEF="-Nz+:4.2#"
FMTWEI="-N:4#"
FMTNIV="-N:4#"
Local Integer LABNIV
LABNIV=3
If([M:DIA]TYPCAL=2)
  LABNIV=4
Endif
If !func ISCOLDISPLAY(1,W_TABCOL)
   Chgfmt [M:RPRF]CRIT1 With FMTCRIT   :     Chgfmt [M:RPRF]COEF1 With FMTCOEF
   Chgfmt [M:RPRF]WEI1 With FMTWEI     :     Chgfmt [M:RPRF]NIV1 With FMTNIV
  Else
  Titcol [M:RPRF]NBRID func GETNAMCOL(1,1,W_TABLIB) For CRIT1   :     Titcol [M:RPRF]NBRID func GETNAMCOL(1,2,W_TABLIB) For COEF1
  Titcol [M:RPRF]NBRID func GETNAMCOL(1,LABNIV,W_TABLIB) For NIV1
Endif

If !func ISCOLDISPLAY(2,W_TABCOL)
  Chgfmt [M:RPRF]CRIT2 With FMTCRIT   :     Chgfmt [M:RPRF]COEF2 With FMTCOEF
  Chgfmt [M:RPRF]WEI2 With FMTWEI     :     Chgfmt [M:RPRF]NIV2 With FMTNIV
Else
  Titcol [M:RPRF]NBRID func GETNAMCOL(2,1,W_TABLIB) For CRIT2   :  Titcol [M:RPRF]NBRID func GETNAMCOL(2,2,W_TABLIB) For COEF2
  Titcol [M:RPRF]NBRID func GETNAMCOL(2,LABNIV,W_TABLIB) For NIV2
Endif
