Subprog ACTDISLEG(VALEUR)
Variable Char VALEUR
Local Integer WOK
If(VALEUR="")
  If zoncou="CPY"
    WOK=(""=VALEUR)
  Else
    WOK=(""=[M]CPY)
  Endif
If(WOK) Actzo [M]LEG
Endif


Endif

End

