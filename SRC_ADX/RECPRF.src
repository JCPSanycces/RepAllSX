# Function to verify if we display the colonne #SBA
#
Funprog ISCOLDISPLAY(INDEX,TABVALUES)
Value Integer INDEX,TABVALUES(0..)
Local Integer RES
RES=TABVALUES(INDEX-1)
#RES =INDEX<[M:DIA]NBRCPC
End RES

Funprog GETNAMCOL(INDEX,WTYPE,TABVALUES)
Value Integer INDEX,WTYPE
Value Char TABVALUES()()
Local Char RES(80)
RES=TABVALUES(INDEX-1)
If(RES<>"")
Case WTYPE:
When 4 :
    RES+="/"+mess(135,10720,1) : #Requis menu local 720
  When 3 :
    RES+="/"+mess(134,10720,1) : #Max menu local 720
Endcase

Endif
End RES

