#**
#* Récupére l'échelle en paramètre de l'écran RECCPCLIS
#* SEGAY 25/11/10 bug 69399
#*!
Funprog CALCSCALE()
Local Integer NBSCALE, IND1, IND2
Local Char WSCALE(30)
If clalev([F:AMK]) = 0 : Local File AMSK     [AMK] : Endif
Raz WSCALE
Read [AMK]CODMSK="RECPRFLIS"
If !fstat
  IND1 = instr(1,[F:AMK]BLOCACT1(0),"?")
  If IND1
     IND2 = instr(IND1+1,[F:AMK]BLOCACT1(0),"?")
     If IND2 & IND1+1 <= IND2-1
       WSCALE = seg$([F:AMK]BLOCACT1(0),IND1+1,IND2-1)
     Endif
  Endif
Endif
If WSCALE <> ""
  NBSCALE = val(WSCALE)
Else
  NBSCALE = 5
Endif
End NBSCALE

######################################################################################
## Etiquette écran RECPRF
######################################################################################
Subprog AM_POT(VALEUR)
Variable Char    VALEUR()
Local    Integer I
If VALEUR<>""
 Effzo JOT
 Grizo JOT
Else
 Actzo JOT
Endif
If VALEUR="" : End : Endif
#ADNGO - 2017-03-14 - X3-29429 - START
  #FRLAA - 2015-04-07 - REQUIREMENT 104631 US 3487 - START
  #Duplicating SUB AM_POT for RSA and africa skills module
  If func AFNC.ACTIV("FKSSD") & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
    Call AM_POT(VALEUR) From RECPRFKSA  : End
  Endif
 #FRLAA - 2015-04-07 - REQUIREMENT 104631 US 3487 - END
#ADNGO - 2017-03-14 - X3-29429 - END
If clalev([F:POT])=0 : Local File POSTE  [POT] : Endif
Call LECTURE("POT",VALEUR,"") From CONTOBJ
#If [M:DIA]JOT="" Then Raz [M:DIA]NBRCPC Endif
If [M:DIA]JOT="" Then
  Effzo [DIA]10  #SBA on raz le tableau
Endif
nolign = [M]NBRCPC
Local Integer ORI(0..dim([F:POT]CPC))
For I=0 To dim([F:POT]CPC)-1
 If [F:POT]CPC(I)="" : Break : Endif
 ###################################################
 # JML 28/07/10 LOT P02
 Call LECTURE("CPC",[F:POT]CPC(I),"") From CONTOBJ
 If !find([F:POT]CPC(I),[M:DIA]CPC(0..[M]NBRCPC-1))
& & ([M:DIA]LEG="" | [F:CPC]LEG=""|[M:DIA]LEG=[F:CPC]LEG)
& & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2) #SBA
 ###################################################
   If nolign>=dim([M:DIA]CPC)
      Call ERREUR(mess(26, 100, 1)) From GESECRAN :#"Le nombre de notifications de relance dépasse la limite autorisée ($1$). Veuillez restreindre votre population"
      Break
    Endif
  [L]ORI(nolign)        = [F:POT]ORI(I)
  [M:DIA]CPC(nolign)    = [F:POT]CPC(I)
  [M:DIA]LEV(nolign)    = [F:POT]NIV(I)
  [M:DIA]WEI(nolign)    = [F:POT]WEI(I)
  [M:DIA]OBGFLG(nolign) = [F:CPC]FLGKEY
  nolign +=1
 Endif
Next
[M:DIA]NBRCPC = nolign
Sorta [M:DIA]NBRCPC [M:DIA]NBRCPC,[L]ORI Order By [L]ORI(indice),[M:DIA]CPC(indice)

Affzo [DIA]10
End

Subprog AM_JOT(VALEUR)
Variable Char    VALEUR()

Local    Integer I
If VALEUR<>""
 Effzo POT
 Grizo POT
Else
 Actzo POT
Endif
If VALEUR="" : End : Endif
#ADNGO - 2017-03-14 - X3-29429 - START
 #FRLAA - 2015-04-07 - REQUIREMENT 104631 US 3487 - START
  #Duplicating SUB AM_JOT for RSA and africa skills module
  If func AFNC.ACTIV("FKSSD") & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
    Call AM_JOT(VALEUR) From RECPRFKSA  : End
  Endif
 #FRLAA - 2015-04-07 - REQUIREMENT 104631 US 3487 - END
#ADNGO - 2017-03-14 - X3-29429 - END
If clalev([F:JOT])=0 : Local File JOBTYP  [JOT] : Endif
Call LECTURE("JOT",VALEUR,"") From CONTOBJ
#If [M:DIA]POT="" Then Raz [M:DIA]NBRCPC Endif
If [M:DIA]POT="" Then
  Effzo [DIA]10  #SBA on raz le tableau
Endif
nolign = [M]NBRCPC
Local Integer ORI(0..dim([F:JOT]CPC))
For I=0 To dim([F:JOT]CPC)-1
 If [F:JOT]CPC(I)="" : Break : Endif
 ###################################################
 # JML 28/07/10 LOT P02
 Call LECTURE("CPC",[F:JOT]CPC(I),"") From CONTOBJ
 If !find([F:JOT]CPC(I),[M:DIA]CPC(0..[M]NBRCPC-1))
& & ([M:DIA]LEG="" | [F:CPC]LEG=""|[M:DIA]LEG=[F:CPC]LEG)
& & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
 ###################################################
  If nolign>=dim([M:DIA]CPC)
      Call ERREUR(mess(26, 100, 1)) From GESECRAN :#"Le nombre de notifications de relance dépasse la limite autorisée ($1$). Veuillez restreindre votre population"
      Break
   Endif
  [L]ORI(nolign)        = [F:JOT]ORI(I)
  [M:DIA]CPC(nolign)    = [F:JOT]CPC(I)
  [M:DIA]LEV(nolign)    = [F:JOT]NIV(I)
  [M:DIA]WEI(nolign)    = [F:JOT]WEI(I)
  [M:DIA]OBGFLG(nolign) = [F:CPC]FLGKEY
  nolign +=1
 Endif
Next
[M:DIA]NBRCPC = nolign
Sorta [M:DIA]NBRCPC [M:DIA]NBRCPC,[L]ORI Order By [L]ORI(indice),[M:DIA]CPC(indice)
Affzo [DIA]10
End

Subprog C_CPC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:DIA]CPC(0..[M]NBRCPC-1)) From OBJDIV
End

Subprog AM_CPC(VALEUR)
Variable Char    VALEUR()
Call BASNIVCPC(VALEUR,[M:DIA]LEV(nolign-1)) From SUBCPC
End

Subprog AS_WEI(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 VALEUR = 1
Endif
End

Subprog C_WEI(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 VALEUR = 1
Endif
End


Subprog INIT_BYLEG(VALEUR)
Value Char VALEUR
#Code à faire
Effzo [M]FLGKEY,JOT,POT
[M]FLGCTR=2
Effzo [DIA]10
Actzo [M]JOT
Actzo[M]POT
Affzo [M]
End

Funprog GET_DIMTAB
Local Integer RES
RES= min([M:DIA]NBRCPC,20)
End RES



######################################################################################
## Etiquette ajoutée par le superviseur (écran RECPRF) 12/03/2013 17:11:38 (SBA)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY

  AUZCFY = func SUBHRSES.GET_AUZ(VALEUR, "", "RECPRF")
  If AUZCFY=1 Then
    mkstat=2
  Endif

  Read [F:AGF]AGF0=VALEUR
  If !fstat & [F:AGF]FLGCPY=1 Then : # Ce n'est pas un groupe de sociétés
    Filter [F:AGC] Where GRP=VALEUR
    If rowcount([F:AGC])=0 Then : # Groupe de sites
      GMESSAGE=VALEUR-mess(216,10717,1) : # est un groupe de sites
      mkstat=2
    Endif
    Filter [F:AGC]
  Endif

End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  #US 1835 : 91298 suppression des maskcou dans ini_byleg
  # Suppression de l'action BMCPY dans le masque et intégration dans l'action standard
  If dim([M]LEG)>0
    Local Char OLD_LEG(5)
    OLD_LEG=[M]LEG
  Endif
  Call AM_CPY(VALEUR)From DIVPAYE

  If(VALEUR<>"")
    Effzo [M]FCY
    Actzo [M]FCY
  Else
    Effzo [M]FCY : Diszo [M]FCY : Affzo [M]FCY
    If dim([M]LEG)>0
      If(VALEUR="" and [M]LEG<>GLEGFIL)
         [M]LEG=GLEGFIL
         # si valeur vide, on n'est pas passé dans la fonction.
         Call INIT_BYLEG([M]LEG)From DIVPAYE  :# traitement générique
      Endif
      Actzo [M]LEG
    Endif
  Endif
  If(dim([M]LEG)>0 and  (OLD_LEG<>[M]LEG))
      Call INIT_BYLEG([M]LEG)
  Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
  #US 1835 : 91298
  # Suppression de l'action BMFCY dans le masque et intégration dans l'action standard
  # simplification du code.
  If dim([M]LEG)>0
    Local Char OLD_LEG(5)
    OLD_LEG=[M]LEG
    If VALEUR=""
       Call AM_CPY([M]CPY) From DIVPAYE
    Else
       Call AM_FCY(VALEUR) From DIVPAYE
    Endif
    If(OLD_LEG<>[M]LEG)
      Call INIT_BYLEG([M]LEG)
    Endif
  Endif
 #fin add
#  If VALEUR=""
#    Call AM_CPY([M]CPY)From DIVPAYE
#  Else
#    Read [F:FCY]FCY0=VALEUR
#      If !fstat Then
#        Read [F:CPY]CPY0=[F:FCY]LEGCPY
#        If [M:DIA]LEG<> [F:CPY]LEG
#            [M:DIA]LEG=[F:CPY]LEG
#            GCURLEG = [M:DIA]LEG
#            Call INIT_BYLEG([M:DIA]LEG)
#        Endif
#   Endif
#Endif
End

