#################################################################
# Librairie de sous-programme de gestion des matières   SCOLIBM #
#################################################################
# Subprog ALLOC_MAT(L)                                          #
# Subprog CAL_AVASCOQTY(LMSK,L)                                 #
# Subprog CALCUL_QTY(WBASQTY,WLIKQTYCOD,WLIKQTY,                #
# &                  WQTYRND,WSCA,WLIEN,WQTY)                   #
# Subprog COUNT_MSX (LCPT)                                      #
# Subprog MAJ_AVASCOQTY(LMSK)                                   #
# Subprog MAT_INTSTO(LFCY, LITM, LLOT, LLOC, LSTA)              #
#################################################################
# Masque STOALL appelée depuis CHARGE_PARAM From TRTSTOALLA     #
# $CHARGE_STOALL                                                #
#################################################################



###########################################################################
## calcul de la quantité productible
#########################################################################
Subprog CAL_AVASCOQTY(LMSK,L)
Value    Char    LMSK
Value    Integer L

Local    Decimal PCTMAT
Local    Decimal WAVASCOQTY
# pour l'instant le système est on ne peut plus simple
# on se base sur la quantité allouée ...

Case LMSK
    When "SCO2":    If [M:SCO2]USEQTY(L) >= [M:SCO2]RETQTY(L)
                        WAVASCOQTY  = [M:SCO1]EXTQTY - [M:SCO1]CPLQTY
                    Else
                        # llc 06.04 si ligne non allouée, qté productible nulle
                        If [M:SCO2]ALLSTA(L) = 1
                            WAVASCOQTY = 0
                        Else
                            PCTMAT      = [M:SCO2]SHTQTY(L) / [M:SCO2]RETQTY(L)
                            WAVASCOQTY  = [M:SCO1]EXTQTY - ([M:SCO1]EXTQTY * PCTMAT)
                            WAVASCOQTY -= [M:SCO1]CPLQTY
                            Call QTEARR(WAVASCOQTY,[M:SCO3]OPESTU) From TRTDIV    # 03.05 29253
                        Endif
                    Endif
                    If (WAVASCOQTY < GAVASCO) | (GAVASCO = 9999999999)
                        [M:SCO1]AVASCOQTY = WAVASCOQTY
                        GAVASCO           = WAVASCOQTY
                    Endif
    When "SCM":     If [F:SCM]USEQTY >= [F:SCM]RETQTY
                        WAVASCOQTY  = [F:SCI]EXTQTY - [F:SCI]CPLQTY
                    Else
                        If [F:SCM]ALLSTA = 1
                           WAVASCOQTY = 0
                        Else
                           PCTMAT      = [F:SCM]SHTQTY / [F:SCM]RETQTY
                         # on utilise les qtés de SCOITM
                           WAVASCOQTY  = [F:SCI]EXTQTY - ([F:SCI]EXTQTY * PCTMAT)
                           WAVASCOQTY -= [F:SCI]CPLQTY
                           Call QTEARR(WAVASCOQTY,[F:SCI]STU) From TRTDIV    # 03.05 29253
                        Endif
                    Endif
                    If (WAVASCOQTY < GAVASCO) | (GAVASCO = 9999999999)
                        [F:SCI]AVASCOQTY  = WAVASCOQTY
                        GAVASCO           = WAVASCOQTY
                    Endif
     Endcase
End


###########################################################################
## calcul du besoin (quantité matière)
#########################################################################
Subprog CALCUL_QTY(WBASQTY,WSTU,WLIKQTYCOD,WLIKQTY,WQTYRND,WSCA,WSCATIA,WLIEN,WQTY)
Value    Decimal WBASQTY
Value    Integer WLIKQTYCOD
Value    Decimal WLIKQTY
Value    Integer WQTYRND
Value    Char    WSTU
Value    Decimal WSCA
Value    Integer WSCATIA
Variable Decimal WLIEN
Value    Decimal WQTY
Local    Decimal WQTYN, WQTYNA : # Qté nette, Qté nette arrondie
Local    Decimal WQTYB, WQTYBA : # Qté brute, Qté brute arrondie
#
If WLIKQTY <> 0
    Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,
&           WQTYRND,WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
    If WSCATIA <> 1
        WLIEN = WQTYBA
    Else
        WLIEN = WQTYNA
    Endif
Else
    WLIEN = 0
Endif
#
End


###########################################################################
## boucle de recalcul quantité productible
#########################################################################
Subprog MAJ_AVASCOQTY(LMSK)
Value Char LMSK

Local Integer I
#GA SCO est Mono-article => qqs différences par rapport à MAJ_AVAMFGQTY
Case LMSK
    When "SCO2":    If  [M:SCO1]ALLSTA < 3
                        [M:SCO1]AVASCOQTY = 0 : GAVASCO = 0
                        End
                    Endif
                    For I=0 To [M:SCO2]NBLIG-1
                        If [M:SCO2]MATSTA(I) <> 4
                            Call CAL_AVASCOQTY(LMSK,I)
                        Endif
                    Next I
                    If [M:SCO1]AVASCOQTY < 0 : [M:SCO1]AVASCOQTY = 0 : Endif
    When "SCM":     If [F:SCO]ALLSTA < 3
                       [F:SCI]AVASCOQTY = 0 : GAVASCO = 0
                       End
                    Endif
                  # appel depuis SCOALL/MAJSCO
                  # on a déjà une boucle sur SCM => il faut utiliser ici SCM2
                    If clalev([F:SCM2]) = 0 : Local File SCOMAT  [SCM2] : Endif
                    For [SCM2]SCM0 Where SCONUM = [F:SCO]SCONUM
                        If [F:SCM2]MATSTA <> 4
                            Call CAL_AVASCOQTY(LMSK,0)
                        Endif
                    Next
Endcase
End


#########################################################################
## Interrogation de stock
#########################################################################
Subprog MAT_INTSTO(LFCY, LITM, LLOT, LLOC, LSTA)
Value Char    LFCY
Value Char    LITM
Value Char    LLOT
Value Char    LLOC
Value Char    LSTA
#
Local Char    WFCY(GLONFCY) : WFCY = LFCY
Local Char    WITM(GLONITM) : WITM = LITM
Local Char    WLOT(GLONLOT) : WLOT = ""
Local Char    WLOC(GLONLOC) : WLOC = ""
Local Char    WPAL(GLONPAL) : WPAL = ""
Local Char    WCTR(GLONCTR) : WCTR = ""
Local Char    WSER(GLONSER) : WSER = ""
Local Date    WDAT           : WDAT = date$
Local Integer WOPT           : WOPT = 1
Call INTSTO(WFCY,WITM,WLOT,WLOC,WPAL,WCTR,WSER,WDAT,WOPT) From SUBSTOI
#
End

#########################################################################
# Allocation globale d'une matière                                      #
# nouvelle version (08.01 9147)                                         #
#########################################################################
Subprog ALLOC_MAT(L)
#Value Char    WTRT    # FQ 69909 Ctrl des sources
Value Integer L
Local Integer WALLTYP
Local Integer WRET
Local Decimal WCPLQTY
Local Decimal WALL, WSHT
Local Integer MEMSTA
Local Char    WCLE(100)  # Issue 79707
Local Char    TRTLIG(1)  # Issue 79707

# constitution de la clé pour les éventuels messages d'erreur ...
WCLE = [M:SCO0]SCONUM-"/"-num$([M:SCO1]SCILIN)-"/"-num$([M:SCO2]SCMLIN(L))

WALLTYP = 1

# début de la transaction d'allocation
GOK=1
Call DEBTRANS From GLOCK
$TR_ALLOC
Trbegin ADOVAL

    Readlock [SCM]SCM0=[M:SCO0]SCONUM;[M:SCO1]SCILIN;[M:SCO2]SCMLIN(L)
    If fstat=1  GOK=-1: GLOCK="$SCOMAT"-WCLE              : Goto ROLL_ALLOC
    Elsif fstat GOK=0 : Call RSTA("SCM", WCLE) From GLOCK : Goto AB_ALLOC   : Endif

    If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
        TRTLIG = "C"
    Else
        TRTLIG = "M"
    Endif
    WALL = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]SHTQTY - [F:SCM]USEQTY
    WSHT = [F:SCM]SHTQTY
    If WALL = 0 & WSHT = 0 : Goto TR_FIN : Endif

    MEMSTA = [F:SCM]ALLSTA # mémo statut    llc 08.02 15532

# appel à la routine de gestion des allocations
    Call ALLOCATION(TRTLIG, WALLTYP, WALL, WSHT, WRET) From SCOALL
    If WRET <> 0 : Goto AB_ALLOC : Endif

    [F:SCM]ALLQTY    += WALL
    [F:SCM]SHTQTY     = WSHT
    [F:SCM]ALLSTA     = 3
    If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif

# mise à jour de l'encours
    Call UPDATE_MSX("M", 0) From SCOLIB


# mise à jour matière
    Gosub REWRITE_SCM From SCOLIB

# mise à jour entete
    Gosub MAJSCOHEAD From SCOLIB

# mise à jour article
    Gosub REWRITE_SCO From SCOLIB

# v6 affectations
    Gosub MAJ_MTO_SCM From SCOMTOLIB
#
$TR_FIN
Commit
# obligatoire sinon pas de réactualisation
Gosub LIENS From SUBSCO2
Affzo [M:SCO2]
Affzo [M:SCO1]ALLSTA
End

$ROLL_ALLOC
Rollback  : Call ROLL From GLOCK
If !GROLL : Goto TR_ALLOC : Endif
End

$AB_ALLOC
Rollback
End



#---------------------------------------------------------------------- #
# Chargement des paramètres dans masque STOALL                          #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
#---------------------------------------------------------------------- #
$CHARGE_STOALL
#Local Char    LWRH(GLONWRH)
#Local Integer LEXC
# Chargement du masque [M:ALL]
Raz [M:ALL]
If [M:SCO2]SCOFLG(LNOL)<>2 | [M:SCO2]CPNTYP(LNOL)<>1 : Return : Endif
[M:ALL]VCRTYP    = 36                  : #GA avant 10 pour les OF
[M:ALL]VCRNUM    = [M:SCO0]SCONUM
[M:ALL]VCRLIN    = [M:SCO1]SCILIN
[M:ALL]VCRSEQ    = [M:SCO2]SCMLIN(LNOL)
[M:ALL]PCU       = [M:SCO2]STU(LNOL)
[M:ALL]STU       = [M:SCO2]STU(LNOL)
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [M:SCO2]RETQTY(LNOL) - [M:SCO2]USEQTY(LNOL)
If [M:ALL]RETQTY < 0  : [M:ALL]RETQTY = 0  : Endif
[M:ALL]OLDALLQTY = [M:SCO2]ALLQTY(LNOL)
[M:ALL]SHTQTY    = [M:SCO2]SHTQTY(LNOL)
# Alimentation de la qté à allouer
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
# sr 05.05
If find([M:SCO2]ALLSTA(LNOL),2,3)
     [M:ALL]ALLTYP = 1
     [M:ALL]GLOALLQTY = [M:SCO2]ALLQTY(LNOL)
Else
     [M:ALL]ALLTYP = 2
     Raz [M:ALL]GLOALLQTY
Endif
[M:ALL]RETDAT    = [M:SCO2]DLVDAT(LNOL)
[M:ALL]DLVDAT    = [M:SCO2]DLVDAT(LNOL)
[M:ALP]PECINTLOC = 1  # Pas d'emplacement interne pour les matières sous-traitance V6 05/2008
[M:ALL]PECPLFLOC = 1  # TS le 18.02.09
[M:ALL]PECSCOLOC = 2
[M:ALL]PECOWNER  = [M:SCO2]STOFCY(LNOL)  : # 03/2006 GA suite à demande TS
[M:ALL]STOLOC    = [M:SCO2]LOC(LNOL)     : # 03/2006 GA selon MFGLIBM 11.05 demande 33011
[M:ALL]XLOT      = [M:SCO2]LOT(LNOL)
[M:ALL]XLOC      = [M:SCO2]LOC(LNOL)
[M:ALL]XSTA      = [M:SCO2]STA(LNOL)
[M:ALL]BPCORD    = [M:SCO0]BPRNUM        : # GA Mail TS du 11/04/2006
[M:ALL]BPAADD    = [M:SCO1]BPAADD        : # GA Mail TS du 11/04/2006
#Call WRHAUTO([M:SCO2]STOFCY(LNOL),[M:SCO2]CPNITMREF(LNOL),36,0,1,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif
# Issue 107513/US2 GA 04/2015: ECC for allocations
If dim([M:SCO2]ECCVALMAJ) >= 0
  [M:ALL]WECCVALMAJ = [M:SCO2]ECCVALMAJ(LNOL)
Endif

Diszo [M:ALL]QTYTOALL
Return

#---------------------------------------------------------------------- #
# Contrôle avant enregistrement                                         #
# Si contrôle non OK, mettre OK=0 pour ne pas enregister                #
# Cette étiquette est appelée depuis AVANT_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$AVANT_STOALL
Return

#---------------------------------------------------------------------- #
# Mise à jour complémentaires après enregistrement                      #
# Si problème mettre GOK=0 pour annuler l'enregistrement                #
# Cette étiquette est appelée depuis APRES_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$APRES_STOALL
Local Integer WRET : WRET=0
Local Decimal WDIS

# FQ 70409 GA 01/2011
Call MAJALLMAT2([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, 2, WRET) From SCOALL
If WRET <> 0 : GOK = 0 : Return : Endif

# FQ 70409 GA 01/2011 dernier composant alloué => maj de l'entete d'EO
If LNOL=[M:SCO2]NBLIG-1
  Call MAJALLSCO([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF,WRET) From SCOALL
  If WRET <> 0 : GOK = 0 : Return : Endif
Endif

# relecture données OF (mises à jour par MAJALLMAT)
# lecture entête OF
If [F:SCO]SCONUM <> [M:SCO0]SCONUM
    Read [SCO]SCO0=[M:SCO0]SCONUM
    If fstat : Return : Endif
Endif

# lecture matière
Read [SCM]SCM0=[M:SCO0]SCONUM;[M:SCO1]SCILIN;[M:SCO2]SCMLIN(LNOL)
If fstat : Return : Endif

[M:SCO2]ALLQTY(LNOL) = [F:SCM]ALLQTY
[M:SCO2]SHTQTY(LNOL) = [F:SCM]SHTQTY
[M:SCO2]ALLSTA(LNOL) = [F:SCM]ALLSTA

WDIS = 0
Call LECITV2([M:SCO2]STOFCY(LNOL), [M:SCO2]CPNITMREF(LNOL), WRET) From MFGLIB
If WRET = 0
   #--- Issue 115110 : Added LECCVAL parameter in 10th position
   Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ=""
   If dim([M:SCO2]ECCVALMAJ)>0 & [M:SCO2]ECCVALMAJ(LNOL)<>""
     If clalev([F:SRU])=0  : Local File TABSTORUL [SRU] : Endif
     Call LECSRU([M:SCO2]STOFCY(LNOL),[F:ITM]TCLCOD,29,"","",WRET) From STKLIB
     If WRET=0 & [F:SRU]ORDVER=2
       WECCVALMAJ=[M:SCO2]ECCVALMAJ(LNOL)
     Endif
   Endif
   Call STODISALL([M:SCO2]STOFCY(LNOL),[M:SCO2]CPNITMREF(LNOL),36,1,2,1,2,"","",WECCVALMAJ,WDIS,WRET) From STKALL
   #Call STODISALL([M:SCO2]STOFCY(LNOL),[M:SCO2]CPNITMREF(LNOL),36,1,2,1,2,"","",WDIS,WRET) From STKALL
   #--- End issue 115110
   Call QTEARR(WDIS,[M]STU) From TRTDIV
Endif

[M:SCO2]AVAQTY(LNOL) = WDIS + [F:SCM]ALLQTY

[M:SCO1]ALLSTA    = [F:SCO]ALLSTA
[M:SCO1]OVRALLNBR = [F:SCO]OVRALLNBR
[M:SCO1]DETALLNBR = [F:SCO]DETALLNBR
[M:SCO1]SHTMATNBR = [F:SCO]SHTMATNBR

# Issue 107513/US2 GA 04/2015: ECC for allocations
If dim([M:SCO2]ECCVALMAJ) >= 0
  [M:SCO2]ECCVALMAJ(LNOL)=[M:ALL]WECCVALMAJ
Endif

Affzo [M:SCO2]
Affzo [M:SCO1]

Return

##########################################################################

# -----------------------------------------------
# Compte les matières "fournies au sous-traitant"
# Si 0, le bouton "allocation" n'est pas accessible
# -----------------------------------------------
Subprog COUNT_MSX (LCPT)
Variable Integer  LCPT
Local Integer I
LCPT = 0
For I=0 To [M:SCO2]NBLIG-1
        If [M:SCO2]SCOFLG(I)=2
            LCPT += 1
        Endif
Next I

End

