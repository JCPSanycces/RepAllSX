#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ABA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
 When "INICRE"       : Gosub INICRE
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "SETBOUT"      : Gosub SETBOUT
 When "STATUT"       : Gosub STATUT
 When "LIENS"        : Gosub LIENS
 When "MODIF"        : Gosub MODIF
 When "CREATION"     : Gosub CREATION
 When "ANNULE"       : Gosub ANNULE
 When "FIN"          : Inftxt "" At 2
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When Default
Endcase
Return

#-------------------------------------------------------------------------------------------------------#
# Les tables ABATGRP et ABATTAC étant de type X3 communes à plusieurs dossiers et l'intitulé
# des tâches et groupes étant du type ATX, il est nécessaire d'ouvrir la table ATEXTE dans le dossier X3
#-------------------------------------------------------------------------------------------------------#

##########################################
$AVANT_OUVRE
Local Char DOSX3(GLONADS)
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
DOSX3 = [F:ADW]VALEUR
If DOSX3="" : DOSX3 = "X3" : Endif
Local File =DOSX3+".ATEXTE" [ATX]
Return

##########################################
$AVANT_MODFIC
If [M:ABA1]GRP<>[F:ABA]GRP | [M:ABA1]TACHE<>[F:ABA]TACHE
 Delete [ABD] Where CODABT=[M:ABA1]CODABT
 If fstat=1  : GOK=-1 : Call RSTA("ABD",[M:ABA1]CODABT) From GLOCK : Return : Endif
 Raz [M:ABA1]DJOUR, DEB, FIN
 Effzo [M:ABA1]DJOUR, DEB, FIN
Endif
Return

##########################################
$ANNULE
Delete [ABD] Where CODABT=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ABD",[L]CODE) From GLOCK : Return : Endif
Return

##########################################
$INICRE
Raz [F:ABA]DJOUR
Effzo [M:ABA1]DJOUR, DEB, FIN
Return

##########################################
$MODIF
$CREATION
If [F:ABA]TACHE<>""
 Read [ABT]CODTAC = [F:ABA]TACHE
 If !fstat
  I = 1
  Call CREPAR([F:ABA]DOSSIER,[F:ABA]CODABT,I)
 Endif
Else
 Read [ABG]ABG0 = [F:ABA]GRP
 For I=1 To [F:ABG]NBTAC
  Read [ABT]CODTAC = [F:ABG]CODTAC(I-1)
  If !fstat
   Call CREPAR([F:ABA]DOSSIER,[F:ABA]CODABT,I)
   If GOK<1 : Break : Endif
  Endif
 Next I
Endif
Return

##########################################
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"B") From GOBJET
Else
 CHMEN += "R"
Endif
Return

##########################################
$STATUT
Case BOUT
 When "R"
  Call VERF_RELANCE(CODABT,OK)
  If OK
   Call RELANCE([M]CODABT) : If GOK=1 : Raz [M]DJOUR : Affzo DJOUR : Endif
  Endif
  If dim([L]AUPDTICK)>0 & dim([F]updTick)>0
   [L]AUPDTICK = [F]updTick
  Endif
Endcase
Return

##########################################
$LIENS
Call GRISE
Call GRIZO_HEURE([F:ABA]GRP,[F:ABA]HDEB,[F:ABA]ONE)
Inftxt format$("D:",date$)-"-"-time$ At 2
Return

##########################################
$VERIF
If [M]TACHE<>""
 Read [ABT]CODTAC = [M]TACHE
 If !fstat
  Call VERFPAR([M]DOSSIER,[M]CODABT,1,OKPAR)
 Endif
Else
 Read [ABG]ABG0 = [M]GRP
 For I=1 To [F:ABG]NBTAC
  Read [ABT]CODTAC = [F:ABG]CODTAC(I-1)
  If !fstat
   Call VERFPAR([M]DOSSIER,[M]CODABT,I,OKPAR)
   If !OKPAR : Break : Endif
  Endif
 Next I
Endif
Return

#-------------------------------------------------------------------------#
# Création d'un enregistrement pour les abonnements sans paramètres
#-------------------------------------------------------------------------#

Subprog CREPAR(DOSSIER,CODABT,NUMLIG)
Value    Char    DOSSIER
Value    Char    CODABT
Value    Integer NUMLIG
Local Integer OKDOS
OKDOS = 1
If [F:ABT]FONCTION=""
 Look [ABD]ABD0(3) = [L]CODABT;[F:ABT]CODTAC;[L]NUMLIG
 If fstat
  Gosub TR_CREPAR
 Endif
Else
 Onerrgo ERRDOS
 Local File =[L]DOSSIER+".AFONCTION" [AFC_], =[L]DOSSIER+".ACTION" [ACT_]
 Onerrgo
 If OKDOS
  Read [AFC_]CODINT = [F:ABT]FONCTION
  If !fstat & [F:AFC_]ACTION<>""
   Read [ACT_]ACTION = [F:AFC_]ACTION
   If !fstat & [F:ACT_]PARAM4=""
    Look [ABD]ABD0(3) = [L]CODABT;[F:ABT]CODTAC;[L]NUMLIG
    If fstat
     Gosub TR_CREPAR
    Endif
   Endif
  Endif
  Close Local File [AFC_], [ACT_]
 Endif
Endif
End

###################
$TR_CREPAR
Raz [F:ABD]
If [V]GPRODUIT=1
 [F:ABD]FCY = [V]GFCY
 [F:ABD]DEP = [V]GDEP
Endif
[F:ABD]CODABT = [F:ABA]CODABT
[F:ABD]CODTAC = [F:ABT]CODTAC
[F:ABD]LIG    = NUMLIG
Write [ABD]
If fstat
 GOK = 0 : Call FSTA("ABD") From GLOCK
Endif
Return

##########################################
Subprog VERF_RELANCE(CODABT,OK)
Value    Char    CODABT
Variable Integer OK
Local Char CRITERE(250)
Local File ABATABT [ABA]
Local Char HH(10), HS(10)
Local Date DD

If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
If clalev([F:ABC])=0 : Local File ABATCAL [ABC] : Endif
Raz OK , GMESSAGE
Read [ABA]CODABT=[L]CODABT
If fstat
 GMESSAGE = [L]CODABT-":"-mess(23,100,1) : # Fiche inexistante
Elsif [F:ABA]ENAFLG<>2
 GMESSAGE = [L]CODABT-":"-mess(2,126,1) : # Fiche inactive
Elsif [F:ABA]DJOUR<>date$
 If [F:ABA]DJOUR<>[0/0/0]
  GMESSAGE = [L]CODABT-":"-mess(102,134,1) : # Non exécuté dans la journée
 Endif
Else
 CRITERE = 'CODABT="'+[L]CODABT+'" & DOSSIER="'+[F:ABA]DOSSIER+'" & DAT=date$'
 CRITERE -='& find(FLAG,1,2,4,5)' : # 1=En attente , 2=En cours , 4=Bloquée , 5=A tuer
 If [F:ABA]GRP<>""
  CRITERE -= '& GRP="'+[F:ABA]GRP+'"'
 Else
  CRITERE -= '& TACHE="'+[F:ABA]TACHE+'"'
 Endif
 Filter [ABR] Where evalue(CRITERE)
 Read [ABR] First
 Filter [ABR]
 If !fstat
  GMESSAGE = [F:ABR]TACHE-":"-mess(101,134,1) : # Tâche en cours
 Else
  # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
  Call SCHEDULING_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS) From SERVEUR

  Local Integer OKDAT
  Gosub VERIF_DAT From SERVEUR
  If OKDAT
   If [F:ABA]HDEB<>"" & HH>=[F:ABA]HDEB & HH<=[F:ABA]HFIN
    OK = 1
   Elsif [F:ABA]HDEB=""
    For I=0 To dim([F:ABA]HEURE)-1
     If (I=0 or [F:ABA]GRP="") & ([F:ABA]HEURE(I)<>"" & [F:ABA]HEURE(I)<>"0000")
      If [F:ABA]HEURE(I)>=HH
       OK = 1 : Break
      Endif
     Endif
    Next I
   Endif
  Endif
  If !OK
   GMESSAGE = [L]CODABT-":"-mess(103,134,1) : # Non exécutable dans la période
  Endif
 Endif
Endif
End

##########################################
Subprog RELANCE(CODABT)
Value Char CODABT
Local Char SYMBOLE(20) , MESSA(250) , MAC(GLONAMC) , USR(GLONALO)

  SYMBOLE = "ABA"+[L]CODABT
  Lock =SYMBOLE With lockwait=0
  If fstat
    GLOCK = "%"+SYMBOLE
    Call QUILOCKE(right$(GLOCK,2),[L]MAC,[L]USR) From OBJDIV
    If [L]USR<>""
      MESSA = mess(101,126,1)+"\"+[L]USR+"\"+[L]MAC : # La fiche est utilisée par
    Else
      MESSA = mess(98,126,1)                        : # La fiche est utilisée par un autre utilisateur
    Endif

    If left$(GLOCK,1)="%" & GLOCK<>"%"+SYMBOLE
      MESSA += "\("+mess(20,100,1)-mess(56,100,1)+" |"+right$(GLOCK,2)+"|)" : # Erreur de verrouillage sur Symbole
    Endif
    Call MESSAGE(MESSA) From GESECRAN
    GOK=0
  Else
    If clalev([F:ABA])=0 : Local File ABATABT [ABA] : Endif
    If !adxlog
      Call DEBTRANS From GLOCK
      Gosub TR_REL
    Else
      Gosub MAJ_REL
    Endif
    Unlock =SYMBOLE
  Endif
End

$TR_REL
Trbegin [ABA]
  Gosub MAJ_REL
  If    GOK > 0   : # TRANSACTION in SUCCESS
    Commit
  Elsif GOK = -1  : # RECORD LOCKED  we try again
    Rollback
    Call ROLL From GLOCK
    If !GROLL
      Goto TR_REL
    Endif
  Else            : # TRANSACTION in ERROR
    Rollback
  Endif
Return

$MAJ_REL
  Readlock [ABA]CODABT=[L]CODABT
  If fstat=1
    GOK=-1    : GLOCK="$ABATABT"-[L]CODABT
  Elsif fstat
    GOK=0     : Call FSTA("ABA") From GLOCK
  Else
    Raz [F:ABA]DJOUR
    Rewrite [ABA]
    If fstat
      GOK=0   : Call FSTA("ABA") From GLOCK
    Endif
  Endif
Return

##########################################
Subprog GRISE
Local Integer I
If [M]PERIO=1
 Effzo [M]QUANT, FDM
 Grizo QUANT, FDM
 Actzo JOUR
Else
 For I=1 To dim([M]JOUR)
  [M]JOUR(I-1) = 1
 Next I
 Affzo JOUR
 Grizo JOUR
 Actzo QUANT, FDM
Endif
End

##########################################
Subprog GRIZO_HEURE(GRP,HDEB,UN)
Value Char    GRP , HDEB
Value Integer UN
If GRP<>""
 [M]TACHE  = ""
 [M]ZTACHE = ""
 [M]FRQ    = 0
 [M]HDEB   = ""
 [M]HFIN   = ""
 [M]EPUR   = 0
 [M]ONE    = 1
 [M]CNTERR = 1
 Grizo TACHE, FRQ, HDEB, HFIN, EPUR, ONE, CNTERR
 Actzo FORCE
 For I=0 To dim([M]HEURE)-1
  Actzo HEURE(I)
 Next I
Else
 Actzo TACHE, HDEB
 If [M]HDEB<>""
  Actzo HFIN, FRQ, ONE, CNTERR
  For I=0 To dim([M]HEURE)-1
   [M]HEURE(I) = ""
   Grizo HEURE(I)
  Next I
  [M]FORCE = 1
  Grizo FORCE
  If UN=2
   [M]EPUR = 1
   Grizo EPUR
  Else
   Actzo EPUR
  Endif
 Else
  [M]HFIN   = ""
  [M]FRQ    = 0
  [M]EPUR   = 0
  [M]ONE    = 1
  [M]CNTERR = 1
  Grizo HFIN, FRQ, EPUR, ONE, CNTERR
  For I=0 To dim([M]HEURE)-1
   Actzo HEURE(I)
  Next I
  Actzo FORCE
 Endif
Endif
End

$ERRDOS
OKDOS = 0
Resume

####################################################
Subprog VERFPAR(DOSSIER,CODABT,NUMLIG,OKPAR)
Value    Char    DOSSIER
Value    Char    CODABT
Value    Integer NUMLIG
Variable Integer OKPAR
Local Integer OKDOS
OKPAR = 1
OKDOS = 1
If [F:ABT]FONCTION<>""
 Onerrgo ERRDOS
 Local File =[L]DOSSIER+".AFONCTION" [AFC_], =[L]DOSSIER+".ACTION" [ACT_]
 Onerrgo
 If !OKDOS : OKPAR = 0 : End : Endif
 Read [AFC_]CODINT = [F:ABT]FONCTION
 If !fstat & [F:AFC_]ACTION<>""
  Read [ACT_]ACTION = [F:AFC_]ACTION
  If !fstat & [F:ACT_]PARAM4<>""
   Look [ABD]ABD0(3) = [L]CODABT;[F:ABT]CODTAC;[L]NUMLIG
   If fstat
    OKPAR = 0
   Endif
  Endif
 Endif
 Close Local File [AFC_], [ACT_]
Endif
End

#######################################################################
$SEL_LISTE
Case LISTE
 When "SELZON" : Gosub SELZON
Endcase
Return

$SELZON
Local Char TEXTE(250)(1..GNBSEL,1..2) , TIT(30)(0..2)
Gosub CHARGE_ZON
NBTEX = 0
For I=1 To NZON
 NBTEX += 1
 TEX(NBTEX) = "["+TBABR(I)+"]"+TBZON(I)
 TEXTE(NBTEX,2) = TBMSK(I)
Next I
TIT(0) = mess(49,105,1) : # Choix zone
TIT(1) = mess(17,115,1) : # Zone
TIT(2) = mess(89,105,1) : # Ecran de saisie
Return

#######################################################################
Subprog AS_USER(VALEUR)
Variable Char     VALEUR
If !instr(1,GUSRAUZ(1),"U")
 VALEUR = GUSER : mkstat = 2 : End
Elsif VALEUR=""
 VALEUR = GUSER
Endif
End

Subprog C_USER(VALEUR)
Variable Char VALEUR
If [M:ABA1]DOSSIER=nomap
 Local File AUTILIS [AUS]
Else
 Local File =[M:ABA1]DOSSIER+".AUTILIS" [AUS]
Endif
Call LECTURE("AUS",VALEUR,"") From CONTOBJ
End

Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer I , OKPAR
If VALEUR=2
 Gosub VERIF
 If !OKPAR
  Call MESSAGE(mess(192,126,1)) From GESECRAN : # Les paramètres de cet abonnement doivent être renseignés
  VALEUR=1 : [M]ENAFLG=1 : mkstat = 2 : End : # mkstat=1 : End : # GH 05/08/05 bug 31616
 Else
  [M]ENAFLG = 2
  Call GRISE
 Endif
Endif
End

Subprog AS_PASSE(VALEUR)
Variable Char    VALEUR()
If !instr(1,GUSRAUZ(1),"U") : mkstat = 1 : End : Endif
If [M:ABA1]DOSSIER=nomap & [M:ABA1]USER=GUSER : mkstat = 1 : End : Endif
End

Subprog C_PASSE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If [M:ABA1]USER<>GUSER or [M:ABA1]DOSSIER<>nomap
 Local File =[M:ABA1]DOSSIER+".AUTILIS" [AUS]
 Local Char    MOTPASSE(24)
 Read [AUS]CODUSR = [M:ABA1]USER
 MOTPASSE = VALEUR
 Call CTLPAS(MOTPASSE,OK) From GESUSER
 If !OK
  GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
  mkstat  = 2 : End
 Endif
Endif
End

Subprog AS_JOUR(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
 VALEUR = 2
Endif
End

Subprog C_GRP(VALEUR)
Variable Char    VALEUR()
[M]GRP = VALEUR
Call GRIZO_HEURE(VALEUR,[M]HDEB,[M]ONE)
Affzo TACHE, FRQ, HDEB, HFIN, EPUR, HEURE, ONE
End

Subprog C_PERIO(VALEUR)
Variable Integer VALEUR
[M]PERIO = VALEUR
Call GRISE
End

Subprog AS_QUANT(VALEUR)
Variable Decimal VALEUR
If indice>0 & [M]QUANT(indice-1)=0
 mkstat = 1
Endif
End

Subprog C_QUANT(VALEUR)
Variable Decimal VALEUR
If VALEUR>31 : mkstat = 1 : End : Endif
End

Subprog C_HEURE(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL = indice
End

Subprog C_ONE(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]TACHE<>""
 Read [ABT]CODTAC = [M]TACHE
 If !fstat & [F:ABT]TYPTAC=1 & [F:ABT]TRAIT<>""
  Call ERREUR(mess(93,134,1)) From GESECRAN : # Option impossible avec ce type de tâche
  mkstat = 1 : End
 Endif
Endif
[M]ONE = VALEUR
Call GRIZO_HEURE([M]GRP,[M]HDEB,VALEUR)
Affzo EPUR
End

Subprog C_HDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000"
 VALEUR = ""
Endif
[M]HDEB = VALEUR
Call GRIZO_HEURE([M]GRP,VALEUR,[M]ONE)
Affzo HFIN, FRQ, EPUR, HEURE, ONE
End

Subprog C_HFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<[M]HDEB
 mkstat = 2
Endif
End

Subprog S_DATZON(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(20)(1..1)
Call S_LIS_CHAR(VALEUR,PARAM,"SELZON","SUBABA","") From GACTION
End

Subprog C_DATZON(VALEUR)
Variable Char    VALEUR()
Local Integer K
Local Char WZON(20)
Call UNICITE(VALEUR,[M]DATZON) From OBJDIV
If mkstat : End : Endif
Gosub CHARGE_ZON
WZON = VALEUR
K = instr(1,WZON,"]")
If K & instr(1,WZON,"[")>0
 WZON = right$(WZON,K+1)
Else
 # L'absence de l'abréviation de l'écran devant les noms
 # des variables peut entrainer des erreurs d'évaluation des formules
 Call AVERTIR(mess(110,134,1),K) From GESECRAN
 If K<2
  mkstat = 2 : End
 Endif
Endif
K = instr(1,WZON,"(")
If K : WZON = left$(WZON,K-1) : Endif
If !find(WZON,TBZON(1..NZON))
 GMESSAGE = WZON-":"-mess(8,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
End

$CHARGE_ZON
Local Char TBZON(GLONAVA)(1..50) , TBMSK(GLONAMK)(1..50) , TBABR(GLONABR)(1..50)
Local Char TBHLP(GLONAMK)(1..20) , MASQUE(GLONAMK)
Local Integer I , J , K , N , NZON , NMSK
Raz NZON , NMSK
If [M]TACHE<>""
 Read [ABT]CODTAC=[M]TACHE
 If !fstat and [F:ABT]FONCTION<>""
  Gosub TAC
 Endif
Elsif [M]GRP<>""
 Read [ABG]ABG0=[M]GRP
 If fstat : Return : Endif
 For J=1 To [F:ABG]NBTAC
  Read [ABT]CODTAC=[F:ABG]CODTAC(J-1)
  If !fstat and [F:ABT]FONCTION<>""
   Gosub TAC
  Endif
 Next J
Endif
Return

$TAC
Local File =[M]DOSSIER+".AFONCTION" [AFC]
Local File =[M]DOSSIER+".ACTION"    [ACT]
Local File =[M]DOSSIER+".AWINDOW"   [AWI]
Local File =[M]DOSSIER+".AMSKZON"   [AMZ]
Local File =[M]DOSSIER+".AMSK"      [AMK]
Local File =[M]DOSSIER+".ATYPE"     [ATY]
Read [AFC]CODINT=[F:ABT]FONCTION
If !fstat and [F:AFC]ACTION<>""
 Read [ACT]ACTION=[F:AFC]ACTION
 If !fstat and [F:ACT]PARAM4<>""
  Read [AWI]AWI0=[F:ACT]PARAM4
  If !fstat
   If [F:AWI]MSKENT<>""
    MASQUE = [F:AWI]MSKENT
    Gosub ZON
   Endif
   For I=1 To [F:AWI]NBMSK
    MASQUE = [F:AWI]NOMMSK(I-1)
    Gosub ZON
   Next I
  Endif
 Endif
Endif
Close Local File [AFC] , [ACT] , [AWI] , [AMZ] , [AMK] , [ATY]
Return

$ZON
Read [AMK]CODMSK=MASQUE
If !fstat & !find(MASQUE,TBHLP(1..NMSK))
 NMSK += 1
 TBHLP(NMSK) = MASQUE
 For [AMZ]CODE Where CODMSK=MASQUE
  Read [ATY]CODTYP=[F:AMZ]CODTYP
  If !fstat & ([F:ATY]CODTYP="AVV" or [F:ATY]TYPTYP=8)
   K = 0
   For N=1 To NZON
    If TBZON(N)=[F:AMZ]CODZON & TBABR(N)=[F:AMK]ABRMSK
     K = 1 : Break
    Endif
   Next N
   If !K
    NZON += 1
    TBZON(NZON) = [F:AMZ]CODZON
    TBMSK(NZON) = MASQUE
    TBABR(NZON) = [F:AMK]ABRMSK
   Endif
  Endif
 Next AMZ
Endif
Return

Subprog AS_DATFRM(VALEUR)
Variable Char    VALEUR()
If [M]DATDEP(nolign-1)<>14
 mkstat = 1 : End
Endif
Raz [M]MSKNAM
Gosub CHARGE_ZON
For I=1 To NMSK
 [M]MSKNAM(I-1) = "[M]"+TBHLP(I)
Next I
End

Subprog AS_DATNBR(VALEUR)
Variable Decimal VALEUR
If [M]DATDEP(nolign-1)=14
 mkstat = 1 : End
Endif
End

Subprog AS_DATJRS(VALEUR)
Variable Integer VALEUR
If [M]DATDEP(nolign-1)=14
 mkstat = 1 : End
Endif
End

Subprog C_FRQ(VALEUR)
Variable Decimal VALEUR
# Attention, lancer une tâche batch en boucle sans attente risque de surcharger votre serveur
If VALEUR=0
 Call MESSAGE(mess(109,134,1)) From GESECRAN
Endif
End
