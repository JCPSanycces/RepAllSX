## Etiquette ajoutée par le superviseur (écran ABA1) 14-02-2015 11:07:24 (ADMIN)
######################################################################################
Subprog IB_CODABT
End


######################################################################################
Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
End :#113860 language not mandatory
If VALEUR=""
 Local File ADOSSIER [ADS]
 If func DOSSUB.FILL_ADS([M:ABA1]DOSSIER)
  VALEUR=[F:ADS]LANDEF
 Endif
Endif
End

Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local File ADOSSIER [ADS]
If func DOSSUB.FILL_ADS([M:ABA1]DOSSIER)
 If find(VALEUR,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))=0
   GMESSAGE=VALEUR-":"-mess(138,124,1)
   GERR=1
   mkstat=2
 Endif
Endif
End

Subprog S_LAN(VALEUR)
Variable Char    VALEUR()
Local Integer NBCHOI, CHOI,J
Local Char    TEX(GLONDES)(1..500,1..2) , TIT(GLONDES)(0..2)
Local File ADOSSIER [ADS]
If [M:ABA1]DOSSIER=nomap
 Local File ATEXTRA [AXX]
Else
 Local File =DOSSIER+".ATEXTRA"   [AXX]
Endif
J=func DOSSUB.FILL_ADS([M:ABA1]DOSSIER)
For J=0 To [F:ADS]NBRLAN-1
 If [F:ADS]LAN(J)<>""
  NBCHOI += 1
  TEX(NBCHOI,1) = [F:ADS]LAN(J)
  Call LECTEXTRA(TEX(NBCHOI,2),"TABLAN","INTDES",[F:ADS]LAN(J),"") From ATEXTRA
 Endif
Next
CHOI = 0
TIT(0) = mess(8,31,1) : #SÉLECTION
TIT(1) = mess(259,123,1) : #Langue
TIT(2) = mess(30,109,1) : #Intitulé
Call SAITEX_COL_MAX(NBCHOI,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
Endif
End


