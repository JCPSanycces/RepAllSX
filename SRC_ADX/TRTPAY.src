#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTPAY","TRTPAY",4,"") From GTRAITE
End

##########################################
## Traitement des actions : TRTPAY
##########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 #: GOK = 0
 When "DEBUT"       : Affzo [DIA] : Setmok[DIA] With 0
Endcase
Return


#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
Gosub OUVFIC
Local Integer NBPCE, OK
Local Char    TIT(50)
Local Char    VALPAR(10)

TIT = "mise à jour des variables de paie"

Local Mask TRTPAY [DIA]
Raz [M:DIA]
#64942
#Call PARAM("","DATPAY",VALPAR) From ADOVAL
#[M:DIA]DAT = gdat$(VALPAR)
[M:DIA]DAT = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
#
Call LECMEMO("STD","[M:DIA]","hrpay") From GMEMO


Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
#66011
If !GPAYE
 # Fonction impossible dans le contexte
 Call ERREUR (mess(127,100,1))  From GESECRAN
 FIN=1 : GOK=0 : Return
Endif

If clalev([F:VEP])=0  : Local File VALEMP    [VEP]  : Endif
If clalev([F:VRA])=0  : Local File VARIA     [VRA]  : Endif
If clalev([F:VLA])=0  : Local File VALEUR    [VLA]  : Endif
If clalev([F:TIP])=0  : Local File TIMEMP    [TIP]  : Endif
If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
Gosub OUVRE From WPDEFTABLE
If clalev([F:BCB])=0  : Local File BCLOB     [BCB]  : Endif
If clalev([F:RUB])=0  : Local File RUBRIQUE  [RUB]  : Endif
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#######################################################
$EXEC
#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Gosub FILTRE

NBPCE=0
For [F:FCY]FCY0 Where evalue (CRITFCY)
 For [F:VEP]VEP0 Where FCY=[F:FCY]FCY & evalue (CRITERE) & PYRDAT=[M:DIA]DAT
  Gosub TRTCONT
  If OK
   NBPCE+=1
   Call ECR_TRACE(space$(1),0) From GESECRAN
   Call ECR_TRACE([F:VEP]EMP-num$([F:VEP]PYRDAT)-": Bulletin traité" ,0) From GESECRAN
   Call MAJ ([F:VEP]EMP,[F:VEP]PYRDAT,[F:VEP]FCY,[F:VEP]CTRNUM,([M:DIA]TRA=2))
  Endif
 Next
Next

Call ECR_TRACE(space$(1),0) From GESECRAN
If !NBPCE
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Else
 Call ECR_TRACE(mess(117,10703,1)-":"-num$(NBPCE),0) From GESECRAN : # Nombre de salariés concernés
Endif


If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$TRTCONT
OK=1
Call CONTROLE([F:VEP]EMP,[M:DIA]DAT,[F:VEP]CTRNUM,[M:DIA]CRI,OK,0) From DIVPAYE
If !OK : Return : Endif

Read [F:ID]ID0=[F:VEP]EMP
If fstat | [F:ID]FLGTPS<>2
 OK=0 : Return
Endif

Return

#######################################################
$FILTRE
Local Char CRITFCY (250)
Local Char CRITERE (250)

CRITFCY="1=1"
#46165
#CRITERE = "[F:VEP]STA=1 & [F:VEP]PST=1"
CRITERE = "[F:VEP]PST=1"
If [M:DIA]ALLCPY<>2  #société
 CRITFCY -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITFCY -= '& [F:FCY]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:VEP]EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:VEP]EMP<="'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
 CRITERE -= '& [F:VEP]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE -= '& [F:VEP]PRF = "'+[M:DIA]PRF+'"'
Endif
Return

#######################################################################
## Mise à jour des variables
#######################################################################
#LIPET - 2017-05-15 - START
#Subprog MAJ(MATRI,DATPAY,SITE,CTR,TRA)
Subprog MAJ(MATRI,DATPAY,SITE,CTR,CTRD,TRA)
#LIPET - 2017-05-15 - END
Value Char    MATRI
Value Date    DATPAY
Value Char    SITE
Value Char    CTR
#LIPET - 2017-05-15 - START
Value Date    CTRD
#LIPET - 2017-05-15 - END
Value Integer TRA

Gosub OUVFIC

#62508
If clalev([F:VEP2])=0  : Local File VALEMP    [VEP2]  : Endif
If clalev([F:VEP3])=0  : Local File VALEMP    [VEP3]  : Endif
#

Local Integer MAXCOD
MAXCOD   = nbrecord([F:TIM])

Local Integer NBCOD, T
Local Char    TBCOD(GLONTPS)(1..MAXCOD)

Local Decimal VALEUR , ARRONDI

Local Decimal HRE(1..MAXCOD)
Local Decimal JRS(1..MAXCOD)

Local Char    BULLETIN(GLONVCR)
#LIPET - 2017-05-15 - START
#Filter [VEP2] Where EMP=MATRI & PYRDAT=DATPAY & FCY=SITE & CTRNUM=CTR
Filter [VEP2] Where EMP=MATRI & PYRDAT=DATPAY & FCY=SITE & CTRNUM=CTR & CTRDAT=CTRD
#LIPET - 2017-05-15 - END
Read [VEP2]VEP0 Last
Filter [VEP2]
If fstat>2 : End : Endif
BULLETIN = [F:VEP2]BUL

Local Char  TEXTE(250), MESSAGE(250)
Local Integer ERR, J
Local Char    DAT_COD(250)(1..MAXCOD)
Local Char    CMT_COD(50)(1..MAXCOD,1..5)
Local Integer NBR_CMT(1..MAXCOD)

#WGA : W00001 - Prolongations
Local Char    EVTPGN(GLONTPS)(0..7)
Local Decimal TYPPGN(1..MAXCOD)

EVTPGN(0) = func AFNC.PARAM("AT","")
EVTPGN(1) = func AFNC.PARAM("MALADIE","")
EVTPGN(2) = func AFNC.PARAM("MATERNITE","")
EVTPGN(3) = func AFNC.PARAM("ATTRAJET","")
EVTPGN(4) = func AFNC.PARAM("PATERNITE","")
EVTPGN(5) = func AFNC.PARAM("MALPROF","")
###CP PATHO
EVTPGN(6) = func AFNC.PARAM("PATHPREN","")
EVTPGN(7) = func AFNC.PARAM("PATHPOST","")
#
#W00001

NBCOD=0 : Raz TBCOD
#** V7 : Waiting Time Mangement **#
#*!
#LIPET - 2017-05-15 - START
For [TIM]TIM0
 NBCOD += 1
 TBCOD(NBCOD) = [F:TIM]COD
Next
#LIPET - 2017-05-15 - END
###DBA 11/08 : Calcul de période du mois courant, précédent & suivant
Gosub  CAL_PERIO From TRTFORVAR
###

#Parcours des temps sur la période de paie
Raz HRE : Raz JRS

#55155
#For [TIP]TIP1 Where REFNUM=MATRI & STRDAT<=[F:VEP2]ENDDAT & ENDDAT>=[F:VEP2]STRDAT & CTRNUM=CTR & FCY=SITE
#58833
#For [TIP]TIP1 Where REFNUM=MATRI & CTRNUM=CTR & FCY=SITE  & ((STRDAT<=[F:VEP2]ENDDAT & ENDDAT>=[F:VEP2]STRDAT) | DATPYR=DATPAY)

Call DEBTRANS From GLOCK
Gosub TR5
#** V7 : Waiting Time Mangement **#
#*!
#LIPET - 2017-05-15 - START
For [TIP]TIP1 Where REFNUM=MATRI & CTRNUM=CTR & FCY=SITE  & ((STRDAT<=[F:VEP2]ENDDAT & ENDDAT>=[F:VEP2]STRDAT) | DATPYR=DATPAY
&                   | (FLGBUL=2 & DATBUL=DATPAY) )
 T = find([F:TIP]TIM,TBCOD(1..NBCOD))
 HRE(T) += [F:TIP]NBRHOU
 JRS(T) += [F:TIP]NBRDAY
 If DAT_COD(T)<>"" : DAT_COD(T) += " , " : Endif
 If [F:TIP]STRDAT=[F:TIP]ENDDAT
  DAT_COD(T) -= format$("D:DD[/]MM",[F:TIP]STRDAT)
 Else
  DAT_COD(T) -= format$("D:DD[/]MM",[F:TIP]STRDAT)+"-"+format$("D:DD[/]MM",[F:TIP]ENDDAT)
 Endif
 If [F:TIP]CMT<>"" & NBR_CMT(T)<5
  NBR_CMT(T) += 1
  CMT_COD(T,NBR_CMT(T)) = [F:TIP]CMT
 Endif

 ## IJSS
# If find(TBCOD(T),EVTPGN) &
#&  ( ( month([F:TIP]STRDAT) = month(FMOIS) & year([F:TIP]STRDAT) = year(FMOIS) )
#&   |( month([F:TIP]ENDDAT) = month(FMOIS) & year([F:TIP]ENDDAT) = year(FMOIS) )
#&   |( [F:TIP]STRDAT < FMOIS               & [F:TIP]ENDDAT > FMOIS             ) )
#69754
 If find(TBCOD(T),EVTPGN) &
&  (
&    ( [F:TIP]STRDAT >= DMOIS & [F:TIP]STRDAT <= FMOIS )
&  | ( [F:TIP]ENDDAT >= DMOIS & [F:TIP]ENDDAT <= FMOIS )
&  | ( [F:TIP]STRDAT <  DMOIS & [F:TIP]ENDDAT >  FMOIS )
&                                                        )

  If    TYPPGN(T) > [F:TIP]TYPPGN
   TYPPGN(T) = 3
  Elsif TYPPGN(T) < [F:TIP]TYPPGN
   TYPPGN(T) = [F:TIP]TYPPGN - TYPPGN(T)
  Else
   TYPPGN(T) = [F:TIP]TYPPGN
  Endif
 Endif

Next
#LIPET - 2017-05-15 - END
#**
###DBA 11/08 : calcul de variables de type formules E_*
Gosub TR_NBJOURS From TRTFORVAR
###

Call DEBTRANS From GLOCK
Gosub TR2
End

$TR2
GOK = 1
Trbegin [VLA]
#Variables en MAJ Auto de type Détail des temps
For [VRA]VRA0 Where TYPINI=4 & ( [F:VRA]TYPMAJ=1 | [F:VRA]TYPMAJ=3)
 If [F:VRA]TYPMAJ=1
  VALEUR = 0
#** V7 : Waiting Time Mangement **#
#*!
#LIPET - 2017-05-15 - START
  For T=1 To NBCOD
   If pat(TBCOD(T),[F:VRA]TIMCOD)
    Case [F:VRA]TYPVAL
      When 1 : # Jours
       VALEUR += JRS(T)
      When 2 : # Heures
       VALEUR += HRE(T)
      When 5 : #Prolongations
       VALEUR = TYPPGN(T)
    Endcase
    TDAT = DAT_COD(T)
   Endif
  Next T
#LIPET - 2017-05-15 - END
#**
#*!
 Else
  Onerrgo RIEN
  ERR = 0
  VALEUR = evalue([F:VRA]FORVAR)
  Onerrgo
 Endif
 If VALEUR<>0
  If [F:ADI]CODE<>[F:VRA]PAGEMP
   Read [ADI]CODE = 10337;[F:VRA]PAGEMP
  Endif
  ARRONDI = 10^(-[F:ADI]N1)
  VALEUR = arr(VALEUR,ARRONDI)
  #LIPET - 2017-05-15 - START
  #Read [VLA]VLA0 = 4;"";"";"";MATRI;DATPAY;[F:VRA]COD;BULLETIN
  Read [VLA]VLA0 = 4;GCURLEG;"";"";MATRI;DATPAY;[F:VRA]COD;BULLETIN
  #LIPET - 2017-05-15 - END
  If fstat=1
   GOK = -1 : GLOCK = "$VALEUR"-MATRI-[F:VRA]COD : Break
  Elsif fstat
   Raz [F:VLA]
   [F:VLA]TYP    = 4
   [F:VLA]VARCOD = [F:VRA]COD
   [F:VLA]BUL    = BULLETIN
   [F:VLA]EMP    = MATRI
   [F:VLA]DAT    = DATPAY
   [F:VLA]VARVAL = VALEUR
   Write [VLA]
  Else
   [F:VLA]VARVAL = VALEUR
   Rewrite [VLA]
  Endif
  If fstat
   GOK = 0 : Call FSTA("VLA") From GLOCK : Break
  Endif
  TEXTE = ""
  If [F:VRA]TIMCMT<>"" or [F:VRA]CMTDET=2
   If [F:VRA]TIMCMT<>""
    Onerrgo RIEN
    ERR = 0
    TEXTE = evalue([F:VRA]TIMCMT)
    Onerrgo
   Endif
   #65792
   #Delete [BCB] Where CODBLB="VARTXT" & IDENT1=[F:VRA]COD & IDENT2=MATRI & IDENT3=format$("D:4Y2M2D",DATPAY)
   Delete [BCB] Where CODBLB="VARTXT" & IDENT1=[F:VRA]COD & IDENT2=BULLETIN
   If fstat=1
    GOK = -1 : GLOCK = "$BCLOB VARTXT"-[F:VRA]COD-BULLETIN : Break
   Endif
   Filter [RUB] Where (TEXVRI(0)=[F:VRA]COD or TEXVRI(1)=[F:VRA]COD) and LEG=GCURLEG
   For [RUB]RUB0
    Raz [F:BCB]
    [F:BCB]CODBLB = "VARTXT"
    [F:BCB]IDENT1 = [F:VRA]COD
    #65792
    #[F:BCB]IDENT2 = MATRI
    #[F:BCB]IDENT3 = format$("D:4Y2M2D",DATPAY)
     [F:BCB]IDENT2 = BULLETIN
     [F:BCB]IDENT3 = ""
    [F:BCB]IDENT4 = [F:RUB]COD
    If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
    If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
    If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
    If !ERR & TEXTE<>"" : MESSAGE=TEXTE : Endif
    If [F:VRA]CMTDET=2
#** V7 : Waiting Time Mangement **#
#*!
#LIPET - 2017-05-15 - START
     For T=1 To NBCOD
      If pat(TBCOD(T),[F:VRA]TIMCOD)
       J = 1
       While J<=NBR_CMT(T)
        MESSAGE-=CMT_COD(T,J)
        J += 1
       Wend
      Endif
     Next T
#LIPET - 2017-05-15 - END
#**
    Endif
    If MESSAGE<>""
     Setlob [F:BCB]CLOB With MESSAGE
     Write [BCB]
     If fstat
      GOK = 0 : Call FSTA("BCB") From GLOCK : Break 2
     Endif
    Endif
   Next
   Filter [RUB]
  Endif
  If GTRACE<>"" & TRA
   Call ECR_TRACE(mess(25,10709,1)-[F:VRA]COD-":"-num$([F:VLA]VARVAL),0) From GESECRAN
   # Mise à jour variable
  Endif
 Endif
Next
If   GOK<0 : Goto ROLL_TR2
Elsif !GOK : Goto AB_TR2
Endif
#46165
Update [VEP2] Where BUL=BULLETIN With STA=1 :#Etat saisi
If fstat
 GOK=0 : Goto AB_TR2
Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$RIEN
ERR = errn
Resume


#######################################################################
## Mise à jour dans TIMREGUL de la zone DATBUL
#######################################################################
$TR5
GOK = 1
#** V7 : Waiting Time Mangement **#
#*!
#LIPET - 2017-05-15 - START
Trbegin [TIP]
 Filter [VEP3] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & CTRDAT=CTRD
 Read [VEP3]VEP0 Last
 If !fstat & [F:VEP3]PST<=1
  For [TIP]TIP1 Where REFNUM=MATRI & CTRNUM=CTR & FLGBUL=2 & DATBUL=[0/0/0]
   Readlock [F:TIP]=
   If fstat=1
    GOK = -1 : GLOCK = "$TIMEMP"-MATRI-CTR-num$([F:TIP]STRDAT) : Break
   Else
    [F:TIP]DATBUL = DATPAY
    Rewrite [TIP]
    If fstat
     GOK = 0 : Call FSTA("TIP") From GLOCK : Break
    Endif
   Endif
  Next
 Endif
 If GOK=-1
  Goto ROLL_TR5
 Elsif GOK=0
  Goto AB_TR5
 Endif
Commit
#LIPET - 2017-05-15 - END
#**
#*!
Return

$AB_TR5
Rollback
Return

$ROLL_TR5
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR5 : Endif



######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTPAY) 28/02/2006 15:23:34 (DBA)
######################################################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR
Call AS_SRV(VALEUR) From DIVPAYE
End

Subprog C_ALLPRF(VALEUR)
Variable Integer VALEUR
Call C_ALLPRF(VALEUR) From DIVPAYE
End

Subprog AS_PRF(VALEUR)
Variable Char  VALEUR
Call AS_PRF(VALEUR) From DIVPAYE
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
#positionnement sur l'enregistrement le plus proche
If clalev([F:VEP])=0 : Local File VALEMP    [VEP] : Endif
If VALEUR<>[0/0/0]
 Gosub FILTRE
 Filter [F:VEP] Where [F:VEP]PYRDAT<=VALEUR & evalue(CRITERE)
# 49457
# Read [F:VEP]VEP0 Last
 Read [F:VEP]VEP4 Last
 Filter [VEP]
 If fstat<=2
  VALEUR = [F:VEP]PYRDAT
 Endif
Endif
End

