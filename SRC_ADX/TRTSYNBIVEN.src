#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
# TRTSYNBIVEN      Fonctions pour la Business Intelligence           Ventes #
#############################################################################

####################################################################################
# 12/01/2010 (SYMEU) : Problème dans la requête sql avec les demandes de livraison #
# Fiche 61511          fermes quand on est sous sql                                #
####################################################################################

###################################################################
## ACTION Mise à jour des tables de faits X3                      #
###################################################################
$ACTION
Case ACTION
 When "AVANT_FAT"  : Gosub AVANT_FAT
 When "DEBUT_FAT"  : Gosub DEBUT_FAT
 When "FIN_FAT"    : Gosub FIN_FAT
Endcase
Return

#############################################################################
# Ouverture des tables qui sont appelées par les fonctions alimentant les
# champs de la table de faits
#############################################################################
$AVANT_FAT

#Case [F:ABV]CODREG
#Endcase

Return

#############################################################################
$AVANT_FAT_COMMUN
  #--- Méthode TRTX3BI.GETSYSCUR
  If !clalev([F:ADW])   : Local File =GDOSSIER+".ADOVAL"    [ADW] : Endif
  If !clalev([F:ADP])   : Local File =GDOSSIER+".ADOPAR"    [ADP] : Endif
  #--- Méthode TRTX3BI.CNVAMT
  If !clalev([F:TCH])   : Local File =GDOSSIER+".TABCHANGE" [TCH] : Endif
  #--- Méthode TRTX3BI.CNVQTY
  If !clalev([F:ITM])   : Local File =GDOSSIER+".ITMMASTER" [ITM] : Endif
  #--- Méthode TRTX3BI.SETCOA et SETACC
  If !clalev([F:GCM])   : Local File =GDOSSIER+".GACM"      [GCM] : Endif
  If !clalev([F:LED])   : Local File =GDOSSIER+".GLED"      [LED] : Endif
  #--- Méthode TRTX3BI.SETACC
  If !clalev([F:GAC])   : Local File =GDOSSIER+".GACCOUNT"  [GAC] : Endif

Return


#############################################################################
$DEBUT_FAT

  # ACA (2010-03-25) Bug 63342 : Plantage sur K=0
  K = instr(1,TBAPP(R),"~")
  GDOSSIER=left$(TBAPP(R),K-1)
  Gosub AVANT_FAT_COMMUN
  Gosub DEBUT_FAT From TRTVENBI

  #  Variable globale pour récupérer la devise dossier
  If dim(GBICURFOLD)<=0 Then
    Global Char GBICURFOLD(GLONCUR)
  Endif
  GBICURFOLD = func TRTX3BI.GETSYSCUR()

Return

#############################################################################
$FIN_FAT
Gosub DECL_VAR

Case TABLE
 When "F_SALES"     : Gosub FIN_SALES  # Table Faits SALES
Endcase

Return

#############################################################################
# Alimentation de la table de faits SALES avec des données supplémentaires
#############################################################################
$FIN_SALES
If [F:ABV]CODREG = "SORDER" Then
  Local File =DOSSIER+"."+TABLE [BBB_]
  Gosub FIN_SALES_ORDER
  Close Local File [BBB_]
Endif
Return

##############################################################################################
# Alimentation de la table de faits SALES avec les demandes de livraison issues de SORDERQ   #
##############################################################################################
$FIN_SALES_ORDER

  Local Char WREQ3 (255)(2) : Raz WREQ3 # Requete pour lire SORDERP
  Local Char STU(GLONUOM), SSU(GLONUOM), SALFCY_CUR(GLONCUR), SYSCUR(GLONCUR), BPCRSK(GLONBPR), FINRSPFCY(GLONFCY)  # FGR 09/10/2014 : X3SUIVI102999 : manquait les longueurs
  Decimal MONTANT

  # Pour que, dans les fonctions BICPT.SETDIE(...), BICPT.SETCCE(...), la variable globale soit rechargée
  # avec les données du bon dossier et que les tables soient ouvertes sur le bon dossier
  If dim([V]GBIDIELIST)>0 : Kill [V]GBIDIELIST : Endif
  If clalev([F:ADW])>0 : Close Local File [ADW] : Endif
  If clalev([F:ADP])>0 : Close Local File [ADP] : Endif
  If clalev([F:CPY])>0 : Close Local File [CPY] : Endif

  # Lecture de la devise système
  SYSCUR=func TRTX3BI.GETSYSCUR()

  If filinfo(filpath("FIL","SORDERQ","fde",GDOSSIER),0)>0
    Call ECR_TRACE("**   TRTSYNBIVEN : SORDERQ"-mess(6,2246,1)-"SORDER",0) From GESECRAN

  #--CPO 89971 Alimentation avec les commandes ouvertes ne fonctionnait pas
  ## Requête de sélection des enregistrements de SORDERQ
  #WREQ(0) ="select SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.SOQSEQ_0, SOQ.ITMREF_0, SOP.LINTYP_0, "
  #WREQ(0)+="SOQ.QTY_0, SOQ.QTYSTU_0, SOQ.TDLQTYSTU_0, SOP.NETPRINOT_0, SOP.NETPRIATI_0, "
  #WREQ(1) ="SOQ.DEMDLVDAT_0, SOH.ORDDAT_0, SOH.PJT_0, "
  #WREQ(1)+="SOQ.CPY_0, SOH.BETCPY_0, SOQ.SALFCY_0, SOQ.STOFCY_0, SOH.BETFCY_0, "
  #WREQ(2) ="SOP.PFM_0, SOP.REP1_0, SOP.REP2_0, SOP.FOCFLG_0, "
  #WREQ(2)+="SOH.BPCORD_0, SOH.BPCINV_0, SOH.BPCPYR_0, SOH.BPCGRU_0, SOH.CUR_0, SOH.CHGTYP_0 "
  #WREQ(2)+="From "+GDOSSIER+".SORDERQ SOQ,"+GDOSSIER+".SORDER SOH,"+GDOSSIER+".SORDERP SOP "
  #WREQ(3) ="Where SOQ.SOHCAT_0=4 and SOQ.DEMSTA_0=1 and SOH.SOHNUM_0=SOQ.SOHNUM_0 and SOP.SOHNUM_0=SOQ.SOHNUM_0 "
  #WREQ(3)+="and SOP.SOPLIN_0=SOQ.SOPLIN_0 and SOP.SOPSEQ_0=SOQ.SOQSEQ_0 "
  #WREQ(3)+="order by SOH.SOHNUM_0"

  # Requête de sélection des enregistrements de SORDERQ
  WREQ(0) ="select SOQ.SOHNUM_0, SOQ.SOPLIN_0, SOQ.SOQSEQ_0, SOQ.ITMREF_0, "
  WREQ(0)+="SOQ.QTY_0, SOQ.QTYSTU_0, SOQ.TDLQTYSTU_0, "
  WREQ(1) ="SOQ.DEMDLVDAT_0, SOH.ORDDAT_0, SOH.PJT_0, "
  WREQ(1)+="SOQ.CPY_0, SOH.BETCPY_0, SOQ.SALFCY_0, SOQ.STOFCY_0, SOH.BETFCY_0, "
  WREQ(2) ="SOH.BPCORD_0, SOH.BPCINV_0, SOH.BPCPYR_0, SOH.BPCGRU_0, SOH.CUR_0, SOH.CHGTYP_0 , SOQ.SHIDAT_0 "
  WREQ(2)+="From "+GDOSSIER+".SORDERQ SOQ,"+GDOSSIER+".SORDER SOH "
  WREQ(3) ="Where SOQ.SOHCAT_0=4 and SOQ.DEMSTA_0=1 and SOH.SOHNUM_0=SOQ.SOHNUM_0 "
  WREQ(3)+="Order by SOQ.SOHNUM_0, SOQ.SOPLIN_0"

  #    For (Char SOHNUM(20), Integer SOPLIN, Integer SOQSEQ, Char ITMREF(20), Integer LINTYP,
  #&       Decimal QTY, Decimal QTYSTU, Decimal TDLQTYSTU, Decimal NETPRINOT, Decimal NETPRIATI,
  #&       Date DEMDLVDAT, Date ORDDAT, Char PJT(20),
  #&       Char CPY(5), Integer BETCPY, Char SALFCY(5), Char STOFCY(5), Integer BETFCY,
  #&       Decimal PFM, Char REP1(GLONREP), Char REP2(GLONREP), Integer FOCFLG,
  #&       Char BPCORD(15), Char BPCINV(15), Char BPCPYR(15), Char BPCGRU(15), Char CUR(3), Integer CHGTYP)
  #&       From WBASE Sql WREQ(0..3) As [REQ_]
# FGR 10/10/2014 : X3SUIVI102999
#  For (Char SOHNUM(20), Integer SOPLIN, Integer SOQSEQ, Char ITMREF(20),
#&       Decimal QTY, Decimal QTYSTU, Decimal TDLQTYSTU,
#&       Date DEMDLVDAT, Date ORDDAT, Char PJT(20),
#&       Char CPY(5), Integer BETCPY, Char SALFCY(5), Char STOFCY(5), Integer BETFCY,
#&       Char BPCORD(15), Char BPCINV(15), Char BPCPYR(15), Char BPCGRU(15), Char CUR(3), Integer CHGTYP , Date SHIDAT)
#&       From WBASE Sql WREQ(0..3) As [REQ_]
  For (Char SOHNUM(GLONVCR), Integer SOPLIN, Integer SOQSEQ, Char ITMREF(GLONITM),
&       Decimal QTY, Decimal QTYSTU, Decimal TDLQTYSTU,
&       Date DEMDLVDAT, Date ORDDAT, Char PJT(GLONPJT),
&       Char CPY(GLONCPY), Integer BETCPY, Char SALFCY(GLONFCY), Char STOFCY(GLONFCY), Integer BETFCY,
&       Char BPCORD(GLONBPR), Char BPCINV(GLONBPR), Char BPCPYR(GLONBPR), Char BPCGRU(GLONBPR), Char CUR(GLONCUR), Integer CHGTYP , Date SHIDAT)
&       From WBASE Sql WREQ(0..3) As [REQ_]
#--/
      Read [BBB_]SIH0 = GDOSSIER;[F:ABV]CODREG;0;[REQ_]SOHNUM+"~"+num$([REQ_]SOPLIN)+"~"+num$([REQ_]SOQSEQ)
      If fstat
        # Lecture de l'article
        Call GET_ITM_UNITS([REQ_]ITMREF,STU,SSU) From TRTX3BI
        # Lecture de la devise du site
        SALFCY_CUR = func TRTX3BI.GETCUR([REQ_]SALFCY)
        # Lecture du client groupe et du client risque
        Call GET_BPC_RSK([REQ_]BPCORD,BPCRSK) From TRTX3BI
        # Lecture de LEGCPY de F:FCY
        Call GET_FINRSPFCY([REQ_]SALFCY,FINRSPFCY) From TRTX3BI
        Raz [BBB_]
        # Alimentation de la clé primaire SIH0
        [BBB_]ADOS=GDOSSIER
        [BBB_]AREG=[F:ABV]CODREG
        [BBB_]AIND=0
        [BBB_]ACLE=[REQ_]SOHNUM+"~"+num$([REQ_]SOPLIN)+"~"+num$([REQ_]SOQSEQ)
        # Alimentation de la table SALES avec les demandes de livraison

        #--CPO 89971 depuis SOP
        #[BBB_]DOC=20
        [BBB_]DOC=13 :# Commandes ouvertes
        #
        #--CPO 89971 depuis SOP
        #        [BBB_]LINDOC=([REQ_]FOCFLG = 3) * 5 + !([REQ_]FOCFLG = 3) * ( (find([REQ_]LINTYP,1,10,11,12,13)) + !(find([REQ_]LINTYP,1,10,11,12,13)) * ( (find([REQ_]LINTYP,2, 6) <> 0) * 3 +
# !(find([REQ_]
        #& LINTYP,2,6) <> 0) * 4 ) )
        #--
        [BBB_]DOSSIER=GDOSSIER
        [BBB_]DAT=[REQ_]ORDDAT
        [BBB_]CPY=[REQ_]CPY
        [BBB_]FCY=FINRSPFCY
        #--CPO 81287 - Rajout de if dim(), en plus des CCE,COA,DIE et ACC
        If dim([BBB_]SALFCY)>0 : [BBB_]SALFCY=[REQ_]SALFCY  : Endif
        If dim([BBB_]STOFCY)>0 : [BBB_]STOFCY=[REQ_]STOFCY  : Endif
        If dim([BBB_]BPCORD)>0 : [BBB_]BPCORD=[REQ_]BPCORD  : Endif
        If dim([BBB_]BPCDLV)>0 : [BBB_]BPCDLV=[REQ_]BPCORD  : Endif
        If dim([BBB_]BPCINV)>0 : [BBB_]BPCINV=[REQ_]BPCINV  : Endif
        If dim([BBB_]BPCPYR)>0 : [BBB_]BPCPYR=[REQ_]BPCPYR  : Endif
        If dim([BBB_]BPCGRU)>0 : [BBB_]BPCGRU=[REQ_]BPCGRU  : Endif
          #--CPO Erreur suite synchro pour test 81556
        #If dim([BBB_]BPCRSK)>0 : [BBB_]BPCRSK=[REQ_]BPCRSK  : Endif
        If dim([BBB_]BPCRSK)>0 : [BBB_]BPCRSK=BPCRSK  : Endif
          #--/CPO
        #[BBB_]PJT=[REQ_]PJT
        If dim([BBB_]CUR)>0    : [BBB_]CUR=[REQ_]CUR        : Endif
        #--CPO 89971 depuis SOP
        #If dim([BBB_]REP1)>0   : [BBB_]REP1=[REQ_]REP1      : Endif
        #If dim([BBB_]REP2)>0   : [BBB_]REP2=[REQ_]REP2      : Endif
        #--
        If dim([BBB_]ITMREF)>0 : [BBB_]ITMREF=[REQ_]ITMREF  : Endif
        #--CPO 89971 depuis SOP
        #If dim([BBB_]CPNITMREF)>0
        #  [BBB_]CPNITMREF=string$ ( !(find([REQ_]LINTYP,1,2,6,10,11,12,13) <> 0) , [REQ_]ITMREF )
        #Endif
        #--
        If dim([BBB_]AMTSIG)>0 : [BBB_]AMTSIG=1             : Endif
        #--/CPO
        [BBB_]SOHNUM=[REQ_]SOHNUM   :#--CPO Pas de dim car champ de la clé !
        [BBB_]SOPLIN=[REQ_]SOPLIN   :#--CPO Pas de dim car champ de la clé !
        [BBB_]SOQSEQ=[REQ_]SOQSEQ   :#--CPO Pas de dim car champ de la clé !
        # Attention : champs soumis à code activité
        If dim([BBB_]DIE1)>0  : [BBB_]DIE1=func BICPT.SETDIE(1,"CAL")       : Endif
        If dim([BBB_]DIE2)>0  : [BBB_]DIE2=func BICPT.SETDIE(2,"CAL")       : Endif
        If dim([BBB_]DIE3)>0  : [BBB_]DIE3=func BICPT.SETDIE(3,"CAL")       : Endif
        If dim([BBB_]DIE4)>0  : [BBB_]DIE4=func BICPT.SETDIE(4,"CAL")       : Endif
        If dim([BBB_]DIE5)>0  : [BBB_]DIE5=func BICPT.SETDIE(5,"CAL")       : Endif
        If dim([BBB_]DIE6)>0  : [BBB_]DIE6=func BICPT.SETDIE(6,"CAL")       : Endif
        If dim([BBB_]DIE7)>0  : [BBB_]DIE7=func BICPT.SETDIE(7,"CAL")       : Endif
        If dim([BBB_]DIE8)>0  : [BBB_]DIE8=func BICPT.SETDIE(8,"CAL")       : Endif
        If dim([BBB_]DIE9)>0  : [BBB_]DIE9=func BICPT.SETDIE(9,"CAL")       : Endif
        If dim([BBB_]DIE10)>0 : [BBB_]DIE10=func BICPT.SETDIE(10,"CAL")     : Endif
        If dim([BBB_]CCE1)>0  : [BBB_]CCE1=func BICPT.SETCCE(1,"CAL")       : Endif
        If dim([BBB_]CCE2)>0  : [BBB_]CCE2=func BICPT.SETCCE(2,"CAL")       : Endif
        If dim([BBB_]CCE3)>0  : [BBB_]CCE3=func BICPT.SETCCE(3,"CAL")       : Endif
        If dim([BBB_]CCE4)>0  : [BBB_]CCE4=func BICPT.SETCCE(4,"CAL")       : Endif
        If dim([BBB_]CCE5)>0  : [BBB_]CCE5=func BICPT.SETCCE(5,"CAL")       : Endif
        If dim([BBB_]CCE6)>0  : [BBB_]CCE6=func BICPT.SETCCE(6,"CAL")       : Endif
        If dim([BBB_]CCE7)>0  : [BBB_]CCE7=func BICPT.SETCCE(7,"CAL")       : Endif
        If dim([BBB_]CCE8)>0  : [BBB_]CCE8=func BICPT.SETCCE(8,"CAL")       : Endif
        If dim([BBB_]CCE9)>0  : [BBB_]CCE9=func BICPT.SETCCE(9,"CAL")       : Endif
        If dim([BBB_]CCE10)>0 : [BBB_]CCE10=func BICPT.SETCCE(10,"CAL")     : Endif
        If dim([BBB_]COA1)>0  : [BBB_]COA1=func TRTX3BI.SETCOA(1,[REQ_]CPY) : Endif
        If dim([BBB_]COA2)>0  : [BBB_]COA2=func TRTX3BI.SETCOA(2,[REQ_]CPY) : Endif
        If dim([BBB_]COA3)>0  : [BBB_]COA3=func TRTX3BI.SETCOA(3,[REQ_]CPY) : Endif
        If dim([BBB_]ACC1)>0  : [BBB_]ACC1=func TRTX3BI.SETACC(1,[REQ_]CPY) : Endif
        If dim([BBB_]ACC2)>0  : [BBB_]ACC2=func TRTX3BI.SETACC(2,[REQ_]CPY) : Endif
        If dim([BBB_]ACC3)>0  : [BBB_]ACC3=func TRTX3BI.SETACC(3,[REQ_]CPY) : Endif
        #--CPO 81287 - Rajout de if dim(), en plus des CCE,COA,DIE et ACC
        If dim([BBB_]FLOW)>0
          [BBB_]FLOW=([REQ_]BETCPY - 1) * 2 + !( [REQ_]BETCPY - 1) * ( ([REQ_]BETFCY - 1) * 3 + !( [REQ_]BETFCY - 1))
        Endif

        #--CPO 89971 depuis SOP
        # Pour chaque demande de livraison, je vais rechercher le bon enregistrement dans SORDERP, pour valoriser la demande
        WREQ3(0) ="select SOP.LINTYP_0, SOP.NETPRINOT_0, SOP.NETPRIATI_0, "
        WREQ3(0)+="SOP.PFM_0, SOP.REP1_0, SOP.REP2_0, SOP.FOCFLG_0 "
        WREQ3(0)+="From "+GDOSSIER+".SORDERP SOP "
        WREQ3(1)="Where SOP.SOHNUM_0='"+[REQ_]SOHNUM+"' and SOP.SOPLIN_0="+num$([REQ_]SOPLIN)+" and SOP.STRDAT_0<="
        If WBASE = "3" Then # Oracle
           WREQ3(1)+="TO_DATE('"+[REQ_]DEMDLVDAT+"','YYYYMMDD')"
        Else
           WREQ3(1)+="convert(char,"+[REQ_]DEMDLVDAT+")"
        Endif
        WREQ3(1)+=" Order by SOP.STRDAT_0 desc"
        #--
        For (Integer LINTYP, Decimal NETPRINOT, Decimal NETPRIATI,
&            Decimal PFM, Char REP1(GLONREP), Char REP2(GLONREP), Integer FOCFLG)
&            From WBASE Sql WREQ3(0..1) As [RE3_]
          # Alimentation de la dimension SORDER avec les demandes de livraison

          #--CPO 89971 depuis SOP déplacé
          [BBB_]LINDOC=([RE3_]FOCFLG = 3) * 5 + !([RE3_]FOCFLG = 3) * ( (find([RE3_]LINTYP,1,10,11,12,13)) + !(find([RE3_]LINTYP,1,10,11,12,13)) * ( (find([RE3_]LINTYP,2, 6) <> 0) * 3 + !(find([RE3_]
& LINTYP,2,6) <> 0) * 4 ) )
          #--
          #--CPO 89971 depuis SOP déplacé
          If dim([BBB_]REP1)>0   : [BBB_]REP1=[RE3_]REP1      : Endif
          If dim([BBB_]REP2)>0   : [BBB_]REP2=[RE3_]REP2      : Endif
          #--
          #--CPO 89971 depuis SOP déplacé
          If dim([BBB_]CPNITMREF)>0
            [BBB_]CPNITMREF=string$ ( !(find([RE3_]LINTYP,1,2,6,10,11,12,13) <> 0) , [REQ_]ITMREF )
          Endif
          #--

          If dim([BBB_]QTYSOH_US)>0
            [BBB_]QTYSOH_US=[REQ_]QTYSTU * (find( [RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif
          If dim([BBB_]QTYSOH_ST)>0
            [BBB_]QTYSOH_ST=func TRTX3BI.CNVQTY([REQ_]QTYSTU, STU, SSU, [REQ_]ITMREF, "SOQ", [REQ_]SOHNUM, [REQ_]SOPLIN, [REQ_]SOQSEQ, 1, 0) *(find( [RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif
          If dim([BBB_]CPNQTYSOH_US)>0
            [BBB_]CPNQTYSOH_US=[REQ_]QTYSTU*!(find( [RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif
          If dim([BBB_]CPNQTYSOH_ST)>0
            [BBB_]CPNQTYSOH_ST=func TRTX3BI.CNVQTY([REQ_]QTYSTU, STU, SSU, [REQ_]ITMREF, "SOQ", [REQ_]SOHNUM, [REQ_]SOPLIN, 0, 1, 0)*(find( [RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif
          If dim([BBB_]QTYSOD_US)>0
            [BBB_]QTYSOD_US=[REQ_]TDLQTYSTU*(find([RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif
          If dim([BBB_]QTYSOD_ST)>0
            [BBB_]QTYSOD_ST=func TRTX3BI.CNVQTY([REQ_]TDLQTYSTU, STU, SSU, [REQ_]ITMREF, "SOQ", [REQ_]SOHNUM, [REQ_]SOPLIN, 0, 1, 0)*(find( [RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif
          If dim([BBB_]CPNQTYSOD_US)>0
            [BBB_]CPNQTYSOD_US=[REQ_]TDLQTYSTU*!(find( [RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif
          If dim([BBB_]CPNQTYSOD_ST)>0
            [BBB_]CPNQTYSOD_ST=func TRTX3BI.CNVQTY([REQ_]TDLQTYSTU, STU, SSU, [REQ_]ITMREF, "SOQ", [REQ_]SOHNUM, [REQ_]SOPLIN, 0, 1, 0)*!(find( [RE3_]LINTYP,1,2,6,10,11,12,13) <> 0)
          Endif

          MONTANT = [RE3_]NETPRINOT*[REQ_]QTY
          If dim([BBB_]AMTNOT_SOH)  >0 : [BBB_]AMTNOT_SOH=MONTANT : Endif
          If dim([BBB_]AMTNOT_SOH_C)>0
            [BBB_]AMTNOT_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
          Endif
          If dim([BBB_]AMTNOT_SOH_F)>0
            [BBB_]AMTNOT_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
          Endif

          MONTANT = [RE3_]NETPRIATI*[REQ_]QTY
          If dim([BBB_]AMTATI_SOH)  >0 : [BBB_]AMTATI_SOH=MONTANT : Endif
          If dim([BBB_]AMTATI_SOH_C)>0
            [BBB_]AMTATI_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
          Endif
          If dim([BBB_]AMTATI_SOH_F)>0
            [BBB_]AMTATI_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
          Endif

          MONTANT = [RE3_]PFM*[REQ_]QTY
          If dim([BBB_]PFM_SOH)  >0 : [BBB_]PFM_SOH=MONTANT : Endif
          If dim([BBB_]PFM_SOH_C)>0
            [BBB_]PFM_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
          Endif
          If dim([BBB_]PFM_SOH_F)>0
            [BBB_]PFM_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
          Endif

          Break

        Next
        #--/

        #--
        #--CPO 89971 depuis SOP
        #MONTANT=func TRTVENBI.GETSALDCA(20,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,2)
        MONTANT=func TRTVENBI.GETSALDCA(13,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,2)
        #--
        If dim([BBB_]DISAMT_SOH)  >0 : [BBB_]DISAMT_SOH=MONTANT : Endif
        If dim([BBB_]DISAMT_SOH_C)>0
          [BBB_]DISAMT_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]DISAMT_SOH_F)>0
          [BBB_]DISAMT_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        #--CPO 89971 depuis SOP
        #MONTANT=func TRTVENBI.GETSALDCA(20,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,1)
        MONTANT=func TRTVENBI.GETSALDCA(13,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,1)
        If dim([BBB_]EXPAMT_SOH)  >0 : [BBB_]EXPAMT_SOH=MONTANT : Endif
        If dim([BBB_]EXPAMT_SOH_C)>0
          [BBB_]EXPAMT_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]EXPAMT_SOH_F)>0
          [BBB_]EXPAMT_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        #--CPO 89971 depuis SOP
        #MONTANT=func TRTVENBI.GETSFIDCA(20,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,2)
        MONTANT=func TRTVENBI.GETSFIDCA(13,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,2)
        If dim([BBB_]DISDTA_SOH)  >0 : [BBB_]DISDTA_SOH=MONTANT : Endif
        If dim([BBB_]DISDTA_SOH_C)>0
          [BBB_]DISDTA_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]DISDTA_SOH_F)>0
          [BBB_]DISDTA_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        #--CPO 89971 depuis SOP
        #MONTANT=func TRTVENBI.GETSFIDCA(20,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,1)
        MONTANT=func TRTVENBI.GETSFIDCA(13,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ, [REQ_]CUR,1)
        If dim([BBB_]EXPDTA_SOH)  >0 : [BBB_]EXPDTA_SOH=MONTANT : Endif
        If dim([BBB_]EXPDTA_SOH_C)>0
          [BBB_]EXPDTA_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]EXPDTA_SOH_F)>0
          [BBB_]EXPDTA_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        #--CPO 89971 depuis SOP
        #MONTANT=func TRTVENBI.GETCOMREP(20,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ,1)
        MONTANT=func TRTVENBI.GETCOMREP(13,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ,1)
        If dim([BBB_]REPAM1_SOH)  >0 : [BBB_]REPAM1_SOH=MONTANT : Endif
        If dim([BBB_]REPAM1_SOH_C)>0
          [BBB_]REPAM1_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]REPAM1_SOH_F)>0
          [BBB_]REPAM1_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        #--CPO 89971 depuis SOP
        #MONTANT=func TRTVENBI.GETCOMREP(20,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ,2)
        MONTANT=func TRTVENBI.GETCOMREP(13,[REQ_]SOHNUM,[REQ_]SOPLIN,[REQ_]SOQSEQ,2)
        If dim([BBB_]REPAM2_SOH)  >0 : [BBB_]REPAM2_SOH=MONTANT : Endif
        If dim([BBB_]REPAM2_SOH_C)>0
          [BBB_]REPAM2_SOH_C=func TRTX3BI.CNVAMT([REQ_]CUR, SALFCY_CUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]REPAM2_SOH_F)>0
          [BBB_]REPAM2_SOH_F=func TRTX3BI.CNVAMT([REQ_]CUR, SYSCUR, SALFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        #--/CPO

        #--CPO 81287 - Rajout de if dim(), en plus des CCE,COA,DIE et ACC
         If dim([BBB_]PJT)>0
           # Issue 78039 - 2016-08-09 by CPO : PJT management in BI
           #[BBB_]PJT=[REQ_]PJT
           [BBB_]PJT=func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT_OPPNUM(GACTX, [REQ_]PJT)
           # End issue 78039
         Endif
        #--/CPO
        CHAINE = [BBB_]SOHNUM-num$([BBB_]SOPLIN)-num$([BBB_]SOQSEQ)
        Write [BBB_]
        If fstat
          Call ERREUR(TABLE-CHAINE,1) From DOSDIC
        Else
          CRE += 1
          If [L]DET=2
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
          Endif
        Endif
      Endif
    Next
  Endif

Return
###################################################################
# Déclarations des variables de travail communes
###################################################################
$DECL_VAR
Local Char WREQ (255)(4) : Raz WREQ : # Requete générique pour base Oracle et SqlServer 7
Local Integer D
Local Integer NB_ENREG : NB_ENREG=0
Local Char WBASE(1)       : WBASE=" "  # FGR 09/10/2014 : X3SUIVI102999 : Manquait (1)
# Alimentation du type de Database
Gosub ALIM_WBASE

Return

###################################################################
## ALIM_WBASE alimentation de la variable donnant le type de       #
## DATABASE à partir de GTYPDBA                                   #
###################################################################
$ALIM_WBASE
Case GTYPDBA
  When 1 : WBASE = "3" : # Oracle
  When 2 : WBASE = "5" : # Sql
  When 3 : WBASE = "2" : # Cisam
  When 4 : WBASE = "4" : # DB2
Endcase
Return

