#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTITC21   Remplacement de la fonction FUNITC par GESHIC      Module TC #
##########################################################################
# - Suppression fonction FUNHIC
# - Suppression action FUNHIC
# - Suppression fenêtre IHIC
# - Suppression objet HCL
##########################################################################
Local Char DOSSIER(30)

DOSSIER = nomap
Call SAIDOS(DOSSIER, "") From SAIDOS
If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
        Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC21(DOSSIER) 
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End

##########################################################################
Subprog MAJ_UTITC21(APPLI)
Value Char APPLI

Local Char    TRTANU(GLONAFC), CODE(3)

If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif  # Pour Trbegin

Call ECR_TRACE("UTITC21: Process Start on : "+APPLI, 0) From GESECRAN

Trbegin [ADS]
#----- Suppression de la fonction FUNHIC -----#
If filinfo(filpath("FIL", "AFONCTION", "fde", APPLI), 0) > 0
    Call ECR_TRACE("Delete FUNHIC function", 0) From GESECRAN
    Local File =APPLI+".AFONCTION" [AFC]
    Delete [AFC]CODEXT="FUNHIC"
    Local File =APPLI+".AFCTPRF" [AFP]
    Delete [AFP] Where FNC="FUNHIC"
    Local File =APPLI+".AMENUSER" [AMU]
    Delete [AMU] Where FONCTION="FUNHIC"
Endif
#----- Suppression de l'action FUNHIC -----#
If filinfo(filpath("FIL", "ACTION", "fde", APPLI), 0) > 0
    Call ECR_TRACE("Delete FUNHIC action", 0) From GESECRAN
    Local File =APPLI+".ACTION" [ACT]
    Local File =APPLI+".ADOCUMENT" [ADO]
    Local File =APPLI+".ADOCCLB"   [ADH]
    Call EFFACE_DOC("ACT","FUNHIC") From SUBADO
    Delete [ACT]ACTION="FUNHIC"
Endif
#----- Suppression de la fenêtre IHIC -----#
If filinfo(filpath("FIL", "AWINDOW", "fde", APPLI), 0) > 0
    Call ECR_TRACE("Delete IHIC window", 0) From GESECRAN
    Local File =APPLI+".AWINDOW" [AWI]
    Call DEL_TRTWIN("IHIC",APPLI) From MSKDIV
    Delete [AWI]AWI0="IHIC"
    Local File =APPLI+".AWINBRO" [AWB]
    Delete [AWB]AWB0="IHIC"
Endif
#----- Suppression de l'objet HCL -----#
If filinfo(filpath("FIL", "AOBJET", "fde", APPLI), 0) > 0
    Call ECR_TRACE("Delete HCL", 0) From GESECRAN
    Local File =APPLI+".AOBJET" [AOB]
    CODE = "HCL"
    TRTANU = "GES"+[L]CODE
    # On efface la fonction et ses liens (connus)
    If filinfo(filpath("FIL", "AREPORTV", "fde", APPLI), 0) > 0
        If clalev([F:ARV])=0 : Local File =APPLI+".AREPORTV" [ARV] : Endif
        Delete [ARV] Where FONCTION=TRTANU
        # FGR 09/02/2010 : X3SUIVI60986 : End pas Return
        If fstat=1 : GOK = -1 : GLOCK = "$AREPORTV"-TRTANU : End : Endif
        Call ECR_TRACE(num$(adxdlrec)-"AREPORTV deleted",0) From GESECRAN
    Endif
    If filinfo(filpath("FIL", "AFCTFCY", "fde", APPLI), 0) > 0
        If clalev([F:AFF])=0 : Local File =APPLI+".AFCTFCY" [AFF] : Endif
        Delete [AFF] Where FNC=TRTANU
        # FGR 09/02/2010 : X3SUIVI60986 : End pas Return
        If fstat=1 : GOK = -1 : GLOCK = "$AFCTFCY"-TRTANU : End : Endif
        Call ECR_TRACE(num$(adxdlrec)-"AFCTFCY deleted",0) From GESECRAN
    Endif
    If filinfo(filpath("FIL", "AFCTPRF", "fde", APPLI), 0) > 0
        If clalev([F:AFP])=0 : Local File =APPLI+".AFCTPRF" [AFP] : Endif
        Delete [AFP] Where FNC=TRTANU
        # FGR 09/02/2010 : X3SUIVI60986 : End pas Return
        If fstat=1 : GOK = -1 : GLOCK = "$AFCTPRF"-TRTANU : End : Endif
        Call ECR_TRACE(num$(adxdlrec)-"AFCTPRF deleted",0) From GESECRAN
    Endif
    If filinfo(filpath("FIL", "ABATTAC", "fde", APPLI), 0) > 0
        If clalev([F:ABT])=0 : Local File =APPLI+".ABATTAC" [ABT] : Endif
        Delete [ABT] Where FONCTION=TRTANU
        # FGR 09/02/2010 : X3SUIVI60986 : End pas Return
        If fstat=1 : GOK = -1 : GLOCK = "$ABATTAC"-TRTANU : End : Endif
        Call ECR_TRACE(num$(adxdlrec)-"ABATTAC deleted",0) From GESECRAN
    Endif
    If filinfo(filpath("FIL", "AFONCTION", "fde", APPLI), 0) > 0
        If clalev([F:AFC])=0 : Local File =APPLI+".AFONCTION" [AFC] : Endif
        Delete [AFC] Where CODINT=TRTANU
        # FGR 09/02/2010 : X3SUIVI60986 : End pas Return
        If fstat=1 : GOK = -1 : GLOCK = "$AFONCTION"-TRTANU : End : Endif
        Call ECR_TRACE(num$(adxdlrec)-"AFONCTION deleted",0) From GESECRAN
    Endif
    If filinfo(filpath("FIL", "AOBJTAB", "fde", APPLI), 0) > 0
        If clalev([F:AOT])=0 : Local File =APPLI+".AOBJTAB" [AOT] : Endif
        Delete [AOT] Where ABREV=[L]CODE
        # FGR 09/02/2010 : X3SUIVI60986 : End pas Return
        If fstat=1 : GOK = -1 : GLOCK = "$AOBJTAB"-[L]CODE : End : Endif
        Call ECR_TRACE(num$(adxdlrec)-"AOBJTAB deleted",0) From GESECRAN
    Endif
    If filinfo(filpath("FIL", "AOBJLST", "fde", APPLI), 0) > 0
        If clalev([F:AOL])=0 : Local File =APPLI+".AOBJLST" [AOL] : Endif
        Delete [AOL] Where ABREV=[L]CODE
        # FGR 09/02/2010 : X3SUIVI60986 : End pas Return
        If fstat=1 : GOK = -1 : GLOCK = "$AOBJLST"-[L]CODE : End : Endif
        Call ECR_TRACE(num$(adxdlrec)-"AOBJLST deleted",0) From GESECRAN
    Endif

    Call DEL_TRTAOB([L]CODE,APPLI) From SUBAOB
    
    Delete [AOB]ABREV="HCL"
Endif

If GOK>0
    Commit
Else
    Rollback
Endif

Call MAJOBJ(APPLI,"HIC")

Call ECR_TRACE("UTITC21 : finished", 0) From GESECRAN

End

########################################################
# MAJOBJ : Met à jour la liste de sélection d'un objet
########################################################
Subprog MAJOBJ(APPLI,OBJ)
Value Char APPLI
Value Char OBJ

Local Integer LRET

  Call ECR_TRACE("Update "+OBJ,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:AOB]) = 0 : Local File =APPLI + ".AOBJET"  [AOB] : Endif
  #
  Read [AOB]ABREV=OBJ
  If !fstat Then
    Call MAJ_SEL(APPLI, OBJ) From PATCHAOB
    #
    If [F:AOB]TYPGES <> 4 Then
      # Pas de fenêtre pour les browsers
      Call VALID("O" + OBJ, APPLI, 1, LRET) From VALWIN
      If LRET <> 1 Then
        Call ECR_TRACE("Erreur revalidation fenêtre O" + OBJ, 1) From GESECRAN
      Endif
    Endif
    #
    Call VALID (OBJ, APPLI, 1, LRET) From VALOBJ
    If LRET <> 1 Then
      Call ECR_TRACE("Erreur revalidation objet" - OBJ, 1) From GESECRAN
    Endif
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC21(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  Call MAJ_UTITC21(APPLI)
End
