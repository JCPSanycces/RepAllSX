#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#        Case [L]AEVENT
#        Endcase
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "LOAD_TO_SPK_FILE" : Gosub LOAD_TO_SPK_FILE
  Endcase
Return
#--------------------------------------

$PROPERTIES
Case [L]CURPRO
Endcase
Return

#-------------------------------------------------------
#--Method used to load properties from class SPRICLINKD to [F:SPK]
$LOAD_TO_SPK_FILE
Local Integer IJ

  If dim([F:SPK]CPY)<1
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class SPRICLINKD : Method call LOAD_TO_SPK_FILE no [F:SPK] file opened", [V]CST_AERROR)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif

  SetInstance [F:SPK] With this
  #--Parcours des collections
  #--TSICOD
  For IJ=1 To maxtab(this.C_TSICOD)
    If dim([F:SPK]TSICOD(IJ-1))<1 : Break : Endif

    [F:SPK]TSICOD(IJ-1) = "" #AVOID.ACHAR

    If this.C_TSICOD(IJ)<>null
      [F:SPK]TSICOD(IJ-1) = this.C_TSICOD(IJ).TSICOD
    Endif

  Next IJ
  #----DIE et CCE
  For IJ=1 To maxtab(this.C_DIE)
    If dim([F:SPK]DIE(IJ-1))<1 : Break : Endif

    [F:SPK]DIE(IJ-1) = "" #AVOID.ACHAR
    [F:SPK]CCE(IJ-1) = "" #AVOID.ACHAR

    If this.C_DIE(IJ)<>null
      [F:SPK]DIE(IJ-1) = this.C_DIE(IJ).DIE
      [F:SPK]CCE(IJ-1) = this.C_DIE(IJ).CCE
    Endif

  Next IJ

Return

