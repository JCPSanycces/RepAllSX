#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
PARAM(1) = "1"
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTTRFSAC","FTRFSAC",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "SORTIE"      : Gosub SORTIE
 When "FIN"        : Gosub FIN
Endcase
Return

$OUVRE
If clalev([F:CPY])=0  : Local File COMPANY      [CPY]  : Endif : # Sociétés
If clalev([F:CPY2])=0 : Local File COMPANY      [CPY2] : Endif : # Sociétés2
If clalev([F:FCY])=0  : Local File FACILITY     [FCY]  : Endif : # Sites
If clalev([F:PER])=0  : Local File PERIOD       [PER]  : Endif : # Périodes
If clalev([F:BAL])=0  : Local File BALANCE      [BAL]  : Endif : # Balances
If clalev([F:GTE])=0  : Local File GTYPACCENT   [GTE]  : Endif : # Types de pièce
If clalev([F:GAC])=0  : Local File GACCOUNT     [GAC]  : Endif : # Comptes généraux
If clalev([F:HAE])=0  : Local File GACCENTRY    [HAE]  : Endif : # Pièces comptables
If clalev([F:DAE])=0  : Local File GACCENTRYD   [DAE]  : Endif : # Lignes pièces comptables
If clalev([F:DUD])=0  : Local File GACCDUDATE   [DUD]  : Endif : # Echéances
If clalev([F:FIY])=0  : Local File FISCALYEAR   [FIY]  : Endif : # Exercices
If clalev([F:DAE3])=0 : Local File GACCENTRYD   [DAE3] : Endif : # Lignes pièces comptables
If clalev([F:BPR])=0  : Local File BPARTNER     [BPR]  : Endif : # Tiers
If clalev([F:MTC])=0  : Local File MATCHCODE    [MTC]  : Endif : # Lettre pour le lettrage
If clalev([F:JOU])=0  : Local File GJOURNAL     [JOU]  : Endif : # Journaux comptables

If clalev([F:DAA])=0  : Local File GACCENTRYA   [DAA]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE      [BAL]  : Endif
If clalev([F:BLA])=0  : Local File BALANA       [BLA]  : Endif
If clalev([F:BLM])=0  : Local File BLACMM       [BLM]  : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY       [BLQ]  : Endif

## Historisation des échéances
If func AFNC.ACTIV("HDU")
 If clalev ([F:HDU])=0  : Local File HISTODUD   [HDU]  : Endif
Endif

If dim(GCURFCY)>0 : Local Char SAV_GCURFCY(GLONFCY) : SAV_GCURFCY = GCURFCY   : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif
Return

$INIT
Gosub OUVRE
TMP = 1
Return

$INIT_DIA
Raz [M:DIA]
Return

$CONTROLE
If [M:DIA]ALLCPY=2
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(SAV_GCURFCY)>0 : GCURFCY = SAV_GCURFCY : Endif
Return

$EXEC
Call TRANSFERT([M:DIA]ALLCPY,[M:DIA]CPY,[M:DIA]ALLFCY,[M:DIA]FCY
& ,[M:DIA]COA,[M:DIA]SAC,[M:DIA]NEWSAC,[M:DIA]BPR,[M:DIA]STRDAT,[M:DIA]ENDDAT
& ,[M:DIA]ALLJOU,[M:DIA]JOU,[M:DIA]ALLTYP,[M:DIA]TYP,[M:DIA]ALLUSR,[M:DIA]USR
& ,[M:DIA]ACEMTC,[M:DIA]TYPMTC)
TRA = 1
Return

Subprog TRANSFERT(TOUSOC,SOCIETE,TOUSIT,SITE,PLAN,COLORG,COLDES,TIERS,DATD
&       ,DATF,TOUJOU,JOU,TOUTYP,TYPVCR,TOUUSR,USR,ECTLET,TYPLET)
Value Integer TOUSOC
Value Char    SOCIETE
Value Integer TOUSIT
Value Char    SITE
Value Char    PLAN
Value Char    COLORG
Value Char    COLDES
Value Char    TIERS
Value Date    DATD
Value Date    DATF
Value Integer TOUJOU
Value Char    JOU
Value Integer TOUTYP
Value Char    TYPVCR
Value Integer TOUUSR
Value Char    USR
Value Integer ECTLET
Value Integer TYPLET

Local Char    CRITERE(250), CRITDAT(250)
Local Char    SOCCUR(GLONCPY) , SITCUR(GLONFCY)
Local Integer OK
Local Integer LASFIYCLO : # Dernier exercice fermé
Local Date    DATFIYEND : # Date fin dernier exercice fermé
Local Char    TYPIECE(GLONGTE)
Local Char    NUMPIECE(GLONVCR)

Local Integer ISOC, IGCM, ILED
Local Integer NBRLEDTYP
Local Integer LEDTYPLIST(0..len(mess(0,2644,1))-1)
Local Integer FLGMTC
Local Char    MTCORG(10), MTCDES(10)

Local Char   GACORG(GLONGAC)

TIT = mess(64,107,1)  :# Transfert de collectif à collectif
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

For [CPY2]CPY0 Where (TOUSOC=2 | CPY=SOCIETE) & CPYLEGFLG=2 & LEG=GCURLEG
 Call SETLEDTYPLIST([F:CPY2]CPY,PLAN,NBRLEDTYP,LEDTYPLIST) From CPTDIV
 For [FCY]FCY0 Where LEGCPY=[F:CPY2]CPY & FINFLG=2 & (TOUSIT=2 | FCY=SITE)
  SOCCUR = [F:CPY2]CPY
  SITCUR = [F:FCY]FCY
  Call ECR_TRACE(mess(2,116,1)-SOCCUR-mess(5,116,1)-SITCUR,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK<1 : Break : Endif
 Next :#[FCY]
Next :#CPY
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
End

$TR1
GOK=1
Trbegin [DAE], [BAL]

 For J=0 To NBRLEDTYP-1

  Filter [FIY] Where CPY=SOCCUR & LEDTYP=LEDTYPLIST(J) & FIYSTA>2
  Read [FIY] Last
  Filter [FIY]
  If !fstat
   LASFIYCLO = [F:FIY]FIYNUM : DATFIYEND = [F:FIY]FIYEND
  Else
   Raz  LASFIYCLO, DATFIYEND
  Endif

  # Mise à jour des écritures et de la balance ... et des stats
  Gosub DEFCRITECT
  If CRITDAT=""
   Filter [DAE] Where evalue(CRITERE)
  Else
   Filter [DAE] Where evalue(CRITERE) & evalue(CRITDAT)
  Endif

  Link [DAE] With [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM As [LNK]
  For [LNK]
   OK = 1
   If [F:HAE]FLGREP = 2 : OK = 0 : Endif
   If TOUJOU<>2 & [F:HAE]JOU<>JOU : OK = 0 : Endif
   If TOUTYP<>2 & [F:HAE]TYP<>TYP : OK = 0 : Endif
   If TOUUSR<>2
    If ([F:HAE]UPDUSR<>"" & [F:HAE]UPDUSR<>USR) or ([F:HAE]UPDUSR="" & [F:HAE]CREUSR<>USR)
     OK = 0
    Endif
   Endif

   If OK & LASFIYCLO>0 & [F:DAE]MTC<>""
    TYPPIECE = [F:DAE]TYP
    NUMPIECE = [F:DAE]NUM
    For [DAE3]DAE6 Where ACC=[F:DAE]ACC & BPR=[F:DAE]BPR & MTC=[F:DAE]MTC
     If [F:DAE3]TYP<>TYPPIECE | [F:DAE3]NUM<>NUMPIECE
      If [F:DAE3]ACCDAT<=DATFIYEND
       OK = 0
       Call ECR_TRACE(mess(12,107,1)-":"-[F:DAE]TYP-[F:DAE]NUM-tolower(mess(3,61,1))-num$([F:DAE]LIN)+","
&                   -tolower(mess(127,107,1))-[F:DAE3]TYP-[F:DAE3]NUM-mess(98,107,1)-format$("D:"+GFMDAT,[F:DAE3]ACCDAT)
&                   -":"+"\"+tolower(mess(128,107,1)),0) From GESECRAN
       Call ECR_TRACE("",0) From GESECRAN
       Break
      Endif
     Endif
    Next :#[DAE3]
   Endif

   If OK
    [L]GACORG = [F:DAE]ACC
    Call BALANCE(-1) From CPTBAL
    If GOK<1 : Break : Endif
    Call VALSTA("GAS",-1) From SUBPS2
    If GOK<1 : Break : Endif
    [F:DAE]SAC = COLDES
    Read [GAC]GAC1 = PLAN;COLDES
    [F:DAE]ACC = [F:GAC]ACC
    Rewrite [DAE]
    If fstat
     GOK = 0 : Call FSTA("DAE") From GLOCK : Break 2
    Endif
    GPOINT = "AFTWRIDAE" : Gosub ENTREE From EXEFNC
    Call BALANCE(+1) From CPTBAL
    If GOK<1 : Break : Endif
    Call VALSTA("GAS",+1) From SUBPS2
    If GOK<1 : Break : Endif
    For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM
     [F:DUD]SAC = COLDES
     Rewrite [DUD]
     If fstat
      GOK = 0 : Call FSTA("DUD") From GLOCK : Break 3
     Endif
    Next :#[DUD]
    ## Historisation des échéances
    If func AFNC.ACTIV("HDU")
     For [HDU] Where ACCNUM=[F:DAE]ACCNUM
      [F:HDU]SAC = COLDES
      Rewrite [HDU]
      If fstat
       GOK = 0 : Call FSTA("HDU") From GLOCK : Break 3
      Endif
     Next
    Endif

    For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
     If [F:DAA]ACC=[L]GACORG
      Call BALANA(-1) From CPTBAL
      If GOK<1 : Break 3 : Endif
      [F:DAA]ACC = [F:DAE]ACC
      Call BALANA(+1) From CPTBAL
      If GOK<1 : Break 3 : Endif
      Rewrite [DAA]
      If fstat
       GOK=0 : Call FSTA("DAA") From GLOCK : Break 3
      Endif
     Endif
    Next :#[DAA]

   Endif
  Next :#[DAE]
 Next J

 # Si un transfert est OK => Mise à jour de MATCHCODE (1seul fois)
 If !FLGMTC : Gosub TR2 : Endif

 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$TR2
[L]FLGMTC = 1  # A faire un seule fois dans le traitement

# Table MATCHCODE
# MTCORG = lettre du collectif d'origine
# MTCDES = lettre du collectif destination

Raz MTCORG
Read [GAC]GAC1 = PLAN;COLORG
If !fstat
 Read [MTC]MTC0 = [F:GAC]COA;[F:GAC]ACC;TIERS
 If !fstat
  [L]MTCORG = [F:MTC]MTC
 Endif
Endif

Raz MTCDES
Read [GAC]GAC1 = PLAN;COLDES
If !fstat
 Read [MTC]MTC0 = [F:GAC]COA;[F:GAC]ACC;TIERS
 If !fstat
  [L]MTCDES = [F:MTC]MTC
  If [L]MTCORG<>"" & len([L]MTCDES)<len([L]MTCORG) or (len([L]MTCDES)=len([L]MTCORG) & [L]MTCDES<[L]MTCORG)
   [F:MTC]MTC = [L]MTCORG
   Rewrite [MTC]
   If fstat
    GOK = 0 : Call FSTA("MTC") From GLOCK
   Endif
  Endif
 Elsif [L]MTCORG<>""
  Raz [F:MTC]
  [F:MTC]COA = [F:GAC]COA
  [F:MTC]ACC = [F:GAC]ACC
  [F:MTC]BPR = TIERS
  [F:MTC]MTC = [L]MTCORG
  Write [MTC]
  If fstat
   GOK = 0 : Call FSTA("MTC") From GLOCK
  Endif
 Endif
Endif
Return

$DEFCRITECT
CRITERE  = "" : CRITDAT=""
CRITERE += " & CPY='"+SOCCUR+"'"
CRITERE += " & FCYLIN='"+SITCUR+"'"
CRITERE += " & LEDTYP="+num$(LEDTYPLIST(J))
CRITERE += " & COA='"+PLAN+"'"
CRITERE += " & SAC='"+COLORG+"'"
CRITERE += " & BPR='"+TIERS+"'"
If TYPVCR<>""
 CRITERE += " & TYP='"+TYPVCR+"'"
Endif
If ECTLET=1 : # On ne prend pas les écritures lettrées
 CRITERE += ' & MTC=""'
Else
 Case TYPLET
  When 1 : # On prend aussi les écritures lettrées en majuscules
   CRITERE += ' & MTC>="A" & MTC<="ZZZZZ"'
  When 2 : # On prend aussi les écritures lettrées en miniscules
   CRITERE += ' & MTC>="a" & MTC<="zzzzz"'
  When 3
   # On prend toutes les écritures, donc pas de filtre sur MTC...
 Endcase
Endif
If LASFIYCLO>0
 CRITDAT += " & ACCDAT>["+format$(GFMD,DATFIYEND)+"]" : # On modifie le collectif que si l'exercice porte sur un exercice clôturé
Endif
If DATD<>[0/0/0]
 CRITDAT += " & ACCDAT>=["+format$(GFMD,DATD)+"]"
Endif
If DATF<>[0/0/0]
 CRITDAT += " & ACCDAT<=["+format$(GFMD,DATF)+"]"
Endif
CRITERE = right$(CRITERE,4)
CRITDAT = right$(CRITDAT,4)
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#########################################################################
## Etiquettes du masque TRFSAC [DIA]
#########################################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call AM_CPY(VALEUR) From CPTTRT
If [M:DIA]NEWSAC<>""  : Raz [M:DIA]NEWSAC
 Affzo [M:DIA]NEWSAC
Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
 If [M:DIA]NEWSAC<>""  : Raz [M:DIA]NEWSAC
  Affzo [M:DIA]NEWSAC
 Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
If [M]ACEMTC=2 : VALEUR = 2 : mkstat = 2 : Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog AS_TYP(VALEUR)
Variable Char    VALEUR()
Call AS_TYP(VALEUR) From CPTTRT
End

Subprog AS_ALLJOU(VALEUR)
Variable Integer VALEUR
If [M]ACEMTC=2 : VALEUR = 2 : mkstat = 2 : Endif
End

Subprog AS_JOU(VALEUR)
Variable Char     VALEUR
Call AS_JOU(VALEUR) From CPTTRT
End

Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
Call C_JOU(VALEUR) From CPTTRT
End

Subprog AS_ALLUSR(VALEUR)
Variable Integer VALEUR
If [M]ACEMTC=2 : VALEUR = 2 : mkstat = 2 : Endif
End

Subprog AS_USR(VALEUR)
Variable Char    VALEUR()
Call AS_USR(VALEUR) From CPTTRT
End

Subprog AS_STRDAT(VALEUR)
Variable Date     VALEUR
If [M]ACEMTC=2 : VALEUR = [0/0/0] : mkstat = 2 : End : Endif
Call AS_STRDAT(VALEUR) From CPTTRT
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If [M]ACEMTC=2 : VALEUR = [0/0/0] : mkstat = 2 : Endif
End

Subprog AS_TYPMTC(VALEUR)
Variable Integer VALEUR
If [M]ACEMTC<>2 : VALEUR = 0 : mkstat = 2 : End : Endif
If VALEUR=0 : VALEUR = 1 : Endif
End

Subprog C_NEWSAC(VALEUR)
Variable Char VALEUR
Local Integer NOK
Local Integer CSLFLGORG, CSLFLGDES
Local Integer CSLBPRORG, CSLBPRDES
Local Char    MESSA(255)
Local Integer NLED, CSLOK
Local Integer ICSL
Local Char    LEDCSLLST(GLONLED) (1..)

If clalev([F:GACO])=0  : Local File GACCOUNT     [GACO]  : Endif
If clalev([F:GCM])=0   : Local File GACM      [GCM]   : Endif
If clalev([F:LED])=0   : Local File GLED      [LED]   : Endif

If VALEUR=[M:DIA]SAC :  mkstat = 1 : End : Endif
If VALEUR = "" : End : Endif

NOK=0
Read [GAC]GAC1=[M:DIA]COA;VALEUR
If !fstat
 Read [GACO]GAC1=[M:DIA]COA;[M:DIA]SAC
 If !fstat
  For I=1 To dim([F:GAC]AUZBPR)-1
   If [F:GACO]AUZBPR(I-1)=2 & [F:GAC]AUZBPR(I-1)<>[F:GACO]AUZBPR(I-1) : NOK=1 : Break :  Endif
  Next
  If NOK
   # Tiers incompatible avec le collectif
   GMESSAGE=mess(45,106,1)
   mkstat=1 : End
  Endif
 Endif
Endif

 #YYFIN_X3-800  Flow/Partner control management between source control account and target control account
 #              if the chart code belongs to a Consolidation ledger
 If func AFNC.ACTIV("PRCSL")
  mkstat = 0 : CSLOK=0 :  ICSL=0
  If  dim([F:GAC]CSLFLGFLW)>0
   CSLFLGDES = [F:GAC]CSLFLGFLW
  Endif
  If  dim([F:GAC]CSLFLGBPR)>0
   CSLBPRDES = [F:GAC]CSLFLGBPR
  Endif
  If  dim([F:GACO]CSLFLGFLW)>0
   CSLFLGORG = [F:GACO]CSLFLGFLW
  Endif
  If  dim([F:GACO]CSLFLGBPR)>0
   CSLBPRORG = [F:GACO]CSLFLGBPR
  Endif

  If (CSLFLGDES = CSLFLGORG) and (CSLBPRDES=CSLBPRORG)  : End : Endif

  If [M]CPY<>""
   Call LEC_GCM([F:CPY]ACM) From CPTLEC
   If !fstat
    For NLED = 1 To len(mess(0,2644,1))
     If [F:GCM]LED(NLED-1)<>"" and [F:GCM]CFMAUT(NLED-1)<>2
      Call LEC_LED([F:GCM]LED(NLED-1)) From CPTLEC
      If [F:LED]CSL=2 and [F:LED]COA=[M:DIA]COA
       CSLOK=1
       Break
      Endif
     Endif
    Next
   Endif
 Else  #  All CPY
  ICSL=0
  # List with consolidated Ledgers for the legislation
  Raz LEDCSLLST
  For [LED]LED0 Where COA=[M:DIA]COA and CSL=2
   ICSL=+1
   LEDCSLLST(ICSL)=[F:LED]LED
  Next
  If ICSL>0
    Link [CPY] With [GCM]GCM0~=[F:CPY]ACM
&             As [LNK]
&             Where [F:CPY]CPYLEGFLG=2 & [F:CPY]LEG=[M:DIA]LEG
    For [LNK]
     For J=1 To len(mess(0,2644,1))
      If [F:GCM]LED(J-1)="" : Break : Endif
      If find ([F:GCM]LED(J-1),LEDCSLLST(1..ICSL))
       CSLOK=1
       Break 2
      Endif
     Next #<LNK>
    Next #<J>
   Endif
 Endif

 If CSLOK
  Call COMPAT_SAC([M:DIA]SAC,CSLFLGORG, CSLBPRORG, VALEUR, CSLFLGDES, CSLBPRDES)
  If mkstat
   GERR=1 :  mkstat = 2 : End
  Endif
 Endif

 Endif

End
#**
#*
#*
####################################################################################
##Checking compatibility of the flow management
# between source account and target account
####################################################################################
#*!
Subprog COMPAT_SAC(PSAC, PCSLFLGO, PCSLBPRO, PNEWSAC, PCSLFLGD, PCSLBPRD)
Value Char    PSAC            # Source control account
Value Integer PCSLFLGO        # Flow management source control account
Value Integer PCSLBPRO        # Partner management source control account
Value Char    PNEWSAC         # Target control account
Value Integer PCSLFLGD        # Flow management target control account
Value Integer PCSLBPRD        # Partner management target control account


If (PCSLFLGD <> 2) and (PCSLFLGO <> PCSLFLGD)
 # Comparison Flow management if Flow management target not optional
 # XXX => YYY - Flow management: Not entered,Optional,Mandatory/XXX ==> Not entered,Mandatory/YYY
 GMESSAGE = num$(PSAC)-"=> "-num$(PNEWSAC)-"-"-mess(204,104,1)-":"-mess(PCSLFLGO,2637,1)-"/"-num$(PSAC)-"=>"-mess(PCSLFLGD,2637,1)-"/"-num$(PNEWSAC)
 mkstat=2 : End
Endif

If (PCSLBPRD <> 2) and (PCSLBPRO <> PCSLBPRD)
 # Comparison Partner management if Partner management target not optional
 # XXX => YYY - Partner management: Not entered,Optional,Mandatory/XXX ==> Not entered,Mandatory/YYY
 GMESSAGE = num$(PSAC)-"=> "-num$(PNEWSAC)-"-"-mess(205,104,1)-":"-mess(PCSLBPRO,2637,1)-"/"-num$(PSAC)-"=>"-mess(PCSLBPRD,2637,1)-"/"-num$(PNEWSAC)
 mkstat=2 : End
Endif

End
######################################################################################

