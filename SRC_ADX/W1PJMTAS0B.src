#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTAS0B 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:57"
A_USER  = "DOC"
A_STAMP = "20181109230557"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTAS0B [PJTA0B]
Gosub HORODAT
Local Inpbox "PJMTAS0B" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTA0B] As [SIM_]
Grizo [PJTA0B]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTA0B]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=132 : Y1(0)=1 : Y2(0)=10
Return

$ON_PRCCPL
Onevent AFTER_CHANGE Gosub AMM_PRCCPL From W1PJMTAS0B
Return

$AMM_PRCCPL
Call AM_PRCCPL(zc)
If !mkstat & GOBJET
 zoncou = "PRCCPL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PRCCPL(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_PRCCPL(VALEUR) From SUBPJTA
If mkstat : GERR = 1 : GZONE = "PRCCPL" : GZNUM = 1003276 : Endif
Gosub _AFF
End

$ON_PRCCPLADI
Onevent INIT_AREA Call D_PRCCPLADI(zc) From W1PJMTAS0B
Onevent CONTROL Call C_PRCCPLADI(zc) From W1PJMTAS0B
Onevent AFTER_CHANGE Gosub AMM_PRCCPLADI From W1PJMTAS0B
Onevent BEFORE_INPUT Call AS_PRCCPLADI(zc) From W1PJMTAS0B
Return

Subprog D_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
If varinit([M]PRCCPLADI,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"387","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"387") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PRCCPLADI(zc) From W1PJMTAS0B
Onkey   2 Titled GBOUTS Call S_PRCCPLADI(zc) From W1PJMTAS0B
Onkey 144 Titled GBOUTP Call P_PRCCPLADI(zc) From W1PJMTAS0B
Onkey 146 Titled GBOUTA Call SA_PRCCPLADI(zc) From W1PJMTAS0B
Gosub _AFF
End

Subprog C_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"387","") From SUBADI
If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"387",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
Endif
Gosub _AFF
End

$AMM_PRCCPLADI
Call AM_PRCCPLADI(zc)
If !mkstat & GOBJET
 zoncou = "PRCCPLADI" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PRCCPLADI(VALEUR) From SUBPJTA
If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZPRCCPLADI)")>indice
 [M]PRCCPLADI(indice) = VALEUR
 Affzo ZPRCCPLADI(indice)
Endif
Gosub _AFF
End

Subprog S_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "387"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"387") From GOBJET
Gosub _AFF
End

Subprog SA_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "387"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "387"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPRCCPLADI
Onevent BEFORE_AREA Gosub AV_ZPRCCPLADI From W1PJMTAS0B
Return

$AV_ZPRCCPLADI
Call LECTEXTRA(zc,"ATABDIV","LNGDES","387",num$([M]PRCCPLADI(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_TASSOR
Onevent AFTER_CHANGE Gosub AMM_TASSOR From W1PJMTAS0B
Return

$AMM_TASSOR
Call AM_TASSOR(zc)
If !mkstat & GOBJET
 zoncou = "TASSOR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TASSOR(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_TASSOR(VALEUR) From SUBPJTA
If mkstat : GERR = 1 : GZONE = "TASSOR" : GZNUM = 50781 : Endif
Gosub _AFF
End

$ON_TASNUM
Return

$ON_ORITAS
Return

$CHG_STY
Return


