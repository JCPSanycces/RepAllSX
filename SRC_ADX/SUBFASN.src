#<AdxTL>@(#)11.0.0.0 $Revision$
# Gestion du masque FASNSP

##########################################################################
Subprog AM_NSPVALP(VALEUR)
Variable Decimal VALEUR

  For nolign = 1 To [M:FASN]NBLIG1
    If ( [M:FASN]ACGCUR = [M:FASN]CUR(nolign-1) ) Then
      # Les plans exprimés dans la devise société héritent de la valeur marché saisie
      [M:FASN]NSPVAL(nolign-1) = VALEUR : Affzo [M:FASN]NSPVAL(nolign-1)
    Else
     # Détermination du taux selon type de cours
     Call CDVCAL( [M:FASN]RATCUR(nolign-1), [M:FASN]ACGCUR, [M:FASN]CUR(nolign-1),
&                 [M:FAS0]CPY, [M:FASN]CURTYP(nolign-1), date$  ) From TRTDIV
     Affzo [M:FASN]RATCUR(nolign-1)
     # Calcul de la valeur marché
     [M:FASN]NSPVALP = VALEUR : Affzo [M:FASN]NSPVALP
     Call CALCUL_NSPVAL()
    Endif 
  Next nolign

End



##########################################################################
Subprog AM_CURTYP(VALEUR)
Variable Integer VALEUR
  # Détermination du taux en fonction du nouveau type de cours
  Call CDVCAL( [M:FASN]RATCUR(nolign-1), [M:FASN]ACGCUR, [M:FASN]CUR(nolign-1), [M:FAS0]CPY, VALEUR, 
&            date$  ) From TRTDIV

  Affzo [M:FASN]RATCUR(nolign-1)

  [M:FASN]CURTYP(nolign-1) = VALEUR : Affzo [M:FASN]CURTYP(nolign-1)
  Call CALCUL_NSPVAL()
End

##########################################################################
Subprog AM_RATCUR(VALEUR)
Variable Decimal VALEUR

  [M:FASN]RATCUR(nolign-1) = VALEUR : Affzo [M:FASN]RATCUR(nolign-1)
  # Calcul de la valeur marché
  Call CALCUL_NSPVAL()
End

##########################################################################
Subprog CALCUL_NSPVAL()

Local Decimal MTDES
Local Integer STAT

  Call CONVERT3([M:FASN]ACGCUR, [M:FASN]CUR(nolign-1), GCOUDEV, [M:FASN]CURTYP(nolign-1), date$, 
&                [M:FASN]NSPVALP, MTDES, [M:FASN]RATCUR(nolign-1), STAT) From CPTSUB
  If ( STAT = 0 ) Then
    Call GET_MNT_ARRONDI (MTDES, [M:FASN]CUR(nolign-1), MTDES) From GLOBIENS
    [M:FASN]NSPVAL(nolign-1) = MTDES : Affzo [M:FASN]NSPVAL(nolign-1)
  Endif
End


