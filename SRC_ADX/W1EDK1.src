#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EDK1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:07"
A_USER  = "DOC"
A_STAMP = "20181109230407"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask EDK1 [EDK1]
Gosub HORODAT
Local Inpbox "EDK1" From GFONCTION At A_STAMP With A_WINDPREV Mask [EDK1] As [SIM_]
Grizo [EDK1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EDK1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=4
Return

$ON_CATTYP
Onevent INIT_AREA Call D_CATTYP(zc) From W1EDK1
Return

Subprog D_CATTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CATTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CATACTFLT
Onevent AFTER_CHANGE Gosub AMM_CATACTFLT From W1EDK1
Onevent INIT_AREA Call D_CATACTFLT(zc) From W1EDK1
Onevent BEFORE_INPUT Call AS_CATACTFLT(zc) From W1EDK1
Return

Subprog IB_CATACTFLT(VALEUR)
Variable Integer VALEUR
## Action STD
Call IB_CATACTFLT From CNSEDKSTD
Gosub _AFF
End

Subprog D_CATACTFLT(VALEUR)
Variable Integer VALEUR
If varinit([M]CATACTFLT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CATACTFLT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call IB_CATACTFLT(VALEUR)
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_CATACTFLT
Call AM_CATACTFLT(zc)
If !mkstat & GOBJET
 zoncou = "CATACTFLT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CATACTFLT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_CATACTFLT(VALEUR) From CNSEDKSTD
If mkstat : GERR = 1 : GZONE = "CATACTFLT" : GZNUM = 90 : Endif
Gosub _AFF
End

$CHG_STY
Return


