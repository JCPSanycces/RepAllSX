#<AdxTL>@(#)0.0.0.0 $Revision$ Validation des factures achat
########################################################################
# FUNPIH           VALIDATION DES FACTURES ACHATS         cg Aout 1998 #
# -------------------------------------------------------------------- #
# Sous-programme FUNPIH remplacé par l'action TRTFUNPIH !              #
# GCUR    = devise societe      GSYSCUR = devise dossier               #
# GFINRSP = site financier                                             #
# -------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)               #
#   - TRTFUNPIH : Fonction de validation des factures et des avoirs    #
########################################################################

$ACTION
#----------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)             #
# TRTFUNPIH  : Fonction de validation des factures/avoirs  #
#----------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Affzo [DIA]1-99 : Gosub GRISAGE
 When "SETBOUT"     : If GHISTO
                        Diszo [DIA]1-99
                        Call VIREBOUT(CHBOU,"O")   From GOBJET
                        Call VIREBOUT(CHMEN,"MRE") From GOBJET
                      Endif
 When "BOUTON"      : Gosub BOUTON
 When "OK"          : GOK=1
 When "END"         : GOK=0
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return


#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
#---------------------------------------------------#
# GTEST=1 permet de voir si la pièce est equilibrée #
#---------------------------------------------------#
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
Gosub OUVRE        : # Ouverture fichiers et déclaration variables locales
Local Mask PIHPST [DIA]
Raz [M:DIA]
[M:DIA]XFCYFLG=2
[M:DIA]XUSRFLG=1
[M:DIA]USR    =GUSER
[M:DIA]XTYPFLG=2
[M:DIA]TRACE  =2
Filter [PIH]
Call LECMEMO("STD","[M:DIA]","pm5") From GMEMO
TIT=mess(136,197,1) : # Titre de la boite de dialogue et message de temporisation
TMP=1               : # Affichage d'un message de temporisation
Return


###############################
# Après exécution d'un bouton #
###############################
$BOUTON
Case BOUT
  When "R" : Gosub GRISAGE
Endcase
Return


##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 : Endif
Call AVERTDGI([M:DIA]XCPYFLG,[M:DIA]CPY,1,SAI) From CPTDIV2
If SAI  Return : Endif
Return


###########################
# Exécution du traitement #
###########################
$EXEC
WNBPCE = 0
If !GSERVEUR
  If [M:DIA]TRACE=2
    #----- Ouverture fichier trace et écriture des sélections -----#
    Call OUVRE_TRACE(mess(136,197,1))  From LECFIC
    Call ECR_TRACE(" ",0)              From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
    Call PRTSCR("PIHPST","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
    Call ECR_TRACE(" ",0)              From GESECRAN
  Endif
Endif
#-----------------------------------------------------#
# On traite les factures et avoirs non comptabilisés  #
# factures à valider et origine module achat          #
# Attention                                           #
#    Table déclenchante est PINVOICEV pour pièce auto #
#-----------------------------------------------------#
#WCRIT="STA=2 & ORIMOD=6"
WCRIT="STA=2 & ORIMOD=6 & TWMSTA<>4"   # Three way matching
If [M:DIA]XCPYFLG<>2
  WCRIT -='& CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]XFCYFLG<>2
  WCRIT -='& FCY="'+[M:DIA]FCY+'"'
Endif
If [M:DIA]XUSRFLG<>2
  WCRIT -='& (UPDUSR="'+[M:DIA]USR+'"'
  WCRIT -='| (UPDUSR="" & CREUSR="'+[M:DIA]USR+'"))'
Endif
If [M:DIA]STRDAT<>[0/0/0]
  WCRIT -="& ACCDAT>=["+format$(GFMD,[M:DIA]STRDAT)+"]"
Endif
If [M:DIA]ENDDAT<>[0/0/0]
  WCRIT -="& ACCDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"]"
Endif
If [M:DIA]VCRDEB<>""
  WCRIT -='& NUM>="'+[M:DIA]VCRDEB+'"'
Endif
If [M:DIA]VCRFIN<>""
  WCRIT -='& NUM<="'+[M:DIA]VCRFIN+'"'
Endif
If [M:DIA]XTYPFLG<>2
  WCRIT -='& INVTYP='+num$([M:DIA]INVTYP)
Endif
#---------------------------------------------------------------------------#
# Point d'entrée PIHFILTRE pour ajouter un filtre supplémentaire            #
# ------------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                               #
#                                                                           #
# WCRIT     : Filtre constitué par le traitement à partir de l'écran PIHPST #
# PIHFILTRE : Filtre supplémentaire sur l'entête de facture                 #
# PIVFILTRE : Filtre supplémentaire sur le complément d'entête de facture   #
#---------------------------------------------------------------------------#
Raz PIHFILTRE, PIVFILTRE
SAV_WCRIT=WCRIT
GPOINT="PIHFILTRE" : Gosub ENTREE From EXEFNC
If WCRIT<>SAV_WCRIT
  WMSG="WCRIT"-mess(382,197,1)-WCRIT
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If PIHFILTRE<>""
  WMSG="PIHFILTRE"-mess(382,197,1)-PIHFILTRE
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If PIVFILTRE<>""
  WMSG="PIVFILTRE"-mess(382,197,1)-PIVFILTRE
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If WCRIT<>SAV_WCRIT | PIHFILTRE<>"" | PIVFILTRE<>""
  Call ECR_TRACE(" ",0)             From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0)             From GESECRAN
Endif
If WCRIT=""     WCRIT    ="1=1" : Endif
If PIHFILTRE="" PIHFILTRE="1=1" : Endif
If PIVFILTRE="" PIVFILTRE="1=1" : Endif
#-----
If parse(WCRIT)
  Call ECR_TRACE("Filter error WCRIT",1)     From GESECRAN : Return
Endif
If parse(PIHFILTRE)
  Call ECR_TRACE("Filter error PIHFILTRE",1) From GESECRAN : Return
Endif
If parse(PIVFILTRE)
  Call ECR_TRACE("Filter error PIVFILTRE",1) From GESECRAN : Return
Endif
#-------------------------------------------------------#
# On traite tout le fichier factures et pièce par pièce #
#-------------------------------------------------------#
For [PIH] Where evalue(WCRIT) & evalue(PIHFILTRE) With Nohint
  mkstat=0
  If PIVFILTRE<>"1=1"
    Read [PIV] PIV0=[F:PIH]NUM
    If !fstat & !evalue(PIVFILTRE)  mkstat=2 : Endif
  Endif
  If [M:DIA]XCPYFLG<>2 & mkstat<>2
    #------------------------------------------------------#
    # Vérification appartenance à la société saisie        #
    # cas saisie pour une société                          #
    # ---------------------------------------------------- #
    # Lecture site achat appartenance à même soc.juridique #
    #------------------------------------------------------#
    Read [FCY] FCY0=[F:PIH]FCY : If fstat Raz [FCY] : Endif
    If [F:FCY]LEGCPY<>[M:DIA]CPY
       #----- Societe n'est pas la même donc on ne prend pas -----#
       mkstat=2
    Endif
  Endif
  If mkstat<>2
    #----- Verrou de la facture -----#
    Gosub VERROU_PIH
    If mkstat<>2
      #----- On va dans le traitement compta si facture non bloquée -----#
      WNUM=[F:PIH]NUM
      # Issue X3-57770 - 2017-10-18 by MUARN : TESTS muarn init param
      Call GETDEV([F:PIH]FCY) From DEVSUB
      If GFINRSP=""  GFINRSP=GFCY : Endif
      # End issue X3-57770
      Call VALID_PIH (WNUM,WNBPCE) From TRTACHFAC1
      #----- Déverrou de la facture -----#
      SYMBOLE2="PIH"+num$([F:PIH]NUM)
      Unlock = SYMBOLE2
    Endif
  Endif
Next
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
If !GSERVEUR
  If [M:DIA]TRACE=2
    If WNBPCE=0 : # Aucune pièce à traiter
      Call ECR_TRACE(mess(8,107,1),0) From GESECRAN
    Endif
    Call FERME_TRACE From LECFIC
    TRA=1
  Endif
Endif
If GFCYDEF(6)<>GFCYDEF(0)
  GFCYDEF(0)=GFCYDEF(6)
Endif
Return


#######################################################
# Traitement du grisage et dégrisage des champs écran #
#######################################################
$GRISAGE
If [M:DIA]XCPYFLG=2 Diszo [DIA]CPY, XFCYFLG Else Actzo [DIA]CPY, XFCYFLG : Endif
If [M:DIA]XFCYFLG=2 Diszo [DIA]FCY          Else Actzo [DIA]FCY          : Endif
If [M:DIA]XUSRFLG=2 Diszo [DIA]USR          Else Actzo [DIA]USR          : Endif
If [M:DIA]XTYPFLG=2 Grizo [DIA]INVTYP       Else Actzo [DIA]INVTYP       : Endif
Return


#---------------------------------------------------------#
# Ouverture des fichiers et déclaration variables locales #
#---------------------------------------------------------#
$OUVRE
If GMODU(8)=2
  Local Mask SBCK [SBCK]
  Raz [M:SBCK]
Endif
#----- Variables locales -----#
Local Char    WCRIT(250), SAV_WCRIT(250), PIHFILTRE(250), PIVFILTRE(250)
Local Integer STAT
Local Integer WNBPCE
Local Integer WRETOUR , WECRITURE
Local Char    WNUM(GLONVCR), WMESSAGE(80), SYMBOLE2(30)
#----- Ouverture des fichiers -----#
If clalev([F:BPS]) =0  Local File BPSUPPLIER  [BPS] : Endif
If clalev([F:BPR]) =0  Local File BPARTNER    [BPR] : Endif
If clalev([F:ITM]) =0  Local File ITMMASTER   [ITM] : Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT  [ITF] : Endif
If clalev([F:TCO]) =0  Local File TABCOEFF    [TCO] : Endif
If clalev([F:PIH]) =0  Local File PINVOICE    [PIH] : Endif
If clalev([F:PIV]) =0  Local File PINVOICEV   [PIV] : Endif
If clalev([F:PID]) =0  Local File PINVOICED   [PID] : Endif
If clalev([F:PID2])=0  Local File PINVOICED  [PID2] : Endif
If clalev([F:CAL]) =0  Local File CPTANALIN   [CAL] : Endif
If clalev([F:POH]) =0  Local File PORDER      [POH] : Endif
If clalev([F:POP]) =0  Local File PORDERP     [POP] : Endif
If clalev([F:POQ]) =0  Local File PORDERQ     [POQ] : Endif
If clalev([F:PTH]) =0  Local File PRECEIPT    [PTH] : Endif
If clalev([F:PTD]) =0  Local File PRECEIPTD   [PTD] : Endif
If clalev([F:FCY]) =0  Local File FACILITY    [FCY] : Endif
If clalev([F:DUD]) =0  Local File GACCDUDATE  [DUD] : Endif
If clalev([F:GAU]) =0  Local File GAUTACE     [GAU] : Endif
If clalev([F:GAD]) =0  Local File GAUTACED    [GAD] : Endif
If clalev([F:CAC]) =0  Local File GACCCODE    [CAC] : Endif
If clalev([F:GAC]) =0  Local File GACCOUNT    [GAC] : Endif
If clalev([F:CPY]) =0  Local File COMPANY     [CPY] : Endif
If clalev([F:TCU]) =0  Local File TABCUR      [TCU] : Endif
If clalev([F:TCH]) =0  Local File TABCHANGE   [TCH] : Endif
If clalev([F:TCK]) =0  Local File TABACCLIK   [TCK] : Endif
If clalev([F:GTE]) =0  Local File GTYPACCENT  [GTE] : Endif
If clalev([F:CCE]) =0  Local File CACCE       [CCE] : Endif
If clalev([F:FIY]) =0  Local File FISCALYEAR  [FIY] : Endif
If clalev([F:PER]) =0  Local File PERIOD      [PER] : Endif
If clalev([F:TUN]) =0  Local File TABUNIT     [TUN] : Endif
If clalev([F:DSP]) =0  Local File CADSP       [DSP] : Endif
If clalev([F:AUZ]) =0  Local File CAAUZ       [AUZ] : Endif
If clalev([F:ANM]) =0  Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN]) =0  Local File AVALNUM     [AVN] : Endif
If clalev([F:CCE2])=0  Local File CACCE      [CCE2] : Endif
If clalev([F:HAE2])=0  Local File GACCTMP    [HAE2] : Endif
If clalev([F:AUS]) =0  Local File AUTILIS     [AUS] : Endif
If clalev([F:STJ]) =0  Local File STOJOU      [STJ] : Endif
If clalev([F:GCM]) =0  Local File GACM        [GCM] : Endif
If clalev([F:ITV]) =0  Local File ITMMVT      [ITV] : Endif # Issue X3-69423 - 2017-12-21 by MUARN
#----- Ouverture des fichiers si le module ventes est présent -----#
If GMODU(5)=2
  If clalev([F:SIV])=0   Local File SINVOICEV  [SIV]  : Endif
  If clalev([F:SVF])=0   Local File SVCRFOOT   [SVF]  : Endif
  If clalev([F:SVV])=0   Local File SVCRVAT    [SVV]  : Endif
  If clalev([F:SGH])=0   Local File SCHGH      [SGH]  : Endif
  If clalev([F:SGD])=0   Local File SCHGD      [SGD]  : Endif
Endif
#----- Ouverture des fichiers si le module compta est présent -----#
If GMODU(2)=2
  If clalev([F:GDE])=0   Local File GDIAENTRY  [GDE]  : Endif
  If clalev([F:GDD])=0   Local File GDIAENTRYD [GDD]  : Endif
  If clalev([F:PBS])=0   Local File GAPARBSE   [PBS]  : Endif
  If clalev([F:JOU])=0   Local File GJOURNAL   [JOU]  : Endif
  If clalev([F:JST])=0   Local File GAJOUSTA   [JST]  : Endif
  If clalev([F:HAE1])=0  Local File GACCENTRY  [HAE1] : Endif
Endif
Return


#---------------------------------------#
# Il faut verrouiller le symbole PIH    #
# personne ne doit modifier la facture  #
#---------------------------------------#
$VERROU_PIH
SYMBOLE2="PIH"+num$([F:PIH]NUM)
Lock = SYMBOLE2 With lockwait = 0
If fstat
  If GTRACE<>""
    Call ECR_TRACE(num$([F:PIH]NUM)- mess(10,100,1),1) From GESECRAN
  Endif
  WNBPCE=1
  mkstat=2
Endif
Return


###########################################################
# Sous-Programmes des actions sur champ de l'écran PIHPST #
###########################################################

Subprog AV_XCPYFLG(VALEUR)
#------------------------------------#
# Avant zone du flag toutes sociétés #
# ---------------------------------- #
# Complément de l'initialisation des #
# champs faite dans INIT et          #
# grisage des champs                 #
#------------------------------------#
Variable Integer  VALEUR
If varinit([M]XCPYFLG) End : Endif : # Pour n'exécuter qu'une seule fois
#----- Traitement des champs société -----#
[M]XCPYFLG=2 : VALEUR=2
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  VALEUR=1 : [M]XCPYFLG=1 : Grizo XCPYFLG
  Call INICPY([M]CPY) From CPTSUB
  Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
Else
  Diszo CPY
Endif
#----- Traitement des champs site -----#
If VALEUR=2
  Grizo XFCYFLG : Diszo FCY
Else
  Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPIH
  If mkstat
    Grizo XFCYFLG : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    Affzo FCY : If dim([M]ZFCY)>0  Affzo ZFCY : Endif
    If GNBAUZ=1 Diszo FCY : Endif
  Else
    Diszo FCY
  Endif
Endif
#----- Traitement des champs utilisateur ----#
Call CONTUSR([M]CPY,[M]FCY) From CPTSUB
If mkstat
  Grizo XUSRFLG : Diszo USR : Raz mkstat
Endif
#----- Traitement des champs type de facture -----#
Grizo INVTYP
End

Subprog AM_XCPYFLG(VALEUR)
#-------------------------------------#
# Après modif du flag toutes sociétés #
#-------------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo CPY
  Call INICPY([M]CPY) From CPTSUB
  Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
  Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPIH
  If mkstat
    Grizo XFCYFLG : Actzo FCY : Raz mkstat
    Call INIFCY([M]FCY,[M]CPY) From CPTSUB
    Affzo FCY : If dim([M]ZFCY)>0  Affzo ZFCY : Endif
    If GNBAUZ=1 Diszo FCY : Endif
  Else
    Actzo XFCYFLG
    If [M]XFCYFLG=1
      Call INIFCY([M]FCY,[M]CPY) From CPTSUB
      Affzo FCY : If dim([M]ZFCY)>0  Affzo ZFCY : Endif
    Endif
  Endif
Else
  [M]XFCYFLG=2 : Affzo XFCYFLG : Grizo XFCYFLG
  Effzo CPY, FCY
  If dim([M]ZCPY)>0  Effzo ZCPY : Endif
  If dim([M]ZFCY)>0  Effzo ZFCY : Endif
  Diszo CPY, FCY
Endif
Call CONTUSR([M]CPY,[M]FCY) From CPTSUB
If mkstat
  [M]XUSRFLG=1 : [M]USR=GUSER
  Affzo XUSRFLG, USR : If dim([M]ZUSR)>0  Affzo ZUSR : Endif
  Grizo XUSRFLG : Diszo USR
  Raz mkstat
Else
  Actzo XUSRFLG
  If [M]XUSRFLG=2 Diszo USR Else Actzo USR : Endif
Endif
End


Subprog C_CPY(VALEUR)
#------------------------------------------------------------------#
# Contrôle société : Obligatoire si flag toutes sociétés non coché #
#------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XCPYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_CPY(VALEUR)
#---------------------------#
# Après modif de la société #
#---------------------------#
Variable Char    VALEUR()
Call INIALLFCY([M]XFCYFLG,VALEUR) From FUNPIH
If mkstat
  Grizo XFCYFLG : Actzo FCY : Raz mkstat
  Call INIFCY([M]FCY,VALEUR) From CPTSUB
  Affzo FCY : If dim([M]ZFCY)>0  Affzo ZFCY : Endif
  If GNBAUZ=1 Diszo FCY : Endif
Else
  Actzo XFCYFLG
  If [M]XFCYFLG=1
    Call INIFCY([M]FCY,VALEUR) From CPTSUB
    Affzo FCY : If dim([M]ZFCY)>0  Affzo ZFCY : Endif
  Endif
Endif
Call CONTUSR(VALEUR,[M]FCY) From CPTSUB
If mkstat
  [M]XUSRFLG=1 : [M]USR=GUSER
  Affzo XUSRFLG, USR : If dim([M]ZUSR)>0  Affzo ZUSR : Endif
  Grizo XUSRFLG : Diszo USR
  Raz mkstat
Else
  Actzo XUSRFLG
Endif
End

Subprog AM_XFCYFLG(VALEUR)
#--------------------------------#
# Après modif du flag tous sites #
#--------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo FCY
  Call INIFCY([M]FCY,[M]CPY) From CPTSUB
  Affzo FCY : If dim([M]ZFCY)>0  Affzo ZFCY : Endif
  If GNBAUZ=1 Diszo FCY : Endif
Else
  Effzo FCY : If dim([M]ZFCY)>0  Effzo ZFCY : Endif
  Diszo FCY
Endif
Call CONTUSR([M]CPY,[M]FCY) From CPTSUB
If mkstat
  [M]XUSRFLG=1 : [M]USR=GUSER
  Affzo XUSRFLG, USR : If dim([M]ZUSR)>0  Affzo ZUSR : Endif
  Grizo XUSRFLG : Diszo USR
  Raz mkstat
Else
  Actzo XUSRFLG
Endif
End


Subprog C_FCY(VALEUR)
#----------------------------------------------------------#
# Contrôle site : Obligatoire si flag tous sites non coché #
#----------------------------------------------------------#
Variable Char    VALEUR()
If [M]XFCYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_FCY(VALEUR)
#---------------------#
# Après modif du site #
#---------------------#
Variable Char    VALEUR()
Call CONTUSR([M]CPY,[M]FCY) From CPTSUB
If mkstat
  [M]XUSRFLG=1 : [M]USR=GUSER
  Affzo XUSRFLG, USR : If dim([M]ZUSR)>0  Affzo ZUSR : Endif
  Grizo XUSRFLG : Diszo USR
  Raz mkstat
Else
  Actzo XUSRFLG
Endif
End

Subprog AM_XUSRFLG(VALEUR)
#---------------------------------------#
# Après modif du flag tous utilisateurs #
#---------------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo USR
  [M]USR=GUSER : Affzo USR : If dim([M]ZUSR)>0  Affzo ZUSR : Endif
Else
  Effzo USR : If dim([M]ZUSR)>0  Effzo ZUSR : Endif
  Diszo USR
Endif
End


Subprog C_USR(VALEUR)
#------------------------------------------------------------------------#
# Contrôle utilisateur : Obligatoire si flag tous utilisateurs non coché #
#------------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XUSRFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_XTYPFLG(VALEUR)
#--------------------------------#
# Après modif du type de facture #
#--------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo INVTYP
Else
  Effzo INVTYP
  Diszo INVTYP
Endif
End

Subprog AS_INVTYP(VALEUR)
#---------------------------------#
# Avant saisie du type de facture #
#---------------------------------#
Variable Integer VALEUR
If dim(GMENLOC)>0
  For I=1 To dim(GMENLOC)-1
    GMENLOC(I)=1
  Next I
  GMENLOC(1)=0 : GMENLOC(2)=0 : # Autorisation facture et avoir
Endif
End

Subprog AP_INVTYP(VALEUR)
#-------------------------------#
# Après zone du type de facture #
#-------------------------------#
Variable Integer VALEUR
Raz GMENLOC
End

Subprog AM_STRDAT(VALEUR)
#------------------------------------#
# Après modif de la borne date début #
#------------------------------------#
Variable Date    VALEUR
If VALEUR<>[0/0/0] & ([M]ENDDAT=[0/0/0] | [M]ENDDAT<VALEUR)
  [M]ENDDAT=VALEUR
Endif
End

Subprog AM_VCRDEB(VALEUR)
#--------------------------------------------#
# Après modif de la borne numéro pièce début #
#--------------------------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & ([M]VCRFIN="" | [M]VCRFIN<VALEUR)
  [M]VCRFIN=VALEUR
Endif
End

Subprog C_VCRFIN(VALEUR)
#------------------------------#
# Contrôle numéro de pièce fin #
#------------------------------#
Variable Char    VALEUR()
If VALEUR<[M]VCRDEB mkstat=1 : GMESSAGE=mess(8,135,1) : End : Endif
End


#############################################
# Contrôle si tous les sites sont autorisés #
#############################################
Subprog INIALLFCY(VALEUR,SOC)
Variable Integer  VALEUR
Value    Char     SOC
Local    Integer  I, OK
If GUSRFCY(1)="\"  End : Endif
If GNBAUZ=GNBSITE  End : Endif
If clalev([F:FGR])=0  Local File FACGROUP [FGR] : Endif
If clalev([F:CPY])=0  Local File COMPANY  [CPY] : Endif
If [L]SOC<>""
  OK=1
  Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
  If [F:CPY]CPYLEGFLG=2  : # Société juridique
    For I=1 To GNBSITE
      If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
        OK=0 : Break
      Endif
    Next I
  Else
    For [FGR]FGR0 Where CPY=[L]SOC
      If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
        OK=0 : Break
      Endif
    Next
  Endif
Endif
If !OK
  VALEUR=1 : mkstat=2 : End : # Tous les sites de la société ne sont pas accessibles
Endif
End


###################
# Si erreur Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End




