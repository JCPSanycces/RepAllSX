Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Return

$LEC_DERLU
Read [FCY]FCY0=[F:ID]FCYORI
If fstat : Raz [F:FCY] : Endif
Read [SRV]SRV0=[F:ID]SRV
If fstat : Raz [F:SRV] : Endif
Read [ACC]CODACC=GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [CP3]CPY0=[F:FCY]LEGCPY
If fstat : Raz [F:CP3] : Endif
Return

$CHARGE_DERLU
Return

$REMP_DERLU
Return

$CLE_DERLU
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:ID]REFNUM"
Call TEXTE(10793,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:15X"
SELFOR(NBSEL) = "K:15c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]REFNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]NAM"
Call TEXTE(55,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]NAM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]SRN"
Call TEXTE(1825,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]SRN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:FCY]LEGCPY"
Call TEXTE(1343,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:FCY]LEGCPY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]FCYORI"
Call TEXTE(46641,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]FCYORI"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:ID_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:CP3])=0 : Local file COMPANY [CP3] : Endif
Link [ID] With
& [FCY]FCY0=[F:ID]FCYORI,
& [SRV]SRV0=[F:ID]SRV,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [CP3]CPY0=[F:FCY]LEGCPY
& As [ID_]
[G:ID_]currind = 1
Return

$DEFAUT_LISTE
Default file [ID_]
Return

$OUVRE_JOIN
Return

$TIT_JOIN
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:15c"
LG = 0
TIT = ""
End

$LIENS
Read [FCY]FCY0 = [F:ID]FCYORI
If fstat : Raz [F:FCY] : Endif
Read [SRV]SRV0 = [F:ID]SRV
If fstat : Raz [F:SRV] : Endif
Read [ACC]CODACC = GUSER;[F:ID]CODACS
If fstat : Raz [F:ACC] : Endif
Read [CP3]CPY0 = [F:FCY]LEGCPY
If fstat : Raz [F:CP3] : Endif
Return

