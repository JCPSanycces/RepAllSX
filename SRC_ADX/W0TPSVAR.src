#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TPSVAR 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LEG or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LEG([M]LEG) From MAJVAR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone VARCOD
mkstat = 0
zoncou = "VARCOD"
If varmode([M]VARCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VARCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]VARCOD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTVRA"
  Call CONTVRA([M]VARCOD(indice)) From SUBVRA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]VARCOD(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]VARCOD(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_VARCOD([M]VARCOD(indice)) From MAJVAR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "VARCOD" : GZNUM = 124 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone TYPMAJ
mkstat = 0
zoncou = "TYPMAJ"
IMPENT = [M]TYPMAJ(indice)
If varinit([M]TYPMAJ,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPMAJ,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_TYPMAJ(IMPENT) From MAJVAR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]TYPMAJ(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPMAJ" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPMAJ(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_TYPMAJ(IMPENT) From MAJVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPMAJ" : GZNUM = 3770 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYPMAJ(indice) = IMPENT

## Zone TYPVAL
mkstat = 0
zoncou = "TYPVAL"
IMPENT = [M]TYPVAL(indice)
If varinit([M]TYPVAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPVAL,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_TYPVAL(IMPENT) From MAJVAR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]TYPVAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPVAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPVAL(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_TYPVAL(IMPENT) From MAJVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPVAL" : GZNUM = 1334 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYPVAL(indice) = IMPENT

## Zone DAYTYP
mkstat = 0
zoncou = "DAYTYP"
IMPENT = [M]DAYTYP(indice)
If varinit([M]DAYTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]DAYTYP,indice)=0
 [M]DAYTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DAYTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DAYTYP(indice)
 Endif
Endif
[M]DAYTYP(indice) = IMPENT

## Zone TIMCOD
mkstat = 0
zoncou = "TIMCOD"
If varmode([M]TIMCOD,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_TIMCOD([M]TIMCOD(indice)) From MAJVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]TIMCOD(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "TIMCOD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_TIMCOD([M]TIMCOD(indice)) From MAJVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TIMCOD" : GZNUM = 47810 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NATCOD
mkstat = 0
zoncou = "NATCOD"
If varmode([M]NATCOD,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NATCOD([M]NATCOD(indice)) From MAJVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NATCOD(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NATCOD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NATCOD([M]NATCOD(indice)) From MAJVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NATCOD" : GZNUM = 35058 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone TIMVAR
mkstat = 0
zoncou = "TIMVAR"
If varmode([M]TIMVAR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_TIMVAR([M]TIMVAR(indice)) From MAJVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]TIMVAR(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "TIMVAR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]TIMVAR(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "TIMVAR" : GZNUM = 124 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_TIMVAR([M]TIMVAR(indice)) From MAJVAR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TIMVAR" : GZNUM = 124 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone FORVAR
mkstat = 0
zoncou = "FORVAR"
If varmode([M]FORVAR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FORVAR" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]FORVAR(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FORVAR" : GZNUM = 4574 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_FORVAR([M]FORVAR(indice)) From MAJVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FORVAR" : GZNUM = 4574 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone TIMCMT
mkstat = 0
zoncou = "TIMCMT"
If varmode([M]TIMCMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TIMCMT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CMTDET
mkstat = 0
zoncou = "CMTDET"
IMPENT = [M]CMTDET(indice)
If varinit([M]CMTDET,indice)=0
 IMPENT = 1
Endif
If varmode([M]CMTDET,indice)=0
 [M]CMTDET(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CMTDET" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CMTDET(indice)
 Endif
Endif
[M]CMTDET(indice) = IMPENT

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TPSVAR"
Return

