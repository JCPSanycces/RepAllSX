#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone REFNUM
mkstat = 0
zoncou = "REFNUM"
indice = 0
WCHAR = [M]REFNUM
If varmode([M]REFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REFNUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]REFNUM,"CTR","1","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]REFNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]REFNUM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_REFNUM([M]REFNUM) From SUBECP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CTRNUM
mkstat = 0
zoncou = "CTRNUM"
indice = 0
If varmode([M]CTRNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CTRNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTVCR"
  Call CONTVCR([M]CTRNUM) From TRTDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CTR","$",[M]CTRNUM,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CAT2483
mkstat = 0
zoncou = "CAT2483"
indice = 0
If varinit([M]CAT2483,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CAT2483,"10453","") From SUBADI
 GACTION = SAVACT
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 2
Endif
[M]ENAFLG = IMPENT

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ECP0"
Return

