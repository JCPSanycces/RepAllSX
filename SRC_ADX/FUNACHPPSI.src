#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque PPSIMUL0
#########################################################################
# FUNACHPPSI : Consultation des tarifs d'achat             MBT 03/08/99 #
# --------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                    #
#    - Action e_commerce : SAIPPSI  (Saisie fenêtre)                    #
#                                    Fenêtre : FPPSI                    #
#                        : SAIPPSIM (Saisie fenêtre)  : Détail tarif    #
#                                    Fenêtre : FPPSIM                   #
#########################################################################

$ACTION
#--- Actions liées à la saisie de fenêtre
Case ACTION
  When "OUVRE"        : Case GACTION
                          When "SAIPPSI"      : Gosub OUV_SAIPPSI
                          When "SAIPPSIM"     : Gosub OUV_SAIPPSIM
                        Endcase
  When "TITRE"        : Case GACTION
                          When "SAIPPSI"      : TIT=mess(2,548,1)   # MH - 105537 UI text review. Change from Price Inquiry (117, 195,1) to Price search (2,548, 1)
                          When "SAIPPSIM"     : TIT=mess(74,198,1)
                        Endcase
  When "DEBUT"        : Case GACTION
                          When "SAIPPSI"      : Gosub DEB_SAIPPSI
                          When "SAIPPSIM"     : Gosub DEB_SAIPPSIM
                        Endcase
  When "BOUTON"       : Case GACTION
                          When "SAIPPSI"      : Gosub BOU_SAIPPSI
                        Endcase
  When "FIN"          : Case GACTION
                          When "SAIPPSI"      : Gosub FIN_SAIPPSI
                        Endcase
  When Default
Endcase
Return

########################################################################
# Détail des actions liées à la saisie fenêtre des variables
########################################################################
$OUV_SAIPPSI
Local Integer  RETOUR
Gosub OUVRE : If RETOUR<>0 : FIN = 1 : Return : Endif
Return

#----------------------------------------------------------------------#
$DEB_SAIPPSI
Local Integer I
GORITITCOL=1
Raz [M:PPM0]
#--- Initialisation des valeurs par défaut
[M:PPM0]ORDDAT   =date$
[M:PPM0]XMOIS   =1
GFCY=GFCYDEF(6)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  If !find(GFCY,GUSRFCY(1..GNBAUZ))
    GFCY=GUSRFCY(1)    : # On prend le premier site autorisé
  Endif
  If GNBAUZ=1
    Diszo [PPM0]POHFCY : # Saisie inutile si un seul site permis
  Endif
Endif
[M:PPM0]POHFCY  = GFCY
If GFCY <> GFCYDEF(6)
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT
  If GFINRSP="" GFINRSP=GFCY : Endif
  Call DEFRCPFCY(GFCY)  From TRTACHDEF1
  Call GLOBVAR(GFCY)    From WWGLOBACH
Endif
[M:PPM0]PRHFCY     =GRCPFCY
[M:PPM0]XQTY       =1
[M:PPM0]VPRIDIV    =1
[M:PPM0]PRITYP     =1
Affzo [PPM0]1-99
Return
#----------------------------------------------------------------------#
$BOU_SAIPPSI
Case BOUT
  When "1"       : Gosub AFFICHAGE
  When "2"       : Gosub CONSULTATION
Endcase
FIN=0
Return
#----------------------------------------------------------------------#
$FIN_SAIPPSI
#----- Restitution des variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
If clalev([M:POH0]) & clalev([M:POW0])
  [M:POH0]=[M:POW0]
Endif
If clalev([M:POH1]) & clalev([M:POW1])
  [M:POH1]=[M:POW1]
Endif
If clalev([M:POH2]) & clalev([M:POW2])
  [M:POH2]=[M:POW2]
Endif
If clalev([M:POH3]) & clalev([M:POW3])
  [M:POH3]=[M:POW3]
Endif
#-----
If clalev([M:AD62]) & clalev([M:ADBW])
  [M:AD62]=[M:ADBW]
Endif
Return

########################################################################
# Détail tarifs
########################################################################
$OUV_SAIPPSIM
If clalev([F:PPR])=0  : Local File PPREASON  [PPR]  : Endif
If clalev([M:PPM1])=0 : Local Mask PPSIMUL1  [PPM1] : Endif
Return
#----------------------------------------------------------------------#
$DEB_SAIPPSIM
[M:PPM1]XMOTIFA(0)=mess(70,200,1) : [M:PPM1]NBREN=1
For I=0 To dim(GCOLREM)-1
  If GCOLREM(I)="" Break : Endif
  [M:PPM1]XMOTIFA(I+1)=GCOLREM(I)
  [M:PPM1]NBREN+=1
Next I
If [M:POH2]PRIREN(0)<>0
  Read [PPR] PPR0=[M:POH2]PRIREN(0) : If fstat Raz [F:PPR] : Endif
#  [M:PPM1]XMOTIFB(0)=[F:PPR]DES
  Call GET_ATEXTRA("PPREASON","DESAXX",GLANGUE,[M:PPM1]XMOTIFB(0)) From TRTX3TEX
Endif
For I=1 To 9
  If evalue("dim([M:POH2]DISCRGVAL"+num$(I)+")")>0
    If evalue("[M:POH2]DISCRGREN"+num$(I))<>0
      Read [PPR] PPR0=evalue("[M:POH2]DISCRGREN"+num$(I)) : If fstat Raz [F:PPR] : Endif
#      [M:PPM1]XMOTIFB(I)=[F:PPR]DES
      Call GET_ATEXTRA("PPREASON","DESAXX",GLANGUE,[M:PPM1]XMOTIFB(I)) From TRTX3TEX

    Endif
  Endif
Next I

Call EXPCALPRI
[M:PPM1]NBCAL=find("",[M:PPM1]CALLIB)
If [M:PPM1]NBCAL>0 : [M:PPM1]NBCAL -=1 : Endif

For I=0 To dim([M:PPM1]PLI)-1
    If [M:PPM1]PLI<>""
       Read [PPC]PPC0=[M:PPM1]PLI(I)
       If !fstat : [M:PPM1]PLISEA=[F:PPC]PLISEA : Endif
       Break
    Endif
Next I
Affzo [PPM1]1-99
Return

#-----------------------------------------------------------------#
# Recherche tarif et affichage après appui sur bouton "Appliquer" #
# Appelé en WEB                                                   #
#-----------------------------------------------------------------#
$AFFICHAGE
# Issue 97289 - 2014-03-14 by MUARN : remise/frais en minoration
Local Integer WSENS
Local Decimal WXAUTRE

#----- Chargement des écrans POH0, POH1, POH2 et POH3 -----#
nolign=1
[M:POH0]=[M:PPM0] : [M:POH1]=[M:PPM0] : [M:POH2]=[M:PPM0] : [M:POH3]=[M:PPM0]
[M:POH2]ITMREF(0)=[M:PPM0]XITMREF
[M:POH2]UOM(0)   =[M:PPM0]XPUU
[M:POH2]QTYUOM(0)=[M:PPM0]XQTY
#----- Lecture BPARTNER si nécessaire pour chargement LAN -----#
If [F:BPR]BPRNUM<>[M:PPM0]BPSNUM
  Read [BPR] BPR0=[M:PPM0]BPSNUM
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
[M:POH0]LAN=[F:BPR]LAN
#----- Lecture BPSUPPLIER si nécessaire -----#
If [F:BPS]BPSNUM<>[M:PPM0]BPSNUM
  Read [BPS] BPS0=[M:PPM0]BPSNUM
  If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
#----- Chargement zones provenant du BPSUPPLIER -----#
If dim([M:POH0]TSSCOD)>0
   For I=0 To dim([M:POH0]TSSCOD)-1
       [M:POH0]TSSCOD(I)=[F:BPS]TSSCOD(I)
   Next I
Endif
If [F:BPS]BPRPAY="" [M:POH1]BPRPAY=[F:BPS]BPSNUM
                    [M:POH1]BPAPAY=[F:BPS]BPAADD
               Else [M:POH1]BPRPAY=[F:BPS]BPRPAY
                    [M:POH1]BPAPAY=[F:BPS]BPAPAY    : Endif
If [F:BPS]BPSINV="" [M:POH1]BPSINV=[F:BPS]BPSNUM
                    [M:POH1]BPAINV=[F:BPS]BPAADD
               Else [M:POH1]BPSINV=[F:BPS]BPSINV
                    [M:POH1]BPAINV=[F:BPS]BPAINV    : Endif
[M:POH0]BPRNAM = [F:BPS]BPSNAM
[M:POH1]MDL    = [F:BPS]MDL
[M:POH1]BPTNUM = [F:BPS]BPTNUM
[M:POH1]CHGTYP = [F:BPS]CHGTYP
Raz [M:AD62] : [M:AD62]BPAADD=[F:BPS]BPAADD
#----- Condition de paiement du tiers ou du tiers payé -----#
Call INIPTE ([M:POH1]BPRPAY, [M:POH0]BPSNUM, "F", [M:POH1]PTE) From TRTX3
#----- Chargement du régime taxe du fournisseur -----#
Call INIT_REGIME([M:POH0]BPSNUM,[M:POH0]POHFCY,"F",[M:POH1]VACBPR) From CPTSUB
#----- Chargement du cours devise -----#
Call COURSITE(GCUR,GFCY,[M:POH1]CHGTYP,[M:POH0]ORDDAT,[M:POH1]CHGCOE,GBIDI1) From TRTDEV
#----- Chargement formats frais-remises tarif -----#
Call FMTREM("POH2",GCUR) From TRTPRICE
#----- Conversion Mt mini commande et Mt encours autorisé -----#
If GSYSCUR<>GCUR
   Local Integer STAT
   Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&               [F:BPS]ORDMINAMT,[M:POH2]ORDMINAMT,STAT) From TRTDEV
   Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&               [F:BPS]OSTAUZAMT,[M:POH0]OSTAUZAMT,STAT) From TRTDEV
Else
   [M:POH2]ORDMINAMT=[F:BPS]ORDMINAMT
   [M:POH0]OSTAUZAMT=[F:BPS]OSTAUZAMT
Endif
#------ Chargement des éléments de facturation -----#
Call INIT_ELEMENTS (3,[M:POH1]CHGTYP,[F:BPS]CUR,GCUR) From TRTACHELT1
#----- Initialisation des sections analytiques -----#
If dim([M:POH1]NBAXE)>=0
  Local Char SECTION(GLONCCE)
  [M:POH1]NBAXE=GNBDIE
  For I=1 To GNBDIE
    [M:POH1]DIE(I-1)=GDIE(I)
    Call INISEC(SECTION,"POH",GDIE(I)) From SUBCDE
    [M:POH1]CCE(I-1)=SECTION
  Next I
Endif
#----- Lecture fichiers article, article-site et article-fourn si nécessaire -----#
If [F:ITM]ITMREF<>[M:PPM0]XITMREF
  Read [ITM] ITM0=[M:PPM0]XITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:PPM0]XITMREF | [F:ITF]STOFCY<>GFCY
  Read [ITF] ITF0=[M:PPM0]XITMREF;GFCY : If fstat Raz [F:ITF] : Endif
Endif
If [F:ITP]ITMREF<>[M:PPM0]XITMREF | [F:ITP]BPSNUM<>[M:PPM0]BPSNUM
  Read [ITP] ITP0=[M:PPM0]XITMREF;[M:PPM0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#---- Chargement code acheteur -----#
If [F:ITM]BUY<>"" [M:POH2]LINBUY(0)=[F:ITM]BUY : Endif
If [F:ITF]BUY<>"" [M:POH2]LINBUY(0)=[F:ITF]BUY : Endif
#----- Chargement code article géré en stock -----#
If [F:ITF]ITMREF<>[M:PPM0]XITMREF | [F:ITF]STOFCY<>[M:PPM0]PRHFCY
  Read [ITF] ITF0=[M:PPM0]XITMREF;[M:PPM0]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
[M:POH2]STOMGTCOD(0)=[F:ITF]STOMGTCOD
#-----
#[M:POH2]ITMDES(0)=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:POH2]ITMDES(0), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
If [F:ITF]QUAFLG>1 [M:POH2]QUAFLG(0)=2  Else [M:POH2]QUAFLG(0)=1 : Endif    # hcb V6CQ
If dim([M:POH2]TSICOD1(0))>0 [M:POH2]TSICOD1(0)=[F:ITM]TSICOD(0) : Endif
If dim([M:POH2]TSICOD2(0))>0 [M:POH2]TSICOD2(0)=[F:ITM]TSICOD(1) : Endif
If dim([M:POH2]TSICOD3(0))>0 [M:POH2]TSICOD3(0)=[F:ITM]TSICOD(2) : Endif
If dim([M:POH2]TSICOD4(0))>0 [M:POH2]TSICOD4(0)=[F:ITM]TSICOD(3) : Endif
If dim([M:POH2]TSICOD5(0))>0 [M:POH2]TSICOD5(0)=[F:ITM]TSICOD(4) : Endif
[M:POH2]PUU(0)     =[F:ITM]PUU
[M:POH2]STU(0)     =[F:ITM]STU
[M:POH2]LINTEX(0)  =""
If [F:ITP]PUU<>""      [M:POH2]PUU(0)      =[F:ITP]PUU          : Endif
If [F:ITP]ITMREF<>""   If [F:ITP]QUAFLG>1 [M:POH2]QUAFLG(0)=2
                                     Else [M:POH2]QUAFLG(0)=1   : Endif
                       [M:POH2]PURMINQTY(0)=[F:ITP]PURMINQTY    : Endif
If GACTDEB=2
   If [F:ITP]EECINCRAT<>0 [M:POH2]EECINCRAT(0)=[F:ITP]EECINCRAT : Endif
Endif
#----- Calcul des quantités UA et US -----#
Call PCAL_QTY([M:POH2]QTYUOM(0),[M:POH2]UOM(0),[M:POH2]QTYPUU(0),[M:POH2]PUU(0),
&             [M:POH2]ITMREF(0),[M:POH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
[M:POH2]UOMPUUCOE(0)=GCOEUOM
Call PCAL_QTY([M:POH2]QTYPUU(0),[M:POH2]PUU(0),[M:POH2]QTYSTU(0),[M:POH2]STU(0),
&             [M:POH2]ITMREF(0),[M:POH0]BPSNUM,1,GBIDD1)  From TRTACHQTE1
If [M:POH2]UOM(0)=[M:POH2]PUU(0)
  [M:POH2]UOMFLG(0)=1
Else
  [M:POH2]UOMFLG(0)=2
Endif
#----- Chargement des code taxes -----#
Local Char    VAT(GLONVAT)(3) : Raz VAT
Local Decimal WCLCAMT(1..7)
Call ALIVATCOD(2,[M:POH0]BPSNUM,[M:POH2]ITMREF(0),"POH2",0) From TRTX3
VAT(0)=[M:POH2]VAT1(0)
VAT(1)=[M:POH2]VAT2(0)
VAT(2)=[M:POH2]VAT3(0)
#----- Pour chargement des indicateurs inter-sites/inter-sociétés -----#
GRCPFCY=[M:PPM0]PRHFCY
Call CTRL_INTERSITE([M:POH0]POHFCY,[M:POH0]BPSNUM,2,[M:POH0]BETFCY,[M:POH0]BETCPY,
&                   [M:POH0]SALFCY,[M:POH1]STOFCY,[M:POH0]BPCORD,[M:POH1]INVFCY,
&                   [M:POH1]BPCINV,[M:POH0]DME) From TRTACHCTL1
If mkstat  Raz mkstat : Endif
#----- Recherche du tarif (utilisation de la ligne 1 de l'écran commande POH2) -----#
[M:POH2]RETQTYSTU(0)=0 : [M:POH2]LINFLG(0)=0
GPUU=[M:POH2]PUU(0) : nolign=1 : Call RECH_TARIF ("POH",0) From TRTACHTAR1
# Issue 78774  - 2011-12-20 by VPO : ajout classe sur EXTRCPDAT
#EXTRCPDAT(0)=[M:POH2]RETRCPDAT(0)
[M:POH2]EXTRCPDAT(0)=[M:POH2]RETRCPDAT(0)
[M:POH2]LINAMT(0)=[M:POH2]NETPRI(0)*[M:POH2]QTYUOM(0)
Call ARRDEV([M:POH2]LINAMT(0),GCUR) From TRTDIV
WCLCAMT(1)=[M:POH2]CLCAMT1(0)
WCLCAMT(2)=[M:POH2]CLCAMT2(0)
WCLCAMT(3)=[M:POH2]CLCAMT3(0)
Call CLCTAXEMNT2([M:POH2]LINAMT(0),VAT,1,GSOCIETE,[M:POH0]ORDDAT,WCLCAMT,[M:POH2]LINATIAMT(0)) From TRTX3
Call ARRDEV([M:POH2]LINATIAMT(0),GCUR) From TRTDIV
[M:POH3]TOTORD+=[M:POH2]LINAMT(0)
[M:POH3]TTVORD+=[M:POH2]LINATIAMT(0)
[M:POH2]FBUFLG(0)=1 : [M:POH2]LINFLG(0)=1
#----- Transfert dans écran PPM0 -----#
If [F:TCU]CUR<>[M:PPM0]CUR
  Read [TCU]TCU0=[M:PPM0]CUR : If fstat Raz [F:TCU] : Endif
Endif
[M:PPM0]XGROPRI(0)=[M:POH2]GROPRI(0)
[M:PPM0]XNETPRI(0)=[M:POH2]NETPRI(0)
[M:PPM0]XNETPRI(1)=arr([M:POH2]NETPRI(0)*[M:PPM0]XQTY,[F:TCU]CURRND)
Raz [M:PPM0]XAUTRE
If dim ([M:PPM0]NBREM)>0
  For I=0 To 8
    WSENS = 1 # Issue 97289 - 2014-03-14 by MUARN : remise/frais en minoration
    If evalue("dim([M:POH2]DISCRGVAL"+num$(I+1)+")")>0 : # pour chaque ligne de structure tarif
      # Issue 97289 - 2014-03-14 by MUARN : remise/frais en minoration
      If [F:PRS]INCDCR(I)=2 : WSENS = -1 : Endif
      WXAUTRE = evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)")*WSENS

      # Issue 97289 - 2014-03-14 by MUARN : remise/frais en minoration
#      If [F:PRS]NPRNOTFLG(I)=1                         : # si valeur colonne hors prix net
#        If [F:PRS]CLCRUL(I)=1                          : # si valeur colonne par unité
#          [M:PPM0]XAUTRE(0)+=arr(evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)"),[F:TCU]CURRND)
#          [M:PPM0]XAUTRE(1)+=arr(evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)")*[M:PPM0]XQTY,[F:TCU]CURRND)
#        Endif
#        If [F:PRS]CLCRUL(I)=2                          : # si valeur colonne par ligne
#          [M:PPM0]XAUTRE(1)+=evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)")
#        Endif
#      Endif
      If [F:PRS]NPRNOTFLG(I)=1                         : # si valeur colonne hors prix net
        # VALTYP = Montant
        If [F:PRS]VALTYP(I)=1
          # CLCRTUL = Par unité
          If [F:PRS]CLCRUL(I)=1                          : # si valeur colonne par unité
            [M:PPM0]XAUTRE(0)+=arr(WXAUTRE,[F:TCU]CURRND)
            [M:PPM0]XAUTRE(1)+=arr(WXAUTRE*[M:PPM0]XQTY,[F:TCU]CURRND)
          Endif
          # CLCRTUL = Par ligne
          If [F:PRS]CLCRUL(I)=2                          : # si valeur colonne par ligne
            [M:PPM0]XAUTRE(1)+=WXAUTRE
          Endif
        # VALTYP = % Cumul
        Elsif [F:PRS]VALTYP(I)=2
          # CLCRTUL = Par unité
          If [F:PRS]CLCRUL(I)=1
            [M:PPM0]XAUTRE(0)+=arr([M:POH2]NETPRI(0)*WXAUTRE/100,[F:TCU]CURRND)
            [M:PPM0]XAUTRE(1)+=arr([M:POH2]LINAMT(0)*WXAUTRE/100,[F:TCU]CURRND)
          # Issue 108761 - 2015-06-12 by MUARN : paramétrage impossible
          # CLCRTUL = Par ligne
          #Elsif [F:PRS]CLCRUL(I)=2
          #  [M:PPM0]XAUTRE(1)+=arr([M:POH2]LINAMT(0)*WXAUTRE/100,[F:TCU]CURRND)
          Endif
        # Issue 108761 - 2015-06-11 by MUARN : ajout % cascade
        # VALTYP = % Cascade
        Else
          # CLCRTUL = Par unité
          If [F:PRS]CLCRUL(I)=1
            [M:PPM0]XAUTRE(0)+=arr([M:POH2]NETPRI(0)*WXAUTRE/100,[F:TCU]CURRND)
            [M:PPM0]XAUTRE(1)+=arr([M:POH2]LINAMT(0)*WXAUTRE/100,[F:TCU]CURRND)
          Endif
        Endif
      Endif

    Endif
  Next I
Endif
[M:PPM0]XTOTAL(1)=[M:PPM0]XNETPRI(1)+[M:PPM0]XAUTRE(1)
If dim ([M:PPM0]NBREM)>0
  For I=0 To 8
    If evalue("dim([M:POH2]DISCRGVAL"+num$(I+1)+")")>0
#      If [F:PRS]VALTYP(I)=1
#        [M:PPM0]AMT(I)=evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)")
#      Else
#        [M:PPM0]RAT(I)=evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)")
#      Endif
       If [F:PRS]VALTYP(I)=1
           [M:PPM0]AMT(I)=format$([M]FMTREM(I), evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)"))
       Else
           [M:PPM0]RAT(I)=format$([M]FMTREM(I), evalue("[M:POH2]DISCRGVAL"+num$(I+1)+"(0)"))
       Endif
    Endif
  Next I
Endif
[M:PPM0]NBPRIX=2
If dim ([M:PPM0]NBREM)>0
  Raz [M:PPM0]NBREM
  For I=0 To dim([M:PPM0]COLDES)-1
    If GCOLREM(I)<>""
      [M:PPM0]NBREM+=1
      [M:PPM0]COLDES(I)=GCOLREM(I)
    Endif
  Next I
Endif
If !GIMPORT & !GSERVEUR : Affzo [PPM0] : Endif
Return

#-----------------------------------------------------------------------------#
# Recherche autres tarifs et affichage après appui sur bouton "Consult tarif" #
# Appelé en WEB                                                               #
#-----------------------------------------------------------------------------#
$CONSULTATION
If [M:PPM0]NBPRIX=0 Gosub AFFICHAGE   : Endif
Local Integer   MODULE                : # module (vente achat)
Local Integer   PLITYP                : # type de tarif
Local Char      TRAIT (5)             : # type de traitement
#---- Paramètres complementaires appel recherche tarifs
Local  Char     PARAM_T (25) (0..5)   : # indice 0 = coef. multiplicateur UV --> US

Local Date      DAT                       : # date commande ou livraison
Local Decimal   QTY                       : # quantité
Local Char      UOM(GLONUOM)              : # unité de vente
Local Integer   CHGTYP                    : # type de cours
Local Char      CUR(GLONCUR)              : # devise de la commande
Local Integer   PRITYP                    : # prix ht ou ttc
Local Char      VAT(GLONVAT)      (0..2)  : # codes taxes
Local Decimal   MONTANT           (0..10) : # (0)=prix (1..9)=fr/rem (10)=comm rep
Local Shortint  MOTIF             (0..10) : # motif
Local Shortint  PRIORITE          (0..10) : # priorité
Local Char      PLI(GLONPLI)      (0..10) : # code tarif
Local Char      PLICRD (GLONVCR)  (0..10) : # code de la fiche tarif
Local Integer   PLILIN            (0..10) : # no de ligne de la fiche tarif
Local Char      FOCITMREF(GLONITM)(0..1)  : # article gratuit
Local Decimal   FOCQTY            (0..1)  : # quantité gratuite
Local Char      FOCUOM(GLONUOM)   (0..1)  : # unité vente gratuit
Local Shortint  FOCMOTIF          (0..1)  : # motif gratuit
Local Date      PLISTRDAT                 : # date debut validite
Local Date      PLIENDDAT                 : # date fin   validite
Local Libelle   INTERDIT                  : # 1 si interdit
Local Libelle   ERR                       : # 1 si erreur

Local Shortint  PIO                   : # priorité courante de table globale
Local Integer   JLT

#----- Initialisation -----#
Raz MONTANT, MOTIF, PRIORITE, PLI, PLICRD, PLILIN
Raz FOCITMREF, FOCQTY, FOCUOM, FOCMOTIF
Raz PLISTRDAT, PLIENDDAT, INTERDIT, ERR

If GFONC1="FUNPPSI"
  MODULE=6               : PLITYP=1               : TRAIT="POH"
  DAT=[M:PPM0]ORDDAT     : QTY=[M:PPM0]XQTY       : UOM=[M:PPM0]XPUU
  CHGTYP=[M:POH1]CHGTYP  : CUR=[M:PPM0]CUR        : PRITYP=[M:PPM0]PRITYP
  VAT(0)=[M:POH2]VAT1(0) : VAT(1)=[M:POH2]VAT2(0) : VAT(2)=[M:POH2]VAT3(0)
Endif

If clalev([F:PPC])=0 Local File PPRICCONF [PPC] : Endif

If [M:PPM0]TARNORACT(0)=""
  Raz JLT
  For [PPC] PPC1 Where PLIENAFLG=2 & PLITYP=1 & PLISTC=GPLISTC
    [M:PPM0]TARNORACT(JLT)=[F:PPC]PLI
    [M:PPM0]TARPIO(JLT)   =[F:PPC]PIO
    JLT += 1
    If JLT>dim([M:PPM0]TARNORACT)-1 Break : Endif
  Next
Endif
Effzo [PPM0]35
For I=0 To dim([M:PPM0]TARNORACT)-1
  If [M:PPM0]TARNORACT(I)="" : Break : Endif
  PIO        = [M:PPM0]TARPIO(I)
  PLI(0)     = "*SIMU*"
  Call TARIF(TRAIT,DAT,QTY,UOM,CHGTYP,CUR,PRITYP,VAT,PIO,PARAM_T,MONTANT,MOTIF,PRIORITE,
&            PLI,PLICRD,PLILIN,FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&            PLISTRDAT,PLIENDDAT,INTERDIT) From ="WAT"+[M:PPM0]TARNORACT(I)
Next I
Affzo [PPM0]35
Return


#--------------------------------------------------------#
# Ouverture écrans et fichiers nécessaires au traitement #
# Appelé en WEB                                          #
#--------------------------------------------------------#
$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
If !clalev([M:PPM0])  Local Mask PPSIMUL0 [PPM0] : Endif
If !clalev([M:PPM1])  Local Mask PPSIMUL1 [PPM1] : Endif
#-----
If clalev([M:POH0])
  If !clalev([M:POW0])  Local Mask POH0 [POW0] : Endif
  [M:POW0]=[M:POH0]
Else
  Local Mask POH0 [POH0]
Endif
If clalev([M:POH1])
  If !clalev([M:POW1])  Local Mask POH1 [POW1] : Endif
  [M:POW1]=[M:POH1]
Else
  Local Mask POH1 [POH1]
Endif
If clalev([M:POH2])
  If !clalev([M:POW2])  Local Mask POH2 [POW2] : Endif
  [M:POW2]=[M:POH2]
Else
  Local Mask POH2 [POH2]
Endif
If clalev([M:POH3])
  If !clalev([M:POW3])  Local Mask POH3 [POW3] : Endif
  [M:POW3]=[M:POH3]
Else
  Local Mask POH3 [POH3]
Endif
#-----
If clalev([M:AD62])
  If !clalev([M:ADBW])  Local Mask ADRBPR [ADBW] : Endif
  [M:ADBW]=[M:AD62]
Else
  Local Mask ADRBPR [AD62]
Endif
#-----
Raz [M:PPM0]
#-----
Default Mask [POH3]
Default Mask [POH2]
Default Mask [POH1]
Default Mask [POH0]
Default Mask [PPM0]
#-----
If clalev([F:BPR])=0 Local File BPARTNER   [BPR] : Endif
If clalev([F:BPS])=0 Local File BPSUPPLIER [BPS] : Endif
If clalev([F:MVS])=0 Local File BPSUPPMVT  [MVS] : Endif
If clalev([F:BPA])=0 Local File BPADDRESS  [BPA] : Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITP])=0 Local File ITMBPS     [ITP] : Endif
If clalev([F:ITV])=0 Local File ITMMVT     [ITV] : Endif
If clalev([F:ITS])=0 Local File ITMSALES   [ITS] : Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF] : Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY] : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU] : Endif
If clalev([F:TVT])=0 Local File TABVAT     [TVT] : Endif
If clalev([F:TRA])=0 Local File TABRATVAT  [TRA] : Endif
If clalev([F:PRS])=0 Local File PRICSTRUCT [PRS] : Endif
If clalev([F:PPC])=0 Local File PPRICCONF  [PPC] : Endif
If clalev([F:PPF])=0 Local File PPRICFICH  [PPF] : Endif
If clalev([F:PPL])=0 Local File PPRICLIST  [PPL] : Endif
If clalev([F:PPK])=0 Local File PPRICLINK  [PPK] : Endif
If clalev([F:PFI])=0 Local File PFOOTINV   [PFI] : Endif
If clalev([F:AXX])=0 Local File ATEXTRA    [AXX] : Endif
If clalev([F:POH])=0 Local File PORDER     [POH] : Endif
If clalev([F:PPR])=0 Local File PPREASON   [PPR] : Endif

If GMODU(5)=2            : # si presence module vente
   If clalev([F:BPC])=0  Local File BPCUSTOMER [BPC] : Endif
   If clalev([F:BPD])=0  Local File BPDLVCUST  [BPD] : Endif
   If clalev([F:MVC])=0  Local File BPCUSTMVT  [MVC] : Endif
   If clalev([F:ITS])=0  Local File ITMSALES   [ITS] : Endif
Endif

#-----------------------------------------------------------#
# Chargement des variables globales pour la recherche tarif #
# Récupération de la structure des frais/remises            #
#-----------------------------------------------------------#
Call CTLSTRUCT(2,RETOUR) From TRTPRICE
If RETOUR<>0 Return : Endif
GPLISTC="néant" : # Pour forcer l'affichage des entêtes de colonne si structure=""
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
#----- chargement des formats évalués pour éviter une erreur format à l'affichage -----#
#For I=0 To 8 [M:POH2]FMTREM(I)="NZ:9.2#" : GFORREM(I)="NZ:9.2#" : Next I
#-----
GFCY=GFCYDEF(6)
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
If GFINRSP="" GFINRSP=GFCY : Endif
Call DEFRCPFCY(GFCY)  From TRTACHDEF1
Call GLOBVAR(GFCY)    From WWGLOBACH
#-----
Global Libelle GPOH_INDTAX : # No de la ligne de taxe à traiter
Global Decimal GPOH_RND    : # Arrondi de la devise de la commande
Return


$APRES_MODIF
Return


#--------------------------------------------------#
# S/P d'explication du calcul du prix unitaire net #
# Ce sous-pro est utilisé en WEB                   #
#--------------------------------------------------#
Subprog EXPCALPRI
Local Integer PARTNER
Local Char STRUCTURE (10)
Local Decimal BRUT
Local Decimal MAJREM (0..8)
Local Decimal QTE
Local Decimal NET
Local Char    CUR (GLONCUR)
Local Integer REN (0..10)

PARTNER  =2
STRUCTURE=GPLISTC
BRUT     =[M:POH2]GROPRI(0)
For I=1 To 9
  If evalue("dim([M:POH2]DISCRGVAL"+num$(I)+")") > 0
    MAJREM(I-1)=evalue("[M:POH2]DISCRGVAL"+num$(I)+"(0)")
  Endif
Next I
QTE      =[M:POH2]QTYPUU(0)
NET      =[M:POH2]NETPRI
CUR      =[M:PPM0]CUR
REN(0)   =[M:POH2]PRIREN(0)
For I=1 To 9
  If evalue("dim([M:POH2]DISCRGREN"+num$(I)+")") > 0
    REN(I)=evalue("[M:POH2]DISCRGREN"+num$(I)+"(0)")
  Endif
Next I

Raz [M:PPM1]CALLIB
Call CALNETLIB (PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR,REN,[M:PPM1]PLI,[M:PPM1]CALLIB) From TRTPRICE

End


#########################################################################
#                    Actions sur champ écran PPSIMUL0                   #
#########################################################################

Subprog IB_XITMREF
Raz GBOUT2, GBOUT4, GBOUT5, GBOUT6 : # GBOUT3 chargé par l'action CONSSFC
If [M:PPM0]BPSNUM<>""
  # Issue X3-86112 - 2018-06-15 by SR : Change of the message number
  #GBOUT2=mess(31,198,1) : # Art/Fourn
  GBOUT2=mess(23,198,1)  : # Article-Fournisseur
Endif
If [F:ITM]STOMGTCOD=1
  Raz GBOUT3
Endif
End


Subprog AM_XITMREF(VALEUR)
#-------------------------------------#
# Après modif de la référence article #
#-------------------------------------#
Variable Char    VALEUR()
If [F:ITM]ITMREF<>VALEUR
  Read [ITM] ITM0=VALEUR : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF<>VALEUR | [F:ITP]BPSNUM<>[M:PPM0]BPSNUM
  Read [ITP] ITP0=VALEUR;[M:PPM0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
[M:PPM0]XPUU=[F:ITM]PUU
If [F:ITP]PUU<>"" [M:PPM0]XPUU=[F:ITP]PUU : Endif
If !GIMPORT & !GSERVEUR
  Affzo [PPM0]XPUU
  If [M:PPM0]NBPRIX>0 Effzo [PPM0]20-35 : Endif
Endif
End


Subprog AS_BPSNUM(VALEUR)
#---------------------------------------------------#
# Avant saisie fournisseur : Activation des boutons #
#---------------------------------------------------#
Variable Char    VALEUR()
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
  # Issue X3-96746 - 2018-07-11 by RBA : Search and fields Product and Supplier
#  GBOUT2=mess(31,198,1)  : # Art/Fourn
  GBOUT2=mess(23,198,1)  : # Article-Fournisseur
End


Subprog AM_BPSNUM(VALEUR)
#---------------------------------#
# Après modif du code fournisseur #
#---------------------------------#
Variable Char    VALEUR()
If len([F:BPS]BPSREM) Call MESSAGE([F:BPS]BPSREM) From GESECRAN : Endif
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR
  If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
GCUR=[F:BPS]CUR : [M:PPM0]CUR=[F:BPS]CUR
If !GIMPORT & !GSERVEUR
  Affzo [PPM0]CUR
  If [M:PPM0]NBPRIX>0 Effzo [PPM0]20-35 : Endif
Endif
#----- Chargement libellés et formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
   GPLISTC=[F:BPS]PLISTC
   Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
   Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
   Call TARIFCHGT(6)                From TRTPRICE
#  #----- Affichage entêtes de colonne variables -----#
   If !GIMPORT
      Local Char BASPAG(10) : BASPAG="NBTAR" : Gosub TIT_COL From W1PPSIMUL0
   Endif
Endif
End


Subprog AM_CUR(VALEUR)
#----------------------------#
# Après modif du code devise #
#----------------------------#
Variable Char    VALEUR()
GCUR=VALEUR
If !GIMPORT & !GSERVEUR
  If [M:PPM0]NBPRIX>0 Effzo [PPM0]20-35 : Endif
Endif
End


Subprog AM_POHFCY(VALEUR)
#---------------------------------------------------#
#      Après modification du site de commande       #
# ------------------------------------------------- #
# Rechargement GSOCIETE : Société juridique         #
#              GLOCALDEV: Devise sté juridique      #
#              GFINRSP  : Site financier            #
#              GFCY     : Site commande             #
#              GRCPFCY  : Site réception par défaut #
#---------------------------------------------------#
Variable Char    VALEUR()
GFCY=VALEUR
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
If GFINRSP="" GFINRSP=GFCY : Endif
Call DEFRCPFCY(GFCY) From TRTACHDEF1
Call GLOBVAR(GFCY)   From WWGLOBACH
[M:PPM0]PRHFCY=GRCPFCY
If !GIMPORT & !GSERVEUR
  Affzo [PPM0]PRHFCY
  If [M:PPM0]NBPRIX>0 Effzo [PPM0]20-35 : Endif
Endif
End


Subprog IB_PRHFCY
#------------------------------------------------------#
# Avant saisie site réception : Activation des boutons #
#------------------------------------------------------#
Raz GBOUT1, GBOUT3, GBOUT4, GBOUT5, GBOUT6 : # GBOUT2 chargé par l'action CONSSFC
GBOUT3=mess(4,198,1)   : # Article-Site
End


Subprog C_PRHFCY(VALEUR)
#-----------------------------------------------------#
# Contrôle site de réception : Même société juridique #
# et si article géré en stock site de stockage        #
#-----------------------------------------------------#
Variable Char     VALEUR
If [F:ITM]STOMGTCOD>1
   Call CONTROLE("FCY","D",VALEUR,"",mkstat) From CONTOBJ
   If mkstat End : Endif
Else
   Call CONTROLE("FCY","", VALEUR,"",mkstat) From CONTOBJ
   If mkstat End : Endif
Endif
If [F:FCY]LEGCPY<>GSOCIETE   GMESSAGE=mess(2,194,1)  : mkstat=1 : End : Endif
End


Subprog AM_PRHFCY(VALEUR)
#----------------------------#
# Après modif site réception #
#----------------------------#
Variable Char    VALEUR()
If !GIMPORT & !GSERVEUR
  If [M:PPM0]NBPRIX>0 Effzo [PPM0]20-35 : Endif
Endif
End


