Subprog IB_NBPRIX
#------------------------------------------------#
# Avant zone : Activation boutons "Détail tarif" #
#------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
If [M:PPM0]NBPRIX>0 GBOUT1=mess(74,198,1) : Endif
End
End


Subprog IB_NBREM
#------------------------------------------------#
# Avant zone : Activation boutons "Détail tarif" #
#------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
If [M:PPM0]NBREM>0 GBOUT1=mess(74,198,1) : Endif
End


Subprog IB_NBTAR
#------------------------------------------------------------#
# Avant zone : Activation tunnels "Tarifs" et "Fiche tarifs" #
#------------------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
If nolign>[M:PPM0]NBTAR & [M:PPM0]NBTAR>0  nolign=[M:PPM0]NBTAR : Endif
If [M:PPM0]VPLI(nolign-1)<>""
  GBOUT1=mess(42,198,1)-[M:PPM0]VPLI(nolign-1)
Endif
If [M:PPM0]VPLICRD(nolign-1)<>""
  GFLTPLI=[M:PPM0]VPLI(nolign-1)
  GBOUT2=mess(9,432,1)-[M:PPM0]VPLICRD(nolign-1)
Endif
End


Subprog AV_XLIBPRIX(VALEUR)
#-------------------------#
# Avant zone libellé prix #
#-------------------------#
Variable Char    VALEUR()
pcolor=GCOUL(3)   : # en bleu
If nolign=1 : VALEUR=tolower(mess(269,198,1)) : Endif    : # unitaire
If nolign=2 : VALEUR="* "+num$([M:PPM0]XQTY)  : Endif    : # * qte
End


Subprog AV_COLDES(VALEUR)
#------------------------------------------#
# Avant zone libellé colonne frais/remises #
#------------------------------------------#
Variable Char    VALEUR()
pcolor=GCOUL(3)   : # en bleu
End


#########################################################################
#                    Actions sur champ écran PPSIMUL1                   #
#########################################################################

Subprog IB_NBREN
#------------------------------------------------------------#
# Avant zone : Activation tunnels "Tarifs" et "Fiche tarifs" #
#------------------------------------------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
If [M:PPM1]PLI(nolign-1)<>""
  GBOUT1=mess(42,198,1)-[M:PPM1]PLI(nolign-1)
Endif
If [M:PPM1]PLICRD(nolign-1)<>""
  GFLTPLI=[M:PPM1]PLI(nolign-1)
  GBOUT2=mess(9,432,1)-[M:PPM1]PLICRD(nolign-1)
Endif
End

