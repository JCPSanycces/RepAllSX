$B2_APPDOWN
  Local Char ZONE1, ZONE2
  ZONE2 = ""
  ZONE1 = "[M:MHC0]"+zoncou
  If left$(zoncou,6)="FLDVAL"
    ZONE2="[M:MHC0]VALINT"+right$(zoncou,7)
  Endif

  For I=nolign-1 To [M:MHC0]NBMOD-1
    Assign ZONE1+"("+num$(I)+")" With VALEUR
    If ZONE2<>""
      Assign ZONE2+"("+num$(I)+")" With VALEUR
    Endif
  Next

  Affzo[M:MHC0]
  Gosub CHANGE_STYLE
Return
#end 72635

###################################
# FQ76293 - MABON 16/09/11 - Sélection des salariés éligibles uniquement
$SELEMPMS
Local Integer NBCTR

  If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  If clalev([F:SRV])=0 : Local File SERVICE  [SRV] : Endif
  If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif

  Link [F:ID] With [F:CTR]CTR0=REFNUM As [ID_] Where [F:CTR]CTRDAT<=datesyst & ([F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>=datesyst) & [F:ID]ENAFLG=2
  Local Char    TEXTE(GLONDES)(1..nbrecord([F:ID_]),1..5), TEX(GLONDES)(1..nbrecord([F:ID_]))

  TIT(0) = mess(10,16,1)-mess(8,10489,1) : # Choix Salariés
  NBCOL = 0
  NBCOL += 1 : TIT(NBCOL) = mess(1,10319,1)  : # Matricule
  NBCOL += 1 : TIT(NBCOL) = mess(38,100,1) : # Nom
  NBCOL += 1 : TIT(NBCOL) = mess(69,10701,1) : # Prénom
  NBCOL += 1 : TIT(NBCOL) = mess(2,45,1)   : # Société
  NBCOL += 1 : TIT(NBCOL) = mess(3,45,1)   : # Site
  Raz NBTEX
  For [F:ID_]
    If [F:CTR]CTRNUM<>"" Then
      Raz NBCTR
      Call LECTURE("FCY",[F:CTR]ETRFCY,"") From CONTOBJ
      Call LECTURE("SRV",[F:CTR]ETRSRV,"") From CONTOBJ
      If GUSRACS<>2
        If !fstat
          If [F:ID]CODACS <> "" Then Read [F:ACC]CODACC = GUSER;[F:ID]CODACS : Endif
        Endif
      Endif
      If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:CTR]ETRSRV,GAUTSRV(1..GNBSERV))) Then
        NBCTR += 1
      Endif
      If NBCTR>0 & !find([F:ID]REFNUM,TEX) Then
        NBTEX += 1
        TEXTE(NBTEX,1)  = [F:ID]REFNUM
        TEXTE(NBTEX,2)  = [F:ID]NAM
        TEXTE(NBTEX,3)  = [F:ID]SRN
        TEXTE(NBTEX,4)  = [F:ID]CPY
        TEXTE(NBTEX,5)  = [F:ID]FCY
        TEX(NBTEX)      = [F:ID]REFNUM
      Endif
    Endif
  Next
Return
