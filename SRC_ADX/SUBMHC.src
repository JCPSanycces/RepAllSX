#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("MHC",GBIDC1,"") From GOBJET
End

######################################################################################
## Objet MHC 00/00/0000 00:00:00 (WGA)
######################################################################################
$ACTION
Case ACTION
 When "FILTRE"      : Gosub FILTRE
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "AVANT_MOD"   : Gosub AVANT_MOD
 When "ANNULE"      : Gosub ANNULE
 When "RAZDUP"      : Gosub RAZDUP
 When "APRES_CRE"   : Gosub APRES_CRE #72635
 When "APRES_MOD"   : Call GENHYPO(nomap,[F:MHC]COD) From SUBMHC
 When "SETBOUT"     : Gosub SETBOUT
 #72635
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 #end 72635
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "SEL_LISTE"
  Case LISTE
   When "SELEMPMS"   : Gosub SELEMPMS
  Endcase
 When "FERME"        : Gosub FERME
Endcase
Return

#####################################
$FILTRE
#59696 : Ajout test sur GFLAG
If GFLAG<>""
 Default File [MHC]
 FILTSUP +="TRN=GFLAG"
Endif
Return

#####################################
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only

If clalev ([F:BCB])=0   : Local File BCLOB     [BCB]    : Endif
If clalev ([F:TCA])=0   : Local File TABCOUAFF [TCA]    : Endif
If clalev ([F:HRSCH])=0 : Local File SCRMHCH   [HRSCH]  : Endif
If clalev ([F:SCD])=0   : Local File SCRMHCD   [SCD]    : Endif
If clalev ([F:ATZ])=0   : Local File ATABZON   [ATZ]    : Endif
If clalev ([F:ATY])=0   : Local File ATYPE     [ATY]    : Endif
If clalev ([F:MCL])=0   : Local File MSSCENAL  [MCL]    : Endif
If clalev ([F:MCH])=0   : Local File MSSCENAH  [MCH]    : Endif
If clalev ([F:CPY])=0   : Local File COMPANY   [CPY]    : Endif

Gosub DEFVAR From SUBMHE

Raz GFLDMS
Raz GVRAMS
#Chargement des champs salariés
Local Integer JJ : JJ= 0
For [F:SCD]SCD0 Where [F:SCD]COD=GFLAG & [F:SCD]ORIFLD=1
 Read [F:DIC]DIC0 = [F:SCD]FLD
 If !fstat & ([F:DIC]CODACT = "" | func AFNC.ACTIV([F:DIC]CODACT) > 0)
  JJ+=1
  If JJ > dim(GFLDMS) : Break : Endif
  GFLDMS(JJ,0) = [F:SCD]FLD
  GFLDMS(JJ,1) = [F:SCD]TIT
 Endif
Next

#Chargement des variables salariés
JJ= 0
For [F:SCD]SCD0 Where [F:SCD]COD=GFLAG & [F:SCD]ORIFLD=2
 Read [F:VRA]VRA0 = GCURLEG;[F:SCD]FLD
 If !fstat
  #61896
  Call CONTEXE([F:VRA]CODACC) From CPTSUB
  If !mkstat & ([F:VRA]CODACT = "" | func AFNC.ACTIV([F:VRA]CODACT) > 0)
   JJ+=1
   If JJ > dim(GVRAMS) : Break : Endif
   GVRAMS(JJ,0) = [F:SCD]FLD
   GVRAMS(JJ,1) = [F:SCD]TIT
  Endif
 Endif
Next
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#Ajouter par DBA le 22/04 :
#Vérouillage de la modification, de la suppression et du changement de clé en fonction du contexte
#####################################
$SETBOUT
If GREP<>"" | !VERROU
 Call VIREBOUT (CHAINE,"AH") From GOBJET
 If GREP="M" | GREP="C" | GREP="D"
  Call VIREBOUT (CHAINE,"B") From GOBJET
 Endif
Elsif  [M:MHC0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AH") From GOBJET
Endif

If [M:MHC0]FLGCLO=2
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endif
Return

#72635
$AVANTBOUT
  Effzo [M:MHC0]
  REP="C" : GREP="C"
  Gosub RAZCRE
  Gosub INICRE
Return

$EXEBOUT
  Case BOUT
    When "B"
      If !GOK
        REP="" : GREP=""
      Endif
      Affzo [M:MHC0]
      Gosub CHANGE_STYLE
  Endcase
Return

$APRES_CRE
  Call GENHYPO(nomap,[F:MHC]COD) From SUBMHC
Return
#end 72635


#####################################
$LIENS
# On décoche Définitif si l'hypothèse n'est stockée dans aucun scénario définitif
Link [MCL] With [MCH]MCH0=[MCL]COD
& As [LMC]
& Where [MCH]FLGCLO=2 & [MCL]TYPHYP=6 & [MCL]CODHYP=[F:MHC]COD
Read [LMC]MCL1 First
If fstat
 [M:MHC0]FLGCLO = 1
 Call DEBTRANS From GLOCK
 Gosub TR_LIEN
Endif
Gosub MHC_VALROWFLD
Return

$TR_LIEN
Trbegin [MHC]
 [F:MHC]FLGCLO = 1
 Rewrite[MHC]
 If fstat : Call FSTA("MHC") From GLOCK : Rollback : Return : Endif
Commit
Return

#####################################
$LIENS2
#CMT
Default Mask [M:MHC0]
Call CHARGE_CMT ("SUBMHC",[F:MHC]COD,"","","")From SUBMSR
Gosub TITROWFLD From SUBMHE
Gosub CHG_FMTROW From SUBMHE
Gosub TITROWVRA From SUBMHE
Gosub CHG_FMTVRA From SUBMHE
Affzo [MHC0]
Gosub CHANGE_STYLE
If [M:MHC0]FLGCLO = 2
 Diszo [M:MHC0]BUD
 Diszo [M:MHC0]10
Else
 Actzo [M:MHC0]BUD
 Actzo [M:MHC0]10
Endif
Return

#####################################
$INIMOD
Default Mask [M:MHC0]
Call SAUVE_CMT ("SUBMHC",[F:MHC]COD,"","","")From SUBMSR
Return

#####################################
$INICRE
Local Integer STAT
Local Char    COMPTEUR(GLONANM)
Actzo [M:MHC0]
## Affectation du no de MHC
If [F:MHC]COD=""
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(51,10722,1) : # Compteur MSR non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(14)
 Endif
 Call NUMERO(COMPTEUR,"",date$,"",[F:MHC]COD,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_CPT([F:MHC]COD,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:MHC0]COD = [F:MHC]COD
 Affzo [M:MHC0]COD
Endif

#CMT
Default Mask [M:MHC0]
Call SAUVE_CMT ("SUBMHC",[F:MHC]COD,"","","")From SUBMSR
#enregistrement champs salarié
Gosub SAV_FLDVAL

Return

#####################################
$AVANT_MOD
If [M:MHC0]FLGCLO = 2
 GMESSAGE=mess(6,10722,1) : GERR=1 : OK=0
Endif
Return


#####################################
## Changement de clé
$AP_CHANGE
Call APCHANGE(6,OCODE,NCODE) From SUBMHR
Return

#####################################
$ANNULE
Call ANNULE_CMT ("SUBMHC",[F:MHC]COD,"","","")From SUBMSR
PROG = "WPMS6"+[F:MHC]COD
Call DELTRTHYP (PROG) From SUBMHE
Return

#####################################
$RAZCRE
[M:MHC0]FLGCLO=1
[M]TRN=GFLAG
Gosub TITROWFLD From SUBMHE
Gosub CHG_FMTROW From SUBMHE
Gosub TITROWVRA From SUBMHE
Gosub CHG_FMTVRA From SUBMHE
Affzo [M:MHC0]
Return

#####################################
$RAZDUP
[M:MHC0]FLGCLO=1
Actzo [M:MHC0]BUD
Actzo [M:MHC0]10
Affzo [M:MHC0]
Return

####################################
$CHANGE_STYLE
For nolign=1 To [M:MHC0]NBMOD
 If [M:MHC0]ENAFLG1(nolign-1)=2
  Chgstl [M:MHC0]NBMOD(nolign-1) With "CONTRAT"
 Else
  Chgstl [M:MHC0]NBMOD(nolign-1) With ""
 Endif
Next
Return

####################################
$MHC_VALROWFLD
#alimentation du tableau des valeur des champs & variables salariés (maxi 20+15)
Local Integer L,R

For L=0 To dim([M:MHC0]REFNUM)-1
 If [M:MHC0]REFNUM(L) = "" : Break : Endif
 If [F:MHC]REFNUM = [M:MHC0]REFNUM(L) & [F:MHC]CTRNUM = [M:MHC0]CTRNUM(L)
#CHAMPS SALARIES
  For R=0 To dim([M:MHC0]FLDEML)-1
#on alimente les valeurs que l'on trouve
   Call VALROWFLD("[M:MHC0]FLDVAL"+num$(R)+"("+num$(L)+")","[F:MHC]FLDVAL("+num$(R)+")") From SUBMHE
   Call VALROWFLD("[M:MHC0]VALINT"+num$(R)+"("+num$(L)+")","[F:MHC]FLDVAL("+num$(R)+")") From SUBMHE
#et le code du champs si il correspond
   If [M:MHC0]FLDEML(R) = ""
    Call VALROWFLD("[M:MHC0]FLDEML"+"("+num$(R)+")","[F:MHC]FLDEML("+num$(R)+")") From SUBMHE
   Endif
  Next
#VARIABLES SALARIES
  For R=0 To dim([M:MHC0]VRAEML)-1
   Call VALROWFLD("[M:MHC0]VRAVAL"+num$(R)+"("+num$(L)+")","[F:MHC]VRAVAL("+num$(R)+")") From SUBMHE
   If [M:MHC0]VRAEML(R) = ""
    Call VALROWFLD("[M:MHC0]VRAEML"+"("+num$(R)+")","[F:MHC]VRAEML("+num$(R)+")") From SUBMHE
   Endif
  Next
# Au passage alimentation des noms-prénom
  Call VAL_NAMSRN ([M:MHC0]REFNUM(L),"[M:MHC0]NAMSRN("+num$(L)+")") From SUBMHE
  Break
 Endif
Next
Return

####################################
$SAV_FLDVAL
#enregistrement champs salariés dans la table
Local Integer L,R

For L=0 To [M:MHC0]NBMOD
 If [M:MHC0]REFNUM(L) = [F:MHC]REFNUM & [M:MHC0]CTRNUM(L) = [F:MHC]CTRNUM
  For R=0 To dim(GFLDMS)-1
   [F:MHC]FLDVAL(R) = evalue("[M:MHC0]VALINT"+num$(R)+"("+num$(L)+")")
  Next
  For R=0 To dim(GVRAMS)-1
   [F:MHC]VRAVAL(R) = evalue("[M:MHC0]VRAVAL"+num$(R)+"("+num$(L)+")")
  Next
  Break
 Endif
Next
Return

####################################
Subprog VERIF_CPT(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:MHCX])=0 : Local File MSMODCTR [MHCX] : Endif
Read [MHCX]MHC0(1)=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",date$,"",NUM,STAT) From SUBANM
 Read [MHCX]MHC0(1)=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

Subprog CTL_DBL (REFN,CTRN,LIG)
Value Char REFN
Value Char CTRN
Value Integer LIG
Local Integer IND
GOK=1
For IND=0 To [M:MHC0]NBMOD-1
 If IND<>LIG
  If [M:MHC0]REFNUM(IND)=REFN & [M:MHC0]CTRNUM(IND)=CTRN
   GOK=0 : GMESSAGE = mess(2,10722,1)-num$(IND+1) #Matricule/Contrat déjà saisi
   Break
  Endif
 Endif
Next
End

Subprog LOOK_FLDVAL(REFN,CTRN,LIG)
Value Char REFN
Value Char CTRN
Value Integer LIG
Local Integer MSI,MSJ
Local Char    TTBL  (GLONATB)(1..dim(GFLDMS))
Local Char    TABLE (GLONATB)
For MSI = 1 To dim(GFLDMS)
 Read [F:DIC]DIC0 = [M:MHC0]FLDEML(MSI-1)
 If !fstat & [F:DIC]TBL <> "" & [F:DIC]MSFLG = 2 & [F:DIC]ENAFLG = 2 &
&   ([F:DIC]CODACT = "" | func AFNC.ACTIV([F:DIC]CODACT) > 0)
   MSJ = find([F:DIC]TBL,TTBL(1..dim(GFLDMS)))
  If !MSJ
   TTBL(MSI) = [F:DIC]TBL
   Local File =TTBL(MSI)
   MSJ = MSI
  Endif
  TABLE = TTBL(MSJ) : Gosub DEFAUT From WPDEFTABLE
  [G]currind = 1
  If dim([F]CTRNUM)>0 & TABLE="EMPLOMED"
   Filter [F] Where REFNUM=REFN & (CTRNUM=CTRN | CTRNUM="")
  Elsif dim([F]CTRNUM)>0
   Filter [F] Where REFNUM=REFN & CTRNUM=CTRN
  Else
   Filter [F] Where REFNUM=REFN
  Endif
  Read Last
  If !fstat
   Case [M:MHC0]TYP(MSI-1)
    When 1,2,3,4,5,6
     Assign("[M:MHC0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")") With  num$(evalue("[F]"+[M:MHC0]FLDEML(MSI-1)))
    When  7
     Assign("[M:MHC0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")") With  evalue("[F]"+[M:MHC0]FLDEML(MSI-1))
   Endcase
  Endif
  Filter [F]
 Endif
Next
End

$CONTROW
Local Char       VALCONT(250)
Local Char       FLDINT(30)
Local Char       VALFLDINT(250)
VALCONT = VALEUR
VALFLDINT = VALEUR
FLDINT  = "[M:MHC0]VALINT"+num$(IROW)+"(nolign-1)"
If VALEUR <> ""
 Call CONTGEN([L]VALCONT,[M:MHC0]OBJET(IROW),[M:MHC0]NOLIBFLD(IROW),[M:MHC0]OBJFLD(IROW)) From SUBMHE
 If mkstat : Return : Endif
 #/FMT
 If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
 Call LECTURE("ATY",[M:MHC0]TYPFLD(IROW),"") From CONTOBJ
 If find([F:ATY]TYPTYP,2,3,4)
  VALFLDINT= vireblc(VALFLDINT,4)
 Else
  Local Integer J , K
  Local Char    COMT(100) , FMT(100)
  VALFLDINT = vireblc(VALFLDINT,2)
  If [F:ATY]TYPTYP=7 & [F:ATY]FORTYP<>""
   FMT = [F:ATY]FORTYP
   Repeat
    K = instr(1,FMT,"[")
    If K
     J = instr(K+1,FMT+"]","]")
     COMT = seg$(FMT,K+1,J-1)
     FMT  = left$(FMT,K-1)+right$(FMT,K+1)
     If left$(VALFLDINT,len(COMT))=COMT
      VALFLDINT = right$(VALFLDINT,len(COMT)+1)
     Elsif seg$(VALFLDINT,K,J-2)=COMT
      VALFLDINT = left$(VALFLDINT,K-1)+right$(VALFLDINT,J-1)
     Endif
    Endif
   Until K=0
  Endif
 Endif
Endif
Assign FLDINT With VALFLDINT
#/FMT

Return
######################################################################################

###############################################################################################################
# Génération Traitement lié à l'hypoyhèse courante
# Ce traitement doit se nommer ainsi : "WPMS"+6+COD    (Chiffre 6 cause ML 485)
###############################################################################################################

Subprog GENHYPO(APPLI, CODHYP)
Value Char APPLI ()
Value Char CODHYP()

If clalev ([F:MHC2])=0 : Local File MSMODCTR   [MHC2] : Endif
If clalev ([F:VRA])=0  : Local File VARIA      [VRA] : Endif
If clalev ([F:DIC])=0  : Local File DICOEMP    [DIC] : Endif
If clalev ([F:ATB])=0  : Local File ATABLE     [ATB] : Endif
If clalev ([F:ATZ])=0  : Local File ATABZON    [ATZ] : Endif


Local Char TETADO (50) , PROG (30) , FICSRC(250) , SAVREF(GLONEML)
Local Char CONDDEB (25) , CONDFIN (25)
Local Char XTBL (GLONATB) , XABR (GLONABR)
Local Integer L,R,C,OK
Local Integer MAXVRA : MAXVRA = func AFNC.ACTIV("MSV")
Local Integer MAXFLD : MAXFLD = func AFNC.ACTIV("MSF")

Local Char    TFLDEMP (GLONAVA)(1..MAXFLD)
Local Char    TFLDFUL (GLONABR+4+GLONAVA)(1..MAXFLD) #[F:xxxx]xxxxxx
Local Integer TFLDTYP (1..MAXFLD,1..2)

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

For [F:MHC2]MHC2 Where COD=CODHYP
 If SAVREF = ""
  TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  PROG = "WPMS6"+[F:MHC2]COD
  FICSRC = filpath("TRT",PROG,"src",APPLI)
  Openo FICSRC , 0
  Wrseq TETADO-mess(6,10485,1)-CODHYP
  Wrseq "###############################################"
  Wrseq "###  MODIFICATIONS                            #" : Wrseq
  Wrseq "$HYPOVAR":Wrseq
  Wrseq "If LIGHYPO<>0 : Return : Endif : # On ne traite que le salarié réel": Wrseq
  Wrseq "Case MATRI"
 Endif
 If [F:MHC2]REFNUM <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHC2]REFNUM+"'"
 Endif
 If [F:MHC2]ENAFLG1 = 2
  Wrseq space$(2)+"If CTR='"+[F:MHC2]CTRNUM+"'";

  If [F:MHC2]MODDAT <> [00/00/0000]
   Wrseq " & PERFIN >= ["+num$([F:MHC2]MODDAT)+"]"
  Else
   Wrseq
  Endif

  For R=0 To MAXVRA-1
   If [F:MHC2]VRAVAL(R) <> 0
    Read [F:VRA]VRA0=GCURLEG;[F:MHC2]VRAEML(R)
    If !fstat
     Wrseq space$(3)+format$('K:15X','V_'+[F:VRA]COD)-' ='-num$([F:MHC2]VRAVAL(R))
    Endif
   Endif
  Next
  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHC2]REFNUM
Next
If TETADO<>""
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

SAVREF=""
Raz XTBL , XABR
Raz TFLDEMP , TFLDFUL , TFLDTYP
For [F:MHC2]MHC2 Where COD=CODHYP
 If SAVREF = ""
  Wrseq : Wrseq "###############################################"
  Wrseq "$LECTURE" : Wrseq
  Wrseq "Case MATRI"
 Endif
 If [F:MHC2]REFNUM <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHC2]REFNUM+"'"
 Endif
 If [F:MHC2]ENAFLG1 = 2
  Wrseq space$(2)+"If CTR='"+[F:MHC2]CTRNUM+"'"

#  If [F:MHC2]MODDAT <> [00/00/0000]
#   Wrseq " & PERFIN >= ["+num$([F:MHC2]MODDAT)+"]"
#  Else
#   Wrseq
#  Endif

  Raz L
  #parcours des champs salarié alimentés et génération au bon format
  For R=0 To MAXFLD-1
   Raz [F:DIC] , [F:ATB] , [F:ATZ] , [F:ATY]
   If [F:MHC2]FLDVAL(R) <> "" & [F:MHC2]FLDVAL(R) <> "0,00"
    #stockage du champ salarié et de son type
    L = find([F:MHC2]FLDEML(R),TFLDEMP(1..MAXFLD))
    If L = 0
     L = R+1
     TFLDEMP(L) = [F:MHC2]FLDEML(R)
     Read [F:DIC]DIC0=TFLDEMP(L)
     #recherche de l'abréviation de la table
     If !fstat & [F:DIC]TBL <> XTBL  : #pour ne pas relire inutilement ATABLE
      XTBL = [F:DIC]TBL
      Read [F:ATB]CODFIC=XTBL
      XABR = [F:ATB]ABRFIC
     Endif
     #recherche du type du champ
     Read [ATZ]CODZONE = [F:DIC]TBL;[F:DIC]FLD
     Read [ATY]CODTYP  = [F:ATZ]CODTYP
     TFLDTYP(L,1) = [F:ATY]TYPTYP
     TFLDTYP(L,2) = [F:ATZ]NOLIB
     TFLDFUL(L) = "[F:"+XABR+"]"+TFLDEMP(L)
    Endif
    If !find("",TFLDFUL(L)) & TFLDTYP(L,1) <> 0
     Case TFLDTYP(L,1)
      When 1 :              #menu local
       C=0
       Repeat C+=1
       Until C > len(mess(0,TFLDTYP(L,2),1)) | mess(C,TFLDTYP(L,2),1) = [F:MHC2]FLDVAL(R)
       If C <= len(mess(0,TFLDTYP(L,2),1))
        #58665 Remplace 15X par 20X
        Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' = '+num$(C)
       Endif
      When 2, 3, 4, 5, 6  : #numérique
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' ='-func AFNC.TRANSF([F:MHC2]FLDVAL(R),",",".")
      When 8 :              #date
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' ='-"["+[F:MHC2]FLDVAL(R)+"]"
      When Default :        #alphanumérique
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' = "'+[F:MHC2]FLDVAL(R)+'"'
     Endcase
    Endif
   Endif
  Next
  If L
   Wrseq space$(3)+"## Si LIGHYPO<>0 le contrôle se fait dans $TR2 de TRTCALMS"
   Wrseq space$(3)+"If LIGHYPO=0"
   Wrseq space$(3)+" Gosub CONTROLE From ='WPMSMCH'+SCENARIO"
   Wrseq space$(3)+"Endif"
  Endif
  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHC2]REFNUM
Next
If SAVREF <> ""
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
adxirs = SAVIRS
adxifs = SAVIFS
End
######################################################################################

######################################################################################
Subprog D_BUD(VALEUR)
Variable Char    VALEUR()
Read [F:HRSCH]SCH0 = GFLAG
If !fstat : VALEUR = [F:HRSCH]BUD : Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

#contrat du salarié
Call SELCTR(VALEUR,datesyst,datesyst,[M:MHC0]CTRNUM(nolign-1)) From DIVPAYE
If [M:MHC0]CTRNUM(nolign-1) = ""
 GOK=0 : GMESSAGE =mess(150,10702,1) : #Pas de contrat de travail pour ce salarié
 mkstat = 2
 End
Endif
If [F:ID]FLGMULCTR>1
 Actzo [M:MHC0]CTRNUM(nolign-1)
Else
 Diszo [M:MHC0]CTRNUM(nolign-1)
Endif
If [M:MHC0]CTRNUM(nolign-1) <> ""
#contrôle des doublons
 Call CTL_DBL(VALEUR,[M:MHC0]CTRNUM(nolign-1),nolign-1)
 If !GOK
  mkstat=2
  End
 Endif
#Recherche des valeurs champs salarié MS
 Call LOOK_FLDVAL(VALEUR,[M:MHC0]CTRNUM(nolign-1),nolign-1)
Endif

#73013 : after contract ctrl
#maj nom-prénom
Call VAL_NAMSRN (VALEUR,"[M:MHC0]NAMSRN("+num$(nolign-1)+")") From SUBMHE
Affzo [M:MHC0]NAMSRN(nolign-1)
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Call CTL_DBL([M:MHC0]REFNUM(nolign-1),VALEUR,nolign-1)
If !GOK
 mkstat=2
 End
Endif
Call LOOK_FLDVAL([M:MHC0]REFNUM(nolign-1),VALEUR,nolign-1)
End

Subprog C_NBMOD
If !adxgtb and GREP<>""
 If [M:MHC0]OKFLD=0
  GMESSAGE=mess(3,10722,1) #Déphasage Champs salariés de l'hypothèse / champs salariés transaction
  mkstat=2 : End
 Endif
 If [M:MHC0]OKVRA=0
  GMESSAGE=mess(7,10722,1) #Déphasage Variables salariés de l'hypothèse / Variables salariés définies dans la transaction
  mkstat=2 : End
 Endif
Endif
End

Subprog C_ENAFLG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgstl [M:MHC0]NBMOD(nolign-1) With "CONTRAT"
Else
 Chgstl [M:MHC0]NBMOD(nolign-1) With ""
Endif
End

