#<AdxTL>@(#)0.0.0.0 $Revision$ 
###############################################################################
# UTI2018R07 UTI process for 2018R07 of X3
#
# --------------------------------------------------------------------------- #
#
# moulinettes à passer en fin du patch de la 2017RX - passage de RX-1 vers R07
#
# correction utility to be done at the end of the patch - move from RX-1 to R97
#
###############################################################################

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2018R07 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC


End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2018R07 (APPLI)

End

###################################################
Subprog EXE_UTI2018R07(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2018R07-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#
#-------------------------------------------------------------#

#  Call PATCH  (LDOSSIER) From UTIXXX

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM201807002    # Issue X3-87228 - 2018-06-26 by FGR/ALMON
    Call PATCH(LDOSSIER) From UTIPJM201807003    # Issue X3-101833 - 2018-07-30 by FGR
    Call PATCH(LDOSSIER) From UTIPJM201807004    # Issue X3-101833 - 2018-08-09 by FGR
    Call PATCH(LDOSSIER) From UTIPJM201807005    # Issue X3-99928 - 2018-08-23 by FGR
    Call PATCH(LDOSSIER) From UTIPJM201807006    # Issue X3-102495 - 2018-08-27 by FGR
  Endif

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTINCS201807001    # Issue X3-102479 - 2018-08-06 by STWIL
  Endif

  # Issue X3-100846 - 2018-07-30 by RBA : Update dictionnary & Transaction revalidation script & merge
  If [F:ADS]MODULE(5) = 2
    Call PATCH(LDOSSIER) From SUBPTC #GESPOI #Buyer plan + GESPOH #Purchase order
    Call PATCH(LDOSSIER) From SUBPTT #GESPOC #Supplier open order
    Call PATCH(LDOSSIER) From SUBPTE #GESSCO #Subcontract order
    Call PATCH(LDOSSIER) From SUBPTN #GESPNH #Purchase return
    Call PATCH(LDOSSIER) From SUBPTF #GESPIH #Purchase invoice
    Call PATCH(LDOSSIER) From SUBPPC #GESPPC #Purchase pricing setup for GESPPL
  Endif

  # X3-101037 Revalidation script & merge (LCC- 20/08/18)
  If [F:ADS]MODULE(11)=2
    Call PATCH(LDOSSIER) From SUBCMS #GESSRE #Service request
    Call PATCH(LDOSSIER) From SUBCMI #GESITN #Service responses
  Endif
  If [F:ADS]MODULE(4)=2
    Call PATCH(LDOSSIER) From SUBSLI #GESSIH #Invoices
    Call PATCH(LDOSSIER) From SUBSLA #GESSIH #Credit memo
  Endif
  # End X3-101037 Revalidation script & merge (LCC- 20/08/18)

  If [F:ADS]MODULE(2) = 2 Then                   # Finance module
    Call PATCH(LDOSSIER) From UTICPT201807001    # X3-93186 - 2018-08-14 DNE
  Endif

  # Issue X3-93418 - 2018-08-10 by FHA : Journal Entry Transaction validation
  If [F:ADS]MODULE(1) = 2
    Call PATCH(LDOSSIER) From SUBGDE    # Journal Entry Transaction validation
  Endif
  # Issue 99277 - 2018-09-10 by MAE : validation after update for responsive UI
  If [F:ADS]MODULE(6) = 2
    Call PATCH(LDOSSIER) From SUBSLT #update caracteristics lots
    Call PATCH(LDOSSIER) From SUBSCT #stocks modification
    Call PATCH(LDOSSIER) From CNSALLSTD #allocation
    Call PATCH(LDOSSIER) From CNSSFCSTD #stock by site
    Call PATCH(LDOSSIER) From CNSSHQSTD #fiche qualité
    Call PATCH(LDOSSIER) From CNSSLOSTD #stocks by lot
    Call PATCH(LDOSSIER) From CNSSHTSTD #allocation rupture

  Endif

  # Issue X3-110400 - 2018-09-27 by FHA : Fixed Assets / Business Object Transactions validation
  If [F:ADS]MODULE(13) = 2
    Call PATCH(LDOSSIER) From SUBTSH
  Endif

Call ECR_TRACE("END : UTI2018R07-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2018R07
End




