#<AdxTL>@(#)9.0.0.0 $Revision$
################################################################################################################
# Routage Recherche Destinataire ou Tiers Destinataire                    Module CRM          01 décembre 2000 #
################################################################################################################
$ACTION
  Case ACTION
    When "CONTROLE"     : BOITE = GSZVWNDADD
    When "OUVRE"        : Gosub OUVRE From =GSZVPROGADD
    When "DEFBOUT"      : Gosub DEFBOUT From =GSZVPROGADD
    When "SETBOUT"      : Gosub SETBOUT From =GSZVPROGADD
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE From =GSZVPROGADD
    When "DEBUT"        : Gosub DEBUT From =GSZVPROGADD
    When "AV_CHOIX"     : Gosub AV_CHOIX From =GSZVPROGADD
    When "AP_CHOIX"     : Gosub AP_CHOIX From =GSZVPROGADD
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON From =GSZVPROGADD
    When "FINSAI"       : Gosub FINSAI From =GSZVPROGADD
    When "FIN"          : Gosub FIN From =GSZVPROGADD
    When "ABANDON"      : Gosub ABANDON From =GSZVPROGADD
    When "APRES_MODIF"  : Gosub APRES_MODIF From =GSZVPROGADD
    When "BOUTON"       : Gosub BOUTON From =GSZVPROGADD
    When "MEN"          : Gosub ONMENU From =GSZVPROGADD
    When "OK"           : Gosub ONOK From =GSZVPROGADD
    When Default
  Endcase
Return
