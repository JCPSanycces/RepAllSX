#<AdxTL>@(#)0.0.0.0 $Revision$ 
################################################################################################
# Modifications :
#    MABOS - 11/04/13 - FQ71754 - US1516- Remove the control on the civility 2 (Mrs./Madame)
#                                          to give the possibility to add the birth Name in all cases.
#    14/01/14 - FQ88174 - Addition of before entry action
#                         Modification of allocation ($AFFECT) in the case CHAMP=FLGBULDEM (Novapost)
################################################################################################

$ACTION
Case ACTION
 When "SEL_LISTE"    : Gosub SEL_LISTE
Endcase
Return

##############################################################
## Controle des zones employés en saisie généralisée
##############################################################
Subprog CONT_CHA(VALEUR,CHAMP)
Variable Char VALEUR()
Value    Char CHAMP
Goto CONTROLE

Subprog CONT_INT(VALEUR,CHAMP)
Variable Integer VALEUR()
Value    Char    CHAMP
Goto CONTROLE

Subprog CONT_DAT(VALEUR,CHAMP)
Variable Date VALEUR()
Value    Char CHAMP
Goto CONTROLE

Subprog CONT_NUM(VALEUR,CHAMP)
Variable Decimal VALEUR()
Value    Char    CHAMP
Goto CONTROLE


$CONTROLE
Local Char CARTE(15)
Local Integer STAT
Local Char PAYS(3)
Local Date ENTREE,SORTIE
Case CHAMP
 When "DATSTY" :  #Date carte de séjour
  If dim([M]STYCRD)>0
   CARTE = [M]STYCRD(nolign-1)
  Else
   If [F:AD]REFNUM<>[M]REFNUM(nolign-1)
    Filter [AD] Where REFNUM=[M]REFNUM(nolign-1)
    Read [AD]AD0 Last
    Filter [AD]
   Endif
   CARTE = [F:AD]STYCRD
  Endif
  Call CONTROLE_VALID(CARTE,VALEUR) From SUBEML2

  When "DATWRK" : #Date carte de travail
  If dim([M]WRKCRD)>0
   CARTE = [M]WRKCRD(nolign-1)
  Else
   If [F:AD]REFNUM<>[M]REFNUM(nolign-1)
    Filter [AD] Where REFNUM=[M]REFNUM(nolign-1)
    Read [AD]AD0 Last
    Filter [AD]
   Endif
   CARTE = [F:AD]WRKCRD
  Endif
  Call CONTROLE_VALID(CARTE,VALEUR) From SUBEML2

 When "NUMSSC" : #N° de sécurité sociale
  # FQ83632 - MABON 08/10/12 - Social insurance numbers
  Call LECTURE("EML",[M]REFNUM(nolign-1),"") From CONTOBJ
  Local Char CRYID : CRYID = func TRTDIV.LECPAYSIT([F:ID]FCYORI)
  If VALEUR<>""
#   Call CONTSS (VALEUR,[F:ID]NTT,[F:ID]CRYBRN,[F:ID]SEX,[F:ID]DATBRN,[F:ID]DEPBRN,[F:ID]CTYBRNSEE) From CONTNUM
   Call CONTSS (VALEUR,[F:ID]NTT,CRYID,[F:ID]SEX,[F:ID]DATBRN,[F:ID]DEPBRN,[F:ID]CTYBRNSEE) From CONTNUM
  Endif
  # Fin MABON

 When "NUMSSC2" : #N° de sécurité sociale 2
  # FQ83632 - MABON 08/10/12 - Social insurance numbers
  Call LECTURE("EML",[M]REFNUM(nolign-1),"") From CONTOBJ
  Local Char CRYID : CRYID = func TRTDIV.LECPAYSIT([F:ID]FCYORI)
  If VALEUR<>""
   Call CONTSS2 (VALEUR,[F:ID]NTT,CRYID,[F:ID]SEX,[F:ID]DATBRN,[F:ID]DEPBRN,[F:ID]CTYBRNSEE) From CONTNUM
  Endif
  # Fin MABON

 When "NUMDDS"    : Call CONTROLE_NUMDDS(VALEUR) From SUBEML2 : #N° DADS


 When "AVNNAT"    : Call CONTROLE_AVNNAT(VALEUR) From SUBCTR :#Avantages en nature


 When "EXSPFL"    : Call CONTROLE_EXSPFL(VALEUR) From SUBCTR : #Frais pro

 When "BIDNUM"    : #Rib
  If dim([M]BIDCRY)>0
   PAYS = [M]BIDCRY(nolign-1)
  Else
   If [F:RIB]REFNUM<>[M]REFNUM(nolign-1)
    Filter [RIB] Where REFNUM=[M]REFNUM(nolign-1)
    Read [RIB]RIB0 Last
    Filter [RIB]
   Endif
   PAYS = [F:RIB]BIDCRY
  Endif
  Call CONTROLE_BIDNUM(VALEUR,PAYS) From SUBEML2

  When "JNTREFNUM" :  #Matricule du conjoint
    If VALEUR<>""
     Read[ID]ID0=VALEUR
     If fstat <> 0
      GMESSAGE = mess(83,10702,1) : # Matricule inexistant
      mkstat = 1 : End
     Endif
    Endif

  #DBA le 07/09/04 : Bug no 23387
  #La modification d'une date d'entrée génère une creation de fiche d'entrée/sortie
  When "CTRDAT"
   # LST : dès fois on ne veut pas créer, mais juste passer sur le champ...
   Look [HRCTR]CTR1=[M]REFNUM(nolign-1);[L]VALEUR
   If !fstat : End : Endif

   If dim([M]XITDAT)>0
     SORTIE=[M]XITDAT(nolign-1)
   Else
     If [F:HRCTR]REFNUM<>[M]REFNUM(nolign-1)
     Filter [HRCTR] Where REFNUM=[M]REFNUM(nolign-1)
     Read [HRCTR]CTR1 Last
     Filter [HRCTR]
    Endif
    SORTIE = [F:HRCTR]XITDAT
   Endif
   #Insertion de fiche entrée/sortie impossible...
   #Création de fiche entrée/sortie dont l'entrée < la sortie précédente...
   If VALEUR<[M]CTRDAT(nolign-1) | VALEUR < SORTIE
    GMESSAGE=mess(7,123,1)    :#Création impossible
    mkstat=2 : End
   Endif
   #Création de fiche entrée/sortie sans faire sortir le salarié...
   If SORTIE=[0/0/0]
    #Création impossible : Date de sortie précédente obligatoire
    GMESSAGE=mess(7,123,1)-":"-mess(7,10701,1)
    mkstat=2 : End
   Endif

  ## MULTICONTRAT A MODIFIER QUAND ECRAN EMPLOYE car controle_sortie a changé
  #When "XITDAT"  :#Date de sortie > date d'entree & ctrl existance paie> date de sortie
  # If dim([M]CTRDAT)>0
  #  ENTREE = [M]CTRDAT(nolign-1)
  # Else
  #  If [F:HRCTR]REFNUM<>[M]REFNUM(nolign-1)
  #   Filter [HRCTR] Where REFNUM=[M]REFNUM(nolign-1)
  #   Read [HRCTR]CTR1 Last
  #   Filter [HRCTR]
  #  Endif
  #  ENTREE = [F:HRCTR]CTRDAT
  # Endif
  # Call CONTROLE_SORTIE(ENTREE,VALEUR,[M]REFNUM(nolign-1)) From SUBEML2

  When "DED" :  #Si la déduction est vide pas d'option de déduction possible
   If dim([M]OPEDED)>0
    If VALEUR=0
     Grizo[M]OPEDED(nolign-1)
    Else
     Affzo[M]OPEDED(nolign-1)
    Endif
   Endif

  When "TYPCON" :  #Restriction de saisie si le type de contrat = CDI
   If dim([M]GRDCDD)>0
    If VALEUR=1
     Grizo[M]GRDCDD(nolign-1)
    Else
     Affzo[M]GRDCDD(nolign-1)
    Endif
   Endif
   If dim([M]RPL)>0
    If VALEUR=1
     Grizo[M]RPL(nolign-1)
    Else
     Affzo[M]RPL(nolign-1)
    Endif
   Endif
   If dim([M]GRD)>0
    If VALEUR=1
     Grizo[M]GRD(nolign-1)
    Else
     Affzo[M]GRD(nolign-1)
    Endif
   Endif

  When "TYDPAY" :  #Restriction de saisie si le calcul de paye à l'envers n'est pas demandé
   If dim([M]OBJRUB)>0
    If VALEUR=0
     Grizo[M]OBJRUB(nolign-1)
    Else
     Affzo[M]OBJRUB(nolign-1)
    Endif
   Endif
   If dim([M]OBJVAR)>0
    If VALEUR=0
     Grizo [M]OBJVAR(nolign-1)
    Else
     Affzo[M]OBJVAR(nolign-1)
    Endif
   Endif
   If dim([M]INCVAR)>0
    If VALEUR=0
     Grizo[M]INCVAR(nolign-1)
    Else
     Affzo[M]INCVAR(nolign-1)
    Endif
   Endif

  When "CIV" :  #Restriction de saisie en fonction de la civilité
    #MABOS-11/04/13-FQ71754-US1516
#   If dim([M]OLDNAM)>0
#    If VALEUR=1
#     Grizo[M]OLDNAM(nolign-1)
#    Else
#     Affzo[M]OLDNAM(nolign-1)
#    Endif
#   Endif

  When "SITFAMA"    :  #Restriction de saisie si la situation de famille = célibataire
   # FQ81085 - 09/01/14 - SITFAM est devenu SITFAMA
   # FQ81085 - 25/11/13 - On ne grise le conjoint que si on est leg FRA
   If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
   If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
   Call LECTURE("FCY", [F:ID]FCYORI, "") From CONTOBJ
   Call LECTURE("CPY", [F:FCY]LEGCPY, "") From CONTOBJ
   If [F:CPY]LEG="FRA" Then
     If dim([M]JNTREFNUM)>0
      # FQ81085 - 09/01/14 - SITFAMA n'est pas de type integer, mais alpha. C'est SITFAM qu'il faut tester
#      If VALEUR=1
      If [M]SITFAM(nolign-1)=1
       Grizo[M]JNTREFNUM(nolign-1)
      Else
         Affzo[M]JNTREFNUM(nolign-1)
      Endif
     Endif
     If dim([M]JNTNAM)>0
      # FQ81085 - 09/01/14 - SITFAMA n'est pas de type integer, mais alpha. C'est SITFAM qu'il faut tester
#      If VALEUR=1
      If [M]SITFAM(nolign-1)=1
       Grizo[M]JNTNAM(nolign-1)
      Else
       Affzo[M]JNTNAM(nolign-1)
      Endif
     Endif
     If dim([M]JNTTEL)>0
      # FQ81085 - 09/01/14 - SITFAMA n'est pas de type integer, mais alpha. C'est SITFAM qu'il faut tester
#      If VALEUR=1
      If [M]SITFAM(nolign-1)=1
       Grizo[M]JNTTEL(nolign-1)
      Else
       Affzo[M]JNTTEL(nolign-1)
      Endif
     Endif
   Else
     If dim([M]JNTREFNUM)>0 Then Affzo[M]JNTREFNUM(nolign-1) : Endif
     If dim([M]JNTNAM)>0    Then Affzo[M]JNTNAM(nolign-1)    : Endif
     If dim([M]JNTTEL)>0    Then Affzo[M]JNTTEL(nolign-1)    : Endif
   Endif

  When Default
   If !clalev([M:DIB]) | type([L]VALEUR)<>3 : End : Endif
   Local Integer I , K
   Local Char    TABLE(10)
   K = find(CHAMP,[M:DIB]HISDAT(1..[M:DIB]NBHIS))
   If K
    If VALEUR<>evalue("[M]"+CHAMP+"("+num$(nolign-1)+")")
     TABLE = [M:DIB]HISTBL(K)
     Gosub DEFAUT From WPDEFTABLE
     [F]REFNUM = [M]REFNUM(nolign-1)
     Assign "[F]"+CHAMP With VALEUR
     [G]currind = 2
     Read =
     If !fstat
      Local Integer I
      For I=0 To [G]nbzon-1
       If evalue("dim([M:GEN]"+[G]adxfname(I)+")")>0
        Assign "[M:GEN]"+[G]adxfname(I)+"("+num$(nolign-1)+")" With evalue("[F]"+[G]adxfname(I))
        Affzo ="[GEN]"+[G]adxfname(I)+"("+num$(nolign-1)+")"
       Endif
      Next I
     Else
      Filter [F] Where REFNUM=[M]REFNUM(nolign-1)
      [G]currind = 2
      Read Last
      Filter [F]
      If !fstat & VALEUR<evalue("[F]"+CHAMP)
       GMESSAGE = mess(78,10702,1) : # Date incorrecte
       mkstat = 2 : End
      Endif
     Endif
    Endif
   Endif

 Endcase
End

##############################################################
## Affectation des zones employés
##############################################################
Subprog AFF_CHA(VALEUR,CHAMP)
Variable Char VALEUR()
Value    Char CHAMP
Goto AFFECT

Subprog AFF_INT(VALEUR,CHAMP)
Variable Integer VALEUR()
Value    Char    CHAMP
Goto AFFECT

Subprog AFF_DAT(VALEUR,CHAMP)
Variable Date VALEUR()
Value    Char CHAMP
Goto AFFECT

Subprog AFF_NUM(VALEUR,CHAMP)
Variable Decimal VALEUR()
Value    Char    CHAMP
Goto AFFECT

$AFFECT
Local Char LIBFLD(30), VALCOD(250)
Local Char CPLT(5)
Local Integer WNOLIB
Local Char CHAMPN(25)
Local Integer VALEURN
Local Char VALCODE(250) : #MABOS

Local Integer WI, WAFF :#88174-US2305

# FQ81085 - 17/12/13 - SITFAM et CIV ont été changés en SITFAMA et CIVA
If find(CHAMP,"SITFAMA","CIVA","CIVCTRA")>0 Then
  CHAMPN=left$(CHAMP,len(CHAMP)-1)
  VALEURN=evalue("[M:GEN]"+CHAMPN+"(nolign-1)")
Endif
# Fin FQ81085

[L]WI=nolign :#88174-US2305
For nolign=nolign+1 To [M:GEN]BPAG2
 #88174-US2305
 If (CHAMPN <>"" & (evalue("[M:GEN]"+CHAMPN+"(nolign-1)") <> VALEURN) )
& | (CHAMPN ="" & evalue("[M:GEN]"+CHAMP+"(nolign-1)") <> VALEUR)
  [L]WAFF=0
  If CHAMP="FLGBULDEM"
   If func SUBEML.DISP_BULDEM([M:GEN]REFNUM(nolign-1),"",[0/0/0])=2 &
&  (VALEUR>1 | [M:GEN]VALORI(nolign-1)=1)
    [L]WAFF=1
   Endif
  Else
   [L]WAFF=1
  Endif
  If [L]WAFF=1
   #MABOS-04/03/13-FQ81085-US1335- add a trace
   Call INFO_FLD(CHAMP,K, [L]LIBFLD,[L]WNOLIB) From TRTEMP1
   Call LIST_MOD(CHAMP, nolign-1,  [L]LIBFLD,[L]WNOLIB) From TRTEMP1
   Assign "[M:GEN]"+CHAMP+"(nolign-1)" With VALEUR
   # FQ81085 - 17/12/13 - SITFAM et CIV ont été changés en SITFAMA et CIVA
   If find(CHAMP,"CIVA","CIVCTRA","SITFAMA")>0 Then
    Assign "[M:GEN]"+CHAMPN+"(nolign-1)" With VALEURN
   Endif
   # Fin FQ81085
   Assign "[M:GEN]FLG(nolign-1)" With 1
  Endif
 Endif
Next nolign
Affzo
nolign=[L]WI
Gosub AVANT_SAISIE
#end 88174-US2305
End

##############################################################
## Sélection des dates
##############################################################
$SEL_LISTE
K = find(PARAM(1),[M:DIB]HISDAT(1..[M:DIB]NBHIS))
If K
 Local Char TABLE(10)
 TABLE = [M:DIB]HISTBL(K)
 Gosub DEFAUT From WPDEFTABLE
 [G]currind = 2
 For [F] Where REFNUM=[M:GEN]REFNUM(nolign-1)
  NBTEX += 1
  TEX(NBTEX) = evalue("[F]"+PARAM(1))
  TEXTE(NBTEX) = format$("D:"+GFMDAT4,gdat$(TEX(NBTEX)))
  If [M:DIB]HISDES(K)<>""
   TEXTE(NBTEX) -= evalue("[F]"+[M:DIB]HISDES(K))
  Endif
 Next
Endif
Return

Case PARAM(1)
 When "MEDDAT"
 When "CTRDAT"
  For [HRCTR] Where REFNUM=[M:GEN]REFNUM(nolign-1)
   NBTEX += 1
   TEX(NBTEX) = [F:HRCTR]CTRDAT
   TEXTE(NBTEX) = format$("D:"+GFMDAT4,[F:HRCTR]CTRDAT)
  Next
Endcase
Return

############################################################
#88174-US2305 - Ajout d'une action d'avant saisie
Subprog BS_NUM(VALEUR,CHAMP)
Variable Decimal VALEUR()
Value    Char    CHAMP
Gosub AVANT_SAISIE
End

Subprog BS_CHA(VALEUR,CHAMP)
Variable Char VALEUR()
Value    Char    CHAMP
Gosub AVANT_SAISIE
End

Subprog BS_INT(VALEUR,CHAMP)
Variable Integer VALEUR()
Value    Char    CHAMP
Gosub AVANT_SAISIE
End

Subprog BS_DAT(VALEUR,CHAMP)
Variable Date VALEUR()
Value    Char    CHAMP
Gosub AVANT_SAISIE
End

$AVANT_SAISIE
Case CHAMP
 When "FLGBULDEM"
  If func SUBEML.DISP_BULDEM([M]REFNUM(nolign-1),"",[0/0/0])<>2
   mkstat=2 : End
  Else
   Discombo 0 From FLGBULDEM
   If [M:GEN]VALORI(nolign-1)>1
    Discombo 1 From FLGBULDEM
   Endif
  Endif
Endcase
Return
#end 88174-US2223



