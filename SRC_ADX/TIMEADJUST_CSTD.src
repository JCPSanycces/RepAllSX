#<AdxTL>@(#)0.0.0.0 $Revision$
# Class TIMEADJUST


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
    When "GET_OFFSET" : Gosub GET_OFFSET
Endcase
Return

#**
#* Indicates if at least 1 rule exists in TIMEADJUST
#* @param COD : code
#* @return [V]CST_AOK if at least 1 record exists in TIMEADJUST for COD
#*!
Funprog EXISTS(COD)
Value Char COD
Local File TIMEADJUST
Look [TAD]TAD0(1)=[L]COD
Filter [TAD]
If fstat
    End [V]CST_AERROR
Endif

End [V]CST_AOK

#**
#* Return the Offset corresponding to an adjustment rule
#* @param COD    = Code of adjustment rule
#* @param DATTIM = Calculate Offset at this date
#* @param OFFSET = offset to apply for this adjustment rule
#* @return error code
#*!
$GET_OFFSET

Local Integer DD, MM, YYYY
Local Integer H, M, S
Local Date DAT
Local Datetime DATSTR, DATEND

Local Instance TIMETRANS  Using C_TIMETRANS
TIMETRANS  = NewInstance C_TIMETRANS AllocGroup TIMETRANS

ARET_VALUE = func TIMEZONE_CSTD.CONVERT_FROM_DATETIME(DATTIM, DD, MM, YYYY, H, M, S)
DAT = gdat$(DD,MM,YYYY)

Local File TIMEADJUST [TAD1]
Filter [TAD1] Where [F:TAD1]COD=[L]COD
&                 & [F:TAD1]STRDAT<=DAT
Read [TAD1]TAD0 Last
Filter [TAD1]
If !fstat
    ARET_VALUE = fmet TIMETRANS.GET_DATTIM([F:TAD1]TTRCODSTR,YYYY,DATSTR)
    If ARET_VALUE=[V]CST_AOK
        ARET_VALUE = fmet TIMETRANS.GET_DATTIM([F:TAD1]TTRCODEND,YYYY,DATEND)
        If ARET_VALUE=[V]CST_AOK
            If DATSTR<DATEND
                If DATTIM>=DATSTR & DATTIM<DATEND
                    OFFSET = [F:TAD1]OFFSET
                Endif
            Else    # for southern hemisphere, in the calendar year, start date is after the end date
                If DATTIM>=DATSTR | DATTIM<DATEND
                    OFFSET = [F:TAD1]OFFSET
                Endif
            Endif
        Endif
    Endif
Else
    # No adjustment for the date requested => offset=0
Endif

FreeGroup [L]TIMETRANS
Return

