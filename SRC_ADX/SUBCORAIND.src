#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant. 
#
# l'affectation se fait à partir des tables 
#############################################################################
$COR_SET_HEA_INFO
  Case IMPZON
    When "CNTNUM"
      #Code interlocuteur
      [M:COR0]CNTNUM = [F:AIN]CNTNUM
      [M:COR0]UPDCNTNUM = 0
    When "HOMEML"
      #E-mail personnel
      [M:COR3]HOMEML = [F:AIN]CNTEMA
    When "HOMZIP"
      [M:COR3]HOMZIP = [F:AIN]ZIP
    When "HOMSAT"
      #Etat personnel
      [M:COR3]HOMSAT = [F:AIN]SAT
    When "LNA"
      #Nom
      [M:COR0]LNA = [F:AIN]CNTLNA
    When "HOMCRY"
      #Pays (personnel)
      [M:COR3]HOMCRY = [F:AIN]CRY
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      [M:COR3]HOMCRYNAM = [F:AIN]CRYNAM
    When "FNA"
      #Prénom
      [M:COR0]FNA = [F:AIN]CNTFNA
    When "HOMADD"
      #Adresse rue (personnel)
      Case indice
        When 0
          [M:COR3]HOMADD(0) = [F:AIN]ADD(0)
        When 1    
          [M:COR3]HOMADD(1) = [F:AIN]ADD(1)
        When 2
          [M:COR3]HOMADD(2) = [F:AIN]ADD(2)
      Endcase
    When "HOMFAX"
      #Fax (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([F:AIN]CNTFAX, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMFAX = ""
      Else
        [M:COR3]HOMFAX = [F:AIN]CNTFAX
      Endif
    When "HOMTEL"
      #Téléphone (personnel)
      # FGR 29/07/2010 : X3SUIVI66067
      If func SUBAINCRM.CTLTEL([F:AIN]CNTETS, [F:AIN]CRY) = 1 Then
        [M:COR3]HOMTEL = ""
      Else
        [M:COR3]HOMTEL = [F:AIN]CNTETS
      Endif
    When "HOMMOB"
      #telephone portable (personnel)
      [M:COR3]HOMMOB = [F:AIN]CNTMOB
    When "TTL"
      #Civilité
      [M:COR0]TTL = [F:AIN]CNTTTL
    When "HOMCTY"
      #Ville (personnel)
      [M:COR3]HOMCTY = [F:AIN]CTY
    # FGR 29/03/2010 : X3SUIVI63506 (début)
    When "BIR"
      # Anniversaire
      [M:COR3]BIR = [F:AIN]CNTBIR
    When "LAN"
      # Langue
      [M:COR3]LAN = [F:AIN]CNTLAN
    When "CSP"
      # Catégorie
      [M:COR3]CSP = [F:AIN]CNTCSP
    When "HOMEML"
      # email personnel
      [M:COR3]HOMEML = [F:AIN]CNTEMA
    # FGR 29/03/2010 : X3SUIVI63506 (fin) 
    When "NBLIGNCOP"
      If GREP = "C" Then
        If dim(GSZREP) >= 0 Then  # FGR 29/03/2010 : X3SUIVI63506
          If GSZREP <> "" Then
            [M:COR4]NBLIGNCOP = 1
            [M:COR4]COPREP(0) = GSZREP
          Endif
        Endif
      Endif
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
  Case IMPZON
    When "COPREP"
      If GREP = "C" Then
        If dim(GSZREP) >= 0 Then  # FGR 29/03/2010 : X3SUIVI63506
          If indice = 0 Then
            If GSZREP <> "" Then
              IMPMOD = 1
              [M:COR4]COPREP(indice) = GSZREP
            Endif
          Endif
        Endif
      Endif
  Endcase
Return
