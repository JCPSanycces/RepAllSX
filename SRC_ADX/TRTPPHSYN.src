#<AdxTL>@(#)1.0.0.0 $Revision$
#----------------------------------------------------------------------
# TRTPPHSYN : Ecran de synthèse des saisies d'une demande par variable
#----------------------------------------------------------------------
# (C) PROSPER 08/10
# LOT P03 - 66096
#----------------------------------------------------------------------

# Ne peut être lancé en direct, suppose un masque "HRPPH1" chargé sous les pieds
End

$ACTION
Case [L]ACTION
    When "INIT_DIA"
        Gosub INIT
    When Default
Endcase
Return

$INIT
Local Char WORIGINE(250), WREQNUM([V]GLONHRPPH)
Local Integer RANG, LASTRANG, I
Local Integer AFFICHER_TOTAL

Gosub GET_PPDSTA From TRTPREPAY

# Est ce qu'on veut un total général (i.e. choux & carottes ...)
[L]AFFICHER_TOTAL = 2

[L]WORIGINE = [L]PARAM(1)        : # Permettra de réutiliser le code pour d'autres provenances que GESHRPPH
[L]WREQNUM = [L]PARAM(2)

Case [L]WORIGINE
    When "GESHRPPH"
        Raz [L]LASTRANG, RANG

        For [L]I = 0 To [M:HRPPH1]NBLIG-1
            [L]RANG = find([M:HRPPH1]VRACOD([L]I), [M:DIA]VRACOD)
            [L]RANG -= 1
            If [L]RANG < 0
                [L]RANG = [L]LASTRANG
                [M:DIA]VRACOD([L]RANG) = [M:HRPPH1]VRACOD([L]I)
                [M:DIA]VRAGRP([L]RANG) = [M:HRPPH1]VRAGRP([L]I)
                [M:DIA]VRAROW([L]RANG) = [M:HRPPH1]VRAROW([L]I)
                [L]LASTRANG += 1
            Endif

            [M:DIA]ACPAMT([L]RANG) += [M:HRPPH1]ACPAMT([L]I)
            [M:DIA]DEMAMT([L]RANG) += [M:HRPPH1]DEMAMT([L]I)

            If [M:HRPPH1]DEMAMT([L]I) <> 0 
                [M:DIA]NBVRA([L]RANG) += 1
            Endif

            Case [M:HRPPH1]STA([L]I)
                When [L]PPDSTA_BROUILLON
                    If [M:HRPPH1]DEMAMT([L]I) <> 0
                        [M:DIA]NBBRO([L]RANG) += 1
                    Endif
                When [L]PPDSTA_INACTIF
                    [M:DIA]NBINA([L]RANG) += 1
                When [L]PPDSTA_DEMANDE
                    [M:DIA]NBDEM([L]RANG) += 1
                When [L]PPDSTA_REFUSE
                    [M:DIA]NBREF([L]RANG) += 1
                When [L]PPDSTA_ACCEPTE
                    [M:DIA]NBACP([L]RANG) += 1
                When [L]PPDSTA_PRISENCOMPTE
                    [M:DIA]NBPEC([L]RANG) += 1
            Endcase

        Next

        # On souhaite un total général ....
        If [L]AFFICHER_TOTAL = 2
            # On saute une ligne
            [L]RANG = [L]LASTRANG : [L]LASTRANG += 1

            # Et on rajoute un total            
            [L]RANG = [L]LASTRANG : [L]LASTRANG += 1
            [M:DIA]ACPAMT([L]RANG) = sum([M:DIA]ACPAMT)
            [M:DIA]DEMAMT([L]RANG) = sum([M:DIA]DEMAMT)
        Endif

        [M:DIA]NBLIG = [L]LASTRANG

    When Default
        # Relecture du bordereau (portail ?)
Endcase

Return
