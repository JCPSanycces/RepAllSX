#<AdxTL>@(#)0.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# Actions of work order optimization menu button                            #
# - SAIMFGOPT    Set work order to 'being optimized'                        #
#---------------------------------------------------------------------------#
Local Integer WOPTFLG
Local Integer OK
Local Char MESSAGE(100)
$ACTION
Return

$SUBMITWO
    WOPTFLG = 2
    MESSAGE = mess(356,193,1)
    Gosub UPDATEWO
    If (OK = 2)
        [M:MFG1]MFGTRKFLG = 2
        [M:MFG1]XTRKFLG = mess([M:MFG1]MFGTRKFLG,339,1)
        Affzo [M:MFG1]XTRKFLG
    Endif
Return

$REMOVEWO
    WOPTFLG = 1
    MESSAGE = mess(357,193,1)
    Gosub UPDATEWO
    If (OK = 2)
        If [M:MFG1]SCDFLG = 4
            [M:MFG1]SCDFLG = 2
            [M:MFG1]XSCDFLG = mess([M:MFG1]SCDFLG,335,1)
            Affzo [M:MFG1]XTRKFLG
        Endif
        [M:MFG1]MFGTRKFLG = 1
        [M:MFG1]XTRKFLG = mess([M:MFG1]MFGTRKFLG,339,1)
        Affzo [M:MFG1]XTRKFLG
        Affzo [M:MFG1]XSCDFLG
    Endif
Return

###########################################################################
# ouverture
$UPDATEWO
    Local    Char    WMFGNUM(GLONVCR) : WMFGNUM = [M:MFG0]MFGNUM
    Local    Char    WFCY(GLONFCY)
    Local    Integer WRET
    Local    Integer WLK  : WLK = 0
    Local    Integer WDLK : WDLK = 0

    If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif

    # Prompt the user for confirmation of change
    Call OUINON(MESSAGE, OK) From GESECRAN
    If (OK = 2)
        # Lock the work order
        WLK =  func TRTX3FNC.CHECK_LOCK("MFG",WMFGNUM,1,WDLK)
        If WLK = 0
            Call DEBTRANS From GLOCK
            Trbegin [MFG]
            Readlock [MFG]MFG0=WMFGNUM
            If fstat
                GOK=0
                Call RSTA("MFG","") From GLOCK
            Else
                If [F:MFG]SCDFLG = 4
                    [F:MFG]SCDFLG = 2
                Endif
                [F:MFG]OPTFLG = WOPTFLG
                Rewrite [F:MFG]
                If fstat
                    GOK=0
                    Call RSTA("MFG","") From GLOCK
                Endif
            Endif

            If WOPTFLG=1
                # Issue X3-29698 - 2017-04-07 by CCC : Remove forced dates set by PS & all pins
                Call REMOVE_PS_INFO([F:MFG]MFGNUM) From PSOPTFREE
            Endif

            If GOK=0
                Rollback
            Else
                Commit
            Endif
        Endif
    Endif

    # if we have locked the WO then unlock it
    If WDLK=1
       Unlock = "MFG"+WMFGNUM
    Endif
Return





