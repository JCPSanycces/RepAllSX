#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("SEH",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Masse salariale: Transaction hypothèses entrée (Objet SEH)18/03/2009 00:00:00 (WGA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "SETBOUT"   : Gosub SETBOUT
 When "EXEBOUT"   : Gosub EXEBOUT
 When "LIENS"     : Gosub LIENS
 When "INIMOD"    : Gosub INIMOD
 When "INICRE"    : Gosub INICRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "ANNULE"    : Gosub ANNULE
 When "FERME"     : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
If clalev([F:MH])=0  : Local File MSENTEML [MH]  : Endif
Local Integer LDICO , LVRA
Local Integer LMS , MSJ , MOK
Local Char NOMWIN(10) , APPLI (GLONADS)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only
Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$SETBOUT
If !CLECUR | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
# Transaction transaction inactive
If [M]ENAFLG<>2
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
Return

$EXEBOUT
Case BOUT
 When "V" : APPLI=nomap(0) : Gosub GENERAWI
 When Default
Endcase
Return

$RAZCRE
[M]ENAFLG=2
Return

$LIENS
LDICO = 1
LVRA  = 1
Raz GFLDMS
Raz GVRAMS
#On charge les champs/variables de la transaction
For [F:SED]SED0 Where COD=[F:SEH]COD
 Case [F:SED]ORIFLD
  When 1 #champ salarié
   If LDICO > dim(GFLDMS)
    GMESSAGE=mess(26,100,1)- num$(LDICO) : #Tableau plein
    Break
   Endif
   nolign=LDICO
   [M:SEH1]FLD(nolign-1)=[F:SED]FLD
   [M:SEH1]TIT(nolign-1)=[F:SED]TIT
   [M:SEH1]ORIFLD(nolign-1)=[F:SED]ORIFLD
   GFLDMS(LDICO,0) = [F:SED]FLD
   LDICO+=1
  When 2 #variable salarié
   If LVRA > dim(GVRAMS)
    GMESSAGE=mess(26,100,1)- num$(LVRA) : #Tableau plein
    Break
   Endif
   nolign=LVRA
   [M:SEH2]VRA(nolign-1)=[F:SED]FLD
   [M:SEH2]TIT(nolign-1)=[F:SED]TIT
   [M:SEH2]ORIFLD(nolign-1)=[F:SED]ORIFLD
   GVRAMS(LVRA,0) = [F:SED]FLD
   LVRA+=1
  When Default
 Endcase
Next
[M]NBDICO=LDICO-1
[M]NBVRA =LVRA-1
Return

$VERIF_MOD
MSJ=1
#On vérifie si il y a eu des suppressions de champs ou de variables
For LMS=1 To dim(GFLDMS)
 #57165
 #MSJ = find(GFLDMS(LMS,0),[M:SEH1]FLD(0..[M:SEH1]NBDICO))
 MSJ = find(GFLDMS(LMS,0),[M:SEH1]FLD(0..[M:SEH1]NBDICO-1))
 If !MSJ : Break : Endif
Next
If MSJ
 For LMS=1 To dim(GVRAMS)
  #57165
  #MSJ = find(GVRAMS(LMS,0),[M:SEH2]VRA(0..[M:SEH2]NBVRA))
  MSJ = find(GVRAMS(LMS,0),[M:SEH2]VRA(0..[M:SEH2]NBVRA-1))
  If !MSJ : Break : Endif
 Next
Endif
If !MSJ
#c'est le cas, on vérifie s'il existe une hypothèse pour cette transaction
 Read [F:MH]MHE1=[M:SEH0]COD
 If !fstat #on averti
  MOK=2
  #Les colonnes supprimées vont être supprimées dans les hypothèses de cette transaction
  Call AVERTIR(mess(8,10722,1),MOK) From GESECRAN
  If MOK = 1
   OK=0
  Endif
 Endif
Endif
If [F:SEH]ENAFLG = 2 & [M:SEH0]ENAFLG = 1
 [F:SEH]ENAFLG = 1
 APPLI=nomap(0)
 Gosub GENERAWI
Endif
Return

$INIMOD
$INICRE
Delete [F:SED] Where COD=[F:SEH]COD
If fstat=1
 GOK =-1 : GLOCK = "$SCRMHED" : Return
Endif
Raz GFLDMS
Raz GVRAMS
#champs salarié
For LMS=1 To [M:SEH1]NBDICO
 nolign=LMS
 Raz [F:SED]
 [F:SED]=[M:SEH0]
 [M:SEH1]TIT(nolign-1)=[M:SEH1]ZFLD(nolign-1) #On récupère l'intitulé long
 [F:SED]=[M:SEH1]
 [F:SED]LIG=LMS
 Write [F:SED]
 If fstat<>0
  GOK = 0 : Call FSTA("SED") From GLOCK : Break
 Endif
 GFLDMS(LMS,0) = [F:SED]FLD
Next
#Variables salarié
If !GOK : Return : Endif
For LMS=1 To [M]NBVRA
 nolign=LMS
 Raz [F:SED]
 [F:SED]=[M:SEH0]
 [M:SEH2]TIT(nolign-1)=[M:SEH2]ZVRA(nolign-1) #On récupère l'intitulé long
 [F:SED]FLD=[M:SEH2]VRA(nolign-1)
 [F:SED]TIT=[M:SEH2]TIT(nolign-1)
 [F:SED]ORIFLD=[M:SEH2]ORIFLD(nolign-1)
 [F:SED]LIG=LMS+[M:SEH1]NBDICO
 Write [F:SED]
 If fstat<>0
  GOK = 0 : Call FSTA("SED") From GLOCK : Break
 Endif
 GVRAMS(LMS,0) = [F:SED]FLD
Next
If !GOK : Return : Endif
#Maj des hypothèses...
Gosub MAJHYP From SUBSEH2
Return

$ANNULE
# Annulation de la fenêtre et des traitements associés
NOMWIN = "WFMHE"+[M:SEH0]COD
Call DELWIN(NOMWIN,nomap) From MSKDIV
If GOK<1 : Return : Endif
Delete [F:SED] Where COD=[F:SEH]COD
If fstat=1
 GOK =-1 : GLOCK = "$SCRMHED" : Return
Endif
Return

$GENERAWI
Call GENECR(APPLI,"MHE",[F:SEH]COD,[F:SEH]ENAFLG,[F:SEH]CODACS,[F:SEH]CODACT,[F:SEH]DES) From SUBSEH2
Return

########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File SCRMHEH [SEH1]
 Local File SCRMHED [SED1]
Else
 Local File =[M]DOSORG+".SCRMHEH" [SEH1]
 Local File =[M]DOSORG+".SCRMHED" [SED1]
Endif
If [M]DOSDES=nomap
 Local File SCRMHEH [SEH2]
 Local File SCRMHED [SED2]
Else
 Local File =[M]DOSDES+".SCRMHEH" [SEH2]
 Local File =[M]DOSDES+".SCRMHED" [SED2]
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [SEH1], [SEH2],[SED1],[SED2]
Return

$TR_COP
GOK = 1
Trbegin [SEH2],[SED2]
 Delete [SEH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRMHEH" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SEH2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [SED2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRMHED" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SEHD","") From GLOCK : Goto AB_TR_COP
 Endif
 #Entete
 Read[SEH1]SEH0=TABLE
 If !fstat
  [F:SEH2] = [F:SEH1]
  If dim([F:SEH2]CREUSR)>0 : [F:SEH2]CREUSR = GUSER : Endif
  If dim([F:SEH2]CREDAT)>0 : [F:SEH2]CREDAT = date$ : Endif
  If dim([F:SEH2]CRETIM)>0 : [F:SEH2]CRETIM = time : Endif
  If dim([F:SEH2]UPDUSR)>0 : Raz [F:SEH2]UPDUSR  : Endif
  If dim([F:SEH2]UPDDAT)>0 : Raz [F:SEH2]UPDDAT  : Endif
  If dim([F:SEH2]UPDTIM)>0 : Raz [F:SEH2]UPDTIM  : Endif
  Write [SEH2]
  If fstat
   GOK = 0 : Call FSTA("SEH2") From GLOCK : Return
  Endif
  #Lignes
  For [SED1]SED0 Where COD=[F:SEH1]COD
   [SED2]=[SED1]
   Write [SED2]
   If fstat
    GOK = 0 : Call FSTA("SED2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

Subprog GENDOS(APPLI)
#Génération en masse
Value Char APPLI()
If clalev([F:SEH])=0  : Local File =APPLI+".SCRMHEH"    [SEH]  : Endif
If clalev([F:SED])=0  : Local File =APPLI+".SCRMHED"    [SED]  : Endif
For [SEH]SEH0 Where ENAFLG=2
 If GTRACE<>"" : Call ECR_TRACE([F:SEH]COD,0) From GESECRAN : Endif
  Gosub GENERAWI
 If GOK=0 : Break : Endif
Next
End

######################################################################################
######################################################################################

Subprog AM_FLD(VALEUR)
Variable Char    VALEUR()
#contrôle des doublons
Call CTL_DBL_FLD(VALEUR,nolign-1) From SUBSEH2
 If !GOK
  mkstat=2
  End
 Endif
End

Subprog AM_VRA(VALEUR)
Variable Char    VALEUR()
#contrôle des doublons
Call CTL_DBL_VRA(VALEUR,nolign-1) From SUBSEH2
 If !GOK
  mkstat=2
  End
 Endif
End

######################################################################################
