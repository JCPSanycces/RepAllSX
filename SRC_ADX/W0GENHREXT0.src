#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EXRTEP
mkstat = 0
zoncou = "EXRTEP"
indice = 0
WCHAR = [M]EXRTEP
If varmode([M]EXRTEP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRTEP" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("HREXT","!$",[M]EXRTEP,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "EXRTEP" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]EXRTEP or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_EXRTEP([M]EXRTEP) From TRTGENHREX
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "EXRTEP" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone EXRVLYOLY
mkstat = 0
zoncou = "EXRVLYOLY"
indice = 0
IMPENT = [M]EXRVLYOLY
If varinit([M]EXRVLYOLY,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXRVLYOLY,indice)=0
 [M]EXRVLYOLY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRVLYOLY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXRVLYOLY(indice)
 Endif
Endif
[M]EXRVLYOLY = IMPENT

## Zone EXRLIVIND
mkstat = 0
zoncou = "EXRLIVIND"
indice = 0
IMPENT = [M]EXRLIVIND
If varinit([M]EXRLIVIND,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXRLIVIND,indice)=0
 [M]EXRLIVIND(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRLIVIND" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXRLIVIND(indice)
 Endif
Endif
[M]EXRLIVIND = IMPENT

## Zone EXRBLODUP
mkstat = 0
zoncou = "EXRBLODUP"
indice = 0
IMPENT = [M]EXRBLODUP
If varinit([M]EXRBLODUP,indice)=0
 IMPENT = 1
Endif
[M]EXRBLODUP = IMPENT

## Zone EXRCLEPRE
mkstat = 0
zoncou = "EXRCLEPRE"
indice = 0
IMPENT = [M]EXRCLEPRE
If varinit([M]EXRCLEPRE,indice)=0
 IMPENT = 1
Endif
[M]EXRCLEPRE = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone EXRFILNAM
mkstat = 0
zoncou = "EXRFILNAM"
indice = 0
If varmode([M]EXRFILNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRFILNAM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EXRFILEXT
mkstat = 0
zoncou = "EXRFILEXT"
indice = 0
If varmode([M]EXRFILEXT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRFILEXT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EXRFXDLNG
mkstat = 0
zoncou = "EXRFXDLNG"
indice = 0
IMPENT = [M]EXRFXDLNG
If varinit([M]EXRFXDLNG,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXRFXDLNG,indice)=0
 [M]EXRFXDLNG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRFXDLNG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXRFXDLNG(indice)
 Endif
Endif
[M]EXRFXDLNG = IMPENT

## Zone EXRPRNFLG
mkstat = 0
zoncou = "EXRPRNFLG"
indice = 0
IMPENT = [M]EXRPRNFLG
If varinit([M]EXRPRNFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXRPRNFLG,indice)=0
 [M]EXRPRNFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRPRNFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXRPRNFLG(indice)
 Endif
Endif
[M]EXRPRNFLG = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone EXRDEBSYM
mkstat = 0
zoncou = "EXRDEBSYM"
indice = 0
If varmode([M]EXRDEBSYM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRDEBSYM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EXRCDTSYM
mkstat = 0
zoncou = "EXRCDTSYM"
indice = 0
If varmode([M]EXRCDTSYM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRCDTSYM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EXRSYMPOS
mkstat = 0
zoncou = "EXRSYMPOS"
indice = 0
IMPENT = [M]EXRSYMPOS
If varinit([M]EXRSYMPOS,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXRSYMPOS,indice)=0
 Call INICOMBO(425) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_EXRSYMPOS(IMPENT) From TRTGENHREX
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,425,1))))
 Endif
 [M]EXRSYMPOS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXRSYMPOS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXRSYMPOS(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "EXRSYMPOS" : GZNUM = 802 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]EXRSYMPOS = IMPENT

####################################
## Bloc liste 5
####################################
IMPTBL = 0

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "GENHREXT0"
Return

