#########################################################################
#                                                                       #
#      TRAITEMENTS LIES aux GRAPHIQUES dans les VENTES                  #
#                                                                       #
#########################################################################
#                                                                       #
#-----------------------------------------------------------------------#
# Etiquettes                                                            #
#-----------------------------------------------------------------------#
#                                                                       #
# $DET_PER_LIB                                                          #
#   Détermination du libellé d'une période                              #
#                                                                       #
#                                                                       #
#                                                                       #
#########################################################################

# --------------------------------------------------------------------- #
# Détermination du libellé de la période                                #
# --------------------------------------------------------------------- #
# Entrée = WDTE = Date                                                  #
#          WPER = Périodicité                                           #
#                 1=jour,2=Semaine,4=Mois,5=Trimestre,6=Semestre,7=Année#
# Sortie = WLIB = Libellé                                               #
# --------------------------------------------------------------------- #
$DET_PER_LIB
Local Integer WWEE, WANN, WMOI, WTRI, WSEM

WANN=year(WDTE)

Case WPER
    When 1 : WLIB = format$("D:"+GFMDAT,WDTE)                       : # jour
    When 2 : WWEE=week(WDTE)                                        : # Semaine                  
             If WWEE=53 & year(aweek(WWEE,WANN)+3)<>WANN
                 WSEM=1
             Elsif WWEE=0
                 If dayn(aweek(WWEE,WANN)+3)<4
                     WWEE=1
                 Else
                     WWEE=53 : WANN-=1
                 Endif
             Endif
#             WLIB=mess(2,2231,1)-num$(WWEE)-"/"-right$(num$(WANN),3)
             WLIB=left$(mess(2,2231,1),1)-num$(WWEE)-"/"-num$(WANN)
    When 3 :                                                        : # Quinzaine
    When 4 : WMOI=month(WDTE)                                       : # Mois
             WLIB=format$("D:MMMMMMMMMM",WDTE)-num$(WANN)
    When 5 : WTRI=int((month(WDTE)-1)/3)+1                          : # Trimestre          
             WLIB=left$(mess(5,2231,1),1)-num$(WTRI)-"/"-num$(WANN)
    When 6 : WSEM=int((month(WDTE)-1)/6)+1                          : # Semestre
             WLIB=left$(mess(6,2231,1),1)-num$(WSEM)-"/"-num$(WANN)
    When 7 : WLIB=num$(WANN)                                        : # Année
#            WLIB=mess(7,2231,1)-num$(WANN)                         : # Année
    When 8 :                                                        : # Décade
Endcase

Return

