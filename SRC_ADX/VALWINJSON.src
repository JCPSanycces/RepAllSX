Return

$JSON_ADDNLOC
If dim(WE_ADITEV)<0
  Local Integer WE_ADITEV
  Local Char WE_TEXTEVL(200)(1..) :#SAM 113641
Endif
 WE_VALUE=""
 If WE_NTEX<>0
   ILOCAL+=1
   LOCALIZ(ILOCAL)=num$(WE_NTEX)
   LOCALIZKEY(ILOCAL)=WE_NTEXKEY
 #  WE_VALUE="{@"+HLOCAL+WE_NTEXKEY+"}"
    WE_VALUE="{@"+WE_NTEXKEY+"}"
 Elsif WE_INTEV<>""
   If left$(WE_INTEV,1)="#"
#        If !find(num$(WE_INTEV),LOCALIZ(1..ILOCAL))
       # If !find(num$(WE_INTEV),WE_TEXTEVL(1..WE_ADITEV)) // pb si plusieurs champs d'un meme ecran on la meme formule
          WE_ADITEV+=1
          WE_TEXTEVL(WE_ADITEV)=num$(WE_INTEV)
          ILOCAL+=1
