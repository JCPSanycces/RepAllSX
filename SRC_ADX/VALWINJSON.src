#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char   FENETRE(10),APPLI(10)
APPLI=nomap
#Dbgaff
Local Integer OK,I
#FENETRE = "AQFG"
#FENETRE = "AASELECT"
#FENETRE = "WOSOHSTD"
#FENETRE = "WOPSHALL"
#FENETRE = "VALDICO"
FENETRE = "OAMK"
#FENETRE = "WOPOHALL"
GTRACE = ""
Call VALID(FENETRE,APPLI,1,OK) From VALWIN
#Gosub PROTO_VISU

#End

#
#Call GLOBWEB(nomap) From INTRUTILA
#Gosub ASSJSON
#Gosub JSON_VISU
Gosub PROTO_VISU
End


#  Create the json associated to a window




$JSON
Local Char GENERATORVERSION : GENERATORVERSION="1"
Local Char GENERATORBUILD : GENERATORBUILD="29"
#10 11 12 : Copy/past on grid (MSK feature Ambassador), Tooltip icon (MSK WIN,feature Ambassador), Exclude col fr graph (GRAPH, feature Ambassador)
#13 : 106364 : empty grid due to block or field invisible or activity code not active (MSK)
#14 : 106115 : Graph . $isReadonly grid and avoid $lazyload when readonly (MSK)
#15 : 105836 : json malformed (empty screen) (MSK)
#16 : Fix issue when empty grid due to activity code not active on grid fields (MSK)
#17 : 107512 : Reorder layout blok issue (MSK)
#18 : 110105 : evaluated title of occursed fields (in case of using 'indice') (MSK)
#19 : 110603 : avoid message like : Can't replace 10, 20 Alwready replace 25 (MSK)
#20 : 103278 : Perf : Validation of Windows / Screens (exculde xml generation)
#21 : 115236 : Timestamps in classic XML window and JSON prototypes mimatch
#22 : 114809  : problems in Multilevel planning (VALMSKJSON)
#24 : 113641 : Evaluate non translatable title on occursed fields
#25 #26 : 117700 : Parse error in Syracuse (classic)
#27 : 118962 : Propertie $rows in prototype in place of article.
#28 : 121578 : Multi-line text truncated to One line
#29 : 121133 : error in screen validation
# AKIRA With BLC_RRX +
#
# ADDBLOCLAYOUT :WE_NTEXKEY from BLC_RNG in place of BLC_RRR

#If nomap<>"SUPERV" : Return : Endif
Local Char JSONPROP(250),JSONVALUE(250)
Local Integer NBITEM,NBLAYOUT,NBLL,INJ,RGJ,INJW,WCRUD,WE_REMIND,WECRUD,WE_ECR
Local Char LETW,VALL1(250),VALTEMP1(250)
Local Integer AWB_SELECT   # Fenêtre de sélection (1)


#Local Char LISTMASK(250)
#LISTMASK=":OZZS:OAMK:"
#If instr(1,LISTMASK,":"+FENETRE+":")<=0 : Return : Endif

# Ouverture du fichier json
Call NAMEFIC(APPLI,"WINDJ","",FENETRE,WE_NOMFIC) From INTRUTILA
Openo WE_NOMFIC,0 Using [JSO_]
Iomode adxifs "" Using [JSO_]
Iomode adxirs chr$(10) Using [JSO_]
Iomode adxium GUTF8 Using [JSO_]

# Détermination des indices pour les IDX des onglets
Local Char AWI_LETIDX(1)(1..MAXFOL)
If AWI_NOMMSK(1)<>"" : AWI_LETIDX(1)="A" : RGJ=1 : Endif
For INJ=2 To AWI_NBRMSK
  If AWI_FLGMSK(INJ)=2
#    AWI_LETIDX(INJ)=mid$(WE_ALPHAB,INJ-1+RGJ,1)
     RGJ+=1
     AWI_LETIDX(INJ)=mid$(WE_ALPHAB,RGJ,1)
  Endif
Next INJ

Gosub JSON_INITLOC : HLOCAL="W-"+FENETRE+"-"

If AWB_NBR > 0 & AWB_OBJ(1) = "AAA"
 AWB_SELECT = 1
Endif

# Ecriture entête
Wrseq '{'  Using [JSO_]
JSONPROP="$type" : JSONVALUE="application/json" : Gosub ADDJSONPROPV From VALMSKJSON
WE_NTEXKEY="W_"+FENETRE
WE_NTEX=AWI_DES : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
JSONPROP="$generatorVersion" : JSONVALUE=GENERATORVERSION : Gosub ADDJSONPROPV  From VALMSKJSON
JSONPROP="$generatorBuild" : JSONVALUE=GENERATORBUILD : Gosub ADDJSONPROPV  From VALMSKJSON
JSONPROP="$generationDate" : JSONVALUE=WE_HORDAT : Gosub ADDJSONPROPV  From VALMSKJSON

If AWI_OBJ<>"" : JSONPROP="$object" : JSONVALUE=AWI_OBJ : Gosub ADDJSONPROPV  From VALMSKJSON : Endif
If AWI_TRN<>"" : JSONPROP="$transaction" : JSONVALUE=AWI_TRN : Gosub ADDJSONPROPV  From VALMSKJSON : Endif
 JSONPROP="$x3Facet"
 Case AWI_TYP
   When 1 : JSONVALUE="fullscreen"
   When 2 : JSONVALUE="dialog"
   When 3 : JSONVALUE="message"
 Endcase
Gosub ADDJSONPROPV  From VALMSKJSON

Wrseq '"$properties":{'  Using [JSO_]
#La génération des fenêtes AASELECT et AACHOOSE sort du cadre générique:
Case FENETRE
 When "AASELECT" : Gosub HEADER_AASELECT
 When "AACHOOSE" : Gosub HEADER_AACHOOSE
 When Default    : Gosub HEADER
Endcase



If AWB_SELECT = 0
 #FENETRE <> AASELECT et AACHOOSE
 #Ecriture links
 Gosub WINLINKS

 # Ecriture actions
 Gosub WINACTIONS
Endif



# Ecriture articles
Gosub WINARTICLES

# Ecritures des localisations
Gosub JSON_LOCALIZW

# Fermeture fichier
Wrseq "}}"  Using [JSO_]
Openo Using [JSO_]

# Assemblage
Gosub ASSJSON

Return

$HEADER_AACHOOSE
Wrseq '"bA": {'  Using [JSO_]
JSONPROP="$type" : JSONVALUE="application/x-array" : Gosub ADDJSONPROPV From VALMSKJSON
JSONPROP="$capabilities" : JSONVALUE= "sort,filter" : Gosub ADDJSONPROPV From VALMSKJSON
JSONPROP="$isFieldPager" : JSONVALUE= "true" : Gosub ADDJSONPROPV From VALMSKJSON
Wrseq '"$links": {'  Using [JSO_]
Wrseq '"$next": {'  Using [JSO_]
WE_NTEXKEY="O_"+FENETRE+"_next"
WE_NTEX=-126031 : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
#Wrseq '"$title":"mynext",'  Using [JSO_]
Wrseq '"$url": "leftList-Next",'  Using [JSO_]
Wrseq '"$type": "application/json"'  Using [JSO_]
Wrseq '},'  Using [JSO_]
Wrseq '"$previous": {'  Using [JSO_]

WE_NTEXKEY="O_"+FENETRE+"_previous"
WE_NTEX=-126030 : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
#Wrseq '"$title":"myprev",'  Using [JSO_]


Wrseq '"$url": "leftList-Prev",'  Using [JSO_]
Wrseq '"$type": "application/json"'  Using [JSO_]
Wrseq '}' Using [JSO_]
Wrseq '}' Using [JSO_]
Wrseq '}' Using [JSO_]
Wrseq "},"  Using [JSO_]
Return

$HEADER_AASELECT
Wrseq '"bA": {'  Using [JSO_]
JSONPROP="$type" : JSONVALUE="application/x-array" : Gosub ADDJSONPROPV From VALMSKJSON
JSONPROP="$isFieldPager" : JSONVALUE= "false" : Gosub ADDJSONPROPV From VALMSKJSON
Wrseq '"$item": {'  Using [JSO_]
Wrseq '"$properties": {'  Using [JSO_]
Wrseq '"bA1": {' Using [JSO_]
JSONPROP="$type"  : JSONVALUE="application/x-string": Gosub ADDJSONPROP From VALMSKJSON
Wrseq '}' Using [JSO_]
Wrseq '}' Using [JSO_]
Wrseq '}' Using [JSO_]
Wrseq '}' Using [JSO_]
Wrseq VALL1+"},"  Using [JSO_]
Return


$HEADER
VALL1=""
For INJ=1 To AWI_NBRMSK
  If AWI_FLGMSK(INJ)=2
    If VALL1<>"" : Wrseq VALL1+","  Using [JSO_] : Endif
    VALL1='"'+AWI_LETIDX(INJ)+'_<!ENTITY!>": ["'+AWI_LETIDX(INJ)+'", "$properties", "../../ALL/SCRNJ/'+AWI_NOMMSK(INJ)+'.json"]'
#  Rajouter virgule si pas dernier
  Endif
Next INJ
If VALL1<>""
  If AWB_NBR>0 : VALL1+="," : Else : VALL1+="}," : Endif
  Wrseq VALL1  Using [JSO_]
Endif
For INJ=1 To AWB_NBR
  Wrseq '"b'+mid$(WE_ALPHAB,INJ,1)+'" : {'  Using [JSO_]
  If AWB_NUM(INJ)<>"9" and AWB_FLE(INJ) <> 1
    Wrseq '"$links": {'  Using [JSO_]
    Wrseq '"$next": {'  Using [JSO_]
    WE_NTEXKEY="O_"
    If(OBJET="")
       WE_NTEXKEY+=AWB_ABR(INJ)
    Else
      WE_NTEXKEY+=OBJET
    Endif
    WE_NTEXKEY+="_"+mid$(WE_ALPHAB,INJ,1)+"_next"
    WE_NTEX=-126031 : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
    JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
#    Wrseq '"$title":"mynext",'  Using [JSO_]

    Wrseq '"$url": "leftList-Next",'  Using [JSO_]
    Wrseq '"$type": "application/json"'  Using [JSO_]
    Wrseq '},'  Using [JSO_]

    Wrseq '"$previous": {'  Using [JSO_]
        WE_NTEXKEY="O_"
    If(OBJET="")
       WE_NTEXKEY+=AWB_ABR(INJ)
    Else
      WE_NTEXKEY+=OBJET
    Endif
    WE_NTEXKEY+="_"+mid$(WE_ALPHAB,INJ,1)+"_previous"
    WE_NTEX=-126030 : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
    JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
#   Wrseq '"$title":"myprev",'  Using [JSO_]

    Wrseq '"$url": "leftList-Prev",'  Using [JSO_]
    Wrseq '"$type": "application/json"'  Using [JSO_]
    Wrseq '      }'  Using [JSO_]
    Wrseq '},'  Using [JSO_]
  Endif
  If AWB_TRE(INJ)>1 and AWB_TRE(INJ)<5
   JSONPROP="$type" : JSONVALUE="application/x-array" : Gosub ADDJSONPROPV From VALMSKJSON
   JSONPROP="$isFieldPager" : JSONVALUE= "true" : Gosub ADDJSONPROP From VALMSKJSON
  Else
    VALL1='"L'+mid$(WE_ALPHAB,INJ,1)+'_<!ENTITY!>": ["'+mid$(WE_ALPHAB,INJ,1)+'", "$properties", "../../ALL/OBJTJ/OBJ_'+AWB_OBJ(INJ)+'.json"]'
    Wrseq VALL1  Using [JSO_]
  Endif
  If INJ=AWB_NBR : Wrseq "}}," Using [JSO_] : Else : Wrseq "}," Using [JSO_] : Endif
Next INJ
Return



$WINLINKS
Wrseq '"$links": {' Using [JSO_]
#  ------ les links


# items de menus
WE_NIVEAU=0
WE_MENCOU=0
WE_1=0
WE_ECR=0
For WE_COU=1 To AWT_NBR
#   Ecriture item
      If AWT_COD(WE_COU)<>"" and AWT_NIV(WE_COU)>0
          If WE_ECR>0
            Wrseq '},' Using [JSO_]
          Endif
          WE_ECR+=1
          Wrseq '"aB'+num$(WE_COU)+'": {' Using [JSO_]
        #  JSONPROP="$category" : JSONVALUE="fusionLink" : Gosub ADDJSONPROPV  From VALMSKJSON
          WE_NTEXKEY="L_"+num$(AWT_STA(WE_COU)+1024)
          WE_NTEX=AWT_TXT(WE_COU) : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
          JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
          JSONPROP="$act" : JSONVALUE=num$(AWT_STA(WE_COU)+1024) : Gosub ADDJSONPROP  From VALMSKJSON
      Endif
# Fin ecriture bouton
Next WE_COU

If WE_ECR>0
  Wrseq '}' Using [JSO_]
Endif

# Boutons standard en bas de fenêtre
WI_MAXBST=5        : #  Les 5 premiers sur tous les modèles sauf les consultations
#If(GUSER="LV") : WI_MAXBST=6 :Endif
If AWI_WINTYP=3 or AWI_WINTYP=4 : WI_MAXBST=MAXBST : Endif
WE_BCO=0 : WECRUD=0
For WE_COU=1 To WI_MAXBST
  If AWI_STA(WE_COU)<>0 and AWI_STA(WE_COU)<>GSTAEND
    WE_BCO+=1 :     WECRUD+=1   :# CCORA
    If WECRUD>1 or (WECRUD=1 and WE_ECR>0) : Wrseq ','  Using [JSO_] : Endif
    Gosub ADDBTN_JS
  Endif
Next WE_COU

# Boutons spéciaux
WE_REMIND=WE_BCO
For WE_COU=1 To AWT_NBR
  If AWT_NIV(WE_COU)=0
    WE_BCO+=1
  Endif
Next WE_COU

 # Ajout du bouton Fin
WE_I=find(GSTAEND,AWI_STA(1..MAXBST))
If WE_I>0 and AWI_STA(WE_I)<>0
  WE_BCO+=1 : WECRUD+=1
  If WECRUD>1 or (WECRUD=1 and WE_ECR>0) : Wrseq ','  Using [JSO_] : Endif
  Gosub $ADDBTN_FIN
Endif


Wrseq "},"  Using [JSO_]
Return


$WINACTIONS
#  ------ les actions
Wrseq '"$actions": {' Using [JSO_]

# Boutons spéciaux
WE_BCO=WE_REMIND
For WE_COU=1 To AWT_NBR
  If AWT_NIV(WE_COU)=0
    If WE_BCO>WE_REMIND : Wrseq ',' Using [JSO_] : Endif
    WE_BCO+=1
    Gosub ADDBTN_JS1
  Endif
Next WE_COU

Wrseq "},"  Using [JSO_]

Return


$ADDBTN_JS
Wrseq '"aA'+num$(WE_BCO)+'": {' Using [JSO_]
#JSONPROP="$category" : JSONVALUE="fusionLink" : Gosub ADDJSONPROPV  From VALMSKJSON
WE_NTEXKEY="L_"+num$(AWI_STA(WE_COU)+1024)
WE_NTEX=AWI_TXT(WE_COU) : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
JSONPROP="$act" : JSONVALUE=num$(AWI_STA(WE_COU)+1024) : Gosub ADDJSONPROP  From VALMSKJSON
Wrseq '}' Using [JSO_]
Return

$ADDBTN_JS1
Wrseq '"aA'+num$(WE_BCO)+'": {' Using [JSO_]
#JSONPROP="$category" : JSONVALUE="fusionLink" : Gosub ADDJSONPROPV  From VALMSKJSON
WE_NTEXKEY="L_"+num$(AWT_STA(WE_COU)+1024)
WE_NTEX=AWT_TXT(WE_COU) : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
JSONPROP="$act" : JSONVALUE=num$(AWT_STA(WE_COU)+1024) : Gosub ADDJSONPROPN  From VALMSKJSON
Wrseq '}' Using [JSO_]
Return

$ADDBTN_FIN
Wrseq '"aA'+num$(WE_BCO)+'": {' Using [JSO_]
#JSONPROP="$category" : JSONVALUE="fusionLink" : Gosub ADDJSONPROPV  From VALMSKJSON
WE_NTEX=-123065
WE_NTEX=-9801040
WE_NTEXKEY="L_"+num$(GSTAEND+1024)
WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
JSONPROP="$title" : JSONVALUE=WE_VALUE : Gosub ADDJSONPROPV  From VALMSKJSON
JSONPROP="$act" : JSONVALUE=num$(GSTAEND+1024) : Gosub ADDJSONPROP  From VALMSKJSON
Wrseq '}' Using [JSO_]
Return


$WINBUTTON
WE_NIVEAU=0
WE_MENCOU=0
WE_1=0
Local Integer WE_ECR,WE_NIVCG,IIJ
Local Integer AWT_VIRG(1..max(1,AWT_NBR)),AWT_MVIRG(1..max(1,AWT_NBR))
For WE_COU=1 To AWT_NBR
  If AWT_NIV(WE_COU)<>0
    WE_ECR=1
    If WE_COU<AWT_NBR  and AWT_STA(WE_COU)<>0 and ((AWT_NIV(WE_COU)=AWT_NIV(WE_COU+1) and AWT_STA(WE_COU+1)<>0)
&                       or                            (AWT_LNI(WE_COU)=AWT_LNI(WE_COU+1) and AWT_STA(WE_COU+1)=0))
#&                      or                         (int(AWT_NIV(WE_COU)/10)=int(AWT_NIV(WE_COU+1)/10) and AWT_STA(WE_COU+1)=0))

      AWT_VIRG(WE_COU)=1
    Endif
    For IIJ=WE_COU+1 To AWT_NBR
      If AWT_NIV(IIJ)=AWT_NIV(WE_COU) or left$(num$(AWT_NIV(IIJ)),1)>left$(num$(AWT_NIV(WE_COU)),1)
        AWT_MVIRG(IIJ)=1
        Break 1
      Endif
    Next IIJ
  Endif
Next WE_COU
#If WE_ECR=0 : Return : Endif


Wrseq '"$menus": {' Using [JSO_]
Wrseq '"$layout": {' Using [JSO_]
Wrseq '"$items": [' Using [JSO_]

# insertion du tableau des boutons CRUD
If WECRUD>=1
  Wrseq '{"$style": "main",' Using [JSO_]
  Wrseq '"$layout": {' Using [JSO_]
  Wrseq '"$items": [' Using [JSO_]

  WE_BCO=0
  For WE_COU=1 To WI_MAXBST
    If AWI_STA(WE_COU)<>0 and AWI_STA(WE_COU)<>GSTAEND
      If WE_BCO>0 : Wrseq ',' Using [JSO_] : Endif
      WE_BCO+=1
      Wrseq '{ "$bind": "aA'+num$(WE_BCO)+'"}'  Using [JSO_]
    Endif
  Next WE_COU

# Boutons spéciaux
  WE_REMIND=WE_BCO
  For WE_COU=1 To AWT_NBR
    If AWT_NIV(WE_COU)=0
      WE_BCO+=1
    Endif
  Next WE_COU

 # Ajout du bouton Fin
  WE_I=find(GSTAEND,AWI_STA(1..MAXBST))
  If WE_I>0 and AWI_STA(WE_I)<>0
    If WE_REMIND>0 : Wrseq ',' Using [JSO_] : Endif
    WE_BCO+=1
 #   Wrseq '{ "$bind": "aA'+num$(WE_BCO)+'"}'  Using [JSO_]
#
    Wrseq '{ "$bind": "aA'+num$(WE_BCO)+'",'  Using [JSO_]
     Wrseq '"$style" : "end"}'  Using [JSO_]
  Endif

  If WE_ECR=0
    Wrseq ']}}' Using [JSO_]
  Else
    Wrseq ']}},' Using [JSO_]
  Endif

Endif

# Fin insertion boutons CRUD

For WE_COU=1 To AWT_NBR
  If AWT_NIV(WE_COU)<>0
    WE_K=AWT_NIV(WE_COU)/10
    If WE_K<>WE_NIVEAU
      Gosub WE_CHGNIV
    Else
      If AWT_COD(WE_COU)=""        : #  C'est un sous-menu
        If WE_MENCOU=2 : Gosub WECR_FMENUG : Endif
        WE_MENCOU=2 :  Gosub WECR_MENU
      Else                         : #  C'est un Item de menu
        If AWT_NIV(WE_COU)<>WE_1 : WE_MENCOU=1 : Gosub WECR_FMENUG : Endif
        Gosub WECR_ITEM
      Endif
    Endif
  Endif
  WE_1=AWT_NIV(WE_COU)
Next WE_COU


For WE_COU=1 To WE_MENCOU
  Gosub WECR_FMENU
Next WE_COU
Wrseq ']}},' Using [JSO_]
Return

#  On change de niveau
$WE_CHGNIV
  For indice=1 To WE_MENCOU
    If indice=WE_MENCOU and AWT_MVIRG(WE_COU)=1
      Gosub WECR_FMENUV
    Else
      Gosub WECR_FMENU
    Endif
  Next indice
   WE_MENCOU=1
  Gosub WECR_MENU
  WE_NIVEAU=AWT_NIV(WE_COU)/10
Return

$WECR_MENU:
  # Menu
  WE_NTEXKEY="L_"+num$(AWT_NIV(WE_COU))+"_"+ num$(WE_COU) #num$(AWT_TXT(WE_COU))
  WE_NTEX=AWT_TXT(WE_COU) : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC From VALWINJSON
  Wrseq '{"$title":"'+WE_VALUE+'",' Using [JSO_]
  Wrseq '"$layout": {' Using [JSO_]
  Wrseq '"$items": [' Using [JSO_]

Return

$WECR_FMENUG:
If AWT_MVIRG(WE_COU)=1
  Gosub WECR_FMENUV
Else
  Gosub WECR_FMENU
Endif
Return

$WECR_FMENU:
  Wrseq "]}}"Using [JSO_]
Return

$WECR_FMENUV:
  Wrseq "]}},"Using [JSO_]
Return

$WECR_ITEM:
  # Ecriture Item de menu
  VALL1='{"$bind" : "aB'+num$(WE_COU)  +'"}'
  If AWT_VIRG(WE_COU)=1 : VALL1+=',' : Endif
  Wrseq VALL1 Using [JSO_]
Return





$WINARTICLES
#  ------ les articles
# Si il y a des listes gauches, on crée un cadre layout 25/75

Gosub WINBUTTON

# Ecrans

If AWB_SELECT <> 1 & AWB_NBR>0
    Wrseq '"$fusionBar":  {' Using [JSO_]
    Wrseq '"$category": "fusionBar",' Using [JSO_]
    Wrseq '"$items":[' Using [JSO_]
    VALL1=""
    For INJ=1 To AWB_NBR
      WE_NTEXKEY="O_"
      If(OBJET="")
         WE_NTEXKEY+=AWB_ABR(INJ)
      Else
        WE_NTEXKEY+=OBJET
      Endif
       WE_NTEXKEY+="_"+mid$(WE_ALPHAB,INJ,1)
      If VALL1<>"" :     Wrseq VALL1+","  Using [JSO_] : Endif
      WE_NTEX=AWB_INT(INJ) : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0 : Gosub JSON_ADDNLOC
      VALL1='{"$title":"'+WE_VALUE+'",'
      If AWB_TRE(INJ)=3 or AWB_TRE(INJ)=5
        VALL1+='"$selectMode":"'+"multi"+'",'
      Else
        VALL1+='"$selectMode":"'+"row"+'",'
      Endif
      If AWB_TRE(INJ)=4
         VALL1+='"$isNodeLazyLoad":'+'true'+','
      Endif
      VALL1+='"L'+mid$(WE_ALPHAB,INJ,1)+'_<!ENTITY!>": ["'+mid$(WE_ALPHAB,INJ,1)+'", "$layout", "../../ALL/OBJTJ/OBJ_'+AWB_OBJ(INJ)+'.json"]}'
    Next INJ
    Wrseq VALL1  Using [JSO_]
    Wrseq ']},' Using [JSO_]
Endif

Wrseq '"$article": {' Using [JSO_]
Wrseq '"$layout": ' Using [JSO_]

# On traite différemment l'entête
If AWI_FLGMSK(1)=2
    Wrseq '{"$layoutType": "stack",' Using [JSO_]
    Wrseq '"$items":[' Using [JSO_]
    Wrseq '{"'+AWI_LETIDX(1)+'_<!ENTITY!>": ["'+AWI_LETIDX(1)+'", "$layout", "../../ALL/SCRNJ/'+AWI_NOMMSK(1)+'.json"]},' Using [JSO_]
    Wrseq '{"$layoutType": "tabs",' Using [JSO_]
Else
    Wrseq '{"$layoutType": "stack",' Using [JSO_]
Endif

Wrseq '"$items":[' Using [JSO_]
VALL1=""
Local Integer NBONGLET,IND_ONG(1..AWI_NBRMSK)
For INJ=2 To AWI_NBRMSK
  If AWI_FLGMSK(INJ)=2
    NBONGLET+=1
    IND_ONG(INJ)=NBONGLET
  Endif
Next INJ


For INJ=2 To AWI_NBRMSK
  If AWI_FLGMSK(INJ)=2
    If VALL1<>"" : Wrseq VALL1+","  Using [JSO_] : Endif
    WE_NTEX=AWI_INTMSK(INJ) : WE_CAPDEF="" : WE_INTEV="" : WE_FORCE=0 : WE_LCH=0
    If WE_NTEX=0 and NBONGLET>1  : WE_NTEX=-10001600-IND_ONG(INJ): Endif
    WE_NTEXKEY="S_"+AWI_NOMMSK(INJ)
    Gosub JSON_ADDNLOC
    VALL1='{"$title":"'+WE_VALUE+'",'
    VALL1+='"'+AWI_LETIDX(INJ)+'_<!ENTITY!>": ["'+AWI_LETIDX(INJ)+'", "$layout", "../../ALL/SCRNJ/'+AWI_NOMMSK(INJ)+'.json"]}'
#  Rajouter virgule si pas dernier
  Endif
Next INJ

Wrseq VALL1+"]}"  Using [JSO_]
If AWI_FLGMSK(1)=2 : Wrseq "]}"  Using [JSO_] : Endif
Wrseq "},"  Using [JSO_]

Return






$JSON_INITLOC
