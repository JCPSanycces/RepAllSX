      #    WE_NTEX=-find(num$(WE_INTEV),WE_TEXTEVL(1..WE_ADITEV))
       # Endif
         WE_VALUE="{@"+WE_NTEXKEY+"}"
   Endif
 Endif
Return

$JSON_ADDNLOCTOOLTIP
  ILOCALTOOLTYP+=1
  LOCALIZTOOLTIP(ILOCALTOOLTYP)=WE_INTEV
  LOCALIZTOOLTIPKEY(ILOCALTOOLTYP)=WE_NTEXKEY+"_tip"
  WE_VALUE="{@"+LOCALIZTOOLTIPKEY(ILOCALTOOLTYP)+"}"
Return


$JSON_LOCALIZW
Wrseq '"$localization": {' Using [JSO_]

# screens

For INJ=1 To AWI_NBRMSK
  If AWI_FLGMSK(INJ)=2
    Wrseq '"'+AWI_LETIDX(INJ)+'_<!ENTITY!>": ["$lang$", "$localization", "../../ALL/SCRNJ/'+AWI_NOMMSK(INJ)+'.json"],'  Using [JSO_]

  Endif
Next INJ

# left lists

For INJ=1 To AWB_NBR
  If INJ=1 or !find(AWB_OBJ(INJ),AWB_OBJ(1..INJ-1))
    Wrseq '"'+mid$(WE_ALPHAB,INJ,1)+'_<!ENTITY!>": ["$lang$", "$localization", "../../ALL/OBJTJ/OBJ_'+AWB_OBJ(INJ)+'.json"],'  Using [JSO_]
  Endif
Next INJ


# Window itself
Wrseq '"W1_<!ENTITY!>": ["$lang$", "$localization", "$self$"]'   Using [JSO_]
Wrseq "},"  Using [JSO_]
#Wrseq '"A_<!REMOVE!>": { '   Using [JSO_]



Wrseq '"$hackLocalization": {' Using [JSO_]

# screens

For INJ=1 To AWI_NBRMSK
  If AWI_FLGMSK(INJ)=2
    Wrseq '"'+AWI_LETIDX(INJ)+'_<!ENTITY!>": ["'+mid$(WE_ALPHAB,INJ,1)+'", "$hackLocalization", "../../ALL/SCRNJ/'+AWI_NOMMSK(INJ)+'.json"],'  Using [JSO_]

  Endif
Next INJ

# left lists

For INJ=1 To AWB_NBR
  If INJ=1 or !find(AWB_OBJ(INJ),AWB_OBJ(1..INJ-1))
    Wrseq '"'+mid$(WE_ALPHAB,INJ,1)+'_<!ENTITY!>": ["'+mid$(WE_ALPHAB,INJ,1)+'", "$hackLocalization", "../../ALL/OBJTJ/OBJ_'+AWB_OBJ(INJ)+'.json"],'  Using [JSO_]
  Endif
Next INJ


# Window itself
#Wrseq '"W1_<!ENTITY!>": ["all", "$hackLocalization", "$self$"]'   Using [JSO_]
Gosub JSON_HLOCALIZCONTENT

Wrseq "},"  Using [JSO_]

Wrseq '"$hackBlockRank": {' Using [JSO_]
VALL1=""
For INJ=1 To AWI_NBRMSK
  If AWI_FLGMSK(INJ)=2
    If(VALL1="")
      VALL1=","
    Else
      Wrseq VALL1 Using [JSO_]
    Endif
    Wrseq '"'+AWI_LETIDX(INJ)+'_<!ENTITY!>": ["'+mid$(WE_ALPHAB,INJ,1)+'", "$hackBlockRank", "../../ALL/SCRNJ/'+AWI_NOMMSK(INJ)+'.json"]'  Using [JSO_]
  Endif
Next INJ
Gosub JSON_HBLOCRANKCONTENT
Wrseq "},"  Using [JSO_]

Wrseq '"A_<!REMOVE!>": { '   Using [JSO_]


$JSON_LOCALIZ
  Wrseq '"$localization": {' Using [JSO_]

  For WE_T2=1 To GI_NBLAN
    Wrseq '"'+GI_LLAN(WE_T2)+'": {' Using [JSO_]
    VALL1=""
    For INJ=1 To ILOCAL
      If VALL1<>"" : Wrseq VALL1+"," Using [JSO_] : Endif
      WE_NTEX=val(LOCALIZ(INJ)) : Gosub ADDLOCTXT
     #VALL1='"@'+HLOCAL+LOCALIZKEY(INJ)+'": "'+WE_VALUE+'"'
      VALL1='"@'+LOCALIZKEY(INJ)+'": "'+WE_VALUE+'"'
    Next INJ
    For INJ=1 To ILOCALTOOLTYP
      If VALL1<>"" : Wrseq VALL1+"," Using [JSO_] : Endif
      WE_VALUE=func TOOLTIPVALUE(GI_LLAN(WE_T2),LOCALIZTOOLTIP(INJ))
      VALL1='"@'+LOCALIZTOOLTIPKEY(INJ)+'": "'+WE_VALUE+'"'
    Next INJ
    Wrseq VALL1 Using [JSO_]
    If WE_T2=GI_NBLAN
      Wrseq '}' Using [JSO_]
    Else
      Wrseq '},' Using [JSO_]
    Endif
  Next WE_T2
  Wrseq '}' Using [JSO_]

Return

$JSON_HLOCALIZCONTENT
    If(VALL1="dummy")
      VALL1=" "
    Else
      VALL1=""
    Endif
    For INJ=1 To ILOCAL
      If VALL1<>"" : Wrseq VALL1+"," Using [JSO_] : Endif
     VALL1='"@'+LOCALIZKEY(INJ)+'": "@'+HLOCAL+LOCALIZ(INJ)+'"'
     #VALL1='"@'+HLOCAL+LOCALIZ(INJ)+'": "@'+LOCALIZKEY(INJ)+'"'
    Next INJ
    Wrseq VALL1 Using [JSO_]
Return

$JSON_HBLOCRANKCONTENT
    If(VALL1="dummy")
      VALL1=" "
    Else
      VALL1=""
    Endif
    For INJ=1 To IRANK
      If VALL1<>"" : Wrseq VALL1+"," Using [JSO_] : Endif
      VALL1=BLOCRANK(INJ)
    Next INJ
    Wrseq VALL1 Using [JSO_]
Return


$ADDLOCTXT
  If WE_NTEX<0
      Gosub WE_TMENL
  Elsif WE_NTEX=0
      WE_VALUE=""
  Else
      Gosub WE_LANGC
  Endif
Return



#  Donne le caption associé à WE_NTEX dans la langue GI_LLAN(WE_T2)
$WE_LANGC
#  Texte normal  (ATT)
Read [ATX]NUMERO = GI_LLAN(WE_T2);WE_NTEX
If fstat=0
    WE_VALUE = escJson([F:ATX]TEXTE)
Else
   If GI_LLAN(WE_T2)<>GLANGUE
        Read [ATX]NUMERO = GLANGUE;WE_NTEX
   Else
        Read [ATX]NUMERO = GLANDEF;WE_NTEX
   Endif
   If fstat=0
        WE_VALUE = escJson([F:ATX]TEXTE)
   Else
        WE_VALUE = ""
   Endif
Endif
#VALLM=WE_VALUE
#Gosub MVALC From INTRUTILA
#WE_VALUE=VALLM
# jira X3-77109 replace by using escjson
#WE_VALUE=ctrans(WE_VALUE,'"',"'")
#WE_VALUE=ctrans(WE_VALUE,"\",'/')
Return

#  Texte dans un Menu local
$WE_TMENL
If WE_NTEX<=-1 and WE_NTEX>=-20
  If GI_LLAN(WE_T2)<>GLANGUE     : # Il faut changer la langue par défaut
    WE_SAVLANG=GLANGUE
    WE_LANGUE=GI_LLAN(WE_T2)
    Gosub WE_SETLANG
    Gosub WE_EVALCAP1
    WE_LANGUE=WE_SAVLANG
    Gosub WE_SETLANG
  Else
    Gosub WE_EVALCAP1
  Endif
  Return
Endif
If left$(num$(WE_NTEX),7)="-100016"
  WE_NOMEN=100
  WE_NOMES=16
  INJW=val(right$(num$(WE_NTEX),len(num$(WE_NTEX))-1))
Else
  WE_NOMEN=-WE_NTEX/1000
  WE_NOMES=-WE_NTEX-WE_NOMEN*1000
Endif
#If WE_NTEX=-100016 and dim(WE_INDIG)>0 : WE_VALUE-=num$(WE_INDIG-1) : Endif   : # Pour avoir Page n

Read [AST]CLE=WE_NOMEN;WE_NOMES;GI_LLAN(WE_T2)
If fstat=0 Then
   WE_VALUE=escJson([F:AST]LANMES)
Else
  If GI_LLAN(WE_T2)<>GLANGUE
    Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANGUE
  Else
    Read [AST]CLE=WE_NOMEN;WE_NOMES;GLANDEF
  Endif
  If fstat=0 : WE_VALUE=escJson([F:AST]LANMES) : Else : WE_VALUE="" : Endif
Endif
If WE_NOMEN=100 and WE_NOMES=16 : WE_VALUE-=num$(INJW) : Endif
#VALLM=WE_VALUE
#Gosub MVALC From INTRUTILA
#WE_VALUE=VALLM
# jira X3-77109 replace by using escjson
#WE_VALUE=ctrans(WE_VALUE,'"',"'")
#WE_VALUE=ctrans(WE_VALUE,"\",'/')
Return




$JSON_VISU
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+APPLI+AASEP+"GEN"+AASEP+"ALL"+AASEP+"WINDJ"
  URL+=AASEP+FENETRE+".json"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return



$PROTO_VISU
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+APPLI+AASEP+"GEN"+AASEP+"SYR"+AASEP+"FR-FR"+AASEP+"FENJ"
  URL+=AASEP+FENETRE+".json"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return


$ASSJSON
Local Integer STA1,IN1
Local Char WE_NOMFP(250),WE_NOMFIC(250)
If dim(GI_NBLAN)<0 : Call GLOBWEB(APPLI) From INTRUTILA : Endif

Call NAMEFIC(APPLI,"WINDJ","",FENETRE,WE_NOMFIC) From INTRUTILA
For IN1=1 To GI_NBLAN
  Call NAMEFIC(APPLI,"FENJ",GI_LLAN(IN1),FENETRE,WE_NOMFP) From INTRUTILA
  #Call ECR_TRACE(WE_NOMFIC + " " + WE_NOMFP,0) From GESECRAN
  STA1=jsonProto(WE_NOMFIC,WE_NOMFP,GI_LLAN(IN1))
Next IN1
Return


$WE_EVALCAP1
  Onerrgo WE_ERREV
  #Call ECR_TRACE(num$(-WE_NTEX) + " " +  WE_TEXTEVL(-WE_NTEX) + " " + right$(WE_TEXTEVL(-WE_NTEX),2) + " " + evalue(right$(WE_TEXTEVL(-WE_NTEX),2)) ,0) From GESECRAN
  WE_VALUE=evalue(right$(WE_TEXTEVL(-WE_NTEX),2))
  WE_VALUE=ctrans(WE_VALUE,'"',"'")
  WE_VALUE=ctrans(WE_VALUE,"\",'/')
  Onerrgo ERREUR From VALMSK
Return

$WE_SETLANG
adxrob(0)   = "ECR"
adxrob(1)   = "M"+WE_LANGUE
messname(0) = WE_LANGUE
adxtms      = APPLI+".APLSTD"
adxmbm      = adxmbm
GLANGUE     = WE_LANGUE
Return

Funprog TOOLTIPVALUE(LANG,KEYWORD)
  Value Char LANG
  Value Char KEYWORD
  Local Char RESVAL(150)
  Local Char    WE_AIDVAL(150)
  Read [ADZ]ADZ0 = LANG;KEYWORD
  If fstat=0
   Setlob WE_AIDVAL With [F:ADZ]TEXTE
   RESVAL=WE_AIDVAL
  Else
  Read [ADZ1]ADZ0 = LANG;KEYWORD
   If fstat=0
    Setlob WE_AIDVAL With [F:ADZ1]TEXTE
    RESVAL=WE_AIDVAL
   Else
     If LANG<>GLANGUE
       Read [ADZ]ADZ0 = GLANGUE;KEYWORD
     Else
       Read [ADZ]ADZ0 = GLANDEF;KEYWORD
     Endif
     If fstat=0
       Setlob WE_AIDVAL With [F:ADZ]TEXTE
       RESVAL=WE_AIDVAL
     Else
       If LANG<>GLANGUE
         Read [ADZ1]ADZ0 = GLANGUE;KEYWORD
       Else
         Read [ADZ1]ADZ0 = GLANDEF;KEYWORD
       Endif
       If fstat=0
        Setlob WE_AIDVAL With [F:ADZ1]TEXTE
        RESVAL=WE_AIDVAL
       Endif
     Endif
   Endif
  Endif
  RESVAL=func CLEANTXT(RESVAL)
End RESVAL

Funprog CLEANTXT(TXT)
  Value Char TXT
  Local Char RESVAL(150)
  RESVAL=ctrans(TXT,'"',"'")
  RESVAL=ctrans(RESVAL,"\",'/')
  RESVAL=ctrans(RESVAL,chr$(10)," ")
  RESVAL=ctrans(RESVAL,chr$(13)," ")
  RESVAL=ctrans(RESVAL,chr$(9)," ")
End RESVAL

$WE_ERREV
 WE_VALUE=""
Resume

