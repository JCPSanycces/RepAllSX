#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION
Return
######################################################################################
######################################################################################
Subprog VAL_SRH(RETNUM)
Value Char RETNUM
Local Integer WRET

Call VALIDATE ([L]RETNUM,[L]WRET)  From TRTVENRET1

End
######################################################################################
######################################################################################
Subprog VALIDATE(SRHNUM,RETVAL)
Value Char     SRHNUM
Value Integer  RETVAL
[L]RETVAL = 0

Local File SRETURN  [SRH]
Local File SRETURND [SRD]

Local Char    SYMBOLSRH
Local Integer LRET, PRIVTRACE
Local Char    WABREV(3)
Local Char    CBLOB(3)
Local Char    WCPT(GLONANM)

#----- Open trace -----#
# Issue 104424 - 2017-02-21 by VAVIL : Sales return mass validation
If GTRACE = ""
  Call OUVRE_TRACE(mess(79,197,1)) From LECFIC
  [L]PRIVTRACE = 1
Else
  Call ECR_TRACE(mess(79,197,1),0) From GESECRAN
Endif

#----- Logic symbol -----#
SYMBOLSRH="SRH"+[L]SRHNUM
Lock=SYMBOLSRH
If fstat
  Call ECR_TRACE("$SRETURN"-[L]SRHNUM-mess(10,100,1),1) From GESECRAN
  SYMBOLSRH="" : Goto FINVAL
Endif

Call DEBTRANS From GLOCK

$TR_VALID

Trbegin [F:SRH]
Readlock [F:SRH]SRH0=[L]SRHNUM
If fstat=1
  GOK=-1 : GLOCK="$SRETURN"                      : Goto ROL_VAL
Elsif fstat
  GOK=0  : Call RSTA("SRH",[L]SRHNUM) From GLOCK : Goto AB_VAL
Endif

#85785
Local Integer PORDIGSIGN : [L]PORDIGSIGN = func PORLEGLIB.DIGSIGN("", [F:SRH]CPY)
If [L]PORDIGSIGN = 1
  Local Char LNUM(GLONVCR)

  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  Call LEC_CPY([F:SRH]CPY) From CPTLEC

  # Document type
  If [F:SRH]SRHTYP<>""
    If !clalev ([F:TRE]) : Local File TABSRHTYP [TRE] : Endif
    Call LEC_TRE_LEG([F:CPY]LEG,[F:SRH]SRHTYP,LRET) From TRTLECLEG
    If LRET<>0 Raz [F:TRE] : Endif

    If [F:SRH]BETFCY <> G_YES and [F:SRH]BETCPY <> G_YES Then
      # Normal return
      WCPT = [F:TRE]CODNUMEND
    Else
      If [F:SRH]BETFCY = G_YES and [F:SRH]BETCPY <> G_YES Then
        # Intersite return
        WCPT = [F:TRE]CODNUMFCYD
      Elsif [F:SRH]BETFCY = G_YES and [F:SRH]BETCPY = G_YES Then
        # Inter company return
        WCPT = [F:TRE]CODNUMCPYD
      Endif
    Endif
  Endif

  #  If WCPT = ""
  #    GMESSAGE = mess(1818,200,1) +":"-tolower(mess(184,100,1)) : GOK = 0 : Goto AB_VAL
  #  Endif

  #If [L]PORDIGSIGN = 1
    If func PORLEGLIB.ANM_OK(WCPT, GMESSAGE) <> 1
      GERR=1 : GOK=0 : Goto AB_VAL
    Endif
  #Endif

  Call NUMERO(WCPT,[F:SRH]STOFCY,[F:SRH]RTNDAT,"",LNUM,LRET) From SUBANM

  If GOK<0 Goto ROL_VAL Endif

  If LRET <> 0 | GOK<1
    Local Char MESSA(80)
    Local Integer SAUV_STAT
    If dim(STAT)<0 : Local Integer STAT : Endif
    SAUV_STAT=STAT : STAT=LRET
    #GMESSAGE=mess(60,199,1)-"("+[F:TCA]CODNUM(13)+") : "
    GMESSAGE=mess(60,199,1)-"("+WCPT+") : "
    Gosub MESSAGE From SUBANM
    STAT=SAUV_STAT
    GMESSAGE-=MESSA : GERR=1 : GOK=0 : Goto AB_VAL
  Endif

  # BRBAN 08/07/2014 SAM #93745 US2
  If [L]PORDIGSIGN=1
    If find([F:TRE]RECTYP,2,3,4)
      If [F:SRH]MANDOCR=''
        GERR=1
        If find([F:TRE]RECTYP,2,3)
          GMESSAGE=mess(128,7711,1) #Should fill the manual/backup document number.
        Else #4
          GMESSAGE=mess(196,7711,1) #Should fill the manual document field with the external document number.
        Endif
        GOK = 0
      Endif
    Endif
    If GOK < 1 Goto AB_VAL Endif
  Endif

  #If [L]PORDIGSIGN = 1
    Gosub CTRL_CHRONOLOGIC
    If GOK=0 : Goto AB_VAL : Endif
  #Endif

  # Table updates with the new sequence counter
  If !clalev([F:ABB]) : Local File ABLOB      [ABB] : Endif
  If !clalev([F:ACB]) : Local File ACLOB      [ACB] : Endif
  If !clalev([F:AOX]) : Local File AOBJTXT    [AOX] : Endif
  If !clalev([F:AOM]) : Local File AOBJTXTA   [AOM] : Endif
  If !clalev([F:CAL]) : Local File CPTANALIN  [CAL] : Endif
  If !clalev([F:LCM]) : Local File LASTCUSMVT [LCM] : Endif
  If !clalev([F:MAI]) : Local File MACITN     [MAI] : Endif
  If GMODU(6) = 2
    If !clalev([F:PND]) : Local File PRETURND    [PND] : Endif
  Endif
  If !clalev([F:STA]) : Local File STOALL     [STA] : Endif
  If !clalev([F:STO]) : Local File STOCK      [STO] : Endif
  If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
  If !clalev([F:STL]) : Local File STOLOT     [STL] : Endif
  If !clalev([F:STS]) : Local File STOSER     [STS] : Endif
  If !clalev([F:STR]) : Local File STOTRK     [STR] : Endif

  [L]WABREV="SRH"

  Update [AOX] Where ABREV=[L]WABREV & IDENT1=[F:SRH]SRHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("AOX") From GLOCK
    Goto AB_VAL
  Endif
  Update [AOM] Where ABREV=[L]WABREV & IDENT1=[F:SRH]SRHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("AOM") From GLOCK
    Goto AB_VAL
  Endif
  [L]CBLOB = "PJ_" : # Pour les pieces jointes
  Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[F:SRH]SRHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ACB") From GLOCK
    Goto AB_VAL
  Endif
  Update [ABB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[F:SRH]SRHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ABB") From GLOCK
    Goto AB_VAL
  Endif
  [L]CBLOB = "CO_" : # Pour les commentaires
  Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[F:SRH]SRHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ACB") From GLOCK
    Goto AB_VAL
  Endif

  Update [STA] Where VCRTYP=13 & VCRNUM=[F:SRH]SRHNUM With VCRNUM=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STA") From GLOCK
    Goto AB_VAL
  Endif
  Update [STJ] Where VCRTYP=13 & VCRNUM=[F:SRH]SRHNUM With VCRNUM=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STJ") From GLOCK
    Goto AB_VAL
  Endif
  Update [STJ] Where VCRTYPORI=13 & VCRNUMORI=[F:SRH]SRHNUM With VCRNUMORI=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STJ") From GLOCK
    Goto AB_VAL
  Endif
  Update [STR] Where VCRTYP=13 & VCRNUM=[F:SRH]SRHNUM With VCRNUM=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STR") From GLOCK
    Goto AB_VAL
  Endif
  Update [STR] Where VCRTYPORI=13 & VCRNUMORI=[F:SRH]SRHNUM With VCRNUMORI=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("STR") From GLOCK
    Goto AB_VAL
  Endif

  Update [CAL] Where ABRFIC="SRD" & VCRTYP=0 & VCRNUM=[F:SRH]SRHNUM With VCRNUM=LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("CAL") From GLOCK
    Goto AB_VAL
  Endif

  Update [LCM] Where VCRNUM=[F:SRH]SRHNUM & MVTTYP = 4 With VCRNUM=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("LCM") From GLOCK
    Goto AB_VAL
  Endif

  Update [MAI] Where ORIVCR=[F:SRH]SRHNUM & find(ORI,7, 8) With ORIVCR=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("MAI") From GLOCK
    Goto AB_VAL
  Endif

  If GMODU(6) = 2
    Update [PND] Where SRHNUM=[F:SRH]SRHNUM With SRHNUM=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("PND") From GLOCK
      Goto AB_VAL
    Endif
  Endif

  # # 78411 : Sage Exchange - Update SDH Num in table SEAUTH
  # Local Integer WRET
  # If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SDH]PTE)
  #   Call TRANSFER(4,[F:SRH]SRHNUM,4,LNUM,WRET) From SEPPLIB
  #   If WRET : Raz GOK : Goto AB_VAL : Endif
  # Endif

  Update [SRD] Where SRHNUM=[F:SRH]SRHNUM With SRHNUM=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("SRD") From GLOCK
    Goto AB_VAL
  Endif

  [F:SRH]TMPSRHNUM = [F:SRH]SRHNUM
  [F:SRH]SRHNUM = LNUM
  Rewrite [SRH]
  If fstat
    GOK=0 : Call FSTA("SRH") From GLOCK
    Goto AB_VAL
  Endif
  Readlock [SRH]SRH0 = LNUM
  If fstat=1
    GOK=-1 : GLOCK="$SRETURN"+SRHNUM : Goto ROL_VAL
  Elsif fstat
     GOK=0  : Call RSTA("SRH",SRHNUM) From GLOCK : Goto AB_VAL
  Endif

  Case GFONCTION
    When "GESSRH"
      If clalev([M:SRH0]) : If dim([M:SRH0]SRHNUM)>0 : [M:SRH0]SRHNUM = LNUM : Endif : Endif
    When "GESSRL"
      If clalev([M:SRL0]) : If dim([M:SRL0]SRHNUM)>0 : [M:SRL0]SRHNUM = LNUM : Endif : Endif
    When "GESSRS"
      If clalev([M:SRS0]) : If dim([M:SRS0]SRHNUM)>0 : [M:SRS0]SRHNUM = LNUM : Endif : Endif
  Endcase

  #If [L]PORDIGSIGN = 1
    Gosub DIGSIGN

    # BRBAN 16/07/2014 SAM 93745 US2
    If [L]LRET=0
      Gosub SEND_AT
    Endif
    If [L]LRET > 1
      If GMESSAGE <> "" : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
      Raz GMESSAGE : Goto AB_VAL
    Endif
  #Endif

  [F:SRH]SRHCFMFLG = 2
  Rewrite [F:SRH]
  If fstat : GOK=0 : Call FSTA("SRH") From GLOCK : Goto AB_VAL : Endif

Endif

Commit
[L]RETVAL = 1

Goto FINVAL
#----- Rollback with retry -----#
$ROL_VAL
Rollback
Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
  Goto FINVAL
Else
  Goto TR_VALID
Endif
#----- Definitive rollback -----#
$AB_VAL
Rollback
If GMESSAGE <> ""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Endif
Call ECR_TRACE(mess(18,114,1),1) From GESECRAN
Call ECR_TRACE([F:SRH]SRHNUM-mess(123,197,1),0) From GESECRAN

$FINVAL
If SYMBOLSRH<>""  Unlock=SYMBOLSRH : Raz SYMBOLSRH : Endif
# Issue 104424 - 2017-02-21 by VAVIL : Sales return mass validation
# Call ECR_TRACE(mess(79,197,1)-mess(124,100,1),0) From GESECRAN
If [L]PRIVTRACE = 1
  Call ECR_TRACE([F:SRH]SRHNUM- mess(79,197,1)-mess(124,100,1),0) From GESECRAN
  Call FERME_TRACE  From LECFIC
  Call LEC_TRACE  From LECFIC
Else
  Call ECR_TRACE([F:SRH]SRHNUM - mess(79,197,1)-mess(124,100,1),0) From GESECRAN
Endif

End
######################################################################################
######################################################################################
$DIGSIGN

#signature variables
Local Char    CURTIM          : [L]CURTIM = time$
Local Date    CURDAT          : [L]CURDAT = date$
Local Char    MESSTOSIGN(250)
Local Decimal VALTMP          : VALTMP = 0
Local Decimal CURRAT
Local Integer TYP             : [L]TYP = 0

Filter [F:SRD] Where [F:SRD]SRHNUM = [L]LNUM
For [F:SRD]
  Call COURDEV ([F:SRD]CUR, "EUR", 1, [F:SRH]RTNDAT, [L]CURRAT, [L]LRET) From TRTDIV
  VALTMP += ([F:SRD]NETPRIATI*[L]CURRAT*[F:SRD]QTY)
Next
Filter [F:SRD]

Case [F:TRE]SRHCAT
  When 1 : [L]TYP=3
  When 2 : [L]TYP=4
  When 3 : [L]TYP=5
Endcase

[L]MESSTOSIGN = format$("D:YYYY[-]MM[-]DD",[F:SRH]RTNDAT) + ";" + format$("D:YYYY[-]MM[-]DD",[L]CURDAT) + "T" + [L]CURTIM + ";" + [F:SRH]SRHTYP-[F:SRH]SRHNUM + ";" +
& ctrans(vireblc(format$("N20.2",[L]VALTMP),4),",",".") + ";"
#NUM, VCRTYP, TYP, MESTOSIGN, ANM, DATDOC, LASDAT, TIM, ISEXTDOC, RETVAL
Call SIGNDOC_NEW ([F:SRH]SRHNUM, [L]TYP, [F:SRH]SRHTYP,[L]MESSTOSIGN,[L]WCPT,[F:SRH]RTNDAT,
&             [L]CURDAT,[L]CURTIM,[F:TRE]RECTYP,[F:TRE]SAFTTRNTYP,LRET)                           From DKSLIB

Return
######################################################################################
######################################################################################
$CTRL_CHRONOLOGIC

Local Integer SEQ
Local Char    DOCNUM(GLONVCR) : DOCNUM=[L]LNUM
If clalev([F:SRHB])=0 Local File SRETURN [SRHB] Endif

Repeat
 Call NUMERO_PREC(WCPT,[F:SRH]STOFCY,[F:SRH]RTNDAT,"",[L]DOCNUM,SEQ,LRET) From SUBANM
 If LRET<>0
    GMESSAGE = WCPT-DOCNUM-mess(60,199,1) : GOK=0 : Break
 Endif
 If SEQ>=1
    Read [F:SRHB]SRH0=DOCNUM
    If !fstat
       If [F:SRHB]RTNDAT>[F:SRH]RTNDAT
          GOK=0 :GMESSAGE = mess(101,121,1)
       Endif
       SEQ=0
    Endif
 Endif
Until SEQ<=1
Close Local File [F:SRHB]
Return
######################################################################################
######################################################################################
$SEND_AT
If [F:SRH]ATDTCODR <> ""
   If !clalev ([F:DKD]) : Local File DKSDATA [DKD] : Endif
   Read [F:DKD]DKD0 = "SAFT-PT";[F:SRH]SRHTYP;[F:SRH]SRHNUM
   If !fstat
      If [F:DKD]ATDTCOD <> ""
         Call ECR_TRACE(mess(125,7711,1),1) From GESECRAN #This document already has a transport code.
      Else
         [F:DKD]ATDTCOD    = [F:SRH]ATDTCODR
         [F:DKD]ATDTCOMSTA = "0"
         [F:DKD]ATDTINPTYP = 1
         [F:DKD]RECTYP     = [F:TRE]RECTYP
         Rewrite [F:DKD]
         If fstat
            Call ECR_TRACE(mess(126,7711,1),1) From GESECRAN #Error while saving manual code.
         Endif
      Endif
   Else
      Call ECR_TRACE(mess(127,7711,1),1) From GESECRAN #The document is not signed.
   Endif
Else
  Local Char    AUTSND(1)
  Local Integer RETSTAT
  Local Integer ITYP

  Case [F:TRE]SRHCAT
    When 1 : [L]ITYP=3
    When 2 : [L]ITYP=4
    When 3 : [L]ITYP=5
  Endcase

  Call PARAML([F:SRH]STOFCY, "AUTCOMAT", [L]AUTSND) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  If [L]AUTSND = '2'
    # BRBAN 24-03-2015 #106027
    If [F:SRH]BPDCRY='PT' & func PORLEGLIB.DOCCTR([L]ITYP,[F:SRH]BPCORD ,[F:SRH]SRHTYP,[F:SRH]STOFCY)=1 & func PORLEGLIB1.CTRL_COMDAT([F:SRH]STOFCY,[F:SRH]DPEDATR,[F:SRH]ETDR)=1
      Call SENDDTTOAT([F:SRH]SRHNUM,[L]ITYP,[L]RETSTAT) From PORLEGLIB1
    Endif
   Endif
Endif

Return

