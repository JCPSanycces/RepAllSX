#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_ATEXTE UTI process                                  PAY Module
#                  Migration To U12 - Vnext version
#
# ==>  Update ATEXTE references for objects in LM 42
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update ATEXTE references for objects in LM 42") From LECFIC

  Call MAJ_EMHRMAJ90_ATEXTE(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

Close Local File
End

Subprog MAJ_EMHRMAJ90_ATEXTE(LDOSSIER)
Value Char LDOSSIER
Local Char DOSLEGMIG(5)

#  Onerrgo CYCLECHECKERROR

  Call ECR_TRACE("EMHRMAJ90_ATEXTE: Update ATEXTE references for objects in LM 42",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_ATEXTE: Start of process on : "+LDOSSIER,0) From GESECRAN

  #gets the folder legislation
  DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)

  Gosub PROCESS_ATEXTE_U9_RECORDS

  Call ECR_TRACE("EMHRMAJ90_ATEXTE : End of process.",0) From GESECRAN
End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_ATEXTE: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
  UPD_OK = 1
Resume

$PROCESS_ATEXTE_U9_RECORDS

  If clalev([F:HRWATX]) = 0 : Local File =LDOSSIER+".WATEXTE" [HRWATX] : Endif #U9 Values
  If clalev([F:HRATX]) = 0  : Local File =LDOSSIER+".ATEXTE" [HRATX]   : Endif #V12 Values

  Local Integer NEW_MASTER_NUMERO

  Filter [F:HRWATX]
  For [F:HRWATX]
    Call ECR_TRACE("Running for [F:HRWATX]NUMERO: " - num$([F:HRWATX]NUMERO) - ", [F:HRWATX]LAN:" - [F:HRWATX]LAN - ", [F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE,0) From GESECRAN
    Read [F:HRATX]NUMERO = [F:HRWATX]LAN;[F:HRWATX]NUMERO
    If fstat #NUMERO does not exist, check if text exists
      Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", NUMERO does not exist",0) From GESECRAN
      Read [F:HRATX]TEXTE = [F:HRWATX]LAN;[F:HRWATX]TEXTE
      If fstat #TEXTE does not exist, create new record
        Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", creating new ATEXTE record",0) From GESECRAN
        Call GENERATE_NEW_NUMERO(NEW_MASTER_NUMERO,1,LDOSSIER)
        Gosub CREATE_ATEXTE_RECORD
      Endif
    Else #NUMERO exists, check if texte is the same
      Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", NUMERO exists",0) From GESECRAN
      If [F:HRWATX]TEXTE<>[F:HRATX]TEXTE #Texte is not the same, search for texte
        Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", text not the same",0) From GESECRAN
        Read [F:HRATX]TEXTE = [F:HRWATX]LAN;[F:HRWATX]TEXTE
        If fstat #TEXTE not found, create it
          Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", creating new ATEXTE record",0) From GESECRAN
          Call GENERATE_NEW_NUMERO(NEW_MASTER_NUMERO,1,LDOSSIER)
          Gosub CREATE_ATEXTE_RECORD
        Endif
      Endif
    Endif
  Next

  Close File [F:HRWATX], [F:HRATX]

  Call UPDATE_NUMERO_REFERENCE(LDOSSIER)

Return

Subprog UPDATE_NUMERO_REFERENCE(LDOSSIER)
Value Char LDOSSIER

  Local Integer UPDATED_RECORDS, OK, ATXCNT
  Local Char    ATXTABLES(250)(1..)
  Local Char    LANG(10) : [L]LANG = GLANGUE
  Call ECR_TRACE("Language GLANGUE:" - [L]LANG,0) From GESECRAN

  If clalev([F:HRATZ]) = 0 : Local File =LDOSSIER+".ATABZON" [HRATZ]  : Endif
  If clalev([F:HRATZ2])= 0 : Local File =LDOSSIER+".ATABZON" [HRATZ2] : Endif
  If clalev([F:HRWATX]) =0 : Local File =LDOSSIER+".WATEXTE" [HRWATX] : Endif #U9 Values
  If clalev([F:HRATX]) = 0 : Local File =LDOSSIER+".ATEXTE"  [HRATX]  : Endif #V12 Values

  ATXCNT = 1
  For [F:HRATZ] Where [F:HRATZ]CODTYP="ATX"
    If find([F:HRATZ]CODFIC, ATXTABLES) = 0
      ATXTABLES(ATXCNT) = [F:HRATZ]CODFIC
      ATXCNT += 1
    Endif
  Next

  Local Char ACTFIELD(250)
  Local Char ATXFIELDS(250)(1..)
  Local Char TABLE(250)
  Local Char CURRENTACTIVITY(250)

  For ATXCNT = 1 To maxtab(ATXTABLES)

    If ATXTABLES(ATXCNT) <> ""
      Call ECR_TRACE("Looping table: "+ATXTABLES(ATXCNT)+", ATXCNT:"+num$(ATXCNT),0) From GESECRAN
      For [F:HRATZ2] Where [F:HRATZ2]CODFIC=ATXTABLES(ATXCNT) & [F:HRATZ2]CODTYP="ACV"
        Read [F:HRATZ]CODTYP(2) = "ATX";ATXTABLES(ATXCNT)
        Raz [L]ACTFIELD, [L]ATXFIELDS, [L]TABLE
        ACTFIELD    = [F:HRATZ2]CODZONE
        ATXFIELDS(1)= [F:HRATZ]CODZONE
        TABLE       = ATXTABLES(ATXCNT)

        If find([F:HRATZ2]CODFIC, "ABIDATMRT", "ACLASSE", "ACTIV", "ASHW") > 0
          If [F:HRATZ2]CODFIC = "ABIDATMRT"
            If [F:HRATZ2]CODZONE = "CODACT"
              ATXFIELDS(1) = "INTIT"
              ACTFIELD = "CODACT"
            Else : Break : Endif
          Elsif [F:HRATZ2]CODFIC = "ACLASSE"
            If [F:HRATZ2]CODZONE = "CODCLA"
              ATXFIELDS(1) = "INTCLA"
              ACTFIELD = "CODCLA"
            Else : Break : Endif
          Elsif [F:HRATZ2]CODFIC = "ACTIV"
            If [F:HRATZ2]CODZONE = "CODACT"
              ATXFIELDS(1) = "LIBACT"
              ACTFIELD = "CODACT"
            Else : Break : Endif
          Elsif [F:HRATZ2]CODFIC = "ASHW"
            If [F:HRATZ2]CODZONE = "CODACT"
              ATXFIELDS(1) = "INTREP"
              ACTFIELD = "CODACT"
            Else : Break: Endif
          Endif
        Endif

        If [F:HRATZ2]CODFIC = "AFONCTION"
          If [F:HRATZ2]CODZONE="CODACT"
            ATXFIELDS(1) = "AIDE"
            ATXFIELDS(2) = "LIBMENU"
            ATXFIELDS(3) = "NOM"
            ACTFIELD = "CODACT"
          Elsif [F:HRATZ2]CODZONE="CODACT"
            ATXFIELDS(1) = "OPTION"
            ACTFIELD = "ACTOPT"
          Else : Break : Endif
        Endif

        If [F:HRATZ2]CODFIC = "AMSK"
          If [F:HRATZ2]CODZONE = "CODACT"
            ATXFIELDS(1) = "INTMSK"
            ACTFIELD = "CODACT"
          Elsif [F:HRATZ2]CODZONE = "ACTBLOC"
            ATXFIELDS(1) = "TITBLOC"
            ACTFIELD = "ACTBLOC"
          Else : Break : Endif
        Endif

        If [F:HRATZ2]CODFIC = "AOBJET"
          If [F:HRATZ2]CODZONE = "CODACT"
            ATXFIELDS(1) = "LIBEL"
            ATXFIELDS(2) = "LIBSHO"
            ATXFIELDS(3) = "LIBPAR"
            ACTFIELD = "CODACT"
          Else : Break: Endif
        Endif


        If [F:HRATZ2]CODFIC = "AWINDOW"
          If [F:HRATZ2]CODZONE = "CODACT"
            ATXFIELDS(1) = "DES"
            ACTFIELD = "CODACT"
          Elsif [F:HRATZ2]CODZONE = "ACTMSK"
            ATXFIELDS(1) = "INTMSK"
            ACTFIELD = "ACTMSK"
          Else : Break : Endif
        Endif

        Call ECR_TRACE("ACV Field: "+ACTFIELD+", ATXFIELDS(1):"+ATXFIELDS,0) From GESECRAN
        If clalev([F:WWWW]) = 0 : Local File =LDOSSIER+"."+TABLE [WWWW] : Endif

        Call ECR_TRACE("Opened table:" + TABLE + " As [F:WWWW]",0) From GESECRAN
        For [F:WWWW]
          Local Integer NUMDIMENSIONS, DIMCNT : [L]NUMDIMENSIONS = 1
          [L]NUMDIMENSIONS = evalue("dim([F:WWWW]"+ACTFIELD+")")  #Check if activity code column is mutli dimentional
          NUMDIMENSIONS = NUMDIMENSIONS - 1
          For DIMCNT = 0 To [L]NUMDIMENSIONS
            CURRENTACTIVITY = evalue("[F:WWWW]"+ACTFIELD+"("+num$(DIMCNT)+")")
            If CURRENTACTIVITY <> "" & (left$(CURRENTACTIVITY,1)="Y" | left$(CURRENTACTIVITY,1)="X")
              Local Integer ATXFIELDCNT
              For ATXFIELDCNT = 1 To maxtab(ATXFIELDS)
                If ATXFIELDS(ATXFIELDCNT) <> ""
                  Read [F:HRWATX]NUMERO = [L]LANG;evalue("[F:WWWW]"+ATXFIELDS(ATXFIELDCNT)+"("+num$(DIMCNT)+")")
                  Call ECR_TRACE("Running for [F:HRWATX]NUMERO: " - num$([F:HRWATX]NUMERO) - ", [F:HRWATX]LAN:" - [F:HRWATX]LAN - ", [F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE,0) From GESECRAN
                  Read [F:HRATX]NUMERO = [L]LANG;[F:HRWATX]NUMERO
                  If fstat #NUMERO does not exist, check if text exists
                    Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", NUMERO does not exist",0) From GESECRAN
                    Read [F:HRATX]TEXTE = [L]LANG;[F:HRWATX]TEXTE
                    If !fstat #TEXTE does not exist, create new record
                      Call ECR_TRACE("Assigning NUMERO:" - num$([F:HRATX]NUMERO) - " to FIELD [F:WWWW]"+ATXFIELDS(ATXFIELDCNT)+"("+num$(DIMCNT)+")",0) From GESECRAN
                      Assign "[F:WWWW]"+ATXFIELDS(ATXFIELDCNT)+"("+num$(DIMCNT)+")" With [F:HRATX]NUMERO
                      Rewrite [F:WWWW]
                      If !fstat
                        Call ECR_TRACE("Updated field:" - ATXFIELDS(ATXFIELDCNT) - "("+num$(DIMCNT)+") on table:" - TABLE - ", from:" - num$([F:HRWATX]NUMERO) - "to:" - num$([F:HRATX]NUMERO) -
& ", text:"-[F:HRATX]TEXTE,0) From GESECRAN
                      Else
                        Call ECR_TRACE("Failed on field:" - ATXFIELDS(ATXFIELDCNT) - "("+num$(DIMCNT)+") on table:" - TABLE - ", from:" - num$([F:HRWATX]NUMERO) - "to:" - num$([F:HRATX]NUMERO) -
& ", text:"-[F:HRATX]TEXTE,0) From GESECRAN
                      Endif
                    Endif
                  Else #NUMERO exists, check if texte is the same
                    Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", NUMERO exists",0) From GESECRAN
                    If [F:HRWATX]TEXTE<>[F:HRATX]TEXTE #Texte is not the same, search for texte
                      Call ECR_TRACE("[F:HRWATX]TEXTE:"-[F:HRWATX]TEXTE-", text not the same",0) From GESECRAN
                      Read [F:HRATX]TEXTE = [L]LANG;[F:HRWATX]TEXTE
                      If !fstat #TEXTE not found, create it
                        Assign "[F:WWWW]"+ATXFIELDS(ATXFIELDCNT)+"("+num$(DIMCNT)+")" With [F:HRATX]NUMERO
                        Rewrite [F:WWWW]
                        If !fstat
                          Call ECR_TRACE("Updated field:" - ATXFIELDS(ATXFIELDCNT) - "("+num$(DIMCNT)+") on table:" - TABLE - ", from:" - num$([F:HRWATX]NUMERO) - "to:" - num$([F:HRATX]NUMERO) -
& ", text:"-[F:HRATX]TEXTE,0) From GESECRAN
                        Else
                          Call ECR_TRACE("Failed on field:" - ATXFIELDS(ATXFIELDCNT) - "("+num$(DIMCNT)+")on table:" - TABLE - ", from:" - num$([F:HRWATX]NUMERO) - "to:" - num$([F:HRATX]NUMERO) -
& ", text:"-[F:HRATX]TEXTE,0) From GESECRAN
                        Endif
                      Endif
                    Endif
                  Endif
                Endif
              Next
            Endif
          Next
        Next

        Close File [F:WWWW]
      Next
    Endif
  Next
End


