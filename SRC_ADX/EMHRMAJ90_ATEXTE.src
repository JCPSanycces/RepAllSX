$TEST
  Local Integer UPDATED_RECORDS, OK
  Local Char    PROCESSED(250)(1..)
  Local Char    LANG(10) : [L]LANG = GLANGUE
  Call ECR_TRACE("Language GLANGUE:" - [L]LANG,0) From GESECRAN

  If clalev([F:HRATZ]) = 0 : Local File ATABZON [HRATZ]  : Endif
  If clalev([F:HRATZ2])= 0 : Local File ATABZON [HRATZ2] : Endif

  Filter [F:HRATZ] Where [F:HRATZ]CODTYP="ATX"
  Call ECR_TRACE("ATX type rowcount:" - num$(rowcount([F:HRATZ])),0) From GESECRAN

  CNT = 1
  For [F:HRATZ] Where find([F:HRATZ]CODFIC, "AMSK", "AWINDOW") > 0
    For [F:HRATZ2] Where [F:HRATZ2]CODFIC=[F:HRATZ]CODFIC and [F:HRATZ2]CODTYP = "ACV"
      Infbox [F:HRATZ2]CODZONE
    Next
  Next

  Filter [F:HRATZ]
Return

# Return list of languages in LANGS(0..(
$INIT_LANGS
Local Char LANGS(3)(0..)
Local Integer NBLANGS
Local File ADOSSIER [ADS]
Local Integer AI
If func DOSSUB.FILL_ADS(LDOSSIER)
 For AI=0 To [F:ADS]NBRLAN-1
  LANGS(AI) = [F:ADS]LAN(AI)
  NBLANGS+=1
 Next AI
Endif
Return

$CREATE_ATEXTE_RECORD
  Raz [F:HRATX]
  [F:HRATX] = [F:HRWATX]
  [F:HRATX]NUMERO = NEW_MASTER_NUMERO
  Raz [F:HRATX]UPDDATTIM
  Raz [F:HRATX]UPDUSR
  [F:HRATX]CREDATTIM = datetime$
  [F:HRATX]CREUSR = "MIG"
  Write [F:HRATX]
  Call ECR_TRACE("EMHRMAJ90_ATEXTE : New record created - NUMERO : " + num$(NEW_MASTER_NUMERO),0) From GESECRAN
Return

Subprog GENERATE_NEW_NUMERO(NEW_NUMERO, STD_CUSTOM, LDOSSIER)
Variable Integer NEW_NUMERO
Value Integer STD_CUSTOM #0 = STANDARD Range; 1 = CUSTOM Range
Value Char LDOSSIER

  If clalev([F:HRCHATX]) = 0 : Local File =LDOSSIER+".ATEXTE" [F:HRCHATX] : Endif
  Filter [F:HRCHATX] Where [F:HRCHATX]NUMERO>1000000
  Read [F:HRCHATX] Last
  If !fstat
    NEW_NUMERO = [F:HRCHATX]NUMERO + 1
  Else
    NEW_NUMERO = 1000001
  Endif

End NUMERO

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
  If [F:ADS]MODULE(14)<>2 : End : Endif
  Call MAJ_EMHRMAJ90_ATEXTE(APPLI)

End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3: End : Endif
  If [F:ADS]MODULE(14)<>2 : End : Endif
  Call MAJ_EMHRMAJ90_ATEXTE(APPLI)

End

