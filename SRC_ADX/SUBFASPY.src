#<AdxTL>@(#)7.0.0.0 $Revision$

######################################################################################
# Gestion du masque FASPHYS
# Création :
#     MABON - FQ55380 - 02/06/09 - Rapprochement d'un Bien comptable à des éléments physiques
#
# Modifications :
#   MWA - 17.02.2015 FQ109842 : Suppression du traitement lié à BACAUTNUM
#   CBO - 17.02.2015 FQ100398/13: Liaison FXD PHY
#   MDJ - 09.02.2015 FQ100398 : Suppression site géographique
#   CBO - 29.04.2014 FQ69690  : Suppression de BACFLG
#   MWA - 31.10.2012 FQ85464  : Prise en compte de la legislation dans la numérotation automatique
#   MDJ - 27.12.2011 FQ78704  : Numérotation automatique des codes barres
######################################################################################

$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "OK"           : Gosub OK
    When "FIN"          : Gosub FIN

    When Default
  Endcase
Return

######################################################################################
$OUVRE
Global Char    GLDAPCRIT(250) : # Critère de sélection des éléments physiques
Global Integer GLDAPSTAR      : # Statut de retour de la fenêtre Critère
Global Integer SAV_NOLIGN
Global Integer GLSELPHY
Local Integer  IS_NEW_LINE

  GLDAPCRIT = ""
  GLDAPSTAR = 0

  SAV_NOLIGN  = nolign-1
  IS_NEW_LINE = G_NON
  If SAV_NOLIGN = [M:FASP]NBPHY Then
    IS_NEW_LINE = G_OUI
  Endif
  If clalev([F:PHYS])=0 : Local File PHYELT [PHYS] : Endif
  GLSELPHY = G_NON
Return

######################################################################################
$DEBUT
Local Integer WINDICE
Global Char LREP   # pour garder le statut du Grep du BCO
Local  Char CRITERE(255)

  GPHN = func AFNC.ACTIV("PHN")
  If [M:FASP]NBPHY >= GPHN Then
    GERR=1
    FIN=1
    If dim(GLPHYSELOBJ)<0 Then
      GMESSAGE=mess(9,GML_MSGPHY,1)+chr$(13)+chr$(10)+mess(133,GML_MSGPHY,1)
    Endif
  Endif

  Filter [F:PHYS]
  Raz [M:FSP]
  nolign=1
  LREP = GREP

  #FQ100398/13
  CRITERE = 'AASREF="" and ISSDAT = [0/0/0] and FCY = "' + [M:FAS0]FCY + '"'

  If dim(GLDAPCRIT)>0 and GLDAPCRIT<>"" and dim(GLDAPSTAR)>0 and GLDAPSTAR>0 Then
    CRITERE += ' and ' + GLDAPCRIT
  Endif
  Filter [F:PHYS] Where evalue(CRITERE) Order By PHYREF

  # Alimentation des icônes et des cases à cocher Annulation attente et Attaché
  For [F:PHYS]
    If nolign>1000 Then
      Infbox mess(130,GML_MSGPHY,1)+ chr$(10) + chr$(13) + mess(131,GML_MSGPHY,1)
      Break
    Endif
    WINDICE = find([F:PHYS]PHYREF, [M:FASP]PHYREF(0..[M:FASP]NBPHY-1))
    If WINDICE=0 Then
      [M:FSP] = [F:PHYS]
      [M:FSP]LOCPHYS(nolign-1) = [F:PHYS]LCTCOD # FQ100398/13
      [M:FSP]BPRPHY(nolign-1)  = [F:PHYS]BPS # FQ100398/13

      nolign += 1
    Endif
  Next
  [M:FSP]NBPHYS = nolign-1
  Filter [F:PHYS]

  If [M:FSP]NBPHYS=0 Then
    GERR=1
    FIN=1
    If dim(GLPHYSELOBJ)<0 Then GMESSAGE=mess(112,GML_MSGPHY,1) Endif
  Endif

  # Référence du bien comptable
  [M:FSP]AASREF  = [M:FAS0]AASREF
  [M:FSP]AASDES1 = [M:FAS0]AASDES1
  Affzo [M:FSP]1-99
Return

######################################################################################
$FIN

  If clalev([F:PHYS])=0 : Local File PHYELT [PHYS] : Endif

  If dim(GLDAPCRIT)  > 0 Then Kill GLDAPCRIT  Endif
  If dim(GLDAPDTAR)  > 0 Then Kill GLDAPSTAR  Endif
  If dim(SAV_NOLIGN) > 0 Then Kill SAV_NOLIGN Endif
Return

######################################################################################
$APRES_MODIF

  If nolign-1>=[M:FSP]NBPHYS Then
    mkstat=2
  Endif
Return

######################################################################################
$OK
Local Integer I, J, WINDICE

  If [M:FSP]NBPHYS=0 : End : Endif
  J=[M:FASP]NBPHY-1
  nolign = [M:FASP]NBPHY
  For I=0 To [M:FSP]NBPHYS-1
    If [M:FSP]ICORATTACH(I)=G_OUI
      If nolign >= GPHN Then
        Infbox mess(9,GML_MSGPHY,1)+chr$(13)+chr$(10)+mess(133,GML_MSGPHY,1)-num$(nolign-[M:FASP]NBPHY)-mess(134,GML_MSGPHY,1)
        Break
      Endif
      WINDICE = find([M:FSP]PHYREF(I), [M:FASP]PHYREF(0..[M:FASP]NBPHY-1))
      # On n'ajoute l'élément que s'il n'est pas déjà dans le tableau
      If WINDICE = 0
        GLSELPHY = G_OUI
        nolign += 1
        Read [F:PHYS]PHY0=[M:FSP]PHYREF(I)
        If !fstat Then
          [M:FASP]PHYREF(nolign-1)     = [F:PHYS]PHYREF
          [M:FASP]LCTCOD(nolign-1)     = [F:PHYS]LCTCOD # FQ100398/13
          [M:FASP]BAC(nolign-1)        = [M:FSP]BAC(I)
          [M:FASP]MVT(nolign-1)        = GVMLPMVNONE
          [M:FASP]FLGMODIF(nolign-1)   = G_OUI
          [M:FASP]FLGLOCK(nolign-1)    = G_OUI
          [M:FASP]ICORATTACH(nolign-1) = GICOATTACHE
          [M:FASP]RATTACHE(nolign-1)   = G_OUI
        Endif
      Else
        [M:FASP]BAC(WINDICE)        = [M:FSP]BAC(I)
      Endif
    Endif
  Next
  If IS_NEW_LINE=G_OUI Then
    VALEUR = [M:FASP]PHYREF(SAV_NOLIGN)
  Endif
  [M:FASP]NBPHY = nolign

  Affzo [M:FASP]1-99
Return

