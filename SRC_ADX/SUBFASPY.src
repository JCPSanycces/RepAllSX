######################################################################################
######################################################################################
Subprog IB_NBPHYS

  Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5

  If [M:FSP]NBPHYS>0 Then
    GBOUT2 = mess(128,GML_MSGPHY,1)
    GBOUT3 = mess(129,GML_MSGPHY,1)
  Endif
  If nolign-1<[M:FSP]NBPHYS Then
    GBOUT4 = mess(132,GML_MSGPHY,1)
  Endif
  GBOUT5 = mess(014,103,1)
  Affzo [M:FSP]
End

######################################################################################
# Sélection de toutes les lignes
Subprog B2_NBPHYS
Local Integer I

  For I=0 To [M:FSP]NBPHYS-1
# FQ100398/13
#    mkstat=0
    # lock logique de l'élément physique
#    Call VERROU_PHYREF([M:FSP]PHYREF(I),[M:FAS0]CPY) From SUBFASP
#    If mkstat = 0
      [M:FSP]ICORATTACH(I) = G_OUI
#    Endif
  Next
  Affzo [M:FSP]
End

######################################################################################
# Dé-sélection de toutes les lignes
Subprog B3_NBPHYS
Local Integer I

  For I=0 To [M:FSP]NBPHYS-1
    [M:FSP]ICORATTACH(I) = G_NON
  Next
  # FQ100398/13
#  Call DEVERROU_PHYREF("")
  Affzo [M:FSP]
End


######################################################################################

