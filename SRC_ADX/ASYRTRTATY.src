Funprog GETFORMATBID(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     AFORMAT
Value    Char     COUNTRY
Local Integer ASTATUS
AFORMAT = ""
If COUNTRY<>""
 AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"BIDFMT")
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLBID(AINSTANCE,APRONAME,AVALUE,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     COUNTRY
Local Integer ASTATUS , CTLBAN , LNGBAN , OKTRT
Local Char    AFORMAT(30) , BANK(30) , CTLPRG(30)
ASTATUS = func GETFORMATBID(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
If AFORMAT<>""
 Gosub CTLCHR
Endif
If ASTATUS=CST_AOK & COUNTRY<>"" & AVALUE<>""
 CTLBAN = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"BIDCTL")
 If CTLBAN=CST_AYES
  LNGBAN = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"BANLNG")
  If LNGBAN>0
   Local File ABANK [ABN]
   BANK = left$(AVALUE,LNGBAN)
   Read [ABN]ABN0 = COUNTRY;BANK
   If fstat
    # Banque inexistante
    ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,BANK-":"-mess(173,133,1),[V]CST_AERROR)
   Endif
   LogicClose File [ABN]
  Endif
 Endif
 If ASTATUS=CST_AOK
  CTLPRG = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"CTLPRG")
  Call EXISTE_ADX("","",CTLPRG,OKTRT) From ASYRSYS
  If OKTRT>0
   #Call RIB(AVALUE,ASTATUS) From =CTLPRG
  Endif
 Endif
Endif
End ASTATUS

#----------------------------------------------------#
# EEC No de TVA intracommunautaire
#----------------------------------------------------#

Funprog GETFORMATEEC(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     AFORMAT
Value    Char     COUNTRY
Local Integer ASTATUS
AFORMAT = ""
If COUNTRY<>""
 AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"EECFMT")
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLEEC(AINSTANCE,APRONAME,AVALUE,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     COUNTRY
Local Integer ASTATUS , CTLTVA , OKTRT
Local Char    AFORMAT(30) , RADTVA(30) , CTLPRG(30)
# Issue 118719 - 2016-11-15 by cfavre : Check null value
If AVALUE = AVOID.ACHAR
  End [V]CST_AOK
Endif
ASTATUS = func GETFORMATEEC(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
If AFORMAT<>""
 Gosub CTLCHR
Endif
If ASTATUS=CST_AOK & COUNTRY<>""
 CTLTVA = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"EECFLG")
 If CTLTVA=2
  RADTVA = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"CRYVATNUM")
  If RADTVA<>"" & left$(AVALUE,len(RADTVA))<>RADTVA
   # Radical de no de TVA différent de
   ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(5,127,1)-RADTVA,[V]CST_AWARNING)
  Endif
 Endif
Endif
If ASTATUS=CST_AOK
 CTLPRG = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"CTLPRG")
 Call EXISTE_ADX("","",CTLPRG,OKTRT) From ASYRSYS
 If OKTRT>0
  #TODO LSE control script name must be taken into account
  #Call TVA(AVALUE,ASTATUS) From =CTLPRG
 Endif
Endif
End ASTATUS

#----------------------------------------------------#
# MD1 Montant en devises
#----------------------------------------------------#

Funprog GETFORMATMD1(AINSTANCE,APRONAME,AVALUE,AFORMAT,CURRENCY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Decimal  AVALUE
Variable Char     AFORMAT
Value    Char     CURRENCY
Local Integer ASTATUS
AFORMAT = ""
If CURRENCY<>""
 AFORMAT = num$(fmet AINSTANCE.ACTX.ACACHE.ACUR.AGETVALDEC(CURRENCY,"DCURFMT1"))+"#"
Endif
ASTATUS=0
End ASTATUS

