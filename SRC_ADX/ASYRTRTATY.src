#---------------------------------------------------------------#
Funprog CONTROLTEL(AINSTANCE,APRONAME,AVALUE,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     COUNTRY
Local Integer ASTATUS , OPTION , OKTRT
Local Char    AFORMAT(30) , CTLPRG(30)
OPTION = val(fmet AINSTANCE.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD,"","CTLTEL"))
If OPTION>1
 ASTATUS = func GETFORMATTEL(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
 If AFORMAT<>""
  Gosub CTLCHR
 Endif
 If ASTATUS=CST_AOK & COUNTRY<>""
  CTLPRG = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"CTLPRG")
  Call EXISTE_ADX("","",CTLPRG,OKTRT) From ASYRSYS
  If OKTRT>0
   #Call CNTTEL(AVALUE,ASTATUS) From =CTLPRG
  Endif
  If ASTATUS=CST_AOK
   Gosub CTLTEL
  Endif
 Endif
Endif
End ASTATUS

