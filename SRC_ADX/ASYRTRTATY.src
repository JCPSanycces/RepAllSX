#----------------------------------------------------#
# QTY Quantité
#----------------------------------------------------#

Funprog GETFORMATQTY(AINSTANCE,APRONAME,AVALUE,AFORMAT,UNIT)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Decimal  AVALUE
Variable Char     AFORMAT
Value    Char     UNIT
Local Integer LNG , DEC
Local Integer ASTATUS
AFORMAT = ""
LNG = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALDEC("QTY","LNGTYP")
If LNG=0 : LNG = 15 : Endif
Case UNIT
 When "#" : AFORMAT = num$(LNG)+"#"
 When "0" : AFORMAT = num$(int(LNG))+"F"
 When "1" : AFORMAT = num$(LNG-1)+".#"
 When "2" : AFORMAT = num$(LNG-2)+".2#"
 When "3" : AFORMAT = num$(LNG-3)+".3#"
 When "4" : AFORMAT = num$(LNG-4)+".4#"
 When "5" : AFORMAT = num$(LNG-5)+".5#"
 When "6" : AFORMAT = num$(LNG-6)+".6#"
 When Default
  If UNIT<>""
   DEC = fmet AINSTANCE.ACTX.ACACHE.ATUN.AGETVALDEC(UNIT,"UOMDEC")
  Else
   DEC = 0
  Endif
  If DEC<0 : # théorique
   AFORMAT = num$(int(LNG))+"F"
  Elsif DEC=0
   AFORMAT = num$(LNG)+"#"
  Else
   AFORMAT = num$(LNG-DEC)+"."+num$(DEC)+"#"
  Endif
Endcase
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLQTY(AINSTANCE,APRONAME,AVALUE,UNIT)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Decimal  AVALUE
Value    Char     UNIT
Local Integer ASTATUS
Local Char    AFORMAT(30)
ASTATUS = func GETFORMATQTY(AINSTANCE,APRONAME,AVALUE,AFORMAT,UNIT)
If AFORMAT<>""
 Gosub CTLNUM
Endif
End ASTATUS

#------------------------------------------------------------#
# Generic
#------------------------------------------------------------#

Funprog GETFORMAT(AINSTANCE,APRONAME,AVALUE,AFORMAT,CODTYP)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     AFORMAT
Value    Char     CODTYP
Local Integer  ASTATUS
Local Integer  LNGTYP , TYPTYP
AFORMAT = ""
If CODTYP<>""
 AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALCHAR(CODTYP,"FORTYP")
 If left$(AFORMAT,1)="="
  AFORMAT = ""
 Endif
 If AFORMAT=""
  LNGTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALNUM(CODTYP,"LNGTYP")
  If LNGTYP>0
   TYPTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALNUM(CODTYP,"TYPTYP")
   Case TYPTYP
    When 1,2,3,4,5,6 : AFORMAT = func SETFMTNUM(CODTYP) : # Menu/Entier court/Long/Décimal/Flottant/Décimal
    When 7           : AFORMAT = func SETFMTCHR(CODTYP) : # Alpha
    When Default     : AFORMAT = ""
   Endcase
  Endif
 Endif
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLFORMAT(AINSTANCE,APRONAME,AVALUE,CODTYP)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     CODTYP
Local Integer ASTATUS, TYPTYP
Local Char    AFORMAT(30)
ASTATUS = func GETFORMAT(AINSTANCE,APRONAME,AVALUE,AFORMAT,CODTYP)
If AFORMAT<>""
 TYPTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALNUM(CODTYP,"TYPTYP")
 Case TYPTYP
  When 1,2,3,4,5,6 : Gosub CTLNUM : # Menu/Entier court/Long/Décimal/Flottant/Décimal
  When 7           : Gosub CTLCHR : # Alpha
 Endcase
Endif
End ASTATUS

#--------------------------------------------------------------------------#
# Miscellaneous sub-programs
#--------------------------------------------------------------------------#

Subprog SETFMTCHR(CODTYP)
Value Char CODTYP
Local    Char    TYPFMT(20), FORTYP(20), CARFMT(20) , OPTION(20)
Local    Integer LNGTYP
Local    Char    FMT(30)
FORTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALCHAR(CODTYP,"FORTYP")
LNGTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALNUM(CODTYP,"LNGTYP")
OPTION = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALCHAR(CODTYP,"OPTION")
If left$(FORTYP,1)="=" or LNGTYP=0
 FMT = ""
Elsif FORTYP=""
 If instr(1,OPTION,"C")
  CARFMT = "c"
 Elsif instr(1,OPTION,"A")
  If instr(1,OPTION,"#") : CARFMT = "B" : Else : CARFMT = "A" : Endif
 Elsif instr(1,OPTION,"#")
  CARFMT = "#"
 Else
  CARFMT = "X"
 Endif
 FMT = num$(LNGTYP)+CARFMT
Else
 FMT = FORTYP
Endif
End FMT

#-----------------------------------------------------------#
Subprog SETFMTNUM(CODTYP)
Value Char CODTYP
Local Integer LNGTYP , TYPTYP
Local Char    OPTION(30) , CARFMT(1) , FORTYP(30)
Local Char FMT(250)
FORTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALCHAR(CODTYP,"FORTYP")
LNGTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALNUM(CODTYP,"LNGTYP")
TYPTYP = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALNUM(CODTYP,"TYPTYP")
OPTION = fmet AINSTANCE.ACTX.ACACHE.ATYP.AGETVALNUM(CODTYP,"OPTION")
If left$(FORTYP,1)="=" or LNGTYP=0
 FMT = ""
Elsif FORTYP=""
 Case TYPTYP
  When 1   : # Menu
   FMT = "3#"
  When 2,3 : # Entier court/Long
   FMT = num$(LNGTYP)+"#"
  When 4   : # Décimal
   If instr(1,num$(LNGTYP),".") & !instr(1,OPTION,"F")
    CARFMT = "#"
   Else
    CARFMT = "F"
   Endif
   FMT = num$(LNGTYP)+CARFMT
  When 5,6 : # Flottant/double
   FMT = num$(LNGTYP)+"F"
  When Default
   FMT = ""
 Endcase
Else
 FMT = FORTYP
Endif
End FMT

#-----------------------------#
$CTLNUM
Local Integer K
Local Char    SEPTHO(1) , SEPDEC(1) , VALFOR(50)
ASTATUS = CST_AOK
If AFORMAT<>""
 SEPTHO = AINSTANCE.ACTX.AINTL.THOUSANDSEP
 If SEPTHO=""
  SEPTHO = mid$(adxsca,3,1)
 Endif
 SEPDEC = AINSTANCE.ACTX.AINTL.DECIMALSEP
 If SEPDEC=""
  SEPDEC = mid$(adxsca,4,1)
 Endif
 VALFOR = vireblc(format$("N:"+AFORMAT,AVALUE),2)
 VALFOR = ctrans(VALFOR,SEPTHO,"")
 VALFOR = ctrans(VALFOR,"*","")
 VALFOR = ctrans(VALFOR,SEPDEC,".")
 K = instr(1,VALFOR,"-")
 If K
  VALFOR = "-"+left$(VALFOR,K-1)+right$(VALFOR,K+1)
 Endif
 K = instr(1,VALFOR,"+")
 If K
  VALFOR = left$(VALFOR,K-1)+right$(VALFOR,K+1)
 Endif
 If AVALUE<>val(VALFOR)
  # Format incorrect
  ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(149,100,1),[V]CST_AERROR)
 Endif
Endif
Return

#-------------------#
$CTLCHR
Local Integer I , J
Local Char    NEWFOR(50) , VALFOR(255)
ASTATUS = CST_AOK
If AFORMAT<>""
 NEWFOR = AFORMAT
 I = instr(1,NEWFOR,"[")
 While I
  J = instr(I+1,NEWFOR,"]")
  If J
   NEWFOR = left$(NEWFOR,I-1)+right$(NEWFOR,J+1)
  Endif
  I = instr(I+1,NEWFOR,"[")
 Wend
 VALFOR = vireblc(format$("K:"+NEWFOR,AVALUE),2)
 If AVALUE<>VALFOR
  # Format incorrect
  ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(149,100,1),[V]CST_AERROR)
 Endif
Endif
Return

#-------------------------------------------------------------------------#
$CTLTEL
Local Char    IDTPAY(10) , IDTREG(10) , NUMTEL(30) , TEL(30)
Local Integer STAT , I

ASTATUS = CST_AOK

If len(AVALUE)=0 : Return : Endif
TEL = AVALUE

Gosub SET_IDT

If len(TEL)<>LNG & LNG>0
 # Longueur incorrecte
 ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(111,123,1)-'('+num$(LNG)+')',[V]CST_AERROR)
 Return
Endif

If CTLTCY
 If IDTPAY=""
  # Indicatif pays impossible à déterminer
  ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(115,127,1),[V]CST_AERROR)
  Return
 Elsif IDTPAY<>""
  STAT = 0
  For I=1 To len(IDTPAY)
   If mid$(IDTPAY,I,1)<"0" or mid$(IDTPAY,I,1)>"9"
    STAT = 1 : Break
   Endif
  Next I
  If STAT
   # Indicatif pays non numérique
   ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(120,127,1),[V]CST_AERROR)
   Return
  Endif
 Endif
Endif

If CTLREG
 If IDTREG=""
  # Indicatif région impossible à déterminer
  ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(116,127,1),[V]CST_AERROR)
  Return
 Elsif IDTREG<>""
  STAT = 0
  For I=1 To len(IDTREG)
   If mid$(IDTREG,I,1)<"0" or mid$(IDTREG,I,1)>"9"
    STAT = 1 : Break
   Endif
  Next I
  If STAT
   # Indicatif régional non numérique
   ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(119,127,1),[V]CST_AERROR)
   Return
  Endif
 Endif
Endif

Return

#--------------------------------------#
$RIEN
Resume

#--------------------------------------#
$SET_IDT
Local Integer K , D , F , M , LNG
Local Integer CTLTCY , CTLREG
Local Char    TELTCY(10) , TELREG(10)
Local Char    CHAINE(250) , TELEP(30)
If AFORMAT<>"" & TEL<>""
 Call LNGFMT(AFORMAT,LNG) From FMTVAR
 TELEP = format$("K:"+AFORMAT,TEL)
 TELTCY = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"TELTCY")
 TELREG = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"TELREG")
 If LNG=len(TEL)
  For CHAINE=TELTCY,TELREG
   If CHAINE<>""
    Case CHAINE
     When TELTCY : CTLTCY = 1
     When TELREG : CTLREG = 1
    Endcase
    K = instr(1,CHAINE,"-")
    If K<>0
     D = val(left$(CHAINE,K-1))
     F = val(right$(CHAINE,K+1))
     M = max(M,F)
     Case CHAINE
      When TELTCY : IDTPAY = seg$(TELEP,D,F)
      When TELREG : IDTREG = seg$(TELEP,D,F)
     Endcase
    Endif
   Endif
  Next CHAINE
 Endif
 NUMTEL = right$(TELEP,M+1)
Endif
Return

#---------------------------------------------------------------------------#
# Renvoie le nombre de caractères maxi d'un format sans les commentaires
#---------------------------------------------------------------------------#

Funprog LNGFMT(FMT)
Value    Char    FMT
Local Integer COM , NUM , LNG , PNT , LNG
Local Integer I , F , K , D , N , L
Local Char    CHAINE(250)
If FMT="" or left$(FMT,1)="="
 LNG = 0
Else
 F = instr(1,FMT,":")
 K = instr(1,FMT,"K")
 D = instr(1,FMT,"D")
 N = instr(1,FMT,"N")
 L = instr(1,FMT,"L")
 If (K & K<F) or (D & D<F) or (N & N<F) or (L & L<F)
  CHAINE = right$(FMT,F+1)
  Gosub LNG
 Else
  CHAINE = FMT
  Gosub LNG
 Endif
Endif
End LNG

#------------------#
$LNG
Raz COM , NUM , LNG , PNT
For I=1 To len(CHAINE)
 If mid$(CHAINE,I,1)="["
  COM = I
 Elsif mid$(CHAINE,I,1)="]"
  COM = 0
 Elsif COM
  # Commentaires
 Elsif instr(1,"0123456789",mid$(CHAINE,I,1))
  If NUM=0
   NUM = val(mid$(CHAINE,I,1))
  Elsif NUM<10
   NUM = (NUM*10)+val(mid$(CHAINE,I,1))
  Elsif NUM<100
   NUM = (NUM*10)+val(mid$(CHAINE,I,1))
  Endif
 Elsif mid$(CHAINE,I,1)="." & I<>len(CHAINE)
  Gosub NUM
  PNT = 1
  LNG += 1
 Elsif mid$(CHAINE,I,1)="+" or mid$(CHAINE,I,1)="-"
  Gosub NUM
  LNG += 1
 Elsif NUM
  Gosub NUM
 Else
  LNG += 1
 Endif
Next I
Gosub NUM
Return

#---------------------#
$NUM
If NUM
 If !PNT & F>0 & instr(1,left$(FMT,F-1),"3")
  LNG += int((NUM-1)/3)+NUM
 Else
  LNG += NUM
 Endif
 NUM = 0
Endif
Return

