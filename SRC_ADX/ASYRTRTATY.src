#----------------------------------------------------#
# ADL Ligne adresse
#----------------------------------------------------#

Funprog GETFORMATADL(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     AFORMAT
Value    Char     COUNTRY
Local Integer ASTATUS
AFORMAT = ""
If COUNTRY<>""
 AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"ADRCODFMT")
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLADL(AINSTANCE, APRONAME,AVALUE,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     COUNTRY
Local Integer ASTATUS
Local Char    AFORMAT(30)
ASTATUS = func GETFORMATADL(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
If AFORMAT<>""
 Gosub CTLCHR
Endif
End ASTATUS

#----------------------------------------------------#
# POS Code postal
#----------------------------------------------------#

Funprog GETFORMATPOS(AINSTANCE,APRONAME,AVALUE,AFORMAT,CRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     AFORMAT
Value    Char     CRY
Local Integer ASTATUS
AFORMAT = ""
If CRY<>""
 AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(CRY,"POSCODFMT")
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLPOS(AINSTANCE,APRONAME,AVALUE,CRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     CRY
Local Integer ASTATUS , MANDAT , MINZIP , CONTROL
Local Char    AFORMAT(30)
If AINSTANCE.ObjectType ="C_POSCOD" & AINSTANCE.ASTALIN=[V]CST_ANEW
 ASTATUS = CST_AOK
Elsif CRY<>""
 ASTATUS = func GETFORMATPOS(AINSTANCE,APRONAME,AVALUE,AFORMAT,CRY)
 MANDAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(CRY,"POSOBL")
 If MANDAT=CST_AYES & len(AVALUE)=0
  # Zone obligatoire
  ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(10,123,1),[V]CST_AERROR)
 Elsif AFORMAT<>""
  Gosub CTLCHR
 Endif
 If ASTATUS=CST_AOK & AVALUE<>""
  MINZIP =  fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(CRY,"MINZIP")
  CONTROL = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(CRY,"POSCODCTL")
  If CONTROL=CST_AYES
   Local File POSCOD [POS]
   Read [POS]POS0(2)=CRY;AVALUE
   If fstat & MINZIP>0
    Read [POS]POS0(2)=CRY;left$(AVALUE,MINZIP)
   Endif
   If fstat
    # Code postal inexistant
    ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,AVALUE-":"-mess(188,100,1),[V]CST_AWARNING)
   Endif
   LogicClose File [POS]
  Endif
 Endif
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog PROPAGATEPOS(AINSTANCE,APRONAME,AVALUE,POSCTY,SAT,CRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     POSCTY
Variable Char     SAT
Value    Char     CRY
Local Integer ASTATUS

ASTATUS= CST_AOK

#If empty nothing
If CRY=AVOID.ACHAR or AVALUE=AVOID.ACHAR
  End ASTATUS
Endif

If ((fmet AINSTANCE.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD,AINSTANCE.ACTX.AFOLDER,"POSCODCPY") <> CST_AYES) and
& (fmet AINSTANCE.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD,AINSTANCE.ACTX.AFOLDER,"CRYDEF") <> CRY) )
  End ASTATUS
Endif

Local Integer NB_TOWN , OK
Local Integer IMINZIP
Local Char    SMINCP(GLONPOS)

Local File POSCOD     [POS]
Local File TABCOUNTRY [TCY]

Read [TCY]TCY0 = CRY
If fstat <> CST_AOK
  ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,CRY -":"-mess(23,100,1),[V]CST_AERROR)
  End ASTATUS
Endif

IMINZIP = 0
SMINCP = AVALUE
If dim([F:TCY]MINZIP) >= 0 Then
  IMINZIP = [F:TCY]MINZIP
Endif
Repeat
  NB_TOWN = 0
# Issue 118719 - 2016-10-25 by CFF : Error in For syntax
# For [POS]POS0(3) Where [F:POS]CRY = CRY & [F:POS]POSCOD = SMINCP
  For [POS]POS0(3) Where CRY=[L]CRY & POSCOD=[L]SMINCP
    NB_TOWN += 1
    If NB_TOWN>1
      Break
    Endif
  Next
  If NB_TOWN >= 1 Then
    Break
  Endif
  If IMINZIP > 0 Then
    If SMINCP = left$(AVALUE,IMINZIP) Then
      Break
    Endif
    SMINCP = left$(AVALUE,IMINZIP)
  Endif
Until IMINZIP = 0

If NB_TOWN=1
  POSCTY = [F:POS]POSCTY
  SAT  = [F:POS]SATCOD
Endif
End ASTATUS

#----------------------------------------------------#
# CTY Ville
#----------------------------------------------------#

Funprog GETFORMATCTY(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     AFORMAT
Value    Char     COUNTRY
Local Integer ASTATUS
AFORMAT = ""
If COUNTRY<>""
 AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"CTYCODFMT")
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLCTY(AINSTANCE,APRONAME,AVALUE,COUNTRY)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     COUNTRY
Local Integer ASTATUS , UPP , POSOBL , OK , CONTROL , OKTRT, MANDAT
Local Char    AFORMAT(30) , CTLPRG(30)
If AINSTANCE.ObjectType ="C_POSCOD" & AINSTANCE.ASTALIN=[V]CST_ANEW
 ASTATUS = CST_AOK
Elsif COUNTRY<>""
 CTLPRG = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"CTLPRG")
 Call EXISTE_ADX("","",CTLPRG,OKTRT) From ASYRSYS
 If OKTRT>0
  #Call FMTCTY(AVALUE,ASTATUS) From =CTLPRG
 Endif
 If ASTATUS=CST_AOK
  ASTATUS = func GETFORMATCTY(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY)
  UPP = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"CTYUPP")
  If UPP=CST_AYES
   AVALUE = toupper(ctrans(AVALUE))
  Endif
  MANDAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"POSOBL")
  If MANDAT=CST_AYES & len(AVALUE)=0
   # Zone obligatoire
   ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,mess(10,123,1),[V]CST_AERROR)
  Elsif AFORMAT<>"" & AVALUE<>""
   Gosub CTLCHR
  Endif
  If ASTATUS=CST_AOK & AVALUE<>""
   CONTROL = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"POSCODCTL")
   If CONTROL=CST_AYES
    Local File POSCOD [POS]
    OK = 0
    For [POS]POS1 Where CRY=COUNTRY & toupper([POS]POSCTY)=toupper(AVALUE)
     OK = 1 : Break
    Next POS
    If !OK
     # Ville inexistante
     ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,AVALUE-":"-mess(189,100,1),[V]CST_AWARNING)
    Endif
    LogicClose File [POS]
   Endif
  Endif
 Endif
Endif
End ASTATUS

