Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     POSTCOD
Variable Char     STATE
Value    Char     COUNTRY
Local Integer ASTATUS
End ASTATUS

#----------------------------------------------------#
# SAT Etat(province)
#----------------------------------------------------#

Funprog GETFORMATSAT(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY,SPECIAL)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Char     AFORMAT
Value    Char     COUNTRY
Value    Char     SPECIAL
Local Integer ASTATUS
Local Integer SUB , FLG : # 115204
AFORMAT = ""
If COUNTRY<>""
  If left$(SPECIAL, 5) <>  "this."
    SUB = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"ETAT")
  Else
    #The subdivison property exists and is in SPECIAL
    SUB= evalue ("AINSTANCE"+ right$ (SPECIAL,5))
  Endif

  AFORMAT = num$(GLONSAT)+"X"
  Case SUB
    When 2
    FLG = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"ETATFLG")
    If FLG=CST_AYES
      AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"ETATFMT")
    Endif

    When 3
    FLG = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"ETATFLG2")
    If FLG=CST_AYES
      AFORMAT = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALCHAR(COUNTRY,"ETATFMT2")
    Endif
  Endcase
Endif
End ASTATUS

#---------------------------------------------------------------#
Funprog CONTROLSAT(AINSTANCE,APRONAME,AVALUE,COUNTRY,SPECIAL)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     COUNTRY
Value    Char     SPECIAL
Local Integer ASTATUS , CTL , STA , OK
Local Char    AFORMAT(30)

If len(AVALUE)=0 : End ASTATUS : Endif
ASTATUS = func GETFORMATSAT(AINSTANCE,APRONAME,AVALUE,AFORMAT,COUNTRY,SPECIAL)
If AFORMAT<>""
 Gosub CTLCHR
Endif

If ASTATUS=CST_AOK
  If SPECIAL="" or (SPECIAL="2" and COUNTRY<>"")
   CTL = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"ETATCTL")
   If CTL=CST_AYES
    STA = fmet AINSTANCE.ACTX.ACACHE.ACRY.AGETVALNUM(COUNTRY,"ETAT")
    If find(STA,2,3)
     Local File TABSUBDIV [ATU]
     OK = 0
     For [ATU]ATU0 Where CRY=[L]COUNTRY & TYP=[L]STA & toupper(COD)=toupper(AVALUE)
      OK = 1 : Break
     Next ATU
     If !OK
      # Fiche inexistante
      ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,AVALUE-":"-mess(23,100,1),[V]CST_AERROR)
     Endif
     LogicClose File [ATU]
    Endif
   Endif
  Elsif left$(SPECIAL, 5)= "this."
    #The subdivison property exists and is in SPECIAL
    STA= evalue ("AINSTANCE"+ right$ (SPECIAL,5))
    Local File TABSUBDIV [ATU]
    OK = 0
    For [ATU]ATU0 Where CRY=[L]COUNTRY & TYP=[L]STA & toupper(COD)=toupper(AVALUE)
      OK = 1 : Break
     Next ATU
     If !OK
      # Fiche inexistante
      ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,AVALUE-":"-mess(23,100,1),[V]CST_AERROR)
     Endif
     LogicClose File [ATU]
  Endif
Endif
End ASTATUS

