#<AdxTL>@(#)3.0.0.0 $Revision$
#############################################################################
# TRTACHPOH1     Traitements liĂŠs aux commandes standards      Module Achat #
# ------------------------------------------------------------------------- #
# Sous-programmes :                                                         #
# Gosub                                                                     #
#   - MGT_POH1        : Gestion auto cdes stds Ă  partir du plan de travail  #
#############################################################################

#############################################################################
# MGT_POH1 : S/P de gestion des commandes stds Ă  partir du plan de travail  #
#           de l'approvisionneur                               MBT 06/10/00 #
# ------------------------------------------------------------------------- #
# Gosub MGT_POH1                                                            #
#     Les paramĂ¨tres sont passĂŠs par l'ĂŠcran PURMGT [PMG]                   #
#     ---------------- A l'appel du sous-programme --------------------     #
#     MAJCOD   : Code mise Ă  jour                                           #
#                  C = CrĂŠation d'une ou plusieurs lignes de commande       #
#                  M = Modification d'une ligne de commande                 #
#                  A = Suppression  d'une ligne de commande                 #
#                  S = Solde d'une ligne de commande                        #
#     RGRFLG   : Code regroupement des lignes Ă  traiter                     #
#                0-1 = Non (1 ligne = 1 commande)                           #
#                  2 = Oui (1 regroupement  = 1 commande)                   #
#                  3 = Oui (X regroupements = X lignes sur mĂŞme DA)         #
#                  4 = Oui (1 regroupement  = 1 cde/da ssi tout est ok )    #
#     MSGFLG   : Code affichage message de temporisation                    #
#                0-1 = Non                                                  #
#                  2 = Oui ("Mise Ă  jour commande en cours ..")             #
#     TRAFLG   : Code fichier trace                                         #
#                0-1 = Non                                                  #
#                  2 = Oui ĂŠcriture des messages dans un fichier trace      #
#     USEPLC   : Lieu de consommation                                       #
#     REQUSR   : Code gestionnaire                                          #
#                  par dĂŠfaut GUSER                                         #
#     PSHFCY   : Site de la commande si ORDFCY() non renseignĂŠ              #
#     PRQDAT   : Date de la commande                                        #
#                  par dĂŠfaut date du jour (date$)                          #
#     TARGRP   : Application des tarifs groupĂŠs si GPURGRUDIS Ă  la demande  #
#                0-1 = Non                                                  #
#                  2 = Oui                                                  #
#     REVFLG   : Modification avec avenant                                  #
#                0-1 = Non                                                  #
#                  2 = Oui                                                  #
#     PRTFLG   : Impression des bons de commande                            #
#                0-1 = Non                                                  #
#                  2 = Oui                                                  #
#     DOCNAM   : Nom du document (ex "BONCDE")                              #
#     PRTCOD   : Destination (nom de l'imprimante)                          #
#     NBLIG    : Nombre de lignes Ă  traiter (par dĂŠfaut 1)                  #
#                  si crĂŠation de 1 Ă  50                                    #
#                  si modification ou suppression 1                         #
#     Tableau des lignes Ă  traiter                                          #
#     WIPTYP()  WIPSTA()    WIPNUM()  ITMREF()    ORDFCY()  ORIFCY()        #
#     STOFCY()  VCRTYP()    VCRNUM()  VCRLIN()    VCRSEQ()  ENDDAT()        #
#     STU()     EXTSTUQTY() PUU()     EXTPUUQTY() ERRLIN()                  #
#     ---------------- Au retour du sous-programme --------------------     #
#     ERRCOD  : Code erreur au retour du S/P                                #
#                0 = OK pas d'erreur                                        #
#                2 = Module Stocks Affectation des compteurs non trouvĂŠe !  #
#                3 = Compteur en-cours incorrect ou non dĂŠfini (max 15 car) #
#                4 = La structure par dĂŠfaut des tarifs n'existe pas !      #
#                5 = Code mise Ă  jour incorrect !                           #
#                7 = 2 xxxxxxxxxx ProblĂ¨me de mise Ă  jour des encours       #
#                8 = xxx xxxxxxxx ProblĂ¨me Ă  la lecture de l'article-site ! #
#                9 = Commande xxx ProblĂ¨me de mise Ă  jour des signatures    #
#               10 = Type d'ordre non traitĂŠ !                              #
#               11 = xxxxxxxx Commande introuvable !                        #
#               12 = xxxxxxxx 99 99 Ligne commande introuvable ! (QtĂŠs)     #
#               13 = xxxxxxxx 99 99 Ligne commande introuvable ! (Prix)     #
#               14 = xxxxxxxx Erreur en mĂ j ordre de fabrication            #
#               15 = Commande xxxxxxxx ProblĂ¨me de mise Ă  jour des avenants #
#               16 = xxxxxxxx 99 99 ProblĂ¨me de mise Ă  jour des avenants    #
#               17 = Commande xxxxxxxxx ProblĂ¨me de mĂ j de statistiques     #
#               18 = xxxxxxxx 99 99 ProblĂ¨me de mĂ j des statistiques        #
#               19 = xxx Vous n'avez pas les droits pour ce site            #
#               20 = xxxxxxxx xxx Article-site introuvable !                #
#               21 = xxxxxxxx 99 99 Modification sans avenant interdite     #
#               22 = xxxxxxxx Commande soldĂŠe. Modification interdite       #
#               23 = xxxxxxxx 99 99 Ligne commande soldĂŠe. Modification ... #
#               24 = xxxxxxxx 99 99 Ligne dĂŠjĂ  soldĂŠe...                    #
#               25 = xxxxxxxx 99 99 Suppression interdite...                #
#               26 = xxxxxxxx 99 99 Commande contremarque...                #
#               27 = ParamĂŠtrage rĂ¨gles signature inexistant pour la soc... #
#               28 = La rĂŠfĂŠrence article est nĂŠcessaire                    #
#               29 = xxxxxxxx : Code article inexistant                     #
#               30 = xxxxxxxx : Article inactif                             #
#               31 = xxxxxxxx : Article non gĂŠrĂŠ en stock                   #
#               32 = xxxxxxxx xxxxxxx L'article est en litige               #
#               33 = La qtĂŠ est infĂŠrieure Ă  la qtĂŠ minimum. 999,99 xxx     #
#               34 = La qtĂŠ saisie ne peut ĂŞtre infĂŠrieure Ă  la qtĂŠ cons... #
#               35 = xxx : Site inexistant ou n'est pas un dĂŠpĂ´t            #
#               36 = xxx Le site n'est pas sur la mĂŞme sociĂŠtĂŠ juridique    #
#               37 = $PORDER  xxxxxxx Modification en cours sur un autre .. #
#                    $PORDERQ xxxxxxx 999 Modification en cours sur un .... #
#                    $PORDERP xxxxxxx 999 Modification en cours sur un .... #
#               38 = xxxxxxxxxxxxxxxxxxxxxxxxxx Erreur de budget !          #
#               39 = Erreur Ă  la mise Ă  jour des demandes d'achat !         #
#               40 = Commande xxxxxxx ProblĂ¨me de mise Ă  jour des acomptes  #
#               41 = ProblĂ¨me sur l'inter-site                              #
#               42 = Pas de fournisseur                                     #
#               43 = QuantitĂŠ Ă  zĂŠro                                        #
#               44 = Commande inter-site                                    #
#               45 = Fournisseur inactif ou prospect                        #
#               99 = Erreurs diverses                                       #
#     ERRLIN(): Code erreur ligne au retour du S/P (indicĂŠ de 0 Ă  45)       #
#                0 = OK pas d'erreur, ligne traitĂŠe                         #
#                1 = Erreur ligne non traitĂŠe                               #
#     GMESSAGE: Contient le texte de l'erreur (ERRCOD=1-45)                 #
#                      ou de la derniĂ¨re erreur recontrĂŠe (ERRCOD=99)       #
#############################################################################

#####################################################
# Gestion des commandes Ă  partir du plan de travail #
#####################################################
$MGT_POH1
If dim(I_DEPART)<1  Local Integer I_DEPART : I_DEPART=0 : Endif
Call MANAGEMENT_POH1(I_DEPART)
Return

#----- Call pour ĂŠviter l'ĂŠcrasement des locales du TRTX3GLOB -----#
Subprog MANAGEMENT_POH1(I_DEPART)
Variable Integer I_DEPART
Local Integer  I, J, K, RETOUR, OUVFICFLG, ISITE
Local Shortint SAVNOLIGN, NOL, WREVNUM, WLINNBR, WCLELINNBR, WFBULINNBR
Local Decimal  MT, WTOTORD, WTTVORD, WMT1, WMT2, WQT1, QTY
Local Decimal  WTOTQTYPUU, WTOTQTYWEU, WTOTQTYVOU
Local Char     SYMBOL2(30), CLEFIC(33),   WMSG(90),  WCUR(GLONCUR)
Local Shortint TARFLG,      SIGN,         NBRGR,     ORIAPPEL
Local Char     WVACBPR(3),  VAT(GLONVAT)(3),   SECTION(GLONCCE), WVCRNUM(GLONVCR)
# Issue 71069 - 2013-08-23 by SR : PJT
Local Char     CCELIG(200), CCEPSD(200), WPJT(GLONPJT)
Local Libelle  WLINPURTYP
Local Char     WITMDES(GLONDES), WITMDES1(GLONDES)
Local Char     WLINTEX(GLONTXC), WLINTEXPSD(GLONTXC)
Local Decimal  QTE2, MT1, MT2, DISCRGVAL(0..8), WORDNOT, WORDATI
Local Integer  OK, STAT, STA
Local Char     WGRPDEB(GLONVCR)
Local Char     SAV_GABREV(5) : [L]SAV_GABREV=GABREV : GABREV="POH"
#--- Zones inter-sites
Local Integer  WBETFCY, WBETCPY    : # inter-site et inter-soc
Local Char     WBPCORD   (GLONBPC) : # numĂŠro client
Local Char     WSALFCY   (GLONFCY) : # site de vente
Local Char     WORDFCY   (GLONFCY) : # site de commande
Local Char     WLINSTOFCY(GLONFCY) : # site d'expĂŠdition
Local Char     WFINRSP   (GLONFCY) : # site de facturation
Local Char     WBPCINV   (GLONBPC) : # client facture
Local Integer  WDME, WSOHCAT       : # commande complĂ¨te - type de commande
Local Libelle  WPRIFLG             : # indicateur prix modifiĂŠ
# Issue 87834 - 2013-02-21 by SR
Local Decimal  WNETPRI             : # pour rupture sur prix
# Issue X3-55891 - 2018-09-28 by SR : DĂŠclinaison par site
Local  Integer  WITMBPS, WRETOUR
Local  Integer  SAV_GIMPORT          : SAV_GIMPORT=GIMPORT
#----
Raz GMESSAGE
SAVNOLIGN=nolign : nolign=1
ORIAPPEL=1
#----- Ouverture fichier trace si nĂŠcessaire -----#
If ([M:PMG]TRAFLG=2 & GTRACE="") | ([M:PMG]MAJCOD="C" & GTRACE="")
  Call OUVRE_TRACE(mess(14,197,1)) From LECFIC : GPURTRACE=1
Endif
#----- Ouverture tables si nĂŠcessaire -----#
If clalev([F:POH]) =0 : Local File PORDER     [POH]  : Endif
If clalev([F:POP]) =0 : Local File PORDERP    [POP]  : Endif
If clalev([F:POQ]) =0 : Local File PORDERQ    [POQ]  : Endif
If clalev([F:BPS]) =0 : Local File BPSUPPLIER [BPS]  : Endif
If clalev([F:BPR]) =0 : Local File BPARTNER   [BPR]  : Endif
If clalev([F:BPR2])=0 : Local File BPARTNER   [BPR2] : Endif
If clalev([F:BPA]) =0 : Local File BPADDRESS  [BPA]  : Endif
If clalev([F:MVS]) =0 : Local File BPSUPPMVT  [MVS]  : Endif
If clalev([F:ITM]) =0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITP]) =0 : Local File ITMBPS     [ITP]  : Endif
If clalev([F:ITS]) =0 : Local File ITMSALES   [ITS]  : Endif
If clalev([F:ITV]) =0 : Local File ITMMVT     [ITV]  : Endif
If clalev([F:ITF]) =0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:FCY]) =0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:PSH]) =0 : Local File PREQUIS    [PSH]  : Endif
If clalev([F:PSD]) =0 : Local File PREQUISD   [PSD]  : Endif
If clalev([F:PSO]) =0 : Local File PREQUISO   [PSO]  : Endif
If clalev([F:ORD]) =0 : Local File ORDERS     [ORD]  : Endif
If clalev([F:TCU]) =0 : Local File TABCUR     [TCU]  : Endif
If clalev([F:TUN]) =0 : Local File TABUNIT    [TUN]  : Endif
If clalev([F:TCA]) =0 : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:ITG]) =0 : Local File ITMCATEG   [ITG]  : Endif
If clalev([F:TCY]) =0 : Local File TABCOUNTRY [TCY]  : Endif
If clalev([F:TCO]) =0 : Local File TABCOEFF   [TCO]  : Endif
If clalev([F:TUV]) =0 : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:PPK]) =0 : Local File PPRICLINK  [PPK]  : Endif
If clalev([F:PPC]) =0 : Local File PPRICCONF  [PPC]  : Endif
If clalev([F:PER]) =0 : Local File PERIOD     [PER]  : Endif
If clalev([F:CAC]) =0 : Local File GACCCODE   [CAC]  : Endif
If clalev([F:GAG]) =0 : Local File GAUTACEF   [GAG]  : Endif
If clalev([F:GAC]) =0 : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:PPR]) =0 : Local File PPREASON   [PPR]  : Endif
If clalev([F:CAL]) =0 : Local File CPTANALIN  [CAL]  : Endif # Issue 80724 - 2012-03-14 by MUARN
If clalev([F:ITPF])=0 : Local File ITMBPSFCY  [ITPF] : Endif # Issue X3-55891 - 2018-09-13 by SR
#----- Ouverture fichiers pour inter-sites / inter-sociĂŠtĂŠs -----#
If GMODU(5)=2 : # Si module Ventes prĂŠsent
  If !clalev([M:SORW])  Local Mask SORW      [SORW]  : Endif
  If !clalev([F:BPC])   Local File BPCUSTOMER [BPC]  : Endif
  If !clalev([F:ITS])   Local File ITMSALES   [ITS]  : Endif
  If !clalev([F:BPD])   Local File BPDLVCUST  [BPD]  : Endif
  If !clalev([F:SOH])   Local File SORDER     [SOH]  : Endif
  If !clalev([F:SOP])   Local File SORDERP    [SOP]  : Endif
  If !clalev([F:SOQ])   Local File SORDERQ    [SOQ]  : Endif
Endif
#----- Ouverture du fichier des opĂŠrations si module GPAO prĂŠsent -----#
If GMODU(8)=2
  If !clalev([F:MFO])   Local File MFGOPE     [MFO]  : Endif
Endif
#-----
If GMODU(2)=1 : # Compta
  Local File BALANA, BUD, BUDPAR
Endif
#-----
If !clalev([F:ITFY]) Link [ITF] With [FCY] FCY0=[F:ITF]STOFCY As [ITFY] : Endif
#----- Ouverture masques si nĂŠcessaire -----#
If !clalev([M:ORDK])  Local Mask ORDK       [ORDK] : Endif
If !clalev([M:SBCK])  Local Mask SBCK       [SBCK] : Endif
If !clalev([M:SCOK])  Local Mask SCOK       [SCOK] : Endif
#----- ContrĂ´le que la structure tarif par dĂŠfaut existe -----#
STAT=0
If clalev([F:PRS])=0 Local File PRICSTRUCT [PRS] : OUVFICFLG=1 : Endif
Read [PRS] PRS0=2;""
If fstat
  GMESSAGE=mess(81,199,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=4  : Goto FIN_MAJ_POH1
Endif
If OUVFICFLG=1 Close Local File [PRS] : Raz OUVFICFLG : Endif
#----- Chargement des paramĂ¨tres par dĂŠfaut de la gestion tarif -----#
Raz GPLISTC
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
#----- Appel du point d'entrĂŠe PECBESOINS pour conversion qtĂŠs en unitĂŠ physique -----#
Local Char     ABREV(4) : [L]ABREV="PMG"
Local Shortint TRAIT    : [L]TRAIT=5
Local Decimal  RMNQTY
For I=0 To [M:PMG]NBLIG-1
  If [M:PMG]EXTSTUQTY(I)=0
    Call PCAL_QTY ([M:PMG]EXTPUUQTY(I),[M:PMG]PUU(I),[L]RMNQTY,
&           [M:PMG]STU(I),[M:PMG]ITMREF(I),[M:PMG]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
  Else
    [L]RMNQTY=[M:PMG]EXTSTUQTY(I)
  Endif
  #-----
  Gosub POINT_PECBESOINS From TRTACHMGT1
  #-----
  [M:PMG]EXTSTUQTY(I)=[L]RMNQTY
  Call PCAL_QTY ([M:PMG]EXTSTUQTY(I),[M:PMG]STU(I),[M:PMG]EXTPUUQTY(I),
&           [M:PMG]PUU(I),[M:PMG]ITMREF(I),[M:PMG]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
Next I
# Issue X3-55891 - 2018-10-01 by SR : Pour avoir tous les messages dans la trace
GIMPORT = 1
#----- SĂŠlection du traitement demandĂŠ -----#
Default Mask [PMG]
Case [M:PMG]MAJCOD
  When "C"     : Gosub CREATION_POH1
  When "M"     : Gosub MODIFICATION_POH1
  When "A"     : Gosub SUPPRESSION_POH1
  When "S"     : Gosub SOLDE_POH1
  When Default : GMESSAGE=mess(227,197,1) : Call ECR_TRACE(1) : [M:PMG]ERRCOD=5
Endcase
$FIN_MAJ_POH1
#----- DĂŠblocage logique entĂŞte cde si nĂŠcessaire -----#
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
nolign=SAVNOLIGN
GABREV=[L]SAV_GABREV
# Issue X3-55891 - 2018-09-28 by SR : DĂŠclinaison par site
GIMPORT=SAV_GIMPORT
End

#############################################################################
# CrĂŠation de lignes de commande Ă  partir d'une ou plusieurs "POS" ou "POP" #
#############################################################################
$CREATION_POH1
#----- Verification et correction des champs [M:PMG]ORDFCY -----#
For I=I_DEPART To [M:PMG]NBLIG-1
  Read [FCY] FCY0=[M:PMG]STOFCY(I) : If fstat  Raz [F:FCY] : Endif
  GBIDC2=[F:FCY]LEGCPY
  If [M:PMG]ORDFCY(I)=""  [M:PMG]ORDFCY(I)=[M:PMG]PSHFCY : Endif
  Read [FCY] FCY0=[M:PMG]ORDFCY(I) : If fstat  Raz [F:FCY] : Endif
  If  [F:FCY]PURFLG<>2 | [F:FCY]LEGCPY<>GBIDC2
    Call GETFCYDEF([M:PMG]ORDFCY(I),"[F:FCY]PURFLG=2 & [F:FCY]LEGCPY=GBIDC2") From TRTX3
  Endif
Next I
#-----
If clalev([F:PWO]) =0 : Local File PWRKORDERS [PWO]  : Endif
#VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
If !clalev([F:PWO0])   Local File PWRKORDERS   [PWO0] : Endif
If clalev([M:POI1])=0 : Local Mask POI1       [POI1] : Endif
#----------------------------------------------------------------------#
# Point d'entrĂŠe ECLBESOINS pour modifier la gestion des regroupements #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrĂŠe :                        #
# La classe [M:PMG]                                                    #
# FOURN     : NumĂŠro du fournisseur  (non utilisĂŠ)                     #
# REFART    : RĂŠfĂŠrence de l'article (non utilisĂŠ)                     #
# WSRTFLG   : Indicateur de tri (0=Tri Ă  faire,  1=Tri effectuĂŠ)       #
# TRAIT     : Code traitement                                          #
#             1 = Prise en compte besoins depuis commandes classiques  #
#             2 = Prise en compte besoins depuis plan de l'acheteur    #
#             3 = Prise en compte besoins depuis les plans d'appro     #
# -------------------------------------------------------------------- #
# Variable modifiable par le point d'entrĂŠe :                          #
# ECLAT_PSH : Eclatement par demandes d'achat     (1=Non / 2=Oui)      #
# ECLAT_DAT : Eclatement par dates de besoin      (1=Non / 2=Oui)      #
# ECLAT_PJT : Eclatement par codes affaire        (1=Non / 2=Oui)      #
# ECLAT_LPT : Eclatement par type d'achat         (1=Non / 2=Oui)      #
# ECLAT_CCE : Eclatement par sections analytiques (1=Non / 2=Oui)      #
# ECLAT_DES : Eclatement par dĂŠsignation article  (1=Non / 2-4=Oui)    #
#               2 = Oui, avec dĂŠsignation traduite ITMDES              #
#               3 = Oui, avec dĂŠsignation standard ITMDES1             #
#               4 = Oui, avec code texte ligne LINTEX                  #
# ECLAT_PRI : Eclatement par prix si TRAIT = 3    (1=Non / 2=Oui)      #
#----------------------------------------------------------------------#
Local Char    FOURN(GLONBPS), REFART(GLONITM)
Local Libelle WSRTFLG   : WSRTFLG=0
Local Libelle TRAIT     : TRAIT=3
Local Libelle ECLAT_PSH : ECLAT_PSH=1
Local Libelle ECLAT_DAT : ECLAT_DAT=1
Local Libelle ECLAT_PJT : ECLAT_PJT=2
Local Libelle ECLAT_LPT : ECLAT_LPT=2
Local Libelle ECLAT_CCE : ECLAT_CCE=2
Local Libelle ECLAT_DES : ECLAT_DES=2
# Issue 87834 - 2013-02-21 by SR
Local Libelle ECLAT_PRI : ECLAT_PRI=1
Gosub POINT_ECLBESOINS From TRTACHCDE1
If find([M:PMG]WIPTYP(0),4,13)
  ECLAT_CCE=2   : # Provoque la rupture Ă  chaque ligne pour les SCx ou EOx
Endif
#VPO 25/01/11 70999 un art ss-traitĂŠ peut aussi ĂŞtre achetĂŠ via POS (cas 92,93,98,96)
# il faut mettre les lignes normales Ă  la fin donc ajout tri sur WIPTYP desc
If !WSRTFLG
# Issue 71276 - 2015-03-02 by SR : Versions
  If dim([M:PMG]ECCVALMAJ) > 0
      If ECLAT_DAT>1
        If ECLAT_PSH>1 | (ECLAT_CCE>1 & ECLAT_PJT<2)
          #---- Tri du tableau picking par article, fourniss, site, date, no DA et affaire ----#
          Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                              [M:PMG]ORDFCY(indice),
&                                              [M:PMG]SOHNUM(indice),
&                                              [M:PMG]ITMREF(indice),
&                                              [M:PMG]ECCVALMAJ(indice),
&                                              [M:PMG]ECCVALMIN(indice),
&                                              [M:PMG]BPRNUM(indice),
&                                              [M:PMG]STOFCY(indice),
&                                              [M:PMG]ENDDAT(indice),
&                                              [M:PMG]VCRNUM(indice),
&                                              [M:PMG]PJT(indice),
&                                              [M:PMG]VCRLIN(indice)
       Else
         #---- Tri du tableau picking par article, fournisseur, site, date et affaire ----#
        Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                              [M:PMG]ORDFCY(indice),
&                                              [M:PMG]SOHNUM(indice),
&                                              [M:PMG]ITMREF(indice),
&                                              [M:PMG]ECCVALMAJ(indice),
&                                              [M:PMG]ECCVALMIN(indice),
&                                              [M:PMG]BPRNUM(indice),
&                                              [M:PMG]STOFCY(indice),
&                                              [M:PMG]ENDDAT(indice),
&                                              [M:PMG]PJT(indice),
&                                              [M:PMG]VCRNUM(indice),
&                                              [M:PMG]VCRLIN(indice)
        Endif
     Elsif ECLAT_PSH>1
        #----- Tri du tableau de picking par article, fourniss, site, no DA et affaire -----#
        Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]ECCVALMAJ(indice),
&                                            [M:PMG]ECCVALMIN(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]PJT(indice),
&                                            [M:PMG]VCRLIN(indice)
     Elsif ECLAT_PJT>1 & ECLAT_CCE<2
        #----- Tri du tableau de picking par article, fourniss, site et affaire -----#
       Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]ECCVALMAJ(indice),
&                                            [M:PMG]ECCVALMIN(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]PJT(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
     Elsif ECLAT_CCE>1 & ECLAT_PJT<2
       #----- Tri du tableau de picking par article, fourniss, site et no DA -----#
      #VPO 07/01/11 70494 correct: remplace [M:PMG]VCRLIN(INFICE) par [M:PMG]VCRLIN(indice)
       Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]ECCVALMAJ(indice),
&                                            [M:PMG]ECCVALMIN(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
     Elsif ECLAT_PJT<2
       #----- Tri du tableau picking par article, type ordre, fourniss, site et date -----#
       Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]ECCVALMAJ(indice),
&                                            [M:PMG]ECCVALMIN(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]ENDDAT(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
      Else
       #----- Tri du tableau picking par article, type ordre, fourniss, site et affaire -----#
       Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]ECCVALMAJ(indice),
&                                            [M:PMG]ECCVALMIN(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]PJT(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
     Endif
   #pas de version
  Else
    If ECLAT_DAT>1
      If ECLAT_PSH>1 | (ECLAT_CCE>1 & ECLAT_PJT<2)
        #---- Tri du tableau picking par article, fourniss, site, date, no DA et affaire ----#
        Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                              [M:PMG]ORDFCY(indice),
&                                              [M:PMG]SOHNUM(indice),
&                                              [M:PMG]ITMREF(indice),
&                                              [M:PMG]BPRNUM(indice),
&                                              [M:PMG]STOFCY(indice),
&                                              [M:PMG]ENDDAT(indice),
&                                              [M:PMG]VCRNUM(indice),
&                                              [M:PMG]PJT(indice),
&                                              [M:PMG]VCRLIN(indice)
      Else
       #---- Tri du tableau picking par article, fournisseur, site, date et affaire ----#
       Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                              [M:PMG]ORDFCY(indice),
&                                              [M:PMG]SOHNUM(indice),
&                                              [M:PMG]ITMREF(indice),
&                                              [M:PMG]BPRNUM(indice),
&                                              [M:PMG]STOFCY(indice),
&                                              [M:PMG]ENDDAT(indice),
&                                              [M:PMG]PJT(indice),
&                                              [M:PMG]VCRNUM(indice),
&                                              [M:PMG]VCRLIN(indice)
     Endif
   Elsif ECLAT_PSH>1
     #----- Tri du tableau de picking par article, fourniss, site, no DA et affaire -----#
     Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]PJT(indice),
&                                            [M:PMG]VCRLIN(indice)
    Elsif ECLAT_PJT>1 & ECLAT_CCE<2
     #----- Tri du tableau de picking par article, fourniss, site et affaire -----#
      Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]PJT(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
    Elsif ECLAT_CCE>1 & ECLAT_PJT<2
      #----- Tri du tableau de picking par article, fourniss, site et no DA -----#
      #VPO 07/01/11 70494 correct: remplace [M:PMG]VCRLIN(INFICE) par [M:PMG]VCRLIN(indice)
     Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
    Elsif ECLAT_PJT<2
      #----- Tri du tableau picking par article, type ordre, fourniss, site et date -----#
     Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]ENDDAT(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
   Else
     #----- Tri du tableau picking par article, type ordre, fourniss, site et affaire -----#
      Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]WIPTYP(indice) *(-1),
&                                            [M:PMG]ORDFCY(indice),
&                                            [M:PMG]SOHNUM(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]PJT(indice),
&                                            [M:PMG]VCRNUM(indice),
&                                            [M:PMG]VCRLIN(indice)
    Endif
  Endif
Endif
$TR_CREATION
# Issue X3-55891 - 2018-09-13 by SR : DĂŠclinaison par site
Raz [F:ITM], [F:ITP], [M:POI1], [F:ITPF]
[M:POI1]USR=GUSER
[M:POI1]PRONUM=adxuid(2)
If [M:PMG]REQUSR<>""
  [M:POI1]BUY=[M:PMG]REQUSR
Else
  [M:POI1]BUY=GUSER
Endif
If [M:PMG]PSHFCY<>""
  [M:POI1]POHFCY=[M:PMG]PSHFCY
Elsif [M:PMG]ORDFCY(0)<>""
  [M:POI1]POHFCY=[M:PMG]ORDFCY(0)
Else
  [M:POI1]POHFCY=[M:PMG]ORIFCY(0)
Endif
If [M:PMG]PRQDAT<>[0/0/0]
  [M:POI1]ORDDAT=[M:PMG]PRQDAT
Else
  [M:POI1]ORDDAT=date$
Endif
# Issue 71069 - 2015-12-17 by SR : PJT
If [M:PMG]PJTH <> "" : [M:POI1]PJTH = [M:PMG]PJTH : Endif

If [M:PMG]TARGRP=2 [M:POI1]TARGRP=2 Else [M:POI1]TARGRP=1 : Endif
#----- RĂŠcupĂŠration des options d'impression -----#
[M:POI1]PRTFLG=max([M:PMG]PRTFLG,1) : # Si non renseignĂŠ, pas d'impression !
[M:POI1]DOCNAM=[M:PMG]DOCNAM
[M:POI1]PRTCOD=[M:PMG]PRTCOD
#-----
# 106430.sn - Purchase planning - carry container info over to PO
[M:POI1]TCTRNUM   = [M:PMG]TCTRNUM
[M:POI1]TCTRQTY   = [M:PMG]TCTRQTY
[M:POI1]WEICAP    = [M:PMG]WEICAP
[M:POI1]VOLCAP    = [M:PMG]VOLCAP
[M:POI1]ORDMAXAMT = [M:PMG]ORDMAXAMT
# 106430.en
Raz NOL, WORDFCY
Call DEBTRANS From GLOCK
Trbegin [PWO]
  Raz [M:POI1]PRHFCY(NOL),[M:POI1]FCYADD(NOL), [M:POI1]QTYSTU(NOL), [F:PWO]
  [M:POI1]RETRCPDAT(NOL)=GHIDATE
  nolign=NOL+1
  [M:POI1]POICOU+=1 : [M:POI1]POILIN(NOL)=[M:POI1]POICOU
  [F:PWO]PRONUM = [M:POI1]PRONUM
  [F:PWO]CODFNC = "POI"
  [F:PWO]LINNUM = [M:POI1]POILIN(NOL)
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO0]=[F:PWO]
  For I=I_DEPART To [M:PMG]NBLIG-1
    #----- Traitement des "POS" "POP" "SOF" "SCF" "TRS" "TRP" "EOF" uniquement -----#
    If ([M:PMG]WIPTYP(I)<>2  | [M:PMG]WIPSTA(I)<2)  &
&      ([M:PMG]WIPTYP(I)<>1  | [M:PMG]WIPSTA(I)<>1) &
&      ([M:PMG]WIPTYP(I)<>7  | [M:PMG]WIPSTA(I)<2)  &
&       [M:PMG]WIPTYP(I)<>4                         &
&       [M:PMG]WIPTYP(I)<>13                        &
&       [M:PMG]WIPNUM(I)<>""
      GMESSAGE=mess(219,197,1) : # Type d'ordre non traitĂŠ !
      Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
    Endif
    #----- Chargement site de commande Ă  la ligne si nĂŠcessaire -----#
    If [M:PMG]ORDFCY(I)=""  [M:PMG]ORDFCY(I)=[M:POI1]POHFCY : Endif
    # FQ 73645 GA 05/2011 ne pas controler ici mais dans SUBPOI
    If [M:PMG]RGRFLG<>4  # Valider ou annuler toute la commande
       #----- ContrĂ´le validitĂŠ des champs -----#
       Call CONTROLE_ZONES(I)
       If GMESSAGE<>""
         [M:PMG]ERRCOD=0 : GOK=1
         Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
       Endif
    Endif
    GRCPFCY=[M:PMG]STOFCY(I) : Gosub CTRL_INTERSITE
    If OK=1 | GMESSAGE<>""
      [M:PMG]ERRCOD=0 : Raz OK : GOK=1
      Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
    Endif
    Gosub CHARG_LIG_CDE : # If GOK<1  Break : Endif
    If GMESSAGE<>""
      [M:PMG]ERRCOD=0
      Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
    Endif
$SUITE_CREATION
  Next I
  If GOK=-1  Goto ROLL_CREATION  Elsif GOK=0  Goto AB_CREATION : Endif
  If [M:POI1]ITMREF(NOL)<>""
    Gosub FIN_CHARG_LIG_CDE From SUBPOIA : Gosub CTL_PURMINQTY
    If GOK=-1  Goto ROLL_CREATION  Elsif GOK=0  Goto AB_CREATION : Endif
    If GERR<>9
      Gosub CHARG_LIG_SUPPLEMENT From TRTACHSCO1
      If GOK=-1  Goto ROLL_CREATION  Elsif GOK=0  Goto AB_CREATION : Endif
    Else
      Raz GERR
    Endif
    [M:POI1]CTLPOICOU=[M:POI1]POILIN(max(NOL,0))
  Endif
Commit
Raz GFCY : # Pour forcer le chargement et le contrĂ´le des paramĂ¨tres
If [M:POI1]NBLIG>0
  Call GENERE_CDE([M:POI1]USR,3,[M:POI1]TARGRP) From TRTACHCDE1
  If GPURTRACE=1  GPURTRACE=2 : Endif
Endif
Gosub EFFAC_PWRKORDERS From SUBPOIA
Return
$ROLL_CREATION
Rollback : Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Gosub EFFAC_PWRKORDERS From SUBPOIA
  Return
Else
  Goto TR_CREATION
Endif
$AB_CREATION
Rollback
Gosub AB_TRANSACTION_MSG
Gosub EFFAC_PWRKORDERS From SUBPOIA
Return

#------------------------------------#
# Chargement de la ligne de commande #
#------------------------------------#
$CHARG_LIG_CDE
#VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
#----- Test si nombre maxi de lignes atteint ! -----#
If dim([M:POI1]ITMREF)<[M:POI1]NBLIG+2
  GMESSAGE=num$([M:POI1]NBLIG)-"[M:POI1]"-mess(26,100,1) : Return
Endif
#-----
[F:PWO0]WIPTYP = [M:PMG]WIPTYP(I)
[F:PWO0]WIPSTA = [M:PMG]WIPSTA(I)
[F:PWO0]ITMREF = [M:PMG]ITMREF(I)   # FQ 73188 GA 04/2011 pb suite 70999
If [M:PMG]WIPNUM(I)<>""
  [F:PWO0]WIPNUM = [M:PMG]WIPNUM(I)
  [F:PWO0]PSDLIN = 0
Elsif [M:PMG]VCRTYP(I)=14
  [F:PWO0]WIPNUM = [M:PMG]VCRNUM(I)
  [F:PWO0]PSDLIN = [M:PMG]VCRLIN(I)
Else
  [F:PWO0]WIPNUM = ""
  [F:PWO0]PSDLIN = 0
Endif
[F:PWO0]STU    = [M:PMG]STU(I)
[F:PWO0]QTYSTU = [M:PMG]EXTSTUQTY(I)
#----- Lecture article et article-fournisseur si nĂŠcessaire -----#
If [F:ITM]ITMREF<>[M:PMG]ITMREF(I)
  Read [ITM] ITM0=[M:PMG]ITMREF(I) : If fstat Raz [F:ITM] : Endif
  Filter [ITP] Where ITMREF=[M:PMG]ITMREF(I)
  Read [ITP] ITP1 First : If fstat Raz [F:ITP] : Endif
  Filter [ITP]
Endif
If [F:ITP]ITMREF<>[M:PMG]ITMREF(I) | [F:ITP]BPSNUM<>[M:PMG]BPRNUM(I)
  Read [ITP] ITP0=[M:PMG]ITMREF(I);[M:PMG]BPRNUM(I)
  If fstat Raz [F:ITP] : Endif
Endif
If [F:ITP]PUU=""  [F:ITP]PUU=[F:ITM]PUU  : Endif
#----- Lecture BPARTNER si nĂŠcessaire -----#
If [F:BPR]BPRNUM<>[M:PMG]BPRNUM(I)
  Read [BPR] BPR0=[M:PMG]BPRNUM(I)
  If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Chargement des dĂŠsignations article -----#
#Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,WITMDES) From TRTX3
#If WITMDES="" WITMDES=[F:ITM]ITMDES1 : Endif
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#WITMDES1=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES1, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
[F:PWO0]PUU=[F:ITP]PUU
#----- Chargement sections analytiques et affaire -----#
Raz CCEPSD, WPJT, WLINTEXPSD, WLINPURTYP
If [M:PMG]WIPTYP(I)=2 & [M:PMG]WIPSTA(I)=2 & [M:PMG]SOHNUM(I)=""
   #----- Chargement sections analytiques, affaire et type d'achat de la DA pour contrĂ´le -----#
   Read [PSD] PSD0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I)
   If fstat Raz [F:PSD] : Endif
   Read [CAL] CAL0="PSD";0;[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);0;"";1
   If fstat  Raz [F:CAL] : Endif
   If GNBDIE>0
     For J=1 To GNBDIE : CCEPSD+=[F:CAL]CCE(J-1) : Next J
   Endif
   WPJT=[F:PSD]PJT
   If [F:PSD]ITMDES<>""  WITMDES  = [F:PSD]ITMDES  : Endif
   If [F:PSD]ITMDES1<>"" WITMDES1 = [F:PSD]ITMDES1 : Endif
   WLINTEXPSD=[F:PSD]LINTEX
   WLINPURTYP=[F:PSD]LINPURTYP
   # Issue 87834 - 2013-02-21 by SR
   WNETPRI = [F:PSD]NETPRI
Else
   #----- Chargement affaire pour contrĂ´le dans les autres cas -----#
   WPJT=[M:PMG]PJT(I)
   # Issue 87834 - 2013-02-21 by SR
   WNETPRI = 0
Endif
#-- Si prise en compte sous-traitance (SCx ou EOx) rupture Ă  chaque ligne --#
If find([M:PMG]WIPTYP(I),4,13)
  CCEPSD=num$(I) : # Provoque la rupture
Endif
#----- Si 1Ă¨re fois -----#
If [M:POI1]PRHFCY(NOL)=""
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
  Gosub DEB_CHARG_LIG_CDE
  If GMESSAGE<>"" Return : Endif
Endif
#-------------------------------------------------------------------#
# Si rupture, fin de la ligne en cours et passage Ă  une autre ligne #
#-------------------------------------------------------------------#
# Issue 87834 - 2013-02-21 by SR : ajout du tests sur NETPRI
If  [M:POI1]ORDFCY(NOL)   <>[M:PMG]ORDFCY(I)                |
&   [M:POI1]SOHNUM(NOL)   <>[M:PMG]SOHNUM(I)                |
&   [M:POI1]SOPLIN(NOL)   <>[M:PMG]SOPLIN(I)                |
&   [M:POI1]SOQSEQ(NOL)   <>[M:PMG]SOQSEQ(I)                |
&   [M:POI1]ITMREF(NOL)   <>[M:PMG]ITMREF(I)                |
&   [M:POI1]BPSNUM(NOL)   <>[M:PMG]BPRNUM(I)                |
&   [M:POI1]PRHFCY(NOL)   <>[M:PMG]STOFCY(I)                |
&  ([M:POI1]RETRCPDAT(NOL)<>[M:PMG]ENDDAT(I) & ECLAT_DAT>1) |
&  (WVCRNUM               <>[M:PMG]VCRNUM(I) & ECLAT_PSH>1) |
&  ([M:POI1]PJT(NOL)      <>WPJT             & ECLAT_PJT>1) |
&  ([M:POI1]LINPURTYP(NOL)<>WLINPURTYP       & ECLAT_LPT>1) |
&  (CCELIG                <>CCEPSD           & ECLAT_CCE>1) |
&  ([M:POI1]NETPRI(NOL)   <>WNETPRI          & ECLAT_PRI>1) |
&  ([M:POI1]ITMDES(NOL)   <>WITMDES          & ECLAT_DES=2) |
&  ([M:POI1]ITMDES1(NOL)  <>WITMDES1         & ECLAT_DES=3) |
&  ((dim([M:POI1]ECCVALMAJ(NOL))> 0 & [M:POI1]ECCVALMAJ(NOL) <>[M:PMG]ECCVALMAJ(I))) |
&  ((dim([M:POI1]ECCVALMIN(NOL))> 0 & [M:POI1]ECCVALMIN(NOL) <>[M:PMG]ECCVALMIN(I))) |
&  (WLINTEX               <>WLINTEXPSD       & ECLAT_DES=4) | ([M:PMG]RGRFLG=1 & I>0)
  Gosub FIN_CHARG_LIG_CDE From SUBPOIA : Gosub CTL_PURMINQTY
  If GOK=0 | mkstat  Return : Endif
  If GERR<>9
    Gosub CHARG_LIG_SUPPLEMENT From TRTACHSCO1
    If GOK=0 | mkstat  Return : Endif
  Else
    # Issue 83406 - 2012-07-24 by MUARN : message d'erreur si quantitĂŠ infĂŠrieure Ă  qtĂŠ mini
    # raz de GERR dĂŠplacĂŠ aprĂ¨s NEW_LINE
    # Raz GERR
  Endif
  #-----
  # FQ 73188 GA 04/2011 code dĂŠplacĂŠ dans $NEW_LINE et idem SUBPOIA
  Gosub NEW_LINE : If mkstat  Return : Endif
  # Issue 83406 - 2012-07-24 by MUARN : message erreur si quantitĂŠ infĂŠrieure Ă  qtĂŠ mini
  If GERR =9 : Raz GERR : Endif
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
  #-----
  Gosub DEB_CHARG_LIG_CDE
  If GMESSAGE<>"" Return : Endif
Else
  #VPO 18/02/11 71725 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
Endif
#-----
[F:PWO]QTYPUU=[M:PMG]EXTPUUQTY(I)
[M:POI1]STU(NOL)=[F:PWO]STU
#----- Mise Ă  jour qtĂŠ en US -----#
[M:POI1]QTYSTU(NOL)+=[F:PWO]QTYSTU
#----- Mise Ă  jour qtĂŠ besoins pris en compte en US -----#
If [M:PMG]WIPNUM(I)<>""
  Read [ORD] ORD0=[M:PMG]WIPTYP(I);[M:PMG]WIPNUM(I);[M:PMG]ITMREF(I)
  If fstat  Raz [F:ORD] : Endif
Else
  Raz [F:ORD]
Endif
If [F:PWO]PSDLIN<>0
  [M:POI1]RETQTYSTU(NOL)+=[F:PWO]QTYSTU
Else
  [M:POI1]RETQTYSTU(NOL)+=min([F:ORD]RMNEXTQTY,[F:PWO]QTYSTU)
Endif
#-----
If dim(WUOMFLG)>0 & find(WUOMFLG,1,2,3)
  If ECLAT_PSH=9  ECLAT_PSH=1 : Endif
  If ECLAT_CCE=9  ECLAT_CCE=1 : Endif
  WUOMFLG=0
Endif
#----- Mises Ă  jour si DA -----#
If [M:PMG]WIPTYP(I)=2 & [M:PMG]WIPSTA(I)=2 & [M:PMG]SOHNUM(I)="" & [F:PSD]PSHNUM<>""
  #----- Mise Ă  jour des prix, frais, remises et motif si DA -----#
  If NBRGR=0 : # Si premiĂ¨re fois : Chargement cpte, nature, type d'achat, prix ...
    #----- Chargement comptes et sections analytiques -----#
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "PSD",0,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"") From TRTX3CPT
    #-----
    [M:POI1]LINPURTYP(NOL) = [F:PSD]LINPURTYP
    [M:POI1]GROPRI(NOL)    = [F:PSD]GROPRI
    [M:POI1]NETPRI(NOL)    = [F:PSD]NETPRI
    [M:POI1]PRIREN(NOL)    = [F:PSD]PRIREN
    [M:POI1]CUR(NOL)       = [F:PSD]CUR
    [M:POI1]CHGTYP(NOL)    = [F:PSD]CHGTYP
    [M:POI1]CHGCOE(NOL)    = [F:PSD]CHGCOE
    # Issue 71276 - 2015-03-02 by SR : Versions
    If dim([M:POI1]ECCVALMAJ)>0
      [M:POI1]ECCVALMAJ(NOL)    = [F:PSD]ECCVALMAJ
      [M:POI1]ECCVALMIN(NOL)    = [F:PSD]ECCVALMIN
    Endif
    # End issue 71276
    # Issue 112754 - 2016-10-27 by SR : services
    [M:POI1]ITMKND(NOL)    = [F:PSD]ITMKND
    # Issue 90504 - 2013-06-19 by MUARN : ne rĂŠcupĂŠrer les codes VAT que si le fournisseur est renseignĂŠ
    If [F:PSD]BPSNUM<>""
      # Issue 81607 - 2012-04-19 by SR : RĂŠcupĂŠration des codes taxe
      [M:POI1]VAT1(NOL)      = [F:PSD]VAT(0)
      [M:POI1]VAT2(NOL)      = [F:PSD]VAT(1)
      [M:POI1]VAT3(NOL)      = [F:PSD]VAT(2)
      # Issue 87670 - 2013-01-31 by MUARN : RĂŠcupĂŠration codes taxes
      If dim([M:POI1]TAXRCP)>0  : [M:POI1]TAXRCP(NOL)  = [F:PSD]TAXRCP  : Endif
      If dim([M:POI1]TAXISS)>0  : [M:POI1]TAXISS(NOL)  = [F:PSD]TAXISS  : Endif
      If dim([M:POI1]TAXOTH1)>0 : [M:POI1]TAXOTH1(NOL) = [F:PSD]TAXOTH1 : Endif
      If dim([M:POI1]TAXOTH2)>0 : [M:POI1]TAXOTH2(NOL) = [F:PSD]TAXOTH2 : Endif
    Endif
    For J=1 To 9
      If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
        Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With evalue("[F:PSD]DISCRGVAL"+num$(J))
        Assign "[M:POI1]DISCRGREN"+num$(J)+"(NOL)" With evalue("[F:PSD]DISCRGREN"+num$(J))
      Endif
    Next J
    #----- Appel point d'entrĂŠe UOMPSHPOH pour rĂŠcup unitĂŠ de la DA -----#
    Gosub POINT_UOMPSHPOH From TRTACHCDE1
    #----- Lecture BPARTNER si nĂŠcessaire -----#
    If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
      Read [BPR] BPR0=[M:POI1]BPSNUM(NOL)
      If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #----- Lecture BPSUPPLIER si nĂŠcessaire pour nom & structure tarif -----#
    If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
      Read [BPS] BPS0=[M:POI1]BPSNUM(NOL)
      If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
    Endif
    #----- RĂŠcupĂŠration devise, type cours et cours si ligne DA sans fournisseur -----#
    If [F:PSD]BPSNUM=""
      [M:POI1]CUR   (NOL)=[F:BPS]CUR
      [M:POI1]CHGTYP(NOL)=[F:BPS]CHGTYP
      Call COURSITE([M:POI1]CUR(NOL),[F:PSD]PSHFCY,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,
&                   [M:POI1]CHGCOE(NOL),STAT) From TRTDEV
    Endif

    # Issue 89832 GA 05/2013 DA multi-site, Raz de l'adresse ligne prĂŠcĂŠdente avant de changer de site de rcp
    If NOL>0 & [M:POI1]PRHFCY(NOL)<> "" & [M:POI1]PRHFCY(NOL)<>[M:POI1]PRHFCY(NOL-1)
       [M:POI1]FCYADD(NOL)=""
    Endif
    #----- Chargement libellĂŠs colonnes et paramĂ¨tres tarif -----#
    If GPLISTC<>[F:BPS]PLISTC
      GPLISTC=[F:BPS]PLISTC
      Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
      Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
      Call TARIFCHGT(6)                From TRTPRICE
    Endif
    #----- Conversion prix unitaire si unitĂŠs DA et commande diffĂŠrentes -----#
    If [F:PSD]PUU<>[M:POI1]UOM(NOL)
      Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),MT1,[F:PSD]PUU,
&                   [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,MT2) From TRTACHQTE1
      [M:POI1]GROPRI(NOL)=arr([M:POI1]GROPRI(NOL)*MT2,10^-GDECPRI)
      For J=1 To 9
        If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
          If GDISCRGTYP(J-1)=1 & GCLCRUL(J-1)=1
&           MT1=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)*MT2")
            Call ARRDEV(MT1,[M:POI1]CUR(NOL)) From TRTDIV
            Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With MT1
          Endif
          DISCRGVAL(J-1)=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)")
        Endif
      Next J
      If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
      If dim(GCALNETABR)>0  GCALNETABR="[M:POI1]" : Endif
      Call CALNET(2,[F:BPS]PLISTC,[M:POI1]GROPRI(NOL),DISCRGVAL,[M:POI1]QTYPUU(NOL),
&                   [M:POI1]NETPRI(NOL),[M:POI1]CUR(NOL)) From TRTPRICE
    Endif
    #----- Conversion prix si devises DA et commande diffĂŠrentes -----#
    If [M:POI1]CUR(NOL)<>[F:PSD]CUR
      Call CONVERT2([F:PSD]CUR,[M:POI1]CUR(NOL),GLOCALDEV,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,
&                   [M:POI1]GROPRI(NOL),MT2,STAT) From TRTDEV
      [M:POI1]GROPRI(NOL)=arr(MT2,10^-GDECPRI)
      For J=1 To 9
        If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
          If GFMTREM(J-1)="M"
            MT1=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)")
            Call CONVERT([F:PSD]CUR,[M:POI1]CUR(NOL),GLOCALDEV,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,
&                        MT1,MT2,STAT) From TRTDEV
            Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With MT2
          Endif
          DISCRGVAL(J-1)=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)")
        Endif
      Next J
      If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
      If dim(GCALNETABR)>0  GCALNETABR="[M:POI1]" : Endif
      Call CALNET(2,[F:BPS]PLISTC,[M:POI1]GROPRI(NOL),DISCRGVAL,[M:POI1]QTYPUU(NOL),
&                   [M:POI1]NETPRI(NOL),[M:POI1]CUR(NOL)) From TRTPRICE
    Endif
  Else
   # Si plusieurs DA sur la mĂŞme ligne : Effacement prix ...
   # Issue 87834 - 2013-02-21 by SR : ... si pas regroupement mĂŞme prix
     If ECLAT_PRI = 1
        Raz [M:POI1]GROPRI(NOL), [M:POI1]NETPRI(NOL), [M:POI1]PRIREN(NOL)
        Raz [M:POI1]CUR(NOL),    [M:POI1]CHGTYP(NOL), [M:POI1]CHGCOE(NOL)
        # Issue 81607 - 2012-04-19 by SR
        Raz [M:POI1]VAT1(NOL) ,  [M:POI1]VAT2(NOL),   [M:POI1]VAT3(NOL)
        For J=1 To 9
          If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
            Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With 0
            Assign "[M:POI1]DISCRGREN"+num$(J)+"(NOL)" With 0
          Endif
        Next J
     Endif
  Endif
# Issue 112754 - 2016-10-27 by SR : Services depuis les plans
Else
  [M:POI1]ITMKND(NOL) = 1
  If [F:ITM]ITMREF <> [M:PMG]ITMREF(I)
    Read [F:ITM]ITM0 = [M:PMG]ITMREF(I)
    If fstat : Raz [F:ITM] : Endif
  Endif
  If [F:ITM]SCSFLG = 2
     # si besoin de sous-traitance
 #    If find([F:PMG]WIPTYP(I),4,13) : [M:POI1]ITMKND(NOL) = 2 : Else : [M:POI1]ITMKND(NOL) = 3 : Endif
    If find([M:POI1]VCRTYPORI(NOL),36,10) : [M:POI1]ITMKND(NOL) = 2 : Else : [M:POI1]ITMKND(NOL) = 3 : Endif
  Endif
# End issue 112754
Endif
#----- Mise Ă  jour date de rĂŠception -----#
If [M:POI1]RETRCPDAT(NOL)>[M:PMG]ENDDAT(I)
   [M:POI1]RETRCPDAT(NOL)=[M:PMG]ENDDAT(I)
Endif
#-----------------------------------------------------------------------#
# Point d'entrĂŠe TRTZONSPE pour traitement de zones spĂŠcifiques         #
# --------------------------------------------------------------------- #
# Variables utilisables par le point d'entrĂŠe                           #
#                                                                       #
# NOL   : Indice de la ligne en cours de chargement dans l'ĂŠcran POI1   #
# I     : Indice de la ligne en cours de traitement dans l'ĂŠcran PURMGT #
#-----------------------------------------------------------------------#
GPOINT="TRTZONSPE" : Gosub ENTREE From EXEFNC
#---- Ecriture fichier de travail -----#
NBRGR+=1
If [F:PWO]WIPTYP=0  Return : Endif
CLEFIC =num$([F:PWO]PRONUM)-[F:PWO]CODFNC
CLEFIC-=num$([F:PWO]LINNUM)-num$([F:PWO]WIPTYP)-[F:PWO]WIPNUM
WMSG=mess(13,100,1)-"PWRKORDERS"-CLEFIC : # Erreur d'ĂŠcriture sur le fichier ...
If [M:PMG]TRAFLG>2    # FQ 73645 GA 05/2011 trace dĂŠtaillĂŠe
   Call ECR_TRACE("Write [PWO]"-[F:PWO]ITMREF-CLEFIC,0) From GESECRAN
Endif
Write [PWO]
If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Return : Endif
Return

$NEW_LINE
# FQ 73188 GA 04/2011 idem SUBPOIA (code dĂŠplacĂŠ)
#----------------#
# Nouvelle ligne #
#----------------#
status=8 : nolign+=1 : NOL+=1
If dim([M:POI1]ITMREF)<[M:POI1]NBLIG+2
  GMESSAGE=num$([M:POI1]NBLIG)-"[M:POI1]"-mess(26,100,1) : Return
Endif
[M:POI1]POICOU+=1 : [M:POI1]POILIN(NOL)=[M:POI1]POICOU
[F:PWO0]LINNUM=[M:POI1]POILIN(NOL)    # FQ 73188 GA 04/2011 avant [F:PWO]LINNUM
Raz [M:POI1]QTYSTU(NOL), [M:POI1]LINFLG(NOL)
[M:POI1]RETRCPDAT(NOL) = GHIDATE
# FQ 73188 GA 04/2011 idem SUBPOIA (lignes ajoutĂŠes car ceci n'etait pas fait ici)
#----- reprise valeurs ligne prĂŠcĂŠdente -----#
# Issue 83406 - 2012-07-24 by MUARN : erreur si quantitĂŠ infĂŠrieur Ă  quantitĂŠ mini
#contrĂ´le de GERR
If GERR <>9
  [M:POI1]PRHFCY   (NOL)=[M:POI1]PRHFCY   (NOL-1)
  [M:POI1]FCYADD   (NOL)=[M:POI1]FCYADD   (NOL-1)
  [M:POI1]USEPLC   (NOL)=[M:POI1]USEPLC   (NOL-1)
  [M:POI1]PJT      (NOL)=[M:POI1]PJT      (NOL-1)
  [M:POI1]BPSNUM   (NOL)=[M:POI1]BPSNUM   (NOL-1)
  [M:POI1]LINSTOFCY(NOL)=[M:POI1]LINSTOFCY(NOL-1)
  [M:POI1]EXTRCPDAT(NOL)=[M:POI1]EXTRCPDAT(NOL-1)
  [M:POI1]CUR      (NOL)=[M:POI1]CUR      (NOL-1)
  [M:POI1]CHGTYP   (NOL)=[M:POI1]CHGTYP   (NOL-1)
  [M:POI1]CHGCOE   (NOL)=[M:POI1]CHGCOE   (NOL-1)
  [M:POI1]SALFCY   (NOL)=[M:POI1]SALFCY   (NOL-1)
  [M:POI1]BPCORD   (NOL)=[M:POI1]BPCORD   (NOL-1)
  [M:POI1]BPCINV   (NOL)=[M:POI1]BPCINV   (NOL-1)
  [M:POI1]INVFCY   (NOL)=[M:POI1]INVFCY   (NOL-1)
  [M:POI1]DME      (NOL)=[M:POI1]DME      (NOL-1)
  [M:POI1]BETFCY   (NOL)=[M:POI1]BETFCY   (NOL-1)
  [M:POI1]BETCPY   (NOL)=[M:POI1]BETCPY   (NOL-1)
  [M:POI1]ORIFCY   (NOL)=[M:POI1]ORIFCY   (NOL-1)
  [M:POI1]SOHCAT   (NOL)=[M:POI1]SOHCAT   (NOL-1)
  [M:POI1]LINBUY   (NOL)=[M:POI1]LINBUY   (NOL-1)
  If !find([M:POI1]VCRTYPORI(NOL-1),36,10)      # Issue 88156 GA 03/2013 sauf ss-traitance
     [M:POI1]ORDFCY   (NOL)=[M:POI1]POHFCY
  Else
     [M:POI1]ORDFCY   (NOL)=[M:POI1]ORDFCY(NOL-1)
     [M:POI1]RETRCPDAT(NOL)=[M:POI1]RETRCPDAT(NOL-1) # Issue 88261 GA 03/2013
  Endif
Endif
Return

#---------------------------------#
# DĂŠbut chargement ligne commande #
#---------------------------------#
$DEB_CHARG_LIG_CDE
[M:POI1]CUR(NOL)      = ""
[M:POI1]CHGTYP(NOL)   = 0
[M:POI1]CHGCOE(NOL)   = 0
[M:POI1]BETFCY(NOL)   = WBETFCY
[M:POI1]BETCPY(NOL)   = WBETCPY
[M:POI1]BPCORD(NOL)   = WBPCORD
[M:POI1]SALFCY(NOL)   = WSALFCY
[M:POI1]LINSTOFCY(NOL)= WLINSTOFCY
[M:POI1]DME(NOL)      = WDME
[M:POI1]SOHCAT(NOL)   = WSOHCAT
[M:POI1]INVFCY(NOL)   = WFINRSP
[M:POI1]BPCINV(NOL)   = WBPCINV
If WPJT="" WPJT=[M:PMG]PJT(I) : Endif
[M:POI1]ITMREF(NOL)   = [M:PMG]ITMREF(I)
# Issue 71276 - 2015-03-02 by SR : Versions
If dim([M:POI1]ECCVALMAJ)> 0
  [M:POI1]ECCVALMAJ(NOL) = [M:PMG]ECCVALMAJ(I)
  [M:POI1]ECCVALMIN(NOL) = [M:PMG]ECCVALMIN(I)
Endif
# End issue 71276
If [M:POI1]PRHFCY(NOL) <> [M:PMG]STOFCY(I) : [M:POI1]FCYADD(NOL)="" : Endif : # GH 12/11/2014 bug 103167
[M:POI1]PRHFCY(NOL)   = [M:PMG]STOFCY(I)
[M:POI1]RETRCPDAT(NOL)= [M:PMG]ENDDAT(I)
[M:POI1]SOHNUM(NOL)   = [M:PMG]SOHNUM(I)
[M:POI1]SOPLIN(NOL)   = [M:PMG]SOPLIN(I)
[M:POI1]SOQSEQ(NOL)   = [M:PMG]SOQSEQ(I)
WVCRNUM               = [M:PMG]VCRNUM(I)
CCELIG                = CCEPSD
NBRGR                 = 0
[M:POI1]BPSNUM(NOL)   = [M:PMG]BPRNUM(I)
[M:POI1]ITMDES(NOL)   = WITMDES
[M:POI1]ITMDES1(NOL)  = WITMDES1
WLINTEX               = WLINTEXPSD
[M:POI1]PJT(NOL)      = WPJT
# Issue 87834 - 2013-02-21 by SR
[M:POI1]NETPRI(NOL)   = WNETPRI
[M:POI1]LINPURTYP(NOL)= WLINPURTYP
#-----
[M:POI1]USEPLC(NOL) = [M:PMG]USEPLC
[M:POI1]UOM(NOL)    = [F:PWO]PUU
[M:POI1]PUU(NOL)    = [F:PWO]PUU
[M:POI1]ORDFCY(NOL) = [M:PMG]ORDFCY(I)
#----- Lecture des paramĂ¨tres -----#
If WORDFCY<>[M:POI1]ORDFCY(NOL)
  WORDFCY=[M:POI1]ORDFCY(NOL)
  GFCY   =[M:POI1]ORDFCY(NOL)
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT  : If GFINRSP="" GFINRSP=GFCY : Endif
  Call GLOBVAR(GFCY)   From WWGLOBACH
  #----- VĂŠrification des droits d'accĂ¨s au site -----#
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    If !find(([M:POI1]ORDFCY(NOL)),GUSRFCY(1..GNBAUZ))
      GMESSAGE=[M:POI1]ORDFCY(NOL)-mess(2,104,1) : Return
    Endif
  Endif
Endif
#----- Suite chargement pour sous-traitance -----#
If find([F:PWO]WIPTYP,4,13)
  Gosub CHARG_LIG_STT From TRTACHSCO1
Else
  [M:POI1]LINTYP(NOL)=1  : # Ligne classique (indĂŠpendante)
Endif
#--------------------------------------------------------------------------------#
# Point d'entrĂŠe ALIUOMPOH pour alimentation unitĂŠ de commande (conditionnement) #
# ------------------------------------------------------------------------------ #
# Variables utilisables par le point d'entrĂŠe                                    #
#                                                                                #
# NOL   : Indice de la ligne en cours de chargement dans l'ĂŠcran POI1            #
# I     : Indice de la ligne en cours de traitement dans l'ĂŠcran PURMGT          #
#                                                                                #
# [M:POI1]UOM(NOL) : UnitĂŠ de commande modifiable                                #
#--------------------------------------------------------------------------------#
Gosub POINT_ALIUOMPOH
Return

$POINT_ALIUOMPOH
#--------------------------------------------------------------------------------#
# Point d'entrĂŠe ALIUOMPOH pour alimentation unitĂŠ de commande (conditionnement) #
# ------------------------------------------------------------------------------ #
# Variables utilisables par le point d'entrĂŠe                                    #
#                                                                                #
# NOL   : Indice de la ligne en cours de chargement dans l'ĂŠcran POI1            #
# I     : Indice de la ligne en cours de traitement dans l'ĂŠcran PURMGT          #
#                                                                                #
# [M:POI1]UOM(NOL) : UnitĂŠ de commande modifiable                                #
#--------------------------------------------------------------------------------#
GPOINT="ALIUOMPOH" : Gosub ENTREE From EXEFNC
Return



#####################################################################
# Modification d'une ligne de commande Ă  partir d'une "POF" ou "TRF"#
#####################################################################
$MODIFICATION_POH1
I=I_DEPART : Gosub CONTROLE : If [M:PMG]ERRCOD<>0  Return : Endif
Call CONTROLE_ZONES (I)
If GMESSAGE<>"" Call ECR_TRACE(1)  : Return : Endif
GRCPFCY=[M:PMG]STOFCY(I) : Gosub CTRL_INTERSITE
If GMESSAGE<>"" Call ECR_TRACE(1)  : Return : Endif
#----- Modification de la ligne de commande -----#
Gosub MODIF_POH From TRTACHPOH2
If WERR=1
  Gosub AB_TRANSACTION_MSG
Else
  [M:PMG]ERRLIN(I)=0
Endif
#-----
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


############################################################
# Suppression d'une ligne de commande Ă  partir d'une "POF" #
############################################################
$SUPPRESSION_POH1
I=I_DEPART : Gosub CONTROLE : If [M:PMG]ERRCOD<>0  Return : Endif
#----- Suppression de la ligne de commande -----#
Gosub MODIF_POH From TRTACHPOH2
If WERR=1
  Gosub AB_TRANSACTION_MSG
Else
  [M:PMG]ERRLIN(I)=0
Endif
#-----
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


#####################################################################
# Solde d'une ligne ou d'un groupe de lignes (composĂŠ + composants) #
#####################################################################
$SOLDE_POH1
I=I_DEPART : Gosub CONTROLE : If [M:PMG]ERRCOD<>0  Return : Endif
#----- Solde de la ligne de commande -----#
Gosub MODIF_POH From TRTACHPOH2
If WERR=1
  Gosub AB_TRANSACTION_MSG
Else
  [M:PMG]ERRLIN(I)=0
Endif
#-----
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


#---------------------------------------------#
# Messages en cas d'abandon de la transaction #
#---------------------------------------------#
$AB_TRANSACTION_MSG
If WMSG<>"" GMESSAGE=WMSG : Call ECR_TRACE(1) : Endif
WMSG=GMESSAGE
GMESSAGE=mess(157,199,1)  : Call ECR_TRACE(1) : # Transaction abandonnĂŠe
GMESSAGE=WMSG : Raz WMSG
If [M:PMG]ERRCOD=0 [M:PMG]ERRCOD=99 : Endif
Return

#----------------------------------------------------------------------#
# ContrĂ´les avant modification,suppression ou solde d'une ligne de cde #
#----------------------------------------------------------------------#
$CONTROLE
#----- Lecture entĂŞte commande -----#
Read [POH] POH0=[M:PMG]VCRNUM(I)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(I)-mess(359,197,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=11 : Return
Endif
Raz WORDNOT, WORDATI, GAPPFLG
WREVNUM   =[F:POH]REVNUM
WLINNBR   =[F:POH]LINNBR
WFBULINNBR=[F:POH]FBULINNBR
WCLELINNBR=[F:POH]CLELINNBR
WTOTORD   =[F:POH]TOTORD
WTTVORD   =[F:POH]TTVORD
WTOTQTYPUU=[F:POH]TOTLINQTY
WTOTQTYWEU=[F:POH]TOTLINWEU
WTOTQTYVOU=[F:POH]TOTLINVOU
#----- Lecture ligne commande (qtĂŠs) -----#
Read [POQ] POQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(360,197,1)
  Call ECR_TRACE(1)
  [M:PMG]ERRCOD=12 : Return
Endif
[M:PMG]WIPTYP(I)=[F:POQ]WIPTYP
[M:PMG]WIPSTA(I)=[F:POQ]WIPSTA
[M:PMG]WIPNUM(I)=[F:POQ]WIPNUM
[M:PMG]ITMREF(I)=[F:POQ]ITMREF
#----- Lecture ligne commande (prix) -----#
Read [POP] POP0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(360,197,1)
  Call ECR_TRACE(1)
  [M:PMG]ERRCOD=13 : Return
Endif
#----- Modif, suppression ou solde interdits si commande soldĂŠe -----#
If [F:POH]CLEFLG=2
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(47,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=22 : # Commande soldĂŠe
  Return
Endif
#----- Modification ou suppression interdite si ligne soldĂŠe -----#
If [F:POQ]LINCLEFLG=2 & ([M:PMG]MAJCOD="M" | [M:PMG]MAJCOD="A")
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(32,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=23 : # Ligne soldĂŠe
  Return
Endif
#----- Solde impossible si ligne dĂŠjĂ  soldĂŠe -----#
If [F:POQ]LINCLEFLG=2 & [M:PMG]MAJCOD="S"
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(168,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=24 : # Ligne dĂŠjĂ  soldĂŠe
  Return
Endif
#----- Suppression interdite si ligne rĂŠceptionnĂŠe ou facturĂŠe -----#
If ([F:POQ]LINRCPNBR>0 | [F:POQ]LININVNBR>0) & [M:PMG]MAJCOD="A"
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(31,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=25 : # Ligne rĂŠceptionnĂŠe ou facturĂŠe
  Return
Endif
#----- Suppression ligne d'un composant (service) interdite -----#
If [F:POQ]LINTYP=3 & [M:PMG]MAJCOD="A"
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(358,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=25 : # Ligne d'un composant service, ...
  Return
Endif
#----- Suppression d'une ligne de contremarque interdite -----#
If [F:POQ]SOHNUM<>"" & [M:PMG]MAJCOD="A"
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(361,197,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=26 : # Ligne de contremarque, suppression interdite !
  Return
Endif
#----- Chargement des paramĂ¨tres -----#
GCUR=[F:POH]CUR
GFCY=[F:POH]POHFCY
Gosub CHARG_PARAM
If  GPURREV>1 & [M:PMG]REVFLG=2  WREVNUM+=1 : Endif # Issue X3-71652 - 2018-01-23 by SDEM
If GMESSAGE<>"" Call ECR_TRACE(1) : [M:PMG]ERRCOD=27 : Return : Endif

#  Issue X3-71652 - 2018-01-23 by SDEM : begin
#----- Ligne commande rĂŠceptionnĂŠe ou facturĂŠe, modification sans avenant interdite -----#
If ([F:POQ]LINRCPNBR>0 | [F:POQ]LININVNBR>0) & [M:PMG]REVFLG<>2 & GPURREV>1 & [M:PMG]MAJCOD="M"
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(33,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=21 : # Ligne rĂŠceptionnĂŠe ou facturĂŠe sans avenant
  Return
Endif
# Issue X3-71652 - 2018-01-23 by SDEM : end

#----- Blocage logique de l'entĂŞte commande -----#
SYMBOL2="POH"+[M:PMG]VCRNUM(I)
Lock=SYMBOL2
If fstat
  GMESSAGE="$PORDER"-[M:PMG]VCRNUM(I)-mess(10,100,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=37 : Return
Endif
Return

#---------------------------#
# Chargement des paramĂ¨tres #
#---------------------------#
$CHARG_PARAM
Raz GMESSAGE
Call GETCPY(GFCY,"",0,"") From TRTX3CPT  : If GFINRSP="" GFINRSP=GFCY : Endif
Call DEFSITE(GFCY) From TRTACHDEF1
Call GLOBVAR(GFCY) From WWGLOBACH
If GMODU(2)=2
  Call GLOBVAR(GFINRSP) From WWGLOBBUD
Endif
Call DEFBUD("POH",GFCY) From TRTACHDEF1
Call DEFRCPFCY(GFCY)    From TRTACHDEF1
Return

#---------------------------------------#
# Ecriture du message ligne non traitĂŠe #
#---------------------------------------#
$ECR_NON_TRAITEE
WMSG=GMESSAGE
GMESSAGE=num$([M:PMG]WIPTYP(I))-[M:PMG]WIPNUM(I)-[M:PMG]ITMREF(I)-mess(225,197,1)
Call ECR_TRACE(1) : # 9 XXXXXXX XXXXXXX Ligne non traitĂŠe !
If [M:PMG]ERRCOD=0 [M:PMG]ERRCOD=99 : Endif
GMESSAGE=WMSG
Return

#-----------------------------------------#
# Ecriture du fichier trace si nĂŠcessaire #
#-----------------------------------------#
Subprog ECR_TRACE (TRAIT)
Value Integer TRAIT
# Issue X3-55891 - 2018-09-28 by SR : si crĂŠation on force la trace puisqu'on a forcĂŠ son ouverture
If ([M:PMG]TRAFLG=2 | [M:PMG]MAJCOD="C") & GMESSAGE<>""
  Call ECR_TRACE(GMESSAGE,TRAIT) From GESECRAN
  If GPURTRACE=1 GPURTRACE=2 : Endif
Endif
End

#---------------------------------------------#
# ContrĂ´les zones en crĂŠation ou modification #
#---------------------------------------------#
Subprog CONTROLE_ZONES (NOL)
Value Integer NOL
Local Integer WOK
Local Integer WNB : WNB=0 : #VPO 09/12/10 17667
# Issue X3-55891 - 2018-09-13 by SR : DĂŠclinaison par site
Local Integer WITMBPS, WRETOUR
Local Char    WBPSNUM(GLONBPS)
Raz GMESSAGE
#----- Valeur par dĂŠfaut des zones Ă  contrĂ´ler -----#
If [M:PMG]MAJCOD<>"C" : # En modification
  [M:PMG]ITMREF(NOL)=[F:POQ]ITMREF
  [M:PMG]STU(NOL)   =[F:POQ]STU
  [M:PMG]PUU(NOL)   =[F:POQ]PUU
  [M:PMG]BPRNUM(NOL)=[F:POQ]BPSNUM
  If [M:PMG]STOFCY(NOL)=""      [M:PMG]STOFCY(NOL)=[F:POQ]PRHFCY    : Endif
  If [M:PMG]ENDDAT(NOL)=[0/0/0] [M:PMG]ENDDAT(NOL)=[F:POQ]EXTRCPDAT : Endif
  If [M:PMG]EXTPUUQTY(NOL)=0 & [M:PMG]EXTSTUQTY(NOL)=0
    [M:PMG]EXTSTUQTY(NOL)=[F:POQ]QTYSTU
  Endif
Else                  : # En crĂŠation
  If [M:PMG]ITMREF(NOL)=""       : # La rĂŠfĂŠrence article est nĂŠcessaire en crĂŠation
    mkstat=1 : GMESSAGE=mess(107,194,1) : [M:PMG]ERRCOD=28 : End
  Endif
  If [F:ITM]ITMREF<>[M:PMG]ITMREF(NOL)
    Read [ITM] ITM0=[M:PMG]ITMREF(NOL)
    If fstat
      Raz [F:ITM] : mkstat=1     : # Code article inexistant
      GMESSAGE=[M:PMG]ITMREF(NOL)-":"-mess(134,100,1) : [M:PMG]ERRCOD=29 : End
    Endif
    #----- pour rĂŠcupĂŠration du fournisseur si nĂŠcessaire -----#
    # Issue X3-55891 - 2018-10-01 by SR : DĂŠclinaison part site
#    Filter [ITP] Where ITMREF=[M:PMG]ITMREF(NOL)
#    Read [ITP] ITP1 First : If fstat Raz [F:ITP] : Endif
#    Filter [ITP]
  Endif
  If [M:PMG]STOFCY(NOL)<>""
    #----- Le site de rĂŠception doit ĂŞtre un dĂŠpĂ´t -----#
    Read [FCY] FCY0=[M:PMG]STOFCY(NOL)
    If fstat
      Raz [F:FCY] : GMESSAGE=[M:PMG]STOFCY(NOL)-mess(14,14,1) : [M:PMG]ERRCOD=99 : End
    Endif
    If [F:FCY]WRHFLG<>2 & [F:ITM]STOMGTCOD>1
      GMESSAGE=[M:PMG]STOFCY(NOL)-mess(58,199,1) : [M:PMG]ERRCOD=99 : End
    Endif
  Endif
  # Issue X3-55891 - 2018-10-01 by SR : DĂŠclinaison part site
  #If [M:PMG]BPRNUM(NOL)="" [M:PMG]BPRNUM(NOL)=[F:ITP]BPSNUM : Endif
  #If [M:PMG]BPRNUM(NOL)=""
  Call DEFBPSNUM([M:PMG]ITMREF(NOL),[M:PMG]ORIFCY(NOL),[M:PMG]PSHFCY,"",1,WBPSNUM,WITMBPS) From TRTACHDEF1
  If WRETOUR <> 0
     GMESSAGE=[M:PMG]ITMREF(NOL)-mess(69,197,1): [M:PMG]ERRCOD=42 : End : # Pas de fournisseur
  Else
     If [M:PMG]BPRNUM(NOL)="" [M:PMG]BPRNUM(NOL)=WBPSNUM : Endif
     Call CONTROLE("BPS","AB",[M:PMG]BPRNUM(NOL),"",mkstat) From CONTOBJ
     If mkstat  [M:PMG]ERRCOD=45 : End : Endif : # Fournisseur inactif ou prospect
  Endif
  Call CONTROLE("ITM","B",[M:PMG]ITMREF(NOL),"",mkstat) From CONTOBJ
  If mkstat                      : # Article inactif ou non achetĂŠ
    [M:PMG]ERRCOD=30 : End
  Elsif [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
    GMESSAGE=[M:PMG]ITMREF(NOL)-":"-mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
    mkstat=1 : [M:PMG]ERRCOD=30 : End
  Endif
  If [M:PMG]STU(NOL)<>[F:ITM]STU : # UnitĂŠ de stock incorrecte !
    GMESSAGE=[M:PMG]STU(NOL)-mess(228,197,1)-"("+[F:ITM]STU+")"
    [M:PMG]ERRCOD=31 : mkstat=1 : End
  Endif
  If [M:PMG]PUU(NOL)=""
    If [F:ITP]PUU<>"" & [F:ITP]BPSNUM=[M:PMG]BPRNUM(NOL)
      [M:PMG]PUU(NOL)=[F:ITP]PUU
    Else
      [M:PMG]PUU(NOL)=[F:ITM]PUU
    Endif
  Endif
Endif
#----- Calcul quantitĂŠ en UA ou US -----#
If [M:PMG]EXTSTUQTY(NOL)=0
  Call PCAL_QTY ([M:PMG]EXTPUUQTY(NOL),[M:PMG]PUU(NOL),[M:PMG]EXTSTUQTY(NOL),
&           [M:PMG]STU(NOL),[M:PMG]ITMREF(NOL),[M:PMG]BPRNUM(NOL),1,GBIDD1) From TRTACHQTE1
Else
  Call PCAL_QTY ([M:PMG]EXTSTUQTY(NOL),[M:PMG]STU(NOL),[M:PMG]EXTPUUQTY(NOL),
&           [M:PMG]PUU(NOL),[M:PMG]ITMREF(NOL),[M:PMG]BPRNUM(NOL),1,GBIDD1) From TRTACHQTE1
Endif
#----- Test si quantitĂŠs nulles -----#
If [M:PMG]EXTPUUQTY(NOL)=0 & [M:PMG]EXTSTUQTY(NOL)=0
  GMESSAGE=[M:PMG]ITMREF(NOL)-mess(6,194,1) : [M:PMG]ERRCOD=43 : mkstat=1 : End
Endif
#----- ContrĂ´les si modification -----#
If [M:PMG]MAJCOD="M"
  #----- ContrĂ´le article-fournisseur -----#
  # Issue X3-55891 - 2018-09-13 by SR : DĂŠclinaison par site
#  If [F:ITP]ITMREF<>[M:PMG]ITMREF(NOL) | [F:ITP]BPSNUM<>[F:POH]BPSNUM
#    Read [ITP] ITP0=[M:PMG]ITMREF(NOL);[F:POH]BPSNUM
#    If fstat
#      Raz [F:ITP]
#    Elsif [F:ITP]DOUFLG=3 : # Article douteux pour ce fournisseur !
#      GMESSAGE=[M:PMG]ITMREF(NOL)-[F:POH]BPSNUM-mess(9,194,1)
#      [M:PMG]ERRCOD=32 : mkstat=1 : End
#    Endif
  Raz WITMBPS, WRETOUR
  Call CTRL_DOUFLG(1,[M:PMG]ITMREF(NOL),[F:POH]BPSNUM,[M:PMG]STOFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
  # Article douteux bloquant pour ce fournisseur  : On ne fait pas la modification
  If WRETOUR <>0
     mkstat=1
     End
  Endif
  # End issue X3-55891
  Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:PMG]STU(NOL),
&                [M:PMG]ITMREF(NOL),[F:POH]BPSNUM,1,GBIDD2) From TRTACHQTE1
  #----- Test qtĂŠ infĂŠrieure Ă  qtĂŠ minimum d'achat -----#
  #VPO 15/10/10 17730/59532 contrĂ´le selon paramĂ¨tre
  If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
  #If [M:PMG]EXTSTUQTY(NOL)<GBIDD1
  If [M:PMG]EXTSTUQTY(NOL)<GBIDD1 & GPOHMINQTY<3
    GMESSAGE=mess(14,194,1)-num$(GBIDD1)-[M:PMG]STU(NOL)
    If GPOHMINQTY=1
        [M:PMG]ERRCOD=33 : mkstat=1 : End
    Else : #GPOHMINQTY=2
        WOK=2
        Call AVERTIR (GMESSAGE, WOK)From GESECRAN
        If WOK=1
            Raz GMESSAGE
            [M:PMG]ERRCOD=33 : mkstat=1 : End
        Endif
        Raz GMESSAGE
    Endif
  Endif
  #----- Test qtĂŠ infĂŠrieure Ă  qtĂŠ initiale besoins pris en compte si DA -----#
  # Issue 112754 - 2016-11-29 by SR : Services
  If [M:PMG]EXTSTUQTY(NOL)<[F:POQ]RETQTYSTU & [P:POQ]ITMKND<>2 & [F:POQ]LINTYP<2
    If !clalev([F:PSO])  Local File PREQUISO  [PSO] : Endif
    Filter [PSO] Where POHNUM=[F:POQ]POHNUM
&                    & POPLIN=[F:POQ]POPLIN
&                    & POQSEQ=1
    #VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
#    Read [PSO] PSO1 First
#    Filter [PSO]
#    If !fstat
#      GMESSAGE=num$([M:PMG]EXTSTUQTY(NOL))-[F:POQ]STU
#      GMESSAGE-=mess(3,194,1)-num$([F:POQ]RETQTYSTU)-[F:POQ]STU
#      [M:PMG]ERRCOD=34 : mkstat=1 : End
#    Endif
    For [PSO]PSO1
        WNB+=1
    Next
    Filter [PSO]
    If WNB>1
      GMESSAGE=num$([M:PMG]EXTSTUQTY(NOL))-[F:POQ]STU
      GMESSAGE-=mess(3,194,1)-num$([F:POQ]RETQTYSTU)-[F:POQ]STU
      [M:PMG]ERRCOD=34 : mkstat=1 : End
    Endif
  Endif
Endif
End

#----------------------------------------------------------------#
# ContrĂ´le si quantitĂŠ supĂŠrieure ou ĂŠgale Ă  la quantitĂŠ minimun #
#----------------------------------------------------------------#
$CTL_PURMINQTY
Local Integer WOK
# FQ 73645 GA 05/2011 ne pas controler ici mais dans SUBPOI
If dim([M:PMG]RGRFLG)>0 & [M:PMG]RGRFLG=4 : Return Endif # Valider ou annuler toute la commande
# Issue X3-55891 - 2018-09-13 by SR : DĂŠclinaison par sociĂŠtĂŠ
##----- ContrĂ´le article-fournisseur -----#
#If [F:ITP]ITMREF<>[M:POI1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:POI1]BPSNUM(NOL)
#  Read [ITP] ITP0=[M:POI1]ITMREF(NOL);[M:POI1]BPSNUM(NOL)
#  If fstat
#    Raz [F:ITP]
#  Elsif [F:ITP]DOUFLG=3 : # Article douteux pour ce fournisseur !
#    GMESSAGE=[M:POI1]ITMREF(NOL)-[M:POI1]BPSNUM(NOL)-mess(9,194,1)
#    Call ECR_TRACE(0) : Raz GMESSAGE
#  Endif
#Endif
Raz WITMBPS, WRETOUR
# Intersite
If [M:POI1]BETFCY(NOL) = 2 & [M:POI1]BETFCY(NOL) <> 2
  Call CTRL_DOUFLG(2,[M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
Else
  Call CTRL_DOUFLG(1,[M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),[M:POI1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
Endif
If WRETOUR <> 0
  Call ECR_TRACE(1)
  Raz GMESSAGE, mkstat
  Delete [PWO] Where PRONUM=[M:POI1]PRONUM & CODFNC="POI" & LINNUM=[M:POI1]POILIN(NOL)
  If fstat=1
    GLOCK="$PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))
    GOK=-1
  Elsif fstat
    Call RSTA("PWO",num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))) From GLOCK
    WMSG=mess(12,100,1)-"PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))
    GOK=0
  Endif
  Raz [M:POI1]ORDFCY(NOL),[M:POI1]ITMREF(NOL),[M:POI1]QTYUOM(NOL),[M:POI1]QTYPUU(NOL),
&     [M:POI1]QTYSTU(NOL),[M:POI1]LINFLG(NOL),[M:POI1]RETQTYSTU(NOL),[M:POI1]PRHFCY(NOL),
&     [M:POI1]GROPRI(NOL),[M:POI1]NETPRI(NOL),[M:POI1]PRIREN(NOL)
      [M:POI1]NBLIG-=1 : nolign-=1 : NOL-=1
      If GOK=1  GERR=9 : Endif
      Return
Endif
# End issue X3-55891
Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:POI1]PUU(NOL),
&              [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD2) From TRTACHQTE1
#----- Test qtĂŠ infĂŠrieure Ă  qtĂŠ minimum d'achat -----#
#VPO 15/10/10 17730/59532 contrĂ´le selon paramĂ¨tre
If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
# Issue 103546 - 2014-11-14 by MUARN : ne pas contrĂ´ler sur les planning dĂŠjĂ  fait
If find(GFONCTION,"FUNGBENCHA","FUNDBENCHA"): Return : Endif

#If [M:POI1]QTYPUU(NOL)<GBIDD1
If [M:POI1]QTYPUU(NOL)<GBIDD1 & GPOHMINQTY<3
  GMESSAGE =[M:POI1]ITMREF(NOL)-mess(14,194,1)
  GMESSAGE-=num$(GBIDD1)-[M:POI1]PUU(NOL)
  If GPOHMINQTY=1
      Call ECR_TRACE(1) : Raz GMESSAGE
      Delete [PWO] Where PRONUM=[M:POI1]PRONUM & CODFNC="POI" & LINNUM=[M:POI1]POILIN(NOL)
      If fstat=1
        GLOCK="$PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))
        GOK=-1
      Elsif fstat
        Call RSTA("PWO",num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))) From GLOCK
        WMSG=mess(12,100,1)-"PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))
        GOK=0
      Endif
      Raz [M:POI1]ORDFCY(NOL),[M:POI1]ITMREF(NOL),[M:POI1]QTYUOM(NOL),[M:POI1]QTYPUU(NOL),
&     [M:POI1]QTYSTU(NOL),[M:POI1]LINFLG(NOL),[M:POI1]RETQTYSTU(NOL),[M:POI1]PRHFCY(NOL),
&     [M:POI1]GROPRI(NOL),[M:POI1]NETPRI(NOL),[M:POI1]PRIREN(NOL)
      [M:POI1]NBLIG-=1 : nolign-=1 : NOL-=1
      If GOK=1  GERR=9 : Endif
      Return
  Else : #GPOHMINQTY=2
      ##Call ECR_TRACE(0)
      WOK=2
      Call AVERTIR (GMESSAGE, WOK)From GESECRAN
      If WOK=1
          Raz GMESSAGE
          Delete [PWO] Where PRONUM=[M:POI1]PRONUM & CODFNC="POI" & LINNUM=[M:POI1]POILIN(NOL)
          If fstat=1
            GLOCK="$PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))
            GOK=-1
          Elsif fstat
            Call RSTA("PWO",num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))) From GLOCK
            WMSG=mess(12,100,1)-"PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(NOL))
            GOK=0
          Endif
          Raz [M:POI1]ORDFCY(NOL),[M:POI1]ITMREF(NOL),[M:POI1]QTYUOM(NOL),[M:POI1]QTYPUU(NOL),
&         [M:POI1]QTYSTU(NOL),[M:POI1]LINFLG(NOL),[M:POI1]RETQTYSTU(NOL),[M:POI1]PRHFCY(NOL),
&         [M:POI1]GROPRI(NOL),[M:POI1]NETPRI(NOL),[M:POI1]PRIREN(NOL)
          [M:POI1]NBLIG-=1 : nolign-=1 : NOL-=1
          If GOK=1  GERR=9 : Endif
          Return
      Endif
      Raz GMESSAGE
  Endif
Endif
# Issue 78615 - 2011-12-15 by VPO : ajout ctrl QTYUOM nulle
If [M:POI1]QTYUOM(NOL)=0
  WMSG=[M:POI1]ITMREF(NOL)-'/ QTYUOM'-mess(6,194,1)
  GOK=0
Endif
#----- ContrĂ´le tarif Ă  zĂŠro pour commande de contremarque (sauf inter-sites) -----#
If [M:POI1]SOHNUM(NOL)<>"" & ([M:POI1]BETFCY(NOL)<>2 | [M:POI1]BETCPY(NOL)=2)
  # Issue 59217 - 2014-10-17 by MUARN : obligation tarif achat
  #If [M:POI1]GROPRI(NOL)=0 & [M:POI1]PRIREN(NOL)=0 & [M:POI1]NETPRI(NOL)=0
  If [M:POI1]GROPRI(NOL)=0 & [M:POI1]PRIREN(NOL)=0 & [M:POI1]NETPRI(NOL)=0 & GPURCTLPRI0 <> 2
   #----- Erreur si pas de tarif -----#
    WMSG =[M:POI1]SOHNUM(NOL)+"/"+num$([M:POI1]SOPLIN(NOL))
    WMSG+="/"+num$([M:POI1]SOQSEQ(NOL))-mess(67,197,1)-mess(84,197,1)
    GOK=0
    # Issue 59217 - 2014-10-17 by MUARN : obligation tarif achat
    GERR=1
  Endif
Endif
If [M:POI1]SALFCY(NOL)<>""
  Raz GBIDC3, GBIDI3
  #-- X3Suivi 77496 : Commandes achat/vente inter-sociĂŠtĂŠs dĂŠsynchronisĂŠes --#
  Call C_QTY(1,[M:POI1]BPCORD(NOL), [M:POI1]ITMREF(NOL),[M:POI1]PUU(NOL),GBIDC3,
&            GBIDI3, GBIDI3,[M:POI1]QTYPUU(NOL)) From TRTVENISOC
  If GMESSAGE<>""
    GMESSAGE=mess(74,187,1)-":"-GMESSAGE
    Call ECR_TRACE(0) : Raz GMESSAGE
  Endif
Endif
Return

#-------------------------------------------------#
# Recherche et ContrĂ´le si on est en inter-site   #
# Positionnement de GFCY avec le site de commande #
# en crĂŠation                                     #
# en modif ou suppression appel des sous-pro de   #
# contrĂ´le vente                                  #
#-------------------------------------------------#
$CTRL_INTERSITE
Raz GMESSAGE
If [M:PMG]MAJCOD<>"C"
  If [F:POH]POHNUM<>[F:POQ]POHNUM
    Read [POH]POH0=[F:POQ]POHNUM
    If fstat Raz [F:POH] : Endif
  Endif
  If [M:PMG]MAJCOD="M"
    #-- En inter-site pas de modif du fournisseur
    If [F:POH]BETFCY=2 & [M:PMG]BPRNUM(I)<>[F:POQ]BPSNUM
       GMESSAGE=mess(286,194,1)-[M:PMG]BPRNUM(I)+"<>"+[F:POQ]BPSNUM
       [M:PMG]ERRCOD=41
       Return
    Endif
    #-- Si pendant vente, le site de rĂŠception n'est pas modifiable
    If [F:POH]SALFCY<>""
      If [M:PMG]STOFCY(I)<>[F:POQ]PRHFCY
        GMESSAGE=mess(286,194,1)-[M:PMG]STOFCY(I)+"<>"+[F:POQ]PRHFCY
        [M:PMG]ERRCOD=41
        Return
      Endif
    Endif
    #-- Si pendant vente, faire les contrĂ´les d'autorisation modif suppression ou solde
    If [F:POQ]LINOCNNUM=""| [F:POH]SALFCY=""  Return : Endif
    If [F:POH]APPFLG=3
      Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI1) From TRTVENISOC
    Else
      Call CTLMAJSOH("M", [F:POH]OCNNUM, GBIDI1) From TRTVENISOC
    Endif
    If GBIDI1<>0 : Return : Endif
    Raz GBIDI1
    Call CTLMAJSOP("M",[F:POQ]LINOCNNUM,[F:POQ]OCNLIN,[F:POQ]OCNSEQ,
&                 GBIDI1) From TRTVENISOC
    If GBIDI1<>0 : [M:PMG]ERRCOD=41 : Return : Endif
    Raz GBIDC3, GBIDI3
    #-- X3Suivi 77496 : Commandes achat/vente inter-sociĂŠtĂŠs dĂŠsynchronisĂŠes --#
    Call C_QTY(1,[F:POH]BPCORD, [M:PMG]ITMREF(I),
&              [M:PMG]PUU(I),GBIDC3,GBIDI3, GBIDI3,[M:PMG]EXTPUUQTY(I)) From TRTVENISOC
    If GMESSAGE<>"" : [M:PMG]ERRCOD=41 : Return : Endif
  Elsif [M:PMG]MAJCOD="A" & [F:POQ]LINOCNNUM<>"" & [F:POH]SALFCY<>""
    Call CTLMAJSOP("A",[M:POQ]LINOCNNUM,[F:POQ]OCNLIN,[F:POQ]OCNSEQ,
&                  GBIDI1) From TRTVENISOC
    If GBIDI1<>0 : [M:PMG]ERRCOD=41 : Return : Endif
    If [F:POH]LINNBR=1
      Raz GBIDI1
      Call CTLMAJSOH("A", [F:POH]OCNNUM, GBIDI1) From TRTVENISOC
      If GBIDI1<>0 : [M:PMG]ERRCOD=41 : Return : Endif
    Endif
  Elsif [M:PMG]MAJCOD="S" & [F:POQ]LINOCNNUM<>"" & [F:POH]SALFCY<>""
    Raz GBIDI1
    Call CTLMAJSOP("S",[F:POQ]LINOCNNUM,[F:POQ]OCNLIN,[F:POQ]OCNSEQ,
&                 GBIDI1) From TRTVENISOC
    If GBIDI1<>0 : [M:PMG]ERRCOD=41 : GERR=1  : End : Endif
  Endif
Else
  #-----------------------------------------------------------#
  # EN CREATION                                               #
  # Est-ce une commande inter-site ? inter-soc ?              #
  #-----------------------------------------------------------#
  Raz WBETFCY, WBETCPY, WBPCORD, WSALFCY, WLINSTOFCY, WDME, WSOHCAT, GMESSAGE, WFINRSP,
&     WBPCINV
  Read [FCY] FCY0=[M:POI1]POHFCY : If fstat  Raz [F:FCY] : Endif
  GFCY=[M:POI1]POHFCY
  #--------------------------------------------#
  # Lecture paramĂ¨tres                         #
  # On en a besoin pour le sous-pro ctrl_inter #
  # GSOCIETE, GFINRSP doivent ĂŞtre positionnĂŠs #
  #--------------------------------------------#
  Call GETDEV(GFCY)    From DEVSUB  : If GFINRSP="" GFINRSP=GFCY : Endif
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    If !find(GFCY,GUSRFCY(1..GNBAUZ))
      GMESSAGE=GFCY-mess(2,104,1) : Return
    Endif
  Endif
  If [F:FCY]PURFLG<>2 : Gosub CHARG_PARNI : Return : Endif
  Call CTRL_INTERSITE(GFCY,[M:PMG]BPRNUM(I),1,WBETFCY,WBETCPY,
&                     WSALFCY,WLINSTOFCY,WBPCORD,WFINRSP,WBPCINV,WDME) From TRTACHCTL1
  If GMESSAGE<>""  Return : Endif
  #----- Si on n'est pas en inter-sites, il faut recharger GFCY -----#
  If WBETFCY<>2
    Gosub CHARG_PARNI : Return
  #----- On est en inter-sites -----#
  Else
    If [F:ITM]ITMREF<>[M:PMG]ITMREF(I)
      Read [ITM] ITM0=[M:PMG]ITMREF(I) : If fstat  Raz [F:ITM] : Endif
    Endif
    #----- Si article gĂŠrĂŠ en stock, l'article-site d'expĂŠdition doit exister -----#
    If [F:ITM]STOMGTCOD>1 & WLINSTOFCY<>""
      Read [ITF] ITF0=[M:PMG]ITMREF(I);WLINSTOFCY
      If fstat  Raz [F:ITF], WLINSTOFCY : Endif
    Endif
    #----- Le site d'expĂŠdition n'a pas ĂŠtĂŠ trouvĂŠ -----#
    If WLINSTOFCY=""
      If [F:ITM]STOMGTCOD>1
        #----- Si gĂŠrĂŠ en stock recherche Ă  partir des article-sites -----#
        If WBETCPY<>2
          Filter [ITFY] Where [F:ITF]ITMREF=[F:ITM]ITMREF
&                           & [F:FCY]LEGCPY=GSOCIETE
&                           & [F:FCY]FCY  <>[M:PMG]STOFCY(I)
        Else
          Filter [ITFY] Where [F:ITF]ITMREF=[F:ITM]ITMREF
&                           & [F:FCY]LEGCPY=GCPY
&                           & [F:FCY]FCY  <>[M:PMG]STOFCY(I)
        Endif
        Read [ITFY] ITF0 First : If fstat  Raz [F:ITF], [F:FCY] : Endif
        Filter [ITFY]
      Else
        #----- Non gĂŠrĂŠ en stock recherche Ă  partir des sites -----#
        If WBETCPY<>2
          Filter [FCY] Where LEGCPY=GSOCIETE & WRHFLG=2 & FCY<>[M:PMG]STOFCY(I)
        Else
          Filter [FCY] Where LEGCPY=GCPY     & WRHFLG=2 & FCY<>[M:PMG]STOFCY(I)
        Endif
        Read [FCY] FCY1 First : If fstat  Raz [F:FCY] : Endif
        Filter [FCY]
      Endif
      #-----
      If fstat
        GMESSAGE=mess(285,194,1)-[M:PMG]ITMREF(I)-"/"-[M:PMG]STOFCY(I) : Return
      Else
        WLINSTOFCY=[F:FCY]FCY
      Endif
    Endif
  Endif
  If WFINRSP="" & WBETCPY=2 & WSALFCY<>""
    #Inter-sites : Site financier liĂŠ au client non trouvĂŠ ou incorrect
     GMESSAGE=mess(299,194,1) :  Return
  Endif
  Local Char WITMREF(GLONITM)
  WITMREF=[M:PMG]ITMREF(I)
  Gosub CTRL_BETITM
  If OK=1 | GMESSAGE<>"" : Return : Endif
  #----- Si inter-sites, contrĂ´le que l'unitĂŠ convienne pour les ventes -----#
  If WBETFCY=2 & WBPCORD<>""
    Call CTLUOM([M:PMG]ITMREF(I),2,WBPCORD,[M:PMG]PUU(I),GBIDD2,
&               GBIDC2,GBIDC3,GBIDI1) From STKACT
    If GMESSAGE<>"" OK=1 : Raz mkstat : Return : Endif
  Endif
Endif
Return

$CHARG_PARNI
#----------------------------------------------------------------#
# On est pas en inter-site, on charge GFCY avec [M:PMG]ORDFCY(I) #
# On vĂŠrifie que l'utilisateur est autorisĂŠ pour ce site         #
#----------------------------------------------------------------#
WBETFCY=1
WBETCPY=1
If [M:PMG]MAJCOD="C"
  If [M:PMG]ORDFCY(I)=""
    GMESSAGE=mess(82,116,1) : Return
  Endif
  #----- VĂŠrification des droits d'accĂ¨s au site -----#
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    If !find(([M:PMG]ORDFCY(I)),GUSRFCY(1..GNBAUZ))
      GMESSAGE=[M:PMG]ORDFCY(I)-mess(2,104,1) : Return
    Endif
  Endif
  If GFCY<>[M:PMG]ORDFCY(I)
    GFCY=[M:PMG]ORDFCY(I)
    Call GETCPY(GFCY,"",0,"") From TRTX3CPT  : If GFINRSP="" GFINRSP=GFCY : Endif
  Endif
Endif
If [M:PMG]STOFCY(I)<>""
  J=find([M:PMG]STOFCY(I),GSITE(1..GNBSITE))
  If J & GSOCSITE(J)<>GSOCIETE
    GMESSAGE=mess(2,194,1)-[M:PMG]STOFCY(I)-GFCY
  Endif
Endif
Return

$CTRL_BETITM
#--------------------------------------------------------#
# ContrĂ´le article sur les ventes et alimentation SOHCAT #
#--------------------------------------------------------#
#--- ContrĂ´le Ă  faire sur l'article en inter-site
#--- Si gĂŠrĂŠ en stock article-site expĂŠ existe ?
Raz OK
If [F:ITM]STOMGTCOD>1
  Look [ITF] ITF0=WITMREF;WLINSTOFCY
  If fstat
   GMESSAGE=WITMREF-mess(25,192,1)-WLINSTOFCY : OK=1 : Return
  Endif
Endif
#----- Test article de sous-traitance ou sous-traitĂŠ -----#
If ([F:ITM]SCSFLG=2 | [F:ITM]SCPFLG=2) & [F:ITM]PURFLG<>2
  GMESSAGE=[F:ITM]ITMREF-":"-mess(70,197,1) : OK=1 : Return
Endif
#-----
If WSALFCY="" : Return : Endif
Call CONTROLE("ITS","",[F:ITM]ITMREF,"",mkstat)   From CONTOBJ
If GMESSAGE<>"" : Raz mkstat : OK=1 : Return : Endif
#--- Appel au programme de contrĂ´le des ventes
If [M:PMG]PRQDAT<>[0/0/0]
  Call C_ITMREF(WITMREF,[M:PMG]PRQDAT,1) From TRTVENISOC
Else
  Call C_ITMREF(WITMREF,date$,1) From TRTVENISOC
Endif
If GMESSAGE<>"" Raz mkstat : OK=1 : Return : Endif
#-- DĂŠfinition du type de commande
If [F:ITM]RCPFLG=2
  WSOHCAT=1 : # normale avec livraison
Else
  WSOHCAT=3 : # facturation directe
Endif
Return

