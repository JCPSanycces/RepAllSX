#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "DEBUT"   : Gosub DEBUT
 When "FINSAI"  : Gosub FINSAI
 When "OK"      : Gosub ENREG   
 When Default
Endcase
Return

$OUVRE
Local Integer NOL
NOL = nolign-1
Local Mask SAISTT [STT]
Return

$DEBUT
Return

$ENREG
VALEUR = num$([M]AMT)
FIN = 1  ## sort de la fenetre
Return

$FINSAI
Return

Subprog AS_BPR(VALEUR)
Variable Char    VALEUR()
If [M:SAMT]SAIBPR=1
 Grizo BPR
 mkstat=2
Else
 Raz [M]BPR
 Actzo [M]BPR
Endif
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
Local Integer OK, I
If [M:SAMT]SCHEMA="" : Return : Endif
Call CONTROLE("GDA","",[M:SAMT]SCHEMA,"",mkstat) From CONTOBJ
If mkstat : End : Endif

For I=0 To [M:HAEF]NBRLED-1
 J = find([M:HAEF]COA(I),[F:GDA]COA(0..[F:GDA]COANBR-1))
 If J
  For [GDC]GDC0 Where DIA=SCHEMA
   Call LEC_GAC([F:GDC]ACC(J-1),[M:HAEF]COA(I)) From CPTLEC
   If [F:GAC]SAC=2
    Gosub CONTBPRACC From SUBGDA
    If mkstat : Break 2 : Endif
   Endif
  Next
 Endif 
Next
End


######################################################################################

