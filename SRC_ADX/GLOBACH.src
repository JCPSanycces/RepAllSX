########################################################################
# GLOBACH : Définition des variables globales                          #
#               utilisées par le module Achat                          #
# pas besoin d'init les variables puisque fait dans chaque programme   #
# les autres sont init par le WWGLOBACH                                #
# -------------------------------------------------------------------- #
# DEFVAR : Définitition des variables globales                         #
########################################################################


########################################################################
#         Définition des variables globales du module Achat            #
########################################################################
Subprog DEFVAR

Call DEFVAR From WWAGLOBACH

End

########################################################################
#       Initialisation des variables globales du module Achat          #
########################################################################
Subprog INIVAR

End
