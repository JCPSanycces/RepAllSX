#<AdxTL>@(#)0.0.0.0 $Revision$
#-------------------------------------------------------------#
$OUVRE
#------------------------------------------------------------#
# Ouverture masques de critères picking                      #
#------------------------------------------------------------#
#Pour utiliser le CRUD de la classe et  pas celui de l'objet
ANOWRITE = 1
Local Char WTIT(150)
#gestion de la classe des LPN
Global Instance WLPN Using C_LPN
If WLPN<> null : FreeGroup WLPN :Endif
WLPN = NewInstance C_LPN AllocGroup null
Local Char WMESS(250)
Local Integer MY_STATUS, WRET, I, WTRKCMP, WNBLIG # Issue 111257 US 43
Return
#-------------------------------------------------------------#
$SETBOUT
If GREP = "C" | GREP = "D"
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
Return
#-------------------------------------------------------------#
$EXEBOUT
Case REP
 When "1"
    Affzo [M:LPN]PRTFLG
Endcase
Return

Return
#-------------------------------------------------------------#
$RAZCRE
If WLPN<> null : FreeGroup WLPN :Endif
WLPN = NewInstance C_LPN AllocGroup null
[L]MY_STATUS = fmet WLPN.AINIT()
If [L]MY_STATUS >= [V]CST_AERROR
  #--- Header errors
  GMESSAGE = func LCCLIB.MAXMSG(WLPN)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
Endif
# Les champs initialisés par la classe sont remis dans la classe et dans la classe F
SetInstance [F:LPN] With WLPN
[M:LPN]=[F:LPN]
[M:LPN0]=[F:LPN]
#initialisation du dépot
If dim([M:LPN]WRH)>0
   Call WRHINIT([M:LPN]WRH,[M:LPN]STOFCY,0) From STKWRH
Endif
Affzo [M:LPN]
Affzo [M:LPN0]
Return
#-------------------------------------------------------------#
$RAZDUP
If WLPN<> null : FreeGroup WLPN :Endif
WLPN = NewInstance C_LPN AllocGroup null
#réinitialisation des zones
Effzo [M:LPN1]5
[M:LPN0]LPNFDAT = AVOID.ADATE
[M:LPN0]LPNLDAT = AVOID.ADATE
[M:LPN]LPNSTAT = 1
[M:LPN]PRTFLG = 1
Affzo [M:LPN]
Affzo [M:LPN0]
SetInstance WLPN With [M:LPN]
SetInstance WLPN With [M:LPN0]
If [M:LPN]TCTRNUM <> AVOID.ACHAR
  Read [TCTR]TCTR0 = [M:LPN]TCTRNUM
  If [TCTR]LPNREFCOU <> AVOID.ACHAR and [M:LPN]LPNNUM <> AVOID.ACHAR
    Call MESSAGE (mess(556,184,1)) From GESECRAN
  Endif
Endif
Return
#-------------------------------------------------------------#
$LIENS
#lecture de la classe
#WLPN = NewInstance C_LPN AllocGroup null

WLPN.LPNNUM=[M:LPN]LPNNUM
WRET = fmet WLPN.AREAD([M:LPN]LPNNUM)
If WRET <> [V]CST_AOK
  #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WLPN)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  If GOK=0 : Return : Endif
Endif
[M:LPN1]NBLIG = 0
#lecture de la table TABCONTAINER pour renseigner le type de contenant
Read [TCTR]TCTR0 = [M:LPN]TCTRNUM
[M:LPN]TCTRTYP = [F:TCTR]TCTRTYP
#lecture de la table STOCK pour renseigner le tableau
Filter [F:STO] Where [F:STO]LPNNUM = [M:LPN]LPNNUM
For [F:STO]
    #insertion de la ligne dans l'écran
    nolign = [M:LPN1]NBLIG
    Insa nolign,1,[M:LPN1]NBLIG [M:LPN1]NBLIG
    [M:LPN1]NBLIG += 1
    nolign = [M:LPN1]NBLIG
    NOL = nolign-1
    [M:LPN1] = [F:STO]
    #lecture de la désignation article
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:STO]ITMREF,[M:LPN1]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    #lecture de l'article
    If [F:ITM]ITMREF <> [F:STO]ITMREF
      Read [ITM]ITM0 = [F:STO]ITMREF
    Endif
    [M:LPN1]STU(nolign-1) = [F:ITM]STU

  #numéros de série pour les articles en série globale
  If [F:ITM]SERMGTCOD = 4
    If [F:STO]QTYPCU = 1
      Filter [STS] Where [STS]ITMREF=[F:STO]ITMREF & [STS]STOCOU = [F:STO]STOCOU
      Read [STS] First
      If fstat: Raz [F:STS]: Endif
      [M:LPN1]SERNUM(nolign-1) = [F:STS]SERNUM
    Else
      [M:LPN1]SERNUM(nolign-1) = "$"
    Endif
    Filter [F:STS]
  Endif
  Next
Diszo [M:LPN]TCTRNUM

Filter [F:STO]
If [M:LPN1]NBLIG <= 0
  Actzo [M:LPN]STOFCY
  Actzo [M:LPN]LOC
Else
  Grizo [M:LPN]STOFCY
  Grizo [M:LPN]LOC
Endif

Affzo [M:LPN]
Affzo [M:LPN0]
Affzo [M:LPN1]
Return

#-------------------------------------------------------------#
$AV_ANNULE
#--------------------------------------------#
# avant annulation des lignes de transport   #
#--------------------------------------------#
Local Integer ANOWRITE
#gestion de la classe des TRANSPORT
Global Instance WLPN Using C_LPN
Local Char WMESS(250)
Local Integer MY_STATUS, WRET

WLPN = NewInstance C_LPN AllocGroup null
ANOWRITE = 1

WLPN.LPNNUM=[M:LPN]LPNNUM
WRET = fmet WLPN.AREAD([M:LPN]LPNNUM)
If WRET <> [V]CST_AOK
  #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WLPN)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  If GOK=0 : Return : Endif
Endif

Return

#-------------------------------------------------------------#
$ANNULE
#--------------------------------------#
# Annulation des lignes de transport   #
#--------------------------------------#
Local Integer I,MY_STATUS
MY_STATUS = fmet WLPN.ADELETE()
If [L]MY_STATUS <> [V]CST_AOK
  #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WLPN)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  If GOK=0 : Return : Endif
Endif
Return

#-------------------------------------------------------------#
$CREATION
#----------------------------------#
# Création des lignes de INCIDENT #
#----------------------------------#
SetInstance WLPN With [M:LPN]
SetInstance WLPN With [M:LPN0]

MY_STATUS = fmet WLPN.AINSERT()
If [L]MY_STATUS >= [V]CST_AERROR
   #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WLPN)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  If GOK=0 : Return : Endif
Endif
[M:LPN]LPNNUM = WLPN.LPNNUM
[F:LPN]LPNNUM = [M:LPN]LPNNUM
Gosub LIENS
Return

#-------------------------------------------------------------#
$MODIF
#--------------------------------------#
# Modification des lignes de TRANSPORT #
#--------------------------------------#
SetInstance WLPN With [M:LPN]
SetInstance WLPN With [M:LPN0]

MY_STATUS = fmet WLPN.AUPDATE()
If [L]MY_STATUS <> [V]CST_AOK
 #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WLPN)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  If GOK=0 : Return : Endif
Endif
If GOK<1 Return : Endif

Gosub LIENS
Return

#-------------------------------------------------------------#
$FERME
#--------------------------------------#
# Annulation des lignes de transport   #
#--------------------------------------#
If WLPN<> null
  FreeGroup WLPN
Endif
Return
######################################################################################
$BOUTON
#------------------------#
# Traitement des boutons #
#------------------------#
Return

