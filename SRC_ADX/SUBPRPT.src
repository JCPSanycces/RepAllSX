#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# SUBPRPT : Eclatement d'une ligne de demande de livraison             #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p         #
# d'éclatement d'une DL et ne sert qu'à gérer le masque écran          #
# "PREPARTI [PRPT]".                                                   #
########################################################################

$ACTION
#---------------------------------------------------------------------#
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# SAISPLPOD  : Eclatement d'une demande de livraison                  #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "TITRE"       : Gosub TITRE_FEN
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "ABA"         : Gosub ABA
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FINSAI"      : Gosub FINSAI
Endcase
Return


#######################################################################
# Actions sur la saisie de fenêtre (GSAISIE)             MBT 27/12/00 #
# ------------------------------------------------------------------- #
# SAISPLPOD  : Eclatement d'une demande de livraison                  #
#######################################################################

#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Local Shortint SAVNOLIGN : SAVNOLIGN=nolign
Local Shortint NOL       : NOL=nolign-1
If [M:POD1]WRCPDAT(NOL)="" | [M:POD1]CAD(NOL)=1 | [M:POD1]QTYPUU(NOL)=0
  FIN=1 : Return
Endif
If [F:POH]CLEFLG=2
  GMESSAGE=mess(47,194,1) : GERR=1 : FIN=1 : Return
Endif
If [F:POH]APPFLG<3
  GMESSAGE=mess(84,194,1) : GERR=1 : FIN=1 : Return
Endif
#----------------------------------------------------------------#
# Eclatement de la ligne selon les répartitions semaines et mois #
# attention pas d'éclatement si la ligne précédente est de       #
# cadencement semaine ou mois                                    #
#----------------------------------------------------------------#
If NOL>0 & [M:POD1]CAD(NOL-1)<>1
  GMESSAGE=mess(23,192,1) : GERR=1 : FIN=1 : Return
Endif
#----- variables locales -----#
Local Integer  WRETOUR
Local Integer  NBRLIG                  : # Nombre de ligne à inserer
Local Shortint MON_ECLAT (0..6)        : # Mois des périodes éclatées
Local Shortint YEA_ECLAT (0..6)        : # Année des périodes éclatées
Local Shortint WEE_ECLAT (0..6)        : # Semaine des périodes éclatées
Local Date     DAT_ECLAT (0..6)        : # Mois des périodes éclatées
Local Libelle  TYP_ECLAT (0..6)        : # Type ordre PP ou PF
Local Decimal  QTY_ECLAT (0..6)        : # Mois des périodes éclatées
Local Char     WRCPDAT_ECLAT(10)(0..6) : # Date affichage
#-----
Local Decimal  W_DAYDSP (0..6)         : # Taux répartition
Local Decimal  W_WEEDSP (0..4)         : # Taux répartition
Local Decimal  W_QTYPUU                : # Somme des qtés pour ecart
Local Decimal  W_SOM_QTY_MIN           : # Ecart à imputer
Local Shortint IND_MAX                 : # Nombre de ligne à insérer
Local Shortint WJOUR, WMOIS, WANNEE
Local Shortint WSEMDEB, WSEMFIN, WSEMORI
Local Char     WDATE(10), WSEM
Return

#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
TIT=mess(25,195,1)
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
Raz NBRLIG, WRETOUR, IND_MAX
Raz [M:PRPT]
[M:PRPT]XRCPDAT = [M:POD1]WRCPDAT(NOL)
[M:PRPT]QTYPUU  = [M:POD1]QTYPUU(NOL)
[M:PRPT]PUU     = [M:POD1]PUU
[M:PRPT]CAD     = [M:POD1]CAD(NOL)
#----- Cas cadencement semaine -----#
If [M:PRPT]CAD=2
  [M:PRPT]NBECLAT=7
  W_QTYPUU=0
  W_SOM_QTY_MIN=0
  #--------------------------------------------------#
  # Répartition de la qté au prorata                 #
  # si la somme des taux de répartition = 0          #
  # alors on répartit sur premier jour de la semaine #
  #--------------------------------------------------#
  If sum([F:POC]DAYDSP(0..6))=0
    W_DAYDSP(0)=1
    For I=1 To 6
      W_DAYDSP(I)=0
    Next I
  Else
    For I=0 To 6
      W_DAYDSP(I)=[F:POC]DAYDSP(I)
    Next I
  Endif
  For I=0 To 6
    #----- Recherche du jour de la semaine -----#
    WDATE  = [M:POD1]STRRCPDAT(NOL)+I
    WANNEE = val(left$(WDATE,4))
    WMOIS  = val(mid$(WDATE,5,2))
    WJOUR  = val(right$(WDATE,7))
    Gosub DAT8 From SUBPODA
    # Issue 83296 - 2012-07-16 by MUARN : contrôle fermeture site
    GBIDA1=gdat$(WJOUR,WMOIS,WANNEE)
    GBIDA2=GBIDA1
    If [F:FCY]FCY<>[M:POD1]XPRHFCY(NOL)
      Read [FCY] FCY0=[M:POD1]XPRHFCY(NOL)
      If fstat Raz [F:FCY] : Endif
    Endif
    Call CTL_JOU2(GBIDA2,GBIDA1,[F:FCY]UVYDAY,[F:FCY]UVYCOD,0) From CONTX3
    If GBIDA2 <> GBIDA1 | mkstat
      mkstat = 0
      GMESSAGE=""
      Goto SUITE_ECLAT
    Endif

    [M:PRPT]XPER    (I) = WDATE
    [M:PRPT]XDAT    (I) = gdat$(WJOUR,WMOIS,WANNEE)
    [M:PRPT]XWIPSTA (I) = 1   : # Ferme par défaut
    If W_DAYDSP(I)<>0
      If sum([F:POC]DAYDSP(0..6))=0
        [M:PRPT]XQTY(I)=[M:PRPT]QTYPUU*W_DAYDSP(I)
      Else
        [M:PRPT]XQTY(I)=([M:PRPT]QTYPUU*W_DAYDSP(I))/sum([F:POC]DAYDSP(0..6))
      Endif
    Endif
    Call QTEARR([M:PRPT]XQTY(I),[M:PRPT]PUU) From TRTDIV
    [M:PRPT]XQTY(I)+=W_SOM_QTY_MIN
    #-----------------------------------------#
    # Test de la qté minimum d'achat          #
    # ou date inférieur à date avance retard  #
    # si inférieur on impute au poste suivant #
    #-----------------------------------------#
    If [M:PRPT]XQTY(I)<[M:POD1]PURMINQTY | [M:PRPT]XDAT(I)<[M:POD1]XEARDAT
      W_SOM_QTY_MIN=[M:PRPT]XQTY(I)
      [M:PRPT]XQTY(I)=0
    Else
      W_SOM_QTY_MIN=0
      W_QTYPUU+=[M:PRPT]XQTY(I)
      If [M:PRPT]XQTY(I)<>0
        IND_MAX=I
      Endif
    Endif
    [M:PRPT]XTOT+=[M:PRPT]XQTY(I)
# Issue 83296 - 2012-07-17 by MUARN : contrôle fermeture site
$SUITE_ECLAT

  Next I

  # Issue 83296 - 2012-07-16 by MUARN : contrôle fermeture site
  Raz I
  While I<[M:PRPT]NBECLAT
    If [M:PRPT]XPER(I)=""
      Dela I,1,[M:PRPT]NBECLAT-1 [M:PRPT]NBECLAT : [M:PRPT]NBECLAT-=1
      IND_MAX = [M:PRPT]NBECLAT-1
      I-=1
    Endif
    I+=1
  Wend
  If IND_MAX=-1 IND_MAX=0 Endif

#----- Cas cadencement mois -----#
Else
  #-----------------------------------------------------------#
  # Recherche de la première semaine                          #
  # STRRCPDAT contient le premier jour de la première semaine #
  #-----------------------------------------------------------#
  WSEMDEB=week([M:POD1]STRRCPDAT(NOL))
  #------------------------------------------#
  # Recherche de la dernière semaine         #
  # Il faut vérifier le 4 jour de la semaine #
  #------------------------------------------#
  WSEMFIN=week([M:POD1]EXTRCPDAT(NOL))
  If dayn([M:POD1]EXTRCPDAT(NOL))<4
    WSEMFIN-=1
  Endif
  If WSEMFIN<WSEMDEB
    GBIDI1 =week([M:POD1]STRRCPDAT(NOL)+7)
    If GBIDI1=2
      WSEMORI=1       : WSEMDEB=1
    Else
      WSEMORI=WSEMDEB : WSEMDEB=0
    Endif
  Endif
  GBIDI1=WSEMFIN-WSEMDEB
  If GBIDI1<=0  FIN=1 : Return : Endif
  [M:PRPT]NBECLAT = GBIDI1+1
  W_QTYPUU        = 0
  W_SOM_QTY_MIN   = 0
  #-------------------------------------------------#
  # Répartition de la qté au prorata                #
  # si la somme des taux de répartition = 0         #
  # alors on répartit    sur premier semaine        #
  # Si répartition sur 5 semaines et mois à 4       #
  # la dernière répartition est ventilé à égalité   #
  # sur les 4 postes                                #
  #-------------------------------------------------#
  If sum([F:POC]WEEDSP (0..4)) = 0
    W_WEEDSP(0)=1
    For I=1 To 4
      W_WEEDSP(I)=0
    Next I
  Else
    For I=0 To 4
      W_WEEDSP(I)=[F:POC]WEEDSP(I)
    Next I
  Endif
  For I=0 To [M:PRPT]NBECLAT-1
    If WSEMDEB+I=0
      [M:PRPT]XDAT(I)=aweek(WSEMORI+I,[M:POD1]YEA(NOL)-1)
      WSEM="0"+num$(WSEMORI+I)
      WDATE=format$("K:3#[-]4#",WSEM+num$([M:POD1]YEA(NOL)-1))
    Else
      [M:PRPT]XDAT(I)=aweek(WSEMDEB+I,[M:POD1]YEA(NOL))
      If len(num$(WSEMDEB+I))=1
        WSEM="00"+num$(WSEMDEB+I)
      Elsif len(num$(WSEMDEB+I))=2
        WSEM="0"+num$(WSEMDEB+I)
      Else
        WSEM=num$(WSEMDEB+I)
      Endif
      WDATE=format$("K:3#[-]4#",WSEM+num$([M:POD1]YEA(NOL)))
    Endif
    [M:PRPT]XPER   (I) = WDATE
    [M:PRPT]XWIPSTA(I) = 2  : # Toujours Planifie
    If W_WEEDSP(I)<>0
      If sum([F:POC]WEEDSP(0..4))=0
        [M:PRPT]XQTY(I)=[M:PRPT]QTYPUU*W_WEEDSP(I)
      Else
        [M:PRPT]XQTY(I)=([M]QTYPUU*W_WEEDSP(I))/sum([F:POC]WEEDSP(0..4))
      Endif
    Endif
    Call QTEARR([M:PRPT]XQTY(I),[M:PRPT]PUU) From TRTDIV
    [M:PRPT]XQTY(I)+=W_SOM_QTY_MIN
    #-----------------------------------------#
    # Test de la qté minimum d'achat          #
    # ou date inférieur à date avance retard  #
    # Si inférieur on impute au poste suivant #
    #-----------------------------------------#
    If [M:PRPT]XQTY(I)<[M:POD1]PURMINQTY | [M:PRPT]XDAT(I)<[M:POD1]XEARDAT
      W_SOM_QTY_MIN=[M:PRPT]XQTY(I)
      [M:PRPT]XQTY(I)=0
    Else
      W_SOM_QTY_MIN=0
      W_QTYPUU+=[M:PRPT]XQTY(I)
      If [M:PRPT]XQTY(I)<>0
        IND_MAX=I
      Endif
    Endif
    [M:PRPT]XTOT+=[M:PRPT]XQTY(I)
  Next I
Endif
#------------------------------------------------#
# Vérification des qtés                          #
#                                                #
# La somme doit être égale à W_QTYPUU            #
# Si ce n'est pas le cas on impute la différence #
# au dernier poste                               #
# Attention au cas cadencement semaine           #
#    si on n 'a rien pu ventiler il faut imputer #
#    sur le premier poste si la date est >= date #
#    avance retard sinon au dernier poste        #
#------------------------------------------------#
If W_QTYPUU<>[M:PRPT]QTYPUU
  W_QTYPUU=[M:PRPT]QTYPUU-W_QTYPUU
  If [M:PRPT]CAD=2 & IND_MAX=0 & [M:PRPT]XDAT(0)<[M:POD1]XEARDAT
    IND_MAX=6
  Endif
  If [M:PRPT]CAD=3 & IND_MAX=0 & [M:PRPT]XDAT(0)<[M:POD1]XEARDAT
    IND_ECLAT=[M:PRPT]NBECLAT-1
  Endif
  [M:PRPT]XQTY(IND_MAX)+=W_QTYPUU
  [M:PRPT]XTOT         +=W_QTYPUU
Endif
If [M:PRPT]CAD=2  IND_MAX=6                 : Endif
If [M:PRPT]CAD=3  IND_MAX=[M:PRPT]NBECLAT-1 : Endif
#----- Affichage écran -----#
Affzo [PRPT]1-99
Return

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK
J=0
# Issue 83296 - 2012-07-17 by MUARN : contrôle période fermeture site
If [M:PRPT]NBECLAT = 0 : Return Endif

For I=0 To IND_MAX
  If [M:PRPT]XQTY(I)<>0
    MON_ECLAT(J)=val(mid$(XDAT(I),5,2))
    YEA_ECLAT(J)=val(left$(XDAT(I),4))
    WEE_ECLAT(J)=week(XDAT(I))
    If WEE_ECLAT(J)=53
      #----- On regarde si le 4 jour de la semaine est sur année suivante -----#
      If year(aweek(WEE_ECLAT(J),YEA_ECLAT(J))+3)<>YEA_ECLAT(J)
        WEE_ECLAT(J)=1
      Endif
    Elsif WEE_ECLAT(J)=0
      #----- On regarde si le 4 jour de la semaine est sur année précédente -----#
      If dayn(aweek(WEE_ECLAT(J),YEA_ECLAT(J))+ 3)<4
        WEE_ECLAT(J)=1
      Else
        WEE_ECLAT(J)=53
      Endif
    Endif
    DAT_ECLAT(J)     = XDAT(I)
    TYP_ECLAT(J)     = XWIPSTA(I)
    QTY_ECLAT(J)     = XQTY(I)
    WRCPDAT_ECLAT(J) = XPER(I)
    J +=1
  Endif
Next I
If J<>0  NBRLIG=J : WRETOUR=1 : Endif
#-----
If WRETOUR=0 | NBRLIG=0
  FIN=1 : Return
Endif
#----- Traitement de l'éclatement -----#
nolign=SAVNOLIGN
Default Mask [POD1]
#----------------------------------------------#
# Contrôle de l'insertion                      #
# On ne peut pas passer par INSERE de tableaux #
# car ne contrôle qu'une seule ligne           #
#----------------------------------------------#
status=73
If dim ([M:POD1]WIPSTA)<[M:POD1]NBLIG+NBRLIG
  GMESSAGE=mess(122,199,1) : GERR=1 : FIN=1 : Return
Endif
If (nolign=1 & [M:POD1]POQSEQ(0)=GQSEQ+1) |
&  (nolign>1 & [M:POD1]POQSEQ(nolign-1)-[M:POD1]POQSEQ(nolign-2)<= NBRLIG)
  GMESSAGE=mess(122,199,1) : GERR=1 : FIN=1 : Return
Endif
#----- Insertion après la ligne -----#
If dim([M]WIPSTA)=[M:POD1]NBLIG+NBRLIG
  Insa nolign,NBRLIG [M:POD1]NBLIG    : # Pas de borne sinon plantage
Else
  Insa nolign,NBRLIG,[M:POD1]NBLIG+NBRLIG-1 [M:POD1]NBLIG
Endif
[M:POD1]NBLIG+=NBRLIG
#nolign+=1     : # de manière à initialiser POQSEQ /insertion après ligne
#status=0
#Call LINNUM("POQSEQ") From TABLEAUX
#nolign-=1
#----- Chargement des lignes -----#
Local File PWRKORDERS [PW2]
J=0
For I=nolign  To nolign-1+NBRLIG
  [M:POD1]WRCPDAT(I) = WRCPDAT_ECLAT(J)
  [M:POD1]WIPSTA (I) = TYP_ECLAT    (J)
  [M:POD1]QTYPUU (I) = QTY_ECLAT    (J)
  [M:POD1]MON    (I) = MON_ECLAT    (J)
  [M:POD1]YEA    (I) = YEA_ECLAT    (J)
  [M:POD1]WEE    (I) = WEE_ECLAT    (J)
  If [M:POD1]CAD(NOL)=2
    [M:POD1]CAD(I)=1
    [M:POD1]EXTRCPDAT(I) = DAT_ECLAT(J)
    [M:POD1]STRRCPDAT(I) = DAT_ECLAT(J)
  Else
    [M:POD1]CAD(I)=2
    [M:POD1]EXTRCPDAT(I)=aweek([M]WEE(I),[M]YEA(I))+6
    [M:POD1]STRRCPDAT(I)=DAT_ECLAT(J)
  Endif
  [M:POD1]XPRHFCY(I)=[M:POD1]XPRHFCY(NOL)
  [M:POD1]XFCYADD(I)=[M:POD1]XFCYADD(NOL)
  [M:POD1]USEPLC (I)=[M:POD1]USEPLC (NOL)
  #----- Eclatement de la qté des besoins pris en compte -----#
  If [M:POD1]RETQTYPUU(NOL)>[M:POD1]QTYPUU(I)
    [M:POD1]RETQTYPUU(I)   =[M:POD1]QTYPUU(I)
    [M:POD1]RETQTYPUU(NOL)-=[M:POD1]QTYPUU(I)
  Elsif [M:POD1]RETQTYPUU(NOL)>0
    [M:POD1]RETQTYPUU(I)=[M]RETQTYPUU(NOL) : Raz [M:POD1]RETQTYPUU(NOL)
  Endif
  If [M:POD1]RETQTYPUU(I)<>0 Gosub ECLATE_PWO : Endif
  #----- Etat de la ligne : en retard si < date jour -----#
  If [M:POD1]EXTRCPDAT(I)<date$
    [M:POD1]LINSTA(I)=2
  Else
    [M:POD1]LINSTA(I)=1
  Endif
  #------------------------------------------#
  # Mise jour du cumul qté cdée sur le ferme #
  # mise jour avance - retard   sur le ferme #
  #------------------------------------------#
  If [M:POD1]WIPSTA(I)=1
    [M:POD1]ORDQTYPUU+=[M:POD1]QTYPUU(I)
    If [M:POD1]LINSTA(I)=2
      [M:POD1]XEARQTY+=[M:POD1]QTYPUU(I)
    Endif
  Endif
  J+=1
Next I
Close Local File [PW2]
#--- Effacement fichier de travail "Besoins pris en compte de la ligne à supprimer ---#
nolign=SAVNOLIGN : Gosub EFFAC_LIG_PWRKORDERS From SUBPODA
#-------------------------------------------------#
# Suppression du texte associé à la ligne éclatée #
#   si ligne créée puis supprimée dans la foulée  #
#-------------------------------------------------#
If [M:POD1]CREFLG(NOL)=0  & [M:POD1]LINTEX(NOL)<>"" & left$([M:POD1]LINTEX(NOL),3)="POQ"
  Call SUP_CLOB([M:POD1]LINTEX(NOL),GBIDI1) From TRTX3TEX
Endif
#-------------------------------------------------#
# Il faut maintenant supprimer la ligne à éclater #
#-------------------------------------------------#
If dim([M:POD1]WIPSTA)=[M:POD1]NBLIG
  Dela NOL,1 [M:POD1]NBLIG
Else
  Dela NOL,1,[M:POD1]NBLIG-1 [M:POD1]NBLIG
Endif
[M:POD1]NBLIG-=1
nolign= SAVNOLIGN
status=0
Call LINNUM("POQSEQ") From TRTX3
Affzo [POD1]XEARQTY, 25
mkstat=4 : FIN=1
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA
Gosub DEBUT : Raz REP
Return

#------------------------------------#
# Après chaque modification de champ #
#------------------------------------#
$APRES_MODIF
REP="M"
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI
nolign=SAVNOLIGN
Return


######################################################################
# Eclatement fichier de travail "Besoins pris en compte d'une ligne" #
######################################################################
$ECLATE_PWO
[M:POD1]POHCOU+=1 : [M:POD1]POHLIN(I)=[M:POD1]POHCOU
Call DEBTRANS From GLOCK
$TR_ECLATE_PWO
GOK=1
Trbegin [PWO]
  GBIDD1=[M:POD1]RETQTYPUU(I)
  For [PWO] PWO0 Where PRONUM=adxuid(1) & CODFNC="POD" & LINNUM=[M:POD1]POHLIN(NOL)
    If [F:PWO]QTYPUU<>0
      Readlock [PWO] Curr
      If fstat=1
        GOK=-1
        GLOCK="$PWRKORDERS"-num$(adxuid(1))-"POD"-num$([M:POD1]POHLIN(NOL))
        Break
      Elsif fstat
        GOK=0
        Call RSTA("PWO",num$(adxuid(1))-"POD"-num$([M:POD1]POHLIN(NOL))) From GLOCK
        Break
      Endif
      [F:PW2]=[F:PWO]
      If [F:PWO]QTYPUU>GBIDD1 [F:PW2]QTYPUU=GBIDD1 : Endif
      [F:PWO]QTYPUU-=[F:PW2]QTYPUU
      Rewrite [PWO]
      If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Break : Endif
      [F:PW2]LINNUM=[M:POD1]POHLIN(I)
      Call PCAL_QTY([F:PW2]QTYPUU,[F:PW2]PUU,[F:PW2]QTYSTU,[F:PW2]STU,
&                   [M:POD1]ITMREF,[M:POD1]BPSNUM,1,GBIDD2) From TRTACHQTE1
      Write [PW2]
      If fstat GOK=0 : Call FSTA("PW2") From GLOCK : Break : Endif
      GBIDD1-=[F:PW2]QTYPUU
    Endif
    If GBIDD1=0 Break : Endif
  Next
  If GOK=-1 Goto ROLL_ECLATE_PWO : Endif
  If GOK=0  Goto AB_ECLATE_PWO   : Endif
Commit
Return
$AB_ECLATE_PWO
Rollback : Return
$ROLL_ECLATE_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_ECLATE_PWO : Endif : Return


####################################################################
# Sous-Programmes des actions sur champ de l'écran PREPARTI [PRPT] #
####################################################################

Subprog AVANT_NBECLAT
#-------------#
# Avant ligne #
#-------------#
[M:PRPT]XTOT-=[M:PRPT]XQTY(nolign-1)
End


Subprog APRES_NBECLAT
#-------------#
# Après ligne #
#-------------#
[M:PRPT]XTOT+=[M:PRPT]XQTY(nolign-1)
Affzo [PRPT]XTOT
End


Subprog AS_XWIPSTA(VALEUR)
#------------------------#
# Avant saisie du statut #
#------------------------#
Variable Integer VALEUR
If [M:PRPT]CAD<>2 mkstat=2 : End : Endif
#---------------------------------------------#
# Filtre du menu local  on désactive tout     #
# et on active type d'ordre ferme ou planifié #
#---------------------------------------------#
If dim(GMENLOC)>0
  For I=1 To dim(GMENLOC)-1
    GMENLOC (I) = 1
  Next I
  GMENLOC(1)=0 : GMENLOC(2)=0
Endif
End


Subprog AP_XWIPSTA(VALEUR)
#-------------------#
# Après zone statut #
#-------------------#
Variable Integer  VALEUR
Raz GMENLOC
End
