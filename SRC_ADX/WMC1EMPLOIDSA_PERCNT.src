Return

$PROPAGATE_ESSUIDCNT
this.isReadonly = 0
[L]CURPRO = "ESSUIDCNT"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_ESSUIDCNT
Gosub DECLARE_VAR From WMC0EMPLOIDSA_PERCNT
[L]CURPRO = "ESSUIDCNT"
$_LNKPRO_ESSUIDCNT
Return




