$_AMANDATORY_ESSUIDCNT
[L]CURPRO = "ESSUIDCNT"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.ESSUIDCNT=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_ESSUIDCNT
[L]CURPRO = "ESSUIDCNT"
Return

$_AOTHERS_ESSUIDCNT
[L]CURPRO = "ESSUIDCNT"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
