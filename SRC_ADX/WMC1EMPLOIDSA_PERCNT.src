#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## ACLA-CLASSE ## EMPLOIDSA_PERCNT
# 2018-11-06 07:05:53 077


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : CNTTYP Relationship type ( Field Local menu number 11681)
####################################################################

$SET_CNTTYP
If [L]_AOLDVAL<>this.CNTTYP
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_CNTTYP
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.CNTTYP
 Gosub PROPAGATE_CNTTYP
Endif
Return

$INIT_CNTTYP
Gosub DECLARE_VAR From WMC0EMPLOIDSA_PERCNT
[L]CURPRO = "CNTTYP"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.CNTTYP=0 and fmet this.AGETATTRIBUTE("CNTTYP","$isMandatory")="true"
 this.CNTTYP = 1
Endif
Return
 
$CONTROL_CNTTYP
Gosub DECLARE_VAR From WMC0EMPLOIDSA_PERCNT
[L]CURPRO = "CNTTYP"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_CNTTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_CNTTYP                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_CNTTYP
[L]CURPRO = "CNTTYP"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.CNTTYP=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_CNTTYP
[L]CURPRO = "CNTTYP"
If this.CNTTYP<0 or this.CNTTYP>len(mess(0,11681,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"11681 ->"-num$(this.CNTTYP)-mess(99,123,1)):  Return : # Local menu "11681 -> Invalid option
Endif
Return

$_AOTHERS_CNTTYP
[L]CURPRO = "CNTTYP"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_CNTTYP
[L]CURPRO = "CNTTYP"
Return

$PROPAGATE_CNTTYP
this.isReadonly = 0
[L]CURPRO = "CNTTYP"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_CNTTYP
Gosub DECLARE_VAR From WMC0EMPLOIDSA_PERCNT
[L]CURPRO = "CNTTYP"
$_LNKPRO_CNTTYP
Return


####################################################################
# 2 : ESSUIDCNT Unique code ( Field L 8)
####################################################################

$SET_ESSUIDCNT
If [L]_AOLDVAL<>this.ESSUIDCNT
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_ESSUIDCNT
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
