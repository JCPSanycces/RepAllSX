#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Raz trigger updtick AJSAUDIT
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Del AJSAUDIT") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

$MAJTAB
Local Char TABLE(GLONATB) : TABLE ="AJSAUDIT"

If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)<=0 : Return : Endif

Local Integer  BASE , NBRQT
Local Char     RQT(250)(1..2000)

If clalev([F:ADS])=0 : Local File ADOSSIER           [ADS] : Endif

Read [ADS]DOSSIER = DOSSIER
BASE = [F:ADS]TYPDBA

Call SUPTRI(BASE,DOSSIER,TABLE,NBRQT,RQT) From ATRIGGERTICK

Onerrgo ERREUR

Case BASE
 When 1 : Execsql From "3" Sql RQT(1..NBRQT)
 When 2 : Execsql From "5" Sql RQT(1..NBRQT)
Endcase

Onerrgo

Return

#----------------------------------------------------------------------------------------#

$ERREUR
Resume
