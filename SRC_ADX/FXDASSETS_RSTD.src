#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe FXDASSETS_DEP

###############
# EVENTS
###############
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"  : Gosub AREAD_AFTER
    Endcase
Endcase
Return
$AREAD_AFTER
  Case CURPTH
      When "" : Gosub AREAD_AFTER_FXDASSETS
  Endcase
Return


$AREAD_AFTER_FXDASSETS
  Local Integer N_I : N_I = 1
  Local Integer LNB : # Line number

  Local Date    FIYSTRDAT(11) : # date de début exercice courant
  Local Date    FIYENDDAT(11) : # date de fin exercice courant
  Local Date    PERSTRDAT(11) : # date de début période courante
  Local Date    PERENDDAT(11) : # date de fin période courante

  Local File CONTEXT  [RCNX]
  Local File FISCYEAR [RFIS]
  Local File DEPREC   [DEP]

  # Recherche des périodes courantes pour les contextes
  For [RCNX] Where CPY=this.FAS.CPY
    Read [RFIS]FIY1=[F:RCNX]CPY;[F:RCNX]CNX;2
    FIYSTRDAT([F:RCNX]CNX) = [F:RFIS]DATSTRFIY
    FIYENDDAT([F:RCNX]CNX) = [F:RFIS]DATENDFIY
    PERSTRDAT([F:RCNX]CNX) = [F:RFIS]DATSTRPER([F:RFIS]INDCURPER-1)
    PERENDDAT([F:RCNX]CNX) = [F:RFIS]DATENDPER([F:RFIS]INDCURPER-1)
  Next

  # Amortissements
  While this.FAS.DEPREC(N_I) <> null
    If (this.FAS.ISSDAT=[0/0/0] or this.FAS.ISSDAT>=FIYSTRDAT(this.FAS.DEPREC(N_I).CNX)) and (this.FAS.DEPREC(N_I).PERSTRDAT=PERSTRDAT(this.FAS.DEPREC(N_I).CNX))
      # -
      # Bien non sorti ou sorti dans l'exercice courant (ou au-delà). On affiche le DEPREC correspondant à la période courante pour le plan
      # -
      Gosub DEP_ADDLINE
      # -
    Elsif (this.FAS.ISSDAT<>[0/0/0] and this.FAS.ISSDAT<FIYSTRDAT(this.FAS.DEPREC(N_I).CNX)) and (this.FAS.DEPREC(N_I+1)=null or this.FAS.DEPREC(N_I).DPRPLN<>this.FAS.DEPREC(N_I+1).DPRPLN)
      # -
      # Bien sorti dans un exercice antérieur à l'exercice courant. On affiche le dernier DEPREC trouvé pour le plan
      # -
      Gosub DEP_ADDLINE
    Endif

    N_I += 1
  Wend

  # TVA
  #TODO A conditionner à la législation française
  #If GKFR = G_OUI Then
    this.ASJCOE2    = this.FAS.ASJCOE
    this.TAXCOE2    = this.FAS.TAXCOE
    this.ADMCOE2    = this.FAS.ADMCOE
    this.DEDCOE2    = this.FAS.DEDCOE
  #Endif

  # Valeur marché
  this.NSPVALP      = this.DEP(1).NSPVAL

  # Elements physiques rattachés au bien
  Local File ACTIV [ACV]
  Read [ACV]CODACT="PHY"
  If fstat : Raz [F:ACV] : Endif
  If [F:ACV]FLACT = [V]CST_AYES
    Local File PHYELT   [PHY]
    For [F:PHY]PHY0 Where AASREF=this.FAS.AASREF
      Gosub PHY_ADDLINE
    Next
  Endif
Return

$DEP_ADDLINE
  LNB = fmet this.ADDLINE("DEP",[V]CST_ALASTPOS)
  # Il ne faut pas faire de SetInstance d'une classe sur une autre car on écrase tous les pointeurs
  SetInstance [F:DEP] With this.FAS.DEPREC(N_I)
  SetInstance this.DEP(LNB) With [F:DEP]
Return

$PHY_ADDLINE
  LNB = fmet this.ADDLINE("PHY",[V]CST_ALASTPOS)
  # Il ne faut pas faire de SetInstance d'une classe sur une autre car on écrase tous les pointeurs
  SetInstance this.PHY(LNB) With [F:PHY]
Return

###############
# METHODS
###############
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return


###############
# OPERATIONS
###############
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return

