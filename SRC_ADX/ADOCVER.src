#<AdxTL>@(#)10.0.0.0 $Revision$
# Gestion du masque ADOCEPUR/ADOCVER
Close Local Mask
Call ADOCVER(nomap)
End

########################################################################
Subprog ADOCVER(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"ADOCVER","ADOCVER","") From GSAISIE
End


######################################################################################
####################
$ACTION
If GACTION="ADOCEPUR"
    Case ACTION
     When "INIT_DIA" : Gosub INITEPUR
     When "EXEC"     : Gosub EXECEPUR
     When "SORTIE"   : Gosub TERMINEEPUR
     When Default
    Endcase
Else
    Case ACTION
     When "INIT_DIA" : Gosub INITVER
     When "EXEC"     : Gosub EXECVER
     When "SORTIE"   : Gosub TERMINEVER
     When Default
    Endcase
Endif
Return

$INITEPUR
[M:DIA]ALLLAN  = 1
[M:DIA]ALLTYP  = 1
[M:DIA]ALLCOD  = 1
[M:DIA]LAN     = PARAM(2)
[M:DIA]TYP     = PARAM(3)
[M:DIA]CODDEB  = PARAM(4)
[M:DIA]CODFIN  = PARAM(4)
[M:DIA]ACTVER=2
[M:DIA]SIMU=2

# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
Return

$EXECEPUR
If [M:DIA]SIMU=2
Call DOCNUT(1,1)
Else
Call DOCNUT(1,0)
Endif
Return

$TERMINEEPUR
Return

$INITVER
[M:DIA]ALLLAN  = 1
[M:DIA]ALLTYP  = 1
[M:DIA]ALLCOD  = 1
[M:DIA]LAN     = PARAM(2)
[M:DIA]TYP     = PARAM(3)
[M:DIA]CODDEB  = PARAM(4)
[M:DIA]CODFIN  = PARAM(4)
[M:DIA]MODVER=2
[M:DIA]ACTVER=2

# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
Return

$EXECVER
Call DOCNUT(0,1)
Return

$TERMINEVER
Return


######################################################################################
#######################################################
Subprog DOCNUT(EPUR,SIMU)
Value Integer EPUR
Value Integer SIMU
Local Char    TIT(250) , MESSA(250)
Local Char    TBTYP(GLONADI)(1..150) , TBOBJ(GLONAOB)(1..150)
Local Char    TBCLE(2*GLONAVA)(1..150), TBCLE2(2*GLONAVA)(1..150), TBCLE3(2*GLONAVA)(1..150), TBCLE4(2*GLONAVA)(1..150)
Local Char    DOC_CODE(30), DOC_TYPE(GLONADI)
Local Integer I , J , K , OK , NBOBJ , OKEPU ,OKACT , OKFIC
  Local Char EV(200)

If EPUR & SIMU
 TIT = mess(221,139,1)-"/"-mess(6,115,1) : # Epuration documentation / Simulation
Elsif EPUR
 TIT = mess(221,139,1) : # Epuration documentation
Else
 TIT = mess(223,139,1) : # Vérification documentation
Endif
If EPUR & !SIMU
 Call AVERTIR(TIT+"\"+mess(205,100,1),OK) From GESECRAN : # Voulez-vous continuer ?
 If OK<>2 : End : Endif
Endif

Call OUVRE_TRACE(TIT) From LECFIC
Call TEMPON(TIT) From GESECRAN
Local File ADOCUMENT [ADO] ,ADOCUMENT [ADO1] , ADOCCLB [ADH] , ADOCBLB [ADB]
Local File ATABDIV [ADI]
Raz NBOBJ
For [ADI] Where NUMTAB=910
 Case [F:ADI]CODE
  When "AT2"
   NBOBJ += 1
   TBTYP(NBOBJ) = "AT2"
   TBOBJ(NBOBJ) = "ATB"
   TBCLE(NBOBJ) = "CODFIC"
  When Default
   # JPGA 19/08/2009 Bug-52238 : Recherche dynamique des Cles multiples d'index (4 au max)
   DOC_TYPE=[F:ADI]CODE
   Gosub DOC_RECH_CLE_MULTIPLE From AGENLIBA
   If IF_DOC_TABLE
      NBOBJ += 1
      TBTYP(NBOBJ) = [F:ADI]CODE
      TBOBJ(NBOBJ) = [F:ADI]CODE
      TBCLE(NBOBJ) = DOC_CLE1  :  TBCLE2(NBOBJ)=DOC_CLE2  :  TBCLE3(NBOBJ)=DOC_CLE3  :  TBCLE4(NBOBJ)=DOC_CLE4
   Endif
 Endcase
Next ADI

GOK = 1
Trbegin [ADO]
  EV= string$( [M:DIA]ALLLAN=1, "([ADO]LAN=[M:DIA]LAN)" )
  EV+=string$( [M:DIA]ALLTYP=1, string$(EV<>""," & ")+"([ADO]TYP=[M:DIA]TYP)" )
  EV+=string$( [M:DIA]ALLCOD=1, string$(EV<>""," & ")+"([ADO]COD>=[M:DIA]CODDEB)&([ADO]COD<=[M:DIA]CODFIN)" )
  EV+=string$( EV="","1=1" )

 For [ADO]ADO0(3) Where evalue(EV)
  Call ECR_TRACE([F:ADO]LAN+"~"+[F:ADO]TYP+"~"+[F:ADO]COD,0) From GESECRAN
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If func AGENLIBA.TEST_GROUPE_OK("ADO", [ADO]LAN, [ADO]TYP, [ADO]COD, "[M]ALLCREGRP")
    K = find([F:ADO]TYP,TBTYP(1..NBOBJ))
    If K
      OKFIC=1
      Case [F:ADO]TYP
        When "ADP"
          Default File [ADP]
          Read [ADP]ADP1 = [F:ADO]COD
        When "APM"
          Default File [AFC]
          Read [AFC]CODINT = [F:ADO]COD
          If fstat : If find(left$([F:ADO]COD,3),TBTYP(1..NBOBJ)) : fstat=0 : OKFIC=0 : Endif
          Elsif !fstat & [F:AFC]TYPTRAIT<>2 : fstat = 3
          Endif
        When "ATD" , "AT3" # JPGA - 29/01/2008 - Bug:51664 : Pas de controle sur les AT3
          #pas de controle
          OKFIC=0
        When Default
          Gosub DEFAUT From ="WO"+TBOBJ(K)
          # JPGA 19/08/2009 Bug-52238 : Alimentation des champs de clé en prenant en comtpe les clé multiples
          DOC_TYPE=[F:ADO]TYP : DOC_CODE=[F:ADO]COD : DOC_CLE1=TBCLE(K) : DOC_CLE2=TBCLE2(K) : DOC_CLE3=TBCLE3(K) : DOC_CLE4=TBCLE4(K)
          Gosub DOC_ALIM_CLE_MULTIPLE From AGENLIBA
          Read [F] =
      Endcase

      OKEPU = 0
      OKACT = 0
      MESSA = ""
      If fstat
        # Objet inexistant
        MESSA = [F:ADO]TYP-[F:ADO]COD-"("+[F:ADO]LAN+")"-":"-mess(161,123,1)
        Call ECR_TRACE(MESSA,1) From GESECRAN
        OKEPU = 1
      Elsif OKFIC
        If dim([F]MODULE)>0 & [F]MODULE<>[F:ADO]MODULE & dim([M:DIA]MODVER)>0 & [M:DIA]MODVER=2
          # Module incorrect
          MESSA = [F:ADO]TYP-[F:ADO]COD-"("+[F:ADO]LAN+")"-":"-mess(132,124,1)-"([F]="+mess([F]MODULE,14,1)+")"-"([ADO]="+mess([F:ADO]MODULE,14,1)+")"
          Call ECR_TRACE(MESSA,1) From GESECRAN
        Endif
        If EPUR=0
          #ssi pas epuration, on regarde les codes activite
          If dim([F]CODACT)>0 & [F]CODACT<>[F:ADO]CODACT & ([F:ADO]TYP<>"ACV" | [F:ADO]CODACT<>"") & [M:DIA]ACTVER=2 & [F:ADO]CODACT<>"FAL"
            # Code activité incorrect
            MESSA = [F:ADO]TYP-[F:ADO]COD-"("+[F:ADO]LAN+")"-":"-mess(224,139,1)-"([F]="+[F]CODACT+")"-"([ADO]="+[F:ADO]CODACT+")"
            Call ECR_TRACE(MESSA,1) From GESECRAN
          Endif
          If dim([F]CODACT)>0 & [F]CODACT<>"" & [M:DIA]ACTVER=2
            For [ADO1] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD & CODACT<>[F]CODACT & CODACT<>"FAL"
              Call ECR_TRACE([F:ADO1]TYP-[F:ADO1]COD-"("+[F:ADO1]LAN+")"-"("+num$([F:ADO1]LEV)+"/"+num$([F:ADO1]SUBLEV)+")"-":"-mess(224,139,1)-"([F]="+[F]CODACT+")"-"([ADO]="+[F:ADO1]CODACT+")",1) 
& From GESECRAN
            Next
          Endif
        Endif
        # dans tous les cas, on verifie existence des codes activite
        If [M:DIA]ACTVER=2
          For [ADO1] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD & CODACT<>"" & CODACT<>"FAL"
            Read [ACV]CODACT=[F:ADO1]CODACT
            If fstat
              Call ECR_TRACE([F:ADO1]TYP-[F:ADO1]COD-"("+[F:ADO1]LAN+")"-"("+num$([F:ADO1]LEV)+"/"+num$([F:ADO1]SUBLEV)+")"-":"-mess(224,139,1)-"([ADO]="+[F:ADO1]CODACT+") -> FAL",1) From GESECRAN
              OKACT = 1
            Endif
          Next
        Endif
      Endif
      If !SIMU & EPUR & OKEPU
        For [ADO]ADO0
          Delete [ADH] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD & LEV=[F:ADO]LEV & SUBLEV=[F:ADO]SUBLEV
          Delete [ADB] Where LAN=[F:ADO]LAN & TYP=[F:ADO]TYP & COD=[F:ADO]COD & LEV=[F:ADO]LEV & SUBLEV=[F:ADO]SUBLEV
          Delete [ADO]ADO0 Curr
          If !fstat
            # JPGA 13/10/2009 Bug-58629 : Marquage des corrections en Epuration de Doc
            Local Char CLE1            : CLE1=[F:ADO]TYP
            Local Char CLE2(50)(0..1)  : CLE2(0) = [F:ADO]LAN : CLE2(1)=[F:ADO]COD
            Call TRACE_COR("ADO",CLE1,CLE2,"A") From AGENLIBA
          Else
            GOK=-1 : Call RSTA("ADO",[F:ADO]TYP-[F:ADO]COD-[F:ADO]LAN) From GLOCK : Break 2
          Endif
        Next
      Elsif !SIMU & EPUR & OKACT
        For [ADO]ADO0
          If [F:ADO]CODACT<>"" & [F:ADO]CODACT<>"FAL"
             Read [ACV]CODACT=[F:ADO]CODACT
             If fstat
                [F:ADO]CODACT="FAL"
                Rewrite [F:ADO]
                If !fstat
                   # JPGA 13/10/2009 Bug-58629 : Marquage des corrections en Epuration de Doc
                   Local Char CLE1            : CLE1=[F:ADO]TYP
                   Local Char CLE2(50)(0..1)  : CLE2(0) = [F:ADO]LAN : CLE2(1)=[F:ADO]COD
                   Call TRACE_COR("ADO",CLE1,CLE2,"M") From AGENLIBA
                Else
                   GOK=-1 : Call RSTA("ADO",[F:ADO]TYP-[F:ADO]COD-[F:ADO]LAN) From GLOCK : Break 2
                Endif
             Endif
          Endif
        Next
      Endif
    Endif
  Endif
 Next ADO(3)
If GOK<1
 Rollback
Else
 Commit
Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCEPUR) 23/09/2008 14:29:46 (VPO)
######################################################################################
Subprog C_ALLLAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]LAN = "" : Affzo LAN : Grizo LAN
Else
 Actzo LAN
Endif
End

Subprog C_ALLTYP(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
 [M]TYP = "" : Affzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End


Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]CODDEB = "" : Affzo CODDEB : Grizo CODDEB
 [M]CODFIN = "" : Affzo CODFIN : Grizo CODFIN
Else
 Actzo CODDEB
 Actzo CODFIN
Endif
End

Subprog AM_CODDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M]CODFIN=""
    [M]CODFIN=VALEUR : Affzo [M]CODFIN
Endif
End

Subprog AS_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]CODDEB
   If VALEUR=""
       VALEUR="X"
   Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCVER) 25/10/2012 17:06:31 (JPGA)
######################################################################################
Subprog AV_ALLCREGRP(VALEUR)
Variable Integer VALEUR
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  #Le modèle "Traitement Standard-Boite de dialogue" ne permet pas chgfmt en INIT_DIA : on le fait donc en Avant-zone de champ
  Call AFFMASK_GROUPE("[M]ALLCREGRP") From AGENLIBA
End
######################################################################################
