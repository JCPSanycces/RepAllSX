#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
 When "INIT" :
  If GPAYE
   OK = 1
   #Le module paie est présent : Etes-vous sûr de vouloir continuer ?
   Call OUINON(mess(129,10709,1),OK) From GESECRAN
   If OK<>2  : FIN=1 : Return : Endif
  Endif
 When "EXEC" :  Gosub EXEC
Endcase
Return

$EXEC
Local Char    CRITERE (250)
Local Char    CRITERE2 (250)
Local Integer I

If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
If clalev([F:AD])=0   : Local File EMPLOAD  [AD]   : Endif
#ADNGO - 2017-03-29 - START
#If clalev([F:CTR])=0  : Local File EMPLOCTR [CTR]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]  : Endif
#ADNGO - 2017-03-29 - END
If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif
If clalev([F:POA])=0  : Local File POPULA   [POA]  : Endif
If clalev([F:CNE])=0  : Local File CNGEMP   [CNE]  : Endif
If clalev([F:CNE2])=0 : Local File CNGEMP   [CNE2] : Endif

## DBA le 19/07/2004 : Sugg 22709 -> Ajout des critères sur Société, Site,
## Service, Profil et Population.


# Salariés actifs + gestion des temps + présents
#ADNGO - 2017-03-29 - START
#CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2 & [F:CTR]XITFNL<>2"
CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2 & [F:HRCTR]XITFNL<>2"
#ADNGO - 2017-03-29 - END
If [M:DIA]MATDEB<>""
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATDEB<>""
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
#ADNGO - 2017-03-29 - START
 #CRITERE -= '& [F:CTR]ETRSRV = "'+[M:DIA]SRV+'"'
 CRITERE -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
#ADNGO - 2017-03-29 - END
Endif
If [M:DIA]ALLPRF<>2  #profil
#ADNGO - 2017-03-29 - START
 #CRITERE -= '& [F:CTR]PROPRF = "'+[M:DIA]PRF+'"'
 CRITERE -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
#ADNGO - 2017-03-29 - END
Endif

# Salarié lié aux sites de la société selectionnée
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:FCY]FCY = "'+[M:DIA]FCY+'"'
Endif
#ADNGO - 2017-03-29 - START
#If [M:DIA]POP<>""
# Link [CTR] With
#&   [ID]ID0   = [F:CTR]REFNUM
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#& , [POA]POA0 = [M:DIA]POP;[F:CTR]REFNUM
#&   As [LNK]
#&   Where evalue(CRITERE) & [F:POA]REFNUM<>""
#Else
# Link [CTR] With
#&   [ID]ID0   = [F:CTR]REFNUM
#& , [FCY]FCY0 = [F:CTR]ETRFCY
#&   As [LNK]
#&   Where evalue(CRITERE)
#Endif

If [M:DIA]POP<>""
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [POA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM
&   As [LNK]
&   Where evalue(CRITERE) & [F:POA]REFNUM<>""
Else
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
&   As [LNK]
&   Where evalue(CRITERE)
Endif
#ADNGO - 2017-03-29 - END
Gosub TR1

Return

$TR1
Trbegin [CNE]
#ADNGO - 2017-03-29 - START
 #For [LNK] Where [F:CTR]ETRFCY=[F:FCY]FCY
 For [LNK] Where [F:HRCTR]ETRFCY=[F:FCY]FCY
#ADNGO - 2017-03-29 - END
  OK=1
  Call CONTROLE([F:ID]REFNUM,datesyst,"","",OK,1) From DIVPAYE
  If OK
   For I=0 To [M:DIA]NBLIG-1
    #If [F:ID]FLGMULCTR=2
    #ADNGO - 2017-03-29 - START
     #Readlock [CNE]CNE0=[M:DIA]YEA;[F:ID]REFNUM;[F:CTR]CTRNUM;[M:DIA]TIM(I)
     Readlock [CNE]CNE0=[M:DIA]YEA;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[M:DIA]TIM(I)
    #ADNGO - 2017-03-29 - END
    #Else
    # Readlock [CNE]CNE0=[M:DIA]YEA;[F:ID]REFNUM;"";[M:DIA]TIM(I)
    #Endif
    If !fstat
     [F:CNE]NBRDAY = [M:DIA]NBRDAY(I)
     Rewrite [CNE]
     If fstat
      GOK = 0 : Call FSTA("CNE") From GLOCK : Break 2
     Endif
    Elsif fstat>1
     Raz [F:CNE]
     [F:CNE]REFNUM = [F:ID]REFNUM
     [F:CNE]TIM    = [M:DIA]TIM(I)
     [F:CNE]YEA    = [M:DIA]YEA
     [F:CNE]NBRDAY = [M:DIA]NBRDAY(I)
     #If [F:ID]FLGMULCTR=2
     #ADNGO - 2017-03-29 - START
      #[F:CNE]CTRNUM = [F:CTR]CTRNUM
      [F:CNE]CTRNUM = [F:HRCTR]CTRNUM
     #ADNGO - 2017-03-29 - END
     #Endif
#JASMI - 2014/09/04 - START
     #LIPET - 2016-11-01 - START
     #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
     #If func AFNC.ACTIV("KGZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
     If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
     #LIPET - 2016-11-01 - END
     #JASMI - 2014-10-29 - 2999 - START
#       Call CALC_LVE_DATES_KSA([M:DIA]TIM(I),[F:FCY]LEGCPY,[M:DIA]YEA,[F:ID]REFNUM,[F:CTR]CTRNUM,
#&                              [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND) From SUBCNEKSA
       Local Integer NEWYEA : [L]NEWYEA = 0
#ADNGO - 2017-03-29 - START
#       Call CALC_LVE_DATES_KSA([M:DIA]TIM(I),[F:FCY]LEGCPY,[M:DIA]YEA,[F:ID]REFNUM,[F:CTR]CTRNUM,
#&                              [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND,
#&                              [0/0/0],[L]NEWYEA) From SUBCNEKSA

       Call CALC_LVE_DATES_KSA([M:DIA]TIM(I),[F:FCY]LEGCPY,[M:DIA]YEA,[F:ID]REFNUM,[F:HRCTR]CTRNUM,
&                              [F:CNE]EMPLEASTR,[F:CNE]EMPLEAEND,[F:CNE]EMPCYCSTR,[F:CNE]EMPCYCEND,
&                              [0/0/0],[L]NEWYEA) From SUBCNEKSA
#ADNGO - 2017-03-29 - END
     #JASMI - 2014-10-29 - 2999 - END
     Endif
#JASMI - 2014/09/04 - END
     Gosub CHER_SLDNEG
     Write [CNE]
     If fstat
      GOK = 0 : Call FSTA("CNE") From GLOCK : Break 2
     Endif
    Elsif fstat=1
      GOK = -1 : GLOCK = "$CNGEMP"-[F:ID]REFNUM : Break 2
    Endif
   Next I
  Endif
 Next
 If GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

#Lors d'une création d'enreg dans [CNE], on reporte le solde négatif de l'année précédente.
#Ce solde négatif est basculé dans le nb de congés pris sur nouvelle fiche.
$CHER_SLDNEG
Filter [F:CNE2] Where YEA<[F:CNE]YEA & REFNUM=[F:CNE]REFNUM & CTRNUM=[F:CNE]CTRNUM & TIM=[F:CNE]TIM
Read [F:CNE2]CNE0 Last
Filter [F:CNE2]
If ! fstat & [F:CNE2]NBRDAY-[F:CNE2]NBRPRI<0
 [F:CNE]NBRPRI =abs([F:CNE2]NBRDAY-[F:CNE2]NBRPRI)
Endif
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

#########################################
Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1900
 GMESSAGE = mess(106,10709,1) : # Année incorrecte
 mkstat = 2 : End
Endif
End

#########################################
Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2017-03-29 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#ADNGO - 2017-03-29 - END
If [F:TIM]CATTIM<>3
 GMESSAGE = mess(105,10709,1) : # Type d'événement incorrect
 mkstat = 2 : End
Endif
Call UNICITE(VALEUR,[M]TIM) From OBJDIV
End

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR
Call AS_SRV(VALEUR) From DIVPAYE
End

Subprog C_ALLPRF(VALEUR)
Variable Integer VALEUR
Call C_ALLPRF(VALEUR) From DIVPAYE
End

Subprog AS_PRF(VALEUR)
Variable Char  VALEUR
Call AS_PRF(VALEUR) From DIVPAYE
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

