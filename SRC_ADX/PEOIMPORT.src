#<AdxTL>@(#)8.0.0.0 $Revision$
########################################################
# GIMP :                                               #
#     GIMP(1) : Code mise à jour                       #
#     GIMP(2) : statut de l'ordre                      #
#     GIMP(3) : Date commande                          #
#     GIMP(4) : Date réception                         #
#     GIMP(5) : Site commande                          #
#     GIMP(6) : Réseau MTO                             #
########################################################
Call IMPORTATION("PEO") From GIMPOBJ
End

###################################################################################
$ACTION
Case [L]ACTION
  When "AP_IMPORT"     : Gosub AP_IMPORT
  When "IMP_FERME"     : Gosub IMP_FERME
  #-----
  When "EXPORT"        : Gosub EXPORT
  When "EXP_ZONE"      : Gosub EXP_ZONE
  When Default
      If dim(GPEO_TRACE)>0 & GPEO_TRACE=2 & ACTION<>"IMP_ZONE"
         GPEO_ACTION=ACTION : GPEO_PGM="PEOIMPORT" : Gosub TRACE_DETAILLEE
      Endif
Endcase
Return

###################################################################################
$EXPORT
Raz GIMP(1), GIMP(2), GIMP(3), GIMP(4), GIMP(5), GIMP(6)
If clalev ([F:SCO]) = 0 : Local File SCOHEAD  [SCO] : Endif
Read [F:SCO]SCO0 = [F:SCI]SCONUM
If !fstat
   GIMP(1) = "M"
   GIMP(2) = num$([F:SCO]SCOSTA)
   GIMP(3) = num$([F:SCO]ORDDAT)
   GIMP(4) = num$([F:SCO]RETDAT)
   GIMP(5) = [F:SCO]POHFCY
   GIMP(6) = [F:SCO]MTOREF
Endif
Return
###################################################################################
$EXP_ZONE
Case EXPZON
  When "GIMP(1)"    :
  When "GIMP(2)"    : If [F:SCO]SCONUM=[F:SCI]SCONUM : GIMP(2)=num$([F:SCO]SCOSTA) : Endif
  When "GIMP(3)"    : If [F:SCO]SCONUM=[F:SCI]SCONUM : Call SETDATE([F:SCO]ORDDAT,GIMP(3),[F:AOE]OPTDAT) From SUBEXPOBJ : Endif
  When "GIMP(4)"    : If [F:SCO]SCONUM=[F:SCI]SCONUM : Call SETDATE([F:SCO]RETDAT,GIMP(4),[F:AOE]OPTDAT) From SUBEXPOBJ : Endif
  When "GIMP(5)"    : If [F:SCO]SCONUM=[F:SCI]SCONUM : GIMP(5)=[F:SCO]POHFCY       : Endif
  When "GIMP(6)"    : If [F:SCO]SCONUM=[F:SCI]SCONUM : GIMP(6)=[F:SCO]MTOREF       : Endif
  When "BPRNUM"     : If [F:SCO]SCONUM=[F:SCI]SCONUM & [F:SCI]BPRNUM="" [F:SCI]BPRNUM=[F:SCO]BPRNUM Endif
  When Default
Endcase

Return
###########################################################################
#                                 IMPORT                                  #
###########################################################################

#------------------------------------------------------------------------------------#
# Chargement masques écrans, appelé directement depuis le traitement généré WWIxxxxx #
#------------------------------------------------------------------------------------#
$SAIMSK
If GREP="A"  Return : Endif
If GPEO_TRACE=2
  GPEO_ACTION="SAIMSK" : GPEO_PGM="PEOIMPORT" : Gosub TRACE_DETAILLEE
Endif
Case IMPFIC
  When "SCI"
    #----- Test rupture sur ligne document -----#
    If GPEO_NBLIG>0
      # Issue X3-38696 - 2017-06-30 by MUARN : import plusieurs lignes
      [F:SCIX]=[F:SCI]
      Gosub PEO_VALID
      # Issue X3-38696 - 2017-06-30 by MUARN : import plusieurs lignes
      [F:SCI]=[F:SCIX]
    Endif
    [M:SCOK]=[F:SCI]
    [F:SCIW]=[F:SCI]
  When "SCS" :
    [F:SCSW]=[F:SCS]
  When "SCO" :
    [M:SCOK]=[F:SCO]
    [F:SCOW]=[F:SCO]
  When "CAL" :
    Case [F:CAL]ABRFIC
       When "SCI"
         [F:CALI]=[F:CAL]
       When "SCS"
         [F:CALS]=[F:CAL]
    Endcase
Endcase
# Issue X3-38696 - 2017-09-21 by SR : To do here because in PEO-VALID GIMP are loaded with values of new line
If G_POHFCYOK :  [M:SCOK]POHFCY    = GIMP(5)      : [F:SCOW]POHFCY = GIMP(5)      : Endif
If G_MTOREFOK :  [M:SCOK]MTOREF    = GIMP(6)      : [F:SCOW]MTOREF = GIMP(6)      : Endif
If G_CODMAJOK :  [M:SCOK]CODMAJ    = GIMP(1)      :  WCODMAJ       = GIMP(1)      : Endif
If G_SCOSTAOK :  [M:SCOK]SCOSTA    = val(GIMP(2)) : [F:SCOW]SCOSTA = val(GIMP(2)) : Endif
If G_ORDDATOK
   Call SETDATE([M:SCOK]STRDAT,GIMP(3),[F:AOE]OPTDAT,WERR) From SUBIMPOBJ
   WSTRDAT = [M:SCOK]STRDAT
Endif
If G_RETDATOK
   Call SETDATE([M:SCOK]ENDDAT,GIMP(4),[F:AOE]OPTDAT,WERR) From SUBIMPOBJ
   WENDDAT = [M:SCOK]ENDDAT
Endif
# End issue X3-38696

GPEO_NBLIG+=1
Return

########################################################
# Ouvertures
########################################################
$IMP_OUVRE
Gosub OUVRE
Return

########################################################
$OUVRE
Local   Char    WMESSAGE(250)
# Issue X3-38696 - 2017-09-21 by SR :
Local     Integer  WERR : WERR=0
Local     Char     WCODMAJ(1)
Local     Date     WSTRDAT, WENDDAT
# End issue X3-38696

#----- Variables globales -----#
Global Integer  GPEO_TRACE : GPEO_TRACE = 1  : # Trace détaillée si =2
Global Char     GPEO_MESS(100), GPEO_PGM(GLONADC), GPEO_ACTION(30)
Global Integer  GPEO_NBLIG                     # Issue 90672 GA 06/2013
Global Integer  G_CODMAJOK, G_SCOSTAOK,G_ORDDATOK, G_RETDATOK,G_POHFCYOK,G_MTOREFOK
Global Date     G_DATE
Global Integer  OKCHAMP, NBERR
#If GUSER="GA" GPEO_TRACE=2 Endif
#
#Pour savoir les zones obligatoires sont paramétrées
Call TST_CHAMP("SCI","*1",G_CODMAJOK) From SUBIMPOBJ    : # Code mise à jour
Call TST_CHAMP("SCI","*2",G_SCOSTAOK) From SUBIMPOBJ    : # Code statut de l'ordre
Call TST_CHAMP("SCI","*3",G_ORDDATOK) From SUBIMPOBJ    : # Date commande
Call TST_CHAMP("SCI","*4",G_RETDATOK) From SUBIMPOBJ    : # Date réception
Call TST_CHAMP("SCI","*5",G_POHFCYOK) From SUBIMPOBJ    : # Site commande (facultatif)
Call TST_CHAMP("SCI","*5",G_MTOREFOK) From SUBIMPOBJ    : # Réseau MTO (Made To Order)(facultatif)
#
Gosub OPEN_FILES_SCO From SCOLIB
If clalev([M:SCOK])=0 : Local Mask SCOK      [SCOK] : Endif       # masque buffer maj automatique EO

# Issue 90672 GA 06/2013 importer des infos absentes du masque SCOK (PE à coder)
If !clalev([F:SCOW]) Local File SCOHEAD    [F:SCOW] Endif
If !clalev([F:SCIW]) Local File SCOITM     [F:SCIW] Endif
If !clalev([F:SCSW]) Local File SCOSRV     [F:SCSW] Endif
If !clalev([F:CALI]) Local File CPTANALIN  [F:CALI] Endif
If !clalev([F:CALS]) Local File CPTANALIN  [F:CALS] Endif

# Issue X3-38696 - 2017-06-30 by MUARN : import plusieurs lignes
If !clalev([F:SCIX]) Local File SCOITM     [F:SCIX] Endif

If clalev([F:FCY])<=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TUN])<=0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:ADP])<=0 : Local File ADOPAR     [ADP] : Endif
If clalev([F:ADW])<=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:TBO])<=0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:BOH])<=0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD])<=0 : Local File BOMD       [BOD] : Endif
If clalev([F:CAL])<=0 : Local File CPTANALIN  [CAL] : Endif
If clalev([F:PTR])<=0 : Local File PURTRS     [PTR] : Endif
If clalev([F:BPR])<=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPS])<=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPC])<=0 : Local File BPCUSTOMER [BPC] : Endif

Call FIND_GFCYDEF(6) From TRTX3   # FQ 54218
Gosub CHARG_PARAM
Call ECR_TRACE("OUVRE ACTION="+ACTION-"/"-GACTION-[F:SCI]ITMREF-num$([F:SCS]NETPRI),0) From GESECRAN
Return

###############################################
$CHARG_PARAM
# Transaction automatique
Global Char    GSCOPTRNUM (GLONTRS)
Call PARAM(GFCY,"SCOPTRNUM",GSCOPTRNUM) From ADOVAL
Read [F:PTR]PTR0 = 9;GSCOPTRNUM
If fstat : OK = 0 : Return : Endif
#----- Variables société
Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
Return

######################################################
# Réinitialisation après création (début de lecture)
$RAZCRE
If GPEO_TRACE=2
  GPEO_ACTION="RAZCRE" : GPEO_PGM="PEOIMPORT" : Gosub TRACE_DETAILLEE
Endif
Raz [M:SCOK]
Return

######################################################
$AP_IMPORT
If GPEO_TRACE=2
  GPEO_ACTION="AP_IMPORT" : GPEO_PGM="PEOIMPORT" : Gosub TRACE_DETAILLEE
Endif
Return
######################################################
$IMP_FERME
If GPEO_TRACE=2
  GPEO_ACTION="RAZCRE" : GPEO_PGM="PEOIMPORT" : Gosub TRACE_DETAILLEE
Endif
If GPEO_NBLIG>0 & [F:SCI]ITMREF<>""
   Gosub PEO_VALID
Endif
Kill OKCHAMP, NBERR
If dim(GPEO_MESS)>0  Kill GPEO_MESS,  GPEO_PGM, GPEO_ACTION                 : Endif
Return
######################################################
# Contrôles et mises à jour
$VALID
WDEBENR = adxseek("IMP")
If IMPFIN : OK = 0 : Return : Endif
# Issue 90672 GA 06/2013 importer des infos absentes du masque SCOK (PE à coder)
# => code déplacé en PEO_VALID, exécuté au changement d'EO
Return

######################################################
# Mises à jour de l'EO
$PEO_VALID
# Issue X3-38696 - 2017-09-21 by SR
#Local     Integer  WERR : WERR=0
#
[M:SCOK]        = [F:SCSW]
[M:SCOK]        = [F:SCOW]
[M:SCOK]        = [F:SCIW]  # Fichier prioritaire (SCONUM, etc ...)
[M:SCOK]CODTRS  = 1
[M:SCOK]MAJPEC  = 9
# Issue X3-38696 - 2017-09-21 by SR : at this time GIMP are already loaded with values for the new line
#If G_CODMAJOK : [M:SCOK]CODMAJ    = GIMP(1)      : Endif
#If G_SCOSTAOK : [M:SCOK]SCOSTA    = val(GIMP(2)) : Endif
#If G_ORDDATOK
#   #[M:SCOK]STRDAT    = val(GIMP(3))
#   Call SETDATE([M:SCOK]STRDAT,GIMP(3),[F:AOE]OPTDAT,WERR) From SUBIMPOBJ
#Endif
#If G_RETDATOK
#   #[M:SCOK]ENDDAT    = val(GIMP(4))
#   Call SETDATE([M:SCOK]ENDDAT,GIMP(4),[F:AOE]OPTDAT,WERR) From SUBIMPOBJ
#Endif
#If G_POHFCYOK : [M:SCOK]POHFCY    = GIMP(5)      : Endif
#If G_MTOREFOK : [M:SCOK]MTOREF    = GIMP(6)      : Endif
[M:SCOK]CODMAJ = WCODMAJ
[M:SCOK]STRDAT = WSTRDAT
[M:SCOK]ENDDAT = WENDDAT
# End issue X3-38696
Gosub CONTROLE_IMP
If !OK
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    GOK = 0
    Return
Endif
Call MAJ_SCO From SCOAUTLIB
If [M:SCOK]CODRET = 0
   Case [M:SCOK]CODMAJ
      When "C" :
             WMESSAGE = mess(641,197,1)-"["-mess([M:SCOK]SCOSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(233,197,1)
      When "M" :
             WMESSAGE = mess(641,197,1)-"["-mess([M:SCOK]SCOSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(232,197,1)
      When "A" :
             WMESSAGE = mess(641,197,1)-"["-mess([M:SCOK]SCOSTA,317,1)-"]"-[M:SCOK]SCONUM-mess(234,197,1)
   Endcase
   Call ECR_TRACE(WMESSAGE,0) From GESECRAN
Endif
# Issue X3-38696 - 2017-09-21 by SR :  ajout [M:SCOK]
Raz [F:SCIW],[F:SCSW],[F:SCOW],[M:SCOK]
Raz GPEO_NBLIG
Return

######################################################
# Contrôles
$CONTROLE_IMP
Local     Char     WFCY(GLONFCY)
Local     Integer  WALT
Local     Date     WDAT
Local     Char     WITM(GLONITM)
Local     Integer  TABTBO(3)
Local     Integer  WOK : WOK=2
# Verifier que le code de mise à jour est correct
If !find([M:SCOK]CODMAJ,"A","C","M")
         WMESSAGE = mess(205,193,1) - [F:SCO]SCONUM
         OK = 0
         Return
Endif

#Contrôle site: au moins un des 2 sites doit être précisé
If [M:SCOK]POHFCY = "" : [M:SCOK]POHFCY = [M:SCOK]PRHFCY : Endif
If [M:SCOK]PRHFCY = "" : [M:SCOK]PRHFCY = [M:SCOK]POHFCY : Endif

Call GETCPY([M:SCOK]POHFCY,"PTR",9,GSCOPTRNUM) From TRTX3CPT    # alimentation de GSOCIETE et GTYPGEN

Case [M:SCOK]CODMAJ
     When "C" : Raz [M:SCOK]SCONUM,SCILIN
                If !find([M:SCOK]PIO,1,2,3) : [M:SCOK]PIO = 1 : Endif
                #[M:SCOK]BPRNUM = [F:SCI]BPRNUM
                #Contrôle fournisseur
                If [M:SCOK]BPRNUM<>""
                  WOK = func BPRLIB.IS_BPS_ACTIVE([M:SCOK]BPRNUM)
                  If WOK<>2 : WMESSAGE = mess(196,194,1) : Endif
                Endif
                #Contrôle site
                If [M:SCOK]POHFCY<>[F:FCY]FCY
                  Read [F:FCY]FCY0 = [M:SCOK]POHFCY
                  If fstat : WMESSAGE = mess(23,100,1) : OK = 0 : Return : Endif
                Endif
                If [M:SCOK]STRDAT = [0/0/0]
                    WMESSAGE = mess(170,193,1) - num$([M:SCOK]STRDAT)
                    OK = 0
                    Return
                Endif
                If [M:SCOK]ENDDAT = [0/0/0] | [M:SCOK]ENDDAT < [M:SCOK]STRDAT
                    WMESSAGE = mess(171,193,1) - num$([M:SCOK]ENDDAT)
                    OK = 0
                    Return
                Endif
#
     When "M" : If [M:SCOK]SCILIN = 0 : [M:SCOK]SCILIN = 1000 : Endif
                Read [F:SCI]SCI0 = [M:SCOK]SCONUM;[M:SCOK]SCILIN
                # Une erreur s'est produite en mise à jour de l'ordre de sous-traitance !
                If fstat : WMESSAGE = mess(913,196,1) - [M:SCOK]SCONUM +"/"+ num$([M:SCOK]SCILIN)
                   OK = 0
                   Return
                Endif
                Read [F:SCO]SCO0 = [M:SCOK]SCONUM
                If fstat : WMESSAGE = mess(913,196,1) - [M:SCOK]SCONUM
                   OK = 0
                   Return
                Endif
                #Zone à zone regarder si la zone est renseignée dans le masque ou si on doit
                #récupérer celle du fichier
                If [M:SCOK]POHFCY= "" [M:SCOK]POHFCY = [F:SCI]POHFCY Endif
                If [M:SCOK]ITMREF= "" [M:SCOK]ITMREF = [F:SCI]ITMREF Endif
                If [F:SCO]SCOSTA  = 1 | [M:SCOK]SCOSTA = 0
                  [M:SCOK]SCOSTA  = [F:SCO]SCOSTA
                Endif
                If [M:SCOK]EXTQTY = 0 : [M:SCOK]EXTQTY = [F:SCI]EXTQTY : Endif
                [M:SCOK]PRVQTY    = [F:SCI]EXTQTY
                #Contrôle quantité prévue
                #Si la nouvelle qté prévue est inférieure à l'ancienne elle ne doit pas être
                #inférieure à la qté réalisée
                If [M:SCOK]EXTQTY < [M:SCOK]PRVQTY & [M:SCOK]EXTQTY < [F:SCI]CPLQTY
                   WMESSAGE = mess(168,193,1) - num$([M:SCOK]EXTQTY)
                   OK = 0
                   Return
                Endif
                # si le suivi a commencé on ne peut pas modifier la date de début
                If [M:SCOK]STRDAT = [0/0/0] : [M:SCOK]STRDAT = [F:SCO]ORDDAT
                Elsif [M:SCOK]STRDAT <> [F:SCO]ORDDAT & [F:SCI]SCITRKFLG > 3
                      WMESSAGE = mess(80,193,1)
                      OK = 0
                      Return
                Endif
                If [M:SCOK]ENDDAT = [0/0/0] : [M:SCOK]ENDDAT = [F:SCO]RETDAT : Endif
                If [M:SCOK]BOMALT = 0       : [M:SCOK]BOMALT = [F:SCI]BOMALT : Endif
                If [M:SCOK]PJT    = ""      : [M:SCOK]PJT    = [F:SCI]PJT    : Endif
                If [M:SCOK]LOT    = ""      : [M:SCOK]LOT    = [F:SCI]LOT    : Endif
                If !find([M:SCOK]PIO,1,2,3) : [M:SCOK]PIO    = [F:SCI]PIO : Endif
                If [M:SCOK]BPRNUM = ""      : [M:SCOK]BPRNUM = [F:SCI]BPRNUM : Endif
                [M:SCOK]VCRTYPORI = [F:SCI]VCRTYPORI
                [M:SCOK]VCRNUMORI = [F:SCI]VCRNUMORI
                [M:SCOK]VCRLINORI = [F:SCI]VCRLINORI
                [M:SCOK]WIPTYP    = 13
                [M:SCOK]WIPNUM    = [F:SCI]WIPNUM
#
    When "A" : Read [F:SCO]SCO0 = [M:SCOK]SCONUM
               If fstat : WMESSAGE = mess(151,193,1) - [M:SCOK]SCONUM
                   OK = 0
                   Return
               Endif
             # pas de suppression si en-cours ou plus
               If [F:SCO]SCOTRKFLG > 3
                   WMESSAGE = mess(169,193,1) - [F:SCO]SCONUM
                   OK = 0
                   Return
               Endif
               [M:SCOK]SCOSTA = [F:SCO]SCOSTA
#
Endcase
#
If [M:SCOK]CODMAJ = "A" : Return : Endif
#
#Contrôles communs à la création et à la modification
#
#Contrôle statut de l'ordre
If !find([M:SCOK]SCOSTA,1,2)
    WMESSAGE = mess(167,193,1) - num$([M:SCOK]SCOSTA)
    OK = 0
    Return
Endif
#Contrôle quantité prévue
If [M:SCOK]EXTQTY <= 0
   WMESSAGE = mess(168,193,1) - num$([M:SCOK]EXTQTY)
   OK = 0
   Return
Endif
#Contrôle article
Read [F:ITM]ITM0 = [M:SCOK]ITMREF
If fstat : WMESSAGE = mess(23,100,1) - [M:SCOK]ITMREF
   OK = 0
   Return
Endif
# Issue 90672 GA 06/2013 tous les ctrl site sont faits sur PRHFCY au lieu de POHFCY
#Contrôle article site
WFCY = [M:SCOK]PRHFCY
Read [ITF]ITF0=[M:SCOK]ITMREF;WFCY
If fstat
   #WMESSAGE = mess(45,193,1) - [M:SCOK]ITMREF + "/" + [M:SCOK]POHFCY
   WMESSAGE = mess(248,197,1) - [M:SCOK]ITMREF + "/" + WFCY
   OK = 0
   Return
Endif
#
#contrôle catégorie article etc ...
WITM=[M:SCOK]ITMREF
Raz GMESSAGE
Call CONTSCOITM(WFCY, 1) From SCOLIB
If GMESSAGE <> ""
   WMESSAGE = GMESSAGE - WITM + "/" + WFCY
   OK = 0
   Return
Endif
#
If [M:SCOK]STRDAT=[0/0/0]
   WDAT=date$
Else
   WDAT=[M:SCOK]STRDAT
Endif
#    Lecture nomenclature
Read [TBO]TBO0=3;[M:SCOK]BOMALT
If fstat : WMESSAGE = mess(23,100,1) + num$([M:SCOK]BOMALT) + num$(3) : OK = 0 : Return : Endif
Read [BOH]BOH0=WITM;[M:SCOK]BOMALT;3
If fstat
   WMESSAGE = mess(95,193,1) - WITM + "/" + num$([M:SCOK]BOMALT)+ "/" + WFCY
   OK = 0
   Return
Endif
Raz GMESSAGE
#contrôle nomenclature
Call CONTSCONOM(WFCY,WALT,WDAT,1) From SCOLIB
If WALT=0 | GMESSAGE <> ""
   WMESSAGE = GMESSAGE  - WITM + "/" + num$([M:SCOK]BOMALT)+ "/" + WFCY
   OK = 0
   Return
Endif
Return
#---------------------------------#
# Trace détaillée si GPEO_TRACE=2 #
#---------------------------------#
$TRACE_DETAILLEE
If GPEO_TRACE<>2  Return : Endif
If GPEO_PGM=""
  If find(GPEO_ACTION,"Trbegin","Commit","Rollback")
    GPEO_MESS="---"-mess(5,126,1)-GPEO_ACTION
  Else
    GPEO_MESS=GPEO_ACTION
  Endif
Else
  If GPEO_ACTION="AP_IMPORT"
    GPEO_ACTION+="("+[M:AOE1]FLGFIL([L]SEPNUM-1)+")"
  Endif
  GPEO_MESS=mess(27,115,1)-GPEO_ACTION+space$(22-len(GPEO_ACTION))+"From "-GPEO_PGM
Endif
Call ECR_TRACE(GPEO_MESS,0) From GESECRAN
Return

