#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTIACH22      Utilitaire de correction des liens          Module ACHAT #
#               sous-traitance sur les lignes de                         #
#               commande d'achat                              15/09/2010 #
# ---------------------------------------------------------------------- #
#   Charger dans l'enregistrement PORDERQ les champs suivants            #
#     [F:POQ]VCRTYPORI = 10                                              #
#   à partir de l'enregistrement MFGOPE contenant la clé ligne commande  #
#     [F:POQ]VCRNUMORI = [F:MFO]MFGNUM                                   #
#     [F:POQ]VCRLINORI = [F:MFO]OPENUM                                   #
#     [F:POQ]VCRSEQORI = [F:MFO]OPESPLNUM                                #
#   à partir du premier article de MFGITM contenant la clé de MFGOPE     #
#     [F:POQ]ITMREFORI = [F:MFI]MFGITM                                   #
##########################################################################


Call MAJ_UTIACH22
End


Subprog MAJ_UTIACH22
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH22 - Ajustement liens sous-traitance dans PORDERQ") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH22 : Ajustement liens sous-traitance dans PORDERQ") From LECFIC
  Call ECR_TIME("UTIACH22 : Starting process on folder "+DOSSIER) From DOSSUB
  Call EXE_UTIACH22(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH22(DOSSIER)
Value Char     DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90)
Local Integer  NBENR, NBCOR, NBMOD, NBCRE, NBPOQ, NBPTD
Local Char     CLE1(GLONVCR)
Local Shortint CLE2
Local Shortint CLE3
Local Char     CRITERE(150)
Local Integer COMPTEUR, STOP
Local Char     WPTHNUM(GLONPTH)
Local Integer  WPTDLIN
#-----
Local Char     WITM(GLONITM)
Local Libelle  WTYP
Local Char     WNUM(GLONVCR)
Local Integer  WLIN
Local Integer  WSEQ
#-----
Local Libelle  WFLAG1
Local Libelle  WFLAG2
#--------- Exemple de sélections sur numéros d'ordre de fabrication ----------#
# Traiter tous les nos d'OF         : WNUMOF="1=1"                            #
# Traiter le no d'OF aa             : WNUMOF="MFGNUM='aa'"                    #
# Traiter les nos d'OF aa, bb et cc : WNUMOF="find(MFGNUM,'aa','bb','cc')<>0" #
#-----------------------------------------------------------------------------#
Local Char     WNUMOF(240) : WNUMOF="1=1" : # WNUMOF = Numéro(s) d'OF à traiter
Local Libelle  WTRACE      : WTRACE=2     : # WTRACE=2 --> Trace détaillée
Local Libelle  WSIMUL      : WSIMUL=1     : # 0=normale, 1=simulation (pas de màj) 
#-----
#WNUMOF="1=1"
#WNUMOF="find(MFGNUM,'CAT02010036','INO01010177')<>0"
#-----
If WSIMUL
 Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
Else
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
#-----
If WNUMOF<>"1=1"
  WMSG="Sélection sur numéro d'OF :"-WNUMOF
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Ouverture des tables -----#
If !clalev([F:MFO])  Local File =DOSSIER+".MFGOPE"    [MFO] : Endif
If !clalev([F:MFI])  Local File =DOSSIER+".MFGITM"    [MFI] : Endif
If !clalev([F:POQ])  Local File =DOSSIER+".PORDERQ"   [POQ] : Endif
If !clalev([F:PTD])  Local File =DOSSIER+".PRECEIPTD" [PTD] : Endif
#----- Début du traitement -----#
Gosub TRT_PORDERQ
#----- Fin du traitement -----#
$FIN_UTIACH22
If WSIMUL
 Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
Else
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
#-----
WMSG ="Nombre de cdes introuvables ......:"-num$(NBPOQ)
Call ECR_TRACE(WMSG,0) From GESECRAN
WMSG ="Nombre de liens cde erronés ......:"-num$(NBMOD)
Call ECR_TRACE(WMSG,0) From GESECRAN
WMSG ="Nombre de liens cde créés ........:"-num$(NBCRE)
Call ECR_TRACE(WMSG,0) From GESECRAN
WMSG ="Nombre de liens rcp erronés ......:"-num$(NBPTD)-"(*) non corrigés !"
Call ECR_TRACE(WMSG,0) From GESECRAN
#-----
WMSG ="UTIACH22 : Number of processed records :"-num$(NBENR)
WMSG+=" corrected :"-num$(NBCOR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [MFO], [MFI], [POQ], [PTD]
End


#------------#
# Traitement #
#------------#
$TRT_PORDERQ
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, CLE3, NBENR, NBCOR, NBMOD, NBCRE, NBPOQ, NBPTD, STOP
#-----
$BOUCLE_MFO
If STOP=1
  STOP=2 : CRITERE ='MFGNUM="'+CLE1+'"'+' & OPENUM='+num$(CLE2)+' & OPESPLNUM>'+num$(CLE3)
Elsif STOP=2
  STOP=3 : CRITERE ='MFGNUM="'+CLE1+'"'+' & OPENUM>'+num$(CLE2)
Elsif STOP=3
  STOP=0 : CRITERE ='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [POQ]
  For [MFO] MFO0 Where evalue(CRITERE) & POHNUM<>"" & evalue(WNUMOF)
    #-----
    Raz WFLAG1, WFLAG2
    NBENR+=1
    Read [POQ] POQ0=[F:MFO]POHNUM;[F:MFO]POPLIN;[F:MFO]POPSEQ
    If fstat
      NBPOQ+=1
      If WTRACE=2
        WMSG=[F:MFO]POHNUM-num$([F:MFO]POPLIN)-num$([F:MFO]POPSEQ)-mess(360,197,1)
        Call ECR_TRACE(WMSG,1) From GESECRAN
      Endif
    Else
      Filter [MFI] Where MFGNUM=[F:MFO]MFGNUM
      Read [MFI] MFI0 First
      If fstat  Raz [F:MFI] : Endif
      Filter [MFI]
      #-----
      WITM=[F:MFI]ITMREF
      WTYP=10
      WNUM=[F:MFO]MFGNUM
      WLIN=[F:MFO]OPENUM
      WSEQ=[F:MFO]OPESPLNUM
      #----- Vérifier si les liens existants sont bons -----#
      If [F:POQ]VCRTYPORI<>0 | [F:POQ]VCRNUMORI<>"" | [F:POQ]VCRLINORI<>0 | [F:POQ]VCRSEQORI<>0
        If [F:POQ]VCRTYPORI<>10            |
&          [F:POQ]VCRNUMORI<>[F:MFO]MFGNUM |
&          [F:POQ]VCRLINORI<>[F:MFO]OPENUM
#&          [F:POQ]VCRSEQORI<>[F:MFO]OPESPLNUM
          #-----
          WMSG=[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)-"Liens cde erronés"
          Call ECR_TRACE(WMSG,1) From GESECRAN
          If WTRACE=2
            If [F:POQ]ITMREFORI<>WITM
              WMSG="- ITMREFORI :"-[F:POQ]ITMREFORI-"-->"-WITM
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:POQ]VCRTYPORI<>10
              WMSG="- VCRTYPORI :"-num$([F:POQ]VCRTYPORI)-"--> 10"
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:POQ]VCRNUMORI<>WNUM
              WMSG="- VCRNUMORI :"-num$([F:POQ]VCRNUMORI)-"-->"-num$(WNUM)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:POQ]VCRLINORI<>WLIN
              WMSG="- VCRLINORI :"-num$([F:POQ]VCRLINORI)-"-->"-num$(WLIN)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:POQ]VCRSEQORI<>WSEQ
              WMSG="- VCRSEQORI :"-num$([F:POQ]VCRSEQORI)-"-->"-num$(WSEQ) 
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
          Endif
          #-----
          NBMOD+=1
          WFLAG1=1
          #-----
        Endif
      #----- Les liens sont à créer -----#
      Else
        WMSG=[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)-"Liens cde manquants"
        Call ECR_TRACE(WMSG,1) From GESECRAN
        If WTRACE=2
          WMSG="- ITMREFORI :"-WITM
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WMSG="- VCRTYPORI : 10"
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WMSG="- VCRNUMORI :"-num$(WNUM)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WMSG="- VCRLINORI :"-num$(WLIN)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WMSG="- VCRSEQORI :"-num$(WSEQ) 
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        NBCRE+=1
        WFLAG1=1
      Endif
      #----- Vérification des réceptions de la commande -----#
      For [PTD] PTD2 Where POHNUM=[F:POQ]POHNUM
&                        & POPLIN=[F:POQ]POPLIN
&                        & POQSEQ=[F:POQ]POQSEQ
        If [F:PTD]ITMREFORI<>WITM |
&          [F:PTD]VCRTYPORI<>10   |
&          [F:PTD]VCRNUMORI<>WNUM |
&          [F:PTD]VCRLINORI<>WLIN
#&          [F:PTD]VCRSEQORI<>WSEQ
          #-----
          WMSG =[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
          WMSG-="Rcp"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"Liens réception erronés (*)"
          Call ECR_TRACE(WMSG,1) From GESECRAN
          If WTRACE=2
            If [F:PTD]ITMREFORI<>WITM
              WMSG="- ITMREFORI :"-[F:PTD]ITMREFORI-"-->"-WITM
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:PTD]VCRTYPORI<>10
              WMSG="- VCRTYPORI :"-num$([F:PTD]VCRTYPORI)-"--> 10"
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:PTD]VCRNUMORI<>WNUM
              WMSG="- VCRNUMORI :"-num$([F:PTD]VCRNUMORI)-"-->"-num$(WNUM)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:PTD]VCRLINORI<>WLIN
              WMSG="- VCRLINORI :"-num$([F:PTD]VCRLINORI)-"-->"-num$(WLIN)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            If [F:PTD]VCRSEQORI<>WSEQ
              WMSG="- VCRSEQORI :"-num$([F:PTD]VCRSEQORI)-"-->"-num$(WSEQ) 
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
          Endif
          #-----
          NBPTD+=1
          WFLAG2=1
          WPTHNUM=[F:PTD]PTHNUM
          WPTDLIN=[F:PTD]PTDLIN
          #-----
        Endif
        #----- Mise à jour de la ligne de réception si nécessaire -----#
#        If WFLAG2
#          COMPTEUR+=1
#          Update [PTD] Where PTHNUM=WPTHNUM
#&                          & PTDLIN=WPTDLIN
#&                      With ITMREFORI=WITM,
#&                           VCRTYPORI=10,
#&                           VCRNUMORI=WNUM,
#&                           VCRLINORI=WLIN,
#&                           VCRSEQORI=WSEQ
#          If fstat
#            WMSG=mess(13,100,1)-"PRECEIPTD"-WPTHNUM-num$(WPTDLIN)
#            Call ECR_TRACE(WMSG-"Error="+num$(fstat),1) From GESECRAN
#          Endif
#        Endif
        #-----
      Next
      #----- Mise à jour de la ligne de commande si nécessaire -----#
      If WFLAG1
        COMPTEUR+=1
        Update [POQ] Where POHNUM=[F:MFO]POHNUM
&                        & POPLIN=[F:MFO]POPLIN
&                        & POQSEQ=[F:MFO]POPSEQ
&                    With ITMREFORI=WITM,
&                         VCRTYPORI=10,
&                         VCRNUMORI=WNUM,
&                         VCRLINORI=WLIN,
&                         VCRSEQORI=WSEQ
        If fstat
          WMSG=mess(13,100,1)-"PORDERQ"-[F:MFO]POHNUM-num$([F:MFO]POPLIN)-num$([F:MFO]POPSEQ)
          Call ECR_TRACE(WMSG-"Error="+num$(fstat),1) From GESECRAN
        Else
          NBCOR+=1
        Endif
      Endif
      #-----
    Endif
    #-----
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:MFO]MFGNUM : CLE2=[F:MFO]OPENUM : CLE3=[F:MFO]OPESPLNUM
      STOP=1 : Break
    Endif
    #-----
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP  Goto BOUCLE_MFO : Endif
#-----
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2 & [F:ADS]MODULE(7)=2
  Call ECR_TRACE("UTIACH22 : Ajustement liens sous-traitance dans PORDERQ",0) From GESECRAN
  Call EXE_UTIACH22(DOSSIER)
Endif
#-----       
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2 & [F:ADS]MODULE(7)=2
  Call ECR_TRACE("UTIACH22 : Ajustement liens sous-traitance dans PORDERQ",0) From GESECRAN
  Call EXE_UTIACH22(DOSSIER)
Endif
#-----
End
