#<AdxTL>@(#)7.0.0.0 $Revision$
Call IMPRIME("CHARGES","") From ETAT
End

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVFIC
Gosub DECLARATION
Local Char PARAM(30)
Local Char VALEUR(30)
#Recup no de requete
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)

CRITCPY="1=1"
CRITFCY="1=1"
CRITDCH="OPTSAL<>6 & OPTSAL<>7"
For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "datdeb"      : If [L]VALEUR<>[0/0/0]
                         [L]VDATDEB =[L]VALEUR
                        Endif
   When "datfin"      : If [L]VALEUR<>[0/0/0]
                         [L]VDATFIN =[L]VALEUR
                        Endif
   When "cpy"         : If [L]VALEUR<>""
                         [L]CRITCPY -= '& [F:FGR]CPY="'+[L]VALEUR+'"'
                        Else
                         Call ERREUR (mess(68,10702,1)) From GESECRAN
                         GOK=0 : End
                        Endif
   When "fcydeb"      : If [L]VALEUR<>""
                         [L]CRITFCY -= '& [F:FGR]FCY>="'+[L]VALEUR+'"'
                        Endif
   When "fcyfin"      : If [L]VALEUR<>""
                         [L]CRITFCY -= '& [F:FGR]FCY<="'+[L]VALEUR+'"'
                        Endif
   When "detfcy"      : If [L]VALEUR="1": #Oui
                         [L]DETAIL =2
                        Else
                         [L]DETAIL =1
                        Endif
   When "declaration" : If [L]VALEUR<>""
                         [L]CRITDCH -= '& [F:DCH]EDTDCC="'+[L]VALEUR+'"'
                        Endif
   When "org"         : If [L]VALEUR<>""
                         [L]ORGANISME =[L]VALEUR
                        Endif
   When "arrbas"      : If [L]VALEUR="1" :#Oui
                         [L]ARRBASE= 2
                        Else
                         [L]ARRBASE=1
                        Endif
   When "arrmtt"      : If [L]VALEUR="1" :#Oui
                         [L]ARRMONTANT=2
                        Else
                         [L]ARRMONTANT=1
                        Endif
  Endcase
 Endif
Next

# Affectation du no de requête
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Gosub EFFACE
Call DEBTRANS From GLOCK
GOK = 1
Trbegin [TM2]
Gosub TR1
Commit
End


########################################
$OUVFIC
Gosub OUVRE From WPDEFTABLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:WAC])=0 : Local File TRVACC     [WAC] : Endif
If clalev([F:WAR])=0 : Local File TRVACCRAT  [WAR] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:HSP])=0 : Local File HISTOPAYE  [HSP] : Endif
If clalev([F:PCA])=0 : Local File CAISSE     [PCA] : Endif
If clalev([F:DCH])=0 : Local File DECCHARGE  [DCH] : Endif
If clalev([F:DCC])=0 : Local File DECCHARGE  [DCC] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:TM1])=0 : Local File TMPDCH1    [TM1] : Endif
If clalev([F:TM2])=0 : Local File TMPDCH2    [TM2] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
Return

########################################
$DECLARATION
Local Integer OK, R, LIG, X, Y, Z, SALOK, NBVEP
Local Char ORGCOURANT (GLONORG)
Local Char MATRI (GLONEML)
Local Date DATMAT
Local Char SITE (GLONFCY)
Local Decimal BASE, BASEPAT, BASESAL, LIMITE_BASE, MONTANT, TAUX, TAUXAT, BASEREG
Local Decimal DEPASSE_EXO
Local Integer DETAIL, FLAG
Local Char FLGEXO (20)
Local Char CODEXO (GLONEXO)(1..5)
Local Char EXO (GLONEXO)
Local Integer POPMAX
Local Integer NUMREQ
Local Char CRITCPY(100)
Local Char CRITFCY(100)
Local Char CRITDCH(100)
Local Char ORGANISME (GLONORG)
Local Date VDATDEB, VDATFIN, DREF, DAT1, DAT2
#72971
Local Date VCOTDEB,VCOTFIN
Local Integer ARRBASE, ARRMONTANT
Local Integer VDEBUT, VFIN

# Tableau des rubriques
Local Integer NRUB, IRUB
Local Char    RUBCOD(GLONRUB)(1..100)
Local Integer TAUX_AT(1..100)
Local Integer TYPECAL(1..100)
Local Integer FLGQTY(1..100)
Local Decimal QTY

Local Char FLGREG
Local Integer REGUL

Local Char CTR(GLONHRCTR)

#05/12/08 - 31032
Local Integer SEPARE
Local Decimal MTTSAL, TXSAL, MTTPAT, TXPAT
#66903
Local Decimal MTTREGPAT, MTTREGSAL
# Appelé par l'extraction Ducs donc test du Dim !
If dim ([M]RPTCOD)>=0 & [M]RPTCOD="DCHARGES2"
 SEPARE=1
Else
 SEPARE=0
Endif
Return

########################################
$EFFACE
Trbegin [TM1]
 Delete [F:TM1] Where USR=GUSER
Commit
Trbegin [TM2]
 Delete [F:TM2] Where USR=GUSER & DAT<=date$
Commit
Return

########################################
$TR1
LIG=1
For [F:FGR]FGR0 Where evalue (CRITCPY)& evalue(CRITFCY)
 Gosub REINIT
 Read [F:FCY]FCY0 = [F:FGR]FCY
 If DETAIL=2
  SITE=[F:FGR]FCY
 Else
  SITE=[F:FGR]CPY
 Endif
 For [F:DCH]DCH1 Where evalue(CRITDCH)
  Gosub REINIT
  Gosub RECUP_RUB
  If OK =1
   #87135 : CICE
    Read[F:ADI]CODE=377;[F:DCH]CODDCS
    If !fstat
      If [F:ADI]A2='400'
        Gosub TR_CICE
      Else
       For [F:VEP]VEP0(1) Where PYRDAT>=VDATDEB & PYRDAT<=VDATFIN & FCY=[F:FCY]FCY & STA>1
        NBVEP=0
        MATRI=[F:VEP]EMP
        Read [ID]ID0=MATRI
        #63102 : Lectures inutiles = ralentissements
        If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
        #
        For [F:VEP]VEP0
         DATMAT=[F:VEP]ENDDAT
         CTR=[F:VEP]CTRNUM
         #63102 : Lectures inutiles = ralentissements
         #Gosub LECEMP From WPDEFTABLE
         Gosub LECEMP
         FLAG=1 :  DREF=[F:VEP]PYRDAT
         Gosub CODEXO
         Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGCOURANT,[F:DCH]CAI-1) From SUBORG
         If ORGCOURANT<>"" & (ORGANISME="" or ORGANISME=ORGCOURANT)
          Gosub POPULATION
          If SALOK
           Gosub REINIT From INITDCH
           For R=1 To NRUB
            Read[RUB]RUB0=GCURLEG;RUBCOD(R)
            If fstat : Break : Endif
            VDEBUT=0 : VFIN=0
            Case TYPECAL(R)
             When 1 : VDEBUT=1 : VFIN=1 :#PS
             When 2 : VDEBUT=2 : VFIN=2 :#PP
             When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
            Endcase
            If VDEBUT
             Gosub RECUP_AT
             For I=VDEBUT To VFIN
              Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I
              If !fstat
               If FLGQTY(R)=2  :# Une quantité = Base
                 QTY+=[F:HSP]BAS
               Else
                TAUX+=[F:HSP]RAT
                If I=1 :#salarial
                 BASESAL=[F:HSP]BAS
                Else   :#patronal
                 BASEPAT=[F:HSP]BAS
                Endif
                MONTANT+=[F:HSP]AMT
               Endif
              Endif
              Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I+6
              If !fstat & FLGQTY(R)<>2 :#pas une quantité
               BASEREG+=[F:HSP]AMT
              Endif
             Next I
             LIMITE_BASE=0
             If [F:DCH]TYPBAS=2 :#cas particulier
              Gosub CAS_PART
             Endif
             Gosub AFFECT_BASE
             BASESAL=0 : BASEPAT=0
            Endif
           Next R
           If BASE<>0
            FLGREG=""
            REGUL=1
            #87135: Loi CICE
            Gosub LOI_CICE
            Gosub ECRIT_LIGNES
           Endif
           If BASEREG<>0 :#Ecrire une 2ième ligne
            BASE=BASEREG
            TAUX=100 : TAUXAT=0
            MONTANT=BASEREG
            FLGREG="("+left$(mess(101,10702,1),1)+")" :#(R) pour régularisations
            REGUL=2
            Gosub ECRIT_LIGNES
           Endif
          Endif
         Endif
        Next :#VEP
       Next :#VEP
      Endif
     Endif
  Endif
 Next :#DCH
Next : #FGR
If ARRBASE=2 or ARRMONTANT=2
 Gosub ARRONDIR
Endif
Return

########################################
$TR_CICE
Local Date DATDEBCICE
Local Char DMA (2)
Raz DMA
DMA=func AFNC.PARAM("DMA", [F:FCY]FCY)
If DMA='' : DMA='12' : Endif
If DMA='12'
 DATDEBCICE=gdat$(1,1,year(VDATFIN))
Else
  If month(VDATFIN)=val(DMA)+1
   DATDEBCICE=gdat$(1,month(VDATFIN), year(VDATFIN))
  Else
  DATDEBCICE=gdat$(1,val(DMA)+1,year(VDATFIN)-1)
 Endif
Endif
For [F:VEP]VEP0(1) Where PYRDAT>=DATDEBCICE & PYRDAT<=VDATFIN & FCY=[F:FCY]FCY & STA>1
 NBVEP=0
 MATRI=[F:VEP]EMP
 Read [ID]ID0=MATRI
 #63102 : Lectures inutiles = ralentissements
 If [F:DCH]PEO<>"" : Read [AD]AD0=MATRI : Endif
 #
 For [F:VEP]VEP0
  DATMAT=[F:VEP]ENDDAT
  CTR=[F:VEP]CTRNUM
  #63102 : Lectures inutiles = ralentissements
  #Gosub LECEMP From WPDEFTABLE
  Gosub LECEMP
  FLAG=1 :  DREF=[F:VEP]PYRDAT
  Gosub CODEXO
  Call ORGANISME ([F:ID]REFNUM,[F:FCY]FCY,[F:VEP]CTRNUM,[L]ORGCOURANT,[F:DCH]CAI-1) From SUBORG
  If ORGCOURANT<>"" & (ORGANISME="" or ORGANISME=ORGCOURANT)
    Gosub POPULATION
    If SALOK
      Gosub REINIT From INITDCH
      For R=1 To NRUB
        Read[RUB]RUB0=GCURLEG;RUBCOD(R)
        If fstat : Break : Endif
        VDEBUT=0 : VFIN=0
        Case TYPECAL(R)
          When 1 : VDEBUT=1 : VFIN=1 :#PS
          When 2 : VDEBUT=2 : VFIN=2 :#PP
          When 3 : VDEBUT=1 : VFIN=2 :#PS+PP
        Endcase
        If VDEBUT
          Gosub RECUP_AT
          For I=VDEBUT To VFIN
           Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I
           If !fstat
             If FLGQTY(R)=2  :# Une quantité = Base
               QTY+=[F:HSP]BAS
             Else
               TAUX+=[F:HSP]RAT
               If I=1 :#salarial
                 BASESAL=[F:HSP]BAS
               Else   :#patronal
                 BASEPAT=[F:HSP]BAS
               Endif
               MONTANT+=[F:HSP]AMT
             Endif
           Endif
           Read [HSP]HSP3 = [F:VEP]BUL;RUBCOD(R);I+6
           If !fstat & FLGQTY(R)<>2 :#pas une quantité
             BASEREG+=[F:HSP]AMT
           Endif
          Next I
          LIMITE_BASE=0
          If [F:DCH]TYPBAS=2 :#cas particulier
            Gosub CAS_PART
          Endif
          Gosub AFFECT_BASE
          BASESAL=0 : BASEPAT=0
        Endif
      Next R
      If BASE<>0
        FLGREG=""
        REGUL=1
        #87135: Loi CICE
        Gosub LOI_CICE
        Gosub ECRIT_LIGNES
      Endif
      If BASEREG<>0 :#Ecrire une 2ième ligne
        BASE=BASEREG
        TAUX=100 : TAUXAT=0
        MONTANT=BASEREG
        FLGREG="("+left$(mess(101,10702,1),1)+")" :#(R) pour régularisations
        REGUL=2
        Gosub ECRIT_LIGNES
      Endif
    Endif
  Endif
 Next :#VEP
Next :#VEP
Return

########################################
$RECUP_RUB
OK=1
Raz RUBCOD,TAUX_AT, NRUB, TYPECAL,FLGQTY
For R=0 To [F:DCH]NUMRUB-1
 If !find([F:DCH]CODRUB(R),RUBCOD(1..NRUB))
  NRUB += 1
  If NRUB>100
   Call ERREUR("Maximum de rubriques dépassé"-"("+num$(100)+")") From GESECRAN
   OK=0 : Break
  Endif
  RUBCOD(NRUB) =[F:DCH]CODRUB(R)
  TAUX_AT(NRUB)=[F:DCH]ACCWRK(R)
  TYPECAL(NRUB)=[F:DCH]TYPCAL(R)
  FLGQTY(NRUB) =[F:DCH]FLGQTY(R)
 Endif
Next R
Return

########################################
$RECUP_AT
If TAUX_AT(R)=2 :#prendre le taux at
 TAUXAT=0
 Read[F:WAC]WAC0=[F:HRCTR]RSKWRK
 #DBA le 07/10/04 : Historisation des taux AT.
 If !fstat
  Filter [F:WAR] Where CODWAC=[F:WAC]CODWAC & DATWAC<=[F:VEP]PYRDAT
  Read [F:WAR]WAR0 Last
  Filter [F:WAR]
  If !fstat : TAUXAT=[F:WAR]RATWAC : Endif
 Endif
Endif
Return

########################################
$CAS_PART
LIMITE_BASE=999999
Raz DEPASSE_EXO
Read[F:DCC]DCH0=[F:DCH]CODDCC
If !fstat
 For X=0 To [F:DCC]NUMRUB-1
  Raz FLGEXO   :# sert à détecter si Part Sal Et Pat sur 1 rub.
  For [F:HSP]HSP3 Where BUL=[F:VEP]BUL & RUB=[F:DCC]CODRUB(X)
   #44721
   #If [F:HSP]TYP=1 or [F:HSP]TYP=2
   If [F:HSP]TYP=1 or ([F:HSP]TYP=2 & FLGEXO<>"")
    FLGEXO += string$([F:HSP]TYP=1,"*")
    FLGEXO += string$([F:HSP]TYP=2,"*")
    #Si les bases<0 (pas d'une extourne) alors il faut prendre le min des valeur absolue donc le max
    If [F:HSP]BAS<0 & LIMITE_BASE<0
     LIMITE_BASE=max(arr([F:HSP]BAS,0.001),LIMITE_BASE)
    Else
     LIMITE_BASE=min(arr([F:HSP]BAS,0.001),LIMITE_BASE)
    Endif
   Endif
  Next
  DEPASSE_EXO+=(FLGEXO="**")
 Next X
Endif
If !DEPASSE_EXO
 LIMITE_BASE=0
Endif
Return

########################################
$CODEXO
Raz CODEXO, DAT1, DAT2
# [F:HRCTR] est en ligne grace au LECEMP
For Y=1 To 4
 EXO=evalue("[F:HRCTR]EXOCOD"+num$(Y))
 If EXO<>""
  DAT1=evalue("[F:HRCTR]EXOSTR"+num$(Y))
  DAT2=evalue("[F:HRCTR]EXOEND"+num$(Y))
  If (DAT1="00/00/00" or DREF>=DAT1) & (DAT2="00/00/00" or DREF<=DAT2)
   CODEXO(Y)=EXO
  Endif
 Endif
Next Y

Filter [HRPOA] Where COD<>"" & REFNUM=[F:VEP]EMP & CTRNUM=[F:VEP]CTRNUM & CTRDAT=[F:VEP]CTRDAT
If rowcount([HRPOA])>0 
 POPMAX=min(rowcount([HRPOA]),32767)
Else
 POPMAX=func AFNC.ACTIV('NBPOP')
Endif
Local Char CODPOP (GLONPOP)(1..POPMAX)
Raz CODPOP
Z=1
For [HRPOA]POA0 
 CODPOP(Z)=[HRPOA]COD
 Z+=1
Next
Filter [HRPOA]
Return

########################################
$POPULATION
SALOK=1
If [F:DCH]PEO<>""
 SALOK *= evalue([F:DCH]PEO)
Endif
Return

#43994 & 44002
########################################
$AFFECT_BASE
Case TYPECAL(R)
When 1 :
  If BASESAL
   If [F:DCH]TYPBAS=2
    BASE=BASESAL-LIMITE_BASE
   Else
    BASE=BASESAL
   Endif
  Endif
 When 2
  If BASEPAT
   BASE=BASEPAT
  Endif
 When 3
  # Pas un cas particulier
  If [F:DCH]TYPBAS=2
   If DEPASSE_EXO & BASESAL>0 & BASEPAT>0
    BASESAL=LIMITE_BASE
    BASEPAT=LIMITE_BASE
   Endif
  Else
   If BASESAL & !BASEPAT
    BASE=BASESAL
   Elsif BASEPAT & !BASESAL
    BASE=BASEPAT
   Endif
  Endif
  If BASESAL & BASEPAT
   #Si les bases<0 (pas d'une extourne) alors il faut prendre le min des valeur absolue donc le max !
   If BASESAL<0 & BASEPAT<0
    BASE=max(BASEPAT, BASESAL)
   Else
    BASE=min(BASEPAT, BASESAL)
   Endif
  Endif
Endcase
#Recalcul du montant si la base a changée
If LIMITE_BASE<>0
 MONTANT=(BASE*TAUX)/100
 #05/12/08 - 31032
 If SEPARE
  MTTSAL=(BASE*TXSAL)/100
  MTTPAT=(BASE*TXPAT)/100
 Endif
Endif
Return

########################################
$ECRIT_LIGNES
Gosub LOI_TEPA
FLAG=0 : NBVEP+=1
Raz [F:TM2]
For[F:TM2]TM20 Where USR=GUSER & NUMREQ=[L]NUMREQ & DCHFCY=SITE & DCHCAI=[F:DCH]CAI & DCHORG=ORGCOURANT & CODDCC=[F:DCH]CODDCC
 If [F:TM2]WACRAT=TAUXAT & [F:TM2]FLGREG=REGUL & (([F:TM2]RAT=TAUX-TAUXAT) | ([F:DCH]CAI=GINDURS & ([F:ADI]A2="003" |[F:ADI]A2="004"| [F:ADI]A2="005")))
  #Même taux donc même ligne...
  FLAG=1
  [F:TM2]BAS+=BASE
  [F:TM2]AMT+=MONTANT
  #Quantité pour Heures supp (Loi TEPA)
  [F:TM2]QTY2+=QTY
#  If  NBVEP=1 :#Si le salarié a plusieurs payes on ne le compte qu'une fois.
#   If [F:ID]CIV=1
#    [F:TM2]NBRMEN+=1
#    [F:TM2]NBREMP+=1
#   Else
#    [F:TM2]NBRWOM+=1
#    [F:TM2]NBREMP+=1
#   Endif
#  Endif

#87135: CICE
  If [F:ADI]A2="400" & CODDCC=[F:DCH]CODDCC
   If NBVEP=1 & BASE>0
    If [F:ID]CIV=1
      [F:TM2]NBRMEN+=1
      [F:TM2]NBREMP+=1
    Else
      [F:TM2]NBRWOM+=1
      [F:TM2]NBREMP+=1
    Endif
   Elsif BASE<0
    If [F:ID]CIV=1
      [F:TM2]NBRMEN-=1
      [F:TM2]NBREMP-=1
    Else
      [F:TM2]NBRWOM-=1
      [F:TM2]NBREMP-=1
    Endif
    NBVEP=0
   Endif
  Else
   If NBVEP=1 & CODDCC=[F:DCH]CODDCC
    If [F:ID]CIV=1
      [F:TM2]NBRMEN+=1
      [F:TM2]NBREMP+=1
     Else
      [F:TM2]NBRWOM+=1
      [F:TM2]NBREMP+=1
     Endif
   Endif
  Endif
#

  Rewrite [F:TM2]
  If fstat<>0
   GOK = 0 : Call FSTA("TM2") From GLOCK : Break
  Endif
  Break
  If GOK<1 : Break : Endif
 Endif
Next
If GOK<1 : Goto AB_TR1 : Endif
If FLAG=0
 [F:TM2]DAT=date$
 [F:TM2]USR=GUSER
 [F:TM2]NUMREQ=[L]NUMREQ
 [F:TM2]DCHFCY=SITE
 [F:TM2]DCHCAI=[F:DCH]CAI
 [F:TM2]DCHORG=ORGCOURANT
 [F:TM2]CODDCC=[F:DCH]CODDCC
 [F:TM2]NUMLIG=LIG
 LIG+=1
 [F:TM2]NUMORD=[F:DCH]NUMORD
 [F:TM2]CODLIG=[F:DCH]CODEDT1+[F:DCH]CODEDT2
 [F:TM2]DESLIG=FLGREG-[F:DCH]DESEDT
 [F:TM2]FLGREG=REGUL
 [F:TM2]BAS=BASE
 [F:TM2]AMT=MONTANT
 #Quantité pour Heures supp (Loi TEPA)
 [F:TM2]QTY2=QTY
 [F:TM2]WACRAT=TAUXAT
 Gosub WR_TEPA
 [F:TM2]TOTRAT=[F:TM2]RAT+[F:TM2]WACRAT
 If [F:ID]CIV=1
  [F:TM2]NBRMEN=1
  [F:TM2]NBRWOM=0
  [F:TM2]NBREMP=1
 Else
  [F:TM2]NBRMEN=0
  [F:TM2]NBRWOM=1
  [F:TM2]NBREMP=1
 Endif
 Write [F:TM2]
 If fstat<>0
  GOK = 0 : Call FSTA("TM2") From GLOCK : Return
 Endif
 If GOK<1 : Goto AB_TR1 : Endif
Endif
Return

########################################
$LOI_TEPA
Read[F:ADI]CODE=10377;[F:DCH]CODDCS
If fstat : Raz [F:ADI] : Endif
If [F:DCH]CAI=GINDURS & [F:ADI]A2="003"
 If [F:DCH]OPTSAL=1
  TAUX=0 : MONTANT=0
  If REGUL=2 : BASE=0 : Endif
  #05/12/08 - 31032
  If SEPARE :  TXSAL=0 : MTTSAL=0 : TXPAT=0 : MTTPAT=0 : Endif
 Else
  # Signe BASE inverse du signe MONTANT !
  If BASE>=0
   MONTANT=abs(MONTANT)*-1
  Else
   MONTANT=abs(MONTANT)
  Endif
  #05/12/08 - 31032
  If SEPARE :  MTTSAL=MONTANT : MTTPAT=0 : Endif
 Endif
Endif
Return

########################################
$WR_TEPA
Read[F:ADI]CODE=10377;[F:DCH]CODDCS
If fstat : Raz [F:ADI] : Endif
#Pas de taux pour Heures supp (Loi TEPA)
If [F:DCH]CAI<>GINDURS | ([F:ADI]A2<>"003" & [F:ADI]A2<>"004" & [F:ADI]A2<>"005")
 [F:TM2]RAT=TAUX-TAUXAT
Else
 [F:TM2]RAT=100
Endif
Return

########################################
$LOI_CICE
Read[F:ADI]CODE=377;[F:DCH]CODDCS
If [F:ADI]A2="400"
    TAUX=0
    MONTANT=0
    TXSAL=0
    TXPAT=0
    MTTSAL=0
    MTTPAT=0
Endif
Return

########################################
$REINIT
BASE=0
TAUX=0
MONTANT=0
TAUXAT=0
BASEREG=0
QTY=0
#18/11/09 - 31032 + 66903
If SEPARE :  TXSAL=0 : MTTSAL=0 : TXPAT=0 : MTTPAT=0 : MTTREGPAT=0 : MTTREGSAL=0 : Endif
Return

########################################
$ARRONDIR
For[F:TM2]TM20 Where NUMREQ=[L]NUMREQ & USR=GUSER
 If ARRBASE=2
  [F:TM2]BAS=arr([F:TM2]BAS,1)
 Endif
 If ARRMONTANT=2
  [F:TM2]AMT=arr([F:TM2]AMT,1)
  #05/12/08 - 31032
  If SEPARE
   [F:TM2]AMTSAL=arr([F:TM2]AMTSAL,1)
   [F:TM2]AMTPAT=arr([F:TM2]AMTPAT,1)
  Endif
 Endif
 Rewrite[F:TM2]
Next
Return

########################################
$AB_TR1
Rollback
Return

#63102 = LECEMP From WPDEFTABLE light !
########################################
$LECEMP
If CTR<>''
 Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [HRCTR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [HRCTR]CTR1 Last
If fstat : Raz [F:HRCTR] : Endif
Filter [HRCTR]
Return
