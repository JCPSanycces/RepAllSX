#********************************************************************
# Funprog FORMATVAL
#********************************************************************
#
#* Format the given string related to a known property into a specific defined format
#*
#* @param WPROPERTY
#* @param WVALUE
#* @return WSTR
#*!
Funprog FORMATVAL(WPROPERTY, WVALUE)
Value Char WPROPERTY
Value Char WVALUE
  Local Char WSTR(250)
  Case WPROPERTY
    When "CODE"       : WSTR = format$("Kv4:20X" ,toupper(WVALUE))
    When "BPAADD"     : WSTR = format$("Kv4:15X" ,toupper(WVALUE))
    When "BPANUM"     : WSTR = format$("Kv4:15X" ,toupper(WVALUE))
    When "BPRNUM"     : WSTR = format$("Kv4:15X" ,toupper(WVALUE))
    When "CPY"        : WSTR = format$("Kv4:5X"  ,toupper(WVALUE))
    When "FCY"        : WSTR = format$("Kv4:15X" ,toupper(WVALUE))
    When "PTCCOD"     : WSTR = format$("Kv4:20X" ,toupper(WVALUE))
    When "CATCOD"     : WSTR = format$("Kv4:20X" ,toupper(WVALUE))
    When "PARCOD"     : WSTR = format$("Kv4:30X" ,toupper(WVALUE))
    When "SAGEDICOD"  : WSTR = format$("Kv4:12"  ,toupper(WVALUE))
    When "FLOCOD"     : WSTR = format$("Kv4:20X" ,toupper(WVALUE))
    When "FLOREL"     : WSTR = format$("Kv4:5X"  ,toupper(WVALUE))
    When "MSGCOD"     : WSTR = format$("Kv4:20X" ,toupper(WVALUE))
    When "MSGREL"     : WSTR = format$("Kv4:5X"  ,toupper(WVALUE))
    When "MSGSEL"     : WSTR = format$("KTv2:250X",WVALUE)
    When "MSGLNKEXP"  : WSTR = format$("KTv2:60X" ,WVALUE)
    When "MSGLNKSEL"  : WSTR = format$("KTv2:60X" ,WVALUE)
    When "EXPRESSION" : WSTR = format$("KTv2:250X",WVALUE)
    When "FLDVAL1"    : WSTR = format$("Kv4:250X",toupper(WVALUE))
    When "FLDVAL2"    : WSTR = format$("Kv4:250X",toupper(WVALUE))
  Endcase
End WSTR




#********************************************************************
# Funprog CAR_ISNUM
#********************************************************************
#
#* Check the imput character is a numeric or not
#* @param WCAR    --> Character
#* @return WOK    --> Status [V]CST_AOK/[V]CST_AERROR
#*!
Funprog CAR_ISNUM(WCAR) #0 to 9
Value Char WCAR
  Local Integer WOK
  WOK = [V]CST_AOK
  If len(WCAR)=1
    If format$("K:1#",WCAR) = WCAR
      WOK = [V]CST_AOK
    Else
      WOK = [V]CST_AERROR
    Endif
  Else
    WOK = [V]CST_AERROR
  Endif
End WOK

Funprog STR_ISNUM(WSTR)
Value Char WSTR
  Local Integer WOK :   WOK = [V]CST_ATRUE
  Local Integer I
  Local Char WCAR(1)
  For I = 1 To len(WSTR)
    WCAR = mid$(WSTR, I, 1)
    If func CAR_ISNUM(WCAR) <> [V]CST_AOK
      WOK = [V]CST_AFALSE
      Break
    Endif
  Next I
End WOK


#********************************************************************
# Function CAR_ISCHAR
#********************************************************************
#
#* Check the imput character is an alpha (A to Z) or not
#* @param WCAR    --> Character
#* @return WOK    --> Status [V]CST_AOK/[V]CST_AERROR
#*!
Funprog CAR_ISCHAR(WCAR) #A to Z
Value Char WCAR
  Local Integer WOK
  WOK = [V]CST_AOK
  If len(WCAR)=1
    WCAR = toupper(WCAR)
    If format$("K:1L",WCAR) = WCAR
      WOK = [V]CST_AOK
    Else
      WOK = [V]CST_AERROR
    Endif
  Else
    WOK = [V]CST_AERROR
  Endif
End WOK

#********************************************************************
# Function CAR_ISCHARORNUM
#********************************************************************
#
#* Check the imput character is an alpha (A to Z) or a numeric or not
#* @param WCAR    --> Character
#* @return WOK    --> Status [V]CST_AOK/[V]CST_AERROR
#*!
Funprog CAR_ISCHARORNUM(WCAR)
Value Char WCAR
  Local Integer WOK
  WOK = [V]CST_AOK
  WOK = func CAR_ISNUM(WCAR)
  If WOK <> [V]CST_AOK
    WOK = func CAR_ISCHAR(WCAR)
  Endif
End WOK

#********************************************************************
# Function STRCMP
#********************************************************************
#
#* Compare two strings
#* @param WCH1    --> String 1
#* @param WCH2    --> String 2
#* @return WOK    --> Status (0) if WCH1 = WCH2, (1) if WCH1 < WCH2 in alphabetical order, (-1) if WCH1 > WCH2 in alphabetical order
#*!
Funprog STRCMP(WCH1, WCH2)
Value Char WCH1
Value Char WCH2

  Local Integer WOK, WMOD, I
  Local Char WSTR1(250)
  Local Char WSTR2(250)
  Local Char WCAR(1)

  If len(WCH1)>=len(WCH2)
    WMOD = 1 : WSTR1 = WCH1 : WSTR2 = WCH2
  Else
    WMOD = 2 : WSTR1 = WCH2 : WSTR2 = WCH1
  Endif

  For I = 1 To len(WSTR2)
    If mid$(WSTR1, I, 1) > mid$(WSTR2, I, 1)
      WOK = 1 #STR1 doit être apres
      Break
    Elsif mid$(WSTR1, I, 1) < mid$(WSTR2, I, 1)
      WOK = -1 #STR1 doit être avant
      Break
    Else
      WOK = 0
    Endif
  Next I
  If WOK = 0 and len(WSTR1) > len(WSTR2)
    WOK = 1 #STR1 est forcement apres
  Endif

  If WMOD = 1
    If WOK = 1
      WOK = 1
    Elsif WOK = -1
      WOK = -1
    Endif
  Elsif WMOD = 2
    If WOK = 1
      WOK = -1
    Elsif WOK = -1
      WOK = 1
    Endif
  Endif

End WOK

#********************************************************************
# Function STR_VIRECAR
#********************************************************************
#
#* Delete specials characters : 10 and 13
#* @param WSTR    --> String
#* @return WSTROK --> String without special characters
#*!
Funprog STR_VIRECAR(WSTR)
Value Char WSTR
  Local Integer I
  Local Char WSTROK(250)
  Local Char WCAR(1)
  For I = 1 To len(WSTR)
    WCAR = mid$(WSTR, I, 1)
    If ascii(mid$(WSTR, I, 1)) = 13 or ascii(mid$(WSTR, I, 1)) = 10
      WCAR = ""
    Endif
      WSTROK = WSTROK+WCAR
  Next I
  WSTROK = vireblc(WSTROK,1)
End WSTROK

Funprog STR_VIRECAR2(WSTR)
Value Char WSTR
  Local Integer I
  Local Char WSTROK(250)
  Local Char WCAR(1)
  For I = 1 To len(WSTR)
    WCAR = mid$(WSTR, I, 1)
    If ascii(mid$(WSTR, I, 1)) >= 0 and ascii(mid$(WSTR, I, 1)) <= 31
      WCAR = ""
    Endif
    WSTROK = WSTROK+WCAR
  Next I
  WSTROK = vireblc(WSTROK,1)
End WSTROK

Funprog STR_VIRECAR3(WSTR)
Value Char WSTR
  Local Integer I
  Local Char WSTROK(250)
  Local Char WCAR(1)
  For I = 1 To len(WSTR)
    WCAR = mid$(WSTR, I, 1)
    If ascii(mid$(WSTR, I, 1)) = 39 or ascii(mid$(WSTR, I, 1)) = 92
      WCAR = ""
    Endif
    WSTROK = WSTROK+WCAR
  Next I
  WSTROK = vireblc(WSTROK,1)
End WSTROK

Funprog STR_GIVEASCII(WSTR)
Value Char WSTR
  Local Integer I
  Local Char WSTROK(250)
  Local Char WCAR(1)
  Local Char TMP(250) : TMP = ""
  For I = 1 To len(WSTR)
    WCAR = mid$(WSTR, I, 1)
    TMP = TMP+'*'+num$(ascii(WCAR))
  Next I
  WSTROK = TMP
End WSTROK


#********************************************************************
# Function STR_INVERT
#********************************************************************
#
#* Invert the string : ABCD will be DCBA
#* @param WSTR      --> String
#* @return WSTR_INV --> String inverted
#*!
Funprog STR_INVERT(WSTR)
Value Char    WSTR
  Local Integer I, WSIZE_TMP
  Local Char WSTR_INV(len(WSTR))
  Local Char WSTR_TMP(len(WSTR))
  WSTR_INV = ''
  WSTR_TMP = WSTR
  WSIZE_TMP = len(WSTR_TMP)
  For I = 0 To len(WSTR)-1
    WSTR_INV = WSTR_INV + right$(WSTR_TMP,len(WSTR_TMP))
    WSIZE_TMP = WSIZE_TMP-1
    WSTR_TMP = left$(WSTR_TMP, WSIZE_TMP)
  Next I
End WSTR_INV


#********************************************************************
# Funprog CATEGORY_IS_AUTHORIZED
#********************************************************************
#
#* Check if the category is enabled
#*
#* @param WPARCOD
#* @param WCATCOD
#* @param WERR
#* @return WOK
#*!
Funprog CATEGORY_IS_AUTHORIZED(WPARCOD, WCATCOD, WERR)
Value Char WPARCOD
Value Char WCATCOD
Variable Char WERR

  Local Char WERR(250)
  Local Integer WFLG        : WFLG = [V]CST_AFALSE

  If WPARCOD <> ""
    If WCATCOD <> ""
      Local File EDIPARTNERD [EPTD]
      Filter [EPTD] Where PARCOD = WPARCOD
      For [EPTD]
        If CATCOD = WCATCOD
          WFLG = [V]CST_ATRUE
          Break
        Endif
      Next
      If WFLG = [V]CST_AFALSE
        WERR = mess(9,2006,1) #"Category not assigned to the EDI partner"
      Endif
      LogicClose File [EPTD]
    Else
      WERR = mess(10,2006,1) #"Category not defined"
    Endif
  Else
    WERR = mess(21,2006,1) #"EDI partner not defined"
  Endif
End WFLG


#-------------------------------------------------------------------#
# Treatments
#-------------------------------------------------------------------#

#********************************************************************
# Subprog DELETELINES
#********************************************************************
#
#* Delete lines
#* @param WOBJECT --> OBJECT
#* @param WCHILD  --> Collection abrev
#*!
Subprog DELETELINES(WOBJECT, WCHILD)
Variable Instance WOBJECT Using OBJECT
Value Char WCHILD
  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer I

  For I = evalue("maxtab(WOBJECT."+WCHILD+")") To 1 Step -1
    WOK = fmet WOBJECT.ADELLINE(WCHILD, I)
  Next I
End


#********************************************************************
# Funprog GET_CODNAM
#********************************************************************
#
#
#********************************************************************
Funprog GET_CODNAM(WCODE)
Value Char WCODE
  Local Char WCODNAM(40)
  Case WCODE
    When "BPANUM" : WCODNAM = mess(108,2006,1) #"Business partner code"
    When "BPAADD" : WCODNAM = mess(109,2006,1) #"Business partner address code"
    When "CPY"    : WCODNAM = mess(110,2006,1) #"Company code"
    When "FCY"    : WCODNAM = mess(111,2006,1) #"Site code"
    When Default  : WCODNAM = ""
  Endcase
End WCODNAM

