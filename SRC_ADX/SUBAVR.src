#<AdxTL>@(#)6.0.0.0 $Revision$  Gestion objet AVR
Raz GPILCOD
Call OBJET("AVR",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
Endcase
Return

#----------------------------------------------------------------------------#
$LIENS
Call TEXTE([M]INTIT(nolign-1),[M]ZINTIT(nolign-1)) From OBJDIV
Gosub TITRE_COD
Return

$SETBOUT
If CLECUR & REP<>"M" & VERROU
 CHAINE += "A" : # Suppression
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$TITRE_COD
Case [M]TYP
 When 1,2 : [M]TITCOD = mess(130,139,1) : # Code variable
 When 3   : [M]TITCOD = mess(75,123,1)  : # Fonction
Endcase
Return

#-----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap 
 Local File AVARLOC  [AVR1] 
 Local File ATEXTE   [ATX1] 
Else 
 Local File =[M]DOSORG+".AVARLOC"  [AVR1]
 Local File =[M]DOSORG+".ATEXTE"   [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File AVARLOC  [AVR2] 
 Local File ATEXTE   [ATX2] 
Else 
 Local File =[M]DOSDES+".AVARLOC"  [AVR2]
 Local File =[M]DOSDES+".ATEXTE"   [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AVR1], [ATX1]
&              , [AVR2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AVR2] , [ATX2]
 Delete [AVR2] Where TYP=val(TABLE) & FCT=TABLE2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AVARLOC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AVR2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AVR1]AVR0 Where TYP=val(TABLE) & FCT=TABLE2
  [F:AVR2] = [F:AVR1]
  Call COPTEXTE([F:AVR1]INTIT,[F:AVR2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:AVR2]UPDUSR)>0 : [F:AVR2]UPDUSR = GUSER : Endif
  If dim([F:AVR2]UPDDAT)>0 : [F:AVR2]UPDDAT = date$ : Endif
  If dim([F:AVR2]UPDTIM)>0 : [F:AVR2]UPDTIM = time  : Endif
  Write [AVR2]
  If fstat
   GOK=0 : Call FSTA("AVR2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------------------------------------------#
$SEL_TABLE
Case val(PARAM(1))
 When 1,2
  OBJET = "AGB"
 When 3
  Gosub SETSEP
  I = instr(1,VALEUR,SEP)
  If I
   SUPP   = left$(VALEUR,I-1)
   VALEUR = right$(VALEUR,I+1)
  Endif
  CRITERE = "[F:ASU]FONCTION=2"
  OBJET = "ASU"
  ORDRE = "PRG;SUBPRG"
Endcase
Return

$SETSEP
Local Char SEP(1)
SEP = "/"
Return

#----------------------------------------------------------------------------#
$FIN_TABLE
Gosub SETSEP
Case val(PARAM(1))
 When 3
  If !mkstat
   VALEUR = [F:ASU]PRG+SEP+[F:ASU]SUBPRG
  Else
   VALEUR = SUPP+SEP+VALEUR
  Endif
Endcase
Return

#----------------------------------------------------------------------------#
Subprog C_TYP(VALEUR)
Variable Integer VALEUR
[M]TYP = VALEUR
Gosub TITRE_COD
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
VALEUR = format$("KTv2:250X",VALEUR)
Call UNICITE(VALEUR,[M]COD) From OBJDIV
End

Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    CHAINE(250)
Gosub SETSEP
Case [M]TYP
 When 1
  CHAINE = VALEUR
  I = instr(1,CHAINE,"]")
  If I>0
   CHAINE = right$(CHAINE,I+1)
  Endif
  If CHAINE<="a" : # On ne vérifie pas les variables systèmes
   Read [AGB]AGB0=CHAINE
   If !fstat
    [M]INTIT(nolign-1) = [F:AGB]INTIT
    Call TEXTE([M]INTIT(nolign-1),[M]ZINTIT(nolign-1)) From OBJDIV
   Else
    Call ERREUR(CHAINE-":"-mess(3,124,1)) From GESECRAN : # Variable non définie
    mkstat = 1
   Endif
  Endif
 When 2
  Read [AGB]AGB0=VALEUR
  If !fstat
   [M]INTIT(nolign-1) = [F:AGB]INTIT
   Call TEXTE([M]INTIT(nolign-1),[M]ZINTIT(nolign-1)) From OBJDIV
  Endif
 When 3
  I = instr(1,VALEUR,SEP)
  If I
   Read [ASU]ASU0=left$(VALEUR,I-1);right$(VALEUR,I+1)
  Else
   fstat = 5
  Endif
  If !fstat
   If [F:ASU]FONCTION<>2
    # Ce sous-programme ne correspond pas à une fonction
    Call ERREUR(VALEUR-":"-mess(201,139,1)) From GESECRAN
    mkstat = 1 : End
   Else
    [M]INTIT(nolign-1) = [F:ASU]INTIT
    Call TEXTE([M]INTIT(nolign-1),[M]ZINTIT(nolign-1)) From OBJDIV
   Endif
  Else
   Call ERREUR(VALEUR-":"-mess(71,150,1)) From GESECRAN : # Sous-programme inexistant
   mkstat = 1 : End
  Endif
Endcase
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(20)(1..2)
PARAM(1) = num$([M]TYP)
Call S_TAB_CHAR(VALEUR,PARAM,"SELAVR","SUBAVR","") From GACTION
End

Subprog C_FCT(VALEUR)
Variable Char     VALEUR()
Local    Shortint STAT
Case [M]TYP
 When 2 
  If VALEUR = "" : GMESSAGE = mess(00010,00123,1) : mkstat = 1 : End : Endif : #  Zone obligatoire
  Call CONTROLE("AFC","",VALEUR,"",STAT) From CONTOBJ
Endcase
End
