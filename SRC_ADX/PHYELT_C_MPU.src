#*!
#TODO: Refactor following methods
# GET_MOVEMENT_DISPOSAL to          GET_DISPOSAL_MOVEMENT
# GET_MOVEMENT_DISPOSAL_CANCEL to   GET_DISPOSAL_CANCEL_MOVEMENT
# IS_LINKED_ASSET to                IS_LINKED_TO_ASSET

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
        When "IS_DISPOSAL"                  : Gosub IS_DISPOSAL                   :   #
        When "GET_MOVEMENT_DISPOSAL"        : Gosub GET_MOVEMENT_DISPOSAL         :   #
        When "GET_MOVEMENT_DISPOSAL_CANCEL" : Gosub GET_MOVEMENT_DISPOSAL_CANCEL  :   #
        When "IS_LINKED_ASSET"              : Gosub IS_LINKED_ASSET               :   #
        When Default
      Endcase
    When Default
  Endcase
Return

$OPERATIONS
  Case [L]CURPTH
    When ""
      Case [L]AOPERATION
        When "GET_PROPERTIES_VALUE"         : Gosub GET_PROPERTIES_VALUE          :   # Get some physical element properties values
        When Default
      Endcase
    When Default
  Endcase
Return

# ======================================================================
#    P U B L I C     M E T H O D S
# ======================================================================

# ======================================================================
#    P U B L I C     O P E R A T I O N S
# ======================================================================

#**
#* ========================================
#* Private Operation : GET_PROPERTIES_VALUE  -  Physical asset value properties
#* ----------------------------------------
#* Get the value of some properties of a physical asset
#*    1- Read the physical asset reference
#*    2- Get the value of PROPERTIES (char array) into VALUES (char array)
#* #*--------------------------------------
#* @param  AASREF     : Fixed asset reference
#* @param  PROPERTIES : Name of each property
#* @return VALUES     : Value of each property
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#* @return            : Error message stack
#*!

$GET_PROPERTIES_VALUE

Local Integer STACK_ERROR

  [L]ARET_VALUE = [V]CST_AOK

  # Parameters control
  Local Shortint NB_PRO : [L]NB_PRO = dim([L]PROPERTIES)
  If not ([L]NB_PRO > 0)
    [L]ERRMSG = func ASYRFNC.MES2(mess(60, [V]CST_MSGMIS, 1), "PROPERTIES", "GET_PROPERTIES_VALUE")
    [L]STACK_ERROR = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    Raz [L]VALUES
    Return
  Endif

  # Read physical assets reference
  If fmet this.AREAD(PHYREF) <> [V]CST_AOK
    # Reading error on table PHYELT => PHYREF=xxxxxx
    [L]STACK_ERROR = fmet this.ASETERROR("", mess(76,127,1)+" PHYELT ("+PHYREF+")", [V]CST_AERROR)
    [L]ARET_VALUE = [V]CST_AERROR
    Return
  Endif
  # Get the value of each property into VALUES
  Local Shortint PRO
  For [L]PRO = 1 To [L]NB_PRO
    Case evalue("type(this."+PROPERTIES([L]PRO)+")")
      When 1, 2, 4, 5, 6, 7, 9
        VALUES([L]PRO) = evalue("num$(this."+PROPERTIES([L]PRO)+")")
      When 3
        VALUES([L]PRO) = format$("D:DDMMYYYY", evalue("this."+PROPERTIES([L]PRO)))
      When Default
        VALUES([L]PRO) = evalue("this."+PROPERTIES([L]PRO))
    Endcase
  Next

Return

#**
#* Does the physical element is issue
#*
#* @param Return CST_ATRUE if disposal, CST_AFALSE otherwise
#*!
$IS_DISPOSAL

  [L]ARET_VALUE = [V]CST_AFALSE

  If (this.ISSDAT <> AVOID.ADATE)
    [L]ARET_VALUE = [V]CST_ATRUE
  Endif

Return

#**
#* Get the index of disposal movement
#*
#* @param  RINDEX Index of movement found, CST_ANOTDEFINED otherwise
#* @return Return CST_ATRUE if found, CST_AFALSE otherwise
#*!
$GET_MOVEMENT_DISPOSAL

  [L]ARET_VALUE = [V]CST_AFALSE

  RINDEX = func PHYELT_C_MPR._COLL_FIND_MVT(this, "PHYMVT", [V]CST_PMVISS)

  If (RINDEX <> [V]CST_ANOTDEFINED)
    [L]ARET_VALUE = [V]CST_ATRUE
  Endif

Return

#**
#* Get the index of cancel disposal movement
#*
#* @param  RINDEX Index of movement found, CST_ANOTDEFINED otherwise
#* @return Return CST_ATRUE if found, CST_AFALSE otherwise
#*!
$GET_MOVEMENT_DISPOSAL_CANCEL

  [L]ARET_VALUE = [V]CST_AFALSE

  RINDEX = func PHYELT_C_MPR._COLL_FIND_MVT(this, "PHYMVT", [V]CST_PMVAISS)

  If (RINDEX <> [V]CST_ANOTDEFINED)
    [L]ARET_VALUE = [V]CST_ATRUE
  Endif

Return

#**
#* Does the physical element is linked with asset
#*
#* @return Return CST_ATRUE if linked, CST_AFALSE otherwise
#*!
$IS_LINKED_ASSET

  [L]ARET_VALUE = [V]CST_AFALSE

  If (this.AASREF <> AVOID.ACHAR)
    [L]ARET_VALUE = [V]CST_ATRUE
  Endif

Return


