#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTICPT60   UTI process                                    Module CPT   #
#            correction utility
#    Update ML693
#    V6 :  22 =  Aucune
#    V7 :  2 news values => 24 = Aucune
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT60(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT60(DOSSIER)
Value Char DOSSIER

Local Integer STOP, NB, WCOMPTEUR
Local Char CRITERE(250), ACLE1(30), ACLE2(30)

Call ECR_TRACE("UTICPT60 : Start of process on : "+DOSSIER,0) From GESECRAN

If clalev([F:CDE])  =0  Local File =DOSSIER+".CACCEDEF"   [CDE] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Raz STOP
$LOOP_CDE

Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:CDE]COD='"+ACLE1+"' & [F:CDE]CPY>'"+ACLE2+"'"
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:CDE]COD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [CDE]
GOK = 1
For [CDE]CDE0 Where evalue(CRITERE)
 For AXE=1 To 20
  For IND=0 To dim([F:CDE]CCE1)-1
   If evalue("[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")") = 22
    Assign "[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")" With 24
#    Call ECR_TRACE([F:CDE]COD-[F:CDE]CPY-"[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")",0) From GESECRAN
   Endif
  Next
 Next

 Rewrite [CDE]
 If !fstat
  WCOMPTEUR += 1
 Else
  GOK = 0 : Call ERREUR("CACCEDEF"-[F:CDE]COD,1) From DOSDIC
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:CDE]COD
  ACLE2 = [F:CDE]CPY
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_CDE
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [CDE]
Call ECR_TRACE("UTICPT60 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT60 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
#If [F:ADS]MODULE(8)<>2 : End : Endif

If filinfo(filpath("FIL","CACCEDEF","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTICPT60(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif
#If [F:ADS]MODULE(8)<>2 : End : Endif
If filinfo(filpath("FIL","CACCEDEF","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTICPT60(APPLI)
End

