#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des demandes de services  Module CRM
# SETDEFDOO : Renvoie le donneur d'ordre définit par défaut pour un utilisateur.
# CREREPTSK : Crée une tâche pour le commercial en charge du compte.
# TSK_SET_HEA_INFO : Affectation des valeurs pour la création d'une tache. Création depuis une demande de service
# CREHISTO : Crée un historique d'état pour la demande de service.
# UPDCOVCTL : Met à jour le statut de contrôle de la couverture commerciale de la demande
# LOADMAC : Chargement du parc concerné
# SAVEMAC : Enregistrement du parc concerné
# LOADCPN : Chargement des composants
# SAVECPN : Enregistrement des composants
# SAVECPNLIN : Enregistrement d'une ligne de composant concerné
# SAVECPNWKEY : Enregistrement des composants suite à la transaction de création de la demande
# CREMANHORO : Création de consommation suite à une saisie manuelle d'horodatage
# MNGHORO : Gestion des menus Horodatage
# BEGINHORO : Gestion du lancement d'un Horodatage
# QUITHORO : Gestion de l'abandon d'un Horodatage
# DETECTITM : Détermine l'article consommé par un horodatage automatique
# ADDHORO : Enregistrement d'un nouvel horodatage
# CPTCUM : Calcul un nouveau cumul suite à une saisie manuelle d'horodatage dans l'onglet Gestion
# SETHOUUOM : Détermine une unité d'heure
# SETDAYUOM : Détermine une unité de jour
# LOADHDT : Chargement des consommations
# SAVEHDT : Enregistrement des consommations (Avec transaction)
# DELHD7CLOB : Suppression des clobs temporaires (Consommations SAV)
# DELHDT : Suppression consommation d'une demande de service
# SETINVINF : Renseigne l'onglet Eléments de facturation d'une demande de service.
# SRE_FOOT : Alimentation des éléments de facturation
# CPTHDTKEY : Calcul une clé primaire pour travaux
# LOADTOTHDT : Calcul du bloc de total des consommations.
# LOADTOTPIT : Calcul du total des points consommés par une demande de service.
# LOADTOT2PIT : Calcul du total des points consommés par une demande de service.
# SETSEQNUM : Calcul un code séquence temporaire pour la création d'une demande de service
# SRE7MAC : Chargement du parc
# AFF_TITCOL : affiche les titres des  colonnes des axes analytiques
# SAVEVALINI : sauvegarde des valeurs initiales
# MNGHISTO : Ajout d'un historique d'état
##########################################################################################################
##########################################################################################################
# Renvoie le donneur d'ordre définit par défaut pour un utilisateur.
###########################################################
Subprog SETDEFDOO(SZUSER, SZDOO)
Value Char SZUSER
Variable Char SZDOO

  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  Read [DVA]DVA0="SRE";SZUSER
  If fstat Then
    SZDOO = ""
  Else
    SZDOO = [F:DVA]ALHX(0)
  Endif
End

##########################################################################################################
# Crée une tâche pour le commercial en charge du compte.
###########################################################
$CREREPTSK
Global Char GSZSALESREP
Global Char GSZTSKDES(250)

Local Char SZTSKNUM
Local Integer STAT
Local Char SZSALESREPNAME
Local Integer LERRCOD
Local Integer IERROR

  GSZSALESREP = ""
  SZSALESREPNAME = ""
  GSZTSKDES = ""
  SZTSKNUM = ""
  LERRCOD = 0
  #Création d'une tâche pour le commercial en charge du compte.
  If [M:SRE2]SREASS = 4 Then
    #------------------------------------------------------------#
    # --> Récupération du code compteur Activité commerciale     #
    #------------------------------------------------------------#
    #Détermine le représentant commercial
    If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
    # FGR 09/03/2009 : X3SUIVI26656
    Call GET_REP_BPR([M:SRE0]SREBPC, GSZSALESREP, IERROR)
    If IERROR = 0 Then
      GMESSAGE = mess(266,196,1)
      GERR = 2
      Return
    Endif
    If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
    #Détermine la description de la tâche
    Local Integer ITERCLOB
    Local Integer I1NBBYTES
    Local Integer I1BUFFSIZE
    Local Integer I1LNGCLOB
    Local Integer I6LNGCLOB
    Local Char SZSREDESCTL(250)
    Local Char SZCHARCLOB(250)

    I1LNGCLOB = 0
    I6LNGCLOB = 0
    Raz SZSREDESCTL
    Raz SZCHARCLOB
    Read [ATY]CODTYP="HD1"
    If fstat Then
      I1LNGCLOB = 6
    Else
      I1LNGCLOB = [F:ATY]LNGTYP
    Endif
    If I1LNGCLOB = 0 Then
      I1LNGCLOB = 6
    Endif
    Read [ATY]CODTYP="HD6"
    If fstat Then
      I6LNGCLOB = 3
    Else
      I6LNGCLOB = [F:ATY]LNGTYP
    Endif
    If I6LNGCLOB = 0 Then
      I6LNGCLOB = 3
    Endif
    Global Clbfile GCLBTSKOBJ(I6LNGCLOB)

    Setlob SZSREDESCTL With [M:SRE1]SREFULDES
    If SZSREDESCTL = "" Then
      Setlob GCLBTSKOBJ With [M:SRE1]SRETTR
      GSZTSKDES = [M:SRE1]SRETTR
    Else
      If [M:SRE1]SRETTR = "" Then
        GCLBTSKOBJ = [M:SRE1]SREFULDES
        Setlob GSZTSKDES With [M:SRE1]SREFULDES
      Else
        I1NBBYTES = 1024*(2^I1LNGCLOB)
        I1BUFFSIZE = I1NBBYTES / 200
        I1BUFFSIZE += 5

        Local Char SZOBJCLOB1(200)(I1BUFFSIZE)
        Local Char SZOBJCLOB2(200)(I1BUFFSIZE)

        Raz SZOBJCLOB1
        Raz SZOBJCLOB2
        Setlob SZOBJCLOB1 With [M:SRE1]SREFULDES
        For ITERCLOB = 0 To I1BUFFSIZE-2
          SZOBJCLOB2(ITERCLOB + 1) = SZOBJCLOB1(ITERCLOB)
        Next
        SZOBJCLOB2(0) = [M:SRE1]SRETTR + " / "
        Setlob GCLBTSKOBJ With SZOBJCLOB2
        GSZTSKDES = [M:SRE1]SRETTR
      Endif
    Endif
    Call CRETSK("SUBSREB1", 0, 0, SZTSKNUM, LERRCOD) From SUBTSKCC
    If LERRCOD = 0 Then
      [M:SRE2]TSKREPCRE = 2
      Read [BPR]BPR0=GSZSALESREP
      If !fstat Then
        SZSALESREPNAME = [F:BPR]BPRNAM
      Endif
      GMESSAGE = mess(292,196,1) - SZSALESREPNAME
      GERR = 2
    Else
      GMESSAGE = mess(142,177,1) #Erreur lors de la création automatique de la tâche associée à la demande.
      GERR = 1
      If adxlog = 1 Then
        Rollback
      Endif
    Endif
  Endif
  Kill GSZSALESREP
  Kill GSZTSKDES
Return

##########################################################################################################
Subprog GET_REP_BPR(SZBPRNUM, SZREP, IERROR)
Value Char SZBPRNUM
Variable Char SZREP
Variable Integer IERROR

  IERROR = 1
  SZREP = ""
  #Détermine le représentant commercial
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  Read [BPR]BPR0=SZBPRNUM
  If fstat Then
    IERROR = 0
  Else
    If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
      Read [BPC]BPC0=SZBPRNUM
      If fstat Then
        IERROR = 0
      Else
        If [F:BPC]REP(0) <> "" Then
          SZREP = [F:BPC]REP(0)
        Else
          If dim([F:BPC]REP) > 1 Then
            If [F:BPC]REP(1) <> "" Then
              SZREP = [F:BPC]REP(1)
            Else
              IERROR = 0
            Endif
          Else
            IERROR = 0
          Endif
        Endif
      Endif
    Else
      IERROR = 0
    Endif
  Endif
End

##########################################################################################################
# Affectation des valeurs pour la création d'une tache. Création depuis une demande de service
#############################################################################
$TSK_SET_HEA_INFO
  Case IMPZON
    When "TSKNUM"
      [M:TSK0]TSKNUM = ""
    When "SALFCY"
      [M:TSK0]SALFCY = [M:SRE0]SALFCY
    When "TSKDON"
      [M:TSK0]TSKDON = 1
    When "TSKCMP"
      [M:TSK0]TSKCMP = [M:SRE0]SREBPC
    When "TSKCCN"
      [M:TSK0]TSKCCN = [M:SRE0]SRECCN
    When "TSKPJT"
      [M:TSK0]TSKPJT = [M:SRE8]SREPJT
    When "TSKDAT"
      [M:TSK1]TSKDAT = [M:SRE2]SRERESDAT
    When "TSKSTR"
      [M:TSK1]TSKSTR = min(date$,[M:SRE2]SRERESDAT)
      # FGR 08/03/2010 : X3SUIVI62924 (début)
      #[M:TSK1]TSKORI = 2
      #[M:TSK1]TSKORIOBC = "SRE"
      #[M:TSK1]TSKORITXT = ""
      [M:TSK1]TSKORIADI = "HDK1"
      [M:TSK1]TSKORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:TSK1]TSKORIADI)
      Call DEFOBJORI([M:TSK1]TSKORIAOB, [M:TSK1]TSKORIAVA) From CRMUTIL150    # FGR 08/03/2010 : X3SUIVI62924
      # FGR 08/03/2010 : X3SUIVI62924 (fin)
      [M:TSK1]TSKORIVCR = [M:SRE0]SRENUM
      [M:TSK1]TSKORIVCRL = 0
      [M:TSK1]TSKCMGNUM = ""
      [M:TSK1]TSKOPGNUM = ""
      [M:TSK1]TSKOPGTYP = ""
    When "TSKPIOLEV"
      [M:TSK1]TSKPIOLEV = [M:SRE2]SREPIOLEV
    When "TSKREP"
      [M:TSK1]TSKREP = GSZSALESREP
    When "TSKDEL"
      [M:TSK1]TSKDEL = 2
    When "TSKDON"
      [M:TSK0]TSKDON = 1
    When "FULOBJ"
      [M:TSK1]TSKDES = GSZTSKDES
      [M:TSK1]FULOBJ = GCLBTSKOBJ
  Endcase
Return

##########################################################################################################
# Crée un historique d'état pour la demande de service.
###########################################################
Subprog CREHISTO(SZSRENUM, SZNEWSAT, SZNEWDET, INEWASS, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Value Char SZNEWSAT
Value Char SZNEWDET
Value Integer INEWASS
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If !clalev([F:SRS]) : Local File SRESAT [SRS] : Endif
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SRS]
  Endif
  [F:SRS]SRENUM = SZSRENUM
  [F:SRS]SAT = SZNEWSAT
  [F:SRS]DET = SZNEWDET
  [F:SRS]ASS = INEWASS
  [F:SRS]SATDAT = date$
  [F:SRS]SATHOU = left$(time$, 2) + mid$(time$, 4, 2)
  Write [SRS]
  If fstat Then
    #Erreur lors de la création de l'historique des états. Transaction abandonnée.
    IERRINF = 304
    ICHAPTER = 196
    IBRETOUR = 0
    Call FSTA("SRS") From GLOCK
    GOK = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Met à jour le statut de contrôle de la couverture commerciale de la demande
#####################################################################
Subprog UPDCOVCTL
  Read [SRE]SRE0=[M:SRE0]SRENUM
  If fstat Then
    End
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [SRE]
  [F:SRE]SRECOVAUS = ""
  [F:SRE]COVAUSCLA = ""
  [F:SRE]SRECOVCTL = ""
  Rewrite [SRE]
  If fstat Then
    Rollback
  Else
    Commit
  Endif
End

##########################################################################################################
# Chargement du parc concerné
#####################################################################
Subprog LOADMAC(SZSRENUM)
Value Char SZSRENUM

Local Integer ILINDEB

  ILINDEB = 0
  Raz [M:SRE7]NBMAC
  Raz [M:SRE7]NBMACSEL
  Raz [M:SRE7]MAC
  Raz [M:SRE7]ITM
  Raz [M:SRE7]ITMDES
  Raz [M:SRE7]SER
  Raz [M:SRE7]QTY
  Raz [M:SRE7]LND
  Raz [M:SRE7]PBL
  Raz [M:SRE7]PBLCLA
  Raz [M:SRE7]COVFLG
  Raz [M:SRE7]COVSPT
  Raz [M:SRE7]COVVCR
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Raz [M:SRE7]PITMAC
  Endif
  Raz [M:SRE7]MACCOVCLA
  Raz [M:SRE7]MACCOVREN
  Raz [M:SRE7]ITNGRU
  Raz [M:SRE7]MACDEF
  Raz [M:SRE7]CKKHDTAMT
  Filter [SRM] Where [F:SRM]SRENUM = SZSRENUM
  nolign = 0
  For [SRM]SRM1
    If ILINDEB >= dim([M:SRE7]MAC) Then
      Break
    Endif
    #Transclass
    nolign += 1
    [M:SRE7] = [F:SRM]
    If ILINDEB = 0 Then
      [M:SRE7]NBMACSEL(ILINDEB) = "->"
    Else
      [M:SRE7]NBMACSEL(ILINDEB) = ""
    Endif
    [M:SRE7]MAC(ILINDEB) = [F:SRM]MACNUM
    If [M:SRE7]MAC(ILINDEB) = "" Then
      [M:SRE7]ITM(ILINDEB) = ""
      [M:SRE7]ITMDES(ILINDEB) = ""
      [M:SRE7]SER(ILINDEB) = ""
      [M:SRE7]QTY(ILINDEB) = 0
      [M:SRE7]LND(ILINDEB) = 1
    Else
      Read [MAC]MAC0=[M:SRE7]MAC(ILINDEB)
      If fstat Then
        [M:SRE7]ITM(ILINDEB) = ""
        [M:SRE7]ITMDES(ILINDEB) = ""
        [M:SRE7]SER(ILINDEB) = ""
        [M:SRE7]QTY(ILINDEB) = 0
        [M:SRE7]LND(ILINDEB) = 1
      Else
        [M:SRE7]ITM(ILINDEB) = [F:MAC]MACPDTCOD
        If [M:SRE7]ITM(ILINDEB) = "" Then
          [M:SRE7]ITMDES(ILINDEB) = ""
        Else
          #Call LECTEXTRA([M:SRE7]ITMDES(ILINDEB), "ITMMASTER", "DES1AXX", [M:SRE7]ITM(ILINDEB), "") From ATEXTRA
          Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SRE7]ITM(ILINDEB),[M:SRE7]ITMDES(ILINDEB), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
        Endif
        [M:SRE7]SER(ILINDEB) = [F:MAC]MACSERNUM
        [M:SRE7]QTY(ILINDEB) = [F:MAC]MACQTY
        If [M:SRE7]QTY(ILINDEB) = 0 Then
          [M:SRE7]QTY(ILINDEB) = 1
        Endif
        [M:SRE7]LND(ILINDEB) = [F:MAC]MACITNLND
      Endif
    Endif
    [M:SRE7]PBL(ILINDEB) = [F:SRM]PBLNUM
    If [M:SRE7]PBL(ILINDEB) = "" Then
      [M:SRE7]PBLCLA(ILINDEB) = ""
    Else
      Read [PBL]PBL0=[M:SRE7]PBL(ILINDEB)
      If fstat Then
        [M:SRE7]PBLCLA(ILINDEB) = ""
      Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:SRE7]PBLCLA(ILINDEB) = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:SRE7]PBLCLA(ILINDEB),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      Endif
    Endif
    [M:SRE7]COVFLG(ILINDEB) = [F:SRM]COVFLG
    [M:SRE7]COVSPT(ILINDEB) = [F:SRM]COVSPT
    [M:SRE7]COVVCR(ILINDEB) = [F:SRM]COVVCR
    [M:SRE7]MACCOVREN(ILINDEB) = [F:SRM]MACCOVREN
    If [M:SRE7]MACCOVREN(ILINDEB) = 0 Then
      [M:SRE7]MACCOVCLA(ILINDEB) = ""
    Else
      [M:SRE7]MACCOVCLA(ILINDEB) = mess([F:SRM]MACCOVREN,178,1)
    Endif
    [M:SRE7]ITNGRU(ILINDEB) = [F:SRM]ITNGRU
    If [F:SRM]MACNUM = [M:SRE0]SREMAC Then
      [M:SRE7]MACDEF(ILINDEB) = 2
    Else
      [M:SRE7]MACDEF(ILINDEB) = 1
    Endif
    #Chargement des points débités
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
      Read [PCT]PCT0=SZSRENUM;0;0;[M:SRE0]SREBPC;[M:SRE7]MAC(ILINDEB);[M:SRE7]PBL(ILINDEB);"";""
      If !fstat Then
        [M:SRE7]PITMAC(ILINDEB) = [F:PCT]PIT
      Endif
    Endif
    Gosub PE_SRELOADMAC From TRTCRMPE  # FGR 18/07/2012 : X3SUIVI3520
    ILINDEB += 1
  Next
  Filter [SRM]
  [M:SRE7]NBMAC = ILINDEB
End

##########################################################################################################
# Enregistrement du parc concerné
#####################################################################
Subprog SAVEMAC(SZSRENUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ILINCPN
Local Integer ITER

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  ILINCPN = 0
  nolign =  0
  #Enregistre le tableau du parc concerné
  For ITER = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]MAC(ITER) <> "" Then
      nolign += 1
      Read [SRM]SRM1=SZSRENUM;[M:SRE7]MAC(ITER)
      If fstat = 5 Then
        #Enregistrement non trouvé il faut le créer
        #Transclass
        [F:SRM] = [M:SRE7]
        [F:SRM]SRENUM = SZSRENUM
        [F:SRM]ITNGRU = [M:SRE7]ITNGRU(ITER)
        [F:SRM]MACNUM = [M:SRE7]MAC(ITER)
        [F:SRM]PBLNUM = [M:SRE7]PBL(ITER)
        [F:SRM]COVFLG = [M:SRE7]COVFLG(ITER)
        [F:SRM]COVSPT = [M:SRE7]COVSPT(ITER)
        [F:SRM]COVVCR = [M:SRE7]COVVCR(ITER)
        [F:SRM]MACCOVREN = [M:SRE7]MACCOVREN(ITER)
        [F:SRM]CREDAT = date$
        [F:SRM]CREUSR = GUSER
        Write [SRM]
        If fstat Then
          #Erreur lors de l'enregistrement du parc concerné par la demande de service.
          IERRINF = 180
          ICHAPTER = 182
          IBRETOUR = 0
          GOK = 0
          Break
        Endif
      Elsif fstat = 0 Then
        #Enregistrement trouvé il faut le mettre à jour
        #Transclass
        [F:SRM] = [M:SRE7]
        [F:SRM]SRENUM = SZSRENUM
        [F:SRM]ITNGRU = [M:SRE7]ITNGRU(ITER)
        [F:SRM]MACNUM = [M:SRE7]MAC(ITER)
        [F:SRM]PBLNUM = [M:SRE7]PBL(ITER)
        [F:SRM]COVFLG = [M:SRE7]COVFLG(ITER)
        [F:SRM]COVSPT = [M:SRE7]COVSPT(ITER)
        [F:SRM]COVVCR = [M:SRE7]COVVCR(ITER)
        [F:SRM]UPDDAT = date$
        [F:SRM]UPDUSR = GUSER
        Rewrite [SRM]
        If fstat Then
          #Erreur lors de l'enregistrement du parc concerné par la demande de service.
          IERRINF = 180
          ICHAPTER = 182
          IBRETOUR = 0
          GOK = 0
          Break
        Endif
      Endif
    Endif
    Gosub PE_SRESAVEMAC From TRTCRMPE  # FGR 18/07/2012 : X3SUIVI3520
  Next
End

##########################################################################################################
# Chargement des composants
#####################################################################
Subprog LOADCPN(SZSRENUM, SZMACNUM, ITPYFLG)
Value Char SZSRENUM
Value Char SZMACNUM
Value Integer ITPYFLG

Local Integer ILINCPN

  ILINCPN = 0
  Raz [M:SRE7]NBCPN
  Raz [M:SRE7]CPNITM
  Raz [M:SRE7]CPNQTY
  Raz [M:SRE7]CPNCOVFLG
  Raz [M:SRE7]CPNCOVSPT
  Raz [M:SRE7]CPNCOVVCR
  Raz [M:SRE7]CPNCOVCLA
  Raz [M:SRE7]CPNCOVREN
  Raz [M:SRE7]CPNSEQ
  Raz [M:SRE7]CPNCKKHDT
  If SZMACNUM = "" Then
    End
  Endif
  #Obtient le code article de la fiche parc
  Read [MAC]MAC0=SZMACNUM
  If fstat Then
    End
  Endif
  Filter [SRN] Where [F:SRN]SRENUM = SZSRENUM and [F:SRN]MACNUM = SZMACNUM and [F:SRN]TPYFLG = ITPYFLG and [F:SRN]FGVCAH = 0 Order By [F:SRN]CPNITM Asc
  For [SRN]
    If ILINCPN >= dim([M:SRE7]CPNITM) Then
      Break
    Endif
    [M:SRE7]CPNITM(ILINCPN) = [F:SRN]CPNITM
    #Call LECTEXTRA([M:SRE7]CPNITMDES(ILINCPN), "ITMMASTER", "DES1AXX", [M:SRE7]CPNITM(ILINCPN), "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SRE7]CPNITM(ILINCPN),[M:SRE7]CPNITMDES(ILINCPN), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    [M:SRE7]CPNSEQ(ILINCPN) = [F:SRN]CPNSEQ
    [M:SRE7]CPNQTY(ILINCPN) = [F:SRN]CPNQTY
    [M:SRE7]CPNCOVFLG(ILINCPN) = [F:SRN]CPNCOVFLG
    [M:SRE7]CPNCOVSPT(ILINCPN) = [F:SRN]CPNCOVSPT
    [M:SRE7]CPNCOVVCR(ILINCPN) = [F:SRN]CPNCOVVCR
    [M:SRE7]CPNCOVREN(ILINCPN) = [F:SRN]CPNCOVREN
    If [M:SRE7]CPNCOVREN(ILINCPN) = 0 Then
      [M:SRE7]CPNCOVCLA(ILINCPN) = ""
    Else
      [M:SRE7]CPNCOVCLA(ILINCPN) = mess([F:SRN]CPNCOVREN,178,1)
    Endif
    Gosub PE_SRELOADCPN From TRTCRMPE  # FGR 04/08/2010 : X3SUIVI65845
    ILINCPN += 1
  Next
  Filter [SRN]
  [M:SRE7]NBCPN = ILINCPN
End

##########################################################################################################
# Enregistrement des composants
#####################################################################
Subprog SAVECPN(SZSRENUM, SZMACNUM, ITPYFLG, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Value Char SZMACNUM
Value Integer ITPYFLG
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ITER
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  #On efface tout
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SRN]
  Endif
  Delete [SRN] Where [F:SRN]SRENUM = SZSRENUM and [F:SRN]MACNUM = SZMACNUM and [F:SRN]TPYFLG = ITPYFLG and [F:SRN]FGVCAH = 0
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement des composants du parc concerné.
    IERRINF = 181
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Endif
  Endif
  If GOK < 1 Then
    End
  Endif
  #On récrée
  For ITER = 0 To [M:SRE7]NBCPN-1
    If [M:SRE7]CPNITM <> "" Then
      Raz [F:SRN]
      [F:SRN]SRENUM = SZSRENUM
      [F:SRN]MACNUM = SZMACNUM
      [F:SRN]TPYFLG = ITPYFLG
      [F:SRN]FGVCAH = 0
      [F:SRN]CPNITM = [M:SRE7]CPNITM(ITER)
      [F:SRN]CPNSEQ = [M:SRE7]CPNSEQ(ITER)
      [F:SRN]CPNQTY = [M:SRE7]CPNQTY(ITER)
      [F:SRN]CPNCOVFLG = [M:SRE7]CPNCOVFLG(ITER)
      [F:SRN]CPNCOVSPT = [M:SRE7]CPNCOVSPT(ITER)
      [F:SRN]CPNCOVVCR = [M:SRE7]CPNCOVVCR(ITER)
      [F:SRN]CPNCOVREN = [M:SRE7]CPNCOVREN(ITER)
      [F:SRN]CREDAT = date$
      [F:SRN]CREUSR = GUSER
      Gosub PE_SRESAVECPN From TRTCRMPE      # FGR 04/08/2010 : X3SUIVI65845
      Write [SRN]
      If fstat Then
        #Erreur lors de l'enregistrement des composants du parc concerné.
        IERRINF = 181
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
        Break
      Endif
    Endif
  Next
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Enregistrement d'une ligne de composant concerné
#####################################################################
Subprog SAVECPNLIN(SZSRENUM, SZMACNUM, SZCPNNUM, ITPYFLG, INOL, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Value Char SZMACNUM
Value Char SZCPNNUM
Value Integer ITPYFLG
Value Integer INOL
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IBDEBTRANSFLG
Local Integer ITER    # FGR 08/07/2016 : X3SUIV117476

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  #On efface tout
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SRN]
  Endif
  Delete [SRN] Where [F:SRN]SRENUM = SZSRENUM and [F:SRN]MACNUM = SZMACNUM and [F:SRN]CPNITM = SZCPNNUM and [F:SRN]TPYFLG = ITPYFLG and [F:SRN]FGVCAH = 0
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement des composants du parc concerné.
    IERRINF = 181
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
        Rollback
    Endif
  Endif
  If GOK < 1 Then
    End
  Endif
  #On récrée
  If [M:SRE7]CPNITM(INOL) <> "" Then
    Raz [F:SRN]
    [F:SRN]SRENUM = SZSRENUM
    [F:SRN]MACNUM = SZMACNUM
    [F:SRN]TPYFLG = ITPYFLG
    [F:SRN]FGVCAH = 0
    [F:SRN]CPNITM = SZCPNNUM
    [F:SRN]CPNSEQ = [M:SRE7]CPNSEQ(INOL)
    [F:SRN]CPNQTY = [M:SRE7]CPNQTY(INOL)
    [F:SRN]CPNCOVFLG = [M:SRE7]CPNCOVFLG(INOL)
    [F:SRN]CPNCOVSPT = [M:SRE7]CPNCOVSPT(INOL)
    [F:SRN]CPNCOVVCR = [M:SRE7]CPNCOVVCR(INOL)
    [F:SRN]CPNCOVREN = [M:SRE7]CPNCOVREN(INOL)
    [F:SRN]CREDAT = date$
    [F:SRN]CREUSR = GUSER
    ITER = INOL                                  # FGR 08/07/2016 : X3SUIV117476
    Gosub PE_SRESAVECPN From TRTCRMPE            # FGR 08/07/2016 : X3SUIV117476
    Write [SRN]
    If fstat Then
      #Erreur lors de l'enregistrement des composants du parc concerné.
      IERRINF = 181
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Enregistrement des composants suite à la transaction de création de la demande
#####################################################################
Subprog SAVECPNWKEY(SZSEQNUM, SZSRENUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSEQNUM
Value Char SZSRENUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  #CHECK FILE_DECLARE SREMACCPN [SRN2]
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #On récrée sur la base de l'ancien numéro de séquence
  Filter [SRN2] Where [F:SRN2]SRENUM = SZSEQNUM and [F:SRN2]TPYFLG = 1 and [F:SRN2]FGVCAH = 0 Order By [F:SRN2]MACNUM Asc; [F:SRN2]CPNITM Asc
  For [SRN2]
    [F:SRN] = [F:SRN2]
    [F:SRN]SRENUM = SZSRENUM
    [F:SRN]TPYFLG = 0
    [F:SRN]CREDAT = date$
    [F:SRN]CREUSR = GUSER
    Write [SRN]
    If fstat Then
      #Erreur lors de l'enregistrement des composants du parc concerné.
      IERRINF = 181
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  If GOK < 1 Then
    End
  Endif
  #On efface tout
  Delete [SRN2] Where [F:SRN2]SRENUM = SZSEQNUM and [F:SRN2]TPYFLG = 1 and [F:SRN]FGVCAH = 0
  If fstat <> 0 Then
    IERRINF = 181
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
  Endif
End

##########################################################################################################
# Création de consommation suite à une saisie manuelle d'horodatage
#######################################################
Subprog CREMANHORO(SZSRENUM, SZMESSAGE, IBRETOUR)
Value Char SZSRENUM
Variable Char SZMESSAGE
Variable Integer IBRETOUR

  [M:SRE0]MAXNBRHDT = 0
  #On vérifie que le nombre maximum de consommations n'est pas atteint
  If [M:SRE9]NBLIG >= dim([M:SRE9]HDTITM)-2 Then
    #Le nombre maximum de consommations saisissables pour une demande de service est atteint.
    [M:SRE0]MAXNBRHDT = 1
    End
  Endif
  Call ADDHORO(SZSRENUM, 1, 0, 0, 0, 0, SZMESSAGE, IBRETOUR)
  If IBRETOUR = 0 Then
    End
  Endif
End

##########################################################################################################
# Gestion des menus Horodatage
#####################################################################
Subprog MNGHORO(SZSRENUM, IAFFFLG, SZSELMAC)
Value Char SZSRENUM
Value Integer IAFFFLG
Value Char SZSELMAC

Local Integer ISLOCKED
Local Integer IUPDSRE

  If GISRE2TIMFLG Then
    Call QUITHORO(SZSRENUM, IAFFFLG)
    Call UNLOCKSRE(SZSRENUM) From SUBITNB1
  Else
    #Vérification du lock superviseur
    ISLOCKED = 0
    Call ISAOBLOCKED([M:SRE0]SRESYM, ISLOCKED) From CRMUTIL140
    If ISLOCKED Then
      #Lancement d'un horodatage impossible. Modification en cours sur un autre poste.
      GMESSAGE = mess(14,177,1)
      GERR = 2
      End
    Endif
    #Contrôle que l'on peut rentrer en modification de la demande.
    Call LOCKSRE(SZSRENUM, IUPDSRE) From SUBITNB1
    If !IUPDSRE Then
        #Lancement d'un horodatage impossible. Intervention en cours de saisie sur un autre poste.
        GMESSAGE = mess(13,177,1)
        GERR = 2
        End
    Endif
    #On vérifie que le nombre maximum de consommations n'est pas atteint
    If [M:SRE9]NBLIG >= dim([M:SRE9]HDTITM)-2 Then
      #Le nombre maximum de consommations saisissables pour une demande de service est atteint.
      GMESSAGE = mess(17,177,1)
      GERR = 2
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      End
    Endif
    GISRE2SELHORMAC = SZSELMAC
    Call BEGINHORO(SZSRENUM)
    If GERR > 0 Then
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Else
      Call SETNAP From SUBSREB4
    Endif
  Endif
End

##########################################################################################################
# Gestion du lancement d'un Horodatage
#####################################################################
Subprog BEGINHORO(SZSRENUM)
Value Char SZSRENUM

Local Char SZITM(GLONITM)
Local Char RETOUR
Local Integer IHANGUP1
Local Integer IHANGUP2
Local Char SZMESSAGE(type(GMESSAGE)-10)
Local Integer IBRETOUR

  SZITM = ""
  RETOUR = ""
  IHANGUP1 = 86400
  IHANGUP2 = 100
  Raz SZMESSAGE
  IBRETOUR = 0
  #On vérifie que toutes les conditions sont réunies pour effectuer un bel horodatage
  Call DETECTITM([M:SRE0]SRENUM, SZITM, SZMESSAGE, IBRETOUR)
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    GERR = 1
    End
  Endif
  If SZITM = "" Then
    #Aucun article a consommer n'a pu être déterminé. L'horodatage n'a pas démarré.
    GMESSAGE = mess(228,182,1)
    GERR = 3
    End
  Endif
  Read [ITM]ITM0=SZITM
  If fstat Then
    #Aucun article a consommer n'a pu être déterminé. L'horodatage n'a pas démarré.
    GMESSAGE = mess(228,182,1)
    GERR = 3
    End
  Else
    Read [TUN]TUN0=[F:ITM]SAU
    If fstat Then
      #Aucun article a consommer n'a pu être déterminé. L'horodatage n'a pas démarré.
      GMESSAGE = mess(228,182,1)
      GERR = 3
      End
    Else
      If [F:TUN]UOMTYP <> 5 Then
        #L'article utilisé pour valoriser l'horodatage ne comporte par une unité de temps.
        GMESSAGE = mess(187,182,1)
        GERR = 1
        #Rollback   # FGR 22/11/2012 : X3SUIVI85908 Je ne vois pas pourquoi un Rollback ici !
        End
      Endif
    Endif
  Endif
  Read [UOT]UOT0=[F:ITM]SAU
  If fstat Then
    #L'article utilisé pour valoriser l'horodatage comporte une unité de temps non typée en jour, heure ou minute.
    GMESSAGE = mess(229,182,1)
    GERR = 3
    End
  Else
    If [F:UOT]TYPUOM <= 1 Then
      #L'article utilisé pour valoriser l'horodatage comporte une unité de temps d'un type incorrect.
      GMESSAGE = mess(230,182,1)
      GERR = 3
      End
    Endif
    If [F:UOT]TYPUOM >= 5 Then
      #L'article utilisé pour valoriser l'horodatage comporte une unité de temps d'un type incorrect.
      GMESSAGE = mess(230,182,1)
      GERR = 3
      End
    Endif
  Endif
  If !GISRE2TIMFLG Then
    [M:SRE2]TITBLK = mess(184,182,1)
    GISRE2TIMFLG = 1
    [M:SRE2]TIMSPGDAY = 0
    [M:SRE2]TIMSPGHOU = 0
    [M:SRE2]TIMSPGMNT = 0
    Diszo [M:SRE2]TIMSPGDAY
    Diszo [M:SRE2]TIMSPGHOU
    Diszo [M:SRE2]TIMSPGMNT
    GISRE2STRDAYCTL = nday(date$)
    GISRE2STRSODCTL = time
  Endif
  Callui RETOUR="" With "UIAction="+chr$(1)+"Sethangup"
&                     , "UITimehangup1="+chr$(1)+num$(IHANGUP1)
&                     , "UITimehangup2="+chr$(1)+num$(IHANGUP2)
  Affzo [M:SRE2]TITBLK
  Affzo [M:SRE2]TIMSPGDAY
  Affzo [M:SRE2]TIMSPGHOU
  Affzo [M:SRE2]TIMSPGMNT
End

##########################################################################################################
# Gestion de l'abandon d'un Horodatage
#####################################################################
Subprog QUITHORO(SZSRENUM, IAFFFLG)
Value Char SZSRENUM
Value Integer IAFFFLG

Local Integer ITOTMNT
Local Integer INBSOD
Local Integer ITIMSPGDAY
Local Integer ITIMSPGHOU
Local Integer ITIMSPGMNT

  ITOTMNT = 0
  INBSOD = 0
  ITIMSPGDAY = 0
  ITIMSPGHOU = 0
  ITIMSPGMNT = 0
  If GISRE2TIMFLG Then
    GISRE2TIMFLG = 0
    [M:SRE2]TITBLK = ""
    #Détermine si l'horodatage est inférieur à la minute
    If GISRE2STRDAYCTL = nday(date$) Then
      ITOTMNT = time - GISRE2STRSODCTL
      If ITOTMNT < 60 Then
        If IAFFFLG Then
          #Aucun nouvel horodatage n'a été enregistré pour cette demande.
          # Sa durée est en effet inférieure à la minute.
          GMESSAGE = mess(190,182,1)
          GERR = 3
        Endif
        #On restaure l'écran
        If IAFFFLG Then
          [M:SRE2]TIMSPGDAY = [F:SRE]TIMSPGDAY
          [M:SRE2]TIMSPGHOU = [F:SRE]TIMSPGHOU
          [M:SRE2]TIMSPGMNT = [F:SRE]TIMSPGMNT
        Endif
        Actzo [M:SRE2]TIMSPGDAY
        Actzo [M:SRE2]TIMSPGHOU
        Actzo [M:SRE2]TIMSPGMNT
        If IAFFFLG Then
          Affzo [M:SRE2]TITBLK
          Affzo [M:SRE2]TIMSPGDAY
          Affzo [M:SRE2]TIMSPGHOU
          Affzo [M:SRE2]TIMSPGMNT
          Affzo [M:SRE2]CTIMSPGDAY
          Affzo [M:SRE2]CTIMSPGHOU
          Affzo [M:SRE2]CTIMSPGMNT
        Endif
        GISRE2SELHORMAC = ""
        End
      Endif
    Endif
    #Détermine si l'horodatage s'est déroulé sur plusieurs jours.
    If GISRE2STRDAYCTL <> nday(date$) Then
      If IAFFFLG Then
        #Aucun nouvel horodatage n'a été enregistré pour cette demande.
        # Sa durée s'échelonne en effet sur plusieurs jours.
        GMESSAGE = mess(221,182,1)
        GERR = 3
      Endif
      #On restaure l'écran
      If IAFFFLG Then
        [M:SRE2]TIMSPGDAY = [F:SRE]TIMSPGDAY
        [M:SRE2]TIMSPGHOU = [F:SRE]TIMSPGHOU
        [M:SRE2]TIMSPGMNT = [F:SRE]TIMSPGMNT
      Endif
      Actzo [M:SRE2]TIMSPGDAY
      Actzo [M:SRE2]TIMSPGHOU
      Actzo [M:SRE2]TIMSPGMNT
      If IAFFFLG Then
        Affzo [M:SRE2]TITBLK
        Affzo [M:SRE2]TIMSPGDAY
        Affzo [M:SRE2]TIMSPGHOU
        Affzo [M:SRE2]TIMSPGMNT
        Affzo [M:SRE2]CTIMSPGDAY
        Affzo [M:SRE2]CTIMSPGHOU
        Affzo [M:SRE2]CTIMSPGMNT
      Endif
      GISRE2SELHORMAC = ""
      End
    Endif
    #Tout est bon. On peut donc calculer les jours, heures et minutes
    ITIMSPGDAY = 0
    INBSOD = time - GISRE2STRSODCTL
    #Calcul du nombre d'heures
    ITIMSPGHOU = int(INBSOD / 3600)
    #Calcul du nombre de minutes
    ITIMSPGMNT = int((mod(INBSOD, 3600)) / 60)
    Actzo [M:SRE2]TIMSPGDAY
    Actzo [M:SRE2]TIMSPGHOU
    Actzo [M:SRE2]TIMSPGMNT
    Call ADDHORO(SZSRENUM, IAFFFLG, 1, ITIMSPGDAY, ITIMSPGHOU, ITIMSPGMNT, SZMESSAGE, IBRETOUR)
    If IBRETOUR = 0 Then
      GMESSAGE = SZMESSAGE
      GERR = 3
      End
    Endif
    If IAFFFLG Then
      Call LOADHDT(SZSRENUM)
      If [M:SRE9]NBLIG > 0 Then
        Grizo [M:SRE8]SRECUR
        Grizo [M:SRE0]SALFCY
        Gosub SETMACGRAY From SUBSREB4
      Endif
    Endif
    GTIMPREVALCTL(0) = [M:SRE2]TIMSPGDAY
    GTIMPREVALCTL(1) = [M:SRE2]TIMSPGHOU
    GTIMPREVALCTL(2) = [M:SRE2]TIMSPGMNT
    [M:SRE9]HORHDTFLG = 1
  Endif
  If IAFFFLG Then
    Affzo [M:SRE2]TITBLK
    Affzo [M:SRE2]TIMSPGDAY
    Affzo [M:SRE2]TIMSPGHOU
    Affzo [M:SRE2]TIMSPGMNT
    Affzo [M:SRE2]CTIMSPGDAY
    Affzo [M:SRE2]CTIMSPGHOU
    Affzo [M:SRE2]CTIMSPGMNT
  Endif
  GISRE2SELHORMAC = ""
End

##########################################################################################################
# Détermine l'article consommé par un horodatage automatique
#########################################################
Subprog DETECTITM(SZSRENUM, SZITMREF, SZMESSAGE, IBRETOUR)
Value Char SZSRENUM
Variable Char SZITMREF
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Char SZSKILL(GLONPBL)
Local Char SZSREMAC(GLONMAC)
Local Char SZITMMAC(GLONITM)

  SZITMREF = ""
  SZSREMAC = ""
  SZITMMAC = ""
  SZSKILL = ""
  If SZSRENUM <> "" Then
    Read [SRE]SRE0=SZSRENUM
    If fstat Then
      #Erreur lors de la recherche de l'article consommé.
      SZMESSAGE= mess(226,182,1)
      IBRETOUR = 0
      GOK = 0
      End
    Endif
  Endif
  If GISRE2SELHORMAC = "" Then
    #Horodatage avec parc par défaut
    SZSREMAC = [F:SRE]SREMAC
  Else
    #Horodatage avec sélection d'un parc
    SZSREMAC = GISRE2SELHORMAC
  Endif
  If SZSREMAC = "" Then
    SZITMMAC = ""
    SZSKILL = [F:SRE]SREPBLGRP
  Else
    Read [MAC]MAC0=SZSREMAC
    If fstat Then
      SZITMMAC = ""
      SZSKILL = [F:SRE]SREPBLGRP
    Else
      SZITMMAC = [F:MAC]MACPDTCOD
      Read [SRM]SRM1=[F:SRE]SRENUM;SZSREMAC
      If fstat Then
        SZSKILL = ""
      Else
        SZSKILL = [F:SRM]PBLNUM
      Endif
    Endif
  Endif
  #Recherche de l'article à consommer
  # Etape 1 : Recherche USER + MACPBL
  Read [HOI]HOI0=SZITMMAC;SZSKILL;GUSER
  If !fstat Then
    SZITMREF = [F:HOI]ITMREF
  Endif
  If SZITMREF <> "" Then
    End
  Endif
  # Etape 2 : Recherche "" + MACPBL
  Read [HOI]HOI0=SZITMMAC;SZSKILL;""
  If !fstat Then
    SZITMREF = [F:HOI]ITMREF
  Endif
  If SZITMREF <> "" Then
    End
  Endif
  # Etape 3 : Recherche USER + ""
  Read [HOI]HOI0="";"";GUSER
  If !fstat Then
    SZITMREF = [F:HOI]ITMREF
  Endif
  If SZITMREF <> "" Then
    End
  Endif
  # Etape 4 : Recherche "" + ""
  Read [HOI]HOI0="";"";""
  If !fstat Then
    SZITMREF = [F:HOI]ITMREF
  Endif
  If SZITMREF <> "" Then
    End
  Endif
  # Etape 5 : On passe au niveau Site
  SZITMREF = GDEFHDTITM
  If SZITMREF <> "" Then
    End
  Endif
End

##########################################################################################################
# Enregistrement d'un nouvel horodatage
###########################################################
Subprog ADDHORO(SZSRENUM, IAFFFLG, IDURFLG, ISPGDAY, ISPGHOU, ISPGMNT, SZMESSAGE, IBRETOUR)
Value Char SZSRENUM
Value Integer IAFFFLG
Value Integer IDURFLG
Value Integer ISPGDAY
Value Integer ISPGHOU
Value Integer ISPGMNT
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Integer INBSOD
Local Integer INBSEC
Local Integer INBALLSOD
Local Decimal GROPRI
Local Decimal NETPRI
Local Decimal MAJREM(0..8)
Local Decimal DCBQTY
Local Shortint ITERNET
Local Integer ITOTMNT
Local Decimal INBHOUPERDAY
Local Integer INBMNTPERDAY
Local Char SZITMREF(GLONITM)
Local Char SZUNITTOUSE(GLONUOM)
Local Char SZTYPEUNIT(2)

  Raz SZMESSAGE
  IBRETOUR = 1
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    #Erreur lors de l'enregistrement d'un nouvel horodatage.
    SZMESSAGE = mess(185,182,1)
    IBRETOUR = 0
    GOK = 0
    End
  Endif
  SZITMREF = ""
  SZUNITTOUSE = ""
  SZTYPEUNIT = ""
  DCBQTY = 0
  INBSOD = 0
  INBALLSOD = 0
  INBSEC = 0
  #Obtention du code article consommé
  Call DETECTITM("", SZITMREF, SZMESSAGE, IBRETOUR)
  If IBRETOUR = 0 Then
    GOK = 0
    End
  Endif
  If SZITMREF = "" Then
    #Aucun article a consommer n'a pu être déterminé.
    SZMESSAGE = mess(227,182,1)
    IBRETOUR = 0
    GOK = 0
    End
  Endif
  #Obtention du nombre d'heures dans une journée
  If SZITMREF = "" Then
    INBHOUPERDAY = 8
  Else
    Read [ITM]ITM0=SZITMREF
    If fstat Then
      #Erreur lors de l'enregistrement des consommations.
      SZMESSAGE = mess(186,182,1)
      IBRETOUR = 0
      GOK = 0
      End
    Endif
    Call SREC_COE(SZITMREF, [M:SRE0]SREBPC, [F:ITM]HOUUOM, [F:ITM]DAYUOM, INBHOUPERDAY) From TRTVENQTE
    If IDURFLG Then
      ITOTMNT = (ISPGDAY * INBHOUPERDAY * 60) + (ISPGHOU * 60) + ISPGMNT
    Else
      ITOTMNT = ([F:SRE]TIMSPGDAY * INBHOUPERDAY * 60) + ([F:SRE]TIMSPGHOU * 60) + [F:SRE]TIMSPGMNT
    Endif
  Endif
  If ITOTMNT <= 0 Then
    End
  Endif
  INBMNTPERDAY = 60 * INBHOUPERDAY
  #On détermine quelle est l'unité à utiliser
  If ITOTMNT <= 59 Then
    If SZITMREF = "" Then
      #On recherche une unité de minute
      Filter [UOT] Where [F:UOT]TYPUOM = 4 Order By [F:UOT]UOM Asc
      For [UOT]
        SZUNITTOUSE = [F:UOT]UOM
        SZTYPEUNIT = "M"
        Break
      Next
      Filter [UOT]
      If SZUNITTOUSE = "" Then
        Gosub SETHOUUOM
      Endif
    Else
      SZUNITTOUSE = [F:ITM]MNTUOM
      SZTYPEUNIT = "M"
    Endif
  Else
    Gosub SETHOUUOM
  Endif
  If GOK < 1 Then
    End
  Endif
  Case SZTYPEUNIT
    When "M"
      DCBQTY = ITOTMNT
    When "H"
      DCBQTY = ((100 * ITOTMNT) / 60) / 100
    When "D"
      DCBQTY = ((100 * ITOTMNT) / INBMNTPERDAY) / 100
  Endcase
  #Enregistrement d'un nouveau cumul
  Gosub CPTCUM
  If GOK < 0 Then
    End
  Endif
  #Enregistrement d'une nouvelle consommation
  Call CREHDTHORO(SZSRENUM, SZITMREF, DCBQTY, SZUNITTOUSE,SZMESSAGE, IBRETOUR) From SUBSREB4
End

##########################################################################################################
# Calcul un nouveau cumul suite à une saisie manuelle d'horodatage dans l'onglet Gestion
#####################################################################
$CPTCUM
Local Integer IBDEBTRANSFLG

  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
  Endif
  Readlock [SRE]SRE0=SZSRENUM
  If fstat Then
    #Erreur lors de l'enregistrement d'un nouvel horodatage.
    Unlock [SRE]
    SZMESSAGE = mess(185,182,1)
    IBRETOUR = 0
    GOK = 0
  Endif
  If GOK < 1 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
    Return
  Endif
  #Enregistrement du dernier horodatage si saisie non manuelle.
  If IDURFLG Then
    [F:SRE]TIMSPGDAY = ISPGDAY
    [F:SRE]TIMSPGHOU = ISPGHOU
    [F:SRE]TIMSPGMNT = ISPGMNT
  Endif
  #On convertit la nouvelle saisie en nombre de secondes
  INBALLSOD = 0
  Call DAYTOSEC([F:SRE]TIMSPGDAY, [F:SRE]TIMSPGHOU, [F:SRE]TIMSPGMNT, 0, INBHOUPERDAY, INBALLSOD) From CRMUTIL140
  #Calcul d'un nouveau cumul
  #On convertit l'ancien cumul en nombre de secondes
  INBSEC = 0
  Call DAYTOSEC([F:SRE]CTIMSPGDAY, [F:SRE]CTIMSPGHOU, [F:SRE]CTIMSPGMNT, 0, INBHOUPERDAY, INBSEC) From CRMUTIL140
  #On ajoute les nouvelles secondes
  INBALLSOD += INBSEC
  #Et on reconverti le nouveau nombre en jours, heures et minutes
  Call SECTODAY(INBALLSOD, INBHOUPERDAY, [F:SRE]CTIMSPGDAY, [F:SRE]CTIMSPGHOU, [F:SRE]CTIMSPGMNT, INBSEC) From CRMUTIL140
  Rewrite [SRE]
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement d'un nouvel horodatage.
    SZMESSAGE = mess(185,182,1)
    IBRETOUR = 0
    GOK = 0
    Unlock [SRE]
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  #Affichage dans l'écran
  If IAFFFLG Then
    [M:SRE2]TIMSPGDAY = [F:SRE]TIMSPGDAY
    [M:SRE2]TIMSPGHOU = [F:SRE]TIMSPGHOU
    [M:SRE2]TIMSPGMNT = [F:SRE]TIMSPGMNT
    [M:SRE2]CTIMSPGDAY = [F:SRE]CTIMSPGDAY
    [M:SRE2]CTIMSPGHOU = [F:SRE]CTIMSPGHOU
    [M:SRE2]CTIMSPGMNT = [F:SRE]CTIMSPGMNT
  Endif
Return

##########################################################################################################
# Détermine une unité d'heure
#####################################################################
$SETHOUUOM
  If ITOTMNT >= INBMNTPERDAY  Then
    #Unité en jours
    Gosub SETDAYUOM
  Else
    #Unité en heures
    If SZITMREF = "" Then
      #On recherche une unité de minute
      Filter [UOT] Where [F:UOT]TYPUOM = 3 Order By [F:UOT]UOM Asc
      For [UOT]
        SZUNITTOUSE = [F:UOT]UOM
        SZTYPEUNIT = "H"
        Break
      Next
      Filter [UOT]
      If SZUNITTOUSE = "" Then
        Gosub SETDAYUOM
      Endif
    Else
      SZUNITTOUSE = [F:ITM]HOUUOM
      SZTYPEUNIT = "H"
    Endif
  Endif
Return

##########################################################################################################
# Détermine une unité de jour
#####################################################################
$SETDAYUOM
  #Unité en jour
  If SZITMREF = "" Then
    #On recherche une unité de minute
    Filter [UOT] Where [F:UOT]TYPUOM = 2 Order By [F:UOT]UOM Asc
    For [UOT]
      SZUNITTOUSE = [F:UOT]UOM
      SZTYPEUNIT = "D"
      Break
    Next
    Filter [UOT]
    If SZUNITTOUSE = "" Then
      #Aucune unité de temps n'a pu être déterminée pour l'enregistrement de cet horodatage. Création abandonnée.
      SZMESSAGE = mess(203,182,1)
      IBRETOUR = 0
      GOK = 0
    Endif
  Else
    SZUNITTOUSE = [F:ITM]DAYUOM
    SZTYPEUNIT = "D"
  Endif
Return

##########################################################################################################
# Chargement des consommations
#####################################################################
Subprog LOADHDT(SZSRENUM)
Value Char SZSRENUM

Local Integer ITER
Local Integer IACTLOT
Local Integer IACTSLO
Local Integer IACTSER
Local Integer IACTEMP
Local Integer ISTOERR
Local Integer ILINDEB
Local Integer IDISCRGFLG(9)

  #Sortie de stock
  Call RAZSTOSORW From STKSOR
  Raz [M:SRE9]CREFLG
  Raz [M:SRE9]UPDFLG
  Raz [M:SRE9]SAVSTOISS    # FGR 05/08/2010 : X3SUIVI66063
  Raz GSRE9HDTISSISS
  Raz GSRE9DIRTYISSISS
  ILINDEB = 0
  ISTOERR = 0
  Raz IDISCRGFLG
  IACTLOT = 0
  IACTSLO = 0
  IACTSER = 0
  IACTEMP = 0
  Raz [M:SRE9]NBLIG
  Raz [M:SRE9]HDTMACSRE
  Raz [M:SRE9]HDTCPN
  Raz [M:SRE9]HDTTYP
  Raz [M:SRE9]HDTITM
  Raz [M:SRE9]ITMREF
  Raz [M:SRE9]HDTQTY
  Raz [M:SRE9]HDTUOM
  Raz [M:SRE9]HDTSTOFCY
  Raz [M:SRE9]HDTAVA
  Raz [M:SRE9]HDTAVAUOM
  Raz [M:SRE9]HDTAUSTYP
  Raz [M:SRE9]HDTAUS
  Raz [M:SRE9]HDTAUSCOD
  Raz [M:SRE9]HDTPLNDAT
  Raz [M:SRE9]HDTDONDAT
  Raz [M:SRE9]HDTSTOISS
  Raz [M:SRE9]HDTINV
  Raz [M:SRE9]HDTTEX
  Raz [M:SRE9]HDTSALTEX
  Raz [M:SRE9]HDTAMT
  Raz [M:SRE9]HDTAMTINV
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Raz [M:SRE9]INVPITFLG
    Raz [M:SRE9]PITHDT
  Endif
  Raz [M:SRE9]HDTCUR
  Raz [M:SRE9]TOTSVC
  Raz [M:SRE9]TOTPDT
  Raz [M:SRE9]TOTEXS
  Raz [M:SRE9]TOTCSM
  Raz [M:SRE9]TOTINV
  Raz [M:SRE9]PRCINV
  Raz [M:SRE9]TOTNOTINV
  Raz [M:SRE9]PRCNOTINV
  Raz [M:SRE9]HDTDONHOU
  Raz [M:SRE9]MANAMTFLG
  Raz [M:SRE9]ITNNUM
  Raz [M:SRE9]HDTMACSET
  Raz [M:SRE9]VAT1
  Raz [M:SRE9]VAT2
  Raz [M:SRE9]VAT3
  Raz [M:SRE9]CLCAMT1
  Raz [M:SRE9]CLCAMT2
  Raz [M:SRE9]PRIREN
  Raz [M:SRE9]SAUSTUCOE
  Raz [M:SRE9]HDTSTUQTY
  Raz [M:SRE9]HDTISSQTY
  Raz [M:SRE9]HDTISSISS
  Raz [M:SRE9]WSTOSEQ
  Raz [M:SRE9]STOMGTCOD
  Raz [M:SRE9]STA
  Raz [M:SRE9]MVTDES
  #
  Read [ACV]CODACT="LOT"
  If [F:ACV]FLACT = 2 Then
    If type([M:SRE9]LOT) > 0 Then
      IACTLOT = 1
      Raz [M:SRE9]LOT
    Endif
  Endif
  Read [ACV]CODACT="SLO"
  If [F:ACV]FLACT = 2 Then
    If type([M:SRE9]SLO) > 0 Then
      IACTSLO = 1
      Raz [M:SRE9]SLO
    Endif
  Endif
  Read [ACV]CODACT="SER"
  If [F:ACV]FLACT = 2 Then
    If type([M:SRE9]SERNUM) > 0 Then
      IACTSER = 1
      Raz [M:SRE9]SERNUM
      Raz [M:SRE9]SERNUMF
    Endif
  Endif
  Read [ACV]CODACT="EMP"
  If [F:ACV]FLACT = 2 Then
    If type([M:SRE9]LOC) > 0 Then
      IACTEMP = 1
      Raz [M:SRE9]LOC
    Endif
  Endif
  #
  For ITER = 0 To dim(IDISCRGFLG)-1
    Read [ACV]CODACT="SP"+num$(ITER+1)
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(ITER) = 1
      Case ITER+1
        When 1 : Raz [M:SRE9]DISCRGVAL1 : Raz [M:SRE9]DISCRGREN1
        When 2 : Raz [M:SRE9]DISCRGVAL2 : Raz [M:SRE9]DISCRGREN2
        When 3 : Raz [M:SRE9]DISCRGVAL3 : Raz [M:SRE9]DISCRGREN3
        When 4 : Raz [M:SRE9]DISCRGVAL4 : Raz [M:SRE9]DISCRGREN4
        When 5 : Raz [M:SRE9]DISCRGVAL5 : Raz [M:SRE9]DISCRGREN5
        When 6 : Raz [M:SRE9]DISCRGVAL6 : Raz [M:SRE9]DISCRGREN6
        When 7 : Raz [M:SRE9]DISCRGVAL7 : Raz [M:SRE9]DISCRGREN7
        When 8 : Raz [M:SRE9]DISCRGVAL8 : Raz [M:SRE9]DISCRGREN8
        When 9 : Raz [M:SRE9]DISCRGVAL9 : Raz [M:SRE9]DISCRGREN9 # FGR 13/01/2010 : X3SUIVI60986
      Endcase
    Endif
  Next ITER
  #
  #Chargement à partir de HDKTASK
  Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 Order By [F:HDT]HDTDONDAT Asc; [F:HDT]HDTDONHOU Asc; [F:HDT]HDTNUM Asc
  nolign = 0
  For [HDT] Hint Key HDT1
    If ILINDEB >= dim([M:SRE9]HDTMACSRE) Then
      Break
    Endif
    #Transclass
    nolign += 1
    [M:SRE9] = [F:HDT]
    [M:SRE9]HDTMACSRE(ILINDEB) = [F:HDT]HDTMACSRE
    [M:SRE9]HDTCPN(ILINDEB) = [F:HDT]HDTCPN
    [M:SRE9]HDTTYP(ILINDEB) = [F:HDT]HDTTYP
    [M:SRE9]HDTITM(ILINDEB) = [F:HDT]HDTITM
    [M:SRE9]ITMREF(ILINDEB) = [F:HDT]HDTITM
    [M:SRE9]HDTQTY(ILINDEB) = [F:HDT]HDTQTY
    [M:SRE9]HDTUOM(ILINDEB) = [F:HDT]HDTUOM
    [M:SRE9]HDTSTOFCY(ILINDEB) = [F:HDT]HDTSTOFCY
    [M:SRE9]HDTAVA(ILINDEB) = [F:HDT]HDTAVA
    [M:SRE9]HDTAVAUOM(ILINDEB) = [F:HDT]HDTAVAUOM
    [M:SRE9]HDTAUSTYP(ILINDEB) = [F:HDT]HDTAUSTYP
    [M:SRE9]HDTAUS(ILINDEB) = [F:HDT]HDTAUS
    Case [M:SRE9]HDTAUSTYP(ILINDEB)
      When 1
        Read [AUS]CODUSR=[F:HDT]HDTAUS
        If fstat Then
          [M:SRE9]HDTAUSCOD(ILINDEB) = [F:HDT]HDTAUS
        Else
          [M:SRE9]HDTAUSCOD(ILINDEB) = [F:AUS]NOMUSR
        Endif
      When 2
        Read [BPR]BPR0=[F:HDT]HDTAUS
        If fstat Then
          [M:SRE9]HDTAUSCOD(ILINDEB) = [F:HDT]HDTAUS
        Else
          [M:SRE9]HDTAUSCOD(ILINDEB) = [F:BPR]BPRNAM
        Endif
      When Default
    Endcase
    [M:SRE9]HDTPLNDAT(ILINDEB) = [F:HDT]HDTPLNDAT
    [M:SRE9]HDTDONDAT(ILINDEB) = [F:HDT]HDTDONDAT
    [M:SRE9]HDTDONHOU(ILINDEB) = [F:HDT]HDTDONHOU
    Call SECTOHOU([F:HDT]HDTDONHOU, [M:SRE9]BHDTDONHOU(ILINDEB)) From CRMUTIL140
    [M:SRE9]HDTTEX(ILINDEB) = [F:HDT]HDTTEX
    [M:SRE9]HDTSALTEX(ILINDEB) = [F:HDT]HDTSALTEX
    [M:SRE9]HDTSTOISS(ILINDEB) = [F:HDT]HDTSTOISS
    [M:SRE9]SAVSTOISS(ILINDEB) = [M:SRE9]HDTSTOISS(ILINDEB)    # FGR 05/08/2010 : X3SUIVI66063
    [M:SRE9]HDTINV(ILINDEB) = [F:HDT]HDTINV
    [M:SRE9]HDTAMT(ILINDEB) = [F:HDT]HDTAMT
    [M:SRE9]HDTAMTINV(ILINDEB) = [F:HDT]HDTAMTINV
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
      [M:SRE9]INVPITFLG(ILINDEB) = [F:HDT]INVPITFLG
    Endif
    [M:SRE9]HDTCUR(ILINDEB) = [F:HDT]HDTCUR
    [M:SRE9]HDTNUM(ILINDEB) = [F:HDT]HDTNUM
    [M:SRE9]MANAMTFLG(ILINDEB) = [F:HDT]MANAMTFLG
    [M:SRE9]ITNNUM(ILINDEB) = [F:HDT]ITNNUM
    [M:SRE9]HDTMACSET(ILINDEB) = [F:HDT]HDTMACSET
    [M:SRE9]VAT1(ILINDEB) = [F:HDT]VAT(0)
    [M:SRE9]VAT2(ILINDEB) = [F:HDT]VAT(1)
    [M:SRE9]VAT3(ILINDEB) = [F:HDT]VAT(2)
    [M:SRE9]CLCAMT1(ILINDEB) = [F:HDT]CLCAMT1
    [M:SRE9]CLCAMT2(ILINDEB) = [F:HDT]CLCAMT2
    [M:SRE9]PRIREN(ILINDEB) = [F:HDT]PRIREN
    [M:SRE9]SAUSTUCOE(ILINDEB) = [F:HDT]SAUSTUCOE
    [M:SRE9]HDTSTUQTY(ILINDEB) = [F:HDT]HDTSTUQTY
    [M:SRE9]HDTISSQTY(ILINDEB) = [F:HDT]HDTISSQTY
    # FGR 12/10/2010 : X3SUIVI66063 (début) : je corrige HDTISSISS qui a une mauvaise valeur ici
    If [M:SRE9]HDTSTOISS(ILINDEB) <> 2 and [F:HDT]HDTISSISS <> 0 Then
      [M:SRE9]HDTISSISS(ILINDEB) = 0
    Else
      [M:SRE9]HDTISSISS(ILINDEB) = [F:HDT]HDTISSISS
    Endif
    # FGR 12/10/2010 : X3SUIVI66063 (fin)
    If [M:SRE9]HDTNUM(ILINDEB) <> "" Then
      If [M:SRE9]HDTTYP(ILINDEB) = 2 Then
        If [M:SRE9]HDTDONDAT(ILINDEB) <> [00/00/00] Then
          If [M:SRE9]HDTSTOISS(ILINDEB) = 2 Then
            If [M:SRE9]HDTISSQTY(ILINDEB) > 0 Then
              [M:SRE9]CREFLG(ILINDEB) = 1
            Endif
          Endif
        Endif
      Endif
    Endif
    For ITER = 0 To dim(IDISCRGFLG)-1
      If IDISCRGFLG(ITER) Then
        Assign("[M:SRE9]DISCRGVAL" + num$(ITER+1) +"(ILINDEB)") With evalue("[F:HDT]DISCRGVAL" + num$(ITER+1))
        [M:SRE9]DISCRGREN1(ILINDEB) = [F:HDT]DISCRGREN1
      Endif
    Next ITER
    #----- Chargement comptes et sections analytiques -----#
    Call CHARG_ACCCCE(ILINDEB,"","","[M:SRE9]CCE", "HDT",0,[F:HDT]HDTNUM,0,0,"") From TRTX3CPT
    #Chargement des points débités
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
      Read [PCT]PCT0=SZSRENUM;0;0;"";"";"";[M:SRE9]HDTNUM(ILINDEB);""
      If !fstat Then
        [M:SRE9]PITHDT(ILINDEB) = [F:PCT]PIT
      Endif
    Endif
    #Gestion de stock de l'article consommé
    If [M:SRE9]HDTITM(ILINDEB) <> "" Then
      Read [ITM]ITM0=[M:SRE9]HDTITM(ILINDEB)
      If !fstat Then
        [M:SRE9]STOMGTCOD(ILINDEB) = [F:ITM]STOMGTCOD
      Endif
    Endif
    #Sortie de stock
    ISTOERR = 0
    If [M:SRE9]HDTNUM(ILINDEB) = "" Then
      Call RECSTOSOR (3, "SRE9", ILINDEB, [M:SRE9]HDTSTOFCY(ILINDEB), [M:SRE9]HDTITM(ILINDEB), 33, [M:SRE9]HDTNUM(nolign - 1), 0, "", ISTOERR) From STKECR
    Else
      Call RECSTOSOR (1, "SRE9", ILINDEB, [M:SRE9]HDTSTOFCY(ILINDEB), [M:SRE9]HDTITM(ILINDEB), 33, [M:SRE9]HDTNUM(nolign - 1), 0, "", ISTOERR) From STKECR
    Endif
    # FGR 31/05/2013 : X3SUIVI90082 : (début) vu avec TS : pas la peine de tester le code retour.
    #If ISTOERR Then
    #  #Erreur lors de la lecture des informations relatives à la gestion des stocks.
    #  GMESSAGE = mess(521,182,1)
    #  GERR = 1
    #  Break
    #Endif
    # FGR 31/05/2013 : X3SUIVI90082 : (fin)
    ILINDEB += 1
  Next
  Filter [HDT]
  [M:SRE9]NBLIG = ILINDEB
  If GERR Then
    End
  Endif
  Call LOADTOTHDT(0)
  Call LOADTOTPIT(0)
  Affzo [M:SRE9]1-99
End

##########################################################################################################
# Enregistrement des consommations (Avec transaction)
#####################################################################
Subprog SAVEHDT(SZSRENUM)
Value Char SZSRENUM

Local Char SZTXCCODE
Local Integer ITER
Local Integer IERR
Local Decimal IBID1
Local Decimal IBID2
Local Integer IBID3
Local Integer IBID4
Local Integer J
Local Integer IBDEBTRANSFLG

  IERR = 0
  IBID1 = 0
  IBID2 = 0
  IBID3 = 0
  IBID4 = 0
  SZTXCCODE = ""
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
 If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [HDT]
  Endif
  Gosub DELHDT
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    #Else                               # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
    #  Commit                           # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
    Endif
  Endif
  If GERR > 0 Then
    GOK = 0
    End
  Endif
  #If IBDEBTRANSFLG = 0 Then            # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
  #  Call DEBTRANS From GLOCK           # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
  #  Trbegin [HDT]                      # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
  #Endif                                # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
  #On récrée
  nolign =  0
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTITM(ITER) <> "" Then
      nolign += 1
      Raz [F:HDT]
      SZTXCCODE = [M:SRE9]HDTSALTEX(ITER)
      #Enregistrement du Clob Consommation
      If [M:SRE9]HDTNUM(ITER) = "" Then
        If [M:SRE9]HDTNUMSEQ(ITER) = "" Then
          #Erreur lors de l'enregistrement des textes saisis sur les consommations.
          GMESSAGE = mess(906,182,1)
          GERR = 1
          GOK = 0
          Break
        Else
          Read [HD7]HD70=[M:SRE9]HDTNUMSEQ(ITER);"HDTSEQ";adxuid(1)
        Endif
      Else
        Read [HD7]HD70=[M:SRE9]HDTNUM(ITER);"HDT";adxuid(1)
      Endif
      If !fstat Then
        If [M:SRE9]HDTSALTEX(ITER) = "" Then
          SZTXCCODE = ""
          Call CPTTXCKEY(SZTXCCODE, IERR) From SUBSREB3
          If IERR Then
            #Erreur lors de l'enregistrement des textes saisis sur les consommations.
            GMESSAGE = mess(906,182,1)
            GERR = 1
            GOK = 0
            Break
          Endif
        Else
          SZTXCCODE = [M:SRE9]HDTSALTEX(ITER)
          Delete [TXC] Where [F:TXC]CODE = [M:SRE9]HDTSALTEX(ITER)
          If fstat Then
            #Erreur lors de l'enregistrement des textes saisis sur les consommations.
            GMESSAGE = mess(906,182,1)
            GERR = 1
            Call FSTA("TXC") From GLOCK
            GOK = 0
            Break
          Endif
        Endif
        #Ecriture du texte dans TEXCLOB
        Raz [F:TXC]
        [F:TXC]CODE = SZTXCCODE
        [F:TXC]TEXTE = [F:HD7]CLOB
        [F:TXC]CREUSR = GUSER
        [F:TXC]CREDAT = date$
        Write [TXC]
        If fstat Then
          #Erreur lors de l'enregistrement des textes saisis sur les consommations.
          GMESSAGE = mess(906,182,1)
          GERR = 1
          Call FSTA("TXC") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
      #Enregistrement de la clé
      If [M:SRE9]HDTNUM(ITER) = "" Then
        #------------------------------------------------------------#
        # --> Calcul du code compteur                                #
        #------------------------------------------------------------#
        Call CPTHDTKEY([M:SRE0]SALFCY, [F:HDT]HDTNUM, IERR)
        If IERR Then
          #Erreur lors de l'enregistrement des consommations.
          GMESSAGE = mess(186,182,1)
          GERR = 1
          GOK = 0
          Break
        Endif
        [M:SRE9]HDTNUM(ITER) = [F:HDT]HDTNUM
      Else
        [F:HDT]HDTNUM = [M:SRE9]HDTNUM(ITER)
      Endif
      #Transclass
      [F:HDT] = [M:SRE9]
      # FGR 03/01/2013 : X3SUIVI86797 (début)
      [F:HDT]VAT(0) = [M:SRE9]VAT1(ITER)
      [F:HDT]VAT(1) = [M:SRE9]VAT2(ITER)
      [F:HDT]VAT(2) = [M:SRE9]VAT3(ITER)
      # FGR 03/01/2013 : X3SUIVI86797 (fin)
      [F:HDT]SRENUM = [M:SRE0]SRENUM
      [F:HDT]HDTSALTEX = SZTXCCODE
      [F:HDT]TPL = 1
      If GSRE9DIRTYISSISS(ITER) > 0 Then
        [F:HDT]HDTISSISS = GSRE9HDTISSISS(ITER)
        [M:SRE9]HDTISSISS(ITER) = GSRE9HDTISSISS(ITER)
      Endif
      # -----------------------------------
      # FGR 13/08/2014 : X3SUIVI91771 (début) : S'il la sortie de stock n'est pas faite, il n'y a pas de qté sortie.
      If [M:SRE9]HDTSTOISS(ITER) <> 2 and [M:SRE9]HDTISSISS(ITER) <> 0 Then
        [M:SRE9]HDTISSISS(ITER) = 0
        [F:HDT]HDTISSISS = 0
      Endif
      # FGR 13/08/2014 : X3SUIVI91771 (fin)
      # -----------------------------------
      Write [HDT]
      If fstat Then
        #Erreur lors de l'enregistrement des consommations.
        GMESSAGE = mess(186,182,1)
        GERR = 1
        GOK = 0
        Break
      Endif
      #
      Call ENREG_ACCCCE(nolign-1, "", "", "[M:SRE9]CCE", "HDT", 0, [F:HDT]HDTNUM, 0, 0, "", "C") From TRTX3CPT
      If GOK < 1 Then
        #Erreur lors de l'enregistrement des axes analytiques des consommations
        GMESSAGE = mess(428,177,1)
        GERR = 1
        GOK = 0
        Break
      Endif
      #Raz [F:CAL]
      #[F:CAL]ABRFIC = "HDT"
      #[F:CAL]VCRNUM = [F:HDT]HDTNUM
      #[F:CAL]VCRLIN = 0
      #[F:CAL]VCRSEQ = 0
      #[F:CAL]CPLCLE = ""
      #[F:CAL]ANALIG = 1
      #For J = 1 To max(GNBDIE,GOPTCANA)
      #  [F:CAL]DIE(J-1) = GDIE(J)
      #  [F:CAL]CCE(J-1) = evalue("[M:SRE9]CCE"+num$(J)+"(nolign-1)")
      #Next J
      #Write [CAL]
      #If fstat Then
      #  #Erreur lors de l'enregistrement des axes analytiques des consommations
      #  GMESSAGE = mess(428,177,1)
      #  GERR = 1
      #  GOK = 0
      #  Break
      #Endif
      #Sortie de stock
      If [M:SRE9]HDTTYP(ITER) = 2 Then
        If [M:SRE9]HDTDONDAT(ITER) <> [00/00/00] Then
          If [M:SRE9]HDTSTOISS(ITER) = 2 Then
            If [M:SRE9]HDTISSQTY(ITER) > 0 Then
              If [M:SRE9]WSTOSEQ(ITER) > 0 Then
                Gosub ALI_STW From SUBSREB3
                Call ALISTOWORK(3, [M:SRE9]WSTOSEQ(ITER), IBID1, IBID2, IBID3, IBID4, IERR) From STKINT
                If IERR Then
                  #Erreur lors du traitement des sorties de stock.
                  GMESSAGE = mess(522,182,1)
                  GERR = 1
                  GOK = 0
                  Break
                Endif
                Call MAJ_STOCK From STKMAJ
                If GOK < 1 Then
                  #Erreur lors du traitement des sorties de stock.
                  GMESSAGE = mess(522,182,1)
                  GERR = 1
                  GOK = 0
                  Break
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    #Else                               # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
    #  Commit                           # FGR 03/01/2012 : X3SUIVI78440 : Ou tout est bon ou rien
    Endif
  Endif
  If GERR Then
    End
  Endif
  Gosub DELHD7CLOB
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
#Suppression des clobs temporaires (Consommations SAV)
#########################################################################
$DELHD7CLOB
  Delete [HD7] Where [F:HD7]PRONUM = adxuid(1)
  If fstat Then
    #Erreur lors de l'enregistrement des textes saisis sur les consommations.
    GMESSAGE = mess(906,182,1)
    GERR = 1
    Call FSTA("HD7") From GLOCK
    GOK = 0
  Endif
Return

##########################################################################################################
# Suppression consommation d'une demande de service
######################################################
$DELHDT
  For [HDT] Where [F:HDT]SRENUM = [M:SRE0]SRENUM
    Call ENREG_ACCCCE(0, "", "", "", "HDT", 0, [F:HDT]HDTNUM, 0, 0, "", "A") From TRTX3CPT
    If GOK < 1 Then
      #Erreur lors de la suppression des axes analytiques associés aux consommations de l'intervention.
      GMESSAGE = mess(429,177,1)
      GERR = 1
      GOK = 0
      Break
    Endif
    #Delete [CAL] Where [F:CAL]ABRFIC = "HDT" and [F:CAL]VCRNUM = [F:HDT]HDTNUM and [F:CAL]VCRLIN = 0 and [F:CAL]VCRSEQ = 0 and [F:CAL]CPLCLE = "" and [F:CAL]ANALIG = 1
    #If fstat Then
    #  #Erreur lors de la suppression des axes analytiques associés aux consommations de la demande de service.
    #  GMESSAGE = mess(429,177,1)
    #  GERR = 1
    #  Call FSTA("CAL") From GLOCK
    #  GOK = 0
    #  Break
    #Endif
  Next
  If GERR > 0 Then
    Return
  Endif
  Delete [HDT] Where [F:HDT]SRENUM = [M:SRE0]SRENUM
  If fstat Then
    #Erreur lors de la suppression des consommations associées à la demande de service. Transaction abandonnée.
    GMESSAGE = mess(912,182,1)
    GERR = 1
    Call FSTA("HDT") From GLOCK
    GOK = 0
  Endif
Return

##########################################################################################################
# Renseigne l'onglet Eléments de facturation d'une demande de service.
###########################################################
Subprog SETINVINF(SZBPC)
Value Char SZBPC

Local Char SECTION
Local Integer J
Local Integer ITER

  If SZBPC = "" Then
    End
  Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
  Read [BPC]BPC0=SZBPC
  If fstat Then
    End
  Endif
  [M:SRE8]SREBPCINV = [F:BPC]BPCINV
  [M:SRE8]SREBPCPYR = [F:BPC]BPCPYR
  [M:SRE8]SREBPCGRU = [F:BPC]BPCGRU
  #Représentants
  Read [ACV]CODACT="REC"
  If !fstat Then
    For ITER = 0 To [F:ACV]DIME-1
      [M:SRE8]SREREP(ITER) = [F:BPC]REP(ITER)
    Next
  Endif
  # Initialisation du régime de taxe
  Call INIT_REGIME([F:BPC]BPCNUM, GSOCIETE, "C", [M:SRE8]SREVACBPR) From CPTSUB
  [M:SRE8]SRECHGTYP = [F:BPC]CHGTYP
  [M:SRE8]SREPRITYP = [F:BPC]PRITYP
  If [M:SRE0]SREBPC = "" Then
    [M:SRE8]SRECUR = GCUR
  Else
    If [F:BPC]BPCNUM <> [M:SRE0]SREBPC  Then
      Read [BPC]BPC0=[M:SRE0]SREBPC
      If fstat Then
        End
      Endif
    Endif
    [M:SRE8]SRECUR = [F:BPC]CUR
    Read [BPR]BPR0=[M:SRE0]SREBPC
  Endif
  # Initialisation des escomptes et agios
  Call INIT_ESCOMPTE([F:BPC]BPCNUM, GSOCIETE, "C", [M:SRE8]SREDEP) From CPTSUB
  #----- Initialisation des sections analytiques entête -----#
  For J = 1 To GNBDIE
    If[M:SRE8]CCE(J-1) = "" Then
      [M:SRE8]DIE(J-1) = GDIE(J)
      Call INISEC(SECTION,"SRE",GDIE(J)) From SUBCDE
      [M:SRE8]CCE(J-1) = SECTION
    Endif
  Next J
  #Eléments de facturation
  Gosub SRE_FOOT
  For ITER = 0 To [M:SRE8]NBFAC-1
    [M:SRE8]INVDTA(ITER) = [F:BPC]INVDTA(ITER)
    [M:SRE8]INVDTAAMT(ITER) = [F:BPC]INVDTAAMT(ITER)
  Next
  # Initialisation du code condition de paiement
  Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SRE8]SREPTE) From TRTX3
End

##########################################################################################################
# Alimentation des éléments de facturation
#######################################################
$SRE_FOOT
Local Integer NBPOSTE

  If GACTFTC = 2 Then
    If [M:SRE8]NBFAC = 0 Then
      NBPOSTE = dim([M:SRE8]NOLIG2)
      Call  SAISFOOT (1,"SRE8",NBPOSTE,[M:SRE8]SRECHGTYP,GSYSCUR,[M:SRE8]SRECUR,"NON") From SUBSFIT
      [M:SRE8]NBFAC = NBPOSTE
    Endif
    # chargement devise client sur ligne montant
    For nolign = 0 To [M:SRE8]NBFAC-1
      If [M:SRE8]AMTCOD(nolign) = 2 Then
        [M:SRE8]WWCUR(nolign) = [M:SRE8]SRECUR
      Endif
    Next
  Endif
Return

##########################################################################################################
# Calcul une clé primaire pour travaux
#######################################################
Subprog CPTHDTKEY(SZSALFCY, SZHDTKEY, IERR)
Variable Char SZSALFCY
Variable Char SZHDTKEY
Variable Integer IERR

Local Char SZCOUNTER(GLONANM)
Local Integer IMANCOU          # FGR 24/02/2014 : X3SUIVI97134
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  # FGR 24/02/2014 : X3SUIVI97134 (début) action READCOUNTER
  #Read [TCA]TCA0=12
  #If fstat Then
  #  IERR = 1
  #  End
  #Endif
  #SZCOUNTER = [F:TCA]CODNUM(10)
  Call READ_COUNTER("", 12, 10, GSOCIETE, GCURLEG, SZCOUNTER, IMANCOU) From CRM_UTIL
  # FGR 24/02/2014 : X3SUIVI97134 (fin)
  #------------------------------------------------------------#
  # --> Calcul du code compteur                                #
  #------------------------------------------------------------#
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK1", SZSALFCY, SZCOUNTER, date$, "", SZHDTKEY, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 0 Then
      # problème lors de la récupération du compteur
      IERR = IBRETOUR
      End
    Endif
  Endif
End

##########################################################################################################
#  Calcul du bloc de total des consommations.
################################################################
Subprog LOADTOTHDT(IAFFFLG)
Value Integer IAFFFLG

Local Decimal INOTINV
Local Decimal IAMTPIT
Local Integer ITER
Local Integer IPRCINV
Local Integer ITOTPRCPIT
Local Integer IPRCNOTINV
Local Integer ITOTPRC
Local Integer IMISPRC
Local Integer IFORMAX

  IPRCINV = 0
  IPRCNOTINV = 0
  ITOTPRC = 0
  IMISPRC = 0
  IAMTPIT = 0
  INOTINV = 0
  IFORMAX = 0
  ITOTPRCPIT = 0
  Raz [M:SRE9]TOTSVC
  Raz [M:SRE9]TOTPDT
  Raz [M:SRE9]TOTEXS
  Raz [M:SRE9]TOTCSM
  Raz [M:SRE9]TOTINV
  Raz [M:SRE9]PRCINV
  Raz [M:SRE9]TOTNOTINV
  Raz [M:SRE9]PRCNOTINV
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    Raz [M:SRE9]PRCPIT
  Endif
  If nolign > [M:SRE9]NBLIG Then
    IFORMAX = [M:SRE9]NBLIG
  Else
    IFORMAX = [M:SRE9]NBLIG - 1
  Endif
  For ITER = 0 To IFORMAX
    [M:SRE9]TOTCSM += [M:SRE9]HDTAMT(ITER)
    [M:SRE9]TOTINV += [M:SRE9]HDTAMTINV(ITER)
    INOTINV = [M:SRE9]HDTAMT(ITER) - [M:SRE9]HDTAMTINV(ITER)
    [M:SRE9]TOTNOTINV += INOTINV
    Case [M:SRE9]HDTTYP(ITER)
      When 2
        [M:SRE9]TOTPDT += [M:SRE9]HDTAMT(ITER)
      When 3
        [M:SRE9]TOTSVC += [M:SRE9]HDTAMT(ITER)
      When 4
        [M:SRE9]TOTEXS += [M:SRE9]HDTAMT(ITER)
    Endcase
    # FGR 29/01/2010 : X3SUIVI62091 : le test est à l'envers
    #If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
      If [M:SRE9]INVPITFLG(ITER) Then
        IAMTPIT += [M:SRE9]HDTAMT(ITER)
      Endif
    Endif
  Next
  If [M:SRE9]TOTCSM = 0 Then
    IPRCINV = 0
    IPRCNOTINV = 0
    [M:SRE9]PRCINV = num$(IPRCINV) + "%"
    [M:SRE9]PRCNOTINV = num$(IPRCNOTINV) + "%"
  Else
    IPRCINV = ([M:SRE9]TOTINV * 100) / [M:SRE9]TOTCSM
    IPRCNOTINV = ([M:SRE9]TOTNOTINV * 100) / [M:SRE9]TOTCSM
    ITOTPRC = IPRCINV + IPRCNOTINV
    IMISPRC = 100 - ITOTPRC
    If IMISPRC < 0 Then
      IMISPRC = 0
    Endif
    IPRCNOTINV += IMISPRC
    [M:SRE9]PRCINV = num$(IPRCINV) + "%"
    [M:SRE9]PRCNOTINV = num$(IPRCNOTINV) + "%"
  Endif
  #Part des points
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    If [M:SRE9]TOTCSM = 0 Then
      [M:SRE9]PRCPIT = "0%"
    Else
      If IAMTPIT > 0 Then
        If IAMTPIT = [M:SRE9]TOTCSM Then
          [M:SRE9]PRCPIT = "100%"
        Else
          ITOTPRCPIT = (IAMTPIT * 100) / [M:SRE9]TOTCSM
          [M:SRE9]PRCPIT = num$(ITOTPRCPIT) + "%"
        Endif
      Else
        [M:SRE9]PRCPIT = "0%"
      Endif
    Endif
  Endif
  If IAFFFLG Then
    Affzo [M:SRE9]10
    Affzo [M:SRE9]15
  Endif
End

##########################################################################################################
#  Calcul du total des points consommés par une demande de service.
################################################################
Subprog LOADTOTPIT(IAFFFLG)
Value Integer IAFFFLG

  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  [M:SRE9]TOTPIT = 0
  If GREP = "C" Then
    Filter [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ and [F:PCT]TPYFLG = 1 and [F:PCT]FGVCAH = 0
  Elsif GREP = "D" Then
    Filter [PCT] Where [F:PCT]SRENUM = [M:SRE0]CRESEQ and [F:PCT]TPYFLG = 1 and [F:PCT]FGVCAH = 0
  Else
    Filter [PCT] Where [F:PCT]SRENUM = [M:SRE0]SRENUM and [F:PCT]TPYFLG = 0 and [F:PCT]FGVCAH = 0
  Endif
  For [PCT]
    [M:SRE9]TOTPIT += [F:PCT]PIT
  Next
  Filter [PCT]
  If IAFFFLG Then
    Affzo [M:SRE9]TOTPIT
  Endif
End

##########################################################################################################
#  Calcul du total des points consommés par une demande de service.
################################################################
Subprog LOADTOT2PIT(IAFFFLG)
Value Integer IAFFFLG

  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 si on ne gère pas les points (PIT) on ne fait rien
    End
  Endif
  #
  [M:SRE9]TOTPIT = 0
  Filter [PCT] Where [F:PCT]SRENUM = [M:SRE0]SRENUM and [F:PCT]TPYFLG = 0 and [F:PCT]FGVCAH = 0
  For [PCT]
    [M:SRE9]TOTPIT += [F:PCT]PIT
  Next
  Filter [PCT]
  If IAFFFLG Then
    Affzo [M:SRE9]TOTPIT
  Endif
End

##########################################################################################################
# Calcul un code séquence temporaire pour la création d'une demande de service
################################################################
Subprog SETSEQNUM(SZSEQNUM)
Variable Char SZSEQNUM

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZSEQCOUNTER
Local Char SZSITE(GLONFCY)

  SZSITE = ""
  SZSEQCOUNTER = ""
  If GPILNAV > 0 Then
    Case GNAVIG(GPILNAV)
      When "GESSRE"
        SZSITE = [M:SRE0]SALFCY
        SZSEQCOUNTER = GSR2CSRECPT
      When "GESSET"
        SZSITE = [M:SET0]SALFCY
        SZSEQCOUNTER = GSR2CSETCPT
      When "GESITN"
        SZSITE = [M:ITN0]SALFCY
        SZSEQCOUNTER = GSR2CITNCPT
    Endcase
  Endif
  # Récupération du compteur de séquence
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK1", SZSITE, SZSEQCOUNTER, date$, "", SZSEQNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 0 Then
      # problème lors de la récupération du compteur
      GERR = 1
      #GMESSAGE = mess(IERRINF,ICHAPTER,1)
      #Erreur lors de la génération du compteur d'identification séquentielle.
      GMESSAGE = mess(536,182,1)
      # FGR 04/12/2009 : X3SUIVI60647 C'est pas "Return" c'est "End"
      #Return
      End
    Endif
  Endif
End

##########################################################################################################
# Chargement du parc
######################################################
$SRE7MAC
  Call LOADMAC([M:SRE0]SRENUM) From SUBSREB1
  If [M:SRE7]NBMAC Then
    Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC(0), 0) From SUBSREB1
  Else
    Raz [M:SRE7]NBCPN
    Raz [M:SRE7]CPNITM
    Raz [M:SRE7]CPNQTY
    Raz [M:SRE7]CPNCOVFLG
    Raz [M:SRE7]CPNCOVSPT
    Raz [M:SRE7]CPNCOVVCR
    Raz [M:SRE7]CPNSEQ
  Endif
  [M:SRE7]PRESRE7NOL = 0
  If GISREHTRUSEMAC Then
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE7]1-99
  Endif
Return

##########################################################################################################
# AFF_TITCOL : affiche les titres des  colonnes des axes analytiques
$AFF_TITCOL
  If GSOC_UPDFLG and !GIMPORT Then
    Local Char BASPAG(10)

    BASPAG = "NBLIG"
    Gosub TIT_COL From ="W1WH2"+GHDKTRSSRE+"9"
    #----- Si tableau vide, il faut forcer l'utilisation des formats évalués -----#
    If [M:SRE9]NBLIG = 0 Then
      [M:SRE9]NBLIG=1
      Affzo [SRE9]5
      Effzo [M:SRE9]5
    Endif
  Endif
  Raz GSOC_UPDFLG
Return

##########################################################################################################
# SAVEVALINI : sauvegarde des valeurs initiales
$SAVEVALINI
  [M:SRE0]SALFCYINI = [M:SRE0]SALFCY
  [M:SRE0]SREBPCINI = [M:SRE0]SREBPC
  [M:SRE1]CREDATINI = [M:SRE1]CREDAT
Return

##########################################################################################################
# Ajout d'un historique d'état
$MNGHISTO
Local Char SZSALESREP
Local Integer IERROR  # FGR 05/11/2010 : X3SUIVI68922

  If GSZPRESAT <> [M:SRE2]SRESAT or GSZPREASS <> [M:SRE2]SREDET or GIPREASS <> [M:SRE2]SREASS Then
    If [M:SRE2]SREASS = 4 Then
      # Service commercial
      # FGR 09/03/2009 : X3SUIVI26656
      Call GET_REP_BPR([M:SRE0]SREBPC, SZSALESREP, IERROR)
      Call CREHISTO([M:SRE0]SRENUM, [M:SRE2]SRESAT, SZSALESREP, [M:SRE2]SREASS, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB1
    Elsif [M:SRE2]SREASS = 5 Then
      # Cloturée
      Call CREHISTO([M:SRE0]SRENUM, [M:SRE2]SRESAT, [M:SRE2]REP, [M:SRE2]SREASS, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB1
    Else
      Call CREHISTO([M:SRE0]SRENUM, [M:SRE2]SRESAT, [M:SRE2]SREDET, [M:SRE2]SREASS, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB1
    Endif
  Endif
  GSZPRESAT = [M:SRE2]SRESAT
  GSZPREASS = [M:SRE2]SREDET
  GIPREASS = [M:SRE2]SREASS
Return

##########################################################################################################
# FGR 07/07/2008 : X3SUIVI48011 (DEBUT)
##########################################################################################################
# Chargement du tableau des factures
###########################################################
Subprog LOADINV(INBLIG)
Variable Integer INBLIG

Local Char CODDEVSOC(GLONCUR)
Local Char SZPRESIDNUM(GLONVCR)
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK
Local Integer ITER
Local Decimal NPARTAMTLIN

  CODDEVSOC = ""
  IT_IS_OK = 1
  IT_IS_NOT_OK = 1
  ITER = 0
  SZPRESIDNUM = ""
  NPARTAMTLIN = 0
  INBLIG = 0
  Raz [M:SREF]INVDAT
  Raz [M:SREF]INVAMT
  Raz [M:SREF]INVVCR
  Raz [M:SREF]NBINV
  Filter [SID] Where [F:SID]SRENUM=[M:SRE0]SRENUM Order By [F:SID]INVDAT Desc; [F:SID]NUM Asc
  For [SID]
    If INBLIG >= dim([M:SREF]INVDAT)-1 Then
      Break
    Endif
    If [F:SID]NUM <> SZPRESIDNUM Then
      If ITER Then
        INBLIG += 1
      Endif
      ITER += 1
      SZPRESIDNUM = [F:SID]NUM
      [M:SREF]INVDAT(INBLIG) = [F:SID]INVDAT
      [M:SREF]INVVCR(INBLIG) = [F:SID]NUM
      Gosub ADDLINAMT
    Else
      Gosub ADDLINAMT
    Endif
  Next
  Filter [SID]
  INBLIG += 1
  [M:SREF]NBINV = INBLIG
  Affzo [M:SREF]10
End

##########################################################################################################
# Augmente le montant d'une facture du montant de la nouvelle ligne
################################################################
$ADDLINAMT
  NPARTAMTLIN = 0
  Read [SIH]SIH0=[F:SID]NUM
  If !fstat Then
    #Conversion du montant à facturer dans une devise unique pour tout le tableau
    If [F:SIH]CUR <> [M:SRE8]SRECUR Then
      Call GETDEVCPY("", [F:SIH]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
      # Devise d'origine
      # Devise destination
      # Devise de la société
      # Type de cours
      # Date du cours
      # Montant origine
      # Montant destination
      # Status de retour (0 = OK)
      Call CONVERT([F:SIH]CUR, [M:SRE8]SRECUR, CODDEVSOC, 2, date$, [F:SID]AMTNOTLIN, NPARTAMTLIN, IT_IS_NOT_OK) From TRTDEV
      If IT_IS_NOT_OK Then
        #Certains montants n'ont pas pus être calculés correctement en raison
        # d'une mauvaise qualification de la table des devises.
        GMESSAGE = mess(278,196,1)
        GERR = 2
      Endif
    Else
      NPARTAMTLIN = [F:SID]AMTNOTLIN
    Endif
  Endif
  [M:SREF]INVAMT(INBLIG) += NPARTAMTLIN
Return

##########################################################################################################
# Chargement du tableau des échéances
###########################################################
Subprog LOADECHE(SZINVNUM)
Value Char SZINVNUM

Local Integer INBLIG
Local Char CODDEVSOC(GLONCUR)
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK

  CODDEVSOC = ""
  IT_IS_OK = 1
  IT_IS_NOT_OK = 1
  INBLIG = 0
  Raz [M:SREF]DUDDAT
  Raz [M:SREF]DUDAMT
  Raz [M:SREF]DUDDPTCOD
  Raz [M:SREF]DUDNUM
  Raz [M:SREF]NBDUD
  If SZINVNUM = "" Then
    Call LOADPAY(SZINVNUM)
    End
  Endif
  Filter [DUD] Where [F:DUD]NUM = SZINVNUM and [F:DUD]TYP = [F:SIH]GTE Order By [F:DUD]DUDLIG Asc
  For [DUD] Hint Key DUD0
    If INBLIG >= dim([M:SREF]DUDDAT)-1 Then
      Break
    Endif
    [M:SREF]DUDDAT(INBLIG) = [F:DUD]DUDDAT
    [M:SREF]DUDDPTCOD(INBLIG) = [F:DUD]DPTCOD
    [M:SREF]DUDNUM(INBLIG) = [F:DUD]DUDLIG
    #Conversion du montant à facturer dans une devise unique pour tout le tableau
    If [F:DUD]CUR <> [M:SRE8]SRECUR Then
      Call GETDEVCPY("", [F:DUD]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
      # Devise d'origine
      # Devise destination
      # Devise de la société
      # Type de cours
      # Date du cours
      # Montant origine
      # Montant destination
      # Status de retour (0 = OK)
      Call CONVERT([F:DUD]CUR, [M:SRE8]SRECUR, CODDEVSOC, 2, date$, [F:DUD]AMTCUR, [M:SREF]DUDAMT(INBLIG), IT_IS_NOT_OK) From TRTDEV
      If IT_IS_NOT_OK Then
        #Certains montants n'ont pas pus être calculés correctement en raison
        # d'une mauvaise qualification de la table des devises.
        GMESSAGE = mess(278,196,1)
        GERR = 2
      Endif
    Else
      [M:SREF]DUDAMT(INBLIG) = [F:DUD]AMTCUR
    Endif
    INBLIG += 1
  Next
  Filter [DUD]
  [M:SREF]NBDUD = INBLIG
  Call LOADPAY(SZINVNUM)
  Affzo [M:SREF]15
End

##########################################################################################################
# Chargement du tableau des réglements
###########################################################
Subprog LOADPAY(SZVCRNUM)
Value Char SZVCRNUM

Local Integer INBLIG
Local Char CODDEVSOC(GLONCUR)
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK

  CODDEVSOC = ""
  IT_IS_OK = 1
  IT_IS_NOT_OK = 1
  INBLIG = 0
  Raz [M:SREF]PAYDAT
  Raz [M:SREF]PAYAMT
  Raz [M:SREF]PAYNUM
  Raz [M:SREF]NBPAY
  If SZVCRNUM = "" Then
    End
  Endif
  For [PYD]PYD0 Where [F:PYD]VCRNUM = SZVCRNUM
    If INBLIG >= dim([M:SREF]PAYDAT)-1 Then
      Break
    Endif
    #Conversion du montant à facturer dans une devise unique pour tout le tableau
    #If [F:PYD]CURLIN <> [M:CON0]CUR Then
    If [F:PYD]CURLIN <> [M:SRE8]SRECUR Then
      Call GETDEVCPY("", [F:PYD]FCYLIN, CODDEVSOC, IT_IS_OK) From CRM_UTIL
      # Devise d'origine
      # Devise destination
      # Devise de la société
      # Type de cours
      # Date du cours
      # Montant origine
      # Montant destination
      # Status de retour (0 = OK)
      Call CONVERT([F:PYD]CURLIN, [M:SRE8]SRECUR, CODDEVSOC, 2, date$, [F:PYD]AMTLIN, [M:SREF]PAYAMT(INBLIG), IT_IS_NOT_OK) From TRTDEV
      If IT_IS_NOT_OK Then
        #Certains montants n'ont pas pus être calculés correctement en raison
        # d'une mauvaise qualification de la table des devises.
        GMESSAGE = mess(278,196,1)
        GERR = 2
      Endif
    Else
      [M:SREF]PAYAMT(INBLIG) = [F:PYD]AMTLIN
    Endif
    [M:SREF]PAYNUM(INBLIG) = [F:PYD]NUM
    [M:SREF]PAYDUDLIG(INBLIG) = [F:PYD]DUDLIG
    Read [PYH] PYH0 = [M:SREF]PAYNUM(INBLIG)
    If !fstat Then
      [M:SREF]PAYDAT(INBLIG) = [F:PYH]ACCDAT
    Endif
    INBLIG += 1
  Next
  Filter [PYD]
  [M:SREF]NBPAY = INBLIG
  Affzo [M:SREF]20
End
