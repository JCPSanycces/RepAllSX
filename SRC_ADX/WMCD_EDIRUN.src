#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## CRUD-CLASSE ## EDIRUN
# 2018-10-17 07:54:24 851


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EDIRUN,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Variable Integer ASTATUS

If EDIRUN = null : End : Endif

Gosub _AVARIABLES From WMC00EDIRUN

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EDIRUN

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EDIRUN,ASTATUS)
Variable Instance EDIRUN Using C_EDIRUN
Variable Integer ASTATUS

If EDIRUN = null : End : Endif

Gosub AVARIABLES From WMC00EDIRUN
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EDIRUN
Else
 Gosub ADELETE_EDIRUN
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EDIRUN,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EDIRUN.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIRUN.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIRUN.EDRD) : # EDIRUND -- 2
 If EDIRUN.EDRD(A_N2) <> null
& and EDIRUN.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIRUN.EDRD(A_N2).ASTALIN<>[V]CST_ANEW
   EDIRUN.EDRD(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIRUN.EDRD) : # EDIRUND -- 2
 If EDIRUN.EDRD(A_N2) <> null
& and EDIRUN.EDRD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EDIRUN
Trbegin [F:EDR]
 Gosub ADELETE_EDIRUN
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EDIRUN
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIRUN.EDRD)
 If EDIRUN.EDRD(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIRUN.EDRD(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDIRUN._MAJSQL_EDIRUND(EDIRUN.EDRD(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.EDRD(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EDIRUN,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIRUN._MAJSQL_EDIRUN(EDIRUN))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUN.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EDIRUN.snapshotEnabled=1
 [L]A_RETIK = EDIRUN.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIRUN.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



