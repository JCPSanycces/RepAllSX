#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
####################################################################################
$ACTION

Case ACTION
  When "SEL_TABLE"         Gosub SEL_TABLE
Endcase

Return
####################################################################################
####################################################################################
$SEL_TABLE

Case PARAM(1)
  When "TABSGHTYP"    : Gosub SEL_TABSGHTYP
  When "TABPNHTYP"    : Gosub SEL_TABPNHTYP
  When "TABTNHTYP"    : Gosub SEL_TABTNHTYP
  When "VATEXEREA"    : Gosub SEL_VATEXEREA
Endcase

Return
####################################################################################
####################################################################################
$SEL_TABSGHTYP

If clalev([F:TSG]) = 0 : Local File TABSGHTYP [TSG] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY  [FCY] : Endif
If clalev([F:FGR]) = 0 : Local File FACGROUP  [FGR] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX] : Endif

Local Char    LFCY(GLONFCY)
Local Char    CODFIC(30)    : CODFIC     = PARAM(1)

LFCY = PARAM(2)

If [F:FCY]FCY <> LFCY
  Read  [F:FCY]FCY0 = LFCY
  If fstat > 1 : Raz [F:FCY] : Endif
Endif

Filter [F:FGR] Where [F:FGR]FCY = LFCY
Look [F:FGR] First
If !fstat
  Local Char LGRP(GLONCPY)(1..1)
  LGRP(1) = [F:FCY]LEGCPY
Else
  Local Integer NGRP
  NGRP = rowcount([F:FGR])
  Local Char LGRP(GLONCPY)(1..NGRP+1)
  Local Integer I : I = 2
  LGRP(1) = [F:FCY]LEGCPY
  For [F:FGR]
    LGRP(I) = [F:FGR]CPY
  Next
Endif
Filter [F:FGR]

CRITERE  = "([F]LEG = '' | [F]LEG = '"+[F:FCY]LEG+"') & "
CRITERE += "([F]GFY = '' | find([F]GFY,LGRP)) & "
CRITERE += "([F]BETFCYCOD = " + PARAM(3) + ")"

Call TEXTE(52507,TIT(0)) From OBJDIV
TIT(0) = mess(12,123,1) - TIT(0)

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:TSG]SGHTYP" : Call TEXTFIC(CODFIC, "SGHTYP", 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "string$([F:TSG]LEG<>'',[F:TSG]LEG)+string$([F:TSG]LEG='',mess(91,187,1))"   : Call TEXTFIC(CODFIC, "LEG", 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"  : Call TEXTFIC(CODFIC, "DESAXX", 1, TIT(NBCOL)) From OBJDIV

Link [TSG] With
& [AXX]AXX0="TABSGHTYP";"DESAXX";GLANGUE;[F:TSG]SGHTYP;[F:TSG]LEG
& As [TSG_]

SIZCOL  = 400
SIZLIG  = 100
START   = "[F:TSG]SGHTYP"
ORDRE   = "[F:TSG]SGHTYP;[F:TSG]LEG"
OBJET   = ""

Default File [F:TSG_]

Return
####################################################################################
####################################################################################
