####################################################################################
####################################################################################
$SEL_VATEXEREA

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
If clalev([F:VER]) = 0 : Local File VATEXEREA [VER] : Endif

Local Char    CODFIC(30)    : CODFIC = PARAM(1)
Local Integer SELFOR        : SELFOR = 1

Call TEXTE(52660,TIT(0)) From OBJDIV
TIT(0) = mess(12,123,1) - TIT(0)

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:VER]CODE"        : Call TEXTFIC(CODFIC, "CODE", 1, TIT(NBCOL)) From OBJDIV
FMTCOL(NBCOL) = "K:3X"
NBCOL += 1 : COL(NBCOL) = "[F:VER]DESCRIPTION" : Call TEXTFIC(CODFIC, "DESCRIPTION", 1, TIT(NBCOL)) From OBJDIV
FMTCOL(NBCOL) = "K:65X"
NBCOL += 1 : COL(NBCOL) = "[F:VER]NOTSUBVAT"   : Call TEXTFIC(CODFIC, "NOTSUBVAT", 1, TIT(NBCOL)) From OBJDIV
FMTCOL(NBCOL) = "LA1:15X"

SIZCOL  = 400
SIZLIG  = 100
START   = "[F:VER]CODE"
ORDRE   = "[F:VER]CODE"
OBJET   = ""

Default File [F:VER]
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END

Return
####################################################################################
####################################################################################
$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return
####################################################################################
####################################################################################
