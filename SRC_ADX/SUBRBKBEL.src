#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBRBKBEL","FRELBAN",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "OUVRE_BATCH" : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$INIT
If clalev([F:TFB])=0  : Local File TABFILBAN    [TFB] : Endif
If clalev([F:RBH])=0  : Local File RBKBELHEA    [RBH] : Endif
If clalev([F:RBD])=0  : Local File RBKBELDET    [RBD] : Endif
If clalev([F:RBD2])=0 : Local File RBKBELDET    [RBD2]: Endif
If clalev([F:RBU])=0  : Local File RBKBELDUD    [RBU] : Endif
If clalev([F:TCU])=0  : Local File TABCUR       [TCU] : Endif
If clalev([F:FCY])=0  : Local File FACILITY     [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY      [CPY] : Endif
If clalev([F:BAN])=0  : Local File BANK         [BAN] : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF    [TCA] : Endif
If clalev([F:RRB])=0  : Local File RBKRUBBEL    [RRB] : Endif
If clalev([F:FRM])=0  : Local File PAYFRM       [FRM] : Endif
If clalev([F:SIH])=0  : Local File SINVOICE     [SIH] : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE   [DUD] : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP    [TPY] : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY    [HAE] : Endif

TMP = 1
TRA = 1
Return

$INIT_DIA
Raz [M:DIA]
Local Char    PARAM1(30)
PARAM1=func AFNC.PARAMUTIL("BELRBKDIR",GUSER,"")
[M:DIA]TYPEXP=2
#The path should be a volume and begin by a [ , the C_VOLFIL will check if the value is OK
If left$(PARAM1,1)="["
 If [M:DIA]VOLFIL="" Then [M:DIA]VOLFIL = PARAM1 : Endif
 Actzo [M:DIA]VOLFIL
Endif

[M:DIA]NOMFIC ="BERLVCODA"    :#Par sécurité (historique X3)

If GNBLEG=1
 [M:DIA]LEG = GDOSLEG(1)
Else
 [M:DIA]LEG = "BEL"
Endif

# Variables for Client
Local Char FICDON(GDIMFIC), URL(GDIMFIC)
Local Integer STAT
Return

$DECLARE
Local Schar   CTEST(1)
Local Integer I, J, K, RG, COK, LIN_REL, LIN_DUD, MAJRBU, STAT, FIN, NBR, LONG, OKTCA, EXIST, DUDOK
Local Integer POS1, POS2
Local Char    COMPTREG(GLONANM), SITE(GLONFCY), REPARCH(GDIMFIC), REPARCHVOL(GDIMFIC), DEVLED(GLONCUR)
Local Integer NB0, NB1, NB21, NB8, NB9, OKBAN, OKFIL, MULTI, CTLDUDOK, TRV_DUD
Local Decimal CUMDEB, CUMCDT, W_COURS

# Variables for record 0
Local Char     ZEROS, NOMDEST, BICBAN, TITULAIRE, VERSION

# Variables for record 1
Local Char     TYPCOMPTE, EXTRAIT, COMPTE(37)
Local Shortint OLDSNS
Local Decimal  OLDAMT
Local Date     OLDDAT
Local Char     TITCPT, DESCPT(35)

# Variables for record 21
Local Char     SEQUENCE, DETAIL, LAST_SEQ
Local Shortint SNS
Local Decimal  AMT
Local Date     DATVAL, DATCPT
Local Char     OPERATION, TYCFLG, COM21(53)

# Variables for record 22
Local Char     REFINT(35), BICCPA, COM22(53)

# Variables for record 23
Local Char     CPTCPA(37), NAMCPA(35), COM23(43)

# Variables for record 31, 32 et 33
Local Char     COM31(73), COM32(105), COM33(90)

# Variables for record 4
Local Char     FREREF(80)

# Variables for record 8
Local Shortint NEWSNS, NEWSNSCAL
Local Decimal  NEWAMT, NEWAMTCAL
Local Date     NEWDAT

# Variables for record 9
Local Decimal  DEBIT, CREDIT, CHECKSUM
Local Char     FND_FRM(GLONVCR), LST_FRM(GLONVCR)(1..30)
Local Integer  NB_FRM, NB_RBU

#---
Local Integer  NBRECTYP : NBRECTYP=11
Local Char     RECTYP(2)(1..NBRECTYP)

Local Char     MACHIN(GDIMFIC)                      : # Machine
Local Char     IRS(2)                               : # Separator
Local Char     OS(20)
Local Char     SEP_CHEMIN(1)                        : # Path Separator ( / or \ )
Local Char     DIR_FIC(GDIMFIC)                     : # Path without machine name
Local Char     PARAM(30)

# Globals Variables for the parameters value level company
Global Char G_BELTRSDEF
Global Char G_BELDENDEF
Global Char G_BELRUBDEF
Global Char G_DENSPG
Global Char G_DENTAK

Global Integer GNBPLAN                               : # Nb of charts of accounts (max 10)
Global Char    GPLAN(GLONCOA)(1..10)                 : # chart of accounts (COA)
Global Integer GTYPLED(1..10)                        : # Types of ledgers
Global Integer GNBAXE                                : # Nb of dimension types (max 20)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Dimension types (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Mandatory (O/N)

Return

$EXEC
If [M]TYPEXP=1 : # Client
 Call COPSRV([M:DIA]FILNAM,[L]FICDON,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN = 1 : TRA = 0 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN = 1 : TRA = 0 : Return
 Endif
Else
 [L]FICDON = [M:DIA]FILNAM
Endif

If !GSERVEUR
 If [M]TYPEXP=2
  Call OUVRE_TRACE(mess(3,120,1)-[M:DIA]VOLFIL) From LECFIC : # Importation relevé bancaire
 Elsif [M]TYPEXP=1
  Call OUVRE_TRACE(mess(3,120,1)-[M:DIA]FILNAM) From LECFIC : # Importation relevé bancaire
 Endif
Endif

If [M:DIA]RBKFMT=1 Then : #Files CODA only
 Call IMPRBKBEL([L]FICDON) From SUBRBKBEL
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return


###########################################################################
#**
#* Import du fichier de relevé bancaire belge
#*
#* @param FICHIER : Fichier à importer
#*!
Subprog IMPRBKBEL(FICHIER)
###########################################################################
Variable Char FICHIER()
Local Integer EXISTE

Gosub DECLARE

# Save the name of file imported
SEP_CHEMIN = "/"
POS1 = 1
POS2 = 0
Repeat
 POS2 = instr(POS1,[M:DIA]FILNAM,SEP_CHEMIN)
 If POS2>=POS1 : POS1 = POS2+1 : Endif
Until !POS2

If POS1=1 Then
 SEP_CHEMIN = "\"
 Repeat
  POS2 = instr(POS1,[M:DIA]FILNAM,SEP_CHEMIN)
  If POS2>=POS1 : POS1 = POS2+1 : Endif
 Until !POS2
Endif

[M:DIA]FICSHO = right$([M:DIA]FILNAM,POS1)

COK=1
I=1
For [TFB]TFB0 Where COD=[M:DIA]NOMFIC and LEG=[M:DIA]LEG and BAN="" and  NUM=1
  RECTYP(I) = [F:TFB]FRM
  I+=1
Next

For [TFB]TFB0 Where COD=[M:DIA]NOMFIC & LEG=[M:DIA]LEG & BAN="" & RECTYP=1
 LONG += [F:TFB]LNG : #Field lenght
Next
Local Schar CHAMP(LONG)

# Importation du fichier XXXX
# Just remove the name of the file already in the title
 Call ECR_TRACE("|"+mess(12,120,1),0) From GESECRAN

Gosub CONTBEL
If !COK Then End : Endif

Gosub IMPORTATION
If !COK Then End : Endif

PARAM = func AFNC.PARAMUTIL("BELRBKDIR",GUSER,"")
If PARAM=""
 Call ECR_TRACE(mess(7,95,1)-":"-mess(157,123,1)-"\"-"BELRBKDIR"-":"-mess(141,143,1),-1) From GESECRAN
 End
Endif
#Begin from the end until the first char and stop before the [
For I=len(PARAM) To 1 Step -1
 If mid$(PARAM,I,1)="[" : Break : Endif
Next I

REPARCHVOL = mid$(PARAM,I+1,len(PARAM)-2)

# Copy of the file in repertory ARCHIVE
REPARCH = filpath(REPARCHVOL,"","")

Call MACHINE(REPARCH,MACHIN,DIR_FIC) From ORDSYS
Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
 When "unix"  : SEP_CHEMIN = "/"
 When Default : SEP_CHEMIN = "\"
Endcase
REPARCH = REPARCH+SEP_CHEMIN+"ARCHIVE"
Call EXISTE(REPARCH,EXIST) From ORDSYS
If EXIST=0    # le répertoire n'existe pas : on le créé
 Call SYSTEME(MACHIN,"ae_mkdir"-REPARCH,"",STAT) From ORDSYS
 Call EXISTE(REPARCH,EXIST) From ORDSYS
Endif
If EXIST=2 # c'est bien un répertoire, on peux y copier le fichier
 Call  COPIE(FICHIER,REPARCH+SEP_CHEMIN+[M:DIA]FICSHO,STAT) From ORDSYS
 If STAT=0 Then
  Call ECR_TRACE("|"+mess(1535,9900,1)-PARAM+SEP_CHEMIN+"ARCHIVE"+SEP_CHEMIN+[M:DIA]FICSHO,0) From GESECRAN
  Call EFFACE([M:DIA]FILNAM,STAT) From ORDSYS
 Else
  Call ECR_TRACE("|"+mess(7,95,1)-mess(157,123,1)-REPARCH+SEP_CHEMIN+[M:DIA]FICSHO,-1) From GESECRAN
 Endif
Else
 Call ECR_TRACE("|"+mess(7,95,1)-mess(157,123,1)-REPARCH+SEP_CHEMIN+[M:DIA]FICSHO,-1) From GESECRAN
Endif
End

###########################################################################################
###                         CONTROLS before IMPORT
###########################################################################################
#**
#* Contrôles liés à la législation Belge (avant import)
#*!
$CONTBEL
Raz J,K, NBR, NB0, NB1, NB9

# Control 1a : blocking : File in text format
Openi FICHIER,0
Gosub LECTEST
While (ascii(CTEST)<32 or ascii(CTEST)>126) & !fstat
 J +=1 : Break
Wend
If J>0 Then Call ECR_TRACE(mess(149,100,1)-":"-mess(73,120,1),1) From GESECRAN : COK=0 : Return : Endif : # Wrong Format

# Control 1a : bloquant : The first line should began with 5 zero
Openi FICHIER,J
Gosub LECTURE
Gosub TRTBEL
If (I=0 or RECTYP(I)+ZEROS<>"00000") Then Call ECR_TRACE(mess(149,100,1)-":"-mess(72,120,1),1) From GESECRAN : COK=0 : Return : Endif : # Wrong Format
Gosub LECTEST
K = 0
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST
Wend
Openi FICHIER,J
Local Schar CHAMP(K+LONG)
Local Schar DRLIG(K+LONG) : # Last line

# Cross all the file
While !fstat
 DRLIG=CHAMP
 Gosub LECTURE
# Control 1a : blocking : Each line should have 128 char
 If !fstat and len(CHAMP)>0 and len(CHAMP)<(LONG) Then STAT=1 : Break : Endif

 Gosub TRTBEL

 If I
 Case RECTYP(I)
  When "0"
   NB0+=1
   Raz CUMDEB, CUMCDT, SEQUENCE, LAST_SEQ

  # Control 6 : blocking : File Version
  # We are on the right line of [TFB] (last of the header = version)
  If VERSION<>[F:TFB]FRM Then Call ECR_TRACE(mess(1,9913,1),1) From GESECRAN : COK=0 : Return : Endif : # Versions non compatibles

  When "1" NB1+=1

   # Control 2 : blocking : Bank control
   #angre X3-89745 (and CUR = vireblc(mid$(COMPTE,14,3),4))
   Raz OKBAN
   Case TYPCOMPTE
    When "0"
      For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,12),4) and CUR = vireblc(mid$(COMPTE,14,3),4)
        OKBAN+=1
        Break
      Next
      If OKBAN = 0
        For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,12),4)
          OKBAN+=1
          Break
        Next
      Endif
    When "1"
      For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,34),4) and CUR =  vireblc(mid$(COMPTE,35,3),4)
        OKBAN+=1
        Break
      Next
      If OKBAN = 0
        For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,34),4)
          OKBAN+=1
          Break
        Next
      Endif
    When "2"
      For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,31),4) and CUR = vireblc(mid$(COMPTE,35,3),4)
        OKBAN+=1
        Break
      Next
      If OKBAN = 0
        For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,31),4)
          OKBAN+=1
          Break
        Next
      Endif
    When "3"
      For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,34),4) and CUR = vireblc(mid$(COMPTE,35,3),4)
        OKBAN+=1
        Break
      Next
      If OKBAN = 0
        For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,34),4)
          OKBAN+=1
          Break
        Next
      Endif
   Endcase
   # Rib of the report not existing in the file BANK
   If !OKBAN Then Call ECR_TRACE(mess(85,120,1),1) From GESECRAN : COK=0 : Return : Endif

   # Control 4 : Old solde : blocking
   Gosub SETFCY
   Filter [F:RBH] Where BAN=[F:BAN]BAN and FCY=SITE
   Read [F:RBH]RBH0 Last
   Filter [F:RBH]
   If !fstat
    If  OLDAMT<>[F:RBH]NEWAMT or OLDSNS<>[F:RBH]NEWSNS Then : # L'ancien solde ne correspond pas au solde précédent
     Call ECR_TRACE([F:RBH]RBKNUM+" : "+mess(11,120,1),1) From GESECRAN : COK=0 : Return
    Endif
    If  OLDDAT<>[F:RBH]NEWDAT  Then : # Date ancien solde ne correspond pas au relevé précédent
     Call ECR_TRACE([F:RBH]RBKNUM+" : "+mess(60,120,1),1) From GESECRAN : COK=0 : Return
    Endif
   Else
    fstat=0
   Endif

   # Contrôle 7 : bloquant : Import 2x du même fichier
   #OKFIL=1
   #For [F:RBH] Where [F:RBH]FILNAM=[M:DIA]FICSHO #or [F:RBH]EXTNUM=val(EXTRAIT) : # Le 31/01/2013 : Désactivation du contrôle de l'extrait car trop contraignant
   #  OKFIL=0 : Break
   #Next
   # Relevé déjà importé N°
   #If !OKFIL Then
   # Call ECR_TRACE(mess(10,120,1)-":"-mess(49,120,1)-num$([F:RBH]RBKNUM)-[F:RBH]BAN-mess(94,100,1)-format$("D:"+GFMDAT,[F:RBH]CREDAT),1) From GESECRAN
   # COK=0
   # Return
   #Endif

  When "21"
   If SEQUENCE<>LAST_SEQ Then
    If SNS=2 : CUMDEB+=AMT : Endif
    If SNS=1 : CUMCDT+=AMT : Endif
   Endif
   LAST_SEQ=SEQUENCE

  When "8"
   If  NEWDAT<OLDDAT Then : # La date de nouveau solde doit être postérieure à la date ancien solde
    Call ECR_TRACE(mess(181,121,1),1) From GESECRAN : COK=0 : Return
   Endif

   If OLDSNS=2 Then
    NEWAMTCAL=OLDAMT-CUMDEB+CUMCDT
    If NEWAMTCAL<0 Then NEWSNSCAL=1 Else NEWSNSCAL=2 : Endif
   Endif
   If OLDSNS=1 Then
    NEWAMTCAL=OLDAMT+CUMDEB-CUMCDT
    If NEWAMTCAL<0 Then NEWSNSCAL=2 Else NEWSNSCAL=1 : Endif
   Endif
   If NEWAMT<>abs(NEWAMTCAL) or NEWSNS<>NEWSNSCAL Then  : # Nouveau solde <> Ancien solde + Total des moovements
    Call ECR_TRACE(mess(13,120,1),1) From GESECRAN : COK=0 : Return
   Endif

  When "9"
   NB9+=1
   # Control 5 : blocking : Addition of movements D and C
   If CUMCDT<>DEBIT  : Call ECR_TRACE(mess(149,100,1)-":"-mess(77,120,1),1) From GESECRAN : COK=0 : Return : Endif : # Wrong format
   If CUMDEB<>CREDIT : Call ECR_TRACE(mess(149,100,1)-":"-mess(78,120,1),1) From GESECRAN : COK=0 : Return : Endif : # Wrong format
 Endcase
 Endif
Wend
If STAT Then Call ECR_TRACE(mess(149,100,1)-":"-mess(75,120,1),1) From GESECRAN : COK=0 : Return : Endif  : # Wrong format

# Control 1a : blocking : The last line should began by "9"
If left$(DRLIG,1)<>"9" Then Call ECR_TRACE(mess(149,100,1)-":"-mess(74,120,1),1) From GESECRAN : COK=0 : Return : Endif : # Wrong format

# Control 1b : blocking : Format file Same number of lines should began by "0", "1" and "9"
If (NB0<>NB1 or NB0<>NB9) Then Call ECR_TRACE(mess(149,100,1)-":"-mess(76,120,1),1) From GESECRAN : COK=0 : Return : Endif : # Wrong format

Return

###########################################################################################
###                    Subprog to read the Belgium Bank statement entry
###########################################################################################
#**
#* Traitement d'une ligne de fichier de relevé pour affectation des variables définies
#* au niveau du paramétrage du fichier bancaire
#*!
$TRTBEL
I=find(left$(CHAMP,1),RECTYP)
If I=0 Then
 I=find(left$(CHAMP,2),RECTYP)
Endif
If I
 Case RECTYP(I)
  When "0"  : Gosub TRTBEL_0
  When "1"  : Gosub TRTBEL_1
  When "21" : Gosub TRTBEL_21
  When "22" : Gosub TRTBEL_22
  When "23" : Gosub TRTBEL_23
  When "31" : Gosub TRTBEL_31
  When "32" : Gosub TRTBEL_32
  When "33" : Gosub TRTBEL_33
  When "4"  : Gosub TRTBEL_4
  When "8"  : Gosub TRTBEL_8
  When "9"  : Gosub TRTBEL_9
 Endcase
Endif
Return

#**
#* Lecture de la ligne de type "0"
#*!
$TRTBEL_0
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "0000"      : ZEROS     = mid$(CHAMP,RG,[F:TFB]LNG)
  When "NOMDEST"   : NOMDEST   = mid$(CHAMP,RG,[F:TFB]LNG)
  When "BICBAN"    : BICBAN    = mid$(CHAMP,RG,[F:TFB]LNG)
  When "TITULAIRE" : TITULAIRE = mid$(CHAMP,RG,[F:TFB]LNG)
  When "2"         : VERSION   = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "1"
#*!
$TRTBEL_1
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "TYPCOMPTE" : TYPCOMPTE = mid$(CHAMP,RG,[F:TFB]LNG)
  When "EXTRAIT"   : EXTRAIT   = mid$(CHAMP,RG,[F:TFB]LNG)
  When "COMPTE"    : COMPTE    = mid$(CHAMP,RG,[F:TFB]LNG)
  When "OLDSNS"    : Call SENS_DC(mid$(CHAMP,RG,[F:TFB]LNG),OLDSNS)
  When "OLDAMT"    : Call MNTT(mid$(CHAMP,RG,[F:TFB]LNG),"3",OLDAMT)
  When "OLDDAT"    : Call DAT (mid$(CHAMP,RG,[F:TFB]LNG),OLDDAT)
  When "TITCPT"    : TITCPT    = mid$(CHAMP,RG,[F:TFB]LNG)
  When "DESCPT"    : DESCPT    = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "21"
#*!
$TRTBEL_21
Call FILTRE(val(RECTYP(I)))
RG=1
LAST_SEQ=SEQUENCE
For [TFB]TFB0
 Case [F:TFB]FRM
  When "SEQUENCE"  : SEQUENCE  = mid$(CHAMP,RG,[F:TFB]LNG)
  When "DETAIL"    : DETAIL    = mid$(CHAMP,RG,[F:TFB]LNG)
  When "SNS"       : Call SENS_DR(mid$(CHAMP,RG,[F:TFB]LNG),SNS)
  When "AMT"       : Call MNTT(mid$(CHAMP,RG,[F:TFB]LNG),"3",AMT)
  When "DATVAL"    : Call DAT (mid$(CHAMP,RG,[F:TFB]LNG),DATVAL)
  When "OPERATION" : OPERATION = mid$(CHAMP,RG,[F:TFB]LNG)
  When "TYCFLG"    : TYCFLG    = mid$(CHAMP,RG,[F:TFB]LNG)
  When "COM21"     : COM21     = mid$(CHAMP,RG,[F:TFB]LNG)
  When "DATCPT"    : Call DAT (mid$(CHAMP,RG,[F:TFB]LNG),DATCPT)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "22"
#*!
$TRTBEL_22
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "COM22"  : COM22  = mid$(CHAMP,RG,[F:TFB]LNG)
  When "REFINT" : REFINT = mid$(CHAMP,RG,[F:TFB]LNG)
  When "BICCPA" : BICCPA = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "23"
#*!
$TRTBEL_23
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "CPTCPA" : CPTCPA = mid$(CHAMP,RG,[F:TFB]LNG)
  When "NAMCPA" : NAMCPA = mid$(CHAMP,RG,[F:TFB]LNG)
  When "COM23"  : COM23  = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "31"
#*!
$TRTBEL_31
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "COM31" : COM31 = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "32"
#*!
$TRTBEL_32
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "COM32" : COM32 = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "33"
#*!
$TRTBEL_33
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "COM33" : COM33 = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "4"
#*!
$TRTBEL_4
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "FREREF" : FREREF = mid$(CHAMP,RG,[F:TFB]LNG)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "8"
#*!
$TRTBEL_8
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "NEWSNS" : Call SENS_DC(mid$(CHAMP,RG,[F:TFB]LNG),NEWSNS)
  When "NEWAMT" : Call MNTT(mid$(CHAMP,RG,[F:TFB]LNG),"3",NEWAMT)
  When "NEWDAT" : Call DAT (mid$(CHAMP,RG,[F:TFB]LNG),NEWDAT)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

#**
#* Lecture de la ligne de type "9"
#*!
$TRTBEL_9
Call FILTRE(val(RECTYP(I)))
RG=1
For [TFB]TFB0
 Case [F:TFB]FRM
  When "DEBIT"  : Call MNTT(mid$(CHAMP,RG,[F:TFB]LNG),"3",DEBIT)
  When "CREDIT" : Call MNTT(mid$(CHAMP,RG,[F:TFB]LNG),"3",CREDIT)
 Endcase
 RG +=[F:TFB]LNG
Next
Filter [F:TFB]
Return

###########################################################################################
###                    Import of Belgium Bank statement
###########################################################################################
#**
#* Importation du fichier dans les tables de relevé bancaire belges
#*!
$IMPORTATION
# Open the transaction
Trbegin [RBH], [RBD], [RBU]
# Open again the file from the beginning
Openi FICHIER,J
#Process the file
Gosub LECTURE
While !fstat
 COK = 1
 Gosub TRTBEL
 If I=0 Then
  # Code Record not existing
  Call ECR_TRACE(left$(CHAMP,2)-":"-mess(4,120,1),-1) From GESECRAN
  COK=0
 Else
  Case RECTYP(I)
   When "0"  : Gosub IMP_0
   When "1"  : Gosub IMP_1
   When "21"
    If [M:DIA]DETFLG=2 Then # Import the detail line ?
     Gosub IMP_21
    Else
     If find(left$(OPERATION,1),"0","1","2","3") Then
      Gosub IMP_21
     Endif
    Endif
   When "22" : Gosub IMP_22
   When "23" : Gosub IMP_23
   When "31" : Gosub IMP_31
   When "32" : Gosub IMP_32
   When "33" : Gosub IMP_33
   When "4"  : Gosub IMP_4
   When "8"  : Gosub IMP_8
   When "9"  : Gosub IMP_9
  Endcase
  If COK Then
   Gosub LECTURE
  Else
   Break
  Endif
 Endif
Wend
If !NBR
 Call ECR_TRACE(mess(8,120,1),0) From GESECRAN  : #Pas de relevé à importer
 COK=0
Endif
# End of transaction
If COK Then
 Commit
Else
 Rollback : FIN=1
Endif
Return

#**
#* Import d'une ligne de fichier de type "0"
#*!
$IMP_0
FIN     = 0
LIN_REL = 1
Raz SEQUENCE, LAST_SEQ
Raz [F:RBH]
[F:RBH]DESTNAM  =[L]NOMDEST
[F:RBH]BICCODBAN=[L]BICBAN
[F:RBH]IDENTNUM =[L]TITULAIRE
Return

#**
#* Import d'une ligne de fichier de type "1"
#*!
$IMP_1
Local Integer CTR : CTR = 0 #angre X3-89745
Raz NB21, NB8
# Defined Currency and Bank
#angre X3-89745 (and CUR = [F:RBH]CUR)
Case TYPCOMPTE
 When "0"
  [F:RBH]CUR=vireblc(mid$(COMPTE,14,3),4)
  For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,12),4) and CUR = [F:RBH]CUR
    CTR += 1
    Break
  Next
  If CTR = 0
    For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,12),4)
      Break
    Next
  Endif
 When "1"
  [F:RBH]CUR=vireblc(mid$(COMPTE,35,3),4)
  For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,34),4) and CUR = [F:RBH]CUR
    CTR += 1
    Break
  Next
  If CTR = 0
    For [F:BAN] Where BIDNUM=vireblc(left$(COMPTE,34),4)
      Break
    Next
  Endif
 When "2"
  [F:RBH]CUR=vireblc(mid$(COMPTE,35,3),4)
  For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,31),4) and CUR = [F:RBH]CUR
    CTR += 1
    Break
  Next
  If CTR = 0
    For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,31),4)
      Break
    Next
  Endif
 When "3"
  [F:RBH]CUR=vireblc(mid$(COMPTE,35,3),4)
  For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,34),4) and CUR = [F:RBH]CUR
    CTR += 1
    Break
  Next
  If CTR = 0
    For [F:BAN] Where IBACOD=vireblc(left$(COMPTE,34),4)
      Break
    Next
  Endif
Endcase
If [F:RBH]CUR="" Then [F:RBH]CUR=[F:BAN]CUR : Endif

# Take back the Sequence number of bank statements
Gosub MAJCHRONO
If !COK Then Return : Endif

# Fill in the other fields of RBKBELHEA (Header of Belgium bank statement)
[F:RBH]CPY      =[F:BAN]CPY
[F:RBH]FCY      =SITE
[F:RBH]BAN      =[F:BAN]BAN
[F:RBH]EXTNUM   =val([L]EXTRAIT)
[F:RBH]RELTYP   =1               : # Imported
[F:RBH]FILTYP   =[M:DIA]RBKFMT   : # CODA, etc.
[F:RBH]FILNAM   =[M:DIA]FICSHO
[F:RBH]OLDSNS   =[L]OLDSNS
[F:RBH]OLDAMT   =[L]OLDAMT
[F:RBH]OLDDAT   =[L]OLDDAT
[F:RBH]BIDNUMBAN=[L]COMPTE
[F:RBH]ACCNAM   =[L]TITCPT
[F:RBH]ACCDES   =[L]DESCPT
[F:RBH]CREUSR   =GUSER
[F:RBH]CREDAT   =date$
[F:RBH]CREDATTIM=datetime$
[F:RBH]ACCNUM   =uniqid([F:RBH])
Write [F:RBH]
If fstat GOK = 0 : Call FSTA("RBH") From GLOCK : COK=0 : Return : Endif
NBR = 1
Return

#**
#* Import d'une ligne de fichier de type "21"
#*!
$IMP_21
NB21+=1
If SEQUENCE<>LAST_SEQ Then
 Raz [F:RBD]
 [F:RBD]RBKNUM=[F:RBH]RBKNUM
 [F:RBD]RBKLIN=LIN_REL : LIN_REL+=1
 [F:RBD]STATUT=1
 [F:RBD]FCYLIN=[F:RBH]FCY
 [F:RBD]ACCDAT=[L]DATCPT
 [F:RBD]VALDAT=[L]DATVAL
 [F:RBD]SNS   =[L]SNS
 [F:RBD]AMTCUR=[L]AMT
 [F:RBD]COA   =GPLAN(1)
 [F:RBD]PAYTYP=G_BELTRSDEF
 If find(1,[F:BAN]JOUTYP) Then
  [F:RBD]ACCBAN=[F:BAN]TREACC(find(1,[F:BAN]JOUTYP)-1)  : # Account of Bank entry
 Endif
 [F:RBD]CREDATTIM=datetime$
 Write [F:RBD]
 If fstat GOK = 0 : Call FSTA("RBD") From GLOCK : COK=0 : Return : Endif
 LIN_DUD = 1
 MAJRBU  = 0
Else
 If !MAJRBU Then LIN_DUD+=1 : Endif
Endif

If MAJRBU Then
 Read [F:RBU]RBU0=[F:RBD]RBKNUM;[F:RBD]RBKLIN;LIN_DUD
 If fstat GOK = 0 : COK=0 : Return : Endif
Else
 Raz [F:RBU]
Endif
[F:RBU]RBKNUM=[F:RBD]RBKNUM
[F:RBU]RBKLIN=[F:RBD]RBKLIN
[F:RBU]LIN   =LIN_DUD
[F:RBU]NUMSEQ=[L]SEQUENCE+[L]DETAIL
[F:RBU]AMTLIN=[L]AMT : Gosub SETAMTLOC
[F:RBU]TYP   =val(left$([L]OPERATION,1))
[F:RBU]CODOP =mid$([L]OPERATION,2,4)
[F:RBU]RUB   =right$([L]OPERATION,6)
[F:RBU]COA   =[F:RBD]COA
[F:RBU]COMFLG=val([L]TYCFLG)+1
If [F:RBU]COMFLG=2 Then
 [F:RBU]TYPCOM=left$([L]COM21,3)
 [F:RBU]COMFLD=right$([L]COM21,4)
 Call SETVCS([F:RBU]TYPCOM,[F:RBU]COMFLD,[F:RBU]BELVCS)
Endif
Gosub SETDEN
If [F:RBU]DENCOD<>"" and [F:RBU]ACC<>"" Then
 Call SETVAT([F:RBU]DENCOD,[F:RBU]COA,[F:RBU]ACC,[F:RBU]VATLIN)
Endif

If MAJRBU Then
 Rewrite [F:RBU]
 If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Return : Endif
 MAJRBU=0
Else
 Write [F:RBU]
 If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Return : Endif
 If LIN_DUD=1 Then MAJRBU=1 : Endif
Endif

Read [F:RBD]RBD0=[F:RBH]RBKNUM;[F:RBD]RBKLIN
If fstat GOK = 0 : COK=0 : Return : Endif
Gosub SETACCTMP
Rewrite [F:RBD]
If fstat GOK = 0 : Call FSTA("RBD") From GLOCK : COK=0 : Return : Endif
Return

#**
#* Import d'une ligne de fichier de type "22"
#*!
$IMP_22
Read [F:RBU]RBU0=[F:RBD]RBKNUM;[F:RBD]RBKLIN;LIN_DUD
If fstat GOK = 0 : COK=0 : Return : Endif
[F:RBU]BICCOD=[L]BICCPA
If [F:RBU]COMFLG<>2 Then
 Call SETREFINT([L]REFINT,[F:RBU]REFINT)
Else
 [F:RBU]COMFLD+=[L]COM22
Endif
Rewrite [F:RBU]
If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Return : Endif
Return

#**
#* Import d'une ligne de fichier de type "23"
#*!
$IMP_23
Read [F:RBU]RBU0=[F:RBD]RBKNUM;[F:RBD]RBKLIN;LIN_DUD
If fstat GOK = 0 : COK=0 : Return : Endif
[F:RBU]OFFACCNAM=[L]NAMCPA
[F:RBU]BIDNUM   =[L]CPTCPA
If [F:RBU]COMFLG=2 Then
 [F:RBU]COMFLD  +=[L]COM23
Endif
Rewrite [F:RBU]
If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Return : Endif

Read [F:RBD]RBD0=[F:RBH]RBKNUM;[F:RBD]RBKLIN
If fstat GOK = 0 : COK=0 : Return : Endif
Call SETBPR([L]TYPCOMPTE,[L]CPTCPA,[F:RBD]BPRNUM,[F:RBD]BPRNAM)
Rewrite [F:RBD]
If fstat GOK = 0 : Call FSTA("RBD") From GLOCK : COK=0 : Return : Endif
Return

#**
#* Import d'une ligne de fichier de type "31"
#*!
$IMP_31
Read [F:RBU]RBU0=[F:RBD]RBKNUM;[F:RBD]RBKLIN;LIN_DUD
If fstat GOK = 0 : COK=0 : Return : Endif
If [F:RBU]COMFLG=2 Then
 [F:RBU]COMFLD+=right$([L]COM31,4)
 Rewrite [F:RBU]
 If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Return : Endif
Endif
Return

#**
#* Import d'une ligne de fichier de type "32"
#*!
$IMP_32
Read [F:RBU]RBU0=[F:RBD]RBKNUM;[F:RBD]RBKLIN;LIN_DUD
If fstat GOK = 0 : COK=0 : Return : Endif
If [F:RBU]COMFLG=2 Then
 [F:RBU]COMFLD+=[L]COM32
 Rewrite [F:RBU]
 If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Return : Endif
Endif
Return

#**
#* Import d'une ligne de fichier de type "33"
#*!
$IMP_33
Read [F:RBU]RBU0=[F:RBD]RBKNUM;[F:RBD]RBKLIN;LIN_DUD
If fstat GOK = 0 : COK=0 : Return : Endif
If [F:RBU]COMFLG=2 Then
 [F:RBU]COMFLD+=[L]COM33
 Rewrite [F:RBU]
 If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Return : Endif
Endif
Return

#**
#* Import d'une ligne de fichier de type "4"
#*!
$IMP_4
Read [F:RBH]RBH0=[F:RBH]RBKNUM
If fstat GOK = 0 : COK=0 : Return : Endif
[F:RBH]FRETXT=[L]FREREF
Rewrite [F:RBH]
If fstat GOK = 0 : Call FSTA("RBH") From GLOCK : COK=0 : Return : Endif
Return

#**
#* Import d'une ligne de fichier de type "8"
#*!
$IMP_8
NB8+=1
Read [F:RBH]RBH0=[F:RBH]RBKNUM
If fstat GOK = 0 : COK=0 : Return : Endif
[F:RBH]NEWSNS=[L]NEWSNS
[F:RBH]NEWAMT=[L]NEWAMT
[F:RBH]NEWDAT=[L]NEWDAT
Rewrite [F:RBH]
If fstat GOK = 0 : Call FSTA("RBH") From GLOCK : COK=0 : Return : Endif
Return

#**
#* Si pas de ligne de type "8" dans le fichier on initialise avec l'ancien
#*!
$IMP_8_VIDE
Read [F:RBH]RBH0=[F:RBH]RBKNUM
If fstat GOK = 0 : COK=0 : Return : Endif
[F:RBH]NEWSNS=[F:RBH]OLDSNS
[F:RBH]NEWAMT=[F:RBH]OLDAMT
[F:RBH]NEWDAT=[F:RBH]OLDDAT
Rewrite [F:RBH]
If fstat GOK = 0 : Call FSTA("RBH") From GLOCK : COK=0 : Return : Endif
Return

#**
#* Import d'une ligne de fichier de type "9"
#*!
$IMP_9
# If file imported is empty
If NB21=0 and NB8=0 Then Gosub IMP_8_VIDE : Endif
Gosub VRF_POST_IMP
# Croos the record 9
Read [F:RBH]RBH0=[F:RBH]RBKNUM
If fstat GOK = 0 : COK=0 : Return : Endif
[F:RBH]AMTDEB=[L]DEBIT
[F:RBH]AMTCDT=[L]CREDIT
Rewrite [F:RBH]
If fstat GOK = 0 : Call FSTA("RBH") From GLOCK : COK=0 : Return : Endif
Call ECR_TRACE(mess(166,117,1)-[F:RBH]RBKNUM,0) From GESECRAN
#angre X3-89745
If [F:RBH]CUR <> [F:BAN]CUR
  Call ECR_TRACE (func AFNC.MES3(mess(353,117,1),[F:RBH]CUR,[F:RBH]BAN,[F:BAN]CUR),0) From GESECRAN
Endif
Return

###########################################################################################
###                     Subprog for Dynamic Allocation
###########################################################################################
#**
#* Détermination du SITE et de la SOCIETE
#*!
$SETFCY
Raz SITE
# Facility
If [F:BAN]FCY<>"" Then
 SITE=[F:BAN]FCY # Bank facility
Else
 Call LEC_CPY([F:BAN]CPY) From CPTLEC
 If [F:CPY]MAIFCY<>"" Then
  SITE=[F:CPY]MAIFCY # Main site
 Else
  # The first site of the company
  For [F:FCY] Where LEGCPY=[F:BAN]CPY : SITE=[F:FCY]FCY : Break : Next
 Endif
Endif
If SITE=""
 # No site
 Call ECR_TRACE(mess(68,107,1)-[F:BAN]CPY,1) From GESECRAN : COK=0
Endif
Return

#**
#* Lecture de la Société et affectation du compteur de relevé
#*!
$MAJCHRONO
Gosub SETFCY
If SITE<>""
 Call GETSOC(SITE) From DEVSUB
# Globals Variables for the parameters value level company
 G_BELTRSDEF=func AFNC.PARAM("BELTRSDEF",SITE)
 G_BELDENDEF=func AFNC.PARAM("BELDENDEF",SITE)
 G_BELRUBDEF=func AFNC.PARAM("BELRUBDEF",SITE)
 G_DENSPG   =func AFNC.PARAM("DENSPG",SITE)
 G_DENTAK   =func AFNC.PARAM("DENTAK",SITE)

 Call SETCUR(1,[F:BAN]CPY,[L]DEVLED) From CPTDIV

 Call SETPLAN([F:BAN]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
 Call LECTCA(3,OKTCA) From SUBTCA
 COMPTREG = ""
 If OKTCA : COMPTREG = [F:TCA]CODNUM(5) : Endif
 If COMPTREG="" : COMPTREG = "BERBK" : Endif
 # Take back the Sequence number of bank statements
 Call NUMERO(COMPTREG,SITE,datesyst,[F:BAN]BAN,[F:RBH]RBKNUM,STAT) From SUBANM
 If STAT | GOK<1
  # PB with the Sequence
  Gosub MESSAGE From SUBANM
  Call ECR_TRACE(mess(60,199,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN : COK=0
 Endif
Endif
Return


#**
#* Détermination du montant en devise locale
#*!
$SETAMTLOC
If [F:RBU]AMTLIN=0      Then [F:RBU]AMTLINLOC=0             : Return : Endif
If [F:RBH]CUR=[L]DEVLED Then [F:RBU]AMTLINLOC=[F:RBU]AMTLIN : Return : Endif

### Call LECTURE("TPY",[F:RBD]PAYTYP,"") From CONTOBJ :#-- @BACKPORTING@ pour V6
Call LEC_TPY_LEG([V]GCURLEG,[F:RBD]PAYTYP) From CPTLEC
[L]W_COURS=0

Call CONVERT3([F:RBH]CUR,[L]DEVLED,[L]DEVLED,[F:TPY]RATTYP,[F:RBD]ACCDAT,[F:RBU]AMTLIN,[F:RBU]AMTLINLOC,[L]W_COURS,STAT) From CPTSUB
If STAT
 # No currency rate
 Call ECR_TRACE(mess(16,114,1)-[F:RBH]CUR-"->"-[L]DEVLED-"("+format$("D:"+GFMDAT,[F:RBD]ACCDAT)-")",1) From GESECRAN
 COK=0
Endif
Return

#**
#* Retourne le numéro VCS si trouvé dans le paramétrage du type de communication
#* (Recherche du titre "VCS" dans le paramétrage de la zone de type de communication)
#*
#* @param P_TYP : Type de communication
#* @param P_COM : Contenu de la zone de communication structurée
#* @param P_VCS : Numéro VCS en retour
#*!
Subprog SETVCS (P_TYP,P_COM,P_VCS)
Value    Char P_TYP()
Value    Char P_COM()
Variable Char P_VCS()
If !clalev([F:TYC]) : Local File TYPCOMBEL [TYC] : Endif
# The VCS number will be in comm 101 ou 102
# composed by one element
If find(P_TYP,"101","102") Then
 For [F:TYC]TYC0 Where COD=P_TYP
  P_VCS=left$(P_COM,[F:TYC]LNG)
  Break
 Next
Endif
End

#**
#* Détermination du compte d'entête
#*!
$SETACCTMP
# Read rubrique
Read [F:RRB]RRB0=right$([L]OPERATION,6)
If !fstat Then
 If [F:RRB]IPTTYP=2 : # Account
   If find([F:RBD]COA,[F:RRB]COA) Then
    [F:RBD]ACCTMP=[F:RRB]ACC(find([F:RBD]COA,[F:RRB]COA)-1)
   Endif
 Endif
Else
 Read [F:RRB]RRB0=G_BELRUBDEF
 If !fstat Then
  If find([F:RBD]COA,[F:RRB]COA) Then
   [F:RBD]ACCTMP=[F:RRB]ACC(find([F:RBD]COA,[F:RRB]COA)-1)
  Endif
 Endif
 fstat=0
Endif
Return

#**
#* Détermination de la destination comptable
#*!
$SETDEN
Read [F:RRB]RRB0=[F:RBU]RUB
If !fstat Then
 Case [F:RRB]IPTTYP
  When 1 : # No imputation
   Case [F:RBD]SNS
    When 1 : [F:RBU]DENCOD=G_DENSPG : # Expense
    When 2 : [F:RBU]DENCOD=G_DENTAK : # Revenue
   Endcase
  When 2 : # Account
   [F:RBU]DENCOD=G_BELDENDEF
   If find([F:RBU]COA,[F:RRB]COA) Then
    [F:RBU]ACC   =[F:RRB]ACC(find([F:RBU]COA,[F:RRB]COA)-1)
   Endif
 Endcase
Else
 Read [F:RRB]RRB0=G_BELRUBDEF
 If !fstat Then
  [F:RBU]DENCOD=G_BELDENDEF
  If find([F:RBU]COA,[F:RRB]COA) Then
   [F:RBU]ACC=[F:RRB]ACC(find([F:RBU]COA,[F:RRB]COA)-1)
  Endif
 Endif
 fstat=0
Endif
Return

#**
#* Détermination de la pièce à partir du numéro VCS
#*
#* @param P_NUMVCS : Numéro VCS
#* @param P_VCRTYP : Type de pièce en retour
#* @param P_VCRNUM : Numéro de pièce en retour
#*!
Subprog SETVCR(P_NUMVCS,P_VCRTYP,P_VCRNUM)
Value    Char P_NUMVCS
Variable Char P_VCRTYP
Variable Char P_VCRNUM
# Find the VCS number in Customer/Supplier invoices
If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
For [F:SIH] Where BELVCS=P_NUMVCS and INVTYP=1 # Invoice
 P_VCRTYP=[F:SIH]GTE
 P_VCRNUM=[F:SIH]NUM
 Break
Next
End

#**
#* Détermination de l'échéance
#* Maj des montant en devise locale et devise d'échéance
#*!
$SETDUD
# Find the VCS number in Customer/Supplier invoices
CTLDUDOK=0
Read [F:SIH]SIH0=[F:RBU]VCRNUM
If !fstat
 Raz MULTI, TRV_DUD
 For [F:DUD] Where ACCNUM=[F:SIH]ACCNUM
  If !TRV_DUD Then
   Gosub CONV_DUD
   If [F:DUD]DUDLIG=1 Then
    [F:RBU]DUDNUM = [F:DUD]ACCNUM
    [F:RBU]DUDLIG = [F:DUD]DUDLIG
   Endif
   If [F:RBU]AMTLINCUR<=[F:DUD]AMTCUR-([F:DUD]PAYCUR+[F:DUD]TMPCUR) Then # No twice payment
    [F:RBU]DUDNUM = [F:DUD]ACCNUM
    [F:RBU]DUDLIG = [F:DUD]DUDLIG
    TRV_DUD=1
   Endif
  Endif
  MULTI+=1 : If MULTI>1 and TRV_DUD Then Break : Endif
 Next
 If MULTI=1 and TRV_DUD=0 Then
  TRV_DUD=1
 Endif
 If MULTI>1 Then
  Call ECR_TRACE(mess(2,2389,1)-[F:SIH]BELVCS-","-mess(82,120,1),-1) From GESECRAN
 Endif
 If TRV_DUD Then
  Read [F:DUD]DUD1=[F:RBU]DUDNUM;[F:RBU]DUDLIG
  If !fstat
   [F:RBU]DUDDAT = [F:DUD]DUDDAT
   Gosub CONV_DUD
   CTLDUDOK = 1
   #Contrôle de l'échéance trouvée
   If [F:DUD]CPY<>[F:RBH]CPY Then # Sociétés echéance / relevé incompatibles
    Call ECR_TRACE(mess(79,120,1)-mess(80,120,1)-[F:SIH]BELVCS-","-[F:DUD]NUM-mess(90,120,1),-1) From GESECRAN
    CTLDUDOK=0
   Endif
   If [F:DUD]BPR<>[F:RBD]BPRNUM Then # Tiers echéance / relevé incompatibles
    Call ECR_TRACE(mess(81,120,1)-mess(80,120,1)-[F:SIH]BELVCS-","-[F:DUD]NUM-mess(90,120,1),-1) From GESECRAN
    CTLDUDOK=0
   Endif
   If [F:SIH]STA<>3 Then # Echéance non comptabilisée
    Call ECR_TRACE(mess(28,121,1)-mess(80,120,1)-[F:SIH]BELVCS-","-[F:DUD]NUM-mess(90,120,1),-1) From GESECRAN
    CTLDUDOK=0
   Endif
   If [F:DUD]FLGPAZ<4 Then # Niveau de bon à payer
    Call ECR_TRACE(mess(16,117,1)-mess(80,120,1)-[F:SIH]BELVCS-","-[F:DUD]NUM-mess(90,120,1),-1) From GESECRAN
    CTLDUDOK=0
   Endif
   If [F:DUD]FLGCLE=2 Then # Echéance déjà soldée
    Call ECR_TRACE(mess(15,117,1)-mess(80,120,1)-[F:SIH]BELVCS-","-[F:DUD]NUM+"/"+num$([F:DUD]DUDLIG)-mess(90,120,1),-1) From GESECRAN
    CTLDUDOK=0
   Endif
   If [F:RBU]AMTLINCUR>[F:DUD]AMTCUR-([F:DUD]PAYCUR+[F:DUD]TMPCUR) Then # Sur-règlement non autorisé
    Call ECR_TRACE(mess(56,117,1)-mess(80,120,1)-[F:SIH]BELVCS-","-[F:DUD]NUM+"/"+num$([F:DUD]DUDLIG)-mess(90,120,1),-1) From GESECRAN
    CTLDUDOK=0
   Endif
  Endif
 Else
  Call ECR_TRACE(mess(2,2389,1)-[F:SIH]BELVCS-","-mess(89,120,1),-1) From GESECRAN
 Endif
Endif

If CTLDUDOK Then
 Gosub CONV_DUD                           : # Find the amount in due date Currency
 If CTLDUDOK Then  Gosub CONV_LOC : Endif : # Find the amount in ledger Currency
Endif

If CTLDUDOK Then
 # Update DueDate
 [F:DUD]TMPCUR += [F:RBU]AMTLINCUR
 [F:DUD]TMPLOC += [F:RBU]AMTLINLOC
 Rewrite [F:DUD]
 If fstat GOK = 0 : Call FSTA("DUD") From GLOCK : CTLDUDOK=0 : Endif
Else
 Raz [F:RBU]VCRTYP,[F:RBU]VCRNUM,[F:RBU]DUDNUM,[F:RBU]DUDLIG,[F:RBU]DUDDAT,[F:RBU]AMTLINCUR
Endif
Return

#**
#* Détermination du montant en devise d'échéance
#*!
$CONV_DUD
If [F:DUD]CUR=[F:RBH]CUR : [F:RBU]AMTLINCUR=[F:RBU]AMTLIN : Return : Endif

### Call LECTURE("TPY",[F:RBD]PAYTYP,"") From CONTOBJ :#-- @BACKPORTING@ pour V6
Call LEC_TPY_LEG([V]GCURLEG,[F:RBD]PAYTYP) From CPTLEC
[L]W_COURS=0
If [F:TPY]RATINV=2 and [F:RBH]CUR=[L]DEVLED :
 Read [HAE]HAE0 = [F:RBU]VCRTYP;[F:RBU]VCRNUM
 If fstat
  Call ECR_TRACE(mess(49,125,1)-mess(12,107,1)-[F:RBU]VCRTYP+"/"+[F:RBU]VCRNUM,-1) From GESECRAN
  CTLDUDOK=0
  Return
 Endif
 If [F:HAE]RATMLT(GTYPGEN-1)<>0
  [L]W_COURS = [F:HAE]RATDIV(GTYPGEN-1)/[F:HAE]RATMLT(GTYPGEN-1)
 Endif
 Call CONVERT3([F:RBH]CUR,[F:DUD]CUR,[L]DEVLED,[F:HAE]TYPRAT,[F:HAE]RATDAT,[F:RBU]AMTLIN,[F:RBU]AMTLINCUR,[L]W_COURS,[L]STAT) From CPTSUB
 If [L]STAT
  ## Pas de cours de devises [F:DUD]CUR -> [M:RBK0]CUR
  Call ECR_TRACE(mess(16,114,1)-[F:RBH]CUR-"->"-[F:DUD]CUR-"("+format$("D:"+GFMDAT,[F:HAE]RATDAT)-")",-1) From GESECRAN
  CTLDUDOK=0
  Return
 Endif
Else
 Call CONVERT3([F:RBH]CUR,[F:DUD]CUR,[L]DEVLED,[F:TPY]RATTYP,[F:RBD]ACCDAT,[F:RBU]AMTLIN,[F:RBU]AMTLINCUR,[L]W_COURS,[L]STAT) From CPTSUB
 If [L]STAT
  ## Pas de cours de devises [F:DUD]CUR -> [M:RBK0]CUR
  GMESSAGE=mess(16,114,1)-[F:RBH]CUR-"->"-[F:DUD]CUR-"("+format$("D:"+GFMDAT,[F:RBD]ACCDAT)-")"
  CTLDUDOK=0
  Return
 Endif
Endif
Return

#**
#* Détermination du montant en devise de référentiel
#*!
$CONV_LOC
If [F:RBU]AMTLIN=0      Then [F:RBU]AMTLINLOC=0             : Return : Endif
If [L]DEVLED=[F:RBH]CUR Then [F:RBU]AMTLINLOC=[F:RBU]AMTLIN : Return : Endif

### Call LECTURE("TPY",[F:RBD]PAYTYP,"") From CONTOBJ :#-- @BACKPORTING@ pour V6
Call LEC_TPY_LEG([L]DEVLED,[F:RBD]PAYTYP) From CPTLEC
[L]W_COURS=0
If [F:RBU]DUDNUM<>0 & [F:RBU]VCRNUM<>""
  Read [HAE]HAE0 = [F:RBU]VCRTYP;[F:RBU]VCRNUM
  If fstat
   Call ECR_TRACE(mess(49,125,1)-mess(12,107,1)-[F:RBU]VCRTYP+"/"+[F:RBU]VCRNUM,-1) From GESECRAN
   CTLDUDOK=0
   Return
  Endif
  If [L]DEVLED = [F:HAE]CUR Then [F:RBU]AMTLINLOC = [F:RBU]AMTLINCUR : Return : Endif
Endif

Call CONVERT3([F:RBH]CUR,[L]DEVLED,[L]DEVLED,[F:TPY]RATTYP,[F:RBD]ACCDAT,[F:RBU]AMTLIN,[F:RBU]AMTLINLOC,[L]W_COURS,STAT) From CPTSUB
If STAT
  ## Pas de cours de devises [F:DUD]CUR -> [F:RBH]CUR
  Call ECR_TRACE(mess(16,114,1)-[F:RBH]CUR-"->"-[L]DEVLED-"("+format$("D:"+GFMDAT,[F:RBD]ACCDAT)-")",-1) From GESECRAN
  CTLDUDOK=0
  Return
Endif
Return

#**
#* Détermination du code taxe à partir du compte
#*
#* @param P_DEN : Destination comptable
#* @param P_COA : Plan
#* @param P_ACC : Compte
#* @param P_VAT : Code taxe en retour
#*!
Subprog SETVAT(P_DEN,P_COA,P_ACC,P_VAT)
Value    Char P_DEN
Value    Char P_COA
Value    Char P_ACC
Variable Char P_VAT
P_VAT=""
If !clalev([F:CDA]) : Local File GACCDENCOD [CDA] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
Call LEC_CDA_LEG(GCURLEG,P_DEN) From CPTLEC
If !fstat Then
 If [F:CDA]RPCVAT<>1 Then
  Call LEC_GAC(P_ACC,P_COA) From CPTLEC
  If !fstat Then
   If [F:GAC]FLGVAT<>1 Then
    P_VAT=[F:GAC]VAT(0)
   Endif
  Endif
 Endif
Endif
End

#**
#* Détermine le numéro interne à partir de la zone du fichier CODA
#* dans le cas ou la communication n'est pas structurée
#*
#* @param P_ZON : Zone du fichier CODA
#* @param P_REF : Référence interne en retour
#*!
Subprog SETREFINT(P_ZON,P_REF)
Value    Char P_ZON
Variable Char P_REF
If vireblc(left$(P_ZON,13),4)<>"" Then
 P_REF=vireblc(left$(P_ZON,13),4)
Else
 If vireblc(mid$(P_ZON,14,13),4)<>"" Then
  P_REF=vireblc(mid$(P_ZON,14,13),4)
 Endif
Endif
End

#**
#* Détermination du bordereau de remise à partir de la référence interne
#*
#* @param P_REF : Référence interne
#* @param P_FRM : Bordereau de remise en retour
#*!
Subprog SETFRM(P_REF,P_FRM)
Value    Char P_REF
Variable Char P_FRM
If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif
Read [F:PYH]PYH0=P_REF
If!fstat Then
 P_FRM=[F:PYH]FRMNUM
Else
 Raz P_FRM
Endif
End

#**
#* Détermination du tiers à partir du RIB/IBAN
#*
#* @param P_TYP : Type de compte (RIB/IBAN)
#* @param P_BID : Compte (RIB/IBAN)
#* @param P_BPR : Tiers en retour
#* @param P_NAM : Raison sociale Tiers en retour
#*!
Subprog SETBPR(P_TYP,P_BID,P_BPR,P_NAM)
Value    Char P_TYP
Value    Char P_BID
Variable Char P_BPR
Variable Char P_NAM

If !clalev([F:BID]) : Local File BID      [BID] : Endif
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
Local Integer NBRIB
NBRIB=0
Case P_TYP
 When "0" : # Numéro de compte Belge
  For [BID] Where [F:BID]BPATYP=1 and BIDNUM=vireblc(left$(P_BID,12),4)
   P_BPR=[F:BID]BPANUM
   NBRIB+=1
   If NBRIB>1 Then Break : Endif
  Next
 When "1" : # Numéro de compte étranger
  For [BID] Where [F:BID]BPATYP=1 and BIDNUM=vireblc(left$(P_BID,34),4)
   P_BPR=[F:BID]BPANUM
   NBRIB+=1
   If NBRIB>1 Then Break : Endif
  Next
 When "2" : # IBAN d'un compte Belge
  For [BID] Where [F:BID]BPATYP=1 and IBAN=left$(P_BID,4) and BIDNUM=vireblc(mid$(P_BID,5,27),4)
   P_BPR=[F:BID]BPANUM
   NBRIB+=1
   If NBRIB>1 Then Break : Endif
  Next
 When "3" : # IBAN d'un compte étranger
  For [BID] Where [F:BID]BPATYP=1 and IBAN=left$(P_BID,4) and BIDNUM=vireblc(mid$(P_BID,5,30),4)
   P_BPR=[F:BID]BPANUM
   NBRIB+=1
   If NBRIB>1 Then Break : Endif
  Next
Endcase
If NBRIB<>1 Then
 Raz P_BPR, P_NAM
Else
 Read [F:BPR]BPR0=P_BPR
 If !fstat Then P_NAM=[F:BPR]BPRNAM(0) Else fstat=0 : Endif
Endif
End

#**
#* Vérification post import du relevé
#*  - Affectation Facture + échéance
#*  - Affectation bordereau
#*  - Détermination du statut de la ligne de relevé
#*!
$VRF_POST_IMP
# Check the details of loop for line detail (and  status) and due date
For [F:RBD]RBD0 Where RBKNUM=[F:RBH]RBKNUM
 #---------------------------------------------------------
 Raz CHECKSUM, LST_FRM, NB_FRM, NB_RBU
 Filter [F:RBU] Where RBKNUM=[F:RBH]RBKNUM and RBKLIN=[F:RBD]RBKLIN
 NB_RBU=rowcount([F:RBU])
 Filter [F:RBU]
 For [F:RBU]RBU0 Where RBKNUM=[F:RBH]RBKNUM and RBKLIN=[F:RBD]RBKLIN
  #--- Total of line detail
  [L]CHECKSUM+=[F:RBU]AMTLIN

  #--- Find invoice and due date
  If [F:RBU]BELVCS<>"" Then
   Call SETVCR([F:RBU]BELVCS,[F:RBU]VCRTYP,[F:RBU]VCRNUM)
   Gosub SETDUD
  Endif
  If [F:RBU]VCRNUM="" : [F:RBU]AMTLINCUR=[F:RBU]AMTLIN : Endif
  Rewrite [F:RBU]
  If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Break : Endif

  #--- If one line detail
  #--- No account on the line and Payment attriibutes by default
  If NB_RBU=1 Then
   Raz [F:RBU]ACC, [F:RBU]VATLIN
   Case [F:RBD]SNS
    When 1 : [F:RBU]DENCOD=G_DENSPG : # Expense
    When 2 : [F:RBU]DENCOD=G_DENTAK : # revenue
   Endcase
   Rewrite [F:RBU]
   If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Break : Endif
  Endif

  #--- Find the remittance
  If [F:RBU]REFINT<>"" Then
   Call SETFRM([F:RBU]REFINT,FND_FRM)
   If FND_FRM<>"" Then
    If NB_FRM=0 Then
     NB_FRM+=1
     LST_FRM(NB_FRM)=FND_FRM
    Else
     If !find(FND_FRM,LST_FRM) Then
      NB_FRM+=1
      LST_FRM(NB_FRM)=FND_FRM
     Endif
    Endif
   Endif
  Endif
  #---------------------------------------------------------
 Next #[RBU]

 #--- Unicity ofthe remittance
 If NB_FRM=1 Then
  [F:RBD]FRMNUM=LST_FRM(1)
 Elsif NB_FRM>1
  Call ECR_TRACE(mess(83,120,1),-1) From GESECRAN
  Call ECR_TRACE(mess(84,120,1),-1) From GESECRAN
  For I=1 To NB_FRM
   Call ECR_TRACE(LST_FRM(I),-1) From GESECRAN
  Next
 Endif

 #---Check the remittance
 If [F:RBD]FRMNUM<>"" Then
  Read [F:FRM]FRM0=1;[F:RBD]FRMNUM
  If !fstat Then
   If [F:FRM]STA<8 Then : # La comptabilisation intermédiaire n'a pas été réalisée sur le bordereau
    Call ECR_TRACE(mess(188,121,1)-[F:RBD]FRMNUM-mess(86,120,1),-1) From GESECRAN
    Raz [F:RBD]FRMNUM
   Elsif [F:FRM]STA>8 : # Bordereau # déjà validé
    Call ECR_TRACE(func AFNC.MES(mess(194,121,1),[F:RBD]FRMNUM)-mess(86,120,1),-1) From GESECRAN
    Raz [F:RBD]FRMNUM
   Else
    For [F:RBD2] Where RBKNUM<>[F:RBD]RBKNUM and FRMNUM=[F:RBD]FRMNUM : #  Bordereau déjà imputé sur relevé
     Call ECR_TRACE([F:RBD]FRMNUM+" : "+mess(186,121,1)-[F:RBD2]RBKNUM-mess(86,120,1),-1) From GESECRAN
     Raz [F:RBD]FRMNUM
     Break
    Next
   Endif
  Endif
 Endif

# Check the remittance company
 If [F:RBD]FRMNUM<>"" Then
  If [F:FRM]CPY <> [F:RBH]CPY Then
   Call ECR_TRACE([F:RBD]FRMNUM-":"-mess(88,120,1)-":"-[F:FRM]CPY-"/"-[F:RBH]CPY-":"-mess(86,120,1),-1) From GESECRAN
   Raz [F:RBD]FRMNUM
  Endif
 Endif
 If [F:RBD]FRMNUM<>"" Then
  If func AFNC.PARAM("BELRBK",[F:FRM]FRMFCY) <> "2" Then
   Call ECR_TRACE([F:FRM]CPY+" : "+mess(87,120,1)-[F:RBD]FRMNUM-mess(86,120,1),-1) From GESECRAN
   Raz [F:RBD]FRMNUM
  Endif
 Endif

 # If remittance :
 # No BPR No account No Payment attributes by default
 # Site and payment entry types for remittance
 If [F:RBD]FRMNUM<>"" Then
  Raz [F:RBD]BPRNUM, [F:RBD]BPRNAM, [F:RBD]ACCTMP
  [F:RBD]FCYLIN=[F:FRM]FRMFCY
  [F:RBD]PAYTYP=[F:FRM]PAYTYP
  Update [F:RBU] Where RBKNUM=[F:RBH]RBKNUM and RBKLIN=[F:RBD]RBKLIN With DENCOD=""
  If fstat GOK = 0 : Call FSTA("RBU") From GLOCK : COK=0 : Break : Endif
 Endif

 #--- No account in header if BPR and multiple detail lines
 If [F:RBD]BPRNUM<>"" or NB_RBU>1 Then
  Raz [F:RBD]ACCTMP
 Endif

 #--- statut of the detail line (idem SUBRBB.APRES_NBDET)
 If [F:RBD]FRMNUM <> ""
  [F:RBD]STATUT = 2
 Else
  If ([F:RBD]BPRNUM="" and [F:RBD]ACCTMP="") or [F:RBD]AMTCUR=0 or [F:RBD]SNS=3 or [F:RBD]PAYTYP=""
   [F:RBD]STATUT=1
  Else
   If [F:RBD]AMTCUR=[L]CHECKSUM
    [F:RBD]STATUT=2
   Else
    [F:RBD]STATUT=1
   Endif
  Endif
 Endif
 If [F:RBD]STATUT=1
  [F:RBD]VALFLG=1
 Endif
 #---------------------------------------------------------
 Rewrite [F:RBD]
 If fstat GOK = 0 : Call FSTA("RBD") From GLOCK : COK=0 : Break : Endif
Next #[RBD]
Return

###########################################################################################
##                                   Technical Subprog
###########################################################################################
#**
#* Lecture d'une ligne de fichier plat
#*!
$LECTURE
Getseq 1, CHAMP
If mid$(CHAMP,len(CHAMP),1)="" : fstat = 4 : Endif
Return

#**
#* Lecture test d'un seul caractère
#*!
$LECTEST
Getseq 1, CTEST
Return

#**
#* Fin de traitement d'import
#*!
$SORTIE
TRA=1
If dim(G_BELTRSDEF)>0 Then Kill G_BELTRSDEF : Endif
If dim(G_BELDENDEF)>0 Then Kill G_BELDENDEF : Endif
If dim(G_BELRUBDEF)>0 Then Kill G_BELRUBDEF : Endif
If dim(G_DENSPG)>0    Then Kill G_DENSPG    : Endif
If dim(G_DENTAK)>0    Then Kill G_DENTAK    : Endif
Return

#**
#* Filtre le paramétrage du fichier bancaire à partir du numéro d'ordre
#*
#* @param ORD : Numéro d'ordre
#*!
Subprog FILTRE(ORD)
Value Integer ORD
Filter [TFB] Where COD=[M:DIA]NOMFIC & LEG=[M:DIA]LEG & BAN="" & ORDNUM=ORD
End

#**
#* Création d'une date à partir du format JJMMAA
#*
#* @param CHP : Champ alpha contenant la date au format JJMMAA
#* @param DAT : Variable de type date en retour
#*!
Subprog DAT(CHP,DAT)
Value Char CHP()
Variable Date DAT
DAT= gdat$(val(mid$(CHP,1,2)),val(mid$(CHP,3,2)),val(mid$(CHP,5,2)))
End

#**
#* Détermine le sens selon le menu local 661
#*   - Si 0 (crédit) : renvoie 1 (Dépense)
#*   - Si 1 (débit)  : renvoie 2 (Recette)
#*
#* @param CHP    : Sens donné par le fichier
#* @param IMPSNS : Sens transcodé en retour
#*!
Subprog SENS_DR(CHP,IMPSNS)
Value Char CHP()
Variable Shortint IMPSNS
Case CHP
 When "0" : IMPSNS=2 : # Credit => Revenue (Value 2 in Local Menu 661)
 When "1" : IMPSNS=1 : # Debit => Expenses (Value 1 in Local Menu 661)
Endcase
End

#**
#* Détermine le sens selon le menu local 626
#*   - Si 0 (crédit) : renvoie 2 (Crédit)
#*   - Si 1 (débit)  : renvoie 1 (Débit)
#*
#* @param CHP    : Sens donné par le fichier
#* @param IMPSNS : Sens transcodé en retour
#*!
Subprog SENS_DC(CHP,IMPSNS)
Value Char CHP()
Variable Shortint IMPSNS
Case CHP
 When "0" : IMPSNS=1 : # Credit => Debit (Value 1 in Local Menu 626)
 When "1" : IMPSNS=2 : # Debit => Credit (Value 2 in Local Menu 626)
Endcase
End

#**
#* Convertir un chaine brute en nombre décimal
#*
#* @param CHP     : Champ brut alphanumérique
#* @param VIRG    : Nombre de décimales
#* @param IMPMONT : Variable décimale en retour
#*!
Subprog MNTT(CHP,VIRG,IMPMONT)
Value Char CHP()
Value Char VIRG()
Variable Decimal IMPMONT
Local Integer I
IMPMONT = val(CHP)
If IMPMONT<>0
 For I=1 To val(VIRG)
  IMPMONT = IMPMONT/10
 Next I
Endif
End

###############################################################################
##  Check when parameter value BELRBKDIR is entered
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

Case PARAM
 When "BELRBKDIR"
 If VALEUR="" : End : Endif
 # Calling when we define the value in IMPBNKTRSF parameter : this should be value defined as
 # [VOL]\name of file so the TYPEXP = 2 = serveur par défaut
 Local Char FIL(GDIMFIC)
 Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
 mkstat = func ASYRSTO.CTL_VOLFIL(2,VALEUR,[L]FIL,E_TYPE_FOLDER,GMESSAGE)
 If mkstat=2 : OK=0 : Else OK=1 : Endif
Endcase
End

###########################################################################################
###                            Mask RBKIMPBEL
###########################################################################################

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
[M]TYPEXP=2
Call AM_TYPEXP([M]TYPEXP)
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [DIA]VOLFIL, [DIA]FILNAM
 Grizo [M]VOLFIL
 End
Else
 Local Char    PARAM1(30)
 PARAM1=func AFNC.PARAMUTIL("BELRBKDIR",GUSER,"")
 If left$(PARAM1,1)="[" & [M:DIA]VOLFIL=""
  [M:DIA]VOLFIL = PARAM1
 Endif
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
#Control that the file exists :
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FILNAM,E_TYPE_FILEREAD,GMESSAGE)
End

Subprog AS_RBKFMT(VALEUR)
Variable Integer VALEUR
GMENLOC(2)=1  : # No access to the "Manuel" option
End

######################################################################################

