#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
############################################################
# Resynchronisation emplacements
# action SAILOCS
############################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH_SYNLOC
  When "INIT"         : Gosub INIT_SYNLOC
  When "EXEC"         : Gosub EXEC_SYNLOC
  When "TERMINE"      : Gosub TERMINE_SYNLOC
  When "INIT_DIA"     : Gosub INIT_DIA_SYNLOC
  When "OK"           : Gosub OK_SYNLOC
  When "END"          : Gosub END_SYNLOC
Endcase 
Return
############################################################
$OUVRE_BATCH_SYNLOC
Gosub OPEN_FILE
Return
############################################################
$INIT_SYNLOC
Gosub OPEN_FILE
Return
#############################################################
$EXEC_SYNLOC
Local Char    WFIL(1) : WFIL = ""
#
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE(mess(133,196,1)-[M:DIA]STOFCY,0) From GESECRAN
Else
  Call OUVRE_TRACE(mess(133,196,1)-[M:DIA]STOFCY) From LECFIC 
  Call ECR_TRACE(mess(133,196,1)-[M:DIA]STOFCY,0) From GESECRAN
Endif
If [M:DIA]STOFCY <> ""
  Call TEMPON ("O") From GESECRAN
  Call TRAITEMENT(WFIL)
  Call TEMPOFF      From GESECRAN
Endif
Return
#############################################################
$TERMINE_SYNLOC
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Return
Endif
Return
#############################################################
$INIT_DIA_SYNLOC
Raz [M:DIA]
[M:DIA]STOFCY = GFCYDEF(0)
Return
#############################################################
$OK_SYNLOC
FIN  = 1
Return
#############################################################
$END_SYNLOC
Raz [M:DIA]
FIN = 1
Return
############################################################
$OPEN_FILE
If clalev([F:STO])  = 0 : Local File STOCK     [STO]  : Endif
If clalev([F:TLO])  = 0 : Local File TABLOCTYP [TLO]  : Endif
If clalev([F:STC])  = 0 : Local File STOLOC    [STC]  : Endif
If clalev([F:STC1]) = 0 : Local File STOLOC    [STC1] : Endif
If clalev([F:STC2]) = 0 : Local File STOLOC    [STC2] : Endif
If clalev([F:STF])  = 0 : Local File STOLOCAFF [STF]  : Endif
If clalev([F:SWL])  = 0 : Local File STOLOCRES [SWL]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER [ITM]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY  [FCY]  : Endif
If clalev([F:ACV])  = 0 : Local File ACTIV     [ACV]  : Endif
Return
############################################################
#Recalcul des statuts occupes / libres
###########################################################
Subprog TRAITEMENT(LFIL)
Value Char    LFIL
#
Gosub OPEN_FILE
#
Local Char     W_MSG(120)
Local Char     W_SUI(120)
Local Char     W_MSGMON(80)
Local Char     W_MSGDED(80)
Local Char     W_MSGSTA(80)
Local Char     W_MSGUOM(80)
Local Char     W_MSGQTY(80)
Local Char     W_MSGFIL(80)
Local Decimal  W_QTYPCU
Local Decimal  W_QTYSTU
Local Decimal  W_MAXQTY
#
Local Char     W_TXT(30)
Local Char     W_TXTL(20)
Local Char     W_TXTO(20)
Local Char     W_TXTQ(20)
Local Char     W_TXTM(20)
Local Integer  W_I, W_J
Local Shortint W_K
#
Local Integer W_NBR 
# Recherche code activité pour dimensionnemnts tableaux de stockage lignes stocks
Read [ACV]CODACT="STW"
If fstat = 0
  W_NBR = [F:ACV]DIME
Else
  W_NBR = 999
Endif
# Recherche de textes pour messages
Call TEXTE(1937,W_TXTL) From OBJDIV
Call TEXTE(3236,W_TXTO) From OBJDIV
Call TEXTE(5374,W_TXTQ) From OBJDIV
Call TEXTE(4901,W_TXTM) From OBJDIV
# Tableaux stockage lignes article
Local Integer W_IND
Local Char    W_ITM(GLONITM)(W_NBR)
Local Char    W_UOM(GLONUOM)(W_NBR)
Local Decimal W_QPCU        (W_NBR)
Local Decimal W_COE         (W_NBR)
Local Decimal W_QSTU        (W_NBR)
Local Char    W_STA(GLONSTA)(W_NBR)
#
Raz [F:TLO]
If LFIL = ""
  Filter [STC] Where STOFCY = [M:DIA]STOFCY & LOC <> ""
&              Order By Key STC0
Else
  Filter [STC] Where STOFCY = [M:DIA]STOFCY & LOC <> "" & evalue(LFIL)
&              Order By Key STC0
Endif
For [STC]
  Gosub TRT_REC
Next
#
Filter [STC]
End
###########################################################
# Traitement d'un emplacement
$TRT_REC
[F:STC1] = [F:STC]
Raz W_IND,    W_ITM,    W_UOM,    W_QPCU,   W_COE,    W_QSTU,   W_STA
Raz W_MSG,    W_MSGMON, W_MSGDED, W_MSGSTA, W_MSGUOM, W_MSGQTY, W_MSGFIL, W_QTYPCU, W_QTYSTU, W_MAXQTY
W_TRTMON = [F:STC]MONITMFLG
W_TRTDED = [F:STC]DEDFLG
If [F:STC]AUZSST <> "A*,Q*,R*"
  W_TRTSTA = 2
ELSe
  W_TRTSTA = 1
Endif
W_TRTFIL = [F:STC]FILMGTFLG
#
If [M:DIA]MONITMFLG = 1
  W_TRTMON = 1
Endif
If [M:DIA]DEDFLG = 1
  W_TRTDED = 1
Endif
If [M:DIA]STAFLG = 1
  W_TRTSTA = 1
Endif
If [M:DIA]FILMGTFLG = 1
  W_TRTFIL = 1
Endif

# lecture type emplacement si gestion du remplissage
If W_TRTFIL = 2
  If [F:TLO]STOFCY <> [F:STC]STOFCY | [F:TLO]LOCTYP <> [F:STC]LOCTYP 
    Read [TLO]TLO0=[F:STC]STOFCY;[F:STC]LOCTYP
    If fstat
      Raz [F:TLO]
    Endif
  Endif
Endif
# Lecture stock si mono article dédié ou gestion remplissage ou filtres statuts
If W_TRTMON = 2 | W_TRTDED = 2 | W_TRTSTA = 2 | W_TRTFIL = 2
  Filter [STO] Where STOFCY=[M:DIA]STOFCY & LOC =[F:STC]LOC & QTYSTU > 0
&              Order By Key STO4
  For [STO]
    If W_IND < W_NBR
      W_ITM (W_IND)  = [F:STO]ITMREF
      W_UOM (W_IND)  = [F:STO]PCU
      W_QPCU(W_IND)  = [F:STO]QTYPCU
      W_COE (W_IND)  = [F:STO]PCUSTUCOE
      W_QSTU(W_IND)  = [F:STO]QTYSTU
      W_STA (W_IND)  = [F:STO]STA 
      W_IND += 1
    Endif  
    W_QTYPCU += [F:STO]QTYPCU
    W_QTYSTU += [F:STO]QTYSTU
  Next
  Filter [STO]
Endif
# Contrôle mono article
If W_TRTMON = 2 & W_IND > 1
  For W_I = 1 To W_IND-1
    If W_ITM(W_I) <> W_ITM(0)
      If W_MSGMON = ""
        W_MSGMON  = W_ITM(0)
      Endif
      W_MSGMON += ", "+W_ITM(W_I) 
    Endif  
  Next W_I
Endif
# Contrôle emplacements dédiés
If W_TRTDED = 2 & W_IND > 0
  For W_I = 0 To W_IND - 1
    Look [STF]STF0=[F:STC]STOFCY;[F:STC]LOC;W_ITM(W_I)
    If fstat
      If W_MSGDED = ""
        W_MSGDED  = W_ITM(W_I)
      Else
        W_MSGDED += ", "+W_ITM(W_I) 
      Endif
    Endif
  Next W_I
Endif
# Contrôle statut stock
If W_TRTSTA = 2
  For W_I = 0 To W_IND - 1
    W_K =0
    Call STKCTRSTA(W_STA(W_I),[F:STC]AUZSST,0,1,0,W_K) From STKACT
    If W_K <> 0
      If W_MSGSTA = ""
        W_MSGSTA  = W_ITM(W_I)-W_STA(W_I)
      Else
        W_MSGSTA += ", "+W_ITM(W_I)-W_STA(W_I)
      Endif
    Endif
  Next W_I 
Endif
# Contrôle remplissage
If W_TRTFIL = 2 
  If W_IND > 0 
    If  [F:TLO]PCUNBR > 0
      For W_I = 0 To W_IND - 1
        W_J = find(W_UOM(W_I),[F:TLO]PCU(0..[F:TLO]PCUNBR-1))
        If W_J = 0
          If W_MSGUOM = ""
            W_MSGUOM  = W_UOM(W_I)
          Else
            W_MSGUOM += ", "+W_UOM(W_I)
          Endif 
        Else
          W_MAXQTY = [F:TLO]MAXQTYPCU(W_J-1)
        Endif
        If W_I > 0 & W_UOM(W_I) <> W_UOM(0) 
          If W_MSGQTY = ""
            W_MSGQTY  = W_UOM(0)
          Endif
          W_MSGQTY += ", "+W_UOM(W_I) 
        Endif
      Next W_I
      If W_MSGUOM = "" & W_MSGQTY = ""
        [F:STC]PCU       = W_UOM(0)
        [F:STC]QTYPCU    = W_QTYPCU
        [F:STC]MAXQTYPCU = W_MAXQTY
        If [F:STC]QTYPCU >= [F:STC]MAXQTYPCU
          [F:STC]OCPCOD = 2
        Else
          [F:STC]OCPCOD = 1
        Endif
        If W_QTYPCU = 0
          [F:STC]PCU       = "" 
          [F:STC]QTYPCU    = 0
          [F:STC]MAXQTYPCU = 0
        Endif
      Endif  
    Else
      [F:STC]PCU       = "" 
      [F:STC]QTYPCU    = 0
      [F:STC]MAXQTYPCU = 0
      If [F:STC]OCPCOD = 2
        [F:STC]OCPCOD =  1
      Endif
    Endif
  Else
    [F:STC]PCU       = "" 
    [F:STC]QTYPCU    = 0
    [F:STC]MAXQTYPCU = 0
    If [F:STC]OCPCOD = 2
      [F:STC]OCPCOD =  1
    Endif
  Endif
# Traitement messages et correction
  W_MSG = [F:STC1]LOCTYP-[F:STC1]LOC-mess([F:STC]LOCCAT,2710,1)
  If [F:STC1]MONITMFLG = 2
    W_MSG -= mess(850,196,1)
  Endif
  If [F:STC1]DEDFLG = 2
    W_MSG -= mess(851,196,1)
  Endif
  If [F:STC1]FILMGTFLG = 2
    W_MSG -= mess(852,196,1)
  Endif
  W_MSG += " : "
  W_SUI = string$(len(W_MSG),"_")
  If W_MSGMON <> ""
    Call ECR_TRACE(W_MSG-mess(53,196,1)-"("+W_MSGMON+")"-mess(24,196,1),1) From GESECRAN
    W_MSG = W_SUI
  Endif
  If W_MSGDED <> ""
    Call ECR_TRACE(W_MSG-mess(849,196,1)-"("+W_MSGDED+")"-mess(24,196,1),1) From GESECRAN
    W_MSG = W_SUI
  Endif
  If W_MSGSTA <> ""
    Call ECR_TRACE(W_MSG-mess(832,196,1)-"("+W_MSGSTA+")"-mess(24,196,1),1) From GESECRAN
    W_MSG = W_SUI
  Endif
  If W_MSGUOM <> ""
    Call ECR_TRACE(W_MSG-mess(847,196,1)-"("+W_MSGUOM+")"-mess(24,196,1),1) From GESECRAN
    W_MSG = W_SUI
  Endif
  If W_MSGQTY <> ""
    Call ECR_TRACE(W_MSG-mess(848,196,1)-"("+W_MSGQTY+")"-mess(24,196,1),1) From GESECRAN
    W_MSG = W_SUI
  Endif
  If [F:STC1]OCPCOD    <> [F:STC]OCPCOD    |
&    [F:STC1]PCU       <> [F:STC]PCU       |
&    [F:STC1]QTYPCU    <> [F:STC]QTYPCU    |
&    [F:STC1]MAXQTYPCU <> [F:STC]MAXQTYPCU
      Gosub TRT_CORRECTION
  Endif 
Endif
Return
###########################################################
$TRT_CORRECTION
If [M:DIA]CORERRFLG = 1 
  W_TXT = "("+mess(24,196,1)+")"
  Gosub ECR_MESS
Else
  Trbegin [STC2]
  GOK = 1
  Readlock [STC2]STC0=[F:STC]STOFCY;[F:STC]LOC
  Case fstat
    When 0 :
      [F:STC2] = [F:STC]
      Rewrite [STC2]
      If fstat
        GOK = 0
        Call FSTA("STC2") From GLOCK
      Endif
    When 1  
      GOK = -1
    When Default :
      GOK = 0
      Call FSTA("STC2") From GLOCK
  Endcase
  Case GOK
    When 1 :
#      Commit
      Rollback
      W_TXT = "("+mess(23,196,1)+")"
      Gosub ECR_MESS
    When Default :
      Rollback
      W_TXT = "("+mess(24,196,1)+")"
      Gosub ECR_MESS
  Endcase
Endif  
Return
############################################################
$ECR_MESS
If [F:STC1]OCPCOD <> [F:STC]OCPCOD
  Call ECR_TRACE(W_MSG-W_TXTO-mess([F:STC1]OCPCOD,703,1)-"-->"-mess([F:STC]OCPCOD,703,1)-
&      W_TXT,1) From GESECRAN
  W_MSG = W_SUI
Endif
If [F:STC1]PCU <> [F:STC]PCU | [F:STC1]QTYPCU <> [F:STC]QTYPCU
  Call ECR_TRACE(W_MSG-W_TXTQ-num$([F:STC1]QTYPCU)-[F:STC1]PCU-"-->"-num$([F:STC]QTYPCU)-[F:STC]PCU-
&      W_TXT,1) From GESECRAN
  W_MSG = W_SUI
Endif
If [F:STC1]MAXQTYPCU <> [F:STC]MAXQTYPCU
  Call ECR_TRACE(W_MSG-W_TXTM-num$([F:STC1]MAXQTYPCU)-[F:STC1]PCU-"-->"-num$([F:STC]MAXQTYPCU)-[F:STC]PCU-
&      W_TXT,1)   From GESECRAN
  W_MSG = W_SUI
Endif
Return
###########################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

