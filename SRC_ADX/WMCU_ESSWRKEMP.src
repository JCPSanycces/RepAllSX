# Supervisor
## CRUD-CLASSE ## ESSWRKEMP
# 2018-10-23 06:53:22 589


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(ESSWRKEMP,ASTATUS)
Variable Instance ESSWRKEMP Using C_ESSWRKEMP
Variable Integer ASTATUS

If ESSWRKEMP = null : End : Endif

Gosub _AVARIABLES From WMC00ESSWRKEMP

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_ESSWRKEMP

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(ESSWRKEMP,ASTATUS)
Variable Instance ESSWRKEMP Using C_ESSWRKEMP
Variable Integer ASTATUS

If ESSWRKEMP = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKEMP
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
ESSWRKEMP.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_ESSWRKEMP
Else
 Gosub AUPDATE_ESSWRKEMP
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = ESSWRKEMP.freeSnapshot
ESSWRKEMP.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKEMP._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKEMP._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKEMP._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If ESSWRKEMP.ASTALIN = [V]CST_ANEWDEL : Return : Endif
ESSWRKEMP.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(ESSWRKEMP.ASTALIN)<>""
 [L]A_ASTALIN = ESSWRKEMP.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(ESSWRKEMP.ASTALIN)<>""
 [L]A_ASTALIN = ESSWRKEMP.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_ESSWRKEMP
Trbegin [F:EWID]
 Gosub AUPDATE_ESSWRKEMP
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_ESSWRKEMP
[L]A_ASTALIN = ESSWRKEMP.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00ESSWRKEMP._MAJSQL_ESSWRKEMP(ESSWRKEMP))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = ESSWRKEMP.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If ESSWRKEMP.snapshotEnabled=1
 [L]A_RETIK = ESSWRKEMP.revertUpdTick
Endif

[L]ASTATUS = max(fmet ESSWRKEMP.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(ESSWRKEMP.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 ESSWRKEMP.ASTALIN = [V]CST_ALL
Endif
Return



