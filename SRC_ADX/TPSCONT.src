#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################
## Contrôle de saisie des temps
#########################################
$ACTION
Case ACTION
 When "INIT" : Gosub INIT
 When "EXEC" : Gosub EXEC
Endcase
Return

$INIT
TRA = 1
Return

$EXEC
#MIPEA - 2017-01-20- X3-11765- START
Call OUVRE_TRACE(mess(100,10709,1)) From LECFIC : # Contrôle de saisie des temps
#Call OUVRE_TRACE(mess(100,709,1)) From LECFIC : # Contrôle de saisie des temps
#MIPEA - 2017-01-20- X3-11765- END
If PARAM(1)=num$(1)
 Call CONTSAI("",[M]REFNUM,[M]CTRNUM,[M]PYRDAT,[0/0/0],[0/0/0]) From TRTTPS
Elsif PARAM(1)=num$(2)
 Call CONTSAI("",[M]REFNUM,[M]CTRNUM,[M]PYRDAT,[M]DAT(0),[M]DAT(6)) From TRTTPS
Endif
If GERRTRACE=0
 If PARAM(1)=num$(1)
  Call ECR_TRACE([M]REFNUM-[M]NAM-[M]CTRNUM-format$("D:"+GFMDAT4,[M]PYRDAT),0) From GESECRAN
 Elsif PARAM(1)=num$(2)
  # Semaine
#MIPEA - 2017-01-20- X3-11765- START
  Call ECR_TRACE([M]REFNUM-[M]NAM-[M]CTRNUM-mess(57,10709,1)-num$([M]NUMWEK),0) From GESECRAN
#  Call ECR_TRACE([M]REFNUM-[M]NAM-[M]CTRNUM-mess(57,709,1)-num$([M]NUMWEK),0) From GESECRAN
#MIPEA - 2017-01-20- X3-11765- END
 Endif
#MIPEA - 2017-01-20- X3-11765- START
 Call ECR_TRACE(mess(101,10709,1),0) From GESECRAN : # Saisie des temps complète
# Call ECR_TRACE(mess(101,709,1),0) From GESECRAN : # Saisie des temps complète
#MIPEA - 2017-01-20- X3-11765- END
Endif
Call FERME_TRACE From LECFIC
Return

