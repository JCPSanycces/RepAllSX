#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
#                                                                       #
#     CONVERSION DES COMMANDES EN EURO                                  #
#                                                                       #
#     - Traitement        : FUNCNVSOH                                   #
#     - Action e_commerce : TRTCNVSOH                                   #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase
Return
#######################################################################
#    Détail des actions liées au traitement standard                  #
#######################################################################
#######################################################################
$INIT

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Return
#######################################################################
$INIT_DIA

Raz [M:DIA]

[M:DIA]DATPAS=date$
[M:DIA]DEVDES=GEURO

[M:DIA]TOUSITE=2
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    [M:DIA]TOUSITE = 1 : [M:DIA]SITE=GFCYDEF(5)
Endif
[M:DIA]TOUCLIENT=2
[M:DIA]TOUDEV=2
[M:DIA]TOUCAT=2 : [M:DIA]SOHCAT=0
[M:DIA]TRACE=2

Return
#######################################################################
$CONTROLE

Raz [F:SOH]
TMP=1
TIT=mess(424,197,1)

Return
#######################################################################
$EXEC

If !GSERVEUR
    If [M:DIA]TRACE = 2
        Call OUVRE_TRACE(TIT) From LECFIC
        Call ECR_TRACE(" ",0) From GESECRAN
        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
        Call PRTSCR("SCNVSOH","DIA","",0,1) From ATRTX3
        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
        Call ECR_TRACE(" ",0) From GESECRAN
    Endif
Endif
Gosub CHARG_SFI
Gosub SEL_SOH
Raz NBCDE
Gosub TRT_SOH

Return
#######################################################################
$TERMINE

If !GSERVEUR
    If [M:DIA]TRACE=2
        Call FERME_TRACE From LECFIC
        TRA=1
    Endif
# --> Aucune commande convertie ou lecture trace
    If !NBCDE
         GERR=2:GMESSAGE = mess(39,192,1)
    Endif
Endif

Return

#########################################################################
#-----------------------------------------------------------------------#
#    Ouvre                                                              #
#-----------------------------------------------------------------------#
$OUVRE
Local Integer OK, I, J, NBCDE

Local Char    TIT(50), CRITERE(250)

Local Char    WMESS(80), WMESS1(80), WMESS2(120)
Local Integer WRET, SPSTAT
Local Integer TSFINUM (0..19), TAMTCOD (0..19)
Local Decimal WMONTORG, WMONTDES, COURS
Local Char    WANC_CUR

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:SOH]) = 0 Local File SORDER      [SOH]:Endif
If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ]:Endif
If clalev([F:SOP]) = 0 Local File SORDERP     [SOP]:Endif
If clalev([F:SOC]) = 0 Local File SORDERC     [SOC]:Endif
If clalev([F:TCU]) = 0 Local File TABCUR      [TCU]:Endif
Gosub OPEN_SFI From TRTX3CPY : #If clalev([F:SFI]) = 0 Local File SFOOTINV    [SFI]:ENDIF
If clalev([F:SDH]) = 0 Local File SDELIVERY   [SDH]:Endif
If clalev([F:SDD]) = 0 Local File SDELIVERYD  [SDD]:Endif
If clalev([F:DUD]) = 0 Local File GACCDUDATE  [DUD]:Endif
If clalev([F:ITS]) = 0 Local File ITMSALES    [ITS]:Endif
If clalev([F:CPY]) = 0 : Local File COMPANY     [CPY] : Endif   # 106867.n

Default File [SOH]

#-----------------------------------------------------------#
# Récupération de la structure des frais/remises            #
#-----------------------------------------------------------#
Call COLREM("C",1,"")     From TRTPRICE

Raz GFCY

# ------------------------------------------------------------------------- #
# Spécificité USA : Pour ne pas faire appel au sous-pro de calcul des taxes #
# ------------------------------------------------------------------------- #
#Local Integer WKUAACT
#Call LECKUACT("KUA",WKUAACT) From TRTX3

Return

#---------------------------------------------------------------------#
# Chargement tableau des éléments de facturation                      #
#---------------------------------------------------------------------#
$CHARG_SFI

I=0
# chgt des postes à partir des éléments de facturation
For [SFI]
    TSFINUM (I) = [F:SFI]SFINUM
    TAMTCOD (I) = [F:SFI]AMTCOD
    I+=1
    If I=20 Break Endif
Next

Return

#---------------------------------------------------------------------#
# Selection des commandes                                             #
#---------------------------------------------------------------------#
$SEL_SOH

#--> critères de saisie
CRITERE  = "1=1"

If [M]SITE   <> ""
   CRITERE -= '& SALFCY ="'+[M:DIA]SITE+'"'
Endif
If [M]CLIENT <> ""
   CRITERE -= '& BPCORD ="'+[M:DIA]CLIENT+'"'
Endif
If [M]DEVISE <> ""
   CRITERE -= '& CUR ="'+[M:DIA]DEVISE+'"'
Endif
If [M]SOHCAT <> 0
   CRITERE -= '& SOHCAT ='+num$([M:DIA]SOHCAT)
Endif
If [M]ORDDAT <> [0/0/0]
   CRITERE -= "& ORDDAT <= [" +format$(GFMD,[M]ORDDAT)+ "]"
Endif
If [M:DIA]SOHNUMDEB <> ""
   CRITERE -= '& SOHNUM >="'+[M:DIA]SOHNUMDEB+'"'
Endif
If [M:DIA]SOHNUMFIN <> ""
   CRITERE -= '& SOHNUM <="'+[M:DIA]SOHNUMFIN+'"'
Endif

CRITERE -= "& ORDSTA <= 1" : # commande non soldée pour les commandes ouvertes ORDSTA = 0
Return

#---------------------------------------------------------------------#
# Traitement des commandes                                            #
#---------------------------------------------------------------------#
$TRT_SOH
Local Char     L_SOHNUM(type([F:SOH]SOHNUM)-10)
Local Integer  L_COMPTEUR
Local Shortint STOP

# --> Lecture des commandes
Filter [SOH] Where evalue (CRITERE)

Raz L_SOHNUM

$DEB_BOUCLE
Raz L_COMPTEUR, STOP

For [SOH]SOH0 Where SOHNUM > L_SOHNUM
    Gosub SEL_SOHCOMPL
    If OK=1 Goto NXTSOH : Endif
    Gosub CNV_SOH
    L_COMPTEUR+=1
    If L_COMPTEUR > 1000
        L_SOHNUM=[F:SOH]SOHNUM : STOP=1 : Break
    Endif
    $NXTSOH
Next
If STOP Goto DEB_BOUCLE Endif
Filter [SOH]
Return


#-----------------------------------------------------------------------#
# Sélections complémentaires sur l'enregistrement SOH                   #
#-----------------------------------------------------------------------#
$SEL_SOHCOMPL
Local Integer WDLVSTA : WDLVSTA=1

OK=2
If [F:SOH]CUR = [M:DIA]DEVDES OK=1 : Return : Endif
#   On prend les commandes ayant une devise "in"                #
If [F:TCU]CUR<>[F:SOH]CUR
    Read [TCU]TCU0=[F:SOH]CUR
    If fstat Raz [F:TCU] : Endif
Endif
If [M:DIA]DEVDES = GEURO & [F:TCU]EURFLG<>2 OK=1 : Return : Endif

#   On prend toujours les commandes non livrées                #
#   ==> DLVSTA n'est pas toujours juste : Dangereux de le tester
#If [F:SOH]DLVSTA = 1 Return : Endif

#   Les livraisons doivent être validées et facturées
Gosub VERIF_SDH
If OK=1 Return : Endif

#    Commande partiellement livrée                             #
#   Traitement particulier si 1 Facture par commande soldée    #
If [F:SOH]IME = 2 & WDLVSTA =2 Gosub TRT_IME2 : OK=1 : Return : Endif

Return

#---------------------------------------------------------------------------------#
#   Traitement particulier : 1 Facture par commande soldée                        #
#---------------------------------------------------------------------------------#
# Condition de conversion :                                                       #
# ------------------------                                                        #
# On doit convertir une commande non soldée et partiellement livrée               #
# pour que la commande soit convertie, ttes les livraisons doivent être facturées #
# Condition de facturation   :                                                    #
# ------------------------                                                        #
# Si 1 facture/cde soldée, Ttes les livraisons doivent être sur la même facture   #
# A la facturation des liv., on ne facture pas tt que la cde n'est pas soldée     #
#                                              tt que les liv. ne pas validées    #
# --> La commande ne sera jamais convertie car les livraisons sont non facturées  #
# --> Les livraisons ne seront jamais facturées car la commande n'est pas soldée  #
# Solution :                                                                      #
# --------                                                                        #
# Modif. mode de facturation sur la cde et les livraisons (1 facture/cde)         #
# --> Les livraisons seront facturées à la prochaine facturation                  #
# --> La commande sera convertie en relançant la moulinette                       #
#---------------------------------------------------------------------------------#
$TRT_IME2

$TRT
GOK=1
Trbegin [SOH],[SDH]

#-- Verrouillage et maj de l'entête commande
Readlock [SOH]SOH0 = SOHNUM
If    fstat=1  GOK=-1 : GLOCK="$SORDER"+SOHNUM          : Goto ROL_TRT
Elsif fstat    GOK=0  : Call RSTA("SOH",SOHNUM) From GLOCK : Goto AB_TRT
Endif
[F:SOH]IME =3
Rewrite [SOH]
If fstat GOK=0 : Call FSTA("SOH") From GLOCK : Goto AB_TRT : Endif

#-- Maj des livraisons de la commande
Update [SDH] Where SOHNUM = [F:SOH]SOHNUM With IME = 3
If fstat=1
    GOK=0 : Call FSTA("SDH") From GLOCK
    Goto AB_TRT
Endif

Commit

If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(98,197,1)-[F:SOH]SOHNUM-":"-mess(423,197,1),0) From GESECRAN
    Call ECR_TRACE(mess(425,197,1),0) From GESECRAN
Endif

Return

#-----------------------------------------------------------------------#
#    Rollback                                                           #
#-----------------------------------------------------------------------#
#--> rollback + nouvelle tentative
$ROL_TRT
Rollback
Call ROLL From GLOCK
If   GROLL
     #--  rollback suite à une erreur dans la transaction
     Call ECR_TRACE(SOHNUM-mess(17,107,1),1)From GESECRAN
Else Goto TRT
Endif
Return

#--> rollback
$AB_TRT
Rollback
Call ECR_TRACE(SOHNUM-mess(17,107,1),1)From GESECRAN
Return

#---------------------------------------------------------------------------------#
# Vérification que les livraisons de la commande sont validées et facturées       #
#---------------------------------------------------------------------------------#
$VERIF_SDH
Raz WMESS

Columns [SDD] (SOHNUM,SDHNUM)
For  [SDD]SDD1 Where [SDD]SOHNUM = [F:SOH]SOHNUM
    If [F:SOH]IME=2 WDLVSTA=2 : Break : Endif
    If [F:SDH]SDHNUM <>[F:SDD]SDHNUM
        Read [SDH]SDH0=[F:SDD]SDHNUM
        If fstat Raz [F:SDH] : Endif
    Endif
    If [F:SDH]CFMFLG=1 OK=1 : Break : Endif
    If [F:SDH]INVFLG=1 OK=1 : Break : Endif
Next
Columns [SDD]

If OK=1 & [M:DIA]TRACE=2
    Call ECR_TRACE(mess(98,197,1)-[F:SOH]SOHNUM-":"-mess(423,197,1),0) From GESECRAN
Endif

Return

#---------------------------------------------------------------------------------#
# Traitement de conversion de la commande                                         #
#---------------------------------------------------------------------------------#
$CNV_SOH

Gosub VERROU
If !OK Return:Endif
Call DEBTRANS From GLOCK

GOK=1
Trbegin [SOH],[SOQ],[SOP]
    #     --> Il faut bloquer la commande
    Readlock [SOH]SOH0=[F:SOH]SOHNUM
    If fstat = 1
       GOK = -1:GLOCK="$SORDER"+[F:SOH]SOHNUM
       Goto ROL_TRT
    Elsif fstat
       GOK = 0 :Call RSTA("SOH", [F:SOH]SOHNUM) From GLOCK
       Goto AB_TRT
    Endif

    Raz [F:SOH]ORDNOT, ORDATI, PFMTOT
    Raz [F:SOH]DLRNOT, DLRATI

    WANC_CUR   = [F:SOH]CUR
    [F:SOH]CUR = [M:DIA]DEVDES

    #------------------------------------------------------------#
    # Réalimentation site fin.(GFINRSP)                          #
    #                soc.     (GSOCIETE)                         #
    #                dev.soc. (GLOCALDEV)                        #
    # Récupération des paramètres vente du site / de la société  #
    #------------------------------------------------------------#
    If GFCY <> [F:SOH]SALFCY
        GFCY = [F:SOH]SALFCY
#        Call GETDEV(GFCY) From DEVSUB
        # --> Chargement globales référenciels, comptes et sections de la société
        Gosub CHARG_PARAM
        Call GLOBVAR(GFCY,"VEN") From TRTX3
    Endif

    # Recalcul des montants de facturation
    For I = 0 To dim([F:SOH]INVDTA)-1
        If [F:SOH]INVDTAAMT(I) <> 0
            J=find ([F:SOH]INVDTA(I), TSFINUM (0..19))
            If J > 0 & TAMTCOD(J-1)=2
                Call CONVERT(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$, [F:SOH]INVDTAAMT(I),WMONTDES,SPSTAT)
&                                From TRTDEV
                [F:SOH]INVDTAAMT(I) = WMONTDES
            Endif
        Endif
    Next I

    If [F:SOH]SOHCAT=4
        Gosub CNV_SOC
    Else
        Gosub CNV_SOP
    Endif
    If GOK = - 1   Goto ROL_TRT
    Elsif GOK = 0  Goto AB_TRT Endif

#   Alimentation cours en devise société
    Call COURSITE([F:SOH]CUR,[F:SOH]SALFCY,[F:SOH]CHGTYP,[F:SOH]ORDDAT,COURS,SPSTAT) From TRTDEV
    [F:SOH]CHGRAT=COURS

    Gosub CNV_ACOMPTE
    If GOK = - 1   Goto ROL_TRT
    Elsif GOK = 0  Goto AB_TRT Endif

    Rewrite [SOH]
    If fstat GOK=0 : Call FSTA("SOH") From GLOCK : Goto AB_TRT : Endif

    If [M:DIA]TRACE=2 Call ECR_TRACE(mess(98,197,1)-[F:SOH]SOHNUM-":"-mess(477,196,1),0) From GESECRAN : Endif
    NBCDE+=1
Commit
Gosub DEVERROU

Return


#-------------------------------------------------------------------------#
# Conversions dans le cas d'une commande normale,prêt,facturation directe #
#-------------------------------------------------------------------------#
$CNV_SOP

For [SOP]SOP0 Where SOHNUM=[F:SOH]SOHNUM
    Readlock [SOP]SOP0=[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ
    If fstat = 1
        GOK = -1:GLOCK="$ORDERP"+[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)
        Break
    Elsif fstat
        GOK = 0 :Call RSTA("SOP",[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)) From GLOCK
        Break
    Endif

    Read [SOQ]SOQ0 = [F:SOP]SOHNUM; [F:SOP]SOPLIN; [F:SOP]SOPSEQ
    If fstat
        GOK = 0 : Call RSTA("SOQ", [F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)) From GLOCK
        Break
    Endif
    Gosub CNV_PRIX   : # Conversion de tous les prix
    Gosub CLC_TOT    : # Recalcul de totaux

    Rewrite [SOP]
    If fstat GOK = 0 : Call FSTA("SOP") From GLOCK  : Break : Endif
Next

Return

#-------------------------------------------------------------------------#
# Conversions dans le cas d'une commande ouverte                          #
#-------------------------------------------------------------------------#
$CNV_SOC

For [SOC]SOC0 Where SOHNUM=[F:SOH]SOHNUM
    Readlock [SOC]SOC0=[F:SOC]SOHNUM;[F:SOC]SOPLIN
    If fstat = 1
        GOK = -1:GLOCK="$ORDERC"+[F:SOC]SOHNUM-num$([F:SOC]SOPLIN)
        Break
    Elsif fstat
        GOK = 0 :Call RSTA("SOC",[F:SOC]SOHNUM-num$([F:SOC]SOPLIN)) From GLOCK
        Break
    Endif
    Call CONVERT(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                [F:SOC]EXTAMT, WMONTDES, SPSTAT) From TRTDEV
    [F:SOC]EXTAMT = WMONTDES
    Call CONVERT(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                [F:SOC]CPLAMT, WMONTDES, SPSTAT) From TRTDEV
    [F:SOC]CPLAMT = WMONTDES

    If [F:SOC]PLI=""
        For [SOP]SOP0 Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN
            Readlock [SOP]SOP0=[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ
            If fstat = 1
                GOK = -1:GLOCK="$ORDERP"+[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)
                Break
            Elsif fstat
                GOK = 0 :Call RSTA("SOP",[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)) From GLOCK
                Break
            Endif
            Gosub CNV_PRIX

            Rewrite [SOP]
            If fstat GOK = 0 : Call FSTA("SOP") From GLOCK  : Break : Endif
        Next
        If GOK<1 Break Endif
    Endif
    Rewrite [SOC]
    If fstat GOK=0 : Call FSTA("SOC") From GLOCK : Break : Endif
Next

Return

#-----------------------------------------------------------------------#
# Conversion de tous les prix de SORDERP (prix, remises, marge...)      #
#-----------------------------------------------------------------------#
$CNV_PRIX

Call CONVERT2(WANC_CUR, [F:SOH]CUR, GLOCALDEV,[F:SOH]CHGTYP,date$,
&             [F:SOP]GROPRI,WMONTDES,SPSTAT) From TRTDEV
[F:SOP]GROPRI = arr(WMONTDES, 10^-GDECPRI)


For I = 0 To 8
    If GFMTREM(I)="M"
        WMONTORG = evalue("[F:SOP]DISCRGVAL"+num$(I+1))
        If WMONTORG <> 0
            Call CONVERT(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                         WMONTORG, WMONTDES, SPSTAT) From TRTDEV
            Assign "[F:SOP]DISCRGVAL"+num$(I+1) With WMONTDES
        Endif
    Endif
Next I

If [F:SOP]NETPRI <> 0
    Call CONVERT2(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$, [F:SOP]NETPRI, WMONTDES, SPSTAT) From TRTDEV
    If GSALRND = 2
       Call ARRDEV(WMONTDES,[F:SOH]CUR) From TRTDIV
       [F:SOP]NETPRI = WMONTDES
    Else
       [F:SOP]NETPRI = arr(WMONTDES, 10^-GDECPRI)
    Endif
Endif

If [F:SOP]CPRPRI <> 0
    Call CONVERT2(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$, [F:SOP]CPRPRI, WMONTDES, SPSTAT) From TRTDEV
    [F:SOP]CPRPRI = arr(WMONTDES, 10^-GDECPRI)
Endif

# Traitement des montants de base de calcul
If [F:SOP]CLCAMT1 <> 0 | [F:SOP]CLCAMT2 <> 0
    # Ces montants dépendent d'une formule donc d'opérandes divers
    # Pas de conversion mais Recalcul
    Call ALICLCAMT([F:SOP]ITMREF, [F:SOQ]QTY, -1, "SOP", [F:SOP]CLCAMT1, [F:SOP]CLCAMT2) From TRTX3
    # Recalcul des prix HT et TTC de la marge
    Gosub CLC_MARGE
    Return
Endif

If [F:SOP]NETPRINOT <> 0
    Call CONVERT2(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$, [F:SOP]NETPRINOT, WMONTDES, SPSTAT) From TRTDEV
    [F:SOP]NETPRINOT = arr(WMONTDES, 10^-GDECPRI)
Endif
If [F:SOP]NETPRIATI <> 0
    Call CONVERT2(WANC_CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$, [F:SOP]NETPRIATI, WMONTDES, SPSTAT) From TRTDEV
    [F:SOP]NETPRIATI = arr(WMONTDES, 10^-GDECPRI)
Endif
# recalcul de la marge
[F:SOP]PFM =[F:SOP]NETPRINOT - [F:SOP]CPRPRI
Return

#-------------------------------------------------------------------------------#
# Recalcul des Prix HT et TTC et recalcul de la marge                           #
#-------------------------------------------------------------------------------#
$CLC_MARGE

# If GLOCUSATAX  # 106867.o
If func AFNC.ACTIV("LTA")  & [F:CPY]SSTTAXACT = 2  # 106867.n
    [F:SOP]NETPRINOT=[F:SOP]NETPRI
    [F:SOP]NETPRIATI=[F:SOP]NETPRI
Else
    If [F:SOH]PRITYP=1
        [F:SOP]NETPRINOT = [F:SOP]NETPRI
        Call CLCTAXEPRIV([F:SOP]NETPRI,[F:SOP]VAT,[F:SOH]PRITYP,GSOCIETE,[F:SOH]ORDDAT,
&                       [F:SOQ]QTY,[F:SOH]VACBPR,[F:SOP]CLCAMT1,[F:SOP]CLCAMT2,[F:SOP]NETPRIATI) From TRTX3
    Else
        [F:SOP]NETPRIATI = [F:SOP]NETPRI
        Call CLCTAXEPRIV([F:SOP]NETPRI,[F:SOP]VAT,[F:SOH]PRITYP,GSOCIETE,[F:SOH]ORDDAT,
&                       [F:SOQ]QTY,[F:SOH]VACBPR,[F:SOP]CLCAMT1,[F:SOP]CLCAMT2,[F:SOP]NETPRINOT) From TRTX3
    Endif
Endif
# Pas de calcul de marge pour les prix à 0
If [F:SOP]NETPRI = 0  & ([F:SOP]FOCFLG = 3 | find([F:SOP]LINTYP,3,4,5,7,8,9,11,12,13)) Return : Endif
# --> Recalcul de la marge
[F:SOP]PFM = [F:SOP]NETPRINOT - [F:SOP]CPRPRI
Return


$CLC_TOT
Local Decimal WQTY

#-------------------------------------------------------------#
# Calcul des montants commande ht et ttc d'une ligne commande #
#-------------------------------------------------------------#
# Montant net HT commandé de la ligne
WMONTDES = [F:SOQ]QTY * [F:SOP]NETPRINOT
Call ARRDEV (WMONTDES, [F:SOH]CUR) From TRTDIV
[F:SOH]ORDNOT += WMONTDES
If dim([F:SOH]ORDINVNOT)>0 : [F:SOH]ORDINVNOT=[F:SOH]ORDNOT : Endif   # JL le 21/12/06

# Montant net TTC commandé de la ligne
WMONTDES = [F:SOQ]QTY * [F:SOP]NETPRIATI
Call ARRDEV (WMONTDES, [F:SOH]CUR) From TRTDIV
[F:SOH]ORDATI += WMONTDES
If dim([F:SOH]ORDINVATI)>0 : [F:SOH]ORDINVATI=[F:SOH]ORDATI : Endif   # JL le 21/12/06

# Marge de la ligne
WMONTDES = [F:SOQ]QTY * [F:SOP]PFM
Call ARRDEV (WMONTDES, [F:SOH]CUR) From TRTDIV
[F:SOH]PFMTOT += WMONTDES

#--------------------------------------------------------------#
# Calcul des montants à livrer HT et TTC d'une ligne commnande #
#--------------------------------------------------------------#
# 107888 : Scheduled invoices : (LD:20/05/16)
#If [F:SOH]SOHCAT=3
If [F:SOH]SOHCAT=3 | ([F:SOQ]SOHCAT=1 & [F:SOQ]DLVFLG=1)
    # --> Commande à facturation directe
    # --> Commande normale et article non livrable
# 107888 : Scheduled invoices : (LD:20/05/16)
    WQTY = [F:SOQ]QTY - [F:SOQ]INVQTY - [F:SOQ]ODLQTY
Else
    # --> Commande normale et article livrable      : # 107888 : Scheduled invoices : (LD:20/05/16)
    WQTY = [F:SOQ]QTY - [F:SOQ]DLVQTY - [F:SOQ]ODLQTY
Endif
If WQTY < 0 WQTY = 0 Endif

# Montant net HT à livrer de la ligne
WMONTDES = WQTY *[F:SOP]NETPRINOT
Call ARRDEV (WMONTDES, [F:SOH]CUR) From TRTDIV
[F:SOH]DLRNOT += WMONTDES

# Montant net TTC à livrer de la ligne
WMONTDES = WQTY*[F:SOP]NETPRIATI
Call ARRDEV (WMONTDES, [F:SOH]CUR) From TRTDIV
[F:SOH]DLRATI += WMONTDES
Return

#-----------------------------------------------------------------------#
# Conversion des acomptes                                               #
# --> On ne converti que les acomptes qui ne sont pas réglés            #
#-----------------------------------------------------------------------#
$CNV_ACOMPTE

For [F:DUD]DUD0 Where TYP = "*SO" & NUM = [F:SOH]SOHNUM & TMPCUR = 0 & PAYCUR = 0
    Readlock [DUD]DUD0=[F:DUD]TYP;[F:DUD]NUM;[F:DUD]LIG;[F:DUD]DUDLIG
    If fstat = 1
        GOK = -1:GLOCK="$GACCDUDATE"+[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG)
        Break
    Elsif fstat
        GOK = 0 :Call RSTA("DUD",[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG)) From GLOCK
        Break
    Endif
    If [F:DUD]AMTCUR <> 0
        Call CONVERT([F:DUD]CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                    [F:DUD]AMTCUR, WMONTDES, SPSTAT) From TRTDEV
        [F:DUD]AMTCUR = WMONTDES
    Endif
    If [F:DUD]PAYCUR <> 0
        Call CONVERT([F:DUD]CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                    [F:DUD]PAYCUR, WMONTDES, SPSTAT) From TRTDEV
        [F:DUD]PAYCUR = WMONTDES
    Endif
    If [F:DUD]TMPCUR <> 0
        Call CONVERT([F:DUD]CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                    [F:DUD]TMPCUR, WMONTDES, SPSTAT) From TRTDEV
        [F:DUD]TMPCUR = WMONTDES
    Endif
    If [F:DUD]IBDAMT <> 0
        Call CONVERT([F:DUD]CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                    [F:DUD]IBDAMT, WMONTDES, SPSTAT) From TRTDEV
        [F:DUD]IBDAMT = WMONTDES
    Endif
    If [F:DUD]DINAMT <> 0
        Call CONVERT([F:DUD]CUR, [F:SOH]CUR, GLOCALDEV, [F:SOH]CHGTYP, date$,
&                    [F:DUD]DINAMT, WMONTDES, SPSTAT) From TRTDEV
        [F:DUD]DINAMT = WMONTDES
    Endif
    [F:DUD]CUR = [F:SOH]CUR
    Call SLDECH("DUD")From MODECHE
    Rewrite [DUD]
    If fstat GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
    Call HISTOECH("DUD",1,[F:SOH]ORDDAT)From MODECHE
Next

Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête commande                      #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "SOH"+[F:SOH]SOHNUM
Lock = SYMBOLE With lockwait = 0
OK=2
If fstat
    Call ECR_TRACE([F:SOH]SOHNUM - mess(10,100,1),1) From GESECRAN
    OK=1
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête commande                           #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

#--------------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande                #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramètres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char     PARAM2(10)

# --- Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"SLT",2,GFLAG) From TRTX3CPT
# --- Si changement société
If GSOC_UPDFLG
    # --- Chargement des paramètres de localisation
    # --- Utilisation systeme de taxe
    Call LEC_CPY(GSOCIETE) From CPTLEC   # 106867.n
#    If func AFNC.ACTIV("KUS")  # 106867.so
#        Call PARAM(GFCY,"USATAX",PARAM2) From ADOVAL
#        GLOCUSATAX=val(PARAM2)
#        If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
#    Else
#      Raz GLOCUSATAX
#    Endif  # 106867.eo
Endif
Return
