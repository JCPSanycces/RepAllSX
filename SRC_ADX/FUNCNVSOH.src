########################################
# ----------------------------------- TOUSITE ---------------------------------
Subprog AS_TOUSITE(VALEUR)
Variable Integer VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    VALEUR=1 : mkstat=2
Else
    VALEUR=2
Endif
End
########################################
Subprog AM_TOUSITE(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 Raz [M]SITE : Affzo [M]SITE : Endif
End
# ----------------------------------- SITE ---------------------------------
########################################
Subprog AS_SITE(VALEUR)
Variable Char    VALEUR()
If [M]TOUSITE = 2 Raz VALEUR : mkstat = 1 Endif
End
########################################
Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M]TOUSITE <> 2 mkstat = 2 Endif
End
