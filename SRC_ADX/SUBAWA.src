Subprog AS_SUIVI(VALEUR)
Variable Integer VALEUR
Local Char ACTION(20)
Case [M]TYPDES(nolign-1)
 When 1 : End
 When 2 : mkstat = 1 : End
Endcase
ACTION = "AS_ZONE" : Gosub ACTION
End

Subprog C_SUIVI(VALEUR)
Variable Integer VALEUR
Local Char ACTION(20) , CHAINE(250) , DEST(GLONAUS)
Local Integer ER
If VALEUR=2 & instr(1,[M]DESTIN(nolign-1),"@")
 DEST = ""
 Onerrgo ER
 CHAINE = evalue([M]DESTIN(nolign-1))
 Onerrgo
 If !ER
  Local File AUTILIS [AUS2]
  For [AUS2] Where toupper(ADDEML)=toupper(CHAINE)
   DEST = [F:AUS2]USR : Break
  Next AUS2
  Close Local File [AUS2]
 Endif
 If DEST=""
  GMESSAGE = mess(180,75,1) : # Suivi impossible\L'adresse email ne correspond pas à un utilisateur enregistré
  mkstat = 2 : End
 Endif
Endif
If [M]TYPDES(nolign-1)<=2 : End : Endif
ACTION = "C_ZONE" : Gosub ACTION
End

$ER
ER = errn
Resume

