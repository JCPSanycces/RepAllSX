Subprog AS_BAKSYRA(VALEUR)
Variable Char    VALEUR()
Raz [M:AWA1]ABRFIL, TABFIL
If [M]RETOUR<>2
 mkstat = 1 : End
Endif
End

Subprog C_BAKSYRA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ASW]ASW0=VALEUR
  If !fstat
    If [F:ASW]TYPMSKREP<>1            # Desktop
      GMESSAGE = mess(207,75,1)       # Representation must be desktop
      mkstat = 2
      End
    Endif
  Else
    GMESSAGE = mess(83,123,1)
    mkstat=2
    End
  Endif
Endif
If [M]BAKSYRA <> VALEUR
 Raz [M]BAKLNKSYRA
Endif
[M]BAKSYRA = VALEUR
Gosub GRISE_RET
End

Subprog AS_BAKLNKSYRA(VALEUR)
Variable Char    VALEUR()

If VALEUR<>"" : End : Endif

Local Integer I,NBCLE
If [M]RETOUR<>2
 mkstat = 1 : End
Endif

# Get representation and class and indices
Read [F:ASW]ASW0=[M]BAKSYRA
If !fstat
  Read [F:ACLA]ACLA0=[F:ASW]CODCLA
  If !fstat
    VALEUR = ctrans([F:ACLA]KEYINT,"+-",";;")
    If left$(VALEUR,1)=";"
      VALEUR = right$(VALEUR,2)
    Endif
  Endif
Endif
End

Subprog AS_BAKLNKMOBILE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif

Local Integer I,NBCLE
If [M]RETOUR<>2
 mkstat = 1 : End
Endif

# Get representation and class and indices
Read [F:ASW]ASW0=[M]BAKMOBILE
If !fstat
  Read [F:ACLA]ACLA0=[F:ASW]CODCLA
  If !fstat
    VALEUR = ctrans([F:ACLA]KEYINT,"+-",";;")
    If left$(VALEUR,1)=";"
      VALEUR = right$(VALEUR,2)
    Endif
  Endif
Endif
End

Subprog AS_BAKMOBILE(VALEUR)
Variable Char    VALEUR()
Raz [M:AWA1]ABRFIL, TABFIL
If [M]RETOUR<>2
 mkstat = 1 : End
Endif
