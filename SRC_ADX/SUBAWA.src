Subprog AS_CONDITION(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TAB
End

$CHARGE_TAB
Local Integer I , NB
Gosub SET_MODELE
Raz [M:AWA1]ABRFIL , TABFIL , NB
If [F:AWM]TABREF<>""
 NB += 1
 Read [ATB]CODFIC = [F:AWM]TABREF
 [M:AWA1]ABRFIL(NB-1) = [F:ATB]ABRFIC
 [M:AWA1]TABFIL(NB-1) = [F:ATB]CODFIC
Endif
If [F:AWM]MODELE<>""
For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & TYPTAB<1
  NB += 1
  [M:AWA1]TABFIL(NB-1) = [F:AWK]TABLNK
  If [F:AWK]ABRLNK<>""
   [M:AWA1]ABRFIL(NB-1) = [F:AWK]ABRLNK
  Else
   Read [ATB]CODFIC = [F:AWK]TABLNK
   [M:AWA1]ABRFIL(NB-1) = [F:ATB]ABRFIC
  Endif
 Next I
Endif
Return

Subprog AM_ENAMES(VALEUR)
Variable Integer VALEUR
Local Integer I , OK
If VALEUR<>2
 For I=1 To [M:AWA2]NBDEST
  If [M:AWA2]ENVOI(I-1)>1
   # Au moins un destinataire est paramétré pour recevoir un mail
   Call AVERTIR(mess(181,75,1),OK) From GESECRAN
   If OK<>2 : mkstat = 2 : Endif
   Break
  Endif
 Next I
Endif
End

Subprog AM_ENASUI(VALEUR)
Variable Integer VALEUR
Local Integer I
Local Integer I , OK
If VALEUR<>2
 For I=1 To [M:AWA2]NBDEST
  If [M:AWA2]SUIVI(I-1)>1
   # Au moins un destinataire est paramétré pour le suivi
   Call AVERTIR(mess(182,75,1),OK) From GESECRAN
   If OK<>2 : mkstat = 2 : Endif
   Break
  Endif
 Next I
Endif
End

