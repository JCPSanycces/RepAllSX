Subprog C_BAKMOBILE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ASW]ASW0=VALEUR
  If !fstat
    If [F:ASW]TYPMSKREP<>2            # Mobile
      GMESSAGE = mess(208,75,1)       # Representation must be mobile
      mkstat = 2
      End
    Endif
  Else
    GMESSAGE = mess(83,123,1)
    mkstat=2
    End
