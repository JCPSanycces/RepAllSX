Subprog AS_BAKLNK(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    OBJET(GLONAOB)
Raz [M:AWA1]ABRFIL, TABFIL
If [M]RETOUR<>2
 mkstat = 1 : End
Endif
Read [AFC]CODINT=[M]BAKFCT
If !fstat & [F:AFC]TYP=2 : # Objet
 Raz I
 For OBJET=right$([M]BAKFCT,4),[M]CODEVT
  Read [AOB]ABREV  = OBJET
  If !fstat & [F:AOB]NOMFIC<>""
   Read [ATB]CODFIC = [F:AOB]NOMFIC
   If !fstat
    [M:AWA1]ABRFIL(I) = [F:ATB]ABRFIC
    [M:AWA1]TABFIL(I) = [F:ATB]CODFIC
    I += 1
   Endif
  Endif
 Next OBJET
Endif
End

Subprog C_BAKLNK(VALEUR)
Variable Char    VALEUR()
Local    Integer I, J, NBPART , NBPOINT
If VALEUR<>""
 Read [AFC]CODINT=[M]BAKFCT
 If !fstat & [F:AFC]TYP=2 : # Objet
  Read [AOB]ABREV  = right$([M]BAKFCT,4)
  If !fstat
   Gosub SETCLE From ="WO"+right$([M]BAKFCT,4)
   NBPART = 1
   If dim([L]CLEVALEUR)>0 : ## GEODE
    For I=0 To dim(CLESUPP)-1
     If CLESUPP(I)<>""
      NBPART += 1
     Endif
    Next I
   Else
    For I=0 To dim(CLESEC)-1
     If CLESEC(I)<>""
      NBPART += 1
     Endif
    Next I
   Endif
   If CLELIG<>""
    NBPART -= 1
   Endif
   NBPOINT = 0
   For I= 1 To len(VALEUR)
    If mid$(VALEUR,I,1)=";"
     NBPOINT += 1
    Endif
   Next I
   If NBPOINT<>NBPART-1
    GMESSAGE = mess(46,9022,1) : # Clé incorrecte
    mkstat = 2
   Endif
  Endif
 Endif
Endif
End

