#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion Règles Workflow
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AWA",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAWAB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "MODIF"      : Gosub MODIF
 When "CREATION"   : Gosub CREATION
 When "APRES_MOD"  : Gosub APRES_MOD
 When "APRES_CRE"  : Gosub APRES_CRE
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "ANNULE"     : Gosub ANNULE

 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "SEL_TABLE"  : Gosub SEL_TABLE

 When "LECENT"     : # Pour rajouter des tables liées dans les traitements WMK*
Endcase
If PSUBB
 Gosub ACTION From SUBAWAB
Endif
Return

#----------------------------------------------------------------------------#
$OUVRE
If GLIAISON<>"" or GLIAISON(1)<>""
 If clalev([F:ALI])=0  : Local File ALINK   [ALI]  : Endif
 Local Integer WNB0 , WNB1
 Local Schar   WLNK0(3+GLONAWA)(1..300) , WLNK1(3+GLONAWA)(1..300)
 Local Schar   WSUP0(GLONADI)(1..300) , WSUP1(GLONADI)(1..300)
Endif
If clalev([F:AWAL])=0 : Local File AWRKPAR [AWAL] : Endif
If !clalev([ASW]) : Local File ASHW [ASW] : Endif                 # X3PLAT-1475 Workflow link on representation
If !clalev([F:ACLA]) : Local File ACLASSE [ACLA] : Endif          # X3PLAT-1475 Workflow link on representation
Return

#----------------------------------------------------------------------------#
$LIENS
Local Char ACT(GLONACT)
Local Integer DIMPAR
Call LECTEXTRA([M]INTIT,"AWRKPAR","INTIT",[M]CODE,"") From ATEXTRA
Read [AWF]AWF0 = [M]CODE
[M:AWA4] = [F:AWF]
Read [AWH]AWH0 = [M]CODE
[M:AWA2] = [F:AWH]
nolign = 0
DIMPAR = dim([F:AWC]VALPAR)
For [AWC]AWC0 Where CODE=[M]CODE
 nolign += 1
 [M:AWA5] = [F:AWC]
 [M:AWA5]NACT(nolign-1) = nolign
 For I=1 To DIMPAR
  [M:AWA5]CPAR((nolign-1)*DIMPAR+I-1) = [F:AWC]CODPAR(I-1)
  [M:AWA5]VPAR((nolign-1)*DIMPAR+I-1) = [F:AWC]VALPAR(I-1)
 Next I
Next AWC
[M]NBACT = nolign
nolign = 1
Gosub CHARGE_PAR
Gosub CHARGE_HLP
Gosub CHARGE_LIBEVT
Gosub GRISE_EVT
Gosub GRISE_OPE
Gosub GRISE_MOD
Gosub GRISE_REG
Gosub GRISE_TYP
Gosub GRISE_GRP
Gosub GRISE_JOI
Gosub GRISE_ACT
Gosub GRISE_RET
Gosub GRISE_REQ
Gosub GRISE_SIG
If GLIAISON(1)<>""
 WNB0 = 0
 For I=1 To [F:AWF]NBRSIG
  If [F:AWF]OPESIG(I-1)<>""
   For [AWAL] Where TYPEVT=9 & OPERATION=[F:AWF]OPESIG(I-1)
    WNB0 += 1
    WLNK0(WNB0) = "AWA"+[F:AWAL]CODE
    WSUP0(WNB0) = [F:AWF]ACTSIG(I-1)
   Next AWAL
  Endif
 Next I
Endif
Return

#----------------------------------------------------------------------------#
$CHARGE_PAR
Raz [M]NBPAR, [M]PARAM, [M]PARVAL
If [M]NACT(nolign-1)=0
 For I=0 To dim([M]ACTION)-1
  If [M]NACT(I)>0 & [M]NACT(I)>NACT(nolign-1)
   [M]NACT(nolign-1) = [M]NACT(I)
  Endif
 Next I
 [M]NACT(nolign-1) += 1
Endif
[M]NPAR =  [M]NACT(nolign-1)
ACT = [M]ACTION(nolign-1)
While ACT<>""
 Read [ACT]ACTION = ACT
 If [F:ACT]AMSFLG=2 & [F:ACT]TYP=8
  For [ATR]NOPAR Where ACTION=ACT
   If [F:ATR]NOPAR>1 or [F:ACT]TYPACT<>2
    If !find([F:ATR]CODPAR,[M]PARAM(0..[M]NBPAR-1))
     [M]PARAM([M]NBPAR) = [F:ATR]CODPAR
     [M]TYPPAR([M]NBPAR) = [F:ATR]TYPPAR
     [M]ADRVAL([M]NBPAR) = [F:ATR]ADRVAL
     K = find([F:ATR]CODPAR,[M]CPAR(([M]NPAR-1)*DIMPAR..([M]NPAR-1)*DIMPAR+DIMPAR-1))
     If K
      [M]PARVAL([M]NBPAR) = [M]VPAR(([M]NPAR-1)*DIMPAR+K-1)
     Endif
     Read [AAR]CODPAR = [F:ATR]CODPAR
     [M]NBPAR += 1
    Endif
   Endif
  Next ATR
  ACT = [F:ACT]ACTSUI
 Else
  ACT = ""
 Endif
Wend
Return

#----------------------------------------------------------------------------#
$CHARGE_LIBEVT
Case [M]TYPEVT
 When 1 : # Divers
  Call LECTEXTRA([M]LIBEVT,"ATABDIV","LNGDES","908",[M]CODEVT) From ATEXTRA
 When 2 : # Objet
  Read [AOB]ABREV = [M]CODEVT
  If !fstat
   Call TEXTE([F:AOB]LIBEL,[M]LIBEVT) From OBJDIV
  Else
   Raz [M]LIBEVT
  Endif
 When 3 : # Fonction
  Read [AFC]CODINT = [M]CODEVT
  If !fstat
   Call TEXTE([F:AFC]NOM,[M]LIBEVT) From OBJDIV
  Else
   Raz [M]LIBEVT
  Endif
 When 4 : # Report
  Read [ARP]ARP0 = [M]CODEVT
  If !fstat
   Call TEXTE([F:ARP]RPTDES,[M]LIBEVT) From OBJDIV
  Else
   Raz [M]LIBEVT
  Endif
 When 5,6 : # Batch
  [M]LIBEVT = ""
  Read [ABT]CODTAC = [M]CODEVT
  If !fstat
   Local Char DOSX3(GLONADS)
   If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
   Read [ADW]ADW0 = "";"";"SUPDOS"
   DOSX3 = [F:ADW]VALEUR
   If DOSX3<>""
    Close Local File [ATX]
    Local File =DOSX3+".ATEXTE" [ATX]
    Call TEXTE([F:ABT]DES,[M]LIBEVT) From OBJDIV
    Close Local File [ATX]
    Local File ATEXTE [ATX]
   Endif
  Endif
 When 8 : # Import/export
  Read [AOE]AOE0 = [M]CODEVT
  If !fstat
   Call LECTEXTRA([M]LIBEVT,"AOBJEXT","INTIT",[F:AOE]EXT,"") From ATEXTRA
  Else
   Raz [M]LIBEVT
  Endif
 When 9 : # Signature
  If [M]CODEVT<>""
   Call LECTEXTRA([M]LIBEVT,"AWRKPAR","INTIT",[M]CODEVT,"") From ATEXTRA
  Else
   Raz [M]LIBEVT
  Endif
 When Default
  Raz [M]LIBEVT
Endcase
Return

#----------------------------------------------------------------------------#
$CHARGE_HLP
Local Integer I , J , NBFOR
Local Char    A_AHLP(50) , OBJET(GLONAOB)
Local Char    FEN(GLONFEN)
Raz [M]HLPFOR, NBFOR
A_HLP = "AUTILIS" : Gosub INC_HLP
FEN = ""
Case TYPEVT
 When 2 : # Objet
  OBJET = [M]CODEVT
  Gosub SET_FENOBJ
 When 4 : # Report
  FEN = "AIMP1"
 When 5 : # Batch
  Read [ABT]CODTAC = [M]CODEVT
  If !fstat & [F:ABT]FONCTION<>""
   Read [AFC]CODINT = [F:ABT]FONCTION
   If !fstat & [F:AFC]ACTION<>""
    Read [ACT]ACTION=[F:AFC]ACTION
    If !fstat & [F:ACT]PARAM4<>""
     FEN = [F:ACT]PARAM4
    Endif
   Endif
  Endif
 When 8 : # Import/export
  FEN = "OAOE"
Endcase
If FEN<>""
 Read [AWI]AWI0 = FEN
 If fstat : FEN = "" : Endif
Endif
Case [M]TYPEVT
 When 1 : # Divers
  Case [M]CODEVT
   When "ARP" :  A_HLP = "AREPORT"      : Gosub INC_HLP
                 A_HLP = "[M:ARP]AIMP1" : Gosub INC_HLP
  Endcase
 When 2 : # Objet
  Read [AOB]ABREV = [M]CODEVT
  If !fstat
   A_HLP = [F:AOB]NOMFIC : Gosub INC_HLP
   Gosub CHARGE_AWI
  Endif
 When 3 : # Fonction
  A_HLP = "AFONCTION" : Gosub INC_HLP
 When 4 : # Report
  A_HLP = "AREPORT" : Gosub INC_HLP
  Gosub CHARGE_AWI
 When 5 : # Batch
  A_HLP = "[V]GERRBATCH"  : Gosub INC_HLP
  A_HLP = "[V]GMESSBATCH" : Gosub INC_HLP
  A_HLP = "[V]GERRTRACE"  : Gosub INC_HLP
  Gosub CHARGE_AWI
 When 8 : # Import/export
  Read [AOE]AOE0 = [M]CODEVT
  If !fstat
   A_HLP = "AOBJEXT" : Gosub INC_HLP
   Gosub CHARGE_AWI
  Endif
Endcase
Gosub SET_MODELE
If [F:AWM]TABREF<>""
 Read [ATB]CODFIC = [F:AWM]TABREF
 A_HLP = "[F:"+[F:ATB]ABRFIC+"]"+[F:AWM]TABREF : Gosub INC_HLP
 If [F:AWM]MODELE<>""
  For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & TYPTAB<1
   If [F:AWK]ABRLNK<>""
    A_HLP = "[F:"+[F:AWK]ABRLNK+"]"+[F:AWK]TABLNK : Gosub INC_HLP
   Else
    Read [ATB]CODFIC = [F:AWK]TABLNK
    A_HLP = "[F:"+[F:ATB]ABRFIC+"]"+[ATB]CODFIC : Gosub INC_HLP
   Endif
  Next I
 Endif
Endif
Return

$INC_HLP
If NBFOR<dim([M]HLPFOR) & !find(A_HLP,[M]HLPFOR(0..NBFOR+1))
 NBFOR += 1
 [M]HLPFOR(NBFOR-1) = A_HLP
Endif
Return

#--------------------------------------------#
$SET_FENOBJ
Filter [AWI] Where OBJ=OBJET
Read [AWI]AWI0 = "O"+OBJET
If !fstat
 FEN = [F:AWI]WIN
Else
 For [AWI]
  FEN = [F:AWI]WIN : Break
 Next AWI
Endif
Filter [AWI]
Return

#--------------------------------------------#
$CHARGE_AWI
If FEN<>""
 If [F:AWI]MSKENT<>""
  Read [AMK]CODMSK = [F:AWI]MSKENT
  If !fstat
   A_HLP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AWI]MSKENT : Gosub INC_HLP
  Else
   A_HLP = "[M]"+[F:AWI]MSKENT : Gosub INC_HLP
  Endif
 Endif
 For I=0 To [F:AWI]NBMSK-1
  If [F:AWI]NOMMSK(I)<>""
   J = 1
   If [F:AWI]ACTMSK(I)<>""
    Read [ACV]CODACT = [F:AWI]ACTMSK(I)
    If fstat | [F:ACV]FLACT<>2
     J = 0
    Endif
   Endif
   If J
    Read [AMK]CODMSK = [F:AWI]NOMMSK(I)
    If !fstat
     A_HLP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AWI]NOMMSK(I)
    Else
     A_HLP = "[M]"+[F:AWI]NOMMSK(I)
    Endif
    Gosub INC_HLP
   Endif
  Endif
 Next I
Endif
Return

#--------------------------------------------#
$GRISE_EVT
Case [M]TYPEVT
 When 1 : # Divers
  Actzo [AWA1]ENAMES, CODEVT , ENASUI , ENAACT
  Effzo [AWA1]OPERATION
  Grizo [AWA1]OPERATION
  Actzo [AWA3]TEXLIG
  Effzo [AWA3]JOIOBJ
  Grizo [AWA3]JOIOBJ
  Actzo [AWA3]JOINT, INTERV, GRPENV
  Actzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  If [M]CODEVT="TRA"
   [M]DEBUG = 1
   Affzo [AWA1]DEBUG
   Diszo [AWA1]DEBUG
   [M]TYPMES = 2
   Affzo [AWA3]TYPMES
   Diszo [AWA3]TYPMES
   [M]TRACE = 2
   Affzo [AWA3]TRACE
   Diszo [AWA3]TRACE
  Else
   Actzo [AWA1]DEBUG
   Actzo [AWA3]TYPMES
   Actzo [AWA3]TRACE
  Endif
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 2 : # Objet
  Actzo [AWA1]DEBUG, ENAMES, CODEVT, OPERATION, ENASUI, ENAACT
  Actzo [AWA3]TEXLIG
  Actzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Actzo [AWA3]JOINT, JOIOBJ, INTERV, TYPMES, GRPENV
  Effzo [AWA3]TRACE
  Grizo [AWA3]TRACE
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 3 : # Fonction
  Actzo [AWA1]DEBUG, ENAMES, CODEVT, ENASUI, ENAACT
  Effzo [AWA1]OPERATION
  Grizo [AWA1]OPERATION
  Actzo [AWA3]TEXLIG
  Actzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, TYPMES, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Effzo [AWA3]JOIOBJ, TRACE
  Grizo [AWA3]JOIOBJ, TRACE
  Actzo [AWA3]JOINT, INTERV, GRPENV
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 4 : # Edition
  Actzo [AWA1]DEBUG, ENAMES, CODEVT, OPERATION, ENASUI, ENAACT
  Actzo [AWA3]TEXLIG
  Effzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Grizo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Effzo [AWA3]JOIOBJ, TRACE
  Grizo [AWA3]JOIOBJ, TRACE
  Actzo [AWA3]JOINT, TYPMES, INTERV, GRPENV
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 5 : # Fin de tâche
  Actzo [AWA1]DEBUG, ENAMES, CODEVT, ENASUI, ENAACT
  Effzo [AWA1]OPERATION
  Grizo [AWA1]OPERATION
  [M]INTERV = 1
  [M]TYPMES = 2
  Affzo [AWA3]TYPMES, INTERV
  Diszo [AWA3]TYPMES, INTERV
  Actzo [AWA3]TEXLIG
  Actzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Effzo [AWA3]JOIOBJ
  Grizo [AWA3]JOIOBJ
  Actzo [AWA3]JOINT, TRACE, GRPENV
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 6 : # Arrêt de tâche (géré par le serveur batch)
  [M]ENASUI = 1
  [M]ENAACT = 1
  Affzo [AWA1]ENASUI, ENAACT
  Grizo [AWA1]ENASUI, ENAACT
  [M]ENAMES = 2
  Affzo [AWA1]ENAMES
  Diszo [AWA1]ENAMES
  Actzo [AWA1]CODEVT, DEBUG
  Effzo [AWA1]OPERATION
  Grizo [AWA1]OPERATION
  [M]INTERV = 1
  [M]TYPMES = 2
  Affzo [AWA3]TYPMES, INTERV
  Diszo [AWA3]TYPMES, INTERV
  Effzo [AWA3]TEXLIG
  Grizo [AWA3]TEXLIG
  Effzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Grizo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Effzo [AWA3]JOINT, JOIOBJ, TRACE, GRPENV
  Grizo [AWA3]JOINT, JOIOBJ, TRACE, GRPENV
  Effzo [AWA4]FLGSIG, TEXSUI
  Grizo [AWA4]FLGSIG, TEXSUI
  Effzo [AWA5]20
  Grizo [AWA5]20
 When 7 : # Gestion des temps (Paye)
  Actzo [AWA1]DEBUG, ENAMES, CODEVT, ENASUI, ENAACT
  Effzo [AWA1]OPERATION
  Grizo [AWA1]OPERATION
  Actzo [AWA3]TEXLIG
  Actzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, TYPMES, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Effzo [AWA3]JOIOBJ, TRACE
  Grizo [AWA3]JOIOBJ, TRACE
  Actzo [AWA3]JOINT, INTERV, GRPENV
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 8 : # Import/export
  Actzo [AWA1]DEBUG, ENAMES, ENASUI, ENAACT
  Actzo [AWA1]OPERATION, CODEVT
  Effzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Grizo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Effzo [AWA3]JOINT , JOIOBJ
  Grizo [AWA3]JOINT , JOIOBJ
  Actzo [AWA3]TEXLIG
  Actzo [AWA3]TRACE, TYPMES, INTERV, GRPENV
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 9 : # Signature
  Actzo [AWA1]DEBUG , ENAMES , ENASUI , ENAACT
  Actzo [AWA1]CODEVT , OPERATION
  Effzo [AWA3]TRACE
  Grizo [AWA3]TRACE
  Actzo [AWA3]JOINT , JOIOBJ
  Actzo [AWA3]BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Actzo [AWA3]TEXLIG, RETOUR , GRPENV
  Actzo [AWA3]TYPMES, INTERV
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
 When 10 : # Manuel
  Effzo [AWA1]CODEVT, OPERATION
  Grizo [AWA1]CODEVT, OPERATION
  Actzo [AWA1]DEBUG, ENAMES, ENASUI, ENAACT
  Actzo [AWA3]RETOUR, BAKFCT, BAKMEN, BAKLNK, BAKSYRA, BAKLNKSYRA, BAKMOBILE, BAKLNKMOBILE  # X3PLAT-1475 Workflow links - add representations
  Effzo [AWA3]JOINT , JOIOBJ
  Grizo [AWA3]JOINT , JOIOBJ
  Actzo [AWA3]TEXLIG
  Actzo [AWA3]TRACE, TYPMES, INTERV, GRPENV
  Actzo [AWA4]FLGSIG, TEXSUI
  Actzo [AWA5]20
Endcase
Return

#--------------------------------------------#
$GRISE_OPE
If [M]TYPEVT=2 & instr(1,[M]OPERATION,"M")
 Actzo [AWA1]TYPDEC
Else
 [M]TYPDEC = 0
 Affzo [AWA1]TYPDEC
 Grizo [AWA1]TYPDEC
Endif
Return

#--------------------------------------------#
$GRISE_MOD
If find([M]TYPEVT,6,9) : # Arrêt d'une tâche , Signature
 Effzo [AWA1]MODELE
 Grizo [AWA1]MODELE
Else
 Actzo [AWA1]MODELE
Endif
Return

#--------------------------------------------#
$GRISE_REG
If ([M]MODELE="" & [M]TYPEVT<>9) or find([M]TYPEVT,6) : # Arrêt d'une tâche
 Effzo [AWA1]REGLE
 Grizo [AWA1]REGLE
Else
 Actzo [AWA1]REGLE
Endif
Return

#--------------------------------------------#
$GRISE_TYP
Local Integer I , K
If [M]TYPEVT=9
 Raz [F:AWR] , [F:AWM]
Elsif [M]REGLE<>""
 Read [AWR]AWR1(1) = [M]REGLE
 Read [AWM]AWM0 = [F:AWR]MODELE
Elsif [M]MODELE<>""
 Read [AWM]AWM0 = [M]MODELE
 Raz [F:AWR]
Else
 Raz [F:AWR] , [F:AWM]
Endif
If [M]TYPEVT=9
 If [M]CODEVT=""
  [M]TYPWRK = 2 : # Entête
 Else
  Read [AWAL]AWA0=[M]CODEVT
  [M]TYPWRK = [F:AWAL]TYPWRK
 Endif
 Affzo [AWA1]TYPWRK
 Diszo [AWA1]TYPWRK
 Effzo [AWA1]TABLIG
 Grizo [AWA1]TABLIG
 Effzo [AWA1]ABRLIG
 Grizo [AWA1]ABRLIG
 Affzo [AWA1]TYPWRK
 Diszo [AWA1]TYPWRK
 Effzo [AWA1]GROUPE
 Grizo [AWA1]GROUPE
 Actzo [AWA3]TEXLIG
Elsif [F:AWR]REGLE<>""
 If [F:AWR]TABLIG<>""
  [M]TYPWRK = 3 : # Ligne
  [M]TABLIG = [F:AWR]TABLIG
  [M]ABRLIG = [F:AWR]ABRLIG
  Diszo [AWA1]TYPWRK , TABLIG , ABRLIG
  Actzo [AWA1]GROUPE
  Actzo [AWA3]TEXLIG
 Else
  Effzo [AWA1]TABLIG , ABRLIG
  Grizo [AWA1]TABLIG , ABRLIG
  If [M]TYPEVT=10
   [M]TYPWRK = 3 : # Ligne
   Affzo [AWA1]TYPWRK
   Diszo [AWA1]TYPWRK
   Actzo [AWA1]GROUPE
   Actzo [AWA3]TEXLIG
  Else
   [M]TYPWRK = 2 : # Entête
   Affzo [AWA1]TYPWRK
   Diszo [AWA1]TYPWRK
   Effzo [AWA1]GROUPE
   Grizo [AWA1]GROUPE
   Effzo [AWA3]TEXLIG
   Grizo [AWA3]TEXLIG
  Endif
 Endif
Else
 K = 0
 If [F:AWM]MODELE<>""
  For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & (TYPLNK=2 or TYPLNK=4)  & TYPTAB<1 : # Lien 0,n/1,n
   K += 1
  Next I
 Endif
 If K
  Actzo [AWA1]TYPWRK , TABLIG , GROUPE , ABRLIG
  Actzo [AWA3]TEXLIG
 Else
  Effzo [AWA1]TABLIG , ABRLIG
  Grizo [AWA1]TABLIG , ABRLIG
  If [M]TYPEVT=10
   [M]TYPWRK = 3 : # Ligne
   Affzo [AWA1]TYPWRK
   Diszo [AWA1]TYPWRK
   Actzo [AWA1]GROUPE
   Actzo [AWA3]TEXLIG
  Else
   [M]TYPWRK = 2 : # Entête
   Affzo [AWA1]TYPWRK
   Diszo [AWA1]TYPWRK
   Effzo [AWA1]GROUPE
   Grizo [AWA1]GROUPE
   Effzo [AWA3]TEXLIG
   Grizo [AWA3]TEXLIG
  Endif
 Endif
Endif
Return

#--------------------------------------------#
$GRISE_GRP
If [M]TYPEVT=10
 Actzo [AWA1]GROUPE
 Actzo [AWA3]TEXLIG
 If [M]TYPWRK<>3
  Effzo [AWA1]TABLIG
  Grizo [AWA1]TABLIG
  Effzo [AWA1]ABRLIG
  Grizo [AWA1]ABRLIG
 Elsif [M]REGLE<>""
  Diszo [AWA1]TABLIG
  Diszo [AWA1]ABRLIG
 Else
  Actzo [AWA1]TABLIG
  Actzo [AWA1]ABRLIG
 Endif
Elsif [M]TYPWRK<>3 : # Ligne
 Effzo [AWA1]TABLIG , GROUPE , ABRLIG
 Grizo [AWA1]TABLIG , GROUPE , ABRLIG
 Effzo [AWA3]TEXLIG
 Grizo [AWA3]TEXLIG
Elsif [M]REGLE<>""
 Diszo [AWA1]TABLIG
 Diszo [AWA1]ABRLIG
 Actzo [AWA1]GROUPE
 Actzo [AWA3]TEXLIG
Else
 Actzo [AWA1]TABLIG , GROUPE , ABRLIG
 Actzo [AWA3]TEXLIG
Endif
Return

#--------------------------------------------#
$GRISE_JOI
If [M]JOIOBJ<>2
 [M]ALLTYPJOI = 0
 [M]TYPJOI = ""
 [M]ALLCATJOI = 0
 [M]CATJOI = 0
 Affzo [AWA3]ALLTYPJOI, TYPJOI, ALLCATJOI, CATJOI
 Grizo [AWA3]ALLTYPJOI, TYPJOI, ALLCATJOI, CATJOI
Else
 Actzo [AWA3]ALLTYPJOI, ALLCATJOI
 If [M]ALLTYPJOI=2
  Raz [M]TYPJOI
  Affzo [AWA3]TYPJOI
  Grizo [AWA3]TYPJOI
 Else
  Actzo [AWA3]TYPJOI
 Endif
 If [M]ALLCATJOI=2
  [M]CATJOI = 0
  Affzo [AWA3]CATJOI
  Grizo [AWA3]CATJOI
 Else
  Actzo [AWA3]CATJOI
 Endif
Endif
Return

#--------------------------------------------#
$GRISE_ACT
If [M]NBACT=0
 Effzo [AWA5]30
 Grizo [AWA5]30
Else
 Actzo [AWA5]30
Endif
Return

#--------------------------------------------#
$GRISE_RET
# X3PLAT-1475 Workflow link on representation - include desktop and mobile fields
If [M]RETOUR<>2
 Effzo [AWA3]BAKFCT, BAKMEN, BAKSYRA, BAKMOBILE
 Grizo [AWA3]BAKFCT, BAKMEN, BAKSYRA, BAKMOBILE
Else
 Actzo [AWA3]BAKFCT, BAKMEN, BAKSYRA, BAKMOBILE
Endif
If [M]BAKFCT=""
 Effzo [AWA3]BAKLNK
 Grizo [AWA3]BAKLNK
Else
 Actzo [AWA3]BAKLNK
Endif
If [M]BAKSYRA=""
 Effzo [AWA3]BAKLNKSYRA
 Grizo [AWA3]BAKLNKSYRA
Else
 Actzo [AWA3]BAKLNKSYRA
Endif
If [M]BAKMOBILE=""
 Effzo [AWA3]BAKLNKMOBILE
 Grizo [AWA3]BAKLNKMOBILE
Else
 Actzo [AWA3]BAKLNKMOBILE
Endif
Return

#--------------------------------------------#
$GRISE_REQ
If [M]TYPMES=2
 Effzo [AWA3]REQREC
 Grizo [AWA3]REQREC
Else
 Actzo [AWA3]REQREC
Endif
Return

#--------------------------------------------#
$GRISE_SIG
If [M]FLGSIG<>2
 Effzo [AWA4]DELSIG
 Grizo [AWA4]DELSIG
 Effzo [AWA4]20, 25
 Grizo [AWA4]20, 25
Else
 Actzo [AWA4]25
 Actzo [AWA4]DELSIG
 If [M]TYPEVT<>9
  Actzo [AWA4]20
 Else
  Effzo [AWA4]20
  Grizo [AWA4]20
 Endif
Endif
Return

#--------------------------------------------#
$MODIF
Delete [AWF] Where CODE=[M]CODE
If fstat=1
 GOK=-1 : Call RSTA("AWF",CLECUR1) From GLOCK : Return
Endif
Delete [AWH] Where CODE=[M]CODE
If fstat=1
 GOK=-1 : Call RSTA("AWH",CLECUR1) From GLOCK : Return
Endif
Delete [AWC] Where CODE=[M]CODE
If fstat=1
 GOK=-1 : Call RSTA("AWC",CLECUR1) From GLOCK : Return
Endif
Delete [AWX] Where CODE=[M]CODE
If fstat=1
 GOK=-1 : Call RSTA("AWX",CLECUR1) From GLOCK : Return
Endif
Gosub ECRIRE
Return

#--------------------------------------------#
$CREATION
Gosub ECRIRE
WNB0 = 0
Return

#--------------------#
$ECRIRE
[F:AWF] = [M:AWA4]
[F:AWF]CODE = [M:AWA0]CODE
Write [AWF]
If fstat
 GOK=0 : Call FSTA("AWF") From GLOCK
 Return
Endif
[F:AWH] = [M:AWA2]
[F:AWH]CODE = [M:AWA0]CODE
Write [AWH]
If fstat
 GOK=0 : Call FSTA("AWH") From GLOCK
 Return
Endif
DIMPAR = dim([F:AWC]VALPAR)
For nolign=1 To [M:AWA5]NBACT
 [M:AWA5]NUMACT(nolign-1) = nolign
Next nolign
Sorta [M]NBACT [M:AWA5]NBACT Order By [M:AWA5]DECACT(indice) , [M:AWA5]NUMACT(indice)
For nolign=1 To [M:AWA5]NBACT
 [F:AWC] = [M:AWA5]
 [F:AWC]CODE = [M:AWA0]CODE
 [F:AWC]NUMACT = nolign
 For I=1 To DIMPAR
  [F:AWC]CODPAR(I-1) = [M:AWA5]CPAR(([M:AWA5]NACT(nolign-1)-1)*DIMPAR+I-1)
  [F:AWC]VALPAR(I-1) = [M:AWA5]VPAR(([M:AWA5]NACT(nolign-1)-1)*DIMPAR+I-1)
 Next I
 Write [AWC]
 If fstat
  GOK=0 : Call FSTA("AWC") From GLOCK : Break
 Endif
Next nolign
If GOK<>1 : Return : Endif
Call MAJTEXTRA([M]INTIT,"AWRKPAR","INTIT",[M:AWA0]CODE,"") From ATEXTRA
If GLIAISON(1)<>""
 Gosub CRE_LIENS
Endif
Return

#--------------------#
$CRE_LIENS
Local Char BID(250)
If clalev([F:AWAL])=0 : Local File AWRKPAR [AWAL] : Endif
If dim(WSUP1)<=0
 Local Schar WSUP1(GLONADI)(1..dim(WLNK1))
Endif
WNB1 = 0
Read [AWF]AWF0 = [F:AWA]CODE
For I=1 To [F:AWF]NBRSIG
 If [F:AWF]OPESIG(I-1)<>""
  For [AWAL] Where TYPEVT=9 & OPERATION=[F:AWF]OPESIG(I-1)
   WNB1 += 1
   WLNK1(WNB1) = "AWA"+[F:AWAL]CODE
   WSUP1(WNB1) = [F:AWF]ACTSIG(I-1)
  Next AWAL
 Endif
Next I
For I=1 To WNB0
 If !find(WLNK0(I),WLNK1(1..WNB1))
  Delete [ALI] Where USRCOD=GLIAISON(1) & SRCOBJ=left$(WLNK0(I),3) & SRCKEY=right$(WLNK0(I),4)
&                  & DSTOBJ="AWA" & DSTKEY=[F:AWA]CODE
 Endif
Next I
For I=1 To WNB1
 If !find(WLNK1(I),WLNK0(1..WNB0))
  Raz [F:ALI]
  [F:ALI]USRCOD = GLIAISON(1)
  [F:ALI]SRCOBJ = "AWA"
  [F:ALI]SRCKEY = [F:AWA]CODE
  [F:ALI]DSTOBJ = left$(WLNK1(I),3)
  [F:ALI]DSTKEY = right$(WLNK1(I),4)
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  Call NUMTEXLAN("Signature","FRA",[F:ALI]DSTTIT) From OBJDIV
  Call LECTEXTRA([F:ALI]DSTDES,"AWRKPAR","INTIT",right$(WLNK1(I),4),"") From ATEXTRA
  Call LECTEXTRA(BID,"ATABDIV","LNGDES","54",WSUP1(I)) From ATEXTRA
  [F:ALI]DSTDES -= "("+BID+")"
  [F:ALI]LNK    = "D"
  [F:ALI]INVFLG = 1
  [F:ALI]AUTFLG = 2
  [F:ALI]ENAFLG = 2
  [F:ALI]CREDAT = date$
  [F:ALI]CREUSR = GUSER
  Write [ALI]
 Endif
Next I
Return

#--------------------------------------------#
$VERIF_CRE
$VERIF_MOD
Local Integer D , F , T , L , S ,I
Local Char    MESSA(255) , FORMULE(255)
Local Clbfile TEXCLB(9)
Gosub SET_SEP
If [M]ENAMES=2 & !find(2,[M]ENVOI)
 Call ERREUR(mess(3,75,1)) From GESECRAN : # Un destinataire principal , au moins, est nécessaire !
 zonsui = "NBDEST"
 OK = 0 : Return
Elsif [M]ENASUI=2 & [M]FLGSIG=2 & !find(3,[M]SUIVI) & !find(2,[M]SUIVI)
 Call ERREUR(mess(62,75,1)) From GESECRAN : # Pas de destinataire pour le suivi
 zonsui = "NBDEST"
 OK = 0 : Return
Elsif [M]ENASUI=2 & find(3,[M]SUIVI) & [M]NBRSIG=0
 Call ERREUR(mess(160,75,1)) From GESECRAN : # Aucune réponse pour le suivi
 zonsui = "NBRSIG"
 OK = 0 : Return
Elsif [M]ENAACT=2 & [M]ACTION=""
 Call ERREUR(mess(84,133,1)) From GESECRAN : # Action inexistante
 zonsui = "ACTION"
 OK = 0 : Return
Elsif [M]ACTION<>"" & [M]ENAACT<>2
 Call AVERTIR(mess(150,75,1),OK) From GESECRAN : # L'exécution des actions est désactivée
 If OK<>2
  zonsui = "ENAACT"
  OK = 0 : Return
 Endif
Elsif [M:AWA3]RETOUR=2 & [M:AWA3]BAKFCT="" & [M:AWA3]BAKSYRA="" & [M:AWA3]BAKMOBILE="" & find([M]TYPEVT,5,10) # X3PLAT-1475 Workflow link on representation
 Call ERREUR(mess(209,75,1)) From GESECRAN      # # At least 1 return application must be specified
 zonsui = "RETOUR"
 OK = 0 : Return
Endif
Read [AWX]AWX0 = [M]CODE
If !fstat
 # Cet évènement est géré par une notification
 # Si vous continuez, vous allez supprimer cette notification.
 # Voulez-vous continuer ?
 OK = 1
 Call AVERTIR(mess(167,75,1)-":"-mess(205,100,1),OK) From GESECRAN
 If OK<>2 : OK = 0 : Return : Endif
Endif
TEXCLB = [M]TEXTE
While TEXCLB<>""
 D = instr(1,TEXCLB,SEP)
 If D
  F = instr(D+1,TEXCLB,SEP)
  If !F
   Call ERREUR(mess(116,75,1)) From GESECRAN : # Séparateurs mal définis dans le texte
   zonsui = "TEXTE"
   OK = 0 : Break
  Endif
  FORMULE = format$("KTv2:255X",seg$(TEXCLB,D+1,F-1))
  If toupper(FORMULE)="LIG"
   If [M]TEXLIG=""
    Call ERREUR(mess(75,75,1)) From GESECRAN : # Le texte ligne est vide
    zonsui = "TEXTE"
    OK = 0 : Break
   Else
    T = 1
   Endif
  Elsif toupper(left$(FORMULE,4))="SIG/"
   # SIG/code action/Texte à mettre devant le lien http
   K = instr(1,FORMULE,"/")
   L = instr(K+1,FORMULE,"/")
   S = 1
   MESSA = mess(164,75,1) : # Présence d'un lien http dans le message
   If !K | !L
    Call ERREUR(MESSA+"\"+mess(123,75,1)) From GESECRAN : # Lien signature mal paramétré dans le texte
    zonsui = "TEXTE"
    OK = 0 : Break
   Elsif [M]ENAMES<>2
    Call ERREUR(MESSA+"\"+mess(94,75,1)) From GESECRAN : # L'envoi de mail est désactivé
    zonsui = "ENAMES"
    OK = 0 : Break
   Elsif [M]ENASUI<>2
    Call ERREUR(MESSA+"\"+mess(95,75,1)) From GESECRAN : # Le suivi est désactivé
    zonsui = "ENASUI"
    OK = 0 : Break
   Elsif !find(toupper(seg$(FORMULE,K+1,L-1)),[M]ACTSIG)
    Call ERREUR(MESSA+"\"+toupper(seg$(FORMULE,K+1,L-1))-":"-mess(76,75,1)) From GESECRAN
    # Opération de signature inexistante
    zonsui = "TEXTE"
    OK = 0 : Break
   Endif
  Endif
  TEXCLB = right$(TEXCLB,F+1)
 Else
  Break
 Endif
Wend
If !OK : Return : Endif
Raz J , K
For I=0 To [M]NBCOND-1
 If J=0 : J = instr(1,[M]CONDITION(I),'"') : Endif
 If K=0 : K = instr(1,[M]CONDITION(I),"'") : Endif
 If J & K
  # Les caractères ' et " ne doivent pas être utilisés ensemble
  Call ERREUR(mess(105,75,1)) From GESECRAN
  zonsui = "NBCOND"
  OK = 0 : Return
 Endif
Next I
If S
 Raz K , L
 For J=1 To [M]NBDEST
  If [M]SUIVI(J-1)>1
   K = 1
  Endif
  If [M]ENVOI(J-1)>1
   L = 1
  Endif
 Next J
 If !K | !L
  Call AVERTIR(mess(78,75,1),OK) From GESECRAN : # Aucun destinataire pour la signature distante
  If OK<>2
   zonsui = "NBDEST("+num$(J-1)+")"
   OK = 0 : Return
  Endif
 Endif
Endif
If ([F:AWA]TYPMES<>[M]TYPMES | [F:AWA]JOIOBJ<>[M]JOIOBJ) & [M]JOIOBJ=2 & [M]TYPMES=3
 # Un workflow envoyé par le client ne permet de gérer qu'une seule pièce jointe
 Call AVERTIR(mess(87,75,1),OK) From GESECRAN
 If OK<>2
  zonsui = "TYPMES"
  OK = 0 : Return
 Endif
Endif
If !T & [M]TEXLIG<>""
 # Le texte ligne n'est pas inséré dans le texte principal
 Call AVERTIR(mess(120,75,1),OK) From GESECRAN
 If OK<>2
  zonsui = "TEXTE"
  OK = 0 : Return
 Endif
Endif
Return

#------------------#
$SET_SEP
Local Char SEP(1)
SEP = "|" : # Les formules à évaluer dans le clob sont entre deux caractères "|"
Return

#--------------------------------------------#
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET : # Changement de clé
If CLECUR=0 or REP="M" or !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Elsif TYPEVT=10
 CHMEN += "A" : # Workflow manuel
Endif
Return

#--------------------------------------------#
$EXEBOUT
Case BOUT
 When "V" : Call VALID(CLECUR1,nomap,0,OK) From AWRKGEN
Endcase
Return

#--------------------------------------------#
$AP_ANNULE
Call VIRE_TRT([L]CODE)
Return

#--------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AWRKPAR" & IDENT1=[L]CODE & ZONE="INTIT"
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK
Endif
Return

#--------------------------------------------#
Subprog VIRE_TRT(COD)
Value Char COD
Local Integer STAT
Local Char    FICANU(GDIMFIC)
Local Char    PREF(4)
Call SET_PREF(COD,PREF)
FICANU = filpath("TRT",PREF+COD,"src",0)
If filinfo(FICANU,0)>=0
 Call EFFACE(FICANU,STAT) From ORDSYS
Endif
Call EFFACE_ADX("","",PREF+COD,STAT) From ORDSYS
End

#-------------------------------------------------------#
Subprog SET_PREF(CODPAR,PREF)
Value    Char CODPAR
Variable Char PREF
PREF = "WMK"
End

#--------------------------------------------#
$APRES_MOD
If [M]CODE<>""
 Call VALID(CLECUR1,nomap,0,OK) From AWRKGEN
Endif
Return

$APRES_CRE
Gosub APRES_MOD
Return

#--------------------------------------------------------------------------------#
# S/Programme de vérification de la longueur des clobs
#--------------------------------------------------------------------------------#

Subprog VERF_PARAM(PARAM,LONG,OK)
Value    Char    PARAM
Value    Char    LONG
Variable Integer OK
Local Integer DIME , MAXDIM
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
OK = 1
MAXDIM = 21
If val(LONG)>MAXDIM
 GMESSAGE = func AFNC.MES(mess(115,75,1),num$(MAXDIM)) : # Valeur trop grande (maximum #)
 OK = 0 : End
Endif
Read [AMZ]CODE="AWA3";"TEXTE"
If !fstat
 Read [F:ATY]CODTYP=[F:ATZ]CODTYP
 If !fstat & [F:ATY]LNGTYP>0
  DIME = [F:ATY]LNGTYP
 Else
  DIME = [F:AMZ]LONG
 Endif
Endif
If DIME>0 & val(LONG)>DIME
 # Le champ $1$ dans l'écran $2$ est dimensionné à $3$.
 # Ce paramètre ne doit pas dépasser cette valeur
 GMESSAGE = func AFNC.MES3(mess(191,75,1)+"\"+mess(192,75,1),"TEXTE","AWA3",num$(DIME))
 OK = 0 : End
Endif
End

#----------------------------------------------------------------------------#
# Actions Sélections
#----------------------------------------------------------------------------#

$SEL_LISTE
Case LISTE
 When "ASELOPE"    : Gosub SEL_OPE
Endcase
Return

$VERF_LISTE
Case LISTE
 When "ASELOPE"    : Gosub VERF_OPE
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELEVT"     : Gosub SEL_EVT
 When "SELACTAWA"  : Gosub SEL_ACTAWA
 When "SELAWR"     : Gosub SEL_AWR
Endcase
Return

#----------------------------------------------------------------------------#
$SEL_EVT
Case PARAM(1)
 When "1"
  OBJET = "ADI"
  CRITERE = "NUMTAB=908"
  Call LECTEXTRA(TIT,"ATABTAB","LNGDES","908","") From ATEXTRA
 When "2"
  OBJET = "AOB"
  CRITERE = "TYPGES<>4"
 When "3"
  OBJET = "AFC"
  CRITERE = "TYPTRAIT=1"
 When "4"
  OBJET = "ARP"
 When "5","6"
  Local Char DOSX3(GLONADS)
  If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
  Read [ADW]ADW0 = "";"";"SUPDOS"
  DOSX3 = [F:ADW]VALEUR
  If DOSX3<>""
   Close Local File [ATX]
   Local File =DOSX3+".ATEXTE" [ATX]
  Endif
  OBJET = "ABT"
 When "7" : # Gestion des temps (Paye)
  OBJET = "TIM"
 When "8"
  OBJET = "AOE"
 When "9"
  OBJET = "AWA"
  CRITERE = "TYPEVT<>6" : # Arrêt de tâche
Endcase
Return

#----------------------------------------------------------------------------#
$SEL_ACTAWA
OBJET = "ACT"
CRITERE = "AMSFLG = 2"
Return

#----------------------------------------------------------------------------#
$SEL_AWR
OBJET = "AWR"
CRITERE = 'MODELE = "'+PARAM(1)+'"'
Return

#----------------------------------------------------------------------------#
$SEL_OPE
Local Char OVALEUR(250) , OBJET(GLONAOB)
Local Integer TYP
OBJET = PARAM(1)
TYP   = val(PARAM(2))
OVALEUR = VALEUR
Gosub DEF_OPE
Case TYP
 When 2   : TIT = mess(147,75,1) : # Choix d'un bouton/menu
 When 4,8 : TIT = mess(146,75,1) : # Choix d'une opération
 When 9   : Call LECTEXTRA(TIT,"ATABTAB","LNGDES","55","") From ATEXTRA
Endcase
Return

$VERF_OPE
Case TYP
 When 9
  If OVALEUR<>""
   If instr(1,OVALEUR,VALEUR)<>0
    VALEUR = OVALEUR
   Elsif right$(OVALEUR,len(OVALEUR))<>";"
    VALEUR = OVALEUR+";"+VALEUR
   Else
    VALEUR = OVALEUR+VALEUR
   Endif
  Endif
 When Default
  VALEUR = OVALEUR+VALEUR
Endcase
mkstat = 2
Return

$DEF_OPE
Local Char TEXTE(30)(1..200,1..2) , TIT(30)(0..2)
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
NBTEX = 0
Case TYP
 When 2
  Local Char    BID(30) , FEN(GLONFEN)
  If clalev([AWT])=0  : Local File AWINBOUT [AWT]  : Endif
  If clalev([AWT2])=0 : Local File AWINBOUT [AWT2] : Endif
  # Opérations standard possibles sur GOBJET
  NBTEX += 1 : TEX(NBTEX) = "C" : TEXTE(NBTEX,2) = mess(59,123,1)  : # Création
  NBTEX += 1 : TEX(NBTEX) = "M" : TEXTE(NBTEX,2) = mess(60,123,1)  : # Modif
  NBTEX += 1 : TEX(NBTEX) = "A" : TEXTE(NBTEX,2) = mess(53,123,1)  : # Suppression
  NBTEX += 1 : TEX(NBTEX) = "H" : TEXTE(NBTEX,2) = mess(2,115,1)   : # Changement de code
  NBTEX += 1 : TEX(NBTEX) = "E" : TEXTE(NBTEX,2) = mess(61,123,1)  : # Impression
  NBTEX += 1 : TEX(NBTEX) = "L" : TEXTE(NBTEX,2) = mess(137,124,1) : # Liste
  NBTEX += 1 : TEX(NBTEX) = "W" : TEXTE(NBTEX,2) = mess(140,75,1)  : # Bouton Workflow
  # Recherche fenêtre principale d'un objet
  Gosub SET_FENOBJ
  If FEN="" : Return : Endif
  # Boutons/menus possibles dans la fenêtre de l'objet
  For [AWT] Where WIN=FEN & find(TYPBOUT,1,3)
   If !find(right$([F:AWT]CODBOUT,len([F:AWT]CODBOUT)),TEX(1..NBTEX))
    NBTEX += 1
    TEX(NBTEX) = right$([F:AWT]CODBOUT,len([F:AWT]CODBOUT))
    If [F:AWT]TYPBOUT=3
     For I=1 To len([F:AWT]CODBOUT)-1
      For [AWT2] Where WIN=FEN & TYPBOUT=2 & CODBOUT=left$([F:AWT]CODBOUT,I)
       Call TEXTE([F:AWT2]TXTBOUT,BID) From OBJDIV
       If TEXTE(NBTEX,2)<>""
        TEXTE(NBTEX,2) += "/"
       Endif
       TEXTE(NBTEX,2) += BID
      Next AWT2
     Next I
    Endif
    If TEXTE(NBTEX,2)<>""
     TEXTE(NBTEX,2) += "/"
    Endif
    Call TEXTE([F:AWT]TXTBOUT,BID) From OBJDIV
    TEXTE(NBTEX,2) += BID
   Endif
  Next AWT
 When 4 : # Opérations possibles sur état
  NBTEX += 1 : TEX(NBTEX) = "C" : TEXTE(NBTEX,2) = mess(61,123,1)  : # Impression
  NBTEX += 1 : TEX(NBTEX) = "P" : TEXTE(NBTEX,2) = mess(118,124,1) : # Pièces jointes
 When 8 : # Opérations possibles sur Import/export
  NBTEX += 1 : TEX(NBTEX) = "E" : TEXTE(NBTEX,2) = mess(142,141,1) : # Export
  NBTEX += 1 : TEX(NBTEX) = "I" : TEXTE(NBTEX,2) = mess(143,141,1) : # Import
  NBTEX += 1 : TEX(NBTEX) = "D" : TEXTE(NBTEX,2) = mess(144,141,1) : # Début
  NBTEX += 1 : TEX(NBTEX) = "F" : TEXTE(NBTEX,2) = mess(65,123,1)  : # Fin
 When 9 : # Opérations signatures
  For [ADI] Where NUMTAB=55
   NBTEX += 1
   TEX(NBTEX) = [F:ADI]CODE
   Call LECTEXTRA(TEXTE(NBTEX,2),"ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From ATEXTRA
  Next ADI
Endcase
Return

#-----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AWRKPAR  [AWA1]
 Local File AWRKPARF [AWF1]
 Local File AWRKPARH [AWH1]
 Local File AWRKPARC [AWC1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".AWRKPAR"  [AWA1]
 Local File =[M]DOSORG+".AWRKPARF" [AWF1]
 Local File =[M]DOSORG+".AWRKPARH" [AWH1]
 Local File =[M]DOSORG+".AWRKPARC" [AWC1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AWRKPAR  [AWA2]
 Local File AWRKPARF [AWF2]
 Local File AWRKPARH [AWH2]
 Local File AWRKPARC [AWC2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".AWRKPAR"  [AWA2]
 Local File =[M]DOSDES+".AWRKPARF" [AWF2]
 Local File =[M]DOSDES+".AWRKPARH" [AWH2]
 Local File =[M]DOSDES+".AWRKPARC" [AWC2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
OK = 1
If GTRACE=""
 Read [AWA2]AWA0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AWA1] , [AWF1] , [AWH1] , [AWC1] , [AWA2] , [AWF2] , [AWH2] , [AWC2] , [AXX1] , [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [AWA2]
 Delete [AWA2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWKRPAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWA2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AWF2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWKRPARF" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWF2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AWH2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWKRPARH" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWH2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AWC2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWKRPARC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWC2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AWA1]AWA0 Where CODE=TABLE
  [F:AWA2] = [F:AWA1]
  Call COPTEXTRA("AWRKPAR","INTIT",TABLE,"") From ATEXTRA
  If dim([F:AWA2]UPDUSR)>0 : [F:AWA2]UPDUSR = GUSER : Endif
  If dim([F:AWA2]UPDDAT)>0 : [F:AWA2]UPDDAT = date$ : Endif
  Write [AWA2]
  If fstat
   GOK=0 : Call FSTA("AWA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AWF1]AWF0 Where CODE=TABLE
  [F:AWF2] = [F:AWF1]
  Write [AWF2]
  If fstat
   GOK=0 : Call FSTA("AWF2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AWH1]AWH0 Where CODE=TABLE
  [F:AWH2] = [F:AWH1]
  Write [AWH2]
  If fstat
   GOK=0 : Call FSTA("AWH2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AWC1]AWC0 Where CODE=TABLE
  [F:AWC2] = [F:AWC1]
  Write [AWC2]
  If fstat
   GOK=0 : Call FSTA("AWC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------#
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------#
# Appelé en validation dossier
#------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK
If clalev([F:AWA2])=0 : Local File =APPLI+".AWRKPAR"   [AWA2] : Endif
If clalev([F:AWA])=0  : Local File =APPLI+".AWRKPAR"   [AWA]  : Endif
If clalev([F:AWF])=0  : Local File =APPLI+".AWRKPARF"  [AWF]  : Endif
If clalev([F:AWC])=0  : Local File =APPLI+".AWRKPARC"  [AWC]  : Endif
If clalev([F:AWM])=0  : Local File =APPLI+".AWRKLNK"   [AWM]  : Endif
If clalev([F:AWK])=0  : Local File =APPLI+".AWRKTAB"   [AWK]  : Endif
If clalev([F:AWR])=0  : Local File =APPLI+".AWRKREG"   [AWR]  : Endif
If clalev([F:AOB])=0  : Local File =APPLI+".AOBJET"    [AOB]  : Endif
If clalev([F:ATB])=0  : Local File =APPLI+".ATABLE"    [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =APPLI+".ATABZON"   [ATZ]  : Endif
If clalev([F:ATI])=0  : Local File =APPLI+".ATABIND"   [ATI]  : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"     [ATY]  : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"   [AMP]  : Endif
If clalev([F:ANX])=0  : Local File =APPLI+".AINDEX"    [ANX]  : Endif
If clalev([F:ACT])=0  : Local File =APPLI+".ACTION"    [ACT]  : Endif
If clalev([F:AAR])=0  : Local File =APPLI+".ACTCODPAR" [AAR]  : Endif
If clalev([F:ATR])=0  : Local File =APPLI+".ACTPAR"    [ATR]  : Endif
If clalev([F:AFC])=0  : Local File =APPLI+".AFONCTION" [AFC]  : Endif
For [AWA2]AWA0
 Call ECR_TRACE([F:AWA2]CODE,0) From GESECRAN
 Call VALID([F:AWA2]CODE,APPLI,1,OK) From AWRKGEN
Next AWA2
End

#-----------------------------------------------------------
#         EVENEMENTS ECRANS AWA0,1,2,3,4,5
#-----------------------------------------------------------

# AWA1
#-----------------------------------------------------------

Subprog AS_TYPEVT(VALEUR)
Variable Integer    VALEUR()
If GPRODUIT<>2
 GMENLOC(7) = 1
Endif
End

Subprog C_TYPEVT(VALEUR)
Variable Integer    VALEUR()
[M]TYPEVT = VALEUR
Gosub GRISE_EVT
Gosub GRISE_MOD
Gosub GRISE_REG
Gosub GRISE_TYP
Gosub GRISE_JOI
Gosub GRISE_ACT
Gosub GRISE_RET
Gosub GRISE_REQ
Gosub GRISE_SIG
End

Subprog IB_CODEVT
GBOUT1 = ""
Case [M]TYPEVT
 When 1   : Call LECTEXTRA(GBOUT1,"ATABTAB","LNGDES","908","") From ATEXTRA
 When 2   : GBOUT1 = mess(18,125,1) : # Objet
 When 3   : GBOUT1 = mess(21,125,1) : # Fonction
 When 4   : GBOUT1 = mess(22,125,1) : # Etat
 When 5,6 : GBOUT1 = mess(92,134,1) : # Tâches
 When 7   : GBOUT1 = mess(5,230,1)  : # Temps
 When 8   : GBOUT1 = mess(26,141,1) : # Modèles
 When 9   : Call LECTEXTRA(GBOUT1,"ATABTAB","LNGDES","55","") From ATEXTRA
Endcase
End

Subprog B1_CODEVT(VALEUR)
Variable Char    VALEUR()
Local Char OBJET(GLONAOB) , SUPP(10)
Case [M]TYPEVT
 When 1   : OBJET = "ADI" : SUPP = "908" : # Divers
 When 2   : OBJET = "AOB" : SUPP = ""    : # Objet
 When 3   : OBJET = "AFC" : SUPP = ""    : # Fonction
 When 4   : OBJET = "ARP" : SUPP = ""    : # Etat
 When 5,6 : OBJET = "ABT" : SUPP = ""    : # Tâches
 When 7   : OBJET = "TIM" : SUPP = ""    : # Temps
 When 8   : OBJET = "AOE" : SUPP = ""    : # Modèles
 When 9   : OBJET = "ADI" : SUPP = "55"  : # Divers
Endcase
Call OBJET_CHAR(VALEUR,OBJET,SUPP) From GOBJET
End

Subprog C_CODEVT(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Case [M]TYPEVT
 When 1 : # Divers
  Read [ADI]CODE = 908;VALEUR
  If fstat
   GMESSAGE = mess(160,123,1) : # Evénement inexistant
   mkstat = 2 : End
  Endif
 When 2 : # Objet
  If find(VALEUR,"AWM","AWR","AWV","AWO","AWA","ANM")
   GMESSAGE = VALEUR-mess(207,126,1) : # Objet interdit dans cette fonction
   mkstat = 2 : End
  Elsif VALEUR<>""
   Read [AOB]ABREV = VALEUR
   If fstat
    Call CONTSEL("AOB","",VALEUR,"",mkstat) From CONTOBJ
   Elsif [F:AOB]TYPGES=4
    GMESSAGE = VALEUR-mess(207,126,1) : # Objet interdit dans cette fonction
    mkstat = 2 : End
   Endif
  Endif
 When 3 : # Fonction
  If VALEUR<>""
   Read [AFC]CODINT = VALEUR
   If fstat | [F:AFC]TYPTRAIT<>1
    Call CONTSEL("AFC","T",VALEUR,"",mkstat) From CONTOBJ
   Endif
  Endif
 When 4 : # Etat
  If VALEUR<>""
   Read [ARP]ARP0 = VALEUR
   If fstat
    Call CONTSEL("ARP","",VALEUR,"",mkstat) From CONTOBJ
   Endif
  Endif
 When 5, 6 : # Batch, Abort
  If VALEUR<>""
   Read [ABT]CODTAC = VALEUR
   If fstat
    Call CONTSEL("ABT","",VALEUR,"",mkstat) From CONTOBJ
   Elsif [F:ABT]MESSAGE<>2
    # L'option message utilisateur n'est pas activée sur cette tâche
    Call AVERTIR(mess(60,139,1),OK) From GESECRAN
    If OK<>2 : mkstat = 2 : End : Endif
   Endif
  Endif
 When 7 : # Temps
  #CHECK UNUSED_BEGIN
  If GPRODUIT=2
   If VALEUR=""
    GMESSAGE = mess(10,123,1) : # Zone obligatoire
    mkstat = 2 : End
   Else
    If clalev([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
    Read [TIM]TIM0 = VALEUR
    If fstat
     Call CONTSEL("TIM","",VALEUR,"",mkstat) From CONTOBJ
    Endif
   Endif
  Endif
  #CHECK UNUSED_END
 When 8 : # Import/export
  If VALEUR<>""
   Read [AOE]AOE0 = VALEUR
   If fstat
    Call CONTSEL("AOE","",VALEUR,"",mkstat) From CONTOBJ
   Endif
  Endif
 When 9 : # Signature
  If VALEUR<>""
   Read [AWA]AWA0 = VALEUR
   If fstat
    Call CONTSEL("AWA","",VALEUR,"",mkstat) From CONTOBJ
   Elsif [F:AWA]TYPEVT=6 : # Arrêt de tâche
    GMESSAGE = mess([F:AWA]TYPEVT,988,1)-":"-mess(145,75,1) : # Type de règle workflow incorrect
    mkstat = 2 : End
   Endif
  Endif
Endcase
End

Subprog AP_CODEVT(VALEUR)
Variable Char    VALEUR()
[M:AWA1]CODEVT = VALEUR
Gosub CHARGE_HLP
Gosub CHARGE_LIBEVT
End

Subprog C_OPERATION(VALEUR)
Variable Char    VALEUR()
Local Integer I , NBTEX , TYP
Local Char    TEX(15)(60)
Local Char    OBJET(20) , BID(1) , CHAINE(250) , COD(GLONADI)
OBJET = [M]CODEVT
TYP   = [M]TYPEVT
Case TYP
 When 2
  If VALEUR=""
   GMESSAGE = mess(32,75,1) : # Il faut renseigner au moins une opération ou un bouton
   mkstat = 2 : End
  Endif
 When 8
  If VALEUR=""
   GMESSAGE = mess(10,123,1) : # Zone obligatoire
   mkstat = 2 : End
  Elsif !instr(1,VALEUR,"E") & !instr(1,VALEUR,"I")
   GMESSAGE = mess(142,141,1)-","-mess(143,141,1)-"?"
   mkstat = 2 : End
  Elsif !instr(1,VALEUR,"D") & !instr(1,VALEUR,"F")
   GMESSAGE = mess(144,141,1)-","-mess(65,123,1)-"?"
   mkstat = 2 : End
  Endif
 When 9
  If VALEUR=""
   GMESSAGE = mess(10,123,1) : # Zone obligatoire
   mkstat = 2 : End
  Endif
Endcase
Gosub DEF_OPE
Case TYP
 When 2 , 4 , 8
  For I=1 To len(VALEUR)
   BID = mid$(VALEUR,I,1)
   If !find(BID,TEX(1..NBTEX))
    GMESSAGE = BID-":"-mess(58,123,1) : # Opération incorrecte
    mkstat = 2 : Break
   Elsif instr(1,left$(VALEUR,I-1),BID)
    GMESSAGE = BID-":"-mess(87,123,1) : # Paramètre déjà existant
    mkstat = 2 : Break
   Endif
  Next I
  If mkstat : End : Endif
 When 9
  CHAINE = VALEUR
  While CHAINE<>""
   I = instr(1,CHAINE,";")
   If I
    COD = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    COD = CHAINE
    CHAINE = ""
   Endif
   Read [ADI]CODE = 55;COD
   If fstat
    GMESSAGE = COD-":"-mess(144,75,1) : # Opération inexistante
    mkstat = 2 : End
   Endif
  Wend
Endcase
[M]OPERATION = VALEUR
Gosub GRISE_OPE
End

Subprog C_MODELE(VALEUR)
Variable Char    VALEUR()
Local Shortint DIMNIV : DIMNIV = 30
Local Char     TAB1(GLONATB+1+GLONABR)(1..DIMNIV) , TAB2(GLONATB+1+GLONABR)(1..DIMNIV) , TAB3(GLONATB+1+GLONABR)(1..DIMNIV)
Local Char     ABR1(GLONABR)(1..DIMNIV) , ABR2(GLONABR)(1..DIMNIV) , ABR3(GLONABR)(1..DIMNIV)
Local Integer  BRA2(1..DIMNIV) , BRA3(1..DIMNIV) , P2 , P3
Local Integer  NB1 , NB2 , NB3
Local Integer  OK
If [M]TYPEVT=10 : # Manuel
 If VALEUR=""
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 2 : End
 Endif
 Call RECHERCHE_NIVEAU(TAB1,TAB2,TAB3,BRA2,BRA3,NB1,NB2,NB3,GMESSAGE,OK) From SUBAWR
 If !OK
  mkstat = 2 : End
 Elsif NB2>0 or NB3>0
  # Ce modèle est incompatible avec le type d'évènement
  GMESSAGE = VALEUR-':'-mess(162,75,1)-'"'+mess([M]TYPEVT,988,1)+'" ('+mess(2716,200,1)-mess(2,2916,1)+')'
  mkstat = 2 : End
 Endif
Endif
[M]MODELE = VALEUR
Gosub GRISE_REG
End

Subprog B1_REGLE(VALEUR)
Variable Char    VALEUR()
Read [AWR]AWR1(1) = VALEUR
If !fstat
 Call OBJET_CHAR(VALEUR,"AWR",[F:AWR]CPY) From GOBJET
Else
 Call OBJET_CHAR(VALEUR,"AWR","") From GOBJET
Endif
End

Subprog B2_REGLE(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(30)
Read [AWV]AWV0(1) = VALEUR
If !fstat
 Call OBJET_CHAR([F:AWV]CPY,"AWV",VALEUR) From GOBJET
Else
 Call OBJET_CHAR(PARAM,"AWV",VALEUR) From GOBJET
Endif
End

Subprog C_REGLE(VALEUR)
Variable Char    VALEUR()
Local Integer DROIT
If VALEUR<>""
 DROIT = 1
 Read [AWR]AWR1(1) = VALEUR
 If fstat
  GMESSAGE = VALEUR-mess(104,75,1) : # Règle inexistante
  mkstat = 2 : End
 Else
  Read [AWM]AWM0 = [M:AWA1]MODELE
  If !fstat
   If [F:AWM]FLDCPY="" and [F:AWM]FLDFCY=""
    Read [AWR]AWR0 = VALEUR;""
    If !fstat & [F:AWR]ACS<>""
     Read [ACC]CODACC = GUSER;[F:AWR]ACS
     If fstat or [F:ACC]EXEC<>2
      DROIT = 0
     Endif
    Endif
   Else
    For [AWR]AWR0 Where REGLE = VALEUR
     If [F:AWR]ACS<>""
      Read [ACC]CODACC = GUSER;[F:AWR]ACS
      If fstat or [F:ACC]EXEC<>2
       DROIT = 0 : Break
      Endif
     Endif
    Next AWR
   Endif
  Endif
 Endif
 If !DROIT
  GMESSAGE = [F:AWR]ACS-":"-mess(59,133,1) : # Droits d'exécution non attribués pour ce code d'accès
  mkstat = 2 : End
 Endif
Endif
If [M]TYPEVT<>9 & VALEUR<>"" : # Signature
 Read [AWR]AWR1(1) = VALEUR
 If [F:AWR]MODELE<>[M]MODELE
  GMESSAGE = mess(141,75,1)-[F:AWR]MODELE : # Cette règle ne fonctionne qu'avec le modèle
  mkstat = 2 : End
 Endif
Endif
[M]REGLE = VALEUR
Gosub GRISE_TYP
End

Subprog AS_TYPWRK(VALEUR)
Variable Integer  VALEUR
GMENLOC(1) = 1
End

Subprog C_TYPWRK(VALEUR)
Variable Integer  VALEUR
[M]TYPWRK = VALEUR
Gosub GRISE_GRP
End

Subprog AS_TABLIG(VALEUR)
Variable Char  VALEUR
Local Integer I , NB
Gosub SET_MODELE
Raz [M:AWA1]ABRFIL , TABFIL , NB
If [F:AWM]MODELE<>""
 For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & (TYPLNK=2 or TYPLNK=4) & TYPTAB<1 : # Lien 0,n/1,n
  [M:AWA1]TABFIL(NB) = [F:AWK]TABLNK
  [M:AWA1]ABRFIL(NB) = [F:AWK]ABRLNK
  NB += 1
 Next I
Endif
End

$SET_MODELE
Raz [F:AWM]
If [M]REGLE<>""
 Read [AWR]AWR1(1) = [M]REGLE
 Read [AWM]AWM0 = [F:AWR]MODELE
Elsif [M]MODELE<>""
 Read [AWM]AWM0 = [M]MODELE
Endif
Return

Subprog C_TABLIG(VALEUR)
Variable Char  VALEUR
If VALEUR="" : End : Endif
Local Integer I
Gosub SET_MODELE
If VALEUR=[F:AWM]TABREF
 GMESSAGE = mess(98,139,1) : # Type de lien incorrect
 mkstat = 2 : End
Endif
For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & TABLNK=VALEUR & TYPTAB<1
 If !find([F:AWK]TYPLNK,2,4)
  GMESSAGE = mess(98,139,1) : # Type de lien incorrect
  mkstat = 2 : Break
 Elsif !find(VALEUR,[M]TABFIL)
  GMESSAGE = mess(93,139,1) : # Table non référencée
  mkstat = 2 : Break
 Endif
Next
End

Subprog C_ABRLIG(VALEUR)
Variable Char    VALEUR()
If [M]TABLIG<>""
 Local Char MESSAGE(250)
 Gosub SET_MODELE
 Call VERIF_ABREV([M]MODELE,[M]TABLIG,VALEUR,MESSAGE) From SUBAWR
 If MESSAGE<>""
  GMESSAGE = MESSAGE
  mkstat =2 : End
 Endif
Endif
End

Subprog AS_ABRLIG(VALEUR)
Variable Char    VALEUR()
If [M]TABLIG=[F:AWM]TABREF : VALEUR = "" : mkstat = 2 : Endif
End

Subprog AS_GROUPE(VALEUR)
Variable Char  VALEUR
Local Integer  I , J , K , NB , OK
Local Shortint DIMNIV : DIMNIV = 30
Local Char     TAB1(GLONATB+1+GLONABR)(1..DIMNIV) , TAB2(GLONATB+1+GLONABR)(1..DIMNIV) , TAB3(GLONATB+1+GLONABR)(1..DIMNIV)
Local Integer  BRA2(1..DIMNIV) , BRA3(1..DIMNIV)
Local Integer  NB1 , NB2 , NB3 , P2 , P3
Local Char     TABLIG(GLONATB+1+GLONABR)
Local Char     MESSA(250)
Gosub SET_MODELE
Call RECHERCHE_NIVEAU(TAB1,TAB2,TAB3,BRA2,BRA3,NB1,NB2,NB3,MESSA,OK) From SUBAWR
If !OK : End : Endif
Raz [M]TABFIL, ABRFIL, NB
Raz P2 , P3
[L]TABLIG = [M]TABLIG
If [M]ABRLIG<>""
 [L]TABLIG += "~"+[M]ABRLIG
Elsif [L]TABLIG<>""
 Read [ATB]CODFIC=[L]TABLIG
 [L]TABLIG += "~"+[F:ATB]ABRFIC
Endif
If [L]TABLIG<>""
 P3 = find([L]TABLIG,TAB3)
 If P3<>0
  P2 = find(BRA3(P3),BRA2)
 Else
  P2 = find([L]TABLIG,TAB2)
 Endif
Endif
If P3>0 : # Il y a un niveau 3
 For I=1 To NB3
  If BRA3(I)=BRA3(P3)
   K = instr(1,TAB3(I),"~")
   If K
    [M]TABFIL(NB) = left$(TAB3(I),K-1)
    [M]ABRFIL(NB) = right$(TAB3(I),K+1)
   Else
    [M]TABFIL(NB) = TAB3(I)
   Endif
   NB += 1
  Endif
 Next I
 For I=1 To NB2
  If BRA2(I)=BRA3(P3)
   K = instr(1,TAB2(I),"~")
   If K
    [M]TABFIL(NB) = left$(TAB2(I),K-1)
    [M]ABRFIL(NB) = right$(TAB2(I),K+1)
   Else
    [M]TABFIL(NB) = TAB2(I)
   Endif
   NB += 1
  Endif
 Next I
Elsif P2>0 : # Il y a un niveau 2
 If !find(BRA2(P2),BRA2(P2+1,dim(BRA2))) : # Il n'y a qu'une table dans ce niveau
  K = instr(1,TAB2(P2),"~")
  If K
   [M]TABFIL(NB) = left$(TAB2(P2),K-1)
   [M]ABRFIL(NB) = right$(TAB2(P2),K+1)
  Else
   [M]TABFIL(NB) = TAB2(P2)
  Endif
  NB += 1
 Else
  For I=1 To NB2
   If BRA2(I)=BRA2(P2)
    K = instr(1,TAB2(I),"~")
    If K
     [M]TABFIL(NB) = left$(TAB2(I),K-1)
     [M]ABRFIL(NB) = left$(TAB2(I),K+1)
    Else
     [M]TABFIL(NB) = TAB2(I)
    Endif
    NB += 1
   Endif
  Next I
 Endif
Elsif [M]TYPEVT=10
 For I=1 To NB1
  NB += 1
  K = instr(1,TAB1(I),"~")
  If K
   [M]TABFIL(NB) = left$(TAB1(I),K-1)
   [M]ABRFIL(NB) = right$(TAB1(I),K+1)
  Else
   [M]TABFIL(NB) = TAB1(I)
  Endif
 Next I
Endif
For I=1 To NB
 If [M]TABFIL(I)=[F:AWM]TABREF
  Read [ATB]CODFIC = [F:AWM]TABREF
  [M]ABRFIL(I) = [F:ATB]ABRFIC
 Else
  For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & TABLNK=[M]TABFIL(I) & TYPTAB<1
   If [F:AWK]ABRLNK<>""
    [M]ABRFIL(I) = [F:AWK]ABRLNK
   Else
    Read [ATB]CODFIC = [F:AWK]TABLNK
    [M]ABRFIL(I) = [F:ATB]ABRFIC
   Endif
   Break
  Next
 Endif
Next I
Gosub CHARGE_HLP
End

Subprog AS_TYPCND(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
