Subprog S_TEXTE(VALEUR)
Variable Clbfile VALEUR
Local Integer I , J , K , POS , MAXLIG , NBCAR
Local Char    PARMSK(250)(1..20) , VALMSK(250) , SAVACT(20)
POS = ctxinfo(0)
If POS=0 : POS = len(VALEUR)+1 : Endif
SAVACT = GACTION : GACTION = "SELFLDTAB2"
PARMSK(1) = "[M:AWA1]TABFIL"
PARMSK(2) = "[M:AWA1]ABRFIL"
Call S_TAB_CHAR(VALMSK,PARMSK,"SELFLDTAB2","LNKSUB","") From GACTION
GACTION = SAVACT
VALEUR = left$(VALEUR,POS-1)+VALMSK+right$(VALEUR,POS)
[M]TEXTE = VALEUR
Affzo TEXTE
zonsui = "TEXTE"
End

