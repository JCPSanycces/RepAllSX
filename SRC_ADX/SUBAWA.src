Call B1_FORMULE(VALMSK,"=[M:AWA1]HLPFOR","[L]WRK","","","") From AFORMULE
GACTION = SAVACT
VALEUR = left$(VALEUR,POS-1)+VALMSK+right$(VALEUR,POS)
[M]TEXTE = VALEUR
Affzo TEXTE
zonsui = "TEXTE"
End

