Subprog AS_FLDMAJ(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_TABREF
End

$CHARGE_TABREF
Local Integer  I , J , K , OK , NB
Local Shortint DIMNIV : DIMNIV = 30
Local Char     TAB1(GLONATB+1+GLONABR)(1..DIMNIV) , TAB2(GLONATB+1+GLONABR)(1..DIMNIV) , TAB3(GLONATB+1+GLONABR)(1..DIMNIV)
Local Integer  BRA2(1..DIMNIV) , BRA3(1..DIMNIV)
Local Integer  NB1 , NB2 , NB3
Local Char     MESSA(250)
Gosub SET_MODELE
Call RECHERCHE_NIVEAU(TAB1,TAB2,TAB3,BRA2,BRA3,NB1,NB2,NB3,MESSA,OK) From SUBAWR
If !OK : Return : Endif
Raz [M]TABFIL , ABRFIL , NB
For I=1 To NB1
 K = instr(1,TAB1(I),"~")
 [M]TABFIL(NB) = left$(TAB1(I),K-1)
 [M]ABRFIL(NB) = right$(TAB1(I),K+1)
 NB += 1
Next I
For I=1 To NB2
 If BRA2(I)=1
  K = instr(1,TAB2(I),"~")
  [M]TABFIL(NB) = left$(TAB2(I),K-1)
  [M]ABRFIL(NB) = right$(TAB2(I),K+1)
  NB += 1
 Endif
Next I
For I=1 To NB3
 If BRA3(I)=1
  K = instr(1,TAB3(I),"~")
  [M]TABFIL(NB) = left$(TAB1(I),K-1)
  [M]ABRFIL(NB) = right$(TAB1(I),K+1)
  NB += 1
 Endif
Next I
Raz [M]HLPFOR
For I=1 To NB
 [M]HLPFOR(I-1) = "[F:"+[M]ABRFIL(I-1)+"]"+[M]TABFIL(I-1)
Next I
Return

Subprog C_FLDMAJ(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | [M]TYPEVT=9 | instr(1,VALEUR,"[V]") or instr(1,VALEUR,"[L]")
 End
Elsif !instr(1,VALEUR,"]")
 Call ERREUR(mess(122,75,1)) From GESECRAN : # Il faut préciser l'abréviation de la table
 mkstat = 1 : End
Endif
Call CONTROLE_FLD([M]TABFIL,[M]ABRFIL,VALEUR) From LNKSUB
If !mkstat
 [M]FLDMAJ(nolign-1) = VALEUR
Endif
End

