 [M]CPAR(([M]NPAR-1)*DIMPAR+I-1) = ""
 [M]VPAR(([M]NPAR-1)*DIMPAR+I-1) = ""
Next I
For I=1 To [M]NBPAR
 [M]CPAR(([M]NPAR-1)*DIMPAR+I-1) = [M]PARAM(I-1)
 [M]VPAR(([M]NPAR-1)*DIMPAR+I-1) = [M]PARVAL(I-1)
Next I
End

