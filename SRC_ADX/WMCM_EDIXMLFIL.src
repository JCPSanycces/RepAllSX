#<AdxTL>@(#)0.0.0.0 $Revision$Class XML files
# Supervisor
## ACLA-CLASSE ## EDIXMLFIL
# 2018-11-06 07:05:17 150

#-------------------------------------------------------#
$METHODS
$EVENTS
Case [L]AEVENT
 When "ADDLINE_AFTER"
  Case [L]CURPTH
   When "EXFD"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD")
    this.MSGCOD = this.APARENT.MSGCOD
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGREL","$namProParent","MSGREL")
    this.MSGREL = this.APARENT.MSGREL
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR")
    this.MSGFILNOR = this.APARENT.MSGFILNOR
   When "EXSD"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD")
    this.MSGCOD = this.APARENT.MSGCOD
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGREL","$namProParent","MSGREL")
    this.MSGREL = this.APARENT.MSGREL
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR")
    this.MSGFILNOR = this.APARENT.MSGFILNOR
   When "EXFF"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD")
    this.MSGCOD = this.APARENT.MSGCOD
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGREL","$namProParent","MSGREL")
    this.MSGREL = this.APARENT.MSGREL
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR")
    this.MSGFILNOR = this.APARENT.MSGFILNOR
   When Default
  Endcase
 When Default
Endcase
Return

#-------------------------------------------------------#
$PROPERTIES
Local Integer ALINE
Case [L]CURPRO
 When "MSGCOD" : Gosub PRO_MSGCOD
 When "MSGREL" : Gosub PRO_MSGREL
 When "MSGFILNOR" : Gosub PRO_MSGFILNOR
Endcase
Return

#-------------------------------------------------------#
$PRO_MSGCOD
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.EXFD)
   If this.EXFD([L]ALINE)<>null
    this.EXFD([L]ALINE).MSGCOD = this.MSGCOD
   Endif
  Next
  For ALINE=1 to maxtab(this.EXSD)
   If this.EXSD([L]ALINE)<>null
    this.EXSD([L]ALINE).MSGCOD = this.MSGCOD
   Endif
  Next
  For ALINE=1 to maxtab(this.EXFF)
   If this.EXFF([L]ALINE)<>null
    this.EXFF([L]ALINE).MSGCOD = this.MSGCOD
   Endif
  Next
Endcase
Return

#-------------------------------------------------------#
$PRO_MSGREL
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.EXFD)
   If this.EXFD([L]ALINE)<>null
    this.EXFD([L]ALINE).MSGREL = this.MSGREL
   Endif
  Next
  For ALINE=1 to maxtab(this.EXSD)
   If this.EXSD([L]ALINE)<>null
    this.EXSD([L]ALINE).MSGREL = this.MSGREL
   Endif
  Next
  For ALINE=1 to maxtab(this.EXFF)
   If this.EXFF([L]ALINE)<>null
    this.EXFF([L]ALINE).MSGREL = this.MSGREL
   Endif
  Next
Endcase
Return

#-------------------------------------------------------#
$PRO_MSGFILNOR
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.EXFD)
   If this.EXFD([L]ALINE)<>null
    this.EXFD([L]ALINE).MSGFILNOR = this.MSGFILNOR
   Endif
  Next
  For ALINE=1 to maxtab(this.EXSD)
   If this.EXSD([L]ALINE)<>null
    this.EXSD([L]ALINE).MSGFILNOR = this.MSGFILNOR
   Endif
  Next
  For ALINE=1 to maxtab(this.EXFF)
   If this.EXFF([L]ALINE)<>null
    this.EXFF([L]ALINE).MSGFILNOR = this.MSGFILNOR
   Endif
  Next
Endcase
Return



