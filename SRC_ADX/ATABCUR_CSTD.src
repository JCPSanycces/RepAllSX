#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# CLASS ATABCUR - Currencies
##########################################################################################################

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_BEFORE"             : Gosub AINSERT_BEFORE
      When "AUPDATE_BEFORE"             : Gosub AUPDATE_BEFORE
      When "AREAD_AFTER"                : Gosub AREAD_AFTER
    Endcase
  When "COLTCH"
    Case [L]AEVENT
      When "ADDLINE_BEFORE"             : Gosub COLTCH_ADDLINE_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return







$COLTCH_ADDLINE_BEFORE

  #this.COLTCH(ALINE).CHRSTRDAT=date$

Return


##########################################################################################################
# Read After
##########################################################################################################
$AREAD_AFTER
Gosub TRANS_COLUMN_CLASS
Return

##########################################################################################################
$AINSERT_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

##########################################################################################################
$AUPDATE_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

##########################################################################################################
# Read - Transfer from column to class
##########################################################################################################
$TRANS_COLUMN_CLASS
Local Integer ILINE

this.FMT1 = val(this.CURFMT1)
this.FMT2 = val(this.CURFMT2)
this.FMT3 = val(this.CURFMT3)

Local File TABCHANGE [TCH]
Filter [TCH] Where CURDEN=this.CUR Order By Key TMPKEY=CUR Asc;CHGTYP Asc;CHGSTRDAT Desc
For [TCH]TMPKEY(2)
  ILINE = fmet this.ADDLINE("COLTCH",[V]CST_ALASTPOS)
  SetInstance this.COLTCH(ILINE) With [F:TCH]
  this.COLTCH(ILINE).ASTALIN   = [V]CST_AOK
  this.COLTCH(ILINE).EQUAL     = "="
  this.COLTCH(ILINE).CURDENSYM = this.CURSYM
  this.COLTCH(ILINE).CURSYM    = fmet this.ACTX.ACACHE.ACUR.AGETVALCHAR(this.COLTCH(ILINE).CUR,"CURSYM")
Next
Filter [TCH]
Return

##########################################################################################################
# Insert & Update - Transfer from class to column
##########################################################################################################
$TRANS_CLASS_COLUMN
this.CURFMT1 = num$(this.FMT1)
this.CURFMT2 = num$(this.FMT2)
this.CURFMT3 = num$(this.FMT3)
Return

