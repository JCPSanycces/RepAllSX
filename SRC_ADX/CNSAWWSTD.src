#<AdxTL>@(#)12.0.0.0 $Revision$ Consultation AWW
Raz GPILOBJ,GNBMASKOUV,GMESSAGE
Local Char PARAM(10)(1..7)
PARAM(1) = "1"
PARAM(2) = "MB"
#PARAM(3) = "20090501"
#PARAM(4) = "20090530"
PARAM(3) = nday$(nday(date$)-30)
PARAM(4) = date$
PARAM(5) = ""
GCONSULT = 0
Call GCONSULT("AWW","STD",PARAM) From GCONSULT
End

#-----------------------#
$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "FIN_CRIT"   : Gosub FIN_CRIT
Endcase
Return

#-----------------------#
$AUTORIS
If filinfo(filpath("FIL","AWRKHISSUI","fde"),0)<=0
 OK = 0 : Return
Endif
Return

#-----------------------#
$OUVRE
If clalev([F:ACN])=0 : Local File ACONSULT   [ACN] : Endif
If clalev([F:AWW])=0 : Local File AWRKTRN    [AWW] : Endif
If clalev([F:AWD])=0 : Local File AWRKTRND   [AWD] : Endif
If clalev([F:AWF])=0 : Local File AWRKPARF   [AWF] : Endif
If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
If clalev([F:AWG])=0 : Local File AWRKHISMES [AWG] : Endif
If clalev([F:AWO])=0 : Local File AWRKHISDES [AWO] : Endif
If clalev([F:AWU])=0 : Local File AWRKUSR    [AWU] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AOB])=0 : Local File AOBJET     [AOB] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif

Local Char    CRITENT(250)(1..3) , CRITSUI(250) , WCHRONO(GLONVCR) , WDEST(GLONAUS) , NBRDAY(10)
Local Char    FILTSAI(250)
Local Integer ICRIT , MAXLIG , DELEXP , DEBUT

MAXLIG = dim([M:CAW2]CHRONO)
DEBUT = 1

Gosub DEFCRIT

# Init periode
If [M:CAW1]DATDEB=[0/0/0] & [M:CAW1]DATFIN=[0/0/0] 
 Call PARAMUTIL("WRKDAY",NBRDAY,GUSER,"") From SUBAUS
 [M:CAW1]DATDEB = date$-val(NBRDAY)
 [M:CAW1]DATFIN = date$
Endif

# Droits
Call DROITSITE("",[M:CAW1]AUZ,OK) From EXEFNC
If !OK : FIN = 1 : Return : Endif
Raz [M:CAW1]TABDEL
I = 0
For [AWU] Where TYPDEL=3 & USRDEL=GUSER
 If !find([F:AWU]USER+"~"+[F:AWU]NATURE,[M:CAW1]TABDEL(0..I-1))
  If I<dim([M:CAW1]TABDEL)
   I += 1
   [M:CAW1]TABDEL(I-1) = [F:AWU]USER+"~"+[F:AWU]NATURE
  Endif
 Endif
Next AWU
[M:CAW1]NBRDEL = I
[M:CAW1]DELEXP = 1

Return

#---------------------------#
$GRISE_USR
If instr(1,dbgstr(1),"[CAWW]")
 If !instr(1,[M:CAW1]AUZ,"U") and [M:CAWW]DELEXP<>2
  [M:CAWW]USER  = GUSER
  Affzo [CAWW]USER
  Diszo [CAWW]USER
 Else
  Actzo [CAWW]USER
 Endif
Else
 If !instr(1,[M:CAW1]AUZ,"U") and [M:CAW1]DELEXP<>2
  [M:CAW1]USER  = GUSER
  Affzo [CAW1]USER
  Diszo [CAW1]USER
 Else
  Actzo [CAW1]USER
 Endif
Endif
Return

#---------------------------#
$GRISE_DEL
If instr(1,dbgstr(1),"[CAWW]")
 If !instr(1,[M:CAW1]AUZ,"G") or [M:CAW1]NBRDEL=0
  Grizo [CAWW]DELEXP
 Else
  Actzo [CAWW]DELEXP
 Endif
Else
 If !instr(1,[M:CAW1]AUZ,"G") or [M:CAW1]NBRDEL=0
  Grizo [CAW1]DELEXP
 Else
  Actzo [CAW1]DELEXP
 Endif
Endif
Return

#----------------------#
$DEFCRIT
For I=1 To dim(PARAM)
 Case I
  When 1 : # DELEXP
   [M:CAW1]DELEXP= val(PARAM(I))
  When 2 : # USER
   If PARAM(I)<>""
    Call LECTURE("AUS",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:CAW1]USER = PARAM(I)
    Endif
   Endif
  When 3 : # DATDEB
   If instr(1,PARAM(I),"/")
    [M:CAW1]DATDEB= "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:CAW1]DATDEB= PARAM(I)
   Endif
  When 4 : # DATFIN
   If instr(1,PARAM(I),"/")
    [M:CAW1]DATFIN= "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:CAW1]DATFIN= PARAM(I)
   Endif
  When 5 : # Filtre
   [M:CAW1]SELWRK = PARAM(I)
 Endcase
Next
Return

#-----------------------#
$LECTURE
If DEBUT
 Gosub GRISE_DEL
 Gosub GRISE_USR
 DEBUT = 0
Endif
Gosub CRITENT
Gosub CRITSUI
Gosub FILTSAI
NOL = 0
SUITE  = 1
RETOUR = 1
If CHGPAG>0
 Filter [AWS] Where evalue(CRITENT) & evalue(CRITSUI) & evalue(FILTSAI) Order By Key CLE=CHRONO Desc;DEST Desc
 NOL = 0
 For [AWS]
  OK = ![L]DELEXP
  If [M:CAW1]NBRDEL>0
   OK += find([F:AWS]DEST+"~",[M:CAW1]TABDEL(0..[M:CAW1]NBRDEL-1))
   OK += find([F:AWS]DEST+"~"+[F:AWS]NATURE,[M:CAW1]TABDEL(0..[M:CAW1]NBRDEL-1))
  Endif
  If OK
   If NOL>=MAXLIG
    SUITE = 2 : Break
   Else
    If CHGPAG=2 : RETOUR = 2 : Endif
    NOL += 1
    Gosub CHARGE
   Endif
  Endif
 Next
 Filter [AWS]
 [M:CAW2]NBLIG = NOL
Else
 Filter [AWS] Where evalue(CRITENT) & evalue(CRITSUI) & evalue(FILTSAI) Order By Key CLE=CHRONO Asc;DEST Asc
 NOL = MAXLIG+1
 For [AWS]
  OK = ![L]DELEXP
  If [M:CAW1]NBRDEL>0
   OK += find([F:AWS]DEST+"~",[M:CAW1]TABDEL(0..[M:CAW1]NBRDEL-1))
   OK += find([F:AWS]DEST+"~"+[F:AWS]NATURE,[M:CAW1]TABDEL(0..[M:CAW1]NBRDEL-1))
  Endif
  If OK
   If NOL<=1
    RETOUR = 2 : Break
   Else
    If CHGPAG=-2 : SUITE = 2 : Endif
    NOL -= 1
    Gosub CHARGE
   Endif
  Endif
 Next
 Filter [AWS]
 [M:CAW2]NBLIG = MAXLIG
Endif
NOL -= 1
Return

#-----------------------#
$CHARGE
If NBLU=1
 NBLU = 2
 If CHGPAG=2 or CHGPAG=-2 : Raz [M:CAW2] : Endif
Endif
nolign = NOL
[M:CAW2] = [F:AWS]
Return

#-----------------------#
$DEB_CRIT
$FIN_CRIT
Gosub SET_ECRAN
Return

#-----------------------#
$SET_ECRAN
If ACTION="DEB_CRIT"
 Gosub GRISE_DEL
 Gosub GRISE_USR
 If [M:CAWW]ECRAN = ""
  Call LECTURE("ACN","AWW","") From CONTOBJ
  If !fstat & [ACN]SCRCOD<>""
   [M:CAWW]ECRAN = [ACN]SCRCOD
  Endif
 Endif
Endif
Return

#-----------------------#
$CRITENT
Raz CRITENT , ICRIT
[L]DELEXP = ([M:CAW1]DELEXP=2)
If [M:CAW1]DATDEB<>[0/0/0]
 Call ADDCRIT(CRITENT,ICRIT,"DATENV","[AWS]DATENV>=["+format$(GFMD,[M:CAW1]DATDEB)+"]","&") From GOBJSUB
Endif
If [M:CAW1]DATFIN<>[0/0/0]
 Call ADDCRIT(CRITENT,ICRIT,"DATENV","[AWS]DATENV<=["+format$(GFMD,[M:CAW1]DATFIN)+"]","&") From GOBJSUB
Endif
If [M:CAW1]USER <> ""
 Call ADDCRIT(CRITENT,ICRIT,"DEST",'[AWS]DEST="'+[M:CAW1]USER+'"',"&") From GOBJSUB
Endif
If CRITENT=""
 CRITENT = "1=1"
Endif
Return

#-----------------------#
$CRITSUI
CRITSUI = ""
Case CHGPAG
 When 2
  If [M:CAW2]NBLIG>0
   WCHRONO = [M:CAW2]CHRONO([M:CAW2]NBLIG-1) 
   WDEST   = [M:CAW2]DEST([M:CAW2]NBLIG-1) 
   CRITSUI = '[F:AWS]CHRONO<"'+WCHRONO+'" or ([F:AWS]CHRONO="'+WCHRONO+'" & [F:AWS]DEST<"'+WDEST+'")'
  Endif
 When -2
  If [M:CAW2]NBLIG>0
   WCHRONO = [M:CAW2]CHRONO(0) 
   WDEST   = [M:CAW2]DEST(0) 
   CRITSUI = '[F:AWS]CHRONO>"'+WCHRONO+'" or ([F:AWS]CHRONO="'+WCHRONO+'" & [F:AWS]DEST>"'+WDEST+'")'
  Endif
Endcase
If CRITSUI=""
 CRITSUI = "1=1"
Endif
Return

#-----------------------#
$FILTSAI
FILTSAI = [M:CAW1]SELWRK
If FILTSAI="" : FILTSAI = "1=1" : Endif
Return

#-----------------------------------------------#
Subprog C_DELEXP(VALEUR)
Variable Integer VALEUR
[M]DELEXP = VALEUR
Gosub GRISE_USR
End

Subprog IB_USER
If [M]DELEXP<>2 or [M]NBRDEL=0
 GBOUT2 = ""
Endif
If !instr(1,[M]AUZ,"U")
 GBOUT1 = ""
 GBOUTS = ""
Endif
End

Subprog C_USER(VALEUR)
Variable Char    VALEUR()
Local Integer I , K , OK
If VALEUR<>""
 OK = 0 
 If [M]DELEXP=2 & [M]NBRDEL<>0
  For I=0 To [M]NBRDEL-1
   K = instr(1,[M]TABDEL(I),"~")
   If K
    If VALEUR=left$([M]TABDEL(I),K-1)
     OK += 1 : Break
    Endif
   Elsif VALEUR=[M]TABDEL(I)
    OK += 1 : Break
   Endif
  Next I
 Elsif instr(1,[M]AUZ,"U")
  OK = 1
 Elsif VALEUR=GUSER
  OK = 1 
 Endif
 If !OK
  mkstat = 1 : End
 Endif
Endif
End

Subprog IB_NBLIG
Call IB_NBLIG From SAIWRKPLN
End

Subprog C_NBLIG
Call AS_NBLIG From ="W1"+maskcou : # Pour exécuter IB_NBLIG
If adxgtb=0 & status<>71
 mkstat = 1 : # On est obligé de mettre en saisie les champs d'un tableau pour que le style fonctionne
Endif
End

