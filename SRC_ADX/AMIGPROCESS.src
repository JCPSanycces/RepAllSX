#<AdxTL>@(#)6.0.0.0 $Revision$
Local Clbfile ORIJSON(9),DESTJSON(9)
Local File APROCESSUS
Local Integer CPTNB
Call INITRACE
For [APR]APR0 
  Call TRACE(string$(CPTNB>0,","+chr$(10))+'{"Name":"'+[APR]CODPRO+'"')
  DESTJSON=""
  CPTNB+=1
  Openo getenv$("HOME")+"/tmp/orijson"+format$("N0:3",CPTNB)+".txt",0 Using [LLL]
  LENCLOB=len([APR]CLOB)
  For I=1 To int((LENCLOB+79)/80)
    Wrseq seg$([APR]CLOB,80*I-79,80*I) Using [LLL]
  Next I
  Openo Using [LLL]

  Call TRSJSON([APR]CLOB,DESTJSON)

  Call TRACE("}")

  Openo getenv$("HOME")+"/tmp/destjson"+format$("N0:3",CPTNB)+".txt",0 Using [LLL]
  LENCLOB=len(DESTJSON)
  For I=1 To int((LENCLOB+79)/80)
    Wrseq seg$(DESTJSON,80*I-79,80*I) Using [LLL]
  Next I
  Openo Using [LLL]
  Break 0*(CPTNB=3)
Next
Call TRACE("]}")
End

Subprog TRSJSON(ORIJSON,DESTJSON)
Value Clbfile ORIJSON()
Variable Clbfile DESTJSON()
Local Clbfile ANCHORJSON(4)

Local Integer CURPTH, LENJSON, I, J, K, NBPAR,ENDJSON
Local Char PATTERN1(200),PATTERN2(200), PATTERN3(200)
Local Char PARAM(50)(1..20), VALEUR(200)(1..20)
Local Integer TYPVAL(1..20)
Local Integer NBLINK

  PATTERN1='"xlinkProps":{'
  PATTERN2='<A HREF=\"'
  PATTERN3='"xtextFormat":{'

  LENJSON=len(ORIJSON)
  CURPTH=1

  While CURPTH<=LENJSON
    I=instr(CURPTH,ORIJSON,PATTERN1) : I+=(I=0)*LENJSON
    J=instr(CURPTH,ORIJSON,PATTERN2) : J+=(J=0)*LENJSON
    L=instr(CURPTH,ORIJSON,PATTERN3) : L+=(L=0)*LENJSON
    #Call TRACE("CURPTH="+num$(CURPTH)+" I="+num$(I)+" J="+num$(J)+" L="+num$(L))
    If (I<J and I<L)
      If I>CURPTH : APPEND DESTJSON,seg$(ORIJSON,CURPTH,I-1) : Endif
      CURPTH=I
      Gosub GLOB_ANCHOR
      If K=0 : Break : Endif
    Elsif (J<I and J<L)
      If J>CURPTH : APPEND DESTJSON,seg$(ORIJSON,CURPTH,J-1) : Endif
      CURPTH=J
      Gosub TXT_ANCHOR
      If K=0 : Break : Endif
    Elsif (L<I and L<J)
      If L>CURPTH : APPEND DESTJSON,seg$(ORIJSON,CURPTH,L-1) : Endif
      CURPTH=L
      Gosub GLOBTXT_ANCHOR
      If K=0 : Break : Endif
    Else
      APPEND DESTJSON,right$(ORIJSON,CURPTH)
      CURPTH=LENJSON+1
      K=1
    Endif
  Wend

  If K=0 and LENJSON<>0 : Call TRACE(',"error":true') : Endif

End DESTJSON

# The case is "xlinkProps": followed by a list of parameters
$GLOB_ANCHOR
# skip "xlinkProps":{, but write it in the final JSON
  Call TRACE("GLOB_ANCHOR:"+mid$(ORIJSON,CURPTH,30)+"...")
  K=instr(CURPTH,ORIJSON,"{")
  APPEND DESTJSON,seg$(ORIJSON,CURPTH,K)
  CURPTH=K+1
  K=instr(CURPTH,ORIJSON,"}")
  If K=0 : Return : Endif
  NBPAR=0
  Call ANAPAR(ORIJSON,CURPTH,PARAM,VALEUR,TYPVAL,K,NBPAR,1,NBLINK)
  If K=0 : Return : Endif
  Gosub TRANSCODE_LINK
  For I=1 To NBPAR
    APPEND DESTJSON,'"'+PARAM(I)+'":'+string$(TYPVAL(I)=2,'"')+VALEUR(I)+string$(TYPVAL(I)=2,'"')+string$(I<NBPAR,",")
  Next I
  CURPTH=K
 Return

# The case is <A HREH=... followed by link
$TXT_ANCHOR
# skip '<A HREF=\"'
  Call TRACE("TXT_ANCHOR:"+mid$(ORIJSON,CURPTH,30)+"...")
  K=instr(CURPTH,ORIJSON,'\"')
  APPEND DESTJSON,seg$(ORIJSON,CURPTH,K+1)
  CURPTH=K+2
  K=instr(CURPTH,ORIJSON,"%7D") : # "}"
  If K=0 : Return : Endif
  NBPAR=0
  ENDJSON=K+3
  ANCHORJSON=seg$(ORIJSON,CURPTH,K-1)
  #Call TRACE("Anchorjson="+ANCHORJSON)
  I=instr(1,ANCHORJSON,"%7B") : # "{"
  #Call TRACE("I="+num$(I))
  If I=0 : K=0 : Return : Endif
  APPEND DESTJSON,left$(ANCHORJSON,I-1)
  ANCHORJSON=func TOASC(right$(ANCHORJSON,I+3))
  #Call TRACE("Anchorjson="+ANCHORJSON)
  I=1
  K=len(ANCHORJSON)
  Call ANAPAR(ANCHORJSON,I,PARAM,VALEUR,TYPVAL,K,NBPAR,2,NBLINK)
  Gosub TRANSCODE_LINK
  ANCHORJSON="{"
  For I=1 To NBPAR
    APPEND ANCHORJSON,'"'+PARAM(I)+'":'+string$(TYPVAL(I)=2,'"')+VALEUR(I)+string$(TYPVAL(I)=2,'"')+string$(I<NBPAR,",")
  Next I
  APPEND ANCHORJSON,"}"
  ANCHORJSON=func TOJSO(ANCHORJSON)
  APPEND DESTJSON,ANCHORJSON
  CURPTH=ENDJSON
  #Call TRACE("remains:"+mid$(ORIJSON,CURPTH,30)+"...")
Return

# The case is "xtextFormat": followed by a list of parameters with an "url" having a not empty text
$GLOBTXT_ANCHOR
  Call TRACE("GLOBTXT_ANCHOR:"+mid$(ORIJSON,CURPTH,30)+"...")
  I=instr(CURPTH,ORIJSON,"}") : J=instr(CURPTH,ORIJSON,'"url":')
  If (I<>0) and (I<J or J=0)
    APPEND DESTJSON,seg$(ORIJSON,CURPTH,I)
    CURPTH=I+1
    K=I
  Elsif J<>0
    APPEND DESTJSON,seg$(ORIJSON,CURPTH,J+5)
    CURPTH=J+6
    #Call TRACE("CURPTH="+num$(CURPTH)-mid$(ORIJSON,CURPTH,200)+"...")
    If mid$(ORIJSON,CURPTH,2)='""'
      APPEND DESTJSON,mid$(ORIJSON,CURPTH,2)
      CURPTH+=2
    Elsif mid$(ORIJSON,CURPTH,4)='null'
      APPEND DESTJSON,mid$(ORIJSON,CURPTH,4)
      CURPTH+=4
    Else
      K=instr(CURPTH,ORIJSON,"%7B") : # "{"
      I=instr(CURPTH+1,ORIJSON,'"') : # Closing quote
      #Call TRACE("I="+num$(I)-"K="+num$(K)-mid$(ORIJSON,K,30)+"...")
      If K=0 or K>I
        K=0 : Return
      Endif
      APPEND DESTJSON,seg$(ORIJSON,CURPTH,K+2)
      CURPTH=K+3
      K=instr(CURPTH,ORIJSON,"%7D") : # "}"
      #Call TRACE("CURPTH="+num$(CURPTH)-mid$(ORIJSON,CURPTH,30)+"...")
      #Call TRACE("CURPTH="+num$(CURPTH)-"K="+num$(K)-mid$(ORIJSON,K,30)+"...")
      If K=0 : Return : Endif
      NBPAR=0
      ENDJSON=K+3
      ANCHORJSON=seg$(ORIJSON,CURPTH,K+2)
      ANCHORJSON=func TOASC(ANCHORJSON)
      #Call TRACE("Anchortxtjson="+ANCHORJSON)
      I=1
      K=len(ANCHORJSON)
      Call ANAPAR(ANCHORJSON,I,PARAM,VALEUR,TYPVAL,K,NBPAR,3,NBLINK)
      Gosub TRANSCODE_LINK
      ANCHORJSON=""
      For I=1 To NBPAR
        APPEND ANCHORJSON,'"'+PARAM(I)+'":'+string$(TYPVAL(I)=2,'"')+VALEUR(I)+string$(TYPVAL(I)=2,'"')+string$(I<NBPAR,",")
      Next I
      APPEND ANCHORJSON,"}"
      ANCHORJSON=func TOJSO(ANCHORJSON)
      APPEND DESTJSON,ANCHORJSON
      CURPTH=ENDJSON
      #Call TRACE("remains:"+mid$(ORIJSON,CURPTH,30)+"...")
    Endif
  Else
    K=0
  Endif
Return


# Lets analyze the parameters
# and store them in PARAM, VALEUR, TYPVAL arrays
# If K=0, error in JSON, otherwise K remains unchanged

Subprog ANAPAR(ORIJSON,CURPTH,PARAM,VALEUR,TYPVAL,K,N,GT,NBLINK)
Variable Integer CURPTH,K,N,TYPVAL(1..)
Value Integer GT
Variable Integer NBLINK
Variable Char PARAM()(1..),VALEUR()(1..)

Local Integer L,M,P

  While CURPTH<K
    L=instr(CURPTH,ORIJSON,'"')
    If L<K and L<>0
      M=instr(L+1,ORIJSON,'"')
      If M<K and M<>0
        N+=1
        PARAM(N)=seg$(ORIJSON,L+1,M-1)
        CURPTH=M+1
        L=instr(CURPTH,ORIJSON,'"')
        If L<K
          M=instr(L+1,ORIJSON,'"')
          P=instr(L+1,ORIJSON,'\"')
          While P<>0 and P<M
            M=instr(P+2,ORIJSON,'"')
            P=instr(P+2,ORIJSON,'\"')
          Wend
          If M<=K and M<>0
            VALEUR(N)=seg$(ORIJSON,L+1,M-1)
            TYPVAL(N)=2 : # alphanumeric
            CURPTH=M+1
          Else Break
          Endif
        Else
         M=instr(CURPTH,ORIJSON,",")
         If M<K and M<>0
           VALEUR(N)=seg$(ORIJSON,CURPTH,M-1)
           TYPVAL(N)=1 : # without quotes (numeric or logical)
           CURPTH=M+1
         Else Break
         Endif
        Endif
      Else Break
      Endif
    Else CURPTH=K+1
    Endif
  Wend
  If CURPTH<K : K=0 : End : Endif

# Now we can analyze the links
  Call TRACE(",")
  NBLINK+=1
  Call TRACE(string$(GT=1,'"Link')+string$(GT=2,'"Text_Link')+string$(GT=3,'"Gobal_Text_Link')+num$(NBLINK)+'":{')
  For L=1 To N
    Call TRACE('"'+PARAM(L)+'" : '+string$(TYPVAL(L)=2,'"')+VALEUR(L)+string$(TYPVAL(L)=2,'"')+string$(L<N,","))
  Next L
  Call TRACE("}")
End

$TRANSCODE_LINK
Return

Funprog TOJSO(ENTREE)
Value Clbfile ENTREE
Local Clbfile SORTIE(4)
Local Integer LENENT,I,J,K
Local Char TRSCAR(40),C(10)

TRSCAR="/':,._{}\éèêëàâîôùûç"+'"'+chr$(195)+chr$(168)+chr$(169)+" ?=~&"
LENENT=len(ENTREE)
For I=1 To LENENT
  C=XGETCHAR(ENTREE,I)
  J=instr(1,TRSCAR,C)
  If J
    K=ascii(mid$(TRSCAR,J,1))
    Append SORTIE,"%"+chr$(48+int(K/16)+7*(K>=160))+chr$(48+mod(K,16)+7*(mod(K,16)>9))
  Else
    Append SORTIE, C
  Endif
Next I
End SORTIE

Funprog TOASC(ENTREE)
Value Clbfile ENTREE
Local Clbfile SORTIE(4)
Local Integer LENENT,I,J,K
Local Char TRSCAR(40),C(10)
LENENT=len(ENTREE)
I=1
While I<=LENENT
  C=XGETCHAR(ENTREE,I)
  If C="%"
    I+=1
    C=XGETCHAR(ENTREE,I)
    J=ascii(C)-48-7*(ascii(C)>64)
    I+=1
    C=XGETCHAR(ENTREE,I)
    J=J*16+ascii(C)-48-7*(ascii(C)>64)
    Append SORTIE,chr$(J)
  Else
    Append SORTIE,C
  Endif
  I+=1
Wend
End SORTIE

Subprog TRACE(TEXT)
Value Char TEXT()

  Openo getenv$("HOME")+"/tmp/links.txt",-1 Using  [LLL]
  Wrseq TEXT Using [LLL]
  Openo Using  [LLL]
End

Subprog INITRACE

  Openo getenv$("HOME")+"/tmp/links.txt",0 Using  [LLL]
  Wrseq '{ "genDate":"'+format$("D:MMM[ ]DD[, ]YYYY[ at ]hh[:]mm[:]ss",date$)+'","processes": [' Using [LLL]
  Openo Using  [LLL]
End
