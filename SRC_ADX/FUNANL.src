#########################################################################
#
# FUNANL                                         MC 30/03/99
# 
# Fonction de lancement analyses du rÃĐalisÃĐ      
# traitements possibles:
#     - lancement analyses postes de charge
#     - lancement analyses OF 
#
# Version modelisÃĐe                              MM - Septembre  2003 
# - modÃĻle : traitement standard (GTRAITE)
# - Ecran principal   : ANL1                 
# - FenÃŠtre : IANL  
# - Action TRTANL                                   
#########################################################################

$ACTION
#--- Actions liÃĐes au traitement standard
Case ACTION
 When "OUVRE_BATCH"    :  Gosub INIT
 When "INIT"           :  Gosub INIT
 When "INIT_DIA"       :  Gosub INIT_DIA
 When "EXEC"           :  Gosub EXEC
 When "TERMINE"        :  Gosub TERMINE
 When Default
Endcase

Return
#########################################################################
$INIT
#
If GSERVEUR
  Onerrgo ERRBATCH
Endif

#---------------------------------------#   
# Ouverture des fichiers utilisÃĐs       #   
#---------------------------------------#
# Ouverture tables
If clalev ([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev ([F:ADP]) = 0 : Local File ADOPAR     [ADP] : Endif
If clalev ([F:ATX]) = 0 : Local File ATEXTE     [ATX] : Endif
If clalev ([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:PJA]) = 0 : Local File PARJAL     [PJA] : Endif

# Ouverture masques ÃĐcrans
Local Mask ANL4[ANL4]  

Gosub OUVRE

Return
#########################################################################
$OUVRE
#
Local  Char    WMSG(120)
Local  Char    WTIT(30) 
#
Local  Integer WPRO                      # Traitement 1=WSA, 2=MFA, 3=WSA+MFA
Local  Char    WFCY(GLONFCY)                   # Site Ã  traiter
Local  Integer IFCY                      # Indice sites
Local  Date    LASTMONTH    
Local  Date    PERSTRDAT     
Local  Date    PERENDDAT  
#    
Local  Integer I
#

Return
#########################################################################
$INIT_DIA

Raz [M:DIA]
nolign = 0
#
Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
WFCY=GFCY
If WFCY<>"" :  Gosub LOA_SITE : Endif
#
LASTMONTH = addmonth(date$,-1)
[M:DIA]PERSTR = gdat$(1,month(LASTMONTH),year(LASTMONTH))
[M:DIA]PEREND = eomonth(LASTMONTH)

Return

########################################################################
# chargement site
$LOA_SITE 
Local Integer WLIN
#
If find(WFCY,[M:DIA]FCY(0..[M:DIA]BASPAG-1))
  Return
Endif
#
WLIN = find("",[M:DIA]FCY(0..dim([M:DIA]FCY)-1))
If WLIN = 0
  Return
Endif
#
Read [FCY]FCY0=WFCY
  If fstat 
    WMSG = WFCY-mess(15,104,1)
    Call ERREUR(WMSG) From GESECRAN  
    Return
  Endif
  If [F:FCY]MFGFLG <> 2
    WMSG = WFCY-mess(1,193,1)
    Call ERREUR(WMSG) From GESECRAN  
    Return
  Endif
#
Read [PJA]PJA0=WFCY
  If fstat
    WMSG = WFCY-mess(37,187,1)
    Call ERREUR(WMSG) From GESECRAN
    Return
  Else
    nolign = WLIN 
    [M:DIA] = [F:FCY]
    [M:DIA]BASPAG = WLIN
  Endif
# 
Return  
#
########################################################################
$EXEC
# Transfert vers masque ANL4 
Raz [M:ANL4]
[M:ANL4] = [M:DIA]
IFCY = 1
For I = 0 To [M:DIA]BASPAG-1
    If [M:DIA]FCY(I) <> ""
      If evalue("dim([M:ANL4]FCY"+format$("N0:3",IFCY)+")") > 0 
        Assign("[M:ANL4]FCY"+format$("N0:3",IFCY)) With [M:DIA]FCY(I)
        IFCY += 1
      Endif
    Endif
Next I  
Close Local Mask [DIA]
Gosub TRT_GEN

Return

########################################################################
# Boucle de traitement sur les sites demandÃĐs
$TRT_GEN

Case [M:ANL4]PRO
  When 1       : WTIT = mess(1,386,1)
  When 2       : WTIT = mess(2,386,1)
  When 3       : WTIT = mess(3,386,1)
Endcase
If !GSERVEUR
    Call TEMPON("") From GESECRAN
    Call OUVRE_TRACE(WTIT) From LECFIC
Endif
IFCY = 1
WPRO = [M:ANL4]PRO
PERSTRDAT = [M:ANL4]PERSTR
PERENDDAT = [M:ANL4]PEREND
While evalue("dim([M:ANL4]FCY"+format$("N0:3",IFCY)+")") > 0
  WFCY = evalue("[M:ANL4]FCY"+format$("N0:3",IFCY))
  If WFCY <> ""
    Case [M:ANL4]PRO
        When 1:    Call WSTANL(WFCY,PERSTRDAT,PERENDDAT) From ANLLIB    
        When 2:    Call MFGANL(WFCY,PERSTRDAT,PERENDDAT) From ANLLIB
        When 3:    Call WSTANL(WFCY,PERSTRDAT,PERENDDAT) From ANLLIB
                   Call MFGANL(WFCY,PERSTRDAT,PERENDDAT) From ANLLIB
    Endcase
  Else
    Break 
  Endif
  IFCY += 1
Wend
#

Return

########################################################################
$TERMINE
# Traitement fin
#
If !GSERVEUR
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
#
Return

########################################################################
#pour les batchs
########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK) 
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # Dossier de lancement
Value    Char    USER      : # Utilisateur
Variable Char    P1()(1..) : # On peut avoir 2 fois 50 chaÃŪnes de 15 caractÃĻres
Variable Char    P2()(1..) 
Variable Integer OK : OK=0

Local    Char    WTIT(30) 
#---- traitement de la comptabilitÃĐ ----#
Local Char    WIN (GLONFEN)
WIN="IANL" 
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT
Gosub TRT_GEN
End 


############################################################
$ERRBATCH 
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

