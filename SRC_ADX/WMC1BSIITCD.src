####################################################################

$SET_LEV
If [L]_AOLDVAL<>this.LEV
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_LEV
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.LEV
 Gosub PROPAGATE_LEV
Endif
Return

$INIT_LEV
Gosub DECLARE_VAR From WMC0BSIITCD
[L]CURPRO = "LEV"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.LEV=0 and fmet this.AGETATTRIBUTE("LEV","$isMandatory")="true"
 this.LEV = 1
Endif
Return
 
$CONTROL_LEV
Gosub DECLARE_VAR From WMC0BSIITCD
[L]CURPRO = "LEV"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_LEV                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_LEV                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_LEV
[L]CURPRO = "LEV"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.LEV=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_LEV
[L]CURPRO = "LEV"
If this.LEV<0 or this.LEV>len(mess(0,3695,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"3695 ->"-num$(this.LEV)-mess(99,123,1)):  Return : # Local menu "3695 -> Invalid option
Endif
Return

$_AOTHERS_LEV
[L]CURPRO = "LEV"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_LEV
[L]CURPRO = "LEV"
Return

$PROPAGATE_LEV
this.isReadonly = 0
[L]CURPRO = "LEV"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_LEV
Gosub DECLARE_VAR From WMC0BSIITCD
[L]CURPRO = "LEV"
$_LNKPRO_LEV
Return


