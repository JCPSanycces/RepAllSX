#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ENTSAL0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone REFNUM
mkstat = 0
zoncou = "REFNUM"
indice = 0
If varmode([M]REFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REFNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FCYORI
mkstat = 0
zoncou = "FCYORI"
indice = 0
WCHAR = [M]FCYORI
If varmode([M]FCYORI,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FCYORI([M]FCYORI) From SUBHRENT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]FCYORI : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCYORI" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]FCYORI,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTFCY"
   Call CONTSITE([M]FCYORI) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("FCY","",[M]FCYORI,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call AP_FCYORI([M]FCYORI) From SUBHRENT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]FCYORI or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_FCYORI([M]FCYORI) From SUBHRENT
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "FCYORI" : GZNUM = 9711 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone FLGNEWSAL
mkstat = 0
zoncou = "FLGNEWSAL"
indice = 0
IMPENT = [M]FLGNEWSAL
If varinit([M]FLGNEWSAL,indice)=0
 IMPENT = 2
Endif
[M]FLGNEWSAL = IMPENT

## Zone FLGITS
mkstat = 0
zoncou = "FLGITS"
indice = 0
IMPENT = [M]FLGITS
If varinit([M]FLGITS,indice)=0
 IMPENT = 2
Endif
[M]FLGITS = IMPENT

## Zone FLGPAR
mkstat = 0
zoncou = "FLGPAR"
indice = 0
IMPENT = [M]FLGPAR
If varinit([M]FLGPAR,indice)=0
 IMPENT = 2
Endif
[M]FLGPAR = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CIVA
mkstat = 0
zoncou = "CIVA"
indice = 0
WCHAR = [M]CIVA
If varmode([M]CIVA,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]CIVA,"M") From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CIVA : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CIVA" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CIVA,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "AFMTCONT"
   Call CONTROLE([M]CIVA,"M",[M]NOLIB,15,[M]VALINT) From FMTVAR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTACL"
    Call CONTACL([M]VALINT,"M","","") From SUBACL
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]CIVA or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_CIVA([M]CIVA) From SUBHRENT
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CIVA" : GZNUM = 14401 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NAM
mkstat = 0
zoncou = "NAM"
indice = 0
WCHAR = [M]NAM
If varmode([M]NAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NAM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]NAM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NAM" : GZNUM = 55 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]NAM or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_NAM([M]NAM) From SUBHRENT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NAM" : GZNUM = 55 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone SRN
mkstat = 0
zoncou = "SRN"
indice = 0
If varmode([M]SRN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SRN" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SRN,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SRN" : GZNUM = 1825 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone LEGORI
mkstat = 0
zoncou = "LEGORI"
indice = 0
If varinit([M]LEGORI,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEGORI,"909","") From SUBADI
 GACTION = SAVACT
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone FLGPAY
mkstat = 0
zoncou = "FLGPAY"
indice = 0
IMPENT = [M]FLGPAY
If varinit([M]FLGPAY,indice)=0
 IMPENT = 2
Endif
If varmode([M]FLGPAY,indice)=0
 [M]FLGPAY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGPAY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGPAY(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLGPAY(IMPENT) From SUBHRENT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLGPAY" : GZNUM = 46644 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGPAY = IMPENT

## Zone FLGMULCTR
mkstat = 0
zoncou = "FLGMULCTR"
indice = 0
IMPENT = [M]FLGMULCTR
If varinit([M]FLGMULCTR,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGMULCTR,indice)=0
 [M]FLGMULCTR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGMULCTR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGMULCTR(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLGMULCTR(IMPENT) From SUBHRENT
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLGMULCTR" : GZNUM = 46642 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGMULCTR = IMPENT

## Zone FLGINT
mkstat = 0
zoncou = "FLGINT"
indice = 0
IMPENT = [M]FLGINT
WNUM = IMPENT
If varinit([M]FLGINT,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGINT,indice)=0
 [M]FLGINT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGINT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGINT(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_FLGINT(IMPENT) From SUBHRENT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FLGINT" : GZNUM = 45114 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]FLGINT = IMPENT

## Zone FCYCRY
mkstat = 0
zoncou = "FCYCRY"
indice = 0
If varinit([M]FCYCRY,indice)=0
 [M]FCYCRY = GPAYS
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ENTSAL0"
Return

