#<AdxTL>@(#)9.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table champ LNKBUSINT
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update field LNKBUSINT") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","AYTFCY","fde",DOSSIER),0) <0 or func AFNC.ACTIVDOS(DOSSIER,"AYT")<1
 End
Endif

Gosub LNKBUSINT
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","AYTFCY","fde",DOSSIER),0) <0 or func AFNC.ACTIVDOS(DOSSIER,"AYT")<1
 End
Endif

Gosub LNKBUSINT
End

#-------------------#
$LNKBUSINT

Local File =DOSSIER+".AYTFCY"  [AYS] 

If dim([F:AYS]LNKBUSINT)<0
 Close Local File [AYS]
 Return 
Endif

# Mise à jour de la table AYTFCY
Call ECR_TRACE(mess(81,125,1)-"AYTFCY:"-time$,0) From GESECRAN
Trbegin [AYS]
 For [AYS]AYS0
  If [F:AYS]LNKBUSINT=0
   [F:AYS]LNKBUSINT=1    
   Rewrite [AYS]
   If fstat
    Call ERREUR("AYTFCY"-[F:AYS]FCYCOD,2) From DOSDIC
   Endif 
  Endif
 Next AYS
Commit

Close Local File [AYS]

Return

