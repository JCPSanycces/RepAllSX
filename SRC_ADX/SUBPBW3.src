#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque PBENCHW3
########################################
$ACTION
Case ACTION
 When "AAM_STOFCY"   : Gosub AAM_STOFCY
 When "BAM_STOFCY"   : Gosub BAM_STOFCY
Endcase
Return

########################################
$AAM_STOFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     SITE(GLONFCY)   : SITE=VALEUR
Local Char     WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:PBW3]STOFCY : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:PBW3]ITMREF
Return

########################################
$BAM_STOFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
nolign=NOL+1: # Restitution du nolign
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:PBW3]ITMREF;VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return

########################################
Subprog AM_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WDATEREF
Local    Date    TODAY : TODAY = date$

If VALEUR < datesyst
          Call MESSAGE(mess(65,194,1)) From GESECRAN
Endif

[M:PBW3]EXTRCPDAT = VALEUR
Gosub CHARGE_WRCPDAT From BENCHLIBP

# raffraichissement liste contrats
If [M:PBW3]EXTRCPDAT <> [0/0/0]
    WDATEREF = [M:PBW3]EXTRCPDAT
Else
    WDATEREF = TODAY
Endif
## GH 02/09/10 bug 75888
#Filter [POC] Where ITMREF = [M:PBW3]ITMREF & ENDDAT >= WDATEREF & PRHFCY = [M:PBW3]STOFCY & WDATEREF >= date$
Filter [POC] Where ITMREF = [M:PBW3]ITMREF & ENDDAT >= WDATEREF & PRHFCY = [M:PBW3]STOFCY & STRDAT<=WDATEREF
nolign = 1
# llc 05.02 14394 Performances
For [POC]POC2
    If nolign > dim([M:PBW3]SELIND) : Break : Endif
    Read [POH]POH0=[F:POC]POHNUM
    If fstat : Goto N_POC : Endif
    If !find([F:POH]APPFLG,3,4,5) : Goto N_POC : Endif
    If [F:POH]CLEFLG = 2          : Goto N_POC : Endif
    [M:PBW3]SELIND(nolign-1) = 1
    [M:PBW3]POHNUM(nolign-1) = [F:POC]POHNUM
    [M:PBW3]BPSNUM2(nolign-1)= [F:POC]BPSNUM
    [M:PBW3]STRDAT(nolign-1) = [F:POC]STRDAT
    [M:PBW3]ENDDAT(nolign-1) = [F:POC]ENDDAT
    [M:PBW3]PUU2(nolign-1)   = [F:POC]PUU
    [M:PBW3]USEPLC2(nolign-1)= [F:POC]USEPLC
    [M:PBW3]PURFCY(nolign-1) = [F:POC]POHFCY
    nolign += 1
$N_POC
Next
[M:PBW3]NBLIG = nolign - 1
Filter [POC]

Actzo [M:PBW3]BPSNUM
Actzo [M:PBW3]PJT
Affzo [M:PBW3]25

End

########################################
Subprog AS_QTYPUU(VALEUR)
Variable Decimal VALEUR
GBOUT1 = ""

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif


#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [M:PBW3]STOFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
   Read [ITF]ITF0 = [F:ITM]ITMREF;[M:PBW3]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If [F:ITF]STOMGTCOD > 1 : GBOUT1=mess(102,198,1) : Endif
End


########################################
Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()

# Epic: 55934 (STLIG) enable/disable product selection on parameter: ITMBPSFCY
If (GITMBPSFCY = 1)
  GBOUT2 = ""
Else
  GBOUT2 = mess(1,3505,1)
Endif
GBOUT3 = mess(2,3505,1) # product-site suppliers
GBOUT4 = mess(24,198,1)
#GBOUT2 = mess(23,198,1)
#GBOUT3 = mess(24,198,1)

End

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer    WRETOUR
Local Decimal    WQTY
Local Decimal    WCOEUOM, WCOEF1, WCOEF2
Local Char       WPUU

# Epic: 55934 (STLIG)
If (VALEUR = "")
  End
Endif

# interx
If [F:BPR]BPRNUM <> VALEUR
    Read [F:BPR]BPR0=VALEUR
    If fstat : Raz [BPR] : Endif
Endif
If [F:BPR]FCY <> ""
    [M:PBW3]ORIFCY = [F:BPR]FCY
Endif

#-------------------------------------------#
# vérification couple article - fournisseur #
#-------------------------------------------#
If clalev([F:ITP]) = 0 : Local File ITMBPS [ITP] : Endif

    # il faut vérifier que la qté saisie >= qte min achat
    # attention l'unité achat est peut etre differente

# Epic: 55934 (STLIG)
If ([F:ITP]BPSNUM <> VALEUR | [F:ITP]ITMREF <> [M:PBW3]ITMREF)
  Read [ITP]ITP0 = [M:PBW3]ITMREF;VALEUR
  If (fstat)
    Raz [F:ITP]
  Endif
Endif
If ([F:ITP]BPSNUM <> "")

  WQTY = [M:PBW3]QTYPUU
  WPUU = [F:ITP]PUU

  #----- Récupération des coefficients entre UA et US -----#
  # 05.05 30036
  Call PCAL_QTY (1, [M:PBW3]PUU, GBIDD3, [M:PBW3]STU,
&   [M:PBW3]ITMREF, [M:PBW3]BPSNUM, 1, WCOEF1) From TRTACHQTE1
  Call PCAL_QTY (1, [F:ITP]PUU, GBIDD3, [M:PBW3]STU,
&   [M:PBW3]ITMREF, VALEUR, 1, WCOEF2) From TRTACHQTE1
  If [M:PBW3]PUU <> [F:ITP]PUU | WCOEF1 <> WCOEF2
    GMESSAGE = mess(13,194,1)
    Call MESSAGE(GMESSAGE) From GESECRAN
    #--------- qté achat saisie ------#
    # 05.05 30036
    Call PCAL_QTY ([M:PBW3]QTYSTU, [M:PBW3]STU, WQTY, [F:ITP]PUU,
&     [M:PBW3]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
  Endif

  [M:PBW3]QTYPUU = WQTY
  [M:PBW3]PUU    = WPUU
  # qté stock saisie
  Call PCAL_QTY ([M:PBW3]QTYPUU, [M:PBW3]PUU, [M:PBW3]QTYSTU, [M:PBW3]STU,
&   [M:PBW3]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
  Affzo [M:PBW3]20    # 06.02 MM

Else
  [M:PBW3]PUU    = [F:ITM]PUU
  # qté stock saisie
  Call PCAL_QTY ([M:PBW3]QTYSTU, [M:PBW3]STU, [M:PBW3]QTYPUU, [M:PBW3]PUU,
&   [M:PBW3]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
  Affzo [M:PBW3]20-25    # 06.02  MM

Endif

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer WRETOUR
Local    Date    WDATEREF
Local    Date    TODAY : TODAY = date$

Raz [M:PBW3]QTYPUU
Raz [M:PBW3]QTYSTU
Raz [M:PBW3]PUU
Raz [M:PBW3]STU

[M:PBW3]STU    = [F:ITM]STU
[M:PBW3]PUU    = [F:ITM]PUU

# recherche fournisseur : on jette les fournisseurs inter-sites

# Epic: 55934 (STLIG) - supplier initialisation
If ([M:PBW3]BPSNUM = "")
  Local Integer ITMBPS
  Call DEFBPSNUM(VALEUR,"",[M:PBW3]PSHFCY,"",1,[M:PBW3]BPSNUM,ITMBPS) From TRTACHDEF1
  If (ITMBPS > 0)
    Read [ITP]ITP0=VALEUR;[M:PBW3]BPSNUM
    If (fstat)
      Raz [F:ITP]
    Else
      [M:PBW3]PUU = [F:ITP]PUU
    Endif
  Endif
Endif

# dans tous les cas, on propose la liste des contrats
If [M:PBW3]EXTRCPDAT <> [0/0/0]
    WDATEREF = [M:PBW3]EXTRCPDAT
Else
    WDATEREF = TODAY
Endif
# GH 27/06/2012 bug 83199
#Filter [POC] Where ITMREF = VALEUR & ENDDAT >= WDATEREF & PRHFCY = [M:PBW3]STOFCY & WDATEREF >= date$
Filter [POC] Where ITMREF = VALEUR & ENDDAT >= WDATEREF & PRHFCY = [M:PBW3]STOFCY & STRDAT <= WDATEREF
nolign = 1
# llc 05.02 14394 Performances
For [POC]POC2
    If nolign > dim([M:PBW3]SELIND) : Break : Endif
    Read [POH]POH0=[F:POC]POHNUM
    If fstat : Goto N_POC2 : Endif
    If !find([F:POH]APPFLG,3,4,5) : Goto N_POC2 : Endif
    If [F:POH]CLEFLG = 2          : Goto N_POC2 : Endif
    [M:PBW3]SELIND(nolign-1) = 1
    [M:PBW3]POHNUM(nolign-1) = [F:POC]POHNUM
    [M:PBW3]BPSNUM2(nolign-1)= [F:POC]BPSNUM
    [M:PBW3]STRDAT(nolign-1) = [F:POC]STRDAT
    [M:PBW3]ENDDAT(nolign-1) = [F:POC]ENDDAT
    [M:PBW3]PUU2(nolign-1)   = [F:POC]PUU
    [M:PBW3]USEPLC2(nolign-1)= [F:POC]USEPLC
    [M:PBW3]PURFCY(nolign-1) = [F:POC]POHFCY
    nolign += 1
$N_POC2
Next
[M:PBW3]NBLIG = nolign - 1
Filter [POC]

Affzo [M:PBW3]BPSNUM
Affzo [M:PBW3]25
If WRETOUR = 1 : End :  Endif

Affzo [M:PBW3]PUU
Affzo [M:PBW3]STU
Affzo [M:PBW3]QTYPUU
Affzo [M:PBW3]QTYSTU

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:PBW3]ECCVALMAJ)>0
    Call AM_ITMREF_PBW3(VALEUR) From SUBPBWECC
Endif

End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

Read [ITF]ITF0 = VALEUR;[M:PBW3]STOFCY
If fstat
    Raz [F:ITF]
    GMESSAGE = mess(25,192,1)
    mkstat = 2
    End
Endif

# llc 11.01 11042
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$
   mkstat = 1 : GMESSAGE = mess(12,318,1) : End
Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:PBW3]ECCVALMAJ)>0
& &    [M:PBW3]ECCVALMAJ=""
    Call C_ITMREF_PBW3(VALEUR) From SUBPBWECC
Endif
End

########################################
Subprog C_QTYPUU(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCOEFF
Local    Decimal WQTYSTU

#-- conversion qté suggérée en ua de l'article
Call PCAL_QTY(VALEUR, [M:PBW3]PUU,
&             WQTYSTU, [M:PBW3]STU, [F:ITM]ITMREF,[M:PBW3]BPSNUM, 1, WCOEFF) From TRTACHQTE1
If WQTYSTU < [M:PBW3]COVQTY
    GMESSAGE = mess(120,193,1)+"("+num$([M:PBW3]COVQTY)+")"
    mkstat = 2
Endif

End

########################################
Subprog AM_SELIND(VALEUR)
Variable Integer VALEUR
Local Integer I
Local Integer    WRETOUR
Local Decimal    WQTY
Local Decimal    WCOEUOM


[M:PBW3]SELIND(nolign-1) = VALEUR
For  I = 0 To [M:PBW3]NBLIG - 1
    If I <> nolign - 1 : [M:PBW3]SELIND(I) = 1 : Endif
Next I
Case VALEUR
    When 2:             Call C_BPSNUM([M:PBW3]BPSNUM2(nolign-1))
                        If mkstat=4 : mkstat=0 : Elsif mkstat : End : Endif
                        WQTY = [M:PBW3]QTYPUU
                        If [M:PBW3]PUU <> [M:PBW3]PUU2(nolign-1)
                           GMESSAGE = mess(13,194,1)
                           Call MESSAGE(GMESSAGE) From GESECRAN
                           #--------- qté achat saisie ------#
                           Call PCAL_QTY ([M:PBW3]QTYPUU, [M:PBW3]PUU, WQTY, [M:PBW3]PUU2(nolign-1),
&                                         [M:PBW3]ITMREF, [M:PBW3]BPSNUM2(nolign-1), 1, WCOEUOM) From TRTACHQTE1
                        Endif

                        [M:PBW3]QTYPUU = WQTY
                        [M:PBW3]PUU    = [M:PBW3]PUU2(nolign-1)
                        # qté stock saisie
                        Call PCAL_QTY ([M:PBW3]QTYPUU, [M:PBW3]PUU, [M:PBW3]QTYSTU, [M:PBW3]STU,
&                                      [M:PBW3]ITMREF, [M:PBW3]BPSNUM2(nolign-1), 1, WCOEUOM) From TRTACHQTE1
                        [M:PBW3]POCNUM = [M:PBW3]POHNUM(nolign-1)
                        [M:PBW3]BPSNUM = [M:PBW3]BPSNUM2(nolign-1)
                        [M:PBW3]USEPLC = [M:PBW3]USEPLC2(nolign-1)
                        [M:PBW3]PSHFCY = [M:PBW3]PURFCY(nolign-1)
    When Default:       [M:PBW3]POCNUM = ""
                        Call AM_BPSNUM([M:PBW3]BPSNUM)
Endcase
Affzo [M:PBW3]15-25
End

########################################
Subprog AV_BPSNUM(VALEUR)
Variable Char    VALEUR()
If find(2,[M:PBW3]SELIND(0..[M:PBW3]NBLIG-1))
    Diszo [M:PBW3]10
    Diszo [M:PBW3]BPSNUM
    Diszo [M:PBW3]PJT
Else
    Actzo [M:PBW3]10
    Actzo [M:PBW3]BPSNUM
    Actzo [M:PBW3]PJT
Endif
End

########################################
Subprog C_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
# llc 11.01 11042
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$
   mkstat = 1 : GMESSAGE = mess(12,318,1) : End
Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:PBW3]ECCVALMAJ)>0
    Call C_EXTRCPDAT(VALEUR, "PBW3") From SUBPBWECC
Endif
End

##########################################################################
## Etiquette ajoutée par le superviseur 08/12/2003 11:45:12 (MM)
##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog AM_QTYPUU(VALEUR)
Variable Decimal VALEUR
Affzo [M:PBW3]QTYSTU

If VALEUR=0 & [M]QTYSTU=0
    Raz [M]QTYPUU
    mkstat = 2 : GMESSAGE = mess(223,193,1)    #Il faut saisir une quantité soit en UA, soit en US
Endif
End


##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR

If VALEUR < [M:PBW3]COVQTY
    # La quantité doit être supérieure ou égale\à la quantité prise en compte
    GMESSAGE = mess(120,193,1)+"("+num$([M:PBW3]COVQTY)+")"
    mkstat = 2
Endif

End

##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Affzo [M:PBW3]QTYPUU

If VALEUR=0 & [M]QTYPUU=0
    Raz [M]QTYSTU
    mkstat = 2 : GMESSAGE = mess(223,193,1)    #Il faut saisir une quantité soit en UA, soit en US
Endif
End


##########################################################################
# 01.04 Inter-société MM
Subprog C_PSHFCY(VALEUR)
Variable Char    VALEUR()
Local Integer    I
I = find(VALEUR ,GSITE(1..GNBSITE))
If I
  GSOCIETE=GSOCSITE(I)
Endif

End

##########################################################################
# 01.04 Inter-société MM
# Saisie d'un fournisseur inter-site interdit pour commande classique
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()

# Epic: 55934 (STLIG) validate 1. blocking flag, and 2. product and product-site reference
Local Integer WITMBPS
Local Integer WRETOUR
If (VALEUR <> "")
  Call CTRL_DOUFLG(1,[M:PBW3]ITMREF,VALEUR,[M:PBW3]PSHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
  If (WRETOUR <> 0)
    mkstat = 2 : End
  Endif
Endif

If VALEUR <> ""
    Read [BPR]BPR0=VALEUR
    If fstat : Raz [F:BPR] : Endif

    If [F:BPR]FCY <> "" & [F:FCY]FCY <> [F:BPR]FCY
       Read [FCY]FCY0=[F:BPR]FCY
       If fstat : Raz [F:FCY] : Endif
    Endif
    If !find([M:PBW3]INTHAB,1,2,3,4,5,6,7) & [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE     # 14102 mm 04.06
        GMESSAGE =mess(233,193,1) :  mkstat=2 : End : # Ce fournisseur est un fournisseur inter-site : choix non autorisé
    Endif
    If !find([M:PBW3]APPHAB,1,2,3,4,5,6,7) & ([F:BPR]FCY = "" | ([F:BPR]FCY <> "" & [F:FCY]LEGCPY <> GSOCIETE))  # 14102 mm 04.06
        GMESSAGE =mess(235,193,1) :  mkstat=2 : End : # Ce fournisseur n'est pas un fournisseur inter-site : choix non autorisé
    Endif
Endif

# GH 26/08/11 bug 75888
#Local    Integer WETABOU(1..GNBBOU)
#Local    Integer INDINTER : INDINTER = 0
#
#If VALEUR<>"" & [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
#
#WETABOU(GSPE1)=0
#WETABOU(GSPE2)=0
#If !INDINTER & find([M:PBW3]APPHAB,2,3,6,7)                 : WETABOU(GSPE1) = 1 : Endif
#If !INDINTER & find([M:PBW3]APPHAB,4,5,6,7) & VALEUR <> ""  : WETABOU(GSPE2) = 1 : Endif
#If  INDINTER & find([M:PBW3]INTHAB,2,3,6,7)                 : WETABOU(GSPE1) = 1 : Endif
#If  INDINTER & find([M:PBW3]INTHAB,4,5,6,7) & VALEUR <> ""  : WETABOU(GSPE2) = 1 : Endif
#WETABOU(GBFIN)=1
#
#Case GPLNFLT
#    When 2:    If [F:ITF]PLANNER <> [M:PBW3]PLANNER & [F:ITF]PLANNER <> ""
#                   WETABOU(GSPE1) = 0
#               Endif
#    When 3:    If [F:ITF]PLANNER <> [M:PBW3]PLANNER
#                   WETABOU(GSPE1) = 0
#               Endif
#Endcase
#
#If GBUYFLT = 2 & [F:ITF]BUY <> [M:PBW3]PLANNER
#               WETABOU(GSPE2) = 0
#Endif
#Call SETBOUT(WETABOU) From GESECRAN

[M:PBW3]BPSNUM = VALEUR
Affzo [M:PBW3]15-25

mkstat=4 : # GH 26/08/11 bug 75888

End

##########################################################################
## Etiquette ajoutée par le superviseur 18/02/2004 14:02:53 (LLC)
##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

## GH 13/09/11 bug 76100
GFCY=VALEUR
Gosub CHARG_PARAM From FUNGBENCH

If [M:PBW3]EXTRCPDAT <> [0/0/0]
    [M:PBW3]STOFCY = VALEUR
    Effzo [PBW3]25
    If !mkstat: Call AM_EXTRCPDAT([M:PBW3]EXTRCPDAT) : Endif
Endif
End


