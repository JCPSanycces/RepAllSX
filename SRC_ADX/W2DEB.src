#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DEB 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_EECNAT
Onevent CONTROL Call C_EECNAT(zc) From W2DEB
Onevent BEFORE_INPUT Call AS_EECNAT(zc) From W2DEB
Onevent AFTER_CHANGE Gosub AMM_EECNAT From W2DEB
Return

Subprog IB_EECNAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action IBTUNLEG
 Call IBTUNLEG("") From TRTVENCTL
Endif
Gosub _AFF
End

Subprog AS_EECNAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(2520,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_EECNAT(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_EECNAT(zc) From W2DEB
Onkey   2 Titled GBOUTS Call S_EECNAT(zc) From W2DEB
Onkey 144 Titled GBOUTP Call P_EECNAT(zc) From W2DEB
Onkey 146 Titled GBOUTA Call SA_EECNAT(zc) From W2DEB
Gosub _AFF
End

Subprog C_EECNAT(VALEUR)
Variable Char    VALEUR()
## Action CONTTEC
Call CONTTEC(VALEUR,GCURLEG,"DEB","EECNAT",[M:DEB]STOFCY,"",[M:DEB]CPY) From SUBTEC
If mkstat : GERR = 1 : GZONE = "EECNAT" : GZNUM = 2520 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "EECNAT" : GZNUM = 2520 : Endif
Endif
Gosub _AFF
End

$AMM_EECNAT
Call AM_EECNAT(zc)
If !mkstat & GOBJET
 zoncou = "EECNAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EECNAT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZEECNAT)")>indice
 [M]EECNAT(indice) = VALEUR
 Affzo ZEECNAT(indice)
Endif
Gosub _AFF
End

Subprog S_EECNAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELTECLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELTECLEG"
 PARMSK(1) = GCURLEG
 PARMSK(2) = [M:DEB]STOFCY
 PARMSK(3) = ""
 PARMSK(4) = [M:DEB]CPY
 PARMSK(5) = ""
 PARMSK(6) = "DEB"
 PARMSK(7) = "EECNAT"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELTECLEG","SUBTEC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_EECNAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNTEC
 Call TUNTEC(VALEUR,GCURLEG) From SUBTEC
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_EECNAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TEC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EECNAT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TEC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZEECNAT
Onevent BEFORE_AREA Gosub AV_ZEECNAT From W2DEB
Return

$AV_ZEECNAT
Call LECTEXTRA(zc,"TABEECNAT","DESAXX",num$([M]EECNAT(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_EECTRN
Onevent BEFORE_INPUT Call AS_EECTRN(zc) From W2DEB
Onevent INIT_AREA Call D_EECTRN(zc) From W2DEB
Onevent CONTROL Call C_EECTRN(zc) From W2DEB
Return

Subprog D_EECTRN(VALEUR)
Variable Integer VALEUR
If varinit([M]EECTRN,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_EECTRN(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(237) From COMBOS
## Action DIVEECTRN
GMENLOC(6)=1
If mkstat=2
 [M]EECTRN(INDIC) = VALEUR
 Affzo EECTRN(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,237,1))))
Endif
If !mkstat
 Discombo 0 From EECTRN(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From EECTRN(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_EECTRN(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_EECLOC
Onevent INIT_AREA Call D_EECLOC(zc) From W2DEB
Onevent BEFORE_INPUT Call AS_EECLOC(zc) From W2DEB
Return

Subprog D_EECLOC(VALEUR)
Variable Integer VALEUR
If varinit([M]EECLOC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_EECLOC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_EECICT
Onevent CONTROL Call C_EECICT(zc) From W2DEB
Onevent BEFORE_INPUT Call AS_EECICT(zc) From W2DEB
Onevent AFTER_CHANGE Gosub AMM_EECICT From W2DEB
Return

Subprog AS_EECICT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(5345,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EECICT(zc) From W2DEB
Onkey   2 Titled GBOUTS Call S_EECICT(zc) From W2DEB
Onkey 144 Titled GBOUTP Call P_EECICT(zc) From W2DEB
Onkey 146 Titled GBOUTA Call SA_EECICT(zc) From W2DEB
Gosub _AFF
End

Subprog C_EECICT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ICT","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "EECICT" : GZNUM = 2523 : Endif
Gosub _AFF
End

$AMM_EECICT
Call AM_EECICT(zc)
If !mkstat & GOBJET
 zoncou = "EECICT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EECICT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZEECICT)")>indice
 [M]EECICT(indice) = VALEUR
 Affzo ZEECICT(indice)
Endif
Gosub _AFF
End

Subprog S_EECICT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ICT"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_EECICT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ICT",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_EECICT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ICT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EECICT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ICT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZEECICT
Onevent BEFORE_AREA Gosub AV_ZEECICT From W2DEB
Return

$AV_ZEECICT
Call LECTEXTRA(zc,"INCOTERM","DES",num$([M]EECICT(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_STAFED
Onevent INIT_AREA Call D_STAFED(zc) From W2DEB
Onevent CONTROL Call C_STAFED(zc) From W2DEB
Onevent BEFORE_INPUT Call AS_STAFED(zc) From W2DEB
Onevent AFTER_CHANGE Gosub AMM_STAFED From W2DEB
Return

Subprog D_STAFED(VALEUR)
Variable Char    VALEUR()
If varinit([M]STAFED,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"80","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_STAFED(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"80") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_STAFED(zc) From W2DEB
Onkey   2 Titled GBOUTS Call S_STAFED(zc) From W2DEB
Onkey 144 Titled GBOUTP Call P_STAFED(zc) From W2DEB
Onkey 146 Titled GBOUTA Call SA_STAFED(zc) From W2DEB
Gosub _AFF
End

Subprog C_STAFED(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"80","") From SUBADI
If mkstat : GERR = 1 : GZONE = "STAFED" : GZNUM = 36795 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"80",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "STAFED" : GZNUM = 36795 : Endif
Endif
Gosub _AFF
End

$AMM_STAFED
Call AM_STAFED(zc)
If !mkstat & GOBJET
 zoncou = "STAFED" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_STAFED(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSTAFED)")>indice
 [M]STAFED(indice) = VALEUR
 Affzo ZSTAFED(indice)
Endif
Gosub _AFF
End

Subprog S_STAFED(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "80"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_STAFED(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"80") From GOBJET
Gosub _AFF
End

Subprog SA_STAFED(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "80"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
