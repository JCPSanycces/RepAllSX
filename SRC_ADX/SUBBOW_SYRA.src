#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# Issue 101318 GA 07/2014
# Components Where-used seeking for Syracuse - Code extracted from SUBBOW
###################################################################################
# Global Variables replaced for Syracuse
#   GUSER   => CTX.USER
#   GUSRACS => CTX.ALLACS
###################################################################################
$ACTION
Case ACTION
    When "FIN"         : Gosub FIN
Endcase
Return

###################################################################################
# Sous-pro pour cas d'emploi premier niveau
###################################################################################
Subprog TRAITPREM(CTX,OK)
Value     Instance   CTX Using C_WMACONTEXT : # General context
Variable  Integer OK
Local Char    XCRITERE(255)
Local Char    XCRITERE1(255)
Local Char    XCRITERE2(255)

#--CPO Si on ne fait pas l'appel depuis une instance, on initialise par le GACTX
If CTX= null
  CTX = GACTX
Endif

Gosub FILTRE From SUBBOW

# GA 05/2015 idem SUBBOW Versioning (GH 05/15)
Local Char    FILTRE2(255)  : FILTRE2 = ""
Local Date    DAT
If dim([M:DIA]ECCVALMAJ)=1 & [M:DIA]ECCVALMAJ<>""
   FILTRE2-= "& ECCVALMAJ = '"+[M:DIA]ECCVALMAJ+"'"
Endif
If dim([M:DIA]ECCVALMIN)=1 & [M:DIA]ECCVALMIN<>""
   FILTRE2-= "& ECCVALMIN = '"+[M:DIA]ECCVALMIN+"'"
Endif
If FILTRE2<>"" : FILTRE2=right$(FILTRE2,4) : Else FILTRE2 = "1=1"  : Endif

# GH 06/05/2013 bug 89819 ajout du critère CPNTYP<>7
If clalev([F:BOD]) = 0 : Local File BOMD [BOD] : Endif
If [M:DIA]DATREF <> [0/0/0]
  Filter [BOD] Where CPNITMREF = [M:DIA]CPNSEL & CPNTYP<>7
&                 &  evalue(XCRITERE1) & evalue(FILTRE2)
&                 &  (BOMSTRDAT <= [M:DIA]DATREF | BOMSTRDAT = [0/0/0])
&                 &  (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0])
Else
  Filter [BOD] Where CPNITMREF = [M:DIA]CPNSEL  & CPNTYP<>7
&                 &  evalue(XCRITERE1) & evalue(FILTRE2)
Endif

Local File BOMWUS [BOW]

# Issue 101318 GA 08/2014 Trbegin/Commit for Syracuse
Local Shortint LOUVTRS : LOUVTRS=0
Gosub CTL_TRS

# purge des éventuels enreg du user
Delete [BOW] Where CREUSR = CTX.USER & BOWUID = adxuid(1)
If fstat = 1 : Gosub CTL_ROLLBACK : OK = 0 : Goto FIN_TRAITPREM : Endif
Gosub CTL_COMMIT

Gosub ANALYSE_FORMULE From SUBBOW

GOK = 1

# Issue 101318 GA 08/2014 Trbegin/Commit for Syracuse
Local Shortint LOUVTRS : LOUVTRS=0
Gosub CTL_TRS

For [BOD]BOD1

    ## Vérification des droits
    mkstat = 0
    Call CTLVISALT(CTX,[F:BOD]BOMALT,[F:BOD]BOMALTTYP) From TRTBOM_SYRA
    If mkstat <> 0 : GMESSAGE="" : Goto NXT_BOD_PREM : Endif

    ## Analyse de la formule de sélection
    Gosub CONTEXTE_FORMULE From SUBBOW
    If !evalue(FORMULE1) : Goto NXT_BOD_PREM : Endif

    Raz [F:BOW]
    [F:BOW]= [F:BOD]
    [F:BOW]CPNDES = [M:DIA]CPNDES
    [F:BOW]BOWUID = adxuid(1)
    [F:BOW]CREDAT = date$
    [F:BOW]CREUSR = CTX.USER
    [F:BOW]TRTCOD = 1  : # code Premier niveau
    Write [BOW]
    If fstat : GOK = 0 : Break : Endif

$NXT_BOD_PREM
Next
If GOK = 0 : Gosub CTL_ROLLBACK : OK = 0 : Goto FIN_TRAITPREM : Endif
OK=1
Gosub CTL_COMMIT

$FIN_TRAITPREM
Filter [BOD]
End


###################################################################################
# Sous-pro filtrant BOD selon les sélections
###################################################################################
Subprog FILTDERMUL(CTX,OK)
Value     Instance   CTX Using C_WMACONTEXT : # General context
Variable  Integer OK

Local    Integer I
Local Char    XCRITERE(255)
Local Char    XCRITERE1(255)
Local Char    XCRITERE2(255)

#--CPO Si on ne fait pas l'appel depuis une instance, on initialise par le GACTX
If CTX= null
  CTX = GACTX
Endif

Global Integer GINIV, GORD
Global Decimal GQTY, GNQTY  : # quantités brute et nette
If clalev([F:BOH]) = 0 : Local File BOM [BOH] : Endif
Local File BOMWUS [BOW]

Gosub FILTRE  From SUBBOW

If !adxlog : Trbegin [BOW] : Endif         # Issue 101318 GA 08/2014 Trbegin/Commit for Syracuse
Delete [BOW] Where CREUSR = CTX.USER : # & BOWUID = adxuid(1)
If fstat = 1 : Gosub CTL_ROLLBACK : OK = 0 : Goto FIN1 : Endif
Gosub CTL_COMMIT

OK = 1
GQTY = 1 : GNQTY = 1

# GA 05/2015 idem SUBBOW Versioning (GH 05/15)
Local Char    VMAJ(GLONICVVAL), VMIN(GLONICVVAL)
If dim([M:DIA]ECCVALMAJ)=1
   VMAJ=[M:DIA]ECCVALMAJ
Endif
If dim([M:DIA]ECCVALMIN)=1
   VMIN=[M:DIA]ECCVALMIN
Endif

For [TBO] Where evalue(XCRITERE1)
    mkstat = 0
    Call CTLVISALT(CTX,[F:TBO]BOMALT,[F:TBO]BOMALTTYP) From TRTBOM_SYRA
    If mkstat=0
        If [M:DIA]TRT = 2
            Call TRAITDER(CTX,[M:DIA]CPNSEL,[L]VMAJ,[L]VMIN,[F:TBO]BOMALT,[F:TBO]BOMALTTYP,OK)
        Else
            Call TRAITMUL(CTX,[M:DIA]CPNSEL,[L]VMAJ,[L]VMIN,[F:TBO]BOMALT,[F:TBO]BOMALTTYP,OK)
        Endif
        If OK = 0 : Break : Endif
        GORD = 0 : # ràz du compteur de parcours
    Endif
Next

$FIN1
End

###################################################################################
# Sous-pro pour gérer les transactions
###################################################################################
# Issue 101318 GA 08/2014 Trbegin/Commit for Syracuse
$CTL_TRS
If !adxlog
    LOUVTRS=1
    Trbegin [BOW]
Endif
Return

$CTL_COMMIT
If dim(LOUVTRS)>0 & LOUVTRS=1
   Commit
Endif
Return
$CTL_ROLLBACK
If dim(LOUVTRS)>0 & LOUVTRS=1
   Rollback
Endif
Return

###################################################################################
# Sous-pro pour les cas d'emploi dernier niveau (récursif)
###################################################################################
Subprog TRAITDER(CTX,CPN,VMAJ,VMIN,ALT,ALTTYP,OK)
Value Instance   CTX Using C_WMACONTEXT : # General context
Value Char       CPN, VMAJ, VMIN
Value Integer    ALT
Value Integer    ALTTYP
Variable Integer OK

Local Integer J, K
Local Integer WLLCTYP :  WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
Local Decimal SGQTY, SNQTY :# locales pour conserver la qté à chaque noeud

# GA 05/2015 idem SUBBOW Versioning (GH 05/15)
Local Date    DAT
Local Char    VMAJ2(GLONICVVAL), VMIN2(GLONICVVAL)
Local Integer SEQ2
Local Char    FILTRE2(255)  : FILTRE2 = ""
If [L]VMAJ<>""
   FILTRE2-= "& ECCVALMAJ='"+[L]VMAJ+"'"
Endif
If [L]VMIN<>""
   FILTRE2-= "& ECCVALMIN='"+[L]VMIN+"'"
Endif
If FILTRE2<>"" : FILTRE2=right$(FILTRE2,4) : Else FILTRE2 = "1=1"  : Endif

#--CPO Si on ne fait pas l'appel depuis une instance, on initialise par le GACTX
If CTX= null
  CTX = GACTX
Endif

# GH 06/05/2013 bug 89819 ajout du critère CPNTYP<>7
If [M:DIA]DATREF <> [0/0/0]
   Local File BOMD [BOD] Where CPNITMREF=CPN & BOMALT=ALT & BOMALTTYP=ALTTYP & CPNTYP<>7
&                            & evalue(FILTRE2)
&                            & (BOMSTRDAT <= [M:DIA]DATREF | BOMSTRDAT = [0/0/0])
&                            & (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0])
Else
   Local File BOMD [BOD] Where CPNITMREF=CPN & BOMALT=ALT & BOMALTTYP=ALTTYP & CPNTYP<>7
&                            & evalue(FILTRE2)
Endif

Gosub ANALYSE_FORMULE From SUBBOW

J=0
For [BOD]BOD3

  ## Analyse de la formule de sélection
  Gosub CONTEXTE_FORMULE From SUBBOW
  If !evalue(FORMULE1) : Goto NXT_BOD_DER : Endif

  If !J : J=1 : GINIV+=1 : Endif : # il existe au moins un lien

  If !WBOH
      Read [BOH]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
  Endif
  SGQTY   = GQTY
  SNQTY   = GNQTY
  GQTY  = GQTY * [F:BOD]LIKQTY * (1 + [F:BOD]SCA/100) / [F:BOH]BASQTY
  GNQTY  = GNQTY * [F:BOD]LIKQTY / [F:BOH]BASQTY

  SEQ2   = 0 : K=1
  Repeat
    If dim([M:DIA]ECCVALMAJ)=1
      Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                      & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                      & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
      Read [EVL]EVL0 > [F:BOD]ITMREF;[L]SEQ2;[F:BOD]BOMALTTYP
      Filter [EVL]
      If fstat<=2
         SEQ2  = [F:EVL]ECCSEQ
      Elsif SEQ2
         Break
      Else
         Raz [F:EVL]
      Endif
      [L]VMAJ2 = [F:EVL]ECCVALMAJ
      [L]VMIN2 = [F:EVL]ECCVALMIN
    Endif

  # Si le composé n'a pas de cas d'emploi on est en haut de l'arborescence
    Read [ITB]ITB0 = [F:BOD]ITMREF;[F:BOD]BOMALT;WLLCTYP
    If !fstat & [F:ITB]WUSEXIFLG = 2
      Call TRAITDER(CTX,[F:BOD]ITMREF,[L]VMAJ2,[L]VMIN2,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,OK)
      Elsif K
         Gosub ECRBOW : K=0
    Endif
    If OK = 0 : Break 2 : Endif
  Until SEQ2<1

  GQTY = SGQTY
  GNQTY = SNQTY

$NXT_BOD_DER
Next

If J = 1 : GINIV -= 1 : Endif
Close Local File
End

###################################################################################
$ECRBOW
# Issue 101318 GA 08/2014 Trbegin/Commit for Syracuse
Local Shortint LOUVTRS : LOUVTRS=0
Gosub CTL_TRS

[F:BOW]BOWUID    = adxuid(1)
[F:BOW]CREUSR    = CTX.USER
[F:BOW]CREDAT    = date$
[F:BOW]CPNITMREF = [M:DIA]CPNSEL
[F:BOW]CPNDES    = [M:DIA]CPNDES
[F:BOW]NIV       = GINIV  : # niveau dans l'arborescence
[F:BOW]ITMREF    = [F:BOD]ITMREF
[F:BOW]BOMALT    = [F:BOD]BOMALT
[F:BOW]BOMALTTYP = [F:BOD]BOMALTTYP     # V6
[F:BOW]CPNTYP    = [F:BOD]CPNTYP        # llc 05.00 sous-produit
[F:BOW]GROQTY    = GQTY
Call QTEARR([F:BOW]GROQTY,[F:BOD]BOMUOM) From TRTDIV    # sr 11.04 demande 26626
[F:BOW]NETQTY    = GNQTY
Call QTEARR([F:BOW]NETQTY,[F:BOD]BOMUOM) From TRTDIV
[F:BOW]BOMSEQ    = 1 : # fictif, sert à dissocier les doublons
[F:BOW]TRTCOD    = 2 : # pour distinguer l'édition Dernier niveau

###################################################################################
$ECRIT
Write [BOW]
# en remontant l'arborescence, on peut trouver plusieurs occurences
# (composé,alternative), BOMSEQ servira à les distinguer :
If fstat = 3 : [F:BOW]BOMSEQ += 1 : Goto ECRIT : Endif
If fstat : OK = 0 : Gosub CTL_ROLLBACK : Return : Endif
Gosub CTL_COMMIT
Return

###################################################################################
$ECRBOWMUL
# Issue 101318 GA 08/2014 Trbegin/Commit for Syracuse
Local Shortint LOUVTRS : LOUVTRS=0
Gosub CTL_TRS

[F:BOW]BOWUID    = adxuid(1)
[F:BOW]          = [F:BOD]
[F:BOW]CREUSR    = CTX.USER
[F:BOW]CREDAT    = date$
[F:BOW]NIV       = GINIV : # niveau dans l'arborescence
[F:BOW]IMULT     = GORD  : # ordre de parcours
[F:BOW]TRTCOD    = 3     : # pour distinguer l'édition Multi niveau
# FQ 73424 GA 05/2011 idem TRAITDER + écran BOW1 champs rajoutés GROQTY et NETQTY
[F:BOW]GROQTY    = GQTY
Call QTEARR([F:BOW]GROQTY,[F:BOD]BOMUOM) From TRTDIV
[F:BOW]NETQTY    = GNQTY
Call QTEARR([F:BOW]NETQTY,[F:BOD]BOMUOM) From TRTDIV

Write [BOW]

# Le cas du doublon peut se produire sans pb : même composant à 2 séq
# seul le cas de la table lockée arrête le trt
If fstat=1 : OK = 0 : Gosub CTL_ROLLBACK : Return : Endif
Gosub CTL_COMMIT
Return

###################################################################################
# Sous-pro pour les cas d'emploi multi niveau (récursif)
###################################################################################
Subprog TRAITMUL(CTX,CPN,VMAJ,VMIN,ALT,ALTTYP,OK)
Value Instance   CTX Using C_WMACONTEXT : # General context
Value Char       CPN, VMAJ, VMIN
Value Integer    ALT
Value Integer    ALTTYP
Variable Integer OK

Local Integer J, I, K
Local Integer WLLCTYP : :  WLLCTYP = func LLCLIB.LLCTYP(ALTTYP)
Local Decimal SGQTY, SNQTY :   # FQ 73424 GA 05/2011 idem TRAITDER

#--CPO Si on ne fait pas l'appel depuis une instance, on initialise par le GACTX
If CTX= null
  CTX = GACTX
Endif

# GA 05/2015 idem SUBBOW Versioning (GH 05/15)
Local Char    VMAJ2(GLONICVVAL), VMIN2(GLONICVVAL)
Local Integer SEQ2
Local Char    FILTRE2(255)  : FILTRE2 = ""
If [L]VMAJ<>""
   FILTRE2-= "& ECCVALMAJ='"+[L]VMAJ+"'"
Endif
If [L]VMIN<>""
   FILTRE2-= "& ECCVALMIN='"+[L]VMIN+"'"
Endif
If FILTRE2<>"" : FILTRE2=right$(FILTRE2,4) : Else FILTRE2 = "1=1"  : Endif

# GH 06/05/2013 bug 89819 ajout du critère CPNTYP<>7
If [M:DIA]DATREF <> [0/0/0]
   Local File BOMD [BOD] Where CPNITMREF  = CPN & BOMALT = ALT & BOMALTTYP = ALTTYP & CPNTYP<>7
&                            & evalue([L]FILTRE2)
&                            & (BOMSTRDAT <= [M:DIA]DATREF | BOMSTRDAT = [0/0/0])
&                            & (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0])
Else
   Local File BOMD [BOD] Where CPNITMREF  = CPN & BOMALT = ALT & BOMALTTYP = ALTTYP & CPNTYP<>7
&                            & evalue([L]FILTRE2)
Endif

Gosub ANALYSE_FORMULE From SUBBOW

J=0 : K=0
For [BOD]BOD3
  K=1

  ## Analyse de la formule de sélection
  Gosub CONTEXTE_FORMULE  From SUBBOW
  If !evalue(FORMULE1)
     Goto NXT_BOD_MUL
  Endif

  I=J
  If !J : J=1 : GINIV+=1 : Endif : # il existe au moins un lien

  GORD += 1 : # séquence de parcours

  If !WBOH
      # FQ 73424 GA 05/2011 idem TRAITDER
      Read [BOH]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
  Endif
  SGQTY  = GQTY
  SNQTY  = GNQTY
  GQTY   = GQTY  * [F:BOD]LIKQTY * (1 + [F:BOD]SCA/100) / [F:BOH]BASQTY
  GNQTY  = GNQTY * [F:BOD]LIKQTY / [F:BOH]BASQTY

  Gosub ECRBOWMUL
  If OK = 0 : Break : Endif


  SEQ2   = 0
  Repeat
    If dim([M:DIA]ECCVALMAJ)=1
      Filter [EVL] Where ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & ECCTYP=[F:BOD]BOMALTTYP
&                      & [F:BOD]BOMSTRDAT<=[F:EVL]STRDAT
&                      & ([F:BOD]BOMENDDAT>=[F:EVL]STRDAT | [F:BOD]BOMENDDAT=[0/0/0])
      Read [EVL]EVL0 > [F:BOD]ITMREF;[L]SEQ2;[F:BOD]BOMALTTYP
      Filter [EVL]
      If fstat<=2
         SEQ2  = [F:EVL]ECCSEQ
      Elsif SEQ2
         Break
      Else
         Raz [F:EVL]
      Endif
      [L]VMAJ2 = [F:EVL]ECCVALMAJ
      [L]VMIN2 = [F:EVL]ECCVALMIN
    Endif


    Read [ITB]ITB0 = [F:BOD]ITMREF;[F:BOD]BOMALT;WLLCTYP
    If !fstat & [F:ITB]WUSEXIFLG = 2
      Call TRAITMUL(CTX,[F:BOD]ITMREF,[L]VMAJ2,[L]VMIN2,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,OK)
      If OK=2
        # Issue 101318 GA 08/2014 Trbegin/Commit for Syracuse
        Local Shortint LOUVTRS : LOUVTRS=0
        Gosub CTL_TRS
        Delete [BOW] Where BOWUID=adxuid(1) & ITMREF=[F:BOD]ITMREF & BOMALT=[F:BOD]BOMALT & BOMSEQ=[F:BOD]BOMSEQ
&                         & CPNITMREF=[F:BOD]CPNITMREF & BOMALTTYP=[F:BOD]BOMALTTYP
        If fstat=1 | fstat>5 : Gosub CTL_ROLLBACK : OK=0 : Break : Endif
        Gosub CTL_COMMIT
      Endif
      If OK=2
       J=I : If !J : GINIV-=1 : Endif
       If !J & GINIV=0 : OK=1 : Endif
      Endif
      If OK = 0 : Break 2 : Endif
    Endif
  Until SEQ2<1

  # FQ 73424 GA 05/2011 idem TRAITDER
  GQTY  = SGQTY
  GNQTY = SNQTY

$NXT_BOD_MUL
Next
If !J & K : OK=2 : Endif

If J = 1 : GINIV -= 1 : Endif
Close Local File # pour libérer la mémoire (bug 12546) 25/01/02
End


###################################################################################
# quand on sort de la fenêtre principale :
$FIN
Return


###################################################################################
# Issue 101318 GA 07/2014
# V8 SYRACUSE : Function to get component where-used list from everywhere
# 0) CTX          Syracuse context
# 1) LCPN         component
# 2) LDATREF      reference date (date$ for today)
# 3) LLSTTYP      what to display 1=first level, 2=last level, 3= multi-level
# 4) LALTTYPSTR   BOM's type (From): default value 1
# 5) LALTTYPEND   BOM's type (To)  : default value 3
# 6) LALTSTR      BOM's alternative (From): default value 0 All
# 7) LALTEND      BOM's alternative (To)  : default value 0 All
# 8) MYCRIT       optionnal: particular criteria on BOMD table
# 9) MYFOR        optionnal: formula code
# 10) LRET        return code (1=Ok, 0=Error)
###################################################################################
Subprog CALCULATE_WHERE_USED(CTX,LCPN,LDATREF,LLSTTYP,LALTTYPSTR,LALTTYPEND,LALTSTR,LALTEND,LCRIT,LFOR,LRET)
Value Instance   CTX Using C_WMACONTEXT : # General context
Value Char       LCPN
Value Date       LDATREF
Value Integer    LLSTTYP
Value Integer    LALTTYPSTR
Value Integer    LALTTYPEND
Value Integer    LALTSTR
Value Integer    LALTEND
Value Char       LCRIT
Value Char       LFOR
Variable Integer LRET

# no display of selection criteria
If clalev([M:DIA])  = 0
    Local Mask BOW0 [DIA]
Endif

#--selon CPO Si on ne fait pas l'appel depuis une instance, on initialise par le GACTX
If CTX= null
  CTX = GACTX
Endif

# received paramters
# 1) wich product
[M:DIA]CPNSEL = LCPN
#date de référence
[M:DIA]DATREF = LDATREF
# 2) what to display 3= All levels
If find(LLSTTYP,1,2,3)
   [M:DIA]TRT = LLSTTYP
Else
   [M:DIA]TRT = 1
Endif
# 3) BOM's type (From)
If find(LALTTYPSTR,1,2,3)
   [M:DIA]ALTTYPDEB = LALTTYPSTR
Else
   [M:DIA]ALTTYPDEB = 1
Endif
# 4) BOM's type (To)
If find(LALTTYPEND,1,2,3)
   [M:DIA]ALTTYPFIN = LALTTYPEND
Else
   [M:DIA]ALTTYPFIN = 3
Endif
[M:DIA]ALTDEB  = LALTSTR
[M:DIA]ALTFIN  = LALTEND
[M:DIA]FORMULE = LFOR
[M:DIA]SCRFLG  = 1

Gosub INIT From SUBBOW
LRET=2

If [M:DIA]TRT = 1
   Call TRAITPREM(CTX,LRET)
Else
   Call FILTDERMUL(CTX,LRET)
Endif

End


###################################################################################
# Suite Issue 101318 GA 05/2015
# V8 SYRACUSE : Function to get component where-used list from everywhere
# 0) CTX          Syracuse context
# 1) LCPN         component
# 2) LMAJ         Major version [optional] ### New !
# 3) LMIN         Minor version [optional] ### New !
# 4) LDATREF      reference date (date$ for today)
# 5) LLSTTYP      what to display 1=first level, 2=last level, 3= multi-level
# 6) LALTTYPSTR   BOM's type (From): default value 1
# 7) LALTTYPEND   BOM's type (To)  : default value 3
# 8) LALTSTR      BOM's alternative (From): default value 0 All
# 9) LALTEND      BOM's alternative (To)  : default value 0 All
# 10) MYCRIT      optionnal: particular criteria on BOMD table
# 11) MYFOR       optionnal: formula code
# 12) LRET        return code (1=Ok, 0=Error)
###################################################################################
Subprog CALCULATE_WHERE_USED_ECC(CTX,LCPN,LMAJ,LMIN,LDATREF,LLSTTYP,LALTTYPSTR,LALTTYPEND,LALTSTR,LALTEND,LCRIT,LFOR,LRET)
Value Instance   CTX Using C_WMACONTEXT : # General context
Value Char       LCPN,LMAJ,LMIN
Value Date       LDATREF
Value Integer    LLSTTYP
Value Integer    LALTTYPSTR
Value Integer    LALTTYPEND
Value Integer    LALTSTR
Value Integer    LALTEND
Value Char       LCRIT
Value Char       LFOR
Variable Integer LRET

# no display of selection criteria
If clalev([M:DIA])  = 0
    Local Mask BOW0 [DIA]
Endif

#--selon CPO Si on ne fait pas l'appel depuis une instance, on initialise par le GACTX
If CTX= null
  CTX = GACTX
Endif

# received paramters
# 1) wich product
[M:DIA]CPNSEL = LCPN
#date de référence
[M:DIA]DATREF = LDATREF
# 2) what to display 3= All levels
If find(LLSTTYP,1,2,3)
   [M:DIA]TRT = LLSTTYP
Else
   [M:DIA]TRT = 1
Endif
# 3) BOM's type (From)
If find(LALTTYPSTR,1,2,3)
   [M:DIA]ALTTYPDEB = LALTTYPSTR
Else
   [M:DIA]ALTTYPDEB = 1
Endif
# 4) BOM's type (To)
If find(LALTTYPEND,1,2,3)
   [M:DIA]ALTTYPFIN = LALTTYPEND
Else
   [M:DIA]ALTTYPFIN = 3
Endif
[M:DIA]ALTDEB  = LALTSTR
[M:DIA]ALTFIN  = LALTEND

# Suite Issue 101318 GA 05/2015
If dim([M:DIA]ECCVALMAJ)=1
  [M:DIA]ECCVALMAJ = LMAJ
  [M:DIA]ECCVALMIN = LMIN
Endif

[M:DIA]FORMULE = LFOR
[M:DIA]SCRFLG  = 1

Gosub INIT From SUBBOW
LRET=2

If [M:DIA]TRT = 1
   Call TRAITPREM(CTX,LRET)
Else
   Call FILTDERMUL(CTX,LRET)
Endif

End

