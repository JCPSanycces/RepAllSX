#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation SAD
Local Char PARAM(20)(1..4)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = "ARTICLE1"
PARAM(4) = ""
Call GCONSULT("SAG","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:STO])=0 : Local File STOCK      [STO] : Endif
If clalev([F:STA])=0 : Local File STOALL     [STA] : Endif
#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSAG"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SAG1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:SAG1]FLG = 0
Return
############################################################
$FERME
If clalev([F:STA]) <> 0 : Filter [STA] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I  
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat 
          [M:SAG1]FCY = PARAM(I) 
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat 
          [M:SAG1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif  
  Endcase
Next I       
Return
############################################################
$LECTURE
If [M:SAG1]ITMREF = "" | [M:SAG1]FCY = ""
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STA]  
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STA] 
      If WLIG >= WSKIP 
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif  
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SAG2]
    WLIG = 0
    For [STA]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STA] 
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif  
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STA] 
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SAG1]FLG = 0
  [M:SAG1]FLG = 1
  Raz [M:SAG2]
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Filter [STA] Where STOFCY = [M]FCY     &
&                    ITMREF = [M]ITMREF  &
&                    ALLTYP = 1          &
&                    evalue(WFILS)       &
&                    evalue(WFILSPE)
&              Order By Key STA0
  Raz [F:STA]
Endif
Return
############################################################
$LOA_LIGNE
[M:SAG2]VCRTYP(nolign-1)    = [F:STA]VCRTYP
[M:SAG2]VCRNUM(nolign-1)    = [F:STA]VCRNUM
[M:SAG2]VCRLIN(nolign-1)    = [F:STA]VCRLIN
[M:SAG2]VCRSEQ(nolign-1)    = [F:STA]VCRSEQ
[M:SAG2]STU(nolign-1)       = [F:ITM]STU
[M:SAG2]QTYSTUACT(nolign-1) = [F:STA]QTYSTUACT
[M:SAG2]ALLDAT(nolign-1)    = [F:STA]ALLDAT
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SAG1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SAG1] = [F:ITM]
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SAG1]FLG = 0
End
###########################################################

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SAG") From SUBGTC

End


