#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES CONCESSIONS - VALIDATION DU RENOUVELLEMENT
# =======================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
#
# - MWA - 16.05.2018 - X3-89794 - Wrong definition of the site length
# - GLE - 06.02.2015 - FQ105441 - Suite 95049 : si la valeur de renouvellement n'est pas forcé il faut la prendre sur CCNRPR
# - GLE - 13.02.2014 - FQ 95049 - Alimentation de la valeur de renouvellement des biens pères au prorata de la base industrielle du bien fils
# - MDJ - 28.01.2014 - FQ 95641 - "Devise inexistante" en validation renouvellement concession
# - MWA - 12.04.2013 - FQ 88613 - Forcer le recalcul des amortissements
# - GBO - 05.08.2010 - FQ 65873 - Utilisation des globales GML_MSGxxx dans les instructions mess()
# - GBO - 05.08.2010 - FQ 66544 - Réponse Non à la demande de confirmation de validation (ou annulation) : boîte calcul à tort
# - GBO - 26.07.2010 - FQ 66187 - Ajout des PE RNWPLNCAD/RNWCANPLNCAD pour pouvoir modifier le plan de caducité du bien fils
#                                 avant sa réécriture.
# - GBO - 15.02.2010 - FQ 62307 - Ajout "Fin normale sur trace"
#
########################################################################################################################
 Raz GPILOBJ
 Call DEFVAR From GLOBIMM
 Call INIVAR From GLOBIMM

 Local Char PARAM(30)(1..4)
 Local Char VALEUR

 PARAM(1) = ""
 PARAM(2) = ""
 PARAM(3) = "RNWACT"
 PARAM(4) = ""

 Call TRAITE_CHAR(VALEUR,PARAM,"","TRTCCNRNW","CCNRNW",3,"") From GTRAITE


End

######################################################################################
$ACTION
 Case ACTION
  When "INIT"        : Gosub INIT
  When "INIT_DIA"    : Gosub INIT_DIA
  When "AVANT_PAR"   : Gosub AVANT_PAR
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH
  When "DEBUT"       : Gosub DEBUT
  When "CONT_BATCH"  : Gosub CONTROLE
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "END"         : ABANDON= G_OUI
  When "SORTIE"      : Gosub SORTIE
  When "TERMINE"     : Gosub TERMINE

  When "APRES_MODIF" : Gosub APRES_MODIF
  When "SETBOUT"     : Gosub SETBOUT

  When "OK"          : Gosub OK

  When  "SEL_LISTE"  : Gosub SEL_LISTE

  When Default
 Endcase
Return

#------------------------------------------------------
$INIT
  If dim(ABANDON)<0 : Global Integer   ABANDON : Endif
  Gosub INIT_COMM From TRTCCNRNW
Return

#------------------------------------------------------
$INIT_DIA
  If dim(ABANDON)<0 : Global Integer   ABANDON : Endif
  Gosub INIT_COMM From TRTCCNRNW
Return

#------------------------------------------------------
$AVANT_PAR
  If dim(ABANDON)<0 : Global Integer   ABANDON : Endif

  If ( GACTSILENCE = G_OUI and GTRTFILMSK <> "" ) Then
   # Pas d'affichage du masque en silencieux
   TYPPRG=0
   # Chargement du masque
   Gosub ALIM_MASK From =GTRTFILMSK
  Endif

  # Pas d'affichage du masque si annulation du renouvellement unitaire
  If GTYPRNW<>"" & GTRTAASREF<>""
   TYPPRG=0
  Endif

Return

#------------------------------------------------------
$OUVRE_BATCH
  If dim(ABANDON)<0 : Global Integer   ABANDON : Endif
Return

#------------------------------------------------------
$DEBUT
 If !GBATCH
   # Restauration avant affichage fenêtre
   Transmask [M:DIA2] To [M:DIA]
   If ( [M:DIA]FLGCAL=G_NON ) Then : Grizo [M:DIA]FLGCAL : Affzo [M:DIA]FLGCAL : Endif
   Affzo [M:DIA]
 Endif
Return

#------------------------------------------------------
$OK
 # Sauvegarde écran suite à OK
 If !GBATCH  :  Transmask [M:DIA] To [M:DIA2] :  Endif
Return

#------------------------------------------------------
$CONTROLE
#
#                   GSERVEUR  GBATCH
# Interactif           0        0
# Saisie param.        0        1
# Lancement trt        1        0

  #-------------
  If ABANDON = G_OUI : Return : Endif

  # Contrôles à effectuer avant de lancer le traitement
  # ---------------------------------------------------
  #
  #  Toujours
  #
  #
  #  Batch
  #
  #
  #  Interactif
  #
  #
  #
  #

  # Lancement traitement batch :
  #   - Est-ce que l'opération de renouvellement existe toujours si elle est précisée
  #   - L'opération existe : annulation ou action compatible avec le statut de l'opération



Return

#------------------------------------------------------
# Aiguillage de l'exécution en fonction du flag
# annulation ou du paramétre GTYPRNW
#------------------------------------------------------
$EXEC
  If ABANDON= G_OUI : Return : Endif

  Local Char LMESSERR(255)
  Local Char LKEYERR(255)

  Local Integer NB_LUS  : NB_LUS=0
  Local Integer NB_MAJ  : NB_MAJ=0
  Local Integer NB_ERR  : NB_ERR=0

  If GTRTAASREF="" & dim([M:DIA]FLGCNL)>0
   If [M:DIA]FLGCNL=G_OUI
    GTYPRNW="RNWCAN"
   Else
    GTYPRNW="RNWACT"
   Endif
  Endif

  Case GTYPRNW
   When "RNWACT" : Gosub EXEC_ACT    # Validation du renouvellement
   When "RNWCAN" : Gosub EXEC_CAN    # Annulation du renouvellement
  Endcase

  If ABANDON=G_OUI : Return : Endif #Fq66544

  # Calcul des biens fils et père si appel de la validation ou de l'annulation par les bouton correspondant de la fonction
  # de préparation du renouvellement.

  If dim([M:RWP0]CPY)>0 & GOK
   # Récupération du paramètre "CALAUTVAL"
   Local Char ACALCULER(10)
   Call PARAM([M:RWP0]CPY,"CALAUTVAL", ACALCULER) From ADOVAL
   # Si CALAUTVAL vaut Oui pour la société courante, on recalcule automatiquement les biens père et le bien fils
   If ACALCULER=num$(G_OUI)
    Call TEMPON("C") From GESECRAN
    Local Integer ERROR
    Call CALCULER_BIEN ([M:RWP0]CPY, [M:RWP0]RNWAASREF, ERROR) From GLOBI
    If !ERROR
     Local Integer I_MOTH
     For I_MOTH=1 To [M:RWP0]NBMOTH
      Call CALCULER_BIEN ([M:RWP0]CPY, [M:RWP0]MOTHAASREF(I_MOTH-1), ERROR) From GLOBI
      If ERROR : Break : Endif
     Next I_MOTH
    Endif
    Call TEMPOFF From GESECRAN
   Endif
  Endif

Return

#------------------------------------------------------
# ANNULATION DE RENOUVELLEMENT
# ============================
#
# 1. Bien renouvelant (bien fils) :
#      1.1. Raz des infos reçues des pères
#      1.2. RNWDONFLG repasse à G_NON
#      1.3. Plan de caducité repasse à SA
# 2. Biens renouvelés :
#      2.1. Annulation de la sortie (la sortie prend en
#      2.2. charge le RAZ des infos transmises)
#      2.3. Raz du champ RNWAASREF
# 3. Traitement de 'opération de renouvellement
#------------------------------------------------------
$EXEC_CAN
If 1=1
 # PARTIE COMMUNE
 If 1=1

  #> Création des variables locales nécessaires au traitement

  Local Char    LSAVCCNREF
  Local Integer LRUPCCNREF
  Local Integer LNBTOTS
  Local Decimal LNBTRTS
  Local Char    LUPDRNWVAL(1) : # Valeur du paramètre LUPDRNWVAL FQ95049

  #> Demande de confirmation de l'annulation du renouvellement (En intéractif seulement)

  If GACTSILENCE<>G_OUI & GTRTAASREF<>""
   Local Integer OK
   Call OUINON(mess(750,GML_MSGFAS,1),OK) From GESECRAN #"Annulation de la précédente opération de renouvellement. Confirmez-vous ?"
   If OK<>G_OUI :  ABANDON=G_OUI : Return : Endif #fq66544
  Endif
  If GACTSILENCE<>G_OUI & GTRTAASREF<>"" & !GSERVEUR
   Call TEMPON("A") From GESECRAN
  Endif

  #> Ouverture des tables

  If !clalev([F:RWPS]) : Local File RNWPREP    [RWPS]  : Endif
  If !clalev([F:RWPF]) : Local File RNWPREP    [RWPF]  : Endif
  If !clalev([F:ACM])  : Local File APLCOM     [ACM]   : Endif
  If !clalev([F:MFAS]) : Local File FXDASSETS  [MFAS]  : Endif : # FQ95049

  #> Chargement de l'environnement global de la société

  If GTRTAASREF<>""
   If [F:FAS]AASREF<>GTRTAASREF
    Read [F:FAS]FAS0=GTRTAASREF
   Endif
   GSOCIETE=[F:FAS]CPY
  Else
   GSOCIETE=[M:DIA]CPY
  Endif

  If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif
  Call CHARGE_ENVIRONNEMENT () From GLOFCYCPY

  Call PARAM(GSOCIETE,"UPDRNWVAL",LUPDRNWVAL) From ADOVAL : # FQ95049
  If LUPDRNWVAL<>"2" : LUPDRNWVAL="1" : Endif

  #> Ouverture de la trace

  If (GACTSILENCE <> G_OUI ) & GTRTAASREF="" Then
    If !GSERVEUR : Call OUVRE_TRACE (toupper(mess(772,GML_MSGFAS,1))) From LECFIC : Endif :   # "RENOUVELLEMENT BIENS EN CONCESSION"
  Endif

  #> Ecriture des paramètres et options dans l'en-tête de la trace

  Gosub TRC_ECR_PARM   From TRTCCNRNW
  Gosub TRC_ECR_ENTETE From TRTCCNRNW

  #> Exécution silencieuse : Création des variables globales : pour intercepter les erreurs dans le traitement.
  #                          Dimensionnement selon le nombre de biens concernés

  If ( GACTSILENCE = G_OUI ) Then
    If dim(G_MAJOK)>0      : Kill G_MAJOK    : Endif
    Global Integer G_MAJOK : G_MAJOK=G_OUI
    If dim(GT_OBJ_REF)>0 : Kill GT_OBJ_REF : Endif
    If dim(GT_OBJ_DES)>0 : Kill GT_OBJ_DES : Endif
    Global Char    GT_OBJ_REF(20)(1)
    Global Char    GT_OBJ_DES(20)(1)
    If [M:DIA]RNWAASREF<>""
     GT_OBJ_REF(0)=[M:DIA]RNWAASREF
     GT_OBJ_DES(0)=[M:DIA]RNWAASDES1
    Elsif [M:DIA]CCNREF<>""
     GT_OBJ_REF(0)=[M:DIA]CCNREF
     GT_OBJ_DES(0)=[M:DIA]CCNDES1
    Elsif [M:DIA]CCNUSR<>""
     GT_OBJ_REF(0)=[M:DIA]CCNUSR
     GT_OBJ_DES(0)=[M:DIA]ZCCNUSR
    Elsif [M:DIA]FCY<>""
     GT_OBJ_REF(0)=[M:DIA]FCY
     GT_OBJ_DES(0)=[M:DIA]ZFCY
    Endif
  Endif

 Endif #Fin partie commune

 # 1. TRAITEMENT DES BIENS FILS
 If 1=1

  #-1 Préparation du critère de sélection LREQ (appel silencieux classique ou appel action en passant une référence de bien renouvelant)

  Local Char LREQ(255)

  If GTRTAASREF=""
   LREQ="CPY=[M:DIA]CPY&FCY=[M:DIA]FCY&RNWDAT<>[0/0/0]"
   If [M:DIA]CCNUSR<>""    : LREQ+="&CCNUSR=[M:DIA]CCNUSR"       : Endif
   If [M:DIA]CCNREF<>""    : LREQ+="&CCNREF=[M:DIA]CCNREF"       : Endif
   If [M:DIA]RNWAASREF<>"" : LREQ+="&RNWAASREF=[M:DIA]RNWAASREF" : Endif
  Elsif GTRTAASREF<>""
   LREQ+='CPY="'+[F:FAS]CPY+'"&FCY="'+[F:FAS]FCY+'"&RNWAASREF="'+[F:FAS]AASREF+'"'
  Endif
  LREQ+="&RNWDONFLG=G_OUI"

  #-2 Sélection sur RWPS avec LREQ

  Filter [F:RWPS] Where evalue(LREQ)

  #> Exécution silencieuse : Création des variables globales
  If GACTSILENCE=G_OUI
    # Dimensionnement de G_LIS_ERR
    Local Integer NB_MAX_ERR : NB_MAX_ERR = rowcount([RWPS])
    If ( NB_MAX_ERR> 0 ) Then
      If dim(I_OBJ)>0      : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      If dim(G_LIS_ERR)>0  : Kill G_LIS_ERR  : Endif
      Global Char    GT_LIS_ERR(100)(NB_MAX_ERR+10)
    Endif
  Endif

  #> Exécution interactive : barre de progression
  If !GSERVEUR & GACTSILENCE<>G_OUI & GTRTAASREF=""
   For [F:RWPS]RWP2(4)
    LNBTOTS+=1
   Next
   Call OUVRE_BOITE(mess(772,GML_MSGFAS,1),LNBTOTS) From GESECRAN
   Call SET_BOITE(mess(772,GML_MSGFAS,1),LNBTOTS) From GESECRAN
  Endif

  #-3 Boucle sur les biens fils RWPS

  For [F:RWPS]RWP2(4)
   If !GSERVEUR & GACTSILENCE<>G_OUI & GTRTAASREF=""
    LNBTRTS+=1
    Call AFF_BOITE([F:RWPS]RNWAASREF-+"("+num$(LNBTRTS)+"/"+num$(LNBTOTS)+")",LNBTRTS,GOK) From GESECRAN
   Endif
   Gosub TRAITE_UN_BIEN_FILS_RNWCAN
  Next
  Filter [F:RWPS]

  If !GSERVEUR & GACTSILENCE<>G_OUI & GTRTAASREF=""
   Call FERME_BOITE From GESECRAN
  Endif

  #> Statistiques

  Gosub ECR_STAT From TRTCCNRNW

  #> Calcul de la société

  Gosub CAL_SOCIETE

  #> Fermeture de la trace

 #If !GSERVEUR and GACTSILENCE <> G_OUI & GTRTAASREF="" : Call LEC_TRACE() From LECFIC : Endif #fq62307
  If !GSERVEUR and GACTSILENCE <> G_OUI & GTRTAASREF="" : Call FERME_TRACE() From LECFIC : TRA=1 : Endif

  #> Fermeture de la boîte d'attente

  If GACTSILENCE<>G_OUI & GTRTAASREF<>"" & !GSERVEUR : Call TEMPOFF From GESECRAN : Endif

 Endif
Endif
Return


#------------------------------------------------------
# RENOUVELLEMENT
# ==============
# 1. Préparation du critère de sélection LREQ
# 2. Sélection sur RWPS avec LREQ
#
# 3. Boucle sur les biens fils RWPS
#   3.1+ Verrouillage opération de préparation de renouvellement
#   3.2+ Début transaction de mise à jour (sauf en mode silencieux)
#   3.3+ Sortie silencieuse des pères : identifiés par RNWAASREF=référence du bien fils
#     3.3.1o Si sortie ok (Les fonds ont été mis à jour sur les biens pères par la sortie)
#        3.3.1.1/ Boucle sur les pères RWPF pour totaliser les fonds
#        3.3.1.2/ Mise à jour du bien fils
#            - RNWDONFLG à oui
#            - Héritage
#            - Changement de méthode du plan de caducité SA => RA (Date de fin ?)
#            - Alimentation de la date de début d'amortissement du plan de caducité avec date de renouvellement régularisée par la règle de sortie
#        3.3.1.3/ Marquage opération de renouvellement comme effectuée RNWDONFLG à oui
#     3.3.2o Si sortie nok / fin du traitement de l'opération de renouvellement
#   3.4+ Commit / Rollback si transaction initiée par le traitement en fonction erreurs
#   3.5+ Déverrouillage opération de préparation de renouvellement
#
# 4. Début transaction de mise à jour (sauf en mode silencieux)
# 5. Delete des enregistrements de la table RWP marqués avec RNWDONFLG=G_OUI
# 6. Commit / Rollback si transaction initiée par le traitement en fonction erreurs
#
#------------------------------------------------------
$EXEC_ACT
 If 1=1

 # PARTIE COMMUNE
 If 1=1

  #> Création des variables locales nécessaires au traitement

  Local Char    LSAVCCNREF
  Local Integer LRUPCCNREF
  Local Integer LNBTOTS
  Local Decimal LNBTRTS
  Local Char    LUPDRNWVAL(1) : # Valeur du paramètre LUPDRNWVAL FQ95049

  #> Demande de confirmation de l'annulation du renouvellement (En intéractif seulement)

  If GACTSILENCE<>G_OUI & GTRTAASREF<>""
   Local Integer OK
   Call OUINON("Validation de l'opération de renouvellement. Confirmez-vous ?",OK) From GESECRAN #"Validation de l'opération de renouvellement. Confirmez-vous ?"
   If OK<>G_OUI :  ABANDON=G_OUI : Return : Endif #fq66544
  Endif
  If GACTSILENCE<>G_OUI & GTRTAASREF<>"" & !GSERVEUR
   Call TEMPON("V") From GESECRAN
  Endif

  #> Ouverture des tables

  If !clalev([F:RWPS]) : Local File RNWPREP   [RWPS]  : Endif
  If !clalev([F:RWPF]) : Local File RNWPREP   [RWPF]  : Endif
  If !clalev([F:ACM])  : Local File APLCOM    [ACM]   : Endif
  If !clalev([F:MFAS]) : Local File FXDASSETS [MFAS]  : Endif : # FQ95049

  #> Chargement de l'environnement global de la société

  If GTRTAASREF<>""
   If [F:FAS]AASREF<>GTRTAASREF
    Read [F:FAS]FAS0=GTRTAASREF
   Endif
   GSOCIETE=[F:FAS]CPY
  Else
   GSOCIETE=[M:DIA]CPY
  Endif

  If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif
  Call CHARGE_ENVIRONNEMENT () From GLOFCYCPY

  Call PARAM(GSOCIETE,"UPDRNWVAL",LUPDRNWVAL) From ADOVAL : # FQ95049
  If LUPDRNWVAL<>"2" : LUPDRNWVAL="1" : Endif

  #> Ouverture de la trace

  If (GACTSILENCE <> G_OUI ) & GTRTAASREF="" Then
    If !GSERVEUR : Call OUVRE_TRACE (toupper(mess(751,GML_MSGFAS,1))) From LECFIC : Endif :   # "RENOUVELLEMENT BIENS EN CONCESSION"
  Endif

  #> Ecriture des paramètres et options dans l'en-tête de la trace

  Gosub TRC_ECR_PARM   From TRTCCNRNW
  Gosub TRC_ECR_ENTETE From TRTCCNRNW

  #> Exécution silencieuse : Création des variables globales : pour intercepter les erreurs dans le traitement.
  #                          Dimensionnement selon le nombre de biens concernés

  If ( GACTSILENCE = G_OUI ) Then
    If dim(G_MAJOK)>0      : Kill G_MAJOK    : Endif
    Global Integer G_MAJOK : G_MAJOK=G_OUI
    If dim(GT_OBJ_REF)>0 : Kill GT_OBJ_REF : Endif
    If dim(GT_OBJ_DES)>0 : Kill GT_OBJ_DES : Endif
    Global Char    GT_OBJ_REF(20)(1)
    Global Char    GT_OBJ_DES(20)(1)
    If [M:DIA]RNWAASREF<>""
     GT_OBJ_REF(0)=[M:DIA]RNWAASREF
     GT_OBJ_DES(0)=[M:DIA]RNWAASDES1
    Elsif [M:DIA]CCNREF<>""
     GT_OBJ_REF(0)=[M:DIA]CCNREF
     GT_OBJ_DES(0)=[M:DIA]CCNDES1
    Elsif [M:DIA]CCNUSR<>""
     GT_OBJ_REF(0)=[M:DIA]CCNUSR
     GT_OBJ_DES(0)=[M:DIA]ZCCNUSR
    Elsif [M:DIA]FCY<>""
     GT_OBJ_REF(0)=[M:DIA]FCY
     GT_OBJ_DES(0)=[M:DIA]ZFCY
    Endif
  Endif
Endif #fin partie commune

 # TRAITEMENT DES BIENS FILS
 If 1=1
  #-1 Préparation du critère de sélection LREQ

  Local Char LREQ(255)
  If GTRTAASREF=""
   LREQ="CPY=[M:DIA]CPY&FCY=[M:DIA]FCY&RNWDAT<>[0/0/0]"
   If [M:DIA]CCNUSR<>""    : LREQ+="&CCNUSR=[M:DIA]CCNUSR"       : Endif
   If [M:DIA]CCNREF<>""    : LREQ+="&CCNREF=[M:DIA]CCNREF"       : Endif
   If [M:DIA]RNWAASREF<>"" : LREQ+="&RNWAASREF=[M:DIA]RNWAASREF" : Endif
  Elsif GTRTAASREF<>""
   LREQ+='CPY="'+[F:FAS]CPY+'"&FCY="'+[F:FAS]FCY+'"&RNWAASREF="'+[F:FAS]AASREF+'"'
  Endif
  LREQ+="&RNWDONFLG<>G_OUI"

  #-2 Sélection sur RWPS avec LREQ

  Filter [F:RWPS] Where evalue(LREQ)

  #> Exécution silencieuse : Création des variables globales
  If GACTSILENCE=G_OUI
    # Dimensionnement de G_LIS_ERR
    Local Integer NB_MAX_ERR : NB_MAX_ERR = rowcount([RWPS])
    If ( NB_MAX_ERR> 0 ) Then
      If dim(I_OBJ)>0      : Kill I_OBJ      : Endif
      Global Integer I_OBJ   : I_OBJ=0
      If dim(G_LIS_ERR)>0  : Kill G_LIS_ERR  : Endif
      Global Char    GT_LIS_ERR(100)(NB_MAX_ERR+10)
    Endif
  Endif

  #> Exécution interactive : barre de progression
  If !GSERVEUR & GACTSILENCE<>G_OUI & GTRTAASREF=""
   For [F:RWPS]RWP2(4)
    LNBTOTS+=1
   Next
   Call OUVRE_BOITE(mess(751,GML_MSGFAS,1),LNBTOTS) From GESECRAN
   Call SET_BOITE(mess(751,GML_MSGFAS,1),LNBTOTS) From GESECRAN
  Endif

  #-3 Boucle sur les biens fils RWPS

  For [F:RWPS]RWP2(4)
   If !GSERVEUR & GACTSILENCE<>G_OUI & GTRTAASREF=""
    LNBTRTS+=1
    Call AFF_BOITE([F:RWPS]RNWAASREF-+"("+num$(LNBTRTS)+"/"+num$(LNBTOTS)+")",LNBTRTS,GOK) From GESECRAN
   Endif
   Gosub TRAITE_UN_BIEN_FILS_RNW
  Next
  Filter [F:RWPS]

  If !GSERVEUR & GACTSILENCE<>G_OUI & GTRTAASREF=""
   Call FERME_BOITE From GESECRAN
  Endif

  #> Statistiques

  Gosub ECR_STAT From TRTCCNRNW

  #> Calcul de la société

  Gosub CAL_SOCIETE

  #> Fermeture de la trace

 #If !GSERVEUR and GACTSILENCE <> G_OUI : Call LEC_TRACE() From LECFIC : Endif #fq62307
  If !GSERVEUR and GACTSILENCE <> G_OUI : Call FERME_TRACE() From LECFIC : TRA=1 : Endif

  #> Fermeture de la boîte d'attente

  If GACTSILENCE<>G_OUI & GTRTAASREF<>"" & !GSERVEUR : Call TEMPOFF From GESECRAN : Endif

 Endif #Fin traitement des biens fils

 Endif #Fin EXEC_ACT
Return

#------------------------------------------------------
$SORTIE
  If dim(GACTSILENCE)>0     : Kill GACTSILENCE     : Endif
  If dim(GTRTFILMSK)>0      : Kill GTRTFILMSK      : Endif
  If dim(GTYPRNW)>0         : Kill GTYPRNW         : Endif
  If dim(GTRTAASREF)>0      : Kill GTRTAASREF      : Endif
Return

#------------------------------------------------------
$TERMINE
  If dim(ABANDON)>0    : Kill ABANDON    : Endif
Return

#------------------------------------------------------
$APRES_MODIF
Return

#------------------------------------------------------
$SETBOUT
  If ( [M:DIA]CPY = "" ) Then
    Call VIREBOUT (CHBOU,"O") From GOBJET
  Endif
Return

######################################################################################
# ROUTINES COMMUNES
######################################################################################

#------------------------------------------------------
$INIT_COMM
  If !clalev([F:CCN])   : Local File CONCESSION  [CCN]  : Endif
  If !clalev([F:FAS])   : Local File FXDASSETS   [FAS]  : Endif
  If !clalev([F:FASS])  : Local File FXDASSETS   [FASS] : Endif
  If !clalev([F:DEP])   : Local File DEPREC      [DEP]  : Endif
  If !clalev([F:DEPI])  : Local File DEPREC      [DEPI] : Endif
  If !clalev([F:CNX])   : Local File CONTEXT     [CNX]  : Endif

  If !clalev([M:DIA])   : Local Mask CCNRNW  [DIA]      : Endif
  If !clalev([M:DIA2])  : Local Mask CCNRNW  [DIA2]     : Endif

  Raz [M:DIA]
  Raz [M:DIA2]

  # Valeurs par défaut
  [M:DIA2]FLGSIM = G_OUI
  [M:DIA2]FLGCAL = G_NON
 #[M:DIA]FLGSIM  = G_OUI

  Global Integer G_ACTION
  Global Integer GACTSILENCE         # Action de renouvellement exécutée en mode silencieux [oui / non]
  Global Char    GTRTFILMSK          # Traitement contenant l'alimentation du masque DIA en cas d'exécution en mode silencieux
  Global Char    GTYPRNW             # Type d'action de renouvellement [RNWACT / RNWCAN]
  Global Char    GTRTAASREF          # Référence du bien fils dont on veut annuler le renouvellement si GTYPRNW = RNWCAN

  # Récupération des paramètres de l'action
  Gosub GET_PARAMETRES From TRTCCNRNW
Return

#------------------------------------------------------
$GET_PARAMETRES

 #-> PARAM(1) - Mode silencieux oui / non
 #-> PARAM(2) - En silencieux : Traitement de remplissage du masque de saisie
 #-> PARAM(3) - Type renouvellement : RNWACT (Action de renouvellement) ou RNWCAN (Annulation de renouvellement)
 #-> PARAM(4) - A ne renseigner que si PARAM(3) vaut "RNWCAN" ou "RNWACT" : contient la référence du bien fils dont il faut annuler le renouvellement

 If ( PARAM(1)<>"" and PARAM(2)<>"" ) Then
   GACTSILENCE = val(PARAM(1))
   GTRTFILMSK  = PARAM(2)
 Else
   GACTSILENCE = G_NON
   GTRTFILMSK  = "....."
 Endif

 GTYPRNW    = PARAM(3)
 GTRTAASREF = PARAM(4)

Return

#------------------------------------------------------
$TRT_ERREUR
 If GACTSILENCE=G_OUI
  GT_LIS_ERR(I_OBJ) = LMESSERR
  G_MAJOK           = G_NON
 Else
  Local Char LIGNE(115)
  LIGNE = LMESSERR
  Call ECR_TRACE("", 0,LIGNE,1,1)         From TRACEABX3
 Endif
Return

#------------------------------------------------------
# Traite l'operation de renouvellement pour un bien
# fils
#------------------------------------------------------
$TRAITE_UN_BIEN_FILS_RNW
If 1=1

   #> Gestion de la rupture sur le contrat de concession pour trace
   If GACTSILENCE<>G_OUI & [M:DIA]FLGDET=G_OUI & GTRTAASREF=""
    # Infos du bien fils à mémoriser
    Read [F:FASS]FAS0=[F:RWPS]RNWAASREF
    If fstat
     GOK=0
     LKEYERR = [F:RWPS]RNWAASREF
     LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Read [F:FASS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
    Endif
    # Rupture
    If LSAVCCNREF<>[F:RWPS]CCNREF
     LRUPCCNREF=1
     LSAVCCNREF=[F:RWPS]CCNREF
    Else
     LRUPCCNREF=0
    Endif
    #Trace
    If LRUPCCNREF=1
     Gosub TRC_ECR_CCNREF From TRTCCNRNW
    Endif
    Gosub TRC_ECR_ET_FILS From TRTCCNRNW
   Endif

   #-3.1.1 -  Verrouillage opération de préparation de renouvellement

   Local Char SYMBRNW : SYMBRNW="RWP~"+[F:RWPS]RNWAASREF
   Lock =SYMBRNW
   If fstat
    LMESSERR="[F:RWP]"-[F:RWPS]RNWAASREF-mess(226,GML_MSGFAS,1)
    Gosub TRT_ERREUR From TRTCCNRNW #@ERR
    Goto NEXT_RNWAASREF2
   Else
    NB_LUS+=1
   Endif

   #-3.1.2 - Verrouillage des biens de l'opération de renouvellement

   Local Integer RERR
   #> Bien fils
   If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:RWPS]CPY, [F:RWPS]RNWAASREF, 0) = 0 ) Then
    RERR=1 : GOK=0
    LMESSERR="[F:FAS]"-[F:RWPS]RNWAASREF-mess(226,GML_MSGFAS,1)
    Gosub TRT_ERREUR From TRTCCNRNW #@err
    Goto NEXT_RNWAASREF2
   Endif
   #> Biens père
   For [RWPF] Where ( CPY=[RWPS]CPY & FCY=[RWPS]FCY & CCNREF=[RWPS]CCNREF & RNWAASREF=[RWPS]RNWAASREF )
    If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:RWPF]CPY, [F:RWPF]MOTHAASREF, 0) = 0 ) Then
     RERR = 1 : GOK=0
     LMESSERR="[F:FAS]"-[F:RWPF]MOTHAASREF-mess(226,GML_MSGFAS,1)
     Gosub TRT_ERREUR From TRTCCNRNW #@err
     Break
    Endif
   Next
   #En cas d'erreur, il faut unlocker les biens déjà locké et l'opération de renouvellement
   If RERR
    Unlock = SYMBRNW
    Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
    Goto NEXT_RNWAASREF2
   Endif

   #-3.2 Début transaction de mise à jour de l'opération de renouvellement

   If ( [M:DIA]FLGSIM <> G_OUI ) Then
     # Traitement en réel
     Local Integer BCMTEXT
     If ( GACTSILENCE = G_OUI ) Then
       # Traitement silencieux
       BCMTEXT = adxlog
     Else
       If dim(GRNWACT)<0 : Global Integer GRNWACT : Endif
       BCMTEXT = 0
     Endif
     If ( !BCMTEXT) Then
      Trbegin [ACM]
       [C]TRTACTMET+=1
      Commit
      GTRANS = 1 : # Pour signaler que c'est ce traitement qui gère le commitment et non pas la transaction objet métier
      GOK    = 1
      Trbegin [FAS], [RWPF]
     Else
       # Si un commitment control a été initialisé on considère que c'est l'appelant qui le gère
     Endif
   Endif

   #-3.3 Mise à jour de la valeur de renouvellement du plan de provision des biens père si UPDRNWVAL vaut Oui
   If LUPDRNWVAL = num$(G_OUI) : # FQ95049
     Gosub MAJ_RNWVAL_RPR
   Endif

   #-3.4 Sortie des biens pères
   If GTRTAASREF="" : [F:FAS]=[F:FASS] : Endif
   Local Integer RETOUR
   Call LAUNCH_SILTRT("FASISS","TRTCCNRNW",RETOUR) From TRCPROCOM
   If (RETOUR) Then
     NB_ERR +=1
     GOK=0
     LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-s/p[LAUNCH_SILTRT] RETOUR"-num$(RETOUR) : Gosub TRT_ERREUR  #@err
   Endif

   If GOK

    #> Calcul de la somme des fonds à transmettre au bien renouvelant

    Global Decimal GCCNTRFCUM, GCCNTRFCAD, GCCNTRFGRT, GCCNTRFRPR, GCCNCADDEV

    For [RWPF] Where ( CPY=[RWPS]CPY & FCY=[RWPS]FCY & CCNREF=[RWPS]CCNREF & RNWAASREF=[RWPS]RNWAASREF )
     Read [F:FAS]FAS0 = [F:RWPF]MOTHAASREF
     If !fstat
      GCCNTRFCAD+=[F:FAS]CCNTRFCAD
      GCCNTRFGRT+=[F:FAS]CCNTRFGRT
      GCCNTRFRPR+=[F:FAS]CCNTRFRPR
      GCCNTRFCUM+=[F:FAS]CCNTRFCUM
      GCCNCADDEV+=[F:FAS]CCNCADDEV
      [F:FAS]CCNCADDEV=0
      Rewrite [F:FAS] Curr
      If fstat
       GOK=0
       LKEYERR = [F:FAS]AASREF
       LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Rewrite [F:FAS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
      Endif

      #> Trace
      If GACTSILENCE<>G_OUI & [M:DIA]FLGDET=G_OUI
       If dim(LPREMLIN)>0
        LPREMLIN=0
       Elsif dim(LPREMLIN)<0
        Local Integer LPREMLIN : LPREMLIN=1
       Endif
       Gosub TRC_ECR_LIST_BIEN From TRTCCNRNW
      Endif
     Endif
    Next

    #> Mise à jour des informations sur le bien renouvelant
    #  ====================================================

    Read [F:FAS]FAS0=[F:RWPS]RNWAASREF
    If fstat
     GOK=0
     LKEYERR = [F:RWPS]RNWAASREF
     LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Read [F:FAS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
    Endif

    If GOK
     If [M:DIA]FLGSIM<>G_OUI

      #> Alimentation du fonds initial

      [F:FAS]CCNINICUM=GCCNTRFCUM
      [F:FAS]RVERPRVAL=GCCNTRFRPR
      [F:FAS]RNWDONFLG=G_OUI

      #> Alimentation de l'écart de caducité

      Read [F:DEPI]DEP0=[F:FAS]AASREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
      If fstat
       GOK=0
       LKEYERR = [F:FAS]AASREF+";"+num$(G_CCNPLNIND)+";"+GFINEXECPF+";"+GFINPERCPF
       LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Read [F:DEPI] fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
      Endif
      [F:FAS]CCNCADDEV=[F:DEPI]DPRBAS+GCCNCADDEV

      #> Modification de la base d'amortissement du plan de caducité et alimentation et du fonds de caducité

      Read [F:DEP]DEP0=[F:FAS]AASREF;G_CCNPLNCAD;GFINEXECPF;GFINPERCPF
      If fstat
       GOK=0
       LKEYERR = [F:FAS]AASREF+";"+num$(G_CCNPLNCAD)+";"+GFINEXECPF+";"+GFINPERCPF
       LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Read [F:DEP] fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
      Endif


      # Définition de la valeur pivot pour le calcul de l'excédent de caducité
      Local Decimal LSEUILCAD : LSEUILCAD=0
      GPOINT = "RNWSEUILCAD" : Gosub ENTREE From EXEFNC
      If GOK<1 : Return : Endif

      If [F:DEP]DPRBAS>=[F:FAS]CCNINICUM+LSEUILCAD
       [F:DEP]DPRBAS     = [F:DEP]DPRBAS-[F:FAS]CCNINICUM
       [F:FAS]CCNCADEXC  = 0
      Else
       [F:FAS]CCNCADEXC  = [F:FAS]CCNINICUM-([F:DEP]DPRBAS-LSEUILCAD)
       [F:DEP]DPRBAS     = LSEUILCAD
      Endif
      [F:DEP]BSEVAL      = [F:DEP]DPRBAS

      [F:DEP]TRFCADCUM   = [F:FAS]CCNINICUM - [F:FAS]CCNCADEXC

      #> Changement de méthode sur le plan de caducité RA date de début = date de renouvellement régularisée

      Local Date    LSTRDPRDAT
      Local Integer LCDRET

      # Détermination de la date de début d'amortissement du plan de caducité en fonction de la règle de sortie

      Case [F:RWPS]ISSDATRUL
       When GVML_IRJPREC  : LSTRDPRDAT=[F:RWPS]RNWDAT
       When Default       : LSTRDPRDAT=[F:RWPS]RNWDAT+1
      Endcase

      If [F:FAS]TPAFLG<>G_OUI
       Call FASMTC_SA_RA ("FAS", "DEP", G_DPMRA, LSTRDPRDAT, G_OUI, GFINPERCPF, LCDRET) From TRTFAS
       If LCDRET
         GOK = 0
         LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-s/p[FASMTC_SA_RA] LCDRET"-num$(LCDRET) : Gosub TRT_ERREUR #@err
       Endif
      Endif

      If GOK
       GPOINT = "RNWPLNCAD" : Gosub ENTREE From EXEFNC  # PE pour pouvoir modifier les infos du plan de caducité : renouvellement
       If GOK
        Rewrite [F:DEP]
        If fstat
         GOK=0
         LKEYERR = [F:DEP]AASREF+";"+num$([F:DEP]DPRPLN)+";"+[F:DEP]FIYENDDAT+";"+[F:DEP]PERENDDAT
         LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Rewrite [F:DEP] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
        Endif

        [F:FAS]FLGCLC                = G_OUI
        [F:FAS]FLGCNXCLC(G300CPFI-1) = G_OUI
        [F:FAS]FLGRPRCLC             = G_OUI

        Rewrite [F:FAS]
        If fstat
         GOK=0
         LKEYERR = [F:FAS]AASREF
         LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Rewrite [F:FAS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
        Endif
       Endif
      Endif

      If GOK & 1=1
       #> Génération de l'événement de renouvellement
       Call GENER_EVE ( GVML_OMBIEN, [F:FAS]CPY, [F:FAS]FCY, [F:FAS]AASREF, 0, "FASRNW", GFINPERCPF, [0/0/0], LCDRET ) From GENEVE
       If (LCDRET > 20) Then
        GOK = 0
        LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-s/p[GENER_EVE] LCDRET"-num$(LCDRET) : Gosub TRT_ERREUR #@err
       Endif
      Endif
     Endif

     If dim(GCCNTRFCAD)>0 : Kill GCCNTRFCAD : Endif
     If dim(GCCNTRFGRT)>0 : Kill GCCNTRFGRT : Endif
     If dim(GCCNTRFRPR)>0 : Kill GCCNTRFRPR : Endif
     If dim(GCCNCADDEV)>0 : Kill GCCNCADDEV : Endif

    Endif

    #> Mise à jour du flag RNWDONFLG sur la préparation de l'opération de renouvellement

    If GOK &[M:DIA]FLGSIM<>G_OUI
     Update [F:RWPF] Where ( CPY=[RWPS]CPY & FCY=[RWPS]FCY & CCNREF=[RWPS]CCNREF & RNWAASREF=[RWPS]RNWAASREF ) With RNWDONFLG=G_OUI
     If fstat
      GOK=0
      LKEYERR = [F:RWPS]CPY+";"+[F:RWPS]FCY+";"+[F:RWPS]CCNREF+";"+[F:RWPS]RNWAASREF
      LMESSERR="$TRAITE_UN_BIEN_FILS_RNW-Update [F:RWPF] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
     Endif
    Endif

   Endif

   #-3.5 Commit / Rollback si transaction initiée par le traitement en fonction erreurs

   If ( [M:DIA]FLGSIM <> G_OUI and !BCMTEXT ) Then
     # Si traitement en réel et commitment control à gérer
     If ( GOK ) Then
       Commit
     Else
       Rollback
     Endif
   Endif

   If GOK : NB_MAJ+=1 : Endif

   $NEXT_RNWAASREF1

   #-3.6.1 Déverrouillage opération de préparation de renouvellement et biens

   Unlock = SYMBRNW
   Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS

   $NEXT_RNWAASREF2

   #-3.6.2 Trace

   If GACTSILENCE<>G_OUI & [M:DIA]FLGDET=G_OUI
    LIGNE=string$(115,"=")
    Call ECR_TRACE("", 0,LIGNE,0,1)         From TRACEABX3
   Endif

Endif
Return

#------------------------------------------------------ FQ95049
# Mise à jour de la valeur de renouvellement des biens pères (renouvelés) dans
# l'enregistrement du plan de provision de la période courante
#------------------------------------------------------
$MAJ_RNWVAL_RPR
  Local Decimal LTOT_BASES_I  : # Cumul des bases du plan Industriel des biens renouvelés
  Local Decimal LBASE_I       : # Base du plan Industriel du bien renouvelant
  Local Decimal LRELIQUAT     : # Reliquat de la répartition de la base du plan industriel du bien renouvelant sur les biens renouvelés
  Local Integer LNBMOTHAASREF : # Nombre de biens renouvelés
  Local Decimal LMNT          : # Zone de travail
  Local Decimal LTOT_RNW_I    : # CFF 2014.10.13: Cumul des valeurs de renouvellements des biens renouvelés

  If !clalev([F:RPR]) : Local File CCNRPR [RPR] : Endif

  LTOT_BASES_I  = 0
  LNBMOTHAASREF = 0
  LTOT_RNW_I    = 0   : # CFF 2014.10.13

  # Cumul des bases du plan industriel des biens pères (renouvelés) pour pouvoir prorater par la suite
  For [RWPF] Where ( CPY=[RWPS]CPY & FCY=[RWPS]FCY & CCNREF=[RWPS]CCNREF & RNWAASREF=[RWPS]RNWAASREF )
    Read [F:DEPI]DEP0=[RWPF]MOTHAASREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
    If fstat
     GOK=0
     LKEYERR = [RWPF]MOTHAASREF+";"+num$(G_CCNPLNIND)+";"+GFINEXECPF+";"+GFINPERCPF
     LMESSERR="$MAJ_RNWVAL_RPR-Read [F:DEPI] (1) fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
     Break
    Endif
    LTOT_BASES_I  += [F:DEPI]DPRBAS
    # CFF 2014.10.13: somme de la VR des biens renouvelés
    Read [F:FAS]FAS0=[RWPF]MOTHAASREF
    If fstat
     GOK=0
     LKEYERR = [RWPF]MOTHAASREF
     LMESSERR="$MAJ_RNWVAL_RPR-Read [F:FAS] (1) fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
     Break
    Endif

    # Cumul du montant de renouvellement
    If [F:FAS]RNWVALFLG = G_OUI
      # Le montant de renouvellementest est forcé, on le prend dans la table FXDASSETS du bien
      LTOT_RNW_I    += [F:FAS]RNWVAL
    Else
      # FQ105441 : Lecture du montant sur RPR si RNWVALFLG non forcé (dans ce cas le champ RNWVAL de FXDASSETS est à zéro)
      Read [F:RPR]RPR0=[RWPF]MOTHAASREF;GFINEXECPF;GFINPERCPF
      If fstat
       GOK=0
       LKEYERR = [RWPF]MOTHAASREF+";"+GFINEXECPF+";"+GFINPERCPF
       LMESSERR="$MAJ_RNWVAL_RPR-Read [F:RPR] (1) fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
       Break
      Endif
      LTOT_RNW_I += [F:RPR]ENDRNWVAL
    Endif
    LNBMOTHAASREF += 1
  Next

  # FQ105441 : Gestion propre de la sortie de boucle en cas d'erreur
  If GOK=0 : Return : Endif

  # Lecture du plan industriel du bien fils (renouvelant) pour connaitre sa base
  Read [F:DEPI]DEP0=[F:RWPS]RNWAASREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
  If fstat
   GOK=0
   LKEYERR = [F:RWPS]RNWAASREF+";"+num$(G_CCNPLNIND)+";"+GFINEXECPF+";"+GFINPERCPF
   LMESSERR="$MAJ_RNWVAL_RPR-Read [F:DEPI] (2) fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
   Return
  Endif
  LBASE_I   = [F:DEPI]DPRBAS
  LRELIQUAT = [F:DEPI]DPRBAS


  # Répartition de la base industrielle du bien fils (renouvelant) sur les valeurs de renouvellement des biens pères (renouvelés)
  # en proratant par rapport aux bases des plans industriels des biens pères (renouvelés)
  For [RWPF] Where ( CPY=[RWPS]CPY & FCY=[RWPS]FCY & CCNREF=[RWPS]CCNREF & RNWAASREF=[RWPS]RNWAASREF )
    # CFF 2014.10.13: Si provision <= acquisition du bien renouvelant, pas de maj
    If LTOT_RNW_I <= LBASE_I
      # La provision des biens renouvelés est <= à la valeur d'acquisition du bien renouvelant.
      # On ne régularise pas la provision des biens renouvelés.
      # C'est la base de caducité du bien renouvelant qui va absorber le manque de provision.

      # FQ105441 : on met à 0 le champ de sauvegarde [F:RWPF]RNWVALFLGO pour ne rien faire lors de l'annulation
      [F:RWPF]RNWVALFLGO = 0
      Rewrite [F:RWPF]
      If fstat
        GOK=0
        LKEYERR = [F:RWPF]CPY+";"+[F:RWPF]FCY+";"+[F:RWPF]RNWAASREF+";"+[F:RWPF]MOTHAASREF
        LMESSERR="$MAJ_RNWVAL-Rewrite [F:RWPF] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
        Break
      Endif
    Else
      Read [F:DEPI]DEP0=[F:RWPF]MOTHAASREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
      If fstat
        GOK=0
        LKEYERR = [F:RWPF]MOTHAASREF+";"+num$(G_CCNPLNIND)+";"+GFINEXECPF+";"+GFINPERCPF
        LMESSERR="$MAJ_RNWVAL_RPR-Read [F:DEPI] (3) fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
        Break
      Endif

      If LNBMOTHAASREF = 1
        # Reliquat
        LMNT = LRELIQUAT
      Else
        Call GET_MNT_ARRONDI(([F:DEPI]DPRBAS * LBASE_I)/LTOT_BASES_I,[M:FPC]CURCPY,LMNT) From GLOBIENS
        LRELIQUAT -= LMNT
      Endif

      Read [MFAS]FAS0=[F:RWPF]MOTHAASREF
      If fstat
        GOK=0
        LKEYERR = [F:RWPF]MOTHAASREF
        LMESSERR="$MAJ_RNWVAL-Read [MFAS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
        Break
      Else
        # Sauvegarde de la valeur de renouvellement et du flag de forçage pour annulation éventuelle
        [F:RWPF]RNWVALO    = [F:MFAS]RNWVAL
        [F:RWPF]RNWVALFLGO = [F:MFAS]RNWVALFLG
        Rewrite [F:RWPF]
        If fstat
          GOK=0
          LKEYERR = [F:RWPF]CPY+";"+[F:RWPF]FCY+";"+[F:RWPF]RNWAASREF+";"+[F:RWPF]MOTHAASREF
          LMESSERR="$MAJ_RNWVAL-Rewrite [F:RWPF] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
          Break
        Endif

        # Mise à jour de la valeur de renouvellement et du flag de forçage sur le bien renouvellé
        [F:MFAS]RNWVAL    = LMNT
        [F:MFAS]RNWVALFLG = G_OUI
        Rewrite [F:MFAS]
        If fstat
          GOK=0
          LKEYERR = [F:MFAS]MOTHAASREF
          LMESSERR="$MAJ_RNWVAL-Rewrite [F:MFAS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
          Break
        Endif
      Endif

      Gosub CALCUL_BIEN

      LNBMOTHAASREF -= 1
    Endif
  Next
Return

$CALCUL_BIEN

  Local Integer PTABCNT(G300MAX) : PTABCNT(0)=1

  #-- Ouverture écran CALDIV
  If clalev([M:DIV]) =0  : Local Mask CALDIV      [DIV]   :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2     [DIV2]  :  Endif             : # Infos diverses FQ77877

  [M:DIV]TRTDEM    = "CALBCO"
  # Concessions gérée - FQ54343
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN
  # Localisation Polonaise - FQ67577
  Local Integer BGESKPL : BGESKPL = func AFNC.ACTIV("KPL") : [M:DIV]BACTKPL = BGESKPL
  #-- Création des globales
  Gosub CALCUL_CRT_GLOBALES From =G_GLOB

  #--
  # Initialisation des constantes
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4
  [M:DIV]CSTLVLMAX = 11
  [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ59941
  [M:DIV]TRTLVL    = 0                    : # Niveau atteint dans le traitement
  [M:DIV]BDEBUG    = 2                    : # Debug

  Raz [M:DIV]LVLID : [M:DIV]LVL = 0 : [M:DIV]LVLLIB= ".CALCULER_BIEN" : Gosub CAL_ADDLVL From =G_GLOB0
  [M:DIV]ERROR   = 0
  [M:DIV]BFS1OPN = 0
  [M:DIV]BFS2OPN = 0
  [M:DIV]SOC     = [F:DEPI]CPY                    : # Société courante
  [M:DIV]PROPLN  = ""                      : # Plan de production à charger
  G_BERRDER      = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BONUS   = 0                       : # Bonus russe à charger FQ59941

  Global Integer G_CLCTRC
  G_CLCTRC       = 0                       : # 0 : pas de trace/1 : trace

  # Ouverture des fichiers
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société

  # Ouverture Fichier  Bien comptable , Plan d'amortissement
  If clalev([F:WFAS])=0  : Local File FXDASSETS     [WFAS]  :  Endif        : # Biens comptables
  If clalev([F:WDEP])=0  : Local File DEPREC        [WDEP]  :  Endif        : # Plans d'amortissement
  If clalev([F:DEPC])=0  : Local File DEPREC        [DEPC]   :  Endif       : # DEPREC courant FQ79813
  If clalev([F:DEPS])=0  : Local File DEPREC        [DEPS]   :  Endif       : # DEPREC suivant FQ79813
  If clalev([F:SEPC])=0  : Local File DEPREC        [SEPC]   :  Endif       : # DEPREC courant FQ79813
  If clalev([F:SEPS])=0  : Local File DEPREC        [SEPS]   :  Endif       : # DEPREC suivant FQ79813
  # FQ54343
  If ([M:DIV]BACTCCN) Then
    If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
    If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement FQ79813
    If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement FQ79813
  Endif

  [M:DIV]LVLLIB = ".CALCUL_SOCIETE_PREPARE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Gosub CALCUL_SOCIETE_PREPARE From =G_GLOB

  [M:DIV]LVLLIB = "0.CAL_LEC_BIEN" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_LEC_BIEN([F:DEPI]AASREF) From =G_GLOB0

  [M:DIV]LVLLIB = ".CALCUL_BIEN" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CALCUL_BIEN(PTABCNT) From GLOBI

  [M:DIV]LVLLIB = ".EXPLOITER_CALCUL_BIEN" : Gosub CAL_ADDLVL  From =G_GLOB0
  Local Integer    PTABPLN(0..G301MAX-1)  : # FQ79856
  Call  EXPLOITER_CALCUL_BIEN ( PTABCNT, PTABPLN) From =G_GLOB  : # FQ79856
Return

#------------------------------------------------------
# Traite l'annulation de l'opération de renouvellement
# pour un bien fils
#------------------------------------------------------
$TRAITE_UN_BIEN_FILS_RNWCAN
If 1=1

  #> Gestion de la rupture sur le contrat de concession pour trace

  If GACTSILENCE<>G_OUI & [M:DIA]FLGDET=G_OUI
   # Infos du bien fils à mémoriser
   Read [F:FASS]FAS0=[F:RWPS]RNWAASREF
   If fstat
    GOK=0
    LKEYERR = [F:RWPS]RNWAASREF
    LMESSERR="$TRAITE_UN_BIEN_FILS_RNWCAN-Read [F:FASS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
   Endif
   # Rupture
   If LSAVCCNREF<>[F:RWPS]CCNREF
    LRUPCCNREF=1
    LSAVCCNREF=[F:RWPS]CCNREF
   Else
    LRUPCCNREF=0
   Endif
   #Trace
   If LRUPCCNREF=1
    Gosub TRC_ECR_CCNREF_CAN From TRTCCNRNW
   Endif
  Endif

  # Verrouillage opération de préparation de renouvellement

  Local Char SYMBRNW : SYMBRNW="RWP~"+[F:RWPS]RNWAASREF
  Lock =SYMBRNW
  If fstat
   LMESSERR="[F:RWP]"-[F:RWPS]RNWAASREF-mess(226,GML_MSGFAS,1)
   Gosub TRT_ERREUR From TRTCCNRNW #@ERR
   Goto NEXT_RNWAASREF2
  Else
   NB_LUS+=1
  Endif

  # Verrouillage des biens de l'opération de renouvellement

  Local Integer RERR
  #> Bien fils
  If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:RWPS]CPY, [F:RWPS]RNWAASREF, 0) = 0 ) Then
   RERR=1 : GOK=0
   LMESSERR="[F:FAS]"-[F:RWPS]RNWAASREF-mess(226,GML_MSGFAS,1)
   Gosub TRT_ERREUR From TRTCCNRNW #@err
   Goto NEXT_RNWCANAASREF2
  Endif
  #> Biens père
  For [RWPF] Where ( CPY=[RWPS]CPY & FCY=[RWPS]FCY & CCNREF=[RWPS]CCNREF & RNWAASREF=[RWPS]RNWAASREF )
   If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:RWPF]CPY, [F:RWPF]MOTHAASREF, 0) = 0 ) Then
    RERR = 1 : GOK=0
    LMESSERR="[F:FAS]"-[F:RWPF]MOTHAASREF-mess(226,GML_MSGFAS,1)
    Gosub TRT_ERREUR From TRTCCNRNW #@err
    Break
   Endif
  Next
  #En cas d'erreur, il faut unlocker les biens déjà locké et l'opération de renouvellement
  If RERR
   Unlock = SYMBRNW
   Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
   Goto NEXT_RNWCANAASREF2
  Endif

  #> Gestion de la transaction de mise à jour

  Local Integer BCMTEXT
  If ( GACTSILENCE = G_OUI ) Then
    # Traitement silencieux
    BCMTEXT = adxlog
  Else
    If dim(GRNWCAN)<0 : Global Integer GRNWCAN : Endif
    BCMTEXT = 0
  Endif
  If ( !BCMTEXT) Then
   Trbegin [ACM]
    [C]TRTACTMET+=1
   Commit
   GTRANS = 1
   GOK    = 1
   Trbegin [FAS]
  Else
    # Si un commitment control a été initialisé on considère que c'est l'appelant qui le gère
  Endif

 #1. MISE A JOUR DU BIEN FILS
 If 1=1

  #> Relecture du bien comptable si nécessaire

  If [F:FAS]AASREF<>[F:RWPS]RNWAASREF
   Read [F:FAS]FAS0=[F:RWPS]RNWAASREF
  Endif

  #> Traitements suivants non exécutés en simulation.

  If (GTRTAASREF<>"") | (GTRTAASREF="" & [M:DIA]FLGSIM<>G_OUI)

   #> Raz des infos du bloc Héritage
   #  ------------------------------

   [F:FAS]CCNINICUM=0
   [F:FAS]CCNCADDEV=0
   [F:FAS]RVERPRVAL=0
   [F:FAS]CCNCADEXC=0

   [F:FAS]RNWDONFLG=G_NON

   #> Evénement d'annulation de renouvellement
   #  ----------------------------------------

   If !clalev([F:EVT0])  : Local File EFASRNW     [EVT0] : Endif
   Filter [F:EVT0] Where REF=[F:FAS]AASREF
   Read [F:EVT0] Last
   If !fstat
    Local Integer LCDRET
    Call EXTOURNE_EVE(GVML_OMCCN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,"FASRNW",GFINPERCPF,LCDRET) From GENEVE
    If LCDRET Then
     GOK=0
     LMESSERR="$EXEC_CAN-s/p[EXTOURNE_EVE] RCOD"-num$(RCOD) : Gosub TRT_ERREUR #@err
    Endif
   Endif
   Filter [F:EVT0]
   Close Local File [F:EVT0]

   #> Plan de caducité repasse à SA début amort recalé sur date début amort industriel, recalcul base caducité avant renouvellement
   #  et RAZ du fonds de caducité
   #  -----------------------------------------------------------------------------------------------------------------------------

   Read [F:DEPI]DEP0=[F:FAS]AASREF;G_CCNPLNIND;GFINEXECPF;GFINPERCPF
   If fstat
    GOK=0
    LKEYERR = [F:FAS]AASREF+";"+num$(G_CCNPLNIND)+";"+GFINEXECPF+";"+GFINPERCPF
    LMESSERR="$EXEC_CAN-Read [F:DEPI] fstat="-num$(fstat)-"key="+LKEYERR  : Gosub TRT_ERREUR  #@err
   Endif
   Read [F:DEP]DEP0=[F:FAS]AASREF;G_CCNPLNCAD;GFINEXECPF;GFINPERCPF
   If fstat
    GOK=0
    LKEYERR = [F:FAS]AASREF+";"+num$(G_CCNPLNCAD)+";"+GFINEXECPF+";"+GFINPERCPF
    LMESSERR="$EXEC_CAN-Read [F:DEP] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
   Endif
   [F:DEP]DPRBAS    = [F:DEPI]DPRBAS
   [F:DEP]BSEVAL    = [F:DEP]DPRBAS
   [F:DEP]TRFCADCUM = 0

    #> Changement de méthode sur le plan de caducité SA date de début = date de début du plan industriel

    Local Date    LSTRDPRDAT
    Local Integer LCDRET
    LSTRDPRDAT=[F:RWPS]RNWDAT+1
    Call FASMTC_SA_RA ("FAS", "DEP", G_DPMSA, [F:DEPI]STRDPRDAT, G_OUI, GFINPERCPF, LCDRET) From TRTFAS
    If LCDRET > 0
     GOK = 0
     LMESSERR="$TRAITE_UN_BIEN_FILS_RNWCAN-s/p[FASMTC_SA_RA] LCDRET"-num$(LCDRET) : Gosub TRT_ERREUR #@err
    Else
     [F:DEP]DEPSTA=GVML_SCNOCAL
     GPOINT = "RNWCANPLNCAD" : Gosub ENTREE From EXEFNC  # PE pour pouvoir modifier les infos du plan de caducité : annulation renouvellement
     If GOK
      Rewrite [F:DEP]
      If fstat
       GOK=0
       LKEYERR = [F:DEP]AASREF+";"+num$([F:DEP]DPRPLN)+";"+[F:DEP]FIYENDDAT+";"+[F:DEP]PERENDDAT
       LMESSERR="$EXEC_CAN-Rewrite [F:DEP] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
      Endif
     Endif
    Endif

   #--

   [F:FAS]FLGCLC                = G_OUI
   [F:FAS]FLGCNXCLC(G300CPFI-1) = G_OUI
   [F:FAS]FLGRPRCLC             = G_OUI

   #--

   Rewrite [F:FAS]
   If fstat
    GOK=0
    LKEYERR = [F:FAS]AASREF
    LMESSERR="$EXEC_CAN-Rewrite [F:FAS] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
   Endif

  Endif

 Endif


 # 2. TRAITEMENT DES BIENS  PERES
 If 1=1
  #> Annulation de la sortie des biens pères
  #  =======================================
  If GOK & (GTRTAASREF<>"") | (GTRTAASREF="" & [M:DIA]FLGSIM<>G_OUI)
   Local Integer RETOUR
   Call LAUNCH_SILTRT("FASISS","TRTCCNRNW",RETOUR) From TRCPROCOM
   If (RETOUR) Then
     NB_ERR +=1
     GOK=0
     LMESSERR="$EXEC_CAN-s/p[LAUNCH_SILTRT] RETOUR"-num$(RETOUR) : Gosub TRT_ERREUR  #@err
   Endif
  Endif

  #> FQ95049
  #> Restauration des valeurs de renouvellement des biens pères à partir de la préparation de renouvellement
  #  =======================================
  If LUPDRNWVAL = num$(G_OUI)
    For [F:RWPF] Where ( CPY=[F:FAS]CPY & FCY=[F:FAS]FCY & CCNREF=[F:FAS]CCNREF & RNWAASREF=[F:FAS]AASREF )
      If [F:RWPF]RNWVALFLGO <> 0 : # FQ105441 : Test que RNWVALFLGO est différent de 0 pour ne pas restaurer les valeurs
                                   # si l'opération de renouvellement a été effectuée avant le patch contenant l'évolution
        Update [F:MFAS] Where AASREF=[F:RWPF]MOTHAASREF With RNWVAL=[F:RWPF]RNWVALO, RNWVALFLG=[F:RWPF]RNWVALFLGO
        If fstat or adxuprec<>1
          GOK=0
          LKEYERR = [F:RWPF]MOTHAASREF
          LMESSERR="$EXEC_CAN-s/p[UPDATE_WFAS] adxuprec"-num$(adxuprec)-"fstat"-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR #@err
        Endif
      Endif
    Next
  Endif
 Endif

 # 3. TRAITEMENT DE L'OPERATION DE RENOUVELLEMENT
 If 1=1

   #> Trace détaillée de l'annulation
   #  ===============================

   If GOK & GTRTAASREF="" & [M:DIA]FLGDET=G_OUI
    For [F:RWPF] Where ( CPY=[F:FAS]CPY & FCY=[F:FAS]FCY & CCNREF=[F:FAS]CCNREF & RNWAASREF=[F:FAS]AASREF )
     Read [F:FASS]FAS0=[F:RWPS]MOTHAASREF
     If dim(LPREMLIN)>0
      LPREMLIN=0
     Elsif dim(LPREMLIN)<0
      Local Integer LPREMLIN : LPREMLIN=1
     Endif
     Gosub TRC_ECR_LIST_BIEN_CAN From TRTCCNRNW
    Next
    Gosub TRC_ECR_PIED_FILS_CAN
   Endif


   #> Annulation du renouvellement sur l'opération de renouvellement
   #  ==============================================================

  If GOK & (GTRTAASREF<>"") | (GTRTAASREF="" & [M:DIA]FLGSIM<>G_OUI)
   If !clalev([F:RWPF]) : Local File RNWPREP [RWPF] : Endif
   Update [F:RWPF] Where ( CPY=[F:FAS]CPY & FCY=[F:FAS]FCY & CCNREF=[F:FAS]CCNREF & RNWAASREF=[F:FAS]AASREF ) With RNWDONFLG=G_NON
   If fstat
    GOK=0
    LKEYERR = [F:FAS]CPY+";"+[F:FAS]FCY+";"+[F:FAS]CCNREF+";"+[F:FAS]AASREF
    LMESSERR="$EXEC_CAN-Update [F:RWPF] fstat="-num$(fstat)-"key="+LKEYERR : Gosub TRT_ERREUR  #@err
   Else
   Endif
  Endif
 Endif

  #> Fin de la transaction

  If !BCMTEXT Then
   # Si traitement en réel et commitment control à gérer
   If ( GOK ) Then
     Commit
   Else
     Rollback
   Endif
  Endif

  If GOK : NB_MAJ+=1 : Endif

  $NEXT_RNWCANAASREF1

  #-3.5.1 Déverrouillage opération de préparation de renouvellement et biens

  Unlock = SYMBRNW
  Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS

  $NEXT_RNWCANAASREF2

Endif
Return

#------------------------------------------------------
# Appelé dans SUBFAS pour activer ou désactiver
# le menu "Annulation du renouvellement"
#------------------------------------------------------
$SETBOUTCAN
 If [F:FAS]RNWDONFLG=G_OUI & GREP=""
  CHMEN+="H"
 Endif
Return

#------------------------------------------------------
# Sélection dans la table RNWPREP #@RAF
#------------------------------------------------------
$SEL_LISTE

  If LISTE = "SELRNWPREP"
    # Sélection liste des opération de renouvellement en préparation

    Local Char LCPY
    Local Char LFCY
    Local Char LCCNREF
    Local Char LCCNUSR
    Local Char LFILTRE

    LCPY    = PARAM(1) : # Société
    LFCY    = PARAM(2) : # Site
    LCCNREF = PARAM(3) : # Contrat de concession
    LCCNUSR = PARAM(4) : # Concédant
    LFILTRE = PARAM(5) : # Filtre supplémentaire

    If clalev([F:RWP])=0 : Local File RNWPREP    [RWP] : Endif
    If clalev([F:FAS])=0 : Local File FXDASSETS  [FAS] : Endif

    If clalev([F:CCN])=0 : Local File CONCESSION [CCN] : Endif

    Link [F:RWP] With [F:CCN]CCN0=[F:RWP]CCNREF, [F:FAS]FAS0=[F:RWP]RNWAASREF  As [RDEC]

    Local Char TEXTE(80)(1..200,1..5)
    Local Char LREQ(255)

    #> Construction du critère

    If LCPY="" & LFCY="" & LCCNUSR=""
     LREQ='(GUSRFCY(1)="\" | find(FCY,GUSRFCY(1..GNBAUZ)))'
    Else
     If LCPY<>"" & LFCY<>""
      LREQ='CPY="'+LCPY+'"&FCY="'+LFCY+'"'
     Endif
     If LCCNREF<>""
      If LREQ<>"" : LREQ+="&" : Endif
      LREQ+='[F:CCN]CCNREF="'+LCCNREF+'"'
     Endif
     If LCCNUSR<>""
      If LREQ<>"" : LREQ+="&" : Endif
      LREQ+='[F:CCN]CCNUSR="'+LCCNUSR+'"'
     Endif
     If LREQ="" : LREQ="1=1" : Endif
    Endif

    NBTEX = 0
    TIT(0) = mess(755,GML_MSGFAS,1) # "Choisir un bien renouvelant"
    TIT(1) = mess(747,GML_MSGFAS,1) # "Bien Renouvelant"
    TIT(2) = mess(251,GML_MSGFAS,1) # "Désignation"
    TIT(3) = mess(756,GML_MSGFAS,1) # "Concession"
    TIT(4) = mess(757,GML_MSGFAS,1) # "Validé"
    TIT(5) = mess(24,GML_MSGCPT,1)  # "Site"

    Filter [F:RDEC] Where evalue(LREQ)
    For [F:RDEC]RWP0(3)
      NBTEX += 1
      TEX(NBTEX)     = [F:RWP]RNWAASREF
      TEXTE(NBTEX,1) = [F:RWP]RNWAASREF
      TEXTE(NBTEX,2) = [F:FAS]AASDES1
      TEXTE(NBTEX,3) = [F:RWP]CCNREF
      TEXTE(NBTEX,4) = mess([F:RWP]RNWDONFLG,1,1)
      TEXTE(NBTEX,5) = [F:RWP]FCY
    Next
    Filter [F:RDEC]
    If !NBTEX
     Call MESSAGE(mess(99,100,1)) From GESECRAN
    Endif

  Endif
Return

#------------------------------------------------------
# Calcul de la société si / demandée
# Utilisable uniquement en interfactif (hors unitaire)
# et en batch. Exclu en silencieux.
#------------------------------------------------------
$CAL_SOCIETE
  If !OK | GACTSILENCE=G_OUI | GTRTAASREF<>"" | [M:DIA]FLGSIM=G_OUI : Return : Endif
  If [M:DIA]FLGCAL<>G_OUI : Return : Endif

  # Si traitement en réel et pas en mode silencieux
  Local Integer TBCNX(1..GMAXCNXC)
  # Local Char    TBFCY(GLONCPY)(1..func AFNC.ACTIV("SIT")) : # X3-89794
  Local Char    TBFCY(GLONFCY)(1..func AFNC.ACTIV("SIT"))
  Local Decimal RERROR
  # Site à calculer
  TBFCY(1) = [M:DIA]FCY
  # Contexte à calculer
  TBCNX(1) = G300CPFI
  # Calcul FQ88613
  Global Integer G_CLCTRC : G_CLCTRC = 1   # 0 : pas de trace/1 : trace
  Gosub AVANT_CALCULER_SOCIETE From GLOBB0
  Call  CALCULER_SOCIETE([M:DIA]CPY, TBFCY, TBCNX, G_NON, RERROR) From GLOBB
  Gosub APRES_CALCULER_SOCIETE  From GLOBB0

Return

######################################################################################
# SOUS-PROGRAMMES COMMUNS
######################################################################################


######################################################################################
# FONCTION COMMUNS
######################################################################################


######################################################################################
# GESTION DE LA TRACE
######################################################################################

#==============================
$TRC_ECR_PARM
If 1=1
  If ( GACTSILENCE = G_OUI      ) | GTRTAASREF<>"" Then : Return : Endif

  # "Options"
  Call ECR_TRACE("", 0,mess(705,GML_MSGFAS,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Traitement simulé    :"
  Call ECR_TRACE("", 0,mess(706,GML_MSGFAS,1)-mess([M:DIA]FLGSIM,1,1),0,1) From TRACEABX3
  # "Trace détaillée      :"
  Call ECR_TRACE("", 0,mess(707,GML_MSGFAS,1)-mess([M:DIA]FLGDET,1,1),0,1) From TRACEABX3

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Critères de sélection"
  Call ECR_TRACE("", 0,mess(709,GML_MSGFAS,1),0,1)    From TRACEABX3
  Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
  # "Société              :"
  Call ECR_TRACE("", 0,mess(710,GML_MSGFAS,1)-[M:DIA]CPY-[M:DIA]ZCPY,0,1) From TRACEABX3
  # "Site                 :"
  Call ECR_TRACE("", 0,mess(711,GML_MSGFAS,1)-[M:DIA]FCY-[M:DIA]ZFCY,0,1) From TRACEABX3
  # "Concédant            :"
  If [M:DIA]CCNUSR<>""
   Call ECR_TRACE("", 0,mess(712,GML_MSGFAS,1)-[M:DIA]CCNUSR-[M:DIA]ZCCNUSR,0,1) From TRACEABX3
  Endif
  # "Contrat concession   :"
  If [M:DIA]CCNREF<>""
   Call ECR_TRACE("", 0,mess(713,GML_MSGFAS,1)-[M:DIA]CCNREF-[M:DIA]CCNDES1,0,1) From TRACEABX3
   #Call ECR_TRACE("", 0,space$(len(mess(713,GML_MSGFAS,1)-[M:DIA]CCNREF)+1)+[M:DIA]CCNDES2,0,1) From TRACEABX3
  Endif
  # "Bien Renouvelant   :"
  If [M:DIA]RNWAASREF<>""
   Call ECR_TRACE("", 0,mess(747,GML_MSGFAS,1)+":"-[M:DIA]RNWAASREF-[M:DIA]RNWAASDES1,0,1) From TRACEABX3
   #Call ECR_TRACE("", 0,space$(len(mess(747,GML_MSGFAS,1)+"      :"-[M:DIA]RNWAASREF)+1)+[M:DIA]RNWAASDES2,0,1) From TRACEABX3
  Endif
  # "Plafonnement de la provision pour renouvellement :" : # FQ95049
  Call ECR_TRACE("", 0,mess(933,GML_MSGFAS,1)-":"-mess(val(LUPDRNWVAL),1,1),0,1) From TRACEABX3

  Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
Endif
Return

#===============================
$TRC_ECR_ENTETE
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>"" : Return : Endif
 Local    Char    LINE(115)
 If ( [M:DIA]FLGDET <> G_OUI ) Then : Return : Endif
 If ( GACTSILENCE = G_OUI    ) Then : Return : Endif
 # Entête
 LINE = ""
 Call ECR_TRACE("", 0, LINE, 0,1)                  From TRACEABX3
 # "Trace détaillée"
 Call ECR_TRACE("", 0,mess(717,GML_MSGFAS,1),0,1)         From TRACEABX3
 Call ECR_TRACE("", 0,string$(len(mess(717,GML_MSGFAS,1)),"="),0,1) From TRACEABX3
Endif
Return

#===============================
$TRC_ECR_CCNREF
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>"" : Return : Endif
 Local    Char    LINE(115)

 # Contrat

 Call ECR_TRACE("", 0,"",0,1)            From TRACEABX3
 LINE=mess(713,GML_MSGFAS,1)-[F:RWPS]CCNREF    : Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 LINE=string$(len(mess(713,GML_MSGFAS,1)),"-") : Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 Call ECR_TRACE("", 0,"",0,1)            From TRACEABX3

 # En-tête tableau des bien fils
 # L1
 LINE=string$(115,"=")
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 # L2
 LINE=space$(1)+left$(mess(752,GML_MSGFAS,1)+space$(21),21)+"!"+space$(1)+left$(mess(753,GML_MSGFAS,1)+space$(33),33)+"!"+space$(22)+"!"+"O"+"!"
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 # L3
 LINE=string$(57,"-")+"!"+space$(22)+"!"+"E"+"!"
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 # L4
 LINE=space$(1)+left$(mess(747,GML_MSGFAS,1)+space$(21),21)+"!"+
&     space$(1)+left$(mess(251,GML_MSGFAS,1)+space$(33),33)+"!"+
&     space$(1)+left$(mess(754,GML_MSGFAS,1)+space$(21),21)+
&     "!"+"R"+"!"+space$(1)+mess(251,GML_MSGFAS,1)
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 # L5
 LINE=string$(115,"=")
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
Endif
Return

#===============================
$TRC_ECR_CCNREF_CAN
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>"" : Return : Endif
 Local    Char    LINE(115)

 # Contrat

 Call ECR_TRACE("", 0,"",0,1)            From TRACEABX3
 LINE=mess(713,GML_MSGFAS,1)-[F:RWPS]CCNREF    : Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 LINE=string$(len(mess(713,GML_MSGFAS,1)),"-") : Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 Call ECR_TRACE("", 0,"",0,1)            From TRACEABX3

 # En-tête tableau des bien fils
 # L1
 LINE=string$(115,"=")
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 # L2
 LINE=space$(1)+left$(mess(747,GML_MSGFAS,1)+space$(21),21)+"!"+
&     space$(1)+left$(mess(251,GML_MSGFAS,1)+space$(33),33)+"!"+
&     space$(1)+left$(mess(754,GML_MSGFAS,1)+space$(21),21)+
&     "!"+space$(1)+mess(251,GML_MSGFAS,1)
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 # L3
 LINE=string$(115,"=")
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
Endif
Return

#==============================
$TRC_ECR_ET_FILS
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>""  : Return : Endif
 Local    Char    LINE(115)
 LINE=space$(1)+left$(format$(GFMDAT4,[F:RWPS]RNWDAT)+space$(21),21)+"!"+
&     space$(1)+left$(mess([F:RWPS]ISSDATRUL,3274,1)+space$(33),33)+"!"+space$(22)+"!"+" "+"!"
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 LINE=string$(57,"-")+"!"+space$(22)+"!"+" "+"!"
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 If dim(LPREMLIN)>0
  Kill LPREMLIN
 Endif
Endif
Return

#==============================
$TRC_ECR_LIST_BIEN
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>""  : Return : Endif
 Local    Char    LINE(115)
 If LPREMLIN
  LINE=space$(1)+left$([F:RWPS]RNWAASREF+space$(21),21)+"!"+
&      space$(1)+left$([F:FASS]AASDES1+space$(33),33)+"!"
 Else
  LINE=space$(1+21)+"!"+space$(1+33)+"!"
 Endif
 LINE+=space$(1)+left$([F:FAS]AASREF+space$(21),21)+"!"
 If [F:FAS]RNWFLG=G_OUI
  LINE+="X"
 Else
  LINE+=space$(1)
 Endif
 LINE+="!"+space$(1)+[F:FAS]AASDES1
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
Endif
Return

#==============================
$TRC_ECR_LIST_BIEN_CAN
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>""  : Return : Endif
 Local    Char    LINE(115)
 If LPREMLIN
  LINE=space$(1)+left$([F:FAS]AASREF+space$(21),21)+"!"+
&      space$(1)+left$([F:FAS]AASDES1+space$(33),33)+"!"
 Else
  LINE=space$(1+21)+"!"+space$(1+33)+"!"
 Endif
 LINE+=space$(1)+left$([F:RWPF]MOTHAASREF+space$(21),21)+"!"
 LINE+=space$(1)+[F:FASS]AASDES1

 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
Endif
Return

#==============================
$TRC_ECR_PIED_FILS_CAN
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>""  : Return : Endif
 Local    Char    LINE(115)
 # Ligne 1
 LINE=string$(115,"=")
 Call ECR_TRACE("", 0,LINE,0,1)         From TRACEABX3
 If dim(LPREMLIN)>0
  Kill LPREMLIN
 Endif
Endif
Return

#==============================
$ECR_STAT
If 1=1
 If GACTSILENCE=G_OUI | GTRTAASREF<>""  : Return : Endif
 Local    Char    LINE(115)
 Call ECR_TRACE("", 0,"",0,1) From TRACEABX3
 # "Statistiques"
 Call ECR_TRACE("", 0,mess(724,GML_MSGFAS,1),0,1)    From TRACEABX3
 Call ECR_TRACE("", 0,"=====================",0,1) From TRACEABX3
 # "Biens"
 Call ECR_TRACE("", 0,mess(725,GML_MSGFAS,1),0,1) From TRACEABX3
 Call ECR_TRACE("", 0,"==========================================",0,1) From TRACEABX3
 # "Sélectionnés     Mis à jour      En erreur"
 Call ECR_TRACE("", 0,mess(726,GML_MSGFAS,1),0,1) From TRACEABX3
 Call ECR_TRACE("", 0,"==========================================",0,1) From TRACEABX3
 LINE  = left$( ""                                   + string$( 5,' '),  5)
 LINE += left$( num$(NB_LUS)                         + string$(10,' '), 10)+"!"
 LINE += left$( ""                                   + string$( 5,' '),  5)
 LINE += left$( num$(NB_MAJ)                         + string$(10,' '), 10)+"!"
 LINE += left$( ""                                   + string$( 5,' '),  5)
 LINE += left$( num$(NB_ERR)                         + string$(10,' '), 10)
 Call ECR_TRACE("", 0, LINE, 0,1) From TRACEABX3
 Call ECR_TRACE("", 0,"==========================================",0,1) From TRACEABX3
Endif
Return

######################################################################################
# ACTION CHAMP SUR LE MASQUE [M:DIA]
######################################################################################

#------------------------------------------------------
Subprog AM_FLGSIM(VALEUR)
Variable Integer VALEUR
 If ( VALEUR = G_OUI ) Then
   # Par défaut traitement simulé => pas de calcul
   [M:DIA]FLGCAL = G_NON
   Affzo [M:DIA]FLGCAL
   Diszo [M:DIA]FLGCAL
 Else
   Actzo [M:DIA]FLGCAL
 Endif
End

#------------------------------------------------------
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
 Read [F:FCY]FCY0=VALEUR
 If (!fstat) Then
   [M:DIA]CPY = [F:FCY]LEGCPY
 Else
   [M:DIA]CPY = ""
 Endif
 [M:DIA]CCNREF      = ""
 [M:DIA]RNWAASREF   = ""
 [M:DIA]RNWAASDES1  = ""
 [M:DIA]RNWAASDES2  = ""
 Affzo [M:DIA]25
End

#------------------------------------------------------
Subprog AM_CCNUSR(VALEUR)
Variable Char    VALEUR()
 [M:DIA]CCNREF      = ""
 [M:DIA]CCNDES1     = ""
 [M:DIA]CCNDES2     = ""
 [M:DIA]RNWAASREF   = ""
 [M:DIA]RNWAASDES1  = ""
 [M:DIA]RNWAASDES2  = ""
 Affzo [M:DIA]25
End

#------------------------------------------------------
Subprog AM_CCNREF(VALEUR)
Variable Char    VALEUR()

 If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
 Read [F:CCN]CCN0=VALEUR
 If (!fstat) Then
   If ( [F:CCN]CCNSTA <> GVML_CSACTI ) Then
     # Référence concession invalide
     GERR= 1: GMESSAGE = mess(271,GML_MSGFAS,1)
     mkstat = 2 : End
   Endif
   [M:DIA]CPY        = [F:CCN]CPY
   [M:DIA]FCY        = [F:CCN]FCY
   [M:DIA]CCNDES1    = [F:CCN]CCNDES1
   [M:DIA]CCNDES2    = [F:CCN]CCNDES2
   [M:DIA]CCNUSR     = [F:CCN]CCNUSR
 Endif

 [M:DIA]RNWAASREF   = ""
 [M:DIA]RNWAASDES1  = ""
 [M:DIA]RNWAASDES2  = ""

 Affzo [M:DIA]25

End

#------------------------------------------------------
Subprog C_RNWAASREF(VALEUR)
Variable Char    VALEUR()
  # Référence Bien comptable invalide
End

#------------------------------------------------------
Subprog AM_RNWAASREF(VALEUR)
Variable Char    VALEUR()
 If !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif
 Read [F:FAS]FAS0=VALEUR
 [M:DIA]RNWAASDES1=[F:FAS]AASDES1
 [M:DIA]RNWAASDES2=[F:FAS]AASDES2
 If (!fstat) Then
   If [F:FAS]OWNTYP<>GVML_TDCONCE
     # Référence bien de renouvellement invalide
     GERR= 1: GMESSAGE = mess(271,GML_MSGFAS,1)
     mkstat = 2 : End
   Endif
   If !clalev([F:CCN]) : Local File CONCESSION [CCN] : Endif
   Read [F:CCN]CCN0=[F:FAS]CCNREF
   If (!fstat) Then
    If ( [F:CCN]CCNSTA <> GVML_CSACTI ) Then
      # Référence concession invalide
      GERR= 1: GMESSAGE = mess(271,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
    [M:DIA]CPY        = [F:FAS]CPY
    [M:DIA]FCY        = [F:FAS]FCY
    [M:DIA]CCNREF     = [F:FAS]CCNREF
    [M:DIA]CCNDES1    = [F:CCN]CCNDES1
    [M:DIA]CCNDES2    = [F:CCN]CCNDES2
    [M:DIA]CCNUSR     = [F:CCN]CCNUSR
   Endif
   Affzo [M:DIA]25
 Endif

 If VALEUR=""
  Actzo [M:DIA]FLGCNL : [M:DIA]FLGCNL=G_NON
 Else
  # Dans tous les cas, l'utilisateur n'a pas la main sur le flag annulation s'il saisit un bien renouvelant
  Grizo [M:DIA]FLGCNL
  # Est-ce qu'il s'agit d'une validation ou d'une annulation ?
  If !clalev([F:RWP]) : Local File RNWPREP : Endif
  Filter [F:RWP] Where RNWAASREF=VALEUR
  Read [F:RWP] First
  If !fstat & [F:RWP]RNWDONFLG=G_OUI
   [M:DIA]FLGCNL=G_OUI
  Else
   [M:DIA]FLGCNL=G_NON
  Endif
 Endif
 Affzo [M:DIA]FLGCNL

End

#------------------------------------------------------
Subprog S_RNWAASREF(VALEUR)
Variable Char    VALEUR()
End

#======================================================
# Traitement d'alimentation
# de la sortie silencieuse
# des biens pères
#======================================================
$ALIM_MASK
 Raz [M:ASL]
 Raz [M:FASS]
 Case GTYPRNW
  When "RNWACT" : Gosub ALIM_MASK_ACT
  When "RNWCAN" : Gosub ALIM_MASK_CAN
 Endcase
Return

#======================================================
# ANNULATION DE RENOUVELLEMENT
#======================================================
$ALIM_MASK_CAN
  # Flag de simulation
  FLGSIM          =  G_NON
  [M:MHC]FLGSIM   =  G_NON
  # Alimentation de l'en-tête
  [M:MHC]FLGCPY(find([F:FAS]CPY,[M:MHC]CPY)-1)  = G_OUI
  [M:MHC]FLGFCY(find([F:FAS]FCY,[M:MHC]FCY)-1)  = G_OUI
  # Alimentation des paramètres de l'action étendue
  [M:ASL]EXP1          = '[F:MAS1]RNWAASREF="'+[F:FAS]AASREF+'"& [F:MAS1]CCNREF="'+[F:FAS]CCNREF+'"'
  # Alimentation des paramètres de la sortie
  [M:FASS]CCLISSFLG    = G_OUI
Return

#======================================================
# RENOUVELLEMENT
#======================================================
$ALIM_MASK_ACT

  # Flag de simulation
  If dim([M:DIA]FLGSIM)>0
     FLGSIM          =  [M:DIA]FLGSIM
     [M:MHC]FLGSIM   =  [M:DIA]FLGSIM
     If [M:DIA]CPY <> ""
        # Alimentation de l'en-tête
        #FQ-95641 si l'on valide depuis l'écran Validation
        [M:MHC]FLGCPY(find([M:DIA]CPY,[M:MHC]CPY)-1)  = G_OUI
        [M:MHC]FLGFCY(find([M:DIA]FCY,[M:MHC]FCY)-1)  = G_OUI
     Else
        #FQ-95641 si l'on valide depuis l'écran Préparation
        [M:MHC]FLGCPY(find([F:FAS]CPY,[M:MHC]CPY)-1)  = G_OUI
        [M:MHC]FLGFCY(find([F:FAS]FCY,[M:MHC]FCY)-1)  = G_OUI
     Endif
  Else
     FLGSIM          =  G_NON
     [M:MHC]FLGSIM   =  G_NON
     ##FQ-95641 si l'on valide depuis l'écran Préparation
     [M:MHC]FLGCPY(find([F:FAS]CPY,[M:MHC]CPY)-1)  = G_OUI
     [M:MHC]FLGFCY(find([F:FAS]FCY,[M:MHC]FCY)-1)  = G_OUI
  Endif
  #FQ-95641  # Alimentation de l'en-tête
  #FQ-95641  [M:MHC]FLGCPY(find([F:FAS]CPY,[M:MHC]CPY)-1)  = G_OUI
  #FQ-95641  [M:MHC]FLGFCY(find([F:FAS]FCY,[M:MHC]FCY)-1)  = G_OUI
  # Alimentation des paramètres de l'action étendue
  [M:ASL]EXP1          = '[F:MAS1]RNWAASREF="'+[F:RWPS]RNWAASREF+'"& [F:MAS1]CCNREF="'+[F:RWPS]CCNREF+'"'
  # Alimentation des paramètres de la sortie
  [M:FASS]CCLISSFLG    = G_NON
  [M:FASS]EXTISSFLG    = G_NON
  [M:FASS]ISSCMPFLG    = G_NON
  [M:FASS]IMLFLG       = G_OUI
  If (GPHY = G_OUI) Then : [M:FASS]ECRPHYATT = G_OUI : Endif
  [M:FASS]ISSDAT       = [F:RWPS]RNWDAT
  [M:FASS]ISSTYP       = GVML_TSRENEW
  [M:FASS]ISSDATRUL    = [F:RWPS]ISSDATRUL
  [M:FASS]ISSAMTTYP    = GVML_TVAUCUN
  [M:FASS]ISSAMT       = 0
  [M:FASS]PYBVATTYP    = GVML_SNSREGU
  [M:FASS]ISSAMTTYP    = 1
Return

