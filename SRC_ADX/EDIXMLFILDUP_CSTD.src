#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIXMLFILDUP                                                     #
# Manages Duplicate class for EDIXMLFIL                                       #
# Author : RBA                                                                #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"    : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "MSGCODNEW" :
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGCODNEW_CONTROL
        When "PROPAGATE" : Gosub MSGCODNEW_PROPAGATE
      Endcase
    When "MSGRELNEW" :
      Case [L]ARULE
        When "CONTROL"   : Gosub MSGRELNEW_CONTROL
        When "PROPAGATE" : Gosub MSGRELNEW_PROPAGATE
      Endcase
    When "MSGFILNORNEW" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub MSGFILNORNEW_PROPAGATE
      Endcase
    When "EXSDOLD.CODE" :
      Case [L]ARULE
        When "CONTROL"   : Gosub EXSDOLD_CODE_CONTROL
        When "PROPAGATE" : Gosub EXSDOLD_CODE_PROPAGATE
       Endcase
    When "EXSD.CODE" :
      Case [L]ARULE
        When "CONTROL"   : Gosub EXSD_CODE_CONTROL
        When "PROPAGATE" : Gosub EXSD_CODE_PROPAGATE
       Endcase
  Endcase
Return

####################################################################

$MSGCODNEW_CONTROL
  If this.MSGCODNEW <> ""
    this.MSGCODNEW = func EDILIBA.FORMATVAL("MSGCOD", this.MSGCODNEW)
  Endif
Return

####################################################################

$MSGCODNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGFILNORNEW")

  If this.MSGCODNEW <> "" and this.MSGRELNEW <> ""
    If func CTRL_EXIST_MSG(this.MSGCODNEW,this.MSGRELNEW) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("MSGCODNEW",mess(126,143,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AERROR)
    Endif
  Endif

  If func CTRL_EXIST_XML(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
    ASTATUS = fmet this.ASETERROR("MSGCODNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
  Endif
Return

####################################################################

$MSGRELNEW_CONTROL
  If this.MSGRELNEW <> ""
    this.MSGRELNEW = func EDILIBA.FORMATVAL("MSGREL", this.MSGRELNEW)
  Endif
Return

####################################################################

$MSGRELNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGFILNORNEW")

  If this.MSGCODNEW <> "" and this.MSGRELNEW <> ""
    If func CTRL_EXIST_MSG(this.MSGCODNEW,this.MSGRELNEW) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("MSGRELNEW",mess(126,143,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW,[V]CST_AERROR)
    Endif
  Endif

  If func CTRL_EXIST_XML(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
    ASTATUS = fmet this.ASETERROR("MSGRELNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
  Endif
Return

####################################################################

$MSGFILNORNEW_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("MSGCODNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGRELNEW")
  ASTATUS = fmet this.ADELETEERROR("MSGFILNORNEW")
  If func CTRL_EXIST_XML(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
    ASTATUS = fmet this.ASETERROR("MSGFILNORNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
  Endif
Return

####################################################################

$EXSDOLD_CODE_CONTROL
  If this.CODE <> ""
    this.CODE = func EDILIBA.FORMATVAL("CODE", this.CODE)
  Endif
Return

####################################################################

$EXSDOLD_CODE_PROPAGATE
  If this.CODE <> ""
    Local File EDIXSDUPL [EXU]
    Read [EXU]EXU0 = this.CODE
    If !fstat
      this.NAM     = [EXU]NAM
      this.FILNAM  = [EXU]FILNAM
      this.FILDES  = [EXU]FILDES
      this.UUIDXSD = [EXU]UUIDXSD
    Else
      this.NAM     = ""
      this.FILNAM  = ""
      this.FILDES  = ""
      this.UUIDXSD = NullUuid()
    Endif
    LogicClose File [EXU]
  Endif
Return

####################################################################

$EXSD_CODE_CONTROL
  If this.CODE <> ""
    this.CODE = func EDILIBA.FORMATVAL("CODE", this.CODE)
  Endif
Return

####################################################################

$EXSD_CODE_PROPAGATE
  If this.CODE <> ""
    Local File EDIXSDUPL [EXU]
    Read [EXU]EXU0 = this.CODE
    If !fstat
      this.NAM     = [EXU]NAM
      this.FILNAM  = [EXU]FILNAM
      this.FILDES  = [EXU]FILDES
      this.UUIDXSD = [EXU]UUIDXSD
    Else
      this.NAM     = ""
      this.FILNAM  = ""
      this.FILDES  = ""
      this.UUIDXSD = NullUuid()
    Endif
    LogicClose File [EXU]
  Endif
Return

####################################################################

$AREAD_AFTER
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Local File EDIXMLFIL [EXF]
    Read [EXF]EXF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
    If !fstat
      this.FILDES    = [EXF]FILDES
      this.FILDESNEW = [EXF]FILDES-"(Copy)"
    Else
      this.FILDES    = ""
      this.FILDESNEW = ""
    Endif
    LogicClose File [EXF]

    Local Integer WPOS
    Local File EDIXMLFILXSD [EXSD]
    Local File EDIXSDUPL [EXU]
    Filter [EXSD] Where MSGCOD = this.MSGCOD and MSGREL = this.MSGREL and MSGFILNOR = this.MSGFILNOR
    For [EXSD]
      #new
      WPOS = fmet this.ADDLINE('EXSD', [V]CST_ALASTPOS)
      this.EXSD(WPOS).MSGCOD     = [EXSD]MSGCOD
      this.EXSD(WPOS).MSGREL     = [EXSD]MSGREL
      this.EXSD(WPOS).MSGFILNOR  = [EXSD]MSGFILNOR
      this.EXSD(WPOS).NUMLIN     = [EXSD]NUMLIN
      this.EXSD(WPOS).SORT       = [EXSD]SORT
      this.EXSD(WPOS).CODE       = [EXSD]CODE
      this.EXSD(WPOS).UUIDXSD    = [EXSD]UUIDXSD
      Read [EXU]EXU0 = [EXSD]CODE
      If !fstat
        this.EXSD(WPOS).NAM     = [EXU]NAM
        this.EXSD(WPOS).FILNAM  = [EXU]FILNAM
        this.EXSD(WPOS).FILDES  = [EXU]FILDES
        this.EXSD(WPOS).UUIDXSD = [EXU]UUIDXSD
      Else
        this.EXSD(WPOS).NAM     = ""
        this.EXSD(WPOS).FILNAM  = ""
        this.EXSD(WPOS).FILDES  = ""
        this.EXSD(WPOS).UUIDXSD = NullUuid()
      Endif
      #old
      WPOS = fmet this.ADDLINE('EXSDOLD', [V]CST_ALASTPOS)
      this.EXSDOLD(WPOS).MSGCOD     = [EXSD]MSGCOD
      this.EXSDOLD(WPOS).MSGREL     = [EXSD]MSGREL
      this.EXSDOLD(WPOS).MSGFILNOR  = [EXSD]MSGFILNOR
      this.EXSDOLD(WPOS).NUMLIN     = [EXSD]NUMLIN
      this.EXSDOLD(WPOS).SORT       = [EXSD]SORT
      this.EXSDOLD(WPOS).CODE       = [EXSD]CODE
      this.EXSDOLD(WPOS).UUIDXSD    = [EXSD]UUIDXSD
      Read [EXU]EXU0 = [EXSD]CODE
      If !fstat
        this.EXSDOLD(WPOS).NAM     = [EXU]NAM
        this.EXSDOLD(WPOS).FILNAM  = [EXU]FILNAM
        this.EXSDOLD(WPOS).FILDES  = [EXU]FILDES
        this.EXSDOLD(WPOS).UUIDXSD = [EXU]UUIDXSD
      Else
        this.EXSDOLD(WPOS).NAM     = ""
        this.EXSDOLD(WPOS).FILNAM  = ""
        this.EXSDOLD(WPOS).FILDES  = ""
        this.EXSDOLD(WPOS).UUIDXSD = NullUuid()
      Endif
    Next
   LogicClose File [EXU]
   LogicClose File [EXSD]
  Endif
Return

####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.MSGCODNEW <> "" and this.MSGRELNEW <> "" and this.MSGFILNORNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_XML(this.MSGCODNEW,this.MSGRELNEW,this.MSGFILNORNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("MSGCODNEW",mess(45,7779,1)-":"-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_XML(this, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.MSGCODNEW+"~"+this.MSGRELNEW+"~"+this.MSGFILNORNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

####################################################################

Funprog CTRL_EXIST_XML(WMSGCOD,WMSGREL,WMSGFILNOR)
Value Char WMSGCOD
Value Char WMSGREL
Value Char WMSGFILNOR

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WMSGCOD <> "" and WMSGREL <> "" and WMSGFILNOR <> ""
    Local File EDIXMLFIL [EXF]
    Filter [EXF] Where MSGCOD = WMSGCOD and MSGREL = WMSGREL and MSGFILNOR = WMSGFILNOR
    For [EXF]
      WOK = [V]CST_ATRUE
      Break
    Next
    Filter [EXF]
    LogicClose File [EXF]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

####################################################################

Funprog CTRL_EXIST_MSG(WMSGCOD,WMSGREL)
Value Char WMSGCOD
Value Char WMSGREL

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WMSGCOD <> "" and WMSGREL <> ""
    Local File EDIMSG [EMS]
    Read [EMS]EMS0 = WMSGCOD;WMSGREL
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [EMS]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

####################################################################

Funprog COPY_XML(WOBJECT, WERR)
Variable Instance WOBJECT Using OBJECT
Variable Char WERR

  Local Char WOLD_MSGCOD(20)    : WOLD_MSGCOD    = WOBJECT.MSGCOD
  Local Char WOLD_MSGREL(5)     : WOLD_MSGREL    = WOBJECT.MSGREL
  Local Char WOLD_MSGFILNOR(20) : WOLD_MSGFILNOR = WOBJECT.MSGFILNOR
  Local Char WNEW_MSGCOD(20)    : WNEW_MSGCOD    = WOBJECT.MSGCODNEW
  Local Char WNEW_MSGREL(5)     : WNEW_MSGREL    = WOBJECT.MSGRELNEW
  Local Char WNEW_MSGFILNOR(20) : WNEW_MSGFILNOR = WOBJECT.MSGFILNORNEW
  Local Char WNEW_FILDES(50)    : WNEW_FILDES    = WOBJECT.FILDESNEW
  Local Integer WOK             : WOK            = [V]CST_AOK

  Local Integer I,J,K, WPOS
  Local Integer WCOPIED : WCOPIED = [V]CST_AFALSE

  #origine
  #on cree une nouvelle instance
  Local Instance WMYXML_OLD Using R_EDIXMLFIL
  WMYXML_OLD = NewInstance R_EDIXMLFIL AllocGroup null
  WOK = fmet WMYXML_OLD.AREAD(WOLD_MSGCOD, WOLD_MSGREL, WOLD_MSGFILNOR)
  If WOK = [V]CST_AOK
    #new"
    Local Instance WMYXML_NEW Using R_EDIXMLFIL
    WMYXML_NEW = NewInstance R_EDIXMLFIL AllocGroup null
    WOK = fmet WMYXML_NEW.AINIT()
    #nouvelles clés
    WMYXML_NEW.EXF.MSGCOD    = WNEW_MSGCOD
    WMYXML_NEW.EXF.MSGREL    = WNEW_MSGREL
    WMYXML_NEW.EXF.MSGFILNOR = WNEW_MSGFILNOR
#    WMYXML_NEW.EXF.FILDES    = WOBJECT.FILDES #X3-66532 Description of XML file duplication (JUCON:19/12/17)
    WMYXML_NEW.EXF.FILDES    = WOBJECT.FILDESNEW
#est-ce util ?
    #récupération des propriétés de l'origine
    WMYXML_NEW.EXF.CODACT       = WMYXML_OLD.EXF.CODACT
    WMYXML_NEW.EXF.FLGMUX       = WMYXML_OLD.EXF.FLGMUX
    WMYXML_NEW.EXF.KEYALIAS     = WMYXML_OLD.EXF.KEYALIAS
    WMYXML_NEW.EXF.KEYDES       = WMYXML_OLD.EXF.KEYDES
    WMYXML_NEW.EXF.KEYPROPERTY  = WMYXML_OLD.EXF.KEYPROPERTY
    WMYXML_NEW.EXF.KEYPROTOPATH = WMYXML_OLD.EXF.KEYPROTOPATH
##
    WMYXML_NEW.EXF.TYPFIL       = WMYXML_OLD.EXF.TYPFIL

    #on prend les XSD défini dans la duplication et non ceux d'origine
    WPOS = 0
    For I = 1 To maxtab(WOBJECT.EXSD) #
      If WOBJECT.EXSD(I)<>null
&       and WOBJECT.EXSD(I).ASTALIN <> [V]CST_ADEL
&       and WOBJECT.EXSD(I).ASTALIN <> [V]CST_ANEWDEL
        WPOS = fmet WMYXML_NEW.EXF.ADDLINE("EXSD",[V]CST_ALASTPOS)
        WMYXML_NEW.EXF.EXSD(WPOS).CODE =  WOBJECT.EXSD(I).CODE
      Endif
    Next I

    #on prend la description du nom de fichier de l'origine (bloc Fichier - pour reception)
    WPOS = 0
    For I = 1 To maxtab(WMYXML_OLD.EXF.EXFF) #
      If WMYXML_OLD.EXF.EXFF(I)<>null
&       and WMYXML_OLD.EXF.EXFF(I).ASTALIN <> [V]CST_ADEL
&       and WMYXML_OLD.EXF.EXFF(I).ASTALIN <> [V]CST_ANEWDEL
        WPOS = fmet WMYXML_NEW.EXF.ADDLINE("EXFF",[V]CST_ALASTPOS)
        WMYXML_NEW.EXF.EXFF(WPOS).FILNAM      = WMYXML_OLD.EXF.EXFF(I).FILNAM
        WMYXML_NEW.EXF.EXFF(WPOS).DESCRIPTION = WMYXML_OLD.EXF.EXFF(I).DESCRIPTION
      Endif
    Next I

    #on prend la description de la définition du nom de fichier à créer de l'origine (bloc Définition du nom de fichier - pour emission)
    WPOS = 0
    For I = 1 To maxtab(WMYXML_OLD.EXF.EXFN) #
      If WMYXML_OLD.EXF.EXFN(I)<>null
&       and WMYXML_OLD.EXF.EXFN(I).ASTALIN <> [V]CST_ADEL
&       and WMYXML_OLD.EXF.EXFN(I).ASTALIN <> [V]CST_ANEWDEL
        WPOS = fmet WMYXML_NEW.EXF.ADDLINE("EXFN",[V]CST_ALASTPOS)
        WMYXML_NEW.EXF.EXFN(WPOS).COMTYP = WMYXML_OLD.EXF.EXFN(I).COMTYP
        WMYXML_NEW.EXF.EXFN(WPOS).COMVAL = WMYXML_OLD.EXF.EXFN(I).COMVAL
        WMYXML_NEW.EXF.EXFN(WPOS).FORMAT = WMYXML_OLD.EXF.EXFN(I).FORMAT
      Endif
    Next I

    #on enregistre
    WOK = fmet WMYXML_NEW.AINSERT()
    If WOK <> [V]CST_AERROR
      WCOPIED = [V]CST_ATRUE
      #On génère les paths
      WOK = fmet WMYXML_NEW.EXF.MET_GET_PATH()
      #On met à jour
      WOK = fmet WMYXML_NEW.AUPDATE()
      #On récupere les paths de l'origine et on assigne les nouveaux ID correpondant aux path d'origine + toute la ligne d'origine (condition etc)
      WOK = func GET_OLD_XML_SETUP(WOBJECT, WERR)
    Else
      WCOPIED = [V]CST_AFALSE
    Endif
    FreeInstance WMYXML_NEW : WMYXML_NEW = null
  Else
    #erreur opening origin
  Endif
  FreeInstance WMYXML_OLD : WMYXML_OLD = null

  Case WCOPIED
    When [V]CST_AFALSE : WOK = [V]CST_AERROR
    When [V]CST_ATRUE  : WOK = [V]CST_AOK
  Endcase
End WOK

####################################################################

Funprog GET_OLD_XML_SETUP(WOBJECT, WERR)
Variable Instance WOBJECT Using OBJECT
Variable Char WERR

  Local Char WOLD_MSGCOD(20)    : WOLD_MSGCOD    = WOBJECT.MSGCOD
  Local Char WOLD_MSGREL(5)     : WOLD_MSGREL    = WOBJECT.MSGREL
  Local Char WOLD_MSGFILNOR(20) : WOLD_MSGFILNOR = WOBJECT.MSGFILNOR
  Local Char WNEW_MSGCOD(20)    : WNEW_MSGCOD    = WOBJECT.MSGCODNEW
  Local Char WNEW_MSGREL(5)     : WNEW_MSGREL    = WOBJECT.MSGRELNEW
  Local Char WNEW_MSGFILNOR(20) : WNEW_MSGFILNOR = WOBJECT.MSGFILNORNEW
  Local Integer WOK             : WOK            = [V]CST_AERROR
  Local Integer WSTA            : WSTA           = [V]CST_AERROR
  Local Integer WFLG_FOUND      : WFLG_FOUND     = [V]CST_AFALSE

  Local Integer WNEW_PATHID
  Local Clbfile WNEW_PATHCLB(1)
  Local Char    WNEW_PATHTYPE(250)
  Local Char    WNEW_PATHREST(250)

  Local File EDIXMLFILD [EXSD_NEW]
  Local File EDIXMLFILD [EXSD_OLD]
  Filter [EXSD_OLD] Where MSGCOD = WOLD_MSGCOD and MSGREL = WOLD_MSGREL and MSGFILNOR = WOLD_MSGFILNOR Order By NUMLIN
  For [EXSD_OLD]
    WFLG_FOUND = [V]CST_ATRUE
    WNEW_PATHCLB = ""
    WSTA = func GET_FULLPATH(WOLD_MSGCOD, WOLD_MSGREL, WOLD_MSGFILNOR, [EXSD_OLD]PATHID, WNEW_PATHCLB)
    If WSTA = [V]CST_AOK
      WNEW_PATHID = 0
      WSTA = func GET_NEW_PATH_INFO(WNEW_MSGCOD, WNEW_MSGREL ,WNEW_MSGFILNOR, WNEW_PATHCLB, WNEW_PATHID, WNEW_PATHTYPE, WNEW_PATHREST)
      Trbegin [EXSD_NEW]
      If WSTA = [V]CST_AOK
        [EXSD_NEW]PATHID      = WNEW_PATHID
        [EXSD_NEW]PATHSTR     = WNEW_PATHCLB
        [EXSD_NEW]PATHTYPE    = WNEW_PATHTYPE
        [EXSD_NEW]PATHREST    = WNEW_PATHREST
      Else
        [EXSD_NEW]PATHID      = 0
        [EXSD_NEW]PATHSTR     = ""
        [EXSD_NEW]PATHTYPE    = ""
        [EXSD_NEW]PATHREST    = ""
        #error GET_NEW_PATH_INFO
        WERR = "Warning :"-"Aucune corrrespondance trouvée."-"Ligne non traitée"-"("+[EXSD_OLD]PATHSTR+")"
        ASTATUS = fmet WOBJECT.ASETERROR("", WERR, [V]CST_AWARNING)
      Endif
      [EXSD_NEW]MSGCOD        = WNEW_MSGCOD
      [EXSD_NEW]MSGREL        = WNEW_MSGREL
      [EXSD_NEW]MSGFILNOR     = WNEW_MSGFILNOR
      [EXSD_NEW]NUMLIN        = [EXSD_OLD]NUMLIN
      [EXSD_NEW]SORT          = [EXSD_OLD]SORT
      [EXSD_NEW]ALIAS         = [EXSD_OLD]ALIAS
      [EXSD_NEW]EXPRESSION    = [EXSD_OLD]EXPRESSION
      [EXSD_NEW]PROTOPATH     = [EXSD_OLD]PROTOPATH
      [EXSD_NEW]CONDITIONSTR  = [EXSD_OLD]CONDITIONSTR
      [EXSD_NEW]CONDITIONPAT  = [EXSD_OLD]CONDITIONPAT
      Write[EXSD_NEW]
      If [S]fstat
        Rollback
        WERR = "Erreur :"-"Ligne non traitée"-"("+[EXSD_OLD]PATHSTR+")"
        ASTATUS = fmet WOBJECT.ASETERROR("", WERR, [V]CST_AERROR)
      Else
        Commit
      Endif
    Else
      #error GET_FULLPATH
      WERR = "Warning :"-"Aucune corrrespondance trouvée."-"Ligne non traitée"-"("+[EXSD_OLD]PATHSTR+")"
      ASTATUS = fmet WOBJECT.ASETERROR("", WERR, [V]CST_AWARNING)
    Endif
  Next
  LogicClose File [EXSD_OLD]
  LogicClose File [EXSD_NEW]

  If WFLG_FOUND = [V]CST_AFALSE
    WOK = [V]CST_AERROR
    WERR = "Error :"-"Enregistrement d'origine non trouvé"
    ASTATUS = fmet WOBJECT.ASETERROR("", WERR, [V]CST_AERROR)
  Else
    WOK = [V]CST_AOK
  Endif

End WOK

####################################################################

Funprog GET_FULLPATH(WMSGCOD, WMSGREL, WMSGFILNOR, WPATHID, WPATHCLB)
Value Char WMSGCOD()
Value Char WMSGREL()
Value Char WMSGFILNOR()
Value Integer WPATHID
Variable Clbfile WPATHCLB()

  Local Integer WSTA       : WSTA       = [V]CST_AERROR
  Local Integer WFLG_FOUND : WFLG_FOUND = [V]CST_AFALSE

  Local File EDIXMLFILP [EXFP]
  Read [EXFP]EXFP0 = WMSGCOD; WMSGREL; WMSGFILNOR; WPATHID
  If !fstat
    WFLG_FOUND = [V]CST_ATRUE
    WPATHCLB   = [EXFP]PATHCLB
  Else
    WFLG_FOUND = [V]CST_AFALSE
  Endif
  LogicClose File [EXFP]

  If WFLG_FOUND = [V]CST_ATRUE
    WSTA = [V]CST_AOK
  Else
    WSTA = [V]CST_AERROR
  Endif
End WSTA

####################################################################

Funprog GET_NEW_PATH_INFO(WMSGCOD, WMSGREL, WMSGFILNOR, WPATHCLB, WPATHID, WPATHTYPE, WPATHREST)
Value Char WMSGCOD()
Value Char WMSGREL()
Value Char WMSGFILNOR()
Value Clbfile WPATHCLB()
Variable Integer WPATHID
Variable Char WPATHTYPE()
Variable Char WPATHREST()

  WPATHID   = 0
  WPATHREST = ""

  Local Integer WSTA       : WSTA       = [V]CST_AERROR
  Local Integer WFLG_FOUND : WFLG_FOUND = [V]CST_AFALSE

  Local File EDIXMLFILP [EXFP]
  Filter [EXFP] Where MSGCOD = WMSGCOD and MSGREL = WMSGREL and MSGFILNOR = WMSGFILNOR #and PATHCLB = WPATHCLB
  For [EXFP]
    If [EXFP]PATHCLB = WPATHCLB
      WFLG_FOUND = [V]CST_ATRUE
      WPATHID    = [EXFP]PATHID
      WPATHTYPE  = [EXFP]PATHTYPE
      WPATHREST  = [EXFP]PATHREST
      Break
    Endif
  Next
  LogicClose File [EXFP]

  If WFLG_FOUND = [V]CST_ATRUE
    WSTA = [V]CST_AOK
  Else
    WSTA = [V]CST_AERROR
  Endif
End WSTA

