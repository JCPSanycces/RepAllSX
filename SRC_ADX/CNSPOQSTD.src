#<AdxTL>@(#)11.0.0.0 $Revision$ Consultation POQ
##################################################
#                                                #
#    Consultation des commandes ST               #
#                                    MM   03/02  #
##################################################


########################################################
#                                                      
# Parametres de consultation via PARAM()               
#                                                      
#
#1 = site
#
#2 = N° commande
#
#3 = Fournisseur
#
########################################################

Local Char PARAM(20)(1..3)
PARAM(1)="GAL"
PARAM(2)=""
PARAM(3)=""

Call GCONSULT("POQ", "",PARAM) From GCONSULT
End


##################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LECTURE"  : Gosub LECTURE
 When default
Endcase
Return


##################################################
$OUVRE

Integer I
Local Char CRITERE(255),CRITERE1(255)
Local Char DEBNUM , FINNUM


If clalev ([F:POQ]) <= 0 : Local File PORDERQ [POQ] : Endif
If clalev ([F:MFO]) <= 0 : Local File MFGOPE  [MFO] : Endif

Gosub DEFCRIT

Return

##################################################
$DEFCRIT
#chargement par defaut : en fonction du site + date du jour


For I= 1 To dim(PARAM)
  Case I
    When 1 :     #site
            If  PARAM(I)<> ""   
                 Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                 If !fstat : [M:POQ]POHFCY = PARAM(I): Endif
            Endif
    When 2 :     # N° commande
            If  PARAM(I)<> ""  
                  [M:POQ1]POHNUMDEB = PARAM(I)
                  [M:POQ1]POHNUMFIN = PARAM(I) 
            Endif  
              
    When 3 :    #fournisseur
            If PARAM(I)<>""
                  [M:POQ1]BPSNUMDEB = PARAM(I)
                  [M:POQ1]BPSNUMFIN = PARAM(I)
           Endif
   When Default : Break

  Endcase
Next I

# Copie de l'ecran d'entête / ecran de criteres
Gosub CRITENT From =PROGCNS

Return

##################################################
$LECTURE
#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

#-- Positionnement des filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################
#-- Application du filtre et positionnement des boutons, classé par N° OF
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR =1       #recherche
    Elsif CHGPAG = 2 : RETOUR = 2   # suite
    Endif 
    Link [MFO] With [POQ]POQ0=POHNUM;POPLIN;POPSEQ As [NEW] Where evalue (CRITERE1)
&         Order By Key CLE =[F:POQ]POHNUM 
Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE =1    #dernier
    Elsif CHGPAG =-2 : SUITE = 2 #retour
    Endif
    Link [MFO] With [POQ]POQ0=POHNUM;POPLIN;POPSEQ As [NEW] Where evalue (CRITERE1)
&         Order By Key CLE =[F:POQ]POHNUM Desc

Endif

# RAZ du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:POQ2] : Endif

For[NEW]
    If NBLU=1 
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:POQ2] : Endif
        NBLU =2
    Endif

    If CHGPAG >0
        If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
        NOL +=1
        If NOL = 0 
            DEBNUM = [F:POQ]POHNUM
        Endif
        FINNUM = [F:POQ]POHNUM
    Else
        If NOL <=0 : RETOUR = 2 : Break : Endif
        NOL -=1
        If NOL = MAXLIG -1 
            FINNUM =  [F:POQ]POHNUM
        Endif
        DEBNUM = [F:POQ]POHNUM

    Endif

    nolign = NOL+1
    [M:POQ2]MFGNUM(nolign-1)    = [F:MFO]MFGNUM 
    [M:POQ2]SCOITMREF(nolign-1) = [F:MFO]SCOITMREF
    [M:POQ2]BPSNUM(nolign-1)    = [F:MFO]BPRNUM
    [M:POQ2]ORDDAT(nolign-1)    = [F:POQ]ORDDAT
    [M:POQ2]POHNUM(nolign-1)    = [F:POQ]POHNUM
   
Next 


Return

##################################################
$LOAD_FILTER

Raz CRITERE 
CRITERE1 ="1=1"

#site
If [M:POQ1]POHFCY <> ""
    CRITERE = "[F:POQ]POHFCY=[M:POQ1]POHFCY"
    Gosub LOAD_CRITERE
Endif

#N° commande
If [M:POQ1]POHNUMDEB<>""
    CRITERE ="[F:POQ]POHNUM >=[M:POQ1]POHNUMDEB"
    Gosub LOAD_CRITERE
Endif

If [M:POQ1]POHNUMFIN<>""
    CRITERE ="[F:POQ]POHNUM <=[M:POQ1]POHNUMFIN"
    Gosub LOAD_CRITERE
Endif

#Fournisseur
If [M:POQ1]BPSNUMDEB<>""
    CRITERE = "[F:POQ]BPSNUM >=[M:POQ1]BPSNUMDEB"
    Gosub LOAD_CRITERE
Endif

If [M:POQ1]BPSNUMFIN<>""
   CRITERE = "[F:POQ]BPSNUM <=[M:POQ1]BPSNUMFIN"
   Gosub LOAD_CRITERE
Endif

Case CHGPAG
    When 3 : # rafraichissement
            CRITERE = "[F:POQ]POHNUM >=DEBNUM"
            Gosub LOAD_CRITERE
    When 2 : #suite    
            CRITERE = "[F:POQ]POHNUM >FINNUM"
            Gosub LOAD_CRITERE
    When -2: # retour
            CRITERE = "[F:MFO]POHNUM < DEBNUM"
            Gosub LOAD_CRITERE
Endcase 

Return

########################################
$LOAD_CRITERE

If len(CRITERE1)<>0 : CRITERE1 += "&": Endif
CRITERE1 += CRITERE

Return

###################################################################################
#                                                                                 #
#    ETIQUETTES ECRAN                                                             #
#                                                                                 #
###################################################################################

########################################
Subprog AM_POHNUMDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<> ""
        [M]POHNUMFIN = VALEUR
  Endif
End

########################################
Subprog C_POHNUMFIN(VALEUR)
Variable Char    VALEUR()
    If VALEUR < [M]POHNUMDEB : GMESSAGE= mess(44,199,1) :  mkstat = 2 : End : Endif
End

########################################
Subprog AM_BPSNUMDEB(VALEUR)
Variable Char    VALEUR()
    If [M]BPSNUMDEB="" : [M]BPSNUMFIN = VALEUR : Endif
    If [M]BPSNUMFIN< VALEUR : [M]BPSNUMFIN = VALEUR : Endif
End

########################################
Subprog C_BPSNUMFIN(VALEUR)
Variable Char    VALEUR()
End

# FQ 57754 Module Tronc commun GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(9)<>2 End Endif

Call VALGTC(APPLI,"POQ") From SUBGTC

End

