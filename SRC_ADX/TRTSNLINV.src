    [M:SNL1]QTYSTUNEW1(NOL) = VALEUR * [M:SNL1]PCUSTUNEW1(NOL)
    Call QTEARR( [M:SNL1]QTYSTUNEW1(NOL),[M:SNL1]STU) From TRTDIV
#    If [F:TUN]UOMDEC = 0  &  WQTYSTU <> WQTYSTU1               # hcb 116716
