#<AdxTL>@(#)7.0.0.0 $Revision$
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "INIT"        : Gosub INIT
 When "TITRE"       : Gosub TIT_TRT
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "ABA"         : Gosub ABA
 When "ENR"         : Gosub ENR
 When "END"         : Gosub FINEND
 When "FIN"         : Gosub FIN
 When "FINSAI"      : Gosub FINSAI
Endcase
Return
#########################################################################
$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","6",GSNLNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GSNLNUM-":"-TIT
Return


#########################################################################
$INIT
# gouvinv = 1 automatique comptage sur ligne
# gouvinv = 2 clic droit comtage sur ligne
# gouvinv = 3 clic droit sur ligne
# gouvinv = 4 clic droit sur fin tableau
#si variable globale GOUVINV <= 1 on sort
If GOUVINV < 1
  FIN = 1
  Return
Endif

#recuperation ecran généré de la saisie des regroupements inventaires
Local Char       LBOI(GLONFEN) : LBOI  =     "WQSNL"+GFLAG+"S"

BCRIT = ""

# ouverture de l ecran géneré
If LBOI = ""
   LBOI = "ISNL1"
Endif

BOITE = LBOI

Return

#########################################################################
$OUVRE_BOITE
#########################################################################
#recuperation parametre standard
#recuperation code ecran
Local Char       LSSS      : LSSS      =      PARAM(1)
#recuperation ecran généré document inventaire
Local Char       LLIS      : LLIS      =      PARAM(2)
#recuperation numero de ligne
Global Integer   GLIG_SNL0 : GLIG_SNL0 =      val(PARAM(3))
#recuperation code ecran
Local Char       LABR      : LABR      =      PARAM(4)


#########################################################################

If clalev([F:STL])=0  Local File STOLOT        [STL]  Endif
If clalev([F:STL1])=0 Local File STOLOT        [STL1] Endif
If clalev([F:ITF])=0  Local File ITMFACILIT    [ITF]  Endif
If clalev([F:ITM])=0  Local File ITMMASTER     [ITM]  Endif
If clalev([F:ITP])=0  Local File ITMBPS        [ITP]  Endif
If clalev([F:TUN])=0  Local File TABUNIT       [TUN]  Endif
If clalev([F:STJ])=0  Local File STOJOU        [STJ]  Endif
If clalev([F:STO])=0  Local File STOCK         [STO]  Endif
If clalev([F:STS])=0  Local File STOSER        [STS]  Endif
If clalev([F:STA])=0  Local File STOALL        [STA]  Endif
If clalev([F:TLO])=0  Local File TABLOCTYP     [TLO]  Endif
If clalev([F:STC])=0  Local File STOLOC        [STC]  Endif
If clalev([F:SLF])=0  Local File STOLOTFCY     [SLF]  Endif
If clalev([F:AWI])=0  Local File AWINDOW       [AWI]  Endif
If clalev([F:LPN])=0  Local File LPN           [LPN]  Endif                        # hcb x3-68147
If clalev([F:CUD1])=0 Local File CUNLISDET     [CUD1] Endif                      # hcb x3-68147

If GWRHACT = 2
   If clalev([F:ITW])=0 Local File ITMWRH     [ITW]  Endif
   If clalev([F:WRH])=0 Local File WAREHOUSE  [WRH]  Endif
Endif

Local Char WNOMMSK(GLONAMK)
Read [AWI] AWI0=BOITE
If fstat
   WNOMMSK="SNL1"
Else
   WNOMMSK=[F:AWI]NOMMSK(0)
Endif

Gosub CHANGE_AWI From STKINV


If [F:ITM]ITMREF <> [M:SNL0]ITMREF(GLIG_SNL0)
   Read [F:ITM]ITM0=[M:SNL0]ITMREF(GLIG_SNL0)
   If fstat
      Raz [F:ITM]
   Endif
Endif
If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SNL0]STOFCY
   Read [ITF]ITF0=[F:ITM]ITMREF;[M:SNL0]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

#desactivation des rubriques ecrans suivant le contexte
Gosub FORMAT_INV_SNL1 From STKINV


Global Integer GMOD_INV
GMOD_INV = 1
If clalev([M:SNL1])  = 0  Local Mask = WNOMMSK   [SNL1] Endif
If clalev([M:VALW])  = 0  Local Mask   STOVALW   [VALW] Endif
If clalev([M:SNL1W]) = 0  Local Mask   SNL1W     [SNL1W] Endif                  # hcb X3-68147


Raz [M:SNL1]
Raz [M:VALW]
[M:VALW]ZONPRI    = "[M:SNL1]PRIORD"
[M:VALW]ZONPRIORD = "[M:SNL1]PRIORD"
Return

#########################################################################
$DEBUT

Gosub CHARGE_SNL1
# pour desactiver ENREGISTRER et ABANDON
REP = ""

Return

#########################################################################
$SETBOUT

Local Integer WI
WI = find(2,[M:SNL1]MODFLG(0..[M:SNL1]NBLIG-1))
If WI > 0 | REP = "M"    # hcb 53846
   ETABOU(GENRE) = 1
   ETABOU(GABAN) = 1

Else
   ETABOU(GENRE) = 0
   ETABOU(GABAN) = 0
Endif
If GSNLSTAIMG3 = 2      # hcb 74380
   ETABOU(GENRE) = 0
   ETABOU(GABAN) = 0
Endif

Return

#########################################################################
$APRES_MODIF

# pour activer ENREGISTRER et ABANDON
REP = "M"
Return

#########################################################################
$AVANT_ENR
Return

#########################################################################
$ENR
Local Integer  WRET


If [M]PECQTY <> 0
   If GOUVINV = 1
#---------------------------#
# Si quantité saisie différente de celle dans le document
#---------------------------#
      If [M]PECQTY <> [M]QTYTOENT
         Call OUINON(mess(23,184,1)-mess(36,100,1),WRET) From GESECRAN
#  la quantitée traitée est incorrecte ! comfirmation ?
         If WRET<>2
            FOK = 0
            Return
         Endif
      Endif
   Endif
Endif


Local Integer LLIG
Local Integer NOL                                                        # hcb x3-68147
For LLIG = 0 To [M:SNL1]NBLIG-1
#                                                                         # hcb x3-68147 deb
    If [M:SNL1]LINFLG(LLIG) =  1
       NOL = LLIG
       Gosub EXI_INVENTAIRE
       If WOK <> 0
          WRET = 2
          Break
       Endif
    Endif
#                                                                         # hcb x3-68147 fin

#                                                                                         # hcb 71659 deb
    If [M:SNL0]MULCTGFLG <> 2
       If [M:SNL1]QTYSTUNEW(LLIG) =  0  & [M:SNL1]ZERSTOFLG(LLIG) =  1
          WRET = 1
          Break
       Endif
    Endif
    If find([M:SNL0]SAICOD(GLIG_SNL0),"+","+1") & [M:SNL1]QTYSTUNEW1(LLIG) =  0  & [M:SNL1]ZERSTOFLG1(LLIG) =  1
             WRET = 1
             Break
    Endif
    If find([M:SNL0]SAICOD(GLIG_SNL0),"+2") & [M:SNL1]QTYSTUNEW2(LLIG) =  0  & [M:SNL1]ZERSTOFLG2(LLIG) =  1
             WRET = 1
             Break
    Endif
    If  find([M:SNL0]SAICOD(GLIG_SNL0),"") & [M:SNL1]QTYSTUNEW(LLIG) =  0  & [M:SNL1]ZERSTOFLG(LLIG) =  1  & GOUVINV <> 4
             WRET = 1
             Break
    Endif
    If [M:SNL0]MULCTGFLG = 2
# si la saisie du comptage 2 = comptage 1 alors comptage = comptage 2
       If [M:SNL1]MODFLG(LLIG) = 2 & [M:SNL1]CTG1(LLIG) = 2 & [M:SNL1]CTG2(LLIG) = 0
#                                                            # hcb 71659 pe deb
          Raz GPE
          If GINICPT <> 0
             GPOINT = "INICPTSNL1"
             Gosub  ENTREE From EXEFNC
          Endif
          If GPE =  0
#                                                            # hcb 71659 pe fin
             If ([M:SNL1]QTYPCUNEW1 (LLIG)= [M:SNL1]QTYPCUNEW2 (LLIG))
&      &        ([M:SNL1]QTYSTUNEW1 (LLIG)= [M:SNL1]QTYSTUNEW2 (LLIG))
&      &        ([M:SNL1]PCUSTUNEW1 (LLIG)= [M:SNL1]PCUSTUNEW2 (LLIG))
&      &        ([M:SNL1]ZERSTOFLG1 (LLIG)= [M:SNL1]ZERSTOFLG2 (LLIG))
                [M:SNL1]QTYPCUNEW  (LLIG)= [M:SNL1]QTYPCUNEW2 (LLIG)
                [M:SNL1]QTYSTUNEW  (LLIG)= [M:SNL1]QTYSTUNEW2 (LLIG)
                [M:SNL1]PCUSTUNEW  (LLIG)= [M:SNL1]PCUSTUNEW2 (LLIG)
                [M:SNL1]ZERSTOFLG  (LLIG)= [M:SNL1]ZERSTOFLG2 (LLIG)
             Endif
          Endif                                              # hcb 71659 pe
       Endif
    Endif
#                                                                                         # hcb 71659 fin

    If [M:SNL1]STOCOU     (LLIG) =  0  & [M:SNL1]CUNLISSTA(LLIG) = 1 &
&      [M:SNL1]ITMLISNUMS (LLIG) <> 0  & [M:SNL1]QTYSTUNEW(LLIG) = 0 & [M:SNL1]ZERSTOFLG(LLIG) = 2
       Goto NEXTCTR
    Endif
    If [M:SNL1]STOCOU(LLIG) =  0  & [M:SNL1]CUNLISSTA(LLIG) =  1
       If [F:ITM]LOTMGTCOD > 2 & dim([M:SNL1]LOT) > 0
          If [M:SNL1]LOT(LLIG) = ""
             WRET = 1
             Break
          Endif
       Endif
       If [F:ITM]LOTMGTCOD =4 & dim([M:SNL1]SLO) > 0
          If [M:SNL1]SLO(LLIG) = ""
             WRET = 1
             Break
          Endif
       Endif
        If [M:SNL1]STA(LLIG) = ""
           WRET = 1
           Break
       Endif
       If [F:ITM]SERMGTCOD = 3 & dim([M:SNL1]SERNUM) > 0            # hcb 48239
          If [M:SNL1]SERNUM(LLIG) = ""
             WRET = 1
             Break
          Endif
       Endif
       If [F:ITF]LOCMGTCOD = 2  & dim([M:SNL1]LOC) > 0
          If [M:SNL1]LOC(LLIG) = ""
             WRET = 1
             Break
          Endif
       Endif
       If [F:ITM]LOTMGTCOD =  1
# creation lot blanc pour les articles non gere en lot
          Read [STL]STL0=[M:SNL1]ITMREF;"";""
          If  fstat
             [F:STL]ITMREF    = [M:SNL1]ITMREF
             Raz [F:STL]LOT
             Raz [F:STL]SLO
             Raz [F:STL]ECCVALMAJ                                       # hcb 71276
             Raz [F:STL]ECCVALMIN                                       # hcb 71276
             [F:STL]VCRTYP    = 9
             [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
             [F:STL]VCRLIN    = 0
             [F:STL]REFPER    = date$
             [F:STL]LOTCREDAT = date$
             [F:STL]DLUDAT    = [31/12/2999]     # V6per
             [F:STL]NEWLTIDAT = [31/12/2999]     # V6per
             #--- Bug 60996
             [F:STL]POT       = 100
             [F:STL]ACT       = 1
             #---
             Call ECRSTL From STKLIB
             If fstat
                Call FSTA("STL") From GLOCK
                WRET = 9
                Break
             Endif
#flag creation STOLOT à oui
            [M:SNL1]STLFLG(LLIG) = 2

          Endif
       Endif
    Endif
$NEXTCTR
Next
#                                                                    # hcb x3-68147 deb
If WRET <> 0
   Case WRET
        When 1 :
           Call ERREUR(mess(7,111,1)-num$(LLIG+1)) From GESECRAN    # Ligne incomplete
        When 2 :
           Call ERREUR(mess(448,199,1)-mess(3,40,1)-num$(LLIG+1)) From GESECRAN  # Ligne d'inventaire déjà présente
        When 9 :
   Endcase
   FOK = 0
   Return
Endif
#If WRET = 9
#   FOK = 0
#   Return
#Endif
#                                                                    # hcb x3-68147 fin


Gosub MOD_INV From STKINV
If WRET <> 0                                           # hcb # 68147
   Return
Endif
Local Integer LRET
Call STKDELRES(0,[M:SNL1]STOFCY,"",LRET) From STKLOC

#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG <> 2
   Gosub DEBUT
Else
   REP = ""
Endif
#                                                                                         # hcb 71659 fin

Return

#########################################################################
$ABA
#suppression des lots créés sur des lignes non validées
Gosub SUP_LOT_SNL1

Gosub DEBUT

Return

#########################################################################
$FINEND

If dim(GMOD_INV) > 0
   If GMOD_INV <> 2
# il ni y pas eu de modifs il faut rafraichir le regroupement avec les valeurs initiales
      If GOUVINV = 4
        [M:SNL0]CUNLISSTAD (GLIG_SNL0) = 7
         Affzo [M:SNL0]CUNLISSTAD(GLIG_SNL0)

      Endif
      If dim ([M:SNL0]QTYPCUNEW (GLIG_SNL0)) > 0
         [M:SNL0]QTYPCUNEW(GLIG_SNL0) = [M:SNL0]QTYPCUNEWS(GLIG_SNL0)
         Affzo [M:SNL0]QTYPCUNEW(GLIG_SNL0)
      Endif
      If dim ([M:SNL0]QTYSTUNEW (GLIG_SNL0)) > 0
         [M:SNL0]QTYSTUNEW(GLIG_SNL0) = [M:SNL0]QTYSTUNEWS(GLIG_SNL0)
         Affzo [M:SNL0]QTYSTUNEW(GLIG_SNL0)
      Endif
      If dim ([M:SNL0]ZERSTOFLG (GLIG_SNL0)) > 0
         [M:SNL0]ZERSTOFLG(GLIG_SNL0) = [M:SNL0]ZERSTOFLGS(GLIG_SNL0)
         Affzo [M:SNL0]ZERSTOFLG(GLIG_SNL0)
      Endif
      [M:SNL0]MODFLG(GLIG_SNL0) = 1
       Affzo [M:SNL0]MODFLG(GLIG_SNL0)
      #                                                                                   # hcb 71659 deb
      If [M:SNL0]MULCTGFLG = 2
         [M:SNL0]QTYPCUNEW1      (GLIG_SNL0) = [M:SNL0]QTYPCUNEWS1(GLIG_SNL0)
         Affzo [M:SNL0]QTYPCUNEW1(GLIG_SNL0)
         [M:SNL0]QTYSTUNEW1      (GLIG_SNL0) = [M:SNL0]QTYSTUNEWS1(GLIG_SNL0)
         Affzo [M:SNL0]QTYSTUNEW (GLIG_SNL0)
         [M:SNL0]ZERSTOFLG1      (GLIG_SNL0) = [M:SNL0]ZERSTOFLGS1(GLIG_SNL0)
         Affzo [M:SNL0]ZERSTOFLG1(GLIG_SNL0)
         [M:SNL0]QTYPCUNEW2      (GLIG_SNL0) = [M:SNL0]QTYPCUNEWS2(GLIG_SNL0)
         Affzo [M:SNL0]QTYPCUNEW1(GLIG_SNL0)
         [M:SNL0]QTYSTUNEW2      (GLIG_SNL0) = [M:SNL0]QTYSTUNEWS2(GLIG_SNL0)
         Affzo [M:SNL0]QTYSTUNEW (GLIG_SNL0)
         [M:SNL0]ZERSTOFLG2      (GLIG_SNL0) = [M:SNL0]ZERSTOFLGS2(GLIG_SNL0)
         Affzo [M:SNL0]ZERSTOFLG2(GLIG_SNL0)
      Endif
      #                                                                                   # hcb 71659 fin
      Return
   Endif

Endif

[M:SNL0]CUNLISSTA = [F:CUL]CUNLISSTA
Affzo [M:SNL0]CUNLISSTA

# il y a eu des modifs il faut rafraichir le regroupement
# dans le cas d un ajout de ligne bas de tableaux SNL0 il faut rafraichir les regroupements
# dans le cas d un import il faut rafraichir les regroupements
#
If GOUVINV = 4 | GIMPINV = 1
   Local Integer WZ
   Local Integer WAF
   Local Integer WI
   Local Integer I
   WI = find(2,[M:SNL0]MODFLG(0..[M:SNL0]NBLIG-1))
   If WI > 0
      If clalev([M:SNLW])  = 0  Local Mask SNL0W   [SNLW] Endif
      Raz [M:SNLW]
      Transmask [M:SNL0] To [M:SNLW] # Issue 25606_Transmask [M:SNLW] = [M:SNL0]
   Endif
#                                                                                         # hcb 71659 deb
# pour ne pas precharger dans le cas du multi-comptages
   Local Integer WLODCOD1
   WLODCOD1 = [F:SRT]LODCOD1
   Raz [F:SRT]LODCOD1
#                                                                                         # hcb 71659 deb
   Effzo [M:SNL0]25                                                   # hcb 110327
   Gosub LOAD_SNL0 From SUBSNL
   [F:SRT]LODCOD1 = WLODCOD1                                                              # hcb 71659
   If WI > 0
         Raz WAF
         For WZ = 0 To [M:SNLW]NBLIG-1
             If [M:SNLW]MODFLG(WZ) = 2
                I =sigma(0,[M:SNL0]NBLIG-1,(indcum+1)*((dim([M:SNL0]LOT)<= 0 | [M:SNL0]LOT(indcum) = [M:SNLW]LOT(WZ))&
&                                      (dim([M:SNL0]SLO)<=0  | [M:SNL0]SLO(indcum) = [M:SNLW]SLO(WZ)) &
&                                      (dim([M:SNL0]SERNUM)<= 0 | [M:SNL0]SERNUM(indcum) = [M:SNLW]SERNUM(WZ)) &
&                                      (dim([M:SNL0]PALNUM)<= 0 | [M:SNL0]PALNUM(indcum) = [M:SNLW]PALNUM(WZ)) &
&                                      (dim([M:SNL0]CTRNUM)<= 0 | [M:SNL0]CTRNUM(indcum) = [M:SNLW]CTRNUM(WZ)) &
&                                      (dim([M:SNL0]LPNNUM)<= 0 | [M:SNL0]LPNNUM(indcum) = [M:SNLW]LPNNUM(WZ)) &
&                                      (dim([M:SNL0]WRH)   <= 0 | [M:SNL0]WRH   (indcum) = [M:SNLW]WRH   (WZ)) &
&                                      ([M:SNL0]ITMREF(indcum)    = [M:SNLW]ITMREF(WZ))        &
&                                      ([M:SNL0]PCU(indcum)       = [M:SNLW]PCU(WZ)) &
&                                      ([M:SNL0]STA(indcum)       = [M:SNLW]STA(WZ)) &
&                                      ([M:SNL0]LOC(indcum)       = [M:SNLW]LOC(WZ)) &
&                                      ([M:SNL0]NBDETAIL(indcum)  = [M:SNLW]NBDETAIL(WZ))))
                If I <> 0
                   I -= 1
                   WAF = 1
                   [M:SNL0]QTYPCUNEW(I)   = [M:SNLW]QTYPCUNEW(WZ)
                   [M:SNL0]QTYSTUNEW(I)   = [M:SNLW]QTYSTUNEW(WZ)
                   [M:SNL0]ZERSTOFLG(I)   = [M:SNLW]ZERSTOFLG(WZ)
                   [M:SNL0]MODFLG   (I)   = 2
#                                                                                         # hcb 71659 deb
                   If [M:SNL0]MULCTGFLG = 2
                      [M:SNL0]QTYPCUNEW1(I)   = [M:SNLW]QTYPCUNEW1(WZ)
                      [M:SNL0]QTYSTUNEW1(I)   = [M:SNLW]QTYSTUNEW1(WZ)
                      [M:SNL0]ZERSTOFLG1(I)   = [M:SNLW]ZERSTOFLG1(WZ)
                      [M:SNL0]QTYPCUNEW2(I)   = [M:SNLW]QTYPCUNEW2(WZ)
                      [M:SNL0]QTYSTUNEW2(I)   = [M:SNLW]QTYSTUNEW2(WZ)
                      [M:SNL0]ZERSTOFLG2(I)   = [M:SNLW]ZERSTOFLG2(WZ)
                   Endif
#                                                                                         # hcb 71659 fin
                Endif
             Endif
         Next WZ
         If WAF = 1
            Affzo [M:SNL0]25
         Endif
   Endif
   Return
Endif
Local Char    CRITER0(100)                                                                # hcb 71659
Local Char RGP_FILTRE (250)                                                               # hcb 71659
Local Char RGP_FILTRE1(250)                                                               # hcb 71659
Local Char RGP_FILTRE2(250)                                                               # hcb 71659
Local Char    CRITER1(250)(3)
Local Integer LLIG
LLIG = GLIG_SNL0
CRITER0 = "[F:CUD]CUNSSSNUM = LSSS &[F:CUD]CUNLISNUM = LLIS"
Call DEF_CRITERE_RGP(LABR,LG,CRITER1,RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2) From STKINV      # hcb 71659

If CRITER1 = ""
   CRITER1 = "1=1"
Endif
#                                                                                         # hcb 71659 deb

If [M:SNL0]MULCTGFLG = 2
   Call SIT_MULTI_COMPTAGE(RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2,LLIG) From STKINV
Endif
#                                                                                         # hcb 71659 fin

[M:SNL0]MODFLG(LLIG)           = 1
[M:SNL0]CUNLISSTAM(LLIG)       = 1
[M:SNL0]CUNLISSTAN(LLIG)       = 9

If dim([M:SNL0]QTYPCU(LLIG))    > 0
       Raz [M:SNL0]QTYPCU(LLIG)
Endif
If dim([M:SNL0]QTYPCUNEW(LLIG)) > 0
       Raz [M:SNL0]QTYPCUNEW(LLIG)
Endif
If dim([M:SNL0]QTYSTU(LLIG))    > 0
        Raz [M:SNL0]QTYSTU(LLIG)
Endif
If dim([M:SNL0]QTYSTUNEW(LLIG)) > 0
        Raz [M:SNL0]QTYSTUNEW(LLIG)
Endif
If dim([M:SNL0]QTYSTUDEV(LLIG)) > 0
        Raz [M:SNL0]QTYSTUDEV(LLIG)
Endif
If dim([M:SNL0]PRCDEV(LLIG))    > 0
        Raz [M:SNL0]PRCDEV(LLIG)
Endif
If dim([M:SNL0]CUNCST(LLIG))    > 0
        Raz [M:SNL0]CUNCST(LLIG)
Endif
If dim([M:SNL0]CUNAMT(LLIG))    > 0
        Raz [M:SNL0]CUNAMT(LLIG)
Endif
If dim([M:SNL0]CUNAMTNEW(LLIG)) > 0
        Raz [M:SNL0]CUNAMTNEW(LLIG)
Endif
If dim([M:SNL0]ZERSTOFLG(LLIG)) > 0
        Raz [M:SNL0]ZERSTOFLG(LLIG)
Endif
If dim([M:SNL0]PCUSTUNEW(LLIG)) > 0              # hcb 31134
        Raz [M:SNL0]PCUSTUNEW(LLIG)              # hcb 31134
Endif                                            # hcb 31134
If dim([M:SNL0]PCUSTUW(LLIG)) > 0                # hcb 31134
        Raz [M:SNL0]PCUSTUW(LLIG)                # hcb 31134
Endif                                            # hcb 31134
#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   Raz [M:SNL0]QTYPCUNEW1(LLIG)
   Raz [M:SNL0]QTYSTUNEW1(LLIG)
   Raz [M:SNL0]ZERSTOFLG1(LLIG)
   Raz [M:SNL0]QTYPCUNEW2(LLIG)
   Raz [M:SNL0]QTYSTUNEW2(LLIG)
   Raz [M:SNL0]ZERSTOFLG2(LLIG)
Endif
#                                                                                         # hcb 71659 fin

[M:SNL0]NBDETAIL(LLIG)          = 0
[M:SNL0]CUMALLQTY(LLIG)         = 0

Local Decimal WQTYSTUNEW
Local Decimal WQTYPCUNEW
Raz WQTYSTUNEW
Raz WQTYPCUNEW
#                                                                                         # hcb 71659 deb
Local Decimal WQTYSTUNEW1
Local Decimal WQTYPCUNEW1
Raz WQTYSTUNEW1
Raz WQTYPCUNEW1
Local Decimal WQTYSTUNEW2
Local Decimal WQTYPCUNEW2
Raz WQTYSTUNEW2
Raz WQTYPCUNEW2
#                                                                                         # hcb 71659 fin


Filter [CUD] Where evalue(CRITER0)&evalue(CRITER1)
&             Order By Key CUD0

For [CUD]
     Gosub RGP_CUM_CUMUL From STKINV
Next

Filter [CUD]


$AFFICH_SNL0

Affzo [M:SNL0]CUNLISSTAD(LLIG)
Affzo [M:SNL0]CUNLOKFLG(LLIG)

If dim([M:SNL0]QTYPCU(LLIG))    > 0
      Affzo [M:SNL0]QTYPCU(LLIG)
Endif
If dim([M:SNL0]QTYPCUNEW(LLIG)) > 0
      Affzo [M:SNL0]QTYPCUNEW(LLIG)
Endif
If dim([M:SNL0]QTYSTU(LLIG))    > 0
      Affzo [M:SNL0]QTYSTU(LLIG)
Endif
If dim([M:SNL0]QTYSTUNEW(LLIG)) > 0
      Affzo [M:SNL0]QTYSTUNEW(LLIG)
Endif
If dim([M:SNL0]QTYSTUDEV(LLIG)) > 0
      Affzo [M:SNL0]QTYSTUDEV(LLIG)
Endif
If dim([M:SNL0]PRCDEV(LLIG))    > 0
      Affzo [M:SNL0]PRCDEV(LLIG)
Endif
If dim([M:SNL0]CUNCST(LLIG))    > 0
      Affzo [M:SNL0]CUNCST(LLIG)
Endif
If dim([M:SNL0]CUNAMT(LLIG))    > 0
      Affzo [M:SNL0]CUNAMT(LLIG)
Endif
If dim([M:SNL0]CUNAMTNEW(LLIG)) > 0
      Affzo [M:SNL0]CUNAMTNEW(LLIG)
Endif
If dim([M:SNL0]ZERSTOFLG(LLIG)) > 0
      Affzo [M:SNL0]ZERSTOFLG(LLIG)
Endif
If dim([M:SNL0]PCUSTUNEW(LLIG)) > 0              # hcb 31134
      Affzo [M:SNL0]PCUSTUNEW(LLIG)              # hcb 31134
Endif                                            # hcb 31134
#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   Affzo [M:SNL0]SAICOD    (LLIG)
   Affzo [M:SNL0]ZERSTOFLG1(LLIG)
   Affzo [M:SNL0]PCUSTUNEW1(LLIG)
   Affzo [M:SNL0]QTYSTUNEW1(LLIG)
   Affzo [M:SNL0]QTYPCUNEW1(LLIG)
   Affzo [M:SNL0]ZERSTOFLG2(LLIG)
   Affzo [M:SNL0]PCUSTUNEW2(LLIG)
   Affzo [M:SNL0]QTYSTUNEW2(LLIG)
   Affzo [M:SNL0]QTYPCUNEW2(LLIG)
Endif
#                                                                                         # hcb 71659 fin

mkstat = 4                # rajouter pour forcer le IB_NBLIG en retour

Return

$FINSAI

Local Integer I
#suppression des lots créés sur des lignes non validées
Gosub SUP_LOT_SNL1

If dim(GMOD_INV) > 0
   Kill GMOD_INV
Endif
If dim(GLIG_SNL0) > 0
   Kill GLIG_SNL0
Endif

Raz GOUVINV
Raz GIMPINV
Return

$FIN
Return
#########################################################################
# SUP_LOT_SNL1           Suppression lot crée par des lignes non validées
#########################################################################

$SUP_LOT_SNL1
Local Char LSLO
For I = 0 To [M:SNL1]NBLIG-1
If [M:SNL1]STLFLG(I) = 2
   If dim([M:SNL1]SLO) > 0
      LSLO = [M:SNL1]SLO(I)
   Else
      Raz LSLO
   Endif
# Suppression lot crée par l'inventaire
   Call SUP_LOT([M:SNL1]ITMREF,[M:SNL1]STOFCY,[M:SNL1]LOT(I),LSLO,[M:SNL1]CUNLISNUM) From STKINV
Endif
Next I
Return


###############################################################################
# GESSELECTION : Met à jour le champ PECQTY
###############################################################################
$GESSELECTION
If [M]COETOENT = 0
   [M]COETOENT = 1
Endif

# L'indice maxi nécessite de prendre le maximum entre nolign et et nblig,
# car sur une nouvelle ligne (à la fin) nblig n'est toujours pas incrémenté

[M]PECQTY = sum([M]QTYSTUNEW(0..max([M]NBLIG-1,nolign-1)))/ [M]COETOENT

Return

#########################################################################
# CHARGE_SNL1                    Chargement ecran SNL1 selon regroupement
#########################################################################
$CHARGE_SNL1
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
Local Integer I,J
I = 0
Local Char    CRITER0(50)
Local Char    CRITER1(250)(3)
Local Decimal LG
LG =  GLIG_SNL0
#                                                                                         # hcb 71659  deb
Local Char RGP_FILTRE (250)
Local Char RGP_FILTRE1(250)
Local Char RGP_FILTRE2(250)

Local Decimal   WQTYSTUNEW
Raz WQTYSTUNEW

If [M:SNL0]MULCTGFLG <> 2
   WQTYSTUNEW = [M:SNL0]QTYPCUNEW(GLIG_SNL0)
Else

   If find("*2",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1)) | find("+2",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1))
      WQTYSTUNEW = [M:SNL0]QTYPCUNEW2(GLIG_SNL0)
   Else
      If find("*1",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1)) | find("+1",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1))
         WQTYSTUNEW = [M:SNL0]QTYPCUNEW1(GLIG_SNL0)
      Endif
   Endif
Endif
#                                                                                         # hcb 71659  fin


#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

#si clic droit "ajout de ligne" depuis le regroupement il ni a pas effacement des lignes precedement ajoutées
#si import il ni a pas effacement des lignes precedement ajoutées
If GOUVINV = 3 | GOUVINV = 4 | GIMPINV = 1
   Goto AFICH_SNL1_01
Endif
Raz   [M:SNL1]
Affzo [M:SNL1]
If clalev([M:VALW])
   Raz [M:VALW]
   [M:VALW]ZONPRI = "[M:SNL1]PRIORD"
   [M:VALW]ZONPRIORD = "[M:SNL1]PRIORD"
Endif

$AFICH_SNL1_01

If [F:ITM]ITMREF <> [M:SNL0]ITMREF(GLIG_SNL0)
   Read [F:ITM]ITM0=[M:SNL0]ITMREF(GLIG_SNL0)
   If fstat
      Raz [F:ITM]
   Endif
Endif
If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SNL0]STOFCY
   Read [ITF]ITF0=[F:ITM]ITMREF;[M:SNL0]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif
#chargement parametrage saisie sections analytiques
[M:SNL1]CCECODS    = [F:DTR]STOCCECOD

#chargement bloc 1
[M:SNL1]STOFCY    = [M:SNL0]STOFCY
[M:SNL1]CUNSSSNUM = [M:SNL0]CUNSSSNUM
[M:SNL1]CUNLISNUM = LLIS
#chargement bloc 2
[M:SNL1]ITMREF    = [F:ITM]ITMREF
[M:SNL1]STU       = [F:ITM]STU
[M:SNL1]LOTMGTCOD = [F:ITM]LOTMGTCOD
[M:SNL1]LPNMGTCOD = [F:ITF]LPNMGTCOD                                       # hcb X3-68147
[M:SNL1]ABCCLS    = [F:ITF]ABCCLS
If GOUVINV = 1
   [M:SNL1]QTYTOENT  = WQTYSTUNEW                                                         # hcb 71659
Endif
If GOUVINV = 2 & [M:SNL0]CUNLISSTAD(GLIG_SNL0) = 1
   [M:SNL1]QTYTOENT  = WQTYSTUNEW                                                         # hcb 71659
Endif

# si ajout de ligne pcu à entrer = stu
If GOUVINV = 4
   [M:SNL1]PCUTOENT  = [F:ITM]STU
   [M:SNL1]COETOENT  = 1
Else
   [M:SNL1]PCUTOENT  = [M:SNL0]PCU(GLIG_SNL0)
   [M:SNL1]COETOENT  = [M:SNL0]PCUSTUCOE(GLIG_SNL0)
Endif

[M:SNL1]COEFUCUS  = [M:SNL1]PCUTOENT+"  ="+format$("N:5.4",[M:SNL1]COETOENT)+"  "+[F:ITM]STU


#chargement bloc 3
CRITER0 = "[F:CUD]CUNSSSNUM = LSSS &[F:CUD]CUNLISNUM = LLIS"
Call DEF_CRITERE_RGP(LABR,LG,CRITER1,RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2) From STKINV                                # hcb 71659

If CRITER1 = ""
   CRITER1 = "1=1"
Endif
#si clic droit "ajout de ligne" depuis le regroupement il ni a pas le chargement du tableaux
If GOUVINV = 3
   Call VPD_DISZO_RGP(LABR,LG,0,2) From STKINV
Endif
Local Integer Y
Raz Y
Local Char    SECTION
Local Integer WSECTION
WSECTION = 1
If GOUVINV = 3 | GOUVINV = 4 | GIMPINV = 1
#---- Récupération des sections analytiques ----#
      Filter [CUD] Where STOFCY     = [M:SNL1]STOFCY            &
&                        ITMREF     = [M:SNL1]ITMREF            &
&                        CUNLISNUM  = [M:SNL1]CUNLISNUM          &
&                        CUNSSSNUM  = [M:SNL1]CUNSSSNUM
&            Order By Key CUD1
      For [CUD]
          If GIMPINV = 1
             If dim([M:SNL1]ITMLISNUMS) > 0
               [M:SNL1]ITMLISNUMS(I) = [F:CUD]ITMLISNUM
             Endif
          Endif

           For Y=1 To GNBDIE                                # Ana
               [M:SNL1]CCE(Y-1) = [F:CUD]CCE(Y-1)           # Ana
           Next                                             # Ana
           WSECTION = 2
           Break
      Next
      Filter [CUD]
      If WSECTION <> 2
         For Y=1 To GNBDIE
             If dim([M:SNL1]CCE(Y-1)) >0
                Call INISEC(SECTION, "STKINVD", Y) From TRTX3CPT
               [M:SNL1]CCE(Y-1) =  SECTION
             Endif
         Next
      Endif
Endif

Filter [CUD] Where evalue(CRITER0)&evalue(CRITER1)
&            Order By Key CUD0

For [CUD]
    If I >  GCOD_INV : Break : Endif
 #---- Récupération des sections analytiques ----#
    If I = 0
       For Y=1 To  GNBDIE                               # Ana
           [M:SNL1]CCE(Y-1) = [F:CUD]CCE(Y-1)           # Ana
           If [M:SNL1]CCE(Y-1) <> ""
              WSECTION = 2
           Endif
       Next
    Endif
# dans le cas ou l article gère les version en majeur et mineur il faut recuperer eccvalmin pour affichage dans
# le complement  LOT
#                                                                                  # hcb 71276 deb
    If [F:ITM]ECCSTO > 2 & dim([M:SNL1]ECCVALMIN) > 0
       Filter [F:STL1] Where ITMREF = [F:ITM]ITMREF  & LOT = [F:CUD]LOT
&             Order By Key STL0
              Read [STL1] First
              If !fstat
                 [M:SNL1]ECCVALMIN (I) = [F:STL1]ECCVALMIN
              Endif
       Filter [F:STL1]
    Endif
#                                                                                  # hcb 71276 fin

    If dim([M:SNL1]WRH) > 0
       [M:SNL1]WRH       (I) = [F:CUD]WRH
    Endif
    If dim([M:SNL1]LOC) > 0
       [M:SNL1]LOC       (I) = [F:CUD]LOC
    Endif
    If dim([M:SNL1]LPNNUM) > 0                                          # hcb x3-68147
       [M:SNL1]LPNNUM    (I) = [F:CUD]LPNNUM
    Endif

    If dim([M:SNL1]LOT) > 0
       [M:SNL1]LOT       (I) = [F:CUD]LOT
    Endif
    If dim([M:SNL1]SLO) > 0
       [M:SNL1]SLO       (I) = [F:CUD]SLO
    Endif
    If dim([M:SNL1]ECCVALMAJ) > 0                                             # hcb 71276
       [M:SNL1]ECCVALMAJ (I) = [F:CUD]ECCVALMAJ
    Endif
    If dim([M:SNL1]ECCSAIFLG) > 0                                             # hcb 112239
       [M:SNL1]ECCSAIFLG (I) = 1
    Endif
    If dim([M:SNL1]PCU) > 0
       [M:SNL1]PCU       (I) = [F:CUD]PCU
    Endif
    If dim([M:SNL1]STA) > 0
       [M:SNL1]STA       (I) = [F:CUD]STA
    Endif
    If dim([M:SNL1]QTYPCU) > 0
       [M:SNL1]QTYPCU    (I) = [F:CUD]QTYPCU
    Endif
    If dim([M:SNL1]QTYPCUNEW) > 0
       [M:SNL1]QTYPCUNEW (I) = [F:CUD]QTYPCUNEW
    Endif
    If dim([M:SNL1]PCUSTUCOE) > 0
       [M:SNL1]PCUSTUCOE (I) = [F:CUD]PCUSTUCOE
    Endif
    If dim([M:SNL1]QTYSTU) > 0
       [M:SNL1]QTYSTU    (I) = [F:CUD]QTYSTU
    Endif
    If dim([M:SNL1]QTYSTUNEW) > 0
       [M:SNL1]QTYSTUNEW (I) = [F:CUD]QTYSTUNEW
    Endif
    If dim([M:SNL1]ZERSTOFLG) > 0
       [M:SNL1]ZERSTOFLG (I) = [F:CUD]ZERSTOFLG
    Endif
    If dim([M:SNL1]SERNUM) > 0
       [M:SNL1]SERNUM    (I) = [F:CUD]SERNUM
    Endif
    If dim([M:SNL1]STOFLD1) > 0
       [M:SNL1]STOFLD1   (I) = [F:CUD]STOFLD1
    Endif
    If dim([M:SNL1]STOFLD2) > 0
       [M:SNL1]STOFLD2   (I) = [F:CUD]STOFLD2
    Endif
    If dim([M:SNL1]CUNLISSTA) > 0
       [M:SNL1]CUNLISSTA (I) = [F:CUD]CUNLISSTA
    Endif
    If dim([M:SNL1]QTYSTUDEV) > 0
       [M:SNL1]QTYSTUDEV (I) = [F:CUD]QTYSTUNEW-[F:CUD]QTYSTU
    Endif
    If dim([M:SNL1]QTYSTUNEW) > 0
       [M:SNL1]QTYSTUNEW (I) = [F:CUD]QTYSTUNEW
    Endif
    If dim([M:SNL1]PRIORD) > 0
       [M:SNL1]PRIORD (I) = [F:CUD]PRIORD
    Endif
     If dim([M:SNL1]PRCDEV) > 0
       If [F:CUD]QTYSTU = 0
          [M:SNL1]PRCDEV (I) = 0
       Else
          [M:SNL1]PRCDEV (I) = ([M:SNL1]QTYSTUDEV (I)/[F:CUD]QTYSTU)*100
       Endif
    Endif
    If dim([M:SNL1]MODFLG) > 0
       [M:SNL1]MODFLG       (I) = 1
    Endif
#                                                                                         # hcb 71659 deb
    If [M:SNL0]MULCTGFLG = 2
       [M:SNL1]QTYPCUNEW1   (I)  = [F:CUD]QTYPCUNEW1
       [M:SNL1]QTYSTUNEW1   (I)  = [F:CUD]QTYSTUNEW1
       [M:SNL1]ZERSTOFLG1   (I)  = [F:CUD]ZERSTOFLG1
       If [F:CUD]QTYSTUNEW1 <> 0 | [F:CUD]ZERSTOFLG1 = 2
          [M:SNL1]CTG1(I)  = 2
       Endif
       [M:SNL1]QTYPCUNEW2 (I) = [F:CUD]QTYPCUNEW2
       [M:SNL1]QTYSTUNEW2 (I) = [F:CUD]QTYSTUNEW2
       [M:SNL1]ZERSTOFLG2 (I) = [F:CUD]ZERSTOFLG2
       If [F:CUD]QTYSTUNEW2 <> 0 | [F:CUD]ZERSTOFLG2 = 2
          [M:SNL1]CTG2(I)  = 2
       Endif
    Endif
#                                                                                         # hcb 71659 fin

    Raz [M:SNL1]GESLOT(I)

# si enregistrement à compter et parametrage prechargement à oui alors comptée = theorique
    If [F:CUD]CUNLISSTA = 1 & [F:SRT]LODCOD1 = 2
       If [M:SNL0]MULCTGFLG <> 2                                                          # hcb 71659
        If dim([M:SNL1]QTYPCUNEW) > 0
           [M:SNL1]QTYPCUNEW (I) = [F:CUD]QTYPCU
        Endif
        If dim([M:SNL1]QTYSTUNEW) > 0
           [M:SNL1]QTYSTUNEW (I) = [F:CUD]QTYSTU
        Endif
        If dim([M:SNL1]PCUSTUNEW) > 0                                            # hcb 57285
           [M:SNL1]PCUSTUNEW(I) = [F:CUD]PCUSTUCOE                               # hcb 57285
        Endif                                                                    # hcb 57285
        If dim([M:SNL1]MODFLG) > 0
           [M:SNL1]MODFLG       (I) = 2
        Endif
        If [F:CUD]QTYPCU = 0 & [F:CUD]QTYSTU = 0 & [F:CUD]STOCOU = 0             # hcb 63659
           If dim([M:SNL1]ZERSTOFLG) > 0
              [M:SNL1]ZERSTOFLG       (I) = 2
           Endif
        Endif                                                                    # hcb 63659
#                                                                                         # hcb 71659 deb
       Else
          If [M:SNL1]CTG1(I)  = 0
             [M:SNL1]QTYPCUNEW1    (I) = [F:CUD]QTYPCU
             [M:SNL1]QTYSTUNEW1    (I) = [F:CUD]QTYSTU
             [M:SNL1]PCUSTUNEW1    (I) = [F:CUD]PCUSTUCOE
             [M:SNL1]MODFLG        (I) = 2
             If [F:CUD]QTYPCU = 0 & [F:CUD]QTYSTU = 0 & [F:CUD]STOCOU = 0
                [M:SNL1]ZERSTOFLG1 (I) = 2
             Endif
          Elsif [M:SNL1]CTG2(I)  = 0
             [M:SNL1]QTYPCUNEW2    (I) = [F:CUD]QTYPCU
             [M:SNL1]QTYSTUNEW2    (I) = [F:CUD]QTYSTU
             [M:SNL1]PCUSTUNEW2    (I) = [F:CUD]PCUSTUCOE
             [M:SNL1]MODFLG        (I) = 2
             If [F:CUD]QTYPCU = 0 & [F:CUD]QTYSTU = 0 & [F:CUD]STOCOU = 0
                [M:SNL1]ZERSTOFLG2 (I) = 2
             Endif
          Endif
       Endif
    Endif
    If [F:CUD]QTYSTUNEW1  <> 0
       [M:SNL1]PCUSTUNEW1(I) = [M:SNL1]QTYSTUNEW1(I) / [M:SNL1]QTYPCUNEW1(I)
    Endif
    If [F:CUD]QTYSTUNEW1 = 0 & [F:SRT]LODCOD1 <> 2
       If [M:SNL1]PCUSTUNEW1(I) = 0
          [M:SNL1]PCUSTUNEW1(I) = [M:SNL1]PCUSTUCOE(I)
       Endif
    Endif
    If [F:CUD]QTYSTUNEW2  <> 0
       [M:SNL1]PCUSTUNEW2(I) = [M:SNL1]QTYSTUNEW2(I) / [M:SNL1]QTYPCUNEW2(I)
    Endif
    If [F:CUD]QTYSTUNEW2 = 0 & [F:SRT]LODCOD1 <> 2
       If [M:SNL1]PCUSTUNEW2(I) = 0
          [M:SNL1]PCUSTUNEW2(I) = [M:SNL1]PCUSTUCOE(I)
       Endif
    Endif
#                                                                                         # hcb 71659 fin

    If dim([M:SNL1]PCUSTUNEW) > 0  & [F:CUD]CUNLISSTA <> 1                   # hcb 57285
       If [M:SNL1]QTYSTUNEW(I) <> 0 & [M:SNL1]QTYPCUNEW(I) <>0               # hcb 31134
          [M:SNL1]PCUSTUNEW(I) = [M:SNL1]QTYSTUNEW(I) / [M:SNL1]QTYPCUNEW(I) # hcb 31134
       Endif                                                                 # hcb 31134
    Endif                                                                    # hcb 31134
    If [F:CUD]CUNLISSTA = 1 & ([F:SRT]LODCOD1 <> 2 | [M:SNL1]CTG2(I)  = 2)                   # hcb 71659
       If dim([M:SNL1]PCUSTUNEW) > 0                                         # hcb 31134
          If [M:SNL1]PCUSTUNEW(I) = 0                                        # hcb 31134
             [M:SNL1]PCUSTUNEW(I) = [M:SNL1]PCUSTUCOE(I)                     # hcb 31134
          Endif                                                              # hcb 31134
       Endif                                                                 # hcb 31134
    Endif                                                                    # hcb 31134


# valeur unitaire
    If dim([M:SNL1]CUNCST) > 0
       [M:SNL1]CUNCST    (I) = [F:CUD]CUNCST
    Endif
# valeur théorique = valeur unitaire * qte informatique
    If dim([M:SNL1]CUNAMT) > 0
       [M:SNL1]CUNAMT    (I) = [F:CUD]CUNCST*[F:CUD]QTYSTU
    Endif

# valeur Comptée = valeur unitaire * qte comptée
    If dim([M:SNL1]CUNAMTNEW) > 0
       [M:SNL1]CUNAMTNEW (I) = [F:CUD]CUNCST*[F:CUD]QTYSTUNEW
    Endif
    If dim([M:SNL1]IPTDAT) > 0
       [M:SNL1]IPTDAT    (I) = [F:CUD]IPTDAT
    Endif
    If dim([M:SNL1]CUNLOKFLG) > 0
       [M:SNL1]CUNLOKFLG (I) = [F:CUD]CUNLOKFLG
    Endif
    If dim([M:SNL1]DEPRAT) > 0
       [M:SNL1]DEPRAT    (I) = [F:CUD]DEPRAT
    Endif
    If dim([M:SNL1]DEPAMT) > 0
       [M:SNL1]DEPAMT    (I) = [F:CUD]DEPAMT
    Endif
    If dim([M:SNL1]PALNUM) > 0
       [M:SNL1]PALNUM    (I) = [F:CUD]PALNUM
    Endif
    If dim([M:SNL1]CTRNUM) > 0
       [M:SNL1]CTRNUM    (I) = [F:CUD]CTRNUM
    Endif
    If dim([M:SNL1]STOFLD1) > 0
       [M:SNL1]STOFLD1   (I) = [F:CUD]STOFLD1
    Endif
    If dim([M:SNL1]STOFLD2) > 0
       [M:SNL1]STOFLD2   (I) = [F:CUD]STOFLD2
    Endif
    If dim([M:SNL1]QLYCTLDEM) > 0
       [M:SNL1]QLYCTLDEM (I) = [F:CUD]QLYCTLDEM
    Endif
    If dim([M:SNL1]OWNER) > 0
       [M:SNL1]OWNER (I)     = [F:CUD]OWNER
    Endif
    If dim([M:SNL1]LINFLG) > 0
       [M:SNL1]LINFLG       (I) = 2
    Endif
    If dim([M:SNL1]ITMLISNUMS) > 0
       [M:SNL1]ITMLISNUMS(I) = [F:CUD]ITMLISNUM
    Endif
    If dim([M:SNL1]STLFLG) > 0
       [M:SNL1]STLFLG       (I) = 1
    Endif
    If dim([M:SNL1]STOCOU) > 0
       [M:SNL1]STOCOU(I) = [F:CUD]STOCOU
       If [M:SNL1]STOCOU(I) <> 0
          If dim([M:SNL1]CUMALLQTY) > 0
             Read [STO]STO0=[M:SNL0]STOFCY;[M:SNL1]STOCOU(I)
             If fstat = 0
                [M:SNL1]CUMALLQTY(I) = [F:STO]CUMALLQTY
             Endif
          Endif
       Endif
    Endif
# si enregistrement à compter et emplacement  à blanc et gestion emplacement = oui et ligne de stock
#    ALORS raz qte compte  et  stock nul = oui si alloue = 0
    If [F:CUD]CUNLISSTA = 1 & [F:ITF]LOCMGTCOD = 2 & [M:SNL1]STOCOU (I) <> 0
       If dim([M:SNL1]LOC) > 0
          If [M:SNL1]LOC       (I) = ""
             If [M:SNL0]MULCTGFLG <> 2                                                    # hcb 71659
                If dim([M:SNL1]QTYPCUNEW) > 0
                   [M:SNL1]QTYPCUNEW (I) = 0
                Endif
                If dim([M:SNL1]QTYSTUNEW) > 0
                   [M:SNL1]QTYSTUNEW (I) = 0
                Endif
                If dim([M:SNL1]PCUSTUNEW) > 0    # hcb 31134
                   [M:SNL1]PCUSTUNEW (I) = 0     # hcb 31134
                Endif                            # hcb 31134
                If dim([M:SNL1]MODFLG) > 0
                   [M:SNL1]MODFLG       (I) = 2
                Endif
                If dim([M:SNL1]ZERSTOFLG) > 0
                   If dim([M:SNL1]CUMALLQTY) > 0
                      If [M:SNL1]CUMALLQTY  =  0
                         [M:SNL1]ZERSTOFLG (I) = 2
                      Endif
                   Endif
                Endif
#                                                                                         # hcb 71659 deb
             Else
                If [M:SNL1]CTG2(I)        = 0
                   [M:SNL1]QTYPCUNEW1 (I) = 0
                   [M:SNL1]QTYSTUNEW1 (I) = 0
                   [M:SNL1]PCUSTUNEW1 (I) = 0
                   [M:SNL1]MODFLG     (I) = 2
                   If dim([M:SNL1]CUMALLQTY)    > 0
                      If [M:SNL1]CUMALLQTY      =  0
                         [M:SNL1]ZERSTOFLG1 (I) = 2
                      Endif
                   Endif
                Else
                   [M:SNL1]QTYPCUNEW2 (I) = 0
                   [M:SNL1]QTYSTUNEW2 (I) = 0
                   [M:SNL1]PCUSTUNEW2 (I) = 0
                   [M:SNL1]MODFLG     (I) = 2
                   If dim([M:SNL1]CUMALLQTY)    > 0
                      If [M:SNL1]CUMALLQTY      =  0
                         [M:SNL1]ZERSTOFLG2 (I) = 2
                      Endif
                   Endif
                Endif
             Endif
#                                                                                         # hcb 71659 fin
          Endif
       Endif
    Endif
#                                                                     # hcb 110327 deb
    [M:SNL1]SERSEQ          (I) =  [F:CUD]SERSEQ
#                                                                     # hcb 110327 deb
    If clalev([M:VALW])
        If (I+1)*max(GACTMAT,GACTMAC,GACTLAB)>=max(dim([M:VALW]OMATCST))
            GMESSAGE = mess(376,199,1)
            FIN=1
            Break
        Endif
        For J=0 To GACTMAT-1
            [M:VALW]OMATCST(I*GACTMAT+J)   = [F:CUD]MATCST(J)
        Next
        [M:VALW]OOVEMATCST(I) = [F:CUD]OVEMATCST

        For J=0 To GACTMAC-1
            [M:VALW]OMACCST(I*GACTMAC+J)   = [F:CUD]MACCST(J)
        Next
        [M:VALW]OOVEMACCST(I) = [F:CUD]OVEMACCST

        For J=0 To GACTLAB-1
            [M:VALW]OLABCST(I*GACTLAB+J)   = [F:CUD]LABCST(J)
        Next
        [M:VALW]OOVELABCST(I) = [F:CUD]OVELABCST
        [M:VALW]OSCOTOT(I)    = [F:CUD]SCOCST
        [M:VALW]OOVESCOCST(I) = [F:CUD]OVESCOCST
        [M:VALW]OINVDTACST(I) = [F:CUD]INVDTACST
        [M:VALW]PRI(I)        = [F:CUD]PRIORD
        [M:VALW]WSTOSEQ(I)    = I+1
        [M:VALW]NBLIG         = I+1
    Endif
    GPOINT = "CUD_SNL"                    # hcb 54067
    Gosub  ENTREE From EXEFNC             # hcb 54067
    I += 1
Next

[M:SNL1]NBLIG = I
# si saisie sur un stock nul on recupere les qtes saisies
#                                                                     # hcb 110327 deb

If [M:SNL1]NBLIG = 1 & (GIMPINV = 1 | (GOUVINV = 2 & [M:SNL0]MODFLG(GLIG_SNL0) = 2 & [M:SNL0]CUNLISSTAD(GLIG_SNL0) = 1))
#If GIMPINV = 1 &  [M:SNL1]NBLIG = 1
#                                                                     # hcb 110327 end
   If dim([M:SNL1]QTYPCUNEW) > 0
      [M:SNL1]QTYPCUNEW (0)  = [M:SNL0]QTYPCUNEW(GLIG_SNL0)
   Endif
   If dim([M:SNL1]QTYSTUNEW) > 0
      [M:SNL1]QTYSTUNEW (0)  = [M:SNL0]QTYSTUNEW(GLIG_SNL0)
   Endif
   If dim([M:SNL1]MODFLG) > 0
      If [M:SNL0]QTYPCUNEW(GLIG_SNL0) <> 0
         [M:SNL1]MODFLG (0)  = 2
      Endif
   Endif
   If dim([M:SNL1]PCUSTUNEW) > 0                                            # hcb 31134
      If [M:SNL1]QTYSTUNEW(0) <> 0 & [M:SNL1]QTYPCUNEW(0) <>0               # hcb 31134
         [M:SNL1]PCUSTUNEW(0) = [M:SNL1]QTYSTUNEW(0) / [M:SNL1]QTYPCUNEW(0) # hcb 31134
      Endif                                                                 # hcb 31134
   Endif                                                                    # hcb 31134
#                                                                                         # hcb 71659 deb
   If [M:SNL0]MULCTGFLG = 2
      [M:SNL1]QTYPCUNEW1   (0)  =  [M:SNL0]QTYPCUNEW1(GLIG_SNL0)
      [M:SNL1]QTYSTUNEW1   (0)  =  [M:SNL0]QTYSTUNEW1(GLIG_SNL0)
      If [M:SNL0]QTYPCUNEW1(GLIG_SNL0) <> 0
         [M:SNL1]MODFLG    (0)  =  2
      Endif
      If [M:SNL1]QTYSTUNEW1(0)  <> 0 & [M:SNL1]QTYPCUNEW1(0) <>0
         [M:SNL1]PCUSTUNEW1(0)  =  [M:SNL1]QTYSTUNEW1(0) / [M:SNL1]QTYPCUNEW1(0)
      Endif
      [M:SNL1]QTYPCUNEW2   (0)  =  [M:SNL0]QTYPCUNEW2(GLIG_SNL0)
      [M:SNL1]QTYSTUNEW2   (0)  =  [M:SNL0]QTYSTUNEW2(GLIG_SNL0)
      If [M:SNL0]QTYPCUNEW2(GLIG_SNL0) <> 0
         [M:SNL1]MODFLG    (0)  =  2
      Endif
      If [M:SNL1]QTYSTUNEW2(0)  <> 0 & [M:SNL1]QTYPCUNEW2(0) <>0
         [M:SNL1]PCUSTUNEW2(0)  =  [M:SNL1]QTYSTUNEW2(0) / [M:SNL1]QTYPCUNEW2(0)
      Endif
   Endif
#                                                                                         # hcb 71659 fin

Endif

#---- Récupération des sections analytiques  si pas dans cunlisdet ----#
If WSECTION <> 2
   Local Char    SECTION
   Local Integer Y
   For Y=1 To GNBDIE
       If dim([M:SNL1]CCE(Y-1)) >0
          Call INISEC(SECTION, "STKINVD", Y) From TRTX3CPT
          [M:SNL1]CCE(Y-1) =  SECTION
       Endif
   Next
Endif

Filter [CUD]

Gosub GESSELECTION From TRTSNLINV

$AFICH_SNL1
# si consultation alors modification interdite
If GCONSULT = 2  |  GSNLSTAIMG3 = 2       # hcb 74380
   Affzo [M:SNL1]
   Diszo [M:SNL1]
   Return
Endif

Actzo [M:SNL1]
If [M:SNL0]CUNLISSTA  > 5
   Diszo [M:SNL1]
Else
#                                                                # hcb 110327 deb
   If [F:ITM]SERMGTCOD = 4
      For I = 0 To [M:SNL1]NBLIG-1
          If  [M:SNL1]SERSEQ (I) <> 0 & [M:SNL1]CUNLISSTA (I) = 1 & [M:SNL1]STOCOU  (I) <> 0
              Local Char    LMSK
              Local Integer LLLG
              LMSK = "SNL1"
              LLLG = I
              Gosub VERIF_DESYNCHRO From STKINV1
          Endif
      Next
   Endif
 #                                                                # hcb 110327 fin
# on desactive les rubriques qui ne servent qu en ajout de lignes
   Gosub DZO_SNL1_RGP From STKINV
Endif
#                                                                   # hcb X3-68147  deb
# on force la valeur à 1 de nblig pour prise en compte des desactivation des rubriques selon les codes activités
If [M:SNL1]NBLIG = 0
   [M:SNL1]NBLIG = 1
   Affzo [M:SNL1]
   [M:SNL1]NBLIG = 0
Else
   Affzo [M:SNL1]
Endif
#                                                                   # hcb X3-68147  fin
# si liste cloturée ajout ligne interdit
If [M:SNL0]CUNLISSTA  < 6
#activation des rubriques  pour rajout de ligne
   Local Integer NOL
   If [M:SNL1]NBLIG-1 > 0          # hcb 104860
       NOL = [M:SNL1]NBLIG-1       # hcb 104860
   Endif                           # hcb 104860
   Gosub AZO_SNL1 From STKINV
Endif
Raz GOUVSNLS   # hcb 110327
Return

#########################################################################
# CTR_DISPO                                 Calcul et Controle disponible
#########################################################################
Subprog CTR_DISPO(LFCY,LITM,LVAL,LNOL)
Value Char    LFCY
Value Char    LITM
Value Decimal LVAL
Value Integer LNOL
#
Local Decimal WDIS : WDIS = 0
Local Integer I
Read [ITV]ITV0=LITM;LFCY
If fstat = 0
   Call STODISTOT("",7,1,"",WDIS) From STKLIB
Endif
If LNOL >= 0
  For I = 0 To [M:SNL1]NBLIG-1
      If left$([M:SNL1]STA(I),1) = "A"
         If I <> LNOL
            If ([M:SNL1]QTYSTUNEW(I) > 0 & [M:SNL1]QTYSTU(I) <> [M:SNL1]QTYSTUNEW(I)) |
&              [M:SNL1]ZERSTOFLG(I) = 2
               WDIS += ([M:SNL1]QTYSTUNEW(I) - [M:SNL1]QTYSTU(I))
            Endif
         Else
            WDIS += (LVAL-[M:SNL1]QTYSTU(I))
         Endif
      Endif
  Next I
Endif
If WDIS < 0
   mkstat = 2
#Quantité supérieure au stock disponible
   GMESSAGE = mess(148,199,1)
Endif
End

#########################################################################
# EXI_INVENTAIRE                     Controle existence inventaire saisie
#########################################################################
$EXI_INVENTAIRE
Local Shortint WRET
Local Integer WOK
Local Char    LLOT(GLONLOT)
Local Char    LSLO(GLONSLO)
Local Char    LMAJ(GLONECS)
Local Char    LLOC(GLONEMP)
Local Char    LSTA(GLONSTA)
Local Char    LSER(GLONSER)

Local Char    LLOTI(GLONLOT)
Local Char    LSLOI(GLONSLO)
Local Char    LMAJI(GLONECS)
Local Char    LLOCI(GLONEMP)
Local Char    LSERI(GLONSER)
Local Char    LPALI(GLONPAL)
Local Char    LCTRI(GLONCTR)
Local Char    LSF1I(GLONSF1)
Local Char    LSF2I(GLONSF2)
Local Char    LWRHI(GLONWRH)
Local Char    LWRH (GLONWRH)

Local Char    LPCU
Local Decimal LCOE
Local Char    LPAL(GLONPAL)
Local Char    LCTR(GLONCTR)
Local Char    LSF1(GLONSF1)
Local Char    LSF2(GLONSF2)
Local Char    LQLY
Local Char    LOWN(GLONBPF)
Local Char    LLPN(GLONLPN)       # hcb X3-68147
Local Char    LLPNI(GLONLPN)      # hcb x3-68147

Raz LLOT
Raz LSLO
Raz LMAJ
Raz LLOC
Raz LSTA
Raz LSER
Raz LLOTI
Raz LSLOI
Raz LMAJI
Raz LLOCI
Raz LSERI
Raz LPALI
Raz LCTRI
Raz LSF1I
Raz LSF2I
Raz LPCU
Raz LCOE
Raz LPAL
Raz LCTR
Raz LSF1
Raz LSF2
Raz LQLY
Raz LOWN
Raz LWRH
Raz LWRHI
Raz WOK
Raz LLPN      # hcb x3-68147
Raz LLPNI     # hcb x3-68147
Raz [M:SNL1W]
[M:SNL1W] = [M:SNL1] # hcb x3-68147


If dim([M:SNL1]LOT) > 0
   LLOT = [M:SNL1]LOT(NOL)
Endif
If dim([M:SNL1]SLO) > 0
   LSLO = [M:SNL1]SLO(NOL)
Endif
If dim([M:SNL1]ECCVALMAJ) > 0                                          # hcb 71276
   LMAJ = [M:SNL1]ECCVALMAJ(NOL)
Endif
If dim([M:SNL1]LPNNUM) > 0                                # hcb x3-68147
   LLPN = [M:SNL1]LPNNUM(NOL)
Endif
If dim([M:SNL1]LOC) > 0
   LLOC = [M:SNL1]LOC(NOL)
Endif
If dim([M:SNL1]STA) > 0
   LSTA = [M:SNL1]STA(NOL)
Endif
If dim([M:SNL1]SERNUM) > 0
   LSER = [M:SNL1]SERNUM(NOL)
Endif
If dim([M:SNL1]PCU) > 0
   LPCU = [M:SNL1]PCU(NOL)
Endif
If dim([M:SNL1]WRH) > 0
   LWRH = [M:SNL1]WRH(NOL)
Endif
If dim([M:SNL1]PCUSTUNEW) > 0
   LCOE = [M:SNL1]PCUSTUNEW(NOL)
Endif
If dim([M:SNL1]PALNUM) > 0
   LPAL = [M:SNL1]PALNUM(NOL)
Endif
If dim([M:SNL1]CTRNUM) > 0
   LCTR = [M:SNL1]CTRNUM(NOL)
Endif
If dim([M:SNL1]STOFLD1) > 0
   LSF1 = [M:SNL1]STOFLD1(NOL)
Endif
If dim([M:SNL1]STOFLD2) > 0
   LSF2 = [M:SNL1]STOFLD2(NOL)
Endif
If dim([M:SNL1]QLYCTLDEM) > 0
   LQLY = [M:SNL1]QLYCTLDEM(NOL)
Endif
If dim([M:SNL1]OWNER) > 0
   LOWN = [M:SNL1]OWNER(NOL)
Endif
# recherche  dans l ecran SNL1
Local Integer I
For I = 0 To [M:SNL1W]NBLIG-1

    If dim([M:SNL1W]LOT) > 0
       LLOTI = [M:SNL1W]LOT(I)
    Endif
    If dim([M:SNL1W]SLO) > 0
       LSLOI = [M:SNL1W]SLO(I)
    Endif
    If dim([M:SNL1W]ECCVALMAJ) > 0                                           # hcb 71276
       LMAJI = [M:SNL1W]ECCVALMAJ(I)
    Endif
    If dim([M:SNL1W]LPNNUM) > 0                                           # hcb  x3-68147
       LLPNI = [M:SNL1W]LPNNUM(I)
    Endif
    If dim([M:SNL1W]LOC) > 0
       LLOCI = [M:SNL1W]LOC(I)
    Endif
    If dim([M:SNL1W]SERNUM) > 0
       LSERI = [M:SNL1W]SERNUM(I)
    Endif
    If dim([M:SNL1W]PALNUM) > 0
       LPALI = [M:SNL1W]PALNUM(I)
    Endif
    If dim([M:SNL1W]CTRNUM) > 0
       LCTRI = [M:SNL1W]CTRNUM(I)
    Endif
    If dim([M:SNL1W]WRH) > 0
       LWRHI = [M:SNL1W]WRH(I)
    Endif
    If dim([M:SNL1W]STOFLD1) > 0
       LSF1I = [M:SNL1W]STOFLD1(I)
    Endif
    If dim([M:SNL1W]STOFLD2) > 0
       LSF2I = [M:SNL1W]STOFLD2(I)
   Endif
   If dim([M:SNL1W]WRH) > 0
      LWRHI = [M:SNL1W]WRH(I)
   Endif

#                                   hcb 31134  deb  ligne LCOE  (PCUSTUNEW)
#                                   # hcb 115089 rajout test [M:SNL1]CUNLISSTA(I) <  4
   If LLOTI                =  LLOT &
&     [M:SNL1]ZERSTOFLG    <> 2    &
&     I                    <> NOL  &
&     LSLOI                =  LSLO &
&     LMAJI                =  LMAJ &
&     LLPNI                =  LLPN &
&     LLOCI                =  LLOC &
&     [M:SNL1]STA(I)       =  LSTA &
&     [M:SNL1]PCU(I)       =  LPCU &
&     [M:SNL1]PCUSTUNEW(I) =  LCOE &
&     LPALI                =  LPAL &
&     LCTRI                =  LCTR &
&     [M:SNL1]QLYCTLDEM(I) =  LQLY &
&     LSERI                =  LSER &
&     LWRHI                =  LWRH &
&     LSF1I                =  LSF1 &
&     LSF2I                =  LSF2 &
&     [M:SNL1]CUNLISSTA(I) <  4    &
&     [M:SNL1]OWNER(I)     =  LOWN
      WOK = 8
      Break
   Endif
Next

#verif que la saisie ne soit pas deja en inventaire
If WOK = 0
    Call EXI_CUD([M:SNL1]STOFCY,[M:SNL1]ITMREF,LLOT,LSLO,LMAJ,LLPN,LLOC,LSTA,LSER,
&                LPCU,LCOE,LPAL,LCTR,LQLY,LOWN,LWRH,LSF1,LSF2,WOK) From STKINV
Endif
If WOK = 1
# hcb 63403 deb
   If [F:CUD]ITMLISNUM = [M:SNL1]ITMLISNUMS(NOL) & [F:CUD]CUNLISNUM = [M:SNL1]CUNLISNUM
       WOK = 0
   #Else
   #   mkstat = 2
#Article deja en inventaire
   #   GMESSAGE = mess(192,199,1)
   #   Local Char MES(255)
   #    MES  = mess(192,199,1)
   #   Call MESSAGE(MES) From GESECRAN  # Ligne incomplete

   #   Return
   Endif
# hcb 63403 fin
Endif
If WOK = 8
#   mkstat = 2
#ligne d inventaire deja presente !
#   GMESSAGE = mess(448,199,1)
#   Return
Endif
#                                                                     # hcb 110327 deb

# si l article gère les séries globales il faut calculer SERSEQ si = 0
If [F:ITM]SERMGTCOD    =   4 & [M:SNL1]SERSEQ(NOL) = 0
   [M:SNL0]LASSERSEQ   +=1
   [M:SNL1]SERSEQ(NOL) =   [M:SNL0]LASSERSEQ
#  rechercher si une ligne de stock existe pour controle des numeros de serie ds la fenetre ISNLSERE
   Local Decimal LSTOCOU
   #--- Issue X3-53322 : Ajout paramètre LPN
   LSTOCOU = func STKLIB.CLESTOFUN([M:SNL1]STOFCY,[M:SNL1]ITMREF,LLOT,LSLO,LPAL,LCTR,LSTA,LLOC,
&                                  LPCU,LCOE,LSER,LQLY,LOWN,LSF1,LSF2,"STO",LLPN)
  [M:SNL1]STOCOU(NOL) =  LSTOCOU
Endif
#                                                                     # hcb 110327 end
Return

#########################################################################
# EXI_SERIE                            Controle existence numéro de série
#########################################################################
$EXI_SERIE
Local Integer WOK
Raz WOK
# recherche  dans l ecran SNL1
Local Integer I
For I = 0 To [M:SNL1]NBLIG-1
If [M:SNL1]SERNUM(I) = VALEUR & [M:SNL1]ZERSTOFLG(I) <> 2 & I <> NOL
   WOK = 9
   Break
Endif
If [M:SNL1]SERNUM(I) = VALEUR & [M:SNL1]ZERSTOFLG(I) =  2 & [M:SNL1]MODFLG(I) = 2
   WOK = 8
Endif

Next


# recherche CUNLISDET
If WOK = 0
   Filter [CUD] Where STOFCY = [M:SNL1]STOFCY &
&                     ITMREF = [M:SNL1]ITMREF &
&                     SERNUM = VALEUR         &
&                     ZERSTOFLG  <> 2         &
&                     CUNLISSTA < 3
&            Order By Key CUD1
   For [CUD]
       WOK = 9
       Break
   Next
   Filter [CUD]
# recherche STOSER
   If WOK = 0
      Read [STS]STS0=[M:SNL1]ITMREF;VALEUR
      If fstat = 0
         WOK = 1
      Endif
   Endif
Endif


If WOK = 9
   mkstat = 2
   GMESSAGE = mess(446,199,1)  # Numero de série en inventaire
Endif
If WOK = 1
   Call AVERTIR(mess(447,199,1),WOK) From GESECRAN   # Numéro de série existant
   If WOK = 1
      mkstat = 2
   Else
      mkstat = 0
   Endif
Endif
Return
##########################################################################
## Action rubriques ecran                                    Action ecrans
##########################################################################
Subprog AS_QTYPCUNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
If [M:SNL1]PCU(NOL) = ""
  mkstat = 2
Endif
End

Subprog AP_QTYPCUNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV

If [M:SNL1]PCU(NOL) <> ""
    Local Decimal  WQTYSTU                                        # hcb 31134
    Local Decimal  WQTYSTU1                                       # hcb 31134
    WQTYSTU  = VALEUR * [M:SNL1]PCUSTUNEW(NOL)                    # hcb 31134
    WQTYSTU1 = int(WQTYSTU)                                       # hcb 31134
    [M:SNL1]QTYSTUNEW(NOL) = VALEUR * [M:SNL1]PCUSTUNEW(NOL)       # hcb 31134
    Call QTEARR( [M:SNL1]QTYSTUNEW(NOL),[M:SNL1]STU) From TRTDIV
#    If [F:TUN]UOMDEC = 0  &  WQTYSTU <> WQTYSTU1               # hcb 116716
#       GMESSAGE = mess(204,184,1)                              # hcb 116716
#       mkstat = 2                                              # hcb 116716
#       End                                                     # hcb 116716
#    Endif                                                      # hcb 116716
#                                                                                 # hcb 110327 deb
    If [M:SNL1]SERSEQ(NOL) <> 0 & [M:SNL1]QTYSTUDEV(NOL) <> 0
       Gosub CTR_SENS From STKINV1
    Endif
#                                                                                 # hcb 110327 deb
    Affzo [M:SNL1]QTYSTUNEW(NOL)
Endif
End

Subprog AM_QTYPCUNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
[M:SNL1]MODFLG(NOL) = 2
[M:SNL1]QTYPCUNEW(NOL) = VALEUR

End


Subprog C_QTYSTUNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

If VALEUR < 0
   mkstat = 2
   End
Endif

If [F:ITM]SERMGTCOD = 3 & VALEUR <> 0 & VALEUR <> 1                              # hcb 110327
   mkstat = 2
# il est interdit de saisir une quantité <> DE  1 sur UN ARTICLE géré en numéro de série.
  GMESSAGE = mess(47,184,1)
   End
Endif

#                                                              # hcb 96065  deb
If dim([M:SNL1]SERNUM) > 0 &[M:SNL1]SERNUM(NOL) <> ""  & VALEUR <> 0 & VALEUR <> 1   # hcb 101553
   mkstat = 2
# Il est interdit de saisir une quantité différente de 0 ou  1  : un numéro de série est renseigné !
  GMESSAGE = mess(417,184,1)
   End
Endif
#                                                              # hcb 96065  fin


If  VALEUR <> 0
  If [M:SNL1]STOCOU(NOL) <> 0
     If dim([M:SNL1]CUMALLQTY) > 0
        If  [M:SNL1]CUMALLQTY(NOL) > VALEUR
            mkstat = 2
# LA qté allouée est supérieure à la qte comptée
            Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL1]ITMREF,[M:SNL1]STOCOU(NOL),"") From STKINV
            End
        Endif
     Endif
  Endif
Endif

Local Char    WLOC(GLONEMP)
If dim([M:SNL1]LOC)>0
   WLOC =  [M:SNL1]LOC(NOL)
Endif
If [F:ITF]LOCMGTCOD > 1                               # hcb 37170
    Call STKCTREMP([M:SNL1]WLOCSEQ(NOL),
&               13,
&               "",
&               [M:SNL0]STOFCY,
&               [M:SNL1]ITMREF,
&               [M:SNL1]STU,
&               [M:SNL1]QTYPCUNEW(NOL),
&               [M:SNL1]STA(NOL),
&               GBIDC3,
&               WLOC,
&               "",
&               [F:ITF]LOCMGTCOD-1,
&               mkstat,
&               GBIDD1,
&               "",
&               "1=1",
&               "") From STKLOC
Endif                                                  # hcb 37170

#                                                                    hcb 31134 deb

Local Decimal LCOEFNEW

If VALEUR   = [M:SNL1]QTYPCUNEW(NOL)
   LCOEFNEW = 1
Else
   If VALEUR  =  0
      [M:SNL1]QTYPCUNEW(NOL) = 0
      LCOEFNEW = 0
      Affzo [M:SNL1]QTYPCUNEW(NOL)
   Else
      If VALEUR  <> 0 & [M:SNL1]QTYPCUNEW(NOL) <>0
         LCOEFNEW = VALEUR / [M:SNL1]QTYPCUNEW(NOL)
      Endif
      Local Decimal LCOEF
      Local Char    PLBEFMT(GLONARP)
      Local Char    LBPR
      Local Char    LUSCAV(5)
      Local Integer LMODIF
      Call CTLUOM ([M:SNL1]ITMREF,3,LBPR,[M:SNL1]PCU(NOL), LCOEF, LUSCAV,PLBEFMT, LMODIF) From STKACT
#                                                                          # hcb X3-78120 deb
# coefficient  mofifiable on recalcule le coef
      If LMODIF = 2
         [M:SNL1]PCUSTUNEW      (NOL) = LCOEFNEW
         Affzo [M:SNL1]PCUSTUNEW(NOL)
      Else
          Local Decimal WQTYARR
          Call CTRQTYPCU([M:SNL1]PCU(NOL),[M:SNL1]PCUSTUNEW(NOL),VALEUR,WQTYARR) From STKLIB
          If WQTYARR<>VALEUR
  #       If VALEUR / [M:SNL1]QTYPCUNEW(NOL) <> [M:SNL1]PCUSTUNEW(NOL)
  #       If LCOEFNEW  <> LCOEF
            GMESSAGE = mess(249,184,1)
            mkstat = 2
            End
         Endif
#      If LMODIF = 1
#
         [M:SNL1]QTYPCUNEW(NOL) = VALEUR / [M:SNL1]PCUSTUNEW(NOL)
#                                                                          # hcb X3-78120 fin
         Call QTEARR( [M:SNL1]QTYPCUNEW(NOL),[M:SNL1]PCU(NOL)) From TRTDIV # hcb 116716
         Affzo [M:SNL1]QTYPCUNEW(NOL)
#      Else                                                                 # hcb X3-78120
#         If LCOEFNEW  <> LCOEF & LMODIF <> 2                               # hcb X3-78120
#            GMESSAGE = mess(249,184,1)                                     # hcb X3-78120
#            mkstat = 2                                                     # hcb X3-78120
#            End                                                            # hcb X3-78120
#         Endif                                                             # hcb X3-78120
#        [M:SNL1]PCUSTUNEW      (NOL) = LCOEFNEW                            # hcb X3-78120
#        Affzo [M:SNL1]PCUSTUNEW(NOL)                                       # hcb X3-78120
      Endif                                                                 # hcb X3-78120
   Endif
Endif
#[M:SNL1]PCUSTUNEW      (NOL) = LCOEFNEW                                   # hcb 116716
#Affzo [M:SNL1]PCUSTUNEW(NOL)                                              # hcb 116716

#
#Local Integer WOK                                                                     # hcb X3-68147
# si l article n est pas gere en serie on controle ici l existence de l inventaire
# si nouvelle ligne si pas saisie PALNUM si pas saisie CTRNUM si pas saisie OWNER
#If [F:ITM]SERMGTCOD    <  3  &
#&  [M:SNL1]LINFLG(NOL) =  1  &
#&  dim([M:SNL1]CTRNUM) <  0  &
#&  [F:SRT]OWNERCOD     <> 1
#   Gosub EXI_INVENTAIRE
#Endif

End

Subprog AM_QTYSTUNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV

# hcb 37170  deb
If  VALEUR <> 0
  If  [M:SNL1]STOCOU(NOL) <> 0
      If dim([M:SNL1]CUMALLQTY) > 0
         If  [M:SNL1]CUMALLQTY(NOL) <> 0 & [M:SNL1]PCU(NOL) <> [M:SNL1]STU
             mkstat = 2
# Ligne de stock faisant l objet d une allocation
             Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL1]ITMREF,[M:SNL1]STOCOU(NOL),"S") From STKINV
             End
         Endif
      Endif
  Endif
Endif
# hcb 37170  fin

[M:SNL1]MODFLG(NOL) = 2
[M:SNL1]QTYSTUNEW(NOL) = VALEUR
If dim([M:SNL1]PCUSTUNEW) > 0                                                  # hcb 31134
   If [M:SNL1]QTYSTUNEW(NOL) <> 0 & [M:SNL1]QTYPCUNEW(NOL) <>0                 # hcb 31134
      [M:SNL1]PCUSTUNEW(NOL) = [M:SNL1]QTYSTUNEW(NOL) / [M:SNL1]QTYPCUNEW(NOL) # hcb 31134
      Affzo [M:SNL1]PCUSTUNEW(NOL)                                             # hcb 31134
   Endif                                                                       # hcb 31134
Endif                                                                          # hcb 31134

End

