Subprog AV_CUNAMTNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
VALEUR = [M:SNL1]CUNCST(NOL)*[M:SNL1]QTYSTUNEW(NOL)

End


Subprog AS_PRIORD(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
Local Char LSLO
# prix non saisissable si quantite comptée nulle
If [M:SNL1]QTYSTUNEW(NOL) = 0
   mkstat = 2
   End
Endif
# prix non saisissable si il existe du stock
# controle par STOCOU
If [M:SNL1]STOCOU(NOL) <> 0
   mkstat = 2
   End
Endif

# prix non saisissable si detail abandonné ou validé
If [M:SNL1]CUNLISSTA(NOL) > 2
   mkstat = 2
   End
Endif

# controle par existance du lot
If [F:ITM]LOTMGTCOD <> 1 & dim([M:SNL1]LOT) > 0  # hcb 60104
   Raz LSLO
   If [F:ITM]LOTMGTCOD =4 & dim([M:SNL1]SLO) > 0
      LSLO = [M:SNL1]SLO(NOL)
   Endif
   # Issue 73278 - 2011-05-16 by CCC : Ajout du filtre sur VCRTYP et VCRNUM
   Filter [F:STL] Where ITMREF = [M:SNL1]ITMREF & LOT = [M:SNL1]LOT(NOL) & SLO = LSLO
&                     & !(VCRTYP=9 & VCRNUM=[M:SNL1]CUNLISNUM)
&         Order By Key STL0
   For [STL]
       mkstat = 2
       Break
   Next
   Filter [F:STL]
   If mkstat = 2
      End
   Endif
Else
# creation lot blanc pour les articles non gere en lot
#  [M:SNL1]LOT(NOL) = ""  # hcb 70380
  Raz LSLO
  Read [STL]STL0=[M:SNL1]ITMREF;"";""
  If  !fstat
      mkstat = 2
      End
  Endif
Endif
End

Subprog B3_SLO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
Call RECLASTSLO([M:SNL1]ITMREF, [M:SNL1]LOT(NOL), "SNL1","", VALEUR) From STKLIB      # hcb 89491

End


