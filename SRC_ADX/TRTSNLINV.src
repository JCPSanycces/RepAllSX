Subprog AS_QTYSTUNEW1(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV

Local Char    WLOC(GLONEMP)
If dim([M:SNL1]LOC)>0
   WLOC =  [M:SNL1]LOC(NOL)
Endif

Call STKMODREMP( [M:SNL1]WLOCSEQ (NOL),
&                [M:SNL0]STOFCY       ,
&                [M:SNL1]ITMREF       ,
&                [M:SNL1]PCU     (NOL),
&                [M:SNL1]QTYPCU  (NOL),
&                [M:SNL1]STA     (NOL),
&                WLOC,
&                ""                   ,
&                mkstat               ,
&                "") From STKLOC

End

Subprog C_QTYSTUNEW1(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

If VALEUR < 0
   mkstat = 2
   End
Endif

If [F:ITM]SERMGTCOD = 3 & VALEUR <> 0 & VALEUR <> 1                # hcb 110327
   mkstat = 2
# il est interdit de saisir une quantité <> DE  1 sur UN ARTICLE géré en numéro de série.
  GMESSAGE = mess(47,184,1)
   End
Endif
#
If dim([M:SNL1]SERNUM) > 0 &[M:SNL1]SERNUM(NOL) <> ""  & VALEUR <> 0 & VALEUR <> 1
   mkstat = 2
# Il est interdit de saisir une quantité différente de 0 ou  1  : un numéro de série est renseigné !
  GMESSAGE = mess(417,184,1)
   End
Endif
#

If  VALEUR <> 0
  If [M:SNL1]STOCOU(NOL) <> 0
     If dim([M:SNL1]CUMALLQTY) > 0
        If  [M:SNL1]CUMALLQTY(NOL) > VALEUR
            mkstat = 2
# LA qté allouée est supérieure à la qte comptée
            Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL1]ITMREF,[M:SNL1]STOCOU(NOL),"") From STKINV
            End
        Endif
     Endif
  Endif
Endif

Local Char    WLOC(GLONEMP)
If dim([M:SNL1]LOC)>0
   WLOC =  [M:SNL1]LOC(NOL)
Endif
If [F:ITF]LOCMGTCOD > 1
    Call STKCTREMP([M:SNL1]WLOCSEQ(NOL),
&               13,
&               "",
&               [M:SNL0]STOFCY,
&               [M:SNL1]ITMREF,
&               [M:SNL1]STU,
&               [M:SNL1]QTYPCUNEW1(NOL),
&               [M:SNL1]STA(NOL),
&               GBIDC3,
&               WLOC,
&               "",
&               [F:ITF]LOCMGTCOD-1,
&               mkstat,
&               GBIDD1,
&               "",
&               "1=1",
&               "") From STKLOC
Endif

Local Decimal LCOEFNEW

If VALEUR   = [M:SNL1]QTYPCUNEW1(NOL)
   LCOEFNEW = 1
Else
   If VALEUR  =  0
      [M:SNL1]QTYPCUNEW1(NOL) = 0
      LCOEFNEW = 0
      Affzo [M:SNL1]QTYPCUNEW1(NOL)
   Else
      If VALEUR  <> 0 & [M:SNL1]QTYPCUNEW1(NOL) <>0
         LCOEFNEW = VALEUR / [M:SNL1]QTYPCUNEW1(NOL)
      Endif
      Local Decimal LCOEF
      Local Char    PLBEFMT(GLONARP)
      Local Char    LBPR
      Local Char    LUSCAV(5)
      Local Integer LMODIF
      Call CTLUOM ([M:SNL1]ITMREF,3,LBPR,[M:SNL1]PCU(NOL), LCOEF, LUSCAV,PLBEFMT, LMODIF) From STKACT
 #                                                                          # hcb X3-78120 deb
# coefficient  mofifiable on recalcule le coef
      If LMODIF = 2
         [M:SNL1]PCUSTUNEW1      (NOL) = LCOEFNEW
         Affzo [M:SNL1]PCUSTUNEW1(NOL)
      Else
          Local Decimal WQTYARR
          Call CTRQTYPCU([M:SNL1]PCU(NOL),[M:SNL1]PCUSTUNEW1(NOL),VALEUR,WQTYARR) From STKLIB
          If WQTYARR<>VALEUR
  #       If VALEUR / [M:SNL1]QTYPCUNEW1(NOL) <> [M:SNL1]PCUSTUNEW1(NOL)
  #       If LCOEFNEW  <> LCOEF
            GMESSAGE = mess(249,184,1)
            mkstat = 2
            End
         Endif
#      If LMODIF = 1
#
         [M:SNL1]QTYPCUNEW1(NOL) = VALEUR / [M:SNL1]PCUSTUNEW1(NOL)
#                                                                          # hcb X3-78120 fin
         Call QTEARR( [M:SNL1]QTYPCUNEW1(NOL),[M:SNL1]PCU(NOL)) From TRTDIV # hcb 116716
         Affzo [M:SNL1]QTYPCUNEW1(NOL)
#      Else                                                                 # hcb X3-78120
#         If LCOEFNEW  <> LCOEF & LMODIF <> 2                               # hcb X3-78120
#            GMESSAGE = mess(249,184,1)                                     # hcb X3-78120
#            mkstat = 2                                                     # hcb X3-78120
#            End                                                            # hcb X3-78120
#         Endif                                                             # hcb X3-78120
#        [M:SNL1]PCUSTUNEW1      (NOL) = LCOEFNEW                            # hcb X3-78120
#        Affzo [M:SNL1]PCUSTUNEW1(NOL)                                       # hcb X3-78120
      Endif                                                                 # hcb X3-78120
   Endif
Endif

#[M:SNL1]PCUSTUNEW1      (NOL) = LCOEFNEW                                   # hcb 116716
#Affzo [M:SNL1]PCUSTUNEW1(NOL)                                              # hcb 116716
Local Integer WOK

# si l article n est pas gere en serie on controle ici l existence de l inventaire      # hcb x3-68147
# si nouvelle ligne si pas saisie PALNUM si pas saisie CTRNUM si pas saisie OWNER
#If [F:ITM]SERMGTCOD    <  3  &
#&  [M:SNL1]LINFLG(NOL) =  1  &
#&  dim([M:SNL1]CTRNUM) <  0  &
#&  [F:SRT]OWNERCOD     <> 1
#   Gosub EXI_INVENTAIRE
#Endif

End

Subprog AM_QTYSTUNEW1(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV

If  VALEUR <> 0
  If  [M:SNL1]STOCOU(NOL) <> 0
      If dim([M:SNL1]CUMALLQTY) > 0
         If  [M:SNL1]CUMALLQTY(NOL) <> 0 & [M:SNL1]PCU(NOL) <> [M:SNL1]STU
             mkstat = 2
# Ligne de stock faisant l objet d une allocation
             Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL1]ITMREF,[M:SNL1]STOCOU(NOL),"S") From STKINV
             End
         Endif
      Endif
  Endif
Endif

[M:SNL1]MODFLG(NOL) = 2
[M:SNL1]QTYSTUNEW1(NOL) = VALEUR
If dim([M:SNL1]PCUSTUNEW1) > 0
   If [M:SNL1]QTYSTUNEW1(NOL) <> 0 & [M:SNL1]QTYPCUNEW1(NOL) <>0
      [M:SNL1]PCUSTUNEW1(NOL) = [M:SNL1]QTYSTUNEW1(NOL) / [M:SNL1]QTYPCUNEW1(NOL)
      Affzo [M:SNL1]PCUSTUNEW1(NOL)
   Endif
Endif
End

