Subprog AV_QTYSTUDEV(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
VALEUR = [M:SNL1]QTYSTUNEW(NOL)-[M:SNL1]QTYSTU(NOL)

End

Subprog AV_PRCDEV(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
If [M:SNL1]QTYSTU(NOL) = 0
   VALEUR = 0
Else
   VALEUR = ([M:SNL1]QTYSTUDEV(NOL)/[M:SNL1]QTYSTU(NOL))*100
Endif
End

Subprog IB_NBLIG
Gosub SET_NOL From STKINV

# Détail lot
GBOUT1 = mess(442,198,1)
# Visu propriétaire
GBOUT4 = mess(472,198,1)
# No série à inventorier                                              # hcb 110327
GBOUT5 = mess(650,199,1)                                              # hcb 110327


# pas de clic droit sur la fenetre lot et detail prix si :
# la quantite saisie est à zero
If [M:SNL0]MULCTGFLG = 2
   If [M:SNL1]QTYSTUNEW1(NOL) = 0 & [M:SNL1]QTYSTUNEW2(NOL) = 0 & [M:SNL1]QTYSTUNEW(NOL) = 0
      GBOUT1 = ""
   Endif
   If [M:SNL1]QTYSTUNEW(NOL) = 0
      GBOUT3 = ""
   Endif
Else
#                                                                                         # hcb 71659
   If [M:SNL1]QTYSTUNEW(NOL) = 0
      GBOUT1 = ""
      GBOUT3 = ""          # hcb 74380
   Endif
Endif                                                                                     # hcb 71659

# si pas proprietaire alors pas de visu propriétaire
If [M:SNL1]OWNER(NOL)  = "" |  GSNLSTAIMG3 = 2       # hcb 74380
   GBOUT4 = ""
Endif
#                                                                     # hcb 110327 deb
# l article ne gère pas les séries "globale"  pas de saisie des numéros de séries
If [F:ITM]SERMGTCOD <> 4
    GBOUT5 = ""
Endif
# si pas d'écart pas de saisie des numéros de séries
If [M:SNL1]QTYSTU (NOL) = [M:SNL1]QTYSTUNEW (NOL)
    GBOUT5 = ""
Endif
# si pas de comptage
If [M:SNL1]QTYSTUNEW (NOL) = 0 & [M:SNL1]QTYPCUNEW (NOL) = 0
    GBOUT5 = ""
Endif

# si multicomptage comptage 1 et comtage 2 doit etre fait
If [M:SNL0]MULCTGFLG = 2 & ([M:SNL1]CTG1(NOL) <>  2 | [M:SNL1]CTG2(NOL) <>  2)
   GBOUT5 = ""
Endif
# si multicomptage  est que l enregistrement a ete fait sur le comptage 2 il faut ressortir avant
If dim(GSNLSERE) > 0
   GBOUT5 = ""
Endif

End
Subprog B5_NBLIG
GOUVSNLS = 2
# si <> "A compter" ou "Comptée"
If [M:SNL1]CUNLISSTA(nolign-1)  > 2
   GOUVSNLS = 9
Endif

End

#                                                                     # hcb 110327 fin

Subprog B1_NBLIG
GOUVINVL = 2
End

Subprog APRES_NBLIG
Gosub SET_NOL From STKINV
Local Shortint WRET
Local Integer LRET
Local Char LSLO(GLONSLO)
Local Char     LECCMAJ(GLONECS), LECCMIN(GLONEVL)

Raz LSLO

#                                                                       # hcb x3-68147 deb
Local Char MES(100)
Raz MES
If [F:ITF]LPNMGTCOD = 2 & dim([M:SNL1]LPNNUM) >0
   If [F:LPN]LPNNUM<>[M:SNL1]LPNNUM(NOL)  & [M:SNL1]LPNNUM(NOL) <> ""
      Read [LPN]LPN0=LPNNUM(NOL)
      If fstat
          MES = LPNNUM(NOL)-":"-mess(243,107,1)-"LPN"  # Enregistrement inexistant dans la table
      Endif
      If [F:LPN]LOC <> "" & [M:SNL1]LOC(NOL) <> "" & [F:LPN]LOC <> [M:SNL1]LOC(NOL)
         MES = mess(523,184,1)-" : "-[F:LPN]LOC       # L' emplacement saisi ne correspond pas à l'emplacement du no de contenant
      Endif
   Endif
   If MES <> ""
      Call MESSAGE(MES) From GESECRAN
      mkstat = 2
      End
   Endif
Endif
Gosub EXI_INVENTAIRE
If WOK <> 0
   MES  = mess(448,199,1)
   Call MESSAGE(MES) From GESECRAN  # Ligne d'inventaire déjà présente
Endif
#                                                                       # hcb x3-68147 deb

If dim([M:SNL1]SLO) > 0 & [F:ITM]LOTMGTCOD = 4
   LSLO = [M:SNL1]SLO(NOL)
Endif
Gosub GESSELECTION From TRTSNLINV
Affzo [M:SNL1]PECQTY

GOUVINVL = 0
GOUVSNLS = 0                                                          # hcb 110327

# ouverture automatique de la fentere lot si :
# la ligne est "a comptée"
# une quantite est saisie
# L'article est géré par lot et la rubrique lot présente(Code activité LOT OK)
# (13/01/05) ajout du test sur "adxgtb"
If adxgtb<>1 & [M:SNL1]CUNLISSTA(NOL) = 1
   If dim([M:SNL1]LOT) > 0
   If [F:ITM]LOTMGTCOD <> 1
      If  [M:SNL1]QTYSTUNEW(NOL) <> 0 | [M:SNL1]QTYSTUNEW1(NOL) <> 0 | [M:SNL1]QTYSTUNEW2(NOL) <> 0 # hcb 71659
          If [F:ITM]LOTMGTCOD = 4
             Read [STL]STL0=[M:SNL1]ITMREF;[M:SNL1]LOT(NOL);LSLO
             If  fstat
                 Filter [F:STL] Where ITMREF = [M:SNL1]ITMREF & LOT = [M:SNL1]LOT(NOL)
&                       Order By Key STL0
                 Read [STL] First
                 If fstat
                    GOUVINVL = 1
                 Else
                    [F:STL]VCRTYP    = 9
                    [F:STL]SLO       = LSLO
                    [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
                    [F:STL]VCRLIN    = 0
                    [F:STL]LOTCREDAT = date$
                    Call ECRSTL From STKLIB
                    If fstat
                       Call FSTA("STL") From GLOCK
                       End
                    Endif
#flag creation STOLOT à oui
                    [M:SNL1]STLFLG(NOL) = 2
                 Endif
                 Filter [F:STL]
             Endif
          Else
             Read [STL]STL0=[M:SNL1]ITMREF;[M:SNL1]LOT(NOL)
             If  fstat
                 GOUVINVL = 1
             Endif
          Endif
      Endif
   Else
# creation lot blanc pour les articles non gere en lot
      [M:SNL1]LOT(NOL) = ""
      Raz LSLO
      Read [STL]STL0=[M:SNL1]ITMREF;[M:SNL1]LOT(NOL);LSLO
      If  fstat
          [F:STL]ITMREF    = [M:SNL1]ITMREF
          [F:STL]LOT       = [M:SNL1]LOT(NOL)
          [F:STL]SLO       = LSLO
          [F:STL]VCRTYP    = 9
          [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
          [F:STL]VCRLIN    = 0
          [F:STL]REFPER    = date$
          [F:STL]LOTCREDAT = date$
          [F:STL]DLUDAT    = [31/12/2999]     # V6per
          [F:STL]NEWLTIDAT = [31/12/2999]     # V6per
          [F:STL]POT       = 100
          [F:STL]ACT       = 1
          Call ECRSTL From STKLIB
          If fstat
             Call FSTA("STL") From GLOCK
             End
          Endif
#flag creation STOLOT à oui
         [M:SNL1]STLFLG(NOL) = 2
      Endif
   Endif
   Endif
Endif

# Issue 98714 - 2014-10-22 by CCC : Call SETNEWPRI if it has not already been done
If adxgtb<>1 & clalev([M:VALW]) & ([M:SNL1]PRIORD(nolign-1)<>[M:VALW]PRI(nolign-1) | !find(nolign,[M:VALW]WSTOSEQ))
    Raz LECCMAJ, LECCMIN
    If dim([M:SNL1]ECCVALMAJ)>0
        [L]LECCMAJ = [M:SNL1]ECCVALMAJ(nolign-1)
        [L]LECCMIN = [M:SNL1]ECCVALMIN(nolign-1)
    Endif
    Call SETNEWPRI([M:SNL1]ITMREF,LECCMAJ,LECCMIN,[M:SNL0]STOFCY,date$,nolign,[M:SNL1]PRIORD(nolign-1),"") From STKVAL
Endif
#       ouverture fenetre saisie serie globale ?
# Issue X3-100690 - 2018-07-23 by MAE : Pas d'ouverture de fenêtre si ligne validée
#If [M:SNL1]SERSEQ(NOL) <> 0
If [M:SNL1]SERSEQ(NOL) <> 0 & [M:SNL1]CUNLISSTA(NOL)<>4
   Call CAL_GOUVSNLS("SNL1",NOL) From STKINV1
Endif
#                                                                     # hcb 110327 end

End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
Local Integer WOK

# si lot obligatoire alors saisie obligatoire
If [F:ITM]LOTMGTCOD > 2 & VALEUR = ""
   mkstat = 2
   End
Endif
#                                                       # hcb 71276 deb
If VALEUR <> [M]LOT(NOL)
   If dim([M:SNL1]ECCVALMIN) > 0
      Raz [M]ECCVALMAJ(NOL)
      Raz [M]ECCVALMIN(NOL)
      Raz [M]ECCSAIFLG(NOL)
   Endif
Endif
#                                                       # hcb 71276 fin

# Un lot blanc n'a pas de sous lot
Raz [M:SNL1]GESLOT(NOL)
If VALEUR="" & dim([M:SNL1]SLO)>0
   [M:SNL1]GESLOT(NOL) = "B"
   Raz   [M:SNL1]SLO(NOL)
   Diszo [M:SNL1]SLO(NOL)
Endif
If VALEUR = "" | [F:ITM]LOTMGTCOD < 4
   Read [STL]STL0=[M:SNL1]ITMREF;VALEUR;""
   If fstat
#lot inexistant pour l article
      Call OUINON(mess(23,107,1)+" : "+VALEUR+" "+mess(445,199,1),WOK) From GESECRAN
      If WOK <> 2
         mkstat = 2
         End
      Endif
  Endif
Endif

End

Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
[M:SNL1]MODFLG(NOL) = 2

End

Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
Local Integer WOK
# si slo obligatoire alors saisie obligatoire
If [F:ITM]LOTMGTCOD = 4 & VALEUR = ""
  mkstat = 2
  End
Endif
Read [STL]STL0=[M:SNL1]ITMREF;[M:SNL1]LOT(NOL);VALEUR
If fstat
#lot inexistant pour l article
   Call OUINON(mess(23,107,1)+" : "+[M:SNL1]LOT(NOL)+" : "+VALEUR+" "+mess(445,199,1),WOK) From GESECRAN
   If WOK <> 2
      mkstat = 2
      End
   Endif
Endif

End

Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
[M:SNL1]MODFLG(NOL) = 2

End
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
Local Char    LUSCAV(5)
Local Integer LMODIF
Local Decimal LCOEF
Local Decimal LQTYSTU
Local Char    PLBEFMT(GLONARP)
Local Char    LBPR

[M:SNL1]MODFLG(NOL) = 2
Call CTLUOM ([M:SNL1]ITMREF,3,LBPR,VALEUR, LCOEF, LUSCAV,PLBEFMT, LMODIF) From STKACT
If LUSCAV <> "S"
   If LUSCAV <> "C"
      mkstat = 2
      End
   Endif
Endif

[M:SNL1]PCUSTUNEW(NOL) = LCOEF                                              # hcb 31134
[M:SNL1]PCUSTUNEW1(NOL) = LCOEF                                                           # hcb 71659
[M:SNL1]PCUSTUNEW2(NOL) = LCOEF                                                           # hcb 71659
[M:SNL1]PCUSTUCOE (NOL) = LCOEF                                                           # hcb 71659
[M:SNL1]QTYSTUNEW(NOL) = [M:SNL1]QTYPCUNEW(NOL) * [M:SNL1]PCUSTUNEW(NOL)    # hcb 31134
LQTYSTU                = [M:SNL1]QTYSTUNEW(NOL)
Call QTEARR(LQTYSTU,[M:SNL1]STU) From TRTDIV
[M:SNL1]QTYSTUNEW   (NOL) = LQTYSTU
Affzo [M:SNL1]PCUSTUNEW(NOL)                                                # hcb 31134
Affzo [M:SNL1]QTYSTUNEW(NOL)

If LMODIF = 2
   Actzo [M:SNL1]PCUSTUNEW(NOL)                                             # hcb 31134
   Actzo [M:SNL1]PCUSTUNEW1(NOL)                                                          # hcb 71659
   Actzo [M:SNL1]PCUSTUNEW2(NOL)                                                          # hcb 71659
Else
   Diszo [M:SNL1]PCUSTUNEW(NOL)                                             # hcb 31134
   Diszo [M:SNL1]PCUSTUNEW1(NOL)                                                          # hcb 71659
   Diszo [M:SNL1]PCUSTUNEW2(NOL)                                                          # hcb 71659
Endif

End

Subprog AM_STA(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
[M:SNL1]MODFLG(NOL) = 2

End

Subprog AVANT_NBLIG

Gosub SET_NOL From STKINV

#activation des rubriques itmref et emplacement pour rajout de ligne
If [M:SNL1]LINFLG(NOL) <> 2
   [M:SNL1]LINFLG(NOL) = 1                                                                # hcb 71659
   Gosub AZO_SNL1 From STKINV
#nouvelle ligne
#  [M:SNL1]LINFLG(NOL) = 1                                                                # hcb 71659
# hcb 67813 deb
   If dim([M:SNL0]LOC) > 0
      If [M:SNL0]LOC(GLIG_SNL0) <> ""
         [M:SNL1]LOC(NOL) = [M:SNL0]LOC(GLIG_SNL0)
      Endif
   Endif
#                                                                         # hcb 68147 deb
   If dim([M:SNL0]LPNNUM) > 0
      If [M:SNL0]LPNNUM(GLIG_SNL0) <> ""
         [M:SNL1]LPNNUM(NOL) = [M:SNL0]LPNNUM(GLIG_SNL0)
      Endif
   Endif
   If dim([M:SNL1]OWNER) > 0
      If [M:SNL1]OWNER(NOL) = ""
         [M:SNL1]OWNER(NOL) = [M:SNL1]STOFCY
      Endif
   Endif
#                                                                         # hcb 68147 deb

# hcb 67813 fin
Else                                      # hcb 110327
  # Actzo  [M:SNL1]QTYPCUNEW       (NOL)   # hcb 110327
  # Actzo  [M:SNL1]QTYSTUNEW       (NOL)   # hcb 110327
  # Actzo  [M:SNL1]ZERSTOFLG       (NOL)   # hcb 110327

Endif

End

Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()

#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif
Gosub SET_NOL From STKINV
Gosub EXI_SERIE
#If  dim([M:SNL1]CTRNUM) < 0 &  [F:SRT]OWNERCOD     <> 1         # hcb x3-68147
#    Gosub EXI_INVENTAIRE
#Endif                             # hcb 32226
End

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV                                      # hcb x3-68147
If [F:ITF]LOCMGTCOD = 2 &  VALEUR = ""
   mkstat = 2
Endif

Call CONTROLE("LOC","",VALEUR,[M:SNL0]STOFCY,mkstat) From CONTOBJ

If [F:CUN]CUNITMWRH =  2
   Read  [STC]STC0=[M:SNL0]STOFCY;VALEUR
   If fstat
      mkstat = 2
      GMESSAGE = mess(233,192,1)       # emplacement non cree sur le site
      End
# L'emplacement n'appartient pas au dépôt
   Elsif [F:STC]WRH<>[M:SNL0]WRHCUL
      mkstat = 2
      GMESSAGE = mess(341,184,1)       # Emplacement n appartenant pas au depot
      End
   Endif
Endif
#                                                                           # hcb x3-68147 deb

If [F:ITF]LPNMGTCOD = 2 & dim([M:SNL1]LPNNUM) > 0 & [M:SNL1]LPNNUM(NOL) <> ""
   If find([F:STC]LOCCAT,3,4)
      GMESSAGE = mess(241,184,1)  # Emplacement non autorise
      mkstat = 2
      End
   Endif
   If [F:LPN]LPNNUM<>[M:SNL1]LPNNUM(NOL)
      Read [LPN]LPN0=[M:SNL1]LPNNUM(NOL)
      If fstat
         GMESSAGE = mess(243,107,1)-"LPN" # enregistrement inexistant
         mkstat = 2
         End
      Endif
   Endif
   If [F:LPN]LOC <> "" & [F:LPN]LOC <> VALEUR
      GMESSAGE         = mess(523,184,1) # l'emplacement saisie ne correspond pas à celui du contenant
      VALEUR =[F:LPN]LOC
      mkstat = 2
      End
   Endif
Endif
#                                                                           # hcb x3-68147 fin


End

