&                [M:SNL1]PCU     (NOL),
&                [M:SNL1]QTYPCU  (NOL),
&                [M:SNL1]STA     (NOL),
&                WLOC,
&                ""                   ,
&                mkstat               ,
&                "") From STKLOC


End


