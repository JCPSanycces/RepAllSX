#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Opération : OPE_IS_SHIPPABLE<br/>
#* Est ce que la ligne de commande est expédiable ?
#* @param POHNUM : numéro de commande
#* @param POQLIN : numéro de ligne de commande
#* @param POQSEQ : séquence de ligne de commande
#* @return CST_AYES si expédiable, sinon CST_ANO
#*!
$OPE_IS_SHIPPABLE
  If fmet this.AREAD(POHNUM, POPLIN, POQSEQ) = [V]CST_AOK
    [L]ARET_VALUE = fmet this.IS_SHIPPABLE()
  Else
    [L]ARET_VALUE = [V]CST_ANO
  Endif
Return

#**
#* Méthode : IS_SHIPPABLE<br/>
#* Est ce que la ligne de commande est expédiable ?
#*!
$IS_SHIPPABLE
  # 1 - La commande est déjà dans un conteneur : error
  # 2 - La ligne de commande est soldée : error
  # 3 - La ligne de commande n'est pas ferme : error
  # 4 - La ligne de commande est de contremarque : error
  # 5 - La ligne de command est sur une commande ouverte : error
  # 6 - La ligne de commande est composé, composant ou sous traitance : error
  # 7 - La qté commandée < qté réceptionnée : error
  Local File CONTAINERD[CTRD]
  Local Integer RET

  # 1 - La commande est déjà dans un conteneur : error
  Read [CTRD] CTRD1=this.POHNUM;this.POPLIN;this.POQSEQ
  If !fstat
    [L]RET = fmet this.ASETERROR("", mess(498,194,1), [V]CST_AERROR)
  Endif
  # 2 - La ligne de commande est soldée : error ou 3 - La ligne de commande n'est pas ferme : error
  If this.LINCLEFLG = CST_AYES | this.WIPSTA >= 2
    [L]RET = fmet this.ASETERROR("", mess(101,194,1), [V]CST_AERROR)
  Endif
  # 4 - La ligne de commande est de contremarque : error
  If this.ORI = 2
    [L]RET = fmet this.ASETERROR("", mess(270,183,1), [V]CST_AERROR)
  Endif
  # 5 - La ligne de command est sur une commande ouverte : error
  If this.POHTYP = 2
    [L]RET = fmet this.ASETERROR("", mess(3,512,1), [V]CST_AERROR)
  Endif
  # 6 - La ligne de commande est composé, composant ou sous traitance : error
  If this.LINTYP <> 1
    [L]RET = fmet this.ASETERROR("", mess(2,436,1), [V]CST_AERROR)
  Endif
  # 7 - la qté commandée < qté réceptionnée : error
  If (this.QTYSTU <= this.RCPQTYSTU)
    [L]RET = fmet this.ASETERROR("", mess(170,194,1), [V]CST_AERROR)
  Endif

  [L]RET = fmet this.AGETMAXERROR("")
  If [L]RET >= [V]CST_AERROR
    [L]ARET_VALUE = CST_ANO
  Else
    [L]ARET_VALUE = CST_AYES
  Endif

Return

#**
#* Opération : OPE_MANAGE_QTY<br/>
#* Manage the quantyties on PORDERQ?
#* @param POHNUM : numéro de commande
#* @param POQLIN : numéro de ligne de commande
#* @param POQSEQ : séquence de ligne de commande
#* @return CST_AOK si OK, sinon erreur
#*!
$OPE_MANAGE_QTY
[L]ARET_VALUE = [V]CST_AOK

  [L]ARET_VALUE = fmet this.AREAD(POHNUM, POPLIN, POQSEQ)
  If [L]ARET_VALUE = [V]CST_AOK
    #modification of shipped quantity
    If ((SHIPMENT.snapshot.SHIQTYSTU <> SHIPMENT.SHIQTYSTU) & SHIPMENT.CTRNUM = AVOID.ACHAR)
      this.SHIQTYSTU = max(0,this.SHIQTYSTU - SHIPMENT.snapshot.SHIQTYSTU + SHIPMENT.SHIQTYSTU)
      this.SHIQTYPUU = max(0,this.SHIQTYPUU - SHIPMENT.snapshot.SHIQTYPUU + SHIPMENT.SHIQTYPUU)
    #shipment pré-réception : passage de pré-réception=1 à pré-réception=2 sur pré-reception d'expé (pré-réception à 0)
    Elsif ((SHIPMENT.CLEFLG<>SHIPMENT.snapshot.CLEFLG) & (SHIPMENT.CLEFLG = 2))
      this.SHIQTYSTU = max(0,this.SHIQTYSTU - (SHIPMENT.SHIQTYSTU - SHIPMENT.RCPQTYSTU ))
      this.SHIQTYPUU = max(0,this.SHIQTYPUU - (SHIPMENT.SHIQTYPUU - SHIPMENT.RCPQTYPUU))
     #shipment pré-réception : passage de pré-réception=2 à pré-réception=1 sur pré-reception d'expé
     Elsif ((SHIPMENT.CLEFLG<>SHIPMENT.snapshot.CLEFLG) & (SHIPMENT.CLEFLG = 1))
      this.SHIQTYSTU = this.SHIQTYSTU + (SHIPMENT.SHIQTYSTU - SHIPMENT.RCPQTYSTU )
      this.SHIQTYPUU = this.SHIQTYPUU + (SHIPMENT.SHIQTYPUU - SHIPMENT.RCPQTYPUU)
     Endif
     #delete line
     If find(SHIPMENT.ASTALIN, CST_ADEL, CST_ANEWDEL)
      this.SHIQTYSTU = max(0,this.SHIQTYSTU - SHIPMENT.SHIQTYSTU)
      this.SHIQTYPUU = max(0,this.SHIQTYPUU - SHIPMENT.SHIQTYPUU)
     Endif
     [L]ARET_VALUE = fmet this.AUPDATE()
  Endif
Return

