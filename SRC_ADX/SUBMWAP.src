#<AdxTL>@(#)6.0.0.0 $Revision$
$SET_NOL
Local Integer NOL
NOL = nolign-1
Return


###########################################################
#Routine de lecture fiche qualité
Subprog LOAFICHE(LFIC,L)
Variable Char LFIC
Variable Integer L
Local    Integer WFSTAT 
Raz nolign, [M:MWAP]BASPAG4 
If LFIC = ""
  End
Endif
Filter [QLC] Where QLYCRD = LFIC
&            Order By Key QLC0
For [QLC]             
  nolign = [F:QLC]NUMLIN
  # FQ 53410 [M:MWAP]QLYCCRDDES        = [F:QLC]QLYCRDDES
  # FGR 24/09/2009 : X3SUIVI58062
  #M:MWAP]TEX(nolign-1)     = [F:QLC]TEX
  Call LECTEXTRA([M:MWAP]TEX(nolign-1),"QLYCRD","QSTTEXAXX",[F:QLC]QLYCRD,num$([F:QLC]NUMLIN)) From ATEXTRA
  [M:MWAP]QSTNUM(nolign-1)  = [F:QLC]QSTNUM 
  WFSTAT = fstat
  Read [QLQ]QLQ0=[F:QLC]QSTNUM
    If fstat =0
      # FQ 53410 [M:MWAP]QSTDES(nolign-1) = [F:QLQ]QSTDES
      Case [F:QLQ]DEMASWTYP
        When 1 : [M:MWAP]FORMAT(nolign-1) = "K:20X"
        When 2 : [M:MWAP]FORMAT(nolign-1) = "NFZ:13F"
        When 3 : [M:MWAP]FORMAT(nolign-1) = "DfZz:"+GFMDAT
        When 4 : [M:MWAP]FORMAT(nolign-1) = "LA1:4X"
      Endcase
    Else
      [M:MWAP]FORMAT(nolign-1) = ""
      # FQ 53410 [M:MWAP]QSTDES(nolign-1) = ""
    Endif 
  fstat = WFSTAT
  Next
Filter [QLC]
[M:MWAP]BASPAG4 = nolign 
End

###########################################################
#controle reponses fiche
Subprog VERFIC(LQUE,LREP,LRMA,LBLO,LBLS,LNEW,LRET)
Variable Decimal LQUE
Variable Decimal LREP
Variable Decimal LRMA
Variable Decimal LBLO
Variable Decimal LBLS
Variable Decimal LNEW
Variable Integer LRET
Local    Integer I, WFSTAT
Raz LQUE, LREP, LRMA, LBLO, LBLS, LNEW, LRET
#
For I = 0 To [M:MWAP]BASPAG4-1
  If [M:MWAP]QSTNUM(I) <> ""
    LQUE += 1
    If [M:MWAP]ASW(I)  <> ""
      LREP += 1
    Endif 
    WFSTAT = fstat 
    Read [QLQ]QLQ0= [M:MWAP]QSTNUM(I)
    If  fstat 
      LRET = fstat
      Break
    Else 
      If ([M:MWAP]OSDASW(I) = 2 | [M:MWAP]ASW(I) = "")
        Case [F:QLQ]LOKTYP 
          When 2 : LBLO = I+1
          When 3 : LBLS = I+1
          When 4 : LNEW = I+1
        Endcase  
      Endif  
    Endif
    fstat = WFSTAT 
    If [M:MWAP]ASW(I) = ""
      LRMA += 1
    Endif  
  Endif 
Next I
If LRET <> 0
  # FQ 69909 Ctrl des sources avant [M:STO]QSTNUM(I)
  Call ERREUR([M:MWAP]QSTNUM(I)+" : "+ mess(112,199,1)) From GESECRAN
Endif
End

###########################################################
$LOA_REPONSE
Local Integer I
I = find([F:MWA]QSTNUM,[M:MWAP]QSTNUM(0..[M:MWAP]BASPAG4-1))
If I = 0
  Return
Endif
Case [F:QLQ]DEMASWTYP
  When 1 : [M:MWAP]ASW(I-1)    = [F:MWA]ALPASW
           [M:MWAP]ALPASW(I-1) = [F:MWA]ALPASW
           [M:MWAP]OSDASW(I-1) = [F:MWA]OSDASW
  When 2 : [M:MWAP]ASW(I-1)    = num$([F:MWA]NUMASW)
           [M:MWAP]NUMASW(I-1) = [F:MWA]NUMASW
           [M:MWAP]OSDASW(I-1) = [F:MWA]OSDASW
  When 3 : [M:MWAP]ASW(I-1)    = [F:MWA]DATASW
           [M:MWAP]DATASW(I-1) = [F:MWA]DATASW
           [M:MWAP]OSDASW(I-1) = 1
  When 4 : [M:MWAP]FLGASW(I-1) = [F:MWA]FLGASW
           If [F:MWA]FLGASW = 2
             [M:MWAP]ASW(I-1)  = "2"
           Else
             [M:MWAP]ASW(I-1)  = "1" 
           Endif
           [M:MWAP]OSDASW(I-1) = 1
Endcase
Return

###########################################################
#Sous programme d'écriture fichier de travail
Subprog ECRFIC(L)
Variable Integer L
Local    Integer I

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [MWA]
#
For nolign = 1 To [M:MWAP]BASPAG4
  If [M:MWAP]QSTNUM(nolign-1) <> "" & [M:MWAP]ASW(nolign-1) <> "" 

     Filter [MWA] Where FCY    = [M:MWAP]FCY     & 
&                       STI    = [M:MWAP]STI     &
&                       BOX    = [M:MWAP]BOX     &
&                       MFGNUM = [M:MWAP]MFGNUM  &
&                       BOMOPE = [M:MWAP]BOMOPE  &
&                       IPTDAT = [M:MWAP]IPTDAT  &
&                       QSTNUM = [M:MWAP]QSTNUM(nolign-1)
&              Order By Key MWA0
     Read [MWA] First
     If fstat = 0  WSEQ =[F:MWA]MVTSEQ-1
        Else       WSEQ = 9999
     Endif                 

     Raz [F:MWA]
                [F:MWA]       = [M:MWAP]
                [F:MWA]FCY    = [M:MWAP]FCY
                [F:MWA]STI    = [M:MWAP]STI
                [F:MWA]BOX    = [M:MWAP]BOX   
                [F:MWA]IPTDAT = [M:MWAP]IPTDAT
                [F:MWA]MVTSEQ = WSEQ
                [F:MWA]PCRTYP = [M:MWAP]LTYP          
                [F:MWA]OBYPCR = [M:MWAP]LOBY          
                If [M:MWAP]LTYP = 1 
                   [F:MWA]MFGNUM = ""
                   [F:MWA]BOMOPE = 0
                Endif
                If [M:MWAP]LTYP = 2
                        [F:MWA]MFGNUM = [M:MWAP]MFGNUM 
                Endif
                If [M:MWAP]LTYP = 3
                        [F:MWA]MFGNUM =[M:MWAP]MFGNUM 
                        [F:MWA]BOMOPE =[M:MWAP]BOMOPE           
                Endif
                [F:MWA]QLYCRD = [M:MWAP]QLYCRD         

                [F:MWA]CREDAT    = date$   
                [F:MWA]CRETIM    = mid$(time$,1,2)+mid$(time$,4,2)
                [F:MWA]CREUSR    = GUSER
                [F:MWA]UPDUSR    = ""
                [F:MWA]UPDDAT    = [0/0/0]
             
     Write [MWA]
       If fstat : Call FSTA("MWA") From GLOCK : GOK = 0 : Break : Endif
     Filter [MWA]
  Endif
Next nolign
#Erreur d'écriture
If GOK = 0
 Rollback :  Call ERREUR( mess(13,100,1)) From GESECRAN
Else
 Commit
Endif     
End

###########################################################
Subprog SELTCT(LTCT,LTYP,LALP,LNUM,LDAT,LFLG)
Variable Char    LTCT
Value    Integer LTYP
Variable Char    LALP
Variable Decimal LNUM
Variable Date    LDAT
Variable Integer LFLG
#
Local    Integer CHOIX
Local    Integer SAVOBJET
Local    Char    SAVPROG
Local    Integer WNOLIGN
Local    Integer WFSTAT
#
WNOLIGN = nolign
Call SAVBOUT From GESECRAN
SAVOBJET = GOBJET
SAVPROG  = GPROGRAMME  
GOBJET   = 0 
#
mkstat = 0
Case LTYP
  When 1 :
    Filter [TCT] Where TCT = LTCT & ALPCOD >= LALP & NUMCOD = 0    
&                Order By Key TCT1
  When 2 :
    Filter [TCT] Where TCT = LTCT & ALPCOD = "" & NUMCOD >= LNUM 
&                Order By Key TCT1   
  When Default :
    Goto FIN_SELTCT
Endcase
Local Mask TCTS [TCTS]
Local Dlgbox Mask [TCTS]
&    Button mess(22,123,1),        mess(5,123,1)
&    With left$(mess(22,123,1),1), left$(mess(5,123,1),1)
&    Coded GSTAOK,                 GSTAFIN                 
&    As [TCTS]
#
Boxact [TCTS]
Raz    [M:TCTS]
nolign = 0
For [TCT]
  If nolign = 0
    [M:TCTS]TCT    = [F:TCT]TCT
    # FGR 14/01/2010 : X3SUIVI60986
    #[M:TCTS]TCTDES = [F:TCT]TCTDES  # V6 GA 03/2009 Texte traduit CRPOP
    #Call LECTEXTRA([M:TCTS]TCTDES,"TABCTL","TCTDESAXX",[F:CQU]TCT,"") From ATEXTRA
  Endif
  If nolign < dim([TCTS]COD)-1 
    Case LTYP              
      When 1 : [M:TCTS]COD(nolign)    = [F:TCT]ALPCOD
               [M:TCTS]ALPCOD(nolign) = [F:TCT]ALPCOD
               [M:TCTS]NUMCOD(nolign) = 0
      When 2 : [M:TCTS]COD(nolign)    = num$([F:TCT]NUMCOD)
               [M:TCTS]ALPCOD(nolign) = ""
               [M:TCTS]NUMCOD(nolign) = [F:TCT]NUMCOD
    Endcase
    [M:TCTS]DESCOD(nolign) = [F:TCT]DESCOD
    [M:TCTS]TCTLIN(nolign) = [F:TCT]TCTLIN
    nolign += 1
    BASTAB += 1
  Else
    Break
  Endif  
Next
Filter [TCT]
If nolign = 0
  Call MESSAGE(mess(99,100,1)) From GESECRAN
  mkstat = 2
  Goto FIN_SELTCT
Endif
############################################################
$DEB_SELTCT
Affzo [TCTS]
Boxinp [TCTS] Using CHOIX
  Case CHOIX 
    When GSTAFIN, GSTAESC :
      LALP = ""
      LNUM = 0
      mkstat = 2
      Goto FIN_SELTCT
    When GSTAOK, GSTARET :
      LALP = [M:TCTS]ALPCOD(nolign-1)
      LNUM = [M:TCTS]NUMCOD(nolign-1)
      Goto FIN_SELTCT
  Endcase
Goto DEB_SELTCT
############################################################
$FIN_SELTCT
Call RESTBOUT From GESECRAN
GOBJET     = SAVOBJET
GPROGRAMME = SAVPROG  
nolign     = WNOLIGN
End
###########################################################
Subprog CONTTCT(LTYP,LALP,LNUM,LDAT,LOSD)
Value    Integer LTYP
Variable Char    LALP
Variable Decimal LNUM
Variable Date    LDAT
Variable Integer LOSD
Local    Integer VS
LOSD   = 1
mkstat = 0
Case LTYP
  When 1 : Gosub CONTALP 
  When 2 : Gosub CONTNUM
Endcase
End
###########################################################
$CONTALP
If [F:QLQ]DEMCTLTYP = 2
  If LALP < [F:QLQ]ALPSTRVAL | LALP > [F:QLQ]ALPENDVAL
    If [F:QLQ]OSDASW = 2
      VS = 1
      Call AVERTIR(mess(60,196,1),VS) From GESECRAN
        If VS = 2 
          LOSD = 2
        Else
          mkstat = 2
          Return
        Endif
    Else
      mkstat = 2
      Return
    Endif
  Endif
Endif
#Table de contrôle
If [F:QLQ]DEMCTLTYP = 1
  Read [TCT]TCT1=[F:QLQ]TCT;LALP;0
  If fstat 
    If [F:QLQ]OSDASW = 2
      VS = 1
      Call AVERTIR(mess(60,196,1),VS) From GESECRAN
        If VS = 2 
          LOSD = 2
        Else
          mkstat = 2
          Return
        Endif
    Else
      mkstat = 2
      Return
    Endif
  Endif
Endif
Return
###########################################################
$CONTNUM
If [F:QLQ]DEMCTLTYP = 2
  If LNUM < [F:QLQ]NUMSTRVAL | LNUM > [F:QLQ]NUMENDVAL
    If [F:QLQ]OSDASW = 2
      VS = 1
      Call AVERTIR(mess(60,196,1),VS) From GESECRAN
        If VS = 2 
          LOSD = 2
        Else
          mkstat = 2
          Return
        Endif
    Else
      mkstat = 2
      Return
      Endif
  Endif
Endif
#Table de contrôle
If [F:QLQ]DEMCTLTYP = 1
  Read [TCT]TCT1=[F:QLQ]TCT;"";LNUM
  If fstat 
    If [F:QLQ]OSDASW = 2
      VS = 1
      Call AVERTIR(mess(60,196,1),VS) From GESECRAN
        If VS = 2 
        Else
          mkstat = 2
          Return
        Endif
      LOSD = 2
    Else
      mkstat = 2
    Endif
  Endif
Endif
Return
###########################################################
Subprog AV_LINNUM4(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL

Local Char WSUF : WSUF = ""
If [M:MWAP]FORMAT(NOL) <> ""
  Case mid$([M:MWAP]FORMAT(NOL),1,1)
    When "K" : If [M:MWAP]ALPASW(NOL) = ""
                 WSUF = "*"
               Else
                 WSUF = "-"
               Endif
    When "N" : If [M:MWAP]NUMASW(NOL) = 0
                 WSUF = "*"
               Else
                 WSUF = "-"
               Endif
    When "D" : If [M:MWAP]DATASW(NOL) = [0/0/0]
                 WSUF = "*"
               Else
                 WSUF = "-"
               Endif
    When "L" : If [M:MWAP]FLGASW(NOL) = 0
                 WSUF = "*"
               Else
                 WSUF = "-"
               Endif
  Endcase
Endif
[M:MWAP]LINNUM4(NOL) = format$("N>:4",NOL+1)+WSUF
End
###########################################################
Subprog AS_BASPAG4
End
###########################################################
Subprog AS_ASW
Gosub SET_NOL
If [M:MWAP]FORMAT(NOL) = ""
  mkstat = 1
  End
Endif
#Relecture question
Read [QLQ]QLQ0=[M:MWAP]QSTNUM(NOL)
  If fstat
    mkstat = 1
    End
  Endif
GBOUT2 = mess(65,198,1)
GBOUT3 = ""
#valeur par défaut
Case [QLQ]DEMASWTYP
  When 1 : If  [M:MWAP]ALPASW(NOL) = ""
             zc = [F:QLQ]ALPDEFASW
           Else
             zc = [M:MWAP]ALPASW(NOL)
           Endif
  When 2 : If [M:MWAP]NUMASW(NOL) = 0
             zc = [F:QLQ]NUMDEFASW
           Else
             zc = [M:MWAP]NUMASW(NOL)
           Endif
  When 3 : zc = [M:MWAP]DATASW(NOL)
           GBOUT3 = mess(75,198,1)
  When 4 : If [M:MWAP]FLGASW(NOL) = 0
             If [F:QLQ]ALPDEFASW = mess(2,1,1)
               zc = 2
             Else
               zc = 1
             Endif
           Else
             zc = [M:MWAP]FLGASW(NOL)
           Endif
Endcase
End
###########################################################
Subprog C_ASW
Gosub SET_NOL
Case [F:QLQ]DEMASWTYP
  When 1 :
    Local    Char    WALP : WALP = zc
    Local    Decimal WNUM : WNUM = 0
    Local    Date    WDAT : WDAT = [0/0/0]
    Local    Integer WOSD : WOSD = 0
    If zc = ""
      [M:MWAP]ASW(NOL)    = ""
      [M:MWAP]ALPASW(NOL) = ""
      [M:MWAP]OSDASW(NOL) = 0
      End
    Endif
    Call CONTTCT([F:QLQ]DEMASWTYP,WALP,WNUM,WDAT,WOSD) From SUBMWAP
      If mkstat =  0
        [M:MWAP]ASW(NOL)    = WALP
        [M:MWAP]ALPASW(NOL) = WALP
        [M:MWAP]OSDASW(NOL) = WOSD
      Endif
  When 2 :
    Local    Char    WALP : WALP = ""
    Local    Decimal WNUM : WNUM = val(num$(zc))
    Local    Date    WDAT : WDAT = [0/0/0]
    Local    Integer WOSD : WFLG = 0
    If val(num$(zc)) = 0
      [M:MWAP]ASW(NOL)    = ""
      [M:MWAP]NUMASW(NOL) = 0
      [M:MWAP]OSDASW(NOL) = 0
      End
    Endif
    Call CONTTCT([F:QLQ]DEMASWTYP,WALP,WNUM,WDAT,WOSD) From SUBMWAP
      If mkstat =  0
        [M:MWAP]ASW(NOL)    = num$(WNUM)
        [M:MWAP]NUMASW(NOL) = WNUM
        [M:MWAP]OSDASW(NOL) = WOSD
      Endif
  When 3 :
    Local    Char    WALP : WALP = ""
    Local    Decimal WNUM : WNUM = 0
    Local    Date    WDAT : WDAT = zc
    Local    Integer WOSD : WOSD = 0
    If zc = [0/0/0]
      [M:MWAP]ASW(NOL)    = ""
      [M:MWAP]DATASW(NOL) = [0/0/0]
      [M:MWAP]OSDASW(NOL) = 0
      End
    Endif
    Call CONTTCT([F:QLQ]DEMASWTYP,WALP,WNUM,WDAT,WOSD) From SUBMWAP         
      If mkstat =  0
        [M:MWAP]ASW(NOL)    = format$("D:"+GFMDAT,WDAT)
        [M:MWAP]DATASW(NOL) = WDAT
        [M:MWAP]OSDASW(NOL) = 1
      Endif
  When 4 :
    Case zc
      When "1"     : [M:MWAP]ASW(NOL)    = mess(1,1,1)
      When "2"     : [M:MWAP]ASW(NOL)    = mess(2,1,1)
      When Default : [M:MWAP]ASW(NOL)    = ""
                     [M:MWAP]FLGASW(NOL) = 0
                     [M:MWAP]OSDASW(NOL) = 0
                     End
    Endcase
    [M:MWAP]FLGASW(NOL)= zc
    [M:MWAP]OSDASW(NOL) = 1
Endcase
End

###########################################################
Subprog S_ASW       
Gosub SET_NOL
Case [QLQ]DEMASWTYP
  When 1 :
    Local    Char    WALP : WALP = zc
    Local    Decimal WNUM : WNUM = 0
    Local    Date    WDAT : WDAT = [0/0/0]
    Local    Integer WFLG : WFLG = 0
    GCONSULT = 2
    If [F:QLQ]TCT = ""
      GCONSULT = 2
      Call OBJET("QST",[M:MWAP]QSTNUM(NOL),"") From GOBJET
      GCONSULT = 0
      End
     Endif  
     Call SELTCT([F:QLQ]TCT,[F:QLQ]DEMASWTYP,WALP,WNUM,WDAT,WFLG) From SUBMWAP
     zc = WALP
  When 2 :
    Local    Char    WALP : WALP = ""
    Local    Decimal WNUM : WNUM = val(num$(zc))
    Local    Date    WDAT : WDAT = [0/0/0]
    Local    Integer WFLG : WFLG = 0
    GCONSULT = 2
    If [F:QLQ]TCT = ""
      GCONSULT = 2
      Call OBJET("QST",[M:MWAP]QSTNUM(NOL),"") From GOBJET
      GCONSULT = 0
      End
    Endif  
    Call SELTCT([F:QLQ]TCT,[F:QLQ]DEMASWTYP,WALP,WNUM,WDAT,WFLG) From SUBMWAP
    zc = num$(WNUM)
  When 3 :
    GCONSULT = 2
    Call OBJET("QST",[M:MWAP]QSTNUM(NOL),"") From GOBJET
    GCONSULT = 0
  When 4 :
    GCONSULT = 2
    Call OBJET("QST",[M:MWAP]QSTNUM(NOL),"") From GOBJET
    GCONSULT = 0 
Endcase
End

###########################################################
Subprog B2_ASW
Gosub SET_NOL
GCONSULT = 2
Call OBJET("QST",[M:MWAP]QSTNUM(NOL),"") From GOBJET
GCONSULT = 0 
End

###########################################################
Subprog B3_ASW
zc = date$
End

###########################################################
Subprog AV_OSDASW(VALEUR)
Variable Integer  VALEUR
Gosub SET_NOL
Affzo [M:MWAP]LINNUM4(NOL)
Affzo [M:MWAP]ASW(NOL)
End





