#<AdxTL>@(#)2.0.0.0 $Revision$
Call VALIDATION(1,"AQCPROC01",nomap,0,1,0,GBIDI2,GBIDI1) From ASHWVAL
End

$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement
#---------------------------------------------------------------------------------------------------#
Subprog CRUD_CLASSE(DOSSIER,CODREP,ACLA,ASHW,AERR)
Value Char DOSSIER , CODREP
Variable  Instance  ACLA  Using C_ACLA
Variable  Instance  ASHW  Using C_ASW
Variable  Instance  AERR(1..) Using C_AERROR
Gosub DEFVAR
Local Integer OK,IFSQL
Call STC_VERF(ASHW.ACLAV.TRTCRUD,ACLA.ACLAV.IDENTWML,APPLI,MACHINE,"TRT",OK,AERR) From ACLASUB
If OK

 For MT=1 To maxtab(ACLA.ACLAT)
  Raz CLOB
  Case ACLA.ACLAT(MT).CODMETSTD
   When "C"
    PROGRAM = [V]CST_APRGAINSERT: # Create
    Gosub TRT_WRITE
    Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.TRTCRUDCRE,ACLA.ACLAV.IDENTWML ,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ASHW.ACLAV.TRTCRUDCRE,0,DOSSIER,"TRT",OK,AERR) From ACLASUB

   When "R"
    Gosub TRT_TEST  From ACLAVALCRUD
    Gosub TRT_READ_ETAG From ACLAREADCRUD
    Gosub TRT_READ_SUPER From ACLAREADCRUD
    Gosub TRT_READ
    Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.TRTCRUDREAD,ACLA.ACLAV.IDENTWML ,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ASHW.ACLAV.TRTCRUDREAD,0,DOSSIER,"TRT",OK,AERR) From ACLASUB

   When "U"
    PROGRAM = [V]CST_APRGAUPDATE : # Update
    Gosub TRT_REWRITE
    Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.TRTCRUDUPD,ACLA.ACLAV.IDENTWML ,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ASHW.ACLAV.TRTCRUDUPD,0,DOSSIER,"TRT",OK,AERR) From ACLASUB

   When "D"
    PROGRAM = [V]CST_APRGADELETE : # Delete
    Gosub TRT_DELETE
    Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.TRTCRUDDEL,ACLA.ACLAV.IDENTWML ,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
    Call TRT_FIN(CLOB,ASHW.ACLAV.TRTCRUDDEL,0,DOSSIER,"TRT",OK,AERR) From ACLASUB

  Endcase
 Next
 If ACLA.TEST : Call ECR_TRACE("- Create TRT WMR CRUD"-ASHW.ACLAV.TRTCRUD,0) From GESECRAN  : Endif
 Raz CLOB
 Gosub TRT_ENTETE From ACLAVALCRUD
 Gosub TRT_AVARIABLES From ACLAVALCRUD
 If ASHW.ACLA.TYPCLA=2 : Gosub TRT_LINK From ACLAVALCRUD : Endif
 Call STC_DEB(APPLI,MACHINE,ASHW.ACLAV.TRTCRUD,ACLA.ACLAV.IDENTWML ,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
 Call TRT_FIN(CLOB,ASHW.ACLAV.TRTCRUD,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
Endif
Gosub CLOSE_FILE From ACLAVALLEC
End

#-------------------------------------------------------#
$DEFVAR
Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Integer OK,NBPRG
Local Char CODCLA(GLONACLA)
[L]CODCLA = ASHW.CODCLA
#Local Char NAMWMR(GLONADC)
#[L]NAMWMR = func APREFIXTRT.GET_PREFIX_REP_CRUD+[L]CODREP
#Local Char IDENTWMR(20)
#[L]IDENTWMR  = "## CRUD-REP ##"
Gosub OPEN_FILE From ASHWVALLEC
Gosub DEFVAR From ACLAVALLEC
Gosub DEFVAR From ASHWVALLEC
Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

# Crud Gestion only
Local Schar     ATBDES(80) , ATBORI(80)
Local Char      TABPARCOURS(100)(1..50)
Local Integer   NIVPARCOURS,ISFOR,NBFOR
Local Char      WCLE1(250),WCLE2(250),WCHAMP(250),WTABLE(250),WLANGUE(80)
Local Char      WSTRUC(30)(1..50),WSTRABR(20)(1..50),WCLALNK(20)(1..50)
Local Schar     ROOTCLA(GLONASW+1+GLONABR),TYPCRUD,ROOTNAM(GLONACLA+2)

[L]ROOTCLA = [L]CODREP+"."+ASHW.ABRCLA
[L]TYPCRUD = "REP"
[L]ROOTNAM = [L]CODREP

# temporaire
ACLA.ACLAV.NOMSTC   = func SUBASW.PREFIX_REP+CODREP
ACLA.ACLAV.TRTCRUD = ASHW.ACLAV.TRTCRUD

# reformatage des pointeur :
For MM=1 To maxtab(ACLA.ACLAK)
 Call DEF_PTRLNK(ACLA.ACLAK(MM), ASHW.CODREP+"."+ASHW.ABRCLA) From ACLAVALLEC
Next

Gosub DEF_PTRFOR From ACLAVALLEC

Return

#-------------------------------------------------------#

$TEXTRA_REP
For I=1 To maxtab(ASHW.ACLAF)
 If find(ASHW.ACLAF(I).CODTYP,"AX3","AX2","AX1","AXX")<>0 & ASHW.ACLAF(I).FLDGRP=""
  Call ATEXTRA_PROG(1,[L]ROOTCLA,PROGRAM,1,ASHW.ACLAF(I),ISFOR,NBFOR,ASHW,LIGNE,CLOB,DIF) From ACLATXTCRUD
  LIGNE = "" : Gosub ADDCLB
 Endif
Next
Return

#-------------------------------------------------------#
$TRT_READ
Gosub START_READ From ACLAREADCRUD

Gosub ADD_RIGHT

Call DECLARE_ACTION([L]ROOTNAM,PROGRAM+"_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_GOTO
LIGNE = "" : Gosub ADDCLB

LIGNE =[L]ROOTCLA+".setAccessorEnabled = 0"  : Gosub ADDCLB
LIGNE = '[L]ASTATUS = max([L]ASTATUS,fmet '+[L]ROOTCLA+'.'+[V]CST_APRGAREAD+'('+"[L]_"+ACLA.ACLAI(1).CLEREF
For I=2 To ACLA.NBCLEREF
 LIGNE += ",[L]_"+ACLA.ACLAI(I).CLEREF
Next
LIGNE += "))" : Gosub ADDCLB
Gosub ERREUR_ACTION_GOTO
LIGNE = "" : Gosub ADDCLB

Gosub TEXTRA_REP

Call DECLARE_ACTION([L]ROOTNAM,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_GOTO
LIGNE = "" : Gosub ADDCLB

Gosub END_READ From ACLAREADCRUD
Return

#-------------------------------------------------------#

$TRT_WRITE
Gosub START_TRTTR
Gosub BEGIN_TR
LIGNE = "Gosub _"+PROGRAM+"_AFTER" : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_END" : Gosub ADDCLB
Gosub INIT_SNAPSHOT From ACLASUBCRUD
LIGNE = "End"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
Gosub END_TRTTR
Gosub TRT_MAJTR
Return

#-------------------------------------------------------#

$TRT_REWRITE
Gosub START_TRTTR
Gosub BEGIN_TR
LIGNE = "Gosub _"+PROGRAM+"_AFTER" : Gosub ADDCLB
Gosub INIT_SNAPSHOT From ACLASUBCRUD
LIGNE = "$"+PROGRAM+"_END" : Gosub ADDCLB
LIGNE = "End"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB

Gosub END_TRTTR
Gosub TRT_MAJTR
Return

#-------------------------------------------------------#

$TRT_DELETE
Gosub START_TRTTR
Gosub BEGIN_TR
LIGNE = "$"+PROGRAM+"_END" : Gosub ADDCLB
LIGNE = "End"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
Gosub END_TRTTR
Gosub TRT_MAJTR
Return

#-------------------------------------------------------#

$TRT_MAJTR
NIVEAU = 1
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_"+[L]ROOTNAM: Gosub ADDCLB
Call DECLARE_ACTION([L]ROOTNAM,PROGRAM+"_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF
LIGNE = "" : Gosub ADDCLB
LIGNE = '[L]ASTATUS = max([L]ASTATUS,fmet '+[L]ROOTCLA+'._'+PROGRAM+")" : Gosub ADDCLB
Gosub ERREUR_ACTION_RECURSIF
LIGNE = "" : Gosub ADDCLB
Gosub TEXTRA_REP
Call DECLARE_ACTION([L]ROOTNAM,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF
NIVEAU = 1
LIGNE = "Return"  : Gosub ADDCLB
LIGNE = ""  : Gosub ADDCLB
Gosub ABORT From ACLASUBCRUD
Return

#-------------------------------------------------------#

$ACONTROLREP
LIGNE = "$AREPCONTROL_"+PROGRAM   :  Gosub ADDCLB

If PROGRAM="AINSERT"
 LIGNE = [L]ROOTNAM+".ASTALIN = [V]CST_ANEW"  : Gosub ADDCLB
 LIGNE = [L]ROOTCLA+".ASTALIN = [V]CST_ANEW"  : Gosub ADDCLB
Elsif PROGRAM ="AUPDATE"
 LIGNE = [L]ROOTNAM+".ASTALIN = [V]CST_AUPD"  : Gosub ADDCLB
 LIGNE = [L]ROOTCLA+".ASTALIN = [V]CST_AUPD"  : Gosub ADDCLB
Elsif PROGRAM ="ADELETE"
 LIGNE = [L]ROOTNAM+".ASTALIN = [V]CST_ADEL"  :  Gosub ADDCLB
 LIGNE = [L]ROOTCLA+".ASTALIN = [V]CST_ADEL"  :  Gosub ADDCLB
Endif

Call DECLARE_ACTION([L]ROOTNAM,PROGRAM+"_CONTROL_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF
LIGNE = "" : Gosub ADDCLB

LIGNE ="Gosub "+PROGRAM+"_CONTROL"  : Gosub ADDCLB
Gosub ERREUR_ACTION_RECURSIF
LIGNE = ""   : Gosub ADDCLB

Call DECLARE_ACTION([L]ROOTNAM,PROGRAM+"_CONTROL_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB

## A_Control
Gosub A_CONTROL From ACLASUBMAJCRUD
Return

$ADD_RIGHT
If ASHW.AFCRIGHT="" : Return  : Endif
NIVEAU = 1
LIGNE = 'If fmet '+[L]ROOTNAM+'.ACTX.AGETAFCRIGHT('+ROOTNAM+',"'+ASHW.AFCRIGHT+'",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto '+PROGRAM+'_END : Endif' : Gosub ADDCLB
Case PROGRAM
 When "AREAD"  :
  If ACLA.TYPCLA=2
   Gosub READ_TABLE_PRINCIPALE_PARAM From ACLASUBCRUD
   Gosub AJOUT_ACCES_SITE From ACLASUBCRUD
 Endif
Endcase


LIGNE = 'If fmet '+[L]ROOTNAM+'.ACTX.AGETAFCRIGHT'
Case PROGRAM
 When "AREAD"      : LIGNE += "R"
 When "AUPDATE"   : LIGNE += "U"
 When "AINSERT"   : LIGNE += "C"
 When "ADELETE"    : LIGNE += "D"
Endcase
LIGNE += '('+ROOTNAM+',"'+ASHW.AFCRIGHT+'",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR' : Gosub ADDCLB
DIF += 1
LIGNE = '[L]ASTATUS=[V]CST_AERROR : Goto '+PROGRAM+'_END' : Gosub ADDCLB
DIF -= 1
LIGNE = 'Endif' : Gosub ADDCLB

If ACLA.ACCSTR<>""
 LIGNE = "If fmet "+[L]ROOTNAM+".ACTX.AGETACSRIGHT"
 Case PROGRAM
  When "AREAD"      : LIGNE += "C" : # Consultation
  When "AUPDATE"   : LIGNE += "M" : # Modification
  When "AINSERT"    : LIGNE += "M"  : # Modification
  When "ADELETE"    : LIGNE += "M" : # Modification
 Endcase
 LIGNE += "("+ROOTNAM+",[L]A_STRACC,[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR" : Gosub ADDCLB
 DIF += 1
 LIGNE = "Goto "+PROGRAM+"_END" : Gosub ADDCLB
 DIF += 1
 LIGNE = "Endif" : Gosub ADDCLB
Endif

If PROGRAM="AREAD" and ASHW.AOBRIGHT<>"" and ACLA.TYPCLA=2 # Ajout test role
 LIGNE = 'If fmet '+[L]ROOTNAM+'.ACTX.ASTACRITROLE('+ROOTNAM+','
 For I=1 To ACLA.ACLAK(NIVEAU).NBRIND
  If I>1 : LIGNE += '+"~"+' : Endif
  If  ACLA.ACLAK(NIVEAU).TYPIND(I)<>[V]CST_ATYPCHAR : LIGNE += 'num$(' : Endif
  LIGNE += '[L]_'+ACLA.ACLAK(NIVEAU).INDEX(I)
  If  ACLA.ACLAK(NIVEAU).TYPIND(I)<>[V]CST_ATYPCHAR : LIGNE += ")" : Endif
  If len(LIGNE)>100
   Gosub ADDCLB
   LIGNE ="& "
  Endif
 Next I
 Gosub ADDCLB0
 LIGNE = '& ,"'+ASHW.AOBRIGHT+'","'+ACLA.ACLAK( NIVEAU).ABRLNK+'",[V]CST_ATRUE)>=[V]CST_AERROR' :  Gosub ADDCLB0
 DIF += 1
 LIGNE = '[L]ASTATUS=[V]CST_AERROR : Goto '+PROGRAM+'_END ' :Gosub ADDCLB
 DIF -= 1
 LIGNE = 'Endif' : Gosub ADDCLB
Endif

LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#

$START_TRTTR
If ACLA.TEST : Call ECR_TRACE("- Create PRG : "+[L]PROGRAM,0) From GESECRAN  : Endif
DIF = 0 : NIVEAU = 1 : NBFOR = 0 : NIVPARCOURS = 0 : ISFOR =0

Gosub ENTETE_SUBPROG From ACLASUBCRUD

Gosub ADD_RIGHT

LIGNE ="Gosub AREPCONTROL_"+PROGRAM  : Gosub ADDCLB
Gosub ERREUR_ACTION_GOTO
LIGNE = ""   : Gosub ADDCLB

DIF = 0 : NIVEAU = 1 : NBFOR = 0 : NIVPARCOURS = 0 : ISFOR =0
Return

#-------------------------------------------------------#

$END_TRTTR
LIGNE = "#-----------------------------------------------------#"  : Gosub ADDCLB
## A_Control
Gosub ACONTROLREP
LIGNE = "#-----------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_TR_"+[L]ROOTNAM  : Gosub ADDCLB

If ACLA.FLGTR=2
 If ACLA.TYPCLA=2
  LIGNE = "Trbegin [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"  : Gosub ADDCLB
 Elsif ACLA.TYPCLA=5
  LIGNE = "Trbegin [F:__INT]"  : Gosub ADDCLB
 Endif
 DIF += 1
Endif
LIGNE = "Gosub "+PROGRAM+"_"+[L]ROOTNAM   : Gosub ADDCLB
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Gosub "+PROGRAM+"_ABORT : Return : Endif"  : Gosub ADDCLB
If ACLA.FLGTR=2
 DIF -= 1
 LIGNE = "Commit"   : Gosub ADDCLB
Endif
LIGNE = "Return"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
LIGNE = "#-----------------------------------------------------#"  : Gosub ADDCLB
Gosub TRT_AFTERREWRITE_OK From ACLAREWRITECRUD
Return

#-------------------------------------------------------#

$BEGIN_TR
LIGNE = "If !adxlog"   : Gosub ADDCLB
DIF +=1
 LIGNE = "Gosub "+PROGRAM+"_TR_"+[L]ROOTNAM : Gosub ADDCLB
DIF -= 1
LIGNE = "Else"   : Gosub ADDCLB
DIF +=1 : LIGNE = "Gosub "+PROGRAM+"_"+[L]ROOTNAM   : Gosub ADDCLB : DIF-= 1
LIGNE = "Endif"   : Gosub ADDCLB
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Gosub "+PROGRAM+"_END : Return : Endif"  : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
Return


#-------------------------------------------------------#
# Gestion erreur avec Goto
#-------------------------------------------------------#
$ERREUR_ACTION_GOTO
If left$(PROGRAM,1)<>"_"
 LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : Goto'-PROGRAM+'_END : Endif'
 Gosub ADDCLB
Endif
Return


#-------------------------------------------------------#
# Gestion erreur
#-------------------------------------------------------#
$ERREUR_ACTION_RECURSIF
LIGNE = ""
If ISFOR>0
 LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : Break'-string$(NBFOR>1,num$(NBFOR))+" : Endif" : Gosub ADDCLB
Else
 LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : Return : Endif' : Gosub ADDCLB
Endif
Return

