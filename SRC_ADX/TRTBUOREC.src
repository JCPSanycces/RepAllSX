#<AdxTL>@(#)3.0.0.0 $Revision$
#------------------------------------------------------------------------------
#                         Budgets Opérationnels
#------------------------------------------------------------------------------
#   Fonction : BUOREC - Reconduction de budgets
#   Action   : BUOREC
#   Fenêtre  : BUOREC
#   Ecran concerné : BUOREC [M:BRC]
#   Description :
#   *2-Reconduction
#          -> Pour une enveloppe budgétaire "Annuelle", il est possible
#             de reconduire (faire glisser) dans l'exercice budgétaire N+1,
#             Ceci evite d'avoir à ressaisir chq année des budgets récurrents.
#------------------------------------------------------------------------------
#
# Issue X3-65573 - 2017-12-05 by BEFOU : No counter when FCY is needed
#

Call TRAITE_CHAR(VALEUR,PARAM,"","BUOREC","TRTBUOREC",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
Endcase
Return

$AVANT_PAR
Raz [M:BRC]
Return

$INIT
#Tables utiles
If !clalev([GCM])  : Local File GACM       [GCM]  : Endif
If !clalev([LED])  : Local File GLED       [LED]  : Endif
If !clalev([CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([FIY])  : Local File FISCALYEAR [FIY]  : Endif
If !clalev([FIY2]) : Local File FISCALYEAR [FIY2] : Endif
If !clalev([CCE])  : Local File CACCE      [CCE]  : Endif
If !clalev([BUT])  : Local File BUDTYP     [BUT]  : Endif
If !clalev([BUP])  : Local File BUDPAR     [BUP]  : Endif
If !clalev([PRJ])  : Local File PROJET     [PRJ]  : Endif
If !clalev([ENV])  : Local File ENVELOPPE  [ENV]  : Endif
If !clalev([ENV2]) : Local File ENVELOPPE  [ENV2] : Endif
If !clalev([ENV3]) : Local File ENVELOPPE  [ENV3] : Endif
If !clalev([ENF])  : Local File ENVFIY     [ENF]  : Endif
If !clalev([ENF2]) : Local File ENVFIY     [ENF2] : Endif
If !clalev([ENF3]) : Local File ENVFIY     [ENF3] : Endif
If !clalev([BUD])  : Local File BUD        [BUD]  : Endif
If !clalev([BUD2]) : Local File BUD        [BUD2] : Endif
If !clalev([BUD3]) : Local File BUD        [BUD3] : Endif
If !clalev([GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([ENT])  : Local File ENTITE     [ENT]  : Endif

#Variable Globale
Global Char GAPPNIV(3)

#Variables Locales
Local Integer OK
Local Char    CRITENV(250),CRITENVR(100)
Local Char    TRACE_REP(250),TRACE_REC(250)
Local Decimal SOM_DISPO_LIG, DISPO_LIG
Local Decimal AMT_LB, SLD_LB, RAV_BUD, RES_BUD
Local Char    NUMENV(15)
Local Integer MAJ
Local Mask BUOREC [BRC]
Local Integer INDENV, INDENT, INDCCE3
Return

$CONTROLE
TMP=1
Return

$EXEC
# Trace/Tracking
If [M]TRC=2
 Local Integer TRCREC
 TRCREC=0
 # Reconduction des enveloppes budgétaires annuelles
 Call OUVRE_TRACE(mess(245,108,1)) From LECFIC
Endif

Gosub LOAD_FILTRE

# Reconduction des budgets
For I=0 To [M]NBLIG-1
 If [M]NIV(I)=1 & [M]RECOND(I) = 2
  NUMENV=""
  Call DEBTRANS From GLOCK
  Gosub RECOND
 Endif
Next

If [M]TRC=2
 If !TRCREC
 # #Rien n'a été reconduit
 # Call ECR_TRACE(mess(206,108,1),0) From  GESECRAN
 Endif
 Call ECR_TRACE("---------------------------------------------",0) From  GESECRAN
Endif
Return

$LOAD_FILTRE
#---- Critères sur Enveloppe ----#
CRITENV="1=1"

# Société/site
If ALLFCY=1
 CRITENV -= '& FCY>="'+[M]FCYSTR+'" & FCY<="'+[M]FCYEND+'"'
Else
 Local Integer SOC,J
 Local Char LISTFCY(GLONFCY)(1..GNBSITE)
 SOC=find([M]CPY,GSOC(1..GNBSOC))
 J=1
 If SOC
  For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
   LISTFCY(J)=[F:FCY]FCY
   J+=1
  Next
 Endif
 CRITENV -='& (FCY="'+[M]CPY+'" | find(FCY,LISTFCY(1..J)))'
Endif

# Projet
If [M]ALLPRJ=1
 CRITENV -= '& PRJ>="'+[M]PRJSTR+'" & PRJ<="'+[M]PRJEND+'"'
Endif
# Entité
If [M]ALLENT=1
 CRITENV -= '& ENTMNA>="'+[M]ENTSTR+'" & ENTMNA<="'+[M]ENTEND+'"'
Endif
# Enveloppe
If [M]ALLENV=1
 CRITENV -= '& ENV>="'+[M]ENVSTR+'" & ENV<="'+[M]ENVEND+'"'
Endif

# Reconductibilité
CRITENV -='& RECOND=2 & DRECOND=[0/0/0]'

# Date exercice en cours
CRITENV -='& REASTR>=['+format$(GFMD,[M]DFIY)+'] & REAEND<=['+format$(GFMD,[M]FFIY)+']'

CRITENVR ='REASTR=['+format$(GFMD,[M]DRFIY)+'] & REAEND=['+format$(GFMD,[M]FRFIY)+']'
Return

#------------------------------------------- RECONDUCTION DE BUDGET ----------------------------------------------#

$RECOND
Trbegin [ENV],[ENV3],[CCE],[ENF3],[BUD3]
 Readlock [ENV]ENV0 = [M]ENV(I)
 If !fstat
  Local Integer STAT, EXISTBUD : EXISTBUD=0
  Local Char    SITE(GLONFCY)
  Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
  Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
  Call GETGDDINDDIE([F:ENV]SOCIETE,[F:BUP]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD

  If [F:BUT]YEAFLG=1 :# Annuelle

   #--- Enveloppe

   Call CTL_DAT2([F:ENV]ENTMNA,[F:ENV]ENTAPP,[F:ENV]ENTRAT,[F:ENV]BUD,[F:ENV]PRJ,
&                [M]TRC,[F:ENV]ENV,[M]DRFIY,[M]FRFIY,OK)
   If OK=1

    #--- Nouveau numéro d'enveloppe
    # Issue X3-65573 - 2017-12-05 by BEFOU : No counter when FCY is needed !  use of [F:ENV]FCY insted of [F:BUD]
    If NUMENV=""
     If [F:BUT]MANCOU<>2
      Call NUMERO([F:BUT]COU,[F:ENV]FCY,[M]DRFIY,"",[L]NUMENV,STAT) From SUBANM
     Else
     NUMENV=[F:ENV]ENV+"_R"+num$([M]RFIY)
     Endif
    Endif
    #---
    Filter [ENV2] Where ENVORG=[F:ENV]ENV
    Read [ENV2]ENV0 First
    If fstat
     Raz [F:ENV3]
     [F:ENV3] = [F:ENV]
     Raz [F:ENV3]AMTAPP
     Raz [F:ENV3]REVDAT
     Raz [F:ENV3]APPDAT
     Raz [F:ENV3]DRECOND
     Raz [F:ENV3]UPDUSR
     Raz [F:ENV3]UPDDAT
     Raz [F:ENV3]UPDTIM
     Raz [F:ENV3]ENVRCD
     Raz [F:ENV3]CRETIM
     [F:ENV3]ENVORG = [F:ENV]ENV
     [F:ENV3]ENV    = NUMENV
     [F:ENV3]REASTR = [M]DRFIY
     [F:ENV3]REAEND = [M]FRFIY
     [F:ENV3]AMTENV = [F:ENV]AMTENV+([F:ENV]AMTENV*[M]PRCREC(I)/100)
     [F:ENV3]AMTRES = [F:ENV]AMTRES+([F:ENV]AMTRES*[M]PRCREC(I)/100)
     [F:ENV3]STA    = 1
     [F:ENV3]CREUSR = GUSER
     [F:ENV3]CREDAT = date$

     Write [ENV3]

     If fstat: GOK=0 : Call FSTA("ENV3") From GLOCK : Goto AB_RECOND : Endif
     Call DUPTEXTRA("ENVELOPPE","DESTRA",[F:ENV]ENV,"","ENVELOPPE","DESTRA",[F:ENV3]ENV,"")  From ATEXTRA
     Call DUPTEXTRA("ENVELOPPE","SHOTRA",[F:ENV]ENV,"","ENVELOPPE","SHOTRA",[F:ENV3]ENV,"")  From ATEXTRA
     If [M]TRC=2
      TRCREC+=1
      # Création de l'enveloppe
      Call ECR_TRACE(mess(201,108,1)-":"-[F:ENV3]ENV,0) From  GESECRAN
     Endif
     #il faut aussi créer la section
     If [F:BUP]DIE(1)<>""
      GOK = 1
      Raz [F:CCE]
      [F:CCE]DIE    = [F:BUP]DIE(1)
      [F:CCE]CCE    = NUMENV
      [F:CCE]ENAFLG = 2
      [F:CCE]ACS    = [F:ENV]ACS
      [F:CCE]VLYSTR = [M]DRFIY
      [F:CCE]VLYEND = [M]FRFIY
      [F:CCE]FCY    = [F:ENV]FCY
      [F:CCE]BUDTRK = 2
      [F:CCE]IPT    = 2
      Write [CCE]
      If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Goto AB_RECOND : Endif
      Call DUPTEXTRA("ENVELOPPE","DESTRA",[F:ENV]ENV,"","CACCE","DESTRA",[F:BUP]DIE(1),NUMENV)  From ATEXTRA
      Call DUPTEXTRA("ENVELOPPE","SHOTRA",[F:ENV]ENV,"","CACCE","SHOTRA",[F:BUP]DIE(1),NUMENV)  From ATEXTRA
     Endif
     # Mise à jour enveloppe d'origine avec date de reconduction
     [F:ENV]TYPREC=1
     [F:ENV]DRECOND=date$
     [F:ENV]ENVRCD=NUMENV
     Rewrite [ENV]
     If fstat: GOK=0 : Call FSTA("ENV") From GLOCK : Goto AB_RECOND : Endif
    #Else
     #Enveloppe existante pour l'exercice recepteur
    Endif
    Filter [ENV2]
    #----- Fin Enveloppe

    #--- Budget exercice
    Read [ENF]ENF0=[F:ENV]ENV;[M]EFIY
    If !fstat
     Filter [ENF2] Where ENV=NUMENV & FIYNUM=[M]RFIY
     Read [ENF2]ENF0 First
     If fstat
      Raz [ENF3]
      [F:ENF3]ENV    = NUMENV
      [F:ENF3]AMTBUDFIY = [F:ENF]AMTBUDFIY+([F:ENF]AMTBUDFIY*[M]PRCREC(I)/100)
      [F:ENF3]AMTRESFIY = [F:ENF]AMTRESFIY+([F:ENF]AMTRESFIY*[M]PRCREC(I)/100)
      [F:ENF3]FIYNUM = [M]RFIY
      [F:ENF3]FIYSTR = [M]DRFIY
      [F:ENF3]FIYEND = [M]FRFIY
      [F:ENF3]STAFIY = 1
      Write [ENF3]
      If fstat: GOK=0 : Call FSTA("ENF3") From GLOCK : Goto AB_RECOND : Endif
      If [M]TRC=2
       TRCREC+=1
       #Création du budget exercice
       Call ECR_TRACE(mess(198,108,1)-":"-[F:ENF3]ENV-"/"-num$([F:ENF3]FIYNUM),0) From  GESECRAN
      Endif
     #Else
      #Budget exercice existant dans l'exercice recepteur
     Endif
     Filter [ENF2]
     #----- Fin budget exercice

     #--- Lignes budgétaires
     For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM
      If INDCCE3>0
       Call CTL_DAT([F:BUD]ACC,[F:BUD]COA,evalue('[F:BUD]DIE'+num$(INDENT)),evalue('[F:BUD]CCE'+num$(INDENT)),
&      evalue('[F:BUD]DIE'+num$(INDCCE3)),evalue('[F:BUD]CCE'+num$(INDCCE3)),[M]TRC,[F:ENV]ENV,[M]DRFIY,[M]FRFIY,OK)
      Else
       Call CTL_DAT([F:BUD]ACC,[F:BUD]COA,evalue('[F:BUD]DIE'+num$(INDENT)),evalue('[F:BUD]CCE'+num$(INDENT)),
&      "","",[M]TRC,[F:ENV]ENV,[M]DRFIY,[M]FRFIY,OK)
      Endif

      If OK=1
       Raz [F:BUD3]
       [F:BUD3] = [F:BUD]
       Raz [F:BUD3]AMTCMM
       Raz [F:BUD3]AMTCMMPRP
       Raz [F:BUD3]AMTREA
       Raz [F:BUD3]AMTAPP
       Raz [F:BUD3]AMTATT
       Raz [F:BUD3]AMTCCA
       Raz [F:BUD3]AMTCAP
       Raz [F:BUD3]UPDDAT
       Raz [F:BUD3]UPDUSR
       Raz [F:BUD3]APPDAT
       Raz [F:BUD3]REVDAT
       Assign('[F:BUD3]CCE'+num$(INDENV)) With NUMENV
       [F:BUD3]ACCNUM = uniqid([F:BUD])
       [F:BUD3]FIY    = [F:BUD]FIY+1
       [F:BUD3]AMT    = [F:BUD]AMT+([F:BUD]AMT*[M]PRCREC(I)/100)
       [F:BUD3]STA    = 1
       [F:BUD3]CREUSR = GUSER
       [F:BUD3]CREDAT = date$
       Write [BUD3]
       If fstat: GOK=0 : Call FSTA("BUD3") From GLOCK : Break : Endif
       If [M]TRC=2
        TRCREC+=1
        #Création de la ligne
        Call ECR_TRACE(mess(196,108,1)-":"-evalue('[F:BUD3]CCE'+num$(INDENV))-"/"-num$([F:BUD3]FIY)
&                      -"/"-[F:BUD3]ACC-"/"-num$([F:BUD3]ACCNUM),0) From  GESECRAN
       Endif
      Endif
     Next
     If GOK=0 : Goto AB_RECOND : Endif
    Endif
   Endif
  Endif
 Endif
Commit
Return

$AB_RECOND
Rollback
Return

#######################################################################################
## Check the validity date of the budget account/  Recipient entity /dimension
#######################################################################################
Subprog CTL_DAT(ACC,COA,DIE1,CCE1,DIE3,CCE3,TRC,ENV,DATSTR,DATEND,OK)
Value    Char    ACC
Value    Char    COA
Value    Char    DIE1
Value    Char    CCE1
Value    Char    DIE3
Value    Char    CCE3
Value    Integer TRC
Value    Char    ENV
Value    Date    DATSTR
Value    Date    DATEND
Variable Integer OK

If !clalev([GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([CCE])  : Local File CACCE      [CCE]  : Endif
OK = 1
Call LEC_GAC(ACC,COA) From CPTLEC
If !fstat & ( ([F:GAC]VLYSTR<>[0/0/0] & [F:GAC]VLYSTR>DATSTR) | ([F:GAC]VLYEND<>[0/0/0] & [F:GAC]VLYEND<DATEND))
 If TRC=2
  # Date incompatible avec les dates de validité du compte budgétaire
  Call ECR_TRACE(mess(178,108,1)-ENV-"\"-mess(278,108,1)-ACC,1) From  GESECRAN
 Endif
 OK = 0
Endif

Call LEC_CCE(CCE1,DIE1) From CPTLEC
If !fstat & ( ([F:CCE]VLYSTR<>[0/0/0] & [F:CCE]VLYSTR>DATSTR) | ([F:CCE]VLYEND<>[0/0/0] & [F:CCE]VLYEND<DATEND))
 If TRC=2
  # Date incompatible avec les dates de validité de l'entité
  Call ECR_TRACE(mess(178,108,1)-ENV-"\"-mess(276,108,1)-CCE1,1) From  GESECRAN
 Endif
 OK = 0
Endif

If CCE3<>""
 Call LEC_CCE(CCE3,DIE3) From CPTLEC
 If !fstat & ( ([F:CCE]VLYSTR<>[0/0/0] & [F:CCE]VLYSTR>DATSTR) | ([F:CCE]VLYEND<>[0/0/0] & [F:CCE]VLYEND<DATEND))
  If TRC=2
   # Date incompatible avec les dates de validité de la section
   Call ECR_TRACE(mess(178,108,1)-ENV-"\"-mess(280,108,1)-CCE3,1) From  GESECRAN
  Endif
  OK = 0
 Endif
Endif
End

#######################################################################################
## Check the validity dates of entity/budget/project
#######################################################################################
Subprog CTL_DAT2(ENTMNA,ENTAPP,ENTRAT,BUD,PRJ,TRC,ENV,DATSTR,DATEND,OK)
Value    Char    ENTMNA
Value    Char    ENTAPP
Value    Char    ENTRAT
Value    Char    BUD
Value    Char    PRJ
Value    Integer TRC
Value    Char    ENV
Value    Date    DATSTR
Value    Date    DATEND
Variable Integer OK

If !clalev([BUP])  : Local File BUDPAR     [BUP]  : Endif
If !clalev([PRJ])  : Local File PROJET     [PRJ]  : Endif
If !clalev([ENT])  : Local File ENTITE     [ENT]  : Endif

OK = 1

# Check the validity date of the entities
If !func TRTBUOREC.CTL_PER_ENT(ENTMNA,DATSTR,DATEND)
&| !func TRTBUOREC.CTL_PER_ENT(ENTAPP,DATSTR,DATEND)
&| !func TRTBUOREC.CTL_PER_ENT(ENTRAT,DATSTR,DATEND)
 OK = 0
 If TRC=2
  # Enveloppe xxxx Date incompatible avec les dates de validité de l'entité
  Call ECR_TRACE(mess(178,108,1)-ENV-"\"-GMESSAGE,1) From  GESECRAN
 Endif
Endif

# Check the validity date of the budget
Call LEC_BUD(BUD) From CPTLEC
If !fstat & (([F:BUP]VLYSTR<>[0/0/0] & [F:BUP]VLYSTR>DATSTR) | ([F:BUP]VLYEND<>[0/0/0] & [F:BUP]VLYEND<DATEND))
 OK = 0
 If TRC=2
  # Enveloppe xxxx Date incompatible avec les dates de validité du budget
  Call ECR_TRACE(mess(178,108,1)-ENV-"\"-mess(277,108,1)-BUD,1) From  GESECRAN
 Endif
Endif

# Check the validity date of the project
Call LEC_PRJ(PRJ) From CPTLEC
If !fstat & (([F:PRJ]REASTR<>[0/0/0] & [F:PRJ]REASTR>DATSTR) | ([F:PRJ]REAEND<>[0/0/0] & [F:PRJ]REAEND<DATEND))
 OK = 0
 If TRC=2
  # Enveloppe xxxx Date incompatible avec les dates de validité du projet
  Call ECR_TRACE(mess(178,108,1)-[F:ENV]ENV-"\"-mess(281,108,1)-[F:ENV]PRJ,1) From  GESECRAN
 Endif
Endif
End

#######################################################################################
## Contrôle que les entités responsable/d'approbation/de rattachement sont valides
## sur la période de reconduction
#######################################################################################
Funprog CTL_PER_ENT(ENT,DAT1,DAT2)
Value Char ENT
Value Date DAT1,DAT2
If ENT<>""
 Call LEC_ENT(ENT) From CPTLEC
 If !fstat & (([F:ENT]VLYSTR<>[0/0/0] & [F:ENT]VLYSTR>DAT1) | ([F:ENT]VLYEND<>[0/0/0] & [F:ENT]VLYEND<DAT2))
  # Date incompatible avec les dates de validité de l'entité
  If GMESSAGE<>"": GMESSAGE -= "\" : Endif
  GMESSAGE -= mess(276,108,1)-ENT-num$([F:ENT]VLYSTR)-"-"-num$([F:ENT]VLYEND)
  End 0
 Endif
Endif
End 1

$TERMINE
Local Integer INDREC : INDREC=0
For I=0 To [M]NBLIG-1
 If [M]RECOND(I)=2 : INDREC=1 : Break : Endif
Next
If !INDREC
 #Vous n'avez rien coché. Souhaitez vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Else
 #Trace
 If [M]TRC=2
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
Endif
Return


$COLORIZE
Local Integer K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M]ENV(0)
For I=0 To [M]NBLIG-1
 If [M]ENV(I)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M]NBLIG(I)  With "GDD"+num$(K)
 Else
  Chgstl [M]NBLIG(I)  With "GDD"+num$(K)
 Endif
 ENVCUR=[M]ENV(I)
Next
Affzo [M]
Return

#######################################################################################
## Etiquette de l'écran REPRECBUD
#######################################################################################

Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]EFIY=0
 # Exercie incorrect
 GMESSAGE = mess(52,116,1)
 mkstat=2 : End
Endif
Gosub INIT
# Filtre/Filter
Gosub LOAD_FILTRE
Local Integer I : I=0
Local Integer STAT
Local Char    NUMENV(15),SITE(GLONFCY)
Local Decimal REALISE
Local Integer OKACS, CTLACS
Local Integer INDENV, INDENT, INDCCE3
CTLACS = 1

For [ENV]ENV0 Where evalue(CRITENV)
 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif
 If OKACS
  Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  If [F:BUT]YEAFLG=1  & I<dim([M]NIV):# Annuelle
   [M]NIV(I)=1
   [M]ENV(I)=[F:ENV]ENV
   [M]FIY(I)=[M]EFIY
   [M]CUR(I)=[F:ENV]CURENV
   [M]AMT(I)=[F:ENV]AMTENV
   [M]RES(I)=[F:ENV]AMTRES
   [M]RECOND(I)=1
   Raz [M]PRCREC(I)
   Read [ENF]ENF0=[F:ENV]ENV;[M]EFIY
   If !fstat
    I+=1
    #----TB protection----
    If I>dim([M]RECOND)
     #Tableau Plein
     Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
    Endif
    #--------------------
    [M]NIV(I)=2
    [M]ENV(I)=[F:ENV]ENV
    [M]FIY(I)=[F:ENF]FIYNUM
    [M]CUR(I)=[F:ENV]CURENV
    [M]AMT(I)=[F:ENF]AMTBUDFIY
    [M]RES(I)=[F:ENF]AMTRESFIY
    [M]RECOND(I)=1
    Raz [M]PRCREC(I)
    For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM
     REALISE+=[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP+[F:BUD]AMTREA
     I+=1
     #----TB protection----
     If I>dim([M]RECOND)
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 2
     Endif
     #--------------------
     [M]NIV(I)=3
     [M]ENV(I)=[F:ENV]ENV
     [M]FIY(I)=[F:BUD]FIY
     [M]ACC(I)=[F:BUD]ACC
     [M]CUR(I)=[F:ENV]CURENV
     [M]AMT(I)=[F:BUD]AMT
     [M]ACCNUM(I)=[F:BUD]ACCNUM
     [M]RECOND(I)=1
     Raz [M]PRCREC(I)
    Next
   Endif
   I+=1
   #----TB protection----
   If I>dim([M]RECOND)
    #Tableau Plein
    Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
   Endif
   #--------------------
  Endif
 Endif
Next
[M]NBLIG=I
Affzo [M]
If [M]NBLIG=0
 #Aucun enregistrement pour ces sélections
 Call MESSAGE(mess(104,199,1)) From GESECRAN
Else
 If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
 Gosub COLORIZE
Endif
End

Subprog CL_COCHER(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]RECOND(0)=1
  COCHE=2
 Else
  COCHE=1
 Endif
 For I=0 To [M]NBLIG-1
 [M]RECOND(I)=COCHE
 Next
 Affzo [M]
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Char SOCIETE(GLONCPY)
 SOCIETE=VALEUR
 Local Integer SOC
 SOC = find(SOCIETE,GSOC(1..GNBSOC))
 If !SOC
  # Société inexistante
  GMESSAGE=mess(16,104,1)
  mkstat=2 : End
 Endif
 #06/10/09-Dmd54223:Autorisation site
 Call CONTCPY(VALEUR) From CPTSUB
 # Paramètrage approbation
 Call SETGLBAPP(SOCIETE,GAPPNIV) From TRTGDD
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
 Local Decimal EXERCICE
 # Plan de compte
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECLED(SOCIETE,LEDTYPANA,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",CODLED,"") From CONTOBJ
 [M]COA=[F:LED]COA
 # Exercice
 Call GETEXE(VALEUR,LEDTYPANA,date$,EXERCICE) From CPTSUB
 Read [FIY]FIY0 = SOCIETE;LEDTYPANA;EXERCICE
 If !fstat & [F:FIY]FIYSTA=2
#  If [F:FIY]FIYSTA<>2
#   GMESSAGE="Exercice courant non ouvert pour cette société"
#   mkstat=2 : End
#  Endif
  [M]EFIY=EXERCICE
  [M]INTEFIY=[F:FIY]DES
  [M]DFIY=[F:FIY]FIYSTR
  [M]FFIY=[F:FIY]FIYEND
  Read [FIY2]FIY0 = SOCIETE;LEDTYPANA;EXERCICE+1
  If !fstat & [F:FIY2]FIYSTA<>3
#   If [F:FIY2]FIYSTA=3
#     #Exercice budgétaire récepteur fermé
#     GMESSAGE=mess(204,108,1)
#     mkstat=2
#   Else
    [M]RFIY=EXERCICE+1
    [M]INTRFIY=[F:FIY2]DES
    [M]DRFIY=[F:FIY2]FIYSTR
    [M]FRFIY=[F:FIY2]FIYEND
#   Endif
#  Else
#   # Il n'existe pas d'exercice recepteur pour cet exercice sur cette société et son référentiel analytique principal
#   GMESSAGE=mess(202,108,1)
#   mkstat=2 : End
  Endif
# Else
#  # Exercice inexistant pour cette société sur le référentiel analytique principal
#  GMESSAGE=mess(203,108,1)
#  mkstat=2 : End
 Endif
Endif
Affzo [M]
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Raz [M]NBLIG
Affzo [M]
End

Subprog C_EFIY(VALEUR)
Variable Decimal VALEUR
If [M]CPY<>""
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 # Plan de compte
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Read [FIY]FIY0 = [M]CPY;LEDTYPANA;VALEUR
 If !fstat
  If [F:FIY]FIYSTA=2
   [M]INTEFIY=[F:FIY]DES
   [M]DFIY=[F:FIY]FIYSTR
   [M]FFIY=[F:FIY]FIYEND
   Read [FIY2]FIY0 = [M]CPY;LEDTYPANA;VALEUR+1
   If !fstat
    If [F:FIY2]FIYSTA=3
     # Exercice budgétaire récepteur fermé
     GMESSAGE=mess(204,108,1)
     mkstat=2
    Else
     [M]RFIY=VALEUR+1
     [M]INTRFIY=[F:FIY2]DES
     [M]DRFIY=[F:FIY2]FIYSTR
     [M]FRFIY=[F:FIY2]FIYEND
    Endif
   Else
    # Il n'existe pas d'exercice recepteur pour cet exercice sur cette société et son référentiel analytique principal
    GMESSAGE=mess(202,108,1)
    mkstat=2 : End
   Endif
  Else
  # Exercice non ouvert
   GMESSAGE=mess(20,101,1)
   mkstat=2 : End
  Endif
 Else
  # Exercice inexistant pour cette société sur le référentiel analytique principal
  GMESSAGE=mess(203,108,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AM_EFIY(VALEUR)
Variable Decimal VALEUR
Raz [M]NBLIG
Affzo [M]
End

#-------------------------------- FCY ---------------------------------
Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M]FCYSTR,FCYEND
 Grizo [M]FCYSTR,FCYEND
Else
 Actzo [M]FCYSTR,FCYEND
Endif
End

Subprog AS_FCYSTR(VALEUR)
Variable Char    VALEUR()
If [M]ALLFCY=2
 Grizo [M]FCYSTR,FCYEND
 Affzo [M]FCYSTR,FCYEND
Endif
End

Subprog C_FCYSTR(VALEUR)
Variable Char    VALEUR()
If [M]ALLFCY=1
 If VALEUR=""
 #Zone Obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Else
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
  If [F:FCY]LEGCPY<>[M]CPY
   # Ce site est dans la société
   GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AS_FCYEND(VALEUR)
Variable Char    VALEUR()
If [M]ALLFCY=2
 Grizo [M]FCYSTR,FCYEND
 Affzo [M]FCYSTR,FCYEND
Endif
If VALEUR="" & [M]FCYSTR<>""
 VALEUR = [M]FCYSTR
 Affzo [M]FCYEND
Endif
End

Subprog C_FCYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 #Zone Obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2
 VALEUR = [M]FCYSTR
 Affzo [M]FCYSTR
 End
Else
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  # Ce site est dans la société
  GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
  mkstat = 2 : End
 Endif
Endif
End


