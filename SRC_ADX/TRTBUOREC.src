#-------------------------------- ENV ---------------------------------
Subprog C_ALLENV(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M]ENVSTR,ENVEND : Grizo [M]ENVSTR,ENVEND
Else
 Actzo [M]ENVSTR,ENVEND
Endif
End

Subprog AS_ENVSTR(VALEUR)
Variable Char    VALEUR()
If [M]ALLENV=2
 Grizo [M]ENVSTR,ENVEND
 Affzo [M]ENVSTR,ENVEND
Endif
End

Subprog C_ENVSTR(VALEUR)
Variable Char    VALEUR()
If [M]ENVEND<>"" & VALEUR=""
 #Zone Obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
Endif
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [F:ENV]FCY<>[M]CPY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CPY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    # L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
  If [F:ENV]DRECOND<>[0/0/0]
   # L'enveloppe a déjà été reconduite
   GMESSAGE=mess(241,108,1)
   mkstat=2 : End
  Endif
  Read [BUT]BUT0=[F:ENV]BUDTYP
  If !fstat & [F:BUT]YEAFLG<>1
   # Fonction réservée aux enveloppes annuelles
   GMESSAGE=mess(242,108,1)
   mkstat=2 : End
  Endif
 Endif
Endif
End

Subprog AS_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENVSTR<>""
 VALEUR = [M]ENVSTR
 Affzo [M]ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 #Zone Obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2
 VALEUR = [M]ENVSTR
 Affzo [M]ENVEND
 End
Else
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [F:ENV]FCY<>[M]CPY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CPY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    # L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
  If [F:ENV]DRECOND<>[0/0/0]
   # L'enveloppe a déjà été reconduite
   GMESSAGE=mess(241,108,1)
   mkstat=2 : End
  Endif
  Read [BUT]BUT0=[F:ENV]BUDTYP
  If !fstat & [F:BUT]YEAFLG<>1
   # Fonction réservée aux enveloppes annuelles
   GMESSAGE=mess(242,108,1)
   mkstat=2 : End
  Endif
 Endif
Endif
End

#-------------------------------- End ENV ---------------------------------

Subprog AM_RECOND(VALEUR)
Variable Integer VALEUR
For I=0 To [M]NBLIG-1
 If [M]ENV(I)=[M]ENV(nolign-1)
  [M]RECOND(I)=VALEUR
  If VALEUR<>2
   Raz [M]PRCREC(I)
  Endif
 Endif
Next
Affzo [M]
End

Subprog AS_PRCREC(VALEUR)
Variable Decimal VALEUR
If [M]NIV(nolign-1)<>1 | [M]RECOND(nolign-1)<>2
 mkstat=2
Endif
End

Subprog AM_PRCREC(VALEUR)
Variable Decimal VALEUR
If [M]NIV(nolign-1)=1
 For I=0 To [M]NBLIG-1
  If I<>(nolign-1) & [M]ENV(I)=[M]ENV(nolign-1)
   [M]PRCREC(I)=VALEUR
  Endif
 Next
 [M]PRCREC(nolign-1)=VALEUR
 Affzo [M]
Endif
End

Subprog C_PRCREC(VALEUR)
Variable Decimal VALEUR
If VALEUR<-100
 # Saisie d'un pourcentage négatif supérieur à 100 interdit
 GMESSAGE = mess(275,108,1)
 mkstat = 2 : End
Endif
End

