## Etiquettes Masque COA5
######################################################################################
Subprog C_ACCROO(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:COA5]ACCROO(0..[M:COA5]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
If vireblc(VALEUR,2)<>vireblc(format$([M]ACCFMT,VALEUR),2)
 # Format incorrect
 GMESSAGE = mess(149,100,1)
 mkstat=2 : End
Endif
End

Subprog AS_SCECODGEN(VALEUR)
Variable Char    VALEUR()
If [M:COA1]GENTRK<>2
 mkstat = 1 : End
Endif
End

Subprog C_SCECODGEN(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:COA1]ANATRK<>2
 GMESSAGE = mess(10,123,1) # Zone obligatoire
 mkstat = 2 : End
Endif
End

Subprog AS_SCECODANA(VALEUR)
Variable Char    VALEUR()
If [M:COA1]ANATRK<>2
 mkstat = 1 : End
Endif
End

Subprog C_SCECODANA(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:COA5]SCECODGEN(nolign-1) = ""
 GMESSAGE = mess(10,123,1) # Zone obligatoire
 mkstat = 2 : End
Endif
End

######################################################################################
## Etiquettes Masque COA6
######################################################################################
Subprog C_COADEN(VALEUR)
Variable Char    VALEUR()
# Valeur incorrecte
If [M:COA0]COA=VALEUR : Call ERREUR(mess(83,123,1)) From GESECRAN : mkstat=2 : Endif
End

Subprog AP_COADEN(VALEUR)
Variable Char    VALEUR()
Call LECTURE("COA",[M:COA0]COA,"") From CONTOBJ
End

Subprog AV_NUMPRE(VALEUR)
Variable Char    VALEUR()
Call LECTURE("COA",[M:COA0]COA,"") From CONTOBJ
# MHB 22/09/08 : il ne faut pas activer cette zone en import, sinon les traitements W0COA4
# et W0COA6 plantent sur l'affectation du [M:COA4]NUMPRE et [M:COA6]NUMPRE
If GIMPORT Then
  mkstat=2
Endif
End

Subprog AV_NUMSUI(VALEUR)
Variable Char    VALEUR()
# MHB 22/09/08 : il ne faut pas activer cette zone en import, sinon les traitements
# W0COA4 et W0COA6 plantent sur l'affectation du [M:COA4]NUMSUI et [M:COA6]NUMSUI
If GIMPORT Then
  mkstat=2
Endif
End

Subprog AV_EXECUTE(VALEUR)
Variable Char    VALEUR()
# MHB 22/09/08 : il ne faut pas activer cette zone en import, sinon les traitements
# W0COA4 et W0COA6 plantent sur l'affectation du [M:COA4]EXECUTE et [M:COA6]EXECUTE
If GIMPORT Then
  mkstat=2
Endif
End


######################################################################################
## Etiquettes Masque COA7
######################################################################################
Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
Local Integer I
For I=0 To [M]NBLIG-1
 If nolign<>I+1 & [M]ACCSTR(I)=[M]ACCSTR(nolign-1) & [M]DIE(I)=VALEUR
  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
  mkstat = 2 : Break
 Endif
Next I
End

######################################################################################
## Etiquettes Masque COA8
######################################################################################
Subprog C_ACCDEB(VALEUR)
Variable Char    VALEUR()
Call CTRL_ACC(VALEUR)
End

Subprog C_ACCCDT(VALEUR)
Variable Char    VALEUR()
Call CTRL_ACC(VALEUR)
End

Subprog CTRL_ACC(ACC)
Value Char ACC()
Local Char RACINE(GLONGAC)

If [M:COA1]FXDLEN=2
 RACINE = left$([L]ACC,len([L]ACC)-1)
 If vireblc([L]RACINE,2)<>vireblc(format$([M]ACCFMT,[L]RACINE),2)
  # Format incorrect
  GMESSAGE = mess(149,100,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AV_INTITDEB(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA(VALEUR,"GACCOUNT","DESTRA",[M:COA0]COA,[M:COA8]ACCDEB(nolign-1)) From ATEXTRA
End

Subprog AV_INTITCDT(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA(VALEUR,"GACCOUNT","DESTRA",[M:COA0]COA,[M:COA8]ACCCDT(nolign-1)) From ATEXTRA
End


