#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("COA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "RAZDUP"     : Gosub RAZDUP
 When "LIENS"      : Gosub LIENS
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "ANNULE"     : Gosub ANNULE
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "ABANDON"    : Gosub ABANDON
 When "RAZCRE"     : Gosub RAZCRE
 When "FERME"      : Gosub FERME
 When Default
Endcase
Return

$OUVRE
If clalev([F:GAC]) = 0  : Local File  GACCOUNT  [GAC]  : Endif
#DIRAS - 14/12/2016 - JIRA X3-11755 - START
#If clalev([F:JOU]) = 0  : Local File  GJOURNAL  [JOU]  : Endif
#If clalev([F:JCO]) = 0  : Local File  GJOUCOA   [JCO]  : Endif
If GMODU(2)=2 : If clalev([F:JOU]) = 0  : Local File  GJOURNAL  [JOU]  : Endif : Endif
If GMODU(2)=2 : If clalev([F:JCO]) = 0  : Local File  GJOUCOA   [JCO]  : Endif : Endif
#DIRAS - 14/12/2016 - JIRA X3-11755 - END
If clalev([F:TCK]) = 0  : Local File  TABACCLIK [TCK]  : Endif
If clalev([F:PBS]) = 0  : Local File  GAPARBSE  [PBS]  : Endif
If clalev([F:GT2]) = 0  : Local File  GTABACC2  [GT2]  : Endif
If clalev([F:GCF]) = 0  : Local File  GACCDEF   [GCF]  : Endif
If clalev([F:GCD]) = 0  : Local File  GACCDIM   [GCD]  : Endif
If clalev([F:CO2]) = 0  : Local File  GCOA      [CO2]  : Endif
If clalev([F:CLS]) = 0  : Local File  GACCCLS   [CLS]  : Endif
If clalev([F:GYM]) = 0  : Local File  GACCPYM   [GYM]  : Endif
If clalev([F:GCM]) = 0  : Local File  GACM      [GCM]  : Endif
If clalev([F:LED]) = 0  : Local File  GLED      [LED]  : Endif
If filinfo(filpath("FIL","GACCAUZ","fde",0),0)>=0
 If clalev([F:GCA])  = 0 : Local File GACCAUZ   [GCA] : Endif
 Local Integer NBCOA
 If nbrecord([CO2])>0
  Local Char TABCOA(GLONCOA)(1..nbrecord([CO2]))
  Call COADEM(TABCOA,NBCOA) From CPTDIV
 Endif
Endif

Local Integer I, ONUM, FLMOD
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$SETBOUT
## Suppression du bouton supprimer si des comptes existent sur le plan de compte.
Filter [GAC] Where [F:GAC]COA = [M:COA0]COA
Look [GAC]GAC0 First
Filter [GAC]
If !fstat
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif

# Si en cours de modification, les bouton "EXCUTE"  liée à l'onglet plan de compte et axe par défaut doivent être grisés.
If GREP<>""
 Grizo [M:COA6]EXECUTE
 Grizo [M:COA7]EXECUTE
Else
 Actzo [M:COA6]EXECUTE
 If [M:COA1]ANATRK=2
  Actzo [M:COA7]EXECUTE
 Endif
Endif

If dim([M:COA8]ACCDEB)>0
 If dim(TABCOA)>0 and !find([M:COA0]COA,TABCOA(1..NBCOA))
  Effzo [M:COA8] : Grizo [M:COA8]
 Else
  Actzo [M:COA8]
 Endif
Endif
Return

$VERIF_MOD
# Lecture du COA, modifié si définition des comptes par défaut (classe COA utilisé)
If [M:COA0]COA <> [F:COA]COA
 Read [COA]COA0 = [M:COA0]COA
Endif

## Vérification de conformité des comptes au nouveau format
If [M:COA1]ACCFMT<>[F:COA]ACCFMT
 Filter [GAC] Where COA=[M:COA0]COA
 For [GAC]GAC0 Where COA=[M:COA0]COA
  If vireblc([F:GAC]ACC,2)<>vireblc(format$([M:COA1]ACCFMT,[F:GAC]ACC),2)
   # Les comptes existants sont incompatibles avec le nouveau format
   GMESSAGE = mess(80,104,1)-"("+[F:GAC]ACC+")"
   OK = 0 : Break
  Endif
 Next
 Filter [GAC]
Endif

# On ne peut pas changer certaines informations d'un code plan lié à un référentiel étant un "Référentiel Générale principale"
FLMOD = 0
If [M:COA1]GENTRK<>[F:COA]GENTRK & [M:COA1]GENTRK<>2
 FLMOD = 1
Elsif [M:COA1]AUX<>[F:COA]AUX & [M:COA1]AUX<>2
 FLMOD = 2
Elsif [M:COA1]TAXMGT<>[F:COA]TAXMGT & [M:COA1]TAXMGT<>2
 FLMOD = 3
Endif
If FLMOD
 OK = 1
 For [LED]
  If [F:LED]COA=[F:COA]COA
   For [GCM]
    If [F:GCM]LED([F:GCM]GENLEDTYP-1)=[F:LED]LED
     Case num$(FLMOD)
      When "1" :
       # Changement "Suivi Général" impossible
       OK = 0 : GMESSAGE = mess(194,105,1)
      When "2" :
       # Changement "Auxiliarisation"  impossible
       OK = 0 : GMESSAGE = mess(195,105,1)
      When "3" :
       # Changement "Gestion des taxes" impossible
       OK = 0 : GMESSAGE = mess(196,105,1)
     Endcase
     If !OK : Break 2 : Endif
    Endif
   Next
  Endif
 Next
 If !OK : Return : Endif
Endif

# On ne peut pas changer certaines informations d'un code plan lié au référentiel étant un "Référentiel Analytique principale"
FLMOD = 0
If [M:COA1]ANATRK<>[F:COA]ANATRK & [M:COA1]ANATRK<>2
 OK = 1
 For [LED]
  If [F:LED]COA=[F:COA]COA
   For [GCM]
    If [F:GCM]LED([F:GCM]ANALEDTYP-1)=[F:LED]LED
     # Changement "Suivi analytique" impossible
     OK = 0 : GMESSAGE = mess(197,105,1) : Break 2
    Endif
   Next
  Endif
 Next
 If !OK : Return : Endif
Endif
Return

$INICRE
$INIMOD
If dim([F:COA]DES)>0
 [F:COA]DES = [M:COA0]DESTRA
Endif
If func AFNC.ACTIV("LEG")=0
 [F:COA]LEG    = GDOSLEG(1)
 [F:COA]LEGCLS = GDOSLEG(1)
 [M]LEGCLSINV = [F:COA]LEGCLS
Endif
Return


$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
## Pour tous les journaux existants, création des enregistrements dans GAJOUCOA (Journaux/plan de compte)
##  Création sans tenir compte du Type de journal (ML613)
#DIRAS - 14/12/2016 - JIRA X3-11755 - START
If GMODU(2)=2
#DIRAS - 14/12/2016 - JIRA X3-11755 - END
  For [JOU]JOU0
   [F:JCO]JOU  =  [F:JOU]JOU
   [F:JCO]LEG  =  [F:JOU]LEG
   [F:JCO]COA  =  [M]COA
   Write [JCO]
   If fstat
    GOK = 0 : Call FSTA("JCO") From GLOCK : Break
   Endif
  Next
#DIRAS - 14/12/2016 - JIRA X3-11755 - START
Endif
#DIRAS - 14/12/2016 - JIRA X3-11755 - END

If GOK<1 : Return : Endif
Gosub CREATION2
If GOK<1 : Return : Endif
Gosub CREATION3
If GOK<1 : Return : Endif
Gosub CREATION5
If GOK<1 : Return : Endif
Gosub CREATION6
If GOK<1 : Return : Endif
Gosub CREATION7
If GOK<1 : Return : Endif
Gosub CREATION8
If GOK<1 : Return : Endif
Return

$CREATION2
Gosub MAJ_TEXTE
## Gestion des enregistrements dans TABACCLIK (Comptes de liaisons)
For nolign=1 To [M:COA3]NBLIG
 Raz [F:TCK]
 [F:TCK]COA    = [M:COA0]COA
 [F:TCK]       = [M:COA3]
 Write [TCK]
 If fstat
  GOK = 0 : Call FSTA("TCK") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
Return

$CREATION3
## Gestion des enregistrements dans GAPARBSE (Codes reporting par défaut)
For nolign=1 To [M:COA4]NBLIG
 [F:PBS]COA    = [M:COA0]COA
 [F:PBS]NUMCOD = [M:COA4]NUM
 [F:PBS]ACCSTR = [M:COA4]ACCSTR(nolign-1)
 [F:PBS]CODCDT = [M:COA4]CODCDT(nolign-1)
 [F:PBS]CODDEB = [M:COA4]CODDEB(nolign-1)
 Write [PBS]
 If fstat
  GOK = 0 : Call FSTA("PBS") From GLOCK : Break
 Endif
Next
Actzo [M:COA4]NUMPRE, NUMSUI
If GOK<1 : Return : Endif
Return

$CREATION5
#Gestion des enregistrements dans GTABACC2
For nolign=1 To [M:COA5]NBLIG
 [F:GT2]UPDUSR    = GUSER
 [F:GT2]UPDDAT    = date$
 [F:GT2]COA       = [M:COA0]COA
 [F:GT2]ACCROO    = [M:COA5]ACCROO(nolign-1)
 [F:GT2]SCECODGEN = [M:COA5]SCECODGEN(nolign-1)
 [F:GT2]SCECODANA = [M:COA5]SCECODANA(nolign-1)
 Write [GT2]
 If fstat
  GOK = 0 : Call FSTA("GT2") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
Return

$CREATION6
[F:GCF]COAORI  = [M:COA0]COA
[F:GCF]COADEN  = [M:COA6]COADEN
For N=0 To [M:COA6]NBLIG-1
 [F:GCF]COASTR = [M:COA6]ACCSTR(N)
 [F:GCF]ACC    = [M:COA6]ACC(N)
 Write [F:GCF]
 If fstat
  GOK = 0 : Call FSTA("GCF") From GLOCK : Break
 Endif
Next
Return

$CREATION7
For nolign=1 To [M:COA7]NBLIG
 [F:GCD]    = [M:COA7]
 [F:GCD]COA = [M:COA0]COA
 [F:GCD]LIN = nolign
 Write [F:GCD]
 If fstat
  GOK = 0 : Call FSTA("GCD") From GLOCK : Break
 Endif
Next nolign
Return

$CREATION8
## Gestion des enregistrements dans GACCAUZ (Comptes comptatibles)
If dim([M:COA8]ACCDEB)<1 : Return : Endif
For nolign=1 To [M:COA8]NBLIG
 [F:GCA]COA    = [M:COA0]COA
 [F:GCA]ACCDEB = [M:COA8]ACCDEB(nolign-1)
 [F:GCA]ACCCDT = [M:COA8]ACCCDT(nolign-1)
 Write [GCA]
 If fstat
  GOK = 0 : Call FSTA("GCA") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
Return

$RAZDUP
Raz [M:COA2] : Affzo [M:COA2]
Raz [M:COA3] : Affzo [M:COA3]
Raz [M:COA6] : Affzo [M:COA6]
If dim([M:COA8]ACCDEB)>0 : Raz [M:COA8] : Affzo [M:COA8] : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Delete [TCK] Where COA = [M:COA0]COA
If fstat
 GOK = 0 : Call FSTA("TCK") From GLOCK : Return
Endif
Delete [PBS] Where COA = [M:COA0]COA and NUMCOD=[M:COA4]NUM
If fstat
 GOK = 0 : Call FSTA("PBS") From GLOCK : Return
Endif
Delete [GT2] Where COA = [M:COA0]COA
If fstat
 GOK = 0 : Call FSTA("PBS") From GLOCK : Return
Endif
Delete [GCF] Where COAORI=[M:COA0]COA and COADEN=[M:COA6]COADEN
If fstat
 GOK = 0 : Call FSTA("GCF") From GLOCK : Return
Endif
Delete [GCD] Where COA=[M:COA0]COA
If fstat
 GOK = 0 : Call FSTA("GCD") From GLOCK : Return
Endif
If clalev([F:GCA])
 Delete [GCA] Where COA=[M:COA0]COA
 If fstat
  GOK = 0 : Call FSTA("GCA") From GLOCK : Return
 Endif
Endif
Grizo [M:COA4]NUMPRE, NUMSUI
Gosub CREATION2
Gosub CREATION3
Gosub CREATION5
Gosub CREATION6
Gosub CREATION7
Gosub CREATION8
Return

$APRES_CRE
Call GLOBVAR From SETGLBCOA
Gosub RELIT From GOBJSUB
Return

$APRES_MOD
Call GLOBVAR From SETGLBCOA
Gosub RELIT From GOBJSUB
Return

$AP_CHANGE
Call GLOBVAR From SETGLBCOA
Read [F:COA]COA0 = NCODE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GCOA","DESTRA",[M:COA0]COA,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("GCOA","SHOTRA",[M:COA0]COA,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("GCOA","COLHEA",[M:COA0]COA,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GCOA","DESTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GCOA","SHOTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GCOA","COLHEA",OCODE,"",NCODE,"") From ATEXTRA


#chgmt de cle PLAN COMPTE alors MAJ des textes traduisibles pour les comptes associé à nouveau PLAN COMPTE
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Filter [GAC] Where COA=NCODE
For [GAC]
 Call CHGTEXTRA("GACCOUNT","DESTRA",OCODE,[F:GAC]ACC,NCODE,[F:GAC]ACC) From ATEXTRA
 Call CHGTEXTRA("GACCOUNT","SHOTRA",OCODE,[F:GAC]ACC,NCODE,[F:GAC]ACC) From ATEXTRA
Next
Filter [GAC]
Return

$AP_ANNULE
Call GLOBVAR From SETGLBCOA
Call SUPTEXTRA ("GCOA","COLHEA",[M:COA0]COA,"") From ATEXTRA
Return

$ABANDON
Actzo [M:COA4]NUMPRE, NUMSUI
Return

$MAJ_TEXTE
Call MAJTEXTRA ([M:COA1]COLHEA,"GCOA","COLHEA",[M:COA0]COA,"") From ATEXTRA
Return

$LIENS
Call LECTEXTRA([M:COA0]DESTRA,"GCOA","DESTRA",[M:COA0]COA,"") From ATEXTRA
Call LECTEXTRA([M:COA1]SHOTRA,"GCOA","SHOTRA",[M:COA0]COA,"") From ATEXTRA
GCURLEG = [F:COA]LEG
If dim([M:COA1]LEG)>0
 If [M:COA1]LEG<>""
  Grizo [M:COA1]LEGCLS
 Else
  Actzo [M:COA1]LEGCLS
 Endif
Endif
[M:COA1]LEGCLSINV = [F:COA]LEGCLS
Gosub TABACCMIS
Gosub TABACCLIK
Gosub TABSCECOD
## Chargement code reporting
If [M:COA4]NUM<1 : [M:COA4]NUM=1 : Endif
Filter [PBS] Where [F:PBS]COA = [M:COA0]COA and [F:PBS]NUMCOD = [M:COA4]NUM
Gosub TABRPTCOD
Call LECTEXTRA([M:COA1]COLHEA,"GCOA","COLHEA",[M:COA0]COA,"") From ATEXTRA
Read [GCF]GCF0=[M:COA0]COA
Gosub LIENS6
Gosub LIENS7
Gosub LIENS8
Raz [M:COA1]CLSNAM
For I=0 To [F:COA]PFXNBR-1
 Call LECTEXTRA([M:COA1]CLSNAM(I),"GACCCLS","DESTRA",[F:COA]LEGCLS,[F:COA]CLSCOD(I)) From ATEXTRA
Next I
Return

$LIENS6
Raz [M:COA6]COADEN
If fstat=0
 [M:COA6]COADEN = [F:GCF]COADEN
Else
 Filter [COA] Where [COA]COA<>[M:COA0]COA & ([COA]LEG=GCURLEG | [COA]LEG="")
 Read [COA] First
 If !fstat
  [M:COA6]COADEN = [F:COA]COA
 Endif
 Filter [COA]
Endif
Gosub CHARGE6
Return

$CHARGE6
Raz [M:COA6]NBLIG, NUMLIG, ACCSTR, ACC
For [GCF] Where COAORI=[M:COA0]COA and COADEN=[M:COA6]COADEN
 [M:COA6]ACCSTR([M:COA6]NBLIG) = [F:GCF]COASTR
 [M:COA6]ACC([M:COA6]NBLIG) = [F:GCF]ACC
 [M:COA6]NBLIG+=1
Next
Affzo [M:COA6]
Return

$LIENS7
nolign = 0
If [F:COA]ANATRK<>2
 Effzo [M:COA7] : Grizo [M:COA7]
Else
 Actzo [M:COA7]
 For [GCD]GCD0 Where COA=[M:COA0]COA
  nolign += 1
  [M:COA7] = [F:GCD]
 Next
Endif
[M:COA7]NBLIG = nolign
Return

$TABACCMIS
## Chargement du tableau des comptes divers
[M]NBRLIG=len(mess(0,2649,1))
For I=0 To [M]NBRLIG-1
 If [F:COA]ACCMIS(I)<>""
  [M]ACCMIS(I) = [F:COA]ACCMIS(I)
 Endif
Next I
Affzo [M:COA2]NBRLIG, ACCDES, ACCMIS
Return

$TABACCLIK
## Chargement du tableau des comptes de liaisons
Filter [TCK] Where [F:TCK]COA = [M:COA0]COA
[M:COA3]NBLIG = rowcount([TCK])
I=0
For [TCK]TCK0
 [M:COA3]FCY1(I) = [F:TCK]FCY1
 [M:COA3]FCY2(I) = [F:TCK]FCY2
 [M:COA3]SAC(I)  = [F:TCK]SAC
 [M:COA3]ACC(I)  = [F:TCK]ACC
 [M:COA3]BPR(I)  = [F:TCK]BPR
 [M]COMBI(I)     = [F:TCK]FCY1+[F:TCK]FCY2
 I+=1
Next
Filter [TCK]
Affzo [M:COA3]
Return

$TABSCECOD
#Chargement du tableau des codes écran par racine de code
Filter [GT2] Where [F:GT2]COA = [M:COA0]COA
[M:COA5]NBLIG = rowcount([GT2])
I=0
For [GT2]GT20
 [M:COA5]ACCROO(I)    = [F:GT2]ACCROO
 [M:COA5]SCECODGEN(I) = [F:GT2]SCECODGEN
 [M:COA5]SCECODANA(I) = [F:GT2]SCECODANA
 I+=1
Next
Filter [GT2]
Affzo [M:COA5]
Return

$LIENS8
## Chargement du tableau des comptes compatibles
If clalev([F:GCA])=0 : Return : Endif
If dim([M:COA8]ACCDEB)<=0 : Return : Endif
Filter [GCA] Where [F:GCA]COA = [M:COA0]COA
[M:COA8]NBLIG = rowcount([GCA])
I=0
For [GCA]GCA0
 [M:COA8]ACCDEB(I) = [F:GCA]ACCDEB
 [M:COA8]ACCCDT(I) = [F:GCA]ACCCDT
 I+=1
Next
Filter [GCA]
Affzo [M:COA8]
Return

$PRECEDENT
ONUM = [M:COA4]NUM
Raz [M:COA4]
[M:COA4]NUM = ONUM-1
If [M:COA4]NUM<=0 : [M:COA4]NUM=1 : End : Endif
Filter [PBS] Where [F:PBS]COA=[M:COA0]COA and [F:PBS]NUMCOD=[M:COA4]NUM
Gosub TABRPTCOD
Return

$SUIVANT
ONUM = [M:COA4]NUM
Raz [M:COA4]NBLIG, ACCSTR, CODDEB, CODCDT
[M:COA4]NUM = ONUM+1
If [M:COA4]NUM>=11 : [M:COA4]NUM=10 : End : Endif
Filter [PBS] Where [F:PBS]COA=[M:COA0]COA and [F:PBS]NUMCOD=[M:COA4]NUM
Gosub TABRPTCOD
Return

$PRECEDENT6
Filter [CO2] Where LEG=GCURLEG | LEG=""
Read [CO2]COA0<[M:COA6]COADEN
Filter [CO2]
If fstat=0
 If [CO2]COA<>[M:COA0]COA
  [M:COA6]COADEN=[CO2]COA
 Else
  Filter [CO2] Where LEG=GCURLEG | LEG=""
  Read [CO2]COA0<[M:COA0]COA
  Filter [CO2]
  If fstat=0
   [M:COA6]COADEN=[CO2]COA
  Endif
 Endif
Endif
Gosub CHARGE6
Affzo [M:COA6]
Return

$SUIVANT6
Filter [CO2] Where LEG=GCURLEG | LEG=""
Read [CO2]COA0>[M:COA6]COADEN
Filter [CO2]
If fstat=0
 If [CO2]COA<>[M:COA0]COA
  [M:COA6]COADEN=[CO2]COA
 Else
  Filter [CO2] Where LEG=GCURLEG | LEG=""
  Read [CO2]COA0>[M:COA0]COA
  Filter [CO2]
  If fstat=0
   [M:COA6]COADEN=[CO2]COA
  Endif
 Endif
Endif
Gosub CHARGE6
Affzo [M:COA6]
Return


$TABRPTCOD
## Chargement du tableau des codes reporting
[M:COA4]NBLIG=rowcount([PBS])
I=0
For [PBS]PBS0
 [M:COA4]ACCSTR(I) = [F:PBS]ACCSTR
 [M:COA4]CODCDT(I) = [F:PBS]CODCDT
 [M:COA4]CODDEB(I) = [F:PBS]CODDEB
 I+=1
Next
Filter [PBS]
Affzo [M:COA4]
Return

$RAZCRE
# Création en mono leg , il faut initialiser les différents champs liés à la législation
# du dossier
#LIPET - 2017-06-02 - X3-43463 - START
#If func AFNC.ACTIV("LEG")=0
# [F:COA]LEG    = GDOSLEG(1)
# [F:COA]LEGCLS = GDOSLEG(1)
# [M]LEGCLSINV = [F:COA]LEGCLS
# [V]GCURLEG   = GDOSLEG(1)
#Endif
Raz GCURLEG
#LIPET - 2017-06-02 - X3-43463 - END
Gosub TABACCMIS
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles
 Call DUPTEXTRA("GCOA","DESTRA",CLECUR1,"","GCOA","DESTRA",[M:COA0]COA,"")  From ATEXTRA
 Call DUPTEXTRA("GCOA","SHOTRA",CLECUR1,"","GCOA","SHOTRA",[M:COA0]COA,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:COA0]DESTRA,"GCOA","DESTRA",[M:COA0]COA,"") From ATEXTRA
Call MAJTEXTRA([M:COA1]SHOTRA,"GCOA","SHOTRA",[M:COA0]COA,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GCOA","DESTRA",[M:COA0]COA,"") From ATEXTRA
Call SUPTEXTRA("GCOA","SHOTRA",[M:COA0]COA,"") From ATEXTRA
Return

####################################################################
#  Etiquettes des masques COA0/COA1/COA2/COA3/COA4/COA5/COA8
####################################################################
######################################################################################
## Etiquettes Masque COA1
######################################################################################

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG= VALEUR
End

Subprog C_GENTRK(VALEUR)
Variable Integer VALEUR
# Pour un référentiel, "Général" ou/et "Analytique" doit être flagué
If [M]GENTRK<>VALEUR & VALEUR<>2 : [M]ANATRK=2 : Affzo [M]ANATRK : Endif
End

Subprog C_ANATRK(VALEUR)
Variable Integer VALEUR
# Pour un référentiel, "Général" ou/et "Analytique" doit être flagué
If [M]ANATRK<>VALEUR & VALEUR<>2 : [M]GENTRK=2 : Affzo [M]GENTRK : Endif
End

Subprog AM_ANATRK(VALEUR)
Variable Integer VALEUR
# si le plan de compte n'est pas suivi en analytique, l'onglet "Axes par défaut" est grisé.
If VALEUR<>2
 Effzo [M:COA7] : Grizo [M:COA7]
Else
 Actzo [M:COA7]
Endif
End

Subprog C_AUX(VALEUR)
Variable Integer VALEUR
If VALEUR=1 & [M]AUX=2
 If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
 Filter [GAC] Where COA=[M]COA & SAC=2
 Read [GAC] First
 Filter [GAC]
 If fstat<=2
  ## Il existe des comptes collectifs
  GMESSAGE = mess(148,102,1)-"("+[F:GAC]ACC+")"
  mkstat = 2
 Endif
Endif
End

Subprog D_TAXMGT(VALEUR)
Variable Integer VALEUR
If [M:COA1]GENTRK=2
 VALEUR=2
Else
 VALEUR=1
Endif
End

Subprog AS_TAXMGT(VALEUR)
Variable Integer VALEUR
If [M:COA1]GENTRK<>2
 VALEUR = 1
 mkstat =2 : End
Endif
End

Subprog C_ACCLEN(VALEUR)
Variable Decimal VALEUR
# 59829
#If VALEUR>GLONGAC or VALEUR<2 & [M]FXDLEN=2
# # Valeur incorrecte
# GMESSAGE = mess(83,123,1)
# mkstat=2 : End
#Endif

#If VALEUR<>[M:COA1]ACCLEN
# Call GLOBVAR From SETGLBCOA
#Endif
End

Subprog AV_ACCLEN(VALEUR)
Variable Decimal VALEUR
End

Subprog AS_ACCFMT(VALEUR)
Variable Char    VALEUR()
#KC 59829
#If [M]FXDLEN=1
# Diszo ACCLEN
#Else
# Actzo ACCLEN
#Endif
#If VALEUR=""  & [M]ACCLEN>0
# VALEUR = num$([M]ACCLEN)+"#"
#Endif
End

Subprog C_ACCFMT(VALEUR)
Variable Char    VALEUR()
## Sous programme récupérer de C_FORTYP From SUBATY
Call C_FORMAT(VALEUR) From SUBDIE
If mkstat : End : Endif
If [M]FXDLEN=2
 If format$("K:"+VALEUR,string$([M]ACCLEN,"0"))<>string$([M]ACCLEN,"0")
  # Le format doit accepter les Zéros
  GMESSAGE = mess(92,102,1)
  mkstat = 2 : End
 Endif
Endif
If [M:COA1]ACCLEN>GLONGAC or [M:COA1]ACCLEN<2 & [M]FXDLEN=2
 # Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat=2 : End
Endif
GFMTACC = VALEUR
End

Subprog C_PFXNBR
If adxgtb=2  :# Sortie du tableau
 Sorta [M:COA1]PFXNBR [M:COA1]PFXNBR  Order By [M:COA1]PFX(indice)
 Affzo [M:COA1]25
Endif
End

Subprog C_PFX(VALEUR)
Variable Char VALEUR()
Call UNICITE(VALEUR,[M]PFX) From OBJDIV
If mkstat : End : Endif
If vireblc(VALEUR,2)<>vireblc(format$([M]ACCFMT,VALEUR),2)
 # Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
If dim([M]LEGCLS)>0
 If VALEUR=""
  Actzo LEGCLS
 Else
  If VALEUR<>[M]LEGCLS
   Effzo 25
  Endif
  [M]LEGCLS = VALEUR
  [M]LEGCLSINV = VALEUR
  Affzo LEGCLS,ZLEGCLS
  Grizo LEGCLS
 Endif
Endif
End

Subprog AS_LEGCLS(VALEUR)
Variable Char    VALEUR()
If dim([M]LEG)>0 & [M]LEG<>""
 VALEUR = [M]LEG
 mkstat = 2 : End
Endif
End

Subprog AM_LEGCLS(VALEUR)
Variable Char    VALEUR()
Effzo 25 : # Raz tableau des classes de compte
[M:COA1]LEGCLSINV = VALEUR
End

Subprog C_PYR(VALEUR)
Variable Char    VALEUR()
Gosub CONTROLE_PYR
End

Subprog C_PYRREF(VALEUR)
Variable Char    VALEUR()
Gosub CONTROLE_PYR
End

Subprog C_FXDLEN(VALEUR)
Variable Integer VALEUR
#KC 59829 si pas de longueur fixe alors grisé ACCLEN
#If VALEUR=1
# Diszo [M]ACCLEN
#Else
# Actzo [M]ACCLEN
#Endif
End

$CONTROLE_PYR
If VALEUR<>""
 Call LECTURE("GYM",VALEUR,"") From CONTOBJ
 If [F:GYM]COA<>[M:COA0]COA
  GMESSAGE = mess(185,105,1)-"("+[F:GYM]COA+")" : # Plan comptable incompatible
  mkstat = 2
  End
 Endif
Endif
Return

######################################################################################
## Etiquettes Masque COA2
######################################################################################
Subprog C_ACCMIS(VALEUR)
Variable Char    VALEUR()
# Les comptes doivent exister sauf pour le compte d'attente conso
If nolign<>1 & VALEUR<>""
 Call CONTROLE("GAC","G",VALEUR,[M:COA0]COA,mkstat) From CONTOBJ
Endif
End

######################################################################################
## Etiquettes Masque COA3
######################################################################################
Subprog C_FCY1(VALEUR)
Variable Char VALEUR()
If !GIMPORT & VALEUR = "" & nolign<>1
 GMESSAGE = mess(10,123,1) # Zone obligatoire
 mkstat = 2 : End
Endif
If VALEUR<>""
 Call CTLLEDCOA(VALEUR)
Endif
End

Subprog AS_FCY2(VALEUR)
Variable Char    VALEUR()
If [M]FCY1(nolign-1)="" : mkstat=2 : Endif
End

Subprog C_FCY2(VALEUR)
Variable Char VALEUR()
If clalev([FCY]) = 0 : Local File FACILITY [FCY] : Endif
If VALEUR=[M]FCY1(nolign-1)
 # Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
## Vérif que les 2 sites indiqués sont dans la même société
Local Char SOCSITE2
Read [FCY]FCY0 = VALEUR
If !fstat
 SOCSITE2 = [F:FCY]LEGCPY
 If [M:COA3]FCY1(nolign-1)<>""
  Read [FCY]FCY0 = [M:COA3]FCY1(nolign-1)
  If !fstat & [F:FCY]LEGCPY<>SOCSITE2
   # Ce site est dans la société
   GMESSAGE = mess(30,106,1)-SOCSITE2
   mkstat = 2 : End
  Endif
 Endif
Endif
[M]COMBI(nolign-1) = [M]FCY1(nolign-1)+VALEUR
Call UNICITE([M]COMBI(nolign-1),[M]COMBI) From OBJDIV
If mkstat : End : Endif
Call UNICITE(VALEUR+[M]FCY1(nolign-1),[M]COMBI) From OBJDIV
If mkstat : End  : Endif
End

Subprog CTLLEDCOA(VALEUR)
Variable Char VALEUR()
Local Integer K
K = 0
If clalev([CPY]) = 0 : Local File COMPANY  [CPY] : Endif
If clalev([FCY]) = 0 : Local File FACILITY [FCY] : Endif
If clalev([GCM]) = 0 : Local File GACM     [GCM] : Endif
If clalev([LED]) = 0 : Local File GLED     [LED] : Endif
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Read [F:CPY]CPY0 = [F:FCY]LEGCPY
Read [F:GCM]GCM0 = [F:CPY]ACM
For I=0 To len(mess(0,2644,1))-1
 Read [LED]LED0 = [F:GCM]LED(I)
 If [F:LED]COA=[M:COA0]COA : K+=1 : Endif
Next
If !K
 # Site du société n'alimentant pas
 GMESSAGE = mess(90,104,1)-[M:COA0]COA
 mkstat = 2 : End
Endif
End

Subprog AS_SAC(VALEUR)
Variable Char VALEUR()
#mkstat = 1
End

Subprog C_SAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If [F:GAC]AUZBPR(5)<>2
  GMESSAGE = mess(51,102,1) : # Collectif incorrect
  mkstat = 2 : End
 Else
  [M:COA3]ACC(nolign-1) = [F:GAC]ACC
  Affzo [M:COA3]ACC
 Endif
Endif
End

Subprog C_ACC(VALEUR)
Variable Char VALEUR()
Call LECTURE("GAC",VALEUR,[M:COA0]COA) From CONTOBJ
Call VERIF([F:GAC]FCY,[M]FCY1(nolign-1),VALEUR) From CFYSUB
If mkstat : End : Endif
Call VERIF([F:GAC]FCY,[M]FCY2(nolign-1),VALEUR) From CFYSUB
If mkstat : End : Endif
End

Subprog AM_ACC(VALEUR)
Variable Char    VALEUR()
## Affichage du code d'appel si le compte est de type collectif
Read [GAC]GAC0 = [M:COA0]COA;VALEUR
If !fstat & [F:GAC]SAC = 2
 [M:COA3]SAC(nolign-1) = [F:GAC]ACCSHO
Else
 [M:COA3]SAC(nolign-1) = ""
Endif
Affzo [M:COA3]SAC
End

Subprog AS_BPR(VALEUR)
Variable Char VALEUR()
If [M]SAC(nolign-1) = "" : mkstat = 1 : End : Endif
End


######################################################################################
## Etiquettes Masque COA4
######################################################################################
Subprog AS_ACCSTR(VALEUR)
Variable Char     VALEUR
End

Subprog C_ACCSTR(VALEUR)
Variable Char     VALEUR
If maskcou="COA4"
 Call UNICITE(VALEUR,[M:COA4]ACCSTR(0..[M:COA4]NBLIG-1)) From OBJDIV
 If mkstat : End : Endif
Elsif maskcou="COA6"
 Call UNICITE(VALEUR,[M:COA6]ACCSTR(0..[M:COA6]NBLIG-1)) From OBJDIV
 If mkstat : End : Endif
Endif
If [M:COA1]FXDLEN=2 & VALEUR<>"*"
 If vireblc(VALEUR,2)<>vireblc(format$([M]ACCFMT,VALEUR),2)
  # Format incorrect
  GMESSAGE = mess(149,100,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog D_CODCDT(VALEUR)
Variable Char     VALEUR
If VALEUR=""
 VALEUR = [M:COA4]CODDEB(nolign-1)
Endif
End

Subprog CL_NUMPRE(VALEUR)
Variable Char    VALEUR()
If maskcou="COA4"
 Gosub PRECEDENT
Elsif maskcou="COA6"
 Gosub PRECEDENT6
Endif
End

Subprog CL_NUMSUI(VALEUR)
Variable Char    VALEUR()
If maskcou="COA4"
 Gosub SUIVANT
Elsif maskcou="COA6"
 Gosub SUIVANT6
Endif
End

Subprog D_CODDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M:COA4]CODCDT(nolign-1)
Endif
End


