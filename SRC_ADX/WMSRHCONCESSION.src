# Supervisor
#WMSRHCONCESSION CONCESSION
# 2018-11-06 07:04:17 811

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","CONCESSION","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File CONCESSION [CCN]
If filinfo(filpath("FIL","ECCNREV","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File ECCNREV [E51]
Local File CONCESSION [CCN_]
Local Char KEY_CCN(120)(1..3)
Local Char KEY_E51(120)(1..3)
#Empty keys :
KEY_CCN(3) = ""
KEY_E51(3) = "+"
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [CCN]
LogicClose File [E51]
LogicClose File [CCN_]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [CCN] With
& [E51]EVE0=[CCN]CCNREF
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [CCN] With
& [E51]EVE0=[CCN]CCNREF
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
Local Integer CI1
Local Integer CJ1
Local Char    SEPINS1(2) : SEPINS1=""
Local Char IS1(1)

Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE
KEY_CCN(2) = [F:CCN]CCNREF
KEY_E51(2) = [F:E51]REF+"+"+[F:E51]TIMSTP

If (KEY_CCN(2) <> KEY_CCN(3)) & (KEY_CCN(1) <> KEY_CCN(2))
 If INS <> null
  [L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
  #serialize INS
  Gosub ASEARCH_TO_JSON
 Endif
#Create a new instance
INS = NewInstance C_CONCESSION(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
SetInstance INS With [F:CCN]
FINS = 1
Local Integer DIES_MAXI:DIES_MAXI= 0
Local Integer DIES_MAXI:DIES_MAXI= 0
Local Integer DIES_MAX:DIES_MAX=0
If dim([F:CCN]CCE)>0
    If DIES_MAXI = 0
        DIES_MAXI = dim([F:CCN]CCE)
    Else
        DIES_MAXI = min(DIES_MAXI,dim([F:CCN]CCE))
    Endif
Endif
If dim([F:CCN]CCE)>0
    If DIES_MAXI = 0
        DIES_MAXI = dim([F:CCN]CCE)
    Else
        DIES_MAXI = min(DIES_MAXI,dim([F:CCN]CCE))
    Endif
Endif
CJ1=1
For CI1 = 0 To DIES_MAXI-1
 Break ([F:CCN]CCE(CI1)="")
 DIES_MAX+=1
 #Create a new instance
 INS.DIES(CJ1) = NewInstance C_CONCESSION_DIES(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
 INS.DIES(CJ1).setaccessorEnabled = 0
 INS.DIES(CJ1).CCE=[F:CCN]CCE(CI1)
 CJ1+=1
Next CI1
 KEY_CCN(1) = KEY_CCN(2)
Endif : # KEY_CCN(1) <> KEY_CCN(2)

Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"CCNREF":'          +'"'+escJson(INS.CCNREF)+'"'
Append ASND.DATA ,',"CCNDES1":'        +'"'+escJson(INS.CCNDES1)+'"'
Append ASND.DATA ,',"CCNDES2":'        +'"'+escJson(INS.CCNDES2)+'"'
IS1=""
CJ1=1
Append ASND.DATA ,',"DIES":['
For CI1=1 To DIES_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"CCE":'             +'"'+escJson(INS.DIES(CJ1).CCE)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
Append ASND.DATA ,'}'
Onerrgo
Freegroup INS
INS = null
Raz KEY_CCN(1),KEY_E51(1)
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:CCN]CCNREF"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
 Gosub METHODS From CONCESSION_CSTD
Gosub METHODS From CONCESSION_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="CONCESSION" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"CONCESSION")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"CONCESSION")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,34692)+'"'
Append WCLOB,',"$url":"{$baseUrl}/CONCESSION'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$facility":"{FCY}"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,34692)+' {$key}"'
Append WCLOB,',"$key":"{CCNREF}"'
Append WCLOB,',"$url":"{$baseUrl}/CONCESSION('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'CONCESSION.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"CCNREF":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,1371)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"CCNDES1":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,2063)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":60'
Append WCLOB,"}"
Append WCLOB,',"CCNDES2":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,2064)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":60'
Append WCLOB,"}"
Append WCLOB,',"DIES":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$minItems":0'
Append WCLOB,',"$maxItems":20'
Append WCLOB,',"$item":{'
Append WCLOB,'"$type":"application/json"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"CCE":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,1688)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,',"$links":{'
Append WCLOB,'"$search$details":{'
Append WCLOB,'"$title":"Detail"'
Append WCLOB,',"$default":true'
Append WCLOB,',"$url":"{$baseUrl}/CONCESSION('+"'"+'{$key}'+"'"+')?representation=CONCESSION.$details"'
Append WCLOB,',"$devices":"desktop"'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
End ERROR
