Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Call AM_ECCVALMAJ(VALEUR, "MBW1") From SUBMBWECC
If VALEUR<>[M:MBW1]ECCVALMAJ
    GMODIF=3
Endif

End

######################################################################################
Subprog AM_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Call AM_ECCVALMIN(VALEUR, "MBW1") From SUBMBWECC
If VALEUR<>[M:MBW1]ECCVALMIN
    GMODIF=3
Endif

End


