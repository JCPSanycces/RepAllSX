#<AdxTL>@(#)8.0.0.0 $Revision$
########################################
Subprog AS_EXTQTY2(VALEUR)
Variable Decimal VALEUR
GBOUT1 = mess(151,198,1)
GBOUT2 = mess(150,198,1)
GBOUT3 = mess(282,198,1)
GBOUT4 = mess(423,198,1)
End

########################################
Subprog B1_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBW1]ITMREF
    Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY2(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MBW1]ITMREF
    Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog C_EXTQTY2(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AM_EXTQTY2(VALEUR)
Variable Decimal VALEUR
Local    Integer OK
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer WALT
Local    Decimal WFRCQTY

If VALEUR = 0 : mkstat = 2 : End : Endif

# v6 affectations
Call GET_FRCQTY([M:MBW1]STOFCY, [M:MBW1]ITMREF, 10, [M:MBW1]VCRNUM, [M:MBW1]VCRLIN, 0, 5, WFRCQTY) From MTOLINKLIB
If VALEUR < WFRCQTY
    # lecture règle si nécessaire
    Local    Char    WPTOCOD(GLONPTO)
    WPTOCOD = func ITMLIB.GET_PTOCOD([M:MBW1]STOFCY, [M:MBW1]ITMREF)
    If [F:PTO]PTOCOD <> WPTOCOD
        Read [PTO]PTO0=WPTOCOD
        If fstat : Raz [F:PTO] : Endif
    Endif
    If [F:PTO]FRCPRO <> 2
        OK=1
        Call OUINON(mess(228,190,1),OK) From GESECRAN
        If OK <> 2 : VALEUR = [M:MBW1]EXTQTY2 : mkstat = 2 : End : Endif
    Endif
Endif

# llc 05.03 18397
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBW1]EXTQTY1 + VALEUR
Else
    WQTY = VALEUR
Endif

If [M:MBW1]ROUNUM <> "" & [M:MBW1]ROUALT <> 0 & [M:MBW1]STRDAT2 <> [0/0/0]
    Raz GMESSAGE
    If clalev([F:TRO]) = 0 : Local File TABROUALT [TRO] : Endif
    If clalev([F:ROH]) = 0 : Local File ROUTING   [ROH] : Endif
    #    Lecture ROUTING
    Read [TRO]TRO0=[M:MBW1]ROUALT
    If fstat
        GMESSAGE = mess(152,193,1)
    Else
        Read [ROH]ROH1=[M:MBW1]STOFCY;[M:MBW1]ROUNUM;[M:MBW1]ROUALT
        If fstat
            GMESSAGE = mess(152,193,1)
        Else
            Call CONTMFGGAM([M:MBW1]STOFCY,WALT,[M:MBW1]STRDAT2,WQTY, [M:MBW1]STU2, 1) From MFGLIB
        Endif
    Endif
    If GMESSAGE <> "" | WALT = 0 : mkstat = 2 : Endif
Endif


If [M:MBW1]STRDAT2 = [0/0/0] | [M:MBW1]ENDDAT2 = [0/0/0] : End : Endif
If [M:MBW1]WIPTYP=5 & [M:MBW1]FMI=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif
Endif
If find([F:ORD1]WIPSTA,1,2)
    If [F:MFG]MFGTRKFLG > 3
        OK=1
        Call OUINON(mess(52,190,1),OK) From GESECRAN
        If OK <> 2 : VALEUR = [M:MBW1]EXTQTY2 : mkstat = 2 : End : Endif
    Endif

    If VALEUR < [F:MFI]CPLQTY
        GMESSAGE = mess(68,193,1)
        mkstat = 2
        End
    Endif
Endif

WORIFCY=[M:MBW1]STOFCY
WLTI=0

# lecture ITF
If [F:ITF]ITMREF<>[M:MBW1]ITMREF
    Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY
    If fstat : End : Endif
Endif

Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# 05.08 47469
If [F:MTS]SCDMODSAI = 1
    # calcul date
    WORIDAT=[M:MBW1]ENDDAT2
    WMEMDAT=[M:MBW1]STRDAT2

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBW1]STRDAT2) From MFGLIB

    Affzo [M:MBW1]STRDAT2
    Call CHECK_PAST([M:MBW1]STRDAT2, 2) From MFGLIB
Else
    # calcul date
    WORIDAT=[M:MBW1]STRDAT2
    WMEMDAT=[M:MBW1]ENDDAT2

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MBW1]ENDDAT2) From MFGLIB

    Affzo [M:MBW1]ENDDAT2
    Call CHECK_PAST([M:MBW1]ENDDAT2, 2) From MFGLIB
Endif

End

########################################
Subprog AS_STRDAT2(VALEUR)
Variable Date    VALEUR
# jalonnement amont, si nouvel ordre on saisit la date de fin
# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 & [M:MBW1]ENDDAT2=[0/0/0] : mkstat=2 : End : Endif
If find([F:ORD1]WIPSTA,1,2) & [F:MFG]MFGTRKFLG > 3 : mkstat = 2 : Endif
End

########################################
Subprog C_STRDAT2(VALEUR)
Variable Date    VALEUR
# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:MBW1]ECCVALMAJ)>0
    Call C_STRDAT2(VALEUR, "MBW1") From SUBMBWECC
Endif
End

########################################
Subprog AM_STRDAT2(VALEUR)
Variable Date    VALEUR
Local    Integer WRET
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer OK

If [F:MTS]SCDMODSAI = 1 & VALEUR > [M:MBW1]ENDDAT2 : mkstat=2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW1]STOFCY) From MFGLIB

If mkstat = 2 : End : Endif

# OF jalonné ?
If find([M:MBW1]WIPSTA,1,2)                        # 01.05 27812
    Call TEST_JAL(WRET) From MFGAUTLIB
    If WRET = 1 : mkstat = 2 : End : Endif
Endif

If [M:MBW1]WIPTYP=5 & [M:MBW1]FMI=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif
Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

# llc 03.02 12520
If [F:MTS]SCDMODSAI = 1 : End : Endif

WORIDAT=VALEUR
WORIFCY=[M:MBW1]STOFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY
If fstat : End : Endif
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBW1]EXTQTY1 + [M:MBW1]EXTQTY2
Else
    WQTY = [M:MBW1]EXTQTY2
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
WMEMDAT = [M:MBW1]ENDDAT2

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:MBW1]ENDDAT2) From MFGLIB

Affzo [M:MBW1]ENDDAT2
#
End

########################################
Subprog AS_ENDDAT2(VALEUR)
Variable Date    VALEUR
# Si jalonnement aval et date début non renseignée, pas de saisie
If ([F:MTS]SCDMODSAI=2 & [M:MBW1]STRDAT2=[0/0/0]) : mkstat=2 : End : Endif
End


########################################
Subprog C_ENDDAT2(VALEUR)
Variable Date    VALEUR
End

########################################
Subprog AM_ENDDAT2(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Date    WMEMDAT
Local    Integer WRET
Local    Integer WMAX
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WRMD
Local    Decimal WQTY
Local    Integer OK

If VALEUR=[0/0/0] : mkstat=2 : End : Endif

If [F:MTS]SCDMODSAI = 2 & VALEUR < [M:MBW1]STRDAT2 : mkstat = 2 : End : Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MBW1]STOFCY) From MFGLIB

If mkstat = 2 : End : Endif

# OF jalonné ?
If find([M:MBW1]WIPSTA,1,2)            # 01.05 27812
    Call TEST_JAL(WRET) From MFGAUTLIB
    If WRET = 1 : mkstat = 2 : End : Endif
Endif

If [M:MBW1]WIPTYP=5 & [M:MBW1]FMI=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : End : Endif
Endif

Call CHECK_PAST(VALEUR, 2) From MFGLIB

# llc 03.02 12520
If [F:MTS]SCDMODSAI = 2 : End : Endif
If find([F:ORD1]WIPSTA,1,2) & [F:MFG]MFGTRKFLG > 3 : End : Endif

WORIDAT=VALEUR
WORIFCY=[M:MBW1]STOFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:MBW1]ITMREF;[M:MBW1]STOFCY
If fstat : End : Endif
If find([F:ORD1]WIPSTA,1,2)
    WQTY = [F:MFG]EXTQTY - [M:MBW1]EXTQTY1 + [M:MBW1]EXTQTY2
Else
    WQTY = [M:MBW1]EXTQTY2
Endif
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# calcul date
WMEMDAT = [M:MBW1]STRDAT2

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MBW1]STRDAT2) From MFGLIB

Affzo [M:MBW1]STRDAT2
Call CHECK_PAST([M:MBW1]STRDAT2, 2) From MFGLIB

# Issue 104943 - 2015-07-27 by BEEBE : Implementing Versioning
If dim([M:MBW1]ECCVALMAJ)>0
    Call AM_ENDDAT2(VALEUR, "MBW1") From SUBMBWECC
    # Issue 104943 - 2016-01-08 by BEEBE : when we have an error in validation on Enddat,
    #                                      the origin values of Enddat/Startdat has to be rejected
    If GERR
        [M:MBW1]STRDAT2 = WMEMDAT
        [M:MBW1]ENDDAT2 = WMEMDAT2
        VALEUR          = WMEMDAT2
        Affzo [M:MBW1]STRDAT2
        Affzo [M:MBW1]ENDDAT2
    Endif
Endif
#
zonsui="STRDAT2"
#
End

########################################
Subprog AV_BPRDES(VALEUR)
Variable Char    VALEUR()
#
If [M:MBW1]BPRNUM = "" : End : Endif

If clalev([F:BPR]) = 0 : Local File BPARTNER [BPR] : Endif
Read [BPR]BPR0=[M:MBW1]BPRNUM
If !fstat : VALEUR = [F:BPR]BPRNAM : End : Endif

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=[M:MBW1]BPRNUM
If !fstat : VALEUR = [F:FCY]FCYNAM : End : Endif
#
End

########################################
Subprog AS_BOMALT2(VALEUR)
Variable Decimal VALEUR

# 36374 mm 06.06
Read [MFG]MFG0=[M:MBW1]VCRNUM
If fstat : End : Endif
#
If [F:MFG]ALLSTA > 1 : mkstat = 2 : End : Endif            # 09.05 32041

# 45423 mm 02.08 - Si mode de lancement = opérations seules, on autorise BOMALT =0
If [F:MTS]MFGMODC=1 & [F:MTS]MFGMODM=1  & [F:MTS]MFGMODO = 2 : mkstat = 2 : End : Endif        # 03.05 29111

If VALEUR = 0
    Call RECH_NOM([M:MBW1]STOFCY, [M:MBW1]STRDAT2, VALEUR,2) From BENCHLIB
Endif

End

########################################
Subprog C_BOMALT2(VALEUR)
Variable Decimal VALEUR

# 45423 mm 02.08 - Si mode de lancement = opérations seules, on autorise BOMALT =0
If VALEUR = 0
    If [F:MTS]MFGMODO <> 2
        mkstat = 2    # 02.05 28246
    Else
        If [F:MTS]MFGMODC =1 & [F:MTS]MFGMODM =2 | [F:MTS]MFGMODC =2
            mkstat = 2
        Endif
    Endif
Endif

End

########################################
Subprog AM_BOMALT2(VALEUR)
Variable Decimal VALEUR
Local    Date    WDAT
Local    Char    WFCY
Local    Integer WALT

If [M:MBW1]STRDAT2=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:MBW1]STRDAT2
Endif

# 45423 mm 02.08 - Si mode de lancement = opérations seules, on autorise BOMALT =0
If VALEUR = 0 & [F:MTS]MFGMODC=1 & [F:MTS]MFGMODM=1 &[F:MTS]MFGMODO = 2 :  End : Endif         # 02.05 28246

WFCY=[M:MBW1]STOFCY
#    Lecture BOM
Read [TBO]TBO0=2;VALEUR
If fstat : mkstat=2 : End : Endif
Read [BOH]BOH0=[M:MBW1]ITMREF;VALEUR;2
If fstat : GMESSAGE = mess(95,193,1) : mkstat=2 : End : Endif
Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
If WALT=0 :  mkstat=2 : End : Endif
If WALT <> [M:MBW1]BOMALT2 : [M:MBW1]FLGPRO = 2 : Endif    # 14102 mm 06.06
End

########################################
Subprog AS_ROUNUM(VALEUR)
Variable Char    VALEUR()

# sr 211100 contrôle selon transaction
If [M:MBW1]WIPSTA= 3 | [F:MFG]MFGMOD = 2
    If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
        Raz VALEUR,[M:MBW1]ROUNUM,ROUALT
        mkstat = 2
        End
    Endif
Endif
If [F:MTS]MFGMODM = 2 : End : Endif        # 03.05 29111

If VALEUR = "" | [M:MBW1]ROUALT = 0
    If [F:ITF]MFGROU = ""
        VALEUR = [M:MBW1]ITMREF
    Else
        VALEUR = [F:ITF]MFGROU
    Endif

    Call RECH_GAM([M:MBW1]STOFCY, [M:MBW1]STRDAT2, VALEUR, [M:MBW1]EXTQTY2,
&                 [M:MBW1]STU2, [M:MBW1]BOMALT2, [M:MBW1]ROUALT) From BENCHLIB
    If [M:MBW1]ROUALT = 0 & [F:MTS]MFGMODM = 2 : Raz VALEUR : Endif                # llc 06.04 22880
Endif
End

########################################
Subprog C_ROUNUM(VALEUR)
Variable Char    VALEUR()

# sr 241100 Si OF complet on ne peut pas se passer de la gamme
If find([M:MBW1]WIPSTA,1,2) & [F:MFG]MFGMOD = 1 & VALEUR = ""
   GMESSAGE = mess(31,190,1)
   mkstat = 2
   End
Endif
End

########################################
Subprog AM_ROUNUM(VALEUR)
Variable Char    VALEUR()

# sr 211100 contrôle selon transaction
If find([F:ORD1]WIPSTA,1,2) & find([F:MFG]MFGMOD,1,3) & VALEUR = ""
    GMESSAGE = mess(31,190,1)
    mkstat = 2
    End
Endif
If find([F:ORD1]WIPSTA,1,2) & !find([F:MFG]MFGMOD,1,3)
    If VALEUR = ""
        [M:MBW1]ROUALT = 0                # 03.05
        Affzo [M:MBW1]ROUALT
    Endif
    End
Endif

# Issue 111414 - 2015-12-30 by GH : implementing route versioning
If dim([M:MBW1]ROUECCMAJ)=1
   Local Integer WALT
   WALT = func RVMLIB.GETRVMALT(VALEUR,[M:MBW1]STOFCY,[M:MBW1]STRDAT2)
   If WALT<>0
     Call CONT_ROUALT([M:MBW1]STOFCY, WALT, VALEUR, [M:MBW1]STRDAT2, [M:MBW1]EXTQTY2,
&                     [M:MBW1]STU2, [M:MBW1]BOMALT2) From BENCHLIB
     If GMESSAGE<>"" : WALT=0 : GMESSAGE="" :  Endif
   Endif
   If WALT<>0
     [M:MBW1]ROUALT=WALT
      Call INIECCROU(VALEUR,[M:MBW1]STOFCY,[M:MBW1]STRDAT2,[M:MBW1]ROUALT,[M:MBW1]ROUECCMAJ,[M:MBW1]ROUECCMIN) From RVMLIB
   Else
      Effzo [MBW1]ROUECCMAJ, ROUECCMIN
   Endif
   Call RVMAFF(VALEUR,[M:MBW1]STOFCY,WALT,"MBW1") From RVMLIB
Endif

If VALEUR<>[M:MBW1]ROUNUM : [M:MBW1]FLGPRO = 2  : Endif    # 14102 mm 06.06
End

########################################
Subprog AS_ROUALT(VALEUR)
Variable Decimal VALEUR

# sr 211100 contrôle selon transaction
If [M:MBW1]WIPSTA= 3 | [F:MFG]MFGMOD = 2
    If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
        mkstat = 2
        End
    Endif
Endif
End

########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY
Local    Integer WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)

#
If VALEUR = 0
  If [F:MTS]MFGMODM = 2 & [M:MBW1]ROUNUM = ""
     End
  Else
    mkstat = 2
    End
  Endif
Endif
WDAT=[M:MBW1]STRDAT2
WFCY=[M:MBW1]STOFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH1=[M:MBW1]STOFCY;[M:MBW1]ROUNUM;VALEUR
If fstat : mkstat=2 : End : Endif
#
Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MBW1]EXTQTY2, [M:MBW1]STU2, 1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
# Contrôle de cohérence des alternatives de nomenclature
If ([F:MTS]MFGMODO = 2 & [M:MBW1]BOMALT2 = 0) : End : Endif            # llc 16545 + 02.05 28246
TABTBO(0)=[F:TRO]BOMALT1
TABTBO(1)=[F:TRO]BOMALT2
TABTBO(2)=[F:TRO]BOMALT3
If !find([M:MBW1]BOMALT2, TABTBO)
   GMESSAGE=mess(53,193,1)
   mkstat=2
   End
Endif
#
End

########################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY
Local    Integer WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)

If VALEUR = 0
  If [F:MTS]MFGMODM = 2 & [M:MBW1]ROUNUM = ""
     End
  Else
    mkstat = 2
    End
  Endif
Endif
WDAT=[M:MBW1]STRDAT2
WFCY=[M:MBW1]STOFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH1=[M:MBW1]STOFCY;[M:MBW1]ROUNUM;VALEUR
If fstat : mkstat=2 : End : Endif
#
Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MBW1]EXTQTY2, [M:MBW1]STU2, 1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
If WALT <>[M:MBW1]ROUALT  : [M:MBW1]FLGPRO =2 : Endif    # 14102 mm 06.06

If ([F:MTS]MFGMODO = 2 & [M:MBW1]BOMALT2 = 0) : End : Endif            # llc 16545 + 02.05 28246
# Contrôle de cohérence des alternatives de nomenclature
TABTBO(0)=[F:TRO]BOMALT1
TABTBO(1)=[F:TRO]BOMALT2
TABTBO(2)=[F:TRO]BOMALT3
If !find([M:MBW1]BOMALT2, TABTBO)
   GMESSAGE = mess(53,193,1)
   mkstat=2
   End
Endif
End

########################################
Subprog AM_OBJDAT(VALEUR)
Variable Date    VALEUR
[M:MBW1]ELFLG  = VALEUR - [M:MBW1]ENDDAT2
End

