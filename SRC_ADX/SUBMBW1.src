Subprog C_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Call CTRROUECC([M:MBW1]ROUNUM,[M:MBW1]STOFCY,"MBW1","ROUECCMAJ",VALEUR,[M:MBW1]ROUECCMIN,[M:MBW1]STRDAT2,LRET,GMESSAGE) From RVMLIB
If find(LRET,1,4)
    mkstat=2 : End
Endif
End

######################################################################################

Subprog C_ROUECCMIN(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Call CTRROUECC([M:MBW1]ROUNUM,[M:MBW1]STOFCY,"MBW1","ROUECCMIN",[M:MBW1]ROUECCMAJ,VALEUR,[M:MBW1]STRDAT2,LRET,GMESSAGE) From RVMLIB
If find(LRET,1,4)
    mkstat=2 : End
Endif
End

