#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
#    Process Name:    SUBFCC - Freight Commodity Codes
#
#                     Field COMTYP defines the type of commodity code,
#                       1 = NMFC    - used for USA domestic shipments (requires KUS active)
#                       2 = HS code - used for international shipments
#
#    Authors:         Eric Millspaugh   Dec, 2014
#
#    Modifications:
#
######################################################################################
######################################################################################
$ACTION
Case ACTION
  When "ANNULE"   : Gosub ANNULE
  When "INICRE"   : Gosub INICRE
  When "INIMOD"   : Gosub INIMOD
  When "LIENS"    : Gosub LIENS
  When "RAZCRE"   : Gosub RAZCRE
Endcase

Return

######################################################################################
$ANNULE
  # Text deletion
  Delete [AXX] Where CODFIC = "FRTCOMCOD" and ZONE = "DESAXX" and IDENT1 = [M:FCC1]COMCOD and IDENT2 = num$([M:FCC1]COMTYP)
  Delete [AXX] Where CODFIC = "FRTCOMCOD" and ZONE = "SHOAXX" and IDENT1 = [M:FCC1]COMCOD and IDENT2 = num$([M:FCC1]COMTYP)
Return

######################################################################################
$INIMOD

Gosub MAJ_AXX

Return

######################################################################################
$INICRE

Gosub MAJ_AXX

Return

######################################################################################
$LIENS

Call LECTEXTRA ([M:FCC1]DESAXX,"FRTCOMCOD","DESAXX",[M:FCC1]COMCOD,num$([M:FCC1]COMTYP)) From ATEXTRA
Call LECTEXTRA ([M:FCC1]SHOAXX,"FRTCOMCOD","SHOAXX",[M:FCC1]COMCOD,num$([M:FCC1]COMTYP)) From ATEXTRA
Affzo [M:FCC1]DESAXX,SHOAXX

Return

######################################################################################
$MAJ_AXX

  # Creation/Modification of ATEXTRA
  Call MAJTEXTRA([M:FCC1]DESAXX,"FRTCOMCOD","DESAXX",[M:FCC1]COMCOD,num$([M:FCC1]COMTYP)) From ATEXTRA
  Call MAJTEXTRA([M:FCC1]SHOAXX,"FRTCOMCOD","SHOAXX",[M:FCC1]COMCOD,num$([M:FCC1]COMTYP)) From ATEXTRA

Return

######################################################################################
$RAZCRE
  #As of Akira release - NMFC code is only type used.
  # Commodity type field is hidden and defaulted to only 1
  [M:FCC1]COMTYP=1
  [M:FCC1]ENAFLG=2
  Affzo [M:FCC1]
Return
##################################################
Subprog TUNFCC(COD,TYP)
Variable Char    COD()
Value    Integer TYP
Local    Char    TYPC
Local Integer O_GNBDERNIER, O_GNBDERCLE
Local Integer TOKILL



TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(9)
  TOKILL = 1
Endif

If !clalev([F:FCC]) : Local File FRTCOMCOD [FCC] : Endif

VCOD = COD
TYPC = num$(TYP)

O_GNBDERNIER = GNBDERNIER
O_GNBDERCLE = GNBDERCLE
Raz GNBDERNIER, GNBDERCLE
Call OBJET("FCC",VCOD,TYPC) From GOBJET
GNBDERNIER = O_GNBDERNIER
GNBDERCLE = O_GNBDERCLE

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
######################################################################################
Subprog C_COMCOD(VALEUR)
Variable Char    VALEUR()

If instr(0,VALEUR,"'")<>0 | instr(0,VALEUR,'"')<>0
  Call ERREUR(mess(113,123,1)) From GESECRAN : mkstat=2
Endif

End


######################################################################################

