Funprog GET_DOC_TYP(DOCTYP)
Value Char DOCTYP

Local Integer RETVAL

Case DOCTYP
  When "GRC"
    RETVAL = 1
  When "GDC"
    RETVAL = 2
  When "GRL"
    RETVAL = 3
  When "SRS"
    RETVAL = 4
  When "SIS"
    RETVAL = 5
  When "PNH"
    RETVAL = 6
  When "SST"
    RETVAL = 7
  When "STR"
    RETVAL = 8
#  When Default
#    RETVAL = 9
Endcase

End RETVAL
################################################################################################
################################################################################################
Funprog GET_DOC_FCY(DOCTYP)
Value Char DOCTYP

Local Char RETVAL(50)

Case DOCTYP
  When 2
    RETVAL = [F:SDH]STOFCY
  When 3,4,5
    RETVAL = [F:SRH]STOFCY
  When 9
    RETVAL = [F:PNH]PNHFCY
  When 6,7,8
    RETVAL = [F:SGH]STOFCY
Endcase

End RETVAL
################################################################################################
################################################################################################
Funprog GET_ADD(DOCTYP)
Value Integer DOCTYP

Local Char RETVAL(50)

Case DOCTYP
  When 2
    RETVAL = [F:SDH]BPAADD
  When 3,4,5
    RETVAL = [F:SRH]BPAADD
  When 9
    RETVAL = [F:PNH]BPAADD
  When 6
    RETVAL = [F:SGH]FCYADD
  When 7,8
    RETVAL = [F:SGH]BPSADD
  When 10
    RETVAL = [F:TNH]BPAADD
Endcase

