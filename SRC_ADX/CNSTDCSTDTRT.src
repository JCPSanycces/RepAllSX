   When "0"
      #RETMES = "Documento registado com sucesso."
      RETMES = mess(151,7711,1)
   When "1"
      #RETMES = "Utilizador não preenchido."
      RETMES = mess(152,7711,1)
   When "2"
      #RETMES = "Tamanho do utilizador incorreto."
      RETMES = mess(153,7711,1)
   When "3"
      #RETMES = "NIF inválido."
      RETMES = mess(154,7711,1)
   When "4"
      #RETMES = "Utilizador com formato inválido."
      RETMES = mess(155,7711,1)
   When "5"
      #RETMES = "Sub-utilizador com formato inválido."
      RETMES = mess(156,7711,1)
   When "6"
      #RETMES = "Senha não preenchida."
      RETMES = mess(157,7711,1)
   When "7"
      #RETMES = "Codificação base64 inválida."
      RETMES = mess(158,7711,1)
   When "8"
      #RETMES = "Cifra da chave pública inválida."
      RETMES = mess(159,7711,1)
   When "9"
      #RETMES = "Formato do timestamp inválido."
      RETMES = mess(160,7711,1)
   When "10"
      #RETMES = "Validade da credencial expirada."
      RETMES = mess(161,7711,1)
   When "11"
      #RETMES = "Chave simétrica inválida."
