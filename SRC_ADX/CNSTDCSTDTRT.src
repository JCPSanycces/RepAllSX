################################################################################################
################################################################################################
Funprog GET_DOC_DAT(DOCTYP)
Value Char DOCTYP

Local Date RETVAL

Case DOCTYP
  When "GRC"                      # SDH
    RETVAL = [F:SDH]SHIDAT
  When "GDC", "GRL", "SRS" # SRH
    RETVAL = [F:SRH]RTNDAT
  When "PNH"                      # PNH
    RETVAL = [F:PNH]RTNDAT
  When "SIS", "SST", "STR"        # SGH
    RETVAL = [F:SGH]IPTDAT
Endcase

End RETVAL
################################################################################################
################################################################################################
Subprog GET_LIN_FIELDS(DOCTYP, LINDOCTYP, LINFCY, LINBPRNUM, LINDOCDAT)
Value Integer DOCTYP
Variable Char    LINDOCTYP, LINFCY, LINBPRNUM
Variable Date    LINDOCDAT

LINDOCTYP = num$([F:DKD]VCRTYP)

Case DOCTYP
  When 2
     #[SDH]
     LINFCY    = [F:SDH]STOFCY
     LINBPRNUM = [F:SDH]BPCORD
     LINDOCDAT = [F:SDH]SHIDAT
  When 3,4,5
     #[SRH]
     LINFCY    = [F:SRH]STOFCY
     LINBPRNUM = [F:SRH]BPCORD
     LINDOCDAT = [F:SRH]RTNDAT
  When 6,7,8
     #[SGH]
     LINFCY    = [F:SGH]STOFCY
     LINBPRNUM = [F:SGH]BPCNUM
     LINDOCDAT = [F:SGH]IPTDAT
  When 9
     #[PNH]
     LINFCY    = [F:PNH]PNHFCY
     LINBPRNUM = [F:PNH]BPSNUM
     LINDOCDAT = [F:PNH]RTNDAT
  When 10
     #[TNH]
     LINFCY    = [F:TNH]FCY
     LINBPRNUM = [F:TNH]BPRNUM
     LINDOCDAT = [F:TNH]TRNDAT
  When Default
Endcase

End
################################################################################################
################################################################################################
Funprog SGH_CPY_OK (DOCNUM)
Value Char DOCNUM

Local Integer RETVAL : RETVAL = 0
Local File COMPANY  [CPY]
Local File FACILITY [FCY]
Local File SCHGH    [SGH]

Read [F:SGH]SGH0 = DOCNUM
If !fstat
  Read [F:FCY]FCY0 = [F:SGH]STOFCY
  If !fstat
    If [F:FCY]LEGCPY = [M:TDC0]CPY : RETVAL = 1 : Endif
  Endif
Else
  RETVAL = 1
Endif

End RETVAL
################################################################################################
################################################################################################
Funprog IS_FINAL_BPC(DOCTYP)
Value Integer DOCTYP

Local Integer RETVAL : RETVAL = 0
Local Char    BPC(GLONBPC)    : BPC    = ""

Case DOCTYP
  When 4
      BPC = [F:SDH]BPCORD
  When 12, 18, 33
     BPC = [F:SRH]BPCORD
  When 19, 29
    BPC = [F:SGH]BPCNUM
Endcase

If BPC <> ""
   If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
   Read [F:BPR]BPR0 = BPC
   If !fstat
     If [F:BPR]LEGETT = 2
       RETVAL = 1
     Endif
   Endif
Endif

End RETVAL
################################################################################################
################################################################################################
Funprog HAS_DOC_GLOB(DOCTYP,TABABR)
Value Char      DOCTYP
Value Integer   TABABR

Local Integer RETVAL  : RETVAL  = 0
Local Char    DOCGLOB : DOCGLOB = ""

Case DOCTYP
  When "GRC"
      DOCGLOB = [F:SDH]XPORDREF
Endcase

If DOCGLOB <> ""
   RETVAL = 1
Endif

End RETVAL
################################################################################################
################################################################################################
Funprog IS_MOV_BACTI(DOCTYP)
Value Integer DOCTYP

If !clalev([F:TSD]) : Local File TABSDHTYP [TSD] : Endif

Local Integer RETVAL  : RETVAL  = 0
Local Integer BACT    : BACT    = 0

If [L]DOCTYP = 4
  Read [F:TSD]TSD0 = [F:SDH]SDHTYP
  If !fstat Then
    BACT = [F:TSD]SAFTTRNTYP
  Endif
Endif

If BACT = 3
   RETVAL = 1
Endif

End RETVAL
################################################################################################
################################################################################################
Funprog IS_MAN_DOCUM(DOCTYP)
Value Integer DOCTYP

If !clalev([F:TSD]) : Local File TABSDHTYP [TSD] : Endif
If !clalev([F:TSG]) : Local File TABSGHTYP [TSG] : Endif
If !clalev([F:TRE]) : Local File TABSRHTYP [TRE] : Endif
If !clalev([F:TPN]) : Local File TABPNHTYP [TPN] : Endif

Local Integer RETVAL : RETVAL = 0
Local Integer DMAN   : DMAN   = 0

Case DOCTYP
  When 4
      Read [F:TSD]TSD0 = [F:SDH]SDHTYP
      If !fstat Then
        DMAN = [F:TSD]RECTYP
      Endif
  When 12, 18, 33
     Read [F:TRE]TRE0 = [F:SRH]TRETYP
     If !fstat Then
       DMAN = [F:TRE]RECTYP
     Endif
  When 19, 29
     Read [F:TSG]TSG0 = [F:TSG]SGHTYP
     If !fstat Then
       DMAN = [F:TSG]RECTYP
     Endif
  When 11
     Read [F:PNH]PNH0 = [F:PNH]PNHTYP
     If !fstat Then
       DMAN = [F:TPN]RECTYP
     Endif
Endcase
#BB * 17-01-2014 * Oficio 50 001
If find(DMAN,2,3)
   RETVAL = 1
Endif
#-
End RETVAL
################################################################################################
################################################################################################
Funprog GET_BPRNUM(DOCTYP)
Value Integer      DOCTYP

Local Char RETVAL

Case DOCTYP
  When 2
      RETVAL = [F:SDH]BPCORD
  When 3,4,5
      RETVAL = [F:SRH]BPCORD
  When 9
      RETVAL = [F:PNH]BPSNUM
  When 6
      RETVAL = [F:SGH]BPCNUM
  When 7,8
      RETVAL = [F:SGH]BPSNUM
  When 10
      RETVAL = [F:TNH]BPRNUM
#  When Default
#    RETVAL = [F:XSIH]BPR
Endcase

End RETVAL
################################################################################################
################################################################################################
$SETBOUT

If !find(2,[M:TDC1]UPDFLG(0..dim([M:TDC1]UPDFLG)-1))
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

#If !find(2,[M:XPT2]FLG(0..dim([M:XPT2]FLG)-1))
#  Call VIREBOUT(CHAINE,"2") From GOBJET
#Endif

Return
################################################################################################
################################################################################################
$EXEBOUT

Case BOUT
   When "1"
      Gosub SAVE_MANUAL
   When "2"
      Gosub SEND_FLAGED
Endcase

Return
################################################################################################
################################################################################################
$SAVE_MANUAL

For I = 0 To [M:TDC1]NBLIG-1
  If [M:TDC1]UPDFLG(I) = 2
    Read [F:DKD]DKD0 = "SAFT-PT";[M:TDC1]LINDOCTYP1(I);[M:TDC1]NUM(I)
    If !fstat
      [F:DKD]ATDTCOD    = [M:TDC1]ATDTCOD(I)
      [F:DKD]ATDTINPTYP = 1
      [F:DKD]ATDTREQDAT = date$
      [F:DKD]ATDTREQTIM = time$
      [F:DKD]ATDTRECDAT = date$
      [F:DKD]ATDTRECTIM = time$
      [F:DKD]ATDTCOMSTA = "0"
      Rewrite [F:DKD]
      If !fstat
#        [M:XPT2]ATDTCOMSTA(I) = [F:XDKD]ATDTCOMSTA
#        [M:XPT2]ATDTINPTYP(I) = [F:XDKD]ATDTINPTYP
      Endif
    Endif
  Endif
Next

Gosub LECTURE From GCONSULT

Return
################################################################################################
################################################################################################
$SEND_FLAGED

Call OUVRE_TRACE(mess(168,7711,1)) From LECFIC
Call TEMPON ("O") From GESECRAN

For I = 0 To [M:TDC1]NBLIG-1
   If [M:TDC1]FLG(I) = 2
      Call SENDDTTOAT([M:TDC1]NUM(I), [M:TDC1]LINDOCTYP(I), [L]STAT) From PORLEGLIB
   Endif
Next
Call TEMPOFF From GESECRAN
Call LEC_TRACE   From LECFIC
Call FERME_TRACE From LECFIC

Gosub LECTURE From GCONSULT

Return
################################################################################################
################################################################################################
$APRES_MODIF

If COUZON="ATDTCOD" | COUZON="FLG" | COUZON="FLGSTA"
  Gosub SETBOUT From GCONSULT
Endif

Return
