#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################################
################################################################################################
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "SETBOUT"     : Gosub SETBOUT
  When "EXEBOUT"     : Gosub EXEBOUT
  When "LECTURE"     : Gosub LECTURE
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "SEL_TABLE"   : Gosub SEL_TABLE
  When "FIN_TABLE"   : Gosub FIN_TABLE
  When Default
Endcase

Return
################################################################################################
################################################################################################
$SEL_TABLE

Case GACTION
  When "SELTDC" : Gosub SEL_SELTDC
Endcase

Return
################################################################################################
################################################################################################
$FIN_TABLE

Case GACTION
  When "SELTDC" : Gosub FIN_SELTDC
Endcase

Return
################################################################################################
################################################################################################
$SEL_SELTDC
Return
Case [M]LINDOCTYP(nolign-1)
  When 4 # 1
    OBJET="SDH" : OPTIONS="#" : CRITERE(1) = "1=1"
  When 12 # 2
    OBJET="SRH" : OPTIONS="#" : CRITERE(1) = "1=1"
  When 18 # 3
    OBJET="GRL" : OPTIONS="#" : CRITERE(1) = "1=1"
  When 33 # 4
    OBJET="SRS" : OPTIONS="#" : CRITERE(1) = "1=1"
  #When 5
  #  Call EXEFNCK("GESSIS","",[M:TDC1]NUM(nolign-1)) From EXEFNC #SCS - trstyp = 14
  When 11 # 6
    OBJET="PNH" : OPTIONS="#" : CRITERE(1) = "1=1"
  When 19 # 7
    Call EXEFNCK("GESSST","",[M:TDC1]NUM(nolign-1)) From EXEFNC #SCS - trstyp = 0?
  When 29 # 8
    Call EXEFNCK("GESSTR","",[M:TDC1]NUM(nolign-1)) From EXEFNC #SCS - trstyp = 7
#  When 9                                              # XSIH
#    If !clalev([F:XSIH]) : Local File SINVOICE [XSIH] : Endif
#    Read [F:XSIH]SIH0 = [M:XPT2]NUM(nolign-1)
#    If !fstat
#      If    [F:XSIH]ORIMOD = 3
#        Call EXEFNCK("GESBIC","",[M:XPT2]NUM(nolign-1)) From EXEFNC
#      Elsif [F:XSIH]ORIMOD = 5
#        Call EXEFNCK("GESSIH","",[M:XPT2]NUM(nolign-1)) From EXEFNC
#      Endif
#    Endif
Endcase

Return
################################################################################################
################################################################################################
$FIN_SELTDC

Return
################################################################################################
################################################################################################
$OUVRE

If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
If !clalev([F:DKD]) : Local File DKSDATA   [DKD] : Endif
If !clalev([F:PIH]) : Local File PINVOICE  [PIH] : Endif
If !clalev([F:PNH]) : Local File PRETURN   [PNH] : Endif
If !clalev([F:SGH]) : Local File SCHGH     [SGH] : Endif
If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
If !clalev([F:FCY2]) : Local File FACILITY  [FCY2] : Endif
#If !clalev([F:SIH]) : Local File SINVOICE  [SIH] : Endif
If !clalev([F:SRH]) : Local File SRETURN   [SRH] : Endif
If func AFNC.ACTIV('TRSNE')>0
  If !clalev([F:TNH])  : Local File TRANNOTEH [TNH] : Endif
  If !clalev([F:BPR2]) : Local File BPARTNER  [BPR2] : Endif
Endif
Local Char    PMGSTREETN_SF(90)   #StreetName
Local Char    PMGADDDETA_SF(100)  #AddressDetail
Local Char    PMGCITY_SF(50)      #City
Local Char    PMGPOSTCOD_SF(20)   #PostalCode
Local Char    PMGREGION_SF(50)    #Region
Local Char    PMGCOUNTRY_SF(2)    #Country

Local Char    PMGSTREETN_ST(90)   #StreetName
Local Char    PMGADDDETA_ST(100)  #AddressDetail
Local Char    PMGCITY_ST(50)      #City
Local Char    PMGPOSTCOD_ST(20)   #PostalCode
Local Char    PMGREGION_ST(50)    #Region
Local Char    PMGCOUNTRY_ST(2)    #Country

Local Char    WFIL(250),WFIL1(250), WFIL2(250), WFIL3(250), WFIL4(250), WFIL5(250)
Local Char    DEBDOCTYP, DEBDOCNUM, FINDOCTYP, FINDOCNUM
Local Integer I, STAT

Local Char    SPEMGCOUNTRY

Return
################################################################################################
################################################################################################
$LECTURE

If [M:TDC0]CPY = "" : Return : Endif

Gosub CHANGE_MSK From GCONSULT

If CHGPAG<0 : NOL = MAXLIG : Endif

#If clalev([LNK]) : Close File [LNK] : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres

If CHGPAG > 0    #recherche, suite ou F5
  SUITE=1
  If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
  If [M:TDC0]DOCTYP = 1
    Gosub LNK_ALL_ASC
  Else
    Gosub LNK_NALL_ASC
  Endif
Else
  RETOUR=1
  If CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
  If [M:TDC0]DOCTYP = 1
    Gosub LNK_ALL_DES
  Else
    Gosub LNK_NALL_DES
  Endif
Endif

#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:TDC1] : Endif

#-- lecture
$BOUCLE
For [LNK] Where evalue(WFIL) & evalue (WFIL1) & evalue (WFIL2) & evalue (WFIL3) & evalue (WFIL4) & evalue (WFIL5)
  Case [F:DKD]VCRTYP
    When 2
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP, [F:SDH]BPCORD, [F:SDH]SDHTYP, [F:SDH]STOFCY)<>1
        Goto NEXT_RECORD
      Endif
      If ctrans([F:SDH]BPDADDLIG(0)+[F:SDH]BPDADDLIG(1)+[F:SDH]BPDADDLIG(2)," ","")<>''
        If [F:SDH]BPDCRY<>'PT'
          Goto NEXT_RECORD
        Endif
      Else
        Call ADDRESS(1,func GET_BPRNUM([F:DKD]VCRTYP),func GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From SAFTGENPORMG
        If PMGCOUNTRY_ST<>'PT'
          Goto NEXT_RECORD
        Endif
      Endif
    When 3,4,5
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP, [F:SRH]BPCORD, [F:SRH]SRHTYP, [F:SRH]STOFCY)<>1
        Goto NEXT_RECORD
      Endif
      Call ADDRESS(3,[F:SRH]STOFCY,[F:FCY]BPAADD,PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From SAFTGENPORMG
      If PMGCOUNTRY_ST <> "PT" : Goto NEXT_RECORD : Endif
      If ctrans([F:SRH]BPDADDLIG(0)+[F:SRH]BPDADDLIG(1)+[F:SRH]BPDADDLIG(2),' ','')<>''
        If [F:SRH]BPDCRY<>'PT' : Goto NEXT_RECORD : Endif
      Else
        Call ADDRESS(1,func GET_BPRNUM([F:DKD]VCRTYP),func GET_ADD([F:DKD]VCRTYP),PMGSTREETN_SF,PMGADDDETA_SF,PMGCITY_SF,PMGPOSTCOD_SF,PMGCOUNTRY_SF,PMGREGION_SF) From SAFTGENPORMG
        If PMGCOUNTRY_SF <> "PT" : Goto NEXT_RECORD : Endif
      Endif
    When 6,7,8
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP,'', [F:SGH]SGHTYP, [F:SGH]STOFCY)<>1
        Goto NEXT_RECORD
      Endif
      Case [F:SGH]BETFCYCOD
        When 4,5
          Call ADDRESS(1,func GET_BPRNUM([F:DKD]VCRTYP),func GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From SAFTGENPORMG
        When 2
          Call ADDRESS(3,[F:SGH]FCYDES,[F:SGH]FCYADD,PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From SAFTGENPORMG
      Endcase
      If PMGCOUNTRY_ST <> "PT"
        Goto NEXT_RECORD
      Endif
    When 9
      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP,'', [F:PNH]PNHTYP, [F:PNH]PNHFCY)<>1
        Goto NEXT_RECORD
      Endif
      If ctrans([F:PNH]BPAADDLIG(0)+[F:PNH]BPAADDLIG(1)+[F:PNH]BPAADDLIG(2),' ','')<>''
        If [F:PNH]CRY<>'PT'
          Goto NEXT_RECORD
        Endif
      Else
        Call ADDRESS(1,func GET_BPRNUM([F:DKD]VCRTYP),func GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From SAFTGENPORMG
        If PMGCOUNTRY_ST <> "PT"
          Goto NEXT_RECORD
        Endif
      Endif
    When 10

      If func PORLEGLIB.DOCCTR([F:DKD]VCRTYP,[F:TNH]BPRNUM,[F:TNH]TNHTYP,[F:TNH]FCY)<>1
        Goto NEXT_RECORD
      Endif

      Read [F:BPR2]BPR0 = [F:TNH]BPRNUM
      If !fstat
        If [F:TNH]BPCBPS=1 & [F:BPR2]LEGETT=2
          Goto NEXT_RECORD
        Endif
      Endif

      If ctrans([F:TNH]BPDADDLIG(0)+[F:TNH]BPDADDLIG(1)+[F:TNH]BPDADDLIG(2)," ","")<>''
        If [F:TNH]BPDCRY<>'PT'
          Goto NEXT_RECORD
        Endif
      Else
        Call ADDRESS(1,func GET_BPRNUM([F:DKD]VCRTYP),func GET_ADD([F:DKD]VCRTYP),PMGSTREETN_ST,PMGADDDETA_ST,PMGCITY_ST,PMGPOSTCOD_ST,PMGCOUNTRY_ST,PMGREGION_ST) From SAFTGENPORMG
        If PMGCOUNTRY_ST<>'PT'
          Goto NEXT_RECORD
        Endif
      Endif
      Read [F:FCY]FCY0=[F:TNH]FCY
      If !fstat
        Call ADDRESS(3,[F:TNH]FCY,[F:FCY]BPAADD,PMGSTREETN_SF,PMGADDDETA_SF,PMGCITY_SF,PMGPOSTCOD_SF,PMGCOUNTRY_SF,PMGREGION_SF) From SAFTGENPORMG
      Endif
      If PMGCOUNTRY_SF <> "PT" : Goto NEXT_RECORD : Endif
    When Default : Goto NEXT_RECORD
  Endcase

  Gosub CHARGE_CNS
  If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
    Break
  Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
    Break
  Endif
  $NEXT_RECORD
Next

Affzo [M:TDC1]

Return
################################################################################################
################################################################################################
$LNK_ALL_ASC
# BRBAN 20/02/2015 SAM#106342 Changed link
Link [F:DKD] With [F:SDH]SDH0=[F:DKD]DOCNUM, [F:PNH]PNH0=[F:DKD]DOCNUM,
&                 [F:SGH]SGH0=[F:DKD]DOCNUM, [F:SRH]SRH0=[F:DKD]DOCNUM, [F:TNH]TNH0=[F:DKD]DOCNUM, [F:FCY2]FCY0=[F:SGH]STOFCY
&                 As [LNK] Order By [F:DKD]DOCNUM Asc
#Link [F:DKD] With [F:SDH]SDH0=[F:DKD]DOCNUM, [F:PNH]PNH0=[F:DKD]DOCNUM,
#&                 [F:SGH]SGH0=[F:DKD]DOCNUM, [F:SRH]SRH0=[F:DKD]DOCNUM
#&                 As [LNK] Order By [F:DKD]DOCNUM Asc
Return
################################################################################################
################################################################################################
$LNK_NALL_ASC
# BRBAN 20/02/2015 SAM#106342 Changed link
Case [M:TDC0]DOCTYP
  When 2
    Link [F:DKD] With [F:SDH]SDH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Asc
  When 3,4,5
    Link [F:DKD] With [F:SRH]SRH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Asc
  When 6,7,8
    Link [F:DKD] With [F:SGH]SGH0=[F:DKD]DOCNUM, [F:FCY2]FCY0=[F:SGH]STOFCY As [LNK] Order By [F:DKD]DOCNUM Asc
  When 9
    Link [F:DKD] With [F:PNH]PNH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Asc
  When 10
    Link [F:DKD] With [F:TNH]TNH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Asc
Endcase

Return
################################################################################################
################################################################################################
$LNK_ALL_DES
# BRBAN 20/02/2015 SAM#106342 Changed link
Link [F:DKD] With [F:SDH]SDH0=[F:DKD]DOCNUM, [F:PNH]PNH0=[F:DKD]DOCNUM,
&                 [F:SGH]SGH0=[F:DKD]DOCNUM, [F:SRH]SRH0=[F:DKD]DOCNUM, [F:TNH]TNH0=[F:DKD]DOCNUM, [F:FCY2]FCY0=[F:SGH]STOFCY
&                 As [LNK] Order By [F:DKD]DOCNUM Desc
#Link [F:DKD] With [F:SDH]SDH0=[F:DKD]DOCNUM, [F:PNH]PNH0=[F:DKD]DOCNUM,
#&                 [F:SGH]SGH0=[F:DKD]DOCNUM, [F:SRH]SRH0=[F:DKD]DOCNUM
#&                 As [LNK] Order By [F:DKD]DOCNUM Desc
Return
################################################################################################
################################################################################################
$LNK_NALL_DES
# BRBAN 20/02/2015 SAM#106342 Changed link
Case [M:TDC0]DOCTYP
  When 2
    Link [F:DKD] With [F:SDH]SDH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Desc
  When 3,4,5
    Link [F:DKD] With [F:SRH]SRH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Desc
  When 6,7,8
    Link [F:DKD] With [F:SGH]SGH0=[F:DKD]DOCNUM, [F:FCY2]FCY0=[F:SGH]STOFCY As [LNK] Order By [F:DKD]DOCNUM Desc
  When 9
    Link [F:DKD] With [F:PNH]PNH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Desc
  When 10
    Link [F:DKD] With [F:TNH]TNH0=[F:DKD]DOCNUM As [LNK] Order By [F:DKD]DOCNUM Desc
Endcase

Return
################################################################################################
################################################################################################
$CHARGE_CNS

If NBLU = 1
  If CHGPAG=2 | CHGPAG=-2  : Endif
  NBLU = 2
Endif

If CHGPAG > 0
  If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
  NOL    += 1
  If NOL=0
    DEBDOCTYP  = [F:DKD]DOCTYP
    DEBDOCNUM  = [F:DKD]DOCNUM
  Endif
  FINDOCTYP  = [F:DKD]DOCTYP
  FINDOCNUM  = [F:DKD]DOCNUM
Else
  If NOL <= 0 : RETOUR=2 : Return : Endif
  NOL    -= 1
  If NOL=MAXLIG-1
    FINDOCTYP  = [F:DKD]DOCTYP
    FINDOCNUM  = [F:DKD]DOCNUM
  Endif
  DEBDOCTYP  = [F:DKD]DOCTYP
  DEBDOCNUM  = [F:DKD]DOCNUM
Endif

Local Char    LINDOCTYP1, LINFCY1, LINBPRNUM1
Local Date    LINDOCDAT1
Call GET_LIN_FIELDS([F:DKD]VCRTYP, [L]LINDOCTYP1, [L]LINFCY1, [L]LINBPRNUM1, [L]LINDOCDAT1)

nolign = NOL+1

[M:TDC1]LINDOCTYP1(NOL)   = [F:DKD]DOCTYP
[M:TDC1]LINDOCTYP(NOL)    = val([L]LINDOCTYP1)
[M:TDC1]LINFCY(NOL)       = [L]LINFCY1
[M:TDC1]NUM(NOL)          = [F:DKD]DOCNUM
[M:TDC1]BPRNUM(NOL)       = [L]LINBPRNUM1
[M:TDC1]DOCDAT(NOL)       = [L]LINDOCDAT1
[M:TDC1]ATDTCOMSTA(NOL)   = [F:DKD]ATDTCOMSTA
[M:TDC1]ATDTINPTYP(NOL)   = [F:DKD]ATDTINPTYP
[M:TDC1]ATDTCOD(NOL)      = [F:DKD]ATDTCOD

Return
################################################################################################
################################################################################################
$LOAD_FILTER

WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"
WFIL4 = "1=1"
WFIL5 = "1=1"

# Document code
If dim([M:TDC0]DTCOD) > 0 & [M:TDC0]DTCOD <> ""
  WFIL += " & [F:DKD]ATDTCOD='"+[M:TDC0]DTCOD+"'"
Endif

If [M:TDC0]DOCTYP = 1
  # BRBAN 20/02/2015 SAM#106342
  # Company
  WFIL += " &((find('" + [M:TDC0]CPY + "', [F:SDH]CPY, [F:SRH]CPY, [F:PNH]CPY,[F:TNH]CPY,[F:FCY2]LEGCPY)))"
  #WFIL += " &((find('" + [M:TDC0]CPY + "', [F:SDH]CPY, [F:SRH]CPY, [F:PNH]CPY,[F:TNH]CPY)) | ([F:SGH]CREUSR<>''))"
  #WFIL += " &((find('" + [M:TDC0]CPY + "', [F:SDH]CPY, [F:SRH]CPY, [F:PNH]CPY)) | ([F:SGH]CREUSR<>''))"
  # Site
  If [M:TDC0]FCY <> ""
    WFIL += " & find('"+[M:TDC0]FCY+"', [F:SDH]STOFCY, [F:SRH]STOFCY, [F:PNH]PNHFCY, [F:SGH]STOFCY,[F:TNH]FCY)"
    #WFIL += " & find('"+[M:TDC0]FCY+"', [F:SDH]STOFCY, [F:SRH]STOFCY, [F:PNH]PNHFCY, [F:SGH]STOFCY)"

  Endif
  # Start date
  If [M:TDC0]STRDAT <> [0/0/0]
    WFIL1 += " & ([F:SDH]SHIDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"] | [F:SRH]RTNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"] | [F:PNH]RTNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"]"+
&            " |  [F:SGH]IPTDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"] | [F:TNH]TRNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"])"
#    WFIL1 += " & ([F:SDH]SHIDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"] | [F:SRH]RTNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"] | [F:PNH]RTNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"]"+
#&            " |  [F:SGH]IPTDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"])"
  Endif
  # End date
  If [M:TDC0]ENDDAT <> [0/0/0]
    WFIL2 += " & ([F:SDH]SHIDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"] | [F:SRH]RTNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"] | [F:PNH]RTNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"]"+
&            " |  [F:SGH]IPTDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"] | [F:TNH]TRNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"])"
#    WFIL2 += " & ([F:SDH]SHIDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"] | [F:SRH]RTNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"] | [F:PNH]RTNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"]"+
#&            " |  [F:SGH]IPTDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"])"
  Endif
  # Start business partner
  If [M:TDC0]BPRNUMSTR <> ""
    WFIL3 += " & ([F:SDH]BPCORD>='"+[M:TDC0]BPRNUMSTR+"' | [F:SRH]BPCORD>='"+[M:TDC0]BPRNUMSTR+"' | [F:PNH]BPSNUM>='"+[M:TDC0]BPRNUMSTR+
&            "' | [F:SGH]BPCNUM>='"+[M:TDC0]BPRNUMSTR+"' | [F:SGH]BPSNUM>='"+[M:TDC0]BPRNUMSTR+"' | [F:TNH]BPRNUM>='"+[M:TDC0]BPRNUMSTR+"')"
#    WFIL3 += " & ([F:SDH]BPCORD>='"+[M:TDC0]BPRNUMSTR+"' | [F:SRH]BPCORD>='"+[M:TDC0]BPRNUMSTR+"' | [F:PNH]BPSNUM>='"+[M:TDC0]BPRNUMSTR+
#&            "' | [F:SGH]BPCNUM>='"+[M:TDC0]BPRNUMSTR+"' | [F:SGH]BPSNUM>='"+[M:TDC0]BPRNUMSTR+"')"
  Endif
  # End business partner
  If [M:TDC0]BPRNUMEND <> ""                           # End business partner
    WFIL4 += " & ([F:SDH]BPCORD<='"+[M:TDC0]BPRNUMEND+"' | [F:SRH]BPCORD<='"+[M:TDC0]BPRNUMEND+"' | [F:PNH]BPSNUM<='"+[M:TDC0]BPRNUMEND+
&            "' | [F:SGH]BPCNUM<='"+[M:TDC0]BPRNUMEND+"' | [F:SGH]BPSNUM<='"+[M:TDC0]BPRNUMEND+"' | [F:TNH]BPRNUM<='"+[M:TDC0]BPRNUMEND+"')"
#    WFIL4 += " & ([F:SDH]BPCORD<='"+[M:TDC0]BPRNUMEND+"' | [F:SRH]BPCORD<='"+[M:TDC0]BPRNUMEND+"' | [F:PNH]BPSNUM<='"+[M:TDC0]BPRNUMEND+
#&            "' | [F:SGH]BPCNUM<='"+[M:TDC0]BPRNUMEND+"' | [F:SGH]BPSNUM<='"+[M:TDC0]BPRNUMEND+"')"
  Endif
Else
  WFIL += " & [F:DKD]VCRTYP="+num$([M:TDC0]DOCTYP)+""
  Case [M:TDC0]DOCTYP
    When 2
      WFIL  += " & [F:SDH]CPY='" + [M:TDC0]CPY + "'"      # Company
      If [M:TDC0]FCY <> ""                                 # Site
        WFIL += " & [F:SDH]STOFCY='"+[M:TDC0]FCY+"'"
      Endif
      If [M:TDC0]STRDAT <> [0/0/0]                         # Start date
         WFIL1 += " & [F:SDH]SHIDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"]"
      Endif
      If [M:TDC0]ENDDAT <> [0/0/0]                         # End date
        WFIL2 += " & [F:SDH]SHIDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"]"
      Endif
      If [M:TDC0]BPRNUMSTR <> ""                           # Start business partner
         WFIL3 += " & [F:SDH]BPCORD>='"+[M:TDC0]BPRNUMSTR + "'"
      Endif
      If [M:TDC0]BPRNUMEND <> ""                           # End business partner
         WFIL4 += " & [F:SDH]BPCORD<='"+[M:TDC0]BPRNUMEND + "'"
      Endif
    When 3,4,5
      WFIL  += " & [F:SRH]CPY='" + [M:TDC0]CPY + "'"      # Company
      If [M:TDC0]FCY <> ""                                 # Site
        WFIL += " & [F:SRH]STOFCY='"+[M:TDC0]FCY+"'"
      Endif
      If [M:TDC0]STRDAT <> [0/0/0]                         # Start date
        WFIL1 += " & [F:SRH]RTNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"]"
      Endif
      If [M:TDC0]ENDDAT <> [0/0/0]                         # End date
        WFIL2 += " & [F:SRH]RTNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"]"
      Endif
      If [M:TDC0]BPRNUMSTR <> ""                           # Start business partner
        WFIL3 += " & [F:SRH]BPCORD>='"+[M:TDC0]BPRNUMSTR+"'"
      Endif
      If [M:TDC0]BPRNUMEND <> ""                           # End business partner
        WFIL4 += " & [F:SRH]BPCORD<='"+[M:TDC0]BPRNUMEND+"'"
      Endif
    When 9
      WFIL  += " & [F:PNH]CPY='" + [M:TDC0]CPY + "'"      # Company
      If [M:TDC0]FCY <> ""                                 # Site
        WFIL += " & [F:PNH]PNHFCY='"+[M:TDC0]FCY+"'"
      Endif
      If [M:TDC0]STRDAT <> [0/0/0]                         # Start date
        WFIL1 += " & [F:PNH]RTNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"]"
      Endif
      If [M:TDC0]ENDDAT <> [0/0/0]                         # End date
        WFIL2 += " & [F:PNH]RTNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"]"
      Endif
      If [M:TDC0]BPRNUMSTR <> ""                           # Start business partner
        WFIL3 += " & [F:PNH]BPSNUM>='"+[M:TDC0]BPRNUMSTR+"'"
      Endif
      If [M:TDC0]BPRNUMEND <> ""                           # End business partner
        WFIL4 += " & [F:PNH]BPSNUM<='"+[M:TDC0]BPRNUMEND+"'"
      Endif
    When 6,7,8                                        # SGH
      # BRBAN 20/02/2015 SAM#106342
      WFIL  += " & [F:FCY2]LEGCPY='" + [M:TDC0]CPY + "'"      # Company
      If [M:TDC0]FCY <> ""                                 # Site
        WFIL += " & [F:SGH]STOFCY='"+[M:TDC0]FCY+"'"
      Endif
      If [M:TDC0]STRDAT <> [0/0/0]                         # Start date
        WFIL1 += " & [F:SGH]IPTDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"]"
      Endif
      If [M:TDC0]ENDDAT <> [0/0/0]                         # End date
        WFIL2 += " & [F:SGH]IPTDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"]"
      Endif
      If [M:TDC0]DOCTYP = 8
        If [M:TDC0]BPRNUMSTR <> ""                           # Start business partner
          WFIL3 += " & [F:SGH]BPCNUM>='"+[M:TDC0]BPRNUMSTR+"'"
        Endif
        If [M:TDC0]BPRNUMEND <> ""                           # End business partner
          WFIL4 += " & [F:SGH]BPCNUM<='"+[M:TDC0]BPRNUMEND+"'"
        Endif
      Else
        If [M:TDC0]BPRNUMSTR <> ""                           # Start business partner
          WFIL3 += " & [F:SGH]BPSNUM>='"+[M:TDC0]BPRNUMSTR+"'"
        Endif
        If [M:TDC0]BPRNUMEND <> ""                           # End business partner
          WFIL4 += " & [F:SGH]BPSNUM<='"+[M:TDC0]BPRNUMEND+"'"
        Endif
      Endif
    When 10
      WFIL  += " & [F:TNH]CPY='" + [M:TDC0]CPY + "'"      # Company
      If [M:TDC0]FCY <> ""                                 # Site
        WFIL += " & [F:TNH]FCY='"+[M:TDC0]FCY+"'"
      Endif
      If [M:TDC0]STRDAT <> [0/0/0]                         # Start date
         WFIL1 += " & [F:TNH]TRNDAT>=["+format$(GFMD,[M:TDC0]STRDAT)+"]"
      Endif
      If [M:TDC0]ENDDAT <> [0/0/0]                         # End date
        WFIL2 += " & [F:TNH]TRNDAT<=["+format$(GFMD,[M:TDC0]ENDDAT)+"]"
      Endif
      If [M:TDC0]BPRNUMSTR <> ""                           # Start business partner
         WFIL3 += " & [F:TNH]BPRNUM>='"+[M:TDC0]BPRNUMSTR + "'"
      Endif
      If [M:TDC0]BPRNUMEND <> ""                           # End business partner
         WFIL4 += " & [F:TNH]BPRNUM<='"+[M:TDC0]BPRNUMEND + "'"
      Endif
  Endcase
Endif

If [M:TDC0]DOCNUMSTR <> ""
  WFIL5 += " & [F:DKD]DOCNUM >= '" + [M:TDC0]DOCNUMSTR + "'"
Endif
If [M:TDC0]DOCNUMEND <> ""
  WFIL5 += " & [F:DKD]DOCNUM <= '" + [M:TDC0]DOCNUMEND + "'"
Endif

Case [M:TDC0]STAT
   When 2
      WFIL5 += " & [F:DKD]ATDTCOMSTA = '0'"
   When 3
      WFIL5 += " & [F:DKD]ATDTCOMSTA <> '' & [F:DKD]ATDTCOMSTA <> '0'"
   When 4
      WFIL5 += " & [F:DKD]ATDTCOMSTA = ''"
   When 5
      WFIL5 += " & ([F:DKD]ATDTCOMSTA = '' | [F:DKD]ATDTCOMSTA <> '0')"
Endcase

Case CHGPAG
   When 3 : # rafraichissement
      WFIL5 += " & [F:DKD]DOCNUM>=DEBDOCNUM"
   When 2 : # suite
      WFIL5 += " & [F:DKD]DOCNUM>FINDOCNUM"
   When -2 : # retour
      WFIL5 += " & [F:DKD]DOCNUM<DEBDOCNUM"
Endcase

Return
