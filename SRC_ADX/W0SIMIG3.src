#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIMIG3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone SIMFLG
mkstat = 0
zoncou = "SIMFLG"
indice = 0
IMPENT = [M]SIMFLG
If varinit([M]SIMFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]SIMFLG,indice)=0
 [M]SIMFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SIMFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SIMFLG(indice)
 Endif
Endif
[M]SIMFLG = IMPENT

## Zone EXEC
mkstat = 0
zoncou = "EXEC"
indice = 0
If varinit([M]EXEC,indice)=0
 [M]EXEC = "258"
Endif
If varmode([M]EXEC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXEC" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone VALID
mkstat = 0
zoncou = "VALID"
IMPENT = [M]VALID(indice)
If varinit([M]VALID,indice)=0
 IMPENT = 1
Endif
If varmode([M]VALID,indice)=0
 [M]VALID(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "VALID" : Gosub ACTION From =IMPTRT
  IMPENT = [M]VALID(indice)
 Endif
Endif
[M]VALID(indice) = IMPENT

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIMIG3"
Return

