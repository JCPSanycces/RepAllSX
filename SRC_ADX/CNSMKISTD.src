########################################
Subprog IB_NBLIG
Local Integer L : L = nolign-1

Raz GBOUT1 ,GBOUT2 ,GBOUT3 , GBOUT4

GBOUT2= mess(311,198,1)
If L>=0
  If [M:MKI2]MFGNUM(L)<> ""    # on ne fait un tunnel que lorsqu'il s'agit d'un OF
    GBOUT1 = mess(166,198,1)
  Endif
  Read [MTK]MTK0 = [M:MKI2]MFGTRKNUM(L)
Endif

If [F:MTK]MATTRKFLG = 2
    If clalev([M:MKM1])> 0 : GBOUT3 = ""
    Elsif clalev([M:MKM1])<=0 : GBOUT3= mess(402,198,1) : Endif    # conso matières
Endif

If [F:MTK]OPETRKFLG = 2
    If clalev([M:MKO1])> 0 : GBOUT4 = ""
    Elsif clalev([M:MKO1])<=0 : GBOUT4= mess(436,198,1) : Endif    # Opérations
Endif

End



