#<AdxTL>@(#)3.0.0.0 $Revision$ Consultation MKI
##################################################
#                                                #
#    Consultation des productions                #
#                                       06/01    #
##################################################

########################################################
#
# Parametres de consultation via PARAM()
#
#
#1 = site
#
#2 = date suivi
#
#3 = article
#
#4 = n° de suivi
#
#5 = n° O.F.
#
#6 = Gamme
#
#7 = Alternative nomenclature
#
#8 = Affaire
#
#9 = Commande
#
#10 = Tri
#
#    1- N° de suivi
#    2- Date suivi
#    3- N° OF
#    4- Article
#
##########################################################


Local Char PARAM(20)(1..10)
PARAM(1) ="GAL"
PARAM(2) =""
PARAM(3) =""
PARAM(4) =""
PARAM(5) =""
PARAM(6) =""
PARAM(7) =""
PARAM(8) =""
PARAM(9) =""
PARAM(10) =""
Call GCONSULT("MKI", "",PARAM) From GCONSULT
End


##################################################

$ACTION

Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "LECTURE" : Gosub LECTURE
 When "DEB_CRIT": Gosub DEB_CRIT
 When Default
Endcase
Return

##################################################

$OUVRE

Integer I
Local Char CRITERE(255)
Local Char CRITERE1(255)
Local Char CRITERE2(255)
Local Char CRITERE3(255)
Local Char DEBNUM(GLONVCR)    , FINNUM(GLONVCR)
Local Char DEBMFGNUM(GLONVCR) , FINMFGNUM(GLONVCR)
Local Char DEBITM(GLONITM)    , FINITM(GLONITM)
Local Date DEBDAT, FINDAT
Local Integer WSRT


Gosub DEFCRIT

If !find ([M:CMKI]TRI,1,2,3,4) : [M:CMKI]TRI=1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMKI"
Return

##################################################

$DEFCRIT

#chargement par defaut : en fonction du site et de la date du jour

For I = 1 To dim(PARAM)
Case I :
    When 1 :    # site
        If PARAM(I)<>""
            Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
            If !fstat  & [F:FCY]MFGFLG = 2 :  [M:MKI1]MFGFCY = PARAM(I): Endif
        Endif
    When 2 :    # article
        If PARAM(I)<>""
            Read [ITM]ITM0 =  PARAM(I)
            If ! fstat
                [M:MKI1]ITMREFDEB = PARAM(I)
                [M:MKI1]ITMREFFIN = PARAM(I)
            Endif
        Endif
    When 3 :    #  date suivi
        If  PARAM(I)<> ""
            If instr(1, PARAM(I),"/")
                [M:MKI1]MFGDATDEB = "["+PARAM(I)+"]"
                [M:MKI1]MFGDATFIN = "["+PARAM(I)+"]"
            Else
                [M:MKI1]MFGDATDEB= PARAM(I)
                [M:MKI1]MFGDATFIN= PARAM(I)
            Endif
        Endif
        If [M:MKI1]MFGDATDEB = [0/0/0]
             [M:MKI1]MFGDATDEB = date$ :  [M:MKI1]MFGDATFIN = date$
        Endif

    When 4 :    # n° de suivi
        If  PARAM(I)<> ""
            [M:MKI1]MFGTNUMDEB =  PARAM(I)
            [M:MKI1]MFGTNUMFIN =  PARAM(I)
        Endif
    When 5 :    #  n° O.F.
        If  PARAM(I)<> ""
            [M:MKI1]MFGNUMDEB = PARAM(I)
            [M:MKI1]MFGNUMFIN = PARAM(I)
        Endif
    When 6 :    # Gamme
         If  PARAM(I)<> ""
            Read [ITM]ITM0 = PARAM(I)
            If !fstat
                [M:CMKI]ROUNUMDEB =  PARAM(I)
                [M:CMKI]ROUNUMFIN =  PARAM(I)
            Endif
         Endif
    When 7 :     #Alt. nomenclature
         If PARAM(I)<>""
             [M:CMKI]BOMALTDEB = val(PARAM(I))
             [M:CMKI]BOMALTFIN = val(PARAM(I))
         Endif
    When 8 :    # Affaire
         If  PARAM(I)<> ""
            [M:CMKI]PJTDEB =  PARAM(I)
            [M:CMKI]PJTFIN =  PARAM(I)
            # Issue X3-25731 - 2017-02-24 by FGR : BEGIN
            If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
              [M:CMKI]PJTDSPALL = [V]CST_AYES
            Endif
            # Issue X3-25731 - 2017-02-24 by FGR : END
         Endif
    When 9 :    # Commande
        If  PARAM(I)<> ""
            [M:CMKI]VCRORIDEB =  PARAM(I)
            [M:CMKI]VCRORIFIN =  PARAM(I)
        Endif
    When 10 :    # Tri
        If PARAM(I)<> ""
            WSRT =  val(PARAM(I))
            If WSRT<0 | WSRT > 4 : WSRT = 1 : Endif
            [M:CMKI]TRI = WSRT
        Endif
   When Default : Break

Endcase
Next I



# Copie de l'ecran d'entête / ecran de criteres
Gosub CRITENT From =PROGCNS

Return

##################################################
$DEB_CRIT
#MAE, diszo des zones articles
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CMKI]ITMREFDEB
            Diszo [M:CMKI]ITMREFFIN
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CMKI]ITMREFDEB
            Diszo [M:CMKI]ITMREFFIN
        Endif
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CMKI]PJTDEB
      Diszo [M:CMKI]PJTFIN
    Endif
    # Issue X3-25731 - 2017-02-24 by FGR : END
Endif

Return
##################################################

$LECTURE
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:MKI1]ITMREFDEB
        Diszo [M:MKI1]ITMREFFIN
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:MKI1]ITMREFDEB
        Diszo [M:MKI1]ITMREFFIN
        Diszo [M:MKI1]MFGFCY
    Endif
Endif


# Si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MKI1]MFGFCY ="" : NBLU= 0 : Return : Endif
If PARAM(9)="" : PARAM(9)="1" : Endif


#-- Changement d'écran paramétrable
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

#-- Positionnement des filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


#########################################################
#                                                       #
#    CHGPAG = 1  : Recherche                            #
#    ------ = 2  : Suite                                #
#    ------ = 3  : F5 (Rafraichissement page courante)  #
#                                                       #
#    CHGPAG = -1 : Dernier                              #
#    ------ = -2 : Retour (page precedente)             #
#                                                       #
#########################################################

#-- Application du filtre et positionnement des boutons
If CHGPAG >0
    SUITE = 1
    If CHGPAG = 1 : RETOUR =1       #recherche
    Elsif CHGPAG = 2 : RETOUR = 2   # suite
    Endif

    Case [M:CMKI]TRI
      When 1 : # Tri par N° de suivi
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE =[F:MKI]MFGTRKNUM
      When 2 : # Tri par Date suivi
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE =[F:MTK]MFGTRKDAT
     When 3 : # Tri par n° d'OF
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE =[F:MKI]MFGNUM
     When 4 : # Tri par article
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE =[F:MKI]ITMREF
   Endcase

Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE =1    #dernier
    Elsif CHGPAG =-2 : SUITE = 2 #retour
    Endif

  Case [M:CMKI]TRI
      When 1 : # Tri par N° de suivi
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE =[F:MKI]MFGTRKNUM Desc
      When 2 : # Tri par Date suivi
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE = [F:MTK]MFGTRKDAT Desc
     When 3 : # Tri par n° d'OF
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE = [F:MKI]MFGNUM Desc
     When 4 : # Tri par article
        Link [MKI] With [F:MTK]MTK0 = [F:MKI]MFGTRKNUM,[F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN,[F:MFG]MFG0 = [F:MKI]MFGNUM
&       As  [LIE]
&       Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3)
&       Order By Key CLE = [F:MKI]ITMREF Desc

    Endcase

Endif


#-- RAZ du masque
       If CHGPAG<>2 | CHGPAG<>-2 : Raz [M:MKI2] : Endif

#--  Lecture
For[LIE]
 If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:MKI2] : Endif
     NBLU = 2
 Endif
 If CHGPAG >0
     If NOL>=MAXLIG-1 : SUITE = 2 : Break : Endif
     NOL +=1
     If NOL = 0
       DEBNUM = [F:MKI]MFGTRKNUM
       DEBDAT = [F:MTK]MFGTRKDAT
       DEBMFGNUM = [F:MKI]MFGNUM
       DEBITM = [F:MKI]ITMREF
     Endif
     FINNUM = [F:MKI]MFGTRKNUM
     FINDAT = [F:MTK]MFGTRKDAT
     FINMFGNUM = [F:MKI]MFGNUM
     FINITM = [F:MKI]ITMREF
 Else
     If NOL <=0 : RETOUR = 2 : Break : Endif
     NOL -=1
     If NOL = MAXLIG -1
        FINNUM = [F:MKI]MFGTRKNUM
        FINDAT = [F:MTK]MFGTRKDAT
        FINMFGNUM = [F:MKI]MFGNUM
        FINITM = [F:MKI]ITMREF
     Endif
     DEBNUM = [F:MKI]MFGTRKNUM
     DEBDAT = [F:MTK]MFGTRKDAT
     DEBMFGNUM = [F:MKI]MFGNUM
     DEBITM = [F:MKI]ITMREF

 Endif


 nolign = NOL +1
 [M:MKI2]MFGTRKNUM(nolign-1)  = [F:MKI]MFGTRKNUM
 [M:MKI2]ITMTRKLIN(nolign-1)  = [F:MKI]ITMTRKLIN
 [M:MKI2]MFGLIN(nolign-1)     = [F:MKI]MFGLIN
 [M:MKI2]ITMREF(nolign-1)     = [F:MKI]ITMREF
 [M:MKI2]PRODTYP(nolign-1)    = [F:MKI]PRODTYP
 [M:MKI2]STU(nolign-1)        = [F:MKI]STU
 [M:MKI2]CPLQTY(nolign-1)     = [F:MKI]CPLQTY
 [M:MKI2]LOT(nolign-1)        = [F:MKI]LOT
 If  [M:MKI2]LOT(nolign-1)="" :  [M:MKI2]LOT(nolign-1)= [F:MFI]LOT : Endif
 If dim([F:MKI]ECCVALMAJ)>0 & dim([M:MKI2]ECCVALMAJ)>0  # Issue 107513 GA 04/2015
   [M:MKI2]ECCVALMAJ(nolign-1)  = [F:MKI]ECCVALMAJ
   [M:MKI2]ECCVALMIN(nolign-1)  = [F:MKI]ECCVALMIN
 Endif
 [M:MKI2]IPTDAT(nolign-1)     = [F:MKI]IPTDAT
 [M:MKI2]UOM(nolign-1)        = [F:MKI]UOM
 [M:MKI2]UOMSTUCOE(nolign-1)  = [F:MKI]UOMSTUCOE
 [M:MKI2]ROUNUM(nolign-1)     = [F:MFG]ROUNUM
 [M:MKI2]ROUALT(nolign-1)     = [F:MFG]ROUALT
 Case [F:MKI]PRODTYP
    When 1 :    # O.F.
        [M:MKI2]BOMALT(nolign-1) = [F:MFI]BOMALT
    When Default :    # nomenclature ou autre
        [M:MKI2]BOMALT(nolign-1) = [F:MKI]BOMALT
 Endcase
 [M:MKI2]MFGNUM(nolign-1)     = [F:MKI]MFGNUM
 [M:MKI2]PJT(nolign-1)        = [F:MFI]PJT
 [M:MKI2]VCRNUMORI(nolign-1)  = [F:MFI]VCRNUMORI
 [M:MKI2]MFGTRKDAT(nolign-1)  = [F:MTK]MFGTRKDAT
 # Issue 92219 GA 10/2013
 # PE permettant de faire apparaitre dans la consultation des champs spécifiques de tables (idem CNSMKOSTD)
 GPOINT = "MKIMAJ" : Gosub ENTREE From EXEFNC

Next

Return

##################################################

$LOAD_FILTER

Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

#site
If [M:MKI1]MFGFCY <> ""
    CRITERE = "[F:MKI]MFGFCY=[M:MKI1]MFGFCY"
Gosub LOAD_CRITERE
Endif

# date de  suivi
If [M:MKI1]MFGDATDEB <> [0/0/0]
    CRITERE = "[F:MTK]MFGTRKDAT >=[M:MKI1]MFGDATDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKI1]MFGDATFIN <> [0/0/0]
    CRITERE = "[F:MTK]MFGTRKDAT <=[M:MKI1]MFGDATFIN"
Gosub LOAD_CRITERE
Endif

# article
If [M:MKI1]ITMREFDEB <> ""
    CRITERE = "[F:MKI]ITMREF >=[M:MKI1]ITMREFDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKI1]ITMREFFIN <> ""
   CRITERE = "[F:MKI]ITMREF <=[M:MKI1]ITMREFFIN"
Gosub LOAD_CRITERE
Endif


# n° de suivi
If [M:MKI1]MFGTNUMDEB<> ""
    CRITERE = "[F:MKI]MFGTRKNUM>=[M:MKI1]MFGTNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKI1]MFGTNUMFIN<> ""
   CRITERE = "[F:MKI]MFGTRKNUM<=[M:MKI1]MFGTNUMFIN"
Gosub LOAD_CRITERE
Endif


# n° O.F.
If [M:MKI1]MFGNUMDEB<> ""
    CRITERE = "[F:MKI]MFGNUM>=[M:MKI1]MFGNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:MKI1]MFGNUMFIN<> ""
   CRITERE = "[F:MKI]MFGNUM<=[M:MKI1]MFGNUMFIN"
Gosub LOAD_CRITERE
Endif

## GH 25/07/2014 bug 101627
# Gamme
If [M:CMKI]ROUNUMDEB<> ""
    CRITERE = "[F:MFG]ROUNUM>=[M:CMKI]ROUNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKI]ROUNUMFIN<> ""
    CRITERE = "[F:MFG]ROUNUM<=[M:CMKI]ROUNUMFIN"
Gosub LOAD_CRITERE
Endif
##

# nomenclature
If [M:CMKI]BOMNUMDEB<> ""
    CRITERE = "[F:MKI]ITMREF >= [M:CMKI]BOMNUMDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKI]BOMNUMFIN<> ""
    CRITERE = "[F:MKI]ITMREF <=[M:CMKI]BOMNUMFIN "
Gosub LOAD_CRITERE
Endif

# Alternative de nomenclature
If [M:CMKI]BOMALTDEB <>0
    CRITERE = "[F:MKI]BOMALT>=[M:CMKI]BOMALTDEB"
Gosub LOAD_CRITERE
Endif

If [M:CMKI]BOMALTFIN <>0
    CRITERE = "[F:MKI]BOMALT<=[M:CMKI]BOMALTFIN"
Gosub LOAD_CRITERE
Endif

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
# Affaire
#If [M:CMKI]PJTDEB <> ""
#    CRITERE = "[F:MFI]PJT>=[M:CMKI]PJTDEB"
#Gosub LOAD_CRITERE
#Endif
#
#If [M:CMKI]PJTFIN <> ""
#    CRITERE = "[F:MFI]PJT<=[M:CMKI]PJTFIN "
#Gosub LOAD_CRITERE
#Endif
If dim([M:CMKI]PJTDSPALL) >= 0 and [M:CMKI]PJTDSPALL = [V]CST_AYES and [M:CMKI]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CMKI]PJTDEB, SPJT, SBUDGET, STASK)
  CRITERE = "pat([F:MFI]PJT,'" + SPJT + "*')<>0"
  Gosub LOAD_CRITERE
Else
  If [M:CMKI]PJTDEB <> ""
      CRITERE = "[F:MFI]PJT>=[M:CMKI]PJTDEB"
  Gosub LOAD_CRITERE
  Endif

  If [M:CMKI]PJTFIN <> ""
      CRITERE = "[F:MFI]PJT<=[M:CMKI]PJTFIN "
  Gosub LOAD_CRITERE
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

# Commande
If [M:CMKI]VCRORIDEB <> ""
   CRITERE = "[F:MFI]VCRNUMORI>=[M:CMKI]VCRORIDEB "
Gosub LOAD_CRITERE
Endif

If [M:CMKI]VCRORIFIN <> ""
   CRITERE = "[F:MFI]VCRNUMORI<=[M:CMKI]VCRORIFIN "
Gosub LOAD_CRITERE
Endif

#Type de suivi
If [M:CMKI]PRODTYPDEB <>0
   CRITERE ="[F:MKI]PRODTYP>=[M:CMKI]PRODTYPDEB "
Gosub LOAD_CRITERE
Endif

If [M:CMKI]PRODTYPFIN <>0
    CRITERE="[F:MKI]PRODTYP<=[M:CMKI]PRODTYPFIN"
Gosub LOAD_CRITERE
Endif


Case CHGPAG
    When 3 : # rafraichissement
      Case [M:CMKI]TRI
        When 1 : # Tri par n° de suivi
              CRITERE ="[F:MKI]MFGTRKNUM >= DEBNUM"
              Gosub LOAD_CRITERE
        When 2 : # Tri par date de suivi
              CRITERE ="[F:MTK]MFGTRKDAT >= DEBDAT"
              Gosub LOAD_CRITERE
        When 3 : # Tri par n° OF
              CRITERE ="[F:MKI]MFGNUM >= DEBMFGNUM"
              Gosub LOAD_CRITERE
        When 4 : # Tri par article
              CRITERE ="[F:MKI]ITMREF >= DEBITM"
              Gosub LOAD_CRITERE
      Endcase

    When 2 : #suite
      Case [M:CMKI]TRI
        When 1 : # Tri par n° de suivi
             CRITERE ="[F:MKI]MFGTRKNUM > FINNUM"
             Gosub LOAD_CRITERE
        When 2 : # Tri par date de suivi
             CRITERE ="[F:MTK]MFGTRKDAT > FINDAT"
             Gosub LOAD_CRITERE
        When 3 : # Tri par n° OF
             CRITERE ="[F:MKI]MFGNUM > FINMFGNUM"
             Gosub LOAD_CRITERE
        When 4 : # Tri par article
             CRITERE ="[F:MKI]ITMREF > FINITM"
             Gosub LOAD_CRITERE
       Endcase

    When -2 : #retour
      Case [M:CMKI]TRI
         When 1 : # Tri par n° de suivi
             CRITERE ="[F:MKI]MFGTRKNUM < DEBNUM"
             Gosub LOAD_CRITERE
         When 2 : # Tri par date de suivi
             CRITERE ="[F:MTK]MFGTRKDAT < DEBDAT"
             Gosub LOAD_CRITERE
        When 3 : # Tri par n° OF
             CRITERE ="[F:MKI]MFGNUM < DEBMFGNUM"
             Gosub LOAD_CRITERE
        When 4 : # Tri par article
             CRITERE ="[F:MKI]ITMREF < DEBITM"
             Gosub LOAD_CRITERE
      Endcase
Endcase


If CRITERE1 = "" : CRITERE1 ="1=1" : Endif
If CRITERE2 = "" : CRITERE2 ="1=1" : Endif
If CRITERE3 = "" : CRITERE3 ="1=1" : Endif


Return

########################################
$LOAD_CRITERE
If len(CRITERE)+len(CRITERE1)+1 <255
    If len(CRITERE1) <>0 : CRITERE1 += "&" : Endif
    CRITERE1 += CRITERE
Elsif len(CRITERE)+len(CRITERE2)+1 <255
    If len(CRITERE2) <>0 : CRITERE2 += "&" : Endif
    CRITERE2 += CRITERE
Else
    If len(CRITERE3) <>0 : CRITERE3 += "&" : Endif
    CRITERE3 += CRITERE
Endif

Return

###################################################################################
#                                                                                 #
#    ETIQUETTES ECRAN                                                             #
#                                                                                 #
###################################################################################
########################################
#article
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    [M]ITMREFFIN = VALEUR
Endif
End

########################################
# article
Subprog C_ITMREFFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFDEB
    GMESSAGE = mess(44,199,1) : mkstat = 2 : End
Endif
End

########################################
# date suivi
Subprog AM_MFGDATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0]
    [M]MFGDATFIN = VALEUR
Endif
End

########################################
# date suivi
