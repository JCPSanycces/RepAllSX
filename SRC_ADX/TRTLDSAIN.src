#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Informations lead                                                 Module CRM          07 novembre 2000 #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:LDS]) : Local File LEAD [LDS] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:HD8]) : Local File HD8CLOB [HD8] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If PARAM(1) = "" Then
    Return
  Endif
  Read [LDS]LDS0=PARAM(1)
  If fstat <> 0 Then
    FIN = 1
    #Cet interlocuteur n'a pas d'information origine.
    GMESSAGE = mess(468,177,1)
    GERR = 3
    Return
  Endif
  #
  Raz [F:BPA]
  Filter [BPA] Where [F:BPA]BPATYP = 6 and [F:BPA]BPANUM = [F:LDS]PSTNUM and [F:BPA]BPAADDFLG = 2
  For [BPA]
    Break
  Next
  Filter [BPA]
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:LDSA] = [F:LDS]
  [M:LDSC] = [F:LDS]
  [M:LDSF] = [F:LDS]
  #
  [M:LDSC]CPYBPADES = [F:BPA]BPADES
  [M:LDSC]CPYADD(0) = [F:BPA]BPAADDLIG(0)
  [M:LDSC]CPYADD(1) = [F:BPA]BPAADDLIG(1)
  [M:LDSC]CPYADD(2) = [F:BPA]BPAADDLIG(2)
  [M:LDSC]CPYZIP = [F:BPA]POSCOD
  [M:LDSC]CPYCTY = [F:BPA]CTY
  If dim([M:LDSC]CPYSAT)>0 Then
    [M:LDSC]CPYSAT = [F:BPA]SAT
  Endif
  [M:LDSC]CPYCRY = [F:BPA]CRY
  [M:LDSC]CPYCRYNAM = [F:BPA]CRYNAM
  [M:LDSC]CPYEML = [F:BPA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
  [M:LDSC]CPYTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
  [M:LDSC]CPYFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
  [M:LDSC]CPYMOB = [F:BPA]TEL(4)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]MOB
  #---------------------------------------------------#
  #Clob
  If [M:LDSF]NUMCLOB <> "" Then
    Read [HD8]HD80=[M:LDSF]NUMCLOB;"LDS"
    If fstat <> 0 Then
      Raz [M:LDSF]CLOB
    Else
      [M:LDSF]CLOB = [F:HD8]CLOB
      [M:LDSF]NUMCLOB = [F:HD8]NUM
    Endif
  Endif
  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  If [M:LDSA]CREUSR <> "" Then
    Read [AUS]CODUSR=[M:LDSA]CREUSR
    If fstat = 0 Then
      [M:LDSA]FULNAMUSR = [F:AUS]NOMUSR
    Endif
    Affzo [M:LDSA]FULNAMUSR
  Endif
  [M:LDSA]PSTORILIB = mess([M:LDSA]PSTORITYP,3037,1)
  If [M:LDSA]PSTORI = 1 Then
    [M:LDSA]PSTORITXT = ""
  Else
    [M:LDSA]PSTORITXT = mess([M:LDSA]PSTORI,2992,1)
  Endif
  #Définition du type de pièce
  Case [M:LDSA]PSTORI
    When 0
      [M:LDSA]PSTORIOBC = ""
    When 1
      [M:LDSA]PSTORIOBC = ""
    When 2
      [M:LDSA]PSTORIOBC = "OMM"
    When 3
      [M:LDSA]PSTORIOBC = "OMP"
    When 4
      [M:LDSA]PSTORIOBC = "OMT"
    When 5
      [M:LDSA]PSTORIOBC = "OMN"
    When 6
      [M:LDSA]PSTORIOBC = "CMG"
    When Default
      Raz [M:LDSA]PSTORIOBC
  Endcase
  Diszo [M:LDSA]PSTORIVCR
  Diszo [M:LDSA]PSTORITXT
  Diszo [M:LDSF]CLOB
  Affzo [M:LDSA]1-99
  Affzo [M:LDSC]1-99
  Affzo [M:LDSF]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

