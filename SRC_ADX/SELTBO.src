#<AdxTL>@(#)5.0.0.0 $Revision$
# Subprog SELTBO(ALT,ACC)  Sélection des alternatives nomenclature 
#                          pour les traitements nomenclature.
##################################################################
#CHECK UNUSED_BEGIN
Local Integer ALT(100), I 
Local Char    ACC(5)(100) , message(80) 
ALT=0
Call SELTBO(ALT,ACC)
MESSAGE = "Sélectionnés :" 
For I=0 To 99 
If alt(i) <> 0 : MESSAGE -= num$(alt(i)) : Else  Break : Endif 
Next 
Call message(message) From GESECRAN 
End
#CHECK UNUSED_END

Subprog SELTBO(ALT,TYP,ACC)
Variable Integer ALT(0..)
Variable Integer TYP(0..)
Variable Char    ACC()(0..)
Local    Integer I, REPONSE 

Local Integer RELIT
Onerrgo ERREUR From CONTROLE
If clalev([F:TBO])=0
 Local File TABBOMALT [TBO]
Else
 RELIT=1
Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Mask SLBA [SLBA]
Local Mesbox Mask SLBA  
& Button mess(64,123,1),mess(5,123,1) With left$(mess(64,123,1),1), left$(mess(5,123,1),1)  
& Coded GSTAOK, GSTAFIN  
& Titled mess(26,195,1) As [SLBA]
 
Boxact [SLBA] : Raz [M]

# Alternatives
nolign = 0
For [TBO]
    nolign += 1
    [M:SLBA] = [F:TBO]
    If nolign > dim([M:SLBA]BOMALT) - 1 : Break : Endif
Next
If nolign > 0 
 [M]BASPAG = nolign 
 Affzo [SLBA]
 Boxinp [SLBA] Using REPONSE 
Else
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=2 : End
Endif
 
# MESSAGE = "reponse="+num$(reponse)+ " et GSTAOK="+num$(GSTAOK) 
# Call message(message) From gesecran 
 
Case REPONSE 
  When GSTAOK 
     I = 0 
     For nolign = 1 To [M:SLBA]BASPAG
         If [M:SLBA]COCHE(nolign-1) = "x"
            ALT(I) = [M:SLBA]BOMALT(nolign-1)
            TYP(I) = [M:SLBA]BOMALTTYP(nolign-1)
            ACC(I) = [M:SLBA]ACSCOD(nolign-1)
            I += 1
         Endif
     Next nolign
  When Default : mkstat=2
Endcase

End

# Etiquettes de zones
########################################
Subprog AS_BASPAG
# Bouton Séléction
GBOUT1 = mess(36,198,1)
End

Subprog B1_BASPAG
If [M:SLBA]COCHE(nolign-1) = ""
   [M:SLBA]COCHE(nolign-1) = "x"
Else
   [M:SLBA]COCHE(nolign-1) = ""
Endif
Affzo [M:SLBA]COCHE(nolign-1)
End


Subprog AS_COCHE(VALEUR)
Variable Char     VALEUR
# If VALEUR = "x" : VALEUR = "" : Else : VALEUR = "x" : Endif
If [M]COCHE(nolign-1) = "x" : VALEUR = "" : Else : VALEUR = "x" : Endif 
End
