#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour ATYPEPRO
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update fields on ATYPEPRO table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Local Integer ERR : ERR=0
If DOSSIER=nomap
 Local File ATYPEPRO [ATYP]
Else
 Local File =DOSSIER+".ATYPEPRO"  [ATYP]
Endif
Filter [ATYP]

If dim([F:ATYP]PREFLG)>0
Gosub ATYP_UPD1
Endif

Close Local File
End

#-------------------#
$ATYP_UPD1

# Mise à jour de la table ATYPEPRO
Call ECR_TRACE("ATYP_UPD1"-mess(81,125,1)-DOSSIER+".ATYPEPRO:"-time$,0) From GESECRAN

Trbegin [ATYP]
For [ATYP] Where PREFLG=0

  If [F:ATYP]PREFLG=0
   [F:ATYP]PREFLG=1
  Endif

  Rewrite [ATYP]
  If fstat
   Call ERREUR("ATYPEPRO"-[F:ATYP]COD,2) From DOSDIC
  Endif
Next ATYP
Commit
Return
