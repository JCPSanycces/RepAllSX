#<AdxTL>@(#)0.0.0.0 $Revision$
##########################
# Pre-Process a BAI2 file
##########################

Gosub READFILE
End

$READFILE
Dbgaff
  Local Char FILNAMTMP(255) : FILNAMTMP  = "/folders/REPOSX3/tmp/CHASE.txt"
  Local Char FLDSEP(1)      : FLDSEP     = ","
  Local Char RECORDTYPE(2)  : RECORDTYPE = ""
  Local Char PRVRECTYPE(2)  : PRVRECTYPE = ""
  Local Clbfile LINE(1)
  Local Clbfile PRVLOGREC(9): PRVLOGREC = ""
  Call OUVRE_TRACE ("Import File") From LECFIC
  Openi FILNAMTMP Using [REPS]
  adxifs = ''
  # If End-Of-Record has to be read from a parameter:
  Local Char EOR : EOR = "chr$(13) + chr$(10)"
  adxirs = evalue(EOR)  # EOR is supposed to have been read from the database
  # If End-Of-Record can be hard-coded as CR/LF:
  #adxirs = chr$(13) + chr$(10)
  Iomode adxium GASCII
  fstat = 0
  Repeat
    Rdseq LINE Using [REPS]
    If !fstat
      Gosub PARSE_LINE
    Endif
  Until fstat
  If PRVLOGREC <> ""
    Gosub SHOW_RECORD
  Endif
  Openi Using [REPS]
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return

$PARSE_LINE
  Local Integer I
  I = instr(1, LINE, FLDSEP)
  If I <> 0
    RECORDTYPE = seg$(LINE, 1, I - 1)
    Case RECORDTYPE
      When "88":
        If PRVRECTYPE <> "16"
          If right$(PRVLOGREC, len(PRVLOGREC)) = "/"
            PRVLOGREC = left$(PRVLOGREC, len(PRVLOGREC) - 1) + ","
          Endif
        Endif
        PRVLOGREC += right$(LINE, I + 1)
      When Default:
        If PRVLOGREC <> ""
          Gosub SHOW_RECORD
        Endif
        PRVLOGREC = LINE
        PRVRECTYPE = RECORDTYPE
        If RECORDTYPE = "16"
          If right$(PRVLOGREC, len(PRVLOGREC) - 1) = ",/"
            PRVLOGREC = left$(PRVLOGREC, len(PRVLOGREC) - 1)
          Endif
          If right$(PRVLOGREC, len(PRVLOGREC)) = "/"
            PRVLOGREC = left$(PRVLOGREC, len(PRVLOGREC) - 1) + ","
          Endif
        Endif
    Endcase
  Endif
Return

$SHOW_RECORD
  If PRVRECTYPE <> "16"
    If right$(PRVLOGREC, len(PRVLOGREC)) = "/"
      PRVLOGREC = left$(PRVLOGREC, len(PRVLOGREC) - 1)
    Endif
  Endif
  # Infbox PRVLOGREC Titled num$(len(PRVLOGREC))
  Local Integer L, M
  Local Char    C(115)
  L = 1
  While L < len(PRVLOGREC)
    C = ""
    For M = 1 To 115
      If mid$(PRVLOGREC, L + M - 1, 1) <> "\"
        C += mid$(PRVLOGREC, L + M - 1, 1)
      Else
        C += "Ñ"
      Endif
    Next M
    Call ECR_TRACE(C, 0) From GESECRAN
    L += 115
  Wend
Return

