#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:46 380

Gosub TEST From WMCR_BSIIMPTC : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,BSICODTC,BAN)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# BSIIMPTC : BSIIMPTC
# BSIITCD : BSIIMPTC BSIITCD
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet BSIIMPTC._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = BSIIMPTC.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(BSIIMPTC.ACTX.AFOLDER,nomap,"")>0
 Local File BSIIMPTC [BSITC]
 Local File BSIITCD [BSITCD]
 Local File ATEXTRA [AXX]
Else
 Local File =BSIIMPTC.ACTX.AFOLDER+".BSIIMPTC" [BSITC]
 Local File =BSIIMPTC.ACTX.AFOLDER+".BSIITCD" [BSITCD]
 Local File =BSIIMPTC.ACTX.AFOLDER+".ATEXTRA" [AXX]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [BSITC] With
& [BSITCD]BSITCD0 = [F:BSITC]BSICODTC;[F:BSITC]BAN
& As [LNK_]
Return

############################################################################################
### BSIIMPTC(WBSITC)
############################################################################################
Funprog  _MAJSQL_BSIIMPTC(WBSITC)
Variable Instance WBSITC Using C_BSIIMPTC
Local Integer ASTATUS,A_I,A_J
Default File [F:BSITC]
If WBSITC.ASTALIN=[V]CST_ANEW
 Call INICRE(WBSITC) From ASYRSUB
 SetInstance [F:BSITC] With WBSITC
 For J=1 To maxtab(WBSITC.AXX)
  If WBSITC.AXX(J)<>null & WBSITC.AXX(J).PRO= "DESAXX" & WBSITC.AXX(J).FLG>0
   Call MAJTEXTRALAN(WBSITC,WBSITC.AXX(J).TEX,"BSIIMPTC","DESAXX",WBSITC.AXX(J).LAN,WBSITC.BSICODTC,"",[L]ASTATUS) From ASYRSUB
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next J
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 Write [F:BSITC]
 If fstat
  Call FSTA("BSITC",WBSITC,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WBSITC.updTick = [F:BSITC]updTick
Elsif WBSITC.ASTALIN=[V]CST_ALL or WBSITC.ASTALIN=[V]CST_AUPD
 Call INIUPD(WBSITC) From ASYRSUB
 SetInstance [F:BSITC] With WBSITC
 For J=1 To maxtab(WBSITC.AXX)
  If WBSITC.AXX(J)<>null & WBSITC.AXX(J).PRO= "DESAXX" & WBSITC.AXX(J).FLG>0
   Call MAJTEXTRALAN(WBSITC,WBSITC.AXX(J).TEX,"BSIIMPTC","DESAXX",WBSITC.AXX(J).LAN,WBSITC.BSICODTC,"",[L]ASTATUS) From ASYRSUB
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next J
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WBSITC,"BSIIMPTC")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:BSITC]BSITC0 = [F:BSITC]BSICODTC;[F:BSITC]BAN
 If fstat
  Call FSTA("BSITC",WBSITC,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WBSITC.updTick = [F:BSITC]updTick
Elsif WBSITC.ASTALIN=[V]CST_ADEL
 SetInstance [F:BSITC] With WBSITC
 For J=1 To maxtab(WBSITC.AXX)
  If WBSITC.AXX(J)<>null & WBSITC.AXX(J).PRO= "DESAXX"
   Call SUPTEXTRA(WBSITC,WBSITC.AXX(J).TEX,"BSIIMPTC","DESAXX",WBSITC.AXX(J).LAN,WBSITC.BSICODTC,"",[L]ASTATUS) From ASYRSUB
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next J
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WBSITC,"BSIIMPTC")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:BSITC]BSITC0 = [F:BSITC]BSICODTC;[F:BSITC]BAN
 If fstat
  Call FSTA("BSITC",WBSITC,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

############################################################################################
### BSIITCD(WBSITCD)
############################################################################################
Funprog  _MAJSQL_BSIITCD(WBSITCD)
Variable Instance WBSITCD Using C_BSIITCD
Local Integer ASTATUS,A_I,A_J
Default File [F:BSITCD]
If WBSITCD.ASTALIN=[V]CST_ANEW
 Call INICRE(WBSITCD) From ASYRSUB
 SetInstance [F:BSITCD] With WBSITCD
 For J=1 To maxtab(WBSITCD.AXX)
  If WBSITCD.AXX(J)<>null & WBSITCD.AXX(J).PRO= "DESAXX" & WBSITCD.AXX(J).FLG>0
   Call MAJTEXTRALAN(WBSITCD,WBSITCD.AXX(J).TEX,"BSIIMPTC","DESAXX",WBSITCD.AXX(J).LAN,WBSITCD.BSICODTC,WBSITCD.COD,[L]ASTATUS) From ASYRSUB
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next J
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 Write [F:BSITCD]
 If fstat
  Call FSTA("BSITCD",WBSITCD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WBSITCD.updTick = [F:BSITCD]updTick
Elsif WBSITCD.ASTALIN=[V]CST_ALL or WBSITCD.ASTALIN=[V]CST_AUPD
 Call INIUPD(WBSITCD) From ASYRSUB
 SetInstance [F:BSITCD] With WBSITCD
 For J=1 To maxtab(WBSITCD.AXX)
  If WBSITCD.AXX(J)<>null & WBSITCD.AXX(J).PRO= "DESAXX" & WBSITCD.AXX(J).FLG>0
   Call MAJTEXTRALAN(WBSITCD,WBSITCD.AXX(J).TEX,"BSIIMPTC","DESAXX",WBSITCD.AXX(J).LAN,WBSITCD.BSICODTC,WBSITCD.COD,[L]ASTATUS) From ASYRSUB
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next J
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WBSITCD,"BSIITCD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:BSITCD]BSITCD0 = [F:BSITCD]BSICODTC;[F:BSITCD]BAN;[F:BSITCD]COD
 If fstat
  Call FSTA("BSITCD",WBSITCD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WBSITCD.updTick = [F:BSITCD]updTick
Elsif WBSITCD.ASTALIN=[V]CST_ADEL
 SetInstance [F:BSITCD] With WBSITCD
 For J=1 To maxtab(WBSITCD.AXX)
  If WBSITCD.AXX(J)<>null & WBSITCD.AXX(J).PRO= "DESAXX"
   Call SUPTEXTRA(WBSITCD,WBSITCD.AXX(J).TEX,"BSIIMPTC","DESAXX",WBSITCD.AXX(J).LAN,WBSITCD.BSICODTC,WBSITCD.COD,[L]ASTATUS) From ASYRSUB
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next J
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WBSITCD,"BSIITCD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:BSITCD]BSITCD0 = [F:BSITCD]BSICODTC;[F:BSITCD]BAN;[F:BSITCD]COD
 If fstat
  Call FSTA("BSITCD",WBSITCD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



