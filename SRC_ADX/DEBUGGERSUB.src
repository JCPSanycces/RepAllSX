#<AdxTL>@(#)10.0.0.0 $Revision$
######################################################################
# MSK DEBUGGER1 Mode pas à pas
# Mode Trace
######################################################################

Subprog B1_TRAVNB
Local Char    PRG_(GLONADC)
Local Integer REPONSE
Local Integer DIM_ , IND_ , NOL_
DIM_ = 1000
NOL_ = nolign-1
Local Char TEX_(250)(1..DIM_) , TEX__(250)(1..DIM_)
If [M:DBG]TRAEXP([S]nolign-1)<>""
 PRG_ = GPROGRAMME
 GPROGRAMME = ""
 Gosub OUVRE_BOITE From WGDEBUGGERB
 Onerrgo ERREUR
 Setlob [M:DBGB]AFF_VAR With num$(evalue([M:DBG]TRAEXP(NOL_)))
 Setlob TEX_ With [M:DBGB]AFF_VAR
 For IND_=1 To DIM_
  If TEX_(IND_)<>""
   TEX__(IND_) = TEX_(IND_)+chr$(10)
  Endif
 Next IND_
 Setlob [M:DBGB]AFF_VAR With TEX__
 Onerrgo ERREUR
 Affzo [M:DBGB]AFF_VAR
 Gosub SAISIE_BOITE From WGDEBUGGERB
 Gosub FERME_BOITE From WGDEBUGGERB
 Gosub FERME_MASK From WGDEBUGGERB
 GPROGRAMME = PRG_
Endif
End

Subprog AV_TRAVAL(VALEUR)
  Variable Char    VALEUR()
  Local Integer DBG_ERR
  VALEUR = ""
  Onerrgo ERREUR
  ## JML/JCD 04/07/00 il ne faut plus l'argument ,1 du evalue() !
  VALEUR = evalue([M:DBG]TRAEXP([S]indice))
  Onerrgo
End

######################################################################
Subprog AS_TRAFIC(VALEUR)
Variable Char     VALEUR()

If [M:DBG]TRATRA<>2 : mkstat=1 : End : Endif

Local Integer DBG_NL
Local Char    DBG_NOMPRG(250)

If VALEUR=""
 [L]DBG_NOMPRG = [LDB]DGNOMPRG
 [L]DBG_NL     = instr( 1, [L]DBG_NOMPRG, 'TRT' )
 If [L]DBG_NL
  [L]DBG_NOMPRG = right$([L]DBG_NOMPRG,[L]DBG_NL+4)
 Endif
 [L]DBG_NL     = instr( 1, [L]DBG_NOMPRG, '$' )
 If [L]DBG_NL
  [L]DBG_NOMPRG = left$([L]DBG_NOMPRG,[L]DBG_NL-1)
 Endif
 VALEUR = filpath("tmp",GUSER,"dbg")
Endif
End

######################################################################
Subprog C_TRAFIC(VALEUR)
Variable Char     VALEUR()

Local Char    DBG_OPENI(250)(2)            : # Pour adxcio, 0=openi, 1=openo
Local Integer DBG_ADXSEEK(2)               : # Pour adxcio
Local Char    DBG_SAVIFS(5), DBG_SAVIRS(5)
Local Integer DBG_OK , DBG_SAVIUM

[L]DBG_OK = 2

If filinfo(filpath("",VALEUR,""),7)>0
 [L]DBG_SAVIFS = adxifs
 [L]DBG_SAVIRS = adxirs
 [L]DBG_SAVIUM = adxium

 Call AVERTIR(mess(32,2,0),[L]DBG_OK) From GESECRAN
 
 # JML 17/09/99 Débug export, conserver le fichier déjà ouvert
 Raz [L]DBG_OPENI, [L]DBG_ADXSEEK
 
 # Pbl tokenisation pour adxcio, jcd n'a pas envoyé rcptok à MGA
 # JML 17/09/99 De plus en 110 ADXCIO renvoi n'importe quoi, dixit JCD
 #              Sur Unix ADXNFS(0) renvoi '', sur NT @nomap.Nom_trt.src !!
 #              et Boum, mais la vache savait nager...
 If adxcio(1)<>-1 
  [L]DBG_OPENI(1)   = adxnfs(adxcio(1)) : # Toujours pbl token adxnfs !!
  [L]DBG_ADXSEEK(1) = adxseek(1)
 Endif

 adxifs = ""
 adxirs = chr$(10)

 If [L]DBG_OK=2
  Openo VALEUR , 0 Using [DBG]   : # On écrase !
 Else
  Openo VALEUR , -1 Using [DBG]  : # On conserve l'existant !
  Wrseq string$(15,"*")-format$("D:"+GFMDAT,date$)-time$-string$(15,"*") Using [DBG]
 Endif

 Openo Using [DBG]

 adxifs = [L]DBG_SAVIFS
 adxirs = [L]DBG_SAVIRS
 adxium = [L]DBG_SAVIUM

Endif

If !find(status,20,21) & status<200
 zonsui = "TRATNB("+num$([LDB]DGNOLIGN-1)+")"
Endif
End

######################################################################
Subprog C_TRATRT(VALEUR)
Variable Char    VALEUR()
VALEUR = [M]TRATRT(nolign-1)
End

######################################################################
Subprog AS_TRATNB
Raz GBOUT1, GBOUT2
GBOUT1 = mess(3,40,1)-mess(128,124,1) : # Ligne Origine
End

######################################################################
Subprog B1_TRATNB
Local Integer DBG_I
zonsui = "TRATNB("+num$([LDB]DGNOLIGN-1)+")"
# JML 18/10/99 71 = Changement ligne dixit JCD (Bug 3442)
status = 71
mkstat = 3
End

######################################################################
Subprog B2_TRATNB
End    

######################################################################
Subprog AV_TRAEXP(VALEUR)
Variable Char     VALEUR()
pcolor = GCOUL(0)
If [M]TRANIV(nolign-1)<>0
 pcolor = GCOUL(1)
Endif
End

######################################################################
Subprog AS_TRAEXP(VALEUR)
Variable Char     VALEUR()
If [M]TRANIV(nolign-1)<>0
 mkstat = 2 : End
Endif
End

######################################################################
Subprog C_TRABPT(VALEUR)
Variable Char    VALEUR()
Local Integer DBG_NL
Local Char    DBG_NOMPRG(250)
# JML 15/03/99, il faut regarder si juste No ligne, rajouter trtcou pour ne pas
#               tomber sur le superbe TRT debugger !!
If val(VALEUR)>0
 # Alors, il n'y a pas le nom du traitement
 [L]DBG_NOMPRG = [LDB]DGNOMPRG
 [L]DBG_NL     = instr( 1, [L]DBG_NOMPRG, 'TRT' )
 If [L]DBG_NL
  [L]DBG_NOMPRG = right$([L]DBG_NOMPRG,[L]DBG_NL+4)
 Endif
 [L]DBG_NL     = instr( 1, [L]DBG_NOMPRG, '$' )
 If [L]DBG_NL
  [L]DBG_NOMPRG = left$([L]DBG_NOMPRG,[L]DBG_NL-1)
 Endif
 VALEUR = [L]DBG_NOMPRG+":"+VALEUR
Endif
VALEUR = toupper(VALEUR)
End

######################################################################
# MSK DEBUGGER6
######################################################################

######################################################################
# Sélection d'une classe de variable
######################################################################

Subprog S_CLANOM(VALEUR)
Variable Char    VALEUR()

Local Integer DBG_I, DBG_J
Local Integer DBG_NB
[L]DBG_NB = dim([M:DBG5]CLANA)-1

Local Char    DBG_T(15)([L]DBG_NB)
Local Integer DBG_N([L]DBG_NB)

[L]DBG_J = 0
For [L]DBG_I = 1 To [L]DBG_NB
   If clanam([L]DBG_I) <> ""
      [L]DBG_T([L]DBG_J)  = format$("N0:3#",[L]DBG_I)-clanam([L]DBG_I)
      [L]DBG_N([L]DBG_J)  = [L]DBG_I
      [L]DBG_J += 1
   Endif
Next
[L]DBG_I = 1

Call SAITEX([L]DBG_J-1,[L]DBG_T(0..[L]DBG_J-1),[L]DBG_I,"") From GESECRAN

[L]DBG_I += 1
If [S]status <> 7
   VALEUR = right$([L]DBG_T([L]DBG_I-1),5)
   [M:DBG6]VARNCL = -[L]DBG_N([L]DBG_I-1)
Endif
End

######################################################################
# Visualisation d'une classe de variables
######################################################################

Subprog C_CLANOM(VALEUR)
Variable Char     VALEUR()

If VALEUR=[M:DBG6]CLANOM : End : Endif

Effzo VARNBR, VARNCL, 10 : # Mieux vaut faire du ménage avant de charger....

Local Integer DBG_NB
[L]DBG_NB = dim([M:DBG5]CLANA)-1

Local Integer DBG_I
Local Integer DBG_J
Local Integer DBG_K
Local Integer DBG_L
Local Integer DBG_M
Local Integer DBG_ERR
Local Char    DBG_S(250)
Local Char    DBG_FMT(16), DBG_EXP(250)
Local Char    DBG_CLANOM(20)

# A-t-on donne le numero de classe ?
If val(VALEUR)<0
 VALEUR = num$(val(VALEUR)*-1)
Endif

If val(VALEUR)>0
   [M:DBG6]VARNCL = val(VALEUR)
   VALEUR         = toupper(clanam([M:DBG6]VARNCL))
Else : # C'est de l'alpha, va falloir trouver la classe...
   [M:DBG6]VARNCL = 0
   VALEUR = toupper(VALEUR)
Endif

# Voyons les crochets
If !instr(1,VALEUR,"[")
 VALEUR = "["+toupper(VALEUR)+"]"
Endif

If [M:DBG6]VARNCL=0
 For [L]DBG_J = 1 To [L]DBG_NB
 ##   If instr(1,clanam([L]DBG_J),VALEUR)<>0
  If clanam([L]DBG_J)=VALEUR
    Break
  Endif
 Next [L]DBG_J
 If [L]DBG_J>[L]DBG_NB
   Infbox "Classe inexistante"
   mkstat = 2
   End
 Endif
 [M:DBG6]VARNCL = [L]DBG_J
Endif

VALEUR = toupper(clanam([M:DBG6]VARNCL))
[M:DBG6]CLANOM = VALEUR

If [M:DBG6]VARNCL<>0
 [M:DBG6]VARNBR = clanbs([M:DBG6]VARNCL,1)
Endif

[M:DBG6]VARBAS = min([M:DBG6]VARNBR,dim([M:DBG6]VARNOM)-1)
For [L]DBG_J = 1 To [M:DBG6]VARBAS
 [M:DBG6]VARNOM([L]DBG_J-1) = vireblc(format$("KT:12X",clavar([M:DBG6]VARNCL,[L]DBG_J)),4)

 If [M:DBG6]VARNOM([L]DBG_J-1)<>"" & ( [M:DBG6]VARNCL<[L]DBG_NB | !clalev([M:DBG6]VARNCL+1) )
   # VARTYP
   [L]DBG_CLANOM = [M:DBG6]CLANOM
   If [L]DBG_CLANOM="[L:L]"
    [L]DBG_CLANOM = ""
   Endif
   [L]DBG_I = evalue("type("+[L]DBG_CLANOM+[M:DBG6]VARNOM([L]DBG_J-1)+")")
   If ([L]DBG_I < 1)
      [M:DBG6]VARTYP([L]DBG_J-1) = ""
   Elsif [L]DBG_I < 10
      # JML 01/04/99 Si type vaut 8 (var. bas de tableau)
      If [L]DBG_I=8
       [L]DBG_I = 4
      Endif
      [M:DBG6]VARTYP([L]DBG_J-1) = mess([L]DBG_I,44,0)
   Else
      [M:DBG6]VARTYP([L]DBG_J-1) = "$"+format$("N0:3#",[L]DBG_I-10)
   Endif

   # VARDIM
   [L]DBG_S              = "dim("+[L]DBG_CLANOM+[M:DBG6]VARNOM([L]DBG_J-1)+","
   [L]DBG_L              = evalue([L]DBG_S+"-1)")
   [M:DBG6]VARDIM([L]DBG_J-1) = "("+num$([L]DBG_L)
   [L]DBG_K = evalue([L]DBG_S+"1)")
   If[L]DBG_K>1
      [M:DBG6]VARDIM([L]DBG_J-1) += ".."+num$([L]DBG_L+[L]DBG_K-1)
   Endif

   [L]DBG_M = evalue([L]DBG_S+"0)")
   [L]DBG_I = 2

   While [L]DBG_I <= [L]DBG_M
       [L]DBG_L = evalue([L]DBG_S+num$(-[L]DBG_I)+")")
       [M:DBG6]VARDIM([L]DBG_J-1)  += ","+num$([L]DBG_L)
       [L]DBG_K = evalue([L]DBG_S+num$([L]DBG_I)+")")
       If [L]DBG_K > 1
          [M:DBG6]VARDIM([L]DBG_J-1) += ".."+num$([L]DBG_L+[L]DBG_K-1)
       Endif
       [L]DBG_I += 1
   Wend
   [M:DBG6]VARDIM([L]DBG_J-1) += ")"
 Endif

 # VARVAL
 Gosub AV_VARVAL

Next [L]DBG_J

Sorta [M:DBG6]VARBAS [M:DBG6]VARBAS Order By [M:DBG6]VARNOM([S]indice)

Affzo VARNCL, 10
zonsui = "VARNOM(0)"
End

######################################################################
$AV_VARVAL
If [M:DBG6]VARNOM([L]DBG_J-1)<>"" & ( [M:DBG6]VARNCL<[L]DBG_NB | !clalev([M:DBG6]VARNCL+1) )
 [L]DBG_I = evalue("type("+[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J-1)+")")
 Case [L]DBG_I
     When -1 : # Var. inex.
         Local Libelle DBG_VAL 
         [L]DBG_FMT = ""
     When 1  : # Libellé
         Local Libelle DBG_VAL 
         [L]DBG_FMT = "N:3#"
     When 2  : # Entier court (Short)
         Local Shortint DBG_VAL 
         [L]DBG_FMT = "N:6#"
     When 3  : # Date
         Local Date DBG_VAL     
         [L]DBG_FMT = "D:"+GFMDAT4
     When 4  : # Entier long (Integer)
         Local Integer DBG_VAL  
         [L]DBG_FMT = "N:10#"
     When 5  : # Nbre flottant (Float Obsolète)
         Local Float DBG_VAL    
         [L]DBG_FMT = "N:9F"
     When 6  : # Nbre Double précision (Double Obsolète)
         Local Double DBG_VAL   
         [L]DBG_FMT = "N:15F"
     When 7,9 : # DCB et DCB IBM (Decimal)
         Local Decimal DBG_VAL  
         [L]DBG_FMT = "N:26F"
     When 8  : # JML 01/04/99 Var. Bas de tableau Entier long (Integer)
         Local Integer DBG_VAL  
         [L]DBG_FMT = "N:10#"
     When Default 
         If [L]DBG_I<11 | [L]DBG_I>265
          #Infbox "type("+[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J-1)+")="+num$([L]DBG_I)
          [L]DBG_I = 265 
         Endif
         Local Char DBG_VAL([L]DBG_I-10) 
         [L]DBG_FMT = "K:"+num$([L]DBG_I-10)+"X"
 Endcase

 [L]DBG_S = "dim("+[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J-1)+","
 [L]DBG_K = evalue([L]DBG_S+"0)")

 If [L]DBG_K > 1
     ###########
     Onerrgo ERREUR
     [L]DBG_EXP=[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J-1)+"("
     For [L]DBG_I = 1 To [L]DBG_K
         [L]DBG_EXP += num$(evalue([L]DBG_S+num$(-[L]DBG_I)+")"))
         If [L]DBG_I < [L]DBG_K
             [L]DBG_EXP += ","
         Endif
     Next [L]DBG_I
     [L]DBG_EXP += ")"

     If [LDB]DBG_TRACON=1
      Infbox "DBG_EXP ="-num$([L]DBG_EXP)
     Endif

     [L]DBG_VAL = evalue( [L]DBG_EXP )
     Onerrgo  
     ###########
     If ([L]DBG_FMT = "")
         [M:DBG6]VARVAL([L]DBG_J-1) = ""
     Else
         [M:DBG6]VARVAL([L]DBG_J-1) = format$([L]DBG_FMT,[L]DBG_VAL)+",..."
     Endif
 Else
     [L]DBG_I = evalue([L]DBG_S+"-1)")
     [L]DBG_L = evalue([L]DBG_S+"1)")
     If [L]DBG_L=0
      [L]DBG_L = 1
     Endif
     For [L]DBG_K = [L]DBG_I To [L]DBG_I+[L]DBG_L-1
         ###########
         Onerrgo ERREUR
         [L]DBG_ERR = 0
         [L]DBG_VAL = evalue([M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J-1)+"("+num$([L]DBG_K)+")")
         If [L]DBG_ERR <> 0
             Break
         Endif  
         Onerrgo
         ###########
         If [L]DBG_K <> [L]DBG_I
             [M:DBG6]VARVAL([L]DBG_J-1) += ","
         Else 
             [M:DBG6]VARVAL([L]DBG_J-1) = ""
         Endif
         If [L]DBG_FMT<>""
             [M:DBG6]VARVAL([L]DBG_J-1) += vireblc(format$([L]DBG_FMT,[L]DBG_VAL),1) : # En fin de chaine
             If len([M:DBG6]VARVAL([L]DBG_J-1)) > 100
                 Break
             Endif
         Endif
     Next
 Endif
Endif  
Return

######################################################################
# Modification d'une variable
######################################################################

Subprog AS_VARBAS
Raz GBOUT1
If [M:DBG6]VARBAS & GDEBUG
 GBOUT1 = mess(3,85,1) : # Modification
Endif
End

Subprog B1_VARBAS

Local Integer DBG_OK, DBG_I
Local Integer DBG_MONO        : # Pour savoir si tableau à +ieurs dimension
Local Integer DBG_DIM         : # Pour savoir si tableau mono dimension
Local Integer DBG_TYP         : # Pour savoir si Alpha, numérique etc...
Local Integer DBG_IND         : # Indice départ tableau suivant (0..2) ou (1..2)
Local Char    DBG_CHAINEA(250) : # Pour affectation valeur

# Pour Gosub AV_VARVAL
Local Integer DBG_J
Local Integer DBG_K
Local Integer DBG_L
Local Integer DBG_ERR
Local Char    DBG_S(250)
Local Char    DBG_FMT(16), DBG_EXP(250)
Local Integer DBG_NB

[L]DBG_NB = dim([M:DBG5]CLANA)-1
[L]DBG_J  = [S]nolign-1

Local Mask DEBUGGERS [DBGR]

[L]DBG_TYP  = evalue("type("+[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J)+")")

[L]DBG_MONO = evalue("dim("+[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J)+",0)")
[L]DBG_DIM  = evalue("dim("+[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J)+",1)")
[L]DBG_IND  = evalue("dim("+[M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J)+",-1)")

If find([L]DBG_TYP,522,523) : # Blob/cblob
 End
Elsif [L]DBG_MONO>1
 # JML 01/04/99 plus d'une dimension, on se casse pour le moment...
 End
Elsif [L]DBG_MONO = 1
 If [L]DBG_DIM>1
  [M:DBGR]CHAINE  = [M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J)+"("+num$([L]DBG_IND)+") = "
 Else
  [M:DBGR]CHAINE  = [M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J)-"= "
 Endif
Else
 # On se casse
 End
Endif

Case [L]DBG_TYP
 When 1,2,4,5,6,7,8,9 : # Numérique
  # Rien à faire
 When 3               : # Date
  [M:DBGR]CHAINE += '['
 When Default         : # Alpha
  [M:DBGR]CHAINE += '"'
Endcase

[M:DBGR]CHAINE += num$(evalue([M:DBG6]CLANOM+[M:DBG6]VARNOM([L]DBG_J)+"("+num$([L]DBG_IND)+")"))

Case [L]DBG_TYP
 When 1,2,4,5,6,7,8,9 : # Numérique
  # Rien à faire
 When 3               : # Date
  [M:DBGR]CHAINE += ']'
 When Default         : # Alpha
  [M:DBGR]CHAINE += '"'
Endcase

[L]DBG_OK = 2
Call DIALWIN([L]DBG_OK,mess(3,85,1)-mess(43,139,1),"DEBUGGERS") From GESECRAN
If [L]DBG_OK<>2 | [M:DBGR]CHAINE="" : End : Endif

Onerrgo ERREUR From CONTROLE
[L]DBG_OK = instr(1,[M:DBGR]CHAINE,"=")
If [L]DBG_OK
 [L]DBG_CHAINEA = vireblc(right$([M:DBGR]CHAINE,[L]DBG_OK+1),2) : # Début et fin de chaine
 Case [L]DBG_TYP
  When 1,2,4,5,6,7,8,9 : # Numérique
   Assign left$([M:DBGR]CHAINE,[L]DBG_OK-2) With val([L]DBG_CHAINEA)
  When 3               : # Date
   Assign left$([M:DBGR]CHAINE,[L]DBG_OK-2) With evalue([L]DBG_CHAINEA)
  When Default         : # Alpha
   [L]DBG_CHAINEA = mid$([L]DBG_CHAINEA,2,len([L]DBG_CHAINEA)-2)
   Assign left$([M:DBGR]CHAINE,[L]DBG_OK-2) With [L]DBG_CHAINEA
 Endcase
Endif
Onerrgo
Close Local Mask [DBGR]

[L]DBG_J += 1 : # Car VARVAL travail avec nolign et pas indice comme si dessus...
Gosub AV_VARVAL
Affzo [DBG6]VARVAL([L]DBG_J-1)
End

######################################################################
# Chargement des onglets
######################################################################

$INIT_MSK

[M:DBG2]MEM1(0) = mess(18,9) : # Mémoire utilisée
[M:DBG2]MEM2(0) = [S]dbglong(0)
[M:DBG2]MEM3(0) = [S]dbglong(1)
[M:DBG2]MEM4(0) = [S]dbglong(2)
[M:DBG2]MEM5(0) = 0

[M:DBG2]MEM1(1) = mess(19,9) : # Canaux utilisés
[M:DBG2]MEM2(1) = ([S]dbglong(9)+1)*[S]dbglong(104)+[S]dbglong(6)+3
[M:DBG2]MEM3(1) = ([S]dbglong(10)+1)*[S]dbglong(104)+[S]dbglong(7)+3
[M:DBG2]MEM4(1) = [S]dbglong(5)
[M:DBG2]MEM5(1) = 0

[M:DBG2]MEM1(2) = mess(28,9) : # Fichiers séquentiels
[M:DBG2]MEM2(2) = [S]dbglong(6)
[M:DBG2]MEM3(2) = [S]dbglong(7)
[M:DBG2]MEM4(2) = [S]dbglong(8)
[M:DBG2]MEM5(2) = 0

[M:DBG2]MEM1(3) = mess(20,9) : # Tables ouvertes
[M:DBG2]MEM2(3) = [S]dbglong(9)
[M:DBG2]MEM3(3) = [S]dbglong(10)
[M:DBG2]MEM4(3) = [S]dbglong(11)
[M:DBG2]MEM5(3) = [S]dbglong(27)

[M:DBG2]MEM1(4) = mess(21,9) : # Masques ouverts
[M:DBG2]MEM2(4) = [S]dbglong(12)
[M:DBG2]MEM3(4) = [S]dbglong(13)
[M:DBG2]MEM4(4) = [S]dbglong(14)
[M:DBG2]MEM5(4) = [S]dbglong(15)

[M:DBG2]MEM1(5) = mess(23,9) : # Traitements en mémoire
[M:DBG2]MEM2(5) = [S]dbglong(19)
[M:DBG2]MEM3(5) = [S]dbglong(20)
[M:DBG2]MEM4(5) = [S]dbglong(21)
[M:DBG2]MEM5(5) = [S]dbglong(22)

[M:DBG2]NBMEM = 6

Titcol [M:DBG2]NBMEM  "",mess(29,9),mess(30,9),mess(31,9),mess(25,9)
                      ## Utilisé,   Chargé,    Maximum,   octets

#-----------------------------------------------------------------------------
# MSK DEBUGGER3 Masques ouvert
#-----------------------------------------------------------------------------

[M:DBG3]MSKBAS = 25
For [L]DBG_I=0 To [M:DBG3]MSKBAS-1
 [M:DBG3]MSKNOM([L]DBG_I) = masknam([L]DBG_I+1)
 [M:DBG3]MSKABV([L]DBG_I) = maskabr([L]DBG_I+1)
 [M:DBG3]MSKNL([L]DBG_I)  = masklev([L]DBG_I+1)
 [M:DBG3]MSKNBZ([L]DBG_I) = masknbf([L]DBG_I+1)
 [M:DBG3]MSKSIZ([L]DBG_I) = masksiz([L]DBG_I+1)
 [M:DBG3]MSKPRG([L]DBG_I) = maskrk([L]DBG_I+1,1)
 [M:DBG3]MSKDRG([L]DBG_I) = maskrk([L]DBG_I+1,-1)
 If [M:DBG3]MSKNOM([L]DBG_I)<>""
  Onerrgo ERREUR
  [M:DBG3]MSKCOM([L]DBG_I) = filcom("E"+GLANGUE,[M:DBG3]MSKNOM([L]DBG_I),"msk")
  Onerrgo
 Endif
Next [L]DBG_I

Titcol [M:DBG3]MSKBAS mess(32,9),mess(33,9),mess(35,9),mess(62,9),mess(50,9),mess(39,9)
&                    ,mess(64,9)-".",mess(64,9)
#                     Nom        Abr        Mask       Nbz        Taille     Commentaire
#                     Rangs      Rangs

#-----------------------------------------------------------------------------
# MSK DEBUGGER4 Tables ouverte
#-----------------------------------------------------------------------------

[M:DBG4]FILBAS = [S]dbglong(11)
For [L]DBG_I=0 To [M:DBG4]FILBAS-1
 [M:DBG4]FILNOM([L]DBG_I) = [S]filename([L]DBG_I+1)
 [M:DBG4]FILABR([L]DBG_I) = [S]fileabre([L]DBG_I+1)
 If [M:DBG4]FILABR([L]DBG_I)<>""
  [M:DBG4]FILFIL([L]DBG_I) = filelev([L]DBG_I+1)
  [M:DBG4]FILTYP([L]DBG_I) = filetyp([L]DBG_I+1)+1 : # 0 Neutre ou Inex, 1 CISAM, 2 ORACLE etc..
  Onerrgo ERREUR
  If [M:DBG4]FILFIL([L]DBG_I)<>0
   [L]DBG_J = evalue("[G:"+[M:DBG4]FILABR([L]DBG_I)+"]currind")
   If [L]DBG_J<>0
    [M:DBG4]FILKEY([L]DBG_I) = evalue("[G:"+[M:DBG4]FILABR([L]DBG_I)+"]keyname("+num$([L]DBG_J-1)+")")
   Endif
  Endif
  [M:DBG4]FILCMM([L]DBG_I) = filcom("FIL",[M:DBG4]FILNOM([L]DBG_I),"fde")
  Onerrgo
 Else
  [M:DBG4]FILTYP([L]DBG_I) = 0
 Endif
Next [L]DBG_I

Titcol [M:DBG4]FILBAS mess(32,9),mess(33,9),mess(42,9),mess(43,9),mess(39,9) , mess(23,0,1)
                      ## Nom,    Abr,       File,      Clé,       Commentaire, Type de base

#-----------------------------------------------------------------------------
# MSK DEBUGGER5 classe de variables
#-----------------------------------------------------------------------------

[M:DBG5]CLABAS = dim([M:DBG5]CLANA)
For [L]DBG_I=0 To [M:DBG5]CLABAS-1
 [M:DBG5]CLANA([L]DBG_I)   = clanam([L]DBG_I+1)
 [M:DBG5]CLALCK([L]DBG_I)  = clalev([L]DBG_I+1)
 [M:DBG5]CLASYM1([L]DBG_I) = clanbs([L]DBG_I+1,1)
 [M:DBG5]CLASYM2([L]DBG_I) = clanbs([L]DBG_I+1,2)
 [M:DBG5]CLABUF1([L]DBG_I) = clasiz([L]DBG_I+1,1)
 [M:DBG5]CLABUF2([L]DBG_I) = clasiz([L]DBG_I+1,2)
Next [L]DBG_I

Titcol [M:DBG5]CLABAS mess(32,9),mess(36,9),mess(55,9)-"/",mess(55,9),mess(56,9)-"/",mess(56,9)
                      ## Nom,    Lck,       Symboles /,    Symboles,  Buffer (octets) /, Buffer (octets)

#-----------------------------------------------------------------------------
# MSK DEBUGGER6 Visualisation d'une classe de variables
#-----------------------------------------------------------------------------

Titcol [M:DBG6]VARBAS mess(32,9),mess(60,9),mess(57,9),mess(61,9)
                      ## Nom,    Type,      Dimensions,Valeurs

#-----------------------------------------------------------------------------
# MSK DEBUGGER7 classe de variables
#-----------------------------------------------------------------------------

[M:DBG7]TRTBAS = progldd(0)
For [L]DBG_I=0 To [M:DBG7]TRTBAS-1
 If progcan([L]DBG_I+1)<>""
  [M:DBG7]TRTNOM([L]DBG_I) = progcan([L]DBG_I+1)
  [M:DBG7]TRTSIZ([L]DBG_I) = progsiz([L]DBG_I+1)
  [M:DBG7]TRTUSD([L]DBG_I) = progusd([L]DBG_I+1)
  [M:DBG7]TRTLDD([L]DBG_I) = progldd([L]DBG_I+1)
 Endif
Next [L]DBG_I

Titcol [M:DBG7]TRTBAS mess(32,9),mess(50,9),mess(29,9),mess(30,9)
#                     Nom        Taille     Utilisé    Chargé

#-----------------------------------------------------------------------------
# MSK DEBUGGER8 classe de variables
#-----------------------------------------------------------------------------
# Ligne | adxnfs(Ligne)            Ligne | adxcio(Ligne) | adxioa(Ligne)
#----------------------            -------------------------------------
# 00001 | lan/FRA                  00001 |  0            | ""           
# 00002 | 002428 (serial) -------->00002 |  4            | AAA          
# 00003 | .users          | ------>00003 |  5            | BBB          
# 00004 | abc (abrev AAA)-- | ---->00004 |  6            | CCC          
# 00005 | def (abrev BBB)---- | -->00005 |  7            | DDD          
# 00006 | ABC (abrev CCC)------ |  00006 |  0            | ""
# 00007 | DEF (abrev DDD)--------  00007 |  0            | ""
#
# Après un Openo using [AAA] qui ferme le fichier
# La ligne 4 et la ligne 2 sont remises à zéro !
#-----------------------------------------------------------------------------

[M:DBG8]SEQBAS = [S]dbglong(8) : # Total
For [L]DBG_I=0 To [M:DBG8]SEQBAS-1
 If adxnfs([L]DBG_I+1)<>""
  [M:DBG8]SEQNOM([L]DBG_I) = adxnfs([L]DBG_I+1)
 Endif
 If adxcio([L]DBG_I+1)<>0
  [L]DBG_K = adxcio([L]DBG_I+1)-1
  [M:DBG8]SEQNOM([L]DBG_K) = adxnfs(adxcio([L]DBG_I+1)) : # JC 24/11/99
  [M:DBG8]SEQABV([L]DBG_K) = adxioa([L]DBG_I+1)
  [M:DBG8]SEQPOS([L]DBG_K) = adxseek([L]DBG_I+1)
### JML 24/11/99 Il faut attendre une nouvelle fonction !! Pour 130 ??
#  [M:DBG8]SEQLEC([L]DBG_K) = adxcio([L]DBG_I+1)
#  [M:DBG8]SEQECR([L]DBG_K) = adxcio([L]DBG_I+1)
 Endif
Next [L]DBG_I

Titcol [M:DBG8]SEQBAS mess(32,9),mess(33,9) ,mess(4,47),mess(2,120)  ,mess(3,120)
#                     Nom        Abréviation Positions  Lecture seule Ecriture seule
Return

######################################################################
# Erreurs
######################################################################

$ERREUR
  [L]DBG_ERR = errn
Resume

