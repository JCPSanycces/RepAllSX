# Classe FXDMVT

$ACTION
Local Integer III
  III += 1
#  Call TRACE_LINE(num$(III) - "action R STD" - ACTION - "curpro" - CURPRO) From AXUNIT

    Case ACTION
    When "LOAD"
    When "AREAD_AFTER"
    When "GET"
      If CURPRO = "FXM.FXD.FXD.DESI"
        this.DESI -= "CBO"
      Endif
    When Default
    Endcase
Return
$PROPERTIES
Case CURPRO
  When "TESTE"       : Gosub TEST
  When "TEST"       : Gosub TEST
Endcase

Return


$TEST
#  Call TRACE_LINE("___$test:" - ACTION - "curpro" - CURPRO) From AXUNIT

Case ACTION
   When "INIT"
   When "CONTROL"
   When "PROPAGATE"
   When "GET"
#        this.TEST="TOTO"
Endcase
Return
