#<AdxTL>@(#)8.0.0.0 $Revision$
Call OBJET ("ORZ", GBIDC1, GBIDC2) From GOBJET
End

#########################################################################
# SUBORZ  : saisie des prévisions de consommations modélisé    MM 06/03 #
# --------------------------------------------------------------------- #
#    - Action e_commerce : Objet ORZ                                    #
#                          Fenêtre : OORZ                               #
#    - Ecran principal   : ORDS                                         #
#    - Ecran critère     : ORDCRIT                                      #
#    - Ecran calcul      : ORDCALC                                      #
#########################################################################


$ACTION
# FQ60136 - MABON 20/11/09 - Auparavant "Case GACTION". Modifié car quand on vient d'une autre action, 
# on n'ouvre pas les tables et on n'initialise pas les variables, d'où plantage
Case ACTION
 When "OUVRE"         : Case left$(GACTION,6) 
                           When "GOBJET" : Gosub OUVRE
                        Endcase
 When "OUVRE_BOITE"   : Case left$(GACTION,6)
                            When "GOBJET" : Gosub OUVRE_BOITE
                        Endcase
 When "HINTCLE"       : Gosub HINTCLE     
 When "SETBOUT"       : Gosub SETBOUT
 When "FILTRE"        : Gosub FILTRE
 When "LIENS"         : Gosub LIENS
 When "VERIF_MOD"     : Gosub VERIF_MOD
 When "MODIF"         : Gosub MODIF 
 When "APRES_MOD"     : Gosub APRES_MOD
 When "EXEBOUT"       : Gosub EXEBOUT
 When "FIN_ACTION"    : Gosub FIN_ACTION
 When "TIROIR"        : Gosub TIROIR
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "GAUCHE"        : Gosub GAUCHE
 When "FERME"         : Gosub FERME
 When Default
Endcase

Case ACTION
 When "DEBUT"         : Case GACTION 
                           When "SAIORDB"    : Gosub DEBUT_ORDB
                           When "SAIORDC"    : Gosub DEBUT_ORDC
                           When "SAIORDCALC" : Gosub DEBUT_ORDCALC
                           When "SAIORDCRIT" : Gosub DEBUT_ORDCRIT
                        Endcase
 When "OK"            : Case GACTION 
                           When "SAIORDB"    : Gosub OK_ORDB
                           When "SAIORDCALC" : Gosub OK_ORDCALC
                           When "SAIORDCRIT" : Gosub OK_ORDCRIT
                        Endcase     
 When "END"           : Case GACTION
                           When "SAIORDCALC" : Gosub END_ORDCALC
                        Endcase
Endcase
Return



#########################################################################
$OUVRE
If clalev ([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:TUN]) = 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:SES]) = 0 : Local File SEASON     [SES] : Endif
If clalev ([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
Local Mask ORDK    [ORDK]
Local Mask ORDTEMP [ORDT]    # Ecran de travail
If clalev([M:ORC]) = 0  : Local Mask ORDCRIT    [ORC] : Endif  # 30164 MM 06.05 : gestion memo STD

#   
Local  Integer VS
Local  Char    WMSG(120)
Local  Integer WTRC  : WTRC = 0
Local  Date    WDORD
Local  Date    WDPRE, WDREF
Local  Decimal WQPRE
Local  Integer NBMAX : NBMAX= 200    # dimension du tableau
Global Date   DATEDEB(NBMAX)
Global Date   DATEFIN(NBMAX)
#
Raz [M:ORDS]

# Contrôle compteur en-cours
#----- Chargement du compteur des encours -----#
If !clalev([F:TCA])   Local File TABCOUAFF  [TCA] : Endif
Read [TCA] TCA0=7
If fstat  GERR=1 : GMESSAGE=mess(64,199,1)  : OK=0 : FIN=1 : Return : Endif
GWIP=[F:TCA]CODNUM(8)
Call CTRCPT(GWIP,GLONVCR+10,VS) From STKLIB  # FQ 54162
If VS <> 0
    GERR=1 : GMESSAGE = mess(222,199,1) : OK=0 : Return 
Endif
# 

Return

##########################################################################################
$OUVRE_BOITE

#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#

Global Char     GBOXOD1(10)
GBOXOD1="GAU_CHE"+num$(find("OD1",OBJLIS(1..8))) : # Duplication
Return

##########################################################################################
$HINTCLE
Case currbox
    When GBOXOD1 : HINTLIS(val(right$(GBOXOD1,8)))="OD1"
    When Default : Return
Endcase
Return

##########################################################################################
$SETBOUT

If [M:ORDS]ITMREF=""
    Call VIREBOUT(CHAINE,"123456")From GOBJET
Endif
If [M:ORDS]ITMREF="" 
    Call VIREBOUT(CHAINE,"7")From GOBJET
Endif

If currbox=GBOXOD1
    Call VIREBOUT(CHAINE,"1234")From GOBJET
Endif

Return

########################################################################
$FILTRE    
Default File [ITF]

Return

########################################################################
$FILGAUCHE
# On ne charge pas la liste de gauche si aucun couple article/site n'est saisi
If currbox=GBOXOD1
 If [M:ORDS]STOFCY="" |[M:ORDS]ITMREF=""
  FILGAUSUP(0)+="[F:ITF]STOCOD=99"    
 Endif
Endif

Return

########################################################################
$LIENS
Read [ITM]ITM0=[M:ORDS]ITMREF
  If fstat 
    mkstat = 2 
    GMESSAGE = mess(134,100,1) : GERR=1 : Return
  Endif
Read [ITF]ITF0=[M:ORDS]ITMREF;[M:ORDS]STOFCY
  If fstat 
    mkstat = 2 
    GMESSAGE = mess(2,196,1)+" : "+[M:ORDS]STOFCY : GERR=1 : Return
  Endif
Read [TUN]TUN0=[F:ITM]STU
  If fstat 
    fstat = 0
    Raz [F:TUN]
  Endif
Call LEC_ITM 
Gosub SEARCH

Return

#########################################################################
Subprog LEC_ITM
Local Integer WCOR
Local Date    WDAT
Local Integer WCOD
Local Decimal WDEL
Local Decimal DMYI
Local Date    DMYD
Local Char    WPAR(1)
Local Integer WTYPP : WTYPP = 1 : # Type d'ordre à traiter 
Local Integer WSTAP : WSTAP = 3 : # Statut ordres à gérer

#
[M:ORDS]STU       = [F:ITM]STU
[M:ORDS]STU0      = [F:ITM]STU
[M:ORDS]STU1      = [F:ITM]STU
[M:ORDS]STU2      = [F:ITM]STU
[M:ORDS]MFGLOTQTY = [F:ITF]MFGLOTQTY
[M:ORDS]REOMINQTY = [F:ITF]REOMINQTY
[M:ORDS]UOMDEC    = [F:TUN]UOMDEC
[M:ORDS]SESCOD    = [F:ITF]SESCOD
If [F:ITF]FOH = 0 
    [M:ORDS]FOHENDDAT = [0/0/0]
Else
    # lecture paramètre premier jour ouvré
    Call PARAM([M:ORDS]STOFCY,"FIRWRKDAY",WPAR) From ADOVAL
    If val(WPAR) < 1 | val(WPAR) > 7
        WCOR = 7
    Else
        WCOR = val(WPAR)-1
    Endif
    WCOD = [F:ITF]FOHUOT
    WDEL = [F:ITF]FOH
    WDAT = date$ 
    Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,DMYI,DMYD,[M:ORDS]FOHENDDAT)
&      From CBNLIB
Endif

#
[M:ORDS]FIMFLG=1
[M:ORDS]PLNFLG=1
[M:ORDS]SUGFLG=2
[M:ORDS]TRCFLG=1
[M:ORDS]AFFFLG=0
#
[M:ORDS]WIPTYP = WTYPP
[M:ORDS]WIPSTA = WSTAP
[M:ORDS]GRUCOD = 1

# 30164 MM 06.05 : gestion memo STD
If filinfo(filpath("ETM",GUSER+"_"+"STD","orc",0),0)>=0
    Call LECMEMO("STD","[M:ORC]","orc") From GMEMO
    [M:ORDS]STRDAT    =[M:ORC]STRDAT
    [M:ORDS]ENDDAT    =[M:ORC]ENDDAT
    [M:ORDS]FIMFLG    =[M:ORC]FIMFLG
    [M:ORDS]PLNFLG    =[M:ORC]PLNFLG
    [M:ORDS]TRCFLG    =[M:ORC]TRCFLG
Endif

Affzo 5-10
End

#######################################################################
$VERIF_MOD
If [M:ORDS]TRCFLG = 2 : Call OUVRE_TRACE(mess(56,190,1)) From LECFIC : Endif

Return

#######################################################################
$MODIF
Local Char WFIL(100)
If [M:ORDT]NBLIG<>0 : Raz [M:ORDT]: Endif

Gosub TRT_MODIF     # 28093 MM 02.05

Return

#######################################################################
$TRT_MODIF

Gosub TRT_VAL

Case GOK
    When 1 : 
        Effzo [M:ORDS]15
        Effzo [M:ORDS]PERQTY
        [M:ORDS]AFFFLG  =1
        Call LEC_ORD([M:ORDS]STOFCY,[M:ORDS]ITMREF) 
        [M:ORDS]AFFFLG =0
        Affzo [M:ORDS]PERQTY
        Call AFF_TAB
Endcase 

Return

#######################################################################
$APRES_MOD

If [M:ORDS]TRCFLG = 2 
  Call FERME_TRACE From LECFIC
  If WTRC <> 0
    Call LEC_TRACE   From LECFIC
  Endif
Endif

Return

#########################################################################
$EXEBOUT

Case BOUT 
    When "1" : Gosub SEARCH
Endcase

Return

#########################################################################
$FIN_ACTION

Case BOUT 
    When "3" :    # 27544 MM 01.05
        If mkstat=4 & GREP=""
            REP="M" : GREP="M"      # Pour forcer le bouton 'enregistrer' quand on vient de "regrouper"
            Diszo [M:ORDS]ITMREF,STOFCY       
        Endif 
    When "4" : 
        If mkstat=4 & GREP=""
            REP="M" : GREP="M"      # Pour forcer le bouton 'enregistrer' quand on vient de "calcul"
            Diszo [M:ORDS]ITMREF,STOFCY       
        Endif 
Endcase

# on force le bouton 'enregistrer' qd on alimente le tableau par duplication
If currbox =GBOXOD1 
 Diszo [M:ORDS]ITMREF,STOFCY,STRDAT,ENDDAT
 If mkstat=4 & GREP="" : REP="M" : GREP="M": Endif
Endif

If (currbox =GBOXOD1|currbox ="GAU_CHE9") & GREP=""    # 21214  03.04 MM Derniers lus
 Actzo [M:ORDS]ITMREF,STOFCY,STRDAT,ENDDAT
Endif

Return

#########################################################################
$DEBUT_ORDB
Local Integer I
Local Integer LIN, LSAI

LIN =val(PARAM(1))
LSAI=val(PARAM(2))

Raz [M:ORDB]
For I = LIN To [M:ORDS]BASPAG-1
  If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA
    [M:ORDB]YEAFIR = [M:ORDS]YEA(I)
    [M:ORDB]YEASTR = [M:ORDS]YEA(I)
    [M:ORDB]YEAEND = [M:ORDS]YEA(I)
    [M:ORDB]MONFIR = [M:ORDS]MON(I)
    [M:ORDB]MONSTR = [M:ORDS]MON(I)
    [M:ORDB]MONEND = [M:ORDS]MON(I)
    Break
  Endif
Next I
For I = [M:ORDS]BASPAG-1 To LIN Step -1
  If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA
    [M:ORDB]YEALAS = [M:ORDS]YEA(I)
    [M:ORDB]MONLAS = [M:ORDS]MON(I)
    Break
  Endif
Next I
[M:ORDB]STU       = [M:ORDS]STU
[M:ORDB]REOMINQTY = [M:ORDS]REOMINQTY
[M:ORDB]MFGLOTQTY = [M:ORDS]MFGLOTQTY
Affzo  [M:ORDB] 
If [M:ORDB]MONSTR = 0
  OK = 1
  Goto  REG_MENSUEL2
Endif

If LSAI= 0
  Grizo  [ORDB]5
Endif

Return

#########################################################################
$OK_ORDB

Local Integer WGRU
Local Integer WARR
Local Decimal WMOD
Local Integer OK
Local Integer I, J, K
Local Integer U,V
Local Decimal WBAST

$REG_MENSUEL1
Case REPONSE 
    When GSTAOK : OK = 2
                  Gosub REG_MENSUEL2    # 27544 MM 01.05 
                  mkstat = 4            # 27544 MM 01.05                
Endcase

Return

#########################################################################
$REG_MENSUEL2
If OK = 2
    WGRU = [M:ORDB]GRUCOD
    WARR = [M:ORDB]RNDCOD
    WMOD = [M:ORDB]RNDVAL
    # 34288 mm 03.06
    # bouton bas d'écran
    If LSAI = 1
        # n° de la première ligne à traiter  
        J = find ([M:ORDB]YEASTR,[M:ORDS]YEA(1.. [M:ORDS]BASPAG))  
        K = find ([M:ORDB]MONSTR,[M:ORDS]MON(J.. [M:ORDS]BASPAG)) 
        # n° de la dernière ligne à traiter 
        U = find ([M:ORDB]YEAEND,[M:ORDS]YEA(1.. [M:ORDS]BASPAG)) 
        V = find ([M:ORDB]MONEND,[M:ORDS]MON(U.. [M:ORDS]BASPAG)) 

        For I =(J+K)-1 To (U+V)-1
            If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA 
                Gosub REG_LIGNE
                # bug 27544 MM 01.05 : conserver le regroupement des prévisions 
                [M:ORDS]UPDFLG(I)=1
                #
            Endif  
        Next I    
    Else
    # click droit
        J = ([M:ORDB]YEAEND*100)+[M:ORDB]MONEND
        For I = LIN To [M:ORDS]BASPAG-1    
            If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA 
                K = ([M:ORDS]YEA(I)*100)+[M:ORDS]MON(I)
                If  K <= J
                    Gosub REG_LIGNE
                    # bug 27544 MM 01.05 : conserver le regroupement des prévisions 
                    [M:ORDS]UPDFLG(I)=1
                    #  
                Endif  
            Endif
        Next I
    Endif
    Gosub CAL_TOTAL
    Call AFF_TAB
Endif

Return

#########################################################################
$DEBUT_ORDC
Local Date    WDAT
Local Integer LIN
LIN =val(PARAM(1))

Raz [M:ORDC]
WDAT = [M:ORDS]DAYSTR(LIN)
[M:ORDC]MONSTR = [M:ORDS]DAYSTR(LIN)
[M:ORDC]MONEND = [M:ORDS]DAYEND(LIN)
WTIT = month$([M:ORDS]MON(LIN))-num$([M:ORDS]YEA(LIN))
[M:ORDC]WEESTR1 = WDAT
[M:ORDC]WEEEND1 = WDAT+6
[M:ORDC]WEENBR1 = week(WDAT)
[M:ORDC]WEESTR2 = WDAT+7
[M:ORDC]WEEEND2 = WDAT+13
[M:ORDC]WEENBR2 = week(WDAT+7)
[M:ORDC]WEESTR3 = WDAT+14
[M:ORDC]WEEEND3 = WDAT+20
[M:ORDC]WEENBR3 = week(WDAT+14)
[M:ORDC]WEESTR4 = WDAT+21
[M:ORDC]WEEEND4 = WDAT+27
[M:ORDC]WEENBR4 = week(WDAT+21)
If [M:ORDS]DAYEND(LIN) <> WDAT+27
  [M:ORDC]WEESTR5 = WDAT+28
  [M:ORDC]WEEEND5 = WDAT+34
  [M:ORDC]WEENBR5 = week(WDAT+28)
Endif

Return

#########################################################################
$DEBUT_ORDCALC

Raz [M:ORL]
[M:ORL]STRDAT    =[M:ORDS]STRDAT
[M:ORL]ENDDAT    =[M:ORDS]ENDDAT
[M:ORL]SESCOD    =[M:ORDS]SESCOD    
[M:ORL]GRUCOD    =1
[M:ORL]PERQTY    =[M:ORDS]PERQTY
[M:ORL]STU2      =[M:ORDS]STU2 
Affzo  [M:ORL]

# on sauve les quantités dans le masque [ORDT]
Raz [M:ORDT]
[M:ORDT]NBLIG=0
For I=0 To [M:ORDS]BASPAG-1
    [M:ORDT]DAYSTR (I) = [M:ORDS]DAYSTR (I)
    [M:ORDT]WEEQTY1(I) = [M:ORDS]WEEQTY1(I)
    [M:ORDT]WEEQTY2(I) = [M:ORDS]WEEQTY2(I)
    [M:ORDT]WEEQTY3(I) = [M:ORDS]WEEQTY3(I)
    [M:ORDT]WEEQTY4(I) = [M:ORDS]WEEQTY4(I)
    [M:ORDT]WEEQTY5(I) = [M:ORDS]WEEQTY5(I)
    [M:ORDT]NBLIG +=1
Next I

Return

#########################################################################
$OK_ORDCALC
# GH 31/05/2013 bug 86023
#[M:ORDS]STRDAT    =[M:ORL]STRDAT
#[M:ORDS]ENDDAT    =[M:ORL]ENDDAT
If [M:ORL]STRDAT<>[0/0/0]
  If [M:ORDS]STRDAT=[0/0/0] : [M:ORDS]STRDAT = [M:ORL]STRDAT
  Else                      : [M:ORDS]STRDAT =min([M:ORL]STRDAT,[M:ORDS]STRDAT)
  Endif
Endif
If [M:ORL]ENDDAT<>[0/0/0]
   [M:ORDS]ENDDAT    =max([M:ORL]ENDDAT,[M:ORDS]ENDDAT)
Endif
[M:ORDS]SESCOD    =[M:ORL]SESCOD 
[M:ORDS]GRUCOD    =[M:ORL]GRUCOD
[M:ORDS]PERQTY    =[M:ORL]PERQTY
[M:ORDS]STU2      =[M:ORL]STU2
Affzo [M:ORDS]5-10

GOK= 1
Gosub CAL_PREV 

#If [M:ORDS]PERQTY<>0 : Gosub RECQTY : Endif : # GH 20/05/2014 bug 100178
If [M:ORL]PERQTY<>0 : Gosub RECQTY : Endif

If [M:ORDS]BASPAG>0
  If WVAL = 2 
    mkstat=4
  Endif
Endif

Return

#########################################################################
$END_ORDCALC
Raz [M:ORDT]

Return

#########################################################################
$DEBUT_ORDCRIT
Raz [M:ORC]
[M:ORC]STRDAT    =[M:ORDS]STRDAT
[M:ORC]ENDDAT    =[M:ORDS]ENDDAT
[M:ORC]FIMFLG    =[M:ORDS]FIMFLG
[M:ORC]PLNFLG    =[M:ORDS]PLNFLG
[M:ORC]SUGFLG    =[M:ORDS]SUGFLG
[M:ORC]TRCFLG    =[M:ORDS]TRCFLG
Affzo [M:ORC]

Return

#########################################################################
$OK_ORDCRIT

# 30164 MM 06.05 
[M:ORDS]STRDAT    =[M:ORC]STRDAT
[M:ORDS]ENDDAT    =[M:ORC]ENDDAT
[M:ORDS]FIMFLG    =[M:ORC]FIMFLG
[M:ORDS]PLNFLG    =[M:ORC]PLNFLG
[M:ORDS]SUGFLG    =[M:ORC]SUGFLG
[M:ORDS]TRCFLG    =[M:ORC]TRCFLG
Affzo [M:ORDS]5-10 

Effzo [M:ORDS]15   
[M:ORDS]AFFFLG=1
If [M:ORDS]STOFCY<>"" & [M:ORDS]ITMREF<>"" 
    Call LEC_ORD([M:ORDS]STOFCY,[M:ORDS]ITMREF) 
Endif 
[M:ORDS]AFFFLG=0
Call AFF_TAB 

Return

############################################################
$CAL_PREV
Local Date    WDAT, WDATD, WDATF, WMOND, WMONF, WPERD, WPERF
Local Date    WDEB, WFIN,  WDEBW, WFINW
Local Integer WSEM, WSEMD, WSEMF
Local Integer WYEA, WMON,  WWEE,  WDTE
Local Integer WSTA, WIND,  WMON,  WDEL
Local Decimal WQTY, WQTR,  WPOI,  WBASL,  WBAST, WWQTR
Local Integer I, J, K, L
Local Integer WGRU
Local Integer WARR
Local Decimal WMOD
Local Integer WVAL
Local Shortint WPROTYP : WPROTYP=2   # FQ 70177 GA 06/2010

WVAL = 2
If [M:ORDS]PERQTY = 0
  If  [M:ORDS]BASPAG>0 
    Call AVERTIR(mess(194,190,1),WVAL) From GESECRAN 
  Endif
  If WVAL<>2 : Goto CAL_PREV_FIN : Endif : # GH 20/05/2014 bug 100178 ajout test de WVAL
Endif

# Génération ligne prévisions à zéro
WQTY  = 0
WSTA  = [M:ORDS]WIPSTA
WDAT  = [M:ORL]STRDAT
Gosub CUM_ORD
WDAT  = [M:ORL]ENDDAT
Gosub CUM_ORD
# GH 05/06/2013 plante si [M:ORDS]STRDAT ou [M:ORDS]ENDDAT n'est pas renseignée
# WMOND = gdat$(15,month([M:ORDS]STRDAT),year([M:ORDS]STRDAT))
# WMONF = gdat$(15,month([M:ORDS]ENDDAT),year([M:ORDS]ENDDAT))
If [M:ORDS]BASPAG<>0
   I=find(min([M:ORDS]YEAMONTYP(0..[M:ORDS]BASPAG-1)),[M:ORDS]YEAMONTYP(0..[M:ORDS]BASPAG-1))-1
   WMOND = gdat$(15,[M:ORDS]MON(I),[M:ORDS]YEA(I))
   I=find(max([M:ORDS]YEAMONTYP(0..[M:ORDS]BASPAG-1)),[M:ORDS]YEAMONTYP(0..[M:ORDS]BASPAG-1))-1
   WMONF = gdat$(15,[M:ORDS]MON(I),[M:ORDS]YEA(I))
Endif
#
While WMOND <= WMONF
  WQTY  = 0
  WDAT  = WMOND
  WSTA  = [M:ORDS]WIPSTA
  Gosub CUM_ORD
  WMOND = addmonth(WMOND,1) 
Wend
#
If GOK <> 1
  WVAL = 1
  Call ERREUR(mess(41,187,1)) From GESECRAN
  Goto CAL_PREV_FIN
Endif
Sorta [M:ORDS]BASPAG [M:ORDS]BASPAG Order By [M:ORDS]YEAMONTYP(indice)
#
Read [SES]SES0=[M:ORDS]SESCOD
If fstat 
    fstat = 0
    [F:SES]STRDAT(0) = [01/01/2000]
    [F:SES]ENDDAT(0) = [31/12/2000]
    [F:SES]SESAMT(0) = 100
    [F:SES]SESNBR    = 1   
Endif
Gosub TRT_REPART
If [M:ORDS]GRUCOD >= 1    # 01.05 MM : utile lors du recalcul de la qté totale/mois aprés réguralisation négative
    WGRU = [M:ORDS]GRUCOD
    WARR = 1
    WMOD = 1
    For I = 0 To [M:ORDS]BASPAG-1
      Gosub REG_LIGNE
    Next I
Endif

$CAL_PREV_FIN
Gosub CAL_TOTAL
Call AFF_TAB
Return

############################################################
$TRT_REPART

WDATD = [M:ORL]STRDAT
WDATF = [M:ORL]ENDDAT
WQTR  = [M:ORDS]PERQTY
WBAST = 0
#---------
# FQ 70177 PE permettant de modifier les paramètres de la répartition
GPOINT = "CALREPART": Gosub  ENTREE From EXEFNC
#---------

# qtés remises à 0 pour calcul des prévisons
For I = 0 To [M:ORDS]BASPAG-1
  If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA
    [M:ORDS]TOTQTY(I)  = 0
    [M:ORDS]TOTPRC(I)  = 0
    J = 0
    # GH 31/05/2013 bug 86023 on ne raze que les cellules à calculer
    If func CALC(I,1) : [M:ORDS]WEEQTY1(I) = 0 : J=1 : Endif
    If func CALC(I,2) : [M:ORDS]WEEQTY2(I) = 0 : J=1 : Endif
    If func CALC(I,3) : [M:ORDS]WEEQTY3(I) = 0 : J=1 : Endif
    If func CALC(I,4) : [M:ORDS]WEEQTY4(I) = 0 : J=1 : Endif
    If func CALC(I,5) : [M:ORDS]WEEQTY5(I) = 0 : J=1 : Endif
    # on repère les lignes modifiées
    If J & [M:ORDS]CREFLG(I)<>0 : [M:ORDS]UPDFLG(I)=1 : Endif
 Endif
Next I

# GH 31/05/2013 bug 86023
# on repère les lignes modifiées
#For I=0 To [M:ORDS]BASPAG-1
# If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA
#    If ([M:ORDS]DAYSTR(I)<=[M:ORDS]STRDAT & [M:ORDS]DAYEND(I)>=[M:ORDS]STRDAT)
#        If [M:ORDS]CREFLG(I)<>0 : [M:ORDS]UPDFLG(I)=1 : Endif
#    Elsif ([M:ORDS]DAYSTR(I)>=[M:ORDS]STRDAT & [M:ORDS]DAYEND(I)<=[M:ORDS]ENDDAT)
#        If [M:ORDS]CREFLG(I)<>0 : [M:ORDS]UPDFLG(I)=1 : Endif
#    Elsif ([M:ORDS]DAYSTR(I)<=[M:ORDS]ENDDAT  & [M:ORDS]DAYEND(I)>=[M:ORDS]ENDDAT)
#        If [M:ORDS]CREFLG(I)<>0 : [M:ORDS]UPDFLG(I)=1 : Endif
#    Endif
# Endif
#Next

While WDATD <= WDATF
  For I = 0 To [F:SES]SESNBR-1
    WPERD = gdat$(day([F:SES]STRDAT(I)),month([F:SES]STRDAT(I)),year(WDATD))
    WPERF = gdat$(day([F:SES]ENDDAT(I)),month([F:SES]ENDDAT(I)),year(WDATD))
    If month(WPERF) = 2 & day(WPERF) > 27
      WPERF = eomonth(WPERF)
    Endif
    If WDATD >= WPERD & WDATD <= WPERF
      WDEB = WDATD
      If WDATF < WPERF
        WFIN = WDATF
      Else
        WFIN = WPERF
      Endif
      If WPROTYP = 2
         Gosub CAL_COEF_WEEK   # FQ 70177 GA 06/2011
      Else
         Gosub CAL_COEF_DAY     # ancienne formule avec coeff par jour
      Endif
      Break
    Endif
  Next I 
  WDATD = WPERF+1
Wend

If WBAST <> 0
  J = -1
  For I = 0 To [M:ORDS]BASPAG-1
    If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA
      [M:ORDS]TOTQTY(I) = 0

     If func CALC(I,1)
         WQTY = arr(([M:ORDS]PERQTY*[M:ORDS]WEEQTY1(I))/WBAST,10^-[M:ORDS]UOMDEC)
         [M:ORDS]WEEQTY1(I) = WQTY
         [M:ORDS]TOTQTY(I) += WQTY
         If WQTY <> 0
          J = I
          K = 1
         Endif
      Endif

      If func CALC(I,2)
         WQTY = arr(([M:ORDS]PERQTY*[M:ORDS]WEEQTY2(I))/WBAST,10^-[M:ORDS]UOMDEC)
         [M:ORDS]WEEQTY2(I) = WQTY
         [M:ORDS]TOTQTY(I) += WQTY
         If WQTY <> 0
          J = I
          K = 2
        Endif
      Endif

      If func CALC(I,3)
        WQTY = arr(([M:ORDS]PERQTY*[M:ORDS]WEEQTY3(I))/WBAST,10^-[M:ORDS]UOMDEC)
        [M:ORDS]WEEQTY3(I) = WQTY
        [M:ORDS]TOTQTY(I) += WQTY
        If WQTY <> 0
          J = I
          K = 3
        Endif
      Endif

      If func CALC(I,4)
        WQTY = arr(([M:ORDS]PERQTY*[M:ORDS]WEEQTY4(I))/WBAST,10^-[M:ORDS]UOMDEC)
        [M:ORDS]WEEQTY4(I) = WQTY
        [M:ORDS]TOTQTY(I) += WQTY
        If WQTY <> 0
          J = I
          K = 4
        Endif
      Endif

      If func CALC(I,5)
        WQTY = arr(([M:ORDS]PERQTY*[M:ORDS]WEEQTY5(I))/WBAST,10^-[M:ORDS]UOMDEC)
        [M:ORDS]WEEQTY5(I) = WQTY
        [M:ORDS]TOTQTY(I) += WQTY
        If WQTY <> 0
          J = I
          K = 5
        Endif
      Endif

      WQTR -= [M:ORDS]TOTQTY(I)
    Endif
  Next I

# Report différence arrondis sur dernier traité
  If J >= 0 & WQTR <> 0
      [M:ORDS]TOTQTY(J) += WQTR
      If WQTR > 0
          Case K
              When 1 : [M:ORDS]WEEQTY1(J) += WQTR
              When 2 : [M:ORDS]WEEQTY2(J) += WQTR
              When 3 : [M:ORDS]WEEQTY3(J) += WQTR
              When 4 : [M:ORDS]WEEQTY4(J) += WQTR
              When 5 : [M:ORDS]WEEQTY5(J) += WQTR
          Endcase
      Endif
      # lissage de la régularisation négative
      If WQTR < 0  
          While WQTR <> 0
              WWQTR = WQTR * -1
              Case K
                  When 1 : If [M:ORDS]WEEQTY1(J) >= WWQTR 
                               [M:ORDS]WEEQTY1(J) += WQTR
                               WQTR = 0
                           Else
                               WQTR += [M:ORDS]WEEQTY1(J)
                               [M:ORDS]WEEQTY1(J) = 0
                           Endif
                  When 2 : If [M:ORDS]WEEQTY2(J) >= WWQTR
                               [M:ORDS]WEEQTY2(J) += WQTR
                               WQTR = 0
                           Else
                               WQTR += [M:ORDS]WEEQTY2(J)
                               [M:ORDS]WEEQTY2(J) = 0
                           Endif
                  When 3 : If [M:ORDS]WEEQTY3(J) >= WWQTR
                               [M:ORDS]WEEQTY3(J) += WQTR
                               WQTR = 0
                           Else
                               WQTR += [M:ORDS]WEEQTY3(J)
                               [M:ORDS]WEEQTY3(J) = 0
                           Endif
                  When 4 : If [M:ORDS]WEEQTY4(J) >= WWQTR
                               [M:ORDS]WEEQTY4(J) += WQTR
                               WQTR = 0
                           Else
                               WQTR += [M:ORDS]WEEQTY4(J)
                               [M:ORDS]WEEQTY4(J) = 0
                           Endif
                  When 5 : If [M:ORDS]WEEQTY5(J) >= WWQTR
                               [M:ORDS]WEEQTY5(J) += WQTR
                               WQTR = 0
                           Else
                               WQTR += [M:ORDS]WEEQTY5(J)
                               [M:ORDS]WEEQTY5(J) = 0
                           Endif
              Endcase
              If K > 1 
                  K -= 1
              Else
                  If J = 0 : Break : Endif 
                  J -= 1
                  K  = 5
              Endif
          Wend
      Endif
   Endif
Endif
Return

############################################################
$CAL_COEF_DAY
If [F:SES]SESAMT(I) = 0 Return Endif
If [F:SES]SESNBR <> 0
 # Poids par jour
   WPOI = (WPERF-WPERD)+1
   If WPOI<>0 WPOI = arr([F:SES]SESAMT(I)/WPOI,0.001) Endif
Endif
While WDEB <= WFIN
  For J = 0 To [M:ORDS]BASPAG-1
    If [M:ORDS]TYP(J) = [M:ORDS]WIPSTA
      For K = 0 To [M:ORDS]WEENBR(J)-1
        WDEBW = [M:ORDS]DAYSTR(J)+(K*7)
        WFINW = WDEBW+6  
        If WDEB >= WDEBW & WDEB <= WFINW
          If WFIN < WFINW
            WBASL = WPOI * ((WFIN-WDEB)+1)
          Else
            WBASL = WPOI * ((WFINW-WDEB)+1)
          Endif
          Case K
            When 0 : [M:ORDS]WEEQTY1(J) += WBASL
            When 1 : [M:ORDS]WEEQTY2(J) += WBASL
            When 2 : [M:ORDS]WEEQTY3(J) += WBASL
            When 3 : [M:ORDS]WEEQTY4(J) += WBASL
            When 4 : [M:ORDS]WEEQTY5(J) += WBASL
          Endcase
          WBAST += WBASL 
          WDEB = WFINW+1
          Break 2
        Endif
      Next K 
    Endif
  Next J
Wend

Return
#
############################################################
# FQ 70177 Nouvelle formule de répartition saisonnalité
############################################################
$CAL_COEF_WEEK
If [F:SES]SESAMT(I) = 0 Return Endif
If [F:SES]SESNBR <> 0
 # Poids par mois
   WPOI = (100 * year(WPERF) + month(WPERF)) - (100 * year(WPERD) + month(WPERD)) + 1
   If WPOI<>0 WPOI = arr([F:SES]SESAMT(I)/WPOI,0.001) Endif
Endif
  For J = 0 To [M:ORDS]BASPAG-1
    If [M:ORDS]TYP(J) = [M:ORDS]WIPSTA 
&    & [M:ORDS]YEA(J)>=year(WPERD) & [M:ORDS]MON(J)>=month(WPERD)
&    & [M:ORDS]YEA(J)<=year(WPERF) & [M:ORDS]MON(J)<=month(WPERF)
     # WPOI contient le coeff à répartir sur la période soient 4 à 5 semaines

     # GH 31/05/2013 bug 86023 on ne recalcule pas forcément toutes les cellules d'une ligne
     #If [M:ORDS]WEENBR(J) > 1
     #    [M:ORDS]WEEQTY1(J) = WPOI / [M:ORDS]WEENBR(J)
     #    [M:ORDS]WEEQTY2(J) = WPOI / [M:ORDS]WEENBR(J)
     #    [M:ORDS]WEEQTY3(J) = WPOI / [M:ORDS]WEENBR(J)
     #    [M:ORDS]WEEQTY4(J) = WPOI / [M:ORDS]WEENBR(J)
     # Endif
     # If [M:ORDS]WEENBR(J) = 4
     #    [M:ORDS]WEEQTY4(J) = WPOI - [M:ORDS]WEEQTY1(J) - [M:ORDS]WEEQTY2(J) -[M:ORDS]WEEQTY3(J)
     #    [M:ORDS]WEEQTY5(J)=0
     # Endif
     # If [M:ORDS]WEENBR(J) = 5
     #    [M:ORDS]WEEQTY5(J) = WPOI - [M:ORDS]WEEQTY1(J) - [M:ORDS]WEEQTY2(J) -[M:ORDS]WEEQTY3(J) - [M:ORDS]WEEQTY4(J)
     #Endif
     #WBAST += WPOI

     WPOI2 = WPOI / [M:ORDS]WEENBR(J)
     For K = 0 To [M:ORDS]WEENBR(J)-1
        WDEBW = [M:ORDS]DAYSTR(J)+(K*7)
        WFINW = WDEBW+6
        If !(WFINW<WDEB | WDEBW>WFIN)
           Case K
             When 0 : [M:ORDS]WEEQTY1(J) = WPOI2
                      WBAST += [M:ORDS]WEEQTY1(J)
             When 1 : [M:ORDS]WEEQTY2(J) = WPOI2
                      WBAST += [M:ORDS]WEEQTY2(J)
             When 2 : [M:ORDS]WEEQTY3(J) = WPOI2
                      WBAST += [M:ORDS]WEEQTY3(J)
             When 3 : If K=[M:ORDS]WEENBR(J)-1 : [M:ORDS]WEEQTY4(J) = WPOI - 3*WPOI2
                      Else                     : [M:ORDS]WEEQTY4(J) = WPOI2
                      Endif
                      WBAST += [M:ORDS]WEEQTY4(J)
             When 4 : If K=[M:ORDS]WEENBR(J)-1 : [M:ORDS]WEEQTY5(J) = WPOI - 4*WPOI2
                      Else                     : [M:ORDS]WEEQTY5(J) = WPOI2
                      Endif
                      WBAST += [M:ORDS]WEEQTY5(J)
           Endcase
        Endif
     Next

    Endif
  Next J
Return

############################################################
# Validation / effacement anciennes prévisions / création nouvelles prévisions
$TRT_VAL
Call AFF_TAB

VS = 2
Call AVERTIR(mess(193,190,1),VS) From GESECRAN
If VS = 1
  Call LEC_ORD([F:ITF]STOFCY,[F:ITF]ITMREF) 
  Call AFF_TAB
  Goto TRT_VAL_FIN
Endif
# Début transaction
GOK = 1
fstat = 0

# suppression des encours prévisionnels
If currbox="GAU_CHE"|currbox="GAU_CHE9" : Gosub PUR_ORD     # 21214 03.04 MM Derniers lus
Elsif currbox=GBOXOD1 : Gosub PUR_ORD1 : Endif

# création encours
If GOK = 1
  If [M:ORDS]TRCFLG = 2
      WTRC = 1 
      #WMSG = mess(56,190,1)-[M:ORDS]STOFCY-format$("K:20X",[M:ORDS]ITMREF)- [F:ITM]ITMDES1   # 03.04 MM # FGR 30/06/2009 : X3SUIVI56189
      Local Char WITMDES(GLONDES)                                                                        # FGR 30/06/2009 : X3SUIVI56189
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3               # FGR 30/06/2009 : X3SUIVI56189
      WMSG = mess(56,190,1)-[M:ORDS]STOFCY-format$("K:20X",[M:ORDS]ITMREF)-WITMDES   # 03.04 MM          # FGR 30/06/2009 : X3SUIVI56189
      Call ECR_TRACE(WMSG,0) From GESECRAN
  Endif
  For I = 0 To [M:ORDS]BASPAG-1
   If currbox="GAU_CHE" |currbox="GAU_CHE9"    # 21214 03.04 MM Derniers lus
       If [M:ORDS]CREFLG(I)=0|[M:ORDS]UPDFLG(I)=1    # Ligne créée ou modifiée
           Gosub CRE_ORD
       Endif
   Elsif  currbox=GBOXOD1
           Gosub CRE_ORD
   Endif 
  Next I
Endif

$TRT_VAL_FIN
Return

#############################################################
$PUR_ORD

# 1ere passe : suppression des encours correspondant aux lignes supprimées
For nolign=1 To [M:ORDS]MAXLIG
  If !find(nolign, [M:ORDS]CREFLG(0..[M:ORDS]BASPAG-1)) 
    Filter [ORD] Where STOFCY = [M:ORDS]STOFCY &
&                  ITMREF =[M:ORDS]ITMREF &           
&                  WIPTYP =[M:ORDS]WIPTYP &
&                  WIPSTA =[M:ORDS]WIPSTA  &
&                  ENDDAT >= DATEDEB(nolign-1) & ENDDAT <= DATEFIN(nolign-1)
#  GH 29/04/2013 bug 89691 par cohérence avec le chargement des lignes du tableau
#&                  STRDAT >= DATEDEB(nolign-1) & ENDDAT <= DATEFIN(nolign-1)

    For [ORD]ORD1
        [M:ORDK]MAJCOD     = "A"
        [M:ORDK]           = [F:ORD]
        Call WIP From TRTWIP
    Next
    Filter [ORD]
  Endif
Next nolign

# 2nde passe : suppression des encours correspondant aux lignes créées et/ou modifiées
For I=0 To [M:ORDS]BASPAG-1
    If [M:ORDS]CREFLG(I)<>0 & [M:ORDS]UPDFLG(I)=0 : Goto NEXT_OPE : Endif

    Filter [ORD] Where STOFCY = [M:ORDS]STOFCY &
&                  ITMREF =[M:ORDS]ITMREF &           
&                  WIPTYP =[M:ORDS]WIPTYP &
&                  WIPSTA =[M:ORDS]WIPSTA &
&                  ENDDAT >= [M:ORDS]DAYSTR(I) & ENDDAT <= [M:ORDS]DAYEND(I)
#  GH 29/04/2013 bug 89691 par cohérence avec le chargement des lignes du tableau
#&                  STRDAT >= [M:ORDS]DAYSTR(I) & ENDDAT <= [M:ORDS]DAYEND(I)
    For [ORD]ORD1
        [M:ORDK]MAJCOD     = "A"
        [M:ORDK]           = [F:ORD]
        Call WIP From TRTWIP
    Next
    Filter [ORD]
$NEXT_OPE
Next
Return

#############################################################
# Duplication
$PUR_ORD1
# suppression des encours prévisionnels de l'article initial
Filter [ORD] Where STOFCY = [M:ORDS]STOFCY &
&                  ITMREF =[M:ORDS]ITMREF &           
&                  WIPTYP =[M:ORDS]WIPTYP &
&                  WIPSTA =[M:ORDS]WIPSTA  &
&                  ENDDAT >= [M:ORDS]STRDAT & ENDDAT <= [M:ORDS]ENDDAT
#  GH 29/04/2013 bug 89691 par cohérence avec le chargement du tableau
#&                  STRDAT >= [M:ORDS]STRDAT & ENDDAT <= [M:ORDS]ENDDAT
    For [ORD]ORD1
        [M:ORDK]MAJCOD     = "A"
        [M:ORDK]           = [F:ORD]
        Call WIP From TRTWIP
    Next
Filter [ORD]
Return

#############################################################
$CRE_ORD
If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA
      # llc 04.06 22609 attention au mois débutant le mardi ...
      WDREF = [M:ORDS]DAYSTR(I)
      If month(WDREF) <> [M:ORDS]MON(I) : WDREF = gdat$(1,[M:ORDS]MON(I),[M:ORDS]YEA(I)) : Endif
        
      If [M:ORDS]WEEQTY1(I) > 0
        WDPRE = WDREF
        WQPRE = [M:ORDS]WEEQTY1(I) 
        Gosub CRE_PREV
      Endif
      If [M:ORDS]WEEQTY2(I) > 0
        WDPRE = [M:ORDS]DAYSTR(I)+7
        WQPRE = [M:ORDS]WEEQTY2(I) 
        Gosub CRE_PREV
      Endif
      If [M:ORDS]WEEQTY3(I) > 0
        WDPRE = [M:ORDS]DAYSTR(I)+14
        WQPRE = [M:ORDS]WEEQTY3(I) 
        Gosub CRE_PREV
      Endif
      If [M:ORDS]WEEQTY4(I) > 0
        WDPRE = [M:ORDS]DAYSTR(I)+21
        WQPRE = [M:ORDS]WEEQTY4(I) 
        Gosub CRE_PREV
      Endif
      If [M:ORDS]WEEQTY5(I) > 0
        WDPRE = [M:ORDS]DAYSTR(I)+28
        WQPRE = [M:ORDS]WEEQTY5(I) 
        Gosub CRE_PREV
      Endif
Endif
Return

#############################################################
# Affichage tableau
Subprog AFF_TAB
[M:ORDS]DISFLG = 0
Actzo [M:ORDS]15
Affzo [M:ORDS]15
[M:ORDS]DISFLG = 1
End

#########################################################################
Subprog LEC_ORD(LFCY,LITM)
Value Char    LFCY
Value Char    LITM
Local Char    WFIL(250)
Local Date    WDAT
Local Decimal WQTY
Local Integer WSTA
Local Date    WSTRDAT, WENDDAT     # 30164 MM 06.05

Raz DATEDEB, DATEFIN
#
[M:ORDS]BASPAG = 0
nolign         = 0
[M:ORDS]MAXLIG = 0

## GH 29/04/2013 bug 89691 s'ils ne sont pas renseignés [M:ORDS]STRDAT/ENDDAT sont affectées selon [F:ORD]ENDDAT
##            => par cohérence, la sélection selon [M:ORDS]STRDAT/ENDDAT doit se faire sur [F:ORD]ENDDAT
#
#If [M:ORDS]STRDAT<>[0/0/0]
#  If [M:ORDS]ENDDAT<>[0/0/0]
#     WFIL ="STRDAT <= [M:ORDS]STRDAT & ENDDAT >= [M:ORDS]STRDAT|"
#     WFIL+="STRDAT >= [M:ORDS]STRDAT & ENDDAT <= [M:ORDS]ENDDAT|"
#     WFIL+="STRDAT <= [M:ORDS]ENDDAT & ENDDAT >= [M:ORDS]ENDDAT&"
#  Else
#    WFIL="STRDAT>= [M:ORDS]STRDAT &"
#  Endif
#Else                                        # 30164 MM 06.05
#  If [M:ORDS]ENDDAT<>[0/0/0]
#    WFIL="ENDDAT<= [M:ORDS]ENDDAT &"
#  Endif
#Endif

WFIL+= "find([F:ORD]WIPSTA"
If [M:ORDS]FIMFLG = 2
  WFIL += ",1"
Endif
If [M:ORDS]PLNFLG = 2
  WFIL += ",2"
Endif
If [M:ORDS]SUGFLG = 2
  WFIL += ",3"
Endif
WFIL += ")<>0"

## GH 29/04/2013 bug 89691
If [M:ORDS]STRDAT<>[0/0/0]
   WFIL+=" & ENDDAT>= [M:ORDS]STRDAT"
Endif
If [M:ORDS]ENDDAT<>[0/0/0]
   WFIL+=" & ENDDAT<= [M:ORDS]ENDDAT"
Endif

Filter [ORD] Where STOFCY = LFCY &
&                  ITMREF = LITM &           
&                  WIPTYP = [M:ORDS]WIPTYP &                 
&                  evalue(WFIL) 
&            Order By Key ORD1  
#
GOK = 1
For [ORD]
  WQTY  = [F:ORD]RMNEXTQTY
  WDAT  = [F:ORD]ENDDAT
  WSTA  = [F:ORD]WIPSTA
  Gosub CUM_ORD
  # 30164 MM 06.05
  # date deb nulle
  If [M:ORDS]STRDAT = [0/0/0] & WSTA = [M:ORDS]WIPSTA & (WDAT < WSTRDAT  | WSTRDAT = [0/0/0])
     WSTRDAT = WDAT
  Endif
  # date fin nulle
  If [M:ORDS]ENDDAT = [0/0/0] & WSTA = [M:ORDS]WIPSTA & (WDAT > WENDDAT  | WENDDAT = [0/0/0])
     WENDDAT = WDAT
  Endif  
Next
Filter [ORD]

# 30164 MM 06.05
If WSTRDAT<>[0/0/0]  : [M:ORDS]STRDAT = WSTRDAT  : Affzo [M:ORDS]STRDAT : Endif
If WENDDAT<>[0/0/0]  : [M:ORDS]ENDDAT = WENDDAT  : Affzo [M:ORDS]ENDDAT : Endif

# correction des valeurs des dates debut/fin mois stockées en fonction de la période traitée
If [M:ORDS]BASPAG>0
   If [M:ORDS]STRDAT<>[0/0/0] :  DATEDEB(0)                 = [M:ORDS]STRDAT : Endif
   If [M:ORDS]ENDDAT<>[0/0/0] :  DATEFIN([M:ORDS]BASPAG-1)  = [M:ORDS]ENDDAT : Endif    
Endif

[M:ORDS]STU2 = [M:ORDS]STU
Sorta [M:ORDS]BASPAG [M:ORDS]BASPAG Order By [M:ORDS]YEAMONTYP(indice)
Gosub CAL_TOTAL

End

############################################################
$CAL_TOTAL

Local Integer J
[M:ORDS]PERQTY = 0
For J = 0 To [M:ORDS]BASPAG-1
  If [M:ORDS]TYP(J) = [M:ORDS]WIPSTA
    [M:ORDS]PERQTY += [M:ORDS]TOTQTY(J)
  Endif
Next J
For J = 0 To [M:ORDS]BASPAG-1
  If [M:ORDS]TYP(J) = [M:ORDS]WIPSTA
    If [M:ORDS]PERQTY <> 0
      [M:ORDS]TOTPRC(J) = ([M:ORDS]TOTQTY(J)*100)/[M:ORDS]PERQTY
    Else
      [M:ORDS]TOTPRC(J) = 0  
    Endif
  Endif
Next J
Return

#############################################################
# Création d'une prévision (SOS)
$CRE_PREV

If GOK = 1
  Raz [M:ORDK]
  [M:ORDK]MAJCOD     = "C"
  [M:ORDK]WIPTYP     = [M:ORDS]WIPTYP
  [M:ORDK]STOFCY     = [M:ORDS]STOFCY
  [M:ORDK]ORIFCY     = [M:ORDS]STOFCY
  [M:ORDK]WIPSTA     = [M:ORDS]WIPSTA
  WDORD = date$ 
  Call NUMERO(GWIP,[M:ORDS]STOFCY,WDORD,"",[M:ORDK]WIPNUM,VS) From SUBANM
     If VS <> 0
       GOK = 0
     Else
       [M:ORDK]ITMREF     = [M:ORDS]ITMREF    # MM 03.04 
       [M:ORDK]PJT        = ""
       [M:ORDK]BPRNUM     = ""
       [M:ORDK]STRDAT     = WDPRE
       [M:ORDK]ENDDAT     = WDPRE
       [M:ORDK]VCRTYP     = 1
       [M:ORDK]VCRNUM     = [M:ORDK]WIPNUM
       [M:ORDK]VCRLIN     = 0
       [M:ORDK]VCRSEQ     = 0
       [M:ORDK]EXTQTY     = WQPRE
       [M:ORDK]CPLQTY     = 0
       [M:ORDK]ALLQTY     = 0
       [M:ORDK]SHTQTY     = 0
       [M:ORDK]FMI        = 1
       [M:ORDK]MRPMES     = 1
       [M:ORDK]VCRTYPORI  = 0
       [M:ORDK]VCRNUMORI  = ""
       [M:ORDK]VCRLINORI  = 0
       [M:ORDK]VCRSEQ     = 0              
       [M:ORDK]BOMALT     = 0
       [M:ORDK]ORI        = 3
       [M:ORDK]ABBFIL     = ""
       Read [ITF]ITF0=[M:ORDS]ITMREF;[F:ITF]STOFCY    # MM 03.04 
       If fstat : Raz [F:ITF] : Endif
       Call WIP From TRTWIP
         If [M:ORDS]TRCFLG = 2
           WTRC = 1 
           # FQ 74427 on n'a plus [F:ORD] en sortie du TRTWIP, le WIPNUM est ok dans [M:ORDK]
#           WMSG = mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)-
#&                 [F:ORD]WIPNUM-format$(GFMDAT4,[F:ORD]ENDDAT)-num$([F:ORD]RMNEXTQTY)-
           WMSG = mess([M:ORDK]WIPTYP,341,1)+mess([M:ORDK]WIPSTA,342,1)-
&                 [M:ORDK]WIPNUM-format$(GFMDAT4,[M:ORDK]ENDDAT)-num$([M:ORDK]EXTQTY)-
&                 [M:ORDS]STU    # MM 03.04  
           Call ECR_TRACE(WMSG,0) From GESECRAN
         Endif
    Endif
Endif
Return

############################################################
# Chargement ordre dans le tableau
$CUM_ORD
Local Date    WDATD, WDATF
Local Integer WSEM, WSEMD, WSEMF
Local Integer WYEA, WMON,  WWEE,  WDTE
Local Integer WIND
Local Integer WGRU
Local Integer WARR
Local Decimal WMOD
Local Integer I

If WDAT <> [0/0/0]
  Call DATMOIS(WDAT,WDATD,WDATF,WSEMD,WSEMF,WYEA,WMON,WWEE) From CBNLIB
  For WIND = 0 To [M:ORDS]BASPAG-1
    If WDAT >= [M:ORDS]DAYSTR(WIND) & 
&      WDAT <= [M:ORDS]DAYEND(WIND) &
&      WSTA  = [M:ORDS]TYP(WIND)
      Gosub CUM_LIGNE 
      Break
    Endif
  Next WIND
  If WIND > [M:ORDS]BASPAG-1
    WDTE  = (WYEA*1000)+(WMON*10)
    If WSTA <> [M:ORDS]WIPSTA
      WDTE += WSTA
    Endif
    If [M:ORDS]BASPAG < dim([M:ORDS]TOTQTY)-1
      [M:ORDS]YEAMONTYP([M:ORDS]BASPAG) = WDTE
      [M:ORDS]YEA([M:ORDS]BASPAG)       = WYEA
      [M:ORDS]MON([M:ORDS]BASPAG)       = WMON
      [M:ORDS]TYP([M:ORDS]BASPAG)       = WSTA 
      WIND = [M:ORDS]BASPAG
      If [M:ORDS]AFFFLG =1 
         [M:ORDS]CREFLG([M:ORDS]BASPAG)    = nolign+1      # flag creation
         [M:ORDS]UPDFLG([M:ORDS]BASPAG)    = 0             # flag modification
         DATEDEB([M:ORDS]BASPAG)           = WDATD         # identificateur1 pour annnulation
         DATEFIN([M:ORDS]BASPAG)           = WDATF         # identificateur2 pour annnulation
      Endif
      Gosub CAL_DAT 
      Gosub CUM_LIGNE 
      nolign         += 1
      [M:ORDS]BASPAG += 1  
      If [M:ORDS]AFFFLG =1  [M:ORDS]MAXLIG = nolign  Endif
    Else
      GOK = 0
    Endif
  Endif
Endif

Return

############################################################
$CUM_LIGNE
[M:ORDS]TOTQTY(WIND) += WQTY
Case WWEE
  When 1 : [M:ORDS]WEEQTY1(WIND) += WQTY
  When 2 : [M:ORDS]WEEQTY2(WIND) += WQTY
  When 3 : [M:ORDS]WEEQTY3(WIND) += WQTY
  When 4 : [M:ORDS]WEEQTY4(WIND) += WQTY
  When 5 : [M:ORDS]WEEQTY5(WIND) += WQTY
Endcase
Return

###########################################################
$CAL_DAT
[M:ORDS]DAYSTR(WIND)    = WDATD
[M:ORDS]DAYEND(WIND)    = WDATF
[M:ORDS]WEENBR(WIND)    = ((WDATF-WDATD)+1)/7
[M:ORDS]WEESTR1(WIND)   = WDATD
[M:ORDS]WEEEND1(WIND)   = WDATD+6
[M:ORDS]WEESTR2(WIND)   = WDATD+7
[M:ORDS]WEEEND2(WIND)   = WDATD+13
[M:ORDS]WEESTR3(WIND)   = WDATD+14
[M:ORDS]WEEEND3(WIND)   = WDATD+20
[M:ORDS]WEESTR4(WIND)   = WDATD+21
[M:ORDS]WEEEND4(WIND)   = WDATD+27
If [M:ORDS]WEENBR(WIND) = 5
  [M:ORDS]WEESTR5(WIND)   = WDATD+28
  [M:ORDS]WEEEND5(WIND)   = WDATD+34
Else 
  [M:ORDS]WEESTR5(WIND)   = [0/0/0]
  [M:ORDS]WEEEND5(WIND)   = [0/0/0]
Endif
Return

############################################################
# Regroupement d'une ligne / arrondis
$REG_LIGNE
If WGRU = 1
  Call ARR_QTY([M:ORDS]WEEQTY1(I),WARR,WMOD)
  Call ARR_QTY([M:ORDS]WEEQTY2(I),WARR,WMOD)
  Call ARR_QTY([M:ORDS]WEEQTY3(I),WARR,WMOD)
  Call ARR_QTY([M:ORDS]WEEQTY4(I),WARR,WMOD)
  Call ARR_QTY([M:ORDS]WEEQTY5(I),WARR,WMOD)
  [M:ORDS]TOTQTY(I) = [M:ORDS]WEEQTY1(I)+[M:ORDS]WEEQTY2(I)+[M:ORDS]WEEQTY3(I)+[M:ORDS]WEEQTY4(I)+[M:ORDS]WEEQTY5(I)
  Return
Endif

If dim([L]WPROTYP)=1
  # GH 31/05/2013 bug 86023 on ne raze et ne groupe que les cellules calculées
  [M:ORDS]TOTQTY(I) = [M:ORDS]WEEQTY1(I)+[M:ORDS]WEEQTY2(I)+[M:ORDS]WEEQTY3(I)+[M:ORDS]WEEQTY4(I)+[M:ORDS]WEEQTY5(I)
  If func CALC(I,1) : [M:ORDS]WEEQTY1(I) = 0 : Endif
  If func CALC(I,2) : [M:ORDS]WEEQTY2(I) = 0 : Endif
  If func CALC(I,3) : [M:ORDS]WEEQTY3(I) = 0 : Endif
  If func CALC(I,4) : [M:ORDS]WEEQTY4(I) = 0 : Endif
  If func CALC(I,5) : [M:ORDS]WEEQTY5(I) = 0 : Endif
Else
  [M:ORDS]WEEQTY1(I) = 0
  [M:ORDS]WEEQTY2(I) = 0
  [M:ORDS]WEEQTY3(I) = 0
  [M:ORDS]WEEQTY4(I) = 0
  [M:ORDS]WEEQTY5(I) = 0
Endif

WBAST = [M:ORDS]TOTQTY(I)-[M:ORDS]WEEQTY1(I)-[M:ORDS]WEEQTY2(I)-[M:ORDS]WEEQTY3(I)-[M:ORDS]WEEQTY4(I)-[M:ORDS]WEEQTY5(I)
Call ARR_QTY(WBAST,WARR,WMOD)
Case WGRU
  When 2 : [M:ORDS]WEEQTY1(I)+= WBAST
  When 3 : [M:ORDS]WEEQTY2(I)+= WBAST
  When 4 : [M:ORDS]WEEQTY3(I)+= WBAST
  When 5 : 
    Case [M:ORDS]WEENBR(I)
      When 4 : [M:ORDS]WEEQTY4(I)+= WBAST
      When 5 : [M:ORDS]WEEQTY5(I)+= WBAST
    Endcase
Endcase
Return

############################################################
# GH 31/05/2013 bug 86023
# rend 1 si la cellule du tableau est à recalculer
# rend 0 sinon

Funprog CALC(IND,COL)
Value Integer IND, COL

Local Date WDEBW
WDEBW = [M:ORDS]DAYSTR(IND) + 7 * (COL-1)

If !(WDEBW+6<[M:ORL]STRDAT | WDEBW>[M:ORL]ENDDAT)
   End 1
Else
   End 0
Endif

############################################################
# Récupération des quantités
$RECQTY
Local Integer J

For I=0 To [M:ORDS]BASPAG-1
 # lignes existantes avant calcul des prévisions ou ajoutées manuellement
 If ([M:ORDS]CREFLG(I)=0 & [M:ORDS]UPDFLG(I)<>0) | ([M:ORDS]CREFLG(I)<>0 & [M:ORDS]UPDFLG(I)=0)
  If [M:ORDS]TYP(I) = [M:ORDS]WIPSTA
    J= find([M:ORDS]DAYSTR(I),[M:ORDT]DAYSTR(0..[M:ORDT]NBLIG-1))
    If J<>0
     [M:ORDS]WEEQTY1(I) =   [M:ORDT]WEEQTY1(J-1) 
     [M:ORDS]WEEQTY2(I) =   [M:ORDT]WEEQTY2(J-1) 
     [M:ORDS]WEEQTY3(I) =   [M:ORDT]WEEQTY3(J-1) 
     [M:ORDS]WEEQTY4(I) =   [M:ORDT]WEEQTY4(J-1) 
     [M:ORDS]WEEQTY5(I) =   [M:ORDT]WEEQTY5(J-1) 
     [M:ORDS]TOTQTY(I)  = [M:ORDS]WEEQTY1(I)+[M:ORDS]WEEQTY2(I)+[M:ORDS]WEEQTY3(I)+[M:ORDS]WEEQTY4(I)+[M:ORDS]WEEQTY5(I)
    Endif
  Endif
 Elsif [M:ORDS]CREFLG(I)<>0 & [M:ORDS]UPDFLG(I)<>0     # Lignes modifiées par le calcul des prévisions
    J= find([M:ORDS]DAYSTR(I),[M:ORDT]DAYSTR(0..[M:ORDT]NBLIG-1))
    If J<>0
      If [M:ORDS]WEEQTY1(I)=0 :  [M:ORDS]WEEQTY1(I) =   [M:ORDT]WEEQTY1(J-1) : Endif
      If [M:ORDS]WEEQTY2(I)=0 :  [M:ORDS]WEEQTY2(I) =   [M:ORDT]WEEQTY2(J-1) : Endif
      If [M:ORDS]WEEQTY3(I)=0 :  [M:ORDS]WEEQTY3(I) =   [M:ORDT]WEEQTY3(J-1) : Endif
      If [M:ORDS]WEEQTY4(I)=0 :  [M:ORDS]WEEQTY4(I) =   [M:ORDT]WEEQTY4(J-1) : Endif
      If [M:ORDS]WEEQTY5(I)=0 :  [M:ORDS]WEEQTY5(I) =   [M:ORDT]WEEQTY5(J-1) : Endif
     [M:ORDS]TOTQTY(I)  = [M:ORDS]WEEQTY1(I)+[M:ORDS]WEEQTY2(I)+[M:ORDS]WEEQTY3(I)+[M:ORDS]WEEQTY4(I)+[M:ORDS]WEEQTY5(I)
    Endif    
 Endif
Next I

Gosub CAL_TOTAL
#Affzo [M:ORDS]
Raz [M:ORDT]

Return
############################################################
Subprog ARR_QTY(LQTY,LARR,LMOD)
Variable Decimal LQTY
Variable Integer LARR
Value    Decimal LMOD
Local    Decimal WQTY, WMOD
WQTY = LQTY*10^[M:ORDS]UOMDEC
WMOD = LMOD*10^[M:ORDS]UOMDEC
Case LARR
  When 2 : WQTY = arr(WQTY,(WMOD*10^-[M:ORDS]UOMDEC))
  When 3 : WQTY = int(WQTY/WMOD)*WMOD
  When 4 : If mod(WQTY,WMOD) <> 0
             WQTY = (int(WQTY/WMOD)*WMOD)+WMOD
           Endif 
Endcase
LQTY = WQTY*10^-[M:ORDS]UOMDEC
End

############################################################
$TIROIR
Local Char WFCY(GLONFCY)
Local Char WITMREF(GLONITM)

Return

############################################################
$GAUCHE

If currbox=GBOXOD1 : Gosub SEL : Endif
Return

############################################################
$SEL
Effzo [M:ORDS]15
Raz WFCY,WITMREF

WITMREF=[F:ITF]ITMREF
WFCY=[F:ITF]STOFCY
Read [ITM]ITM0= WITMREF
  If fstat 
    GMESSAGE = mess(134,100,1)
    mkstat = 2 : GERR=1
    Return
  Endif
Read [TUN]TUN0=[F:ITM]STU
  If fstat 
    fstat = 0
    Raz [F:TUN]
  Endif

[M:ORDS]FIMFLG=1
[M:ORDS]PLNFLG=1
[M:ORDS]SUGFLG=2
#
[M:ORDS]GRUCOD = 1 : Affzo [M:ORDS]GRUCOD
#
Call LEC_ORD(WFCY,WITMREF) 
Grizo 10
Call AFF_TAB 
mkstat=4

Return
#######################################################################
$SEARCH
Local Integer WMAX
WMAX = dim([M:ORDS]YEA)    # mémorisation nombre de ligne maxi : 30164 MM 06.05

Effzo [M:ORDS]15
[M:ORDS]AFFFLG =1
If currbox="GAU_CHE"
    Call LEC_ORD([M:ORDS]STOFCY,[M:ORDS]ITMREF)
Elsif  currbox=GBOXOD1|currbox="GAU_CHE9"            # 21214 03.04 MM Derniers lus
    Call LEC_ORD([F:ITF]STOFCY,[F:ITF]ITMREF)
Endif
[M:ORDS]AFFFLG =0
Affzo [M:ORDS]10
Call AFF_TAB 
If nolign = WMAX-1 : GMESSAGE = mess(168,190,1) : Endif    # 30164 MM 06.05

Return

#######################################################################
$FERME
Inftxt "" At 2
Kill DATEDEB,DATEFIN
Close Local Mask [ORDK]
Close Local File [TUN]
Close Local File [ITM]
Close Local File [ORD]
Close Local File [SES]
If dim(GBOXOD1)>0 : Kill GBOXOD1 : Endif

Return
