#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# FUNBPSMVT : Resynchronisation en cours fournisseurs       MBT 04/06/00 #
# ---------------------------------------------------------------------- #
#    Contrôle et correction de la table BPSUPPMVT [MVS]                  #
#       - ORDNOTC   : Montant en commande HT  devise transaction         #
#       - ORDNOTL   : Montant en commande HT  devise société             #
#       - ORDNOTR   : Montant en commande HT  devise dossier             #
#       - ORDATIC   : Montant en commande TTC devise transaction         #
#       - ORDATIL   : Montant en commande TTC devise société             #
#       - ORDATIR   : Montant en commande TTC devise dossier             #
#       - RCPNOTC   : Mt réceptionné non facturé HT  devise transaction  #
#       - RCPNOTL   : Mt réceptionné non facturé HT  devise société      #
#       - RCPNOTR   : Mt réceptionné non facturé HT  devise dossier      #
#       - RCPATIC   : Mt réceptionné non facturé TTC devise transaction  #
#       - RCPATIL   : Mt réceptionné non facturé TTC devise société      #
#       - RCPATIR   : Mt réceptionné non facturé TTC devise dossier      #
#       - INVAMTC   : Mt facturé non comptabilisé devise transaction     #
#       - INVAMTL   : Mt facturé non comptabilisé devise société         #
#       - INVAMTR   : Mt facturé non comptabilisé devise dossier         #
#    Contrôle et correction de la table LASTSUPMVT [LSM]                 #
#       - MVTDAT    : Date dernière pièce                                #
#       - VCRNUM    : Numéro dernière pièce                              #
#       - AMT       : Montant dernière pièce                             #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais une fonction                     #
# ---------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                 #
#   - TRTBPSMVT : Fonction de resynchronisation des encours fournisseurs #
##########################################################################

$ACTION
#---------------------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)                        #
# TRTBPSMVT  : Fonction de resynchronisation des encours fournisseurs #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE_FIC
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Affzo [DIA]1-99 : Gosub GRISAGE
 When "SETBOUT"     : If GHISTO
                        Diszo [DIA]1-99
                        Call VIREBOUT(CHBOU,"O")   From GOBJET
                        Call VIREBOUT(CHMEN,"MRE") From GOBJET
                      Endif
 When "BOUTON"      : Gosub BOUTON
 When "OK"          : GOK=1
 When "END"         : GOK=0
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return


#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
Gosub OUVRE_FIC    : # Ouverture fichiers
Local Mask BPSMVT [DIA]
Raz [M:DIA]
[M:DIA]XBPSFLG=2
[M:DIA]TRACE  =2
Call LECMEMO("STD","[M:DIA]","pm6") From GMEMO
TIT=mess(332,197,1) : # Titre de la boite de dialogue et message de temporisation
TMP=1               : # Affichage d'un message de temporisation
Return


###############################
# Après exécution d'un bouton #
###############################
$BOUTON
Case BOUT
  When "R" : Gosub GRISAGE
Endcase
Return


##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 : Endif
Return


###########################
# Exécution du traitement #
###########################
$EXEC
Call RESYNCHRO_BPSMVT([M:DIA]XCPYFLG,[M:DIA]CPY,[M:DIA]XBPSFLG,[M:DIA]BPSNUM,[M:DIA]TRACE)
Return


##############################################
# Resynchronisation des encours fournisseurs #
# ------------------------------------------ #
# L_XCPYFLG : Indicateur toutes sociétés     #
#             1 = Non,  2 = Oui              #
# L_CPY     : Société à traiter              #
# L_WBPSFLG : Indicateur tous fournisseurs   #
#             1 = Non,  2 = Oui              #
# L_BPSNUM  : Fournisseur à traiter          #
# L_TRACE   : Ecriture d'une trrace          #
#             1 = Non,  2 = Oui              #
##############################################
Subprog RESYNCHRO_BPSMVT(L_XCPYFLG,L_CPY,L_XBPSFLG,L_BPSNUM,L_TRACE)
Value Integer  L_XCPYFLG
Value Char     L_CPY
Value Integer  L_XBPSFLG
Value Char     L_BPSNUM
Value Integer  L_TRACE
#----- Variables locales -----#
Local Libelle  LASFLG, WIFFTYP, WMVTTYP
Local Shortint INDIC, CREFLG, CREFLG2, UPDFLG, UPDFLG2
Local Integer  OK, STAT, COMPTEUR, CTEURMVS, WNBLIG, WI
Local Char     CRITERE(170), WIFFFCY(GLONFCY), WFCY(GLONFCY)
Local Char     WBPSNUM(GLONBPS), WBPSRSK(GLONBPS), WCPY(GLONCPY), WCUR(GLONCUR), WMSG(110)
Local Decimal  WORDNOTC, WORDNOTL, WORDNOTR, WORDATIC, WORDATIL, WORDATIR
Local Decimal  WRCPNOTC, WRCPNOTL, WRCPNOTR, WRCPATIC, WRCPATIL, WRCPATIR
Local Decimal  WINVAMTC, WINVAMTL, WINVAMTR
Local Decimal  WMT1, WMT2, WMT3, WMT4, WCOURS
Local Date     WLASINVDAT, WLASCNODAT, WLASORDDAT, WLASPQHDAT, WLASRCPDAT
Local Char     WLASINVNUM(GLONPIH), WLASCNONUM(GLONPIH), WLASPOHNUM(GLONPOH)
Local Char     WLASPQHNUM(GLONPQH), WLASPTHNUM(GLONPTH)
Local Decimal  WLASINVAMT, WLASCNOAMT, WLASPOHAMT, WLASPQHAMT, WLASPTHAMT
#-----
Gosub OUVRE_FIC  : # Par sécurité pour les Call RESYNCHRO_BPSMVT direct !
Gosub TRT_BPSMVT
End


#----------------------------------------------------------#
# Traitement de resynchronisation des encours fournisseurs #
#----------------------------------------------------------#
$TRT_BPSMVT
#-----
If !GSERVEUR
  #----- Ouverture fichier trace et écriture des sélections -----#
  If L_TRACE=2 & GTRACE=""
    Call OUVRE_TRACE(mess(332,197,1))  From LECFIC
    Call ECR_TRACE(" ",0)              From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
    Call PRTSCR("BPSMVT","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0)  From GESECRAN
    Call ECR_TRACE(" ",0)              From GESECRAN
  Endif 
Endif
# Issue 85354 - 2012-11-06 by SR 
##-----------------------------------------------------------------------------------------
## On commence par supprimer tous les enr. concernés par la sélection de la table BPSUPPMVT
##-----------------------------------------------------------------------------------------
CRIT='1=1'
If L_CPY   <>"" CRIT+=' & CPY=L_CPY' Endif
If L_BPSNUM<>"" CRIT+=' & BPSNUM=L_BPSNUM' Endif
Trbegin [MVS] 
Delete [MVS] Where evalue(CRIT)
If fstat
    Rollback
    GOK=0
    If L_TRACE=2
        Call ECR_TRACE("File BPSUPPMVT, Error ="-num$(fstat),1) From GESECRAN
    Endif
    Return
Else
    Commit
Endif
#-----------------------------------------#
# Vérification si des mouvements existent #
# avec un fournisseur non renseigné ou    #
# avec un tiers risque non renseigné ou   #
# avec une société non renseignée ou      #
# avec une devise non renseignée          #
#-----------------------------------------#
If L_TRACE=2
  WMSG="- "+mess(666,197,1)+" "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Raz CTEURMVS
For [MVS] MVS0 Where BPSNUM="" | BPSRSK="" | CPY="" | CUR=""
  CTEURMVS+=1
  WBPSNUM=[F:MVS]BPSNUM
  WBPSRSK=[F:MVS]BPSRSK
  WCPY   =[F:MVS]CPY
  WCUR   =[F:MVS]CUR
  If L_TRACE=2
    WMSG=WBPSNUM
    WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
    WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
    WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
    WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(411,197,1) : # Enregistrement supprimé
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
Next
If CTEURMVS>0
  GOK=1
  Trbegin [MVS]
  WMSG=mess(12,100,1)-"BPSUPPMVT"              : # Erreur d'accès sur le fichier ...
  Delete [MVS] Where BPSNUM=""
  If !fstat
    Commit
  Else
    Rollback
    GOK=0
    Call ECR_TRACE(WMSG,1) From GESECRAN       : # Erreur d'accès
    WMSG=mess(157,199,1)
    Call ECR_TRACE(WMSG,1) From GESECRAN       : # Transaction abandonnée
  Endif
  If GOK=1
    Trbegin [MVS]
    WMSG=mess(12,100,1)-"BPSUPPMVT"            : # Erreur d'accès sur le fichier ...
    Delete [MVS] Where BPSRSK=""
    If !fstat
      Commit
    Else
      Rollback
      GOK=0
      Call ECR_TRACE(WMSG,1) From GESECRAN     : # Erreur d'accès
      WMSG=mess(157,199,1)
      Call ECR_TRACE(WMSG,1) From GESECRAN     : # Transaction abandonnée
    Endif
    If GOK=1
      Trbegin [MVS]
      WMSG=mess(12,100,1)-"BPSUPPMVT"          : # Erreur d'accès sur le fichier ...
      Delete [MVS] Where CPY=""
      If !fstat
        Commit
      Else
        Rollback
        GOK=0
        Call ECR_TRACE(WMSG,1) From GESECRAN   : # Erreur d'accès
        WMSG=mess(157,199,1)
        Call ECR_TRACE(WMSG,1) From GESECRAN   : # Transaction abandonnée
      Endif
      If GOK=1
        Trbegin [MVS]
        WMSG=mess(12,100,1)-"BPSUPPMVT"        : # Erreur d'accès sur le fichier ...
        Delete [MVS] Where CUR=""
        If !fstat
          Commit
        Else
          Rollback
          GOK=0
          Call ECR_TRACE(WMSG,1) From GESECRAN : # Erreur d'accès
          WMSG=mess(157,199,1)
          Call ECR_TRACE(WMSG,1) From GESECRAN : # Transaction abandonnée
        Endif
      Endif
    Endif
  Endif
Endif
If L_TRACE=2
  WMSG="- ("+num$(CTEURMVS)+"-"+num$(CTEURMVS)+") "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(" ",0)  From GESECRAN
Endif
If GOK<1  Return : Endif

#--------------------------------------------#
# Traitement des commandes pour réajustement #
#     - Mt en commande HT    (ORDNOTC/L/R)   #
#     - Mt en commande TTC   (ORDATIC/L/R)   #
#     - Date dernière cde    (MVTDAT)        #
#     - Numéro dernière cde  (VCRNUM)        #
#     - Montant dernière cde (AMT)           #
#--------------------------------------------#
If L_TRACE=2
  WMSG="- "+mess(333,197,1)+" "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Vérification si des montants existent sans commande -----#
CRITERE="[F:MVS]ORDNOTC<>0"
If L_XCPYFLG<>2 CRITERE+=" & [F:MVS]CPY=L_CPY"       : Endif
If L_XBPSFLG<>2 CRITERE+=" & [F:MVS]BPSNUM=L_BPSNUM" : Endif
Raz CTEURMVS
GOK=1
For [MVS] Where evalue(CRITERE)
  INDIC=1
  Filter [POH] Where BPSNUM=[F:MVS]BPSNUM
&                  & CPY=[F:MVS]CPY
&                  & CLEFLG<>2
&                  & (BETFCY<2 | BETCPY=2)
  Read [POH] POH1 First
  If !fstat  Raz INDIC : Break : Endif
  If INDIC=1
    WBPSNUM=[F:MVS]BPSNUM
    WBPSRSK=[F:MVS]BPSRSK
    WCPY   =[F:MVS]CPY
    WCUR   =[F:MVS]CUR
    Gosub RAZ_MVS : If GOK<1 Break : Endif
  Endif
Next
Filter [POH]
If GOK<1 Return : Endif
#----- Vérification des montants avec les commandes -----#
CRITERE="[F:POH]CLEFLG<>2 & ([F:POH]BETFCY<2 | [F:POH]BETCPY=2)"
If L_XCPYFLG<>2 CRITERE+=" & [F:POH]CPY=L_CPY"       : Endif
If L_XBPSFLG<>2 CRITERE+=" & [F:POH]BPSNUM=L_BPSNUM" : Endif
Link [POH] With [BPS] BPS0=[POH]BPSNUM
&          As [POHX] Order By Key CLEX=[BPS]BPSRSK;[POH]CPY;[POH]BPSNUM;[POH]CUR;[POH]POHNUM Desc
Raz WORDNOTC, WORDNOTL, WORDNOTR, WORDATIC, WORDATIL, WORDATIR
Raz WLASORDDAT, WLASPOHNUM, WLASPOHAMT, WBPSNUM, WBPSRSK, WCPY, WCUR, COMPTEUR
GOK=1 : INDIC=1
For [POHX] CLEX Where evalue(CRITERE)
  If (WBPSRSK<>"" & WBPSRSK<>[F:BPS]BPSRSK) |
&    (WCPY   <>"" & WCPY   <>[F:POH]CPY)    |
&    (WBPSNUM<>"" & WBPSNUM<>[F:POH]BPSNUM) |
&    (WCUR   <>"" & WCUR   <>[F:POH]CUR)
    Gosub MAJ_MVS : If GOK<1 Break : Endif
  Endif
  If WBPSRSK=""
    WBPSRSK=[F:BPS]BPSRSK
    WCPY   =[F:POH]CPY
    WBPSNUM=[F:POH]BPSNUM
    WFCY   =[F:POH]POHFCY
    WCUR   =[F:POH]CUR
    GFCY   =[F:POH]POHFCY
    Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
  Endif
  #-----
  Raz WNBLIG
  For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
    #----- Exclure les lignes commandes ouvertes non fermes -----#
    If [F:POQ]POHTYP<>2 | [F:POQ]WIPSTA=1
      #----- Ne prendre que les lignes non soldées -----#
      If [F:POQ]LINCLEFLG<>2
        #-----
        If [F:POQ]QTYPUU=0 [F:POQ]QTYPUU=1 : Endif
        If [F:POQ]INVQTYPUU>[F:POQ]RCPQTYPUU
          #----- Si article facturé avant réception ou jamais réceptionné -----#
          WMT1=([F:POQ]LINAMT*max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU)
          WMT2=([F:POQ]LINATI*max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU)
        Else
          #----- Autres cas -----#
          WMT1=([F:POQ]LINAMT*max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU)
          WMT2=([F:POQ]LINATI*max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU)
        Endif
        #-----
        If [F:TCU]CUR<>[F:POH]CUR
          Read [TCU] TCU0=[F:POH]CUR : If fstat [F:TCU]CURRND=0.01 : Endif
        Endif
        WORDNOTC+=max(arr(WMT1,[F:TCU]CURRND),0)
        WORDATIC+=max(arr(WMT2,[F:TCU]CURRND),0)
        #----- Conversion si nécessaire des montants en devise société -----#
        If [F:POH]CUR<>GLOCALDEV
          Call CONVERT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                      WMT1,WMT3,STAT) From TRTDEV
          If STAT  WMT3=arr(WMT1,0.01) : Endif
          Call CONVERT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                      WMT2,WMT4,STAT) From TRTDEV
          If STAT  WMT4=arr(WMT2,0.01) : Endif
        Else
          WMT3=arr(WMT1,[F:TCU]CURRND)
          WMT4=arr(WMT2,[F:TCU]CURRND)
        Endif  
        WORDNOTL+=max(WMT3,0)
        WORDATIL+=max(WMT4,0)
        #----- Conversion si nécessaire des montants en devise dossier -----#
        If [F:POH]CUR<>GCURSHR
          Call CONVERT([F:POH]CUR,GCURSHR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                      WMT1,WMT3,STAT) From TRTDEV
          If STAT  WMT3=arr(WMT1,0.01) : Endif
          Call CONVERT([F:POH]CUR,GCURSHR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                      WMT2,WMT4,STAT) From TRTDEV
          If STAT  WMT4=arr(WMT2,0.01) : Endif
        Else
          WMT3=arr(WMT1,[F:TCU]CURRND)
          WMT4=arr(WMT2,[F:TCU]CURRND)
        Endif  
        WORDNOTR+=max(WMT3,0)
        WORDATIR+=max(WMT4,0)
        #----
        COMPTEUR+=1
      Endif
      #----- Cteur de lignes de commande (fermes pour les contrats) -----#
      WNBLIG+=1
    Endif
  Next
  #-----
  If WNBLIG>0 | [F:POH]POHTYP=1
    If WLASORDDAT<[F:POH]ORDDAT
      WLASORDDAT=[F:POH]ORDDAT
      WLASPOHNUM=[F:POH]POHNUM
      WLASPOHAMT=[F:POH]TTVORD
    Elsif WLASORDDAT=[F:POH]ORDDAT & WLASPOHNUM<[F:POH]POHNUM
      WLASPOHNUM=[F:POH]POHNUM
      WLASPOHAMT=[F:POH]TTVORD
    Elsif WLASORDDAT=[F:POH]ORDDAT & WLASPOHNUM=[F:POH]POHNUM
      WLASPOHAMT=[F:POH]TTVORD
    Endif
  Endif
Next
If GOK<1  Return : Endif
Raz [F:POH]
If WBPSRSK<>"" | WCPY<>"" | WBPSNUM<>"" | WCUR<>""  Gosub MAJ_MVS : Endif
Close Local File [POHX]
If L_TRACE=2
  WMSG="- ("+num$(COMPTEUR)+"-"+num$(CTEURMVS)+") "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(" ",0)  From GESECRAN
Endif
If GOK<1  Return : Endif

#----------------------------------------------------#
# Traitement des réceptions pour réajustement        #
#     - Mt réceptionné non facturé HT  (RCPNOTC/L/R) #
#     - Mt réceptionné non facturé TTC (RCPATIC/L/R) #
#     - Date dernière réception        (MVTDAT)      #
#     - Numéro dernière réception      (VCRNUM)      #
#     - Montant dernière réception     (AMT)         #
#----------------------------------------------------#
If L_TRACE=2
  WMSG="- "+mess(334,197,1)+" "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Vérification si des montants existent sans réception -----#
CRITERE="[F:MVS]RCPNOTC<>0"
If L_XCPYFLG<>2 CRITERE+=" & [F:MVS]CPY=L_CPY"       : Endif
If L_XBPSFLG<>2 CRITERE+=" & [F:MVS]BPSNUM=L_BPSNUM" : Endif
Link [PTD] With [PTH] PTH0=[F:PTD]PTHNUM    As [PTDX]
Raz CTEURMVS
GOK=1
For [MVS] Where evalue(CRITERE)
  INDIC=2
  Filter [PTDX] Where [F:PTD]LININVFLG<>2
&                   & [F:PTD]CPY=[F:MVS]CPY
&                   & [F:PTD]BPSNUM=[F:MVS]BPSNUM
&                   & ([F:PTH]BETFCY<>2 | [F:PTH]BETCPY=2)
    Read [PTDX] PTD1 First
    If !fstat  Raz INDIC : Break : Endif
  If INDIC=2
    WBPSNUM=[F:MVS]BPSNUM
    WBPSRSK=[F:MVS]BPSRSK
    WCPY   =[F:MVS]CPY
    WCUR   =[F:MVS]CUR
    Gosub RAZ_MVS : If GOK<1 Break : Endif
  Endif
Next
Filter [PTDX]
Close Local File [PTDX]
If GOK<1 Return : Endif
#----- Vérification des montants avec les réceptions -----#
CRITERE="[F:PTD]LININVFLG<>2 & ([F:PTH]BETFCY<2 | [F:PTH]BETCPY=2)"
If L_XCPYFLG<>2 CRITERE+=" & [F:PTH]CPY=L_CPY"       : Endif
If L_XBPSFLG<>2 CRITERE+=" & [F:PTH]BPSNUM=L_BPSNUM" : Endif
Link [PTD] With [PTH] PTH0=[F:PTD]PTHNUM, [BPS] BPS0=[PTD]BPSNUM
&          As [PTDX] Order By Key CLEX=[BPS]BPSRSK;[PTH]CPY;[PTH]BPSNUM;[PTH]CUR;[PTH]PTHNUM Desc
Raz WRCPNOTC, WRCPNOTL, WRCPNOTR, WRCPATIC, WRCPATIL, WRCPATIR
Raz WLASRCPDAT, WLASPTHNUM, WLASPTHAMT, WBPSNUM, WBPSRSK, WCPY, WCUR, COMPTEUR
GOK=1 : INDIC=2
For [PTDX] CLEX Where evalue(CRITERE)
  If (WBPSRSK<>"" & WBPSRSK<>[F:BPS]BPSRSK) |
&    (WCPY   <>"" & WCPY   <>[F:PTH]CPY)    |
&    (WBPSNUM<>"" & WBPSNUM<>[F:PTH]BPSNUM) |
&    (WCUR   <>"" & WCUR   <>[F:PTH]CUR)
    Gosub MAJ_MVS : If GOK<1 Break : Endif
  Endif
  If WBPSRSK=""
    WBPSRSK=[F:BPS]BPSRSK
    WCPY   =[F:PTH]CPY
    WBPSNUM=[F:PTH]BPSNUM
    WFCY   =[F:PTH]PRHFCY
    WCUR   =[F:PTH]CUR
    If [F:PTD]POHNUM<>""
      GFCY=[F:PTD]POHFCY : # Site de commande
    Else
      GFCY=[F:PTD]PRHFCY : # Site de réception (si rcp sans cde)
    Endif
    Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
  Endif
  #-----
  If WLASRCPDAT<[F:PTH]RCPDAT
    WLASRCPDAT=[F:PTH]RCPDAT
    WLASPTHNUM=[F:PTH]PTHNUM
    WLASPTHAMT=[F:PTH]TOTAMTATI
  Elsif WLASRCPDAT=[F:PTH]RCPDAT & WLASPTHNUM<[F:PTH]PTHNUM
    WLASPTHNUM=[F:PTH]PTHNUM
    WLASPTHAMT=[F:PTH]TOTAMTATI
  Elsif WLASRCPDAT=[F:PTH]RCPDAT & WLASPTHNUM=[F:PTH]PTHNUM
    WLASPTHAMT=[F:PTH]TOTAMTATI
  Endif
  #-----
  If [F:PTD]QTYPUU<>0 & [F:PTD]INVQTYPUU<>0
    WMT1=[F:PTD]LINAMT   *max([F:PTD]QTYPUU-[F:PTD]INVQTYPUU,0)/[F:PTD]QTYPUU
    WMT2=[F:PTD]LINATIAMT*max([F:PTD]QTYPUU-[F:PTD]INVQTYPUU,0)/[F:PTD]QTYPUU
  Else
    WMT1=[F:PTD]LINAMT
    WMT2=[F:PTD]LINATIAMT
  Endif
  #-----
  If [F:PTD]POHNUM<>""
    If [F:POH]POHNUM<>[F:PTD]POHNUM
      Read [POH] POH0=[F:PTD]POHNUM
      If fstat
        Raz [F:POH] : [F:POH]CHGTYP=[F:PTH]CHGTYP : [F:POH]ORDDAT=[F:PTH]RCPDAT
      Endif
    Endif
  Else
    Raz [F:POH] : [F:POH]CHGTYP=[F:PTH]CHGTYP : [F:POH]ORDDAT=[F:PTH]RCPDAT
  Endif
  #----- Conversion si nécessaire du montant en devise entête réception -----#
  If [F:PTH]CUR<>[F:PTD]NETCUR
    Call CONVERT2([F:PTD]NETCUR,[F:PTH]CUR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT1,WMT3,STAT) From TRTDEV
    If STAT  WMT3=WMT1 : Endif
    Call CONVERT2([F:PTD]NETCUR,[F:PTH]CUR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT2,WMT4,STAT) From TRTDEV
    If STAT  WMT4=WMT2 : Endif
  Else
    WMT3=WMT1
    WMT4=WMT2
  Endif
  #-----
  If [F:TCU]CUR<>[F:PTH]CUR
    Read [TCU] TCU0=[F:PTH]CUR : If fstat [F:TCU]CURRND=0.01 : Endif
  Endif
  WRCPNOTC+=max(arr(WMT3,[F:TCU]CURRND),0)
  WRCPATIC+=max(arr(WMT4,[F:TCU]CURRND),0)
  #----- Conversion si nécessaire des montants en devise société -----#
  If [F:PTH]CUR<>GLOCALDEV
    Call CONVERT([F:PTD]NETCUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT1,WMT3,STAT) From TRTDEV
    If STAT  WMT3=arr(WMT1,0.01) : Endif
    Call CONVERT([F:PTD]NETCUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT2,WMT4,STAT) From TRTDEV
    If STAT  WMT4=arr(WMT2,0.01) : Endif
  Else
    WMT3=arr(WMT1,[F:TCU]CURRND)
    WMT4=arr(WMT2,[F:TCU]CURRND)
  Endif  
  WRCPNOTL+=max(WMT3,0)
  WRCPATIL+=max(WMT4,0)
  #----- Conversion si nécessaire des montants en devise dossier -----#
  If [F:PTH]CUR<>GCURSHR
    Call CONVERT([F:PTD]NETCUR,GCURSHR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT1,WMT3,STAT) From TRTDEV
    If STAT  WMT3=arr(WMT1,0.01) : Endif
    Call CONVERT([F:PTD]NETCUR,GCURSHR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT2,WMT4,STAT) From TRTDEV
    If STAT  WMT4=arr(WMT2,0.01) : Endif
  Else
    WMT3=arr(WMT1,[F:TCU]CURRND)
    WMT4=arr(WMT2,[F:TCU]CURRND)
  Endif  
  WRCPNOTR+=max(WMT3,0)
  WRCPATIR+=max(WMT4,0)
  #-----
  COMPTEUR+=1
  #----- Vérif si ligne de réception sans entête -----#
  If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
    If L_TRACE=2
      Call ECR_TRACE([F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-mess(212,194,1),1) From GESECRAN
    Endif
    Raz WBPSRSK, WCPY, WBPSNUM, WCUR
    Raz WRCPNOTC, WRCPNOTL, WRCPNOTR, WRCPATIC, WRCPATIL, WRCPATIR
  Endif
Next
If GOK<1  Return : Endif
Raz [F:PTH]
If WBPSRSK<>"" | WCPY<>"" | WBPSNUM<>"" | WCUR<>""  Gosub MAJ_MVS : Endif
Close Local File [PTDX]
If L_TRACE=2
  WMSG="- ("+num$(COMPTEUR)+"-"+num$(CTEURMVS)+") "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(" ",0)  From GESECRAN
Endif
If GOK<1  Return : Endif

#-------------------------------------------------#
# Traitement des factures pour réajustement       #
#     - Mt facturé non comptabilisé (INVAMTC/L/R) #
#     - Date dernière facture       (MVTDAT)      #
#     - Numéro dernière facture     (VCRNUM)      #
#     - Montant dernière facture    (AMT)         #
#-------------------------------------------------#
If L_TRACE=2
  WMSG="- "+mess(335,197,1)+" "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#----- Vérification si des montants existent sans facture -----#
CRITERE="[F:MVS]INVAMTC<>0"
If L_XCPYFLG<>2 CRITERE+=" & [F:MVS]CPY=L_CPY"       : Endif
If L_XBPSFLG<>2 CRITERE+=" & [F:MVS]BPSNUM=L_BPSNUM" : Endif
Raz CTEURMVS
GOK=1
For [MVS] Where evalue(CRITERE)
  INDIC=3
  Filter [PIH] Where BPR=[F:MVS]BPSNUM & CPY=[F:MVS]CPY
  Read [PIH] PIH1 First
  If !fstat Raz INDIC : Break : Endif
  If INDIC=3
    WBPSNUM=[F:MVS]BPSNUM
    WBPSRSK=[F:MVS]BPSRSK
    WCPY   =[F:MVS]CPY
    WCUR   =[F:MVS]CUR
    Gosub RAZ_MVS : If GOK<1 Break : Endif
  Endif
Next
Filter [PIH]
If GOK<1 Return : Endif
#----- Vérification des montants avec les factures -----#
CRITERE="1=1"
If L_XCPYFLG<>2 CRITERE+=" & [F:PIH]CPY=L_CPY"       : Endif
If L_XBPSFLG<>2 CRITERE+=" & [F:PIH]BPR=L_BPSNUM"    : Endif
Link [PIH] With [BPS] BPS0=[PIH]BPR
&          As [XPIH] Order By Key CLEX=[BPS]BPSRSK;[PIH]CPY;[PIH]BPR;[PIH]CUR;[PIH]NUM Desc
Raz WINVAMTC, WINVAMTL, WINVAMTR
Raz WLASINVDAT, WLASINVNUM, WLASINVAMT, WLASCNODAT, WLASCNONUM, WLASCNOAMT
Raz WBPSNUM, WBPSRSK, WCPY, WCUR, COMPTEUR
GOK=1 : INDIC=3
For [XPIH] CLEX Where evalue(CRITERE)
  If (WBPSRSK<>"" & WBPSRSK<>[F:BPS]BPSRSK) |
&    (WCPY   <>"" & WCPY   <>[F:PIH]CPY)    |
&    (WBPSNUM<>"" & WBPSNUM<>[F:PIH]BPR)    |
&    (WCUR   <>"" & WCUR   <>[F:PIH]CUR)
    Gosub MAJ_MVS : If GOK<1 Break : Endif
  Endif
  If WBPSRSK=""
    WBPSRSK=[F:BPS]BPSRSK
    WCPY   =[F:PIH]CPY
    WBPSNUM=[F:PIH]BPR
    WFCY   =[F:PIH]FCY
    WCUR   =[F:PIH]CUR
    GFCY   =[F:PIH]FCY
    Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
  Endif
  WMT1=[F:PIH]AMTATI
  #----- Conversion si nécessaire du montant en devise société -----#
  If [F:PIH]CUR<>GLOCALDEV
    WCOURS=0
    WI=find(GLOCALDEV,[F:PIH]CURLED)
    If WI & [F:PIH]RATDIV(WI-1)<>0
      WCOURS=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
    Endif
    Call COURMNT([F:PIH]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,1,
&              WMT1,WMT2,WCOURS,STAT) From TRTDEV
    If STAT  WMT2=WMT1 : Endif
  Else
    WMT2=WMT1
  Endif
  #----- Conversion si nécessaire du montant en devise dossier -----#
  If [F:PIH]CUR<>GCURSHR
    Call CONVERT([F:PIH]CUR,GCURSHR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                WMT1,WMT3,STAT) From TRTDEV
    If STAT  WMT3=WMT1 : Endif
  Else
    WMT3=WMT1
  Endif
  #-----
  If [F:PIH]STA<>3
    WINVAMTC+=WMT1*(3-(2*[F:PIH]INVTYP))
    WINVAMTL+=WMT2*(3-(2*[F:PIH]INVTYP))
    WINVAMTR+=WMT3*(3-(2*[F:PIH]INVTYP))
  #-----
  Else
    If [F:PIH]INVTYP<2
      If WLASINVDAT<[F:PIH]ACCDAT
        WLASINVDAT=[F:PIH]ACCDAT
        WLASINVNUM=[F:PIH]NUM
        WLASINVAMT=[F:PIH]AMTATI
      Elsif WLASINVDAT=[F:PIH]ACCDAT & WLASINVNUM<[F:PIH]NUM
        WLASINVNUM=[F:PIH]NUM
        WLASINVAMT=[F:PIH]AMTATI
      Elsif WLASINVDAT=[F:PIH]ACCDAT & WLASINVNUM=[F:PIH]NUM
        WLASINVAMT=[F:PIH]AMTATI
      Endif
    Else
      If WLASCNODAT<[F:PIH]ACCDAT
        WLASCNODAT=[F:PIH]ACCDAT
        WLASCNONUM=[F:PIH]NUM
        WLASCNOAMT=[F:PIH]AMTATI
      Elsif WLASCNODAT=[F:PIH]ACCDAT & WLASCNONUM<[F:PIH]NUM
        WLASCNONUM=[F:PIH]NUM
        WLASCNOAMT=[F:PIH]AMTATI
      Elsif WLASCNODAT=[F:PIH]ACCDAT & WLASCNONUM=[F:PIH]NUM
        WLASCNOAMT=[F:PIH]AMTATI
      Endif
    Endif
  Endif
  #-----
  COMPTEUR+=1
Next
If GOK<1  Return : Endif
Raz [F:PIH]
If WBPSRSK<>"" | WCPY<>"" | WBPSNUM<>"" | WCUR<>""  Gosub MAJ_MVS : Endif
Close Local File [XPIH]
If L_TRACE=2
  WMSG="- ("+num$(COMPTEUR)+"-"+num$(CTEURMVS)+") "
  WMSG+=string$(70-len(WMSG),"-")
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(" ",0)  From GESECRAN
Endif
If GOK<1  Return : Endif

#-------------------------------------------------------------#
# Traitement des mouvements comptables si module compta actif #
#     - Mt solde comptable (BLCAMTC/L/R)                      #
#     - Mts portefeuille   (BILAMTC/L/R)                      #
#-------------------------------------------------------------#
If !clalev([F:ADS]) & GMODU(2)=2
  Call RECUPSOL(L_CPY,1,2,2,2,GSERVEUR,1,L_TRACE-1) From RECUPSOL
  If GOK<1  Return : Endif
Endif
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
TRA=0
If !GSERVEUR
  #----- Fermeture et affichage de la trace -----#
  If [M:DIA]TRACE=2
    Call FERME_TRACE From LECFIC : TRA=1
  Endif
Endif
Return


#######################################################
# Traitement du grisage et dégrisage des champs écran #
#######################################################
$GRISAGE
If [M:DIA]XCPYFLG=2 Diszo [DIA]CPY     Else Actzo [DIA]CPY    : Endif
If [M:DIA]XBPSFLG=2 Diszo [DIA]BPSNUM  Else Actzo [DIA]BPSNUM : Endif
Return


#------------------------------------------------------------------------#
# Chargement devise, site principal et site financier de la société WCPY #
#------------------------------------------------------------------------#
$CHARG_DEVSOC
If WCPY<>GSOCIETE
  GSOCIETE=WCPY
  If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE : If fstat  Raz [F:CPY] : [F:CPY]ACCCUR="EUR" : Endif
  Endif
  GLOCALDEV=[F:CPY]ACCCUR
  GFCY     =[F:CPY]MAIFCY
  If [F:FCY]FCY<>GFCY
    Read [FCY] FCY0=GFCY : If fstat  Raz [F:FCY] : [F:FCY]FINRSPFCY=GFCY : Endif
  Endif
  GFINRSP=[F:FCY]FINRSPFCY
Endif
Return


#-------------------------------------------------------------#
# Remise à zéro du fichier mouvements fournisseur (BPSUPPMVT) #
# ----------------------------------------------------------- #
#   INDIC = 1 : Traitement commandes                          #
#                  - Raz ORDNOTC, ORDNOTL, ORDNOTR            #
#                        ORDATIC, ORDATIL, ORDATIR            #
#           2 : Traitement réceptions                         #
#                  - Raz RCPNOTC, RCPNOTL, RCPNOTR            #
#                        RCPATIC, RCPATIL, RCPATIR            #
#           3 : Traitement factures                           #
#                  - Raz INVAMTC, INVAMTL, INVAMTR            #
#-------------------------------------------------------------#
$RAZ_MVS
Gosub CHARG_DEVSOC : # Récupération devise et sites de la société WCPY
Call DEBTRANS From GLOCK
$DEB_RAZ_MVS
GOK=1
Trbegin [MVS]
  CREFLG=0 : UPDFLG=0
  WMSG=mess(12,100,1)-"BPSUPPMVT"-WBPSRSK-WCPY-WBPSNUM-WCUR
  Readlock [MVS] MVS0=WBPSRSK;WCPY;WBPSNUM;WCUR
  If fstat=1
    GOK=-1 : GLOCK="$BPSUPPMVT"-WBPSRSK-WCPY-WBPSNUM-WCUR : Goto ROLL_RAZ_MVS 
  Elsif fstat 
    CREFLG=1
    Raz [F:MVS]
    [F:MVS]BPSNUM   =WBPSNUM
    [F:MVS]ACCCUR   =GLOCALDEV
    [F:MVS]BPSRSK   =WBPSRSK
    [F:MVS]CPY      =WCPY
    [F:MVS]CUR      =WCUR
    If dim([F:MVS]CREDAT)>0 [F:MVS]CREDAT=date$     : Endif
    If dim([F:MVS]CREUSR)>0 [F:MVS]CREUSR=GUSER     : Endif
    If dim([F:MVS]EXPNUM)>0 [F:MVS]EXPNUM=[C]EXPORT : Endif
  Endif
  Case INDIC
    When 1
      If [F:MVS]ORDNOTC<>0 | [F:MVS]ORDNOTL<>0 | [F:MVS]ORDNOTR<>0 |
&        [F:MVS]ORDATIC<>0 | [F:MVS]ORDATIL<>0 | [F:MVS]ORDATIR<>0
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #----- Rectif Mt en commande
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(336,197,1)
          WMSG-=num$([F:MVS]ORDNOTC)-"-->"-num$(0)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        Raz [F:MVS]ORDNOTC, [F:MVS]ORDNOTL, [F:MVS]ORDNOTR,
&           [F:MVS]ORDATIC, [F:MVS]ORDATIL, [F:MVS]ORDATIR                   
        UPDFLG=1
      Endif
    When 2
      If [F:MVS]RCPNOTC<>0 | [F:MVS]RCPNOTL<>0 | [F:MVS]RCPNOTR<>0 |
&        [F:MVS]RCPATIC<>0 | [F:MVS]RCPATIL<>0 | [F:MVS]RCPATIR<>0
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #-----  Rectif Mt réceptionné non fact
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(338,97,1)
          WMSG-=num$([F:MVS]RCPNOTL)-"-->"-num$(0)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        Raz [F:MVS]RCPNOTC, [F:MVS]RCPNOTL, [F:MVS]RCPNOTR,
&           [F:MVS]RCPATIC, [F:MVS]RCPATIL, [F:MVS]RCPATIR
        UPDFLG=1
      Endif
    When 3
      If [F:MVS]INVAMTC<>0 | [F:MVS]INVAMTL<>0 | [F:MVS]INVAMTR<>0
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #-----  Rectif Mt facturé non compta
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(339,197,1)
          WMSG-=num$([F:MVS]INVAMTC)-"-->"-num$(0)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        # Issue 76000 - 2011-09-02 by VPO : classe inexistante [M:MVS]
        #Raz [F:MVS]INVAMTC, [F:MVS]INVAMTL, [M:MVS]INVAMTR
        Raz [F:MVS]INVAMTC, [F:MVS]INVAMTL, [F:MVS]INVAMTR
        UPDFLG=1
      Endif
  Endcase
  If UPDFLG=1
    If dim([F:MVS]UPDDAT)>0 [F:MVS]UPDDAT=date$ : Endif
    If dim([F:MVS]UPDUSR)>0 [F:MVS]UPDUSR=GUSER : Endif
  Endif
  WMSG=mess(13,100,1)-"BPSUPPMVT"-WBPSRSK-WCPY-WBPSNUM-WCUR
  If CREFLG=0
    [F:MVS]ACCCUR=GLOCALDEV : # Par sécurité si la devise société a été changée
    Rewrite [MVS]
  Else 
    Write [MVS]
  Endif 
  If fstat  GOK=0 : Call FSTA("MVS") From GLOCK : Goto AB_TRA_MVS : Endif
Commit
$FIN_RAZ_MVS
CTEURMVS+=1
Raz WBPSNUM
Return

#----- Nouvel essai de transaction ou abandon suivant GROLL -----#
$ROLL_RAZ_MVS
Rollback : Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(WMSG,1) From GESECRAN : # Erreur d'accès ou d'écriture
  WMSG=mess(157,199,1)
  Call ECR_TRACE(WMSG,1) From GESECRAN : # Transaction abandonnée
  Goto FIN_RAZ_MVS
Else
  Goto DEB_RAZ_MVS
Endif

#----- Abandon de la transaction -----#
$AB_RAZ_MVS
Rollback
Call ECR_TRACE(WMSG,1) From GESECRAN   : # Erreur d'accès ou d'écriture
WMSG=mess(157,199,1)
Call ECR_TRACE(WMSG,1) From GESECRAN   : # Transaction abandonnée
Goto FIN_RAZ_MVS


#-----------------------------------------------------------#
# Mise à jour du fichier mouvements fournisseur (BPSUPPMVT) #
# --------------------------------------------------------- #
#   INDIC = 1 : Traitement commandes                        #
#                  - Vérif WORDNOTC, WORDATIC               #
#           2 : Traitement réceptions                       #
#                  - Vérif WRCPNOTC, WRCPATIC               #
#           3 : Traitement factures                         #
#                  - Vérif WINVAMTC                         #
#-----------------------------------------------------------#
$MAJ_MVS
#-----
Call DEBTRANS From GLOCK
$DEB_TRA_MVS
GOK=1
Trbegin [MVS], [LSM]
  #-----
  CREFLG=0 : UPDFLG=0
  WMSG=mess(12,100,1)-"BPSUPPMVT"-WBPSRSK-WCPY-WBPSNUM-WCUR
  Readlock [MVS] MVS0=WBPSRSK;WCPY;WBPSNUM;WCUR
  If fstat=1
    GOK=-1 : GLOCK="$BPSUPPMVT"-WBPSRSK-WCPY-WBPSNUM-WCUR : Goto ROLL_TRA_MVS 
  Elsif fstat
    CREFLG=1
    Raz [F:MVS]
    [F:MVS]BPSNUM   =WBPSNUM
    [F:MVS]ACCCUR   =GLOCALDEV
    [F:MVS]BPSRSK   =WBPSRSK
    [F:MVS]CPY      =WCPY
    [F:MVS]CUR      =WCUR
    If dim([F:MVS]CREDAT)>0 [F:MVS]CREDAT=date$     : Endif
    If dim([F:MVS]CREUSR)>0 [F:MVS]CREUSR=GUSER     : Endif
    If dim([F:MVS]EXPNUM)>0 [F:MVS]EXPNUM=[C]EXPORT : Endif
  Endif
  #-----
  Case INDIC
    When 1 : #----- Traitement des commandes -----#
      If [F:MVS]ORDNOTC<>WORDNOTC
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #----- Rectif Mt en commande
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(336,197,1)
          WMSG-=mess(1,243,1)-num$([F:MVS]ORDNOTC)-"-->"-num$(WORDNOTC)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        [F:MVS]ORDNOTC=WORDNOTC
        [F:MVS]ORDNOTL=WORDNOTL
        [F:MVS]ORDNOTR=WORDNOTR
        UPDFLG=1
      Endif
      If [F:MVS]ORDATIC<>WORDATIC
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #----- Rectif Mt en commande
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(336,197,1)
          WMSG-=mess(2,243,1)-num$([F:MVS]ORDATIC)-"-->"-num$(WORDATIC)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        [F:MVS]ORDATIC=WORDATIC
        [F:MVS]ORDATIL=WORDATIL
        [F:MVS]ORDATIR=WORDATIR
        UPDFLG=1
      Endif
      If WBPSNUM<>[F:POH]BPSNUM | WCPY<>[F:POH]CPY
        If WLASPOHNUM<>""
          WIFFTYP=3 : WMVTTYP=3 : WIFFFCY=WFCY : Gosub MAJ_LSM
          If GOK=-1  Goto ROLL_TRA_MVS : Endif
          If GOK<1   Goto AB_TRA_MVS   : Endif 
        Endif
      Endif
    When 2 : #----- traitement des réceptions -----#
      If [F:MVS]RCPNOTC<>WRCPNOTC
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #----- Rectif Mt réceptionné non fact
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(338,197,1)
          WMSG-=mess(1,243,1)-num$([F:MVS]RCPNOTC)-"-->"-num$(WRCPNOTC)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        [F:MVS]RCPNOTC=WRCPNOTC
        [F:MVS]RCPNOTL=WRCPNOTL
        [F:MVS]RCPNOTR=WRCPNOTR
        UPDFLG=1
      Endif
      If [F:MVS]RCPATIC<>WRCPATIC
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #----- Rectif Mt réceptionné non fact
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(338,197,1)
          WMSG-=mess(2,243,1)-num$([F:MVS]RCPATIC)-"-->"-num$(WRCPATIC)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        [F:MVS]RCPATIC=WRCPATIC
        [F:MVS]RCPATIL=WRCPATIL
        [F:MVS]RCPATIR=WRCPATIR
        UPDFLG=1
      Endif
      If WBPSNUM<>[F:PTH]BPSNUM | WCPY<>[F:PTH]CPY
        If WLASPTHNUM<>""
          WIFFTYP=4 : WMVTTYP=4 : WIFFFCY=WFCY : Gosub MAJ_LSM
          If GOK=-1  Goto ROLL_TRA_MVS : Endif
          If GOK<1   Goto AB_TRA_MVS   : Endif
        Endif
      Endif
    When 3 : #----- Traitement des factures et avoirs -----#
      If [F:MVS]INVAMTC<>WINVAMTC
        If L_TRACE=2
          WMSG=WBPSNUM
          WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
          WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
          #----- Rectif Mt facturé non compta
          WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(339,197,1)
          WMSG-=num$([F:MVS]INVAMTC)-"-->"-num$(WINVAMTC)
          # Issue 85354 - 2012-11-06 by SR
          Call ECR_TRACE(WMSG,-1) From GESECRAN
        Endif
        [F:MVS]INVAMTC=WINVAMTC
        [F:MVS]INVAMTL=WINVAMTL
        [F:MVS]INVAMTR=WINVAMTR
        UPDFLG=1
      Endif
      If WBPSNUM<>[F:PIH]BPR | WCPY<>[F:PIH]CPY
        If WLASINVNUM<>""
          WIFFTYP=6 : WMVTTYP=6 : WIFFFCY=WFCY : Gosub MAJ_LSM
          If GOK=-1  Goto ROLL_TRA_MVS : Endif
          If GOK<1   Goto AB_TRA_MVS   : Endif 
        Endif
        If WLASCNONUM<>""
          WIFFTYP=7 : WMVTTYP=6 : WIFFFCY=WFCY : Gosub MAJ_LSM
          If GOK=-1  Goto ROLL_TRA_MVS : Endif
          If GOK<1   Goto AB_TRA_MVS   : Endif 
        Endif
      Endif
  Endcase
  If UPDFLG=1
    If dim([F:MVS]UPDDAT)>0 [F:MVS]UPDDAT=date$ : Endif
    If dim([F:MVS]UPDUSR)>0 [F:MVS]UPDUSR=GUSER : Endif
  Endif
  WMSG=mess(13,100,1)-"BPSUPPMVT"-WBPSRSK-WCPY-WBPSNUM-WCUR
  If CREFLG=0
    [F:MVS]ACCCUR=GLOCALDEV : # Par sécurité si la devise société a été changée
    Rewrite [MVS]
  Else
    Write [MVS]
  Endif 
  If fstat  GOK=0 : Call FSTA("MVS") From GLOCK : Goto AB_TRA_MVS : Endif
Commit
$FIN_TRA_MVS
CTEURMVS+=1
Raz WBPSRSK, WCPY, WBPSNUM, WCUR
Raz WORDNOTC, WORDNOTL, WORDNOTR, WORDATIC, WORDATIL, WORDATIR
Raz WRCPNOTC, WRCPNOTL, WRCPNOTR, WRCPATIC, WRCPATIL, WRCPATIR
Raz WINVAMTC, WINVAMTL, WINVAMTR
Raz WLASORDDAT, WLASPOHNUM, WLASPOHAMT
Raz WLASRCPDAT, WLASPTHNUM, WLASPTHAMT
Raz WLASINVDAT, WLASINVNUM, WLASINVAMT
Raz WLASCNODAT, WLASCNONUM, WLASCNOAMT
Return

#----- Nouvel essai de transaction ou abandon suivant GROLL -----#
$ROLL_TRA_MVS
Rollback : Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(WMSG,1) From GESECRAN : # Erreur d'accès ou d'écriture
  WMSG=mess(157,199,1)
  Call ECR_TRACE(WMSG,1) From GESECRAN : # Transaction abandonnée
  Goto FIN_TRA_MVS
Else
  Goto DEB_TRA_MVS
Endif

#----- Abandon de la transaction -----#
$AB_TRA_MVS
Rollback
Call ECR_TRACE(WMSG,1) From GESECRAN   : # Erreur d'accès ou d'écriture
WMSG=mess(157,199,1)
Call ECR_TRACE(WMSG,1) From GESECRAN   : # Transaction abandonnée
Goto FIN_TRA_MVS


#---------------------------------------------------------------------#
# Mise à jour du fichier derniers mouvements fournisseur (LASTSUPMVT) #
# ------------------------------------------------------------------- #
#   WIFFTYP = 3 : Traitement commandes                                #
#                    - Vérif WLASORDDAT, WLASPOHNUM et WLASPOHAMT     #
#             4 : Traitement réceptions                               #
#                    - Vérif WLASRCPDAT, WLASPTHNUM et WLASPTHAMT     #
#             6 : Traitement factures                                 #
#                    - Vérif WLASINVDAT, WLASINVNUM et WLASINVAMT     #
#             7 : Traitement avoirs                                   #
#                    - Vérif WLASCNODAT, WLASCNONUM et WLASCNOAMT     #
#---------------------------------------------------------------------#
$MAJ_LSM
#-----
CREFLG2=0 : UPDFLG2=0
WMSG=mess(12,100,1)-"LASTSUPMVT"-WBPSNUM-num$(WIFFTYP)-WCPY
Readlock [LSM] LSM0=WBPSNUM;WIFFTYP;WCPY
If fstat=1
  GOK=-1 : GLOCK="$LASTSUPMVT"-WBPSNUM-num$(WIFFTYP)-WCPY : Return 
Elsif fstat
  CREFLG2=1
  Raz [F:LSM]
  [F:LSM]BPSNUM   =WBPSNUM
  [F:LSM]IFFTYP   =WIFFTYP
  [F:LSM]CPY      =WCPY
  [F:LSM]MVTTYP   =WMVTTYP
  [F:LSM]CUR      =WCUR
  [F:LSM]IFFFCY   =WIFFFCY
  If dim([F:LSM]CREDAT)>0 [F:LSM]CREDAT=date$     : Endif
  If dim([F:LSM]CREUSR)>0 [F:LSM]CREUSR=GUSER     : Endif
  If dim([F:LSM]EXPNUM)>0 [F:LSM]EXPNUM=[C]EXPORT : Endif
Endif
#-----
Case WIFFTYP
  When 3 : #----- Traitement des commandes -----€
    Raz LASFLG
    If [F:LSM]MVTDAT<WLASORDDAT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif Date dernière cde
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(337,197,1)
        WMSG-=format$("DD2",[F:LSM]MVTDAT)-"-->"-format$("DD2",WLASORDDAT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]MVTDAT=WLASORDDAT : UPDFLG2=1 : LASFLG=1
    Endif
    If (LASFLG=1 & [F:LSM]VCRNUM<>WLASPOHNUM) |
&      ([F:LSM]MVTDAT=WLASORDDAT & [F:LSM]VCRNUM<WLASPOHNUM)
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif numéro dernière cde
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(514,197,1)
        WMSG-=[F:LSM]VCRNUM-"-->"-WLASPOHNUM
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]VCRNUM=WLASPOHNUM : UPDFLG2=1 : LASFLG=1
    Endif
    If LASFLG=1 & [F:LSM]AMT<>WLASPOHAMT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif montant dernière cde
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(515,197,1)
        WMSG-=num$([F:LSM]AMT)-"-->"-num$(WLASPOHAMT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]AMT=WLASPOHAMT : UPDFLG2=1
    Endif
  When 4 : #----- Traitement des réceptions -----#
    Raz LASFLG
    If [F:LSM]MVTDAT<WLASRCPDAT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif Date dernière rcp
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(516,197,1)
        WMSG-=format$("DD2",[F:LSM]MVTDAT)-"-->"-format$("DD2",WLASRCPDAT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]MVTDAT=WLASRCPDAT : UPDFLG2=1 : LASFLG=1
    Endif
    If (LASFLG=1 & [F:LSM]VCRNUM<>WLASPTHNUM) |
&      ([F:LSM]MVTDAT=WLASRCPDAT & [F:LSM]VCRNUM<WLASPTHNUM)
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif numéro dernière rcp
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(517,197,1)
        WMSG-=[F:LSM]VCRNUM-"-->"-WLASPTHNUM
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]VCRNUM=WLASPTHNUM : UPDFLG2=1 : LASFLG=1
    Endif
    If LASFLG=1 & [F:LSM]AMT<>WLASPTHAMT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif montant dernière rcp
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(518,197,1)
        WMSG-=num$([F:LSM]AMT)-"-->"-num$(WLASPTHAMT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]AMT=WLASPTHAMT : UPDFLG2=1
    Endif
  When 6 : #----- Traitement des factures -----#
    Raz LASFLG
    If [F:LSM]MVTDAT<WLASINVDAT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif Date dernière facture
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(340,197,1)
        WMSG-=format$("DD2",[F:LSM]MVTDAT)-"-->"-format$("DD2",WLASINVDAT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]MVTDAT=WLASINVDAT : UPDFLG2=1 : LASFLG=1
    Endif
    If (LASFLG=1 & [F:LSM]VCRNUM<>WLASINVNUM) |
&      ([F:LSM]MVTDAT=WLASINVDAT & [F:LSM]VCRNUM<WLASINVNUM)
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif numéro dernière facture
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(512,197,1)
        WMSG-=[F:LSM]VCRNUM-"-->"-WLASINVNUM
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]VCRNUM=WLASINVNUM : UPDFLG2=1 : LASFLG=1
    Endif
    If LASFLG=1 & [F:LSM]AMT<>WLASINVAMT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif montant dernière facture
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(513,197,1)
        WMSG-=num$([F:LSM]AMT)-"-->"-num$(WLASINVAMT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]AMT=WLASINVAMT : UPDFLG2=1
    Endif
  When 7 : #----- Traitement des avoirs -----#
    Raz LASFLG
    If [F:LSM]MVTDAT<WLASCNODAT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif Date dernière facture
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(663,197,1)
        WMSG-=format$("DD2",[F:LSM]MVTDAT)-"-->"-format$("DD2",WLASCNODAT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]MVTDAT=WLASCNODAT : UPDFLG2=1 : LASFLG=1
    Endif
    If (LASFLG=1 & [F:LSM]VCRNUM<>WLASCNONUM) |
&      ([F:LSM]MVTDAT=WLASCNODAT & [F:LSM]VCRNUM<WLASCNONUM)
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif numéro dernière facture
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(664,197,1)
        WMSG-=[F:LSM]VCRNUM-"-->"-WLASCNONUM
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]VCRNUM=WLASCNONUM : UPDFLG2=1 : LASFLG=1
    Endif
    If LASFLG=1 & [F:LSM]AMT<>WLASCNOAMT
      If L_TRACE=2
        WMSG=WBPSNUM
        WMSG+=space$(GLONBPS+1-len(WMSG))+WBPSRSK
        WMSG+=space$(GLONBPS+GLONBPS+2-len(WMSG))+WCPY
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+3-len(WMSG))+WCUR
        #----- Rectif montant dernière facture
        WMSG+=space$(GLONBPS+GLONBPS+GLONCPY+GLONCUR+4-len(WMSG))+mess(665,197,1)
        WMSG-=num$([F:LSM]AMT)-"-->"-num$(WLASCNOAMT)
        # Issue 85354 - 2012-11-06 by SR
        Call ECR_TRACE(WMSG,-1) From GESECRAN
      Endif
      [F:LSM]AMT=WLASCNOAMT : UPDFLG2=1
    Endif
Endcase
#-----
If UPDFLG2=1
  [F:LSM]CUR      =WCUR
  [F:LSM]IFFFCY   =WIFFFCY
  If dim([F:LSM]UPDDAT)>0 [F:LSM]UPDDAT=date$ : Endif
  If dim([F:LSM]UPDUSR)>0 [F:LSM]UPDUSR=GUSER : Endif
Endif
WMSG=mess(13,100,1)-"LASTSUPMVT"-WBPSNUM-num$(WIFFTYP)-WCPY
If CREFLG2=0
  Rewrite [LSM]
Else 
  Write [LSM]
Endif 
If fstat  GOK=0 : Call FSTA("LSM") From GLOCK : Return : Endif
Return


#------------------------#
# Ouverture des fichiers #
#------------------------#
$OUVRE_FIC
#----- Ouverture des fichiers -----#
If !clalev([F:CPY])  Local File COMPANY    [CPY]  : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY]  : Endif
If !clalev([F:TCU])  Local File TABCUR     [TCU]  : Endif
If !clalev([F:ITM])  Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:MVS])  Local File BPSUPPMVT  [MVS]  : Endif
If !clalev([F:LSM])  Local File LASTSUPMVT [LSM]  : Endif
If !clalev([F:POH])  Local File PORDER     [POH]  : Endif
If !clalev([F:POQ])  Local File PORDERQ    [POQ]  : Endif
If !clalev([F:PTH])  Local File PRECEIPT   [PTH]  : Endif
If !clalev([F:PTD])  Local File PRECEIPTD  [PTD]  : Endif
If !clalev([F:PIH])  Local File PINVOICE   [PIH]  : Endif
If !clalev([F:BPR])  Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS]  : Endif
Return


################################################################################
#             Actions sur champ pour gestion de l'écran BPSMVT                 #
################################################################################

Subprog AV_XCPYFLG(VALEUR)
#--------------------------------------#
# Avant saisie du flag toutes sociétés #
# ------------------------------------ #
# Complément de l'initialisation des   #
# champs faite dans INIT_DIA et        #
# grisage des champs                   #
#--------------------------------------#
Variable Integer VALEUR
If varinit([M]XCPYFLG) End : Endif : # Pour n'exécuter qu'une seule fois
#----- Traitement des champs société -----#
[M]XCPYFLG=2 : VALEUR=2
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  VALEUR=1 : [M]XCPYFLG=2 : Grizo XCPYFLG
  Call INICPY([M]CPY) From CPTSUB : Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
Else
  Diszo CPY
Endif
#----- traitement du champ fournisseur -----#
If [M]XBPSFLG=2 : Diszo BPSNUM : Endif
End


Subprog AM_XCPYFLG(VALEUR)
#-------------------------------------#
# Après modif du flag toutes sociétés #
#-------------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo CPY
  Call INICPY([M]CPY) From CPTSUB : Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
  If GNBAUZ=1 Diszo CPY : Endif
Else
  Effzo CPY : If dim([M]ZCPY)>0  Effzo ZCPY : Endif
  Diszo CPY
Endif
End


Subprog C_CPY(VALEUR)
#------------------------------------------------------------------#
# Contrôle société : Obligatoire si flag toutes sociétés non coché #
#------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XCPYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_CPY(VALEUR)
#----------------------------------#
# Après modification de la société #
#----------------------------------#
Variable Char    VALEUR()
End


Subprog AM_XBPSFLG(VALEUR)
#---------------------------------------#
# Après modif du flag tous fournisseurs #
#---------------------------------------#
Variable Integer VALEUR
If VALEUR=2
  Effzo BPSNUM : If dim([M]ZBPSNUM)>0  Effzo ZBPSNUM : Endif
  Diszo BPSNUM
Else
  Actzo BPSNUM
Endif
End


Subprog C_BPSNUM(VALEUR)
#------------------------------------------------------------------------#
# Contrôle fournisseur : Obligatoire si flag tous fournisseurs non coché #
#------------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XBPSFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


###################
# Erreur en Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
