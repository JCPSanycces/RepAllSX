#<AdxTL>@(#)12.0.0.0 $Revision$
# Action de visualisation nomenclatures et gammes
# VISUGHOST  : Visualisation fantôme(s) et leurs composants
# VISUBOM    : Visualisation nomenclature premier ou multiniveaux
# VISUBOD    : Visualisation lien
#
# VISUOPE    : Visualisation opération
# VISUMWS    : Visualisation poste de charge
# VISUSCD    : Visualisation jalonnement
############################################################
$ACTION
Case ACTION
  When "OUVRE"      :
    Case GACTION
      When "VISUOPE"     : Gosub OUVRE_OPE
      When "VISUMWS"     : Gosub OUVRE_MWS
      When "VISUBOM"     : Gosub OUVRE_BOM
      When "VISUBOD"     : Gosub OUVRE_BOD
      When "VISUSCD"     : Gosub OUVRE_SCD
      When "VISUGHOST"   : Gosub OUVRE_GHOST            # llc 02.03 (R)
    Endcase
  When "FIN"         :
    Case GACTION
      When "VISUOPE"     : Gosub FIN_OPE
      When "VISUMWS"     : Gosub FIN_MWS
      When "VISUBOM"     : Gosub FIN_BOM
      When "VISUBOD"     : Gosub FIN_BOD
      When "VISUSCD"     : Gosub FIN_SCD
      When "VISUGHOST"   : Gosub FIN_GHOST              # llc 02.03 (R)
    Endcase
  When "SETBOUT"    :
    Case GACTION
      When "VISUOPE"     : Gosub SETBOUT_OPE
      When "VISUMWS"     : Gosub SETBOUT_MWS
      When "VISUBOM"     : Gosub SETBOUT_BOM
      When "VISUBOD"     : Gosub SETBOUT_BOD
      When "VISUSCD"     : Gosub SETBOUT_SCD
      When "VISUGHOST"   : Gosub SETBOUT_GHOST          # llc 02.03 (R)
    Endcase
  When "DEBUT"      :
    Case GACTION
      When "VISUOPE"     : Gosub DEBUT_OPE
      When "VISUMWS"     : Gosub DEBUT_MWS
      When "VISUBOM"     : Gosub DEBUT_BOM
      When "VISUBOD"     : Gosub DEBUT_BOD
      When "VISUSCD"     : Gosub DEBUT_SCD
      When "VISUGHOST"   : Gosub DEBUT_GHOST            # llc 02.03 (R)
    Endcase
  When "BOUTON"     :
    Case GACTION
      When "VISUOPE"     : Gosub BOUTON_OPE
      When "VISUMWS"     : Gosub BOUTON_MWS
      When "VISUBOM"     : Gosub BOUTON_BOM
      When "VISUBOD"     : Gosub BOUTON_BOD
      When "VISUSCD"     : Gosub BOUTON_SCD
      When "VISUGHOST"   : Gosub BOUTON_GHOST           # llc 02.03 (R)
    Endcase
  When "APRES_MODIF" :
    Case GACTION
      When "VISUBOM" : Gosub APRES_MODIF_BOM
    Endcase
Endcase
Return
############################################################
# Visualisation opération
############################################################
$OUVRE_OPE
Local Integer IROH, IROO, IMWS, IQLC, IITM
If clalev([F:ROH1])= 0 : Local File ROUTING    [ROH1]  : IROH = 1 : Endif
If clalev([F:ROO1])= 0 : Local File ROUOPE     [ROO1]  : IROO = 1 : Endif
If clalev([F:MWS1])= 0 : Local File WORKSTATIO [MWS1]  : IMWS = 1 : Endif
If clalev([F:QLC1])= 0 : Local File QLYCRD     [QLC1]  : IQLC = 1 : Endif
If clalev([F:ITM1])= 0 : Local File ITMMASTER  [ITM1]  : IITM = 1 : Endif
Return
############################################################
$FIN_OPE
If IROH = 1
  IROH = 0
  Close Local File [ROH1]
Endif
If IROO = 1
  IROO = 0
  Close Local File [ROO1]
Endif
If IMWS = 1
  IMWS = 0
  Close Local File [MWS1]
Endif
If IQLC = 1
  IQLC = 0
  Close Local File [QLC1]
Endif
If IITM = 1
  IITM = 0
  Close Local File [ITM1]
Endif
Call IMPSCR From ATRTX3
Return
############################################################
$SETBOUT_OPE
If [M:VOP1]WST = ""
  ETABOU(GSPE1) = 0
Else
  ETABOU(GSPE1) = 1
Endif
If [M:VOP1]LABWST = ""
  ETABOU(GSPE2) = 0
Else
  ETABOU(GSPE2) = 1
Endif
If [M:VOP2]SCOWST = ""
  ETABOU(GSPE3) = 0
Else
  ETABOU(GSPE3) = 1
Endif
Return
############################################################
$DEBUT_OPE
Raz [M:VOP0]
Raz [M:VOP1]
Raz [M:VOP2]
# FQ 74811 GA 08/2011 index ROH1=FCY+ITMREF+ROUALT
#Read [ROH1]ROH1=PARAM(3);PARAM(1);val(PARAM(2))
Read [ROH1]ROH1=PARAM(5);PARAM(1);val(PARAM(2))
If fstat
  FIN = 1
Else
  [M:VOP0]FCY = PARAM(5)
  # FQ 74811 GA 08/2011 index ROO0=FCY+ITMREF+ROUALT+OPENUM+RPLIND
  #Read [ROO1]ROO0=PARAM(1);val(PARAM(2));val(PARAM(3));val(PARAM(4))
  Read [ROO1]ROO0=PARAM(5);PARAM(1);val(PARAM(2));val(PARAM(3));val(PARAM(4))
  If fstat = 0
    [M:VOP0] = [F:ROO1]
    [M:VOP1] = [F:ROO1]
    [M:VOP2] = [F:ROO1]
    Case [F:ROH1]TIMUOMCOD
      When 1 :
        [M:VOP1]TIMUOM1 = mess(30,197,1)
        [M:VOP1]TIMUOM2 = mess(30,197,1)
        [M:VOP1]TIMUOM3 = mess(30,197,1)
        [M:VOP1]TIMUOM4 = mess(30,197,1)
        [M:VOP1]TIMUOM5 = mess(30,197,1)
        [M:VOP1]TIMUOM6 = mess(30,197,1)
      When 2 :
        [M:VOP1]TIMUOM1 = mess(32,197,1)
        [M:VOP1]TIMUOM2 = mess(32,197,1)
        [M:VOP1]TIMUOM3 = mess(32,197,1)
        [M:VOP1]TIMUOM4 = mess(32,197,1)
        [M:VOP1]TIMUOM5 = mess(32,197,1)
        [M:VOP1]TIMUOM6 = mess(32,197,1)
    Endcase
    If [M:VOP1]CAD <> 0
      [M:VOP1]X = "/"
    Else
      [M:VOP1]TIMUOM3 = ""
    Endif
    Read [MWS1]WST0=[M:VOP1]WST;PARAM(5)
    If fstat = 0
      [M:VOP1]WSTWCR    = [F:MWS1]WCR
#      [M:VOP1]WSTDES    = [F:MWS1]WSTDES
      [M:VOP1]WSTTXT    = mess([F:MWS1]WSTTYP,313,1)
    Endif
    If [M:VOP1]LABWST <> ""
      Read [MWS1]WST0=[M:VOP1]LABWST;PARAM(5)
      If fstat = 0
        [M:VOP1]LABWSTWCR    = [F:MWS1]WCR
#        [M:VOP1]LABWSTDES    = [F:MWS1]WSTDES
        #LECTURE du libellé traduisible
        Call LECTEXTRA([M:VOP1]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
       [M:VOP1]LABWSTTXT    = mess([F:MWS1]WSTTYP,313,1)
      Endif
    Endif
    If [M:VOP2]SCOWST <> ""
      Read [MWS1]WST0=[M:VOP2]SCOWST;PARAM(5)
      If fstat = 0
        [M:VOP2]SCOWCR       = [F:MWS1]WCR
#        [M:VOP2]SCOWSTDES    = [F:MWS1]WSTDES
        #LECTURE du libellé traduisible
        Call LECTEXTRA([M:VOP2]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
        [M:VOP2]SCOWSTTXT    = mess([F:MWS1]WSTTYP,313,1)
      Endif
    Endif
    If [M:VOP2]TECCRD <> ""
      Read [QLC1]QLC0=[M:VOP2]TECCRD
      If fstat = 0
        # FGR 24/09/2009 : X3SUIVI58062
        #[M:VOP2]TECCRDDES = [F:QLC1]QLYCRDDES
        Call LECTEXTRA([M:VOP2]TECCRDDES,"QLYCRD","QLYDESAXX",[F:QLC1]QLYCRD,"") From ATEXTRA
      Endif
    Endif
    If [M:VOP2]SCOITMREF <> ""
      Read [ITM1]ITM0= [M:VOP2]SCOITMREF
      If fstat = 0
#        [M:VOP2]SCOITMREFT = [F:ITM1]ITMDES1
        #LECTURE du libellé traduisible
        #Call LECTEXTRA([M:VOP2]SCOITMREFT,"ITMMASTER","DES1AXX",[F:ITM1]ITMREF,"") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VOP2]SCOITMREFT, "[F:ITM1]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      Endif
    Endif
    If [M:VOP2]EQUNUM <> ""
      Read [ITM1]ITM0= [M:VOP2]EQUNUM
      If fstat = 0
#        [M:VOP2]EQUNUMDES = [F:ITM1]ITMDES1
        #LECTURE du libellé traduisible
        #Call LECTEXTRA([M:VOP2]EQUNUMDES,"ITMMASTER","DES1AXX",[F:ITM1]ITMREF,"") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VOP2]EQUNUMDES, "[F:ITM1]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      Endif
    Endif
    Affzo [M:VOP0]
    Affzo [M:VOP1]
    Affzo [M:VOP2]
  Else
    FIN = 1
  Endif
Endif
Return
############################################################
$BOUTON_OPE
Case BOUT
  When "d"  :
    Local Char WMSK(10)(03)
    Local Char WABR(06)(03)
    WMSK(0) = "VISUOPE0"
    WMSK(1) = "VISUOPE1"
    WMSK(2) = "VISUOPE2"
    WABR(0) = "VOP0"
    WABR(1) = "VOP1"
    WABR(2) = "VOP2"
    Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
Endcase
Return
############################################################
# Visualisation poste de charge
############################################################
$OUVRE_MWS
Local Integer IMWS, IMWC, ITWC, IFCY
If clalev([F:MWS1]) = 0 : Local File WORKSTATIO     [MWS1]  : IMWS = 1 : Endif
If clalev([F:MWC1]) = 0 : Local File WORKCOST       [MWC1]  : IMWC = 1 : Endif
If clalev([F:TWC1]) = 0 : Local File TABWRKCTR      [TWC1]  : ITWC = 1 : Endif
If clalev([F:FCY1]) = 0 : Local File FACILITY       [FCY1]  : IFCY = 1 : Endif
Return
############################################################
$FIN_MWS
If IMWS = 1
  IMWS = 0
  Close Local File [MWS1]
Endif
If IMWC = 1
  IMWC = 0
  Close Local File [MWC1]
Endif
If ITWC = 1
  ITWC = 0
  Close Local File [TWC1]
Endif
If IFCY = 1
  IFCY = 0
  Close Local File [FCY1]
Endif
Call IMPSCR From ATRTX3
Return
############################################################
$SETBOUT_MWS
Return
############################################################
$DEBUT_MWS
Raz [M:VMWS]
Read [MWS1]WST0=PARAM(1);PARAM(2)
If fstat = 0
  [M:VMWS] =  [F:MWS1]
  Read [MWC1]WCT0=[F:MWS1]VLTCCE;[F:MWS1]WCRFCY
  If fstat = 0
#    [M:VMWS]VLTCCEDES = [F:MWC1]WCTDES
     #LECTURE du libellé traduisible
     Call LECTEXTRA([M:VMWS]VLTCCEDES,"WORKCOST","WCTDESAXX",[F:MWS1]VLTCCE,[F:MWS1]WCRFCY) From ATEXTRA
  Endif
  Read [TWC1]TWC0=[M:VMWS]WCR
  If fstat = 0
#    [M:VMWS]WCRDES = [F:TWC1]WCRDES
    #LECTURE du libellé traduisible
    Call LECTEXTRA([M:VMWS]WCRDES,"TABWRKCTR","WCRDESAXX",[F:TWC1]WCR,"") From ATEXTRA
  Endif
  Read [FCY1]FCY0=[M:VMWS]WCRFCY
  If fstat = 0
    [M:VMWS]WCRFCYNAM = [F:FCY1]FCYNAM
  Endif
  [M:VMWS]RPLWSTDES = ""
  [M:VMWS]RPLWSTTYP = 0
  [M:VMWS]RPLWCR    = ""
  [M:VMWS]RPLWCRDES = ""
  If [M:VMWS]RPLWST <> ""
    Read [MWS1]WST0=[M:VMWS]RPLWST;PARAM(2)
    If fstat = 0
#      [M:VMWS]RPLWSTDES = [F:MWS1]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:VMWS]RPLWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
      [M:VMWS]RPLWSTTYP = [F:MWS1]WSTTYP
      [M:VMWS]RPLWCR    = [F:MWS1]WCR
      Read [TWC1]TWC0=[F:MWS1]WCR
      If fstat = 0
#        [M:VMWS]RPLWCRDES = [F:TWC1]WCRDES
        #LECTURE du libellé traduisible
        Call LECTEXTRA([M:VMWS]RPLWCRDES ,"TABWRKCTR","WCRDESAXX",[F:TWC1]WCR,"") From ATEXTRA
      Endif
     Endif
  Endif
Else
  FIN = 1
Endif
Return
############################################################
$BOUTON_MWS
Case BOUT
  When "a"
    Call PRTSCR("VISUMWS","VMWS","",0,0) From ATRTX3
Endcase
Return
############################################################
# Visualisation nomenclatures
############################################################
$OUVRE_BOM
Local Integer IITM, IITF, IBOH, IBOD, ITBO
If clalev([F:ITM1]) = 0 : Local File ITMMASTER     [ITM1]  : IITM = 1 : Endif
If clalev([F:ITF1]) = 0 : Local File ITMFACILIT    [ITF1]  : IITF = 1 : Endif
If clalev([F:BOH1]) = 0 : Local File BOM           [BOH1]  : IBOH = 1 : Endif
If clalev([F:BOD1]) = 0 : Local File BOMD          [BOD1]  : IBOD = 1 : Endif
If clalev([F:TBO1]) = 0 : Local File TABBOMALT     [TBO1]  : ITBO = 1 : Endif
Return
############################################################
$FIN_BOM
If IITM = 1
  IITM = 0
  Close Local File [ITM1]
Endif
If IITF = 1
  IITF = 0
  Close Local File [ITF1]
Endif
If IBOH = 1
  IBOH = 0
  Close Local File [BOH1]
Endif
If IBOD = 1
  IBOD = 0
  Close Local File [BOD1]
Endif
If ITBO = 1
  ITBO = 0
  Close Local File [TBO1]
Endif
Call IMPSCR From ATRTX3
Return
############################################################
$SETBOUT_BOM
If [M:VBOM]BOMFLG = 0
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 1
Else
  ETABOU(GSPE1) = 1
  ETABOU(GSPE2) = 0
Endif
Return
############################################################
$DEBUT_BOM
Raz [M:VBOM]

# rajout TB pour 10716 (04/10/01)
If clalev([M:BOH0])
  [M:VBOM]BOMFLG = 1
Endif
[M:VBOM]PARITMREF = PARAM(1)
[M:VBOM]BOMALT    = val(PARAM(2))
[M:VBOM]DATREF    = PARAM(3)    # !!! peut être 0/0/0 !!!
[M:VBOM]STOFCY    = PARAM(4)
[M:VBOM]BOMALTTYP = val(PARAM(5)) : # GA 08/2007 ajout V6
# Lecture composé
Read [ITM1]ITM0=PARAM(1)
If fstat
  FIN = 1
  Return
Endif
#[M:VBOM]ITMDES1 = [F:ITM1]ITMDES1
[M:VBOM]BOMSTU  = [F:ITM1]STU
If [M:VBOM]BOMALT <> 0
  Grizo [M:VBOM]BOMALT
  Gosub TRT_AFFBOM
Endif
Return
############################################################
$APRES_MODIF_BOM
Case COUZON
  When "DATREF" : [M:VBOM]DATREF = CZ
  When "BOMALT" : [M:VBOM]BOMALT = val(CZ)
Endcase
If [M:VBOM]BOMALT <> 0
  Gosub TRT_AFFBOM
Endif
Return
############################################################
$TRT_AFFBOM
# Lecture alternative
If [M:VBOM]BOMALTTYP=0 : [M:VBOM]BOMALTTYP=2 : Endif
Read [TBO1]TBO0=[M:VBOM]BOMALTTYP;[M:VBOM]BOMALT
If fstat
  FIN = 1
  Return
Endif
#
Read [BOH1]BOH0=[M:VBOM]PARITMREF;[M:VBOM]BOMALT;[M:VBOM]BOMALTTYP
If fstat
  GMESSAGE = mess(95,193,1)
  GERR     = 1
  FIN      = 1
  Return
Endif
[M:VBOM] = [F:BOH1]
Affzo [M:VBOM]5-20
# Contrôle validité entête
If [F:BOH1]BOHENDDAT = [0/0/0]
  [F:BOH1]BOHENDDAT = [31/12/2999]
Endif
If ([M:VBOM]DATREF >= [F:BOH1]BOHSTRDAT | [M:VBOM]DATREF=[0/0/0]) & [M:VBOM]DATREF <= [F:BOH1]BOHENDDAT
  Gosub DIS_BOM
Else
  GMESSAGE = mess(54,199,1)
  GERR     = 2
Endif
Return
############################################################
$DIS_BOM
Effzo [M:VBOM]25
If [M:VBOM]BOMFLG = 0
  [M:VBOM]BOMLEV = mess(1,256,1)
Else
  [M:VBOM]BOMLEV = mess(3,256,1)
Endif
#
Local Date    WDAT     : WDAT = [M:VBOM]DATREF
Local Char    WUND(20) : WUND = "____________________"
Local Char    WPAR(30)(dim([M:VBOM]BOMSEQ))
Local Char    WCPN(30)(dim([M:VBOM]BOMSEQ))
Local Integer WTYP    (dim([M:VBOM]BOMSEQ))

Local Integer WSEQ    (dim([M:VBOM]BOMSEQ))
Local Integer WLEV    (dim([M:VBOM]BOMSEQ))
Local Integer I, J, K, L
# sr 10.02 demande 15297
Local Decimal WQTY,WWQTY,WDIS,WQTYN,WQTYNA,WQTYB,WQTYBA,WLIEN
Local Decimal WBASQTY
Local Integer WLIKQTYCOD
Local Decimal WLIKQTY
Local Integer WQTYRND,WRET
Local Decimal WLSCA
Local Char    WSTU(GLONUOM)
#
Filter [BOD1] Where ITMREF    = [M:VBOM]PARITMREF &
&                   BOMALT    = [M:VBOM]BOMALT    &
&                   BOMALTTYP = [M:VBOM]BOMALTTYP &
&                  (WDAT = [0/0/0] | (BOMSTRDAT <= WDAT  &
&                  (BOMENDDAT = [0/0/0] | BOMENDDAT >= WDAT)))
&             Order By Key BOD0

# au lieu de l'expression  (TB 29/11/01)
##&                  (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDAT))  &
##&                  (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDAT))
I = 0
For [BOD1]
  If I < dim(WPAR)-1
     WPAR(I) = [F:BOD1]ITMREF
     WCPN(I) = [F:BOD1]CPNITMREF
     WSEQ(I) = [F:BOD1]BOMSEQ
     WTYP(I) = [F:BOD1]CPNTYP
     If [M:VBOM]BOMFLG = 0
       WLEV(I) = 1
     Else
       WLEV(I) = -1
     Endif
     I += 1
  Endif
Next
Filter [BOD1]
#
J = -1
$DIS_BOM1
While find(J,WLEV)
  K = find(J,WLEV)
  L = 0
  WLEV(K-1) *= -1
  If WTYP(K-1) <> 4
      Filter [BOD1] Where ITMREF    = WCPN(K-1)            &
&                         BOMALT    = [M:VBOM]BOMALT       &
&                         BOMALTTYP = [M:VBOM]BOMALTTYP    &
&                    (WDAT = [0/0/0] | (BOMSTRDAT <= WDAT  &
&                    (BOMENDDAT = [0/0/0] | BOMENDDAT >= WDAT)))
&               Order By Key BOD0
      For [BOD1]
        If WPAR(dim([M:VBOM]BOMSEQ)-1) = ""
          Insa K,1 WPAR,WCPN,WTYP,WSEQ,WLEV
          WPAR(K) = [F:BOD1]ITMREF
          WCPN(K) = [F:BOD1]CPNITMREF
          WTYP(K) = [F:BOD1]CPNTYP
          WSEQ(K) = [F:BOD1]BOMSEQ
          WLEV(K) = J-1
          K += 1
        Else
          L = 1  # c'est que le tableau est plein !
          Break
        Endif
      Next
      Filter [BOD1]
  Endif
  If L = 1
    # correction bug 17927 (TB)  14/05/03
    GERR = 2
    GMESSAGE = mess(26,100,1) # "Tableau plein"
    Break
  Endif
Wend
# tester qu'on n'a pas dépassé la taille du tableau (bug 17927)
If L=0
  J -= 1
  If find(J,WLEV)
    Goto DIS_BOM1
  Endif
Endif
#
# Affichage
#
I = 0   # + test de la dimension max (TB) 14/05/03 :
While I < dim(WPAR) & WPAR(I) <> ""
  Read [BOD1]BOD0=WPAR(I);[M:VBOM]BOMALT;WSEQ(I);WCPN(I);[M:VBOM]BOMALTTYP
  If fstat = 0
      If [F:BOD1]CPNTYP <> 5
         Read [ITM1]ITM0=WCPN(I)
         If fstat : Raz [F:ITM1] : Endif
      Endif
      If [F:BOD1]CPNTYP = 5 | [F:ITM1]ITMREF <> ""
          [M:VBOM]NBLIG += 1
          nolign = [M:VBOM]NBLIG
          [M:VBOM] = [F:BOD1]
          If WLEV(I) < 19
            [M:VBOM]LEV(nolign-1) = left$(WUND,WLEV(I)-1)+num$(WLEV(I))
          Else
            [M:VBOM]LEV(nolign-1) = left$(WUND,18)+num$(WLEV(I))
          Endif
          If [F:BOD1]CPNTYP <> 5
#              [M:VBOM]CPNITMDES1(nolign-1) = [F:ITM1]ITMDES1
              #LECTURE du libellé traduisible
              #Call LECTEXTRA([M:VBOM]CPNITMDES1(nolign-1),"ITMMASTER","DES1AXX",[F:ITM1]ITMREF,"") From ATEXTRA
              Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VBOM]CPNITMDES1(nolign-1), "[F:ITM1]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
              [M:VBOM]CPNSTU    (nolign-1) = [F:ITM1]STU
              [M:VBOM]PARITM    (nolign-1) = [F:BOD1]ITMREF

              # calcul de la qté en dépliage de nomenclature (bug 15297) TB 12/08/02
              # lire l'entête et appeler le sous-pro >> LIKQTY
              # sr 10.02 demande 15297 suite
              Read [F:BOH1]BOH0 = WPAR(I);[M:VBOM]BOMALT;[M:VBOM]BOMALTTYP
              If fstat : Raz [F:BOH1] : Endif
              # il faut retrouver dans le tableau la ligne correspondant au composé (pour la quantité)
              Gosub REC_QUANTITE
              WQTY         = WWQTY
              WSTU         = [F:ITM1]STU
              WBASQTY      = [F:BOH1]BASQTY
              WLIKQTYCOD   = [F:BOD1]LIKQTYCOD
              WLIKQTY      = [F:BOD1]LIKQTY
              WQTYRND      = [F:BOD1]QTYRND
              WSCA         = [F:BOD1]SCA
              If  WQTY  = 0  | [F:BOD1]LIKQTY = 0
                  WLIEN = 0
              Else
                   Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,WQTYRND,
&                      WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
                   WLIEN = WQTYBA
              Endif
              Call QTEARR(WLIEN, [F:ITM1]STU) From TRTDIV
        # sr 06.04 demande 23094 récupérer systématiquement la quantité issue du calcul même si c'est 0
        #      If WLIEN <> 0
                 [M:VBOM]LIKQTY(nolign-1) = WLIEN
        #      Endif
              #--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
              #Call STODISALL([M:VBOM]STOFCY,[F:BOD1]CPNITMREF,10,1,2,1,2,"","",WDIS,WRET) From STKALL
              Call STODISALL([M:VBOM]STOFCY,[F:BOD1]CPNITMREF,[F:BOD1]ECCVALMAJ,WDIS) From MFGLIBM

              [M:VBOM]AVAQTY(nolign-1) = WDIS

              # process 03.03 MM
              If dim([M:VBOM]BOMUOM(nolign-1))>0
                  If [M:VBOM]BOMUOM(nolign-1)="" : [M:VBOM]BOMUOM(nolign-1)=[F:ITM1]STU: Endif
                  If [M:VBOM]BOMSTUCOE(nolign-1)=0 :  [M:VBOM]BOMSTUCOE(nolign-1)=1 : Endif
                  If [M:VBOM]BOMQTY(nolign-1)=0  : [M:VBOM]BOMQTY(nolign-1)=[M:VBOM]LIKQTY(nolign-1)
                  Else : [M:VBOM]BOMQTY(nolign-1)=[M:VBOM]LIKQTY(nolign-1)/[M:VBOM]BOMSTUCOE(nolign-1) : Endif
              Endif
              # Fin process 03.03 MM
          Else
             [M:VBOM]PARITM    (nolign-1) = [F:BOD1]ITMREF
          Endif
      Endif
  Endif
  I += 1
Wend
Affzo [M:VBOM]BOMLEV
Affzo [M:VBOM]25
Return
############################################################
# sr 10.02 demande 15297
$REC_QUANTITE
Local Integer II
Raz WWQTY
# sr 06.04 demande 23094
If WLEV(I) = 1 : WWQTY = [F:BOH1]BASQTY : Return : Endif
For II = nolign-2 To 0 Step -1
    If [M:VBOM]CPNITMREF(II) = [F:BOH1]ITMREF & [M:VBOM]LEV(II) <> [M:VBOM]LEV(nolign-1)
       WWQTY = [M:VBOM]LIKQTY(II)
       Break
    Endif
Next
# sr 06.04 garder 0 demande 23094
#If WWQTY = 0 : WWQTY = [F:BOH1]BASQTY : Endif
Return

############################################################
$BOUTON_BOM
Case BOUT
  When "a" :
    [M:VBOM]BOMFLG = 0
    Gosub DIS_BOM
  When "b" :
    [M:VBOM]BOMFLG = 1
    Gosub DIS_BOM
  When "c" :
    Call PRTSCR("VISUBOM","VBOM","",0,0) From ATRTX3
Endcase
Return
############################################################
# Visualisation lien nomenclatures
############################################################
$OUVRE_BOD
Local Integer IITM1, IBOD, IBOD1, ITBO
If clalev([F:ITM1]) = 0 : Local File ITMMASTER     [ITM1]  : IITM1 = 1 : Endif
If clalev([F:BOD])  = 0 : Local File BOMD          [BOD]   : IBOD  = 1 : Endif
If clalev([F:BOD1]) = 0 : Local File BOMD          [BOD1]  : IBOD1 = 1 : Endif
If clalev([F:TBO1]) = 0 : Local File TABBOMALT     [TBO1]  : ITBO  = 1 : Endif
Return
############################################################
$FIN_BOD
If IITM1 = 1
  IITM1 = 0
  Close Local File [ITM1]
Endif
If IBOD = 1
  IBOD = 0
  Close Local File [BOD]
Endif
If IBOD1 = 1
  IBOD1 = 0
  Close Local File [BOD1]
Endif
If ITBO = 1
  ITBO = 0
  Close Local File [TBO1]
Endif
Call IMPSCR From ATRTX3
Return
############################################################
$SETBOUT_BOD
Return
############################################################
$DEBUT_BOD
Raz [M:VBOD]
# GA 08/2007 idem VISUBOM
[M:VBOD]ITMREF    = PARAM(1)
[M:VBOD]BOMALT    = val(PARAM(2))
[M:VBOD]BOMSEQ    = val(PARAM(3))
[M:VBOD]CPNITMREF = PARAM(4)
[M:VBOD]BOMALTTYP = val(PARAM(5)) : # GA 08/2007 ajout V6

# Lecture composé
Read [ITM1]ITM0=[M:VBOD]ITMREF
If fstat
  FIN = 1
  Return
Endif
#[M:VBOD]ITMDES1 = [F:ITM1]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VBOD]ITMDES1, "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:VBOD]STU     = [F:ITM1]STU
#Lecture du lien de nomenclature
#Read [BOD]BOD0=PARAM(1);val(PARAM(2));val(PARAM(3));PARAM(4);2
Read [BOD]BOD0=[M:VBOD]ITMREF;[M:VBOD]BOMALT;[M:VBOD]BOMSEQ;[M:VBOD]CPNITMREF;[M:VBOD]BOMALTTYP
If fstat
  FIN = 1
  Return
Endif
# Lecture composant si composé de type autre que texte
If [F:BOD]CPNTYP <> 5
    Read [ITM1]ITM0=[M:VBOD]CPNITMREF
    If fstat
      FIN = 1
      Return
    Endif
    #[M:VBOD]CPNITMREF  = [F:ITM1]ITMREF
#    [M:VBOD]CPNITMDES1 = [F:ITM1]ITMDES1
    #LECTURE du libellé traduisible
    #Call LECTEXTRA([M:VBOD]CPNITMDES1,"ITMMASTER","DES1AXX",[F:ITM1]ITMREF,"") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VBOD]CPNITMDES1, "[F:ITM1]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    [M:VBOD]CPNSTU     = [F:ITM1]STU
    [M:VBOD]STU0       = [F:ITM1]STU
Endif
#
# Lecture alternative
#Read [TBO1]TBO0=2;val(PARAM(2))
Read [TBO1]TBO0=[M:VBOD]BOMALTTYP;[M:VBOD]BOMALT
If fstat
  FIN = 1
  Return
Endif
[M:VBOD]BOMALT    = [F:TBO1]BOMALT
# FGR 16/09/2009 : X3SUIVI57824
#If dim([M:VBOD]BOMALTDES)> 0 : [M:VBOD]BOMALTDES = [F:TBO1]TBODES    : Endif
If dim([M:VBOD]BOMALTDES)> 0 Then
  Call LECTEXTRA([M:VBOD]BOMALTDES,"TABBOMALT","TBODESAXX",num$([F:TBO1]BOMALTTYP),num$([F:TBO1]BOMALT)) From ATEXTRA
Endif
#
[M:VBOD] = [F:BOD]
Affzo [M:VBOD]
Return
############################################################
$BOUTON_BOD
Case BOUT
  When "a" :
    Call PRTSCR("VISUBOD","VBOD","",0,0) From ATRTX3
Endcase
Return
############################################################
############################################################
# Visualisation jalonnement
############################################################
$OUVRE_SCD
Local Integer IROH, IROO, IROS, IMWS, IITM
If clalev([F:ROH1])= 0 : Local File ROUTING    [ROH1]  : IROH = 1 : Endif
If clalev([F:ROO1])= 0 : Local File ROUOPE     [ROO1]  : IROO = 1 : Endif
If clalev([F:ROS1])= 0 : Local File ROUSCD     [ROS1]  : IROS = 1 : Endif
If clalev([F:MWS1])= 0 : Local File WORKSTATIO [MWS1]  : IMWS = 1 : Endif
If clalev([F:ITM1])= 0 : Local File ITMMASTER  [ITM1]  : IITM = 1 : Endif
Return
############################################################
$FIN_SCD
If IROH = 1
  IROH = 0
  Close Local File [ROH1]
Endif
If IROO = 1
  IROO = 0
  Close Local File [ROO1]
Endif
If IROS = 1
  IROS = 0
  Close Local File [ROS1]
Endif
If IMWS = 1
  IMWS = 0
  Close Local File [MWS1]
Endif
If IITM = 1
  IITM = 0
  Close Local File [ITM1]
Endif
Call IMPSCR From ATRTX3
Return
############################################################
$SETBOUT_SCD
Return
############################################################
$DEBUT_SCD
Raz [M:VSCD]
Read [ROH1]ROH1=PARAM(3);PARAM(1);val(PARAM(2))
If fstat
  FIN = 1
Else
  [M:VSCD]FCY    = [F:ROH1]FCY
  [M:VSCD]ROUALT = [F:ROH1]ROUALT
  # FGR 02/10/2009 : X3SUIVI58337
  #[M:VSCD]ROUDES = [F:ROH1]ROUDES
  Call LECTEXTRA([M:VSCD]ROUDES,"ROUTING", "ROUDESAXX", [F:ROH1]ITMREF+"~"+num$([F:ROH1]ROUALT),[F:ROH1]FCY) From ATEXTRA

  Read [ITM1]ITM0=[F:ROH1]ITMREF
  If fstat
    Raz [F:ITM1]
  Endif
  [M:VSCD]ITMREF  = [F:ROH1]ITMREF
#  [M:VSCD]ITMDES1 = [F:ITM1]ITMDES1
  #LECTURE du libellé traduisible
  #Call LECTEXTRA([M:VSCD]ITMDES1,"ITMMASTER","DES1AXX",[F:ITM1]ITMREF,"") From ATEXTRA
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VSCD]ITMDES1, "[F:ITM1]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
  Filter [ROS1] Where FCY    =  [F:ROH1]FCY   &
&                     ITMREF = [F:ROH1]ITMREF &
&                     ROUALT = [F:ROH1]ROUALT
&               Order By Key ROS0

  For [ROS1]
    Read [ROO1]ROO0=[F:ROH1]FCY;[F:ROH1]ITMREF;[F:ROH1]ROUALT;[F:ROS1]OPENUM
    If fstat
      Raz [F:ROO1]
    Endif
    Read [MWS1]WST0=[F:ROO1]WST;PARAM(3)
    If fstat
      Raz [F:MWS1]
    Endif
    If [M:VSCD]NBLIG < dim([M:VSCD]OPENUM)-1
      [M:VSCD]NBLIG += 1
      nolign = [M:VSCD]NBLIG
      [M:VSCD]OPENUM   (nolign-1) = [F:ROS1]OPENUM
      [M:VSCD]RPLIND   (nolign-1) = [F:ROO1]RPLIND
      [M:VSCD]WCR      (nolign-1) = [F:MWS1]WCR
      [M:VSCD]WSTTYP   (nolign-1) = [F:MWS1]WSTTYP
      [M:VSCD]WST      (nolign-1) = [F:ROO1]WST
#      [M:VSCD]WSTDES   (nolign-1) = [F:MWS1]WSTDES
      #LECTURE du libellé traduisible
      Call LECTEXTRA([M:VSCD]WSTDES(nolign-1),"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
      [M:VSCD]DACMST   (nolign-1) = [F:ROS1]DACMST
      [M:VSCD]MFGMST   (nolign-1) = [F:ROS1]MFGMST
      [M:VSCD]NEXOPENUM(nolign-1) = [F:ROS1]NEXOPENUM
      [M:VSCD]SCDCOD   (nolign-1) = [F:ROS1]SCDCOD
      [M:VSCD]SCDTIM   (nolign-1) = [F:ROS1]SCDTIM
      [M:VSCD]SCDQTY   (nolign-1) = [F:ROS1]SCDQTY
      [M:VSCD]SCDLOT   (nolign-1) = [F:ROS1]SCDLOT
      [M:VSCD]OPEUOM   (nolign-1) = [F:ROO1]OPEUOM
    Endif
  Next
  Filter [ROS1]
  Affzo [M:VSCD]
Endif
Return
############################################################
$BOUTON_SCD
Return

############################################################
# Visualisation fantômes
# llc 02.03 (R)
############################################################
$OUVRE_GHOST
Local Integer IITM, IITF, IBOH, IBOD, ITBO, IITV, IFCY

If clalev([F:FCY])  = 0 : Local File FACILITY      [FCY]   : IFCY = 1 : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER     [ITM1]  : IITM = 1 : Endif
If clalev([F:ITF1]) = 0 : Local File ITMFACILIT    [ITF1]  : IITF = 1 : Endif
If clalev([F:BOH1]) = 0 : Local File BOM           [BOH1]  : IBOH = 1 : Endif
If clalev([F:BOD1]) = 0 : Local File BOMD          [BOD1]  : IBOD = 1 : Endif
If clalev([F:TBO1]) = 0 : Local File TABBOMALT     [TBO1]  : ITBO = 1 : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT        [ITV]   : IITV = 1 : Endif
Return

############################################################
$FIN_GHOST
If IFCY = 1
  IFCY = 0
  Close Local File [FCY]
Endif
If IITM = 1
  IITM = 0
  Close Local File [ITM1]
Endif
If IITF = 1
  IITF = 0
  Close Local File [ITF1]
Endif
If IBOH = 1
  IBOH = 0
  Close Local File [BOH1]
Endif
If IBOD = 1
  IBOD = 0
  Close Local File [BOD1]
Endif
If ITBO = 1
  ITBO = 0
  Close Local File [TBO1]
Endif
If IITV = 1
  IITV = 0
  Close Local File [ITV]
Endif
Call IMPSCR From ATRTX3
Return

############################################################
$SETBOUT_GHOST
Return

############################################################
$DEBUT_GHOST
Raz [M:VGHT]

[M:VGHT]STOFCY    = PARAM(1)
[M:VGHT]PARITMREF = PARAM(2)
[M:VGHT]BOMALT    = val(PARAM(3))
[M:VGHT]BOMALTTYP = 2
If instr(1,PARAM(4),"/")
     [M:VGHT]DATREF = "["+PARAM(4)+"]"
Else
     [M:VGHT]DATREF = PARAM(4)
Endif
# lecture site
Call LECTURE("FCY", [M:VGHT]STOFCY, "") From CONTOBJ
[M:VGHT]FCYDES = [F:FCY]FCYNAM

# Lecture composé
Read [ITM1]ITM0=PARAM(2)
If fstat
  FIN = 1
  Return
Endif
#[M:VGHT]ITMDES1 = [F:ITM1]ITMDES1
#LECTURE du libellé traduisible
#Call LECTEXTRA([M:VGHT]ITMDES1,"ITMMASTER","DES1AXX",[F:ITM1]ITMREF,"") From ATEXTRA
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VGHT]ITMDES1, "[F:ITM1]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
[M:VGHT]BOMSTU  = [F:ITM1]STU
Gosub TRT_AFFGHOST
Return

############################################################
$TRT_AFFGHOST

# FQ 71053 GA 02/2011 selon MFGLIBM GENMAT
Local    Integer  WLEV           : WLEV = 1
Local    Integer  WLIG           : WLIG = 1
Local    Decimal  WQTY           : WQTY = 1
Local    Char     WLOT(GLONLOT)  : WLOT = ""
Local    Integer  WOPE           : WOPE = 0
Local    Integer  WOFS           : WOFS = 0
Local    Integer  WLIKQTYCOD     : WLIKQTYCOD = 1 # FQ 73109 GA 05/2011
Local    Decimal  WLIKQTY        : WLIKQTY = 1
Local    Decimal  WSCA           : WSCA = 1
Local    Decimal  WBAS           : WBAS = 1
Local    Integer  WVISUGHOST     : WVISUGHOST = 0
Local    Integer  WRET           : WRET = 0

# Lecture alternative
Read [TBO1]TBO0=[M:VGHT]BOMALTTYP;[M:VGHT]BOMALT
If fstat
  FIN = 1
  Return
Endif

Read [BOH1]BOH0=[M:VGHT]PARITMREF;[M:VGHT]BOMALT;[M:VGHT]BOMALTTYP
If fstat
  GMESSAGE = mess(95,193,1)
  GERR     = 1
  FIN      = 1
  Return
Endif

[M:VGHT] = [F:BOH1]
# FGR 16/09/2009 : X3SUIVI57824
#[M:VGHT]ALTDES = [F:TBO1]TBODES
Call LECTEXTRA([M:VGHT]ALTDES,"TABBOMALT","TBODESAXX",num$([F:TBO1]BOMALTTYP),num$([F:TBO1]BOMALT)) From ATEXTRA

Affzo [M:VGHT]5-20

# Contrôle validité entête
If [F:BOH1]BOHENDDAT = [0/0/0]
  [F:BOH1]BOHENDDAT = [31/12/2999]
Endif

If ([M:VGHT]DATREF >= [F:BOH1]BOHSTRDAT | [M:VGHT]DATREF=[0/0/0]) & [M:VGHT]DATREF <= [F:BOH1]BOHENDDAT
     # FQ 71053 GA 02/2011 algorithme revu selon MFGLIBM parcours de tous les niveaux
     # FQ 73109 GA 05/2011 tenir compte de WLIKQTYCOD si fantome avec qté forfaitaire
      Call CREMAT(WLEV,WLIG,[M:VGHT]STOFCY,[M:VGHT]PARITMREF,[M:VGHT]BOMALT,[M:VGHT]DATREF,
&                 WQTY,WLOT,WOPE,WOFS,WLIKQTYCOD,WLIKQTY,WSCA,WBAS,WVISUGHOST,WRET)
      Affzo [M:VGHT]BOMLEV
      Affzo [M:VGHT]25
      If WLIG<0 : # GH 02/12/2013 bug 94899
         GERR = 2
         GMESSAGE = mess(26,100,1) # Tableau plein
      Endif
Else
  GMESSAGE = mess(54,199,1) # Cette nomenclature n'est valide à la date indiquée
  GERR     = 2
Endif
Return

############################################################
$REC_QUANTITE_GHT
Local Integer II
Raz WWQTY
If nolign = 1 : WWQTY = [F:BOH1]BASQTY : Return : Endif
For II = nolign-2 To 0 Step -1
    If [M:VGHT]CPNITMREF(II) = [F:BOH1]ITMREF & [M:VGHT]LEV(II) <> [M:VGHT]LEV(nolign-1)
       WWQTY = [M:VGHT]LIKQTY(II)
       Break
    Endif
Next
If WWQTY = 0 : WWQTY = [F:BOH1]BASQTY : Endif
Return

############################################################
$BOUTON_GHOST
Case BOUT
  When "a" :
    Call PRTSCR("VISUGHOST","VGHT","",0,0) From ATRTX3
Endcase
Return

############################################################
# FQ 71053 GA 02/2011 algorithme idem MFGLIBM
############################################################
Subprog CREMAT(LLEV,LLIG,LFCY,LITM,LALT,LDAT,LQTY,LLOT,LOPE,LOFS,LLIKQTYCOD,LLIK,LSCA,LBAS,LGHOST,LRET)
Value    Integer  LLEV
Variable Integer  LLIG
Value    Char     LFCY
Value    Char     LITM
Value    Integer  LALT
Value    Date     LDAT
Value    Decimal  LQTY
Value    Char     LLOT
Value    Integer  LOPE                            # llc 12.01 11561 propagation en traversée fantôme
Value    Integer  LOFS                            # llc 12.01 11561 propagation en traversée fantôme
Value    Integer  LLIKQTYCOD                      # FQ 73109 GA 04/2011 fantome avec qté Forfaitaire
Value    Decimal  LLIK                            # llc 01.03 16961
Value    Decimal  LSCA                            # mm  11.06 38064
Value    Decimal  LBAS                            # mm  11.06 38064
Variable Integer  LGHOST                          # llc 03.03 (R) 17425
Variable Integer  LRET           : LRET = 0
#
If LLIG<0 : End : Endif : # GH 02/12/2013 bug 94899

Local    Decimal WQTY,WWQTY,WDIS,WQTYN,WQTYNA,WQTYB,WQTYBA, WLIEN
Local    Decimal WBAS
Local    Integer WLIKQTYCOD
Local    Decimal WLIKQTY
Local    Integer WQTYRND
Local    Decimal WSCA            # 49281 mm 09.08
Local    Integer WSCATIA
Local    Integer WOPE            # FQ 70236 GA 02/2011 propagation OPENUM si fantôme

Local    Integer WRET
Local    Char    XMSG(120)
Local    Integer OK
Local    Integer WOK             # sr 12/00 variable pour call AVERTIR à la place de I
Local    Decimal WWRK
# sr 09.04 demande 25090
Local    Integer WORITRT : WORITRT = 1

# point d'entrée génération liste composant 12264
GPOINT = "BOMDET" : Gosub ENTREE From EXEFNC
If LRET = 9 : LRET = 0 : End : Endif

# lecture entête
Gosub LEC_FILES_BOH1

# FQ 71053 GA 02/2011 sortir si nomenclature non utilisable
# Issue 122178 GH 25/03/2017 - an error is displayed in case of anomaly
Local    Integer WALT : WALT=LALT
Call CONTMFGNOM(LFCY,WALT,LDAT,1)
If WALT=0
   If GMESSAGE<>""
      Call ERREUR("("+LITM+")"-GMESSAGE) From GESECRAN
      GMESSAGE=""
   Endif
   LRET = 0 : End
Endif


# lecture liens
Local File BOMD [BOD1] Where ITMREF = LITM & BOMALT = LALT & BOMALTTYP = 2 &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LDAT)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LDAT)) &
&                    !find(CPNTYP,5,6,7)

# lecture premier enregistrement
Read [BOD1]BOD0 First                          # 10.02 Performances

# tant qu'y en a !
While !fstat
    # lecture composant
        Gosub LEC_FILES_BOD1
        Call CONTMATITM(LFCY, 1)

        If [F:BOD1]LIKQTY <> 0
        # calcul quantité
            WQTY         = LQTY
            WSTU         = [F:ITM1]STU
            WBAS         = [F:BOH1]BASQTY
            WLIKQTYCOD   = [F:BOD1]LIKQTYCOD
            WLIKQTY      = [F:BOD1]LIKQTY
            WQTYRND      = [F:BOD1]QTYRND
            WSCA         = [F:BOD1]SCA
            Call LIKQTY(WQTY,WSTU,WBAS,WLIKQTYCOD,WLIKQTY,WQTYRND,
&               WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
            If WSCATIA
                WLIEN = WQTYBA
            Else
                WLIEN = WQTYNA
            Endif
        Else
            WLIEN = 0
        Endif

       # Issue 93672 GA 11/2013 à faire après DISPLAY_MAT cf + loin
       # # FQ 73109 GA 04/2011 tenir compte de WLIKQTYCOD=Forfait au niveau supérieur si descente récursive
       # If LLIKQTYCOD=2
       #    [F:BOD1]LIKQTYCOD=LLIKQTYCOD : WLIKQTYCOD=2
       # Endif

    # si sous-produit, traitement particulier
        If [F:BOD1]CPNTYP = 4
           ### If [F:BOD1]CPNOPE=0 WOPE=LOPE Else WOPE=[F:BOD1]CPNOPE Endif
           ### Call DISPLAY_SOUSPROD(LLEV,WLIEN,WOPE, LOFS , LLIK,WSCA,WBAS)
        Else
    # composant normal: on n'affiche qu'à partir du 1er fantôme
            If LLEV>1 | [F:ITM1]PHAFLG=2
               Call DISPLAY_MAT(LLEV,LLIG,WLIEN,WDIS,WSCATIA,LOPE,LOFS,LLIK,WSCA,WBAS,LGHOST)
               If LLIG<0 : Break : Endif : # GH 02/12/2013 bug 94899
            Endif
           # Issue 93672 GA 11/2013 à faire après DISPLAY_MAT
            If LLIKQTYCOD=2
               [F:BOD1]LIKQTYCOD=LLIKQTYCOD : WLIKQTYCOD=2
            Endif

           # si article fantôme descente par récursivité  (llc 03.01 8467 + 8791)
            If ([F:ITM1]PHAFLG = 2)
                If [F:BOD1]CPNOPE=0 WOPE=LOPE Else WOPE=[F:BOD1]CPNOPE Endif
                # FQ 73109 GA 05/2011 tenir compte de WLIKQTYCOD
                Call CREMAT(LLEV+1,LLIG,LFCY,[F:ITM1]ITMREF,LALT,LDAT,WLIEN,LLOT,WOPE,[F:BOD1]BOMOFS,
&                           WLIKQTYCOD,WLIKQTY,WSCA,WBAS, LGHOST, LRET)
            Endif
        Endif
#
$NEXT_BOD
    # FQ 73109 GA 05/2011 pb depuis la génération auto on n'a pas [M:MFG2] ;-)
    If clalev([M:MFG2])>0
       If dim([M:MFG2]ITMREF) < [M:MFG2]NBLIG + 2 : Break : Endif
    Endif
    Read [BOD1]BOD0 Next
Wend
#
If XMSG <> "" : LRET=1 : Endif
#
End

############################################################
$LEC_FILES_BOH1
# lecture entete nomenclature
Read [BOH1]BOH0=LITM;LALT;2
If fstat : Return : Endif
If [F:ITM1]ITMREF <> LITM
    Read [ITM1]ITM0=LITM
    If fstat
        XMSG = (LITM+":"-mess(212,199,1)-LFCY)
        Call ECR_TRACE(XMSG,1) From GESECRAN
    Endif
Endif

WSCATIA = 0
If [F:ITF1]ITMREF <> LITM | [F:ITF1]STOFCY <> LFCY
    Read [ITF1]ITF0=LITM;LFCY
    If fstat
        XMSG = (LITM+":"-mess(45,193,1)-LFCY)
        Call ECR_TRACE(XMSG,1) From GESECRAN
        WSCATIA = 1
    Endif
Endif
If WSCATIA = 0
    If [F:ITF1]RELSCATIA <> 1 : WSCATIA = 1 : Endif
Endif
Return

############################################################
$LEC_FILES_BOD1
If [F:ITM1]ITMREF <> [F:BOD1]CPNITMREF
    Read [ITM1]ITM0=[F:BOD1]CPNITMREF
    If fstat
        XMSG = ([F:BOD1]CPNITMREF+":"-mess(212,199,1))
        Call ECR_TRACE(XMSG,1) From GESECRAN
    Endif
Endif

If [F:ITF1]ITMREF <> [F:BOD1]CPNITMREF | [F:ITF1]STOFCY <> LFCY
    Read [ITF1]ITF0=[F:BOD1]CPNITMREF;LFCY
    If fstat
        XMSG = ([F:BOD1]CPNITMREF+":"-mess(45,193,1))
        Call ECR_TRACE(XMSG,1) From GESECRAN
    Endif
Endif
Return

############################################################
# FQ 71053 GA 02/2011 algorithme idem MFGLIBM
############################################################
Subprog DISPLAY_MAT(LLEV,LIG,LQ,LDIS,LSCATIA,LOPE,LOFS,LLIK,LSCA,LBAS,LGHOST)
Value    Integer LLEV
Variable Integer LIG
Value    Decimal LQ
Value    Decimal LDIS
Value    Integer LSCATIA
Value    Integer LOPE                    # llc 12.01 11561 propagation en traversée fantôme
Value    Integer LOFS                    # llc 12.01 11561 propagation en traversée fantôme
Value    Decimal LLIK                    # llc 01.03 16961
Value    Decimal LSCA                    # mm  11.06 38064
Value    Decimal LBAS                    # mm  11.06 38064
Value    Integer LGHOST                  # FQ 67713 GA 09/2010

Local    Char    WUND(20) : WUND = "____________________"
Local    Decimal WQTY,WWQTY,WDIS,WQTYN,WQTYNA,WQTYB,WQTYBA, WLIEN
Local    Decimal WBAS
Local    Integer WLIKQTYCOD
Local    Decimal WLIKQTY
Local    Integer WQTYRND
Local    Decimal WSCA            # 49281 mm 09.08
Local    Integer WSCATIA
Local    Integer WOPE            # FQ 70236 GA 02/2011 propagation OPENUM si fantôme
Local    Integer WRET

# GH 02/12/2013 bug 94899
If [M:VGHT]NBLIG = dim([M:VGHT]CPNITMREF) : LIG=-1 : Endif
If LIG<0 : End : Endif

[M:VGHT]NBLIG += 1
nolign = [M:VGHT]NBLIG
[M:VGHT] = [F:BOD1]
If LLEV < 19
    [M:VGHT]LEV(nolign-1) = left$(WUND,LLEV-1)+num$(LLEV)
Else
    [M:VGHT]LEV(nolign-1) = left$(WUND,18)+num$(LLEV)
Endif
[M:VGHT]ILEV      (nolign-1) = LLEV
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VGHT]CPNITMDES1(nolign-1), "[F:ITM1]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296 + 65498
[M:VGHT]CPNSTU    (nolign-1) = [F:ITM1]STU
[M:VGHT]PARITM    (nolign-1) = [F:BOD1]ITMREF
[M:VGHT]PURFLG    (nolign-1) = [F:ITM1]PURFLG
[M:VGHT]MFGFLG    (nolign-1) = [F:ITM1]MFGFLG
[M:VGHT]SCPFLG    (nolign-1) = [F:ITM1]SCPFLG
[M:VGHT]SCSFLG    (nolign-1) = [F:ITM1]SCSFLG
[M:VGHT]PHAFLG    (nolign-1) = [F:ITM1]PHAFLG
[M:VGHT]GENFLG    (nolign-1) = [F:ITM1]GENFLG
[M:VGHT]TOOFLG    (nolign-1) = [F:ITM1]TOOFLG
[M:VGHT]DLVFLG    (nolign-1) = [F:ITM1]DLVFLG
[M:VGHT]SALFLG    (nolign-1) = [F:ITM1]SALFLG
[M:VGHT]INTFLG    (nolign-1) = [F:ITM1]INTFLG
Read [F:BOH1]BOH0 =[F:BOD1]ITMREF;[M:VGHT]BOMALT;[M:VGHT]BOMALTTYP
If fstat : Raz [F:BOH1] : Endif
# il faut retrouver dans le tableau la ligne correspondant au composé (pour la quantité)
Gosub REC_QUANTITE_GHT
WQTY         = WWQTY
WSTU         = [F:ITM1]STU
WBASQTY      = [F:BOH1]BASQTY
WLIKQTYCOD   = [F:BOD1]LIKQTYCOD
WLIKQTY   = [F:BOD1]LIKQTY
WQTYRND      = [F:BOD1]QTYRND
# Issue 104942 - 2015-01-06 by CCC
#WSCA         = [F:BOD1]SCA
WSCA         = [F:BOD1]SCA * (LSCATIA<>0)
If  WQTY  = 0 | [F:BOD1]LIKQTY = 0
    WLIEN = 0
Else
    Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,WQTYRND,
&               WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB

# Issue 104942 - 2015-01-05 by CCC : type of quantity has to be chosen according to [ITF]RELSCATIA
#    WLIEN = WQTYBA
    If LSCATIA
        WLIEN = WQTYBA
    Else
        WLIEN = WQTYNA
    Endif
Endif
Call QTEARR(WLIEN, [F:ITM1]STU) From TRTDIV
If WLIEN <> 0
    [M:VGHT]LIKQTY(nolign-1) = WLIEN
Endif
#--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
#Call STODISALL([M:VGHT]STOFCY,[F:BOD1]CPNITMREF,10,1,2,1,2,"","",,WDIS,WRET) From STKALL
Call STODISALL([M:VGHT]STOFCY,[F:BOD1]CPNITMREF,[F:BOD1]ECCVALMAJ,WDIS) From MFGLIBM
[M:VGHT]AVAQTY(nolign-1) = WDIS

# FQ 70236 GA 02/2011
If [M:VGHT]CPNOPE(nolign-1)=0 & LOPE<>0 [M:VGHT]CPNOPE(nolign-1)=LOPE Endif
If [M:VGHT]BOMOFS(nolign-1)=0 & LOFS<>0 [M:VGHT]BOMOFS(nolign-1)=LOFS Endif

End
#########################################################################
# Contrôle de validité (pour prod) d'une alternative                    #
# [F:TBO1] & [F:BOH1] doivent être chargés ...                 FQ 71053 #
#-----------------------------------------------------------------------#
Subprog CONTMFGNOM(LFCY,LALT,LDAT,LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Integer  LMSG
LALT=0
# Alternative de production ?
If [F:TBO1]BOMALTTYP<>2
    If LMSG<>0 : GMESSAGE=mess(47,193,1) : Endif
    End
Endif
# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TBO1]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    If LMSG<>0 : GMESSAGE=mess(46,193,1) : Endif
    End
Endif
# Site ?
If ([F:TBO1]FCY<>"" & [F:TBO1]FCY<>LFCY)
    If LMSG<>0 : GMESSAGE=mess(48,193,1) : Endif
    End
Endif
# Utilisable en production ?
If [F:TBO1]MFGUSE<>2
    If LMSG<>0 : GMESSAGE=mess(49,193,1) : Endif
    End
Endif
# Utilisable en exploitation ?
If [F:BOH1]USESTA<>2
    If LMSG<>0 : GMESSAGE=mess(51,193,1) : Endif
    End
Endif
# Nomenclature valide ?
If ([F:BOH1]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH1]BOHSTRDAT)
     If LMSG<>0 : GMESSAGE=mess(50,193,1) : Endif
     End
Endif
If ([F:BOH1]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH1]BOHENDDAT)
     If LMSG<>0 : GMESSAGE=mess(50,193,1) : Endif
     End
Endif
#
LALT=[F:BOH1]BOMALT
End
#########################################################################
# Contrôle de validité (pour prod) d'une matière                        #
# ITM1 & ITF1 doivent être chargés ...                                    #
#-----------------------------------------------------------------------#
Subprog CONTMATITM(LFCY,LMSG)
Variable Char     LFCY
Value    Integer  LMSG
Local    Integer  VS

#
GPE = 0
GPOINT = "CTLITMSTA"
Gosub  ENTREE From EXEFNC
If !GPE
    Case [F:ITM1]ITMSTA
        When 1:       #   Article actif = ok
        When 2,3:     #   Article non disponible (non bloquant)
                  If LMSG=1
                      VS=1
                      # llc 09.01 10432
                      Call AVERTIR([F:ITM1]ITMREF+":"-mess(3,196,1)+" ("+mess([F:ITM1]ITMSTA,246,1)+")",VS) From GESECRAN
                      If VS = 1 : mkstat = 2 : End : Endif
                  Else
                      mkstat=2
                      End
                  Endif
        When Default: #   Article non disponible (bloquant)
                  # llc 09.01 10432
                  If LMSG=1 : GMESSAGE = [F:ITM1]ITMREF+":"-(mess(3,196,1)+" ("+mess([F:ITM1]ITMSTA,246,1)+")") : Endif
                  mkstat = 2
                  End
    Endcase
Endif
#    contrôle catégorie
If [F:ITM1]PURFLG <> 2 & [F:ITM1]MFGFLG <> 2 & [F:ITM1]SCPFLG <> 2
  # PE permettant de court-circuiter le message - 04.07 mm 46759
  GPE = 0
  GPOINT = "CTLCAT"
  Gosub  ENTREE From EXEFNC
  If !GPE
      If LMSG=1 : GMESSAGE = [F:ITM1]ITMREF+":"-mess(65,193,1) : Endif
  Endif
  mkstat = 2
  End
Endif
#    Article non géré en stock
If !find([F:ITF1]STOMGTCOD,2,3,4)
    If [F:ITM1]PHAFLG <> 2
        # PE permettant de court-circuiter le message - 12.06 mm 38828
        GPE = 0
        GPOINT = "ITMCTL"
        Gosub  ENTREE From EXEFNC
        If !GPE
            If LMSG=1 : GMESSAGE = [F:ITM1]ITMREF+":"-mess(147,199,1) : Endif
        Endif
        mkstat = 2
        End
    Endif
Endif

#---------
# PE permettant d'ajouter des contrôles supplémentaires - 07.05 MM 31031
GPOINT = "CHECKCOMP"
Gosub  ENTREE From EXEFNC
#---------

End





