# Superviseur
## CRUD-CLASSE ## CCMCRORIGC
# 2018-10-19 07:50:18 149


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(CCMCRORIGC,ASTATUS)
Variable Instance CCMCRORIGC Using C_CCMCRORIGC
Variable Integer ASTATUS

If CCMCRORIGC = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_CCMCRORIGC

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(CCMCRORIGC,ASTATUS)
Variable Instance CCMCRORIGC Using C_CCMCRORIGC
Variable Integer ASTATUS

If CCMCRORIGC = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGC
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_CCMCRORIGC
Else
 Gosub ADELETE_CCMCRORIGC
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(CCMCRORIGC,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If CCMCRORIGC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGC.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_CCMCRORIGC
Trbegin [F:CCMCROC]
 Gosub ADELETE_CCMCRORIGC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_CCMCRORIGC
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(CCMCRORIGC,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGC._MAJSQL_CCMCRORIGC(CCMCRORIGC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If CCMCRORIGC.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGC.revertUpdTick
Endif
[L]ASTATUS = max(fmet CCMCRORIGC.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



