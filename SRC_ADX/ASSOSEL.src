#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet ANU
Local Char PARAM(250)(1..3) , VALEUR(250)
PARAM(1) = ""
PARAM(2) = "DisplayName,mail,sAMAccountName,whenCreated,distinguishedName"
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","ASSOSEL","ASSOSEL",3,"") From GTRAITE
End

#------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "SEL_LISTE"  : Gosub SEL_LISTE
Endcase
Return

#------------------------------------------------#
$INIT
Local Integer NCOL : NCOL = 5
Local Integer I , J , PORT , AERR , FORCE
Local Char    CHAINE(250) , MESSAG(250) , CHAINE2(250) , CLAOBJ(30)
Local Char    DOMAINE(50)

If clalev([F:ANU])=0 : Local File ANNUAIRE  [ANU] : Endif

If dim(PARAM)>2
 FORCE = 1
 DOMAINE = PARAM(3)
Endif

Call VERIF(FORCE,DOMAINE,PORT,GERR,GMESSAGE) From ASSOCODE
If GERR : FIN = 1 : Return : Endif

Call PARAM("","SSOCLAOBJ",CHAINE) From ADOVAL
If CHAINE<>""
 CLAOBJ = CHAINE
Else
 CLAOBJ = "user"
Endif

Return

#------------------------------------------------#
$INIT_DIA
If PARAM(1)=""
 [M]FILTRE = "(&(objectclass="+CLAOBJ+")(SN=*)(GIVENNAME=*))"
Else
 [M]FILTRE = PARAM(1)
Endif
For I=1 To [F:ANU]NBRFLD
 [M]ADDFLD(I-1) = [F:ANU]ADDFLD(I-1)
 [M]SELECT(I-1) = 0
Next I
[M]NBRFLD = [F:ANU]NBRFLD
CHAINE = PARAM(2)
I = 0
While CHAINE<>"" & I<NCOL
 K = instr(1,CHAINE,",")
 If K
  CHAINE2 = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CHAINE2 = CHAINE
  CHAINE = ""
 Endif
 For J=1 To [M]NBRFLD
  If toupper(CHAINE2)=toupper([M]ADDFLD(J-1))
   I += 1
   [M]SELECT(J-1) = I
   Break
  Endif
 Next J   
Wend
If I=0
 [M]SELECT(0) = 1
Endif
If dim(PARAM)>2 & dim([M]DOMAIN)>0
 [M]DOMAIN = PARAM(3)
Endif
Return

#-----------------------------------#
$CONTROLE
If [M]FILTRE=""
 Call ERREUR(mess(194,117,1)) From GESECRAN : # Critère obligatoire
 SAI = 1 : Return
Endif
K = max([M]SELECT)
If K>NCOL
 Call ERREUR(func AFNC.MES(mess(256,139,1),num$(NCOL))) From GESECRAN : # Trop de champs (maxi #)
 SAI = 1 : Return
Endif
CHAINE = ""
For J=1 To K
 For I=1 To [M]NBRFLD
  If [M]SELECT(I-1)=J
   If CHAINE<>"" : CHAINE += "," : Endif
   CHAINE += [M]ADDFLD(I-1) : Break
  Endif
 Next I
Next J
Return

#-----------------------------------#
$EXEC
Local Char PARBOUT(250)(1..20)
PARBOUT(1) = [M]FILTRE
PARBOUT(2) = CHAINE
If dim([M]DOMAIN)>0
 PARBOUT(3) = [M]DOMAIN
Endif
Call S_LIS_CHAR(VALEUR,PARBOUT,"ASSOSEL","ASSOSEL","") From GACTION
Return

#------------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "ASSOSEL" : Gosub SELSSO
Endcase
Return

#-----------------------#
$SELSSO
Local Integer NCOL : NCOL = 5
Local Char    PREF(10) , TRTANU(GLONADC)
Local Char    AAUSER(20) , APASSWD(20) , MESSAG(250) , CHAINE(250) , CHAINE2(250)
Local Char    ANOM(80) , APRE(80) , ACLE(30) , DOMAINE(50)
Local Integer AERR , SIZCOL , SIZLIG , PORT , ACOL(1..NCOL) , ANUMCLE , FORCE
Local Char    TEX(250)(1..GNBSEL) , TEXTE(250)(1..GNBSEL,1..NCOL) , TIT(30)(0..NCOL)

If clalev([F:ANU])=0 : Local File ANNUAIRE [ANU] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif

If dim(PARAM)>2
 FORCE = 1
 DOMAINE = PARAM(3)
Endif

Call VERIF(FORCE,DOMAINE,PORT,AERR,MESSAG) From ASSOCODE
If AERR : GERR = 1 : GMESSAGE = MESSAG : goto FIN_SEL : Endif

Call OUVRE([F:ANU]SERV1,PORT,[F:ANU]CONNEC,[F:ANU]PASSE,AERR,MESSAG) From ASSOCODE
If AERR : GERR = 1 : GMESSAGE = MESSAG : goto FIN_SEL : Endif

Call SET_PREF(PREF) From SUBANU
TRTANU = PREF+[F:ANU]COD
Gosub INIT From =TRTANU

FORCE   = 1
SIZCOL  = 500
SIZLIG  = 200
TIT(0)  = mess(54,130,1)-[F:ANU]COD : # Annuaire utilisateur

AFILTRE = PARAM(1)
CHAINE  = PARAM(2)
ACLE    = "distinguishedName"

Raz I , ANUMCLE
While CHAINE<>"" & I<dim(ACOL)
 K = instr(1,CHAINE,",")
 If K
  CHAINE2 = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CHAINE2 = CHAINE
  CHAINE = ""
 Endif
 For J=1 To [F:ANU]NBRFLD
  If toupper(CHAINE2)=toupper([M]ADDFLD(J-1))
   I += 1
   ACOL(I) = J
   TIT(I) = [F:ANU]ADDFLD(J-1)
   If toupper(CHAINE2)=toupper(ACLE)
    ANUMCLE = J
   Endif
   Break
  Endif
 Next J   
Wend
If sum(ACOL)=0
 For J=1 To [F:ANU]NBRFLD
  If toupper(CHAINE2)=toupper(ACLE)
   ACOL(1) = J
   TIT(1) = [F:ANU]ADDFLD(J-1)
   ANUMCLE = J
   Break
  Endif
 Next J   
 If sum(ACOL)=0 
  ACOL(1) = 1
 Endif
Endif

ABASE  = [F:ANU]PARAM1
ASCOPE = [F:ANU]PARAM2

Raz NBTEX , AERR

Onerrgo ERR_LIRE
Gosub LIRE From =TRTANU
Onerrgo
If AERR : GERR = 1 : GMESSAGE = MESSAG : goto FIN_SEL : Endif

While !fstat & NBTEX<dim(TEX)-1
 NBTEX += 1
 If ANUMCLE>0
  TEX(NBTEX) = evalue(AVALEUR(ANUMCLE))
 Else
  TEX(NBTEX) = evalue(AVALEUR(ACOL(1)))
 Endif
 I = 0
 While I<dim(ACOL)
  I += 1
  If ACOL(I)>0
   TEXTE(NBTEX,I) = evalue(AVALEUR(ACOL(I)))
  Endif
 Wend
 Onerrgo ERR_SUITE
 Gosub SUITE From =TRTANU
 Onerrgo
 If AERR : Break : Endif
Wend

Call FERME From ASSOCODE

#----------------------#
$FIN_SEL
If dim(GSSODOMSEL)>0
 Kill GSSODOMSEL
Endif
Return

#----------------------#
$ERR_LIRE
AERR = 2
ER = errn
MESSAG = mess(6,123,1)-num$(ER)-errmes$(ER)-errm
Resume

$ERR_SUITE
AERR = 2
Resume

#-------------------------------------------------------------------------------------------------------#
Subprog C_SELECT(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : End : Endif
If VALEUR>5
 Call ERREUR(func AFNC.MES(mess(115,75,1),"5")) From GESECRAN : # Valeur trop grande (maximum #)
 mkstat = 1 : End
Endif
Call UNICITE(VALEUR,[M]SELECT(0..[M]NBRFLD-1)) From OBJDIV
End
