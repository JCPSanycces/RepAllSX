  CHIFFRE(4)  = "vier"
  CHIFFRE(5)  = "fünf"
  CHIFFRE(6)  = "sechs"
  CHIFFRE(7)  = "sieben"
  CHIFFRE(8)  = "acht"
  CHIFFRE(9)  = "neun"
  CHIFFRE(10) = "zehn"
  CHIFFRE(11) = "elf"
  CHIFFRE(12) = "zwölf"
  CHIFFRE(13) = "dreizehn"
  CHIFFRE(14) = "vierzehn"
  CHIFFRE(15) = "funfzehn"
  CHIFFRE(16) = "sechzehn"
  CHIFFRE(17) = "siebzehn"
  CHIFFRE(18) = "achtzehn"
  CHIFFRE(19) = "neunzehn"
 When Default
