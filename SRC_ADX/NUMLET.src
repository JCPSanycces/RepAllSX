Endcase
Return

##############################################################
## Libellé des monnaies
##############################################################
Subprog MONNAIE(LANGUE,DEVISE,FRANC,CENTIME)
Value    Char LANGUE ()
Value    Char DEVISE ()
Variable Char FRANC ()
Variable Char CENTIME ()

Case LANGUE
 When "ENG","BRI"
  Case DEVISE
   When "FRF" , "BEF" , "FRS" , "LUF"
    FRANC = "franc"   : CENTIME = "centime"
   When "EUR"
    FRANC = "euro"    : CENTIME = "cent"
   When "DEM"
    FRANC = "Mark"    : CENTIME = "Pfennig"
   When "ITL"
    FRANC = "lira"    : CENTIME = ""
   When "GBP" , "IEP"
    FRANC = "pound"   : CENTIME = "pence"
   When "ESP"
    FRANC = "peseta"  : CENTIME = ""
   When "PTE"
    FRANC = "escudo"  : CENTIME = ""
   When "GRD"
    FRANC = "drachme" : CENTIME = ""
   When "DKK"
    FRANC = "crown"   : CENTIME = "ore"
   When "NLG"
    FRANC = "guilder" : CENTIME = "cent"
   When "USD"
    FRANC = "dollar"  : CENTIME = "cent"
   When "JPY"
    FRANC = "yen"     : CENTIME = ""
   When "ECU"
    FRANC = "ecu"     : CENTIME = "cent"
  Endcase
 When Default
  Case DEVISE
   When "FRF" , "BEF" , "FRS" , "LUF"
    FRANC = "franc"    : CENTIME = "centime"
   When "EUR"
    FRANC = "euro"     : CENTIME = "cent"
   When "DEM"
    FRANC = "Mark"     : CENTIME = "Pfennig"
   When "ITL"
    FRANC = "lire"     : CENTIME = ""
   When "GBP" , "IEP"
    FRANC = "livre"    : CENTIME = "pence"
   When "ESP"
    FRANC = "peseta"   : CENTIME = ""
   When "PTE"
    FRANC = "escudo"   : CENTIME = ""
   When "GRD"
    FRANC = "drachme"  : CENTIME = ""
   When "DKK"
    FRANC = "couronne" : CENTIME = "ore"
   When "NLG"
    FRANC = "florin"   : CENTIME = "cent"
   When "USD"
    FRANC = "dollar"   : CENTIME = "cent"
   When "JPY"
    FRANC = "yen"      : CENTIME = ""
   When "ECU"
    FRANC = "ecu"      : CENTIME = "cent"
  Endcase
Endcase
End


