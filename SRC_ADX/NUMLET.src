  CHIFFRE(2)  = "deux"
  CHIFFRE(3)  = "trois"
  CHIFFRE(4)  = "quatre"
  CHIFFRE(5)  = "cinq"
  CHIFFRE(6)  = "six"
  CHIFFRE(7)  = "sept"
  CHIFFRE(8)  = "huit"
  CHIFFRE(9)  = "neuf"
  CHIFFRE(10) = "dix"
  CHIFFRE(11) = "onze"
  CHIFFRE(12) = "douze"
  CHIFFRE(13) = "treize"
  CHIFFRE(14) = "quatorze"
  CHIFFRE(15) = "quinze"
  CHIFFRE(16) = "seize"
  CHIFFRE(17) = "dix-sept"
  CHIFFRE(18) = "dix-huit"
  CHIFFRE(19) = "dix-neuf"
Endcase
Case LANGUE
 When "ENG","BRI"
  DIZAINE(1) = "ten"
  DIZAINE(2) = "twenty"
  DIZAINE(3) = "thirty"
  DIZAINE(4) = "fourty"
  DIZAINE(5) = "fifty"
  DIZAINE(6) = "sixty"
  DIZAINE(7) = "seventy"
  DIZAINE(8) = "eighty"
  DIZAINE(9) = "ninety"
 When "DUT"
  DIZAINE(1) = "tien"
  DIZAINE(2) = "twintig"
  DIZAINE(3) = "dertig"
  DIZAINE(4) = "veertig"
  DIZAINE(5) = "vijftig"
