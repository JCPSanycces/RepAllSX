#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################
## Subprog NUMLET(LANGUE,DEVISE,NOMBRE,TEXTE,LONG)
## Subprog NUMBLET(LANGUE,NOMBRE,UNIT1,UNIT2,TEXTE,LONG)
## Subprog MONNAIE(LANGUE,DEVISE,FRANC,CENTIME)
################################################################
Local Decimal X
Local Char    TEXTE(255)(10) , LAN(GLONLAN) , DEV(GLONCUR)

X = 1234567.89
X = 9876543.21
DEV = "EUR"
For LAN = "FRA","ENG","DEU","DUT"
 Call NUMLET(LAN,DEV,X,TEXTE,60)
 Infbox TEXTE(0)-TEXTE(1)-TEXTE(2) Titled format$("N3:13.2",X)-DEV-"=>"-LAN
Next LAN
End

##############################################################
Subprog NUMLET(LANGUE,DEVISE,NOMBRE,TEXTE,LONG)
Value    Char    LANGUE ()
Value    Char    DEVISE ()
Value    Decimal NOMBRE
Variable Char    TEXTE ()()
Value    Integer LONG
Local    Char    UNIT1(20) , UNIT2(20)

Call MONNAIE(LANGUE,DEVISE,UNIT1,UNIT2)
Call NUMBLET(LANGUE,NOMBRE,UNIT1,UNIT2,TEXTE,LONG)
End

##############################################################
Subprog NUMBLET(LANGUE,NOMBRE,UNIT1,UNIT2,TEXTE,LONG)
Value    Char    LANGUE ()
Value    Decimal NOMBRE
Value    Char    UNIT1 () , UNIT2 ()
Variable Char    TEXTE ()()
Value    Integer LONG

Local Integer FRANCS , CENTIMES
Local Integer I , J , K
Local Char    CHAINE(255) , CH1(255)

Case LANGUE
 When "ENG","BRI" : Gosub ANGLAIS
 When "DEU"       : Gosub ALLEMAND
 When "DUT"       : Gosub NEERLANDAIS
 When Default     : Gosub FRANCAIS
Endcase

CHAINE = vireblc(CHAINE,2)
Raz TEXTE
I = 0 : J = 0
While I<=len(CHAINE)
 K = min(instr(I+1,CHAINE+" "," "),instr(I+1,CHAINE+"-","-"))
 If K>LONG
  TEXTE(J) = vireblc(left$(CHAINE,I),2)
  CHAINE   = right$(CHAINE,I+1)
  J += 1 : I = 0
 Else
  I = K
 Endif
Wend
TEXTE(J) = vireblc(CHAINE,2)
TEXTE(0) = toupper(left$(TEXTE(0),1))+right$(TEXTE(0),2)
End

########################################################
## En Français                                        ##
########################################################
$FRANCAIS
CHAINE   = ""
FRANCS   = int(NOMBRE)
CENTIMES = 100*(NOMBRE-FRANCS)
If FRANCS>0
 Call NOMBRE(FRANCS,CH1,LANGUE)
 CHAINE -= CH1
 If mod(FRANCS,1000000)=0 : CHAINE -= "de" : Endif
 CHAINE -= UNIT1
 If FRANCS>1
  If right$(UNIT1,len(UNIT1))="|"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += "s"
  Endif
 Endif
Endif
If CENTIMES>0
 Call NOMBRE(CENTIMES,CH1,LANGUE)
 If FRANCS>0 : CHAINE -= "et" : Endif
 CHAINE -= CH1-UNIT2
 If CENTIMES>1
  If right$(UNIT2,len(UNIT2))="|"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += "s"
  Endif
 Endif
Endif
Return

Subprog NOMBRE(NOMBRE,CHAINE,LANGUE)
Value    Integer NOMBRE
Variable Char    CHAINE()
Variable Char    LANGUE()
Local Integer MILLION , MILLE , UNITE
Local Char    CH1(255)

MILLION = int(NOMBRE/1000000)
MILLE   = int(mod(NOMBRE,1000000)/1000)
UNITE   = mod(NOMBRE,1000)
CHAINE = ""
If MILLION>0
 Call MILLE(MILLION,CH1,LANGUE)
 CHAINE += CH1-"million" : If MILLION>1 : CHAINE += "s" : Endif
Endif
If MILLE>0
 If MILLE=1
  CHAINE -= "mille"
 Else
  Call MILLE(MILLE,CH1,LANGUE)
  CHAINE -= CH1-"mille"
 Endif
Endif
If UNITE>0
 Call MILLE(UNITE,CH1,LANGUE)
 CHAINE -= CH1
Endif
CHAINE = vireblc(CHAINE,2)
End

Subprog MILLE(NOMBRE,TEXTE,LANGUE)
Value    Integer NOMBRE
Variable Char    TEXTE
Variable Char    LANGUE()

Gosub CHIFFRE
Local Integer CEN,DIZ,UNT

CEN = int(NOMBRE/100)
DIZ = int(mod(NOMBRE,100)/10)
UNT = mod(NOMBRE,10)

Case CEN
 When 0
  TEXTE=""
 When 1
  TEXTE="cent"
 When Default
  TEXTE = CHIFFRE(CEN)
  If DIZ=0 & UNT=0
   TEXTE -= "cents"
  Else
   TEXTE -= "cent"
  Endif
Endcase

Case DIZ
 When 0
  If UNT<>0
   TEXTE -= CHIFFRE(UNT)
  Endif
 When 1
  TEXTE -= CHIFFRE(10+UNT)
 When 2,3,4,5,6,8
  Case UNT
   When 0
    If DIZ=8 : TEXTE -= "quatre-vingts"
    Else     : TEXTE -= DIZAINE(DIZ)
    Endif
   When 1
    If DIZ=8 : TEXTE -= DIZAINE(DIZ)+"-un"
    Else     : TEXTE -= DIZAINE(DIZ)-"et un"
    Endif
   When Default
    TEXTE -= DIZAINE(DIZ)+"-"+CHIFFRE(UNT)
  Endcase
 When 7,9
  Case UNT
   When 0
    TEXTE -= DIZAINE(DIZ)
   When 1
    If DIZ=7 : TEXTE -= "soixante et onze"
    Else     : TEXTE -= "quatre-vingt-onze"
    Endif
   When Default
    TEXTE -= DIZAINE(DIZ-1)+"-"+CHIFFRE(10+UNT)
  Endcase
Endcase
End

##########################################################
## En anglais                                           ##
##########################################################
$ANGLAIS
CHAINE   = ""
FRANCS   = int(NOMBRE)
CENTIMES = 100*(NOMBRE-FRANCS)
If FRANCS>0
 Call NUMBER(FRANCS,CH1,LANGUE)
 CHAINE -= CH1
 CHAINE -= UNIT1
 If FRANCS>1
  If right$(UNIT1,len(UNIT1))="|"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += "s"
  Endif
 Endif
Endif
If CENTIMES>0
 Call NUMBER(CENTIMES,CH1,LANGUE)
 If FRANCS>0 : CHAINE -= "   " : Endif
 CHAINE -= CH1-UNIT2
 If CENTIMES>1
  If right$(UNIT2,len(UNIT2))="|"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += "s"
  Endif
 Endif
Endif
Return

Subprog NUMBER(NOMBRE,CHAINE,LANGUE)
Value    Integer NOMBRE
Variable Char    CHAINE()
Variable Char    LANGUE()
Local Integer MILLION , MILLE , UNITE
Local Char    CH1(255)

MILLION = int(NOMBRE/1000000)
MILLE   = int(mod(NOMBRE,1000000)/1000)
UNITE   = mod(NOMBRE,1000)
CHAINE  = ""
If MILLION>0
 Call THOUS(MILLION,CH1,LANGUE)
 CHAINE += CH1-"million"
Endif
If MILLE>0
 If MILLE=1
  CHAINE -= "one thousand"
 Else
  Call THOUS(MILLE,CH1,LANGUE)
  CHAINE -= CH1-"thousand"
 Endif
Endif
If UNITE>0
 Call THOUS(UNITE,CH1,LANGUE)
 If UNITE<100 & NOMBRE>1000
  CHAINE -= "and"
 Endif
 CHAINE -= CH1
Endif
CHAINE = vireblc(CHAINE,2)
End

Subprog THOUS(NOMBRE,TEXTE,LANGUE)
Value    Integer NOMBRE
Variable Char    TEXTE

Gosub CHIFFRE
Local Integer CEN,DIZ,UNT

CEN = int(NOMBRE/100)
DIZ = int(mod(NOMBRE,100)/10)
UNT = mod(NOMBRE,10)

Case CEN
 When 0
  TEXTE = ""
 When 1
  TEXTE = "one hundred"
 When Default
  TEXTE = CHIFFRE(CEN)-'hundred'
Endcase
If NOMBRE>100 & mod(NOMBRE,100)<>0 : TEXTE -= "and" : Endif
Case DIZ
 When 0
  If UNT<>0
   TEXTE -= CHIFFRE(UNT)
  Endif
 When 1
  TEXTE -= CHIFFRE(10+UNT)
 When Default
  TEXTE -= DIZAINE(DIZ)-CHIFFRE(UNT)
Endcase
End

###################################################################
## En allemand
###################################################################
$ALLEMAND
CHAINE   = ""
FRANCS   = int(NOMBRE)
CENTIMES = 100*(NOMBRE-FRANCS)
If FRANCS>0
 Call NOMMER(FRANCS,CH1,LANGUE)
 CHAINE -= CH1
 CHAINE -= UNIT1
 If FRANCS>1
  If right$(UNIT1,len(UNIT1))="|"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += ""
  Endif
 Endif
Endif
If CENTIMES>0
 Call NOMMER(CENTIMES,CH1,LANGUE)
 If FRANCS>0 : CHAINE -= "und" : Endif
 CHAINE -= CH1-UNIT2
 If CENTIMES>1
  If right$(UNIT2,len(UNIT2))="|"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += ""
  Endif
 Endif
Endif
Return

Subprog NOMMER(NOMBRE,CHAINE,LANGUE)
Value    Integer NOMBRE
Variable Char    CHAINE()
Variable Char    LANGUE()
Local Integer MILLION , MILLE , UNITE
Local Char    CH1(255)

MILLION = int(NOMBRE/1000000)
MILLE   = int(mod(NOMBRE,1000000)/1000)
UNITE   = mod(NOMBRE,1000)
CHAINE  = ""
If MILLION>0
 Call THAUSEND(MILLION,CH1,LANGUE)
 CHAINE += CH1
 If MILLION=1 : CHAINE +='e' : Endif
 CHAINE -= "Million"
Endif
If MILLE>0
 If MILLE=1
  CHAINE -= "Tausand"
 Else
  Call THAUSEND(MILLE,CH1,LANGUE)
  CHAINE -= CH1-"Tausand"
 Endif
Endif
If UNITE>0
 Call THAUSEND(UNITE,CH1,LANGUE)
 If UNITE<100 & NOMBRE>1000
  CHAINE -= 'und'
 Endif
 CHAINE -= CH1
Endif
CHAINE = vireblc(CHAINE,2)
End

Subprog THAUSEND(NOMBRE,TEXTE,LANGUE)
Value    Integer NOMBRE
Variable Char    TEXTE
Variable Char    LANGUE()

Gosub CHIFFRE
Local Integer CEN,DIZ,UNT

CEN = int(NOMBRE/100)
DIZ = int(mod(NOMBRE,100)/10)
UNT = mod(NOMBRE,10)
Case CEN
 When 0
  TEXTE = ""
 When 1
  TEXTE = "Hundert"
 When Default
  TEXTE = CHIFFRE(CEN)
  TEXTE += "hundert"
Endcase

Case DIZ
 When 0
  If UNT<>0 & CEN=0
   TEXTE -= CHIFFRE(UNT)
  Elsif UNT<>0
   TEXTE -= 'und'-CHIFFRE(UNT)
  Endif
 When 1
  If CEN=0
   TEXTE -= CHIFFRE(10+UNT)
  Else
   TEXTE -= 'und'-CHIFFRE(10+UNT)
  Endif
 When Default
  If UNT<>0
   TEXTE -= CHIFFRE(UNT)+"und"+DIZAINE(DIZ)
  Else
   If CEN=0
    TEXTE -= DIZAINE(DIZ)
   Else
    TEXTE -= "und"-DIZAINE(DIZ)
   Endif 
  Endif
Endcase
End

####################################################################
## En néerlandais
####################################################################
$NEERLANDAIS
CHAINE   = ""
FRANCS   = int(NOMBRE)
CENTIMES = 100*(NOMBRE-FRANCS)
If FRANCS>0
 Call NUMMER(FRANCS,CH1,LANGUE)
 CHAINE -= CH1
 CHAINE -= UNIT1
 If FRANCS>1
  If right$(UNIT1,len(UNIT1))="|"
   CHAINE = left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += ""
  Endif
 Endif
Endif
If CENTIMES>0
 Call NUMMER(CENTIMES,CH1,LANGUE)
 If FRANCS>0 : CHAINE -= "en" : Endif
 CHAINE -= CH1-UNIT2
 If CENTIMES>1
  If right$(UNIT2,len(UNIT2))="|"
   CHAINE=left$(CHAINE,len(CHAINE)-1)
  Else
   CHAINE += ""
  Endif
 Endif
Endif
Return

Subprog NUMMER(NOMBRE,CHAINE,LANGUE)
Value    Integer NOMBRE
Variable Char    CHAINE()
Local Integer MILLION , MILLE , UNITE
Local Char    CH1(255)

MILLION = int(NOMBRE/1000000)
MILLE   = int(mod(NOMBRE,1000000)/1000)
UNITE   = mod(NOMBRE,1000)
CHAINE  = ""
If MILLION>0
 Call DUIZEND(MILLION,CH1,LANGUE)
 CHAINE += CH1-"millioen"
Endif
If MILLE>0
 If MILLE=1
  CHAINE -= "duizend"
 Else
  Call DUIZEND(MILLE,CH1,LANGUE)
  CHAINE -= CH1-"duizend"
 Endif
Endif
If UNITE>0
 Call DUIZEND(UNITE,CH1,LANGUE)
 If UNITE<10 & NOMBRE>1000
  CHAINE -= 'en'
 Endif
 CHAINE -= CH1
Endif
CHAINE = vireblc(CHAINE,2)
End

Subprog DUIZEND(NOMBRE,TEXTE,LANGUE)
Value    Integer NOMBRE
Variable Char    TEXTE

Gosub CHIFFRE
Local Integer CEN,DIZ,UNT

CEN = int(NOMBRE/100)
DIZ = int(mod(NOMBRE,100)/10)
UNT = mod(NOMBRE,10)

Case CEN
 When 0
  TEXTE = ""
 When 1
  TEXTE = "honderd"
 When Default
  TEXTE = CHIFFRE(CEN)
  TEXTE -= "honderd"
Endcase

Case DIZ
 When 0
  If UNT<>0 & CEN=0
   TEXTE -= CHIFFRE(UNT)
  Elsif UNT<>0
   TEXTE -= 'en'-CHIFFRE(UNT)
  Endif
 When 1
  If CEN=0
   TEXTE -= CHIFFRE(10+UNT)
  Else
   TEXTE -= 'en'-CHIFFRE(10+UNT)
  Endif
  When Default
   If UNT<>0
    TEXTE -= CHIFFRE(UNT)-"en"-DIZAINE(DIZ)
   Else
    If CEN=0
     TEXTE -= 'en'-DIZAINE(DIZ)
    Else
     TEXTE -= DIZAINE(DIZ)
    Endif
   Endif
Endcase
End

###########################################################
## Chiffres de base
###########################################################
$CHIFFRE
Local Char CHIFFRE(30)(20)
Local Char DIZAINE(20)(20)
Case LANGUE
 When "ENG","BRI"
  CHIFFRE(1)  = "one"
  CHIFFRE(2)  = "two"
  CHIFFRE(3)  = "three"
  CHIFFRE(4)  = "four"
  CHIFFRE(5)  = "five"
  CHIFFRE(6)  = "six"
  CHIFFRE(7)  = "seven"
  CHIFFRE(8)  = "eight"
  CHIFFRE(9)  = "nine"
  CHIFFRE(10) = "ten"
  CHIFFRE(11) = "eleven"
  CHIFFRE(12) = "twelve"
  CHIFFRE(13) = "thirteen"
  CHIFFRE(14) = "fourteen"
  CHIFFRE(15) = "fifteen"
  CHIFFRE(16) = "sixteen"
  CHIFFRE(17) = "seventeen"
  CHIFFRE(18) = "eighteen"
