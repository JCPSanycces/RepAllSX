  CHIFFRE(4)  = "vier"
  CHIFFRE(5)  = "vijf"
  CHIFFRE(6)  = "zes"
  CHIFFRE(7)  = "zeven"
  CHIFFRE(8)  = "acht"
  CHIFFRE(9)  = "negen"
  CHIFFRE(10) = "tien"
  CHIFFRE(11) = "elf"
  CHIFFRE(12) = "twaalf"
  CHIFFRE(13) = "dertien"
  CHIFFRE(14) = "veertien"
  CHIFFRE(15) = "vijftien"
  CHIFFRE(16) = "zestien"
  CHIFFRE(17) = "zeventien"
  CHIFFRE(18) = "achttien"
  CHIFFRE(19) = "negentien"
 When "DEU"
  CHIFFRE(1)  = "ein"
