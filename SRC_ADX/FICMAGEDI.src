#<AdxTL>@(#)1.0.0.0 $Revision$
End


############################################
Subprog FICHIER_EDI(MESSAGE,TYPBOR,NUMERO,NOMFIC,NOM,EXT)
Value    Char    MESSAGE()
Value    Integer TYPBOR
Value    Char    NUMERO()
Value    Char    NOMFIC()
Value    Char    NOM()
Value    Char    EXT()

#Call OUVRE_TRACE("Virements commerciaux EDI") From LECFIC
#Call ECR_TRACE("Génération fichier EDI sur le bordereau :"-NUMERO,0) From GESECRAN

GOK=1
Gosub OUVRE
Gosub DECLARE
Gosub DECLARE From FICEDI
Gosub CONTROLE

If GOK=1
 SYMBOLE = "FRM"+NUMERO+"\"+num$(TYPBOR)
 Lock =SYMBOLE
 If fstat
  STA = 6 : Gosub TRTERR From FICEDI
  Raz SYMBOLE
 Else
  Openo NOMFIC,0 Using [TRA]
  Gosub TR1
  Openo Using [TRA]
  If GOK=1
    [L]DATJ = datesyst
    Gosub TR2  :# Mise à jour des règlements et du bordereau
    If GTRACE<>"" : Call ECR_TRACE("",0) From GESECRAN : Endif
    K = instr(1,NOMFIC,"#")
    If K : NOMFIC = right$(NOMFIC,K+2) : Endif    
    Call ECR_TRACE(mess(104,121,1)+":|"-NOMFIC,0) From GESECRAN
  Endif
 Endif
Endif

If SYMBOLE<>""
  Unlock =SYMBOLE
Endif
#Call FERME_TRACE From LECFIC
#Call SUPP_TRACE From LECFIC
End

############################################
$CONTROLE
Read [FRM]FRM0 = TYPBOR;NUMERO
If fstat 
 STA = 1 : GOK=0 : Gosub TRTERR From FICEDI : Return
Endif
BANQUE = [F:FRM]BAN
If GTRACE<>"" 
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE(mess(126,117,1)-":"-NUMERO+" - "+mess(1,653,1)-":"-BANQUE,0) From GESECRAN
 Call ECR_TRACE(string$(100,"-"),0) From GESECRAN
Endif
Read [PYH]PYH1(2) = TYPBOR;NUMERO
If fstat 
 STA = 1 : GOK=0 : Gosub TRTERR From FICEDI : Return
Endif
Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
Call LEC_TPY_LEG([F:CPY]LEG,[F:FRM]PAYTYP) From CPTLEC
If [F:TPY]STA6<>2
 STA = 2 : GOK=0 : Gosub TRTERR From FICEDI : Return
Endif
Filter [EDM] Where MES=MESSAGE & BAN=BANQUE
Look [EDM]EDM0 First
If fstat
 STA = 9 : GOK=0 : MESSA = MESSAGE-BANQUE
 Gosub TRTERR From FICEDI : Return
Endif
Return

############################################
$TR1
Raz NBMESS, NBBPR, NBSEG, SEGEXC
[C]EDIINT += 1 : NUMINT = [C]EDIINT

Filter [PYH] Where FRMFLG=TYPBOR & FRMNUM=NUMERO Order By Key CLE = DUDDAT;CUR;BPR;NUM
Filter [PY2] Where FRMFLG=TYPBOR & FRMNUM=NUMERO Order By Key CLE = DUDDAT;CUR;BPR;NUM
Filter [PYD] Order By Key CLE = NUM;VCRTYP;VCRNUM;ACCTYP;LIN

Call LECTURE("BAN",BANQUE,"") From CONTOBJ
Call LECTURE("CPY",[F:BAN]CPY,"") From CONTOBJ
Call LECTURE("FCY",[F:FRM]FRMFCY,"") From CONTOBJ

GOK=1
Gosub ECRIT_UNA From FICEDI
If GOK<1 : Goto FIN : Endif

# DEBUT D'INTERCHANGE (UNB)
GRPDEB=0 : GRPFIN=0 : CODSEG="UNB"
Gosub ECRIT_GRP From FICEDI
CODSEG="" : SEGEXC(0)="UNA" : SEGEXC(1)="UNB"

For [PYH]CLE(2)  :# date + devise
  # Partie débit : groupes 0 à 10
  Gosub RUPTURE_DATE
  If GOK<1 : Break : Endif

  For [PYH]CLE(3)   :# tiers
    # Partie crédit : groupes 11 à 16
    Gosub RUPTURE_TIERS
    If GOK<1 : Break 2 : Endif

    For [PYH]CLE
      # Détail des documents : groupes 17 à 22
      Gosub RUPTURE_RGLT
      If GOK<1 : Break 3 : Endif
    Next

    GRPDEB=23 : GRPFIN=23   # Totaux pour contrôles
    Gosub ECRIT_GRP From FICEDI
  Next   :# Tiers

  GRPDEB=24 : GRPFIN=26   # Segment de contrôle et fin de message
  Gosub ECRIT_GRP From FICEDI
Next   :# Date

# FIN D'INTERCHANGE (UNZ)
GRPDEB=27 : GRPFIN=27 
Gosub ECRIT_GRP From FICEDI

$FIN
Filter [EDM]
Filter [PYH]
Filter [PY2]
Filter [PYD]
Return

$RUPTURE_DATE

Raz NBBPR, NBSEG, TOTVIR, DEVREG, DEVFAC
[C]EDIMES += 1 : NUMMES = [C]EDIMES
NBMESS += 1 
# Positionnement des classes [F] et calcul des variables utilisées dans les formules
# Adresse site (sinon société)
Read [BPA]BPA0 = 3;[F:FCY]FCY;[F:FCY]BPAADD
If fstat
  Read [BPA]BPA0 = 2;[F:CPY]CPY;[F:CPY]BPAADD
Endif
# Devise
Call LECTURE("TCU",[F:PYH]CUR,"") From CONTOBJ
DEVREG = [F:TCU]CUR  :# devise de règlement
# Variables
For [PY2]CLE Where DUDDAT=[F:PYH]DUDDAT & CUR=DEVREG
 TOTVIR += [F:PY2]AMTCUR
Next
GRPDEB=0 : GRPFIN=10
Gosub ECRIT_GRP From FICEDI
Return

$RUPTURE_TIERS
If GTRACE<>"" : Call ECR_TRACE(format$(GFMD,[F:PYH]DUDDAT)-"-"-[F:PYH]BPR,0) From GESECRAN : Endif
Raz TOTBPR, SIRET, SIRET_PE
NBBPR += 1
TIERSPAY = [F:PYH]BPR  :# Tiers payé
TIERS = TIERSPAY       :# Tiers bénéficiaire
Call LECTURE("BPR",TIERS,"") From CONTOBJ
SIRET = [F:BPR]CRN   :# SIRET du tiers

#Read [BPA]BPA0 = 1;TIERS;[F:BPR]BPAADD
If [F:PYH]SNS=1   # Dépense/Fournisseur  
 Call LECTURE("BPS",TIERS,"") From CONTOBJ
 Read [BPA]BPA0 = 1;[F:BPS]BPSNUM;[F:BPS]BPAADD
 If fstat : Raz [F:BPA] : Endif
Else              # Recette/Client
 Call LECTURE("BPC",TIERS,"") From CONTOBJ
 Read [BPA]BPA0 = 1;[F:BPC]BPCNUM;[F:BPC]BPAADD
 If fstat : Raz [F:BPA] : Endif
Endif  
If [F:BPA]BPANUM=""
 Read [BPA]BPA0 = 1;TIERS;[F:BPR]BPAADD
 If fstat : Raz [F:BPA] : Endif
Endif

# Le tiers payé est-il aussi le bénéficiaire ?
SIRET_PE = SIRET     :# Par défaut, le tiers payé est le bénéficiaire
Read [PD2]PYD0 = [F:PYH]NUM;1
If !fstat
  If [F:PD2]VCRNUM<>""
    Read [PIH]PIH0 = [F:PD2]VCRNUM
    If !fstat
      DEVFAC = [F:PIH]CUR
      If [F:PIH]BPR<>[F:PIH]BPRPAY
        TIERS = [F:PIH]BPR
        Call LECTURE("BPR",TIERS,"") From CONTOBJ
        SIRET = [F:BPR]CRN   :# SIRET du tiers
        #Read [BPA]BPA0 = 1;TIERS;[F:BPR]BPAADD
        If [F:PYH]SNS=1   # Dépense/Fournisseur  
         Call LECTURE("BPS",TIERS,"") From CONTOBJ
         Read [BPA]BPA0 = 1;[F:BPS]BPSNUM;[F:BPS]BPAADD
         If fstat : Raz [F:BPA] : Endif
        Else              # Recette/Client
         Call LECTURE("BPC",TIERS,"") From CONTOBJ
         Read [BPA]BPA0 = 1;[F:BPC]BPCNUM;[F:BPC]BPAADD
         If fstat : Raz [F:BPA] : Endif
        Endif  
        If [F:BPA]BPANUM=""
         Read [BPA]BPA0 = 1;TIERS;[F:BPR]BPAADD
         If fstat : Raz [F:BPA] : Endif
        Endif
        TIERSPAY = [F:PIH]BPRPAY
        Call LECTURE("BPR",TIERSPAY,"") From CONTOBJ
        SIRET_PE = [F:BPR]CRN   :# SIRET du tiers payé (ex: factor...)
        #Read [BPA2]BPA0 = 1;TIERSPAY;[F:BPR]BPAADD
        If [F:PYH]SNS=1   # Dépense/Fournisseur  
         Call LECTURE("BPS",TIERSPAY,"") From CONTOBJ
         Read [BPA2]BPA0 = 1;[F:BPS]BPSNUM;[F:BPS]BPAADD
         If fstat : Raz [F:BPA2] : Endif
        Else              # Recette/Client
         Call LECTURE("BPC",TIERSPAY,"") From CONTOBJ
         Read [BPA2]BPA0 = 1;[F:BPC]BPCNUM;[F:BPC]BPAADD
         If fstat : Raz [F:BPA2] : Endif
        Endif  
        If [F:BPA2]BPANUM=""
         Read [BPA2]BPA0 = 1;TIERSPAY;[F:BPR]BPAADD
         If fstat : Raz [F:BPA2] : Endif
        Endif
      Endif
    Endif
  Endif
Endif
For [PY2]CLE Where DUDDAT=[F:PYH]DUDDAT & CUR=DEVREG & BPR=TIERSPAY
 TOTBPR += [F:PY2]AMTCUR   :# Montant total pour ce tiers
Next
Raz MOYPAI   : # Moyen de paiement finançable (Z7 ou Z8)
GPOINT = "TIERS" : Gosub ENTREE From EXEFNC
If !find(MOYPAI,"Z7","Z8")  :# Z7 = remise finançable (crédit)
  MOYPAI = "Z8"
Endif
GRPDEB=11 : GRPFIN=16
Gosub ECRIT_GRP From FICEDI
Return

$RUPTURE_RGLT
If GTRACE<>"" : Call ECR_TRACE([F:PYH]NUM-"-"-format$("N:8.2",[F:PYH]AMTCUR),0) From GESECRAN : Endif
Raz SOMTOT
For [PYD]CLE(3) Where NUM=[F:PYH]NUM & ACCTYP<>2  :# Une facture
  Raz TYPFAC, FLFAC, NUMFAC, DOCUMENT, MNTFAC
  SOMTOT += [F:PYD]AMTLIN
  If [F:PYD]VCRNUM<>""
    Read [DUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
    Case [F:PYD]IPTTYP
      When 3  : # pièce comptable
        Read [PIH]PIH0 = [F:PYD]VCRNUM
        If fstat = 0
          FLFAC  = 1
          If [F:PIH]BPRVCR<>""
            NUMFAC  = [F:PIH]BPRVCR
          Else
            NUMFAC  = [F:PYD]VCRNUM
          Endif
          If [F:PIH]BPRDAT<>[0/0/0]
            DATFAC  = [F:PIH]BPRDAT 
          Else
            DATFAC  = [F:PIH]ACCDAT
          Endif
          MNTFAC = [F:PIH]AMTATI
          Case [F:PIH]INVTYP
            When 1,4 : TYPFAC = 1 : # Facture commerciale
            When 2,3 : TYPFAC = 2 : # Avoir
          Endcase
        Else
          Read [DAE]DAE2 = [F:PYD]DUDNUM
          If fstat=0
            Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
            FLFAC   = 1
            If [F:HAE]BPRVCR<>""
              NUMFAC  = [F:HAE]BPRVCR
            Else
              NUMFAC  = [F:HAE]NUM
            Endif
            If [F:HAE]BPRDATVCR<>[0/0/0]
              DATFAC  = [F:HAE]BPRDATVCR
            Else
              DATFAC  = [F:HAE]ACCDAT
            Endif
            MNTFAC = [F:DAE]AMTCUR
            If [F:DAE]SNS = +1 : TYPFAC=1 : Else : TYPFAC=2 : Endif
          Endif
        Endif

      When 2   : # commande fournisseur
        Read [POH]POH0 = [F:PYD]VCRNUM
        If fstat = 0
          FLFAC  = 2
          NUMFAC = [F:POH]POHNUM
          DATFAC = [F:POH]ORDDAT
          MNTFAC = [F:POH]TTVORD
          TYPFAC = 4 : # Paiement d'avance ?
        Endif
    Endcase
  Else
    FLFAC  = 2
    NUMFAC = [F:PYH]REF
    DATFAC = [F:PYH]ACCDAT
    MNTFAC = 0
    TYPFAC = 1
  Endif
  For [PYD]CLE(4) : # Un type d'imputation
   Case [F:PYD]ACCTYP
    When 1   :# Banque <=> Tiers
     For [PYD]CLE
      TOTREG += [F:PYD]AMTLIN2
      If [F:PYD]CURLIN<>[F:PYH]CUR : FLDEV = 1 : Endif
     Next
     If FLFAC
      MNTREG = 0
      For [PD2]PYD0 Where NUM=[F:PYH]NUM & ACCTYP<>2 & VCRNUM=[F:PYD]VCRNUM & VCRTYP=[F:PYD]VCRTYP
       Case [F:PD2]ACCSNS
        When 1,2 : MNTREG += [F:PD2]AMTLIN   :# sens du règlement, dépense
        When 3   : MNTREG -= [F:PD2]AMTLIN   :# recette
       Endcase
      Next
      If FLFAC=2
       MNTFAC = MNTREG
      Endif
      Gosub LIGNE_DOC
     Endif

    When 3   :# Compte <=> Tiers
     If [F:PYD]VCRNUM<>""
      MNTREG = [F:PYD]AMTLIN
      Case [F:PYD]ACCSNS
       When 1,2  :# sens règlement, dépense
        If MNTREG>0
         TYPFAC  = 2
        Else
         TYPFAC  = 1
         MNTREG = -MNTREG
        Endif
       When 3    :# recette
        If MNTREG>0
         TYPFAC  = 1
        Else
         TYPFAC  = 2
         MNTREG = -MNTREG
        Endif
      Endcase
      MNTFAC = MNTREG
      Gosub LIGNE_DOC
     Endif
   Endcase
  Next 
Next
Return

$LIGNE_DOC
Case TYPFAC
  When 1 : DOCUMENT = "380"  : # Facture commerciale
  When 2 : DOCUMENT = "381"  : # Avoir (note de crédit)
  When 3 : DOCUMENT = "383"  : # Note de débit
  When 4 : DOCUMENT = "386"  : # Facture d'acompte
  When 5 : DOCUMENT = "326"  : # Facture partielle
Endcase
If TIERS<>TIERSPAY : DOCUMENT = "393" : Endif   : # Facture affacturée
GRPDEB=17 : GRPFIN=22   # Détails des documents de la transaction
Gosub ECRIT_GRP From FICEDI
Return

$TR2
Call DEBTRANS From GLOCK
Trbegin [PYH], [FRM]
 For [PYH]PYH1 Where FRMFLG=[L]TYPBOR & FRMNUM=[L]NUMERO With Lock
  If fstat=1
   GOK = -1 : GLOCK = "$PAYMENTH"-"1"-[L]NUMERO : Break
  Endif
  [F:PYH]STA=max([F:PYH]STA,6) : [F:PYH]STAFLG(5)=2
  [F:PYH]TFBFIL=NOM+"."+EXT : [F:PYH]TFBDAT=[L]DATJ
  Rewrite [PYH]
  If fstat=1
   GOK = -1 : GLOCK = "$PAYMENTH"-"1"-[L]NUMERO : Break
  Elsif fstat
   GOK = 0 : Call RSTA("PYH","1"-[L]NUMERO) From GLOCK : Break
  Endif
 Next : # [PYH]
 If GOK<0    : Goto ROLL_TR2
 Elsif GOK=0 : Goto AB_TR2
 Endif 

 Readlock [FRM]FRM0 = [L]TYPBOR;[L]NUMERO
 If fstat=1
  GOK=-1 : GLOCK="$PAYFRM"-num$([L]TYPBOR)-[F:PYH]FRMNUM : Goto ROLL_TR2
 Endif
 [F:FRM]STA=max([F:FRM]STA,6) 
 [F:FRM]TFBFIL=NOM+"."+EXT : [F:FRM]TFBDAT=[L]DATJ
 Rewrite [FRM] 
 If fstat
  GOK = 0 : Call FSTA("FRM") From GLOCK : Goto AB_TR2
 Endif

Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$OUVRE
If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
If clalev([F:PY2])=0 : Local File PAYMENTH   [PY2] : Endif
If clalev([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
If clalev([F:PD2])=0 : Local File PAYMENTD   [PD2] : Endif
If clalev([F:FRM])=0 : Local File PAYFRM     [FRM] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY] : Endif
If clalev([F:TFB])=0 : Local File TABFILBAN  [TFB] : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPA2])=0 : Local File BPADDRESS [BPA2] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE  [TCH] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
If clalev([F:POH])=0 : Local File PORDER     [POH] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
Return

$DECLARE
Local Integer K, GROUPE, ORDRE, TYPFAC, FLFAC
Local Date    DAT, DATJ
Local Char    TIERS(GLONBPR), TIERSPAY(GLONBPR)            # hcb V6
Local Char    BANQUE(5)
Local Char    SYMBOLE(30), DEVFAC(3), DIR_FICBAN(GDIMFIC)

# Variables utilisées dans les formules
Local Integer NUMINT, NBMESS, NUMMES, NBBPR
Local Decimal TOTVIR, TOTBPR, TOTREG, MNTREG, MNTFAC, SOMTOT
Local Char    DEVREG(3), MOYPAI(2), SIRET(20), SIRET_PE(20), SIRET_DO(20), DOCUMENT(5), NUMFAC(15)
Local Date    DATFAC
Return

