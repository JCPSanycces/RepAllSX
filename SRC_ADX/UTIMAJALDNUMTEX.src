#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Initialisation de la table ALISTED
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Init ALISTED file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#
# Initialise field NUMTEX in table ALISTED (Bug 78943)
#----------------------------------------------------------------------------------------#

$MAJTAB

If DOSSIER=nomap
 Local File ALISTED [ALD]
Else
 Local File =DOSSIER+".ALISTED" [ALD]
Endif

If dim([F:ALD]NUMTEX)<0
 Return
Endif

Trbegin [ALD]
 For [ALD]
  If [F:ALD]NUMTEX = 0
   [F:ALD]NUMTEX = [F:ALD]LIG
   Rewrite [ALD]
   If fstat
    Call ERREUR("ALISTED"-num$([F:ALD]COD),3) From DOSDIC
   Endif
  Endif
 Next ALD
Commit

Close Local File [ALD]

Return


#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char    DOSSIER
 If DOSSIER<>  GDOSX3
  Gosub MAJTAB
 Endif
End
