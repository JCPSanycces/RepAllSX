#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TXC0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:58"
A_USER  = "DOC"
A_STAMP = "20181109230658"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TXC0 [TXC0]
Gosub HORODAT
Local Inpbox "TXC0" From GFONCTION At A_STAMP With A_WINDPREV Mask [TXC0] As [SIM_]
Grizo [TXC0]5
Grizo [TXC0]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TXC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=104 : Y1(0)=1 : Y2(0)=4
X1(1)=1 : X2(1)=104 : Y1(1)=5 : Y2(1)=28
Return

$ON_REFNUM
Return

$ON_ZREFNUM
Onevent BEFORE_AREA Gosub AV_ZREFNUM From W1TXC0
Return

$AV_ZREFNUM
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]REFNUM(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$ON_DESDOCCLA
Onevent BEFORE_AREA Gosub AV_DESDOCCLA From W1TXC0
Return

$AV_DESDOCCLA
## Action STD
Call AV_DESDOCCLA(zc) From SUBTXC
Gosub _AFF
Return

$ON_CTRNUM
Return

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1TXC0
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CODCLA
Onevent AFTER_AREA Call AP_CODCLA(zc) From W1TXC0
Return

Subprog AP_CODCLA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_CODCLA(VALEUR) From SUBTXC
If mkstat : GERR = 1 : GZONE = "CODCLA" : GZNUM = 20742 : Endif
Gosub _AFF
End

$ON_ZCODCLA
Onevent BEFORE_AREA Gosub AV_ZCODCLA From W1TXC0
Return

$AV_ZCODCLA
Call LECTEXTRA(zc,"CLACTR","DESCLA",num$([M]CODCLA(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_DESCLA
Onevent INIT_AREA Call D_DESCLA(zc) From W1TXC0
Return

Subprog D_DESCLA(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESCLA,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"CLACTR","DESCLA",[M]CODCLA,[M]LEG) From ATEXTRA
Endif
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1TXC0
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1TXC0
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


