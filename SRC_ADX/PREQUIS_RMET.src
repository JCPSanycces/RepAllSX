#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
$PSD_AREAD_AFTER
#Itmref
#Extrcpdat
#itmdes
#itmdes1
#prhfcy
#Puu
[L]ASTATUS = fmet this.ASETATTRIBUTE("ITMREF","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("EXTRCPDAT","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("ITMDES","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("ITMDES1","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("PRHFCY","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("PUU","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("QTYPUU","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("BPSNUM","$isDisabled", "true")
[L]ASTATUS = fmet this.ASETATTRIBUTE("EXTORDDAT","$isDisabled", "true")

Return

#######################################################################################
$ADDLINE_AFTER
  Local Integer CTX_BUYFLT(1)
 # if one line  :
  # PSHFCY no longer modifiable
  # if buyer filter is active, requester no longer modifiable
  If maxtab(this.PSD) = 1
    ASTATUS = fmet this.ASETATTRIBUTE("PSHFCY","$isDisabled","true")
    CTX_BUYFLT  = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "BUYFLT")
    If CTX_BUYFLT > 1
       ASTATUS = fmet this.ASETATTRIBUTE("REQUSR","$isDisabled","true")
    Endif
  Endif

Return

#######################################################################################
$ADELLINE_AFTER
  # if 0 line  :
  # PSHFCY is modifiable
  # requester is modifiable
  If maxtab(this.PSD) = 0
    ASTATUS = fmet this.ASETATTRIBUTE("PSHFCY","$isDisabled","false")
    ASTATUS = fmet this.ASETATTRIBUTE("REQUSR","$isDisabled","false")
  Endif
Return
