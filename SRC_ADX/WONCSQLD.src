Call TEXTE(4969,TITJOI(1)) From OBJDIV
Call TEXTE(7218,TITJOI(2)) From OBJDIV
Call TEXTE(19618,TITJOI(3)) From OBJDIV
TITJOI(4) = mess(59,100,1) : # Type
TITJOI(5) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Kf:20X"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "LA701f:15X"
End

