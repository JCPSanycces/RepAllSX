Call TEXTE(4948,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..1) , CLELIG(GLONAVA)
CLEPRIM = 'VCRNUM'
CLESEC(0) = 'VCRTYP'
CLESEC(1) = 'VCRLIN'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
NBCOND += 1
OPT(NBCOND)    = 'P'
CONDIT(NBCOND) = "[F:QLD]ITMREF=[M]PRODUCT"
Call TEXTE(19528,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(0,MESSAG(NBCOND)) From OBJDIV
NBCOND += 1
OPT(NBCOND)    = 'D'
CONDIT(NBCOND) = "[F:QLD]VCRNUM=[M:NCSH1]VCRNUM(indice)"
Call TEXTE(5169,LIBOPT(NBCOND)) From OBJDIV
Call TEXTE(0,MESSAG(NBCOND)) From OBJDIV
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(4969,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(5)(0..GNBDERNIER)
Local Char     A_BUF2(20)(0..GNBDERNIER)
Local Integer  A_BUF3(0..GNBDERNIER)
Local Char     A_BUF4(20)(0..GNBDERNIER)
Local Char     A_BUF5(10)(0..GNBDERNIER)
Local Char     A_BUF6(10)(0..GNBDERNIER)
Local Decimal  A_BUF7(0..GNBDERNIER)
If clalev([F:QLD9])>0 : Close Local File [QLD9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(5),
& Char     A_TAB2(20),
& Integer  A_TAB3,
& Char     A_TAB4(20),
& Char     A_TAB5(10),
& Char     A_TAB6(10),
& Decimal  A_TAB7
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7
& As [QLD9]
Return

$LEC_DERLU
Read [AFF]AFF0 = [F:QLD]STOFCY;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Read [QLH]QLH0=[F:QLD]VCRTYP;[F:QLD]VCRNUM
If fstat : Raz [F:QLH] : Endif
Return

$CHARGE_DERLU
If clalev([F:QLD9])>0
 Read [QLD9] = [F:QLD9]A_TABI
 [L]CLE = [F:QLD9]A_TABC
Endif
Return

$REMP_DERLU
Return

$CLE_DERLU
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 0
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:QLH]STOFCY"
Call TEXTE(1347,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:QLH]STOFCY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:QLH]VCRNUM"
Call TEXTE(7218,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:QLH]VCRNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:QLD]VCRLIN"
Call TEXTE(641,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 3
SELFMT(NBSEL) = "N:5F"
SELFOR(NBSEL) = "N:5#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:QLD]VCRLIN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:QLH]ITMREF"
Call TEXTE(3651,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:QLH]ITMREF"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:QLD]ECCVALMAJ"
Call TEXTE(44206,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:QLD]ECCVALMAJ"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:QLD]ECCVALMIN"
Call TEXTE(44208,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:QLD]ECCVALMIN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:QLD]QTYSTU"
Call TEXTE(4479,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 4
SELFMT(NBSEL) = "N:15F"
SELFOR(NBSEL) = "Nz:15F"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:QLD]QTYSTU"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:QLD_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:QLH])=0 : Local file STOQLYH [QLH] : Endif
Link [QLD] With
& [AFF]AFF0~=[F:QLD]STOFCY;GPROFIL;GUSRFCT,
& [QLH]QLH0=[F:QLD]VCRTYP;[F:QLD]VCRNUM
& As [QLD_]
Return

$DEFAUT_LISTE
Default file [QLD_]
Return

$OUVRE_JOIN
