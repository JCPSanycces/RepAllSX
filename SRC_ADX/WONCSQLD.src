Local Char     A_BUFJ5(80)(1..GNBSEL)
Local File(
& Libelle  A_TABJ1,
& Char     A_TABJ2(20),
& Integer  A_TABJ3,
& Char     A_TABJ4(15),
& Char     A_TABJ5(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5
& As [PCEJ]
Return

$TIT_JOIN
