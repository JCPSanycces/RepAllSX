#<AdxTL>@(#)0.0.0.0 $Revision$ TVA intracommunautaire
# Gestion du masque DCLEECVATBEL
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DCLEECVATBEL","DCLEECVATBEL",4,"XYDCLEECVATBEL") From GTRAITE
End

######################################################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH

  When "INIT"        : Gosub INIT
  When "DEBUT"       : Gosub DEBUT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "TERMINE"     : Gosub TERMINE
  When "SORTIE"      : Gosub SORTIE
  When "OK"          : FIN = 1 : GOK = 1
  When "END"         : FIN = 1 : GOK = 0
Endcase
Return

######################################################################################
$INIT
Gosub OPEN_FIL
Gosub DECLARE
Local Mask DCLEECVATBEL [DIA]
Raz [M:DIA]
Call INI
Call LECMEMO("STD","[M:DIA]","dcleecbel") From GMEMO
Return

######################################################################################
$OPEN_FIL
If !clalev([F:DLEB])  : Local File DCLEECVATBE  [DLEB]  : Endif
If !clalev([F:DLEB1]) : Local File DCLEECVATBE  [DLEB1] : Endif
If !clalev([F:DLEBD]) : Local File DCLEECVATBED [DLEBD] : Endif
If !clalev([F:TVT])   : Local File TABVAT       [TVT]   : Endif
If !clalev([F:TVB])   : Local File TABVACBPR    [TVB]   : Endif
If !clalev([F:TRA])   : Local File TABRATVAT    [TRA]   : Endif
If !clalev([F:GTE])   : Local File GTYPACCENT   [GTE]   : Endif
If !clalev([F:CPY])   : Local File COMPANY      [CPY]   : Endif
If !clalev([F:HAE])   : Local File GACCENTRY    [HAE]   : Endif
If !clalev([F:DAE])   : Local File GACCENTRYD   [DAE]   : Endif
If !clalev([F:SIH])   : Local File SINVOICE     [SIH]   : Endif
If !clalev([F:SIV])   : Local File SINVOICEV    [SIV]   : Endif
If !clalev([F:SID])   : Local File SINVOICED    [SID]   : Endif
If !clalev([F:GAC])   : Local File GACCOUNT     [GAC]   : Endif
If !clalev([F:BPR])   : Local File BPARTNER     [BPR]   : Endif
If !clalev([F:BPC])   : Local File BPCUSTOMER   [BPC]   : Endif
If !clalev([F:TCY])   : Local File TABCOUNTRY   [TCY]   : Endif
If !clalev([F:TCY1])  : Local File TABCOUNTRY   [TCY1]  : Endif
If !clalev([F:TCY2])  : Local File TABCOUNTRY   [TCY2]  : Endif
If !clalev([F:TCY3])  : Local File TABCOUNTRY   [TCY3]  : Endif
If !clalev([F:SOQ])   : Local File SORDERQ      [SOQ]   : Endif
If !clalev([F:POH])   : Local File PORDER       [POH]   : Endif
If !clalev([F:TCA])   : Local File TABCOUAFF    [TCA]   : Endif
If !clalev([F:FCY])   : Local File FACILITY     [FCY]   : Endif
If !clalev([F:BPA])   : Local File BPADDRESS    [BPA]   : Endif

If clalev([F:AOE])=0  : Local File AOBJEXT      [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD     [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR     [AOR]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE       [ATB]  : Endif
If clalev([M:AOE0])=0 : Local Mask AOE0         [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1         [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2         [AOE2] : Endif
If clalev([M:EXP1])=0 : Local Mask EXPOBJ       [EXP1] : Endif : # to load the template
If clalev([M:EXP2])=0 : Local Mask EXPOBJ2      [EXP2] : Endif : # Ecran référence (export + export enchaîné)
Return

######################################################################################
$DECLARE
Local Integer  STAT, OK
Local Char     VALPAR(GLONAOE)         : # To store the value of a parameter
Local Char     NUMIMP(8)               : # Request number
Local Char     COMPTEUR(GLONANM)       : # Counter that assigns the request number
Local Integer  OKTCA
Global Integer GNUMRPT                 : # Request number used to print
#
Local Integer  NBTAX                   : # Number of tax codes defined with tax/debits
Filter [TVT] Where VATPAY=1 & VATTYP=1
NBTAX = rowcount([F:TVT])
Filter [TVT]
Local Char     TTAX(GLONVAT)(1..NBTAX) : # List of the tax codes used when the tax is due /debits
#
Local Integer  NBTYP                   : # Number of document types (GTE) defined with tax/debits
Filter [GTE] Where VAT=2
NBTYP = rowcount([F:GTE])
Filter [GTE]
Local Char     TTYP(GLONGTE)(1..NBTYP) : # List of of document types (GTE) defined with tax/debits

Local Char     OPT(1)                  : # Take into account the "1"=accounting date or "2"=source document date
Local Char     OPE(1)                  : # Operation triangulaire
Local Char     CRITERE(250)            : # Criteria for [DAE]
Local Char     CRIT_BPC(250)           : # Criteria for [BPC]
Local Char     TCY(GLONCRY)            : # Delivery country
Local Char     SPE_CRITERE(250)        : # Specific criteria
Local Integer  SAVGPARTRABTC           : # The value of the GPARTRABTC parameter is saved
Local Char     BPRNAM1(GLONNAM)        : # Name of the customer
Local Char     BPRNAM2(GLONNAM)        : # Name of the customer
Local Char     EECNUM(GLONEEC)         : # VAT number
Local Char     OLDBPC(GLONBPC)         : # customer code
Local Integer  LIN_FCY                 : # displays a line in the log file after the forbidden sites

Local Integer  DEL_DLEBD               : # 1 to not take into account the journal entry and delete the lines in DCLVATBELD
Local Integer  ADD_DLEB                : # 1 if a line is added in DCLEECVATBED.Indicates that DCLEECVATBE must be updated
Local Decimal  SUM_AMTNOT(1..2)        : # Sum of amount by operation code for each journal entry
Local Char     LETOPECOD(1)(1..2)      : # List of th operation codes
LETOPECOD(1) = "S"
LETOPECOD(2) = "L"
Local Integer  DLVCRYOK                : #X3-29219 Delivery country not "BE" and EECFLG=G_OUI(2)

# These variables handle the loop breaks in order to avoid the "snapshot too old" error message
Local Char     KEYFCY(GLONFCY), KEYTYP(GLONGTE), KEYNUM(GLONVCR)
Local Integer  NB, STOP
Local Char    SAVE_BPC(GLONBPC)
Return

######################################################################################
$DEBUT
Affzo [DIA]
If GBATCH : Call INI : Endif
Call GRISE
Setmok [DIA] With 0
Return

######################################################################################
$CONTROLE
If GOK<1 : FIN = 1 : Return : Endif

Call LEC_CPY([M:DIA]CPY) From CPTLEC
GSOCIETE = [M:DIA]CPY
GCURLEG = [F:CPY]LEG
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV

Lock ="DCLEECVATBEL\"+GSOCIETE With lockwait=0
If fstat
 # Opération en cours sur autre poste
 GERR = 2 : GMESSAGE=mess(30,100,1)
 FIN = 1 : Return
Endif

Gosub READ_PARAM
If FIN=1 : Return : Endif

Gosub TRABTC

TMP = 1
Return

######################################################################################
$READ_PARAM
# Request number
COMPTEUR = ""
Call LECTCA(2,OKTCA)From SUBTCA
If OKTCA : COMPTEUR= [F:TCA]CODNUM(17) : Endif
If COMPTEUR="" : COMPTEUR = "EECVT" : Endif
Call NUMERO(COMPTEUR,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
If STAT
 Gosub MESSAGE From SUBANM
 Call ERREUR(mess(60,199,1)-"("+COMPTEUR+") : "-MESSA) From GESECRAN
 FIN = 1 : Return
Endif
GNUMRPT = val(NUMIMP)

Gosub LECPARAM_GTE
Gosub LECPARAM_TVT

# Accounting date or  source document date ?
Call PARAML(GSOCIETE,"DCLVATDAT",OPT) From ADOVAL

Call PARAML(GSOCIETE,"BELEECOPE",OPE) From ADOVAL

Return

######################################################################################
$LECPARAM_GTE
# Load the list of the  document types (GTE) defined with tax on issue
Filter [GTE] Where LEG=GCURLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
Raz NBTYP, TTYP
For [GTE]CLE(1)
 If [F:GTE]VAT=2
  NBTYP += 1
  TTYP(NBTYP) = [F:GTE]TYP
 Endif
Next
Filter [GTE]
Return

######################################################################################
$LECPARAM_TVT
Call PARAML(GSOCIETE,"DEPEXETAX", VALPAR) From ADOVAL
# Load the list of the tax code used when the tax is due as soon as the invoice is issued
Filter [TVT] Where LEG=GCURLEG | LEG="" Order By Key CLE=VAT Asc ; LEG Desc
Raz NBTAX, TTAX
For [TVT]CLE(1)
 If [F:TVT]VATPAY=1 & [F:TVT]VATTYP=1 & [F:TVT]VAT<>VALPAR
  NBTAX += 1
  TTAX(NBTAX) = [F:TVT]VAT
 Endif
Next
Filter [TVT]
Return

######################################################################################
$TRABTC
# To not display the log file "MASQUE_TRACE" managed by the supervisor in GTRAITE
If GSERVEUR=1 & dim(GPARTRABTC)>0
 SAVGPARTRABTC = GPARTRABTC
 GPARTRABTC = 1
Endif
Return

######################################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRCFLG = 2
 If dim(GPARTRABTC)>0
  GPARTRABTC = SAVGPARTRABTC
 Endif
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
 Call OUVRE_TRACE(mess(18,866,1)) From LECFIC
Endif
If [M:DIA]TRCFLG=2
 Call ECR_TRACE(mess(18,866,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 ## Display the criteria in the log file
 Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(38,114,1)-":"-num$(GNUMRPT),0) From GESECRAN
 Call ECR_TRACE(mess(26,113,1)-":"-[M:DIA]CPY,0) From GESECRAN
 Call ECR_TRACE(mess(374,107,1)-":"-mess([M:DIA]DCLPER,3657,1),0) From GESECRAN
 Call ECR_TRACE(mess(14,119,1)-":"-format$(GFMDAT,[M:DIA]STRDAT)-mess(95,100,1)-format$(GFMDAT,[M:DIA]ENDDAT),0) From GESECRAN
 Call ECR_TRACE(mess(55,100,1)-":"-mess([M:DIA]FLGFIL,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

# Delete in the tables
Call DEBTRANS From GLOCK
Gosub TR_DELDLV
If GOK<1 : Return : Endif

Link [BPC] With [F:BPR]BPR0~=[F:BPC]BPCNUM, [TCY2]TCY0=[F:BPR]CRY, [BPA]BPA0= "1";[F:BPC]BPCNUM, [TCY3]TCY0=[F:BPA]CRY
& As [LNK_B]
& Where [BPC]BPCSTA=2 & ([BPC]BPCTYP=2 | ([BPC]BPCTYP=1 & ([BPR]CRY<>"BE" & [TCY2]EECFLG=2) | ([BPA]CRY<>"BE" & [TCY3]EECFLG=2)))

# Run the declaration
Gosub DECLARATION

If GOK=1 & [M:DIA]FLGFIL=2
 # File generation
 Call PARAML(GSOCIETE, "BELEECAOE", VALPAR) From ADOVAL
 If VALPAR=""
  Call ECR_TRACE("BELEECAOE :"-mess(171,133,1),1) From GESECRAN
 Else
  Raz [M:EXP2]NOMEXP
  [M:EXP2] = [M:DIA]

  If [M:EXP2]TYPEXP=2
   [M:EXP2]NOMEXP = [M:DIA]FILDIRLOC
   If right$([M:EXP2]NOMEXP, len([M:EXP2]NOMEXP))<>"/" : [M:EXP2]NOMEXP += "/" : Endif
  Endif
  [M:EXP2]NOMEXP += "BEINTRA_" + num$(GNUMRPT) + "_" + num$(func DCLEECVATBEL.GET_MONTH([M:DIA]STRDAT, [M:DIA]ENDDAT)) + "-" + num$(func DCLEECVATBEL.GET_QUARTER([M:DIA]STRDAT, [M:DIA]ENDDAT)) + "-" +
& num$(year([M:DIA]ENDDAT))
  [M:EXP2]MODELE = VALPAR
  Filter [DLEB] Where NUMRPT = GNUMRPT
  If rowcount([DLEB])=0
   Call ECR_TRACE("0"-mess(82,141,1), 0) From GESECRAN
  Else
   Call EXPORTSIL From GEXPOBJ
   If [M:EXP2]STAT=0 and !GSERVEUR
    If [M:DIA]TYPEXP=1
     Call ECR_TRACE(mess(178,115,1)-[M:EXP2]NOMEXP, 0) From GESECRAN
    Else
     Call ECR_TRACE("|"+mess(14,9003,1)-[M:EXP2]NOMEXP, 0) From GESECRAN
    Endif
   Endif
  Endif
  Filter [DLEB]
 Endif
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
Endif

Return

######################################################################################
$TR_DELDLV
GOK = 1
Trbegin [DLEB],[DLEBD]
 # Delete the records existing for the company and overlaping the period defined by [M:DIA]STRDAT->[M:DIA]ENDDAT
 Filter [DLEB1] Where CPY=GSOCIETE & ENDDAT>=[M:DIA]STRDAT & STRDAT<=[M:DIA]ENDDAT
 For [DLEB1]DLEB0(2)
  Delete [DLEB] Where NUMRPT=[F:DLEB1]NUMRPT
  If fstat=1 | fstat>5
   GOK = 0 : Call RSTA("DLEB",GSOCIETE-num$([F:DLEB1]NUMRPT)) From GLOCK : Break
  Endif
  Delete [DLEBD] Where NUMRPT=[F:DLEB1]NUMRPT
  If fstat=1 | fstat>5
   GOK = 0 : Call RSTA("DLEBD",GSOCIETE-num$([F:DLEB1]NUMRPT)) From GLOCK : Break
  Endif
 Next
 Filter [DLEB1]
 If GOK<1 : Goto AB_TR_DELDLV : Endif
Commit
Return

$AB_TR_DELDLV
Rollback
Return

######################################################################################
$DECLARATION
Raz [L]LIN_FCY
If GUSRFCY<>"\" & [M:DIA]TRCFLG=2
 For [FCY] Where LEGCPY=GSOCIETE & FINFLG=2
  If !find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
   Call ECR_TRACE([F:FCY]FCY-":"-mess(63,133,1)-":"-mess(805,197,1),0) From GESECRAN
   [L]LIN_FCY = 1
  Endif
 Next
 If [L]LIN_FCY=1
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
Endif

Raz [L]SPE_CRITERE
GPOINT = "FILTER_DCLEEC" : Gosub ENTREE From EXEFNC
If [L]SPE_CRITERE="" : [L]SPE_CRITERE="1=1" : Endif

Raz SAVE_BPC, KEYFCY, KEYTYP, KEYNUM, STOP
Raz OLDBPC

$LOOP_01
Raz NB
Gosub FILTRE
Call DEBTRANS From GLOCK

Trbegin [DLEB], [DLEBD]

 For [LNK_B]BPC0(1) Where evalue(CRIT_BPC)
  Gosub DECL_LNK
  For [LNK_E]CLE(1) : # Site. Cannot put this line in CRITERE because of the find
   If GUSRFCY(1)="\" | find([F:DAE]FCYLIN,GUSRFCY(1..GNBAUZ))
    For [LNK_E]CLE(3) : # Journal entry
     If OLDBPC<>[F:BPC]BPCNUM & [M:DIA]TRCFLG=2
      OLDBPC = [F:BPC]BPCNUM
      Call ECR_TRACE(mess(358,107,1)-[F:BPC]BPCNUM,0) From GESECRAN
     Endif
     Gosub CHK_EECNUM
     If OK
      ## Checks that the delivery country is not Belgium but is an european country
      ## Le pays de livraison est européen et non Belge
      Raz [L]BPRNAM1,[L]BPRNAM2, [L]TCY
# X3-29219 FHA - start
# X3-29219 The delivery country and EECFLG should not be tested for "S" records ("Collected B&S")
# X3-29219 This test is moved into the line detail loop
      Raz DLVCRYOK                                          :# X3-29219 FHA
      Case [F:HAE]ORIMOD
       When 3 : # customer bp invoice
        If !fstat #& [F:BPR]CRY<>"BE" & [F:TCY2]EECFLG=2    :# X3-29219 FHA
         [L]TCY = [F:TCY2]CRY
        Else
         OK = 0
        Endif
        If [F:BPR]CRY <> "BE" & [F:TCY2]EECFLG = G_OUI      :# X3-29219 FHA
         [L]DLVCRYOK = 1                                    :# X3-29219 FHA
        Endif                                               :# X3-29219 FHA
        [L]BPRNAM1 = [F:BPR]BPRNAM(0)
        [L]BPRNAM2 = [F:BPR]BPRNAM(1)
       When 5 : # sale invoice
        If !fstat #& [F:SIV]BPDCRY<>"BE" & [F:TCY1]EECFLG=2 :# X3-29219 FHA
         [L]TCY = [F:TCY1]CRY
        Else
         OK = 0
        Endif
        If [F:SIV]BPDCRY <> "BE" & [F:TCY1]EECFLG = G_OUI   :# X3-29219 FHA
         [L]DLVCRYOK = 1                                    :# X3-29219 FHA
        Endif                                               :# X3-29219 FHA
        [L]BPRNAM1 = [F:SIH]BPRNAM(0)
        [L]BPRNAM2 = [F:SIH]BPRNAM(1)
      Endcase
# X3-29219 FHA - end
     Endif
     If OK
      Raz DEL_DLEBD, OK
      Raz SUM_AMTNOT,ADD_DLEB
      For [LNK_E]CLE # Journal entry lines
       Gosub CHK_ACCOUNT1
       If !OK : DEL_DLEBD = 1 : Break : Endif  :# Do not take into account the journal entry

       If [L]DLVCRYOK = 1                                   :# X3-29219 FHA Triangular behavior not to be changed
        If [F:HAE]ORIMOD=5 & OPE="2"
         Gosub CHK_TRIANG # Triangular transaction
         If !OK : DEL_DLEBD = 1 : Break : Endif :# Do not take into account the journal entry
        Endif
       Endif                                                :# X3-29219 FHA Triangular behavior not to be changed

# X3-29219 FHA - start
       Gosub CHK_B2B_B2C_DLVCRY :# If OK=0=>Do not take into account the journal entry line
# X3-29219 FHA - end
       If OK                                                :# X3-29219 FHA
        Gosub CHK_DELIVERY_TAX :# If OK=0=>Do not take into account the journal entry line
       Endif                                                :# X3-29219 FHA

       If OK
        Gosub CHK_ACCOUNT2    :# If OK=0=>Do not take into account the journal entry line
       Endif

       If OK
        Gosub TR_DLEBD
        If GOK<1 : STOP = 0 : Break 4 : Endif
        ADD_DLEB = 1
        If [F:DLEBD]OPECOD = "S"
         SUM_AMTNOT(1) += [F:DAE]AMTLED*[F:DAE]SNS*(-1)
        Else
         SUM_AMTNOT(2) += [F:DAE]AMTLED*[F:DAE]SNS*(-1)
        Endif
       Endif
       NB +=1
      Next
      If DEL_DLEBD=1 :# Do not take into account the journal entry
       Delete [DLEBD] Where CPY=GSOCIETE & NUMRPT=GNUMRPT & TYP=[F:DAE]TYP & NUM=[F:DAE]NUM
       If fstat=1 | fstat>5
        GOK = 0 : Call RSTA("DLEBD",GSOCIETE-num$(GNUMRPT)) From GLOCK : STOP = 0 : Break 3
       Endif
       NB +=1
      Elsif ADD_DLEB=1
       Gosub TR_DLEB
       If GOK<1 : STOP = 0 : Break 3 : Endif
       NB +=1
      Endif
      If NB>GMAXUPDTRS # CLE=[DAE]FCYLIN;[F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN
       KEYFCY = [F:DAE]FCYLIN
       KEYTYP = [F:DAE]TYP
       KEYNUM = [F:DAE]NUM
       STOP = 1
       Break 3
      Endif
     Endif
    Next
   Endif
  Next
  # To avoid looping to another customer before completely process all the invoices of the customer
  If STOP : Break  : Endif
  # To update the filter otherwise the filter on the FCYLIN stays
  If !STOP : Gosub FILTRE : Endif
 Next
 If GOK<=0 : Goto AB_TR_DLEB : Endif
Commit

If STOP
 SAVE_BPC = [F:BPC]BPCNUM
 Goto LOOP_01
Endif

Return

######################################################################################
$FILTRE
# An invoice is mono site
If STOP=1
 STOP = 2
 CRITERE  = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)+
&           " & [F:DAE]FCYLIN='"+KEYFCY+"' & [F:DAE]TYP='"+KEYTYP+"' & [F:DAE]NUM>'"+KEYNUM+"'"
 CRIT_BPC = "BPCNUM>='"+SAVE_BPC+"'"
Elsif STOP=2
 STOP = 3
 CRITERE  = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)+
&           " & [F:DAE]FCYLIN='"+KEYFCY+"' & [F:DAE]TYP>'"+KEYTYP+"'"
 CRIT_BPC = "BPCNUM>='"+SAVE_BPC+"'"
Elsif STOP=3
 STOP = 0
 CRITERE  = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)+
&           " & [F:DAE]FCYLIN>'"+KEYFCY+"'"
 CRIT_BPC = "BPCNUM>='"+SAVE_BPC+"'"
Else
 CRITERE  = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)
 CRIT_BPC = "BPCNUM>'"+SAVE_BPC+"'"
Endif

Return

######################################################################################
$DECL_LNK
If NBTYP+NBTAX<=50
 If OPT = "1" # Accounting date
  Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM, [TCY1]TCY0=[F:SIV]BPDCRY
&  As [LNK_E]
&  Where evalue(CRITERE) & evalue(SPE_CRITERE) & find([DAE]TYP,TTYP(1..NBTYP))<>0
&&       [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT
&&       find([F:DAE]TAX,TTAX(1..NBTAX))<>0
&&       [HAE]CAT=1
&&       [SIH]BPR=[F:BPC]BPCNUM
&    Order By Key CLE=[DAE]FCYLIN;[F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN
 Else
   Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM, [TCY1]TCY0=[F:SIV]BPDCRY
&  As [LNK_E]
&  Where evalue(CRITERE) & evalue(SPE_CRITERE) & find([DAE]TYP,TTYP(1..NBTYP))<>0
&&       (([HAE]BPRDATVCR>=[M:DIA]STRDAT & [HAE]BPRDATVCR<=[M:DIA]ENDDAT) | ([HAE]BPRDATVCR=[0/0/0] & [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT))
&&       find([F:DAE]TAX,TTAX(1..NBTAX))<>0
&&       [HAE]CAT=1
&&       [SIH]BPR=[F:BPC]BPCNUM
&    Order By Key CLE=[DAE]FCYLIN;[F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN
 Endif

Else

 If OPT = "1" # Accounting date
  Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM, [TCY1]TCY0=[F:SIV]BPDCRY
&  As [LNK_E]
&  Where evalue(CRITERE) & evalue(SPE_CRITERE) & find([DAE]TYP,TTYP(1..NBTYP))
&&       [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT
&&       find([F:DAE]TAX,TTAX(1..NBTAX))
&&       [HAE]CAT=1
&&       [SIH]BPR=[F:BPC]BPCNUM
&    Order By Key CLE=[DAE]FCYLIN;[F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN
 Else
   Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM, [TCY1]TCY0=[F:SIV]BPDCRY
&  As [LNK_E]
&  Where evalue(CRITERE) & evalue(SPE_CRITERE) & find([DAE]TYP,TTYP(1..NBTYP))
&&       (([HAE]BPRDATVCR>=[M:DIA]STRDAT & [HAE]BPRDATVCR<=[M:DIA]ENDDAT) | ([HAE]BPRDATVCR=[0/0/0] & [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT))
&&       find([F:DAE]TAX,TTAX(1..NBTAX))
&&       [HAE]CAT=1
&&       [SIH]BPR=[F:BPC]BPCNUM
&    Order By Key CLE=[DAE]FCYLIN;[F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN
 Endif
Endif
Return

######################################################################################
$CHK_EECNUM
Raz [L]EECNUM
OK = 1
Case [F:HAE]ORIMOD
 When 3 : # customer bp invoice
  If [F:BPR]EECNUM<>"" & left$([F:BPR]EECNUM,2)="BE"
   OK = 0
  Elsif [F:BPR]EECNUM=""
   [L]EECNUM = "XXXXX"
  Else
   [L]EECNUM = [F:BPR]EECNUM
  Endif
 When 5 : # sale invoice
  If [F:SIV]BPIEECNUM<>"" & left$([F:SIV]BPIEECNUM,2)="BE"
   OK = 0
  Elsif [F:SIV]BPIEECNUM=""
   [L]EECNUM = "XXXXX"
  Else
   [L]EECNUM = [F:SIV]BPIEECNUM
  Endif
Endcase
Return

# X3-29219 FHA - start
######################################################################################
# If account not "Collected B&S" (Not "S" record) : Delivery country and eecflg must be tested
# If account "Collected B&S" ("S" record) and BP is a Physical person : line shouldn't be considered
$CHK_B2B_B2C_DLVCRY
OK=1
If [F:GAC]VATIPT <> 8 :# If account not "Collected B&S" (Not S record) : Delivery country and eecflg must be tested
    If [L]DLVCRYOK = 0
     OK = 0
    Endif
Elsif [F:GAC]VATIPT = 8 & [F:BPR]LEGETT = G_OUI :# "Collected B&S" (S record) and Physical person : line not to be considered
    OK = 0
Endif
Return
# X3-29219 FHA - end

######################################################################################
## The type of the code tax is VAT and the invoice tax due=issued and the rule type for the tax rule is EU
## Le code taxe est de type TVA et de type débit et le régime de taxe des codes taxes est de type CEE.
$CHK_DELIVERY_TAX
OK = 1
Call LEC_TVT_LEG(GCURLEG,[F:DAE]TAX) From CPTLEC
If fstat | [F:TVT]VATTYP<>1 | [F:TVT]VATPAY<>1 # already check in the link
 OK = 0 : Return
Endif
Call LEC_TVB([F:TVT]LEG,[F:TVT]VATVAC) From CPTLEC
If fstat | [F:TVB]REGVAC<>4
 OK = 0 : Return
Endif
Return

######################################################################################
## Checks that the account is subjected and collected or company rules
## Compte soumis et collecté ou régul pour entreprise
$CHK_ACCOUNT1
OK = 1
If [F:GAC]FLGVAT<>2
 OK = 0
 If [M:DIA]TRCFLG=2
  # Message A
  Call ECR_TRACE(func AFNC.MES1(mess(371,107,1),[F:DAE]ACC)-mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM
&                -mess(136,105,1)-num$([F:DAE]LIN)-"-"-mess(375,107,1),1) From GESECRAN
 Endif
Endif
Return

$CHK_ACCOUNT2
OK = 1
If !find([F:GAC]VATIPT,1,2,7,8)
 OK = 0
 If [M:DIA]TRCFLG=2
  # Message B
  Call ECR_TRACE(func AFNC.MES1(mess(371,107,1),[F:DAE]ACC)-mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM
&                -mess(136,105,1)-num$([F:DAE]LIN), 1) From GESECRAN
 Endif
Endif
Return

######################################################################################
## Triangular operation
$CHK_TRIANG
OK = 1

## Conditions à remplir pour l'intervenant A (= émetteur de la facture) pour une opération triangulaire
# Site de facturation de la vente = Site belge
# Conditions required for A - who creates the sales invoice - to be a triangular operation
# Sales site in the invoice is a belgium site
Call LEC_FCY([F:SIH]FCY) From CPTLEC
If [F:FCY]CRY<>"BE" : Return : Endif
# Le N°TVA intracom de la société juridique du site est belge
# EU VAT number of the legal company of the site is belgium
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
If left$([F:CPY]EECNUM,2)<>"BE" : Return : Endif

## Conditions à remplir pour l'intervenant B (= client de la facture) pour une opération triangulaire
# Intervenant B a un N° de TVA intracom
# Conditions required for B - the customer - to be a triangular operation
# The EU VAT number is not empty
If [L]EECNUM = "XXXXX" : Return : Endif

## Conditions à remplir pour l'intervenant C (= fournisseur de la commande) pour une opération triangulaire
# Au moins une ligne de la facture est associée à une ligne de commande de vente de type contremarque directe
# Conditions required for C - the supplier - to be a triangular operation
# At least one invoice line is linked with a sale order line that generates a source for delivery
Link [SID] With [SOQ]SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
& As [LNK_S]
& Where [SID]NUM=[F:SIH]NUM & [F:SOQ]FMI=2 & [F:SOQ]FMINUM<>""  # Contremarque sur la commande de vente
For [LNK_S]
 # La contremarque renvoie à une commande fournisseur. Le fournisseur est dans un pays EU,non BE, et différent de l'intervenant B
 # Le fournisseur a un N° TVA intracom
 If [F:POH]POHNUM<>[F:SOQ]FMINUM
  Read [POH]POH0=[F:SOQ]FMINUM
 Endif
 If !fstat & [F:POH]BPOCRY<>'BE'& [F:POH]BPOCRY<>[F:SIV]BPDCRY & [F:POH]EECNUM<>""
  Call LEC_TCY([F:POH]BPOCRY) From CPTLEC
  If [F:TCY]EECFLG=2
   If [M:DIA]TRCFLG=2
    # Message C
    Call ECR_TRACE(mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-"-"-mess(376,107,1)-"-"-mess(375,107,1),1) From GESECRAN
   Endif
   OK = 0 : # triangular operation
   Break
  Endif
 Endif
Next
Return

######################################################################################
$TR_DLEBD
Raz [F:DLEBD]
[F:DLEBD]CPY    = GSOCIETE
[F:DLEBD]NUMRPT = GNUMRPT
[F:DLEBD]BPR    = [F:BPC]BPCNUM
[F:DLEBD]EECNUM = [L]EECNUM
[F:DLEBD]TYP    = [F:DAE]TYP
[F:DLEBD]NUM    = [F:DAE]NUM
[F:DLEBD]LIN    = [F:DAE]LIN
[F:DLEBD]CUR    = [F:DAE]CURLED
[F:DLEBD]AMTNOT = [F:DAE]AMTLED*[F:DAE]SNS*(-1)
[F:DLEBD]VAT    = [F:DAE]TAX

If [F:GAC]VATIPT=8
 [F:DLEBD]OPECOD = "S"
Else
 [F:DLEBD]OPECOD = "L"
Endif

If OPT="1"
 [F:DLEBD]ACCDAT = [F:DAE]ACCDAT
Else
 If [F:HAE]BPRDATVCR<>[0/0/0]
  [F:DLEBD]ACCDAT = [F:HAE]BPRDATVCR
 Else
  [F:DLEBD]ACCDAT = [F:DAE]ACCDAT
 Endif
Endif

Filter [TRA] Where CPY=GSOCIETE & VAT=[F:DAE]TAX & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If !fstat
 [F:DLEBD]VATRAT = [F:TRA]VATRAT
Elsif fstat>2
 # sinon on se rabat sur le code dossier
 Filter [TRA] Where CPY="" & VAT=[F:DAE]TAX & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
 Read [TRA]TRA0 Last
 If !fstat
  [F:DLEBD]VATRAT = [F:TRA]VATRAT
 Endif
Endif
Filter [TRA]

Write [F:DLEBD]
If fstat
 GOK=0 : Call FSTA("DLEBD") From GLOCK
Endif
Return

$AB_TR_DLEB
Rollback

######################################################################################
$TR_DLEB
For I=1 To 2
 If SUM_AMTNOT(I)<>0
  Readlock [DLEB]DLEB0=GSOCIETE;GNUMRPT;[F:BPC]BPCNUM;[L]EECNUM;LETOPECOD(I)
  If !fstat
   [F:DLEB]AMTNOT   += SUM_AMTNOT(I)
   Rewrite [F:DLEB]
   If fstat
    GOK=0 : Call FSTA("DLEB") From GLOCK : Break
   Endif
  Elsif fstat=1
   GOK=0 : Call FSTA("DLEB") From GLOCK : Break
  Else
   Raz [F:DLEB]
   [F:DLEB]CPY       = GSOCIETE
   [F:DLEB]NUMRPT    = GNUMRPT
   [F:DLEB]BPR       = [F:BPC]BPCNUM
   [F:DLEB]EECNUM    = [L]EECNUM
   [F:DLEB]OPECOD    = LETOPECOD(I)
   [F:DLEB]STRDAT    = [M:DIA]STRDAT
   [F:DLEB]ENDDAT    = [M:DIA]ENDDAT
   [F:DLEB]BPRNAM(0) = [L]BPRNAM1
   [F:DLEB]BPRNAM(1) = [L]BPRNAM2
   [F:DLEB]CRY       = [L]TCY
   [F:DLEB]CUR       = [F:DAE]CURLED
   [F:DLEB]AMTNOT    = SUM_AMTNOT(I)
   Write [F:DLEB]
   If fstat
    GOK=0 : Call FSTA("DLEB") From GLOCK : Break
   Endif
  Endif
 Endif
Next
Return

######################################################################################
$TERMINE
Local Integer NBPAR1
Local Char    TBPAR1(20)(1..10) , TBVAL1(50)(1..10)
Local Char    NAM_PRT(GLONADP)

# Print the report if no error occurs
If GOK=1
 If GSERVEUR=1
  # Batch
  NBPAR1 = 0
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "numrpt"        : TBVAL1(NBPAR1) = num$(GNUMRPT)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "impselections" : TBVAL1(NBPAR1) = num$(1)
  Call PARAML([M:DIA]CPY, "VATRPTBAT", NAM_PRT) From ADOVAL
  Call ETAT("DCLEECVATBEL1", NAM_PRT, "", 0, "", TBPAR1, TBVAL1) From AIMP3
 Else
  Call IMPRIME("DCLEECVATBEL1", "DCLEECVATBEL") From ETAT
 Endif
Endif

# Logfile
If !GSERVEUR & [M:DIA]TRCFLG=2
 TRA = 1
Else
 TRA = 0
Endif

Return

######################################################################################
$SORTIE
If dim(GNUMRPT)>0 : Kill GNUMRPT : Endif
# Unlock
Unlock ="DCLEECVATBEL\"+GSOCIETE
Return

#############################################################################
## BATCH
#############################################################################
$OUVRE_BATCH
Gosub OPEN_FIL
Gosub DECLARE
Return

######################################################################################
## DCLEECVATBEL screen
######################################################################################
Subprog GRISE
Actzo [DIA]
If [M:DIA]FLGFIL=1
 Grizo [DIA]TYPEXP, VOLFIL
Else
 Actzo [DIA]TYPEXP
 If [M:DIA]TYPEXP = 1 : Grizo [DIA]VOLFIL : Else Actzo [DIA]VOLFIL : Endif
Endif
Affzo [M:DIA]
End

Subprog INI
[M:DIA]FLGFIL = 2 : # File generation
If GBATCH : [M:DIA]TYPEXP = 2 : Else  : [M:DIA]TYPEXP = 1 : Endif
[M:DIA]TRCFLG = 2 : # Trace
End

######################################################################################
## Etiquette écran DCLEECVATBEL 25/11/2014
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
## Check that the BELVAT parameter is set to Yes
Call CTLCPYLEGVAT(VALEUR,"BEL") From DCLVATSTD
If mkstat=2 : End : Endif
GSOCIETE = VALEUR
End

######################################################################################
Subprog D_DCLPER(VALEUR)
Variable Integer VALEUR
Call INI_DCLPER(VALEUR)
End

Subprog AM_DCLPER(VALEUR)
Variable Integer VALEUR
Call INI_DCLPER(VALEUR)
End

Subprog INI_DCLPER(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : # Month
  If month(date$)=1
   [M]STRDAT = gdat$(1,12,year(date$)-1)
  Else
   [M]STRDAT = gdat$(1,month(date$)-1,year(date$))
  Endif
  [M]ENDDAT = eomonth([M]STRDAT)
 When 2 : # Quarter
  Call QUARTER(date$,[M]STRDAT,[M]ENDDAT,-1)
 When 3 : # Year
  [M]STRDAT = gdat$(1,1,year(date$)-1)
  [M]ENDDAT = gdat$(31,12,year(date$)-1)
Endcase
Affzo [M]STRDAT,ENDDAT
End

Subprog QUARTER(VDAT,DATSTR,DATEND,FLG)
Value    Date    VDAT
Variable Date    DATSTR
Variable Date    DATEND
Value    Integer FLG : # -1=Previous quarter / 1=Current quarter
If FLG=-1
 If month(VDAT)<=3
  DATSTR = gdat$(1,10,year(VDAT)-1)
  DATEND = gdat$(31,12,year(VDAT)-1)
 Elsif month(date$)>=4 & month(VDAT)<=6
  DATSTR = gdat$(1,1,year(VDAT))
  DATEND = gdat$(31,3,year(VDAT))
 Elsif month(date$)>=7 & month(VDAT)<=9
  DATSTR = gdat$(1,4,year(VDAT))
  DATEND = gdat$(30,6,year(VDAT))
 Else
  DATSTR = gdat$(1,7,year(VDAT))
  DATEND = gdat$(30,9,year(VDAT))
 Endif
Else
 If month(VDAT)<=3
  DATSTR = gdat$(1,1,year(VDAT))
  DATEND = gdat$(31,3,year(VDAT))
 Elsif month(date$)>=4 & month(VDAT)<=6
  DATSTR = gdat$(1,4,year(VDAT))
  DATEND = gdat$(30,6,year(VDAT))
 Elsif month(date$)>=7 & month(VDAT)<=9
  DATSTR = gdat$(1,7,year(VDAT))
  DATEND = gdat$(30,9,year(VDAT))
 Else
  DATSTR = gdat$(1,10,year(VDAT))
  DATEND = gdat$(31,12,year(VDAT))
 Endif
Endif
End

######################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Date DAT1
Case [M]DCLPER
 When 1 : # Month
  VALEUR    = gdat$(1,month(VALEUR),year(VALEUR))
  [M]ENDDAT = eomonth(VALEUR)
 When 2 : # Quarter
  DAT1 = VALEUR
  Call QUARTER(DAT1,VALEUR,[M]ENDDAT,1)
 When 3 : # Year
  VALEUR    = gdat$(1,1,year(VALEUR))
  [M]ENDDAT = gdat$(31,12,year(VALEUR))
Endcase
End

######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local Date DAT1
Case [M]DCLPER
 When 1 : # Month
  VALEUR    = eomonth(VALEUR)
  [M]STRDAT = gdat$(1,month(VALEUR),year(VALEUR))
 When 2 : # Quarter
  DAT1 = VALEUR
  Call QUARTER(DAT1,[M]STRDAT,VALEUR,1)
 When 3 : # Year
  VALEUR    = gdat$(31,12,year(VALEUR))
  [M]STRDAT = gdat$(1,1,year(VALEUR))
Endcase
Affzo [M]STRDAT
End

######################################################################################
Subprog C_FLGFIL(VALEUR)
Variable Integer VALEUR
Call C_FLGFIL(VALEUR) From DCLCUSVATBEL
End

######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
Call C_TYPEXP(VALEUR) From DCLCUSVATBEL
End

######################################################################################
Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Char FILNAM(GDIMFIC)
If VALEUR=""
 Call PARAML(GSOCIETE,"BELEECFIL",FILNAM) From ADOVAL
 If FILNAM=""
  VALEUR = "["+GDIRDEC+"]"
 Else
  VALEUR = FILNAM
 Endif
Endif
End

######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FILDIRLOC,E_TYPE_FOLDER,GMESSAGE)
End

######################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
OK=1
If PARAM="BELEECFIL" and VALEUR<>""
 Local Char TMP(250)
 Gosub ENUM_VOLFIL_TYPE From ASYRSTO
 If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
  OK = 0 : End
 Endif
Endif
End

Funprog GET_QUARTER(STRDAT, ENDDAT)
Value Date STRDAT, ENDDAT
If month(ENDDAT)-month(STRDAT)=2
 End int(month(STRDAT)/3+1)
Else
 End 0
Endif

Funprog GET_MONTH(STRDAT, ENDDAT)
Value Date STRDAT, ENDDAT
If month(STRDAT)=month(ENDDAT)
 End month(STRDAT)
Else
 End 0
Endif

