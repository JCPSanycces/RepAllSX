#ANCOA - 2017-09-28 - X3-57912 - START
#**
#* <pre>Return the requested value of contribution fund assigned to legislation/company/organisation
#* Note: only returns decimal values
#* </pre>
#*
#* @param LEGISLATION Legislation to check for e.g. "BRI"
#* @param COMPANY Company to check for
#* @param ORGANISATION Organisation to check for
#* @param VAL_TO_RETURN Value to return can be CAI to return the position
#* @return Returns the value requested (decimals only)
#*!
Funprog GET_FUND_DATA (LEGISLATION, COMPANY, ORGANISATION, VAL_TO_RETURN)
  Value Char LEGISLATION, COMPANY, ORGANISATION, VAL_TO_RETURN
  Local Decimal RETVAL

  If clalev([F:PCA]) = 0 : Local File CAISSE [PCA] : Endif
  Filter [PCA] Where [PCA]LEG = [L]LEGISLATION and [PCA]CPY = [L]COMPANY
  Read [PCA] Last
  Filter [PCA]

  If find(ORGANISATION,[F:PCA]ORG) > 0
    If VAL_TO_RETURN = "CAI"
      RETVAL = find(ORGANISATION,[F:PCA]ORG)
    Else
      RETVAL = evalue("[F:PCA]" + VAL_TO_RETURN + "(find(ORGANISATION,[F:PCA]ORG)-1)")
    Endif
  Endif
End RETVAL
#**
#* Return the requested value of contribution fund assigned to Employee contract
#*
#* @param ORGANISATION
#* @param EMPID
#* @param CONTRACT
#* @param CONTRACT_DATE
#* @param PERIOD_END_DATE
#* @param VAL_TO_RETURN
#* @return Returns the value requested (decimals only)
#*!
Funprog GET_CTRFUND_DATA(ORGANISATION, EMPID, CONTRACT, CONTRACT_DATE, PERIOD_END_DATE, VAL_TO_RETURN)
  Value Char EMPID, CONTRACT, ORGANISATION, VAL_TO_RETURN
  Value Date CONTRACT_DATE, PERIOD_END_DATE
  Local Decimal RETVAL

  If clalev([F:HRCTR]) = 0 : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:CTRPEN]) = 0 : Local File HRUKCTRPEN [CTRPEN] : Endif

  Link [F:CTRPEN] With [F:HRCTR]CTR0=REFNUM;CTRNUM;CTRDAT
&                   As [LNK]
&                Where REFNUM=[L]EMPID and CTRNUM=[L]CONTRACT and CTRDAT=CONTRACT_DATE
&                  and ORG=[L]ORGANISATION and [F:CTRPEN]PENJONDAT <= PERIOD_END_DATE
&                  and ([F:CTRPEN]PENXITDAT = [0/0/0] or PERIOD_END_DATE <= [F:CTRPEN]PENXITDAT)
  Read [LNK] Last
  If !fstat
    Case VAL_TO_RETURN
      When "EMEPRC", "EMRPRC"
        RETVAL = evalue("[F:CTRPEN]" + VAL_TO_RETURN)
      When Default
        RETVAL = func GET_FUND_DATA (GCURLEG, func DIVPAYE.GETSOC([F:HRCTR]ETRFCY), ORGANISATION, VAL_TO_RETURN)
    Endcase
  Endif
  Filter [LNK]
End RETVAL
#ANCOA - 2017-09-28 - X3-57912 - END

#**
#* Function to determine if the employee is enrolled:
#*
#* @param EMPLOYEE Employee reference to use for checking
#* @param CONTRACT Contract number to use for checking
#* @param CONTRACT_DATE Contract start date
#* @param PAY_DATE Payroll pay date
#* @param POSTPONEMENT_MONTHS
#* @param POSTPONEMENT_WEEKS
#* @param EARNINGS
#* @param EARNINGS_TRIGGER_MONTH
#* @param EARNINGS_TRIGGER_WEEK
#* @return Returns 1 if the employee is enrolled, 0 if not
#*
#*!
Funprog ENROLL_EMPLOYEE (EMPLOYEE, CONTRACT, CONTRACT_DATE, PAY_DATE, POSTPONEMENT_MONTHS, POSTPONEMENT_WEEKS, EARNINGS, EARNINGS_TRIGGER_MONTH, EARNINGS_TRIGGER_WEEK)
  Value Char EMPLOYEE, CONTRACT
  Value Date CONTRACT_DATE, PAY_DATE
  Value Decimal EARNINGS, EARNINGS_TRIGGER_MONTH, EARNINGS_TRIGGER_WEEK
  Value Integer POSTPONEMENT_MONTHS, POSTPONEMENT_WEEKS

  Local Integer RETVAL, PAY_FREQ : RETVAL = 0
  Local Char COMPANY(30)
  Local Date WRKPOSENDDAT

  If clalev([CTR1])    = 0 : Local File EMPLOCTR [CTR1]    : Endif
  If clalev([CTRUK1])  = 0 : Local File EMPLOCTRUKI [CTRUK1]  : Endif
#ALHAR - X3-90798 - 14/05/2018 - Start
#  If clalev([EMP1])    = 0 : Local File EMPLOID [EMP1]       : Endif
  If clalev([EMPAH])    = 0 : Local File EMPLOID [EMPAH]       : Endif
#ALHAR - X3-90798 - 14/05/2018 - End

  Read [CTR1]CTR0 = EMPLOYEE;CONTRACT;CONTRACT_DATE
  If fstat : End 0 : Endif

  Read [CTRUK1]CTRUKI0 = EMPLOYEE;CONTRACT;CONTRACT_DATE
  If fstat : End 0 : Endif

#ALHAR - X3-90798 - 14/05/2018 - Start
#  Read [EMP1]ID0 = EMPLOYEE
  Read [EMPAH]ID0 = EMPLOYEE
#ALHAR - X3-90798 - 14/05/2018 - End
  If fstat : End 0 : Endif

  [L]COMPANY = func DIVPAYE.GETSOC([F:CTR1]ETRFCY)

  If func OPT_IN_NOTICE_CHECK(EMPLOYEE, CONTRACT, CONTRACT_DATE, PAY_DATE)
   [L]RETVAL = 1
  Else
    [L]PAY_FREQ = func UK_FUNCTIONS.GET_PAY_FREQUENCY([CTR1]PERCOD)
    [L]WRKPOSENDDAT = func GET_WORKER_POSTPONEMENT_ENDDATE(EMPLOYEE, CONTRACT, CONTRACT_DATE, PAY_DATE)

#ALHAR - X3-90798 - 14/05/2018 - Start
#    If func STAGING_DATE_CHECK(COMPANY,PAY_DATE) = 1 &
#&      func REENROL_DATE_CHECK(COMPANY,PAY_DATE) = 1 &
#&      func POSTPONEMENT_ENDED_CHECK([F:CTR1]DATANC,[L]WRKPOSENDDAT, POSTPONEMENT_MONTHS,POSTPONEMENT_WEEKS,PAY_DATE,[L]PAY_FREQ) = 1 &
#&      func ELIGIBLE_AGE_CHECK([F:EMP1]DATBRN,PAY_DATE,[F:EMP1]SEX) = 1 &
#&      func EARNINGS_CHECK (EARNINGS, EARNINGS_TRIGGER_MONTH, EARNINGS_TRIGGER_WEEK, PAY_FREQ) = 1 &
#&      [F:CTRUK1]EXCFRMAUTENR <> 2 &
#&      func OPT_OUT_NOTICE_CHECK(EMPLOYEE, CONTRACT, CONTRACT_DATE,PAY_DATE) = 0
#AH
    If func STAGING_DATE_CHECK(COMPANY,PAY_DATE) = 1 &
&      func REENROL_DATE_CHECK(COMPANY,PAY_DATE) = 1 &
&      func POSTPONEMENT_ENDED_CHECK([F:CTR1]DATANC,[L]WRKPOSENDDAT, POSTPONEMENT_MONTHS,POSTPONEMENT_WEEKS,PAY_DATE,[L]PAY_FREQ) = 1 &
&      func ELIGIBLE_AGE_CHECK([F:EMPAH]DATBRN,PAY_DATE,[F:EMPAH]SEX) = 1 &
&      func EARNINGS_CHECK (EARNINGS, EARNINGS_TRIGGER_MONTH, EARNINGS_TRIGGER_WEEK, PAY_FREQ) = 1 &
&      [F:CTRUK1]EXCFRMAUTENR <> 2 &
&      func OPT_OUT_NOTICE_CHECK(EMPLOYEE, CONTRACT, CONTRACT_DATE,PAY_DATE) = 0
#ALHAR - X3-90798 - 14/05/2018 - End
      [L]RETVAL = 1
    Endif
  Endif

End [L]RETVAL

#**
#* Function to determine if Jobholder opt in notice has been received prior to pay date
#*
#* @param EMPLOYEE Employee to check
#* @param CONTRACT Contract number to check
#* @param CONTRACT_DATE Contract date to check
#* @param PAY_DATE Pay date
#* @return Returns 1 if opt in notice received prior to the pay date, 0 otherwise
#*!
Funprog OPT_IN_NOTICE_CHECK(EMPLOYEE, CONTRACT, CONTRACT_DATE, PAY_DATE)
  Value Char EMPLOYEE, CONTRACT
  Value Date CONTRACT_DATE, PAY_DATE
  Local Integer RETVAL

  If clalev([F:HRCTR1]) = 0 : Local File EMPLOCTR [HRCTR1] : Endif
  If clalev([F:CTRPEN1]) = 0 : Local File HRUKCTRPEN [CTRPEN1] : Endif

  Link [F:CTRPEN1] With [F:HRCTR1]CTR0=REFNUM;CTRNUM;CTRDAT
&                   As [LNK]
&                Where REFNUM=EMPLOYEE and CTRNUM=CONTRACT and CTRDAT=CONTRACT_DATE
&                  and [F:CTRPEN1]PENJONDAT <= PAY_DATE
&                  and ([F:CTRPEN1]PENXITDAT = [0/0/0] or PAY_DATE <= [F:CTRPEN1]PENXITDAT)
  Read [LNK] Last

  If fstat : End 0 : Endif

  If [F:CTRPEN1]OPTNOTRCV <> [00/00/00] and [F:CTRPEN1]OPTNOTRCV <= PAY_DATE
    [L]RETVAL = 1
  Endif

End [L]RETVAL

#**
#* Function to determine if Valid opt out notice to employer has been received prior to pay date
#*
#* @param EMPLOYEE Employee to check
#* @param CONTRACT Contract number to check
#* @param CONTRACT_DATE Contract date to check
#* @param PAY_DATE Pay date
#* @return Returns 1 if opt out notice received prior to the pay date, 0 otherwise
#*!
Funprog OPT_OUT_NOTICE_CHECK(EMPLOYEE, CONTRACT, CONTRACT_DATE, PAY_DATE)
  Value Char EMPLOYEE, CONTRACT
  Value Date CONTRACT_DATE, PAY_DATE
  Local Integer RETVAL

  If clalev([F:HRCTR1]) = 0 : Local File EMPLOCTR [HRCTR1] : Endif
  If clalev([F:CTRPEN1]) = 0 : Local File HRUKCTRPEN [CTRPEN1] : Endif

  Link [F:CTRPEN1] With [F:HRCTR1]CTR0=REFNUM;CTRNUM;CTRDAT
&                   As [LNK]
&                Where REFNUM=EMPLOYEE and CTRNUM=CONTRACT and CTRDAT=CONTRACT_DATE
&                  and [F:CTRPEN1]PENJONDAT <= PAY_DATE
&                  and ([F:CTRPEN1]PENXITDAT = [0/0/0] or PAY_DATE <= [F:CTRPEN1]PENXITDAT)
  Read [LNK] Last

  If fstat : End 0 : Endif

  If [F:CTRPEN1]OPTOUTNOTEMR <> [00/00/00] and [F:CTRPEN1]OPTOUTNOTEMR <= PAY_DATE
    [L]RETVAL = 1
  Endif
End [L]RETVAL

Funprog GET_WORKER_POSTPONEMENT_ENDDATE (EMPLOYEE, CONTRACT, CONTRACT_DATE, PAY_DATE)
  Value Char EMPLOYEE, CONTRACT
  Value Date CONTRACT_DATE, PAY_DATE
  Local Date RETVAL

  If clalev([F:HRCTR1]) = 0 : Local File EMPLOCTR [HRCTR1] : Endif
  If clalev([F:CTRPEN1]) = 0 : Local File HRUKCTRPEN [CTRPEN1] : Endif

  Link [F:CTRPEN1] With [F:HRCTR1]CTR0=REFNUM;CTRNUM;CTRDAT
&                   As [LNK]
&                Where REFNUM=EMPLOYEE and CTRNUM=CONTRACT and CTRDAT=CONTRACT_DATE
&                  and [F:CTRPEN1]PENJONDAT <= PAY_DATE
&                  and ([F:CTRPEN1]PENXITDAT = [0/0/0] or PAY_DATE <= [F:CTRPEN1]PENXITDAT)
  Read [LNK] Last

  If fstat : End [00/00/0000] : Endif

  [L]RETVAL = [F:CTRPEN1]WRKPOSENDDAT

End [L]RETVAL
#**
#* <pre>Function to check whether an employee age makes them eligible for auto-enrolment,
#* i.e. that are aged between 22 and state pension age (SPA)</pre>
#*
#* @param DATE_OF_BIRTH Birth date of the employe
#* @param DATE_TO_CHECK The date upon which to check the employee age, if not supplied todays date is assumed
#* @param GENDER Employee Gender 1=Male, 2=Female. Any other value means SPA cannot be calculated to return value will be 0
#* @return Returns 1 if employee meets the age check criteria, 0 if not
#*!
Funprog ELIGIBLE_AGE_CHECK (DATE_OF_BIRTH, DATE_TO_CHECK, GENDER)
  Value Date DATE_OF_BIRTH
  Value Date DATE_TO_CHECK
  Value Integer GENDER
  Local Integer AGE_IN_YEARS, RETVAL : RETVAL = 0

  If DATE_TO_CHECK = [00/00/00] : DATE_TO_CHECK = date$ : Endif

  If GENDER = 1 or GENDER = 2
    [L]AGE_IN_YEARS = func SUBCTRUKI.CALCULATEAGE(DATE_OF_BIRTH, DATE_TO_CHECK)

    If [L]AGE_IN_YEARS >= 22 and DATE_TO_CHECK < func SUBCTRUKI.RETIREMENTDATE(DATE_OF_BIRTH, GENDER)
      [L]RETVAL = 1
    Endif
  Endif
End [L]RETVAL

#**
#* Function to determine if the company staging date has been set, and if it is less than or equal to pay date
#*
#* @param COMPANY Company to check
#* @param PAY_DATE Pay date
#* @return Returns 1 if the staging date criteria is met, 0 if not
#*!
Funprog STAGING_DATE_CHECK (COMPANY, PAY_DATE)
  Value Char COMPANY
  Value Date PAY_DATE
  Local Integer RETVAL : RETVAL = 0

  If clalev([CPYUKI1])    = 0  : Local File HRCOMPANYUKI [CPYUKI1]    :  Endif

  Read [CPYUKI1]CPYUKI0 = COMPANY
  If !fstat & [CPYUKI1]CMPSTGDAT <> [00/00/00] & [CPYUKI1]CMPSTGDAT <= PAY_DATE
    [L]RETVAL = 1
  Endif
End [L]RETVAL

