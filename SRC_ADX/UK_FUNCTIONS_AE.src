#**
#* Function to determine if the postponement end date has expired. Postponement is n months after an employee has joined the company
#*
#* @param START_DATE Date employee joined the company
#* @param POSTPONEMENT_END Employee override for postponement end date, if populated this will be used to test against
#* @param POSTPONEMENT_MONTHS number of months to postpone after start date
#* @param POSTPONEMENT_WEEKS number of weeks to postpone after start date
#* @param PAY_DATE Pay date
#* @param PAY_FREQUENCY 6 for monthly, 1 for weekly
#* @return 1 if the postponement end date is less than pay date, 0 otherwise
#*!
Funprog POSTPONEMENT_ENDED_CHECK (START_DATE, POSTPONEMENT_END, POSTPONEMENT_MONTHS, POSTPONEMENT_WEEKS, PAY_DATE, PAY_FREQUENCY)
  Value Date START_DATE, PAY_DATE, POSTPONEMENT_END
  Value Integer POSTPONEMENT_MONTHS, POSTPONEMENT_WEEKS
  Local Integer RETVAL : RETVAL = 0
  Local Date CHECK_DATE

  If POSTPONEMENT_END <> [00/00/00]
    [L]CHECK_DATE = POSTPONEMENT_END
  Else
    [L]CHECK_DATE = func CALC_DEFAULT_POSTPONEMENT_END(START_DATE,POSTPONEMENT_MONTHS, POSTPONEMENT_WEEKS, PAY_FREQUENCY)
  Endif

  If [L]CHECK_DATE <> [00/00/00] and [L]CHECK_DATE < PAY_DATE
    [L]RETVAL = 1
  Endif
End [L]RETVAL

#**
#* Function to calculate the default postponement end date
#*
#* @param START_DATE Date employee joined the company
#* @param POSTPONEMENT_MONTHS Number of months to postpone for monthly payrolls
#* @param POSTPONEMENT_WEEKS Number of weeks to postpone for weekly payrolls
#* @param PAY_FREQUENCY 6 for monthly, 1 for weekly
#*!
Funprog CALC_DEFAULT_POSTPONEMENT_END(START_DATE, POSTPONEMENT_MONTHS, POSTPONEMENT_WEEKS, PAY_FREQUENCY)
  Value Date START_DATE
  Value Integer POSTPONEMENT_MONTHS, POSTPONEMENT_WEEKS
  Local Date RETVAL

  Case PAY_FREQUENCY
    When 1 : [L]RETVAL = START_DATE + (POSTPONEMENT_WEEKS * 7)
    When 6 : [L]RETVAL = addmonth(START_DATE,POSTPONEMENT_MONTHS)
  Endcase
End [L]RETVAL

#**
#* Function to check if the earnings exceed the earnings threshold
#*
#* @param EARNINGS Earnings for period
#* @param EARNINGS_TRIGGER_MONTH Monthly earnings trigger
#* @param EARNINGS_TRIGGER_WEEK Weekly earnings trigger
#* @param PAY_FREQUENCY 6 to check against monthly trigger, 1 for weekly trigger
#* @return 1 if the earings threshold is exceed, 0 otherwise
#*!
Funprog EARNINGS_CHECK (EARNINGS, EARNINGS_TRIGGER_MONTH, EARNINGS_TRIGGER_WEEK, PAY_FREQUENCY)
  Value Decimal EARNINGS, EARNINGS_TRIGGER_MONTH, EARNINGS_TRIGGER_WEEK
  Value Integer PAY_FREQUENCY
  Local Integer RETVAL : RETVAL = 0

  Case PAY_FREQUENCY
    When 1
      If EARNINGS > EARNINGS_TRIGGER_WEEK
        [L]RETVAL = 1
      Endif
    When 6
      If EARNINGS > EARNINGS_TRIGGER_MONTH
        [L]RETVAL = 1
      Endif
  Endcase
End [L]RETVAL

#**
#* Function to determine the number of periods for postponement for a given pay frequency
#*
#* @param PAY_FREQUENCY 6 for monthly, 1 for weekly
#* @param COMPANY Company code to check
#* @return Returns number of periods for postponement. If parameters are not setup then default for monthly is 3 and weekly is 12
#*!
Funprog GET_POSTPONEMENT_PERIODS(PAY_FREQUENCY, COMPANY)
  Value Integer RETVAL : RETVAL = 0
  Local File VALEUR [VLA1], VALCPY [VCP1]
  Local Char VAR_CODE

  # Set the default return values
  Case PAY_FREQUENCY
    When 1
      [L]VAR_CODE = "POST_W"
      [L]RETVAL = 12
    When 6
      [L]VAR_CODE = "POST_M"
      [L]RETVAL = 3
  Endcase

  # Check if company has a value set up
  Filter [VCP1] Where CPY=COMPANY
  Read [VCP1]VCP0 Last
  Filter [VCP1]
  If !fstat
    Read[VLA1]VLA0=2;"";[F:VCP1]CPY;"";"";[F:VCP1]DAT;VAR_CODE
    If !fstat
      [L]RETVAL=[VLA1]VARVAL
    Endif
  Endif

End [L]RETVAL

