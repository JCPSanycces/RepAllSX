#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################################
# UTITRC06   Utility to copy automatically Graphical query tool (ALT),  Statistical parameters (PS2)      #
#            Dashboard views (APV)                                                                        #
#            when they don't exist or when they exist but are not protected by an activity code           #
# (due to the fact that in a folder with existing data the mecanic of the supervisor doesn't copy         #
# the news elements/news setting. The copy exists only if the folder is created or if [f:ADK]INSTALL <> 2)#
###########################################################################################################
# Issue 111940 - 20151028 by LD : Mobility U9 and migration folder

Local Char DOSSIER(30)

  DOSSIER=nomap
  #Call SAIDOS(DOSSIER,"UTITRC06") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"UTITRC06") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTITRC06") From LECFIC
    Call MAJ_UTITRC06(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITRC06(DOSSIER)
Value Char DOSSIER

  Call ECR_TIME("UTITRC06 : Start folder's process"-DOSSIER) From DOSSUB
  #
  Call ECR_TIME("UTITRC06 Graphical query tool (ALT) Process   : --- Step 1") From DOSSUB
  Gosub TRTALT
  #
  Call ECR_TIME("UTITRC06 Statistical parameters (PS2) Process : --- Step 2 ") From DOSSUB
  Gosub TRTPS2
  #
  Call ECR_TIME("UTITRC06 Dashboard views (APV) Process        : --- Step 3 ") From DOSSUB
  Gosub TRTAPV
  #

$FIN_UTITRC06
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTITRC06 : End folder's process"-DOSSIER) From DOSSUB

End


# -------------------------------------  #
#  Graphical query tool Process (ALT)    #
# -------------------------------------  #
$TRTALT

  # No to do if it is an historic folder
  If func DOSVUE.ISVIEW(DOSSIER,"ALISTEH") : Return : Endif

  If filinfo(filpath("FIL","ALISTEH","fde",DOSSIER),0) <= 0 : Return : Endif

  Local File =DOSSIER+".ALISTEH"        [ALHD]
  Local File =[F:ADS]DOSREF+".ALISTEH"  [ALH]

  Filter [ALH] Where COD = "STO085" or COD = "STO086"
&                  or find (COD, "VEN070","VEN071","VEN072","VEN073","VEN076","VEN077","VEN078","VEN079") <> 0
&                  or find (COD, "VEN080","VEN081","VEN082","VEN083","VEN084","VEN088","VEN089","VEN007") <> 0
&                  or find (COD, "CRM074","CRM075","CRM090","CRM091","CRM092","CRM093","CRM094","CRM095") <> 0
  For [ALH]
    Read [ALHD]ALH0=[F:ALH]COD
    # There is no activity code : Copy is always done
#    # To do if the record doesn't or if it exists and is not protected by an activity code
#    If fstat | [F:ALHD]CODACT = "" | [F:ALHD]CODACT < "X"
      Call COPOBJ([F:ADS]DOSREF, DOSSIER, "ALT", [F:ALH]COD, "", "", "") From ACOPIE
      Call ECR_TRACE("ALT - copied" - [F:ALH]COD,0) From GESECRAN
#    Else
#      Call ECR_TRACE("ALT - not copied" - [F:ALH]COD - [F:ALHD]CODACT,-1) From GESECRAN
#    Endif
  Next
  Filter [ALH]

  Call ECR_TIME("Graphical query tool (ALT) Process Ended") From DOSSUB

  Close Local File [ALHD]
  Close Local File [ALH]

Return

# -------------------------------------  #
#  Statistical parameters Process (PS2)  #
# -------------------------------------  #
$TRTPS2

  # No to do if it is an historic folder
  If func DOSVUE.ISVIEW(DOSSIER,"PARSTA2") : Return : Endif

  If filinfo(filpath("FIL","PARSTA2","fde",DOSSIER),0) <= 0 : Return : Endif

  Local File =DOSSIER+".PARSTA2"        [PS2D]
  Local File =[F:ADS]DOSREF+".PARSTA2"  [PS2]

  Filter [PS2] Where find (COD, "VEN40","VEN41","VEN42","VEN43") <> 0
  For [PS2]
    Read [PS2D]PS20=[F:PS2]COD
    # To do if the record doesn't or if it exists and is not protected by an activity code
    #If fstat | [F:PS2D]CODACT = "" | [F:PS2D]CODACT < "X"  ## SAM 118248
    If (fstat | [F:PS2D]CODACT = "" | [F:PS2D]CODACT < "X") & [F:ADS]OPTINI(6)=2 ## SAM 118248
      Call COPOBJ([F:ADS]DOSREF, DOSSIER, "PS2", [F:PS2]COD, "", "", "") From ACOPIE
      Call ECR_TRACE("PS2 - copied" - [F:PS2]COD,0) From GESECRAN
    Else
      Call ECR_TRACE("PS2 - not copied" - [F:PS2]COD - [F:PS2D]CODACT,-1) From GESECRAN
    Endif
  Next
  Filter [PS2]

  Call ECR_TIME("Statistical parameters (PS2) Process Ended") From DOSSUB

  Close Local File [PS2D]
  Close Local File [PS2]

Return

# -------------------------------------  #
#  Dashbord views Process (APV)          #
# -------------------------------------  #
$TRTAPV

  # No to do if it is an historic folder
  If func DOSVUE.ISVIEW(DOSSIER,"APTLVW") : Return : Endif

  If filinfo(filpath("FIL","APTLVW","fde",DOSSIER),0) <= 0 : Return : Endif

  Local File =DOSSIER+".APTLVW"        [APVD]
  Local File =[F:ADS]DOSREF+".APTLVW"  [APV]

  Filter [APV] Where find (APVCOD, "SVEN02B","SVEN06B","SVEN42B","SVEN43B") <> 0
  For [APV]
    Read [APVD]APV0=[F:APV]APVCOD
    # There is no activity code : Copy is always done
#    # To do if the record doesn't or if it exists and is not protected by an activity code
#    If fstat | [F:APVD]CODACT = "" | [F:APVD]CODACT < "X"
      Call COPOBJ([F:ADS]DOSREF, DOSSIER, "APV", [F:APV]APVCOD, "", "", "") From ACOPIE
      Call ECR_TRACE("APV - copied" - [F:APV]APVCOD,0) From GESECRAN
#    Else
#      Call ECR_TRACE("APV - not copied" - [F:APV]APVCOD - [F:APVD]CODACT,-1) From GESECRAN
#    Endif
  Next
  Filter [APV]

  Call ECR_TIME("Dashbord views (APV) Process Ended") From DOSSUB

  Close Local File [APVD]
  Close Local File [APV]

Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 : End : Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  Call MAJ_UTITRC06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 : End : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  Call MAJ_UTITRC06(APPLI)
End

