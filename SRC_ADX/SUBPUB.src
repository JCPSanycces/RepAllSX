#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
# Suggestions :
# - Bouton déplacer
# - Supprimer des répertoires non vides
# - Afficher les derniers lus dans un répertoire dédié dans le libre-service

Raz [V]GPILOBJ, [V]GBIDC1, [V]GBIDC2
Call OBJET("PUB",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
#Infbox ACTION
Case [L]ACTION
 When "SETBOUT"      : If [L]REP="" : [L]CHMEN+="123" : Endif
#-------------------------------------------------------------------------------
 When "LIENS"        : Gosub LIENS
#-------------------------------------------------------------------------------
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "STATUT"       : Gosub STATUT
#-------------------------------------------------------------------------------
 When "FILGAUCHE"    : Gosub FILGAUCHE
#-------------------------------------------------------------------------------
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Call DELOCK("PUB\") From GLOCK
 When "AB_CREATION"  : Call DELOCK("PUB\") From GLOCK
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "INIMOD"       : Gosub INIMOD
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Call DELOCK("PUB\") From GLOCK
 When "AB_MODIF"     : Call DELOCK("PUB\") From GLOCK
 When "ANNULE"       : Gosub ANNULE
 When "AP_CHANGE"    : Gosub AP_CHANGE
#-------------------------------------------------------------------------------
 When "SEL_TABLE"
  Case [L]COUZON
   When "FDR"        : [L]OBJET="PUB"
   When "PUB"        : Gosub ST_PUB
   When "SHOPUB"     : Gosub ST_SHOPUB
  Endcase
 When "FIN_TABLE"
  If mkstat : Return : Else [M:PUB0]GSELECT=[L]COUZON : Endif
  Case [L]COUZON
   When "FDR"        : Gosub FT_FDR
   When "SHOPUB"     : Gosub FT_SHOPUB
  Endcase
#-------------------------------------------------------------------------------
 When "SEL_LISTE"
  If [M:PUB0]GSELECT=[L]COUZON : [M:PUB0]GSELECT="" : Return : Endif
  Case [L]COUZON
   When "FDR"       : Gosub SL_FDR
   When "SHOPUB"    : Gosub SL_SHOPUB
  Endcase
 When "FIN_LISTE"
  If mkstat : Return : Endif
  Case [L]COUZON
   When "FDR"       : Gosub FL_FDR
   When "SHOPUB"    : Gosub FL_SHOPUB
  Endcase
Endcase
Return

################################################################################
#
# Initialisation de la fenêtre
#
################################################################################

$LIENS
[M:PUB0]FDRADD=func ARBRE([F:PUB]FDRKEY)

Case [F:PUB]TYPDOC
When "DIR"
 Grizo [PUB1] 20
 Actzo [PUB1] 30
 Grizo [PUB2]
When "SHO"
 Actzo [PUB1] 20
 Diszo [PUB1] 30
 Grizo [PUB2]
 Call INISHO([F:PUB]SHOKEY,[F:PUB]SHOPUB)
 [M:PUB1]SHOADD=func ARBRE([F:PUB]SHOKEY)
When Default
 Read [BBB]BBB0="PUBLI";num$([F:PUB]FDRKEY);[F:PUB]PUB;""
 If !fstat : [M:PUB2]BB1=[F:BBB]BLOB : Endif
 Grizo [PUB1] 20
 Actzo [PUB1] 30
 Actzo [PUB2]
Endcase
Return

################################################################################
#
# Evénements
#
################################################################################

$APRES_MODIF
Case [L]COUZON
 When "FDR" : [L]COUZON="FDRKEY" : [L]CZ=num$([M:PUB0]FDRKEY)
Endcase
Return

#-------------------------------------------------------------------------------
$STATUT
Case [L]BOUT
When "1" : # Liste de diffusion
 Call DIFFUSE([M:PUB0]FDRKEY,[M:PUB0]PUB)
When "2" : # Arborescence complète
 Call DEVELOPPE("")
When "3" : # Arboresecence d'un salarié
 If [L]VALBOUT>""
  Call DEVELOPPE([L]VALBOUT)
 Endif
Endcase
Return

################################################################################
#
# Liste de gauche
#
################################################################################

$FILGAUCHE
If [L]OBJLIS([L]ILIS)="PU1" : [L]FILGAUSUP="FDRKEY=0" : Endif
Return

################################################################################
#
# Transactions
#
################################################################################

$VERIF_CRE
$VERIF_MOD
If !len([M:PUB2]BB1) & !find([M:PUB1]TYPDOC,"DIR","SHO")
 [V]GMESSAGE=mess(26,10719,1) : # Document vide
 [L]SUIZON  ="DOC"
 [L]OK      =0
 Return
Endif
Return

#-------------------------------------------------------------------------------
$INICRE
$INIMOD
If [M:PUB1]TYPDOC="DIR"
 If [F:PUB]PUBKEY<1
  Filter [PUB2] Order By Key CLE=PUBKEY
  I=1
  For [PUB2] Where PUBKEY>0
   While [F:PUB2]PUBKEY>I
    Lock ="PUB\"+num$(I)
    If !fstat : Break 2 : Else I+=1 : Endif
   Wend
   I+=1
  Next
  Repeat
   Lock ="PUB\"+num$(I)
   If fstat : I+=1 : Endif
  Until !fstat
  Filter [PUB2]
  [F:PUB]PUBKEY=I
 Endif
 [F:PUB]SIZDOC=0
Else
 [F:PUB]PUBKEY=-1
 [F:PUB]SIZDOC=-int(-len([M:PUB2]BB1)/1024)
Endif
Return

#-------------------------------------------------------------------------------
$CREATION
Gosub CRE_BLOB
Goto DEL_ARBRE

#-------------------------------------------------------------------------------
$AVANT_MODFIC
If [F:PUB]DES<>[M:PUB0]DES | [F:PUB]TYPDOC<>[M:PUB1]TYPDOC
&| [F:PUB]SHOKEY<>[M:PUB1]SHOKEY | [F:PUB]SHOPUB<>[M:PUB1]SHOPUB
 Goto DEL_ARBRE
Endif
Return

#-------------------------------------------------------------------------------
$MODIF
Readlock [BBB]BBB0(3)="PUBLI";num$([F:PUB]FDRKEY);[F:PUB]PUB
If fstat=1
 [V]GOK  =-1
 [V]GLOCK="$BBLOB"-"PUBLI"-num$([F:PUB]FDRKEY)-[F:PUB]PUB
 Return
Elsif fstat
 If find([F:PUB]TYPDOC,"DIR","SHO") : Return
 Else                                 Goto CRE_BLOB
 Endif
Endif

If find([F:PUB]TYPDOC,"DIR","SHO")
 Delete [BBB] Where CODBLB="PUBLI" & IDENT1=num$([F:PUB]FDRKEY)
&                 & IDENT2=[F:PUB]PUB
Else
 [F:BBB]TYPDOC=[M:PUB1]TYPDOC
 [F:BBB]TYPBLB=func TYPBLB([F:BBB]TYPDOC)
 [F:BBB]BLOB  =[M:PUB2]BB1
 If dim([F:BBB]UPDUSR)=1 : [F:BBB]UPDUSR=[V]GUSER : Endif
 If dim([F:BBB]UPDDAT)=1 : [F:BBB]UPDDAT=date$    : Endif
 If dim([F:BBB]UPDTIM)=1 : [F:BBB]UPDTIM=time     : Endif

 Rewrite [BBB] Curr
Endif
If fstat
 [V]GOK=0
 Call FSTA("BBB") From GLOCK
 Return
Endif
Return

#-------------------------------------------------------------------------------
$AP_CHANGE
If !clalev([F:BBB]) : Local File BBLOB [BBB] : Endif
[V]GOK=1
Trbegin [BBB]
 Update [BBB] Where CODBLB="PUBLI" & IDENT1=[L]SUPP(0) & IDENT2=[L]OCODE
&              With IDENT2=[L]NCODE
 If fstat
  [V]GOK=0
  Call RSTA("BBB","PUBLI"-[L]SUPP(0)-[L]OCODE) From GLOCK
  Rollback
  Return
 Endif
Commit
Return

#-------------------------------------------------------------------------------
$ANNULE
If !find([L]APPLI,"",nomap)
 Local File =[L]APPLI+".BBLOB"   [BBB]
 Local File =[L]APPLI+".PUBTREE" [PUT]
Else
 If !clalev([F:BBB]) : Local File BBLOB   [BBB] : Endif
 If !clalev([F:PUT]) : Local File PUBTREE [PUT] : Endif
Endif
Delete [BBB] Where CODBLB="PUBLI" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat
 [V]GOK=0
 Call RSTA("BBB","PUBLI"-[L]SUPP(0)-[L]CODE) From GLOCK
 Return
Endif
Goto DEL_ARBRE

################################################################################
#
# Routines
#
################################################################################

$CRE_BLOB
If !find([F:PUB]TYPDOC,"DIR","SHO")
 Raz [F:BBB]
 [F:BBB]CODBLB="PUBLI"
 [F:BBB]IDENT1=num$([F:PUB]FDRKEY)
 [F:BBB]IDENT2=[F:PUB]PUB
 [F:BBB]TYPDOC=[F:PUB]TYPDOC
 [F:BBB]TYPBLB=func TYPBLB([F:BBB]TYPDOC)
 [F:BBB]BLOB  =[M:PUB2]BB1
 If dim([F:BBB]CREUSR)=1 : [F:BBB]CREUSR=[V]GUSER : Endif
 If dim([F:BBB]CREDAT)=1 : [F:BBB]CREDAT=date$    : Endif
 If dim([F:BBB]CRETIM)=1 : [F:BBB]CRETIM=time     : Endif
 Write [BBB]
 If fstat
  [V]GOK=0
  Call FSTA("BBB") From GLOCK
  Return
 Endif
Endif
Return

#-------------------------------------------------------------------------------
Funprog TYPBLB(TYPDOC)
Value Char TYPDOC()

Case [L]TYPDOC
 When "TXT"   : End 2
 When "PIC"   : End 3
 When "DOC"   : End 5
 When "XLS"   : End 6
 When "PPT"   : End 7
 When Default : End 1
Endcase

#-------------------------------------------------------------------------------
$DEL_ARBRE
Delete [PUT] Where 1=1
If fstat=1
 [V]GOK  =-1
 [V]GLOCK="$PUBTREE"
Elsif fstat
 [V]GOK=0
 Call RSTA("PUT","") From GLOCK
Endif
Return

################################################################################
Funprog ARBRE(I)
Value Shortint I

If !clalev([F:PUB2]) : Local File PUBLISHING  [PUB2] : Endif

Local Char RETOUR(255)

While I
 Filter [PUB2] Where PUBKEY=I
 Read [PUB2]PUB0 First
 [L]RETOUR="/"+[F:PUB2]PUB+[L]RETOUR
 I        =[F:PUB2]FDRKEY
Wend
Filter [PUB2]
If [L]RETOUR="" : End "/" : Else End [L]RETOUR : Endif

################################################################################
Subprog INISHO(FDRKEY,PUB)
Value Shortint FDRKEY
Value Char     PUB()

Read [PUB2]PUB0=[L]FDRKEY;[L]PUB
[M:PUB1]ENAFLG=[F:PUB2]ENAFLG
[M:PUB1]ACS   =[F:PUB2]ACS
[M:PUB1]CPY   =[F:PUB2]CPY
[M:PUB1]FCY   =[F:PUB2]FCY
[M:PUB1]SRV   =[F:PUB2]SRV
[M:PUB1]PRF   =[F:PUB2]PRF
[M:PUB1]POP   =[F:PUB2]POP
[M:PUB1]CRI   =[F:PUB2]CRI

End

################################################################################
Subprog DIFFUSE(FDRKEY,PUB)
Value Shortint FDRKEY
Value Char     PUB()

If !clalev([F:PUB])  : Local File PUBLISHING [PUB]  : Endif
If !clalev([F:HRPOA])  : Local File POPULA     [HRPOA]  : Endif
If !clalev([F:PUT])  : Local File PUBTREE    [PUT]  : Endif

Call CRETREE

Gosub OUVRE From WPDEFTABLE

Local Shortint OK, DEB, FIN, LVL, SHOKEY
Local Char     MATRI([V]GLONREF), FFCY(8), FSRV(8), FMAT(8), FNAM(8)
Local Char     SHOPUB([V]GLONPUB)

[L]OK  =type([F:ID]SRN)+type([F:ID]NAM)-20
[L]FFCY="K:"+num$(max([V]GLONFCY,len(mess(43,10702,1))))+"X[ ]" : # Site
[L]FSRV="K:"+num$(max([V]GLONSRV,len(mess(44,10702,1))))+"X[ ]" : # Service
[L]FMAT="K:"+num$(max([V]GLONEML,len(mess(80,10703,1))))+"X[ ]" : # Matricule
[L]FNAM="K:"+num$(max([L]OK,len(mess(74,10702,1))))     +"X[ ]" : # Nom prénom

Read [PUB]PUB0=[L]FDRKEY;[L]PUB
Call OUVRE_TRACE(func AFNC.MES1(mess(33,10719,1),[F:PUB]FDR-[F:PUB]PUB)) From LECFIC
#                               Liste de diffusion de la publication $1$
Call ECR_TRACE( format$([L]FFCY,mess(43,10702,1))+format$([L]FSRV,mess(44,10702,1))
&             + format$([L]FMAT,mess(80,10703,1))+format$([L]FNAM,mess(74,10702,1))
&             , 0
&             ) From GESECRAN
#               Site       Service
#               Matricule  Nom Prénom
Call ECR_TRACE( format$([L]FFCY,string$(80,"-"))+format$([L]FSRV,string$(80,"-"))
&             + format$([L]FMAT,string$(80,"-"))+format$([L]FNAM,string$(80,"-"))
&             , 0
&             ) From GESECRAN

Filter [PUT] Order By Key CLE=ORN Desc
For [PUT]CLE
 If [F:PUT]FDRKEY=[L]FDRKEY & [F:PUT]PUB=[L]PUB
  If ![L]FIN : [L]FIN=[F:PUT]ORN : Endif
  [L]LVL=[F:PUT]LVL
 Endif
 If [L]LVL & [F:PUT]LVL=1 : [L]DEB=[F:PUT]ORN : [L]LVL=0 : Endif
Next

Link [ENT] With [ID]ID0=REFNUM
&            As [LNK]
&  Order By Key CLE=ETRFCY;ETRSRV;REFNUM

[L]MATRI="*"
For [LNK]CLE Where ETRDAT<=datesyst & (XITDAT=[0/0/0] | XITDAT>=datesyst)

 Link [PUB] With [HRPOA]POA1=[F:ID]REFNUM;POP As [LNK2]

 For [PUT]CLE Where ORN>=[L]DEB & ORN<=[L]FIN
  If [F:PUT]FDRKEY=[L]FDRKEY & [F:PUT]PUB=[L]PUB
   If [F:PUT]ORN=[L]FIN
    Read [LNK2]PUB0=[L]FDRKEY;[L]PUB
    If [F:PUB]TYPDOC="SHO"
     [L]SHOKEY=[F:PUB]SHOKEY
     [L]SHOPUB=[F:PUB]SHOPUB
     Read [LNK2]PUB0=[L]SHOKEY;[L]SHOPUB
    Endif
    If !func ACCES([L]MATRI) : [L]OK=0 : Break : Endif
   Endif
   [L]LVL=[F:PUT]LVL
   [L]OK =1
  Elsif [F:PUT]LVL<[L]LVL
   Read [LNK2]PUB0=[F:PUT]FDRKEY;[F:PUT]PUB
   If    [F:PUB]TYPDOC<>"SHO" & !func ACCES([L]MATRI) : [L]LVL=1 : [L]OK=0
   Elsif [F:PUT]LVL=1                                 : Break
   Else                                                 [L]LVL=[F:PUT]LVL
   Endif
  Endif
 Next

 If [L]OK
  Call ECR_TRACE( format$([L]FFCY,[F:ENT]ETRFCY)+format$([L]FSRV,[F:ENT]ETRSRV)
&               + format$([L]FMAT,[F:ID]REFNUM)
&               + format$([L]FNAM,[F:ID]NAM-[F:ID]SRN)
&               , 0
&               ) From GESECRAN
 Endif
Next
Filter [PUT]

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

################################################################################
Funprog ACCES(MATRI)
Variable Char MATRI()

If    [F:PUB]ENAFLG<2                 : End 0
Elsif !find([F:PUB]POP,"",[F:HRPOA]COD) : End 0
Elsif !func AFNC.EXEC([F:PUB]ACS)     : End 0
Endif

If [F:PUB]CRI>"" | [F:PUB]CPY>"" | [F:PUB]PRF>"" | [F:PUB]SRV>"" | [F:PUB]FCY>""
 If !find([L]MATRI,"",[F:ID]REFNUM)
  Local Date DATMAT
  [L]DATMAT=datesyst
  [L]MATRI =[F:ID]REFNUM
  Gosub LECEMP From WPDEFTABLE
 Endif
 If    !find([F:PUB]FCY,"",[F:ENT]ETRFCY)                             : End 0
 Elsif !find([F:PUB]PRF,"",[F:PRO]PROPRF)                             : End 0
 Elsif !find([F:PUB]SRV,"",[F:ENT]ETRSRV)                             : End 0
 Elsif [F:PUB]CRI>"" & !evalue([F:PUB]CRI)                            : End 0
 Elsif [F:PUB]CPY>"" & [F:PUB]CPY<>func DIVPAYE.GETSOC([F:ENT]ETRFCY) : End 0
 Endif
Endif

End 1

################################################################################
Subprog DEVELOPPE(MATRI)
Value Char MATRI()

If !clalev([F:PUB])  : Local File PUBLISHING [PUB]  : Endif
If !clalev([F:PUB2]) : Local File PUBLISHING [PUB2] : Endif
If !clalev([F:PUT])  : Local File PUBTREE    [PUT]  : Endif
If !clalev([F:PUT2]) : Local File PUBTREE    [PUT2] : Endif

Call CRETREE

If [L]MATRI>""
 If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif
 Local Date DATMAT
 [L]DATMAT=datesyst
 Gosub OUVRE From WPDEFTABLE
 Gosub LECEMP From WPDEFTABLE
Endif

Local Shortint LONG, I, J, K, PRELVL, OK
Local Char     TRAIT(115), LIGNE(115), PRETYP([V]GLONADI)

If [L]MATRI=""
 Call OUVRE_TRACE(mess(27,10719,1)) From LECFIC
 #                Arborescence
Else
 Call OUVRE_TRACE(mess(27,10719,1)-":"-[L]MATRI-[F:ID]NAM-[F:ID]SRN) From LECFIC
 #                Arborescence
Endif
Call ECR_TRACE("0",0) From GESECRAN

If [L]MATRI=""
 Link [PUT] With [PUB2]PUB0=FDRKEY;PUB As [LNK]
 Link [PUT2] With [PUB2]PUB0=FDRKEY;PUB As [LNK2]
Else
 Link [PUT] With [PUB2]PUB0=FDRKEY;PUB
&              , [HRPOA]POA1=[L]MATRI;POP
&             As [LNK]
 Link [PUT2] With [PUB2]PUB0=FDRKEY;PUB
&               , [HRPOA]POA1=[L]MATRI;POP
&              As [LNK2]
 Link [PUB] With [HRPOA]POA1=[L]MATRI;POP As [LNK3]
Endif

[L]LONG =type([L]LIGNE)-10
[L]TRAIT="! "
[L]OK   =1
For [LNK]PUT0

 If [L]MATRI>"" & ([L]OK>=0 | [F:PUT]LVL<=-[L]OK)
  If [F:PUB2]TYPDOC="SHO" : Read [LNK3]PUB0=[F:PUB2]SHOKEY;[F:PUB2]SHOPUB
  Else                     [F:PUB]=[F:PUB2]
  Endif
  [L]OK=func ACCES([L]MATRI)
  If ![L]OK & find([F:PUB2]TYPDOC,"DIR","SHO") : [L]OK=-[F:PUT]LVL : Endif
 Endif

 If [L]OK=1
  If [L]PRELVL<>[F:PUT]LVL | [L]PRETYP="DIR"
   Call ECR_TRACE(left$([L]TRAIT,2*[F:PUT]LVL),0) From GESECRAN
  Endif
  [L]LIGNE=left$([L]TRAIT,2*[F:PUT]LVL-2)+"+"+[F:PUB2]TYPDOC+">"+[F:PUB2]PUB+" "
  Call ECR_TRACE([L]LIGNE+left$([F:PUB2]DES,[L]LONG-len([L]LIGNE)),0) From GESECRAN

  If find([F:PUB2]TYPDOC,"DIR","SHO")
   I=0
   For [LNK2] Where ORN>[F:PUT]ORN & LVL<=[F:PUT]LVL
    If [L]MATRI=""
     I=[F:PUT2]LVL
     Break
    Else
     If [F:PUB2]TYPDOC="SHO" : Read [LNK3]PUB0=[F:PUB2]SHOKEY;[F:PUB2]SHOPUB
     Else                      [F:PUB]=[F:PUB2]
     Endif
     If func ACCES([L]MATRI) : I=[F:PUT2]LVL : Break : Endif
    Endif
   Next
   [L]TRAIT=left$([L]TRAIT,2*[F:PUT]LVL-2)
   If I=[F:PUT]LVL : [L]TRAIT+="! ! " : Else [L]TRAIT+="  ! " : Endif
  Endif

  I=len([F:PUB2]DES)
  J=[L]LONG-len([L]LIGNE)
  K=0
  While J+K<I
   Call ECR_TRACE( format$("K:"+num$([L]LONG-J)+"X",[L]TRAIT)
&                + mid$([F:PUB2]DES,J+K+1,J),0
&                ) From GESECRAN
   K+=J
  Wend

  [L]PRELVL=[F:PUT]LVL
  [L]PRETYP=[F:PUB2]TYPDOC
 Endif
Next
Filter [PUT2]

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End
   
################################################################################
Subprog CRETREE

If !clalev([F:PUT]) : Local File PUBTREE [PUT] : Endif
If nbrecord([PUT]) : End : Endif

Lock PUBTREE
If fstat
 Repeat : Sleep 1 : Lock PUBTREE : Until !fstat
 Unlock PUBTREE
 End
Endif

If !clalev([F:PUB])  : Local File PUBLISHING [PUB]  : Endif
If !clalev([F:PUB2]) : Local File PUBLISHING [PUB2] : Endif
If !clalev([F:ADI])  : Local File ATABDIV    [ADI]  : Endif

Local Shortint ORN, LVL, FDRKEY, SHOKEY, PUBKEY
Local Char     DES(type([F:PUB]DES)-10), DES0(type([F:PUB]DES)-10)
Local Char     SHOPUB([V]GLONPUB), TYPDOC([V]GLONADI)

Link [PUB] With [PUB2]PUB0=SHOKEY;SHOPUB As [LNK]
Link [PUT] With [PUB]PUB0 =FDRKEY;PUB
&             , [PUB2]PUB0=[PUB]SHOKEY;[PUB]SHOPUB
&            As [LNK2]
Filter [ADI] Where NUMTAB=10601 & find(CODE,"DIR","SHO")=0 Order By Key CLE=N2

Call DEBTRANS From GLOCK
$TR_PUT
[V]GOK=1
Trbegin [PUT]
 Gosub PUBTREE
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Goto FIN_PUT : Else Goto TR_PUT : Endif
 Elsif ![V]GOK
  Rollback
  Goto FIN_PUT
 Endif
Commit

$FIN_PUT
Filter [ADI]
Unlock PUBTREE

End

#-------------------------------------------------------------------------------
$PUBTREE
[L]LVL=1
Raz [L]DES0, [L]ORN, [L]FDRKEY
Repeat 
 [L]TYPDOC="DIR"
 Gosub MINDES

 If [L]DES<>[L]DES0
  Gosub CREPUT
  If [V]GOK<1 : Break : Endif
  If [L]SHOPUB>""
   Gosub CRESHO
   If [V]GOK<1 : Break : Endif
  Endif

  [L]LVL   +=1
  [L]FDRKEY =[L]PUBKEY
  [L]DES0   =""

 Else
  For [ADI]CLE
   [L]DES0  =""
   [L]TYPDOC=[F:ADI]CODE
   Repeat
    Gosub MINDES

    If [L]DES0=[L]DES
     [L]DES=""
    Else
     [L]DES0=[L]DES
     Gosub CREPUT
     If [V]GOK<1 : Break 3 : Endif
     If [L]SHOPUB>""
      Gosub CRESHO
      If [V]GOK<1 : Break 3 : Endif
      [L]LVL-=1
     Endif
    Endif
   Until [L]DES=""
  Next

  [L]LVL-=1
 Endif

 If [L]DES="" & [L]LVL
  Filter [LNK2] Where LVL=[L]LVL & [PUB]TYPDOC="DIR" Order By Key CLE=ORN Desc
  Read [LNK2] First
  [L]FDRKEY =[F:PUB]FDRKEY
  [L]DES0   =toupper([F:PUB]DES)
  Filter [LNK2]
  [F:PUT]ORN-=1
  Read [LNK2]PUT0 =
  If !fstat & [F:PUB]TYPDOC="SHO"
   [L]FDRKEY =[F:PUB]FDRKEY
   [L]DES0   =toupper([F:PUB2]DES)
   [L]LVL   -=1
  Endif
 Endif

Until [L]LVL=0
Return

#-------------------------------------------------------------------------------
$MINDES
[L]DES=[L]DES0
For [LNK]PUB0 Where FDRKEY=[L]FDRKEY
&                 & ( TYPDOC=[L]TYPDOC
&                   | (TYPDOC="SHO" & num$([PUB2]TYPDOC)=[L]TYPDOC)
&                   )
 If ( ([F:PUB2]DES>"" & toupper([F:PUB2]DES)>[L]DES0)
&   | ([F:PUB2]DES="" & toupper([F:PUB]DES)>[L]DES0)
&   )
& & ( [L]DES=[L]DES0
&   | ([F:PUB2]DES>"" & toupper([F:PUB2]DES)<[L]DES)
&   | ([F:PUB2]DES="" & toupper([F:PUB]DES)<[L]DES)
&   )
  If [F:PUB2]DES="" : [L]DES=toupper([F:PUB]DES)  : [L]PUBKEY=[F:PUB]PUBKEY
  Else                [L]DES=toupper([F:PUB2]DES) : [L]PUBKEY=[F:PUB2]PUBKEY
  Endif
  [F:PUT]FDRKEY=[F:PUB]FDRKEY
  [F:PUT]PUB   =[F:PUB]PUB
  [L]SHOKEY    =[F:PUB]SHOKEY
  [L]SHOPUB    =[F:PUB]SHOPUB
 Endif
Next
Return

#-------------------------------------------------------------------------------
$CRESHO
[L]LVL       +=1
[F:PUT]FDRKEY =[L]SHOKEY
[F:PUT]PUB    =[L]SHOPUB

#-------------------------------------------------------------------------------
$CREPUT
[L]ORN    +=1
[F:PUT]ORN =[L]ORN
[F:PUT]LVL =[L]LVL
Write [PUT]
If fstat
 [V]GOK=0
 Call FSTA("PUT") From GLOCK
Endif
Return

################################################################################
#
# Etiquettes du masque PUB0
#
################################################################################

########################################
$FT_FDR
[M:PUB0]FDRADD=func ARBRE([F:PUB]FDRKEY)
[M:PUB0]FDRKEY=[F:PUB]FDRKEY
[M:PUB0]ANUCOD=[F:PUB]ANUCOD
Return

########################################
$SL_FDR
If [L]VALEUR>""
 Filter [PUB] Where PUB=[L]VALEUR & TYPDOC="DIR"
 Look [PUB] First
 Filter [PUB]
 If fstat
  [V]GMESSAGE=mess(28,10719,1) : # Dossier inexistant
  [V]GERR    =1
  Return
 Endif
Endif

Local Char PUB([V]GLONPUB), TEXTE(4*[V]GLONPUB+4)(dim([L]TEX))

[L]PUB=[L]VALEUR
[L]TIT=mess(27,10719,1) : # Arborescence
For [PUB]PUB0 Where PUB=[L]VALEUR & TYPDOC="DIR"
 [L]NBTEX          +=1
 [L]TEX  ([L]NBTEX) =num$([F:PUB]PUBKEY)
 [L]TEXTE([L]NBTEX) =func ARBRE([F:PUB]FDRKEY)
Next
If ![L]NBTEX : [M:PUB0]FDRADD="/" : [M:PUB0]FDRKEY=0 : Endif
Return

########################################
$FL_FDR
[M:PUB0]FDRKEY=val([L]VALEUR)
[L]VALEUR     =[L]PUB
[M:PUB0]FDRADD=func ARBRE([M:PUB0]FDRKEY)
Filter [PUB] Where PUBKEY=[M:PUB0]FDRKEY
Read [PUB]PUB0 First
Filter [PUB]
[M:PUB0]ANUCOD=[F:PUB]FDRKEY
Return

########################################
$ST_PUB
[L]OBJET="PUB"
[L]CRITERE(1)="FDRKEY="+num$([M:PUB0]FDRKEY)
Return

################################################################################
#
# Etiquettes du masque PUB1
#
################################################################################

########################################
Subprog AM_TYPDOC(VALEUR)
Variable Char    VALEUR()

Case [L]VALEUR
When "SHO"
 Filter [PUB2] Where SHOKEY=[M:PUB0]FDRKEY & SHOPUB=[M:PUB0]PUB
 Read [PUB2]PUB0 First
 Filter [PUB2]
 If fstat
  Actzo [PUB1] 20
  Diszo [PUB1] 30
  If len([M:PUB2]BB1) : Effzo [PUB2] : Endif
  Grizo [PUB2]
 Else
  [V]GMESSAGE=func AFNC.MES1(mess(30,10719,1),[F:PUB2]FDR-[F:PUB2]PUB)
  #           Le raccourci $1$ pointe sur cette publication
  mkstat     =2
 Endif
When "DIR"
 Effzo [PUB1] 20
 Grizo [PUB1] 20
 Actzo [PUB1] 30
 If len([M:PUB2]BB1) : Effzo [PUB2] : Endif
When Default
 Effzo [PUB1] 20
 Grizo [PUB1] 20
 Actzo [PUB1] 30
 Actzo [PUB2]
Endcase

End

########################################
$ST_SHOPUB
[L]OBJET     ="PUB"
I            =[M:PUB0]FDRKEY
[L]CRITERE(1)="FDRKEY<>"+num$(I)
J            =1
While I
 Filter [PUB2] Where PUBKEY=I
 Read [PUB2]PUB0 First
 I=[F:PUB2]FDRKEY
 If J : [L]CRITERE(1)-="& find(PUBKEY" : J=0 : Endif
 If I : [L]CRITERE(1)+=","+num$(I) : Endif
Wend
If !J : [L]CRITERE(1)+=")=0" : Endif
Return

########################################
$FT_SHOPUB
[M:PUB1]SHOADD=func ARBRE([F:PUB]FDRKEY)
[M:PUB1]SHOKEY=[F:PUB]FDRKEY
Affzo [PUB1] SHOADD
Call INISHO([M:PUB1]SHOKEY,[L]VALEUR)
Affzo [PUB1] 30
Return

########################################
$SL_SHOPUB
Local Char CIRCREF(255), PUB([V]GLONPUB), TEXTE(4*[V]GLONPUB+4)(dim([L]TEX))

I=[F:PUB]FDRKEY
J=1
While I
 Filter [PUB2] Where PUBKEY=I
 Read [PUB2]PUB0 First
 I=[F:PUB2]FDRKEY
 If J : [L]CIRCREF="find(PUBKEY" : J=0 : Endif
 If I : [L]CIRCREF+=","+num$(I) : Endif
Wend
If J : [L]CIRCREF="1=1" : Else [L]CIRCREF+=")=0" : Endif

Filter [PUB] Where PUB=[L]VALEUR & TYPDOC<>"SHO"
Look [PUB] First 
Filter [PUB]
If fstat
 [V]GMESSAGE=mess(29,10719,1) : # Dossier ou fichier inexistant
 [V]GERR    =1
 Return
Endif
Filter [PUB] Where PUB=[L]VALEUR & TYPDOC<>"SHO" & FDRKEY<>[M:PUB0]FDRKEY
&                & evalue([L]CIRCREF)
Look [PUB] First 
Filter [PUB]
If fstat
 [V]GMESSAGE=mess(32,10719,1) : # Référence circulaire
 [V]GERR    =1
 Return
Endif

[L]PUB=[L]VALEUR
[L]TIT=mess(27,10719,1) : # Arborescence
For [PUB]PUB0 Where PUB=[L]VALEUR & TYPDOC<>"SHO" & FDRKEY<>[M:PUB0]FDRKEY
&                 & evalue([L]CIRCREF)
 [L]NBTEX          +=1
 [L]TEX  ([L]NBTEX) =num$([F:PUB]FDRKEY)
 [L]TEXTE([L]NBTEX) =func ARBRE([F:PUB]FDRKEY)
Next
If ![L]NBTEX : [M:PUB1]SHOADD="/" : [M:PUB1]SHOKEY=0 : Endif
Return

########################################
$FL_SHOPUB
[M:PUB1]SHOKEY=val([L]VALEUR)
[L]VALEUR     =[L]PUB
[M:PUB1]SHOADD=func ARBRE([M:PUB1]SHOKEY)
Affzo [PUB1] SHOADD
Call INISHO([M:PUB1]SHOKEY,[L]PUB)
Affzo [PUB1] 30
Return

