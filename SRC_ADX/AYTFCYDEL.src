#<AdxTL>@(#)9.0.0.0 $Revision$
######################################################################################
## Xtend: Suppression Xtend
######################################################################################
##  Gestion Ecran
#    AYTFCYDEL
#
##  Actions
#    AYTFCYDEL    Suppression d'un site Xtend
#
##  Gosub
#
##  Subprog
#    FCYDELPRG       Trt de suppression d'un site Xtend
######################################################################################
$ACTION
  #Call ECR_TRACE("Action:"-ACTION,0)From GESECRAN
  #
  If dim([L]PTRTB)<=0        # Perso par produit
    Local Integer PTRTB
    Call EXISTE_ADX("","","AYTFCYDELB",PTRTB) From ORDSYS
  Endif
  #
  Case ACTION
    When "INIT"     : Gosub FCYDEL_INI
    When "INIT_DIA" : Gosub FCYDEL_DIA
    When "CONTROLE" : Gosub FCYDEL_CTL
    When "EXEC"     : Gosub FCYDEL_EXEC
  Endcase
  If PTRTB: Gosub ACTION From AYTFCYDELB : Endif           # Perso par produit
Return

######################################################################################
#    AYTFCYDEL    Procédure générale de suppression d'un site Xtend
#                 Ecran AYTFCYDEL
#        Param(1)      Dossier 
#        Param(2)      Site Xtend 
# $$$$
######################################################################################
$FCYDEL_INI
#-----------------------------
Local Char FCYDES(GLONAYS), DOSDES(GDIMFIC)
Local Char OBJET(20), ELTCOD(30), WSTR1(200), WDES(50), WMSG(250)
Local Char MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)
Local Char OPTION(10)(1..10)     : Local Integer OPTIND
Local Char LSTOBJCOD(3)(1..20)   : Local Integer LSTIND
Local Integer WI, RET 

[L]OBJET="AYS" 
[L]DOSDES=PARAM(1) 
[L]FCYDES=PARAM(2) 
Return

$FCYDEL_DIA
#-----------------------------
[M:DIA]DOSDES=DOSDES
[M:DIA]FCYDES=FCYDES
Return

$FCYDEL_CTL
#-----------------------------
If DESM1<>2 & PARM1 <>2 : GERR=1 : GMESSAGE=mess(147,7900,1) : SAI=1 : Return : Endif
OK=1 : Call AVERTIR(mess(28,7900,1)-[M:DIA]FCYDES,OK) From GESECRAN
If OK<>2 : FIN = 1 : Endif
Return

$FCYDEL_EXEC
#-----------------------------
WMSG=mess(29,7900,1)-[M]FCYDES-"("-[M:DIA]DOSDES-")"
If !GSERVEUR
    TRA=1
    Call TEMPON(WMSG) From GESECRAN 
    Call OUVRE_TRACE(WMSG) From LECFIC
Else
    OPTIND+=1 : OPTION(OPTIND)="NOTEMPON"
Endif
#
Raz LSTIND, OPTIND
If [M:DIA]PARM1=2
     LSTIND+=1 : LSTOBJCOD(LSTIND)="***"
     LSTIND+=1 : LSTOBJCOD(LSTIND)="AYG"
     LSTIND+=1 : LSTOBJCOD(LSTIND)="AYS"  # Suppression du site
Endif
If [M:DIA]DESM1=2: OPTIND+=1 : OPTION(OPTIND)="DESSUP" : Endif
If [M:DIA]TRAOPT=2: OPTIND+=1 : OPTION(OPTIND)="TRADET" : Endif   
Call FCYDELPRG([M:DIA]DOSDES, [M:DIA]FCYDES, LSTOBJCOD, OPTION, RET) 
If RET=0 : FIN=1 : Goto FCYDEL_FIN: Endif

# MAJ site de travail si besoin 
If GAYTFCYWRK=[M:DIA]FCYDES : Call SETFCYWRK("") From SUBAYS : Endif

$FCYDEL_FIN
If !GSERVEUR
 Call TEMPOFF() From GESECRAN 
Endif
Return


######################################################################################
### Utilitaires - Gosub
######################################################################################


######################################################################################
###     Utilitaires générations subprog et funprog 
######################################################################################

#------------------------------------------------------------#
# Suppression d'un site Xtend 
# $$$$
#------------------------------------------------------------#
Subprog FCYDELPRG(DOSDES, FCYDES, LSTOBJCOD, OPTION, RET)       
Value Char DOSDES              # sodaix01:5000@XTEND
Value Char FCYDES              # Site Xtend
Value Char LSTOBJCOD()(1..)    # Liste des objets Xtend à regénérer AYG, AYL... ou "***" pour tous sauf AYS
                               #  Le site doit être spécifié par AYS pour être supprimé
Value Char OPTION()(1..)       # Options 
                               #   'DESSUP' =Suppression du design
                               #   'TRADET'    =Trace détaillée
                               #   'NOTEMPON'  =Pas de popup avancement
Variable Integer RET : RET=1   # 1: Ok
#
Local Char MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)        # sodaix01:5000 ; XTEND
Local Integer DESFLG      : DESFLG      =find("DESSUP",OPTION)
Local Integer TRADETFLG   : TRADETFLG   =find("TRADET",OPTION)
Local Integer TMPONFLG    : TMPONFLG    =(find("NOTEMPON",OPTION)=0)
Local Integer FLGALL      : FLGALL      =find("***",LSTOBJCOD)
Local Char WMSG(200)
#
# Perso par produit
Local Integer PTRTB
Call EXISTE_ADX("","","AYTFCYDELB",PTRTB) From ORDSYS
#
WMSG=mess(29,7900,1)-[L]FCYDES-"("-DOSDES-")"
Call ECR_TRACE(WMSG,0) From GESECRAN
If vireblc(FCYDES,2)="" :  Call ECR_TRACE(mess(148,7900,1),1) From GESECRAN : Goto FCYDELPRG_F : Endif
If vireblc(DOSDES,2)="" :  Call ECR_TRACE(mess(149,7900,1),1) From GESECRAN : Goto FCYDELPRG_F : Endif
If len(sum(LSTOBJCOD))=0 and !DESFLG : Call ECR_TRACE(mess(133,7900,1),1) From GESECRAN : Goto FCYDELPRG_F : Endif
#

# Design
RET=1
If DESFLG
    WMSG=mess(41,7900,1)-"("+[L]FCYDES+")"
    If TMPONFLG : Call TEMPON(WMSG) From GESECRAN : Endif
    Call ECR_TRACE(WMSG,0) From GESECRAN 
    Call MACHINE([L]DOSDES,MACDES,DOSNAMDES) From ORDSYS
    Call DIRFCYDEL(MACDES,DOSNAMDES,[L]FCYDES,RET) From AYTGESFILE
Endif
If RET=0 : Goto FCYDELPRG_F : Endif
#
# Paramétrage
If len(sum(LSTOBJCOD))=0  : Goto FCYDELPRG_F : Endif

WMSG=mess(111,7900,1)-"("+[L]FCYDES+")"
If TMPONFLG : Call TEMPON(WMSG) From GESECRAN : Endif
Call ECR_TRACE(WMSG,0) From GESECRAN 

If [L]DOSDES=nomap 
 Local File AYTINT      [AYI2]
 Local File AYTMES      [AYM2]
 Local File AYTELTSPE   [AYX2]
 Local File AYTELTFLD   [AYF2]
 Local File AYTPAG      [AYG2]
 Local File AYTPRF      [AYD2]
 Local File AYTENT      [AYE2]
 Local File AYTLINES    [AYN2]
 Local File AYTELTBLC   [AYB2]
 Local File AYTACT      [AYA2]
 Local File AYTELTDLK   [AYL2]
 Local File AYTELTBLCW  [AYW2]
 Local File AYTMEN      [AYC2]
 Local File AYTFCY      [AYS2]
 Local File AYTADVPAR   [AYU2]
 Local File ATEXTRA     [AXX2]
Else 
 Local File =[L]DOSDES+".AYTINT"      [AYI2]
 Local File =[L]DOSDES+".AYTMES"      [AYM2]
 Local File =[L]DOSDES+".AYTELTSPE"   [AYX2]
 Local File =[L]DOSDES+".AYTELTFLD"   [AYF2]
 Local File =[L]DOSDES+".AYTPAG"      [AYG2]
 Local File =[L]DOSDES+".AYTPRF"      [AYD2]
 Local File =[L]DOSDES+".AYTENT"      [AYE2]
 Local File =[L]DOSDES+".AYTLINES"    [AYN2]
 Local File =[L]DOSDES+".AYTELTBLC"   [AYB2]
 Local File =[L]DOSDES+".AYTACT"      [AYA2]
 Local File =[L]DOSDES+".AYTELTDLK"   [AYL2]
 Local File =[L]DOSDES+".AYTELTBLCW"  [AYW2]
 Local File =[L]DOSDES+".AYTMEN"      [AYC2]
 Local File =[L]DOSDES+".AYTFCY"      [AYS2]
 Local File =[L]DOSDES+".AYTADVPAR"   [AYU2]
 Local File =[L]DOSDES+".ATEXTRA"     [AXX2]
Endif 

# Perso par produit
If PTRTB: Gosub FCYDELDEB From AYTFCYDELB: Endif           
If RET=0 : Goto FCYDELPRG_F : Endif

#
Call DEBTRANS From GLOCK  
Gosub TR_DEL
If (GOK<1 | RET=0) : Goto FCYDELPRG_F : Endif

$FCYDELPRG_F
# Perso par produit
If PTRTB: Gosub FCYDELFIN From AYTFCYDELB: Endif       
#    
If clalev([F:AYF2]) : Close Local File [AYF2] : Endif
If clalev([F:AYX2]) : Close Local File [AYX2] : Endif
If clalev([F:AYM2]) : Close Local File [AYM2] : Endif
If clalev([F:AYI2]) : Close Local File [AYI2] : Endif
If clalev([F:AYG2]) : Close Local File [AYG2] : Endif
If clalev([F:AYD2]) : Close Local File [AYD2] : Endif
If clalev([F:AYE2]) : Close Local File [AYE2] : Endif
If clalev([F:AYN2]) : Close Local File [AYN2] : Endif
If clalev([F:AYB2]) : Close Local File [AYB2] : Endif
If clalev([F:AYA2]) : Close Local File [AYA2] : Endif
If clalev([F:AYL2]) : Close Local File [AYL2] : Endif
If clalev([F:AYW2]) : Close Local File [AYW2] : Endif
If clalev([F:AYC2]) : Close Local File [AYC2] : Endif
If clalev([F:AYS2]) : Close Local File [AYS2] : Endif
If clalev([F:AYU2]) : Close Local File [AYU2] : Endif
If clalev([F:AXX2]) : Close Local File [AXX2] : Endif
Call TEMPOFF From GESECRAN
End


# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$TR_DEL
Local Char WSP (2) : WSP="  "
GOK = 1
Trbegin [AYS2], [AYG2], [AYD2], [AYF2], [AYX2], [AYM2], [AYI2], [AYN2]
&     , [AYE2], [AYB2], [AYA2], [AYW2], [AYC2], [AYU2]

# Perso par produit
If PTRTB: Gosub FCYDELTRA From AYTFCYDELB: Endif           
If (GOK<1 | RET=0) : Return : Endif

# Paramétres avancés
If FLGALL or find("AYU",LSTOBJCOD)
 Call TITOBJ("AYU","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON                                     # Call TEMPON(mess(53,123,1)-WMSG-"("+[L]FCYDES+")") From GESECRAN
 Delete [AYU2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTADVPAR" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYU2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif


# Menus
If FLGALL or find("AYC",LSTOBJCOD)
 Call TITOBJ("AYC","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYN2] Where FCYCOD=[L]FCYDES & LINCODTYP=7
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLINES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(130,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
 Delete [AYC2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTACT" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYC2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Blocs conditionné
If FLGALL or find("AYW",LSTOBJCOD)
 Call TITOBJ("AYW","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYN2] Where FCYCOD=[L]FCYDES & LINCODTYP=5
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLINES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(130,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
 Delete [AYW2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTBLCW" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYW2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Liens dynamiques
If FLGALL or find("AYL",LSTOBJCOD)
 Call TITOBJ("AYL","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYN2] Where FCYCOD=[L]FCYDES & LINCODTYP=4
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLINES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(130,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
 Delete [AYL2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTDLK" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYL2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Interfaces
If FLGALL or find("AYI",LSTOBJCOD)
 Call TITOBJ("AYI","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYN2] Where FCYCOD=[L]FCYDES & LINCODTYP=6
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLINES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(130,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
 Delete [AYI2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTINT" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYI2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Actions
If FLGALL or find("AYA",LSTOBJCOD)
 Call TITOBJ("AYA","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYN2] Where FCYCOD=[L]FCYDES & LINCODTYP=3
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLINES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(130,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
 Delete [AYA2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTACT" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYA2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Messages
If FLGALL or find("AYM",LSTOBJCOD)
 Call TITOBJ("AYM","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYM2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTMES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYM2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Elt spéciaux
If FLGALL or find("AYX",LSTOBJCOD)
 Call TITOBJ("AYX","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYX2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTSPE" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYX2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Blocs
If FLGALL or find("AYB",LSTOBJCOD)
 Call TITOBJ("AYB","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYN2] Where FCYCOD=[L]FCYDES & LINCODTYP=2
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLINES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(130,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
 Delete [AYB2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTBLC" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYB2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Entités
If FLGALL or find("AYE",LSTOBJCOD)
 Call TITOBJ("AYE","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYN2] Where FCYCOD=[L]FCYDES & LINCODTYP=1
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLINES" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(130,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
 Delete [AYE2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTENT" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYE2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Elt champs
If FLGALL or find("AYF",LSTOBJCOD)
 Call TITOBJ("AYF","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYF2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTFIE" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYF2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Profil
If FLGALL or find("AYD",LSTOBJCOD)
 Call TITOBJ("AYD","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYD2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTPRF" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYD2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Alias de pages
If find("AYG",LSTOBJCOD) : # Commepour les sites il faut le préciser pour les suprrimer
 Call TITOBJ("AYG","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYG2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTPAG" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYG2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Site (gestion particulière)
If find("AYS",LSTOBJCOD)
 Call TITOBJ("AYS","",WMSG) From CONTOBJ  :  Call ECR_TRACE(mess(53,123,1)-WMSG,0) From GESECRAN
 Gosub TEMPON
 Delete [AYS2] Where FCYCOD=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTFCY" : Goto ROLL_TR_DEL
 Elsif fstat>5
  GOK = 0 : Call RSTA("AYS2","") From GLOCK : Goto AB_TR_DEL
 Endif
 If TRADETFLG : Call ECR_TRACE(WSP+mess(209,7900,1)-num$(adxdlrec),0) From GESECRAN : Endif
Endif

# Suppression de atextra correspondant a chaque table
Local Char TAB
For TAB="AYTACT","AYTELTBLC","AYTELTBLCW","AYTELTDLK","AYTELTFLD","AYTENT","AYTFCY","AYTINT","AYTMEN","AYTMES","AYTPAG","AYTPRF"
 Delete [AXX2] Where CODFIC = TAB & IDENT1=[L]FCYDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTFCY" : Break
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Break
 Endif
Next TAB
If GOK=-1 : Goto ROLL_TR_DEL
Elsif fstat>5 : Goto AB_TR_DEL
Endif

Commit
Return

$AB_TR_DEL
RET=0
Rollback
Return

$ROLL_TR_DEL
Rollback
Call ROLL From GLOCK
If GROLL : RET=0 : Return : Else : Goto TR_DEL : Endif


# Gestion popup
#------------------------------------------------------------#
$TEMPON
