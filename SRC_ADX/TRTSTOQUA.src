######################################################################################


#                                                                   # hcb 110327 deb
Subprog IB_NBLIG
# No séries concernés
GBOUT1 = mess(655,199,1)
# pas de saisie des series concernés si :
# saisie détail impossible
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
If [F:ITM]SERMGTCOD <> 4 | [M:SQD]WSTOCOU1 = 0 | [M:SQD]QTYSTUDES (nolign-1)= 0
   Raz GBOUT1
Endif

End

Subprog B1_NBLIG
Local Integer LRET
Local Integer LSEQ
Local Decimal LQTYSTU

GOUVCHGS = 2
If [M:SQD]WSTJFLG(nolign-1) <> 0 | [M:STQ1]VALFLG = 2 | GCONSULT
   GOUVCHGS = 9
   End
Endif

Call DELSTOCHGW(LABR, [M:SQD]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB
LSEQ = [M:SQD]WSTOSEQ
I = find(0,[M:SQD]WSTJFLG(0..[M:SQD]NBLIG-1))-1
If I>=0
   Call FILLCHGW("SQD", I, [M:SQD]NBLIG-I, LSEQ, [M:SQD]STOFCY, LRET, LQTYSTU) From SUBSCSB
Endif

End


Subprog AM_QTYPCUDES(VALEUR)
Variable Decimal VALEUR
If [F:ITM]SERMGTCOD = 4 & [M:SQD]QTYPCUDES(nolign-1) <> VALEUR
   Raz   [M:SQD]SERNUM (nolign-1)
   Raz   [M:SQD]SERNUMF(nolign-1)
   Affzo [M:SQD]SERNUM (nolign-1)
   Affzo [M:SQD]SERNUMF(nolign-1)
Endif
End


