#<AdxTL>@(#)0.0.0.0 $Revision$ Détails qualité
#####################################################################
# Action     SAISTOQUA : Saisie du détail de contrôle qualité       #
# Fenêtre    ISTOQUA                                                #
# Ecran      STOQUA                                                 #
# Traitement supplémentaire : TRTSTOQUAB                            #
#####################################################################
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "TITRE"       : Gosub TIT_TRT
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "DEBUT"       : Gosub DEBUT
    When "AVANT_MEN"   : Gosub AVANT_MEN
    When "AVANT_BOUTON":
        Case BOUT
            When "E"   : Gosub AVANT_ENR
        Endcase
    When "BOUTON" :
        Case BOUT
            When "E"   : Gosub ENR
            When "A"   : Gosub ABANDON
        Endcase
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "END"         : Gosub ACTEND
    When "FINSAI"      : Gosub FINSAI
    When "SETBOUT"     : Gosub SETBOUT
    When "OK"          : Gosub OK
    When Default       :
Endcase

Return

$OK
#------------------------------#
# Apres exécution du bouton OK #
#------------------------------#
mkstat=4
Return

$APRES_MODIF
#-------------#
# Après modif #
#-------------#
REP="M"
Return

$SET_NOL
Local Integer NOL
NOL = nolign-1
Return

$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","8",GSTQNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GSTQNUM-":"-TIT
Return

##################################################
$OUVRE

Local Integer SAVCONS : SAVCONS=GCONSULT
If !GOUVENT
   FIN = 1
   Return
Endif
If dim(GMAJLIGDOC)<=0
   Global Integer GMAJLIGDOC
Endif
Raz GMAJLIGDOC
Global Integer LLIGDOC   : LLIGDOC = val(PARAM(1))             # hcb 110327
Global Char    LABR(5)   : LABR    = PARAM(2)                  # hcb 110327
Local Integer LLIGDOC   : LLIGDOC = val(PARAM(1))
Local Char    LABR(5)   : LABR    = PARAM(2)
Local Char    LMABR(10) : LMABR   = "[M:"+LABR+"]"
Local Decimal W_QTE
Local Integer J
GOUVENT = 1    # Pour pouvoir ouvrir le complément lot
# Initialisation de GOUVLOT (valable pour tout le document)
GOUVLOT = 30    # Modif des rubriques utilisateur
#-- Si article titré
If [F:ITF]STOMGTCOD=3 | [F:ITF]STOMGTCOD=4
#                                                         # hcb X3-43207 deb
# Modification du titre  du lot uniquement si toutes les lignes du lot sont dans ce controle qualité

   Filter [STO] Where ITMREF     =  [M:STQ1]ITMREF
&                    & LOT       =  [M:STQ1]LOT(LLIGDOC)
&                    & SLO       =  [M:STQ1]SLO(LLIGDOC)
&                    & QLYCTLDEM <> [M:STQ1]VCRNUM
   Look [STO]STO3 First
   Filter [STO]
   If fstat
#                                                         # hcb X3-43207 end
   Read [STO]STO0=[M:STQ1]STOFCY;[M:STQ1]WSTOCOU(LLIGDOC)
   If fstat : Raz [F:STO] Endif
   W_QTE=sigma(J=0,[M:SGW]NBLIG-1,[M:SGW]WWIPQTY(J)*([M:SGW]WSTOSEQ(J)=[M:STQ1]WSTOSEQ(LLIGDOC)))
   If W_QTE>=[F:STO]CUMWIPQTY
    #-- Gestion du titre
      If [F:ITF]STOMGTCOD=3
         GOUVLOT += 32
      Elsif [F:ITF]STOMGTCOD=4
         GOUVLOT += 64
      Endif
   Endif
   Endif                                                  # hcb X3-43207
Endif
If [F:ITM]EXYMGTCOD>1
   GOUVLOT += 128
Endif
Return

##################################################
$OUVRE_BOITE

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif

# ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
BOITE = "WQSQD"+GSTQNUM+"S"            # hcb 50197
GBOITE = BOITE
Call NOMTRTWIN(BOITE,WINPROG) From MSKDIV

Gosub FORMAT_INV From STKLIB
Gosub FORMAT_INV_CHG From STKLIB                               # hcb 110327

If [F:ITM]SERMGTCOD=2 & evalue("dim("+LMABR+"SERNUMDEP)")>0 & evalue(LMABR+"SERNUMDEP(LLIGDOC)")=""
    GWSINVSER = "-"+GSINVSER
    GWSINVSERF= "-"+GSINVSERF
    GWSINTSER = ""
    GWSINTSERF= ""
Endif
Return

##################################################
$SETBOUT
If evalue(LMABR+"QLYCRD")=""
   Call VIREBOUT(CHMEN,"Of") From GOBJET
Endif
If REP<>"M"
   Call VIREBOUT(CHMEN,"E,A") From GOBJET
Endif
If [M:STQ1]VALFLG=2 | [M:STQ1]WSTJQTY(LLIGDOC)=[M:STQ1]QTYSTU(LLIGDOC)
   Call VIREBOUT(CHMEN,"E,A") From GOBJET
Endif
Return

##################################################
$DEBUT
Local Integer I
Local Integer LRET
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Raz [M:SQD]
# Ne pas déplacer le Diszo (fait avant l'actzo de iptdat)
Diszo [M:SQD]5-15

Call TEXTE(3569,[M:SQD]TOTLIG) From OBJDIV
Call TEXTE(8094,[M:SQD]TOTPEC) From OBJDIV

[M:SQD]STOFCY     = PARAM(3)
[M:SQD]ITMREF     = PARAM(4)
[M:SQD]QLYCRD     = evalue(LMABR+"QLYCRD")
[M:SQD]CRDSEQ     = evalue(LMABR+"CRDSEQ(LLIGDOC)")
[M:SQD]IPTDAT     = evalue(LMABR+"IPTDAT(LLIGDOC)")

[M:SQD]TRSTYP     = val(PARAM(5))
[M:SQD]TRSCOD     = PARAM(6)
[M:SQD]VCRTYP     = val(PARAM(7))
[M:SQD]VCRNUM     = PARAM(8)
[M:SQD]VCRLIN     = val(PARAM(9))

If dim([M:SQD]LOT)>0
   [M:SQD]LOT        = evalue(LMABR+"LOT(LLIGDOC)")
   [L]WLOT           = [M:SQD]LOT
Endif
If dim([M:SQD]SLO)>0
   [M:SQD]SLO        = evalue(LMABR+"SLO(LLIGDOC)")
   [L]WSLO           = [M:SQD]SLO
Endif
[M:SQD]POT        = evalue(LMABR+"POT(LLIGDOC)")
If dim([M:SQD]LOCTYP)>0
   [M:SQD]LOCTYP     = evalue(LMABR+"LOCTYP(LLIGDOC)")
   [M:SQD]LOC        = evalue(LMABR+"LOC(LLIGDOC)")
Endif
[M:SQD]STA        = evalue(LMABR+"STA(LLIGDOC)")
If [F:ITM]SERMGTCOD>1 & dim([M:SQD]SERNUMDEP)>0
   [M:SQD]SERNUMDEP  = evalue(LMABR+"SERNUMDEP(LLIGDOC)")
   [M:SQD]SERNUMFDEP = evalue(LMABR+"SERNUMFDEP(LLIGDOC)")
Endif
If dim([M:SQD]WRH)>0
   [M:SQD]WRH     = evalue(LMABR+"WRH(LLIGDOC)")
Endif
If dim([M:SQD]PALNUM)>0
   [M:SQD]PALNUM     = evalue(LMABR+"PALNUM(LLIGDOC)")
Endif
If dim([M:SQD]CTRNUM)>0
   [M:SQD]CTRNUM     = evalue(LMABR+"CTRNUM(LLIGDOC)")
Endif
If dim([M:SQD]STOFLD1)>0
   [M:SQD]STOFLD1    = evalue(LMABR+"STOFLD1(LLIGDOC)")
Endif
If dim([M:SQD]STOFLD2)>0
   [M:SQD]STOFLD2    = evalue(LMABR+"STOFLD2(LLIGDOC)")
Endif
#                                                                                         # hcb X3-77043 deb
If dim([M:SQD]LPNNUM)>0
   [M:SQD]LPNNUM    = evalue(LMABR+"LPNNUM(LLIGDOC)")
Endif
# si la transaction ne permet pas la modification de l'emplacement la selection sur LPNNUMDES
# affiche les Contenants ayant le meme emplacement ou ceux n ayant pas d'emplacement
Raz [M:SQD]LOCSELLPN
If dim([M:SQD]LPNNUM)>0 & [M:SQD]LPNNUM <> "" & [F:SRT]CHGEMPCOD <> 2
   [M:SQD]LOCSELLPN = [M:SQD]LOC
Endif
[M:SQD]LOTACT = [M:STQ1]LOTACT
#                                                                                         # hcb X3-77043 fin
#
[M:SQD]OWNER      = evalue(LMABR+"OWNER(LLIGDOC)")
[M:SQD]QTYPCU     = evalue(LMABR+"QTYPCU(LLIGDOC)")
[M:SQD]PCU        = evalue(LMABR+"PCU(LLIGDOC)")
[M:SQD]PCUSTUCOE  = evalue(LMABR+"PCUSTUCOE(LLIGDOC)")
[M:SQD]QTYSTU     = evalue(LMABR+"QTYSTU(LLIGDOC)")
[M:SQD]STU        = evalue(LMABR+"STU")
[M:SQD]WSTOCOU1   = evalue(LMABR+"WSTOCOU(LLIGDOC)")                 # hcb 110327
[M:SQD]COEUCUS = "1"-[M:SQD]PCU-"="-num$([M:SQD]PCUSTUCOE)-[M:SQD]STU

If [M:STQ1]VALFLG=2                                                                     # hcb 50950
   Call POSTABLE2([M:SQD]STOFCY, [M:SQD]ITMREF, [L]WLOT, [L]WSLO, LRET) From TRTSTOQUAB # hcb 50950
Else                                                                                    # hcb 50950
   Call POSTABLE([M:SQD]STOFCY, [M:SQD]ITMREF, [L]WLOT, [L]WSLO, LRET) From SUBSCSB
   If LRET
      FIN = 1
      Return
   Endif
Endif                                                                                   # hcb 50950


Raz [M:SQD]WSTJFLG
Gosub LOAD_FROM_STJ From TRTSTOQUAB
        If [M:SQD]NBLIG=0 & dim([M:SQD]IPTDAT)>0
            [M:SQD]IPTDAT = date$
            Actzo [M:SQD]IPTDAT
#                                                                # hcb X3-106063 deb
        Else
            Call STKCTRIPT( [M:SQD]IPTDAT,[M:SQD]STOFCY, "1") From STKLIB
            If GERR=1
               Call ERREUR(GMESSAGE) From GESECRAN
               Raz GERR
               Raz GMESSAGE
               LNBLIG = [M:SQD]NBLIG
               Gosub LOAD_FROM_SGW From TRTSTOQUAB
               Gosub MAJ_PECQTY    From TRTSTOQUAB
               Affzo [M:SQD]1-99
               Grizo [M:SQD]
               Return
            Endif
#                                                                # hcb X3-106063 fin
        Endif
        If dim([M:SQD]PCUDES)>0
            Diszo [M:SQD]PCUDES
            Actzo [M:SQD]PCUDES([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]QTYPCUDES)>0
            Diszo [M:SQD]QTYPCUDES
            Actzo [M:SQD]QTYPCUDES([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]COEDES)>0
            Diszo [M:SQD]COEDES
            Actzo [M:SQD]COEDES([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]STADES)>0
            Diszo [M:SQD]STADES
            Actzo [M:SQD]STADES([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]SERNUM)>0
            Diszo [M:SQD]SERNUM
            Actzo [M:SQD]SERNUM([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]LOCDES)>0
            Diszo [M:SQD]LOCDES
            Actzo [M:SQD]LOCDES([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]WRHDES)>0
            Diszo [M:SQD]WRHDES
            Actzo [M:SQD]WRHDES([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]LOCTYPDES)>0
            Diszo [M:SQD]LOCTYPDES
            Actzo [M:SQD]LOCTYPDES([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]LBEFMT)>0
            Diszo [M:SQD]LBEFMT
            Actzo [M:SQD]LBEFMT([M:SQD]NBLIG)
        Endif
        If dim([M:SQD]LBENBR)>0
            Diszo [M:SQD]LBENBR
            Actzo [M:SQD]LBENBR([M:SQD]NBLIG)
        Endif
#                                                                                         # hcb X3-77043 deb
        If dim([M:SQD]LPNNUMDES)>0
           Diszo [M:SQD]LPNNUMDES
           Actzo [M:SQD]LPNNUMDES([M:SQD]NBLIG)
        Endif
#                                                                                         # hcb X3-77043 deb

LNBLIG = [M:SQD]NBLIG
Gosub LOAD_FROM_SGW From TRTSTOQUAB
Gosub MAJ_PECQTY    From TRTSTOQUAB

# Maj ecran SQD  (hcb demande PE 37203)
GPOINT="MAJ_SQD" : Gosub ENTREE From EXEFNC

# Si toute la quantité a déjà changé de statut (STJ) => on grise tout
If [M:SQD]NBLIG=LNBLIG & [M:SQD]PECQTYSTU=[M:SQD]QTYSTU
    Diszo [M:SQD]20
Endif
Read [ACC]CODACC=GUSER;[F:ITF]QUAACS
If fstat | [F:ACC]MODIF<>2
   Diszo [M:SQD]20
Endif

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
If GWRHACT = 2
   If [M]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[M]STOFCY
   Endif
   If [F:FCY]WRHGES <> 2
      Grizo [M:SQD]WRHDES
   Endif
Endif

#-------- Pour afficher les colonnes correctement même s'il n'y a pas de ligne -------#
# mis en commentaire le 22 12 2016 pb pb automatisation   V12
#If [M:SQD]NBLIG=0
#   [M:SQD]NBLIG=1
#    Affzo [M:SQD]1-99
#    [M:SQD]NBLIG=0
#Endif

Affzo [M:SQD]1-99
Return

#############################################################
$AVANT_MEN
# Si toute la quantité a déjà changé de statut (STJ) => on grise tout
If [M:SQD]NBLIG=LNBLIG & [M:SQD]PECQTYSTU=[M:SQD]QTYSTU
  GCONSULT=1
Endif
Return

#############################################################
$AVANT_ENR
Local Integer  LRET
Local Shortint WRET
Local Integer  LLIG
Local Integer  J, K, L                      # hcb X3-77043
Local Char     MES(255)
Local Integer  LNBNEWLIG

LNBNEWLIG = sigma(0,[M:SQD]NBLIG-1,[M:SQD]WSTJFLG(indcum)<>1)
If LNBNEWLIG=0
   Return
Endif

Raz FOK

#------------------------------------------------------------------------------#
# Vérification que toutes les lignes saisies peuvent être entrées dans STOCHGW #
#------------------------------------------------------------------------------#
If [M:SGW]NBLIG+[M:SQD]NBLIG > dim([M:SGW]WSTOSEQ)
    Call ERREUR(mess(36,184,1)+"\"+mess(353,199,1)) From GESECRAN
    Return
Endif

#--------------------------------#
# controle saisie lignes entrées #
#--------------------------------#
LRET = 0
GERR = 0                                                             # hcb X3-77043
For LLIG = 0 To [M:SQD]NBLIG-1
    Call CTRLIG("SQD",LLIG, LRET) From SUBSCSB
    If LRET > 0
        MES  = mess(93,100,1)+":"+num$(LLIG+1)+"\"
        If LRET=256
            MES += mess(67,184,1)+"\"        # Ligne stock en inventaire
        Else
            MES += mess(7,111,1) +":\"
            If mod(LRET ,2)>=1
                MES += mess(23,197,1)+"\"    # Unités
            Endif
            If mod(LRET ,4)>=2
                MES += mess(9,184,1)+"\"     # Quantité doit être >0
            Endif
            If mod(LRET ,8)>=4
                MES += mess(398,198,1)+"\"   # Coeff
            Endif
            If mod(LRET ,16)>=8
                MES += mess(24,197,1)+"\"    # Statut
            Endif
            If mod(LRET ,32)>=16 | mod(LRET ,64)>=32
                MES += mess(2,181,1)+"\"     # Emplacement / Type Emplacement
            Endif
            If mod(LRET ,128)>=64
                MES += mess(47,197,1)        # N° de série non saisi
            Endif
#                                                                                       # hcb 110327 deb
            If mod(LRET ,1024)>=512
                MES += mess(246,199,1)        # # Le nb de no série ne correspond pas à la qté à traiter
            Endif
#                                                                                       # hcb 110327 end
        Endif
    Endif
    If LRET : Break : Endif
#                                                             # hcb X3-77043 deb
# controle meme emplacement pour chaque contenant
    If [F:ITF]LPNMGTCOD = 2 & [F:SRT]CHGEMPCOD = 2 & [M:SQD]LPNNUMDES(LLIG) <> ""
#--- Contrôle du mono-emplacement par LPN
       K=sigma(LLIG+1,[M:SQD]NBLIG-1,1*([M:SQD]LPNNUMDES(indcum)=[M:SQD]LPNNUMDES(LLIG) & [M:SQD]WSTJFLG(indcum)=0))
       L=sigma(LLIG+1,[M:SQD]NBLIG-1,1*([M:SQD]LPNNUMDES(indcum)=[M:SQD]LPNNUMDES(LLIG) & [M:SQD]WSTJFLG(indcum)=0
&                & [M:SQD]LOCDES(indcum)=[M:SQD]LOCDES(LLIG)))
       If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:SQD]LPNNUMDES(LLIG),[M:SQD]LOCDES(LLIG))) From GESECRAN
          GERR=1
          Break
       Endif
    Endif
Next
If GERR = 1                                                   # hcb X3-77043
   Return                                                     # hcb X3-77043
Endif                                                         # hcb X3-77043
If LRET
    Call ERREUR(MES) From GESECRAN  # Ligne incomplete
    FOK= 0
    Return
Endif
#                                                                       # hcb 110327 deb
Raz GERR
If [M:SQD]NBLIG>1 & [F:ITM]SERMGTCOD = 4
   # Vérification que les plages de no série sont bien croissantes
   Sorta [M:SQD]NBLIG [M:SQD]NBLIG Order By [M:SQD]SERNUM([S]indice)
   For J=1 To [M:SQD]NBLIG-1
      If [M:SQD]SERNUM(J) <= [M:SQD]SERNUMF(J-1)
         GMESSAGE = mess(464,199,1)                # numeros de série incorrectes des numeros sont présents plusieurs fois
         GERR=1
         FOK=0
         Break
      Endif
   Next J
Endif
If GERR = 1
   Return
Endif
#                                                                       # hcb 110327 fin

FOK=1

Return

##################################################
$ENR
    Local Integer LRET
    Local Integer LSEQ
    Local Decimal LQTYSTU
    Local Char    LPCU(GLONUOM)
    Local Decimal LCOEF
    Local Char    LSTA(GLONSTA)
    Local Char    LLOCTYP(GLONTLO)
    Local Char    LLOC(GLONLOC)
    Local Char    LWRH(GLONWRH)
    Local Char    LSER(GLONSER), LSERF(GLONSER)
    Local Integer LQLYFLG
    Local Date    LDAT
    Local Decimal LAAA, LRRR

    LPCU    = string$( !!( sigma(I=0,[M:SQD]NBLIG-1,([M:SQD]PCUDES(0)=[M:SQD]PCUDES(I))) = [M:SQD]NBLIG), [M:SQD]PCUDES(0))
    LCOEF   = !!( sigma(I=0,[M:SQD]NBLIG-1,([M:SQD]COEDES(0)=[M:SQD]COEDES(I))) = [M:SQD]NBLIG)* [M:SQD]COEDES(0)

    Call DELSTOCHGW(LABR, [M:SQD]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB
    LSEQ = [M:SQD]WSTOSEQ
    I = find(0,[M:SQD]WSTJFLG(0..[M:SQD]NBLIG-1))-1
    If I>=0
        Call FILLCHGW("SQD", I, [M:SQD]NBLIG-I, LSEQ, [M:SQD]STOFCY, LRET, LQTYSTU) From SUBSCSB
        # La ligne chargée n'est pas correcte
        If LRET<>0 | GERR=2
          LRET=99
        Endif
        If LQTYSTU=0
            Call ERREUR(mess(367,199,1)) From GESECRAN
        Elsif LQTYSTU<[M:SQD]PECQTYSTU-sigma(0,[M:SQD]NBLIG-1,[M:SQD]QTYSTUDES(indcum)*[M:SQD]WSTJFLG(indcum))
            Call MESSAGE( mess(275,198,1)-":"-num$(LQTYSTU)-"/"-num$([M:SQD]PECQTYSTU) ) From GESECRAN
        Endif
    Endif

    LQTYSTU += sigma(0,[M:SQD]NBLIG-1,[M:SQD]QTYSTUDES(indcum)*[M:SQD]WSTJFLG(indcum))
    If LNBNEWLIG=0 & LQTYSTU<>0
        Call RECSTO_F (LABR,[M:STQ1]ITMREF,[M:STQ1]STOFCY,[M:STQ1]VCRTYP,
&                      [M:STQ1]VCRNUM,[M:STQ1]VCRLIN(LLIGDOC),LLIGDOC,"",
&                      LAAA,LRRR) From SUBSTQB
    Else
        Call RECSTO_MF (LABR,[M:STQ1]ITMREF,[M:STQ1]STOFCY,[M:STQ1]VCRTYP,
&                       [M:STQ1]VCRNUM,[M:STQ1]VCRLIN(LLIGDOC),LLIGDOC,
&                       [M:SQD]WSTOSEQ,"") From SUBSTQB
    Endif
    Default Mask "["+LABR+"]"
    LSTJEXI = evalue(LMABR+"WSTJQTY(LLIGDOC)")>0
    If [M:SQD]NBLIG>1 | LSTJEXI
        Diszo [M]STADES(LLIGDOC)
    Elsif !LSTJEXI
        Actzo [M]STADES(LLIGDOC)
    Endif
    If evalue("dim("+LMABR+"LOCTYPDES)")>0
        If [M:SQD]NBLIG>1 | LSTJEXI
            Diszo [M]LOCTYPDES(LLIGDOC)
        Elsif !LSTJEXI
            Actzo [M]LOCTYPDES(LLIGDOC)
        Endif
    Endif
    If evalue("dim("+LMABR+"LOCDES)")>0
        If [M:SQD]NBLIG>1 | LSTJEXI
            Diszo [M]LOCDES(LLIGDOC)
        Elsif !LSTJEXI
            Actzo [M]LOCDES(LLIGDOC)
        Endif
    Endif
#                                                              # hcb x3-77043 deb
   If evalue("dim("+LMABR+"LPNNUMDES)")>0
        If [M:SQD]NBLIG>1 | LSTJEXI
            Diszo [M]LPNNUMDES(LLIGDOC)
        Elsif !LSTJEXI
            Actzo [M]LPNNUMDES(LLIGDOC)
        Endif
    Endif
#                                                              # hcb x3-77043 fin
    If evalue("dim("+LMABR+"WRHDES)")>0
        If [M:SQD]NBLIG>1 | LSTJEXI
            Diszo [M]WRHDES(LLIGDOC)
        Elsif !LSTJEXI
            Actzo [M]WRHDES(LLIGDOC)
        Endif
    Endif
    If evalue("dim("+LMABR+"SERNUM)")>0
        If [M:SQD]NBLIG>1 | LSTJEXI
            Diszo [M]SERNUM(LLIGDOC)
        Elsif !LSTJEXI
            Actzo [M]SERNUM(LLIGDOC)
        Endif
    Endif
    Assign LMABR+"IPTDAT(LLIGDOC)"  With [M:SQD]IPTDAT
    If LRET=99
        Assign LMABR+"WSTOFLG(LLIGDOC)" With 0
    Else
        Assign LMABR+"WSTOFLG(LLIGDOC)" With 1
    Endif
    Default Mask [SQD]
    Gosub MAJ_LIG_DOC From SUBSCSB
    #-- Mise à jour des zones concernant la péremption
    If evalue("dim("+LMABR+"REFPER)")>0
        Assign LMABR+"REFPER(LLIGDOC)"  With [M:SQD]REFPER
        Affzo [M]REFPER(LLIGDOC)
    Endif
    If evalue("dim("+LMABR+"SHL)")>0
        Assign LMABR+"SHL(LLIGDOC)"     With [M:SQD]SHL
        Affzo [M]SHL(LLIGDOC)
    Endif
    If evalue("dim("+LMABR+"SHLDAT)")>0
        Assign LMABR+"SHLDAT(LLIGDOC)"  With [M:SQD]SHLDAT
        Affzo [M]SHLDAT(LLIGDOC)
    Endif
    If evalue("dim("+LMABR+"BPSLOT)")>0
        Assign LMABR+"BPSLOT(LLIGDOC)"  With [M:SQD]BPSLOT
    Endif
FIN=1
If LNBNEWLIG>0    #calculé en AVANT_ENR
    GMAJLIGDOC=1
    mkstat=4
Endif

Return


##################################################
$ABANDON
    Gosub ANNULE
    Raz [M:SQD]
    Raz REP
    Gosub DEBUT
Return

##########################################################################
$ANNULE
Local Integer  I
Local Integer  LRET
Local Shortint WRET

    For I=0 To [M:SQD]NBLIG-1
       If [M:SQD]WLOCSEQ(I)<>0 & dim([M:SQD]LOCDES)>0
        Call STKDELRES([M:SQD]WLOCSEQ(I), [M:SQD]STOFCY, [M:SQD]LOCDES(I), LRET) From STKLOC
       Endif
    Next

    I=find([M:SQD]WSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
    While I>0 & I<dim([M:SGW]WSTOSEQ) & [M:SGW]WSTOSEQ(I)=[M:SQD]WSTOSEQ
        If [M:SGW]WLOCDES(I) = [M:SQD]LOC
            Call STKVALEMP([M:SGW]WLOCSEQ(I),
&                      [M:SQD]TRSTYP,[M:SQD]TRSCOD,
&                      [M:SQD]STOFCY,[M:SQD]ITMREF,
&                      [M:SGW]WPCUDES(I),
&                      [M:SQD]QTYPCU,[M:SGW]WQTYPCUDES(I),
&                      [M:SGW]WSTADES(I),[M:SGW]WLOCTYPDES(I),
&                      [M:SGW]WLOCDES(I),"",WRET,GBIDD1,"","") From STKLOC
        Else
            Call STKCTREMP([M:SGW]WLOCSEQ(I),
&                      [M:SQD]TRSTYP,[M:SQD]TRSCOD,
&                      [M:SQD]STOFCY,[M:SQD]ITMREF,
&                      [M:SGW]WPCUDES(I),
&                      [M:SGW]WQTYPCUDES(I),
&                      [M:SGW]WSTADES(I),[M:SGW]WLOCTYPDES(I),
&                      [M:SGW]WLOCDES(I),"",1,WRET,GBIDD1,"","",
&                      "") From STKLOC
        Endif

        I += 1
    Wend
Return

##########################################################################
$ACTEND
    Gosub ANNULE
Return

##########################################################################
$FINSAI
GCONSULT=SAVCONS
Return
##########################################################################
Subprog C_NBLIG
Local Integer I
Local Integer LRET
Gosub SET_NOL

Case status
    When 73, 82:

        If [M:SQD]PECQTYSTU=[M:SQD]QTYSTU
            mkstat=2
        Elsif [M:SGW]NBLIG+[M:SQD]NBLIG+1>=dim([M:SGW]WSTOSEQ)
            mkstat=2
            GMESSAGE=mess(36,184,1)
        Endif

    # annulation d une ligne
    When 65 :
        If [M:SQD]WSTJFLG(nolign-1)=0 & [M:SQD]WLOCSEQ(nolign-1)<>0 & dim([M:SQD]LOCDES)>0
            Call STKDELRES([M:SQD]WLOCSEQ(nolign-1), [M:SQD]STOFCY, [M:SQD]LOCDES(nolign-1), LRET) From STKLOC
            [M:SQD]QTYSTUDES(nolign-1) = 0
            Gosub MAJ_PECQTY From TRTSTOQUAB
        Else
            mkstat=2
        Endif

    # annulation d'un groupe de lignes
    When 68,83 :
        If [M:SQD]WSTJFLG(nolign-1)=0
            For I=nolign-1 To nolign1
               If [M:SQD]WLOCSEQ(I)<>0 & dim([M:SQD]LOCDES)>0
                 Call STKDELRES([M:SQD]WLOCSEQ(I), [M:SQD]STOFCY, [M:SQD]LOCDES(I), LRET) From STKLOC
               Endif
               [M:SQD]QTYSTUDES(I) = 0
            Next
            Gosub MAJ_PECQTY From TRTSTOQUAB
        Else
            mkstat=2
        Endif
Endcase

    # Pour saisir un complément lot il faut:
    # un lot et des nouveaux mouvements (pour pouvoir enregistrer ces modif)
    If dim([M:SQD]LOT)<=0 | [M:SQD]LOT="" | [M:SQD]NBLIG=0 | !(sigma(0,[M:SQD]NBLIG-1,[M:SQD]WSTJFLG(indcum)>0)<[M:SQD]NBLIG)
        [M:SQD]MODIF = 1
    Else
        [M:SQD]MODIF = 2
    Endif

End

##########################################################################
Subprog AVANT_NBLIG
Local Integer LRET
Local Char    WWRH(GLONWRH)

    If [M:SQD]QTYSTUDES(nolign-1)=0
        If nolign-1=0
            [M:SQD]PCUDES(nolign-1)    = [M:SQD]PCU
            [M:SQD]COEDES(nolign-1)    = [M:SQD]PCUSTUCOE
            If dim([M:SQD]LPNNUMDES)>0                                            # hcb x3-77043
               [M:SQD]LPNNUMDES(nolign-1) = [M:SQD]LPNNUM                         # hcb x3-77043
            Endif                                                                 # hcb x3-77043
            If [M:STQ1]DEFSTA <> ""  &   [M:STQ1]DEFSTA <> [M:SQD]STA
               [M:SQD]STADES(nolign-1) = [M:STQ1]DEFSTA
            Endif
            If dim ([M:SQD]WRHDES)> 0
               [M:SQD]WRHDES(nolign-1) = [M:SQD]WRH
            Endif

            If [M:SQD]STADES(nolign-1)<>"" & [F:ITF]LOCMGTCOD=2
              If [F:ITF]ITMREF<>[M:SQD]ITMREF | [F:ITF]STOFCY<>[M:SQD]STOFCY
                Read [ITF]ITF0 = [M:SQD]ITMREF; [M:SQD]STOFCY
                If fstat : Raz [F:ITF] : Endif
              Endif
              If dim([M:SQD]WRH) > 0
                WWRH=[M:SQD]WRH
              Else
                WWRH=""
              Endif
              Call STKCTRTLO([M:SQD]WLOCSEQ(nolign-1),[M:SQD]TRSTYP,[M:SQD]TRSCOD,[M:SQD]STOFCY,[M:SQD]ITMREF
&                           ,[M:SQD]PCUDES(nolign-1),[M:SQD]QTYPCUDES(nolign-1),[M:SQD]STADES(nolign-1)
&                           ,0,[M:SQD]LOCTYP,mkstat,"QU","",WWRH) From STKLOC
              If !mkstat & [M:SQD]LOC<>""
                Call STKCTREMP([M:SQD]WLOCSEQ(nolign-1),[M:SQD]TRSTYP,[M:SQD]TRSCOD,[M:SQD]STOFCY
&                             ,[M:SQD]ITMREF,[M:SQD]PCUDES(nolign-1),[M:SQD]QTYPCUDES(nolign-1),[M:SQD]STADES(nolign-1)
&                             ,[M:SQD]LOCTYP,[M:SQD]LOC,"",0,mkstat,GBIDD1,"QU","",WWRH) From STKLOC
                If !mkstat
                  [M:SQD]LOCTYPDES(nolign-1)=[M:SQD]LOCTYP
                  [M:SQD]LOCDES(nolign-1)   =[M:SQD]LOC
                  If dim ([M:SQD]WRHDES)> 0
                     [M:SQD]WRHDES(nolign-1)=[M:SQD]WRH
                  Endif
                Endif
              Endif
            Endif
            #---

        Else
            [M:SQD]PCUDES(nolign-1)    = [M:SQD]PCUDES(nolign-2)
            [M:SQD]COEDES(nolign-1)    = [M:SQD]COEDES(nolign-2)
            [M:SQD]STADES(nolign-1)    = [M:SQD]STADES(nolign-2)
            If dim([M:SQD]LPNNUMDES)>0                                                 # hcb x3-77043
               [M:SQD]LPNNUMDES(nolign-1) = [M:SQD]LPNNUMDES(nolign-2)                 # hcb x3-77043
            Endif                                                                      # hcb x3-77043
        Endif
        If dim([M:SQD]SERNUM)>0 & [M:SQD]SERNUMDEP<>""
            If nolign=1
                [M:SQD]SERNUM(nolign-1) = [M:SQD]SERNUMDEP
            Elsif nolign>1 & [M:SQD]SERNUMF(nolign-2)<>""
                If [M:SQD]SERNUMFDEP <> [M:SQD]SERNUMF(nolign-2)
                    Call PLUS_UN([M:SQD]SERNUMF(nolign-2),[M:SQD]SERNUM(nolign-1),LRET) From STKLIB
                Endif
            Endif
        Endif
        If [F:ITF]LOCMGTCOD=2
            Call STKWLOCSEQ("SQD", nolign-1, LRET) From STKECR
            If nolign>1
                [M:SQD]LOCTYPDES(nolign-1) = [M:SQD]LOCTYPDES(nolign-2)
                [M:SQD]LOCDES   (nolign-1) = [M:SQD]LOCDES   (nolign-2)
                If dim([M:SQD]WRHDES) > 0
                   [M:SQD]WRHDES(nolign-1) = [M:SQD]WRHDES   (nolign-2)
                Endif
            Endif
            If sigma(0,[M:SQD]NBLIG-1,[M:SQD]WSTJFLG(indcum)=0)=0
                Call STKMODREMP([M:SQD]WLOCSEQ(nolign-1),
&                               [M:SQD]STOFCY,
&                               [M:SQD]ITMREF,
&                               [M:SQD]PCU,
&                               [M:SQD]QTYPCU-[M:SQD]PECQTYPCU,
&                               [M:SQD]STA,
&                               [M:SQD]LOC,
&                               "",mkstat,"") From STKLOC
            Endif
        Endif
 #       If dim([M:SQD]SERNUMDEP)>0 & [M:SQD]SERNUMDEP=""         # hcb X3-104511
         If dim([M:SQD]SERNUMDEP)>0                               # hcb X3-104511
            If [M:SQD]SERNUMDEP=""                                # hcb X3-104511
               Actzo [M:SQD]PCUDES(nolign-1),COEDES(nolign-1)
            Endif                                                 # hcb X3-104511
         Else                                                     # hcb X3-104511
            Actzo [M:SQD]PCUDES(nolign-1),COEDES(nolign-1)        # hcb X3-104511
        Endif
        Actzo [M:SQD]QTYPCUDES(nolign-1)
        If dim([M:SQD]STADES(nolign-1))>0
           Actzo [M:SQD]STADES(nolign-1)
        Endif
        If dim([M:SQD]SERNUM(nolign-1))>0
           Actzo [M:SQD]SERNUM(nolign-1)
        Endif
        If dim([M:SQD]WRHDES(nolign-1))>0
           Actzo [M:SQD]WRHDES(nolign-1)
        Endif
        If dim([M:SQD]LOCDES(nolign-1))>0
           Actzo [M:SQD]LOCTYPDES(nolign-1)
           Actzo [M:SQD]LOCDES(nolign-1)
        Endif
#                                                                                         # hcb x3-77043 deb
        If dim([M:SQD]LPNNUMDES)>0
           Actzo [M:SQD]LPNNUMDES(nolign-1)
        Endif
    Else
        If dim([M:SQD]LPNNUMDES) > 0
           If [M:SQD]LPNNUMDES               (nolign-1)<>""
              Read [LPN]LPN0=[M:SQD]LPNNUMDES(nolign-1)
              If !fstat & [F:LPN]LOC<>""
                 Diszo [M:SQD]LOCDES         (nolign-1)
                 Diszo [M:SQD]LOCTYPDES      (nolign-1)
              Endif
           Endif
        Endif
#                                                                                         # hcb x3-77043 fin
    Endif
End

##########################################################################
Subprog APRES_NBLIG
Local Integer     LRET
Local Shortint    WRET
Local Char        LSLO(GLONSLO)
Local Decimal     WOVF
Local Libelle LNOTPCU
Local Libelle LNOTCOE
Local Libelle LNOTSTA
Local Libelle LNOTLOC
Local Libelle LNOTLOF
Local Libelle LNOTLOT
Local Libelle LNOTSLO
Local Libelle LNOTSER
Local Libelle LNOTPAL
Local Libelle LNOTCTR
Local Integer LDUP
Local Integer I
Gosub SET_NOL
If [M:SQD]WLOCSEQ(NOL)=0 | [M:SQD]WLOCSEQ(NOL)=100000
    Call STKDELRES(100000,"","",LRET) From STKLOC
    [M:SQD]WLOCSEQ(NOL)=0
Endif
#                                                                 # hcb 110327 deb

If [F:ITM]SERMGTCOD = 4
   Local Integer LSEQIND
   Call WSTOSEQIND ("SQD",NOL+1, LSEQIND, LRET) From SUBSCSB
   If LRET
      End
   Endif
   [M:SQD]WSTOSEQIND(NOL) = LSEQIND
Endif

#                                                                 # hcb 110327 end

If adxgtb=1 | find(status,65,68,83)
    If [F:ITF]LOCMGTCOD=2 & dim([M:SQD]LOC) & [M:SQD]WLOCSEQ(NOL)<>100000
        # Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
        If [M:SGW]WLOCSEQCUR>100000 & [M:SGW]WLOCSEQCUR<>99999999
          [M:SGW]WLOCSEQCUR -= 100000
        Endif
        If [M:SGW]WLOCSEQCUR<>0
            Call STKDELRES([M:SGW]WLOCSEQCUR, [M:SQD]STOFCY, "", LRET) From STKLOC
            [M:SGW]WLOCSEQCUR = 99999999
        Endif
        If [M:SQD]WLOCSEQ(NOL)>0
            # Recréer les réservations
            Call STKCTREMP([M:SQD]WLOCSEQ(NOL),
&                          [M:SQD]TRSTYP,
&                          [M:SQD]TRSCOD,
&                          [M:SQD]STOFCY,
&                          [M:SQD]ITMREF,
&                          [M:SQD]PCUDES(NOL),
&                          [M:SQD]QTYPCUDES(NOL),
&                          [M:SQD]STADES(NOL),
&                          [M:SQD]LOCTYPDES(NOL),
&                          [M:SQD]LOCDES(NOL),
&                          "",0,WRET,WOVF,"","","") From STKLOC
        Endif
    Endif
    Gosub MAJ_PECQTY From TRTSTOQUAB
    End
Endif

# Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
If [M:SQD]WLOCSEQ(NOL)>100000
    [M:SQD]WLOCSEQ(NOL) -= 100000
Endif
If [M:SQD]WLOCSEQ(NOL)<>0 & dim([M:SQD]LOCDES)>0
# hcb 69752
   If [F:TLO]STOFCY <> [M:SQD]STOFCY | [F:TLO]LOCTYP <> [M:SQD]LOCTYPDES(NOL)
      Read [TLO]TLO0=[M:SQD]STOFCY;[M:SQD]LOCTYPDES(NOL)
      If fstat
         Raz [F:TLO]
      Endif
   Endif
   If [M:SQD]LOCDES(NOL) <> [M:SQD]LOC | [F:TLO]FILMGTFLG<>2
       Call STKDELRES([M:SQD]WLOCSEQ(NOL), [M:SQD]STOFCY, [M:SQD]LOCDES(NOL), LRET) From STKLOC
   Endif
    If !LRET
       Call STKCTREMP([M:SQD]WLOCSEQ(NOL),  [M:SQD]TRSTYP, [M:SQD]TRSCOD, [M:SQD]STOFCY,
&                      [M:SQD]ITMREF, [M:SQD]PCUDES(NOL), [M:SQD]QTYPCUDES(NOL), [M:SQD]STADES(NOL),
&                      [M:SQD]LOCTYPDES(NOL), [M:SQD]LOCDES(NOL), "", 1, mkstat, WOVF, "", "", "")
&                      From STKLOC
        [M:SGW]WLOCSEQCUR = 99999999
    Endif
Endif

End


##########################################################################
Subprog C_PCUDES(VALEUR)
Variable Char    VALEUR()
    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal LCOE

    Gosub SET_NOL

    Call CTLUOM ([M:SQD]ITMREF,3,"", VALEUR,LCOE, LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif

    If LMODIF=2
        Actzo [M:SQD]COEDES(NOL)
    Else
        Diszo [M:SQD]COEDES(NOL)
    Endif
    If VALEUR<>[M:SQD]PCUDES(NOL)
        [M:SQD]COEDES(NOL) = LCOE
    Endif
    [M:SQD]QTYSTUDES(NOL) = [M:SQD]QTYPCUDES(NOL) * [M:SQD]COEDES(NOL)
    Call QTEARR([M:SQD]QTYSTUDES(NOL),[M:SQD]STU) From TRTDIV    # hcb 113039
    Affzo [M:SQD]COEDES(NOL),QTYSTUDES(NOL)
    Gosub MAJ_PECQTY From TRTSTOQUAB
End

##########################################################################
Subprog C_QTYPCUDES(VALEUR)
Variable Decimal VALEUR

    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal WCOEF

    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
    If [F:SRT]SRTTYP<>8 | [F:SRT]SRTNUM<>GSTQNUM                    # hcb 50197
       Read [SRT]SRT0=8;GSTQNUM : If fstat  Raz [F:SRT] : Endif
    Endif
    Gosub SET_NOL

    If VALEUR = 0
        mkstat = 2
        End
    Endif

    If [F:SRT]UOMSAIFLG=2
        WCOEF = [M:SQD]COEDES(NOL)
        Call CTLUOM([M:SQD]ITMREF,3,"", [M:SQD]PCUDES(NOL),WCOEF, LUSCAV, LFMT, LMODIF) From STKACT
        If LMODIF<>2
            Call CTRNEWQTY( NOL, VALEUR, [M:SQD]COEDES(NOL) )  From TRTSTOQUAB
            If mkstat=2
                End
            Endif
            Diszo [M:SQD]COEDES(NOL)
        Else
            Actzo [M:SQD]COEDES(NOL)
        Endif
    Else
        Call CTRNEWQTY( NOL, VALEUR, [M:SQD]COEDES(NOL) )  From TRTSTOQUAB
        If mkstat=2
            End
        Endif
    Endif
    [M:SQD]QTYSTUDES(NOL) = VALEUR * [M:SQD]COEDES(NOL)
    Call QTEARR([M:SQD]QTYSTUDES(NOL),[M:SQD]STU) From TRTDIV    # hcb 113039
    Affzo [M:SQD]QTYSTUDES(NOL)

    Gosub MAJ_PECQTY From TRTSTOQUAB

End

##########################################################################
Subprog C_COEDES(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL

    If VALEUR = 0
        mkstat=2
    Endif

    Call CTRNEWQTY( NOL, [M:SQD]QTYPCUDES(NOL), VALEUR ) From TRTSTOQUAB
    If mkstat=2
        End
    Endif
    [M:SQD]QTYSTUDES(NOL) = [M:SQD]QTYPCUDES(NOL) * VALEUR
    Call QTEARR([M:SQD]QTYSTUDES(NOL),[M:SQD]STU) From TRTDIV    # hcb 113039
    Affzo QTYSTUDES(NOL)
    Gosub MAJ_PECQTY From TRTSTOQUAB

End

##########################################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
Local Char LSERF(GLONSER)

    If [M:SQD]SERNUMDEP<>"" # [F:ITM]SERMGTCOD=3  !! Il faut aussi traiter les cas des n° série gérés en sortie!
        Call CTRSERNUM( nolign-1, VALEUR, LSERF ) From TRTSTOQUAB
        If GMESSAGE<>""
            mkstat = 2
        Else
            If LSERF>[M:SQD]SERNUMFDEP
                mkstat=2
            Else
                [M:SQD]SERNUMF(nolign-1) = LSERF
                Affzo [M:SQD]SERNUMF(nolign-1)
            Endif
        Endif
    Endif
End

##########################################################################

Subprog AM_STADES(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Local Char     WWRH(GLONWRH)
If [M:SQD]STA = VALEUR
    mkstat = 2
   GMESSAGE=mess(83,123,1)
Endif

# Si emplacement destination saisissable
#If GTRSCHGEMP = 2 End Endif

#-- Si article géré en emplacement , on essaie
#-- d'initialiser avec l'emplacement d'origine, on fait les contrôles
#-- Si contrôle non ok on raz
If [F:ITF]ITMREF<>[M:SQD]ITMREF | [F:ITF]STOFCY<>[M:SQD]STOFCY
  Read [ITF]ITF0 = [M:SQD]ITMREF; [M:SQD]STOFCY
  If fstat : Raz [F:ITF] : Endif
Endif
If [F:ITF]LOCMGTCOD=2
  If dim([M:SQD]WRH) > 0
    WWRH=[M:SQD]WRH
  Else
    WWRH=""
  Endif
  If [M:SQD]LOCDES(NOL)  = ""   # hcb 74288
  Call STKCTRTLO([M:SQD]WLOCSEQ(NOL),[M:SQD]TRSTYP,[M:SQD]TRSCOD,[M:SQD]STOFCY,[M:SQD]ITMREF
&               ,[M:SQD]PCUDES(NOL),[M:SQD]QTYPCUDES(NOL),VALEUR
&               ,0,[M:SQD]LOCTYP,mkstat,"QU","",WWRH) From STKLOC
  If mkstat
     If GTRSCHGEMP = 2              # hcb 73215
        Raz mkstat                  # hcb 73215
        End                         # hcb 73215
     Else                           # hcb 73215
        GMESSAGE =VALEUR-":"-mess(213,184,1)-[M:SQD]LOCTYP-[M:SQD]LOC
        GMESSAGE+="\"+mess(214,184,1)
     Endif                          # hcb 73215
  Elsif [M:SQD]LOC<>""
    Call STKCTREMP([M:SQD]WLOCSEQ(NOL),[M:SQD]TRSTYP,[M:SQD]TRSCOD,[M:SQD]STOFCY
&                 ,[M:SQD]ITMREF,[M:SQD]PCUDES(NOL),[M:SQD]QTYPCUDES(NOL),VALEUR
&                 ,[M:SQD]LOCTYP,[M:SQD]LOC,"",0,mkstat,GBIDD1,"QU","",WWRH) From STKLOC
    If !mkstat
       [M:SQD]LOCTYPDES(NOL)=[M:SQD]LOCTYP
       [M:SQD]LOCDES(NOL)   =[M:SQD]LOC
       If dim ([M:SQD]WRHDES)> 0
          [M:SQD]WRHDES(NOL)   =[M:SQD]WRH
       Endif
    Else
       If GTRSCHGEMP = 2                           # hcb 76949
          Raz mkstat                               # hcb 76949
          End                                      # hcb 76949
       Else
          GMESSAGE =VALEUR-":"-mess(213,184,1)-[M:SQD]LOCTYP-[M:SQD]LOC
          GMESSAGE+="\"+mess(214,184,1)            # hcb 76949
       Endif                                       # hcb 76949
    Endif
  Endif
  Endif  # hcb 74288
Endif
End

Subprog AS_WRHDES(VALEUR)
Variable Char    VALEUR()
If GWRHACT = 2
   If [M]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[M]STOFCY
   Endif
   If [F:FCY]WRHGES<>2
      mkstat = 2
   Endif
Endif
End

Subprog C_WRHDES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF;VALEUR
  If fstat
     GMESSAGE=[M]ITMREF-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRHDES(VALEUR)
Variable Char    VALEUR()
If [M:SQD]WRHDES(nolign-1)<>""
   #--- Bug 64285
   #Raz [M:SQD]LOCDES(nolign-1)
   Raz [M:SQD]LOCDES(nolign-1), [M:SQD]LOCTYPDES(nolign-1)
   #---
Endif
End

