#--- Bug 72649
Subprog C_LOCTYPDES(VALEUR)
Variable Char    VALEUR()
If [M:SQD]LOCTYPDES(nolign-1)<>VALEUR
   Call RAZLOC([M:SQD]LOCDES(nolign-1),[M:SQD]WLOCSEQ(nolign-1)) From STKACT
Endif
#                                                                                         # hcb X3-77043 deb
If [F:ITF]LPNMGTCOD = 2 &  dim([M:SQD]LPNNUMDES) > 0 & [M:SQD]LPNNUMDES(nolign-1) <> ""
   If find([F:TLO]LOCCAT,3,4)
      GMESSAGE = mess(241,184,1)  # Emplacement non autorise
      mkstat = 2
      End
   Endif
Endif
#                                                                                         # hcb X3-77043 fin

End
