#<AdxTL>@(#)5.0.0.0 $Revision$
########################################################################################################################
#   Traitement de gestion de la saisie des critères de recherche de demandes    Module CRM             8 Décembre 2003
########################################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


$OUVRE
If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
Global Char GSZLKP7SELQUR
GSZLKP7SELQUR = ""
Return

$DEFBOUT
Return

$SETBOUT
If [M:LKP7]ISDIRTY
    ETABOU(GSPE1) = 1
Else
    ETABOU(GSPE1) = 0
Endif
Return

$OUVRE_BOITE
Return

$DEBUT
[M:LKP7]SEAOPD = 1
[M:LKP7]TTRDESFLG = 1
[M:LKP7]SREHD1FLG = 1
[M:LKP7]TTRDES = ""
Grizo [M:LKP7]SREHD1FLG
Grizo [M:LKP7]TTRDES

[M:LKP7]QURNUM = ""
[M:LKP7]QURNAM = ""

Affzo [M:LKP7]

Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Case BOUT
    When "1"
        If [M:LKP7]TTRDES = "" & [M:LKP7]QURNUM = ""
            #Aucun critère de recherche n'a été saisi. La recherche n'a pas été exécutée.
            GMESSAGE = mess(838, 182, 2)
            GERR = 2
            FOK = 0
        Endif
    When Default
Endcase
Return

$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:LKP7]

Kill GSZLKP7SELQUR
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
[M:LKP7]ISDIRTY = 1
Return

$BOUTON
Case BOUT
    When "2"
        Gosub ONRAZ
    When Default
Endcase
Return

$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
$ONRAZ
Raz [M:LKP7]

[M:LKP7]TTRDESFLG = 1
[M:LKP7]SREHD1FLG = 1
[M:LKP7]TTRDES = ""
Grizo [M:LKP7]SREHD1FLG
Grizo [M:LKP7]TTRDES

[M:LKP7]QURNUM = ""
[M:LKP7]QURNAM = ""

[M:LKP7]ISDIRTY = 0
Affzo [M:LKP7]
Return



