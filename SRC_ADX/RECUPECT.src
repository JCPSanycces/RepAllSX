#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPECT","UTIRECECT",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If clalev([F:HAE])=0 : Local File GACCENTRY     [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD    [DAE] : Endif
If clalev([F:DAA])=0 : Local File GACCENTRYA    [DAA] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE    [DUD] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR    [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD        [PER] : Endif
If clalev([F:FCY])=0 : Local File FACILITY      [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY       [CPY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT      [GAC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER      [BPR] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT    [GTE] : Endif
If clalev([F:CCE])=0 : Local File CACCE         [CCE] : Endif
If clalev([F:TCU])=0 : Local File TABCUR        [TCU] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV       [ADI] : Endif

If clalev([F:GCM])=0 : Local File GACM          [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED          [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA          [COA] : Endif

# Lecture pour les liens (Automatique ou partie Double)
If clalev([F:DAE2])=0 : Local File GACCENTRYD    [DAE2] : Endif
Return

$INIT
Gosub OUVRE
TMP = 1
Return

$INIT_DIA
[M:DIA]SOCIETE = GDEFSOC
Call SETMAINREF([M:DIA]SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call DEFEXE([M:DIA]SOCIETE,GTYPGEN,[M:DIA]EXERCICE) From CPTSUB
Call DATEXE([M:DIA]SOCIETE,GTYPGEN,[M:DIA]EXERCICE,[M:DIA]DATDEB,[M:DIA]DATFIN) From CPTSUB
Return

$EXEC
Call RECUPECT([M:DIA]SOCIETE,[M:DIA]TOUSITE,[M:DIA]SITE,[M:DIA]EXERCICE,[M:DIA]DATDEB
& ,[M:DIA]DATFIN,[M:DIA]TYPPCE,[M:DIA]RECUP,GSERVEUR)
TRA = 1
Return

Subprog RECUPECT(SOCIETE,TOUSITE,SITE,EXERCICE,DATDEB,DATFIN,TYPPCE,RECUP,BATCH)
Value Char    SOCIETE
Value Integer TOUSITE
Value Char    SITE
Value Integer EXERCICE
Value Date    DATDEB
Value Date    DATFIN
Value Char    TYPPCE
Value Integer RECUP
Value Integer BATCH

Gosub OUVRE

# Indice de travail
Local Integer MAXLIG, MAXPER, MAXANA, NBLED
Local Mask GACCENT2 [HAE2]
NBLED = dim([F:HAE]LED)
MAXLIG = dim([M:HAE2]ACC1)
MAXANA = GMAXVANA
MAXPER=func AFNC.ACTIV("PER")
Close Local Mask [HAE2]

# Totaux en montant devise de transaction
Local Decimal TOTCUR1(1..GNBSITE), TOTCUR2(1..GNBSITE), TOTCUR3(1..GNBSITE), TOTCUR4(1..GNBSITE), TOTCUR5(1..GNBSITE)
Local Decimal TOTCUR6(1..GNBSITE), TOTCUR7(1..GNBSITE), TOTCUR8(1..GNBSITE), TOTCUR9(1..GNBSITE), TOTCUR10(1..GNBSITE)

# Totaux en montant devise de référentiel
Local Decimal TOTLED1(1..GNBSITE), TOTLED2(1..GNBSITE), TOTLED3(1..GNBSITE), TOTLED4(1..GNBSITE), TOTLED5(1..GNBSITE)
Local Decimal TOTLED6(1..GNBSITE), TOTLED7(1..GNBSITE), TOTLED8(1..GNBSITE), TOTLED9(1..GNBSITE), TOTLED10(1..GNBSITE)

# Variable pour les totaux par site
Local Integer ISITE , NBSITE
Local Char    TBSITE(GLONFCY)(1..GNBSITE)

# Variable pour la re-synchronisation des montants
Local Decimal MTDEB(1..MAXLIG)  , MTCRE(1..MAXLIG)
Local Decimal DEBLED(1..MAXLIG) , CDTLED(1..MAXLIG)
Local Decimal MTFLED(1..MAXLIG)
Local Integer FLGLED(1..MAXLIG)
Local Char    MTSIT(GLONFCY)(1..MAXLIG)
Local Decimal MTANA(1..MAXANA) , MTANALED(1..MAXANA)
Local Integer SNSLED(1..MAXLIG)

# Variable pour la re-synchronisation des échéances
Local Decimal ECHCUR , ECHLED
Local Integer ECHNUM

# Variable pour la gestion des cours (devises)
Local Decimal COURS
Local Decimal AROCUR , AROLED(NBLED)

# Variable contenant les informations du Référentiel
Local Integer IND,AXI
Local Char AXE(GLONDIE)

# Variable pour le filtre des pièces
Local Char    FILTECT(250)(1..4)
Local Integer IFILT : IFILT = 1

# Variable pour la re-synchronisation de l'analytique selon paramètarge "Stockage des imputations vides"
Local Integer INDANA, DELANA

Local Decimal ANACUR , ANALED  , ANAQTE        # Totaux analytique (AMTCUR,AMTLED,QTY)
Local Decimal EXE , PER                        # Exercice et période
Local Char    MESSA(80)                        # Message d'erreur
Local Integer GRAVE                            # Flag d'importance du message d'erreur
Local Integer ANOM                             # Flag d'anomalies
Local Decimal RATIO                            # Ratio pour le calcul du montant douteux
Local Integer NBLIG                            # Nombre pièces générales   à vérifier/re-synchroniser
Local Integer NBANA                            # Nombre pièces analytiques à vérifier/re-synchroniser
Local Integer STAT                             # Statut d'erreur

Local Integer OK , RW , RWL , RWA , RWE ,  FLMT , FLCNV , FLNCNV
Local Integer FLGAUT, FLGDOE
Local Integer FLGPER  # Flag des pièces d'à-nouveau (permet d'inhiber les contrôles analytiques)

Local Integer PEROK,PERMSGDONE

RECUP = (RECUP=2)

If !BATCH
 If RECUP
  Call OUVRE_TRACE(mess(1,116,1)) From LECFIC : # Récupération des pièces
 Else
  Call OUVRE_TRACE(mess(72,116,1)) From LECFIC : # Vérification des écritures
 Endif
Endif

If RECUP
 Call MONOCPY(SOCIETE, OK) From AX3MONO
 If !OK : Goto FIN : Endif
Endif

Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
If !GTYPGEN
 # Valeur incorrecte
 Call ECR_TRACE(SOCIETE-mess(83,123,1)-"(GTYPGEN=0)",1) From GESECRAN : Goto FIN
Endif

Gosub VERECT

$FIN
If RECUP
 Call MULTICPY(SOCIETE) From AX3MONO
Endif
If !BATCH
 Call FERME_TRACE From LECFIC
Endif
End # fin du Subprog RECUPECT

########################################
$VERECT
ANOM = 0 : GRAVE = 0
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
If RECUP
 Call ECR_TRACE(mess(1,116,1),0) From GESECRAN : # Récupération des pièces
Else
 Call ECR_TRACE(mess(72,116,1),0) From GESECRAN : # Vérification des écritures
Endif
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN : # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN : # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN : # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN : # Site
Endif
Call ECR_TRACE(mess(188,107,1)-format$("D:"+GFMDAT,DATDEB)-format$("D:"+GFMDAT,DATFIN),0) From GESECRAN
If TYPPCE<>""
 Call ECR_TRACE(mess(6,116,1)-TYPPCE,0) From GESECRAN : # Type de pièce
Endif
If RECUP
 Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Début récup
Else
 Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Début vérification
Endif
#--------------------- VERIF --------------------------
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Gosub VERIF
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#------------------------------------------------------
If RECUP
 Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin récup
Else
 Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin Vérification
Endif
If ANOM
 Call ECR_TRACE(num$(ANOM)-mess(7,116,1),0) From GESECRAN : # anomalies
Else
 Call ECR_TRACE(mess(8,116,1),0) From GESECRAN : # Aucune anomalie
Endif
Return

########################################
$VERIF
Raz FILTECT, IFILT

#-- Société & Site
Call ADDCRIT(FILTECT,IFILT,"CPY",'[F:HAE]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2
 Call ADDCRIT(FILTECT,IFILT,"FCY",'[F:HAE]FCY="'+SITE+'"'," & ") From GOBJSUB
Endif

#-- Exercice, Date
Call ADDCRIT(FILTECT,IFILT,"DATDEB",'[F:HAE]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILT,"DATDEB",'[F:HAE]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

#-- Type de pièce
If TYPPCE<>""
 Call ADDCRIT(FILTECT,IFILT,"TYP",'[F:HAE]TYP="'+TYPPCE+'"'," & ") From GOBJSUB
Endif

#-- Pièce définitive (DdM16245)
If [M:DIA]PCEDEF<>2
 Call ADDCRIT(FILTECT,IFILT,"STA",'[F:HAE]STA<>2'," & ") From GOBJSUB
Endif


#-- Lancement de la vérification
For [HAE]HAE0 Where evalue(FILTECT)
 Gosub VERFPCE
Next

Raz FILTECT, IFILT

#-- Société & Site
Call ADDCRIT(FILTECT,IFILT,"CPY",'[F:DAE]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2
 Call ADDCRIT(FILTECT,IFILT,"FCY",'[F:DAE]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif

#-- Exercice, Date
Call ADDCRIT(FILTECT,IFILT,"DATDEB",'[F:DAE]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILT,"DATDEB",'[F:DAE]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

#-- Type de pièce
If TYPPCE<>""
 Call ADDCRIT(FILTECT,IFILT,"TYP",'[F:HAE]TYP="'+TYPPCE+'"'," & ") From GOBJSUB
Endif

For [DAE]DAE0(2) Where evalue(FILTECT)
 Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
 If fstat
  MESSA = mess(9,116,1) : GRAVE = 1 : Gosub ERRLIG
  # Ligne sans pièce
 Endif
Next
Return

########################################
$VERFPCE
RW = 0
PEROK = 1
PERMSGDONE = 0
#-- Vérification site
Read [FCY]FCY0 = [F:HAE]FCY
If fstat
 MESSA = [F:HAE]FCY-mess(19,116,1) : Gosub ERRTET :  # Site inexistant
 If RECUP : [F:HAE]FCY = GFCYDEF : RW = 1 : Endif
Elsif [F:FCY]FINFLG<>2
 MESSA = [F:HAE]FCY-mess(96,199,1) : Gosub ERRTET :  # Site non financier
 If RECUP : [F:HAE]FCY = [F:FCY]FINRSPFCY : RW = 1 : Endif
Endif

#-- Vérification Devise
Read [TCU]TCU0 = [F:HAE]CUR
If fstat
 MESSA = [F:HAE]CUR-mess(12,116,1) : Gosub ERRTET :  # Devise inexistante
 If RECUP : [F:HAE]CUR = [F:CPY]ACCCUR : RW = 1
  Read [TCU]TCU0 = [F:HAE]CUR
 Endif
Endif
AROCUR = [F:TCU]CURRND

#-- Référentiel / Cours Référentiel
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]LED(I)<>""
  #-- Vérification Référentiel
  Call LECTURE("LED",[F:GCM]LED(I),"") From CONTOBJ
  If [F:HAE]LED(I)<>"" & [F:HAE]LED(I)<>[F:GCM]LED(I)
   MESSA = [F:HAE]LED(I)-mess(153,116,1)-mess(I+1,2644,1) : Gosub ERRTET :  # Référentiel incorrect + Type de référentiel
   If RECUP : [F:HAE]LED(I) = [F:GCM]LED(I) : RW = 1 :  Endif
  Endif

  #-- Vérification devise de référentiel
  If [F:HAE]CURLED(I)<>"" & [F:HAE]CURLED(I)<>[F:GCM]CUR(I)
   MESSA = [F:HAE]CURLED(I)-mess(84,116,1)-mess(I+1,2644,1) : Gosub ERRTET :  # Devise incorrecte + Type de référentiel
   If RECUP : [F:HAE]CURLED(I) = [F:GCM]CUR(I) : RW = 1 :  Endif
  Endif
  Call LECTURE("TCU",[F:GCM]CUR(I),"") From CONTOBJ
  AROLED(I) = [F:TCU]CURRND

  #-- Vérification cours<0
  If [F:HAE]RATMLT(I)<0 or [F:HAE]RATDIV(I)<0
   MESSA = [F:HAE]CUR-mess(16,116,1)-mess(I+1,2644,1)  : Gosub ERRTET      # Cours < 0 + Type de référentiel
   If RECUP : [F:HAE]RATMLT(I) = 0 : [F:HAE]RATDIV(I) = 0 : RW = 1 :  Endif
  Endif

  #-- Vérification cours<>1 par rapport au paramétrage du modèle comptable : Mode saisie cours. (1 Multiplicateur et 2 Diviseur)
  If ([F:GCM]DACRAT(I)=1 & [F:HAE]RATDIV(I)<>1) or ([F:GCM]DACRAT(I)=2 & [F:HAE]RATMLT(I)<>1)
   MESSA = [F:HAE]CUR-mess(14,116,1)-mess(I+1,2644,1)  : Gosub ERRTET      # Cours <> 1 + Type de référentiel
  Endif

  #-- Vérification cours<>1 par rapport à la devise de pièce
  If [F:HAE]CUR=[F:HAE]CURLED(I)
   If [F:HAE]RATMLT(I)<>1 or [F:HAE]RATDIV(I)<>1
    MESSA = [F:HAE]CUR-mess(14,116,1)-mess(I+1,2644,1)  : Gosub ERRTET      # Cours <> 1 + Type de référentiel
    If RECUP : [F:HAE]RATMLT(I) = 1 : [F:HAE]RATDIV(I) = 1 : RW = 1 :  Endif
   Endif
  Endif
 Endif
Next

#-- Vérification période (simple information, non importante en entête)
Call LEC_GTE_LEG([F:CPY]LEG,[F:HAE]TYP) From CPTLEC
If [F:GTE]PER=2 : FLGPER = 1 : Else FLGPER = 0 : Endif
Call GETPERSOC([F:HAE]CPY,GTYPGEN,[F:HAE]ACCDAT,EXE,PER) From CPTSUB
If EXE=0 or PER=0
 MESSA = mess(10,116,1) : Gosub ERRTET    :    # Période incorrecte
Else
 Case [F:GTE]PER
  When 2
   PER = 0
  When 3,4,5,6,7
   PER = MAXPER-1
 Endcase
Endif
If EXE<>[F:HAE]FIY | PER<>[F:HAE]PER
 MESSA = mess(10,116,1) : Gosub ERRTET : # Période incorrecte
 If RECUP
  [F:HAE]FIY = EXE
  [F:HAE]PER = PER
  RW = 1
 Endif
Endif

For I=1 To 10
 For J=1 To GNBSITE
  Assign  "TOTCUR"+num$(I)+"("+num$(J)+")" With 0
  Assign  "TOTLED"+num$(I)+"("+num$(J)+")" With 0
 Next
Next

Raz TBSITE, NBSITE

FLCNV = 0 : FLNCNV = 0
NBLIG = 0
For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM
 NBLIG += 1
 RWL = 0

 #-- Zones identiques DAE/HAE (CPY,ACCDAT,CURLED)
 If [F:DAE]CPY<>[F:HAE]CPY
  MESSA = mess(17,116,1) : Gosub ERRLIG  : # Société ligne <> Société pièce
  If RECUP : [F:DAE]CPY = [F:HAE]CPY : RWL = 1 : Endif
 Endif
 If [F:DAE]ACCDAT<>[F:HAE]ACCDAT
  MESSA = mess(18,116,1) : Gosub ERRLIG  : # Date ligne <> Date pièce
  If RECUP : [F:DAE]ACCDAT = [F:HAE]ACCDAT : RWL = 1 : Endif
 Endif
 #-- Vérification site
 Read [FCY]FCY0 = [F:DAE]FCYLIN
 If fstat
  MESSA = [F:DAE]FCYLIN-mess(19,116,1) : Gosub ERRLIG :  # Site inexistant
  If RECUP : [F:DAE]FCYLIN = [F:HAE]FCY : RWL = 1 : Endif
 Elsif [F:FCY]FINFLG<>2
  MESSA = [F:DAE]FCYLIN-mess(96,199,1) : Gosub ERRLIG :  # Site non financier
  If RECUP : [F:DAE]FCYLIN = [F:FCY]FINRSPFCY : RWL = 1 : Endif
 Endif
 #-- Vérification devise référentiel
 If [F:DAE]CURLED<>[F:HAE]CURLED([F:DAE]LEDTYP-1)
  MESSA = mess(84,116,1)-mess([F:DAE]LEDTYP,2644,1) : Gosub ERRLIG  : # Devise incorrecte + Type de référentiel
  If RECUP : [F:DAE]CURLED = [F:HAE]CURLED([F:DAE]LEDTYP-1) : RWL = 1 : Endif
 Endif

 #-- Vérification période
 Call LEC_GTE_LEG([F:CPY]LEG,[F:DAE]TYP) From CPTLEC
 Call GETPERSOC([F:DAE]CPY,[F:DAE]LEDTYP,[F:DAE]ACCDAT,EXE,PER) From CPTSUB
 If EXE=0 or PER=0
  MESSA = mess(10,116,1) : GRAVE = 1 : Gosub ERRLIG    :    # Période incorrecte
 Else
  Case [F:GTE]PER
   When 2
    PER = 0
   When 3,4,5,6,7
    PER = MAXPER-1
  Endcase
 Endif
 If EXE<>[F:DAE]FIY | PER<>[F:DAE]PER
  MESSA = mess(10,116,1) : Gosub ERRLIG : # Période incorrecte
  If RECUP
   [F:DAE]FIY = EXE
   [F:DAE]PER = PER
   RWL = 1
  Endif
 Endif

 #-- Pas de récupération sur une PERIODE FERME
 If RECUP
  Read [PER]PER0=[F:DAE]CPY;[F:DAE]LEDTYP;EXE;PER
  If !fstat & [PER]PERSTA<>2
   RW=0
   PEROK = 0
   # Pas de récupération sur une période fermée
   #MESSA = mess(158,116,1) : Gosub ERRLIG
   #Break
  Endif
 Endif

 #-- Vérification des contreparties (Automatique & Double partie)
 Call LEDTYPAUT([F:DAE]CPY,[F:DAE]LEDTYP,[L]FLGAUT) From CPTDIV
 If [L]FLGAUT=2

  If [F:DAE]ACCNUMORI=0
   MESSA = "ACCNUMORI"-mess(102,116,1) : GRAVE = 1 : Gosub ERRLIG : # Numéro interne incorrect
  Else
   Read [F:DAE2]DAE2 = [F:DAE]ACCNUMORI
   If fstat
    MESSA = "ACCNUMORI"-mess(9,116,1)-"("+num$([F:DAE]ACCNUMORI)+")"  : GRAVE = 1 : Gosub ERRLIG : # Ligne sans pièce
   Endif
  Endif

  If [F:DAE]ACCNUMDOE<>0
   Read [F:DAE2]DAE2 = [F:DAE]ACCNUMDOE
   If fstat
    MESSA = "ACCNUMDOE"-mess(9,116,1)-"("+num$([F:DAE]ACCNUMDOE)+")"  : GRAVE = 1 : Gosub ERRLIG : # Ligne sans pièce
   Endif
  Endif

 Else
  # Ligne à zéro mais faut il rechercher ACCNUM => ACCNUMORI dans le cas d'un référentiel automatique lié ?!
  # Ligne à zéro mais faut il rechercher ACCNUM => ACCNUMDOE dans le cas d'un référentiel double partie lié ?!
 Endif


 #-- Montants (Arrondi)
 If [F:DAE]AMTCUR<>arr([F:DAE]AMTCUR,AROCUR)
  MESSA = num$([F:DAE]AMTCUR)-[F:HAE]CUR-mess(20,116,1) : Gosub ERRLIG : # Montant incorrect
  If RECUP : [F:DAE]AMTCUR = arr([F:DAE]AMTCUR,AROCUR) : RWL = 1 :  Endif
 Endif
 If [F:DAE]AMTLED<>arr([F:DAE]AMTLED,AROLED([F:DAE]LEDTYP-1))
  MESSA = num$([F:DAE]AMTLED)-[F:DAE]CURLED-mess(20,116,1) : Gosub ERRLIG : # Montant incorrect
  If RECUP : [F:DAE]AMTLED = arr([F:DAE]AMTLED,AROLED([F:DAE]LEDTYP-1)) : RWL = 1 :  Endif
 Endif

 #-- Montants (Forcé)
 If [F:HAE]CUR=[F:DAE]CURLED & [F:DAE]AMTFLG<>0 & [F:DAE]AMTLED1<>[F:DAE]AMTCUR
  MESSA = mess(103,116,1)-[F:DAE]CURLED-num$([F:DAE]AMTLED1) : Gosub ERRLIG
  If RECUP
   [F:DAE]AMTFLG = 0 : [F:DAE]AMTLED1 = 0 : RWL = 1
   [F:DAE]AMTLED = [F:DAE]AMTCUR
  Endif
 Endif

 #-- Cours
 Raz COURS

 #-- Montants (Vraisemblance des conversions) => Cours saisi est en EURO !!!
 If [F:HAE]RATDIV([F:DAE]LEDTYP-1)<>0
  Call SETFLGDEV([F:HAE]CUR,[F:HAE]CPY,[F:HAE]RATDAT) From CPTDIV
  COURS = [F:HAE]RATMLT([F:DAE]LEDTYP-1)/[F:HAE]RATDIV([F:DAE]LEDTYP-1)

  #- Monnaie OUT et Devise référentiel est IN non EURO
  If (GCURFLG=1 & GLEDFLG([F:DAE]LEDTYP)=2 & [F:HAE]CURLED([F:DAE]LEDTYP-1)<>GEURO)
   Call CONVERT(GEURO,[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]TYPRAT,[F:HAE]RATDAT,
&              10^GDECRCU,COURS,STAT) From TRTDEV
   COURS = COURS/10^GDECRCU*[F:HAE]RATMLT([F:DAE]LEDTYP-1)/[F:HAE]RATDIV([F:DAE]LEDTYP-1)
  #-  Monnaie IN non EURO et Devise référentiel est OUT
  Elsif (GCURFLG=2 & GLEDFLG([F:DAE]LEDTYP)=1 & [F:HAE]CUR<>GEURO)
   If [F:HAE]RATDIV([F:DAE]LEDTYP-1)=1
     Call CONVERT([F:HAE]CUR,GEURO,[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]TYPRAT,[F:HAE]RATDAT,
&                10^GDECRCU,COURS,STAT) From TRTDEV
     COURS = COURS/10^GDECRCU*[F:HAE]RATMLT([F:DAE]LEDTYP-1)/[F:HAE]RATDIV([F:DAE]LEDTYP-1)
   Endif
  Endif
 Endif

 If [F:DAE]AMTFLG=0
  If [F:DAE]AMTLED=0 & COURS<>0 & [F:DAE]AMTCUR<>0
   # Montants douteux en
   MESSA = mess(21,116,1)-[F:HAE]CURLED([F:DAE]LEDTYP-1) : Gosub ERRLIG
   If RECUP : FLCNV = 1 : Endif
  Elsif [F:DAE]AMTLED<>0 & COURS<>0
   Call LEC_TCU([F:HAE]CURLED([F:DAE]LEDTYP-1)) From CPTLEC
   RATIO = abs(arr([F:DAE]AMTCUR*COURS,[F:TCU]CURRND)/[F:DAE]AMTLED)
   If RATIO>1.05 | RATIO<0.95
    # Montants douteux en
    MESSA = mess(21,116,1)-[F:HAE]CURLED([F:DAE]LEDTYP-1) : Gosub ERRLIG
    If RECUP : FLCNV = 1 : Endif
   Endif
  Endif
 Endif

 Call INDLED([F:DAE]LED,"",IND,AXI) From CPTDIV

 # Vérification : Code plan, Compte/collectif, Tiers, Unité d'oeuvre
 If GLEDCOA(IND)<>[F:DAE]COA
  # Code plan inexistant
  MESSA = [F:DAE]COA-mess(157,116,1) : Gosub ERRLIG
  If RECUP : [F:DAE]COA=GLEDCOA(IND) : RWL = 1 : Endif
 Endif
 Read [GAC]GAC0 = [F:DAE]COA;[F:DAE]ACC
 If fstat
  MESSA = [F:DAE]ACC-mess(22,116,1) : Gosub ERRLIG    #  Compte inexistant
  If RECUP
   Call LECTURE("COA",GLEDCOA(IND),"") From CONTOBJ
   [F:DAE]ACC = [F:COA]ACCMIS(1) :  [F:DAE]SAC = "" : [F:DAE]BPR = "" : RWL = 1
  Endif
 Else
  If [F:GAC]SAC=2
   If [F:DAE]SAC<>[F:GAC]ACCSHO
    MESSA = [F:DAE]SAC-mess(23,116,1) : Gosub ERRLIG  # Collectif incorrect
    If RECUP : [F:DAE]SAC = [F:GAC]ACCSHO : RWL = 1 : Endif
   Endif
   Read [BPR]BPR0 = [F:DAE]BPR
   If fstat
    MESSA = [F:DAE]BPR-mess(24,116,1) : Gosub ERRLIG  #  Tiers incorrect
   Endif
   OK  = [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
   OK += [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
   OK += [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2
   OK += [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2
   OK += [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2
   OK += [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2
   If !OK
    MESSA = [F:DAE]BPR-mess(25,116,1) : GRAVE = 1 : Gosub ERRLIG    #  Tiers non autorisé
   Endif
  Else
   If [F:DAE]SAC<>""
    MESSA = [F:DAE]SAC-mess(26,116,1) : Gosub ERRLIG   #    Collectif en trop
    If RECUP : [F:DAE]SAC = "" : RWL = 1 : Endif
   Endif
   If [F:DAE]BPR<>""
    MESSA = [F:DAE]BPR-mess(27,116,1) : Gosub ERRLIG   #    Tiers en trop
    If RECUP : [F:DAE]BPR = "" : RWL = 1 : Endif
   Endif
  Endif
  Call LECTURE("GAC",[F:DAE]ACC,[F:DAE]COA) From CONTOBJ
 Endif

 If [F:DAE]UOM<>[F:GAC]UOM
  MESSA = mess(38,116,1) : Gosub ERRLIG : #  Unité ana <> Unité compte
  If RECUP : [F:DAE]UOM = [F:GAC]UOM : RWL = 1 :  Endif
 Endif

 #-- Vérification de l'analytique
 If [F:DAE]ACC<>"" and GLEDFLGANA(IND)=2
  Raz ANALED, ANAQTE, ANACUR, INDANA
  NBANA = 0
  For [DAA]DAA0 Where TYP=[F:DAE]TYP & LEDTYP=[F:DAE]LEDTYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN
   NBANA += 1
   RWA = 0
   #-- Zones identiques
   If [F:DAA]LED<>[F:DAE]LED
    MESSA = mess(154,116,1) : Gosub ERRANA  # Référentiel ana <> Référentiel ligne
    If RECUP : [F:DAA]LED = [F:DAE]LED : RWA = 1 :  Endif
   Endif
   If [F:DAA]CPY<>[F:HAE]CPY
    MESSA = mess(34,116,1) : Gosub ERRANA  #   Société ana <> Société ligne
    If RECUP : [F:DAA]CPY = [F:HAE]CPY : RWA = 1 :  Endif
   Endif
   If [F:DAA]FCYLIN<>[F:DAE]FCYLIN
    MESSA = mess(33,116,1) : Gosub ERRANA #   Site ana <> Site ligne
    If RECUP : [F:DAA]FCYLIN = [F:DAE]FCYLIN : RWA = 1 :  Endif
   Endif
   If [F:DAA]ACCDAT<>[F:HAE]ACCDAT
    MESSA = mess(35,116,1) : Gosub ERRANA #   Date ana <> Date ligne
    If RECUP : [F:DAA]ACCDAT = [F:HAE]ACCDAT : RWA = 1 : Endif
   Endif
   If [F:DAA]ACCNUM<>[F:DAE]ACCNUM
    MESSA = mess(36,116,1) : Gosub ERRANA #   Numéro ana <> Numéro ligne
    If RECUP : [F:DAA]ACCNUM = [F:DAE]ACCNUM : RWA = 1 :  Endif
   Endif
   If [F:DAA]ACC<>[F:DAE]ACC
    MESSA = mess(37,116,1) : Gosub ERRANA #   Compte ana <> Compte ligne
    If RECUP :  [F:DAA]ACC = [F:DAE]ACC : RWA = 1 :    Endif
   Endif
   If [F:DAA]BPR<>[F:DAE]BPR
    MESSA = mess(178,116,1) : Gosub ERRANA #   Tiers ana <> Tiers ligne
    If RECUP :  [F:DAA]BPR = [F:DAE]BPR : RWA = 1 :    Endif
   Endif
   If [F:DAA]UOM<>[F:GAC]UOM
    MESSA = mess(38,116,1) : Gosub ERRANA : #   Unité ana <> Unité compte
    If RECUP : [F:DAA]UOM = [F:GAC]UOM : RWA = 1 :  Endif
   Endif
   If [F:DAA]SNS<>[F:DAE]SNS
    MESSA = mess(155,116,1) : Gosub ERRANA : #   Sens ana <> Sens ligne
    If RECUP : [F:DAA]SNS = [F:DAE]SNS : RWA = 1 : Endif
   Endif
   If [F:DAA]CUR<>[F:DAE]CUR
    MESSA = mess(156,116,1) : Gosub ERRANA : #   Devise ana <> Devise ligne
    If RECUP : [F:DAA]CUR = [F:DAE]CUR : RWA = 1 : Endif
   Endif

   #-- Arrondi des montants
   If [F:DAA]AMTCUR<>arr([F:DAA]AMTCUR,AROCUR)
    MESSA = num$([F:DAA]AMTCUR)-[F:HAE]CUR-mess(20,116,1) : Gosub ERRANA       #   Montant incorrect
    If RECUP : [F:DAA]AMTCUR = arr([F:DAA]AMTCUR,AROCUR) : RWA = 1 : Endif
   Endif
   If [F:DAA]AMTLED<>arr([F:DAA]AMTLED,AROLED([F:DAA]LEDTYP-1))
    MESSA = num$([F:DAA]AMTLED)-[F:DAA]CURLED-mess(20,116,1) : Gosub ERRANA    #   Montant incorrect
    If RECUP : [F:DAA]AMTLED = arr([F:DAA]AMTLED,AROLED) : RWA = 1 : Endif
   Endif

   #-- Vérification Axes & Sections
   # Suite à l'idée qu'un axe peut devenir obsolète et que le référentiel pourrait connaitre une évolution de ces axes...

   For AXI=1 To GLEDDIENBR(IND)
   # AXE=evalue("GDIE"+num$(AXI)+"("+num$(IND)+")")
   # If [F:DAA]DIE(AXI-1)<>AXE
   #  MESSA = "Axe incorrect" : Gosub ERRANA
   #  If RECUP : [F:DAA]DIE(AXI-1) = AXE : RWA = 1 : Endif
   # Endif

    If [F:DAA]CCE(AXI-1)<>""
     Read [CCE]CCE0 = [F:DAA]DIE(AXI-1);[F:DAA]CCE(AXI-1)
     If fstat
      MESSA = [F:DAA]CCE(AXI-1)-mess(39,116,1) : Gosub ERRANA :  #     Section inexistante
      If RECUP & find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
        [F:DAA]CCE(AXI-1) = [F:GAC]CCEDEF(find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))) : RWA = 1
      Endif
     Endif
     INDANA+=1
    Endif
   Next AXI

   # Total montant Analytique
   ANACUR += [F:DAA]AMTCUR
   ANALED += [F:DAA]AMTLED
   ANAQTE += [F:DAA]QTY

   # Ré-écriture de la ligne analytique
   If RWA & PEROK
    GOK = 1
    Trbegin [DAA]
     Rewrite [DAA]
     If fstat
      GOK = 0 : Call FSTA("DAA") From GLOCK
     Endif
    Commit
   Endif
  Next

  # Contrôles finaux : Nb de ventilation & Totaux
  FLMT = 0 : DELANA = 0
  If NBANA>MAXANA
   MESSA = mess(40,116,1)-num$(NBANA) : GRAVE = 1 : Gosub ERRLIG  #  Trop de ventilations
   FLNCNV = 1
  Elsif NBANA=0 and GLEDDIEOBY(IND)=2 & [F:GAC]DACDIENBR>0 & !FLGPER
   MESSA = mess(43,116,1) : GRAVE = 1 : Gosub ERRLIG  #  Pas de ventilation ana
   FLNCNV = 1
  Elsif NBANA=0 and GLEDDIEIPT(IND)= 2
   MESSA = mess(43,116,1) : GRAVE = 1 : Gosub ERRLIG  #  Pas de ventilation ana
   FLNCNV = 1
   DELANA = 2
  Elsif NBANA>0
   If ANACUR<>[F:DAE]AMTCUR
    MESSA = [F:HAE]CUR-mess(41,116,1) : Gosub ERRLIG    #   Total ana <> Montant ligne
    FLMT = 1
   Elsif ANALED<>[F:DAE]AMTLED
    MESSA = [F:CPY]ACCCUR-mess(41,116,1) : Gosub ERRLIG    #   Total ana <> Montant ligne
    FLMT = 1
   Endif
   If ANAQTE<>[F:DAE]QTY
    MESSA = mess(42,116,1) : Gosub ERRLIG    #   Total qté ana <> Qté ligne
    FLMT = 1
   Endif
   If !INDANA & GLEDDIEIPT(IND)<>2
    MESSA = mess(40,116,1) : GRAVE = 1 : Gosub ERRLIG  #  Trop de ventilations
    FLNCNV = 1
    DELANA = 1
   Endif
  Endif

  # Ré-écriture de la première ligne analytique
  If RECUP & FLMT & PEROK
   GOK = 1
   Trbegin [DAA]
    Filter [DAA] Where TYP=[F:DAE]TYP & LEDTYP=[F:DAE]LEDTYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN
    Read [DAA]DAA0 First
    Filter [DAA]
    If !fstat
     [F:DAA]AMTCUR += [F:DAE]AMTCUR-ANACUR
     [F:DAA]AMTLED += [F:DAE]AMTLED-ANALED
     [F:DAA]QTY    += [F:DAE]QTY   -ANAQTE
     Rewrite [DAA]
     If fstat
      GOK = 0 : Call FSTA("DAA") From GLOCK
     Endif
    Else
     MESSA = mess(43,116,1) : GRAVE = 1 : Gosub ERRLIG  #    Pas de ventilation ana
    Endif
   Commit
  Endif
  If RECUP
   If DELANA=1
    # Suppression de la ventilation
    Trbegin [DAA]
     Delete [DAA] Where TYP=[F:DAE]TYP & LEDTYP=[F:DAE]LEDTYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN
     Filter [DAA]
     If fstat
      GOK = 0 : Call FSTA("DAA") From GLOCK
     Endif
    Commit
   Endif
   If DELANA=2 & PEROK
    # Création d'une ventilation
    Trbegin [F:DAA]
     Raz [F:DAA]
     [F:DAA] = [F:HAE]
     [F:DAA] = [F:DAE]
     [F:DAA]ANALIN = 1
     For AXI=1 To GLEDDIENBR(IND)
      [F:DAA]DIE(AXI-1) = evalue("GDIE"+num$(AXI)+"("+num$(IND)+")")
     Next
     Write [DAA]
     If fstat
      GOK = 0 : Call FSTA("DAA") From GLOCK
     Endif
    Commit
   Endif
  Endif
 Endif

 #-- Total montant Ligne
 ISITE = find([F:DAE]FCYLIN,TBSITE(1..NBSITE))
 If !ISITE
  NBSITE += 1 : ISITE = NBSITE
  TBSITE(ISITE) = [F:DAE]FCYLIN
 Endif
 Assign "TOTCUR"+num$([F:DAE]LEDTYP)+"("+num$(ISITE)+")" With evalue("TOTCUR"+num$([F:DAE]LEDTYP)+"("+num$(ISITE)+")") +( [F:DAE]SNS*[F:DAE]AMTCUR)
 Assign "TOTLED"+num$([F:DAE]LEDTYP)+"("+num$(ISITE)+")" With evalue("TOTLED"+num$([F:DAE]LEDTYP)+"("+num$(ISITE)+")") +( [F:DAE]SNS*[F:DAE]AMTLED)

 #-- Vérification échéances
 If [F:DAE]SAC<>"" and [F:DAE]LEDTYP=GTYPGEN
  Raz ECHCUR , ECHLED , ECHNUM
  For [DUD]DUD0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LIG=[F:DAE]LIN
   ECHCUR += [F:DUD]AMTCUR
   ECHLED += [F:DUD]AMTLOC
   ECHNUM  = [F:DUD]DUDLIG
   RWE = 0
   If [F:DUD]ACCNUM<>[F:DAE]ACCNUM
    MESSA = mess(102,116,1) : Gosub ERRECH : # Numéro interne incorrect
    If RECUP : [F:DUD]ACCNUM = [F:DAE]ACCNUM : RWE = 1 : Endif
   Endif
   If [F:DUD]CPY<>[F:DAE]CPY
    MESSA = mess(81,116,1) : Gosub ERRECH : # Société incorrecte
    If RECUP : [F:DUD]CPY = [F:DAE]CPY : RWE = 1 : Endif
   Endif
   If [F:DUD]FCY<>[F:DAE]FCYLIN
    MESSA = mess(82,116,1) : Gosub ERRECH : # Site incorrect
    If RECUP : [F:DUD]FCY = [F:DAE]FCYLIN : RWE = 1 : Endif
   Endif
   If [F:DUD]SNS<>[F:DAE]SNS
    MESSA = mess(83,116,1) : Gosub ERRECH : # Sens incorrect
    If RECUP : [F:DUD]SNS = [F:DAE]SNS : RWE = 1 : Endif
   Endif
   If [F:DUD]CUR<>[F:HAE]CUR
    MESSA = mess(84,116,1) : Gosub ERRECH : # Devise incorrecte
    If RECUP : [F:DUD]CUR = [F:HAE]CUR : RWE = 1 : Endif
   Endif
   If [F:DUD]SAC<>[F:DAE]SAC
    MESSA = mess(23,116,1) : Gosub ERRECH : # Collectif incorrect
    If RECUP : [F:DUD]SAC = [F:DAE]SAC : RWE = 1 : Endif
   Endif
   If RWE & PEROK
    Trbegin [DUD]
    Rewrite [DUD]
     If fstat
      GOK = 0 : Call FSTA("DUD") From GLOCK
     Endif
     Call HISTOECH("DUD",1,[F:HAE]ACCDAT)From MODECHE
    Commit
   Endif
  Next
  If ECHNUM=0 | ECHCUR<>[F:DAE]AMTCUR | ECHLED<>[F:DAE]AMTLED
   MESSA = mess(85,116,1) : Gosub ERRLIG : # Echéances incorrectes
   If RECUP
    Trbegin [DUD]
     Gosub MODECHE From SUBGAS
    Commit
   Endif
  Endif
 Else
  ECHNUM = 0
  For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM
   MESSA = mess(86,116,1) : Gosub ERRLIG : # Echéances en trop
   ECHNUM = 1 : Break
  Next
  If RECUP & ECHNUM
   Trbegin [DUD]
    Gosub DELECHE From SUBGAS
   Commit
  Endif
 Endif
 If RWL & PEROK
  GOK = 1
  Trbegin [DAE]
  Rewrite [DAE]
  If fstat :  GOK = 0 : Call FSTA("DAE") From GLOCK :   Endif
  Commit
 Endif
Next

#-- Vérification des totaux
For I=1 To len(mess(0,2644,1))
 If [F:GCM]LED(I-1)<>""
  Call LECTURE("LED",[F:GCM]LED(I-1),"") From CONTOBJ
  If evalue("sum(TOTCUR"+num$(I)+"(1..NBSITE))")<>0 & [F:LED]BAL=2
   MESSA = mess(44,116,1)-[F:HAE]CUR-"("+mess(I,2644,1)+")" : GRAVE = 1 : Gosub ERRTET              # Pièce déséquilibrée en
  Elsif evalue("sum(TOTLED"+num$(I)+"(1..NBSITE))")<>0 & [F:LED]BAL=2
   MESSA = mess(44,116,1)-[F:HAE]CURLED([F:DAE]LEDTYP-1)-"("+mess(I,2644,1)+")" : Gosub ERRTET      # Pièce déséquilibrée en
   If RECUP : FLCNV = 1 : Endif
  Elsif [F:LED]FCYBAL=2
   For ISITE=1 To NBSITE
    If evalue("TOTCUR"+num$(I)+"(ISITE)")<>0
     MESSA = TBSITE(ISITE)-mess(44,116,1)-[F:HAE]CUR-"("+mess(I,2644,1)+")" : GRAVE = 1 : Gosub ERRTET   #  Pièce déséquilibrée en
    Elsif evalue("TOTLED"+num$(I)+"(ISITE)")<>0
     MESSA = TBSITE(ISITE)-mess(44,116,1)-[F:HAE]CURLED(I-1)-"("+mess(I,2644,1)+")" : Gosub ERRTET         #  Pièce déséquilibrée en
     If RECUP : FLCNV = 1 : Endif
    Endif
   Next ISITE
  Endif
 Endif
Next

If NBLIG>MAXLIG
 MESSA = mess(45,116,1)-num$(NBLIG) : GRAVE = 1 : Gosub ERRTET  # Trop de lignes
 FLNCNV = 1
Endif

If RW
  GOK = 1
  Trbegin [HAE]
  Rewrite [HAE]
  If fstat :   GOK = 0 : Call FSTA("HAE") From GLOCK :  Endif
  Commit
Endif
If FLCNV & !FLNCNV & PEROK
 Gosub CONVERT
Endif
Return

$ERRTET
Call ECR_TRACE(mess(46,116,1)-[F:HAE]TYP-[F:HAE]NUM,GRAVE) From GESECRAN
# Pièce
Goto ERREUR

$ERRLIG
Call ECR_TRACE(mess(46,116,1)-[F:DAE]TYP-[F:DAE]NUM-mess(47,116,1)-num$([F:DAE]LIN)-
&            "("+left$(mess(153,116,1),3)+"."-mess([F:DAE]LEDTYP,2644,1)+")",GRAVE) From GESECRAN
# Pièce... Ligne... (Réf. ...)
Goto ERREUR

$ERRANA
Call ECR_TRACE(mess(46,116,1)-[F:DAA]TYP-[F:DAA]NUM-mess(47,116,1)-num$([F:DAA]LIN)-
&            "("+left$(mess(153,116,1),3)+"."-mess([F:DAA]LEDTYP,2644,1)+")"-
&             mess(48,116,1)-num$([F:DAA]ANALIN),GRAVE) From GESECRAN
# Pièce... Ligne... (Réf. ...)  Analytique
Goto ERREUR

$ERRECH
Call ECR_TRACE(mess(46,116,1)-[F:DUD]TYP-[F:DUD]NUM-mess(47,116,1)-num$([F:DUD]LIG)
& -"Echéance"-num$([F:DUD]DUDLIG),GRAVE) From GESECRAN
# Pièce... Ligne... Echéance
Goto ERREUR

$ERREUR
Call ECR_TRACE("   "+MESSA,0) From GESECRAN
#------------------------------------
If !PEROK & !PERMSGDONE
 # Pas de récupération sur une période fermée
 Call ECR_TRACE(mess(158,116,1),1) From GESECRAN
 PERMSGDONE=1
Endif
#------------------------------------
ANOM += 1
GRAVE = 0
Return

########################################
Subprog AM_SOCIETE(VALEUR)
Variable Char VALEUR
GSOCIETE = VALEUR
Call AM_CPY(VALEUR) From CPTTRT
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call DEFEXE(VALEUR,GTYPGEN,[M:DIA]EXERCICE) From CPTSUB
Call DATEXE(VALEUR,GTYPGEN,[M:DIA]EXERCICE,[M:DIA]DATDEB,[M:DIA]DATFIN) From CPTSUB
If !GIMPORT
 Affzo EXERCICE, DATDEB, DATFIN
Endif
End

Subprog AP_SOCIETE(VALEUR)
Variable Char    VALEUR()
Call LECLEDMAIN(GTYPGEN,VALEUR,[M:DIA]LEDTYP) From CPTDIV
End

Subprog C_SOCIETE(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AS_TOUSITE(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
If [M]TOUSITE = 2 : VALEUR = "" : mkstat = 1 : End : Endif
End

Subprog C_EXERCICE(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]SOCIETE;GTYPGEN;VALEUR
If fstat
 GMESSAGE = mess(52,116,1) : mkstat = 2 : End        # Exercice incorrect
Endif
If [F:FIY]FIYSTA=3
 Local Integer OK
 OK = 1 : Call AVERTIR(mess(21,101,1),OK) From GESECRAN : # Exrcice clôturé
 If OK<>2 : mkstat = 2 : End : Endif
Endif
If VALEUR<>[M]EXERCICE
 [M]DATDEB = [F:FIY]FIYSTR
 [M]DATFIN = [F:FIY]FIYEND
 Affzo DATDEB, DATFIN
Endif
End

Subprog AS_EXERCICE(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 Filter [FIY] Where CPY=[M]SOCIETE and LEDTYP=GTYPGEN
 Read [FIY]FIY0 Last
 Filter [FIY]
 VALEUR = [F:FIY]FIYNUM
 [M]DATDEB = [F:FIY]FIYSTR
 [M]DATFIN = [F:FIY]FIYEND
 Affzo DATDEB, DATFIN
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR<[F:FIY]FIYSTR | VALEUR>[F:FIY]FIYEND
 GMESSAGE = mess(53,116,1) : mkstat = 2 : End
# Date en dehors de l'exercice
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR<[F:FIY]FIYSTR | VALEUR>[F:FIY]FIYEND
 GMESSAGE = mess(53,116,1) : mkstat = 2 : End
# Date en dehors de l'exercice
Endif
End

###################################################
# Recalcul des montants en devises

$CONVERT

NBLIG = 0
Raz MTDEB , MTCRE

GOK = 1
Trbegin [DAE]

# La re-synchronisation des montants doit s'effectuer  par Type de Référentiel (les devises de chaque Référentiel peuvent être différente)
For I=1 To len(mess(0,2644,1))
 If [F:GCM]LED(I-1)<>""
  Raz NBLIG
  Filter [DAE] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=I
  For [DAE]DAE0
   NBLIG += 1
   If [F:DAE]SNS>0
    MTDEB(NBLIG) = [F:DAE]AMTCUR
    MTCRE(NBLIG) = 0 #65024
   Else
    MTCRE(NBLIG) = [F:DAE]AMTCUR
    MTDEB(NBLIG) = 0 #65024
   Endif
   FLGLED(NBLIG) = [F:DAE]AMTFLG
   MTFLED(NBLIG) = [F:DAE]AMTLED1
   MTSIT(NBLIG)  = [F:DAE]FCYLIN
   SNSLED(NBLIG) = [F:DAE]SNS
   #-- Force les montants des lignes d'écritures lettrées en majuscule
   If [F:DAE]MTC>="A" and [F:DAE]MTC<="ZZZZZ"
    FLGLED(NBLIG) = 1
    MTFLED(NBLIG) = [F:DAE]AMTLED
   Endif
  Next

  Call LECTURE("TCU",[F:HAE]CUR,"") From CONTOBJ
  Call SETFLGDEV([F:HAE]CUR,[F:HAE]CPY,[F:HAE]RATDAT) From CPTDIV
  Raz COURS
  If [F:HAE]RATDIV([F:DAE]LEDTYP-1)<>0
   COURS = [F:HAE]RATMLT([F:DAE]LEDTYP-1)/[F:HAE]RATDIV([F:DAE]LEDTYP-1)
  Endif

  Call LEC_LED([F:GCM]LED(I-1)) From CPTLEC
  If [F:LED]BAL<>2
   Raz DEBLED, CDTLED
   For J=1 To NBLIG
    If MTDEB(J)<>0 & FLGLED(J)=0
     Call CONVERT3([F:HAE]CUR,[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]TYPRAT,[F:HAE]RATDAT,
&    MTDEB(J),DEBLED(J),COURS,STAT) From CPTSUB
    Endif
    If MTCRE(J)<>0 & FLGLED(J)=0
     Call CONVERT3([F:HAE]CUR,[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]TYPRAT,[F:HAE]RATDAT,
&    MTCRE(J),CDTLED(J),COURS,STAT) From CPTSUB
    Endif
    If FLGLED(J)<>0
     If MTDEB(J)<>0 : DEBLED(J) = MTFLED(J) : Endif
     If MTCRE(J)<>0 : CDTLED(J) = MTFLED(J) : Endif
    Endif
    If STAT : Break : Endif
   Next
  Else
   If NBLIG>0
    Call CONVERT_SIT([F:HAE]CUR,[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]CURLED([F:DAE]LEDTYP-1),0,NBLIG-1,MTDEB,
&                 DEBLED,MTCRE,CDTLED,FLGLED,MTFLED,MTSIT,[F:HAE]TYPRAT,[F:HAE]RATDAT,COURS,[F:TCU]CURRND,SNSLED,STAT) From SUBGA2
   Endif
  Endif
  If STAT
   Call ECR_TRACE(GMESSAGE-"/"-[F:HAE]CUR-"/"-[F:HAE]CURLED([F:DAE]LEDTYP-1)-"/"-num$(COURS),1) From GESECRAN : Rollback : Return
  Endif

  NBLIG = 0
  For [DAE]DAE0
   NBLIG += 1
   [F:DAE]AMTLED = DEBLED(NBLIG)+CDTLED(NBLIG)
   Rewrite [DAE]
   If fstat
    GOK = 0 : Call FSTA("DAE") From GLOCK
   Endif
   Raz NBANA,MTANA
   For [DAA] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LEDTYP=[F:DAE]LEDTYP & LIN=[F:DAE]LIN
    NBANA += 1
    MTANA(NBANA) = [F:DAA]AMTCUR
   Next
   If NBANA<>0
    If NBANA>1
     Call CONVERT_DEV([F:HAE]CUR,[F:HAE]CURLED([F:DAE]LEDTYP-1),[F:HAE]CURLED([F:DAE]LEDTYP-1),NBANA,MTANA,MTANALED,COURS,
&                     [F:HAE]TYPRAT,[F:HAE]RATDAT,AROLED) From CPTSUB
    Else
     MTANALED(1) = [F:DAE]AMTLED
    Endif
    Raz NBANA
    For [DAA] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LEDTYP=[F:DAE]LEDTYP & LIN=[F:DAE]LIN
     NBANA += 1
     [F:DAA]AMTLED = MTANALED(NBANA)
     Rewrite [DAA]
     If fstat
      GOK= 0 : Call FSTA("DAA") From GLOCK
     Endif
    Next
   Endif
  Next
 Endif
Next
Commit
Filter [DAE]
Return

