#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECHACC","RECHACC",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Integer I , J , K , INTE , OK , N
Local Char    ACS(10) , TEXTE(80)
Local Char    CLE(10)(1..16) , CHAINE(80)
Local Integer NBCLE
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Local Mask RECHACC [DIA]
Raz [M:DIA]
TRA = 1
Return

$EXEC
ACS = toupper([M:DIA]ACS)
Call OUVRE_BOITE(mess(24,115,1),100) From GESECRAN : # Recherche code d'accès
Call OUVRE_TRACE(mess(25,115,1)-ACS) From LECFIC : # Code d'accès
If [M:DIA]AMK=2 : Gosub ECRANS    : Endif
If [M:DIA]AUT=2 : Gosub AUTRES    : Endif
If [M:DIA]ACLA=2 : Gosub CLASSES    : Endif
If [M:DIA]ASW=2 : Gosub REPRESENTATIONS    : Endif
Call FERME_TRACE From LECFIC
Call FERME_BOITE From GESECRAN
Return


## classes
$CLASSES
Local File ACLASSE [ACLA] , ACLAFLD [ACLAF]
Call SET_BOITE(mess(3,140,1),nbrecord([F:ACLA])) From GESECRAN : # Tables
Call ECR_TRACE(mess(3,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ACLAF]ACLAF0(1)
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ACLAF]ACLAF0
  If [ACLAF]ACS<>"" & pat([ACLAF]ACS,ACS)
   Call TEXTE([ACLAF]INTFLD,TEXTE) From OBJDIV
   Call ECR_TRACE([ACLAF]ACS-":"-[ACLAF]CODCLA-mess(34,140,1)-[ACLAF]FLDCLA-TEXTE,0) From GESECRAN
#  Zone
  Endif
 Next
Next
Close Local File [ACLA] , [ACLAF]
Call ECR_TRACE("",0) From GESECRAN
Return

## classes
$REPRESENTATIONS
Local File ASHW [ASW] , ASHWFLD [ASWF]
Call SET_BOITE(mess(3,140,1),nbrecord([F:ASW])) From GESECRAN : # Tables
Call ECR_TRACE(mess(3,140,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [ASWF]ASWF0(1)
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [ASWF]ASWF0
  If [ASWF]ACS<>"" & pat([ASWF]ACS,ACS)
   Call TEXTE([ASWF]INTFLD,TEXTE) From OBJDIV
   Call ECR_TRACE([ASWF]ACS-":"-[ASWF]CODREP-mess(34,140,1)-[ASWF]CODFLD-TEXTE,0) From GESECRAN
#  Zone
  Endif
 Next
Next
Close Local File [ASW] , [ASWF]
Call ECR_TRACE("",0) From GESECRAN
Return

## Ecrans
$ECRANS
Local File AMSK [AMK] , AMSKZON [AMZ]
Call SET_BOITE(mess(17,125,1),nbrecord([AMK])) From GESECRAN : # Ecrans
Call ECR_TRACE(mess(17,125,1),0) From GESECRAN
Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
K = 0
For [AMZ]CODE(1)
 K += 1
 Call AFF_BOITE("",K,INTE) From GESECRAN
 For [AMZ]CODE
  If [F:AMZ]CODACC<>"" & pat([F:AMZ]CODACC,ACS)
   Call TEXTE([F:AMZ]INTIT,TEXTE) From OBJDIV
   Call ECR_TRACE([F:AMZ]CODACC-":"-[F:AMZ]CODMSK-mess(17,115,1)-[F:AMZ]CODZON-TEXTE,0) From GESECRAN
#  Zone
  Endif
 Next
Next
Close Local File [AMK] , [AMZ]
Call ECR_TRACE("",0) From GESECRAN
Return

## Autres tables
$AUTRES
Local File ATABZON [ATZ] , ATABLE [ATB] , ATABIND [ATI]
For [ATZ]CODTYP(2) Where CODTYP="ACS"
 If !find([F:ATZ]CODFIC,"ACCES","AMSKZON") & filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde"),0)>0
  Local File =[F:ATZ]CODFIC [FFF]
  Read [ATB]CODFIC = [F:ATZ]CODFIC
  Read [ATI]NUMLIG(2) = [F:ATZ]CODFIC;1
  CHAINE = [F:ATI]DESCRIPT
  NBCLE = 0
  While CHAINE<>""
   NBCLE += 1
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If    I & J  : I = min(I,J)
   Elsif J & !I : I = J
   Endif
   If I
    CLE(NBCLE) = left$(CHAINE,I-1) : CHAINE = right$(CHAINE,I+1)
   Else
    CLE(NBCLE) = CHAINE : CHAINE = ""
   Endif
  Wend
  Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
  Call SET_BOITE(TEXTE,nbrecord([FFF])) From GESECRAN
  K = 0 : N = 0
  For [FFF]
   K += 1
   Call AFF_BOITE("",K,INTE) From GESECRAN
   ACCES = evalue("[F:FFF]"+[F:ATZ]CODZONE)
   If ACCES<>"" & pat(ACCES,ACS)
    If N=0
     Call TEXTE([F:ATB]INTITFIC,TEXTE) From OBJDIV
     Call ECR_TRACE(TEXTE,0) From GESECRAN
     Call ECR_TRACE(string$(20,"-"),0) From GESECRAN
    Endif
    N += 1
    If [F:ATB]INTIT<>"" & evalue("type([F:FFF]"+[F:ATB]INTIT+")")>10
     TEXTE = evalue("[F:FFF]"+[F:ATB]INTIT)
    Else
     TEXTE = ""
    Endif
    GCLE = ""
    For I=1 To NBCLE
     GCLE -= num$(evalue("[F:FFF]"+CLE(I)))
    Next I
    Call ECR_TRACE(ACCES-":"-GCLE-TEXTE,0) From GESECRAN
   Endif
  Next
  Close Local File [FFF]
  If N>0
   Call ECR_TRACE("",0) From GESECRAN
  Endif
 Endif
Next
Close Local File [ATB] , [ATZ]
Return
