##########################################################################################################
#   Traitement de gestion de la consultation          Module CRM                  3 octobre 2000
#    de l'historique des états des demandes de sevrice
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIHBDISP

Local Char SZSRENUM(GLONVCR)

  GIHBDISP = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  # PARAM(1) = Numéro de demande de service
  SZSRENUM = PARAM(1)
  Gosub LOADSAT
  GIHBDISP = 1
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIHBDISP Then
    #Nettoie l'écran avant de partir.
    Raz [M:SRE5]
  Endif
  Kill GIHBDISP
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
$LOADSAT
Local Integer IZ

  IZ = 0
  If !clalev([F:SRS]) : Local File SRESAT [SRS] : Endif
  Filter [SRS] Where [F:SRS]SRENUM = SZSRENUM Order By [F:SRS]SATDAT Desc; [F:SRS]SATHOU Desc
  For [SRS]
    If IZ >= dim([M:SRE5]SATDAT)-1 Then
      Break
    Endif
    If [F:SRS]SAT <> "" Then
      [M:SRE5]SATDAT(IZ) = [F:SRS]SATDAT
      [M:SRE5]SATHOU(IZ) = [F:SRS]SATHOU
      Call GET_LIB(422, [F:SRS]SAT, [M:SRE5]SAT(IZ)) From CRM_UTIL
      [M:SRE5]ASS(IZ) = [F:SRS]ASS
      [M:SRE5]DET(IZ) = [F:SRS]DET
      ##################################################
      #  Affiche le nom de l'affectation en clair
      ##################################################
      If [M:SRE5]DET(IZ) <> "" Then
        Case [M:SRE5]ASS(IZ)
          When 1
            If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
            Read [FCY]FCY0=[M:SRE5]DET(IZ)
            If fstat Then
              [M:SRE5]DETCLA(IZ) = [M:SRE5]DET(IZ)
            Else
              [M:SRE5]DETCLA(IZ) = [F:FCY]FCYNAM
            Endif
          When 2
            Read [AUS]CODUSR=[M:SRE5]DET(IZ)
            If fstat Then
              [M:SRE5]DETCLA(IZ) = [M:SRE5]DET(IZ)
            Else
              [M:SRE5]DETCLA(IZ) = [F:AUS]NOMUSR
            Endif
          When 3
            If !clalev([F:QUE]) Local File QUEUE [QUE] : Endif
            Read [QUE]QUE0=[M:SRE5]DET(IZ)
            If fstat Then
              [M:SRE5]DETCLA(IZ) = [M:SRE5]DET(IZ)
            Else
              # FGR 23/09/2009 : X3SUIVI58037
              #[M:SRE5]DETCLA(IZ) = [F:QUE]TTR
              Call LECTEXTRA([M:SRE5]DETCLA(IZ),"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
            Endif
          When 4
            # FGR 09/03/2009 : X3SUIVI26656
            If [M:SRE5]DET(IZ) = "" Then
              [M:SRE5]DETCLA(IZ) = ""
            Else
              If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
              Read [BPR]BPR0=[M:SRE5]DET(IZ)
              If fstat Then
                [M:SRE5]DETCLA(IZ) = ""
              Else
                [M:SRE5]DETCLA(IZ) = mess(292,196,1) - [F:BPR]BPRNAM
              Endif
            Endif
          When 5
            If [M:SRE5]DET(IZ) = "" Then
              [M:SRE5]DETCLA(IZ) = ""
            Else
              Read [AUS]CODUSR=[M:SRE5]DET(IZ)
              If fstat Then
                [M:SRE5]DETCLA(IZ) = ""
              Else
                [M:SRE5]DETCLA(IZ) = mess(351,196,1) - [F:AUS]NOMUSR
              Endif
            Endif
          When Default
        Endcase
      Else
        [M:SRE5]DETCLA(IZ) = ""
      Endif
      IZ += 1    
    Endif
  Next
  Filter [SRS]
  [M:SRE5]NBSAT = IZ
  Affzo [M:SRE5]1-99
Return
