#<AdxTL>@(#)0.0.0.0 $Revision$

#EMPCTRUKISTG
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "PROPVALUE"          : Gosub PROPVALUE
Endcase
Return


$PROPVALUE
#(PPROPERTY,PVALUE,PLEG) - Parameters
Gosub PROPVALUE From PIHRMFAIR_FUNCTIONS
Return

$INIT_CURRCLASS
Local Integer EMPSTGINIT
Local Instance  I_EMPCTRUKISTG  Using C_EMPCTRUKISTG
I_EMPCTRUKISTG  = NewInstance C_EMPCTRUKISTG AllocGroup null
INITCLASS  = fmet I_EMPCTRUKISTG.AINIT()
Return

$WRITE_CURRCLASS
Local Integer WRITESTATUS,ERRHANDLE
#Invoke the creation process and handle the error if applicable
#We will always invoke creation here as it is the staging tables
#Before writing the values - we need to check for errors

#Add system properties / keys
I_EMPCTRUKISTG.INTUID = VUNIQID

#Additional handling
#Control of fields or Legislation specific handling
Gosub CONTROL_FIELDS

##Handle possible errors - ERRHANLDE will be called before and during the AINSERT
#ERRHANDLE = func PIHRMFAIR_FUNCTIONS.HANDLE_EMPLOYEE_ERRORS_CLASS(I_EMPCTRUKISTG,"Employment",1,"Validation","ERROR",VUNIQID,VLEG,VPROCESSID,I_EMPCTRUKISTG.INTID,I_EMPCTRUKISTG.REFNUM,
#& ACTIVE_CLASS)

[L]WRITESTATUS = fmet I_EMPCTRUKISTG.AINSERT()
If ([L]WRITESTATUS >= [V]CST_AERROR)
  ERRHANDLE = func PIHRMFAIR_FUNCTIONS.HANDLE_EMPLOYEE_ERRORS_CLASS(I_EMPCTRUKISTG,"Employment",1,"Validation","ERROR",VUNIQID,VLEG,VPROCESSID,I_EMPCTRUKISTG.INTID,I_EMPCTRUKISTG.REFNUM,
& ACTIVE_CLASS)
Endif

Gosub FREE_CURRCLASS
Return

$FREE_CURRCLASS
FreeGroup I_EMPCTRUKISTG
Return


$PROPVAL_INIT
Local Char ERROR_MSG(250)
Local Integer INVOKE_ERROR
PROPRETVAL = fmet I_EMPCTRUKISTG.PROPVALUE(PROPERTY,PROPVAL,VLEG,ERROR_MSG)

##Handle the possible error - Add it as a warning and let the supervisor handle it on CRUD
#If ([L]PROPRETVAL >= [V]CST_AWARNING)
#  INVOKE_ERROR = fmet I_EMPCTRUKISTG.ASETERROR(PROPERTY,ERROR_MSG,PROPRETVAL)
#Endif
Return
Return

$CONTROL_FIELDS
I_EMPCTRUKISTG.SETDEF = 2
I_EMPCTRUKISTG.TYP    = 1
Return

$CLASS_UPDATE
Local Integer READSTATUS,UPDSTATUS,AINITSTATUS,NUMREC,EMP_UPDFLG,NUMERR
Local Char ERRMSG(250)
Local File EMPCTRUKISTG [CTRUSG1]
For [CTRUSG1]CTRUSG2 Where INTUID = PINTUID
  Local Instance  I_EMPCTRUKISTG_UPD  Using C_EMPCTRUKISTG
  I_EMPCTRUKISTG_UPD  = NewInstance C_EMPCTRUKISTG AllocGroup null
  READSTATUS = fmet I_EMPCTRUKISTG_UPD.AREAD([F:CTRUSG1]REFNUM,[F:CTRUSG1]CTRNUM,[F:CTRUSG1]CTRDAT)
  #Test READSTATUS
  If [L]READSTATUS = [V]CST_AOK
    Gosub EMPLOID_UPDATE
    If [L]ARET_VALUE <>[V]CST_AOK
      [L]EMP_UPDFLG = [V]CST_AWARNING
      [L]NUMERR+=1
      Call GET_ERRORS(I_EMPCTRUKIINS,ERRMSG)
    Else
      [L]NUMREC+=1
    Endif
  Endif
  FreeGroup I_EMPCTRUKISTG_UPD
Next

#TODO: Create function - pass results back to main method
If [L]EMP_UPDFLG = [V]CST_AOK
  ASTATUS = fmet this.ASETERROR("","Employee UK contract records updated : "+num$(NUMREC),[V]CST_AINFO)
Else
  ASTATUS = fmet this.ASETERROR("","Employee UK contract records updated : "+num$(NUMREC)+ " , Errors found ; "+num$(NUMERR)-ERRMSG,[V]CST_AWARNING)
Endif
LogicClose File [CTRUSG1]
Return

$EMPLOID_UPDATE
Local Integer READSTATUS,UPDSTATUS,WRITESTATUS,INITSTATUS

#This was set as a method on the class but removed and set as normal prog
#Setting the return value for the method
[L]ARET_VALUE = [V]CST_AWARNING
[L]INITSTATUS = [V]CST_AWARNING
[L]WRITESTATUS = [V]CST_AERROR

#Instantiate the employee class
Local Instance  I_EMPCTRUKIINS Using C_EMPCTRUKIINS
If (I_EMPCTRUKIINS <> null) : FreeGroup I_EMPCTRUKIINS : Endif
I_EMPCTRUKIINS  = NewInstance C_EMPCTRUKIINS AllocGroup null
READSTATUS = fmet I_EMPCTRUKIINS.AREAD(I_EMPCTRUKISTG_UPD.REFNUM,I_EMPCTRUKISTG_UPD.CTRNUM,I_EMPCTRUKISTG_UPD.CTRDAT)
#Test the read status to decide if the record must be updated or created
If READSTATUS = [V]CST_AOK
  #Record exist - Update
  Gosub UPDATE_FIELD From EMPCTRUKIINS_CSTD
  [L]ARET_VALUE = UPDSTATUS
Else
  INITSTATUS    = fmet I_EMPCTRUKIINS.AINIT()
  If INITSTATUS = [V]CST_AOK
    Gosub DUPLICATE From EMPCTRUKIINS_CSTD
    [L]ARET_VALUE = WRITESTATUS
  Endif
Endif
Return

Subprog GET_ERRORS(WCONTAINER,VERRMSG)
Variable Char VERRMSG
Variable Instance WCONTAINER Using C_EMPCTRUKIINS

Local Integer I
Local Char WTEXTE(50)

 VERRMSG = func LCCLIB.MAXMSG(WCONTAINER)
End

