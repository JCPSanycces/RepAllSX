#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
# Etape 1 de la définition d'un salon professionnel                 Module CRM          07 novembre 2000 #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer ISDIRTY

  If !clalev([F:HD5]) : Local File HD5CLOB [HD5] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  ISDIRTY = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If ISDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Raz [M:OMT0]
  Raz [M:OMT1]
  Raz [M:OMT2]
  If GSZOPGNUM = "" Then
    Gosub SETOPGNUM
  Else
    Gosub LOADOPG
  Endif
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:OMT0]
  Raz [M:OMT1]
  Raz [M:OMT2]
  Kill ISDIRTY
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  ISDIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################

##########################################################################################################
$ONOK
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCPT(GLONANM)

  SZCPT = ""
  Gosub CHECKDATA From SUBOMTB
  If OK = 0 Then
    FIN = 0
    Return
  Endif
  If GSZOPGNUM = "" Then
    # Récupération du compteur Activité commerciale
    # ----------------------------------------------------------
    # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
    #    If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
    #    Read [TCA]TCA0=13
    #    If fstat Then
    #      GERR = 1
    #      GMESSAGE = mess(64,199,1)
    #    Endif
    #    GMANCOU = [F:TCA]MANCOU(2)
    #    SZCPT = [F:TCA]CODNUM(2)
    Call READ_COUNTER([M:OMT0]FCY, 13, 2, GSOCIETE, GCURLEG, SZCPT, GMANCOU) From CRM_UTIL
    # FGR 20/12/2012 : X3SUIVI71937 (fin)
    # ----------------------------------------------------------
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMT0]FCY, SZCPT, date$, "", [M:OMT0]OMTNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        GSZOPGNUM = [M:OMT0]OMTNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        Return
      Endif
    Else
      GSZOPGNUM = [M:OMT0]OMTNUM
    Endif
  Endif
  [M:OMT1]TYPFULOBJ = "OMT"
  [M:OMT1]NUMFULOBJ = [M:OMT0]OMTNUM
  Call DEBTRANS From GLOCK
  Trbegin [OMT]
  Readlock [OMT]OMT0=[M:OMT0]OMTNUM
  If fstat Then
    #Il s'agit d'un nouvel enregistrement
    # FGR 25/07/2013 : X3SUIVI91397 (début)
    [F:OMT] = [M:OMT0]
    [F:OMT] = [M:OMT1]
    [F:OMT] = [M:OMT2]
    # FGR 25/07/2013 : X3SUIVI91397 (fin)
    [F:OMT]OMTNUM = [M:OMT0]OMTNUM
    [F:OMT]FCY = [M:OMT0]FCY
    [F:OMT]CUR = [M:OMT0]CUR
    [F:OMT]CMGNUM = [M:CMG0]NUM
    [F:OMT]DES = [M:OMT1]DES
    [F:OMT]OBJ = [M:OMT1]OBJ
    [F:OMT]NEWPPTOBJ = [M:OMT1]NEWPPTOBJ
    [F:OMT]OMTSTR = [M:OMT2]OMTSTR
    [F:OMT]OMTEND = [M:OMT2]OMTEND
    [F:OMT]BOOSUR = [M:OMT2]BOOSUR
    [F:OMT]BOOSURBAS = [M:OMT2]BOOSURBAS
    [F:OMT]BOOCST = [M:OMT2]BOOCST
    [F:OMT]OTHCST = [M:OMT2]OTHCST
    [F:OMT]CREDAT = date$
    [F:OMT]CREUSR = GUSER
    [F:OMT]UPDDAT = [00/00/00]
    [F:OMT]UPDUSR = ""
    [F:OMT]TYPFULOBJ = [M:OMT1]TYPFULOBJ
    [F:OMT]NUMFULOBJ = [M:OMT1]NUMFULOBJ
    [F:OMT]OBJFLG = [M:OMT1]OBJFLG
    Write [OMT]
    If fstat Then
      #L'enregistrement du salon professionnel a échoué.
      GMESSAGE = mess(888,182,1)
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMTB
      If GOK < 1 Then
        #L'enregistrement du salon professionnel a échoué.
        GMESSAGE = mess(888,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Else
    # Il s'agit d'une modification
    # FGR 25/07/2013 : X3SUIVI91397 (début)
    [F:OMT] = [M:OMT0]
    [F:OMT] = [M:OMT1]
    [F:OMT] = [M:OMT2]
    # FGR 25/07/2013 : X3SUIVI91397 (fin)
    [F:OMT]OMTNUM = [M:OMT0]OMTNUM
    [F:OMT]FCY = [M:OMT0]FCY
    [F:OMT]CUR = [M:OMT0]CUR
    [F:OMT]CMGNUM = [M:CMG0]NUM
    [F:OMT]DES = [M:OMT1]DES
    [F:OMT]OBJ = [M:OMT1]OBJ
    [F:OMT]NEWPPTOBJ = [M:OMT1]NEWPPTOBJ
    [F:OMT]OMTSTR = [M:OMT2]OMTSTR
    [F:OMT]OMTEND = [M:OMT2]OMTEND
    [F:OMT]BOOSUR = [M:OMT2]BOOSUR
    [F:OMT]BOOSURBAS = [M:OMT2]BOOSURBAS
    [F:OMT]BOOCST = [M:OMT2]BOOCST
    [F:OMT]OTHCST = [M:OMT2]OTHCST
    [F:OMT]TYPFULOBJ = [M:OMT1]TYPFULOBJ
    [F:OMT]NUMFULOBJ = [M:OMT1]NUMFULOBJ
    [F:OMT]OBJFLG = [M:OMT1]OBJFLG
    [F:OMT]UPDDAT = date$
    [F:OMT]UPDUSR = GUSER
    Rewrite [OMT]
    If fstat Then
      #L'enregistrement du salon professionnel a échoué.
      GMESSAGE = mess(888,182,1)
      Rollback
      Return
    Else
      Gosub SAVECLOB From SUBOMTB
      If GOK < 1 Then
        #L'enregistrement du salon professionnel a échoué.
        GMESSAGE = mess(888,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
  ISDIRTY = 0
Return

##########################################################################################################
$SETOPGNUM
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  [M:OMT0]CMGNUM = [M:CMG0]NUM
  [M:OMT0]CMGTTR = [M:CMG0]TTR
  #Définit la devise par défaut
  [M:OMT0]FCY = [M:CMG0]FCY
  [M:OMT0]CUR = GSYSCUR
  [M:OMT2]CUR1 = GSYSCUR
  [M:OMT2]CUR2 = GSYSCUR
  [M:OMT2]CUR3 = GSYSCUR
  Call CMGINIDATES([M:OMT0]CMGNUM,[M:OMT2]OMTSTR, [M:OMT2]OMTEND,IERRINF,ICHAPTER, IBRETOUR)  From SUBCMGB
  [M:OMT2]BOOSURBAS = mess(338, 196, 2) #m2
  Gosub DISPICON From SUBOMTB
  Affzo [M:OMT0]1-99
  Affzo [M:OMT1]1-99
  Affzo [M:OMT2]1-99
Return

##########################################################################################################
$LOADOPG
  Read [OMT]OMT0=GSZOPGNUM
  If fstat Then
    Return
  Endif
  Read [CMG]CMG0=[F:OMT]CMGNUM
  If fstat Then
    [M:OMT0]CMGTTR = ""
  Else
    [M:OMT0]CMGTTR = [F:CMG]TTR
  Endif
  [M:OMT0]CMGNUM = [F:OMT]CMGNUM
  [M:OMT0]OMTNUM = [F:OMT]OMTNUM
  [M:OMT0]FCY = [F:OMT]FCY
  [M:OMT0]CUR = [F:OMT]CUR

  [M:OMT1]DES = [F:OMT]DES
  [M:OMT1]OBJ = [F:OMT]OBJ
  [M:OMT1]NEWPPTOBJ = [F:OMT]NEWPPTOBJ

  [M:OMT2]OMTSTR = [F:OMT]OMTSTR
  [M:OMT2]OMTEND = [F:OMT]OMTEND
  [M:OMT2]BOOSUR = [F:OMT]BOOSUR
  [M:OMT2]BOOSURBAS = mess(338, 196, 2) #m2
  [M:OMT2]BOOCST = [F:OMT]BOOCST
  [M:OMT2]OTHCST = [F:OMT]OTHCST
  [M:OMT2]TOTBUD = [F:OMT]OTHCST + [F:OMT]BOOCST
  [M:OMT2]CUR1 = [M:OMT0]CUR
  [M:OMT2]CUR2 = [M:OMT0]CUR
  [M:OMT2]CUR3 = [M:OMT0]CUR

  [M:OMT1]TYPFULOBJ = [F:OMT]TYPFULOBJ
  [M:OMT1]NUMFULOBJ = [F:OMT]NUMFULOBJ
  [M:OMT1]OBJFLG = [F:OMT]OBJFLG

  Read [HD5]HD50=[F:OMT]NUMFULOBJ;[F:OMT]TYPFULOBJ
  If fstat Then
    Raz [M:OMT1]FULOBJ
  Else
    [M:OMT1]FULOBJ = [F:HD5]CLOB
  Endif
  Gosub DISPICON From SUBOMTB
  Affzo [M:OMT0]1-99
  Affzo [M:OMT1]1-99
  Affzo [M:OMT2]1-99
Return

##########################################################################################################
$CANCELSTEP
  Call DEBTRANS From GLOCK
  Trbegin [OMT]
  Readlock [OMT]OMT0=GSZOPGNUM
  If fstat Then
    Rollback
    Return
  Endif
  Delete [HD5] Where [F:HD5]NUM = [F:OMT]NUMFULOBJ and [F:HD5]TYP = [F:OMT]TYPFULOBJ
  If fstat Then
    Rollback
    Return
  Endif
  Delete [OMT]Curr
  If fstat Then
    Rollback
    Return
  Else
    Commit
  Endif
Return
