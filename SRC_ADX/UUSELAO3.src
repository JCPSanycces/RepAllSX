Call PATCH("TEST3")
End

##############################################################################
## MAJ de l'onglet sélection de l'objet AO3 (Sas import/export par erreur)
##############################################################################

Subprog EXE_SELAO3(APPLI)
Value Char APPLI

Call ECR_TRACE("SELAO3 : Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Call MAJ_SEL(APPLI,"AO3") From PATCHAOB
Call ECR_TRACE("SELAO3 : Process End on : "+APPLI,0) From GESECRAN
End


Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_SELAO3(APPLI)
End

