#<AdxTL>@(#)3.0.0.0 $Revision$
#####################################################################################
# UTITC45 : Initialization of the value of the LASINTNUM Internal Parameter         #
#####################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Initialization of the LASINTNUM Parameter") From LECFIC
 Call MAJ_UTITC45(DOSSIER) 
 
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End


#####################################################################################
Subprog MAJ_UTITC45(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTITC45 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open Tables -----#
If clalev([F:ADW])  =0  Local File =DOSSIER+".ADOVAL"   [ADW]  : Endif


Local Integer WACCNUM
Local Integer COMPTEUR

Call DEBTRANS From GLOCK


Trbegin [ADW]

 Readlock [ADW]ADW1 = "LASINTNUM";"";""    
 If fstat>1
  Raz [F:ADW]
  [F:ADW]PARAM  = "LASINTNUM"
  Call ACCNUM(DOSSIER,WACCNUM)
  [F:ADW]VALEUR = num$(WACCNUM)
  [F:ADW]CREDAT = date$
  [F:ADW]CREUSR = GUSER
  ## The field that contains the time has been renamed in V8... 
  If dim([F:ADW]CRETIM)>0
   [F:ADW]CRETIM = time 
  Elsif dim([F:ADW]CREDATTIM)>0
   [F:ADW]CREDATTIM = time
  Endif
  Write [ADW]
  If !fstat : COMPTEUR +=1 : Endif
 Elsif !fstat
  Call ACCNUM(DOSSIER,WACCNUM)
  [F:ADW]VALEUR = num$(WACCNUM)
  [F:ADW]UPDDAT = date$
  [F:ADW]UPDUSR = GUSER
  ## The field that contains the time has been renamed in V8... 
  If dim([F:ADW]UPDTIM)>0
   [F:ADW]UPDTIM = time
  Elsif dim([F:ADW]UPDDATTIM)>0
   [F:ADW]UPDDATTIM = time
  Endif

  Rewrite [ADW]
  If !fstat : COMPTEUR +=1 : Endif
 Endif

Commit

Close Local File [ADW]

Call ECR_TRACE("UTITC45 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End


Subprog ACCNUM(DOSSIER,NUM)
Value    Char    DOSSIER()
Variable Integer NUM
If filinfo(filpath("FIL","GACCENTRYD","fde",DOSSIER),0)>0 
 Local File =[L]DOSSIER+".GACCENTRYD" [DAE]
Elsif filinfo(filpath("FIL","GACCTMPD","fde",DOSSIER),0)>0
 Local File =[L]DOSSIER+".GACCTMPD" [DAE]
Endif
NUM = uniqid([F:DAE])
End


########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif  

Call MAJ_UTITC45(APPLI)  
      
End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

If APPLI="X3" End : ENDIF
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTITC45(APPLI)
End


