#########################################################################
#                                                                       #
#      TRAITEMENTS de DATES et PERIODES dans les ACHATS                 #
#                                                                       #
#########################################################################
# GA selon CALC_DAT* de TRTVENDAT
#########################################################################
#########################################################################
#                                                                       #
# Subprog CALC_DAT (ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, DSTDAT)        #
#      Calcul date = date +/- delai avec ctrl jours indispo             #
#                                                                       #
# Subprog CALC_DAT_FCY(ORIDAT, LTI, ORIFCY, SENCAL, DSTDAT)             #
#      Calcul date = date +/- delai avec ctrl jours indispo site        #
#                                                                       #
# Subprog CALC_DAT_BPD(ORIDAT, LTI, BPAADD, BPCORD, SENCAL, DSTDAT)     #
#      Calcul date = date +/- delai avec ctrl jours indispo client [BPD]#
#                                                                       #
# Subprog CTRL_DAT_HGH (ORIDAT,DSTDAT)                                  #
#      Si la date DST est < à la date ORI, DST = ORI                    #
# Subprog CTRL_DAT_LOW (ORIDAT,DSTDAT)                                  #
#      Si la date DST est > à la date ORI, DST = ORI                    #
#                                                                       #
#########################################################################


#----------------------------------------------------------------#
# Calcul d'une date à partir d'une date et un delai              #
#                     avec ctrl jours et périodes indispo        #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         UVYDAY   : Jours indisponibilités                      #
#         UVYCOD   : Code période indisponibilité                #
#         SENCAL   : Sens de calcul date                         #
#             0 => addition, sinon soustraction                  #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALC_DAT(ORIDAT, LTI, UVYDAY, UVYCOD, SENCAL, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Libelle  UVYDAY 
Value    Char     UVYCOD
Value    Integer  SENCAL
Variable Date     DSTDAT

If SENCAL = 0
     DSTDAT = ORIDAT + LTI
Else DSTDAT = ORIDAT - LTI:Endif
# -----------------------------------#
#  Point d'entree calcul d'une date  #
# -----------------------------------#
Local Integer WPE_CTLDAT : WPE_CTLDAT=1
GPOINT="CALCDAT" : Gosub ENTREE From EXEFNC : #CHECK IGNORE_LINE
If WPE_CTLDAT=0 : End : Endif
# --> Controle date par rapport jours indisponibilites
Call CTL_JOU(DSTDAT, UVYDAY, UVYCOD, SENCAL) From CONTX3
End

#----------------------------------------------------------------#
# Calcul d'une date d'expedition avec une date et un délai       #
#                        et ctrl jours et périodes indispo site  #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         ORIFCY   : Site expedition                             #
#         SENCAL   : Sens de calcul date                         #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALC_DAT_FCY(ORIDAT, LTI, ORIFCY, SENCAL, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Char     ORIFCY
Value    Integer  SENCAL
Value    Date     CTRDAT
Variable Date     DSTDAT

Local    Integer  UVYDAY (0..6)
Local    Integer  I

If [F:FCY]FCY <> ORIFCY
    Read [F:FCY]FCY0 = ORIFCY
    If fstat Raz [F:FCY] : Endif
Endif
Call CALC_DAT(ORIDAT, LTI, [F:FCY]UVYDAY, [F:FCY]UVYCOD, SENCAL, DSTDAT)

End

#----------------------------------------------------------------#
# Calcul d'une date de livraison avec une date et un délai       #
#                        et ctrl jours et périodes indispo bpd   #
#----------------------------------------------------------------#
# Entrée  ORIDAT   : Date origine                                #
#         LTI      : Délai                                       #
#         BPAADD   : Client livré                                #
#         BPCORD   : Client commande                             #
#         SENCAL   : Sens de calcul date                         #
# Sortie  DSTDAT   : Date destination                            #
#----------------------------------------------------------------#
Subprog CALC_DAT_BPD(ORIDAT, LTI, BPAADD, BPCORD, SENCAL, DSTDAT)
Value    Date     ORIDAT
Value    Integer  LTI
Value    Char     BPAADD
Value    Char     BPCORD
Value    Integer  SENCAL
Variable Date     DSTDAT

Local    Integer  UVYDAY (0..6)
Local    Integer  I

#GA Mai 2006
#If [F:BPD]BPCNUM <> BPCORD | [F:BPD]BPAADD <> BPAADD 
#   Read [BPD]BPD0 = BPCORD;BPAADD
#   If fstat Raz [F:BPD] : Endif
#Endif 
Local Char WBPRNUM(GLONBPR) : WBPRNUM=BPCORD
Local Char WBPAADD(GLONBPA) : WBPAADD=BPAADD
Gosub READ_BPD From BPRLIB

For I=0 To 6
    UVYDAY(I) = evalue ("[F:BPD]UVYDAY"+num$(I+1))
Next
Call CALC_DAT(ORIDAT, LTI, UVYDAY, [F:BPD]UVYCOD, SENCAL, DSTDAT)
End

#----------------------------------------------------------------#
# Fonctions de Contrôle [remplacement si non ok] entre deux dates# 
# Subprog CTRL_DAT_HGH (ORIDAT,DSTDAT)                           #
#      Si la date DST est < à la date ORI, DST = ORI             #
#----------------------------------------------------------------#
Subprog CTRL_DAT_HGH (ORIDAT,DSTDAT)
Value    Date     ORIDAT
Variable Date     DSTDAT
   If DSTDAT < ORIDAT
      DSTDAT = ORIDAT
   Endif 
End

#----------------------------------------------------------------#
# Fonctions de Contrôle [remplacement si non ok] entre deux dates# 
# Subprog CTRL_DAT_LOW (ORIDAT,DSTDAT)                           #
#      Si la date DST est > à la date ORI, DST = ORI             #
#----------------------------------------------------------------#
Subprog CTRL_DAT_LOW (ORIDAT,DSTDAT)
Value    Date     ORIDAT
Variable Date     DSTDAT
   If DSTDAT > ORIDAT
      DSTDAT = ORIDAT
   Endif 
End
