#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################
## Récup des utilisateurs nommés
################################################################
Call OUVRE_TRACE("Update Users") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ

Local Integer NB , NBMAX , ER , VIDE
Local Char    SYMBOLE(50) , DOSX3(20)

VIDE = 0 : # Pas de raz

SYMBOLE = "RECAUO"

NBMAX = func ARECAUO.NBR_UTINOM
If NBMAX=0
 Return
Endif

Local File ADOSSIER [ADX2]
Local File AUSRSOL  [AUO]
Local File =DOSSIER+".ADOVAL"  [ADW]

Read [ADW]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW]VALEUR<>""
 DOSX3 = [F:ADW]VALEUR
Endif

If DOSX3="" or nomap=DOSX3
 Lock =SYMBOLE
Else
 Lock =SYMBOLE From =DOSX3
Endif
If fstat
 Close Local File
 Return
Endif

Call DEBTRANS From GLOCK
If VIDE or nbrecord([AUO])>NBMAX
 Gosub EFFACE
 NB = 0
Else
 NB = nbrecord([AUO])
Endif

Local File =DOSSIER+".AUTILIS"  [AUS]
Gosub TR2
Close Local File [AUS]

For [ADX2]
 If !func ARECAUO.APPRAC([F:ADX2]DOSSIER) & !func ARECAUO.APPDEM([F:ADX2]DOSSIER)
  ER = 0
  Onerrgo ERFIC
  If filinfo(filpath("FIL","AUTILIS","fde",[F:ADX2]DOSSIER),0)>=0
   Local File =[F:ADX2]DOSSIER+".AUTILIS" [AUS]
   Onerrgo
   Gosub TR1
   Close Local File [AUS]
  Endif
  Onerrgo
 Endif
Next ADX2

If DOSX3="" or nomap=DOSX3
 Unlock =SYMBOLE
Else
 Unlock =SYMBOLE From =DOSX3
Endif

Close Local File

Return

$ERFIC
ER = errn
Resume

$EFFACE
GOK = 1
Trbegin [AUO]
 Delete [AUO] Where 1=1
Commit
Return

$TR1
GOK = 1
Trbegin [AUO]
 For [AUS] Where ENAFLG=2 & USRCONNECT=2
  If !func ARECAUO.USRSAG([F:AUS]USR)
   Look [AUO]AUO0=[F:AUS]USR
   If fstat
    If NB<NBMAX
     [F:AUO] = [F:AUS]
     Write [AUO]
     NB += 1
    Else
     Readlock [AUS] Curr
     If !fstat
      [F:AUS]ENAFLG = 1
      Rewrite [AUS]
     Endif
    Endif
   Endif
  Endif
 Next
Commit
Return

$TR2
GOK = 1
Trbegin [AUO]
 Read [AUS]CODUSR = GSUPER
 Read [AUO]AUO0 = GSUPER
 If fstat
  [F:AUO] = [F:AUS]
  Write [AUO]
  NB += 1
 Endif
Commit
Return


