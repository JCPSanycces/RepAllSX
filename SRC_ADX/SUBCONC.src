#<AdxTL>@(#)11.0.0.0 $Revision$
#############################################################################################
#   Composants technique de gestion de contrat de service       Module CRM       20 Aout 2003 
#
# CRECON    : Sous-programme de création d'un contrat de service.
# UPDCON    : Sous-programme de mise à jour d'un contrat de service. (Dans le traitement SUBCONCB)
# DELCON    : Sous-programme de suppression d'un contrat de service.
# DUPLICON  : Sous-programme de duplication d'un contrat de service.
#
#############################################################################################
#############################################################################################
# Sous-programme de création d'un contrat de service.
#############################################################################################
Subprog CRECON(SZCRECONTRT, ITRACE, ILEC_TRACE, SZCONNUM, LERRCOD) 
Value Char SZCRECONTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Variable Char SZCONNUM
Variable Integer LERRCOD

Global Char GSZCRECONTRT
Global Integer GICRECONTRACE

Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG

  GSZCRECONTRT = SZCRECONTRT
  GICRECONTRACE = ITRACE
  IBOPENTRACE = 0
  If GSZCRECONTRT = "" Then
    GSZCRECONTRT = "SUBCONC"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Création de contrat de service démarrée à partir du contexte : + GSZCRECONTRT
      Call OUVRE_TRACE (mess(434,177,1) - GSZCRECONTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif

  #--- variables
Local Integer OK, SAVGIMPORT 
Local Char ACTION(20), ABREV(5) 
Local Char SAVGABREV

  #--- declaration et chargement des variables objet 
  ABREV = "CON"
  SAVGABREV = GABREV
  GABREV = "CON"
  Gosub DEFVAR From GOBJET
  SAVGIMPORT = GIMPORT
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK = 1
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION="AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If clalev([M:CON0])=0 : Local Mask CON0 [CON0] : Endif
  If clalev([M:CON1])=0 : Local Mask CON1 [CON1] : Endif
  If clalev([M:CON4])=0 : Local Mask CON4 [CON4] : Endif
  If clalev([M:CON8])=0 : Local Mask CON8 [CON8] : Endif
  If clalev([M:CONG])=0 : Local Mask CONG [CONG] : Endif
  If clalev([M:CON2])=0 : Local Mask CON2 [CON2] : Endif
  If clalev([M:CON5])=0 : Local Mask CON5 [CON5] : Endif
  Raz [M:CON0], [M:CON1], [M:CON4], [M:CON8], [M:CONG], [M:CON2], [M:CON5]
  #--- ouverture des tables necessaires
  If clalev([F:CON])=0 : Local File CONTSERV [CON] : Endif
  Gosub OUVRE From WOCON 
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
        Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  WINPROG = "WGOCON"
  GREP = "C"
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=RAZCRE",0) From GESECRAN
  Endif
  ACTION = "RAZCRE" : Gosub ACTION From GOBJSUB
  If GERR = 1 Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR RAZCRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- chargement des masques de objet
  If ITRACE > 1 Then
    Call ECR_TRACE("MASK",0) From GESECRAN
  Endif
  #------------------------------------------------------------------------  
  # chargement masques enregistrement entête facture
  Default Mask [CON0]
  Call SAIMSK("CON","IMP_ZONE","SUBCONC") From W0CON0
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CON0 mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  Default Mask [CON1]
  Call SAIMSK("CON","IMP_ZONE","SUBCONC") From W0CON1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CON1 mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  Default Mask [CON4]
  Call SAIMSK("CON","IMP_ZONE","SUBCONC") From W0CON4
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CON4 mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  Default Mask [CON8]
  Call SAIMSK("CON","IMP_ZONE","SUBCONC") From W0CON8
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CON8 mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  Default Mask [CONG]
  Call SAIMSK("CON","IMP_ZONE","SUBCONC") From W0CONG
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CONG mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  Default Mask [CON2]
  Call SAIMSK("CON","IMP_ZONE","SUBCONC") From W0CON2
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CON2 mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  Default Mask [CON5]
  Call SAIMSK("CON","IMP_ZONE","SUBCONC") From W0CON5
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK CON5 mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  # FGR 15/09/2008 : X3SUIVI49186 : Appel du PE avec la méthode "standard" CRM + Doc jamais faite
  Gosub PE_MSKCRECON From TRTCRMPE
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  GPOINT=MSKCRECON mkstat=" + num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 8
    Gosub ONERROR
    End
  Endif
  #
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERIF_CRE",0) From GESECRAN
  Endif
  #
  ACTION = "VERIF_CRE"   : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERIF_CRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #
  GOK = 1
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CON]
  Endif
  #
  Raz [F:CON]
  Default File [F:CON]
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=INICRE",0) From GESECRAN
  Endif
  #
  ACTION = "INICRE"      : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
        Call ECR_TRACE("  ERROR INICRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #
  [F:CON]=[M:CON0]
  [F:CON]=[M:CON1]
  [F:CON]=[M:CON4]
  [F:CON]=[M:CON8]
  [F:CON]=[M:CONG]
  [F:CON]=[M:CON2]
  [F:CON]=[M:CON5]
  [F:CON]CREUSR = GUSER
  [F:CON]CREDAT = date$
  #
  If ITRACE > 1 Then
    Call ECR_TRACE("Write [F:CON]  -  CONNUM="+[F:CON]CONNUM,0) From GESECRAN
  Endif
  #
  Write [F:CON]
  If fstat Then
    #Erreur lors de l'écriture du contrat de service +" CONNUM="+[F:CON]CONNUM
    Call ECR_TRACE(mess(435,177,1)+" CONNUM="+[F:CON]CONNUM,1) From GESECRAN
    LERRCOD = 9
    GOK = 0
    Call FSTA("CON") From GLOCK
    Gosub ONERROR
    End
  Endif
  #
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=CREATION",0) From GESECRAN
  Endif
  #
  ACTION = "CREATION" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR CREATION",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
  #
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=APRES_CRE",0) From GESECRAN
  Endif
  #
  ACTION = "APRES_CRE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR APRES_CRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE Then
    Call ECR_TRACE("[M:CON0]CONNUM="+[M:CON0]CONNUM+"  GOK=" + num$(GOK),0) From GESECRAN
  Endif
  If GOK <= 0 Then
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #
  SZCONNUM = [M:CON0]CONNUM
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  #
  ACTION = "FERME" : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  #
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  Kill GSZCRECONTRT 
  Kill GICRECONTRACE
  #
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
End

##############################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If evalue ("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1 Then
    SZVALBEFORE = num$(evalue ("[M]"+IMPZON))
  Endif
  If GICRECONTRACE > 1 Then
    Call ECR_TRACE("ACTION = " + ACTION - "IMPZON=" + IMPZON - "XOK=" + num$(XOK),0) From GESECRAN
    If IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE 
      Call ECR_TRACE("    " - mess(369,177,1) - ":" - SZVALBEFORE,0) From GESECRAN 
    Endif
  Endif
  Case ACTION 
    When "IMP_ZONE" : Gosub SET_HEA_INFO From=GSZCRECONTRT
    When "IMP_TAB"  : Gosub SET_DET_INFO From=GSZCRECONTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER =num$(evalue ("[M]"+IMPZON))
    If SZVALAFTER<>SZVALBEFORE 
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  #
  If GICRECONTRACE > 1 Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    " - mess(370,177,1) - ":" - SZVALAFTER,0) From GESECRAN 
    Endif
  Endif
Return

##############################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      Rollback
    Endif
  Endif
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  Kill GSZCRECONTRT 
  Kill GICRECONTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
Return

#############################################################################################
# Sous-programme de suppression d'un contrat de service.
#############################################################################################
Subprog DELCON(SZCONNUM, IERRCOD)
Variable Char    SZCONNUM
Variable Integer IERRCOD

Local Integer IBDEBTRANSFLG   # FGR 28/04/2011 : X3SUIVI73484

  If adxlog = 1 Then          # FGR 28/04/2011 : X3SUIVI73484
    IBDEBTRANSFLG = 1         # FGR 28/04/2011 : X3SUIVI73484
  Else                        # FGR 28/04/2011 : X3SUIVI73484
    IBDEBTRANSFLG = 0         # FGR 28/04/2011 : X3SUIVI73484
  Endif                       # FGR 28/04/2011 : X3SUIVI73484
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:CQL]) : Local File CONTQUAL [CQL] : Endif
  If !clalev([F:CAM]) : Local File CONTAMT [CAM] : Endif
  If !clalev([F:CRE]) : Local File CONTREW [CRE] : Endif
  If !clalev([F:CCA]) : Local File CONTCARE [CCA] : Endif
  If !clalev([F:CCV]) : Local File CONTCOV [CCV] : Endif
  LERRCOD = 0
  If IBDEBTRANSFLG = 0 Then   # FGR 28/04/2011 : X3SUIVI73484
    Call DEBTRANS From GLOCK
    Trbegin [CON], [CQL], [CAM], [CRE], [CCA], [CCV]
  Endif
  Filter [CON] Where [F:CON]CONNUM = SZCONNUM
  For [CON]
    #Suppression de la couverture article et compétences
    Delete [CCV] Where [F:CCV]CONNUM = [F:CON]CONNUM and [F:CCV]TPL <> 2
    If fstat Then
      #Rollback               # FGR 28/04/2011 : X3SUIVI73484
      GERR = 1
      GMESSAGE = mess(455,196,1) #La suppression des contrats de service associés a échouée. Suppression interrompue.
      #MAE, bg70563
      #End
      Break
    Endif
    #Suppression des contraintes qualités
    Delete [CQL] Where [F:CQL]CONNUM = [F:CON]CONNUM and [F:CQL]TPL <> 2
    If fstat Then
      #Rollback               # FGR 28/04/2011 : X3SUIVI73484
      GERR = 1
      GMESSAGE = mess(455,196,1) #La suppression des contrats de service associés a échouée. Suppression interrompue.
      #MAE, bg70563
      #End
      Break
    Endif
    #Suppression du plan d'entretien
    Delete [CCA] Where [F:CCA]CONNUM = [F:CON]CONNUM and [F:CCA]TPL <> 2
    If fstat Then
      #Rollback               # FGR 28/04/2011 : X3SUIVI73484
      GERR = 1
      GMESSAGE = mess(455,196,1) #La suppression des contrats de service associés a échouée. Suppression interrompue.
      #MAE, bg70563
      #End
      Break
    Endif
    #Suppression de l'historique des bases annuelles
    Delete [CAM] Where [F:CAM]CONNUM = [F:CON]CONNUM
    If fstat Then
      #Rollback               # FGR 28/04/2011 : X3SUIVI73484
      GERR = 1
      GMESSAGE = mess(455,196,1) #La suppression des contrats de service associés a échouée. Suppression interrompue.
      #MAE, bg70563
      #End
      Break
    Endif
    #Suppression de l'historique des renouvellements
    Delete [CRE] Where [F:CRE]CONNUM = [F:CON]CONNUM
    If fstat Then
      #Rollback               # FGR 28/04/2011 : X3SUIVI73484
      GERR = 1
      GMESSAGE = mess(455,196,1) #La suppression des contrats de service associés a échouée. Suppression interrompue.
      #MAE, bg70563
      #End
      Break
    Endif
  Next
  Filter [CON]
  #MAE, bg70563
  If GERR Then
    If IBDEBTRANSFLG = 0 Then # FGR 28/04/2011 : X3SUIVI73484
      Rollback
    Endif
    End
  Endif
  Delete [CON] Where [F:CON]CONNUM = SZCONNUM
  If fstat Then
    If IBDEBTRANSFLG = 0 Then # FGR 28/04/2011 : X3SUIVI73484
      Rollback
    Endif
    GERR = 1
    GMESSAGE = mess(455,196,1) #La suppression des contrats de service associés a échouée. Suppression interrompue.
    End
  Endif
  If IBDEBTRANSFLG = 0 Then   # FGR 28/04/2011 : X3SUIVI73484
    Commit
  Endif
End

##########################################################
# Sous-programme de duplication d'un contrat de service.
##########################################################
Subprog DUPLICON(SZCONNUM, SZDUPCON, IERRINF)
Variable Char SZCONNUM
Variable Char SZDUPCON
Variable Integer IERRINF

Local Integer IERR
Local Char SZCOUNTER
Local Integer IBDEBTRANSFLG   # FGR 28/04/2011 : X3SUIVI73484

  If adxlog = 1 Then          # FGR 28/04/2011 : X3SUIVI73484
    IBDEBTRANSFLG = 1         # FGR 28/04/2011 : X3SUIVI73484
  Else                        # FGR 28/04/2011 : X3SUIVI73484
    IBDEBTRANSFLG = 0         # FGR 28/04/2011 : X3SUIVI73484
  Endif                       # FGR 28/04/2011 : X3SUIVI73484
  IERRINF = 0
  SZCOUNTER = ""
  IERR = 0
  ITRCTL = 0
  SZDUPCON = ""
  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  #Duplication du contrat de service
  Local File CONTSERV [COND]
  Local File CONTSERV [CONE]
  Local File CONTCOV [CCVD]   # FGR 28/04/2011 : X3SUIVI73484
  Local File CONTCOV [CCVE]   # FGR 28/04/2011 : X3SUIVI73484
  Local File CONTQUAL [CQLD]  # FGR 28/04/2011 : X3SUIVI73484
  Local File CONTQUAL [CQLE]  # FGR 28/04/2011 : X3SUIVI73484
  Local File CONTCARE [CCAD]  # FGR 28/04/2011 : X3SUIVI73484
  Local File CONTCARE [CCAE]  # FGR 28/04/2011 : X3SUIVI73484
  #Trbegin [COND]             # FGR 28/04/2011 : X3SUIVI73484
  Raz [F:COND]
  Read [CONE]CON0=SZCONNUM
  If fstat Then
    #Erreur lors de la lecture du contrat de service à dupliquer.
    IERRINF = 395
    End
  Endif
  [F:COND] = [F:CONE]
  ##############################################
  # Calcul d'une nouvelle clé primaire
  ##############################################
  Read [TCA]TCA0=12
  If fstat Then
    #Aucun compteur n'a pu être identifié pour la création du contrat de service.
    IERRINF = 401
    End
  Endif
  #
  If IBDEBTRANSFLG = 0 Then   # FGR 28/04/2011 : X3SUIVI73484
    Trbegin [COND]
  Endif
  SZCOUNTER = [F:TCA]CODNUM(0)
  Call NUMERO(SZCOUNTER, [F:COND]SALFCY, date$, "", SZDUPCON, IERR) From SUBANM
  If IERR Then
    #Erreur lors du calcul du numéro de chrono du contrat de service.
    IERRINF = 396
    If IBDEBTRANSFLG = 0 Then # FGR 28/04/2011 : X3SUIVI73484
      Rollback
    Endif
    End
  Endif
  [F:COND]CONNUM = SZDUPCON
  [F:COND]CONORI = 6
  [F:COND]CONORIVCR = SZCONNUM
  [F:COND]CONORIVCRL = 0
  Write [COND]
  If fstat Then
    If IBDEBTRANSFLG = 0 Then # FGR 28/04/2011 : X3SUIVI73484
      Rollback
    Endif
    #Erreur en duplication de contrat de service.
    IERRINF = 397
    End
  Endif
  #
  #Duplication de la couverture du contrat
  Filter [CCVE] Where [F:CCVE]CONNUM = SZCONNUM and [F:CCVE]TPL <> 2
  For [CCVE]
    Raz [F:CCVD]
    [F:CCVD] = [F:CCVE]
    [F:CCVD]CONNUM = SZDUPCON
    Write [CCVD]
    If fstat Then
      #Erreur en duplication de la couverture des articles et des compétences du contrat de service.
      IERRINF = 398
      Break
    Endif
    ITRCTL += 1
  Next
  Filter [CCVE]
  If IERRINF Then
    If IBDEBTRANSFLG = 0 Then # FGR 28/04/2011 : X3SUIVI73484
      Rollback
    Endif
    End
  Endif
  #
  #Duplication des contraintes qualité
  Filter [CQLE] Where [F:CQLE]CONNUM = SZCONNUM and [F:CQLE]TPL <> 2
  For [CQLE]
    Raz [F:CQLD]
    [F:CQLD] = [F:CQLE]
    [F:CQLD]CONNUM = SZDUPCON
    Write [CQLD]
    If fstat Then
      #Erreur en duplication des contraintes qualité du contrat de service.
      IERRINF = 399
      Break
    Endif
    ITRCTL += 1
  Next
  Filter [CQLE]
  If IERRINF Then
    If IBDEBTRANSFLG = 0 Then # FGR 28/04/2011 : X3SUIVI73484
      Rollback
    Endif
    End
  Endif
  #
  #Duplication du plan d'entretien
  Filter [CCAE] Where [F:CCAE]CONNUM = SZCONNUM and [F:CCAE]TPL <> 2
  For [CCAE]
    Raz [F:CCAD]
    [F:CCAD] = [F:CCAE]
    [F:CCAD]CONNUM = SZDUPCON
    Write [CCAD]
    If fstat Then
      #Erreur en duplication du plan d'entretien du contrat de service.
      IERRINF = 400
      Break
    Endif
    ITRCTL += 1
  Next
  Filter [CCAE]
  If IERRINF Then
    If IBDEBTRANSFLG = 0 Then # FGR 28/04/2011 : X3SUIVI73484
      Rollback
    Endif
    End
  Endif
  If IBDEBTRANSFLG = 0 Then   # FGR 28/04/2011 : X3SUIVI73484
    Commit
  Endif
End
