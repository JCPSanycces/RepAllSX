#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTIINDFIXR3 
# ---------------------------------------------------------------------- #
#      mise a jour du champs NUMP dans APATCH suite à la R3
# n etait pas a jour dans certain cas 219 est la bonne valeur et pas 218
# pour la R3 (verif du dernier type P  si pas 218 c'est que c'est bon
# car denrier mnt du R3 est la 219
# 
##########################################################################
Infbox "only update folder by patch"
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour aussi le dossier X3
#If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTIINDFIXR3 (APPLI)  
End



Subprog EXE_UTIINDFIXR3(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)

#-----
Call ECR_TRACE("UTIINDFIXR3: Update APATCH for Folder "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ZZZ]) =0  Local File =LDOSSIER+".APATCH"     [ZZZ] : Endif
If clalev([F:ZZR]) =0  Local File =LDOSSIER+".APATCH"     [ZZR] : Endif

#-----
$MISE_JOUR_APATCH
#-----------------------------#
#   mise a jour table APATCH  #
#-----------------------------#

Filter [ZZZ] Where TYP= "P" 
# 
Read [ZZZ]Last 
If fstat = 0
      If [F:ZZZ]FICRELABR = "R090" and [F:ZZZ]PATNUM  = 3 and [F:ZZZ]NUMP = 218 and [F:ZZZ]RELEASE = "R090.003"
             Trbegin [ZZR]
             Read [ZZR]APT0 = [F:ZZZ]NUM
             If fstat = 0
                 [F:ZZR]NUMP = 219
                 Rewrite [ZZR] 
                 If fstat 
                     Call ERREUR("APATCH",2) From DOSDIC 
                 Else
                    Call ECR_TRACE("Update APATCH record "+num$([F:ZZZ]NUM),0) From GESECRAN
                 Endif 
             Endif
             Commit
    
     Endif 
Endif

Filter [ZZZ]

#----- Fin du traitement -----#
$FIN_UTIINDFIXR3
WMSG ="UTIINDFIXR3: end of Update APATCH"
Call ECR_TRACE(WMSG,0) From GESECRAN

End



