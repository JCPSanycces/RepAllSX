#<AdxTL>@(#)12.0.0.0 $Revision$
Call OBJET("CCL",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBCCLB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "INICRE"     : Gosub INICRE
 When "LIENS"      : Gosub LIENS
 When "SETBOUT"    : Gosub SETBOUT
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "FIN_LISTE"  : Gosub FIN_LISTE
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When Default
Endcase
If PSUBB
 Gosub ACTION From SUBCCLB
Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"A") From GOBJET
Return

$LIENS
If [M]OTHPPU(nolign-1)=2
 [M]ATXT(nolign-1) = mess([M]TXT(nolign-1),2820,1)
Else
 [M]ATXT(nolign-1) = mess([M]TXT(nolign-1),853,1)
Endif
Return

$INICRE
[F:CCL]TYPDES = [F:CCL]TYP
Return

$SEL_LISTE
Local Char    OVALEUR(5)
Local Integer NOL , CHAP
Local Char    CRITERE(100)
Local Char    TEX(10)(0..400) , TEXTE(200)(0..400)
If clalev([F:AST])=0 : Local File APLSTD [AST] : Endif
OVALEUR = VALEUR
CHAP = val(PARAM(1))
NOL = nolign-1
If dim([M]TXT)>0
 VALEUR = num$([M]TXT(NOL))
Endif
CRITERE = "LANCHP="+num$(CHAP)
CRITERE += ' & LAN="'+GLANGUE+'"'
CRITERE += " & LANNUM<>0"
Raz NBTEX
For [AST]CLE Where evalue(CRITERE)
 If NBTEX+1>dim(TEX)-1 : Break : Endif
 NBTEX +=1
 TEX(NBTEX)   = num$([F:AST]LANNUM)
 TEXTE(NBTEX) = num$([F:AST]LANNUM)+"/ "+[F:AST]LANMES
Next AST
TIT = mess(0,CHAP,1)
Return

$VERF_LISTE
If dim([M]TXT)>0 & dim([M]ATXT)>0
 [M]TXT(NOL)  = val(VALEUR)
 [M]ATXT(NOL) = mess(val(VALEUR),CHAP,1)
 Affzo [M]ATXT(NOL)
Endif
Return

$FIN_LISTE
VALEUR = OVALEUR
Return

######################################################################################
Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
Local Char ACTION(10)
ACTION = "AS_TYP" : Gosub ACTION
End

