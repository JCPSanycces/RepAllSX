#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque SAIAUT
$ACTION
Case ACTION
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
Return

$SEL_TABLE
Case TABLE
  When "SELMAT"
  OBJET = "GRH"
  START = "MATRI"
#on filtre sur le type, ici "Salarié"
  CRITERE="FLAG=2"
  ORDRE = "MATRI"
Endcase
Return

