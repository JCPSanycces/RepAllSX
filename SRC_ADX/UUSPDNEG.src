#<AdxTL>@(#)3.0.0.0 $Revision$ DÃĐcomposition des coÃŧts & [F]...CST<0
##
## Bug 81221 GH 24/05/2012
## Correction des montants<0 de dÃĐcomposition de coÃŧt selon le mode de sortie
## de la 1ÃĻre mÃĐthode de valorisation de l'article-site :
##     - AxxxCST(..) dans les tables ITMMVT STOLOTFCY
##     - xxxCST (..) dans la table STOCOST
## avec xxx=MAT,MAC,LAB,SCO + OVExxx
##

Call CALCUL("","","","","",-1)
End

###################################################################

Subprog CALCUL(FCY,ITM,P1,P2,P3,SIMUL)
Value Char FCY(), ITM()
Value Char P1(),P2(), P3() : # Lot et Sous-lot, ou Type No et No ligne de piÃĻce
Value Integer SIMUL        : # 0=Pas simulation, 1= simulation, autre = saisie des Site Article et Flag simulation O/N

If !GACTDECCST
   # Fonction impossible dans le contexte\ SPD : code activite inactif
   Call ERREUR(mess(127,100,1)+"\SPD :"-mess(24,176,1)) From GESECRAN
   End
Endif

If !clalev([F:ITF])  : Local File ITMFACILIT [ITF]  : Endif
If !clalev([F:TCM])  : Local File TABCOSTMET [TCM]  : Endif
# optimisation GETTCM de STKVAL
If !clalev([F:ITM])  : Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITG])  : Local File ITMCATEG   [ITG]  : Endif

Local Mask SAIDECPRI [SDT]
Local Mask STKREGW   [SRW]

Local Integer I, J, K, N
Local Integer ERR, MAJ, LCK, CAS, TMP, TRA
Local Integer JFIN1, JFIN2, JFIN3
Local Decimal AREPARTIR(6)
Local Char    TEXITF(50), TEXLOT(50), TEXSLO(50), TEXFCY(50), TEXITM(50), TIT(80)
Local Char    VALEUR(80), CRITERE(250), CRITITF(100)

JFIN1=GACTMAT
JFIN2=JFIN1+GACTMAC+GACTLAB+1
JFIN3=JFIN2+4

Local Decimal TABMT(JFIN3)

Call LIENS("ACV","ACTIV","SPD","","num$(LIBACT)",VALEUR) From CONTOBJ
Call TEXTE(val(VALEUR),[L]TIT) From OBJDIV
[L]TIT-=" & [F]...CST<0"

If !find([L]SIMUL,0,1)
    # Site
    Call TEXTFIC("ITMFACILIT","STOFCY",2,[L]TEXFCY) From OBJDIV
    VALEUR=[L]FCY
    Call SAICAR(VALEUR,[L]TIT,[L]TEXFCY,"FCY",0,GLONFCY,"",[L]SIMUL) From GESECRAN : # Site
    If [L]SIMUL<>2 : End : Endif
    [L]FCY=VALEUR

    # Article
    Call TEXTFIC("ITMFACILIT","ITMREF",2,[L]TEXITM) From OBJDIV
    VALEUR=[L]ITM
    Call SAICAR(VALEUR,[L]TIT,[L]TEXITM,"ITM",0,GLONITM,"",[L]SIMUL) From GESECRAN : # Site
    If [L]SIMUL<>2 : End : Endif
    [L]ITM=VALEUR

    # Simulation
    VALEUR=""
    Call SAICAR(VALEUR,[L]TIT,mess(25,133,1),"M",9032,10,"",[L]SIMUL) From GESECRAN : # Simulation
    If [L]SIMUL<>2 : End : Endif
    [L]SIMUL=(val(VALEUR)=1)
Endif

If [L]FCY=""
   CRITITF="STOFCY<>''"
Else
   CRITITF="STOFCY='"+[L]FCY+"'"
Endif

If instr(1,[L]ITM,"*") | instr(1,[L]ITM,"?") | instr(1,[L]ITM,"#") | instr(1,[L]ITM,"!")
   CRITITF+=" & pat(ITMREF,'"+[L]ITM+"')"
Elsif [L]ITM<>""
   CRITITF+=" & ITMREF='"+[L]ITM+"'"
Endif

If !GTEMPON
    Call TEMPON([L]TIT) From GESECRAN
    TMP=1
Endif

## textes
Call LIENS("ATY","ATYPE","ITF","","num$(INTITTYP)",VALEUR) From CONTOBJ
Call TEXTE(val(VALEUR),[L]TEXITF) From OBJDIV : # Article-Site
Call TEXTFIC("STOLOTFCY","LOT",2,[L]TEXLOT) From OBJDIV
Call TEXTFIC("STOLOTFCY","SLO",2,[L]TEXSLO) From OBJDIV

If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
[V]GRNDVAL = 10^-[V]GDECPRI

If GTRACE=""
   Call OUVRE_TRACE([L]TIT-string$(SIMUL,"("+mess(25,133,1)+")")) From LECFIC
   TRA=1
Else
   Call ECR_TRACE([L]TIT-string$(SIMUL,"("+mess(25,133,1)+")"),0) From GESECRAN
Endif

For [ITF] Where evalue([L]CRITITF)
  Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,[L]VALEUR,K) From STKVAL
  If !K & [F:TCM]VLTCOD=[L]VALEUR
     Case [F:TCM]ISSVLTCOD
         When 5 : CAS=5 : Gosub FIFO
         When 6 : CAS=6 : Gosub LOT
         When 4 : CAS=4 : Gosub PMP
     Endcase
  Endif
Next

If TMP
   Call TEMPOFF From GESECRAN
Endif

If TRA
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

End

###################################################################

$PMP
If !clalev([F:ITV])  : Local File ITMMVT     [ITV]  : Endif
# optimisation $SAVDETITV de STKVALREG
If !clalev([F:ITV1]) : Local File ITMMVT     [ITV1] : Endif

LCK=0
Readlock [ITV]ITV0 = [F:ITF]ITMREF;[F:ITF]STOFCY
If fstat=1
   Gosub ITF_TRACE
   GOK=1 : Call FSTA("ITV") From GLOCK
   Return
Elsif fstat
   Return
Endif
LCK=1 : MAJ=0

Raz [M:SDT]
Call LOADSDPX("SDT","[F:ITV]","A",1) From STKVAL

If [F:ITV]AVCBASQTY=0
   Gosub TEST1
   If ERR
        Gosub ITF_TRACE
        Gosub SET_SRW
        If GTRACE<>""
           Call ECR_TRACE("AVCBASQTY = 0",0) From GESECRAN
           If [F:ITV]AVCBASAMT<>0 : Call ECR_TRACE("AVCBASAMT = "+num$([F:ITV]AVCBASAMT),0) From GESECRAN : Endif
        Endif
        Raz [L]TABMT : [L]ERR=0 : Gosub TRACE
        MAJ=1
   Endif
Endif

If !MAJ
    Gosub TEST2
    If ERR
       Gosub REPARTIR
       If !ERR :  MAJ=1 : Endif
    Endif
Endif

If !MAJ : Goto FIN_PMP : Endif

GOK=1
Trbegin [ITV]
  Call UPD_ITMMVT([F:ITF]ITMREF,[F:ITF]STOFCY) From STKVALREG
  If [L]SIMUL : GOK=0 : Endif
If GOK<1 : Rollback
Else     : Commit
Endif

$FIN_PMP
If LCK : Unlock [ITV] : Endif
Return

###################################################################

$LOT
If !clalev([F:SLFW])    : Local File STOLOTFCY [SLFW]   : Endif

CRITERE=""
If [L]P1<>""
   CRITERE+= " & LOT='"+[L]P1+"'"
Endif
If [L]P2<>""
   CRITERE+= " & SLO='"+[L]P2+"'"
Endif
If CRITERE="" : CRITERE = "1=1" : Else CRITERE = right$(CRITERE,4) : Endif

For [SLFW] Where ITMREF=[F:ITF]ITMREF & STOFCY=[F:ITF]STOFCY & evalue([L]CRITERE)
  LCK=0
  Readlock [SLFW] Curr
  If fstat
     Gosub ITF_TRACE
     GOK=1 : Call FSTA("SLFW") From GLOCK
     Goto NEXT_LOT
  Endif
  LCK=1 : MAJ=0

  Raz [M:SDT]
  Call LOADSDPX("SDT","[F:SLFW]","A",1) From STKVAL

  If [F:SLFW]AVCBASQTY=0
      Gosub TEST1
      If ERR
          Gosub ITF_TRACE
          Gosub SET_SRW
          If GTRACE<>""
             Call ECR_TRACE("AVCBASQTY = 0",0) From GESECRAN
             If [F:SLFW]AVCBASAMT<>0 : Call ECR_TRACE("AVCBASAMT = "+num$([F:SLFW]AVCBASAMT),0) From GESECRAN : Endif
          Endif
          Raz [L]TABMT : [L]ERR=0 : Gosub TRACE
          MAJ=1
      Endif
  Endif

  If !MAJ
      Gosub TEST2
      If ERR
         Gosub REPARTIR
         If !ERR :  MAJ=1 : Endif
      Endif
  Endif

  If !MAJ : Goto NEXT_LOT : Endif

  If !clalev([F:SLF])    : Local File STOLOTFCY [SLF]   : Endif
  # optimisation $SAVDETSLF de STKVALREG
  If !clalev([F:SLF1])   : Local File STOLOTFCY [SLF1]  : Endif

  GOK=1
  Trbegin [SLF]
    Call UPD_STOLOTFCY([F:ITF]ITMREF,[F:ITF]STOFCY) From STKVALREG
    If [L]SIMUL : GOK=0 : Endif
  If GOK<1 : Rollback
  Else     : Commit
  Endif

$NEXT_LOT
  If LCK : Unlock [SLFW] : Endif
Next

Return

###################################################################

$FIFO
If !clalev([F:STP])    : Local File STOCOST [STP]    : Endif
If !clalev([F:STP1])   : Local File STOCOST [STP1]   : Endif

CRITERE=""
If [L]P1<>""
   CRITERE+= " & VCRTYP='"+val([L]P1)
Endif
If [L]P2<>""
   CRITERE+= " & VCRNUM='"+[L]P2+"'"
Endif
If [L]P3<>""
   CRITERE+= " & VCRLIN="+val([L]P3)
Endif
If CRITERE="" : CRITERE = "1=1" : Else CRITERE = right$(CRITERE,4) : Endif

For [STP]STP1(5) Where ITMREF=[F:ITF]ITMREF & STOFCY=[F:ITF]STOFCY & evalue([L]CRITERE)
  LCK=0
  Filter [STP1] Where ITMREF=[F:STP]ITMREF & STOFCY=[F:STP]STOFCY & VCRTYP=[F:STP]VCRTYP & VCRNUM=[F:STP]VCRNUM & VCRLIN=[F:STP]VCRLIN
  K=rowcount([F:STP1])
  Filter [STP1]
  If K<>1 : Goto NEXT_FIFO : Endif

  Readlock [STP] Curr
  If fstat
     Gosub ITF_TRACE
     GOK=1 : Call FSTA("STP") From GLOCK
     Goto NEXT_FIFO
  Endif
  LCK=1 : MAJ=0

  Raz [M:SDT]
  Call LOADSDPX("SDT","[F:STP]","",1) From STKVAL

  Gosub TEST2
  If ERR
     Gosub REPARTIR
     If !ERR :  MAJ=1 : Endif
  Endif

  If !MAJ : Goto NEXT_FIFO : Endif

  GOK=1
  Trbegin [STP]
    Call UPD_STOCOST([F:ITF]ITMREF,[F:ITF]STOFCY) From STKVALREG
    If [L]SIMUL : GOK=0 : Endif
  If GOK<1 : Rollback
  Else     : Commit
  Endif

$NEXT_FIFO
  If LCK : Unlock [STP] : Endif
Next

Return

###################################################################

$ITF_TRACE
If GTRACE="" : Return : Endif

Case CAS
  When 6       : GMESSAGE=TEXLOT-[F:SLFW]LOT-TEXSLO-[F:SLFW]SLO
  When 5       : GMESSAGE=mess([F:STP]VCRTYP,701,1)-[F:STP]VCRNUM-num$([F:STP]VCRLIN)
  When Default : GMESSAGE=""
Endcase
Call ECR_TRACE("\"+TEXITF-[F:ITF]ITMREF-[F:ITF]STOFCY-GMESSAGE,-1) From GESECRAN : # Article-site
GMESSAGE=""
Return

###################################################################

$TEST1
ERR=0
If sigma(0,dim([M:SDT]MATCST)-1,[M:SDT]MATCST(indcum)<>0) |
&  sigma(0,dim([M:SDT]MACCST)-1,[M:SDT]MACCST(indcum)<>0) |
&  sigma(0,dim([M:SDT]LABCST)-1,[M:SDT]LABCST(indcum)<>0) |
&  [M:SDT]SCOCST<>0 |
&  [M:SDT]OVEMATCST<>0 | [M:SDT]OVEMACCST<>0 | [M:SDT]OVELABCST<>0 | [M:SDT]OVESCOCST<>0
   ERR=2
Endif
Return

###################################################################

$TEST2
# couts matiere, machine, main d'oeuvre, sous-traitance
AREPARTIR(0) =-sigma(0,GACTMAT-1,[M:SDT]MATCST(indcum)*([M:SDT]MATCST(indcum)<0))
AREPARTIR(1) =-sigma(0,GACTMAC-1,[M:SDT]MACCST(indcum)*([M:SDT]MACCST(indcum)<0))
AREPARTIR(2) =-sigma(0,GACTLAB-1,[M:SDT]LABCST(indcum)*([M:SDT]LABCST(indcum)<0))
AREPARTIR(3) =-[M:SDT]SCOCST*([M:SDT]SCOCST<0)
# frais generaux matiere, non matiere (machine + main d'oeuvre + sous-traitance)
AREPARTIR(4) =-[M:SDT]OVEMATCST*([M:SDT]OVEMATCST<0)
AREPARTIR(5) =-[M:SDT]OVEMACCST*([M:SDT]OVEMACCST<0)
AREPARTIR(5)+=-[M:SDT]OVELABCST*([M:SDT]OVELABCST<0)
AREPARTIR(5)+=-[M:SDT]OVESCOCST*([M:SDT]OVESCOCST<0)

ERR = (sum([L]AREPARTIR)<>0)
Return

###################################################################

$SET_SRW
Raz [M:SRW] : [M:SRW]NBLIG=1
Case CAS
  When 6 : # lot
    [M:SRW]LOT(0) = [F:SLFW]LOT
    [M:SRW]SLO(0) = [F:SLFW]SLO
    [M:SRW]QTYSTOLOT(0) = [F:SLFW]AVCBASQTY
  When 5 : # FIFO
    [M:SRW]VCRTYP(0) = [F:STP]VCRTYP
    [M:SRW]VCRNUM(0) = [F:STP]VCRNUM
    [M:SRW]VCRLIN(0) = [F:STP]VCRLIN
Endcase
Return

###################################################################

$REPARTIR
Gosub ITF_TRACE

N = 0
For I=0 To GACTMAT-1
  TABMT(N) = [M:SDT]MATCST(I) : N+=1
Next
For I=0 To GACTMAC-1
  TABMT(N) = [M:SDT]MACCST(I) : N+=1
Next
For I=0 To GACTLAB-1
  TABMT(N) = [M:SDT]LABCST(I) : N+=1
Next
TABMT(N) = [M:SDT]SCOCST      : N+=1
TABMT(N) = [M:SDT]OVEMATCST   : N+=1
TABMT(N) = [M:SDT]OVEMACCST   : N+=1
TABMT(N) = [M:SDT]OVELABCST   : N+=1
TABMT(N) = [M:SDT]OVESCOCST   : N+=1

ERR=0
For I=0 To dim([L]AREPARTIR)-1
  If AREPARTIR(I)<>0
     If I=0    : # couts matiere
        Gosub REPCSTMAT
        Gosub REPCSTDIV
        Gosub REPFG
     Elsif I<4 : # couts non matiere (machine, main d'oeuvre, sous-traitance)
        # CSTDIV, CSTMAT, FG
        Gosub REPCSTDIV
        Gosub REPCSTMAT
        Gosub REPFG
     Elsif I=4 : # frais generaux matiere
        Gosub REPFG
        Gosub REPCSTMAT
        Gosub REPCSTDIV
     Else      : # frais generaux non matiere (machine, main d'oeuvre, sous-traitance)
        Gosub REPFG
        Gosub REPCSTDIV
        Gosub REPCSTMAT
     Endif
     If AREPARTIR(I)<[V]GRNDVAL : AREPARTIR(I)=0 : Endif
     If AREPARTIR(I)<>0 : ERR=1 : Break : Endif
  Endif
Next I

If !ERR
  For I=0 To N-1
    If TABMT(I)<0 : TABMT(I)=0 : Endif
  Next
  Gosub SET_SRW
Elsif GTRACE<>""
  Call ECR_TRACE(mess(24,196,1),1) From GESECRAN : # Correction non effectuÃĐe
Endif

If (ERR & GTRACE<>"") | !ERR
   Gosub TRACE
Endif
Return

###################################################################

$TRACE
N=0
For I=0 To GACTMAT-1
  If !ERR & [M:SDT]MATCST(I)<>TABMT(N)
     If GTRACE<>"" : Call ECR_TRACE("MATCST("+num$(I)+") = "+num$([M:SDT]MATCST(I))+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
     [M:SRW]MATCST(I) = TABMT(N)-[M:SDT]MATCST(I)
     [M:SDT]MATCST(I) = TABMT(N)
  Elsif GTRACE<>"" & ERR & [M:SDT]MATCST(I)<0
     Call ECR_TRACE("MATCST("+num$(I)+") = "+num$([M:SDT]MATCST(I)),0) From GESECRAN
  Endif
  N+=1
Next

For I=0 To GACTMAC-1
  If !ERR & [M:SDT]MACCST(I)<>TABMT(N)
     If GTRACE<>"" : Call ECR_TRACE("MACCST("+num$(I)+") = "+num$([M:SDT]MACCST(I))+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
     [M:SRW]MACCST(I) = TABMT(N)-[M:SDT]MACCST(I)
     [M:SDT]MACCST(I) = TABMT(N)
  Elsif GTRACE<>"" & ERR & [M:SDT]MACCST(I)<0
     Call ECR_TRACE("MACCST("+num$(I)+") = "+num$([M:SDT]MACCST(I)),0) From GESECRAN
  Endif
  N+=1
Next

For I=0 To GACTLAB-1
  If !ERR & [M:SDT]LABCST(I)<>TABMT(N)
     If GTRACE<>"" : Call ECR_TRACE("LABCST("+num$(I)+") = "+num$([M:SDT]LABCST(I))+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
     [M:SRW]LABCST(I) = TABMT(N)-[M:SDT]LABCST(I)
     [M:SDT]LABCST(I) = TABMT(N)
  Elsif GTRACE<>"" & ERR & [M:SDT]LABCST(I)<0
     Call ECR_TRACE("LABCST("+num$(I)+") = "+num$([M:SDT]LABCST(I)),0) From GESECRAN
  Endif
  N+=1
Next

If !ERR & [M:SDT]SCOCST<>TABMT(N)
   If GTRACE<>"" : Call ECR_TRACE("SCOCST"+" = "+num$([M:SDT]SCOCST)+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
   [M:SRW]SCOCST(0) = TABMT(N)-[M:SDT]SCOCST
   [M:SDT]SCOCST = TABMT(N)
Elsif GTRACE<>"" & ERR & [M:SDT]SCOCST(I)<0
   Call ECR_TRACE("SCOCST = "+num$([M:SDT]SCOCST),0) From GESECRAN
Endif
N+=1

If !ERR & [M:SDT]OVEMATCST<>TABMT(N)
   If GTRACE<>"" : Call ECR_TRACE("OVEMATCST"+" = "+num$([M:SDT]OVEMATCST)+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
   [M:SRW]OVEMATCST(0) = TABMT(N)-[M:SDT]OVEMATCST
   [M:SDT]OVEMATCST = TABMT(N)
Elsif GTRACE<>"" & ERR & [M:SDT]OVEMATCST<0
   Call ECR_TRACE("OVEMATCST = "+num$([M:SDT]OVEMATCST),0) From GESECRAN
Endif
N+=1

If !ERR & [M:SDT]OVEMACCST<>TABMT(N)
   If GTRACE<>"" : Call ECR_TRACE("OVEMACCST"+" = "+num$([M:SDT]OVEMACCST)+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
   [M:SRW]OVEMACCST(0) = TABMT(N)-[M:SDT]OVEMACCST
   [M:SDT]OVEMACCST = TABMT(N)
Elsif GTRACE<>"" & ERR & [M:SDT]OVEMACCST<0
   Call ECR_TRACE("OVEMACCST = "+num$([M:SDT]OVEMACCST),0) From GESECRAN
Endif
N+=1

If !ERR & [M:SDT]OVELABCST<>TABMT(N)
   If GTRACE<>"" : Call ECR_TRACE("OVELABCST"+" = "+num$([M:SDT]OVELABCST)+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
   [M:SRW]OVELABCST(0) = TABMT(N)-[M:SDT]OVELABCST
   [M:SDT]OVELABCST = TABMT(N)
Elsif GTRACE<>"" & ERR & [M:SDT]OVELABCST<0
   Call ECR_TRACE("OVELABCST = "+num$([M:SDT]OVELABCST),0) From GESECRAN
Endif
N+=1

If !ERR & [M:SDT]OVESCOCST<>TABMT(N)
   If GTRACE<>"" : Call ECR_TRACE("OVESCOCST"+" = "+num$([M:SDT]OVESCOCST)+" -> "+num$(TABMT(N)),0) From GESECRAN : Endif
   [M:SRW]OVESCOCST(0) = TABMT(N)-[M:SDT]OVESCOCST
   [M:SDT]OVESCOCST = TABMT(N)
Elsif GTRACE<>"" & ERR & [M:SDT]OVESCOCST<0
   Call ECR_TRACE("OVESCOCST = "+num$([M:SDT]OVESCOCST),0) From GESECRAN
Endif
N+=1
Return

###################################################################
# rÃĐpartition sur les couts matiÃĻre MATCST(0..GACTMAT-1) en montant
$REPCSTMAT
If AREPARTIR(I)<[V]GRNDVAL : Return : Endif

Call REPMONT(AREPARTIR(I),TABMT,0,JFIN1-1)
Return

###################################################################
# rÃĐpartition sur les couts non matiÃĻre MACCST(0..GACTMAC-1), LABCST(0..GACTMAC-1) et SCOCST
$REPCSTDIV
If AREPARTIR(I)<[V]GRNDVAL : Return : Endif

Call REPMONT(AREPARTIR(I),TABMT,JFIN1,JFIN2-1)
Return

###################################################################
# rÃĐpartition sur les frais gÃĐnÃĐraux OVE...CST
$REPFG
If AREPARTIR(I)<[V]GRNDVAL : Return : Endif

Call REPMONT(AREPARTIR(I),TABMT,JFIN2,JFIN3-1)
Return

###################################################################
Subprog REPMONT(AREPARTIR,TABMT,JDEB,JFIN)
Variable Decimal AREPARTIR, TABMT()
Value Integer JDEB, JFIN

Local Integer J
Local Decimal TOT, MT

For J=JDEB To JFIN
  If TABMT(J)>0
     TOT = sigma(J,JFIN,TABMT(indcum)*(TABMT(indcum)>0))
     If TOT=0 : Break : Endif

     MT = arr(min(TABMT(J),TABMT(J)*AREPARTIR/TOT),[V]GRNDVAL)
     If MT<>0
         TABMT(J)-= MT
         AREPARTIR -= MT
         If AREPARTIR<[V]GRNDVAL : AREPARTIR=0 : Endif
         If AREPARTIR=0 : Break : Endif
     Endif
  Endif
Next J
End
