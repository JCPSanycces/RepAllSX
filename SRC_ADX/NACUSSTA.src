#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
# Program Name: NACUSSTA Customer statement
####################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End
####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE


For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "datmax"
    DATMAX = [L]VALEUR
   When "sitedeb"
    SITEDEB = [L]VALEUR
   When "sitefin"
    SITEFIN = [L]VALEUR
   When "bpdeb"
    BPDEB = [L]VALEUR
   When "bpfin"
    BPFIN = [L]VALEUR
   # 100524.sn
   When "txncur"
    TXNCUR = [L]VALEUR
   When "rptcur"
    RPTCUR = [L]VALEUR
   # 100524.en
   When "numedt"
    [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
 Endcase
 Endif
Next

Lock [ARM]
   Delete[ARM] Where [ARM]NUMREQ=[L]NUMREQ | CREDAT<date$-7 | ([ARM]CREUSR=GUSER & [ARM]RPTCOD = "NA-CUSSTA")
Unlock [ARM]

# Write the ARM Records
Gosub ARM_LOOP

End
####################################################################################
$OUVRE

If !clalev([F:ARM])  : Local File AREPORTM    [ARM]  : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT  [GTE]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL    [JOU]  : Endif
If !clalev([F:SIH])  : Local File SINVOICE    [SIH]  : Endif
If !clalev([F:PYH])  : Local File PAYMENTH    [PYH]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY   [HAE]  : Endif
If !clalev([F:CPY])  : Local File COMPANY     [CPY]  : Endif

# Local File NACUSSTA [CUS] ####

Local Char    LTYP(3)

Return
####################################################################################
$DECLARE

Local Char    PARAM(30),VALEUR(30),ETAT(15),USR(15),XNUM(35)
Local Date    DTEDEB,DTEFIN,XDAT
Local Integer NUMREQ,WNUMLIG,PERDEB,PERFIN,XRET


Return
####################################################################################
$ARM_LOOP



#{GACCDUDATE.BPRTYP_0} = 1 and ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
#{GACCDUDATE.AMTLOC_0}>{GACCDUDATE.PAYLOC_0} and ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
#{GACCDUDATE.BPRPAY_0} IN {?BPDEB} To {?BPFIN} and ^^^^^^^^^^^^^^^^^^^^^^^^^^^
#{GACCDUDATE.DUDSTA_0} = 2 and  ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
#{@INVDATE} <= {?DATMAX} and
#{GACCDUDATE.FCY_0} IN {?SITEDEB} To {?SITEFIN} and ^^^^^^^^^^^^^^^^^^^^^^^^^^^
#{GTYPACCENT.TYP_0} <> "2" ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^


Filter [DUD] Where [DUD]DUDSTA=2 & [DUD]FCY >= SITEDEB and [DUD]FCY <= SITEFIN and [DUD]BPR >= BPDEB and
& [DUD]BPR <= BPFIN and [DUD]BPRTYP = 1 and [DUD]AMTLOC > [DUD]PAYLOC Order By Key DUD0

Filter [CPY] Where [CPY]CPY=[DUD]CPY
Filter [GTE] Where [GTE]TYP <> 2

Link [DUD] With [CPY]CPY0=[DUD]CPY As [LNK]

For [LNK]
  ## If XNUM = [DUD]NUM : Goto SKIP : Endif
  Gosub DATCHECK
  If XDAT <= num$(DATMAX)
    #Filter [GTE] Where [GTE]TYP=[DUD]TYP & [GTE]LEG=[CPY]LEG # 95285.o
    Filter [GTE] Where [GTE]TYP=[DUD]TYP & [GTE]LEG=[CPY]LEG and [GTE]PER=1  # 95285.n
    Read [GTE] First
      If fstat
        fstat=0
        #Filter [GTE] Where [GTE]TYP=[DUD]TYP  # 95285.o
        Filter [GTE] Where [GTE]TYP=[DUD]TYP and [GTE]PER=1  # 95285.n
        Read [GTE] First
      Endif
    If !fstat
    # 95285.so
    #  Filter [JOU] Where [JOU]JOU=[GTE]DEFJOU # 95285.so Skip carry over journals  LEC_JOU_LEG from CPTLEC instead ?
    #  Read [JOU] First
    #    If (!fstat & [JOU]TYP<>7) | fstat
          Gosub WRITE_RECORD
    #    Endif
    #  Filter [JOU]  # 95285.eo
    Endif
$SKIP
XNUM = [DUD]NUM
  Endif # XDAT
Next


Filter [DUD]
Filter [GTE]
Filter [SIH]


Return
####################################################################################
$WRITE_RECORD


Readlock [ARM]ARM0=[L]NUMREQ;GUSER;[L]ETAT;[L]WNUMLIG

If fstat # New record

GOK = 1
Trbegin [ARM]
  Raz [F:ARM]
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1 =  [DUD]NUM
  [F:ARM]CLEN1 =  [JOU]TYP
  [F:ARM]CLEA10 = [DUD]BPR
  [F:ARM]CLEA11 = [DUD]CPY
  [F:ARM]CLEMD2 = [DUD]AMTCUR * [DUD]SNS
  [F:ARM]CLEA2  = [DUD]TYP
  # 100524.sn
  If [L]TXNCUR = "1" Then
    [F:ARM]CLEA3  = [DUD]CUR # Transaction currency
  Else
    [F:ARM]CLEA3  = [CPY]ACCCUR # Reporting (company) currency
  Endif
  # 100524.en
  [F:ARM]CLEN2  = [DUD]LIG
  [F:ARM]CLEN3  = [DUD]DUDLIG
  [F:ARM]CLED1 =  XDAT
  [F:ARM]CREDAT  = date$
  WNUMLIG += 1
  Write [ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Rollback : Endif

If fstat
  Rollback
Else
  Commit
Endif

Endif

Filter [ARM]
Return
#########################################################################################################
$DATCHECK

Raz XDAT
Raz [SIH], [HAE]

XDAT = [0/0/0]
Filter [SIH] Where [SIH]NUM = [DUD]NUM
Read [SIH] First
Raz fstat

Filter [HAE] Where [HAE]NUM = [DUD]NUM
Read [HAE] First
If !fstat
  Filter [PYH] Where [PYH]NUM = [HAE]BPRVCR
  Read [PYH] First
Endif

If [DUD]TYPDUD = 2 and dim([SIH]ACCDAT) > 0 and [SIH]ACCDAT > [1/1/1900]
  XDAT = [SIH]ACCDAT
Elsif [DUD]TYPDUD = 3 and dim([PYH]ACCDAT) > 0
  XDAT = [PYH]ACCDAT
Else
  XDAT = [DUD]DUDDAT
Endif

Return
