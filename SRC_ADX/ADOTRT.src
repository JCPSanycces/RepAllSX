#<AdxTL>@(#)0.0.0.0 $Revision$ Editeur traitement
Local Char VALEUR(GLONADC)
Local Char PARAM(GLONADC)(1..2)
Call S_AFF_CHAR(VALEUR,PARAM,"","ADOTRT","") From GACTION
End

$ACTION
Case ACTION
 When "TRT_DIV" : Gosub TRT_DIV
Endcase
Return

$TRT_DIV
Local Integer STAT
Local Char    TRTADO(GLONADC) , PARADO(GLONADC)(1..2)
STAT = adxmpr
Onerrgo RIEN
adxmpr = STAT
Onerrgo
If GBROWS
 TRTADO = PARAM(1)
 PARADO(1) = nomap(0)
 PARADO(2) = "1"
 Call TRAITE_CHAR(TRTADO,PARADO,"EDITRTWEB","EDITRTWEB","",6,"") From GTRAITE
Elsif PARAM(1)<>"" & filinfo(filpath("TRT",PARAM(1),"src",0),0)>=0
 Pmt =PARAM(1)
Else
 Pmt
Endif
Return

$RIEN
Resume
