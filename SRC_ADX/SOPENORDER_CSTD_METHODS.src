#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SOPENORDER
#######################################################################################
End

#######################################################################################
$AREAD_AFTER
Local Integer IRET

  IRET = fmet this.INIT_TSCCODADI()

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.CPYCUR = [F:CPY]ACCCUR
  Endif

  # -----------------------------------
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACBPR, DEP, PTE, SOHTYP, SDHTYP
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SOHTYP_LEG(this, this.SOHTYP, this.CPY, this.SALFCY, this.LEG, this.SOHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SDHTYP_LEG(this, this.SDHTYP, this.CPY, this.SALFCY, this.LEG, this.SDHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEP, this.CPY, this.SALFCY, this.LEG, this.DEP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PTE_LEG(this, this.PTE, this.CPY, this.SALFCY, this.LEG, this.PTE_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPR, this.CPY, this.SALFCY, this.LEG, this.VACBPR_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

#######################################################################################
$AINIT
Local Integer IRET

  IRET = fmet this.INIT_TSCCODADI()
Return

#######################################################################################
$INIT_TSCCODADI
Local Integer DIM_STC
Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STC")
  # -------------------
  For NI = 1 To DIM_STC
    this.C_TSCCOD(NI).TSCCODADI = NI + 30
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_AFTER_SVV
Local Integer IRET

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  #--everything that concern SIH.C_TAX must be done at SIH.C_TAX level for CURPTH="SIH.C_TAX"
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT, this.VAT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG, this.VAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_AFTER_SVF
Local Integer IRET

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT, this.SUMDTAVAT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG, this.SUMDTAVAT_LE)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_AFTER_SVF_C_DTAVAT
Local Integer IRET

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  #--everything that concern SIH.C_TAX must be done at SIH.C_TAX level for CURPTH="SIH.C_TAX"
  If this.APARENT.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT.APARENT, this.APARENT.APARENT.CPY, this.APARENT.APARENT.SALFCY, this.APARENT.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT.APARENT, this.DTAVAT, this.APARENT.APARENT.CPY, this.APARENT.APARENT.SALFCY, this.APARENT.APARENT.LEG, this.DTAVAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

