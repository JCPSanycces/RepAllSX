#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTSTO01   Moulinette de Migration  des STOJOU       Module Stocks #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   #--- Issue 108760 By TS
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
   If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
   #---
   #Call ACTIVE      From TIMING
   If !GSERVEUR
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("UUMGTRTSTO01") From LECFIC
   Endif
   #Call RAZ_UUMGTRTSTO01(DOSSIER)
   Call MAJ_UUMGTRTSTO01(DOSSIER)
   If !GSERVEUR
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE   From LECFIC
   Endif
   #Call ARRET       From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTSTO01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(6)<>2 : : # N= no module
   End
Endif

Local Char WNAMSTJM
Call MIGTABNAME (DOSSIER,"STOJOU",WNAMSTJM,ERR) From TRTMIG

If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSTJM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

##2 - On vide les fichiers selon le cas
#######################################

Call MIGTABRAZ (DOSSIER,"STOJOU",ERR) From TRTMIG


##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTSTO01",ERR) From TRTMIG

End




Subprog MAJ_UUMGTRTSTO01(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 by TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---
Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(6)<>2 : : # N= no module
   Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSTO01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
Local Char WNAMSTJM
Call MIGTABNAME (DOSSIER,"STOJOU",WNAMSTJM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSTO01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSTJM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSTO01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSTO01",2,ERR) From TRTMIG : #2=En cours

###################


Call ECR_TIME ("UUMGTRTSTO01 : tables STJ Process : Update STOJOU") From DOSSUB
Call ECR_TRACE("UUMGTRTSTO01 : Process Start on : "+DOSSIER,0)   From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"STOJOU",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:STJ])  = 0 : Local File =DOSSIER+".STOJOU"      [STJ]  : Endif   # Fichier X3 "Vide"

If clalev([F:STJM]) = 0 : Local File =DOSSIER+"."+WNAMSTJM   [STJM] : Endif   # Fichier X3 renommé Avant Migration
#-----  Déclaration des variables -----#
Gosub OUVRE_STO01

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char    CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char    TABMIGKEY(30)(1..NBMIGKEY)
Raz STOP, CRITERE, NBCOMMIT, NBLUS
# Déclaration des variables communes de travail
Local Char    WSTOFCY
Raz WSTOFCY
Local Integer WI

# pour les WriteB des tables détails
Local Char WTAB_STJ (100) (adxwrb)
Local Shortint WCPT_STJ

Filter [STJM] Order By Key CLE=[F:STJM]STOFCY;[F:STJM]ITMREF;[F:STJM]IPTDAT

###################################################
#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTSTO01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTSTO01" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_STJ00
Raz NB
If STOP = 1
   CRITERE = "[F:STJM]STOFCY=TABMIGKEY(1) & [F:STJM]ITMREF=TABMIGKEY(2) & [F:STJM]IPTDAT> ["+TABMIGKEY(3)+"] "
   STOP = 2
Elsif STOP=2
   CRITERE = "[F:STJM]STOFCY=TABMIGKEY(1) & [F:STJM]ITMREF>TABMIGKEY(2) "
   STOP = 3
Elsif STOP=3
   CRITERE = "[F:STJM]STOFCY>TABMIGKEY(1)"
   STOP = 0
Else
   CRITERE = "1=1"
Endif
Trbegin [STJ]
GOK = 1
For [STJM]CLE(3) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

  For [STJM]CLE
    NBLUS+=1

    # PE pour exclure ligne
    If FILTRELIN
        FLUX="UUMGTRTSTO01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
        # Issue 80147 - 2012-02-16 by VPO : erreur suite prise en compte ISVALID
        #If ISVALID=0 : Break : Endif
        If ISVALID=0 : Goto SUITE_BOUCLE1 : Endif
    Endif

    Gosub RAZ_STJ
    [F:STJ] = [F:STJM]

    #APPEL proc de migration STOJOU
    Gosub MAJ30_STJ
    If GOK<1 : Break : Endif

    # --- écriture enreg
    #--- Issue 108760 by TS
    #If NEWMOTEUR
    #   Gosub STJ_STK : # pour stocker ref
    #   WriteB [F:STJ]
    #Else
    #   Write [F:STJ]
    #Endif
    #If fstat
    #   If NEWMOTEUR & adxwrb>1
    #      Call ECR_TRACE("File STOJOU, Error ="-num$(fstat),1) From GESECRAN
    #      Gosub STJ_ERRTRA : # pour afficher les ref
    #   Else
    #      Call ECR_TRACE("File STOJOU"-[F:STJ]STOFCY-num$([F:STJ]UPDCOD)-[F:STJ]ITMREF-format$(GFMD,[F:STJ]IPTDAT)-num$([F:STJ]MVTSEQ)-num$([F:STJ]MVTIND)+", Error ="-num$(fstat),1) From GESECRAN
    #   Endif
    #  GOK=0 : Break
    #Endif
    Gosub STJ_STK : # pour stocker ref
    WriteB [F:STJ]
    If fstat
      Call ECR_TRACE("File STOJOU, Error ="-num$(fstat),1) From GESECRAN
      Gosub STJ_ERRTRA : # pour afficher les ref
      GOK=0 : Break
    Endif
    #---

    NB+=1
$SUITE_BOUCLE1
  Next
  If GOK<1 : Break : Endif
  # Issue 80147 - 2012-02-16 by VPO : erreur suite prise en compte ISVALID
  #If ISVALID=0 : Goto SUITE_BOUCLE : Endif

  If NB>GMAXUPDTRS
     TABMIGKEY(1) = [F:STJM]STOFCY
     TABMIGKEY(2) = [F:STJM]ITMREF
     TABMIGKEY(3) = format$(GFMD,[F:STJM]IPTDAT)
     STOP=1
     Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSTO01",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:STJ]
    If fstat
       Call ECR_TRACE("File STOJOU, Error ="-num$(fstat),1) From GESECRAN
       Gosub STJ_ERRTRA : # pour afficher les ref
       GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #--- Issue 108760 by TS
  #Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
     TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
     Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTSTO01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTSTO01",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_STJ00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [STJ]
Close Local File [STJM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"STOJOU",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTSTO01") From TRTMIG

Call ECR_TIME("UUMGTRTSTO01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

$OUVRE_STO01
Local File =[F:ADS]DOSSIER+".ATYPE" [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]
Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
##ssi compta
If [F:ADS]MODULE(6)<>2
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".GLED"       [LED]
Endif
Return
################################################
$RAZ_STJ
  Raz [F:STJ]AMTDEV2
  Raz [F:STJ]AMTVAL2
  Raz [F:STJ]PRINAT2
  Raz [F:STJ]PRIVAL2
  Raz [F:STJ]VARVAL2
  Raz [F:STJ]BETCPY
  Raz [F:STJ]CCE
  Raz [F:STJ]DIE
  Raz [F:STJ]DLUDAT
  Raz [F:STJ]NEWLTIDAT
  Raz [F:STJ]OWNER
  Raz [F:STJ]WRH
Return

################################################
$MAJ30_STJ
#----- Alimentation champs pour le multi-référenciels comptabilité -----#
If [F:STJ]STOFCY<>WSTOFCY
   Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:STJ]STOFCY) From TRTX3CPT
   WSTOFCY = [F:STJ]STOFCY
Endif
[F:STJ]CCE(0) = [F:STJM]CCE1
[F:STJ]CCE(1) = [F:STJM]CCE2
[F:STJ]CCE(2) = [F:STJM]CCE3
[F:STJ]CCE(3) = [F:STJM]CCE4
[F:STJ]CCE(4) = [F:STJM]CCE5
[F:STJ]CCE(5) = [F:STJM]CCE6
[F:STJ]CCE(6) = [F:STJM]CCE7
[F:STJ]CCE(7) = [F:STJM]CCE8
[F:STJ]CCE(8) = [F:STJM]CCE9
For WI=1 To max(GNBDIE,GOPTCANA)
   [F:STJ]DIE(WI-1)=GDIE(WI)
Next WI
If [F:STJ]VCRTYP=30 & [F:STJ]REGFLG=0
   [F:STJ]REGFLG = 1
Endif
If [F:STJ]OWNER="" & [F:STJ]UPDCOD>1
   [F:STJ]OWNER = [F:STJ]STOFCY
   If [F:STJ]ACTQTY<>0
      [F:STJ]PRIVAL = [F:STJ]AMTVAL / [F:STJ]ACTQTY
      [F:STJ]PRIORD = [F:STJ]AMTORD / [F:STJ]ACTQTY
   Endif
Endif

Return

################################################
$STJ_STK
Call STK (WTAB_STJ,WCPT_STJ,[F:STJ]STOFCY-'/'-num$([F:STJ]UPDCOD)-'/'-[F:STJ]ITMREF-'/'-format$(GFMD,[F:STJ]IPTDAT)-'/'-num$([F:STJ]MVTSEQ)-'/'-num$([F:STJ]MVTIND)) From TRTMIG
Return
##############################################################################################
$STJ_ERRTRA
Call ERRTRA (WTAB_STJ,WCPT_STJ,"File STOJOU(STOFCY/UPDCOD/ITMREF/IPTDAT/MVTSEQ/MVTIND)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTSTO01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSTO01(APPLI)
End

