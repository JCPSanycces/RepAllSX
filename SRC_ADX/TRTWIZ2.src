#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Assistant X3                                                      Module CRM          03 novembre 2000 #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  #PARAM(1) = Code assistant.
  If !clalev([F:ACT]) : Local File ACTION [ACT] : Endif

Global Char GSZWIZCOD(100)
Global Integer GINBSTEP
Global Integer GIFSTEP
Global Integer GILSTEP
Global Integer GICSTEP
Global Integer GISTEPBPR
Global Integer GISTEPAIN

  GSZWIZCOD = PARAM(1)
  GINBSTEP = 0
  GIFSTEP = 0
  GILSTEP = 0
  GICSTEP = 0
  GWIZPROG = ""
  GWIZBOIT = ""
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Bouton Suivant
  If [M:VIZ2]WNDRUU = "" or [M:VIZ2]PRORUU = "" Then
    ETABOU(GSPE2) = 1
  Else
    If GISTECPL(GICSTEP-1) Then
      ETABOU(GSPE2) = 1
    Else
      ETABOU(GSPE2) = 0
    Endif
  Endif
  #Bouton Précédent sur la premiète étape
  If GICSTEP = GIFSTEP Then
    ETABOU(GSPE1) = 0
  Endif
  #Bouton Précédent et Suivant sur la dernière étape.
  If GICSTEP = GILSTEP Then
    ETABOU(GSPE1) = 1
    ETABOU(GSPE2) = 1
  Endif
  #Bouton Exécuter
  If [M:VIZ2]WNDRUU = "" or [M:VIZ2]PRORUU = "" Then
    ETABOU(GSPE3) = 0
  Else
    ETABOU(GSPE3) = 1
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer IFIRSTEP
Local Integer I

  I = 0
  IFIRSTEP = 1
  Case GSZWIZCOD
    When "MAILING"
      [M:VIZ2]WIZNUM = GSZWIZCOD
      [M:VIZ2]WIZDES = mess(1,179,1)
      GIFSTEP = 1
      GICSTEP = 1
      [M:VIZ2]STETTR = mess(2,179,1)
      [M:VIZ2]STEDES = mess(10,179,1) + chr$(13) + chr$(10) +
&                      mess(11,179,1) + chr$(13) + chr$(10) +
&                      mess(12,179,1)
      [M:VIZ2]WNDRUU = ""
      [M:VIZ2]PRORUU = ""
      GINBSTEP = 8
      GILSTEP = 8
      [M:VIZ2]STENUM = "1/8"
      GISTEPBPR=3
      GISTEPAIN=4
    When "PHONING"
      [M:VIZ2]WIZNUM = GSZWIZCOD
      [M:VIZ2]WIZDES = mess(101,179,1)
      GIFSTEP = 1
      GICSTEP = 1
      [M:VIZ2]STETTR = mess(102,179,1)
      [M:VIZ2]STEDES = mess(110,179,1) + chr$(13) + chr$(10) +
&                      mess(11,179,1) + chr$(13) + chr$(10) +
&                      mess(12,179,1)
      [M:VIZ2]WNDRUU = ""
      [M:VIZ2]PRORUU = ""
      GINBSTEP = 8
      GILSTEP = 8
      [M:VIZ2]STENUM = "1/8"
      GISTEPBPR=4
      GISTEPAIN=5
    When "TRADESHOW"
      [M:VIZ2]WIZNUM = GSZWIZCOD
      [M:VIZ2]WIZDES = mess(201,179,1)
      GIFSTEP = 1
      GICSTEP = 1
      [M:VIZ2]STETTR = mess(202,179,1)
      [M:VIZ2]STEDES = mess(210,179,1) + chr$(13) + chr$(10) +
&                      mess(11,179,1) + chr$(13) + chr$(10) +
&                      mess(12,179,1)
      [M:VIZ2]WNDRUU = ""
      [M:VIZ2]PRORUU = ""
      GINBSTEP = 3
      GILSTEP = 3
      [M:VIZ2]STENUM = "1/3"
      GISTEPBPR=3
      GISTEPAIN=4
    When "MEDIA"
      [M:VIZ2]WIZNUM = GSZWIZCOD
      [M:VIZ2]WIZDES = mess(301,179,1)
      GIFSTEP = 1
      GICSTEP = 1
      [M:VIZ2]STETTR = mess(302,179,1)
      [M:VIZ2]STEDES = mess(310,179,1) + chr$(13) + chr$(10) +
&                      mess(11,179,1) + chr$(13) + chr$(10) +
&                      mess(12,179,1)
      [M:VIZ2]WNDRUU = ""
      [M:VIZ2]PRORUU = ""
      GINBSTEP = 3
      GILSTEP = 3
      [M:VIZ2]STENUM = "1/3"
      GISTEPBPR=3
      GISTEPAIN=4
    When Default
  Endcase
  #Crée les variables utiles pour la gestion du comportement de l'assistant
  Gosub SETWIZVAR
  GSZCMGNUM = [M:CMG0]NUM
  #Initialise les variables utiles pour chaque type d'assistant
  Gosub SETVAR
  #
  Affzo [M:VIZ2]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
AP_CHOIX
Return

##########################################################################################################
$FINSAI
  Gosub UNSETVAR
  Kill GSZWIZCOD
  Kill GINBSTEP
  Kill GIFSTEP
  Kill GILSTEP
  Kill GICSTEP
  Kill GIWIZCPL                    # Assistant complétement réalisé.
  Kill GISTECPL                    # Réalisation des étapes.
  Kill GSZCMGNUM                   # Code campagne marketing.
  Kill GSZOPGNUM                   # Code opération marketing.
  Kill GSZOPGDES                   # Titre opération marketing.
  Kill GISTEPBPR
  Kill GISTEPAIN
  # FGR 01/08/2014 : X3SUIVI101740 (début)
  #If dim(GCOMMCPT) >= 0 Then                                         # FGR 15/06/2015 : X3SUIVI108846
  If dim(GCOMMCPT) >= 0 and !find("GESOMM",GNAVIG(1..GPILNAV-0)) Then # FGR 15/06/2015 : X3SUIVI108846
    Kill GCOMMCPT
  Endif
  #If dim(GCOMNCPT) >= 0 Then                                         # FGR 15/06/2015 : X3SUIVI108846
  If dim(GCOMNCPT) >= 0 and !find("GESOMN",GNAVIG(1..GPILNAV-0)) Then # FGR 15/06/2015 : X3SUIVI108846
    Kill GCOMNCPT
  Endif
  #If dim(GCOMPCPT) >= 0 Then                                         # FGR 15/06/2015 : X3SUIVI108846
  If dim(GCOMPCPT) >= 0 and !find("GESOMP",GNAVIG(1..GPILNAV-0)) Then # FGR 15/06/2015 : X3SUIVI108846
    Kill GCOMPCPT
  Endif
  #If dim(GCOMTCPT) >= 0 Then                                         # FGR 15/06/2015 : X3SUIVI108846
  If dim(GCOMTCPT) >= 0 and !find("GESOMT",GNAVIG(1..GPILNAV-0)) Then # FGR 15/06/2015 : X3SUIVI108846
    Kill GCOMTCPT
  Endif
  # FGR 01/08/2014 : X3SUIVI101740 (fin)
Return

##########################################################################################################
$FIN
Local Integer I

  GIWIZCPL = 1
  For I = 0 To dim(GISTECPL) - 1
    If GISTECPL(I) = 0 Then
      GIWIZCPL = 0
      Break
    Endif
  Next
  #L'assistant n'a pas été exécuté complétement
  If GIWIZCPL = 0 Then
    Gosub CANCELWIZ
  Endif
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONPREV
    When "B"
      Gosub ONNEXT
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONPREV
  #On ne fait rien si on est déjà sur la première étape.
  If GICSTEP = GIFSTEP Then
    Return
  Endif
  Raz [M:VIZ2]STENUM
  Raz [M:VIZ2]STETTR
  Raz [M:VIZ2]STEDES
  GICSTEP -= 1
  Gosub SETWIZ2INFO
  #
  Affzo [M:VIZ2]1-99
Return

##########################################################################################################
$ONNEXT
  #On ne fait rien si on est déjà sur la dernière étape.
  If GICSTEP = GILSTEP Then
    Call LOAD_OPG From SUBCMGB
    GISTECPL(GICSTEP-1) = 1
    FIN = 1
    Return
  Endif
  #S'il n'y a rien à exécuter, on considère l'étape comme effectuée.
  If [M:VIZ2]WNDRUU = "" or [M:VIZ2]PRORUU = "" Then
    GISTECPL(GICSTEP-1) = 1
  Endif
  Raz [M:VIZ2]STENUM
  Raz [M:VIZ2]STETTR
  Raz [M:VIZ2]STEDES
  GICSTEP += 1
  Gosub SETWIZ2INFO
  Affzo [M:VIZ2]1-99
Return

