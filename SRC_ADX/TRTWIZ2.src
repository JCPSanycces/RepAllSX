##########################################################################################################
$CANCELWIZ
  Case GSZWIZCOD
    When "MAILING"
      Gosub CANCELSTEP From TRTMAI1
      Gosub CANCELSTEP From TRTMGD1
      Gosub CANCELSTEP From TRTMAI3
      Gosub CANCELSTEP From TRTMAI4
      Gosub CANCELSTEP From TRTMAI5
      Gosub CANCELSTEP From TRTMAI6
    When "PHONING"
      Gosub CANCELSTEP From TRTPHO1
      Gosub CANCELSTEP From TRTMGD1
      Gosub CANCELSTEP From TRTMAI3
      Gosub CANCELSTEP From TRTMAI4
      Gosub CANCELSTEP From TRTPHO5
      Gosub CANCELSTEP From TRTPHO6
    When "TRADESHOW"
      Gosub CANCELSTEP From TRTSHO1
    When "MEDIA"
      Gosub CANCELSTEP From TRTMED1
    When Default
  Endcase
Return

##########################################################################################################
$SETVAR
  Case GSZWIZCOD
    When "MAILING"
      Global Char GSZOBJSEL(100)                 # Type de fichier maitre utilisé pour les sélections.
      Global Integer GIDEFADD                    # Type d'adresse utilisée pour les sélections.
      Global Char GSZTYPSEA(3)                   # Type de recherche effectuée.
      Global Integer GIHIEBPR                    # Test de demande de hiérarchisation d'adresse
      Global Char GSZRPTTOCCEL(250)              # Etat Crystal Report personnalisé
      Global Char GSZWIZMGG(100)                 # Flag d'utilisation du ciblage dans le cadre de l'assistant
      Global Char GSZXMLCNTTTR(100)              # Titre générique pour les mailing Tiers
    When "PHONING"
      Global Char GSZOBJSEL(100)                 # Type de fichier maitre utilisé pour les sélections.
      Global Integer GIDEFADD                    # Type d'adresse utilisée pour les sélections.
      Global Char GSZTYPSEA(3)                   # Type de recherche effectuée.
      Global Char GSZSCRNUM(100)                 # Code script.
      Global Integer GIHIEBPR                    # Test de demande de hiérarchisation d'adresse
      Global Char GSZWIZMGG(100)                 # Flag d'utilisation du ciblage dans le cadre de l'assistant
      Global Char GSZXMLCNTTTR(100)              # Titre générique pour les mailing Tiers
    When "TRADESHOW"
    When "MEDIA"
    When Default
  Endcase
Return

##########################################################################################################
$UNSETVAR
  Case GSZWIZCOD
    When "MAILING"
      Kill GSZOBJSEL                      # Type de fichier maitre utilisé pour les sélections.
      Kill GIDEFADD                       # Type d'adresse utilisée pour les sélections.
      Kill GSZTYPSEA                      # Type de recherche effectuée.
      Kill GIHIEBPR                       # Test de demande de hiérarchisation d'adresse
      Kill GSZRPTTOCCEL                   # Etat Crystal Report personnalisé
      Kill GSZWIZMGG                      # Flag d'utilisation du ciblage dans le cadre de l'assistant
      Kill GSZXMLCNTTTR                   # Titre générique pour les mailing Tiers
    When "PHONING"
      Kill GSZOBJSEL                      # Type de fichier maitre utilisé pour les sélections.
      Kill GIDEFADD                       # Type d'adresse utilisée pour les sélections.
      Kill GSZTYPSEA                      # Type de recherche effectuée.
      Kill GSZSCRNUM                      # Code script.
      Kill GIHIEBPR                       # Test de demande de hiérarchisation d'adresse
      Kill GSZWIZMGG                      # Flag d'utilisation du ciblage dans le cadre de l'assistant
      Kill GSZXMLCNTTTR                   # Titre générique pour les mailing Tiers
    When "TRADESHOW"
    When "MEDIA"
    When Default
  Endcase
Return

##########################################################################################################
$SETWIZVAR
Global Integer GIWIZCPL                    # Assistant complétement réalisé.
Global Integer GISTECPL(GINBSTEP)          # Réalisation des étapes.
Global Char GSZCMGNUM(GLONCMG)             # Code campagne marketing.
Global Char GSZOPGNUM(GLONOPG)             # Code opération marketing.
Global Char GSZOPGDES(GLONDCO)             # Titre opération marketing.

  GIWIZCPL = 0
  GSZOPGNUM = ""
  GSZOPGDES = ""
  GSZOBJSEL = ""
  GSZCMGNUM = ""
  Raz GISTECPL
Return

