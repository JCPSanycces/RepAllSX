#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GYM",GBIDC1,GBIDC2) From GOBJET
End

############################################################################
## Duplication pyramide
############################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC 
 When Default
Endcase
Return

$INIT
If clalev([F:GYM]) = 0 : Local File GACCPYM  [GYM] : Endif
TMP = 1
GBIDC3 = ""
Return

$INIT_DIA
[M]PYRORG = PARAM(1)
zonsui = "PYM"
Return

$EXEC
Call COPIE([M]DOSORG,[M]DOSDES,[M]PYRORG,[M]PYM,[M]DES)
If GOK=1
 GBIDC3 = [M]PYM
Endif
Return

######################################################################################
## Ecran PYRCOP
######################################################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
End

Subprog C_DOSORG(VALEUR)
Variable Char    VALEUR()
Local File =VALEUR+".GACCPYM" [GYM]
Read [GYM]GYM0 = [M]PYRORG
If fstat
 GMESSAGE = mess(96,102,1) : # Pyramide inexistante
 mkstat = 2 : End
Endif
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M]DOSORG
Endif
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSORG+".GACCPYM" [GYM]
Local File =VALEUR+".GCOA"       [COA]
Read [GYM]GYM0 = [M]PYRORG
Read [COA]COA0 = [F:GYM]COA
If fstat
 GMESSAGE = [F:GYM]COA-":"-mess(110,102,1) : # Plan de compte inexistant
 mkstat = 2 : End
Endif
End

Subprog C_PYM(VALEUR)
Variable Char    VALEUR()
Local File =[M]DOSDES+".GACCPYM" [GYM]
Call LECTURE("GYM",VALEUR,"") From CONTOBJ
If !fstat         
 GMESSAGE = mess(94,102,1) : # Pyramide déjà existante
 mkstat = 2 : End
Endif
End

######################################################################################
Subprog COPIE (DOSORG,DOSDES,PYRORG,PYRDES,DESIG)
Value Char DOSORG
Value Char DOSDES
Value Char PYRORG
Value Char PYRDES
Value Char DESIG

Local File =DOSORG+".GACCPYM"    [GYM1]
Local File =DOSDES+".GACCPYM"    [GYM2]
Local File =DOSORG+".GACCGRUPYM" [GRY1]
Local File =DOSDES+".GACCGRUPYM" [GRY2]
Local File =DOSORG+".GACCPYMLIK" [GYK1]
Local File =DOSDES+".GACCPYMLIK" [GYK2]
Local File =DOSORG+".GACCPYMPRT" [GYP1]
Local File =DOSDES+".GACCPYMPRT" [GYP2]
Local File =DOSORG+".ATEXTRA"    [AXX1]
Local File =DOSDES+".ATEXTRA"    [AXX2]
Local File =DOSDES+".TABUNIT"    [TUN2]
Local File =DOSDES+".CADISTMP"   [DTP2]

Local Char TABLE(GLONATB)
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [GYM2],[GRY2],[GYK2]
 Read [GYM1]GYM0 = PYRORG
 If !fstat 
  [F:GYM2] = [F:GYM1]
  [F:GYM2]PYM    = PYRDES
  If dim([F:GYM2]DES)>0    : [F:GYM2]DES    = DESIG   : Endif
  If dim([F:GYM2]CREDAT)>0 : [F:GYM2]CREDAT = date$   : Endif
  If dim([F:GYM2]CREUSR)>0 : [F:GYM2]CREUSR = GUSER   : Endif
  If dim([F:GYM2]CRETIM)>0 : [F:GYM2]CRETIM = time    : Endif
  If dim([F:GYM2]UPDDAT)>0 : [F:GYM2]UPDDAT = [0/0/0] : Endif
  If dim([F:GYM2]UPDUSR)>0 : [F:GYM2]UPDUSR = ""      : Endif
  If dim([F:GYM2]UPDTIM)>0 : [F:GYM2]UPDTIM = 0       : Endif
  Write  [GYM2]
  If fstat 
   GOK = 0 : Call FSTA("GYM2") From GLOCK : Goto AB_TR1
  Endif
  #
  # Copie des groupes
  #
  Filter [GRY1] Where PYM=PYRORG
  For [GRY1] 
   [F:GRY2]       = [F:GRY1]
   [F:GRY2]PYM    = PYRDES
   If dim([F:GRY2]CREDAT)>0 : [F:GRY2]CREDAT = date$   : Endif
   If dim([F:GRY2]CREUSR)>0 : [F:GRY2]CREUSR = GUSER   : Endif
   If dim([F:GRY2]CRETIM)>0 : [F:GRY2]CRETIM = time    : Endif
   If dim([F:GRY2]UPDDAT)>0 : [F:GRY2]UPDDAT = [0/0/0] : Endif
   If dim([F:GRY2]UPDUSR)>0 : [F:GRY2]UPDUSR = ""      : Endif
   If dim([F:GRY2]UPDTIM)>0 : [F:GRY2]UPDTIM = 0       : Endif
   If DOSORG<>DOSDES
    If [F:GRY2]UOM<>""
     Read [TUN2]TUN0 = [F:GRY2]UOM
     If fstat
      [F:GRY2]UOM    = ""
      [F:GRY2]UOMDAC = 1
     Endif
    Endif
    If [F:GRY2]TIMDSP<>""
     Read [DTP2]DTP0 = [F:GRY2]TIMDSP
     If fstat
      [F:GRY2]TIMDSP = ""
     Endif
    Endif
   Endif
   Write [GRY2]
   If fstat 
    GOK = 0 : Call FSTA("GRY2") From GLOCK : Break
   Endif
  Next
  Filter [GRY1]
  If GOK<1 : Goto AB_TR1 : Endif
  #
  # Copie des liens
  #
  Filter [GYK1] Where PYM=PYRORG
  For [GYK1] 
   [F:GYK2] = [F:GYK1]
   [F:GYK2]PYM = PYRDES
   Write [GYK2]
   If fstat 
    GOK = 0 : Call FSTA("GYK2") From GLOCK : Break
   Endif
  Next
  Filter [GYK1]
  If GOK<1 : Goto AB_TR1 : Endif
  #
  # Copie des liens
  #
  Filter [GYP1] Where PYM=PYRORG
  For [GYP1] 
   [F:GYP2] = [F:GYP1]
   [F:GYP2]PYM = PYRDES
   Write [GYP2]
   If fstat 
    GOK = 0 : Call FSTA("GYP2") From GLOCK : Break
   Endif
  Next
  Filter [GYP1]
  If GOK<1 : Goto AB_TR1 : Endif
  #
  # Copie des textes traduisibles
  #
  For TABLE="GACCPYM","GACCGRUPYM"
   For [AXX1] Where CODFIC=TABLE & IDENT1=PYRORG
    [F:AXX2] = [F:AXX1]
    [F:AXX2]IDENT1 = PYRDES
    If TABLE="GACCPYM" & [F:AXX1]ZONE="DESTRA" & [F:AXX1]LANGUE=GLANGUE
     [F:AXX2]TEXTE = DESIG
    Endif
    Write [AXX2]
    If fstat
     GOK = 0 : Call FSTA("AXX2") From GLOCK : Break 2
    Endif
   Next
  Next TABLE
  If GOK<1 : Goto AB_TR1 : Endif
  #
 Commit
Endif
End

$AB_TR1
Rollback
Return


######################################################################################

