#<AdxTL>@(#)4.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Fill AFCRIGHT on table ASHW
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Fill AFCRIGHT on table ASHW") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ASHW [ASW]
Else
 Local File =DOSSIER+".ASHW" [ASW]
Endif

Gosub MAJTAB

Close Local File [ASW]
End


#----------------------------------------------------------------------------------------#
$MAJTAB
Local Integer BTROUVE : BTROUVE=0

If dim([F:ASW]AFCRIGHT)<=0 : Return : Endif

Filter [ASW] Where [F:ASW]AFCRIGHT<>"" and (GPRODUIT=-1 or MODULE<>1)
Read [ASW]First
If !fstat
  BTROUVE=1
Endif
Filter [ASW]
If BTROUVE=1 : Return : Endif

Local Char TAB_ASW(GLONASW)(1..)
Local Integer NB_ASW
NB_ASW=0

Trbegin [ASW]
 For [ASW]ASW0 Where [F:ASW]AFCRIGHT="" & [F:ASW]FONCTION<>""
  NB_ASW+=1
  TAB_ASW(NB_ASW)=[F:ASW]CODREP

  [F:ASW]AFCRIGHT=[F:ASW]FONCTION

  Rewrite [ASW]
  If fstat
   Call ERREUR("ASHW"-[F:ASW]CODREP,2) From DOSDIC
  Endif
 Next
Commit

#Validation différée (à la volée)
Local Integer SAVGVALID
If dim(GVALIDDIFF)<=0 : Global Integer GVALIDDIFF : Endif
SAVGVALID=GVALIDDIFF
GVALIDDIFF=3
For I=1 To NB_ASW
  Call VALIDATION(0,DOSSIER,TAB_ASW(I)) From SUBASW
Next I
GVALIDDIFF=SAVGVALID

Return
