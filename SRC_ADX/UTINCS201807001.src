#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTINCS201807001   Deletion of NCS views NCSCRAPP and NCSCRPLN          #
# X3-102479 - STWIL                                                      #
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTINCS201807001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTINCS201807001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Char SVIEW(30)

  Call ECR_TRACE("UTINCS201807001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Opening files -----#
  Local File ADOSSIER [ADS]
  Local File =DOSSIER + ".AVIEW"   [AVW]
  Local File =DOSSIER + ".AVIEWB"  [AVB]
  Local File =DOSSIER + ".AVIEWC"  [AVC]
  Local File =DOSSIER + ".AVIEWD"  [AVD]
  # -----------------
  Read [ADS]DOSSIER=DOSSIER
  Raz COMPTEUR
  # -----------------
  Trbegin [AVW]
  # Issue X3-80591 - 2018-10-16 by BAKHA : delete views not needed
  For SVIEW = "NCSCRAPP", "NCSCRPLN", "NCSCRREA", "NCSCRREAGRP", "NCSCRREAMON", "NCSCRSEV", "NCSCRSEVGRP", "NCSCRSEVMON", "NCSCRSTA", "NCSCRVERIMP"
    # --------------------------
    Filter [AVW] Where [F:AVW]CODVUE = SVIEW
    For [AVW]
      COMPTEUR += 1
      Delete [AVW]
      If fstat Then
        Call ECR_TRACE("File AVIEW" - [F:AVW]CODVUE + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVW]
    # --------------------------
    Filter [AVB] Where [F:AVB]CODVUE = SVIEW
    For [AVB]
      COMPTEUR += 1
      Delete [AVB]
      If fstat Then
        Call ECR_TRACE("File AVIEWB" - [F:AVB]CODVUE + "~" + num$([F:AVB]TYPDBA) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVB]
    # --------------------------
    Filter [AVC] Where [F:AVC]CODVUE = SVIEW
    For [AVC]
      COMPTEUR += 1
      Delete [AVC]
      If fstat Then
        Call ECR_TRACE("File AVIEWC" - [F:AVC]CODVUE + "~" + num$([F:AVC]CODCLE) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVC]
    # --------------------------
    Filter [AVD] Where [F:AVD]CODVUE = SVIEW
    For [AVD]
      COMPTEUR += 1
      Delete [AVD]
      If fstat Then
        Call ECR_TRACE("File AVIEWD" - [F:AVD]CODVUE + "~" + num$([F:AVD]NUMLIG) + "~" + num$([F:AVD]FLDVUE) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVD]
    # --------------------------
    Call SUPVUE(SVIEW, DOSSIER, [F:ADS]TYPDBA) From DOSVUE
    # --------------------------
  Next
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTINCS201807001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTINCS201807001 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [AVW]
  Close Local File [AVB]
  Close Local File [AVC]
  Close Local File [AVD]
End

########################################################################
# For automatic execution in patch management                          #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","AVIEW","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEW") : End : Endif
  If filinfo(filpath("FIL","AVIEWD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWD") : End : Endif
  If filinfo(filpath("FIL","AVIEWC","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWC") : End : Endif
  If filinfo(filpath("FIL","AVIEWB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWB") : End : Endif
  # -------------------------
  Call MAJ_UTINCS201807001(APPLI)
End

#######################################################################
# For execution since dosmaj (file validation)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If filinfo(filpath("FIL","AVIEW","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEW") : End : Endif
  If filinfo(filpath("FIL","AVIEWD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWD") : End : Endif
  If filinfo(filpath("FIL","AVIEWC","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWC") : End : Endif
  If filinfo(filpath("FIL","AVIEWB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWB") : End : Endif
  # -------------------------
  Call MAJ_UTINCS201807001(APPLI)
End

