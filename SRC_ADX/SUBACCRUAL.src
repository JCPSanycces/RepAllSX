#<AdxTL>@(#)0.0.0.0 $Revision$ 

#FRLAA 2018-02-14 X3-74480 - START
Subprog LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,NEVENT,CTRNUMBER,LVESUBTYPE,FILTERDATE,FUTBALS,RF_IS_SOA,LVE_ERRMESSAGE,LVE_GOK,LVE_MPYRDAT,CTRENDDAT,IS_PREVIOUS_CTR)
Value Integer IS_PREVIOUS_CTR
Value Integer RF_IS_SOA
Variable Char LVE_ERRMESSAGE
Variable Integer LVE_GOK
Value Date LVE_MPYRDAT
#FRLAA 2018-02-14 X3-74480 - END
Value Char CRITHRTIM(),CRITHRLST(),CRITHRCTR()
Value Char NEVENT,CTRNUMBER,LVESUBTYPE
Value Date FILTERDATE,CTRENDDAT
Variable Char FUTBALS()(0..,0..10)
Global Integer Z
Global Char GLMCYCLESTR(250)
Global Date GLMCYCLE
Local Date FILTERDATEDCG
FILTERDATEDCG=FILTERDATE

Local Char LVE_GCURLEG(GLONADI) #FRLAA 2018-02-14 X3-74480
  If clalev([TIM]) = 0      : Local File TIMCOD [TIM] Endif
  If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
  If clalev([HRLSTH]) = 0      : Local File HRLVESUBHEA [HRLSTH] Endif
  If clalev([HRLSTH1]) = 0      : Local File HRLVESUBHEA [HRLSTH1] Endif
  If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
  If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
  If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
  If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
  If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
  If clalev ([HRACCR]) = 0   : Local File HRLVEACCRU [HRACCR] Endif
  If clalev ([HRACCR1]) = 0   : Local File HRLVEACCRU [HRACCR1] Endif
  If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
  If clalev([F:VEP2])=0   : Local File VALEMP     [VEP2]  : Endif
  If clalev([F:DCGAC])=0 : Local File DEMCONGE   [DCGAC] : Endif
  If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
  If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
  If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif

  Local Integer S
  Local Char CRITACC1(250),CRITACCCHK1(250),CRITACC2(250),CRITACCCHK2(250),CRITLTA(250)
  Local Integer CRITCOUNT,DIMTIM
  Local Integer CRFCHK,RCOUNTACCR,ARRNEXT,TRACECOUNT

  If FILTERDATE=[0/0/0]
    Gosub SUBACCRUAL_TRTLVEACC
  Else
    Gosub SUBACCRUAL_CONTRACT
  Endif
End

$CARRY_OVER_EXP
#read from DEMCONGE
#read from accruals done from date of cycle
  Local Decimal ACCRUALS
  Local Decimal LVETKN
  Local Decimal CAROVERAMT
  Local Date EXPIRY1

  If clalev([F:DCGSP]) = 0 : Local File DEMSPLITS [DCGSP] : Endif

  If PREVCYCDAT = [0/0/0] : PREVCYCDAT=[F:HRACCR]LVEACCEXP :  Endif
  Filter [F:HRLSTH1] Where COD = [F:HRLSTH]LVECARSUB and LEG = [F:CPY]LEG
#NEW lst EXPIR
  Read [F:HRLSTH1] First
  Filter [F:HRLSTH1]
  CURRDAT = [F:HRACCR]LVEACCDAT
  CYCLEN = [F:HRLSTH1]CYCLEN
  If [F:HRLSTH1]CYCLENU = 1
    CARRYDATE = addmonth(CURRDAT,CYCLEN*-12)
  Else
    CARRYDATE = addmonth(CURRDAT,-CYCLEN)
  Endif

  Filter [HRACCR1] Where CTR = [F:HRCTR]CTRNUM and CTRDAT=[L]CTR_DATE and [F:HRACCR1]LVEACCLST = [F:TIM]LVESUBTYP(S-1) and [F:HRACCR1]LVEACCEXP = [F:HRACCR]LVEACCEXP#PREVCYCDAT
#calculate all accruals plus the previous carry overs excluding Excess
  For [HRACCR1]
    ACCRUALS += val([HRACCR1]LVEACCAMT)
  Next

#  Filter [DCGAC] Where CTRNUM = [F:HRACCR]CTR and [F:DCGAC]TIM = [F:TIM]COD and ([F:DCGAC]STRDAT >= CARRYDATE and [F:DCGAC]STRDAT <= CURRDAT) and UID>0
#&                and ([F:DCGAC]STA=1|[F:DCGAC]STA=2|[F:DCGAC]STA=3|[F:DCGAC]STA=4|[F:DCGAC]STA=5)
#  If rowcount([F:DCGAC]) > 0

  #PEVAN - 2018-10-10 - X3-111790 - START
  Link [DCGAC] With [DCGSP]DCGSP1=[DCGAC]UID As [SPLITS]
& Where [DCGAC]CTRNUM = [F:HRACCR]CTR and [F:DCGSP]LVESUBTYP = [F:TIM]LVESUBTYP(S-1) and [F:DCGSP]LVESUBBAL > 0
&   and ([DCGAC]STA = 1 | [DCGAC]STA = 2 | [DCGAC]STA = 3 or [DCGAC]STA = 5 or [DCGAC]STA = 7)
&   and ([F:DCGSP]LVEDAT >= CARRYDATE and [F:DCGSP]LVEDAT <= CURRDAT)

  Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
  For [SPLITS]
    LVETKN += [DCGSP]LVESUBBAL
  Next
  Columns [SPLITS]
  #PEVAN - 2018-10-10 - X3-111790 - END

##check for transaction in DCG and amounts taken for whole transaction falling into cycle.
#    For [F:DCGAC]
##no over laps
#      If [F:DCGAC]STRDAT >= CARRYDATE and [F:DCGAC]ENDDAT <= CURRDAT ##Leave transaction only in current cycle
#        LVETKN = LVETKN + [F:DCGAC]NBRDAY
#      Elsif [F:DCGAC]STRDAT >= CARRYDATE and [F:DCGAC]ENDDAT > CURRDAT ##Leave transaction going over cycle
#        Local Decimal NRDAYS,NRHOURS: NRDAYS=0: NRHOURS=0
#        Call VALORIS_L([F:DCGAC]STRDAT,CURRDAT,[F:HRCTR]REFNUM,[TIM]COD,NRDAYS,NRHOURS,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT)
#        LVETKN += NRDAYS
#      Endif
##Over laps --> nou nou
#    Next
#  Endif
#  Filter [F:DCGAC]

#carry over
  CAROVERAMT=ACCRUALS-LVETKN
  [F:HRACCR]LVEACCAMT=num$(CAROVERAMT)
  [F:HRACCR]LVEACCTYP = "Carry Over"

  If [F:HRLSTH1]LVECARSUB <> ""
    [F:HRACCR]LVEACCLST = [F:HRLSTH1]LVECARSUB
    [F:HRACCR]ACCFRM=[TIM]LVESUBTYP(S-1)
    If [F:HRLSTH1]CYCLENU = 1
      EXPIRY1 = addmonth(PREVCYCDAT,[F:HRLSTH1]CYCLEN*12)
    Else
      EXPIRY1 = addmonth(PREVCYCDAT,[F:HRLSTH1]CYCLEN)
    Endif
    [F:HRACCR]LVEACCEXP=EXPIRY1#-1
  Else
    [F:HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1)
    [F:HRACCR]LVEACCEXP=EXPIRY#-1
  Endif
  Local Char ACC(GLONVCR)
  [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([F:HRCTR]REFNUM)
  If LVE_GOK = 1
    Return
  Endif
  [F:HRACCR]LVEACCTRS = [L]ACC
  If NEED_TO_WRITE=1
    Write [F:HRACCR]
  Else
    FUTBALS(Z,1)=[F:HRACCR]LVEACCTIM
    FUTBALS(Z,2)=[F:HRACCR]LVEACCLST
    FUTBALS(Z,3)=[F:HRACCR]LVEACCDAT
    FUTBALS(Z,4)=[F:HRACCR]LVEACCEXP
    FUTBALS(Z,5)=[F:HRACCR]LVEACCAMT
    Z+=1
  Endif

  If RF_IS_SOA
  Else
    If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
      Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1) - " CARRY OVER",0) From GESECRAN
    Endif
  Endif

  TRACECOUNT+=1
Return

$WRITE_ACCRU
  Local Date CHECKWRITE
  Local Integer SUSPENDINT, SUSPENDED
  SUSPENDED = 0
  ACC_CHK+=1

  [F:HRACCR]CTR=[F:HRCTR]CTRNUM
  [F:HRACCR]SYSDAT=datesyst

  Raz [F:HRACCR]LVEACCPRD
  If find([TIM]COD,"SSP","SPP","SMP")=0
    [F:HRACCR]LVEACCPRD=[F:VEP2]BUL
  Endif

  [F:HRACCR]LVEACCTIM=[TIM]COD
  [F:HRACCR]REFNUM=[F:HRCTR]REFNUM

  Local Char ALLSUBTYPES(GLONHRLST)(0..,0..9)
  Local Integer CNTALL
  Call GET_LEAVE_SUB_TYPES([HRCTR]CTRNUM, [F:HRACCR]LVEACCDAT,[TIM]COD, ALLSUBTYPES) From SUBHRBAL
  For CNTALL = 0 To maxtab(ALLSUBTYPES)
    If ALLSUBTYPES(CNTALL,1) = [TIM]LVESUBTYP(S-1)
      Local Date CTRCONVDATE
      Call CONVERT_TO_DATE(ALLSUBTYPES(CNTALL,4), CTRCONVDATE) From SUBHRBAL
      [F:HRACCR]CTRDAT=CTRCONVDATE
      Call CONVERT_TO_DATE(ALLSUBTYPES(CNTALL,5), CTRCONVDATE) From SUBHRBAL
      [F:HRACCR]XITDAT=CTRCONVDATE
      Break
    Endif
  Next

  Gosub GET_EXPIRY
  Gosub GET_VALUE

#Storing the period end date
  If clalev([HRLSTH7]) = 0 : Local File HRLVESUBHEA [HRLSTH7] : Endif
  Read [HRLSTH7]HRLST0 = GCURLEG;[F:HRACCR]LVEACCLST
  If !fstat
    If [F:HRLSTH7]LVEACCOPT = 2 | [F:HRLSTH7]LVEACCOPT = 5
      [F:HRACCR]ACCPEREXP = EXPIRY
      [F:HRACCR]ACCCYCSTR = evalue([F:HRLSTH7]CYCSTRCAL)
      [F:HRACCR]ACCPERSTR = [F:HRPEOD]PERSTR(1)
    Else
      If [F:HRLSTH7]LVEACCOPT = 3 | [F:HRLSTH7]LVEACCOPT = 4
        [F:HRACCR]ACCPEREXP = [F:HRPEOD]PEREND(1)
        [F:HRACCR]ACCCYCSTR = evalue([F:HRLSTH7]CYCSTRCAL)
        [F:HRACCR]ACCPERSTR = [F:HRPEOD]PERSTR(1)
      Endif
    Endif
  Endif

  If VARDAT>[F:HRACCR]LVEACCDAT
    [F:HRACCR]LVEACCDAT=VARDAT
  Endif

  If EXPIRY2<>[0/0/0]
    CHECKWRITE=EXPIRY2
  Else
    CHECKWRITE=CURRDAT
  Endif
#TESTING FOR accrual non recuring
#checking for accual suspentions start
  For SUSPENDINT = 0 To dim([F:HRCTR]CODLST)-1
    If [F:HRCTR]CODLST(SUSPENDINT) = [F:HRLSTH]COD
      If ([F:HRCTR]STRDATLVE(SUSPENDINT)=[0/0/0] & [F:HRCTR]ENDDATLVE(SUSPENDINT)=[0/0/0]) | (([F:HRCTR]STRDATLVE(SUSPENDINT)<=[F:HRPEOD]PERSTR(1)) & ([F:HRCTR]ENDDATLVE(SUSPENDINT)>=[F:HRPEOD]PERSTR(
&          1)))
        SUSPENDED = 1
      Endif
    Endif
  Next

  If SUSPENDED = 0
#checking for accual suspensions end
    If ([F:HRLSTH]CYCREC=1 and ([HRLSTH]LVEACCOPT <> 2 &([F:HRPEOD]PEREND(1)<=CHECKWRITE))) | [F:HRLSTH]CYCREC=2 | ([HRLSTH]LVEACCOPT = 2 & (CYCARR(I-1,1)>=[HRACCR]LVEACCDAT))
&    | ([HRLSTH]LVEACCOPT = 2 & CYCARR(I-1,2)>ZUTEXPDAT)

      [F:HRACCR]ACCFRM=""

      If NEED_TO_WRITE=1
        Local Char ACC(GLONVCR)
        [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([F:HRCTR]REFNUM)
        [F:HRACCR]LVEACCTRS = [L]ACC
        Write [F:HRACCR]
      Else
        FUTBALS(Z,1)=[F:HRACCR]LVEACCTIM
        FUTBALS(Z,2)=[F:HRACCR]LVEACCLST
        FUTBALS(Z,3)=[F:HRACCR]LVEACCDAT
        FUTBALS(Z,4)=[F:HRACCR]LVEACCEXP
        FUTBALS(Z,5)=[F:HRACCR]LVEACCAMT
        Z+=1
      Endif

      If RF_IS_SOA
      Else
        If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
          Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1) - " ACCRUAL",0) From GESECRAN
        Endif
      Endif
      TRACECOUNT+=1
    Endif
    If [F:HRLSTH]CYCREC=1 and (([HRLSTH]LVEACCOPT = 2 & CYCARR(I-1,1)<CHECKWRITE) & (CYCARR(I-1,1)>[HRACCR]LVEACCDAT))
      [F:HRACCR]ACCFRM=""
      If NEED_TO_WRITE=1
        Local Char ACC(GLONVCR)
        [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([LNK]REFNUM)
        [F:HRACCR]LVEACCTRS = [L]ACC
        Write [F:HRACCR]
        If [F:HRACCR]LVEACCAMT < 0
      Endif
      Else
        FUTBALS(Z,1)=[F:HRACCR]LVEACCTIM
        FUTBALS(Z,2)=[F:HRACCR]LVEACCLST
        FUTBALS(Z,3)=[F:HRACCR]LVEACCDAT
        FUTBALS(Z,4)=[F:HRACCR]LVEACCEXP
        FUTBALS(Z,5)=[F:HRACCR]LVEACCAMT
        Z+=1
      Endif

      If RF_IS_SOA
      Else
        If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
          Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1) - " ACCRUAL",0) From GESECRAN
        Endif
      Endif
      TRACECOUNT+=1
    Endif
  Endif
# IF Raz is only in the NEED_TO_WRITE=1 if statement, the [F:HRACCR] stays in context and you will get unwanted values...
  Raz [F:HRACCR]
Return

$WRITE_ACCRU_CALC
  Local Date CHECKWRITE
  [F:HRACCR]CTR=[HRCTR]CTRNUM
  [F:HRACCR]SYSDAT=datesyst
  Raz [F:HRACCR]LVEACCPRD
  If find([TIM]COD,"SSP","SPP","SMP")=0
    [F:HRACCR]LVEACCPRD=[F:VEP2]BUL
  Endif
  [F:HRACCR]LVEACCTIM=[TIM]COD
  [F:HRACCR]REFNUM=[F:HRCTR]REFNUM

  Gosub GET_EXPIRY
  Gosub GET_VALUE

  If clalev([HRLSTH7]) = 0      : Local File HRLVESUBHEA [HRLSTH7] Endif
  Read [HRLSTH7]HRLST0 = GCURLEG;[F:HRACCR]LVEACCLST
  If !fstat
    If [F:HRLSTH7]LVEACCOPT = 2 | [F:HRLSTH7]LVEACCOPT = 5
      [F:HRACCR]ACCPEREXP = EXPIRY
      [F:HRACCR]ACCCYCSTR = evalue([F:HRLSTH7]CYCSTRCAL)
      [F:HRACCR]ACCPERSTR = [F:HRPEOD]PERSTR(1)
    Else
      If [F:HRLSTH7]LVEACCOPT = 3 | [F:HRLSTH7]LVEACCOPT = 4
        [F:HRACCR]ACCPEREXP = [F:HRPEOD]PEREND(1)
        [F:HRACCR]ACCCYCSTR = evalue([F:HRLSTH7]CYCSTRCAL)
        [F:HRACCR]ACCPERSTR = [F:HRPEOD]PERSTR(1)
      Endif
    Endif
  Endif

  If EXPIRY2<>[0/0/0]
    CHECKWRITE=EXPIRY2
  Else
    CHECKWRITE=CURRDAT
  Endif
#TESTING FOR accrual non recuring
#checking for accual suspentions start
  If ([HRCTR]STRDATLVE=[0/0/0] & [HRCTR]ENDDATLVE=[0/0/0]) | (([HRCTR]STRDATLVE<[F:HRPEOD]PERSTR(1))  & ([HRCTR]ENDDATLVE<[F:HRPEOD]PERSTR(1))) | (([HRCTR]STRDATLVE>[F:HRPEOD]PERSTR(1))  & ([HRCTR]
&     ENDDATLVE>[F:HRPEOD]PERSTR(1)))
#checking for accual suspensions end
    If ([F:HRLSTH]CYCREC=1 and ([HRLSTH]LVEACCOPT <> 2 &([F:HRPEOD]PEREND(1)<CHECKWRITE))) | ([F:HRLSTH]CYCREC=2 | ([HRLSTH]LVEACCOPT = 2 & (CYCARR(I-1,1)>[HRACCR]LVEACCDAT)))
      [F:HRACCR]ACCFRM=""
      If NEED_TO_WRITE=1
      Else
        FUTBALS(Z,1)=[F:HRACCR]LVEACCTIM
        FUTBALS(Z,2)=[F:HRACCR]LVEACCLST
        FUTBALS(Z,3)=[F:HRACCR]LVEACCDAT
        FUTBALS(Z,4)=[F:HRACCR]LVEACCEXP
        FUTBALS(Z,5)=[F:HRACCR]LVEACCAMT
        Z+=1
      Endif

      If RF_IS_SOA
      Else
        If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
          Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1) - " ACCRUAL",0) From GESECRAN
        Endif
      Endif
      TRACECOUNT+=1
    Endif
    If [F:HRLSTH]CYCREC=1 and (([HRLSTH]LVEACCOPT = 2 & CYCARR(I-1,1)<CHECKWRITE) & (CYCARR(I-1,1)>[HRACCR]LVEACCDAT))
      [F:HRACCR]ACCFRM=""
      If NEED_TO_WRITE=1
      Else
        FUTBALS(Z,1)=[F:HRACCR]LVEACCTIM
        FUTBALS(Z,2)=[F:HRACCR]LVEACCLST
        FUTBALS(Z,3)=[F:HRACCR]LVEACCDAT
        FUTBALS(Z,4)=[F:HRACCR]LVEACCEXP
        FUTBALS(Z,5)=[F:HRACCR]LVEACCAMT
        Z+=1
      Endif

      If RF_IS_SOA
      Else
        If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
          Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1) - " ACCRUAL",0) From GESECRAN
        Endif
      Endif
      TRACECOUNT+=1
    Endif
  Endif
# IF Raz is only in the NEED_TO_WRITE=1 if statement, the [F:HRACCR] stays in context and you will get unwanted values...
  Raz [F:HRACCR]
Return

$WRITE_ACCRU_LINK
  Local Integer ROWW,U

  If dim([M:CTR0]CTRDAT)>0
    Filter [HRACCR] Where [HRACCR]CTR = [LNK2]CTRNUM and [HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1) and [HRACCR]CTRDAT=[M:CTR0]CTRDAT and LVEACCTYP = "Linking"
  Else
    Filter [HRACCR] Where [HRACCR]CTR = [LNK2]CTRNUM and [HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1) and [HRACCR]CTRDAT=[F:HRCTR]CTRDAT and LVEACCTYP = "Linking"
  Endif
  Read [HRACCR] Last
  ROWW=rowcount([HRACCR])

  If ROWW=0 & [HRCTR]XITFNL<>2
    If !clalev([F:LSTCHK])   : Local File HRLVESUBDET [F:LSTCHK]   : Endif
    If !clalev([F:LSTWRITE]) : Local File HRLVESUBDET [F:LSTWRITE] : Endif
    If dim(UPDATE_SUBTYPES) > 0 & UPDATE_SUBTYPES = 1
      Filter [F:LSTCHK] Where [F:LSTCHK]CTRNUM=[F:HRCTR]CTRNUM & [F:LSTCHK]COD=[TIM]LVESUBTYP(S-1) & [F:LSTCHK]LEV=7
      For [F:LSTCHK]
        Raz [F:LSTWRITE]
        [F:LSTWRITE]=[F:LSTCHK]
        [F:LSTWRITE]CTRDAT=[F:HRCTR]CTRDAT
        Write [F:LSTWRITE]
      Next
    Endif
    Close File [F:LSTCHK]

    [F:HRACCR]CTR=[LNK2]CTRNUM
    [F:HRACCR]SYSDAT=datesyst

    Raz [F:HRACCR]LVEACCPRD
    If find([F:HRACCR]LVEACCTIM,"SSP","SPP","SMP")=0
      [F:HRACCR]LVEACCPRD=[F:VEP2]BUL
    Endif
    [F:HRACCR]REFNUM=[F:HRCTR]REFNUM
    [F:HRACCR]LVEACCTIM=[TIM]COD
    [F:HRACCR]LVEACCDAT=[01/01/1900]
    [F:HRACCR]ACCPEREXP=[01/01/1900] #FRLAA 2018-08-21 X3-104072
    [F:HRACCR]ACCCYCSTR=[01/01/1900] #FRLAA 2018-08-21 X3-104072
    [F:HRACCR]ACCPERSTR=[01/01/1900] #FRLAA 2018-08-21 X3-104072
    [F:HRACCR]LVEACCAMT="0"
    If dim([M:CTR0]CTRDAT)>0
      [F:HRACCR]CTRDAT=[M:CTR0]CTRDAT
      [F:HRACCR]XITDAT=[M:CTR0]XITDAT
    Else
      [F:HRACCR]CTRDAT=[F:HRCTR]CTRDAT
      [F:HRACCR]XITDAT=[F:HRCTR]XITDAT
    Endif

    Gosub ACCRUDETAIL_LINKING
    Write [F:HRACCR]
  Else
    For [HRACCR]
#XITDAT update from contract
      If dim([M:CTR0]CTRDAT)>0
        Update [HRACCR] Where [HRACCR]CTRDAT = [LNK2]CTRNUM and [HRACCR]CTRDAT=[M:CTR0]CTRDAT  With [HRACCR]XITDAT = [M:CTR0]XITDAT
      Else
        Update [HRACCR] Where [HRACCR]CTRDAT = [LNK2]CTRNUM and [HRACCR]CTRDAT=[LNK]CTRDAT  With [HRACCR]XITDAT = [F:HRCTR]XITDAT
      Endif
    Next
  Endif
  Filter [HRACCR]
Return

$GET_VALUE
  Local Decimal AMT
  Local Decimal NRDAYS,NRDAYSL
  Local Decimal NRHOURS,NRHOURSL
  Local Integer CPRO,CYCPER
  Local Date EXTRACTION_START_DATECL,EXTRACTION_END_DATECL

  Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, CYCARR(I-1,1), EXTRACTION_START_DATECL, EXTRACTION_END_DATECL,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL

  NRDAYS=0
  NRDAYSL=0
  NRHOURS=0
  NRHOURSL=0
  CPRO=0
  If (VARDAT > [F:HRPEOD]PERSTR(1) and [F:HRLSTH]LVEPRORAT=2 and [F:HRLSTH]ENTTYP<>1 and RCOUNTACCR=0) | (EXTRACTION_START_DATE> [F:HRPEOD]PERSTR(1)and [F:HRLSTH]LVEPRORAT=2
& and [F:HRLSTH]ENTTYP<>1 and RCOUNTACCR=0) | (CYCARR(I-1,1)<[F:HRPEOD]PERSTR(1) and [F:HRLSTH]LVEPRORAT=2 and [F:HRLSTH]ENTTYP<>1 and RCOUNTACCR=0  and ACC_CHK=1 )
#SAVAN - 2018/03/07 - Pro-Rata Add Cycle Start - Check year instead of month - start
    If ([F:HRLSTH]LVEACCOPT=3 | [F:HRLSTH]LVEACCOPT=4)
      If VARDAT<EXTRACTION_START_DATE
        Call VALORIS_L(EXTRACTION_START_DATE,[F:HRPEOD]PEREND(1),[HRCTR]REFNUM,[TIM]COD,NRDAYS,NRHOURS,[F:HRCTR]ETRFCY,[HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT) #FRLAA 2018-02-14 X3-74480
        If [F:HRLSTH]LVEACCOPT=3
          [F:HRACCR]LVEACCDAT=EXTRACTION_START_DATE
        Endif
      Else
        Call VALORIS_L(VARDAT,[F:HRPEOD]PEREND(1),[HRCTR]REFNUM,[TIM]COD,NRDAYS,NRHOURS,[F:HRCTR]ETRFCY,[HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT) #FRLAA 2018-02-14 X3-74480
        [F:HRACCR]LVEACCDAT=VARDAT
      Endif
      Call VALORIS_L([F:HRPEOD]PERSTR(1),[F:HRPEOD]PEREND(1),[HRCTR]REFNUM,[TIM]COD,NRDAYSL,NRHOURSL,[F:HRCTR]ETRFCY,[HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT)#FRLAA 2018-02-14 X3-74480
    Elsif ([F:HRLSTH]LVEACCOPT=5 | [F:HRLSTH]LVEACCOPT=6 | [F:HRLSTH]LVEACCOPT=2)
    #Get cycle start date and end to determine the days in a cycle compared to the ones worked.
      If VARDAT<EXTRACTION_START_DATE
        Call VALORIS_L(EXTRACTION_START_DATE,EXTRACTION_END_DATE,[HRCTR]REFNUM,[TIM]COD,NRDAYS,NRHOURS,[F:HRCTR]ETRFCY,[HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT)
      Else
        Call VALORIS_L(VARDAT,EXTRACTION_END_DATE,[HRCTR]REFNUM,[TIM]COD,NRDAYS,NRHOURS,[F:HRCTR]ETRFCY,[HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT)#FRLAA 2018-02-14 X3-74480
      Endif
      If [F:HRLSTH]LVEACCOPT<>2
        Call VALORIS_L(EXTRACTION_START_DATECL,EXTRACTION_END_DATE,[HRCTR]REFNUM,[TIM]COD,NRDAYSL,NRHOURSL,[F:HRCTR]ETRFCY,[HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT)#FRLAA 2018-02-14 X3-74480
        [F:HRACCR]LVEACCDAT=EXTRACTION_START_DATE
      Else
        Call VALORIS_L(EXTRACTION_START_DATECL,EXTRACTION_END_DATE,[HRCTR]REFNUM,[TIM]COD,NRDAYSL,NRHOURSL,[F:HRCTR]ETRFCY,[HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT)
        [F:HRACCR]LVEACCDAT=EXTRACTION_START_DATE
      Endif
    Endif
    CPRO=1
    Gosub GET_CYCLE_LENGTH
#SAVAN - 2018/03/09 - DIV=0 as the Entitlement type is Not applicable
    If DIV=0 : DIV=1 : Endif
    AMT=(evalue([F:HRLSTH]ENTCAL)/DIV)*PRO
    [F:HRACCR]LVEACCAMT=num$(AMT)
  Elsif (VARDAT > [F:HRPEOD]PERSTR(1) and [F:HRLSTH]LVEPRORAT=1 and [F:HRLSTH]ENTTYP<>1 and RCOUNTACCR=0) | (EXTRACTION_START_DATE> [F:HRPEOD]PERSTR(1)and [F:HRLSTH]LVEPRORAT=1
& and [F:HRLSTH]ENTTYP<>1 and RCOUNTACCR=0) | (CYCARR(I-1,1)<[F:HRPEOD]PERSTR(1) and [F:HRLSTH]LVEPRORAT=1 and [F:HRLSTH]ENTTYP<>1 and RCOUNTACCR=0  and ACC_CHK=1 )
    If [F:HRLSTH]LVEACCOPT = 3 | [F:HRLSTH]LVEACCOPT = 4
      If VARDAT = [F:HRPEOD]PERSTR(1)
        Gosub GET_CYCLE_LENGTH
        If DIV=0 : DIV=1 : Endif
        AMT=val([F:HRLSTH]ENTCAL)/DIV
        [F:HRACCR]LVEACCAMT=num$(AMT)
      Else
        Raz AMT
        [F:HRACCR]LVEACCAMT=num$(AMT)
      Endif
    Endif
  Else
    Gosub GET_CYCLE_LENGTH
    If DIV=0 : DIV=1 : Endif
    If [F:HRLSTH]COD="SSP_E"
      AMT=evalue([F:HRLSTH]ENTCAL)/DIV
    Else
      AMT=val([F:HRLSTH]ENTCAL)/DIV
    Endif
    [F:HRACCR]LVEACCAMT=num$(AMT)
  Endif
Return

$EXTRACTION_ACCRUAL
  Local Date CCYCLDAT,EXTRACTION_START_DATE,EXTRACTION_END_DATE,TARGET_DATE,ZUTEXPDAT
  Local Integer I,Y,NEED_TO_WRITE,ACC_CHK,T
  Local Char CTRNUMBER(GLONHRCTR)  #FRLAA 2018-08-14 X3-104072

  If clalev ([ACCRCAL]) = 0 : Local File HRLVEACCRU [ACCRCAL] : Endif

  Filter [F:ACCRCAL] Where CTR=[L]ACC_CTRNUM and CTRDAT=[L]ACC_CTRDAT & (ACCCYCSTR <= FILTERDATE & ACCPEREXP >= FILTERDATE) & LVEACCLST = [F:HRLSTH]COD and LVEACCTYP = "Accrual"
  If rowcount([F:ACCRCAL])>0 and IS_PREVIOUS_CTR <> 1
    Filter [F:ACCRCAL]
    Return
  Endif
  Filter [F:ACCRCAL]

  If  EXTRACTION_START_DATE=[0/0/0]
    EXTRACTION_START_DATE=COMPDAT
    VARDAT=COMPDAT
  Endif
  Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, VARDAT, EXTRACTION_START_DATE, EXTRACTION_END_DATE,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL

  Local Char CTRNUMBER(GLONHRCTR) : CTRNUMBER = [F:HRCTR]CTRNUM
  Local Date CTR_DATE             : CTR_DATE = [F:HRCTR]CTRDAT

  Gosub CYCLE_CHECK From SUBDCGGLM
  If [HRLSTH]CYCLENU=1 & [HRLSTH]CYCLEN<50
    Gosub CHECK_HRPEOD_STR
  Endif
#SAVAN checks for writing accrual or FUTBALS - start
  If IS_PREVIOUS_CTR <> 1 and FILTERDATEDCG<>[0/0/0]
    TARGET_DATE=FILTERDATEDCG
    NEED_TO_WRITE=0
  Else
    If [F:HRCTR]XITDAT<>[0/0/0]
      If [F:HRCTR]XITDAT<[VEP2]ENDDAT
        TARGET_DATE=[F:HRCTR]XITDAT
      Else
        TARGET_DATE=[VEP2]ENDDAT
      Endif
    Else
      TARGET_DATE=[VEP2]ENDDAT
    Endif
    NEED_TO_WRITE=1
  Endif

  If ([HRLSTH]LVEACCOPT <> 2 & [HRLSTH]LVEACCOPT <> 7)
    If [HRLSTH]LVEACCOPT = 3 | [HRLSTH]LVEACCOPT = 4
      Local Integer CONTINUE_ACCRUAL: CONTINUE_ACCRUAL=1
      If RCOUNTACCR=0
        I=1
        Filter [HRPEOD]
        If [HRLSTH]LVEACCOPT = 3
          If [F:HRLSTH]LVEPRORAT=2
            Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
          Else
            Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
          Endif
        Else
          If [F:HRLSTH]LVEPRORAT=2
            Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PEREND(1) <= TARGET_DATE)
          Else
            Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PEREND(1) <= TARGET_DATE) & (([F:HRPEOD]PERSTR(1) >= EXTRACTION_START_DATE
&                           and [F:HRPEOD]PEREND(1) <= TARGET_DATE))
          Endif
        Endif
        For [HRPEOD]
          I=0
          For V=0 To maxtab(CYCARR)
            If CYCARR(V,1)=[0/0/0] : Break : Endif
            If [F:HRPEOD]PEREND(1) >= CYCARR(V,1) : I+=1: Endif
          Next
          If I > 0
            If CYCARR(I-1,1) <> [0/0/0]
              If [F:HRPEOD]PEREND(1) <= CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 4
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
                Gosub WRITE_ACCRU
              Elsif [F:HRPEOD]PERSTR(1) <= CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 3
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
              Endif
              If LVE_GOK =1
                Break
                Return
              Endif
            Endif
          Endif
        Next
        Filter [HRPEOD]
      Else
        I=1
        Filter [HRPEOD]
        If [HRLSTH]LVEACCOPT = 3
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PEREND(1) <= TARGET_DATE)
        Endif
        For [HRPEOD]
          I=0
          For V=0 To maxtab(CYCARR)
            If CYCARR(V,1)=[0/0/0] : Break : Endif
            If [F:HRPEOD]PEREND(1) >= CYCARR(V,1) : I+=1: Endif
          Next
          If I > 0
            If CYCARR(I-1,1) <> [0/0/0]
              If [F:HRPEOD]PEREND(1) <= CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 4
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
                Gosub WRITE_ACCRU
              Elsif [F:HRPEOD]PERSTR(1) <= CYCARR(I-1,2) & [F:HRLSTH]LVEACCOPT = 3
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
              Endif
              If LVE_GOK = 1
                Break
                Return
              Endif
            Endif
          Endif
        Next
      Endif
    Endif
    If [HRLSTH]LVEACCOPT = 5 | [HRLSTH]LVEACCOPT = 6
      If clalev ([ACCRCAL]) = 0   : Local File HRLVEACCRU [ACCRCAL] Endif
      If RCOUNTACCR=0
        If [HRLSTH]LVEACCOPT = 5
          If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
            Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD
          Else
            If [F:HRLSTH]LVEPRORAT=2
              Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
            Else
              Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
            Endif
          Endif
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PEREND(1) <= TARGET_DATE)
        Endif

        For I=1 To maxtab(CYCARR)
          If CYCARR(I-1,1) <> [0/0/0]
            For [HRPEOD]
              If [F:HRLSTH]LVEPRORAT=2 and ACC_CHK=0
                If [HRLSTH]LVEACCOPT = 5 & ((CYCARR(I-1,1)<[F:HRPEOD]PEREND(1) & CYCARR(I-1,2)>[F:HRPEOD]PEREND(1)) & ([F:HRPEOD]PEREND(1)>=EXTRACTION_START_DATE & [F:HRPEOD]PERSTR(1)<=
& EXTRACTION_START_DATE))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
              Elsif [HRLSTH]LVEACCOPT = 5 & (([F:HRPEOD]PERSTR(1) <= CYCARR(I-1,1) & ([F:HRPEOD]PEREND(1)>=CYCARR(I-1,1)) & [F:HRPEOD]PEREND(1)>=EXTRACTION_START_DATE & [F:HRPEOD]PERSTR(1)<=
& EXTRACTION_START_DATE))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
              Elsif [HRLSTH]LVEACCOPT = 6 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
                Gosub WRITE_ACCRU
              Endif
            Else
              If [HRLSTH]LVEACCOPT = 5 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,1) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,1))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
                If LVE_GOK =1
                  Break 2
                  Return
                Endif
              Elsif [HRLSTH]LVEACCOPT = 6 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
                Gosub WRITE_ACCRU
                If LVE_GOK =1
                  Break 2
                  Return
                Endif
              Endif
            Endif
          Next
        Endif
      Next
      Filter [HRPEOD]
    Else
      If [HRLSTH]LVEACCOPT = 5
        If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
        Endif
      Else
        Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PEREND(1) <= TARGET_DATE)
      Endif

      Filter [ACCRCAL]
      Filter [ACCRCAL] Where [F:ACCRCAL]CTR = [F:HRCTR]CTRNUM and [F:ACCRCAL]CTRDAT=[L]CTR_DATE and [F:ACCRCAL]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:ACCRCAL]LVEACCTYP = "Accrual"
&                      Order By [F:ACCRCAL]LVEACCDAT
      Read [F:ACCRCAL] Last
      Filter [ACCRCAL]

      For I=1 To maxtab(CYCARR)
        If CYCARR(I-1,1) <> [0/0/0]
          For [HRPEOD]
            If [HRLSTH]LVEACCOPT = 5 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,1) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,1))
              If LVE_GCURLEG="BRI" and ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
                [F:HRACCR]LVEACCDAT=CYCARR(I-1,1)
              Else
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
              Endif
              If [F:ACCRCAL]LVEACCDAT<[F:HRACCR]LVEACCDAT
                Gosub WRITE_ACCRU
                If LVE_GOK =1
                  Break 2
                  Return
                Endif
              Endif
            Elsif [HRLSTH]LVEACCOPT = 6 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2))
              [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
              Gosub WRITE_ACCRU
              If LVE_GOK =1
                Break 2
                Return
              Endif
            Endif
          Next
        Endif
      Next
      Filter [HRPEOD]
    Endif
  Endif
    Filter [ACCRCAL]
    Filter [VEP2]
  Else
    If [HRLSTH]LVEACCOPT = 2
      Gosub CALC_EXTRACTION_ACCRUAL
    Endif
    If [HRLSTH]LVEACCOPT = 7
      Local Integer DAYSTOACCRU,E,I
      E=1
      I=1
      For E=1 To maxtab(LOOPDATE)
        If LOOPDATE(E-1,1) >= CYCARR(I-1,2) : I+=1 : Endif
        If CYCARR(I-1,1)=[0/0/0] : Break : Endif
        If LOOPDATE(E-1,1)>=CYCARR(I-1,1) and LOOPDATE(E-1,1)>[HRACCR]LVEACCDAT
          [F:HRACCR]LVEACCDAT=LOOPDATE(E-1,1)
          Gosub WRITE_ACCRU
          If LVE_GOK = 1
            Break
            Return
          Endif
        Endif
      Next
    Endif
  Endif
Return

$CALC_EXTRACTION_ACCRUAL
  If [HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 6
    If clalev ([ACCRCAL]) = 0 : Local File HRLVEACCRU [ACCRCAL] Endif
      If RCOUNTACCR=0
        If [HRLSTH]LVEACCOPT = 2
          If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
            Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD
          Else
            If [F:HRLSTH]LVEPRORAT=2
              Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
            Else
              Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
            Endif
          Endif
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) >= EXTRACTION_START_DATE and [F:HRPEOD]PEREND(1) <= TARGET_DATE)
        Endif

        For I=1 To maxtab(CYCARR)
          If CYCARR(I-1,1) <> [0/0/0]
            For [HRPEOD]
              If [F:HRLSTH]LVEPRORAT=2 and ACC_CHK=0
                If [HRLSTH]LVEACCOPT = 2 & ((CYCARR(I-1,1)<[F:HRPEOD]PEREND(1) & CYCARR(I-1,2)>[F:HRPEOD]PEREND(1)) & ([F:HRPEOD]PEREND(1)>=EXTRACTION_START_DATE & [F:HRPEOD]PERSTR(1)<=
& EXTRACTION_START_DATE))
                  [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                  Gosub WRITE_ACCRU
                Elsif [HRLSTH]LVEACCOPT = 2 & (([F:HRPEOD]PERSTR(1) <= CYCARR(I-1,1) & ([F:HRPEOD]PEREND(1)>=CYCARR(I-1,1)) & [F:HRPEOD]PEREND(1)>=EXTRACTION_START_DATE & [F:HRPEOD]PERSTR(1)<=
& EXTRACTION_START_DATE))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
              Elsif [HRLSTH]LVEACCOPT = 6 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
                Gosub WRITE_ACCRU
              Endif
            Else
              If [HRLSTH]LVEACCOPT = 2 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,1) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,1))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
                Gosub WRITE_ACCRU
                If LVE_GOK =1
                  Break 2
                  Return
                Endif
              Elsif [HRLSTH]LVEACCOPT = 6 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2))
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
                Gosub WRITE_ACCRU
                If LVE_GOK =1
                  Break 2
                  Return
                Endif
              Endif
            Endif
          Next
        Endif
      Next
      Filter [HRPEOD]
    Else
      If [HRLSTH]LVEACCOPT = 2
        If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD
        Else
          Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PERSTR(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PERSTR(1) <= TARGET_DATE)
        Endif
      Else
        Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD and ([F:HRPEOD]PEREND(1) > [F:HRACCR]LVEACCDAT and [F:HRPEOD]PEREND(1) <= TARGET_DATE)
      Endif
      Filter [ACCRCAL]
      Filter [ACCRCAL] Where [F:ACCRCAL]CTR = [F:HRCTR]CTRNUM and [F:ACCRCAL]CTRDAT=[F:HRCTR]CTRDAT and [F:ACCRCAL]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:ACCRCAL]LVEACCTYP = "Accrual"
&                      Order By [F:ACCRCAL]LVEACCDAT
      Read [F:ACCRCAL] Last
      Filter [ACCRCAL]
      For I=1 To maxtab(CYCARR)
        If CYCARR(I-1,1) <> [0/0/0]
          For [HRPEOD]
            If [HRLSTH]LVEACCOPT = 2 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,1) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,1))
              If LVE_GCURLEG="BRI" and ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
                [F:HRACCR]LVEACCDAT=CYCARR(I-1,1)
              Else
                [F:HRACCR]LVEACCDAT=[F:HRPEOD]PERSTR(1)
              Endif
              If [F:ACCRCAL]LVEACCDAT<[F:HRACCR]LVEACCDAT
                Gosub WRITE_ACCRU
                If LVE_GOK =1
                  Break 2
                  Return
                Endif
              Endif
            Elsif [HRLSTH]LVEACCOPT = 6 & ([F:HRPEOD]PERSTR(1)<=CYCARR(I-1,2) & [F:HRPEOD]PEREND(1)>=CYCARR(I-1,2))
              [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
              Gosub WRITE_ACCRU
              If LVE_GOK =1
                Break 2
                Return
              Endif
            Endif
          Next
        Endif
      Next
      Filter [HRPEOD]
    Endif
  Endif
  Filter [ACCRCAL]
Return

$CHECK_HRPEOD_END
  Local Integer C,GOTO_NO_ACCRUAL
  If clalev([F:HRPEODD])=0 : Local File HRPEODET   [HRPEODD] : Endif
  Filter [HRPEODD] Where [HRPEODD]PERCOD = [F:HRCTR]PERCOD
  Read [HRPEODD] Last

  For C=1 To dim(CYCARR)
    If CYCARR(C-1,2)=[0/0/0] : Break : Endif
    If CYCARR(C-1,2)>[HRPEODD]PEREND(1)
      If RF_IS_SOA
      Else
        If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
          Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " no accruals could be done for cycle ending" - num$(CYCARR(C-1,2)) - "as the cycle exceeds the extraction period "
& - num$([HRPEODD]PEREND(1)) - "on leave sub type" - [HRLSTH]COD,1) From GESECRAN
        Endif
      Endif
      Filter [HRPEODD]
      GOTO_NO_ACCRUAL=0
      Break
    Endif
  Next
  Filter [HRPEODD]
  If GOTO_NO_ACCRUAL
    Goto NOACCRUAL
  Endif
Return

$CHECK_HRPEOD_STR
  Local Integer C,GOTO_NO_ACCRUAL
  If clalev([F:HRPEODD])=0 : Local File HRPEODET [HRPEODD] : Endif
  Filter [HRPEODD] Where [HRPEODD]PERCOD = [F:HRCTR]PERCOD
  Read [HRPEODD] First
  Filter [HRPEODD]
  If VARDAT < [HRPEODD]PERSTR(1)
    If RF_IS_SOA
    Else
      If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
        Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " no accruals could be done as the cycle" - num$(VARDAT) - "starts before the extraction period" - num$([HRPEODD]
& PERSTR(1)) - "on leave sub type" - [HRLSTH]COD,1) From GESECRAN
    Endif
  Endif
    GOTO_NO_ACCRUAL=0
  Endif
  If GOTO_NO_ACCRUAL
    Goto NOACCRUAL
  Endif
Return

$GET_CYCLE_LENGTH
  Local Char ENTTYP(10)
  Local Integer CYCLENUNIT
  Local Decimal CYCLEN,PRO
  Local Integer DIV,DIVCYC
  Local Date CYCLESTARTDATECCL, CYCLEENDDATECCL

  If clalev([F:HRPEODD])=0 : Local File HRPEODET [HRPEODD] : Endif

  If [F:HRLSTH]ENTTYP = 2
    If ([HRLSTH]CYCLENU = 1)
      DIV = 12
    Else
      DIV = [HRLSTH]CYCLEN
    Endif
    If [HRLSTH]LVEACCOPT = 7
      If mod(year(CCYCLDAT),4) = 0
        DIV = 366
      Else
        DIV = 365
      Endif
    Endif
    If [HRLSTH]LVEACCOPT = 5 | [HRLSTH]LVEACCOPT = 6 | [HRLSTH]LVEACCOPT = 2
      DIV = 1
    Endif
  Endif
    For COUNTER = 0 To maxtab(CYCARR)
      If CYCARR(COUNTER, 1) <> [0/0/0] and [F:HRPEOD]PEREND(1) >= CYCARR(COUNTER, 1) and [F:HRPEOD]PEREND(1) < CYCARR(COUNTER, 2)
        CYCLESTARTDATECCL = CYCARR(COUNTER, 1)
        CYCLEENDDATECCL = CYCARR(COUNTER, 2)
        Break
      Endif
    Next

    If CARRYOVER=1
      If [HRLSTH]LVEPRORAT=2 and ACC_CHK=1 and [F:HRPEOD]PERSTR(1)<>CYCARR(I-1,1) and EXTRACTION_START_DATECL<>[F:HRPEOD]PERSTR(1) and EXTRACTION_START_DATECL<CYCLESTARTDATECCL
        Filter [HRPEODD] Where PERCOD = [F:HRCTR]PERCOD and [HRPEODD]PEREND(1)>=EXTRACTION_START_DATECL and [HRPEODD]PERSTR(1)<=EXTRACTION_END_DATECL
      Else
        Filter [HRPEODD] Where PERCOD = [F:HRCTR]PERCOD and [HRPEODD]PEREND(1)>=EXTRACTION_START_DATECL and [HRPEODD]PERSTR(1)<=EXTRACTION_END_DATECL
      Endif
    Else
      If [HRLSTH]LVEPRORAT=2 and ACC_CHK=1 and [F:HRPEOD]PERSTR(1)<>CYCARR(I-1,1) and EXTRACTION_START_DATECL<>[F:HRPEOD]PERSTR(1) and EXTRACTION_START_DATECL<CYCLESTARTDATECCL
        Filter [HRPEODD] Where PERCOD = [F:HRCTR]PERCOD and [HRPEODD]PEREND(1)>=EXTRACTION_START_DATECL and [HRPEODD]PERSTR(1)<=EXTRACTION_END_DATECL
      Else
        Filter [HRPEODD] Where PERCOD = [F:HRCTR]PERCOD and [HRPEODD]PEREND(1)>=CYCARR(I-1,1) and [HRPEODD]PERSTR(1)<=EXTRACTION_END_DATECL
    Endif
  Endif
  DIVCYC=rowcount([HRPEODD])
  Filter [HRPEODD]

  If DIVCYC<>0
    If ([HRLSTH]LVEACCOPT = 5 | [HRLSTH]LVEACCOPT = 6 | [HRLSTH]LVEACCOPT = 2)
      DIV=DIV
    Else
      DIV=DIVCYC
    Endif
  Endif
  If NRDAYSL <> 0 and CPRO=1
    PRO=NRDAYS/NRDAYSL
  Endif
Return

$GET_EXPIRY
  Local Date CURRDAT,CYCLESTARTDATECC,CYCLEENDDATECC
  Local Date EXPIRY
  Local Date EXPIRY2
  Local Date CARRYDATE,TESTDATE
  Local Integer CARRYOVER
  Local Integer CHKDD
  CARRYOVER=0
  ARRAYCHECK=1
  If COMPDAT<>GLMCYCLE
    CYCLESTARTDATECC=CONVDAT_STR
    CYCLEENDDATECC=CONVDAT_END
  Endif
  If clalev ([HRACCR2]) = 0 : Local File HRLVEACCRU [HRACCR2] : Endif
  Filter [HRACCR2]
  Filter [HRACCR2] Where [F:HRACCR2]CTR = [HRCTR]CTRNUM and [F:HRACCR2]CTRDAT=[HRCTR]CTRDAT and [F:HRACCR2]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:HRACCR2]LVEACCTYP = "Accrual" Order By [F:HRACCR2]
& LVEACCDAT
  Read [F:HRACCR2] Last
  If fstat=0
    EXPIRY2=[F:HRACCR2]LVEACCEXP
  Endif
  CURRDAT=CYCARR(I-1,2)

  If ([HRLSTH]LVEACCOPT = 2)
    If (CHECKD>=[F:ACCRCAL]LVEACCEXP & [F:ACCRCAL]LVEACCEXP=[F:HRACCR]LVEACCDAT & [F:ACCRCAL]LVEACCEXP<>[0/0/0])
      CARRYOVER=1
    Endif
  Endif
  If ([HRLSTH]LVEACCOPT = 7)  & (CURRDAT > EXPIRY2& EXPIRY2<>[0/0/0])
    CARRYOVER=1
  Endif
  If Z>0
    For F=0 To maxtab(FUTBALS)
      If (FUTBALS(F,4)="" or FUTBALS(F,4)=[0/0/0]) : Break : Endif
      Call CONVERT_TO_DATE(FUTBALS(F,4), TESTDATE) From SUBHRBAL
      Local Char LVSUB(250)
      LVSUB=[TIM]LVESUBTYP(S-1)
      If ([F:HRPEOD]PEREND(1)>=TESTDATE+1 and [F:HRPEOD]PERSTR(1)<=TESTDATE+1 and FUTBALS(F,2) = LVSUB)
        CARRYOVER=1
        ARRAYCHECK=1
      Endif
    Next
  Endif

  If ([F:HRPEOD]PEREND(1)>EXPIRY2 & EXPIRY2<>[0/0/0] & TESTDATE=[0/0/0] ) & [HRLSTH]LVEACCOPT <> 7
    CARRYOVER = 1
  Endif

  If ([HRLSTH]LVEACCOPT = 6)
    EXPIRY = CYCARR(I,2)
  Elsif ([HRLSTH]LVEACCOPT = 222222)
    Call GET_CYCLE_START_DATE([F:HRCTR]CTRNUM, [F:HRLSTH]COD, [F:HRACCR]LVEACCDAT, CYCLESTARTDATECC, CYCLEENDDATECC,RF_IS_SOA) From SUBHRBAL
    EXPIRY=CYCLEENDDATECC
  Else
    Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, [F:HRACCR]LVEACCDAT, CYCLESTARTDATECC, CYCLEENDDATECC,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL
    If EXTRACTION_END_DATE>CYCLEENDDATECC
      EXPIRY=EXTRACTION_END_DATE
    Else
      EXPIRY=CYCLEENDDATECC
    Endif
  Endif
  PREVCYCDAT=EXPIRY
  If CARRYOVER = 1 and [F:HRLSTH]LVECARSUB <> ""
    Gosub CARRY_OVER
    If LVE_GOK = 1
      Return
    Endif
    Gosub ACCRUDETAIL
  Else
    Gosub ACCRUDETAIL
  Endif
  Raz PREVCYCDAT
  Filter [HRACCR2]
Return

$CARRY_OVER
#read from DEMCONGE
#read from accruals done from date of cycle
  Local Decimal ACCRUALS
  Local Decimal LVETKN
  Local Decimal CAROVERAMT,ALLOWAMT,EXCESSAMT,PERCAMT
  Local Date EXPIRY1,CYCLESTARTDATE, CYCLEENDDATE,CYCLESTARTDATECO, CYCLEENDDATECO
  Local Integer EXCESSCHK,LVEOPT,G,CARRYALLCHK
  CARRYALLCHK=0

  If !clalev([F:DCGAC])   : Local File DEMCONGE [DCGAC]     : Endif
  If !clalev([F:ACCCARO]) : Local File HRLVEACCRU [ACCCARO] : Endif
  If !clalev([F:DCGSP])   : Local File DEMSPLITS [DCGSP]    : Endif

  Read [F:HRLSTH1]HRLST0 = [F:CPY]LEG;[F:HRLSTH]LVECARSUB
  Read [HRLSTH]HRLST0=LVE_GCURLEG;[TIM]LVESUBTYP(S-1)
  Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, EXPIRY, CYCLESTARTDATECO, CYCLEENDDATECO,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL
  If [L]NEED_TO_WRITE=1
    CURRDAT = [F:HRACCR2]LVEACCDAT
  Else
    CURRDAT = TESTDATE
  Endif
  CYCLEN = [F:HRLSTH1]CYCLEN
  ALLOWAMT= val([F:HRLSTH]LVECARFWD)
  If CYCLESTARTDATECO=[0/0/0]
    If [F:HRLSTH1]CYCLENU = 1
      CARRYDATE = addmonth(CURRDAT,CYCLEN*-12)
    Else
      CARRYDATE = addmonth(CURRDAT,-CYCLEN)
    Endif
  Endif
  If CYCLESTARTDATECO<>[0/0/0]
    If EXPIRY2 < CYCLESTARTDATECO
      Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, EXPIRY2, CYCLESTARTDATECO, CYCLEENDDATECO,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL
    Endif
    Filter [F:DCGAC] Where CTRNUM = [F:HRACCR]CTR and [F:DCGAC]TIM = [TIM]COD and ([F:DCGAC]ENDDAT >= CYCLESTARTDATECO and [F:DCGAC]STRDAT <= CYCLEENDDATECO and UID>0
&   and ([F:DCGAC]STA<>4 and [F:DCGAC]STA<>6))
  Else
    Filter [F:DCGAC] Where CTRNUM = [F:HRACCR]CTR and [F:DCGAC]TIM = [TIM]COD and ([F:DCGAC]STRDAT >= CARRYDATE and [F:DCGAC]STRDAT <= CURRDAT and UID>0
&   and ([F:DCGAC]STA<>4 and [F:DCGAC]STA<>6))
  Endif
  Filter [HRACCR2]
  If LINKED>1
    Filter [HRACCR2] Where CTR=[F:HRCTR]CTRNUM and [HRACCR2]CTRDAT=[F:HRCTR]CTRDAT and [F:HRACCR2]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:HRACCR2]LVEACCEXP = EXPIRY2 and [F:HRACCR2]LVEACCDAT>=COMPDAT
  Else
    Filter [HRACCR2] Where CTR = [F:HRCTR]CTRNUM and [HRACCR2]CTRDAT=[F:HRCTR]CTRDAT and [F:HRACCR2]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:HRACCR2]LVEACCEXP = EXPIRY2
  Endif
  For [HRACCR2]
    ACCRUALS += val([HRACCR2]LVEACCAMT)
  Next
  Filter [HRACCR2]
  Local Date ARRAYD_CAR
  For OL=1 To maxtab(CARFUTBALS)
    If CARFUTBALS(OL,1)="" : Break : Endif
    Call CONVERT_TO_DATE(CARFUTBALS(OL,3), ARRAYD_CAR) From SUBHRBAL
    If CYCLESTARTDATECO<>[0/0/0]
      If [F:HRLSTH]COD=CARFUTBALS(OL,2) and ARRAYD_CAR<CYCLESTARTDATECO
        ACCRUALS += val(CARFUTBALS(OL,5))
      Endif
    Else
      If [F:HRLSTH]COD=CARFUTBALS(OL,2) and ARRAYD_CAR=EXPIRY
        ACCRUALS += val(CARFUTBALS(OL,5))
      Endif
    Endif
  Next
  Local Date ARRAYD
  For K=0 To maxtab(FUTBALS)
    If FUTBALS(K,5)="" : Break : Endif
    Call CONVERT_TO_DATE(FUTBALS(K,4), ARRAYD) From SUBHRBAL
    If TESTDATE<>[0/0/0]
      If [F:HRLSTH]COD=FUTBALS(K,2) and ARRAYD=TESTDATE
        ACCRUALS += val(FUTBALS(K,5))
      Endif
    Else
      If [F:HRLSTH]COD=FUTBALS(K,2) and ARRAYD=EXPIRY
        ACCRUALS += val(FUTBALS(K,5))
      Endif
    Endif
  Next
  Local Char LVSUBCO(250)
  LVSUBCO=[TIM]LVESUBTYP(S-1)

  Local Date CYCLESTARTDATETKN,CYCLEENDDATETKN
  Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, [F:HRLSTH]COD, CYCLESTARTDATECO, CYCLESTARTDATETKN, CYCLEENDDATETKN,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL
  #PEVAN - 2018-10-10 - X3-111790 - START
  Filter [DCGAC]
  Link [DCGAC] With [DCGSP]DCGSP1=[DCGAC]UID As [SPLITS]
& Where [DCGAC]CTRNUM = [F:HRACCR]CTR and [F:DCGSP]LVESUBTYP = [F:TIM]LVESUBTYP(S-1) and [F:DCGSP]LVESUBBAL > 0
&   and ([DCGAC]STA = 1 | [DCGAC]STA = 2 | [DCGAC]STA = 3 or [DCGAC]STA = 5 or [DCGAC]STA = 7)
&   and ([F:DCGSP]LVEDAT >= CYCLESTARTDATETKN and [F:DCGSP]LVEDAT <= CYCLEENDDATETKN)

  Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
  For [SPLITS]
    LVETKN += [DCGSP]LVESUBBAL
  Next
  Columns [SPLITS]
  #PEVAN - 2018-10-10 - X3-111790 - END

#  If rowcount([F:DCGAC]) > 0
#    For G=1 To dim([F:DCGAC]LVESUBTYP)
#      For [F:DCGAC]
#        If ([F:DCGAC]ENDDAT >= CYCLESTARTDATECO and [F:DCGAC]ENDDAT <= CYCLEENDDATECO) and [F:DCGAC]LVESUBTYP(G-1)=[TIM]LVESUBTYP(S-1) ##Leave transaction only in current cycle
#          LVETKN = LVETKN + [F:DCGAC]LVESUBBAL(G-1) #[F:DCGAC]NBRDAY
#        Elsif ([F:DCGAC]STRDAT >= CYCLESTARTDATECO and [F:DCGAC]ENDDAT > CYCLEENDDATECO) and [F:DCGAC]LVESUBTYP(G-1)=[TIM]LVESUBTYP(S-1) ##Leave transaction going over cycle
#          Local Decimal NRDAYS,NRHOURS: NRDAYS=0: NRHOURS=0
#          Call VALORIS_L([F:DCGAC]STRDAT,CYCLEENDDATECO,[F:HRCTR]REFNUM,[TIM]COD,NRDAYS,NRHOURS,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,RF_IS_SOA,LVE_GCURLEG,LVE_MPYRDAT)
#          LVETKN += [F:DCGAC]LVESUBBAL(G-1) #NRDAYS
#        Endif
#      Next
#    Next
#  Endif
#  Filter [F:DCGAC]

  LVEOPT=[F:HRLSTH]LVEACCOPT
  CAROVERAMT=ACCRUALS-LVETKN
  If [HRLSTH]LVECARPRC=1
    PERCAMT=val([F:HRLSTH]LVECARFWD)/100
    ALLOWAMT= CAROVERAMT*PERCAMT
  Else
    ALLOWAMT= val([F:HRLSTH]LVECARFWD)
  Endif
  If CAROVERAMT>ALLOWAMT
    EXCESSAMT=CAROVERAMT-ALLOWAMT
    CAROVERAMT=ALLOWAMT
    If [HRLSTH]LVEEXSSUB<>""
      EXCESSCHK=1
      Gosub EXCESS_CARRY_OVER
      If LVE_GOK = 1
        Return
      Endif
    Endif
  Endif

  [F:HRACCR]LVEACCAMT=num$(CAROVERAMT)
  [F:HRACCR]LVEACCTYP = "Carry Over"
  Local Char MAINSUBTYPE(250): MAINSUBTYPE = [F:HRLSTH]COD
  Local Char CARRYSUBTYPE(250): CARRYSUBTYPE = [F:HRLSTH]LVECARSUB
  Read [F:HRLSTH]HRLST0 = LVE_GCURLEG;CARRYSUBTYPE
  If [F:HRLSTH]COD="" : CARRYSUBTYPE=MAINSUBTYPE : Endif
  LVEOPT=[F:HRLSTH]LVEACCOPT
  If LVEOPT<>2
    Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, CARRYSUBTYPE, [F:HRACCR]LVEACCDAT+1,CYCLESTARTDATE , CYCLEENDDATE,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL
  Else
    Call GET_CYCLE_START_DATE([F:HRCTR]CTRNUM, CARRYSUBTYPE, [F:HRACCR]LVEACCDAT,CYCLESTARTDATE , CYCLEENDDATE,RF_IS_SOA) From SUBHRBAL
  Endif
  Read [F:HRLSTH]HRLST0 = LVE_GCURLEG;MAINSUBTYPE
  If [F:HRLSTH]LVECARSUB <> "" and CAROVERAMT>=0
    [F:HRACCR]LVEACCLST = [F:HRLSTH]LVECARSUB
    [F:HRACCR]ACCFRM=[TIM]LVESUBTYP(S-1)
    Filter [F:ACCCARO]
    Filter [F:ACCCARO] Where [F:ACCCARO]CTR=[F:HRACCR]CTR and [F:ACCCARO]CTRDAT=[F:HRACCR]CTRDAT and [F:ACCCARO]LVEACCLST=[F:HRLSTH]LVECARSUB and [F:HRLSTH]CYCREC=1  and (CYCLEENDDATE<>[0/0/0] & [F:
& ACCCARO]LVEACCDAT<=CYCLESTARTDATE & [F:ACCCARO]LVEACCDAT<=CYCLEENDDATE) & [F:ACCCARO]LVEACCTYP="Carry Over"
    If rowcount([F:ACCCARO])<>0
      CARRYALLCHK=1
    Endif
    Filter [F:ACCCARO]
    If [F:HRLSTH]LVEACCOPT<>1
      [F:HRACCR]LVEACCEXP=CYCLEENDDATE
    Else
      [F:HRACCR]LVEACCEXP=CYCLEENDDATE
    Endif
  Else
    [F:HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1)
    [F:HRACCR]LVEACCEXP=CYCLEENDDATE#-1
    [F:HRACCR]ACCFRM=[TIM]LVESUBTYP(S-1)
  Endif
  If NEED_TO_WRITE=1 & (CARRYALLCHK=0)
    Local Char ACC(GLONVCR)
    [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([F:HRCTR]REFNUM)
    [F:HRACCR]LVEACCTRS = [L]ACC
    Write [F:HRACCR]
  Elsif (CARRYALLCHK=0)
    FUTBALS(Z,1)=[F:HRACCR]LVEACCTIM
    FUTBALS(Z,2)=[F:HRACCR]LVEACCLST
    FUTBALS(Z,3)=[F:HRACCR]LVEACCDAT#[L]ARRLVEACCDAT
    FUTBALS(Z,4)=[F:HRACCR]LVEACCEXP
    FUTBALS(Z,5)=[F:HRACCR]LVEACCAMT#num$(ARRAMT)
    Z+=1
  Endif
  If RF_IS_SOA
  Else
    If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
      Call ECR_TRACE("Employee  " - [HRCTR]REFNUM - "   Contract " - [HRCTR]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1) - " CARRY OVER",0) From GESECRAN
    Endif
  Endif
  TRACECOUNT+=1
Return

$EXCESS_CARRY_OVER
  Local Date EXPCARDATE,CYCLESTARTDATEECO,CYCLEENDDATEECO
  [F:HRACCR]LVEACCAMT=num$(EXCESSAMT)
  [F:HRACCR]LVEACCTYP = "Carry Over Excess"
  [F:HRACCR]LVEACCLST = [F:HRLSTH]LVEEXSSUB
  [F:HRACCR]ACCFRM=[TIM]LVESUBTYP(S-1)

  Local Char MAINSUBTYPE(250): MAINSUBTYPE = [F:HRLSTH]COD
  Local Char EXCESSSUBTYPE(250): EXCESSSUBTYPE = [F:HRLSTH]LVEEXSSUB
  Read [F:HRLSTH]HRLST0 = LVE_GCURLEG;EXCESSSUBTYPE
  If COMPDAT<>GLMCYCLE
    CYCLESTARTDATEECO=CONVDAT_STR
    CYCLEENDDATEECO=CONVDAT_END
  Endif
  Call GET_CYCLE_START_DATE_EXTRACTION([F:HRCTR]CTRNUM, EXCESSSUBTYPE, [F:HRACCR]LVEACCDAT, CYCLESTARTDATEECO, CYCLEENDDATEECO,RF_IS_SOA,LVE_GCURLEG) From SUBHRBAL
  Read [F:HRLSTH]HRLST0 = LVE_GCURLEG;MAINSUBTYPE
  [F:HRACCR]LVEACCEXP=CYCLEENDDATEECO
  If NEED_TO_WRITE=1
    Local Char ACC(GLONVCR)
    [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([F:HRCTR]REFNUM)
    [F:HRACCR]LVEACCTRS = [L]ACC
    Write [F:HRACCR]
  Else
    FUTBALS(Z,1)=[F:HRACCR]LVEACCTIM
    FUTBALS(Z,2)=[F:HRACCR]LVEACCLST
    FUTBALS(Z,3)=[F:HRACCR]LVEACCDAT
    FUTBALS(Z,4)=[F:HRACCR]LVEACCEXP
    FUTBALS(Z,5)=[F:HRACCR]LVEACCAMT
    Z+=1
  Endif
  If RF_IS_SOA
  Else
    If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
      Call ECR_TRACE("Employee  " - [HRCTR]REFNUM - "   Contract " - [HRCTR]CTRNUM - " Leave sub type " - [TIM]LVESUBTYP(S-1) - " EXCESS",0) From GESECRAN
    Endif
  Endif
  TRACECOUNT+=1
Return

$ACCRUDETAIL
  [F:HRACCR]LVEACCTYP="Accrual"
  [F:HRACCR]LVEACCEXP=EXPIRY
  [F:HRACCR]LVEACCLST=[TIM]LVESUBTYP(S-1)
Return

$ACCRUDETAIL_LINKING
  Local Char ACC(GLONVCR)
  [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([F:HRCTR]REFNUM)
  [F:HRACCR]LVEACCTRS = [L]ACC
  [F:HRACCR]LVEACCTYP="Linking"
  [F:HRACCR]LVEACCEXP=[01/01/1900]
  [F:HRACCR]LVEACCLST=[TIM]LVESUBTYP(S-1)
  [F:HRACCR]ACCPEREXP=[01/01/1900] #FRLAA 2018-08-21 X3-104072
  [F:HRACCR]ACCCYCSTR=[01/01/1900] #FRLAA 2018-08-21 X3-104072
  [F:HRACCR]ACCPERSTR=[01/01/1900] #FRLAA 2018-08-21 X3-104072
Return

$GET_TRANSNR
  If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
  Local Integer STAT
  Local Char    COMPTEUR(GLONANM)
  Local Char    ACC(GLONVCR)
  Local Integer READSTATUS,SEQ_ISMANUAL #FRLAA 2018-02-14 X3-74480

  If RF_IS_SOA
    Local Instance I_EMPLOID Using C_EMPLOID
    I_EMPLOID  = NewInstance C_EMPLOID AllocGroup null
    READSTATUS = fmet I_EMPLOID.AREAD([LNK]REFNUM)
    If READSTATUS <= [V]CST_AWARNING
#Set the company value from different LNK
      Local File FACILITY [FCY6]
      Read [FCY6]FCY0 = [LNK]ETRFCY
      If fstat = [V]CST_AOK
        If func TCA_TOOL.LECTCA(I_EMPLOID.ACTX, 15, [F:FCY6]LEGCPY, LVE_GCURLEG, 24, ACC, SEQ_ISMANUAL, LVE_ERRMESSAGE)=[V]CST_AFALSE
          LVE_GOK = 1 : End
        Endif
      Else
        LVE_ERRMESSAGE = mess(4,10702,1)-COMPTEUR
        LVE_GOK = 1 : End
      Endif
      LogicClose File [FCY6]
    Endif
    FreeGroup I_EMPLOID
  Else
    Read [TCA]TCA0 = 15 : # Module Human resources
    COMPTEUR = [F:TCA]CODNUM(24)
    Call NUMERO([L]COMPTEUR,[HRCTR]ETRFCY,CHECKD,[HRCTR]CTRNUM,[L]ACC,[L]STAT) From SUBANM
    If STAT
      LVE_ERRMESSAGE = mess(4,10702,1)-COMPTEUR
      LVE_GOK = 1 : End
    Endif
  Endif
Return

Subprog VALORIS_L(DATDEB,DATFIN,MATRI,CODE,JOUR,HEURE,SITE,CTR,VAL_IS_SOA,VAL_VGCURLEG,VALORIS_MPYRDAT)
Value Date VALORIS_MPYRDAT
Value Integer VAL_IS_SOA
Value Char VAL_VGCURLEG
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI ()
Value    Char    CODE ()
Variable Decimal JOUR
Variable Decimal HEURE
Value    Char    SITE ()
Value    Char    CTR()
Goto VALOR_L

$VALOR_L
  If VAL_IS_SOA
    Local Integer SOA_GOUVTABW            : Call GOUVTABW(SOA_GOUVTABW) From ESSGLOB_SOA
    Local Char    SOA_GTPSPARINITCP (10)  : Call GTPSPARINITCP(SOA_GTPSPARINITCP) From ESSGLOB_SOA
    Local Integer SOA_GTPSCREAGLOB        : Call GTPSCREAGLOB(SOA_GTPSCREAGLOB) From ESSGLOB_SOA
    Local Char    SOA_GTPSPARCPA(GLONTPS) : Call GTPSPARCPA(SOA_GTPSPARCPA) From ESSGLOB_SOA
    Local Char    SOA_GTPSPARCPE(GLONTPS) : Call GTPSPARCPE(SOA_GTPSPARCPE) From ESSGLOB_SOA
    Local Char    SOA_GPLANNING(30)       : Call GPLANNING(SOA_GPLANNING) From ESSGLOB_SOA

# These are from TRTTPS
    Local Char    SOA_GTABCLE(50)(1..10000)
    Local Decimal SOA_GTABJOUR(1..10000)
    Local Decimal SOA_GTABHEURE(1..10000)
    Local Integer SOA_GTABIND             : Call GTABIND(SOA_GTABIND) From ESSGLOB_SOA
    Local Char    SOA_GMATRI(50)          : Call GMATRI(SOA_GMATRI) From ESSGLOB_SOA
    Local Integer SOA_OPENED_TABLES
    Local Integer SOA_GFIRDAY
    If dim(SOA_GOUVTABW)<0 or (dim(SOA_GOUVTABW)>0 and SOA_GOUVTABW=0)
      If dim(SOA_GOUVTABW)>0
        SOA_GOUVTABW=1
      Endif
      Local Integer SOA_GTPS : Call GTPS(SOA_GTPS) From ESSGLOB_SOA
      If SOA_GTPS
        If clalev([F:PLE]) = 0 : Local File PLANEMP  [PLE] : Endif
      Endif
      Gosub VALORIS_L_ADD_DECLARE_GOUVTABW
    Endif
  Else
    If dim(GOUVTABW)<0 or (dim(GOUVTABW)>0 and GOUVTABW=0)                                                          # vérifie l'existence de la table */
      If dim(GOUVTABW)>0
        GOUVTABW=1
      Endif
      If GTPS
        If clalev([F:PLE])=0 : Local File PLANEMP   [PLE] : Endif
      Endif
      Gosub VALORIS_L_ADD_DECLARE_GOUVTABW
    Endif
  Endif

  Local Integer ANNEE , SEMAINE , ANNCUR , SEMCUR
  Local Char    SEMTYP(GLONSTY)
  Local Date    DAT , DEBUT , FIN
  Local Date    DEBCTR , FINCTR
  Local Char    PLNCUR(GLONPLN)
  Local Integer K , I, LTYPDAY, J
  Local Decimal WJOUR , WHEURE, LNBRHOU, LNBRDAY
  Local Decimal LNBRHOUFULL    ##101660
  Local Char    CPE(GLONTPS) , CPA(GLONTPS) , PARAM(10)
  Local Integer TPS_COMPLET , DIFF_COMPL , FERIE
  Local Integer OK
  Local Integer GLMSOA_GTPS
  Local Integer WOKPLE #104478
  Local Integer VKILL
  VKILL=0

  If VAL_IS_SOA
    If dim(SOA_GFERIE)<1    :   # This will always declare the variable now
      Local Integer SOA_GFERIE
      SOA_GFERIE=0 : VKILL=1
    Endif
  Else
    If dim(GFERIE)<1
      Global Integer GFERIE     :#0=non compté 1= compté
      GFERIE=0 : VKILL=1
    Endif
  Endif

  If dim(DJOUR)>0  : Raz DJOUR  : Endif
  If dim(DHEURE)>0 : Raz DHEURE : Endif

  If VAL_IS_SOA
    GLMSOA_GTPS = SOA_GTPS
  Else
    GLMSOA_GTPS = GTPS
  Endif
  If CODE=""
    If VAL_IS_SOA
      Local Char SOA_GTPSW(30) : Call GTPSW(SOA_GTPSW) From ESSGLOB_SOA
      Read [TIM]TIM0 = VAL_VGCURLEG; SOA_GTPSW
    Else
      Read [TIM]TIM0 = VAL_VGCURLEG; GTPSW
    Endif
  Elsif [F:TIM]COD<>CODE
    Read [TIM]TIM0 = VAL_VGCURLEG; [L]CODE
  Endif

  Local Integer VTYPDAY
  If dim(PTYPDAY)>0
    VTYPDAY=PTYPDAY
  Else
    VTYPDAY=[F:TIM]DAYTYP
  Endif

  If VAL_IS_SOA
    If dim(SOA_GTPSCREAGLOB) > 0
      PARAM=SOA_GTPSPARINITCP
      CPA=SOA_GTPSPARCPA
      CPE=SOA_GTPSPARCPE
    Else
      PARAM = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "INITCP")
      CPA = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "CPA")
      CPE = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "CPE")
    Endif
  Else
    If dim(GTPSCREAGLOB) > 0
      PARAM=GTPSPARINITCP
      CPA=GTPSPARCPA
      CPE=GTPSPARCPE
    Else
      Call PARAM("","INITCP",PARAM) From ADOVAL
      Call PARAM("","CPA",CPA) From ADOVAL
      Call PARAM("","CPE",CPE) From ADOVAL
    Endif
  Endif

  DIFF_COMPL = (val(PARAM)=2)
  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATFIN
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If fstat<=2
    If VAL_IS_SOA
      TPS_COMPLET = ([F:HRCTR]TYPJOB=1)
    Else
      If dim([M]PYRDAT)>0 Then
        TPS_COMPLET = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[M]PYRDAT,"TYPJOB","HRCTR"))=1)
      Else
        TPS_COMPLET = ([F:HRCTR]TYPJOB=1)
      Endif
    Endif
  Else
    TPS_COMPLET = 1
  Endif
  If VAL_IS_SOA
    Read [FCY]FCY0 = [F:HRCTR]ETRFCY
  Else
    If dim([M]PYRDAT)>0 Then
      Call LECTURE("FCY",func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR"),"") From CONTOBJ
    Else
      Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
    Endif
    If [F:AD]REFNUM<>MATRI
      Read [AD]AD0 = MATRI
    Endif
  Endif

  DAT = DATDEB

  If VAL_IS_SOA
    Local Libelle SOA_GFIRDAY
    Call SET_GFIRDAY([F:HRCTR]PERCOD, SOA_GFIRDAY) From SUBPLN_SOA
  Else
    Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
  Endif

  If VAL_IS_SOA
    Call DAT(DATDEB,ANNEE,SEMAINE,CTR,MATRI) From SUBPLN_SOA
  Else
    Call DAT(DATDEB,ANNEE,SEMAINE) From SUBPLN
  Endif

  If GLMSOA_GTPS
    Read [PLE]PLE0=MATRI;DATDEB;CTR
    If fstat
      Gosub SETSEM #From SUBPLN
      If SEMTYP="" : SEMTYP="WORK" : Endif
    Endif
  Else
    Gosub SETSEM #From SUBPLN
    If SEMTYP="" : SEMTYP="WORK" : Endif
  Endif
  ANNCUR = ANNEE
  SEMCUR = SEMAINE
  Read [HLY]HLY0 = ANNEE;SITE;VAL_VGCURLEG
  If fstat
    Read [HLY]HLY0 = ANNEE;"";VAL_VGCURLEG
  Endif
  If year(DATDEB)<>ANNEE
    Read [HLY]HLY0 = year(DATDEB);SITE;VAL_VGCURLEG
    If fstat
      Read [HLY]HLY0 = year(DATDEB);"";VAL_VGCURLEG
    Endif
  Endif
  If VAL_IS_SOA
  Else
    GPOINT = "AV_VALOR" : Gosub ENTREE From EXEFNC
    If OK : End : Endif
  Endif

  Raz JOUR,HEURE
  For I=1 To (DATFIN-DATDEB)+1
    Raz LNBRHOU, LNBRDAY
    Raz LNBRHOUFULL    ##101660
    If VAL_IS_SOA
      Call DAT(DAT,ANNEE,SEMAINE,CTR,MATRI) From SUBPLN_SOA
    Else
      Call DAT(DAT,ANNEE,SEMAINE) From SUBPLN
    Endif
    If GLMSOA_GTPS
      Read [PLE]PLE0 = MATRI;DAT;CTR
    Endif
    Raz WOKPLE #104478
    If GLMSOA_GTPS & !fstat
      LNBRHOU = [F:PLE]NBRHOU
      LNBRDAY = [F:PLE]NBRDAY
      LTYPDAY = [F:PLE]TYPDAY
      WOKPLE=1 #104478
    Else
      If SEMAINE<>SEMCUR or ANNEE<>ANNCUR or DAT>FINCTR
        Gosub SETSEM #From SUBPLN
        If SEMTYP="" : SEMTYP="WORK" : Endif
        ANNCUR = ANNEE
        SEMCUR = SEMAINE
      Endif
      K = DAT-DEBUT
      LNBRHOU = [F:WTY]NBRHRS1(K)
      LNBRDAY = [F:WTY]NBRDAY1(K)
      LTYPDAY = [F:WTY]TYPDAY(K)
    Endif
    LNBRHOUFULL=LNBRHOU     ##101660
    If dim([L]AM)>0 & [L]AM=1
      LNBRDAY = LNBRDAY/2
      LNBRHOU = LNBRHOU/2    ##101660
    Endif
    If ANNEE<>[F:HLY]YEA
      Read [HLY]HLY0 = ANNEE;SITE;VAL_VGCURLEG
      If fstat
        Read [HLY]HLY0 = ANNEE;"";VAL_VGCURLEG
      Endif
    Endif
    If year(DAT)<>ANNEE
      Read [HLY]HLY0 = year(DAT);SITE;VAL_VGCURLEG
      If fstat
        Read [HLY]HLY0 = year(DAT);"";VAL_VGCURLEG
      Endif
    Endif

    FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
    Raz WJOUR,WHEURE

    If dim(VPHI) > 0
      If VPHI = 1
        FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
      Else
        Raz FERIE
      Endif
    Endif

    Case [F:TIM]COD
      When CPE
        If !FERIE & LTYPDAY=2
          If !TPS_COMPLET or DIFF_COMPL=1
            WJOUR  = 1
            WHEURE = LNBRHOUFULL   ##101660
            If (dim([L]AM)>0 & [L]AM=1) & DIFF_COMPL=1
              WJOUR  = LNBRDAY
              WHEURE = LNBRHOU      ##101660
            Endif
          Else
            If LTYPDAY=2 : # ouvré
              WJOUR  = LNBRDAY
              WHEURE = LNBRHOU
            Endif
          Endif
        Endif
      When CPA
        If !FERIE & LTYPDAY<=2 : # ouvrable ou ouvré
          If !TPS_COMPLET or DIFF_COMPL=1
            WJOUR  = 1
            WHEURE = LNBRHOUFULL    ##101660
            If (dim([L]AM)>0 & [L]AM=1) & DIFF_COMPL=1
              WJOUR  = LNBRDAY
              WHEURE = LNBRHOU       ##101660
            Endif
          Else
            WJOUR  = LNBRDAY
            WHEURE = LNBRHOU
          Endif
        Endif
      When Default
        Case VTYPDAY
          When 1 : # Jours ouvrables
            If VAL_IS_SOA #FRLAA 2018-02-13 X3-74480 - START
              If (!FERIE | SOA_GFERIE) or CODE="" or WOKPLE
                If LTYPDAY<=2 : # Ouvrable ou ouvrés
                  WJOUR  = LNBRDAY
                  WHEURE = LNBRHOU
                Endif
              Endif
            Else
              If (!FERIE | GFERIE) or CODE="" or WOKPLE
                If LTYPDAY<=2 : # Ouvrable ou ouvrés
                  WJOUR  = LNBRDAY
                  WHEURE = LNBRHOU
                Endif
              Endif
            Endif
          When 2 : # Jours ouvrés
            If VAL_IS_SOA #FRLAA 2018-02-13 X3-74480 - START
              If (!FERIE | SOA_GFERIE) or CODE="" or WOKPLE
                If LTYPDAY=2 : # Ouvrable ou ouvrés
                  WJOUR  = LNBRDAY
                  WHEURE = LNBRHOU
                Endif
              Endif
            Else
              If (!FERIE | GFERIE) or CODE="" or WOKPLE
                If LTYPDAY=2 : # Ouvrable ou ouvrés
                  WJOUR  = LNBRDAY
                  WHEURE = LNBRHOU
                Endif
              Endif
            Endif
          When 3 : # Calendaires
            WJOUR = 1
            If VAL_IS_SOA #FRLAA 2018-02-13 X3-74480 - START
              If (!FERIE | SOA_GFERIE) or CODE="" or WOKPLE
                If LTYPDAY<=2 : # Ouvrable ou ouvrés
                  WJOUR  = LNBRDAY
                  WHEURE = LNBRHOU
                Endif
              Endif
            Else
              If (!FERIE | GFERIE) or CODE="" or WOKPLE
                If LTYPDAY<=2 : # Ouvrable ou ouvrés
                  WHEURE = LNBRHOU
                Endif
              Endif
            Endif
          Endcase
        Endcase
    If dim(DJOUR)>0  : DJOUR(I)  = WJOUR  : Endif
    If dim(DHEURE)>0 : DHEURE(I) = WHEURE : Endif
      JOUR  += WJOUR
      HEURE += WHEURE
      DAT += 1
    Next I
#Point d'entrée AP_VALOR

  If VAL_IS_SOA
#NO entry points on SOA here
  Else
    GPOINT = "AP_VALOR" : Gosub ENTREE From EXEFNC
  Endif

  If VAL_IS_SOA
    If dim(PTYPDAY)>0
     If dim(SOA_GTABCLE)>0
        If SOA_GMATRI<>MATRI
           SOA_GMATRI=MATRI
           SOA_GTABIND=1
           Raz SOA_GTABCLE,SOA_GTABJOUR,SOA_GTABHEURE
        Endif
        If SOA_GMATRI=MATRI
           Local Char CLETABLE(50)
           If dim(SOA_GFERIE)<0
            CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)
           Else
            CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)+num$(SOA_GFERIE)
           Endif
           SOA_GTABCLE(SOA_GTABIND)=CLETABLE
           SOA_GTABJOUR(SOA_GTABIND)=JOUR
           SOA_GTABHEURE(SOA_GTABIND)=HEURE
           SOA_GTABIND+=1
        Endif
     Endif
    Endif
  Else
    If dim(PTYPDAY)>0
      If dim(GTABCLE)>0     # vérifie l'existence de la table */
        If [V]GMATRI<>MATRI          # SI MATRICULE DIFFÉRENT */
          [V]GMATRI=MATRI           # RÉINITIALISER LE CACHE TABLEAU */
          [V]GTABIND=1
          Raz [V]GTABCLE,[V]GTABJOUR,[V]GTABHEURE
        Endif
        If [V]GMATRI=MATRI # si matricule courant */
          Local Char CLETABLE(50)
          If dim(GFERIE)<0
            CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)  # calcul cle */
          Else
            CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)+num$(GFERIE)  # calcul cle */
          Endif
          [V]GTABCLE([V]GTABIND)=CLETABLE  # stocker la cle */
          [V]GTABJOUR([V]GTABIND)=JOUR     # stocker la valeur JOUR */
          [V]GTABHEURE([V]GTABIND)=HEURE   # stocker la valeur HEURE */
          [V]GTABIND+=1
        Endif
      Endif
    Endif
  Endif

  If dim(SOA_GFERIE)>=0 & VKILL
    Kill SOA_GFERIE
  Endif

  If VAL_IS_SOA
    If dim(SOA_GFERIE)>=0 & VKILL
      Kill SOA_GFERIE
    Endif
  Else
    If dim(GFERIE)>=0 & VKILL
      Kill GFERIE
    Endif
  Endif
End

$SETSEM
  If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
# FQ82073 - Si CTR2 est déjà utilisé et renseigné dans un autre traitement, il faut le sauvegarder
  If [F:HRCTR2]CTRNUM<>"" Then
    Local Char SCTRNUM(250) : SCTRNUM=[F:HRCTR2]CTRNUM
    Local Char SREFNUM(250) : SREFNUM=[F:HRCTR2]REFNUM
    Local Date SCTRDAT : SCTRDAT=[F:HRCTR2]CTRDAT
  Endif
# Fin FQ82073
  SEMTYP="WORK"

  If VAL_IS_SOA
#Dont do anything the global variable GTPSMAT could not be found
  Else
    If dim(GTPSMAT) > 0
      If [F:HRCTR]REFNUM=[V]GTPSMAT & [L]CTR=[V]GTPSCTR & [F:HRCTR]CTRDAT=[V]GTPSCTRDAT & [L]DAT=[V]GTPSDAT & [L]ANNEE=[V]GTPSANNCUR & [L]SEMAINE=[V]GTPSSEMCUR & [F:WTY]COD=[V]GTPSSEMTYP
        [L]FINCTR = [V]GTPSFINCTR
        [L]PLNCUR = [V]GTPSPLNCUR
        [L]DEBUT  = [V]GTPSDEBUT
        [L]FIN    = [V]GTPSFIN
        [L]SEMTYP = [V]GTPSSEMTYP
        Return
      Endif
    Endif
  Endif
# Recherche dans planning type du salarié
  If PLNCUR="" or [F:HRCTR]REFNUM<>MATRI or DEBCTR<>[F:HRCTR]CTRDAT or DAT>FINCTR
# FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
    Filter [HRCTR2] Where REFNUM=[L]MATRI & CTRNUM=[L]CTR
# Fin FQ85820
    Read [HRCTR2]CTR1 Last
    Filter [HRCTR2]
# FQ85820 - On cherche si on a une fiche de rétroactivité relative aux champs ETRFCY et ETRSRV
    If VAL_IS_SOA
      PLNCUR = [F:HRCTR2]PLNTYP
    Else
      If dim([M]PYRDAT)>0 Then
        PLNCUR = func SUBCTRRET.FIND_RETRO_FLD([L]MATRI,[L]CTR,[F:HRCTR2]CTRDAT,VALORIS_MPYRDAT,"PLNTYP","HRCTR2")
      Else
        PLNCUR = [F:HRCTR2]PLNTYP
      Endif
    Endif

    If DAT<[F:HRCTR2]CTRDAT
      DEBCTR=DAT
    Else
      DEBCTR = [F:HRCTR2]CTRDAT
    Endif
 # FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
    Filter [HRCTR2] Where REFNUM=[L]MATRI & CTRNUM=CTR
    Read [HRCTR2]CTR1 First
    Filter [HRCTR2]
    If fstat>2
      FINCTR = [31/12/2999]
    Else
      FINCTR = [F:HRCTR2]CTRDAT-1
    Endif
  Endif

  If VAL_IS_SOA
    If PLNCUR="" : PLNCUR = SOA_GPLANNING : Endif
  Else
    If PLNCUR="" : PLNCUR = GPLANNING : Endif
  Endif

  If PLNCUR="" : Return : Endif
  If [F:PLN]COD<>PLNCUR or [F:PLN]YEA<>ANNEE
    Read [PLN]PLN0 = ANNEE;PLNCUR;VAL_VGCURLEG
  Else
    fstat = 0
  Endif
  If !fstat
    SEMTYP = [F:PLN]WEKTYP(SEMAINE-1)
  Endif

  If SEMTYP="" : Return : Endif

  If [F:WTY]COD<>SEMTYP
    Read [WTY]WTY0 = VAL_VGCURLEG;SEMTYP
  Endif
  If VAL_IS_SOA
    Call SEMAINE(ANNEE,SEMAINE,DEBUT,FIN,CTR,MATRI) From SUBPLN_SOA
  Else
    Call SEMAINE(ANNEE,SEMAINE,DEBUT,FIN) From SUBPLN
  Endif

  If VAL_IS_SOA
    #Dont do anything the global variable GTPSMAT could not be found
  Else
    If dim(GTPSMAT) > 0
      [V]GTPSMAT    =[F:HRCTR]REFNUM
      [V]GTPSCTR    =[L]CTR
      [V]GTPSCTRDAT =[L]DEBCTR
      [V]GTPSFINCTR =[L]FINCTR
      [V]GTPSDAT    =[L]DAT
      [V]GTPSANNCUR =[L]ANNEE
      [V]GTPSSEMCUR =[L]SEMAINE
      [V]GTPSSEMTYP =[F:WTY]COD
      [V]GTPSPLNCUR =[L]PLNCUR
      [V]GTPSDEBUT  =[L]DEBUT
      [V]GTPSFIN    =[L]FIN
    Endif
  Endif
# FQ82073 - Si CTR2 est déjà utilisé et renseigné dans un autre traitement, il faut le sauvegarder
  If dim(SCTRNUM)>0 Then
    Read [F:HRCTR2]CTR0=SREFNUM;SCTRNUM;SCTRDAT
  Endif
Return

#FRLAA X3-86960 - 2018-04-25 - START - Optimization
#**
#* Link the accrual tables, the parameters used is to declare the calling funcion with INTFUNC
#* @param P_NATEVT Value Char, Nature of event
#* @param P_LVESUB Value Char, Leave subtype
#* @param P_POP Value Char, Population
#* @param P_CTRNUM Value Char, Contract number
#* @param P_CTRDAT Value Date, Contract date
#* @param INTFUNC Value Integer, Function #1=Nature of event,2=Subtype,3=Population,4=Contract
#*!
Subprog LINKING_ACCRUALS_PROG(P_NATEVT, P_LVESUB,P_POP,P_CTRNUM,P_CTRDAT,INTFUNC,UPDATE_SUBTYPES)
Value Char P_NATEVT, P_LVESUB,P_POP,P_CTRNUM
Value Date P_CTRDAT
Value Integer INTFUNC
Value Integer UPDATE_SUBTYPES
Local Char CRITCTR (250)
Local Char CRITTIM (250)
Local Char CRITLVESUB (250)
Local Char CRITPOP (250)

  CRITTIM = "1=1"
  CRITLVESUB = "1=1"
  CRITCTR = "1=1"
  CRITPOP = "1=1"


  Case INTFUNC
    When 1    : CRITTIM     += " and [TIM]COD ='"+P_NATEVT+"'"
    When 2    : CRITLVESUB  += " and [TIM]LVESUBTYP(S-1) ='"+P_LVESUB+"'"
    When 3    : CRITPOP     = " [F:HRPOA]COD ='"+P_POP+"'"
    When 4    : CRITCTR    = " [F:HRCTR]CTRNUM ='"+P_CTRNUM+"' and [F:HRCTR]CTRDAT=["+num$(P_CTRDAT)+"]"
  Endcase
  Gosub LINKING_ACCRUALS
End
#FRLAA X3-86960 - 2018-04-25 - END - Optimization

$LINKING_ACCRUALS
  Local Integer RF_IS_SOA
  If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
  If clalev([F:VEP2])=0   : Local File VALEMP     [VEP2]  : Endif
  If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
  If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
  If clalev([TIM]) = 0      : Local File TIMCOD [TIM] Endif
  If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
  If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
  If clalev ([HRACCR]) = 0   : Local File HRLVEACCRU [HRACCR] Endif
  If clalev ([HRCLV]) = 0   : Local File HRCLLCVT [HRCLV] Endif
  If clalev ([SRV]) = 0   : Local File SERVICE [SRV] Endif
  If clalev ([PRF]) = 0   : Local File PROFIL [PRF] Endif
  If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
  Local Integer S(1)
  Local Char CRITACC1(250),CRITACCCHK1(250),CRITACC2(250),CRITACCCHK2(250),CRITACC3(250),CRITACCCHK3(250)
  Local Integer CRITCOUNT
  Local Integer CRFCHK

  Filter [TIM] Where ([TIM]CATTIM=3 |[TIM]CATTIM=2)  and [TIM]ENAFLG=2 and evalue(CRITTIM)
  For [TIM]
    For S=1 To dim([TIM]LVESUBTYP)
      CRITACC1 = "1=0"
      CRITACC2 = "1=0"
      CRITACC3 = "1=0"
      If [TIM]LVESUBTYP(S-1) <> "" and evalue(CRITLVESUB)
        CRITCOUNT=1
        For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG = [TIM]LEG
          If len(CRITACC1)>=200 : CRITCOUNT=2 : If len(CRITACC2)>=200 : CRITCOUNT=3 : Endif : Endif
          If CRITCOUNT=1
            Case [HRLSTD]LEV
              When 1  : CRITACC1 = CRITACC1 - " | 1=1"  #Folder
              When 2  : CRITACC1 = CRITACC1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC1 = CRITACC1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC1 = CRITACC1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC1 = CRITACC1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC1 = CRITACC1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC1 = CRITACC1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC1 = CRITACC1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC1 = CRITACC1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC1 = CRITACC1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
          Elsif CRITCOUNT=2
            Case [HRLSTD]LEV
              When 1  : CRITACC2 = CRITACC2 - " | 1=1"  #Folder
              When 2  : CRITACC2 = CRITACC2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC2 = CRITACC2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC2 = CRITACC2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC2 = CRITACC2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC2 = CRITACC2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC2 = CRITACC2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC2 = CRITACC2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC2 = CRITACC2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC2 = CRITACC2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
          Else
            Case [HRLSTD]LEV
              When 1  : CRITACC3 = CRITACC3 - " | 1=1"  #Folder
              When 2  : CRITACC3 = CRITACC3 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC3 = CRITACC3 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC3 = CRITACC3 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC3 = CRITACC3 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC3 = CRITACC3 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC3 = CRITACC3 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC3 = CRITACC3 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC3 = CRITACC3 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC3 = CRITACC3 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
          Endif
        Next
        If [HRLSTD]LEV=3
          Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&          As [LNK]
&          Where (evalue(CRITACC1) or evalue(CRITACC2) or evalue(CRITACC3)) and evalue(CRITPOP) and evalue(CRITCTR) #FRLAA X3-86960 - 2018-04-25
        Else
          Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF
& As [LNK]
&          Where  (evalue(CRITACC1) or evalue(CRITACC2) or evalue(CRITACC3)) and evalue(CRITCTR) #FRLAA X3-86960 - 2018-04-25
        Endif

        For [LNK]
          Local Date CHECKD
          Local Integer MDIFF,FOUND
          CRITCOUNT   = 1
          CRITACCCHK1 = "1=0"
          CRITACCCHK2 = "1=0"
          CRITACCCHK3 = "1=0"
          For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG = [TIM]LEG
            If len(CRITACCCHK1)>=200 : CRITCOUNT=2 : If len(CRITACCCHK2)>=200 : CRITCOUNT=3 : Endif : Endif
            If CRITCOUNT = 1
              Case [HRLSTD]LEV
                When 1  : CRITACCCHK1 = CRITACCCHK1 - " | 1=0"  #Folder
                When 2  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                When 3  : CRITACCCHK1 = CRITACCCHK1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                When 4  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                When 5  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                When 6  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                When 7  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                When 8  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                When 9  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                When 10 : CRITACCCHK1 = CRITACCCHK1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
              Endcase
            Elsif CRITCOUNT = 2
              Case [HRLSTD]LEV
                When 1  : CRITACCCHK2 = CRITACCCHK2 - " | 1=0"  #Folder
                When 2  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                When 3  : CRITACCCHK2 = CRITACCCHK2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                When 4  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                When 5  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                When 6  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                When 7  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                When 8  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                When 9  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                When 10 : CRITACCCHK2 = CRITACCCHK2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
              Endcase
            Else
              Case [HRLSTD]LEV
                When 1  : CRITACCCHK3 = CRITACCCHK3 - " | 1=0"  #Folder
                When 2  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                When 3  : CRITACCCHK3 = CRITACCCHK3 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                When 4  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                When 5  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                When 6  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                When 7  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                When 8  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                When 9  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                When 10 : CRITACCCHK3 = CRITACCCHK3 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
              Endcase
            Endif
          Next

          If [HRLSTD]LEV=3
            Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&          As [LNK2]
&          Where (evalue(CRITACCCHK1) or evalue(CRITACCCHK2) or evalue(CRITACCCHK3)) and evalue(CRITPOP) and evalue(CRITCTR) and [F:FCY]LEG=[F:HRLSTD]LEG #PEVAN - X3-111882 - 2018-10-08
#&          Where (evalue(CRITACCCHK1) or evalue(CRITACCCHK2) or evalue(CRITACCCHK3)) and evalue(CRITPOP) and evalue(CRITCTR) #FRLAA X3-86960 - 2018-04-25
          Else
            Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF
& As [LNK2]
&          Where (evalue(CRITACCCHK1) or evalue(CRITACCCHK2) or evalue(CRITACCCHK3)) and evalue(CRITCTR) and [F:FCY]LEG=[F:HRLSTD]LEG #PEVAN - X3-111882 - 2018-10-08
#&          Where (evalue(CRITACCCHK1) or evalue(CRITACCCHK2) or evalue(CRITACCCHK3)) and evalue(CRITCTR) #FRLAA X3-86960 - 2018-04-25
          Endif
          Filter [LNK2] Where CTRNUM = [LNK]CTRNUM
          Read [LNK2] Last
          Filter [LNK2]

          If fstat>0
            Goto MANUAL_L
          Endif

          If [LNK2]XITFNL = 2 | [LNK2]FLGRET = 2 | [LNK2]FLGVAR = 2
            Goto MANUAL_L
          Endif

          Gosub WRITE_ACCRU_LINK

          : MANUAL_L
        Next
      Endif
    Next
  Next
  Filter [TIM]
Return

$VALORIS_L_ADD_DECLARE_GOUVTABW
  If clalev([F:PLN])=0 : Local File PLANTYP   [PLN] : Endif
  If clalev([F:WTY])=0 : Local File TYPWEEK   [WTY] : Endif
  If clalev([F:HLY])=0 : Local File HLYDAY    [HLY] : Endif
  If clalev([F:TIM])=0 : Local File TIMCOD    [TIM] : Endif
  If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
  If clalev([F:AD])=0  : Local File EMPLOAD   [AD]  : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR  [HRCTR] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
  If clalev([F:HRCTR2]) =0 : Local File EMPLOCTR [HRCTR2] : Endif
Return

Funprog GETFIRSTHRPEOD(PDATANC)
  Value Date PDATANC
  Local Date DATANCA,PPDATE
  If clalev([F:HRPPD])=0 : Local File HRPEODET   [HRPPD] : Endif

  Filter [HRPPD] Where PERCOD = [F:HRCTR]PERCOD and [F:HRPPD]PERSTR(1)<=PDATANC and [F:HRPPD]PEREND(1)>=PDATANC
  Read [HRPPD] First
  DATANCA=[HRPPD]PERSTR(1)
  Filter [HRPPD]
End DATANCA

$SUBACCRUAL_TRTLVEACC
  Local Char SUBTYPES(GLONHRLST)(0..,0..9)
  Local Date CONVDAT_STR,CONVDAT_END,COMPDAT
  Local Integer ACCSUT,LINKED
  If NEVENT<>""
    Filter [TIM] Where ([TIM]CATTIM=3 |[TIM]CATTIM=2)  and [TIM]ENAFLG=2 and [TIM]COD=NEVENT
  Else
    Filter [TIM] Where ([TIM]CATTIM=3 |[TIM]CATTIM=2)  and [TIM]ENAFLG=2
  Endif
  ARRNEXT=0
  For [TIM]
    DIMTIM=dim([TIM]LVESUBTYP)
    CRITLTA="[HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG ="-[TIM]LEG
    For S=1 To DIMTIM
      CRITACC1 = "1=0"
      CRITACC2 = "1=0"
      CRITACC3 = "1=0"
      If [TIM]LVESUBTYP(S-1) <> "" | LVESUBTYPE<>""
        If CRITHRLST=""
          CRITCOUNT=1
          For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG = [TIM]LEG
            If len(CRITACC1)>=200 : CRITCOUNT=2 : If len(CRITACC2)>=200 : CRITCOUNT=3 : Endif : Endif
              If CRITCOUNT=1
                Case [HRLSTD]LEV
                  When 1  : CRITACC1 = CRITACC1 - " | 1=0"  #Folder
                  When 2  : CRITACC1 = CRITACC1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                  When 3  : CRITACC1 = CRITACC1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                  When 4  : CRITACC1 = CRITACC1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                  When 5  : CRITACC1 = CRITACC1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                  When 6  : CRITACC1 = CRITACC1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                  When 7  : CRITACC1 = CRITACC1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                  When 8  : CRITACC1 = CRITACC1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                  When 9  : CRITACC1 = CRITACC1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                  When 10 : CRITACC1 = CRITACC1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                Endcase
              Elsif CRITCOUNT=2
                Case [HRLSTD]LEV
                  When 1  : CRITACC2 = CRITACC2 - " | 1=0"  #Folder
                  When 2  : CRITACC2 = CRITACC2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                  When 3  : CRITACC2 = CRITACC2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                  When 4  : CRITACC2 = CRITACC2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                  When 5  : CRITACC2 = CRITACC2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                  When 6  : CRITACC2 = CRITACC2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                  When 7  : CRITACC2 = CRITACC2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                  When 8  : CRITACC2 = CRITACC2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                  When 9  : CRITACC2 = CRITACC2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                  When 10 : CRITACC2 = CRITACC2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                Endcase
              Else
                Case [HRLSTD]LEV
                  When 1  : CRITACC3 = CRITACC3 - " | 1=0"  #Folder
                  When 2  : CRITACC3 = CRITACC3 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                  When 3  : CRITACC3 = CRITACC3 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                  When 4  : CRITACC3 = CRITACC3 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                  When 5  : CRITACC3 = CRITACC3 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                  When 6  : CRITACC3 = CRITACC3 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                  When 7  : CRITACC3 = CRITACC3 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                  When 8  : CRITACC3 = CRITACC3 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                  When 9  : CRITACC3 = CRITACC3 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                  When 10 : CRITACC3 = CRITACC3 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                Endcase
              Endif
            Next
          Else
            CRITACC1=CRITHRLST
          Endif
          Filter [HRCTR]
          If [HRLSTD]LEV=3
            Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&           As [LNK]
&           Where evalue(CRITACC1) or evalue(CRITACC2) or evalue(CRITACC3)
          Else
            Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [SRV]SRV0=[F:HRCTR]ETRSRV,
&             [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&             [PRF]PRF0=[F:HRCTR]PROPRF
&           As [LNK]
&           Where evalue(CRITACC1) or evalue(CRITACC2) or evalue(CRITACC3)
          Endif

          For [LNK]
            Local Date CHECKD
            Local Integer MDIFF,FOUND
            CRITCOUNT   = 1
            CRITACCCHK1 = "1=0"
            CRITACCCHK2 = "1=0"
            CRITACCCHK3 = "1=0"
            For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1) and [HRLSTD]LEG = [TIM]LEG
              If len(CRITACCCHK1)>=200 : CRITCOUNT=2 : If len(CRITACCCHK2)>=200 : CRITCOUNT=3 : Endif : Endif
              If CRITCOUNT = 1
                Case [HRLSTD]LEV
                  When 1  : CRITACCCHK1 = CRITACCCHK1 - " | 1=0"  #Folder
                  When 2  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                  When 3  : CRITACCCHK1 = CRITACCCHK1 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                  When 4  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                  When 5  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                  When 6  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                  When 7  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                  When 8  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                  When 9  : CRITACCCHK1 = CRITACCCHK1 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                  When 10 : CRITACCCHK1 = CRITACCCHK1 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                Endcase
              Elsif CRITCOUNT = 2
                Case [HRLSTD]LEV
                  When 1  : CRITACCCHK2 = CRITACCCHK2 - " | 1=0"  #Folder
                  When 2  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                  When 3  : CRITACCCHK2 = CRITACCCHK2 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                  When 4  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                  When 5  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                  When 6  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                  When 7  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                  When 8  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                  When 9  : CRITACCCHK2 = CRITACCCHK2 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                  When 10 : CRITACCCHK2 = CRITACCCHK2 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                Endcase
              Else
                Case [HRLSTD]LEV
                  When 1  : CRITACCCHK3 = CRITACCCHK3 - " | 1=0"  #Folder
                  When 2  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
                  When 3  : CRITACCCHK3 = CRITACCCHK3 - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
                  When 4  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
                  When 5  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
                  When 6  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
                  When 7  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
                  When 8  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
                  When 9  : CRITACCCHK3 = CRITACCCHK3 - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
                  When 10 : CRITACCCHK3 = CRITACCCHK3 - " | ([F:PRF]PRFCOD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
                Endcase
              Endif
            Next
            If [HRLSTD]LEV=3
              Link [HRCTR] With
&               [ID]ID0=[F:HRCTR]REFNUM,
&               [FCY]FCY0=[F:HRCTR]ETRFCY,
&               [CPY]CPY0=[F:FCY]LEGCPY,
&               [SRV]SRV0=[F:HRCTR]ETRSRV,
&               [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&               [PRF]PRF0=[F:HRCTR]PROPRF,
&               [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&             As [LNK2]
&             Where evalue(CRITACCCHK1) or evalue(CRITACCCHK2) or evalue(CRITACCCHK3)
            Else
              Link [HRCTR] With
&               [ID]ID0=[F:HRCTR]REFNUM,
&               [FCY]FCY0=[F:HRCTR]ETRFCY,
&               [CPY]CPY0=[F:FCY]LEGCPY,
&               [SRV]SRV0=[F:HRCTR]ETRSRV,
&               [HRCLV]HRCLV0=[F:HRCTR]CLLCVT,
&               [PRF]PRF0=[F:HRCTR]PROPRF
&             As [LNK2]
&             Where evalue(CRITACCCHK1) or evalue(CRITACCCHK2) or evalue(CRITACCCHK3)
            Endif

            Filter [LNK2] Where REFNUM= [LNK]REFNUM and CTRNUM = [LNK]CTRNUM and CTRDAT=[LNK]CTRDAT Order By CTRDAT
              Read [LNK2] Last
            Filter [LNK2]
            If fstat>0
              Goto NOACCRUAL
            Endif

            Local Char ACC_CTRNUM(GLONHRCTR)
            Local Date ACC_CTRDAT
            [L]ACC_CTRNUM = [LNK2]CTRNUM
            [L]ACC_CTRDAT = [LNK2]CTRDAT

            Local Char SUBTYPES(GLONHRLST)(0..,0..9)
            Call GET_LEAVE_SUB_TYPES([LNK2]CTRNUM, [LNK2]CTRDAT,[TIM]COD, SUBTYPES) From SUBHRBAL
            Filter [HRCTR] Where [HRCTR]CTRNUM=[LNK2]CTRNUM and [HRCTR]CTRDAT=[LNK2]CTRDAT
            Read [HRCTR] Last
            Filter [HRCTR]
            Local Char CTRNUMBER(GLONHRCTR) : CTRNUMBER = [F:HRCTR]CTRNUM
            Local Date CTR_DATE             : CTR_DATE = [F:HRCTR]CTRDAT

            For ACCSUT=0 To maxtab(SUBTYPES)

              If SUBTYPES(ACCSUT,1)=[TIM]LVESUBTYP(S-1) and SUBTYPES(ACCSUT,4)=[HRCTR]CTRDAT
                Call CONVERT_TO_DATE(SUBTYPES(ACCSUT,4), CONVDAT_STR) From SUBHRBAL
                Call CONVERT_TO_DATE(SUBTYPES(ACCSUT,5), CONVDAT_END) From SUBHRBAL
                Call GET_LEAVE_SUB_TYPE_STR_DATE([LNK2]CTRNUM,CONVDAT_STR,[TIM]LVESUBTYP(S-1),COMPDAT,LINKED) From SUBHRBAL
                LVE_GCURLEG = [F:FCY]LEG
                If RF_IS_SOA
                  GLMCYCLESTR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 5, LVE_GCURLEG, "GLMCYCLE")
                Else
                  GCURLEG=[F:FCY]LEG
                  GLMCYCLE = func SUBHRBAL.GET_GLM_CYCLE([LNK2]CTRNUM,[LNK2]CTRDAT)
                Endif
                Read [F:HRLSTH]HRLST0 = [F:FCY]LEG;[TIM]LVESUBTYP(S-1)#[F:HRLSTH]LVECARSUB
                If [HRLSTH]LVEACCOPT <> 1
                  Filter [HRACCR] Where [F:HRACCR]CTR = [LNK2]CTRNUM  and [F:HRACCR]CTRDAT=[LNK2]CTRDAT and [F:HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1) and [F:HRACCR]LVEACCTYP = "Accrual" Order By [
&                 HRACCR]LVEACCDAT #and [F:HRACCR]LVEACCTYP =
                  Read [HRACCR] Last
                  RCOUNTACCR=rowcount([HRACCR])
                  Local Date VARDAT
                  If parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>10 & parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>0
                    If COMPDAT<>GLMCYCLE
                      VARDAT = CONVDAT_STR
                    Else
                      VARDAT = GLMCYCLE
                    Endif
                  Else
                    If evalue([F:HRLSTH]CYCSTRCAL)<GLMCYCLE and ([HRLSTH]LVEACCOPT <> 5 & [HRLSTH]LVEACCOPT <> 6)
                      If COMPDAT<>GLMCYCLE
                        VARDAT = CONVDAT_STR
                      Else
                        VARDAT = GLMCYCLE
                      Endif
                    Else
                      VARDAT = evalue([F:HRLSTH]CYCSTRCAL)
                    Endif
                  Endif
                  If ([HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 7)
                    CHECKD = datesyst
                    If [HRLSTH]LVEACCOPT = 2
                      If parse(evalue([F:HRLSTH]LVEACCCAL), 0) <> 10 & parse(evalue([F:HRLSTH]LVEACCCAL), 0) <> 0
                        ACCDAT = GLMCYCLE
                      Else
                        If evalue([F:HRLSTH]LVEACCCAL) < GLMCYCLE
                          ACCDAT=GLMCYCLE
                        Else
                          ACCDAT = evalue([F:HRLSTH]LVEACCCAL)
                        Endif
                      Endif
                    Endif
                    If [HRLSTH]LVEACCOPT = 7
                      If evalue([F:HRLSTH]CYCSTRCAL)<GLMCYCLE
                        ACCDAT = GLMCYCLE
                      Else
                        ACCDAT = evalue([F:HRLSTH]CYCSTRCAL)
                      Endif
                    Endif

                    Gosub EXTRACTION_ACCRUAL
                  Endif
                  If ([HRLSTH]LVEACCOPT = 3 | [HRLSTH]LVEACCOPT = 5) #Start of period/cycle
                    Filter [VEP2] Where CTRNUM = [LNK2]CTRNUM and CTRDAT=[LNK2]CTRDAT Order By [F:VEP2]ENDDAT
                    Read [VEP2] Last
                    CHECKD=[F:VEP2]ENDDAT
                    Filter [VEP2]
                    Gosub EXTRACTION_ACCRUAL
                    If LVE_GOK = 1
                      End
                    Endif
                  Endif
                  If ([HRLSTH]LVEACCOPT = 4 | [HRLSTH]LVEACCOPT = 6) #End of Period/CYCLE
                    Filter [VEP2] Where CTRNUM = [LNK2]CTRNUM  and CTRDAT=[LNK2]CTRDAT and [F:VEP2]STA=3
                    Read [VEP2] Last
                    CHECKD=[F:VEP2]ENDDAT
                    Gosub EXTRACTION_ACCRUAL
                    If LVE_GOK = 1
                      End
                    Endif
                    Filter [VEP2]
                  Endif
                Else
                  Filter [VEP2] Where CTRNUM = [LNK2]CTRNUM and CTRDAT=[LNK2]CTRDAT Order By [F:VEP2]ENDDAT
                  Read [VEP2] Last
                  CHECKD=[F:VEP2]ENDDAT
                  Filter [VEP2]
                  If ([HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 7)
                    If [LNK]XITDAT<>[0/0/0]
                      CHECKD = datesyst
                    Else
                      CHECKD = [LNK]XITDAT
                    Endif
                  Endif
                  Filter [HRACCR] Where [F:HRACCR]CTR = [LNK2]CTRNUM and CTRDAT=[LNK2]CTRDAT  and [F:HRACCR]LVEACCLST = [TIM]LVESUBTYP(S-1) Order By [HRACCR]LVEACCDAT
                  For [HRACCR]
                    Filter [HRPEOD] Where PERCOD = [F:VEP2]PERCOD and (CHECKD<=[F:HRACCR]LVEACCEXP and CHECKD >= [F:HRACCR]LVEACCEXP)
                    For [HRPEOD]
                      [F:HRACCR]LVEACCDAT=[F:HRPEOD]PEREND(1)
                      If LVE_GOK = 1
                        End
                      Endif
                    Next
                    Filter [HRPEOD]
                  Next
                  Filter [HRACCR]
                Endif
                Filter [HRLSTH]
              Endif
            Next
          : NOACCRUAL
          Next
        Endif
      Next
    Next

    Filter [TIM]
    If TRACECOUNT=0
    If RF_IS_SOA
    Else
      If GFONCTION <> "GESDCG" and GFONCTION <> "GESHRLAF" and GFONCTION <> "CONSLTA" and GFONCTION <> "SAIWRKMAN"
        Call ECR_TRACE("Employee  " - [LNK]REFNUM - "   Contract " - [LNK]CTRNUM - " no accruals could be done for this time period",0) From GESECRAN
      Endif
    Endif
  Endif
Return

$SUBACCRUAL_CONTRACT
  Local Char SUBTYPES(GLONHRLST)(0..,0..9)
  Local Date CONVDAT_STR,CONVDAT_END,COMPDAT
  Local Integer S,LINKED
  Call GET_LEAVE_SUB_TYPES(CTRNUMBER, FILTERDATE,NEVENT, SUBTYPES) From SUBHRBAL

  For STYP=0 To maxtab(SUBTYPES)
    If (LVESUBTYPE<>"" and SUBTYPES(STYP,1)=LVESUBTYPE) | GFONCTION="GESDCG"
      Call CONVERT_TO_DATE(SUBTYPES(STYP,4), CONVDAT_STR) From SUBHRBAL
      Call CONVERT_TO_DATE(SUBTYPES(STYP,5), CONVDAT_END) From SUBHRBAL
      Call GET_LEAVE_SUB_TYPE_STR_DATE(CTRNUMBER,FILTERDATE,SUBTYPES(STYP,1),COMPDAT,LINKED) From SUBHRBAL
      Filter [F:HRCTR] Where [F:HRCTR]CTRNUM=CTRNUMBER and [F:HRCTR]CTRDAT=CONVDAT_STR
      Read [HRCTR] Last
      Filter [F:HRCTR]
      Local Integer SUBTYPEINCL
      LVE_GCURLEG = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,1)
      Read [F:HRLSTH]HRLST0 = LVE_GCURLEG;SUBTYPES(STYP,1)
      If !fstat
        If evalue([F:HRLSTH]CYCSTRCAL)<=FILTERDATE
          [L]SUBTYPEINCL = 1
        Endif
      Endif

      If [L]SUBTYPEINCL = 1 Then
        Local Char ACC_CTRNUM(GLONHRCTR)
        Local Date ACC_CTRDAT
        [L]ACC_CTRNUM = [F:HRCTR]CTRNUM
        [L]ACC_CTRDAT = [F:HRCTR]CTRDAT
        Local Char CTRNUMBER(GLONHRCTR) : CTRNUMBER = [F:HRCTR]CTRNUM
        Local Date CTR_DATE             : CTR_DATE = [F:HRCTR]CTRDAT
        LVE_GCURLEG = func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,1)
        Read [TIM]TIM0=LVE_GCURLEG;SUBTYPES(STYP,3)
        S=val(SUBTYPES(STYP,2))
        Filter [VEP2]
        If RF_IS_SOA
          GLMCYCLESTR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 5, LVE_GCURLEG, "GLMCYCLE")
        Else
          GCURLEG=func DIVPAYE_SOA.GET_LEG_CTR([HRCTR]REFNUM,[HRCTR]CTRNUM,[HRCTR]CTRDAT,1)
          GLMCYCLE = func SUBHRBAL.GET_GLM_CYCLE([F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT)
        Endif
        Read [F:HRLSTH]HRLST0 = LVE_GCURLEG;SUBTYPES(STYP,1)
        If [HRLSTH]LVEACCOPT <> 1
          Filter [HRACCR] Where [F:HRACCR]CTR = CTRNUMBER and [F:HRACCR]CTRDAT = [L]CTR_DATE and [F:HRACCR]LVEACCLST = SUBTYPES(STYP,1) and [F:HRACCR]LVEACCTYP = "Accrual" and [F:HRACCR]LVEACCDAT>=
&         COMPDAT Order By [HRACCR]LVEACCDAT
          Read [HRACCR] Last
          RCOUNTACCR=rowcount([HRACCR])
          Local Date VARDAT
          If parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>10 & parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>0
            If COMPDAT<>GLMCYCLE
              VARDAT=COMPDAT
            Else
              VARDAT = GLMCYCLE
            Endif
          Else
            If evalue([F:HRLSTH]CYCSTRCAL)<GLMCYCLE and ([HRLSTH]LVEACCOPT <> 5 & [HRLSTH]LVEACCOPT <> 6)
              If COMPDAT<>GLMCYCLE
                VARDAT=COMPDAT
              Else
                VARDAT=GLMCYCLE
              Endif
            Else
              VARDAT = evalue([F:HRLSTH]CYCSTRCAL)
            Endif
          Endif
          If ([HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 7)
            CHECKD=FILTERDATE
            If [HRLSTH]LVEACCOPT = 2
              If parse(evalue([F:HRLSTH]LVEACCCAL), 0) <> 10 & parse(evalue([F:HRLSTH]LVEACCCAL), 0) <> 0
                If COMPDAT<>GLMCYCLE
                  ACCDAT=COMPDAT
                Else
                  ACCDAT = GLMCYCLE
                Endif
              Else
                If evalue([F:HRLSTH]LVEACCCAL) < GLMCYCLE
                  If COMPDAT<>GLMCYCLE
                    ACCDAT=COMPDAT
                  Else
                    ACCDAT = GLMCYCLE
                  Endif
                Else
                  ACCDAT = evalue([F:HRLSTH]LVEACCCAL)
                Endif
              Endif
            Endif
            If [HRLSTH]LVEACCOPT = 7
              If evalue([F:HRLSTH]CYCSTRCAL)<GLMCYCLE
                ACCDAT = GLMCYCLE
              Else
                ACCDAT = evalue([F:HRLSTH]CYCSTRCAL)
              Endif
            Endif
            Gosub EXTRACTION_ACCRUAL
          Endif
          If ([HRLSTH]LVEACCOPT = 3 | [HRLSTH]LVEACCOPT = 5) #Start of period/cycle
            Filter [VEP2] Where CTRNUM = [F:HRCTR]CTRNUM and CTRDAT=[F:HRCTR]CTRDAT Order By [F:VEP2]ENDDAT
            Read [VEP2] Last
            CHECKD=[F:VEP2]ENDDAT
            Filter [VEP2]
            Gosub EXTRACTION_ACCRUAL
            If LVE_GOK = 1
              End
            Endif
          Endif
          If ([HRLSTH]LVEACCOPT = 4 | [HRLSTH]LVEACCOPT = 6) #End of Period/CYCLE
            Filter [VEP2] Where CTRNUM = [F:HRCTR]CTRNUM and CTRDAT=[F:HRCTR]CTRDAT and [F:VEP2]STA=3 Order By [F:VEP2]ENDDAT
            Read [VEP2] Last
            CHECKD=[F:VEP2]ENDDAT
            Gosub EXTRACTION_ACCRUAL
            If LVE_GOK = 1
              End
            Endif
            Filter [VEP2]
          Endif
        Else
          Filter [VEP2] Where CTRNUM = [F:HRCTR]CTRNUM and CTRDAT=[F:HRCTR]CTRDAT Order By [F:VEP2]ENDDAT
          Read [VEP2] Last
          CHECKD=[F:VEP2]ENDDAT
          Filter [VEP2]
          If ([HRLSTH]LVEACCOPT = 2 | [HRLSTH]LVEACCOPT = 7)
            CHECKD = datesyst
          Endif
          Filter [HRACCR] Where [F:HRACCR]CTR = CTRNUMBER and [F:HRACCR]CTRDAT = [L]CTR_DATE and [F:HRACCR]LVEACCLST = SUBTYPES(STYP,1) Order By [HRACCR]LVEACCDAT
          For [HRACCR]
            Filter [HRPEOD] Where PERCOD = [F:VEP2]PERCOD and (CHECKD<=[F:HRACCR]LVEACCEXP and CHECKD >= [F:HRACCR]LVEACCEXP)
            For [HRPEOD]
              If LVE_GOK = 1
                End
              Endif
            Next
            Filter [HRPEOD]
          Next
          Filter [HRACCR]
        Endif

      Endif #FRLAA X3-101914 2018-09-04
    Endif
  Next
  Filter [HRLSTH]
Return

