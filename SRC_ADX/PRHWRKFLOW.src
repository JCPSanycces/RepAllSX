Subprog PRHSUIWRK(AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
&                ,AXWHRANDOR,AXORDCOD,AXORDTYP
&                ,REFNUM,DATENV,CODEVT,TEXSUI,ETAPE,CHRONO)

Value    Char     AXPARCOD()()
Variable Char    AXPARVAL()()
Value Integer AXWHRLFTBRK()
Value Char    AXWHRCOD()()
Value Integer AXWHROPE()
Value Char    AXWHRCODVAL()()
Value Integer AXWHRRGTBRK()
Value Integer AXWHRANDOR()
Value Char    AXORDCOD()()
Value Integer AXORDTYP()
Variable Date    DATENV(0..)
Variable Char    REFNUM()(0..), CODEVT()(0..), TEXSUI()(0..), ETAPE()(0..), CHRONO()(0..)
Local  Char    EMETTEUR(0)(0..dim(REFNUM)-1)
Local    Char    MAT(30)
Local    Char EVT(30)
Local    Date    DEB, FIN
Local    Integer ETAT
MAT="toto"


Local Integer IRES
Local Char SRES
IRES=find("MAT",AXPARCOD)
MAT=""
If IRES
    MAT=AXPARVAL(IRES-1)
Endif

IRES=find("EVT",AXPARCOD)
EVT=""
If IRES
    EVT=AXPARVAL(IRES-1)
Endif

IRES=find("DEB",AXPARCOD)
DEB=[0/0/0]
If IRES
    DEB=func PRHUTIFCTPRH.CONVMYDATE(AXPARVAL(IRES-1))
Endif

IRES=find("FIN",AXPARCOD)
FIN=[0/0/0]
If IRES
    DEB=func PRHUTIFCTPRH.CONVMYDATE(AXPARVAL(IRES-1))
Endif

IRES=find("ETAT",AXPARCOD)
ETAT=0
If IRES
    ETAT=val(AXPARVAL(IRES-1))
Endif




# MAT=GETBYCODBYVAL("MAT",AXPARCOD,AXPARVAL ,-1)
# EVT=GETBYCODBYVAL("EVT",AXPARCOD,AXPARVAL,type(EVT))
# DEB=GETBYCODBYVAL("DEB",AXPARCOD,AXPARVAL,type(DEB))
# FIN=GETBYCODBYVAL("FIN",AXPARCOD,AXPARVAL,type(FIN))
# ETAT=GETBYCODBYVAL("ETAT",AXPARCOD,AXPARVAL,type(ETAT))

Call FLUX(MAT,DEB,FIN,EVT,ETAT,EMETTEUR,REFNUM,DATENV,CODEVT,TEXSUI,ETAPE,CHRONO) From PORSUP

End

Funprog GETBYCODBYVAL(STRSEARCH,BYCODE,BYVAL,TYPEVAR)
Value Char STRSEARCH()
Value Char BYCODE()()
Value Char BYVAL()()
Value Integer TYPEVAR
Local Integer IRES
Local Char SRES
Infbox "0"
IRES=find(STRSEARCH,BYCODE)
SRES=""
Infbox num$(IRES)
If IRES
    SRES=BYVAL(IRES-1)
Endif

 If(TYPEVAR>-1)Then
      Case TYPEVAR
         When 2,4,5,6,7,9:
             If SRES="" Then End 0 Else End val(SRES) Endif
         When 3 :    
             If SRES="" Then End [0/0/0] Else End func PRHUTIFCTPRH.CONVMYDATE(SRES) Endif
         When Default
 Endcase

 Endif
End SRES
