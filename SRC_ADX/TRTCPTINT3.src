 Infbox func  GET_ACCCOD_BUY("SIEMENS")
End
 If !clalev([F:CPT]) : Local File EFASAFFAGE [CPT] : Endif
 Read [F:CPT]EVE0="IGLE0100051";"20081202385051461"
 If !fstat
  Infbox "Evénement de transfert analytique comptabilisable :"-mess(func TRTCPTINT3.EVT_TRF_DIE_PST,1,1)
 Endif
