#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:47 513


############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using R_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub AVARIABLES From WMR00BSIIMPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

If fmet BSIIMPTC.ACTX.AGETAFCRIGHT(BSIIMPTC,"BSIIMPORT",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto ADELETE_END : Endif
If fmet BSIIMPTC.ACTX.AGETAFCRIGHTD(BSIIMPTC,"BSIIMPORT",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR : Goto ADELETE_END
Endif

Gosub AREPCONTROL_ADELETE
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_BSIIMPTC
Else
 Gosub ADELETE_BSIIMPTC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_END : Return : Endif

$ADELETE_END
End

#-----------------------------------------------------#
$AREPCONTROL_ADELETE
BSIIMPTC.ASTALIN = [V]CST_ADEL
BSIIMPTC.BSITC.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(BSIIMPTC.BSITC,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If BSIIMPTC.BSITC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
BSIIMPTC.BSITC.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(BSIIMPTC.BSITC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.BSITC.LINES(A_N2) <> null
& and BSIIMPTC.BSITC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If BSIIMPTC.BSITC.LINES(A_N2).ASTALIN<>[V]CST_ANEW
   BSIIMPTC.BSITC.LINES(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.LINES(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
For A_N2=1 To maxtab(BSIIMPTC.BSITC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.BSITC.LINES(A_N2) <> null
& and BSIIMPTC.BSITC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.LINES(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_BSIIMPTC
Trbegin [F:BSITC]
 Gosub ADELETE_BSIIMPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
$_ADELETE_AFTER
Return

#-----------------------------------------------------#
$ADELETE_BSIIMPTC
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC._ADELETE)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If BSIIMPTC.snapshotEnabled=1
 [L]A_RETIK = BSIIMPTC.revertUpdTick
Endif
[L]ASTATUS = max(fmet BSIIMPTC.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#



