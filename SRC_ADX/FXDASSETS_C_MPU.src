#**
#* =================================================================================
#* FXDASSETS_C_MPU : Fixed assets public methods
#* =================================================================================
#* You will find hereunder a full desciption of PHYELT pubilc methods, operations or functions.
#*     - Get the value of any property of a fixed asset (GET_PROPERTIES_VALUE)
#* #* _______________________________________________________________________________
#*
#*!

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
        When Default
      Endcase
    When Default
  Endcase
Return

$OPERATIONS
  Case [L]CURPTH
    When ""
      Case [L]AOPERATION
        When "GET_PROPERTIES_VALUE"   : Gosub GET_PROPERTIES_VALUE  :   # Oper   : Get some fixed assets properties values
        When "GET_ENABLED_OPE"        : Gosub GET_ENABLED_OPE       :   # Method :
        When Default
      Endcase
    When Default
  Endcase
Return

# ======================================================================
#    P U B L I C     M E T H O D S
# ======================================================================


# ======================================================================
#    P U B L I C     O P E R A T I O N S
# ======================================================================

#**
#* Operation:
#* Get the value of some properties of a fixed asset
#*    1- Read the fixed asset reference
#*    2- Get the value of PROPERTIES (char array) into VALUES (char array)
#*
#* Input parameters
#* @param AASREF     Fixed asset reference
#* @param PROPERTIES Name of each property (char array)
#* Output parameters
#* @return VALUES    Value of each property (char array)
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#* @return            : Error message stack
#*
#*!
$GET_PROPERTIES_VALUE

  [L]ARET_VALUE  = [V]CST_AOK

  # Parameters control
  Local Shortint NB_PRO : NB_PRO = dim([L]PROPERTIES)
  If not ( [L]NB_PRO > 0 )
    [L]ERRMSG = func ASYRFNC.MES2(mess(60, [V]CST_MSGMIS, 1), "PROPERTIES", "GET_PROPERTIES_VALUE")
    [L]ARET_VALUE = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    Raz [L]VALUES
    Return
  Endif

  # Read fixed assets reference
  If fmet this.AREAD(AASREF) <> [V]CST_AOK
    # Reading error on table FXDASSETS
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(76,127,1)+" FXDASSETS ("+AASREF+")", [V]CST_AERROR)
    Return
  Endif
  # Get the value of each property into VALUES
  Local Shortint PRO
  For [L]PRO = 1 To [L]NB_PRO
    Case evalue("type(this."+PROPERTIES([L]PRO)+")")
      When 1, 2, 4, 5, 6, 7, 9
        VALUES([L]PRO) = evalue("num$(this."+PROPERTIES([L]PRO)+")")
      When 3
        VALUES([L]PRO) = format$("D:DDMMYYYY","this."+PROPERTIES([L]PRO))
      When Default
        VALUES([L]PRO) = evalue("this."+PROPERTIES([L]PRO))
    Endcase
  Next

Return

#**
#* Get the of status of the ENAFLG property
#*
#* @param (AASREF Asset reference)
#* @param RENABLED Status value of ENAFLG property (CST_AYES, CST_ANO)
#* @param RMESSAGE Error message if error
#* @return CST_AOK if asset was found, CST_AERROR otherwise
#*!
$GET_ENABLED_OPE

  Local Integer STA

  [L]ARET_VALUE = [V]CST_AOK
  RMESSAGE = AVOID.ACHAR

  Local File FXDASSETS [FAS]
  Read [FAS]FAS0=AASREF
  If fstat = [V]CST_AOK
    RENABLED = [F:FAS]ENAFAS
  Else
    RENABLED = [V]CST_ANO
    # Error message is put to receive parameter and to error stack
    RMESSAGE = "[FAS]" - mess(76,127,1) + " ("+AASREF+")"
    [L]ARET_VALUE = fmet this.ASETERROR("", RMESSAGE, [V]CST_AERROR)
  Endif
  LogicClose File [FAS]

Return

