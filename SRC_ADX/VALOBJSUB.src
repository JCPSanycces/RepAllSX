#<AdxTL>@(#)10.0.0.0 $Revision$
#---------------------------------------------------------------------------------------------------#
# Sous_programmes
#---------------------------------------------------------------------------------------------------#

$WRGRISE
If CLEGEO="" : # X3 classique
 Wrseq CLEPRIM;
 For I=0 To dim(CLESEC)-1
  If CLESEC(I)<>"" & (AOB_GES<>3 | I<>NBCLE-2) 
   Wrseq ","+CLESEC(I);
  Endif
 Next I
 Wrseq
Else : # GH Geode
 K=0
 If !find(CLEPRIM,CLEFCY,CLEDEP)
  Wrseq CLEPRIM; : K = 1
 Endif
 For I=0 To dim(CLESEC)-1
  If CLESEC(I)<>"" & (AOB_GES<>3 | I<>NBCLE-2) & !find(CLESEC(I),CLEFCY,CLEDEP)
   If K : Wrseq ","+CLESEC(I); 
   Else : Wrseq CLESEC(I); : K = 1
   Endif
  Endif
 Next I
 If K : Wrseq : Endif
Endif
Return

#---------------------------------------------------------------------------------------------------#
# Link utilisé dans la sélection
#---------------------------------------------------------------------------------------------------#

$WRLINK
J = 0
If FLDTXT<>"" and OKTXT=0
 Wrseq space$(SPA);"If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif"
 OKTXT = 1
Endif
If AOB_FLDACC<>"" and OKACC=0
 Wrseq space$(SPA);"If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif"
 OKACC = 1
Endif
If AOB_FLDFCY<>"" and OKFCY=0
 Wrseq space$(SPA);"If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif"
 OKFCY = 1
Endif
If AOB_FLDGRF<>"" and OKGRF=0
 Wrseq space$(SPA);"If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif"
 OKGRF = 1
Endif
If AOB_FLDGRC<>"" and OKGRC=0
 Wrseq space$(SPA);"If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif"
 OKGRC = 1
Endif
For I=1 To AOB_NBFIC
 If AOB_EXPLNK(I)<>"" & AOB_OBLLNK(I)
  Wrseq space$(SPA);"If clalev([F:"+AOB_ABRLNK(I)+"])=0 ";
  Wrseq ": Local file"-AOB_FICLNK(I)-"["+AOB_ABRLNK(I)+"] : Endif"
 Endif
Next
Wrseq space$(SPA);"Link ["+ATB_ABR+"] With";
If FLDTXT<>""
 Wrseq
 Wrseq "& [ATX]NUMERO=GLANGUE;"+FLDTXT; : J += 1
Endif
If AOB_FLDACC<>""
 If J : Wrseq "," Else Wrseq : Endif
 Wrseq "& [ACC]CODACC=GUSER;[F:"+ATB_ABR+"]"+AOB_FLDACC; : J += 1
Endif
If AOB_FLDFCY<>""
 If J : Wrseq "," Else Wrseq : Endif
 Wrseq "& [AFF]AFF0~=[F:"+ATB_ABR+"]"+AOB_FLDFCY+";GPROFIL;GUSRFCT"; : J += 1
Endif
If AOB_FLDGRF<>""
 If J : Wrseq "," Else Wrseq : Endif
 Wrseq "& [FGR]FGR0=[F:"+ATB_ABR+"]"+AOB_FLDGRF+";GCURFCY"; : J += 1
Endif
If AOB_FLDGRC<>""
 If J : Wrseq "," Else Wrseq : Endif
 Wrseq "& [AGC]AGC0=[F:"+ATB_ABR+"]"+AOB_FLDGRC+";GSOCIETE"; : J += 1
Endif
For I=1 To AOB_NBFIC
 If J<MAXLNK & AOB_EXPLNK(I)<>"" & AOB_OBLLNK(I)
  If J : Wrseq "," Else Wrseq : Endif
  CHAINE = vireblc(format$("KT:200X",AOB_EXPLNK(I)),2)
  Wrseq "& ["+AOB_ABRLNK(I)+"]"+AOB_CLELNK(I)+"="+CHAINE; : J += 1
 Endif    
Next I
Wrseq
Wrseq "& As ["+ATB_ABR+"_]"
If AOB_TRE=2
 Wrseq space$(SPA);"[G:"+ATB_ABR+"_]currind = "+num$(AOB_NOI) 
Endif
Return

