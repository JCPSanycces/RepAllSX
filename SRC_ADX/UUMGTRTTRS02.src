#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRS02                              Module   A/P-A/R Accounting  #
#                                                                        #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Suppliers BP Invoices                                    #
#            PINVOICE/BPSINVLIG/BPSINVLIGA                               #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   PINVOICE  : CPY;FCY;NUM                                              #
#   BPSINVLIG : CPY;NUM;LIG                                              #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   PINVOICE   : NUM                                                     #
#   BPSINVLIG  : NUM;LIG                                                 #
#   BPSINVLIGA : NUM;LIG;ANALIG                                          #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRS02") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRS02(DOSSIER)
  Call MAJ_UUMGTRTTRS02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTTRS02(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(2)<>2 : End : Endif

#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",7,ERR) From TRTMIG : End : Endif
##YYFIN_X3-17688
#If val(VERSION)>=GMIGX3VER70 : End : Endif
If val(VERSION)>=GMIGX3VER120 : End : Endif
##YYFIN_X3-17688_End

#----- File naming...  -----#
Local Char WNAMPIHM,WNAMPILM,WNAMPIAM
Call MIGTABNAME (DOSSIER,"PINVOICE",WNAMPIHM,ERR) From TRTMIG   : If ERR : End : Endif
If val(VERSION)<GMIGX3VER60
 Call MIGTABNAME (DOSSIER,"BPSINVLIG",WNAMPILM,ERR) From TRTMIG  : If ERR : End : Endif
 Call MIGTABNAME (DOSSIER,"BPSINVLIGA",WNAMPIAM,ERR) From TRTMIG : If ERR : End : Endif
Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMPIHM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If val(VERSION)<GMIGX3VER60
 If filinfo(filpath("FIL",WNAMPILM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
 If filinfo(filpath("FIL",WNAMPIAM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
Endif

#----- Deleting of records...  -----#
If val(VERSION)<GMIGX3VER60
 Call MIGTABRAZ (DOSSIER,"BPSINVLIG",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"BPSINVLIGA",ERR) From TRTMIG
Endif

Local File =DOSSIER+".PINVOICE"  [PIH]
Trbegin [PIH]
Delete [PIH] Where ORIMOD=3
Commit

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRS02",ERR) From TRTMIG
End

########################################################################
Subprog MAJ_UUMGTRTTRS02(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(2)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",3,ERR) From TRTMIG : End
Endif

#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",7,ERR) From TRTMIG : End : Endif
##YYFIN_X3-17688
#If val(VERSION)>=GMIGX3VER70
If val(VERSION)>=GMIGX3VER120
##YYFIN_X3-17688_End
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMPIHM,WNAMPILM,WNAMPIAM
Call MIGTABNAME (DOSSIER,"PINVOICE",WNAMPIHM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",7,ERR) From TRTMIG : End : Endif
If val(VERSION)<GMIGX3VER60
 Call MIGTABNAME (DOSSIER,"BPSINVLIG",WNAMPILM,ERR) From TRTMIG
 If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",7,ERR) From TRTMIG : End : Endif
 Call MIGTABNAME (DOSSIER,"BPSINVLIGA",WNAMPIAM,ERR) From TRTMIG
 If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",7,ERR) From TRTMIG : End : Endif
Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMPIHM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",3,ERR) From TRTMIG : End
Endif

If val(VERSION)<GMIGX3VER60
 If filinfo(filpath("FIL",WNAMPILM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",3,ERR) From TRTMIG : End
 Endif
 If filinfo(filpath("FIL",WNAMPIAM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",3,ERR) From TRTMIG : End
 Endif
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",2,ERR) From TRTMIG

Call ECR_TIME("UUMGTRTTRS02 suppliers BP Invoice Process : Update PINVOICE/BPSINVLIG/BPSINVLIGA") From DOSSUB
Call ECR_TRACE("UUMGTRTTRS02 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"PINVOICE",ERR) From TRTMIG
If val(VERSION)<GMIGX3VER60
 Call MIGTABINIT (DOSSIER,"BPSINVLIG",ERR) From TRTMIG
 Call MIGTABINIT (DOSSIER,"BPSINVLIGA",ERR) From TRTMIG
Endif

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:PIH]) = 0 :  Local File =DOSSIER+".PINVOICE"    [PIH]   : Endif      # Supliers BP Invoices
If clalev([F:PIL]) = 0 :  Local File =DOSSIER+".BPSINVLIG"   [PIL]   : Endif      # General  BP Invoices Lines
If clalev([F:PIA]) = 0 :  Local File =DOSSIER+".BPSINVLIGA"  [PIA]   : Endif      # Analytic BP Invoices Lines

# X3 Renamed File
If clalev([F:PIHM]) = 0 :  Local File =DOSSIER+"."+WNAMPIHM   [PIHM]  : Endif    # Supliers BP Invoices

If val(VERSION)<GMIGX3VER60
 If clalev([F:PILM]) = 0 :  Local File =DOSSIER+"."+WNAMPILM   [PILM]  : Endif    # General  BP Invoices Lines
 If clalev([F:PIAM]) = 0 :  Local File =DOSSIER+"."+WNAMPIAM   [PIAM]  : Endif    # Analytic BP Invoices Lines
Endif

If clalev([F:PIHW]) = 0 :  Local File =DOSSIER+"."+WNAMPIHM   [PIHW]  : Endif    # Supliers BP Invoices

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables  -----#
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_PIH (100) (adxwrb)
Local Char WTAB_PIL (100) (adxwrb)
Local Char WTAB_PIA (100) (adxwrb)
Local Shortint WCPT_PIH,WCPT_PIL,WCPT_PIA

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT


#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRS02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

#-----  Link of Head Table & Line Table (except Analytic, including in For)
#-----  We don't have the line number in the key !
If val(VERSION)<GMIGX3VER60
 Link [PILM] With [PIHM]PIH0~=[F:PILM]NUM
&    As [LNK]
&    Order By Key CLE = [F:PIHM]CPY;[F:PIHM]FCY;[F:PIHM]NUM
Else
 Link [PIHW] With [PIHM]PIH0~=[F:PIHW]NUM
&    As [LNK]
&    Where [F:PIHM]ORIMOD=3
&    Order By Key CLE = [F:PIHM]CPY;[F:PIHM]FCY;[F:PIHM]NUM
Endif

# EP to add a criteria in the "where"
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRS02" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif


Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST


$LOOP_TRS02
Raz NB

If STOP = 1
 STOP = 2
 CRITERE = "[F:PIHM]CPY='"+TABMIGKEY(1)+"' & [F:PIHM]FCY='"+TABMIGKEY(2)+"' & [F:PIHM]NUM>'"+TABMIGKEY(3)+"'"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:PIHM]CPY='"+TABMIGKEY(1)+"' & [F:PIHM]FCY>'"+TABMIGKEY(2)+"'"
Elsif STOP = 3
 STOP = 0
 CRITERE = "[F:PIHM]CPY>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif


Trbegin [PIH],[PIL],[PIA]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:PIHM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [LNK]CLE(3)

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTTRS02" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif


  If val(VERSION)<GMIGX3VER60
   # Update PINVOICE Table - Head of Supplier BP Invoices
   Gosub MAJ30_PIH
   If GOK<1 : Break 2 : Endif

   For [LNK]CLE

    # Update BPSINVLIG Table - # Generals Lines of Supplier BP Invoices
    Gosub MAJ30_PIL
    If !GOK : Break 3 : Endif

   Next

   # Update BPCINVLIGA Table - # Analyticals Lines of Supplier BP Invoices
   Gosub MAJ30_PIA
   If !GOK : Break 2 : Endif

  Else

   # Since V7 => Update PINVOICE Table - Head of Supplier BP Invoices
   Gosub MAJ30_PIH_V7
   If GOK<1 : Break 2 : Endif


  Endif

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1)= [F:PIHM]CPY
   TABMIGKEY(2)= [F:PIHM]FCY
   TABMIGKEY(3)= [F:PIHM]NUM
   STOP=1
   Break 2
  Endif

 $SUITE_BOUCLE
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS02",7,ERR) From TRTMIG : #7=Erreur
Else
 Flush [F:PIH]
 If fstat
  Call ECR_TRACE("File PINVOICE, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub PIH_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:PIL]
 If fstat
  Call ECR_TRACE("File BPSINVLIG, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub PIL_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:PIA]
 If fstat
  Call ECR_TRACE("File BPSINVLIGA, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub PIA_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(4)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTTRS02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRS02",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_TRS02
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PIH], [PIL], [PIA]
Close Local File [PIHM], [PIHW]
If val(VERSION)<GMIGX3VER60
 Close Local File [PILM], [PIAM]
Endif
Close Local File [GCM], [LED], [CPY]


#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"PINVOICE",ERR) From TRTMIG
If val(VERSION)<GMIGX3VER60
 Call MIGTABEND (DOSSIER,"BPSINVLIG",ERR) From TRTMIG
 Call MIGTABEND (DOSSIER,"BPSINVLIGA",ERR) From TRTMIG
Endif

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTTRS02") From TRTMIG
Call ECR_TIME("UUMGTRTTRS02 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

#############################################################################################################
$MAJ30_PIH
#--- Transclass
# Raz [SIH]  # expensive... must RAZ new V6 fields
[PIH] = [PIHM]


#-- Update news Fields
#       Update FIY/PER Fields on Post-Migration UPOSMIGCOM01 Process
#[F:PIH]FIY = [L]EXERCICE
#[F:PIH]PER = [L]PERIODE

#--- New fields's assignation : LED/CURLED/RATxxx/DIE
For IREF=1 To dim([F:GCM]LED)
 If [F:GCM]LED(IREF-1)<>""
  [F:PIH]LED(IREF-1) = [F:GCM]LED(IREF-1)
  [F:PIH]CURLED(IREF-1) = [F:GCM]CUR(IREF-1)
  [F:PIH]RATDIV(IREF-1) = 1
  If find(IREF,1,2,3)
   [F:PIH]RATMLT(IREF-1) = [F:PIHM]RATCUR
  Else
   [F:PIH]RATMLT(IREF-1) = [F:PIHM]RATRPT
  Endif
 Else # useful to delete intruction RAZ
  [F:PIH]LED(IREF-1)    = ""
  [F:PIH]CURLED(IREF-1) = ""
  [F:PIH]RATDIV(IREF-1) = 0
  [F:PIH]RATMLT(IREF-1) = 0
 Endif
Next

For AXE=1 To dim([F:PIH]DIE)
 If AXE<10
  If [L]AXEA(AXE)<>""
   [F:PIH]DIE(AXE-1) = [L]AXEA(AXE)
  Elsif [L]AXEI(AXE-NBAAXE)<>""
   [F:PIH]DIE(AXE-1) = [L]AXEI(AXE-NBAAXE)
  Else  # useful to delete intruction RAZ
   [F:PIH]DIE(AXE-1) = ""
  Endif
 Else  # useful to delete intruction RAZ
  [F:PIH]DIE(AXE-1) = ""
 Endif
Next


Gosub WRI_PIH
Return

$MAJ30_PIH_V7
#--- Transclass
[F:PIH] = [F:PIHW]
Gosub WRI_PIH
Return


#############################################################################################################
$MAJ30_PIL
#--- Transclass
# Raz [F:SIL]  # expensive... must RAZ new V6 fields
[F:PIL] = [F:PILM]

#--- Field linked to SIH Fields
[F:PIL]STRDAT = [F:PIH]STRDATSVC
[F:PIL]ENDDAT = [F:PIH]ENDDATSVC

#--- New fields's assignation : LED/COA/ACC
For IREF=1 To dim([F:GCM]LED)
 If [F:GCM]LED(IREF-1)<>""
  [F:PIL]LED(IREF-1) = [F:GCM]LED(IREF-1)
  If find(IREF,1,2,3)
   If [F:PIL]LED(IREF-1)=LEDGEN
    [F:PIL]COA(IREF-1) = COAGEN
    [F:PIL]ACC(IREF-1) = [F:PILM]ACC
   Elsif [F:PIL]LED(IREF-1)=LEDANA
    [F:PIL]COA(IREF-1) = COAANA
    [F:PIL]ACC(IREF-1) = [F:PILM]CNA
   Elsif dim([F:PILM]ACCIAS)>0 & [F:PIL]LED(IREF-1)=LEDIAS
    [F:PIL]COA(IREF-1) = COAIAS
    [F:PIL]ACC(IREF-1) = [F:PILM]ACCIAS
   Endif
  Else # useful to delete intruction RAZ
   [F:PIL]COA(IREF-1)    = ""
   [F:PIL]ACC(IREF-1)    = ""
  Endif
 Else # useful to delete intruction RAZ
  [F:PIL]LED(IREF-1)    = ""
  [F:PIL]COA(IREF-1)    = ""
  [F:PIL]ACC(IREF-1)    = ""
 Endif
Next
Gosub WRI_PIL
Return

#############################################################################################################
$MAJ30_PIA
#--- Reading of the Analytics Lines
For [PIAM]PIA0 Where NUM=[F:PILM]NUM #& LIG=[F:PILM]LIG

 #--- Transclass
 # Raz [F:PIA]  # expensive... must RAZ new V6 fields
 [F:PIA] = [F:PIAM]

 For IREF=1 To dim([F:GCM]LED)
  If [F:GCM]LED(IREF-1)<>""
   If find(IREF,1,2,3)
    If [F:PIL]LED(IREF-1)=LEDGEN
     [F:PIA]COA(IREF-1) = COAGEN
     [F:PIA]ACC(IREF-1) = [F:PILM]ACC
    Elsif [F:PIL]LED(IREF-1)=LEDANA
     [F:PIA]COA(IREF-1) = COAANA
     [F:PIA]ACC(IREF-1) = [F:PILM]CNA
    Elsif dim([F:PILM]ACCIAS)>0 & [F:PIL]LED(IREF-1)=LEDIAS
     [F:PIA]COA(IREF-1) = COAIAS
     [F:PIA]ACC(IREF-1) = [F:PILM]ACCIAS
    Endif
   Else # useful to delete intruction RAZ
    [F:PIA]COA(IREF-1)    = ""
    [F:PIA]ACC(IREF-1)    = ""
   Endif
  Else # useful to delete intruction RAZ
   [F:PIA]COA(IREF-1)    = ""
   [F:PIA]ACC(IREF-1)    = ""
  Endif
 Next

 For AXE=1 To dim([F:PIA]DIE)
  If AXE<10
   If [L]AXEA(AXE)<>""
    [F:PIA]DIE(AXE-1) = [L]AXEA(AXE)
   Elsif [L]AXEI(AXE)<>""
    [F:PIA]DIE(AXE-1) = [L]AXEI(AXE)
   Else # useful to delete intruction RAZ
    [F:PIA]DIE(AXE-1)    = ""
   Endif
  Else # useful to delete intruction RAZ
   [F:PIA]DIE(AXE-1)    = ""
  Endif
 Next

 Gosub WRI_PIA
 If GOK<1 : Break : Endif

Next
Return


# Write Instruction
$WRI_PIH
# To Save reference
Gosub PIH_STK
WriteB [F:PIH]
If fstat
 Call ECR_TRACE("File PINVOICE, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub PIH_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_PIL
# To Save reference
Gosub PIL_STK
WriteB [F:PIL]
If fstat
 Call ECR_TRACE("File BPSINVLIG, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub PIL_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_PIA
# To Save reference
Gosub PIA_STK
WriteB [F:PIA]
If fstat
 Call ECR_TRACE("File BPSINVLIGA, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub PIA_ERRTRA
 GOK=0 : Return
Endif
Return

##############################################################################################
$PIH_STK
Call STK (WTAB_PIH,WCPT_PIH,[F:PIH]NUM) From TRTMIG
Return
$PIL_STK
Call STK (WTAB_PIL,WCPT_PIL,[F:PIL]NUM-'/'-num$([F:PIL]LIG)) From TRTMIG
Return
$PIA_STK
Call STK (WTAB_PIA,WCPT_PIA,[F:PIA]NUM-'/'-num$([F:PIA]LIG)-'/'-num$([F:PIA]ANALIG)) From TRTMIG
Return
##############################################################################################
$PIH_ERRTRA
Call ERRTRA (WTAB_PIH,WCPT_PIH,"File PINVOICE(NUM)=") From TRTMIG
Return
$PIL_ERRTRA
Call ERRTRA (WTAB_PIL,WCPT_PIL,"File BPSINVLIG(NUM/LIG)=") From TRTMIG
Return
$PIA_ERRTRA
Call ERRTRA (WTAB_PIA,WCPT_PIA,"File BPSINVLIGA(NUM/LIG/ANALIG)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTTRS02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTTRS02(APPLI)
End

