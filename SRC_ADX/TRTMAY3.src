##########################################################################################################
#   Ajout d'un Tiers destinataire                                   Module CRM         01 décembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIBMAY3MODIF

  GIBMAY3MODIF = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIBMAY3MODIF = 1 Then
    Call LOADRESULT(1,1) From TRTMAI4
    Affzo [M:MAI4]1-99
  Endif
  #Nettoie l'écran avant de partir.
  Raz [M:MAY3]
  Kill GIBMAY3MODIF
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Local Integer ICURLIGNE

  ICURLIGNE = nolign-1
  Case BOUT
    When "B"
      Gosub ONADD
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONADD
  If ICURLIGNE < 0 Then
    Return
  Endif
  If [M:MAY3]BPRNUM(ICURLIGNE ) = "" Then
    Return
  Endif
  #Test tout d'abord si le tiers n'est pas déjà inclus dans la sélection.
  Read [SCL]SCL1=GSZOPGNUM;"BPR";[M:MAY3]BPRNUM(ICURLIGNE)
  If !fstat Then
    GMESSAGE = mess(358,196,1) #Ce tiers est déjà inclus dans la sélection.
    GERR = 2
    Return
  Endif
  GIBMAY3MODIF = 1
  Call DEBTRANS From GLOCK
  Trbegin [SCL]
  [F:SCL]OPGNUM = GSZOPGNUM
  [F:SCL]RECTYP = "BPR"
  [F:SCL]RECNUM = [M:MAY3]BPRNUM(ICURLIGNE)
  [F:SCL]BPRNUM = ""
  [F:SCL]BPAADD = ""
  Write [SCL]
  If fstat Then
    GMESSAGE = mess(100,141,1) #Erreur création
    GERR = 1
    Rollback
  Else
    Commit
  Endif
  FIN = 1
Return

##########################################################################################################
$ONLOAD
Local Char SZWHERE (250)(20)
Local Integer ILIGNEWHERE
Local Char SZAND
Local Char SZVALEUR (100)
Local Char SZRECHERCHE (100)
Local Integer IBNONVIDE
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  IBNONVIDE = 0
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Effzo [M:MAY3]15
  [M:MAY3]NBREC = 0
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  #Il faut créer le link
  Link [BPA] With [BPR]BPR0=[F:BPA]BPANUM As [BPRA] Where [F:BPR]BPRNUM<>"" and [F:BPA]BPATYP=1
  If [M:MAY3]BPRNAM <> "" Then
    SZVALEUR = [M:MAY3]BPRNAM
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND - "pat(toupper([F:BPR]BPRNAM)," + SZRECHERCHE + ")<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:MAY3]BPRZIP <> "" Then
    SZVALEUR = [M:MAY3]BPRZIP
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND - "pat(toupper([F:BPA]POSCOD)," + SZRECHERCHE + ")<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:MAY3]BPRCTY <> "" Then
    SZVALEUR = [M:MAY3]BPRCTY
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND - "pat(toupper([F:BPA]CTY)," + SZRECHERCHE + ")<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:MAY3]BPRADEDEF = 2 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:BPA]BPAADDFLG=2"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  ILIGNE = 0
  While ILIGNE < ILIGNEWHERE
    If SZWHERE <>"" Then
      IBNONVIDE = 1
    Endif
    ILIGNE += 1
  Wend
  If IBNONVIDE = 1 Then
    Filter [BPRA] Where evalue (SZWHERE) Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
  Else
    Filter [BPRA] Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
  Endif
  INBLIGNETOTAL = rowcount([BPRA])
  ILIGNE = 0
  For [BPRA]
    If ILIGNE >= dim([M:MAY3]NAM)-1 Then
      Break
    Endif
    If [F:BPA]BPANUM <> "" Then
      [M:MAY3]BPRNUM(ILIGNE) = [F:BPR]BPRNUM
      [M:MAY3]NAM(ILIGNE) = [F:BPR]BPRNAM
      [M:MAY3]ZIP(ILIGNE) = [F:BPA]POSCOD
      [M:MAY3]CTY(ILIGNE) = [F:BPA]CTY
      [M:MAY3]TEL(ILIGNE) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:MAY3]CRY(ILIGNE) = [F:BPA]CRY
      [M:MAY3]BPAADDFLG(ILIGNE) = [F:BPA]BPAADDFLG
      [M:MAY3]BPADES(ILIGNE) = [F:BPA]BPADES
      ILIGNE += 1
    Endif
  Next
  Filter [BPRA]
  [M:MAY3]NBREC = ILIGNE
  Affzo [M:MAY3]1-99
  If ILIGNE < INBLIGNETOTAL Then
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963,182,1)
    GERR = 2
  Endif
Return

