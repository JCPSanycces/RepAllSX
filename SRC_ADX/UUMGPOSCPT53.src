#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UUMGPOSCPT53                                       Module  Accounting  #
#                    Migration Process                                   #
#                                                                        #
#      Financial Post-migration : Resynchronization                      #
#                                                                        #
##########################################################################
#                                                                        #
#                                                                        #
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSCPT53") From LECFIC
  Endif

  #Call RAZ_UUMGPOSCPT53(DOSSIER)
  Call MAJ_UUMGPOSCPT53(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSCPT53(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(1)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSCPT53",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGPOSCPT53(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(1)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT53",3,ERR) From TRTMIG : End
Endif

If func DOSVUE.ISVIEW(DOSSIER,"BLACMM")=1 or func DOSVUE.ISVIEW(DOSSIER,"GCOMMIT")=1
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT53",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT53",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT53",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSCPT53",3,ERR) From TRTMIG : End
Endif

#--------------- Opening of files  -----#
If clalev([F:CPY9]) = 0 :  Local File =DOSSIER+".COMPANY"      [CPY9]   : Endif     # Company
If clalev([F:FIY9]) = 0 :  Local File =DOSSIER+".FISCALYEAR"   [FIY9]   : Endif     # Fiscal years
If clalev([F:GCM])  = 0 :  Local File =DOSSIER+".GACM"         [GCM]    : Endif     # Account core model
If clalev([F:LED])  = 0 :  Local File =DOSSIER+".GLED"         [LED]    : Endif     # Ledge

Local Integer DIRECT : DIRECT = 1
Local Integer ANOM

Local Char CRITERESPE(250),HINTSPE(30)
Local Char FLUX
Local Integer FILTRELIN

FLUX="UUMGPOSCPT53" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call OUVRE_VLC("UUMGPOSCPT53","","") From GESECRAN

Filter [FIY9] Where FIYSTA=3

For [CPY9]CPY0 Hint Key=HINTSPE Where CPYLEGFLG=2 & evalue(CRITERESPE)

 Call LEC_GCM([F:CPY9]ACM) From CPTLEC

 For [FIY9]FIY0(2) Where CPY=[F:CPY9]CPY

  If [F:GCM]LED([F:FIY9]LEDTYP-1)<>""
   Call LEC_LED([F:GCM]LED([F:FIY9]LEDTYP-1)) From CPTLEC

   For [FIY9]FIY0

    If [F:LED]CMM=2
      Call AFF_VLC(mess(2,45,1)-":"-[F:CPY9]CPY-"-"-mess(166,105,1)-":"-num$([F:FIY9]LEDTYP)-"-"-mess(4,48,1)-":"-num$([F:FIY9]FIYNUM),"BLACMM") From GESECRAN
      Call RECUPBLM2(DOSSIER,[F:CPY9]CPY,2,"",[F:FIY9]LEDTYP,[F:FIY9]FIYNUM,"",2,"",GSERVEUR,DIRECT) From RECUPBLM
    Endif

   Next

  Endif

 Next

Next

Filter [FIY9]

Call FERME_VLC From GESECRAN

Close Local File [CPY9], [FIY9], [GCM], [LED]
Call MIGTRTEND (DOSSIER,"UUMGPOSCPT53") From TRTMIG
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGPOSCPT53(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGPOSCPT53(APPLI)
End

