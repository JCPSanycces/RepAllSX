#<AdxTL>@(#)3.0.0.0 $Revision$
#-------------------------------------------------------------------------------------------------------------#
# Suppression des enregistrements avec code paramètre obsolète ou mise à groupe dans les jeux de valeurs
#-------------------------------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour table ADOVALGRP d'après la table ADOPAR") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DESPAR
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub DESPAR
End

#-------------------#
$DESPAR
Local Integer NBD , NBR

Local File =DOSSIER+".ADOVALGRP" [ADG] , =DOSSIER+".ADOPAR" [ADP]

# Mise à jour de la table ADOVALGRP
Call ECR_TRACE(mess(81,125,1)-"ADOVALGRP:"-time$,0) From GESECRAN
Trbegin [ADG]
 For [ADG]
  Read [ADP]ADP1=[F:ADG]PARAM
  If fstat
   Delete [ADG] Curr
   If fstat
    Call ERREUR("ADOVALGRP"-[F:ADG]PARAM,3) From DOSDIC
   Endif
   NBD += 1 
  Elsif [F:ADG]GRPPAR<>[F:ADP]GRPPAR
   [F:ADG]GRPPAR = [F:ADP]GRPPAR
   Rewrite [ADG]
   If fstat
    Call ERREUR("ADOVALGRP"-[F:ADG]PARAM,2) From DOSDIC
   Endif
   NBR += 1 
  Endif
 Next ADG
 Call ECR_TRACE(num$(NBR)-"Updated record &"-num$(NBD)-"deleted record",0) From GESECRAN
Commit

Close Local File [ADP] , [ADG]

Return

