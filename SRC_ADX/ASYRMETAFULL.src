#<AdxTL>@(#)0.0.0.0 $Revision$
Call TEST
End

Subprog TEST
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Integer ASTATUS

ASTATUS = func EXTRACT_METADATA_FULL(RESHEAD, RESBODY)
End


#**
#* This Function allows to extract all metadatas from sql (sql server, oracle, ...) to mongodb
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/etna-etl/lib/syncArea.md
#*
#* @
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : Document Descriptor UUID or 'null' if document was not found.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog EXTRACT_METADATA_FULL(RESHEAD, RESBODY)
Value Clbfile RESHEAD()
Value Clbfile RESBODY()

Local Integer STATUSCODE
Local Clbfile ARGUMENTS(0) : ARGUMENTS = '{'
If GSERVEUR : Append ARGUMENTS,  '"solution": "'+GINSTID+'","folder": "'+nomap+'",' : Endif :#For the batch serveur
Append ARGUMENTS,  '"entityType": ""' :# to extract all entities
Append ARGUMENTS, '}'

STATUSCODE = func ASYRWEBSER.EXEC_JS('etna-etl/lib/sync', 'extractMetadataFromX3', 'wait', ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)
End STATUSCODE

