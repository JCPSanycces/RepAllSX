#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Invalidation des écrans ayant le type de données SAT et/ou ADL
# FGR 06/03/2012 : X3SUIVI79830
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Screens with data type 'SAT' invalidated") From LECFIC
Local File ADOSSIER [ADS2]
Local File ADOSSIER [ADS]  # FGR 03/08/2012 : X3SUIVI82937
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

  Local File ADOSSIER [ADS]     # FGR 03/08/2012 : X3SUIVI82937
  Read [F:ADS]DOSSIER=DOSSIER   # FGR 03/08/2012 : X3SUIVI82937
  Gosub SATINVALID
End

#-------------------#
$SATINVALID
#CHECK IGNORE_BEGIN
Local Integer OK  # FGR 03/08/2012 : X3SUIVI82937

  # ------------------------------
  Local File =DOSSIER+".AMSKZON" [WAMZ]
  # ------------------------------
  Filter [WAMZ] Where (CODTYP = "SAT" or CODTYP = "ADL")
  For [WAMZ]CODE(1)
      Call ECR_TRACE(mess(2,9043,1) - "CODMSK :" - [F:WAMZ]CODMSK - "at" - time$,0) From GESECRAN
      # FGR 03/08/2012 : X3SUIVI82937 (début)
      #Call GENERDIFFSCREEN(DOSSIER, [F:WAMZ]CODMSK) From INTRUTILB
      Call VALID([F:WAMZ]CODMSK, DOSSIER, [F:ADS]NBRLAN, [F:ADS]LAN, 1, OK) From VALMSK
      # FGR 03/08/2012 : X3SUIVI82937 (fin)
  Next
  Filter [WAMZ]
  Close Local File [WAMZ]
  #CHECK IGNORE_END
Return
