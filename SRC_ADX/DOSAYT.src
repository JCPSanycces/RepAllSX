#<AdxTL>@(#)6.0.0.0 $Revision$
######################################################################################
## Xtend: Gestion pour la validation de dossier
#
# Voir Marc pour intégration dans les trts stds
#
#    AYTDIC - Maj dictionnaire Xtend et design 
#             Appelé par DOSDIC
#
#    AYTGEN - Validation des sites Xtend 
#             Appelé par SUBADS2
######################################################################################
# Maj dictionnaire Xtend et design
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog AYTDIC()
Local Integer RET    # 1: Ok 0:Ko
# 
Call ECR_TIME(mess(15,125,1)-mess(12,7901,1)) From DOSSUB
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(12,7901,1),"") From GESECRAN
Endif


Local File =GDOSREF+".AYTFCY"         [AYSO] 
Local File =[F:ADS]DOSSIER+".AYTFCY"  [AYSD]
#Local Integer AX_NBAYF
Local Integer AX_NBAYF, AX_WI, AX_RET, SPEC, NEWREC
Local Char    AX_NOTUSED
Local Char    AX_LSTOBJCOD(12)     : AX_LSTOBJCOD="***"
Local Char    AX_OPTION(12)(1..2)  
AX_OPTION(1)="DESCOP"    # Copie design
AX_OPTION(2)="NOTEMPON"  # pas de popup avancement

# Recherche des sites
# AX_NBAYF = nbrecord([AYS_])
# Local Char    AX_LSTFCYCOD(GLONFCY)(0..(AX_NBAYF-1))        # Liste des sites à générer

For [AYSO]
    Read [AYSD]AYS0=[AYSO]FCYCOD
    If !fstat
        Call SPEC([F:AYSD]CODACT,SPEC) From DOSSUB  # Spécifique destination - pas d'écrasement 
    Else
        SPEC=0
    Endif
    If !SPEC
        Call NEWREC([F:ADS]DOSSIER,[F:AYSO]CODACT,0,NEWREC) From DOSSUB   # Xtend: pas de module
        If NEWREC  
            Call ECR_TIME("==>"-mess(26,7900,1)-[AYSO]FCYCOD) From DOSSUB
            If GINFO
             Call AFF_VLC(mess(15,125,1)-mess(12,7901,1), mess(26,7900,1)-[AYSO]FCYCOD) From GESECRAN
            Endif
            # L'ensemble du site est copié 
            Call FCYCOPPRG(GDOSREF, [AYSO]FCYCOD, [F:ADS]DOSSIER, [AYSO]FCYCOD, 
&                          AX_NOTUSED, AX_LSTOBJCOD, AX_OPTION, AX_RET) From AYTFCYCOP
            If !AX_RET : RET=0 : Endif
        Endif
    Endif 
Next
Close File [AYSO],[AYSD]
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
End

# Génération des sites Xtend  
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog AYTGEN()
Local Integer RET    # 1: Ok 0:Ko
#
If GINFO
 Call AFF_VLC(mess(13,7901,1),"") From GESECRAN
Endif

Local File =GDOSREF+".AYTFCY"         [AYSO] 
Local File =[F:ADS]DOSSIER+".AYTFCY"  [AYSD]
Local Integer AX_NBAYF, AX_WI, AX_RET, SPEC, NEWREC
Local Char    AX_NOTUSED
Local Char    AX_LSTOBJCOD(12)     : AX_LSTOBJCOD="***"
Local Char    AX_OPTION(12)(1..1)  
AX_OPTION(1)="NOTEMPON"  # pas de popup avancement

For [AYSO]
    Read [AYSD]AYS0=[AYSO]FCYCOD
    If !fstat
        Call SPEC([F:AYSD]CODACT,SPEC) From DOSSUB  # Spécifique destination - pas d'écrasement  
        If !SPEC
            Call NEWREC([F:ADS]DOSSIER,[F:AYSO]CODACT,0,NEWREC) From DOSSUB   # Xtend: pas de module
            If NEWREC  
                Call ECR_TIME("==>"-mess(42,7900,1)-[AYSO]FCYCOD) From DOSSUB
                If GINFO
                 Call AFF_VLC(mess(15,125,1)-mess(12,7901,1), mess(42,7900,1)-[AYSO]FCYCOD) From GESECRAN
                Endif
                Call XMLGENPRG([F:ADS]DOSSIER, [AYSO]FCYCOD, AX_LSTOBJCOD, AX_OPTION, AX_RET) From AYTGEN
                If !AX_RET : RET=0 : Endif
            Endif
        Endif 
    Endif 
Next
Close File  [AYSO],[AYSD]
End
