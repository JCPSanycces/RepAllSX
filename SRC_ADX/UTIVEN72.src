#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UTIVEN72    Utilitaire de migration des livraisons module ventes     Module VENTE  #
#              Initialisation des nouveaux champs suite                              #
#                au développement de l'exigence 91606(65)                            #
#              Init. nouveau champs ARRDATCOD, DEPDATCOD et TRAPLTCOD de SALTRS      #
# X3SUIVI91606                                                                       #
# X3SUIVI96249                                                                       #
######################################################################################
  Call MAJ_UTIVEN72
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIVEN72
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTIVEN72 - New delivery transactions fields initialisation") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIVEN72 : New delivery transactions fields initialisation") From LECFIC
    Call EXE_UTIVEN72(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTIVEN72(DOSSIER)
Value Char    DOSSIER

  Call ECR_TIME("UTIVEN72 : Start folder's process"-DOSSIER) From DOSSUB
  #----- Chargement globale GMAXUPDTRS -----#
  If dim([V]GMAXUPDTRS) < 1 Then
    Global Integer GMAXUPDTRS
  Endif
  Local File =DOSSIER+".ADOVAL" [ADW]
  Read [ADW] ADW0="";"";"MAXUPDTRS"
  If fstat Then
    Raz [F:ADW]
  Endif
  If val([F:ADW]VALEUR) > 0 Then
    GMAXUPDTRS = val([F:ADW]VALEUR)
  Else
    GMAXUPDTRS = 1000
  Endif
  Close Local File [ADW]
  #----- Début mise à jour SALTRS -----#
  #-- CPO 65018 Code Incoterm dans transactions
  Gosub TRT_SLT
  #----- Fin mise à jour SALTRS   -----#
$FIN_UTIVEN72
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTIVENV12 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
#   Initialisation des nouveaux champs dans les transactions vente              #
# ----------------------------------------------------------------------------- #
# Table SALTRS - Transactions vente                                             #
#-------------------------------------------------------------------------------#
$TRT_SLT
Local Shortint INDIC

  If filinfo(filpath("FIL","SALTRS","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("UTIVEN72 Sales Transactions Process : Update SALTRS") From DOSSUB
  Local File =DOSSIER+".SALTRS"    [SLT]
  #
  Call ECR_TIME("UTIVEN72 Sales Transactions Process : --- Step 1 ") From DOSSUB
  Gosub TXNLIV
  #
  Call ECR_TIME("UTIVEN72 Sales Transactions Process : --- Step 2 ") From DOSSUB
  Gosub TXNRET
  #
  Call ECR_TIME("UTIVEN72 Sales Transactions Process : --- Step 3 ") From DOSSUB
  Gosub TXNFAC
  #
  Close Local File [SLT]
Return

#-------------------------------------------------------------------------------#
# Transaction pour les livraisons                                               #
#-------------------------------------------------------------------------------#
$TXNLIV
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 4
    Raz INDIC
    If dim([F:SLT]TRAPLTCOD) > 0 Then
      If !find([F:SLT]TRAPLTCOD,1,2,3) Then
        # Immat remorque (invisible)
        INDIC = 1
        [F:SLT]TRAPLTCOD = 3
      Endif
    Endif
    If dim([F:SLT]DPEDATCOD) > 0 Then
      If !find([F:SLT]DPEDATCOD,1,2,3) Then
        # Date départ (invisible)
        INDIC = 1
        [F:SLT]DPEDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ARVDATCOD) > 0 Then
      If !find([F:SLT]ARVDATCOD,1,2,3) Then
        # Date arrivée (invisible)
        INDIC = 1
        [F:SLT]ARVDATCOD = 3
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
  Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les retours                                                  #
#-------------------------------------------------------------------------------#
$TXNRET
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 6 or STRTYP = 7 or STRTYP = 8
    Raz INDIC
    If dim([F:SLT]LICPLATCOD) > 0 Then
      If !find([F:SLT]LICPLATCOD,1,2,3) Then
        # Immattriculation (invisible)
        INDIC = 1
        [F:SLT]LICPLATCOD = 3
      Endif
    Endif
    If dim([F:SLT]TRAPLTCOD) > 0 Then
      If !find([F:SLT]TRAPLTCOD,1,2,3) Then
        # Immat remorque (invisible)
        INDIC = 1
        [F:SLT]TRAPLTCOD = 3
      Endif
    Endif
    If dim([F:SLT]DPEDATCOD) > 0 Then
      If !find([F:SLT]DPEDATCOD,1,2,3) Then
        # Date départ (invisible)
        INDIC = 1
        [F:SLT]DPEDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ARVDATCOD) > 0 Then
      If !find([F:SLT]ARVDATCOD,1,2,3) Then
        # Date arrivée (invisible)
        INDIC = 1
        [F:SLT]ARVDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETDCOD) > 0 Then
      If !find([F:SLT]ETDCOD,1,2,3) Then
        # Heure départ (invisible)
        INDIC = 1
        [F:SLT]ETDCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETACOD) > 0 Then
      If !find([F:SLT]ETACOD,1,2,3) Then
        # Heure arrivée (invisible)
        INDIC = 1
        [F:SLT]ETACOD = 3
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
  Commit
Return

#-------------------------------------------------------------------------------#
# Transaction pour les factures et avoirs                                       #
#-------------------------------------------------------------------------------#
$TXNFAC
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 5
    Raz INDIC
    If dim([F:SLT]LICPLATCOD) > 0 Then
      If !find([F:SLT]LICPLATCOD,1,2,3) Then
        # Immattriculation (invisible)
        INDIC = 1
        [F:SLT]LICPLATCOD = 3
      Endif
    Endif
    If dim([F:SLT]TRAPLTCOD) > 0 Then
      If !find([F:SLT]TRAPLTCOD,1,2,3) Then
        # Immat remorque (invisible)
        INDIC = 1
        [F:SLT]TRAPLTCOD = 3
      Endif
    Endif
    If dim([F:SLT]DPEDATCOD) > 0 Then
      If !find([F:SLT]DPEDATCOD,1,2,3) Then
        # Date départ (invisible)
        INDIC = 1
        [F:SLT]DPEDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ARVDATCOD) > 0 Then
      If !find([F:SLT]ARVDATCOD,1,2,3) Then
        # Date arrivée (invisible)
        INDIC = 1
        [F:SLT]ARVDATCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETDCOD) > 0 Then
      If !find([F:SLT]ETDCOD,1,2,3) Then
        # Heure départ (invisible)
        INDIC = 1
        [F:SLT]ETDCOD = 3
      Endif
    Endif
    If dim([F:SLT]ETACOD) > 0 Then
      If !find([F:SLT]ETACOD,1,2,3) Then
        # Heure arrivée (invisible)
        INDIC = 1
        [F:SLT]ETACOD = 3
      Endif
    Endif
    # -------------------------------------
    # FGR 12/08/2014 : X3SUIVI86249 (début)
    If dim([F:SLT]BELVCSCOD) > 0 Then
      If !find([F:SLT]BELVCSCOD,1,2,3) Then
        If dim(IKBEENABLE) < 0 Then
          Local Integer IKBEENABLE

          IKBEENABLE = 1
          Local File =DOSSIER+".ACTIV"    [WACV]
          Read [F:WACV]CODACT="KBE"
          If !fstat Then
            If [F:WACV]FLACT = 2 Then
              IKBEENABLE = 2
            Endif
          Endif
          Close Local File [WACV]
        Endif
        # ---------------------------
        INDIC = 1
        If IKBEENABLE = 2 Then
          [F:SLT]BELVCSCOD = 1 # Saisi
        Else
          [F:SLT]BELVCSCOD = 3 # Invisible
        Endif
        # ---------------------------
      Endif
    Endif
    # FGR 12/08/2014 : X3SUIVI86249 (fin)
    # -------------------------------------
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
  Commit
Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN72(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN72(APPLI)
End
