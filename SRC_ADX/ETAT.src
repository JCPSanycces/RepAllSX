#<AdxTL>@(#)11.0.0.0 $Revision$
################################################################################
## Traitement ETAT - Maintenu par compatibilité avec la 130
################################################################################
## Subprog IMPCOMP(ETAT,FONCTION,TYP,NBMASK,...    Impression avec hard-copy
## Subprog IMPRIME(ETAT1,FONCTION,TYP)             Impression avec type d'impression
## Subprog IMPRIME(ETAT1,FONCTION)                 Impression avec transcodage
## Subprog ETAT(ETAT,FONCTION,TBPAR,TBVAL)         Impression avec code impression
## Subprog ETATN(ETAT,FONCTION,TBPAR,TBVAL)        Impression avec code état
## Subprog GETPARAM(PARAM,NBPAR,PARAMETRES,VALEUR) Lecture paramètres
## Subprog SETPARAM(PARAM,NBPAR,PARAMETRES,VALEUR) Ecriture paramètres
## Subprog ALIMETAT(ETAT,FONCTION,TBPAR,TBVAL,TRTINI,REQUETE,NUMLIG) ???????????
## Subprog EDTMSG(ETAT,IMPRIMANTE,MSG)             Message d'impression
################################################################################

Subprog IMPCOMP(ETAT,VALEUR,FONCTION,TYP,NBMASK,NOMMSK,ABMSK,AMA,TIT)
Value    Char    ETAT
Value    Char    VALEUR
Value    Char    FONCTION
Variable Integer TYP
Value    Integer NBMASK
Variable Char    NOMMSK()(0..)
Variable Char    ABMSK()(0..)
Variable Integer AMA(0..)
Value    Char    TIT
Local Char IMPDIRECT(250)
Goto IMPR1

Subprog IMPRESSION(ETAT,FONCTION,TYP)
Value    Char    ETAT
Value    Char    FONCTION
Variable Integer TYP
Local Char IMPDIRECT(250)
Goto IMPR1

Subprog IMPDEF(ETAT,VALEUR,FONCTION)
Value    Char    ETAT
Value    Char    VALEUR
Value    Char    FONCTION
Local    Integer TYP
Local Char IMPDIRECT(250)
Goto IMPR1

Subprog IMPRIME(ETAT,FONCTION)
Value    Char    ETAT
Value    Char    FONCTION
Local    Integer TYP
Local Char IMPDIRECT(250)
[L]TYP = 1
Goto IMPR1

Subprog GO_AIMP_WITH_PARAM(ETAT,FONCTION)
Value    Char    ETAT
Value    Char    FONCTION
Local    Integer TYP
Local Char IMPDIRECT(250)  : IMPDIRECT="1"
[L]TYP = 1
Goto IMPR1

$IMPR1
Local Char    PARAM(250)(1..7) ,VAL_ETAT(250)
Local Char    SAVREP1(20) , SAVREP2(20), RETOUR(10)
Local Integer ER , OBLIG
Local Char    COMPLEMENT(250) , NOMSPE(GLONADC)
If dim(VALEUR)>0 : VAL_ETAT = VALEUR : Endif
GPOINT = "IMPRIME" : Gosub ENTREE From EXEFNC
PARAM(1) = ETAT                 : # Code impression ou Etat
PARAM(5) = num$(dim([L]NBMASK)) : # Copie d'écran directement depuis la gestion d'objet
Call TRTSPE("","AIMP0",NOMSPE) From SUBACT
Call S_TAB_CHAR(VAL_ETAT,PARAM,"AIMP0","AIMP0",NOMSPE) From GACTION
If PARAM(1)<>""
 TYP       = val(PARAM(3)) : # Type d'impression
 PARAM(3)  = "0"           : # Dans l'action AIMP1, c'est le groupe d'état
 GTYPIMP   = [L]TYP
 PARAM(2)  = FONCTION      : # Fonction
 GFCTIMP   = FONCTION
 IMPDIRECT = PARAM(4)      : # Impression directe
 SAVREP1   = GREPORT1
 SAVREP2   = GREPORT2
 GREPORT1  = ""
 GREPORT2  = ""
 Case [L]TYP
  When 1 : # Etat CR
   If PARAM(1)="PRTSCR" & dim([L]NBMASK)>0
    Call HCOPY(NBMASK,NOMMSK,ABMSK,AMA,TIT) From GOBJIMP
   Elsif IMPDIRECT<>"2"
    Call TRTSPE("","AIMP1",NOMSPE) From SUBACT
    Call TRAITE_CHAR(VAL_ETAT,PARAM,"","AIMP1","AIMP1",4,NOMSPE) From GTRAITE
   Else
    ETAT = PARAM(1)
    Gosub OUVFIC From AIMP1
    If clalev([M:AIP])=0 : Local Mask AIMP0 [AIP] : Raz [M:AIP] : Endif
    If clalev([M:RPT])=0 : Local Mask AIMP1 [RPT] : Raz [M:RPT] : Endif
    Gosub REMPLIT From AIMP1
    Gosub SETPAR  From AIMP1
    [M]RPTCOD = PARAM(1)
    [M]LANGUE = GLANGUE
    Read [ARP]ARP0 = [M]RPTCOD
    If fstat : End : Endif
    Call COMPLEMENT(COMPLEMENT) From AIMP1
    Call DEFIMP([M]RPTCOD,GUSER,COMPLEMENT,[M]PRT,OBLIG) From IMPRIME
    #Call AIMCONT([M]PRT,[M]RPTCOD,([M]BATCH<>0) or ([M]DIFFERE=2)) From IMPRIME # bug CCL 52531
    Call CONT_PRT([M]PRT) : # bug CCL 52531
    If mkstat : End : Endif
    [M]IMPRIME = [F:AIM]PRT
    Call IMPRIME([M]RPTCOD,[M]LANGUE,[M]NBRPAR,[M]PARCOD,[M]TYP,[M]PARTYP,[M]NOLIB
&            ,[M]DEBFIN,[M]VALINT1,[M]VALINT2,[M]DIFFERE
&            ,[M]IMPRIME,[M]SERVEUR,[M]IMPRIMANTE,[M]PRTPOR,[M]PRTDRV
&            ,[M]PRTDES,[M]NBRCPY,[M]ASSCPY,[M]PAGDEB,[M]PAGFIN,[M]FICHIER,[M]FMTFIC
&            ,[M]NBSEG,[M]VALSEG,[M]DIFDAT,[M]DIFTIM,[M]DIFSRVC,[M]FORPAP
&            ,[M:AIP]TBPAR,[M:AIP]TBVAL,[M]MESSAGE,[M]NBPLAG,[M]PARPLAG,[M]BORPLAG,[M]VALPLAG1,[M]VALPLAG2,RETOUR,ER)
&   From AIMP3
   Endif
  When  2 , 3 : # Requêtes/SQL
   If !clalev([F:ALH]) : Local File ALISTEH  [ALH] : Endif
   If !clalev([F:ARV]) : Local File AREPORTV [ARV] : Endif
   If !clalev([F:ALR]) : Local File ALISTER  [ALR] : Endif
   PARAM(3) = "9" : # Exécution
   Read [ALH]ALH0 = PARAM(1)
   If !fstat
    Case [F:ALH]ALLUSR
     When 1 : # normale
      Read  [ARV]ARV0(3) = GFCTIMP;GTYPIMP;PARAM(1)
      If fstat
       Read [ALR]ALR0(2) = PARAM(1);GUSER
       If !fstat
        PARAM(3) = "0"
       Endif
      Endif
     When  2 : #  Partage
      Read  [ARV]ARV0(3) = GFCTIMP;GTYPIMP;PARAM(1)
      If fstat
       PARAM(3) = "0"
      Endif
     When 3 : # Recalculée
    Endcase
   Endif
   PARAM(4) = ""
   Call TRTSPE("","ALISTE",NOMSPE) From SUBACT
   Call TRAITE_CHAR(VAL_ETAT,PARAM,"ALISTE","SUBALH2","ALISTE",6,NOMSPE) From GTRAITE
  When 4 : # Export
   Call TRTSPE("","GEXPOBJ",NOMSPE) From SUBACT
   Call TRAITE_CHAR(VAL_ETAT,PARAM,"","GEXPOBJ","DEXPOBJ",4,NOMSPE) From GTRAITE
  When 5

   Call TRAITE_CHAR(VAL_ETAT,PARAM,"","ABIIMP","ABIIMP",4,"") From GTRAITE
  When Default
 Endcase
Endif
GREPORT1 = SAVREP1
GREPORT2 = SAVREP2
GFCTIMP = ""
GTYPIMP = 0
End

##################################################################################
Subprog CONT_PRT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call AIMCONT(VALEUR,[M]RPTCOD,([M]BATCH<>0) or ([M]DIFFERE=2)) From IMPRIME
 If mkstat : End : Endif
 [M]IMPRIME    = [F:AIM]PRT
 If [F:AIM]PRTSRV<>[M]SERVEUR
   [M]SERVEUR    = [F:AIM]PRTSRV
 Endif
 [M]IMPRIMANTE = [F:AIM]PRTNAM
 [M]PRTPOR     = [F:AIM]PRTPOR
 [M]PRTDRV     = [F:AIM]PRTDRV
 Raz [M]PRTDES
 For [AID]AID0 Where COD=[F:AIM]COD
  [M]PRTDES([F:AID]NUM-1)  = [F:AID]PRTDES
 Next
 If find([M]IMPRIME,2,5)
  [M]NBRCPY     = [F:AIM]NBRCPY
  [M]ASSCPY     = [F:AIM]ASSCPY
 Endif
 If find([M]IMPRIME,3,4) or (GFUSION>0 and [M]IMPRIME=1) : # Message,Fichier :  112927 Destination export format not respected in direct print
  [M]FMTFIC     = [F:AIM]PRTFMT
 Endif
 [M]PRTORIENT     = [F:ARP]ORIENT
Endif
End

##################################################################################
Subprog ETAT(ETAT,FONCTION,TBPAR,TBVAL)
Value Char ETAT
Value Char FONCTION
Value Char TBPAR()(1..)
Value Char TBVAL()(1..)
Local Mask AIMP0 [AIP]
Gosub CHARGE_PAR
Call IMPRIME(ETAT,FONCTION)
End

$CHARGE_PAR
Local Integer I
[M:AIP]NBLIG = min(dim([M:AIP]TBPAR),dim(TBPAR))
For I=1 To [M:AIP]NBLIG
 [M:AIP]TBPAR(I-1) = TBPAR(I)
 [M:AIP]TBVAL(I-1) = TBVAL(I)
Next I
Return

##################################################################################
Subprog ETATN(ETAT,FONCTION,TBPAR,TBVAL)
Value Char ETAT
Value Char FONCTION
Value Char TBPAR()(1..)
Value Char TBVAL()(1..)
Local Mask AIMP0 [AIP]
Gosub CHARGE_PAR
Local Char PARAM(250)(1..3) , VALEUR(250) , NOMSPE(GLONADC)
PARAM(1) = ETAT
PARAM(2) = FONCTION
Call TRTSPE("","AIMP1",NOMSPE) From SUBACT
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,NOMSPE) From GTRAITE
End

##################################################################################
Subprog GETPARAM(PARAM,NBPAR,PARAMETRES,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Variable Char    VALEUR()
Local Integer I , L
Local Char    VALPAR(250)
L = len(PARAM)
Gosub SET_VIDE
VALPAR = VIDE
For I=1 To NBPAR
 If left$(PARAMETRES(I),L+1)=PARAM+"="
  VALPAR = right$(PARAMETRES(I),L+2)
  If right$(PARAMETRES(I),L+2) = "_ALPHA_RANGE_MIN"
   VALPAR = "  "
  Elsif right$(PARAMETRES(I),L+2) = "_ALPHA_RANGE_MAX"
   VALPAR = "zzzzzzzzzz"
#  Elsif (left$(PARAMETRES(I),2)="__" or left$(PARAMETRES(I),1)<>"_")
#&  & ascii(left$(VALPAR,1))>=1 & ascii(left$(VALPAR,1))<=20
  Elsif ascii(left$(VALPAR,1))>=1 & ascii(left$(VALPAR,1))<=20
   VALPAR = right$(VALPAR,2)
  Endif
  Break
 Endif
Next I
VALEUR = VALPAR
End

#################
$SET_VIDE
Local Char VIDE(5)
VIDE = "?????"
Return

##################################################################################
Subprog SETPARAM(PARAM,NBPAR,PARAMETRES,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Variable Char    VALEUR()
Local Integer I , K , L , OK
L = len(PARAM)
OK = 0
For I=1 To NBPAR
 If left$(PARAMETRES(I),L+1)=PARAM+"="
  PARAMETRES(I) = PARAM+"="+VALEUR
  OK = 1 : Break
 Endif
Next I
If !OK
 NBPAR += 1
 PARAMETRES(NBPAR) = PARAM+"="+VALEUR
Endif
End

##################################################################################
# mb 4.10.7 Obsolète dès que la new AdxDll_Cr11_Netv1s1.dll sera livrée
##################################################################################

Subprog SETVIR(ETAT,NBPAR,PARAMETRES)
Value    Char    ETAT
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Local Integer I , K , L
Local Char    VALEUR(255)
If mid$(adxsca,4,1)<>"," : End : Endif
For [ARD]ARD0 Where RPTCOD=ETAT & PARCOD<>""
 Read [ATY]CODTYP = [F:ARD]PARTYP
 If find([F:ATY]TYPTYP,2,3,4,5,6)
  PARAM = [F:ARD]PARCOD
  L = len(PARAM)
  Gosub MODVIR
  If [F:ARD]PARSTREND=2
   Case tolower(right$(PARAM,len(PARAM)-2))
    When "deb" : PARAM  = left$(PARAM,len(PARAM)-3)+"fin"
    When "str" : PARAM  = left$(PARAM,len(PARAM)-3)+"end"
   Endcase
   Gosub MODVIR
  Endif
 Endif
Next ARD
End

$MODVIR
For I=1 To NBPAR
 If toupper(left$(PARAMETRES(I),L+1))=toupper(PARAM+"=")
  K = ascii(mid$(PARAMETRES(I),L+2,1))
  If K<20
   VALEUR = right$(PARAMETRES(I),L+3)
   If instr(1,VALEUR,".")<>0
    PARAMETRES(I)=left$(PARAMETRES(I),L+2)+ctrans(VALEUR,".",",")
   Endif
  Else
   VALEUR = right$(PARAMETRES(I),L+2)
   If instr(1,VALEUR,".")<>0
    PARAMETRES(I)=left$(PARAMETRES(I),L+1)+ctrans(VALEUR,".",",")
   Endif
  Endif
  Break
 Endif
Next I
Return

##################################################################################
Subprog ALIMETAT (ETAT, FONCTION, TBPAR, TBVAL, TRTINI, REQUETE, NUMLIG)
Value    Char    ETAT
Value    Char    FONCTION
Value    Char    TBPAR () (1..)
Value    Char    TBVAL () (1..)
Variable Char    TRTINI ()
Variable Integer REQUETE
Variable Integer NUMLIG

Global Integer GWNUMREQ     : # pour passage du no de requete
If clalev([ARP])=0 : Local File AREPORT [ARP] : Endif
If TRTINI=""                : # pour recuperer le traitement (uniquement la première fois)
  Read [ARP] ARP0=ETAT
  If fstat : End : Endif
  TRTINI=[F:ARP]TRTINI
Endif

# faire appel au s/p du document (ex: SBONFAC) pour ajouter une ligne
GWNUMREQ=REQUETE
Gosub ALIMETAT From =TRTINI
REQUETE=GWNUMREQ
End

$ALIMETAT_PE
# point d'entree commun appele du traitement d'impression
GPOINT="ALIMETAT" : Gosub ENTREE From EXEFNC
Return


##################################################################################
#  Modifie les paramètres d'impression pour rajouter un chr$(1) après le =
#  pour les paramètres dont le nom commence par __ ou ceux sans _
##################################################################################

Subprog PARAMPRINT(PARAM,NBPAR)
Variable Char PARAM()(1..)
Value Integer NBPAR
If dbglong(3)<2 : End : Endif
Local Integer I , J , K , L
Local Char OLDPAR(250) , NOMPAR(250)
OLDPAR = ""
For I=1 To NBPAR
 If left$(PARAM(I),9)<>"___TABLE_" & (left$(PARAM(I),2)="__" or left$(PARAM(I),1)<>"_")
  J = instr(1,PARAM(I),"=")
  If J>0
   If ascii(mid$(PARAM(I),J+1,1))<>255
    NOMPAR = left$(PARAM(I),J-1)
    If NOMPAR=OLDPAR
     L += 1
    Else
     L = 1
     OLDPAR = NOMPAR
    Endif
    K = ascii(mid$(PARAM(I),J+1,1))
    If K<>L
     If K<20
      PARAM(I) = left$(PARAM(I),J)+chr$(L)+right$(PARAM(I),J+2)
     Else
      PARAM(I) = left$(PARAM(I),J)+chr$(L)+right$(PARAM(I),J+1)
     Endif
    Endif
   Else
    PARAM(I) = left$(PARAM(I),J)+chr$(1)+right$(PARAM(I),J+2)
   Endif
  Endif
 Endif
Next I
End

######################################
Subprog EDTMSG(ETAT,IMPRIMANTE,MSG)
Value Char ETAT(), IMPRIMANTE(), MSG()

If !clalev([F:ARP]) : Local File AREPORT [ARP] : Endif
Local Char TEXETA(GLONDES)

Call LECTURE("ARP",ETAT,"") From CONTOBJ
Call TEXTE([F:ARP]RPTDES,TEXETA) From OBJDIV
# Impression de l'état, Imprimante
If left$(IMPRIMANTE,1)="?"
 Local Integer OK
 IMPRIMANTE=right$(IMPRIMANTE,2)
 Call OUINON(mess(10,135,1)-ETAT+"\"+TEXETA
&            +string$(MSG<>"","\"+MSG)
&            +string$(IMPRIMANTE<>"","\"+mess(16,135,1)-IMPRIMANTE),OK) From GESECRAN
 If OK=2 : GOK=1 : Else GOK=0 : Endif
Elsif GTRACE=""
 Call MESSAGE(mess(10,135,1)-ETAT+"\"+TEXETA
&            +string$(MSG<>"","\"+MSG)
&            +string$(IMPRIMANTE<>"","\"+mess(16,135,1)-IMPRIMANTE)) From GESECRAN
Else
 Call ECR_TRACE(mess(10,135,1)-ETAT-TEXETA
&              -MSG
&              -string$(IMPRIMANTE<>"","->"-mess(16,135,1)-IMPRIMANTE)
&              ,0) From GESECRAN
Endif
End

###############################################################################
Subprog SETPARAMPLAG(PARAM,NBPAR,PARAMETRES,VALDEB,VALFIN,NBVAL)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Variable Char    VALDEB()(1..)
Variable Char    VALFIN()(1..)
Variable Integer NBVAL
Local Integer I,J,K,NBPL,NBPLD
I = 1
While I<NBPAR
 J = instr(1,PARAMETRES(I),"_"+PARAM+"=")
 If J
  Dela I,1 PARAMETRES
  NBPAR -= 1
 Else
  I += 1
 Endif
Wend
For I=1 To NBVAL
 If VALFIN(I)="" or VALDEB(I)=VALFIN(I)
  NBPLD +=1
  NBPAR +=1
  PARAMETRES(NBPAR) = "]["+num$(NBPLD)+"_"+PARAM+"="+chr$(255)+VALDEB(I)
 Else
  NBPL +=1
  NBPAR +=1
  PARAMETRES(NBPAR) = "[["+num$(NBPL)+"_"+PARAM+"="+chr$(255)+VALDEB(I)
  NBPAR +=1
  PARAMETRES(NBPAR) = "]]"+num$(NBPL)+"_"+PARAM+"="+chr$(255)+VALFIN(I)
 Endif
Next I
End

###############################################################################
Subprog GETPARAMPLAG(PARAM,NBPAR,PARAMETRES,VALDEB,VALFIN,NBVAL)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Variable Char    VALDEB()(1..)
Variable Char    VALFIN()(1..)
Variable Integer NBVAL

Local Integer I,WNBVAL
Local Char    VALPAR(dim(PARAMETRES))
Local Char    WVALDEB(dim(PARAMETRES))(1..250), WVALFIN(dim(PARAMETRES))(1..250)

For I=1 To NBPAR
 L = instr(0,PARAMETRES(I),"_"+PARAM+"=")
 If L
  WNBVAL+= 1
  WVALDEB(WNBVAL) = right$(PARAMETRES(I),L+1+len("_"+PARAM+"="))
  WVALFIN(WNBVAL) = left$(PARAMETRES(I),L-2+len("_"+PARAM+"="))
  If right$(PARAMETRES(I),L+2+len("_"+PARAM+"=")) = "_ALPHA_RANGE_MIN"
   WVALDEB(WNBVAL) = "  "
  Elsif right$(PARAMETRES(I),L+2+len("_"+PARAM+"=")) = "_ALPHA_RANGE_MAX"
   WVALDEB(WNBVAL) = "zzzzzzzzzz"
#  Elsif (left$(PARAMETRES(I),2)="__" or left$(PARAMETRES(I),1)<>"_")
#&  & ascii(left$(WVALDEB(WNBVAL),1))>=1 & ascii(left$(WVALDEB(WNBVAL),1))<=20
  Elsif ascii(left$(WVALDEB(WNBVAL),1))>=1 & ascii(left$(WVALDEB(WNBVAL),1))<=20
   WVALDEB(WNBVAL) = right$(WVALDEB(WNBVAL),2)
  Endif
 Endif
Next I

For I=1 To WNBVAL
 Case left$(WVALFIN(I),2)
  When  "]["
   NBVAL += 1
   VALDEB(NBVAL) = WVALDEB(I)
  When "[["
   L = find("]]"+right$(WVALFIN(I),3),WVALFIN(1..WNBVAL))
   If L
    NBVAL +=1
    VALDEB(NBVAL) = WVALDEB(I)
    VALFIN(NBVAL) = WVALDEB(L)
   Endif
 Endcase
Next I
End

