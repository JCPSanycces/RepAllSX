#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When 'DEBUT'        : Gosub DEBUT
  When 'ENR'          : Gosub ENR
  When 'APRES_MODIF'  : Gosub APRES_MODIF
Endcase
Return

$APRES_MODIF
REP = "M"
Chgfmt [M:TRND]ATCOMICO With "-K:3X"
Return

$DEBUT
Raz [M:TRND]
If clalev([F:SGH2])= 0 : Local File SCHGH [SGH2] : Endif
Call READ_SCS([M:SCS1]VCRNUM)
Return
######################################################################
######################################################################
$ENR
Call WRITE_SCS([M:SCS1]VCRNUM)
REP=''
Read [F:SGH2]SGH0=[M:SCS1]VCRNUM
If fstat : Raz [SGH2] : Endif
Gosub SET_AT
Return
######################################################################
######################################################################
Subprog READ_SCS(VCRNUM)
Value Char VCRNUM

If [L]VCRNUM = "" : End : Endif

If clalev([F:SGH2]) = 0 : Local File SCHGH    [SGH2] : Endif
If clalev([F:DKD2]) = 0 : Local File DKSDATA  [DKD2] : Endif
Local Char DTYP(250)

Read [F:SGH2]SGH0 = [L]VCRNUM
If fstat <> 0
   Close File [SGH2]
   End
Else
  [M:TRND]DPEDAT      = [F:SGH2]DPEDAT
  [M:TRND]ETD         = [F:SGH2]ETD
  [M:TRND]ARVDAT      = [F:SGH2]ARVDAT
  [M:TRND]ETA         = [F:SGH2]ETA
  [M:TRND]LICPLATE    = [F:SGH2]LICPLATE
  [M:TRND]TRLLICPLATE = [F:SGH2]TRLLICPLATE
  [M:TRND]MANDOC      = [F:SGH2]MANDOC

  If [F:SGH2]CFMFLG=2
    Read [F:DKD2]DKD0='SAFT-PT';[F:SGH2]SGHTYP;[F:SGH2]VCRNUM
    If !fstat & [F:DKD2]ATDTCOD<>''
      [M:TRND]ATDTCOD = [F:DKD2]ATDTCOD
    Endif
  Else
    [M:TRND]ATDTCOD = [F:SGH2]ATDTCOD
  Endif
  Gosub SET_AT

  Endif

End
######################################################################
######################################################################
Subprog WRITE_SCS(VCRNUM)
Value Char VCRNUM

If [L]VCRNUM = "" : End : Endif

If clalev([F:SGH2]) = 0 : Local File SCHGH [SGH2] : Endif

Read [F:SGH2]SGH0 = [L]VCRNUM
If fstat <> 0
   Close File [SGH2]
   End
Else
   [F:SGH2]DPEDAT       = [M:TRND]DPEDAT
   [F:SGH2]ETD          = [M:TRND]ETD
   [F:SGH2]ARVDAT       = [M:TRND]ARVDAT
   [F:SGH2]ETA          = [M:TRND]ETA
   [F:SGH2]LICPLATE     = [M:TRND]LICPLATE
   [F:SGH2]TRLLICPLATE  = [M:TRND]TRLLICPLATE
   [F:SGH2]ATDTCOD      = [M:TRND]ATDTCOD
   If [F:SGH2]CFMFLG <> 2
    [F:SGH2]MANDOC = [M:TRND]MANDOC
   Endif

   Rewrite [F:SGH2]
   #To manage the Communication button
   Gosub SET_AT

   If clalev([F:SGH]) & [F:SGH]VCRNUM = [L]VCRNUM
     [F:SGH]DPEDAT     = [M:TRND]DPEDAT
     [F:SGH]ETD        = [M:TRND]ETD
     [F:SGH]ARVDAT     = [M:TRND]ARVDAT
     [F:SGH]ETA        = [M:TRND]ETA
     [F:SGH]LICPLATE   = [M:TRND]LICPLATE
     [F:SGH]ATDTCOD    = [M:TRND]ATDTCOD
     If [F:SGH]CFMFLG <> 2
      [F:SGH]MANDOC = [M:TRND]MANDOC
     Endif
   Endif

Endif

End

Subprog AS_GLBDOCTYP(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
For I=1 To  dim(GMENLOC)-1
  GMENLOC(I)=1
Next
GMENLOC(2) = 0
GMENLOC(3) = 0
GMENLOC(10) = 0
End

Subprog AM_GLBDOCNUM(VALEUR)
Variable Char    VALEUR()
Local Char MSK(250) : [L]MSK = ''
If clalev([F:PTSDH])= 0 : Local File SDELIVERY  [PTSDH] : Endif
If clalev([F:PTSRH])= 0 : Local File SRETURN    [PTSRH] : Endif
If clalev([F:PTTNH])= 0 : Local File TRANNOTEH  [PTTNH] : Endif

Case GFONCTION
  When "GESSDH"
    Case [M:SDH3]GLBDOCTYP
      When 2
        Read [F:PTSDH]SDH0=VALEUR
        [M:SDH3]GLBDOCDAT = [F:PTSDH]SHIDAT
      When 3
        Read [F:PTSRH]SRH0=VALEUR
        [M:SDH3]GLBDOCDAT = [F:PTSRH]RTNDAT
      When 10
        Read [F:PTTNH]TNH0=VALEUR
        [M:SDH3]GLBDOCDAT = [F:PTTNH]TRNDAT
    Endcase
    Affzo [M:SDH3]GLBDOCDAT
  When "GESSRH"
    Case [M:SRH2]GLBDOCTYPR
      When 2
        Read [F:PTSDH]SDH0=VALEUR
        [M:SRH2]GLBDOCDATR = [F:PTSDH]SHIDAT
      When 3
        Read [F:PTSRH]SRH0=VALEUR
        [M:SRH2]GLBDOCDATR = [F:PTSRH]RTNDAT
      When 10
        Read [F:PTTNH]TNH0=VALEUR
        [M:SRH2]GLBDOCDATR = [F:PTTNH]TRNDAT
    Endcase
    Affzo [M:SRH2]GLBDOCDATR
  When "GESSRL"
    Case [M:SRL2]GLBDOCTYPR
      When 2
        Read [F:PTSDH]SDH0=VALEUR
        [M:SRL2]GLBDOCDATR = [F:PTSDH]SHIDAT
      When 3
        Read [F:PTSRH]SRH0=VALEUR
        [M:SRL2]GLBDOCDATR = [F:PTSRH]RTNDAT
      When 10
        Read [F:PTTNH]TNH0=VALEUR
        [M:SRL2]GLBDOCDATR = [F:PTTNH]TRNDAT
    Endcase
    Affzo [M:SRL2]GLBDOCDATR
  When "GESSRS"
   Case [M:SRS2]GLBDOCTYPR
      When 2
        Read [F:PTSDH]SDH0=VALEUR
        [M:SRS2]GLBDOCDATR = [F:PTSDH]SHIDAT
      When 3
        Read [F:PTSRH]SRH0=VALEUR
        [M:SRS2]GLBDOCDATR = [F:PTSRH]RTNDAT
      When 10
        Read [F:PTTNH]TNH0=VALEUR
        [M:SRS2]GLBDOCDATR = [F:PTTNH]TRNDAT
    Endcase
    Affzo [M:SRS2]GLBDOCDATR
  When "GESTNH"
   Case [M:TNH2]GLBDOCTYP
      When 2
        Read [F:PTSDH]SDH0=VALEUR
        [M:TNH2]GLBDOCDAT = [F:PTSDH]SHIDAT
      When 3
        Read [F:PTSRH]SRH0=VALEUR
        [M:TNH2]GLBDOCDAT = [F:PTSRH]RTNDAT
      When 10
        Read [F:PTTNH]TNH0=VALEUR
        [M:TNH2]GLBDOCDAT = [F:PTTNH]TRNDAT
    Endcase
    Affzo [M:TNH2]GLBDOCDAT
Endcase

Close File [PTSDH]
Close File [PTSRH]
Close File [PTTNH]
End


######################################################################################
######################################################################################
## Section automatically added (screen TRNDOC) 27-06-2014 11:48:14 ()
######################################################################################
Subprog AS_DPEDAT(VALEUR)
Variable Date    VALEUR
Call DIS_MANDOC(GFONCTION)
End


Subprog C_ARVDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <>[0/0/0]
  Case GFONCTION
    When Default
      If VALEUR < [M:TRND]DPEDAT
        Call ERREUR(mess(93,7711,1)) From GESECRAN
        mkstat=2
      Endif
  Endcase
Endif
End

Subprog C_ETA(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000" : End : Endif
Case GFONCTION
  When Default
    If [M:TRND]DPEDAT<>[0/0/0] & [M:TRND]ARVDAT<>[0/0/0]
      If [M:TRND]DPEDAT=[M:TRND]ARVDAT & VALEUR<=[M:TRND]ETD
         Call ERREUR(mess(69,134,1)) From GESECRAN
         mkstat=2
      Endif
    Endif
Endcase
End

Subprog C_MANDOC(VALEUR)
Variable Char    VALEUR()
Local Integer CTRL      :[L]CTRL       = 1

If VALEUR<>''
  #BRBAN 30-06-2014 Law 500001
  Call CTRL_STRUCT(VALEUR,[L]CTRL) From PORLEGLIB
  If [L]CTRL = 0
    Call ERREUR(mess(135,7711,1)) From GESECRAN
    mkstat = 2
    End
  Endif
  If find(GREP,'C','D')
    Case GFONCTION
      When "GESSRH"
        Call CONT_MANINV('',[M]SRHNUM ,[M]ENTRTNDAT ,GFONCTION,GREP,VALEUR,[F:TRE]RECTYP,[L]CTRL) From PORLEGLIB
        If [L]CTRL = 0
          mkstat = 2
        Endif
      When "GESSRL","GESSRS"
        Call CONT_MANINV('',[M]SRHNUM ,[M]RTNDAT ,GFONCTION,GREP,VALEUR,[F:TRE]RECTYP,[L]CTRL) From PORLEGLIB
        If [L]CTRL = 0
          mkstat = 2
        Endif
      When "GESTNH"
        Call CONT_MANINV('',[M:TNH0]TNHNUM ,[M:TNH0]TRNDAT ,GFONCTION,GREP,VALEUR,[F:TTN]RECTYP,[L]CTRL) From PORLEGLIB
        If[L]CTRL = 0
          mkstat = 2
        Endif
    Endcase
  Else
    Case GFONCTION
     When "GESSDH"
      Call CONT_MANINV('',[F:SDH]SDHNUM,[F:SDH]SHIDAT,GFONCTION,GREP,VALEUR,[F:TSD]RECTYP,[L]CTRL) From PORLEGLIB
      If [L]CTRL = 0
        mkstat = 2
      Endif
     When "GESPNH"
      Local File TABPNHTYP [TPN]
      Local Integer RET : [L]RET = 0
      Call LEC_TPN_LEG([F:FCY]LEG,[F:PNH]PNHTYP,RET) From TRTLECLEG

      Call CONT_MANINV('',[F:PNH]PNHNUM,[F:PNH]RTNDAT,GFONCTION,GREP,VALEUR,[F:TPN]RECTYP ,[L]CTRL) From PORLEGLIB
      If[L]CTRL = 0
        mkstat = 2
      Endif
     When "GESSIS","GESSST","GESSTR"

      Call CONT_MANINV(num$([F:SGH]BETFCYCOD),[F:SGH]VCRNUM,[F:SGH]IPTDAT,GFONCTION,GREP,VALEUR,[F:TSG]RECTYP,[L]CTRL) From PORLEGLIB
      If[L]CTRL = 0
        mkstat = 2
      Endif
     When "GESSRH","GESSRL","GESSRS"
      Local Integer RET : [L]RET = 0
      Call LEC_TRE_LEG([F:FCY]LEG,[F:SRH]SRHTYP,[L]RET) From TRTLECLEG

      Call CONT_MANINV('',[F:SRH]SRHNUM ,[F:SRH]RTNDAT ,GFONCTION,GREP,VALEUR,[F:TRE]RECTYP,[L]CTRL) From PORLEGLIB
      If [L]CTRL = 0
        mkstat = 2
      Endif
     When "GESTNH"
      Call CONT_MANINV('',[F:TNH]TNHNUM ,[F:TNH]TRNDAT ,GFONCTION,GREP,VALEUR,[F:TTN]RECTYP,[L]CTRL) From PORLEGLIB
      If[L]CTRL = 0
        mkstat = 2
      Endif
    Endcase
  Endif
Endif
End
#####################################################################################
$CTRL_ETD
#TODO : Isto tinha aqui mais codigo,abrir a v6 e falar com o ricardo
Local Char DATCTR(250) : [L]DATCTR = ''

[L]DATCTR = format$("D:YYYY[-]MM[-]DD",[M:TRND]DPEDAT)+"T"+format$("hh[:]mm[:]ss",ctrans(VALEUR,":","")+"00")
If [L]DATCTR < format$("D:YYYY[-]MM[-]DD",date$)+"T"+format$("hh[:]mm[:]ss",ctrans(time$,":","")+"00")
   Call ERREUR(mess(92,7711,1)) From GESECRAN
   mkstat=2
Endif

Return

$SET_AT
If clalev([F:DKD]) = 0  : Local File DKSDATA [DKD] : Endif
Diszo [M:TRND]ATDTCOD#,ATCOMICO
Chgfmt [M:TRND]ATCOMICO With "-K:3X"

Case GFONCTION
  When "GESSIS","GESSST","GESSTR"
    If func PORLEGLIB.DOCCTR(6,'', [F:SGH2]SGHTYP, [F:SGH2]STOFCY) = 1
      If [F:SGH2]CFMFLG<>2
        Actzo [M:TRND]ATDTCOD
      Else
        Read [F:DKD]DKD0 = "SAFT-PT";[F:SGH2]SGHTYP;[F:SGH2]VCRNUM
        # BRBAN 24-03-2015 #106027
        If !fstat & [F:DKD]ATDTCOD = "" & func PORLEGLIB1.CTRL_COMDAT([F:SGH2]STOFCY,[F:SGH2]DPEDAT,[F:SGH2]ETD)=1
          Chgfmt [M:TRND]ATCOMICO With "K:3X"
        Elsif [F:DKD]ATDTCOD<>''
          Diszo [M:TRND]
        Endif
      Endif
    Endif
Endcase
Close File [F:DKD]
Affzo [M:TRND]
Return

Subprog DIS_MANDOC(FONC)
Value Char FONC
Case [L]FONC
   When "GESSDH"
    If(find([F:TSD]RECTYP,2,3) & [F:SDH]CFMFLG=2) | [F:TSD]RECTYP=1
      Diszo [M:SDH3]MANDOC
      Affzo [M:SDH3]MANDOC
    Endif
   When "GESPNH"
    If (find([F:TPN]RECTYP,2,3) & [F:PNH]CFMFLG=2)  | [F:TPN]RECTYP=1
      Diszo [M:PNH2]MANDOCR
      Affzo [M:PNH2]MANDOCR
    Endif
   When "GESSIS","GESSST","GESSTR"
    If (find([F:TSG]RECTYP,2,3) & [F:SGH]CFMFLG=2) |  [F:TSG]RECTYP=1
      Diszo [M:TRND]MANDOC
      Affzo [M:TRND]MANDOC
    Endif
   When "GESSRH"
    If (find([F:TRE]RECTYP,2,3) & [F:SRH]SRHCFMFLG=2) | [F:TRE]RECTYP=1
      Diszo [M:SRH2]MANDOCR
      Affzo [M:SRH2]MANDOCR
    Endif
   When "GESSRL"
     If (find([F:TRE]RECTYP,2,3) & [F:SRH]SRHCFMFLG=2) | [F:TRE]RECTYP=1
      Diszo [M:SRL2]MANDOCR
      Affzo [M:SRL2]MANDOCR
    Endif
   When "GESSRS"
     If (find([F:TRE]RECTYP,2,3) & [F:SRH]SRHCFMFLG=2) | [F:TRE]RECTYP=1
      Diszo [M:SRS2]MANDOCR
      Affzo [M:SRS2]MANDOCR
    Endif
   When "GESTNH"
     If (find([F:TTN]RECTYP,2,3) & [F:TNH]CFMFLG=2) | [F:TTN]RECTYP=1
      Diszo [M:TNH2]MANDOC
      Affzo [M:TNH2]MANDOC
    Endif
Endcase

End


Subprog CL_ATCOMICO(VALEUR)
Variable Char    VALEUR()
If clalev([F:DKD2])=0 : Local File DKSDATA [DKD2] : Endif

Read [F:DKD2]DKD0='SAFT-PT';[F:SGH]SGHTYP;[F:SGH]VCRNUM
If !fstat & [F:DKD2]ATDTCOD<>''
  [M:TRND]ATDTCOD= [F:DKD2]ATDTCOD
  Chgfmt [M:TRND]ATCOMICO With "- K:3X"
  Diszo [M:TRND]LICPLATE,DPEDAT,ETD,ARVDAT,ETA,TRLLICPLATE
  Affzo [M:TRND]LICPLATE,DPEDAT,ETD,ARVDAT,ETA,TRLLICPLATE,ATDTCOD
Endif
End


Subprog AM_GLBDOC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Case GFONCTION
    When "GESSDH"
      Raz [M:SDH3]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
      Diszo [M:SDH3]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
      Affzo [M:SDH3]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
    When "GESSRH"
      Raz [M:SRH2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
      Diszo [M:SRH2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
      Affzo [M:SRH2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
    When "GESSRL"
      Raz [M:SRL2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
      Diszo [M:SRL2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
      Affzo [M:SRL2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
    When "GESSRS"
      Raz [M:SRS2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
      Diszo [M:SRS2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
      Affzo [M:SRS2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
    When "GESTNH"
      Raz [M:TNH2]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
      Diszo [M:TNH2]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
      Affzo [M:TNH2]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
  Endcase
Else
  Case GFONCTION
    When "GESSDH"
      Actzo [M:SDH3]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
    When "GESSRH"
      Actzo [M:SRH2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
    When "GESSRL"
      Actzo [M:SRL2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
    When "GESSRS"
      Actzo [M:SRS2]GLBDOCNUMR,GLBDOCDATR,GLBDOCTYPR
    When "GESTNH"
      Actzo [M:TNH2]GLBDOCNUM,GLBDOCDAT,GLBDOCTYP
  Endcase
Endif
End

