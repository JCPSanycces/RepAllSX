#<AdxTL>@(#)1.0.0.0 $Revision$
$ACTION
Case ACTION
 When "FIN"   : Gosub FIN
Endcase
Return

$FIN
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat | [F:ADS]MODULE(4)<>2 : # 4= Module Formation
 Call ECR_TRACE("---"-mess(5,14,1)-":"-mess(58,125,1),0) From GESECRAN
Else
 If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
 Call DEBTRANS From GLOCK
 Gosub TR_PAR
Endif
Return

$TR_PAR
GOK = 1
Trbegin [ADW]
 For PARAMTX="TXHRPAT","TXHRPAT2","TXHRSAL","TXHRSAL2"
  Readlock [ADW]ADW0 = "";"";PARAMTX
  If fstat=1
   GOK = -1 : GLOCK = "$ADOVAL"-PARAMTX : Goto ROLL_PAR
  Elsif fstat
   Raz [F:ADW]
   [F:ADW]PARAM = PARAMTX
   Gosub RUB
   Write [ADW]
  Else
   Gosub RUB
   Rewrite [ADW]
  Endif
  If fstat
   GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_PAR
  Endif
 Next
Commit
Return

$RUB
Case PARAMTX
 When "TXHRPAT"  : [F:ADW]VALEUR = "TX_FORM_PI"
 When "TXHRPAT2" : [F:ADW]VALEUR = "TX_FORM_P"
 When "TXHRSAL"  : [F:ADW]VALEUR = "TX_FORM_SI"
 When "TXHRSAL2" : [F:ADW]VALEUR = "TX_FORM_S"
Endcase
Return


$ROLL_PAR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PAR : Endif
Return

$AB_PAR
Rollback
