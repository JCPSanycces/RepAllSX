#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT6 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRCTR
mkstat = 0
zoncou = "NBRCTR"
indice = 0
status = 1
zoncou = "NBRCTR"
If varmode([M]NBRCTR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRCTR From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRCTR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCTR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCTR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCTR = nolign
   status = 75
   Call SAI_NBRCTR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ICO
mkstat = 0
zoncou = "ICO"
indice = 0
If varmode([M]ICO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ICO" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRFCY
mkstat = 0
zoncou = "ETRFCY"
indice = 0
If varinit([M]ETRFCY,indice)=0
 [M]ETRFCY = GFCYDEF
Endif

## Zone CALPAY
mkstat = 0
zoncou = "CALPAY"
indice = 0
IMPENT = [M]CALPAY
If varinit([M]CALPAY,indice)=0
 IMPENT = 1
Endif
[M]CALPAY = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone TYPJOB
mkstat = 0
zoncou = "TYPJOB"
indice = 0
IMPENT = [M]TYPJOB
If varinit([M]TYPJOB,indice)=0
 IMPENT = 1
Endif
[M]TYPJOB = IMPENT

## Zone STAEMP
mkstat = 0
zoncou = "STAEMP"
indice = 0
IMPENT = [M]STAEMP
If varinit([M]STAEMP,indice)=0
 IMPENT = 1
Endif
[M]STAEMP = IMPENT

## Zone PLNDES
mkstat = 0
zoncou = "PLNDES"
indice = 0
SAVACT = GACTION : GACTION = "STD"
Call AV_PLNDES([M]PLNDES) From SUBEML2
GACTION = SAVACT
If mkstat=1 : Raz [M]PLNDES : Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone XITFNL
mkstat = 0
zoncou = "XITFNL"
indice = 0
IMPENT = [M]XITFNL
If varinit([M]XITFNL,indice)=0
 IMPENT = 1
Endif
[M]XITFNL = IMPENT

## Zone XITLEA
mkstat = 0
zoncou = "XITLEA"
indice = 0
If varinit([M]XITLEA,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]XITLEA,"10379","") From SUBADI
 GACTION = SAVACT
Endif

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone FLGCRECTR
mkstat = 0
zoncou = "FLGCRECTR"
indice = 0
IMPENT = [M]FLGCRECTR
If varinit([M]FLGCRECTR,indice)=0
 IMPENT = 1
Endif
[M]FLGCRECTR = IMPENT

## Zone FLGCRELET
mkstat = 0
zoncou = "FLGCRELET"
indice = 0
IMPENT = [M]FLGCRELET
If varinit([M]FLGCRELET,indice)=0
 IMPENT = 1
Endif
[M]FLGCRELET = IMPENT

## Zone FLGCREAVN
mkstat = 0
zoncou = "FLGCREAVN"
indice = 0
IMPENT = [M]FLGCREAVN
If varinit([M]FLGCREAVN,indice)=0
 IMPENT = 1
Endif
[M]FLGCREAVN = IMPENT

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRCTR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCTR
mkstat = 0
zoncou = "NBRCTR"

## Zone LEGCTR
mkstat = 0
zoncou = "LEGCTR"
If varinit([M]LEGCTR,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEGCTR(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone NBRCTR
mkstat = 0
zoncou = "NBRCTR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRMAT6"
Return

