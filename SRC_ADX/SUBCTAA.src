End
##########################################################################################################
# Objet TCA
##########################################################################################################
##########################################################################################################
$OUVRE
Global Instance GZINSCATTSK Using C_PJMTSKCAT           # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  ANOWRITE = 1
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSCATTSK <> null Then
    FreeGroup GZINSCATTSK
  Endif
  Kill GZINSCATTSK
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$LIENS
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSCATTSK <> null Then
    FreeGroup GZINSCATTSK
  Endif
  GZINSCATTSK = NewInstance C_PJMTSKCAT AllocGroup null
  [L]MY_STATUS = fmet GZINSCATTSK.AREAD([M:CTA0]TCACOD)
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSCATTSK)
    GOK = 0
    GERR = 1
    Return
  Endif
  Call SHOW_RECORD(GZINSCATTSK)
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$RAZCRE
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  If GZINSCATTSK <> null Then
    FreeGroup GZINSCATTSK
  Endif
  GZINSCATTSK = NewInstance C_PJMTSKCAT AllocGroup null
  [L]MY_STATUS = fmet GZINSCATTSK.AINIT()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSCATTSK)
    GOK = 0
    GERR = 1
    Return
  Endif
  # -------------------------------
  Call SHOW_RECORD(GZINSCATTSK)  # Take back init values
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$RAZDUP
  # ----------------------------------------------------------
  # Hybrid part (begin)
  Gosub RELIT From GOBJSUB
  GMESSAGE = mess(464,2260,1)
  GOK = 0
  GERR = 1
  REP = ""
  mkstat = 2
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$CREATION
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  [L]MY_STATUS = fmet GZINSCATTSK.AINSERT()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSCATTSK)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(166,2260,1)
    Endif
    GOK = 0
    GERR = 1
    Return
  Endif
  # ----------------------------------------------------------
  [M:CTA0]TCACOD = GZINSCATTSK.TCACOD
  Affzo [M:CTA0]TCACOD
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$APRES_CRE
  Gosub RELIT From GOBJSUB
Return

##########################################################################################################
$MODIF
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  [L]MY_STATUS = fmet GZINSCATTSK.AUPDATE()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSCATTSK)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(167,2260,1)
    Endif
    GOK = 0
    GERR = 1
    Return
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
$APRES_MOD
  Gosub RELIT From GOBJSUB
Return

##########################################################################################################
$AV_ANNULE
Local Integer ANOWRITE

  ANOWRITE = 1
Return

##########################################################################################################
$ANNULE
Local Integer MY_STATUS                          # Hybrid part

  # ----------------------------------------------------------
  # Hybrid part (begin)
  [L]MY_STATUS = fmet GZINSCATTSK.ADELETE()
  If [L]MY_STATUS >= [V]CST_AERROR Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSCATTSK)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(168,2260,1)
    Endif
    GOK = 0
    GERR = 1
    Return
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
Return

##########################################################################################################
# SUBROUTINES
##########################################################################################################
Subprog RECOVERS_ERROR_IN_CLASSIC(GZINSCATTSK)
Variable Instance GZINSCATTSK Using C_PJMTSKCAT

Local Integer NI                                 # Hybrid part
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE

  # ----------------------------------------------------------
  # Hybrid part (begin)
  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(GZINSCATTSK, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GMESSAGE = SMESSAGE
    GERR = 2
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GMESSAGE = SMESSAGE
    GOK = 0
    GERR = 1
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
  # To help debug process : write a classic log file with all errors in class.
  #Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
  #Call ECR_TRACE("->", 0) From GESECRAN
  #Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(GZINSCATTSK) From SYRSTACKTOOLS
  #Call FERME_TRACE From LECFIC
  # ----------------------------------------------------------
End

##########################################################################################################
Subprog SHOW_RECORD(GZINSCATTSK)
Variable Instance GZINSCATTSK Using C_PJMTSKCAT

  SetInstance [M:CTA0] With GZINSCATTSK
  SetInstance [M:CTA1] With GZINSCATTSK
  Affzo [M:CTA0]
  Affzo [M:CTA1]
End

