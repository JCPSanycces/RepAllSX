###############################################################################
# Issue 110210/8 - 2015-12-14 by JUSYN : New labels for supervisor update
# Issue 114035/3/4 - 2016-02-17 by BAKHA : Initialise new fields NCSROOCAU and NCSPROCAU
# Issue X3-62786 - 2017-11-21 by BAKHA : Initialse all local menus for Hybrid
# Issue X3-69858 - 2018-01-03 by BAKHA : Initialise QA manager and Planner to blank
# Issue X3-74449 - 2018-02-09 by BAKHA : Set default closed state to 0
# Issue X3-76268 - 2018-02-13 by JUSYN : Remove/deactivate email notification NCS (2018-02-28)
# Issue X3-77826 - 2018-03-09 by BAKHA : Add a method for check document number
# Issue X3-83483 - 2018-05-01 by BAKHA : Remove initial values for Reason, Root cause and Probable cause
# Issue X3-94378 - 2018-06-05 by BAKHA : Changes due to table/class renaming
# Issue X3-84473 - 2018-06-26 by BAKHA : Add new method for creating document lines
# Issue X3-105283 - 2018-08-29 by BAKHA : Authorisation check removed for NC approvers and actioners
# Issue X3-104585 - 2018-09-03 by BAKHA : Add sublot to document lines, also fix issue with lines created for
#                                         non-stock managed products and services
# Issue X3-105269 - 2018-09-18 by BAKHA : Remove authorisation checks on Planner and QA Manager.
# Issue X3-108668 - 2018-09-21 by BAKHA : Changed REJECTCOD from local  menu to ADI

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"                            : Gosub INITIALISE
      Endcase
  Endcase
Return

# Issue X3-62786 - 2017-11-22 by JUSYN : Moved IS_USER_PLANNER here to class from representation
$METHODS
  Case [L]AMETHOD
    When "DUPLICATE_PRODUCT"                : Gosub DUPLICATE_PRODUCT
    When "IS_USER_PLANNER"                  : Gosub IS_USER_PLANNER
    When "IS_ADMIN_USER"                    : Gosub IS_ADMIN_USER
    When "IS_DOCUMENT_VALID"                : Gosub IS_DOCUMENT_VALID     # X3-77826 - check document no
    When "CREATE_DOCUMENT_LINES"            : Gosub CREATE_DOCUMENT_LINES # Issue X3-84473
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
    When "UPDATE_IMPLEMENT_STATUS"          : Gosub UPDATE_IMPLEMENT_STATUS
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "NCSMANAGER"
      Case [L]ARULE
        When "CONTROL"
          Gosub VALIDATE_QA_MANAGER
      Endcase
    When "NCSPLANNER"
      Case [L]ARULE
        When "CONTROL"
          Gosub VALIDATE_PLANNER
      Endcase
  Endcase
Return
###############################################################################

# ------------------------------------------------------
# Subroutine: INITIALISE
#
# Called from this Script.
# Set Impact Analysis 'Created' flag = 1 ...
#
$INITIALISE

  this.NCSREC = 2
  this.NCSSTA = 1
  this.CLOSEDATE = AVOID.ADATE
  this.CLOSEDST = 0 # X3-74449 set default closed state
  # Issue X3-87959 - 2018-04-27 by JUSYN : Check for ECC
  If dim(this.ECCVALMAJ) > 0
      this.ECCVALMAJ = ""
      this.ECCVALMIN = ""
  Endif
  # End issue X3-87959
  # Issue X3-62786 - setup default values for all local menus
  this.NCSCATEGORY = 4

  # Issue X3-83483 - Remove initial values for Reason, Root cause and Probable cause
  #this.NCSROOCAU = 19
  #this.NCSPROCAU = 8
  #this.NCSREASON = 2
  # Issue X3-83483 - end

  this.SEVERITY = 5
  this.IMPACT = 4
  this.REJECTCOD = "" # Issue X3-108668
  # Issue X3-62786 - end

  # X3-69858 - Set QA manager and Planner to blank
  this.NCSMANAGER = ""  # X3-69858
  this.NCSPLANNER = ""  # X3-69858

Return

# --------------------------------------------------
# Custom Method
# Check for duplicate product ...
# Return values:
# ARET_VALUE - CST_AERROR, CST_AINFO and 0
# MESSAGE    - corresponding message string.
$DUPLICATE_PRODUCT

  Local File NCSRECENT [NCSRC]

  MESSAGE = ""
  ARET_VALUE = 0

  # Issue 109094/15 - allow multiple non-conformances to be processed
  If (this.NCSSTA = 1 or
&      this.NCSSTA = 2 or
&     this.NCSSTA = 4 or
&     this.NCSSTA = 5 or
&     this.NCSSTA = 6)

    Filter [NCSRC] Where PRODUCT = this.PRODUCT and NCSID <> this.NCSID and NCSSTA >= 1 and NCSSTA <= 6
    Read [NCSRC] First
    If (fstat = 0)
      MESSAGE = mess(12,3702,1)
      ARET_VALUE = CST_AINFO
    Endif
  Endif
  # End issue 109094/15
  Filter [NCSRC]
  LogicClose File [NCSRC]

Return

# Issue X3-77826 - new method for checking Document number
# --------------------------------------------------
# Custom Method
# Check document number is valid
# Parameters : DOCTYP - document  type
#              DOCNUM - document number
# Return values:
# ARET_VALUE - CST_AERROR or 0
# MESSAGE    - corresponding message string.
$IS_DOCUMENT_VALID

  ARET_VALUE = 0
  MESSAGE = ""

  # check document exists
  Case DOCTYP

    When 1 : # check purchase receipt
             Local File PRECEIPT [PTH]
             Read [F:PTH]PTH0=DOCNUM
             If (fstat = 0)
               # check site
               If ([F:PTH]PRHFCY <> this.SITE)
                 MESSAGE = mess(289,194,1)
                 ARET_VALUE = CST_AERROR
               # if NCS supplier then check receipt for NCS supplier
               Elsif (this.NCSBPS <> "" and [F:PTH]BPSNUM <> this.NCSBPS)
                 MESSAGE = mess(282,194,1)
                 ARET_VALUE = CST_AERROR
               Endif
             Else
               MESSAGE = mess(79,121,1)
               ARET_VALUE = CST_AERROR
             Endif
             LogicClose File [PTH]

    When 2 : # check customer return
             Local File SRETURN [SRH]
             Read [F:SRH]SRH0=DOCNUM
             If (fstat = 0)
               # check site
               If ([F:SRH]STOFCY <> this.SITE)
                 MESSAGE = mess(103,192,1)
                 ARET_VALUE = CST_AERROR
               # if NCS supplier then check receipt for NCS supplier
               Elsif (this.NCSBPC <> "" and [F:SRH]BPCORD <> this.NCSBPC)
                 MESSAGE = mess(224,192,1)
                 ARET_VALUE = CST_AERROR
               Endif
             Else
               MESSAGE = mess(109,194,1)
               ARET_VALUE = CST_AERROR
             Endif
             LogicClose File [SRH]

    When 3 : # check production tracking
             Local File MFGHEADTRK [MTK]
             Read [F:MTK]MTK0=DOCNUM
             If (fstat = 0)
               # check site
               If ([F:MTK]MFGFCY <> this.SITE)
                 MESSAGE = mess(33,3702,1)
                 ARET_VALUE = CST_AERROR
               Endif
             Else
               MESSAGE = mess(214,195,1)-mess(9,155,1)
               ARET_VALUE = CST_AERROR
             Endif
             LogicClose File [MTK]

    When 4 : # check quailty control
             Local File STOQLYH [QLH]
             Read [F:QLH]QLH0=28;DOCNUM
             If (fstat = 0)
               # check site
               If ([F:QLH]STOFCY <> this.SITE)
                 MESSAGE = mess(34,3702,1)
                 ARET_VALUE = CST_AERROR
               Elsif (this.PRODUCT <> "" and [F:QLH]ITMREF <> this.PRODUCT)
                 MESSAGE = mess(35,3702,1)
                 ARET_VALUE = CST_AERROR
               Endif
             Else
               MESSAGE = mess(28,701,1)-mess(9,155,1)
               ARET_VALUE = CST_AERROR
             Endif
             LogicClose File [QLH]

  Endcase

Return
# Issue X3-77826 end

# --------------------------------------------------
# Method: UPDATE_IMPLEMENT_STATUS
#
# Determine the IMPLEMENT the state of the IMPLEMENT flag across all Detail Plans and
# Set the Change Request Status to Implement (from Plan) or Plan (from Implement).
$UPDATE_IMPLEMENT_STATUS

  Local Integer STAT, IMPLEMENT_STATUS, STATUS_CHANGE

  Local Instance MYNCSRECENT Using C_NCSRECENT
  MYNCSRECENT = NewInstance C_NCSRECENT AllocGroup null

  STAT = fmet MYNCSRECENT.AREAD(NCSID)
  If (STAT = CST_AOK)

    STATUS_CHANGE = CST_AFALSE

    IMPLEMENT_STATUS =  fmet MYNCSRECENT.DETERMINE_IMPLEMENT_STATUS()

    If (IMPLEMENT_STATUS = 2)
      If (MYNCSRECENT.NCSSTA = 4)
        MYNCSRECENT.NCSSTA = 5
        STATUS_CHANGE = CST_ATRUE
      Endif
    Else
      If (MYNCSRECENT.NCSSTA = 5)
        MYNCSRECENT.NCSSTA = 4
        STATUS_CHANGE = CST_ATRUE
      Endif
    Endif

    If (CYCLE = CST_AFALSE)
      MYNCSRECENT.IMPPLANS = 100
    Endif

    If (STATUS_CHANGE)
      STAT =  fmet MYNCSRECENT.AUPDATE()
    Endif

  Endif

  FreeGroup MYNCSRECENT

Return

# --------------------------------------------------
# Validate QA manager (NCSMANAGER)
$VALIDATE_QA_MANAGER

  Local Char NCSQAMAN(30)
  Local Char MESSAGE(100)
# Issue X3-77876 - 2018-05-03 by JUSYN : QA Manager is always mandatory... if created outside function too.
  Local Char WNCSQADEF(5)

  ASTATUS = fmet this.ADELETEERROR("NCSMANAGER")
  # If this.NCSMANAGER = "" : Return : Endif
  If this.NCSMANAGER = ""
      Call PARAM(this.SITE, "NCSQADEF", WNCSQADEF) From ADOVAL
      If WNCSQADEF = ""
          MESSAGE = mess(40,3702,1) # No default QA Manager - see parameter NCSQADEF
          ASTATUS = fmet this.ASETERROR("NCSMANAGER", MESSAGE, CST_AERROR)
      Else
          this.NCSMANAGER = WNCSQADEF
      Endif
  Endif

  If (ASTATUS = CST_AOK)
      Call PARAMUTIL("NCSQAMAN", NCSQAMAN, this.NCSMANAGER, "") From SUBAUS
      If (NCSQAMAN <> "2")
        MESSAGE = func ASYRFNC.MES1(mess(8,3702,1),this.NCSMANAGER)
        ASTATUS = fmet this.ASETERROR("NCSMANAGER", MESSAGE, CST_AERROR)
      Endif
  Endif
# End issue X3-77876

Return

# --------------------------------------------------
# Validate planner (NCSPLANNER)
$VALIDATE_PLANNER

  Local Char NCSPLANNER(30)
  Local Char MESSAGE(100)

  ASTATUS = fmet this.ADELETEERROR("NCSPLANNER")

  If (this.NCSPLANNER <> "")
    Call PARAMUTIL("NCSPLANNER", NCSPLANNER, this.NCSPLANNER, "") From SUBAUS
    If (NCSPLANNER <> "2")
      MESSAGE = func ASYRFNC.MES1(mess(74,2038,1),this.NCSPLANNER)
      ASTATUS = fmet this.ASETERROR("NCSPLANNER", MESSAGE, CST_AERROR)
    Endif
  Endif

Return

# Issue X3-62786 - 2017-11-22 by JUSYN : Moved to class from representation
# --------------------------------------------------
# Custom Method
#
# Is the logged-in user a NCS PLANNER ?
# Return true or false.

$IS_USER_PLANNER
  Local Char NCSPLANNER(30)

  Call PARAMUTIL("NCSPLANNER", NCSPLANNER, this.ACTX.USER, "") From SUBAUS
  If (NCSPLANNER = "2")
    ARET_VALUE = CST_ATRUE
  Else
    ARET_VALUE = CST_AFALSE
  Endif

Return

# --------------------------------------------------
# Custom Method
#
# Is the logged-in user an X3 administrator ?
# Return true or false.
$IS_ADMIN_USER
  Local Integer LOCSTATUS
  Local Instance AUTILIS Using C_AUTILIS

  AUTILIS = NewInstance C_AUTILIS AllocGroup null
  LOCSTATUS = fmet AUTILIS.AREAD(this.ACTX.USER)
  If (AUTILIS.PRFFCT = "ADMIN")
    ARET_VALUE = CST_ATRUE
  Else
    ARET_VALUE = CST_AFALSE
  Endif
  FreeGroup AUTILIS

Return

# End issue X3-62786

# Issue X3-84473 - start
######################################################################################
# Customer Method
# Read document's stock lines and fill class for document lines
# Return true or false, also return error message (MESSAGE)
#

$CREATE_DOCUMENT_LINES
  Local Integer ASTATUS
  Local Integer INDEX, NI
  Local Char    WSERNUM(GLONSER)
  If clalev([F:STS])=0  Local File STOSER     [STS]   Endif

  MESSGAGE = ""
  ARET_VALUE = CST_ATRUE

  # delete any existing lines
  If maxtab(this.NCSDOCHDR(HDRLIN).NCSDOCLIN) > 0
      For NI = maxtab(this.NCSDOCHDR(HDRLIN).NCSDOCLIN) To 1 Step -1
          [L]ASTATUS = fmet this.NCSDOCHDR(HDRLIN).ADELLINE("NCSDOCLIN",NI)
          If [L]ASTATUS >= [V]CST_AERROR Then
              MESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(this)
              ARET_VALUE = CST_AFALSE
              Break
          Endif
      Next NI
  Endif
  If ARET_VALUE = CST_AFALSE
      Return
  Endif

  Case this.NCSDOCHDR(HDRLIN).DOCTYP

      When 1 : # purchase receipt line
               Local File STOJOU [STJ]
               For [STJ]STJ1 Where STOFCY=this.SITE & VCRTYP=6 & VCRNUM=this.NCSDOCHDR(HDRLIN).VCRNUM & VCRLIN=this.NCSDOCHDR(HDRLIN).VCRLIN & REGFLG=1
                   If [F:STJ]SERDEB <> "" & [F:STJ]SERFIN <> ""
                       Gosub SEPERATE_SERNUM_DOCLINES
                   Else
                       WSERNUM = [F:STJ]SERNUM
                       Gosub ADD_NCSDOCLIN
                   Endif
               Next
               LogicClose File [STJ]

      When 2 : # customer return line
               Local File STOJOU [STJ]
               For [STJ]STJ1 Where STOFCY=this.SITE & VCRTYP=13 & VCRNUM=this.NCSDOCHDR(HDRLIN).VCRNUM & VCRLIN=this.NCSDOCHDR(HDRLIN).VCRLIN & REGFLG=1
                   If [F:STJ]SERDEB <> "" & [F:STJ]SERFIN <> ""
                       Gosub SEPERATE_SERNUM_DOCLINES
                   Else
                       WSERNUM = [F:STJ]SERNUM
                       Gosub ADD_NCSDOCLIN
                   Endif
               Next
               LogicClose File [STJ]

      When 3 : # production tracking line
               Local File STOJOU [STJ]
               For [STJ]STJ1 Where STOFCY=this.SITE & VCRTYP=15 & VCRNUM=this.NCSDOCHDR(HDRLIN).VCRNUM & VCRLIN=this.NCSDOCHDR(HDRLIN).VCRLIN & REGFLG=1
                   If [F:STJ]SERDEB <> "" & [F:STJ]SERFIN <> ""
                       Gosub SEPERATE_SERNUM_DOCLINES
                   Else
                       WSERNUM = [F:STJ]SERNUM
                       Gosub ADD_NCSDOCLIN
                   Endif
               Next
               LogicClose File [STJ]

      When 4 : # quality control line
               Local File STOQLYD [QLD]
               For [QLD]QLD0 Where VCRNUM = this.NCSDOCHDR(HDRLIN).VCRNUM and VCRLIN = this.NCSDOCHDR(HDRLIN).VCRLIN
                   INDEX = fmet this.NCSDOCHDR(HDRLIN).ADDLINE("NCSDOCLIN", [V]CST_ALASTPOS) # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
                   If INDEX <> [V]CST_ANOTDEFINED Then
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).NCSID = this.NCSDOCHDR(HDRLIN).NCSID
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).DOCLIN = this.NCSDOCHDR(HDRLIN).DOCLIN
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SUBLIN = [F:QLD]VCRLIN
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SELLIN = 2
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).DOCQTY = [F:QLD]QTYSTU
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).NCSQTY = [F:QLD]QTYSTU
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).BPSLOT = ''
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).LOT    = [F:QLD]LOT
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SLO    = [F:QLD]SLO    # X3-104585
                       this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SERNUM = [F:QLD]SERNUM
                   Else
                       MESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(this)
                       ARET_VALUE = CST_AFALSE
                   Endif
               Next
               LogicClose File [QLD]
  Endcase

  LogicClose File [STS]

  # X3-105525 - STWIL - If we do not have any lines (non-stock or service item) add one line for the quantity
  If maxtab(this.NCSDOCHDR(HDRLIN).NCSDOCLIN) = 0 & this.NCSDOCHDR(HDRLIN).DOCQTY > 0
      INDEX = fmet this.NCSDOCHDR(HDRLIN).ADDLINE("NCSDOCLIN", [V]CST_ALASTPOS) # ISSUE X3-94378 CCMNCSDOC to NCSDOCHDR
      If INDEX <> [V]CST_ANOTDEFINED Then
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).NCSID = this.NCSDOCHDR(HDRLIN).NCSID
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).DOCLIN = this.NCSDOCHDR(HDRLIN).DOCLIN
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SUBLIN = INDEX
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SELLIN = 2
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).DOCQTY = this.NCSDOCHDR(HDRLIN).DOCQTY # X3-104585 wrong qty was written
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).NCSQTY = this.NCSDOCHDR(HDRLIN).NCSQTY # X3-104585 wrong qty was written
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).BPSLOT = ''
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).LOT    = ''
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SLO    = '' # X3-104585
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SERNUM = ''
      Else
          MESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(this)
          ARET_VALUE = CST_AFALSE
      Endif
  Endif

Return

# Separate serial number range

$SEPERATE_SERNUM_DOCLINES
  Local Integer J, WRET
  Local Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)

  # 1st serial number
  WSERNUM = [F:STJ]SERDEB
  Gosub ADD_NCSDOCLIN
  If (ARET_VALUE = CST_AFALSE)
    Return
  Endif

  # 2nd serial number to end serial number
  WNUMDEB = [F:STJ]SERDEB
  For J=1 To [F:STJ]QTYSTU - 1
     Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
     If WRET=0
        Read [STS]STS0=[F:STJ]ITMREF;WNUMFIN
        If fstat
           MESSAGE=WNUMFIN-":"-mess(43,196,1)    # Non-existent Serial Number
           ARET_VALUE = CST_AFALSE
        Else
           WSERNUM = WNUMFIN
           Gosub ADD_NCSDOCLIN
           WNUMDEB = WNUMFIN
        Endif
     Else
        MESSAGE=WNUMDEB-":"-mess(476,197,1)
        ARET_VALUE = CST_AFALSE
     Endif
     If (ARET_VALUE = CST_AFALSE)
       Break
     Endif
  Next J

Return

# add a document line
$ADD_NCSDOCLIN

  INDEX = fmet this.NCSDOCHDR(HDRLIN).ADDLINE("NCSDOCLIN", [V]CST_ALASTPOS)
  If INDEX <> [V]CST_ANOTDEFINED Then
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).NCSID = this.NCSDOCHDR(HDRLIN).NCSID
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).DOCLIN = this.NCSDOCHDR(HDRLIN).DOCLIN
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SUBLIN = INDEX
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SELLIN = 2
      If [F:STJ]SERFIN <> ""
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).DOCQTY = 1 # SERNUM separated - one record per serial number
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).NCSQTY = 1
      Else
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).DOCQTY = [F:STJ]QTYSTU
          this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).NCSQTY = [F:STJ]QTYSTU
      Endif
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).BPSLOT = [F:STJ]BPSLOT
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).LOT    = [F:STJ]LOT
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SLO    = [F:STJ]SLO   # X3-104585
      this.NCSDOCHDR(HDRLIN).NCSDOCLIN(INDEX).SERNUM = WSERNUM
  Else
      MESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(this)
      ARET_VALUE = CST_AFALSE
  Endif

Return

######################################################################################
# Issue X3-84473 - end

