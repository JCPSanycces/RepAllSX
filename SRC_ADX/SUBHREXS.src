#If [F:TES]GRP<>""
#   Read [XFGR]FGR0=[F:TES]GRP;[M:EXS0]FCY(nolign-1)
#   If fstat
#      mkstat=2: [V]GMESSAGE= [M:EXS0]FCY(nolign-1)-":"-mess(24,127,1)-[F:TES]GRP
#   Endif
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

########################################
Subprog AM_CODEXP(VALEUR)
Variable Char    VALEUR()

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
[M:HREXS0]UOMDES(nolign-1)=func AFNC.TEXTRA("ATABDIV","LNGDES","10551",[F:HRTES]UOM)
If [F:HRTES]DEB=2 : [M:HREXS0]SNS(nolign-1)="-" : Else [M:HREXS0]SNS(nolign-1)="+" : Endif
Affzo [HREXS0] UOMDES(nolign-1), SNS(nolign-1)

Call INIPAYE( [M:HREXS0]DATEXS(nolign-1),[L]VALEUR,[M:HREXS0]CUR(nolign-1)
&           , [M:HREXS0]QTY(nolign-1),[M:HREXS0]PAYCUR(nolign-1)
&           )

#44925
If    [F:HRTES]VAT>"" : [M:HREXS0]VAT(nolign-1)=[F:HRTES]VAT
Elsif nolign>1      : [M:HREXS0]VAT(nolign-1)=[M:HREXS0]VAT(nolign-2)
Endif
## fq105501
Call INITVA( [M:HREXS0]CUR(nolign-1),[M:HREXS0]VAT(nolign-1),[M:HREXS0]FCY(nolign-1),[M:HREXS0]DATEXS(nolign-1),[M:HREXS0]PAYCUR(nolign-1)
&          , [M:HREXS0]VATCUR(nolign-1)
&          )
Call INITAX( [M:HREXS0]CUR(nolign-1),[M:HREXS0]VAT(nolign-1),[M:HREXS0]FCY(nolign-1),[M:HREXS0]DATEXS(nolign-1),[M:HREXS0]PAYCUR(nolign-1)
&          , [M:HREXS0]VATCUR(nolign-1),[M:HREXS0]RFUCUR(nolign-1)
&          )

#[M:EXS0]UOMDES(nolign-1)=func AFNC.TEXTRA("ATABDIV","LNGDES","551",[F:TES]UOM)
#If [F:TES]DEB=2 : [M:EXS0]SNS(nolign-1)="-" : Else [M:EXS0]SNS(nolign-1)="+" : Endif
#Affzo [EXS0] UOMDES(nolign-1), SNS(nolign-1)
#
#Call INIPAYE( [M:EXS0]DATEXS(nolign-1),[L]VALEUR,[M:EXS0]CUR(nolign-1)
#&           , [M:EXS0]QTY(nolign-1),[M:EXS0]PAYCUR(nolign-1)
#&           )
#
##44925
#If    [F:TES]VAT>"" : [M:EXS0]VAT(nolign-1)=[F:TES]VAT
#Elsif nolign>1      : [M:EXS0]VAT(nolign-1)=[M:EXS0]VAT(nolign-2)
#Endif
### fq105501
#Call INITVA( [M:EXS0]CUR(nolign-1),[M:EXS0]VAT(nolign-1),[M:EXS0]FCY(nolign-1),[M:EXS0]DATEXS(nolign-1),[M:EXS0]PAYCUR(nolign-1)
#&          , [M:EXS0]VATCUR(nolign-1)
#&          )
#Call INITAX( [M:EXS0]CUR(nolign-1),[M:EXS0]VAT(nolign-1),[M:EXS0]FCY(nolign-1),[M:EXS0]DATEXS(nolign-1),[M:EXS0]PAYCUR(nolign-1)
#&          , [M:EXS0]VATCUR(nolign-1),[M:EXS0]RFUCUR(nolign-1)
#&          )
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

########################################
Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()

If [L]VALEUR=[V]GCURSHR : pcolor=[V]GCOUL(0) : Else pcolor=[V]GCOUL(3) : Endif

End

########################################
Subprog D_CUR(VALEUR)
Variable Char    VALEUR()

Local Char CPY([V]GLONCPY)

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call LECTURE("HRTES",[M:HREXS0]CODEXP(nolign-1),"") From CONTOBJ
Case [F:HRTES]TYPVLT
When 1,3
 [L]CPY   =[V]GSOCSITE(find([M:HREXS0]FCY(nolign-1),[V]GSITE(1..[V]GNBSITE)))
 [L]VALEUR=[V]GDEVSOC(find([L]CPY,[V]GSOC(1..[V]GNBSOC)))
 mkstat   =2
When 2
 If nolign=1 : [L]VALEUR=[V]GCURSHR : Else [L]VALEUR=[M:HREXS0]CUR(nolign-2) : Endif
Endcase

#Call LECTURE("TES",[M:EXS0]CODEXP(nolign-1),"") From CONTOBJ
#Case [F:TES]TYPVLT
#When 1,3
# [L]CPY   =[V]GSOCSITE(find([M:EXS0]FCY(nolign-1),[V]GSITE(1..[V]GNBSITE)))
# [L]VALEUR=[V]GDEVSOC(find([L]CPY,[V]GSOC(1..[V]GNBSOC)))
# mkstat   =2
#When 2
# If nolign=1 : [L]VALEUR=[V]GCURSHR : Else [L]VALEUR=[M:EXS0]CUR(nolign-2) : Endif
#Endcase
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

