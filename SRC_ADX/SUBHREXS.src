End

########################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()

#57122
#Local Date DAT, DEB, FIN

#[L]DAT=[M:EXS0]STRDAT-1
#For [CTR]CTR0 Where REFNUM=[M:EXS0]REFNUM & CTRNUM=[L]VALEUR
# If [L]DEB=[0/0/0] : [L]DEB=[F:CTR]CTRDAT : Endif
# If [F:CTR]XITDAT=[0/0/0] : [L]FIN=[M:EXS0]ENDDAT : Else [L]FIN=[F:CTR]XITDAT : Endif
# If [F:CTR]CTRDAT>[L]DAT+1
#  Break
# Elsif [F:CTR]XITDAT>[M:EXS0]ENDDAT | [F:CTR]XITDAT=[0/0/0]
#  [L]DAT=[M:EXS0]ENDDAT
#  Break
# Elsif [L]DAT<=[F:CTR]XITDAT+1
#  [L]DAT=[F:CTR]XITDAT
# Endif
#Next
#If [L]DAT<[M:EXS0]ENDDAT
# [V]GMESSAGE=func AFNC.MES2( mess(25,718,1),format$([V]GFMD,[L]DEB)
#&                          , format$([V]GFMD,[L]FIN)
#&                          )
 #           Contrat couvrant la période du $1$ au $2$
# mkstat     =2
# End
#Endif


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=VALEUR & CTRDAT<=[M:EXS0]ENDDAT & (XITDAT>=[M:EXS0]STRDAT | XITDAT=[0/0/0])
Filter [HRCTR] Where REFNUM=[M:HREXS0]REFNUM & CTRNUM=VALEUR & (CTRDAT<=[M:HREXS0]ENDDAT | (FLGRET=2 & RETDATEFF<=[M:HREXS0]ENDDAT)) & (XITDAT>=[M:HREXS0]STRDAT | XITDAT=[0/0/0])
# Fin MABON
Read [HRCTR]CTR0 First
Filter [HRCTR]
If fstat
 # Contrat non valide sur la période
 GMESSAGE =mess(25,10718,1)
 mkstat =2 : End
Endif

Gosub DIE_TYP ## FQ 105501

[M:HREXS0]ETRFCY=[F:HRCTR]ETRFCY
[M:HREXS0]ETRSRV=[F:HRCTR]ETRSRV

Call GETCTRLEG(VALEUR)

Affzo [HREXS0] ETRFCY, ETRSRV

## FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
##Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=VALEUR & CTRDAT<=[M:EXS0]ENDDAT & (XITDAT>=[M:EXS0]STRDAT | XITDAT=[0/0/0])
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=VALEUR & (CTRDAT<=[M:EXS0]ENDDAT | (FLGRET=2 & RETDATEFF<=[M:EXS0]ENDDAT)) & (XITDAT>=[M:EXS0]STRDAT | XITDAT=[0/0/0])
## Fin MABON
#Read [CTR]CTR0 First
#Filter [CTR]
#If fstat
# # Contrat non valide sur la période
# GMESSAGE =mess(25,718,1)
# mkstat =2 : End
#Endif
#
#Gosub DIE_TYP ## FQ 105501
#
#[M:EXS0]ETRFCY=[F:CTR]ETRFCY
#[M:EXS0]ETRSRV=[F:CTR]ETRSRV
#Affzo [EXS0] ETRFCY, ETRSRV
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


End

