########################################
Subprog C_EXSNUM(VALEUR)
Variable Decimal VALEUR

Local Integer OK


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Filter [HREXS] Where EXSNUM=[L]VALEUR
Read [HREXS]HREXS0 First
Filter [HREXS]
If fstat
 [V]GMESSAGE=mess(23,100,1) : # Fiche inexistante
 mkstat     =2
Elsif [F:HREXS]REFNUM<>[M:HREXS0]REFNUM
 Read [ID]ID0=[F:HREXS]REFNUM
 Call AVERTIR( func AFNC.MES1(mess(68,10701,1),[F:HREXS]REFNUM-"("+[F:ID]SRN-[F:ID]NAM+")")
&            , [L]OK
&            ) From GESECRAN
#              Fiche du salarié du matricule $1$
 If [L]OK=2
  [M:HREXS0]REFNUM=[F:HREXS]REFNUM
  [M:HREXS0]CTRNUM=[F:HREXS]CTRNUM
  Affzo [HREXS0] REFNUM, CTRNUM
 Else
  mkstat=2
 Endif
Endif

#Filter [EXS] Where EXSNUM=[L]VALEUR
#Read [EXS]EXS0 First
#Filter [EXS]
#If fstat
# [V]GMESSAGE=mess(23,100,1) : # Fiche inexistante
# mkstat     =2
#Elsif [F:EXS]REFNUM<>[M:EXS0]REFNUM
# Read [ID]ID0=[F:EXS]REFNUM
# Call AVERTIR( func AFNC.MES1(mess(68,701,1),[F:EXS]REFNUM-"("+[F:ID]SRN-[F:ID]NAM+")")
#&            , [L]OK
#&            ) From GESECRAN
##              Fiche du salarié du matricule $1$
# If [L]OK=2
#  [M:EXS0]REFNUM=[F:EXS]REFNUM
#  [M:EXS0]CTRNUM=[F:EXS]CTRNUM
#  Affzo [EXS0] REFNUM, CTRNUM
# Else
#  mkstat=2
# Endif
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


End

