$S_EXSNUM

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
[L]OBJET="HREXS"
[L]CRITERE="REFNUM=[M:HREXS0]REFNUM & CTRNUM=[M:HREXS0]CTRNUM"

