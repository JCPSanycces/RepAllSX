#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Local Integer FOUND
If clalev([F:HREXS2])=0 : Local File HREXPENSES [HREXS2] : Endif
FOUND=1
Filter [F:HREXS2] Where REFNUM=[M:HREXS0]REFNUM & EXSNUM=[M:HREXS0]EXSNUM & CTRNUM=[M:HREXS0]CTRNUM
For [F:HREXS2]
  If [F:HREXS2]TRFREQ<>2 & find([F:HREXS2]EXSSTA,3,7)>0 Then FOUND=2 : Break : Endif
Next
Filter [F:HREXS2]
If FOUND=2 Then
  CHMEN += "A"
Endif

