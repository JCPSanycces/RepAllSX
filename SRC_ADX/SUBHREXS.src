Variable Char    VALEUR()
Local Integer AXE
AXE = 18 : Goto CONTCCE

Subprog C_CCE19(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 19 : Goto CONTCCE

Subprog C_CCE20(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 20: Goto CONTCCE

$CONTCCE
Local Integer I
Local Char    BID([V]GLONCCE)

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call LECTURE("HRTES",[M]CODEXP(nolign-1),"") From CONTOBJ
I=find([M]DIETYP(AXE-1),[F:HRTES]DIE())
If I
  If [F:HRTES]CCEDAC(I-1)=2 and VALEUR=""
    GMESSAGE = mess(46,106,1)-[M]INTDIE(AXE-1) : # Mandatory dimension on dimension type'
    mkstat = 2 : End
  Endif
Endif
If VALEUR="" : End : Endif

#Call LECTURE("TES",[M]CODEXP(nolign-1),"") From CONTOBJ
#I=find([M]DIETYP(AXE-1),[F:TES]DIE())
#If I
#  If [F:TES]CCEDAC(I-1)=2 and VALEUR=""
#    GMESSAGE = mess(46,106,1)-[M]INTDIE(AXE-1) : # Mandatory dimension on dimension type'
#    mkstat = 2 : End
#  Endif
#Endif
#If VALEUR="" : End : Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


If !clalev([F:CCE]) : Local File =GTABCPT+"CACCE" [CCE] : Endif
Call LECTURE("CCE",VALEUR,[M]DIETYP(AXE-1)) From CONTOBJ
If fstat
 GMESSAGE = VALEUR-mess(35,106,1) : # Nonexistent dimension value
 mkstat = 2 : End
Endif

Call VERIF([F:CCE]FCY,[M]FCY(nolign-1),VALEUR) From CFYSUB
If mkstat : End : Endif

If dim([F:CCE]IPT)>0 & [F:CCE]IPT<>2
 GMESSAGE = VALEUR-mess(24,106,1) : # Dimension is not chargeable
 mkstat = 1 : End
Endif

Call CONTEXE([F:CCE]ACS) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call CTLVLYDAT([M:HREXS0]DATEXS(nolign-1),[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
#Call CTLVLYDAT([M:EXS0]DATEXS(nolign-1),[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif

## 'Prohibited for the dimension'
If GCOMPTA<>3
  If clalev([F:CAZ])=0 : Local File =GTABCPT+"CAAUZ" [CAZ] : Endif
Else
  If clalev([F:AUZ])=0 : Local File CAAUZ [AUZ] : Endif
Endif

For I=1 To dim([M]CCE())
  If I <> AXE
    If evalue("[M]CCE"+num$(I))<>""
      BID = evalue("[M]CCE"+num$(I))
      If !clalev([F:CCE2]) : Local File =GTABCPT+"CACCE" [CCE2] : Endif
      Read [CCE2]CCE0 = [M]DIETYP(AXE-1) ; BID
      If GCOMPTA<>3
        Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
      Else
        Look [AUZ]AUZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
      Endif
      If !fstat
        GMESSAGE = VALEUR-mess(26,106,1)-[F:CCE2]CCE : # Interdit avec la section
         mkstat = 1 : Break
      Endif
    Endif
  Endif
Next I

End
