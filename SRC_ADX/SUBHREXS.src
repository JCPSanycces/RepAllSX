Subprog C_CODEXP(VALEUR)
Variable Char    VALEUR()

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call CONTEXE([F:HRTES]ACS) From CPTSUB
If mkstat : [V]GMESSAGE=[L]VALEUR-[V]GMESSAGE : End : Endif
Call CTLVLYDAT([M:HREXS0]DATEXS(nolign-1),[F:HRTES]VLYSTR,[F:HRTES]VLYEND) From CPTSUB
If mkstat : [V]GMESSAGE=[L]VALEUR-[V]GMESSAGE : End : Endif


## fq 105501
If clalev([F:XFGR])=0 : Local File FACGROUP   [XFGR]  : Endif
If [F:HRTES]GRP<>""
   Read [XFGR]FGR0=[F:HRTES]GRP;[M:HREXS0]FCY(nolign-1)
   If fstat
      mkstat=2: [V]GMESSAGE= [M:HREXS0]FCY(nolign-1)-":"-mess(24,127,1)-[F:HRTES]GRP
   Endif
Endif

#Call CONTEXE([F:TES]ACS) From CPTSUB
#If mkstat : [V]GMESSAGE=[L]VALEUR-[V]GMESSAGE : End : Endif
#Call CTLVLYDAT([M:EXS0]DATEXS(nolign-1),[F:TES]VLYSTR,[F:TES]VLYEND) From CPTSUB
#If mkstat : [V]GMESSAGE=[L]VALEUR-[V]GMESSAGE : End : Endif
#
#
### fq 105501
