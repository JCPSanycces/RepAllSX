Return

################################################################################
#
# Listes de gauche
#
################################################################################

$FILGAUCHE
#59181
Case currbox
 When BOXSTD
  [L]FILGAUCHE = 'EXSSTA>1'
 When BOXBRL
  [L]FILGAUCHE = 'EXSSTA=1 & LIN=1'    #61868 : Ajout '& LIN=1' pour n'avoir qu'un ligne dans le browser par note de frais
Endcase
#
If !instr(1,[V]GUSRAUZ(1),"1")
 #59181
 If [L]FILGAUCHE<>"" : [L]FILGAUCHE -= "&" : Endif
 #
 [L]FILGAUCHE -= "REFNUM='"+[V]GREFNUM+"'"
Endif
#61751
If GUSRACS<>2
 [L]FILGAUSUP  = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 [L]FILGAUSUP -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))'
Endif
#
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If [L]FILGAUSUP<>"" : [L]FILGAUSUP -= "& " : Endif
 [L]FILGAUSUP += 'find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))'
Endif
If [L]FILGAUCHE<>""
 If  [L]FILGAUSUP<>"" : [L]FILGAUSUP -= "&" : Endif
 [L]FILGAUSUP -= [L]FILGAUCHE
Endif

Return


