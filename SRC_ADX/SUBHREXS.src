Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [F:ID]FLGMULCTR<>2
 Call CHERCHE_CTRPER(VALEUR,[M:HREXS0]STRDAT,[M:HREXS0]ENDDAT,[M:HREXS0]CTRNUM) From DIVPAYE
 Grizo [HREXS0]CTRNUM
Else
 Raz [M:HREXS0]CTRNUM
 Actzo [HREXS0] CTRNUM
Endif
Affzo [HREXS0]CTRNUM
