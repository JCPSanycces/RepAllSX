Subprog B3_NBLIG
Local Integer READSTAT
READSTAT = 0
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [M:HREXS0]UID(nolign-1) = 0 : End : Endif
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Decimal BASPAG
 If !GWEBSERV
    SAVACT = GACTION : GACTION = "AOBJTXT"
    PARMSK(1) = "EML"
    PARMSK(2) = "HREXS"+"~"+num$([M:HREXS0]REFNUM)+"~"+num$([M:HREXS0]EXSNUM)
    PARMSK(3) = num$([M:HREXS0]UID(nolign-1))
    PARMSK(4) = "M"
    Call SAISIE_NUM(BASPAG,PARMSK,"AOBJTXT","GOBJTXT","XWAOBJTXT") From GSAISIE
    GACTION = SAVACT
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  If mkstat=2 Then
    READSTAT = func PRHPORATT.FILTER_AOX("HREXS",[M:HREXS0]REFNUM,[M:HREXS0]EXSNUM,[M:HREXS0]UID(nolign-1))
    If READSTAT = 1
      [M:HREXS0]PJ(nolign-1)="175"
    Else
      [M:HREXS0]PJ(nolign-1)=""
    Endif
    Affzo [M:HREXS0]PJ(nolign-1)
    mkstat=4
  Endif

