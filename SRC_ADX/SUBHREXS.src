$ACTION
Case [L]ACTION
 When "OUVRE"        : Gosub OUVRE
 #59181
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "SETBOUT"      : Gosub SETBOUT
#-------------------------------------------------------------------------------
 When "AFFMASK"      : Gosub GRISE_MAT
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "ANNULE"       : Gosub ANNULE
 When "LIENS0"       : Gosub LIENS0
 When "LIENS"        : Gosub LIENS
 When "LIENS2"       : Gosub LIENS2
 When "DEGRISE"      : Gosub GRISE_MAT
#-------------------------------------------------------------------------------
 When "FILTRE"       : Gosub FILTRE
 When "EXEBOUT"      : Gosub EXEBOUT
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
 When "ABA"          : Actzo [HREXS0] EXSNUM

#When "ABA"          : Actzo [EXS0] EXSNUM
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
#-------------------------------------------------------------------------------
 When "FILGAUCHE"    : Gosub FILGAUCHE
#-------------------------------------------------------------------------------
 When "DEBUT_CRE"    : Gosub DEBUT_CRE
 When "INICRE"       : Gosub INICRE
 When "APRES_CRE"    : Gosub APRES_CRE
 When "DEBUT_MOD"    : Gosub DEBUT_MOD
 When "MODIF"        : Gosub MODIF
#-------------------------------------------------------------------------------
 When "SEL_TABLE"
  Case [L]COUZON
   When "EXSNUM"     : Gosub S_EXSNUM
  Endcase
 When "AVANT_OUVRE"        : Gosub AVANT_OUVRE
 When "APRES_MOD"          : Gosub APRES_MOD
Endcase
Return

