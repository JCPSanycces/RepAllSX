#Endcase
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call INITAX([L]CUR,[M:HREXS0]VAT(nolign-1),[M:HREXS0]FCY(nolign-1),[M:HREXS0]DATEXS(nolign-1),[L]PAYE,[M:HREXS0]VATCUR(nolign-1),[L]REMB)
