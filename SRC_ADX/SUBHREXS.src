$OUVRE_BOITE
Local Char    BOXSTD(10) , BOXBRL(10)
Local Integer I
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
I=find("HREXS",OBJLIS(1..dim(OBJLIS)-1))
If I : BOXSTD = "GAU_CHE"+num$(I) : Else : BOXSTD="GAU_CHE" : Endif
I=find("HREX0",OBJLIS(1..dim(OBJLIS)-1))
If I : BOXBRL = "GAU_CHE"+num$(I) : Else : BOXBRL="GAU_CHE" : Endif

