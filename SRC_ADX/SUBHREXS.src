########################################
Subprog D_CCE(VALEUR)
Variable Char VALEUR

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [L]VALEUR>"" : Return : Endif
Call LECTURE("HRTES",[M:HREXS0]CODEXP(nolign-1),"") From CONTOBJ
If [F:HRTES]CCEINI<>""
 Call INISEC([L]VALEUR,[F:HRTES]CCEINI,num$([V]GAXE)) From SUBCDE
Endif
If [L]VALEUR="" : [L]VALEUR=[F:HRTES]CCE([V]GAXE-1) : Endif
If [L]VALEUR="" & nolign>1
 [L]VALEUR=evalue("[M:HREXS0]CCE"+num$([V]GAXE)+"(nolign-2)")
Endif

#If [L]VALEUR>"" : Return : Endif
#Call LECTURE("TES",[M:EXS0]CODEXP(nolign-1),"") From CONTOBJ
#If [F:TES]CCEINI<>""
# Call INISEC([L]VALEUR,[F:TES]CCEINI,num$([V]GAXE)) From SUBCDE
#Endif
#If [L]VALEUR="" : [L]VALEUR=[F:TES]CCE([V]GAXE-1) : Endif
#If [L]VALEUR="" & nolign>1
# [L]VALEUR=evalue("[M:EXS0]CCE"+num$([V]GAXE)+"(nolign-2)")
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

########################################
Subprog AS_CCE(VALEUR)
Variable Char VALEUR

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call LECTURE("HRTES",[M:HREXS0]CODEXP(nolign-1),"") From CONTOBJ
If [F:HRTES]CCEDAC([V]GAXE-1)<>2
 [L]VALEUR=""
 Call D_CCE([L]VALEUR)
 mkstat=2
 End
Elsif [L]VALEUR=""
 Call D_CCE([L]VALEUR)
Endif

#Call LECTURE("TES",[M:EXS0]CODEXP(nolign-1),"") From CONTOBJ
#If [F:TES]CCEDAC([V]GAXE-1)<>2
