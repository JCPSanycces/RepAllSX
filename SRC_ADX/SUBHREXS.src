########################################
Subprog AM_PAYCUR(VALEUR)
Variable Decimal VALEUR

Local Integer STAT

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
## fq 105501
Call INITVA( [M:HREXS0]CUR(nolign-1),[M:HREXS0]VAT(nolign-1),[M:HREXS0]FCY(nolign-1),[M:HREXS0]DATEXS(nolign-1),[L]VALEUR
&          , [M:HREXS0]VATCUR(nolign-1)
&          )
Call INIREMB( [M:HREXS0]DATEXS(nolign-1),[M:HREXS0]CODEXP(nolign-1)
&           , [M:HREXS0]CUR(nolign-1),[M:HREXS0]QTY(nolign-1),[L]VALEUR
&           , [M:HREXS0]RFUCUR(nolign-1)
&           )
#62198
If mkstat=2 : End : Endif
If [M:HREXS0]CUR(nolign-1) <> [V]GCURSHR  : # 67388
 Call CONVERT3( [M:HREXS0]CUR(nolign-1),[V]GCURSHR,[F:CPY]ACCCUR
&             , [M:HREXS0]TYPRAT(nolign-1),[M:HREXS0]DATEXS(nolign-1),[L]VALEUR
&             , [M:HREXS0]PAYSHR(nolign-1),[M:HREXS0]RATCPY(nolign-1),[L]STAT
&             ) From CPTSUB
Else
 [M:HREXS0]PAYSHR(nolign-1) = [L]VALEUR : # # 67388
Endif

### fq 105501
#Call INITVA( [M:EXS0]CUR(nolign-1),[M:EXS0]VAT(nolign-1),[M:EXS0]FCY(nolign-1),[M:EXS0]DATEXS(nolign-1),[L]VALEUR
#&          , [M:EXS0]VATCUR(nolign-1)
#&          )
#Call INIREMB( [M:EXS0]DATEXS(nolign-1),[M:EXS0]CODEXP(nolign-1)
#&           , [M:EXS0]CUR(nolign-1),[M:EXS0]QTY(nolign-1),[L]VALEUR
#&           , [M:EXS0]RFUCUR(nolign-1)
#&           )
##62198
#If mkstat=2 : End : Endif
#If [M:EXS0]CUR(nolign-1) <> [V]GCURSHR  : # 67388
# Call CONVERT3( [M:EXS0]CUR(nolign-1),[V]GCURSHR,[F:CPY]ACCCUR
#&             , [M:EXS0]TYPRAT(nolign-1),[M:EXS0]DATEXS(nolign-1),[L]VALEUR
#&             , [M:EXS0]PAYSHR(nolign-1),[M:EXS0]RATCPY(nolign-1),[L]STAT
#&             ) From CPTSUB
#Else
# [M:EXS0]PAYSHR(nolign-1) = [L]VALEUR : # # 67388
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

