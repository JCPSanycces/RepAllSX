#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Subprog GETCTRLEG(VALEUR)
Value Char VALEUR()

If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
If clalev([F:FCY2])=0   : Local File FACILITY [FCY2]   : Endif

  If VALEUR<>""
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] Last
    Filter [HRCTR2]
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:HREXS0]LEG = GCURLEG
    Affzo [M:HREXS0]LEG
    Endif
  Endif
End

#DIRAS - 2017/05/10 - JIRA X3-11253 - END


