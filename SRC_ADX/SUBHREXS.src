#[L]CODE =[M:EXS0]CODEXP(nolign-1)
#[L]CCE  ="[M:EXS0]CCE#"
#[L]ABREV="TES"
#[L]NOL  =nolign-1
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Gosub CONTCCE From SUBCDEB

End

