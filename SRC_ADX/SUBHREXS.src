########################################
Subprog C_DATEXS(VALEUR)
Variable Date    VALEUR

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [L]VALEUR<[M:HREXS0]STRDAT | [L]VALEUR>[M:HREXS0]ENDDAT
 [V]GMESSAGE=mess(12,122,1)  # Date en dehors de la période
 mkstat     =2
 End
Endif

#If [L]VALEUR<[M:EXS0]STRDAT | [L]VALEUR>[M:EXS0]ENDDAT
# [V]GMESSAGE=mess(12,122,1)  # Date en dehors de la période
# mkstat     =2
# End
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#DIRAS - 2017/05/10 - JIRA X3-11253 - START

#61757
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRDAT<=[L]VALEUR
#&                & (XITDAT>=[L]VALEUR | XITDAT=[0/0/0])
Filter [HRCTR] Where REFNUM=[M:HREXS0]REFNUM & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR))
&                & (XITDAT>=[L]VALEUR | XITDAT=[0/0/0])
# Fin MABON
Look [HRCTR]CTR0 First
Filter [HRCTR]
If fstat
 [V]GMESSAGE=mess(15,10718,1) : # Salarié non présent en ce jour
 mkstat     =2
Endif
# fin 61757

##61757
## FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
##Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRDAT<=[L]VALEUR
##&                & (XITDAT>=[L]VALEUR | XITDAT=[0/0/0])
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR))
#&                & (XITDAT>=[L]VALEUR | XITDAT=[0/0/0])
## Fin MABON
#Look [CTR]CTR0 First
#Filter [CTR]
#If fstat
# [V]GMESSAGE=mess(15,718,1) : # Salarié non présent en ce jour
# mkstat     =2
#Endif
## fin 61757
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
End

########################################
Subprog AM_DATEXS(VALEUR)
Variable Date    VALEUR

Local Char CPY([V]GLONCPY)

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=[M:EXS0]CTRNUM & CTRDAT<=[L]VALEUR
#&     Order By Key CLE=CTRDAT Desc
Filter [HRCTR] Where REFNUM=[M:HREXS0]REFNUM & CTRNUM=[M:HREXS0]CTRNUM & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR))
&     Order By Key CLE=CTRDAT Desc
# Fin MABON
Read [HRCTR] First
Filter [HRCTR]
[M:HREXS0]FCY(nolign-1)=[F:HRCTR]ETRFCY

If [M:HREXS0]CUR(nolign-1)=""
 [L]CPY               =[V]GSOCSITE(find([F:HRCTR]ETRFCY,[V]GSITE(1..[V]GNBSITE)))
 [M:HREXS0]CUR(nolign-1)=[V]GDEVSOC(find([L]CPY,[V]GSOC(1..[V]GNBSOC)))
Endif

Call INIDEV([M:HREXS0]CUR(nolign-1),[L]VALEUR)

## FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
##Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=[M:EXS0]CTRNUM & CTRDAT<=[L]VALEUR
##&     Order By Key CLE=CTRDAT Desc
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=[M:EXS0]CTRNUM & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR))
#&     Order By Key CLE=CTRDAT Desc
## Fin MABON
#Read [CTR] First
#Filter [CTR]
#[M:EXS0]FCY(nolign-1)=[F:CTR]ETRFCY
#
#If [M:EXS0]CUR(nolign-1)=""
# [L]CPY               =[V]GSOCSITE(find([F:CTR]ETRFCY,[V]GSITE(1..[V]GNBSITE)))
# [M:EXS0]CUR(nolign-1)=[V]GDEVSOC(find([L]CPY,[V]GSOC(1..[V]GNBSOC)))
#Endif
#
#Call INIDEV([M:EXS0]CUR(nolign-1),[L]VALEUR)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

