##################################################
Subprog WRKRER_HEA(CHRONO,ADEST)
Value    Char    CHRONO
Value    Char    ADEST
End


$WRITE_EXPENSES
Gosub MAJIDES
Return

$MAJIDES
GOK=1
If clalev([F:EXSH])=0   : Local File EXPENSESHEA    [EXSH]    : Endif
Trbegin [EXSH]
Gosub DEL_EXPENSESHEA

If !clalev([CTR9]) : Local File EMPLOCTR [CTR9] : Endif
Local Date CTRDAT
Filter [CTR9] Where REFNUM=[M:HREXS0]REFNUM & CTRNUM=[M:HREXS0]CTRNUM & (CTRDAT<=[M:HREXS0]ENDDAT | (FLGRET=2 & RETDATEFF<=[M:HREXS0]ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=[M:HREXS0]STRDAT) Order By CTRDAT Desc
Read [CTR9] First
If !fstat
  [L]CTRDAT = [F:CTR9]CTRDAT
Endif

If clalev([CTR9]) : Close File [CTR9] : Endif

Raz [F:EXSH]
[F:EXSH]REFNUM  = [M:HREXS0]REFNUM
[F:EXSH]CTRNUM  = [M:HREXS0]CTRNUM
[F:EXSH]STRDAT  = [M:HREXS0]STRDAT
[F:EXSH]ENDDAT  = [M:HREXS0]ENDDAT
[F:EXSH]ETRFCY  = [M:HREXS0]ETRFCY
[F:EXSH]ETRSRV  = [M:HREXS0]ETRSRV
[F:EXSH]EXSNUM  = [M:HREXS0]EXSNUM
[F:EXSH]EXSSTA  = [M:HREXS0]EXSSTA
[F:EXSH]TIT     = [M:HREXS0]TIT
[F:EXSH]CMT     = [M:HREXS0]CMT
[F:EXSH]DIETYP  = [M:HREXS0]DIETYP
[F:EXSH]FMTDIE  = [M:HREXS0]FMTDIE
[F:EXSH]INTDIE  = [M:HREXS0]INTDIE
[F:EXSH]LEG     = [M:HREXS0]LEG
[F:EXSH]CTRDAT  = [L]CTRDAT

Write [F:EXSH]
If fstat
  Rollback
Else
  Commit
Endif

Return

$DEL_EXPENSESHEA
If clalev([F:EXSH])=0 : Local File EXPENSESHEA [EXSH] : Endif
Filter [F:EXSH]
Delete [F:EXSH] Where REFNUM = [M:HREXS0]REFNUM & EXSNUM = [M:HREXS0]EXSNUM & CTRNUM = [M:HREXS0]CTRNUM
If fstat
  GOK = 0 : Call FSTA("EXSH") From GLOCK
Endif
Return

