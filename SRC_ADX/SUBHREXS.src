Subprog D_CCE20(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 20 : Gosub DEFCCE: End

$DEFCCE
   If [L]VALEUR>"" : Return : Endif
   If !clalev([F:FCY]): Local File FACILITY [FCY]: Endif
   If !clalev([F:CPY]): Local File COMPANY  [CPY]: Endif
   If !clalev([F:GCM]): Local File =GTABCPT+"GACM"     [GCM]: Endif
   If !clalev([F:LED]): Local File =GTABCPT+"GLED"     [LED]: Endif
   If !clalev([F:CAC]): Local File GACCCODE [CAC]: Endif

   Local Char LED(GLONLED), ACC(GLONGAC)
   Local Integer NLED, I

   Call LEC_FCY([M]FCY(nolign-1)) From CPTLEC
   GSOCIETE=[F:FCY]LEGCPY
   Call LEC_CPY(GSOCIETE) From CPTLEC
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
   Call LECTURE("HRTES",[M:HREXS0]CODEXP(nolign-1),"") From CONTOBJ
#   Call LECTURE("TES",[M:EXS0]CODEXP(nolign-1),"") From CONTOBJ
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
   Call LEC_GCM([F:CPY]ACM) From CPTLEC

   For NLED=1 To 10
       If [F:GCM]LED(NLED-1)="": Break: Endif
       [L]LED=[F:GCM]LED(NLED-1)
       Call LEC_LED([L]LED) From CPTLEC
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
       Call LEC_CAC(11,[F:HRTES]ACCCOD,[F:LED]COA) From CPTLEC
       Call INICCE(VALEUR,[M]DIETYP(AXE-1),LED,[F:CAC]ACC(0),[F:HRTES]CCEINI) From CPTINI

#       Call LEC_CAC(11,[F:TES]ACCCOD,[F:LED]COA) From CPTLEC
#       Call INICCE(VALEUR,[M]DIETYP(AXE-1),LED,[F:CAC]ACC(0),[F:TES]CCEINI) From CPTINI
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
       If VALEUR<>"": Break: Endif
   Next
   If VALEUR<>"": Return: Endif
#   Call LECTURE("TES",[M:EXS0]CODEXP(nolign-1),"") From CONTOBJ
#   If [F:TES]CCEINI<>""
#      Call INISEC([L]VALEUR,[F:TES]CCEINI,[M]DIETYP(AXE-1)) From SUBCDE
#   Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
   I=find([M]DIETYP(AXE-1),[F:HRTES]DIE())
   If I
    [L]VALEUR=[F:HRTES]CCE(I-1)
   Endif

If [L]VALEUR="" & nolign>1
 [L]VALEUR=evalue("[M:HREXS0]CCE"+num$(AXE)+"(nolign-2)")
Endif

#   I=find([M]DIETYP(AXE-1),[F:TES]DIE())
#   If I
#    [L]VALEUR=[F:TES]CCE(I-1)
#   Endif
#
#If [L]VALEUR="" & nolign>1
# [L]VALEUR=evalue("[M:EXS0]CCE"+num$(AXE)+"(nolign-2)")
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Return
