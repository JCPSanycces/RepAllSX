[L]CPY=func DIVPAYE.GETSOC([M:HREXS0]FCY(nolign-1))
#[L]CPY=func DIVPAYE.GETSOC([M:EXS0]FCY(nolign-1))
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
Return

#-------------------------------------------------------------------------------
Subprog INIDEV(CUR,DAT)
Value Char CUR()
Value Date DAT

If [L]CUR="" | [L]DAT=[0/0/0] : End : Endif

Local Char    CPYCUR([V]GLONCUR), RPTCUR([V]GLONCUR)
Local Decimal RATCUR, RATRPT
Local Integer STAT

Gosub INICPY
#Call SETFLGDEV([L]CUR,[L]CPY,[L]DAT) From SUBGA0
Call SETFLGDEV([L]CUR,[L]CPY,[L]DAT) From CPTDIV
[V]GDEVORI1=[L]CUR
[V]GDEVORI2=[L]CUR

If [V]GCURFLG=2 & [L]CUR<>[V]GEURO
 If [V]GCPYFLG=1 : [V]GDEVORI1=[V]GEURO : Endif
 If [V]GRPTFLG=1 : [V]GDEVORI2=[V]GEURO : Endif
Endif

[L]CPYCUR=[F:CPY]ACCCUR
[L]RPTCUR=[V]GSYSCUR
If [V]GCURFLG=1
 If [V]GCPYFLG=2 & [V]GSYSCUR<>[V]GEURO : [L]CPYCUR=[V]GEURO : Endif
 If [V]GRPTFLG=2 & [L]CPYCUR <>[V]GEURO : [L]RPTCUR=[V]GEURO : Endif
Endif


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
# Calcul du taux théorique
Call CONVERT( [V]GDEVORI1,[L]CPYCUR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1)
&           , [L]DAT,10^[V]GDECRCU,[L]RATCUR,[L]STAT
&           ) From TRTDEV
If ![L]STAT : [L]RATCUR=arr([L]RATCUR*10^-[V]GDECRCU,10^-[V]GDECRCU) : Endif
Call CONVERT( [V]GDEVORI2,[L]RPTCUR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1)
&           , [L]DAT,10^[V]GDECRCU,[L]RATRPT,[L]STAT
&           ) From TRTDEV
If ![L]STAT : [L]RATRPT=arr([L]RATRPT*10^-[V]GDECRCU,10^-[V]GDECRCU) Endif

If [L]CUR=[L]CPYCUR : [M:HREXS0]RATCPY(nolign-1)=1
Else                  [M:HREXS0]RATCPY(nolign-1)=[L]RATCUR
Endif
Case [L]RPTCUR
 When [L]CUR    : [M:HREXS0]RATRPT(nolign-1)=1
 When [L]CPYCUR : [M:HREXS0]RATRPT(nolign-1)=[L]RATCUR
 When Default   : [M:HREXS0]RATRPT(nolign-1)=[L]RATRPT
Endcase

Call INIPAYE( [L]DAT,[M:HREXS0]CODEXP(nolign-1),[L]CUR,[M:HREXS0]QTY(nolign-1)
&           , [M:HREXS0]PAYCUR(nolign-1)
&           )

## Calcul du taux théorique
#Call CONVERT( [V]GDEVORI1,[L]CPYCUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1)
#&           , [L]DAT,10^[V]GDECRCU,[L]RATCUR,[L]STAT
#&           ) From TRTDEV
#If ![L]STAT : [L]RATCUR=arr([L]RATCUR*10^-[V]GDECRCU,10^-[V]GDECRCU) : Endif
#Call CONVERT( [V]GDEVORI2,[L]RPTCUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1)
#&           , [L]DAT,10^[V]GDECRCU,[L]RATRPT,[L]STAT
#&           ) From TRTDEV
#If ![L]STAT : [L]RATRPT=arr([L]RATRPT*10^-[V]GDECRCU,10^-[V]GDECRCU) Endif
#
#If [L]CUR=[L]CPYCUR : [M:EXS0]RATCPY(nolign-1)=1
#Else                  [M:EXS0]RATCPY(nolign-1)=[L]RATCUR
#Endif
#Case [L]RPTCUR
# When [L]CUR    : [M:EXS0]RATRPT(nolign-1)=1
# When [L]CPYCUR : [M:EXS0]RATRPT(nolign-1)=[L]RATCUR
# When Default   : [M:EXS0]RATRPT(nolign-1)=[L]RATRPT
#Endcase
#
#Call INIPAYE( [L]DAT,[M:EXS0]CODEXP(nolign-1),[L]CUR,[M:EXS0]QTY(nolign-1)
#&           , [M:EXS0]PAYCUR(nolign-1)
#&           )
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

#-------------------------------------------------------------------------------
Subprog INIPAYE(DAT,HRTES,CUR,QTY,PAYE)
Value    Date    DAT
Value    Char    HRTES(), CUR()
Value    Decimal QTY
Variable Decimal PAYE

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If find("",[L]HRTES,[L]CUR) | [L]DAT=[0/0/0] | [L]QTY=0 : End : Endif
#If find("",[L]TES,[L]CUR) | [L]DAT=[0/0/0] | [L]QTY=0 : End : Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Local Libelle  CAT, BKT
Local Integer  STAT , TROUVE  # 62198
Local Decimal  CNS
Local Shortint I



Gosub INICPY

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call LECTURE("HRTES",[L]HRTES,"") From CONTOBJ

If [M:HREXS0]ISOLDE & [F:HRTES]PRO=2 & [F:HRTES]DEB=2 : # restitution d'avance
 If ![L]PAYE
  Read [SDP]SDP0=[M:HREXS0]REFNUM;[M:HREXS0]CTRNUM
  If !fstat : [L]CNS=-func SUBSLD.GETSOLDE([M:HREXS0]ISOLDE) : Endif
  If [L]CNS<=0
   [L]CNS=0
  Else
   Link [HREXS] With [HRTES]HRTES0~=CODEXP As [LNK]
   For [LNK]reckey Where REFNUM=[M:HREXS0]REFNUM & STA<2 & [HRTES]PRO=2 & [HRTES]DEB=2
    If [F:HREXS]DATEXS>=[M:HREXS0]STRDAT & [F:HREXS]DATEXS<=[M:HREXS0]ENDDAT
     I=find([F:HREXS]LIN,[M:HREXS0]LIN(0..[M:HREXS0]NBLIG-1))
     If !find(I,0,nolign) : [L]CNS-=[M:HREXS0]RFUCUR(I-1) : Endif
    Else
     [L]CNS-=[F:HREXS]RFUCUR
    Endif
    If [L]CNS<=0 : [L]CNS=0 : Break : Endif
   Next
   If [L]CNS>0
    For [HRTES]reckey Where PRO=2 & DEB=2
     For I=0 To [M:HREXS0]NBLIG-1
      If ![M:HREXS0]LIN(I) & I<>nolign-1 & [M:HREXS0]CODEXP(I)=[F:HRTES]CODEXP
       [L]CNS-=[M:HREXS0]RFUCUR(I)
       If [L]CNS<=0 : [L]CNS=0 : Break 2 : Endif
      Endif
     Next
    Next
   Endif
  Endif
 Endif

#Call LECTURE("TES",[L]TES,"") From CONTOBJ
#
#If [M:EXS0]ISOLDE & [F:TES]PRO=2 & [F:TES]DEB=2 : # restitution d'avance
# If ![L]PAYE
#  Read [SDP]SDP0=[M:EXS0]REFNUM;[M:EXS0]CTRNUM
#  If !fstat : [L]CNS=-func SUBSLD.GETSOLDE([M:EXS0]ISOLDE) : Endif
#  If [L]CNS<=0
#   [L]CNS=0
#  Else
#   Link [EXS] With [TES]TES0~=CODEXP As [LNK]
#   For [LNK]reckey Where REFNUM=[M:EXS0]REFNUM & STA<2 & [TES]PRO=2 & [TES]DEB=2
#    If [F:EXS]DATEXS>=[M:EXS0]STRDAT & [F:EXS]DATEXS<=[M:EXS0]ENDDAT
#     I=find([F:EXS]LIN,[M:EXS0]LIN(0..[M:EXS0]NBLIG-1))
#     If !find(I,0,nolign) : [L]CNS-=[M:EXS0]RFUCUR(I-1) : Endif
#    Else
#     [L]CNS-=[F:EXS]RFUCUR
#    Endif
#    If [L]CNS<=0 : [L]CNS=0 : Break : Endif
#   Next
#   If [L]CNS>0
#    For [TES]reckey Where PRO=2 & DEB=2
#     For I=0 To [M:EXS0]NBLIG-1
#      If ![M:EXS0]LIN(I) & I<>nolign-1 & [M:EXS0]CODEXP(I)=[F:TES]CODEXP
#       [L]CNS-=[M:EXS0]RFUCUR(I)
#       If [L]CNS<=0 : [L]CNS=0 : Break 2 : Endif
#      Endif
#     Next
#    Next
#   Endif
#  Endif
# Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Else
 Case [F:HRTES]TYPVLT
 When 1
  #56776
  #If [L]PAYE>0 : End : Endif
      [L]PAYE=func PARAM([F:HRTES]VLTDEFPAR,[M:HREXS0]FCY(nolign-1),[M:HREXS0]REFNUM,[L]DAT,TROUVE)
 When 2
  [L]PAYE=func PARAM([F:HRTES]VLTDEFPAR,[M:HREXS0]FCY(nolign-1),[M:HREXS0]REFNUM,[L]DAT,TROUVE)
 When 3
  [L]BKT=func PARAM("#10553",[M:HREXS0]FCY(nolign-1),[M:HREXS0]REFNUM,[L]DAT,TROUVE)
  [L]CAT=func PARAM("#10554",[M:HREXS0]FCY(nolign-1),[M:HREXS0]REFNUM,[L]DAT,TROUVE)
  Filter [HREXK] Where find(CPY,"",[L]CPY)<>0 & DAT<=[L]DAT & BKT=[L]BKT & CAT=[L]CAT
&                  & find(FCY,"",[M:HREXS0]FCY(nolign-1))<>0
&       Order By Key CLE=FCY Desc;CPY Desc;DAT Desc
  Read [HREXK] First
  Filter [HREXK]
  If !fstat : [L]PAYE=[F:HREXK]RAT : Else [L]PAYE=0 : Endif
 Endcase
Endif

#Else
# Case [F:TES]TYPVLT
# When 1
#  #56776
#  #If [L]PAYE>0 : End : Endif
#      [L]PAYE=func PARAM([F:TES]VLTDEFPAR,[M:EXS0]FCY(nolign-1),[M:EXS0]REFNUM,[L]DAT,TROUVE)
# When 2
#  [L]PAYE=func PARAM([F:TES]VLTDEFPAR,[M:EXS0]FCY(nolign-1),[M:EXS0]REFNUM,[L]DAT,TROUVE)
# When 3
#  [L]BKT=func PARAM("#553",[M:EXS0]FCY(nolign-1),[M:EXS0]REFNUM,[L]DAT,TROUVE)
#  [L]CAT=func PARAM("#554",[M:EXS0]FCY(nolign-1),[M:EXS0]REFNUM,[L]DAT,TROUVE)
#  Filter [EXK] Where find(CPY,"",[L]CPY)<>0 & DAT<=[L]DAT & BKT=[L]BKT & CAT=[L]CAT
#&                  & find(FCY,"",[M:EXS0]FCY(nolign-1))<>0
#&       Order By Key CLE=FCY Desc;CPY Desc;DAT Desc
#  Read [EXK] First
#  Filter [EXK]
#  If !fstat : [L]PAYE=[F:EXK]RAT : Else [L]PAYE=0 : Endif
# Endcase
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [V]GCURSHR<>[L]CUR & [M:HREXS0]RATRPT(nolign-1)<>0
 Call CONVERT3( [V]GCURSHR,[L]CUR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1)
&             , [L]DAT,[L]PAYE,[L]PAYE,1/[M:HREXS0]RATRPT(nolign-1),[L]STAT
&             ) From CPTSUB
 Call CONVERT3( [V]GCURSHR,[L]CUR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1)
&             , [L]DAT,[L]CNS,[L]CNS,1/[M:HREXS0]RATRPT(nolign-1),[L]STAT
&             ) From CPTSUB
Endif

#If [V]GCURSHR<>[L]CUR & [M:EXS0]RATRPT(nolign-1)<>0
# Call CONVERT3( [V]GCURSHR,[L]CUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1)
#&             , [L]DAT,[L]PAYE,[L]PAYE,1/[M:EXS0]RATRPT(nolign-1),[L]STAT
#&             ) From CPTSUB
# Call CONVERT3( [V]GCURSHR,[L]CUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1)
#&             , [L]DAT,[L]CNS,[L]CNS,1/[M:EXS0]RATRPT(nolign-1),[L]STAT
#&             ) From CPTSUB
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


[L]PAYE=[L]PAYE*[L]QTY+[L]CNS


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
## fq 105501
Call INITVA([L]CUR,[M:HREXS0]VAT(nolign-1),[M:HREXS0]FCY(nolign-1),[M:HREXS0]DATEXS(nolign-1),[L]PAYE,[M:HREXS0]VATCUR(nolign-1))
Call INIREMB([L]DAT,[L]HRTES,[L]CUR,[L]QTY,[L]PAYE,[M:HREXS0]RFUCUR(nolign-1))

### fq 105501
#Call INITVA([L]CUR,[M:EXS0]VAT(nolign-1),[M:EXS0]FCY(nolign-1),[M:EXS0]DATEXS(nolign-1),[L]PAYE,[M:EXS0]VATCUR(nolign-1))
#Call INIREMB([L]DAT,[L]TES,[L]CUR,[L]QTY,[L]PAYE,[M:EXS0]RFUCUR(nolign-1))
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#62198
If mkstat=2 : End : Endif


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call CONVERT3( [L]CUR,[V]GCURSHR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1),[L]DAT
&            , [L]PAYE,[M:HREXS0]PAYSHR(nolign-1),[M:HREXS0]RATCPY(nolign-1),[L]STAT
&            ) From CPTSUB

#Call CONVERT3( [L]CUR,[V]GCURSHR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1),[L]DAT
#&            , [L]PAYE,[M:EXS0]PAYSHR(nolign-1),[M:EXS0]RATCPY(nolign-1),[L]STAT
#&            ) From CPTSUB
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#62220
#Call CONVERT3( [L]CUR,[L]CUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1),[L]DAT
#&            , [L]PAYE,[L]PAYE,[M:EXS0]RATCPY(nolign-1),[L]STAT
#&            ) From CPTSUB
# 67388, maj correction 62220 - il faut arrondir le montant payé et pas le reconvertir.
# sinon, pour les devises de cours <> 1 (à priori toutes sauf devise locale)
# on alimente à tort par le montant en devise locale au lieu de laisser le montant converti


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call CONVERT3( [L]CUR,[L]CUR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1),[L]DAT
&            , [L]PAYE,[L]PAYE,1,[L]STAT
&            ) From CPTSUB

#Call CONVERT3( [L]CUR,[L]CUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1),[L]DAT
#&            , [L]PAYE,[L]PAYE,1,[L]STAT
#&            ) From CPTSUB
#DIRAS - 2017/05/10 - JIRA X3-11253 - END



End

