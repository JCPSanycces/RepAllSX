#&                   , [F:AWS]ACTSIG = REP
#&                   , [F:AWS]USRSIG = GUSER
#&                   , [F:AWS]DATSIG = date$
#Else
#  If [L]STA <> 2 | [L]STA = [F:EXS]EXSSTA | GWEBSERV : End : Endif
#
#  Local Char REP (GLONADI)
#  If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif
#
#  Case [L]STA
#   When [F:EXS]EXSSTA + 1 : REP = "CMP"
#   When [F:EXS]EXSSTA - 1 : REP = "VIS"
#   When [F:EXS]EXSSTA - 2 : REP = "REF"
#   When Default           : REP = "ANN"
#  Endcase
#
#  Update [F:AWS] Where VALCTX1 = [F:EXS]REFNUM
#&                    & VALCTX2 = num$([F:EXS]EXSNUM)
#&                    & VALCTX3 = "20"
#&                    & VALCTX4 = [F:EXS]CTRNUM
#&                    & FLGSIG  = 3
#&                With [F:AWS]FLGSIG = 5
#&                   , [F:AWS]ACTSIG = REP
#&                   , [F:AWS]USRSIG = GUSER
#&                   , [F:AWS]DATSIG = date$
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
End

