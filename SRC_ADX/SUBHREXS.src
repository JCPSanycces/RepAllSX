$TR_VISA
[V]GOK=1

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Trbegin [HREXS]
 Update [HREXS] Where EXSNUM=[M:HREXS0]EXSNUM With STAFLG=[V]GUSER, STADAT=date$ ,EXSSTA=3
 If fstat
  [V]GOK=0
  Call RSTA("HREXS",num$([M:HREXS0]EXSNUM)) From GLOCK
  Rollback
  Return
 Endif
Commit

