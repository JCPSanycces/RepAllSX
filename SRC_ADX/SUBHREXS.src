Call B3_NBLIG
READSTAT = func PRHPORATT.FILTER_AOX("HREXS",[M:HREXS0]REFNUM,[M:HREXS0]EXSNUM,[M:HREXS0]UID(nolign-1))
If READSTAT = 1
  VALEUR="175"
Else
  VALEUR=""
Endif

