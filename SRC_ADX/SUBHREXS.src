########################################
Subprog C_CCE(VALEUR)
Variable Char VALEUR

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Local Char     FCY([V]GLONFCY), CODE([V]GLONHRTES), CCE(20), ABREV(3)
#Local Char     FCY([V]GLONFCY), CODE([V]GLONTES), CCE(20), ABREV(3)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
Local Date     DAT
Local Shortint NOL

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
[L]FCY  =[M:HREXS0]FCY(nolign-1)
[L]DAT  =[M:HREXS0]DATEXS(nolign-1)
[L]CODE =[M:HREXS0]CODEXP(nolign-1)
[L]CCE  ="[M:HREXS0]CCE#"
[L]ABREV="HRTES"
[L]NOL  =nolign-1

#[L]FCY  =[M:EXS0]FCY(nolign-1)
