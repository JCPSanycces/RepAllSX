#-------------------------------------------------------------------------------
Subprog INITVA(CUR,TAX,FCY,DAT,PAYE,TVA)   ## Fq 105501
Value    Char    CUR(),TAX(), FCY()
Value    Date    DAT
Value    Decimal PAYE
Variable Decimal TVA

If find("",[L]CUR,[L]TAX) | [L]PAYE=0 : [L]TVA=0 : End : Endif

##Call LECTURE("ADI",[L]TAX,"552") From CONTOBJ Fq 105501
If !clalev([TRA]): Local File =GTABCPT+"TABRATVAT": Endif

Local Char LEGCPY(GLONCPY)
[L]LEGCPY=func DIVPAYE.GETSOC(FCY)

Raz [TRA]
Filter [F:TRA] Where VAT=TAX & CPY=[L]LEGCPY & STRDAT<=DAT
Read [F:TRA]TRA1 Last
If fstat
   Filter [F:TRA] Where VAT=TAX & CPY="" & STRDAT<=DAT
   Read [F:TRA]TRA1 Last
Endif
Filter [TRA]

##[L]TVA=[F:ADI]N1*0.01*[L]PAYE/(1+[F:ADI]N1*0.01) ##Fq 105501
[L]TVA=[F:TRA]VATRAT*0.01*[L]PAYE/(1+[F:TRA]VATRAT*0.01)  ##Fq 105501
Call ARRDEV([L]TVA,[L]CUR)From TRTDIV

End

#-------------------------------------------------------------------------------
Subprog INITAX(CUR,TAX,FCY,DAT,PAYE,TVA,REMB)
Value Char    CUR(), TAX(), FCY()
Value Date    DAT
Value Decimal TVA, PAYE, REMB


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If find("",[L]CUR,[L]TAX) | find(0,[L]REMB,[L]PAYE,[L]TVA)
 Raz [M:HREXS0]TAXCUR(nolign-1), [M:HREXS0]DEDCUR(nolign-1)
 End
Endif

#If find("",[L]CUR,[L]TAX) | find(0,[L]REMB,[L]PAYE,[L]TVA)
# Raz [M:EXS0]TAXCUR(nolign-1), [M:EXS0]DEDCUR(nolign-1)
# End
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


## Fq 105501
##Call LECTURE("ADI",[L]TAX,"552") From CONTOBJ

If !clalev([TRA]): Local File =GTABCPT+"TABRATVAT" : Endif

Local Char LEGCPY(GLONCPY)
[L]LEGCPY=func DIVPAYE.GETSOC(FCY)

Call LEC_FCY([L]FCY) From CPTLEC
Raz [TRA]
Filter [F:TRA] Where VAT=TAX & CPY=[L]LEGCPY & STRDAT<=DAT
Read [F:TRA]TRA1 Last
If fstat
   Filter [F:TRA] Where VAT=TAX & CPY="" & STRDAT<=DAT
   Read [F:TRA]TRA1 Last
Endif
Filter [TRA]

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [L]REMB<[L]PAYE : [M:HREXS0]TAXCUR(nolign-1)=[L]TVA*[L]REMB/[L]PAYE
Else                 [M:HREXS0]TAXCUR(nolign-1)=[L]TVA
Endif
Call ARRDEV([M:HREXS0]TAXCUR(nolign-1),[L]CUR)From TRTDIV
##[M:EXS0]DEDCUR(nolign-1)=[F:ADI]N2*0.01*[M:EXS0]TAXCUR(nolign-1)  ## Fq 105501
[M:HREXS0]DEDCUR(nolign-1)=[F:TRA]DEDRAT*0.01*[M:HREXS0]TAXCUR(nolign-1)
Call ARRDEV([M:HREXS0]DEDCUR(nolign-1),[L]CUR) From TRTDIV

#If [L]REMB<[L]PAYE : [M:EXS0]TAXCUR(nolign-1)=[L]TVA*[L]REMB/[L]PAYE
#Else                 [M:EXS0]TAXCUR(nolign-1)=[L]TVA
#Endif
#Call ARRDEV([M:EXS0]TAXCUR(nolign-1),[L]CUR)From TRTDIV
###[M:EXS0]DEDCUR(nolign-1)=[F:ADI]N2*0.01*[M:EXS0]TAXCUR(nolign-1)  ## Fq 105501
#[M:EXS0]DEDCUR(nolign-1)=[F:TRA]DEDRAT*0.01*[M:EXS0]TAXCUR(nolign-1)
#Call ARRDEV([M:EXS0]DEDCUR(nolign-1),[L]CUR) From TRTDIV
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

#-------------------------------------------------------------------------------
Funprog PARAM(PARAM,FCY,MAT,DAT,TROUVE)
Value Char PARAM(), MAT(), FCY()
Value Date DAT
Variable Integer TROUVE :  # 62198

# 62198
TROUVE = 1

If !clalev([F:EXN]) : Local File EMPLOEXN [EXN] : Endif
Local Char CPY([V]GLONCPY)

Filter [EXN] Where REFNUM=[L]MAT & EXSVAR=[L]PARAM & EXSDAT<=[L]DAT
&     Order By Key CLE=EXSDAT Desc
Read [EXN] First
Filter [EXN]
If !fstat
 End [F:EXN]EXSAMT
Else
 # 62077
 #If !clalev([F:VLA]) : Local File VALEUR [VLA] : Endif
 #If [L]FCY>"" : [L]CPY=[V]GSOCSITE(find([L]FCY,[V]GSITE(1..[V]GNBSITE))) : Endif
 #Filter [VLA] Where VARCOD=[L]PARAM & DAT<=[L]DAT & find(CPY,"",[L]CPY)<>0
 #&                 & find(FCY,"",[L]FCY)<>0
 #&      Order By Key CLE=TYP Desc;DAT Desc
 #Read [VLA] First
 #Filter [VLA]
 #If !fstat : End [F:VLA]VARVAL : Else End 0 : Endif

 If !clalev([F:VLA]) : Local File VALEUR [VLA] : Endif
 If !clalev([F:VFD]) : Local File VALFDR [VFD] : Endif
 If !clalev([F:VFC]) : Local File VALFCY [VFC] : Endif
 If !clalev([F:VCP]) : Local File VALCPY [VCP] : Endif

 If [L]FCY>"" : [L]CPY=[V]GSOCSITE(find([L]FCY,[V]GSITE(1..[V]GNBSITE))) : Endif

 Filter [VFC] Where FCY=[L]FCY & DAT<=[L]DAT
 Read [VFC]VFC0 Last
 Filter [VFC]
 If !fstat
  #62911
  #Read [F:VLA]VLA0=3;"";[L]FCY;"";[F:VFD]DAT;[L]PARAM;""
#DIRAS - 2017/05/18 - JIRA X3-11253 - START
#MIPEA - 2017/05/30 - JIRA X3-11253 - START
  Read [F:VLA]VLA0=3;"";"";[L]FCY;"";[F:VFC]DAT;[L]PARAM;""
#  Read [F:VLA]VLA0=3;GCURLEG;"";[L]FCY;"";[F:VFC]DAT;[L]PARAM;""
#MIPEA - 2017/05/30 - JIRA X3-11253 - END
#  Read [F:VLA]VLA0=3;"";[L]FCY;"";[F:VFC]DAT;[L]PARAM;""
#DIRAS - 2017/05/18 - JIRA X3-11253 - END
  If !fstat : End [F:VLA]VARVAL : Endif
 Endif

 Filter [VCP] Where CPY=[L]CPY & DAT<=[L]DAT
 Read [VCP]VCP0 Last
 Filter [VCP]
 If !fstat
  #62911
  #Read [F:VLA]VLA0=2;[L]CPY;"";"";[F:VFD]DAT;[L]PARAM;""
#DIRAS - 2017/05/18 - JIRA X3-11253 - START
#MIPEA - 2017/05/30 - JIRA X3-11253 - START
  Read [F:VLA]VLA0=2;"";[L]CPY;"";"";[F:VCP]DAT;[L]PARAM;""
#  Read [F:VLA]VLA0=2;GCURLEG;[L]CPY;"";"";[F:VCP]DAT;[L]PARAM;""
#MIPEA - 2017/05/30 - JIRA X3-11253 - END
#  Read [F:VLA]VLA0=2;[L]CPY;"";"";[F:VCP]DAT;[L]PARAM;""
#DIRAS - 2017/05/18 - JIRA X3-11253 - END
  If !fstat : End [F:VLA]VARVAL : Endif
 Endif

 Filter [VFD] Where DAT<=[L]DAT
 Read [VFD]VFD0 Last
 Filter [VFD]
 If !fstat
#DIRAS - 2017/05/18 - JIRA X3-11253 - START
  Read [F:VLA]VLA0=1;GCURLEG;"";"";"";[F:VFD]DAT;[L]PARAM;""
#  Read [F:VLA]VLA0=1;"";"";"";[F:VFD]DAT;[L]PARAM;""
#DIRAS - 2017/05/18 - JIRA X3-11253 - END
  If !fstat : End [F:VLA]VARVAL : Endif
 Endif
 TROUVE = 0
 End 0
 # fin 62077
Endif

Subprog MAJ_HISSUI(STA)
Value Integer STA
#STA = valeur avant modif - On ne traite que "Demande",seul à générer un suivi à signer
#Mise à jour du suivi workflow

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [L]STA=1 & GREP='A' Then
  REP="ANN"
  Update [F:AWS] Where VALCTX1 = [F:HREXS]REFNUM
&                    & VALCTX2 = num$([F:HREXS]EXSNUM)
&                    & VALCTX3 = "20"
&                    & VALCTX4 = [F:HREXS]CTRNUM
&                With [F:AWS]FLGSIG = 5
&                   , [F:AWS]ACTSIG = REP
&                   , [F:AWS]USRSIG = GUSER
&                   , [F:AWS]DATSIG = date$
Else
  If [L]STA <> 2 | [L]STA = [F:HREXS]EXSSTA | GWEBSERV : End : Endif

  Local Char REP (GLONADI)
  If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif

  Case [L]STA
   When [F:HREXS]EXSSTA + 1 : REP = "CMP"
   When [F:HREXS]EXSSTA - 1 : REP = "VIS"
   When [F:HREXS]EXSSTA - 2 : REP = "REF"
   When Default           : REP = "ANN"
  Endcase

  Update [F:AWS] Where VALCTX1 = [F:HREXS]REFNUM
&                    & VALCTX2 = num$([F:HREXS]EXSNUM)
&                    & VALCTX3 = "20"
&                    & VALCTX4 = [F:HREXS]CTRNUM
&                    & FLGSIG  = 3
&                With [F:AWS]FLGSIG = 5
&                   , [F:AWS]ACTSIG = REP
&                   , [F:AWS]USRSIG = GUSER
&                   , [F:AWS]DATSIG = date$
Endif

#If [L]STA=1 & GREP='A' Then
#  REP="ANN"
#  Update [F:AWS] Where VALCTX1 = [F:EXS]REFNUM
#&                    & VALCTX2 = num$([F:EXS]EXSNUM)
#&                    & VALCTX3 = "20"
#&                    & VALCTX4 = [F:EXS]CTRNUM
