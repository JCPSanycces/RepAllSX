$EXEBOUT
Case [L]BOUT
When "V"

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Filter [AWS] Where ABROBJ="HREXS" & FLGSIG=3
&                 & CLEOBJ=num$([M:HREXS0]EXSNUM)+"~"+[M:HREXS0]REFNUM+"~"+[M:HREXS0]CTRNUM+"~"
 Look [AWS] First
 Filter [AWS]
 If !fstat
  Call SIGNATURE([L]ABREV,[L]CLECUR1,[L]CLECUR2,[L]OK) From GOBJACT
  If [L]OK<>0
   Gosub RELIT From GOBJSUB
  Endif
  Return
 Endif

#Filter [AWS] Where ABROBJ="EXS" & FLGSIG=3
#&                 & CLEOBJ=num$([M:EXS0]EXSNUM)+"~"+[M:EXS0]REFNUM+"~"+[M:EXS0]CTRNUM+"~"
