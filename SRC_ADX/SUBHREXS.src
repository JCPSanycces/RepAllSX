Subprog AS_CCE20(VALEUR)
Variable Char    VALEUR()
Local Integer AXE
AXE = 20: Goto SAICCE

$SAICCE
Local Integer I
Local Char TLED(GLONLED), ACC(GLONGAC)
Local Integer NLED, IND, AXI

If !clalev([F:FCY]): Local File FACILITY [FCY]: Endif
If !clalev([F:CPY]): Local File COMPANY  [CPY]: Endif
If !clalev([F:GCM]): Local File =GTABCPT+"GACM"     [GCM]: Endif
If !clalev([F:LED]): Local File =GTABCPT+"GLED"     [LED]: Endif
If !clalev([F:GAC]): Local File =GTABCPT+"GACCOUNT" [GAC]: Endif
If !clalev([F:CAC]): Local File GACCCODE [CAC]: Endif



 Call LEC_FCY([M]FCY(nolign-1)) From CPTLEC
 GSOCIETE=[F:FCY]LEGCPY
 Call LEC_CPY(GSOCIETE) From CPTLEC

 If !find([M]DIETYP(AXE-1),[F:CPY]DIE()): mkstat=2: End: Endif

 Call LEC_GCM([F:CPY]ACM) From CPTLEC



mkstat = 2
For NLED=1 To 10
 If [F:GCM]LED(NLED-1)="": Break: Endif
 [L]TLED=[F:GCM]LED(NLED-1)
 Call LEC_LED([L]TLED) From CPTLEC
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
 Call LEC_CAC(11,[F:HRTES]ACCCOD,[F:LED]COA) From CPTLEC
# Call LEC_CAC(11,[F:TES]ACCCOD,[F:LED]COA) From CPTLEC
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


 Call INDLED([L]TLED,[M]DIETYP(AXE-1),IND,AXI) From CPTDIV
 If AXI
   Call LECTURE("GAC",[F:CAC]ACC(0),[F:LED]COA) From CONTOBJ
   If find([M]DIETYP(AXE-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : Raz mkstat : Break : Endif
 Endif
Next
If mkstat: End: Endif



Gosub DEFCCE


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call LECTURE("HRTES",[M]CODEXP(nolign-1),"") From CONTOBJ
I=find([M]DIETYP(AXE-1),[F:HRTES]DIE())
If I
  If [F:HRTES]CCEDAC(I-1)<>2
    mkstat=2
  Endif
Endif

#Call LECTURE("TES",[M]CODEXP(nolign-1),"") From CONTOBJ
#I=find([M]DIETYP(AXE-1),[F:TES]DIE())
#If I
#  If [F:TES]CCEDAC(I-1)<>2
#    mkstat=2
#  Endif
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END



End

######################################################################################
Subprog CCEFIC(FIC,ECR,NOL)
Value Char     FIC(), ECR()
Value Shortint NOL

If ![V]GOPTCANA : End : Endif

Local Integer I, J

If [L]FIC>"" : Default File "["+[L]FIC+"]" : Endif
If [L]ECR>"" : Default Mask "["+[L]ECR+"]" : Endif

If !clalev([F:FCY]): Local File FACILITY [FCY]: Endif
If !clalev([F:CPY]): Local File COMPANY  [CPY]: Endif

Call LEC_FCY([M]FCY([L]NOL)) From CPTLEC
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC

Raz [F]DIE, [F]CCE

For I=1 To dim([F]DIE)
 If [F:CPY]DIE(I-1)<>""
   J=find([F:CPY]DIE(I-1),[M]DIETYP())
   If J
     [F]DIE(I-1)=[M]DIETYP(J-1)
     [F]CCE(I-1)=evalue("[M]CCE"+num$(J)+"([L]NOL)")
   Endif
 Endif
Next

End

Subprog CCEMSK(FIC,ECR,NOL)
Value Char     FIC(), ECR()
Value Shortint NOL


If ![V]GOPTCANA : End : Endif
If NOL=0: Gosub DIE_TYP: Endif
Local Integer I, J

If [L]FIC>"" : Default File "["+[L]FIC+"]" : Endif
If [L]ECR>"" : Default Mask "["+[L]ECR+"]" : Endif

If !clalev([F:FCY]): Local File FACILITY [FCY]: Endif
If !clalev([F:CPY]): Local File COMPANY  [CPY]: Endif

Call LEC_FCY([M]FCY([L]NOL)) From CPTLEC
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC

For I=1 To dim([F:CPY]DIE)
  If [F:CPY]DIE(I-1)<>""
     J=find([F:CPY]DIE(I-1),[M]DIETYP())
     If J
       Case J
          When 1: [M]CCE1([L]NOL)=[F]CCE(I-1)
          When 2: [M]CCE2([L]NOL)=[F]CCE(I-1)
          When 3: [M]CCE3([L]NOL)=[F]CCE(I-1)
          When 4: [M]CCE4([L]NOL)=[F]CCE(I-1)
          When 5: [M]CCE5([L]NOL)=[F]CCE(I-1)
          When 6: [M]CCE6([L]NOL)=[F]CCE(I-1)
          When 7: [M]CCE7([L]NOL)=[F]CCE(I-1)
          When 8: [M]CCE8([L]NOL)=[F]CCE(I-1)
          When 9: [M]CCE9([L]NOL)=[F]CCE(I-1)
          When 10: [M]CCE10([L]NOL)=[F]CCE(I-1)
          When 11: [M]CCE11([L]NOL)=[F]CCE(I-1)
          When 12: [M]CCE12([L]NOL)=[F]CCE(I-1)
          When 13: [M]CCE13([L]NOL)=[F]CCE(I-1)
          When 14: [M]CCE14([L]NOL)=[F]CCE(I-1)
          When 15: [M]CCE15([L]NOL)=[F]CCE(I-1)
          When 16: [M]CCE16([L]NOL)=[F]CCE(I-1)
          When 17: [M]CCE17([L]NOL)=[F]CCE(I-1)
          When 18: [M]CCE18([L]NOL)=[F]CCE(I-1)
          When 19: [M]CCE19([L]NOL)=[F]CCE(I-1)
          When 20: [M]CCE20([L]NOL)=[F]CCE(I-1)

       Endcase
     Endif
  Endif
Next



End
