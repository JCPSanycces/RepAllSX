$OUVRE
Local Libelle ISOLDE
Local Integer NDFNUM , SAVEXSSTA
Local Integer READSTAT

If clalev([F:HRTES])=0 : Local File HRTABEXPENS     [HRTES] : Endif #FRLAA X3-91917 2018-10-03


#MIPEA - 2017/05/30 - JIRA X3-11253 - START
Call PARAM(GCURLEG,"EXSADV",[L]CHAINE) From ADOVAL
#Call PARAM("","EXSADV",[L]CHAINE) From ADOVAL
#MIPEA - 2017/05/30 - JIRA X3-11253 - END
If val([L]CHAINE)
 [L]ISOLDE=val([L]CHAINE)
Elsif [L]CHAINE>""
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
 Call LECTURE("ADI",[L]CHAINE,"10365") From CONTOBJ
# Call LECTURE("ADI",[L]CHAINE,"365") From CONTOBJ
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
 If !fstat | [F:ADI]N1>0 : [L]ISOLDE=[F:ADI]N1 : Endif
Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Affzo [HREXS0]LEG


#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Return

