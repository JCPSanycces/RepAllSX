Subprog INIREMB(DAT,HRTES,CUR,QTY,PAYE,REMB)
Value    Date    DAT
Value    Char    HRTES(), CUR()
Value    Decimal QTY,PAYE
Variable Decimal REMB


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If find("",[L]HRTES,[L]CUR) | [L]DAT=[0/0/0] | find(0,[L]QTY,[L]PAYE)
 Raz [L]REMB, [M:HREXS0]RFUSHR(nolign-1)
 End
Endif

#If find("",[L]TES,[L]CUR) | [L]DAT=[0/0/0] | find(0,[L]QTY,[L]PAYE)
# Raz [L]REMB, [M:EXS0]RFUSHR(nolign-1)
# End
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


Local Integer STAT, TROUVE  # 62198

Gosub INICPY

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call LECTURE("HRTES",[L]HRTES,"") From CONTOBJ
Call LECTURE("CPY",[L]CPY,"") From CONTOBJ

#Call LECTURE("TES",[L]TES,"") From CONTOBJ
#Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Case [F:HRTES]TYPVLT
When 3
 [L]REMB                 =[L]PAYE
 [M:HREXS0]RFUSHR(nolign-1)=[L]PAYE
 #62220
 #Call INITAX([L]CUR,[M:EXS0]VAT(nolign-1),[L]PAYE,[M:EXS0]VATCUR(nolign-1),[L]REMB)
 #End
When 2
 [L]REMB=func PARAM([F:HRTES]VLTPFDPAR,[M:HREXS0]FCY(nolign-1),[M:HREXS0]REFNUM,[L]DAT,TROUVE)
 If [V]GCURSHR=[L]CUR
  If [L]REMB>0 : [L]REMB=min([L]PAYE,[L]REMB*[L]QTY)
  Else           [L]REMB=[L]PAYE
  Endif
 Elsif [L]REMB=0 | [M:EXS0]RATRPT(nolign-1)=0
  [L]REMB=[L]PAYE
 Else
  Call CONVERT3( [V]GCURSHR,[L]CUR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1)
&              , [L]DAT,[L]REMB,[L]REMB,1/[M:HREXS0]RATRPT(nolign-1),[L]STAT
&              ) From CPTSUB
  [L]REMB=min([L]PAYE,[L]REMB*[L]QTY)
 Endif
When 1
 [L]REMB =[L]QTY
&       * func PARAM([F:HRTES]VLTDEFPAR,[M:HREXS0]FCY(nolign-1),[M:HREXS0]REFNUM,[L]DAT,TROUVE)

 # 62198
 If TROUVE=0
  # Forfait non défini dans la variable
  Raz [M:HREXS0]VATCUR(nolign-1)
  GMESSAGE = mess(28,10718,1)-[F:HRTES]VLTDEFPAR
  mkstat=2 : End
 Endif
 # fin 62198

 # 57160
 If [V]GCURSHR<>[L]CUR
  Call CONVERT3( [V]GCURSHR,[L]CUR,[F:CPY]ACCCUR,[M:HREXS0]TYPRAT(nolign-1)
&              , [L]DAT,[L]REMB,[L]REMB,1/[M:HREXS0]RATRPT(nolign-1),[L]STAT
&              ) From CPTSUB
 Endif
 #
Endcase

#Case [F:TES]TYPVLT
#When 3
# [L]REMB                 =[L]PAYE
# [M:EXS0]RFUSHR(nolign-1)=[L]PAYE
# #62220
# #Call INITAX([L]CUR,[M:EXS0]VAT(nolign-1),[L]PAYE,[M:EXS0]VATCUR(nolign-1),[L]REMB)
# #End
#When 2
# [L]REMB=func PARAM([F:TES]VLTPFDPAR,[M:EXS0]FCY(nolign-1),[M:EXS0]REFNUM,[L]DAT,TROUVE)
# If [V]GCURSHR=[L]CUR
#  If [L]REMB>0 : [L]REMB=min([L]PAYE,[L]REMB*[L]QTY)
#  Else           [L]REMB=[L]PAYE
#  Endif
# Elsif [L]REMB=0 | [M:EXS0]RATRPT(nolign-1)=0
#  [L]REMB=[L]PAYE
# Else
#  Call CONVERT3( [V]GCURSHR,[L]CUR,[F:CPY]ACCCUR,[M:EXS0]TYPRAT(nolign-1)
#&              , [L]DAT,[L]REMB,[L]REMB,1/[M:EXS0]RATRPT(nolign-1),[L]STAT
#&              ) From CPTSUB
#  [L]REMB=min([L]PAYE,[L]REMB*[L]QTY)
# Endif
#When 1
# [L]REMB =[L]QTY
#&       * func PARAM([F:TES]VLTDEFPAR,[M:EXS0]FCY(nolign-1),[M:EXS0]REFNUM,[L]DAT,TROUVE)
#
