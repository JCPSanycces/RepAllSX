$FILTRE
[L]FILTSUP="LIN>0"
If [V]GUSRACS<>2 & [V]GNBSERV<nbrecord([SRV])
 [L]FILTSUP-="& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Endif
If !instr(1,[V]GUSRAUZ(1),"1") : [L]FILTSUP-="& REFNUM='"+[V]GREFNUM+"'" : Endif
#61751
If GUSRACS<>2
 FILTSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
Endif
Return

