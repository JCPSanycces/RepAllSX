#  Endif
#  Return
# Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
[L]OK=2
 Call OUINON(mess(27,10709,1),[L]OK) From GESECRAN : # Confirmation du visa
 If [L]OK=2
  Call DEBTRANS From GLOCK
  Gosub TR_VISA
  If [V]GOK=1 : [M:HREXS0]EXSSTA=3 : Affzo [HREXS0] EXSSTA : Endif
 Endif
Endcase

#[L]OK=2
# Call OUINON(mess(27,709,1),[L]OK) From GESECRAN : # Confirmation du visa
# If [L]OK=2
#  Call DEBTRANS From GLOCK
