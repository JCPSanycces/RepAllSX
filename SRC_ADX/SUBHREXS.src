Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [M:HREXS0]CTRNUM=""
 Call SELCTR([M:HREXS0]REFNUM,[M:HREXS0]STRDAT,[M:HREXS0]ENDDAT,VALEUR) From DIVPAYE
 If VALEUR="" & GMESSAGE<>""
  Call ERREUR(GMESSAGE) From GESECRAN
 Endif
Endif

