Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
For nolign=1 To [M:HREXS0]NBLIG
 # test date nulle pour webservices !
 If [M:HREXS0]DATEXS(nolign-1)>[0/0/0]
& & ([M:HREXS0]DATEXS(nolign-1)>[L]VALEUR | [M:HREXS0]DATEXS(nolign-1)<[M:HREXS0]STRDAT)
  [V]GMESSAGE=mess(3,10718,1)-"("+mess(61,100,1)-num$(nolign)+")"
  #           Date en dehors de la période (ligne no )
  mkstat     =2
  Break
 Endif
Next

#For nolign=1 To [M:EXS0]NBLIG
# # test date nulle pour webservices !
# If [M:EXS0]DATEXS(nolign-1)>[0/0/0]
#& & ([M:EXS0]DATEXS(nolign-1)>[L]VALEUR | [M:EXS0]DATEXS(nolign-1)<[M:EXS0]STRDAT)
#  [V]GMESSAGE=mess(3,718,1)-"("+mess(61,100,1)-num$(nolign)+")"
#  #           Date en dehors de la période (ligne no )
#  mkstat     =2
#  Break
# Endif
#Next
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

If mkstat : End : Endif

If [F:ID]FLGMULCTR<2
 # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
# Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRDAT<=[L]VALEUR & (XITDAT>=[M:EXS0]STRDAT | XITDAT=[0/0/0])

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Filter [HRCTR] Where REFNUM=[M:HREXS0]REFNUM & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR)) & (XITDAT>=[M:HREXS0]STRDAT | XITDAT=[0/0/0])
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR)) & (XITDAT>=[M:HREXS0]STRDAT | XITDAT=[0/0/0])
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

 # Fin MABON

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
 Read [HRCTR]CTR0 First
 Filter [HRCTR]

# Read [CTR]CTR0 First
# Filter [CTR]
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If fstat
  [V]GMESSAGE=func AFNC.MES2( mess(171,10709,1),format$([V]GFMD,[M:HREXS0]STRDAT)
&                           , format$([V]GFMD,[L]VALEUR)
&                           )
  #           Pas de contrat de travail pour la période du $1$ au $2$
  mkstat     =2
  End
 Else
  [M:HREXS0]CTRNUM=[F:HRCTR]CTRNUM
    Gosub DIE_TYP ## FQ 105501
  #57139
  [M:HREXS0]ETRFCY=[F:HRCTR]ETRFCY
  [M:HREXS0]ETRSRV=[F:HRCTR]ETRSRV
  Affzo [HREXS0]ETRFCY,ETRSRV
  # fin 57139
  Affzo [HREXS0] CTRNUM
 Endif
Endif

#If fstat
#  [V]GMESSAGE=func AFNC.MES2( mess(171,709,1),format$([V]GFMD,[M:EXS0]STRDAT)
#&                           , format$([V]GFMD,[L]VALEUR)
#&                           )
#  #           Pas de contrat de travail pour la période du $1$ au $2$
#  mkstat     =2
#  End
# Else
#  [M:EXS0]CTRNUM=[F:CTR]CTRNUM
#    Gosub DIE_TYP ## FQ 105501
#  #57139
#  [M:EXS0]ETRFCY=[F:CTR]ETRFCY
#  [M:EXS0]ETRSRV=[F:CTR]ETRSRV
#  Affzo [EXS0]ETRFCY,ETRSRV
#  # fin 57139
#  Affzo [EXS0] CTRNUM
# Endif
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

