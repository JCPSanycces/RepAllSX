#-------------------------------------------------------------------------------
Subprog TOTAUX()

Local Shortint I, J

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Raz [M:HREXS0]TOTPAY, [M:HREXS0]TOTRFU, [M:HREXS0]TOTSTA
For J=0 To [M:HREXS0]NBLIG-1
 If [M:HREXS0]SNS(J)="+" : I=1 : Else I=-1 : Endif
 [M:HREXS0]TOTPAY+=I*[M:HREXS0]PAYSHR(J)
 [M:HREXS0]TOTRFU+=I*[M:HREXS0]RFUSHR(J)
 If [M:HREXS0]STA(J)=2 : [M:HREXS0]TOTSTA+=I*[M:HREXS0]RFUSHR(J) : Endif
Next

#Raz [M:EXS0]TOTPAY, [M:EXS0]TOTRFU, [M:EXS0]TOTSTA
#For J=0 To [M:EXS0]NBLIG-1
# If [M:EXS0]SNS(J)="+" : I=1 : Else I=-1 : Endif
# [M:EXS0]TOTPAY+=I*[M:EXS0]PAYSHR(J)
# [M:EXS0]TOTRFU+=I*[M:EXS0]RFUSHR(J)
# If [M:EXS0]STA(J)=2 : [M:EXS0]TOTSTA+=I*[M:EXS0]RFUSHR(J) : Endif
#Next
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

End

$APRES_MOD
Local Integer RESULT

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Local Char VLUID(20)(1..[M:HREXS0]NBLIG)

#Local Char VLUID(20)(1..[M:EXS0]NBLIG)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
#Populating a list with all the UID per line
For nolign=1 To [M:HREXS0]NBLIG
  VLUID(nolign) = num$([M:HREXS0]UID(nolign-1))
Next

##Populating a list with all the UID per line
#For nolign=1 To [M:EXS0]NBLIG
#  VLUID(nolign) = num$([M:EXS0]UID(nolign-1))
#Next
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#Check if there are attachments on deleted lines that must be removed

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Call DELETE_AOX_ATTACH("HREXS",[F:HREXS]REFNUM,num$([F:HREXS]EXSNUM),VLUID,2)From PRHPORATT

#Call DELETE_AOX_ATTACH("EXS",[F:EXS]REFNUM,num$([F:EXS]EXSNUM),VLUID,2)From PRHPORATT
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Gosub WRITE_EXPENSES #FRLAA 2018-05-23 X3-91917
Return

#-------------------------------------------------------------------------------
Subprog LITDAT(OBJ,DEB,FIN)
Value    Char OBJ
Variable Date DEB, FIN

If !clalev([F:ALS]) : Local File ALSTRD [ALS] : Endif

Read [ALS]ALS0=[V]GUSER;tolower([L]OBJ);1
If    !fstat             : [L]DEB=gdat$([F:ALS]CLES)
Elsif [V]GMOIPAY>[0/0/0] : [L]DEB=[V]GMOIPAY
Else                       [L]DEB=1+eomonth(addmonth(datesyst,-1))
Endif
Read [ALS]ALS0=[V]GUSER;tolower([L]OBJ);2
If    !fstat             : [L]FIN=gdat$([F:ALS]CLES)
Elsif [V]GMOIPAY>[0/0/0] : [L]FIN=eomonth([V]GMOIPAY)
Else                       [L]FIN=eomonth(datesyst)
Endif

End

#-------------------------------------------------------------------------------
Funprog DATDEB

If !clalev([F:ALS]) : Local File ALSTRD [ALS] : Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Read [ALS]ALS0=[V]GUSER;"hrexs";1
#Read [ALS]ALS0=[V]GUSER;"exs";1
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

If    !fstat             : End gdat$([F:ALS]CLES)
Elsif [V]GMOIDAT>[0/0/0] : End [V]GMOIPAY
Else                       End 1+eomonth(addmonth(datesyst,-1))
Endif

#-------------------------------------------------------------------------------
Funprog DATFIN

If !clalev([F:ALS]) : Local File ALSTRD [ALS] : Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Read [ALS]ALS0=[V]GUSER;"hrexs";2
#Read [ALS]ALS0=[V]GUSER;"exs";2
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

If    !fstat             : End gdat$([F:ALS]CLES)
Elsif [V]GMOIDAT>[0/0/0] : End eomonth([V]GMOIPAY)
Else                       End eomonth(datesyst)
Endif

#-------------------------------------------------------------------------------
Subprog SAVDAT(OBJ,DEB,FIN)
Value Char OBJ
Value Date DEB, FIN

If !clalev([F:ALS]) : Local File ALSTRD [ALS] : Endif

Trbegin [ALS]
 Delete [ALS] Where USR=[V]GUSER & OBJ=tolower([L]OBJ)
 If fstat : Rollback : End : Endif

 [F:ALS]USR =[V]GUSER
 [F:ALS]OBJ =tolower([L]OBJ)
 If [L]DEB>[0/0/0]
  [F:ALS]LIG =1
  [F:ALS]CLES=[L]DEB
  Write [ALS]
  If fstat : Rollback : End : Endif
 Endif

 If [L]FIN>[0/0/0]
  [F:ALS]LIG=2
  [F:ALS]CLES=[L]FIN
  Write [ALS]
  If fstat : Rollback : End : Endif
 Endif
Commit

End
#-------------------------------------------------------------------------------
Subprog WRKSIG(EVT,DEM)
Value Char EVT(), DEM()

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If !clalev([F:HREXS]) : Local File HREXPENSES [HREXS] : Endif

Filter [HREXS] Where EXSNUM=val([L]DEM)
Read [HREXS] First
Filter [HREXS]
Lock ="HREXS"+num$([F:HREXS]EXSNUM)+"\"+[F:HREXS]REFNUM+"\"+[F:HREXS]CTRNUM
If fstat
 [V]GOK  =-1
 [V]GLOCK="%HREXS"+[F:ID]REFNUM
 End
Endif

#If !clalev([F:EXS]) : Local File EXPENSES [EXS] : Endif
#
#Filter [EXS] Where EXSNUM=val([L]DEM)
#Read [EXS] First
#Filter [EXS]
#Lock ="EXS"+num$([F:EXS]EXSNUM)+"\"+[F:EXS]REFNUM+"\"+[F:EXS]CTRNUM
#If fstat
# [V]GOK  =-1
# [V]GLOCK="%EXS"+[F:ID]REFNUM
# End
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Case [L]EVT
When "VIS"
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Update [HREXS] Where EXSNUM=val([L]DEM)
&  With STAFLG=[V]GUSER
&      , STADAT=date$
&      , EXSSTA=3
&      , CMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,CMT)

#Update [EXS] Where EXSNUM=val([L]DEM)
#&  With STAFLG=[V]GUSER
#&      , STADAT=date$
#&      , EXSSTA=3
#&      , CMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,CMT)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

When "REF"
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
 Update [HREXS] Where EXSNUM=val([L]DEM)
&   With STAFLG=[V]GUSER
&      , STADAT=date$
&      , EXSSTA=4
&      , CMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,CMT)

# Update [EXS] Where EXSNUM=val([L]DEM)
#&   With STAFLG=[V]GUSER
#&      , STADAT=date$
#&      , EXSSTA=4
#&      , CMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,CMT)
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

When "CMP"
#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [F:HREXS]EXSSTA < 3
  Update [HREXS] Where EXSNUM=val([L]DEM)
&    With STAFLG=[V]GUSER
&       , STADAT=date$
&       , EXSSTA=1
&       , CMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,CMT)
 Endif

#If [F:EXS]EXSSTA < 3
#  Update [EXS] Where EXSNUM=val([L]DEM)
#&    With STAFLG=[V]GUSER
#&       , STADAT=date$
#&       , EXSSTA=1
#&       , CMT = string$(len(GCOMMENTSIG)>0,GCOMMENTSIG)+string$(len(GCOMMENTSIG)=0,CMT)
# Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
 #63859 : Ajout [F:EXS]

When Default
 End
Endcase

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If fstat
 [V]GOK=0
 Call RSTA("HREXS",[L]DEM) From GLOCK
 End
Endif

#If fstat
# [V]GOK=0
# Call RSTA("EXS",[L]DEM) From GLOCK
# End
#Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

#FRLAA- X3-52609 -2017-08-11 - START
#Updating the ESS Header record
If func AFNC.ACTIV("HRESS")>0 Then
  If !clalev([F:EXSH2]) : Local File EXPENSESHEA [F:EXSH2] : Endif

  Filter [EXSH2] Where EXSNUM=val([L]DEM)
  Read [EXSH2] First
  Filter [EXSH2]
  Lock ="EXSH2"+num$([F:EXSH2]EXSNUM)+"\"+[F:EXSH2]REFNUM+"\"+[F:EXSH2]CTRNUM
  If fstat
   [V]GOK  =-1
   [V]GLOCK="%EXSH2"+[F:EXSH2]REFNUM
   End
  Endif

  Case [L]EVT
  When "VIS"
   Update [EXSH2] Where EXSNUM=val([L]DEM)
&  With EXSSTA=3
  When "REF"
   Update [EXSH2] Where EXSNUM=val([L]DEM)
&  With EXSSTA=4
  When Default
   End
  Endcase
  If fstat
   [V]GOK=0
   Call RSTA("EXSH2",[L]DEM) From GLOCK
   End
  Endif
Endif
#FRLAA- X3-52609 -2017-08-11 - END

End

Subprog WRKRER(KRONO,ADEST)
Value Char    KRONO(), ADEST()
#64406 Appellé en fin de workflow demande si 0 signataire trouvé = alimentation CTX(8) avec destinataire routage

 Update [F:AWS2] Where CHRONO = KRONO & DEST = ADEST
&                With  VALCTX8 = DEST

End

