Call CCEMSK("HREXS","HREXS0",nolign-1)


#FRLAA X3-91917 2018-10-03 START
Call GETCTRLEG([M:HREXS0]CTRNUM)
Read [F:HRTES]HRTES0 = GCURLEG;[M:HREXS0]CODEXP(nolign-1)  #V12
If !fstat
  [M:HREXS0]UOMDES(nolign-1) = func AFNC.TEXTRA("ATABDIV","LNGDES","10551",[F:HRTES]UOM)
Endif
#FRLAA X3-91917 2018-10-03 END

