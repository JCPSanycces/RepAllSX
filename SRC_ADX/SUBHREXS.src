####################################################
## Analytical dimension   ## FQ 105501 LUCUE
###################################################
$DIE_TYP

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
If [M:HREXS0]REFNUM="": Return: Endif
#If [M:EXS0]REFNUM="": Return: Endif
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

Local Integer I,J

If !clalev([F:FCY]): Local File FACILITY [FCY]: Endif
If !clalev([F:CPY]): Local File COMPANY [CPY]: Endif
If !clalev([F:AXXX]): Local File =GTABCPT+"ATEXTRA" [AXXX]: Endif
If !clalev([F:CTRX]): Local File EMPLOCTR [CTRX]: Endif

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Filter [CTRX] Where REFNUM=[M:HREXS0]REFNUM  & (CTRDAT<=[M:HREXS0]ENDDAT | (FLGRET=2 & RETDATEFF<=[M:HREXS0]ENDDAT))
&                & (XITDAT=[0/0/0] | XITDAT>=[M:HREXS0]STRDAT)
&     Order By Key CLE=ETRFCY

#Filter [CTRX] Where REFNUM=[M:EXS0]REFNUM  & (CTRDAT<=[M:EXS0]ENDDAT | (FLGRET=2 & RETDATEFF<=[M:EXS0]ENDDAT))
#&                & (XITDAT=[0/0/0] | XITDAT>=[M:EXS0]STRDAT)
#&     Order By Key CLE=ETRFCY
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#Filter [CTRX] Where REFNUM=[M:EXS0]REFNUM
#&     Order By Key CLE=ETRFCY

Raz [F:FCY], [F:CPY]
Raz [M]DIETYP, [M]INTDIE, [M]FMTDIE
For [CTRX]CLE
  If [F:CTRX]ETRFCY<>[F:FCY]FCY
     Call LEC_FCY([F:CTRX]ETRFCY) From CPTLEC
     If [F:FCY]LEGCPY<>[F:CPY]CPY
        Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
        For I=0 To 19
          If [F:CPY]DIE(I)="" or I=dim([F:CPY]DIE): Break: Endif
          For J=0 To 19
            If [F:CPY]DIE(I)=[M]DIETYP(J): Break: Endif
            If [M]DIETYP(J)=""
               [M]DIETYP(J)=[F:CPY]DIE(I)
               Read [F:AXXX]AXX0="GDIE";"SHOTRA";GLANGUE;[M]DIETYP(J)
               If !fstat
                 [M]INTDIE(J)=[F:AXXX]TEXTE
               Endif
               Break
            Endif
           Next J
        Next I
     Endif
   Endif
Next
For I=0 To 19
   If [M]DIETYP(I)=""
     [M]FMTDIE(I) = "-K:10X"
   Else
     #[M]FMTDIE(I) = "K:"+GFMTSEC(I+1)
     [M]FMTDIE(I) = "K:10X"
   Endif
Next

If [M]NBLIG=0
 [M]NBLIG=1

   Affzo [M]CCE1,CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE9
   Affzo [M]CCE10, CCE11, CCE12, CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
   [M]NBLIG=0
   Effzo [M]CCE1,CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, CCE9
   Effzo [M]CCE10, CCE11, CCE12, CCE13, CCE14, CCE15, CCE16, CCE17, CCE18, CCE19, CCE20
#   Affzo [M]NBLIG
Endif
Close File [CTRX]
Return
