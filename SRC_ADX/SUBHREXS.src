$LIENS2
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=[M:EXS0]CTRNUM & CTRDAT<=[M:EXS0]ENDDAT
#&                & (XITDAT=[0/0/0] | XITDAT>=[M:EXS0]STRDAT)
#&     Order By Key CLE=CTRDAT Desc

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Filter [HRCTR] Where REFNUM=[M:HREXS0]REFNUM & CTRNUM=[M:HREXS0]CTRNUM & (CTRDAT<=[M:HREXS0]ENDDAT | (FLGRET=2 & RETDATEFF<=[M:HREXS0]ENDDAT))
&                & (XITDAT=[0/0/0] | XITDAT>=[M:HREXS0]STRDAT)
&     Order By Key CLE=CTRDAT Desc

#Filter [CTR] Where REFNUM=[M:EXS0]REFNUM & CTRNUM=[M:EXS0]CTRNUM & (CTRDAT<=[M:EXS0]ENDDAT | (FLGRET=2 & RETDATEFF<=[M:EXS0]ENDDAT))
#&                & (XITDAT=[0/0/0] | XITDAT>=[M:EXS0]STRDAT)
#&     Order By Key CLE=CTRDAT Desc
#DIRAS - 2017/05/10 - JIRA X3-11253 - END

# Fin MABON

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Read [HRCTR] First
Filter [HRCTR]

#Read [CTR] First
#Filter [CTR]
#DIRAS - 2017/05/10 - JIRA X3-11253 - END
Gosub DIE_TYP ## FQ 105501

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
[M:HREXS0]ETRFCY=[F:HRCTR]ETRFCY
[M:HREXS0]ETRSRV=[F:HRCTR]ETRSRV

Read [FCY]FCY0=[F:HRCTR]ETRFCY

Read [ID]ID0=[F:HREXS]REFNUM
[M:HREXS0]NAMSRN=toupper([F:ID]NAM)-tolower([F:ID]SRN)

Call TOTAUX()
[M:HREXS0]STATUS75=[M:HREXS0]NBLIG

#[M:EXS0]ETRFCY=[F:CTR]ETRFCY
#[M:EXS0]ETRSRV=[F:CTR]ETRSRV
#
#Read [FCY]FCY0=[F:CTR]ETRFCY
#
