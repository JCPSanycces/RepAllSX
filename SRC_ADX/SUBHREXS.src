########################################
Subprog C_NBLIG

Local Integer OK, I, STAT, REPET
Local Char    MES1(250), MES2(250)

[L]STAT=status

#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Case [L]STAT
When 65,68,83
 [L]MES1=mess(1,115,1)+" : " : # Suppression impossible
When 75 : #:-(=)
 #61800
 #If [M:EXS0]STATUS75<[M:EXS0]NBLIG | [M:EXS0]CODEXP(nolign-1)=""
 If [M:HREXS0]STATUS75<[M:HREXS0]NBLIG | ((nolign-1)<dim([M:HREXS0]CODEXP) & [M:HREXS0]CODEXP(nolign-1)="")
  [L]REPET=1
 Else
  [M:HREXS0]STATUS75-=1
 Endif
 [L]MES1=mess(9,123,1)+" : " : # Modification impossible
When 71
 [M:HREXS0]STATUS75+=1
When Default
 End
Endcase

#Case [L]STAT
#When 65,68,83
# [L]MES1=mess(1,115,1)+" : " : # Suppression impossible
#When 75 : #:-(=)
# #61800
# #If [M:EXS0]STATUS75<[M:EXS0]NBLIG | [M:EXS0]CODEXP(nolign-1)=""
# If [M:EXS0]STATUS75<[M:EXS0]NBLIG | ((nolign-1)<dim([M:EXS0]CODEXP) & [M:EXS0]CODEXP(nolign-1)="")
#  [L]REPET=1
# Else
#  [M:EXS0]STATUS75-=1
# Endif
# [L]MES1=mess(9,123,1)+" : " : # Modification impossible
#When 71
# [M:EXS0]STATUS75+=1
#When Default
# End
#Endcase
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


#DIRAS - 2017/05/10 - JIRA X3-11253 - START
Case [L]STAT
When 65,75 : # Annulation/Modification d'une ligne
 #61800
 #If [M:EXS0]STA(nolign-1)>1
 If (nolign-1)<dim([M:HREXS0]STA) & [M:HREXS0]STA(nolign-1)>1
  If ![L]REPET : [V]GMESSAGE=[L]MES1+mess(2,10718,1) : Else : [V]GMESSAGE="" : Endif
  #                                  Ligne déjà comptabilisée
  mkstat=2
 Endif
 If !mkstat
  Call TOTAUX()
  If [L]STAT=65 : [M:HREXS0]STATUS75-=1 : Endif
 Endif

When 68,83 : # Annulation  ou effacement d'un groupe de lignes
 For I=nolign-1 To nolign1-1
  If [M:HREXS0]STA(I)>1
   [V]GMESSAGE=[L]MES1+mess(2,10718,1)-"(" +mess(61,100,1)-num$(I+1)+")"
   #           Ligne déjà comptabilisée (ligne no)
   mkstat     =2
   Break
  Endif
 Next
 If !mkstat
  Call TOTAUX()
  [M:HREXS0]STATUS75-=nolign1-nolign+1
 Endif
When Default
 Call TOTAUX()
 Affzo [HREXS0] 30
Endcase

#Case [L]STAT
#When 65,75 : # Annulation/Modification d'une ligne
# #61800
# #If [M:EXS0]STA(nolign-1)>1
# If (nolign-1)<dim([M:EXS0]STA) & [M:EXS0]STA(nolign-1)>1
#  If ![L]REPET : [V]GMESSAGE=[L]MES1+mess(2,718,1) : Else : [V]GMESSAGE="" : Endif
#  #                                  Ligne déjà comptabilisée
#  mkstat=2
# Endif
# If !mkstat
#  Call TOTAUX()
#  If [L]STAT=65 : [M:EXS0]STATUS75-=1 : Endif
# Endif
#
#When 68,83 : # Annulation  ou effacement d'un groupe de lignes
# For I=nolign-1 To nolign1-1
#  If [M:EXS0]STA(I)>1
#   [V]GMESSAGE=[L]MES1+mess(2,718,1)-"(" +mess(61,100,1)-num$(I+1)+")"
#   #           Ligne déjà comptabilisée (ligne no)
#   mkstat     =2
#   Break
#  Endif
# Next
# If !mkstat
#  Call TOTAUX()
#  [M:EXS0]STATUS75-=nolign1-nolign+1
# Endif
#When Default
# Call TOTAUX()
# Affzo [EXS0] 30
#Endcase
#DIRAS - 2017/05/10 - JIRA X3-11253 - END


If [V]GWEBSERV : Raz mkstat, [V]GMESSAGE : End : Endif

End

