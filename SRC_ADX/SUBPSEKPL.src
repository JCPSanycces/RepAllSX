#<AdxTL>@(#)0.0.0.0 $Revision$

#*********************************************************************
#          Législation  P O L O N A I S E
#*********************************************************************


#=====================================================================
#
$LIENS

  # Mois de la période courante
  Local Date    LCNXDAT(1..5)
  Local Integer PRET
  Call GET_CNX_DAT( [M:PSE0]CPY, G300CPFI, LCNXDAT, PRET ) From GLOBIENS
  Local Integer IMC
  IMC = month(LCNXDAT(3))
  # Premier mois actif dans le plan de saisonnalité
  IMA = find(G_OUI, [M:PSE1]ACTFLGO)

  # La modification du plan de saisonnalité est interdite
  # dès lors qu'il est utilisé par au moins un bien comptable et
  # qu'une période active a déjà été close.
  If ( [M:PSE0]UTILISE = G_OUI and IMA < IMC  ) Then
    Diszo [M:PSE1]1-99
  Else
    # Si la modification du plan est possible,
    # cette modification ne peut porter que sur les périodes non closes.
    Local Integer IM
    For IM = 1 To [M:PSE1]NB_PSE
      If ( IM < IMC ) Then : Diszo [M:PSE1]ACTFLG (IM-1) : Endif
    Next IM
  Endif

Return

#=====================================================================
#
$VERIF_MOD

  G_MODIF = 0
  Local Integer IM
  For IM = 1 To [M:PSE1]NB_PSE
    If ( [M:PSE1]ACTFLG <> [M:PSE1]ACTFLGO ) Then : G_MODIF = 1 : Break : Endif
  Next IM

  If not (G_MODIF) and [M:PSE1]SESTYP <> [M:PSE1]SESTYPO Then
    G_MODIF = 1
  Endif

  #---------------
  # Verrouillage ( avant TRBEGIN du modèle objet)
  #---------------
  If (G_MODIF) Then
    Call PSE_LOCK_FAS ( [M:PSE0]CPY, [M:PSE0]PSEPLN, G_NOLCK) From SUBPSEKPL
  Endif

Return

#=====================================================================
#
$MODIF

  #---------------
  # Mise à jour
  #---------------

  #-1 -------------------
  If (G_MODIF) Then
    #-2 -------------------
    If (G_NOLCK) Then
      GOK = 0
      Errbox mess(693,7773,1)
      Return
    #-2 -------------------
    Else
      If clalev([F:FAS1])=0  : Local File FXDASSETS     [FAS1]  :  Endif
      If clalev([F:DEP1])=0  : Local File DEPREC        [DEP1]  :  Endif

      Local Date    LCNXDAT(1..5)
      Local Integer PRET
      Call GET_CNX_DAT( [M:PSE0]CPY, G300CPFI, LCNXDAT, PRET ) From GLOBIENS

      # 3 >>>>>>>>
      For [FAS1]FAS10 Where KPSEPLN= [M:PSE0]PSEPLN and CPY= [M:PSE0]CPY
        #-4 -------------------
        If ( [F:FAS1]ISSDAT = [0/0/0] ) Then
          # FXDASSETS
          [F:FAS1]FLGCLC                = G_OUI
          [F:FAS1]FLGCNXCLC(G300CPFI-1) = G_OUI
          [F:FAS1]FLGRPRCLC             = G_OUI
          Rewrite [FAS1]
          If (fstat) Then
            GOK = 0
            Call RSTA("FAS","") From GLOCK
            Return #CHECK IGNORE_LINE
          Endif
          # DEPREC
          # 5 >>>>>>>>
          For [DEP1]DEP0 Where AASREF= [F:FAS1]AASREF and CNX= G300CPFI and
&             FIYENDDAT= LCNXDAT(2) and PERENDDAT= LCNXDAT(4)
            If ( val(mid$([F:FAS1]KSESFLG, [F:DEP1]DPRPLN, 1)) = G_OUI ) Then
              [F:DEP1]DEPSTA = GVML_SCNOCAL
              Rewrite [DEP1]
              If (fstat) Then
                GOK = 0
                Call RSTA("DEP","") From GLOCK
                Return #CHECK IGNORE_LINE
              Endif
            Endif
          Next
          # 5 <<<<<<<<
        Endif
        #-4 -------------------
      Next
      # 3 <<<<<<<<

      # Déverrouillage
      Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
    Endif
    #-2 -------------------
  Endif
  #-1 -------------------
Return


#------------------------------------------------------
# S/P permettant de locker les biens
#   utilisant le plan de saisonnalité
#
#   PCPY      Société du plan de saisonnalité
#   PPSEPLN   Référence du plan de saisonnalité
#   RERR
#          -1 paramètre inconsistant
#           0 Tous les biens ont été lockés
#           1 Au moins un bien n'a pas pu être locké
#
#------------------------------------------------------
Subprog PSE_LOCK_FAS ( PCPY, PPSEPLN, RERR)
Value    Char    PCPY
Value    Char    PPSEPLN
Variable Integer RERR

  REER = 0
  If (PCPY =  "" and PPSEPLN =  "" ) Then : RERR = -1 : End : Endif

  If clalev([F:FAS2])=0  : Local File FXDASSETS     [FAS2]  :  Endif

  # Verrouillage
  Local Char LLOCK (200)

  For [FAS2]FAS10 Where KPSEPLN =PPSEPLN and CPY = PCPY
    If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:FAS2]CPY, [F:FAS2]AASREF, 0) = 0 ) Then
      RERR = 1
      Break
    Endif
  Next

  # Si tout n'a pas pu être locké, il faut dévérouiller les biens ayant déjà été lockés
  If ( RERR ) Then
    Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
  Endif

End


######################################################################################
## Ecran PSE0
######################################################################################

#----------------------------------------------
$AM_CPY
    # Le type du plan de saisonnalité est à renseigner pour la législation polonaise
    Chgfmt [M:PSE1]SESTYP With "N+:1#"
Return

#----------------------------------------------
$AV_SESTYP
    # Le type du plan de saisonnalité est à renseigner pour la législation polonaise
    Chgfmt [M:PSE1]SESTYP With "N+:1#"
Return
