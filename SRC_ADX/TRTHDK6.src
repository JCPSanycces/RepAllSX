#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
#   Affectation d'un collaborateur à une demande de service            Module CRM          6 octobre 2000
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
#PARAM(1) = Code de la fonction appelante. (STAT, NBLIGSRE, HDK, HDK2, SRE ou DSC)
#PARAM(2) = Code demande de service.
Global Char GSZSELREP(GLONREP)
Global Integer GREPFOUND
Global Char GSZSRE(GLONVCR)

  If !clalev([F:AFT]) : Local File AFCTFCT [AFT] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif     : # FGR 28/04/2009 : X3SUIVIyyyyy : pour report V5
  If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif       : # FGR 28/04/2009 : X3SUIVIyyyyy : pour report V5
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif  : # FGR 28/04/2009 : X3SUIVIyyyyy : pour report V5
  GSZSELREP = ""
  GREPFOUND = 0
  GSZSRE = PARAM(2)
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNHDK6"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If PARAM(1) = "STAT" Then
    ETABOU(GSPE1) = 0
  Else
    ETABOU(GSPE1) = 1
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Définition du site par défaut.
  [M:HDK6]HDKFCY = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", "")
  Gosub LOADREP
  GSZSELREP = [M:HDK6]HDKREP(0)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GREPFOUND Then
    #Nettoie l'écran avant de partir.
    Raz [M:HDK6]
    If PARAM(1) = "DSC" Then
      #Rafraichit le dispatching
      Gosub RAZDSC1 From TRTDSC1
      Gosub LOADDISP From TRTDSC1
    Elsif PARAM(1) = "HDKAGD1" Then
      Gosub LOAD_SRE From TRTHDKAGD
    Endif
  Endif
  Kill GSZSELREP
  Kill GREPFOUND
  Kill GSZSRE
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSELECT
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
#
# ONSELECT : Traitement du bouton Sélectionner.
# LOADREP  : Chargement du tableau des collaborateurs.
#
#########################################################
##########################################################################################################
# Traitement du bouton Sélectionner
#########################################################
$ONSELECT
  Case PARAM(1) 
    When "SRE"
      VALEUR = GSZSELREP
      mkstat = 4
      Affzo [M:SRE2]SREDET
    When "NBLIGSRE"
      Gosub ASSSRE
    When "DSC"
      Gosub ASSSRE
    When "HDKAGD1"
      # FGR 30/09/2009 : X3SUIVI57393
      Gosub ASSSRE
  Endcase
  FIN = 1
Return

##########################################################################################################
$ASSSRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Affecte la demande de service.à l'utilisateur sélectionné
  Readlock [SRE]SRE0=GSZSRE
  If fstat Then
    GMESSAGE = mess(318,196,1) #L'affectation n'a pu être effectuée. Transaction abandonnée
    GERR = 1
    Return
  Endif
  #Ajoute un historique d'état de la demande
  Call CREHISTO(GSZSRE, [F:SRE]SRESAT, GSZSELREP, 2,IERRINF,ICHAPTER,IBRETOUR)  From SUBSREB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    Return
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [SRE]
  [F:SRE]SREASS = 2
  [F:SRE]SREDATASS = date$
  [F:SRE]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
  [F:SRE]SREDET = GSZSELREP
  Rewrite [SRE]
  If fstat Then
    GMESSAGE = mess(318,196,1) #L'affectation n'a pu être effectuée. Transaction abandonnée
    GERR = 1
    Rollback
    Return
  Else
    Commit
  Endif
Return

##########################################################################################################
$LOADREP
Local Integer IFCYFLG
Local Integer I
Local Integer IREP
Local Integer IALDONE
Local Char SZHDKREP
Local Integer IHDKREP

  SZHDKREP = ""
  IHDKREP = 0
  I = 0
  IREP = 0
  IALDONE = 0
  IFCYFLG = 0
  Call TEMPON("R") From GESECRAN
  If [M:HDK6]HDKFCY = "" Then
    IALDONE = 1
  Endif
  Filter [AUS] Where [F:AUS]ENAFLG = 2
  For [AUS]
    If  I >= dim([M:HDK6]HDKREP)-1 Then
      Break
    Endif
    Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS]USR, "") From SUBAUS
    If SZHDKREP = "" Then
      IHDKREP = 1
    Else
      IHDKREP = val(SZHDKREP)
    Endif
    If IHDKREP = 2 Then
      IFCYFLG = 0
      If [M:HDK6]HDKFCY = "" Then
        IFCYFLG = 1
      Else
        Read [AFT]AFT0=[F:AUS]PRFFCT
        If !fstat Then
          If [F:AFT]FCYDEF(11) = [M:HDK6]HDKFCY Then
            IFCYFLG = 1
          Endif
        Endif
      Endif
      If IFCYFLG Then
        Filter [SRE] Where [F:SRE]SREASS = 2 and [F:SRE]SREDET = [F:AUS]USR
        IREP = 0
        For [SRE]
          IREP += 1
        Next
        [M:HDK6]HDKREP(I) = [F:AUS]USR
        [M:HDK6]NBRSRE(I) = IREP 
        Filter [SRE]
        I += 1
      Endif
    Endif
  Next
  Filter [AUS]
  If I = 0 and IALDONE = 0 Then
    I = 0
    Filter [AUS] Where [F:AUS]ENAFLG = 2
    For [AUS]
      If  I >= dim([M:HDK6]HDKREP)-1 Then
        Break
      Endif
      Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS]USR, "") From SUBAUS
      If SZHDKREP = "" Then
        IHDKREP = 1
      Else
        IHDKREP = val(SZHDKREP)
      Endif
      If IHDKREP = 2 Then
        Filter [SRE] Where [F:SRE]SREASS = 2 and [F:SRE]SREDET = [F:AUS]USR
        IREP = 0
        For [SRE]
          IREP += 1
        Next
        [M:HDK6]HDKREP(I) = [F:AUS]USR
        [M:HDK6]NBRSRE(I) = IREP 
        Filter [SRE]
        I += 1
      Endif
    Next
    Filter [AUS]
    [M:HDK6]HDKFCY = ""
  Endif
  If I = 0 Then
    GMESSAGE = mess(319,196,1)  #Aucun collaborateur Help-Desk n'est déclaré dans l'application.
    GERR = 2
    FIN = 1
    Call TEMPOFF From GESECRAN
    Return
  Endif
  GREPFOUND = 1
  [M:HDK6]NBREP = I
  Call TEMPOFF From GESECRAN
  Affzo [M:HDK6]1-99
Return
