#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UUMGTRTPUR10   migration des conteneurs : CONTAINER et CONTAINERD      Module PUR  #
#            Mise à jour poids et volume                                             #
######################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR10") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR10(DOSSIER)
  Call MAJ_UUMGTRTPUR10(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR10(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################
If [F:ADS]MODULE(5)<>2 : End : Endif          : # N= no module

Local Char WNAMCTRHM,WNAMCTRDM
Call MIGTABNAME (DOSSIER,"CONTAINER",WNAMCTRHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"CONTAINERD",WNAMCTRDM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMCTRHM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif
If filinfo(filpath("FIL",WNAMCTRDM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

##2 - On vide les fichiers selon le cas
#######################################

Call MIGTABRAZ (DOSSIER,"CONTAINER",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"CONTAINERD",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR10",ERR) From TRTMIG

End

##########################################################################
##########################################################################
##########################################################################
Subprog MAJ_UUMGTRTPUR10(DOSSIER)
Value Char DOSSIER

Local Integer ERR

Gosub MIG_OUVRE From TRTMIG

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR10",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMCTRHM,WNAMCTRDM
Call MIGTABNAME (DOSSIER,"CONTAINER",WNAMCTRHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"CONTAINERD",WNAMCTRDM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR10",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMCTRHM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR10",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

If filinfo(filpath("FIL",WNAMCTRDM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR10",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR10",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version

Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR10",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

###################


Local Char WTAB_CTRH (100) (adxwrb)

Local Char WTAB_CTRD (100) (adxwrb)
Local Shortint WCPT_CTRH,WCPT_CTRD

Call ECR_TIME("UUMGTRTPUR10 tables CTRH Process : Update CTRH") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR10 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"CONTAINER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"CONTAINERD",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:CTRH])  = 0 : Local File =DOSSIER+".CONTAINER"    [CTRH]  : Endif   # Fichier X3 "Vide"
If clalev([F:CTRD])  = 0 : Local File =DOSSIER+".CONTAINERD"    [CTRD]  : Endif   # Fichier X3 "Vide"

If clalev([F:CTRHM]) = 0 : Local File =DOSSIER+"."+WNAMCTRHM   [CTRHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:CTRDM]) = 0 : Local File =DOSSIER+"."+WNAMCTRDM   [CTRDM] : Endif   # Fichier X3 renommé Avant Migration

#Local File =[F:ADS]DOSSIER+".CONTAINER"    [CTRH]
Local File =[F:ADS]DOSSIER+".TABCONTAINER"    [TCTR]

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE,NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR10",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [CTRDM] With [CTRHM]CTRH0~=[F:CTRDM]CTRNUM
&    As [LNK]
&    Order By Key CLE = [F:CTRHM]CTRNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR10" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CTRH00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:CTRHM]CTRNUM=TABMIGKEY(1) "
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:CTRHM]CTRNUM=TABMIGKEY(1) "
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:CTRHM]CTRNUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [CTRH],[CTRD]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR10" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  #Raz [F:XXX]
   # version < V11, raz des champs v11
  If val(VERSION)<GMIGX3VER110
      Gosub RAZV11_CTRH
  Endif

  [F:CTRH] = [F:CTRHM]

  #Appel proc de migration sur entete
  # Passage en V11
  If val(VERSION)<GMIGX3VER110
    Gosub MAJV11_CTRH
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne
    # version < V11, raz des champs v11
    If val(VERSION)<GMIGX3VER110
        Gosub RAZV11_CTRD
    Endif

    [F:CTRD] = [F:CTRDM]

    #Appel proc de migration sur detail
    # Passage en V11
    If val(VERSION)<GMIGX3VER110
      Gosub MAJV11_CTRD
      If GOK<1 : Break : Endif
    Endif

    # --- écriture enreg
    Gosub CTRD_STK : # pour stocker ref
    WriteB [CTRD]
    If fstat
        Call ECR_TRACE("File CONTAINERD, Error ="-num$(fstat),1) From GESECRAN
        Gosub CTRD_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
  Next

  If GOK<1 : Break : Endif

  #Appel proc de migration sur entete arpès boucle sur les détails
  # Passage en V11
  If val(VERSION)<GMIGX3VER110
    Gosub MAJV11_CTRH_SUITE
    If GOK<1 : Break : Endif
  Endif


  # --- écriture enreg
  Gosub CTRH_STK : # pour stocker ref
  WriteB [F:CTRH]
  If fstat
    Call ECR_TRACE("File CONTAINER, Error ="-num$(fstat),1) From GESECRAN
    Gosub CTRH_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:CTRHM]CTRNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR10",7,ERR) From TRTMIG : #7=Erreur
Else
   Flush [F:CTRH]
   If fstat
      Call ECR_TRACE("File CONTAINER, Error ="-num$(fstat),1) From GESECRAN
      Gosub CTRH_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  Endif
  Flush [F:CTRD]
  If fstat
      Call ECR_TRACE("File CONTAINERD, Error ="-num$(fstat),1) From GESECRAN
      Gosub CTRD_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR10",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR10",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_CTRH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [CTRH], [CTRD]
Close Local File [CTRHM], [CTRDM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"CONTAINER",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"CONTAINERD",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTPUR10") From TRTMIG
Call ECR_TIME("UUMGTRTPUR10 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$CTRH_STK
Call STK (WTAB_CTRH,WCPT_CTRH,[F:CTRH]CTRNUM) From TRTMIG
Return
$CTRD_STK
Call STK (WTAB_CTRD,WCPT_CTRD,[F:CTRD]CTRNUM-'/'-num$([F:CTRD]CTRLIN)) From TRTMIG
Return
##############################################################################################
$CTRH_ERRTRA
Call ERRTRA (WTAB_CTRH,WCPT_CTRH,"File CONTAINER(CTRNUM)=") From TRTMIG
Return
$CTRD_ERRTRA
Call ERRTRA (WTAB_CTRD,WCPT_CTRD,"File CONTAINERD(CTRNUM/CTRLIN)=") From TRTMIG
Return

########################################################################
# Migration entete                                                     #
########################################################################
$RAZV11_CTRH
Raz [F:CTRH]CRRWEI
Raz [F:CTRH]AVAWEI
Raz [F:CTRH]AVAVOL
Return

$MAJV11_CTRH
#mise à jour du poids total (lignes + tare)
Read [TCTR]TCTR0 = [F:CTRH]TCTRNUM
If fstat : Raz [F:TCTR] : Endif

[F:CTRH]CRRWEI = [F:CTRH]TOTLINWEU + [F:TCTR]TARWEI
[F:CTRH]AVAWEI = [F:TCTR]MAXWEI - [F:CTRH]TOTLINWEU
If [F:CTRH]AVAWEI <0 : [F:CTRH]AVAWEI = 0 : Endif
[F:CTRH]AVAVOL = [F:TCTR]USFVOL - [F:CTRH]TOTLINVOU
If [F:CTRH]AVAVOL <0 : [F:CTRH]AVAVOL = 0 : Endif

Return

$MAJV11_CTRH_SUITE

Return
# Migration détail                                                     #
########################################################################
########################################################################

$RAZV11_CTRD
Return

$MAJV11_CTRD
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
#on charge [F:ADS]
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR10(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
#on sait qu'on a déjà [F:ADS]
Call MAJ_UUMGTRTPUR10(APPLI)
End

