#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------#
# Contains global variables (Origin X3 V6)
#----------------------------------------------#

Subprog DEFVAR

Local Integer ER

#--------------------------------------------------#
Onerrgo ER
Global Char GVERSOL(20)
GVERSOL = func GLOBVAR.VERSOL : # mb 13.12.12
Onerrgo
If ER
 GVERSOL = "20v.001"
Endif
#--------------------------------------------------#

If dim(GTEST)<0 : Global Integer GTEST : GTEST=0 : Endif # For tests

Global Integer  GTRASYR             : # Génération des traces dans /tmp/syracuse_adxusr.tra
Case tolower(adxusr)
 When "mbeinat" : GTRASYR = 1
 When "ccl" : GTRASYR = 1
 When "eboyard" : GTRASYR = 1
 When "rbu" : GTRASYR = 1
 When Default   : GTRASYR = 0
Endcase

Global Char     GTRACE(250)         : # Fichier de trace
Global Char     GTRACEASYR(250)     : # AKA X3-103331.n Define a new global variable for "Syracuse" trace file used in "D" mode

Case tolower(adxusr)
 When "rbu" : GTRACE = "FTESTRBU.tra"
Endcase
Global Char     GLANDEF(10)         : # Langue par défaut

Global Char     GADOVERS(1)         : # No version adonix entête des sources
GADOVERS = "L"

Global Integer  GDIMFIC        : [V]GDIMFIC = 250

Global Integer  GNEWTXTSTD          : # Limite des numéros de textes standard #115210/6
GNEWTXTSTD = 1000000

Global Integer  GMAXTXTSTD          : # Limite des numéros de textes standard
GMAXTXTSTD = 100000

Global Integer  GMAXTXTSPE          : # Limite des numéros de textes spécifiques
GMAXTXTSPE = 200000

Global Libelle  GASCII              : # Pour écrire en Ascii
Global Libelle  GUCS2               : # Pour écrire sur 2 octets
Global Libelle  GUTF8               : # Pour écrire en UTF8 (défaut)
GASCII = 50  : # Pour écrire en Ascii
GUCS2  = 122 : # Pour écrire sur 2 octets
GUTF8  = 0   : # Pour écrire en UTF8 (défaut)

Global Decimal GTIMESTAMP

#TODO: transformer en variable contexte
Global Char     GUSER(GLONAUS)      : # Code utilisateur

#TODO: transformer en variable contexte
Global Char     GPROFIL(5)          : # Code profil fonction

#TODO: supprimer
Global Char     GMENDEP(10)         : # Menu de départ
#TODO: transformer en variable contexte
Global Date     GDATDEB             : # Date début
#TODO: transformer en variable contexte
Global Date     GDATFIN             : # Date de fin

#TODO: transformer en variable contexte
Global Decimal  GNBSEL              : # Nb d'élément pour sélections

Global Integer  GPRODUIT            : # Type de produit
If dim(GSERVEUR)<=0 : Global Integer GSERVEUR : Endif
If dim(GSILENCE)<=0 : Global Integer GSILENCE : Endif
If dim(GWEBSERV)<=0 : Global Integer GWEBSERV : Endif

Local Char PARAM(10)
Call PARAM("","TYPDOS",PARAM) From ADOVAL
GPRODUIT = val(PARAM)-1

Global Integer GTYPDBA
Call PARAM("","TYPDBA",PARAM) From ADOVAL
GTYPDBA = val(PARAM)

Global Integer GADONIX
Call PARAM("","ADONIX",PARAM) From ADOVAL
GADONIX = val(PARAM)

#109897
# Nombre de rollback
Global Integer GROLLBACK
Call PARAM("","ROLLBACK",PARAM) From ADOVAL
GROLLBACK = val(PARAM)

# Présence du fichier sophia_gaillard
Global Integer GSOPHIA
GSOPHIA = (filinfo(filpath("","sophia_gaillard","",nomap),0)>0)

# For tests
Global Integer GIMPORT
GIMPORT = 0 : #116971 instead of 1

#NOM                  indice      VALEUR
#                     DANS        (EXEMPLE)
#                     adxfmt
#shortDateFormat      0           D :DD[/]MM[/]YY
#longDateFormat       1           D :DD[/]MM[/]YYYY
#shortTimeFormat      2           D :HH[ :]MM
#longTimeFormat       3           D :HH[ :]MM[ :]SS
#shortDatetimeFormat  4           D:DD[/]MM[/]YY[ ]HH[:]MM
#longDatetimeFormat   5           D:DD MMM YYYY[, ]HH[:]MM[:]SS
#decimalSep           6           .
#thousandsSep         7           ,

#109897
If find(adxtyp,34,35)=0
#TODO: transformer en variable contexte
 Global Char     GFMDAT(20)          : # Format date complète
 GFMDAT  = adxfmt(0)
 Global Char     GFMDAT4(20)         : # Format date complète
 GFMDAT4 = adxfmt(1)
Endif
Gosub SETBATCHDIRECTORY From GLOBVAR: #109897

Local Char    PARAM(250)
Local Integer I , J , K , L
Local File    ADOVAL [ADW] , ADOPAR [ADP]

# Date de base
Call PARAM("","DCS",PARAM) From ADOVAL
[S]adxdcs = val(PARAM)

# Temps de verrou
Call PARAM("","TIMLCK",PARAM) From ADOVAL
[S]lockwait = val(PARAM)

## Paramètres adonix
For I=1 To 30
 Call PARAM("","TUL"+format$("N0:##",I),PARAM) From ADOVAL
 If PARAM<>""
  adxtul(I-1) = left$(PARAM,1)
  J = instr(1,PARAM,":")
  If J
   adxtut(I-1) = seg$(PARAM,2,J-1)
   adxtuc(I-1) = right$(PARAM,J+1)
  Endif
 Endif
Next I

# Nb errors for syracuse errors
Global Integer GNBERROSYR

actihgup(0) = "TIMOUT_SYRA" : # Traitement de déconnexion sur time out
actihgup(1) = "FIN_SYRA"    : # Traitement de déconnexion volontaire
actihgup(2) = "FINERR_SYRA"    : # Traitement des erreurs involontaires

Close Local File [ADW] , [ADP]
End

#------------#
$ER
ER = errn
Resume

