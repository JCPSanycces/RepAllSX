###########################################################################
# Test de la saisie du code paramètre DEFHDTITM
#
# Module CRM                                                25 Juillet 2003
############################################################################
Subprog VERF_PARAM(PARAM, TSTVALEUR, OK)
Value Char PARAM
Value Char TSTVALEUR
Variable Integer OK

  If PARAM <> "DEFHDTITM" Then
    #Erreur dans le code paramètre
    GMESSAGE = mess(204,196,1)
    GERR = 1
    OK = 0
    End
  Endif
  If TSTVALEUR = "" Then
    End
  Endif
  #
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  Read [ITM]ITM0=TSTVALEUR
  If fstat Then
    #La valeur saisie pour ce paramètre ne correspond à un code article.
    GMESSAGE = mess(338,182,1)
    GERR = 1
    OK = 0
    End
  Endif
  If [F:ITM]HDKITMTYP <> 3 Then
    #L'article indiqué ne correspond pas à de la main d'oeuvre. Saisie refusée.
    GMESSAGE = mess(339,182,1)
    GERR = 3
    OK = 0
    End
  Endif
  OK = 1
End
