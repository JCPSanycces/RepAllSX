#<AdxTL>@(#)0.0.0.0 $Revision$ Object management POPSCV
######################################################################################
## Section automatically added (Object POPSCV) 06/09/2017 13:22:02 (STWIL)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "AVANT_ACT"    : Gosub AVANTACT
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "INIMOD"       : Gosub INIMOD
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "AV_ANNULE"    : Gosub AV_ANNULE
 When "ANNULE"       : Gosub ANNULE
 When "FERME"        : Gosub FERME
 When Default
Endcase
Return

$OUVRE
    If clalev([F:PSCV]) <= 0 : Local File POPSCUSVALS     [PSCV] : Endif
    ANOWRITE = 1

    Local Integer AUPDTICK
    Local Integer CVOK
    Local Char CHKFCY(GLONFCY)
    Global Instance GPOPSCUSVALS Using C_POPSCUSVALS

    Local Instance POPSCUSFLDS Using C_POPSCUSFLDS
    POPSCUSFLDS = NewInstance C_POPSCUSFLDS AllocGroup null

    [L]CVOK = fmet POPSCUSFLDS.INITIALIZE()
Return

$SETBOUT
    #--- No duplication
    Call VIREBOUT (CHAINE,"D")    From GOBJET

Return

$LIENS
    If GPOPSCUSVALS <> null
        FreeGroup GPOPSCUSVALS
    Endif
    GPOPSCUSVALS = NewInstance C_POPSCUSVALS AllocGroup null
    Local Integer MY_STATUS
    [L]MY_STATUS = fmet GPOPSCUSVALS.AREAD([M:PSCV]FCY)
    If ([L]MY_STATUS >= [V]CST_AERROR)
      # Error management
      Call GET_ERRORS(GPOPSCUSVALS)
      Return
    Endif

    [M:PSCV]DEFFLG = GPOPSCUSVALS.DEFFLG
    [M:PSCV]WOCUSFLD1 = GPOPSCUSVALS.WOCUSFLDS(1).WOCUSFLD
    [M:PSCV]WOCUSFLD2 = GPOPSCUSVALS.WOCUSFLDS(2).WOCUSFLD
    [M:PSCV]OPCUSFLD1 = GPOPSCUSVALS.OPCUSFLDS(1).OPCUSFLD
    [M:PSCV]OPCUSFLD2 = GPOPSCUSVALS.OPCUSFLDS(2).OPCUSFLD
    [L]AUPDTICK = GPOPSCUSVALS.updTick
Return

$RAZCRE
    If GPOPSCUSVALS <> null
        FreeGroup GPOPSCUSVALS
    Endif
    GPOPSCUSVALS = NewInstance C_POPSCUSVALS AllocGroup null
    Local Integer MY_STATUS
    [L]MY_STATUS = fmet GPOPSCUSVALS.AINIT()
    If ([L]MY_STATUS >= [V]CST_AERROR)
      # Error management
      Call GET_ERRORS(GPOPSCUSVALS)
      Return
    Endif

    If GPOPSCUSVALS.FCY = ""
        [M:PSCV]DEFFLG = GPOPSCUSVALS.DEFFLG
    Else
        SetInstance [F:PSCV] With GPOPSCUSVALS
        [M:PSCV] = [F:PSCV]
    Endif

    Affzo [M:PSCV]1-99
Return

$CREATION
    GPOPSCUSVALS.FCY = [M:PSCV]FCY
    GPOPSCUSVALS.DEFFLG = [M:PSCV]DEFFLG
    GPOPSCUSVALS.WOCUSFLDS(1).WOCUSFLD = [M:PSCV]WOCUSFLD1
    GPOPSCUSVALS.WOCUSFLDS(2).WOCUSFLD = [M:PSCV]WOCUSFLD2
    GPOPSCUSVALS.OPCUSFLDS(1).OPCUSFLD = [M:PSCV]OPCUSFLD1
    GPOPSCUSVALS.OPCUSFLDS(2).OPCUSFLD = [M:PSCV]OPCUSFLD2

    [L]CVOK = 0
    Gosub CHECKDEFAULTSITE
    If [L]CVOK = 1
        Return
    Endif

    Local Integer MY_STATUS
    [L]MY_STATUS = fmet GPOPSCUSVALS.AINSERT()
    If ([L]MY_STATUS >= [V]CST_AERROR)
      # Error management
      Call GET_ERRORS(GPOPSCUSVALS)
      Return
    Endif

    If [L]CVOK = 2
        [L]MY_STATUS = fmet GPOPSCUSVALS.REMOVEDEFAULTSITE([L]CHKFCY)
        If ([L]MY_STATUS >= [V]CST_AERROR)
          # Error management
          Call GET_ERRORS(GPOPSCUSVALS)
          Return
        Endif
    Endif

    SetInstance [F:PSCV] With GPOPSCUSVALS
    [L]CVOK = 2
Return

$APRES_CRE
    # Only update object if we have written something
    If [L]CVOK = 2
        Gosub RELIT From GOBJSUB
    Endif
Return

$INIMOD
Return

$MODIF
    GPOPSCUSVALS.FCY = [M:PSCV]FCY
    GPOPSCUSVALS.DEFFLG = [M:PSCV]DEFFLG
    GPOPSCUSVALS.WOCUSFLDS(1).WOCUSFLD = [M:PSCV]WOCUSFLD1
    GPOPSCUSVALS.WOCUSFLDS(2).WOCUSFLD = [M:PSCV]WOCUSFLD2
    GPOPSCUSVALS.OPCUSFLDS(1).OPCUSFLD = [M:PSCV]OPCUSFLD1
    GPOPSCUSVALS.OPCUSFLDS(2).OPCUSFLD = [M:PSCV]OPCUSFLD2

    [L]CVOK = 0
    Gosub CHECKDEFAULTSITE
    If [L]CVOK = 1
        Return
    Endif

    Local Integer MY_STATUS
    [L]MY_STATUS = fmet GPOPSCUSVALS.AUPDATE()
    If ([L]MY_STATUS >= [V]CST_AERROR)
      # Error management
      Call GET_ERRORS(GPOPSCUSVALS)
      Return
    Endif

    If [L]CVOK = 2
        [L]MY_STATUS = fmet GPOPSCUSVALS.REMOVEDEFAULTSITE([L]CHKFCY)
        If ([L]MY_STATUS >= [V]CST_AERROR)
          # Error management
          Call GET_ERRORS(GPOPSCUSVALS)
          Return
        Endif
    Endif

    [L]CVOK = 2
Return

$APRES_MOD
    # Only update object if we have written something
    If [L]CVOK = 2
        Gosub RELIT From GOBJSUB
    Endif
Return

$AV_ANNULE
    Local Integer ANOWRITE
    [L]ANOWRITE = 1
Return

$ANNULE
    Local Integer MY_STATUS
    Local Integer CVOK
    Local Char CHKFCY(GLONFCY)

    If [M:PSCV]DEFFLG = 2
        # There is no other record with the default flag set
        GMESSAGE = mess(392,193,1)
        GOK=0 : GERR=1
        Return
    Endif

    [L]MY_STATUS = fmet GPOPSCUSVALS.ADELETE()
    If ([L]MY_STATUS >= [V]CST_AERROR)
      # Error management
      Call GET_ERRORS(GPOPSCUSVALS)
      Return
    Endif

Return

$FERME
    If GPOPSCUSVALS <> null
        FreeGroup GPOPSCUSVALS
    Endif
    Kill GPOPSCUSVALS
Return

$CHECKDEFAULTSITE
    Local Instance POPSCV Using C_POPSCUSVALS
    POPSCV = NewInstance C_POPSCUSVALS AllocGroup null
    Local Char WTEXTE(50)

    [L]CHKFCY = fmet POPSCV.FINDDEFAULTSITE()
    If [M:PSCV]DEFFLG = 1
        # The default flag is no, check there is a record with the default flag set
        If [L]CHKFCY = "" | [L]CHKFCY = [M:PSCV]FCY
            # There is no other record with the default flag set
            GMESSAGE = mess(392,193,1)
            GOK=0 : GERR=1
            [L]CVOK = 1
        Endif
    Endif
    If [M:PSCV]DEFFLG = 2
        If [L]CHKFCY <> "" & [L]CHKFCY <> [M:PSCV]FCY
            Call OUINON (mess(393,193,1), [L]CVOK) From GESECRAN
            If [L]CVOK = 1
                GOK=0 : GERR=1
            Endif
        Endif
    Endif

    FreeGroup POPSCV
Return

# Before a button is pressed (Save, Create)
$AVANTACT
# If this record has been modified by removing the default flag in another process, display an error message to avoid the record of modifications
If BOUT="E" & dim([L]AUPDTICK)>0 & dim([F]updTick)>0
    Filter [PSCV] Where FCY=[M:PSCV]FCY & [F:PSCV]updTick=[L]AUPDTICK
    Look [F:PSCV] First
    Filter [PSCV]
    If fstat
        # This custom values record has been modified simulateneously. Please cancel and redo your modifications.
        Call ERREUR(mess(394,193,1)) From GESECRAN
        OK=0
    Endif
Endif
Return

######################################################################################
#------------------------------------#
#--- Get the errors                  #
#------------------------------------#
Subprog GET_ERRORS(WPOPSCUSVALS)
Variable Instance WPOPSCUSVALS Using C_POPSCUSVALS

 GMESSAGE = func LCCLIB.MAXMSG(WPOPSCUSVALS)
 GOK=0 : GERR=1

End

