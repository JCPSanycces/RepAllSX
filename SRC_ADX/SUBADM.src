#<AdxTL>@(#)11.0.0.0 $Revision$
Call OBJET("ADM",GBIDC1,GBIDC2) From GOBJET
End

#################################################################################
$ACTION
Case ACTION
 When "SETBOUT"   : Gosub SETBOUT
 When "FERME"     : Gosub FERME
 When "LIENS"     : Gosub LIENS
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "INICRE"    : Gosub INICRE
Endcase
Return

$SETBOUT
Lock [ADM]
If fstat
 Grizo
Endif
Return

$FERME
Unlock [ADM]
Return

$LIENS
Call TEXTE([M]DES(nolign-1),[M]ZDES(nolign-1)) From OBJDIV
Return

$VERIF_MOD
Local Char BID(80)
For I=0 To [M]NBLIG-1
 Read [ADM]ADM0 = [M]COD(I)
 If fstat
  [M]MODIF(I) = 2
 Elsif [F:ADM]COD<>[M]COD(I) | [F:ADM]MODULE<>[M]MODULE(I) | [F:ADM]RANG<>[M]RANG(I)
  [M]MODIF(I) = 1
 Else
  Call TEXTE([F:ADM]DES,BID) From OBJDIV
  If BID<>[M]ZDES(I)
   [M]MODIF(I) = 1
  Else
   [M]MODIF(I) = 0
  Endif
 Endif
Next I
Return

$INICRE
Case [M]MODULE(nolign-1)
 When 1       : [F:ADM]ORDRE = 0
 When 9       : [F:ADM]ORDRE = 1000
 When 2       : [F:ADM]ORDRE = 2000
 When 3       : [F:ADM]ORDRE = 3000
 When 4       : [F:ADM]ORDRE = 4000
 When 7       : [F:ADM]ORDRE = 5000
 When 5       : [F:ADM]ORDRE = 6000
 When 6       : [F:ADM]ORDRE = 7000
 When 8       : [F:ADM]ORDRE = 8000
 When 10      : [F:ADM]ORDRE = 9000
 When Default : [F:ADM]ORDRE = 10000
Endcase
[F:ADM]ORDRE += [M]RANG(nolign-1)
Case [M]MODIF(nolign-1)
 When 0 : # Rien
  If dim([F:ADM]CREUSR)>0 & dim([M]CREUSR)>0 : [F:ADM]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:ADM]CREDAT)>0 & dim([M]CREDAT)>0 : [F:ADM]CREDAT = [M]CREDAT(nolign-1) : Endif
 When 1 : # Modification
  If dim([F:ADM]CREUSR)>0 & dim([M]CREUSR)>0 : [F:ADM]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:ADM]CREDAT)>0 & dim([M]CREDAT)>0 : [F:ADM]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:ADM]UPDUSR)>0 : [F:ADM]UPDUSR = GUSER   : Endif
  If dim([F:ADM]UPDDAT)>0 : [F:ADM]UPDDAT = date$   : Endif
 When 2 : # Création
  If dim([F:ADM]CREUSR)>0 : [F:ADM]CREUSR = GUSER   : Endif
  If dim([F:ADM]CREDAT)>0 : [F:ADM]CREDAT = date$   : Endif
  If dim([F:ADM]UPDUSR)>0 : [F:ADM]UPDUSR = ""      : Endif
  If dim([F:ADM]UPDDAT)>0 : [F:ADM]UPDDAT = [0/0/0] : Endif
Endcase
Return

########################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]COD(0..[M]NBLIG-1)) From OBJDIV
End

