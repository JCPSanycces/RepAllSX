If IOPENPPR=1 : Close Local File [PPR] : Raz IOPENPPR : Endif
Return

#########################################################################
#    Action SELREN : sélection des motifs de tarif                      #
#########################################################################
$S_REN

Local Integer MODULE  : MODULE=val(PARAM(1))

#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6 OK=0 : Return : Endif
#----- Sélection motifs manuels -----#

OPTIONS="A"
If MODULE=5
    OBJET="SPR"
Elsif MODULE=6
    OBJET="PPR"
Endif

Return

#########################################################################
#    Action SELSTCCPY : sélection sociétés de meme structure tarifs     #
#########################################################################
$S_STCCPY
If clalev([F:ATZ])=0 : Local File ATABZON : Endif
Local Char CODFIC    : CODFIC = "COMPANY"

Default File [CPY]
CRITERE = 'CPYLEGFLG=2 & PLISTC=[M]PLISTC'
START   = 'CPY'
TIT(0) = mess(12,123,1)
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "CPY"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "CPYNAM" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "PLISTC" : Gosub TEXTE
Return

#########################################################################

$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return


#########################################################################
#    Action SELLPFIL : sélection des fichiers pour critères tarifs      #
#########################################################################
$SL_PFIL
Local Integer IJL
Local Integer IATB, IATX
If clalev ([F:ATB])<=0 : IATB=1 : Local File ATABLE [ATB] : Endif
If clalev ([F:ATX])<=0 : IATX=1 : Local File ATEXTE [ATX] : Endif
Raz NBTEX
TIT=mess(10,141,1)
For IJL=0 To dim(JGFICFIC)-1
  If JGFICFIC(IJL)<>""
    NBTEX +=1
    Read [F:ATB]CODFIC=JGFICFIC(IJL)
    Read [F:ATX]NUMERO=GLANGUE;[F:ATB]INTITFIC

    TEX(NBTEX)=JGFICFIC(IJL)
    TEXTE(NBTEX)=format$("K:15X",JGFICFIC(IJL))+[F:ATX]TEXTE
  Endif
Next IJL

If IATB=1 : Close Local File [ATB] : Endif
If IATX=1 : Close Local File [ATX] : Endif

Return


#########################################################################
#                                                                       #
#      TRAITEMENTS LIES aux PRIX ACHAT/VENTE                            #
#                                                                       #
#########################################################################
#-----------------------------------------------------------------------#
# Traitements non e_commerce                                            #
#-----------------------------------------------------------------------#
#########################################################################
# Subprog COLREM (TAILLE,PARTNER,STRUCTURE)                             #
# garni les variables GCOLREM (x) pour les colonnes rem/frais des tarifs#
# garni le code format "%" ou "M" dans GFMTREM (0..8)                   #
# garni le format des colonnes rem/frais dans GFMTCOL (0..8)            #
#-----------------------------------------------------------------------#
# DEFINIR dans masque lib. évalués GCOLREM(0..8) format GFMTREM(0..8)   #
# APPELER dans action OUVRE avant affichage du masque                   #
#-----------------------------------------------------------------------#
#  TAILLE    = C (libellé 12) / L (libellé 20)                          #
#  PARTNER   = 1 (client) / 2 (fournisseur)                             #
#  STRUCTURE = Code structure de PRICSTRUCT                             #
#########################################################################
Subprog COLREM (TAILLE,PARTNER,STRUCTURE)
Value    Char    TAILLE
Value    Integer PARTNER
Value    Char    STRUCTURE
#----- Vérification de la validité des paramètres -----#
If TAILLE<>"C" & TAILLE<>"L"  End : Endif
If PARTNER<>1  & PARTNER<>2   End : Endif
#----- Lecture de la structure tarif -----#
If !clalev([F:PRS])  Local File PRICSTRUCT [PRS] : Endif
# Issue 74556 - 2011-07-04 by VPO : lecture ssi besoin
If [F:PRS]BPCBPS<>PARTNER | [F:PRS]PLISTC<>STRUCTURE
  Read [PRS] PRS0=PARTNER;STRUCTURE
  If fstat  End : Endif
Endif
#-----
Local    Integer I
Local    Integer NBMAX
#----- Récupération valeur du code activité pour nbre de colonnes tarif -----#
If PARTNER=1
  NBMAX=func AFNC.ACTIV("SPR")
Else
  NBMAX=func AFNC.ACTIV("PPR")
Endif
#-----
Raz GCOLREM, GFMTREM, GFMTCOL
#-----
For I=0 To NBMAX-1
  If [F:PRS]INCDCR(I)<>0
    If TAILLE="L"
      #--CPO 87751 Il faut les lire dans tous les cas (sinon impossible d'importer des remises/frais)
      #-- 80866 Performance Import --#
      #If !GIMPORT : Call GET_ATEXTRA ("PRICSTRUCT","DESAXX("+num$(I)+")",GLANGUE,GCOLREM(I)) From TRTX3TEX : Endif
      Call GET_ATEXTRA ("PRICSTRUCT","DESAXX("+num$(I)+")",GLANGUE,GCOLREM(I)) From TRTX3TEX
      #--/
    Else
      #--CPO 87751 Il faut les lire dans tous les cas (sinon impossible d'importer des remises/frais)
      #-- 80866 Performance Import --#
      #If !GIMPORT : Call GET_ATEXTRA ("PRICSTRUCT","SHOAXX("+num$(I)+")",GLANGUE,GCOLREM(I)) From TRTX3TEX : Endif
      Call GET_ATEXTRA ("PRICSTRUCT","SHOAXX("+num$(I)+")",GLANGUE,GCOLREM(I)) From TRTX3TEX
      #--/
    Endif
    If [F:PRS]VALTYP(I)=2 | [F:PRS]VALTYP(I)=3
      GFMTREM(I)="%"
    Else
      GFMTREM(I)="M"
    Endif
    GFMTCOL(I)=[F:PRS]FMTCOL(I)

  Endif
Next I
#-----

# -------------------------------------------------------------------------
# Point d'entrée COLREM pour modifier l'intitulé des colonnes frais/remises
# -------------------------------------------------------------------------
GPOINT="COLREM" : Gosub ENTREE From EXEFNC

End


#########################################################################
# Subprog FMTREM (WABMSK,CUR)                                           #
# garni le format de saisie pour les colonnes rem/frais des tarifs      #
# garni le code format "%" ou "M" dans GFMTREM (0..8)                   #
#-----------------------------------------------------------------------#
# DEFINIR dans masque en invisible FMTREM (0..8)                        #
# Dans bloc tableau /option/format/format adonix [M:xxx]FMTREM(nolign-1)#
# IMPERATIF : Appeler COLREM auparavant                                 #
#-----------------------------------------------------------------------#
#  WABMSK    = Abréviation du masque                                    #
#  CUR       = Devise                                                   #
#########################################################################
Subprog FMTREM(WABMSK,CUR)
Value Char      WABMSK
Value Char      CUR
#-----
Local Integer I
Call LECDEV (CUR) From TRTDIV
For I=0 To 8
  If GCOLREM(I)=""
    GFORREM(I)="-Nz:0#[       ]"
  Else
    If GFMTCOL(I)=""
      If GFMTREM(I)="M"
        If [F:TCU]CURFMT2="8"
          GFORREM(I)="NZ:"+[F:TCU]CURFMT2+"[ ]"
        Else
          GFORREM(I)="NZ:"+[F:TCU]CURFMT2
        Endif
      Else
        GFORREM(I)="NZ:3.2#[   ]"
      Endif
    Else
      If instr(1,GFMTCOL(I),"[F:TCU]")
        GFORREM(I)="N:"+evalue(GFMTCOL(I))
      Else
        GFORREM(I)="N:"+GFMTCOL(I)
      Endif
    Endif
  Endif
  Assign "[M:"+WABMSK+"]FMTREM(I)" With GFORREM(I)
Next I
#----------------------------------------------------------------------#
# Point d'entrée MAJFORMAT pour modifier les formats des frais/remises #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
# WABMSK     : Abréviation du masque                                   #
# CUR        : Devise                                                  #
# I          : Indice pour traitement en boucle des formats (0 à 8)    #
# GFMTREM(I) : Types de format ("M"=Montant, "%"=Taux)                 #
# GCOLREM(I) : Intitulés de colonne (si ="" colonne inactive)          #
# -------------------------------------------------------------------- #
# Variables modifiables par le point d'entrée                          #
# "[M:"+WABMSK+"]FMTREM (I)" : Formats des colonnes                    #
#----------------------------------------------------------------------#
GPOINT="MAJFORMAT" : Gosub ENTREE From EXEFNC
#-----
If !GIMPORT & find(WABMSK,"POH2","POC2","PTH1","PNH1","SCO2","SCO3") Gosub FMTREM_PUR : Endif
End

#---------------------------------------------------------------#
# Modification du format pour les champs affichés ou invisibles #
# Ceci n'est valable que pour les achats                        #
# GPTRNUM doit contenir le code de la transaction               #
# Si champ affiché, ajout de "P" avant ":"                      #
# Si champ invisible le format est précédé d'un "-"             #
#---------------------------------------------------------------#
$FMTREM_PUR
Local Integer  PTRTYP
Local Char     FORMAT(15)
Local Shortint J
For I=0 To 8
  If GCOLREM(I)<>""
    Case WABMSK
      When "POH2"
        FORMAT=[M:POH2]FMTREM(I) : PTRTYP=3 : Gosub MODIF_FORMAT : [M:POH2]FMTREM(I)=FORMAT
      When "POC2"
        FORMAT=[M:POC2]FMTREM(I) : PTRTYP=5 : Gosub MODIF_FORMAT : [M:POC2]FMTREM(I)=FORMAT
      When "PTH1"
        FORMAT=[M:PTH1]FMTREM(I) : PTRTYP=6 : Gosub MODIF_FORMAT : [M:PTH1]FMTREM(I)=FORMAT
      When "PNH1"
        FORMAT=[M:PNH1]FMTREM(I) : PTRTYP=7 : Gosub MODIF_FORMAT : [M:PNH1]FMTREM(I)=FORMAT
      When "SCO2","SCO3"
        FORMAT=[M:SCO3]FMTREM(I) : PTRTYP=0 : Gosub MODIF_FORMAT : [M:SCO3]FMTREM(I)=FORMAT
    Endcase
  Endif
Next I
Return

$MODIF_FORMAT
If !clalev([F:PTR])  Return : Endif : # Dans le cas de la fonction recherche tarif
If [F:PTR]PTRTYP<>PTRTYP | [F:PTR]PTRNUM<>GPTRNUM
  Read [PTR] PTR0=PTRTYP;GPTRNUM : If fstat  Raz [F:PTR] : Endif
Endif
If [F:PTR]DISCRGCOD(I)=2
  J=instr(1,FORMAT,":")
  FORMAT=left$(FORMAT,J-1)+"P"+right$(FORMAT,J)
Elsif [F:PTR]DISCRGCOD(I)=3
  FORMAT="-"+FORMAT
Endif
Return


#########################################################################
# Subprog TYPREM (PARTNER,STRUCTURE)                                    #
# garni le type de chaque remise/frais (mnt,%)                          #
# garni le no d'élément de facturation associé à chaque remise/frais    #
# garni l'indicateur prix net HT ligne                                  #
# garni l'indicateur base de calcul (par unité, ligne ou document)      #
#-----------------------------------------------------------------------#
# APPELER dans action OUVRE pour les ventes                             #
#         après saisie du fournisseur pour les achats                   #
# Il faut ensuite charger les var.globales dans [F] en INICRE           #
#-----------------------------------------------------------------------#
#  PARTNER   = 1 (client) / 2 (fournisseur)                             #
#  STRUCTURE = Code structure de PRICSTRUCT                             #
#########################################################################
Subprog TYPREM (PARTNER,STRUCTURE)
Value    Integer PARTNER
Value    Char    STRUCTURE
#
Raz GINCDCR
Raz GDISCRGTYP
Raz GINVDTALIN
Raz GNPRNOTFLG
Raz GCLCRUL

Local Integer I
#
If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif
If PARTNER<>1 & PARTNER<>2 : End : Endif
# Issue 74556 - 2011-07-04 by VPO : lecture ssi besoin
If [F:PRS]BPCBPS<>PARTNER | [F:PRS]PLISTC<>STRUCTURE
  Read [PRS]PRS0=PARTNER;STRUCTURE
  If fstat : End : Endif
Endif
For I=0 To 8
   GINCDCR(I)    = [F:PRS]INCDCR(I)
   GDISCRGTYP(I) = [F:PRS]VALTYP(I)
   GINVDTALIN(I) = [F:PRS]INVDTA(I)
   GNPRNOTFLG(I) = [F:PRS]NPRNOTFLG(I)
   GCLCRUL(I)    = [F:PRS]CLCRUL(I)
Next I
End

##########################################################################
# Subprog CALNET (PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET)                 #
#------------------------------------------------------------------------#
# Calcul du prix net (dans NET) à partir du prix brut et des maj/remises #
#------------------------------------------------------------------------#
#  PARTNER   = 1 (client) / 2 (fournisseur)                              #
#  STRUCTURE = Code structure de PRICSTRUCT                              #
#  BRUT      = Prix brut                                                 #
#  MAJREM    = Majoration/Remises (en % ou montant/en cumul ou cascade   #
#  QTE       = Quantité                                                  #
#  NET       = Prix net                                                  #
#  CUR       = Devise pour arrondir le prix calcule  (pas besoin)        #
#              tant pis on la passe quand même                           #
#------------------------------------------------------------------------#
# Attention: La table PRICSTRUCT (PRS) doit être ouverte                 #
#            Si le prix net est négatif après calcul, celui est mis à    #
#            zéro et GMESSAGE est chargé avec un message d'avertissement #
##########################################################################
Subprog CALNET (PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR)
Value    Integer PARTNER
Value    Char    STRUCTURE
Value    Decimal BRUT, QTE
Value    Decimal MAJREM(0..8)
Variable Decimal NET
Value    Char    CUR
#
Local    Decimal WREM(0..8) : Raz WREM
Local    Integer I
If dim(GCALNETLIN)<=0 : Global Integer GCALNETLIN : Endif
If dim(GCALNETABR)<=0 : Global Char    GCALNETABR : Endif

If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif
#Call LECTURE ("PRS",STRUCTURE,num$(PARTNER)) From CONTOBJ
# Issue 74556 - 2011-07-04 by VPO : lecture ssi besoin
If [F:PRS]BPCBPS<>PARTNER | [F:PRS]PLISTC<>STRUCTURE
  Read [PRS]PRS0=PARTNER;STRUCTURE
  If fstat
     NET = 0 : Raz GCALNETLIN, GCALNETABR # Issue 93046 - 2013-09-30 by MUARN : erreur variable
     End
  Endif
Endif
If QTE = 0  QTE = 1  Endif
NET = BRUT
For I = 0 To 8
   If [F:PRS]NPRNOTFLG(I) = 2
      If [F:PRS]INCDCR(I) = 1
         If [F:PRS]VALTYP(I) = 1
            If [F:PRS]CLCRUL(I) <> 1
               NET += MAJREM(I)/QTE      : WREM(I) = MAJREM(I)/QTE
            Else
               NET += MAJREM(I)          : WREM(I) = MAJREM(I)
            Endif
         Elsif [F:PRS]VALTYP(I) = 2
            WREM(I) = (BRUT*MAJREM(I))/100 : NET += (BRUT*MAJREM(I))/100
         Else
            WREM(I) = (NET*MAJREM(I))/100  : NET += (NET*MAJREM(I))/100
         Endif
      Else
         If [F:PRS]VALTYP(I) = 1
            If [F:PRS]CLCRUL(I) <> 1
               NET -= MAJREM(I)/QTE      : WREM(I) = -MAJREM(I)/QTE
            Else
               NET -= MAJREM(I)          : WREM(I) = -MAJREM(I)
            Endif
         Elsif [F:PRS]VALTYP(I) = 2
            WREM(I) = -(BRUT*MAJREM(I))/100 : NET -= (BRUT*MAJREM(I))/100
         Else
            WREM(I) = -(NET*MAJREM(I))/100  : NET -= (NET*MAJREM(I))/100
         Endif
      Endif
   Endif
Next I

# Point d'entrée pour intervenir sur le calcul du prix net
Local Integer GPE_RND
GPOINT="CALNET" : Gosub ENTREE From EXEFNC

#---------------------#
# arrondi du prix net #
#---------------------#
If !GPE_RND
   If (PARTNER = 1 & GSALRND = 2) | (PARTNER = 2 & GPURRND = 2)
      Call ARRDEV(NET,CUR) From TRTDIV
   Else
      NET = arr(NET,10^-GDECPRI)
   Endif
Endif
Raz GPE_RND

#----- Test si prix net négatif alors GMESSAGE et raz -----#
If NET<0  GMESSAGE=mess(216,199,1) : GERR=2 Else Raz GMESSAGE : Endif

#--------------------------------------------------------#
# Point d'entrée NEGPRI pour autoriser les prix négatifs #
# ------------------------------------------------------ #
# Ce point d'entrée n'est appelé que pour les achats,    #
# si l'article concerné n'est pas géré en stock.         #
# Appelé dans les ventes (05/08/03) pour dem.modif 18577 #
# mais non documenté pour rester ponctuel(trop dangereux)#
#                                                        #
# Variables utilisables par le point d'entrée            #
# PARTNER   : Business partner (2=Fournisseur)           #
# STRUCTURE : Code structure tarif                       #
# BRUT      : Prix unitaire brut                         #
# NET       : Prix unitaire net                          #
# GMESSAGE  : Est renseigné si le prix est négatif       #
# ------------------------------------------------------ #
# Variable modifiable par le point d'entrée              #
# Effacer GMESSAGE pour autoriser le prix négatif        #
#--------------------------------------------------------#
If PARTNER=2 & dim(GPURNEGPRI)>0 & GPURNEGPRI=2
  GPOINT="NEGPRI" : Gosub ENTREE From EXEFNC
  Raz GPURNEGPRI
Endif
If PARTNER=1
  GPOINT="NEGPRI" : Gosub ENTREE From EXEFNC
Endif
#-----
If GMESSAGE<>""  Raz NET : Endif
Raz GCALNETLIN, GCALNETABR
End


#########################################################################
# CTLREN : S/P de contrôle motifs tarif obligatoires       MBT 29/12/97 #
#-----------------------------------------------------------------------#
# Subprog CTLREN (MOTIF,MODULE,OLDREN,VALDCB)                           #
#    MOTIF  : Numéro du motif (zc)                                      #
#    MODULE : Code du module à traiter (5=Ventes, 6=Achats)             #
#    OLDREN : Numéro de motif actuel (valeur avant modification)        #
#    VALDCB : Valeur de la colonne tarif concernée (GROPRI, DISCRGVAL1, #
#                                       DISCRGVAL2, ....... DISCRGVAL9) #
#########################################################################
Subprog CTLREN (MOTIF,MODULE,OLDREN,VALDCB)
Value Decimal MOTIF
Value Integer MODULE
Value Integer OLDREN
Value Decimal VALDCB
#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6 End : Endif
#----- Si valeur de la colonne nulle alors motif non nécessaire -----#
If VALDCB=0 & MOTIF=0 End : Endif
#----- Test si motif obligatoire -----#
Local Char CLE(2) : CLE=num$(MOTIF)
If MODULE=5
   If GSALREN=2 & MOTIF=0 & VALDCB<>0
                    GMESSAGE=mess(86,199,1) : mkstat=1 : End : Endif
   If MOTIF<>0
      If MOTIF<>OLDREN Call CONTROLE("SPR","A",CLE,"",mkstat) From CONTOBJ
                  Else Call CONTROLE("SPR","" ,CLE,"",mkstat) From CONTOBJ
      Endif
   Endif
Endif
If MODULE=6
   If GPURREN=2 & MOTIF=0 & VALDCB<>0
                    GMESSAGE=mess(86,199,1) : mkstat=1 : End : Endif
   If MOTIF<>0
      If MOTIF<>OLDREN Call CONTROLE("PPR","A",CLE,"",mkstat) From CONTOBJ
                  Else Call CONTROLE("PPR","" ,CLE,"",mkstat) From CONTOBJ
      Endif
   Endif
Endif
End


#########################################################################
# LECREN : S/P de lecture des motifs tarifs si nécessaire  MBT 20/01/98 #
#          pour affichage de l'intitulé                                 #
#-----------------------------------------------------------------------#
# Subprog LECREN (DESMOTIF,MOTIF,MODULE)                                #
#    DESMOTIF : Désignation du motif                                    #
#    MOTIF    : Numéro du motif                                         #
#    MODULE  : Code du module à traiter (5=Ventes, 6=Achats)            #
#########################################################################
Subprog LECREN (DESMOTIF,MOTIF,MODULE)
Variable Char    DESMOTIF
Value    Integer MOTIF
Value    Integer MODULE
#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6 End : Endif
#----- Lecture des motifs si nécessaire -----#
If MODULE=5
   If [F:SPR]PRIREN<>MOTIF
      Read [SPR] SPR0=MOTIF : If fstat Raz [SPR] : Endif
   Endif
  #-- 80866 Performance Import --#
  If !GIMPORT : Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX : Endif
  #Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX
Endif
If MODULE=6
   If [F:PPR]PRIREN<>MOTIF
      Read [PPR] PPR0=MOTIF : If fstat Raz [PPR] : Endif
   Endif
   #-- 80866 Performance Import --#
   If !GIMPORT : Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX : Endif
   #Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX
Endif
End


########################################################################
# CTLSTRUCT : S/P contrôle existence de la structure tarif par défaut  #
#----------------------------------------------------------------------#
# Subprog CTLSTRUCT (PARTNER,STAT)                        MBT 19/12/97 #
#   PARTNER : Code du business-partner (1=Client, 2=Fournisseur)       #
#   STAT    : Code erreur (0=OK, 1=Structure par défaut inexistante    #
########################################################################
Subprog CTLSTRUCT (PARTNER,STAT)
Value    Integer PARTNER
Variable Integer STAT
STAT=0
If clalev ([F:PRS])<=0 Local File PRICSTRUCT [PRS] : Endif
# Issue 74556 - 2011-07-04 by VPO : lecture ssi besoin
If [F:PRS]BPCBPS<>PARTNER | [F:PRS]PLISTC<>""
  Read [PRS] PRS0=PARTNER;""
  If fstat
     Raz [PRS] : STAT=1 : GMESSAGE=mess(81,199,1) : GERR=1
  Endif
Endif
End

#########################################################################
# Traitements utilisés dans la recherche des tarifs
#########################################################################
#------------------------------------------------------------------------
#--- Calcul du prix si valeur pou N / Coefficient / Formule
$TAR_CALPRI
Return

#------------------------------------------------------------------------
#--- Conversion colonnes frais/remise.
$TAR_LIGCOL
Return

#------------------------------------------------------------------------
#--- Conversion unités.
$TAR_LIGUNI
Return

#########################################################################
# Subprog TARIFCHGT (module)                                            #
# garni les variables globales nécessaire à la recherche tarif          #
#-----------------------------------------------------------------------#
# APPELE  dans action OUVRE avant affichage du masque                   #
#-----------------------------------------------------------------------#
#  module    = 5 (ventes) / 6 (achats)                                  #
#########################################################################
Subprog TARIFCHGT (MODULE)
Value Integer   MODULE
Local Integer   I , J, ERR
If    MODULE = 5  : Gosub CHGTVEN
Elsif MODULE = 6  : Gosub CHGTACH
Endif
End
#-----------------------------------------------------------------------#
$CHGTVEN
If    clalev([F:SPC])=0 : Local File SPRICCONF[SPC] : Endif

Filter [SPC] Where PLISTC=GPLISTC & find(PLICPY,"",GSOCIETE)

Raz GPLITYP                            : # type de tarif
Raz GPLISEA                            : # code de la boucle de recherche
Raz GPIO                               : # priorite tarif
Raz GPLI                               : # code tarif
Raz GPLINBR                            : # nombre de tarifs actif ( max=dim(GPLI) )
GDISCRG = dim([F:SPC]DISCRGPRO)
#---- lecture du param. tarif / stockage en table des tarifs actifs
I = 0 : ERR = 0
For   [SPC]SPC1 Where PLIENAFLG = 2
      For   J = 0 To 4
            If    [F:SPC]ABB(J) <> "" & evalue("clalev([F:"+[F:SPC]ABB(J)+"])") = 0
                  ERR=1 : Break : Endif
      Next  J
      If    ERR = 0
            GPLITYP(I) = [F:SPC]PLITYP
            GPIO(I)    = [F:SPC]PIO
            GPLI(I)    = [F:SPC]PLI
            If dim([F:SPC]PLISEA)>0 : GPLISEA(I)=[F:SPC]PLISEA : Endif
            I += 1
            If I=dim(GPLI) : Break : Endif
      Endif
      ERR = 0
Next
GPLINBR = I
Filter [SPC]
Return
#-----------------------------------------------------------------------#
$CHGTACH
If    clalev([F:PPC])=0 : Local File PPRICCONF[PPC] : Endif
Filter [PPC] Where PLISTC=GPLISTC

Raz GPLITYP                            : # type de tarif
Raz GPLISEA                            : # code boucle de recherche
Raz GPIO                               : # priorite tarif
Raz GPLI                               : # code tarif
Raz GPLINBR                            : # nombre de tarifs actif ( max=dim(GPLI) )
GDISCRG = dim([F:PPC]DISCRGPRO)

#---- lecture du param. tarif / stockage en table des tarifs actifs
I = 0 : ERR = 0
For   [PPC]PPC1 Where PLIENAFLG = 2
      For J = 0 To 4
          If [F:PPC]ABB(J) <> "" & evalue("clalev([F:"+[F:PPC]ABB(J)+"])") = 0
             If !(GMODU(5)=2 & find([F:PPC]ABB(J),"BPC","BPD","ITS","MVC"))
                ERR=1 : Break
             Endif
          Endif
      Next  J
      If    ERR = 0
            GPLITYP(I) = [F:PPC]PLITYP
            GPIO(I)    = [F:PPC]PIO
            GPLI(I)    = [F:PPC]PLI
            If dim([F:PPC]PLISEA)>0 : GPLISEA(I)=[F:PPC]PLISEA : Endif
            I += 1
            If I=dim(GPLI) : Break : Endif
      Endif
      ERR = 0
Next
GPLINBR = I
Filter [PPC]
Return

#########################################################################
# Subprog TARIFRECH (module,plityp,err)                                 #
# pour chaque ligne de la table appel de la recherche tarif             #
#-----------------------------------------------------------------------#
# APPELE                                                                #
#-----------------------------------------------------------------------#
#  module    = 5 (ventes) / 6 (achats)                                  #
#  plityp    = 1 (normal) / 2 (groupé) / 3 (interdit) / 4 (composant)   #
#  trait     = traitement appelant (utilisé par tarif groupe)           #
#              achats : POH cde std / POC cde ouv / POS cde sous-trait  #
#              ventes : SOH cde std / SOI cde ouv / SIH fac directe     #
#                       SQH offre   / SDH liv directe                   #
#                       SCS trf inter-sociétés                          #
#  err       = 0 (non) / 1 (oui)                                        #
#########################################################################
Subprog TARIFRECH
&             (MODULE,PLITYP,TRAIT,
&              DAT,QTY,UOM,CHGTYP,CUR,PRITYP,VAT,PARAM_T,MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR)
Value    Integer   MODULE            : # module (vente achat)
Value    Integer   PLITYP            : # type de tarif
Value    Char      TRAIT ()          : # type de traitement

Value    Date      DAT               : # date commande ou livraison
Value    Decimal   QTY               : # quantité
Value    Char      UOM               : # unité de vente
Value    Integer   CHGTYP            : # type de cours
Value    Char      CUR               : # devise de la commande
Value    Integer   PRITYP            : # prix ht ou ttc
Value    Char      VAT()(0..2)       : # codes taxes
Variable Char      PARAM_T () (0..)  : # parametres complementaires
                                       # indice 0 = coef multiplicateur UV --> US
                                       # indice 1 = régime de taxe
                                       # indice 2 = coef. conversion devise (si facture vente)
                                       # indice 3 = date pour le calcul des taxes (prix HT/TTC)           : # Bug 84596
Variable Decimal   MONTANT(0..10)    : # (0)=prix (1..9)=fr/rem (10)=comm rep
Variable Shortint  MOTIF  (0..10)    : # motif
Variable Shortint  PRIORITE(0..10)   : # priorité
Variable Char      PLI   () (0..)    : # code tarif
Variable Char      PLICRD () (0..)   : # code de la fiche tarif
Variable Integer   PLILIN    (0..)   : # no de ligne de la fiche tarif
Variable Char      FOCITMREF() (0..) : # article gratuit
Variable Decimal   FOCQTY      (0..) : # quantité gratuite
Variable Char      FOCUOM()    (0..) : # unité vente gratuit
Variable Shortint  FOCMOTIF    (0..) : # motif gratuit
Variable Date      PLISTRDAT         : # date debut validite
Variable Date      PLIENDDAT         : # date fin   validite
Variable Libelle   INTERDIT          : # 1 si interdit
Variable Libelle   ERR               : # 1 si erreur

#  variables locales de sauvegarde
Local Decimal  JMONTANT            (0..10)
Local Shortint JMOTIF              (0..10)
Local Shortint JPRIORITE           (0..10)
Local Char     JPLI       (10)     (0..dim(PLI)-1)
Local Char     JPLICRD    (20)     (0..dim(PLICRD)-1)
Local Integer  JPLILIN             (0..dim(PLILIN)-1)
Local Char     JFOCITMREF (GLONITM)(0..dim(FOCITMREF)-1)
Local Decimal  JFOCQTY             (0..dim(FOCQTY)-1)
Local Char     JFOCUOM    (GLONUOM)(0..dim(FOCUOM)-1)
Local Shortint JFOCMOTIF           (0..dim(FOCMOTIF)-1)
Local Date     JPLISTRDAT
Local Date     JPLIENDDAT
Local Libelle  JINTERDIT
Local Libelle  JERR

Local Decimal  JNETPRI

Local Integer  PARTNER
Local Decimal  GROPRI, MAJREM (0..8), NETPRI

Local    Shortint  PIO               : # priorité courante de table globale
Local    Integer   I, J, FIN

#----- Sauvegarde de la table des types de tarif -----#
Local    Integer   SAVPLITYP(0..dim(GPLI)-1)

For I=0 To GPLINBR-1 : SAVPLITYP(I)=GPLITYP(I) : Next I
#----------------------------------------------------------------#
# Point d'entrée AVRECHTAR pour désactiver certains codes tarif  #
# -------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                    #
#                                                                #
# MODULE         : Module (5=Ventes, 6=Achats)                   #
# PLITYP         : Type de tarif recherché                       #
# TRAIT          : Code traitement ayant lancé la recherche      #
# GPLI(0..xxx)    : Table des codes tarifs                       #
# GPIO(0..xxx)    : Table des priorités des codes tarif          #
# GPLITYP(0..xxx) : Table des types de tarif                     #
#                  (1=Normal, 2=Groupé, 3=Interdit, 4=Composant) #
# GPLINBR        : Nombre de codes tarif sélectionnés            #
#--------------------------------------------------------------- #
# Variables modifiables par le point d'entrée                    #
#                                                                #
# GPLITYP(0..xxx) : Mettre la valeur à 9 pour désactiver         #
#                  le code tarif correspondant GPLI(0..xxx)      #
#----------------------------------------------------------------#
GPOINT="AVRECHTAR" : Gosub ENTREE From EXEFNC

#---------------------------------------------------------------------------------
#  pour determiner si on a plusieurs recherches a effectuer
#---------------------------------------------------------------------------------
Local Integer TPLISEA  (0..10)                          : # table des codes de recherche
Local Integer NBPLISEA                                  : # nombre de codes de recherche
Local Integer IPLISEA                                   : # indice du code de recherche
Local Integer RPLISEA                                   : # valeur du codde de recherche en cours
For I=0 To dim(TPLISEA)-1 : TPLISEA(I)=9999 : Next I    : # mise a maxi table des codes recherche

For I=0 To GPLINBR-1
  If GPLITYP(I)<>9 & GPLITYP(I)=PLITYP
     If !find(GPLISEA(I),TPLISEA)
       TPLISEA(NBPLISEA)=GPLISEA(I) : NBPLISEA +=1
     Endif
  Endif
Next I

If MODULE = 5 JMONTANT(10) = 1 Endif                     : # Bug 62429

$BOUCLE_RECH
RPLISEA=TPLISEA(IPLISEA)

#---- initialisation
Raz MONTANT, MOTIF, PRIORITE, PLI, PLICRD, PLILIN
Raz FOCITMREF, FOCQTY, FOCUOM, FOCMOTIF
Raz PLISTRDAT, PLIENDDAT, INTERDIT, ERR

#If MODULE = 5 MONTANT(10) = 1 : JMONTANT(10) = 1 Endif : # Bug 62429
If MODULE = 5 MONTANT(10) = 1 Endif                     : # Bug 62429

#---- lecture de la table globale
For I=0 To GPLINBR-1
   If GPLITYP(I)<>9 & GPLISEA(I)=RPLISEA : # Le code tarif n'est pas rendu inactif par le point d'entrée
      #---- fin de recherche en table
      If    INTERDIT = 1 : Goto FIN_TARIFRECH : Endif
      If    GPLITYP(I) > PLITYP : Goto FIN_BOUCLE_RECH : Endif
            FIN = 1
            For   J = 1 To GDISCRG
                  If    MOTIF(J) = 0 | PRIORITE(J) = GPIO(I) : FIN = 0 : Break
                  Endif
            Next J
      If    MOTIF(0) = 0 | PRIORITE(0) = GPIO(I) : FIN = 0 : Endif
      If    MOTIF(10)= 0 | PRIORITE(10)= GPIO(I) : FIN = 0 : Endif
      If    FIN = 1 : Goto FIN_BOUCLE_RECH : Endif
      #---- chargement des tarifs
      If    GPLITYP(I) = PLITYP
            PIO        = GPIO(I)
            If MODULE  = 5
              NOMTRAIT = "WBT"+GPLI(I)
             Else
              NOMTRAIT = "WAT"+GPLI(I)
            Endif
#            Call TARIF(TRAIT,DAT,QTY,UOM,CHGTYP,CUR,PRITYP,VAT,PIO,
            Call TARIF(TRAIT,DAT,QTY,UOM,CHGTYP,CUR,PRITYP,VAT,PIO,PARAM_T,
&                      MONTANT,MOTIF,PRIORITE,
&                      PLI,PLICRD,PLILIN,
&                      FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&                      PLISTRDAT,PLIENDDAT,INTERDIT)
&                From =NOMTRAIT

            GPOINT="CPLTARIF" : Gosub ENTREE From EXEFNC

      Endif
   Endif
Next I
$FIN_BOUCLE_RECH

If NBPLISEA <2
  Goto FIN_TARIFRECH                      : # un seul niveau pas besoin de comparaison
Endif

If MODULE=5 : PARTNER=1 Else PARTNER=2 : Endif
GROPRI=MONTANT(0)
For I=0 To dim(MAJREM)-1 : MAJREM(I)=MONTANT(I+1) :Next I
Raz NETPRI

If MOTIF(0)<>0                            : # uniquement si prix avec motif
    # pas de garnissage de GCALNETLIN et GCALNETABR ( Interne a recherche tarif )
    Call CALNET (PARTNER,"",GROPRI,MAJREM,QTY,NETPRI,CUR) From TRTPRICE

#-- Stockage donnee de la nouvelle boucle de recherche
#      - si les donnees stockees sans prix dans le parametrage
#      - ou si prix net nouvelle boucle < boucle stockee
    If JPLI(0)="" | (NETPRI<JNETPRI & PLI(0)<>"")
      JNETPRI=NETPRI
      Gosub RECH_STOC
    Endif
Endif

#-- Stockage donnee de la nouvelle boucle de recherche ( bug 31160 )
#      - si boucle sans parametrage prix ( prix issu des prix de base )
#      - et si aucune donnees stockees
If MOTIF(0)=0 & sum(MOTIF)<>0 & sum(JMOTIF)=0
   Gosub RECH_STOC
Endif

IPLISEA +=1
If IPLISEA < NBPLISEA
  Goto BOUCLE_RECH                       : # boucle sur autre code de recherche
Else
  Gosub STOC_RECH                        : # il faut recharger le buffer de recherche
Endif

$FIN_TARIFRECH
#----- Restauration de la table des types de tarif -----#
For I=0 To GPLINBR-1 : GPLITYP(I)=SAVPLITYP(I) : Next I
#--------------------------------------------------------------------------------#
# Point d'entrée TARIFVEN pour intervenir sur les valeurs du tarif vente trouvés #
# ------------------------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                                    #
#                                                                                #
# MODULE    : Module (5 = Ventes)                                                #
# PLITYP    : Type de tarif (1 = Normal, 2 = Groupé, 3 = Interdit, 4 = Composant)#
# TRAIT     : Code traitement ayant lancé la recherche                           #
#               SQH = Recherche depuis devis                                     #
#               SOH = Recherche depuis cdes standards                            #
#               SOI = Recherche depuis commandes ouvertes                        #
#               SDH = Recherche depuis livraisons                                #
#               SIH = Recherche depuis factures                                  #
# ------------------------------------------------------------------------------ #
# Variables modifiables par le point d'entrée                                    #
#                                                                                #
# MONTANT(0..10) : Valeurs tarif trouvées                                        #
#                    indice  0 = Prix unitaire brut                              #
#                    indices 1 à 9 = Frais/Remises 1 à 9                         #
#                    indice 10 = Coefficient pour le calcul des commissions      #
# MOTIF (0..10)  : Codes motifs                                                  #
#                    indice  0 = Motif du prix unitaire brut                     #
#                    indices 1 à 9 = Motifs des Frais/Remises 1 à 9              #
#--------------------------------------------------------------------------------#
If MODULE=5
  GPOINT="TARIFVEN" : Gosub ENTREE From EXEFNC
Endif
#--------------------------------------------------------------------------------#
# Point d'entrée TARIFACH pour intervenir sur les valeurs du tarif achat trouvés #
# ------------------------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                                    #
#                                                                                #
# MODULE    : Module (6 = Achats)                                                #
# PLITYP    : Type de tarif (1 = Normal,  2 = Groupé)                            #
# TRAIT     : Code traitement ayant lancé la recherche                           #
#               PSH  = Recherche depuis demandes achats                          #
#               PSM  = Recherche depuis gestion auto DA                          #
#               POH  = Recherche depuis cdes standards                           #
#               POI  = Recherche depuis plan de l'acheteur (cdes/articles)       #
#               POC  = Recherche depuis contrats pour ligne tarif                #
#               POV  = Recherche depuis contrats pour prix de valorisation       #
#               POD  = Recherche depuis demandes de livraison                    #
#               PTH  = Recherche depuis réceptions directes                      #
#               PNH  = Recherche depuis retours fournisseurs sans rcp            #
#               PSCM = Recherche depuis ordres sous-traitance matière            #
#               PSCS = Recherche depuis ordres sous-traitance service            #
#               FSCM = Recherche gestion auto ordres sous-traitance matière      #
#               FSCS = Recherche gestion auto ordres sous-traitance service      #
# ------------------------------------------------------------------------------ #
# Variables modifiables par le point d'entrée                                    #
#                                                                                #
# MONTANT(0..10) : Valeurs tarif trouvées                                        #
#                    indice  0 = Prix unitaire brut                              #
#                    indices 1 à 9 = Frais/Remises 1 à 9                         #
#                    indice 10 = Délai en jour pour calcul date de réception     #
# MOTIF (0..10)  : Codes motifs                                                  #
#                    indice  0 = Motif du prix unitaire brut                     #
#                    indices 1 à 9 = Motifs des Frais/Remises 1 à 9              #
#--------------------------------------------------------------------------------#
If MODULE=6
  GPOINT="TARIFACH" : Gosub ENTREE From EXEFNC
Endif
End

#---------------------------------------------------------------------------------
#  buffer recherche --> buffer stockage
#---------------------------------------------------------------------------------
$RECH_STOC
For I=0 To dim(MONTANT)-1    : JMONTANT(I)  =MONTANT(I)    : Next I
For I=0 To dim(MOTIF)-1      : JMOTIF(I)    =MOTIF(I)      : Next I
For I=0 To dim(PRIORITE)-1   : JPRIORITE(I) =PRIORITE(I)   : Next I
For I=0 To dim(PLI)-1        : JPLI(I)      =PLI(I)        : Next I
For I=0 To dim(PLICRD)-1     : JPLICRD(I)   =PLICRD(I)     : Next I
For I=0 To dim(PLILIN)-1     : JPLILIN(I)   =PLILIN(I)     : Next I
For I=0 To dim(FOCITMREF)-1  : JFOCITMREF(I)=FOCITMREF(I)  : Next I
For I=0 To dim(FOCQTY)-1     : JFOCQTY(I)   =FOCQTY(I)     : Next I
For I=0 To dim(FOCUOM)-1     : JFOCUOM(I)   =FOCUOM(I)     : Next I
For I=0 To dim(FOCMOTIF)-1   : JFOCMOTIF(I) =FOCMOTIF(I)   : Next I
JPLISTRDAT=PLISTRDAT : JPLIENDDAT=PLIENDDAT : JINTERDIT=INTERDIT : JERR=ERR
Return

#---------------------------------------------------------------------------------
#  buffer stockage --> buffer recherche
#---------------------------------------------------------------------------------
$STOC_RECH
For I=0 To dim(MONTANT)-1    : MONTANT(I)  =JMONTANT(I)    : Next I
For I=0 To dim(MOTIF)-1      : MOTIF(I)    =JMOTIF(I)      : Next I
For I=0 To dim(PRIORITE)-1   : PRIORITE(I) =JPRIORITE(I)   : Next I
For I=0 To dim(PLI)-1        : PLI(I)      =JPLI(I)        : Next I
For I=0 To dim(PLICRD)-1     : PLICRD(I)   =JPLICRD(I)     : Next I
For I=0 To dim(PLILIN)-1     : PLILIN(I)   =JPLILIN(I)     : Next I
For I=0 To dim(FOCITMREF)-1  : FOCITMREF(I)=JFOCITMREF(I)  : Next I
For I=0 To dim(FOCQTY)-1     : FOCQTY(I)   =JFOCQTY(I)     : Next I
For I=0 To dim(FOCUOM)-1     : FOCUOM(I)   =JFOCUOM(I)     : Next I
For I=0 To dim(FOCMOTIF)-1   : FOCMOTIF(I) =JFOCMOTIF(I)   : Next I
PLISTRDAT=JPLISTRDAT : PLIENDDAT=JPLIENDDAT : INTERDIT=JINTERDIT : ERR=JERR
Return

########################################################################
# ALIPLK : S/P alimentation du fichier lien SPRICLINK                  #
#          ou PPRICLINK   pour la recherche tarif                      #
#----------------------------------------------------------------------#
# Subprog ALIPLK (TRAIT)                                   TS  01/1998 #
#                                                                      #
#   TRAIT : Code traitement                                            #
#               CRM  = recherche depuis la CRM                         #
#               SQH  = recherche depuis devis (objet SQH)              #
#               SOH  = recherche depuis cdes (objet SOH)               #
#               SOI  = recherche depuis cdes ouv (objet SOI)           #
#               SDH  = recherche depuis liv directe (objet SDH)        #
#               SDD  = recherche depuis liv automatique                #
#               SDD1 = recherche depuis liv cde ouv (picking ou auto)  #
#               SIH  = recherche depuis fac directe (objet SIH)        #
#               SPSI = recherche depuis la simulation tarif            #
#               SCS  = recherche depuis les transferts inter-sociétés  #
#                              ... à compléter                         #
#               PSH  = Recherche depuis demandes d'achat               #
#               PSM  = Recherche depuis gestion auto demandes d'achat  #
#               POH  = Recherche depuis cdes standards                 #
#               POM  = Recherche depuis gestion auto cdes standards    #
#               POC  = Recherche depuis cdes ouvertes                  #
#               POD  = Recherche depuis demandes livraison fermes      #
#               PTH  = Recherche depuis réceptions directes            #
#               PNH  = Recherche depuis retours fournisseurs sans rcp  #
#               PSCM = Recherche depuis ordres sous-traitance matière  #
#               PSCS = Recherche depuis ordres sous-traitance service  #
#               FSCM = Recherche gestion auto ordres ss-trait matière  #
#               FSCS = Recherche gestion auto ordres ss-trait service  #
#                              ... à compléter                         #
#               #--- Issue 110325
#               SHP  = Recherche depuis expéditions (pour formule STC) #
#                              ... à compléter                         #
# Attention : nolign doit être chargé pour les champs ligne de cde     #
########################################################################
Subprog ALIPLK (TRAIT)
Value    Char  TRAIT
GALIPLK=TRAIT
Gosub GALIPLK
End

##################################
$GALIPLK
#          init. [F:SPK] ou [F:PPK] uniquement en V140
Case GALIPLK
 When "CRM"  : Raz [F:SPK] : Gosub TRTCRM
 When "SQH"  : Raz [F:SPK] : Gosub TRTSQH
 When "SOH"  : Raz [F:SPK] : Gosub TRTSOH
 When "SOI"  : Raz [F:SPK] : Gosub TRTSOI
 When "SDH"  : Raz [F:SPK] : Gosub TRTSDH
 When "TNH"  : Raz [F:SPK] : Gosub TRTTNH     : # 91606 :(04/08/14) Transportation notes (Sales part dev)
 When "SDD"  : Raz [F:SPK] : Gosub TRTSDD
 When "SDD1" : Raz [F:SPK] : Gosub TRTSDD1
 When "SIH"  : Raz [F:SPK] : Gosub TRTSIH
 When "SPSI" : Raz [F:SPK] : Gosub TRTSPSI
 When "SCS"  : Raz [F:SPK] : Gosub TRTSCS

 When "POH"  : Raz [F:PPK] : Gosub TRTPOH
 When "POM"  : Raz [F:PPK] : Gosub TRTPOM
 When "PSH"  : Raz [F:PPK] : Gosub TRTPSH
 When "PSM"  : Raz [F:PPK] : Gosub TRTPSM
 When "POI"  : Raz [F:PPK] : Gosub TRTPOI
 When "POC","POV"  : Raz [F:PPK] : Gosub TRTPOC # Issue 116706 - 2016-05-24 by SR : "POV"
 When "POD"  : Raz [F:PPK] : Gosub TRTPOD
 When "PTH"  : Raz [F:PPK] : Gosub TRTPTH
 When "PNH"  : Raz [F:PPK] : Gosub TRTPNH
 When "PSCM" : Raz [F:PPK] : Gosub TRTPSCM
 When "PSCS" : Raz [F:PPK] : Gosub TRTPSCS
 When "FSCM" : Raz [F:PPK] : Gosub TRTFSCM  # FQ 72413 GA 05/2011
 When "FSCS" : Raz [F:PPK] : Gosub TRTFSCS  # FQ 72413 GA 05/2011
 When "SHP"  : Raz [F:PPK] : Gosub TRTSHP   # Issue 110325 by TS
Endcase

Gosub ALIPLK_COMP

# P.E. pour intervenir sur le contenu des buffers SPRICLINK ou PPRICLINK
GPOINT="ALIPLK" : Gosub ENTREE From EXEFNC
Return

##################################
### FGR 17/06/2010 : X3SUIVI65413 ##
#----- Chargement environnement tarif depuis le module CRM -----#
$OLD_TRTCRM
#    #LSE 05/12/2006 FQ38640
#    Case [M:SPSW]CONTEXT
#        When "ITN"
#            [F:SPK] = [F:ITN]
#        When "SRE"
#            [F:SPK] = [F:SRE]
#
#    Endcase

    #La classe [F:SRE] est chargé dans les 2 cas
    [F:SPK] = [F:SRE]
    If [M:SPSW]CONTEXT="ITN"
        [F:SPK] = [F:ITN]
    Endif
    #Client facture
    If [F:SRE]SREBPCINV<>""
        [F:SPK]BPCINV=[F:SRE]SREBPCINV
    Else
        [F:SPK]BPCINV=[F:SRE]SREBPC
    Endif
    #Client groupe
    If [F:SRE]SREBPCGRU<>""
        [F:SPK]BPCGRU=[F:SRE]SREBPCGRU
    Else
        [F:SPK]BPCGRU=[F:SRE]SREBPC
    Endif
    #Affaire
    [F:SPK]PJT=[F:SRE]SREPJT
    # 71065 : PJT
    [F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([F:SRE]SREPJT) : # Code affaire seul
    # 71065 : PJT
    [F:SPK]PTE=[F:SRE]SREPTE
Return

$TRTCRM
  #La classe [F:SRE] est chargé dans les 2 cas
  # FGR 17/06/2010 : X3SUIVI65413 : c'est pas vrai. Voir mes commentaires dans la fiche
  If [M:SPSW]CONTEXT = "ITN" Then
    [F:SPK] = [F:SRE]
    #[F:SPK] = [F:ITN]
    [F:SPK] = [M:ITN0]
    [F:SPK] = [M:ITN1]
    [F:SPK] = [M:ITN3]
    [F:SPK] = [M:ITN7]
    [F:SPK] = [M:ITN8]
    [F:SPK] = [M:ITN4]
    #Client facture
    If [F:SRE]SREBPCINV <> "" Then
      [F:SPK]BPCINV = [F:SRE]SREBPCINV
    Else
      [F:SPK]BPCINV = [F:SRE]SREBPC
    Endif
    #Client groupe
    If [F:SRE]SREBPCGRU <> "" Then
      [F:SPK]BPCGRU = [F:SRE]SREBPCGRU
    Else
      [F:SPK]BPCGRU = [F:SRE]SREBPC
    Endif
    #Affaire
    [F:SPK]PJT = [F:SRE]SREPJT
    # 71065 : PJT
    [F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([F:SRE]SREPJT) : # Code affaire seul
    # 71065 : PJT
    [F:SPK]PTE = [F:SRE]SREPTE
    [F:SPK]CPY = GSOCIETE      # FGR 29/06/2014 : X3SUIVI101073
  Else
    [F:SPK] = [M:SRE0]
    [F:SPK] = [M:SRE1]
    [F:SPK] = [M:SRE7]
    [F:SPK] = [M:SRE2]
    [F:SPK] = [M:SRE8]
    [F:SPK] = [M:SRE9]
    #Client facture
    If [M:SRE8]SREBPCINV <> "" Then
      [F:SPK]BPCINV = [M:SRE8]SREBPCINV
    Else
      [F:SPK]BPCINV = [M:SRE0]SREBPC
    Endif
    #Client groupe
    If [M:SRE8]SREBPCGRU <> "" Then
      [F:SPK]BPCGRU = [M:SRE8]SREBPCGRU
    Else
      [F:SPK]BPCGRU = [M:SRE0]SREBPC
    Endif
    #Affaire
    [F:SPK]PJT = [M:SRE8]SREPJT
    # 71065 : PJT
    [F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SRE8]SREPJT) : # Code affaire seul
    # 71065 : PJT
    [F:SPK]PTE = [M:SRE8]SREPTE
    [F:SPK]CPY = GSOCIETE      # FGR 29/06/2014 : X3SUIVI101073
  Endif
Return


#----- Chargement environnement tarif depuis les devis -----#
$TRTSQH
For I=1 To dim([F:SPK]TSCCOD)
  If dim([F:BPC]TSCCOD) >= I : [F:SPK]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1) : Endif
Next I
For I=1 To dim([F:SPK]TSICOD)
  If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
Next I
[F:SPK] = [M:SQH0]
[F:SPK] = [M:SQH1]
[F:SPK] = [M:SQH2]
[F:SPK] = [M:SQH3]
[F:SPK]PNTITMREF = GPNTITMREF
[F:SPK]CPY       = GSOCIETE
If [M:SQH2]FOCFLG(nolign-1)=3 [F:SPK]FOCITM=2 Else [F:SPK]FOCITM=1 Endif
# 71065 : PJT
[F:SPK]PJT    = [M:SQH2]DPJT(nolign-1)
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SQH2]DPJT(nolign-1)) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[M:SQH0]BPCORD : WBPAADD=[M:SQH1]BPAADD   : # Step2
WDBPAADD=[M:SQH2]DBPAADD(nolign-1)                : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

[F:SPK]BPCINV = [F:BPC]BPCINV : # Bug 85621
[F:SPK]BPCGRU = [F:BPC]BPCGRU : # Bug 85621

#--CPO 85811 BPTNUM et MDL tarifs devis
#--Dans le cas du devis il faut les lire depuis le client livré
[F:SPK]BPTNUM = [F:BPD]BPTNUM
[F:SPK]MDL    = [F:BPD]MDL

Return


#----- Chargement environnement tarif depuis commandes standards -----#
$TRTSOH
[F:SPK] = [M:SOH0] : # TSCCOD dans ecran SOH0
[F:SPK] = [M:SOH1]
[F:SPK] = [M:SOH2]
[F:SPK] = [M:SOH3]
[F:SPK] = [M:SOH4]
[F:SPK]BPTNUM    = [M:SOH4]DBPTNUM(nolign-1)
[F:SPK]STOFCY    = [M:SOH4]DSTOFCY(nolign-1)
[F:SPK]PNTITMREF = GPNTITMREF
For I = 1 To dim([F:SPK]TSICOD)
    If evalue("dim([M:SOH4]TSICOD"+num$(I)+"(nolign-1))")>0
       [F:SPK]TSICOD(I-1) = evalue("[M:SOH4]TSICOD"+num$(I)+"(nolign-1)")
    Endif
Next I
#   pour recherche interdit la classe M n'est pas garnie on charge a partir de l article
If vireblc(sum([F:SPK]TSICOD),2)=""   : # la classe M n'est pas garnie si recherche interdit
  For I=1 To dim([F:SPK]TSICOD)
    If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
  Next I
Endif

[F:SPK]CPY       = GSOCIETE
If [M:SOH4]FOCFLG(nolign-1)=3 [F:SPK]FOCITM=2 Else [F:SPK]FOCITM=1 Endif
# 71065 : PJT
[F:SPK]PJT    = [M:SOH4]DPJT(nolign-1)
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SOH4]DPJT(nolign-1)) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[M:SOH0]BPCORD : WBPAADD=[M:SOH1]BPAADD : # Step2
WDBPAADD=[M:SOH4]DBPAADD(nolign-1)              : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

Return


#----- Chargement environnement tarif depuis commandes ouvertes -----#
$TRTSOI
For I=1 To dim([F:SPK]TSCCOD)
  If dim([F:BPC]TSCCOD) >= I : [F:SPK]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1) : Endif
Next I
For I=1 To dim([F:SPK]TSICOD)
  If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
Next I
[F:SPK] = [M:SOR1]
[F:SPK] = [M:SOI1]
[F:SPK]BPTNUM = [M:SOI1]XBPTNUM
[F:SPK]PCK    = [M:SOI1]XPCK
[F:SPK]CPY       = GSOCIETE
[F:SPK]FOCITM    = 1
# 71065 : PJT
[F:SPK]PJT    = [M:SOI1]DPJT
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SOI1]DPJT) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[M:SOI1]BPCORD : WBPAADD=[M:SOI1]BPAADD
WDBPAADD=WBPAADD                           : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

Return


#----- Chargement environnement tarif depuis livraisons -----#
$TRTSDH
For I=1 To dim([F:SPK]TSCCOD)
  If dim([F:BPC]TSCCOD) >= I : [F:SPK]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1) : Endif
Next I
[F:SPK] = [M:SDH0]
[F:SPK] = [M:SDH1]
[F:SPK] = [M:SDH2]
[F:SPK]PNTITMREF = GPNTITMREF
For I = 1 To dim([F:SPK]TSICOD)
    If evalue("dim([M:SDH1]TSICOD"+num$(I)+"(nolign-1))")>0
       [F:SPK]TSICOD(I-1) = evalue("[M:SDH1]TSICOD"+num$(I)+"(nolign-1)")
    Endif
Next I
#   pour recherche interdit la classe M n'est pas garnie on charge a partir de l article
If vireblc(sum([F:SPK]TSICOD),2)=""   : # la classe M n'est pas garnie si recherche interdit
  For I=1 To dim([F:SPK]TSICOD)
    If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
  Next I
Endif

[F:SPK]CPY       = GSOCIETE
If [M:SDH1]FOCFLG(nolign-1)=3 [F:SPK]FOCITM=2 Else [F:SPK]FOCITM=1 Endif
# 71065 : PJT
[F:SPK]PJT = [M:SDH1]DPJT(nolign-1)
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SDH1]DPJT(nolign-1)) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[M:SDH0]BPCORD : WBPAADD=[M:SDH0]BPAADD
WDBPAADD=WBPAADD                           : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

Return

# 91606 :(04/08/14) Transportation notes (Sales part dev)
#----- Charge price environnement from transportation notes  -----#
$TRTTNH
For I=1 To dim([F:SPK]TSCCOD)
  If dim([F:BPC]TSCCOD) >= I : [F:SPK]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1) : Endif
Next I
[F:SPK] = [M:TNH0]
[F:SPK] = [M:TNH1]
[F:SPK] = [M:TNH2]
[F:SPK]PNTITMREF = GPNTITMREF
For I = 1 To dim([F:SPK]TSICOD)
    If evalue("dim([M:TNH1]TSICOD"+num$(I)+"(nolign-1))")>0
       [F:SPK]TSICOD(I-1) = evalue("[M:TNH1]TSICOD"+num$(I)+"(nolign-1)")
    Endif
Next I
#   pour recherche interdit la classe M n'est pas garnie on charge a partir de l article
If vireblc(sum([F:SPK]TSICOD),2)=""   : # la classe M n'est pas garnie si recherche interdit
  For I=1 To dim([F:SPK]TSICOD)
    If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
  Next I
Endif

[F:SPK]CPY       = GSOCIETE
If [M:TNH1]FOCFLG(nolign-1)=3 [F:SPK]FOCITM=2 Else [F:SPK]FOCITM=1 Endif

Gosub DECLARE_CRY_SAT
WBPCORD=[M:TNH0]BPCORD : WBPAADD=[M:TNH0]BPAADD
WDBPAADD=WBPAADD                           : # Step2
Gosub CHARGE_CRY_SAT

Return
# 91606 :(04/08/14) Transportation notes (Sales part dev)

#----- Chargement environnement tarif depuis fichier livraison -----#
$TRTSDD
For I=1 To dim([F:SPK]TSCCOD)
  If dim([F:BPC]TSCCOD) >= I : [F:SPK]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1) : Endif
Next I
[F:SPK] = [F:SDH]
[F:SPK] = [F:SDD]
[F:SPK]PNTITMREF = GPNTITMREF
For I = 1 To dim([F:SPK]TSICOD)
    If evalue("dim([F:SDD]TSICOD"+num$(I)+")")>0
       [F:SPK]TSICOD(I-1) = evalue("[F:SDD]TSICOD"+num$(I))
    Endif
Next I
#   pour recherche interdit la classe M n'est pas garnie on charge a partir de l article
If vireblc(sum([F:SPK]TSICOD),2)=""   : # la classe M n'est pas garnie si recherche interdit
  For I=1 To dim([F:SPK]TSICOD)
    If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
  Next I
Endif
[F:SPK]CPY       = GSOCIETE
If [F:SDD]FOCFLG=3 [F:SPK]FOCITM=2 Else [F:SPK]FOCITM=1 Endif
# 71065 : PJT
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([F:SDD]PJT) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[F:SDH]BPCORD : WBPAADD=[F:SDH]BPAADD
WDBPAADD=WBPAADD                           : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

Return


#----- Chargement environnement tarif en livraison cde ouverte depuis fichier livraison -----#
#      depuis les classes [F] des commandes ( concerne le picking ou auto )
#
$TRTSDD1
[F:SPK] = [F:SOH]
[F:SPK] = [F:SOC]
[F:SPK] = [F:SOQ]
[F:SPK]PNTITMREF = GPNTITMREF
[F:SPK]CPY       = GSOCIETE
# 71065 : PJT
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([F:SOQ]PJT) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[F:SOH]BPCORD : WBPAADD=[F:SOC]BPAADD
WDBPAADD=WBPAADD                           : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

Return


$TRTSIH
#----- Chargement environnement tarif depuis factures -----#
[F:SPK] = [M:SIH0] : # TSCCOD dans ecran SIH0
[F:SPK] = [M:SIH1]
[F:SPK] = [M:SIH2]
[F:SPK] = [M:SIH4]
[F:SPK]STOFCY    = [M:SIH4]DSTOFCY(nolign-1)
[F:SPK]PNTITMREF = GPNTITMREF
For I = 1 To dim([F:SPK]TSICOD)
    If evalue("dim([M:SIH4]TSICOD"+num$(I)+"(nolign-1))")>0
       [F:SPK]TSICOD(I-1) = evalue("[M:SIH4]TSICOD"+num$(I)+"(nolign-1)")
    Endif
Next I
#   pour recherche interdit la classe M n'est pas garnie on charge a partir de l article
If vireblc(sum([F:SPK]TSICOD),2)=""   : # la classe M n'est pas garnie si recherche interdit
  For I=1 To dim([F:SPK]TSICOD)
    If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
  Next I
Endif

[F:SPK]CPY       = GSOCIETE
If [M:SIH4]FOCFLG(nolign-1)=3 [F:SPK]FOCITM=2 Else [F:SPK]FOCITM=1 Endif
# 71065 : PJT
[F:SPK]PJT = [M:SIH4]DPJT(nolign-1)
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SIH4]DPJT(nolign-1)) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[M:SIH1]BPCORD : WBPAADD=[M:SIH1]BPAADD
WDBPAADD=WBPAADD                           : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

Return


$TRTSPSI
#----- Chargement environnement tarif depuis simulation -----#
For I=1 To dim([F:SPK]TSCCOD)
  If dim([F:BPC]TSCCOD) >= I : [F:SPK]TSCCOD(I-1) = [F:BPC]TSCCOD(I-1) : Endif
Next I
For I=1 To dim([F:SPK]TSICOD)
  If dim([F:ITM]TSICOD) >= I : [F:SPK]TSICOD(I-1) = [F:ITM]TSICOD(I-1) : Endif
Next I
[F:SPK] = [M:SPSI]
[F:SPK]CPY       = GSOCIETE
[F:SPK]FOCITM    = 1

Return

#----- Chargement environnement tarif depuis les transferts inter-société -----#
$TRTSCS
[F:SPK] = [M:SCS1]
[F:SPK]BPCINV=[F:BPC]BPCINV
[F:SPK]BPCGRU=[F:BPC]BPCGRU
# Initialisation du code condition de paiement
Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [F:SPK]PTE) From TRTX3

For I=1 To dim([F:BPC]TSCCOD)
    [F:SPK]TSCCOD(I-1)=[F:BPC]TSCCOD(I-1)
Next I
For I=1 To dim([F:ITM]TSICOD)
    [F:SPK]TSICOD(I-1)=[F:ITM]TSICOD(I-1)
Next I
[F:SPK]CPY=GSOCIETE
# 71065 : PJT
[F:SPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([F:SPK]PJT) : # Code affaire seul
# 71065 : PJT

# 79705 : V7 : SAT in SPRICLINK
Gosub DECLARE_CRY_SAT
WBPCORD=[F:BPC]BPCNUM : WBPAADD=[M:SCS1]FCYADD
WDBPAADD=WBPAADD                           : # Step2
Gosub CHARGE_CRY_SAT
# 79705 : V7 : SAT in SPRICLINK

Return


# 79705 : V7 : SAT in SPRICLINK
$DECLARE_CRY_SAT
Local Char WBPCORD(GLONBPC), WBPAADD(GLONADR)
Local Char WDBPAADD(GLONADR)                                  : # Step2
Return

$CHARGE_CRY_SAT

# Chargement du code pays :
# --> A partir de l'écran adresse de livraison ADB2 s'il est chargé
# --> A partir de l'adresse du client livré sinon chargé dans ADB2
#If dim([M:ADB2]CRY) > 0 & [M:ADB2]CRY<>""                    : # Step2
If dim([M:ADB2]CRY) > 0 & [M:ADB2]CRY<>"" & WDBPAADD=WBPAADD  : # Step2
  [F:SPK]CRY=[M:ADB2]CRY
Else
  If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
  #If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>WBPCORD | [F:BPA]BPAADD<>WBPAADD : # Step2
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>WBPCORD | [F:BPA]BPAADD<>WDBPAADD : # Step2
     #Read [BPA]BPA0=1;WBPCORD;WBPAADD                                   : # Step2
     Read [BPA]BPA0=1;WBPCORD;WDBPAADD                                   : # Step2
    If fstat  Raz [F:BPA] : Endif
  Endif
  [F:SPK]CRY=[F:BPA]CRY
Endif

# Chargement du code état :
# --> A partir de l'écran adresse de livraison ADB2 s'il est chargé
# --> A partir de l'adresse du client livré sinon chargé dans ADB2
#If dim([M:ADB2]SAT) > 0 & [M:ADB2]SAT<>""                    : # Step2
If dim([M:ADB2]SAT) > 0 & [M:ADB2]SAT<>"" & WDBPAADD=WBPAADD  : # Step2
  [F:SPK]SAT=[M:ADB2]SAT
Else
  If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
  #If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>WBPCORD | [F:BPA]BPAADD<>WBPAADD : # Step2
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>WBPCORD | [F:BPA]BPAADD<>WDBPAADD : # Step2
     #Read [BPA]BPA0=1;WBPCORD;WBPAADD                                   : # Step2
     Read [BPA]BPA0=1;WBPCORD;WDBPAADD                                   : # Step2
    If fstat  Raz [F:BPA] : Endif
  Endif
  [F:SPK]SAT=[F:BPA]SAT
Endif

Return
# 79705 : V7 : SAT in SPRICLINK

#----- Chargement environnement tarif depuis demandes d'achat -----#
$TRTPSH
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[M:PSH0] : [F:PPK]=[M:PSH1] : [F:PPK]UOM=[M:PSH1]PUU(nolign-1)
# Issue 80455 - 2012-03-01 by MUARN : site non renseigné
[F:PPK]POHFCY=[M:PSH0]PSHFCY
# Initialisation du code condition de paiement
Call INIPTE ([F:BPS]BPRPAY, [F:BPS]BPSINV, "F", [F:PPK]PTE) From TRTX3

For I=1 To dim([F:BPS]TSSCOD)
    [F:PPK]TSSCOD(I-1)=[F:BPS]TSSCOD(I-1)
Next I
For I=1 To dim([F:ITM]TSICOD)
    [F:PPK]TSICOD(I-1)=[F:ITM]TSICOD(I-1)
Next I
[F:PPK]CPY=GSOCIETE

# Issue 71069 - 2016-05-18 by MUARN : PJT
[F:PPK]PJT    = [M:PSH1]PJT(nolign-1)
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:PSH1]PJT(nolign-1)) : # Code affaire seul
# End issue 71069

Return


#----- Chargement environnement tarif depuis gestion auto demandes d'achat -----#
$TRTPSM
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[F:PSD] : [F:PPK]UOM=[F:PSD]PUU
[F:PPK]CPY=GSOCIETE
Return


#----- Chargement environnement tarif depuis commandes standards -----#
$TRTPOH
[F:PPK]PURTYP=1
[F:PPK]POHTYP=1
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[M:POH0] : [F:PPK]=[M:POH1] : [F:PPK]=[M:POH2]
# Issue X3-82137 - 2018-03-22 by SR : Récupérer l'Incoterm de la commande (noms différents)
[F:PPK]EECICT = [M:POH1]EECICT2
If dim([F:PPK]MFGITM)>0             # Champ destiné à disparaître ?
   [F:PPK]MFGITM=[M:POH2]ITMREFORI(nolign-1)
Endif
If dim([F:PPK]OPENUM)>0             # Champ destiné à disparaître ?
   [F:PPK]OPENUM=[M:POH2]VCRLINORI(nolign-1)
Endif
If dim([F:PPK]ITMREFORI)>0          # V6
   [F:PPK]ITMREFORI=[M:POH2]ITMREFORI(nolign-1)
Endif
If dim([F:PPK]VCRLINORI)>0          # V6
   [F:PPK]VCRLINORI=[M:POH2]VCRLINORI(nolign-1)
Endif
If clalev([M:AD61])
  If [M:AD61]BPAADD<>"" [F:PPK]BPAADD=[M:AD61]BPAADD : Endif
Endif
For I = 1 To 5
    If evalue("dim([M:POH2]TSICOD"+num$(I)+"(nolign-1))")>0
       [F:PPK]TSICOD(I-1) = evalue("[M:POH2]TSICOD"+num$(I)+"(nolign-1)")
    Endif
Next I
[F:PPK]CPY=GSOCIETE

# Issue 71069 - 2016-01-29 by SR : PJT
[F:PPK]PJT    = [M:POH2]PJT(nolign-1)
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:POH2]PJT(nolign-1)) : # Code affaire seul
# End issue 71069

Return


#----- Chargement environnement tarif depuis gestion auto cdes standards -----#
$TRTPOM
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[F:POH] : [F:PPK]=[F:POQ] : [F:PPK]=[F:POP]
If dim([F:PPK]MFGITM)>0             # Champ destiné à disparaître ?
   [F:PPK]MFGITM=[F:POQ]ITMREFORI
Endif
If dim([F:PPK]OPENUM)>0             # Champ destiné à disparaître ?
   [F:PPK]OPENUM=[F:POQ]VCRLINORI
Endif
If dim([F:PPK]ITMREFORI)>0          # V6
   [F:PPK]ITMREFORI=[F:POQ]ITMREFORI
Endif
If dim([F:PPK]VCRLINORI)>0          # V6
   [F:PPK]VCRLINORI=[F:POQ]VCRLINORI
Endif
[F:PPK]CPY=GSOCIETE
# Issue 71069 - 2016-01-29 by SR : PJT
[F:PPK]PJT    = [F:POP]PJT
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([F:POP]PJT) : # Code affaire seul
# End issue 71069
Return


#----- Chargement environnement tarif depuis commandes / article -----#
$TRTPOI
[F:PPK]PURTYP=1
[F:PPK]POHTYP=1
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
If [M:POI1]SOHNUM(nolign-1)<>""
  If clalev([F:SOH])  [F:PPK]=[F:SOH] : Endif
  If clalev([F:SOP])  [F:PPK]=[F:SOP] : Endif
  If clalev([F:SOQ])  [F:PPK]=[F:SOQ] : Endif
Endif
[F:PPK]=[M:POI1]
[F:PPK]CPY=GSOCIETE
# ISSUE 71069 - 2016-01-29 By SR : PJT
[F:PPK]PJT    = [M:POI1]PJT(nolign-1)
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:POI1]PJT(nolign-1)) : # Code affaire seul
# End issue 71069
# Issue X3-77905 - 2018-02-28 by MUARN : incoterm/mode de livraison perdus avec transclasse vente
[F:PPK]EECICT = [F:BPS]EECICT
[F:PPK]MDL    = [F:BPS]MDL
Return


#----- Chargement environnement tarif depuis commandes ouvertes -----#
$TRTPOC
[F:PPK]PURTYP=1
[F:PPK]POHTYP=2
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[M:POC0] : [F:PPK]=[M:POC1] : [F:PPK]=[M:POC2]
If clalev([M:AD63])
  If [M:AD63]BPAADD<>"" [F:PPK]BPAADD=[M:AD63]BPAADD : Endif
Endif
[F:PPK]CPY=GSOCIETE
# Issue 71069 - 2016-01-29 by SR : PJT
[F:PPK]PJT    = [M:POC2]PJT
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:POC2]PJT) : # Code affaire seul
# End issue 71069
Return


#----- Chargement environnement tarif depuis demandes livraison -----#
# attention chargement a partir des fichiers                    -----#
$TRTPOD
[F:PPK]PURTYP=1
[F:PPK]POHTYP=2
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[F:POH] : [F:PPK]=[F:POC] : [F:PPK]=[F:POQ]
[F:PPK]CPY=GSOCIETE
