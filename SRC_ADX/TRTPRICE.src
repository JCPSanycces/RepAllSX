#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
#  TRTPRICE                                                             #
#      TRAITEMENTS LIES aux PRIX ACHAT/VENTE                            #
#                                                                       #
#########################################################################
#                                                                       #
#-----------------------------------------------------------------------#
# Traitements e_commerce                                                #
#-----------------------------------------------------------------------#
# ACTIONS                                                               #
# ------------------                                                    #
# Affichages divers                                                     #
# ------------------                                                    #
# ALIREN    : Alimentation de la designation du modif                   #
# CTLREN    : Contrôle motifs tarif obligatoires                        #
# INIREN    : Definition bouton motif en as_ prix et remises Achat/vente#
# DIVREN    : As_ prix et remises Achat/Vente pour positionner mkstat   #
# LECREN    : Lecture des motifs pour récupération désignation          #
# ------------------                                                    #
# Fenêtres de saisie                                                    #
# ------------------                                                    #
# SAIPURREN : Saisie des motifs tarif achat                             #
# SAIREN    : Saisie des motifs tarif Vente                             #
# VISUCLCPRI: Visu de l'explication du calcul de prix                   #
# ------------------------                                              #
# Selection dans une table                                              #
# ------------------------                                              #
# SELREN    : Sélection des motifs tarif Achat/Vente                    #
# SELSTCCPY : Sélection des sociétés de même structure Achat/Vente      #
# ------------------------                                              #
# Selection dans une liste                                              #
# ------------------------                                              #
# SELLPFIL  : Sélection des fichiers des critères tarif Achat/Vente     #
#                                                                       #
#########################################################################
# Issue 53412 - 20171019 by LD : Discount reason changed and but not saved

$ACTION
#--- Actions liés au type traitement et affichage divers
Case ACTION
 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
#--- Actions liés au type fenetres de saisie
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "ABA"         : Gosub ABA
 When "OK"          : Gosub OK
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FIN"         : Gosub FIN
 When "FINSAI"      : Gosub FINSAI
Endcase
#--- Actions liés au type sélection dans une table
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
#--- Actions liés au type sélection dans une liste
Case ACTION
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$TRT_DIV
Case TRAIT
 When "ALIREN"     : Gosub A_REN
 When "CTLREN"     : Gosub C_REN
 When "DIVREN"     : Gosub D_REN
 When "INIREN"     : Gosub I_REN
 When "LECREN"     : Gosub L_REN
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Case GACTION
 When "SAIPURREN"   : Gosub OUV_SAIPURREN
 When "SAIREN"      : Gosub OUVRE_SAIREN
 When "VISUCLCPRI"  : Gosub OUVRE_VISUCLCPRI
Endcase
Return

$DEBUT
Case GACTION
 When "SAIPURREN"   : Gosub DEB_SAIPURREN
 When "SAIREN"      : Gosub DEB_SAIREN
                      Affzo [M]1-99
 When "VISUCLCPRI"  : Gosub DEB_VISUCLCPRI
Endcase
Return

$ABA
Case GACTION
 When "SAIPURREN"   : Gosub ABA_SAIPURREN
 When "SAIREN"      : Gosub ABA_SAIREN
Endcase
Return

$OK
Case GACTION
 When "SAIPURREN"   : Gosub OK_SAIPURREN
 When "SAIREN"      : Gosub OK_SAIREN
Endcase
Return

$APRES_MODIF
Case GACTION
 When "SAIPURREN"   : REP="M"
 When "SAIREN"      : REP="M"
Endcase
Return

$FIN
Case GACTION
 When "SAIREN"      : Gosub FIN_SAIREN
 When "VISUCLCPRI"  : Gosub FIN_VISUCLCPRI
Endcase
Return

$FINSAI
Case GACTION
 When "SAIPURREN"   : Gosub FINSAI_SAIPURREN
Endcase
Return

#########################################################################
#    Actions liés au type sélection dans une table                      #
#########################################################################
$SEL_TABLE
Case TABLE
    When "SELREN"    : Gosub S_REN
    When "SELSTCCPY" : Gosub S_STCCPY
Endcase
Return

#########################################################################
#    Actions liés au type sélection dans une liste                      #
#########################################################################
$SEL_LISTE
Case LISTE
    When "SELLPFIL" : Gosub SL_PFIL
Endcase
Return

#########################################################################
#   Action ALIREN : lecture des motifs tarif pour affichage désignation #
#########################################################################
$A_REN
Local Integer MOTIF  : MOTIF  = VALEUR
Local Integer MODULE : MODULE = val(PARAM(1))
#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6  Return  Endif
#----- Lecture des motifs si nécessaire -----#
If MODULE=5
   If [F:SPR]PRIREN<>MOTIF
      Read [SPR] SPR0=MOTIF : If fstat Raz [F:SPR] : Endif
   Endif
   #-- 80866 Performance Import --#
   If !GIMPORT : Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,PARAM(2)) From TRTX3TEX : Endif
   #Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,PARAM(2)) From TRTX3TEX
Endif
If MODULE=6
   If [F:PPR]PRIREN<>MOTIF
      Read [PPR] PPR0=MOTIF : If fstat Raz [F:PPR] : Endif
   Endif
   #-- 80866 Performance Import --#
   If !GIMPORT : Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,PARAM(2)) From TRTX3TEX : Endif
   #Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,PARAM(2)) From TRTX3TEX
Endif
Return

#########################################################################
#    Action CTLREN : Contrôle motifs tarif obligatoires                 #
#########################################################################
$C_REN
Local Integer MODULE    : MODULE = val(PARAM(1))
Local Integer OLDREN    : OLDREN = val(PARAM(2))
Local Decimal VALDCB    : VALDCB = val(PARAM(3)) : # valeur du prix ou remise
#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6 Return : Endif
#----- En import on considere que le prix ou la remise est <>0
If GIMPORT : VALDCB=1 : Endif
#----- Si valeur de la colonne nulle alors motif non nécessaire -----#
If VALDCB=0 & VALEUR=0 Return : Endif
#----- Test si motif obligatoire -----#
Local Char CLE(2) : CLE=num$(VALEUR)
If MODULE=5
   If GSALREN=2 & VALEUR=0 & VALDCB<>0
      If GIMPORT
         VALAEUR=GDACMANSAL
      Else
         GMESSAGE=mess(86,199,1) : mkstat=1 : Return
      Endif
   Endif
   If VALEUR<>0
      If VALEUR<>OLDREN Call CONTROLE("SPR","A",CLE,"",mkstat) From CONTOBJ
                   Else Call CONTROLE("SPR","" ,CLE,"",mkstat) From CONTOBJ
      Endif
   Endif
Endif
If MODULE=6
   If GPURREN=2 & VALEUR =0 & VALDCB<>0
                    GMESSAGE=mess(86,199,1) : mkstat=1 : Return : Endif
   If VALEUR <>0
      If VALEUR<>OLDREN Call CONTROLE("PPR","A",CLE,"",mkstat) From CONTOBJ
                   Else Call CONTROLE("PPR","" ,CLE,"",mkstat) From CONTOBJ
      Endif
   Endif
Endif

Return
#########################################################################
#    Action INIREN : positionnement bouton motifs prix/remises tarif    #
#########################################################################
$I_REN
Local Char    WABMSK   :    WABMSK = PARAM(1)
Local Integer MODULE   :    MODULE = val(PARAM(2))
Local Integer NOLIG    :    NOLIG  = val(PARAM(3))
Local Char    AZC      :    AZC    = PARAM(4)
Local Integer MOTIF

#Raz GBOUT2
#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6  Return  Endif
#----- Chargement du numéro de motif concerné -----#
Case AZC
  When "GROPRI"     : MOTIF=evalue("[M:"+WABMSK+"]PRIREN(NOLIG)")
  When "DISCRGVAL1" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN1(NOLIG)")
  When "DISCRGVAL2" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN2(NOLIG)")
  When "DISCRGVAL3" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN3(NOLIG)")
  When "DISCRGVAL4" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN4(NOLIG)")
  When "DISCRGVAL5" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN5(NOLIG)")
  When "DISCRGVAL6" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN6(NOLIG)")
  When "DISCRGVAL7" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN7(NOLIG)")
  When "DISCRGVAL8" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN8(NOLIG)")
  When "DISCRGVAL9" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN9(NOLIG)")
Endcase
#----- Ouverture, lecture fichier des motifs et test modif prix -----#
If MODULE=5
   If clalev ([F:SPR])<=0 Local File SPREASON [SPR] : Endif
   Read [SPR] SPR0=MOTIF
   If fstat
     Raz [F:SPR]
   Elsif [F:SPR]UPDPRI<>2
     Raz GBOUT2
   Endif
Endif
If MODULE=6
   If clalev ([F:PPR])<=0 Local File PPREASON [PPR] : Endif
   Read [PPR] PPR0=MOTIF
   If fstat
     Raz [F:PPR]
   Elsif [F:PPR]UPDPRI<>2
     Raz GBOUT2
   Endif
Endif

Return
#########################################################################
#    Action DIVREN : avant saisie des motifs prix/remises tarif         #
#########################################################################
$D_REN
Local Char    WABMSK   :    WABMSK = PARAM(1)
Local Integer MODULE   :    MODULE = val(PARAM(2))
Local Integer NOLIG    :    NOLIG  = val(PARAM(3))
Local Char    AZC      :    AZC    = PARAM(4)
Local Integer MOTIF

#Raz GBOUT2
#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6  Return  Endif
#----- Chargement du numéro de motif concerné -----#
Case AZC
  When "GROPRI"     : MOTIF=evalue("[M:"+WABMSK+"]PRIREN(NOLIG)")
  When "DISCRGVAL1" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN1(NOLIG)")
  When "DISCRGVAL2" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN2(NOLIG)")
  When "DISCRGVAL3" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN3(NOLIG)")
  When "DISCRGVAL4" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN4(NOLIG)")
  When "DISCRGVAL5" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN5(NOLIG)")
  When "DISCRGVAL6" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN6(NOLIG)")
  When "DISCRGVAL7" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN7(NOLIG)")
  When "DISCRGVAL8" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN8(NOLIG)")
  When "DISCRGVAL9" : MOTIF=evalue("[M:"+WABMSK+"]DISCRGREN9(NOLIG)")
Endcase
#----- Ouverture, lecture fichier des motifs et test modif prix -----#
If MODULE=5
   # X3-69134 : Performance enhancements for sales order import / X3-74049  : Restricted prices (LD:05/29/18)
   If MOTIF=0 : Return : Endif
   # X3-69134 : Performance enhancements for sales order import / X3-74049  : Restricted prices (LD:05/29/18)
   If clalev ([F:SPR])<=0 Local File SPREASON [SPR] : Endif
   # X3-69134 : Performance enhancements for sales order import / X3-74049  : Restricted prices (LD:05/29/18)
   If [F:SPR]PRIREN<>MOTIF
   # X3-69134 : Performance enhancements for sales order import / X3-74049  : Restricted prices (LD:05/29/18)
     Read [SPR] SPR0=MOTIF
     If fstat Raz [F:SPR] : Endif
   # X3-69134 : Performance enhancements for sales order import / X3-74049  : Restricted prices (LD:05/29/18)
   Endif
   # X3-69134 : Performance enhancements for sales order import / X3-74049  : Restricted prices (LD:05/29/18)
   If [F:SPR]UPDPRI=1 mkstat=2 : Endif
Endif
If MODULE=6
   If clalev ([F:PPR])<=0 Local File PPREASON [PPR] : Endif
   Read [PPR] PPR0=MOTIF
   If fstat Raz [F:PPR] : Endif
   If [F:PPR]UPDPRI=1 mkstat=2 : Endif
Endif

Return
#########################################################################
#   Action LECREN : lecture des motifs tarif pour affichage désignation #
#########################################################################
$L_REN

Local Integer MOTIF    :    MOTIF  = val(PARAM(1))
Local Integer MODULE   :    MODULE = val(PARAM(2))
#----- Contrôle validité du code module -----#
If MODULE<5 | MODULE>6  Return  Endif
#----- Lecture des motifs si nécessaire -----#
If MODULE=5
   If [F:SPR]PRIREN<>MOTIF
      Read [SPR] SPR0=MOTIF : If fstat Raz [SPR] : Endif
   Endif
   #-- 80866 Performance Import --#
   If !GIMPORT : Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,VALEUR) From TRTX3TEX : Endif
   #Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,VALEUR) From TRTX3TEX
Endif
If MODULE=6
   If [F:PPR]PRIREN<>MOTIF
      Read [PPR] PPR0=MOTIF : If fstat Raz [PPR] : Endif
   Endif
   #-- 80866 Performance Import --#
   If !GIMPORT : Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,VALEUR) From TRTX3TEX : Endif
   #Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,VALEUR) From TRTX3TEX
Endif
Return


###########################################################################
# EXEBUTREN : S/P d'affichage et saisie des motifs tarif     MBT 16/12/97 #
#   WABMSK  : Abréviation du masque écran contenant les lignes            #
#   MODULE  : Code du module à traiter (5=Ventes, 6=Achats)               #
#   NOLIG   : Indice de la ligne active (nolign-1)                        #
# ----------------------------------------------------------------------- #
# Remplacé pour les ventes par l'action SAIREN et            MBT 08/12/00 #
#          pour les achats par l'action SAIPURREN avec paramètres :       #
#   PARAM(1) = ABREV  : Abréviation du masque écran                       #
#   PARAM(2) = NOLIG  : Indice de la ligne active (nolign-1)              #
###########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIPURREN
#----- Variables locales -----#
Local Char     WABMSK       : WABMSK=PARAM(1)
Local Integer  NOLIG        : NOLIG=val(PARAM(2))
Local Shortint I, SAVNOLIGN
SAVNOLIGN=nolign
#-----
If clalev([F:PPR])<=0 Local File PPREASON [PPR] : Endif
Return

#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIPURREN
Local Char DESMOTIF (80)
Raz [M:PREN]
#----- Chargement des valeurs et affichage (foreground) -----#
[M:PREN]GROPRICOD = evalue("[M:"+WABMSK+"]PRIREN(NOLIG)")
[M:PREN]GROPRI    = evalue("[M:"+WABMSK+"]GROPRI(NOLIG)")
If [F:PPR]PRIREN<>[M:PREN]GROPRICOD
  Read [PPR] PPR0=[M:PREN]GROPRICOD : If fstat Raz [PPR] : Endif
Endif

#-- 80866 Performance Import --#
If !GIMPORT : Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,[M:PREN]GROPRIDES) From TRTX3TEX : Endif
#Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,[M:PREN]GROPRIDES) From TRTX3TEX

For I=1 To 9
  If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG))")>0
    Assign "[M:PREN]DISCRGCOD"+num$(I) With
&           evalue("[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG)")
    Assign "[M:PREN]DISCRGVAL"+num$(I) With
&           evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOLIG)")
    If [F:PPR]PRIREN<>evalue("[M:PREN]DISCRGCOD"+num$(I))
      Read [PPR] PPR0=evalue("[M:PREN]DISCRGCOD"+num$(I)) : If fstat Raz [PPR] : Endif
    Endif
    #-- 80866 Performance Import --#
    If !GIMPORT : Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX : Endif
    #Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX
    Assign "[M:PREN]DISCRGDES"+num$(I) With DESMOTIF
    If GCOLREM(I-1)=""
      Case I
        When 1 : Grizo [PREN]DISCRGCOD1
        When 2 : Grizo [PREN]DISCRGCOD2
        When 3 : Grizo [PREN]DISCRGCOD3
        When 4 : Grizo [PREN]DISCRGCOD4
        When 5 : Grizo [PREN]DISCRGCOD5
        When 6 : Grizo [PREN]DISCRGCOD6
        When 7 : Grizo [PREN]DISCRGCOD7
        When 8 : Grizo [PREN]DISCRGCOD8
        When 9 : Grizo [PREN]DISCRGCOD9
      Endcase
    Endif
  Endif
Next I
Affzo [PREN]1-99
Return

#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIPURREN
Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With [M:PREN]GROPRICOD
For I=1 To 9
  If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG))")>0
     Assign "[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG)"
&           With evalue("[M:PREN]DISCRGCOD"+num$(I))
  Endif
Next I
mkstat=4 : FIN=1
Return

#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIPURREN
REP=""
Gosub DEB_SAIPURREN
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIPURREN
nolign=SAVNOLIGN
Return


#########################################################################
#    Action SAIREN : saisie des motifs de tarif vente                   #
#########################################################################
$OUVRE_SAIREN
Local Char    WABMSK   :    WABMSK = PARAM(1)
Local Integer MODULE   :    MODULE = val(PARAM(2))
Local Integer NOLIG    :    NOLIG  = val(PARAM(3))

#----- Variables locales -----#
Local Shortint I
Local Integer  SAVNOLIGN
Local Char     SAVGTRAITE(10)

# Issue X3-53412
Local Decimal WDISCRGVAL : WDISCRGVAL=VALEUR
# End ssue X3-53412

If MODULE = 5
   If clalev ([F:SPR])<=0 Local File SPREASON [SPR] : Endif
Elsif MODULE=6
   If clalev ([F:PPR])<=0 Local File PPREASON [PPR] : Endif
Else
    FIN=1
Endif

SAVNOLIGN=nolign
SAVGTRAITE=GTRAITE

Return

#------------------------------------------------------------------------------#
$DEB_SAIREN
Local Integer MOTIF
Local Char    DESMOTIF (80)

#----- Chargement des valeurs et affichage (foreground) -----#
[M]GROPRICOD = evalue("[M:"+WABMSK+"]PRIREN(NOLIG)")
[M]GROPRI    = evalue("[M:"+WABMSK+"]GROPRI(NOLIG)")
MOTIF = [M]GROPRICOD : Gosub LECRENDES : [M]GROPRIDES = DESMOTIF
For I=1 To 9
    If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG))")>0
       Assign "[M]DISCRGCOD"+num$(I) With
&              evalue("[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG)")
       Assign "[M]DISCRGVAL"+num$(I) With
&              evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOLIG)")
       MOTIF = evalue("[M]DISCRGCOD"+num$(I))
       Gosub LECRENDES
       Assign "[M]DISCRGDES"+num$(I) With DESMOTIF
    Endif
Next I
Return

$LECRENDES
#----- Lecture des motifs si nécessaire -----#
If MODULE=5
   If [F:SPR]PRIREN<>MOTIF
      Read [SPR] SPR0=MOTIF : If fstat Raz [SPR] : Endif
   Endif
   #-- 80866 Performance Import --#
   If !GIMPORT : Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX : Endif
   #Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX
Endif
If MODULE=6
   If [F:PPR]PRIREN<>MOTIF
      Read [PPR] PPR0=MOTIF : If fstat Raz [PPR] : Endif
   Endif
   #-- 80866 Performance Import --#
   If !GIMPORT : Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX : Endif
   #Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX
Endif
Return

#------------------------------------------------------------------------------#
$ABA_SAIREN

[M]GROPRICOD=evalue("[M:"+WABMSK+"]PRIREN(NOLIG)")
For I=1 To 9
    If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG))")>0
        Assign "[M]DISCRGCOD"+num$(I) With
&               evalue("[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG)")
    Endif
Next I

GNBAFF = 99
REP = ""
Affzo

#Gosub AFF From GSAISIE

Return

#------------------------------------------------------------------------------#
$OK_SAIREN

Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With [M]GROPRICOD
For I=1 To 9
    If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG))")>0

       # Issue X3-53412
       Local Integer WDISCRGREN, WDISCRGCOD
       WDISCRGREN=evalue ("[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG)")
       WDISCRGCOD=evalue("[M]DISCRGCOD"+num$(I))

       If WDISCRGREN <> WDISCRGCOD
       # The code reason has been modified manually,
       # --> we charged [M]DISCRGVAL with the new value, no to initialize the code reason with the manual code reason (done in AM_DISCRGVAL if it has been changed)
            Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOLIG)" With WDISCRGVAL
       Endif
       # End issue X3-53412

       Assign "[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOLIG)"
&             With evalue("[M]DISCRGCOD"+num$(I))
    Endif
Next I
mkstat=4
FIN=1

Return

#------------------------------------------------------------------------------#
$FIN_SAIREN

nolign=SAVNOLIGN
GTRAITE=SAVGTRAITE

Return

################################################################################
# VISUCLCPRI : Visu de l'explication du calcul de prix                         #
################################################################################
$OUVRE_VISUCLCPRI
Local Char    ORI     : ORI = PARAM(1)
Local Char    CUR     : CUR=PARAM(2)
Local Integer NLIG    : NLIG = val(PARAM(3))
Local Integer PARTNER : PARTNER = val(PARAM(4))

Local Integer I
Local Integer COD
Local Char    STRUCTURE
Local Decimal BRUT
Local Decimal MAJREM (0..8)
Local Decimal QTE
Local Decimal NET
Local Integer REN (0..10)
Local Char    PLI (6) (0..10)
Local Char    LIB (70) (0..30)

Case PARTNER
    When 1   :
        COD      = 1          : # affichage du masque
        PARTNER  = 1          : # client
#        STRUCTURE= ""         : # toujours standard pour clients
        STRUCTURE=[M]PLISTC   : # Structure tarif document
        BRUT     = [M]GROPRI(NLIG)
        For I=1 To 9
          If evalue("dim([M]DISCRGVAL"+num$(I)+")") > 0
            MAJREM(I-1)=evalue("[M]DISCRGVAL"+num$(I)+"(NLIG)")
          Endif
        Next I
        QTE      = [M]QTY(NLIG)
        NET      = [M]NETPRI(NLIG)
        REN(0)   = [M]PRIREN(NLIG)
        For I=1 To 9
          If evalue("dim([M]DISCRGREN"+num$(I)+")") > 0
            REN(I)=evalue("[M]DISCRGREN"+num$(I)+"(NLIG)")
          Endif
        Next I

        Gosub DEB_CALNETLIB
    When 2   :
        #----- Chargement des valeurs -----#
        COD      = 1          : # Affichage du masque
        PARTNER  = 2          : # Fournisseur
        STRUCTURE= GPLISTC    : # Structure tarif du fournisseur
        #----- Traitement suivant la valeur du code -----#
        Case ORI
         When "PSH"  : Gosub EXPPSH
         When "POH"  : Gosub EXPPOH
         When "POI"  : Gosub EXPPOI
         When "POC"  : Gosub EXPPOC
         When "PTH"  : Gosub EXPPTH
         When "PNH"  : Gosub EXPPNH
         When "PSCM" : Gosub EXPPSCM
         When "PSCS" : Gosub EXPPSCS
        Endcase
        Gosub DEB_CALNETLIB
Endcase
Return
#########################################################################
#---------------------------------------------------#
# Explication du prix à partir des demandes d'achat #
#---------------------------------------------------#
$EXPPSH
BRUT = [M:PSH1]GROPRI(NLIG)
For I=1 To 9
  If evalue("dim([M:PSH1]DISCRGVAL"+num$(I)+")") > 0
    MAJREM(I-1)=evalue("[M:PSH1]DISCRGVAL"+num$(I)+"(NLIG)")
  Endif
Next I
QTE    = [M:PSH1]QTYPUU(NLIG)
NET    = [M:PSH1]NETPRI(NLIG)
REN(0) = [M:PSH1]PRIREN(NLIG)
For I=1 To 9
  If evalue("dim([M:PSH1]DISCRGREN"+num$(I)+")") > 0
    REN(I)=evalue("[M:PSH1]DISCRGREN"+num$(I)+"(NLIG)")
  Endif
Next I
Return

