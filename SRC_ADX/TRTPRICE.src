#--- Issue 110325
#----- Chargement environnement tarif depuis les expéditions -----#
# Utilisé pour les formules dans les structures de coût
$TRTSHP
[F:PPK]PURTYP=1
[F:PPK]POHTYP=1
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[M:SHIP1]
[F:PPK]PRHFCY=[M:SHIP2]FCY
[F:PPK]CPY=GSOCIETE
# Issue 71069 - 2016-01-29 by SR : PJT
If !clalev([F:POP]) : Local File PORDERP [POP] : Endif
Read [F:POP]POP0 = [M:SHIP1]POHNUM(nolign-1);[M:SHIP1]POPLIN(nolign-1);1
If !fstat
  [F:PPK]PJT    = [F:POP]PJT
  [F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([F:POP]PJT) : # Code affaire seul
Endif
# End issue 71069
Return

##################################
#----- Complément de constitution de [F:SPK] et [F:PPK]
$ALIPLK_COMP
If clalev([F:SPK])
#      gestion du type de ligne
  If find([F:SPK]LINTYP,1,2,6,10)             : [F:SPK]LINTYP_A=1 : Endif : # normal/compose
  If find([F:SPK]LINTYP,3,4,5,7,8,9,11,12,13) : [F:SPK]LINTYP_A=2 : Endif : # composant/option/variante
  If [F:SPK]LINTYP=1                          : [F:SPK]LINTYP_B=1 : Endif : # normal
  If find([F:SPK]LINTYP,2,3,4,5,10,11,12,13)  : [F:SPK]LINTYP_B=2 : Endif : # ligne de kit/sous-traité
  If find([F:SPK]LINTYP,6,7,8,9)              : [F:SPK]LINTYP_B=3 : Endif : # ligne de nomenclature
  If find([F:SPK]LINTYP,3,7,11,12,13)         : [F:SPK]LINTYP_C=1 : Endif : # composant
  If find([F:SPK]LINTYP,4,8)                  : [F:SPK]LINTYP_C=2 : Endif : # option
  If find([F:SPK]LINTYP,5,9)                  : [F:SPK]LINTYP_C=3 : Endif : # variante
Endif

Return

#########################################################################
# Subprog TRANSPORT : Calcul des frais de port (tarifs transporteurs)   #
#-----------------------------------------------------------------------#
# Transporteur                                                          #
# Client  (pour les conditions : franco, facturé, ou le seuil utilisé)  #
# Site d'expédition                                                     #
# Pays, Ville, Code postal de destination                               #
# Devise, Type de cours, Date du cours                                  #
# Montant HT (utilisé pour test du seuil)                               #
# Unité de poids, Poids                                                 #
# Unité de volume, Volume (pour calcul du poids volumique)              #
#-----------------------------------------------------------------------#
# Retour                                                                #
# Région de tarification (si tarif par régions)                         #
# Montant des frais (dans la devise demandée)                           #
# Code retour (si aucun frais)                                          #
#   1 = pas de tiers / 2 = pas de transporteur / 3 = tarif inactif      #
#   4 = application du seuil / 5 = franco de port                       #
#########################################################################

Subprog TRANSPORT (BPTNUM,BPCNUM,STOFCY,CRY,POSCTY,POSCOD,CUR,CHGTYP,CHGDAT,AMTNOT,
&                  WEU,GROWEI,VOU,VOL,BPTARE,AMTFRE,FRELIB,STAT)
Value    Char    BPTNUM ()
Value    Char    BPCNUM ()
Value    Char    STOFCY ()
Value    Char    CRY ()
Value    Char    POSCTY ()
Value    Char    POSCOD ()
Value    Char    CUR ()
Value    Integer CHGTYP
Value    Date    CHGDAT
Value    Decimal AMTNOT
Value    Char    WEU ()
Value    Decimal GROWEI
Value    Char    VOU ()
Value    Decimal VOL
Variable Char    BPTARE ()
Variable Decimal AMTFRE
Variable Char    FRELIB () (0..)
Variable Integer STAT

Local Integer WCHGTYP    : # type de cours
Local Date    WCHGDAT    : # date du cours
Local Decimal WAMTNOT    : # montant pour test seuil
Local Decimal WGROWEI    : # poids
Local Decimal WVOL       : # volume (pour calcul poids volumique)
Local Decimal WVOL1      : # volume (pour calcul poids volumique)
Local Char    WPOSCOD    : # code postal (pour recherche de la région)
Local Integer WLEN       : # longueur du code postal (pour recherche de la region)

Local Char    CURBPT     : # devise du transporteur (donc des tarifs)
Local Decimal CURRNDBPT  : # code arrondi de la devise transporteur
Local Integer DECNBRBPT  : # nombre de dec. de devise transporteur
Local Char    FORMAT     : # formatage des montants
Local Char    FORMATV    : # formatage des montants si nb dec. > nb dec. devise transporteur
Local Decimal POIDS_P    : # poids converti en unité poids du tarif
Local Decimal POIDS_V    : # poids volumique converti en unité poids du tarif
Local Decimal POIDS_CPP  : # poids restant pour calcul poids proportionnel
Local Decimal POIDS      : # poids utilisé pour le calcul (le + important)
Local Decimal SEUIL      : # valeur du seuil en fonction paramètre du client
Local Decimal COEF
Local Integer ILIB, IDEC, IJL

Local Char    LIBCONPV (150)        : # si conversion volume -> poids (poids volumique)
Local Char    LIBNCAL  (150)        : # pas de calcul erreur ou seuil
Local Char    LIBFIX   (150)        : # montant fixe
Local Char    LIBFIXR  (150)        : # montant fixe par région
Local Char    LIBPRO1  (150)        : # montant proportionnel
Local Char    LIBPRO2  (150)        : # montant proportionnel (suite)
Local Char    LIBPROR1 (150)        : # montant proportionnel par région
Local Char    LIBPROR2 (150)        : # montant proportionnel par région (suite)
Local Char    LIBCONVD (150)        : # si conversion devise
Local Char    LIBUSER  (150) (0..9) : # libelle libre utilisateur (10 lignes )

WAMTNOT=AMTNOT : WCHGTYP=CHGTYP : WCHGDATE=CHGDAT
WGROWEI=GROWEI : WVOL1=VOL
Raz STAT
Raz LIBCONPV, LIBNCAL, LIBFIX, LIBFIXR, LIBPRO1, LIBPRO2, LIBPROR1, LIBPROR2, LIBCONVD

If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPT])=0 : Local File BPCARRIER  [BPT] : Endif
If clalev([F:CAA])=0 : Local File CARAREA    [CAA] : Endif
If clalev([F:CAP])=0 : Local File CARPRICE   [CAP] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:TCO])=0 : Local File TABCOEFF   [TCO] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif

# ACA (2010-03-10) Bug 63210 : On vérifie si le transporteur est fournit
If [L]BPTNUM=""
  Raz [L]BPTARE : Raz AMTFRE : STAT=1 : End
Endif

#--- lecture du tiers (pour avoir la devise)
If [F:BPR]BPRNUM <> [L]BPTNUM
  Read [BPR]BPR0 = [L]BPTNUM
  If fstat : Raz [L]BPTARE : Raz AMTFRE : STAT=1 : End : Endif
Endif
#--- lecture du transporteur
If [F:BPT]BPTNUM <> [L]BPTNUM
  Read [BPT]BPT0 = [L]BPTNUM
  If fstat : Raz [L]BPTARE : Raz AMTFRE : STAT=2 : End : Endif
Endif
#    si tarif transporteur inactif --> fin
If [F:BPT]PLIFLG<>2
  Raz [L]BPTARE : Raz AMTFRE
  #--CPO 67345 Dde de passage par point d'entrée si pas de tarif
  GPOINT="FREINV1" : Gosub ENTREE From EXEFNC
  #--CPO
  STAT=3 : End
Endif

[L]CURBPT=[F:BPT]CUR
#--- lecture devise transporteur pour arrondi
If [F:TCU]CUR <> [L]CURBPT
  Read [TCU]TCU0 = [L]CURBPT
  If fstat : Raz [L]BPTARE : Raz AMTFRE : STAT=1 : End : Endif
Endif
[L]CURRNDBPT=[F:TCU]CURRND : [L]DECNBRBPT=[F:TCU]DECNBR

FORMAT="N<:11.2#"
If [L]CUR=[L]CURBPT & dim(GDEVFMT1)
  FORMAT="N<:"+GDEVFMT1
Endif

#--- si présence du client on charge le seuil
#    convertir le montant en devise du seuil fournisseur
If [L]BPCNUM<>"" & [F:BPC]BPCNUM <> [L]BPCNUM
   Read [BPC]BPC0 = [L]BPCNUM
Endif

Local Integer WPE_WEIVOL : WPE_WEIVOL=0
# Point d'entrée pour intervenir sur le seuil de calcul du port
#                pour intervenir sur la prise en compte du poids volumétrique
GPOINT="FREINV" : Gosub ENTREE From EXEFNC

Raz LIBNCAL
If [L]BPCNUM<>""
  Case [F:BPC]FREINV
    When 1  : SEUIL = 999999999.99     : # facturé
    When 2  : SEUIL = 0                : # franco pas de calcul
              Raz [L]BPTARE : Raz AMTFRE
              LIBNCAL = mess(159,196,1)
              GPOINT="FREINV1" : Gosub ENTREE From EXEFNC
              Gosub EXPLICATION
              STAT=5 : End
    When 3  : SEUIL = [F:BPT]TSDFRE(0) : # seuil 1
    When 4  : SEUIL = [F:BPT]TSDFRE(1) : # seuil 2
    When 5  : SEUIL = [F:BPT]TSDFRE(2) : # seuil 3
    When 6  : SEUIL = [F:BPT]TSDFRE(3) : # seuil 4
    When 7  : SEUIL = [F:BPT]TSDFRE(4) : # seuil 5
  Endcase

#    il faut faire le test du seuil
  If SEUIL<>0 & WAMTNOT<>0
#   devise du montant différent de celui des seuils
    If [L]CUR<>[L]CURBPT
      If WCHGTYP=0          : WCHGTYP=1     : Endif
      If WCHGDAT=[00/00/00] : WCHGDAT=date$ : Endif
      Call CONVERT([L]CUR,[L]CURBPT,GLOCALDEV,WCHGTYP,WCHGDAT,WAMTNOT,WAMTNOT,GBIDI3) From TRTDEV
    Endif
#   montant supérieur au seuil --> pas de frais de transport
    If WAMTNOT>=SEUIL
#               Port éxonéré : montant supérieur au seuil $1$ $2$
#                 $1$ = valeur du seuil
#                 $2$ = devise du tarif
      LIBNCAL = mess(14,185,1)
      Call DYNAMIC(LIBNCAL,"$1$",format$(FORMAT,SEUIL)) From TEXTE
      Call DYNAMIC(LIBNCAL,"$2$",CURBPT) From TEXTE
      Raz [L]BPTARE : Raz AMTFRE
      GPOINT="FREINV1" : Gosub ENTREE From EXEFNC
      Gosub EXPLICATION
      STAT=4 : End
    Endif
  Endif
Endif

#--- le poids doit être dans unité du transporteur : sinon conversion
If [L]WEU<>[F:BPT]WEU
  Call CALCUL_QTY(WGROWEI,[L]WEU,WGROWEI,[F:BPT]WEU,COEF) From TRTX3
Endif

#--- si volume doit être dans unité du transporteur : sinon conversion
If [L]VOU<>""
  If [L]VOU<>[F:BPT]VOU
    Call CALCUL_QTY(WVOL1,[L]VOU,WVOL1,[F:BPT]VOU,COEF) From TRTX3
  Endif
Else
  WVOL1=0
Endif

#--- on prend le poids le plus grand : poids et éventuel poids volumique
#    si WPE_WEIVOL=1 on prend toujours le poids volumique
#    si absence de poids fin (à voir)
Raz LIBCONPV
If WVOL1<>0 & [F:BPT]COEWEIVOL<>0
  WVOL=WVOL1*[F:BPT]COEWEIVOL
  If WVOL>WGROWEI | WPE_WEIVOL=1
    WGROWEI=WVOL
#              Utilisation du coefficient de correspondance poids volume : $1$ $2$ * $3$ = $4$ $5$
#                $1$ = volume dans l'unité du tarif
#                $2$ = unité de volume du tarif
#                $3$ = coefficient de conversion poids/volume
#                $4$ = poids calculé
#                $5$ = unité de poids du tarif
    LIBCONPV = mess(15,185,1)
    Call DYNAMIC(LIBCONPV,"$1$",num$(WVOL1)) From TEXTE
    Call DYNAMIC(LIBCONPV,"$2$",[F:BPT]VOU) From TEXTE
    Call DYNAMIC(LIBCONPV,"$3$",num$([F:BPT]COEWEIVOL)) From TEXTE
    Call DYNAMIC(LIBCONPV,"$4$",num$(WGROWEI)) From TEXTE
    Call DYNAMIC(LIBCONPV,"$5$",[F:BPT]WEU) From TEXTE
  Endif
Endif

#--- recherche de la région
Raz [L]BPTARE
WPOSCOD=POSCOD
WLEN=len(WPOSCOD)
While WLEN >=0
  Read [F:CAA]CAA1=[L]BPTNUM;STOFCY;[L]CRY;WPOSCOD
  If !fstat
    [L]BPTARE=[F:CAA]BPTARE : Break
  Endif
  If len(WPOSCOD)>0
    WPOSCOD=left$(WPOSCOD,len(WPOSCOD)-1)
  Endif
  WLEN -=1
Wend

#    recherche sans tenir compte du site d'expédition (si non trouvé avant)
If [L]BPTARE=""
  WPOSCOD=POSCOD
  WLEN=len(WPOSCOD)
  While WLEN >=0
    Read [F:CAA]CAA1=[L]BPTNUM;"";[L]CRY;WPOSCOD
    If !fstat
      [L]BPTARE=[F:CAA]BPTARE : Break
    Endif
    If len(WPOSCOD)>0
      WPOSCOD=left$(WPOSCOD,len(WPOSCOD)-1)
    Endif
    WLEN -=1
  Wend
Endif

Raz LIBFIX, LIBFIXR, LIBPRO1, LIBPRO2, LIBPROR1, LIBPROR2

#--- montant fixe
AMTFRE=[F:BPT]FXDAMT
If [F:BPT]FXDAMT<>0
#          Montant fixe = $1$ $2$
#            $1$ = montant
#            $2$ = devise du tarif
  LIBFIX = mess(16,185,1)
  Call DYNAMIC(LIBFIX,"$1$",format$(FORMAT,[F:BPT]FXDAMT)) From TEXTE
  Call DYNAMIC(LIBFIX,"$2$",[L]CURBPT) From TEXTE
Endif
#--- montant proportionnel initial = poids total
POIDS_CPP = WGROWEI

#--- montant par région
Raz [CAP]
Filter [CAP] Where BPTNUM=[L]BPTNUM & BPTARE=[L]BPTARE
&                & [L]WGROWEI>=MINQTY & [L]WGROWEI<=MAXQTY
&            Order By Key CAP2
Read [CAP]CAP2 First
If !fstat
  POIDS_CPP -= [F:CAP]MINQTY
  AMTFRE += [F:CAP]PRI

  If [F:CAP]PRI<>0
#             Montant fixe par région pour un poids de $1$ à $2$ $3$ = $4$ $5$
#               $1$ = borne inférieure de poids (borne comprise)
#               $2$ = borne supérieure de poids (borne comprise)
#               $3$ = unité de poids du tarif
#               $4$ = montant
#               $5$ = devise du tarif
#               $6$ = région (tag non utilisé actuellement dans message)
    LIBFIXR = mess(17,185,1)
    Call DYNAMIC(LIBFIXR,"$1$",num$([F:CAP]MINQTY)) From TEXTE
    Call DYNAMIC(LIBFIXR,"$2$",num$([F:CAP]MAXQTY)) From TEXTE
    Call DYNAMIC(LIBFIXR,"$3$",[F:BPT]WEU) From TEXTE
    Call DYNAMIC(LIBFIXR,"$4$",format$(FORMAT,[F:CAP]PRI)) From TEXTE
    Call DYNAMIC(LIBFIXR,"$5$",[L]CURBPT) From TEXTE
    Call DYNAMIC(LIBFIXR,"$6$",[L]BPTARE) From TEXTE
  Endif

  If [F:CAP]BKT<>0 & [F:CAP]ADL<>0
    NBTRANCHES=(WGROWEI-[F:CAP]MINQTY)/[F:CAP]BKT
    Case [F:CAP]WEIRND
      When 1       : NBTRANCHES=int(NBTRANCHES)
      When 2       : NBTRANCHES=int(NBTRANCHES+0.999999)
      When Default : NBTRANCHES=arr(NBTRANCHES,1)
    Endcase
    AMTFRE += arr([F:CAP]ADL*NBTRANCHES,[L]CURRNDBPT)

    If [F:CAP]ADL*NBTRANCHES <>0

#                Montant proportionnel par région de $1$ * $2$ = $3$ $4$
#                  $1$ = valeur d'une tranche
#                  $2$ = nombre de tranches
#                  $3$ = montant
#                  $4$ = devise du tarif
#                  $5$ = région (tag non utilisé actuellement dans message)

      FORMATV=FORMAT
      IDEC = len(num$(abs([F:CAP]ADL-fix([F:CAP]ADL))))-2
      If IDEC>[L]DECNBRBPT : FORMATV="N<:11."+num$(IDEC)+"#" : Endif
      LIBPROR1 = mess(19,185,1)
      Call DYNAMIC(LIBPROR1,"$1$",format$(FORMATV,[F:CAP]ADL)) From TEXTE
      Call DYNAMIC(LIBPROR1,"$2$",num$(NBTRANCHES)) From TEXTE
      Call DYNAMIC(LIBPROR1,"$3$",format$(FORMAT,arr([F:CAP]ADL*NBTRANCHES,[L]CURRNDBPT))) From TEXTE
      Call DYNAMIC(LIBPROR1,"$4$",[L]CURBPT) From TEXTE
      Call DYNAMIC(LIBPROR1,"$5$",[L]BPTARE) From TEXTE

      If WGROWEI-[F:CAP]MINQTY = [F:CAP]BKT*NBTRANCHES : # pas d'arrondi nombre de tranches

        If [F:CAP]MINQTY = 0                           : # pas de borne inférieure

#                    (poids retenu $1$ $2$ soit $3$ tranches de $4$ $2$)
#                      $1$ = poids
#                      $2$ = unité de poids du tarif
#                      $3$ = nombre de tranches
#                      $4$ = poids d'une tranche

          LIBPROR2="   "+mess(21,185,1)
          Call DYNAMIC(LIBPROR2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$2$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPROR2,"$3$",num$(NBTRANCHES)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$4$",num$([F:CAP]BKT)) From TEXTE

        Else                                           : # il y a une borne inférieure

#                    (poids retenu: $1$ - $2$ = $3$ $4$ soit $5$ tranches de $6$ $4$)
#                      $1$ = poids
#                      $2$ = borne inférieure de poids (borne comprise)
#                      $3$ = poids calculé
#                      $4$ = unité de poids du tarif
#                      $5$ = nombre de tranches
#                      $6$ = poids d'une tranche

          LIBPROR2="   "+mess(20,185,1)
          Call DYNAMIC(LIBPROR2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$2$",num$([F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$3$",num$(WGROWEI-[F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$4$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPROR2,"$5$",num$(NBTRANCHES)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$6$",num$([F:CAP]BKT)) From TEXTE

        Endif

      Else                                             : # arrondi nombre de tranches

        If [F:CAP]MINQTY = 0                           : # pas de borne inférieure

#                (poids retenu: $1$ $2$ arrondi à la $3$ de $4$ $2$ soit $5$ tranches)
#                  $1$ = poids
#                  $2$ = unité de poids du tarif
#                  $3$ = type d'arrondi: menu local 238 (1=tranche< 2=tranche> 3=tranche la +proche)
#                  $4$ = poids d'une tranche
#                  $5$ = nombre de tranches

          LIBPROR2="   "+mess(23,185,1)
          Call DYNAMIC(LIBPROR2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$2$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPROR2,"$3$",mess([F:CAP]WEIRND,238,1)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$4$",num$([F:CAP]BKT)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$5$",num$(NBTRANCHES)) From TEXTE

        Else                                           : # il y a une borne inférieure

#                (poids retenu: $1$ - $2$ = $3$ $4$ arrondi à la $5$ de $6$ $4$ soit $7$ tranches)
#                  $1$ = poids
#                  $2$ = borne inférieure de poids (borne comprise)
#                  $3$ = poids calculé
#                  $4$ = unité de poids du tarif
#                  $5$ = type d'arrondi: menu local 238 (1=tranche< 2=tranche> 3=tranche la +proche)
#                  $6$ = poids d'une tranche
#                  $7$ = nombre de tranches

          LIBPROR2="   "+mess(22,185,1)
          Call DYNAMIC(LIBPROR2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$2$",num$([F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$3$",num$(WGROWEI-[F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$4$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPROR2,"$5$",mess([F:CAP]WEIRND,238,1)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$6$",num$([F:CAP]BKT)) From TEXTE
          Call DYNAMIC(LIBPROR2,"$7$",num$(NBTRANCHES)) From TEXTE

        Endif
      Endif
    Endif
  Endif
Endif
Filter [CAP]

#--- montant proportionnel

If [F:BPT]BKT<>0 & [F:BPT]ADL<>0
  NBTRANCHES=POIDS_CPP/[F:BPT]BKT
#   arrondi : 1=tranche < / 2=tranche > / 3=tranche la + proche
  Case [F:BPT]WEIRND
    When 1       : NBTRANCHES=int(NBTRANCHES)
    When 2       : NBTRANCHES=int(NBTRANCHES+0.999999)
    When Default : NBTRANCHES=arr(NBTRANCHES,1)
  Endcase
  AMTFRE += arr([F:BPT]ADL*NBTRANCHES,[L]CURRNDBPT)

    If [F:BPT]ADL*NBTRANCHES <>0

#                Montant proportionnel de $1$ * $2$ = $3$ $4$
#                  $1$ = valeur d'une tranche
#                  $2$ = nombre de tranches
#                  $3$ = montant
#                  $4$ = devise du tarif

      FORMATV=FORMAT
      IDEC= len(num$(abs([F:BPT]ADL-fix([F:BPT]ADL))))-2
      If IDEC>[L]DECNBRBPT : FORMATV="N<:11."+num$(IDEC)+"#" : Endif
      LIBPRO1 = mess(18,185,1)
      Call DYNAMIC(LIBPRO1,"$1$",format$(FORMATV,[F:BPT]ADL)) From TEXTE
      Call DYNAMIC(LIBPRO1,"$2$",num$(NBTRANCHES)) From TEXTE
      Call DYNAMIC(LIBPRO1,"$3$",format$(FORMAT,arr([F:BPT]ADL*NBTRANCHES,[L]CURRNDBPT))) From TEXTE
      Call DYNAMIC(LIBPRO1,"$4$",CURBPT) From TEXTE

      If WGROWEI - [F:CAP]MINQTY = [F:BPT]BKT*NBTRANCHES : # pas d'arrondi nombre de tranches

        If [F:CAP]MINQTY = 0                             : # pas de borne inférieure

#                    (poids retenu $1$ $2$ soit $3$ tranches de $4$ $2$)
#                      $1$ = poids
#                      $2$ = unité de poids du tarif
#                      $3$ = nombre de tranches
#                      $4$ = poids d'une tranche

          LIBPRO2="   "+mess(21,185,1)
          Call DYNAMIC(LIBPRO2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$2$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPRO2,"$3$",num$(NBTRANCHES)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$4$",num$([F:BPT]BKT)) From TEXTE

        Else                                             : # il  y a une borne inférieure

#                    (poids retenu: $1$ - $2$ = $3$ $4$ soit $5$ tranches de $6$ $4$)
#                      $1$ = poids
#                      $2$ = borne inférieure de poids (borne comprise)
#                      $3$ = poids calculé
#                      $4$ = unité de poids du tarif
#                      $5$ = nombre de tranches
#                      $6$ = poids d'une tranche

          LIBPRO2="   "+mess(20,185,1)
          Call DYNAMIC(LIBPRO2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$2$",num$([F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$3$",num$(WGROWEI-[F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$4$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPRO2,"$5$",num$(NBTRANCHES)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$6$",num$([F:BPT]BKT)) From TEXTE

        Endif

      Else                                               : # arrondi nombre de tranches

        If [F:CAP]MINQTY = 0                             : # pas de borne inférieure

#                (poids retenu: $1$ $2$ arrondi à la $3$ de $4$ $2$ soit $5$ tranches)
#                  $1$ = poids
#                  $2$ = unité de poids du tarif
#                  $3$ = type d'arrondi: menu local 238 (1=tranche< 2=tranche> 3=tranche la +proche)
#                  $4$ = poids d'une tranche
#                  $5$ = nombre de tranches

          LIBPRO2="   "+mess(23,185,1)
          Call DYNAMIC(LIBPRO2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$2$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPRO2,"$3$",mess([F:BPT]WEIRND,238,1)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$4$",num$([F:BPT]BKT)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$5$",num$(NBTRANCHES)) From TEXTE

        Else                                           : # il y a une borne inférieure

#              (poids retenu: $1$ - $2$ = $3$ $4$ arrondi à la $5$ de $6$ $4$ soit $7$ tranches)
#                $1$ = poids
#                $2$ = borne inférieure de poids (borne comprise)
#                $3$ = poids calculé
#                $4$ = unité de poids du tarif
#                $5$ = type d'arrondi: menu local 238 (1=tranche< 2=tranche> 3=tranche la +proche)
#                $6$ = poids d'une tranche
#                $7$ = nombre de tranches

          LIBPRO2="   "+mess(22,185,1)
          Call DYNAMIC(LIBPRO2,"$1$",num$(WGROWEI)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$2$",num$([F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$3$",num$(WGROWEI-[F:CAP]MINQTY)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$4$",[F:BPT]WEU) From TEXTE
          Call DYNAMIC(LIBPRO2,"$5$",mess([F:BPT]WEIRND,238,1)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$6$",num$([F:BPT]BKT)) From TEXTE
          Call DYNAMIC(LIBPRO2,"$7$",num$(NBTRANCHES)) From TEXTE

        Endif

      Endif

    Endif
Endif

GPOINT="FREINV1" : Gosub ENTREE From EXEFNC

#--- si devises différentes
If [L]CUR<>[L]CURBPT
  LIBCONVD = "   "+mess(69,116,1)+" = "+format$(FORMAT,AMTFRE)-[L]CURBPT
  If WCHGTYP=0          : WCHGTYP=1     : Endif
  If WCHGDAT=[00/00/00] : WCHGDAT=date$ : Endif
  Call CONVERT([L]CURBPT,[L]CUR,GLOCALDEV,WCHGTYP,WCHGDAT,AMTFRE,AMTFRE,GBIDI3) From TRTDEV
Endif

#--- trace

Case STAT
  When 1       : FRELIB(0)=mess(49,125,1)-mess(3,14,1)-num$([M]VBPTNUM)
  When 2       : FRELIB(0)=mess(49,125,1)-mess(129,198,1)-num$([M]VBPTNUM)
  When 3       : FRELIB(0)=mess(11,15,1)-num$([M]VBPTNUM)-mess(1,8,1)
  When 4       : FRELIB(0)=mess(81,200,1)
  When 5       : FRELIB(0)=mess(159,196,1)
  When Default : Gosub EXPLICATION   : # explication du calcul
Endcase

End

#  explication du calcul.
$EXPLICATION
Raz FRELIB, ILIB
If LIBNCAL<>""  & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBNCAL   : ILIB+=1 : Endif
If LIBCONPV<>"" & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBCONPV  : ILIB+=1 : Endif
If LIBFIX<>""   & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBFIX    : ILIB+=1 : Endif
If LIBFIXR<>""  & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBFIXR   : ILIB+=1 : Endif
If LIBPRO1<>""  & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBPRO1   : ILIB+=1 : Endif
If LIBPRO2<>""  & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBPRO2   : ILIB+=1 : Endif
If LIBPROR1<>"" & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBPROR1  : ILIB+=1 : Endif
If LIBPROR2<>"" & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBPROR2  : ILIB+=1 : Endif
For IJL=0 To dim(LIBUSER)-1
    If LIBUSER(IJL)<>"" & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBUSER(IJL) : ILIB+=1 : Endif
Next IJL
If LIBCONVD<>"" & dim(FRELIB)>ILIB : FRELIB(ILIB)=LIBCONVD  : ILIB+=1 : Endif

Return

#########################################################################
# Subprog TARIF_VEN : Recherche d'un tarif vente                        #
#-----------------------------------------------------------------------#
#    Utilisé par le configurateur                                       #
#-----------------------------------------------------------------------#
# BPC     Code client                                                   #
# ITM     Reference Article                                             #
# SALFCY  Site vente (site par defaut si non renseigné)                 #
# STOFCY  Site expédition ou stockage (site par defaut si non renseigné)#
# CUR     Devise                                                        #
# DAT     Date de la recherche (tarif valide à cette date)              #
# QTY     Quantite                                                      #
# UOM     Unite (de vente)                                              #
#-----------------------------------------------------------------------#
# Retour                                                                #
# GROPRI  Prix unitaire brut                                            #
# NETPRI  Prix unitaire net (prise en compte des frais/remises)         #
#########################################################################

Subprog TARIF_VEN (BPC,ITM,SALFCY,STOFCY,CUR,DAT,QTY,UOM,GROPRI,NETPRI)
Value    Char    BPC ()
Value    Char    ITM ()
Value    Char    SALFCY ()
Value    Char    STOFCY ()
Value    Char    CUR ()
Value    Date    DAT
Value    Decimal QTY
Value    Char    UOM ()
Variable Decimal GROPRI
Variable Decimal NETPRI

Local Integer AFF, NOL

#--- pas d'appel du s/p si les on est dans les commandes
If GFONCTION="GESSOH" : End : Endif

NOL=nolign

Gosub SIM_SPC_FILE From TRTPRICE
Gosub SIM_SPC_GLOB From TRTPRICE
Call TARIFCHGT(5)  From TRTPRICE

If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif


If clalev([M:SOH0])=0 : Local Mask SOH0      [SOH0] : Raz [M:SOH0] : Endif
If clalev([M:SOH1])=0 : Local Mask SOH1      [SOH1] : Raz [M:SOH1] : Endif
If clalev([M:SOH2])=0 : Local Mask SOH2      [SOH2] : Raz [M:SOH2] : Endif
If clalev([M:SOH3])=0 : Local Mask SOH3      [SOH3] : Raz [M:SOH3] : Endif
If clalev([M:SOH4])=0 : Local Mask SOH4      [SOH4] : Raz [M:SOH4] : Endif

Default Mask [SOH4]
Default Mask [SOH3]
Default Mask [SOH2]
Default Mask [SOH1]
Default Mask [SOH0]

# Issue 74556 - 2011-07-04 by VPO : lecture ssi besoin
If [F:BPC]BPCNUM<>[L]BPC
Read [BPC]BPC0=[L]BPC : #Call LECTURE ("BPC",[L]BPC,"") From CONTOBJ
Endif
If [F:ITS]ITMREF<>[L]ITM
Read [ITS]ITS0=[L]ITM : #Call LECTURE ("ITS",[L]ITM,"") From CONTOBJ
Endif
If [F:ITM]ITMREF<>[L]ITM
Read [ITM]ITM0=[L]ITM : #Call LECTURE ("ITM",[L]ITM,"") From CONTOBJ
Endif

[M]BPCORD=[L]BPC : [M]ORDDAT=[L]DAT

If [L]SALFCY = "" [M]SALFCY=GFCYDEF(5) Else [M]SALFCY=[L]SALFCY Endif
If [L]STOFCY = "" [M]STOFCY=GFCYDEF(7) Else [M]STOFCY=[L]STOFCY Endif

nolign=1
[M:SOH4]ITMREF(0)=[L]ITM
[M:SOH4]SAU(0)=[L]UOM
[M:SOH4]QTY(0)=[L]QTY

Call ALICDE(1,"C",[M]BPCORD) From TRTVENCDE
[M]CUR=[L]CUR
Call INIT_SOH(1,AFF) From SUBSOHB
Call INIT_ITM (1,[M:SOH4]ITMREF(0)) From SUBSOHB

Raz [L]GROPRI, [L]NETPRI
Call RECH_TARIF (1,[M:SOH4]ITMREF(0),0,[M:SOH4]QTY(0),"SOH",[M:SOH4]GROPRI(0)) From TRTVENTAR
[L]GROPRI=[M:SOH4]GROPRI(0)
Call CLCNETPRI([M]QTY(0),[M:SOH0]CUR,0) From TRTVENPRI
[L]NETPRI=[M]NETPRI(0)

nolign=NOL

End

#########################################################################
# Traitement communs pour simulation de recherche parif
#########################################################################
# Ouverture des fichiers nécessaires
#-----------------------------------------------------------------------#
$SIM_SPC_FILE
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:MVC])=0 : Local File BPCUSTMVT  [MVC] : Endif
If clalev([F:BPD])=0 : Local File BPDLVCUST  [BPD] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITS])=0 : Local File ITMSALES   [ITS] : Endif
If clalev([F:ITU])=0 : Local File ITMBPC     [ITU] : Endif
If clalev([F:ITV])=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif
If clalev([F:TRA])=0 : Local File TABRATVAT  [TRA] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT [PRS] : Endif
If clalev([F:SPC])=0 : Local File SPRICCONF  [SPC] : Endif
If clalev([F:SPF])=0 : Local File SPRICFICH  [SPF] : Endif
If clalev([F:SPL])=0 : Local File SPRICLIST  [SPL] : Endif
If clalev([F:SPK])=0 : Local File SPRICLINK  [SPK] : Endif
Gosub OPEN_SFI From TRTX3CPY : #If clalev([F:SFI])=0 : Local File SFOOTINV   [SFI] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif
If clalev([F:SPR])=0 : Local File SPREASON   [SPR] : Endif
Return
#-----------------------------------------------------------------------#
# Réservation des variables globales
#-----------------------------------------------------------------------#
$SIM_SPC_GLOB
Global Char     GFOCITMREF
Global Decimal  GFOCQTY
Global Char     GFOCUOM, GPNTITMREF
Global Shortint GFOCMOTIF
Global Shortint GFOCFLG
Return
#########################################################################

##########################################################################
# Subprog CALNETLIB   Explication du calcul du prix                      #
#------------------------------------------------------------------------#
# Il n y a pas de recherche de tarifs                                    #
# Les libelles sont constitués à partir du contenu de la ligne           #
# ( devis, commande, livraison, facture )                                #
# Les codes tarifs ne sont intégrés aux libelles que lorsqu'ils sont     #
# présents dans l'appel (toujours dans l'écran de simulation)            #
##########################################################################
Subprog CALNETLIB (PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR,REN,PLI,LIB)
Value    Integer PARTNER        : # 1=client / 2=fournisseur
Value    Char    STRUCTURE      : # Code structure de PRICSTRUCT
Value    Decimal BRUT           : # Prix unitaire brut
Value    Decimal MAJREM (0..)   : # Frais/remises
Value    Decimal QTE            : # Quantité
Value    Decimal NET            : # Prix unitaire net
Value    Char    CUR            : # Devise
Value    Integer REN (0..)      : # Motifs (prix / 1 à 9 frais/remise / gratuit)
Value    Char    PLI () (0..)   : # Codes tarif (prix / 1 à 9 remises / gratuit)
Variable Char    LIB () (0..)   : # Libellés explication du tarif
#

Gosub DEB_CALNETLIB

$FIN_CALNETLIB
#--- renvoi table des libelles
For I=0 To dim(TLIB)-1
  If dim(LIB) <= I : Break : Endif
  LIB(I)=TLIB(I)
Next I
End

#-------------------------------------------------------------------------
$DEB_CALNETLIB

Local    Integer I, IREM, ILIB, ITAR, IPIED
Local    Integer IOPENSPR, IOPENPPR
Local    Char    TLIB(100) (0..30)
Local    Decimal MNET, MNETR, RMNT
Local    Decimal LQTE           : LQTE=QTE
Local    Char    LCUR           : LCUR=CUR
Local    Char    FORMAT, FMT_INTER
Local    Char    FMTCOL(15)(0..8)

If LQTE=0 : LQTE=1 : Endif

If clalev ([F:TCU])<=0 : Local File TABCUR [TCU] : Endif
If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif
If PARTNER=1
  If clalev ([F:SPR])<=0 : Local File SPREASON [SPR] : IOPENSPR=1 : Endif
Endif
If PARTNER=2
  If clalev ([F:PPR])<=0 : Local File PPREASON [PPR] : IOPENPPR=1 : Endif
Endif

Call LECDEV(CUR) From TRTDIV
FORMAT="N:"+GDEVFMT1
FMT_INTER="7.4#"
If dim(GDECPRI)>0
   FMT_INTER=num$(11-GDECPRI)+"."+num$(GDECPRI)+"#"
Endif

Raz GLIBDES
Read [F:PRS]PRS0=PARTNER;STRUCTURE
If fstat : End : Endif

For I=0 To 8
  If [F:PRS]INCDCR(I)=0 : Break : Endif
  #-- 80866 Performance Import --#
  If !GIMPORT : Call GET_ATEXTRA ("PRICSTRUCT","DESAXX("+num$(I)+")",GLANGUE,GLIBDES(I)) From TRTX3TEX : Endif
  #Call GET_ATEXTRA ("PRICSTRUCT","DESAXX("+num$(I)+")",GLANGUE,GLIBDES(I)) From TRTX3TEX
  If GFORREM(I)<>""
      FMTCOL(I)=GFORREM(I)
  Else
      FMTCOL(I)="N:"+GDEVFMT1
  Endif
Next I

ILIB=-1
#--- prix unitaire brut
Gosub LBRUT
#--- colonnes frais/remises dans prix untaire net
For IREM=0 To 8
  If MAJREM(IREM)<>0 & [F:PRS]NPRNOTFLG(IREM)=2
    Gosub LREM
  Endif
Next IREM
#--- prix untaire net
Gosub LNET
#--- colonnes hors prix unitaire net et intégrés au pieds de facture
For IREM=0 To 8
  If MAJREM(IREM)<>0 & [F:PRS]NPRNOTFLG(IREM)=1 & [F:PRS]CLCRUL<>3
    Gosub LPIED
  Endif
Next IREM

Return

# --- Libellé du prix brut -----------------------------------------------
$LBRUT
MNET = BRUT
ILIB +=1
TLIB(ILIB)=toupper(mess(294,197,1))-"="-vireblc(format$("N:11.4#",BRUT),2)-LCUR
ITAR=0 : Gosub LTAR
Return

# --- Libellé d'une colonne intégrée au prix net -------------------------
$LREM

ILIB +=1
TLIB(ILIB)=GLIBDES(IREM)-":"

#  -- c'est une majoration --
If [F:PRS]INCDCR(IREM) = 1

  If [F:PRS]VALTYP(IREM) = 1          # c'est un montant
    If [F:PRS]CLCRUL(IREM) <> 1       # par ligne ou document (divise par qté)
      MNET += MAJREM(IREM)/LQTE
#                   $1$ par ligne pour une quantité de $2$
      TLIB(ILIB) -= mess(2,185,1)
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$2$",num$(QTE)) From TEXTE
      ITAR=IREM+1 : Gosub LTAR

      ILIB +=1
#                       soit une majoration de $1$ du prix unitaire
      TLIB(ILIB)="    "+mess(4,185,1)
#      RMNT=MAJREM(IREM)/LQTE : Call ARRDEV(RMNT,CUR) From TRTDIV
      RMNT=MAJREM(IREM)/LQTE
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,RMNT),2)) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMT_INTER,RMNT),2)) From TEXTE
    Else                              # par unité
      MNET += MAJREM(IREM)
#                   $1$ de majoration
      TLIB(ILIB) -= mess(6,185,1)
 #     Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
       Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
     ITAR=IREM+1 : Gosub LTAR
    Endif
  Endif

  If [F:PRS]VALTYP(IREM) = 2          # c'est un % en cumul
    MNET += (BRUT*MAJREM(IREM))/100
#                 $1$ de majoration
    TLIB(ILIB) -= mess(6,185,1)
#    Call DYNAMIC(TLIB(ILIB),"$1$",num$(MAJREM(IREM))-"%") From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$1$",format$(FMTCOL(IREM),MAJREM(IREM))-"%") From TEXTE
    ITAR=IREM+1 : Gosub LTAR

    ILIB +=1
#                     calculé sur le prix unitaire brut $1$ soit $2$
    TLIB(ILIB)="    "+mess(7,185,1)
#    RMNT = (BRUT*MAJREM(IREM))/100 : Call ARRDEV(RMNT,CUR) From TRTDIV
    RMNT = (BRUT*MAJREM(IREM))/100
    Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,BRUT),2)) From TEXTE
#    LIBM="("+vireblc(format$(FORMAT,BRUT),2)+"*"+num$(MAJREM(IREM))+")/100 = "+vireblc(format$(FORMAT,RMNT),2)
    LIBM="("+vireblc(format$(FORMAT,BRUT),2)+"*"+format$(FMTCOL(IREM),MAJREM(IREM))+")/100 = "+vireblc(format$(FMT_INTER,RMNT),2)
    Call DYNAMIC(TLIB(ILIB),"$2$",LIBM) From TEXTE
  Endif

  If [F:PRS]VALTYP(IREM) = 3          # c est un % en cascade
    LNET=MNET : Call ARRDEV(LNET,CUR) From TRTDIV
#    RMNT = (MNET*MAJREM(IREM))/100 : Call ARRDEV(RMNT,CUR) From TRTDIV
    RMNT = (MNET*MAJREM(IREM))/100
    MNET += (MNET*MAJREM(IREM))/100
#                   $1$ de majoration
    TLIB(ILIB) -= mess(6,185,1)
#    Call DYNAMIC(TLIB(ILIB),"$1$",num$(MAJREM(IREM))-"%") From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$1$",format$(FMTCOL(IREM),MAJREM(IREM))-"%") From TEXTE
    ITAR=IREM+1 : Gosub LTAR

    ILIB +=1
#                     calculé sur le prix unitaire net intermédiaire $1$ soit $2$
    TLIB(ILIB)="    "+mess(8,185,1)
    Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,LNET),2)) From TEXTE
#    LIBM="("+vireblc(format$(FORMAT,LNET),2)+"*"+num$(MAJREM(IREM))+")/100 = "+vireblc(format$(FORMAT,RMNT),2)
    LIBM="("+vireblc(format$(FORMAT,LNET),2)+"*"+format$(FMTCOL(IREM),MAJREM(IREM))+")/100 = "+vireblc(format$(FMT_INTER,RMNT),2)
    Call DYNAMIC(TLIB(ILIB),"$2$",LIBM) From TEXTE
  Endif
Endif

#  -- c'est une minoration --
If [F:PRS]INCDCR(IREM) <> 1

  If [F:PRS]VALTYP(IREM) = 1          # c'est un montant
    If [F:PRS]CLCRUL(IREM) <> 1       # par ligne ou document (on divise par la qté)
      MNET -= MAJREM(IREM)/LQTE
#                   $1$ par ligne pour une quantité de $2$
      TLIB(ILIB) -= mess(2,185,1)
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$2$",num$(QTE)) From TEXTE
      ITAR=IREM+1 : Gosub LTAR

      ILIB +=1
#                       soit une minoration de $1$ du prix unitaire
      TLIB(ILIB)="    "+mess(3,185,1)
#      RMNT=MAJREM(IREM)/LQTE : Call ARRDEV(RMNT,CUR) From TRTDIV
      RMNT=MAJREM(IREM)/LQTE
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,RMNT),2)) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMT_INTER,RMNT),2)) From TEXTE
    Else
      MNET -= MAJREM(IREM)
#                   $1$ de minoration
      TLIB(ILIB) -= mess(5,185,1)
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
      ITAR=IREM+1 : Gosub LTAR
    Endif
  Endif

  If [F:PRS]VALTYP(IREM) = 2          # c'est un % en cumul
    MNET -= (BRUT*MAJREM(IREM))/100
#                 $1$ de minoration
    TLIB(ILIB) -= mess(5,185,1)
#    Call DYNAMIC(TLIB(ILIB),"$1$",num$(MAJREM(IREM))-"%") From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$1$",format$(FMTCOL(IREM),MAJREM(IREM))-"%") From TEXTE
    ITAR=IREM+1 : Gosub LTAR

    ILIB +=1
#                     calculé sur le prix unitaire brut $1$ soit $2$
    TLIB(ILIB)="    "+mess(7,185,1)
#    RMNT = (BRUT*MAJREM(IREM))/100 : Call ARRDEV(RMNT,CUR) From TRTDIV
    RMNT = (BRUT*MAJREM(IREM))/100
    Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,BRUT),2)) From TEXTE
#    LIBM="("+vireblc(format$(FORMAT,BRUT),2)+"*"+num$(MAJREM(IREM))+")/100 = "+vireblc(format$(FORMAT,RMNT),2)
    LIBM="("+vireblc(format$(FORMAT,BRUT),2)+"*"+format$(FMTCOL(IREM),MAJREM(IREM))+")/100 = "+vireblc(format$(FMT_INTER,RMNT),2)
    Call DYNAMIC(TLIB(ILIB),"$2$",LIBM) From TEXTE
  Endif

  If [F:PRS]VALTYP(IREM) = 3          # c'est un % en cascade
    LNET=MNET : Call ARRDEV(LNET,CUR) From TRTDIV
#    RMNT = (LNET*MAJREM(IREM))/100 : Call ARRDEV(RMNT,CUR) From TRTDIV
    RMNT = (LNET*MAJREM(IREM))/100
    MNET -= (MNET*MAJREM(IREM))/100
#                 $1$ de minoration
    TLIB(ILIB) -= mess(5,185,1)
#    Call DYNAMIC(TLIB(ILIB),"$1$",num$(MAJREM(IREM))-"%") From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$1$",format$(FMTCOL(IREM),MAJREM(IREM))-"%") From TEXTE
    ITAR=IREM+1 : Gosub LTAR

    ILIB +=1
#                     calculé sur le prix unitaire net intermédiaire $1$ soit $2$
    TLIB(ILIB)="    "+mess(8,185,1)
    Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,LNET),2)) From TEXTE
#    LIBM="("+vireblc(format$(FORMAT,LNET),2)+"*"+num$(MAJREM(IREM))+")/100 = "+vireblc(format$(FORMAT,RMNT),2)
    LIBM="("+vireblc(format$(FORMAT,LNET),2)+"*"+format$(FMTCOL(IREM),MAJREM(IREM))+")/100 = "+vireblc(format$(FMT_INTER,RMNT),2)
    Call DYNAMIC(TLIB(ILIB),"$2$",LIBM) From TEXTE
  Endif
Endif

Return

# --- Libellé du prix net ------------------------------------------------
$LNET
MNET=arr(MNET,10^-GDECPRI)
MNETR=MNET
If (PARTNER=1 & GSALRND=2) | (PARTNER=2 & GPURRND=2)
  Call ARRDEV(MNETR,CUR) From TRTDIV
Endif
ILIB +=1
TLIB(ILIB)=toupper(mess(295,197,1))-"="-vireblc(format$("N:11.4#",MNETR),2)-LCUR
If MNETR<>MNET
  TLIB(ILIB) -= "  ("-vireblc(format$("N:11.4#",MNET),2)-tolower(mess(68,124,1))-")"
Endif

Return

# --- Libellé d'une colonne qui passe en pied de facture -----------------
$LPIED
If IPIED=0
  IPIED=1
  ILIB +=1
  TLIB(ILIB)="-"
  ILIB +=1
  TLIB(ILIB)=toupper(mess(301,197,1))
Endif

ILIB +=1
TLIB(ILIB)=GLIBDES(IREM)-":"

If [F:PRS]INCDCR(IREM) = 1           # c'est majoration

  If [F:PRS]VALTYP(IREM) = 1         # c'est un montant

    If [F:PRS]CLCRUL(IREM) = 2       # par ligne
#                   $1$ de majoration par ligne
      TLIB(ILIB) -= mess(10,185,1)
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
      ITAR=IREM+1 : Gosub LTAR

      ILIB +=1
#                         soit $1$ sur l'élément de facturation $2$
      TLIB(ILIB) = "    "+mess(13,185,1)
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$2$",num$([F:PRS]INVDTA(IREM))) From TEXTE
    Endif

    If [F:PRS]CLCRUL(IREM) = 1       # par unité
#                   $1$ de majoration par unité
      TLIB(ILIB) -= mess(12,185,1)
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
      ITAR=IREM+1 : Gosub LTAR

      ILIB +=1
#                         soit $1$ sur l'élément de facturation $2$
      TLIB(ILIB) = "    "+mess(13,185,1)
#      LIBM="("+vireblc(format$(FORMAT,MAJREM(IREM)),2)+"*"+num$(QTE)+") = "
      LIBM="("+vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)+"*"+num$(QTE)+") = "
      LIBM +=vireblc(format$(FORMAT,MAJREM(IREM)*QTE),2)-LCUR
      Call DYNAMIC(TLIB(ILIB),"$1$",LIBM) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$2$",num$([F:PRS]INVDTA(IREM))) From TEXTE
    Endif
  Endif

  If [F:PRS]VALTYP(IREM) > 1         # c'est un % (toujours sur le net)
#                 $1$ de majoration
    TLIB(ILIB) -= mess(6,185,1)
#    Call DYNAMIC(TLIB(ILIB),"$1$",num$(MAJREM(IREM))-"%") From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$1$",format$(FMTCOL(IREM),MAJREM(IREM))-"%") From TEXTE
    ITAR=IREM+1 : Gosub LTAR

    ILIB +=1
#                        soit $1$ sur l'élément de facturation $2$
    TLIB(ILIB) += "    "+mess(13,185,1)
    RMNT = (arr(MNET,[F:TCU]CURRND)*LQTE*MAJREM(IREM))/100 : Call ARRDEV(RMNT,CUR) From TRTDIV
    LIBM="(("+vireblc(format$(FORMAT,arr(MNET,[F:TCU]CURRND)),2)+"*"+num$(QTE)+")*"
#    LIBM +=num$(MAJREM(IREM))+")/100 = "
    LIBM +=format$(FMTCOL(IREM),MAJREM(IREM))+")/100 = "
    LIBM +=vireblc(format$(FORMAT,RMNT),2)-LCUR
    Call DYNAMIC(TLIB(ILIB),"$1$",LIBM) From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$2$",num$([F:PRS]INVDTA(IREM))) From TEXTE
  Endif
Endif

If [F:PRS]INCDCR(IREM) <>1           # c'est une minoration

  If [F:PRS]VALTYP(IREM) = 1         # c'est un montant

    If [F:PRS]CLCRUL(IREM) = 2       # par ligne
#                   $1$ de minoration par ligne
      TLIB(ILIB) -= mess(9,185,1)
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
      ITAR=IREM+1 : Gosub LTAR

      ILIB +=1
#                          soit $1$ sur l'élément de facturation $2$
      TLIB(ILIB) += "    "+mess(13,185,1)
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$2$",num$([F:PRS]INVDTA(IREM))) From TEXTE
    Endif

    If [F:PRS]CLCRUL(IREM) = 1       # par unité
#                   $1$ de minoration par unité
      TLIB(ILIB) -= mess(11,185,1)
#      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FORMAT,MAJREM(IREM)),2)-LCUR) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$1$",vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)-LCUR) From TEXTE
      ITAR=IREM+1 : Gosub LTAR

      ILIB +=1
#                          soit $1$ sur l'élément de facturation $2$
      TLIB(ILIB) += "    "+mess(13,185,1)
#      LIBM="("+vireblc(format$(FORMAT,MAJREM(IREM)),2)+"*"+num$(QTE)+") = "
      LIBM="("+vireblc(format$(FMTCOL(IREM),MAJREM(IREM)),2)+"*"+num$(QTE)+") = "
      LIBM +=vireblc(format$(FORMAT,MAJREM(IREM)*QTE),2)-LCUR
      Call DYNAMIC(TLIB(ILIB),"$1$",LIBM) From TEXTE
      Call DYNAMIC(TLIB(ILIB),"$2$",num$([F:PRS]INVDTA(IREM))) From TEXTE
    Endif
  Endif

  If [F:PRS]VALTYP(IREM) > 1         # c'est un % (toujours sur le net)
    TLIB(ILIB) -= mess(5,185,1)
#    Call DYNAMIC(TLIB(ILIB),"$1$",num$(MAJREM(IREM))-"%") From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$1$",format$(FMTCOL(IREM),MAJREM(IREM))-"%") From TEXTE
    ITAR=IREM+1 : Gosub LTAR

    ILIB +=1
#                        soit $1$ sur l'élément de facturation $2$
    TLIB(ILIB) += "    "+mess(13,185,1)
    RMNT = (arr(MNET,[F:TCU]CURRND)*LQTE*MAJREM(IREM))/100 : Call ARRDEV(RMNT,CUR) From TRTDIV
    LIBM="(("+vireblc(format$(FORMAT,arr(MNET,[F:TCU]CURRND)),2)+"*"+num$(QTE)+")*"
#    LIBM +=num$(MAJREM(IREM))+")/100 = "
    LIBM +=format$(FMTCOL(IREM),MAJREM(IREM))+")/100 = "
    LIBM +=vireblc(format$(FORMAT,RMNT),2)-LCUR
    Call DYNAMIC(TLIB(ILIB),"$1$",LIBM) From TEXTE
    Call DYNAMIC(TLIB(ILIB),"$2$",num$([F:PRS]INVDTA(IREM))) From TEXTE
  Endif
Endif

Return

$LTAR
Gosub LREN
If dim(PLI)>=ITAR+1 & PLI(ITAR)<>""
  TLIB(ILIB) += " ("+toupper(mess(390,197,1))+":"-PLI(ITAR)-")"
Endif
Return

$LREN
Local Char DESMOTIF (80)
If dim(REN)>=ITAR+1 & REN(ITAR)<>0
  If PARTNER=1
    Read [SPR]SPR0=REN(ITAR)
    #-- 80866 Performance Import --#
    If !GIMPORT : Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX : Endif
    #Call GET_ATEXTRA ("SPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX
    If !fstat
      TLIB(ILIB) += " ("+toupper(mess(389,197,1))+":"-DESMOTIF-")"
    Endif
  Endif
  If PARTNER=2
    Read [PPR]PPR0=REN(ITAR)
    #-- 80866 Performance Import --#
    If !GIMPORT : Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX : Endif
    #Call GET_ATEXTRA ("PPREASON","DESAXX",GLANGUE,DESMOTIF) From TRTX3TEX
    If !fstat
      TLIB(ILIB) += " ("+toupper(mess(389,197,1))+":"-DESMOTIF-")"
    Endif
  Endif
Endif
Return

#########################################################################
# Point d'entrée appelé dans $CONSULTATION des traitements générés tarifs
# lors de la simulation de recherche
# - WATxxxxxx des achats
# - WBTxxxxxx des ventes
#------------------------------------------------------------------------
$PE_SIMTARIF
GPOINT="SIMTARIF" : Gosub ENTREE From EXEFNC
Return

#########################################################################
# Alimentation classes [F] des ventes pour tarifs achats inter-sociétés
# Garnir  avant appel :
#   LBPSNUM : fournisseur  LITMREF : article
#   LPOHFCY : site cde achats      LPRHFCY : site reception achat
# Retour :
#   LSALFCY : site vente           LBPCORD : client cde vente
#   LSALCPY : société vente (si la variable locale a été définie !)
#   Classes [F] de BPARTNER ( du client !....)
#                  BPCUSTOMER   ITMSALES   BPCUSTMVT   BPDLVCUST
#########################################################################
$IS_ALIFICVEN
If clalev ([F:BPR])=0  Local File BPARTNER  [BPR] Endif
If [F:BPR]BPRNUM<>LBPSNUM
   Read [BPR]BPR0=LBPSNUM
   If fstat : Raz [BPR] : Endif
Endif
Raz LSALFCY, LBPCORD
If [F:BPR]BETFCY<2                               : # fournisseur non inter-sociétés
   Gosub IS_INIFICVEN
   Return
Endif
LSALFCY=[F:BPR]FCY
# --- Chargement société du site de vente si la variable locale LSALCPY est déclarée
If dim(LSALCPY)>0
  If clalev ([F:FCY])=0  Local File FACILITY  [FCY] Endif
  If [F:FCY]FCY<>LSALFCY
    Read [FCY] FCY0=LSALFCY : If fstat  Raz [F:FCY] : Endif
  Endif
  LSALCPY=[F:FCY]LEGCPY
Endif
# ---
If clalev([F:BPC])=0  Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPD])=0  Local File BPDLVCUST  [BPD] : Endif
If clalev([F:MVC])=0  Local File BPCUSTMVT  [MVC] : Endif
If clalev([F:ITS])=0  Local File ITMSALES   [ITS] : Endif
# ---
Read [BPR]BPR2(2)=2;LPOHFCY
[G:BPR]currind=1 : [G:BPR]currlen=0   : # reinitialisation cle par defaut
If fstat : Gosub IS_INIFICVEN : Return : Endif
# ---
Read [BPC]BPC0=[F:BPR]BPRNUM
If fstat : Gosub IS_INIFICVEN : Return : Endif
LBPCORD=[F:BPC]BPCNUM
# ---
If LITMREF<>"" : # Il n'y a pas d'article pour les tarifs groupés !
  Read [ITS]ITS0=LITMREF
  If fstat : Gosub IS_INIFICVEN : Return : Endif
Else
  Raz [F:ITS]
Endif
# ---
If LPRHFCY<>"" : # Il n'y a pas de site de réception pour les tarifs groupés
  For [BPD] Where BPCNUM=[F:BPC]BPCNUM & RCPFCY=LPRHFCY
      If  fstat : Raz [F:BPD] : Endif
      Break
  Next
Else
  Raz [F:BPD]
Endif
# ---
#ISITE=find(LSALFCY,GSITE(1..GNBSITE))
#If ISITE
#   Read [MVC]MVC0=[F:BPC]BPCNUM;GFINSITE(ISITE)
#   If fstat : Raz [F:MVC] : Endif
# Else
#   Raz [F:MVC]
#Endif
Return
# --- erreur : initialisation des classes [F] (sauf l'ITS") ---
$IS_INIFICVEN
Raz LSALFCY, LBPCORD
If dim(LSALCPY)>0  Raz LSALCPY : Endif
If clalev ([F:BPC])<>0 : Raz [F:BPC] : Endif
If clalev ([F:MVC])<>0 : Raz [F:MVC] : Endif
If clalev ([F:BPD])<>0 : Raz [F:BPD] : Endif
Return

#########################################################################
#------------------------------------------------------------------#
# Alimentation concernant les colonnes frais/remises               #
#              suite à modification de la structure tarif          #
#------------------------------------------------------------------#
# Entrée   WPARTNER   : 1 (client) / 2 (fournisseur)               #
#          WSTRTYP    : Type transaction                           #
#          WSTRNUM    : Code transaction                           #
#          WABMSK     : Abréviation du masque                      #
#          WDEVISE    : Devise                                     #
#          WRECPLISTC : Recherche structure 0 (non) / 1 (oui)      #
# Sortie   WPLISTC    : Code structure                             #
#------------------------------------------------------------------#
Subprog ALICOLREM (WPARTNER, WSTRTYP, WSTRNUM, WABMSK, WDEVISE, WRECPLISTC, WPLISTC)
Value    Integer WPARTNER
Value    Integer WSTRTYP
Value    Char    WSTRNUM
Value    Char    WABMSK
Value    Char    WDEVISE
Value    Integer WRECPLISTC
Variable Char    WPLISTC
Local Integer  WMODULE : If WPARTNER=1 WMODULE=5 Else WMODULE=6 Endif
Local Char     WNUMERO : If WABMSK<>"" WNUMERO=right$(WABMSK,len(WABMSK)) Endif
If WSTRTYP=3  WNUMERO="2" Endif

If WRECPLISTC=1
    If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    If [F:CPY]CPY<>GSOCIETE
        Read [CPY] CPY0=GSOCIETE
        If fstat Raz [F:CPY] Endif
    Endif
    WPLISTC=[F:CPY]PLISTC
Endif
If GPLISTC<>WPLISTC
    GPLISTC=WPLISTC
    # Lit la structure, garnit GFMTREM(I) (% ou M), GFMTCOL(I) (Fmt col.), GCOLREM(I) (Lib. col.)
    Call COLREM("C",WPARTNER, GPLISTC) From TRTPRICE
    # Lit la structure, garnit des globales avec les caractéristiques des colonnes
    Call TYPREM(WPARTNER,GPLISTC)     From TRTPRICE
    # Affichage des entêtes de colonne variables -----#
    If !GIMPORT & WABMSK<>"" & WSTRNUM<>"" & evalue("dim([M:"+WABMSK+"]DISCRGVAL1)")>0
        Local Char BASPAG(10) : BASPAG="NBLIG" : Gosub TIT_COL From ="W1WK"+num$(WSTRTYP)+WSTRNUM+WNUMERO
    Elsif !GIMPORT & WABMSK<>"" & evalue("dim([M:"+WABMSK+"]VXFRAREM1)")>0
        Local Char BASPAG(10) : BASPAG="NBTAR" : Gosub TIT_COL From W1SPSIMUL0
    Endif
Endif
# Lit la structure, garnit des globales utiles à la recherche tarif
# Fait systématiquement : La liste des tarifs actifs est dépendante de la structure mais aussi de la société
Call TARIFCHGT(WMODULE) From TRTPRICE
# Garnissage du format de saisie des colonnes dans GFORREM (0..8)
If WDEVISE<>"" Call ALIFORREM (WSTRTYP, WSTRNUM, WABMSK, 0, WDEVISE) From TRTPRICE Endif

End
#------------------------------------------------------------------#
# Alimentation du format de saisie des colonnes                    #
#              dans GFORREM (0..8) à partir de GFMTCOL (0..8)      #
#------------------------------------------------------------------#
# IMPERATIF : Appeler COLREM auparavant                            #
#------------------------------------------------------------------#
# Entrée   WSTRTYP   : Type transaction                            #
#          WSTRNUM   : Code transaction                            #
#          WABMSK    : Abréviation du masque                       #
#          WNUMREM   : N° de remise (0..8)                         #
#                      Si 0, alimente le format de ttes les remises#
#                      Si <> 0, alimente le format de la remise    #
#          WDEVISE   : Devise                                      #
#------------------------------------------------------------------#
# ACTION associée ALIFORREM                                        #
#------------------------------------------------------------------#
Subprog ALIFORREM(WSTRTYP, WSTRNUM, WABMSK, WNUMREM, WDEVISE)
Value    Integer  WSTRTYP
Value    Char     WSTRNUM
Value    Char     WABMSK
Value    Integer  WNUMREM
Value    Char     WDEVISE
If WNUMREM<0 | WNUMREM>8 End Endif

If [F:TCU]CUR<>WDEVISE Call LECDEV(WDEVISE) From TRTDIV Endif

For I=WNUMREM To 8
#  If GFMTCOL(I)=""
  If GCOLREM(I)=""
    GFORREM(I)="-Nz:0#[       ]"
  Else

    If GFMTCOL(I)=""
      If GFMTREM(I)="M"
        If [F:TCU]CURFMT2="8"
          GFORREM(I)="NZ:"+[F:TCU]CURFMT2+"[ ]"
        Else
          GFORREM(I)="NZ:"+[F:TCU]CURFMT2
        Endif
      Else
        GFORREM(I)="NZ:3.2#[   ]"
      Endif
    Else

      If instr(1, GFMTCOL(I), "[F:TCU]")
          GFORREM(I)="N:"+evalue(GFMTCOL(I))
      Else
          GFORREM(I)="N:"+GFMTCOL(I)
      Endif
    Endif

  Endif
  If WNUMREM<>0 Break Endif
Next I

#-----
If !GIMPORT & WSTRNUM<>"" Gosub FMTCOL_SLT : Endif
End


#---------------------------------------------------------------#
# Modification du format pour les champs affichés ou invisibles #
# Si champ affiché, ajout de "P" avant ":"                      #
# Si champ invisible le format est précédé d'un "-"             #
#---------------------------------------------------------------#
$FMTCOL_SLT
Local Char     FORMAT(15)
Local Shortint J

For I=0 To 8
  If GCOLREM(I)<>"" FORMAT=GFORREM(I) : Gosub MODIF_GFORREM : GFORREM(I)=FORMAT : Endif
Next I
Return

$MODIF_GFORREM
If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
If [F:SLT]STRTYP<>WSTRTYP | [F:SLT]STRNUM<>WSTRNUM
  Read [SLT] SLT0=WSTRTYP;WSTRNUM : If fstat  Raz [F:SLT] : Endif
Endif
If evalue("[F:SLT]DISCRGCOD"+num$(I+1))=2
  J=instr(1,FORMAT,":")
  FORMAT=left$(FORMAT,J-1)+"P"+right$(FORMAT,J)
# Apparemment plus besoin en V150
#Elsif evalue("[F:SLT]DISCRGCOD"+num$(I+1))=3
#  FORMAT="-"+FORMAT
Endif
Return

#------------------------------------------------------------------#
# Arrondi des valeurs de colonnes frais/remise                     #
#         suite à changement de structure et de devise             #
#------------------------------------------------------------------#
# Entrée   DEVISE    : Devise                                      #
#          WABMSK    : Abréviation du masque                       #
#------------------------------------------------------------------#
Subprog ARRCOLREM(WDEVISE, WABMSK)
Value    Char     WDEVISE
Value    Char     WABMSK

Local Integer I, J, WNBLIG
Local Decimal WRND

If [F:TCU]CUR<>WDEVISE Call LECDEV(WDEVISE) From TRTDIV : Endif

WNBLIG = evalue("[M:"+WABMSK+"]NBLIG")

For J=0 To WNBLIG-1
    For I = 1 To 9
        If evalue ("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I)+")")>0
            If instr(1, GFMTCOL(I-1), "[F:TCU]")
                WRND=min([F:TCU]CURRND,10^-(mod(val(GFORREM(I-1)),1)*10))
                WDISCRGVAL = evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(J)")
                WDISCRGVAL = arr(WDISCRGVAL,WRND)
                Assign ("[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(J)") With WDISCRGVAL
            Endif
        Endif
    Next
Next

End

#########################################################################
# Point d'entrée appelé dans divers traitements tarifs ( générés ou non )
# - Rappel : Trt générés ( WATxxxxxx = achats / WBTxxxxxx = ventes )
#------------------------------------------------------------------------
# Valeurs codes : ( Txx = Tous les tarifs / Axx = Achats / Vxx = Ventes
# - T01 : Tous  : Appel avant le Filter
#------------------------------------------------------------------------
$PE_TARIFS
GPOINT="TARIFS" : Gosub ENTREE From EXEFNC
If dim(CODENTPNT)>0 : Raz CODENTPNT : Endif
Return
#########################################################################

