#----- Chargement environnement tarif depuis les réceptions -----#
$TRTPTH
[F:PPK]PURTYP=1
[F:PPK]POHTYP=1
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[M:PTH1]
# Issue 92966 - 2013-10-04 by MUARN : dernier prix achat en réception
[F:PPK]PRHFCY=[M:PTH0]PRHFCY
For I = 1 To 5
    If evalue("dim([M:PTH1]TSICOD"+num$(I)+"(nolign-1))")>0
       [F:PPK]TSICOD(I-1) = evalue("[M:PTH1]TSICOD"+num$(I)+"(nolign-1)")
    Endif
Next I
[F:PPK]CPY=GSOCIETE
# Issue 71069 - 2016-01-29 by SR : PJT
[F:PPK]PJT    = [M:PTH1]PJT(nolign-1)
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:PTH1]PJT(nolign-1)) : # Code affaire seul
# End issue 71069
Return


#----- Chargement environnement tarif depuis retours fournisseurs -----#
$TRTPNH
[F:PPK]PURTYP=1
[F:PPK]POHTYP=1
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[M:PNH1]
[F:PPK]PRHFCY=[M:PNH1]PNHFCY
If clalev([M:AD65])
  If [M:AD65]BPAADD<>"" [F:PPK]BPAADD=[M:AD65]BPAADD : Endif
Endif
For I=1 To 5
  If evalue("dim([M:PNH1]TSICOD"+num$(I)+"(nolign-1))")>0
    [F:PPK]TSICOD(I-1) = evalue("[M:PNH1]TSICOD"+num$(I)+"(nolign-1)")
  Endif
Next I
[F:PPK]CPY=GSOCIETE
# Issue 71069 - 2016-01-29 by SR : PJT
[F:PPK]PJT    = [M:PNH1]PJT(nolign-1)
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:PNH1]PJT(nolign-1)) : # Code affaire seul
# End issue 71069
Return


#----- Chargement environnement tarif depuis ordres sous-traitance matière -----#
$TRTPSCM
[F:PPK]PURTYP=1
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[M:SCO0] : [F:PPK]=[M:SCO1] : [F:PPK]=[M:SCO2]
If dim([F:PPK]ITMREF)>0
   [F:PPK]ITMREF=[M:SCO2]CPNITMREF(nolign-1)    : # Matière : zone inexistante dans le fichier [F:PPK]?
Endif
If [M:SCO0]ITMREF<>""
   [F:PPK]ITMREFORI=[M:SCO0]ITMREF           : # Article lancé
Elsif GITMREF<>""
   [F:PPK]ITMREFORI=GITMREF                  : # Article lancé
Endif
If dim([M:SCO2]BOMUOM(nolign-1))>0    # UML actif # FQ 76146 GA 09/2011
   [F:PPK]UOM=[M:SCO2]BOMUOM(nolign-1)
Else
   [F:PPK]UOM=[F:ITM]PUU
Endif
[F:PPK]CPY=GSOCIETE
# Issue 71069 - 2016-01-29 by SR : PJT
[F:PPK]PJT    = [M:SCO1]PJT
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SCO1]PJT) : # Code affaire seul
# End issue 71069
Return


#----- Chargement environnement tarif depuis ordres sous-traitance service -----#
$TRTPSCS
[F:PPK]PURTYP=1
[F:PPK]=[F:BPR]
[F:PPK]=[F:BPS]
[F:PPK]=[F:ITM]
[F:PPK]=[M:SCO0] : [F:PPK]=[M:SCO1] : [F:PPK]=[M:SCO3]
If dim([F:PPK]ITMREF)>0
   [F:PPK]ITMREF=[M:SCO3]SRVITMREF             : # Service : zone inexistante dans le fichier [F:PPK]?
Endif
If [M:SCO0]ITMREF<>""
   [F:PPK]ITMREFORI=[M:SCO0]ITMREF           : # Article lancé
Elsif GITMREF<>""
   [F:PPK]ITMREFORI=GITMREF                  : # Article lancé
Endif
[F:PPK]UOM=[M:SCO3]SCOPUU
[F:PPK]CPY=GSOCIETE
# Issue 71069 - 2016-01-29 by SR : PJT
[F:PPK]PJT    = [M:SCO1]PJT
[F:PPK]PJTNUM = func TRTPJT.GET_OPPNUM_FROM_PIMNUM([M:SCO1]PJT) : # Code affaire seul
# End issue 71069
Return

