#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


$METHODS
#ASTATUS = fmet this.ASETERROR( "SUB_METHODS", CURPTH - "/" - ACTION, 0 )
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
      Endcase
  Endcase
Return


$PROPERTIES
#ASTATUS = fmet this.ASETERROR( "SUB_PROPERTIES", [L]CURPRO - "/" - ACTION, CST_AERROR )
  Case [L]CURPRO
    When "LEG"       : Gosub PROP_LEG
    When "COD"       : Gosub PROP_COD
    When "FLGALL"    : Gosub PROP_FLGALL
    When "TYP"       : Gosub PROP_TYP
    When "BPR"       : Gosub PROP_BPR
    When "CRYADDCOD" : Gosub PROP_CRYADDCOD
    When "FLGBPNINC" : Gosub PROP_FLGBPNINC
    When "ECOCOD"    : Gosub PROP_ECOCOD
  Endcase
Return

$PROP_LEG
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.LEG = ""
  Endcase
Return

$PROP_COD
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.COD = ""
  Endcase
Return

$PROP_FLGALL
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.FLGALL = [V]CST_AYES
    When "PROPAGATE"
      If this.FLGALL = [V]CST_AYES
        this.TYP = 0
      Endif
  Endcase
Return

$PROP_TYP
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.TYP = 0
  Endcase
Return

$PROP_BPR
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.BPR = ""
    When "CONTROL"


    If  this.BPR <> ""
    #Laurent SERVETTAZ
    #The property is mandatory => the supervisor will check that the value is not empty before saving the record
    #If the value is empty => you have the message "Mandatorty field" it is the first control
    #So when you save a record => you can check that the value is coorect if the value is not empty
    #
        Local Integer POS : POS = instr( 1, this.BPR, "*" )

        If ( POS > 0 )
            If ( POS <> len(this.BPR) )
                ASTATUS = fmet this.ASETERROR( "BPR", mess(275,139,1), [V]CST_AERROR ) # "The type of this column only authorizes a single wildcard character '*' at the end of the string"
            Endif
        Else
            Local File BPARTNER [BPR]  # Business partner table

            Read [F:BPR]BPR0 = this.BPR
            If fstat                                     # not found
                ASTATUS = fmet this.ASETERROR( "BPR", mess(1128,196,1), CST_AERROR ) # 'Invalid BP'
            Endif
            LogicClose File [BPR]
        Endif
Endif
  Endcase

Return

$PROP_CRYADDCOD
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.CRYADDCOD = 1
  Endcase
Return

$PROP_FLGBPNINC
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.FLGBPNINC = [V]CST_ANO
  Endcase
Return

$PROP_ECOCOD
  # SAM # 111399 changed ACTION to ARULE
  #Case ACTION
  Case [L]ARULE
    When "INIT" : this.ECOCOD = ""
    When "CONTROL"
    #Laurent SERVETTAZ if you want to test the mandatory aspect of a field, you must use the mandatory attribut
    # With the mandatory attribut the supperviseur will shown the madatory aspect and do the control at the rigth time
    #If the property is always mandatory => use the ditionnary
#        If this.ECOCOD = ""
#            ASTATUS = fmet this.ASETERROR("ECOCOD", mess(10,123,1), [V]CST_AERROR)
#       Endif
  Endcase
Return

