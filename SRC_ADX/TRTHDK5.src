#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
#   Statistiques queues                                                Module CRM          6 octobre 2000
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
#PARAM(1) = Code de la fonction appelante. (STAT, SRE, HDK ou DSC)
#PARAM(2) = Code demande de service.
Global Char GSZSELQUE(GLONVCR)
Global Integer GQUEFOUND
Global Char GSZSRE(GLONVCR)

  If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif       : # FGR 28/04/2009 : X3SUIVIyyyyy : pour report V5
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif  : # FGR 28/04/2009 : X3SUIVIyyyyy : pour report V5
  GSZSELQUE = ""
  GQUEFOUND = 0
  GSZSRE = PARAM(2)
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNHDK5"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If PARAM(1) = "STAT" Then
    ETABOU(GSPE1) = 0
  Else
    ETABOU(GSPE1) = 1
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Gosub LOADQUE
  GSZSELQUE = [M:HDK5]QUENUM(0)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GQUEFOUND Then
    #Nettoie l'écran avant de partir.
    Raz [M:HDK5]
    If PARAM(1) = "HDKAGD1" Then
      #Rafraichit l'agenda
      Gosub ONLOAD From TRTHDKAGD
    Elsif PARAM(1) = "DSC" Then
      #Rafraichit le dispatching
      Gosub RAZDSC1 From TRTDSC1
      Gosub LOADDISP From TRTDSC1
    Endif
  Endif
  Kill GSZSELQUE
  Kill GQUEFOUND
  Kill GSZSRE
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSELECT
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
# ONSELECT : Traitement du bouton Sélectionner.
# LOADQUE  : Chargement du tableau des queues.
# AFFQUE   : Affecte la queue à une demande de service.
##########################################################################################################
##########################################################################################################
# Traitement du bouton Sélectionner
#########################################################
$ONSELECT
  If PARAM(1) = "HDKAGD1" Then
    VALEUR = GSZSELQUE
    [M:HDK1]HDKQUEUE = GSZSELQUE
    Affzo [M:HDK0]1-99
    Affzo [M:HDK1]1-99
    mkstat = 4
  Elsif PARAM(1) = "SRE" Then
    VALEUR = GSZSELQUE
    mkstat = 4
    Affzo [M:SRE2]SREDET
  Elsif PARAM(1) = "DSC" Then
    Gosub AFFQUE
  Endif
  FIN = 1
Return

##########################################################################################################
$LOADQUE
Local Integer I
Local Integer ISRE

  I = 0
  ISRE = 0
  For [QUE]
    If  I >= dim([M:HDK5]QUENUM)-1 Then
      Break
    Endif
    Filter [SRE] Where [F:SRE]SREASS = 3 and [F:SRE]SREDET = [F:QUE]NUM
    ISRE = 0
    For [SRE]
      ISRE += 1
    Next
    [M:HDK5]QUENUM(I) = [F:QUE]NUM
    [M:HDK5]NBRSRE(I) = ISRE
    Filter [SRE]
    I += 1
  Next
  If I = 0 Then
    GMESSAGE = mess(315,196,1)  #Aucune queue n'est définie dans l'application.
    GERR = 2
    FIN = 1
    Return
  Endif
  GQUEFOUND = 1
  [M:HDK5]NBQUE = I
  Affzo [M:HDK5]1-99
Return

##########################################################################################################
$AFFQUE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Affecte la demande de service.à la queue sélectionnée
  Readlock [SRE]SRE0=GSZSRE
  If fstat Then
   GMESSAGE = mess(318,196,1) #L'affectation n'a pu être effectuée. Transaction abandonnée
   GERR = 1
   Return
  Endif
  #Ajoute un historique d'état de la demande
  Call CREHISTO(GSZSRE, [F:SRE]SRESAT, GSZSELQUE, 3, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB1
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    Return
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [SRE]
  [F:SRE]SREASS = 3
  [F:SRE]SREDATASS = date$
  [F:SRE]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
  [F:SRE]SREDET = GSZSELQUE
  Rewrite [SRE]
  If fstat Then
    GMESSAGE = mess(318,196,1) #L'affectation n'a pu être effectuée. Transaction abandonnée
    GERR = 1
    Rollback
    Return
  Else
    Commit
  Endif
Return
