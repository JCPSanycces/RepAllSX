#<AdxTL>@(#)3.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#################################################################
# Gbn - Initialisation du paramètre CCNAUTNUM                   #
# 28012010-Fq 54343                                             #
#################################################################
 Call PATCH(nomap)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

If filinfo(filpath("FIL","ADOVAL",PAPPLI),0)<=0
      End
Else
    Gosub INIT_VALPAR
Endif

End

#######################################################################

Subprog PATCH(PAPPLI)
Value Char PAPPLI

 Local Char FICHIER(250)
 FICHIER=filpath("FIL","ADOVAL","fde",PAPPLI)
 If filinfo(FICHIER,0) < 0
  End
 Endif 

 If nomap=GDOSX3 & PAPPLI<>GDOSX3 : Gosub INIT_VALPAR : Endif

End

#----------------------------------------------------------------------
$INIT_VALPAR

 Call ECR_TRACE("UINIPARMIS01: Update CCNAUTNUM parameter "+PAPPLI,0) From GESECRAN

 Local File  =PAPPLI+".ADOVAL" [ADV]
 Local File  =PAPPLI+".ACTIV"  [ACV]

 Local Integer LCCN

 Trbegin [ADV] : GOK=1
  
 Read [F:ACV]CODACT="CCN"                 : # Dossier avec Concession ?
 If !fstat
  LCCN=[F:ACV]FLACT
 Elsif fstat=5
  LCCN=G_NON
 Else
  GOK=0 : Goto FIN  
 Endif

 If LCCN=G_OUI
  Filter [ADV] Where PARAM="CCNAUTNUM"
  If rowcount([F:ADV])
   Update [ADV] Where PARAM="CCNAUTNUM" With VALEUR="3"
   If fstat
    GOK=0 : Goto FIN
   Endif
  Else
   Raz [F:ADV]   
   [F:ADV]CMP   = ""
   [F:ADV]FCY   = ""
   [F:ADV]PARAM = "CCNAUTNUM"
   [F:ADV]CREDAT= date$
   [F:ADV]CRETIM= time
   [F:ADV]CREUSR= GUSER
   [F:ADV]JEU   = ""
   [F:ADV]VALEUR= "3"
   Write [F:ADV]
   If fstat
    GOK=0 : Goto FIN
   Endif
  Endif
 Endif

$FIN
 If GOK=1
  Commit
 Else
  Rollback
 Endif
 #----- Fin du traitement -----#
 Call ECR_TRACE("UINIPARMIS01: end of process",0) From GESECRAN


Return


