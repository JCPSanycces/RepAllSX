$ACTION
  Case ACTION
     When "OUVRE"         : Gosub OUVRE
     When "LIENS"         : Gosub LIENS
  Endcase

Return

#FRLAA - 2016-01-20 - Requirement 113799 US 4216 - START

$OUVRE
  Read [ACV]CODACT="KAUS"
  If !fstat & [F:ACV]FLACT=2
    NBTBL += 1  : TBTABLE(NBTBL) = "EMPLOIDAUS"  : TYPTABLE(NBTBL) = 1
    MSKTAB(NBTBL) = "5" : TBABREV(NBTBL) = "EAUS" :
    If clalev([F:EAUS])=0 : Local File EMPLOIDAUS    [EAUS]         : Endif
  Endif

Return

$LIENS


#MAPAD - 2016-05-03 - Req 114309 - START
If !func SUBEML.IS_LEG('AUS')
  Return
Endif
#MAPAD - 2016-05-03 - Req 114309 - END


Call AM_TFNNUM([M:EMP5]TFNNUM)

Return

Subprog AM_TFNNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = ""
    Actzo [M:EMP5]TFNREN
  Else
    Grizo [M:EMP5]TFNREN
    Raz [M:EMP5]TFNREN
  Endif

End

Subprog C_TFNREN(VALEUR)
Variable Integer VALEUR

  #If VALEUR = 1
    #mkstat = 1 : GMESSAGE = mess(10,123,1)
  #Endif
  # If [M:MAT5]TFNNUM = "" and VALEUR = 1
  #  mkstat = 1 : GMESSAGE = mess(10,123,1)
  #Endif

End


Subprog C_TFNNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> ""
    If func _VALID_TFNNUM(VALEUR) = 0
      mkstat = 2 : GERR = 2  : GMESSAGE = mess(00083,00123,1)
    Endif
  Endif

End


Funprog _VALID_TFNNUM(TFNNUM)
Value Char TFNNUM
Local Integer I, Z, WRET : WRET = 0
Local Integer CASERESULT, RUNNINGTOTAL, MODVAL, CHARLENGTH

  CHARLENGTH = len(TFNNUM)

Local Integer RESULTNUM(1..CHARLENGTH)

  MODVAL = 11

  #TFNNUM ( minimum of 8 characters)
  If CHARLENGTH < 8
    End WRET
  Endif

  For I = 1 To CHARLENGTH
    If  CHARLENGTH = 9
      CASERESULT =func ASSIGN_TFNNUM9(I)
    Else
      CASERESULT =func ASSIGN_TFNNUM8(I)
    Endif
    RESULTNUM(I) = val(mid$(TFNNUM,I,1))*CASERESULT
    RUNNINGTOTAL += RESULTNUM(I)
  Next

  If RUNNINGTOTAL > 0
    If mod(RUNNINGTOTAL,MODVAL) = 0
      WRET = 1
    Endif
  Endif

End WRET

Funprog ASSIGN_TFNNUM9(VARI)
  Value Integer VARI
  Local Integer RESULTVAL : RESULTVAL = 0
  Case VARI
    When 1  : RESULTVAL = 1
    When 2  : RESULTVAL = 4
    When 3  : RESULTVAL = 3
    When 4  : RESULTVAL = 7
    When 5  : RESULTVAL = 5
    When 6  : RESULTVAL = 8
    When 7  : RESULTVAL = 6
    When 8  : RESULTVAL = 9
    When 9  : RESULTVAL = 10
  Endcase

End RESULTVAL

Funprog ASSIGN_TFNNUM8(VARI)
Value Integer VARI
Local Integer RESULTVAL : RESULTVAL = 0

  Case VARI
    When 1  : RESULTVAL = 10
    When 2  : RESULTVAL = 7
    When 3  : RESULTVAL = 8
    When 4  : RESULTVAL = 4
    When 5  : RESULTVAL = 6
    When 6  : RESULTVAL = 3
    When 7  : RESULTVAL = 5
    When 8  : RESULTVAL = 1
  Endcase

End RESULTVAL


