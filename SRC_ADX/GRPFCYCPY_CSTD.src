#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe GRPFCYCPY_L_CPY
#--Test
Local Integer  RET,I
Local Instance GROUPE Using C_GRPFCYCPY

GROUPE = NewInstance With C_GRPFCYCPY

#RET= fmet GROUPE.READOBJ("MIX")
#RET= fmet GROUPE.AREAD("MIX")
RET= fmet GROUPE.AREAD("SAFT2")

For I=1 To maxtab(GROUPE.L_FCY)
	Infbox "GROUPE="+GROUPE.GRP-"FCY="+GROUPE.L_FCY(I).FCY
Next
For I=1 To maxtab(GROUPE.L_CPY)
	Infbox "GROUPE="+GROUPE.GRP-"CPY="+GROUPE.L_CPY(I).CPY
Next
For I=1 To maxtab(GROUPE.L_LEG)
	Infbox "GROUPE="+GROUPE.GRP-"LEG="+GROUPE.L_LEG(I).LEG
Next

FreeInstance =GROUPE.AllocGrp

End
