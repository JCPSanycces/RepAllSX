Return
#########################################################################################
$AREAD

	Local Integer WRET

	Local Integer NBFCY
	Local Integer NBCPY
	Local Integer NBLEG

  Local File AGRPFCY  [AGF]
  Local File FACGROUP [FGR]
  Local File FACILITY [FCY]
  Local File COMPANY  [CPY]

	Link [AGF] With [FGR]FGR0(1)~=[AGF]GRP,
&									[FCY]FCY0   ~=[FGR]FCY,
&									[CPY]CPY0		~=[FCY]LEGCPY
& 				 	As [AGFLNK_]
&						Where GRP=this.GRP


  For [AGFLNK_]
  	NBFCY +=1
  	If this.L_FCY(NBFCY)=null
  		WRET = fmet this.ADDLINE("L_FCY",NBFCY)
  	Endif

		this.L_FCY(NBFCY).FCY 			= [F:FGR]FCY
		this.L_FCY(NBFCY).FCYCPY 		= [F:CPY]CPY
		this.L_FCY(NBFCY).FCYCPYLEG = [F:CPY]LEG

		#--Chargement de la collection L_CPY

  	If find([F:CPY]CPY,this.L_CPY(1..maxtab(this.L_CPY)).CPY)=0
  		NBCPY +=1
  		If this.L_CPY(NBCPY)=null
  			WRET = fmet this.ADDLINE("L_CPY",NBCPY)
  		Endif
  		this.L_CPY(NBCPY).CPY    = [F:CPY]CPY
  		this.L_CPY(NBCPY).CPYLEG = [F:CPY]LEG
		Endif
		#--chargement de la collection L_LEG

  	If find([F:CPY]LEG,this.L_LEG(1..maxtab(this.L_LEG)).LEG)=0
  		NBLEG +=1
  		If this.L_LEG(NBLEG)=null
  			WRET = fmet this.ADDLINE("L_LEG",NBLEG)
  		Endif
  		this.L_LEG(NBLEG).LEG = [F:CPY]LEG
		Endif

  Next

	#--Cas d'une société passés en paramètre
	#--Si une société est passée en paramètre, il existe de toute facon un groupe portant le nom de la société
	#--donc, c'est géré plus haut

	#--Cas d'un site passé en paramètre
	If [L]NBFCY<1

		Read [F:FCY]FCY0=this.GRP
		If fstat : Return : Endif

		Read [F:CPY]CPY0=[F:FCY]LEGCPY
		If fstat : Return : Endif

		#--Ajout du site dans la collection Sites
  	If this.L_FCY(1)=null
  		WRET = fmet this.ADDLINE("L_FCY",1)
  	Endif
		this.L_FCY(1).FCY 			= [F:FCY]FCY
		this.L_FCY(1).FCYCPY 		= [F:CPY]CPY
		this.L_FCY(1).FCYCPYLEG = [F:CPY]LEG

		#--Ajout de la société du site dans la collection Sociétés
		If this.L_CPY(1)=null
			WRET = fmet this.ADDLINE("L_CPY",1)
		Endif
		this.L_CPY(1).CPY    = [F:CPY]CPY
		this.L_CPY(1).CPYLEG = [F:CPY]LEG

		#--Ajout de la législation de la société du site dans la collection Législations
		If this.L_LEG(1)=null
			WRET = fmet this.ADDLINE("L_LEG",1)
		Endif
		this.L_LEG(1).LEG = [F:CPY]LEG

	Endif


Return
#----------------------------------------------------------------------------------------

