#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","CALBIL","CALBIL",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 #81085
 When "DEBUT"       : Gosub DEBUT
 When "BOUTON"      : Gosub BOUTON
Endcase
Return

$INIT
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Local Char    SOC(GLONCPY) , SIT(GLONFCY)
Local Integer STA
TMP = 1
Local Mask CALBIL [CBI]
Raz [M:CBI]
If clalev([M:BIL1])>0
 [M:CBI]EXE      = [M:BIL1]EXE
 [M:CBI]DATDEB   = gdat$(1,1,val([M:CBI]EXE))
 [M:CBI]DATFIN   = gdat$(31,12,val([M:CBI]EXE))
 [M:CBI]TOUSOC   = 1+([M:BIL1]CPY="")
 [M:CBI]SOCIETE  = [M:BIL1]CPY
 [M:CBI]TOUSIT   = 1+([M:BIL1]FCY="")
 [M:CBI]SITE     = [M:BIL1]FCY
 [M:CBI]INDICDEB = [M:BIL1]COD
 [M:CBI]INDICFIN = [M:BIL1]COD
 [M:CBI]TRACE    = 1
Endif
#81085
Call LECMEMO("STD","[M:CBI]","bis") From GMEMO
If [M:CBI]TOUSOC=2 : Grizo [CBI] SOCIETE, TOUSIT : Else : Actzo [CBI] SOCIETE, TOUSIT : Endif
If [M:CBI]TOUSIT=2 : Grizo [CBI] SITE : Else : Actzo [CBI]SITE : Endif
#Call AFF_MEMO From DIVPAYE
Return

################################################################################
$DEBUT
#81085
Affzo [CBI]
Setmok [CBI] With 0
Call AFF_MEMO From DIVPAYE
Return

################################################################################
#81085
$BOUTON
Case BOUT
   When "R" :
     # Button "Rappel MEMO"
     #If GUSER="LANEG": Dbgaff: Endif
     If [M:CBI]TOUSOC=2 : Grizo [CBI] SOCIETE, TOUSIT : Else : Actzo [CBI] SOCIETE, TOUSIT : Endif
     If [M:CBI]TOUSIT=2 : Grizo [CBI] SITE : Else : Actzo [CBI]SITE : Endif
Endcase
Return
################################################################################
# FQ61784 - MABON 15/02/11 - Contrôle des indicateurs contenus dans les bornes : au moins un doit être calculable,
# sinon inutile de lancer le calcul sur les salariés
$CONTROLE
# on n'execute pas le traitement si bouton end
 If GSTATUT<>GSTAOK Then
    FIN = 1
    Return
 Endif

  Local Char CRITERE(250)
  If [M:CBI]INDICDEB<>"" & [M:CBI]INDICFIN<>"" Then
    CRITERE = "CALFLG=2 & TXTFLG<>2"
    CRITERE -= '& COD>="'+[M:CBI]INDICDEB+'" & COD<="'+[M:CBI]INDICFIN+'"'
    If clalev([F:BIN])=0 : Local File BILIND [BIN] : Endif
    Filter [BIN] Where evalue(CRITERE)
    If rowcount([F:BIN])=0 Then
      GERR=1
      GMESSAGE=[M:CBI]INDICDEB-"/"-[M:CBI]INDICFIN-":"-mess(36,10722,1) : # Indicateurs non calculés
      SAI=1
    Endif
    Filter [BIN]
  Endif
Return

$EXEC
Call OUVRE_TRACE(mess(2,10716,1)) From LECFIC : # Calcul du bilan social
If [M]TOUSOC=2
 For [CPY] Where CPYLEGFLG=2
  SOC = [F:CPY]CPY
  Gosub SOCIETE
 Next
Else
 SOC = [M]SOCIETE
 Call LECTURE("CPY",SOC,"") From CONTOBJ
 Gosub SOCIETE
Endif
Call FERME_TRACE From LECFIC
If clalev([M:BIL1])>0
 TRA = ([M:CBI]TRACE=2)
Else
 TRA = 1
Endif
If TRA=0
 Call EFFACE(filpath("TRA",GTRACE,"tra",0),STA) From ORDSYS
Endif
Return

$SOCIETE
If [M]TOUSIT=2
 If [F:CPY]CPYLEGFLG=2
  For [FCY] Where LEGCPY=SOC
   SIT = [F:FCY]FCY
   Gosub SITE
  Next
 Endif
 SIT = ""
 Raz [F:FCY]
 Gosub SITE
Else
 SIT = [M]SITE
 Call LECTURE("FCY",SIT,"") From CONTOBJ
 Gosub SITE
Endif
Return

$SITE
If SIT<>""
 Call ECR_TRACE(mess(2,10716,1)-mess(3,10716,1)-":"-SOC-"/"-SIT,0) From GESECRAN : # Calcul du bilan social. Société/site"
Else
 Call ECR_TRACE(mess(2,10716,1)-mess(3,10716,1)-":"-SOC-"/"-mess(4,116,1),0) From GESECRAN : # Calcul du bilan social. Société/site"
Endif
Call CALBIL(SOC,SIT,[M]EXE,[M]DATDEB,[M]DATFIN,[M]INDICDEB,[M]INDICFIN,([M]TRACE=2)) From CALBIL1
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Return


######################################################################################
Subprog AM_EXE(VALEUR)
Variable Char    VALEUR()
If VALEUR=num$(val(VALEUR)) & len(VALEUR)=4
 [M]DATDEB = gdat$(1,1,val(VALEUR))
 [M]DATFIN = gdat$(31,12,val(VALEUR))
 Affzo DATDEB,DATFIN
Endif
End

Subprog AM_TOUSOC(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo SOCIETE
 Actzo TOUSIT
Else
 [M]SOCIETE = ""
 [M]SITE    = ""
 Affzo SOCIETE,SITE
 Grizo SOCIETE,SITE
 [M]TOUSIT =2
 Affzo TOUSIT
 Grizo TOUSIT
Endif
End

Subprog AS_SOCIETE(VALEUR)
Variable Char    VALEUR()
If [M]TOUSOC=2
 mkstat = 1 : End
Elsif VALEUR=""
 VALEUR = GDEFSOC
Endif
End

Subprog C_SOCIETE(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPY",VALEUR,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Actzo TOUSIT
Else
 [M]TOUSIT = 2
 [M]SITE   = ""
 Affzo TOUSIT,SITE
 Grizo TOUSIT,SITE
Endif
End

Subprog AS_TOUSIT(VALEUR)
Variable Integer VALEUR
If [M]TOUSOC=2
 VALEUR = 2
 mkstat = 2 : End
Endif
End

Subprog AM_TOUSIT(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo SITE
Else
 [M]SITE = ""
 Affzo SITE
 Grizo SITE
Endif
End

Subprog AS_SITE(VALEUR)
Variable Char    VALEUR()
If [M]TOUSIT=2
 mkstat = 1 : End
Endif
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]SOCIETE
  GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY : # Ce site est dans la société...
  mkstat = 2 : End
 Endif
Endif
End

Subprog AV_INI(VALEUR)
Variable Char    VALEUR()
If [M]EXE=""
 [M]EXE    = num$(year(date$)-1)
 [M]DATDEB  = gdat$(1,1,year(date$)-1)
 [M]DATFIN  = gdat$(31,12,year(date$)-1)
 [M]TOUSOC  = 2
 [M]TOUSIT  = 2
 [M]SOCIETE = ""
 [M]SITE    = ""
 [M]TRACE   = 2
 Grizo SOCIETE,SITE,TOUSIT
Else
 If [M:CBI]TOUSOC=2 : Grizo [CBI] SOCIETE, TOUSIT : Endif
 If [M:CBI]TOUSIT=2 : Grizo [CBI] SITE            : Endif
Endif
Affzo [CBI] TRACE-EXE
End

Subprog C_INDICFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]INDICDEB
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 1 : End
Endif
End

