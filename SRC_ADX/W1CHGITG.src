Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZTSICODEND)")>indice
 [M]TSICODEND(indice) = VALEUR
 Affzo ZTSICODEND(indice)
Endif
Gosub _AFF
End

