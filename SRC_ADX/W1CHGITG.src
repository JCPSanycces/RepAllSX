 PARMSK(1) = num$(indice+20)
 PARMSK(2) = func TRTX3.DEPFAM(TSICODEND,indice,20)
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

