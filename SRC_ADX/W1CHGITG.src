If !GWEBSERV
 ## Action SELITMF
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELITMF"
 PARMSK(1) = "[F:ITM]TCLCOD = [M:DIA0]TCLCODOLD"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELITMF","STKSEL","") From GACTION
 GACTION = SAVACT
