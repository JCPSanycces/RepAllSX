#<AdxTL>@(#)2.0.0.0 $Revision$
# Gestion du masque REO1
#---------------------------------#
$ACTION

Case ACTION
 When "FIN_TABLE"     : Gosub FINTABLE     From TRTREOA
 When "CONTROLE"      : Gosub CONTROLE     From TRTREOA
 When "SEL_TABLE"     : Gosub SELTABLE     From TRTREOA
 When "SEL_LISTE"     : Gosub SELLISTE     From TRTREOA
 When "FIN_LISTE"     : Gosub FINLISTE     From TRTREOA
 When "VERF_TABLE"    : Gosub VERFTABLE    From TRTREOA
 When "INIT"          : Gosub INIT         From TRTREOA
 When "TITRE"         : Gosub TIT_TRT      From TRTREOA
 When "OUVRE_BOITE"   : Gosub OUVREBOITE   From TRTREOA
 When "OUVRE"         : Gosub OUVRE        From TRTREOA
 When "DEBUT"         : Gosub DEBUT        From TRTREOA
 When "ABA"           : Gosub ABANDON      From TRTREOA
 When "END"           : Gosub ACTEND       From TRTREOA
 When "FIN"           : Gosub FIN          From TRTREOA
 When "FINSAI"        : Gosub FINSAI       From TRTREOA
 When "OK"            : Gosub OK           From TRTREOA
 When "BOUTON"        : Gosub BOUTON       From TRTREOA
 When "SETBOUT"       : Gosub SETBOUT      From TRTREOA
 When "AP_CHOIX"      : Gosub APCHOIX      From TRTREOA
 When "APRES_MODIF"   : Gosub APRES_MODIF  From TRTREOA
 When "AVANT_LIS"     : Gosub AVANT_LIS    From TRTREOA

 When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG From TRTREO

 When Default
Endcase
Return
##########################################################################
# TRT_COCHAGE                           appeller en AM_COCHAGE et B2_NBLIG
##########################################################################
$TRT_COCHAGE
If [M:REO1]ORIREO (NOL) <> 2
   Default Mask [REO1]
# Lecture article et règle de gestion
   Call INIZONSOR("REO1",[M:REO1]ITMREF(NOL),[M:REO1]STOFCY,NOL,[M:REO1]TRSTYP,[M:REO1]TRSCOD,"") From STKECR    # hcb 50197
#RUBRIQUE origine défaut
   If [M:REO1]QTYSTUACT        (NOL) = 0
      [M:REO1]QTYSTUACT        (NOL) = [M:REO1]QTYSTUORIA  (NOL)
      Affzo [M:REO1]QTYSTUACT  (NOL)
   Endif
   Gosub LEC_STOLOC From TRTREOA
Else
#   Raz GOUVSOR
Endif
If   [M:REO1]SRGPPS(NOL) = ""
     [M:REO1]SRGPPS(NOL) = [M:REO1]SRGPPSSTR
     Affzo [M:REO1]SRGPPS    (NOL)
Endif

[M:REO1]COCHAGE         (NOL) = 2
[M:REO1]MODFLG          (NOL) = 2

#GREP = "M"
Return

##########################################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
# saisie interdite si ligne de cochée .... sinon plantage en abandon
Local Integer I
If find( 2, [M:REO1]COCHAGE(I..[M:REO1]NBLIG-1))
   mkstat = 2
Endif
End

########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

If GFCY <> VALEUR
    GFCY = VALEUR
Endif
GHCBFCY = VALEUR

End
########################################
Subprog AM_SRGPPSSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
   Raz   [M:REO1]LSTWIOFLG
   Grizo [M:REO1]LSTWIOFLG
   Actzo [M:REO1]15
Else
   If [M:REO1]NBLIG <> 0
      Gosub DEBUT_SAIREO From TRTREOA
      [M:REO1]SRGPPSSTR = VALEUR
      Affzo  [M:REO1]SRGPPSSTR
   Else
      [M:REO1]SRGPPSSTR = VALEUR
   Endif
   Actzo [M:REO1]LSTWIOFLG
Endif
End

########################################
Subprog C_SRGPPSSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Call CTRPPSREO([M:REO1]STOFCY,VALEUR) From TRTREOA
Endif
End

########################################
Subprog C_LSTWIOFLG(VALEUR)
Variable Integer VALEUR
If [M:REO1]SRGPPSSTR <> ""
   If VALEUR = 1
      Raz [M:REO1]ITMREFSTR
      Raz [M:REO1]ITMREFEND
      Raz [M:REO1]LOCSTR
      Raz [M:REO1]LOCEND
      Grizo [M:REO1]15
   Else
      Actzo [M:REO1]15
   Endif
Endif

End

#                                          rubriques bornes début / fin 15
########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif

End

########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

########################################
Subprog AM_WRHSTR(VALEUR)
Variable Char    VALEUR()
If [M]WRHEND=[M]WRHSTR | [M]WRHEND<VALEUR
   [M]WRHEND = VALEUR
   Affzo [M]WRHEND
Endif
End

########################################
Subprog C_WRHEND(VALEUR)
Variable Char    VALEUR()
If [M]WRHSTR>VALEUR
   GMESSAGE = mess(44,199,1)
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M]WRHSTR
Endif
End

########################################
Subprog AM_LOCSTR(VALEUR)
Variable Char    VALEUR()
If [M]LOCEND = ""     : [M]LOCEND = VALEUR : Affzo [M]LOCEND : Endif
If [M]LOCEND < VALEUR : [M]LOCEND = VALEUR : Affzo [M]LOCEND : Endif

End

########################################
Subprog C_LOCEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]LOCSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

#                                          rubriques lignes 25

########################################
Subprog IB_NBLIG
# Bouton  2 : Saisie des sorties
# Bouton  3 : Solde

Gosub SET_NOL From TRTREOA

GOUVSOR = 1
GBOUT2 = mess(574,197,1)
GBOUT3 = mess(1,106,1)
If  [M:REO1]ITMREF(NOL) = ""
    Raz GBOUT2
Endif
If  [M:REO1]QTYSTUACT(NOL) >= [M:REO1]QTYSTUORIA(NOL)
    Raz GBOUT3
Endif

# si type <> emplacement reapprovisionnable pas de bouton : solde
If  [M:REO1]ORIREO(NOL) <> 1
    Raz GBOUT3
Endif
# si type  zone de consommation pas de bouton : sortie
If  [M:REO1]ORIREO(NOL) = 2
    Raz GBOUT2
Endif

End

########################################
Subprog B2_NBLIG

Gosub SET_NOL From TRTREOA

If  [M:REO1]COCHAGE(NOL) <> 2 | [M:REO1]SRGPPS_AV(NOL) =  ""
    [M:REO1]COCHAGE(NOL) = 2
    Gosub TRT_COCHAGE         From TRTREO
    Call MAJ_STA_STAFLG(NOL,[M:REO1]COCHAGE(NOL))  From TRTREOA
    If GOK < 1
        Raz GOUVSOR
        [M:REO1]COCHAGE              (NOL)    = 1
        Raz [M:REO1]SRGPPS           (NOL)
        Raz [M:REO1]WSTOFLG          (NOL)
        Raz [M:REO1]QTYSTUACT        (NOL)
        If dim([M:REO1]LOT) > 0
           Raz [M:REO1]LOT           (NOL)
        Endif
        If dim([M:REO1]SLO) > 0
           Raz [M:REO1]SLO           (NOL)
        Endif
        If dim([M:REO1]SERNUM) > 0
           Raz [M:REO1]SERNUM        (NOL)
           Raz [M:REO1]SERNUMF       (NOL)
        Endif
        If dim([M:REO1]PALNUM) > 0                     # hcb 27200
           Raz [M:REO1]PALNUM        (NOL)             # hcb 27200
           Raz [M:REO1]CTRNUM        (NOL)             # hcb 27200
        Endif                                          # hcb 27200
        Raz [M:REO1]STA              (NOL)
        If dim([M:REO1]LPNNUM) > 0                                                       # hcb x3-82749
           Raz [M:REO1]LPNNUM        (NOL)                                               # hcb x3-82749
#           Affzo [M:REO1]LPNNUM      (NOL)                                               # hcb x3-82749
        Endif                                                                            # hcb x3-82749
        If dim([M:REO1]LOC) > 0
           Raz [M:REO1]LOC           (NOL)
        Endif
        Raz [M:REO1]MVTDES           (NOL)
        Raz [M:REO1]CLEFLG           (NOL)
        Affzo [M:REO1]COCHAGE        (NOL)
        Affzo [M:REO1]SRGPPS         (NOL)
        Affzo [M:REO1]WSTOFLG        (NOL)
        Affzo [M:REO1]QTYSTUACT      (NOL)
        If dim([M:REO1]LOT) > 0
           Affzo [M:REO1]LOT         (NOL)
        Endif
        If dim([M:REO1]SLO) > 0
           Affzo [M:REO1]SLO         (NOL)
        Endif
        If dim([M:REO1]SERNUM) > 0
           Affzo [M:REO1]SERNUM      (NOL)
           Affzo [M:REO1]SERNUMF     (NOL)
        Endif
        If dim([M:REO1]PALNUM) > 0                      # hcb 27200
           Affzo [M:REO1]PALNUM      (NOL)              # hcb 27200
           Affzo [M:REO1]CTRNUM      (NOL)              # hcb 27200
        Endif                                           # hcb 27200
        Affzo [M:REO1]STA            (NOL)
        If dim([M:REO1]LOC) > 0
           Affzo [M:REO1]LOC         (NOL)
        Endif
        Affzo [M:REO1]MVTDES         (NOL)
        Affzo [M:REO1]CLEFLG         (NOL)
        Raz   [M:REO1]WSTOFLG        (NOL)
        [M:REO1]MODFLG               (NOL)    = 1
        End
    Endif
Else

       Gosub LEC_STOLOC From TRTREOA
       [M:ALP]VCRTYP    = [M:REO1]VCRTYP       # 34
       [M:ALP]TRSTYP    = [M:REO1]TRSTYP       # 25
       [M:ALP]TRSCOD    = [M:REO1]TRSCOD       # hcb 50197
       [M:ALP]STOFCY    = [M:REO1]STOFCY
       [M:ALP]ITMREF    = [M:REO1]ITMREF     (NOL)
       [M:ALP]QTY       = [M:REO1]QTYSTUACT  (NOL)

       [M:ALP]MVTDES    = [M:REO1]MVTDES     (NOL)
       [M:ALP]PCU       = [M:REO1]STU        (NOL)
       [M:ALP]PCUSTUCOE = 1
       [M:ALP]BESDAT    = [M:REO1]BESDAT     (NOL)
       [M:ALP]AUZSST    = [F:STC]AUZSST
       [M:ALP]LOCCAT    = [F:STC]LOCCAT
       [M:ALP]STOLOC    = ""
       [M:ALP]PECINTLOC = 2
       [M:ALP]PECSCOLOC = 1
       [M:ALP]PECPLFLOC = 2
       [M:ALP]PECCUNLOK = 1
       [M:ALP]FILSTO    = ""
       [M:ALP]TYPQTY    = 2
       [M:ALP]VCRNUM     = [M:REO1]SRGPPS     (NOL)
       If [M:REO1]SRGPPS  (NOL) <> ""
          [M:ALP]VCRLIN     = [M:REO1]SRGLIN  (NOL)
       Else
          [M:ALP]VCRLIN     = 0
       Endif
       [M:ALP]VCRSEQ     = 0
       Raz [M:ALP]ALLDAT, [M:ALP]DESQTY, [M:ALP]ALLQTY
       Raz [M:ALP]VCRTYPORI,[M:ALP]VCRNUMORI,[M:ALP]VCRLINORI
       Raz [M:ALP]VCRSEQORI,[M:ALP]ALLTYPORI
       Raz [M:ALP]LOT, [M:ALP]LOC, [M:ALP]STA
Endif

End

########################################
Subprog B3_NBLIG
Gosub SET_NOL From TRTREOA
If [M:REO1]CLEFLG     (NOL) = 2
   [M:REO1]CLEFLG     (NOL) = 1
Else
   [M:REO1]CLEFLG     (NOL) = 2
Endif

[M:REO1]COCHAGE       (NOL) = 2
[M:REO1]MODFLG        (NOL) = 2
Affzo [M:REO1]CLEFLG  (NOL)
Affzo [M:REO1]COCHAGE (NOL)
# pour passer par le setbout ....
mkstat = 4                       # hcb 33235

End

########################################
Subprog APRES_NBLIG
Gosub SET_NOL From TRTREOA

# mise à jour du flag STAFLG
Affzo [M:REO1]COCHAGE(NOL)
If [M:REO1]ITMREF(NOL) <> ""
   Call MAJ_STA_STAFLG(NOL,[M:REO1]COCHAGE(NOL))  From TRTREOA
Endif
End

########################################
Subprog AM_COCHAGE(VALEUR)
Variable Integer VALEUR
GOK = 1

Gosub SET_NOL From TRTREOA
Local Integer WRET
If VALEUR = 1

    Call DELSTOSORW(NOL,NOL,"REO1",[M:REO1]STOFCY,WRET) From STKSOR
    If WRET<>0 : mkstat=2 : Endif

#    Raz [M:REO1]SRGPPS              (NOL)        # hcb 86239
    Raz [M:REO1]WSTOFLG             (NOL)
    If [M:REO1]ORIREO               (NOL) <> 2
       Raz [M:REO1]QTYSTUACT        (NOL)
       If dim([M:REO1]LOT) > 0
          Raz [M:REO1]LOT           (NOL)
       Endif
       If dim([M:REO1]SLO) > 0
          Raz [M:REO1]SLO           (NOL)
       Endif
       If dim([M:REO1]SERNUM) > 0
          Raz [M:REO1]SERNUM        (NOL)
          Raz [M:REO1]SERNUMF       (NOL)
       Endif
       If dim([M:REO1]PALNUM) > 0                      # hcb 27200
          Raz [M:REO1]PALNUM        (NOL)              # hcb 27200
          Raz [M:REO1]CTRNUM        (NOL)              # hcb 27200
       Endif                                           # hcb 27200
       Raz [M:REO1]STA              (NOL)
       If dim([M:REO1]LPNNUM) > 0                                                        # hcb X3-82749
          Raz [M:REO1]LPNNUM        (NOL)                                                # hcb X3-82749
 #         Affzo [M:REO1]LPNNUM      (NOL)                                                # hcb X3-82749
       Endif                                                                             # hcb X3-82749
       If dim([M:REO1]LOC) > 0
          Raz [M:REO1]LOC           (NOL)
       Endif
       If dim([M:REO1]LOT) > 0
          Affzo [M:REO1]LOT         (NOL)
       Endif
       If dim([M:REO1]SLO) > 0
          Affzo [M:REO1]SLO         (NOL)
       Endif
       If dim([M:REO1]SERNUM) > 0
          Affzo [M:REO1]SERNUM      (NOL)
          Affzo [M:REO1]SERNUMF     (NOL)
       Endif
       If dim([M:REO1]PALNUM) > 0                      # hcb 27200
          Affzo [M:REO1]PALNUM      (NOL)              # hcb 27200
          Affzo [M:REO1]CTRNUM      (NOL)              # hcb 27200
       Endif                                           # hcb 27200
       Affzo [M:REO1]STA            (NOL)
       If dim([M:REO1]LOC) > 0
          Affzo [M:REO1]LOC         (NOL)
       Endif
    Endif
    Raz [M:REO1]MVTDES        (NOL)
    Raz [M:REO1]CLEFLG        (NOL)

    Affzo [M:REO1]SRGPPS      (NOL)
    Affzo [M:REO1]WSTOFLG     (NOL)
    Affzo [M:REO1]QTYSTUACT   (NOL)
    Affzo [M:REO1]MVTDES      (NOL)
    Affzo [M:REO1]CLEFLG      (NOL)
    Gosub ACT_RUB_DESTINATION From TRTREOA

    [M:REO1]COCHAGE(NOL)    = 1
    GOUVSOR = 0                      # rajouter que dans passaireo le trt_cochage ne se fasse
    If [M:REO1]SRGPPS_AV(NOL) = ""
       [M:REO1]SRGPPS(NOL)    = ""
       Affzo [M:REO1]SRGPPS(NOL)
       Raz   [M:REO1]WSTOFLG(NOL)
       [M:REO1]MODFLG(NOL)    = 1
    Endif

Else
    Gosub TRT_COCHAGE From TRTREO
Endif
End

########################################
Subprog IB_SRGPPS
Gosub SET_NOL From TRTREOA
#  Bouton  1 liste à ranger du filtre
GBOUT1 = mess(450,198,1)
#  Bouton  2 dernière liste à ranger
GBOUT2= mess(451,198,1)
#  Bouton  3 nouvelle liste à ranger
GBOUT3= mess(452,198,1)
# Bouton   4 liste à blanc
GBOUT4 = mess(453,198,1)

If  [M:REO1]SRGPPSSTR = ""
    GBOUT1 = ""
Endif
If  [M:REO1]SRGPPSEND = ""
    GBOUT2 = ""
Endif
If  [M:REO1]COCHAGE(NOL) <> 2
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
Endif
If  [M:REO1]SRGPPS(NOL) =  ""
    Raz GBOUT4
Endif
# sur une liste deja enregistrer seule lste à blanc est permit
If  [M:REO1]CREFLG(NOL) <> 0
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
Endif
End

########################################
Subprog AM_SRGPPS(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA

If [M:REO1]CREFLG(NOL) <> 0 & (VALEUR <> [M:REO1]SRGPPS_AV(NOL) & [M:REO1]SRGPPS(NOL) <> "")
   GMESSAGE= mess(77,184,1)       # Vous ne pouvez pas modifier directement le numéro
   mkstat=2
   End
Endif

If [M:REO1]SRGPPS_AV(NOL) <> ""  & ([M:REO1]SRGPPS(NOL) = "" | VALEUR = "" )
    Diszo [M:REO1]QTYSTUACT(NOL)
    [M:REO1]MODFLG(NOL)=2
    End
Endif

#si compteur manuel on peut saisir une liste inexistante
[M:REO1]MODFLG          (NOL) = 2

If GSTKCPTMAN(18) = 2
   Actzo [M:REO1]QTYSTUACT(NOL)
   End
Endif
If [M:REO1]SRGPPSSTR = VALEUR
   Actzo [M:REO1]QTYSTUACT(NOL)
   End
Endif
If [M:REO1]SRGPPSEND = VALEUR
   Actzo [M:REO1]QTYSTUACT(NOL)
   End
Endif
Local Integer WEXI
WEXI = 0
WEXI = find ( VALEUR,[M:REO1]SRGPPS(0..[M:REO1]NBLIG))
If WEXI <> 0
   Actzo [M:REO1]QTYSTUACT(NOL)
   End
Endif
#Compteur manuel à non , le numero de liste doit exister dans le tableau
GMESSAGE= mess(55,184,1)
mkstat=2
End

########################################
Subprog B1_SRGPPS(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
VALEUR             = [M:REO1]SRGPPSSTR
[M:REO1]SRGPPS(NOL)= [M:REO1]SRGPPSSTR             # hcb  33235
[M:REO1]MODFLG(NOL)=2

End

########################################
Subprog B2_SRGPPS(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
VALEUR             = [M:REO1]SRGPPSEND
[M:REO1]SRGPPS(NOL)= [M:REO1]SRGPPSEND             # hcb  33235

[M:REO1]MODFLG(NOL)=2

End

########################################
Subprog B3_SRGPPS(VALEUR)
Variable Char    VALEUR()
Local Integer WRET
Gosub SET_NOL From TRTREOA
Call DEBTRANS From GLOCK
Trbegin [REO]
Call NUMERO(GSTKCPT(18),[M:REO1]STOFCY,date$,[M:REO1]ITMREF(NOL),VALEUR,WRET) From SUBANM
If WRET = 1  mkstat = 2 :
   GMESSAGE= mess(842,196,1)
Endif
If WRET = 2  mkstat = 2 :
   GMESSAGE= mess(30,196,1)
Endif
If WRET = 0
   [M:REO1]SRGPPSEND   = VALEUR
   [M:REO1]SRGPPS(NOL) = VALEUR                    # hcb 33235
   [M:REO1]MODFLG(NOL) = 2
   Commit
Else
   Rollback
Endif
End

########################################
Subprog B4_SRGPPS(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
VALEUR = ""

[M:REO1]SRGPPS(NOL) = ""
Affzo  [M:REO1]SRGPPS(NOL)
[M:REO1]MODFLG(NOL)=2

End

########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
Local    Decimal WQTY

Raz WQTY
pcolor=GCOUL(0)
# Colorisation de l'article
# - si la quantite sortie = 0 et que le solde soit à non
   # Nouvelle ligne ou ligne modifiée
   If [M:REO1]COCHAGE(NOL)=2
      # Si qty sortie = 0 est solde = non  => rouge
      If [M:REO1]QTYSTUACT(NOL)=0 & [M:REO1]CLEFLG(NOL)<>2
         pcolor=GCOUL(1)
      Endif
      If [M:REO1]WSTOSEQ(NOL)<> 0    # nouvelle ligne  (sans liste à ranger) ou
                                     # ancienne ligne (avec liste à ranger) + acces "saisie sortie"
         WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:REO1]WSTOSEQ(NOL)))
         # si qty à sortir est <> qty sortie  et que le solde = non  => rouge
         If WQTY<>[M:REO1]QTYSTUACT(NOL) & [M:REO1]CLEFLG(NOL)<>2
            pcolor=GCOUL(1)
         Else
            WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*
&                     ([M:SOW]WSTOSEQ(J)=[M:REO1]WSTOSEQ(NOL)&[M:SOW]WSTOCOU(J)<>0))
            # Il y a une quantité en rupture
            If WQTY<>[M:REO1]QTYSTUACT(NOL)
               pcolor=GCOUL(2)
            Endif
         Endif
      Endif
   Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
If [M:REO1]COCHAGE(NOL) <> 2
   Call CTRCLEREO("REO1",2,[M:REO1]LOCORI(NOL),VALEUR) From TRTREOA
Endif
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
Gosub ACT_PIKREO From TRTREOA
End

########################################
Subprog C_LOCORI(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
If [M:REO1]ORIREO(NOL) = 2
   If VALEUR = ""
      GMESSAGE = mess(553,197,1) # Emplacement non renseigné
      mkstat = 2
   Else
      If [M:REO1]DEFLOC(NOL) <> ""
         If !pat(VALEUR,[M:REO1]DEFLOC(NOL))
            GMESSAGE = mess(243,184,1)-" ("-VALEUR-"/"-[M:REO1]DEFLOC(NOL)-")" # Emplacement non conforme
            mkstat = 2
         Endif
      Else
         If [M:REO1]DEFTYPLOC(NOL) <> ""
            Read [STC]STC0=[M:REO1]STOFCY;VALEUR
            If fstat
               Raz [F:STC0]
            Endif
            If !pat([F:STC]LOCTYP,[M:REO1]DEFTYPLOC(NOL))
               GMESSAGE = mess(244,184,1)-" ("-[F:STC]LOCTYP-"/"-[M:REO1]DEFTYPLOC(NOL)-")" # Emplacement non conforme
               mkstat = 2
            Endif
         Endif
      Endif
   Endif
Else
   If [M:REO1]COCHAGE(NOL) <> 2
      Call CTRCLEREO("REO1",1,VALEUR,"") From TRTREOA
   Endif
Endif

End

########################################
# Appelé avant l'action SAISTOSOR
# Permet de vérifier s'il faut la lancer ou non
$AAPRES_NBLIG
Local Integer WRET
Raz WRET
Raz GOUVSOR
Gosub SET_NOL From TRTREOA

If GOK < 1
        [M:REO1]COCHAGE           (NOL)    = 1
        Raz [M:REO1]SRGPPS        (NOL)
        Raz [M:REO1]WSTOFLG       (NOL)
        Raz [M:REO1]QTYSTUACT     (NOL)
        If dim([M:REO1]LOT) > 0
           Raz [M:REO1]LOT           (NOL)
        Endif
        If dim([M:REO1]SLO) > 0
           Raz [M:REO1]SLO           (NOL)
        Endif
        If dim([M:REO1]SERNUM) > 0
           Raz [M:REO1]SERNUM        (NOL)
           Raz [M:REO1]SERNUMF       (NOL)
        Endif
        If dim([M:REO1]PALNUM) > 0                     # hcb 27200
           Raz [M:REO1]PALNUM       (NOL)              # hcb 27200
           Raz [M:REO1]CTRNUM       (NOL)              # hcb 27200
        Endif                                          # hcb 27200
        Raz [M:REO1]STA           (NOL)
        If dim([M:REO1]LPNNUM) > 0                                                       # hcb x3-82749
           Raz [M:REO1]LPNNUM       (NOL)                                                # hcb x3-82749
 #          Affzo [M:REO1]LPNNUM     (NOL)                                                # hcb x3-82749
        Endif                                                                            # hcb x3-82749
        If dim([M:REO1]LOC) > 0
           Raz [M:REO1]LOC           (NOL)
        Endif
        Raz [M:REO1]MVTDES        (NOL)
        Raz [M:REO1]CLEFLG        (NOL)
        Affzo [M:REO1]COCHAGE     (NOL)
        Affzo [M:REO1]SRGPPS      (NOL)
        Affzo [M:REO1]WSTOFLG     (NOL)
        Affzo [M:REO1]QTYSTUACT   (NOL)
        If dim([M:REO1]LOT) > 0
           Affzo [M:REO1]LOT         (NOL)
        Endif
        If dim([M:REO1]SLO) > 0
           Affzo [M:REO1]SLO         (NOL)
        Endif
        If dim([M:REO1]SERNUM) > 0
           Affzo [M:REO1]SERNUM      (NOL)
           Affzo [M:REO1]SERNUMF     (NOL)
        Endif
        If dim([M:REO1]PALNUM) > 0                       # hcb 27200
           Affzo [M:REO1]PALNUM       (NOL)              # hcb 27200
           Affzo [M:REO1]CTRNUM       (NOL)              # hcb 27200
        Endif                                            # hcb 27200
        Affzo [M:REO1]STA         (NOL)
        If dim([M:REO1]LOC) > 0
           Affzo [M:REO1]LOC         (NOL)
        Endif
        Affzo [M:REO1]MVTDES      (NOL)
        Affzo [M:REO1]CLEFLG      (NOL)
        Raz   [M:REO1]WSTOFLG     (NOL)
        [M:REO1]MODFLG            (NOL)    = 1
        Return
Endif

If [M:REO1]COCHAGE(NOL) = 2
  Gosub DES_RUB_DESTINATION From TRTREOA
Endif

If [M:REO1]ORIREO (NOL) = 2
   Return
Endif

# Si sortie tableau validante
If adxgtb<>1 & !find(status,65,68,83)
   If [M:REO1]COCHAGE(NOL) = 2
# Alimentation de [M:ALP]
      Gosub ALI_ALP From TRTREOA
# Détermination du stock à sortir (automatisme, saisie)
      Diszo [M:REO1]ITMREF(NOL)
      Call OUVSOR("REO1",NOL,[M:REO1]NBLIG,[M:REO1]WSTOSEQ(NOL),[M:REO1]STKFLG,WRET) From STKSOR        # hcb 50197
      Affzo [M:REO1]ITMREF(NOL) # Pour la couleur
   Endif
Endif

Return

########################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
Gosub SET_NOL From TRTREOA

If VALEUR<>""
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From TRTREOA
   # Détermination no série fin
   Call CTLSORSER("REO1",NOL,VALEUR,[M:REO1]QTYSTUACT(NOL),LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M:REO1]SERNUMF(NOL)
   Else
      [M:REO1]SERNUMF(NOL)=LSERF
   Endif
Else
   Raz [M:REO1]SERNUMF(NOL)
Endif
Affzo [M:REO1]SERNUMF(NOL)

End

########################################
Subprog AS_CLEFLG(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL From TRTREOA
# si pas de rubrique saisie le solde ce fait par clic droit
If [M:REO1]QTYSTUACT(NOL) = 0
   mkstat = 2
   End
Endif

If [M:REO1]QTYSTUACT(NOL) >= [M:REO1]QTYSTUORIA(NOL)
   mkstat = 2
   End
Endif

End

########################################
Subprog AS_SRGPPS(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
If [M:REO1]COCHAGE(NOL) <> 2 |[M:REO1]ITMREF(NOL) = ""
   mkstat = 2
   End
Endif

End

########################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
Local Shortint WRET
If VALEUR <> "$"
   If VALEUR <> ""
      Call STKCTRSTA(VALEUR,[F:STC]AUZSST,0,1,0,WRET) From STKACT
      If WRET = 2
         mkstat = 2
      Endif
   Endif
Endif

End

########################################
Subprog AM_LSTWIOFLG(VALEUR)
Variable Integer VALEUR
If [M:REO1]SRGPPSSTR <> ""
   If VALEUR = 1
      [M:REO1]LSTWIOFLG = 1
      Call ACT_SELREO From TRTREOA
   Endif
Endif

End

##########################################################################
##   Bouton  Qté US à traiter
##########################################################################
Subprog IB_QTYSTUACT
Gosub SET_NOL From TRTREOA
# Qté US à traiter
GBOUT1 = mess(22,180,1)
If [M:REO1]QTYSTUORIA(NOL) = [M:REO1]QTYSTUACT(NOL)
   GBOUT1 = ""
Endif
End

########################################
Subprog B1_QTYSTUACT(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From TRTREOA
VALEUR  = [M:REO1]QTYSTUORIA(NOL)

End

##########################################################################
## Qtystu est toujours modifiable
##########################################################################
Subprog AS_QTYSTUACT(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From TRTREOA
# on ne recalcul pas les zones si une saisie à ete deja faite
If [M:REO1]MODFLG(NOL) = 2
   End
Endif
If [M:REO1]COCHAGE(NOL) = 2
   End
Endif
If [M:REO1]ITMREF(nolign-1) = ""
   mkstat = 2
   End
Endif

# cas ou on saisie directement
If GOUVSOR = 0
   End
Endif
Gosub TRT_COCHAGE From TRTREO
GOUVSOR = 0

End

########################################
Subprog C_QTYSTUACT(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From TRTREOA

If [M:REO1]COCHAGE(NOL) = 2 & [M:REO1]SRGPPS(NOL) <> ""  & VALEUR = 0
   mkstat = 2
Endif

End

########################################
Subprog AS_COCHAGE(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL From TRTREOA
If [M:REO1]ITMREF(NOL) = ""
   mkstat = 2
Endif
End

########################################
Subprog AS_VCRTYP2(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,3,11,37)
        GMENLOC(I) = 1
    Endif
Next
End

########################################
Subprog AM_VCRNUMSTR2(VALEUR)
Variable Char    VALEUR()
If [M:REOC]VCRNUMEND2 = ""      : [M:REOC]VCRNUMEND2 = VALEUR : Affzo [M:REOC]VCRNUMEND2 : Endif
If [M:REOC]VCRNUMEND2 < VALEUR  : [M:REOC]VCRNUMEND2 = VALEUR : Affzo [M:REOC]VCRNUMEND2 : Endif

End

########################################
Subprog C_VCRNUMEND2(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M:REOC]VCRNUMSTR2 : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AS_VCRTYP3(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,3,5,6,11,37)
        GMENLOC(I) = 1
    Endif
Next
End

########################################
Subprog AM_VCRNUMSTR3(VALEUR)
Variable Char    VALEUR()
If [M:REOC]VCRNUMEND3 = ""      : [M:REOC]VCRNUMEND3 = VALEUR : Affzo [M:REOC]VCRNUMEND3 : Endif
If [M:REOC]VCRNUMEND3 < VALEUR  : [M:REOC]VCRNUMEND3 = VALEUR : Affzo [M:REOC]VCRNUMEND3 : Endif
End

########################################
Subprog C_VCRNUMEND3(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M:REOC]VCRNUMSTR3 : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AS_LOCORI(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTREOA
# locori est saisissable uniquement si type = zone de consommation
#                                   si locori pas renseigné
#                                   si ligne ancienne
# saisissable si GORIGINE = 2 (type emplacement réapprovisionnable uniquement et sur nouvelle ligne
If GORIGINE = 2 & [M:REO1]WFLG(NOL) = 0
   End
Endif
Local Integer WSAI
WSAI = 0
If  [M:REO1]ORIREO(NOL) = 2
    If   !instr(1,[M:REO1]DEFLOC(NOL) ,'*')    & !instr(1,[M:REO1]DEFLOC(NOL),'?')
&      & !instr(1,[M:REO1]DEFLOC(NOL) ,'!')    & !instr(1,[M:REO1]DEFLOC(NOL),'#')
&      & [M:REO1]DEFLOC(NOL) <> ""
       WSAI = 0
    Else
       WSAI = 1
    Endif
Endif
#[M:REO1]LOCORI(NOL) = "" & [M:REO1]WFLG(NOL) = 1
If [M:REO1]ORIREO(NOL) = 2 & WSAI = 1
   Actzo [M:REO1]LOCORI(NOL)
Else
   mkstat = 2
Endif
End

######################################################################################
Subprog C_WRHORI(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End


