###########################################################################################
# Script            : AIFIMPGENFIC                                                        #
# Created date      : 27/01/2016                                                          #
# Version           : 1.0.0                                                               #
# Auteurs           : SAGE (OMA)                                                          #
# Module            : Supervisor                                                          #
# ----------------------------------------------------------------------------------------#
# Activity code     :                                                                     #
# Description       : Conversion monoline files                                          #
#                     This script can from a single line for a record generate a file     #
#                     with the     X3 FORMAT File For IMPORT                              #
#-----------------------------------------------------------------------------------------#                                                                                         #
###########################################################################################

# List of the object for use this script
# Type objet  Objet
# TRT             AIFIMPGENFIC
# AWI             AIFIMPGENFIC
# AMK             AIFIMPGENFIC
# ACT             AIFIMPGENF
# AFC             AIFIMPGENFIC
# Menu item       STD_X3_ERP_AIFIMPGENFIC
# Menu Submodule  SUPERVISOR_TEST ( in SUPERV) : add menu item STD_X3_ERP_AIFIMPGENFIC

### Start of test
Local Integer STAT
Local Char FIC_SRC(GDIMFIC)
Local Char FIC_DES_EVAL(GDIMFIC)
Local Char SEPFLD(10)
Local Char SEPREC(10)
Local Integer CODDBA

FIC_SRC = filpath("tmp","IMP_X3_ITM","csv")
[L]FIC_DES_EVAL = 'FIC_SRC+".out"'
SEPFLD = ';'
SEPREC='\013\010'

CODDBA = 1
#Local menu 945 - 'Character coding'
#1 - ascii
#2 - UTF-8
#3 - UCS-2

Call GENFIC(FIC_SRC,[L]FIC_DES_EVAL,SEPFLD,SEPREC,CODDBA,STAT)


End

### End of test
#**
#* Actions for the fonction AIFIMPGENFIC ( action AIFIMPGENFIC)
#*!
$ACTION

Case ACTION
 When "INIT"      : Gosub INIT
 When "INIT_DIA"  : Gosub INIT_DIA
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
Endcase
Return

$INIT_DIA
Raz [M:AIMP]
Return

$INIT

Local Integer YSTAT
Local Char YWFICHIER(GDIMFIC), YWFICCLI(GDIMFIC)
Local Char YURL(GDIMFIC)

Return

$CONTROLE

YWFICHIER = [M:AIMP]NOMIMP
If [M:AIMP]TYPEXP=1
 YWFICCLI = [M:AIMP]NOMIMP
 Call SET_FICNAM(YWFICCLI,YWFICHIER,YURL) From ORDSYS
 Call COPSRV(YWFICCLI,YWFICHIER,YSTAT) From ORDSYS
 If YSTAT : FIN = 1 : Return : Endif
 [M:AIMP]NOMIMP = YWFICHIER
 [M:AIMP]NOMGEN = evalue([M:AIMP]NOMGENEVA)
Endif
Return

$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Call GENFIC([M:AIMP]NOMIMP,[M:AIMP]NOMGENEVA,[M:AIMP]SEPFLD,[M:AIMP]SEPREC,[M:AIMP]CODDBA,YSTAT)

If [M:AIMP]TYPEXP = 2
 If YSTAT
  Call ECR_TRACE(mess(00043,00149,1),1) From GESECRAN : # The file could not be created on the server'
 Else
  Call ECR_TRACE(func AFNC.MES1(mess(00055,00149,1), [M:AIMP]NOMGEN)+"|",0) From GESECRAN : # The $1$ file has been sucessfully created
 Endif
Elsif [M:AIMP]TYPEXP = 1
 If YSTAT
  Call ECR_TRACE(mess(00164,00141,1),1) From GESECRAN : # File not copied to the client workstation
 Else
  [M:AIMP]NOMIMP = YWFICCLI
  YWFICCLI = evalue([M:AIMP]NOMGENEVA)
  Call COPCLI([M:AIMP]NOMGEN,YWFICCLI,YSTAT) From ORDSYS
  Call ECR_TRACE(func AFNC.MES1(mess(00055,00149,1)+"|", YWFICCLI),0) From GESECRAN : # The $1$ file has been sucessfully created
 Endif
Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA = 1
Endif

Return

#**
#*
#*
#* @param FIC_SRC Source file
#* @param FIC_DES_EVAL evaluate destination file generated
#* @param SEPFLD  Field separator
#* @param SEPREC  record séparateur
#* @param CODDBA coding text
#*                1 - ascii
#*                2 - UTF-8
#*                3 - UCS-2
#* @param STAT 0= OK
#*!
Subprog GENFIC(FIC_SRC,FIC_DES_EVAL,SEPFLD,SEPREC,CODDBA,STAT)
Value Char    FIC_SRC()
Value Char    FIC_DES_EVAL()
Value Char    SEPFLD()
Value Char    SEPREC()
Value Integer CODDBA

Variable Integer STAT

Raz STAT



Local Char SEPENR(30) : # Record separator
Local Integer CODDBA2  : # File type Type ascii or utf8
Local Integer I,J,K,L, YFSTAT, NBCOL,NBLIG
Local Clbfile LEC(2) : # reading line into the input file

[L]SEPENR = SEPREC
# \013\010
I = 1
$SEP
I = instr(1,SEPENR,"\")
If I
 SEPENR = left$(SEPENR,I-1)+chr$(val(mid$(SEPENR,I+1,3)))+right$(SEPENR,I+4)
 I += 1
 Goto SEP
Endif

Case CODDBA
 When 1 : CODDBA2 = GASCII
 When 2 : CODDBA2 = GUTF8
 When 3 : CODDBA2 = GUCS2
Endcase

Openi FIC_SRC Using [YIN]

Iomode adxifs SEPFLD Using [YIN]
Iomode adxirs [L]SEPENR Using [YIN]
Iomode adxium [L]CODDBA2 Using [YIN]

Openi FIC_SRC Using [YIN2]

Iomode adxifs "" Using [YIN2]
Iomode adxirs [L]SEPENR Using [YIN2]
Iomode adxium [L]CODDBA2 Using [YIN2]

Openo evalue([L]FIC_DES_EVAL),0 Using [YOUT]

Iomode adxifs SEPFLD Using [YOUT]
Iomode adxirs [L]SEPENR Using [YOUT]
Iomode adxium [L]CODDBA2 Using [YOUT]

Rdseq LEC Using [YIN2]
If fstat
 STAT = 1 : Goto END_FIC
Endif
J=1 : NBCOL=0
Repeat
 I = instr(J,LEC,SEPFLD)
 J = I+1
 If I>0
  NBCOL+=1
 Endif
Until I=0
NBCOL+=1

Openi Using [YIN2]

Local Char COL_TYP(200)(1..NBCOL) : # First line into the input file : B      A     R
Local Integer COL_NB : # Nomber of columns into the input file
Local Char COL(200)(1..NBCOL) : # Table of reading columns

YFSTAT = 0
NBLIG=0


While YFSTAT=0
 If NBLIG=0 : # First line
  Rdseq [L]COL_TYP Using [YIN]
  YFSTAT = fstat
 Else
  Rdseq [L]COL Using [YIN]
  YFSTAT =fstat
  If COL(1)="C" : Goto NEXT_LEC : Endif
 Endif

 If YFSTAT=0 : NBLIG+=1 : Endif
 If NBCOL<=1
  STAT = 1 : Break
 Endif
 If NBLIG>1 & YFSTAT=0 & COL(2)<>"" : # delete the empty lines
  Gosub ECR_YOUT
 Endif
 $NEXT_LEC
Wend
If STAT=0
  Wrseq  Using [YOUT] : # End of file
Endif
$END_FIC
Openi Using [YIN]
Openi Using [YIN2]
Openo Using [YOUT]
End


#**
#* To write all the columns to the ouput file from a singlu input line
#*!
$ECR_YOUT
J=0
For [L]I = 2 To [L]NBCOL : # Not I=1 , not the first colomns contents "C" for comment or blank
  Gosub ECR_COL
Next

Return

#**
#* To write a single column
#*!
$ECR_COL
If COL(I) = [L]COL_TYP([L]I) & COL(I)<>""
 J = I : # indice of A, B , R
Elsif [L]COL_TYP([L]I)<>"" & COL(I)=""
 J=0
Endif

If J<>0 & COL(I)=COL(J)
  If !(I=2 & NBLIG=2)
   Wrseq  Using [YOUT] : # end of line
  Endif
Endif
If J<> 0 & COL(J)<>""
 Wrseq COL([L]I), Using [YOUT]
Endif
Return

### Fields actions

# this actions are the same into the script GIMPOBJ
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif

End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

If VALEUR=1
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL

End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()

#control de la valeur [espace]chemin relatif
#calcul du chemin absolu
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]NOMIMP,E_TYPE_FILEREAD,GMESSAGE)
[M:AIMP]NOMGEN = evalue([M:AIMP]NOMGENEVA)
Affzo [M:AIMP]NOMGEN
End

Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
 If [M:AIMP]TYPEXP=1
   mkstat=2
   Grizo [M:AIMP] VOLFIL
 Endif
End

Subprog AM_NOMGENEVA(VALEUR)
Variable Char VALEUR()
[M:AIMP]NOMGEN = evalue(VALEUR)
Affzo [M:AIMP]NOMGEN
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran AIFIMPGENFIC) 29/01/2016 15:30:01 (OMA)
######################################################################################
Subprog C_NOMIMP(VALEUR)
Variable Char    VALEUR()
End


######################################################################################

