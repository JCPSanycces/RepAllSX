######################################################################################

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE | [M:MFG2]CPNTYP(nolign-1) = 5 : Return : Endif
Call INIT_CCE(VALEUR,AXE,"MFM","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If [M:MFG2]CPNTYP(nolign-1) = 5 :  mkstat=2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date du jour au lieu de [0/0/0]
Local Date WDATE : WDATE = date$
If [M:MFG2]CPNTYP(nolign-1) = 5 : Return : Endif
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return


