#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
## Programme de traitement de l'onglet matière des O.F      SUBMFG2    ##
#########################################################################
## écrit en Septembre 1998 par LLC                                     ##
#########################################################################
# Issue X3-6311 - 2017-06-22 by BAKHA : if versiond product, ask before you exclude or reinstate
# Issue X3-25054/1 - 2017-07-07 by BAKHA : get reason for exclude/reinstate for auditing
# Issue X3-47100 - 2017-07-20 by BAKHA : Remove button for audit history enquiry
# Issue X3-48941 - 2017-08-01 by BAKHA : use new GMFGREV parameter for writing audit
# Issue X3-55832 - 2017-09-13 by BAKHA : before checking versioning fields, make sure Versioning is in use
# Issue X3-55431 - 2017-09-15 by BAKHA : Display Revision history button when needed

$ACTION
Case ACTION
 When "AB6_NBLIG"     : Return
 When "BB6_NBLIG"     : Gosub BB6_NBLIG    # Issue 113364 by BEEBE : Button 6 - manual allocation
 When "AB13_NBLIG"    : Gosub MEM_VCR
 When "AB14_NBLIG"    : Gosub AB14_NBLIG   # FQ 64658 GA 07/2010 tunnel Article-site
 When "BB14_NBLIG"    : Gosub BB14_NBLIG   # FQ 64658 GA 07/2010 tunnel Article-site
Endcase
Return
###########################################################################
##
$OUVRE
Global Integer WLIGART
Global Integer MMODIF
Global Decimal GAVAMFG : GAVAMFG = 9999999999
Return

########################################################################
$FERME
Return

########################################################################
$APRES_MODIF
MMODIF=1
Return

###########################################################################
## Action technique de définition du filtre de lecture
$DEFLIG
FICLIG = "MFGMAT" : ABLIG = "MFM"
# sr 05.02 performances
[G:MFM]currind = 1
[G:MFM]currlen = 0

Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Decimal WDIS
Local Integer WRET
Local Integer I : I=0
Local Integer L

# Issue 119469 GH 04/11/2016 - performance enhancement
#Effzo [MFG2]10
Raz [M:MFG2]ITMERRCOD, [M:MFG2]ITMERRMSG
Raz [M:MFG2]ECCERRCOD, [M:MFG2]ECCERRMSG

[M:MFG2]NBLIG = 0
For [MFM]MFM0 Where MFGNUM=[M:MFG0]MFGNUM
#    llc 03.01 8593
    nolign = I + 1
    [M:MFG2] = [F:MFM]
    [M:MFG2]XMATSTA(I) = mess([M:MFG2]MATSTA(I),363,1)
    If [M:MFG2]CPNTYP(I) = 5
       [M:MFG2]XMATSTA(I) = mess(38,198,1)
    Endif
#    [M:MFG2]CPNTYP(I)    =[F:MFM]CPNTYP
#    [M:MFG2]ITMREF(I)    =[F:MFM]ITMREF
#    [M:MFG2]BOMOPE(I)    =[F:MFM]BOMOPE
#    [M:MFG2]STU(I)       =[F:MFM]STU
#    [M:MFG2]STOMGTCOD(I) =[F:MFM]STOMGTCOD
#    [M:MFG2]RETQTY(I)    =[F:MFM]RETQTY
#    [M:MFG2]STDQTY(I)    =[F:MFM]STDQTY
#    [M:MFG2]RETDAT(I)    =[F:MFM]RETDAT
#    [M:MFG2]USEQTY(I)    =[F:MFM]USEQTY
#    [M:MFG2]ALLQTY(I)    =[F:MFM]ALLQTY
#    [M:MFG2]ALLSTA(I)    =[F:MFM]ALLSTA
#    [M:MFG2]SHTQTY(I)    =[F:MFM]SHTQTY
    # Issue 87587 si et seulement si article géré en stock
    If [F:ITF]STOFCY<>[M:MFG0]MFGFCY | [F:ITF]ITMREF<>[F:MFM]ITMREF
      Read [ITF]ITF0=[F:MFM]ITMREF;[M:MFG0]MFGFCY
      If fstat : Raz [F:ITF] : Endif
    Endif
    If [M:MFG2]CPNTYP(I) <> 5 & [F:ITF]STOMGTCOD=2
        # recherche stock disponible site
        Call LECITV2([M:MFG0]MFGFCY,[F:MFM]ITMREF,WRET) From MFGLIB
        #--- Issue 115110 & 120456 : Added LECCVAL parameter in 10th position
        #Call STODISALL([M:MFG0]MFGFCY,[F:MFM]ITMREF,10,1,2,1,2,"","",WDIS,WRET) From STKALL
        Call STODISALL([M:MFG0]MFGFCY,[F:MFM]ITMREF,func TRTX3FNC.VALFLD_C("[M:MFG2]ECCVALMAJ("+num$(I)+")"),WDIS) From MFGLIBM
        [M:MFG2]AVAQTY(I)    = WDIS + [F:MFM]ALLQTY                    # llc 09.02 15756
    Else
        [M:MFG2]AVAQTY(I)=0
    Endif
    #
#    [M:MFG2]MFGLIN(I)    =[F:MFM]MFGLIN
    [M:MFG2]MEMLIN(I)    =[F:MFM]MFGLIN            # (correction llc 09.00)
    If [M:MFG2]MFGLIN(I) = 0
        [M:MFG2]MFGLINK(I) = 1
    Else
        [M:MFG2]MFGLINK(I) = 2
    Endif
#   [M:MFG2]PLANNER(I)   =[F:MFM]PLANNER
#   [M:MFG2]PICPRN(I)    =[F:MFM]PICPRN
#   If dim([M:MFG2]PKC(I)) > 0 : [M:MFG2]PKC(I)  =[F:MFM]PKC  : Endif  # hcb le 240101

#    [M:MFG2]BOMSEQ(I)    =[F:MFM]BOMSEQ
#    [M:MFG2]BASQTY(I)    =[F:MFM]BASQTY
#    [M:MFG2]QTYCOD(I)    =[F:MFM]QTYCOD
#    [M:MFG2]LIKQTYCOD(I) =[F:MFM]LIKQTYCOD
#    [M:MFG2]QTYRND(I)    =[F:MFM]QTYRND
#    [M:MFG2]LIKQTY(I)    =[F:MFM]LIKQTY
#    [M:MFG2]CUMFLG(I)    =[F:MFM]CUMFLG
#    [M:MFG2]CUMFXDQTY(I) =[F:MFM]CUMFXDQTY
#    [M:MFG2]BOMSHO(I)    =[F:MFM]BOMSHO
#    [M:MFG2]MFMTEX(I)    =[F:MFM]MFMTEX
#    [M:MFG2]SCA(I)       =[F:MFM]SCA
#    [M:MFG2]RELSCATIA(I) =[F:MFM]RELSCATIA
#    [M:MFG2]BOMOFS(I)    =[F:MFM]BOMOFS
#    [M:MFG2]STOMGTCOD(I) =[F:MFM]STOMGTCOD
#    [M:MFG2]LOT(I)       =[F:MFM]LOT
#    [M:MFG2]STA(I)       =[F:MFM]STA
#    [M:MFG2]LOC(I)       =[F:MFM]LOC
#    [M:MFG2]PRPSTA(I)    =[F:MFM]PRPSTA
#    [M:MFG2]MFMTRKFLG(I) =[F:MFM]MFMTRKFLG
#    [M:MFG2]SCOFLG(I)    =[F:MFM]SCOFLG
#    [M:MFG2]WIPNUM(I)    =[F:MFM]WIPNUM
#    [M:MFG2]MATSTA(I)    =[F:MFM]MATSTA
    [M:MFG2]XMATSTA(I)   = mess([M:MFG2]MATSTA(I),363,1)
    # process 03.03 MM
    If dim([M:MFG2]BOMUOM(I))>0
      If [M:MFG2]BOMUOM(I)=""
         [M:MFG2]BOMUOM(I)=[F:MFM]STU
         [M:MFG2]BOMSTUCOE(I)=1
         [M:MFG2]BOMQTY(I)=[F:MFM]LIKQTY
      Endif
    Endif
    # Fin process 03.03 MM

    If [M:MFG2]CPNTYP(I) <> 5
        Read [ITM]ITM0=[F:MFM]ITMREF
        If fstat : Raz [F:ITM] : Endif

        #[M:MFG2]ITMDES1(I)=[F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFG2]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        # (titres llc 130)
        If [F:ITM]STOMGTCOD <> 3
            If dim([M:MFG2]TYPQTY(I)) > 0 : [M:MFG2]TYPQTY(I) = 2 : Endif
        Else
            If dim([M:MFG2]DEFPOT(I)) > 0  : [M:MFG2]DEFPOT(I) = [F:ITM]DEFPOT : Endif
            If dim([M:MFG2]TYPQTY(I))  > 0 : [M:MFG2]TYPQTY(I)  = 1 : Endif
            If dim([M:MFG2]RETQTY2(I)) > 0
                [M:MFG2]RETQTY2(I) = ([M:MFG2]RETQTY(I) * 100) / [M:MFG2]DEFPOT(I)
                Call QTEARR([M:MFG2]RETQTY2(I),[M:MFG2]STU(I)) From TRTDIV
                If dim([M:MFG2]TYPQTY2(I)) > 0 :  [M:MFG2]TYPQTY2(I) = 2 : Endif
            Endif
        Endif

        # lecture encours pour récupérer le n° affaire
        Read [ORD]ORD0=6;[F:MFM]WIPNUM;[F:MFM]ITMREF
        If !fstat
            [M:MFG2]PJT(I)     = [F:ORD]PJT
            [M:MFG2]BOMALT(I)  = [F:ORD]BOMALT
        Endif
        #----- Chargement sections analytiques -----#
        Call CHARG_ACCCCE(I,"","","[M:MFG2]CCE","MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT
        # V6 Règle affectation
        [M:MFG2]PTOCOD(I) = func ITMLIB.GET_PTOCOD([F:MFM]ITMREF,[M:MFG0]MFGFCY)

        # Issue 107513
        WRET=0
        Call CONTMATITM([M:MFG2]ITMREF(I), [M:MFG0]MFGFCY, "MFG2", WRET, [M:MFG2]ITMERRMSG(I)) From MFGLIB
        [M:MFG2]ITMERRCOD(I) = WRET

        # Issue 119469 GH 04/11/2016 - performance enhancement
        If dim([M:MFG2]ECCVALMAJ)>0
           Call CTRECC([M:MFG2]ITMREF(I),"MFG2","STRDAT",[M:MFG2]ECCVALMAJ(I),[M:MFG2]ECCVALMIN(I),
&                      [M:MFG2]RETDAT(I),WRET,[M:MFG2]ECCERRMSG(I)) From ECCLIB
           [M:MFG2]ECCERRCOD(I) = WRET
        Endif

        # Issue 110957 - 2015-09-17 by CCC
        If dim([M:MFG2]CRID)>0 & varmode([M:MFG2]CRID(I))<>3
            [M:MFG2]CRID(I) = func TRTX3FNC.CCMID([M:MFG2]ITMREF(I),
&                                                        func TRTX3FNC.VALFLD_C("[M:MFG2]ECCVALMAJ("+num$(I)+")"),
&                                                        func TRTX3FNC.VALFLD_C("[M:MFG2]ECCVALMIN("+num$(I)+")"))
            If dim([M:MFG2]CRFLG)>0
                [M:MFG2]CRFLG(I) = string$([M:MFG2]CRID(I)<>"","151")
            Endif
        Endif

    Endif
    # Issue X3-25054 - 2017-07-13 by JUSYN : Initialise REVCOD
    If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
      If GMFGREV=2 : # Issue X3-54274 - 2017-09-12 by GH : test added in order not to crash for a folder with no versioning
       [M:MFG2]REVCOD(I) = 0
      Endif
    Endif # Issue X3-55832
    I+=1
Next

[M:MFG2]NBLIG        =I
[M:MFG2]MFGEXTQTY    =[M:MFG1]MFGEXTQTY
GAVAMFG = 9999999999
Call MAJ_AVAMFGQTY("MFG2") From MFGLIBM    # llc 06.04

Call UPDATE_FDMA(0)    # X3-3999 Display the first date of availability of each component

#
#    llc 08.01 10038
#If GSORT = 0 : Call TRI_MAT("S") From MFGLIBM : Else : Call TRI_MAT("O") From MFGLIBM : Endif
#

# Issue 119469 GH 04/11/2016 - performance enhancement
#Gosub LIENS From SUBMFG2ECC
#Affzo [M:MFG2]
#Call HIGHLIGHT("MFG2", -1) From ECCLIB
Return


# X3-3999
#**----------------------------------------------------------------<br/>
#* UPDATE_FDMA : Display the first date of availability of each component
#**<br/>----------------------------------------------------------------<br/>
#* @param PAFF = 1 : force to Affzo the field
#**<br/>----------------------------------------------------------------
#*!
Subprog UPDATE_FDMA(PAFF)
Value Integer PAFF
If !(dim([M:MFG2]FDMA)>0 & varmode([M:MFG2]FDMA)<>3) : End : Endif

Local Instance FDMA Using C_MFGFDMA      # X3-3999 To test => delete
Local Integer WRET
Local Integer I,J,L
Local Integer LLIN
Local Decimal LQTA
Local Date STKFDMA

# for debugging purpose, change to displayed the hidden fields STKFDMA and STKQTY
J = (dim([M:MFG2]STKFDMA)>0 & varmode([M:MFG2]STKFDMA)<>3)
L = (dim([M:MFG2]STKQTY)>0 & varmode([M:MFG2]STKQTY)<>3)
If J | L
    Local Decimal WQTY
    For I=0 To [M:MFG2]NBLIG-1
        # Calculate first date of availability when taking into account stock, assignment and expected receipts
        WQTY = max(0,[M:MFG2]RETQTY(I)-[M:MFG2]USEQTY(I)-[M:MFG2]ALLQTY(I))
        Call CAL_FDMA([M:MFG0]MFGFCY,[M:MFG2]ITMREF(I),10,[M:MFG0]MFGNUM,[M:MFG2]MFGLIN(I),[M:MFG2]BOMSEQ(I), 2, WQTY,[L]LQTA,[L]STKFDMA) From STKLIB
        If J
           [M:MFG2]STKFDMA(I) = [L]STKFDMA
        Endif
        If L
           [M:MFG2]STKQTY(I) = [L]LQTA
        Endif
    Next
    If PAFF & J
       Affzo [MFG2]STKFDMA
    Endif
    If PAFF & L
       Affzo [MFG2]STKQTY
    Endif
Endif

# X3-3999 Display the first date of availability
LLIN=0
# Issue X3-65500 - 2017-11-23 by ALSHE : Calculate FDMA for all components at once - not for each released product separate
FDMA = NewInstance C_MFGFDMA AllocGroup null
WRET = fmet FDMA.INITIALIZE([M:MFG0]MFGNUM,LLIN,[M:MFG0]MFGFCY,"00:00:00")
If FDMA.COMFDMAS <> null & maxtab(FDMA.COMFDMAS) > 0
   For J=0 To [M:MFG2]NBLIG-1
        # X3-64451 - STWIL - Don't blank previous FDMA fields.
        #Raz [M:MFG2]FDMA(J)
        For I = 1 To maxtab(FDMA.COMFDMAS)
            If find(FDMA.COMFDMAS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
&               & ([M:MFG2]ITMREF(J)=FDMA.COMFDMAS(I).ITMREF & [M:MFG2]BOMOPE(J)=FDMA.COMFDMAS(I).OPENUM & [M:MFG2]BOMSEQ(J)=FDMA.COMFDMAS(I).BOMSEQ)
                [M:MFG2]FDMA(J) = FDMA.COMFDMAS(I).FDMA
                If PAFF
                   Affzo [M:MFG2]FDMA(J)
                Endif
                Break
            Endif
        Next
   Next
Endif
FreeGroup FDMA
End

#########################################################################
## Modification des lignes
#########################################################################
$MODIF
Local Integer I
Local Integer J : J=0
Local Char    WIPMEM(GLONVCR)(GMFMMAX) # FQ 59777 GA 11/2009 avant (15)(GMFMMAX) # 7761 llc 01.01
Local Integer WRETOUR,K
Local Char    WNUMTEX (12)
Local Integer L         : # pour sections analytiques
Local Integer KLIN
Local Integer WEXISTE
# Issue X3-25054 - 2017-07-07 by JUSYN : Field to set revision code
Local Shortint WREVCOD : WREVCOD = 0
# Issue X3-25054 - 2017-07-07 by JUSYN : END
#
Local Shortint WUPDWEI  # X3-84111 - JOBRO - 2018-05-09

Gosub DEFLIG

For I=0 To [M:MFG2]NBLIG-1
    nolign = I + 1
    Case [M:MFG2]MFGLINK(I)                       # (correction llc 09.00)
        When 1:    KLIN = [M:MFG2]MEMLIN(I)     # (correction llc 09.00)
        When 2:    KLIN = [M:MFG2]MFGLIN(I)     # (correction llc 09.00)
    Endcase                                     # (correction llc 09.00)
    Readlock [MFM]MFM0=[M:MFG0]MFGNUM;KLIN;[M:MFG2]BOMSEQ(I);[M:MFG2]ITMREF(I)     # (correction llc 09.00)
    If fstat=1 : GOK=-1 : GLOCK="$"+FICLIG-num$(I) : Break : Endif
    WEXISTE = fstat
    #----- Mise à jour statistiques matière -----#
    If fstat = 0
        Call VALSTA("MFM",-1) From SUBPS2 : If GOK<1 : Break : Endif
    Endif

#
# Issue X3-25054 - 2017-07-07 by JUSYN : Write component/material auditing record
#   WEXISTE 0 = record already exists
#   WEXISTE 5 = new record
    If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
      Case WEXISTE
          When 0: WREVCOD = 2 # Modify
          When 2: WREVCOD = 2 # Modify
          When 5: WREVCOD = 1 # Add
      Endcase
      If WREVCOD = 2
          If [M:MFG2]MATSTA(I) = 4 & [F:MFM]MATSTA < 3 :  WREVCOD = 3  : Endif   # 3 # Excluded (Cancelled)
          If [M:MFG2]MATSTA(I) < 3 & [F:MFM]MATSTA = 4 :  WREVCOD = 4  : Endif   # 4 # Reinstate
      Endif

      # Issue X3-48941 - use new global parameter for audit
      If GMFGREV=2 & find(WREVCOD,2,3,4) & func ECCLIB.CTRECCPROD(I)=1 & [M:MFG2]REVCOD(I) > 0
      # Issue X3-48941 - 2017-08-24 by JUSYN : Set automatic revision reason if BOM reload
          If find([M:MFG2]MFGLIN(I),GMFGLINVCH) > 0
              [M:MFG2]REVREASON(I) = mess(405,193,1)   # BOM has been reloaded
          Endif
          Call HISTO_REVMFG ("MMR", WREVCOD, I, "G") From TRTREVMFG
      Endif
    Endif # Issue X3-55832
# Issue X3-25054 - 2017-07-07 by JUSYN : End
#
   # llc 9728
   If [M:MFG2]MATSTA(I) < 3 & [M:MFG2]ALLSTA(I) > 3
      If [F:MFM]LOC <> [M:MFG2]LOC (I)
           Call MESSAGE(mess(156,190,1)+"("+[F:MFM]ITMREF+")") From GESECRAN
      Endif
      # 06.06 demande 35052
      If [F:MFM]RETDAT <> [M:MFG2]RETDAT(I)
         If clalev([F:STA]) = 0 : Local File STOALL  [STA]  : Endif
         Update [F:STA]  Where VCRTYP = 10 & VCRNUM = [F:MFM]MFGNUM &
&                        VCRLIN = [F:MFM]MFGLIN & VCRSEQ = [F:MFM]BOMSEQ &
&                        ITMREF = [F:MFM]ITMREF
&                        With BESDAT = [M:MFG2]RETDAT(I)
      Endif
   Endif

   #X3-84111.sn - JOBRO - may need to update weighing statuses
   If func AFNC.ACTIV("MWM") & [M:MFG2]RETQTY(I)>[F:MFM]RETQTY & [M:MFG2]RETQTY(I)>[F:MFM]USEQTY &
&     WEXISTE=0 & [F:MFM]PKC>1 & [F:MFM]WGGSTA>1
     [F:MFM]WGGSTA = 1
      If [F:MFM]WGGBOX=2 : [F:MFM]WGGBOX=1 : Endif
      WUPDWEI=1
   Endif
   #X3-84111.en

#    llc 03.01 8593
   [F:MFM] = [M:MFG2]                        # llc 11.01 11146

#   process 03.04 MM
    If dim([M:MFG2]BOMUOM(I))<0    # UML inactif
        [F:MFM]BOMUOM =[M:MFG2]STU(I)
        [F:MFM]BOMSTUCOE=1
        [F:MFM]BOMQTY=[M:MFG2]LIKQTY(I)
    Endif

   [F:MFM]MFGFCY        =[M:MFG0]MFGFCY
   [F:MFM]MFGSTA        =[M:MFG0]MFGSTA
#
   [F:MFM]CPNTYP        =[M:MFG2]CPNTYP(I)
   [F:MFM]ITMREF        =[M:MFG2]ITMREF(I)
   [F:MFM]BOMOPE        =[M:MFG2]BOMOPE(I)
   [F:MFM]STU           =[M:MFG2]STU(I)
   [F:MFM]STOMGTCOD     =[M:MFG2]STOMGTCOD(I)
   [F:MFM]RETQTY        =[M:MFG2]RETQTY(I)
   [F:MFM]STDQTY        =[M:MFG2]STDQTY(I)
   [F:MFM]RETDAT        =[M:MFG2]RETDAT(I)
   [F:MFM]USEQTY        =[M:MFG2]USEQTY(I)
   [F:MFM]ALLQTY        =[M:MFG2]ALLQTY(I)
   [F:MFM]ALLSTA        =[M:MFG2]ALLSTA(I)
   [F:MFM]SHTQTY        =[M:MFG2]SHTQTY(I)
   [F:MFM]MFGLIN        =[M:MFG2]MFGLIN(I)
   [F:MFM]PLANNER       =[M:MFG2]PLANNER(I)
   [F:MFM]PICPRN        =[M:MFG2]PICPRN(I)

   If dim([M:MFG2]PKC(I)) > 0 : [F:MFM]PKC  = [M:MFG2]PKC(I)  : Endif  # hcb le 240101
    If [F:MFM]CPNTYP <> 5
        # l article ne rentre pas en centrale de pesée si gestion serie   (hcb 06 11 01 )
        Read [ITM]ITM0=[F:MFM]ITMREF
        If fstat : Raz [F:ITM] : Endif
        If [F:ITM]SERMGTCOD > 1 [F:MFM]PKC  = 1 : Endif
    Endif
    #
   [F:MFM]BOMSEQ        =[M:MFG2]BOMSEQ(I)
   [F:MFM]BASQTY        =[M:MFG2]BASQTY(I)
   [F:MFM]QTYCOD        =[M:MFG2]QTYCOD(I)
   [F:MFM]LIKQTYCOD     =[M:MFG2]LIKQTYCOD(I)
   [F:MFM]QTYRND        =[M:MFG2]QTYRND(I)
   [F:MFM]LIKQTY        =[M:MFG2]LIKQTY(I)
   [F:MFM]CUMFLG        =[M:MFG2]CUMFLG(I)
   [F:MFM]CUMFXDQTY     =[M:MFG2]CUMFXDQTY(I)
   [F:MFM]BOMSHO        =[M:MFG2]BOMSHO(I)
   [F:MFM]MFMTEX        =[M:MFG2]MFMTEX(I)
   [F:MFM]SCA           =[M:MFG2]SCA(I)
   [F:MFM]RELSCATIA     =[M:MFG2]RELSCATIA(I)
   [F:MFM]BOMOFS        =[M:MFG2]BOMOFS(I)
   [F:MFM]STOMGTCOD     =[M:MFG2]STOMGTCOD(I)
   [F:MFM]LOT           =[M:MFG2]LOT(I)
   [F:MFM]STA           =[M:MFG2]STA(I)
   [F:MFM]LOC           =[M:MFG2]LOC(I)
   If dim([M:MFG2]DEFPOT(I)) > 0 : [F:MFM]DEFPOT        =[M:MFG2]DEFPOT(I) : Endif   # (titres llc 130)
#
   [F:MFM]PRPSTA        =[M:MFG2]PRPSTA(I)
   [F:MFM]MATSTA        =[M:MFG2]MATSTA(I)
   [F:MFM]MFMTRKFLG     =[M:MFG2]MFMTRKFLG(I)
   # CCC (2009-10-27) Bug 56688 : Si la matière est soldée (matsta=3), mfmtrkflg doit être au moins égal à 5 (soldé)
   If [F:MFM]MATSTA=3
      [F:MFM]MFMTRKFLG =max(5,[M:MFG2]MFMTRKFLG(I))
   Endif
   [F:MFM]SCOFLG        =[M:MFG2]SCOFLG(I)
   [F:MFM]MFGPIO        =[M:MFG1]MFGPIO
#
   #---------------------------------------------#
   # nouvelle gestion des textes                 #
   #---------------------------------------------#
   If [M:MFG2]MFMTEX(I) <> ""
      [F:MFM]MFMTEX  = [M:MFG2]MFMTEX(I)
      If left$([F:MFM]MFMTEX,3)="MFM"
          Call CRE_CLOB([F:MFM]MFMTEX,GOK) From TRTX3TEX
      Elsif left$([F:MFM]MFMTEX,3) <> "BOD"
          Call DUP_CLOB("MFM",[F:MFM]MFMTEX,GOK) From TRTX3TEX
      Endif
   Endif
   If    WEXISTE=0
        # (llc 05.00) si matières cumulées en modif, ligne à 0
        If [M:MFG2]MFGLINK(I) = 1 : [F:MFM]MFGLIN = 0 : Endif
        If [F:MTS]MODALL > 1 & [M:MFG0]MFGSTA = 1 & GMEMSTA = 2
            Case [F:MTS]MODALL
                When 2: Call UPDATE_MFX("U", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 2) From MFGLIBM # llc 10.00 bug 6553
                When 3: Call UPDATE_MFX("U", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 3) From MFGLIBM # llc 10.00 bug 6553
            Endcase
        Else
            Call UPDATE_MFX("U", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 1) From MFGLIBM             # llc 10.00 bug 6553
        Endif

        [F:MFM]UPDDAT = date$
        [F:MFM]UPDUSR = GUSER
        [F:MFM]EXPNUM = [C]EXPORT
        # Issue 91336 GA 09/2014 Rewrite [MFM]
        Gosub REWRITE_MFM From MFGAUTLIB
        WIPMEM(J) = [F:MFM]WIPNUM
        J+=1
   Elsif WEXISTE = 5
        [F:MFM]MFGNUM        =[M:MFG0]MFGNUM
        [F:MFM]PLNFCY        =[M:MFG0]PLNFCY
        # sr 07.02 Tenir compte du statut de l'OF pour allouer demande 15034
        Case [F:MTS]MODALL
            When 1: Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 0) From MFGLIBM
            When 2: If [M:MFG0]MFGSTA = 1
                        Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 2) From MFGLIBM
                    Else
                        Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 0) From MFGLIBM
                    Endif
            When 3: If [M:MFG0]MFGSTA = 1
                        Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 3) From MFGLIBM
                    Else
                        Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 0) From MFGLIBM
                    Endif
        Endcase

        GOK = 1        # 10.08
        [F:MFM]CREDAT = date$
        [F:MFM]CREUSR = GUSER
        [F:MFM]EXPNUM = [C]EXPORT
        If dim([F:MFM]WGGSTA) > 0
           [F:MFM]WGGSTA = 1
           [F:MFM]WGGBOX = 1  # mm 12.10
        Endif

        # Issue 91336 GA 09/2014 Write [MFM]
        Gosub WRITE_MFM From MFGAUTLIB
        WIPMEM(J) = [F:MFM]WIPNUM
        J+=1
        # Issue X3-25054 - 2017-07-07 by JUSYN : Auditing: insert new record.
        # Issue X3-48941 - use new global parameter for audit
        If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
          If GMFGREV=2 & find(WREVCOD,1) & func ECCLIB.CTRECCPROD(I)=1 & [M:MFG2]REVCOD(I) > 0
            # Issue X3-48941 - 2017-08-16 by JUSYN : Set automatic revision reason if BOM reload
            If WREVCOD=1
                If find([M:MFG2]MFGLIN(I),GMFGLINVCH) > 0
                    [M:MFG2]REVREASON(I) = mess(405,193,1)   # BOM has been reloaded
                Endif
            Endif
            Call HISTO_REVMFG ("MMR", WREVCOD, I, "G") From TRTREVMFG
          Endif
        Endif # Issue X3-55832
   Endif
   #----- Ecriture des sections de la ligne matière -----#
   If [F:MFM]CPNTYP <> 5
       Call MAJMFM_CPTANALIN(WEXISTE)
   Endif

   #----- Mise à jour statistiques matière -----#
   Call VALSTA("MFM",1) From SUBPS2 : If GOK<1 : Break : Endif
Next I

# Purge des matières non prévues et exclues ou remplacées
For [MFM]MFM0 Where MFGNUM=[M:MFG0]MFGNUM  & CPNTYP <> 5 With Lock
    If !find([F:MFM]WIPNUM,[M:MFG2]WIPNUM(0..[M:MFG2]NBLIG-1)) &
&      !find([F:MFM]WIPNUM,WIPMEM(0..J-1))
#&     !find([F:MFM]WIPNUM,WIPMEM(0..dim(WIPMEM)-1)) # GH 13/12/2013 bug 91148

        # Issue 118057 - 2016-12-14 by STLIG : Update/delete corresponding allocations [F:MFM]ALLSTA>1
        #                                      before deletion of old material.
        #Call UPDATE_MFX("A", "", "", [F:MFM]ALLSTA>1) From MFGLIBM
        # Issue 120704 GH 04/01/2017 - crashed with type incompatibility
        Call UPDATE_MFX("A", "", 0, [F:MFM]ALLSTA>1) From MFGLIBM

        If [F:MFM]MFMTEX <> "" & left$([F:MFM]MFMTEX,3) = "MFM"
           Call SUP_CLOB([F:MFM]MFMTEX,WRET) From TRTX3TEX
        Endif
        # Issue X3-25054 - 2017-07-14 by JUSYN : write critical changes into auditing table
        # Issue X3-48941 - use new global parameter for audit
        If GMFGREV=2
            If dim([M:MFG1]ECCVALMAJ) > 0
                I = find([F:MFM]MFGLIN,[M:MFG1]MFGLIN)
                If I>0 & [M:MFG1]ECCVALMAJ(I-1)<>""
                    Call HISTO_REVMFG ("MMR",3 , 0, "E") From TRTREVMFG
                Endif
            Endif
        Endif
        # Issue X3-25054 - 2017-07-14 by JUSYN : END
        Delete [MFM]
        #----- Suppression des sections de la ligne matière -----#
#        Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN &
#&                    VCRSEQ = [F:MFM]BOMSEQ & CPLCLE = [F:MFM]ITMREF
        # Issue 119469 GH 04/11/16 - performance enhancement
        Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN
&                        & VCRSEQ=[F:MFM]BOMSEQ & CPLCLE=[F:MFM]ITMREF & VCRTYP=0
        If fstat=1
          GOK=-1 : GLOCK="$CPTANALIN MFM 0"-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
          Break # FQ 69909 Ctrl des sources avant Return
        Endif
        #----- Mise à jour statistiques matière -----#
        Call VALSTA("MFM",-1) From SUBPS2 : If GOK<1 : Break : Endif
    Endif
Next
# llc 01.03 17227
For [ORD]ORD3 Where STOFCY=[M:MFG0]MFGFCY & VCRTYP = 10 & VCRNUM = [M:MFG0]MFGNUM & WIPTYP = 6
    If !find([F:ORD]WIPNUM,[M:MFG2]WIPNUM(0..[M:MFG2]NBLIG-1)) &
&      !find([F:ORD]WIPNUM,WIPMEM(0..J-1))
#&     !find([F:ORD]WIPNUM,WIPMEM(0..dim(WIPMEM)-1)) # GH 13/12/2013 bug 91148
       # suppression encours
       [M:ORDK]MAJCOD     = "A"
       [M:ORDK]WIPTYP     = 6
       [M:ORDK]WIPNUM     = [F:ORD]WIPNUM
       [M:ORDK]ITMREF     = [F:ORD]ITMREF
       Call WIP From TRTWIP
    Endif
Next
# 06.09 55573
Readlock [MFG]MFG0=[M:MFG0]MFGNUM
If fstat GOK=0 : Call FSTA("MFG") From GLOCK : Return : Endif

GAVAMFG = 9999999999
Call  MAJ_AVAMFGQTY("MFM") From MFGLIBM

#X3-84111.sn - JOBRO - may need to update weighing statuses
If WUPDWEI
  If [F:MFG]WGGSTA>1 : [F:MFG]WGGSTA = 1 : Endif
  If [F:MFG]WGGFLG>3 : [F:MFG]WGGFLG = 2 : Endif
Endif
#X3-84111.en

Rewrite [MFG]

If fstat GOK=0 : Call FSTA("MFG") From GLOCK : Return : Endif
# Issue number - 2017-08-17 by JUSYN : reset array of product line numbers for which a BOM load has been done
Raz GMFGLINVCH
Return

###########################################################################
## Création des lignes
#   HCB le 26 11 01  si une modif est faite dans "CREATION" ne pas
#                    oublier de la repercuter aussi dans le programme
#                    CNSMWHSTD dans "TRT_ANNULATION"   merci !
#########################################################################
$CREATION
Local Integer I
Local Integer WRETOUR,K
Local Char WNUMTEX (12)
Local Integer L         : # pour sections analytiques

Raz [F:MFM]                        # 10.04

For I=0 To [M:MFG2]NBLIG-1
#    llc 03.01 8593
    nolign = I + 1
    [F:MFM] = [M:MFG2]

#   process 03.04 MM
    If dim([M:MFG2]BOMUOM(I))<0    # UML inactif
        [F:MFM]BOMUOM =[M:MFG2]STU(I)
        [F:MFM]BOMSTUCOE=1
        [F:MFM]BOMQTY=[M:MFG2]LIKQTY(I)
    Endif

    [F:MFM]MFGNUM        =[M:MFG0]MFGNUM
    [F:MFM]MFGSTA        =[M:MFG0]MFGSTA
    [F:MFM]PLNFCY        =[M:MFG0]PLNFCY
    [F:MFM]MFGFCY        =[M:MFG0]MFGFCY
#
    [F:MFM]CPNTYP        =[M:MFG2]CPNTYP(I)
    [F:MFM]ITMREF        =[M:MFG2]ITMREF(I)
    [F:MFM]BOMOPE        =[M:MFG2]BOMOPE(I)
    [F:MFM]STU           =[M:MFG2]STU(I)
    [F:MFM]STOMGTCOD     =[M:MFG2]STOMGTCOD(I)
    [F:MFM]RETQTY        =[M:MFG2]RETQTY(I)
    [F:MFM]STDQTY        =[M:MFG2]STDQTY(I)
    [F:MFM]RETDAT        =[M:MFG2]RETDAT(I)
    [F:MFM]USEQTY        =[M:MFG2]USEQTY(I)
    [F:MFM]ALLQTY        =[M:MFG2]ALLQTY(I)
    [F:MFM]ALLSTA        =[M:MFG2]ALLSTA(I)
    [F:MFM]SHTQTY        =[M:MFG2]SHTQTY(I)
    [F:MFM]MFGLIN        =[M:MFG2]MFGLIN(I)
    [F:MFM]PLANNER       =[M:MFG2]PLANNER(I)
    [F:MFM]PICPRN        =[M:MFG2]PICPRN(I)

    If dim([M:MFG2]PKC(I)) > 0 : [F:MFM]PKC  = [M:MFG2]PKC(I)  : Endif  # hcb le 240101

    If [F:MFM]CPNTYP <> 5
        # l article ne rentre pas en centrale de pesée si gestion serie   (hcb 06 11 01 )
        Read [ITM]ITM0=[F:MFM]ITMREF
        If fstat : Raz [F:ITM] : Endif
        If [F:ITM]SERMGTCOD > 1 [F:MFM]PKC  = 1 : Endif
    Endif
    #
    [F:MFM]BOMSEQ        =[M:MFG2]BOMSEQ(I)
    [F:MFM]BASQTY        =[M:MFG2]BASQTY(I)
    [F:MFM]QTYCOD        =[M:MFG2]QTYCOD(I)
    [F:MFM]LIKQTYCOD     =[M:MFG2]LIKQTYCOD(I)
    [F:MFM]QTYRND        =[M:MFG2]QTYRND(I)
    [F:MFM]LIKQTY        =[M:MFG2]LIKQTY(I)
    [F:MFM]CUMFLG        =[M:MFG2]CUMFLG(I)
    [F:MFM]CUMFXDQTY     =[M:MFG2]CUMFXDQTY(I)
    [F:MFM]BOMSHO        =[M:MFG2]BOMSHO(I)
    [F:MFM]MFMTEX        =[M:MFG2]MFMTEX(I)
    [F:MFM]SCA           =[M:MFG2]SCA(I)
    [F:MFM]RELSCATIA     =[M:MFG2]RELSCATIA(I)
    [F:MFM]BOMOFS        =[M:MFG2]BOMOFS(I)
    [F:MFM]STOMGTCOD     =[M:MFG2]STOMGTCOD(I)
    [F:MFM]LOT           =[M:MFG2]LOT(I)
    [F:MFM]STA           =[M:MFG2]STA(I)
    [F:MFM]LOC           =[M:MFG2]LOC(I)
    If dim([M:MFG2]DEFPOT(I)) > 0 : [F:MFM]DEFPOT        =[M:MFG2]DEFPOT(I)  : Endif   # (titres llc 130)
#
    [F:MFM]PRPSTA        =[M:MFG2]PRPSTA(I)
    [F:MFM]MATSTA        =[M:MFG2]MATSTA(I)
    [F:MFM]MFMTRKFLG     =[M:MFG2]MFMTRKFLG(I)
    [F:MFM]SCOFLG        =[M:MFG2]SCOFLG(I)
    [F:MFM]MFGPIO        =[M:MFG1]MFGPIO
#
    Case [F:MTS]MODALL
        When 1: Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 0) From MFGLIBM
        When 2: If [M:MFG0]MFGSTA = 1
                    Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 2) From MFGLIBM
                Else
                    Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 0) From MFGLIBM
                Endif
        When 3: If [M:MFG0]MFGSTA = 1
                    Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 3) From MFGLIBM
                Else
                    Call UPDATE_MFX("C", [M:MFG2]PJT(I), [M:MFG2]BOMALT(I), 0) From MFGLIBM
                Endif
    Endcase

    GOK = 1            # 10.08

    #---------------------------------------------#
    # nouvelle gestion des textes                 #
    #---------------------------------------------#
    If [M:MFG2]MFMTEX(I) <> ""
       [F:MFM]MFMTEX  = [M:MFG2]MFMTEX(I)
       If left$([F:MFM]MFMTEX,3)="MFM"
           Call CRE_CLOB([F:MFM]MFMTEX,GOK) From TRTX3TEX
       Elsif left$([F:MFM]MFMTEX,3) <> "BOD"
           Call DUP_CLOB("MFM",[F:MFM]MFMTEX,GOK) From TRTX3TEX
       Endif
    Endif

    [F:MFM]CREDAT = date$
    [F:MFM]CREUSR = GUSER
    [F:MFM]EXPNUM = [C]EXPORT

    If dim([F:MFM]WGGSTA) > 0
      [F:MFM]WGGSTA = 1
      [F:MFM]WGGBOX = 1  # mm 12.10
    Endif


    Write [MFM]
    If fstat : GOK=0 : Call FSTA("MFM") From GLOCK : Break : Endif
    #----- Ecriture des sections de la ligne matière -----#
     If [F:MFM]CPNTYP <> 5
         Call MAJMFM_CPTANALIN(1)
     Endif
    #----- Mise à jour statistiques matière -----#
    Call VALSTA("MFM",1) From SUBPS2 : If GOK<1 : Break : Endif
Next I

# 06.09 55573
Readlock [MFG]MFG0=[M:MFG0]MFGNUM
If fstat : GOK=0 : Call FSTA("MFG") From GLOCK : Return : Endif

GAVAMFG = 9999999999
Call  MAJ_AVAMFGQTY("MFM") From MFGLIBM

Rewrite [MFG]
If fstat : GOK=0 : Call FSTA("MFG") From GLOCK : Return : Endif
Return

###########################################################################
## Annulation des lignes
#########################################################################
# La suppression des matières liées à un article lancé est gérée dans
# VALLIG (Gosub UPDATE_MAT)
# La purge ci-dessous est utile au cas ou des matières "non prévues"
# sont attachées à l'OF
$ANNULE
Local Integer WRET
For [MFM]MFM0 Where MFGNUM=[M:MFG0]MFGNUM With Lock
    Call UPDATE_MFX("A","",0,1) From MFGLIBM

    If [F:MFM]MFMTEX <> "" & left$([F:MFM]MFMTEX,3) = "MFM"
        Call SUP_CLOB([F:MFM]MFMTEX,WRET) From TRTX3TEX
    Endif
    Delete [MFM]
    #----- Suppression des sections de la ligne matière -----#
#    Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN &
#&                VCRSEQ = [F:MFM]BOMSEQ & CPLCLE = [F:MFM]ITMREF
    # Issue 119469 GH 04/11/16 - performance enhancement
    Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN
&                    & VCRSEQ=[F:MFM]BOMSEQ & CPLCLE=[F:MFM]ITMREF & VCRTYP=0
    If fstat=1
       GOK=-1 : GLOCK="$CPTANALIN MFM 0"-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
       Break # FQ 69909 Ctrl des sources avant Return
    Endif
    #----- Mise à jour statistiques matière -----#
    Call VALSTA("MFM",-1) From SUBPS2 : If GOK<1 : Break : Endif
Next
Return


###########################################################################
#---------------------------------------------------------#
# Ecriture des sections de la ligne matière               #
#---------------------------------------------------------#
Subprog MAJMFM_CPTANALIN(WEXISTE)
Value Integer WEXISTE
# Issue 104346 GA 02/2015 always check existence sending code "M" to ENREG_ACCCE
###If WEXISTE = 0
###    # FQ 69971 GA 12/2010 Vérifier si la clé n'a pas changé ([F:MFM]MFGLIN maj si cumul matières)
###    Read [CAL] CAL0="MFM";0;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:MFM]ITMREF;1
###    If !fstat
###       Call ENREG_ACCCCE(nolign-1,"","","[M:MFG2]CCE","MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF,"M") From TRTX3CPT
###    Else
###      # FQ 69971 GA 12/2010
###      #----- Suppression des anciennes sections de la ligne matière car changement de clé -----#
###       Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & (VCRLIN=[F:MFM]MFGLIN | [F:MFM]MFGLIN=0)  &
###&                VCRSEQ = [F:MFM]BOMSEQ & CPLCLE = [F:MFM]ITMREF
###       If fstat=1
###          GOK=-1 : GLOCK="$CPTANALIN MFM 0"-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF: Return
###       Endif
###      # Issue 104346 GA 02/2015 always check sending code "M" to ENREG_ACCCE
###       Call ENREG_ACCCCE(nolign-1,"","","[M:MFG2]CCE","MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF,"C") From TRTX3CPT
###    Endif
###Else
###   # Issue 104346 GA 02/2015 always check sending code "M" to ENREG_ACCCE
###    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG2]CCE","MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF,"C") From TRTX3CPT
###Endif
If WEXISTE = 0
      # FQ 69971 GA 12/2010
      #----- Suppression des anciennes sections de la ligne matière car changement de clé -----#
#       Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & (VCRLIN=[F:MFM]MFGLIN | [F:MFM]MFGLIN=0)  &
#&                VCRSEQ = [F:MFM]BOMSEQ & CPLCLE = [F:MFM]ITMREF
       # Issue 119469 GH 04/11/16 - performance enhancement
       Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & (VCRLIN=[F:MFM]MFGLIN | [F:MFM]MFGLIN=0)
&                       & VCRSEQ=[F:MFM]BOMSEQ & CPLCLE=[F:MFM]ITMREF & VCRTYP=0
       If fstat=1
          GOK=-1 : GLOCK="$CPTANALIN MFM 0"-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF: Return
       Endif
Endif
# Issue 104346 GA 02/2015 always check existence sending code "M" to ENREG_ACCCE
Call ENREG_ACCCCE(nolign-1,"","","[M:MFG2]CCE","MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF,"M") From TRTX3CPT

End

###########################################################################
## Etiquettes de l'écran
###########################################################################

Subprog C_NBLIG
Local Integer NOL
#
# pour bug moteur
If [M:MFG2]NBLIG > 0
  If [M:MFG2]ITMREF([M:MFG2]NBLIG-1) = "" & [M:MFG2]CPNTYP([M:MFG2]NBLIG-1) <> 5
    status=65 : nolign=[M:MFG2]NBLIG
    Dela [M:MFG2]NBLIG-1,1,[M:MFG2]NBLIG-1 [M:MFG2]NBLIG : [M:MFG2]NBLIG-=1
  Endif
Endif
GMODIF=2    # pour bug moteur
Case status
    When 75:          NOL=nolign-1                    # Modification
                      Gosub TEST_MOD
    When 82:          NOL=nolign-1                    # Reprise
                      GMODIF=1    # pour bug moteur
                      mkstat=2
Endcase
End

########################################
$TEST_MOD
If [M:MFG2]MATSTA(nolign-1) > 2 : mkstat=2 : Endif # si matière exclue,soldée
Return

########################################
Subprog IB_NBLIG
If GACTION = "MFMFAN"
    If !func ECCLIB.ERRCOD("MFMF",nolign-1)
        Raz GBOUT2     # Information
    Endif
Else
    Local Integer I, NBITM
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT5 = ""    # 46332 mm 03.08
    GBOUT6 = ""    # 46332 mm 03.08

    GBOUT8 = ""
    GBOUT9 = ""
    GBOUT10 = ""
    GBOUT11 = ""
    GBOUT12 = ""
    GBOUT13 = ""
    GBOUT14 = ""   # FQ 64658 RAZ boutons Article-Site
    # Issue X3-55431 - set Revision history button if needed
    GBOUT16 = ""

    If dim([M:MFG1]ECCVALMAJ) > 0
      If GMFGREV = 2 & [M:MFG2]ITMREF(nolign-1) <> "" & [M:MFG2]REVCOD(nolign-1) <> 1 & func ECCLIB.CTRECCPROD(nolign-1)=1 & GREP <> "C"
        GBOUT16 = mess(174,195,1) # Revision history
      Endif
    Endif
    # End issue X3-55431

    # pas de matières
    If dim([M:MFG2]ITMREF) < (nolign + 1) : mkstat = 2 : End : Endif
    If !find([M:MFG0]MFGMOD,1,2) : End : Endif

    If [M:MFG2]CPNTYP(nolign-1) <> 5
        GBOUT5 = mess(427,198,1)        # allocation globale   # 17724 03.03 MM
        GBOUT6 = mess( 33,191,1)        # allocation manuelle - 46332 mm 03.08
    Endif

    # 44409 mm 06.08 - matière en cours de pesée, on interdit de désallouer + 49229
    # 85521 mm 10.12 - WGGBOX géré pour la pesée par OF :
    # c'est lui qui porte l'info "matière en cours de pesée box" à la place de WGGSTA
    If find([M:MFG2]MATSTA(nolign-1),1,2) & [M:MFG2]ALLSTA(nolign-1) >= 4
        Read [MFM]MFM0=[M:MFG0]MFGNUM;[M:MFG2]MFGLIN(nolign-1);[M:MFG2]BOMSEQ(nolign-1);[M:MFG2]ITMREF(nolign-1)
        If !fstat
            #If dim([F:MFM]WGGSTA)>0
            If dim([F:MFM]WGGBOX)>0
                If [MFM]WGGBOX = 2 : Raz GBOUT6 : Endif
            Endif
        Endif
    Endif

    # boutons
    # 12.05 gestion des liens de type texte
    If [M:MFG2]ITMREF(nolign-1) <> "" | [M:MFG2]CPNTYP(nolign-1) = 5
        # bouton tri tableau matières
        Case GSORT
            When 0: GBOUT1 = mess(172,198,1)
            When 1: GBOUT1 = mess(171,198,1)
        Endcase

        # fenêtre détail
        GBOUT2 = mess(84,195,1)


        # si matière exclue: réactivation
        # llc 01.03 16965

        If [M:MFG2]MATSTA(nolign-1) = 4
           If find([M:MFG1]WORTYP,2,4)  : GBOUT3 = mess(185,198,1) : Endif
        Else
           If [M:MFG2]CPNTYP(nolign-1) = 5
                GBOUT3 = mess(182,198,1)
           Else
               Case [M:MFG2]ALLSTA(nolign-1)
                    When 1 :         If find([M:MFG1]WORTYP,2,4) & [M:MFG2]MATSTA(nolign-1) = 1
                                        GBOUT3 = mess(182,198,1)                         # exclure
                                     Endif
                                     GBOUT7 = ""
                    When Default:    GBOUT7 = mess(426,198,1)                            # voir allocation
               Endcase
            Endif
        Endif
        If [M:MFG2]CPNTYP(nolign-1) <> 5
            # stock projeté
            If clalev([M:SPR2])<= 0 : GBOUT8 = mess(157,198,1): Endif            # 47661 mm 06.08

            # si statut ferme: etat suivi
            If [M:MFG0]MFGSTA = 1 : GBOUT10 = mess(242,198,1) : Endif

            # article/site
            GBOUT11= mess(456,198,1)
            If [M:MFG0]MFGSTA = 1 & [M:MFG2]MATSTA(nolign-1) < 3 : GBOUT13 = mess(467,198,1) : Endif

        Else
            GBOUT5 = ""
            GBOUT6 = ""
            GBOUT7 = ""
        Endif

        # texte
        GBOUT9 =  mess(38,198,1)

        # si consultation, pas d'exclusion, pas d'allocation
        If GCONSLCT = 1
            GBOUT3 = ""
            GBOUT5 = ""
            GBOUT6 = ""
        Endif

        # si création/modif pas d'allocation
        If GREP <> ""
            GBOUT5 = ""
            GBOUT6 = ""
        Endif

        # statut non ferme, pas d'allocation
        If [M:MFG0]MFGSTA <> 1
            GBOUT5 = ""
            GBOUT6 = ""
            GBOUT7 = ""
        Endif

        # si matière soldée, pas d'allocation, ni d'exclusion
        If [M:MFG2]MATSTA(nolign-1) = 3
            GBOUT3 = ""
            GBOUT5 = ""
            GBOUT6 = ""
            GBOUT7 = ""
        Endif

        # si matière exclue, pas d'allocation    # llc 12.01
        If [M:MFG2]MATSTA(nolign-1) = 4
            GBOUT5 = ""
            GBOUT6 = ""
            GBOUT7 = ""
        Endif


        # si OF à l'étude, pas d'allocation ni d'exclusion
        # ISSUE X3-30339 - 2017-04-07 By ALSHE : Release WO managed by PS - hide "Exclude line"
        If [M:MFG1]MFGTRKFLG = 2 | (func AFNC.ACTIV("POPS") & [M:MFG1]SCDFLG=4)
            GBOUT3 = ""
    # 05.05 30050
    #        GBOUT5 = ""
    #        GBOUT6 = ""
    #        GBOUT7 = ""
        Endif

        # si allocation détail, on ne propose pas allocation globale
        If [M:MFG2]ALLSTA(nolign-1) > 3 : GBOUT5 = "" : Endif

        # si allocation globale sans rupture, pas d'allocation globale
        If [M:MFG2]ALLSTA(nolign-1) = 3 : GBOUT5 = "" : Endif
        # Ctrl autorisation bouton allocation manuelle
        If !find (GREP, "C", "D") & GBOUT6 <> "" & [M:MFG2]CPNTYP(nolign-1) <> 5
            GBIDC2="A": GFCY=[M:MFG0]MFGFCY : Gosub AUTORIS_OPT From CONTX3
            If !GBIDI2 : Raz GBOUT6  : Endif
        Endif

        # FQ 64658 Article-Site - Objet ITF
        # Pour éviter Tunnel de tunnel en boucle !
        If [M:MFG2]ITMREF(nolign-1) <> "" & !find("GESITF",GNAVIG(1..GPILNAV))
           GBOUT14 = mess(4,198,1)
        Endif

    Else
        GBOUT1 = ""

        If find([M:MFG1]WORTYP,2,4)
            GBOUT2 = mess(180,198,1)                        # ajout matière non prévue
            GBOUT12 = mess(412,198,1)                       # ajout sous-ensemble
        Endif

        # si OF multi-articles, pas d'ajout de sous-ensemble
        NBITM = 0
        For I = 0 To [M:MFG1]NBLIG - 1
            If [M:MFG1]ITMTYP(I) = 1 : NBITM += 1 : Endif
        Next I
        If NBITM > 1 : GBOUT12 = "" : Endif

        # si consultation, pas d'ajout
        If GCONSLCT = 1
            GBOUT2 = ""
            GBOUT12 = ""
        Endif

        # si OF clos, pas d'ajout
        Case [M:MFG0]MFGSTA
            When 4         : GBOUT2 = "" : GBOUT12 = "" # clôs
            When Default   : # rien
        Endcase

        # si OF à l'étude ou soldé+PRF
        Case [M:MFG1]MFGTRKFLG
            When 2,6         : GBOUT2 = ""  : GBOUT12 = "" # soldé + prf
            When Default   : # rien
        Endcase

        # ISSUE X3-30339 - 2017-04-07 By ALSHE : Release WO managed by PS - hide buttons "Adding material" and  "Adding sub-assembly"
        If func AFNC.ACTIV("POPS") & ([M:MFG1]MFGTRKFLG=2 | [M:MFG1]SCDFLG=4)
            GBOUT2 = "" : GBOUT12 = ""
        Endif

        # RAZ boutons allocation
        GBOUT5 = ""
        GBOUT6 = ""
        GBOUT7 = ""

    Endif

    Call IB_NBLIG From SUBMFG2ECC       # 107513 hide buttons (adding material, adding sub-assembly, exclude)

    If !func ECCLIB.ERRCOD("MFG2",nolign-1)
        Raz GBOUT15     # Information
    Endif
Endif
End

########################################
Subprog B1_NBLIG
# pour forcer la sortie du mode commande sur NBLIG
# (pour la mise à jour du texte du bouton) on force mkstat à 99
# cela permet: a) d'activer l'action disponible contextuellement
#              b) d'économiser 1 action
If [M:MFG2]NBLIG = 0 : End : Endif
Case GSORT
    When 0: Call TRI_MAT("O") From MFGLIBM : mkstat = 99
    When 1: Call TRI_MAT("S") From MFGLIBM : mkstat = 99
Endcase
#
If GSORT = 0 : GSORT = 1 : Else : GSORT = 0 : Endif

# Issue 119469 GH 04/11/16 - performance enhancement
#Affzo [M:MFG2]10        # llc 08.01 10038

Call HIGHLIGHT("MFG2",-1) From ECCLIB
mkstat=99 : # pour réinitialiser texte bouton

End

########################################
Subprog B3_NBLIG
Local    Decimal WBES
Local    Decimal LQTY
Local    Integer I, WRET, IOK
Local    Integer N : N = nolign-1

# Issue X3-6311 - if released product versioned, ask before you exclude or reinstate
# Issue X3-25054 - 2017-07-18 by JUSYN : Do not ask for Revision reasion if a non BOM components has to be excluded.
# Line will disappear without to enter a revision reason. A generated message 402/193 will be used instead.

If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  For I=0 To [M:MFG1]NBLIG-1
    If [M:MFG1]MFGLIN(I)=[M:MFG2]MFGLIN(N) : Break : Endif
  Next I
  If ([M:MFG1]ECCVALMAJ(I)<>"" & [M:MFG1]ITMTYP(I)=1)
    If !GREVMESSC
      GREVMESSC = 1
      GERR = 2
      GMESSAGE = mess(401,193,1) # You are about to do critical changes on a versioned product's components
    Endif

    # Issue X3-25054/1 - get revision reason
    # Issue X3-48941 - check audit parameter
    If GMFGREV=2
      Local Char PARAM(250)(1..20) , SAVACT(10)
      Local Char VALEUR(20)
      PARAM(1)= ""

      If [M:MFG2]BOMSEQ(N) > 0 & (([M:MFG2]MATSTA(N) < 3) | ([M:MFG2]MATSTA(N) = 4))
        SAVACT = GACTION : GACTION = "MFGREVREA"
        Call SAISIE_CHAR(VALEUR,PARAM,"OMFGR","SUBMFGR","") From GSAISIE
        GACTION = SAVACT
        If (PARAM(1) <> "")
          [M:MFG2]REVREASON(N) = PARAM(1)
          Affzo [M:MFG2]REVREASON(N)
        Else
          mkstat = 2
          End
        Endif
        # End issue X3-25054/1
      Endif
      # Issue X3-25054 - 2017-07-13 by JUSYN : Set revision code for critical change.
      If PARAM(1) <> "" & mkstat = 0
          If [M:MFG2]MATSTA(N) < 3  # YES
              [M:MFG2]REVCOD(N) = 4 # = Reinstate
          Elsif [M:MFG2]MATSTA(N) = 4
              [M:MFG2]REVCOD(N) = 3 # = Exclusion
          Endif
      Endif
    Endif
  # Issue X3-25054 - 2017-07-13 by JUSYN : End
  Endif
Endif # Issue X3-55832
# End issue X3-6311

# l'exclusion d'une matière est gérée par la mise à 0 de la quantité besoin
# pour l'instant on laisse la ligne affichée ...
# la réactivation implique le recalcul du besoin à partir des données initiales
# sr V150 Pour les lignes de type texte on ne touche qu'à MATSTA
If [M:MFG2]MATSTA(N) = 4
    If [M:MFG2]CPNTYP(N) = 5
        [M:MFG2]MATSTA(N) = 1
        [M:MFG2]XMATSTA(N) = mess([M:MFG2]MATSTA(N),363,1)
        Affzo [M:MFG2]XMATSTA(N)
    Else
        # 107513 - if a status error exist, it's not possible to reintegrate the component
        If find([M:MFG2]ITMERRCOD(N),1,4) : # Issue 116724 GH 22/06/2016 # find([M:MFG2]ITMERRCOD,1,4)
            Call ERRMSG("MFG2",N) From MFGLIB
            End
        Endif
    # recherche ligne article concernée
        For I=0 To [M:MFG1]NBLIG-1
            If [M:MFG1]MFGLIN(I)=[M:MFG2]MFGLIN(N) : Break : Endif
        Next I
        Case [M:MFG2]MFGLINK(N)
          When 1 :  LQTY     = [M:MFG1]MFGEXTQTY
          When 2 :  LQTY     = [M:MFG1]EXTQTY(I)
        Endcase
        If [M:MFG2]LIKQTYCOD(N) = 2 : [M:MFG2]CUMFXDQTY(N) -= [M:MFG2]RETQTY(N) : Endif
        If [M:MFG2]LIKQTY(N) <> 0
        # calcul quantité besoin
            Call CALCUL_BESOIN([M:MFG2]BASQTY(N),[M:MFG2]STU(N),[M:MFG2]LIKQTYCOD(N),
&                      [M:MFG2]LIKQTY(N),[M:MFG2]QTYRND(N),[M:MFG2]SCA(N),[M:MFG2]RELSCATIA(N), WBES,LQTY) From MFGLIBM
            [M:MFG2]RETQTY(N) = WBES + [M:MFG2]CUMFXDQTY(N)
        Else
            [M:MFG2]RETQTY(N) = [M:MFG2]CUMFXDQTY(N)
        Endif
        If [M:MFG2]LIKQTYCOD(N) = 2 : [M:MFG2]CUMFXDQTY(N) += [M:MFG2]RETQTY(N) : Endif
        [M:MFG1]DMATNBR  += 1
        [M:MFG2]MATSTA(N) = 1
        [M:MFG2]XMATSTA(N) = mess([M:MFG2]MATSTA(N),363,1)
        Affzo [M:MFG2]XMATSTA(N)
        Affzo [M:MFG2]RETQTY(N)
    Endif
Else
    If [M:MFG2]CPNTYP(N) = 5
       [M:MFG2]MATSTA(N) = 4
       [M:MFG2]XMATSTA(N) = mess([M:MFG2]MATSTA(N),363,1)
       Affzo [M:MFG2]XMATSTA(N)
# cas matière non prévue
    Else
        If !find(GREP,"C","D")
            Call CHECK_FRCQTY([M:MFG0]MFGFCY, [M:MFG2]ITMREF(N), 10, [M:MFG0]MFGNUM, [M:MFG2]MFGLIN(N), [M:MFG2]BOMSEQ(N), 6, WRET) From MTOLINKLIB
            If WRET
                # lecture règle si nécessaire
                If [F:PTO]PTOCOD <> [M:MFG2]PTOCOD(N)
                    Read [PTO]PTO0=[M:MFG2]PTOCOD(N)
                    If fstat : Raz [F:PTO] : Endif
                Endif
                If [F:PTO]FRCPRO <> 2
                    IOK = 1
                    Call OUINON(mess(228,190,1),IOK) From GESECRAN
                    If IOK <> 2 :  mkstat = 2 : End : Endif
                Endif
            Endif
        Endif
        If [M:MFG2]BOMSEQ(N) = 0
            # suppression de la ligne
            Dela N,1 [M:MFG2]NBLIG
            # mise à jour NBLIG et réaffichage
            [M:MFG2]NBLIG     -= 1
            [M:MFG1]DMATNBR   -= 1
        Else
            [M:MFG2]MATSTA(N) = 4
            [M:MFG2]XMATSTA(N) = mess([M:MFG2]MATSTA(N),363,1)
            Affzo [M:MFG2]XMATSTA(N)
            [M:MFG1]DMATNBR   -= 1
        Endif
        Affzo [M:MFG2]10
    Endif
Endif
# pour réinitialiser texte bouton
mkstat=4
End

########################################
# allocation globale (llc 08.01 9147)
Subprog B5_NBLIG
Local Integer L : L = nolign-1

Call ALLOC_MAT(L) From MFGLIBM
mkstat = 99

End

########################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If GMODMAT =1 : mkstat = 2 : Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Char     WFCY(GLONFCY)
Local Integer  I

# 107513
Call CONTMATITM(VALEUR, [M:MFG0]MFGFCY, "MFMW", GERR, GMESSAGE) From MFGLIB
If find(GERR,4,1)
    GERR=1
    mkstat=2
    End
Endif

# GH 09/01/2015 bug 105215
# V6 Règle affectation
#[M:MFG2]PTOCOD(nolign-1) = func ITMLIB.GET_PTOCOD(VALEUR,[M:MFG0]MFGFCY)

# Issue 106222 - 2015-02-12 by CCC : If by-product don't check in components
If [M:MFMW]CPNTYP<>4
    For I=0 To [M:MFG2]NBLIG-1
        If [M:MFG2]BOMSEQ(I)=0 & [M:MFG2]ITMREF(I) = VALEUR
          GMESSAGE = mess(67,193,1)
          mkstat = 2
          Break
        Endif
    Next I
Endif

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Decimal WBES
Local    Decimal LQTY
Local    Integer L : L = nolign-1
#
#[M:MFMW]ITMDES1    = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFMW]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MFMW]STU        = [F:ITM]STU
[M:MFMW]STOMGTCOD  = [F:ITM]STOMGTCOD
MMODIF = 1

# (titres llc v130)
If dim([M:MFMW]DEFPOT) > 0
    [M:MFMW]DEFPOT = [F:ITM]DEFPOT
Endif
If [M:MFMW]RETQTY <> 0 & [F:ITM]STOMGTCOD = 3
    If dim([M:MFMW]RETQTY2) > 0
        [M:MFMW]RETQTY2 = ([M:MFMW]RETQTY * 100) /[M:MFMW]DEFPOT
        Call QTEARR([M:MFMW]RETQTY2,[M:MFMW]STU) From TRTDIV
        Affzo [M:MFMW]RETQTY2
    Endif
    End
Endif

# mm 05.12 82100
# ajout d'un composant non prévu
If ![M:MFMW]MFGLIN
    LQTY=[M:MFG1]MFGEXTQTY
Else
    # remplacement d'un composant existant
    Read [MFI]MFI0 = [M:MFG0]MFGNUM;[M:MFMW]MFGLIN
    # Issue 113368 - 2016-01-07 by BEEBE : after "Replace" of ITMREF is MFGLIN > 0, but row MFI
    #                                      doesn´t exist, LQTY will be initialized with a correct value
    If !fstat
        LQTY=[F:MFI]EXTQTY
    Else
        LQTY=[M:MFG1]MFGEXTQTY
    Endif
Endif
If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY : Endif
If [M:MFMW]LIKQTY <> 0
    Call CALCUL_BESOIN([M:MFMW]BASQTY,[M:MFMW]STU,[M:MFMW]LIKQTYCOD,[M:MFMW]LIKQTY,
&                  [M:MFMW]QTYRND,[M:MFMW]SCA,[M:MFMW]RELSCATIA,WBES,LQTY) From MFGLIBM
    [M:MFMW]RETQTY = WBES + [M:MFMW]CUMFXDQTY
Else
    [M:MFMW]RETQTY = [M:MFMW]CUMFXDQTY
Endif

If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY += [M:MFMW]RETQTY : Endif

# (titres llc v130)
If [F:ITM]STOMGTCOD = 3
    If dim([M:MFMW]RETQTY2) > 0
        [M:MFMW]RETQTY2 = ([M:MFMW]RETQTY * 100) /[M:MFMW]DEFPOT
        Call QTEARR([M:MFMW]RETQTY2,[M:MFMW]STU) From TRTDIV
    Endif
Endif

If instr(1,dbgstr(1),"MFMW")
    Call ANALYSE_LOC("MFMW", [M:MFG0]MFGFCY, [M:MFMW]BOMOPE,
&                    0, VALEUR) From MFGLIBM
    # (titres llc v130)
    If dim([M:MFMW]RETQTY2) > 0        # llc 03.02 13482
        If [M:MFMW]STOMGTCOD = 3
            [M:MFMW]XTYPQTY  = mess(1,2311,1)
            [M:MFMW]XTYPQTY2 = mess(2,2311,1)
            Affzo [M:MFMW]XTYPQTY
            Affzo [M:MFMW]XTYPQTY2
        Else
            Grizo [M:MFMW]RETQTY2
            Grizo [M:MFMW]XTYPQTY2
            [M:MFMW]XTYPQTY  = mess(2,2311,1)
            Affzo [M:MFMW]XTYPQTY
        Endif
    Endif
Else
    Call ANALYSE_LOC("MFG2", [M:MFG0]MFGFCY, [M:MFG2]BOMOPE(L),
&                    L, VALEUR) From MFGLIBM
Endif

Call AM_ITMREF(VALEUR) From SUBMFG2ECC

If !mkstat & dim([M]CRID)>0 & varmode([M]CRID)<>3 & func ECCLIB.NBRCPN(VALEUR)=0
    # Issue 110957 - 2015-09-17 by CCC
    If maskcou="MFMW" : L=0
    Else              : L=nolign-1
    Endif
    [M]CRID(L) = func TRTX3FNC.CCMID(VALEUR, "", "")
    Affzo [M]CRID(L)
    If dim([M]CRFLG)>0
        [M]CRFLG(L) = string$([M]CRID(L)<>"","151")
        Affzo [M]CRFLG(L)
    Endif
Endif
End

########################################
Subprog AS_MFGLINK(VALEUR)
Variable Integer VALEUR
If GMODMAT > 0 : mkstat = 2 : End : Endif : # Issue 119394 GH 23/12/2016 - addition of GMODMAT test
If [M:MFG1]NBLIG = 1 : VALEUR = 2 : [M:MFMW]MFGLIN = [M:MFG1]MFGLIN(0) :  mkstat = 2 : Endif
Call AS_MFGLINK(VALEUR) From SUBMFG2ECC
End

########################################
Subprog C_MFGLINK(VALEUR)
Variable Integer VALEUR
If VALEUR = 0 : mkstat=2 : End : Endif
End

########################################
Subprog AM_MFGLINK(VALEUR)
Variable Integer VALEUR
#
Case VALEUR
    When 1 : [M:MFMW]MFGLIN = 0 : Affzo [M:MFMW]MFGLIN : zonsui="QTYCOD"
    When 2 : # rien pour l'instant
Endcase
MMODIF = 1
End

########################################
Subprog AS_MFGLIN(VALEUR)
Variable Decimal VALEUR
Local Integer I

If GMODMAT > 0 : mkstat = 2 : End : Endif
# si matière non prévue, on demande si celle-ci est liée à l'OF ou
# à un article lancé particulier
# Ce choix devra être désactivé si le paramètre de la transaction
# "Multi-article autorisé ?" est à non, dans ce cas les matières non prévues
# sont toujours liées à la ligne 1000...
If [M:MFMW]MFGLINK <> 2 : mkstat = 2 : End : Endif
If [M:MFMW]MFGLINK = 2 & [M:MFG1]NBLIG = 1 : mkstat = 2 : End : Endif
If VALEUR <> 0 & [M:MFG1]NBLIG > 1 : End : Endif
# selbox sur les articles lancés si > 1, sinon ligne = première ligne
If [M:MFG1]NBLIG = 1
    VALEUR = [M:MFG1]MFGLIN(0)
    mkstat = 2
    End
Endif
End

########################################
Subprog C_MFGLIN(VALEUR)
Variable Decimal VALEUR
Local    Integer I

If [M:MFMW]MFGLINK <> 2 : End : Endif
If [M:MFG1]NBLIG    = 1 : End : Endif

I = find(VALEUR,[M:MFG1]MFGLIN(0..[M:MFG1]NBLIG-1))
If I=0 : mkstat=2 : End : Endif

# Issue 104862 - 2015-02-09 by FRHOL : In case of a by-product the MFGLIN has to be checked. A by-product couldn't be attached to another by-product
If [M:MFMW]CPNTYP = 4
  If [M:MFG1]ITMTYP(I-1) = 2
    GMESSAGE = mess(305, 193, 1)
    mkstat=2
    End
  Endif
Endif

# 81976
For I = 0 To [M:MFG1]NBLIG - 1
    If [M:MFG1]MFGLIN(I) = VALEUR : WLIGART = I : Endif
Next I

Call C_MFGLIN(VALEUR) From SUBMFG2ECC
End

########################################
Subprog AM_MFGLIN(VALEUR)
Variable Decimal VALEUR
Local    Decimal WBES
Local    Decimal LQTY

LQTY     = [M:MFG1]EXTQTY(WLIGART)
If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY : Endif
If [M:MFMW]LIKQTY <> 0
    Call CALCUL_BESOIN([M:MFMW]BASQTY,[M:MFMW]STU,[M:MFMW]LIKQTYCOD,[M:MFMW]LIKQTY,
&                  [M:MFMW]QTYRND,[M:MFMW]SCA,[M:MFMW]RELSCATIA,WBES,LQTY) From MFGLIBM
    [M:MFMW]RETQTY = WBES + [M:MFMW]CUMFXDQTY
Else
    [M:MFMW]RETQTY = [M:MFMW]CUMFXDQTY
Endif
If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY += [M:MFMW]RETQTY : Endif
Affzo [M:MFMW]RETQTY
Affzo [M:MFMW]CUMFXDQTY
MMODIF = 1
End

########################################
Subprog AS_QTYCOD(VALEUR)
Variable Integer VALEUR
If GMODMAT > 0 : mkstat = 2 : End : Endif
If [M:MFMW]MFGLINK = 1 : GMENLOC(5) = 1 : Endif
End

########################################
Subprog AM_QTYCOD(VALEUR)
Variable Integer VALEUR
Local    Decimal WBES
Local    Decimal LQTY
#
Case VALEUR
 When 1    : [M:MFMW]BASQTY = 1
 When 2, 4 : [M:MFMW]BASQTY = 100
 When 3    : [M:MFMW]BASQTY = 1000
 When 5    : # lot réappro du site de l'alternative s'il est renseigné
 Read [ITF]ITF0 = [M:MFG1]ITMREF(WLIGART);[M:MFG0]MFGFCY
 If !fstat : [M:MFMW]BASQTY = [F:ITF]MFGLOTQTY : Endif
 When Default : [M:MFMW]BASQTY = 1
Endcase
Affzo [M:MFMW]BASQTY
#
If [M:MFMW]RETQTY <> 0
    Case [M:MFMW]MFGLINK
      When 1 :  LQTY     = [M:MFG1]MFGEXTQTY
      When 2 :  LQTY     = [M:MFG1]EXTQTY(WLIGART)
    Endcase
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY : Endif
    If [M:MFMW]LIKQTY <> 0
        Call CALCUL_BESOIN([M:MFMW]BASQTY,[M:MFMW]STU,[M:MFMW]LIKQTYCOD,[M:MFMW]LIKQTY,
&                      [M:MFMW]QTYRND,[M:MFMW]SCA,[M:MFMW]RELSCATIA,WBES,LQTY) From MFGLIBM
        [M:MFMW]RETQTY = WBES + [M:MFMW]CUMFXDQTY
    Else
        [M:MFMW]RETQTY = [M:MFMW]CUMFXDQTY
    Endif
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY += [M:MFMW]RETQTY : Endif
    Affzo [M:MFMW]RETQTY
    Affzo [M:MFMW]CUMFXDQTY
Endif
#
End


########################################
Subprog AS_BASQTY(VALEUR)
Variable Decimal VALEUR
# initialisation de la quantité selon le code quantité
mkstat = 2 : # non saisissable sauf quand code "par lot"
Case [M:MFMW]QTYCOD
 When 1 : VALEUR = 1
 When 2 : VALEUR = 100
 When 3 : VALEUR = 1000
 When 4 : VALEUR = 100
 When 5 : # lot réappro du site de l'alternative s'il est renseigné
    mkstat = 0
    If [M:MFMW]BASQTY = 0 :
       VALEUR = 1
    Endif
    Read [ITF]ITF0 = [M:MFG1]ITMREF(WLIGART);[M:MFG0]MFGFCY
    If !fstat : VALEUR = [F:ITF]MFGLOTQTY : Endif
 When Default : VALEUR = 1
Endcase
#
End

########################################
Subprog AM_BASQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WBES
Local    Decimal LQTY

If [M:MFMW]RETQTY <> 0
    Case [M:MFMW]MFGLINK
      When 1 :  LQTY     = [M:MFG1]MFGEXTQTY
      When 2 :  LQTY     = [M:MFG1]EXTQTY(WLIGART)
    Endcase
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY : Endif
    If [M:MFMW]LIKQTY <> 0
        Call CALCUL_BESOIN(VALEUR,[M:MFMW]STU,[M:MFMW]LIKQTYCOD,[M:MFMW]LIKQTY,
&                      [M:MFMW]QTYRND,[M:MFMW]SCA,[M:MFMW]RELSCATIA,WBES,LQTY) From MFGLIBM
        [M:MFMW]RETQTY = WBES + [M:MFMW]CUMFXDQTY
    Else
        [M:MFMW]RETQTY = [M:MFMW]CUMFXDQTY
    Endif
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY += [M:MFMW]RETQTY : Endif
    Affzo [M:MFMW]RETQTY
    Affzo [M:MFMW]CUMFXDQTY
Endif
MMODIF = 1
End

