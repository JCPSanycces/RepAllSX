##########################################################################
Subprog C_BOMOPE(VALEUR)
Variable Decimal VALEUR
If instr(1,dbgstr(1),"MFMW")
   If  dim([M:MFMW]PKC) > 0 & VALEUR = 900 & !find([M:MFMW]PKC,0,1,8,9)
       GMESSAGE = mess(41,2324,1)
       mkstat = 2
       End
   Endif
Else
   If dim([M:MFG2]PKC(nolign-1)) > 0 & VALEUR = 900 & !find([M:MFG2]PKC(nolign-1),0,1,8,9)
       GMESSAGE = mess(41,2324,1)
       mkstat = 2
       End
   Endif
Endif
End


