########################################
Subprog AS_SCA(VALEUR)
Variable Decimal VALEUR
If [M:MFG2]CPNTYP(nolign-1) = 5 :  mkstat=2 : End : Endif
End


########################################
Subprog C_SCA(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AM_SCA(VALEUR)
Variable Decimal VALEUR
Local    Decimal WBES
Local    Decimal LQTY
Local    Integer L  : L = nolign-1
Local    Integer I
If instr(1,dbgstr(1),"MFMW")
    If [M:MFMW]RETQTY <> 0
        Case [M:MFMW]MFGLINK
            When 1 :  LQTY     = [M:MFG1]MFGEXTQTY
            When 2 :  LQTY     = [M:MFG1]EXTQTY(WLIGART)
        Endcase
        If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY : Endif
        If [M:MFMW]LIKQTY <> 0
            Call CALCUL_BESOIN([M:MFMW]BASQTY,[M:MFMW]STU,[M:MFMW]LIKQTYCOD,[M:MFMW]LIKQTY,
&                          [M:MFMW]QTYRND,VALEUR,[M:MFMW]RELSCATIA,WBES,LQTY) From MFGLIBM
            [M:MFMW]RETQTY = WBES  + [M:MFMW]CUMFXDQTY
        Else
            [M:MFMW]RETQTY = [M:MFMW]CUMFXDQTY
        Endif
        If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY += [M:MFMW]RETQTY : Endif
        Affzo [M:MFMW]RETQTY
        Affzo [M:MFMW]CUMFXDQTY
    Endif
    MMODIF = 1
Else
    If [M:MFG2]MFGLIN(L) = 0
        LQTY = [M:MFG1]MFGEXTQTY
    Else
        For I = 0 To [M:MFG1]NBLIG - 1
            If [M:MFG2]MFGLIN(L) = [M:MFG1]MFGLIN(I) : Break : Endif
        Next
        LQTY = [M:MFG1]EXTQTY(I)
    Endif
    If [M:MFG2]LIKQTYCOD(L) = 2 : [M:MFG2]CUMFXDQTY(L) -= [M:MFG2]RETQTY(L) : Endif
    If [M:MFG2]LIKQTY(L) <> 0
        Call CALCUL_BESOIN([M:MFG2]BASQTY(L),[M:MFG2]STU(L),[M:MFG2]LIKQTYCOD(L),
&                      [M:MFG2]LIKQTY(L),[M:MFG2]QTYRND(L),VALEUR,[M:MFG2]RELSCATIA(L),WBES,LQTY) From MFGLIBM
        [M:MFG2]RETQTY(L) = WBES  + [M:MFG2]CUMFXDQTY(L)
    Else
        [M:MFG2]RETQTY(L) = [M:MFG2]CUMFXDQTY(L)
    Endif
    If [M:MFG2]LIKQTYCOD(L) = 2 : [M:MFG2]CUMFXDQTY(L) += [M:MFG2]RETQTY(L) : Endif
    Affzo [M:MFG2]RETQTY(nolign-1)
Endif
End

########################################
Subprog AS_BOMSHO(VALEUR)
Variable Char    VALEUR()
If GMODMAT > 0 : mkstat = 2 : Endif
End


########################################
Subprog AM_BOMOFS(VALEUR)
Variable Decimal  VALEUR

Local    Date     WORIDAT   # FQ 69971 ctrl des sources par Eclipse avant Value
Local    Char     WORIFCY(GLONFCY)
Local    Integer  WLTI
Local    Date     WDSTDAT
#
# application du nouveau délai
If [M:MFG3]SCDFLG > 1 & [M:MFMW]BOMOPE <> 0 : End : Endif
WORIDAT    = [M:MFG1]STRDAT
WORIFCY    = [M:MFG0]MFGFCY
WLTI       = VALEUR

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB


[M:MFMW]RETDAT  = WDSTDAT
Affzo [M:MFMW]30
#
If instr(1,dbgstr(1),"MFMW") : MMODIF = 1 : Endif
End

########################################
Subprog C_RETQTY(VALEUR)
Variable Decimal VALEUR

# Issue 88151 - 2013-03-08 by CCC
#If VALEUR = 0 : End : Endif
# 02.05 28793
If instr(1,dbgstr(1),"MFMW")
    # Issue 88151 - 2013-03-08 by CCC
    #If VALEUR > 0 & VALEUR < [M:MFMW]USEQTY
    If VALEUR < [M:MFMW]USEQTY
        Call MESSAGE(mess(63,193,1)) From GESECRAN
        mkstat=2
        End
    Endif
Else
    # Issue 88151 - 2013-03-08 by CCC
    #If VALEUR > 0 & VALEUR < [M:MFG2]USEQTY(nolign-1)
    If VALEUR < [M:MFG2]USEQTY(nolign-1)
        Call MESSAGE(mess(63,193,1)) From GESECRAN
        mkstat=2
        End
    Endif
Endif

End

########################################
Subprog AM_RETQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCPL
Local    Decimal WEXT
Local    Integer WRET
Local    Integer L : L = nolign-1
Local    Integer VS

WEXT = VALEUR
# vérification seuil solde automatique atteint
If instr(1,dbgstr(1),"MFMW")
    WCPL = [M:MFMW]USEQTY
    Call CONT_SOLDE_MAT([M:MFG0]MFGFCY, [M:MFMW]ITMREF, WCPL, WEXT, WRET) From MFGLIBM
Else
    WCPL = [M:MFG2]USEQTY(L)
    Call CONT_SOLDE_MAT([M:MFG0]MFGFCY, [M:MFG2]ITMREF(L), WCPL, WEXT, WRET) From MFGLIBM
Endif

If WRET = 1
    VS=1
    Call AVERTIR(mess(53,190,1),VS) From GESECRAN
    If VS = 1
        If instr(1,dbgstr(1),"MFMW")
            VALEUR = [M:MFMW]RETQTY
        Else
            VALEUR = [M:MFG2]RETQTY(L)
        Endif
        mkstat = 2
        End
    Endif
    If instr(1,dbgstr(1),"MFMW")
        [M:MFMW]MATSTA = 3
        Diszo [M:MFMW]
    Else
        [M:MFG2]MATSTA(L)   = 3
        [M:MFG2]XMATSTA(L) = mess([M:MFG2]MATSTA(L),363,1)
        Affzo [M:MFG2]XMATSTA(L)
    Endif
Endif

If instr(1,dbgstr(1),"MFMW")
    If [M:MFMW]LIKQTYCOD = 2
        [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY
        [M:MFMW]CUMFXDQTY += VALEUR
        Affzo [M:MFMW]CUMFXDQTY
    Endif
    # (titres llc v130)
    If [M:MFMW]STOMGTCOD = 3
        If dim([M:MFMW]RETQTY2) > 0
            [M:MFMW]RETQTY2 = (VALEUR * 100) /[M:MFMW]DEFPOT
            Call QTEARR([M:MFMW]RETQTY2,[M:MFMW]STU) From TRTDIV
            Affzo [M:MFMW]RETQTY2
        Endif
    Endif
Else
    If [M:MFG2]LIKQTYCOD(L) = 2
        [M:MFG2]CUMFXDQTY(L) -= [M:MFG2]RETQTY(L)
        [M:MFG2]CUMFXDQTY(L) += VALEUR
    Endif
    If [M:MFG2]STOMGTCOD(L) = 3
        If dim([M:MFG2]RETQTY2(L)) > 0
            [M:MFG2]RETQTY2(L) = (VALEUR * 100) / [M:MFG2]DEFPOT(L)
            Call QTEARR([M:MFG2]RETQTY2(L),[M:MFG2]STU(L)) From TRTDIV
        Endif
    Endif
Endif

# Issue X3-25054 - 2017-07-13 by JUSYN : Set revision code for critical change.
If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If instr(1,dbgstr(1),"MFG2")
    # Issue X3-48941 - use new global parameter for audit
    If func ECCLIB.CTRECCPROD(L)=1 & VALEUR <> [M:MFG2]RETQTY(L)
      If GMFGREV=2
        [M:MFG2]REVCOD(L) = 2 # = Modify
      Endif
      # Issue X3-55431 - Display info message once after change
      If !GREVMESSC
        GREVMESSC = 1
        GERR = 2
        GMESSAGE = mess(411,193,1)
      Endif
      # End issue X3-55431
    Endif
  Endif
Endif # Issue X3-55832
# Issue X3-25054 - 2017-07-13 by JUSYN : End

MMODIF = 1

End

########################################
Subprog AM_RETDAT(VALEUR)
Variable Date    VALEUR

If VALEUR > [M:MFG1]ENDDAT
    Call ERREUR(mess(64,193,1)) From GESECRAN
    mkstat=2
    End
Endif
# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2) From MFGLIB

If instr(1,dbgstr(1),"MFMW") : MMODIF=1 : Endif
End

########################################
Subprog C_RETDAT(VALEUR)
Variable Date    VALEUR
#
If VALEUR = [0/0/0] : mkstat = 2 : End : Endif
If VALEUR > [M:MFG1]ENDDAT
    Call ERREUR(mess(64,193,1)) From GESECRAN
    mkstat=2
    End
Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MFG0]MFGFCY) From MFGLIB

End

########################################
Subprog AM_BOMOPE(VALEUR)
Variable Decimal VALEUR
Local    Integer L : L = nolign-1
Local    Integer I
Local    Date    WORIDAT, WDSTDAT
Local    Integer WLTI
Local    Char    WORIFCY(GLONFCY)
#
If instr(1,dbgstr(1),"MFMW")
    # 06.06 demande 36661
    Raz [M:MFMW]LOC
    Call ANALYSE_LOC("MFMW", [M:MFG0]MFGFCY, VALEUR, 0, [M:MFMW]ITMREF)    From MFGLIBM
    Call ANALYSE_STR("MFMW", VALEUR, L) From MFGLIBM
    If find(VALEUR,[M:MFG3]OPENUM(0..[M:MFG3]NBLIG-1))
        For I=0 To [M:MFG3]NBLIG-1
            If [M:MFG3]OPENUM(I) = VALEUR : Break : Endif
        Next I
        [M:MFMW]RETDAT = [M:MFG3]OPESTR(I)
    Else
        WORIDAT    = [M:MFG1]STRDAT
        WORIFCY    = [M:MFG0]MFGFCY
        WLTI       = [M:MFMW]BOMOFS
        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
        [M:MFMW]RETDAT  = WDSTDAT
    Endif
    Affzo [M:MFMW]RETDAT
 Else
    # 06.06 demande 36661
    Raz [M:MFG2]LOC(L)
    Call ANALYSE_LOC("MFG2", [M:MFG0]MFGFCY, VALEUR, L, [M:MFG2]ITMREF(L)) From MFGLIBM
    Call ANALYSE_STR("MFG2", VALEUR, L) From MFGLIBM
    If find(VALEUR,[M:MFG3]OPENUM(0..[M:MFG3]NBLIG-1))
        For I=0 To [M:MFG3]NBLIG-1
            If [M:MFG3]OPENUM(I) = VALEUR : Break : Endif
        Next I
        [M:MFG2]RETDAT(L) = [M:MFG3]OPESTR(I)
    Else
        WORIDAT    = [M:MFG1]STRDAT
        WORIFCY    = [M:MFG0]MFGFCY
        WLTI       = [M:MFG2]BOMOFS(L)
        Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB
        [M:MFG2]RETDAT(L)  = WDSTDAT
    Endif
    Affzo [M:MFG2]RETDAT(L)
Endif

# Issue X3-25054 - 2017-07-13 by JUSYN : Set revision code for critical change.
If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If instr(1,dbgstr(1),"MFG2")
    # Issue X3-48941 - use new global parameter for audit
    If func ECCLIB.CTRECCPROD(L)=1 & VALEUR <> [M:MFG2]BOMOPE(L)
      If GMFGREV=2
        [M:MFG2]REVCOD(L) = 2 # = Modify
      Endif
      # Issue X3-55431 - Display info message once after change
      If !GREVMESSC
        GREVMESSC = 1
        GERR = 2
        GMESSAGE = mess(411,193,1)
      Endif
      # End issue X3-55431
    Endif
  Endif
Endif # Issue X3-55832
# Issue X3-25054 - 2017-07-13 by JUSYN : End

MMODIF = 1

End

########################################
Subprog AM_CUMFXDQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCPL
Local    Decimal WEXT
Local    Integer WRET
Local    Integer L : L = nolign-1
Local    Integer VS

WEXT = VALEUR
# vérification seuil solde automatique atteint
WEXT  = [M:MFMW]RETQTY
WEXT -= [M:MFMW]CUMFXDQTY
WEXT += VALEUR
WCPL =  [M:MFMW]USEQTY
#
Call CONT_SOLDE_MAT([M:MFG0]MFGFCY, [M:MFMW]ITMREF, WCPL ,
&                   WEXT, WRET) From MFGLIBM
#
If WRET = 1
    VS=1
    Call AVERTIR(mess(53,190,1),VS) From GESECRAN
    If VS = 1
        VALEUR = [M:MFMW]CUMFXDQTY
        mkstat = 2
        End
    Endif
    [M:MFMW]MATSTA = 3
    Diszo [M:MFMW]
Endif
[M:MFMW]RETQTY = WEXT
Affzo[M:MFMW]RETQTY
MMODIF = 1
End

#########################################
# process 03.03 MM
Subprog AS_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer    TYP
If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif

If VALEUR = "" : VALEUR = [M]STU : Endif    # llc 09.03
TYP=0
Read [TUN]TUN0=[M]STU
If !fstat
    TYP = [F:TUN]UOMTYP
Endif

If (TYP <>3 & TYP <>4)
    VALEUR =[M]STU
    [M]BOMSTUCOE=1
    [M]BOMQTY=[M]LIKQTY
    mkstat=2
Endif


End

########################################
# process 03.03 MM
Subprog AM_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local    Decimal WBES
Local    Decimal LQTY

If instr(1,dbgstr(1),"MFMW")
  If [M:MFMW]BOMUOM<>VALEUR
    [M:MFMW]BOMQTY=0 : [M:MFMW]LIKQTY=0
    Affzo [M:MFMW]BOMQTY,LIKQTY
  Endif
Endif

MMODIF =1
End

########################################
# process 03.03 MM
Subprog AM_BOMQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WBES
Local    Decimal LQTY

If [M:MFMW]RETQTY <> 0
    Case [M:MFMW]MFGLINK
      When 1 :  LQTY     = [M:MFG1]MFGEXTQTY
      When 2 :  LQTY     = [M:MFG1]EXTQTY(WLIGART)
    Endcase
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY : Endif
    If [M:MFMW]LIKQTY <> 0
        Call CALCUL_BESOIN([M:MFMW]BASQTY,[M:MFMW]STU,[M:MFMW]LIKQTYCOD,[M:MFMW]LIKQTY,
&                      [M:MFMW]QTYRND,[M:MFMW]SCA,[M:MFMW]RELSCATIA,WBES,LQTY) From MFGLIBM
        [M:MFMW]RETQTY =WBES+ [M:MFMW]CUMFXDQTY
    Else
        [M:MFMW]RETQTY = [M:MFMW]CUMFXDQTY
    Endif
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY += [M:MFMW]RETQTY : Endif
    Affzo [M:MFMW]RETQTY
    Affzo [M:MFMW]CUMFXDQTY
MMODIF =1
Endif

End


#########################################################################
## Etiquettes liées à l'écran MFMS (stock matières)                    ##
#########################################################################
########################################
Subprog AM_XDETAIL(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    Diszo [M:MFMS]20
    When 2:    Actzo [M:MFMS]20
Endcase
End

########################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()
Local    Char    A1(1)
#
VALEUR = toupper(VALEUR)
# le statut doit obligatoirement commencer par "A"
If VALEUR <> ""
    A1 = left$(VALEUR,1)
    If A1 <> "A" : mkstat = 2 : Endif
Endif
#
End

########################################
Subprog C_LOT(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End

########################################
Subprog C_LOC(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End



########################################
Subprog AM_LOC(VALEUR)
Variable Char    VALEUR()
Affzo [M:MFMS]LOT
End


########################################
Subprog B1_GHOSTALT(VALEUR)
Variable Decimal VALEUR
Local Char    ALTALP(3)
Local Char    WITM(GLONITM) : # 05/2008 V6 avant (20)
Local Integer NBTBO

WITM=[M:MFMF]GHOST
#   sélectionner les alt. de nomenclature compatibles avec site de prod
Filter [TBO] Where ([F:TBO]FCY=[M:MFG0]MFGFCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=2
For [TBO]TBO1                                    # 10.02 Performances
    GBOMALT (NBTBO) = [F:TBO]BOMALT
    NBTBO += 1
Next
#
Filter [TBO]
#   filtre sur article parent
Local File BOM [BOH] Where find(BOMALT, GBOMALT) & ITMREF=WITM  & BOMALTTYP = 2
#
ALTALP = num$(GBOMALT(0))
GFONBOD="BOMP"
If [M:MFG1]STRDAT=[0/0/0]
    GDATEREF=date$
Else
    GDATEREF=[M:MFG1]STRDAT
Endif
If VALEUR<>0 : ALTALP=num$(VALEUR) : Endif

# GH 17/08/11 bug 74528
#Local Char    WSUPP(20)
#WSUPP = num$(ALTALP) + "~" + num$(2)
#Call OBJET("BOD", WITM, WSUPP) From GOBJET
Local Char WSUPP(GLONITM)(2)
WSUPP(0)=WITM : WSUPP(1)="2"
Call OBJET("BOD",ALTALP,WSUPP) From GOBJET

# relecture article
If [F:BOH]ITMREF=""
    mkstat=2
    End
Else
    VALEUR=[F:BOH]BOMALT
Endif
#
Raz GBOMALT
End

########################################
Subprog AS_GHOSTALT(VALEUR)
Variable Decimal VALEUR
GBOUT1=mess(153,198,1)
End

########################################
Subprog C_GHOSTALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY(GLONFCY) : # 05/2008 V6 avant (3)
Local    Integer WALT
Local    Date    WDAT
Local    Char    WITM(GLONITM) : # 05/2008 V6 avant (20)

WITM=[M:MFMF]GHOST

If [M:MFG1]STRDAT=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:MFG1]STRDAT
Endif
WFCY=[M:MFG0]MFGFCY
#    Lecture BOM
Read [TBO]TBO0=2;VALEUR
If fstat : mkstat=2 : End : Endif
Read [BOH]BOH0=WITM;VALEUR;2
If fstat
    GMESSAGE = mess(95,193,1)
    mkstat=2
    End
Endif
Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
End

########################################
Subprog S_GHOSTALT(VALEUR)
Variable Decimal VALEUR
Local Integer WALT

Call SELMFGNOM([M:MFG0]MFGFCY, [M:MFMF]GHOST, WALT) From MFGLIB
If WALT=0
    VALEUR=0
    mkstat=2
Else
    VALEUR=WALT
Endif
End

########################################
Subprog AS_LIKQTYG(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog C_LIKQTYG(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AM_LIKQTYG(VALEUR)
Variable Decimal VALEUR

Local    Decimal WQTY

Case [M:MFMF]LIKQTYCODG
     When 1: WQTY         = VALEUR * [M:MFMF]EXTQTY
     When 2: WQTY         = VALEUR
Endcase

Goto LEC_BOM

########################################

$LEC_BOM
Local Date WDAT
# Issue 110935 - 2016-04-19 by BEEBE : Deactivate EP PE_BOMDATCTL for product managed by version
Local Char WITMREF(GLONITM)

WITMREF = [M:MFG1]ITMREF

# Issue 105251 GA 04/2015 EP to use end date instead of [M:MFG1]STRDAT to check availability of component
#If [M:MFG1]STRDAT=[0/0/0]
#    WDAT=date$
#Else
#    WDAT=[M:MFG1]STRDAT
#Endif
# Check validity date of the link
#----- Read [F:ITM] with WITMREF
Local Integer WBOMDATCTL : WBOMDATCTL=2

If clalev([F:ITM])=0 | [F:ITM]ITMREF <> WITMREF
    Gosub READ_ITM From ITMLIB
Endif

If dim([F:ITM]ECCFLG)<=0 | [F:ITM]ECCFLG<>2
    Gosub PE_BOMDATCTL From MFGAUTLIB
Endif
# End issue 110935
Case WBOMDATCTL
  When 1       : WDAT=[M:MFG1]ENDDAT
  When Default : WDAT=[M:MFG1]STRDAT  # standard mode
Endcase
If WDAT=[0/0/0] WDAT=date$ Endif

# Issue 113561 - 2016-01 by GH : Material load for a version in derogation
If dim([M:MFMF]GHTECCMAJ)>0 & [M:MFMF]GHTECCMAJ<>""
   Call CORDAT([M:MFMF]GHOST,[M:MFMF]GHTECCMAJ,[M:MFMF]GHTECCMIN,2,WDAT) From ECCLIB
Endif

[M:MFMF]NBLIG = 0
Call CHARGE_MFMF([M:MFMF]GHOST,WDAT, WQTY)
End

########################################
Subprog CHARGE_MFMF(LITM,LDAT,LQTY)
Value    Char    LITM
Value    Date    LDAT
Value    Decimal LQTY

Local    Decimal WQTY, WDIS, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN, WWRK
Local    Decimal WBASQTY
Local    Integer WLIKQTYCOD, I    # llc 01.02 12406
Local    Decimal WLIKQTY
Local    Integer WQTYRND
Local    Decimal WLSCA
Local    Char    WITM(GLONITM) : WITM = LITM
Local    Integer WALT          : WALT = [M:MFMF]GHOSTALT
Local    Date    WDAT          : WDAT = LDAT
Local    Integer WRET , WSCATIA
Local    Char    WSTU(GLONUOM)     # llc 01.02 UOM
Local    Char    XMSG(120)
Local    Integer OK
Local    Integer WORITRT : WORITRT = 1 : # pour le point d'entrée CROSSTEST
Local Integer LERRCOD      # 107513
Local Char LERRMSG(250)    # 107513

Gosub MFMF_LEC
If fstat : End : Endif

# lecture liens (sauf CPNTYP=6 ou 7)
Local File BOMD [BOD] Where ITMREF = WITM & BOMALT = WALT & BOMALTTYP = 2 &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDAT)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDAT)) &
&                   CPNTYP < 6

# lecture premier enregistrement
Read [BOD]BOD0 First                              # 10.02 Performances

# tant qu'y en a !
While !fstat
    If [F:BOD]CPNTYP = 5
        [M:MFMF]                 = [F:BOD]
        [M:MFMF]BOMOPE(nolign-1) = [F:BOD]CPNOPE        # llc 11561 + 11937
        nolign += 1
        [M:MFMF]NBLIG     += 1
    Else
        # 107513
        Raz LERRCOD, LERRMSG
        Call CONTMATITM([F:BOD]CPNITMREF, [M:MFG0]MFGFCY, "MFG2", LERRCOD, LERRMSG) From MFGLIB

# useless
#    # lecture cumuls stocks
#        Call LECITV2([M:MFG0]MFGFCY,[F:BOD]CPNITMREF,WRET) From MFGLIB
#        # Issue 72149 - 2011-03-08 by CCC : test du code retour de LECITV2
#        If WRET : Goto NEXT_BOD : Endif

    # calcul quantité
        If [F:BOD]LIKQTY <> 0
            WQTY         = LQTY
            WSTU         = [F:ITM]STU
            WBASQTY      = [F:BOH]BASQTY
            WLIKQTYCOD   = [F:BOD]LIKQTYCOD
            WLIKQTY      = [F:BOD]LIKQTY
            WQTYRND      = [F:BOD]QTYRND
            WSCA         = [F:BOD]SCA
            Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,WQTYRND,
&               WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
            If WSCATIA
                WLIEN = WQTYBA
            Else
                WLIEN = WQTYNA
            Endif
        Else
            WLIEN = 0
        Endif

        # Issue 94453 GA 11/2013 sauf si Texte
        # Issue 87587 si et seulement si article géré en stock
        If [F:BOD]CPNTYP <> 5 & [F:ITF]STOMGTCOD=2
          # recherche stock disponible site
          #--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
          #Call STODISALL([M:MFG0]MFGFCY,[F:BOD]CPNITMREF,10,1,2,1,2,"","",WDIS,WRET) From STKALL
          Call STODISALL([M:MFG0]MFGFCY,[F:BOD]CPNITMREF,[F:BOD]ECCVALMAJ,WDIS) From MFGLIBM
        Else WDIS=0 Endif

        # demande 21559 Possibilité de traverser les articles autres que fantôme
        # Mettre GPE = 1 pour forcer la récursivité quel que soit la catégorie article
        GPE = 0
        GPOINT = "CROSSTEST"
        Gosub  ENTREE From EXEFNC

        # si article fantôme descente par récursivité
        # If ([F:ITM]PHAFLG = 2) & (WDIS = 0)
        #    Goto NEXT_BOD
        If [F:ITM]PHAFLG=2  | GPE
           If WDIS = 0 | GPE
             # substitution totale
# Issue 104942 - 2015-01-05 by CCC : type of quantity has to be chosen according to [ITF]RELSCATIA
#             WWRK = WQTYB
             If WSCATIA
                 WWRK = WQTYB
             Else
                 WWRK = WQTYN
             Endif
             OK = 0
           Elsif WDIS < WLIEN
             OK = 1
             Call OUINON("("+[F:BOD]CPNITMREF+")"-mess(139,190,1),OK) From GESECRAN
             If OK = 2
               WQTY = WDIS : # substitution partielle
             Else
               WQTY = 0   :  # pas de substitution
             Endif
             WWRK = WLIEN - WQTY
           Endif
        Else
           OK = 1 : WQTY = WLIEN : WWRK=0
        Endif

        If OK
            nolign = [M:MFMF]NBLIG+1
            [M:MFMF]                 = [F:BOD]
            [M:MFMF]                 = [F:ITM]
            [M:MFMF]BOMOPE(nolign-1) = [F:BOD]CPNOPE        # llc 11561 + 11937
            [M:MFMF]RETQTY(nolign-1) = WQTY
            # (titres llc 130)
            If dim([M:MFMF]TYPQTY(nolign-1)) > 0
                 [M:MFMF]TYPQTY(nolign-1) = 1 + ([F:ITM]STOMGTCOD <> 3)
            Endif

            [M:MFMF]ITMERRCOD(nolign-1) = LERRCOD
            [M:MFMF]ITMERRMSG(nolign-1) = LERRMSG
            # 120980 mm 02.2017
            If dim([M:MFMF]ECCVALMAJ)>0
              Call CTRECC([M:MFMF]CPNITMREF(nolign-1),"MFMF","CPNITMREF",[M:MFMF]ECCVALMAJ(nolign-1),[M:MFMF]ECCVALMIN(nolign-1),
&                       [M:MFG1]STRDAT,LERRCOD,[M:MFMF]ECCERRMSG(nolign-1)) From ECCLIB
              [M:MFMF]ECCERRCOD(nolign-1) = LERRCOD
            Endif

            [M:MFMF]NBLIG     += 1
        Endif

        If WWRK<>0
           Call CHARGE_MFMF([F:BOD]CPNITMREF,LDAT,WWRK)
           Gosub MFMF_LEC
        Endif
    Endif
#
$NEXT_BOD
    If dim([M:MFMF]CPNITMREF) < [M:MFMF]NBLIG + 2 : Break : Endif
    Read [BOD]BOD0 Next                     # 10.02 Performances
Wend

If [M:MFMF]NBLIG <> 0 : Affzo [MFMF]15 : Endif
Call HIGHLIGHT("MFMF", -1) From ECCLIB
End

$MFMF_LEC
# lecture entete nomenclature
Read [BOH]BOH0=WITM;WALT;2
If fstat : Return : Endif

WSCATIA = 0
# lecture article/site composé
If [F:ITF]ITMREF <> WITM | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
    Read [ITF]ITF0=WITM;[M:MFG0]MFGFCY
    If fstat : WSCATIA = 1 : fstat=0 : Endif
Endif
If WSCATIA = 0 & [F:ITF]RELSCATIA <> 1 : WSCATIA = 1 : Endif
Return

########################################
Subprog AS_LIKQTYCODG(VALEUR)
Variable Integer VALEUR
End

########################################
Subprog AM_LIKQTYCODG(VALEUR)
Variable Integer VALEUR
Local    Decimal WQTY

If [M:MFMF]NBLIG = 0 : End : Endif

Case VALEUR
     When 1: WQTY         = [M:MFMF]LIKQTYG * [M:MFMF]EXTQTY
     When 2: WQTY         = [M:MFMF]LIKQTYG
Endcase

Goto LEC_BOM

########################################
Subprog AM_RELSCATIA(VALEUR)
Variable Integer VALEUR
Local    Decimal WBES
Local    Decimal LQTY
Local    Integer L  : L = nolign-1
Local    Integer I

If [M:MFMW]RETQTY <> 0
    Case [M:MFMW]MFGLINK
        When 1 :  LQTY     = [M:MFG1]MFGEXTQTY
        When 2 :  LQTY     = [M:MFG1]EXTQTY(WLIGART)
    Endcase
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY -= [M:MFMW]RETQTY : Endif
    If [M:MFMW]LIKQTY <> 0
        Call CALCUL_BESOIN([M:MFMW]BASQTY,[M:MFMW]STU,[M:MFMW]LIKQTYCOD,[M:MFMW]LIKQTY,
&                      [M:MFMW]QTYRND,[M:MFMW]SCA,VALEUR,WBES,LQTY) From MFGLIBM
        [M:MFMW]RETQTY = WBES  + [M:MFMW]CUMFXDQTY
    Else
        [M:MFMW]RETQTY = [M:MFMW]CUMFXDQTY
    Endif
    If [M:MFMW]LIKQTYCOD = 2 : [M:MFMW]CUMFXDQTY += [M:MFMW]RETQTY : Endif
    Affzo [M:MFMW]RETQTY
    Affzo [M:MFMW]CUMFXDQTY
Endif
MMODIF = 1

End

########################################
Subprog AV_SHTQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
  pcolor = GCOUL(1)
Else
  pcolor = GCOUL(0)
Endif

End

#---------------------------------------------------------------------- #
# Action avant bouton  : Vérifications au préalable                     #
# Si GNOTALL=1 Pas d'ouverture de la fenêtre allocations manuelles      #
#---------------------------------------------------------------------- #
$AB6_NBLIG
Local Integer OK, NOL : NOL = nolign-1

# -- OF vérouillé
Gosub VERROU_MFG From SUBMFGA
If GERR = 1 : GNOTALL = 1 : Return : Endif
Return


########################################

$AB14_NBLIG
#--------------------------------#
# Avant bouton vers article site #
#--------------------------------#
# FQ 64658 GA 07/2010 Accès à l'Objet ITF en tunnel
If dim(GFLTITM)<=0 Global Char GFLTITM(GLONITM) Endif
If dim(GFLTFCY)<=0 Global Char GFLTFCY(GLONFCY) Endif
GFLTFCY=[M:MFG0]MFGFCY
#GFLTITM=[M:MFG1]ITMREF(nolign-1) : # GH 30/07/13 bug 91507
GFLTITM=[M:MFG2]ITMREF(nolign-1)
GBIDI1=GCONSULT
GCONSULT=2 # pas de maj de l'article-site ?
Return

$BB14_NBLIG
#--------------------------------#
# Après bouton vers article site #
#--------------------------------#
Raz GFLTITM
Raz GFLTFCY
GCONSULT=GBIDI1
# Issue 48563 03/08/2017 by GEBIL : Error: [F:ROH] : Class Non-existent + Error: [F:BOH] : Class Non-existent
If clalev([F:ROH])=0 | clalev([F:BOH])=0 : mkstat=4 : Endif
Return

# 107513
Subprog B15_NBLIG
Call ERRMSG("MFG2",nolign-1) From MFGLIB
End


