##########################################################################
Subprog C_PKC(VALEUR)
Variable Integer VALEUR
If instr(1,dbgstr(1),"MFMW")
   If [M:MFMW]BOMOPE = 900 & !find(VALEUR,1,8,9)
       GMESSAGE = mess(41,2324,1)
       mkstat = 2
       End
   Endif
Else
   If [M:MFG2]BOMOPE(nolign-1) = 900 & !find(VALEUR,1,8,9)
       GMESSAGE = mess(41,2324,1)
       mkstat = 2
       End
   Endif
Endif
End


