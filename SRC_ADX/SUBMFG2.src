######################################################################################
# pour la navigation vers le plan d'affectation
$MEM_VCR
If find(GREP,"C","D")
    If dim(GVCR) > 0 : # If dim(GVCR) : # Issue 121512 GH 15/02/2017 - Wrong test of dim
        Raz GVCR, GLIN, GSEQ
    Endif
    Return
Endif
If dim(GVCR) < 0
    Global Char    GVCR(GLONVCR)
    Global Integer GLIN
    Global Integer GSEQ
Endif

GVCR = [M:MFG0]MFGNUM
GLIN = [M:MFG2]MFGLIN(nolign-1)
GSEQ = [M:MFG2]BOMSEQ(nolign-1)
Return

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer L

Call C_ECCVALMAJ(VALEUR) From SUBMFG2ECC

# Issue 111417 - 2015-09-30 by CCC : same action used in MFMW & MFG2
If maskcou="MFMW"
    L=0
Else
    L=nolign-1
Endif
If !mkstat & dim([M]CRID)>0 & varmode([M]CRID)<>3 & func ECCLIB.NBRCPN([M]ITMREF(L))=1
    [M]CRID(L) = func TRTX3FNC.CCMID([M]ITMREF(L), VALEUR, "")
    Affzo [M]CRID(L)
    If dim([M]CRFLG)>0
        [M]CRFLG(L) = string$([M]CRID(L)<>"","151")
        Affzo [M]CRFLG(L)
    Endif
Endif

End

Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

Local Integer L

Call C_ECCVALMIN(VALEUR) From SUBMFG2ECC

# Issue 111417 - 2015-09-30 by CCC : same action used in MFMW & MFG2
If maskcou="MFMW"
    L=0
Else
    L=nolign-1
Endif
If !mkstat & dim([M]CRID)>0 & varmode([M]CRID)<>3 & func ECCLIB.NBRCPN([M]ITMREF(L))=2
    [M]CRID(L) = func TRTX3FNC.CCMID([M]ITMREF(L), [M]ECCVALMAJ(L), VALEUR)
    Affzo [M]CRID(L)
    If dim([M]CRFLG)>0
        [M]CRFLG(L) = string$([M]CRID(L)<>"","151")
        Affzo [M]CRFLG(L)
    Endif
Endif

End

