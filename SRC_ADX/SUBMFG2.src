######################################################################################

# Issue X3-25054 - 2017-07-13 by JUSYN : Set revision code for critical change.
######################################################################################
## Section automatically added (screen MFG2) 07/13/2017 08:00:02 (JUSYN)
######################################################################################
Subprog AM_PKC(VALEUR)
Variable Integer VALEUR
Local    Integer L : L = nolign-1

If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If instr(1,dbgstr(1),"MFG2")
    # Issue X3-48941 - use new global parameter for audit
    If func ECCLIB.CTRECCPROD(L)=1 & VALEUR <> [M:MFG2]PKC(L)
      If GMFGREV=2
       [M:MFG2]REVCOD(L) = 2 # = Modify
      Endif
      # Issue X3-55431 - Display info message once after change
      If !GREVMESSC
        GREVMESSC = 1
        GERR = 2
        GMESSAGE = mess(411,193,1)
      Endif
      # End issue X3-55431
    Endif
  Endif
Endif # Issue X3-55832

#CATUA X3-30179.sn Blank out container code if not weighed at station
If dim([M:MFG2]CTN(nolign-1))>0
  If !find(VALEUR,2,4,6)
    [M:MFG2]CTN(nolign-1) = ""
    Affzo[M:MFG2]CTN(nolign-1)
  Endif
Endif
#CATUA X3-30179.en

End
######################################################################################
# Issue X3-25054 - 2017-07-13 by JUSYN : End

# Issue X3-48941 - mandatory revison reason if critical field changed
######################################################################################
## Section automatically added (screen MFG2) 08/31/2017 08:31:27 (BAKHA)
######################################################################################
Subprog C_REVREASON(VALEUR)
Variable Char    VALEUR()
Local    Integer L : L = nolign-1

If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If instr(1,dbgstr(1),"MFG2")
    If GMFGREV=2 and [M:MFG2]REVCOD(L) > 0 and VALEUR = ""
      GMESSAGE = mess(403,193,1)
      GERR=1
      mkstat=2
    Endif
  Endif
Endif # Issue X3-55832
End

######################################################################################

# End issue X3-48941


#CATUA X3-30179.sn
#Manage container fields in WO
Subprog AV_CTN(VALEUR)
Variable Char    VALEUR()
  If dim([M:MFG2]CTN(nolign-1))>0 & dim([M:MFG2]PKC(nolign-1))>0
    If find([M:MFG2]PKC(nolign-1),2,4,6)
      Actzo [M:MFG2]CTN(nolign-1)
    Else
      Grizo [M:MFG2]CTN(nolign-1)
    Endif
    Call DISP_CTN_FLDS(VALEUR)
  Endif
End

Subprog AM_CTN(VALEUR)
Variable Char    VALEUR()
  If dim([M:MFG2]CTN(nolign-1))>0 & dim([M:MFG2]PKC(nolign-1))>0
    Call DISP_CTN_FLDS(VALEUR)
  Endif
End

#Show display only fields 'container weight unit' and 'container capacity'
Subprog DISP_CTN_FLDS(CTNCODE)
Value Char CTNCODE
  Local Integer ISEMPTY

  ISEMPTY=1
  If clalev ([F:CTN])=0  Local File CONTAINERS [CTN] Endif
  If CTNCODE<>""
    Read [CTN]CTN0=CTNCODE
    If !fstat
      ISEMPTY=0
      [M:MFG2]CTNWEU(nolign-1) = [CTN]CTNWEU
      [M:MFG2]CTNCAP(nolign-1) = [CTN]CTNCAP
    Endif
  Endif

  If ISEMPTY
    Raz [M:MFG2]CTNWEU(nolign-1)
    Raz [M:MFG2]CTNCAP(nolign-1)
  Endif

  Affzo [M:MFG2]CTNWEU(nolign-1)
  Affzo [M:MFG2]CTNCAP(nolign-1)
End
#CATUA X3-30179.en

