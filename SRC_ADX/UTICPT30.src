#<AdxTL>@(#)3.0.0.0 $Revision$
# Sert à initialiser le nouveau champ FLIBAN de la table TABCOUNTRY : 
#   - Les pays contenus dans une liste fermée doivent avoir ce champ positionné à Oui
#   - Si le code ISO de ces pays est vide, il faut le renseigner avec la valeur du code pays
  APPLI = "GX3APP"
  Call EXE_UTICPT30(APPLI)
End

Subprog EXE_UTICPT30(APPLI)
Value Char APPLI

  # Ouverture de la table TABCOUNTRY
  If clalev([F:WTCY]) : Close Local File [WTCY] : Endif
  Local File =APPLI+".TABCOUNTRY" [WTCY]

  # Trace de démarrage
  Call ECR_TRACE("UTICPT30: Process Start on : "+APPLI,0) From GESECRAN

  # Traitement
  Call DEBTRANS From GLOCK
  Gosub TR_UTICPT30

  # Trace de fin
  Call ECR_TRACE("UTICPT30: Process End on : "+APPLI,0) From GESECRAN

  # Fermeture de la table TABCOUNTRY
  If clalev([F:WTCY]) : Close Local File [WTCY] : Endif
End


#### Corps de la moulinette - début
$TR_UTICPT30
Local Char    LIST_CRY(3)(60)
Local Integer I, NBCRY, FLGMOD

  I=0   : LIST_CRY(I)="AL"  : I+=1  : LIST_CRY(I)="AD"  : I+=1  : LIST_CRY(I)="DE"  : I+=1  : LIST_CRY(I)="SA"
  I+=1  : LIST_CRY(I)="AT"  : I+=1  : LIST_CRY(I)="BE"  : I+=1  : LIST_CRY(I)="BA"  : I+=1  : LIST_CRY(I)="BG"
  I+=1  : LIST_CRY(I)="CY"  : I+=1  : LIST_CRY(I)="HR"  : I+=1  : LIST_CRY(I)="DK"  : I+=1  : LIST_CRY(I)="ES"
  I+=1  : LIST_CRY(I)="EE"  : I+=1  : LIST_CRY(I)="FI"  : I+=1  : LIST_CRY(I)="FR"  : I+=1  : LIST_CRY(I)="GI"
  I+=1  : LIST_CRY(I)="GR"  : I+=1  : LIST_CRY(I)="HU"  : I+=1  : LIST_CRY(I)="IE"  : I+=1  : LIST_CRY(I)="IS"
  I+=1  : LIST_CRY(I)="IL"  : I+=1  : LIST_CRY(I)="IT"  : I+=1  : LIST_CRY(I)="LV"  : I+=1  : LIST_CRY(I)="LI"
  I+=1  : LIST_CRY(I)="LT"  : I+=1  : LIST_CRY(I)="LU"  : I+=1  : LIST_CRY(I)="MK"  : I+=1  : LIST_CRY(I)="MT"
  I+=1  : LIST_CRY(I)="MU"  : I+=1  : LIST_CRY(I)="MC"  : I+=1  : LIST_CRY(I)="ME"  : I+=1  : LIST_CRY(I)="NO"
  I+=1  : LIST_CRY(I)="NL"  : I+=1  : LIST_CRY(I)="PL"  : I+=1  : LIST_CRY(I)="PT"  : I+=1  : LIST_CRY(I)="CZ"
  I+=1  : LIST_CRY(I)="RO"  : I+=1  : LIST_CRY(I)="GB"  : I+=1  : LIST_CRY(I)="SM"  : I+=1  : LIST_CRY(I)="RS"
  I+=1  : LIST_CRY(I)="SK"  : I+=1  : LIST_CRY(I)="SI"  : I+=1  : LIST_CRY(I)="SE"  : I+=1  : LIST_CRY(I)="CH"
  I+=1  : LIST_CRY(I)="TN"  : I+=1  : LIST_CRY(I)="TR"

  NBCRY = I

  # On sélectionne les enregistrements qui sont dans la liste fermée
  Filter [F:WTCY] Where find(CRY, LIST_CRY(0..NBCRY))
  
  Trbegin [WTCY]
  For [F:WTCY]
    FLGMOD=1
    If [F:WTCY]FLIBAN<>2 Then
      [F:WTCY]FLIBAN = 2 : # Le champ FLIBAN est coché
      FLGMOD=2  
    Endif
    If [F:WTCY]ISO="" Then 
      [F:WTCY]ISO = [F:WTCY]CRY  : # Mise à jour du code ISO
      FLGMOD=2  
    Endif
    If FLGMOD=2 Then 
      Rewrite [F:WTCY]
      If fstat
        GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"TABCOUNTRY:"-[F:WTCY]CRY,1) From GESECRAN
        Break
      Endif
    Endif
  Next
  
  If !GOK Then
    Goto AB_UTICPT30
  Else
    Commit
  Endif
  Filter [F:WTCY]
Return

$AB_UTICPT30
  Rollback
Return 
#### Corps de la moulinette - fin 


Subprog PATCH(APPLI)
Value Char    APPLI
#Local Integer GVII

  If APPLI=adxmother(0) : End : Endif

  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
#  # On  regarde si le module Comptabilité est à "Oui"
#  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
#  If [F:ADS]MODULE(1) <> 2 : End : Endif
#
#  # On  regarde si le code activité VII Virements internationaux pour le dossier est à "Oui"
#  If !clalev([F:ADA]) : Local File ADOSACT  [ADA] : Endif
#  Read [ADA]ADA0=APPLI;"VII"  : # Dossier avec Virements internationaux
#
#  If fstat Then
#    GVII = 2 : # Par défaut on gère les virements internationaux
#  Else
#    GVII = [F:ADA]FLACT
#  Endif
#
#  If GVII<>2 : End : Endif

  If filinfo(filpath("FIL","TABCOUNTRY","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTICPT30(APPLI)
End

