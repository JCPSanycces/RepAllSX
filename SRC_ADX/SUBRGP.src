#<AdxTL>@(#)2.0.0.0 $Revision$
Local Decimal BASPAG
## Action VISURGP
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VISURGP"
PARMSK(1) = "INTERCO1"
PARMSK(2) = "PAR"
PARMSK(3) = "041029"
PARMSK(4) = "99999993"
PARMSK(5) = "0"
Call SAISIE_NUM(BASPAG,PARMSK,"IVISURGP","SUBRGP","SPERGP") From GSAISIE
End

$ACTION
Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
Endcase
Return

$OUVRE
    Local Char LITM(GLONITM)    : LITM = PARAM(1)
    Local Char LFCY(GLONFCY)    : LFCY = PARAM(2)
    Local Date LDAT             : LDAT = PARAM(3)
    Local Integer LSEQ          : LSEQ = val(PARAM(4))
    Local Integer LIND          : LIND = val(PARAM(5))
    # Issue 82166 - 2012-08-09 by CCC
    # LFLG = 0 ou 2 : pas de regroupement et on filtre sur les infos stock
    # LFLG = 1      : regroupement des mouvements pour une même ligne de doc. C'est le n° de la régul qui différencie chaque ligne
    Local Integer LFLG          : LFLG = val(PARAM(6))

Local Integer LTYPREG
Local Char    LNUMREG(GLONVCR)
Local Integer LLINREG
Local Integer MAXLIG : # GH 06/12/2013 bug 89849
Return

$DEBUT
MAXLIG = dim([M:RGP]VCRNUMREG) : # GH 06/12/2013 bug 89849
Diszo [M:RGP]VCRNUM    # Défini saisissable dans l'écran pour pouvoir avoir un bouton
# C'est la classe STJ1 qui est utilisée car [STJ] a un filtre de positionné dans la consult SMV
If !clalev([STJ1]) : Local File STOJOU [STJ1] : Endif
    Read [STJ1]STJ0=LFCY;2;LITM;LDAT;LSEQ;LIND
    If fstat
        Call FSTA("STJ1") From GLOCK
        FIN = 1
        Return
    Endif
    [M:RGP] = [F:STJ1]
    Effzo [M:RGP]15    # On efface le tableau

    # CCC (2010-01-14) Bug 57930 : Perf : ajout du site dans le filtre et de l'instruction "With Nohint"
    If find(LFLG,0,2)
        Filter [STJ1] Where STOFCY = [M:RGP]STOFCY
&                         & VCRTYP = [M:RGP]VCRTYP
&                         & VCRNUM = [M:RGP]VCRNUM
&                         & VCRLIN = [M:RGP]VCRLIN
&                         & ITMREF = [M:RGP]ITMREF
&                         & PCU    = [M:RGP]PCU
&                         & PCUSTUCOE = [M:RGP]PCUSTUCOE
&                         & LOT    = [M:RGP]LOT
&                         & SLO    = [M:RGP]SLO
&                         & LOC    = [M:RGP]LOC
&                         & STA    = [M:RGP]STA
&                         & SERNUM = [M:RGP]SERNUM
&                         & PALNUM = [M:RGP]PALNUM
&                         & CTRNUM = [M:RGP]CTRNUM
&                         & QTYSTU > 0
&                         & AMTVAL = VARVAL
    Else
        Filter [STJ1] Where STOFCY = [M:RGP]STOFCY
&                         & VCRTYP = [M:RGP]VCRTYP
&                         & VCRNUM = [M:RGP]VCRNUM
&                         & VCRLIN = [M:RGP]VCRLIN
&                         & ITMREF = [M:RGP]ITMREF
&                         & QTYSTU > 0
&                         & AMTVAL = VARVAL
    Endif
    nolign=0
    For [STJ1]STJ0 With Nohint
        Gosub ADDLIN
    Next
    Filter [STJ1]

    If find(LFLG,0,2)
        Filter [STJ1] Where STOFCY = [M:RGP]STOFCY
&                         & VCRTYP = [M:RGP]VCRTYP
&                         & VCRNUM = [M:RGP]VCRNUM
&                         & VCRLIN = [M:RGP]VCRLIN
&                         & ITMREF = [M:RGP]ITMREF
&                         & PCU    = [M:RGP]PCU
&                         & PCUSTUCOE = [M:RGP]PCUSTUCOE
&                         & LOT    = [M:RGP]LOT
&                         & SLO    = [M:RGP]SLO
&                         & LOC    = [M:RGP]LOC
&                         & STA    = [M:RGP]STA
&                         & SERNUM = [M:RGP]SERNUM
&                         & PALNUM = [M:RGP]PALNUM
&                         & CTRNUM = [M:RGP]CTRNUM
&                         & QTYSTU > 0
&                         & AMTVAL <> VARVAL
&                     Order By IPTDAT;MVTSEQ Desc
    Else
        Filter [STJ1] Where STOFCY = [M:RGP]STOFCY
&                         & VCRTYP = [M:RGP]VCRTYP
&                         & VCRNUM = [M:RGP]VCRNUM
&                         & VCRLIN = [M:RGP]VCRLIN
&                         & ITMREF = [M:RGP]ITMREF
&                         & QTYSTU > 0
&                         & AMTVAL <> VARVAL
&                     Order By IPTDAT;MVTSEQ Desc
    Endif
    For [STJ1] With Nohint
        Gosub ADDLIN
    Next
    Filter [STJ1]

[M:RGP]NBLIG = nolign
Affzo [RGP]

# GH 06/12/2013 bug 89849
If MAXLIG<0
   MAXLIG*=-1
   GERR=2 : GMESSAGE=mess(26,100,1) : # Tableau plein
Endif
#
Return

$ADDLIN
        If find(LFLG,0,2)
&        | nolign=0
&        |( LTYPREG<>[F:STJ1]VCRTYPREG
&         | LNUMREG<>[F:STJ1]VCRNUMREG
&         | LLINREG<>[F:STJ1]VCRLINREG )
# GH 06/12/2013 bug 89849
            If nolign=MAXLIG : MAXLIG*=-1 : Endif
            If MAXLIG<0 : Return : Endif
#
            nolign += 1
            [M:RGP] = [F:STJ1]
            LTYPREG=[F:STJ1]VCRTYPREG
            LNUMREG=[F:STJ1]VCRNUMREG
            LLINREG=[F:STJ1]VCRLINREG
        Else
            [M:RGP]QTYSTU(nolign-1) += [F:STJ1]QTYSTU
            [M:RGP]AMTORD(nolign-1) += [F:STJ1]AMTORD
            [M:RGP]AMTVAL(nolign-1) += [F:STJ1]AMTVAL
            [M:RGP]AMTDEV(nolign-1) += [F:STJ1]AMTDEV
            If [M:RGP]QTYSTU(nolign-1)<>0
                [M:RGP]PRIORD(nolign-1) = arr([M:RGP]AMTORD(nolign-1)/[M:RGP]QTYSTU(nolign-1),10^-GDECPRI)
                [M:RGP]PRIVAL(nolign-1) = arr([M:RGP]AMTVAL(nolign-1)/[M:RGP]QTYSTU(nolign-1),10^-GDECPRI)
            Endif
        Endif
Return

##########################################################################
Subprog IB_VCRNUM
If !find([M:RGP]VCRTYP,6,15,19,29)
    Raz GBOUT2
Endif
End
##########################################################################
Subprog B2_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer SAVGCONS : SAVGCONS = GCONSULT
GCONSULT = 1

Case [M:RGP]VCRTYP
    When 6  : Call OBJET_CHAR([M:RGP]VCRNUM,"PTH","") From GOBJET    # Réception
    When 15 : Call OBJET_CHAR([M:RGP]VCRNUM,"MFG","") From GOBJET    # Déclaration de production
    When 19 : Call OBJET_CHAR([M:RGP]VCRNUM,"SMR","") From GOBJET    # Entrées diverses
    When 29 : Call OBJET_CHAR([M:RGP]VCRNUM,"SCS","") From GOBJET    # Changement stock (Transfert inter-sites)
Endcase

GCONSULT = SAVGCONS

End


##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 14/04/2004 17:15:59 (CCC)
##########################################################################
Subprog IB_NBLIG
If !find([M:RGP]VCRTYPREG(nolign-1),17)    #17=Facture d'achat
    Raz GBOUT2
Else
    GBOUT2 = mess(55,198,1)-[M:RGP]VCRNUMREG(nolign-1)
Endif
End

Subprog B2_NBLIG
Local Integer SAVGCONS : SAVGCONS = GCONSULT
GCONSULT = 1

Case [M:RGP]VCRTYPREG(nolign-1)
    When 17 : Call OBJET_CHAR([M:RGP]VCRNUMREG(nolign-1),"PIH","") From GOBJET    # Facture d'achat
Endcase

GCONSULT = SAVGCONS

End


##########################################################################
