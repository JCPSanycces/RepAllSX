$ON_INVNUM
Onevent CONTROL Call C_INVNUM(zc) From W1ZBIC1
Onevent BEFORE_INPUT Call AS_INVNUM(zc) From W1ZBIC1
Onevent AFTER_AREA Call AP_INVNUM(zc) From W1ZBIC1
Onevent AFTER_CHANGE Gosub AMM_INVNUM From W1ZBIC1
Return

Subprog AS_INVNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_INVNUM(VALEUR) From SUBBIC2
If mkstat=2
 [M]INVNUM(INDIC) = VALEUR
 Affzo INVNUM(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_INVNUM(zc) From W1ZBIC1
Gosub _AFF
End

Subprog C_INVNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "INVNUM" : GZNUM = 6731 : Endif
Endif
If !mkstat
 ## Action STD
 Call C_INVNUM(VALEUR) From SUBBIC2
 If mkstat : GERR = 1 : GZONE = "INVNUM" : GZNUM = 6731 : Endif
Endif
Gosub _AFF
End

Subprog AP_INVNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_INVNUM(VALEUR) From SUBBIC2
If mkstat : GERR = 1 : GZONE = "INVNUM" : GZNUM = 6731 : Endif
Gosub _AFF
End

