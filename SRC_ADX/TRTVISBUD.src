#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(30)(1..6) , VALEUR(10)
Local Mask VISBUD [VBD]
# Paramètres de l'action
# Param(1) => Date
# Param(2) => Site
# Param(3) => Nom du champ compte
# Param(4) => Nom du/des champ(s) section(s) <=>aux axes
# Param(5) => Nom du/des champ(s) axe(s)
# Param(6) => nolign
PARAM(1) = date$
PARAM(2) = "ZJHS1"
PARAM(3) = "601"
PARAM(4) = "[M]CCE#"
PARAM(5) = "[M]DIE(0"
PARAM(6) = "1"
Call SAISIE_CHAR(VALEUR,PARAM,"VISBUD","TRTVISBUD","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "SUI"          : Gosub SUI
 When "PRE"          : Gosub PRE
 When Default
Endcase
Return

$OUVRE
If clalev([F:BUD])=0  : Local File BUD        [BUD] : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP] : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV] : Endif
If clalev([F:GSP])=0  : Local File GRPDSP     [GSP] : Endif
If clalev([F:BLA])=0  : Local File BALANA     [BLA] : Endif
If clalev([F:BLM])=0  : Local File BLACMM     [BLM] : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY     [BLQ] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER] : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU] : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE  [TCH] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC] : Endif
If clalev([F:TUN])=0  : Local File TABUNIT    [TUN] : Endif
If clalev([F:LED])=0  : Local File GLED       [LED] : Endif
If clalev([F:CRY])=0  : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:GRY])=0  : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:CYK])=0  : Local File GCCEPYMLIK [CYK] : Endif
If clalev([F:GYK])=0  : Local File GACCPYMLIK [GYK] : Endif
If clalev([F:CLS])=0  : Local File GACCCLS    [CLS] : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif

If clalev([F:CYK1])=0  : Local File GCCEPYMLIK [CYK1] : Endif
If clalev([F:CYK2])=0  : Local File GCCEPYMLIK [CYK2] : Endif
If clalev([F:CYK3])=0  : Local File GCCEPYMLIK [CYK3] : Endif
If clalev([F:CYK4])=0  : Local File GCCEPYMLIK [CYK4] : Endif
If clalev([F:CYK5])=0  : Local File GCCEPYMLIK [CYK5] : Endif
If clalev([F:CYK6])=0  : Local File GCCEPYMLIK [CYK6] : Endif
If clalev([F:CYK7])=0  : Local File GCCEPYMLIK [CYK7] : Endif
If clalev([F:CYK8])=0  : Local File GCCEPYMLIK [CYK8] : Endif
If clalev([F:CYK9])=0  : Local File GCCEPYMLIK [CYK9] : Endif

Return

$DEBUT
Local Integer C , AXE , ISOC , ISITE , IBUD, INDDIE, LEDTYP , IND1, IND2
Local Char    SOCIETE(GLONCPY) , VALPAR(30) , BUDGET(GLONBUP) , BUDVER(GLONBUV)
Local Char    BLAFCY(GLONFCY), BLACPY(GLONCPY), BUDCPY(GLONCPY), BUDFCY(GLONFCY)
Local Char    SECTION(GLONCCE), BUDCCE(GLONCCE)(1..9)
Local Decimal EXERCICE, PERIODE, EXODEB, EXOFIN, PERDEB, PERFIN, PER1, PER2
Local Char    DEVCPY(GLONCUR), DEVBUD(GLONCUR)
Local Integer TYPCUR, STA
Local Decimal COURS
Local Integer BUDPER, ENGAGE, PREENG, AX
Local Date    DAT
Local Char    SITE(GLONFCY)
Local Char    ACC(GLONGAC)
Local Char    TBDIE(GLONDIE)(1..GOPTCANA+1)  # +1 pour éviter un plantage si GOPTCANA=0
Local Char    TBCCE(GLONCCE)(1..GOPTCANA+1)  # +1 pour éviter un plantage si GOPTCANA=0
Local Char    REF(GLONLED), DEVREF(GLONCUR), PLAN(GLONCOA)

Local Char    BUDACC(GLONGAC)
Local Char    GRUREF(max(GLONCYR,GLONGRY)) : # Groupe sections/comptes auquel est DIRECTEMENT rattaché la section/compte
Local Char    SECTION(GLONCCE)

Local Char    CRITBLA(250)(2), CRITPYR(250)(3)
Local Integer IND(1..10), K, IEXO, NUMCCE(1..9)
Local Integer SEP  : # Separator , already written in the Link
Local Integer STAT : # Status
Local Char    FILPROG(GLONADC) , FILSRC(250) , FILADX(250) : # Generation of the Link
Local Integer OKBUDCCE(1..9)
Local Char    ACCSIGN(GLONGAC): # Keep the account to search the sign
Local Integer IPYR

Local Char    LEDBUDCCE(GLONCCE)(1..9)

Local Integer DIMPER : DIMPER = 300
Local Decimal AMTREA(1..DIMPER)      : # Montant réel
Local Decimal QTYREA(1..DIMPER)      : # Quantité réelle
Local Decimal AMTCMM(1..DIMPER)      : # Montant engagé
Local Decimal QTYCMM(1..DIMPER)      : # Quantité engagée
Local Decimal AMTPRP(1..DIMPER)      : # Montant pré-engagé
Local Decimal QTYPRP(1..DIMPER)      : # Quantité pré-engagé

Local Char VARRUN(GLONBUP+2) : # Variable de parcours
Local Integer TLEDTYP(1..len(mess(0,2644,1))), NBLT
Local Char TLED(GLONLED)(1..len(mess(0,2644,1)))
Local Char TCURLED(GLONCUR)(1..len(mess(0,2644,1)))
Local Char TCOA(GLONCOA)(1..len(mess(0,2644,1)))
Local Char TACC(GLONGAC)(1..len(mess(0,2644,1)))
Local Char TABRUN(5)(1..(9*len(mess(0,2644,1))))
#nb:  il y a 9 parametres et il peu donc y avoir 9 budgets renseignés sur chaque type de référentiel
Local Integer NBRUN

# Paramètres de l'action
# Param(1) => Date
# Param(2) => Site
# Param(3) => Nom du champ compte
# Param(4) => Nom du/des champ(s) section(s) <=>aux axes
# Param(5) => Nom du/des champ(s) axe(s)
# Param(6) => nolign

DAT    = PARAM(1)
SITE   = PARAM(2)

Call LEC_FCY(PARAM(2)) From CPTLEC
SOCIETE=[F:FCY]LEGCPY
If SOCIETE<>""
 Call LSTLEDTYP(SOCIETE,4,TLEDTYP,NBLT) From CPTDIV
Else
 # Société ou site incorrect
 GMESSAGE=mess(62,133,1)
 GERR=2
 FIN=1
 Return
Endif

Local Integer L_NBCOA, L_NBDIE
Local Char L_TCOA(GLONCOA) (1..10)
Local Integer L_TLEDTYP    (1..10)
Local Char L_TDIE(GLONDIE) (1..10)
Local Integer L_OBLIG      (1..10)


#For fonction from purchase module
Call LEC_CPY(SOCIETE) From CPTLEC
Call SETPLAN2([F:CPY]ACM,L_NBCOA,L_TCOA,L_TLEDTYP,L_NBDIE,L_TDIE,L_OBLIG) From CPTDIV

For L=1 To NBLT
 Call LECLED(SOCIETE,TLEDTYP(L),TLED(L),TCURLED(L)) From CPTDIV
 Call LECPLAN(SOCIETE,TLEDTYP(L),TCOA(TLEDTYP(L))) From CPTDIV
Next L

# Pour avoir le tableau des comptes/type de référentiels
#** To set the Accounts table
If GFONCTION="GESCMM"
 # Ligne suivante ajoutée car GCOA n'est pas alimenté lorsque l'on vient des engagements??(GESCMM)
 # Call RECUP_GLOBAL_CPT(nomap(0),SITE) From TRTX3CPT
 J = instr(1,PARAM(3),"#")
 If J
  For L=1 To NBLT
   TACC(TLEDTYP(L)) = evalue(left$(PARAM(3),J-1)+num$(TLEDTYP(L))+"("+PARAM(6)+")")
  Next
 Endif
Else
 # For fonctions from purchase module
 Local Integer RIGHT_LT
 J = instr(1,PARAM(3),"#")
 If J
  For L=1 To len(mess(0,2644,1))
   RIGHT_LT = find(L,L_TLEDTYP(1..L_NBCOA))
   If RIGHT_LT & find(L,TLEDTYP(1..NBLT))
    TACC(L) = evalue(left$(PARAM(3),J-1)+num$(RIGHT_LT)+"("+PARAM(6)+")")
   Endif
  Next
 Else
  ZONE = PARAM(3)
  If evalue("dim("+ZONE+")>1")
   For L=1 To len(mess(0,2644,1))
    RIGHT_LT = find(L,L_TLEDTYP(1..L_NBCOA))
    If RIGHT_LT & find(L,TLEDTYP(1..NBLT))
     Onerrgo ERROUV
     ERR = 0
     TACC(L) = evalue(PARAM(3)+"("+num$(L-1)+")")
     Onerrgo
     If ERR : Break : Endif
    Endif
   Next
  Else
   For L=1 To len(mess(0,2644,1))
    RIGHT_LT = find(L,L_TLEDTYP(1..L_NBCOA))
    If RIGHT_LT & find(L,TLEDTYP(1..NBLT))
     TACC(L) = evalue(PARAM(3))
    Endif
   Next
  Endif
 Endif
Endif

#Axes
#**Dimensions
N=1
K = instr(1,PARAM(5),"(")
If K
 IND1 = val(mid$(PARAM(5),K+1,1))
 PARAM(5) = left$(PARAM(5),K-1)
 Raz IND2
 If IND1=0 : IND2=min(19,GOPTCANA-1)  : Endif
 If IND1=1 : IND2=min(20,GOPTCANA) : Endif
 For I=IND1 To IND2
  ZONE = PARAM(5)+"("+num$(I)+")"
  If evalue("dim("+ZONE+")>0")
   TBDIE(N) = evalue(ZONE)
   N+=1
  Endif
 Next
Else
 K = len(PARAM(5))-1
 IND1 = val(mid$(PARAM(5),K+1,1))
 Raz IND2
 If IND1=0 : IND2=min(19,GOPTCANA-1)  : Endif
 If IND1=1 : IND2=min(20,GOPTCANA) : Endif
 For I=IND1 To IND2
  ZONE = PARAM(5)+"("+num$(I)+")"
  If evalue("dim("+ZONE+")>0")
   TBDIE(N) = evalue(ZONE)
   N+=1
  Endif
 Next
Endif

#Sections
#**Centers
For AXE=1 To GOPTCANA
 I = instr(1,PARAM(4),"#")
 If I
  ZONE = left$(PARAM(4),I-1)+num$(AXE)+right$(PARAM(4),I+1)+"("+PARAM(6)+")"
 Else
  ZONE = PARAM(4)+"(AXE-1)"
 Endif
 If evalue("dim("+ZONE+")>0")
  TBCCE(AXE) = evalue(ZONE)
 Endif
Next AXE

Call DEFVAR(SITE) From CPTBUD

#------------------------------------------------#
# Définition de la clé de parcours de l'action
#** Definition of the run key of the action
#------------------------------------------------#
NBRUN=0
For I=1 To GBUDNB
 For J=1 To NBLT
  Filter [BUD] Where BUD=GBUDGET(I) & VER=GBUDVER(I) & LEDTYP=TLEDTYP(J)
  Read [BUD]BUD0 First
  If !fstat
   NBRUN+=1
   TABRUN(NBRUN)=num$(I)+";"+num$(TLEDTYP(J)) :#num$(J)
  Endif
  Filter [BUD]
 Next
Next

IBUD = 1

Gosub VISBUD
Return

$ERROUV
ERR = errn
Resume

$VISBUD
Raz [M:VBD]
If val(left$(TABRUN(IBUD),1))=0
 GMESSAGE = mess(265,108,1) : # Aucun budget à contrôler avec version définitive
 GERR = 1 : FIN = 1 : Return
Endif

BUDGET = GBUDGET(val(left$(TABRUN(IBUD),1)))
BUDVER = GBUDVER(val(left$(TABRUN(IBUD),1)))
LEDTYP = val(right$(TABRUN(IBUD),3))
DEVREF = TCURLED(find(LEDTYP,TLEDTYP(1..NBLT)))

PLAN   = TCOA(LEDTYP)
ACC    = TACC(LEDTYP)

Call LEC_BUP(BUDGET) From CPTLEC

ISITE = find(SITE,GSITE(1..GNBSITE))
If ISITE=0
 FIN = 1 : Return
Endif
SOCIETE = GSOCSITE(ISITE)
ISOC = find(SOCIETE,GSOC(1..GNBSOC))
DEVCPY = GDEVSOC(ISOC)

# Devise de budget
#**Budget's currency
DEVBUD = [F:BUP]CUR
If DEVREF<>DEVBUD
 Call COURDEV(DEVBUD,DEVREF,GBUDTYPCUR,DAT,COURS,STA) From TRTDIV
 If STA
  FIN = 1 : Return
 Endif
Endif
Raz EXODEB,PERDEB,EXOFIN,PERFIN
# Exercices, périodes
#** Fiscalyears, periods
Case [F:BUP]BUDCTL
 When 2,3 : # Contrôle annuel et par période
  Call GETPERSOC(SOCIETE,LEDTYP,DAT,EXERCICE,PERIODE) From CPTSUB
  EXODEB = EXERCICE
  EXOFIN = EXERCICE
 When 4   : # Contrôle global
  Call GETPERSOC(SOCIETE,LEDTYP,[F:BUP]VLYSTR,EXODEB,PERDEB) From CPTSUB
  If EXODEB=0 | PERDEB=0
   Filter [PER] Where CPY=SOCIETE & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
   Read [PER]PER0 First
   If !fstat
    EXODEB = [F:PER]FIYNUM
    PERDEB = [F:PER]PERNUM
   Endif
  Endif
  If [F:BUP]VLYEND<>[0/0/0]
   Call GETPERSOC(SOCIETE,LEDTYP,[F:BUP]VLYEND,EXOFIN,PERFIN) From CPTSUB
   If EXOFIN=0 | PERFIN=0
    Filter [PER] Where CPY=SOCIETE & PERSTR<=[F:BUP]VLYEND & PEREND<=[F:BUP]VLYEND
    Read [PER]PER0 Last
    If !fstat
     EXOFIN = [F:PER]FIYNUM
     PERFIN = [F:PER]PERNUM
    Endif
   Endif
   If EXOFIN=0
    Local Date DATSTR
    Gosub DERPEREXO From CPTBUD
    Call DATEXE(SOCIETE,LEDTYP,EXOFIN,DATSTR,[F:BUP]VLYEND) From CPTSUB
   Endif
  Else
   Gosub DERPEREXO From CPTBUD
  Endif
 When 5   : # Contrôle cumulé
  Call GETPERSOC(SOCIETE,LEDTYP,[F:BUP]VLYSTR,EXODEB,PERDEB) From CPTSUB
  If EXODEB=0 | PERDEB=0
   Filter [PER] Where CPY=SOCIETE & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
   Read [PER]PER0 First
   If !fstat
    EXODEB = [F:PER]FIYNUM
    PERDEB = [F:PER]PERNUM
   Endif
  Endif
  Call GETPERSOC(SOCIETE,LEDTYP,DAT,EXOFIN,PERFIN) From CPTSUB
Endcase

If EXODEB = 0 & PERDEB = 0
 Filter [PER] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP
 Read [PER]PER0 First
 Filter [PER]
 If !fstat & [F:PER]PERSTR>[F:BUP]VLYSTR
  EXODEB = [F:PER]FIYNUM
  PERDEB = [F:PER]PERNUM
 Endif
Endif

BUDCPY = SOCIETE
BLACPY = SOCIETE
If [F:BUP]LEV=1
 BUDFCY = ""
 BLAFCY = ""
Else
 BUDFCY = SITE
 BLAFCY = SITE
Endif

Gosub INI_ACC_CCE
Raz LEDBUDCCE
For K=1 To 9
 Call GETNUMAXE(SOCIETE,LEDTYP,[F:BUP]DIE(K-1),NUMCCE(K)) From CPTDIV
 If NUMCCE(K)<>0 : LEDBUDCCE(NUMCCE(K)) = BUDCCE(K) : Endif
Next

#---------------------------------------------#
# Court-circuit pour budgets opérationnels
#** Short-cut for operating budgets
If [F:BUP]GDDFLG=2
 Local Decimal ENVFIY
 Local Decimal GDDEXE, GDDPER
 Local Date    GDDDEB, GDDFIN
 Call GETPERSOC(SOCIETE,LEDTYP,DAT,GDDEXE,GDDPER) From CPTSUB
 If !clalev([F:ENV])  : Local File ENVELOPPE [ENV]  : Endif
 If !clalev([F:BUT])  : Local File BUDTYP    [BUT]  : Endif
 Call LEC_ENV(BUDCCE(2)) From CPTLEC
 Call LEC_BUT([F:ENV]BUDTYP) From CPTLEC
 #Différencier enveloppe annuelle de pluriannuelle
 #**Is it a Yearly or a Multi annual budget envelop
 If [F:BUT]YEAFLG=1
  ## Annuelle / Yearly
  #vérifier la cohérence entre la date passée et la date de l'enveloppe*
  #**Check the consistency between given date and the budget envelop's date
  Call GETEXE(SOCIETE,LEDTYP,[F:ENV]REASTR,ENVFIY) From CPTSUB
  If GDDEXE<ENVFIY
   GDDEXE=ENVFIY
  Endif
 Else
  ##Enveloppe pluriannuelle / Multi annual
  #vérifier la cohérence entre la date passée et la date de l'enveloppe*
  #(*dans le cas pluri-annuelle, voir si un report à eu lieu sur l'engagement pour récupérer la date à traiter)
  #**Check the consistency between given date and the budget envelop's date*
  #(*in this multi annual case, look for an existing report on the commitment to get the correct date
  If !clalev([CMD2]) : Local File GCOMMITD [CMD2] : Endif
  Local Char CURRENT_CMM(GLONVCR)
  Case GFONCTION
   When "GESPSH" : CURRENT_CMM=[M:PSH1]CMMPRPNUM(nolign-1)
   When "GESPOH" : CURRENT_CMM=[M:POH2]CMMNUM(nolign-1)
   When "GESPOD" : CURRENT_CMM=[M:POD1]CMMNUM(nolign-1)
   When "GESCMM" : CURRENT_CMM=[M:CMM1]NUM
  Endcase
  Filter [CMD2] Where NUM=CURRENT_CMM & GRDPCE=6
  Read [CMD2]CMD0 Last
  If !fstat
   Call GETEXE(SOCIETE,LEDTYP,[F:CMD2]ACCDAT,ENVFIY) From CPTSUB
   If GDDEXE < ENVFIY
    GDDEXE=ENVFIY
   Endif
  Endif
  Filter [CMD2]
 Endif
 [M]LEDTYP = [L]LEDTYP
 Call DATEXE(SOCIETE,LEDTYP,GDDEXE,[M]DATDEB,[M]DATFIN) From CPTSUB
 Read [BUD]BUD0 = LEDTYP;BUDGET;BUDCPY;BUDFCY;GDDEXE;BUDVER;ACC;LEDBUDCCE(1);LEDBUDCCE(2);LEDBUDCCE(3);
&                     LEDBUDCCE(4);LEDBUDCCE(5);LEDBUDCCE(6);LEDBUDCCE(7);LEDBUDCCE(8);LEDBUDCCE(9)
 If !fstat
  [M]MTREL = [F:BUD]AMTREA
  [M]MTENG = [F:BUD]AMTCMM
  [M]MTPRE = [F:BUD]AMTCMMPRP
  [M]MTTOT = [F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP
  [M]CUR   = [F:BUD]CUR
  [M]INTIT = ACC
  For K=1 To 9 : [M]INTIT -= BUDCCE(K) : Next
  [M]BUP   = BUDGET
  [M]VER   = BUDVER
  [M]MTBUD = [F:BUD]AMT
 Endif
 Affzo [M]
 Return
Endif

#----------------------------------------------------------------#
# Suite pour Budgets analytiques 'classiques'(Non Opérationnels)
#** what's following is for classical analytics budgets
For EXERCICE=EXODEB To EXOFIN
 Read [BUD]BUD0 = LEDTYP;BUDGET;BUDCPY;BUDFCY;EXERCICE;BUDVER;ACC;LEDBUDCCE(1);LEDBUDCCE(2);LEDBUDCCE(3);
&                     LEDBUDCCE(4);LEDBUDCCE(5);LEDBUDCCE(6);LEDBUDCCE(7);LEDBUDCCE(8);LEDBUDCCE(9)
 If fstat : Raz [BUD] : Endif
 Case [F:BUP]BUDCTL
  When 2   : # Contrôle annuel
   [M]MTBUD = sum([F:BUD]AMT)
   [M]QTBUD = sum([F:BUD]QTY)
  When 3   : # Contrôle par période
   [M]MTBUD = [F:BUD]AMT(PERIODE-1)
   [M]QTBUD = [F:BUD]QTY(PERIODE-1)
  When 4,5 : # Contrôle global et cumulé
   If EXERCICE=EXODEB & EXERCICE=EXOFIN
    [M]MTBUD += sum([F:BUD]AMT(PERDEB-1..PERFIN-1))
    [M]QTBUD += sum([F:BUD]QTY(PERDEB-1..PERFIN-1))
   Elsif EXERCICE=EXODEB
    [M]MTBUD += sum([F:BUD]AMT(PERDEB-1..dim([F:BUD]AMT)-1))
    [M]QTBUD += sum([F:BUD]QTY(PERDEB-1..dim([F:BUD]QTY)-1))
   Elsif EXERCICE=EXOFIN
    [M]MTBUD += sum([F:BUD]AMT(0..PERFIN-1))
    [M]QTBUD += sum([F:BUD]QTY(0..PERFIN-1))
   Else
    [M]MTBUD += sum([F:BUD]AMT(0..dim([F:BUD]AMT)-1))
    [M]QTBUD += sum([F:BUD]QTY(0..dim([F:BUD]QTY)-1))
   Endif
 Endcase
Next

If DEVREF<>DEVBUD
 Call LEC_TCU(DEVREF) From CPTLEC
 [M]MTBUD = arr([M]MTBUD*COURS,[F:TCU]CURRND)
Endif

[M]CUR=DEVREF



If [F:BUP]PYMACC="" & [F:BUP]PYMCCE(0)="" & [F:BUP]PYMCCE(1)="" & [F:BUP]PYMCCE(2)="" & [F:BUP]PYMCCE(3)="" & [F:BUP]PYMCCE(4)=""
&    & [F:BUP]PYMCCE(5)="" & [F:BUP]PYMCCE(6)="" & [F:BUP]PYMCCE(7)="" & [F:BUP]PYMCCE(8)=""

 # La balance se décompose en 3, balance analytique, balance en quantité et balance d'engagemment
 CRITBLA  = "LEDTYP="+num$([L]LEDTYP)+" & CPY='"+BLACPY+"' & FCY='"+BLAFCY+"' & BPR=''"
&       -"& COA='"+PLAN+"' & ACC='"+ACC+"'"

 # Lecture de l'ordre des axes pour attribuer le bon indice /t aux sections
 N=0
 For K=1 To 9
  If NUMCCE(K)<>0
   Call ADDCRIT(CRITBLA, N, "CRITBLA", "CCE"+num$(NUMCCE(K))+"='"+BUDCCE(K)+"'", "&") From GOBJSUB
  Endif
 Next

# Sens analytique du compte ACC
 Call LEC_GAC(ACC,PLAN) From CPTLEC
 Call LEC_COA(PLAN) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
 If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif

 #Parcours des balances
 For EXERCICE=EXODEB To EXOFIN
  #Balance analytique BALANA [BLA]
  #BLA0=>LEDTYP+CPY+FCY+FIY+ACC+BPR+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9+CUR
  Filter [BLA] Where evalue(CRITBLA) & FIY=EXERCICE
  For [BLA]BLA0
   Case [F:BUP]BUDCTL
    When 2 : # Annuel
      [M]MTREL += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
    When 3 :# Par période
      [M]MTREL += SIGN*([F:BLA]DEBLED(PERIODE)-[F:BLA]CDTLED(PERIODE))
    When 4,5 : # Contrôle global et cumulé
     IEXO = EXERCICE
     If IEXO=EXODEB & IEXO=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif IEXO=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLA]DEB)-1
     Elsif IEXO=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLA]DEB)-1
     Endif
      [M]MTREL += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
    Endcase
  Next
  Filter [BLA]
  #Balance analytique en quantité BLAQTY [BLQ]
  #BLQ0=>LEDTYP+CPY+FCY+FIY+ACC+BPR+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9+CUR
  Filter [BLQ] Where evalue(CRITBLA) & FIY=EXERCICE
  For [BLQ]BLQ0
   Case [F:BUP]BUDCTL
    When 2 : # Annuel
     [M]QTREL += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
     [M]QTENG += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
     [M]QTPRE += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
    When 3 :# Par période
     [M]QTREL += SIGN*[F:BLQ]QTY(PERIODE)
     [M]QTENG += SIGN*[F:BLQ]QTYCMM(PERIODE)
     [M]QTPRE += SIGN*[F:BLQ]QTYPRP(PERIODE)
    When 4,5 : # Contrôle global et cumulé
     If IEXO=EXODEB & IEXO=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif IEXO=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLQ]QTY)-1
     Elsif IEXO=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLQ]QTY)-1
     Endif
     [M]QTREL += SIGN*sum([F:BLQ]QTY(PER1..PER2))
     [M]QTENG += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
     [M]QTPRE += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
   Endcase
  Next
  Filter [BLQ]
  #Balance analytique engagement BLACMM [BLM]
  #BLM0=>LEDTYP+CPY+FCY+FIY+ACC+BPR+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9+CUR
  Filter [BLM] Where evalue(CRITBLA) & FIY=EXERCICE
  For [BLM]BLM0
   Case [F:BUP]BUDCTL
    When 2 : # Annuel
     [M]MTENG += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
     [M]MTPRE += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
    When 3 :# Par période
     [M]MTENG += SIGN*[F:BLM]CMMLED(PERIODE)
     [M]MTPRE += SIGN*[F:BLM]CMMPRPLED(PERIODE)
    When 4,5 : # Contrôle global et cumulé
     If IEXO=EXODEB & IEXO=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif IEXO=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLM]CMM)-1
     Elsif IEXO=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLM]CMM)-1
     Endif
     [M]MTENG += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
     [M]MTPRE += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
   Endcase
  Next
  Filter [BLM]

 Next :#EXERCICE

Else

 # Cas de pyramides dans les budgets
 Raz CRITPYR, IPYR
 Call ADDCRIT(CRITPYR,IPYR,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"FCY",'FCY="'+BUDFCY+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"COA",'COA="'+PLAN+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"BPR",'BPR=""'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"FIY",'FIY>='+num$(EXODEB)," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"FIY",'FIY<='+num$(EXOFIN)," & ") From GOBJSUB

 If [F:BUP]PYMACC=""
  Call ADDCRIT(CRITPYR,IPYR,"ACC",'ACC="'+BUDACC+'"'," & ") From GOBJSUB
 Endif

 If sum(OKBUDCCE)=[F:BUP]DIENBR
  Gosub PYM_BLA
 Endif

Endif

[M]MTTOT = [M]MTREL
[M]QTTOT = [M]QTREL

If GBUDENG
 [M]MTTOT += [M]MTENG
 [M]QTTOT += [M]QTENG
Endif

If GBUDPRE
 [M]MTTOT += [M]MTPRE
 [M]QTTOT += [M]QTPRE
Endif

[M]INTIT = ACC
For K=1 To 9 : [M]INTIT -= BUDCCE(K) : Next

[M]UOM   = [F:GAC]UOM
[M]BUP = BUDGET
[M]VER = BUDVER
[M]BUDCTL = [F:BUP]BUDCTL
[M]LEDTYP = [L]LEDTYP

Case [F:BUP]BUDCTL
 When 2 : # Contrôle annuel
  Read [FIY]FIY0=SOCIETE;LEDTYP;EXODEB
  [M]DATDEB = [F:FIY]FIYSTR
  [M]DATFIN = [F:FIY]FIYEND
 When 3 : # Controle par période
  [M]DATDEB = [F:PER]PERSTR
  [M]DATFIN = [F:PER]PEREND
 When 4 : # Controle global
  [M]DATDEB = [F:BUP]VLYSTR
  If [F:BUP]VLYEND<>[0/0/0]
   [M]DATFIN = [F:BUP]VLYEND
  Else
   [M]DATFIN = [F:PER]PEREND
  Endif
 When 5 : # Controle cumulé
  [M]DATDEB = [F:BUP]VLYSTR
  [M]DATFIN = [F:PER]PEREND
Endcase

Call LEC_TUN([M]UOM) From CPTLEC
Call LECTEXTRA([M]LIBUOM,"TABUNIT","DESSHO",[M]UOM,"") From ATEXTRA
Call LEC_TCU(DEVCPY) From CPTLEC

Affzo [M:VBD] 5
Affzo [M:VBD] 10
Affzo [M:VBD] 15
Affzo [M:VBD] 20
Affzo [M:VBD] 25
Affzo [M:VBD] 30

If FILSRC<>""
 Call EFFACE(FILSRC,STAT) From ORDSYS
 Call EFFACE(FILADX,STAT) From ORDSYS
Endif

Return

$SETBOUT
ETABOU(GSUIV) = 0
ETABOU(GPREC) = 0
If GBUDNB>1
 ETABOU(GSUIV) = 1
 ETABOU(GPREC) = 1
Endif
ETABOU(GVALI) = 1
ETABOU(GBFIN) = 1
Return

$SUI
IBUD += 1 : If IBUD>NBRUN : IBUD = 1 : Endif
Gosub VISBUD
Return

$PRE
IBUD -= 1 : If IBUD<1 : IBUD = NBRUN : Endif
Gosub VISBUD
Return

$PYM_BLA
Gosub GENLNK
Gosub LIENS From =FILPROG

#Balance
For [LBLA]CLE(1)
 ACCSIGN = [F:BLA]ACC
 Gosub SEARCH_SIGN
 For [LBLA]CLE
  Case [F:BUP]BUDCTL
   When 2   : # Contrôle annuel
    [M]MTREL += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
   When 3   : # Contrôle par période
    [M]MTREL += SIGN*(sum([F:BLA]DEBLED(PERIODE)-[F:BLA]CDTLED(PERIODE)))
   When 4,5 : # Contrôle global et cumulé
    If [F:BLA]FIY=EXODEB & [F:BLA]FIY=EXOFIN
     PER1 = PERDEB
     PER2 = PERFIN
    Elsif [F:BLA]FIY=EXODEB
     PER1 = PERDEB
     PER2 = dim([F:BLA]CDT)-1
    Elsif [F:BLA]FIY=EXOFIN
     PER1 = 1
     PER2 = PERFIN
    Else
     PER1 = 1
     PER2 = dim([F:BLA]CDT)-1
    Endif
    [M]MTREL += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
  Endcase
 Next
Next

# Balance of commitment
For [LBLM]CLE(1)
 ACCSIGN = [F:BLM]ACC
 Gosub SEARCH_SIGN
 For [LBLM]CLE
  Case [F:BUP]BUDCTL
   When 2   : # Contrôle annuel
    [M]MTENG += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
    [M]MTPRE += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
   When 3   : # Contrôle par période
    [M]MTENG += SIGN*[F:BLM]CMMLED(PERIODE)
    [M]MTPRE += SIGN*[F:BLM]CMMPRPLED(PERIODE)
   When 4,5 : # Contrôle global et cumulé
    If [F:BLM]FIY=EXODEB & [F:BLM]FIY=EXOFIN
     PER1 = PERDEB
     PER2 = PERFIN
    Elsif [F:BLM]FIY=EXODEB
     PER1 = PERDEB
     PER2 = dim([F:BLM]CMM)-1
    Elsif [F:BLM]FIY=EXOFIN
     PER1 = 1
     PER2 = PERFIN
    Else
     PER1 = 1
     PER2 = dim([F:BLM]CMM)-1
    Endif
    [M]MTENG += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
    [M]MTPRE += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
  Endcase
 Next : #BLM
Next

# Balance of quantity
For [LBLQ]CLE(1)
 ACCSIGN = [F:BLQ]ACC
 Gosub SEARCH_SIGN
 For [LBLQ]CLE
  Case [F:BUP]BUDCTL
   When 2   : # Contrôle annuel
    [M]QTREL += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
    [M]QTENG += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
    [M]QTPRE += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
   When 3   : # Contrôle par période
    [M]QTREL += SIGN*sum([F:BLQ]QTY(PERIODE))
    [M]QTENG += SIGN*sum([F:BLQ]QTYCMM(PERIODE))
    [M]QTPRE += SIGN*sum([F:BLQ]QTYPRP(PERIODE))
   When 4,5 : # Contrôle global et cumulé
    If [F:BLQ]FIY=EXODEB & [F:BLQ]FIY=EXOFIN
     PER1 = PERDEB
     PER2 = PERFIN
    Elsif [F:BLQ]FIY=EXODEB
     PER1 = PERDEB
     PER2 = dim([F:BLQ]QTY)-1
    Elsif [F:BLQ]FIY=EXOFIN
     PER1 = 1
     PER2 = PERFIN
    Else
     PER1 = 1
     PER2 = dim([F:BLQ]QTY)-1
    Endif
    [M]QTREL += SIGN*sum([F:BLQ]QTY(PER1..PER2))
    [M]QTENG += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
    [M]QTPRE += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
  Endcase
 Next
Next : #BLQ
Return

# Also called from CPTBUD
$GENLNK
# Generation of the good link ...

FILPROG   = "WW"+num$(adxuid(1))
FILSRC = filpath("TRT",FILPROG,"src",0)
FILADX = filpath("TRT",FILPROG,"adx",0)

Openo FILSRC,0
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq
Wrseq "$LIENS"
Raz SEP
Wrseq '  Link [BLA] With'
If [F:BUP]PYMACC<>""
 Wrseq '&   [GYK]GYK0 ~= [F:BUP]PYMACC;[F:BUP]PYMACCLEV;[F:BLA]ACC'
 Call ADDCRIT(CRITPYR, IPYR, "GRU", '[F:GYK]GRU=BUDACC', "&") From GOBJSUB
 SEP = 1
Endif
For I=1 To [F:BUP]DIENBR
 If [F:BUP]DIE(I-1)="" : Break : Endif
 If [F:BUP]PYMCCE(I-1)<>""
  Call ADDCRIT(CRITPYR, IPYR, "GRU", '[F:CYK'+num$(I)+']GRU=BUDCCE('+num$(I)+')', "&") From GOBJSUB
  If SEP=0
   Wrseq '&   [CYK'+num$(I)+']CYK0 ~= [F:BUP]PYMCCE('+num$(I-1)+');[F:BUP]PYMCCELEV('+num$(I-1)+');[F:BLA]CCE'+num$(NUMCCE(I))
   SEP = 1
  Else
   Wrseq '& , [CYK'+num$(I)+']CYK0 ~= [F:BUP]PYMCCE('+num$(I-1)+');[F:BUP]PYMCCELEV('+num$(I-1)+');[F:BLA]CCE'+num$(NUMCCE(I))
  Endif
 Else
  Call ADDCRIT(CRITPYR, IPYR, "CCE", 'pat(CCE'+num$(NUMCCE(I))+',BUDCCE('+num$(I)+'))<>0', "&") From GOBJSUB
 Endif
Next
Wrseq "&   As [LBLA]"
Wrseq "&   Where evalue(CRITPYR)"
Wrseq "&   Order By Key CLE = ACC"


Raz SEP
Wrseq '  Link [BLM] With'
If [F:BUP]PYMACC<>""
 Wrseq '&      [GYK]GYK0  ~= [F:BUP]PYMACC;[F:BUP]PYMACCLEV;[F:BLM]ACC'
 SEP = 1
Endif
For I=1 To [F:BUP]DIENBR
 If [F:BUP]PYMCCE(I-1)<>""
  If SEP=0
   Wrseq '&      [CYK'+num$(I)+']CYK0  ~= [F:BUP]PYMCCE('+num$(I-1)+');[F:BUP]PYMCCELEV('+num$(I-1)+');[F:BLM]CCE'+num$(NUMCCE(I))
   SEP = 1
  Else
   Wrseq '&    , [CYK'+num$(I)+']CYK0  ~= [F:BUP]PYMCCE('+num$(I-1)+');[F:BUP]PYMCCELEV('+num$(I-1)+');[F:BLM]CCE'+num$(NUMCCE(I))
  Endif
 Endif
Next
Wrseq "&   As [LBLM]"
Wrseq "&   Where evalue(CRITPYR)"
Wrseq "&   Order By Key CLE = ACC"


Raz SEP
Wrseq '  Link [BLQ] With'
If [F:BUP]PYMACC<>""
 Wrseq '&      [GYK]GYK0  ~= [F:BUP]PYMACC;[F:BUP]PYMACCLEV;[F:BLQ]ACC'
 SEP = 1
Endif
For I=1 To [F:BUP]DIENBR
 If [F:BUP]PYMCCE(I-1)<>""
  If SEP=0
   Wrseq '&      [CYK'+num$(I)+']CYK0  ~= [F:BUP]PYMCCE('+num$(I-1)+');[F:BUP]PYMCCELEV('+num$(I-1)+');[F:BLQ]CCE'+num$(NUMCCE(I))
   SEP = 1
  Else
   Wrseq '&    , [CYK'+num$(I)+']CYK0  ~= [F:BUP]PYMCCE('+num$(I-1)+');[F:BUP]PYMCCELEV('+num$(I-1)+');[F:BLQ]CCE'+num$(NUMCCE(I))
  Endif
 Endif
Next
Wrseq "&   As [LBLQ]"
Wrseq "&   Where evalue(CRITPYR)"
Wrseq "&   Order By Key CLE = ACC"
Wrseq "Return"
Wrseq

Openo

# Processing validation

Call VALID("TRT",FILPROG,nomap,STAT) From VALMSKSUB
Return


# Also called from CPTBUD
$SEARCH_SIGN
# Search of the analytical sens of the account
If [F:BUP]PYMACC=""
 Call LEC_GAC(ACCSIGN,PLAN) From CPTLEC
 Call LEC_COA([F:GAC]COA) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
 If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif
Else
 Raz [F:GRY]
 For [GRY] Where PYM=[F:BUP]PYMACC and pat(ACCSIGN,ACC)<>0
  Break
 Next
 If [F:GRY]COA<>""
  Call LEC_COA([F:GRY]COA) From CPTLEC
  Call LEC_CLS([F:COA]LEGCLS, [F:GRY]CLSCOD) From CPTLEC
  If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif
 Else
  SIGN = -1
 Endif
Endif
Return

$INI_ACC_CCE
Raz BUDACC
If [F:BUP]PYMACC<>""
 Filter [GRY] Where PYM=[F:BUP]PYMACC & pat([L]ACC,ACC)<>0
 Read [GRY]GRY0 First
 Filter [GRY]
 If ! fstat
  GRUREF = [F:GRY]GRU
  Filter [GRY] Where PYM=[F:BUP]PYMACC & GRU=GRUREF & LEV=[F:BUP]PYMACCLEV
  Read [GRY]GRY0 First
  Filter [GRY]
  If !fstat
   BUDACC = GRUREF
  Else
   Read[GYK]GYK0=[F:BUP]PYMACC;[F:BUP]PYMACCLEV;[L]ACC
   If !fstat
    BUDACC = [F:GYK]GRU
   Else
    Filter [GYK] Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV
    Read [GYK]GYK0 First
    Filter [GYK]
    If !fstat
     BUDACC = [F:GYK]GRU
    Endif
   Endif
  Endif
 Endif
 # To read in the BUD table the right group of accounts when the budget is defined for a group of accounts
 [L]ACC = BUDACC
Else
 BUDACC = [L]ACC
Endif

# Sections
Raz BUDCCE
Raz OKBUDCCE
For AX=1 To dim([F:BUP]DIE)
 If [F:BUP]DIE(AX-1)="" : Break : Endif
 If [F:BUP]PYMCCE(AX-1)="" : # pas de pyramide pour cet axe
  VU = find([F:BUP]DIE(AX-1),TBDIE(1..dim(TBDIE)-1))
  If VU
   BUDCCE(AX) = TBCCE(VU)
   OKBUDCCE(AX) = 1
  Endif
 Else : # pyramide ana
  VU = find([F:BUP]DIE(AX-1),TBDIE(1..dim(TBDIE)-1))
  If VU
   BUDCCE(AX) = TBCCE(VU)
  Endif
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(AX-1) & pat(BUDCCE(AX), CCE)<>0
  Read [CRY]CRY0 First
  Filter [CRY]
  If !fstat
   GRUREF = [F:CRY]GRU
   Filter [CRY] Where PYM=[F:BUP]PYMCCE(AX-1) & GRU=GRUREF & LEV=[F:BUP]PYMCCELEV(AX-1)
   Read [CRY]CRY0 First
   Filter [CRY]
   If !fstat
    BUDCCE(AX) = GRUREF
    OKBUDCCE(AX) = 1
   Else
    If BUDCCE(AX)<>""
     Read [CYK]CYK0 = [F:BUP]PYMCCE(AX-1);[F:BUP]PYMCCELEV(AX-1);BUDCCE(AX)
     If !fstat
      BUDCCE(AX) = [F:CYK]GRU
      OKBUDCCE(AX) = 1
     Else
      Filter [CYK] Where PYM=[F:BUP]PYMCCE(AX-1) & LEV=[F:BUP]PYMCCELEV(AX-1)
      Read [CYK]CYK0 First
      Filter [CYK]
      If !fstat
       BUDCCE(AX) = [F:CYK]GRU
       OKBUDCCE(AX) = 1
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Next AX
Return

