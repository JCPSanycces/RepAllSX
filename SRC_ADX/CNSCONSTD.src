######################################################################################
######################################################################################
######################################################################################
######################################################################################
#        Pour éxécution validation écrans de consultation en gestion de patch        #
######################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If !clalev([F:ADS]) Then Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat and [F:ADS]MODULE(11) <> G_YES Then
    End
  Endif
  Call VALGTC(APPLI, "CON") From SUBGTC
End

