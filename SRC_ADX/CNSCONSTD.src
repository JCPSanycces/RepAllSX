#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation CON
#########################################################################
# CNSCONSTD : Consultation des devis ventes                             #
# ECRAN 1   : CONSCON0                                                  #
# ECRAN 2   : CONSCON1                                                  #
# ECRAN CRIT: CRITCON                                                   #
#                                     FGR 30/05/2012 : X3SUIVI60482 CRM #
#########################################################################
$ACTION
  Case GACTION
    When "CONSCON"
      Case ACTION
        When "AUTORIS"    : Gosub AUTORIS
        When "OUVRE"      : Gosub OUVRE
        When "DEB_CRIT"   : Gosub DEB_CRIT
        When "LECTURE"    : Gosub LECTURE
        When "SETBOUT"    : Gosub SETBOUT
        When "EXEBOUT"    : Gosub EXEBOUT
        When "FIN_CRIT"   : Gosub FIN_CRIT
        When Default
      Endcase
    When Default
  Endcase
Return

######################################################################################
$DEB_CRIT
  If find(GNAVIG(GPILNAV-1),"GESBPC", "GESBPR") Then
    Diszo [M:CCON]CONBPC
  Endif
  Default Mask [CCON]
  Call AM_ALLREWCON([M:CCON]ALLREWCON)
  Call AM_ORITAK([M:CCON]ORITAK)
  Call AM_ALLSITCON([M:CCON]ALLSITCON)
Return

######################################################################################
$AUTORIS
Return

######################################################################################
$OUVRE
Local Char WFIL(250)(50)      # Conditions saisies
Local Char WFIL1(250)(50)     # Conditions de gestions de pages
Local Char WFIL2(250)(50)     # Conditions spécifiques
Local Integer INBFIL
Local Integer INBFIL1
Local Integer INBFIL2
Local Char DEBNUM(GLONCON)
Local Char FINNUM(GLONCON)
Local Date DEBDAT
Local Date FINDAT
Local Char DEBBPC(GLONBPC)
Local Char FINBPC(GLONBPC)
Local Integer DEBCAT
Local Integer FINCAT

  Raz DEBNUM
  Raz FINNUM
  Raz DEBDAT
  Raz FINDAT
  Raz DEBBPC
  Raz FINBPC
  Raz DEBCAT
  Raz FINCAT
  #
  NAVIG = "CONSCON"
  Call REWWARRANTY From SUBCONB2
  Gosub DEFCRIT
Return

######################################################################################
$LECTURE
Local Char CUSSEAORI(GLONAOB)

  Default Mask [CSC0]
  Call SHOW_HIDE_ALLSITCON([M:CSC0]ALLSITCON)
  #
  If GPILNAV > 1 Then
    #acces depuis clients ou tiers
    If find(GNAVIG(GPILNAV-1),"GESBPC", "GESBPR") Then
      Diszo [M:CSC0]CONBPC
    Endif
    CUSSEAORI = "CSC0"
    Gosub LECTURE From CUSSEALIB
  Endif
  # -------------------------------------------------------
  Gosub CHANGE_MSK From GCONSULT
  If CHGPAG < 0 Then
    NOL = MAXLIG
  Endif
  # -------------------------------------------------------
  #-- Positionnement des Filtres
  Gosub LOAD_FILTER
  If PROGSPE <> "" Then
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  # -------------------------------------------------------
  # ------------------------------------------------------- #
  # CHGPAG = 1    :    Recherche                            #
  # ------ = 2    :    Suite                                #
  #        = 3    :    F5 (Rafraichissement page courante)  #
  # CHGPAG = -1   :    Dernier                              #
  # ------ = -2   :    Retour (Page précédente)             #
  # ------------------------------------------------------- #
  Default File [CON]
  #-- Application des Filtres
  If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
      RETOUR = 1
    Elsif CHGPAG = 2 Then
      RETOUR = 2
    Endif
    Case [M:CCON]TRI
      When 1
        # Tri par numéro
        Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key CON0
      When 2
        # tri par date
        If [M:CSC0]DATTAK = 1 Then
          Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONSTRDAT;[F:CON]CONNUM
        Else
          Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONENDDAT;[F:CON]CONNUM
        Endif
      When 3
        # tri par client
        Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONBPC;[F:CON]CONNUM
      When 4
        # tri par catégorie
        Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONCAT;[F:CON]CONNUM
    Endcase
  Else
    RETOUR = 1
    If CHGPAG = -1 Then
      SUITE = 1
    Else
      SUITE = 2
    Endif
    Case [M:CCON]TRI
      When 1
        # Tri par numéro
        Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key CON0 Desc
      When 2
        # tri par date
        If [M:CSC0]DATTAK = 1 Then
          Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONSTRDAT Desc;[F:CON]CONNUM Desc
        Else
          Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONENDDAT Desc;[F:CON]CONNUM Desc
        Endif
      When 3
        # tri par client
        Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONBPC Desc;[F:CON]CONNUM Desc
      When 4
        # tri par catégorie
        Filter [CON] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)Order By Key CLE=[F:CON]CONCAT Desc;[F:CON]CONNUM Desc
    Endcase
  Endif
  #-- raz du masque
  If CHGPAG <> 2 and CHGPAG <> -2 Then
    Raz [M:CSC1]
  Endif
  # --------------------------------------------------
  # -- Lecture
$BOUCLE
  For [CON] With Nohint
    If NBLU = 1 Then
      If CHGPAG = 2 or CHGPAG = -2 Then
        Raz [M:CSC1]
      Endif
       NBLU = 2
    Endif
    If CHGPAG > 0 Then
      If NOL >= MAXLIG-1 Then
        SUITE = 2
        Break
      Endif
      NOL += 1
      If NOL = 0 Then
        Gosub PLANQUE_BEGIN
      Endif
      Gosub PLANQUE_END
    Else
      If NOL <= 0 Then
        RETOUR = 2
        Break
      Endif
      NOL -= 1
      If NOL = MAXLIG-1 Then
        Gosub PLANQUE_END
      Endif
      Gosub PLANQUE_BEGIN
    Endif
    # ----------------------------------------------------------------
    nolign = NOL + 1
    [M:CSC1] = [F:CON]
    # ----------------------------------------------------------------
    If [M:CSC1]DSYWND(nolign-1) = 2 or [M:CSC1]DSYWND(nolign-1) = 4 Then
      If [M:CSC1]RSIFLG(nolign-1) = G_NO and [M:CSC1]FDDFLG(nolign-1) = G_NO Then
        # Le contrat n'est A renouveler que s'il n'est ni clôturé, ni résilié
        [M:CSC1]TBEREWCON(nolign-1) = G_YES
      Else
        [M:CSC1]TBEREWCON(nolign-1) = G_NO
      Endif
    Else
      [M:CSC1]TBEREWCON(nolign-1) = G_NO
    Endif
    # ----------------------------------------------------------------
    Case [M:CSC1]CONORI(NOL)
      When 2
        # Commande de vente
        [M:CSC1]CONORIAOB(NOL) = "SOH"
      When 3
        # Livraison de vente
        [M:CSC1]CONORIAOB(NOL) = "SDH"
      When 4
        # Facture de vente
        [M:CSC1]CONORIAOB(NOL) = "SIH"
      When 5
        # Demande de garantie
        [M:CSC1]CONORIAOB(NOL) = "RQW"
      When Default
        Raz [M:CSC1]CONORIAOB(NOL)
    Endcase
    # ----------------
  Next
  Filter [CON]
Return

######################################################################################
$PLANQUE_BEGIN
  DEBNUM = [F:CON]CONNUM
  If [M:CSC0]DATTAK = 1 Then
    DEBDAT = [F:CON]CONSTRDAT
  Else
    DEBDAT = [F:CON]CONENDDAT
  Endif
  DEBBPC = [F:CON]CONBPC
  DEBCAT = [F:CON]CONCAT
Return

######################################################################################
$PLANQUE_END
  FINNUM = [F:CON]CONNUM
  If [M:CSC0]DATTAK = 1 Then
    FINDAT = [F:CON]CONSTRDAT
  Else
    FINDAT = [F:CON]CONENDDAT
  Endif
  FINBPC = [F:CON]CONBPC
  FINCAT = [F:CON]CONCAT
Return

######################################################################################
$SETBOUT
Return

######################################################################################
$EXEBOUT
Return

######################################################################################
$FIN_CRIT
Return

######################################################################################
$LOAD_FILTER
Local Integer NI
Local Char SOR(GLONDES)
Local Char SENCCON_Y(250)
Local Char SENCCON_N(250)
Local Char STBEREWCON_Y(250)
Local Char STBEREWCON_N(250)
Local Char SRSICON_Y(250)
Local Char SRSICON_N(250)
Local Char SFDDFLG_Y(250)
Local Char SFDDFLG_N(250)

  Raz WFIL
  Raz WFIL1
  Raz WFIL2
  INBFIL = 0
  INBFIL1 = 0
  INBFIL2 = 0
  WFIL(INBFIL) = "1=1"
  WFIL1(INBFIL1) = "1=1"
  WFIL2(INBFIL2) = "1=1"
  #
  If [M:CSC0]CPY <> "" Then
    INBFIL += 1
    WFIL(INBFIL) -= "&[F:CON]CPY=[M:CSC0]CPY"
  Endif
  #
  If [M:CSC0]SALFCY <> "" Then
    INBFIL += 1
    WFIL(INBFIL) -= "&[F:CON]SALFCY=[M:CSC0]SALFCY"
  Endif
  # Autorisation site
  If GUSRFCY(1) <> "\" and [M:CSC0]SALFCY = "" and GNBAUZ <> GNBSITE Then
    INBFIL += 1
    WFIL(INBFIL) -= "& find([F:CON]SALFCY,GUSRFCY(1..GNBAUZ))"
  Endif
  #
  If [M:CSC0]CONBPC <> "" Then
    INBFIL += 1
    WFIL(INBFIL) -= "&[F:CON]CONBPC=[M:CSC0]CONBPC"
  Endif
  #
  If [M:CSC0]GUACON = G_NO Then
    # Pas Garantie
    INBFIL += 1
    WFIL(INBFIL) -= "&[F:CON]CONCAT<>1"
  Endif
  If [M:CSC0]MCECON = G_NO Then
    # Pas Maintenance
    INBFIL += 1
    WFIL(INBFIL) -= "&[F:CON]CONCAT<>3"
  Endif
  If [M:CSC0]PITCON = G_NO Then
    # Pas A points
    INBFIL += 1
    WFIL(INBFIL) -= "&[F:CON]CONCAT<>4"
  Endif
  # -----------------------------------------------------------------
  If [M:CSC0]ALLSITCON = G_NO Then
    # ---------------------------------------------------------------
    SENCCON_Y = "(([F:CON]FDDFLG = G_NO)&([F:CON]RSIFLG = G_NO))"
    SENCCON_N = "(([F:CON]FDDFLG = G_YES)|([F:CON]RSIFLG = G_YES))"
    SRSICON_Y = "([F:CON]RSIFLG = G_YES)"
    SRSICON_N = "([F:CON]RSIFLG = G_NO)"
    SFDDFLG_Y = "([F:CON]FDDFLG = G_YES)"
    SFDDFLG_N = "([F:CON]FDDFLG = G_NO)"
    # A renouveler ou pas, MAIS TOUJOURS EN COURS (donc ni clôturé ni résilité)
    STBEREWCON_Y = "([F:CON]DSYWND = 2 or [F:CON]DSYWND = 4)"
    STBEREWCON_N = "([F:CON]DSYWND <> 2 and [F:CON]DSYWND <> 4)"
    # ---------------------------------------------------------------
    INBFIL += 1
    WFIL(INBFIL) -= "&("
    Raz SOR
    # ---------------------------------------------------------------
    # En cours ------------------------------------------------------
    If [M:CSC0]ENCCON = G_YES Then
      WFIL(INBFIL) -= SOR - "((" + SENCCON_Y + ")"
      SOR = "|"
      # A renouveler ------------------------------------------------
      If [M:CSC0]TBEREWCON = G_YES Then
        WFIL(INBFIL) -= "&(" + STBEREWCON_Y + ")"
      Elsif [M:CSC0]TBEREWCON = G_NO Then
        WFIL(INBFIL) -= "&(" + STBEREWCON_N + ")"
      Endif
      WFIL(INBFIL) -= ")"
      # Résiliés ------------------------------------------------------
      If [M:CSC0]RSICON = G_YES Then
        WFIL(INBFIL) -= SOR - "(" + SRSICON_Y + ")"
        SOR = "|"
      Endif
      # Clôturés ------------------------------------------------------
      If [M:CSC0]FDDFLG = G_YES Then
        WFIL(INBFIL) -= SOR - "(" + SFDDFLG_Y + ")"
        SOR = "|"
      Endif
      # ---------------------------------------------------------------
    Else
      WFIL(INBFIL) -= SOR - "(" + SENCCON_N + ")"
      SOR = "&"
      # Résiliés ------------------------------------------------------
      If [M:CSC0]RSICON = G_NO Then
        WFIL(INBFIL) -= SOR - "(" + SRSICON_N + ")"
        SOR = "&"
      Endif
      # Clôturés ------------------------------------------------------
      If [M:CSC0]FDDFLG = G_NO Then
        WFIL(INBFIL) -= SOR - "(" + SFDDFLG_N + ")"
        SOR = "&"
      Endif
    Endif
    # ---------------------------------------------------------------
    If SOR = "" Then
      WFIL(INBFIL) -= "(1=1)"
    Endif
    WFIL(INBFIL) -= ")"
  Endif
  # -----------------------------------------------------------------
  INBFIL += 1
  If [M:CSC0]BEGCON <> "" Then
    # Borne contrat début
    WFIL(INBFIL) -= "&([F:CON]CONNUM >= [M:CSC0]BEGCON)"
  Endif
  If [M:CSC0]ENDCON <> "" Then
    # Borne contrat fin
    WFIL(INBFIL) -= "&([F:CON]CONNUM <= [M:CSC0]ENDCON)"
  Endif
  #
  If [M:CSC0]BEGDAT <> [0/0/0] or [M:CSC0]ENDDAT <> [0/0/0] Then
    INBFIL += 1
    If [M:CSC0]DATTAK = 1 Then
      # Sur date début de contrat
      If [M:CSC0]BEGDAT <> [0/0/0] Then
        WFIL(INBFIL) -= "&([F:CON]CONSTRDAT >= [M:CSC0]BEGDAT)"
      Endif
      If [M:CSC0]ENDDAT <> [0/0/0] Then
        WFIL(INBFIL) -= "&([F:CON]CONSTRDAT <= [M:CSC0]ENDDAT)"
      Endif
    Else
      # Sur date fin de contrat
      If [M:CSC0]BEGDAT <> [0/0/0] Then
        WFIL(INBFIL) -= "&([F:CON]CONENDDAT >= [M:CSC0]BEGDAT)"
      Endif
      If [M:CSC0]ENDDAT <> [0/0/0] Then
        WFIL(INBFIL) -= "&([F:CON]CONENDDAT <= [M:CSC0]ENDDAT)"
      Endif
    Endif
  Endif
  #
  If [M:CCON]ALLREWCON = G_NO Then
    INBFIL += 1
    WFIL(INBFIL) -= "&([F:CON]CONREW = [M:CCON]REWCON)"
  Endif
  #
  If dim([M:CCON]BEGREP) >= 0 Then
    # Représentants
    For NI = 0 To dim([M:CCON]BEGREP)-1
      If [M:CCON]BEGREP(NI) <> "" or [M:CCON]ENDREP(NI) <> "" Then
        INBFIL += 1
        If [M:CCON]BEGREP(NI) <> "" Then
          WFIL(INBFIL) -= "&([F:CON]SALREP(" + num$(NI) + ") >= [M:CCON]BEGREP(" + num$(NI) + "))"
        Endif
        If [M:CCON]ENDREP(NI) <> "" Then
          WFIL(INBFIL) -= "&([F:CON]SALREP(" + num$(NI) + ") <= [M:CCON]ENDREP(" + num$(NI) + "))"
        Endif
      Endif
    Next NI
  Endif
  #
  If [M:CCON]ITMREF <> "" Then
    INBFIL += 1
    WFIL(INBFIL) -= "&([F:CON]ITMREF = [M:CCON]ITMREF)"
  Endif
  #
  If [M:CCON]ORITAK = G_YES Then
    INBFIL += 1
    WFIL(INBFIL) -= "&([F:CON]CONORI = [M:CCON]CONORI)"
    #
    If [M:CCON]CONORIVCR <> "" Then
      WFIL(INBFIL) -= "&([F:CON]CONORIVCR = [M:CCON]CONORIVCR)"
    Endif
  Endif
  #----------------------------------------
  Case CHGPAG
     When 3
      # rafraichissement
      INBFIL1 += 1
      Case [M:CCON]TRI
        When 1
          # Tri par numéro
          WFIL1(INBFIL1) -= "&[F:CON]CONNUM>=DEBNUM"
        When 2
          # Tri par date
          If [M:CSC0]DATTAK = 1 Then
            WFIL1(INBFIL1) -= "&[F:CON]CONSTRDAT>=DEBDAT & [F:CON]CONNUM>=DEBNUM"
          Else
            WFIL1(INBFIL1) -= "&[F:CON]CONENDDAT>=DEBDAT & [F:CON]CONNUM>=DEBNUM"
          Endif
        When 3
          # Tri par client
          WFIL1(INBFIL1) -= "&[F:CON]CONBPC>=DEBBPC & [F:CON]CONNUM>=DEBNUM"
        When 4
          # Tri par catégorie
          WFIL1(INBFIL1) -= "&[F:CON]CONCAT>=DEBCAT & [F:CON]CONNUM>=DEBNUM"
        When Default
      Endcase
    When 2 :
       # suite
      INBFIL1 += 1
      Case [M:CCON]TRI
        When 1
          # Tri par numéro
          WFIL1(INBFIL1) -= "&[F:CON]CONNUM>FINNUM"
        When 2
          # Tri par date
          If [M:CSC0]DATTAK = 1 Then
            WFIL1(INBFIL1) -= "&([F:CON]CONSTRDAT>FINDAT | ([F:CON]CONSTRDAT=FINDAT & [F:CON]CONNUM>FINNUM))"
          Else
            WFIL1(INBFIL1) -= "&([F:CON]CONENDDAT>FINDAT | ([F:CON]CONENDDAT=FINDAT & [F:CON]CONNUM>FINNUM))"
          Endif
        When 3
          # Tri par client
          WFIL1(INBFIL1) -= "&([F:CON]CONBPC>FINBPC | ([F:CON]CONBPC=FINBPC & [F:CON]CONNUM>FINNUM))"
        When 4
          # Tri par catégorie
          WFIL1(INBFIL1) -= "&([F:CON]CONCAT>FINCAT | ([F:CON]CONCAT=FINCAT & [F:CON]CONNUM>FINNUM))"
        When Default
      Endcase
    When -2 :
      # retour
      INBFIL1 += 1
      Case [M:CCON]TRI
        When 1
          # Tri par numéro
          WFIL1(INBFIL1) -= "&[F:CON]CONNUM<DEBNUM"
        When 2
          # Tri par date
          If [M:CSC0]DATTAK = 1 Then
            WFIL1(INBFIL1) -= "&([F:CON]CONSTRDAT<DEBDAT | ([F:CON]CONSTRDAT=DEBDAT & [F:CON]CONNUM>DEBNUM))"
          Else
            WFIL1(INBFIL1) -= "&([F:CON]CONENDDAT<DEBDAT | ([F:CON]CONENDDAT=DEBDAT & [F:CON]CONNUM>DEBNUM))"
          Endif
        When 3
          # Tri par client
          WFIL1(INBFIL1) -= "&([F:CON]CONBPC<DEBBPC | ([F:CON]CONBPC=DEBBPC & [F:CON]CONNUM>=DEBNUM))"
        When 4
          # Tri par catégorie
          WFIL1(INBFIL1) -= "&([F:CON]CONCAT<DEBCAT | ([F:CON]CONCAT=DEBCAT & [F:CON]CONNUM>=DEBNUM))"
        When Default
       Endcase
    When Default
  Endcase
Return

######################################################################################
# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations                                       #
# --------------------------------------------------------------------------#
$DEFCRIT
Local Integer NI
Local Integer NCHG_ALLSITCON

  NCHG_ALLSITCON = G_NO
  If [M:CSC0]SALFCY <> "" and GUSRFCY(1) <> "\" and !find([M:CSC0]SALFCY,GUSRFCY(1..GNBAUZ)) Then
    [M:CSC0]SALFCY = ""
  Endif
  # ---------------------------------------
  For NI = 1 To dim(PARAM)
    Case NI
      When 1
        # Parametre Client
        If PARAM(NI) <> "" Then
          If [F:BPC]BPCNUM <> PARAM(NI) Then
            Read [F:BPC]BPC0=PARAM(NI)
            If fstat Then
              Raz [F:BPC], PARAM(NI)
            Endif
          Endif
          [M:CSC0]CONBPC = PARAM(NI)
        Endif
      When 2
        # Parametre Site
        If PARAM(NI) <> ""
          If [F:FCY]FCY <> PARAM(NI)Then
            Read [F:FCY]FCY0=PARAM(NI)
            If fstat Then
              Raz [F:FCY], PARAM(NI)
            Endif
          Endif
          If GUSRFCY(1) = "\" or find(PARAM(NI),GUSRFCY(1..GNBAUZ)) Then
             [M:CSC0]SALFCY = PARAM(NI)
             If [M:CSC0]SALFCY <> ""
               Call GETDEV([M:CSC0]SALFCY) From DEVSUB
               [M:CSC0]CPY  = GSOCIETE
             Endif
          Endif
        Endif
      When Default
    Endcase
  Next NI
  # ---------------------------------------
  # Bloc 2
  If !find([M:CSC0]ALLSITCON,G_NO,G_YES) Then
    Default Mask [CSC0]
    [M:CSC0]ALLSITCON = G_YES
    NCHG_ALLSITCON = G_YES
    Call AM_ALLSITCON([M:CSC0]ALLSITCON)
  Endif
  # ---------------------------------------
  # Bloc 3
  If !find([M:CSC0]GUACON,G_NO,G_YES) Then
    # Garantie
    [M:CSC0]GUACON = G_YES
  Endif
  If !find([M:CSC0]MCECON,G_NO,G_YES) Then
    # Maintenance
    [M:CSC0]MCECON = G_YES
  Endif
  If !find([M:CCON]PITCON,G_NO,G_YES) Then
    # A points
    [M:CSC0]PITCON = G_YES
  Endif
  # ---------------------------------------
  # Bloc 4
  If !find([M:CCON]ALLREWCON,G_NO,G_YES) Then
    # Tous
    [M:CCON]ALLREWCON = G_YES
    Call AM_ALLREWCON([M:CCON]ALLREWCON)
  Endif
  # ---------------------------------------
  # Bloc 5
  [M:CSC0]BEGDAT = gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
  [M:CSC0]ENDDAT = eomonth(date$)
  If !find([M:CSC0]DATTAK,1,2) Then
    [M:CSC0]DATTAK = 1
  Endif
  # ---------------------------------------
  # Bloc 8
  If !find([M:CCON]ORITAK,G_NO,G_YES) Then
    # Tous
    [M:CCON]ORITAK = G_NO
    Call AM_ORITAK([M:CCON]ORITAK)
  Endif
  # ---------------------------------------
  If !find([M:CCON]TRI,1,2) Then
    [M:CCON]TRI = 1
  Endif
  # ---------------------------------------
  # -- copie de l'écran critères (CCON) vers le masque 1 (CSC0)
  Gosub CRITENT From =PROGCNS
  # ---------------------------------------
  If NCHG_ALLSITCON = G_YES Then
    Default Mask [CCON]
    Call AM_ALLSITCON([M:CCON]ALLSITCON)
  Endif
Return

######################################################################################
Subprog SHOW_HIDE_ALLSITCON(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_NO Then
    Chgfmt [M]ENCCON With "LA:1"
    Chgfmt [M]RSICON With "LA:1"
    Chgfmt [M]FDDFLG With "LA:1"
    Affzo [M]ENCCON
    Affzo [M]RSICON
    Affzo [M]FDDFLG
    Call SHOW_HIDE_ENCCON([M]ENCCON)   # FGR 18/08/2015 : X3SUIVI110396
  Else
    Chgfmt [M]ENCCON With "-LA:1"
    Chgfmt [M]RSICON With "-LA:1"
    Chgfmt [M]FDDFLG With "-LA:1"
    Call SHOW_HIDE_ENCCON(G_YES)       # FGR 18/08/2015 : X3SUIVI110396
  Endif
  #Call SHOW_HIDE_ENCCON([M]ENCCON)    # FGR 18/08/2015 : X3SUIVI110396
End

######################################################################################
Subprog SHOW_HIDE_ENCCON(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_YES Then
    Chgfmt [M]TBEREWCON With "LA:1"
    Affzo [M]TBEREWCON
  Else
    Chgfmt [M]TBEREWCON With "-LA:1"
  Endif
End

######################################################################################
######################################################################################
######################################################################################
######################################################################################
# Gestion du masque CONSCON0/CRITCON
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    GSOCIETE = VALEUR
  Elsif [M]SALFCY = "" Then
    GSOCIETE = ""
    GLOCALDEV = ""
  Endif
  If dim([M]ZCPY) >= 0 Then
    Affzo [M]ZCPY
  Endif
  #
  Raz [M]SALFCY
  Affzo [M]SALFCY
  If dim([M]ZSALFCY) >= 0 Then
    Raz [M]ZSALFCY
    Affzo [M]ZSALFCY
  Endif
End

######################################################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
  Elsif [M]CPY = "" Then
  Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
  Endif
End

######################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    Affzo [M]CPY
    If dim([M]CPY) >= 0 Then
      Affzo [M]ZCPY
    Endif
  Elsif [M]CPY = "" Then
    GSOCIETE = ""
    GLOCALDEV = ""
  Else
  Endif
End

######################################################################################
Subprog AM_BEGCON(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    [M]ENDCON = VALEUR
  Endif
End

######################################################################################
Subprog AM_BEGDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [0/0/0] and [M]ENDDAT = [0/0/0] and [M]ENDDAT < VALEUR Then
    [M]ENDDAT = VALEUR
  Endif
End

######################################################################################
Subprog AM_ALLSITCON(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_NO Then
    [M]ENCCON = G_YES
    [M]RSICON = G_NO
    [M]FDDFLG = G_NO
  Else
    [M]ENCCON = G_YES        # FGR 18/08/2105 : X3SUIVI110396  pas G_NO
    [M]RSICON = G_YES        # FGR 18/08/2105 : X3SUIVI110396  pas G_NO
    [M]FDDFLG = G_YES        # FGR 18/08/2105 : X3SUIVI110396  pas G_NO
  Endif
  Call SHOW_HIDE_ALLSITCON(VALEUR)
  Call AM_ENCCON([M]ENCCON)
End

######################################################################################
Subprog AM_ENCCON(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_NO Then
    [M]TBEREWCON = G_NO
  Else
    [M]TBEREWCON = 3
  Endif
  Call SHOW_HIDE_ENCCON(VALEUR)
End

######################################################################################
Subprog AM_ORITAK(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_YES Then
    Chgfmt [M:CCON]CONORI With "LA:2977"
    Chgfmt [M:CCON]CONORIVCR With "K:" + num$(GLONVCR) + "X"
  Else
    Raz [M:CCON]CONORI
    Raz [M:CCON]CONORIVCR
    Chgfmt [M:CCON]CONORI With "-LA:2977"
    Chgfmt [M:CCON]CONORIVCR With "-K:" + num$(GLONVCR) + "X"
  Endif
End

######################################################################################
Subprog AM_BEGREP(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    [M]ENDREP(indice) = VALEUR
  Endif
End

######################################################################################
Subprog AM_ALLREWCON(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_YES Then
    [M:CCON]REWCON = G_NON
    Chgfmt [M:CCON]REWCON With "-LA:1"
  Else
    Chgfmt [M:CCON]REWCON With "LA:1"
  Endif
End

######################################################################################
# Gestion du masque CONSCON1
######################################################################################
Subprog IB_NBLIG
  # --------------------------------
  # GBOUT1 : Contrat de service      (toujours actif)
  # GBOUT2 : Traçabilité des pièces  (toujours actif)
  # GBOUT3 : Compétences couvertes
  # GBOUT4 : Parc couvert
  # GBOUT5 : Pièces d'origine
  # GBOUT6 : Dernière facture
  # GBOUT7 : Contraintes qualité
  # --------------------------------
  If [M:CSC1]EVRPBL(nolign-1) = G_YES Then
    Raz GBOUT3
  Endif
  #
  If [M:CSC1]EVRMAC(nolign-1) = G_YES Then
    Raz GBOUT4
  Endif
  #
  If [M:CSC1]CONORIAOB(nolign-1) = "" Then
    Raz GBOUT5
  Else
    Case [M:CSC1]CONORIAOB(nolign-1)
      When "SOH"
        # Commande de vente
        GBOUT5 = mess(332,182,1) - [M:CSC1]CONORIVCR(nolign-1)
      When "SDH"
        # Livraison de vente
        GBOUT5 = mess(1015,182,1) - [M:CSC1]CONORIVCR(nolign-1)
      When "SIH"
        # Facture de vente
        GBOUT5 = mess(1016,182,1) - [M:CSC1]CONORIVCR(nolign-1)
      When "RQW"
        # Demande de garantie
        GBOUT5 = mess(1017,182,1) - [M:CSC1]CONORIVCR(nolign-1)
      When Default
        Raz GBOUT5
    Endcase
  Endif
  #
  If [M:CSC1]OINV(nolign-1) = "" Then
    Raz GBOUT6
  Else
    GBOUT6 = mess(1018,182,1) - [M:CSC1]OINV(nolign-1)
  Endif
  #
  If [M:CSC1]CONCCN(nolign-1) = "" Then
    Raz GBOUT8
  Endif
End

######################################################################################
Subprog B1_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20), SAVACT(20)
Local Char OBJCLE(GLONCON)

  # Contrat de service
  If !GWEBSERV Then
    GCONSULT = 2
    SAVACT = GACTION : GACTION = "GOBJET"
    OBJCLE = [M:CSC1]CONNUM(nolign-1)
    Call OBJET("CON",OBJCLE,"") From GOBJET
    GACTION = SAVACT
    GCONSULT = 0
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Gosub AFF From GSAISIE
End

######################################################################################
Subprog B2_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20) , SAVACT(20)

  # Traçabilité pièces ventes
  If !GWEBSERV Then
    ## Action CONSPIV
    GCONSULT = 2
    SAVACT = GACTION : GACTION = "CONSPIV"
    PARMSK(1) = "CON"
    PARMSK(2) = [M:CSC1]CONNUM(nolign-1)
    PARMSK(3) = ""
    Call CONSULT_NUM(BASPAG,"PIV",PARMSK) From GCONSULT
    GACTION = SAVACT
    GCONSULT = 0
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Gosub AFF From GSAISIE
End

######################################################################################
Subprog B3_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20) , SAVACT(20)

  # Compétences couvertes
  If !GWEBSERV Then
    ## Action SAICONF
    GCONSULT = 2
    SAVACT = GACTION : GACTION = "SAICONF"
    PARMSK(1) = [M:CSC1]CONNUM(nolign-1)
    PARMSK(2) = "1"
    PARMSK(3) = [M:CSC1]CONBPC(nolign-1)
    PARMSK(4) = [M:CSC1]CUR(nolign-1)
    PARMSK(5) = num$([M:CSC1]EVRMAC(nolign-1))
    PARMSK(6) = num$([M:CSC1]CRSCOVSAM(nolign-1))
    Call SAISIE_NUM(BASPAG,PARMSK,"FCONF","TRTCONF","XWFCONF") From GSAISIE
    GACTION = SAVACT
    GCONSULT = 0
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Gosub AFF From GSAISIE
End

######################################################################################
Subprog B4_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20) , SAVACT(20)

  # Parc couvert
  If !GWEBSERV Then
   ## Action SAICONH
   GCONSULT = 2
   SAVACT = GACTION : GACTION = "SAICONH"
   PARMSK(1) = [M:CSC1]CONNUM(nolign-1)
   PARMSK(2) = [M:CSC1]CUR(nolign-1)
   PARMSK(3) = "1"
   PARMSK(4) = [M:CSC1]CONBPC(nolign-1)
   PARMSK(5) = ""
   PARMSK(6) = num$([M:CSC1]CRSCOVSAM(nolign-1))
   Call SAISIE_NUM(BASPAG,PARMSK,"FCONH","TRTCONH","") From GSAISIE
   GACTION = SAVACT
   GCONSULT = 2
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Gosub AFF From GSAISIE
End

######################################################################################
Subprog B5_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20), SAVACT(20)
Local Char OBJCLE(GLONCON)

  # Pièce d'origine
  If !GWEBSERV Then
    GCONSULT = 2
    SAVACT = GACTION : GACTION = "GOBJET"
    OBJCLE = [M:CSC1]CONORIVCR(nolign-1)
    Call OBJET([M:CSC1]CONORIAOB(nolign-1),OBJCLE,"") From GOBJET
    GACTION = SAVACT
    GCONSULT = 0
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Gosub AFF From GSAISIE
End

######################################################################################
Subprog B6_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20), SAVACT(20)
Local Char OBJCLE(GLONCON)

  # Dernière facture
  If !GWEBSERV Then
    GCONSULT = 2
    SAVACT = GACTION : GACTION = "GOBJET"
    OBJCLE = [M:CSC1]OINV(nolign-1)
    Call OBJET("SIH",OBJCLE,"") From GOBJET
    GACTION = SAVACT
    GCONSULT = 0
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Gosub AFF From GSAISIE
End

######################################################################################
Subprog B7_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20) , SAVACT(20)

  # Contraintes qualité
  If !GWEBSERV Then
    ## Action SAICON3
    GCONSULT = 2
    SAVACT = GACTION : GACTION = "SAICON3"
    PARMSK(1) = [M:CSC1]CONNUM(nolign-1)
    PARMSK(2) = "1"
    PARMSK(3) = [M:CSC1]CUR(nolign-1)
    Call SAISIE_NUM(BASPAG,PARMSK,"FCON3","TRTCON3","XWFCON3") From GSAISIE
    GACTION = SAVACT
    GCONSULT = 0
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
  Gosub AFF From GSAISIE
End

######################################################################################
Subprog B8_NBLIG
Local Decimal BASPAG
Local Char PARMSK(250)(1..20), SAVACT(20)
Local Char OBJCLE(GLONCON)

  # Interlocuteur
  If !GWEBSERV Then
    GCONSULT = 2
    SAVACT = GACTION : GACTION = "GOBJET"
    OBJCLE = [M:CSC1]CONCCN(nolign-1)
    Call OBJET("AIN",OBJCLE,"") From GOBJET
    GACTION = SAVACT
    GCONSULT = 0
  Endif
  If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
