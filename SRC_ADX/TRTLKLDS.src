##########################################################################################################
#   Recherche d'un tiers par rapport lead         Module CRM         septembre 2006
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Local Integer IBOKTRTLKLDS0

  IBOKTRTLKLDS0 = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Raz [M:LLD0]
  [M:LLD0]BPRNAM = PARAM(2)
  [M:LLD0]CP = PARAM(3)
  [M:LLD0]VILLE = PARAM(4)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "1"
      Gosub LIAISON        
  Endcase    
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
Return

##########################################################################################################
$LIAISON
  If [M:LLD0]BPR = "" Then
    #Il faut définir un tiers
    GMESSAGE = mess(470,177,1)
    GERR = 2
    GOK = 0
    FIN = 0
    Return
  Endif

Local Integer NOLIGNSAVE
Local Integer ILIGNE
Local Integer IBTROUVE
Local Char SZADRESSE
Local Char SZOBJET

  NOLIGNSAVE = nolign
  ILIGNE = 0
  IBTROUVE = 0
  Raz SZADRESSE
  While ILIGNE < [M:LLD0]NBBPA
    If [M:LLD0]CHOIX(ILIGNE) = 2 Then
      IBTROUVE = 1
      SZADRESSE = [M:LLD0]CODADR(ILIGNE)
      Break
    Endif    
    ILIGNE = ILIGNE+1
  Wend
  nolign = NOLIGNSAVE
  If IBTROUVE = 0 Then
    #Il faut indiquer une adresse
    GMESSAGE = mess(471,177,1)
    GERR = 2
    GOK = 0
    FIN = 0
    Return
  Endif
  If clalev([F:BPRL])=0 : Local File BPARTNER [BPRL] : Endif
  Read [BPRL]BPR0=[M:LLD0]BPR
  If [F:BPRL]BPCFLG = 2 Then
    SZOBJET = "BPC"
  Else
    SZOBJET = "BPP"
  Endif
  GBCRMFLGUPD = 1

   ## Action GOBJETC1
Local Char    PARMSK(250)(1..20) , SAVACT(20)

  SAVACT = GACTION
  GACTION = "GOBJETC1"
  Call OBJET_CHAR([M:LLD0]BPR, SZOBJET, "") From GOBJET
  GACTION = SAVACT
  Gosub AFF From GSAISIE
  FIN = 1
Return


