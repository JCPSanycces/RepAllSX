#################################################
$SOH_ERRTRA
Call ERRTRA (WTAB_SOH,WCPT_SOH,"File SORDER(SOHNUM)=") From TRTMIG
Return
$SOP_ERRTRA
Call ERRTRA (WTAB_SOP,WCPT_SOP,"File SORDERP(SOHNUM/SOPLIN/SOPSEQ)=") From TRTMIG
Return
$SOQ_ERRTRA
Call ERRTRA (WTAB_SOQ,WCPT_SOQ,"File SORDERQ(SOHNUM/SOPLIN/SOQSEQ)=") From TRTMIG
Return
$SOC_ERRTRA
Call ERRTRA (WTAB_SOC,WCPT_SOC,"File SORDERC(SOHNUM/SOPLIN)=") From TRTMIG
Return
$SVF_ERRTRA
Call ERRTRA (WTAB_SVF,WCPT_SVF,"File SVCRFOOT(VCRNUM/VCRTYP/DTA)=") From TRTMIG
Return
$CAL_ERRTRA
Call ERRTRA (WTAB_CAL,WCPT_CAL,"File CPTANALIN(ABRFIC/VCRTYP/VCRNUM/VCRLIN/VCRSEQ/CPLCLE/ANALIG)=") From TRTMIG
Return

########################################################################
$RAZ_SOH

Raz [F:SOH]APPFLG
Raz [F:SOH]BPAORD      : Raz [F:SOH]BPAINV      : Raz [F:SOH]BPAPYR
If dim([F:SOH]DIE)>0 Raz [F:SOH]DIE : Endif
Raz [F:SOH]CPY
Raz [F:SOH]DSPTOTQTY   : Raz [F:SOH]DSPTOTVOL   : Raz [F:SOH]DSPTOTWEI
Raz [F:SOH]DSPVOU      : Raz [F:SOH]DSPWEU
Raz [F:SOH]EECICT
If GACTDEB=2 Raz [F:SOH]EECLOC Endif
Raz [F:SOH]FFWADD      : Raz [F:SOH]FFWNUM      : Raz [F:SOH]ICTCTY
If dim([F:SOH]INVDTADSP)>0 Raz [F:SOH]INVDTADSP : Raz [F:SOH]INVDTATYP : Raz [F:SOH]SFISSTCOD : Endif #Gbn-101380
Raz [F:SOH]PLISTC
Raz [F:SOH]ORDNOTL     : Raz [F:SOH]ORDATIL
Raz [F:SOH]ORDINVNOTL  : Raz [F:SOH]ORDINVATIL

Return
########################################################################
$RAZ_SOP

Raz [F:SOP]CPY

Return
########################################################################
$RAZ_SOQ

Raz [F:SOQ]CPY
If dim([F:SOQ]DDTANOT)>0 Raz [F:SOQ]DDTANOT : Raz [F:SOQ]DDTANUM  Endif
Raz [F:SOQ]DSPLINFLG
Raz [F:SOQ]DSPLINVOL : Raz [F:SOQ]DSPLINWEI
Raz [F:SOQ]DSPVOU    : Raz [F:SOQ]DSPWEU
Raz [F:SOQ]LPRQTY    : Raz [F:SOQ]LPRQTYSTU  : Raz [F:SOQ]OPRQTY  : Raz [F:SOQ]OPRQTYSTU
Raz [F:SOQ]PRECOD    : Raz [F:SOQ]PREQTY     : Raz [F:SOQ]PREQTYSTU


Return
########################################################################
$RAZ_SOC

If GACTDEB=2 Raz [F:SOC]BPIEECNUM Endif
Raz [F:SOC]CPY
Raz [F:SOC]EECICT
If GACTDEB=2 Raz [F:SOC]EECLOC Endif
Raz [F:SOC]FFWADD : Raz [F:SOC]FFWNUM : Raz [F:SOC]ICTCTY
Raz [F:SOC]VACBPR

Return

########################################################################
# Initialization of the new fields for V6.0
########################################################################
$MAJ60_SOH

     [F:SOH]CPY=GSOCIETE
     If [F:SOH]SOHCAT<>4
        # Si ce n'est pas une cde ouverte, alimentation incoterm et lieu de transport CEE
        # Si c'est une cde ouverte, l'alimentation se fera dans SORDERC
        Gosub RECUP_BPD_SOH
     Endif
     # Initialisation ds le tableau des éléments de facturation
     # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
     For WI=0 To dim([F:SOH]INVDTA)-1
         If [F:SOH]INVDTA(WI)<>0
             [F:SOH]INVDTATYP(WI)=1
             WJ=find([F:SOH]INVDTA(WI),WSFINUM(0..WNBSFI-1))
             If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:SOH]INVDTATYP(WI)=3 Endif
         Endif
     Next
     # Renseignement des unités de répartition
     [F:SOH]DSPWEU=GSALDSPWEU
     [F:SOH]DSPVOU=GSALDSPVOU
     Raz [F:SOH]DSPTOTQTY, [F:SOH]DSPTOTWEI, [F:SOH]DSPTOTVOL

     # Pour les commande non soldées :
     # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
     If ([F:SOH]ORDSTA<>2 & [F:SOH]SOHCAT<>4)
         # Valorisation
         #--- entete
         Raz [M:SOH0], [M:SOH1], [M:SOH2], [M:SOH3], [M:SOH4]
         [M:SOH0]=[F:SOH]
         [M:SOH1]=[F:SOH]
         # Pour l'alim du tableau des éléments voir s'il faut appeler SAISFOOT
         [M:SOH2]=[F:SOH]
         [M:SOH3]=[F:SOH]
         nolign=0
     Endif
Return

########################################################################
$RECUP_BPD_SOH

     If ([F:SOH]EECICT="" | (GACTDEB=2 & [F:SOH]EECLOC=0))
         # Si ce n'est pas une cde ouverte, alimentation incoterm et lieu de transport CEE
         # Si c'est une cde ouverte, l'alimentation se fera dans SORDERC
         If [F:BPD]BPCNUM<>[F:SOH]BPCORD | [F:BPD]BPAADD<>[F:SOH]BPAADD
             Read [F:BPD]BPD0 = [F:SOH]BPCORD;[F:SOH]BPAADD : If fstat Raz [BPD] Endif
         Endif
         If [F:SOH]EECICT="" [F:SOH]EECICT=[F:BPD]EECICT Endif
         If GACTDEB=2 & [F:SOH]EECLOC=0 [F:SOH]EECLOC=[F:BPD]EECLOC Endif
     Endif

Return

########################################################################
$MAJ60_SOPSOC

      [F:SOC]CPY   =[F:SOH]CPY
      [F:SOC]VACBPR=[F:SOH]VACBPR

      # --- Alimentation incoterm et lieu de transport CEE
      Gosub RECUP_BPD_SOC
      # Issue 78997 : Si cde ouverte inter-site, alimentation des champs à partir de la cde ouverte d'achat
      If [F:ADS]MODULE(5)=2 & [F:SOH]BETFCY=2 & [F:SOH]ORIFCY<>"" & [F:SOH]ORIFCY<>[F:SOH]SALFCY
          Gosub RECUP_POC_SOC
      Endif

      # --- Alimentation n° d'identification CEE
      Gosub RECUP_BPR_SOC

Return

########################################################################
$RECUP_BPD_SOC

#   Alimentation incoterm si cde ouverte non inter-site         : # Issue 78997
#   Alimentation lieu de transport CEE dans tous les cas        : # Issue 78997
#     If [F:SOC]EECICT="" | (GACTDEB=2 & [F:SOC]EECLOC=0)
      If (([F:SOC]EECICT="" & ([F:ADS]MODULE(5)<>2 | [F:SOH]BETFCY<>2 | [F:SOH]ORIFCY="" | [F:SOH]ORIFCY=[F:SOH]SALFCY))
&       | (GACTDEB=2 & [F:SOC]EECLOC=0))                        : # Issue 78997
          # --- Alimentation incoterm, lieu de transport CEE
          If [F:BPD]BPCNUM<>[F:SOC]BPCORD | [F:BPD]BPAADD<>[F:SOC]BPAADD
              Read [F:BPD]BPD0 = [F:SOC]BPCORD;[F:SOC]BPAADD : If fstat Raz [BPD] Endif
          Endif
          # Issue 78997
          #If [F:SOC]EECICT="" [F:SOC]EECICT=[F:BPD]EECICT Endif
          If [F:SOC]EECICT="" & ([F:ADS]MODULE(5)<>2 | [F:SOH]BETFCY<>2 | [F:SOH]ORIFCY="" | [F:SOH]ORIFCY=[F:SOH]SALFCY)
          # Issue 78997
            [F:SOC]EECICT=[F:BPD]EECICT
          Endif
          If GACTDEB=2 & [F:SOC]EECLOC=0 [F:SOC]EECLOC=[F:BPD]EECLOC Endif
      Endif

Return

# Issue 78997
######################################################################################
# Si cde ouverte inter-site alimentation des champs à partir de la cde ouverte achat #
######################################################################################
$RECUP_POC_SOC

     If [F:SOC]EECICT=""
         # Alimentation incoterm à partir de la cde ouverte d'achat
         If [F:POC]POHNUM<>[F:SOC]CUSORDREF | [F:POC]POPLIN<>[F:SOC]SOPLIN
            Read [F:POC]POC0 = [F:SOC]CUSORDREF;[F:SOC]SOPLIN : If fstat Raz [POC] Endif
         Endif
         [F:SOC]EECICT=[F:POC]EECICT2
         If [F:SOC]EECICT=""
             # Alimentation incoterm à partir du fournisseur
             If [F:BPS]BPSNUM<>[F:POC]BPSNUM
                Read [F:BPS]BPS0 = [F:POC]BPSNUM : If fstat Raz [BPS] Endif
             Endif
             [F:SOC]EECICT=[F:BPS]EECICT
         Endif
     Endif

Return
# Issue 78997

########################################################################
$RECUP_BPR_SOC

      If GACTDEB=2 & [F:SOC]BPIEECNUM=""
          # --- Alimentation n° d'identification CEE
          If [F:BPR]BPRNUM<>[F:SOH]BPCINV
              Read [F:BPR]BPR0 = [F:SOH]BPCINV : If fstat Raz [BPR] Endif
          Endif
          [F:SOC]BPIEECNUM=[F:BPR]EECNUM
      Endif

Return

########################################################################
# Initialization of the new fields for V6.1
########################################################################
$MAJ61_SOH

      If dim([F:SOH]APPFLG)>0 & [F:SOH]APPFLG=0 [F:SOH]APPFLG=4 Endif : # Init du flag signée à 4 : Pas de signature

Return


########################################################################
# Initialization of the new fields (Open order lines) for V6.0
########################################################################
$MAJ60_SOPSOQSOH

      # Pour les commande non soldées :
      # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
      If [F:SOH]ORDSTA<>2
              If nolign>=dim([M:SOH4]UPDFLG) Return Endif        : # Bug 69648
              nolign += 1
              [M:SOH4]=[F:SOP]
              [M:SOH4]=[F:SOQ]
              [M:SOH4]VAT1(nolign-1)    = [F:SOP]VAT(0)
              [M:SOH4]VAT2(nolign-1)    = [F:SOP]VAT(1)
              [M:SOH4]VAT3(nolign-1)    = [F:SOP]VAT(2)
              [M:SOH4]VACITM1(nolign-1) = [F:SOP]VACITM(0)
              [M:SOH4]VACITM2(nolign-1) = [F:SOP]VACITM(1)
              [M:SOH4]VACITM3(nolign-1) = [F:SOP]VACITM(2)
              [M:SOH4]NBLIG+=1
              [F:SOP]CPY=[F:SOH]CPY
              WFICD="SOQ" : WFICD1="SOP" : WFICE="SOH" : Gosub ALIM_FICD
      Else
              [F:SOP]CPY=[F:SOH]CPY
              WFICD="SOQ" : WFICD1="SOP" : WFICE="SOH" : Gosub ALIM_FICD
      Endif
Return

########################################################################
$SUITE_MAJ60_SOH

      # Pour les commande non soldées :
      # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
      If ([F:SOH]ORDSTA<>2 & [F:SOH]SOHCAT<>4)
         # Bug 69648
         If nolign>=dim([M:SOH4]UPDFLG)
             Call ECR_TRACE("File SORDER"-[F:SOH]SOHNUM-":"-mess (26,100,1)-mess(224,139,1)-":"-"SOH",1) From GESECRAN
         Else
         # Bug 69648
             [M:SIH0]ORICLC="GESSOH"
             #Call CHARG_SIHX From TRTVENFACC : # Bug 70931
             Gosub CHARG_TABLEAUX  From TRTVENFACC
             If [M:SIH4]NBLIG>0
                 Gosub CAL_FACTURE     From TRTVENFACC
             Endif
             #-- création des enr dans les tables SVCRVAT et SVCRFOOT à partir de l'écran [M:SIHV]
             WVCRTYP=20 : WVCRNUM=[F:SOH]SOHNUM
#             # Faut-il systématiquement supprimer
#             Delete [SVF] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#                 If fstat=1
#                     GOK=-1 : GLOCK="$SVCRFOOT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#                 Endif
#             Delete [SVV] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#                 If fstat=1
#                     GOK=-1 : GLOCK="$SVCRVAT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#                 Endif
             Gosub UPD_SVF_SIHV : Gosub UPD_SVV_SIHV
             [F:SOH]ORDINVNOT =[M:SIHV]INVNOT
             [F:SOH]ORDINVATI =[M:SIHV]INVATI
             [F:SOH]ORDINVNOTL=[M:SIHV]INVNOTRPT
             [F:SOH]ORDINVATIL=[M:SIHV]INVATIRPT
#             Call ECR_TRACE("SORDER : "-[F:SOH]SOHNUM,1) From GESECRAN
         Endif :  # Bug 69648
      Endif

      # Alimentation des montants en devise société
      If [F:SOH]ORDNOT<>0
        Call COURMNT([F:SOH]CUR,GLOCALDEV,GLOCALDEV,[F:SOH]CHGTYP,[F:SOH]ORDDAT,1,
&                    [F:SOH]ORDNOT,[F:SOH]ORDNOTL,[F:SOH]CHGRAT,WRET) From TRTDEV
        If WRET <> 0 Then
          # FGR 12/01/2010 : X3SUIVI61184
          Call ECR_TRACE("     1-File SORDER"-[F:SOH]SOHNUM+", Error ="-num$(WRET),-1) From GESECRAN
        Endif
      Endif
      If [F:SOH]ORDATI<>0
        Call COURMNT([F:SOH]CUR,GLOCALDEV,GLOCALDEV,[F:SOH]CHGTYP,[F:SOH]ORDDAT,1,
&                    [F:SOH]ORDATI,[F:SOH]ORDATIL,[F:SOH]CHGRAT,WRET) From TRTDEV
        If WRET <> 0 Then
          # FGR 12/01/2010 : X3SUIVI61184
          Call ECR_TRACE("     2-File SORDER"-[F:SOH]SOHNUM+", Error ="-num$(WRET),-1) From GESECRAN
        Endif
      Endif
      Gosub RECUP_BPR

Return

########################################################################
$RECUP_BPR

    If [F:SOH]BPAORD="" | [F:SOH]BPAPYR="" | [F:SOH]BPAINV=""
      If [F:BPC]BPCNUM<>[F:SOH]BPCORD
        Read [BPC]BPC0=[F:SOH]BPCORD
        If fstat Raz [F:BPC] Endif
      Endif
    Endif

    If [F:SOH]BPAORD=""
      [F:SOH]BPAORD=[F:BPC]BPAADD
    Endif

    If [F:SOH]BPAPYR=""
#     [F:SOH]BPAPYR=[F:BPC]BPAPYR
      If [F:SOH]BPCPYR=[F:BPC]BPCPYR
           [F:SOH]BPAPYR=[F:BPC]BPAPYR
      Else
          If [F:BPR]BPRNUM<>[F:SOH]BPCPYR
              Read [BPR]BPR0=[F:SOH]BPCPYR
              If fstat Raz [F:BPR] Endif
          Endif
          [F:SOH]BPAPYR=[F:BPR]BPAADD
      Endif
    Endif

    If [F: SOH]BPAINV=""
#     [F:SOH]BPAINV=[F:BPC]BPAINV
      If [F:SOH]BPCINV=[F:BPC]BPCINV
          [F:SOH]BPAINV=[F:BPC]BPAINV
      Else
          If [F:BPR]BPRNUM<>[F:SOH]BPCINV
              Read [BPR]BPR0=[F:SOH]BPCINV
              If fstat Raz [F:BPR] Endif
          Endif
          [F:SOH]BPAINV=[F:BPR]BPAADD
      Endif
    Endif

Return

########################################################################
$AMAJ60_SOP
    Gosub UPD_CAL_SOP
Return
########################################################################
# 107890 : Scheduled invoices : (LD:25/03/16)
# Source folder version before V11 [CHALLENGER-U11]
########################################################################
$MAJ110_SOQ

If [F:SOQ]DLVFLG=0 [F:SOQ]DLVFLG = 2 Endif : # Type of flow deliverable

Return
# 107890 : Scheduled invoices : (LD:25/03/16)
########################################################################
########################################################################
# Initialization of the new fields for V8 [AKIRA]
########################################################################
$MAJ80_SOH
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:SOH]CPY,GSOC)) #108649.n
      For I=0 To dim([F:SOH]INVDTA)-1
          If [F:SOH]INVDTA(I)<>0
              Local Integer WJ
              WJ=find([F:SOH]INVDTA(I),WSFINUM(0..WNBSFI))
              If WJ>0 : [F:SOH]SFISSTCOD(I)=WSFISSTCOD(WJ-1) : Endif
          Endif
      Next
  Endif
Return

########################################################################
# Initialization of the new fields (open orders lines) for V8 [AKIRA]
########################################################################
$MAJ80_SOPSOC
    #SST Line Level Override
    #If GACTLTA & GLOCUSATAX #108649.o
    If GSSTTAX(find([F:SOH]CPY,GSOC)) #108649.n
         If [F:SOC]ITMREF<>""
            Read [F:ITM]ITM0 = [F:SOC]ITMREF
            If !fstat #Record exists
                If [F:ITM]SSTCOD <> ""
                    [F:SOC]SSTCOD = [F:ITM]SSTCOD
                Endif
            Endif
        Endif
    Endif
Return

# -------------------------------------------------- #
# Création des enregistrements de la table CPTANALIN #
# -------------------------------------------------- #
$UPD_CAL_SOP

#Look [CAL] CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
#If fstat
    Raz [F:CAL]
    [F:CAL]ABRFIC="SOP"
    [F:CAL]VCRNUM=[F:SOP]SOHNUM
    [F:CAL]VCRLIN=[F:SOP]SOPLIN
    [F:CAL]VCRSEQ=[F:SOP]SOPSEQ
    [F:CAL]ANALIG=1
    For J=1 To max(GNBCOA,2)
        [F:CAL]LED(J-1)=GLEDSOC(J)
        [F:CAL]COA(J-1)=GCOA(J)
    Next J
    Gosub EVAL_CAL

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub CAL_STK : # pour stocker ref
#        WriteB [F:CAL]
#    Else
#        Write [F:CAL]
#    Endif
#    If fstat
#      If NEWMOTEUR & adxwrb>1
#        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#        Gosub CAL_ERRTRA : # pour afficher les ref
#      Else
#        Call ECR_TRACE("File CPTANALIN SOP 0"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)
#&                                +", Error ="-num$(fstat),1) From GESECRAN
#      Endif
#      GOK=0 : Return
#    Endif
    Gosub CAL_STK : # pour stocker ref
    WriteB [F:CAL]
    If fstat
      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA : # pour afficher les ref
      GOK=0 : Return
    Endif
    # Issue 106947 - 20150811 by LD
#Endif

Return


$EVAL_CAL
  For J=1 To max(GNBDIE,GOPTCANA)
      [F:CAL]DIE(J-1)=GDIE(J)
      Case J
          When 1 : [F:CAL]CCE(J-1)=[F:SOPM]CCE1
          When 2 : [F:CAL]CCE(J-1)=[F:SOPM]CCE2
          When 3 : [F:CAL]CCE(J-1)=[F:SOPM]CCE3
          When 4 : [F:CAL]CCE(J-1)=[F:SOPM]CCE4
          When 5 : [F:CAL]CCE(J-1)=[F:SOPM]CCE5
          When 6 : [F:CAL]CCE(J-1)=[F:SOPM]CCE6
          When 7 : [F:CAL]CCE(J-1)=[F:SOPM]CCE7
          When 8 : [F:CAL]CCE(J-1)=[F:SOPM]CCE8
          When 9 : [F:CAL]CCE(J-1)=[F:SOPM]CCE9
          When Default
      Endcase

#       If evalue("dim([F:SOPM]CCE"+num$(J)+")")>0
#           [F:CAL]CCE(J-1)=evalue("[F:SOPM]CCE"+num$(J))
#       Endif

  Next J
Return


# ---------------------------------------------------- #
# Creation dans la table SVCRFOOT à partir de [M:SIHV] #
# ---------------------------------------------------- #
$UPD_SVF_SIHV
# On boucle sur la table des élements de pied
For JL=0 To dim([M:SIHV]XFNUM)-1
#  If [M:SIHV]XFNUM(JL)<>0                              : # Issue 74556 - Optimisation
  If [M:SIHV]XFNUM(JL)<>0 & [M:SIHV]XFNOT(JL)<>0        : # Issue 74556 - Optimisation
##     Look [SVF] SVF0=WVCRNUM;WVCRTYP;[M:SIHV]XFNUM(JL)
##     If fstat
         Raz [F:SVF]
         [F:SVF]VCRTYP=WVCRTYP : [F:SVF]VCRNUM=WVCRNUM

         [F:SVF]CPY=GSOCIETE
         [F:SVF]CUR=[M:SIHV]VCUR

#         If evalue("dim([F:SVF]CREDAT)")>0
#              Assign "[F:SVF]CREDAT" With date$
#         Endif
#         If evalue("dim([F:SVF]CREUSR)")>0
#              Assign "[F:SVF]CREUSR" With GUSER
#         Endif

         [F:SVF]CREDAT = date$
         [F:SVF]CREUSR = GUSER

         [F:SVF]DTA        = [M:SIHV]XFNUM(JL)
         [F:SVF]DTAAMT     = [M:SIHV]XFDTAAMT(JL)
         [F:SVF]DTATYP     = [M:SIHV]CLCBAS(JL)
         [F:SVF]DTANOT     = [M:SIHV]XFNOT(JL)

         For I=0 To dim([F:SVF]DTANET)-1
             [F:SVF]DTAVATNOT(I) = evalue ("[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTANET(I)    = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVAT(I)    = evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVATRAT(I) = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVATAMT(I) = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
         Next

         [F:SVF]CLCORD     = [M:SIHV]CLCORD(JL)
         [F:SVF]AMTCOD     = [M:SIHV]AMTCOD(JL)
         [F:SVF]DTADSP     = [M:SIHV]DSP(JL)

          # Issue 106947 - 20150811 by LD : Migration of historic folder
#          If NEWMOTEUR
#              Gosub SVF_STK : # pour stocker ref
#              WriteB [F:SVF]
#          Else
#              Write [F:SVF]
#          Endif
#          If fstat
#            If NEWMOTEUR & adxwrb>1
#              Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
#              Gosub SVF_ERRTRA : # pour afficher les ref
#            Else
#              Call ECR_TRACE("File SVCRFOOT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XFNUM(JL))+", Error ="-num$(fstat),1) From GESECRAN
#            Endif
#            GOK=0 : Break
#          Endif
          Gosub SVF_STK : # pour stocker ref
          WriteB [F:SVF]
          If fstat
            Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
            Gosub SVF_ERRTRA : # pour afficher les ref
            GOK=0 : Break
          Endif
          # Issue 106947 - 20150811 by LD
     Endif
##  Endif
Next JL

Return

# --------------------------------------------------- #
# Creation dans la table SVCRVAT à partir de [M:SIHV] #
# --------------------------------------------------- #
$UPD_SVV_SIHV
Local Integer I
Local Char    WVAT (GLONVAT)

# On boucle sur la table des taxes liées aux produits
For JL=0 To dim ([M:SIHV]XVTAX)-1
  If [M:SIHV]XVTAX(JL)<>""
##     Look [SVV] SVV0=WVCRTYP;WVCRNUM;[M:SIHV]XVTAX(JL)
##     If fstat
         Raz [F:SVV]
         [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

         [F:SVV]CPY=GSOCIETE
         [F:SVV]CUR=[M:SIHV]VCUR

#         If evalue("dim([F:SVV]CREDAT)")>0
#             Assign "[F:SVV]CREDAT" With date$
#         Endif
#         If evalue("dim([F:SVV]CREUSR)")>0
#             Assign "[F:SVV]CREUSR" With GUSER
#         Endif

         [F:SVV]CREDAT = date$
         [F:SVV]CREUSR = GUSER

         [F:SVV]VAT       = [M:SIHV]XVTAX(JL)
         [F:SVV]VATTYP    = [M:SIHV]XVTYP(JL)
         [F:SVV]VATRAT    = [M:SIHV]XVRAT(JL)

         [F:SVV]VATGRO    = [M:SIHV]XVNOT(JL)
         [F:SVV]VATNET    = [M:SIHV]XVSMI(JL)
         [F:SVV]VATAMT    = [M:SIHV]XVAMT(JL)
         [F:SVV]VATSUPAMT = [M:SIHV]XVSUP(JL)

         [F:SVV]BASTAX    = [M:SIHV]XVSMI(JL)
         [F:SVV]AMTTAX    = [M:SIHV]XVAMT(JL)

         Write [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Endif
##  Endif
Next JL

# On boucle sur la table des éléments de pied
For JL=0 To dim([M:SIHV]XFTAX)-1
  If [M:SIHV]XFTAX(JL)<>""
     Read [SVV]SVV0=WVCRTYP;WVCRNUM;[M:SIHV]XFTAX(JL)
     If fstat
         Raz [F:SVV]
         [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

         [F:SVV]CPY=GSOCIETE
         [F:SVV]CUR=[M:SIHV]VCUR

#         If evalue("dim([F:SVV]CREDAT)")>0
#             Assign "[F:SVV]CREDAT" With date$
#         Endif
#         If evalue("dim([F:SVV]CREUSR)")>0
#             Assign "[F:SVV]CREUSR" With GUSER
#         Endif

         [F:SVV]CREDAT = date$
         [F:SVV]CREUSR = GUSER

         [F:SVV]VAT    = [M:SIHV]XFTAX(JL)
         [F:SVV]VATTYP = 1
         [F:SVV]VATRAT = [M:SIHV]XFRAT(JL)

         [F:SVV]BASTAX = [M:SIHV]XFSMI(JL)
         [F:SVV]AMTTAX = [M:SIHV]XFVATAMT(JL)

         Write [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Else
         [F:SVV]BASTAX += [M:SIHV]XFSMI(JL)
         [F:SVV]AMTTAX += [M:SIHV]XFVATAMT(JL)

         Rewrite [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Endif
  Elsif [M:SIHV]XFVATAMT(JL)<>0
     For I=0 To dim([M:SIHV]XVTAX)-1
         If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",I+1)+")")>0
             If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")") <> ""
                 WVAT=evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                 Read [SVV]SVV0=WVCRTYP;WVCRNUM;WVAT
                 If fstat
                     Raz [F:SVV]
                     [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

                     [F:SVV]CPY=GSOCIETE
                     [F:SVV]CUR=[M:SIHV]VCUR

#                     If evalue("dim([F:SVV]CREDAT)")>0
#                         Assign "[F:SVV]CREDAT" With date$
#                     Endif
#                     If evalue("dim([F:SVV]CREUSR)")>0
#                         Assign "[F:SVV]CREUSR" With GUSER
#                     Endif

                     [F:SVV]CREDAT = date$
                     [F:SVV]CREUSR = GUSER

                     [F:SVV]VAT    = WVAT
                     [F:SVV]VATTYP = 1
                     [F:SVV]VATRAT = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                     [F:SVV]BASTAX = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                     [F:SVV]AMTTAX = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                     Write [F:SVV]
                     If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                 Else
                     [F:SVV]BASTAX += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                     [F:SVV]AMTTAX += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                     Rewrite [F:SVV]
                     If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                 Endif
             Endif
         Endif
     Next
  Endif
Next JL

Return


$READ_ITM
WITMREF = [F:SOP]ITMREF
If [F:ITM]ITMREF<>WITMREF
    Read [F:ITM]ITM0 = WITMREF : If fstat Raz [ITM] Endif
Endif
Return

$ALIM_FICD

[F:SOQ]CPY= [F:SOH]CPY

[F:SOQ]DSPLINFLG= 2

Gosub READ_ITM

WMNTCALC = [F:ITM]ITMWEI * [F:SOQ]QTY * [F:SOP]SAUSTUCOE
WUOM1=[F:ITM]WEU
WUOM2=GSALDSPWEU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,WMNTCALC)
Gosub CONVERT_QTY From UUMGTRTSAL00
WMNTCALC=WQTY
[F:SOQ]DSPLINWEI= WMNTCALC

WMNTCALC = [F:ITM]ITMVOU * [F:SOQ]QTY * [F:SOP]SAUSTUCOE
WUOM1=[F:ITM]VOU
WUOM2=GSALDSPVOU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,WMNTCALC)
Gosub CONVERT_QTY From UUMGTRTSAL00
WMNTCALC=WQTY
[F:SOQ]DSPLINVOL= WMNTCALC

[F:SOQ]DSPWEU= [F:SOH]DSPWEU
[F:SOQ]DSPVOU= [F:SOH]DSPVOU

WMONT  = [F:SOH]DSPTOTQTY
If WFICD<>"SQD"
    WMONT += [F:SOQ]QTYSTU
Else
    WMONT += [F:SQD]QTY
Endif
[F:SOH]DSPTOTQTY= WMONT

WMONT  = [F:SOH]DSPTOTWEI
WMONT += [F:SOQ]DSPLINWEI
[F:SOH]DSPTOTWEI= WMONT

WMONT  = [F:SOH]DSPTOTVOL
WMONT += [F:SOQ]DSPLINVOL
[F:SOH]DSPTOTVOL= WMONT

Return

###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGTRTSAL03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSAL03(APPLI)
End

