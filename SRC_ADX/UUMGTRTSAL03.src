#<AdxTL>@(#)3.0.0.0 $Revision$
###############################################################################
# UUMGTRTSAL03   Open orders migration script                    Sales module #
###############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTSAL03") From LECFIC
  Endif
  #Call RAZ_UUMGTRTSAL03(DOSSIER)
  Call MAJ_UUMGTRTSAL03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
# UUMGTRTSAL03 Moulinette de Migration des commandes ouvertes
Subprog MAJ_UUMGTRTSAL03(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMSOHM,WNAMSOPM,WNAMSOQM,WNAMSOCM
Call MIGTABNAME (DOSSIER,"SORDER", WNAMSOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERP",WNAMSOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERQ",WNAMSOQM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERC",WNAMSOCM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSOHM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSOPM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSOQM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSOCM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",2,ERR) From TRTMIG : #2=En cours
Gosub MIG_OUVRE From TRTMIG #Gbn-108768

###################

Local Char WTAB_SOH (30) (adxwrb)
Local Char WTAB_SOP (90) (adxwrb)
Local Char WTAB_SOQ (90) (adxwrb)
Local Char WTAB_SOC (90) (adxwrb)
Local Char WTAB_CAL (120) (adxwrb)
Local Shortint WCPT_SOH,WCPT_SOP,WCPT_SOQ,WCPT_SOC,WCPT_CAL

Call ECR_TIME("UUMGTRTSAL03 Sales Order Process : Update SORDER-Q-P-C") From DOSSUB
Call ECR_TRACE("UUMGTRTSAL03 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"SORDER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SORDERP",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SORDERQ",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SORDERC",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:SOH])  = 0 : Local File =DOSSIER+".SORDER"       [SOH]  : Endif   # Fichier X3 "Vide"
If clalev([F:SOP])  = 0 : Local File =DOSSIER+".SORDERP"      [SOP]  : Endif   # Fichier X3 "Vide"
If clalev([F:SOQ])  = 0 : Local File =DOSSIER+".SORDERQ"      [SOQ]  : Endif   # Fichier X3 "Vide"
If clalev([F:SOC])  = 0 : Local File =DOSSIER+".SORDERC"      [SOC]  : Endif   # Fichier X3 "Vide"

If clalev([F:SOHM]) = 0 : Local File =DOSSIER+"."+WNAMSOHM    [SOHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SOPM]) = 0 : Local File =DOSSIER+"."+WNAMSOPM    [SOPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SOQM]) = 0 : Local File =DOSSIER+"."+WNAMSOQM    [SOQM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SOCM]) = 0 : Local File =DOSSIER+"."+WNAMSOCM    [SOCM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#101380 SST Line Level Override .sn
Local Char WPARAM(GLONADP)
#101380 SST Line Level Override .en


# Déclaration des variables communes de travail
Local Integer I, J

#déclaration des variables locales de travail

Gosub OUVRE_SAL From UUMGTRTSAL00
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif
# Issue 78997
Gosub OUVRE_SAL03
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif
# Issue 78997

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTSAL03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(4))

# Pour les commandes ouvertes pas de link possible car SOC SOP SOQ ne sont pas obligatoires
# On fait des boucles for
##-----  Lien des tables entête & lignes -----#
##----- on ne met pas le numero de ligne dans le tri
#Link [SOCM] With [SOHM]SOH0=[F:SOCM]SOHNUM,
#&    [ITM]ITM0=[F:SOCM]ITMREF
#&    As [LNK] Where [F:SOCM]SOHCAT=4
#&    Order By Key CLE = [F:SOCM]SALFCY;[F:SOCM]SOHNUM;[F:SOCM]SOPLIN

Link [SOHM] With [BPC]BPC0=[F:SOHM]BPCORD As [LNK]
&    Order By Key CLE = [F:SOHM]SOHCAT;[F:SOHM]SALFCY;[F:SOHM]SOHNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTSAL03" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

# Boucle de traitement des commandes normales, prêts, à facturation directe
$LOOP_SAL03
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:SOHM]SOHCAT=4 & [F:SOHM]SALFCY=TABMIGKEY(2) & [F:SOHM]SOHNUM>TABMIGKEY(3)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:SOHM]SOHCAT=4 & [F:SOHM]SALFCY>TABMIGKEY(2)"
Else
 CRITERE = "[F:SOHM]SOHCAT=4"
Endif

Trbegin [SOH],[SOC],[SOQ],[SOP]
GOK = 1

For [LNK]CLE(3) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  #rupture par site,commande
  NBLUS+=1

  # PE pour exclure ligne
  If  FILTRELIN
    FLUX="UUMGTRTSAL03" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_LOOP : Endif
  Endif

  #Raz [F:SOH]
  Gosub RAZ_SOH
  [F:SOH] = [F:SOHM]

  If WSITE<>[F:SOHM]SALFCY
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SOHM]SALFCY) From TRTX3CPT
      Call GLOBVAR([F:SOHM]SALFCY) From WWGLOBVEN
      WSITE=[F:SOHM]SALFCY

      #108649.so
      #If GACTKUS
      #    Call PARAM([F:SOHM]SALFCY,"USATAX",WPARAM) From ADOVAL
      #    GLOCUSATAX=val(WPARAM)
      #    If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
      #Else
      #    Raz GLOCUSATAX
      #Endif
      #108649.eo
  Endif

  If dim([F:SOH]DIE)>0 & [F:SOH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
          [F:SOH]DIE(I-1)=GDIE(I)
      Next I
  Endif

  # Source folder version before V6.0
  If VERSION<GMIGX3VER60
    Gosub MAJ60_SOH
    If GOK<1 : Break : Endif
  Endif

  # Source folder version before V6.1
  If VERSION<GMIGX3VER61
    Gosub MAJ61_SOH
    If GOK<1 : Break : Endif
  Endif

  #101380 SST Line Level Override .sn
  # Source folder version before V8 [AKIRA]
  If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
    Gosub MAJ80_SOH
    If GOK<1 : Break : Endif
  Endif
  #101380 SST Line Level Override .en

  ###################################
  #-- Boucle sur les lignes articles
  ###################################
  For [SOCM]SOC0 Where SOHNUM=[F:SOH]SOHNUM

    #rupture par ligne article
    #Raz [F:SOC]
    Gosub RAZ_SOC
    [F:SOC] = [F:SOCM]

    # Source folder version before V6.0
    If VERSION<GMIGX3VER60
      Gosub MAJ60_SOPSOC
      If GOK<1 : Break : Endif
    Endif

    #101380 SST Line Level Override .sn
    # Source folder version before V8 [AKIRA]
    If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
      Gosub MAJ80_SOPSOC
      If GOK<1 : Break : Endif
    Endif
    #101380 SST Line Level Override .en

    ###################################
    #-- Boucle sur les lignes qté
    ###################################
    For [SOQM]SOQ0 Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN

        #Raz [F:SOQ]
        Gosub RAZ_SOQ
        [F:SOQ] = [F:SOQM]
        [F:SOQ]CPY=GSOCIETE

        # 107890 : Scheduled invoices : (LD:25/03/16)
        # Source folder version before V11 [CHALLENGER-U11]
        If VERSION<GMIGX3VER110
          Gosub MAJ110_SOQ
          If GOK<1 : Break : Endif
        Endif
        # 107890 : Scheduled invoices : (LD:25/03/16)

        # Issue 106947 - 20150811 by LD : Migration of historic folder
#        If NEWMOTEUR
#            Gosub SOQ_STK : # pour stocker ref
#            WriteB [SOQ]
#        Else
#            Write [SOQ]
#        Endif
#        If fstat
#            If NEWMOTEUR & adxwrb>1
#              Call ECR_TRACE("File SORDERQ, Error ="-num$(fstat),1) From GESECRAN
#              Gosub SOQ_ERRTRA : # pour afficher les ref
#            Else
#              Call ECR_TRACE("File SORDERQ(SOHNUM/SOPLIN/SOQSEQ)"-[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)+", ERROR ="-num$(fstat),1) From GESECRAN
#            Endif
#            GOK=0 : Break
#        Endif
        Gosub SOQ_STK : # pour stocker ref
        WriteB [SOQ]
        If fstat
            Call ECR_TRACE("File SORDERQ, Error ="-num$(fstat),1) From GESECRAN
            Gosub SOQ_ERRTRA : # pour afficher les ref
            GOK=0 : Break
        Endif
        # Issue 106947 - 20150811 by LD
    Next
    If GOK<1 Break Endif

    ###################################
    #-- Boucle sur les lignes prix
    ###################################
    For [SOPM]SOP0 Where SOHNUM=[F:SOC]SOHNUM & SOPLIN=[F:SOC]SOPLIN

        #Raz [F:SOP]
        Gosub RAZ_SOP
        [F:SOP] = [F:SOPM]
        [F:SOP]CPY=GSOCIETE

        # Source folder version before V6.0
        If VERSION<GMIGX3VER60
          Gosub AMAJ60_SOP
          If GOK<1 : Break : Endif
        Endif
        # Issue 106947 - 20150811 by LD : Migration of historic folder
#        If NEWMOTEUR
#            Gosub SOP_STK : # pour stocker ref
#            WriteB [SOP]
#        Else
#            Write [SOP]
#        Endif
#        If fstat
#            If NEWMOTEUR & adxwrb>1
#              Call ECR_TRACE("File SORDERP, Error ="-num$(fstat),1) From GESECRAN
#              Gosub SOQ_ERRTRA : # pour afficher les ref
#            Else
#              Call ECR_TRACE("File SORDERP(SOHNUM/SOPLIN/SOPSEQ)"-[F:SOP]SOHNUM-num$([F:SOP]SOPLIN)-num$([F:SOP]SOPSEQ)+", ERROR ="-num$(fstat),1) From GESECRAN
#            Endif
#            GOK=0 : Break
#        Endif
        Gosub SOP_STK : # pour stocker ref
        WriteB [SOP]
        If fstat
            Call ECR_TRACE("File SORDERP, Error ="-num$(fstat),1) From GESECRAN
            Gosub SOQ_ERRTRA : # pour afficher les ref
            GOK=0 : Break
        Endif
        # Issue 106947 - 20150811 by LD
    Next
    If GOK<1 Break Endif

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub SOC_STK : # pour stocker ref
#        WriteB [SOC]
#    Else
#        Write [SOC]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File SORDERC, Error ="-num$(fstat),1) From GESECRAN
#          Gosub SOQ_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File SORDERC(SOHNUM/SOPLIN)"-[F:SOC]SOHNUM-num$([F:SOC]SOPLIN)+", ERROR ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
    Gosub SOC_STK : # pour stocker ref
    WriteB [SOC]
    If fstat
        Call ECR_TRACE("File SORDERC, Error ="-num$(fstat),1) From GESECRAN
        Gosub SOQ_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
    # Issue 106947 - 20150811 by LD
  Next
  If GOK<1 : Break : Endif

  # Source folder version before V6.0
  If VERSION<GMIGX3VER60
    Gosub SUITE_MAJ60_SOH
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  # Issue 106947 - 20150811 by LD : Migration of historic folder
#  If NEWMOTEUR
#     Gosub SOH_STK : # pour stocker ref
#     WriteB [F:SOH]
#  Else
#     Write [F:SOH]
#  Endif
#  If fstat
#     If NEWMOTEUR & adxwrb>1
#       Call ECR_TRACE("File SORDER, Error ="-num$(fstat),1) From GESECRAN
#       Gosub SOH_ERRTRA : # pour afficher les ref
#     Else
#       Call ECR_TRACE("File SORDER(SOHNUM)"-[F:SOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
#     Endif
#     GOK=0 : Break
#  Endif
  Gosub SOH_STK : # pour stocker ref
  WriteB [F:SOH]
  If fstat
     Call ECR_TRACE("File SORDER, Error ="-num$(fstat),1) From GESECRAN
     Gosub SOH_ERRTRA : # pour afficher les ref
     GOK=0 : Break
  Endif
  # Issue 106947 - 20150811 by LD
  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:SOHM]SOHCAT)
    TABMIGKEY(2) = [F:SOHM]SALFCY
    TABMIGKEY(3) = [F:SOHM]SOHNUM
    STOP=1
    Break
  Endif
$SUITE_LOOP
Next
Filter [SOHM]

$FIN_LOOP
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",7,ERR) From TRTMIG : #7=Erreur
Else
  #If NEWMOTEUR & adxwrb>1  : # Issue 106947 - 20150811 by LD : Migration of historic folder
    Flush [F:SOH]
    If fstat
        Call ECR_TRACE("File SORDER, Error ="-num$(fstat),1) From GESECRAN
        Gosub SOH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP : #on part sur rollback
    Endif
    Flush [F:SOC]
    If fstat
        Call ECR_TRACE("File SORDERC, Error ="-num$(fstat),1) From GESECRAN
        Gosub SOC_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP : #on part sur rollback
    Endif
    Flush [F:SOP]
    If fstat
        Call ECR_TRACE("File SORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub SOP_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP : #on part sur rollback
    Endif
    Flush [F:SOQ]
    If fstat
        Call ECR_TRACE("File SORDERQ, Error ="-num$(fstat),1) From GESECRAN
        Gosub SOQ_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP : #on part sur rollback
    Endif
  #Endif                    : # Issue 106947 - 20150811 by LD : Migration of historic folder
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
      TABMIGKEY(4)=num$(STOP)
  Else
      Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTSAL03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_LOOP
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTSAL03",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_SAL03
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN
Close Local File [SOP], [SOH], [SOQ], [SOC]
Close Local File [SOPM], [SOHM], [SOQM], [SOCM]

Call ECR_TIME("UUMGTRTSAL03 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"SORDER" ,ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SORDERP",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SORDERQ",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SORDERC",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTSAL03") From TRTMIG
End
##########################################################################
Subprog RAZ_UUMGTRTSAL03(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

#Gbn-101445
##1.1 - Récupération du n° de version
#####################################
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL03",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMSOHM,WNAMSOPM,WNAMSOQM,WNAMSOCM
Call MIGTABNAME (DOSSIER,"SORDER", WNAMSOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERP",WNAMSOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERQ",WNAMSOQM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERC",WNAMSOCM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMSOHM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSOPM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSOQM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSOCM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################
Local Char REQTSQL (250) (2)
Local File =DOSSIER+".SORDER"     [SOH]
Local File =DOSSIER+".SORDERP"    [SOP]
Local File =DOSSIER+".SORDERQ"    [SOQ]
Local File =DOSSIER+".SORDERC"    [SOC]
Local File =DOSSIER+".CPTANALIN"  [CAL]

Onerrgo ERR_SQL
Trbegin [SOH]
REQTSQL(0)="DELETE FROM "-DOSSIER+".SORDER WHERE SOHCAT_0=4 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Onerrgo ERR_SQL
Trbegin [SOP]
REQTSQL(0)="DELETE FROM "-DOSSIER+".SORDERP WHERE SOHCAT_0=4 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Onerrgo ERR_SQL
Trbegin [SOQ]
REQTSQL(0)="DELETE FROM "-DOSSIER+".SORDERQ WHERE SOHCAT_0=4 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Call MIGTABRAZ (DOSSIER,"SORDERC",ERR) From TRTMIG

#Gbn-101445
If val(VERSION)<GMIGX3VER60
  Onerrgo ERR_SQL
  Trbegin [CAL]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".CPTANALIN WHERE ABRFIC_0='SOP' AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SORDER WHERE CPTANALIN.VCRNUM_0=SORDER.SOHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTSAL03",ERR) From TRTMIG

End

# Issue 78997
##############################################################################################
$OUVRE_SAL03

If [F:ADS]MODULE(5)=2
    If clalev([F:POC])  = 0 : Local File =DOSSIER+".PORDERC"   [POC]  : Endif
Endif
If clalev([F:BPS])  = 0 : Local File =DOSSIER+".BPSUPPLIER"    [BPS]  : Endif

Return
################################################
# Issue 78997

################################################
$SOH_STK
Call STK (WTAB_SOH,WCPT_SOH,[F:SOH]SOHNUM) From TRTMIG
Return
$SOP_STK
Call STK (WTAB_SOP,WCPT_SOP,[F:SOP]SOHNUM-'/'-num$([F:SOP]SOPLIN)-'/'-num$([F:SOP]SOPSEQ)) From TRTMIG
Return
$SOQ_STK
Call STK (WTAB_SOQ,WCPT_SOQ,[F:SOQ]SOHNUM-'/'-num$([F:SOQ]SOPLIN)-'/'-num$([F:SOQ]SOQSEQ)) From TRTMIG
Return
$SOC_STK
Call STK (WTAB_SOC,WCPT_SOC,[F:SOC]SOHNUM-'/'-num$([F:SOC]SOPLIN)) From TRTMIG
Return
$SVF_STK
Call STK (WTAB_SVF,WCPT_SVF,[F:SVF]VCRNUM-'/'-num$([F:SVF]VCRTYP)-'/'-num$([F:SVF]DTA)) From TRTMIG
Return
$CAL_STK
Call STK (WTAB_CAL,WCPT_CAL,[F:CAL]ABRFIC-'/'-num$([F:CAL]VCRTYP)-'/'-[F:CAL]VCRNUM-'/'-num$([F:CAL]VCRLIN)-'/'-num$([F:CAL]VCRSEQ)-'/'-[F:CAL]CPLCLE-'/'-num$([F:CAL]ANALIG)) From TRTMIG
Return
