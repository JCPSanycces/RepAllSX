#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
# UTIINIUID                                                                          #
#                                                                                    #
# Initialize AUUID field in tables concerned by GDPR                                 #
#                                                                                    #
######################################################################################
If GSERVEUR
    Call EXE_UTIINIUID(nomap)
Else
    Call MAJ_UTIINIUID
Endif
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIINIUID
Local Char DOSSIER(30)
Local Integer LRET
Local Integer LFORCE
Local Integer LDELAXX

DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIINIUID - Init AUUID fields") From SAIDOS
If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIINIUID - Init AUUID fields") From LECFIC
    Call EXE_UTIINIUID(DOSSIER)

    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End

#-------------------------------------------------------------------------------#
#**
#* Initialize AUUID field in tables concerned by GDPR
#*
#* @param DOSSIER : Folder namein which ru
#*!
Subprog EXE_UTIINIUID(DOSSIER)
Value Char    DOSSIER

If filinfo(filpath("FIL","AGDPRSETTING","fde",DOSSIER),0)<=0
   End
Endif
Local File =DOSSIER+".AGDPRSETTING" [AGS]
Local File =DOSSIER+".ATABZON"      [ATZ]

Call ECR_TIME("UTIINIUID : Start folder's process"-DOSSIER) From DOSSUB

For [AGS]AGS2(3)
    If [F:AGS]CODATB<>""
        Call UPDATE_AUUID(DOSSIER,[F:AGS]CODATB)
    Endif
    If [F:AGS]CODATY<>""
        For [ATZ]CODTYP(2) Where [F:ATZ]CODTYP=[F:AGS]CODATY & [F:ATZ]CODFIC<>[F:AGS]CODATB
            Call UPDATE_AUUID(DOSSIER,[F:ATZ]CODFIC)
        Next
    Endif
Next

LogicClose File [ATZ], [AGS]

Call ECR_TIME("UTIINIUID : End folder's process"-[L]DOSSIER) From DOSSUB
End

Subprog UPDATE_AUUID(PDOSSIER,PCODFIC)
Value Char PDOSSIER
Value Char PCODFIC

If PDOSSIER=""
    PDOSSIER=nomap
Endif

# check if the table exists
If filinfo(filpath("FIL",PCODFIC,"fde",PDOSSIER),0)<0
    End
Endif

Local Integer LNB, LNBTOT, STOP
Local File =PDOSSIER+"."+PCODFIC [TAB]

$LOOP
Trbegin [TAB]
Raz STOP, LNB
For [TAB] Where AUUID=NullUuid
    [F:TAB]AUUID = getUuid
    Rewrite [TAB]
    If fstat<>[V]CST_AOK
        Call ERREUR(PCODFIC, 2) From DOSDIC
        GOK=0
        Break
    Endif
    LNBTOT+=1
    LNB+=1
    If LNB>GMAXUPDTRS
        STOP = 1
        Break
    Endif
Next

If GOK=1
    Commit
    If STOP
        Goto LOOP
    Endif
    If LNBTOT>0
        Call ECR_TIME("AUUID initialized in "+PCODFIC+" for "+num$(LNBTOT)+" records") From DOSSUB
    Endif
Else
    Rollback
    Call ECR_TIME ("Error during initialization of AUUID in "+PCODFIC) From DOSSUB
Endif

LogicClose File [TAB]
End

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  Call EXE_UTIINIUID(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Call EXE_UTIINIUID(APPLI)

End

