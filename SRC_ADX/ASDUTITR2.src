#######################################################################
## Définition des triggers d'audit pour SData
##  Issu du modle SUBTRIGGER
##  SData - Version 0006
#######################################################################
Subprog DEFTRI(BASE,OPERATION,N,T)
#######################################################################
Value    Integer BASE                : # 1=Oracle, 2=Sql-serveur
Value    Char    OPERATION           : # C=Create, U=Update, D=Delete
Variable Integer N                   : # Nombre de lignes
Variable Char    T()(1..)            : # Texte du trigger

Local Char ACTION(20)
Local Integer OKTRT

N = 0
Case BASE
 When 1 : Gosub DEFTRI_ORA : # Oracle
 When 2 : Gosub DEFTRI_SQL : # Sql
Endcase

End

#################################################################
## Syntaxe sous oracle (PL/SQL)
#  Memo
#    Exe pour lancer requete Oracle:  SQL *Plus Worksheet  - F:\oracle\product\10.2.0\client_1\BIN\oemapp.bat worksheet
#    Trace
#      Echo des traces :  SET SERVEROUTPUT ON
#      DBMS_OUTPUT.PUT_LINE('texte' || xx);
#    Execution requete:    /
#################################################################
## DOSSIER        ## Code du dosssier
## TABLE          ## Nom de la table
## NOMTRIG        ## Extension du trigger (INS,UPD ou DEL)
## ACTION         ## Action effectuée (Insert, Update ou Delete)
## NBCOL          ## Nb de colonnes auditées
## LISCOL         ## Liste des colonnes séparées par des virgules
## CONDITION      ## Condition de déclenchement
## TABLOGIN       ## Nom de la table de login (ALOGIN)
## TABAUDITH      ## Nom de la table d'audit (AUDITH)
## TABAUDITL      ## Nom de lat table de détail audit (AUDITL)
## OLDCLE1        ## Champ "première partie de clé", ancienne valeur
## NEWCLE1        ## Champ "première partie de clé", nouvelle valeur
## OLDCLE2        ## Champ "deuxième partie de clé", ancienne valeur
## NEWCLE2        ## Champ "deuxième partie de clé", nouvelle valeur
## INDICE         ## Indice de boucle
## ADOCHAMP       ## Nom "adonix" du champ
## OLDCHAMP       ## Nom "BBD" de la colonne, ancienne valeur
## NEWCHAMP       ## Nom "BBD" de la colonne, nouvelle valeur
## WORKFLOW       ## Valeur du flag workflow
## BI             ## Valeur du flag BI
#################################################################
$DEFTRI_ORA
N += 1 : T(N) = "Declare"
N += 1 : T(N) = " x3seq  NUMBER;"
#N += 1 : T(N) = " x3seq  BINARY_INTEGER;"
N += 1 : T(N) = " x3evt  VARCHAR(10);"
N += 1 : T(N) = " heusys VARCHAR(50);"
N += 1 : T(N) = " cle1   VARCHAR(150);"
N += 1 : T(N) = " timstp timestamp(3);"
N += 1 : T(N) = " datsys DATE;"

# Pour calcul timestamp en milliseconde
N += 1 : T(N) = " stputc    timestamp(3);"
N += 1 : T(N) = " daynb     VARCHAR(10);"
N += 1 : T(N) = " secnb     VARCHAR(10);"
N += 1 : T(N) = " franb     VARCHAR(10);"
N += 1 : T(N) = " stp70utc  timestamp(3);"
N += 1 : T(N) = " day70nb   VARCHAR(10);"
N += 1 : T(N) = " timstptri timestamp(3);"

N += 1 : T(N) = "Begin"
N += 1 : T(N) = " Select trunc(sysdate,'DD'),to_char(sysdate,'HH24MISS')"
N += 1 : T(N) = "  into datsys,heusys from DUAL;"
N += 1 : T(N) = " Select SEQ_#<TABAUDITH>#.NEXTVAL"
N += 1 : T(N) = "  into x3seq from DUAL;"

N += 1 : T(N) = " x3evt := '"+OPERATION+"';"


Case OPERATION
 When "C","U"
  N += 1 : T(N) = " timstp := #<TIMSTP>#;"
 When "D"
 # N += 1 : T(N) = " timstp := ' ';"
 N += 1 : T(N) = " timstp := SYS_EXTRACT_UTC(SYSTIMESTAMP);"
Endcase

N += 1 : T(N) = " stputc     := SYS_EXTRACT_UTC(SYSTIMESTAMP);"
N += 1 : T(N) = " daynb      := to_char(stputc,'J')  ;"
N += 1 : T(N) = " secnb      := to_char(stputc,'SSSSS')  ;"
N += 1 : T(N) = " franb      := to_char(stputc,'FF3')  ;"
N += 1 : T(N) = " stp70utc   := TO_TIMESTAMP ('01/01/1970 00:00:00.000', 'DD/MM/YYYY HH24:MI:SS.FF');"
N += 1 : T(N) = " day70nb    := to_char(stp70utc,'J')  ;"
#N += 1 : T(N) = " timstptri   := (86400 * (daynb - day70nb) + secnb) * 1000 + franb ;"
N += 1 : T(N) = " timstptri     := SYS_EXTRACT_UTC(SYSTIMESTAMP);"

Case OPERATION
 When "C","U"
  N += 1 : T(N) = " cle1 := #<NEWCLE1>#;"
 When "D"
  N += 1 : T(N) = " cle1 := #<OLDCLE1>#;"
Endcase

N += 1 : T(N) = " Insert into #<TABAUDITH>#"
N += 1 : T(N) = "  (SEQ_0,EVT_0,TBL_0,DAT_0,HOU_0"
N += 1 : T(N) = "  ,ID_0,TIMSTP_0,TIMSTPTRI_0"
T(N) += ")"
N += 1 : T(N) = "  values (x3seq,x3evt,'#<TABLE>#',datsys,heusys"
N += 1 : T(N) = "  ,cle1,timstp,timstptri"
T(N) += ");"

N += 1 : T(N) = "End;"
Return

#################################################################
## Syntaxe sous Sql-server (TRANSAC-SQL)
# Memo
#     Exe pour lancer requete Oracle:  Microsoft SQL Server Management studio
#        "C:\Program Files\Microsoft SQL Server\90\Tools\Binn\VSShell\Common7\IDE\SqlWb.exe"
#     Trace
#        PRINT N'This message was printed on '+ cast(@datsys as nvarchar(20))+cast(CURRENT_TIMESTAMP as nvarchar(20))
#################################################################
$DEFTRI_SQL
N += 1 : T(N) = "Begin"
N += 1 : T(N) = "  Declare @blank   NVARCHAR(1)"
N += 1 : T(N) = "  Declare @datsys  DATETIME"
N += 1 : T(N) = "  Declare @heusys  NVARCHAR(10)"
N += 1 : T(N) = "  Declare @hh      NVARCHAR(2)"
N += 1 : T(N) = "  Declare @mm      NVARCHAR(2)"
N += 1 : T(N) = "  Declare @ss      NVARCHAR(2)"
N += 1 : T(N) = "  Declare @timstp  NVARCHAR(20);"
N += 1 : T(N) = "  Declare @x3seq   NUMERIC(18,0)"
#N += 1 : T(N) = "  Declare @x3seq   INT"
N += 1 : T(N) = "  Declare @x3evt   NVARCHAR(10)"
N += 1 : T(N) = "  Declare @cle1    NVARCHAR(150)"
N += 1 : T(N) = "  Declare @ocle1   NVARCHAR(150)"

# Pour calcul timestamp en milliseconde
   N += 1 : T(N) = "  Declare @stputc    DATETIME"
   N += 1 : T(N) = "  Declare @stp70utc  DATETIME"
   N += 1 : T(N) = "  Declare @daynb     INT"
N += 1 : T(N) = "  Declare @hounb     INT"
N += 1 : T(N) = "  Declare @minnb     INT"
   N += 1 : T(N) = "  Declare @secnb     INT"
   N += 1 : T(N) = "  Declare @franb     INT"
   N += 1 : T(N) = "  Declare @timstpint BIGINT"
N += 1 : T(N) = "  Declare @timstptri NVARCHAR(20);"

N += 1 : T(N) = "  set nocount on"
N += 1 : T(N) = "  set @blank = ' '"

N += 1 : T(N) = "  set @datsys = getdate()"
N += 1 : T(N) = "  set @hh = datename(hour,@datsys)"
N += 1 : T(N) = "  set @mm = datename(minute,@datsys)"
N += 1 : T(N) = "  set @ss = datename(second,@datsys)"
N += 1 : T(N) = "  If len(@hh)=1 set @hh = '0'+@hh"
N += 1 : T(N) = "  If len(@mm)=1 set @mm = '0'+@mm"
N += 1 : T(N) = "  If len(@ss)=1 set @ss = '0'+@ss"
N += 1 : T(N) = "  set @heusys = @hh+@mm+@ss"

N += 1 : T(N) = "  set @x3evt = '"+OPERATION+"'"

N += 1 : T(N) = "  set @stp70utc = convert(DATETIME, '1970-01-01T00:00:00', 126)"
N += 1 : T(N) = "  set @stputc =  getutcdate()"
N += 1 : T(N) = "  set @daynb = DATEDIFF(day, @stp70utc, @stputc);"
N += 1 : T(N) = "  set @hounb = datepart(hh, @stputc)"
N += 1 : T(N) = "  set @minnb = datepart(mi, @stputc)"
N += 1 : T(N) = "  set @secnb = datepart(ss, @stputc)"
N += 1 : T(N) = "  set @franb = datepart(ms, @stputc)"
N += 1 : T(N) = "  set @timstpint = 86400*@daynb + 3600*@hounb + 60*@minnb + @secnb"
N += 1 : T(N) = "  set @timstpint = @timstpint*1000 + @franb"
N += 1 : T(N) = "  set @timstptri = cast( @timstpint as nvarchar(20))"


Case OPERATION
 When "D" : Gosub SQL_DEL
 When "U" : Gosub SQL_INSUPD
 When "C" : Gosub SQL_INSUPD
Endcase

N += 1 : T(N) = "  set nocount off"
N += 1 : T(N) = "End"
Return


#$SQL_INS
#N += 1 : T(N) = "  Select"
#N += 1 : T(N) = "     @cle1   = #<NEWCLE1>#"
#N += 1 : T(N) = "   , @timstp = #<TIMSTP>#"
#N += 1 : T(N) = "  From Inserted"
#Gosub SQL_TETE
#Return

$SQL_TETE
N += 1 : T(N) = "  Insert into #<DOSSIER>#.#<TABAUDITH>#"
N += 1 : T(N) = "   (SEQ_0,EVT_0,TBL_0,DAT_0,HOU_0"
N += 1 : T(N) = "   ,ID_0,TIMSTP_0,TIMSTPTRI_0"
T(N) += ")"
N += 1 : T(N) = "   values (-@@spid,@x3evt,'#<TABLE>#',@datsys,@heusys"   # mb 28.1.2010
N += 1 : T(N) = "   ,@cle1,@timstp,@timstptri"
T(N) += ")"
N += 1 : T(N) = "  set @x3seq = @@identity" : # mb 28.1.2010
N += 1 : T(N) = "  Update #<DOSSIER>#.#<TABAUDITH># set SEQ_0 = @x3seq where ROWID=@x3seq" : # mb 28.1.2010
Return

#$SQL_UPD
#N += 1 : T(N) = "  Select"
#N += 1 : T(N) = "     @cle1   = #<NEWCLE1>#"
#N += 1 : T(N) = "   , @timstp = #<TIMSTP>#"
#N += 1 : T(N) = "  From Inserted"
#Gosub SQL_TETE
#Return

$SQL_INSUPD        # 31/05/2011 - Ajout boucle
N += 1 : T(N) = "  set @timstp = ' '"
N += 1 : T(N) = "  Declare nouveau Cursor For"
N += 1 : T(N) = "  Select #<NEWCLE1># "
N += 1 : T(N) = "       , #<TIMSTP># "
N += 1 : T(N) = "  From Inserted"
N += 1 : T(N) = "  Open nouveau"
N += 1 : T(N) = "  Fetch Next From nouveau into @cle1, @timstp"
N += 1 : T(N) = "  While @@FETCH_STATUS = 0"
N += 1 : T(N) = "  Begin"
Gosub SQL_TETE
N += 1 : T(N) = "  Fetch Next From nouveau into @cle1, @timstp"
N += 1 : T(N) = "  End"
N += 1 : T(N) = "  Close nouveau"
N += 1 : T(N) = "  Deallocate nouveau"
Return


$SQL_DEL
N += 1 : T(N) = "  set @timstp = ' '"
N += 1 : T(N) = "  Declare ancien Cursor For"
N += 1 : T(N) = "  Select #<OLDCLE1># "
N += 1 : T(N) = "  From Deleted"
N += 1 : T(N) = "  Open ancien"
N += 1 : T(N) = "  Fetch Next From ancien  into @cle1"
N += 1 : T(N) = "  While @@FETCH_STATUS = 0"
N += 1 : T(N) = "  Begin"
Gosub SQL_TETE
N += 1 : T(N) = "  Fetch Next From ancien  into @cle1"
N += 1 : T(N) = "  End"
N += 1 : T(N) = "  Close ancien"
N += 1 : T(N) = "  Deallocate ancien"
Return

#--------------------------------------------------------#
# Récupération du rowid d'une table sous SQL
#--------------------------------------------------------#

Subprog GET_ROWID(DOSSIER,TABLE,MAXROW)
Value    Char    DOSSIER , TABLE
Variable Decimal MAXROW
# Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
Call GET_ROWID(DOSSIER,TABLE,MAXROW) From SUBTRIGGER
