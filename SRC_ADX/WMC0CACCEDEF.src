#<AdxTL>@(#)0.0.0.0 $Revision$Class Default dimensions
# Supervisor
## ACLA-CLASSE ## CACCEDEF
# 2018-11-06 07:04:06 354

####################################################################
# Traitments
####################################################################
$_ADDTRT
this.AINF.TRT(1) = "CACCEDEF_CSTD"
this.AINF.TYP(1) = 1
this.AINF.PTH(1) = ""
this.AINF.NBTRT = 1
Return

####################################################################
#Declaration of variables
####################################################################

$DECLARE_VAR
Local Char    ACTION(50) , CURPRO(250) , VALPRO(250) , CURQRY(50) , CURPTH(250)
Local Char    AMETHOD(50) ,AOPERATION(50),AEVENT(50),ARULE(50)
Local Integer ALLSTAT,AISMET,ASTATUS
Return


####################################################################
# Global methods & standards
####################################################################
$AINIT
Gosub DECLARE_VAR
[L]AEVENT = "AINIT" : [L]ACTION = "AINIT" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# AERRORS
####################################################################

$_AERROR
Gosub DECLARE_VAR From WMC0CACCEDEF
Local Integer ALLSTAT
Call ALLERRORS(this,_CTX,_SUPP) From ASYRSUB
For AINDCLA=1 To 25
 If this.IDENT(AINDCLA)<>null
  [L]ASTATUS = fmet this.IDENT(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.DIMCEN(AINDCLA)<>null
  [L]ASTATUS = fmet this.DIMCEN(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To 5
 If this.LISCCE(AINDCLA)<>null
  [L]ASTATUS = fmet this.LISCCE(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
Return

####################################################################
# Delete all errors
####################################################################

$_ADELERRORS
Gosub DECLARE_VAR From WMC0CACCEDEF
Local Integer ALLSTAT
[L]ASTATUS = fmet this.ADELETEERROR([L]_APARAM)
For AINDCLA=1 To 25
 If this.IDENT(AINDCLA)<>null
  [L]ASTATUS = fmet this.IDENT(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.DIMCEN(AINDCLA)<>null
  [L]ASTATUS = fmet this.DIMCEN(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To 5
 If this.LISCCE(AINDCLA)<>null
  [L]ASTATUS = fmet this.LISCCE(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
Return

####################################################################
# _ASEARCHINFOS
####################################################################

$_ASEARCHINFOS
Gosub DECLARE_VAR From WMC0CACCEDEF
ASTATUS= func ASYRSUB.ASEARCHINFOS(this,[L]AINS_ORI,[L]ERR_TYPE,[L]PROPERTY,[L]ASTAT,[L]SELSTAT,[L]PATH)
If [L]ERR_TYPE=[V]CST_ACURRENT : Return : Endif
For AINDCLA=1 To 25
 If this.IDENT(AINDCLA)<>null
  [L]ASTATUS = fmet this.IDENT(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'IDENT('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.DIMCEN(AINDCLA)<>null
  [L]ASTATUS = fmet this.DIMCEN(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'DIMCEN('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To 5
 If this.LISCCE(AINDCLA)<>null
  [L]ASTATUS = fmet this.LISCCE(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'LISCCE('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
Return

####################################################################
# AGETERRORSFROM
####################################################################

$_AGETERRORSFROM
Gosub DECLARE_VAR From WMC0CACCEDEF
If AINS_FROM<>null
 [L]ASTATUS = fmet AINS_FROM.ASEARCHINFOS( [V]CST_ALL, "", [V]CST_AFATAL, 0)
Endif
Call AGETERRORSFROM(AINS_FROM,this,ENVIRONNEMENT) From ASYRSUB
Return

####################################################################
$ACONTROL
####################################################################
Gosub DECLARE_VAR
[L]AEVENT = "ACONTROL" : [L]ACTION = "ACONTROL" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# ADELLINE
####################################################################
$ADELLINE
Case _ACOLLECTION
 When "DIMCEN"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"DIMCEN",this)
  If [L]_ALINE<>[V]CST_ANOTDEFINED : this.NBRDIE -= 1 : Endif
 When "IDENT"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"IDENT",this)
 When "LISCCE"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"LISCCE",this)
  If [L]_ALINE<>[V]CST_ANOTDEFINED : this.NBLIG -= 1 : Endif
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# ADDLINE
####################################################################
$ADDLINE
Case _ACOLLECTION
 When "DIMCEN"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"DIMCEN","C_CACCEDEF_DIMCEN",this)
  If [L]_ALINE<>[V]CST_ANOTDEFINED : this.NBRDIE += 1 : Endif
 When "IDENT"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"IDENT","C_CACCEDEF_IDENT",this)
 When "LISCCE"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"LISCCE","C_CACCEDEF_LISCCE",this)
  If [L]_ALINE<>[V]CST_ANOTDEFINED : this.NBLIG += 1 : Endif
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETDIM
####################################################################
$AGETDIM
Case _ACOLLECTION
 When "DIMCEN"
  [L]_ALINE = 20
 When "IDENT"
  [L]_ALINE = 25
 When "LISCCE"
  [L]_ALINE = 5
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETMIN
####################################################################
$AGETMIN
Case _ACOLLECTION
 When "DIMCEN"
  [L]_ALINE = 1
 When "IDENT"
  [L]_ALINE = 2
 When "LISCCE"
  [L]_ALINE = 1
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# _ALOAD_KEYS
####################################################################
$_ALOAD_KEYS
this.AKEYS(1) = "COD"
this.AKEYS(2) = "CPY"
Return

####################################################################
# _ADELINSTANCE
####################################################################
$_ADELINSTANCE
[L]ASTATUS = func ASYRSUBTAB._ADELINSTANCE(this)
Return

####################################################################
# ADDINSTANCE_BOUND
####################################################################
$ADDINSTANCE_BOUND
Return



