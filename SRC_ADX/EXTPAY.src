#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","EXTPAY","EXTPAY",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Raz [M]
 When "EXEC"       : Gosub EXEC
 When "SORTIE"     : Gosub SORTIE
 #SEGAY US1840 81085 20/08/2013 action envoyée de SELEMPCTR
 When "BAS_CTRNUM"  : Gosub BAS_CTRNUM From TOOLSHRLEG
Endcase
Return

$INIT
#86255
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
#End 86255
Gosub OUVRE From WPDEFTABLE
If clalev([F:VEP])=0    : Local File VALEMP    [VEP]    : Endif
If clalev([F:HSP])=0    : Local File HISTOPAYE [HSP]    : Endif
If clalev([F:HSP2])=0   : Local File HISTOPAYE [HSP2]   : Endif
If clalev([F:HRSDP])=0    : Local File SOLDPAY   [HRSDP]    : Endif
If clalev([F:VAN])=0    : Local File VALANA    [VAN]    : Endif
If clalev([F:CUM])=0    : Local File CUMUL     [CUM]    : Endif
If clalev([F:RUB])=0    : Local File RUBRIQUE  [RUB]    : Endif
If clalev([F:VLA])=0    : Local File VALEUR    [VLA]    : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]    : Endif
If clalev([F:TCA])=0    : Local File TABCOUAFF [TCA]    : Endif
If GINTMT=1
  If clalev([F:PSN])=0   : Local File PRESTATION[PSN]    : Endif
Endif
If clalev([F:VEP2])=0   : Local File VALEMP    [VEP2]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]     : Endif
TMP = 1
TRA = 1
Local Char NEWBUL(GLONVCR)
Return

########################################
#86255
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

########################################
## Extourne de paye
########################################
$EXEC
Call EXTOURNE([M:DIA]BUL,[M:DIA]RVSDAT,([M:DIA]SIM=2),NEWBUL,1)
Return

Subprog EXTOURNE(BULLETIN,DATEXT,SIMUL,NEWBUL,TRANSAC)
Value    Char    BULLETIN
Value    Date    DATEXT
Value    Integer SIMUL
Variable Char    NEWBUL
Value Integer    TRANSAC     : #0=Transaction déjà en cours ; 1= Transaction à faire

Local Char    SYMBOLE(80)
Local Char    MATRI(GLONEML) , DERBUL(GLONVCR)
Local Char    CTR(GLONHRCTR) , COMPTEUR(GLONANM)
Local Integer STAT
Local Date    DATPAY , DERPAY, DATCTR
Local Char    PAYNET(GLONRUB)(1..10)
Local Char    INICUM(24)(1..len(mess(0,10334,1)))
Local Integer I , J , K
Local Integer EXCEPT
Local Date    DATFIN ,DATSUIV
Local Date    DATMAT
Local Decimal AMT
Local Char    CRIT(250)
Local Integer NUMCODADI
#JOJAC - 2016-07-25 - REQ114309 US127 - START
# FQ110254 - 23/05/16 - Prise en compte des acomptes dans une extourne
Local Char    PAYACPT1(GLONRUB), PAYACPT3(GLONRUB)
Local Decimal TPAYACPT1,TPAYACPT3
Call PARAM("","PAYACPT1",PAYACPT1) From ADOVAL
Call PARAM("","PAYACPT3",PAYACPT3) From ADOVAL
#JOJAC - 2016-07-25 - REQ114309 US127 - START

Read [VEP]VEP5 = BULLETIN
If fstat : End : Endif
MATRI  = [F:VEP]EMP
DATPAY = [F:VEP]PYRDAT
DATFIN = [F:VEP]ENDDAT
CTR    = [F:VEP]CTRNUM
DATCTR = [F:VEP]CTRDAT

##**82073
#SYMBOLE = "VEP"+format$("D:"+GFMDAT4,DATPAY)+"\"+MATRI+"\"+CTR
Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE
Lock =SYMBOLE
If fstat
 Call ERREUR(mess(10,100,1)) From GESECRAN : End
Endif

#Recherche de la dernière paie du salarié

#84670 : Add filter STA>1 pour calcul des delta sur cumuls !
Filter [VEP] Where EMP=MATRI & CTRNUM=CTR  & STA>1
Read [VEP]VEP0 Last
Filter [VEP]
If !fstat : DERBUL = [F:VEP]BUL : Endif
For I=1 To 5
 Call PARAM(GCURLEG,"PAYNET"+num$(I),PAYNET(I)) From ADOVAL
Next I
For I=1 To len(mess(0,10334,1))
 Call PARAM(GCURLEG,"PERCUM"+num$(I),INICUM(I)) From ADOVAL
 INICUM(I) = left$(INICUM(I)+INICUM(I)+string$(24,"N"),24)
Next I
DATMAT = DATPAY
Gosub LECEMP From WPDEFTABLE
#85082
If !GSERVEUR
  Call OUVRE_TRACE(mess(61,10702,1)-":"-MATRI-format$("D:"+GFMDAT,DATPAY)) From LECFIC
Endif
#end 85082
Call DEBTRANS From GLOCK
If TRANSAC
 Gosub TR1
Else
 Gosub TR2
Endif
Unlock =SYMBOLE
#85082
If !GSERVEUR
  Call FERME_TRACE From LECFIC
Endif
#end 85082
End

$TR1
GOK = 1
Trbegin [VEP]
 Readlock [EPC]EPC0 = MATRI;CTR
 If fstat=1
  GOK = -1 : GLOCK = "$EMPLOCUM"-MATRI-CTR : Goto ROLL_TR1
 Endif
 Gosub TETE
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub HISTO
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub CUMUL
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub VARIA
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub SOLDE
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub ANA
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 If GINTMT=1
  Gosub INTMT
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
 Endif
 Rewrite [EPC]
 If fstat
  GOK = 0 : Call FSTA("EPC") From GLOCK : Goto AB_TR1
 Endif
If SIMUL
 Rollback
Else
 Commit
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK = 1
Readlock [EPC]EPC0 = MATRI;CTR
If fstat=1
 GOK = -1 : GLOCK = "$EMPLOCUM"-MATRI-CTR : Return
Endif
Gosub TETE
If   GOK<=0 : Return : Endif
Gosub HISTO
If   GOK<=0 : Return : Endif
Gosub CUMUL
If   GOK<=0 : Return : Endif
Gosub VARIA
If   GOK<=0 : Return : Endif
Gosub SOLDE
If   GOK<=0 : Return : Endif
Gosub ANA
If   GOK<=0 : Return : Endif

#JOJAC - 2016-07-25 - REQ114309 US217 - START
#92316 US2227
#If we are here it's because TRANSAC = 0.
#If TRANSAC = 0 it's because we come from pay-back process.
#When we come from pay-back process, we don't want to erase the payslip number linked with the original prestation because the new payslip
#number will be linked with the new prestation (in pay-back contrat)
#If GINTMT=1
# Gosub INTMT
# If   GOK<=0 : Return : Endif
#Endif
#
#JOJAC - 2016-07-25 - REQ114309 US217 - END

Rewrite [EPC]
If fstat
 GOK = 0 : Call FSTA("EPC") From GLOCK : Return
Endif
Return

$TETE
## On modifie l'en-tête de la paye a extourner pour mettre à jour
## la date d'extourne
Readlock [VEP]VEP5 = BULLETIN
If fstat=1
 GOK = -1 : GLOCK = "$VALEMP"-MATRI : Return
Endif
[F:VEP]RVSDAT = DATEXT
Rewrite [VEP]
If fstat
 GOK = 0 : Call FSTA("VEP") From GLOCK : Return
Endif
## On duplique l'en-tête de la paye a extourner pour en créer la paye d'extourne
#Read [TCA]TCA0 = 15 : # Module Admin des RH
#COMPTEUR = [F:TCA]CODNUM(4)
#If COMPTEUR=""
# GMESSAGE = mess(149,10702,1) : # Compteur bulletin non défini
# GOK = 0 : Return
#Endif
Call LECTCA(15,STAT) From SUBTCA
If !STAT
  GMESSAGE = mess(149,10702,1) : # Compteur bulletin non défini
  GOK = 0 : Return
Else
  COMPTEUR= [F:TCA]CODNUM(4)
Endif

#Call NUMERO(COMPTEUR,[F:HRCTR]ETRFCY,[F:HRCTR]CTRDAT,CTR,NEWBUL,STAT) From SUBANM
Call NUMERO(COMPTEUR,[F:HRCTR]ETRFCY,DATEXT,CTR,NEWBUL,STAT) From SUBANM
If STAT
 GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
 GOK = 0 : Return
Endif
[F:VEP]BUL    = NEWBUL
[F:VEP]RVS    = 2
[F:VEP]RVSDAT = [0/0/0]
[F:VEP]ORIDAT = DATPAY
[F:VEP]ORIBUL = BULLETIN
[F:VEP]PYRDAT = DATEXT
[F:VEP]PAYDAT = DATEXT
[F:VEP]PST    = 1
[F:VEP]STA    = 2
[F:VEP]LEG= GCURLEG
[F:VEP]FLGLOCK = 1 : # Verrouillé US1918 65062
# SEGAY  US 2325-88174 BULDEM
If dim([F:VEP]FLGDEMAT) > 0 : [F:VEP]FLGDEMAT = 1 : Endif
If dim([F:VEP]BULDEMAFF) > 0
    If(func SUBEML.DISP_BULDEM([F:VEP]EMP,[F:VEP]CTRNUM,[F:HRCTR]CTRDAT)<>0 and  func SUBEML.GETVAL_BULDEM([F:VEP]EMP)=2)
      [F:VEP]BULDEMAFF=2
    Else
      [F:VEP]BULDEMAFF=1
    Endif
Endif

#JOJAC - 2016-07-25 - REQ114309 US127 - START
Raz [F:VEP]AEMNUM :#92316
#JOJAC - 2016-07-25 - REQ114309 US127 - END

#77923 : PE pour personnalisation de l'entête
[V]GPE = 0
GPOINT = "MAJVEPEXT" : Gosub ENTREE From EXEFNC
If [V]GPE : GOK=0 : Return : Endif

Write [VEP]
If fstat
 GOK = 0 : Call FSTA("VEP") From GLOCK : Return
Endif
Return

$HISTO
Call ECR_TRACE(mess(62,10702,1),0) From GESECRAN : # Historique de paye
## On duplique à l'inverse l'historique de la paye a extourner (sauf les cumuls)
## pour créer l'historique de la paye d'extourne
For [HSP]HSP0 Where BUL=BULLETIN & TYP<>6
 [F:HSP]BUL = NEWBUL
 [F:HSP]DAT = DATEXT
 [F:HSP]BAS = -[F:HSP]BAS
 [F:HSP]AMT = -[F:HSP]AMT
 [F:HSP]LEG = GCURLEG
 Write [HSP]
 If fstat
  GOK = 0 : Call FSTA("HSP") From GLOCK : Break
 Endif

#JOJAC - 2016-07-25 - REQ114309 US127 - START
 # FQ110254 - 23/05/16 - Prise en compte des acomptes dans une extourne
 If (PAYACPT1<>"" & [F:HSP]RUB=PAYACPT1) Then
  TPAYACPT1 += [F:HSP]AMT
 Endif
 If (PAYACPT3<>"" & [F:HSP]RUB=PAYACPT3) Then
  TPAYACPT3 += [F:HSP]AMT
 Endif
#JOJAC - 2016-07-25 - REQ114309 US127 - END

 ## Mise à jour des cumuls de la fiche employé...
 Read [RUB]RUB0 = GCURLEG;[F:HSP]RUB
 NUMCODADI=val(right$([F:RUB]CUMNUMADI,len([F:RUB]CUMNUMADI)))
# Case [F:RUB]CUMNUM
 Case NUMCODADI
  When 1 : [F:EPC]CUM1 += [F:HSP]AMT
  When 2 : [F:EPC]CUM2 += [F:HSP]AMT
  When 3 : [F:EPC]CUM3 += [F:HSP]AMT
  When 4 : [F:EPC]CUM4 += [F:HSP]AMT
  When 5 : [F:EPC]CUM5 += [F:HSP]AMT
  When 6 : [F:EPC]CUM6 += [F:HSP]AMT
  When 7 : [F:EPC]CUM7 += [F:HSP]AMT
  When 8 : [F:EPC]CUM8 += [F:HSP]AMT
  When 9 : [F:EPC]CUM9 += [F:HSP]AMT
#JOJAC - 2016-07-25 - REQ114309 US127 - START
# JASMI - 2014/03/24 - Requirement 95019 US 2547
# Setup new fields
  When 10  : [F:EPC]CUM10 += [F:HSP]AMT
  When 11  : [F:EPC]CUM11 += [F:HSP]AMT
  When 12  : [F:EPC]CUM12 += [F:HSP]AMT
  When 13  : [F:EPC]CUM13 += [F:HSP]AMT
  When 14  : [F:EPC]CUM14 += [F:HSP]AMT
  When 15  : [F:EPC]CUM15 += [F:HSP]AMT
  When 16  : [F:EPC]CUM16 += [F:HSP]AMT
  When 17  : [F:EPC]CUM17 += [F:HSP]AMT
  When 18  : [F:EPC]CUM18 += [F:HSP]AMT
# JASMI - 2014/03/24 - Requirement 95019 US 2547
#JOJAC - 2016-07-25 - REQ114309 US127 - END
 Endcase
 Call ECR_TRACE(format$("N:5#",[F:RUB]ROW)+" "+format$("K:12X",[F:RUB]COD)+" "
& +format$("Nz:9.2",[F:HSP]BAS)+"    "+format$("Nz:9.2",[F:HSP]RAT)+"    "+format$("Nz:9.2",[F:HSP]AMT)
& ,0) From GESECRAN
Next

#JOJAC - 2016-07-25 - REQ114309 US127 - START
For [F:HSR]HSR0 Where BUL=BULLETIN
 [F:HSR]BUL = NEWBUL
 [F:HSR]AMT = -[F:HSR]AMT
 Write [HSR]
 If fstat
  GOK = 0 : Call FSTA("HSR") From GLOCK : Break
 Endif
Next
#JOJAC - 2016-07-25 - REQ114309 US127 - END
Return

## MAJ Cumuls
$CUMUL
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(63,10702,1),0) From GESECRAN : # Valeurs des cumuls
## Parcours des cumuls de la paye a extourner. On fait la différence entre ces cumuls
## et ceux de la dernière paye du salarié pour créer ceux de la paye d'extourne.
## [HSP]AMT contient la valeur du cumul au mois M
## [HSP]BAS contient la valeur du cumul au mois M-1
For [HSP]HSP0 Where BUL=BULLETIN & TYP=6
 # 26061
 Raz EXCEPT
 # fin 26061
 Read [HSP2]HSP3 = DERBUL;[F:HSP]RUB;6
 If fstat : Raz [F:HSP2] : Endif
 [F:HSP]BUL = NEWBUL
 [F:HSP]DAT = DATEXT
 # 26061
 Read [CUM]CUM0 = GCURLEG;[F:HSP]RUB

#JOJAC - 2016-07-25 - REQ114309 US127 - START
# JASMI - 2014/03/24 - Requirement 95019 US 2547 - Start
# If [F:CUM]CUMINI="" & [F:CUM]CUMPER>1 & [F:CUM]CUMPER<len(mess(0,334,1))
# If [F:CUM]CUMINI="" & [F:CUM]CUMPER>1 & [F:CUM]CUMPER<len(mess(0,10334,1))
 If [F:CUM]CUMINI="" & [F:CUM]CUMPER>1 & [F:CUM]CUMPER<>7
# JASMI - 2014/03/24 - Requirement 95019 US 2547 - End
#JOJAC - 2016-07-25 - REQ114309 US127 - END

  # Recherche de la première paye faite après la paye à extourner
  Filter [VEP2] Where EMP=MATRI & PYRDAT>=DATPAY & BUL>BULLETIN & CTRNUM=CTR
  Read [VEP2]VEP0 First
  Filter [VEP2]
  If fstat>2 : DATSUIV = [0/0/0] : Else : DATSUIV = [F:VEP2]ENDDAT : Endif
  K = month(DATSUIV)+12*(year(DATSUIV)-year(DATFIN))
  J = month(DATFIN)
  If K>=J & instr(1,seg$(INICUM([F:CUM]CUMPER),J,K),"O")
   EXCEPT=1
  Endif
#JOJAC - 2016-07-25 - REQ114309 US127 - START
 # JASMI - 2014/03/24 - Requirement 95019 US 2547 - Start
# Elsif [F:CUM]CUMPER=1 | [F:CUM]CUMPER=len(mess(0,334,1))
#Elsif [F:CUM]CUMPER=1 | [F:CUM]CUMPER=len(mess(0,10334,1))
 Elsif [F:CUM]CUMPER=1 | [F:CUM]CUMPER=7
# JASMI - 2014/03/24 - Requirement 95019 US 2547 - End
#JOJAC - 2016-07-25 - REQ114309 US127 - END
  EXCEPT = 1
 Endif
 If EXCEPT=1
  [L]AMT     = [F:HSP]AMT
  [F:HSP]AMT = [F:HSP]BAS
  [F:HSP]BAS = [L]AMT
 Else
 # fin 26061
  [F:HSP]AMT = [F:HSP2]AMT-([F:HSP]AMT-[F:HSP]BAS)
  [F:HSP]BAS = [F:HSP2]AMT
 Endif
 [F:HSP]LEG= GCURLEG
 Write [HSP]
 If fstat
  GOK = 0 : Call FSTA("HSP") From GLOCK : Break
 Endif

 NUMCODADI=val(right$([F:CUM]CUMNUMADI,len([F:CUM]CUMNUMADI)))
# Case [F:CUM]CUMNUM
 Case NUMCODADI
  When 1 : [F:EPC]CUM1 = [F:HSP]AMT
  When 2 : [F:EPC]CUM2 = [F:HSP]AMT
  When 3 : [F:EPC]CUM3 = [F:HSP]AMT
  When 4 : [F:EPC]CUM4 = [F:HSP]AMT
  When 5 : [F:EPC]CUM5 = [F:HSP]AMT
  When 6 : [F:EPC]CUM6 = [F:HSP]AMT
  When 7 : [F:EPC]CUM7 = [F:HSP]AMT
  When 8 : [F:EPC]CUM8 = [F:HSP]AMT
  When 9 : [F:EPC]CUM9 = [F:HSP]AMT
#JOJAC - 2016-07-25 - REQ114309 US127 - START
# JASMI - 2014/03/24 - Requirement 95019 US 2547
# Setup new fields
  When 10  : [F:EPC]CUM10 += [F:HSP]AMT
  When 11  : [F:EPC]CUM11 += [F:HSP]AMT
  When 12  : [F:EPC]CUM12 += [F:HSP]AMT
  When 13  : [F:EPC]CUM13 += [F:HSP]AMT
  When 14  : [F:EPC]CUM14 += [F:HSP]AMT
  When 15  : [F:EPC]CUM15 += [F:HSP]AMT
  When 16  : [F:EPC]CUM16 += [F:HSP]AMT
  When 17  : [F:EPC]CUM17 += [F:HSP]AMT
  When 18  : [F:EPC]CUM18 += [F:HSP]AMT
# JASMI - 2014/03/24 - Requirement 95019 US 2547
# End
#JOJAC - 2016-07-25 - REQ114309 US127 - END
 Endcase
 Call ECR_TRACE(format$("K:12X",[F:CUM]CUMCOD)+":"-format$("Nz:9.2",[F:HSP]AMT),0) From GESECRAN
Next
Return

## Dupli variables
$VARIA
For [VLA]VLA0 Where TYP=4 & CPY="" & FCY="" & LEG="" & EMP=MATRI & DAT=DATPAY & BUL=BULLETIN
 [F:VLA]BUL = NEWBUL
 [F:VLA]DAT = DATEXT
 Write [VLA]
 If fstat
  GOK = 0 : Call FSTA("VLA") From GLOCK : Break
 Endif
Next
Return

## Solde des paiements
$SOLDE
Readlock [HRSDP]SDP0 = MATRI;CTR
If fstat=1
 GOK = -1 : GLOCK = "$SOLDPAY"-MATRI-CTR : Return
Endif
For I=1 To 5
 If PAYNET(I)<>""
  Read [HSP]HSP3 = BULLETIN;PAYNET(I);1
  If !fstat
   Case I
    When 1 : [F:HRSDP]BNC1 -= [F:HSP]AMT
    When 2 : [F:HRSDP]BNC2 -= [F:HSP]AMT
    When 3 : [F:HRSDP]BNC3 -= [F:HSP]AMT
    When 4 : [F:HRSDP]BNC4 -= [F:HSP]AMT
    When 5 : [F:HRSDP]BNC5 -= [F:HSP]AMT
   Endcase
  Endif
 Endif
Next I
#JOJAC - 2016-07-25 - REQ114309 US127 - START
# FQ110254 - 23/05/16 - Prise en compte des acomptes dans une extourne
If TPAYACPT1<>0 Then
  [F:HRSDP]BNCPOA += TPAYACPT1
Endif
If TPAYACPT3<>0 Then
  [F:HRSDP]BNCPOA -= TPAYACPT3
Endif
#JOJAC - 2016-07-25 - REQ114309 US127 - END

Rewrite [HRSDP]
If fstat
 GOK = 0 : Call FSTA("HRSDP") From GLOCK : Return
Endif
Return

## Analytique
$ANA
For [VAN]VAN0 Where EMP=MATRI & PYRDAT=DATPAY & BUL=BULLETIN
 [F:VAN]BUL    = NEWBUL
 [F:VAN]PYRDAT = DATEXT
 Write [VAN]
 If fstat
  GOK = 0 : Call FSTA("VAN") From GLOCK : Break
 Endif
Next
Return

# Spécificité V6 Intermittents
$INTMT
Filter [PSN] Where BUL=BULLETIN
For [PSN]PSN2
 Readlock Curr
 If fstat=1
  GOK = -1 : GLOCK = "$PRESTATION"-[F:PSN]CTRNUM-num$([F:PSN]PSNNUM) : Break
 Endif
 Raz [F:PSN]BUL
 Rewrite [PSN]
 If fstat
  GOK = 0 : Call FSTA("PSN") From GLOCK : Break
 Endif
Next
Filter [PSN]
Return

########################################
## Ecran EXTPAY
########################################

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
[M]NAM = [F:ID]NAM-[F:ID]SRN
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
If [F:ID]FLGMULCTR<>2
 Call CHERCHE_CTR(VALEUR,eomonth(GMOIPAY), [M]CTRNUM) From DIVPAYE
Endif
Call GRISE_CTRNUM([F:ID]FLGMULCTR)
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
#JOJAC - 2016-07-25 - REQ114309 US127 - START
#If VALEUR=2
##**92316 US2225 : Add filter about FLGINT
If VALEUR=2 | (GINTMT & [F:ID]FLGINT=2)
#JOJAC - 2016-07-25 - REQ114309 US127 - END
 Actzo [M]CTRNUM
Else
 Diszo [M]CTRNUM
Endif
Affzo [M]CTRNUM
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
#If VALEUR <> ""
# Call SELCTR([M]REFNUM,eomonth(GMOIPAY),GMOIPAY,VALEUR) From DIVPAYE
#Endif
End

Subprog AS_PYRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
Filter [VEP] Where EMP=[M]REFNUM & CTRNUM=[M]CTRNUM & RVSDAT=[0/0/0] & RVS<>2
Read [VEP]VEP5 Last
Filter [VEP]
If !fstat
 VALEUR=[F:VEP]PYRDAT
 [M]BUL=[F:VEP]BUL
Endif
End

Subprog C_PYRDAT(VALEUR)
Variable Date    VALEUR
Filter [VEP] Where EMP=[M]REFNUM & PYRDAT=VALEUR & CTRNUM=[M]CTRNUM & RVSDAT=[0/0/0] & RVS<>2
Read [VEP]VEP5 Last
Filter [VEP]
If fstat
 GMESSAGE = mess(56,10702,1) : # Paye inexistante
 mkstat = 2 : End
Endif
[M]BUL=[F:VEP]BUL
Affzo BUL
If [F:VEP]RVSDAT<>[0/0/0]
 GMESSAGE = mess(57,10702,1)-format$("D:"+GFMDAT,[F:VEP]RVSDAT) : # Paye déjà extournée le
 mkstat = 2 : End
Endif
If [F:VEP]RVS=2
 GMESSAGE = mess(58,10702,1) : # Paye d'extourne
 mkstat = 2 : End
Endif
Filter [VEP] Where EMP=[M]REFNUM & CTRNUM=[M]CTRNUM
Read [VEP]VEP0 Last
Filter [VEP]
If !fstat & [VEP]BUL=[M]BUL & [VEP]PST=1
 GMESSAGE = mess(59,10702,1) : # Dernière paye, annulation possible
 mkstat = 2 : End
Endif
End

Subprog C_RVSDAT(VALEUR)
Variable Date    VALEUR
#La paie d'extourne doit être réaliser en dernier bulletin pour pouvoir être supprimen en cas d'erreur
Filter [VEP] Where EMP=[M]REFNUM & PYRDAT>=VALEUR  & CTRNUM=[M]CTRNUM
Read [VEP]VEP0 First
Filter [VEP]
If !fstat
  #Paie existante au
  GMESSAGE = mess(20,10702,1)-format$("D:"+GFMDAT4,[F:VEP]PYRDAT)
  mkstat = 2 : End
Endif

#la paye précédente doit être calculée car aprés la création de la paye d'extourne
# on ne pourra plus y accéder et les cumuls seront faux
Filter [VEP] Where EMP=[M]REFNUM & PYRDAT<VALEUR & CTRNUM=[M]CTRNUM
Read [VEP]VEP0 Last
Filter [VEP]
If !fstat & [F:VEP]STA=1
 GMESSAGE = mess(116,10702,1)-format$("D:"+GFMDAT,[F:VEP]PYRDAT) : # Paye non calculée au
 mkstat = 2 : End
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran EXTPAY) 12/06/2013 16:54:33 (LANEG)
######################################################################################
#86255
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
Raz [M:DIA]
[M]LEG=GCURLEG
Affzo [M:DIA]
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR ="" :  End     : Endif
If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
Call LECTURE("HRCTR", VALEUR,"") From CONTOBJ
Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
Call LECTURE("CPY", [F:FCY]LEGCPY, "") From CONTOBJ
If [F:CPY]LEG<>GCURLEG
 GMESSAGE = [L]VALEUR-":"-mess(14,10712,1) : # Fiche inexistante pour la législation courante
 mkstat = 2
Endif
End

