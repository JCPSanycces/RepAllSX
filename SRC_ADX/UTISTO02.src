#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
# UTISTO02      Moulinette pour nouveau flag de STOJOU      Module STOCK #
# ---------------------------------------------------------------------- #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MOULI_STJFLG(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MOULI_STJFLG(DOSSIER)
Value Char DOSSIER

# moulinette pour passer à oui le flag AGGIFAFLG des mouvements interfacés auparavant
# en se basant sur la table paramètre de traitement
# pour les autres mouvements le flag reste à zéro : ce n'est pas gênant

Local Date    DAT_REF        # ou passer en paramètre ??
Local Integer NB, STOP
Local Char    ERR_TRA(120)
Local Char    CLE1

If clalev([STJ]) = 0 Local File =DOSSIER+".STOJOU"    [STJ] Endif
If clalev([SCR]) = 0 Local File =DOSSIER+".STOCSTREG" [SCR] Endif
If clalev([SAC]) = 0 Local File =DOSSIER+".STOACCPAR" [SAC] Endif
If clalev([ITM]) = 0 Local File =DOSSIER+".ITMMASTER" [ITM] Endif
#

ERR_TRA = "Stock mouvements processing for flag update (aggregation/interface)"
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

Read [SAC]SAC0 Last
If !fstat  
    DAT_REF = [F:SAC]PRODAT  
Else
    Goto FIN_MOULI  # rien à traiter !
Endif

$BOUCLESTJ
Raz NB,STOP

Call DEBTRANS From GLOCK
Trbegin [STJ]

For [ITM] Where ITMREF > CLE1
 For [STJ] Where ITMREF=[F:ITM]ITMREF & CREDAT<=DAT_REF & UPDCOD=2 & ENTCOD<>""
   Readlock [STJ]Curr # locké dans tous les cas
   If fstat
     # Tracer "Enreg verrouillé"
       ERR_TRA = mess(60,100,1)-[F:STJ]STOFCY-[F:STJ]ITMREF-format$(GFMD,[F:STJ]IPTDAT)-num$([F:STJ]MVTSEQ)
       Call ECR_TRACE(ERR_TRA,1) From GESECRAN
       GOK = 0 : Break 2
   Endif  

   [F:STJ]AGGIFAFLG = 2
   Rewrite [STJ]
   If fstat
      # Trace : erreur d'écriture sur le fichier STOJOU "Mvt de stock xxx ..."
       ERR_TRA = mess(13,100,1)-"STOJOU \"-mess(12,197,1)-":"-[F:STJ]STOFCY
       ERR_TRA -= [F:STJ]ITMREF-format$(GFMD,[F:STJ]IPTDAT)-num$([F:STJ]MVTSEQ)
       Call ECR_TRACE(ERR_TRA,1) From GESECRAN
       GOK=0
       Break 2
   Endif
 Next
 NB += 1
 If NB > GMAXUPDTRS : # par tranche (100 articles) pour éviter erreur Oracle
      CLE1 = [F:ITM]ITMREF
      STOP = 1
      Break
 Endif
Next

If GOK = 1
  Commit
  If STOP Goto BOUCLESTJ Endif
Else
  Rollback
  Goto FIN_MOULI
Endif


# traitement des régularisations
Call DEBTRANS From GLOCK
Trbegin [SCR]

For [SCR] Where CREDAT <= DAT_REF
  Readlock [SCR]Curr # locké dans tous les cas
  If fstat
   # Tracer "Enreg verrouillé" # NE DEVRAIT PAS ARRIVER !!
     ERR_TRA = mess(60,100,1)-[F:SCR]STOFCY-mess([F:SCR]VCRTYP,701,1)-[F:SCR]VCRNUM-format$(GFMD,[F:SCR]IPTDAT)
     Call ECR_TRACE(ERR_TRA,1) From GESECRAN
     GOK=0 : Break
  Endif  
  [F:SCR]AGGIFAFLG = 2
  Rewrite [SCR]
  If fstat
     # Trace : erreur à la mise à jour de STOCSTREG
       ERR_TRA = mess(13,100,1)-"STOCSTREG"-[F:SCR]STOFCY-mess([F:SCR]VCRTYP,701,1)
       ERR_TRA -= [F:SCR]VCRNUM-format$(GFMD,[F:SCR]IPTDAT)
       Call ECR_TRACE(ERR_TRA,1) From GESECRAN
       GOK=0
       Break
  Endif

  NB += 1
  If NB > GMAXUPDTRS : # par tranche pour éviter erreur Oracle
      Commit
      Trbegin [SCR]
      Raz NB
  Endif

Next
If GOK = 1
  Commit
Else
  Rollback
Endif

$FIN_MOULI
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
# s'il n'y a pas le module stock ou le module compta, on ne fait rien
If [F:ADS]MODULE(6)<>2 | [F:ADS]MODULE(1)<>2 End : Endif
Call MOULI_STJFLG(APPLI)
End


#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

# s'il n'y a pas le module stock ou le module compta, on ne fait rien
If [F:ADS]MODULE(6)<>2 | [F:ADS]MODULE(1)<>2 End : Endif
Call MOULI_STJFLG(APPLI)
End

