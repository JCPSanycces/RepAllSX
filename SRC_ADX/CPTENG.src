#<AdxTL>@(#)8.0.0.0 $Revision$
#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################################
## Programme de création automatique d'engagements V6 Multi-Référetiels
# Issue X3-83028 - 2018-05-07 by CBO : cannot modify purchase order or request if created in currently closed period
# Issue X3-48560 - 2017-07-27 by BEFOU : Wrong dimension balance after carry-forward of commitments.
#                 - MAJ_BUA : Adding a while to have the good Excercice
#
#########################################################################################
# Subprog MAJENG(DAT,SITE,CUR,MONTANT,RATDIV,RATMLT,QUANTITE,TBACC,TBLED,TIERS
#&                 ,TBDIE,TBCCE,SENS,SIGN,TYP,CONTBUD,ENGAGE,COMMANDE,OK,MESSA
#&                 ,PIECE,IDENT,TYPPCE,NUMPCE,TYPORG,TYPCUR)
#########################################################################################
Subprog MAJENG(DAT,SITE,CUR,MONTANT,RATDIV,RATMLT,QUANTITE,TBACC,TBLED,TIERS
&             ,TBDIE,TBCCE,SENS,SIGN,TYP,CONTBUD,ENGAGE,DOCUMENT,MOTIF,OK,MESSA
&             ,PIECE,IDENT,TYPPCE,NUMPCE,TYPORG,TYPCUR)
Value    Date    DAT              #1
Value    Char    SITE             #2
Value    Char    CUR              #3 Devise
Value    Decimal MONTANT          #4 Montant
Value    Decimal RATDIV(1..)      #5 Tableau des cours diviseur
Value    Decimal RATMLT(1..)      #6 Tableau des cours multiplicateur
Value    Decimal QUANTITE         #7
Value    Char    TBACC()(1..)     #8 Tableau des comptes
Value    Char    TBLED()(1..)     #9 Tableau des référentiels correspondant
Value    Char    TIERS            #10
Value    Char    TBDIE()(1..)     #11 Tableau des axes
Value    Char    TBCCE()(1..)     #12 Tableau des sections (ordre correspondant à celui des axes)
Value    Integer SENS             #13
Value    Integer SIGN             #14
Value    Integer TYP              #15
Value    Integer CONTBUD          #16
Variable Char    ENGAGE()         #17 N° d'engagement quand il en existe déjà un
Value    Char    DOCUMENT()(1..)  #18 (1)n° de la pièce d'origine (2)n° de ligne de la pièce d'origine (3)n° de séquence pour les commandes
Value    Libelle MOTIF(1..)       #19 (1)Motif Action AML-2683  (2) Motif Pièce AML-2684
Variable Integer OK               #20
Variable Char    MESSA()          #21
Value    Char    PIECE            #22
Value    Char    IDENT()(1..)     #23
Value    Char    TYPPCE           #24
Value    Integer TYPORG           #25
Value    Char    NUMPCE           #26
Value    Integer TYPCUR           #27

Local Integer DEBUGTRACE
[L]DEBUGTRACE=[V]CST_AFALSE
Gosub TRC


Local Integer I, B , C , AXE , OK2 , STA, K
Local Integer BALEXE
Local Integer BALPER
Local Integer BALSNS
Local Char    BALCUR(GLONCUR),CPYCUR(GLONCUR),RPTCUR(GLONCUR)
Local Decimal BALAMT
Local Decimal BALQTY
Local Char    BALSIT(GLONFCY) , BALSOC(GLONCPY)
Local Char    BALACC(GLONGAC) , BALBPR(GLONBPR)
Local Integer ISITE , ISOC , NIVSOC , NIVDEV , NBMESSA
Local Decimal EXERCICE , PERIODE , PREVEXE , PREVPER
Local Char    SOCIETE(GLONCPY), DEVSOC(GLONCUR)
Local Integer OKBUD(1..10)
Local Integer CREENG , LIG
Local Char    SYMBOLE(30) , ENGCPT(GLONANM)
Local Integer FLGPCE , STAT , NBCLE , INDCUR, OKQTY
Local Char    CRITERE(250) , CLE(10)(1..8)

Local Integer LEDTYPANAPPL :# Type de référentiel analytique principal

# Référentiel de référence = on prends le référentiel analytique principal si celui-ci est
# falgué engagements, sinon on prend le premier référentiel passé flagué engagament
Local Integer LEDTYPREF       :# Type de référentiel de référence

# Variable tableau de tri des données dont référentiel sont flagués 'engagement'
Local Char TBENGLED(GLONLED)(1..10)  # tableau des référentiels flagué engagement
Local Char TBENGCUR(GLONCUR)(1..10)  # tableau des devises des référentiels flagué engagement
Local Char TBENGCOA(GLONCOA)(1..10)  # tableau des plans de comptes correspondant
Local Char TBENGACC(GLONGAC)(1..10)  # tableau des comptes
Local Char TBENGDIE(GLONDIE)(1..20)  # tableau des axes
Local Char TBENGCCE(GLONCCE)(1..20)  # tableau des sections
Local Integer TBENGLEDTYP(1..10)     # tableau des types de référentiel
Local Integer TBENGDACRAT(1..10)     # tableau des modes de saisie des cours
Local Decimal TBENGRATMLT(1..10)     # tableau des cours multiplicateur
Local Decimal TBENGRATDIV(1..10)     # tableau des cours diviseur
Local Integer TBENGBUDFLG(1..10)     # tableau des flag 'Budget'
Local Decimal TBENGAMTLED(1..10)     # tableau des montants par référentiel
Local Decimal AMTLEDC                # montant référentiel calculé
Local Integer NBTYP                  # nombre de type de référentiel flagué engagement

# Pour les particularités liées au BUO, dans la gestion des AAR & FAR
# sur les changements d'enveloppe (type annuelle), séparation des sections
# des engagements et des lignes budgétaires
Local Char TBCMDDIE(GLONDIE)(1..20)  # tableau des axes pour la ligne d'engagement
Local Char TBCMDCCE(GLONCCE)(1..20)  # tableau des sections pour la ligne d'engagement
Local Char TBBUDDIE(GLONDIE)(1..20)  # tableau des axes pour la ligne budgétaire
Local Char TBBUDCCE(GLONCCE)(1..20)  # tableau des sections pour la ligne budgétaire
Local Date CMDDAT : CMDDAT=DAT
Local Date BUDDAT : BUDDAT=DAT
Local Integer CMDFIY,CMDPER

#Flag indication pièce d'achat reportée
Local Integer PURRPT : PURRPT=0

#Pour les erreurs d'arrondi Dmd 59712
Local Decimal SOM_AMTCUR
Local Decimal MONTANT_FINAL

If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BLM])=0 : Local File BLACMM     [BLM] : Endif
If clalev([F:BUD])=0 : Local File BUD        [BUD] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR     [BUP] : Endif
If clalev([F:CMM])=0 : Local File GCOMMIT    [CMM] : Endif
If clalev([F:CMD])=0 : Local File GCOMMITD   [CMD] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif

#Operating Budgets Tables
If func AFNC.ACTIV("GDD")
 If !clalev([F:ENV])  : Local File ENVELOPPE [ENV]  : Endif
 If !clalev([F:ENV2]) : Local File ENVELOPPE [ENV2] : Endif
 If !clalev([F:BUA])  : Local File BUDPURAUD [BUA]  : Endif
 Local Char ENVELOP(GLONENV),ENTITY(GLONENT),SECTION3(GLONCCE)
 Local Char BUOSITE(GLONFCY), BUDCOD(GLONBUP)
 Local Integer AXENV , AXENT , AX3 , OKBUO, YEAFLG
 If [L]DEBUGTRACE : Call ECR_TRACE("Operating Budgets Tables",0) From  GESECRAN :Endif
 Call GETBUOINF(TBDIE,TBCCE,SITE,BUDCOD,ENTITY,AXENT,ENVELOP,AXENV,SECTION3,AX3,OKBUO,YEAFLG,BUOSITE) From TRTGDD
Endif

## Préambules
OK = 1 : Raz MESSA
BALSIT = SITE
ISITE = find(BALSIT,GSITE(1..GNBSITE))
If !ISITE
 MESSA = SITE-mess(15,104,1) : # Site inexistant
 Goto ABORT
Endif
BALSOC = GSOCSITE(ISITE)
ISOC = find(BALSOC,GSOC(1..GNBSOC))
If !ISOC
 MESSA = BALSOC-mess(16,104,1) : # Société inexistante
 Goto ABORT
Endif
SOCIETE = GSOC(ISOC)

Call DEFVAR(SITE) From CPTBUD

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
DEVSOC=[F:CPY]ACCCUR
#Référentiel analytique principal
Call LECTURE("GCM",[F:CPY]ACM,"")From CONTOBJ
LEDTYPANAPPL = [F:GCM]ANALEDTYP

############### Tri des comptes et référentiel reçus + variables utiles #############
# On reçoit dans les paramètres:
# -la liste des comptes,
# -les types de référentiel corrrespondants
# -ainsi que les montants et devises référentiels...
# ...Mais tous les référentiels ne sont pas flagué engagements et
# il incombe donc ici d'en faire le tri...
#----------------------------------------------------------------
# Récupération des référentiels flagués engagament de la société et
# des données les concernants
#----------------------------------------------------------------
J=0 : NBTYP=0
For I=1 To dim(TBLED)
 K = find(TBLED(I),[F:GCM]LED(0..9))
 If K
  Read [LED]LED0 = [F:GCM]LED(K-1)
  If !fstat & [F:LED]CMM=2
   J+=1
   NBTYP+=1
   TBENGLEDTYP(J) = K
   TBENGLED(J) = [F:GCM]LED(K-1)
   TBENGCUR(J) = [F:GCM]CUR(K-1)
   TBENGACC(J) = TBACC(I)
   TBENGCOA(J) = [F:LED]COA
   TBENGDACRAT(J) = [F:GCM]DACRAT(K-1)
   TBENGRATDIV(J) = RATDIV(I)
   TBENGRATMLT(J) = RATMLT(I)
   TBENGBUDFLG(J) = [F:LED]BUD
  Endif
 Endif
Next

If NBTYP=0
 OK=0
 #Aucun référentiel n'est flagué engagement pour ce document
 MESSA=mess(199,107,1)
 End
Endif

#Pour la Dmd 60018
#Dimensionnement à NBTYP pour optimisation
Local Integer LSTNEWLEDTYP(1..NBTYP)

## Contrôle sur date : on détermine et utilise ici le référentiel de référence
If find(LEDTYPANAPPL,TBENGLEDTYP(1..NBTYP))
 LEDTYPREF=LEDTYPANAPPL
Else
 LEDTYPREF=TBENGLEDTYP(1)
Endif

Call GETPERSOC(SOCIETE,LEDTYPREF,DAT,EXERCICE,PERIODE) From CPTSUB
If EXERCICE=0 | PERIODE=0
 MESSA = num$(DAT)-mess(1,104,1) : # Date incorrecte
 Goto ABORT
Endif
mkstat=0

# Issue X3-83028
Local Char LPARM(10)
  Call PARAM("", "CMMPERCTL", LPARM) From ADOVAL
  If LPARM = num$([V]CST_AYES)
    Call CONTPER(DAT,LEDTYPREF,SITE) From CPTSUB
    If mkstat
      MESSA = mess(1,104,1)-num$(DAT)-"\"-GMESSAGE : # Date incorrecte
      Raz mkstat, GMESSAGE
      Goto ABORT
    Endif
  Endif
# EndIssue X3-83028

# Récupération Exercice et période pour la ligne d'engagement
Call GETPERCPY(SOCIETE,LEDTYPREF,CMDDAT,CMDFIY,CMDPER) From CPTSUB

If [L]DEBUGTRACE : Call ECR_TRACE("Exercice : "-num$(CMDFIY) ,0) From  GESECRAN :Endif

## Vérif ou création en-tête engagement
CREENG=0
If ENGAGE=""
 CREENG = 1
Else
 Readlock [CMM]CMM0 = ENGAGE
 If fstat=1
  GOK = -1 : GLOCK = "$GCOMMIT"-ENGAGE : Goto AB_TR
 Elsif fstat
  CREENG = 1
 Elsif !fstat
  Filter [CMD] Where NUM=ENGAGE
  Read [CMD]CMD0 Last
  If !fstat
   #Dmd 60018 : Detection des ledtyp non-utilisés, utile dans le calculs des montants
   Raz LSTNEWLEDTYP
   J=0
   For I=1 To NBTYP
    If !find(TBENGLEDTYP(I),[F:CMD]LEDTYP(0..dim([F:CMD]LEDTYP)-1))
     J+=1
     LSTNEWLEDTYP(J)=TBENGLEDTYP(I)
    Endif
   Next
  Endif
  Filter [CMD]
 Endif
Endif
If [L]DEBUGTRACE : Call ECR_TRACE("Creation d'engagement : "-num$(CREENG) ,0) From  GESECRAN :Endif
#----------------------------- Axes & Sections   ----------------------------#

## Construction du tableau des couples Axe/section des référentiels flagué engagement
## à partir des couples Axe/Section passé en paramètre
Local Integer NBDIE : NBDIE=0
K=0
For I=1 To NBTYP
 If !find(TBENGLEDTYP(I),LSTNEWLEDTYP(1..NBTYP))
  Read [LED]LED0=TBENGLED(I)
  If !fstat
   For J=0 To [F:LED]DIENBR-1
    X=find([F:LED]DIE(J),TBDIE(1..dim(TBDIE)))
    If X & !find([F:LED]DIE(J),TBENGDIE(1..20))
     NBDIE+=1
     K+=1
     TBENGDIE(K)=TBDIE(X)
     TBENGCCE(K)=TBCCE(X)
     #Pour les particularités liées au BUO, dans la gestion des AAR & FAR
     #sur les changements d'enveloppe (type annuelle), séparation des sections
     #des engagements et des lignes budgétaires
     TBCMDDIE(K)=TBDIE(X)
     TBCMDCCE(K)=TBCCE(X)
     TBBUDDIE(K)=TBDIE(X)
     TBBUDCCE(K)=TBCCE(X)
    Endif
   Next
  Endif
 Endif
Next

## Point d'entrée pour modifier des variables
GPOINT = "ENGAGE" : Gosub ENTREE From EXEFNC

If CREENG=-1
 End
Elsif CREENG

 # Récupération du compteur d'engagement
 ENGCPT = ""
 Read [TCA]TCA0 = 2;SOCIETE
 If !fstat
  If TYP=2
   ENGCPT = [F:TCA]CODNUM(1)
  Else
   ENGCPT = [F:TCA]CODNUM(5)
  Endif
 Endif
 If ENGCPT=""
  Read [TCA]TCA0 = 2;""
  If !fstat
   If TYP=2
    ENGCPT = [F:TCA]CODNUM(1)
   Else
    ENGCPT = [F:TCA]CODNUM(5)
   Endif
  Endif
 Endif
 If ENGCPT="" : ENGCPT="CMM" : Endif
 Call NUMERO(ENGCPT,SITE,DAT,"",ENGAGE,STAT) From SUBANM
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE=mess(60,199,1)-"("+ENGCPT+") : "+MESSA
  Goto ABORT
 Endif
Endif

## Verrou de l'engagement
SYMBOLE = "CMM"+ENGAGE
Lock =SYMBOLE
If fstat=1
 GOK = -1 : GLOCK = "%"+SYMBOLE : Goto AB_TR
Endif

#----------------------------- Calculs Montants/Amount's calculation  ----------------------------#

#Pour Defaut d'arrondi sur montant AMTCUR
MONTANT_FINAL=MONTANT

#################
# Cas de modification d'un engagement ou préengagement existant
# que l'on désengage ou dèspréengage avec légère variation du montant.
# ex on avait 12.34 & on dèsengage 12.35
# Methode dite de l'arrondi progressif sur les lignes de l'engagement
If CREENG<>1
 Raz SOM_AMTCUR
 #
 For [CMD]CMD0 Where NUM=ENGAGE
  SOM_AMTCUR+=[F:CMD]AMTCUR
 Next
 SOM_AMTCUR+=SIGN*MONTANT
 #
 If SOM_AMTCUR<0 & abs(SOM_AMTCUR)<1
  MONTANT_FINAL = MONTANT-abs(SOM_AMTCUR)
 Endif
Endif
#################

# Gestion des montants référentiels et cours devises
For I=1 To NBTYP
 TBENGAMTLED(I)=0
 If !find(TBENGLEDTYP(I),LSTNEWLEDTYP(1..NBTYP))
  Case TBENGDACRAT(I)
   When 1,3 :# Type saisie cours :  Multiplicateur(1) ou Les Deux(3)
    If TBENGRATMLT(I)<>0
     TBENGAMTLED(I) = MONTANT_FINAL*TBENGRATMLT(I)
    Else
     If TBENGCUR(I)<>CUR
      #CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
      Call CONVERT(CUR,TBENGCUR(I),DEVSOC,TYPCUR,DAT,MONTANT_FINAL,AMTLEDC,STAT) From TRTDEV
      If !STAT
       TBENGAMTLED(I) = AMTLEDC
      Endif
     Else
      TBENGAMTLED(I)= MONTANT_FINAL
     Endif
     If MONTANT_FINAL<>0
      TBENGRATMLT(I)= TBENGAMTLED(I) / MONTANT_FINAL
      TBENGRATDIV(I)= 1
     Endif
    Endif
   When 2 : # Type saisie cours : Diviseur (2)
    If TBENGRATDIV(I)<>0
     TBENGAMTLED(I) = MONTANT_FINAL / TBENGRATDIV(I)
    Else
     If TBENGCUR(I)<>CUR
      #CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
      Call CONVERT(CUR,TBENGCUR(I),DEVSOC,TYPCUR,DAT,MONTANT_FINAL,AMTLEDC,STAT) From TRTDEV
      If !STAT
       TBENGAMTLED(I) = AMTLEDC
      Endif
     Else
      TBENGAMTLED(I)= MONTANT_FINAL
     Endif
     If TBENGAMTLED(I)<>0
      TBENGRATDIV(I)= MONTANT_FINAL / TBENGAMTLED(I)
      TBENGRATMLT(I)= 1
     Endif
    Endif
  Endcase
 Endif
Next
#----------------------------- Fin calcul montant ----------------------------#

########################
## En-tête d'Engagement
########################

## Création / mise à jour
If CREENG
 Raz [F:CMM]
 [F:CMM]NUM = ENGAGE
 If TYP=1
  [F:CMM]TYP = 1 : # Pré-Engagement
 Else
  [F:CMM]TYP = 2 : # Engagement
 Endif
 [F:CMM]SNS    = SENS
 For I=0 To len(mess(0,2644,1))-1
  K=find(I+1,TBENGLEDTYP(1..NBTYP))
  If K
   [F:CMM]LED(I)    = TBENGLED(K)
   [F:CMM]CURLED(I) = TBENGCUR(K)
   [F:CMM]RATMLT(I) = TBENGRATMLT(K)
   [F:CMM]RATDIV(I) = TBENGRATDIV(K)
  Endif
 Next
 [F:CMM]CPY    = SOCIETE
 [F:CMM]FCY    = BALSIT
 [F:CMM]BPR    = TIERS
 [F:CMM]CUR    = CUR
 [F:CMM]TYPCUR = TYPCUR
 If TYPPCE<>"" : [F:CMM]TYPREF = TYPPCE : Endif
 If NUMPCE<>"" : [F:CMM]NUMREF = NUMPCE : Endif
 [F:CMM]TYPORG = TYPORG
 [F:CMM]NUMORG = DOCUMENT(1)
 [F:CMM]CREDAT = date$
 [F:CMM]CREUSR = GUSER
 Gosub EVAL_PIECE
 If [F:CMM]REFINT=""
  [F:CMM]REFINT = DOCUMENT(1)
 Endif
 If [F:CMM]DESVCR=""
  [F:CMM]DESVCR = mess(28,104,1) : # Engagement auto
 Endif
 Write [CMM]
Else
 [F:CMM]BPR    = TIERS
 [F:CMM]CUR    = CUR
 [F:CMM]UPDDAT = date$
 [F:CMM]UPDUSR = GUSER
 If TYPPCE<>"" : [F:CMM]TYPREF = TYPPCE : Endif
 If NUMPCE<>"" : [F:CMM]NUMREF = NUMPCE : Endif
 [F:CMM]TYPORG = TYPORG
 [F:CMM]NUMORG = DOCUMENT(1)
 Rewrite [CMM]
Endif
If fstat
 GOK = 0 : Call FSTA("CMM") From GLOCK : Goto AB_TR
Endif

########################
## Lignes d'Engagement
########################

Filter [CMD] Where NUM=ENGAGE
Read [CMD]CMD0 Last
Filter [CMD]
If fstat
 LIG = 1
Else
 LIG = [F:CMD]LIN+1
Endif


#---------------------------------------------------------#
#----- !!!  Yearly Closing / FAR & ARR gestion !!! -------#
#  L'Affectation des variables suivantes peut y changer:  #
# TBCMDDIE-TBCMDCCE / TBBUDDIE-TBBUDCCE                   #
# CMDDAT / BUDDAT                                         #
#---------------------------------------------------------#
If func AFNC.ACTIV("GDD")
 Gosub BUO_CLOSING
 If OK = 0 : End : Endif
Endif
#---------------------------------------------------------#

#-------------------------------------------#
# Audit des achats                          #
# Mise à jour/création de la piste d'audit  #
#-------------------------------------------#
Gosub MAJ_BUA
#-------------------------------------------#

Raz [F:CMD]
[F:CMD] = [F:CMM]
[F:CMD]LIN = LIG
[F:CMD]FCYLIN = BALSIT
[F:CMD]BPRACC = TIERS
For I=0 To len(mess(0,2644,1))-1
 K=find(I+1,TBENGLEDTYP(1..NBTYP))
 If K & !find(TBENGLEDTYP(K),LSTNEWLEDTYP(1..NBTYP))
  [F:CMD]LED(I)    = TBENGLED(K)
  [F:CMD]LEDTYP(I) = TBENGLEDTYP(K)
  [F:CMD]COA(I)    = TBENGCOA(K)
  [F:CMD]ACC(I)    = TBENGACC(K)
 Else
  [F:CMD]LEDTYP(I) = 0
 Endif
Next
For AXE=1 To min(dim([F:CMD]DIE),GOPTCANA)
 [F:CMD]DIE(AXE-1) = TBCMDDIE(AXE)
 [F:CMD]CCE(AXE-1) = TBCMDCCE(AXE)
Next AXE
Gosub MAJLIG
Gosub EVAL_LIG
If [F:CMD]DES=""
 For I=0 To dim([F:CMD]ACC)-1
  If [F:CMD]ACC(I)<>""
   Call LECTEXTRA([F:CMD]DES,"GACCOUNT","DESTRA",[F:CMD]COA(I),[F:CMD]ACC(I)) From ATEXTRA
   Break
  Endif
 Next
Endif
[F:CMD]GRDACT = MOTIF(1)
[F:CMD]GRDPCE = MOTIF(2)
If [L]DEBUGTRACE : Call ECR_TRACE("GCOMMITD Write : "-left$(num$([F:CMD]ACCDAT),10) ,0) From  GESECRAN :Endif
Write [CMD]
If fstat
 GOK = 0 : Call FSTA("CMD") From GLOCK : Goto AB_TR
Else
 If GFONCTION="CMMREP" & GTRACE<>""
  Call ECR_TRACE (mess(TYP,631,1)-ENGAGE-":"-format$("D:DD[/]MM[/]YYYY",DAT)-":"-mess(MOTIF(1),2683,1)-mess(MOTIF(2),2684,1)-":"-num$(SIGN*MONTANT_FINAL),0) From GESECRAN
 Endif
Endif


#-------------------------------------------#
# Contrôle budgétaire                       #
# Mise à jour des budgets                   #
# Mise à jour de la balance d'engagement    #
#-------------------------------------------#

Local Char TBDIELED(GLONDIE)(1..dim([L]TBDIE))
Local Char TBCCELED(GLONCCE)(1..dim([L]TBDIE))

For I=1 To NBTYP
 If !find(TBENGLEDTYP(I),LSTNEWLEDTYP(1..NBTYP)) :#Dmd 60018
  Raz TBDIELED, TBCCELED
  # Axes et sections associés au référentiel courant TBENGLEDTYP(I)
  Call SETDIECCELED(TBBUDDIE,TBBUDCCE,TBENGLED(I),TBDIELED,TBCCELED) From CPTDIV
  # MAJ budgets et balance d'engagement/updating budgets & commitment's balance
  Call MAJBUD(BUDDAT,SITE,TBENGLEDTYP(I),CUR,MONTANT_FINAL,TBENGAMTLED(I),QUANTITE,
&             TBENGACC(I),TIERS,TBDIELED,TBCCELED,SENS,SIGN,TYP,CONTBUD,OK,MESSA) From CPTBUD
  If OK<1
   If CONTBUD<>2 & MESSA<>""
    Call MESSAGE(MESSA) From GESECRAN
   Endif
   Break
  Endif
 Endif
Next
End

$MAJLIG
# Date
[F:CMD]ACCDAT = CMDDAT
[F:CMD]FIY    = CMDFIY
[F:CMD]PER    = CMDPER
# Amount
[F:CMD]AMTCUR += SIGN*MONTANT_FINAL
For I=0 To len(mess(0,2644,1))-1
 K=find(I+1,TBENGLEDTYP(1..NBTYP))
 If K & !find(TBENGLEDTYP(K),LSTNEWLEDTYP(1..NBTYP))
  [F:CMD]CURLED(I) = TBENGCUR(K)
  [F:CMD]AMTLED(I) += SIGN*TBENGAMTLED(K)
 Endif
Next
# Quantity
OKQTY=0
For I=0 To len(mess(0,2644,1))-1
 K=find(I+1,TBENGLEDTYP(1..NBTYP))
 If K & !find(TBENGLEDTYP(K),LSTNEWLEDTYP(1..NBTYP))
  Call LECTURE("GAC",TBENGACC(K),TBENGCOA(K)) From CONTOBJ
  If [F:GAC]FLGUOM=2 : OKQTY=1 : Break : Endif
 Endif
Next
If OKQTY
 [F:CMD]QTY += SIGN*QUANTITE
 [F:CMD]UOM = [F:GAC]UOM
Else
 QUANTITE   = 0
 [F:CMD]QTY = 0
 [F:CMD]UOM = ""
Endif
Return


#------------------------------------------------
Subprog CORBLACMM(SIGN)
Value Integer SIGN

Local Date    BLMDAT
Local Char    BLMFCY(GLONFCY)
Local Char    BLMCUR(GLONCUR)
Local Decimal BLMAMT
Local Char    BLMBPR(GLONBPR)
Local Integer BLMSNS
Local Integer TYP
Local Integer CONTBUD
Local Integer OK
Local Char    MESSA
Local Char    TBDIE(GLONDIE)(1..dim([F:CMD]DIE))
Local Char    TBCCE(GLONCCE)(1..dim([F:CMD]CCE))

CONTBUD   = 0
TYP       = [F:CMM]TYP
BLMDAT    = [F:CMD]ACCDAT
BLMFCY    = [F:CMD]FCYLIN
BLMCUR    = [F:CMM]CUR
BLMAMT    = [F:CMD]AMTCUR
BLMAMTLED = [F:CMD]AMTLED
BLMQTY    = [F:CMD]QTY
BLMBPR    = [F:CMD]BPRACC
BLMSNS    = [F:CMM]SNS

For I=0 To dim([F:CMD]LED)-1
 Raz TBDIE,TBCCE
 Call SETDIECCELED([F:CMD]DIE,[F:CMD]CCE,[F:CMD]LED(I),TBDIE,TBCCE) From CPTDIV
 Call MAJBUD(BLMDAT,BLMFCY,[F:CMD]LEDTYP(I),BLMCUR,BLMAMT,[F:CMD]AMTLED(I),BLMQTY
&          ,[F:CMD]ACC(I),BLMBPR,TBDIE,TBCCE,BLMSNS,SIGN,TYP,CONTBUD,OK,MESSA) From CPTBUD
 If OK<1
  Call MESSAGE(MESSA) From GESECRAN
  Break
 Endif
Next
End

$ABORT
OK = 0 : GOK = 0
End

$AB_TR
OK = 0
MESSA = mess(18,114,1) : # Transaction abandonnée
End

## V130, évaluation de certains élément en fonction de la pseudo-pièce auto
$EVAL_PIECE
If PIECE<>""
 Gosub OUVRE_PIECE
 If FLGPCE
  Call EVAL_CHAR([F:CMM]DESVCR,"VCR",1,0,"",STAT) From CPTAUTO
  Call EVAL_CHAR([F:CMM]REFINT,"REF",1,0,"",STAT) From CPTAUTO
  ## Point d'entrée pour Dmd 60027/en-tête
  GPOINT = "EVALHEA" : Gosub ENTREE From EXEFNC
 Endif
Endif
Return

$EVAL_LIG
If PIECE<>""
 Gosub OUVRE_PIECE
 If FLGPCE
  Call EVAL_CHAR([F:CMD]DES,"DES",2,1,"",STAT) From CPTAUTO
  ## Point d'entrée pour Dmd 60027/Ligne
  GPOINT = "EVALLIN" : Gosub ENTREE From EXEFNC
 Endif
Endif
Return

$OUVRE_PIECE
If FLGPCE=0
 If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif
 If clalev([F:GAD])=0 : Local File GAUTACED    [GAD] : Endif
 Read [GAU]GAU0 = PIECE
 If fstat : Return : Endif
 Read [GAD]GAD0 = PIECE;1
 If fstat : Return : Endif
 If clalev([F:TB0])=0 : Local File =[F:GAU]TBL [TB0] : Endif
 Gosub OUVRE  From ="WMGAU"+PIECE
 Gosub CLE    From ="WMGAU"+PIECE
 CRITERE = ""
 For I=1 To NBCLE
  If [F:GAU]GRPFLG=1 | IDENT(I)<>""
   If CRITERE<>"" : CRITERE += " & " : Endif
   Case evalue("type([F:TB0]"+CLE(I)+")")
    When 1,2,4,5,6,7,8,9
     CRITERE += CLE(I)+'='+IDENT(I)
    When 3
     CRITERE += CLE(I)+'=['+format$(GFMD,gdat$(IDENT(I)))+']'
    When Default
     CRITERE += CLE(I)+'="'+IDENT(I)+'"'
   Endcase
  Endif
 Next I
 Default File [TB0]
 If [F:GAU]FORCND<>""
  If CRITERE<>"" : CRITERE -= "&" : Endif
  CRITERE -= "("+[F:GAU]FORCND+")"
 Endif
 If CRITERE<>""
  Filter [TB0] Where evalue(CRITERE)
 Endif
 [G:TB0]currind = 1
 [G:TB0]currlen = 0
 Read [TB0] First
 Gosub LIENS  From ="WMGAU"+PIECE
 Gosub LIENS1 From ="WMGAU"+PIECE
 FLGPCE = 1
Endif
Return


$BUO_CLOSING
#-------- All Yearly Closing stuff right here --------
# Originals Parameters of the Call MAJENG (Date, Envelope , Entity)

# Intervention on Variable:
# TBCMDCCE()
# TBBUDCCE()
# CMDDAT
# BUDDAT

Local Char ENTITY(GLONCCE), ENVELOP(GLONCCE), CCE3(GLONCCE)
Local Integer INDENT, INDENV, INDCCE3, BUO, YEAFLG
Local Char BUDCOD(GLONBUP),FCYBUD(GLONFCY)
Local Decimal FIYCUR, FIYENV, FIYENV2

Local Char SITUATION (3)
SITUATION = num$(MOTIF(1))+";"+num$(MOTIF(2))

# Année fiscale de la date courant/ Fiscalyear of the current date
Call GETEXE(SOCIETE,LEDTYPANAPPL,DAT,FIYCUR) From CPTSUB
# Info des BUO / Budget operationnal's informations (ENVELOP,YEAFLG mainly used)
Call GETBUOINF(TBENGDIE,TBENGCCE,SITE,BUDCOD,ENTITY,INDENT,ENVELOP,INDENV,CCE3,INDCCE3,BUO,YEAFLG,FCYBUD) From TRTGDD

If BUO
 # On est dans le cas d'un budget opérationnel (entité et enveloppe sont renseignées, et la 3ème section éventuellement)
 # Budget operationnal (it means that Entity & Envelop Centers are set, and eventually a third center too)

 Call LECTURE("ENV",ENVELOP,"") From CONTOBJ
 Call LECTURE("BUP",BUDCOD,"") From CONTOBJ

 Local Decimal FIYORD
 Local Char    ORDNUM(GLONVCR)
 Local Integer ORDLIN,ORDSEQ,ORDDL
 Local Char    INFPUR(25)(1..4)
 Local Integer TOTRCP
 Local Integer CMMLFT
 Local Decimal PURRPTFIY : # 80562

 Local Integer LEDTYPANA_TBENG
 LEDTYPANA_TBENG = find(LEDTYPANAPPL,TBENGLEDTYP(1..NBTYP))
 If LEDTYPANA_TBENG=0 : LEDTYPANA_TBENG=LEDTYPANAPPL : Endif

 Local Char BUDLED(GLONLED), DEVLED(GLONCUR), BUDCRI(250)
 Call LECLED(SOCIETE,LEDTYPANAPPL,BUDLED,DEVLED) From CPTDIV
 Call LEC_LED(BUDLED) From CPTLEC

 Local Char ENVDIE(GLONDIE), ENTDIE(GLONDIE), AXE3DIE(GLONDIE)
 ENTDIE = [F:BUP]DIE(0)
 ENVDIE = [F:BUP]DIE(1)
 OTHDIE = [F:BUP]DIE(2)

 TOTRCP=0 #Flag Reception totale / Total receipt flag
 CMMLFT=1 #Flag il reste des engagements / There still are commitment
 PURRPT=0 #Flag pièce d'achat reportée

 Raz ORDLIN, ORDSEQ, ORDDL

 ORDNUM = DOCUMENT(1) # Numéro de pièce d'achat à l'origine
 If dim(DOCUMENT(2))>=2
  ORDLIN = val(DOCUMENT(2)) # Numéro de ligne de pièce d'achat en cours
 Endif
 If dim(DOCUMENT(3))>=3
  ORDSEQ = val(DOCUMENT(3)) # Numéro de séquence (pour les commandes)
 Endif
 #101680 : La piste d'Audit permet de savoir s'il y a report des engagements
 # Sous MAJ_BUA de CPTENG, le champ ANALIN est exclusivement renseigné pour les commandes ouvertes.
 # Il faut alimenter ORDDL avec la même condition
 #If dim(DOCUMENT(4))>=4
 # ORDDL = val(DOCUMENT(4)) # Numéro de séquence (pour les DL)
 #Endif
 If TYPORG=2 & dim(DOCUMENT)>=4 # commande ouverte
  ORDDL = val(DOCUMENT(4))
 Endif

 If !clalev([F:CPOH]) : Local File PORDER     [CPOH] : Endif
 If !clalev([F:CPOP]) : Local File PORDERP    [CPOP] : Endif
 If !clalev([F:CPOQ]) : Local File PORDERQ    [CPOQ] : Endif
 If !clalev([F:CCAL]) : Local File CPTANALIN  [CCAL] : Endif
 If !clalev([F:CUOP]) : Local File UPORDERP   [CUOP] : Endif
 If !clalev([F:CPTH]) : Local File PRECEIPT   [CPTH] : Endif
 If !clalev([F:CPTD]) : Local File PRECEIPTD  [CPTD] : Endif
 If !clalev([F:CPNH]) : Local File PRETURN    [CPNH] : Endif
 If !clalev([F:CPND]) : Local File PRETURND   [CPND] : Endif
 If !clalev([F:BUA])  : Local File BUDPURAUD  [BUA]  : Endif

 #---------------------- TOTRCP ------------------------#
 #Vérification du caractère total de la reception
 #Checking if the receipt is total or not
 Local Integer QTYORDUOM,QTYORDPUU,QTYRCPUOM,QTYRCPPUU,QTYRTNUOM,QTYRTNPUU
 #Quantité commandée / Quantity ordered
 Read [CPOQ]POQ0=ORDNUM;ORDLIN;ORDSEQ
 If !fstat
  QTYORDUOM = [F:CPOQ]QTYUOM
  QTYORDPUU = [F:CPOQ]QTYPUU
 Endif
 #Quantité receptionnée / Quantity receipted
 Filter [CPTD] Where POHNUM=ORDNUM & POPLIN=ORDLIN & POQSEQ=ORDSEQ
 For [CPTD]PTD0
  QTYRCPUOM += [F:CPTD]QTYUOM
  QTYRCPPUU += [F:CPTD]QTYPUU
 Next
 Filter [CPTD]
 #Quantité retournnée / Quantity returned
  Filter [CPND] Where POHNUM=ORDNUM & POPLIN=ORDLIN & POQSEQ=ORDSEQ
 For [CPND]PND0
  QTYRTNUOM += [F:CPND]QTYUOM
  QTYRTNPUU += [F:CPND]QTYPUU
 Next
 Filter [CPND]

 # Reception totale/Total receipt ?
 TOTRCP = ((QTYORDUOM<>0 & QTYORDUOM=QTYRCPUOM) | (QTYORDPUU<>0 & QTYORDPUU=QTYRCPPUU))
 #------------------------------------------------------#

 #---------------------- CMMLFT/PURPRT ------------------------#
 # Reste-t-il de l'engagement sur la cmd ? A-t-elle été reportée ?
 #Is there Commitment left on order ? Has it been postponed ?


# 04/02/2013
#Suite à la correction de 84939 Prise en compte du cas des DL pour une détection
# correcte des pièce d'achat reportée => utilisation du ORDDL

 Read [CPOH]POH0 = ORDNUM
 If !fstat
  Call GETEXE(SOCIETE,LEDTYPANAPPL,[F:CPOH]ORDDAT,FIYORD) From CPTSUB
  Read [BUA]BUA0 = 2;"";ORDNUM;ORDLIN;ORDSEQ;ORDDL;FIYORD
  If !fstat
   If [F:BUA]CMM<=0
    CMMLFT=0
   Endif
   If [F:BUA]POSTPONED=2
    PURRPT=1
    PURRPTFIY=[F:BUA]FIY+1
   Endif
  Endif
 Endif

 #-------------------------------------------------------------#
 # 80562 : Cas pour ENVA & ENVP
 If SITUATION="2;2" : #Modification commande
  #Cas de modification de date de réception sur la ligne de commande aprés report
  #des engagements. Il faut déengager sur l'exercice de report
  If PURRPT & FIYCUR<PURRPTFIY
   Local Date DATSTR,DATEND
   Call DATEXE(SOCIETE,LEDTYPANAPPL,PURRPTFIY,DATSTR,DATEND) From CPTSUB
   CMDDAT=DATSTR
   BUDDAT=DATSTR
  Endif
 Endif

 If YEAFLG=1
  ##################
  # Annual envelop #
  ##################
  Call GETEXE(SOCIETE,LEDTYPANAPPL,[F:ENV]REASTR,FIYENV) From CPTSUB
   #Situation :
   # LEDTYP+BUD+CPY+FCY+FIY+VER+ACC+CCE1+CCE2+CCE3
   Raz [F:BUD]
   I = find(ENTDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
   If I : Assign "[F:BUD]CCE"+num$(I) With ENTITY : Endif
   I = find(ENVDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
   If I : Assign "[F:BUD]CCE"+num$(I) With ENVELOP : Endif
   If OTHDIE<>""
    I = find(OTHDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
    If I : Assign "[F:BUD]CCE"+num$(I) With CCE3 : Endif
   Endif
   [F:BUD]LEDTYP = LEDTYPANAPPL
   [F:BUD]BUD    = [F:ENV]BUD
   [F:BUD]CPY    = SOCIETE
   [F:BUD]FCY    = FCYBUD
   [F:BUD]FIY    = FIYENV
   [F:BUD]VER    = "1"
   [F:BUD]ACC    = TBENGACC(LEDTYPANA_TBENG)
   Read [BUD]BUD0=

  Case SITUATION
   When "1;4","1;5" : #Création FAR,Creation AAR
    If !fstat & [F:BUD]STA=5 & (!CMMLFT | PURRPT)
     #Cas de la FAR APRES report des engagements, il y a une enveloppe sur N+1
     #After Commitment's report, if there is an envelop on N+1
     Read [ENV2]ENV0 = [F:ENV]ENVRCD
     If !fstat
      TBCMDCCE(INDENV)=[F:ENV2]ENV
      CMDDAT=[F:ENV2]REASTR
      Call GETPERCPY(SOCIETE,LEDTYPANAPPL,CMDDAT,CMDFIY,CMDPER) From CPTSUB
      TBBUDCCE(INDENV)=[F:ENV2]ENV
      BUDDAT=[F:ENV2]REASTR
     Endif
    Endif
   When "5;4","5;5" : #Extourne FAR,Extourne AAR
     If !fstat & [F:BUD]STA<>5 & FIYCUR>FIYENV
      # Before commitment's report
      # If the status of the budget line of the Annual budget envelop on N
      # HASN'T been 'reported for commitment', and the fiscalyear of the given
      # parameter date  is bigger than the fiscalyear of the parameter envelop
      # then the envelop of the commitment line and the budget affectaion have
      # to change for the receiver envelop on N+1
      # Avant le report d'engagement
      # Si le statut de la ligne bugétaire n'est pas 'reporté pour engagement, et que l'année fiscale
      # de la date paramètre est supérieure à l'année fiscale de l'enveloppe, alors l'enveloppe de la
      # ligne d'engagement et pour la mise à jour du budget doit être l'enveloppe de reception sur l'exercice
      # fiscal suivant.
      TBENGCCE(INDENV)=[F:ENV]ENVRCD
      TBCMDCCE(INDENV)=[F:ENV]ENVRCD
      TBBUDCCE(INDENV)=[F:ENV]ENVRCD

      # Pour le cas CMD/REC TOT/FAR/PAS DE REPORT :
      # Le N° d'enveloppe annuelle dans la cmd et la reception doit être celui
      # de l'enveloppe de réception N+1 ou si la commande est soldée sur N

      # Reception totale/Total Receipt?
      If ENVDIE<>"" & (TOTRCP | !CMMLFT)
       # Commande
       Readlock [CCAL]CAL0="POP";0;ORDNUM;ORDLIN;ORDSEQ;"";1
       If !fstat
        INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
        If INDENV & [F:CCAL]CCE(INDENV-1)<>[F:ENV]ENVRCD
         [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
         Rewrite [CCAL]
         If fstat: GOK=0 : Call FSTA("CCAL") From GLOCK : Goto AB_TR : Endif
        Endif
       Endif
       # Historique commande
       Filter [CUOP] Where POHNUM=ORDNUM & POPLIN=ORDLIN & POPSEQ=ORDSEQ
       For [CUOP]POP0
        Readlock [CCAL]CAL0="UOP";0;ORDNUM;ORDLIN;0;num$([F:CUOP]LINREVNUM);1
        If !fstat
         INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
         If INDENV
          [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
          Rewrite [CCAL]
          If fstat: GOK=0 : Call FSTA("CCAL") From GLOCK : Goto AB_TR : Endif
         Endif
        Endif
       Next
       Filter [CUOP]
       # Ré-écriture des receptions sur la commande
       Filter [CPTD] Where POHNUM=ORDNUM & POPLIN=ORDLIN
       For [CPTD]PTD0
        Readlock [CCAL]CAL0="PTD";0;[F:CPTD]PTHNUM;[F:CPTD]PTDLIN;0;"";1
        If !fstat
         INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
         If INDENV
          [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
          Rewrite [CCAL]
          If fstat: GOK=0 : Call FSTA("CCAL") From GLOCK : Goto AB_TR : Endif
         Endif
        Endif
       Next
       Filter [CPTD]
      Endif :# Quantity - Total Receipt

      If SITUATION = "5;5" #extourne AAR
       # Ré-écriture des retours sur la commande
       Filter [CPND] Where POHNUM=ORDNUM & POPLIN=ORDLIN
       For [CPND]PND0
        Readlock [CCAL]CAL0="PND";0;[F:CPND]PNHNUM;[F:CPND]PNDLIN;0;"";1
        If !fstat
         INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
         If INDENV
          [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
          Rewrite [CCAL]
          If fstat: GOK=0 : Call FSTA("CCAL") From GLOCK : Goto AB_TR : Endif
         Endif
        Endif
       Next
       Filter [CPND]
      Endif

     Elsif !fstat & [F:BUD]STA=5

      #Cas de la FAR APRES report des engagements
      # If the status of the budget line of the Annual budget envelop on N
      # HAS been 'reported for commitment'.
      Read [ENV2]ENV0 = [F:ENV]ENVRCD
      If !fstat
       TBCMDCCE(INDENV)=[F:ENV2]ENV
       TBBUDCCE(INDENV)=[F:ENV2]ENV
       CMDDAT=[F:ENV2]REASTR
       Call GETPERCPY(SOCIETE,LEDTYPANAPPL,CMDDAT,CMDFIY,CMDPER) From CPTSUB
       BUDDAT=[F:ENV2]REASTR
      Endif
     Endif
  Endcase

  # In case of closing a purchase request or closing an order which has been reported to N+1
  # because the date of the purchase object is still in fiscalyear N, in order to do the
  # commitment and budget mouvement on the right fiscalyear, date of update must be on N.
  #---
  # En cas de solde d'une DA ou d'une CMD qui a été reporté sur N+1, puisque la date de l'objet d'achat
  # est encore sur N, la date de mise à jour de la ligne d'engagement et du budget doivent être changé.
  # Ou en cas d'annulation de solde d'une DA ou CMD reportée sur N+1
  If (MOTIF(1)=4 | MOTIF(1)=6 | MOTIF(1)=3) & FIYCUR<FIYENV:# Solde
   Local Date DATSTR,DATEND
   Call DATEXE(SOCIETE,LEDTYPANAPPL,FIYENV,DATSTR,DATEND) From CPTSUB
   CMDDAT=DATSTR
   Call GETPERCPY(SOCIETE,LEDTYPANAPPL,CMDDAT,CMDFIY,CMDPER) From CPTSUB
   BUDDAT=DATSTR
  Endif

  # Cas FAR avant report sur ENVA
  #L'extourne de la FAR à modifié l'enveloppe de la cmd avec l'env N+1
  # du coup  lorsqu'on fait le solde pour report on le fait sur N+1 au lieu de N
  If SITUATION="4;6" & FIYCUR<FIYENV
   TBCMDCCE(INDENV)=[F:ENV]ENVORG
   TBBUDCCE(INDENV)=[F:ENV]ENVORG
   CMDDAT=DAT
   Call GETPERCPY(SOCIETE,LEDTYPANAPPL,CMDDAT,CMDFIY,CMDPER) From CPTSUB
   BUDDAT=DAT
  Endif

  ##84195 dernier pb
  #US169 US168 US 169 US 168
  #280912 Création report
  If SITUATION="1;6" & FIYCUR>FIYENV
   TBENGCCE(INDENV)=[F:ENV]ENVRCD
   TBCMDCCE(INDENV)=[F:ENV]ENVRCD
   TBBUDCCE(INDENV)=[F:ENV]ENVRCD
  Endif

 Else
  ########################
  # Multi-annual envelop #
  ########################

  #Dans le Cas ENVP/CMD/REC Partielle/REPORT TOT (eng)/FAR
  # Aprés report des engagement, le désengagement dû à la constitution de la FAR
  # doit etre fait sur N+1 et non sur N
  Case SITUATION
   When "1;4","1;5" : #Création FAR / création AAR

    #Regarde la commande et sa date pour voir sur quelle ligne budgétaire on travail
    # et si cette ligne est en engagement reporté ou fermée, on cherche à imputer sur
    #la ligne du budget supérieur

    #TYPORG=> Type de document 1,2-> Cmd - 3-> DA
    If TYPORG=1 | TYPORG=2 :#Si commande
     If !clalev([F:CPOH]) : Local File PORDER [CPOH] : Endif
     Read [CPOH]POH0 = DOCUMENT(1) :# Numéro de pièce d'achat à l'origine
     If !fstat
      Call GETEXE(SOCIETE,LEDTYPANAPPL,[F:CPOH]ORDDAT,FIYORD) From CPTSUB
      #LEDTYP+BUD+CPY+FCY+FIY+VER+ACC+CCE1+CCE2+CCE3
      Raz [F:BUD]
      I = find(ENTDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
      If I : Assign "[F:BUD]CCE"+num$(I) With ENTITY : Endif
      I = find(ENVDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
      If I : Assign "[F:BUD]CCE"+num$(I) With ENVELOP : Endif
      If OTHDIE<>""
       I = find(OTHDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
       If I : Assign "[F:BUD]CCE"+num$(I) With CCE3 : Endif
      Endif
      [F:BUD]LEDTYP = LEDTYPANAPPL
      [F:BUD]BUD    = [F:ENV]BUD
      [F:BUD]CPY    = SOCIETE
      [F:BUD]FCY    = FCYBUD
      [F:BUD]FIY    = FIYORD
      [F:BUD]VER    = "1"
      [F:BUD]ACC    = TBENGACC(LEDTYPANA_TBENG)
      Read [BUD]BUD0=
      If !fstat
       If ([F:BUD]STA=5 | [F:BUD]STA=4) & !CMMLFT
        If !clalev([F:BUD2]) : Local File BUD [BUD2] : Endif
        Raz [F:BUD2]
        I = find(ENTDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
        If I : Assign "[F:BUD2]CCE"+num$(I) With ENTITY : Endif
        I = find(ENVDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
        If I : Assign "[F:BUD2]CCE"+num$(I) With ENVELOP : Endif
        If OTHDIE<>""
         I = find(OTHDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
         If I : Assign "[F:BUD2]CCE"+num$(I) With [L]CCE3 : Endif
        Endif
        [F:BUD2]LEDTYP = LEDTYPANAPPL
        [F:BUD2]BUD    = [F:ENV]BUD
        [F:BUD2]CPY    = SOCIETE
        [F:BUD2]FCY    = FCYBUD
        [F:BUD2]FIY    = FIYORD+1
        [F:BUD2]VER    = "1"
        [F:BUD2]ACC    = TBENGACC(LEDTYPANA_TBENG)
        Read [BUD2]BUD0=
        If fstat | [F:BUD2]STA<>3
         If GTRACE<>""
          # Aucune ligne budgétaire appropriée et approuvée dans l'enveloppe de reception XXXXX
          Call ECR_TRACE(mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYORD+1),1) From GESECRAN
         Else
          Call MESSAGE(mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYORD+1)) From GESECRAN
         Endif
         GOK=0 : Return
        Elsif !fstat
         Local Date DATSTR,DATEND
         Call DATEXE(SOCIETE,LEDTYPANAPPL,(FIYORD+1),DATSTR,DATEND) From CPTSUB
         CMDDAT=DATSTR
         Call GETPERCPY(SOCIETE,LEDTYPANAPPL,CMDDAT,CMDFIY,CMDPER) From CPTSUB
         BUDDAT=DATSTR
        Endif
       Endif :#fstat Read [BUD]
      Endif
     Endif
    Endif

  Endcase

  # Si l'on agit sur une DA ou une CMD reportée, que l'on fasse un solde ou une création,
  # on doit désengager sur l'exercice de reception
   Local Decimal PURFIY
   Local Integer PURTYP
   Local Char PURNUM(GLONVCR),PURPCETYP(GLONGTE)
   Local Integer PURLIN,ANALIN,PURSEQ,PURGRDACT,PURGRDPCE
   Case TYPORG
    When 3   : PURTYP = 1 :# DA
    When 2,1 : PURTYP = 2 :# CMD
   Endcase
   PURNUM = DOCUMENT(1)
   PURLIN = val(DOCUMENT(2))
   PURSEQ = val(DOCUMENT(3))
   PURGRDACT = MOTIF(1)
   PURGRDPCE = MOTIF(2)
   PURPCETYP = ""

   #82536 aprés la correction de SR, il se passait lors de la création du solde sur
   #N+1 ici que ne lisant pas de LB avec STA 4 ou 5, on gardait les valeurs
   #de PURRPT et [BUA] lut plus haut pour N, du coup on passait dans le if PURRPT
   #plus bas et on cherchait une ligne sur N+2.
   Raz PURRPT
   Raz [F:BUA]

   #Cmd ou DA reportées?
   Raz [F:BUD]
   I = find(ENTDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
   If I : Assign "[F:BUD]CCE"+num$(I) With ENTITY : Endif
   I = find(ENVDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
   If I : Assign "[F:BUD]CCE"+num$(I) With ENVELOP : Endif
   If OTHDIE<>""
    I = find(OTHDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
    If I : Assign "[F:BUD]CCE"+num$(I) With CCE3 : Endif
   Endif
   [F:BUD]LEDTYP = LEDTYPANAPPL
   [F:BUD]BUD    = [F:ENV]BUD
   [F:BUD]CPY    = SOCIETE
   [F:BUD]FCY    = FCYBUD
   [F:BUD]FIY    = FIYCUR
   [F:BUD]VER    = "1"
   [F:BUD]ACC    = TBENGACC(LEDTYPANA_TBENG)
   Read [BUD]BUD0=
   If !fstat
    Read [BUA]BUA0 = [L]PURTYP;[L]PURPCETYP;[L]PURNUM;[L]PURLIN;[L]PURSEQ;[L]ANALIN;FIYCUR
    If !fstat
     If [F:BUD]STA=5 | [F:BUD]STA=4
      Case [L]PURTYP
       When 1
        If [F:BUA]CMMPRP =0 : PURRPT=1 : Endif
       When 2
        If [F:BUA]CMM =0 : PURRPT=1 : Endif
      Endcase
     Endif
     If [F:BUA]POSTPONED=2 : PURRPT=1 : Endif
    Endif
   Endif


   If PURRPT :# Budget line reported
    # cas SOLDE DA ou CMD / ou cas  creation CMD sur DA reportée / Ou annulation de solde
    If MOTIF(1)=4 | MOTIF(1)=1 | MOTIF(1)=6 | MOTIF(1)=3

     # Verification qu'une ligne approuvée dans l'exercice de réception existe
     If !clalev([F:BUD2]) : Local File BUD [BUD2] : Endif
     [L]BUDCRI = "1=1"
     I = find(ENTDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
     If I : [L]BUDCRI += "& [F:BUD]CCE"+num$(I)+"='"+ENTITY+"'" : Endif
     I = find(ENVDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
     If I : [L]BUDCRI += "& [F:BUD]CCE"+num$(I)+"='"+ENVELOP+"'" : Endif
     If OTHDIE<>""
      I = find(OTHDIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
      If I : [L]BUDCRI += "& [F:BUD]CCE"+num$(I)+"='"+[L]CCE3+"'" : Endif
     Endif
     Filter [BUD2] Where LEDTYP=LEDTYPANAPPL & BUD=[F:ENV]BUD & CPY=SOCIETE & FCY=FCYBUD & FIY=(FIYCUR+1)
&    & VER="1" & ACC=TBENGACC(LEDTYPANA_TBENG) & evalue(BUDCRI)
&    & STA=3
     Read [BUD2]BUD0 First
     If fstat
      If GTRACE<>""
       # Aucune ligne budgétaire appropriée et approuvée dans l'enveloppe de reception XXXXX
       Call ECR_TRACE(mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYCUR+1),1) From GESECRAN
      Else
       Call MESSAGE(mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYCUR+1)) From GESECRAN
      Endif
      GOK=0 : Return
     Elsif !fstat
      Local Date DATSTR,DATEND
      Call DATEXE(SOCIETE,LEDTYPANAPPL,(FIYCUR+1),DATSTR,DATEND) From CPTSUB
      CMDDAT=DATSTR
      Call GETPERCPY(SOCIETE,LEDTYPANAPPL,CMDDAT,CMDFIY,CMDPER) From CPTSUB
      BUDDAT=DATSTR
     Endif
    Endif
   Endif

 Endif :#YEAFLG

Endif :#BUO
Return


#----------------------------------------------
# Maj/création piste d'achat
#----------------------------------------------
$MAJ_BUA
If !clalev([F:BUA]) : Local File BUDPURAUD [BUA] : Endif

#**************************************************************
# Variables utiles
Local Integer PURTYP
Local Char PURNUM(GLONVCR),CMMNUM(GLONVCR),PURPCETYP(GLONGTE),PIECEAUTO
Local Integer PURLIN,ANALIN,PURSEQ,PURGRDACT,PURGRDPCE

Case TYPORG
 When 3 :# DA
  PURTYP = 1
 When 2,1 :#CMD
  PURTYP = 2
Endcase

#Info pièce d'achat
PURNUM = DOCUMENT(1)
If PURNUM = "" : Return : Endif
If dim(DOCUMENT)>=2
 PURLIN = val(DOCUMENT(2))
Endif
If dim(DOCUMENT)>=3
 PURSEQ = val(DOCUMENT(3))
Endif

##84195
# US169 US168 US 169 US 168
# Modifié via 87711 suite à la correction des Achats 84939
# -> Cas des commande ouverte avec plusieurs Demande de livraison Ferme entrainant plusieurs
# engagement pour une même ligne de commande
# Du coup => Gestion de [BUA] pour un seul et même couple engagement/exercice
#On utilise le ANALIN déjà présent dans la table BUDPURAUD pour ne pas tout réécrire
If TYPORG=2 & dim(DOCUMENT)>=4 # commande ouverte
 [L]ANALIN = val(DOCUMENT(4))
Endif
#
#
CMMNUM = ENGAGE
PURGRDACT = MOTIF(1)
PURGRDPCE = MOTIF(2)
#
PURPCETYP = "" :#TYPPCE Variable vide car elle ne concerne que les factures
PIECEAUTO = PIECE
#*************************************************************
#*!
# 80562
If func AFNC.ACTIV("GDD") # Issue X3-48560 GDD ==> Operating budgets
 If SITUATION="2;2" & PURRPT & FIYCUR<PURRPTFIY
  EXERCICE = PURRPTFIY
 Endif
Endif
If [L]DEBUGTRACE : Call ECR_TRACE("Exercice MAJ BUA  : "-num$(EXERCICE) ,0) From  GESECRAN :Endif
#BUA0 Key ==> TYP+TYPPCE+NUM+LIN+SEQ+ANALIN+FIY
# Issue X3-48560 - 2017-07-27 by BEFOU :
# On charge la bonne ligne de BUA

  Local Integer BUAPOSTPONED
  Local Integer CUMULCMM
  Local Integer ENGREPORT # Engagement Reporté
  Local Decimal  CUMULCMMLED(0..10)
  For I=0 To len(mess(0,2644,1))-1
    [L]CUMULCMMLED(I)=0
  Next
  BUAPOSTPONED=2
  CUMULCMM=0
  ENGREPORT=0

  While fstat=0 and BUAPOSTPONED=2 # IF the ligne has been reported
    Readlock [BUA]BUA0 = [L]PURTYP;[L]PURPCETYP;[L]PURNUM;[L]PURLIN;[L]PURSEQ;[L]ANALIN;EXERCICE
    If fstat=0
      BUAPOSTPONED=[F:BUA]POSTPONED
      If BUAPOSTPONED=2
        If PURGRDACT=3
          # Delete of the Postponed Audit Lines
          If [L]DEBUGTRACE : Call ECR_TRACE("Suppression Ligne:"-num$(PURGRDACT),0) From  GESECRAN :Endif
          Delete [BUA]BUA0 Curr
          If fstat : GOK = 0 : Call FSTA("BUA") From GLOCK : Return : Endif
        Else
          CUMULCMM+=[F:BUA]CMM
          [F:BUA]CMM=0
          For I=0 To len(mess(0,2644,1))-1 # 2644 ==> Types de référentiels
            [L]CUMULCMMLED(I)+=[F:BUA]CMMLED(I)
            [F:BUA]CMMLED(I)=0
          Next
          Rewrite [BUA]
        Endif
        EXERCICE+=1 # We check the next exercice
        ENGREPORT=1
      Endif
    Else
      Break
    Endif
  Wend
# End issue X3-48560
 If fstat=1
  GOK = -1 : GLOCK = "$BUA"-[F:BUA]BUANUM : Return
 Elsif fstat=0
  # ! Mise à jour !
  If PURGRDACT=3
   # Cas de suppression
  # Issue X3-43823 - 2017-08-10 by BEFOU : Before WHEN We delete We don't feed CMDDAT !
   If ENGREPORT=1 # Only if the commitement has been POSTPONED
    Local Date DATSTR,DATEND
    Call DATEXE(SOCIETE,LEDTYPANAPPL,EXERCICE,DATSTR,DATEND) From CPTSUB
    Call GETPERSOC(SOCIETE,LEDTYPANAPPL,DATSTR,EXERCICE,PERIODE) From CPTSUB
    CMDDAT=DATSTR
   Endif
  # End issue X3-43823
   Delete [BUA]BUA0 Curr
   If fstat : GOK = 0 : Call FSTA("BUA") From GLOCK : Return : Endif
  Else

  #------------------------------------------------------------
  #  Pour les budgets analytiques (BUD="" n.b. BUD<>"" pour les BUO)
  #  06/07/11 Prise de main pour gestion de date analytique

  #Cas 8 Reprise sur un CMD N+1 d'un DA N reportée : DA déseng sur N+1
  #Cas 9 Reprise DA reportée sur N+1 sur CMD N : déseng DA sur N+1 et engagement CMD sur N
  #Cas trouvé : Modification d'une pièce d'achat reportée
  #Cas 18 Création de FAR aprés report des engagements
  #20/07/2011 : cas MCL
  #Solde de cmd reportée sur N+1, désengagement doit être sur N+1
  #Modification & FAR/AAR sur pièce d'achat Analytique & reportée
    If [F:BUA]BUD="" & ENGREPORT=1
&    & ((PURTYP=1 & PURGRDACT<>2)
&    | PURGRDACT=2
&    | (PURGRDACT=1 & find(PURGRDPCE,4,5))
&    | PURGRDACT=4) # Issue X3-48560 ==> [F:BUA]POSTPONED ==> ENGREPORT

   Local Date DATSTR,DATEND
   Local Integer NBPER
   #NBPER=0
   #EXERCICE+=1 # Issue X3-48560

   Call DATEXE(SOCIETE,LEDTYPANAPPL,EXERCICE,DATSTR,DATEND) From CPTSUB
   Call GETPERSOC(SOCIETE,LEDTYPANAPPL,DATSTR,EXERCICE,PERIODE) From CPTSUB
   CMDDAT=DATSTR
   Call GETPERCPY(SOCIETE,LEDTYPANAPPL,CMDDAT,CMDFIY,CMDPER) From CPTSUB
   BUDDAT=DATSTR
  Endif

  #------------------------------------------------------------

   # Autre action => donc maj
   Case TYP
    When 1 :# Pre-eng
     [F:BUA]CMMPRP    += SIGN*SENS*MONTANT_FINAL
    When 2 :# Eng
     [F:BUA]CMM    += SIGN*SENS*MONTANT_FINAL + CUMULCMM # Issue X3-48560 - 2017-08-02 by BEFOU : CUMULCMM
   Endcase

   #
   For I=0 To len(mess(0,2644,1))-1 # 2644 ==> Types de référentiels
    K=find(I+1,TBENGLEDTYP(1..NBTYP))
    If K & !find(TBENGLEDTYP(K),LSTNEWLEDTYP(1..NBTYP))
     [F:BUA]LEDTYP(I) = TBENGLEDTYP(K)
     [F:BUA]LED(I)    = TBENGLED(K)
     [F:BUA]CURLED(I) = TBENGCUR(K)
     [F:BUA]COA(I)    = TBENGCOA(K)
     [F:BUA]ACC(I)    = TBENGACC(K)
     Case TYP
      When 1 :# Pré-engagements
       [F:BUA]CMMPRPLED(I) += SIGN*SENS*TBENGAMTLED(K)
      When 2 :# Engagements
       [F:BUA]CMMLED(I) += SIGN*SENS*TBENGAMTLED(K)+[L]CUMULCMMLED(I) # Issue X348560 - 2017-08-02 by BEFOU
     Endcase
    Else
     [F:BUA]LEDTYP(I) = 0
    Endif
   Next
   #
   [F:BUA]QTY += SIGN*QUANTITE
   #
   For I=1 To min(dim([F:BUA]DIE),dim(TBDIE))
    Assign "[F:BUA]DIE("+num$(I-1)+")" With evalue("TBDIE("+num$(I)+")")
    Assign "[F:BUA]CCE("+num$(I-1)+")" With evalue("TBCCE("+num$(I)+")")
   Next
   #
   [F:BUA]BPR    = TIERS
   [F:BUA]GRDACT = PURGRDACT
   [F:BUA]GRDPCE = PURGRDPCE
   [F:BUA]UPDDAT = date$
   [F:BUA]UPDUSR = GUSER
   #
   #Si Motif 'Solde Report' => Pièce d'achat reportée
   If PURGRDACT=4 & PURGRDPCE=6
    [F:BUA]POSTPONED = 2
   Endif
   #
   Rewrite [BUA]
   If fstat
    GOK = 0 : Call FSTA("BUA") From GLOCK : Return
   Endif
   If GFONCTION="BUOCMMREP" | GFONCTION="CMMREP" & GTRACE<>""
    #Mise à jour piste d'audit : clé
    Call ECR_TRACE (mess(211,107,1)-":"-mess([L]PURTYP,2684,1)-"/"-[L]PURPCETYP-"/"-[L]PURNUM-"/"-num$([L]PURLIN)-"/"-num$([L]PURSEQ)-"/"-num$([L]ANALIN)-"/"-num$(EXERCICE),0) From GESECRAN
   Endif
  Endif
 Elsif fstat=5
  # ! Création de l'enregistrement !
  Raz [BUA]
  # Clé Primaire / TYP+TYPPCE+NUM+LIN+SEQ+ANALIN+FIY
  [F:BUA]BUANUM = uniqid([F:BUA])
  [F:BUA]TYPPCE = [L]PURPCETYP
  [F:BUA]TYP = [L]PURTYP
  [F:BUA]NUM = [L]PURNUM
  [F:BUA]LIN = [L]PURLIN
  [F:BUA]SEQ = [L]PURSEQ
  [F:BUA]ANALIN = [L]ANALIN
  #
  #Code budget uniquement pour les Budgets opérationnels
  If func AFNC.ACTIV("GDD")
   If OKBUO : [F:BUA]BUD = BUDCOD : Endif
  Endif
  #
  Case TYP
   When 1 :# Pré-engagements
    [F:BUA]CMMPRP = SIGN*SENS*MONTANT_FINAL
   When 2 :# Engagements
    [F:BUA]CMM    = SIGN*SENS*MONTANT_FINAL
  Endcase
  For I=0 To len(mess(0,2644,1))-1
   K=find(I+1,TBENGLEDTYP(1..NBTYP))
   If K & !find(TBENGLEDTYP(K),LSTNEWLEDTYP(1..NBTYP))
    [F:BUA]LEDTYP(I) = TBENGLEDTYP(K)
    [F:BUA]LED(I)    = TBENGLED(K)
    [F:BUA]CURLED(I) = TBENGCUR(K)
    [F:BUA]COA(I)    = TBENGCOA(K)
    [F:BUA]ACC(I)    = TBENGACC(K)
    Case TYP
     When 1 :# Pré-engagements
      [F:BUA]CMMPRPLED(I) = SIGN*SENS*TBENGAMTLED(K)
     When 2 :# Engagements
      [F:BUA]CMMLED(I)    = SIGN*SENS*TBENGAMTLED(K)
    Endcase
   Else
    [F:BUA]LEDTYP(I) = 0
   Endif
  Next
  #
  For I=1 To min(dim([F:BUA]DIE),dim(TBDIE))
   Assign "[F:BUA]DIE("+num$(I-1)+")" With evalue("TBDIE("+num$(I)+")")
   Assign "[F:BUA]CCE("+num$(I-1)+")" With evalue("TBCCE("+num$(I)+")")
  Next
  If func AFNC.ACTIV("GDD")
   If BUO
    If YEAFLG=1 :#Env annuelle
     Local Decimal FIYENV
     If [F:ENV]ENV<>ENVELOP
      Read [ENV]ENV0 = ENVELOP
     Endif
     Call GETEXE(SOCIETE,LEDTYPANAPPL,[F:ENV]REASTR,FIYENV) From CPTSUB
     If EXERCICE>FIYENV
      Assign "[F:BUA]CCE("+num$(AXENV-1)+")" With [F:ENV]ENVRCD
     Endif
    Endif
   Endif
  Endif
  #
  [F:BUA]CUR = CUR
  [F:BUA]DAT = DAT
  [F:BUA]CPY = SOCIETE
  [F:BUA]FCY = SITE
  [F:BUA]FIY = EXERCICE
  [F:BUA]BPR = TIERS
  #
  [F:BUA]CMMNUM = CMMNUM
  [F:BUA]CODGAU = PIECEAUTO
  [F:BUA]QTY    = QUANTITE
  [F:BUA]CREDAT = date$
  [F:BUA]CREUSR = GUSER
  [F:BUA]GRDACT = PURGRDACT
  [F:BUA]GRDPCE = PURGRDPCE
  #
  Write [BUA]
  If fstat
   GOK = 0 : Call FSTA("BUA") From GLOCK : Return
  Endif
  If GFONCTION="BUOCMMREP" | GFONCTION="CMMREP" & GTRACE<>""
   # Création piste d'audit : clé
   Call ECR_TRACE (mess(212,107,1)-":"-mess([L]PURTYP,2684,1)-"/"-[L]PURPCETYP-"/"-[L]PURNUM-"/"-num$([L]PURLIN)-"/"-num$([L]PURSEQ)-"/"-num$([L]ANALIN)-"/"-num$(EXERCICE),0) From GESECRAN
  Endif
 Endif
Return

$TRC
If adxmac(-2)="*******.sagefr.adinternal.com" #or adxmac(-2)="172.17.0.8"
  Local Char TRC1(250)
  [L]DEBUGTRACE = [V]CST_ATRUE


  TRC1 ="(1)=> [TYPORG]=["+num$(TYPORG)+"]"
  TRC1 +=chr$(10)+"(2)=> [DOCUMENT(1)]=["+DOCUMENT(1)+"]"
  TRC1 +=chr$(10)+"(3)=> [DOCUMENT(2)]=["+DOCUMENT(2)+"]"
  TRC1 +=chr$(10)+"(4)=> [DOCUMENT(3)]=["+DOCUMENT(3)+"]"
  If dim(DOCUMENT)>=4
    TRC1 +=chr$(10)+"(5)=> [DOCUMENT(4)]=["+DOCUMENT(4)+"]"
  Endif
  TRC1 +=chr$(10)+"(6)=> [ENGAGE]=["+ENGAGE+"]"
  TRC1 +=chr$(10)+"(7)=> [MOTIF(1)]=["+num$(MOTIF(1))+"-"+mess(MOTIF(1),2683,1)+"]"
  TRC1 +=chr$(10)+"(8)=> [MOTIF(2)]=["+num$(MOTIF(2))+"-"+mess(MOTIF(2),2684,1)+"]"
  TRC1 +=chr$(10)+"(9)=> [TYPPCE]=["+TYPPCE+"]"
  TRC1 +=chr$(10)+"(10)=> [PIECE]=["+PIECE+"]"

  #Infbox TRC1
Endif
Return

