#<AdxTL>@(#)10.0.0.0 $Revision$
######################################################################################
## Xtend:  Gestion des Entités
#          Aide au pré-remplissage à partir d'une interface
#  Version 0001
######################################################################################

$ACTION
Case ACTION
    When "INIT"     : Gosub INIT
    When "EXEC"     : Gosub EXEC
    When "SORTIE"   : Gosub SORTIE
    When "AVANT_OK" : Gosub AVANT_OK
    # Saisie fenêtre
      When "DEBUT"  : Gosub DEBUT
Endcase
Return

$INIT
If clalev([F:AYI])=0 : Local File AYTINT  [AYI] : Endif
Local Integer WI, WFLG
Local Mask AYEINTSEL [DIA]
Return

$DEBUT
[M:DIA]FCYCOD=PARAM(1)
[M:DIA]INTCOD=PARAM(2)
Call AM_INTCOD([M:DIA]INTCOD)
Return

$EXEC
If GSTATUT<>GSTAOK : Return : Endif        # A gérer soi-même car fenêtre
Gosub SETINTCOD

If WFLG : mkstat=4 : Endif      # Pour provoquer enregistrer sur l'appelant
Return

$SORTIE
Close Local Mask [DIA]
Return

$AVANT_OK
#Ctl - Utile car l'utilisateur peut sortir du mode saisie avec une erreur et faire Ok
For WI =0 To [M:DIA]NBZONE-1
    If [M:DIA]WSEL(WI)=2 and[M:DIA]FIECOD(WI)=""
        GMESSAGE=mess(10,123,1): GERR=1 : FIN=0
        zonsui="[M]FIECOD("+num$(WI)+")"  : Break 
    Endif
Next
Return

$SETINTCOD
Raz WFLG
For WI =0 To [M:DIA]NBZONE-1
    If [M:DIA]WSEL(WI)=2
       [M:AYE1]FIECOD10([M:AYE1]NUM10)    =[M:DIA]FIECOD(WI)
       WFLG=1
       If [M:DIA]INTCOD=[M:AYE1]INTCOD
           [M:AYE1]DSCCOD10([M:AYE1]NUM10)    =[M:DIA]DSCCOD(WI)
           [M:AYE1]DSCGRP10([M:AYE1]NUM10)    =[M:DIA]DSCGRP(WI)
       Endif
       [M:AYE1]NUM10+=1
    Endif
Next
Affzo [M:AYE1]15
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran AYEINTSEL) 03/08/2007 10:27:21 (JPJ)
######################################################################################
Subprog AM_INTCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif

Read [F:AYI]AYI0=[M:DIA]FCYCOD;VALEUR
If fstat : End : Endif
[M:DIA]WEBSRCCOD=[F:AYI]WEBSRCCOD : Affzo [M:DIA]WEBSRCCOD

Gosub GETWS_VAR From SUBAYIACT     # Variables pour GETWS_INF
WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD 
Gosub GETWS_INF From SUBAYIACT :  If WS_RET : GERR=1 : GMESSAGE=WS_MES : End: Endif

Effzo [DIA]10
Case [F:AYI]TYP
When 1,2,4     # Accès sous-programme généré accès sur table 
               # Accès sous-programme utilisateur
    For WI=0 To RUBNBR-1
        # If left$(RUBCOD(WI),2)<>"AX"    # Ne pas afficher les rubriques techniques
        If !find(RUBGRP(WI),"AX_PAR","AX_WHR","AX_ORD")
          # Sauter celles déjà existantes
          If !find(RUBCOD(WI),[M:AYE1]DSCCOD10)    
            [M:DIA]DSCCOD([M:DIA]NBZONE)    = RUBCOD(WI)
            [M:DIA]DSCGRP([M:DIA]NBZONE)    = RUBGRP(WI)
            Call TEXTE(RUBINTIT(WI),[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
            [M:DIA]NBZONE+=1
          Endif    
        Endif    
    Next 
#
When 20,3,21      # Action sous-programme utilisateur
                  # Accès liste gauche
                  # Action objet
        For WI=0 To RUBNBR-1
         # Sauter celles déjà existantes 
         If !find(RUBCOD(WI),[M:AYE1]DSCCOD10)    
            [M:DIA]DSCCOD([M:DIA]NBZONE)    = RUBCOD(WI)
            Call TEXTE(RUBINTIT(WI),[M:DIA]INTITCOURT([M:DIA]NBZONE)) From OBJDIV
            [M:DIA]DSCGRP([M:DIA]NBZONE)    = RUBGRP(WI)
            [M:DIA]NBZONE+=1
         Endif
        Next 
#
When Default
    GERR=1 : GMESSAGE="Xtend - Interface type unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)
    Return
Endcase
If [M:DIA]NBZONE=0
    GERR=2
    GMESSAGE=mess(91,7900,1)
Endif
Affzo [DIA]10
End

Subprog B1_NBZONE
Local Integer FLGSEL : FLGSEL=2
Gosub SEL_NBZONE
End

Subprog B2_NBZONE
Local Integer FLGSEL : FLGSEL=1
Gosub SEL_NBZONE
End

$SEL_NBZONE
Local Integer WI
Local Integer  SAVNOL
Local Shortint FLG, WMKSTAT
SAVNOL=nolign
Local Integer WNEW
For nolign=SAVNOL To [M:DIA]NBZONE
     WNEW=1
     [M:DIA]WSEL(nolign-1)=FLGSEL  
     FIECOD(nolign-1)=""
     If FLGSEL=2
        Call UNICITE(DSCCOD(nolign-1),[M:DIA]FIECOD(0..[M:DIA]NBZONE-1)) From OBJDIV
        If mkstat
            Raz GMESSAGE,GERR,mkstat
        Else
            If !find(DSCCOD(nolign-1),[M:AYE1]FIECOD10)
                Call CONTROLE("AYF","",DSCCOD(nolign-1),[M:DIA]FCYCOD,WMKSTAT) From CONTOBJ
                If WMKSTAT
                    Raz GMESSAGE,GERR
                Else
                    FIECOD(nolign-1)=DSCCOD(nolign-1)
                Endif
            Endif    
        Endif
     Endif
Next
nolign=SAVNOL

If WNEW
 Affzo [M:DIA]10
Endif
Return

Subprog APRES_NBZONE
End

Subprog AM_WSEL(VALEUR)
Variable Integer VALEUR
Local Shortint WMKSTAT

If VALEUR = 2
    Call CONTROLE("AYF","",DSCCOD(nolign-1),[M:DIA]FCYCOD,WMKSTAT) From CONTOBJ
    If WMKSTAT
        Raz GMESSAGE,GERR
    Else
      FIECOD(nolign-1)=DSCCOD(nolign-1)
    Endif
    zonsui="FIECOD("+num$(nolign-1)+")"
Else
    FIECOD(nolign-1)=""
Endif
End


Subprog C_FIECOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:DIA]FIECOD(0..[M:DIA]NBZONE-1)) From OBJDIV
If !mkstat and find(VALEUR,[M:AYE1]FIECOD10)    
    mkstat=2 : GMESSAGE=mess(170,7900,1)
Endif
End

