#<AdxTL>@(#)0.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# Modification des lots :                                                   #
# - changement de numéro de lot                                             #
# - mélange de lot                                                          #
# - division de lot                                                         #
#---------------------------------------------------------------------------#
# Gestion du masque SLM1
$ACTION
Case ACTION
    When "DEFTRANS"     : Gosub DEFTRANS     From SUBSLMA
    When "VARIANTE"     : Gosub VARIANTE     From SUBSLMA
    When "SETTRANS"     : Gosub SETTRANS     From SUBSLMA
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBSLMA
    When "OUVRE"        : Gosub OUVRE        From SUBSLMA
    When "FILTRE"       : Gosub FILTRE       From SUBSLMA
    When "LIENS"        : Gosub LIENS        From SUBSLMA
    When "DEFLIG"       : Gosub DEFLIG       From SUBSLMA
    When "SETBOUT"      : Gosub SETBOUT      From SUBSLMA
    When "EXEBOUT"      : Gosub EXEBOUT      From SUBSLMA
    When "RAZCRE"       : Gosub RAZCRE       From SUBSLMA
    When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBSLMA
    When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBSLMA
    When "INICRE"       : Gosub INICRE       From SUBSLMA
    When "CREATION"     : Gosub CREATION     From SUBSLMA
    When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBSLMA
    When "VALLIG"       : Gosub VALLIG       From SUBSLMA
    When "APRES_CRE"    : Gosub APRES_CRE    From SUBSLMA
    When "MODIF"        : Gosub MODIF        From SUBSLMA
    When "APRES_MOD"    : Gosub APRES_MOD    From SUBSLMA
    When "ANNULE"       : Gosub ANNULE       From SUBSLMA
    When "ABANDON"      : Gosub ABANDON      From SUBSLMA
#    When "FIN"          : Gosub ABANDON      From SUBSLMA                  # hcb 110327
    When "FERME"        : Gosub FERME        From SUBSLMA
    When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBSLMA
    When "TIROIR"       : Gosub TIROIR       From SUBSLMP
    When "REMP_DERLU"   : Gosub REMP_DERLU   From SUBSLMP
    When "FILGAUCHE"    : Gosub FILGAUCHE    From SUBSLMP
    When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE From SUBSLMP
    When "PICKE"        : Gosub PICKE        From SUBSLMP
    When "DEPICK"       : Gosub DEPICK       From SUBSLMP
    When "FIN_PICK"     : Gosub FIN_PICK     From SUBSLMP
Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return


##########################################################################
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:SLM1]VCRTYP = 35
End

##########################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
#-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
If VALEUR = "" &  GSTKCPT(5) = "" : mkstat = 2 : End : Endif

#-- Si on est en création , n° saisi vide et un compteur est présent on sort
If GREP = "C" & VALEUR = "" &  GSTKCPT(5) <> "" : End : Endif

#-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
If [M:SLM1]VCRNUM = "" & GREP <> "C"
    Look [F:SLH]SLH0=VALEUR
    If fstat
        GMESSAGE = mess(178,199,1) : mkstat = 2 : End
    Endif
Endif

If VALEUR <> "" & GSTKCPTMAN(5) <> 2
    Look [F:SLH]SLH0=VALEUR
    If fstat : Raz VALEUR : End : Endif
Endif
End

##########################################################################
Subprog IB_NBLIG
#                                                           # hcb 110327 deb
# Btn 1 = saisie serie globales
# No séries concernés
GBOUT1 = mess(655,199,1)

# pas de saisie des series concernés si :
# saisie détail impossible
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
If [F:ITM]SERMGTCOD <> 4 | [M:SLM1]WSTOCOU (nolign-1)= 0 | [M:SLM1]QTYSTU (nolign-1)= 0
   Raz GBOUT1
Endif

#                                                           # hcb 110327 end

End

##########################################################################
Subprog C_NBLIG
Local Integer PRET                                                                 # hcb 110327
#--- Bug 62346
#If find(status,65,75) & (GREP <> "C" | [M:SLM1]NBLIG=0) : mkstat = 2 : Endif        # 10.04
If find(status,65,68,75,83) & (GREP<>"C" | [M:SLM1]NBLIG=0)
   mkstat = 2
Endif
Local Integer WTRBEGIN
#--- Maj des cumuls quantité en cours de traitement
Case status
  When 65     : If [M:SLM1]CREFLG(nolign-1)=0
                  If adxlog<>1
                    Trbegin [STO]
                    WTRBEGIN=1
                  Endif
                  Readlock [STO]STO0=[M:SLM1]STOFCY;[M:SLM1]WSTOCOU(nolign-1)
                  If !fstat
                    [F:STO]CUMWIPQTY = max(0,[F:STO]CUMWIPQTY-[M:SLM1]QTYSTU(nolign-1))
                    [F:STO]CUMWIPQTA = max(0,[F:STO]CUMWIPQTA-([M:SLM1]QTYSTU(nolign-1)*[M:SLM1]POT/100))
                    Call DEL_STOWIPW([F:STO]STOCOU,[M:SLM1]QTYSTU(nolign-1)) From STKLIB
                    Rewrite [STO]
                    If fstat
                      Call FSTA("STO") From GLOCK
                      mkstat=2
#                                                                                          # hcb 110327 deb
                     Else
                        If [F:ITM]SERMGTCOD = 4 & [M:SLM1]SERNUM(nolign-1) <> ""
                           Call DEL_STOSERW([F:ITM]ITMREF,[M:SLM1]SERNUM(nolign-1),[M:SLM1]QTYSTU(nolign-1),PRET) From STKLIB
                        Endif
                        If PRET <> 0
                           mkstat=2
                        Endif
#                                                                                          # hcb 110327 end
                    Endif
                  Else
                    mkstat=2
                  Endif
                  If WTRBEGIN=1
                    If mkstat=2 : Rollback : Else : Commit : Endif
                  Endif
                Endif
  When 68, 83 : If adxlog<>1
                  Trbegin [STO]
                  WTRBEGIN=1
                Endif
                For I=nolign-1 To nolign1-1
                  If [M:SLM1]CREFLG(I)=0
                    Readlock [STO]STO0=[M:SLM1]STOFCY;[M:SLM1]WSTOCOU(I)
                    If !fstat
                      [F:STO]CUMWIPQTY = max(0,[F:STO]CUMWIPQTY-[M:SLM1]QTYSTU(I))
                      [F:STO]CUMWIPQTA = max(0,[F:STO]CUMWIPQTA-([M:SLM1]QTYSTU(I)*[M:SLM1]POT/100))
                      Call DEL_STOWIPW([F:STO]STOCOU,[M:SLM1]QTYSTU(I)) From STKLIB
                      Rewrite [STO]
                      If fstat
                        Call FSTA("STO") From GLOCK
                        mkstat=2 : Break
                      Endif
#                                                                                          # hcb 110327 deb
                        If [F:ITM]SERMGTCOD = 4 & [M:SLM1]SERNUM(I) <> ""
                           Call DEL_STOSERW([F:ITM]ITMREF,[M:SLM1]SERNUM(I),[M:SLM1]QTYSTU(I),PRET) From STKLIB
                        Endif
                        If PRET <> 0
                           mkstat=2
                           Break
                        Endif
#                                                                                          # hcb 110327 end
                    Else
                      mkstat=2 : Break
                    Endif
                  Else
                    mkstat=2 : Break
                  Endif
                Next I
                If WTRBEGIN=1
                  If mkstat=2 : Rollback : Else : Commit : Endif
                Endif
Endcase
Raz WTRBEGIN
#--- Fin Bug 62346
End

##########################################################################
Subprog AVANT_NBLIG
End

##########################################################################
Subprog C_WSTOCOU(VALEUR)
Variable Decimal VALEUR
End

##########################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
# article doit être géré avec lot
If !find([F:ITM]LOTMGTCOD,2,3,4) : mkstat = 2 : GMESSAGE = mess(480,199,1) : Endif
End

##########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer LRET

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSLMNUM                   # hcb 50197
   Read [SRT]SRT0=4;GSLMNUM : If fstat Raz [F:SRT] : Endif
Endif

Call LECITM([M:SLM1]STOFCY,VALEUR,"",3,"",LRET) From STKLIB
If LRET : mkstat = 2 : End : Endif

If [F:ITM]LOTCOU <> "" : [M:SLM1]GESLOTD = "C" : Endif

Raz [M:SLM1]LOT
If dim([M:SLM1]SLO) > 0      : Raz [M:SLM1]SLO     : Endif
If [F:SRT]LOTCOD = 1         : Raz [M:SLM1]LOTDES  : Endif
If dim([M:SLM1]SLODES) > 0   : Raz [M:SLM1]SLODES  : Endif
Effzo [M:SLM1]20

[M:SLM1]SLOMOD = 1
If dim([M:SLM1]SLO) > 0
    If [F:ITM]LOTMGTCOD <> 4
        Grizo [M:SLM1]SLO
        Grizo [M:SLM1]SLODES
    Else
        Actzo [M:SLM1]SLO
        Actzo [M:SLM1]SLODES
        [M:SLM1]SLOMOD = 2
    Endif
Endif

Affzo [M:SLM1]LOT
If dim([M:SLM1]SLO) > 0     : Affzo [M:SLM1]SLO     : Endif
Affzo [M:SLM1]LOTDES
If dim([M:SLM1]SLODES)  > 0 : Affzo [M:SLM1]SLODES  : Endif

Raz [M:SLM1]WFEALOTLEV                                                   # hcb unicite
If [F:ITM]LOTMGTCOD=4                                                    # hcb unicite
   [M:SLM1]WFEALOTLEV = mess(90,187,1) + " : " + mess(GFEALOTLEV,2773,1) # hcb unicite
Endif                                                                    # hcb unicite


#                                                           # Hcb 71276 deb
If dim([M:SLM1]ECCVALMAJ)>0
   Local Char WINVECC
   Case [F:ITM]ECCSTO
        When 0,1
           WINVECC="-K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMAJ  With WINVECC
           Chgfmt [M:SLM1]ECCVALMIN  With WINVECC
        When 2
           WINVECC="-K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMIN  With WINVECC
           WINVECC="K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMAJ  With WINVECC
           Raz  [M:SLM1]ECCVALMAJ
           Diszo  [M:SLM1]ECCVALMAJ
           Affzo  [M:SLM1]ECCVALMAJ
         When 3
           WINVECC="K:"+num$(GLONECS)+"X"
           Chgfmt [M:SLM1]ECCVALMAJ  With WINVECC
           Chgfmt [M:SLM1]ECCVALMIN  With WINVECC
           Raz  [M:SLM1]ECCVALMAJ
           Diszo  [M:SLM1]ECCVALMAJ
           Affzo  [M:SLM1]ECCVALMAJ
           Raz  [M:SLM1]ECCVALMIN
           Diszo  [M:SLM1]ECCVALMIN
           Affzo  [M:SLM1]ECCVALMIN

        When Default
   Endcase
Endif
#                                                           # Hcb 71276 fin
Affzo [M:SLM1]20
End

##########################################################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
[M:SLM1]LOT = VALEUR

#                                                  # hcb 71276 deb
If dim([M:SLM1]ECCVALMAJ)>0 & [F:ITM]ECCSTO > 1
   Filter [STL] Where ITMREF = [M:SLM1]ITMREF   &  LOT = VALEUR
      For [STL]
       [M:SLM1]ECCVALMAJ = [F:STL]ECCVALMAJ
       [M:SLM1]ECCVALMIN = [F:STL]ECCVALMIN
       Affzo [M:SLM1]ECCVALMAJ
       Affzo [M:SLM1]ECCVALMIN
   Next
   Filter [STL]
Endif
#                                                  # hcb 71276 fin

End

##########################################################################
Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
[M:SLM1]SLO = VALEUR
End


##########################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
Local    Integer WIND : WIND = 0
Local    Integer WLINNBR : WLINNBR = 0
Local    Char    WDUMMY  : WDUMMY = ""

If VALEUR = "" & [F:ITM]LOTMGTCOD <> 2    # 55612
   mkstat = 2
   End
Endif

#--- Issue 100805
#If VALEUR = [M:SLM1]LOT : End : Endif
If VALEUR = [M:SLM1]LOT & VALEUR<>"" : End : Endif
#---

If [F:ITM]LOTMGTCOD <> 4
    Read [SLF]SLF0=[M:SLM1]ITMREF;VALEUR;WDUMMY;[M:SLM1]STOFCY
    Read [STL]STL0=[M:SLM1]ITMREF;VALEUR;WDUMMY
    If fstat : mkstat = 2 : GMESSAGE = mess(123,199,1) : End : Endif
    [M:SLM1]POT = [F:STL]POT
    # déverrouillage lot
    If GREP = "C" & [M:SLM1]LOT <> "" : Gosub DEVERROU From SUBSLMB : Endif
    # vérification stock

    Call CHECK_LOT_STA([M:SLM1]AAASTA, [M:SLM1]QQQSTA, [M:SLM1]RRRSTA, WIND) From SUBSLMB
    If WIND : Goto NXT_C_LOT : Endif

    For [F:STO]STO3 Where STOFCY = [M:SLM1]STOFCY &
&                         ITMREF = [M:SLM1]ITMREF &
&                         LOT    = VALEUR
        If [F:STO]CUMALLQTY <> 0  : WIND = 1 : Break : Endif
        If [F:STO]QLYCTLDEM <> "" : WIND = 2 : Break : Endif
        If [F:STO]CUMWIPQTY <> 0  : WIND = 3 : Break : Endif
        If WLINNBR < 9999 : WLINNBR += 1 : Endif
    Next
$NXT_C_LOT
    If !WIND
        [M:SLM1]WLINNBR = WLINNBR
        # verrouillage lot
        If GREP = "C"
            [M:SLM1]LOT = VALEUR
            Gosub VERROU From SUBSLMB
            If mkstat : End : Endif
        Endif
        If [F:SRT]LOTCOD = 2
            [M:SLM1]LOT = VALEUR
            Gosub MOD_QUEST_NEW
        Endif
    Else
        mkstat = 2
        If WIND <> 4
            GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
            GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
            If [F:ITF]LOCMGTCOD=2
               GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
            Endif
        Else
            GMESSAGE=mess(43,197,1)-":"-VALEUR
        Endif
        Case WIND
            When 1:    GMESSAGE+="\"+mess(482,199,1)
            When 2:    GMESSAGE+="\"+mess(460,199,1)
            When 3:    GMESSAGE+="\"+mess(488,199,1)
            When 4:    GMESSAGE+="\"+mess(500,199,1)
        Endcase
        End
    Endif
Else
    If dim([M:SLM1]SLO) > 0
        If GREP = "C" & [M:SLM1]SLO <> "" : Gosub DEVERROU From SUBSLMB : Endif
    Endif
Endif
End


##########################################################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
Local    Integer WIND : WIND = 0
Local    Integer WLINNBR : WLINNBR = 0
# déverrouillage
If GREP = "C" & [F:ITM]LOTMGTCOD = 4 & [M:SLM1]SLO <> "" : Gosub DEVERROU From SUBSLMB : Endif

Read [SLF]SLF0=[M:SLM1]ITMREF;[M:SLM1]LOT;VALEUR;[M:SLM1]STOFCY
Read [STL]STL0=[M:SLM1]ITMREF;[M:SLM1]LOT;VALEUR
If fstat : mkstat = 2 : GMESSAGE = mess(123,199,1) : End : Endif
[M:SLM1]POT = [F:STL]POT

Call CHECK_LOT_STA([M:SLM1]AAASTA, [M:SLM1]QQQSTA, [M:SLM1]RRRSTA, WIND) From SUBSLMB
If WIND : Goto NXT_C_SLO : Endif

For [F:STO]STO3 Where STOFCY = [M:SLM1]STOFCY &
&                     ITMREF = [M:SLM1]ITMREF &
&                     LOT    = [M:SLM1]LOT    &
&                     SLO    = VALEUR
    If [F:STO]CUMALLQTY <> 0  : WIND = 1 : Break : Endif
    If [F:STO]QLYCTLDEM <> "" : WIND = 2 : Break : Endif
    If [F:STO]CUMWIPQTY <> 0  : WIND = 3 : Break : Endif
    If WLINNBR < 999 : WLINNBR += 1 : Endif
Next
$NXT_C_SLO
If !WIND
    [M:SLM1]WLINNBR = WLINNBR
    # verrouillage lot
    If GREP = "C"
        [M:SLM1]SLO = VALEUR
        Gosub VERROU From SUBSLMB
        If mkstat : End : Endif
    Endif

    If [F:SRT]LOTCOD = 2
        [M:SLM1]SLO = VALEUR
        Gosub MOD_QUEST_NEW
        If [F:SRT]SLOCOD = 2 & [F:ITM]LOTMGTCOD = 4 : [M:SLM1]SLODES = VALEUR : Endif
    Endif
    End
Else
    mkstat = 2
    If WIND <> 4
        GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
        GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
        GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
        If [F:ITF]LOCMGTCOD=2
            GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
        Endif
    Else
       GMESSAGE=mess(43,197,1)-":"-[M:SLM1]LOT
       GMESSAGE-=mess(456,197,1)-":"-VALEUR
    Endif
    Case WIND
        When 1:    GMESSAGE+="\"+mess(482,199,1)
        When 2:    GMESSAGE+="\"+mess(460,199,1)
        When 3:    GMESSAGE+="\"+mess(488,199,1)
        When 4:    GMESSAGE+="\"+mess(500,199,1)
    Endcase
Endif
End

##########################################################################
Subprog C_LOTDES(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
Local    Integer WIND : WIND = 0
Local    Char    WDUMMY  : WDUMMY = ""

If [M:SLM1]SLOMOD = 2 : End : Endif
If [F:ITM]LOTMGTCOD <> 4
    [M:SLM1]POTDES = [M:SLM1]POT
    If VALEUR = ""                                       : mkstat = 2 : End : Endif
    If VALEUR = [M:SLM1]LOT : GMESSAGE = mess(474,199,1) : mkstat = 2 : End : Endif
    If VALEUR = [M:SLM1]LOTDES : End : Endif
    # vérifier existence du lot saisi
    Read [SLF]SLF0=[M:SLM1]ITMREF;VALEUR;WDUMMY;[M:SLM1]STOFCY
    Read [STL]STL0=[M:SLM1]ITMREF;VALEUR;WDUMMY
    If !fstat
      Gosub MOD_QUEST                             # hcb 71276

       [M:SLM1]POTDES = [F:STL]POT
       If [F:ITF]STOMGTCOD = 3 &  [M:SLM1]POTDES <>[M:SLM1]POT
          mkstat = 2
          GMESSAGE = mess(502,199,1)
          End
       Endif
#                                                  # hcb 71276 deb
      If dim([M:SLM1]ECCVALMAJ)>0 & [F:ITM]ECCSTO > 1
         If [F:STL]ECCVALMAJ <> [M:SLM1]ECCVALMAJ
             mkstat = 2
             GMESSAGE = mess(436,184,1)-":"-[F:STL]ECCVALMAJ
             End
          Endif
          If [F:ITM]ECCSTO = 3 & [F:STL]ECCVALMIN <> [M:SLM1]ECCVALMIN
             mkstat = 2
             GMESSAGE = mess(437,184,1)-":"-[F:STL]ECCVALMIN
             End
          Endif
      Endif
#                                                  # hcb 71276 fin

       Call CHECK_LOT_STA([M:SLM1]AAASTA, [M:SLM1]QQQSTA, [M:SLM1]RRRSTA, WIND) From SUBSLMB
       If WIND : Goto NXT_C_LOTDES : Endif
    Endif
#   Gosub MOD_QUEST                                # hcb 71276
    GRAFFRAICHISLM = 1  # hcb 57578
    WIND = func SUBSLMB.CHECK_LOT([M:SLM1]ITMREF,VALEUR,WDUMMY)
    If WIND : Goto NXT_C_LOTDES : Endif
    End

    $NXT_C_LOTDES
    Case WIND
        When 4: mkstat = 2
                GMESSAGE=mess(43,197,1)-":"-VALEUR
                GMESSAGE+="\"+mess(500,199,1)
        When 5: Filter [SLF] Where ITMREF=[M:SLM1]ITMREF
&                                & LOT=VALEUR
&                                & SLO=WDUMMY
&                                & STOFCY<>[M:SLM1]STOFCY
                Read [F:SLF] First
                Filter [SLF]
                If !fstat
                   GMESSAGE=mess(206,184,1)-[F:SLF]STOFCY
                Endif
        When 6: Local Integer WOK : WOK=1
                Call AVERTIR (mess(389,184,1), WOK)From GESECRAN
                If WOK=1 mkstat=2 Endif
        When 7: Local Integer WOK : WOK=1
                Call AVERTIR (mess(390,184,1), WOK)From GESECRAN
                If WOK=1 mkstat=2 Endif
    Endcase
Endif
End

##########################################################################
Subprog C_SLODES(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
Local    Integer WIND : WIND = 0

If VALEUR = ""
   mkstat = 2 : End
Endif
If [M:SLM1]LOTDES=[M:SLM1]LOT & VALEUR=[M:SLM1]SLO
   GMESSAGE = mess(474,199,1) : mkstat = 2 : End
Endif
# vérifier existence du lot saisi
[M:SLM1]POTDES = [M:SLM1]POT
Read [SLF]SLF0=[M:SLM1]ITMREF;[M:SLM1]LOTDES;VALEUR;[M:SLM1]STOFCY
Read [STL]STL0=[M:SLM1]ITMREF;[M:SLM1]LOTDES;VALEUR
If !fstat
   [M:SLM1]POTDES = [F:STL]POT
   If [F:ITF]STOMGTCOD = 3 &  [M:SLM1]POTDES <>[M:SLM1]POT
      mkstat = 2
      GMESSAGE = mess(502,199,1)
      End
   Endif
#                                                  # hcb 71276 deb
      If dim([M:SLM1]ECCVALMAJ)>0 & [F:ITM]ECCSTO > 1
         If [F:STL]ECCVALMAJ <> [M:SLM1]ECCVALMAJ
             mkstat = 2
             GMESSAGE = mess(436,184,1)-":"-[F:STL]ECCVALMAJ
             End
          Endif
          If [F:ITM]ECCSTO = 3 & [F:STL]ECCVALMIN <> [M:SLM1]ECCVALMIN
             mkstat = 2
             GMESSAGE = mess(437,184,1)-":"-[F:STL]ECCVALMIN
             End
          Endif
      Endif
#                                                  # hcb 71276 fin
   Call CHECK_LOT_STA([M:SLM1]AAASTA, [M:SLM1]QQQSTA, [M:SLM1]RRRSTA, WIND) From SUBSLMB
   If WIND : Goto NXT_C_SLODES : Endif
Endif
Gosub MOD_QUEST
WIND = func SUBSLMB.CHECK_LOT([M:SLM1]ITMREF,[M:SLM1]LOTDES,VALEUR)
If WIND : Goto NXT_C_SLODES : Endif
End

$NXT_C_SLODES
Case WIND
    When 4: mkstat = 2
            GMESSAGE=mess(43,197,1)-":"-[M:SLM1]LOTDES
            GMESSAGE-=mess(456,197,1)-":"-VALEUR
            GMESSAGE+="\"+mess(500,199,1)
    When 5: Filter [SLF] Where ITMREF=[M:SLM1]ITMREF
&                            & LOT=[M:SLM1]LOTDES
&                            & SLO=VALEUR
&                            & STOFCY<>[M:SLM1]STOFCY
            Read [F:SLF] First
            Filter [SLF]
            If !fstat
               GMESSAGE=mess(206,184,1)-[F:SLF]STOFCY
            Endif
    When 6: Local Integer WOK : WOK=1
            Call AVERTIR (mess(389,184,1), WOK)From GESECRAN
            If WOK=1 mkstat=2 Endif
    When 7: Local Integer WOK : WOK=1
            Call AVERTIR (mess(390,184,1), WOK)From GESECRAN
            If WOK=1 mkstat=2 Endif
Endcase
End
#--- Bug 71538 End ------------------------------------------------------

##########################################################################
# suivant existence ou non du lot destinataire et suivant autorisations
# question sur le type de traitement souhaité ...
$MOD_QUEST
If fstat
    If [F:SRT]RENUMCOD = 1
        mkstat = 2
        GMESSAGE = mess(487,199,1)
        End
    Else
        # renumérotation seulement
        GMODCOD = 1
        Goto FIN_QUEST
    Endif
Else
    If [F:SRT]MIXCOD = 1
        mkstat = 2
        GMESSAGE = mess(486,199,1)
        End
    Else
        # mélange
        GMODCOD = 2
        Goto FIN_QUEST
    Endif
Endif
$FIN_QUEST
Case GMODCOD
    When 1:    [M:SLM1]MODMESS = "("+mess(575,197,1)+")"
    When 2:    [M:SLM1]MODMESS = "("+mess(577,197,1)+")"
Endcase
If [M:SLM1]WLINNBR <= 1
    Gosub FULL_LOT From SUBSLMB
Else
    OK = 2
    Case GMODCOD
        When 1: Call OUINON(mess(880,196,1),OK) From GESECRAN
        When 2: Call OUINON(mess(881,196,1),OK) From GESECRAN
    Endcase
    If OK = 2 : Gosub FULL_LOT From SUBSLMB : Endif
Endif
Diszo [M:SLM1]10
Affzo [M:SLM1]20
Return

##########################################################################
# nouveau lot forcé (non saisi), 1 seule question possible
$MOD_QUEST_NEW
# renumérotation
If [F:SRT]RENUMCOD <> 2 : mkstat = 2 : GMESSAGE = mess(477,199,1) : End : Endif
GMODCOD = 1
If [M:SLM1]WLINNBR <= 1
    Gosub FULL_LOT From SUBSLMB
Else
    OK = 2
    Call OUINON(mess(880,196,1),OK) From GESECRAN
    If OK = 2 : Gosub FULL_LOT From SUBSLMB : Endif
Endif
Diszo [M:SLM1]10
Affzo [M:SLM1]20
Return

##########################################################################
Subprog AM_LOTDES(VALEUR)
Variable Char    VALEUR()
If [F:ITM]LOTMGTCOD = 4 & (GMODCOD = 1 | [F:SRT]RENUMCOD = 2 & [F:SRT]MIXCOD = 2)
    If dim([M:SLM1]SLODES) > 0 : Raz [M:SLM1]SLODES : Endif
    Raz [M:SLM1]MODMESS
    Affzo [M:SLM1]MODMESS
Endif
End

##########################################################################
Subprog AM_SLODES(VALEUR)
Variable Char    VALEUR()
End

##########################################################################
Subprog IB_LBENBR
If [M:SLM1]NBLIG >  1 : GBOUT1 = mess(01,108,1) : Else : GBOUT1 = ""  : Endif            # mise à jour colonne
End

##########################################################################
Subprog C_LBENBR(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
    Diszo [M:SLM1]LBEFMT(nolign-1)
Else
    Actzo [M:SLM1]LBEFMT(nolign-1)
    If [M:SLM1]LBEFMT(nolign-1) = ""
        Local Char    LUSCAV(5)
        Local Integer LMODIF
        Local Char    LLBEFMT(GLONARP)
        Local Decimal LCOEF
        Call CTLUOM ([M:SLM1]ITMREF,3,"", [M:SLM1]PCU(nolign-1), LCOEF, LUSCAV, LLBEFMT, LMODIF) From STKACT
        [M:SLM1]LBEFMT(nolign-1) = LLBEFMT
    Endif
Endif

End

##########################################################################
Subprog B1_LBENBR(VALEUR)
Variable Decimal VALEUR
Call MAJCOLONNE ("SLM1", 6, nolign-1) From TRTSTOENTB
End

##########################################################################
Subprog IB_LBEFMT
If [M:SLM1]NBLIG >  1 : GBOUT2 = mess(01,108,1) : Else : GBOUT2 = ""  : Endif            # mise à jour colonne
End

##########################################################################
Subprog IB_LOTDES
If GMODCOD = 1 : Raz GBOUTS : Endif
If GMODCOD = 2 : Raz GBOUT2 : Endif
End

##########################################################################
Subprog B2_LBEFMT(VALEUR)
Variable Char    VALEUR()

Call MAJCOLONNE ("SLM1", 5, nolign-1) From TRTSTOENTB
End

##########################################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
#                                                                               # hcb 110327 deb
Local Integer PRET
Local Decimal WQTYSTU
Raz   PRET
WQTYSTU = [M:SLM1]QTYSTU(nolign-1)
#                                                                               # hcb 110327 deb
#--- Bug 62346
Local Decimal LWIPQTY, LWIPQTA, LINIQTA, LINIQTY, LNEWQTA, LNEWQTY
LINIQTY = [M:SLM1]QTYSTU(nolign-1)
LINIQTA = LINIQTY*[M:SLM1]POT/100
LNEWQTY = VALEUR*[M:SLM1]PCUSTUCOE(nolign-1)
LNEWQTA = LNEWQTY*[M:SLM1]POT/100
#--- Fin Bug 62346

[M:SLM1]QTYSTU(nolign-1) = VALEUR * [M:SLM1]PCUSTUCOE(nolign-1)
Call QTEARR([M:SLM1]QTYSTU(nolign-1), [M:SLM1]STU(nolign-1)) From TRTDIV
Affzo [M:SLM1]QTYSTU(nolign-1)
#--- Bug 59444
#[M:SLM1]LBENBR(nolign-1) = int(VALEUR)
If int(VALEUR)=VALEUR
   [M:SLM1]LBENBR(nolign-1) = VALEUR
Else
   [M:SLM1]LBENBR(nolign-1) = int(VALEUR)+1
Endif
#---
Affzo [M:SLM1]LBENBR(nolign-1)

#--- Bug 62346
If adxlog<>1
   Trbegin [STO]
   WTRBEGIN=1
Endif
Readlock [STO]STO0=[M:SLM1]STOFCY;[M:SLM1]WSTOCOU(nolign-1)
If !fstat
   If LNEWQTY>LINIQTY
      # La quantité a augmenté
      LWIPQTY = LNEWQTY - LINIQTY
      LWIPQTA = LNEWQTA - LINIQTA
      [F:STO]CUMWIPQTY += LWIPQTY
      [F:STO]CUMWIPQTA += LWIPQTA
      Call ADD_STOWIPW([F:STO]STOCOU,LINIQTA,LWIPQTY,LWIPQTA) From STKLIB
   Else
      # La quantité a diminué
      LWIPQTY = LINIQTY - LNEWQTY
      LWIPQTA = LINIQTA - LNEWQTA
      [F:STO]CUMWIPQTY -= LWIPQTY
      [F:STO]CUMWIPQTA -= LWIPQTA
      Call DIM_STOWIPW([F:STO]STOCOU,LWIPQTY,LWIPQTA) From STKLIB
   Endif
   Rewrite [STO]
   If fstat
      Call FSTA("STO") From GLOCK
      mkstat=2
#                                                                               # hcb 110327 deb
   Else
# Suppression no série en cours de traitement
      If [F:ITM]SERMGTCOD=4 & [M:SLM1]SERNUM(nolign-1)<>""
         Call DEL_STOSERW([F:ITM]ITMREF,[M:SLM1]SERNUM(nolign-1),WQTYSTU,PRET) From STKLIB
         If PRET<>0
            mkstat=2
         Else
            Raz   [M:SLM1]SERNUM (nolign-1)
            Raz   [M:SLM1]SERNUMF(nolign-1)
            Affzo [M:SLM1]SERNUM (nolign-1)
            Affzo [M:SLM1]SERNUMF(nolign-1)
         Endif
      Endif
#                                                                               # hcb 110327 end
   Endif
Else
   Call RSTA("STO",[M:SLM1]STOFCY-num$([M:SLM1]WSTOCOU(nolign-1))) From GLOCK
   mkstat=2
Endif
# Si on a ouvert une transaction
If WTRBEGIN=1
   If mkstat=2 Rollback Else Commit Endif
   Raz WTRBEGIN
Endif
#--- Fin bug 62342

End

##########################################################################
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
#                                                                               # hcb 110327 deb
Local Integer PRET
Local Decimal WQTYSTU
Raz   PRET
WQTYSTU = [M:SLM1]QTYSTU(nolign-1)
#                                                                               # hcb 110327 deb
#--- Bug 62346
Local Decimal LWIPQTY, LWIPQTA, LINIQTA, LINIQTY, LNEWQTA, LNEWQTY
LINIQTY = [M:SLM1]QTYSTU(nolign-1)
LINIQTA = LINIQTY*[M:SLM1]POT/100
LNEWQTY = VALEUR
LNEWQTA = LNEWQTY*[M:SLM1]POT/100
#--- Fin Bug 62346

Local Decimal WQTYARR
#--- Contrôle cohérence Qté US, UC et coeff UC/US
If [M:SLM1]PCU(nolign-1)<>[M:SLM1]STU(nolign-1)
   Call CTRQTYPCU([M:SLM1]PCU(nolign-1),[M:SLM1]PCUSTUCOE(nolign-1),VALEUR,WQTYARR) From STKLIB
   If WQTYARR<>VALEUR
      Call MESSAGE(mess(160,184,1)-"("+[M:SLM1]PCU(nolign-1)+")\"+mess(161,184,1)-":"-num$(WQTYARR)) From GESECRAN
      mkstat=2 : End
   Endif
Endif

[M:SLM1]QTYPCU(nolign-1) = VALEUR / [M:SLM1]PCUSTUCOE(nolign-1)
Call QTEARR([M:SLM1]QTYPCU(nolign-1), [M:SLM1]STU(nolign-1)) From TRTDIV
Affzo [M:SLM1]QTYPCU(nolign-1)
#--- Bug 59444
#[M:SLM1]LBENBR(nolign-1) = int([M:SLM1]QTYPCU(nolign-1))
If int([M:SLM1]QTYPCU(nolign-1))=[M:SLM1]QTYPCU(nolign-1)
   [M:SLM1]LBENBR(nolign-1) = [M:SLM1]QTYPCU(nolign-1)
Else
   [M:SLM1]LBENBR(nolign-1) = int([M:SLM1]QTYPCU(nolign-1))+1
Endif
#---
Affzo [M:SLM1]LBENBR(nolign-1)

#--- Bug 62346
If adxlog<>1
   Trbegin [STO]
   WTRBEGIN=1
Endif
Readlock [STO]STO0=[M:SLM1]STOFCY;[M:SLM1]WSTOCOU(nolign-1)
If !fstat
   If LNEWQTY>LINIQTY
      # La quantité a augmenté
      LWIPQTY = LNEWQTY - LINIQTY
      LWIPQTA = LNEWQTA - LINIQTA
      [F:STO]CUMWIPQTY += LWIPQTY
      [F:STO]CUMWIPQTA += LWIPQTA
      Call ADD_STOWIPW([F:STO]STOCOU,LINIQTA,LWIPQTY,LWIPQTA) From STKLIB
   Else
      # La quantité a diminué
      LWIPQTY = LINIQTY - LNEWQTY
      LWIPQTA = LINIQTA - LNEWQTA
      [F:STO]CUMWIPQTY -= LWIPQTY
      [F:STO]CUMWIPQTA -= LWIPQTA
      Call DIM_STOWIPW([F:STO]STOCOU,LWIPQTY,LWIPQTA) From STKLIB
   Endif
   Rewrite [STO]
   If fstat
      Call FSTA("STO") From GLOCK
      mkstat=2
#                                                                               # hcb 110327 deb
   Else
# Suppression no série en cours de traitement
      If [F:ITM]SERMGTCOD=4 & [M:SLM1]SERNUM(nolign-1)<>""
         Call DEL_STOSERW([F:ITM]ITMREF,[M:SLM1]SERNUM(nolign-1),WQTYSTU,PRET) From STKLIB
         If PRET<>0
            mkstat=2
         Else
            Raz   [M:SLM1]SERNUM (nolign-1)
            Raz   [M:SLM1]SERNUMF(nolign-1)
            Affzo [M:SLM1]SERNUM (nolign-1)
            Affzo [M:SLM1]SERNUMF(nolign-1)
         Endif
      Endif
#                                                                               # hcb 110327 end
   Endif
Else
   Call RSTA("STO",[M:SLM1]STOFCY-num$([M:SLM1]WSTOCOU(nolign-1))) From GLOCK
   mkstat=2
Endif
# Si on a ouvert une transaction
If WTRBEGIN=1
   If mkstat=2 Rollback Else Commit Endif
   Raz WTRBEGIN
Endif
#--- Fin bug 62342

End


##########################################################################
##########################################################################
## Etiquette ajoutée par le superviseur 27/01/2004 13:23:09 (LLC)
##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
Raz [M:SLM1]ITMREF
Raz [M:SLM1]LOT
If dim([M:SLM1]SLO) > 0     : Raz [M:SLM1]SLO     : Endif
If [F:SRT]LOTCOD = 1 : Raz [M:SLM1]LOTDES : Endif
If dim([M:SLM1]SLODES) > 0  : Raz [M:SLM1]SLODES  : Endif
Effzo [M:SLM1]20
Actzo [M:SLM1]10
Affzo [M:SLM1]LOT
If dim([M:SLM1]SLO) > 0     : Affzo [M:SLM1]SLO     : Endif
Affzo [M:SLM1]LOTDES
If dim([M:SLM1]SLODES) > 0  : Affzo [M:SLM1]SLODES  : Endif
Affzo [M:SLM1]20
GFCY=VALEUR
Gosub CHARG_PARAM From SUBSLMA       # ana

End


