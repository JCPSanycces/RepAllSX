Subprog AS_CTRGRD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(2675,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRCGD
Call DEFHRCGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRCGD
If mkstat=2
 [M]CTRGRD(INDIC) = VALEUR
 Affzo CTRGRD(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CTRGRD(zc) From W1CTR0
Onkey   2 Titled GBOUTS Call S_CTRGRD(zc) From W1CTR0
Onkey 144 Titled GBOUTP Call P_CTRGRD(zc) From W1CTR0
Onkey 146 Titled GBOUTA Call SA_CTRGRD(zc) From W1CTR0
Gosub _AFF
End

Subprog C_CTRGRD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
If !mkstat
 ## Action CONTHRCGD
 Call CONTHRCGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRCGD
 If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
  If !mkstat
   ## Action STD
   Call C_CTRGRD(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CTRGRD
