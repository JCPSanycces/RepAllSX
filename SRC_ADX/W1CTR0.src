#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:39"
A_USER  = "DOC"
A_STAMP = "20181109230339"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR0 [CTR0]
Gosub HORODAT
Local Inpbox "CTR0" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR0] As [SIM_]
Grizo [CTR0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=172 : Y1(0)=1 : Y2(0)=5
Return

$ON_REFNUM
Onevent CONTROL Call C_REFNUM(zc) From W1CTR0
Onevent BEFORE_INPUT Call AS_REFNUM(zc) From W1CTR0
Onevent AFTER_CHANGE Gosub AMM_REFNUM From W1CTR0
Return

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_REFNUM(VALEUR) From SUBCTR
If mkstat=2
 [M]REFNUM(INDIC) = VALEUR
 Affzo REFNUM(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_REFNUM(zc) From W1CTR0
Onkey   2 Titled GBOUTS Call S_REFNUM(zc) From W1CTR0
Onkey 144 Titled GBOUTP Call P_REFNUM(zc) From W1CTR0
Onkey 146 Titled GBOUTA Call SA_REFNUM(zc) From W1CTR0
Gosub _AFF
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTEMP
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTEMP"
  PARMSK(1) = ""
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = ""
  PARMSK(5) = ""
  PARMSK(6) = func TOOLSHRLEG.LEGWRK
  Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","1","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_REFNUM
Call AM_REFNUM(zc)
If !mkstat & GOBJET
 zoncou = "REFNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_REFNUM(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZREFNUM)")>indice
 [M]REFNUM(indice) = VALEUR
 Affzo ZREFNUM(indice)
Endif
Gosub _AFF
End

Subprog S_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "EML"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_REFNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("EML",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZREFNUM
Onevent BEFORE_AREA Gosub AV_ZREFNUM From W1CTR0
Return

$AV_ZREFNUM
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]REFNUM(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$ON_CTRNUM
Onevent CONTROL Call C_CTRNUM(zc) From W1CTR0
Onevent AFTER_CHANGE Gosub AMM_CTRNUM From W1CTR0
Onevent BEFORE_INPUT Call AS_CTRNUM(zc) From W1CTR0
Return

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CTRNUM(zc) From W1CTR0
Onkey 144 Titled GBOUTP Call P_CTRNUM(zc) From W1CTR0
Onkey 146 Titled GBOUTA Call SA_CTRNUM(zc) From W1CTR0
Gosub _AFF
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
## Action CONTVCR
Call CONTVCR(VALEUR) From TRTDIV
If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTCTR
  Call CONTCTR(VALEUR,[M]REFNUM) From DIVPAYE
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CTR","!$",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
 If !mkstat
  ## Action STD
  Call C_CTRNUM(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CTRNUM
Call AM_CTRNUM(zc)
If !mkstat & GOBJET
 zoncou = "CTRNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CTRNUM(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
Gosub _AFF
End

Subprog S_CTRNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "CTR"
 PARMSK(2) = ""
 PARMSK(3) = [M]REFNUM
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CTR"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CTR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

