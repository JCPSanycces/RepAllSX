Subprog AS_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1427,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_ETRFCY(VALEUR) From SUBCTR
If mkstat=2
 [M]ETRFCY(INDIC) = VALEUR
 Affzo ETRFCY(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_ETRFCY(zc) From W1CTR0
Onkey   2 Titled GBOUTS Call S_ETRFCY(zc) From W1CTR0
Onkey 144 Titled GBOUTP Call P_ETRFCY(zc) From W1CTR0
Onkey 146 Titled GBOUTA Call SA_ETRFCY(zc) From W1CTR0
Gosub _AFF
End

Subprog C_ETRFCY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action ACONTFCY
 Call CONTSITE(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("FCY","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
  If !mkstat
   ## Action STD
   Call C_ETRFCY(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

