End

$ON_NATCON
Onevent BEFORE_INPUT Call AS_NATCON(zc) From W1CTR0
Onevent CONTROL Call C_NATCON(zc) From W1CTR0
Onevent AFTER_CHANGE Gosub AMM_NATCON From W1CTR0
Return

Subprog AS_NATCON(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(15886,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRNCT
Call DEFHRNCT(VALEUR,GCURLEG,GSOCIETE) From SUBHRNCT
If mkstat=2
 [M]NATCON(INDIC) = VALEUR
 Affzo NATCON(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_NATCON(zc) From W1CTR0
Onkey   2 Titled GBOUTS Call S_NATCON(zc) From W1CTR0
Onkey 144 Titled GBOUTP Call P_NATCON(zc) From W1CTR0
Onkey 146 Titled GBOUTA Call SA_NATCON(zc) From W1CTR0
Gosub _AFF
End

Subprog C_NATCON(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
If !mkstat
 ## Action CONTHRNCT
 Call CONTHRNCT(VALEUR,GCURLEG,GSOCIETE) From SUBHRNCT
 If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_NATCON
Call AM_NATCON(zc)
If !mkstat & GOBJET
 zoncou = "NATCON" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NATCON(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_NATCON(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZNATCON)")>indice
 [M]NATCON(indice) = VALEUR
 Affzo ZNATCON(indice)
Endif
Gosub _AFF
End

Subprog S_NATCON(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRNCT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRNCT"
 PARMSK(1) = GCURLEG
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRNCT","SUBHRNCT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_NATCON(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRNCT
 Call TUNHRNCT(VALEUR,GCURLEG,GSOCIETE) From SUBHRNCT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_NATCON(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRNCT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NATCON(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRNCT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZNATCON
Onevent BEFORE_AREA Gosub AV_ZNATCON From W1CTR0
Return

$AV_ZNATCON
Call LECTEXTRA(zc,"HRNATCON","DESAXX",num$([M]NATCON(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


