Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(49838,GBOUT3) From OBJDIV
Call TEXTE(49417,GBOUT4) From OBJDIV
Call IB_CTRDAT(VALEUR)
## Action STD
Call AS_CTRDAT(VALEUR) From SUBCTR
If mkstat=2
 [M]CTRDAT(INDIC) = VALEUR
 Affzo CTRDAT(INDIC) : mkstat = 2
Endif
Onkey 131 Titled GBOUT3 Call B3_CTRDAT(zc) From W1CTR0
Onkey 132 Titled GBOUT4 Call B4_CTRDAT(zc) From W1CTR0
Gosub _AFF
End

Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTRDAT" : GZNUM = 212 : Endif
Gosub _AFF
End

$AMM_CTRDAT
Call AM_CTRDAT(zc)
If !mkstat & GOBJET
