#<AdxTL>@(#)11.0.0.0 $Revision$
##############################################################################
## Copie onglet sélection sur appli fille
##############################################################################
Call OUVRE_TRACE("update AOBJET") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub AOBJSEL
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub AOBJSEL
End

$AOBJSEL

Local Integer I , VALMOD(20)
Local Char    OBJCUR(GLONAOB)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

For OBJCUR="ANM","ATY","AWA"

 # Onglet Sélection

 Call MAJ_SEL(DOSSIER,OBJCUR) From PATCHAOB

 # Validation de l'objet

 Call VALID_TRT(DOSSIER,0,"","","","","","","","",OBJCUR,OBJCUR,"","","","","","","","","","",VALMOD) From VALDICO
 Call VALFEN(DOSSIER,OBJCUR) From SUBAOB

Next OBJCUR

Return
