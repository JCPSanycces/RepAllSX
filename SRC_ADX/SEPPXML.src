#<AdxTL>@(#)0.0.0.0 $Revision$

####################################################################################################
# SEPPXML is the interface between X3 applications and the JavaScript that makes API
# calls to Sage Exchange.
#
# Transaction types for Sage Exchange:
#   01  Sale.......................(No UI)...transaction is authorized and captured in one step
#   02  Authorization..............(No UI)...an account is verified to be valid and has not reached its limit
#   03  Capture....................(No UI)...puts an Authorization transaction into a Captured state for settlement
#   04  Void.......................(No UI)...cancels a transaction that has not yet been settled
#   05  Force......................(No UI)...used to force a transaction into settlement in cases where a Sale or
#                                            Authorization transaction cannot be processed
#   06  Credit.....................(No UI)...transfers funds to the account, rather than from the account
#   07  Credit without reference...(No UI)...Credit transaction without a VAN reference
#
#   22  Account Query..............(No UI)...get the status and services available for a particular merchant account
#   23  Transaction Status Query...(No UI)...get the status of a transaction using the Transaction ID
#   24  Vault Status Query.........(No UI)...get the status of a Vault using the Vault ID
#
#   30  Vault Create...............(UI)......create a storage record in the Sage Payment Solutions Vault
#   31  Vault Update...............(UI)......update a storage record in the Sage Payment Solutions Vault
#   32  Vault Delete...............(No UI)...remove a storage record from the Sage Payment Solutions Vault
#
####################################################################################################


####################################################################################################
# Sale (01)
####################################################################################################
Subprog SALE(TXNID,RESP,ERR,ERRMSG)
  Variable Char    TXNID
  Variable Char    RESP
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2) : TXNTYP="01"
  Gosub SEND_TXN

End

#---------------------------------------------------------------------------------------------------
$SALE_REQUEST   # Called from SEND_TXN

  Gosub GET_SEB
  If ERR : Return : Endif

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_PAYMENTS
  Append ARGUMENTS, '","PaymentResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return


####################################################################################################
# Authorization (02)
####################################################################################################
Subprog AUTH(TXNID,RESP,ERR,ERRMSG)
  Variable Char    TXNID
  Variable Char    RESP
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2) : TXNTYP="02"
  Gosub SEND_TXN

End

#---------------------------------------------------------------------------------------------------
$AUTH_REQUEST   # Called from SEND_TXN

  Gosub GET_SEB
  If ERR : Return : Endif

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_PAYMENTS
  Append ARGUMENTS, '","PaymentResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return


####################################################################################################
# Capture (03)
####################################################################################################
Subprog CAPTURE(TXNID,RESP,ERR,ERRMSG)
  Variable Char    TXNID
  Variable Char    RESP
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char SAVTXN(50) : SAVTXN = TXNID

  Local Char TXNTYP(2) : TXNTYP="03"
  Gosub SEND_TXN

  # If Capture failed, attempt Force
  If ERR | RESP<>"A"
    TXNID  = SAVTXN : Raz ERR
    TXNTYP = "05"
    Gosub SEND_TXN
  Endif

End

#---------------------------------------------------------------------------------------------------
$CAPTURE_REQUEST   # Called from SEND_TXN

  Gosub CHECK_VANREF
  If ERR : Return : Endif

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_PAYMENTS_VANREF
  Append ARGUMENTS, '~,~Payments.PaymentType.Level2.CustomerNumber~=~' + [F:SEU]BPCNUM
  Append ARGUMENTS, '~,~Payments.PaymentType.Level2.TaxAmount~=~'      + func FORMATCURR([F:SEU]TAXAMT)    # 98909 - Ensure currencies are not formatted with a ,
  Append ARGUMENTS, '","PaymentResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return


####################################################################################################
# Void (04)
####################################################################################################
Subprog VOID(TXNID,RESP,ERR,ERRMSG)
  Variable Char    TXNID
  Variable Char    RESP
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2) : TXNTYP="04"
  Gosub SEND_TXN

End

#---------------------------------------------------------------------------------------------------
$VOID_REQUEST   # Called from SEND_TXN

  Gosub CHECK_VANREF
  If ERR : Return : Endif

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_PAYMENTS_VANREF
  Append ARGUMENTS, '","PaymentResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return


####################################################################################################
# Force (05)
####################################################################################################
Subprog FORCE(TXNID,RESP,ERR,ERRMSG)
  Variable Char    TXNID
  Variable Char    RESP
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2) : TXNTYP="05"
  Gosub SEND_TXN
End

#---------------------------------------------------------------------------------------------------
$FORCE_REQUEST   # Called from SEND_TXN

  Gosub GET_SEB
  If ERR : Return : Endif

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_PAYMENTS
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.AuthCode~=~' + [F:SEU]AUTID
  Append ARGUMENTS, '","PaymentResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return


####################################################################################################
# Credit (06) / Credit without reference (07)
####################################################################################################
Subprog CREDIT(TXNID,RESP,ERR,ERRMSG)
  Variable Char    TXNID
  Variable Char    RESP
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2)
  If [F:SEU]VANREF<>""
    TXNTYP="06"
  Else
    TXNTYP="07"
  Endif

  Gosub SEND_TXN

  # If Credit failed, attempt Credit No Ref
  If TXNTYP="06" & (ERR | RESP<>"A")
    TXNTYP="07"
    Gosub SEND_TXN
  Endif

End

#---------------------------------------------------------------------------------------------------
$CREDIT_REQUEST   # Called from SEND_TXN

  Gosub CHECK_VANREF
  If ERR : Return : Endif

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_PAYMENTS_VANREF
  Append ARGUMENTS, '","PaymentResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return

#---------------------------------------------------------------------------------------------------
$CREDIT_NO_REF_REQUEST   # Called from SEND_TXN

  Gosub GET_SEB
  If ERR : Return : Endif

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_PAYMENTS
  Append ARGUMENTS, '","PaymentResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return


####################################################################################
# Batch settlement (21) *****NOT IMPLEMENTED*****
####################################################################################
Subprog BATCH(PRCCOD,RESP,BATCH_NUM,BATCH_REF,BATCH_CNT,BATCH_NET,ERR,ERRMSG)
Value    Char    PRCCOD
Variable Char    RESP
Variable Char    BATCH_NUM
Variable Char    BATCH_REF
Variable Decimal BATCH_CNT
Variable Decimal BATCH_NET
Variable Integer ERR
Variable Char    ERRMSG

Local Char TXNTYP(2) : TXNTYP="21"

Gosub SEND_TXN
If ERR : End : Endif

BATCH_NUM  = vireblc(func FINDVALUE("/BatchNumber",RESP_PATH,RESP_VALUE),4)
BATCH_REF  = func FINDVALUE("/BatchReference",RESP_PATH,RESP_VALUE)
BATCH_NET  = val(func FINDVALUE("/Net",RESP_PATH,RESP_VALUE))
BATCH_CNT  = val(func FINDVALUE("/Count",RESP_PATH,RESP_VALUE))

End


####################################################################################################
# Account Query (22)
####################################################################################################
Subprog ACCOUNT_QRY(MERID,MERKEY,RESP,ACTIVE,ERR,ERRMSG)
  Value    Char    MERID
  Value    Char    MERKEY
  Variable Char    RESP
  Variable Char    ACTIVE
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2) : TXNTYP="22"
  Gosub SEND_TXN

End

#---------------------------------------------------------------------------------------------------
$ACCT_QUERY   # Called from SEND_TXN

  FUNCTION = 'seRequest'

  # Decrypt MERKEY
  If len(MERKEY)=24  # new style
    Call VARPSE(MERKEY) From GESUSER
  Endif

  # Build ARGUMENTS
  Gosub COMMON_ARGS_APPLICATION
  Append ARGUMENTS, '~,~AccountQuery.Merchant.MerchantID~=~'+MERID
  Append ARGUMENTS, '~,~AccountQuery.Merchant.MerchantKey~=~'+MERKEY
  Append ARGUMENTS, '","AccountQueryResponse"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

  RESP   = func FINDVAL(RESBODY,"ResponseIndicator")
  ACTIVE = func FINDVAL(RESBODY,"Active")

Return


####################################################################################################
# Transaction Status Query (23)
####################################################################################################
Subprog TXN_QRY(TXNID,RESP,TXNTYP,STLTYP,ERR,ERRMSG)
  Value    Char    TXNID
  Variable Char    RESP
  Variable Char    TXNTYP
  Variable Char    STLTYP
  Variable Integer ERR
  Variable Char    ERRMSG

  If TXNID="" : End : Endif

  TXNTYP="23"
  Gosub SEND_TXN

End


#---------------------------------------------------------------------------------------------------
$TXN_QUERY   # Called from SEND_TXN

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub DECRYPT_MERKEY
  Gosub COMMON_ARGS_APPLICATION
  Append ARGUMENTS, '~,~TransactionStatusQueries.TransactionStatusQueryType.Merchant.MerchantID~=~'+[F:SER]MERID
  Append ARGUMENTS, '~,~TransactionStatusQueries.TransactionStatusQueryType.Merchant.MerchantKey~=~'+[L]MERKEY
  Append ARGUMENTS, '~,~TransactionStatusQueries.TransactionStatusQueryType.TransactionID~=~'+[L]TXNID
  Append ARGUMENTS, '","TransactionStatusQueryResponses"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

  RESP   = func FINDVAL(RESBODY,"ResponseIndicator")
  TXNTYP = func FINDVAL(RESBODY,"TransactionType")
  STLTYP = func FINDVAL(RESBODY,"SettlementType")

Return


####################################################################################################
# Vault Status Query (24)
####################################################################################################
Subprog VAULT_QRY(PRCCOD,TXNID,RESP,GUID,EXPDAT,PAYDES,PAYTYP,ERR,ERRMSG)
  Value    Char    PRCCOD
  Value    Char    TXNID
  Variable Char    RESP
  Variable Char    GUID
  Variable Date    EXPDAT
  Variable Char    PAYDES
  Variable Char    PAYTYP
  Variable Integer ERR
  Variable Char    ERRMSG

  If TXNID="" : End : Endif

  Local Char TXNTYP(2) : TXNTYP="24"
  Gosub SEND_TXN

End

#---------------------------------------------------------------------------------------------------
$VAULT_QUERY   # Called from SEND_TXN

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub DECRYPT_MERKEY
  Gosub COMMON_ARGS_APPLICATION
  Append ARGUMENTS, '~,~VaultStatusQuery.Merchant.MerchantID~=~'+[F:SER]MERID
  Append ARGUMENTS, '~,~VaultStatusQuery.Merchant.MerchantKey~=~'+ [L]MERKEY
  Append ARGUMENTS, '~,~VaultStatusQuery.VaultID~=~'+[L]TXNID
  Append ARGUMENTS, '","VaultStatusQueryResponse"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

  Local Char TMPDAT(10)

  RESP   = func FINDVAL(RESBODY,"ResponseIndicator")
  GUID   = func FINDVAL(RESBODY,"GUID")
  TMPDAT = func FINDVAL(RESBODY,"ExpirationDate")
  PAYDES = func FINDVAL(RESBODY,"PaymentDescription")
  PAYTYP = func FINDVAL(RESBODY,"PaymentTypeID")

  If len(TMPDAT)=4
    EXPDAT = eomonth(evalue("[1/"+num$(val(left$(TMPDAT,2)))+"/"+num$(2000+val(right$(TMPDAT,3)))+"]"))
  Endif

Return


####################################################################################################
# Vault Create (30) / Vault Update (31)
####################################################################################################
Subprog VAULT_CRE(PRCCOD,TXNID,ERR,ERRMSG)
  Value    Char    PRCCOD
  Value    Char    TXNID
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2)

  If dim([F:SEB]VLTGUID)<=0 | [F:SEB]VLTGUID=""
    TXNTYP="30"
  Else
    TXNTYP="31"
  Endif
  Gosub SEND_TXN

End

#---------------------------------------------------------------------------------------------------
$VAULT_CREATE   # Called from SEND_TXN

  Local Char PROTO(5)
  Local Char FIL(250)

  # Get Redirect URL.
  FUNCTION = 'getRedirectUrl'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_VAULT
  Append ARGUMENTS, '~,~VaultOperation.VaultStorage.Service~=~CREATE'
  Append ARGUMENTS, '~,~UI.VaultOperation.AccountNumber.Enabled~=~true'
  Append ARGUMENTS, '~,~UI.VaultOperation.AccountNumber.Visible~=~true'
  Append ARGUMENTS, '",3000' # time to live

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
  Call BREAK_URL(RESBODY, PROTO, FIL)

  # Open Sage Exchange window in browser.
  Callui RETOUR="" With "UIAction="    + chr$(1) + "OpenFile"
&                      ,"UILocalDir="  + chr$(1) + PROTO
&                      ,"UILocalFile=" + chr$(1) + FIL

Return

#---------------------------------------------------------------------------------------------------
$VAULT_UPDATE   # Called from SEND_TXN

  Local Char PROTO(5)
  Local Char FIL(250)

  # Get Redirect URL.
  FUNCTION = 'getRedirectUrl'

  # Build ARGUMENTS
  Gosub COMMON_ARGS_VAULT
  Append ARGUMENTS, '~,~VaultOperation.VaultStorage.Service~=~UPDATE'
  Append ARGUMENTS, '~,~UI.VaultOperation.AccountNumber.Enabled~=~false'
  Append ARGUMENTS, '~,~UI.VaultOperation.AccountNumber.Visible~=~true'
  Append ARGUMENTS, '",3000' # time to live

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
  Call BREAK_URL(RESBODY, PROTO, FIL)

  # Open Sage Exchange window in browser.
  Callui RETOUR="" With "UIAction="    + chr$(1) + "OpenFile"
&                      ,"UILocalDir="  + chr$(1) + PROTO
&                      ,"UILocalFile=" + chr$(1) + FIL

Return

####################################################################################################
Subprog BREAK_URL(RESBODY, PROTO, FIL)
  Value    Clbfile RESBODY
  Variable Char    PROTO
  Variable Char    FIL

  PROTO = toupper(left$(RESBODY, instr(1,RESBODY,'://')-1))
  FIL = right$(RESBODY, instr(1,RESBODY,'://')+3)

End

####################################################################################################
# Vault Delete (32)
####################################################################################################
Subprog VAULT_DEL(RESP,ERR,ERRMSG)
  Variable Char    RESP
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Char TXNTYP(2) : TXNTYP="32"
  Gosub SEND_TXN

End

#---------------------------------------------------------------------------------------------------
$VAULT_DELETE   # Called from SEND_TXN

  FUNCTION = 'seRequest'

  # Build ARGUMENTS
  Gosub DECRYPT_MERKEY
  Gosub COMMON_ARGS_VAULT
  Append ARGUMENTS, '~,~VaultOperation.VaultStorage.Service~=~DELETE'
  Append ARGUMENTS, '","VaultResponse"'

  Call SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)

Return


####################################################################################
$SEND_TXN

  If !clalev([F:SER])  : Local File SEPRC       [SER]  : Endif
  If !clalev([F:SEX])  : Local File SETXN       [SEX]  : Endif

  If !clalev([M:SEX1]) : Local Mask SETXN       [SEX1] : Endif

  If dim([L]PRCCOD)<=0 : Local Char PRCCOD(10) : Endif
  If [L]PRCCOD=""
    If dim([F:SEU]PRCCOD)>0 & [F:SEU]PRCCOD<>""
      PRCCOD = [F:SEU]PRCCOD
    Elsif dim([F:SEB]PRCCOD)>0 & [F:SEB]PRCCOD<>""
      PRCCOD = [F:SEB]PRCCOD
    Endif
  Endif
  If [L]PRCCOD<>""
    Call GET_SER([L]PRCCOD) From SEPPLIB
    If fstat : ERR=1 : Return : Endif
  Endif

  If dim([L]TXNID)<=0 : Local Char TXNID(30) : Endif

  # don't get new UUID for Vault Create, or Txn or Vault Query
  If [L]TXNID=""
    [L]TXNID = uuid$  # get new UUID for transaction
  Endif

  # Set Application ID.  It was stored in Javabridge definition table (SEPAR)
  Local Char APPID(50) : [L]APPID = "SAGEERPX5X00000ERPLAAA5USEN"

  Local Char FUNCTION(30)
  Local Clbfile ARGUMENTS(0)
  Local Clbfile RESHEAD(0)
  Local Clbfile RESBODY(6)

  Case TXNTYP
    When "01" : Gosub SALE_REQUEST
    When "02" : Gosub AUTH_REQUEST
    When "03" : Gosub CAPTURE_REQUEST
    When "04" : Gosub VOID_REQUEST
    When "05" : Gosub FORCE_REQUEST
    When "06" : Gosub CREDIT_REQUEST
    When "07" : Gosub CREDIT_NO_REF_REQUEST
  # When "21" : Gosub BATCH_REQ - Batch not implemented
    When "22" : Gosub ACCT_QUERY
    When "23" : Gosub TXN_QUERY
    When "24" : Gosub VAULT_QUERY
    When "30" : Gosub VAULT_CREATE
    When "31" : Gosub VAULT_UPDATE
    When "32" : Gosub VAULT_DELETE

    When Default
      ERRMSG = "transaction not supported"
      ERR = 1 : Return
  Endcase
  If ERR : Return : Endif

  Call TXNLOG(RESBODY,TXNTYP,1,ERR,ERRMSG)
  If ERR : Return : Endif

  Call TXNLOG(RESBODY,TXNTYP,2,ERR,ERRMSG)
  If ERR : Return : Endif

  If dim(RESP)>0
    RESP = func FINDVAL(RESBODY,"ResponseIndicator")
  Endif

  # Save SE transaction
  Call SAVE_TXN(ERR)

Return


####################################################################################################
$GET_SEB

  If [F:SEU]VCRNUM=""
    ERRMSG = mess(23,100,1)-"SEU"
    ERR = 1 : Return
  Endif

  Call GET_SEB([F:SEU]BPCNUM,[F:SEU]ACCNCKNAM) From SEPPLIB
  If fstat : ERR=1 : Return : Endif
  If [F:SEB]VLTGUID=""
    ERRMSG = mess(14,2092,1)-[F:SEB]BPCNUM-[F:SEB]ACCNCKNAM
    ERR = 1 : Return
  Endif

Return


####################################################################################################
$CHECK_VANREF

  If [F:SEU]VANREF=""
    ERRMSG = mess(15,2092,1)-num$([F:SEU]VCRTYP)-[F:SEU]VCRNUM-num$([F:SEU]VCRSEQ)
    ERR = 1 : Return
  Endif

Return


####################################################################################################
$COMMON_ARGS_APPLICATION

  Raz ARGUMENTS
  Append ARGUMENTS, '"'
  Append ARGUMENTS, 'Application.ApplicationID~=~' + [L]APPID
  Append ARGUMENTS, '~,~Application.LanguageID~=~' + func GET_LANID()

Return


####################################################################################################
$COMMON_ARGS_VAULT

  Local Char VAULTGUID(50)
  If dim([F:SEB]VLTGUID)>0 : [L]VAULTGUID = [F:SEB]VLTGUID : Endif

  Gosub COMMON_ARGS_APPLICATION

  Gosub DECRYPT_MERKEY
  Append ARGUMENTS, '~,~VaultOperation.Merchant.MerchantID~=~'  + [F:SER]MERID
  Append ARGUMENTS, '~,~VaultOperation.Merchant.MerchantKey~=~' + [L]MERKEY
  Append ARGUMENTS, '~,~VaultOperation.VaultID~=~'              + [L]TXNID
  Append ARGUMENTS, '~,~VaultOperation.VaultStorage.GUID~=~'    + [L]VAULTGUID

Return


####################################################################################################
$COMMON_ARGS_PAYMENTS

  Gosub COMMON_ARGS_APPLICATION

  Gosub DECRYPT_MERKEY
  Append ARGUMENTS, '~,~Payments.PaymentType.Merchant.MerchantID~=~'             + [F:SER]MERID
  Append ARGUMENTS, '~,~Payments.PaymentType.Merchant.MerchantKey~=~'            + [L]MERKEY
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.TransactionID~=~'   + [L]TXNID
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.TransactionType~=~' + [L]TXNTYP
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.Amount~=~'          + func FORMATCURR([F:SEU]AUTAMT)    # 98909 - Ensure currencies are not formatted with a ,
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.Reference1~=~'      + func SEPPLIB.GET_SEUDOC([F:SEU]VCRTYPORI)
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.Reference2~=~'      + [F:SEU]VCRNUM
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Name.FirstName~=~'         + [F:SEB]ACCNAM
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Address.AddressLine1~=~'   + func CHECKVAL([F:SEB]ADDLIG(0))
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Address.AddressLine2~=~'   + [F:SEB]ADDLIG(1)
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Address.City~=~'           + func CHECKVAL([F:SEB]CTY)
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Address.State~=~'          + func CHECKVAL([F:SEB]SAT)
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Address.ZipCode~=~'        + func CHECKVAL([F:SEB]POSCOD)
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Address.Country~=~'        + [F:SEB]CRY
  Append ARGUMENTS, '~,~Payments.PaymentType.Customer.Address.EmailAddress~=~'   + [F:SEB]EMAIL
  Append ARGUMENTS, '~,~Payments.PaymentType.VaultStorage.GUID~=~'               + [F:SEB]VLTGUID
  Append ARGUMENTS, '~,~Payments.PaymentType.VaultStorage.Service~=~'            + 'RETRIEVE'

Return


####################################################################################################
$COMMON_ARGS_PAYMENTS_VANREF

  Gosub COMMON_ARGS_APPLICATION

  Gosub DECRYPT_MERKEY
  Append ARGUMENTS, '~,~Payments.PaymentType.Merchant.MerchantID~=~'             + [F:SER]MERID
  Append ARGUMENTS, '~,~Payments.PaymentType.Merchant.MerchantKey~=~'            + [L]MERKEY
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.TransactionID~=~'   + [L]TXNID
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.TransactionType~=~' + [L]TXNTYP
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.Amount~=~'          + func FORMATCURR([F:SEU]AUTAMT)    # 98909 - Ensure currencies are not formatted with a ,
  Append ARGUMENTS, '~,~Payments.PaymentType.TransactionBase.VANReference~=~'    + [F:SEU]VANREF

Return


####################################################################################################
Funprog GET_LANID()
  Case GLANGUE
    When "ENG" : End "en-US"
    When "FRA" : End "fr-CA"
    When "SPA" : End "es-MX"
  Endcase
End ""


####################################################################################################
$DECRYPT_MERKEY

  Local Char MERKEY(30)
  [L]MERKEY = [F:SER]MERKEY
  If len([L]MERKEY)=24  # new style
    Call VARPSE([L]MERKEY) From GESUSER
  Endif

Return


####################################################################################
$BATCH_REQ

Local Char REQ_PATH(250)(1..10),REQ_VALUE(100)(1..10)

# Gosub COMMON_REQ

REQ_PATH(06)  = "/Request_v1/Batch/Merchant/MerchantID"
REQ_PATH(07)  = "/Request_v1/Batch/Merchant/MerchantKey"
REQ_PATH(08)  = "/Request_v1/Batch/Net"
REQ_PATH(09)  = "/Request_v1/Batch/Count"
REQ_PATH(10)  = "/Request_v1/Batch/BatchPayment"

REQ_VALUE(08) = format$("N:6.2",[L]BATCH_NET)
REQ_VALUE(09) = num$([L]BATCH_CNT)
REQ_VALUE(10) = "CREDITCARD"

Return


####################################################################################
# Write message to a log file
####################################################################################
Subprog SE_LOG(JBSFUNC,MESSAGE)
Value    Char    JBSFUNC
Value    Char    MESSAGE

Local Char    FICTRA(GDIMFIC)

Onerrgo ERR_LOG
FICTRA = filpath("TRA","SEPPLOG","tra",0)
MESSAGE = date$ - time$ - JBSFUNC - "-" - MESSAGE

Openo FICTRA,-1
Wrseq MESSAGE
Openo
Onerrgo

End

$ERR_LOG
Resume


####################################################################################
Funprog FINDVALUE(ANAME,APATHS,AVALS)
Value    Char    ANAME,APATHS()(1..),AVALS()(1..)

Local Char WVALUE(250) : WVALUE=""
Local Integer WI,WMAX
WMAX = dim(APATHS)
For WI=1 To WMAX
    If pat(APATHS(WI),"*"+ANAME)
        WVALUE = vireblc(AVALS(WI),2)
        Break
    Endif
Next WI
End WVALUE


####################################################################################
# Subprogram : TXNLOG
# Description: Put the request/response in the work screen
####################################################################################
Subprog TXNLOG(RESBODY,TXNTYP,REQRSP,ERR,ERRMSG)
Value    Clbfile RESBODY
Value    Char    TXNTYP
Value    Integer REQRSP
Variable Char    ERRMSG
Variable Integer ERR

# Don't log Query type request txns
If find(TXNTYP,"21","22","23") : End : Endif

# Log successful Vault inquiry response
If TXNTYP="24" & (REQRSP=1 | func FINDVAL(RESBODY,"GUID")="") : End : Endif

# Prevent going over dimension on screen
If dim([M:SEX1]TXNID)=[M:SEX1]NBLIG+1 : End : Endif

Local Integer I : I = [M:SEX1]NBLIG

[M:SEX1]REQRSP(I) = [L]REQRSP

[M:SEX1]TXNID(I) = func FINDVAL(RESBODY,"TransactionID")
If [M:SEX1]TXNID(I)=""
  [M:SEX1]TXNID(I) = func FINDVAL(RESBODY,"GUID")
Endif
If [M:SEX1]TXNID(I)=""  # if we still don't have a transaction ID, just create one
  [M:SEX1]TXNID(I) = uuid$
Endif

[M:SEX1]TXNTYP(I) = func FINDVAL(RESBODY,"TransactionType")
If [M:SEX1]TXNTYP(I)=""
   [M:SEX1]TXNTYP(I) = [L]TXNTYP
Endif
#122362.so - JOBRO - we want our server date/time not the time from them
#[M:SEX1]TXNDATTIM(I) = func FINDVAL(RESBODY,"TransactionDate")
#If [M:SEX1]TXNDATTIM(I)=""
#    [M:SEX1]TXNDATTIM(I) = format$("DD2",date$)-time$
#Endif
#122362.eo - JOBRO
[M:SEX1]TXNDATTIM(I) = format$("DD2",date$)-time$   #122362.n - JOBRO
[M:SEX1]PAYPRC(I)  =     1  # 109253 - Added new processor type field
[M:SEX1]RESP(I)    =     func FINDVAL(RESBODY,"ResponseIndicator")
[M:SEX1]RSPCOD(I)  =     func FINDVAL(RESBODY,"ResponseCode")
[M:SEX1]RSPMSG(I)  =     func FINDVAL(RESBODY,"ResponseMessage")
[M:SEX1]REF1(I)    =     func FINDVAL(RESBODY,"Reference1")
[M:SEX1]REF2(I)    =     func FINDVAL(RESBODY,"Reference2")
[M:SEX1]AMT(I)     = val(func FINDVAL(RESBODY,"Amount"))
[M:SEX1]TAXAMT(I)  = val(func FINDVAL(RESBODY,"TaxAmount"))
[M:SEX1]BPCNUM(I)  =     func FINDVAL(RESBODY,"CustomerNumber")
[M:SEX1]ACCNAM(I)  =     func FINDVAL(RESBODY,"FirstName")
[M:SEX1]ADDLIG0(I) =     func FINDVAL(RESBODY,"AddressLine1")
[M:SEX1]ADDLIG1(I) =     func FINDVAL(RESBODY,"AddressLine2")
[M:SEX1]CTY(I)     =     func FINDVAL(RESBODY,"City")
[M:SEX1]SAT(I)     =     func FINDVAL(RESBODY,"State")
[M:SEX1]POSCOD(I)  =     func FINDVAL(RESBODY,"ZipCode")
[M:SEX1]CRY(I)     =     func FINDVAL(RESBODY,"Country")
[M:SEX1]EMAIL(I)   =     func FINDVAL(RESBODY,"EmailAddress")
[M:SEX1]CVV(I)     =     func FINDVAL(RESBODY,"CVVResult")
[M:SEX1]AVS(I)     =     func FINDVAL(RESBODY,"AVSResult")
[M:SEX1]VANREF(I)  =     func FINDVAL(RESBODY,"VANReference")
[M:SEX1]PAYDES(I)  =     func FINDVAL(RESBODY,"PaymentDescription")
[M:SEX1]CRDTYP(I)  =     func FINDVAL(RESBODY,"PaymentTypeID")
[M:SEX1]GUID(I)    =     func FINDVAL(RESBODY,"GUID")
[M:SEX1]EXPDAT(I)  =     func FINDVAL(RESBODY,"ExpirationDate")

[M:SEX1]CREUSR(I)  = GUSER

# Fill in missing fields with SEU
If dim([F:SEU]VCRNUM)>0 & [F:SEU]VCRNUM<>""
  If [M:SEX1]BPCNUM(I)=""  : [M:SEX1]BPCNUM(I)  = [F:SEU]BPCNUM    : Endif
  If [M:SEX1]REF1(I)=""    : [M:SEX1]REF1(I)    = func SEPPLIB.GET_SEUDOC([F:SEU]VCRTYPORI) : Endif
  If [M:SEX1]REF2(I)=""    : [M:SEX1]REF2(I)    = [F:SEU]VCRNUM    : Endif
  If [M:SEX1]PAYDES(I)=""  : [M:SEX1]PAYDES(I)  = [F:SEU]ACCL4D    : Endif
  If [M:SEX1]CRDTYP(I)=""  : [M:SEX1]CRDTYP(I)  = [F:SEU]CRDTYP    : Endif
  If [M:SEX1]EXPDAT(I)=""  : [M:SEX1]EXPDAT(I)  = format$("D:MMYY",[F:SEU]EXPDAT) : Endif
Endif

# Fill in missing fields with SEB
If dim([F:SEB]BPCNUM)>0 & [F:SEB]BPCNUM<>""
  If [M:SEX1]BPCNUM(I)=""  : [M:SEX1]BPCNUM(I)  = [F:SEB]BPCNUM    : Endif
  If [M:SEX1]ACCNAM(I)=""  : [M:SEX1]ACCNAM(I)  = [F:SEB]ACCNAM    : Endif
  If [M:SEX1]ADDLIG0(I)="" : [M:SEX1]ADDLIG0(I) = [F:SEB]ADDLIG(0) : Endif
  If [M:SEX1]ADDLIG1(I)="" : [M:SEX1]ADDLIG1(I) = [F:SEB]ADDLIG(1) : Endif
  If [M:SEX1]CTY(I)=""     : [M:SEX1]CTY(I)     = [F:SEB]CTY       : Endif
  If [M:SEX1]SAT(I)=""     : [M:SEX1]SAT(I)     = [F:SEB]SAT       : Endif
  If [M:SEX1]POSCOD(I)=""  : [M:SEX1]POSCOD(I)  = [F:SEB]POSCOD    : Endif
  If [M:SEX1]CRY(I)=""     : [M:SEX1]CRY(I)     = [F:SEB]CRY       : Endif
  If [M:SEX1]PAYDES(I)=""  : [M:SEX1]PAYDES(I)  = [F:SEB]ACCL4D    : Endif
  If [M:SEX1]CRDTYP(I)=""  : [M:SEX1]CRDTYP(I)  = [F:SEB]CRDTYP    : Endif
  If [M:SEX1]EXPDAT(I)=""  : [M:SEX1]EXPDAT(I)  = format$("D:MMYY",[F:SEB]EXPDAT) : Endif
Endif

If [L]ERRMSG="" & find([M:SEX1]RESP(I),"E","X")
    [L]ERRMSG = [M:SEX1]RSPMSG(I)
Endif

[M:SEX1]NBLIG += 1

# Set variable indicating there is screen data to be saved to the db
[M:SEX1]TOSAVE = 2

End


####################################################################################
# Save the transaction
####################################################################################
Subprog SAVE_TXN(ERR)
Variable Integer ERR

# Skip if txn was already saved
If [M:SEX1]TOSAVE<>2 : End : Endif

WTRBEGIN = adxlog
If !WTRBEGIN : Trbegin [SEX] : Endif

# read from work screen and save to table
For I=0 To [M:SEX1]NBLIG-1
  If [M:SEX1]TXNID(I)="" : I-=1 : Break : Endif

  Look [SEX]SEX0=[M:SEX1]TXNDATTIM(I);[M:SEX1]REQRSP(I);[M:SEX1]TXNID(I)
  If fstat
    Raz [F:SEX]
    [F:SEX]PAYPRC    = [M:SEX1]PAYPRC(I)   # 109253 - Added new processor type field
    [F:SEX]TXNID     = [M:SEX1]TXNID(I)
    [F:SEX]TXNTYP    = [M:SEX1]TXNTYP(I)
    [F:SEX]BPCNUM    = [M:SEX1]BPCNUM(I)
    [F:SEX]REQRSP    = [M:SEX1]REQRSP(I)
    [F:SEX]RESP      = [M:SEX1]RESP(I)
    [F:SEX]RSPCOD    = [M:SEX1]RSPCOD(I)
    [F:SEX]RSPMSG    = [M:SEX1]RSPMSG(I)
    [F:SEX]REF1      = [M:SEX1]REF1(I)
    [F:SEX]REF2      = [M:SEX1]REF2(I)
    [F:SEX]AMT       = [M:SEX1]AMT(I)
    [F:SEX]TAXAMT    = [M:SEX1]TAXAMT(I)
    [F:SEX]CVV       = [M:SEX1]CVV(I)
    [F:SEX]AVS       = [M:SEX1]AVS(I)
    [F:SEX]VANREF    = [M:SEX1]VANREF(I)
    [F:SEX]TXNDATTIM = [M:SEX1]TXNDATTIM(I)
    [F:SEX]TXNDAT    = func SEPPLIB.GET_DATE([M:SEX1]TXNDATTIM(I))
    [F:SEX]CREUSR    = [M:SEX1]CREUSR(I)
    [F:SEX]ACCNAM    = [M:SEX1]ACCNAM(I)
    [F:SEX]ADDLIG(0) = [M:SEX1]ADDLIG0(I)
    [F:SEX]ADDLIG(1) = [M:SEX1]ADDLIG1(I)
    [F:SEX]CTY       = [M:SEX1]CTY(I)
    [F:SEX]SAT       = [M:SEX1]SAT(I)
    [F:SEX]POSCOD    = [M:SEX1]POSCOD(I)
    [F:SEX]CRY       = [M:SEX1]CRY(I)
    [F:SEX]EMAIL     = [M:SEX1]EMAIL(I)
    [F:SEX]PAYDES    = [M:SEX1]PAYDES(I)
    [F:SEX]CRDTYP    = [M:SEX1]CRDTYP(I)
    [F:SEX]GUID      = [M:SEX1]GUID(I)
    [F:SEX]EXPDAT    = [M:SEX1]EXPDAT(I)
    Write [SEX]
    If fstat
      Call FSTA("SEX") From GLOCK
      ERR = 1 : Break
    Endif
  Endif
Next
If !WTRBEGIN
  If ERR
    Rollback
  Else
    # 111808.n - Since the data saved correctly - clear the screen
    Raz [M:SEX1]

    # Clear variable indicating data has been saved to the db
    [M:SEX1]TOSAVE = 0
    Commit
  Endif
Else
  # 111808.n - Since the data saved correctly - clear the screen
  #   Unless PostAut - need to keep it longer - will RAZ second pass through here
  If !ERR & !([F:SEU]POSTAUT=2 & [F:SEU]STAFLG<3) : Raz [M:SEX1] : Endif
Endif

End


####################################################################################
# Function   : CHECKVAL
# Description: Returns "XX" if value is ""
#              Needed when value is required by SE, but not by X3.
####################################################################################
Funprog CHECKVAL(IVALUE)
Value Char IVALUE

If IVALUE="" : IVALUE="XX" : Endif

End IVALUE


####################################################################################
Funprog FINDVAL(RESP,K)
Value    Clbfile  RESP
Value    Char     K
Local Integer X
X = instr(1,RESP,K+'":"')
If !X : End "" : Endif
X += len(K)+3
End seg$(RESP,X,instr(X,RESP,'"')-1)


####################################################################################################
Subprog SEND_REQUEST(FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
  Value    Char    FUNCTION
  Value    Clbfile ARGUMENTS
  Variable Clbfile RESHEAD
  Variable Clbfile RESBODY
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Integer STATUSCODE
  Local Char    MODULE(100)   : MODULE = 'bundles/sage-exchange'
  Local Char    MODE(10)      : MODE   = 'wait'
  Local Char    ENCODINGS(40)
  Local Integer CALLBACKINDEX
  Local Char    RETURNS(50)
  Local Char    RETURNS_ENC(3)

  STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE,FUNCTION,MODE,ARGUMENTS,ENCODINGS,CALLBACKINDEX,RETURNS,RETURNS_ENC,RESHEAD,RESBODY)
  If STATUSCODE<>200
    ERR = 1
    ERRMSG = FUNCTION+":"-num$(STATUSCODE)
  Endif
  RESBODY=unescJson(RESBODY) # 118578.n - Add call to clean up JSON response and remove ESC characters

End


####################################################################################################
# Function   : FormatCurr
# Description: Forces number format to have a . as the decimal separator
#              Introduced for SAM defect # 98909
####################################################################################################
Funprog FORMATCURR(IVALUE)
Value Decimal IVALUE
Local Char OVALUE
Local Char LADXSCA

# The 4th character in the variable adxsca indicates the decimal separator
# Modify that to force a . then set it back to what it was.
LADXSCA = adxsca
adxsca = left$(adxsca,3)+"."+right$(adxsca,len(adxsca)-3)

OVALUE = format$("N:6.2",IVALUE)

adxsca=LADXSCA

End OVALUE

