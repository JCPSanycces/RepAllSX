#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################################
## Xtend:  Gestion champs Xtend    
## Actions
#  Version 0001
######################################################################################
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 
Case ACTION
 When "TRT_DIV"          : Gosub TRT_DIV
# When "SEL_LISTE"        : Gosub SEL_LISTE (voir SUBAYEACT)
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
#      AYFFIEFMTC    FIEFMTCTL     Controle format d'un champ Xtend 
######################################################################################
$TRT_DIV
Case TRAIT
  When "FIEFMTCTL" : Gosub FIE_FMT
Endcase
Return


#    AYFFIEFMT  Controle format d'un champ Xtend
#    Action non utilisée
######################################################################################
# VALEUR        Adresse       Code champ    
#               
$FIE_FMT
Local Integer WI
Local Char    WSTR(1)
For WI=1 To len(VALEUR)
    WSTR=mid$(VALEUR, WI,1)
    If ctrans(WSTR)<>WSTR    # ctrans: carac. std
                mkstat=2 
                GMESSAGE=mess(94,123,1) -'"' +WSTR+ '"'
                Break
    Endif
    If !pat(WSTR,"!")
        If !pat(WSTR,"#")
            If WSTR <> "-" 
                mkstat=2 
                GMESSAGE=mess(94,123,1) -'"' +WSTR+ '"'
                Break
            Endif
        Endif
    Endif
Next
Return
