Funprog TRCHAINE(CHAINE)
Value Char CHAINE()
Local Char RESULT(255)
RESULT='"'
Local Integer I,J
  # Issue 52169 - 2017-09-05 by CCC : Keep " if there is no ' (avoid to replace by a total of 6 char)
  #                                   Keep ' if there is no "
  I=instr(1,CHAINE,"'") :
  If I=0 : End "'"+CHAINE+"'" : Endif

  I=instr(1,CHAINE,'"')
  If I=0 : End '"'+CHAINE+'"' : Endif
  While I
    # Issue 52169 - 2017-09-05 by CCC
    #I=instr(1,CHAINE,"'") : J=instr(1,CHAINE,'"')
    #If (I<>0 and I<J) or (I<>0 and J=0)
      RESULT+=left$(CHAINE,I-1)+'"+DQ+"'
      CHAINE=right$(CHAINE,I+1)
    #Elsif (J<>0)
    #  RESULT+=left$(CHAINE,J-1)+'"+SQ+"'
    #  CHAINE=right$(CHAINE,J+1)
    #Else
    #  RESULT+=CHAINE
    #  Break
    #Endif
    # Issue 52169 - 2017-09-05 by CCC
    I=instr(1,CHAINE,'"')
  Wend
  RESULT+=CHAINE

  If right$(RESULT,len(RESULT)-1)='+"'
    End left$(RESULT,len(RESULT)-2)
  Else
    End RESULT+'"'
  Endif
End

Funprog TABLE(COD,ABRFIC)
Value Char COD
Value Char ABRFIC
Local Char TABLE(GLONATB)
  Read [ALH]ALH0=COD
  If [ALH]TYP=3
    For [ALT]Where COD = [L]COD
      Read [AVWT]CODFIC = [F:ALT]TBL
      If !fstat & [F:AVWT]ABRFIC = [L]ABRFIC
        TABLE = [F:ALT]TBL : Break
      Endif
    Next
  Else
    For [ALD]Where COD = [L]COD
      Read [AVWT]CODFIC = [F:ALD]TBL
      If !fstat & [F:AVWT]ABRFIC = [L]ABRFIC
        TABLE = [F:ALD]TBL : Break
      Endif
    Next ALD
  Endif
End TABLE

# Fix on precision and scale for requests where the length and type is not defined in type Sept 16, 2014
Subprog LNG3(TYP,LNG, FORM,SCALE,PREC)
Value Char TYP
Value Decimal LNG
Variable Char FORM
Variable Integer SCALE,PREC

Local Integer I

  If !clalev([F:ATY2]) : Local File ATYPE [ATY2] : Endif

  Read [F:ATY2]CODTYP = [L]TYP


  PREC=int(LNG)+10*(LNG-int(LNG))
  SCALE=10*(LNG-int(LNG))

  If instr(1,[F:ATY2]OPTION,"F")
#108166
#    SCALE=0
#    FORM="#"
    FORM=string$(LNG>3,"#,##")+"#"+string$(SCALE<>0,"."+string$(SCALE,"#"))
  Else
    FORM=string$(LNG>3,"#,##")+"#"+string$(SCALE<>0,"."+string$(SCALE,"0"))
  Endif
End

#{SAM120181
# Count the number of columns on the table
Funprog MAXCOLSIZ(TABLE,COLUMN,NBCHP)
Value Char TABLE
Value Char COLUMN()
Value Integer NBCHP

Local Integer I,RANG(1..250), TAILLE, DIMCHP
Local File ATABZON, ACTIV, ATABLE

  Read [ATB]CODFIC=TABLE
  For [ATZ] Where CODFIC=TABLE
    For I=1 To NBCHP : If sum("[F:",[ATB]ABRFIC,"]",[ATZ]CODZONE)=vireblc(ctrans(COLUMN(I),"("," "),3) : RANG(I)=TAILLE : Break : Endif : Next I
    If  find([ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0
      DIMCHP=[ATZ]DIME
      If [ATZ]CODACT<>""
          Read [ACV]CODACT=[ATZ]CODACT
          If !fstat
             If [F:ACV]DIMFIL>0 & [F:ACV]DIME>0 & [F:ACV]DIMMAX>0
                   DIMCHP= min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
              Elsif ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
                   DIMCHP=max([F:ACV]DIMFIL,[F:ACV]DIME)
             Endif
             If [F:ACV]FLACT<>2
                  DIMCHP=1
             Endif
          Else
              DIMCHP=1
          Endif
      Endif
      TAILLE+=DIMCHP
    Endif
Next
End max(RANG)
#SAM120181}

# sub-program called at the end of the query execution to unlock the query and move the result in mongoDB file system (Cloud evolution)
$CLEANFILE
Local Integer STAT
Local Char MESSAGE(250)
Local Char FILENA(250)
Local Char X3FOLDER(100)

  I=0 : Repeat X3FOLDER=nomap(I) : I+=1 : Until nomap(I)=''

  For I=1 To dim(PATH_RQT)
    FILENA=filpath("RQT",FILEBASE+num$(I),"req")
    stat1=Delfile(FILENA)
    stat1=func ASYRSYS.MOVEFILE(PATH_RQT(I),FILENA,MESSAGE)
    FILENA=filpath("RQT",FILEBASE+num$(I),"idx")
    stat1=Delfile(FILENA)
    stat1=func ASYRSYS.MOVEFILE(PATH_IDX(I),FILENA,MESSAGE)
  Next I

  If stat1<>0
    ERROR = fmet ACTX.ASETERROR("",MESSAGE,[V]CST_AERROR)
  Endif

Return

# Link to execute reports on a Syracuse page
Subprog EXECREPORT(QUERY)
Value Char QUERY
Local Char RETVALUE(250)
Local Char URL_LAUNCHED(250),ENDPOINT(200), URLPROTOCOL(5)
Local Integer POS1,POS2

If QUERY="" : End : Endif

POS1=instr(1,baseUrl,"/trans")
POS2=instr(1,baseUrl,"/erp")
POS3=instr(1,baseUrl,"http://")
URL_LAUNCH=right$(left$(baseUrl,POS1-1),8)+"/syracuse-main/html/main.html?url=%2Fsdata%2Fx3%2Ferp%2F"
URL_LAUNCH+=right$(baseUrl,POS2+5)+"%2FQUERY('"+QUERY+"')%3Frepresentation%3DQUERY~"+QUERY+"~1.%24query"
URLPROTOCOL = func ASYRFNC.GET_URLPREFIX # Issue X3-62662 - 23-08-2018 by MGO - Display option opens new window (browser tab) - Get HTTP or HTTPS protocol for URL
Callui RETVALUE="" With     "UIAction=" + chr$(1) + "OpenFile",
&                           "UILocalDir=" + chr$(1) + URLPROTOCOL,
&                           "UILocalFile=" + chr$(1) + URL_LAUNCH
End

# Issue X3-54853 - 2018-02-27 by CCC
# see also SAM 116052
#**
#* Get key for tunnel <br>
#* <pre>
#* Ex: PDESCRIPTKEY(1)="FLD1"<br>
#*     PDESCRIPTKEY(2)="FLD2"<br>
#*     PDESCRIPTKEY(3)="FLD3"<br>
#* --> "{FLD2}~{FLD1}~{FLD3}"  (1st and 2nd elements are inverted)
#*</pre>
#* @param PDESCRIPTKEY : Array of key fields to use
#* @param PDESCRIPTLEN : number of key elements
#* @param PFNCKEY      : String with description to use for tunnel
#*!
Subprog SETTUNKEY(PDESCRIPTKEY, PDESCRIPTLEN, PFNCKEY)
Value Char     PDESCRIPTKEY()(1..)
Value Integer  PDESCRIPTLEN
Variable Schar PFNCKEY

Local Integer DESORD(1..4)
Local Integer DESIDX
Local Char DESSEP(1)
DESORD(1)=2
DESORD(2)=1
DESORD(3)=3
DESORD(4)=4

#If DESCRIPT contains more than one part the second one is to be placed in front on the first one:
Sorta min(dim(DESORD),PDESCRIPTLEN) DESORD,PDESCRIPTKEY
PFNCKEY=""
DESSEP=""
For DESIDX=1 To PDESCRIPTLEN
    # The descriptor of a link can use " for fixed values Ex: "" or "C"...
    # => " must be modified with '
    PFNCKEY += DESSEP +  '{' + ctrans(PDESCRIPTKEY(DESIDX),'"',"'") + '}'
    DESSEP='~'
Next DESIDX
End

