$CRIT_CPY
#MABOS-28/02/13-88305
   [L]NBGRP=0
   Call GRP_WITH_CPY_IN([F:FCY]LEGCPY,[F:FCY]FCY,[L]LIS_CPY_GRP,[L]NBGRP ) From SUBCTR
   L_CRITERE = " find([F]CPY, [L]LIS_CPY_GRP(0..[L]NBGRP)) "
