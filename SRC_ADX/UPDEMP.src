#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################################################################
# JML 22/07/10 Gestion UPDEMP Modification en masse employés / Criteria window GENUPDEMP LOT P01
# SEGAY - 31/03/11 - Bug 72823
#              - Mise à jour des champs contrat profil
#              - Convention collective que si GPAYE
# Modification :
#     SEGAY - 13/06/11 - FQ73348 - Trace de MAJ
#     MABOS - 25/02/13 - FQ81085 - US 1335 - Synchronize populations + add question to confirme recording
#     MABOS - 28/02/13 - Bug 88305 - Group of companies
#     MABOS - 09/08/13 - FQ81085 - US1833 - Manage Memo
#     MABOS - 10/10/13 - FQ81085 - US2047 - Modif memo code: emp -> emp1
#########################################################################################################################
Local Char     PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = ""        : #

## GPROG    = Traitement
## GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
## GWINDOW  = Ecran de saisie
## GWINCRIT = Ecran de critères
## Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,GPROGSPE)

Call TRAITE_CHAR(VALEUR,PARAM,"UPDEMP","UPDEMP","GENUPDEMP",4,"") From GTRAITE
End

#########################################
## Traitement des actions : UPDEMP
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 #MABOS-FQ81085-US1833 - manage mémo + FQ91298-US1835
# When "OUVRE"       : If BOITE="GENUPDEMP"
#                       Call LECMEMO("STD","[M:DIA]","emp") From GMEMO
#                       Call AFF_MEMO From DIVPAYE: #81085
#                      Endif
#MABOS-FQ81085-US1833 - manage memo + FQ91298-US1835
 When "OUVRE_BOITE" :
 When "TITRE"       :
 When "DEBUT"       : If BOITE="UPDEMP"
                       Gosub CHARGE_CRIT
                       Gosub CHARGE_MSK
                      Else
                       Affzo [DIA]: Setmok [DIA] With 0
                       #MABOS-FQ81085-US1833 - manage mémo + FQ91298-US1835
                       Call AFF_MEMO2(1) From DIVPAYE: #81085
                       # SEGAY 25/10/12 US 940 81085
#                       If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> "" : GCURLEG=[M:DIA]LEG : Endif :
#                       If BOITE="GENUPDEMP"
#                          Call D_INI([M]INI) From DIVPAYE
#                          Call GRISE_LEG([M]CPY,[M]FCY) From DIVPAYE
#                       Endif
                       #end MABOS-FQ81085-US1833 - manage mémo + FQ91298-US1835
                      Endif
 When "OK"          : If BOITE="GENUPDEMP"
                       BOX = 0 : # To keep [M:DIA] open
                      Elsif BOITE="UPDEMP"
                       Gosub EXEC
                      Endif
 When "END"         : FIN = 1
 When "CONTROLE"    : If GSTATUT<>GSTAOK
                       # To exit If End button is activated on criteria window
                       FIN = 1
                      Endif
 When "EXEC"        : Gosub EXECFIN # SEGAY 25/10/12 US 940 81085
 When "BOUTON"      : Gosub BOUTON # SEGAY 25/10/12 US 940 81085
Endcase
Return

#########################################################################################################################
$INIT
Local Mask   GENUPDEMP [DIA]

Local Char      CRITERE_DAT(GDIMFIC)
Local Char      CRITERE_CPY(GDIMFIC), CRITERE_FCY(GDIMFIC), CRITERE_SRV(GDIMFIC), CRITERE_PRF(GDIMFIC)
Local Char      CRITERE_DEB(GDIMFIC), CRITERE_FIN(GDIMFIC), CRITERE_LIBRE(GDIMFIC), CRITERE_POP(GDIMFIC)
Local Char      CRITERE_POT(GDIMFIC), CRITERE_JOBPOT(GDIMFIC)
Local Char      CRITERE_LEG(GDIMFIC) # SEGAY 25/10/12 US 940 81085
#SEGAY - 13/06/11 - FQ73348 - Trace de MAJ
Local Char SYMBOLE (80)
#END- FQ73348
Gosub OUVFIC
Raz [M:DIA] # SEGAY 25/10/12 US 940 81085
#MABOS-FQ81085-US1833 - manage mémo
Call INI_LEG From DIVPAYE
Call LECMEMO("STD","[M:DIA]","emp1") From GMEMO :#MABOS-FQ81085-US2047
#end MABOS-FQ81085-US1833 - manage mémo
Return
######################################################
## Ouverture des tables
######################################################
$OUVFIC
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND    [ATI] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE     [ATX] : Endif
If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
If clalev([F:DIC])=0 : Local File DICOEMP    [DIC] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:HRSMH])=0 : Local File SCREMPH    [HRSMH] : Endif
If clalev([F:HRSMD])=0 : Local File SCREMPD    [HRSMD] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR     [ECT] : Endif
If clalev([F:JOD])=0 : Local File JOBTYPDEF  [JOD] : Endif
If clalev([F:POD])=0 : Local File POSTEDEF   [POD] : Endif
#SEGAY 72823
If clalev([F:HRPFD])=0 : Local File PROFILDEF  [HRPFD] : Endif
# SEGAY 25/10/12 US 940 81085
If clalev([F:AGC])=0  : Local File AGRPCPY  [AGC]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP  [FGR]  : Endif : #MABOS-25/02/13-FQ81085-US1335-Synchronize populations

Gosub OUVRE From WPDEFTABLE

Return
#########################################################################################################################
$CHARGE_CRIT
Local Char    LIS_CPY(GLONCPY)(0..100) # SEGAY 25/10/12 US 940 81085

CRITERE_DAT  = '[F:HRCTR]CTRDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']'
CRITERE_DAT += '&([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+format$(GFMD,[M:DIA]DATDEB)+'])'

# SEGAY 25/10/12 US 940 81085
#If [M:DIA]CPY<>""
# CRITERE_CPY = "[F:FCY]LEGCPY='"+[M:DIA]CPY+"'"
#Else
# CRITERE_CPY = "1=1"
#Endif
  CRITERE_CPY = "1=1"
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITERE_CPY -= "& find([F:FCY]LEGCPY,"
      For K=0 To I-1
        CRITERE_CPY += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERE_CPY += "," : Endif
      Next
      CRITERE_CPY += ")>0"
    Else
      If [M:DIA]CPY <> ""
        CRITERE_CPY="1=2"
      Endif
    Endif
  Endif


If [M:DIA]FCY<>""
 CRITERE_FCY = "[F:HRCTR]ETRFCY='"+[M:DIA]FCY+"'"
Else
 CRITERE_FCY = "1=1"
Endif

If [M:DIA]SRV<>""
 CRITERE_SRV = "[F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"
Else
 CRITERE_SRV = "1=1"
Endif

If [M:DIA]PRF<>""
 CRITERE_PRF = "[F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"
Else
 CRITERE_PRF = "1=1"
Endif

If [M:DIA]MATDEB<>""
 CRITERE_DEB = '[F:HRCTR]REFNUM>="'+[M:DIA]MATDEB+'"'
Else
 CRITERE_DEB = "1=1"
Endif

If [M:DIA]MATFIN<>""
 CRITERE_FIN = '[F:HRCTR]REFNUM<="'+[M:DIA]MATFIN+'"'
Else
 CRITERE_FIN = "1=1"
Endif

If [M:DIA]CRITERE<>""
 CRITERE_LIBRE = [M:DIA]CRITERE
Else
 CRITERE_LIBRE = "1=1"
Endif

If [M:DIA]POT<>""
 CRITERE_POT = "[F:HRCTR]POT='"+[M:DIA]POT+"'"
Else
 CRITERE_POT = "1=1"
Endif

If [M:DIA]JOBPOT<>""
 CRITERE_JOBPOT = "[F:HRCTR]JOBPOT='"+[M:DIA]JOBPOT+"'"
Else
 CRITERE_JOBPOT = "1=1"
Endif

######
#Liens pour gestion des critères...
CRITERE_POP = "1=1"  # SEGAY 25/10/12 US 940 81085
If [M:DIA]POP<>""
# CRITERE_POP = "[F:HRPOA]REFNUM<>''"
 CRITERE_POP += "& [F:HRPOA]REFNUM<>'' & [F:HRPOA]CTRNUM<>''"  # SEGAY 25/10/12 US 940 81085
Endif
######
# SEGAY 25/10/12 US 940 81085
CRITERE_LEG= "1=1"
If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> ""
  CRITERE_LEG += "& (find([F:FCY]LEG,'"+[M:DIA]LEG+"','')>0)"
Endif

Return
#########################################################################################################################
$CHARGE_MSK
Local Integer   L_OK, L_IJ, L_DEBSAL
Local Char      L_BIDON(GDIMFIC), L_BIDON2(GDIMFIC)
Local Char      L_POPUL(GLONPOP)(0..)
Local Integer   L_NB_POPUL
#MABOS-25/02/13-FQ81085-US1335-Synchronize populations
Local Integer   L_POPMAJTYP(0..) : # Tableau des Types(Manuelle/Auto) Pop du salarié
Local Char      L_CRITERE(GDIMFIC)
#MABOS-28/02/13-88305
Local Integer   NBGRP
Local Char      LIS_CPY_GRP(GLONCPY)(0..100)
# SEGAY 25/10/12 US 940 81085
#Link [HRCTR] With [ID]ID0   = [F:HRCTR]REFNUM
#&             , [FCY]FCY0 = [F:HRCTR]ETRFCY
#&          As [LCTR]

If CRITERE_POP<>"1=1" Then

  Link [HRCTR] With [ID]ID0   = [F:HRCTR]REFNUM
&                   , [FCY]FCY0 = [F:HRCTR]ETRFCY
&                   , [HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&              As [LCTR]
&              Where evalue(CRITERE_LEG) # SEGAY 25/10/12 US 940 81085
Else
  Link [HRCTR] With [ID]ID0   = [F:HRCTR]REFNUM
&             , [FCY]FCY0 = [F:HRCTR]ETRFCY
&          As [LCTR]
&              Where evalue(CRITERE_LEG) # SEGAY 25/10/12 US 940 81085
Endif
#Onerrgo ERREUR

Raz [M:UPDE]

If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> "" : GCURLEG=[M:DIA]LEG : Endif : # SEGAY 25/10/12 US 940 81085

GERR   = 0
nolign = 0

For [LCTR]CTR0(2) Where evalue(CRITERE_DAT)
&                     & evalue(CRITERE_CPY) & evalue(CRITERE_FCY)
&                     & evalue(CRITERE_SRV) & evalue(CRITERE_PRF)
&                     & evalue(CRITERE_DEB) & evalue(CRITERE_FIN)
&                     & evalue(CRITERE_POP)
&                     & evalue(CRITERE_POT) & evalue(CRITERE_JOBPOT)
&                     & [F:ID]ENAFLG=2
 L_OK = 1
  Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,CRITERE_LIBRE,L_OK,1) From DIVPAYE
 If L_OK
  For [LCTR]CTR0
   L_DEBSAL = nolign
   #MABOS-05/11/12-Modif parameters of CHARGE_POPUL
   Call CHARGE_POPUL([F:HRCTR]REFNUM,L_POPUL,L_NB_POPUL,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,L_POPMAJTYP) From SUBCTR
   # Population
   For L_IJ=0 To L_NB_POPUL-1
    L_CRITERE = "[F]POP='"+L_POPUL(L_IJ)+"'"
    Gosub CHARGE_DEFPOT
    If nolign>=dim([M:UPDE]REFNUM)
     Break(3)
    Endif
   Next L_IJ

   # Convention
   #SEGAY 31/03/11 BUG 72823  convention que si GPAYE
   If GPAYE
     L_CRITERE = "[F]CLLCVT='"+[F:HRCTR]CLLCVT+"'"
     Gosub CHARGE_DEFPOT
     If nolign>=dim([M:UPDE]REFNUM)
      Break(2)
     Endif
   Endif
   # Facility
   L_CRITERE = "[F]FCY='"+[F:FCY]FCY+"'"
   Gosub CHARGE_DEFPOT
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

   # Company
   #MABOS-28/02/13- 88305
#   L_CRITERE = "[F]CPY='"+[F:FCY]LEGCPY+"'"
## SEGAY 25/10/12 US 940 81085
## On teste les groupes de société
#   Filter [F:AGC] Where CPY=[F:FCY]LEGCPY and [F:AGC]GRP <> [F:FCY]LEGCPY
#   Read [F:AGC]AGC1 First
#   If !fstat
#     L_CRITERE += " or [F]CPY='"+[F:AGC]GRP+"'"
#   Endif
#   Filter [F:AGC]
   Gosub CRIT_CPY
   #end MABOS-28/02/13- 88305
   Gosub CHARGE_DEFPOT
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

# SEGAY 25/10/12 US 940 81085
   # LEG
   If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> ""
     L_CRITERE = "[F]LEGLEV='"+[M:DIA]LEG+"'"
     Gosub CHARGE_DEFPOT
     If nolign>=dim([M:UPDE]REFNUM)
      Break(2)
     Endif
   Endif

   # Every body, need somebody (Jake & Elwood^^)
   #SEGAY 31/03/11 BUG 72823  convention que si GPAYE
   If GPAYE
     L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]CLLCVT=''&[F]POP=''&[F]LEGLEV=''"
   Else
     L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]POP=''&[F]LEGLEV=''"
   Endif
   Gosub CHARGE_DEFPOT
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

   #######################################################################
   # Population
   For L_IJ=0 To L_NB_POPUL-1
    L_CRITERE = "[F]POP='"+L_POPUL(L_IJ)+"'"
    Gosub CHARGE_DEFJOT
    If nolign>=dim([M:UPDE]REFNUM)
     Break(3)
    Endif
   Next L_IJ

   # Convention
   #SEGAY 31/03/11 BUG 72823  convention que si GPAYE
   If GPAYE
     L_CRITERE = "[F]CLLCVT='"+[F:HRCTR]CLLCVT+"'"
     Gosub CHARGE_DEFJOT
     If nolign>=dim([M:UPDE]REFNUM)
      Break(2)
     Endif
   Endif

   # Facility
   L_CRITERE = "[F]FCY='"+[F:FCY]FCY+"'"
   Gosub CHARGE_DEFJOT
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

   # Company
   #MABOS-28/02/13- 88305
#   L_CRITERE = "[F]CPY='"+[F:FCY]LEGCPY+"'"
## SEGAY 25/10/12 US 940 81085
## On teste les groupes de société
#   Filter [F:AGC] Where CPY=[F:FCY]LEGCPY and [F:AGC]GRP <> [F:FCY]LEGCPY
#   Read [F:AGC]AGC1 First
#   If !fstat
#     L_CRITERE += " or [F]CPY='"+[F:AGC]GRP+"'"
#   Endif
#   Filter [F:AGC]
   Gosub CRIT_CPY
   #end MABOS-28/02/13- 88305
   Gosub CHARGE_DEFJOT
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

# SEGAY 25/10/12 US 940 81085
   # LEG
   If dim([M:DIA]LEG)>0 & [M:DIA]LEG <> ""
     L_CRITERE = "[F]LEGLEV='"+[M:DIA]LEG+"'"
     Gosub CHARGE_DEFJOT
     If nolign>=dim([M:UPDE]REFNUM)
      Break(2)
     Endif
   Endif

   # Every body, need somebody (Jake & Elwood^^)
   #SEGAY 31/03/11 BUG 72823  convention que si GPAYE
   If GPAYE
     L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]CLLCVT=''&[F]POP=''&[F]LEGLEV=''"
   Else
     L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]POP=''&[F]LEGLEV=''"
   Endif
   Gosub CHARGE_DEFJOT
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

   #######################################################################
#SEGAY 31/03/11 BUG 72823
# Chargement valeur par défaut du profil
   # Population
   For L_IJ=0 To L_NB_POPUL-1
    L_CRITERE = "[F]POP='"+L_POPUL(L_IJ)+"'"
    Gosub CHARGE_DEFPRF
    If nolign>=dim([M:UPDE]REFNUM)
     Break(3)
    Endif
   Next L_IJ

   # Convention
   #SEGAY 31/03/11 BUG 72823  convention que si GPAYE
   If GPAYE
     L_CRITERE = "[F]CLLCVT='"+[F:HRCTR]CLLCVT+"'"
     Gosub CHARGE_DEFPRF
     If nolign>=dim([M:UPDE]REFNUM)
      Break(2)
     Endif
   Endif

   # Facility
   L_CRITERE = "[F]FCY='"+[F:FCY]FCY+"'"
   Gosub CHARGE_DEFPRF
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

   # Company
   #MABOS-28/02/13- 88305
#   L_CRITERE = "[F]CPY='"+[F:FCY]LEGCPY+"'"
## SEGAY 25/10/12 US 940 81085
## On teste les groupes de société
#   Filter [F:AGC] Where CPY=[F:FCY]LEGCPY and [F:AGC]GRP <> [F:FCY]LEGCPY
#   Read [F:AGC]AGC1 First
#   If !fstat
#     L_CRITERE += " or [F]CPY='"+[F:AGC]GRP+"'"
#   Endif
#   Filter [F:AGC]
   Gosub CRIT_CPY
   #end MABOS-28/02/13- 88305
   Gosub CHARGE_DEFPRF
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif

   # Every body, need somebody (Jake & Elwood^^)
   #SEGAY 31/03/11 BUG 72823  convention que si GPAYE
   If GPAYE
     L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]CLLCVT=''&[F]POP=''"
   Else
     L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]POP=''"
   Endif
   Gosub CHARGE_DEFPRF
   If nolign>=dim([M:UPDE]REFNUM)
    Break(2)
   Endif
#END_BUG 72823
  Next : # [LCTR]CTR0
 Endif : # If L_OK
Next : # [LCTR]CTR0(2)
If GERR : Return : Endif
Onerrgo
[M:UPDE]NBLIG = nolign
Affzo [UPDE]
Return
#########################################################################################################################
$CHARGE_DEFPOT
If [F:HRCTR]POT="" : Return : Endif
For [POD]POD0 Where [F:POD]COD=[F:HRCTR]POT & [F:POD]VALDEF<>""
&                 & evalue(L_CRITERE)
 If nolign>=dim([M:UPDE]REFNUM)
  Call ERREUR(mess(161,115,1)) From GESECRAN : Break
  #### Trop de lignes
 Endif
 L_BIDON = num$(evalue("[F:HRCTR]"+[F:POD]FLD))
 L_BIDON2 = L_BIDON
 Call CONTROLE(L_BIDON2,[F:POD]CODTYP,[F:POD]NOLIB,[F:POD]LONG,L_BIDON) From FMTVAR
#Infbox L_BIDON-"-"-L_BIDON2-"/"-[F:POD]VALINT
 If L_BIDON<>[F:POD]VALINT & !find([F:POD]FLD,[M:UPDE]FLD001(L_DEBSAL..nolign))
  nolign += 1
  [M:UPDE] = [F:ID]
  [M:UPDE] = [F:HRCTR]
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  [M:UPDE]CPY(nolign-1) =[F:FCY]LEGCPY
  [M:UPDE]DES001(nolign-1)     = [F:POD]TIT
  [M:UPDE]CODTYP001(nolign-1)  = [F:POD]CODTYP
  [M:UPDE]NOLIB001(nolign-1)   = [F:POD]NOLIB
  [M:UPDE]LONG001(nolign-1)    = [F:POD]LONG
  [M:UPDE]OVALINT001(nolign-1) = L_BIDON          : # Valeur 'Interne'
  [M:UPDE]OCOL001(nolign-1)    = L_BIDON          : # Valeur 'Affichée'
  Call CONTROLE([M:UPDE]OCOL001(nolign-1),[F:POD]CODTYP,[F:POD]NOLIB,[F:POD]LONG,[M:UPDE]OVALINT001(nolign-1)) From FMTVAR
  [M:UPDE]OVALPAR001(nolign-1) = [F:POD]VALPAR
  [M:UPDE]VALPAR001(nolign-1)  = [F:POD]VALPAR
  [M:UPDE]VALINT001(nolign-1)  = [F:POD]VALINT    : # Valeur 'Interne'
  [M:UPDE]COL001(nolign-1)     = [F:POD]VALDEF    : # Valeur 'Affichée'
  [M:UPDE]FLD001(nolign-1)     = [F:POD]FLD
  [M:UPDE]UPD(nolign-1)        = 2                : # SEGAY 25/10/12 US 940 81085
 Endif
Next : # [POD]POD0
Return
#########################################################################################################################
$CHARGE_DEFJOT
If [F:HRCTR]JOBPOT="" : Return : Endif
For [JOD]JOD0 Where [F:JOD]COD=[F:HRCTR]JOBPOT & [F:JOD]VALDEF<>""
&                 & evalue(L_CRITERE)
 If nolign>=dim([M:UPDE]REFNUM)
  Call ERREUR(mess(161,115,1)) From GESECRAN : Break
  #### Trop de lignes
 Endif
 L_BIDON = num$(evalue("[F:HRCTR]"+[F:JOD]FLD))
 L_BIDON2 = L_BIDON
 Call CONTROLE(L_BIDON2,[F:JOD]CODTYP,[F:JOD]NOLIB,[F:JOD]LONG,L_BIDON) From FMTVAR
#Infbox L_BIDON-"-"-L_BIDON2-"\"-[F:JOD]VALINT
 If L_BIDON<>[F:JOD]VALINT & !find([F:JOD]FLD,[M:UPDE]FLD001(L_DEBSAL..nolign))
  nolign += 1
  [M:UPDE] = [F:ID]
  [M:UPDE] = [F:HRCTR]
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  [M:UPDE]CPY(nolign-1) =[F:FCY]LEGCPY
  [M:UPDE]DES001(nolign-1)     = [F:JOD]TIT
  [M:UPDE]CODTYP001(nolign-1)  = [F:JOD]CODTYP
  [M:UPDE]NOLIB001(nolign-1)   = [F:JOD]NOLIB
  [M:UPDE]LONG001(nolign-1)    = [F:JOD]LONG
  [M:UPDE]OVALINT001(nolign-1) = L_BIDON          : # Valeur 'Interne'
  [M:UPDE]OCOL001(nolign-1)    = L_BIDON          : # Valeur 'Affichée'
  Call CONTROLE([M:UPDE]OCOL001(nolign-1),[F:JOD]CODTYP,[F:JOD]NOLIB,[F:JOD]LONG,[M:UPDE]OVALINT001(nolign-1)) From FMTVAR
  [M:UPDE]OVALPAR001(nolign-1) = [F:JOD]VALPAR
  [M:UPDE]VALPAR001(nolign-1)  = [F:JOD]VALPAR
  [M:UPDE]VALINT001(nolign-1)  = [F:JOD]VALINT    : # Valeur 'Interne'
  [M:UPDE]COL001(nolign-1)     = [F:JOD]VALDEF    : # Valeur 'Affichée'
  [M:UPDE]FLD001(nolign-1)     = [F:JOD]FLD
  [M:UPDE]UPD(nolign-1)        = 2                : # SEGAY 25/10/12 US 940 81085
 Endif
Next : # [JOD]JOD0
Return
#########################################################################################################################
#########################################################################################################################
#SEGAY 72823
$CHARGE_DEFPRF
If [F:HRCTR]PROPRF="" : Return : Endif
For [HRPFD]PFD0 Where [F:HRPFD]PRFCOD=[F:HRCTR]PROPRF & [F:HRPFD]LEG=[F:FCY]LEG & [F:HRPFD]VALDEF<>""
&                 & evalue(L_CRITERE)
 If nolign>=dim([M:UPDE]REFNUM)
  Call ERREUR(mess(161,115,1)) From GESECRAN : Break
  #### Trop de lignes
 Endif
 L_BIDON = num$(evalue("[F:HRCTR]"+[F:HRPFD]FLD))
 L_BIDON2 = L_BIDON
 Call CONTROLE(L_BIDON2,[F:HRPFD]CODTYP,[F:HRPFD]NOLIB,[F:HRPFD]LONG,L_BIDON) From FMTVAR
#Infbox L_BIDON-"-"-L_BIDON2-"\"-[F:PFD]VALINT
 If L_BIDON<>[F:HRPFD]VALINT & !find([F:HRPFD]FLD,[M:UPDE]FLD001(L_DEBSAL..nolign))
  nolign += 1
  [M:UPDE] = [F:ID]
  [M:UPDE] = [F:HRCTR]
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  [M:UPDE]CPY(nolign-1) =[F:FCY]LEGCPY
  [M:UPDE]DES001(nolign-1)     = [F:HRPFD]TIT
  [M:UPDE]CODTYP001(nolign-1)  = [F:HRPFD]CODTYP
  [M:UPDE]NOLIB001(nolign-1)   = [F:HRPFD]NOLIB
  [M:UPDE]LONG001(nolign-1)    = [F:HRPFD]LONG
  [M:UPDE]OVALINT001(nolign-1) = L_BIDON          : # Valeur 'Interne'
  [M:UPDE]OCOL001(nolign-1)    = L_BIDON          : # Valeur 'Affichée'
  Call CONTROLE([M:UPDE]OCOL001(nolign-1),[F:HRPFD]CODTYP,[F:HRPFD]NOLIB,[F:HRPFD]LONG,[M:UPDE]OVALINT001(nolign-1)) From FMTVAR
  [M:UPDE]OVALPAR001(nolign-1) = [F:HRPFD]VALPAR
  [M:UPDE]VALPAR001(nolign-1)  = [F:HRPFD]VALPAR
  [M:UPDE]VALINT001(nolign-1)  = [F:HRPFD]VALINT    : # Valeur 'Interne'
  [M:UPDE]COL001(nolign-1)     = [F:HRPFD]VALDEF    : # Valeur 'Affichée'
  [M:UPDE]FLD001(nolign-1)     = [F:HRPFD]FLD
  [M:UPDE]UPD(nolign-1)        = 2                : # SEGAY 25/10/12 US 940 81085
 Endif
Next : # [PFD]PFD0
Return
######################################################
$ERREUR
Resume
######################################################
## It begins here...
######################################################
#  - On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
# en réel après l'avoir lancé en simulation)
# SEGAY 25/10/12 US 940 81085
$EXECFIN
  If BOITE="UPDEMP"
     SAI=1
  Endif
Return


$EXEC
#SEGAY - 13/06/11 - FQ73348 - Trace de MAJ
Local  Integer NBENREG_CTR
Local  Char    L_MESSAGE(250)
Local  Char    L_CONTRAT(250)
Local  Char    L_SAV_CONTRAT(250)
Local  Integer WOK # MABOS-25/02/2013-FQ 81085-US1336-Confirmation enreg

# MABOS-25/02/2013-FQ 81085-US1335-add question to confirme recording
Call OUINON(mess(162,10701,1), [L]WOK) From GESECRAN : # Confirmez-vous l'enregistrement des modifications pour les lignes cochées ?
If [L]WOK = 1 Then SAI=1 : Return : Endif

Raz L_MESSAGE,L_CONTRAT,L_SAV_CONTRAT
SYMBOLE = "UPDEMP"
Lock =SYMBOLE
If fstat
  GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
  Unlock =SYMBOLE
  GERR = 1 : SAI = 1 : Return
Endif
TIT = mess(116,10701,1) : # Mise à jour des contrats des salariés
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#END - FQ73348 - Trace de MAJ

# MABOS-25/02/13-FQ 81085-US1336-synchronize the populations
If [M:DIA]FLGPOP = 2 Then
Gosub OUVRE_POPUL From SUBEML
Gosub DEFPOP From SUBPOP
Endif
# end MABOS-25/02/13-FQ 81085-US1336

For L_IJ=0 To [M:UPDE]NBLIG-1
 If [M:UPDE]UPD(L_IJ)=2
  Gosub TR1
  If GOK<1 : Break : Endif
 Endif
Next L_IJ

#SEGAY - 13/06/11 - FQ73348 - Trace de MAJ
Unlock =SYMBOLE

# Gestion de la trace
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If NBENREG_CTR>0  Then
  Call ECR_TRACE(mess(117,10701,1)-":"-num$(NBENREG_CTR),0) From GESECRAN : # Nombre de contrat mise à jour
Else
  Call ECR_TRACE(mess(118,10701,1),0) From GESECRAN : # Aucun contrat à traiter
Endif
Call FERME_TRACE From LECFIC
# Lecture de la trace, sinon avec la nouvelle étiquette EXEC, on ne la voit pas
Call LEC_TRACE From LECFIC
GMESSAGE=""
#END - FQ73348 - Trace de MAJ

Return
##############
$TR1
GOK = 1
Call DEBTRANS From GLOCK
Trbegin [F:HRCTR]
 GCLE = [M:UPDE]REFNUM(L_IJ)+"|"+[M:UPDE]CTRNUM(L_IJ)+"|"+[M:UPDE]CTRDAT(L_IJ)
 Readlock [HRCTR]CTR0=[M:UPDE]REFNUM(L_IJ);[M:UPDE]CTRNUM(L_IJ);[M:UPDE]CTRDAT(L_IJ)
 If fstat=1
  GOK = -1 : GLOCK = "$EMPLOCTR"-GCLE : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("HRCTR",GCLE) From GLOCK : Goto AB_TR1
 Endif
 # Small problem with numerical values....
 Case evalue("type([F:HRCTR]"+[M:UPDE]FLD001(L_IJ)+")")
  When 1,2,4,5,6,7
       Assign "[F:HRCTR]"+[M:UPDE]FLD001(L_IJ) With val([M:UPDE]VALINT001(L_IJ))
  When Default
       Assign "[F:HRCTR]"+[M:UPDE]FLD001(L_IJ) With [M:UPDE]VALINT001(L_IJ)
 Endcase
 Rewrite [HRCTR]
 If fstat
  GOK = 0 : Call FSTA("HRCTR") From GLOCK
 Endif
 If GOK=-1 : Goto ROLL_TR1
 Elsif GOK<1 : Goto AB_TR1
 Endif

#SEGAY - 13/06/11 - FQ73348 - Trace de MAJ
 L_MESSAGE =""
 L_CONTRAT = [M:UPDE]REFNUM(L_IJ)+[M:UPDE]CTRNUM(L_IJ)+format$("D:"+GFMDAT,[M:UPDE]CTRDAT(L_IJ))
 If L_CONTRAT <> L_SAV_CONTRAT
   L_SAV_CONTRAT = L_CONTRAT
   NBENREG_CTR+=1
   L_MESSAGE = space$(3)+mess(5,10935,1)-[M:UPDE]REFNUM(L_IJ)-"/"-mess(72,10720,1)-[M:UPDE]CTRNUM(L_IJ)-":"+chr$(13)+chr$(10)
   L_MESSAGE+= space$(4)+mess(274,142,1)-[M:UPDE]DES001(L_IJ)+chr$(13)+chr$(10)
 Else
   L_MESSAGE = space$(4)+mess(274,142,1)-[M:UPDE]DES001(L_IJ)+chr$(13)+chr$(10)
 Endif

 L_MESSAGE+= space$(5)+mess(205,197,1)-" : "-mess(130,6000,1)-[M:UPDE]OVALINT001(L_IJ)+chr$(13)+chr$(10)
 L_MESSAGE+= space$(5)+mess(206,197,1)-" : "-mess(130,6000,1)-[M:UPDE]VALINT001(L_IJ)
 Call ECR_TRACE(L_MESSAGE,0) From GESECRAN : # Matricule / Contrat : Champ ... avant ... aprés
#END - FQ73348 - Trace de MAJ
 # MABOS-25/02/13-FQ 81085-US1336-synchronize the populations
  If (L_IJ+1 > ([M:UPDE]NBLIG-1))
&   | (L_CONTRAT <>[M:UPDE]REFNUM(L_IJ+1)+[M:UPDE]CTRNUM(L_IJ+1)+format$("D:"+GFMDAT,[M:UPDE]CTRDAT(L_IJ+1)) )
    If [M:DIA]FLGPOP = 2 Then
       Gosub POPUL_CTR From SUBEML
       If GOK=-1 : Goto ROLL_TR1
       Elsif GOK<1 : Goto AB_TR1
       Else   Call ECR_TRACE(space$(4)+mess(163,10701,1),0) From GESECRAN :#Mise à jour des populations effectuée'
       Endif
     Endif
   Endif


Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return
