#-----------------------------------#
Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
If GCONSULT
 Diszo [M:DIA]
Endif
End

#----------------------------------#
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

#-----------------------------#
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

Local Integer ASTATUS

If VALEUR=1
 Raz [DIA]VOLFIL, [DIA]FIC
 Grizo [DIA]VOLFIL
Else
 Actzo [DIA]VOLFIL
Endif
Affzo [DIA]VOLFIL
End
#
#-------------------------------------------------------#
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Integer ASTATUS

#Control that the file exists :
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
If [M]TYPEXP=2
 ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FOLDER,GMESSAGE)
 If ASTATUS<>CST_AOK
  ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FILEREAD,GMESSAGE)
  If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
 Endif
Else
 ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FILEREAD,GMESSAGE)
 If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
Endif

GFICPATH = [M]FIC

End
