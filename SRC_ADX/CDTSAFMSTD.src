#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management IMPCDTSAF

$ACTION

Case ACTION
  When "INIT"        : Gosub INIT
  When "OUVRE_BATCH" : Gosub INIT
  When "EXEC"        : Gosub EXEC
Endcase

Return
#################################################################################################
#################################################################################################
$INIT

Local Integer STAT
Local Char    FILORI(250)
Local Char    FILDES(250)
Local Integer PRIVTRACE

Local Integer OK , STAT
Local Char    TEXTE(250)
Local Char    WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(10)
Local Char    OGTRACE(GDIMFIC)
TRA = 1

Local Mask    IMPCDTSAF [DIA]
Local File    ADOSSIER [ADS], ADOSACT [ADA]

Raz [M:DIA]

Raz [M:DIA]
[M:DIA]FIC = GFICPATH
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
  [M]VOLFIL = "[TMP]"
Endif
Actzo [M]VOLFIL,TYPEXP
Return
#################################################################################################
#################################################################################################
$EXEC

[L]PRIVTRACE = 0
If GTRACE = ""
  [L]PRIVTRACE = 1
  Call OUVRE_TRACE (mess(117,7711,1)) From LECFIC
Endif

If dim([L]OK)<=0
  Local Integer OK : OK = 1
Endif
#Gosub LIC_CONTROLE From XPCDTAT
If !OK : Return : Endif


#[L]FILORI = [M:DIA]FILNAM
#[L]FILDES = filpath('TMP', 'AT_DTCOD_'+format$("D:DDMMYYYYhhmmss", date$),'xml')

#If [M:DIA]TYPFIL = 1
#  If [L]FILORI<>""
#    If GOS(0)="unix"
#      If right$([L]FILORI,len([L]FILORI))<>"/" : [L]FILORI += "/" : Endif
#    Else
#      If right$([L]FILORI,len([L]FILORI))<>"\" : [L]FILORI += "\" : Endif
#    Endif
#  Endif
#  Call COPSRV([L]FILORI, [L]FILDES, [L]STAT) From ORDSYS
#  If STAT : Call ERREUR (mess(122,7711,1) + " ("+num$([L]STAT)+")") From GESECRAN : Endif #TODO Check message
#Else
#  Call COPIE([L]FILORI, [L]FILDES, [L]STAT) From ORDSYS
#  If STAT : Call ERREUR (mess(122,7711,1) + " ("+num$([L]STAT)+")") From GESECRAN : Endif
#Endif
#
#If filinfo([L]FILDES,7) <= 0
#  Return
#Endif

WFICHIER = [M:DIA]FIC
If [M:DIA]TYPEXP=1
 WFICCLI = [M:DIA]FIC
 Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
 Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
 If STAT : FIN = 1 : Return : Endif
 GFICPATH = WFICCLI
Else
 WFICCLI = ""
Endif
Call IMPORTCODES([L]WFICHIER)

If [L]PRIVTRACE = 1
  Call FERME_TRACE From LECFIC
  If !GSERVEUR
    Call LEC_TRACE From LECFIC
  Endif
Endif

Return
#################################################################################################
#################################################################################################
Subprog IMPORTCODES(P_FILE)
Value Char P_FILE

Gosub OPEN_TABLES
Gosub DECLARE_VARS

[L]LTRT = "CDTSAFMSTD"
Gosub PARSE_XML From PORXMLLIB

End
##################################################################################################
##################################################################################################
$INI_TAG
#Do not delete this label, altough it is empty it is used for the XMLLIB interface and it is called.
Return
##################################################################################################
##################################################################################################
$VAL_TAG
#Do not delete this label, altough it is empty it is used for the XMLLIB interface and it is called.
Return
##################################################################################################
##################################################################################################
$END_TAG
Raz [L]COMSTA

Case LTAG
  When "</DocumentNumber>"
    [L]DOCNUM    = [L]LVAL
  When "</ATDocCodeID>"
    [L]ATRETCOD  = [L]LVAL
      Gosub SAVE_COD
  When "</ErrorMessage>"
    [L]ERRMESS   = [L]LVAL
  When "</LineNumber>"
    [L]ERRLINNUM = [L]LVAL
    If [L]ERRLINNUM ='0'
      [L]DOCNUM   = vireblc(left$([L]ERRMESS,instr(1,[L]ERRMESS,' - ')),1)
      [L]ATRETCOD = '0'
      [L]COMSTA   = [L]ERRMESS
      Gosub SAVE_COD
      Call ECR_TRACE  (mess(121,7711,1) - [L]ERRLINNUM + ": " + [L]ERRMESS, -1)   From GESECRAN
    Else
      Gosub WRITE_ERROR
    Endif
  When "</FileProcResult>"
    [L]SAVFSTAT= 9 #not necessary
Endcase

Return
##################################################################################################
##################################################################################################
$SAVE_COD

If [L]DOCNUM <> "" & [L]ATRETCOD <> ""
  Read [F:DKD]DKD1 = "SAFT-PT";[L]DOCNUM
  If !fstat
    If [F:DKD]ATDTCOD <> "" #check if the document have been already communicated with sucess
      Call ECR_TRACE(func AFNC.MES1(mess(109,7711,1), [L]DOCNUM), 1) From GESECRAN
    Else
      Trbegin [F:DKD]
      [F:DKD]ATDTCOD    = [L]ATRETCOD
      If [L]COMSTA <>''
        [F:DKD]ATDTCOMSTA= [L]COMSTA
      Else
        [F:DKD]ATDTCOMSTA = "0"
      Endif
      [F:DKD]ATDTINPTYP = 2
      [F:DKD]ATDTRECDAT = date$
      [F:DKD]ATDTRECTIM = time$
      Rewrite [F:DKD]
      If fstat
        Rollback
        Call ECR_TRACE(mess(118,7711,1) - [L]DOCNUM + " - " +[L]ATRETCOD, 1) From GESECRAN
      Else
        Commit
        Call ECR_TRACE([L]DOCNUM + " - " +[L]ATRETCOD, 0) From GESECRAN
      Endif
    Endif
  Else
    Call ECR_TRACE(mess(119,7711,1) - [L]DOCNUM, 1) From GESECRAN
  Endif
Else
  Call ECR_TRACE(mess(120,7711,1) - [L]DOCNUM + " - " +[L]ATRETCOD, 1) From GESECRAN
Endif

Return
##################################################################################################
##################################################################################################
$OPEN_TABLES

Local File DKSDATA [DKD]

Return
##################################################################################################
##################################################################################################
$DECLARE_VARS

Local Char DOCNUM(50)
Local Char ATRETCOD(200)
Local Char ERRMESS(255)
Local Char ERRLINNUM(10)
Local Char COMSTA(250)
Local Char LTRT

Return
##################################################################################################
##################################################################################################
$WRITE_ERROR

Call ECR_TRACE  (mess(121,7711,1) - [L]ERRLINNUM + ": " + [L]ERRMESS, 1)   From GESECRAN

Return
##################################################################################################
##################################################################################################


