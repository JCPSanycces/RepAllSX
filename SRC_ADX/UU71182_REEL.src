#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UUACCNUM  Squelette pour Moulinette                      Module CPT    #
#            description de la moulinette                                #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UU71182_REEL Process") From LECFIC
  
  Global Integer GSIMACCNUM
  GSIMACCNUM=1

  Call MAJ_71182(DOSSIER) 

  Kill GSIMACCNUM

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_71182(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, NBRPYH
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3

Local Char SVG_NUM(30)

#----- Ouverture des fichiers -----#
If clalev([F:HAE])  =0  Local File =DOSSIER+".GACCENTRY"    [HAE] : Endif
If clalev([F:DAE])  =0  Local File =DOSSIER+".GACCENTRYD"   [DAE] : Endif
If clalev([F:DAT])  =0  Local File =DOSSIER+".GACCTMPD"     [DAT] : Endif
If clalev([F:PAN])  =0  Local File =DOSSIER+".PAYACCNUM"    [PAN] : Endif
If clalev([F:PA2])  =0  Local File =DOSSIER+".PAYACCNUM"    [PA2] : Endif
If clalev([F:PMD])  =0  Local File =DOSSIER+".PAYACCNUMD"   [PMD] : Endif
If clalev([F:PM2])  =0  Local File =DOSSIER+".PAYACCNUMD"   [PM2] : Endif

If clalev([F:TPY])  =0  Local File =DOSSIER+".TABPAYTYP"    [TPY] : Endif
If clalev([F:PAY])  =0  Local File =DOSSIER+".PAYMENTH"     [PYH] : Endif
If clalev([F:BAN])  =0  Local File =DOSSIER+".BANK"         [BAN] : Endif
If clalev([F:JOU])  =0  Local File =DOSSIER+".GJOURNAL"     [JOU] : Endif
If clalev([F:JCO])  =0  Local File =DOSSIER+".GJOUCOA"      [JCO] : Endif

If clalev([F:HAE]) Close  File  [HAE] : Endif
Local File =[F:ADS]DOSSIER+".GACCENTRY"    [HAE]    Order By Key CLE=CPY;REFINT;JOU;TYP;NUM

Local Integer ETAP, TYPJOU, CAS
Local Char COMPTE(GLONGAC), JOU(GLONJOU) , REFINT(30)
Local Char PLAN(GLONCOA)

Local Integer ACCNUM_FALSE
Local Integer ACCNUM_TRUE


# Déclaration process 2
Local Integer ACCNUM_TRESO
Local Integer SNS_TRESO

Local Integer ACCNUM_REW(0..999)
Local Integer NUM_REW

Local Integer SVG_ACCNUM
Local Integer OK_ACCNUM


##----------------------------------------------------------------------------------------------------------------------
Call ECR_TRACE("UUACCNUM/1 : Process Start on : "+DOSSIER,-1) From GESECRAN
Gosub PROCESS1
Call ECR_TRACE("UUACCNUM/1 : "+num$(COMPTEUR)+" records processed"-"("+num$(NBRPYH)+")",-1) From GESECRAN
##----------------------------------------------------------------------------------------------------------------------
Call ECR_TRACE("UUACCNUM/2 : Process Start on : "+DOSSIER,-1) From GESECRAN
Gosub PROCESS2
Call ECR_TRACE("UUACCNUM/2 : "+num$(COMPTEUR)+" records processed"-"("+num$(NBRPYH)+")",-1) From GESECRAN
##----------------------------------------------------------------------------------------------------------------------
End


##----------------------------------------------------------------------------------------------------------------------
$PROCESS1
Link [PAN] With [PYH]PYH0~=[F:PAN]NUM
&   As [LNK]
&   Where [F:PAN]TYPNUM=3 & [F:PAN]ACCNUM>0
&   Order By Key CLE = [F:PAN]ACCNUM;[F:PAN]NUM;[F:PAN]STA;[F:PAN]TYPNUM

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR, NBRPYH

$LOOP_PAN
Raz NB
If STOP = 1
 STOP = 0
 CRITERE = "[F:PAN]ACCNUM>"+num$(ICLE1)
Else
 CRITERE = "1=1"
Endif

For [LNK]CLE(1) Where evalue(CRITERE) 
 Read [DAE]DAE2 = [F:PAN]ACCNUM
 If fstat
  # Peut-être est ce en batch...
  Read [DAT]DAT1 = [F:PAN]ACCNUM
  If fstat
   For [LNK]CLE
    # Code transaction ... Règlement
    Call ECR_TRACE(mess(102,105,1)-":"-[F:PYH]PAYTYP-mess(47,109,1)-":"-[F:PAN]NUM-"("+num$([F:PAN]ACCNUM)+")"-format$("D:"+GFMDAT,[F:PYH]ACCDAT)-mess([F:PAN]TYPNUM,685,1)-"(STA="+num$([F:PAN]STA)+")",0) From GESECRAN
    COMPTEUR+=1
    If SVG_NUM<>[F:PAN]NUM : NBRPYH+=1 : Endif
    SVG_NUM = [F:PAN]NUM

    Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV
    Call LECPLAN([F:PYH]CPY,GTYPGEN,PLAN) From CPTDIV
    Call LEC_TPY([F:PYH]PAYTYP) From CPTLEC
    Gosub SEARCH_ACC
    If COMPTE<>"" & JOU<>""
     Filter [HAE] Where CPY=[F:PYH]CPY & [F:HAE]REFINT=[L]REFINT & [F:HAE]JOU=[L]JOU
     If rowcount([F:HAE])=1
      Read [HAE]CLE First
      If !fstat
       Filter [DAE] Where [F:DAE]TYP=[F:HAE]TYP & [F:DAE]NUM=[F:HAE]NUM & [F:DAE]LEDTYP=GTYPGEN & [F:DAE]ACC=COMPTE & [F:DAE]COA=PLAN & [F:DAE]FCYLIN=[F:PYH]FCY
       If rowcount([F:DAE])=0
        # Action impossible - 0 Ligne
        Call ECR_TRACE(mess(186,123,1)-"- 0 "-mess(136,105,1)-"-"-[F:HAE]TYP-[F:HAE]NUM-PLAN-COMPTE,0) From GESECRAN
       Elsif rowcount([F:DAE])=1
        Read [DAE]DAE0 First
        If !fstat
         [L]ACCNUM_FALSE = [F:PAN]ACCNUM
         [L]ACCNUM_TRUE  = [F:DAE]ACCNUM
         Gosub WRITE_ACCNUM : Gosub END_FIL : Break
        Endif
       Else
        For [DAE]
         # Action impossible - x Lignes
         Call ECR_TRACE(mess(186,123,1)-"- x"-mess(7,105,1)-"-"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-[F:DAE]ACC-num$([F:DAE]ACCNUM)-"/"-num$([F:DAE]AMTCUR),0) From GESECRAN
        Next
       Endif
      Endif
     Else
      NBCHX=0
      For [HAE]
       Filter [DAE] Where [F:DAE]TYP=[F:HAE]TYP & [F:DAE]NUM=[F:HAE]NUM  & [F:DAE]LEDTYP=GTYPGEN & [F:DAE]ACC=COMPTE & [F:DAE]COA=PLAN  & [F:DAE]FCYLIN=[F:PYH]FCY   
       NBCHX+= rowcount([F:DAE])
      Next
      If NBCHX=1
       For [HAE]
        For [DAE]
         [L]ACCNUM_FALSE = [F:PAN]ACCNUM
         [L]ACCNUM_TRUE  = [F:DAE]ACCNUM
         Gosub WRITE_ACCNUM
         Gosub END_FIL : Break 3
        Next
       Next
      Else
       For [HAE]
        Filter [DAE] Where [F:DAE]TYP=[F:HAE]TYP & [F:DAE]NUM=[F:HAE]NUM  & [F:DAE]LEDTYP=GTYPGEN & [F:DAE]ACC=COMPTE & [F:DAE]COA=PLAN   & [F:DAE]FCYLIN=[F:PYH]FCY 
        For [DAE]
         # Action impossible - x Lignes
         Call ECR_TRACE(mess(186,123,1)-"- x"-mess(7,105,1)-"-"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-[F:DAE]ACC-num$([F:DAE]ACCNUM)-"/"-num$([F:DAE]AMTCUR),0) From GESECRAN
        Next
       Next
      Endif
     Endif
     Gosub END_FIL
    Endif # COMPTE <>
   Next
  Endif # Read DAT
 Endif # Read DAE
 NB+=1

 If NB>GMAXUPDTRS
  ICLE1 = [F:PAN]ACCNUM
  ACLE2 = [F:PAN]NUM
  ICLE2 = [F:PAN]STA
  ICLE3 = [F:PAN]TYPNUM
  STOP=1
  Break
 Endif
Next

If STOP
 Goto LOOP_PAN
Endif
Gosub UNSET_FIRST From TRTFIRST

Return

##----------------------------------------------------------------------------------------------------------------------
$SEARCH_ACC
Raz COMPTE,JOU,REFINT

If [F:PAN]TYPVCR = "A" or [F:PAN]TYPVCR = "9" or [F:PAN]TYPVCR = "8"

 # Nombre d'étapes. [F:PAN]STA correspond à l'étape de comptablisation 3 à 10 (de portefeuille à dévalorisation) 
 #  SAUF si Transction = une seule étape de comptabilisation
 Raz ETAP
 For I=0 To dim([F:PYH]ACCNUMTRE)-1
  If [F:PYH]ACCNUMTRE(I)<>0 : ETAP += 1 : Endif
 Next

 If ETAP=1
  ETAP=9  # Etape de comptabilisation
 Else
  ETAP=[F:PAN]STA
 Endif

 Case [F:PAN]ACCSTA
  When 3 : # Mise en portefeuille
   TYPJOU = [F:TPY]JOU3
  When 8 : # Comptabilisation intermédiaire
   If find([F:PYH]FRMTYP,0,1,3) : # Encaissement
    TYPJOU = [F:TPY]JOU8
   Else
    TYPJOU = [F:TPY]JOU82
   Endif
  When 9 : # Remise en banque
   TYPJOU = [F:TPY]JOU9
  When 10 : # Dévalorisation portefeuille
   TYPJOU = [F:TPY]JOU10
  When 11 : # Impayé
   # Ligne non traitée
   Call ECR_TRACE(mess(189,197,1),1) From GESECRAN   # Problème de frais séparé ?!
  When Default :
   # Ligne non traitée 
   Call ECR_TRACE(mess(189,197,1),1) From GESECRAN   # Problème de frais séparé ?!
 Endcase
 If [F:PAN]TYPVCR = "T"
  # Ligne non traitée
  Call ECR_TRACE(mess(189,197,1),1) From GESECRAN   # Imputation
 Endif
 If [F:PAN]ACCSTA<11
  If [F:PYH]BAN<>""
   Call LEC_BAN([F:PYH]BAN) From CPTLEC
   If fstat=0 & TYPJOU<>len(mess(0,660,1)) : # aucun
    I=find(TYPJOU,[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
    If I
     COMPTE = [F:BAN]TREACC(I-1) : JOU=[F:BAN]JOU(I-1)
    Endif 
   Endif
  Endif
 Endif
Else
 # Ligne non traitée
 Call ECR_TRACE(mess(189,197,1)-[F:PAN]TYPVCR-"("+num$([F:PAN]ACCSTA)+")",-1) From GESECRAN   # Imputation
Endif

# Initialisation de REFINT
CAS = 1 
If ETAP=9
 If [F:PYH]FRMTYP = 1 | [F:PYH]FRMTYP = 3 | ([F:PYH]FRMTYP = 0 & [F:TPY]ACETYP91<>0) : # encaissements
  CAS = [F:TPY]ACETYP91
 Else : # escompte
  CAS = [F:TPY]ACETYP92
 Endif
Endif
If CAS=1
 REFINT="PYH"-[F:PYH]NUM
Else
 REFINT="FRM"-[F:PYH]FRMNUM
 If [F:PYH]FRMNUM=""
  # Ligne non traitée... vide
  Call ECR_TRACE(mess(189,197,1)-"- REFINT"-mess(23,147,1),-1) From GESECRAN   # Imputation
 Endif
Endif
Return

##----------------------------------------------------------------------------------------------------------------------
$WRITE_ACCNUM
If [L]ACCNUM_FALSE=[L]ACCNUM_TRUE | [L]ACCNUM_FALSE=0 | [L]ACCNUM_TRUE=0 : Return : Endif
# Modification 
Call ECR_TRACE(mess(60,123,1)-"ACCNUM : "-num$([L]ACCNUM_FALSE)-"=>"-num$([L]ACCNUM_TRUE),1) From GESECRAN

GOK = 1 
Trbegin [PAN] , [PMD] , [PYH]
 
 Update [PAN] Where ACCNUM=[L]ACCNUM_FALSE
&             With  ACCNUM=[L]ACCNUM_TRUE
 If fstat  
  Call ERREUR("PAYACCNUM"-num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA)-num$([F:PAN]ACCNUM),1) From DOSDIC
  GOK = 0 :  : Goto AB_TR_ANNUL
 Else
  If adxuprec>0
   # Mise à jour de
   Call ECR_TRACE(num$(adxuprec)-":"-mess(33,141,1)-"ACCNUM (PAYACCNUM)",0) From GESECRAN
  Endif
 Endif 

 Update [PAN] Where RVSACCNUM=[L]ACCNUM_FALSE
&             With  RVSACCNUM=[L]ACCNUM_TRUE
 If fstat  
  Call ERREUR("PAYACCNUM"-num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA)-num$([F:PAN]ACCNUM),1) From DOSDIC
  GOK = 0 :  : Goto AB_TR_ANNUL
 Else
  If adxuprec>0
   # Mise à jour de
   Call ECR_TRACE(num$(adxuprec)-":"-mess(33,141,1)-"RVSACCNUM (PAYACCNUM)",0) From GESECRAN
  Endif
 Endif 


 Update [PMD] Where ACCNUM=[L]ACCNUM_FALSE
&             With  ACCNUM=[L]ACCNUM_TRUE
 If fstat  
  Call ERREUR("PAYACCNUMD"-[F:PMD]NUM-num$([F:PMD]ACCSTA)-num$([F:PMD]ACCNUM),1) From DOSDIC
  GOK = 0 :  : Goto AB_TR_ANNUL
 Else
  If adxuprec>0
   # Mise à jour de
   Call ECR_TRACE(num$(adxuprec)-":"-mess(33,141,1)-"ACCNUM (PAYACCNUMD)",0) From GESECRAN
  Endif
 Endif 

 Update [PMD] Where RVSACCNUM=[L]ACCNUM_FALSE
&             With  RVSACCNUM=[L]ACCNUM_TRUE
 If fstat  
  GOK = 0 : Call FSTA("PMD") From GLOCK : Goto AB_TR_ANNUL
 Else
  If adxuprec>0
   # Mise à jour de
   Call ECR_TRACE(num$(adxuprec)-":"-mess(33,141,1)-"RVSACCNUM (PAYACCNUMD)",0) From GESECRAN
  Endif
 Endif 

 For I=0 To dim([F:PYH]ACCNUMTRE)-1
  If [F:PYH]ACCNUMTRE(I)=[L]ACCNUM_FALSE
   Update [PYH] Where ACCNUMTRE(I)=[L]ACCNUM_FALSE
&               With  ACCNUMTRE(I)=[L]ACCNUM_TRUE
   If fstat  
    GOK = 0 : Call FSTA("PYH") From GLOCK : Goto AB_TR_ANNUL
   Else
    If adxuprec>0
     # Mise à jour de
     Call ECR_TRACE(num$(adxuprec)-":"-mess(33,141,1)-"ACCNUMTRE(x) (PAYMENTH)",0) From GESECRAN
    Endif
   Endif 
  Endif
 Next

If dim(GSIMACCNUM)>0 & GSIMACCNUM=1
 Commit 
Else
 Rollback
Endif
Return 
 
$AB_TR_ANNUL
Rollback 
Return 


##----------------------------------------------------------------------------------------------------------------------
$PROCESS2
Link [PMD] With [PYH]PYH0=[F:PMD]NUM
&   As [LNK] Where [F:PYH]NUM<>""
&   Order By Key CLE = [F:PMD]TYP;[F:PMD]VCRNUM;[F:PMD]ACCNUM;[F:PMD]NUM;[F:PMD]ACCSTA

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
Raz COMPTEUR, NBRPYH

$LOOP_PMD
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PMD]TYP='"+ACLE1+"' & [F:PMD]VCRNUM>'"+ACLE2+"'"
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:PMD]TYP>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

CRITERE+=' & [F:PMD]AMTCUR>0' 

For [LNK]CLE(2) Where evalue(CRITERE) 

 Raz NUM_REW, ACCNUM_TRESO, SNS_TRESO

 For [LNK]CLE(3)
  Read [DAE]DAE2 = [F:PMD]ACCNUM
  If fstat
   # Peut-être est ce en batch...
   Read [DAT]DAT1 = [F:PMD]ACCNUM
   If fstat
 
    For [LNK]CLE
     # Numéro de pièce ... Code transaction ... Règlement
     Call ECR_TRACE(mess(11,105,1)-[F:PMD]TYP-[F:PMD]VCRNUM-mess(102,105,1)-":"-[F:PYH]PAYTYP-mess(47,109,1)-":"-[F:PMD]NUM-"("+num$([F:PMD]ACCNUM)+")"-format$("D:"+GFMDAT,[F:PYH]ACCDAT),0) From GESECRAN
     COMPTEUR+=1
     If SVG_NUM<>[F:PMD]NUM : NBRPYH+=1 : Endif
     SVG_NUM = [F:PMD]NUM

     Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV
     Call LECPLAN([F:PYH]CPY,GTYPGEN,PLAN) From CPTDIV
     Call LEC_TPY([F:PYH]PAYTYP) From CPTLEC
     COMPTE = ""
     If [F:PYH]BAN<>""
      Call LEC_BAN([F:PYH]BAN) From CPTLEC
      If fstat=0 & [F:TPY]JOU9<>len(mess(0,660,1)) : # aucun
       I=find([F:TPY]JOU9,[F:BAN]JOUTYP(0..[F:BAN]NBRJOU-1))
       If I : COMPTE = [F:BAN]TREACC(I-1) : Endif
      Endif
     Endif
     If COMPTE=""
      # Action impossible - 0 Compte de banque
      Call ECR_TRACE(mess(186,123,1)-"- 0"-mess(115,121,1)-"-"-[F:PMD]TYP-[F:PMD]VCRNUM,0) From GESECRAN
     Else
      # Pièces comptables qui à priori a été "touché"
      Filter [DAE] Where [F:DAE]TYP=[F:PMD]TYP & [F:DAE]NUM=[F:PMD]VCRNUM & [F:DAE]LEDTYP=GTYPGEN & [F:DAE]COA=PLAN & [F:DAE]ACC=[L]COMPTE & [F:DAE]FCYLIN=[F:PYH]FCY
      If rowcount([F:DAE])<>1
       # Action impossible - x Compte de banque
       Call ECR_TRACE(mess(186,123,1)-"- x"-mess(115,121,1)-"-"-[F:PMD]TYP-[F:PMD]VCRNUM,0) From GESECRAN
      Else
       Read [DAE]DAE0 First
       If !fstat
        [L]SNS_TRESO     = [F:DAE]SNS
        [L]ACCNUM_TRESO  = [F:DAE]ACCNUM
        Gosub VCRNUM_PMD :  Gosub END_FIL : Break 2 
       Endif
      Endif
      Filter [DAE]
     Endif
    Next
   Endif
  Endif
 Next

 COMPTEUR+=1
 NB+=1

 If NB>GMAXUPDTRS
  ACLE1 = [F:PMD]TYP
  ACLE2 = [F:PMD]VCRNUM
  STOP=1
  Break
 Endif
Next

If STOP
 Goto LOOP_PMD
Endif
Gosub UNSET_FIRST From TRTFIRST
Return


##----------------------------------------------------------------------------------------------------------------------
$VCRNUM_PMD

Filter [PM2] Where TYP=[F:PMD]TYP & VCRNUM=[F:PMD]VCRNUM & SNS=[L]SNS_TRESO
OK_ACCNUM=0
SVG_ACCNUM=0

# Ligne Trésorerie
LIBEL = mess(136,105,1)-mess(3,613,1)
For [PM2]
 If [L]SVG_ACCNUM=0 : [L]SVG_ACCNUM=[F:PM2]ACCNUM : Endif
 If [L]SVG_ACCNUM<>[F:PM2]ACCNUM
  # Action impossible -  Ligne Tréso - <> ACCNUM
  Call ECR_TRACE(mess(186,123,1)-"-"-LIBEL-"- <> ACCNUM"-[F:PM2]TYP-[F:PM2]VCRNUM-num$([F:PM2]ACCNUM)+"/"+num$(SVG_ACCNUM),1) From GESECRAN
  OK_ACCNUM=1 : Break
 Endif
Next

If !OK_ACCNUM & [L]SVG_ACCNUM 
 # ACCNUM de Tréso est OK
 [L]ACCNUM_FALSE = [L]SVG_ACCNUM
 [L]ACCNUM_TRUE  = [L]ACCNUM_TRESO
 Gosub WRITE_ACCNUM
Else
# Return
Endif


Filter [PM2] Where TYP=[F:PMD]TYP & VCRNUM=[F:PMD]VCRNUM & SNS=[L]SNS_TRESO*-1
OK_ACCNUM=0
# <> Ligne Trésorerie
LIBEL = "<>"+mess(136,105,1)-mess(3,613,1)
For [PM2]

 Filter [DAE] Where [F:DAE]TYP=[F:PM2]TYP & [F:DAE]NUM=[F:PM2]VCRNUM & [F:DAE]LEDTYP=GTYPGEN & [F:DAE]SNS=[F:PM2]SNS & [F:DAE]AMTCUR=[F:PM2]AMTCUR
 If rowcount([F:DAE])=1
  Read [DAE]First
  If !fstat
   [L]ACCNUM_FALSE = [F:PM2]ACCNUM
   [L]ACCNUM_TRUE  = [F:DAE]ACCNUM
   Gosub WRITE_ACCNUM2
  Endif
 Else
  For [DAE]
   If !NUM_REW | !find([F:DAE]ACCNUM,ACCNUM_REW(0..NUM_REW))
    [L]ACCNUM_FALSE = [F:PM2]ACCNUM
    [L]ACCNUM_TRUE  = [F:DAE]ACCNUM
    Gosub WRITE_ACCNUM2
    ACCNUM_REW(NUM_REW)=[F:DAE]ACCNUM : NUM_REW+=1 : Break
   Endif
  Next
 Endif
Next
Return



##----------------------------------------------------------------------------------------------------------------------
$WRITE_ACCNUM2
If [L]ACCNUM_FALSE=[L]ACCNUM_TRUE | [L]ACCNUM_FALSE=0 | [L]ACCNUM_TRUE=0 : Return : Endif

# Modification
Call ECR_TRACE(LIBEL-":"-mess(60,123,1)-"ACCNUM (PAYACCCNUMD)"-num$([L]ACCNUM_FALSE)-"=>"-num$([L]ACCNUM_TRUE),1) From GESECRAN
 
GOK = 1 
Trbegin [PMD]
 

 Update [PMD] Where ACCNUM=[L]ACCNUM_FALSE
&             With  ACCNUM=[L]ACCNUM_TRUE
 If fstat  
  Call ERREUR("PAYACCNUMD"-[F:PMD]NUM-num$([F:PMD]ACCSTA)-num$([F:PMD]ACCNUM),1) From DOSDIC
  GOK = 0 :  : Goto AB_TR_ANNUL
 Else
  # Mise à jour de
  If adxuprec>0
   Call ECR_TRACE(num$(adxuprec)-":"-mess(33,141,1)-"ACCNUM (PAYACCNUMD)",0) From GESECRAN
  Endif
 Endif 

 Update [PMD] Where RVSACCNUM=[L]ACCNUM_FALSE
&             With  RVSACCNUM=[L]ACCNUM_TRUE
 If fstat  
  GOK = 0 : Call FSTA("PMD") From GLOCK : Goto AB_TR_ANNUL
 Else
  # Mise à jour de
  If adxuprec>0
   Call ECR_TRACE(num$(adxuprec)-":"-mess(33,141,1)-"RVSACCNUM (PAYACCNUMD)",0) From GESECRAN
  Endif
 Endif 

If dim(GSIMACCNUM)>0 & GSIMACCNUM=1
 Commit 
Else
 Rollback
Endif
Return 
 

$END_FIL
    Filter [DAE]
    Filter [HAE]
Return


