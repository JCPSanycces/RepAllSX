#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(20)(1..5)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = ""
Call GCONSULT("SPE","",PARAM) From GCONSULT
End
############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz[M:CSPE]: Transmask [M:SPE1] To [M:CSPE] # Issue 25606 [M:CSPE] = [M:SPE1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY  [SLF] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif


#
Local Char    WFIL(250)
Local Char    WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Decimal WACT
Local Char    WPAR(10)
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J, K, L, WNOLIGN
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSPE"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SPE1]FLG = 0
[M:SPE1]    = [M:CSPE]
Return
############################################################
$AP_MAGNETO
[M:SPE1]FLG = 0
Return
############################################################
$FERME
If clalev([F:STO]) <> 0 : Filter [STO] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SPE1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SPE1]ITMREFSTR = [F:ITM]ITMREF
          [M:SPE1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        [M:SPE1]REFPER = PARAM(I)
      Else
        [M:SPE1]REFPER = date$
      Endif
    When 5 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSPE]) <> 0 & [M:CSPE]MEMO = "STD"  : # <MG> 26/04/00
  [M:SPE1] = [M:CSPE]                            : # <MG> 26/04/00
Endif                                            : # <MG> 26/04/00
Return
############################################################
$LECTURE
If [M:SPE1]FLG = 2
  [M:SPE1]FLG = 0
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SPE2]
    WLIG = 0
    For [LNK]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SPE1]FLG = 0
  [M:SPE1]FLG = 1
  Raz [M:SPE2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  If [M]ITMREFSTR = "" & [M]ITMREFEND = ""
    Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO,[F:ITM]ITM0=[F:STL]ITMREF
&              As [LNK]
&              Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&              Order By Key STL3
  Else
    Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO,[F:ITM]ITM0=[F:STL]ITMREF
&              As [LNK]
&              Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE)
&              Order By Key STL2
  Endif
  Raz [F:STL],[F:SLF],[F:ITM]       # hcb V6per
Endif
Return
############################################################
$LOAD_FILTER
WFIL = "1=1"
If [M]ITMREFSTR <> "" | [M]ITMREFEND <> ""
  If [M]ITMREFSTR = [M]ITMREFEND
    WFIL  += "&[F:STL]ITMREF=[M]ITMREFSTR"
  Else
    WFIL  += "&[F:STL]ITMREF>=[M]ITMREFSTR&[F:STL]ITMREF<=[M]ITMREFEND"
  Endif
Endif

#                                                              hcb V6per deb
Case [M]TYPREF
     When 1 :
          WFIL += "&[F:STL]SHLDAT<=([M]REFPER+[M]MARPER)"
     When 2 :
          WFIL += "&[F:STL]DLUDAT<=([M]REFPER+[M]MARPER)"
     When 3 :
          WFIL += "&[F:STL]NEWLTIDAT<=([M]REFPER+[M]MARPER)"
Endcase
#                                                              hcb V6per fin

WFIL += "&sum([F:SLF]AAACUMQTY,[F:SLF]QQQCUMQTY,[F:SLF]RRRCUMQTY)<>0"
If [M:SPE1]FCY<>""
    WFIL += "&[F:SLF]STOFCY=[M:SPE1]FCY"
Endif
Return
############################################################
$LOA_LIGNE
If [F:ITM]ITMREF <> [F:STL]ITMREF     # hcb v6per
   Read [ITM]ITM0=[F:STL]ITMREF
   If fstat
      nolign -= 1
      NOL    -= 1
      Raz [F:ITM]
      Goto LOA_LIGNE_FIN
   Endif
Endif                                 # hcb v6per

Read [TUN]TUN0= [F:ITM]STU
If fstat
  Raz [F:TUN]
Endif
Gosub CAL_STOCK
If WAAA = 0 & WQQQ = 0 & WRRR = 0
  nolign -= 1
  NOL    -= 1
  Goto LOA_LIGNE_FIN
Endif
WNOLIGN = nolign
If [M:SPE1]AGRFCYFLG=2 & [M:SPE1]FCY=""
    nolign = sigma(0,nolign-1,(indcum+1)
&                            *([M:SPE2]ITMREF(indcum)=[F:SLF]ITMREF
&                             &[M:SPE2]LOT(indcum)   =[F:SLF]LOT
&                             &[M:SPE2]SLO(indcum)   =[F:SLF]SLO))
    If nolign>0
        [M:SPE2]STOFCY(nolign-1) = "$"
        [M:SPE2]AAACUMQTY(nolign-1) += WAAA
        [M:SPE2]QQQCUMQTY(nolign-1) += WQQQ
        [M:SPE2]RRRCUMQTY(nolign-1) += WRRR
        [M:SPE2]CUMALLQTY(nolign-1) += WALL
        [M:SPE2]LOTQTY(nolign-1)    += WAAA+WQQQ+WRRR
        nolign = WNOLIGN-1
        NOL   -=1
        Goto LOA_LIGNE_FIN
    Endif
Endif
nolign = WNOLIGN
[M:SPE2] = [F:STL]
[M:SPE2] = [F:SLF]
[M:SPE2]AAACUMQTY(nolign-1) = WAAA
[M:SPE2]QQQCUMQTY(nolign-1) = WQQQ
[M:SPE2]RRRCUMQTY(nolign-1) = WRRR
[M:SPE2]CUMALLQTY(nolign-1) = WALL
[M:SPE2]LOTQTY(nolign-1)    = WAAA+WQQQ+WRRR
#[M:SPE2]ITMDES1(nolign-1)   = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SPE2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:SPE2]STU(nolign-1)       = [F:ITM]STU

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:SLF]STOFCY | [F:ITF]ITMREF <> [F:SLF]ITMREF
   Read [ITF]ITF0 = [F:SLF]ITMREF;[F:SLF]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif


If dim([M:SPE2]POT) > 0 & [F:ITF]STOMGTCOD <> 3
  [M:SPE2]POT(nolign-1) = 0
Endif
If dim([M:SPE2]ACT) > 0 &[ F:ITF]STOMGTCOD <> 4
  [M:SPE2]ACT(nolign-1) = 0
Endif
If dim([M:SPE2]SERFLG) < 0
  [M:SPE2]SERMGTCOD(nolign-1) = 1
Else
  [M:SPE2]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
Endif

$LOA_LIGNE_FIN
Return
###########################################################
$CAL_STOCK
WAAA = 0
WQQQ = 0
WRRR = 0
WALL = 0
  Filter [STO] Where ITMREF = [F:STL]ITMREF &
&                    STOFCY = [F:SLF]STOFCY &
&                    LOT    = [F:STL]LOT    &
&                    SLO    = [F:STL]SLO
&              Order By Key STO3
For [STO]
  If mid$([F:STO]STA,1,1) = "A"
      If dim([M:SPE1]CRIQTY) > 0 & [M:SPE1]CRIQTY = 2
           WAAA += [F:STO]QTYSTUACT
      Else WAAA += [F:STO]QTYSTU
      Endif
  Endif
  If mid$([F:STO]STA,1,1) = "Q"
      If dim([M:SPE1]CRIQTY) > 0 & [M:SPE1]CRIQTY = 2
           WQQQ += [F:STO]QTYSTUACT
      Else WQQQ += [F:STO]QTYSTU
      Endif
  Endif
  If mid$([F:STO]STA,1,1) = "R"
      If dim([M:SPE1]CRIQTY) > 0 & [M:SPE1]CRIQTY = 2
           WRRR += [F:STO]QTYSTUACT
      Else WRRR += [F:STO]QTYSTU
      Endif
  Endif
  If dim([M:SPE1]CRIQTY) > 0 & [M:SPE1]CRIQTY = 2
       WALL += [F:STO]CUMALLQTA
  Else WALL += [F:STO]CUMALLQTY
  Endif
Next
Filter [STO]
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SPE1]FLG = 0
End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:SPE1]FLG  = 0
[M]ITMREFEND = VALEUR
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M:SPE1]FLG = 0
End
############################################################
Subprog AM_CRIQTY(VALEUR)
Variable Integer VALEUR
[M:SPE1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End
############################################################
Subprog AM_REFPER(VALEUR)
Variable Date    VALEUR
[M:SPE1]FLG = 0
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSPE1) 13/05/2008 16:04:04 (HCB)
######################################################################################
Subprog AM_TYPREF(VALEUR)
Variable Integer VALEUR
[M:SPE1]FLG = 0
End

Subprog AM_MARPER(VALEUR)
Variable Decimal VALEUR
[M:SPE1]FLG = 0
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSPE2) 12-07-2008 14:43:21 (MB)
######################################################################################
Subprog IB_VCRTYP
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSPE2) 04/11/2008 16:38:12 (SYMEU)
######################################################################################
## SYMEU 61044 (21/12/2009) : oublié de tester la présence du champ [M:SPE2]LOT
######################################################################################
Subprog IB_NBLIG
  If dim([M:SPE2]LOT) > 0 Then      # SYMEU 61044
    If [M:SPE2]LOT(nolign-1)="" Then
       Raz GBOUT6
    Endif
  Endif
  If [M:SPE2]ITMREF(nolign-1) <> [F:ITM]ITMREF
     Read [ITM]ITM0=[M:SPE2]ITMREF(nolign-1)
  Endif
  If (dim([M:SPE2]LOT) > 0 and [M:SPE2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1 Then # SYMEU 61044
     Raz GBOUT7
  Endif
End


######################################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SPE") From SUBGTC

End

