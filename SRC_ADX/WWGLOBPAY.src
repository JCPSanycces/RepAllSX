#<AdxTL>@(#)0.0.0.0 $Revision$ Global variables
Subprog GLOBVAR(SITE)
Value Char SITE
Onerrgo ERREUR
Local File ADOPAR [ADP]
Local File ADOVAL [ADW]
Local Char    PARAM(250)
Global Char     GINDAGI(30)         : # AGIRC fund
Call PARAM(SITE,"AGIRC",PARAM) From ADOVAL
GINDAGI = PARAM
Global Decimal  GAMTVIR1            : # Threshold 1 payment balance
Call PARAM(SITE,"AMTVIR1",PARAM) From ADOVAL
GAMTVIR1 = val(PARAM)
Global Decimal  GAMTVIR2            : # Threshold 2 payment balance
Call PARAM(SITE,"AMTVIR2",PARAM) From ADOVAL
GAMTVIR2 = val(PARAM)
Global Decimal  GAMTVIR3            : # Threshold 3 PB countervalue
Call PARAM(SITE,"AMTVIR3",PARAM) From ADOVAL
GAMTVIR3 = val(PARAM)
Global Char     GINDARR(30)         : # ARRCO fund
Call PARAM(SITE,"ARRCO",PARAM) From ADOVAL
GINDARR = PARAM
Global Char     GINDASS(30)         : # ASSEDIC fund
Call PARAM(SITE,"ASSEDIC",PARAM) From ADOVAL
GINDASS = PARAM
Global Char     GINDBTP(30)         : # BTP bad weather fund
Call PARAM(SITE,"CIBTP",PARAM) From ADOVAL
GINDBTP = PARAM
Global Char     GINDDDTE(30)        : # DDTE fund
Call PARAM(SITE,"DDTE",PARAM) From ADOVAL
GINDDDTE = PARAM
Global Char     GINDMED(30)         : # Occupational health
Call PARAM(SITE,"MEDECINE",PARAM) From ADOVAL
GINDMED = PARAM
Global Char     GINDMUT(30)         : # Compl. health insurance
Call PARAM(SITE,"MUTUELLE",PARAM) From ADOVAL
GINDMUT = PARAM
Global Char     GINDPREV(30)        : # Welfare fund
Call PARAM(SITE,"PREVOYANCE",PARAM) From ADOVAL
GINDPREV = PARAM
Global Char     GINDURS(30)         : # URSSAF fund
Call PARAM(SITE,"URSSAF",PARAM) From ADOVAL
GINDURS = PARAM
End

$ERREUR
Call ERREUR(errp-"("+num$(errl)+")"-errmes$(errn)-errm) From GESECRAN
Resume

