#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Contrôle qu'une abréviation de vue n'est pas utilisée dans une table
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Control view file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Control folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Control folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub CTL
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub CTL
End

#-------------------#
$CTL

Local File =DOSSIER+".AVIEW"  [AVW] 
Local File =DOSSIER+".ATABLE" [ATB]
Local Integer OK

OK = 1
For [AVW]
 Read [ATB]ABRFIC=[F:AVW]ABRVUE
 If !fstat
  # La vue $1$ utilise la même abréviation ($2$) que la table $3$    
  Call ECR_TRACE(func AFNC.MES3(mess(210,125,1),[F:AVW]CODVUE,[F:AVW]ABRVUE,[F:ATB]CODFIC),1) From GESECRAN
  OK = 0
 Endif
Next AVW
If OK
 Call ECR_TRACE("Control : OK",0) From GESECRAN
Endif

Return
