########################################
Subprog S_DEBTAR(VALEUR)
Variable Char    VALEUR()
If clalev([F:SPC])=0 : Local File SPRICCONF [SPC] : Endif 
Choose [SPC] Where 1=1 
& Order By Key SPC0 
& Using [F:SPC]PLI Titled "", 
&       [F:SPC]PLIDES Titled "" 
& Sized (200,104) Titled "" 
& Starting At PLI="" 
If status=0 
  Call message(mess(99,100,1)) From GESECRAN 
# pas de fiche sélectionnée 
  mkstat=2 
Elsif status<>7 
  valeur=[F:SPC]PLI 
endif  
End
########################################
Subprog S_FINTAR(VALEUR)
Variable Char    VALEUR()
If clalev([F:SPC])=0 : Local File SPRICCONF [SPC] : Endif  
Choose [SPC] Where 1=1  
& Order By Key SPC0  
& Using [F:SPC]PLI Titled "",   
&       [F:SPC]PLIDES Titled ""  
& Sized (200,104) Titled ""  
& Starting At PLI>=[M]DEBTAR 
If status=0  
  Call message(mess(99,100,1)) From GESECRAN  
# pas de fiche sélectionnée 
  mkstat=2  
Elsif status<>7  
  valeur=[F:SPC]PLI  
endif   

End
#---------------------------------------
Subprog AP_FINTAR(VALEUR) 
Variable Char     VALEUR 
If VALEUR < [M]DEBTAR : mkstat=2 : Endif 
End 
