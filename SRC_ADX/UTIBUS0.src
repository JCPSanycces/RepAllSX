#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIBUS0   Suppression des types de données BUS et BUI,                 #
#           des objets BUS et BUI, et des traitements SUBBUS et SUBBUI   #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTIBUS0(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog MAJ_UTIBUS0(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTIBUS0 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:AOB])  =0  Local File =DOSSIER+".AOBJET"   [AOB] : Endif
If clalev([F:ATY])  =0  Local File =DOSSIER+".ATYPE"    [ATY] : Endif
If clalev([F:ADC])  =0  Local File =DOSSIER+".ADICTRT"  [ADC] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

# Suppression des objets BUS et BUI
Trbegin [AOB]
Delete [AOB] Where ABREV='BUS' or ABREV='BUI'
COMPTEUR += adxdlrec
Commit
Close Local File [AOB]

# Suppression des types de données BUS et BUI
Trbegin [ATY]
Delete [ATY] Where CODTYP='BUS' or CODTYP='BUI'
COMPTEUR += adxdlrec
Commit
Close Local File [ATY]

# Suppression des traitements SUBBUS et SUBBUI
Trbegin [ADC]
Delete [ADC] Where CODTRT='SUBBUS' or CODTRT='SUBBUI'
COMPTEUR += adxdlrec
Commit
Close Local File [ADC]

Infbox num$(COMPTEUR)
Call ECR_TRACE("UTIBUS0 : "+num$(COMPTEUR)+" records deleted",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ATYPE", "fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIBUS0(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ATYPE", "fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIBUS0(APPLI)
End

