#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# Subprog TARIFRECH (module,plityp,err)                                 #
# pour chaque ligne de la table appel de la recherche tarif             #
#-----------------------------------------------------------------------#
# APPELE                                                                #
#-----------------------------------------------------------------------#
#  module    = 5 (ventes) / 6 (achats)                                  #
#  plityp    = 1 (normal) / 2 (groupé) / 3 (interdit) / 4 (composant)   #
#  err       = OK ([v]cst_aok ou [v]cst_asuccess) / NOK [v]cst_aerror   #
#########################################################################
Subprog TARIFRECH(SPPARAM,PLINEDOC, RESULT, WMESSAGE, ERR)
Value    Instance SPPARAM  Using  OBJECT :#Value    Instance PARAM  Using  C_FINDPRICE    : # instance des paramètres en entrée de recherche tarif
Value    Integer  PLINEDOC
Variable Instance RESULT Using  C_RESULTPRICE  : # instance des paramètres en sortie de recherche tarif
Variable Char WMESSAGE
Variable Integer  ERR                         : # 1 si erreur

  ERR = [V]CST_AOK

  If SPPARAM = null      : ERR=[V]CST_AERROR : End : Endif

  #--Cast for further calls (in case of functions having in their prototypes an instance different from OBJECT)
  Local Instance PARAM  Using =SPPARAM.ObjectType
  PARAM = cast(SPPARAM,=SPPARAM.ObjectType)
  #--

  If PARAM.PLI(1) = null : ERR = [V]CST_AERROR : End : Endif

  #--Local variable declaration
  Local Decimal  JNP_MONTANT
  Local Shortint JNP_MOTIF
  Local Shortint JNP_PRIORITE
  Local Char     JNP_PLI       (GLONPLI)
  Local Char     JNP_PLICRD    (GLONVCR)
  Local Integer  JNP_PLILIN

  Local Decimal  JCRG_MONTANT            (1..)
  Local Shortint JCRG_MOTIF              (1..)
  Local Shortint JCRG_PRIORITE           (1..)
  Local Char     JCRG_PLI       (GLONPLI)(1..)
  Local Char     JCRG_PLICRD    (GLONVCR)(1..)
  Local Integer  JCRG_PLILIN             (1..)

  Local Decimal  JREP_MONTANT
  Local Shortint JREP_MOTIF
  Local Shortint JREP_PRIORITE
  Local Char     JREP_PLI       (GLONPLI)
  Local Char     JREP_PLICRD    (GLONVCR)
  Local Integer  JREP_PLILIN

  Local Char     JFOCITMREF     (GLONITM)
  Local Decimal  JFOCQTY
  Local Char     JFOCUOM        (GLONUOM)
  Local Shortint JFOCMOTIF

  Local Date     JPLISTRDAT
  Local Date     JPLIENDDAT
  Local Libelle  JINTERDIT
  Local Libelle  JERR

  Local Decimal  JNETPRI

  Local Integer  PARTNER
  Local Decimal  GROPRI, MAJREM (1..), NETPRI

  Local    Shortint  PIO                        : # priorité courante de table globale
  Local    Integer   I, J, FIN

  Local    Integer   WERR                       : # si erreur => positionné avec [V]CST_Axxx selon erreur

  #----- Sauvegarde de la table des types de tarif -----#
  Local    Integer   SAVPLITYP(1..)

  #--CPO ajout => infos concernant PARAM_T
  # PARAM_T(0) => PARAM.C_LINE().SAUSTUCOE
  # PARAM_T(1) => PARAM.VACBPR
  # PARAM_T(2) => PARAM.MLTDIVCOE
  # PARAM_T(3) => PARAM.VATCLCDAT

  For I=1 To maxtab(PARAM.PLI(1).C_PLI) : SAVPLITYP(I)=PARAM.PLI(1).C_PLI(I).GPLITYP : Next I
  #----------------------------------------------------------------#
  # Point d'entrée AVRECHTAR pour désactiver certains codes tarif  #
  # -------------------------------------------------------------- #

  #GPOINT="AVRECHTAR" : Gosub ENTREE From EXEFNC #--Attendons de voir la solution pour les PE

  #---------------------------------------------------------------------------------
  #  pour determiner si on a plusieurs recherches a effectuer
  #---------------------------------------------------------------------------------
  Local Integer WNBPLI : WNBPLI=maxtab(PARAM.PLI(1).C_PLI)
  If WNBPLI<1 : WNBPLI=1 : Endif

  Local Integer TPLISEA  (1..WNBPLI)                    : # table des codes de recherche
  Local Integer NBPLISEA : NBPLISEA = 1                 : # nombre de codes de recherche
  Local Integer IPLISEA  : IPLISEA=1                    : # indice du code de recherche
  Local Integer RPLISEA                                 : # valeur du codde de recherche en cours

  Local Integer WNBFRAISREM

  Local Decimal  WRATRPT, WCOEFDEVISE  : Raz WRATRPT : # Bug 65663
  Local Integer  WI                                  : # Bug 65663


  Local File  ACTIV     [ACV]
  Local File  ITMMASTER [ITM]

  If PARAM.MODULE = 5
    #func AFNC.ACTIV("SPR")
    Read [ACV]CODACT="SPR"
    If fstat or [F:ACV]FLACT<>[V]CST_AYES : Raz [F:ACV] : Endif
    WNBFRAISREM=[F:ACV]DIME
  Elsif PARAM.MODULE = 6
    #func AFNC.ACTIV("PPR")
    Read [ACV]CODACT="PPR"
    If fstat or [F:ACV]FLACT<>[V]CST_AYES : Raz [F:ACV] : Endif
    WNBFRAISREM=[F:ACV]DIME
  Else
    WNBFRAISREM = 0
  Endif

  For I=1 To dim(TPLISEA) : TPLISEA(I)=9999 : Next I    : # mise a maxi table des codes recherche

  For I=1 To maxtab(PARAM.PLI(1).C_PLI)
    If PARAM.PLI(1).C_PLI(I).GPLITYP<>9 & PARAM.PLI(1).C_PLI(I).GPLITYP=PARAM.PLITYP
       If !find(PARAM.PLI(1).C_PLI(I).GPLISEA,TPLISEA)
         TPLISEA(NBPLISEA)=PARAM.PLI(1).C_PLI(I).GPLISEA : NBPLISEA +=1
       Endif
    Endif
  Next I

  If PARAM.MODULE = 5 JREP_MONTANT = 1 Endif                     : # Bug 62429

  $BOUCLE_RECH
  RPLISEA=TPLISEA(IPLISEA)

  #---- initialisation
  If RESULT=null
    RESULT = NewInstance C_RESULTPRICE AllocGroup PARAM
  Endif

  ERR = [V]CST_AOK

  #RESULT.PLISTRDAT = AVOID.ADATE : RESULT.PLIENDDAT = AVOID.ADATE : RESULT.INTERDIT = AVOID.AINT
  RESULT.PLISTRDAT = [0/0/0] : RESULT.PLIENDDAT = [0/0/0] : RESULT.INTERDIT = 0

  Local Integer WLINE

  I=1
  If RESULT.C_PRICE(I)=null
    WLINE = fmet RESULT.ADDLINE("C_PRICE",I)
    If WLINE = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      WMESSAGE  = func ASYRFNC.MES2(mess(266,133,1),'C_PRICE','RESULTPRICE')
      ERR = fmet RESULT.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
      End
    Endif
  Else
    RESULT.C_PRICE(I).MONTANT  = 0  #AVOID.ADEC
    RESULT.C_PRICE(I).MOTIF    = 0  #AVOID.AINT
    RESULT.C_PRICE(I).PRIORITE = 0  #AVOID.AINT
    RESULT.C_PRICE(I).PLI      = "" #AVOID.ACHAR
    RESULT.C_PRICE(I).PLICRD   = "" #AVOID.ACHAR
    RESULT.C_PRICE(I).PLILIN   = 0  #AVOID.AINT
  Endif

  For I=1 To WNBFRAISREM
    If RESULT.C_DISCRG(I)=null
      WLINE = fmet RESULT.ADDLINE("C_DISCRG",I)
      If WLINE = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        WMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'C_DISCRG','RESULTPRICE')
        ERR = fmet RESULT.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
        End
      Endif
    Else
      RESULT.C_DISCRG(I).MONTANT  = 0  #AVOID.ADEC
      RESULT.C_DISCRG(I).MOTIF    = 0  #AVOID.AINT
      RESULT.C_DISCRG(I).PRIORITE = 0  #AVOID.AINT
      RESULT.C_DISCRG(I).PLI      = "" #AVOID.ACHAR
      RESULT.C_DISCRG(I).PLICRD   = "" #AVOID.ACHAR
      RESULT.C_DISCRG(I).PLILIN   = 0  #AVOID.AINT
    Endif
  Next I

  I=1
  If RESULT.C_FOC(I)=null
    WLINE = fmet RESULT.ADDLINE("C_FOC",I)
    If WLINE = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      WMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'C_FOC','RESULTPRICE')
      ERR = fmet RESULT.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
      End
    Endif
  Else
    RESULT.C_FOC (I).FOCITMREF = "" #AVOID.ACHAR
    RESULT.C_FOC (I).FOCQTY    = 0  #AVOID.ADEC
    RESULT.C_FOC (I).FOCUOM    = "" #AVOID.ACHAR
    RESULT.C_FOC (I).FOCMOTIF  = 0  #AVOID.AINT
  Endif

  I=1
  If RESULT.C_REPCOE(I)=null
    WLINE = fmet RESULT.ADDLINE("C_REPCOE",I)
    If WLINE = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      WMESSAGE =  func ASYRFNC.MES2(mess(266,133,1),'C_REPCOE','RESULTPRICE')
      ERR = fmet RESULT.ASETERROR ("", WMESSAGE, [V]CST_AERROR)
      End
    Endif
  Else
    RESULT.C_REPCOE(I).MONTANT  = 0  #AVOID.ADEC
    RESULT.C_REPCOE(I).MOTIF    = 0  #AVOID.AINT
    RESULT.C_REPCOE(I).PRIORITE = 0  #AVOID.AINT
    RESULT.C_REPCOE(I).PLI      = "" #AVOID.ACHAR
    RESULT.C_REPCOE(I).PLICRD   = "" #AVOID.ACHAR
    RESULT.C_REPCOE(I).PLILIN   = 0  #AVOID.AINT
  Endif

  If PARAM.MODULE = 5 RESULT.C_REPCOE(1).MONTANT = 1 Endif                     : # Bug 62429

  #---- lecture de la table globale

  For I=1 To maxtab(PARAM.PLI(1).C_PLI)
    If PARAM.PLI(1).C_PLI(I) <> null and find(PARAM.PLI(1).C_PLI(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1

     If PARAM.PLI(1).C_PLI(I).GPLITYP<>9 & PARAM.PLI(1).C_PLI(I).GPLISEA=RPLISEA : # Le code tarif n'est pas rendu inactif par le point d'entrée
        #---- fin de recherche en table
        If    RESULT.INTERDIT = 1             : Goto FIN_TARIFRECH   : Endif
        If    PARAM.PLI(1).C_PLI(I).GPLITYP > PARAM.PLITYP : Goto FIN_BOUCLE_RECH : Endif

        FIN = 1
        For   J = 1 To PARAM.GDISCRG
          If RESULT.C_DISCRG(J) <> null and find(RESULT.C_DISCRG(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
            If    RESULT.C_DISCRG(J).MOTIF = 0 | RESULT.C_DISCRG(J).PRIORITE = PARAM.PLI(1).C_PLI(I).GPIO : FIN = 0 : Break
            Endif
          Endif
        Next J
        If RESULT.C_PRICE(1)<>null and find(RESULT.C_PRICE(1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
          If    RESULT.C_PRICE(1).MOTIF = 0 | RESULT.C_PRICE(1).PRIORITE = PARAM.PLI(1).C_PLI(I).GPIO
            FIN = 0
          Endif
        Endif
        If RESULT.C_REPCOE(1)<>null and find(RESULT.C_REPCOE(1).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
          If    RESULT.C_REPCOE(1).MOTIF  = 0 | RESULT.C_REPCOE(1).PRIORITE  = PARAM.PLI(1).C_PLI(I).GPIO
            FIN = 0
          Endif
        Endif
        If    FIN = 1 : Break : Endif #Goto FIN_BOUCLE_RECH : Endif
        #---- chargement des tarifs
        If    PARAM.PLI(1).C_PLI(I).GPLITYP = PARAM.PLITYP
              PIO = PARAM.PLI(1).C_PLI(I).GPIO
              PARAM.PIO = PIO
              If PARAM.MODULE  = 5
                NOMTRAIT = "WBT"+PARAM.PLI(1).C_PLI(I).GPLI+"_SY"
               Else
                NOMTRAIT = "WAT"+PARAM.PLI(1).C_PLI(I).GPLI+"_SY"
              Endif

          If filinfo(filpath("TRT",[L]NOMTRAIT,"adx",nomap,"",""),0)>0 # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA

              Call TARIF(PARAM, PLINEDOC, RESULT, WERR, WMESSAGE) From =NOMTRAIT

              If fmet RESULT.AGETMAXERROR("")>=[V]CST_AERROR or WERR>=[V]CST_AERROR
                If WMESSAGE="" #AVOID.ACHAR
                  WMESSAGE = mess(68,123,1)-":"-mess(3,7845,1)-"TARIF"
                Endif
                ERR = fmet PARAM.ASETERROR ("",WMESSAGE , [V]CST_AERROR)
                End
              Endif

           Endif # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA

           #GPOINT="CPLTARIF" : Gosub ENTREE From EXEFNC #--Attendons de voir la solution pour les PE

        Endif
     Endif
    Endif
  Next I

  $FIN_BOUCLE_RECH

  If NBPLISEA <3 #2
    Goto FIN_TARIFRECH                      : # un seul niveau pas besoin de comparaison
  Endif

  If PARAM.MODULE=5 : PARTNER=1 Else PARTNER=2 : Endif

  GROPRI=RESULT.C_PRICE(1).MONTANT

  For I=1 To maxtab(RESULT.C_DISCRG)
    If RESULT.C_DISCRG(I)<>null and find(RESULT.C_DISCRG(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
      If I <= dim(MAJREM)
        MAJREM(I)=RESULT.C_DISCRG(I).MONTANT
      Endif
    Endif
  Next I

  Raz NETPRI

  If RESULT.C_PRICE(1)<>null and RESULT.C_PRICE(1).MOTIF<>0  :# uniquement si prix avec motif

      # pas de garnissage de GCALNETLIN et GCALNETABR ( Interne a recherche tarif )
      Call CALNET(PARAM.ACTX,PARAM.FCY, PARTNER,"",GROPRI,MAJREM,PARAM.C_LINE(PLINEDOC).QTY,NETPRI,PARAM.CUR, WERR, WMESSAGE) From TRTPRICE_SYRA

      If fmet PARAM.AGETMAXERROR("")>=[V]CST_AERROR or WERR>=[V]CST_AERROR
        If WMESSAGE="" #AVOID.ACHAR
          WMESSAGE = mess(68,123,1)-":"-mess(3,7845,1)-"CALNET"
        Endif
        ERR = fmet PARAM.ASETERROR ("",WMESSAGE , [V]CST_AERROR)
        End
      Endif

      #-- Stockage donnee de la nouvelle boucle de recherche
      #      - si les donnees stockees sans prix dans le parametrage
      #      - ou si prix net nouvelle boucle < boucle stockee
      If JNP_PLI = "" | (NETPRI<JNETPRI & RESULT.C_PRICE(1).PLI<>"")

        JNETPRI=NETPRI
        Gosub RECH_STOC

      Endif
  Endif

  #-- Stockage donnee de la nouvelle boucle de recherche ( bug 31160 )
  #      - si boucle sans parametrage prix ( prix issu des prix de base )
  #      - et si aucune donnees stockees
  If RESULT.C_PRICE(1) <> null and RESULT.C_PRICE(1).MOTIF=0 &
&  sum(RESULT.C_PRICE(1..maxtab(RESULT.C_PRICE)).MOTIF,
&      RESULT.C_REPCOE(1..maxtab(RESULT.C_REPCOE)).MOTIF,
&      RESULT.C_DISCRG(1..maxtab(RESULT.C_DISCRG)).MOTIF)<>0 &
&  sum(JNP_MOTIF, JCRG_MOTIF, JREP_MOTIF)=0

     Gosub RECH_STOC

  Endif

  IPLISEA +=1
  If IPLISEA < NBPLISEA
    Goto BOUCLE_RECH                       : # boucle sur autre code de recherche
  Else
    Gosub STOC_RECH                        : # il faut recharger le buffer de recherche
  Endif

  $FIN_TARIFRECH
  #----- Restauration de la table des types de tarif -----#
  For I=1 To maxtab(PARAM.PLI(1).C_PLI)
    If PARAM.PLI(1).C_PLI(I)<>null
      PARAM.PLI(1).C_PLI(I).GPLITYP=SAVPLITYP(I)
    Endif
  Next I

  If PARAM.MODULE=5
    #GPOINT="TARIFVEN" : Gosub ENTREE From EXEFNC #--Attendons de voir la solution pour les PE
  Endif

  If PARAM.MODULE=6
    #GPOINT="TARIFACH" : Gosub ENTREE From EXEFNC #--Attendons de voir la solution pour les PE
  Endif

End
#--------------------------------------------------------------------------------------------------
$PE_RECHTARIF

  #--Attendons de voir la solution pour les PE
  #GPOINT="RECHTARIF" : Gosub ENTREE From EXEFNC

Return
#--------------------------------------------------------------------------------------------------
$PE_RECHTARIF1

  #--Attendons de voir la solution pour les PE
  #GPOINT="RECHTARIF1" : Gosub ENTREE From EXEFNC

Return
#--------------------------------------------------------------------------------------------------
#---------------------------------------------------------------------------------
#  buffer recherche --> buffer stockage
#---------------------------------------------------------------------------------
$RECH_STOC

  I=1
  If RESULT.C_PRICE(I)<>null
    JNP_MONTANT  = RESULT.C_PRICE(I).MONTANT
    JNP_MOTIF    = RESULT.C_PRICE(I).MOTIF
    JNP_PRIORITE = RESULT.C_PRICE(I).PRIORITE
    JNP_PLI      = RESULT.C_PRICE(I).PLI
    JNP_PLICRD   = RESULT.C_PRICE(I).PLICRD
    JNP_PLILIN   = RESULT.C_PRICE(I).PLILIN
  Endif

  For I=1 To maxtab(RESULT.C_DISCRG)
    If RESULT.C_DISCRG(I)<>null
      If I<=dim(JCRG_MONTANT)  : JCRG_MONTANT (I) = RESULT.C_DISCRG(I).MONTANT  : Endif
      If I<=dim(JCRG_MOTIF)    : JCRG_MOTIF   (I) = RESULT.C_DISCRG(I).MOTIF    : Endif
      If I<=dim(JCRG_PRIORITE) : JCRG_PRIORITE(I) = RESULT.C_DISCRG(I).PRIORITE : Endif
      If I<=dim(JCRG_PLI)      : JCRG_PLI     (I) = RESULT.C_DISCRG(I).PLI      : Endif
      If I<=dim(JCRG_PLICRD)   : JCRG_PLICRD  (I) = RESULT.C_DISCRG(I).PLICRD   : Endif
      If I<=dim(JCRG_PLILIN)   : JCRG_PLILIN  (I) = RESULT.C_DISCRG(I).PLILIN   : Endif
    Endif
  Next I

  I=1
  If RESULT.C_REPCOE(I)<>null
    JREP_MONTANT  = RESULT.C_REPCOE(I).MONTANT
    JREP_MOTIF    = RESULT.C_REPCOE(I).MOTIF
    JREP_PRIORITE = RESULT.C_REPCOE(I).PRIORITE
    JREP_PLI      = RESULT.C_REPCOE(I).PLI
    JREP_PLICRD   = RESULT.C_REPCOE(I).PLICRD
    JREP_PLILIN   = RESULT.C_REPCOE(I).PLILIN
  Endif

  I=1
  If RESULT.C_FOC(I)<>null
    JFOCITMREF    = RESULT.C_FOC(I).FOCITMREF
    JFOCQTY       = RESULT.C_FOC(I).FOCQTY
    JFOCUOM       = RESULT.C_FOC(I).FOCUOM
    JFOCMOTIF     = RESULT.C_FOC(I).FOCMOTIF
  Endif

  JPLISTRDAT   = RESULT.PLISTRDAT
  JPLIENDDAT   = RESULT.PLIENDDAT
  JINTERDIT    = RESULT.INTERDIT
  JERR=ERR

Return
#--------------------------------------------------------------------------------------------------
#---------------------------------------------------------------------------------
#  buffer stockage --> buffer recherche
#---------------------------------------------------------------------------------
$STOC_RECH

  I=1
  If RESULT.C_PRICE(I)<>null
    RESULT.C_PRICE(I).MONTANT  = JNP_MONTANT
    RESULT.C_PRICE(I).MOTIF    = JNP_MOTIF
    RESULT.C_PRICE(I).PRIORITE = JNP_PRIORITE
    RESULT.C_PRICE(I).PLI      = JNP_PLI
    RESULT.C_PRICE(I).PLICRD   = JNP_PLICRD
    RESULT.C_PRICE(I).PLILIN   = JNP_PLILIN
  Endif

  For I=1 To maxtab(RESULT.C_DISCRG)
    If RESULT.C_DISCRG(I)<>null
      If I<=dim(JCRG_MONTANT)  : RESULT.C_DISCRG(I).MONTANT  = JCRG_MONTANT(I)  : Endif
      If I<=dim(JCRG_MOTIF)    : RESULT.C_DISCRG(I).MOTIF    = JCRG_MOTIF(I)    : Endif
      If I<=dim(JCRG_PRIORITE) : RESULT.C_DISCRG(I).PRIORITE = JCRG_PRIORITE(I) : Endif
      If I<=dim(JCRG_PLI)      : RESULT.C_DISCRG(I).PLI      = JCRG_PLI(I)      : Endif
      If I<=dim(JCRG_PLICRD)   : RESULT.C_DISCRG(I).PLICRD   = JCRG_PLICRD(I)   : Endif
      If I<=dim(JCRG_PLILIN)   : RESULT.C_DISCRG(I).PLILIN   = JCRG_PLILIN(I)   : Endif
    Endif
  Next I

  I=1
  If RESULT.C_REPCOE(I)<>null
    RESULT.C_REPCOE(I).MONTANT  = JREP_MONTANT
    RESULT.C_REPCOE(I).MOTIF    = JREP_MOTIF
    RESULT.C_REPCOE(I).PRIORITE = JREP_PRIORITE
    RESULT.C_REPCOE(I).PLI      = JREP_PLI
    RESULT.C_REPCOE(I).PLICRD   = JREP_PLICRD
    RESULT.C_REPCOE(I).PLILIN   = JREP_PLILIN
  Endif

  I=1
  If RESULT.C_FOC(I)<>null
    RESULT.C_FOC(I).FOCITMREF   = JFOCITMREF
    RESULT.C_FOC(I).FOCQTY      = JFOCQTY
    RESULT.C_FOC(I).FOCUOM      = JFOCUOM
    RESULT.C_FOC(I).FOCMOTIF    = JFOCMOTIF
  Endif

  RESULT.PLISTRDAT = JPLISTRDAT
  RESULT.PLIENDDAT = JPLIENDDAT
  RESULT.INTERDIT  = JINTERDIT
  ERR = JERR

Return
#--------------------------------------------------------------------------------------------------
#########################################################################
# Point d'entrée appelé dans divers traitements tarifs ( générés ou non )
# - Rappel : Trt générés ( WATxxxxxx = achats / WBTxxxxxx = ventes )
#------------------------------------------------------------------------
# Valeurs codes : ( Txx = Tous les tarifs / Axx = Achats / Vxx = Ventes
# - T01 : Tous  : Appel avant le Filter
#------------------------------------------------------------------------
$PE_TARIFS

  #GPOINT="TARIFS" : Gosub ENTREE From EXEFNC #--Attendons de voir la solution pour les PE
  If dim(CODENTPNT)>0 : Raz CODENTPNT : Endif

Return
#--------------------------------------------------------------------------------------------------
#########################################################################
# Point d'entrée appelé dans $CONSULTATION des traitements générés tarifs
# lors de la simulation de recherche
# - WATxxxxxx des achats
# - WBTxxxxxx des ventes
#------------------------------------------------------------------------
$PE_SIMTARIF

  #GPOINT="SIMTARIF" : Gosub ENTREE From EXEFNC #--Attendons de voir la solution pour les PE

Return
#--------------------------------------------------------------------------------------------------
##########################################################################
# Subprog CALNET (PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET)                 #
#------------------------------------------------------------------------#
# Calcul du prix net (dans NET) à partir du prix brut et des maj/remises #
#------------------------------------------------------------------------#
#  PARTNER   = 1 (client) / 2 (fournisseur)                              #
#  STRUCTURE = Code structure de PRICSTRUCT                              #
#  BRUT      = Prix brut                                                 #
#  MAJREM    = Majoration/Remises (en % ou montant/en cumul ou cascade   #
#  QTE       = Quantité                                                  #
#  NET       = Prix net                                                  #
#  CUR       = Devise pour arrondir le prix calcule  (pas besoin)        #
#              tant pis on la passe quand même                           #
#------------------------------------------------------------------------#
# Attention: La table PRICSTRUCT (PRS) doit être ouverte                 #
#            Si le prix net est négatif après calcul, celui est mis à    #
#            zéro et GMESSAGE est chargé avec un message d'avertissement #
##########################################################################
Subprog CALNET_ADAPTER(CTX,PFCY,PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR,WERR,WMESSAGE)
Value  Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char     PFCY
Value    Integer  PARTNER
Value    Char     STRUCTURE
Value    Decimal  BRUT
Variable Instance MAJREM(1..) Using OBJECT
Value    Decimal  QTE
Variable Decimal  NET
Value    Char     CUR
Variable Integer  WERR                   : # si erreur => positionné avec [V]CST_Axxx selon erreur
Variable Char     WMESSAGE()             : # le contenu du message

  WERR     = [V]CST_AOK
  WMESSAGE = "" #AVOID.ACHAR

  #If MAJREM = null : WERR=[V]CST_AERROR : End : Endif
  If MAJREM <> null
    Local Decimal   TAB_MAJREM(1..9) #maxtab(MAJREM)) # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA
    Local Integer   I,J # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA

    J=0
    For I=1 To maxtab(MAJREM)
      # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA
      #If MAJREM(I)<>null and dim(MAJREM(I).DISCRGVAL)>0
      #  TAB_MAJREM(I)= MAJREM(I).DISCRGVAL
      #Else
      #  TAB_MAJREM(I)= 0
      #Endif
      If MAJREM(I)<>null and dim(MAJREM(I).DISCRGVAL)>0
&       and find(MAJREM(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL) = 0 and J<=8
        J=J+1
        TAB_MAJREM(J)= MAJREM(I).DISCRGVAL
      Endif
    Next I
  Else
    Local Decimal   TAB_MAJREM(1..9)
  Endif

  Call CALNET(CTX,PFCY,PARTNER,STRUCTURE,BRUT,TAB_MAJREM,QTE,NET,CUR,WERR,WMESSAGE)
  If WERR>=[V]CST_AERROR
    If WMESSAGE="" #AVOID.ACHAR
      WMESSAGE = "Subroutine CALNET_ADAPTER from TRTPRICE_SYRA : result error for Call TARIF"
    Endif
    End
  Endif

  #--CPO No need => used only as input to CALNET
  #  #--Load the collection to dimensioned variable
  #  For I=1 To maxtab(MAJREM)
  #    If MAJREM(I)<>null
  #      MAJREM(I).DISCRGVAL = TAB_MAJREM(I)
  #    Endif
  #  Next I

End
#--------------------------------------------------------------------------------------------------
Subprog CALNET (CTX,PFCY,PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR,WERR,WMESSAGE)
Value  Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char     PFCY
Value    Integer  PARTNER
Value    Char     STRUCTURE
Value    Decimal  BRUT
Value    Decimal  MAJREM(1..)
Value    Decimal  QTE
Variable Decimal  NET
Value    Char     CUR
Variable Integer  WERR                   : # si erreur => positionné avec [V]CST_Axxx selon erreur
Variable Char     WMESSAGE()             : # le contenu du message

  #Local    Decimal WREM(1..9) : Raz WREM  :#--CPO For what purpose do we need this variable ? Is it for the Entry Point ?
  If dim(MAJREM) >0
    Local    Decimal WREM(1..dim(MAJREM))
  Else
    Local    Decimal WREM(1..9)
  Endif

  Call CALNET_DETAILS(CTX,PFCY,PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR,WREM,WERR,WMESSAGE)

End
#--------------------------------------------------------------------------------------------------
Subprog CALNET_DETAILS(CTX,PFCY,PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR,WREM,WERR,WMESSAGE)
Value  Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char     PFCY
Value    Integer  PARTNER
Value    Char     STRUCTURE
Value    Decimal  BRUT
Value    Decimal  MAJREM(1..)
Value    Decimal  QTE
Variable Decimal  NET
Value    Char     CUR
Variable Decimal  WREM(1..)
Variable Integer  WERR                   : # si erreur => positionné avec [V]CST_Axxx selon erreur
Variable Char     WMESSAGE()             : # le contenu du message

  #Local    Decimal WREM(1..) : Raz WREM  :#--CPO For what purpose do we need this variable ? Is it for the Entry Point ?
  Local    Integer I

##--------------------------------------------------------------------------------------------------
#Subprog CALNET (CTX,PFCY,PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR,WERR,WMESSAGE)
#Value  Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
#Value    Char     PFCY
#Value    Integer  PARTNER
#Value    Char     STRUCTURE
#Value    Decimal  BRUT
#Value    Decimal  MAJREM(1..)
#Value    Decimal  QTE
#Variable Decimal  NET
#Value    Char     CUR
#Variable Integer  WERR                   : # si erreur => positionné avec [V]CST_Axxx selon erreur
#Variable Char     WMESSAGE()             : # le contenu du message
#
#  Local    Decimal WREM(1..) : Raz WREM  :#--CPO For what purpose do we need this variable ? Is it for the Entry Point ?
  Local    Integer I

  WERR     = [V]CST_AOK
  WMESSAGE = "" #AVOID.ACHAR

  #If dim(GCALNETLIN)<=0 : Global Integer GCALNETLIN : Endif
  #If dim(GCALNETABR)<=0 : Global Char    GCALNETABR : Endif

  Local File PRICSTRUCT [PRS]

  If [F:PRS]BPCBPS<>PARTNER | [F:PRS]PLISTC<>STRUCTURE
    Read [PRS]PRS0=PARTNER;STRUCTURE
    If fstat
       NET = 0 : #Raz GCALNETLIN, GCALNETABR # Issue 93046 - 2013-09-30 by MUARN : erreur variable
       WMESSAGE = mess(23,100,1)-num$(PARTNER)+";"+STRUCTURE
       End
    Endif
  Endif

  #--CPO Remplacement des globales
  #GDECPRI, GSALRND, GPURRND
  If CTX = null
    CTX = GACTX
  Endif

  Local Integer CTX_DECPRI : CTX_DECPRI = func SREPLACEGLOB_SYRA.GET_GDECPRI()
  Local Tinyint CTX_SALRND : CTX_SALRND = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,PFCY,"SALRND")
  Local Tinyint CTX_PURRND : CTX_PURRND = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,PFCY,"PURRND")
  #--

  If QTE = 0  QTE = 1  Endif

  NET = BRUT

  For I = 0 To dim(MAJREM)-1 #8 # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA
     If [F:PRS]NPRNOTFLG(I) = 2
        If [F:PRS]INCDCR(I) = 1
           If [F:PRS]VALTYP(I) = 1
              If [F:PRS]CLCRUL(I) <> 1
                 NET += MAJREM(I+1)/QTE      : WREM(I+1) = MAJREM(I+1)/QTE
              Else
                 NET += MAJREM(I+1)          : WREM(I+1) = MAJREM(I+1)
              Endif
           Elsif [F:PRS]VALTYP(I) = 2
              WREM(I+1) = (BRUT*MAJREM(I+1))/100 : NET += (BRUT*MAJREM(I+1))/100
           Else
              WREM(I+1) = (NET*MAJREM(I+1))/100  : NET += (NET*MAJREM(I+1))/100
           Endif
        Else
           If [F:PRS]VALTYP(I) = 1
              If [F:PRS]CLCRUL(I) <> 1
                 NET -= MAJREM(I+1)/QTE      : WREM(I+1) = -MAJREM(I+1)/QTE
              Else
                 NET -= MAJREM(I+1)          : WREM(I+1) = -MAJREM(I+1)
              Endif
           Elsif [F:PRS]VALTYP(I) = 2
              WREM(I+1) = -(BRUT*MAJREM(I+1))/100 : NET -= (BRUT*MAJREM(I+1))/100
           Else
              WREM(I+1) = -(NET*MAJREM(I+1))/100  : NET -= (NET*MAJREM(I+1))/100
           Endif
        Endif
     Endif
  Next I

  # Point d'entrée pour intervenir sur le calcul du prix net
  Local Integer GPE_RND
  #GPOINT="CALNET" : Gosub ENTREE From EXEFNC #--Attendons de voir la solution pour les PE

  #---------------------#
  # arrondi du prix net #
  #---------------------#
  If !GPE_RND
     If (PARTNER = 1 & CTX_SALRND = 2) | (PARTNER = 2 & CTX_PURRND = 2)
        Call ARRDEV(NET,CUR, "") From TRTDIV_SYRA #Call ARRDEV(NET,CUR, AVOID.ACHAR) From TRTDIV_SYRA
     Else
        NET = arr(NET,10^-CTX_DECPRI)
     Endif
  Endif

  Raz GPE_RND

  #----- Test si prix net négatif alors GMESSAGE et raz -----#
  If NET<0  WMESSAGE=mess(216,199,1) : WERR=[V]CST_AERROR Else Raz WMESSAGE : Endif

  #--------------------------------------------------------#
  # Point d'entrée NEGPRI pour autoriser les prix négatifs #
  # ------------------------------------------------------ #

  #--Attendons de voir la solution pour les PE
  #If PARTNER=2 & dim(GPURNEGPRI)>0 & GPURNEGPRI=2
  #  GPOINT="NEGPRI" : Gosub ENTREE From EXEFNC
  #  Raz GPURNEGPRI
  #Endif
  #--Attendons de voir la solution pour les PE
  #If PARTNER=1
  #  GPOINT="NEGPRI" : Gosub ENTREE From EXEFNC
  #Endif

  #-----
  If WMESSAGE<>""  Raz NET : Endif

  #Raz GCALNETLIN, GCALNETABR

End
#--------------------------------------------------------------------------------------------------
#------------------------------------------------------------------#
# Alimentation concernant les colonnes frais/remises               #
#              suite à modification de la structure tarif          #
#------------------------------------------------------------------#
# Entrée   WPARTNER   : 1 (client) / 2 (fournisseur)               #
#          WDEVISE    : Devise                                     #
#          WRECPLISTC : Recherche structure 0 (non) / 1 (oui)      #
#          MYDOC      : Instance de document                       #
# Sortie   WPLISTC    : Code structure                             #
#          MYPLI      : Instance contenant les coll de GPLIetc     #
#          MYFMTCOLREM: Instance contenant les coll de GFMTetc     #
#          VMESSA     : Le message d'erreur (cas échéant)          #
#------------------------------------------------------------------#
Funprog ALICOLREM(WPARTNER, WDEVISE, WRECPLISTC, MYDOC, MYPLI, MYFMTCOLREM, WPLISTC, VMESSA)
Value    Integer  WPARTNER
Value    Char     WDEVISE
Value    Integer  WRECPLISTC
Value    Instance MYDOC       Using OBJECT
Variable Instance MYPLI       Using C_PLI
Variable Instance MYFMTCOLREM Using C_FMTCOLREM
Variable Char     WPLISTC
Variable Char     VMESSA

Local Integer WRET
Raz VMESSA

  If MYDOC = null :
    VMESSA = "ALICOLREM :"-mess(18,9137,1)-"MYDOC"
    End [V]CST_AERROR
  Endif

  If MYPLI = null
     VMESSA = "ALICOLREM :"-mess(18,9137,1)-"MYPLI"
     WRET = fmet MYDOC.ASETERROR("",VMESSA,[V]CST_AERROR)
     End WRET
#    MYPLI = NewInstance C_PLI :#--CPO If new instance => to what allocgroup must we attach it ? (For when we free it)
  Endif

  Local Integer  WMODULE : If WPARTNER=1 WMODULE=5 Else WMODULE=6 Endif

  Local File COMPANY [CPY]
  Raz WPLISTC

  If WRECPLISTC=1 and MYDOC <> null and dim(MYDOC.CPY)>0
      If [F:CPY]CPY<>MYDOC.CPY
          Read [CPY] CPY0=MYDOC.CPY
          If fstat Raz [F:CPY] Endif
      Endif
      WPLISTC=[F:CPY]PLISTC
  Endif

  If WRECPLISTC=2
    If [F:BPS]BPSNUM<>MYDOC.BPSNUM
      Read [BPS]BPS0=MYDOC.BPSNUM
          If fstat Raz [F:CPY] Endif
      Endif
      WPLISTC=[F:BPS]PLISTC
  Endif
  #-- Lit la structure, garnit GFMTREM(I) (% ou M), GFMTCOL(I) (Fmt col.), GCOLREM(I) (Lib. col.)
  WRET = func TRTPRICE_SYRA.COLREM("C",WPARTNER, WPLISTC, MYDOC, MYFMTCOLREM, VMESSA) #From TRTPRICE_SYRA
  If WRET>= [V]CST_AERROR
     If VMESSA=""
       VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"COLREM"
     Endif
     WRET = fmet MYDOC.ASETERROR("", VMESSA, WRET)
     End WRET
  Endif
  #-- Lit la structure, garnit des globales avec les caractéristiques des colonnes
  WRET = func TRTPRICE_SYRA.TYPREM(WPARTNER, WPLISTC, MYDOC, MYFMTCOLREM, VMESSA) #From TRTPRICE_SYRA
  If WRET>= [V]CST_AERROR
     If VMESSA=""
       VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"TYPREM"
     Endif
     WRET = fmet MYDOC.ASETERROR("", VMESSA, WRET)
     End WRET
  Endif

  #-- Lit la structure, garnit des anciennes globales devenues propriétés utiles à la recherche tarif
  #-- Fait systématiquement : La liste des tarifs actifs est dépendante de la structure mais aussi de la société
  WRET = func TRTPRICE_SYRA.TARIFCHGT(WMODULE, MYDOC, MYPLI, WPLISTC, VMESSA) #From TRTPRICE_SYRA
  If WRET>= [V]CST_AERROR
     If VMESSA=""
       VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"TARIFCHGT"
     Endif
     WRET = fmet MYDOC.ASETERROR("", VMESSA, WRET)
     End WRET
  Endif

  #-- Garnissage du format de saisie des colonnes dans GFORREM (0..8)
  If WDEVISE<>""
    WRET = func  TRTPRICE_SYRA.ALIFORREM(MYDOC, 1, WDEVISE, MYFMTCOLREM, VMESSA) #From TRTPRICE_SYRA
    If WRET>= [V]CST_AERROR
       If VMESSA=""
         VMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"ALIFORREM"
       Endif
       WRET = fmet MYDOC.ASETERROR("", VMESSA, WRET)
       End WRET
    Endif
  Endif

End WRET
#--------------------------------------------------------------------------------------------------
#########################################################################
#                                                                       #
#      TRAITEMENTS LIES aux PRIX ACHAT/VENTE                            #
#                                                                       #
#########################################################################
#-----------------------------------------------------------------------#
# Traitements non e_commerce                                            #
#-----------------------------------------------------------------------#
#########################################################################
# Subprog COLREM (TAILLE,PARTNER,STRUCTURE)                             #
# garni les variables GCOLREM (x) pour les colonnes rem/frais des tarifs#
# garni le code format "%" ou "M" dans GFMTREM (0..8)                   #
# garni le format des colonnes rem/frais dans GFMTCOL (0..8)            #
#-----------------------------------------------------------------------#
# DEFINIR dans masque lib. évalués GCOLREM(0..8) format GFMTREM(0..8)   #
# APPELER dans action OUVRE avant affichage du masque                   #
#-----------------------------------------------------------------------#
#  TAILLE    = C (libellé 12) / L (libellé 20)                          #
#  PARTNER   = 1 (client) / 2 (fournisseur)                             #
#  STRUCTURE = Code structure de PRICSTRUCT                             #
#########################################################################
Funprog COLREM (TAILLE,PARTNER,STRUCTURE,MYDOC,MYFMTCOLREM, VMESSA)
Value    Char     TAILLE
Value    Integer  PARTNER
Value    Char     STRUCTURE
Value    Instance MYDOC       Using OBJECT
Variable Instance MYFMTCOLREM Using C_FMTCOLREM
Variable Char     VMESSA

Local Integer WRET

  If MYDOC = null :
    VMESSA = "MYDOC"-mess(18,9137,1)
    End [V]CST_AERROR
  Endif

  If MYFMTCOLREM=null
     VMESSA = "MYFMTCOLREM :"-mess(18,9137,1)
     WRET = fmet MYDOC.ASETERROR("", VMESSA, [V]CST_AERROR)
     End WRET
  Endif

  #----- Vérification de la validité des paramètres -----#
  If TAILLE<>"C" & TAILLE<>"L"  End [V]CST_AOK : Endif
  If PARTNER<>1  & PARTNER<>2   End [V]CST_AOK : Endif

  #----- Lecture de la structure tarif -----#
  Local File PRICSTRUCT [PRS]
  Local File ACTIV      [ACV]

  Read [PRS]PRS0=PARTNER;STRUCTURE
  If fstat
    Raz [F:PRS]
    VMESSA = mess(23,100,1)-num$(PARTNER)+";"+STRUCTURE
    WRET = fmet MYDOC.ASETERROR("",VMESSA,[V]CST_AWARNING)
    End WRET
  Endif
  #-----
  Local    Integer I
  Local    Integer NBMAX
  #----- Récupération valeur du code activité pour nbre de colonnes tarif -----#
  If PARTNER=1
    # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA
    #Read [ACV]CODACT="SPR"
    #If fstat or [F:ACV]FLACT<>[V]CST_AYES : Raz [F:ACV] : Endif
    #NBMAX=[F:ACV]DIME
    NBMAX = func ASYRFNC.ACTIV("SPR")
    # End issue X3-36849
  Elsif PARTNER=2
    # Issue X3-36849 - 2017-05-11 by CPO : (SAM 122869) Price search read only pages TRTPRICE_SYRA
    #Read [ACV]CODACT="PPR"
    #If fstat or [F:ACV]FLACT<>[V]CST_AYES : Raz [F:ACV] : Endif
    #NBMAX=[F:ACV]DIME
    NBMAX = func ASYRFNC.ACTIV("PPR")
    # End issue X3-36849
  Else
    NBMAX = 0
  Endif
  #-----
  Local Integer WLINE, I

  For I=1 To NBMAX
    If MYFMTCOLREM.C_FMTCOL(I)=null
      WLINE = fmet MYFMTCOLREM.ADDLINE("C_FMTCOL",I)
      If WLINE = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        VMESSA = func ASYRFNC.MES2(mess(266,133,1),'C_FMTCOL','FMTCOLREM')
        WERR = fmet MYFMTCOLREM.ASETERROR ("",VMESSA, [V]CST_AERROR)
        End WERR
      Endif
    Else
      MYFMTCOLREM.C_FMTCOL(I).GFMTCOL = "" #AVOID.ACHAR
      MYFMTCOLREM.C_FMTCOL(I).GCOLREM = "" #AVOID.ACHAR
      MYFMTCOLREM.C_FMTCOL(I).GFMTREM = "" #AVOID.ACHAR
    Endif
  Next I

  #-----
  For I=1 To NBMAX
    If dim([F:PRS]INCDCR(I-1))<1 : Break : Endif
    If [F:PRS]INCDCR(I-1)<>0
      If TAILLE="L"
        #--CPO 87751 Il faut les lire dans tous les cas (sinon impossible d'importer des remises/frais)
        #-- 80866 Performance Import --#
        #If !GIMPORT : Call GET_ATEXTRA ("PRICSTRUCT","DESAXX("+num$(I)+")",GLANGUE,GCOLREM(I)) From TRTX3TEX : Endif
        Call GET_ATEXTRA (MYDOC.ACTX, "PRICSTRUCT","DESAXX("+num$(I-1)+")",MYDOC.ACTX.LAN,num$([F:PRS]BPCBPS),[F:PRS]PLISTC,MYFMTCOLREM.C_FMTCOL(I).GCOLREM) From SREPLACEGLOB_SYRA
        #--/
      Else
        #--CPO 87751 Il faut les lire dans tous les cas (sinon impossible d'importer des remises/frais)
        #-- 80866 Performance Import --#
        #If !GIMPORT : Call GET_ATEXTRA ("PRICSTRUCT","SHOAXX("+num$(I)+")",GLANGUE,GCOLREM(I)) From TRTX3TEX : Endif
        Call GET_ATEXTRA (MYDOC.ACTX, "PRICSTRUCT","SHOAXX("+num$(I-1)+")",MYDOC.ACTX.LAN,num$([F:PRS]BPCBPS),[F:PRS]PLISTC,MYFMTCOLREM.C_FMTCOL(I).GCOLREM) From SREPLACEGLOB_SYRA
        #--/
      Endif
      If [F:PRS]VALTYP(I-1)=2 | [F:PRS]VALTYP(I-1)=3
        MYFMTCOLREM.C_FMTCOL(I).GFMTREM="%"
      Else
        MYFMTCOLREM.C_FMTCOL(I).GFMTREM="M"
      Endif
      MYFMTCOLREM.C_FMTCOL(I).GFMTCOL=[F:PRS]FMTCOL(I-1)

    Endif
  Next I
  #-----

  # -------------------------------------------------------------------------
  # Point d'entrée COLREM pour modifier l'intitulé des colonnes frais/remises
  # -------------------------------------------------------------------------
  #GPOINT="COLREM" : Gosub ENTREE From EXEFNC

End WRET
#--------------------------------------------------------------------------------------------------
#########################################################################
# Subprog TYPREM (PARTNER,STRUCTURE)                                    #
# garni le type de chaque remise/frais (mnt,%)                          #
# garni le no d'élément de facturation associé à chaque remise/frais    #
# garni l'indicateur prix net HT ligne                                  #
# garni l'indicateur base de calcul (par unité, ligne ou document)      #
#-----------------------------------------------------------------------#
# APPELER dans action OUVRE pour les ventes                             #
#         après saisie du fournisseur pour les achats                   #
# Il faut ensuite charger les var.globales dans [F] en INICRE           #
#-----------------------------------------------------------------------#
#  PARTNER   = 1 (client) / 2 (fournisseur)                             #
#  STRUCTURE = Code structure de PRICSTRUCT                             #
#########################################################################
Funprog TYPREM (PARTNER,STRUCTURE, MYDOC, MYFMTCOLREM, VMESSA)
Value    Integer  PARTNER
Value    Char     STRUCTURE
Value    Instance MYDOC       Using OBJECT
Variable Instance MYFMTCOLREM Using C_FMTCOLREM
Variable Char     VMESSA

Local Integer WRET

  If MYDOC = null :
    VMESSA = "MYDOC"-mess(18,9137,1)
    End [V]CST_AERROR
  Endif

  If MYFMTCOLREM=null
     VMESSA = "MYFMTCOLREM :"-mess(18,9137,1)
     WRET = fmet MYDOC.ASETERROR("",VMESSA,[V]CST_AERROR)
     End WRET
  Endif

  Local File ACTIV      [ACV]
  #----- Récupération valeur du code activité pour nbre de colonnes tarif -----#
  Local Integer NBMAX

  If PARTNER=1
    #NBMAX=func AFNC.ACTIV("SPR")
    Read [ACV]CODACT="SPR"
    If fstat or [F:ACV]FLACT<>[V]CST_AYES : Raz [F:ACV] : Endif
    NBMAX=[F:ACV]DIME
  Elsif PARTNER=2
    #NBMAX=func AFNC.ACTIV("PPR")
    Read [ACV]CODACT="PPR"
    If fstat or [F:ACV]FLACT<>[V]CST_AYES : Raz [F:ACV] : Endif
    NBMAX=[F:ACV]DIME
  Else
    NBMAX = 0
  Endif
  #-----

  For I=1 To NBMAX
    If MYFMTCOLREM.C_FMTCOL(I)=null
      WLINE = fmet MYFMTCOLREM.ADDLINE("C_FMTCOL",I)
      If WLINE = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        VMESSA = func ASYRFNC.MES2(mess(266,133,1),'C_FMTCOL','FMTCOLREM')
        WERR = fmet MYFMTCOLREM.ASETERROR ("", VMESSA, [V]CST_AERROR)
        End WERR
      Endif
    Else
      MYFMTCOLREM.C_FMTCOL(I).GINCDCR    = 0  #AVOID.AINT
      MYFMTCOLREM.C_FMTCOL(I).GDISCRGTYP = 0  #AVOID.AINT
      MYFMTCOLREM.C_FMTCOL(I).GINVDTALIN = 0  #AVOID.AINT
      MYFMTCOLREM.C_FMTCOL(I).GNPRVLTFLG = 0  #AVOID.AINT
      MYFMTCOLREM.C_FMTCOL(I).GNPRNOTFLG = 0  #AVOID.AINT
      MYFMTCOLREM.C_FMTCOL(I).GCLCRUL    = 0  #AVOID.AINT
    Endif
  Next I
  #
  Local File PRICSTRUCT [PRS]

  If PARTNER<>1 & PARTNER<>2 : End : Endif

  Read [PRS]PRS0=PARTNER;STRUCTURE
  If fstat
    Raz [F:PRS]
    VMESSA = mess(23,100,1)-num$(PARTNER)+";"+STRUCTURE
    WRET = fmet MYDOC.ASETERROR("",VMESSA,[V]CST_AWARNING)
    End WRET
  Endif

  For I=1 To dim([F:PRS]INCDCR)
     If dim([F:PRS]INCDCR(I-1))<1 : Break : Endif
     If MYFMTCOLREM.C_FMTCOL(I)<>null
       MYFMTCOLREM.C_FMTCOL(I).GINCDCR    = [F:PRS]INCDCR(I-1)
       MYFMTCOLREM.C_FMTCOL(I).GDISCRGTYP = [F:PRS]VALTYP(I-1)
       MYFMTCOLREM.C_FMTCOL(I).GINVDTALIN = [F:PRS]INVDTA(I-1)
      #MYFMTCOLREM.C_FMTCOL(I).GNPRVLTFLG = [F:PRS]NPRVLTFLG(I-1) => n'était pas utilisé dans le TRTPRICE vintage ?!
       MYFMTCOLREM.C_FMTCOL(I).GNPRNOTFLG = [F:PRS]NPRNOTFLG(I-1)
       MYFMTCOLREM.C_FMTCOL(I).GCLCRUL    = [F:PRS]CLCRUL(I-1)
     Endif
  Next I

End WRET
#--------------------------------------------------------------------------------------------------
#########################################################################
# Subprog FMTREM (WABMSK,CUR)                                           #
# garni le format de saisie pour les colonnes rem/frais des tarifs      #
# garni le code format "%" ou "M" dans GFMTREM (0..8)                   #
#-----------------------------------------------------------------------#
# DEFINIR dans masque en invisible FMTREM (0..8)                        #
# Dans bloc tableau /option/format/format adonix [M:xxx]FMTREM(nolign-1)#
# IMPERATIF : Appeler COLREM auparavant                                 #
#-----------------------------------------------------------------------#
#  WABMSK    = Abréviation du masque                                    #
#  CUR       = Devise                                                   #
#########################################################################
Subprog FMTREM(WABMSK,CUR)
Value Char      WABMSK
Value Char      CUR
#-----
#Local Integer I
#Call LECDEV (CUR) From TRTDIV
#For I=0 To 8
#  If GCOLREM(I)=""
#    GFORREM(I)="-Nz:0#[       ]"
#  Else
#    If GFMTCOL(I)=""
#      If GFMTREM(I)="M"
#        If [F:TCU]CURFMT2="8"
#          GFORREM(I)="NZ:"+[F:TCU]CURFMT2+"[ ]"
#        Else
#          GFORREM(I)="NZ:"+[F:TCU]CURFMT2
#        Endif
#      Else
#        GFORREM(I)="NZ:3.2#[   ]"
#      Endif
#    Else
#      If instr(1,GFMTCOL(I),"[F:TCU]")
#        GFORREM(I)="N:"+evalue(GFMTCOL(I))
#      Else
#        GFORREM(I)="N:"+GFMTCOL(I)
#      Endif
#    Endif
#  Endif
#  Assign "[M:"+WABMSK+"]FMTREM(I)" With GFORREM(I)
#Next I
#----------------------------------------------------------------------#
# Point d'entrée MAJFORMAT pour modifier les formats des frais/remises #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
# WABMSK     : Abréviation du masque                                   #
# CUR        : Devise                                                  #
# I          : Indice pour traitement en boucle des formats (0 à 8)    #
# GFMTREM(I) : Types de format ("M"=Montant, "%"=Taux)                 #
# GCOLREM(I) : Intitulés de colonne (si ="" colonne inactive)          #
# -------------------------------------------------------------------- #
# Variables modifiables par le point d'entrée                          #
