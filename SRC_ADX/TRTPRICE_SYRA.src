#########################################################################
# Subprog TARIFCHGT (module)                                            #
# garni les variables globales nécessaire à la recherche tarif          #
#-----------------------------------------------------------------------#
# APPELE  dans action OUVRE avant affichage du masque                   #
#-----------------------------------------------------------------------#
#  module    = 5 (ventes) / 6 (achats)                                  #
#########################################################################
Funprog TARIFCHGT (MODULE, MYDOC, MYPLI, WPLISTC, VMESSA)
Value Integer     MODULE
Value    Instance MYDOC   Using OBJECT
Variable Instance MYPLI   Using C_PLI
Variable Char     WPLISTC
Variable Char     VMESSA

Local Integer WRET : WRET = [V]CST_AOK
Raz VMESSA

  If MYDOC = null :
    VMESSA = "MYDOC"-mess(18,9137,1)
    End [V]CST_AERROR
  Endif

  If MYPLI = null
     VMESSA = "MYPLI :"-mess(18,9137,1)
     WRET = fmet MYDOC.ASETERROR("",VMESSA,[V]CST_AERROR)
     End WRET
#    MYPLI = NewInstance C_PLI :#--CPO If new instance => to what allocgroup must we attach it ? (For when we free it)
  Endif

  Local Integer   I , J, ERR

  If    MODULE = 5  : Gosub CHGTVEN
  Elsif MODULE = 6  : Gosub CHGTACH
  Endif

End WRET
#--------------------------------------------------------------------------------------------------
$CHGTVEN
  Local File SPRICCONF[SPC]
  Local Integer WLINE

  If dim(MYDOC.CPY)>0
    Filter [SPC] Where PLISTC=WPLISTC & find(PLICPY,"",MYDOC.CPY)
  Else
    Filter [SPC] Where PLISTC=WPLISTC & PLICPY=""
  Endif

  MYPLI.GPLINBR = 0  #AVOID.AINT

  For I=1 To maxtab(MYPLI.C_PLI)
    If MYPLI.C_PLI(I)=null
      WLINE = fmet MYPLI.ADDLINE("C_PLI",I)
      If WLINE = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        VMESSA  =  func ASYRFNC.MES2(mess(266,133,1),'C_PLI','PLI')
        [L]WRET = fmet this.ASETERROR ("",VMESSA, [V]CST_AERROR)
        Return
      Endif
    Else
      MYPLI.C_PLI(I).GPLI    = "" #AVOID.ACHAR
      MYPLI.C_PLI(I).GPLICRD = "" #AVOID.ACHAR
      MYPLI.C_PLI(I).GPLILIN = 0  #AVOID.AINT
      MYPLI.C_PLI(I).GPLISEA = 0  #AVOID.AINT
      MYPLI.C_PLI(I).GPLITYP = 0  #AVOID.AINT
      MYPLI.C_PLI(I).GPIO    = 0  #AVOID.AINT
    Endif
  Next I

  MYPLI.GDISCRG = dim([F:SPC]DISCRGPRO)
  #---- lecture du param. tarif / stockage en table des tarifs actifs
  I = 1 : ERR = [V]CST_AOK
  For   [SPC]SPC1 Where PLIENAFLG = [V]CST_AYES #2
  #--CPO Encore besoin de tester l'ouverture afin de remplir les tarifs ???
  #      For   J = 0 To 4
  #            If    [F:SPC]ABB(J) <> "" & evalue("clalev([F:"+[F:SPC]ABB(J)+"])") = 0
  #                  ERR=1 : Break : Endif
  #      Next  J
  #      If    ERR = 0
          If MYPLI.C_PLI(I) = null
            WLINE = fmet MYPLI.ADDLINE("C_PLI",I)
            If WLINE = [V]CST_ANOTDEFINED
              #--The insertion was not possible
              VMESSA =  func ASYRFNC.MES2(mess(266,133,1),'C_PLI','PLI')
              [L]WRET = fmet MYPLI.ASETERROR ("",VMESSA, [V]CST_AERROR)
              Break
            Endif
          Endif
          MYPLI.C_PLI(I).GPLITYP = [F:SPC]PLITYP
          MYPLI.C_PLI(I).GPIO    = [F:SPC]PIO
          MYPLI.C_PLI(I).GPLI    = [F:SPC]PLI
          If dim([F:SPC]PLISEA)>0 : MYPLI.C_PLI(I).GPLISEA=[F:SPC]PLISEA : Endif
          I += 1
          #If I=dim(GPLI) : Break : Endif
  #      Endif
  #      ERR = 0
  Next

  MYPLI.GPLINBR = maxtab(MYPLI.C_PLI)

  Filter [SPC]

Return
#--------------------------------------------------------------------------------------------------
$CHGTACH
  #If    clalev([F:PPC])=0 : Local File PPRICCONF[PPC] : Endif
  #Filter [PPC] Where PLISTC=GPLISTC
  #
  #Raz GPLITYP                            : # type de tarif
  #Raz GPLISEA                            : # code boucle de recherche
  #Raz GPIO                               : # priorite tarif
  #Raz GPLI                               : # code tarif
  #Raz GPLINBR                            : # nombre de tarifs actif ( max=dim(GPLI) )
  #GDISCRG = dim([F:PPC]DISCRGPRO)
  #
  ##---- lecture du param. tarif / stockage en table des tarifs actifs
  #I = 0 : ERR = 0
  #For   [PPC]PPC1 Where PLIENAFLG = 2
  #      For J = 0 To 4
  #          If [F:PPC]ABB(J) <> "" & evalue("clalev([F:"+[F:PPC]ABB(J)+"])") = 0
  #             If !(GMODU(5)=2 & find([F:PPC]ABB(J),"BPC","BPD","ITS","MVC"))
  #                ERR=1 : Break
  #             Endif
  #          Endif
  #      Next  J
  #      If    ERR = 0
  #            GPLITYP(I) = [F:PPC]PLITYP
  #            GPIO(I)    = [F:PPC]PIO
  #            GPLI(I)    = [F:PPC]PLI
  #            If dim([F:PPC]PLISEA)>0 : GPLISEA(I)=[F:PPC]PLISEA : Endif
  #            I += 1
  #            If I=dim(GPLI) : Break : Endif
  #      Endif
  #      ERR = 0
  #Next
  #GPLINBR = I
  #Filter [PPC]

  Local File PPRICCONF[PPC]
  Local Integer WLINE

  Filter [PPC] Where PLISTC=WPLISTC # & PLICPY="" no PLICPY on PPC table



  #If dim(MYDOC.CPY)>0
  #  Filter [PPC] Where PLISTC=WPLISTC & find(PLICPY,"",MYDOC.CPY)
  #Else
  #  Filter [PPC] Where PLISTC=WPLISTC & PLICPY=""
  #Endif



  #Raz MYPLI.GPLINBR
  MYPLI.GPLINBR = 0  #AVOID.AINT

  For I=1 To maxtab(MYPLI.C_PLI)
    If MYPLI.C_PLI(I)=null
      WLINE = fmet MYPLI.ADDLINE("C_PLI",I)  # 99354 WLINE)
      If WLINE = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        VMESSA = func ASYRFNC.MES2(mess(266,133,1),'C_PLI','PLI')
        [L]WRET = fmet this.ASETERROR ("",VMESSA, [V]CST_AERROR)
        Return
      Endif
    Else
  #    Raz MYPLI.C_PLI(I).GPLI
  #    Raz MYPLI.C_PLI(I).GPLICRD
  #    Raz MYPLI.C_PLI(I).GPLILIN
  #    Raz MYPLI.C_PLI(I).GPLISEA
  #    Raz MYPLI.C_PLI(I).GPLITYP
  #    Raz MYPLI.C_PLI(I).GPIO

      MYPLI.C_PLI(I).GPLI    = "" #AVOID.ACHAR
      MYPLI.C_PLI(I).GPLICRD = "" #AVOID.ACHAR
      MYPLI.C_PLI(I).GPLILIN = 0  #AVOID.AINT
      MYPLI.C_PLI(I).GPLISEA = 0 # "" # AVOID.ACHAR
      MYPLI.C_PLI(I).GPLITYP = 0  #AVOID.AINT
      MYPLI.C_PLI(I).GPIO    = 0  #AVOID.AINT
    Endif
  Next I

  MYPLI.GDISCRG = dim([F:PPC]DISCRGPRO)
  #---- lecture du param. tarif / stockage en table des tarifs actifs
  #I = 0 : ERR = 0
  I = 1 : ERR = 0
  For   [PPC]PPC1 Where PLIENAFLG = [V]CST_AYES # 2
  #--CPO Still need to test the opening to fill rates  ?????
  #For J = 0 To 4
  #  If [F:PPC]ABB(J) <> "" & evalue("clalev([F:"+[F:PPC]ABB(J)+"])") = 0
  #    If !(GMODU(5)=2 & find([F:PPC]ABB(J),"BPC","BPD","ITS","MVC"))
  #      ERR=1 : Break
  #      Endif
  #  Endif
  #Next  J
  #      If    ERR = 0
          If MYPLI.C_PLI(I) = null
            WLINE = fmet MYPLI.ADDLINE("C_PLI",I)
            If WLINE = [V]CST_ANOTDEFINED
              #--The insertion was not possible
              VMESSA =  func ASYRFNC.MES2(mess(266,133,1),'C_PLI','PLI')
              [L]WRET = fmet MYPLI.ASETERROR ("",VMESSA, [V]CST_AERROR)
              Break
            Endif
          Endif
          MYPLI.C_PLI(I).GPLITYP = [F:PPC]PLITYP
          MYPLI.C_PLI(I).GPIO    = [F:PPC]PIO
          MYPLI.C_PLI(I).GPLI    = [F:PPC]PLI
          If dim([F:PPC]PLISEA)>0 : MYPLI.C_PLI(I).GPLISEA=[F:PPC]PLISEA : Endif
          I += 1
          #If I=dim(GPLI) : Break : Endif
  #      Endif
  #      ERR = 0
  Next

  MYPLI.GPLINBR = maxtab(MYPLI.C_PLI)

  Filter [PPC]

Return
#--------------------------------------------------------------------------------------------------
#------------------------------------------------------------------#
# Alimentation du format de saisie des colonnes                    #
#              dans GFORREM (0..8) à partir de GFMTCOL (0..8)      #
#------------------------------------------------------------------#
# IMPERATIF : Appeler COLREM auparavant                            #
#------------------------------------------------------------------#
# Entrée   WNUMREM   : N° de remise (1..)                          #
#                      Si 1, alimente le format de ttes les remises#
#                      Si <> 1, alimente le format de la remise    #
#          WDEVISE   : Devise                                      #
#------------------------------------------------------------------#
# ACTION associée ALIFORREM                                        #
#------------------------------------------------------------------#
Funprog ALIFORREM(MYDOC, WNUMREM, WDEVISE, MYFMTCOLREM, VMESSA)
Value    Instance MYDOC   Using OBJECT
Value    Integer  WNUMREM
Value    Char     WDEVISE
Variable Instance MYFMTCOLREM Using C_FMTCOLREM
Variable Char     VMESSA

#Variable Instance MYPLI       Using C_PLI
Local Integer WRET : WRET = [V]CST_AOK
Raz VMESSA

  If MYDOC = null :
    VMESSA = "MYDOC"-mess(18,9137,1)
    End [V]CST_AERROR
  Endif

  If MYFMTCOLREM = null
     VMESSA = "MYFMTCOLREM :"-mess(18,9137,1)
     WRET = fmet MYDOC.ASETERROR("",VMESSA,[V]CST_AERROR)
     End WRET
#    MYPLI = NewInstance C_PLI :#--CPO If new instance => to what allocgroup must we attach it ? (For when we free it)
  Endif

  Local Integer NBMAX

  Local File TABCUR [F:TCU]

  NBMAX = maxtab(MYFMTCOLREM.C_FMTCOL)
  If WNUMREM<1 | WNUMREM>NBMAX : End [V]CST_AOK : Endif

  If dim(MYDOC.CPY)>0 and WDEVISE=""
    WDEVISE = func SREPLACEGLOB_SYRA.GET_GLOCALDEV("", MYDOC.CPY)#(AVOID.ACHAR, MYDOC.CPY)
  Endif

  Read [TCU]TCU0 = WDEVISE
  If fstat : Raz [F:TCU]
    VMESSA = mess(23,100,1)-":"-WDEVISE
    WRET = fmet MYDOC.ASETERROR("",VMESSA,[V]CST_AWARNING)
    End WRET
  Endif

  For I=WNUMREM To NBMAX
    If MYFMTCOLREM.C_FMTCOL(I)<>null
      If MYFMTCOLREM.C_FMTCOL(I).GCOLREM=""
        MYFMTCOLREM.C_FMTCOL(I).GFORREM="-Nz:0#[       ]"
      Else

        If MYFMTCOLREM.C_FMTCOL(I).GFMTCOL=""
          If MYFMTCOLREM.C_FMTCOL(I).GFMTREM="M"
            If [F:TCU]CURFMT2="8"
              MYFMTCOLREM.C_FMTCOL(I).GFORREM="NZ:"+[F:TCU]CURFMT2+"[ ]"
            Else
              MYFMTCOLREM.C_FMTCOL(I).GFORREM="NZ:"+[F:TCU]CURFMT2
            Endif
          Else
            MYFMTCOLREM.C_FMTCOL(I).GFORREM="NZ:3.2#[   ]"
          Endif
        Else

          If instr(1, MYFMTCOLREM.C_FMTCOL(I).GFMTCOL, "[F:TCU]")
              MYFMTCOLREM.C_FMTCOL(I).GFORREM="N:"+evalue(MYFMTCOLREM.C_FMTCOL(I).GFMTCOL)
          Else
              MYFMTCOLREM.C_FMTCOL(I).GFORREM="N:"+MYFMTCOLREM.C_FMTCOL(I).GFMTCOL
          Endif
        Endif

      Endif
      If WNUMREM<>1 Break Endif
    Endif
  Next I

  #-----
  #If !GIMPORT & WSTRNUM<>"" Gosub FMTCOL_SLT From TRTPRICE : Endif
End WRET
#--------------------------------------------------------------------------------------------------




