#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:28"
A_USER  = "DOC"
A_STAMP = "20181109230628"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBPFI"
  If [M]NBPFI=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SIPAR6 [SIP6]
Gosub HORODAT
Local Inpbox "SIPAR6" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIP6] As [SIM_]
Grizo [SIP6]5
Grizo [SIP6]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SIP6]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=15
X1(1)=1 : X2(1)=112 : Y1(1)=16 : Y2(1)=17
Return

$ON_NBPFI
Onevent BEFORE_AREA Call AV_NBPFI From W1SIPAR6
Return

Subprog AV_NBPFI
Local Decimal BASPAG
[M]NBPFI = 8
Gosub _AFF
End

$ON_INVDTALIB
Onevent BEFORE_AREA Gosub AV_INVDTALIB From W1SIPAR6
Return

$AV_INVDTALIB
zc = SI_MES(97+nolign)
Gosub _AFF
Return

$ON_PFINUM
Onevent CONTROL Call C_PFINUM(zc) From W1SIPAR6
Onevent BEFORE_INPUT Call AS_PFINUM(zc) From W1SIPAR6
Onevent AFTER_CHANGE Gosub AMM_PFINUM From W1SIPAR6
Return

Subprog IB_PFINUM(VALEUR)
Variable Decimal VALEUR
## Action STD
Call IB_PFINUM From SUBSIP
Gosub _AFF
End

Subprog AS_PFINUM(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6015,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call IB_PFINUM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_PFINUM(zc) From W1SIPAR6
Onkey   2 Titled GBOUTS Call S_PFINUM(zc) From W1SIPAR6
Onkey 144 Titled GBOUTP Call P_PFINUM(zc) From W1SIPAR6
Gosub _AFF
End

Subprog C_PFINUM(VALEUR)
Variable Decimal VALEUR
## Action %CNTOBJ
Call CONTNUM("PFI","!ABC",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PFINUM" : GZNUM = 3660 : Endif
If !mkstat
 ## Action STD
 Call C_PFINUM(VALEUR) From SUBSIP
 If mkstat : GERR = 1 : GZONE = "PFINUM" : GZNUM = 3660 : Endif
Endif
Gosub _AFF
End

$AMM_PFINUM
Call AM_PFINUM(zc)
If !mkstat & GOBJET
 zoncou = "PFINUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PFINUM(VALEUR)
Variable Decimal VALEUR
If !mkstat & evalue("dim("+clanam([M])+"ZPFINUM)")>indice
 [M]PFINUM(indice) = VALEUR
 Affzo ZPFINUM(indice)
Endif
Gosub _AFF
End

Subprog S_PFINUM(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action SELPFI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPFI"
 PARMSK(1) = [M]PFIFILTRE
 PARMSK(2) = "AB"
 Call S_TAB_NUM(VALEUR,PARMSK,"SELPFI","TRTACHSEL1","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PFINUM(VALEUR)
Variable Decimal VALEUR
Local Char VALCHAR(20)
VALCHAR = num$(VALEUR)
Call OBJET("PFI",VALCHAR,"") From GOBJET
VALEUR = val(VALCHAR)
Gosub _AFF
End

Subprog P_PFINUM(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PFI",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPFINUM
Onevent BEFORE_AREA Gosub AV_ZPFINUM From W1SIPAR6
Return

$AV_ZPFINUM
Call LECTEXTRA(zc,"PFOOTINV","DESAXX",num$([M]PFINUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_PFINUM1
Onevent CONTROL Call C_PFINUM1(zc) From W1SIPAR6
Onevent BEFORE_INPUT Call AS_PFINUM1(zc) From W1SIPAR6
Onevent AFTER_CHANGE Gosub AMM_PFINUM1 From W1SIPAR6
