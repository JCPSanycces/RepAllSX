 Call C_PFINUM1(VALEUR) From SUBSIP
 If mkstat : GERR = 1 : GZONE = "PFINUM1" : GZNUM = 23268 : Endif
Endif
Gosub _AFF
End

$AMM_PFINUM1
Call AM_PFINUM1(zc)
If !mkstat & GOBJET
 zoncou = "PFINUM1" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

