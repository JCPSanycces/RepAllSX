#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
$INITFORMULE
  [M:SPT1]SPTFILTAB = 'pat(ABRFIC,"LDS")<>0 or pat(ABRFIC,"AIN")<>0'
Return

##########################################################################################################
$LOAD_SPS
Local Integer ILIGNE
Local Date DTDATE

  ILIGNE = 0
  Raz DTDATE
  Filter [SPS] Where SPSNUM=[M:SPT0]SPTNUM 
  [M:SPT1]NBCRI = 0
  For [SPS]
    [M:SPT1]SPSLIN(ILIGNE) = [F:SPS]SPSLIN 
    [M:SPT1]SPSOPD(ILIGNE) = [F:SPS]SPSOPD
    [M:SPT1]NBPARDEB(ILIGNE) = [F:SPS]NBPARDEB
    If [F:SPS]NBPARDEB <> 0 Then
      [M:SPT1]PARDEB(ILIGNE) = string$ ([F:SPS]NBPARDEB,"(")
    Else
      [M:SPT1]PARDEB(ILIGNE) = ""
    Endif
    [M:SPT1]SPSABRFIC(ILIGNE) = [F:SPS]SPSABRFIC
    [M:SPT1]SPSTAB(ILIGNE) = [F:SPS]SPSTAB
    [M:SPT1]SPSFIE(ILIGNE) = [F:SPS]SPSFIE
    [M:SPT1]SPSFIETYP(ILIGNE) = [F:SPS]SPSFIETYP
    [M:SPT1]SPSINDOK(ILIGNE) = [F:SPS]SPSINDOK
    [M:SPT1]SPSINDNUM(ILIGNE) = [F:SPS]SPSINDNUM
    [M:SPT1]SPSCND(ILIGNE) = [F:SPS]SPSCND
    [M:SPT1]VALBASE(ILIGNE) = [F:SPS]SPSVAL
    [M:SPT1]VALECR(ILIGNE) = [F:SPS]SPSVAL   # FGR 21/10/2009 : X3SUIVI58010
    Read [ATZ]CODZONE=[M:SPT1]SPSTAB(ILIGNE);[M:SPT1]SPSFIE(ILIGNE)
    If fstat = 0 Then
      [M:SPT1]VALCODTYP(ILIGNE) = [F:ATZ]CODTYP
      [M:SPT1]VALLONG(ILIGNE) = [F:ATZ]LONG
      [M:SPT1]VALNOLIB(ILIGNE) = [F:ATZ]NOLIB
      [M:SPT1]VALTCT(ILIGNE) = ""
      [M:SPT1]VALSUPP(ILIGNE) = ""
      [M:SPT1]VALOPTION(ILIGNE) = ""
    Endif
    If [M:SPT1]VALBASE(ILIGNE) <> "" Then
      # FGR 21/10/2009 : X3SUIVI58010
      #Dbgaff
      Call CHARGE([M:SPT1]VALECR(ILIGNE),[M:SPT1]VALCODTYP(ILIGNE),[M:SPT1]VALNOLIB(ILIGNE),0,[M:SPT1]VALBASE(ILIGNE)) From ASELOBJ
      #Case [M:SPT1]SPSFIETYP(ILIGNE)
      #  When 2
      #    [M:SPT1]VALECR(ILIGNE) = num$(evalue([M:SPT1]VALBASE(ILIGNE)))
      #  When 3 
      #    Call CONVID([M:SPT1]VALBASE(ILIGNE),DTDATE) From CRMUTIL150
      #    [M:SPT1]VALECR(ILIGNE) = format$(GFMDAT4, DTDATE)
      #  When Default    
      #    [M:SPT1]VALECR(ILIGNE) = [M:SPT1]VALBASE(ILIGNE)
      #Endcase
    Endif
    [M:SPT1]NBPARFIN(ILIGNE) = [F:SPS]NBPARFIN
    If [F:SPS]NBPARFIN <> 0 Then
      [M:SPT1]PARFIN(ILIGNE) = string$ ([F:SPS]NBPARFIN,")")
    Else
      [M:SPT1]PARFIN(ILIGNE) = ""
    Endif
    ILIGNE += 1
  Next
  Filter [SPS]
  [M:SPT1]NBCRI = ILIGNE
Return

##########################################################################################################
$VERIF_SPS
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Integer INBPARENTHESE
Local Char SZRESULT
Local Integer INBLIGNE
Local Integer ILIGNE
Local Integer INOLIGNSAVE
Local Integer IBERROR
Local Integer INBPARDEB
Local Integer INBPARFIN

  Raz SZMESSAGE
  IBRETOUR = 1
  INBPARENTHESE = 0
  Raz SZRESULT
  INBLIGNE = 0
  ILIGNE = 0
  INOLIGNSAVE = nolign
  IBERROR = 0
  INBPARDEB = 0
  INBPARFIN = 0
  If [M:SPT0]SPTCRI = 1 or [M:SPT0]SPTCRI = 3 Then
    While ILIGNE < [M:SPT1]NBCRI
      INBLIGNE = INBLIGNE + 1
      [M:SPT1]SPSLIN(ILIGNE) = ILIGNE
      If ILIGNE = 0 Then
        [M:SPT1]SPSOPD(ILIGNE) = 1
      Endif
      If ILIGNE <> 0 Then
        If [M:SPT1]SPSOPD(ILIGNE) <> 2 and [M:SPT1]SPSOPD(ILIGNE) <> 3 Then
          IBERROR = 1
          #L'opérateur est obligatoire.
          GMESSAGE = mess(530,177,1)
          Break
        Endif
      Endif
      Call GETNBPARENTHESE([M:SPT1]PARDEB(ILIGNE), 0,INBPARENTHESE,SZRESULT, SZMESSAGE, IBRETOUR) From CRMUTIL150
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        IBERROR = 1
        Break
      Endif
      [M:SPT1]PARDEB(ILIGNE) = SZRESULT
      [M:SPT1]NBPARDEB(ILIGNE) = INBPARENTHESE
      INBPARDEB = INBPARDEB + [M:SPT1]NBPARDEB(ILIGNE)           
      If [M:SPT1]SPSTAB(ILIGNE) = "" Then
        IBERROR = 1
        #La table est obligatoire.
        GMESSAGE = mess(531,177,1)
        Break
      Endif
      If [M:SPT1]SPSTAB(ILIGNE) <> "" Then
        Read [ATB]CODFIC=[M:SPT1]SPSTAB(ILIGNE)
        If fstat = 0 Then
          [M:SPT1]SPSABRFIC(ILIGNE)=[F:ATB]ABRFIC
        Else
          IBERROR = 1
          #Erreur lecture table des tables
          GMESSAGE = mess(558,177,1)
          Break
        Endif
      Endif
      If [M:SPT1]SPSFIE(ILIGNE) = "" Then
        IBERROR = 1
        #Le champ est obligatoire.
        GMESSAGE = mess(532,177,1)
        Break
      Endif
      If [M:SPT1]SPSFIE(ILIGNE) <> "" and [M:SPT1]SPSTAB(ILIGNE) <> "" Then
        Read [ATZ]CODZONE=[M:SPT1]SPSTAB(ILIGNE);[M:SPT1]SPSFIE(ILIGNE)
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur le champs ne correspond pas à la table
          GMESSAGE = mess(567,177,1)
          Break
        Endif
      Endif
      If [M:SPT1]SPSCND(ILIGNE) = 0 Then
        IBERROR = 1
        #La condition est obligatoire.
        GMESSAGE = mess(533,177,1)
        Break
      Endif
      Call GETNBPARENTHESE([M:SPT1]PARFIN(ILIGNE), 1,INBPARENTHESE,SZRESULT, SZMESSAGE, IBRETOUR) From CRMUTIL150
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        IBERROR = 1
        Break
      Endif
      [M:SPT1]PARFIN(ILIGNE) = SZRESULT
      [M:SPT1]NBPARFIN(ILIGNE) = INBPARENTHESE
      INBPARFIN = INBPARFIN + [M:SPT1]NBPARFIN(ILIGNE)
      If INBPARFIN > INBPARDEB Then
        #Erreur dans la répartition des parenthèses ouvrantes et fermantes.
        GMESSAGE = mess(543,177,1)
        IBERROR = 1
        Break
      Endif
      ILIGNE += 1
    Wend
    If IBERROR = 0 Then
      If INBPARDEB <> INBPARFIN Then
        #Il n'y a pas le même nombre de parenthèses ouvrantes et fermantes.
        GMESSAGE = mess(534,177,1)
        IBERROR = 1
      Endif
    Endif
  Endif
  If IBERROR = 0 Then
    If [M:SPT0]SPTCRI = 3 Then
      If [M:SPT1]SPTFOROPD = 0 or [M:SPT1]SPTFOROPD = 1 Then
        #Vous devez préciser un opérateur de liaison entre les critères et la formule.
        GMESSAGE = mess(560,177,1)
        IBERROR = 1
      Endif   
      If IBERROR = 0 Then
        If [M:SPT1]SPTFOR = "" Then
          #Vous ne pouvez pas lier les critères avec une formule vide.
          GMESSAGE = mess(562,177,1)
          IBERROR = 1
        Endif
      Endif
    Endif
  Endif
  If IBERROR = 1 Then
    GERR = 2
    OK = 0
    GOK = 0
  Endif
Return

##########################################################################################################
$SAVE_SPS
Local Integer ILIGNE
Local Integer INOLIGNSAVE
Local Integer IBERROR

  ILIGNE = 0
  INOLIGNSAVE = nolign
  IBERROR = 0
  Delete  [SPS] Where SPSNUM=[M:SPT0]SPTNUM 
  If fstat <> 0 Then
    #Erreur lors de la suppression des critères
    GMESSAGE = mess(538,177,1)
    GOK = 0
    Return
  Endif
  While ILIGNE < [M:SPT1]NBCRI
    [F:SPS]SPSNUM = [M:SPT0]SPTNUM 
    [F:SPS]SPSLIN = [M:SPT1]SPSLIN(ILIGNE)
    [F:SPS]SPSOPD = [M:SPT1]SPSOPD(ILIGNE)
    [F:SPS]NBPARDEB = [M:SPT1]NBPARDEB(ILIGNE)
    [F:SPS]SPSABRFIC = [M:SPT1]SPSABRFIC(ILIGNE)
    [F:SPS]SPSTAB = [M:SPT1]SPSTAB(ILIGNE)
    [F:SPS]SPSFIE = [M:SPT1]SPSFIE(ILIGNE)
    [F:SPS]SPSFIETYP = [M:SPT1]SPSFIETYP(ILIGNE)
    [F:SPS]SPSINDOK = [M:SPT1]SPSINDOK(ILIGNE)
    [F:SPS]SPSINDNUM = [M:SPT1]SPSINDNUM(ILIGNE)
    [F:SPS]SPSCND = [M:SPT1]SPSCND(ILIGNE)
    [F:SPS]SPSVAL = [M:SPT1]VALBASE(ILIGNE)
    [F:SPS]NBPARFIN = [M:SPT1]NBPARFIN(ILIGNE)
    [F:SPS]CREUSR = GUSER    
    [F:SPS]CREDAT = date$    
    Write [SPS]
    If fstat <> 0 Then
      #Erreur lors de l'écriture d'un critère. 
      GMESSAGE = mess(539,177,1)
      GOK = 0
      IBERROR = 1
      Break
    Endif
    ILIGNE += 1
  Wend
Return

##########################################################################################################
# Génération de la chaine de regroupement
$REGROUPEMENT
Local Integer ILIGNESAVE
Local Char SZREGROUPE (250)
Local Char SZREGROUPETRAD (250)
Local Integer ILIGNE
Local Char SZOPER
Local Char SZOPERTRAD
Local Char SZFORMULE
Local Char SZFORMULETRAD
Local Char SZNUMCRI
Local Integer INBLIGNEMAX

  ILIGNESAVE = nolign
  Raz SZREGROUPE
  Raz SZREGROUPETRAD
  Raz SZOPER
  Raz SZOPERTRAD
  Raz SZFORMULE
  Raz SZFORMULETRAD
  Raz SZNUMCRI
  ILIGNE = 0
  INBLIGNEMAX = max(ILIGNESAVE-1, [M:SPT1]NBCRI)
  While ILIGNE < dim([M:SPT1]SPSOPD(ILIGNE))
    If [M:SPT1]SPSOPD(ILIGNE) > 0 Then
      If [M:SPT1]SPSOPD(ILIGNE) = 1 Then
        SZOPER = ""
        SZOPERTRAD = ""
      Else
        SZOPERTRAD = " " + mess([M:SPT1]SPSOPD(ILIGNE),2955,1) + " "
        Case [M:SPT1]SPSOPD(ILIGNE)
          When 2
            SZOPER = " or "
          When 3
            SZOPER = " and "
        Endcase
      Endif
      SZNUMCRI = num$(ILIGNE+1)
      SZREGROUPE = SZREGROUPE + SZOPER + [M:SPT1]PARDEB(ILIGNE) + SZNUMCRI + [M:SPT1]PARFIN(ILIGNE)
      SZREGROUPETRAD = SZREGROUPETRAD + SZOPERTRAD + [M:SPT1]PARDEB(ILIGNE) + SZNUMCRI + [M:SPT1]PARFIN(ILIGNE)
    Endif
    ILIGNE = ILIGNE + 1
  Wend
  nolign = ILIGNESAVE
  SZFORMULE = "(FORMU)"
  SZFORMULETRAD = "(" + mess(561,177,1) + ")"
  If [M:SPT0]SPTCRI = 1 Then
    #Critère uniquement
    [M:SPT1]SPTRES = SZREGROUPE 
    [M:SPT1]SPTSYN = SZREGROUPETRAD
  Endif
  If [M:SPT0]SPTCRI = 2 Then
    #Formule
    If [M:SPT1]SPTFOR <> "" Then
      [M:SPT1]SPTRES = SZFORMULE
      [M:SPT1]SPTSYN = SZFORMULETRAD
    Else
      [M:SPT1]SPTRES = ""
      [M:SPT1]SPTSYN = ""
    Endif
  Endif
  If [M:SPT0]SPTCRI = 3 Then
    Case [M:SPT1]SPTFOROPD
      When 2
        SZOPER = " or "
      When 3
        SZOPER = " and "
      When Default 
        SZOPER = " "
    Endcase
    If [M:SPT1]SPTFOR <> "" Then
      [M:SPT1]SPTRES = SZREGROUPE + SZOPER + SZFORMULE
      [M:SPT1]SPTSYN = SZREGROUPETRAD - mess([M:SPT1]SPTFOROPD,2955,1) - SZFORMULETRAD
    Else
      [M:SPT1]SPTRES = SZREGROUPE
      [M:SPT1]SPTSYN = SZREGROUPETRAD
    Endif
  Endif
Return
