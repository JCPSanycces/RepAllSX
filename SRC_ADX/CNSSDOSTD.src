#<AdxTL>@(#)8.0.0.0 $Revision$ Consultation SMV
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSDO] : Transmask [M:SDO1] To [M:CSDO] # Issue 25606 [M:CSDO] = [M:SDO1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
Global Char    GALIGN0
#initialisation du format des filler pour rendre des zones invisible, qui permettent l'alignement des champs.
GALIGN0 = "-K:10X"

If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSDO"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SDO1]FLG = 0
[M:SDO1]    = [M:CSDO]
[M:SDO1]REFPER = addmonth(date$,([M:SDO1]MONNBR*-1))
Return
############################################################
$AP_MAGNETO
[M:SDO1]FLG = 0
Return
############################################################
$FERME
If dim(WGCONSULT) > 0
  GCONSULT = WGCONSULT
Endif
If dim (GALIGN0)>0       Kill GALIGN0   Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SDO1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSDO]) <> 0 & [M:CSDO]MEMO = "STD"
  [M:SDO1] = [M:CSDO]
  [M:SDO1]REFPER = addmonth(date$,([M:SDO1]MONNBR*-1))
Endif
Return
############################################################
$LECTURE
If [M:SDO1]FLG = 2
  [M:SDO1]FLG = 0
  NBLU = 0
  Return
Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SDO2]
    WLIG = 0
    For [LNK]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SDO1]FLG = 0
  [M:SDO1]FLG = 1
  Raz [M:SDO2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
     ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Link [ITF] With [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
&            As [LNK]
&            Where evalue(WFIL)  &
&                  evalue(WFILS) &
&                  evalue(WFILSPE)
&            Order By Key ITF1
Endif
Return
############################################################
$LOAD_FILTER
# Préparation filtre [ITF]
WFIL  = "[F:ITF]CREDAT<=[M:SDO1]REFPER&[F:ITV]LASRCPDAT<[M:SDO1]REFPER&[F:ITV]LASISSDAT<[M:SDO1]REFPER"
# Filtre site
If [M:SDO1]FCY <> ""
  WFIL += "&[F:ITF]STOFCY=[M:SDO1]FCY"
Endif
# MHB 04/08/08 : A voir si on filtre uniquement sur PHYSTO, ou sur le cumul des stocks internes
If [M:SDO1]STONUL = 1
  WFIL += "&([F:ITV]PHYSTO+[ITV]CTLSTO+[F:ITV]REJSTO>0)"
  # WFIL += "&([F:ITV]PHYSTO>0)"
Else
  WFIL += "&([F:ITV]PHYSTO+[ITV]CTLSTO+[F:ITV]REJSTO=0)"
  # WFIL += "&([F:ITV]PHYSTO=0)"
Endif
Return
############################################################
$LOA_LIGNE
Read [ITM]ITM0=[F:ITF]ITMREF
If fstat
  Raz [F:ITM]
Endif
[M:SDO2] = [F:ITM]
[M:SDO2] = [F:ITF]
[M:SDO2]PHYSTO(nolign-1)  = [F:ITV]PHYSTO    + [F:ITV]CTLSTO       + [F:ITV]REJSTO
[M:SDO2]PLFSTO(nolign-1)  = [F:ITV]PLFPHYSTO + [F:ITV]PLFCTLSTO    + [F:ITV]PLFREJSTO
[M:SDO2]BPRSTO(nolign-1)  = [F:ITV]BPRPHYSTO + [F:ITV]BPRCTLSTO    + [F:ITV]BPRREJSTO
[M:SDO2]SCOSTO(nolign-1)  = [F:ITV]SCOPHYSTO + [F:ITV]SCOCTLSTO    + [F:ITV]SCOREJSTO
[M:SDO2]ALLSTO(nolign-1)  = [F:ITV]PHYALL    + [F:ITV]CTLALL       + [F:ITV]REJALL    +
&                           [F:ITV]SCOPHYALL + [F:ITV]SCOCTLALL    + [F:ITV]SCOREJALL
[M:SDO2]GLOALL(nolign-1)  = [F:ITV]GLOALL
[M:SDO2]GLOSHT(nolign-1)  = [F:ITV]GLOSHT
[M:SDO2]DETSHT(nolign-1)  = [F:ITV]DETSHT
[M:SDO2]TRFSTO(nolign-1)  = [F:ITV]TRFSTO
[M:SDO2]TRASTO(nolign-1)  = [F:ITV]TRASTO
[M:SDO2]ORDSTO(nolign-1)  = [F:ITV]ORDSTO
[M:SDO2]SALSTO(nolign-1)  = [F:ITV]SALSTO
[M:SDO2]WAISTO(nolign-1)  = [F:ITV]WAISTO
[M:SDO2]LASRCPDAT(nolign-1)=[F:ITV]LASRCPDAT
[M:SDO2]LASISSDAT(nolign-1)=[F:ITV]LASISSDAT
[M:SDO2]LASCUNDAT(nolign-1)=[F:ITV]LASCUNDAT
[M:SDO2]SCCLNDSTO(nolign-1)=[F:ITV]SCCLNDSTO

Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SDO1]FLG = 0
End
############################################################
Subprog AM_REFPER(VALEUR)
Variable Date    VALEUR
[M:SDO1]FLG = 0
End
############################################################
Subprog D_REFPER(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
  VALEUR = date$-365
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSDO1) 05/08/2008 09:38:59 (MABON)
######################################################################################
Subprog AM_STONUL(VALEUR)
Variable Integer VALEUR
[M:SDO1]FLG = 0
End


######################################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SDO") From SUBGTC

End

