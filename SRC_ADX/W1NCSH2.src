#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:30"
A_USER  = "DOC"
A_STAMP = "20181109230530"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG2"
  If [M]NBLIG2=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSH2 [NCSH2]
Gosub HORODAT
Local Inpbox "NCSH2" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSH2] As [SIM_]
Grizo [NCSH2]5
Grizo [NCSH2]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSH2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=10
X1(1)=1 : X2(1)=74 : Y1(1)=11 : Y2(1)=25
Return

$ON_NCSROOCAU
Onevent INIT_AREA Call D_NCSROOCAU(zc) From W1NCSH2
Onevent CONTROL Call C_NCSROOCAU(zc) From W1NCSH2
Onevent BEFORE_INPUT Call AS_NCSROOCAU(zc) From W1NCSH2
Onevent AFTER_CHANGE Gosub AMM_NCSROOCAU From W1NCSH2
Return

Subprog D_NCSROOCAU(VALEUR)
Variable Char    VALEUR()
If varinit([M]NCSROOCAU,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"803","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_NCSROOCAU(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_NCSROOCAU(zc) From W1NCSH2
Onkey 144 Titled GBOUTP Call P_NCSROOCAU(zc) From W1NCSH2
Onkey 146 Titled GBOUTA Call SA_NCSROOCAU(zc) From W1NCSH2
If VALEUR="" : Call INIADI(VALEUR,"803") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_NCSROOCAU(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NCSROOCAU" : GZNUM = 54865 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"803","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "NCSROOCAU" : GZNUM = 54865 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"803",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "NCSROOCAU" : GZNUM = 54865 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_NCSROOCAU
Call AM_NCSROOCAU(zc)
If !mkstat & GOBJET
 zoncou = "NCSROOCAU" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NCSROOCAU(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZNCSROOCAU)")>indice
 [M]NCSROOCAU(indice) = VALEUR
 Affzo ZNCSROOCAU(indice)
Endif
Gosub _AFF
End

Subprog S_NCSROOCAU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "803"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_NCSROOCAU(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "803"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NCSROOCAU(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "803"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZNCSROOCAU
Onevent BEFORE_AREA Gosub AV_ZNCSROOCAU From W1NCSH2
Return

$AV_ZNCSROOCAU
Call LECTEXTRA(zc,"ATABDIV","LNGDES","803",num$([M]NCSROOCAU(indice))) From ATEXTRA
Gosub _AFF
Return

