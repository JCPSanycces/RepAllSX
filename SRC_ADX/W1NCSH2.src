$ON_SEVERITY
Onevent BEFORE_INPUT Call AS_SEVERITY(zc) From W1NCSH2
Onevent INIT_AREA Call D_SEVERITY(zc) From W1NCSH2
Onevent CONTROL Call C_SEVERITY(zc) From W1NCSH2
Return

Subprog D_SEVERITY(VALEUR)
Variable Integer VALEUR
If varinit([M]SEVERITY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SEVERITY(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2030) From COMBOS
## Action STD
Call AS_SEVERITY(VALEUR) From SUBNCSH
If mkstat=2
 [M]SEVERITY(INDIC) = VALEUR
 Affzo SEVERITY(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2030,1))))
Endif
If !mkstat
 Discombo 0 From SEVERITY(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From SEVERITY(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_SEVERITY(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SEVERITY" : GZNUM = 20701 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

