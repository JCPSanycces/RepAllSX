SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "AUS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NCSAPPUSR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("AUS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_TRANSTYPE
Onevent INIT_AREA Call D_TRANSTYPE(zc) From W1NCSH2
Onevent CONTROL Call C_TRANSTYPE(zc) From W1NCSH2
Onevent BEFORE_INPUT Call AS_TRANSTYPE(zc) From W1NCSH2
Onevent AFTER_CHANGE Gosub AMM_TRANSTYPE From W1NCSH2
Return

Subprog D_TRANSTYPE(VALEUR)
Variable Char    VALEUR()
If varinit([M]TRANSTYPE,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"807","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_TRANSTYPE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_TRANSTYPE(VALEUR) From SUBNCSH
If mkstat=2
 [M]TRANSTYPE(INDIC) = VALEUR
 Affzo TRANSTYPE(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_TRANSTYPE(zc) From W1NCSH2
Onkey 144 Titled GBOUTP Call P_TRANSTYPE(zc) From W1NCSH2
Onkey 146 Titled GBOUTA Call SA_TRANSTYPE(zc) From W1NCSH2
Gosub _AFF
End

Subprog C_TRANSTYPE(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"807","") From SUBADI
If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"807",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
 If !mkstat
  ## Action STD
  Call C_TRANSTYPE(VALEUR) From SUBNCSH
  If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TRANSTYPE
Call AM_TRANSTYPE(zc)
If !mkstat & GOBJET
 zoncou = "TRANSTYPE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TRANSTYPE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TRANSTYPE(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZTRANSTYPE)")>indice
 [M]TRANSTYPE(indice) = VALEUR
 Affzo ZTRANSTYPE(indice)
Endif
Gosub _AFF
End

Subprog S_TRANSTYPE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "807"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_TRANSTYPE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "807"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TRANSTYPE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "807"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTRANSTYPE
Onevent BEFORE_AREA Gosub AV_ZTRANSTYPE From W1NCSH2
Return

$AV_ZTRANSTYPE
Call LECTEXTRA(zc,"ATABDIV","LNGDES","807",num$([M]TRANSTYPE(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_APPRSTAT
Onevent BEFORE_INPUT Call AS_APPRSTAT(zc) From W1NCSH2
Onevent AFTER_CHANGE Gosub AMM_APPRSTAT From W1NCSH2
Onevent INIT_AREA Call D_APPRSTAT(zc) From W1NCSH2
Return

Subprog D_APPRSTAT(VALEUR)
Variable Integer VALEUR
If varinit([M]APPRSTAT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_APPRSTAT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_APPRSTAT(VALEUR) From SUBNCSH
If mkstat=2
 [M]APPRSTAT(INDIC) = VALEUR
 Affzo APPRSTAT(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_APPRSTAT
Call AM_APPRSTAT(zc)
If !mkstat & GOBJET
 zoncou = "APPRSTAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_APPRSTAT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_APPRSTAT(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "APPRSTAT" : GZNUM = 52454 : Endif
Gosub _AFF
End

$ON_APPRREASON
Onevent BEFORE_INPUT Call AS_APPRREASON(zc) From W1NCSH2
Onevent CONTROL Call C_APPRREASON(zc) From W1NCSH2
Onevent AFTER_CHANGE Gosub AMM_APPRREASON From W1NCSH2
Return

Subprog AS_APPRREASON(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_APPRREASON(VALEUR) From SUBNCSH
If mkstat=2
 [M]APPRREASON(INDIC) = VALEUR
 Affzo APPRREASON(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_APPRREASON(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_APPRREASON(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "APPRREASON" : GZNUM = 2675 : Endif
Gosub _AFF
End

$AMM_APPRREASON
Call AM_APPRREASON(zc)
If !mkstat & GOBJET
 zoncou = "APPRREASON" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_APPRREASON(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_APPRREASON(VALEUR) From SUBNCSH
If mkstat : GERR = 1 : GZONE = "APPRREASON" : GZNUM = 2675 : Endif
Gosub _AFF
End

$ON_NCSID
Return

$CHG_STY
Return


