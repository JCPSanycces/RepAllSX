###################################################################################################
# Class TECPSO_PSO
# Issue X3-8085/121537 - 2017-02-15 by FGR
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "PSO_ADD_LINE"                : Gosub PSO_ADD_LINE
    #
    When "_IS_LINE_EXIST"              : Gosub _IS_LINE_EXIST
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

###################################################################################################
# METHODS
###################################################################################################
$PSO_ADD_LINE
#Value Char SAOB ()
#Value Char SSXHNUM ()
#Value Char SPSONUM ()
#Value Integer ISEQNUM
#Local Integer ARET_VALUE

Local Integer ILINE

  # ------------------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If SPSONUM <> AVOID.ACHAR and ISEQNUM > 0 Then
    If this.AOB = AVOID.ACHAR or this.SXHNUM = AVOID.ACHAR Then
      this.AOB = SAOB
      this.SXHNUM = SSXHNUM
    Endif
    # ------------------------------------
    If fmet this._IS_LINE_EXIST(SPSONUM, ISEQNUM) = [V]CST_ANO Then
      ILINE = fmet this.ADDLINE("PSO", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        this.PSO(ILINE).PSONUM = SPSONUM
        this.PSO(ILINE).SEQNUM = ISEQNUM
      Endif
    Endif
  Endif
Return

###################################################################################################
$_IS_LINE_EXIST
#Value Char SPSONUM ()
#Value Shortint ISEQNUM
#Local Integer ARET_VALUE

Local Integer NI

  # ------------------------------------
  [L]ARET_VALUE = [V]CST_ANO
  # ------------------------------------
  For NI = 1 To maxtab(this.PSO)
    If this.PSO(NI) <> null and find(this.PSO(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.PSO(NI).PSONUM = SPSONUM and this.PSO(NI).SEQNUM = ISEQNUM Then
        [L]ARET_VALUE = [V]CST_AYES
        Break
      Endif
    Endif
  Next NI
Return

