############################################################################################################
$G_CONTROL_DATE

Local Tinyint FLG_AFTERNOON   #: # ENDDAY
Local Tinyint FLG_MORNING     #: # STRDAY
Local Char SOA_GMESSAGE(250)
FLG_AFTERNOON = this.ENDDAY
FLG_MORNING   = this.STRDAY

# Open DEMCONGE before routine and close after (make sure both are done)
# STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - add this.TCH_LEG to parameters
Local File DEMCONGE [DCG]
Call CONTROL_DATE(this.STRDAT,this.ENDDAT,this.TCH_STA0,this.STA,this.REFNUM,this.CTRNUM,this.UID,this.TCH_LEG,FLG_AFTERNOON,FLG_MORNING,SOA_GMESSAGE)
LogicClose File [DCG]

Return
#---------------------------
# Ancien contenu de C_ENDDAY
#Subprog CONTROL_DATE(FLG_AFTERNOON,FLG_MORNING,CDCG,SOA_GMESSAGE)
Subprog CONTROL_DATE(CDCG_STRDAT,CDCG_ENDDAT,CDCG_TCH_STA0,CDCG_STA,CDCG_REFNUM,CDCG_CTRNUM,CDCG_UID,CDCG_TCH_LEG,FLG_AFTERNOON,FLG_MORNING,SOA_GMESSAGE)
Value Date CDCG_STRDAT
Value Date CDCG_ENDDAT
Value Integer CDCG_TCH_STA0
Value Libelle CDCG_STA
Value Char CDCG_REFNUM
Value Char CDCG_CTRNUM
Value Integer CDCG_UID
Value Char CDCG_TCH_LEG          #  V12 enhancement
Variable Tinyint FLG_AFTERNOON   #: # ENDDAY
Variable Tinyint FLG_MORNING     #: # STRDAY
Variable Char SOA_GMESSAGE

Local Tinyint L_M, L_A, L_K

Local Integer  SOA_GPAYE      : Call GPAYE(SOA_GPAYE) From ESSGLOB_SOA       : # Présence du module paye
Local Integer  SOA_GWEBSERV   : Call GWEBSERV(SOA_GWEBSERV) From ESSGLOB_SOA : # Environnement WEB (Adapi)
Local Integer  SOA_GTPS       : Call GTPS(SOA_GTPS) From ESSGLOB_SOA         : # Présence du module temps
Local Char     SOA_GFMD(30)   : Call GFMD(SOA_GFMD) From ESSGLOB_SOA

#Used by the Web interface. Commented out at this point until required.
Local Char     SOA_ACTPOR(30) : Call ACTPOR(SOA_ACTPOR) From ESSGLOB_SOA

Local File VALEMP   [VEP]
Local File DEMCONGE [DCG]
## Si RTE saisi à une date future
Local File TIMCOD [TIM]
Local File TIMEMP [TIP]

#CDCG_TCH_STA0

[L]L_M=FLG_MORNING
[L]L_A=FLG_AFTERNOON
If [L]L_A=2 & [L]L_M=2 & CDCG_STRDAT=CDCG_ENDDAT : [L]L_M=1 : [L]L_A=1 : Endif : # 73242 ligne non modifiée

If CDCG_TCH_STA0<3 & CDCG_STA<4  #???? does STA0 exist? Web related? ZPORDCGSBA, ZPORDCGNEW, PORPPH, PORDCG_AVPJ, PORDCG
  # / 72113 pas de contrôle dans la paye si paye absente
  If SOA_GPAYE
    MAXL = 1   # we are maintaining each line separately   #maxtab(CDCG)
#    If MAXL > 1  # CDCG code does not apply to the representation - ???? make sure
#      For I = 1 To MAXL
#        If CDCG(I) <> null and find(CDCG(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
#          If CDCG_AORDER <> CDCG(I).AORDER
#&           & find(CDCG(I).STA,1,2,3,5,7)
#&           & (    CDCG(I).STRDAT < CDCG_ENDDAT
#&              |  (CDCG(I).STRDAT = CDCG_ENDDAT & (CDCG(I).ENDDAY<2 | [L]L_M<2)))
#&           & (    CDCG(I).ENDDAT > CDCG_STRDAT
#&              |  (CDCG(I).ENDDAT = CDCG_STRDAT & (CDCG(I).STRDAY<2 | [L]L_A<2 )))
#&           & uni(CDCG_CTRNUM, CDCG(I).CTRNUM,"")
#
#            # Chevauchement refusé si la demande concerne une paie non arrêtée dans les temps
#            Filter [VEP] Where EMP=[M:DCG1]REFNUM & (CTRNUM=CDCG_CTRNUM | CDCG_CTRNUM="")
#&                                                 & STRDAT<=CDCG_STRDAT & ENDDAT>=CDCG_ENDDAT
#            Read [VEP]VEP0 Last
#            Filter [VEP]
#            If fstat | ([F:VEP]PST<2 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
#            # Paie non générée ou Paie non comptabilisée avec arrêté des temps non fait
#              [V]GMESSAGE=func AFNC.MES1(mess(169,10709,1),num$(I+1)) : # Chevauchement avec la ligne $1$
#              #mkstat     =2  #????
#              Break
#            Endif
#          Endif
#        Endif
#      Next
      #If mkstat : End : Endif  #????
#    Endif

    # CONTROLE DES ABSENCES AUX MEMES DATES (Control of leave at the same dates)
    #Local File VALEMP   [VEP]
    #Local File DEMCONGE [DCG]

    For [DCG]DCG1 Where REFNUM=CDCG_REFNUM & UID>0 & STA<>4 & STA<>6
&                                      & STRDAT<=CDCG_ENDDAT
&                                      & ENDDAT>=CDCG_STRDAT
&                                      & UID <> CDCG_UID      # SOA-required when amending record so does not select itself
# check if the below is still needed
#&                                      & find(UID,CDCG_DELUID(1..CDCG_NBDEL))=0
#&                                      & find(UID,CDCG(1..maxtab(CDCG)).UID)=0   # sb find(UID,CDCG_UID)=0  ????

      #bug 74580
      # Chevauchement autorisé si pour la même date
      # ligne DCG a une 1/2 journée # de la 1/2 journée de la ligne en cours
      If uni(CDCG_CTRNUM,[F:DCG]CTRNUM,"")
&        & (    [F:DCG]STRDAT<CDCG_ENDDAT
&           |  ([F:DCG]STRDAT=CDCG_ENDDAT & ([F:DCG]ENDDAY<2 | [L]L_M<2)))
&        & (    [F:DCG]ENDDAT>CDCG_STRDAT
&           |  ([F:DCG]ENDDAT=CDCG_STRDAT & ([F:DCG]STRDAY<2 | [L]L_A<2)))
        # 59187 - Pas si fonction calcul du portail
        #    If !GWEBSERV | ACTPOR <> "CAL"
        # FQ82441 - 25/05/12 -   Test existance globale ACTPOR


        If !SOA_GWEBSERV #| (dim(ACTPOR) >= 0 & ACTPOR <> "CAL") #???? looks like global i.e. SOA_ACTPOR Discussed with DH - Only used for WEB interface
          # Chevauchement refusé si la demande concerne une paie non arrêtée dans les temps
          Filter [VEP] Where EMP=[F:DCG]REFNUM & (CTRNUM=[F:DCG]CTRNUM | [F:DCG]CTRNUM="")
&                            & STRDAT<=[F:DCG]STRDAT & ENDDAT>=[F:DCG]ENDDAT
          Read [VEP]VEP0 Last
          Filter [VEP]
          If fstat | ([F:VEP]PST<2 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)

          # Paie non générée ou Paie non comptabilisée avec arrêté des temps non fait
            SOA_GMESSAGE=mess(174,10709,1)-"("+num$([F:DCG]DEM)+")" : # Chevauchement avec d'autres demandes de congé
            #mkstat     =2  #????
            #ASTATUS=fmet CDCG_ASETERROR([L]CURPRO,SOA_GMESSAGE,[V]CST_AERROR)
            Break
          Endif
        Endif
      Endif
    Next
    #If mkstat : End : Endif
    If SOA_GMESSAGE <> AVOID.ACHAR
      End
    Endif

    ## Si RTE saisi à une date future
    #Local File TIMCOD [TIM]
    #Local File TIMEMP [TIP]
    For [TIP]TIP1 Where REFNUM=CDCG_REFNUM & STRDAT<=CDCG_ENDDAT
&                                          & ENDDAT>=CDCG_STRDAT
&                                          & DCGUID=0  #????
      If find(CDCG_CTRNUM,"",[F:TIP]CTRNUM)
&        & (    [F:TIP]STRDAT<CDCG_ENDDAT
&           |  ([F:TIP]STRDAT=CDCG_ENDDAT & ([F:TIP]STRDAY<2 | [L]L_M<2)))
&        & (    [F:TIP]ENDDAT>CDCG_STRDAT
&           |  ([F:TIP]ENDDAT=CDCG_STRDAT & ([F:TIP]ENDDAY<2 | [L]L_A<2)))
        #STCAH - 2017-08-08 - X3-50596 - START
        #Include code from SUBDCG added by JASMI
        #JASMI - 2017-07-13 - X3-48882 - START
        #Filter [VEP] Where EMP=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT<=[F:TIP]STRDAT & ENDDAT>=[F:TIP]ENDDAT
        If func AFNC.ACTIV("KGZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
          Filter [VEP] Where EMP=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & PYRDAT=[F:TIP]DATPYR
        Else
          Filter [VEP] Where EMP=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & STRDAT<=[F:TIP]STRDAT & ENDDAT>=[F:TIP]ENDDAT
        Endif
        #JASMI - 2017-07-13 - X3-48882 - END
        #STCAH - 2017-08-07 - X3-50596 - END
        Read [VEP]VEP0 Last
        Filter [VEP]
        If fstat | ([F:VEP]PST<2 & [F:VEP]FLGVRA<>2 & [F:VEP]FLGGEN<>2 & [F:VEP]FLGSYN<>2 & [F:VEP]FLGANA<>2)
          # Paie non générée ou Paie non comptabilisée avec arrêté des temps non fait
          #Read [TIM]TIM0=[F:TIP]TIM
          Read [TIM]TIM0=CDCG_TCH_LEG;[F:TIP]TIM  #STCAH - 2017-08-08 - X3-50596 - add legislation
          SOA_GMESSAGE =format$(SOA_GFMD,[F:TIP]STRDAT)
&                      - string$([F:TIP]STRDAT<>[F:TIP]ENDDAT,"->"-format$(SOA_GFMD,[F:TIP]ENDDAT))
&                      - ":"-func ASYRFNC.MES1(mess(192,10709,1),[F:TIM]COD)
          #            Evènement $1$ déjà saisi pour cette date
          #mkstat = 2  #????
          #ASTATUS=fmet CDCG_ASETERROR([L]CURPRO,SOA_GMESSAGE,[V]CST_AERROR)
          Break
        Endif
      Endif
    Next
    If SOA_GMESSAGE <> AVOID.ACHAR
      End
    Endif
  Endif # END If SOA_GPAYE

  # On interdit la saisie d'une demande sur une période qui a des régularisations
  If SOA_GTPS=1
    Local File TIMREGUL [TIG]
    For [TIG]TIG1 Where REFNUM=CDCG_REFNUM & STRDAT<=CDCG_ENDDAT
&                                          & ENDDAT>=CDCG_STRDAT
      If find(CDCG_CTRNUM,"",[F:TIG]CTRNUM)
&        & (   [F:TIG]STRDAT<CDCG_ENDDAT
&           | ([F:TIG]STRDAT=CDCG_ENDDAT & ([F:TIG]ENDDAY<2 | [L]L_M<2)))
&        & (   [F:TIG]ENDDAT>CDCG_STRDAT
&           | ([F:TIG]ENDDAT=CDCG_STRDAT & ([F:TIG]STRDAY<2 | [L]L_A<2)))
        #Read [TIM]TIM0=[F:TIG]TIM
        #FRLAA 2018-01-25 X3-71901 - START
        Read [TIM]TIM0=CDCG_TCH_LEG;[F:TIG]TIM
        If !fstat
          SOA_GMESSAGE =format$(SOA_GFMD,[F:TIG]STRDAT)
&                    - string$([F:TIG]STRDAT<>[F:TIG]ENDDAT,"->"-format$(SOA_GFMD,[F:TIG]ENDDAT))
&                    - ":"-func ASYRFNC.MES1(mess(170,10709,1),[F:TIG]TIM)
          #Read [TIM]TIM0=CDCG_TCH_LEG;[F:TIP]TIM
          #FRLAA 2018-01-25 X3-71901 - END
#          SOA_GMESSAGE =format$(SOA_GFMD,[F:TIG]STRDAT)
#&                    - string$([F:TIG]STRDAT<>[F:TIG]ENDDAT,"->"-format$(SOA_GFMD,[F:TIG]ENDDAT))
#&                    - ":"-func ASYRFNC.MES1(mess(170,10709,1),[F:TIM]COD)
          #          Evènement $1$ déjà régularisé pour cette date \ Passer une régularisation
          #mkstat=2  #????
          #ASTATUS=fmet CDCG_ASETERROR([L]CURPRO,SOA_GMESSAGE,[V]CST_AERROR)
          Break
        Endif
      Endif
    Next
    If SOA_GMESSAGE <> AVOID.ACHAR
      End
    Endif
  Endif
Endif

#If J<>[L]VALEUR                : # 73242 ligne non modifiée
# [L]VALEUR               =1
# [M:DCG1]STRDAY(nolign-1)=1
#Affzo [DCG1] STRDAY(nolign-1)
If [L]L_A<>FLG_AFTERNOON
 FLG_AFTERNOON = 1
 FLG_MORNING   = 1
Endif

End
############################################################################################################
$DATE_RANGE_SETUP

#temp date for initial testing
#this is not being used now as we have moved contract number below the date fields
#and the contract number requires the dates field to contain data

this.TCH_DATDEB = date$-365
this.TCH_DATFIN = date$+365

Return
############################################################################################################
$DATDEBFIN

Local Char ERR_MSG(250)
If this.ENDDAT <> [0/0/0] & this.ENDDAT < this.STRDAT
  #GFMDAT4 = "DD[/]MM[/]YYYY"
  Local Char SOA_GFMDAT4(20) : SOA_GFMDAT4 = "DD[/]MM[/]YYYY"
  ERR_MSG = mess(1,104,1) - ":" - format$("D:"+SOA_GFMDAT4,this.ENDDAT) - "<" - format$("D:"+SOA_GFMDAT4,this.STRDAT)
  ASTATUS=fmet this.ASETERROR([L]CURPRO,ERR_MSG,[V]CST_AERROR)
  Return
Endif

Return
############################################################################################################
$G_C_NBLIG_FIELDCONTROL

Local Integer WRET
Local Char ERR_MSG(255)

Call C_NBLIG_FIELDCONTROL(this.TCH_FCY,this.TCH_STA0,this.WEBSRV,this.REFNUM,this.ENDDAT,this.STRDAT,this.CTRNUM,ERR_MSG,WRET)

Return
#---------------------------
#Subprog C_NBLIG_FIELDCONTROL(CDCG,ERR_MSG,WRET)
Subprog C_NBLIG_FIELDCONTROL(CDCG_TCH_FCY,CDCG_TCH_STA0,CDCG_WEBSRV,CDCG_REFNUM,CDCG_ENDDAT,CDCG_STRDAT,CDCG_CTRNUM,ERR_MSG,WRET)
Value Char CDCG_TCH_FCY
Value Integer CDCG_TCH_STA0
Value Integer CDCG_WEBSRV
Value Char CDCG_REFNUM
Value Date CDCG_ENDDAT
Value Date CDCG_STRDAT
Value Char CDCG_CTRNUM
Variable Char ERR_MSG
Variable Integer WRET

#If !nolign : End : Endif
#If !maxtab(this) : End : Endif

#Gosub DROIT

Local Shortint I, J
Local Integer SOA_GDIMSIT                  : Call GDIMSIT(SOA_GDIMSIT)               From ESSGLOB_SOA
Local Char SOA_GUSRAUZ(23)(1..SOA_GDIMSIT) : Call GUSRAUZ("GESDCG", SOA_GUSRAUZ)     From ESSGLOB_SOA
Local Date SOA_GMOIPAY                     : Call GMOIPAY(CDCG_TCH_FCY, SOA_GMOIPAY) From ESSGLOB_SOA

#Case status
# When 75
    # Will always go into the else when creating a new record
    #If !find([M:DCG1]STA0(nolign-1),0,1,3) & !instr(1,[V]GUSRAUZ,"2") & [M:DCG1]WEBSRV(nolign-1)=2
    If !find(CDCG_TCH_STA0,0,1,3) & !instr(1,SOA_GUSRAUZ,"2") & CDCG_WEBSRV=2
      ERR_MSG= mess(175,10709,1)
      #mkstat = 2
      End
    Else
      Local File EMPLOCTR [HRCTR3]
      Filter [HRCTR3] Order By Key CLE=ETRFCY
      #For [HRCTR]CLE(1) Where REFNUM=[M:DCG1]REFNUM & (CTRDAT<=[M:DCG1]ENDDAT(nolign-1) | (FLGRET=2 & RETDATEFF<=[M:DCG1]ENDDAT(nolign-1)))
#&           & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1)) & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)<>0
      For [HRCTR3]CLE(1) Where REFNUM=CDCG_REFNUM & (CTRDAT<=CDCG_ENDDAT | (FLGRET=2 & RETDATEFF<=CDCG_ENDDAT))
&        & (XITDAT=AVOID.ADATE | XITDAT>=CDCG_STRDAT) & find(CDCG_CTRNUM,"",CTRNUM)<>0
        #If [M:DCG1]STRDAT(nolign-1)<[V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:HRCTR]ETRFCY))
        If CDCG_STRDAT<SOA_GMOIPAY-val(func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, [F:HRCTR3]ETRFCY, "DCGJOUANT"))
          ERR_MSG = mess(13,10715,1)-num$(SOA_GMOIPAY-val(func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, [F:HRCTR3]ETRFCY, "DCGJOUANT")))
          #mkstat  = 2
          Break
        Endif
      Next
      Filter [HRCTR3]
      #LogicClose File [HRCTR]
    Endif
#Endcase

#If !mkstat
If ERR_MSG = AVOID.ACHAR
  WRET = 1
Endif

End
############################################################################################################
$G_C_TIM

Local Char SOA_GMESSAGE(255)
Local Decimal THIS_NBRDAY
Local Decimal THIS_NBRHOU
THIS_NBRDAY = this.NBRDAY
THIS_NBRHOU = this.NBRHOU
Local Char XMSG(250)
Call C_TIM(this.ENDDAT,this.STRDAT,this.REFNUM,this.CTRNUM,this.ENDDAY,this.STRDAY,this.STA,this.UID,THIS_NBRDAY,THIS_NBRHOU,this.TYPPGN,this.TIM,this.TCH_FCY,this.TCH_LEG,SOA_GMESSAGE,
& XMSG)
#Local Integer ZSTAT
#ZSTAT = fmet this.ASETERROR("",XMSG,[V]CST_AINFO)
#FRLAA X3-74200 2018-02-21 - START
#If ACTION_MODE = "PROPAGATE"
#  this.NBRDAY = THIS_NBRDAY
#  this.NBRHOU = THIS_NBRHOU
#  If this.TIM<>this.snapshot.TIM
#    this.TYPPGN = 0
#  Endif
#Endif
#FRLAA X3-74200 2018-02-21 - END

Return
#---------------------------
#Subprog C_TIM(TIMCOD, SOA_GMESSAGE, ACTION_MODE, CDCG)
Subprog C_TIM(CDCG_ENDDAT,CDCG_STRDAT,CDCG_REFNUM,CDCG_CTRNUM,CDCG_ENDDAY,CDCG_STRDAY,CDCG_STA,CDCG_UID,CDCG_NBRDAY,CDCG_NBRHOU,CDCG_TYPPGN,TIMCOD,CDCG_FCY,CDCG_LEG,SOA_GMESSAGE,XMSG)
Value Date CDCG_ENDDAT
Value Date CDCG_STRDAT
Value Char CDCG_REFNUM
Value Char CDCG_CTRNUM
Value Libelle CDCG_ENDDAY
Value Libelle CDCG_STRDAY
Value Libelle CDCG_STA
Value Integer CDCG_UID
Variable Decimal CDCG_NBRDAY
Variable Decimal CDCG_NBRHOU
Variable Libelle CDCG_TYPPGN
Variable Char TIMCOD
Value Char CDCG_FCY
Value Char CDCG_LEG
Variable Char SOA_GMESSAGE
Value Char ACTION_MODE
Variable Char XMSG
Local Integer CHOK #FRLAA 2018-03-02 X3-74480

# do not call routine if there is no nature of events
If TIMCOD = AVOID.ACHAR
  End
Endif

#FRLAA 2018-03-02 X3-74480 - START
If func AFNC.ACTIV("GLM")
  Call CHECK_EXTR(CDCG_CTRNUM,TIMCOD,CDCG_STRDAT,CDCG_ENDDAT,SOA_GMESSAGE,CHOK)
  If CHOK=1 : End : Endif
Endif
#FRLAA 2018-03-02 X3-74480 - END

#Dbgaff

Local Integer I, N, J , F
Local Decimal NBJ, NBRDAY, SOLNEG , D
Local Date    DEB, FIN, DEBTOL, FINTOL
Local Char    VALPAR(20), AM(4), PM(4), C(1), L_CTRNUM(GLONHRCTR)

#N=[M:DCG1]ENDDAT(nolign-1)-[M:DCG1]STRDAT(nolign-1)+1
N=CDCG_ENDDAT-CDCG_STRDAT+1

#FRLAA X3-81054 2018-03-05 - START
If N <= 0
  End
Endif
#FRLAA X3-81054 2018-03-05 - END


Local Decimal JOUR(1..N), HEURE(1..N), JOUR2(1..N)

Local Integer SOA_GTPS : Call GTPS(SOA_GTPS) From ESSGLOB_SOA

If SOA_GTPS = 1
  Local File PLANEMP [PLE]
Endif

Local File HLYDAY [HLY]
Local File TIMCOD [TIM]
Local File DEMCONGE [DCG]
Local File EMPLOCTR [HRCTR]

If [F:TIM]COD <> TIMCOD
  #Read [F:TIM]TIM0 = TIMCOD
  Read [F:TIM]TIM0 = CDCG_LEG;TIMCOD    # STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - add LEG
Endif
Call CONTEXE([F:TIM]ACS, SOA_GMESSAGE) From CPTSUB_SOA
If SOA_GMESSAGE <> AVOID.ACHAR
  End
Endif

#If dim(ACTPOR) >= 0 and  ACTPOR="ANNUL"
#Else
  If [F:TIM]FILTRE<>AVOID.ACHAR | [F:TIM]POP<>AVOID.ACHAR
    Local Integer RET
    #Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M:DCG1]REFNUM,[M:DCG1]CTRNUM(nolign-1),RET) From DIVPAYE : #TODO
    Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,CDCG_REFNUM,CDCG_CTRNUM,RET) From DIVPAYE_SOA
    If RET>0 Then
      #GMESSAGE=[F:TIM]COD-":"-mess(320,199,1)
      SOA_GMESSAGE = [F:TIM]COD-":"-mess(00220,10709,1)
      End
    Endif
  Endif
#Endif

Local Integer SOA_GWEBSERV : Call GWEBSERV(SOA_GWEBSERV) From ESSGLOB_SOA

If (SOA_GWEBSERV & [F:TIM]AUZPRH<2)
&| ( !SOA_GWEBSERV
&  & (!find([F:TIM]CATTIM,2,3) | (SOA_GTPS & [F:TIM]CTLDAC=2))
&  )
  SOA_GMESSAGE = mess(83,123,1)
  End
Endif

#If [F:TIM]DAYDAC<2 & eomonth([M:DCG1]STRDAT(nolign-1))<>eomonth([M:DCG1]ENDDAT(nolign-1))
If [F:TIM]DAYDAC<2 & eomonth(CDCG_STRDAT)<>eomonth(CDCG_ENDDAT)
  SOA_GMESSAGE = mess(186,10709,1)
  End
Endif

#Local File EMPLOCTR [HRCTR]   #SOA-move code (see above)

#If val(func AFNC.PARAM("CPOUVRA",""))=2
If val(func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "CPOUVRA")) = 2
 For [HRCTR]CTR0(2) Where REFNUM=CDCG_REFNUM & find(CDCG_CTRNUM,"",CTRNUM) & (CTRDAT<=CDCG_ENDDAT | (FLGRET=2 & RETDATEFF<=CDCG_ENDDAT)) & (XITDAT=[0/0/0] | XITDAT>=CDCG_ENDDAT)
  #If [L]TIMCOD=func AFNC.PARAM("CPA",[F:HRCTR]ETRFCY)
  If TIMCOD = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, [F:HRCTR]ETRFCY, "CPA") & func TPSSTD1_SOA.OUVRABLE(CDCG_REFNUM,CDCG_ENDDAT+1,[F:HRCTR]CTRNUM,CDCG_FCY,SOA_GMESSAGE) #done
   #Call AVERTIR(mess(70,10709,1),I) From GESECRAN
#   If I<>2 : mkstat=2 : Endif
#      Break
#   Endif
#   Note: we will let the routine continue at this stage for the purpose of SOA
#   i.e. do not return the error
    #SOA_GMESSAGE = mess(70,10709,1)
    Break
  Endif
 Next
 If SOA_GMESSAGE <> AVOID.ACHAR
  End  # do not END based on question above - carry on as if the user answered to do so - only END if genuine error message
 Endif
Endif

Local File CNGCPY[CNG]
Local File CNGEMP[CNE]

Local Date DATDEBCTR
For [HRCTR]CTR0(2) Where REFNUM=CDCG_REFNUM & find(CDCG_CTRNUM,"",CTRNUM) & (CTRDAT<=CDCG_ENDDAT | (FLGRET=2 & RETDATEFF<=CDCG_ENDDAT)) & (XITDAT=[0/0/0] | XITDAT>=CDCG_STRDAT)
 Raz [L]JOUR
 For [HRCTR]CTR0
  DATDEBCTR=[F:HRCTR]CTRDAT
  If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0]
   DATDEBCTR=[F:HRCTR]RETDATEFF
  Endif
  [L]DEB=max(CDCG_STRDAT,DATDEBCTR)
  If [F:HRCTR]XITDAT=[0/0/0]
  [L]FIN=CDCG_ENDDAT
  Else
  [L]FIN=min(CDCG_ENDDAT,[F:HRCTR]XITDAT)
  Endif

  I=[L]DEB-CDCG_STRDAT+1
  Raz [L]JOUR2
  If [F:HRCTR]PLNTYP=AVOID.ACHAR
   For J=I To N : [L]JOUR2(J)=1 : Next
  Else
   # [L]JOUR2(I..N) and[L]HEURE(I..N) are updated by SUBPLN_SOA
  #FRLAA - 2018-01-17 - X3-67633 - START - Comment all code
  #MIPEA - 2017-11-27- US X3-63170- START
   #Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
  #MIPEA - 2017-11-27- US X3-63170- END
  #FRLAA - 2018-01-17 - X3-67633 - END
   Call VALORDET( [L]DEB,[L]FIN,CDCG_REFNUM,[L]TIMCOD,[L]JOUR2(I..N),[L]HEURE(I..N),[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,CDCG_LEG) From SUBPLN_SOA
  Endif

  If SOA_GTPS
    If CDCG_ENDDAY=2 & [L]DEB=CDCG_STRDAT

       Call GETSEMTYP([F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]DEB,[L]DEB,C,[L]DEB,C,F,D,[L]AM,C,[L]PM,C,C,C,SOA_GMESSAGE) From PORTPS_SOA

        If [L]AM<>AVOID.ACHAR & [L]PM<>AVOID.ACHAR
        [L]HEURE(1)-=min(0.5,[L]JOUR2(1))*[L]HEURE(1)
        [L]JOUR2(1)-=min(0.5,[L]JOUR2(1))

       Endif
       If [L]PM = AVOID.ACHAR
        F = 2 : #Assumed Yes for AVERTIR below (Not possible in Syracuse)
        If !SOA_GWEBSERV

         #Call AVERTIR(mess(194,10709,1),F) From GESECRAN : #Assumed Yes
         [L]HEURE(1)=0
         [L]JOUR2(1)=0
        Endif
        If F<>2
         LogicClose File [CNG]
         LogicClose File [CNE]
         End
        Endif
       Endif
    Endif

    If CDCG_STRDAY=2 & [L]FIN=CDCG_ENDDAT

        Call GETSEMTYP([F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]FIN,[L]FIN,C,[L]FIN,C,F,D,[L]AM,C,[L]PM,C,C,C,SOA_GMESSAGE) From PORTPS_SOA
        If [L]AM<>AVOID.ACHAR & [L]PM<>AVOID.ACHAR

          [L]HEURE(N)-=min(0.5,[L]JOUR2(N))*[L]HEURE(N)
          [L]JOUR2(N)-=min(0.5,[L]JOUR2(N))
        Endif

        If [L]AM = AVOID.ACHAR
         F = 2 : #Assumed Yes for AVERTIR below (Not possible in Syracuse)
         If !SOA_GWEBSERV
          #Call AVERTIR(mess(194,10709,1),F) From GESECRAN : #Assumed Yes
          [L]HEURE(N)=0
          [L]JOUR2(N)=0
         Endif
         If F<>2
          LogicClose File [CNG]
          LogicClose File [CNE]
          End
         Endif
        Endif
    Endif  #If CDCG_STRDAY=2 & [L]FIN=CDCG_ENDDAT

  Else : # 69211  #If SOA_GTPS
#   73242 If [M:DCG1]STRDAY(nolign-1)=2
     If CDCG_ENDDAY=2

      [L]HEURE(1)-=min(0.5,[L]JOUR2(1))*[L]HEURE(1)
      [L]JOUR2(1)-=min(0.5,[L]JOUR2(1))

     Endif

#73242   If [M:DCG1]ENDDAY(nolign-1)=2
     If CDCG_STRDAY=2
      [L]HEURE(N)-=min(0.5,[L]JOUR2(N))*[L]HEURE(N)
      [L]JOUR2(N)-=min(0.5,[L]JOUR2(N))
     Endif

  Endif   : # 69211  #If SOA_GTPS   #Else

  If [F:TIM]CATTIM=3
   #If [F:TIM]FLGBLC=2 & [M:DCG1]STA(nolign-1) <> 1
   If [F:TIM]FLGBLC=2 & CDCG_STA <> 1
    Raz I, [L]NBJ
    Raz [L]DEBTOL, [L]FINTOL
    Link [CNG] With [CNE]CNE0=YEA;CDCG_REFNUM;[F:HRCTR]CTRNUM;TIM As [LNK]
    Local Char     CRITERIA(100)
    # STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - START
    #If func ASYRFNC.ACTIV("KSA")>0 & (func ASYRFNC.ACTIV("KFR")=0 & func ASYRFNC.ACTIV("KPO")=0)
    If func DIVPAYE.IS_ZA_DEV_LEG(CDCG_LEG) Then    #check this new routine ????
    #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
    # CRITERIA = '[F:CNE]EMPLEAEND>=[L]DEB & [F:CNE]EMPLEASTR<=[L]FIN'
    # STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - END
      CRITERIA = '[F:CNE]EMPLEAEND>=[L]DEB & [F:CNE]EMPLEASTR<=[L]FIN'
    Else
      CRITERIA = 'FINDAT>=[L]DEB & DEBDAT<=[L]FIN'
    Endif
    For [LNK]CNG0 Where CPY=func DIVPAYE_SOA.GETSOC([F:HRCTR]ETRFCY) & TIM=[L]TIMCOD & evalue(CRITERIA)
     If [F:CNE]TIM<>TIMCOD
      #GMESSAGE = mess(165,10709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
      SOA_GMESSAGE = mess(165,10709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
      Break 3
     Endif

     [L]NBJ+=[F:CNE]NBRDAY
     I      =1
     XMSG-="NBJ="+num$([L]NBJ)
     # STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - START
     #If func ASYRFNC.ACTIV("KSA")>0 & (func ASYRFNC.ACTIV("KFR")=0 & func ASYRFNC.ACTIV("KPO")=0) Then
     If func DIVPAYE.IS_ZA_DEV_LEG(CDCG_LEG) Then    #check this new routine ????
      # STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - END
      If [L]DEBTOL = [0/0/0] | [L]DEBTOL > [F:CNE]EMPLEASTR
        [L]DEBTOL = [F:CNE]EMPLEASTR
      Endif
      If [L]FINTOL = [0/0/0] | [L]FINTOL < [F:CNE]EMPLEAEND
        [L]FINTOL = [F:CNE]EMPLEAEND
      Endif
     Else
      If [L]DEBTOL = [0/0/0] | [L]DEBTOL > [F:CNG]DEBDAT
        [L]DEBTOL = [F:CNG]DEBDAT
      Endif
      If [L]FINTOL = [0/0/0] | [L]FINTOL < [F:CNG]FINDAT
        [L]FINTOL = [F:CNG]FINDAT
      Endif
     Endif
    Next
     If I
      [L]NBJ-=sum([L]JOUR2)

#Contract number can be null or same as one being passed into routine
      XMSG-=CDCG_REFNUM-TIMCOD-CDCG_CTRNUM-num$([L] DEBTOL)-num$([L]FINTOL)
      #FRLAA 2018-01-18 X3-62402 - START
      #For [F:DCG] Where REFNUM=CDCG_REFNUM & (STA=2 or STA=3) & UID>0 & TIM = TIMCOD
#&              & find(CTRNUM,"",CDCG_CTRNUM)
#&              & (STRDAT >= [L] DEBTOL & ENDDAT <= [L]FINTOL)

      For [F:DCG] Where REFNUM=CDCG_REFNUM & (STA=2 or STA=3 or STA=5 or STA=7) & UID>0 & TIM = TIMCOD
&              & find(CTRNUM,"",CDCG_CTRNUM)
&              & (STRDAT >= [L] DEBTOL & ENDDAT <= [L]FINTOL)
      #FRLAA 2018-01-18 X3-62402 - END
        If [F:DCG]UID <> CDCG_UID             # exclude current record
          [L]NBJ-=[F:DCG]NBRDAY
        Else
        Endif
      Next

# Code below is for looking at mask (grid) in V6
#&                    & !find(UID,CDCG_UID)
#TODO - is this still necessary
     #For F = 0 To maxtab(this)
#       If F <> nolign-1 & [M:DCG1]TIM(F) = TIMCOD & find([M:DCG1]STA(F),2,3)
#&      and ([M:DCG1]CTRNUM(F) = "" or [M:DCG1]CTRNUM(F) = [F:HRCTR]CTRNUM)
#&      and (([M:DCG1]STRDAT(F) >= [L]DEBTOL & [M:DCG1]STRDAT(F) <= [L]FINTOL)
#&         | ([M:DCG1]ENDDAT(F) <= [L]FINTOL & [M:DCG1]ENDDAT(F) >= [L]DEBTOL))
#        [L]NBJ-=[M:DCG1]NBRDAY(F)
#       Endif
#     Next

     [L]SOLNEG=[L]NBJ
     [L]L_CTRNUM = [F:HRCTR]CTRNUM
    Else
     #GMESSAGE -= '\'-mess(319,199,1)-[F:TIM]COD  : # Fiche période de congé inexistante pour l'évènement
     SOA_GMESSAGE -= '\'-mess(00240,10709,1)  : #  Leave period record does not exist for the event

     Break 2
    Endif
   Endif
  Endif
  If SOA_GMESSAGE <> AVOID.ACHAR
    LogicClose File [CNG]
    LogicClose File [CNE]
    End
  Endif
  For I=1 To N
   If (I=1 & CDCG_ENDDAY=2) | (I=N & CDCG_STRDAY=2)
    [L]NBJ=0.5
   Else
    [L]NBJ=1
   Endif
   If [L]JOUR(I)+[L]JOUR2(I)<=[L]NBJ : [L]JOUR(I)+=[L]JOUR2(I) : Endif
  Next
 [L]NBRDAY=max([L]NBRDAY,sum([L]JOUR))

 If [F:TIM]FLGBLC=2 & [L]SOLNEG<[F:TIM]BLCMIN
   Break 2
 Endif
 Next
Next
LogicClose File [CNG]
LogicClose File [CNE]
LogicClose File [DCG]
If SOA_GMESSAGE <> AVOID.ACHAR
  End
Endif
#If dim(ACTPOR) >= 0 & ACTPOR="ANNUL"
#Else

#FRLAA 2018-02-22 X3-74480 - START
#Global leave management - GLM
If func AFNC.ACTIV("GLM")=0
  #Declare GLM SOA Variables
   If [F:TIM]FLGBLC=2 and [L]SOLNEG<[F:TIM]BLCMIN
    SOA_GMESSAGE = mess(118,10709,1)-":"-num$([L]SOLNEG)-"("+mess(72,10720,1)-L_CTRNUM+")"
    End
  Endif
Endif
# If [F:TIM]FLGBLC=2 and [L]SOLNEG<[F:TIM]BLCMIN
#  SOA_GMESSAGE = mess(118,709,1)-":"-num$([L]SOLNEG)-"("+mess(72,720,1)-L_CTRNUM+")"
#  End
#Endif
#FRLAA 2018-02-22 X3-74480 - END

#Endif
XMSG-=":)"
CDCG_NBRDAY = [L]NBRDAY
CDCG_NBRHOU = sum([L]HEURE)

#If ACTION_MODE = "PROPAGATE"
  #CDCG_NBRDAY = [L]NBRDAY
  #CDCG_NBRHOU = sum([L]HEURE)

  #Affzo [DCG1] NBRDAY(nolign-1), NBRHOU(nolign-1)
  # we are creating so do not need to look at snapshot
  #If CDCG_TIM<>CDCG_snapshot.TIM
    #CDCG_TYPPGN = 0
  #Endif
#Endif

End
############################################################################################################
$GET_CTR

# this routine was added for SOA
# it will try to get the relevant contract in order to update the technical field for the contract date
# it is called from CTRNUM, STRDAT, ENDDAT
# it is only used in propagate as we are not trying to change any previous V6/classis logic

If this.REFNUM = AVOID.ACHAR
  Return
Endif
#
If this.STRDAT = AVOID.ADATE
  Return
Endif
#
If this.ENDDAT = AVOID.ADATE
  Return
Endif
#
#If this.CTRNUM = AVOID.ACHAR
  #Return
#Endif

#Local File EMPLOID  [ID9]

# don't need this as we always get the latest contract with the same contract number
# FLGMULCTR flag from employee
#Read [F:ID9]ID0 = this.REFNUM
#If fstat <> [V]CST_AOK
  #LogicClose File [ID9]
  #Return
#Endif

Local File EMPLOCTR [HRCTR9]
#
Local Integer FUNC_STA #FRLAA X3-53638 2017-08-25
If this.CTRNUM = AVOID.ACHAR
  Filter [HRCTR9] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT) Order By CTRDAT Desc
Else
  Filter [HRCTR9] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT) Order By CTRDAT Desc
Endif
Read [HRCTR9] First
If fstat = [V]CST_AOK
  this.CTRDAT  = [F:HRCTR9]CTRDAT
  this.TCH_FCY = [F:HRCTR9]ETRFCY
  this.TCH_SRV = [F:HRCTR9]ETRSRV
  this.TCH_CPY = func DEMCONGE_CSTD_EVT.SETTCHCPY([F:HRCTR9]ETRFCY)#FRLAA - 2018-03-01 - X3-80678
  this.CTRNUM  = [F:HRCTR9]CTRNUM
  If this.RPL = AVOID.ACHAR
    this.RPL=[F:HRCTR9]RPL(0)
  Endif
  Local Char CTR_LEG(GLONADI)
  Local Integer VLEGLVL : VLEGLVL = 1
  CTR_LEG = func DIVPAYE_SOA.GET_LEG_FCY([F:HRCTR9]ETRFCY,VLEGLVL)
  If CTR_LEG <> AVOID.ACHAR
    this.TCH_LEG  = CTR_LEG
  Endif
  #Set legislation in cached class for usage in lookup on other classes
  FUNC_STA = func DIVPAYE_SOA.SET_CACHED_LEG(this.ACTX.USER, this.TCH_LEG) #FRLAA X3-53638 2017-08-25
Endif




Filter [F:HRCTR9]
LogicClose File [F:HRCTR9]

Return
###########################################################################################################


$CHECK_SUBORDINATE
If this.REFNUM = AVOID.ACHAR
  Return
Endif

If this.STRDAT = AVOID.ADATE
  Return
Endif

If this.ENDDAT = AVOID.ADATE
  Return
Endif

Local File EMPLOCTR [HRCTR4]

If this.CTRNUM = AVOID.ACHAR
  Filter [HRCTR4] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT) Order By CTRDAT Desc
Else
  Filter [HRCTR4] Where REFNUM=this.REFNUM & CTRNUM=this.CTRNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&           & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT) Order By CTRDAT Desc
Endif
Read [HRCTR4] First
If fstat = [V]CST_AOK
  #After setting the Contract, check that the logged in user can log a request for the employee
  Local File EMPSBD [ESB1]
  If this.TCH_EMPSBD <> AVOID.ACHAR
    #Subordinate selected - Only available on Manager ESS
    Local Integer FOUND_CHEF
    Filter [F:ESB1] Where REFNUM = [F:HRCTR4]REFNUM and CTRNUM = [F:HRCTR4]CTRNUM and CTRDAT = [F:HRCTR4]CTRDAT
    For [ESB1]
      If [F:ESB1]CHEF = fmet this.ACTX.ACACHE.USRESS.AGETVALCHAR(this.ACTX.USER,"REFNUM")
        FOUND_CHEF = 1
        Break
      Endif
    Next
    If FOUND_CHEF <> 1
      ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00192,10702,1),[V]CST_AERROR)
    Endif
  Endif
  Filter [F:ESB1]
  LogicClose File [ESB1]
Endif

Filter [F:HRCTR4]
LogicClose File [HRCTR4]
Return
#FRLAA 2018-02-27 X3-74480 - START
$DEMCONGEESS_LVERSN
Case [L]ARULE
  When "CONTROL"
    Gosub DEMCONGEESS_LVERSN_CONTROL
Endcase
Return

$DEMCONGEESS_LVERSN_CONTROL
Local Integer NM
Local Char VGCURLEG(GLONADI)
Local File TIMCOD  [TIM3]

#Get the legislation for the current record to be used when filtering [F:TIM3]
If this.REFNUM <> AVOID.ACHAR and this.CTRNUM <> AVOID.ACHAR and this.CTRDAT <> AVOID.ADATE
  #Only perform this check if all required fields are completed
  VGCURLEG = func DIVPAYE_SOA.GET_LEG_CTR(this.REFNUM, this.CTRNUM, this.CTRDAT, 1)
  Filter [TIM3] Where COD = this.TIM and LEG = VGCURLEG  and RSNMAN = 2
  Read [TIM3] First
  Filter [TIM3]
  If fstat = [V]CST_AOK Then
    If this.LVERSN = AVOID.ACHAR
      ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
    Endif
  Endif

  #Check if the leave reason is linked to the nature of events
  If func DEMCONGE_CSTD_PRO.CONTLVERSN(this.LVERSN,this.TIM,VGCURLEG) = [V]CST_ANO
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(25,11691,1)-this.TIM,[V]CST_AERROR)
  Endif
Endif


Return

$DEMCONGEESS_LVENOT
Case [L]ARULE
  When "CONTROL"
    Gosub DEMCONGEESS_LVENOT_CONTROL
Endcase
Return

$DEMCONGEESS_LVENOT_CONTROL
Local Integer DIFDAT : DIFDAT = 0
Local Integer DOK : DOK = 0
Local Date BLNKDAT : Raz BLNKDAT
Local Char VGCURLEG(GLONADI)
Local Integer BEFORENON, AFTERNON
Local File TIMCOD  [TIM3]

DIFDAT = (this.ENDDAT - this.STRDAT)+1

#Get the legislation for the current record to be used when filtering [F:TIM3]
If this.REFNUM <> AVOID.ACHAR and this.CTRNUM <> AVOID.ACHAR and this.CTRDAT <> AVOID.ADATE
  #Only perform this check if all required fields are completed
  VGCURLEG = func DIVPAYE_SOA.GET_LEG_CTR(this.REFNUM, this.CTRNUM, this.CTRDAT, 1)
  Filter [TIM3] Where COD = this.TIM and LEG = VGCURLEG
  Read [TIM3] First
  Filter [TIM3]
  If fstat = [V]CST_AOK Then
    If [F:TIM3]NBRDAY > 0 and this.NBRDAY >= [F:TIM3]NBRDAY Then
      If this.LVENOT = 1 Then
        ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
      Endif
    Elsif [F:TIM3]NONBUS = 2 and DIFDAT >= [F:TIM3]NBRDAY  Then
      If this.LVENOT  = 1 Then
        ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
      Endif
    Elsif [F:TIM3]BFRNON = 2 | [F:TIM3]AFTNON = 2 Then
      If this.LVENOT = 1 Then
        BEFORENON = [F:TIM3]BFRNON
        AFTERNON = [F:TIM3]AFTNON
        If func DEMCONGE_CSTD_PRO.COMPARE_DAYS(this.STRDAT,this.ENDDAT,this.CTRNUM,BEFORENON,AFTERNON,VGCURLEG) = [V]CST_ANO
          ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,123,1),[V]CST_AERROR)
        Endif
      Endif
    Endif
  Endif
Endif

Return

$DEMCONGEESS_UID
Case [L]ARULE
  When "INIT"
    Gosub DEMCONGEESS_UID_INIT
Endcase
Return

$DEMCONGEESS_UID_INIT
If this.UID = 0
  Local File TIMEMP [TIP1]
  UNIQUE_ID = uniqid([TIP1])
  this.UID = UNIQUE_ID
Endif
Return

$DEMCONGEESS_DEM
Case [L]ARULE
  When "INIT"
    Gosub DEMCONGEESS_DEM_INIT
Endcase
Return

$DEMCONGEESS_DEM_INIT
If this.DEM = 0
  Local File DEMCONGE[DCG1]
  this.DEM = uniqid([DCG1])
Endif
Return


Funprog CONTLVERSN(V_LVERSN,V_TIM,V_VGURLEG)
Value Char V_LVERSN()
Value Char V_TIM
Value Char V_VGURLEG
Local Integer FUNC_RESULT
FUNC_RESULT = [V]CST_AYES

If V_LVERSN <> AVOID.ACHAR Then
  Local File HRLVEREA  [HRLSE]
  Filter [HRLSE] Where COD=V_LVERSN and LEG = V_VGURLEG
  Read [HRLSE] First
  If fstat = [V]CST_AOK and [F:HRLSE]TIMCOD <> V_TIM Then
    FUNC_RESULT = [V]CST_ANO
  Endif
Endif
End FUNC_RESULT

Funprog COMPARE_DAYS(STRDAY, ENDDAY, CTR, BEFORENON, AFTERNON,V_VGURLEG)
Value Char V_VGURLEG
Variable Date STRDAY
Variable Date ENDDAY
Variable Char CTR
Variable Integer BEFORENON
Variable Integer AFTERNON
Local Date SDAT : If STRDAY<>[0/0/0]:SDAT = STRDAY-1:Endif
Local Date EDAT : If ENDDAY<>[0/0/0]:EDAT = ENDDAY+1:Endif
Local Char STDAT(30)
Local Char EDDAT(30)
Local Integer YY : YY = year(date$)
Local Integer X
Local Integer FAILED
Local Integer FUNC_RESULT : FUNC_RESULT = [V]CST_AYES

Local File HLYDAY     [HLY1]
Local File EMPLOCTR   [HRCTR1]
Local File PLANTYP    [PLN1]
Local File TYPWEEK    [WTY1]

Filter [HRCTR1] Where CTRNUM = CTR and PLNTYP <> ""
Read [HRCTR1] Last
Filter [HRCTR1]
If fstat = [V]CST_AOK Then
  Filter [PLN1] Where COD = [HRCTR1]PLNTYP and LEG = V_VGURLEG and WEKTYP(0) <> ""
  Read [PLN1] First
  Filter [PLN1]
  If fstat = [V]CST_AOK Then
      Filter [WTY1] Where COD = [PLN1]WEKTYP(0) and LEG = V_VGURLEG
      Read [WTY1] First
      Filter [WTY1]
      If fstat = [V]CST_AOK Then
        If (AFTERNON = 2)
          Local Integer STRDAYINT, ENDDAYINT
          If dayn(STRDAY)-1 < 0
            STRDAYINT = 6
          Else
            STRDAYINT = dayn(STRDAY)-1
          Endif
          If dayn(ENDDAY)-1 < 0
            ENDDAYINT = 6
          Else
            ENDDAYINT = dayn(ENDDAY)-1
          Endif
          If ([WTY1]TYPDAY(STRDAYINT) = 3 or [WTY1]TYPDAY(ENDDAYINT) = 3)
            FAILED = 1
          Elsif (ENDDAY - STRDAY > 2)
            Local Date COUNTERDATE: COUNTERDATE = STRDAY:
            Local Integer COUNTERDATEINT
            While COUNTERDATE < ENDDAY and FAILED = 0
              If dayn(COUNTERDATE)-1 < 0
                COUNTERDAYINT = 6
              Else
                COUNTERDAYINT = dayn(COUNTERDATE)-1
              Endif
              If ([WTY1]TYPDAY(COUNTERDAYINT) = 3)
                FAILED = 1
              Endif
              COUNTERDATE += 1
            Wend
          Endif
        Endif
        If (FAILED = 1)
          End [V]CST_ANO
        Endif
        If (BEFORENON = 2)
          Local Integer STRDAYINT, ENDDAYINT
          If dayn(STRDAY)+1 > 6
            STRDAYINT = 0
          Else
            STRDAYINT = dayn(STRDAY)+1
          Endif
          If dayn(ENDDAY)+1 > 6
            ENDDAYINT = 0
          Else
            ENDDAYINT = dayn(ENDDAY)+1
          Endif
          If ([WTY1]TYPDAY(STRDAYINT) = 3 or [WTY1]TYPDAY(ENDDAYINT) = 3)
            FAILED = 1
          Elsif (ENDDAY - STRDAY > 2)
            Local Date COUNTERDATE: COUNTERDATE = STRDAY:
            Local Integer COUNTERDATEINT
            While COUNTERDATE < ENDDAY and FAILED = 0
              If dayn(COUNTERDATE)+1 > 6
                COUNTERDAYINT = 0
              Else
                COUNTERDAYINT = dayn(COUNTERDATE)+1
              Endif
              If ([WTY1]TYPDAY(COUNTERDAYINT) = 3)
                FAILED = 1
              Endif
              COUNTERDATE += 1
            Wend
          Endif
        Endif
        If (FAILED = 1)
          End [V]CST_ANO
        Endif
      Endif
    Endif
  Endif

  #Checks for public holidays
  Filter [HLY1] Where YEA = YY and LEG = V_VGURLEG
  Read [HLY1] First
  Filter [HLY1]
  If !fstat
    For X=1 To dim([HLY1]HLYDAY)
      If [HLY1]HLYDAY(X-1) <> [0/0/0] Then
        If ([HLY1]HLYDAY(X-1) = STRDAY and [HLY1]HLYDAY(X-1) = ENDDAY) ## Nothing should happen as this is a public holiday that was selected
        Elsif (BEFORENON = 2 and ([HLY1]HLYDAY(X-1) - 1 = STRDAY or [HLY1]HLYDAY(X-1) - 1 = ENDDAY or ([HLY1]HLYDAY(X-1) >= STRDAY and [HLY1]HLYDAY(X-1) <= ENDDAY))) or
&          (AFTERNON = 2 and ([HLY1]HLYDAY(X-1) + 1 = STRDAY or [HLY1]HLYDAY(X-1) + 1 = ENDDAY or ([HLY1]HLYDAY(X-1) >= STRDAY and [HLY1]HLYDAY(X-1) <= ENDDAY)))
          End [V]CST_ANO
        Endif
      Endif
    Next
  Endif
End FUNC_RESULT
#FRLAA 2018-02-27 X3-74480 - END


#FRLAA 2018-03-02 X3-74480 - START
Subprog CHECK_EXTR(CTR,TIM,STRDAT,ENDDAT,ERRMESS,CHOK)
#-------------------------SOA Compatible------------------------------#
Variable Char CTR()
Variable Char TIM
Variable Date STRDAT
Variable Date ENDDAT
Variable Char ERRMESS
Variable Integer CHOK

If clalev([F:TIM2])=0 : Local File TIMCOD  [TIM2] : Endif
If clalev([F:HRCTR2])=0  : Local File EMPLOCTR [HRCTR2]  : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
If clalev([F:PLN])=0 : Local File PLANTYP [PLN] : Endif

  Filter [F:TIM2] Where COD = TIM and  LVEENHANCE = 2
  Read [TIM2] First
  Filter [F:TIM2]
  If !fstat Then
    Filter [F:HRCTR2] Where CTRNUM = CTR
    Read [HRCTR2] First
    Filter [HRCTR2]
    If !fstat Then
      Filter [HRPEOD] Where PERCOD = [F:HRCTR2]PERCOD and PERSTR(1) >= STRDAT  and PEREND(1) <= ENDDAT
      Read [HRPEOD] Last
      Filter [HRPEOD]
      If fstat>4
        ERRMESS= mess(10,11691,1)
        CHOK=1 : End
      Endif
      If [F:HRCTR2]PLNTYP <> "" Then
          Filter [F:PLN] Where COD = [F:HRCTR2]PLNTYP and WEKTYP <> ""
          Read [PLN] First
          Filter [PLN]
          If fstat>4 Then
            ERRMESS= mess(11,11691,1)
            CHOK=1 : End
          Endif
        Else
          ERRMESS= mess(12,11691,1)
          CHOK=1 :End
      Endif
    Endif
  Endif
#-------------------------SOA Compatible------------------------------#
End

#FRLAA 2018-03-02 X3-74480 - END

