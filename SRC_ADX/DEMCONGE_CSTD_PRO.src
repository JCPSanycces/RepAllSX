  Return
Endif

Local File EMPLOCTR [HRCTR3]
If this.CTRNUM>AVOID.ACHAR
 Read [HRCTR3]CTR0=this.REFNUM;this.CTRNUM;this.CTRDAT     #???? waiting to get contract date if selected
 If fstat <> [V]CST_AOK
  #ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(38,10720,1)-this.TIM,[V]CST_AERROR)   #???? get lm message
  #LogicClose File [TIM]
  #Return
 Endif
 this.RPL=[F:HRCTR3]RPL(0)
Else
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
 For [HRCTR3]CTR1 Where REFNUM=this.REFNUM & (CTRDAT<this.STRDAT | (FLGRET=2 & RETDATEFF<this.STRDAT))
&                  & (XITDAT=[0/0/0] | XITDAT>this.ENDDAT) & sum(RPL)>""
  For I=0 To dim([F:HRCTR3]RPL)-1
   If [F:HRCTR3]RPL(I)>AVOID.ACHAR : this.RPL=[F:HRCTR3]RPL(I) : Break 2 : Endif
  Next
 Next
Endif
LogicClose File [HRCTR3]

