$DEMCONGEESS_ENDDAT_PROPAGATE

ASTATUS = fmet this.ADELETEERROR("STRDAT")
ASTATUS = fmet this.ADELETEERROR("CTRNUM")
ASTATUS = fmet this.ADELETEERROR("NBRDAY")
ASTATUS = fmet this.ADELETEERROR("STRDAY")
ASTATUS = fmet this.ADELETEERROR("ENDDAY")
ASTATUS = fmet this.ADELETEERROR("TIM")

Gosub GET_CTR

# set STA in creation mode
# STA needs to be set in creation in order to validate overlapping dates

#FRLAA X3-74200 2018-02-21 - START
#If this.UID = AVOID.AINT
#  this.STA = 2
#Endif
#FRLAA X3-74200 2018-02-21 - END

If this.TIM <> AVOID.ACHAR
#FRLAA X3-74200 2018-02-21 - START
  Gosub G_C_TIM
  this.NBRDAY = THIS_NBRDAY
  this.NBRHOU = THIS_NBRHOU
  If this.TIM<>this.snapshot.TIM
    this.TYPPGN = 0
  Endif
#  Local Char ACTION_MODE(10)  :  ACTION_MODE = "PROPAGATE"
#  Gosub G_C_TIM
#FRLAA X3-74200 2018-02-21 - END
Endif

# STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - new code added in GX3APP - START
#MIPEA - 2017-01-06- X3-12089- START
If this.CTRNUM=AVOID.ACHAR
  If clalev([HRCTR3]) = 0 : Local File EMPLOCTR[HRCTR3] : Endif
  If clalev([FCY]) = 0 : Local File FACILITY[FCY] : Endif
  Link [HRCTR3]
&   With [FCY]FCY0=ETRFCY
&   As [LNK]
&   Where REFNUM=this.REFNUM & find(this.CTRNUM,"",CTRNUM)
&       & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&       & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT)
&       & (CTRDAT<=this.STRDAT) & [FCY]LEG=this.TCH_LEG
  Filter [LNK]
  Read [LNK] First
  If rowcount([LNK])=1
    this.CTRNUM = [F:HRCTR3]CTRNUM
  Endif
  LogicClose File [HRCTR3]
  LogicClose File [FCY]
Endif
#MIPEA - 2017-01-06- X3-12089- END
# STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - new code added in GX3APP - END

Return
