#---------------------------
$C_STA_CONTROL

Local Integer  SOA_GTPS :  Call GTPS(SOA_GTPS) From ESSGLOB_SOA

#Call C_NBLIG_FIELDCONTROL(this,ERR_MSG,WRET)
Gosub G_C_NBLIG_FIELDCONTROL
If !WRET
  ASTATUS=fmet this.ASETERROR([L]CURPRO,ERR_MSG,[V]CST_AERROR)
  Return
Endif

If this.STA<>5 & this.STA<>6 : Return : Endif : # Demande d'annulation / Annulation acceptée

Local File EMPLOCTR [HRCTR3]
#Local File PERIOD   [PEO]
Local File HRPEODET [HRPEOD]
Local File TIMCOD   [TIM]
Local File VALEMP   [VEP]

# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
For [HRCTR3]CTR0 Where REFNUM=this.REFNUM & find(this.CTRNUM,"",CTRNUM)
&                 & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&                 & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT)

# STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - START
# Filter [PEO] Where PERSTR(0)<=this.ENDDAT
#&                 & PEREND(1)>=this.STRDAT & find(FCY,"",[F:HRCTR]ETRFCY)<>0
#&      Order By Key CLE=PYRDAT;FCY Desc
 Filter [HRPEOD] Where PERSTR(0)<=this.ENDDAT
&                 & PEREND(1)>=this.STRDAT & find(PERCOD,"",[F:HRCTR3]PERCOD)<>0
&      Order By Key CLE=PYRDAT;PERCOD Desc
 For [HRPEOD]CLE(1)
  If [F:HRPEOD]STA<>2 & SOA_GTPS
   #[V]GMESSAGE=mess(58,10709,1) : # Période non ouverte à la saisie
   #mkstat     =2
   ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(58,10709,1),[V]CST_AERROR)
   Break 2
  Endif
 Next

 # Fiche 68349 - 25/10/2010 : même message si aucune période d'extraction
 If rowcount([F:HRPEOD]) = 0
   #[V]GMESSAGE=mess(58,10709,1) : # Période non ouverte à la saisie
   #mkstat     =2
   ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(58,10709,1),[V]CST_AERROR)
   Break 2
   #Break
 Endif

#JIRA_18702
# # Interdire la demande d'annulation si l'arrêté des temps a déjà été fait sur la paie ou si paie suivante faite
# Filter [VEP] Where EMP=[M:DCG1]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
#&                 & ((STRDAT<=[M:DCG1]ENDDAT(nolign-1) & ENDDAT>=[M:DCG1]STRDAT(nolign-1)) | STRDAT>[M:DCG1]ENDDAT(nolign-1))
# Read [VEP]VEP0 First
# If !fstat
#  GMESSAGE = mess(20,10702,1)-num$([F:VEP]PYRDAT) : # Paye existante au
#  mkstat = 2 : Break
# Endif
  # Interdire la demande d'annulation si l'arrêté des temps a déjà été fait sur la paie ou si paie suivante faite

  Read [F:TIM]TIM0 = this.TCH_LEG;this.TIM
  If fstat = [V]CST_AOK  #!fstat
    If [F:TIM]MONDAC=1
#       Filter [VEP] Where EMP=this.REFNUM & CTRNUM=this.CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
#&                 & ((STRDAT>=[F:PEO]PERSTR(0) & ENDDAT<=[F:PEO]PEREND(0)) | STRDAT>[F:PEO]PEREND(0))
#    Else
#       Filter [VEP] Where EMP=this.REFNUM & CTRNUM=[F:HRCTR]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
#&                 & ((STRDAT>=[F:PEO]PERSTR(1) & ENDDAT<=[F:PEO]PEREND(1)) | STRDAT>[F:PEO]PEREND(1))
      Filter [VEP] Where EMP=this.REFNUM & CTRNUM=[F:HRCTR3]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
&                 & ((STRDAT>=[F:HRPEOD]PERSTR(0) & ENDDAT<=[F:HRPEOD]PEREND(0)) | STRDAT>[F:HRPEOD]PEREND(0))
    Else
      Filter [VEP] Where EMP=this.REFNUM & CTRNUM=[F:HRCTR3]CTRNUM & (GTPS=0 | FLGGEN=2 | FLGSYN=2 | FLGVRA=2 | FLGANA=2 | PST>1)
&                 & ((STRDAT>=[F:HRPEOD]PERSTR(1) & ENDDAT<=[F:HRPEOD]PEREND(1)) | STRDAT>[F:HRPEOD]PEREND(1))
    Endif
    Read [VEP]VEP0 First
    If fstat = [V]CST_AOK   #!fstat
      #GMESSAGE = mess(20,10702,1)-num$([F:VEP]PYRDAT) : # Paye existante au
      #mkstat = 2 : Break
      ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(20,10702,1)-num$([F:VEP]PYRDAT),[V]CST_AERROR)
      Break
    Endif
  Endif
Next
#Filter [PEO]
Filter [HRPEOD]   #V12
Filter [VEP]
# STCAH - 2017-08-07 - X3-50596 - upgrade for V12 - END

Return
