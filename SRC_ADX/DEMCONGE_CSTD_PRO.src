$DEMCONGEESS_TCH_EMPSBD_CONTROL


Return

$DEMCONGEESS_TCH_EMPSBD_PROPAGATE

If this.CHEF = AVOID.ACHAR
  this.CHEF   = this.REFNUM
Endif

this.REFNUM = this.TCH_EMPSBD


#Setting the technical properties
#Subordinate
#Only used to verify and not actual record read
Local File EMPSBD [ESB1]
Filter [F:ESB1] Where CHEF = this.CHEF and REFNUM = this.TCH_EMPSBD
Read [ESB1] First
If !fstat
  this.TCH_SBDCTR     = [F:ESB1]CTRNUM
  this.TCH_SBDDAT     = [F:ESB1]CTRDAT
  this.TCH_SBDCHEF    = this.CHEF
  this.TCH_SBDNIV     = [F:ESB1]NIVEAU
  this.TCH_SBDRANG    = [F:ESB1]RANG
Endif
Filter [ESB1]
LogicClose File [ESB1]



Return
