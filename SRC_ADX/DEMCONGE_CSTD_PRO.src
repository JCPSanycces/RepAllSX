#---------------------------
#Subprog AS_TYPPGN(CDCG)
Subprog AS_TYPPGN(CDCG_TIM,CDCG_REFNUM,CDCG_STRDAT,CDCG_TYPPGN)
Value Char CDCG_TIM
Value Char CDCG_REFNUM
Value Date CDCG_STRDAT
Variable Libelle CDCG_TYPPGN

#Local Libelle TYPPGN

#60685
#Call NOPROLONG([M:DCG1]TIM(nolign-1),mkstat)
Local Integer OK
Call NOPROLONG(CDCG_TIM,OK)
#VALEUR = evalue("OK=0")
#mkstat=OK                              #???? add to representation to disable field
# add ASTATUS ????
If OK=1 : End : Endif

If CDCG_TYPPGN : End : Else : CDCG_TYPPGN=1 : Endif

#56914
#Si un congé patho prénatal PATHM est suivi d'un congés maternité, la maternité doit être typé 'prolongation'
Local Integer SOA_NOLIGN   # we are dealing with one line at a time and not in a grid
If CDCG_TIM = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","MATERNITE") #func AFNC.PARAM("MATERNITE","")
 If SOA_NOLIGN>1 # won't get here in SOA
  #If ([M]TIM(nolign-2)=[M]TIM(nolign-1) | [M]TIM(nolign-2)=func AFNC.PARAM("PATHPREN","")) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   #VALEUR=2 : Else : VALEUR=1
  #Endif
 Else
  Call INIT_TYPPNG(CDCG_TYPPGN,CDCG_TIM,func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","PATHPREN"),CDCG_REFNUM,CDCG_STRDAT) From TPSSTD_SOA
 Endif
#Si un congé patho postnatal PATHO est suivi d'un congés maladie, la maladie doit être typé 'prolongation'
Elsif CDCG_TIM = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","MALADIE")    #func AFNC.PARAM("MALADIE","")
 If SOA_NOLIGN>1  # won't get here in SOA
  #If ([M]TIM(nolign-2)=[M]TIM(nolign-1) | [M]TIM(nolign-2)=func AFNC.PARAM("PATHPOST","")) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   #VALEUR=2 : Else : VALEUR=1
  #Endif
 Else
  Call INIT_TYPPNG(CDCG_TYPPGN,CDCG_TIM,func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","PATHPOST"),CDCG_REFNUM,CDCG_STRDAT) From TPSSTD_SOA
 Endif
Elsif !OK :# Prologuation si 2 mêmes evt se suivent...
 If SOA_NOLIGN>1 # won't get here in SOA
  #If ([M]TIM(nolign-2)=[M]TIM(nolign-1)) & [M]ENDDAT(nolign-2)=[M]STRDAT(nolign-1)-1
   #VALEUR=2 : Else : VALEUR=1
  #Endif
 Else
  Call INIT_TYPPNG(CDCG_TYPPGN,CDCG_TIM,CDCG_TIM,CDCG_REFNUM,CDCG_STRDAT) From TPSSTD_SOA    #???? Check paramas - missing TYPPNG
 Endif
Endif

#CDCG_TYPPGN = TYPPGN

End
############################################################################################################
Subprog NOPROLONG(EVT,OK)
Value    Char    EVT ()
Variable Integer OK
OK = 0
#56914

If !find( EVT,func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","AT"),func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","ATTRAJET")
&       ,func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","MALADIE"),func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","MALPROF")
&       ,func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","MATERNITE"),func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","PATERNITE")
&       ,func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","PATHPREN"),func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,1,"","PATHPOST")
&       )
 OK=1
Endif

#If !find( EVT,func AFNC.PARAM("AT",""),func AFNC.PARAM("ATTRAJET","")
#&       , func AFNC.PARAM("MALADIE",""),func AFNC.PARAM("MALPROF","")
#&       , func AFNC.PARAM("MATERNITE",""),func AFNC.PARAM("PATERNITE","")
#&       ,func AFNC.PARAM("PATHPREN",""),func AFNC.PARAM("PATHPOST","")
#&       )
 #OK=1
#Endif
End
