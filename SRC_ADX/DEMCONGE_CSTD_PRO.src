#STCAH - 2017-04-26 - REQUIREMENT nnn - US nnn
#Handling all properties for DEMCONGE_CSTD
#
# STCAH - 2017-08-07 - X3-50596 - upgrade for V12
############################################################################################################
$PROPERTIES
#Handling all the property code in  DEMCONGEESS_CSTD_PRO

Case [L]CURPRO
  When "REFNUM"                     : Gosub DEMCONGEESS_REFNUM
  When "TCH_EMPSBD"                 : Gosub DEMCONGEESS_TCH_EMPSBD
  When "STRDAT"                     : Gosub DEMCONGEESS_STRDAT      # starting date
  When "STRDAY"                     : Gosub DEMCONGEESS_STRDAY      # morning
  When "ENDDAT"                     : Gosub DEMCONGEESS_ENDDAT      # ending date
  When "ENDDAY"                     : Gosub DEMCONGEESS_ENDDAY      # afternoon
  When "CTRNUM"                     : Gosub DEMCONGEESS_CTRNUM
  When "CTRDAT"                     : Gosub DEMCONGEESS_CTRDAT
  When "NBRDAY"                     : Gosub DEMCONGEESS_NBRDAY
  When "NBRHOU"                     : Gosub DEMCONGEESS_NBRHOU
  When "TIM"                        : Gosub DEMCONGEESS_TIM
  When "CMT"                        : Gosub DEMCONGEESS_CMT
  When "RPL"                        : Gosub DEMCONGEESS_RPL
  When "TYPPGN"                     : Gosub DEMCONGEESS_TYPPGN
  When "STA"                        : Gosub DEMCONGEESS_STA
  When "WRK"                        : Gosub DEMCONGEESS_WRK
  When "CMT2"                       : Gosub DEMCONGEESS_CMT2
  When "ESSATT.TCH_ATT"             : Gosub DEMCONGEESS_ESSATT_TCHATT
  When "LVERSN"                     : Gosub DEMCONGEESS_LVERSN #FRLAA 2018-02-27 X3-74480
  When "LVENOT"                     : Gosub DEMCONGEESS_LVENOT #FRLAA 2018-02-27 X3-74480
  When "UID"                        : Gosub DEMCONGEESS_UID
  When "DEM"                        : Gosub DEMCONGEESS_DEM
Endcase



Return
############################################################################################################
$DEMCONGEESS_ESSATT_TCHATT
Case [L]ARULE
  When "CONTROL"
    Gosub DEMCONGEESS_ESSATT_TCHATT_CONTROL
Endcase
Return
#------------------------------
$DEMCONGEESS_ESSATT_TCHATT_CONTROL

Return
############################################################################################################
$DEMCONGEESS_REFNUM
Case [L]ARULE
  When "INIT"
    Gosub DEMCONGEESS_REFNUM_INIT
  When "CONTROL"
    Gosub DEMCONGEESS_REFNUM_CONTROL
  When "PROPAGATE"
    Gosub DEMCONGEESS_REFNUM_PROPAGATE
Endcase
Return
#---------------------------
$DEMCONGEESS_REFNUM_INIT

#Gosub DATE_RANGE_SETUP  # temporary until we decide how to cater for the date range
If this.REFNUM = AVOID.ACHAR
  this.REFNUM = fmet this.ACTX.ACACHE.USRESS.AGETVALCHAR(this.ACTX.USER,"REFNUM")
Endif

Return
#---------------------------
$DEMCONGEESS_REFNUM_CONTROL

If this.TCH_EMPSBD = AVOID.ACHAR       # not in manager representation
  Local Char THIS_REFNUM(GLONEML)
  THIS_REFNUM = fmet this.ACTX.ACACHE.USRESS.AGETVALCHAR(this.ACTX.USER,"REFNUM")
  If this.REFNUM <> THIS_REFNUM
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(174,10720,1)-THIS_REFNUM,[V]CST_AERROR)  #added to LM10720
    Return
  Endif
Endif

# FQ106640 - 27/02/15 - si multi-contrats, le contrat le plus récent n'est pas forcément celui en cours
Local    Integer FOUNDCTR : FOUNDCTR=0
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
#Filter [HRCTR] Where REFNUM=VALEUR & (CTRDAT<=[M:DCG1]DATFIN | (FLGRET=2 & RETDATEFF<=[M:DCG1]DATFIN))

#Gosub DATE_RANGE_SETUP  # temporary until we decide how to cater for the date range

Local File EMPLOID  [ID]
Read [F:ID]ID0 = this.REFNUM
If fstat <> [V]CST_AOK
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(175,10720,1)-this.REFNUM,[V]CST_AERROR)   #added to LM 10720
  LogicClose File [ID]
  Return
Endif

# SOA - code below does not make sense until we have a leave start and end date
# SOA - code changed to use actual leave start and end dates
If this.ENDDAT <> AVOID.ADATE & this.STRDAT <> AVOID.ADATE  # new for SOA
  Local File EMPLOCTR [HRCTR2]
  #Filter [HRCTR] Where REFNUM=this.REFNUM & (CTRDAT<=this.TCH_DATFIN | (FLGRET=2 & RETDATEFF<=this.TCH_DATFIN)) Order By CTRDAT Desc
  Filter [HRCTR2] Where REFNUM=this.REFNUM & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT)) Order By CTRDAT Desc
  If [F:ID]FLGMULCTR<>2 Then
  #  Read [HRCTR]CTR1 Last
    Read [HRCTR2] First
  Else
    For [HRCTR2]
      If [HRCTR2]XITDAT<>[0/0/0] & [HRCTR2]XITDAT<this.STRDAT Then
      Else
        FOUNDCTR=1
        Break
      Endif
    Next
    If !FOUNDCTR Then Read [HRCTR2] First : Endif
  Endif
  Filter [HRCTR2]
  If fstat <> [V]CST_AOK |( [HRCTR2]XITDAT<>[0/0/0] & [HRCTR2]XITDAT < this.STRDAT)
   #Employé non présent sur la période
    #GMESSAGE=mess(9,10709,1)
    #mkstat=2 : End
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(9,10709,1),[V]CST_AERROR)
    LogicClose File [ID]
    LogicClose File [HRCTR2]
    Return
  Endif

  # cannot see in SUBDCG how this will get here as the code exists after the first error
  If ASTATUS = [V]CST_AERROR
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(46,10702,1)-"-"-mess(9,10709,1),[V]CST_AERROR) : #Sélection salarié
  Endif
  LogicClose File [HRCTR2]
Endif  # new for SOA
LogicClose File [ID]

Return
#---------------------------
$DEMCONGEESS_REFNUM_PROPAGATE
Local File EMPLOID    [ID]
Local File EMPLOCTR   [HRCTR2] #FRLAA 2018-03-02 X3-74480

Read [F:ID]ID0 = this.REFNUM
If fstat = [V]CST_AOK
  #this.TCH_NAMSRN   = [F:ID]NAM-[F:ID]SRN
  this.TCH_FLGMLCTR = string$([F:ID]FLGMULCTR<>2,"-")+"KM:"+num$(GLONHRCTR)+"X"
  this.TCH_FCY      = [F:ID]FCY
  this.TCH_SRV      = [F:ID]SRV
  # Could disable contract using the code below if we want the system to get auto get the contract number
  #  If [F:ID]FLGMULCTR = 2
  #    ASTATUS = fmet this.ASETATTRIBUTE("CTRNUM","$isDisabled","false")
  #  Else
  #    ASTATUS = fmet this.ASETATTRIBUTE("CTRNUM","$isDisabled","true")
  #  Endif
  # STCAH - 2017-08-07 - X3-50596 - START
  Local Char VREFNUM(GLONEML) : VREFNUM = this.REFNUM
  Local Integer VLEGLVL       : VLEGLVL = 1
  this.TCH_LEG  = func DIVPAYE_SOA.GET_LEG_EMP(VREFNUM,VLEGLVL)
  # STCAH - 2017-08-07 - X3-50596 - END
Endif

#FRLAA 2018-03-02 X3-74480 - START

If func AFNC.ACTIV("GLM")
  Filter [F:HRCTR2] Where REFNUM = this.REFNUM and XITDAT = [0/0/0]
  If rowcount([HRCTR2]) = 1 Then
    Read [F:HRCTR2] First
    #Set values
    this.DATPYR = func DEMCONGE_CSTD_PRO.SET_DATPYR([F:HRCTR2]CTRNUM)
    #ASTATUS=fmet this.ASETERROR([L]CURPRO,num$(this.DATPYR),[V]CST_AINFO)
    this.DATLVE = func DEMCONGE_CSTD_PRO.SET_DATLVE([F:HRCTR2]CTRNUM)
  Endif
  Filter [F:HRCTR2]
Endif

LogicClose File [ID]
Return


#FRLAA 2018-03-02 X3-74480 - START
Funprog SET_DATPYR(VCTRNUM)
Value Char VCTRNUM
Local Date VDATPYR
Local File VALEMP [VEP2]

Filter [F:VEP2] Where [F:VEP2]CTRNUM = VCTRNUM Order By [F:VEP2]PYRDAT
Read [F:VEP2] Last
Filter [F:VEP2]
If fstat = [V]CST_AOK
    VDATPYR = [F:VEP2]ENDDAT
Endif
End VDATPYR

Funprog SET_DATLVE(VCTRNUM)
Value Char VCTRNUM
Local Date VLVEACCDAT
Local File HRLVEACCRU [ACCRU2]

Filter [F:ACCRU2] Where CTR = VCTRNUM and LVEACCAMT <> "0" Order By [F:ACCRU2]LVEACCDAT
Read [F:ACCRU2] Last
Filter [F:ACCRU2]
If fstat = [V]CST_AOK
  VLVEACCDAT = [F:ACCRU2]LVEACCDAT
Endif
End VLVEACCDAT
#FRLAA 2018-03-02 X3-74480 - END

