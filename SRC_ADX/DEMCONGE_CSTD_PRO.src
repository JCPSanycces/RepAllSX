If ASTATUS = [V]CST_AERROR
  Return
Endif

#Gosub DATE_RANGE_SETUP  # temporary until we decide how to cater for the date range
#SOA - code below not required as there is no longer a technical date range
#If !SOA_GWEBSERV & (this.ENDDAT<this.TCH_DATDEB | this.ENDDAT>this.TCH_DATFIN) #???? technical dates TODO/discuss
# ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(1,10709,1),[V]CST_AERROR)
# #[V]GMESSAGE=mess(1,10709,1) : # Date en dehors de la période
# #mkstat     =2
# Return
#Endif

####
Local File EMPLOCTR [HRCTR3]
#Local File PERIOD   [PEO]    #V12

#STCAH
If clalev([HRPEOD]) = 0 : Local File HRPEODET [HRPEOD]  : Endif   #V12
If clalev([FCY])    = 0 : Local File FACILITY [FCY]     : Endif   #V12

#MIPEA - 2017-01-20 - X3-12089- START
Link [HRCTR3]
&   With [FCY]FCY0=ETRFCY
&   As [LNK]
&   Where REFNUM=this.REFNUM & find(this.CTRNUM,"",CTRNUM)
&       & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&       & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT)
&       & [FCY]LEG=this.TCH_LEG
&       Order By Key CLE=REFNUM; CTRNUM; CTRDAT Desc
#MIPEA - 2017-01-20 - X3-12089- END
#STCAH

## On contrôle que chaque chrono contrat a des fiches contrats successives sur la période d'absence
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat

# For [HRCTR]CTR0(2) Where REFNUM=this.REFNUM & find(this.CTRNUM,"",CTRNUM)  # V12  - changes per MIPEA on SUBDCG
For [LNK]CLE(2) Where REFNUM=this.REFNUM & find(this.CTRNUM,"",CTRNUM)
&                 & (CTRDAT<=this.ENDDAT | (FLGRET=2 & RETDATEFF<=this.ENDDAT))
&                 & (XITDAT=[0/0/0]  | XITDAT>=this.STRDAT)
 [L]DAT  = this.STRDAT
 [L]DAT3 = this.STRDAT : #62192

 #For [HRCTR]CTR0 # V12 - changes per MIPEA on SUBDCG
 For [LNK]CLE
  #62192
  #If [F:HRCTR]CTRDAT>[L]DAT
  # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
  If ([F:HRCTR3]CTRDAT>[L]DAT & ([F:HRCTR3]FLGRET<>2 | [F:HRCTR3]RETDATEFF>[L]DAT)) & TROUVE=0
    SOA_GMESSAGE=func ASYRFNC.MES2( mess(171,10709,1),format$(SOA_GFMD,[L]DAT), format$(SOA_GFMD,[F:HRCTR3]CTRDAT-1))
    ASTATUS=fmet this.ASETERROR([L]CURPRO,SOA_GMESSAGE,[V]CST_AERROR)
   #           Pas de contrat de travail pour la période du $1$ au $2$
   #mkstat     =2
   Break 2
  Elsif [F:HRCTR3]XITDAT=[0/0/0] | [F:HRCTR3]XITDAT>=this.ENDDAT
   [L]DAT  = this.ENDDAT
   [L]DAT3 = this.ENDDAT  : #62192
  Else
   [L]DAT3 = max([L]DAT,[F:HRCTR3]XITDAT) : #62192
   [L]DAT  = max([L]DAT,[F:HRCTR3]XITDAT)+1
  Endif

  # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
  DATDEBCTR=[F:HRCTR3]CTRDAT
  If [F:HRCTR3]FLGRET=2 & [F:HRCTR3]RETDATEFF<>[0/0/0] Then
   DATDEBCTR=[F:HRCTR3]RETDATEFF
  Endif
  [L]DAT2 = max(this.STRDAT,DATDEBCTR)
  #Filter [PEO] Where PERSTR(0)  <=this.ENDDAT & PEREND(1)>=this.STRDAT    #V12
#&                  & find(FCY,"",[F:HRCTR]ETRFCY)<>0
#&       Order By Key CLE=PYRDAT;FCY Desc
  Filter [HRPEOD] Where PERSTR(0)  <=this.ENDDAT & PEREND(1)>=this.STRDAT
&                  & find(PERCOD,"",[F:HRCTR3]PERCOD)<>0
&       Order By Key CLE=PYRDAT;PERCOD Desc
  #For [PEO]CLE(1)    #V12
  For [HRPEOD]CLE(1)
   #If ([F:PEO]STA<>2 & SOA_GTPS) | [F:PEO]PERSTR(0)>[L]DAT2   #V12
   If ([F:HRPEOD]STA<>2 & SOA_GTPS) | [F:HRPEOD]PERSTR(0)>[L]DAT2
    #[V]GMESSAGE=mess(58,10709,1) : # Période non ouverte à la saisie
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(58,10709,1),[V]CST_AERROR)
    #mkstat     =2
    Break 3
   Elsif [F:HRPEOD]PEREND(0)>=this.ENDDAT     #V12
    [L]DAT2=this.ENDDAT
    Break
   Else
    [L]DAT2=[F:HRPEOD]PEREND(0)+1             #V12
   Endif
   # On autorise la saisie sur période de paie calculée
  Next


  If [L]DAT2<this.ENDDAT or rowcount([F:HRPEOD]) = 0
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(10,11691,1),[V]CST_AERROR)
    Break 2
  Endif
  #62192
  TROUVE = 1
 Next
Next
#Filter [PEO]
Filter [F:HRPEOD]     #V12
#71976
#If clalev([F:VEP]) : Filter [VEP] : Endif  # ???? why close filter here

If ASTATUS >= [V]CST_AERROR
 Gosub CLEANUP_ENDDAT
 Return
Elsif [L]DAT3<this.ENDDAT : #62192 : [L]DAT remplacé par [L]DAT3
 If [L]DAT3=[0/0/0] : [L]DAT3=this.STRDAT : Endif : #62192 : [L]DAT remplacé par [L]DAT3
 #SOA_GMESSAGE=func AFNC.MES2( mess(171,10709,1),format$([V]GFMD,[L]DAT3), format$([V]GFMD,[L]VALEUR))
 SOA_GMESSAGE=func ASYRFNC.MES2( mess(171,10709,1),format$(SOA_GFMD,[L]DAT3), format$(SOA_GFMD,this.ENDDAT))
 ASTATUS=fmet this.ASETERROR([L]CURPRO,SOA_GMESSAGE,[V]CST_AERROR)
 #           Pas de contrat de travail pour la période du $1$ au $2$
 #mkstat     =2
 Gosub CLEANUP_ENDDAT
 Return
Endif



Return
#---------------------------
$CLEANUP_ENDDAT

LogicClose File [HRCTR3]
#LogicClose File [PEO]
LogicClose File [FCY]
LogicClose File [HRPEOD]

Return
