Local Integer SOA_GWEBSERV : Call GWEBSERV(SOA_GWEBSERV) From ESSGLOB_SOA
Local Date SOA_GMOIPAY     : Call GMOIPAY(this.TCH_FCY,SOA_GMOIPAY) From ESSGLOB_SOA

#Gosub DATE_RANGE_SETUP  # temporary until we decide how to cater for the date range

# SOA - validation below is not applicable - not using other dates
#If !SOA_GWEBSERV & (this.STRDAT<this.TCH_DATDEB | this.STRDAT>this.TCH_DATFIN)
# ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(1,10709,1),[V]CST_AERROR)
# #[V]GMESSAGE=mess(1,10709,1) : # Date en dehors de la période
# #mkstat     =2
# Return
#Endif

Local File EMPLOCTR [HRCTR2]
Local Date DAT2
If this.ENDDAT=[0/0/0]
 DAT2 = this.STRDAT
Else
 DAT2 = this.ENDDAT
Endif
Filter [HRCTR2] Order By Key CLE=ETRFCY
# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
For [HRCTR2]CLE(1) Where REFNUM=this.REFNUM & (CTRDAT<=DAT2 | (FLGRET=2 & RETDATEFF<=DAT2))
&                   & (XITDAT=[0/0/0] | XITDAT>=this.STRDAT)
&                   & find(this.CTRNUM,"",CTRNUM)<>0   # this.CTRNUM can be "" or = [F:HRCTR]CTRNUM
# 28/03/01 - Bug 72654
# - Pouvoir saisir quand on n'a pas GPAYE et GTPS
##71976 : GMOIPAY is now in 'Common module'
 Local Date DAT3
 DAT3 = SOA_GMOIPAY-val(func ADP_TOOL.GET_PARAM(GACTX.AFOLDER,3,[F:HRCTR2]ETRFCY,"DCGJOUANT"))
 If this.STRDAT<DAT3
  # La saisie ne peut s'effectuer à une date antèrieure au
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(13,10715,1)-num$(DAT3),[V]CST_AERROR)
  #mkstat     =2
  Break
 Endif
Next
Filter [HRCTR2]
LogicClose File [HRCTR2]

Gosub CHECK_SUBORDINATE

Return
