#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################
#
# Fixed Assets migration process to V8
#
# --> Change ATBDIV 611 (family) in an object FAM
# --> Initialize flag FLGDETEXP in table LAYOUTFAS
# --> Change types BCP to CPY and BFC to FCY in table LISTED
#
#  CBO   13.04.2016  115826   Change other types in ATABDIV
#  MDJ   22.03.2016  115487   The field  BACFLG does not exist anymore in the FASFAM table (>=U9)
#  GLE   02.06.2015  FQ108289 Archive folder management
#  GLE   27.02.2015  FQ106483 Change types in table LISTED
#  CBO   28.11.2014  FQ104360 Undo a linked expense when balance sht val is changed
#
#############################################################

Subprog AFASMAJ50

  Call ECR_TRACE("Start AFASMAJ50 on" - [F:ADS]DOSSIER, 0) From GESECRAN

  If !(func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)) : # FQ108289
    # Not to perform in an archive folder (settings data)
    # Change ATBDIV 611 (family) in an object FAM
    Gosub AMAJ_FAM_611

    # Not to perform in an archive folder (technical data, useless in for archived expenses)
    # Initialize flag FLGDETEXP
    Gosub AMAJ_LAYOUTFAS # FQ104360

    # Not to perform in an archive folder (supervisor metadata)
    # Change types BCP to CPY and BFC to FCY in LISTED table
    Gosub AMAJ_ALISTED # FQ106483

    # Not to perform in an archive folder (supervisor metadata)
    # Change other types in LISTED table FQ115826
    Gosub AMAJ_ALISTEDB # FQ115826
  Endif

  Call ECR_TRACE("End AFASMAJ50 on" - [F:ADS]DOSSIER, 0) From GESECRAN

End

################################################################

########################################
#
# change ATBDIV 611 (family) in an object FAM
#
########################################

$AMAJ_FAM_611


  Call ECR_TRACE("Change ATBDIV 611 (family) in an object FAM", 0) From GESECRAN

  Local Integer N_FAM_DEPART, N_FAM_CRT, N_FAM_EXIST

  If clalev([F:ADI])  : Close File  [ADI]  : Endif
  Local File =[F:ADS]DOSSIER + ".ATABDIV" [ADI]

  If clalev([F:ADV])  : Close File  [ADV]  : Endif
  Local File =[F:ADS]DOSSIER + ".ATABTAB" [ADV]

  If clalev([F:AXX2]) : Close File  [AXX2] : Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX2]

  If clalev([F:AXX3]) : Close File  [AXX3] : Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX3]

  If clalev([F:FAM])  :  Close File  [FAM] : Endif
  Local File =[F:ADS]DOSSIER + ".FASFAM" [FAM]


  GOK = 1
  Raz N_FAM_CRT, N_FAM_DEPART, N_FAM_EXIST
  Onerrgo ERR_FAM611


  Trbegin [ADI]
  For [F:ADI]CODE Where NUMTAB = 611

    N_FAM_DEPART += 1
    [F:FAM]FAMREF = [F:ADI]CODE
    [F:FAM]GFY    = [F:ADI]SOC
    # Issue 115487 -  [F:FAM]BACFLG = [F:ADI]N1

    If GLEGACT = G_OUI
      [F:FAM]LEG = [F:ADI]LEG
    Else
      [F:FAM]LEG = GDOSLEG
    Endif

    For [F:AXX2]AXX0 Where CODFIC = "ATABDIV" and (ZONE = "LNGDES" or ZONE = "SHODES") and IDENT1 = num$(611) and IDENT2 = [F:ADI]CODE
      [F:AXX3] = [F:AXX2]
      [F:AXX3]CODFIC = "FASFAM"
      If [F:AXX2]ZONE = "LNGDES"
        [F:AXX3]ZONE   = "FAMDES"
      Else
        [F:AXX3]ZONE   = "SHODES"
      Endif
      [F:AXX3]LANGUE = [F:AXX2]LANGUE
      [F:AXX3]LANORI = [F:AXX2]LANORI
      [F:AXX3]IDENT1 = [F:FAM]FAMREF
      [F:AXX3]IDENT2 = ""
      [F:AXX3]TEXTE = [F:AXX2]TEXTE

      Write [F:AXX3]
    Next

    Write [F:FAM]
    If fstat = 3  # already exists
      N_FAM_EXIST += 1
    Elsif fstat
      GOK = 0
      Call ECR_TRACE("Error writing [FASFAM] <" + [F:FAM]FAMREF + "> fstat=" + num$(fstat), 1) From GESECRAN
      Break
    Else
      N_FAM_CRT += 1
    Endif
  Next

  If GOK
    Delete [F:AXX2] Where CODFIC="ATABDIV" and IDENT1=num$(611)
    Delete [F:ADI]  Where NUMTAB=611
    Delete [F:ADV]  Where NUMTAB=611
  Endif


  If GOK
    Commit
  Else
    Rollback
  Endif

  #Infbox num$(N_FAM_DEPART) - "families (611) and" - num$(N_FAM_CRT) - "created +" - num$(N_FAM_EXIST) - "exist in FASFAM"
  Onerrgo

  Call ECR_TRACE("From" - num$(N_FAM_DEPART) - "families in 611 ATABDIV", 0) From GESECRAN
  Call ECR_TRACE(num$(N_FAM_CRT) - "accounting groups created in FASFAM", 0) From GESECRAN
  Call ECR_TRACE(num$(N_FAM_EXIST) - "accounting groups already exist in FASFAM", 0) From GESECRAN


  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of Change ATBDIV 611 (family) in an object FAM", 0) From GESECRAN

Return

$ERR_FAM611
  GOK = 0
Resume
################################################################

$AMAJ_LAYOUTFAS

    Call ECR_TRACE("# Initialize FLGDETEXP in LAYOUTFAS table", 0) From GESECRAN

    If clalev([F:LOF])
        Close File  [LOF]
    Endif
    Local File =[F:ADS]DOSSIER + ".LAYOUTFAS" [LOF]

    GOK = 1
    Onerrgo ERR_LAYOUTFAS

    Trbegin [LOF]
    Update [LOF] Where FLGDETEXP = 0 With FLGDETEXP = 2

    If GOK
        Commit
    Else
        Rollback
    Endif
    Onerrgo

    Call ECR_TRACE(num$(adxuprec) - "updated enreg. in LAYOUTFAS", 0) From GESECRAN

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("End of change in LAYOUTFAS table", 0) From GESECRAN

Return

$ERR_LAYOUTFAS
    GOK = 0
Resume
################################################################
# Change types BCP to CPY and BFC to FCY in LISTED table
$AMAJ_ALISTED
    Local Integer NBUPDREC : NBUPDREC = 0

    Call ECR_TRACE("# Change types BCP to CPY and BFC to FCY in ALISTED table", 0) From GESECRAN

    If clalev([F:ALD])
        Close File  [ALD]
    Endif
    Local File =[F:ADS]DOSSIER + ".ALISTED" [ALD]

    GOK = 1
    Onerrgo ERR_ALISTED

    Trbegin [ALD]

    Update [ALD] Where CODTYP = "BCP" With CODTYP = "CPY"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "BFC" With CODTYP = "FCY"
    NBUPDREC += adxuprec

    If GOK
        Commit
    Else
        Rollback
    Endif
    Onerrgo

    Call ECR_TRACE(num$(NBUPDREC) - "updated enreg. in ALISTED", 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("End of first change in ALISTED table", 0) From GESECRAN

Return

$ERR_ALISTED
    GOK = 0
Resume

################################################################
# Issue 115826
# Change other types in LISTED table
$AMAJ_ALISTEDB
    Local Integer NBUPDREC : NBUPDREC = 0

    Call ECR_TRACE("# Change types BCD, BCU, BGA, BUO, DBI, MDZ, RA2, SRL", 0) From GESECRAN
    Call ECR_TRACE("#           to CCE, CUR, GAC, UOM, DCO, MD1, RAT, SER in ALISTED table", 0) From GESECRAN

    If clalev([F:ALD])
        Close File  [ALD]
    Endif
    Local File =[F:ADS]DOSSIER + ".ALISTED" [ALD]

    GOK = 1
    Onerrgo ERR_ALISTED

    Trbegin [ALD]

    Update [ALD] Where CODTYP = "BCD" With CODTYP = "CCE"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "BCU" With CODTYP = "CUR"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "BGA" With CODTYP = "GAC"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "BUO" With CODTYP = "UOM"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "DBI" With CODTYP = "DCO"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "MDZ" With CODTYP = "MD1"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "RA2" With CODTYP = "RAT"
    NBUPDREC += adxuprec

    Update [ALD] Where CODTYP = "SRL" With CODTYP = "SER"
    NBUPDREC += adxuprec

    If GOK
        Commit
    Else
        Rollback
    Endif
    Onerrgo

    Call ECR_TRACE(num$(NBUPDREC) - "updated enreg. in ALISTED", 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("End of second change in ALISTED table", 0) From GESECRAN

Return
# Issue 115826

