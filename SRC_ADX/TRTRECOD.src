#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
##         Source : TRTRECOD                                                                       ##
##         Auteur : JDE                                                                            ##
##         Date création : 17/11/04                                                                ##
##         Traitement de recodification                                                           ##
####################################################################################################
##  MDJ  04/05/2015  FQ107562  : Recodification des familles (table FASFAM au lieu de TDIV 611)
##  MDJ  01/04/2015  FQ107422  : Remplacement PHYREF1 (inexistant) par PHYDES1
##  MDJ  04/03/2015  FQ106258  : Aménagement trace suite FQ105388
##  MDJ  09/02/2015 (FQ100398) : Suppression site géographique
##  MDJ  04/02/2015 (FQ105388) : Champs "Localisation" dimensionnés avec GLONBCL + longueur variables Char=255 par défaut
##  MDJ  29/01/2015 (FQ105829) : Data type "BCD" has been changed in "CCE" since the release AKIRA
##  GLE  28/11/2013 (FQ 94836) : Chargement du masque [M:FPC] pour la recodification des axes analytiques
##  MDJ  29/05/2013 (FQ 90165) : Correction dépendante de la réactivation de la possibilité de créer des sections
##  MDJ  28/03/2013 (FQ 88543) : Erreur Selection ADI : création enreg. erronés dans ATEXTRA
##  MDJ  20/02/2013 (FQ 87418) : Contrôle liens groupe de société/sites et sections analytiques
##  MDJ  01/10/2012 (FQ 84345) : Offset>0*8000 :too many values : modif instruction find
##  MDJ  17/08/2012 (FQ 83418) : Alerte et blocage recodif en CIG
##  MDJ  22/06/2012 (FQ 83112) : Erreur s/ masque [M:RC0] inexistant                              ##
##  MDJ  22.12.2010 (Fq 70141) : Vérification de sources (interne)
##  MDJ  07/12/2010 (FQ 69756) : contrôle sur date clôture, modifié si CIG  + supp msg "Code déjà existant)
##  MDJ  03/11/2010 (FQ 68840) : Statut recodification ne passait pas à "Traité" quand CIG        ##
##  MDJ  20/08/2010 (FQ-66813) : var. GLONFCY utilisée pour dimensionner le tableau des sites    ##                                                    ##
##  MDJ  03/08/2010 (FQ-42964) : Recodifications Zones libres sans effet si pas de valeurs par société
##  MDJ  03/08/2010 (FQ-52344) : Recodifications tables CCE
##  MDJ  27/10/2009 : variable GTRC_CRERREUR (13 car.) inexistante ==> GTRC_CRERREU (12 car.)
####################################################################################################
##------------------------------------------------------------------------------------------------##
##  La fonction de recodification est appelé par :                                                ##
##       - Le trt SUBREC de paramétrage de la recodification       ([F:CDF]PROSTA = GVML_RECATR)  ##
##       - Le trt SUBCII de cession intra-groupe (CIG)             ([F:CDF]PROSTA = GVML_RECATRC) ##
##  qui lui passe , la référence de recodification , la société à traiter (si cession intra-groupe##
##  et l'indicateur de simulation                                                                 ##
##------------------------------------------------------------------------------------------------##
## Déroulement du traitement                                                                      ##
##  Subprog TRT_RECODIF           : demande de recodification d'une référence de recodification   ##
##    1) Définition ds variables du traitement                                                    ##
##    2  Lecture des enregistrements de paramétrage (CDFPAR,.....)                                ##
##    3) EDIT_DEB_COMPTERENDU                                                                     ##
##    4) STOCKAGE_SITES_SEL (stockage des sites financiers sélectionnés)                          ##
##       STOCKAGE_SOC_SEL   (stockage des sociétés sélectionnées)                                 ##
##       STOCKAGE_OBJ_TRT   (stockage d'un tableau des objets                                     ##
##       LOCK_ALL           (Test si les sociétés a traiter sont lockées pour les objets traités  ##
##    5) TRAIT_MAJ_EDIT_TABLE (maj des codes dans la table traité                                 ##
##                             + stockage en mémoire de valeurs (avant et après ) à traiter       ##
##                             + Val avant et après dans CR                                       ##
##    6) PHASE_PREPARATION                                                                        ##
##       6-A)  Stockage en mémoire d'un indicateur pour chaque objet à traiter                    ##
##       6-B)  RECH_RUB_OBC : Stockage rubriques concernées par recodification pour chaque objet  ##
##    7) PHASE_TRAITEMENT_SUP    (si ancien code = supprimé)                                      ##
##       - Boucle sur les objets a traiter                                                        ##
##          7-A) TRT_SUP_UN_OBJ                                                                   ##
##           7-A-1) ALIM_NEWCOD_DS_ENREGISTREMENT                                                 ##
##           7-A-2) Rewrite de l'enr maitre modifié (si pas simu)                                 ##
##    8) PHASE_TRAITEMENT_INACON (si ancien code = inactif ou conservé)                           ##
##       8-A) -Si pas CIG : ALIM_WCWHERE_OBC (Suivant l'objet, sélec de certains types d'enregs)  ##
##            -Si pas CIG : ALIM_WCWHERE_LIAISON_FAS (pour recherche des FAS lié à l'objet MAITRE)##
##            -Si CIG     : Sélection des enregistrements de la société transmise                 ##
##       8-B) Lecture des enreg. objet maître correspondants à la sélection des sites paramétrés  ##
##       8-C) RECODIF_ENR_OBJET_MAITRE                                                            ##
##         8-C-1) ALIM_NEWCOD_DS_ENREGISTREMENT                                                   ##
##         8-C-2) ALIM_NEWFCYFI_SI_FCY  (uniquement si cession intra-groupe)                      ##
##         8-C-5) Rewrite de l'enr maitre modifié (si pas simu)                                   ##
##         8-C-6) TRT_TOUS_AUTRES_OBC ( Boucle sur les objets AUTRE à traiter )                   ##
##             8-C-6-1) TRT_UN_AUTRE_OBC                                                          ##
##                - Boucle sur les FAS lié à l'objet MAITRE                                       ##
##                      - ALIM_WCWHERE_AUT(Suivant l'objet AUTRE, sélec. de certains types d'enr) ##
##                      - ALIM_WCWHERE_LIAISON_AUT (Lien entre l'enr FAS lu et l'objet AUTRE,     ##
##                      - BOUCLE sur les enregistrements de l'objet AUTRE correspondant           ##
##                        à l'enregistrement maitre traité                                         ##
##                           - RECODIF_ENR_OBJET_AUTRES                                           ##
##                              - ALIM_NEWCOD_DS_ENREGISTREMENT                                   ##
##                              - Alimentation du nouveau site financier s'il a changé            ##
##                                 - Rewrite de l'enr AUTRE modifié (si pas simu)                 ##
##    9) EDIT_FIN_COMPTERENDU                                                                     ##
##   10) TRT_MAJ_ASSOCIATION                                                                      ##
##   11) Si pas simulation : Rewrite du parametrage de recodification                             ##
##   12) UNLOCK_ALL                                                                               ##
##------------------------------------------------------------------------------------------------##

####################################################################################################
####################################################################################################
## PARTIE : TRAITEMENT DE RECODIFICATION                                                          ##
####################################################################################################

####################################################################################################
## Subprog TRT_RECODIF(PCREFCDF, PCSOCREC, PFLGSIM, PRETOUROK)                                    ##
####################################################################################################
Subprog TRT_RECODIF(PCREFCDF, PCSOCREC, PFLGSIM, PRETOUROK)
Value Char        PCREFCDF            : # Référence de recodification
Value Char        PCSOCREC            : # Nouvelle société (si cession intra-groupe)
Value Integer     PFLGSIM             : # Flag simulation
Variable Integer  PRETOUROK           : # Code retour

Global Char WCGTABCPT

Local  Char WCREFCDF
Local  Char WCDESI
Local  Char WCLIGFIXE1 (60)
Local  Char WCLIGFIXE2 (50)
Local  Char WC10BLANC  (10)
Local  Char WCTIRET
Local  Char WCOUINON
Local  Char WCDESIFIXE (150)
Local  Char WCTEXTEJAUGE(40)
Local  Char WCLIGNE (GTRC_LGLIGTR)
Local  Char WDDATENDACT
Local  Char WCTABNAM
Local  Char WCREFTRFCMP
Local  Char WCNOMPROG

Local  Integer WNBENRTRT
Local  Integer WNBREJET
Local  Integer WNBTOTAL
Local  Integer I
Local  Integer WINBTOT
Local  Integer WINBENCOURS
Local  Integer WINBMAJLDR
Local  Integer WINBMAJFAS
Local  Integer WINBMAJLEA
Local  Integer WINBMAJLOF
Local  Integer WINBMAJGRT
Local  Integer WINBMAJIVY
Local  Integer WINBMAJPHY
Local  Integer WISTAOLDCOD
Local  Integer WIFLGUPDASS
Local  Integer WIPROSTA
Local  Integer LOK
Local  Integer WIERRTITRE
Local  Integer WIALLOBJLOCK
Local  Integer WIUNOBJLOCK
Local  Integer WIOBCTRT      : # Code de l'objet traité
Local  Integer WIOBCLDR      : # Code de l'objet maitre
Global Integer WIMAXOBC

PRETOUROK    = G_OUI
TRA          = 1      : ## affichage trace et conservation
WCTIRET      = '------------------'
WC10BLANC    = "          "
WIVIDE       = 0
WNBENRTRT    = 0
WNBREJET     = 0
WINBTOT      = 0
WCNOMPROG    = 'TRTRECOD'
WCREFCDF     = ""
WINBENCOURS  = 0
WINBMAJLDR   = 0
WINBMAJFAS   = 0
WINBMAJLEA   = 0
WINBMAJLOF   = 0
WINBMAJGRT   = 0
WINBMAJIVY   = 0
WINBMAJPHY   = 0
WITRTREC     = G_OUI
WIERRTITRE   = G_NON
WIUNOBJLOCK  = G_NON
WIALLOBJLOCK = G_NON
WCGTABCPT    = GTABCPT
WCREFCDF     = PCREFCDF
#FQXXXXXX WIMAXOBC     = 6
WIMAXOBC     = 5   # Remis à la valeur 5 car L'objet Inventaire a été supprimé


If clalev([F:ATB])  =0 : Local File ATABLE    [ATB]     : Endif : # Table des Tables
If clalev([F:ATX2]) =0 : Local File ATEXTE    [ATX2]    : Endif : # Table des textes
If clalev([F:AST])  =0 : Local File APLSTD    [AST]     : Endif : # Table des menus locaux
If clalev([F:FAS])  =0 : Local File FXDASSETS [FAS]     : Endif : # Table des biens pour liaison entre objet
If clalev([F:ALK])  =0 : Local File APLLCK    [ALK]     : Endif : # Table des verrous
If clalev([F:RVA])  =0 : Local File RUBASSVAL [RVA]     : Endif : # Table des Associations - valeurs
If clalev([F:WRVA]) =0 : Local File RUBASSVAL  [WRVA]   : Endif : #*FQ107562 Table des Associations - valeurs
If clalev([F:RVP])  =0 : Local File RUBASSVALP [RVP]    : Endif : #*FQ107562 Table des Associations - valeurs/plans
If clalev([F:WRVP]) =0 : Local File RUBASSVALP [WRVP]   : Endif : #*FQ107562 Table des Associations - valeurs/plans
If clalev([F:FRF])  =0 : Local File FREFLD    [FRF]     : Endif : # Table de paramétrages des zones libres
If clalev([F:FCY])  =0 : Local File FACILITY  [FCY]     : Endif : # Table des Sites
If clalev([F:CPY])  =0 : Local File COMPANY   [CPY]     : Endif : # Table des Sociétés
If clalev([F:ADI])  =0 : Local File ATABDIV   [ADI]     : Endif : # Table diverses
If clalev([F:ATZ])  =0 : Local File ATABZON   [ATZ]     : Endif : # Dictionnaire des champs
If clalev([F:CCE])  =0 : Local File CACCE     [CCE]     : Endif : # Table des sections analytiques
If clalev([F:FAM])  =0 : Local File FASFAM    [FAM]     : Endif : # Table des familles (FQ107562)
If clalev([F:FAMO]) =0 : Local File FASFAM    [FAMO]    : Endif : # Table des anciens codes familles (FQ107562)

##------------------------------------------------------------------------------------------------##
## Lecture de la table de paramétrage                                                             ##
##  - 1 Enregistrement  : Paramétrage               (CDFPAR)                                      ##
##  - X Enregistrements : Anciens et nouveaux codes (CDFCOD)                                      ##
##  - X Enregistrements : Sélection des sites       (CDFFCY)                                      ##
##  - X Enregistrements : Sélection des sociétés    (CDFCPY)                                      ##
##------------------------------------------------------------------------------------------------##
If clalev([F:CDF])  =0 : Local File CDFPAR    [CDF]     : Endif : # Table de  paramétrage recodification
If clalev([F:CDC])  =0 : Local File CDFCOD    [CDC]     : Endif : # Table des nouveaux codes
If clalev([F:CDY])  =0 : Local File CDFFCY    [CDY]     : Endif : # Table des Sites    à recodifier
If clalev([F:CDS])  =0 : Local File CDFCPY    [CDS]     : Endif : # Table des Sociétés à recodifier

##  - Lecture enregistrement  : Paramétrage               (CDFPAR)                                ##

Read [F:CDF] = WCREFCDF
If [S]fstat <> 0
          Infbox 'Read [F:CDF] stat = ' + num$( fstat )
Endif

GOK = 1

If [F:CDF]PROSTA = GVML_RECATR
    GTRANS=1
    Trbegin [CDF]
Endif

##------------------------------------------------------------------------------------------------##
## Demande de confirmation du traitement en simulation                                            ##
##------------------------------------------------------------------------------------------------##
If [F:CDF]PROSTA = GVML_RECATR  and PFLGSIM = G_OUI
      #-->Ce traitement est un traitement simulé. Confirmez-vous ?
      Call OUINON(mess(20,GML_MSGINV,1), LOK) From GESECRAN
      If ( LOK = G_OUI)
          GOK = 1
          FIN = 1
      Else
          GOK = 0
          FIN = 0
          Rollback  #Fq-73840
          GTRANS=0  #Fq-73840
          End
      Endif
Else
          GOK = 1
          FIN = 1
Endif

If [F:CDF]PROSTA = GVML_RECATR
   WIEDITTRA    = [F:CDF]FLGTRCEDT
Else
   WIEDITTRA    = G_NON
Endif
##------------------------------------------------------------------------------------------------##
## - Edition du début du compte-rendu                                                             ##
##------------------------------------------------------------------------------------------------##
Gosub EDIT_DEB_COMPTERENDU

##------------------------------------------------------------------------------------------------##
## Stockage en mémoire d'un tableau des sites sélectionnés     (Lecture table CDFFCY)             ##
## Stockage en mémoire d'un tableau des sociétés sélectionnées (Lecture table CDFCPY)             ##
## Stockage en mémoire d'un tableau des objets                                                    ##
##------------------------------------------------------------------------------------------------##
Gosub STOCKAGE_SITES_SEL
Gosub STOCKAGE_SOC_SEL
Gosub STOCKAGE_OBJ_TRT

If  PFLGSIM = G_NON & [F:CDF]PROSTA <> GVML_RECATRC
    Gosub LOCK_ALL
Endif

If WIALLOBJLOCK <> G_OUI
  ##------------------------------------------------------------------------------------------------##
  ## - Lecture enregistrements 'Anciens et nouveaux codes' (CDFCOD)                                 ##
  ## + Maj des postes de la table                                                                   ##
  ##------------------------------------------------------------------------------------------------##
  Gosub TRAIT_MAJ_EDIT_TABLE
  ##------------------------------------------------------------------------------------------------##
  ## - Préparation du traitement : stockage en mémoire des objets traités , de l'objet maitre       ##
  ##                               et pour chaque objet , de la liste des rubriques concernées      ##
  ##------------------------------------------------------------------------------------------------##
  Gosub PHASE_PREPARATION
  ##------------------------------------------------------------------------------------------------##
  ## - Phase de traitement si anciens codes = inactifs ou conservés                                 ##
  ##------------------------------------------------------------------------------------------------##
  If [F:CDF]STAOLDCOD = GVML_RECINA or [F:CDF]STAOLDCOD = GVML_RECCON
      Gosub PHASE_TRAITEMENT_INACON
  Endif
  ##------------------------------------------------------------------------------------------------##
  ## - Phase de traitement si anciens codes = supprimés                                             ##
  ##------------------------------------------------------------------------------------------------##
  If [F:CDF]STAOLDCOD = GVML_RECSUP
      Gosub PHASE_TRAITEMENT_SUP
  Endif
  ##------------------------------------------------------------------------------------------------##
  ## - Réecriture du paramétrage de recodification                                                  ##
  ##------------------------------------------------------------------------------------------------##
  If  WITRTREC = G_OUI and PFLGSIM     = G_NON and  PRETOUROK    = G_OUI and [F:CDF]PROSTA = GVML_RECATR
     Read [F:CDF] = [F:CDF]REFCDF
     If [S]fstat <> 0
          Infbox 'Read [F:CDF] stat = ' + num$( fstat )
     Else
         If [F:CDF]PROSTA = GVML_RECATR
              [F:CDF]PROSTA    = GVML_RECTRT
         Else
              [F:CDF]PROSTA    = GVML_RECTRTC
         Endif
         [F:CDF]PRODAT    = date$
         [F:CDF]PROUSR    = GUSER
         Rewrite [F:CDF]
         If [S]fstat <> 0
              Infbox 'Rewrite [F:CDF] stat = ' + num$( fstat )
         Endif
     Endif
    Endif

    If [F:CDF]FLGUPDASS = G_OUI
        Gosub TRT_MAJ_ASSOCIATION
    Endif

    If [F:CDF]PROSTA = GVML_RECATR
        Gosub EDIT_FIN_COMPTERENDU
    Endif
  #Fq-68840
    #Fq-68409 IF  WITRTREC = G_OUI and PFLGSIM= G_NON and  PRETOUROK = G_OUI and [F:CDF]PROSTA = GVML_RECATRC
    #Fq-68409     Read [F:CDF] = [F:CDF]REFCDF
    #Fq-68409    [F:CDF]PROSTA    = GVML_RECTRTC
    #Fq-68409    [F:CDF]PRODAT    = date$
    #Fq-68409    [F:CDF]PROUSR    = GUSER
    #Fq-68409    Rewrite [F:CDF]
    #Fq-68409    If [S]fstat <> 0
    #Fq-68409        Infbox 'Rewrite [F:CDF] stat = ' + num$( fstat )
    #Fq-68409   Endif
    #Fq-68409 Endif   #Fq-68840

Endif

#Fq-73840 If PFLGSIM = G_NON
   Gosub UNLOCK_ALL
#Fq-73840Endif

If [F:CDF]PROSTA = GVML_RECATR   or [F:CDF]PROSTA = GVML_RECTRT
    If GOK <> 0 and  WITRTOK = G_OUI and PFLGSIM = G_NON
        Commit
    Else
        Rollback
    Endif
    GTRANS=0
    If !GSERVEUR : Call LEC_TRACE_FIC (1) From TRACEABX3 : Call LEC_TRACE From LECFIC : Endif
Endif

End
####################################################################################################
## $PHASE_PREPARATION                                                                            ##
####################################################################################################
$PHASE_PREPARATION

Local Char    WCCODTYP
Local Integer WITRTADI


WITRTADI = G_NON


##------------------------------------------------------------------------------------------------##
## Edition de l'entête des Objets et Rubriques à mettre à jour                                    ##
##------------------------------------------------------------------------------------------------##
If [F:CDF]PROSTA = GVML_RECATR
    WCLIGNE="===================================================================================================================="
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> LISTE DES RUBRIQUES MISES A JOUR
    WCLIGNE="                            " + mess(57,GML_MSGREC,1) + "                                             "
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="===================================================================================================================="
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCDESIFIXE= format$("Kb:90X", mess(14,GML_MSGTRC,1)) : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
    WCLIGNE="------------------------------------         ----------------------------    "
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
Endif

#---- Stockage en mémoire du type de données correspondant à la table à recodifier ----------------*
If [F:CDF]TABNAM = 'FAM'   #FQ107562
   WCCODTYP = 'FAM'           #FQ107562
Elsif [F:CDF]TABNAM = 'FCY'
   # BLS : site géographique
   WCCODTYP = 'BLS'
Elsif left$ ([F:CDF]TABNAM,3) = 'CCE'
   #FQ-52344 WCCODTYP = 'BCC'
   #FQ105829X WCCODTYP = 'BCD'
   WCCODTYP = 'CCE'
Else
   WCCODTYP = 'ADI'
   WITRTADI = G_OUI
Endif


Global  Integer  WIMAXOBC

WIMAXOBC = 5

#---- Stockage des rubriques concernées par la recodification pour chaque objet ------#

#-- Recherche du nombre maximum de rubriques à traiter pour chaque objet a traiter ---#

Local Integer WIOBC
Local Integer WIRUB
Local Integer WIRUBMAX

WIRUBMAX  = 0
WIRUBMAX  = 1

For WIOBC=1 To WIMAXOBC
  WIRUB= 0
  If WIOBCSEL(WIOBC)= G_OUI
     Gosub COUNT_RUB_OBC
     If WIRUB  > WIRUBMAX
         WIRUBMAX  = WIRUB
     Endif
  Endif
Next

#-- Déclaration d'un tableau de rubriques (20 caractères) à 2 dimensions         -----#
#-- N° max d'objet traités , et 10 rubriques max par objet)                      -----#

If dim(WCRUBOBC )>0 : Kill WCRUBOBC  : Endif
Local Char    WCRUBOBC (20) (WIMAXOBC+1, WIRUBMAX+1) : # Code des rubriques par objet
Local Integer WIOBC
Local Integer WIRUB

For WIOBC=1 To WIMAXOBC
  WIRUB= 0
  If WIOBCSEL(WIOBC)= G_OUI
     Gosub RECH_RUB_OBC
  Endif
Next

Return
####################################################################################################
## $COUNT_RUB_OBC : Comptage du nombre de rubrique max pour un objet traité                       ##
####################################################################################################
$COUNT_RUB_OBC

Local Char WCNOMOBJET
Local Char WCNOMOBJETDES (25)
Local Char WCNOMRUBDES   (25)
Local Integer WITAB
Local Integer WIALPREF

If WIOBC = GVML_OMBIEN  :  WCNOMOBJET = 'FXDASSETS'   : Endif
If WIOBC = GVML_OMDEPEN :  WCNOMOBJET = 'LAYOUTFAS'   : Endif
If WIOBC = GVML_OMLOCFI :  WCNOMOBJET = 'LEASE'       : Endif
If WIOBC = GVML_OMSUBV  :  WCNOMOBJET = 'GRANTS'      : Endif
If WIOBC = GVMLOMPHY    :  WCNOMOBJET = 'PHYELT'      : Endif

WITAB = 0
#*FQ107562 If [F:CDF]TABNAM <> 'LOC' and [F:CDF]TABNAM <> 'FCY'  and left$ ([F:CDF]TABNAM,3) <> 'CCE'
  If  [F:CDF]TABNAM           <> 'FCY'  and
&     left$ ([F:CDF]TABNAM,3) <> 'CCE'  and
&     [F:CDF]TABNAM           <> 'FAM'
    WITAB = val([F:CDF]TABNAM)
Endif

##------------------------------------------------------------------------------------------------##
## Boucle sur toutes les rubriques de l'objet testé (WIOBC) afin de voir si la rubrique est       ##
## controlée par la table à recodifer                                                             ##
##------------------------------------------------------------------------------------------------##
## Création du filtre (sur la table Dictionnaire des champs (ATABZON)) sélectionnant les champs   ##
##  ayant le  type de données                                                                     ##
##------------------------------------------------------------------------------------------------##
Filter[F:ATZ] Where (CODTYP=WCCODTYP) and CODFIC = WCNOMOBJET
For [F:ATZ]
   If    WITRTADI = G_NON or (WITRTADI = G_OUI and left$ ([F:ATZ]EXPLIEN,3) = [F:CDF]TABNAM)
      WIRUB += 1
   Elsif WITRTADI = G_OUI and left$ ([F:ATZ]EXPLIEN,6) = "REFTAB"
      ##------------------------------------------------------------------------------------------------##
      ## 1) Si la rubrique est une zone libre ([F:ATZ]EXPLIEN,6) = "REFTAB")                            ##
      ## 2) Recherche du paramétrage de la zone libre associée (indice de ALPREF = 7éme pos - 1 )       ##
      ## 3) Recherche si, dans le paramétrage des zones libres, la rubrique est controlé par la table   ##
      ## a recodifier                                                                                   ##
      ##------------------------------------------------------------------------------------------------##
      If  val(mid$([F:ATZ]EXPLIEN,7,2)) = 10
         WIALPREF = 9
      Else
         WIALPREF = val(mid$([F:ATZ]EXPLIEN,7,1)) -1
      Endif
      Filter [F:FRF] Where  [F:FRF]OBJ = WIOBC and [F:FRF]ALPREF(WIALPREF) = WITAB
      For [F:FRF]
         #Fq-84345 If find ([F:FRF]CPY,LIST_CPY) <> 0
         If find([F:FRF]CPY,LIST_CPY)
            WIRUB += 1
         Endif
      Next
     Filter [F:FRF]
  Endif
Next
Filter[F:ATZ]

Return
####################################################################################################
## $RECH_RUB_OBC : Recherche des rubriques de l'objet traités                                     ##
####################################################################################################
$RECH_RUB_OBC

Local Char WCNOMOBJET
Local Char WNOMOBJETDES (25)
Local Char WCNOMRUBDES   (40)
Local Char WCSOCZL
Local Integer WITAB
Local Integer WISELRUB

If WIOBC = GVML_OMBIEN  :  WCNOMOBJET = 'FXDASSETS'   : Endif
If WIOBC = GVML_OMDEPEN :  WCNOMOBJET = 'LAYOUTFAS'   : Endif
If WIOBC = GVML_OMLOCFI :  WCNOMOBJET = 'LEASE'       : Endif
If WIOBC = GVML_OMSUBV  :  WCNOMOBJET = 'GRANTS'      : Endif
If WIOBC = GVMLOMPHY    :  WCNOMOBJET = 'PHYELT'      : Endif

Read [F:ATB]CODFIC = WCNOMOBJET
If [S]fstat =  0
    # Décodification de l'intitulé qui a été récupéré sous forme de nombre
    Call TEXTE([F:ATB]INTITFIC,WNOMOBJETDES) From OBJDIV
Endif

WITAB = 0
#*FQ107562 If [F:CDF]TABNAM <> 'LOC' and [F:CDF]TABNAM <> 'FCY'  and left$ ([F:CDF]TABNAM,3) <> 'CCE'
  If [F:CDF]TABNAM           <> 'FCY'  and
&    left$ ([F:CDF]TABNAM,3) <> 'CCE' and
&    [F:CDF]TABNAM           <> 'FAM'
    WITAB = val([F:CDF]TABNAM)
Endif

##------------------------------------------------------------------------------------------------##
## Boucle sur toutes les rubriques de l'objet testé (WIOBC) afin de voir si la rubrique est       ##
## controlée par la table à recodifer                                                             ##
##------------------------------------------------------------------------------------------------##
## Création du filtre (sur la table Dictionnaire des champs (ATABZON)) sélectionnnant les champs  ##
##  ayant le  type de données                                                                     ##
##------------------------------------------------------------------------------------------------##
Filter[F:ATZ] Where (CODTYP=WCCODTYP) and CODFIC = WCNOMOBJET
For [F:ATZ]
  WCSOCZL  = ""
  WISELRUB = G_NON
  ##------------------------------------------------------------------------------------------------##
  ## Table a recodifer différent de ADI (ex:LOC), ou table ADI avec même référence table que TABNAM ##
  ##------------------------------------------------------------------------------------------------##
  If    WITRTADI = G_NON or (WITRTADI = G_OUI and left$ ([F:ATZ]EXPLIEN,3) = [F:CDF]TABNAM)
      WISELRUB = G_OUI

      Call TEXTFIC(WCNOMOBJET , [F:ATZ]CODZONE , 1, WCNOMRUBDES ) From OBJDIV
      If [F:CDF]PROSTA = GVML_RECATR
          WCDESIFIXE= format$("Kb:11X", WCNOMOBJET )+ format$("Kb:25X",'(' + WNOMOBJETDES + ')' )
&                       + format$("Kb:9X","") + format$("KB:13X",[F:ATZ]CODZONE) + '(' + WCNOMRUBDES + ')'
          Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
      Endif
 ##------------------------------------------------------------------------------------------------##
 ## Table a recodifer = table ADI d'une zone libre avec même référence que TABNAM                  ##
 ##------------------------------------------------------------------------------------------------##
 Elsif WITRTADI = G_OUI and left$ ([F:ATZ]EXPLIEN,6) = "REFTAB"
     ##------------------------------------------------------------------------------------------------##
     ## 1) Si la rubrique est une zone libre ([F:ATZ]EXPLIEN,6) = "REFTAB")                            ##
     ## 2) Recherche du paramétrage de la zone libre associée (indice de ALPREF= 7éme pos EXPLIEN - 1) ##
     ## 3) Recherche si, dans le paramétrage des zones libres, la rubrique est controlée par la table  ##
     ##    a recodifier                                                                                ##
     ## 4) Edition dans Compte-rendu du nom de la rubrique et de la société pour laquelle              ##
     ##    cette rubrique est controlée par la table                                                   ##
     ##------------------------------------------------------------------------------------------------##
      If  val(mid$([F:ATZ]EXPLIEN,7,2)) = 10
            WIALPREF = 9
      Else
            WIALPREF = val(mid$([F:ATZ]EXPLIEN,7,1)) -1
      Endif
      Filter [F:FRF] Where  [F:FRF]OBJ = WIOBC and [F:FRF]ALPREF(WIALPREF) = WITAB
      For [F:FRF]
         #Fq-84345 If find([F:FRF]CPY,LIST_CPY) <> 0
         If find([F:FRF]CPY,LIST_CPY)
            WCSOCZL  = [F:FRF]CPY
            WISELRUB = G_OUI
            Call TEXTFIC(WCNOMOBJET , [F:ATZ]CODZONE , 1, WCNOMRUBDES ) From OBJDIV
            If WCSOCZL  <> ""
               #--> Société :
               WCNOMRUBDES  = WCNOMRUBDES  + '  (' + mess(82,GML_MSGREC,1) + WCSOCZL + ')'
            Endif
            If [F:CDF]PROSTA = GVML_RECATR
               WCDESIFIXE= format$("Kb:11X", WCNOMOBJET )+ format$("Kb:25X",'(' + WNOMOBJETDES + ')' )
&                        + format$("Kb:9X","") + format$("KB:13X",[F:ATZ]CODZONE) + '(' + WCNOMRUBDES + ')'
               Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
               Endif
            Endif
         Next
      Filter [F:FRF]
  Endif

  If   WISELRUB = G_OUI
     WIRUB                  += 1
     WCRUBOBC(WIOBC, WIRUB) = [F:ATZ]CODZONE
  Endif
Next

###  Réintialisation du filtre
Filter[F:ATZ]

Return
####################################################################################################
## $PHASE_TRAITEMENT_SUP                                                                          ##
####################################################################################################
$PHASE_TRAITEMENT_SUP

Local Char    WCNOMCLE
Local Char    WCNOMOBJLONG
Local Char    WCNOMDES
Local Date    WDDATE (1..5)
Local Date    WDDATDERCLOT
Local Integer WICODERET
Local Integer WIENRSEL
Local Integer WIOBCSUP      : # Code de l'objet pour lequel on suppirme les codes
Local Char    WCWHERELDR (255)
Local Char    WCWHEREFAS (255)
Local Integer WITRTOK
Local Integer WINBENROBJ

WITRTOK   = G_OUI

Local Integer WI7
##------------------------------------------------------------------------------------------------##
## Préparation de la jauge                                                                        ##
##------------------------------------------------------------------------------------------------##
WINBENROBJ = 0
WINBTOT    = 0

# For WI7=1 To 5
For WI7=1 To WIMAXOBC
   If WIOBCSEL (WI7)  = G_OUI
      # WI7 = N° de l'objet a traiter
      WIOBCSUP      = WI7
      # [F:TRT] : classe qu'on va transmettre a l'étiquette ALIM_NEWCOD_DS_ENREGISTREMENT
      If WIOBCSUP      = GVML_OMBIEN
         If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File FXDASSETS [TRT]
         WINBENROBJ    = rowcount ([F:TRT])
         WINBTOT       = WINBTOT + WINBENROBJ
      Endif

      If WIOBCSUP      = GVML_OMDEPEN
         If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LAYOUTFAS [TRT]
         WINBENROBJ    = rowcount ([F:TRT])
         WINBTOT       = WINBTOT + WINBENROBJ
      Endif

      If WIOBCSUP      = GVML_OMLOCFI  & G_ACTLEA = G_OUI
         If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LEASE [TRT]
         WINBENROBJ    = rowcount ([F:TRT])
         WINBTOT       = WINBTOT + WINBENROBJ
      Endif

      If WIOBCSUP      = GVML_OMSUBV  & G_ACTGRT = G_OUI
         If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File GRANTS [TRT]
         WINBENROBJ    = rowcount ([F:TRT])
         WINBTOT       = WINBTOT + WINBENROBJ
      Endif

      If WIOBCSUP      = GVMLOMPHY
         If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File PHYELT [TRT]
         WINBENROBJ    = rowcount ([F:TRT])
         WINBTOT       = WINBTOT + WINBENROBJ
      Endif
   Endif
Next

If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif

#--> Recodification
WCTEXTEJAUGE  = mess(84,GML_MSGREC,1) + ' : ' +  [F:CDF]REFCDF
Call TEMPOFF() From GESECRAN
Call OUVRE_BOITE(WCTEXTEJAUGE, WINBTOT ) From GESECRAN
Call SET_BOITE(WCTEXTEJAUGE, WINBTOT   ) From GESECRAN

##------------------------------------------------------------------------------------------------##
## Traitements de tous les objets sélectionnés                                                    ##
##------------------------------------------------------------------------------------------------##
# For WI7=1 To 5
For WI7=1 To WIMAXOBC
   If WIOBCSEL (WI7)  = G_OUI
    # WI7 = N° de l'objet a traiter
    WIOBCSUP      = WI7
    WIOBCTRT      = WIOBCSUP
    WIOBCLDR      = WIOBCSUP
    # [F:TRT] : classe qu'on va transmettre a l'étiquette ALIM_NEWCOD_DS_ENREGISTREMENT
    If WIOBCSUP      = GVML_OMBIEN
       If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File FXDASSETS [TRT]
    Endif

    If WIOBCSUP      = GVML_OMDEPEN
       If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LAYOUTFAS [TRT]
    Endif

    If WIOBCSUP      = GVML_OMLOCFI  & G_ACTLEA = G_OUI
       If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LEASE [TRT]
    Endif

    If WIOBCSUP      = GVML_OMSUBV  & G_ACTGRT = G_OUI
       If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File GRANTS [TRT]
    Endif

    If WIOBCSUP      = GVMLOMPHY
       If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File PHYELT [TRT]
    Endif

    If  WIEDITTRA     = G_OUI
       WCLIGNE="===================================================================================================================="
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
       #--> LISTE DES ENREGISTREMENTS MIS A JOUR : Objet xxx
       WCLIGNE= format$("KB:35X",  "" ) + mess(12,GML_MSGREC,1) + ' : ' + mess(75,GML_MSGREC,1) + ' ' + mess(WIOBCSUP,GML_OBJMETIE,1)
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
       WCLIGNE="===================================================================================================================="
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
          #--> Soc. Site Référence Libelle Rubrique Ancienne valeur Nouvelle valeur
          WCLIGNE= mess(16,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
       WCLIGNE="---    ---- ---------           ---------------         -------------    ---------------      ---------------"
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
    Endif

    ##------------------------------------------------------------------------------------------------##
    ## Traitements de suppresion des codes dans les renregistrement de l'objet sélectionné            ##
    ##------------------------------------------------------------------------------------------------##
    Gosub TRT_SUP_UN_OBJ
   Endif
Next

Call FERME_BOITE From GESECRAN

Return
####################################################################################################
## $TRT_SUP_UN_OBJ                                                                                ##
####################################################################################################
$TRT_SUP_UN_OBJ

Filter[F:TRT]
##---------------------------------------------------------------------------------------------##
## Lecture des enregistrements de l'objet a traiter                                            ##
##---------------------------------------------------------------------------------------------##
For [F:TRT] With Stability
   ##------------------------------------------------------------------------------------------##
   ## Si Statut ancien code = Supprimé  :  on prend tous les enregistrements                   ##
   ##------------------------------------------------------------------------------------------##

     WINEWCOD =  G_NON
     Gosub ALIM_NEWCOD_DS_ENREGISTREMENT
     If WINEWCOD =  G_OUI
        #
        If WIOBCSUP      = GVML_OMBIEN  :  WINBMAJFAS +=1 :  Endif
        If WIOBCSUP      = GVML_OMDEPEN :  WINBMAJLOF +=1 :  Endif
        If WIOBCSUP      = GVML_OMLOCFI :  WINBMAJLEA +=1 :  Endif
        If WIOBCSUP      = GVML_OMSUBV  :  WINBMAJGRT +=1 :  Endif
        If WIOBCSUP      = GVMLOMPHY    :  WINBMAJPHY +=1 :  Endif
        #- si pas simu : rewrite----------------------------------------------------------------------##
        If PFLGSIM  <> G_OUI and  PRETOUROK    = G_OUI
            Rewrite [F:TRT]
            If fstat = 1
                WIRECLDROK = G_NON
                #--> Rejet enregistrement
                WCLIGNE= mess(15,GML_MSGREC,1) + '  ' + WCNOMOBJLONG +  '   ' + evalue("[F:TRT]"+WCNOMCLE )
                Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
            Elsif fstat <> 0
                GOK = 0 : Call FSTA("TRT") From GLOCK
                Break
            Endif
            #
        Endif
     Endif
   ##---------------------------------------------------------------------------------------------##
   ## évolution de l'avancement de la jauge                                                       ##
   ##---------------------------------------------------------------------------------------------##
   WINBENCOURS += 1
   #--> Enregistrements :
   WCTEXTEJAUGE= mess(81,GML_MSGREC,1) +'['+num$(WINBENCOURS)+'/'+num$(WINBTOT )+']'
   Call AFF_BOITE(WCTEXTEJAUGE,WINBENCOURS,LOK) From GESECRAN
Next
Filter[F:TRT]

Return
####################################################################################################
## $PHASE_TRAITEMENT_INACON                                                                       ##
####################################################################################################
$PHASE_TRAITEMENT_INACON

Local Char    WCNOMCLE
Local Char    WCNOMOBJLONG
Local Char    WCNOMDES
Local Date    WDDATE (1..5)
Local Date    WDDATDERCLOT
Local Integer WICODERET
Local Integer WIENRSEL
Local Char    WCWHERELDR (255)
Local Char    WCWHEREFAS (255)
Local Integer WITRTOK

WITRTOK   = G_OUI

WIOBCLDR  = [F:CDF]OBCLDR

# [F:OBC] : classe de l'objet maitre sur laquelle on va fait un For (Boucle sur tous les enregistrements)
If WIOBCLDR = GVML_OMBIEN
   If clalev([F:OBC]) =  0 : Local File FXDASSETS [OBC]  : Endif          : # Biens comptables
Endif

If WIOBCLDR = GVML_OMDEPEN
   If clalev([F:OBC])  =0 : Local File LAYOUTFAS [OBC]   : Endif          : # Dépenses
Endif

If WIOBCLDR = GVML_OMLOCFI  & G_ACTLEA = G_OUI
   If clalev([F:OBC])  =0 : Local File LEASE [OBC]       : Endif          : # Contrat financement
Endif


If WIOBCLDR = GVML_OMSUBV & G_ACTGRT = G_OUI
   If clalev([F:OBC])  =0 : Local File GRANTS [OBC]      : Endif          : # Subvention
Endif

If WIOBCLDR = GVMLOMPHY
   If clalev([F:OBC])  =0 : Local File PHYELT [OBC]      : Endif          : # Eléments physiques
Endif

##------------------------------------------------------------------------------------------------##
## 1) Création du filtre sur  l'objet maitre                                                      ##
## 2) Préparation de l'affichage de la jauge                                                      ##
## 3) Boucle sur les enregistrements --> Traitement de recodification                             ##
##------------------------------------------------------------------------------------------------##

## 1) Création du filtre sur l'objet maitre                                                       ##
##    Uniquement si Statut ancien code <> Supprimé car sinon on prend tous les enregistrements    ##
WCWHERELDR = ""
If  [F:CDF]PROSTA = GVML_RECATR
   If [F:CDF]STAOLDCOD <> GVML_RECSUP and [F:CDF]PROSTA = GVML_RECATR
     Gosub ALIM_WCWHERE_OBC
     If WIOBCLDR = GVML_OMLOCFI or WIOBCLDR = GVML_OMSUBV
        ##--- Sélection permettant de trouver les FAS liés à  l'enr de l'objet maître traité --------##
        WCWHEREFAS = ""
        Gosub ALIM_WCWHERE_LIAISON_FAS
     Endif
   Endif
Else
   ##------------------------------------------------------------------------------------------------##
   ## Si Cession intra-groupe --> traitement de la société transmise                                 ##
   ##------------------------------------------------------------------------------------------------##
   If WIOBCLDR    = GVML_OMBIEN
      WCWHERELDR = " ( [F:OBC]CPY = PCSOCREC and [F:OBC]CIGCOD = [F:CDF]REFTRFCMP) "
   Endif
Endif
##------------------------------------------------------------------------------------------------##
## Préparation de la jauge                                                                        ##
##------------------------------------------------------------------------------------------------##
#--> Recodification :
WCTEXTEJAUGE  = mess(84,GML_MSGREC,1) + ' : ' +  [F:CDF]REFCDF
If WCWHERELDR <> ""
    Filter[F:OBC] Where (evalue(WCWHERELDR))
Else
    Filter[F:OBC]
Endif

WINBTOT       = rowcount ([F:OBC])

Call TEMPOFF() From GESECRAN
Call OUVRE_BOITE(WCTEXTEJAUGE, WINBTOT ) From GESECRAN
Call SET_BOITE(WCTEXTEJAUGE, WINBTOT   ) From GESECRAN
##---------------------------------------------------------------------------------------------##
## Lecture des enregistrements de l'objet maître puis recherche si la sélection utilisateur    ##
## est Ok pour l'enregistrement lu                                                             ##
##---------------------------------------------------------------------------------------------##
For [F:OBC]
   ##------------------------------------------------------------------------------------------##
   ## Si Statut ancien code <> Supprimé car sinon on prend tous les enregsitrements            ##
   ##   Rejet des enregistrements 'Biens' si bien sortie dans exercices antérieurs             ##
   ##   Ceci n'a pas pu être mis dans le filter car la condition dépend de la société          ##
   ##------------------------------------------------------------------------------------------##
   WIENRSEL = G_OUI
   #FQ-69756   If [F:CDF]STAOLDCOD <> GVML_RECSUP
   If [F:CDF]STAOLDCOD <> GVML_RECSUP and [F:CDF]PROSTA <> GVML_RECATRC
      If WIOBCLDR = GVML_OMBIEN
         ##------------------------------------------------------------------------------------------##
         # Appel d'une fonction qui rend la date de dernière cloture "exercice" pour un contexte transmis
         # G300CPFI Global du contexte comptable et fiscal
         ##------------------------------------------------------------------------------------------##
         WDDATE (1) = [0/0/0]
         Call GET_CNX_DAT([F:OBC]CPY ,G300CPFI,WDDATE,WICODERET) From GLOBIENS
         #FQ-69756  WDDATDERCLOT = WDDATE(5)
         WDDATDERCLOT = WDDATE(1)
         If [F:OBC]ISSDAT <> [0/0/0] and [F:OBC]ISSDAT <= WDDATDERCLOT
             WIENRSEL = G_NON
         Endif
      Endif
   Endif

  If dim(LIST_FCY)>0
    #Fq-52344If find([F:OBC]FCY,LIST_FCY)> 0 and WIENRSEL = G_OUI
    Local Integer RERROR
    Call LOAD_FASPARCPY([F:OBC]CPY,"",G_NON,RERROR) From GLOFCYCPY     : # FQ94836

    If WIENRSEL = G_OUI
        Gosub RECODIF_ENR_OBJET_MAITRE
    Endif
  Endif
  ##---------------------------------------------------------------------------------------------##
  ## évolution de l'avancement de la jauge                                                       ##
  ##---------------------------------------------------------------------------------------------##

  WINBENCOURS += 1
  #--> Enregistrements :
  WCTEXTEJAUGE= mess(81,GML_MSGREC,1)  +'['+num$(WINBENCOURS)+'/'+num$(WINBTOT )+']'
  Call AFF_BOITE(WCTEXTEJAUGE,WINBENCOURS,LOK) From GESECRAN
Next
Filter[F:OBC]

Call FERME_BOITE From GESECRAN

Return
####################################################################################################
## $ALIM_WCWHERE_OBC : Requete de filtration des enregistrments de l'objet maitre                 ##
####################################################################################################
$ALIM_WCWHERE_OBC

If WIOBCLDR    = GVML_OMBIEN
    ##------------------------------------------------------------------------------------------------##
    ## La sélection des biens non sortis ou sortis après la date de dernière cloture, dépend de la    ##
    ## date de dernière cloture de la société du bien traité. Ce contrôle n'est donc pas fait ici     ##
    ## mais doit donc être fait après lecture du bien et non dans le FILTER                           ##
    ##------------------------------------------------------------------------------------------------##
Endif

# Sélection des dépenses non rattachés aux biens

If WIOBCLDR     = GVML_OMDEPEN
   WCWHERELDR = " ( [F:OBC]AASREF = '' ) "
Endif

# Sélection des contrats  dont statut <> Echu, Rachat, Resilié

If WIOBCLDR    = GVML_OMLOCFI  & G_ACTLEA = G_OUI
   WCWHERELDR = " ( [F:OBC]LEASTA <> GVML_STECHU and [F:OBC]LEASTA <> GVML_STRACHA and [F:OBC]LEASTA <> GVML_STRESIL ) "
Endif

# Sélection des subventions non supprimées

If WIOBCLDR   = GVML_OMSUBV
   WCWHERELDR = " ( [F:OBC]GRASTA <> GVML_SUBANNU ) "
Endif

If WCWHERELDR = "" : WCWHERELDR="1=1" : Endif
If [F:CDF]REQUETE <> ""
  #Fq-84345  WCWHERELDR = WCWHERELDR +"&"+[F:CDF]REQUETE +"&"+ "find([F:OBC]FCY,LIST_FCY)<>0"
   WCWHERELDR = WCWHERELDR +"&"+[F:CDF]REQUETE +"&"+ "find([F:OBC]FCY,LIST_FCY)"
Endif
#Fq-84345 WCWHERELDR = WCWHERELDR +"&"+ "find([F:OBC]FCY,LIST_FCY)<>0"
 WCWHERELDR = WCWHERELDR +"&"+ "find([F:OBC]FCY,LIST_FCY)"

Return
####################################################################################################
## $ALIM_WCWHERE_AUT : Requete de filtration des enregistrments de l'objet Autre                  ##
####################################################################################################
$ALIM_WCWHERE_AUT

If WIOBCAUT   = GVML_OMBIEN
    ##------------------------------------------------------------------------------------------------##
    ## La sélection des biens non sortis ou sortis après la date de dernière cloture, dépend de la    ##
    ## date de dernière cloture de la société du bien traité. Ce contrôle n'est donc pas fait ici     ##
    ## mais doit donc être fait après lecture du bien et non dans le FILTER                           ##
    ##------------------------------------------------------------------------------------------------##
Endif

WCWHEREAUT = ""

# Sélection des contrats  dont statut <> Echu, Rachat, Resilié

If WIOBCAUT= GVML_OMLOCFI  & G_ACTLEA = G_OUI
   WCWHEREAUT = "  [F:AUT]LEASTA <> GVML_STECHU and [F:AUT]LEASTA <> GVML_STRACHA and [F:AUT]LEASTA <> GVML_STRESIL  "
Endif

# Sélection des subventions non supprimées

If WIOBCAUT   = GVML_OMSUBV
  WCWHEREAUT = "  [F:AUT]GRASTA <> GVML_SUBANNU  "
Endif

Return

####################################################################################################
## $ALIM_WCWHERE_LIAISON_AUT : Ajout au WHERE de la clause permettant de sélectionner les         ##
##                             enregistrements de l'objet AUTRE liés à l'enregistrement FAS       ##
##                             traité                                                             ##
####################################################################################################
ALIM_WCWHERE_LIAISON_AUT

##----  Si Objet autre = Dépense  ---------------------------------##
If WIOBCAUT = GVML_OMDEPEN
    ##---  Liaison sur la référence de bien   ---------------------##
    ##---  Plusieurs dépenses peuvent être lié au bien traité -----##
    If WCWHEREAUT <> "" : WCWHEREAUT = WCWHEREAUT  + " and " : Endif
    WCWHEREAUT = WCWHEREAUT  + " [F:AUT]CPY = [F:FAS]CPY    and [F:AUT]AASREF <> ''  and [F:AUT]AASREF = [F:FAS]AASREF   "

##----  Si Objet autre = Contrat  ---------------------------------##
Elsif WIOBCAUT = GVML_OMLOCFI & G_ACTLEA=G_OUI
    ##---  Liaison sur la référence de contrat financement   ------##
    ##---  1 seul contrat peut être lié au bien traité ------------##
    If WCWHEREAUT <> "" : WCWHEREAUT = WCWHEREAUT  + " and " : Endif
    WCWHEREAUT = WCWHEREAUT  + " [F:AUT]LEAREF <> '' and [F:AUT]LEAREF = [F:FAS]LEAREF   "

##----  Si Objet autre = Suvention---------------------------------##
Elsif WIOBCAUT = GVML_OMSUBV
    ##-- Liaison sur la référence du projet d'investissements -----##
    ##-- plusieurs subventions peuvent être liées au bien traité --##
    If WCWHEREAUT <> "" : WCWHEREAUT = WCWHEREAUT  + " and " : Endif
    WCWHEREAUT = WCWHEREAUT  + " [F:AUT]CPY = [F:FAS]CPY   and [F:FAS]INVPLN <> '' and [F:AUT]INVPLN = [F:FAS]INVPLN  "

Elsif WIOBCAUT = GVMLOMPHY
    ##---  Liaison sur la référence du bien -----------------------##
    ##---  plusiseurs éléments physiques --------------------------##
    ##---  peuvent être liés au bien traité -----------------------##
    If WCWHEREAUT <> "" : WCWHEREAUT = WCWHEREAUT  + " and " : Endif
    WCWHEREAUT = WCWHEREAUT  + " [F:AUT]AASREF = [F:FAS]AASREF  "

Endif

Return
####################################################################################################
## $ALIM_WCWHERE_LIAISON_FAS : Ajout au WHERE de la clause permettant de sélectionner les         ##
##                             enregistrements de l'objet FAS  liés à l'enregistrement de         ##
##                             l'objet MAITRE traité                                              ##
####################################################################################################
ALIM_WCWHERE_LIAISON_FAS

##------------------------------------------------------------------------------------------------##
##                                                                                                ##
## L'enregistrement maitre lu est dans [F:OBC]                                                    ##
##                                                                                                ##
## Si objet maitre FAS (Bien comptable) : il n'y a pas besoin de rechercher le bien comptable     ##
##                                        lié  car on est déjà sur un bien                        ##
##                                                                                                ##
## Si objet maitre est LEA (Contrat)    : Recherche des biens comptables liés au contrat          ##
##                                                                                                ##
## Si objet maitre est GRT (Subvention) : Recherche des biens comptables liés à la subvention     ##
##                                        (Même projet d'investissement)                          ##
##                                                                                                ##
## Si objet maitre est LOF (Dépense)    : il n'y a pas besoin de rechercher le bien comptable lié ##
##   - LOF (Dépense) car on ne sélectionne que les dépenses non liées aux biens                   ##
##                                                                                                ##
## Si objet maitre est LOF (Dépense)    : il n'y a pas besoin de rechercher le bien comptable lié ##
##------------------------------------------------------------------------------------------------##

## Si Objet maitre = Subventions
## L'objet à lier est FAS

If WIOBCLDR  = GVML_OMSUBV
        ##-- Liaison sur la référence du projet d'investissements -----##
        ##-- plusieurs subventions peuvent être liées au bien traité --##
        If WCWHEREFAS <> "" : WCWHEREFAS = WCWHEREFAS + " and " : Endif
        WCWHEREFAS = WCWHEREFAS + " [F:FAS]CPY = [F:OBC]CPY   and  [F:FAS]FCY = [F:OBC]FCY   and [F:FAS]INVPLN <> '' and [F:FAS]INVPLN = [F:OBC]INVPLN  "

Endif

## Si Objet maitre = Contrats

If WIOBCLDR  = GVML_OMLOCFI & G_ACTLEA=G_OUI
        ##---  Liaison sur la référence de contrat---------------------##
        If WCWHEREFAS <> "" : WCWHEREFAS = WCWHEREFAS + " and " : Endif
        # WCWHEREFAS = WCWHEREFAS + " [F:FAS]CPY = [F:OBC]CPY   and  [F:FAS]FCY = [F:OBC]FCY   and [F:FAS]AASREF  <> '' and [F:FAS]AASREF  = [F:OBC]AASREF   "
        WCWHEREFAS = WCWHEREFAS + " [F:FAS]LEAREF  = [F:OBC]LEAREF   "
Endif

Return
####################################################################################################
## $STOCKAGE_SITES_SEL : Constitution de la sélection des sites                                      ##
####################################################################################################
$STOCKAGE_SITES_SEL

Local Char    CRITSUPR (40)
Local Integer NBR_FCY

Raz NBR_FCY

If [F:CDF]PROSTA = GVML_RECATR
##------------------------------------------------------------------------------------------------##
    ## Edition de l'entête de la sélection des sociétés et sites                                      ##
    ##------------------------------------------------------------------------------------------------##
    WCLIGNE="===================================================================================================================="
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="                            " + mess(58,GML_MSGREC,1) + "                                             "
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="===================================================================================================================="
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> Société Sites financiers
    WCDESIFIXE= format$("Kb:90X", mess(15,GML_MSGTRC,1)) : Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
    WCLIGNE="----------------------       ---------------------   " :  Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
Endif

# On commence par compter le nombre de sites sélectionnés

Filter[F:CDY] Where (REFCDF = WCREFCDF)

For [F:CDY]
  If [F:CDY]FLGFCY = G_OUI
     NBR_FCY+=1
  Endif
Next
Filter[F:CDY]

# En fonction du nombre de sites sélectionnés et de la globale G_NOCHOI_SELALL

If NBR_FCY  :  # Un ou plusieurs sites sont sélectionnés

      # Déclaration de la variable destinée à recevoir les sites à sélectionner

      If dim(LIST_FCY)>0 : Kill LIST_FCY : Endif
      #FQ-66813 Global Char    LIST_FCY(5)(0..NBR_FCY)
      Global Char    LIST_FCY(GLONFCY)(0..NBR_FCY)

      # Remplissage de la variable contenant les sites à sélectionner
      Local Integer I_LIST_FCY
      Raz I_LIST_FCY
      Filter[F:CDY] Where (REFCDF = WCREFCDF)

      For [F:CDY]
        If [F:CDY]FLGFCY = G_OUI
            I_LIST_FCY+=1
            LIST_FCY(I_LIST_FCY-1)=[F:CDY]FCY
            Read [F:FCY]   = [F:CDY]FCY
            Read [F:CPY]   = [F:CDY]FCYCPY
            If [F:CDF]PROSTA = GVML_RECATR
                WCDESIFIXE= format$("Kb:5X", [F:CDY]FCYCPY )+ format$("Kb:22X", [F:CPY]CPYNAM) + format$("Kb:2X", "")
&                         + format$("KB:5X",[F:CDY]FCY )  + [F:FCY]FCYNAM
                Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
            Endif
        Endif
      Next
      Filter[F:CDY]
      # FQ-84345 CRITSUPR="Find(FCY,LIST_FCY)<>0"
      CRITSUPR="Find(FCY,LIST_FCY)"
Endif

Return
####################################################################################################
## $STOCKAGE_SOC_SEL : Constitution de la sélection des sociétés                                  ##
####################################################################################################
$STOCKAGE_SOC_SEL

Local Integer NBR_CPY

Raz NBR_CPY

# On commence par compter le nombre de sociétés sélectionnés

Filter[F:CDS] Where (REFCDF = WCREFCDF)

For [F:CDS]
  If [F:CDS]FLGCPY = G_OUI
     NBR_CPY+=1
  Endif
Next
Filter[F:CDS]

# En fonction du nombre de sociétes sites sélectionnés et de la globale G_NOCHOI_SELALL

If NBR_CPY  :  # Une ou plusieurs sociétés sont sélectionnées

      # Déclaration de la variable destinée à recevoir les sociétés à sélectionner

      If dim(LIST_CPY)>0 : Kill LIST_CPY : Endif
      #*FQ107562 Global Char    LIST_CPY(3)(0..NBR_CPY)
      Global Char    LIST_CPY(GLONCPY)(0..NBR_CPY)

      # Remplissage de la variable contenant les sociétés à sélectionner
      Local Integer I_LIST_CPY
      Raz I_LIST_CPY
      Filter[F:CDS] Where (REFCDF = WCREFCDF)

      For [F:CDS]
        If [F:CDS]FLGCPY = G_OUI
            I_LIST_CPY+=1
            LIST_CPY(I_LIST_CPY-1)=[F:CDS]CPY
         Endif
      Next
      Filter[F:CDS]
Endif

Return
####################################################################################################
## $STOCKAGE_OBJ_TRT : Stockage des objets a traiter                                              ##
####################################################################################################
$STOCKAGE_OBJ_TRT

#---- Stockage de l'indicateur A traité  ou Non pour chaque objet traité -------------------------#

Local Integer WIOBCSEL (20)          : # Tableau des objets sélectionnés (N° Indice)
Local Char    WCOBCSEL (3) (20)      : # Tableau des objets sélectionnés (Nom court)

Raz WIOBCSEL
Raz WCOBCSEL

If [F:CDF]OBCPCDFAS = G_OUI :  WIOBCSEL (GVML_OMBIEN)  = G_OUI  : WCOBCSEL(GVML_OMBIEN)  = 'FAS' : Endif
If [F:CDF]OBCPCDLOF = G_OUI :  WIOBCSEL (GVML_OMDEPEN) = G_OUI  : WCOBCSEL(GVML_OMDEPEN) = 'LOF' : Endif
If [F:CDF]OBCPCDLEA = G_OUI :  WIOBCSEL (GVML_OMLOCFI) = G_OUI  : WCOBCSEL(GVML_OMLOCFI) = 'LEA' : Endif
If [F:CDF]OBCPCDGRT = G_OUI :  WIOBCSEL (GVML_OMSUBV)  = G_OUI  : WCOBCSEL(GVML_OMSUBV)  = 'GRT' : Endif
If [F:CDF]OBCPCDPHY = G_OUI :  WIOBCSEL (GVMLOMPHY)    = G_OUI  : WCOBCSEL(GVMLOMPHY)    = 'PHY' : Endif

Return
####################################################################################################
## $TRAIT_MAJ_EDIT_TABLE :      Traitement de maj des postes de la table                          ##
####################################################################################################
$TRAIT_MAJ_EDIT_TABLE
Local Integer WIVALEXIST
Local Char    WCDESIFIXE2
Local Char    WCDESIGNAT
Local Integer WINBCODREC

WINBCODREC   = 0

Filter[F:CDC] Where (REFCDF = WCREFCDF)
For [F:CDC]
   If [F:CDC]VALNEWCOD <> "" or left$([F:CDF]TABNAM,3) = 'CCE'
               WINBCODREC += 1
       Endif
Next
Filter[F:CDC]

Local Char    WCMODOLDCOD (20) (WINBCODREC+1)
Local Char    WCMODNEWCOD (20) (WINBCODREC+1)

##------------------------------------------------------------------------------------------------##
## Edition compte-rendu de la recodification des valeurs paramétrées par le client                ##
##------------------------------------------------------------------------------------------------##
If [F:CDF]PROSTA = GVML_RECATR
    WCLIGNE="===================================================================================================================="
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> LISTE DES CODES A RECODIFIER
    WCLIGNE="                            " + mess(44,GML_MSGREC,1) + "                                             "
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE="===================================================================================================================="
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> Code (Avant) Libellé (Avant) Code (Après) Libellé (Après)
    WCDESIFIXE= format$("Kb:90X", mess(13,GML_MSGTRC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
    WCLIGNE="------------   --------------------                     ------------   ---------------"
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
Else
    #--> LISTE DES CODES A RECODIFIER
    WCLIGNE= mess(44,GML_MSGREC,1) + "                                             "
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> 'Code (Avant) Libellé (Avant) Code (Après) Libellé (Après)
    #FQ106258 WCDESIFIXE= format$("Kb:3X", "") + format$("KB:90X", mess(13,GML_MSGTRC,1))
    #--> 'Code (Avant)                 Code (Après)
    WCDESIFIXE= format$("Kb:3X", "") + format$("KB:90X", mess(122,GML_MSGTRC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
    WCLIGNE= format$("Kb:3X", "") + "------------                                            ------------"
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
Endif

WINBCODREC = 0
Filter[F:CDC] Where (REFCDF = WCREFCDF)
For [F:CDC]
   If [F:CDC]VALNEWCOD <> "" or left$([F:CDF]TABNAM,3) = 'CCE'
      WIVALEXIST = G_NON
      WINBCODREC += 1
      WCDESIFIXE2 = ""
      ##------------------------------------------------------------------------------------------------##
      ## stockage dans un tableau des codes modifié    --> Meilleure performance                        ##
      ##------------------------------------------------------------------------------------------------##
      WCMODOLDCOD (WINBCODREC)  = [F:CDC]VALOLDCOD
      If [F:CDC]VALNEWCOD <> ""
          WCMODNEWCOD (WINBCODREC)  = [F:CDC]VALNEWCOD
      Else
          WCMODNEWCOD (WINBCODREC)  = [F:CDC]VALOLDCOD
      Endif
      WCDESIGNAT = ""
      If left$([F:CDF]TABNAM,3) = 'CCE'
         Read[F:CCE] = [F:CDF]CCEDIE; [F:CDC]VALOLDCOD
         WCDESIGNAT  = [F:CCE]DES
      Else
          If  [F:CDF]TABNAM = 'FCY'
            Read [F:FCY]   = [F:CDC]VALOLDCOD
            #FQ106258 WCDESIGNAT  = [F:FCY]FCYSHO
            WCDESIGNAT  = [F:FCY]FCYNAM
          Elsif  [F:CDF]TABNAM = 'FAM'  #*FQ107562
            Read [F:FAM]FAM0   = [F:CDC]VALOLDCOD
            Call LECTEXTRA(WCDESIGNAT,"FASFAM","FAMDES",[F:FAM]FAMREF,"") From ATEXTRA
         Elsif  [F:CDF]TABNAM <> ''
           Call LECTEXTRA(WCDESIGNAT  ,"ATABDIV","LNGDES",[F:CDF]TABNAM, [F:CDC]VALOLDCOD ) From ATEXTRA
         Endif
      Endif
      ##------------------------------------------------------------------------------------------------##
      ## Maj des nouveaux postes dans la table traitée                                                  ##
      ##------------------------------------------------------------------------------------------------##
      If  [F:CDF]TABNAM = 'FCY'
      ##------------------------------------------------------------------------------------------------##
      ## Aucun traitement car les nouveaux postes doivent avoir été créés préalablement a ce traitement ##
      ##------------------------------------------------------------------------------------------------##
   #Fq-88543 Elsif left$ ([F:CDF]TABNAM,3) = 'CCE' and [F:CDC]VALNEWCOD <> ""
   Elsif left$ ([F:CDF]TABNAM,3) = 'CCE'
      If  [F:CDC]VALNEWCOD <> ""
      ##------------------------------------------------------------------------------------------------##
      ## Ecriture dans table section analytique du NOUVEAU code                                         ##
      ##------------------------------------------------------------------------------------------------##
      Read[F:CCE]  = [F:CDF]CCEDIE;[F:CDC]VALNEWCOD
      If [S]fstat = 0
         WIVALEXIST = G_OUI
      Else
         If PFLGSIM  = G_NON
               #Fq-90165 [F:CCE]DIE    = val(mid$([F:CDF]TABNAM,4,1))
               [F:CCE]DIE    = [F:CDF]CCEDIE
            [F:CCE]CCE    = [F:CDC]VALNEWCOD
            [F:CCE]DES    = left$([F:CDC]VALNEWDES,30)
            [F:CCE]DESSHO = left$([F:CDC]VALNEWDES,10)
            Write [F:CCE]
            If [S]fstat <> 0
               Infbox 'write CCE stat = ' + num$( fstat )
            Endif
         Endif
      Endif
      Endif
   #*FQ107562
   Elsif [F:CDF]TABNAM = 'FAM'
      If  [F:CDC]VALNEWCOD <> ""
        ##------------------------------------------------------------------------------------##
        ## Ecriture dans table FASFAM du NOUVEAU code                                         ##
        ##------------------------------------------------------------------------------------##
        Read[F:FAM]= [F:CDC]VALNEWCOD
        If [S]fstat = 0
           WIVALEXIST = G_OUI
        Else
           If PFLGSIM  = G_NON
              Read[F:FAMO]= [F:CDC]VALOLDCOD
              If !fstat
                [F:FAM]  =  [F:FAMO]
              Endif
              [F:FAM]FAMREF    = [F:CDC]VALNEWCOD
              Call MAJTEXTRA(left$([F:CDC]VALNEWDES,10),"FASFAM","FAMDES",[F:FAM]FAMREF, "" ) From ATEXTRA
              Call MAJTEXTRA(left$([F:CDC]VALNEWDES,10),"FASFAM","SHODES",[F:FAM]FAMREF, "" ) From ATEXTRA
              Write [F:FAM]
              If [S]fstat <> 0
                 Infbox 'write FAM stat = ' + num$( fstat )
              Endif
           Endif
        Endif
     Endif #*FQ107562/
   Else
      ##------------------------------------------------------------------------------------------------##
      ## Ecriture dans table diverses du NOUVEAU code                                                   ##
      ##------------------------------------------------------------------------------------------------##
      Read[F:ADI]  = val([F:CDF]TABNAM);[F:CDC]VALNEWCOD
      #*Fq-88543 If [S]fstat = 0
      If [S]fstat = 0 and [F:CDC]VALNEWCOD<> ""
         WIVALEXIST = G_OUI
      Else
         If PFLGSIM  = G_NON
            [F:ADI]NUMTAB = val([F:CDF]TABNAM)
            [F:ADI]CODE   = [F:CDC]VALNEWCOD
            Write [F:ADI]
            If [S]fstat <> 0
               Infbox 'write ADI stat = ' + num$( fstat )
            Else
               ##------------------------------------------------------------------------------------------------##
               ## Maj des champs LNGDES et SHODES dans la table ATEXTRA                                          ##
               ##*Fq-88543 ==> pas nécessaire                                                                    ##
               ##------------------------------------------------------------------------------------------------##
               Call MAJTEXTRA([F:CDC]VALNEWDES,"ATABDIV","LNGDES",[F:CDF]TABNAM, [F:CDC]VALNEWCOD ) From ATEXTRA
               Call MAJTEXTRA(left$([F:CDC]VALNEWDES,10),"ATABDIV","SHODES",[F:CDF]TABNAM, [F:CDC]VALNEWCOD ) From ATEXTRA
            Endif
         Endif
      Endif
   Endif
   ##------------------------------------------------------------------------------------------------##
   ## Ce traitement edite le compte-rendu que si M:RC0]PROSTA  = GVML_RECATR                         ##
   ## Les tables FCY et LOC ne sont donc pas traitées -->les colonnes VALOLDLOC ne sont pas éditées  ##
   ##------------------------------------------------------------------------------------------------##
   If WIVALEXIST = G_OUI
      #Fq-69756 WCDESIFIXE2 = mess(45,GML_MSGREC,1)
      WCDESIFIXE2 = ""
   Else
      WCDESIFIXE2 = ""
   Endif
   If [F:CDF]PROSTA = GVML_RECATR
      WCDESIFIXE= format$("Kb:15X", [F:CDC]VALOLDCOD) + format$("Kb:30X", WCDESIGNAT   )
&               + format$("Kb:1X", "") + format$("KB:15X", [F:CDC]VALNEWCOD) +  format$("Kb:30X", [F:CDC]VALNEWDES) +  WCDESIFIXE2
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
   Else
      If [F:CDC]VALNEWCOD <> ""  #FQ-83418
            WCDESIFIXE= format$("Kb:3X", "") + format$("Kb:15X", [F:CDC]VALOLDCOD) + format$("Kb:30X", WCDESIGNAT)
&                  + format$("Kb:1X", "") + format$("KB:15X", [F:CDC]VALNEWCOD)
&                     + format$("Kb:30X", [F:CDC]VALNEWDES) +  WCDESIFIXE2
            Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  ,0,1) From TRACEABX3
         Endif
      Endif
   ##------------------------------------------------------------------------------------------------##
   ## Maj ou suppression de l'ancien postes dans la table traitée                                    ##
   ##------------------------------------------------------------------------------------------------##
   If PFLGSIM  = G_NON  and  PRETOUROK    = G_OUI
      If [F:CDF]STAOLDCOD =  GVML_RECINA
         If left$ ([F:CDF]TABNAM,3) = 'CCE'  and WCGTABCPT  = ""
            Read [F:CCE]  = [F:CDF]CCEDIE;[F:CDC]VALOLDCOD
            If [S]fstat =  0
               [F:CCE]VLYEND = [F:CDF]DATENDACT
               Rewrite [F:CCE]
               If [S]fstat <> 0
                  Infbox 'Rewrite CCE stat = ' + num$( fstat )
               Endif
            Endif
         Else
            ##-----------------------------------------------------------------------------------##
            ## 1) Les tables sensibles (LOC , FCY et CCE si partagée) ne sont pas concernées par ##
            ## la maj de date fin de validité car les anciens postes ne sont pas maj par ce trt  ##
            ## Rappel : Nouveaux postes créés préalablement a ce traitement                      ##
            ## 2) Les tables diverses seront traitées dans le futur -> maj au niveau superviseur ##
            ##------------------------------------------------------------------------------------##
         Endif
      Elsif [F:CDF]STAOLDCOD = GVML_RECSUP
         If [F:CDF]TABNAM = 'FCY'
            ##----------------------------------------------------------------------------##
            ## Tables sensibles : Aucun poste créé, maj ou supprimé                       ##
            ## Nouveaux postes créés préalablement a ce traitement                        ##
            ##----------------------------------------------------------------------------##
         Elsif left$ ([F:CDF]TABNAM,3) = 'CCE'
            If WCGTABCPT  = ""
               Delete [F:CCE]  = val(mid$([F:CDF]TABNAM,4,1));[F:CDC]VALOLDCOD
               If [S]fstat = 0
               Else
                  Infbox 'delete CCE stat = ' + num$( fstat )
               Endif
            Else
               ##----------------------------------------------------------------------------##
               ## Table sensible car partagée avec d'autres applications (WCGTABCPT  <> "")  ##
               ## Aucun poste créé, maj ou supprimé                                          ##
               ## Nouveaux postes créés préalablement a ce traitement                        ##
               ##----------------------------------------------------------------------------##
            Endif
         Else
            Delete [F:ADI]  = val([F:CDF]TABNAM);[F:CDC]VALOLDCOD
            If [S]fstat = 0
                #Ok
                ##------------------------------------------------------------------------------------------------##
                ## Supression des champs LNGDES et SHODES dans la table ATEXTRA                                   ##
                ##------------------------------------------------------------------------------------------------##
                #Call SUPTEXTRA("ATABDIV","LNGDES",[F:CDF]TABNAM, [F:CDC]VALOLDCOD ) From ATEXTRA
                #Call SUPTEXTRA("ATABDIV","SHODES",[F:CDF]TABNAM, [F:CDC]VALOLDCOD ) From ATEXTRA
            Else
               Infbox 'delete ADI stat = ' + num$( fstat )
            Endif
         Endif
      Endif
   Endif
Endif
Next
Filter[F:CDC]

Call ECR_TRACE_FIC ("",GTRC_PARAM,"",0,1) From TRACEABX3

Return
####################################################################################################
## $RECODIF_ENR_OBJET_MAITRE : Recodification d'un enregistrement de l'objet maitre              ##
####################################################################################################
$RECODIF_ENR_OBJET_MAITRE

Local Integer I
Local Integer WIRELSILENC
Local Integer WINEWCOD
Local Integer WIOBCAUT                  # Code de l'objet autres
Local Char    WCNEWFCYFIN               # Nouveau site géographique financier
Local Char    WCOLDFCYFIN               # Ancien  site géographique financier
Local Char    WCSOCCIBLE


# WCSOCCIBLE  est la société trasmise par la cession intra-groupe
WCSOCCIBLE  = PCSOCREC

WINEWCOD    = G_NON
WCNEWFCYFIN = ""
WCOLDFCYFIN = ""

# [F:TRT] : classe qu'on va transmettre a l'étiquette ALIM_NEWCOD_DS_ENREGISTREMENT
If WIOBCLDR = GVML_OMBIEN
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File FXDASSETS [TRT]
Endif

If WIOBCLDR = GVML_OMDEPEN
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LAYOUTFAS [TRT]
Endif

If WIOBCLDR = GVML_OMLOCFI &  G_ACTLEA = G_OUI
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LEASE [TRT]
Endif


If WIOBCLDR = GVML_OMSUBV  & G_ACTGRT = G_OUI
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File GRANTS [TRT]
Endif

If WIOBCLDR = GVMLOMPHY
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File PHYELT [TRT]
Endif

##------------------------------------------------------------------------------------------------##
## Alimentation des rubriques d'un enregistrement si codes modifiés                               ##
##------------------------------------------------------------------------------------------------##
WIOBCTRT = WIOBCLDR
[F:TRT] = [F:OBC]
Gosub ALIM_NEWCOD_DS_ENREGISTREMENT
##------------------------------------------------------------------------------------------------##
## Si traitement 'Cession intra-groupe'  et le site géographique a été changé                     ##
##           --> Alimentation du nouveau site financier                                           ##
##------------------------------------------------------------------------------------------------##
If [F:CDF]TABNAM = 'FCY' and WIOBCLDR = GVML_OMBIEN and WINEWCOD =  G_OUI
   ##------------------------------------------------------------------------------------------------##
   ## Le site géographique a été modifé --> On modifie le site financier                             ##
   ##                                   --> On vérifie que le nouveau site géographique est un site  ##
   ##                                      de  la société cible                                      ##
   ##------------------------------------------------------------------------------------------------##
   Gosub ALIM_NEWFCYFI_SI_FCY
Endif
##------------------------------------------------------------------------------------------------##
## Si traitement 'Cession intra-groupe' et recodification des sites -> test si une nouvelle loc a ##
## été paramétrée car celle-ci peut l'avoir été sans que le site géographique ait été modifié     ##
##------------------------------------------------------------------------------------------------##
If [F:CDF]TABNAM = 'FCY' and (WIOBCLDR = GVML_OMBIEN or WIOBCLDR = GVMLOMPHY)
  #  On alimente la localisation si elle a été paramétrée
Endif
##------------------------------------------------------------------------------------------------##
## Si traitement 'Cession intra-groupe' et la localisation a été changée                          ##
##           --> Alimentation du nouveau site géographique                                        ##
##           --> Alimentation du nouveau site financier                                           ##
##------------------------------------------------------------------------------------------------##
##------------------------------------------------------------------------------------------------##
## Maj de l'enregistrement                                                                        ##
##------------------------------------------------------------------------------------------------##
[F:OBC] = [F:TRT]
    #
If WINEWCOD =  G_OUI
    WNBENRTRT  +=1
    #Fq-76082 WINBMAJLDR +=1
    #
    #- si pas simu : rewrite----------------------------------------------------------------------##
    If PFLGSIM  = G_NON and  PRETOUROK    = G_OUI
        Rewrite [F:OBC]
        If fstat = 1
                WIRECLDROK = G_NON
                WCLIGNE= mess(15,GML_MSGREC,1) + '  ' + WCNOMOBJLONG +  '   ' + evalue("[F:OBC]"+WCNOMCLE )
                Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
        Elsif fstat <> 0
                GOK = 0 : Call FSTA("OBJ") From GLOCK
                Return
        Endif
        #
    Endif
    ##------------------------------------------------------------------------------------------------##
    ## Maj des enregs des autres objets lié à l'objet maître traité                                   ##
    ##------------------------------------------------------------------------------------------------##


    Gosub TRT_TOUS_AUTRES_OBC
 Else

Endif

Return
####################################################################################################
## $ALIM_NEWCOD_DS_ENREGISTREMENT : Alim. des rubriques d'un enregistrement si codes modifiés     ##
####################################################################################################
$ALIM_NEWCOD_DS_ENREGISTREMENT
Local Integer WI2, I
Local Integer WI3
Local Integer WIDIMRUB
Local Integer WIDIMVAL
Local Integer WIRUB
Local Integer WINEWRUB
Local Char    WCRUB1
Local Char    WCRUB2
Local Char    WCZONFIC
Local Char    WCNOMRUBDES
Local Char    WCVALORIG (255)    #FQ105388
Local Char    WCVALORIGLOC (255) #FQ105388
Local Char    WCVALNOUV (255)    #FQ105388
Local Char    WCVALNOUVLOC (255) #FQ105388
Local Char    WCLIBCPY
Local Char    WCLIBFCY
Local Char    WCLIBREF
Local Char    WCLIBDES
Local Char    WCDESDEBUT

#Rappel
#  Ancien   code                          : WCMODOLDCOD (WINBCODREC)
#  Ancienne localisation                  : WCMODOLDLOC (WINBCODREC)
#  Nouveau  code                          : WCMODNEWCOD (WINBCODREC)
#  Nouvelle localisation                  : WCMODNEWLOC (WINBCODREC)
#  Dimension du taleau des nouveaux codes : WINBCODREC

#  Code integer de l'objet maitre         : WIOBCLDR
#  Nom long de     l'objet maitre         : WCNOMOBJLONG
#  Code des rubriques par objet           : WCRUBOBC (20) (WIMAXOBC+1, 10)

If WIOBCTRT = GVML_OMBIEN
   WCNOMCLE = 'AASREF'    : WCNOMDES = 'AASDES1' :   WCNOMOBJLONG = 'FXDASSETS'
Endif

If WIOBCTRT = GVML_OMDEPEN
   WCNOMCLE = 'CODLOF'    : WCNOMDES = 'DES'     :   WCNOMOBJLONG = 'LAYOUTFAS'
Endif

If WIOBCTRT = GVML_OMLOCFI &  G_ACTLEA = G_OUI
   WCNOMCLE = 'LEAREF'    : WCNOMDES = 'LEADES'  :   WCNOMOBJLONG = 'LEASE'
Endif

If WIOBCTRT = GVML_OMSUBV
   WCNOMCLE = 'GRAREF'    : WCNOMDES = 'DES'     :   WCNOMOBJLONG = 'GRANTS'
Endif


If WIOBCTRT = GVMLOMPHY
   #--FQ107422 WCNOMCLE = 'PHYREF'    : WCNOMDES = 'PHYREF1' :   WCNOMOBJLONG = 'PHYELT'
   WCNOMCLE = 'PHYREF'    : WCNOMDES = 'PHYDES1' :   WCNOMOBJLONG = 'PHYELT'
Endif

# Tableau a 2 dimensions : Nombre d'occurrence pour la 1ère dimension (Objets cibles )
WIDIMRUB = dim(WCRUBOBC, 1)

# Tableau a 2 dimensions : Nombre d'occurrence pour la 2ème dimension (Rubriques  controles par la table)
WIDIMRUB = dim(WCRUBOBC, 2)

WI2 = 0

# Boucle sur les rubriques (controlées par la table à recodifer)  de l'objet a traiter (MAITRE ou AUTRE)
For WI2=1 To WIRUBMAX
   WINEWRUB = G_NON
   WCRUB1 = WCRUBOBC (WIOBCTRT, WI2)
   # Alimentation de WCRUB2 avec le nom de la rubrique à mettre a jour pour l'objet traité (MAITRE ou AUTRE)
   WCRUB2 = ""
   If  left$ (WCRUBOBC (WIOBCTRT, WI2),7) = "USRFLDA"
      ##------------------------------------------------------------------------------------------------##
      ## - Si la rubrique a alimenter commence par USRFLDA (Zone libre), recherche du 8ème caractére    ##
      ##   de la rubrique                                                                               ##
      ## - Lecture de la table des zones libres afin de voir, pour l'objet et la société traité,        ##
      ##   si la table a traiter contrôle cette zone libre                                              ##
      ##   Si nom rubrique = USRFLDA6 --> le nom de la Table de contrôle est dans ALPREF(5)             ##
      ##------------------------------------------------------------------------------------------------##
      If  val(mid$(WCRUB1 ,8,2)) = 10
         WIRUB  = 9
      Else
         WIRUB  = val(mid$(WCRUB1 ,8,1)) -1
      Endif
      Read [F:FRF]FRF0 = WIOBCTRT;[F:TRT]CPY
      If fstat <> 0  #*FQ-42964
         Read [F:FRF]FRF0 = WIOBCTRT;""
      Endif#*FQ-42964
      If [S]fstat = 0
         If num$([F:FRF]ALPREF(WIRUB )) = [F:CDF]TABNAM
            WCRUB2 = WCRUBOBC (WIOBCTRT, WI2)
         Endif
      Endif
      #Fq-52344 Elsif left$ ([F:CDF]TABNAM,3) = 'CCE'
      #Fq-83112 Elsif left$ ([F:CDF]TABNAM,3) = 'CCE' and ([F:OBC]DIE=[M:REC0]CCEDIE) #CHECK IGNORE_LINE
   Elsif left$ ([F:CDF]TABNAM,3) = 'CCE'
      If clalev ([M:FPC])
         I=find([F:CDF]CCEDIE, [M:FPC]DIE)
      Endif
      #---------------------------------------------------------------------------------------------------------#
      # Particularité pour les sections : le nom de la rubrique est le nom trouvé dans la
      # table des tables et suffixée par le N° d'axe - 1
      # Exemple : Dans les biens, le nom de la rubrique est CCE. Le nom mis dans WCRUB2 pour l'axe 2 est CCE(1)
      #---------------------------------------------------------------------------------------------------------#
      #Fq-83418 WIRUB = val(mid$([F:CDF]TABNAM,4,1)) - 1
      If I > 0
         WIRUB = I-1
      Endif
      If WCRUBOBC (WIOBCTRT, WI2) <> ""
         WCRUB2 = WCRUBOBC (WIOBCTRT, WI2) + '(' + num$(WIRUB)  + ')'
      Else
         WCRUB2 = ""
      Endif
    Else
        WCRUB2 = WCRUBOBC (WIOBCTRT, WI2)
    Endif

  If WCRUB2 <> ""
      # Boucle sur les valeurs d'origines pour voir s'il faut les remplacer
      For WI3=1 To WINBCODREC
             WCVALORIG    = WCMODOLDCOD (WI3)
             WCVALNOUV    = WCMODNEWCOD (WI3)
         #-------------------------------------------------------------------------------------------#
         # L'enregistrement de l'objet (MAITRE ou AUTRE) est modifié, si la rubrique de l'objet a    #
         # mettre a jour, contenait la valeur 'Avant(code)' dans le tableau de recodif et si la      #
         # nouvelle valeur est diff de l'ancienne                                                    #
         #-------------------------------------------------------------------------------------------#
           If evalue("[F:TRT]"+ WCRUB2)  = WCVALORIG  and  ( WCVALORIG <> WCVALNOUV or left$ ([F:CDF]TABNAM,3) = "CCE" )
            If [F:CDF]TABNAM <> 'FCY'
               # Indication que l'enr traité a été modifié
               WINEWCOD = G_OUI
               WINEWRUB = G_OUI
            Else
               #-- Rappel : si recodif FCY --> Objet maitre est obligatoirement FAS  -------------------#
               #-- --> on peut donc mettre [F:TRT]LOC en toutes lettres                     -------------------#
               # If WIOBCTRT = WIOBCLDR and (WCVALORIGLOC    = "" or (WCVALORIGLOC  <> "" and [F:TRT]LOC = WCVALORIGLOC))
               If ( WIOBCTRT = WIOBCLDR or WIOBCTRT = GVMLOMPHY)
                  # Indication que l'enr traité a été modifié
                  WINEWCOD = G_OUI
                  WINEWRUB = G_OUI
               Endif
            Endif
         Endif

           If WINEWRUB =  G_OUI
                  WCZONFIC = "[F:TRT]"+ WCRUB2
                  If WIEDITTRA     = G_OUI
                      If left$ ([F:CDF]TABNAM,3) = 'CCE'
                         WCNOMRUBDES  = ''
                         Read [F:AST] = GML_AXEANAL; val(mid$([F:CDF]TABNAM,4,1));GLANGUE
                         WCNOMRUBDES  = mess(46,GML_MSGREC,1) + [F:AST]LANMES + ')'
                      Elsif [F:CDF]TABNAM = 'FCY'
                         Call TEXTFIC(WCNOMOBJLONG, WCRUB1, 1, WCNOMRUBDES ) From OBJDIV
                         WCNOMRUBDES  = WCNOMRUBDES  + ' ' + mess(62,GML_MSGREC,1)
                      Else
                         Call TEXTFIC(WCNOMOBJLONG, WCRUB1, 1, WCNOMRUBDES ) From OBJDIV
                      Endif

                      #--- Edition dans le compte-rendu d'une ligne correspondant à l'enr mis à jour  ---#
                      WCLIBREF = evalue("[F:TRT]"+WCNOMCLE )
                      If  WIOBCTRT = GVML_OMDEPEN
                         WCLIBREF = WCLIBREF + '(' + num$([F:TRT]LINLOF) + ')'  #CHECK IGNORE_LINE
                      Endif
                         WCLIBCPY = [F:TRT]CPY
                         WCLIBFCY = [F:TRT]FCY
                         WCLIBDES = evalue("[F:TRT]"+WCNOMDES)

                      #--- Si on est sur un objet autre (et que l'on est pas dans le cas ou les codes   ---#
                      #--- sont supprimés) : le début de la ligne (société et site)   n'est pas édité   ---#
                      If [F:CDF]STAOLDCOD <> GVML_RECSUP and WIOBCTRT <> WIOBCLDR
                         If WIOBCTRT = GVML_OMBIEN
                             WCDESDEBUT = '  ' + format$("Kb:10X",mess(69,GML_MSGREC,1))
                         Elsif WIOBCTRT = GVML_OMDEPEN
                             WCDESDEBUT = '  ' + format$("Kb:10X",mess(66,GML_MSGREC,1))
                         Elsif WIOBCTRT = GVML_OMLOCFI
                             WCDESDEBUT = '  ' + format$("Kb:10X",mess(67,GML_MSGREC,1))
                         Elsif WIOBCTRT = GVML_OMSUBV
                             WCDESDEBUT = '  ' + format$("Kb:10X",mess(68,GML_MSGREC,1))
                         Elsif WIOBCTRT = GVMLOMPHY
                             WCDESDEBUT = '  ' + format$("Kb:10X",mess(91,GML_MSGREC,1))
                         Endif
                      Else
                             WCDESDEBUT = format$("Kb:7X", WCLIBCPY) + format$("Kb7X",WCLIBFCY  )
                         Endif
                      WCDESIFIXE = WCDESDEBUT + format$("Kb:20X", WCLIBREF  )+ '  '+ format$("KB:15X", WCLIBDES ) + '  '
&                                + format$("KB:20X",WCNOMRUBDES ) + '  '  + format$("KB:21X", WCVALORIG )
&                                + format$("KB:21X", WCVALNOUV )
                      Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCDESIFIXE  ,0,1) From TRACEABX3
                  Endif
                  #--- Stockage de la nouvelle valeur dans la rubrique de l'objet traité  (MAITRE ou AUTRE)  ---#
                  Assign  WCZONFIC  With  WCVALNOUV
                  If left$ ([F:CDF]TABNAM,3) = 'CCE'
                     Gosub CTRL_CCE
                  Endif
              Break
           Endif
        Next
     Endif
Next

Return
####################################################################
# Contrôle des sections analytiques du bien à créer
####################################################################
$CTRL_CCE

   ##Fq-83418--------- Contrôle cohérence Section analytique/site financier
   Read [CCE]CCE0=[F:CDF]CCEDIE;WCVALNOUV #CHECK IGNORE_LINE
   If fstat = 0
     #-Fq-87418 If ( [F:CCE]FCY <> "" ) and  ([F:CCE]FCY <> [F:TRT]FCY and [F:CCE]FCY <> [F:TRT]CPY )
     If ( [F:CCE]FCY <> "" )
        #-Fq-87418 GMESSAGE= "Axe"-num$([F:CCE]DIE)-" "-mess(345,GML_MSGFAS,1)-" "-WCVALNOUV-" réservée à la société/Site "-[F:CCE]FCY  # "SECTION reservée au site"
        #-Fq-87418 WCLIGNE= format$("Kb:2X", "") + format$("Kb:5X", [F:TRT]CPY) + format$("Kb:2X", "") + format$("Kb:20X", [F:TRT]AASREF)
        #-Fq-87418 &     + GMESSAGE
        #-Fq-87418 PRETOUROK  = G_NON
        #-Fq-87418 WIRETOUROK   = G_NON
        #-Fq-87418 GOK=0
        #-Fq-87418 GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,1,1) From TRACEABX3
        #-Fq-87418 Endif

         #<<<Fq-87418  Contrôle par rapport au groupe de sociétés ou de sites
         #----- Section compatible avec les sites/sociétés du groupe -----#
         Call VERIF([F:CCE]FCY,[F:TRT]FCY,WCVALNOUV) From CFYSUB
         If mkstat=2
            # "Axe n Section reservée au groupe de sites"
            GMESSAGE= "Axe"-num$([F:CCE]DIE)-" "-mess(345,GML_MSGFAS,1)-" "-WCVALNOUV-" "-mess(66,133,1)-[F:CCE]FCY
        WCLIGNE= format$("Kb:2X", "") + format$("Kb:5X", [F:TRT]CPY) + format$("Kb:2X", "") + format$("Kb:20X", [F:TRT]AASREF)
&     + GMESSAGE
        PRETOUROK  = G_NON
        WIRETOUROK   = G_NON
        GOK=0
        GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,1,1) From TRACEABX3
     Endif
         #>>>Fq-87418
     Endif
  Else
        # "Section inexistante"
        GMESSAGE= "Axe"-num$([F:TRT]DIE)-" "-mess(345,GML_MSGFAS,1)-" "-WCVALNOUV-" : "-mess(42,GML_MSGFASPR,1)  #CHECK IGNORE_LINE
        WCLIGNE= format$("Kb:2X", "") + format$("Kb:5X", [F:TRT]CPY) + format$("Kb:2X", "") + format$("Kb:20X", [F:TRT]AASREF)
&     + GMESSAGE
        PRETOUROK  = G_NON
        WIRETOUROK   = G_NON
        GOK=0
        GERRTRACE=1 : Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,1,1) From TRACEABX3
   Endif

Return
####################################################################################################
## $ALIM_NEWFCYFI_SI_FCY : Alim. du nouveau site financier si recodif du site géographique        ##
####################################################################################################
$ALIM_NEWFCYFI_SI_FCY
#----------------------------------------------------------------------------------------------#
# Lecture dans la table des sites afin de trouver le site financier correspondant a :
# Société cible (de la cession intra-groupe) + nouveau site géographique
# Rappel : la recodifcation de la table FCY ne peut se faire que par la cession intra-groupe.
#----------------------------------------------------------------------------------------------#

Filter [F:FCY] Where [F:FCY]LEGCPY = WCSOCCIBLE
Read[F:FCY] First
If [S]fstat = 0
    #----------------------------------------------------------------------------------------------#
    # Mémorisation de l'ancien  site financier de l'objet [F:TRT] (c'est à dire FAS)
    # Mémorisation du nouveau site financier pour alimentation du site financier
    #  des autres objets lié au bien FXDASSETS
    #----------------------------------------------------------------------------------------------#
    WCOLDFCYFIN = [F:TRT]FCY
    WCNEWFCYFIN = [F:FCY]FINRSPFCY
    [F:TRT]FCY  = WCNEWFCYFIN
    If [F:CDF]PROSTA = GVML_RECATR
        Call TEXTFIC(WCNOMOBJLONG, "FCY", 1, WCNOMRUBDES ) From OBJDIV
        WCDESIFIXE= format$("Kb:54X", "")    + '  ' + format$("KB:16X",WCNOMRUBDES ) + ' '
&                 + format$("KB:21X", WCOLDFCYFIN )  + format$("KB:21X", WCNEWFCYFIN)
        Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCDESIFIXE  ,0,1) From TRACEABX3
        WCDESIFIXE = ""
    Endif
Else
    #
Endif

Filter [F:FCY]
WCDESIFIXE = ""

Return

####################################################################################################
## $TRT_TOUS_AUTRES_OBC : Boucle sur les objets AUTRES sélectionnés pour les traiter              ##
####################################################################################################
$TRT_TOUS_AUTRES_OBC
Local Integer WI6

# Traitements de tous les objets sélectionnés sauf objet maitre (car il est déjà traité)

# MHB 30/07/08 - jusqu'à 6 pour boucler aussi sur les éléments physiques
# For WI6=1 To 5
For WI6=1 To WIMAXOBC
   If WIOBCSEL (WI6)  = G_OUI and WI6  <> WIOBCLDR
         # WI6 = N° de l'objet autres
         WIOBCAUT = WI6
         Gosub TRT_UN_AUTRE_OBC
   Endif
Next

Return
####################################################################################################
## $TRT_UN_AUTRE_OBC  : Traitement de l'objet AUTRE sélectionné afin de le traiter                ##
####################################################################################################
$TRT_UN_AUTRE_OBC

##------------------------------------------------------------------------------------------------##
##                                                                                                ##
## L'enregistrement maitre lu est dans [F:OBC]                                                    ##
##                                                                                                ##
## Si objet maitre FAS (Bien comptable) : il n'y a pas besoin de rechercher le bien comptable     ##
##                                        lié  car on est déjà sur un bien                        ##
##                                                                                                ##
## Si objet maitre est LEA (Contrat)    : Recherche des biens comptables liés au contrat          ##
##                                                                                                ##
## Si objet maitre est GRT (Subvention) : Recherche des biens comptables liés à la subvention     ##
##                                        (Même projet d'investissement)                          ##
##                                                                                                ##
## Si objet maitre est LOF (Dépense)    : il n'y a pas besoin de rechercher le bien comptable lié ##
##   - LOF (Dépense) car on ne sélectionne que les dépenses non liées aux biens                   ##
##                                                                                                ##
## Si objet maitre est LOF (Dépense)    : il n'y a pas besoin de rechercher le bien comptable lié ##
##------------------------------------------------------------------------------------------------##

If WIOBCLDR = GVML_OMLOCFI or WIOBCLDR = GVML_OMSUBV
     If WCWHEREFAS <> ""
        Filter[F:FAS] Where evalue(WCWHEREFAS )
     Else
        Filter[F:FAS]
     Endif

     For [F:FAS]
            Gosub TRT_OBJAUT_POUR_UN_FAS
     Next
     Filter[F:FAS]

Elsif WIOBCLDR = GVML_OMBIEN
     [F:FAS] = [F:OBC]
     Gosub TRT_OBJAUT_POUR_UN_FAS
Endif

Return
####################################################################################################
## $TRT_OBJAUT_POUR_UN_FAS : Traitement de l'objet AUTRE lié à l'enreg. de l'objet MAITRE traité  ##
####################################################################################################
TRT_OBJAUT_POUR_UN_FAS

Local Char    WCNOMCLE
Local Char    WCNOMOBJLONG
Local Char    WCNOMDES
Local Date    WDDATE (1..5)
Local Date    WDDATDERCLOT
Local Integer WICODERET
Local Integer WIENRSEL
Local Char    WCWHEREAUT (255)

##---------------------------------------------------------------------------------------------------------##
## [F:AUT] : classe de l'objet AUTRE sur laquelle on va fait un For (Boucle sur tous les enregsitrements)  ##
## [F:TRT] : classe qu'on va transmettre a l'étiquette ALIM_NEWCOD_DS_ENREGISTREMENT                       ##
##---------------------------------------------------------------------------------------------------------##
If clalev([F:AUT]) <> 0  :     Close Local File [AUT] : Endif

If WIOBCAUT = GVML_OMBIEN
   If clalev([F:AUT]) =  0 : Local File FXDASSETS [AUT]  : Endif          : # Biens comptables
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File FXDASSETS [TRT]
Endif

If WIOBCAUT = GVML_OMDEPEN
   If clalev([F:AUT])  =0 : Local File LAYOUTFAS [AUT]   : Endif          : # Dépenses
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LAYOUTFAS [TRT]
Endif

If WIOBCAUT = GVML_OMLOCFI & G_ACTLEA = G_OUI
   If clalev([F:AUT])  =0 : Local File LEASE [AUT]       : Endif          : # Contrat financement
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File LEASE [TRT]
Endif

If WIOBCAUT = GVML_OMSUBV  &   G_ACTGRT = G_OUI
   If clalev([F:AUT])  =0 : Local File GRANTS [AUT]      : Endif          : # Subvention
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File GRANTS [TRT]
Endif

If WIOBCAUT = GVMLOMPHY
   If clalev([F:AUT])  =0 : Local File PHYELT [AUT]      : Endif          : # Eléments physiques
   If clalev([F:TRT]) <> 0 : Close Local File [TRT]      : Endif  : Local File PHYELT [TRT]
Endif

##------------------------------------------------------------------------------------------------##
## 1) Sélection fixe standard sur la table de l'objet AUTRE                                       ##
## 2) Sélection sur la table de l'objet AUTRE, en fonction de l'enr de l'objet FAS lu (lui-même   ##
##    lié à l'objet maître traité)                                                                ##
## 3) Boucle sur les enregistrements AUT sélectionnés --> Traitement de recodification            ##
##------------------------------------------------------------------------------------------------##

##--  Sélection fixe standard sur la table de l'objet AUTRE      ---------------------------------##
##--  Uniquement si Statut ancien code <> Supprimé car sinon on prend tous les enregsitrements  --##

WCWHEREAUT = " "
If [F:CDF]STAOLDCOD <> GVML_RECSUP
   Gosub ALIM_WCWHERE_AUT
Endif

##---- 2) Sélection sur la table de l'objet AUTRE, en fonction de l'enr de l'objet [FAS] traité  -##
Gosub ALIM_WCWHERE_LIAISON_AUT

##---- 3) Boucle sur les enregistrements AUT sélectionnés --> Traitement de recodification -------##
If ( clalev([F:AUT]))
  If WCWHEREAUT <> ""
      Filter[F:AUT] Where evalue(WCWHEREAUT)
  Else
      Filter[F:AUT]
  Endif
  For [F:AUT] With Stability
     ##------------------------------------------------------------------------------------------##
     ## Si statut ancien code <> Supprimé                                                        ##
     ## - Rejet des enregistrements 'Biens' si bien sortie dans exercices antérieurs             ##
     ##   Ceci n'a pas pu être mis dans le filter car la condition dépend de la société          ##
     ##------------------------------------------------------------------------------------------##
     WIENRSEL = G_OUI
     If [F:CDF]STAOLDCOD <> GVML_RECSUP
         If WIOBCAUT = GVML_OMBIEN
             ##------------------------------------------------------------------------------------------##
             # Appel d'une fonction qui rend la date de dernière cloture pour un contexte transmis
             # G300CPFI Global du contexte comptable et fiscal
             ##------------------------------------------------------------------------------------------##
             WDDATE (5) = [0/0/0]
             Call GET_CNX_DAT([F:AUT]CPY ,G300CPFI,WDDATE,WICODERET) From GLOBIENS
             WDDATDERCLOT = WDDATE(5)
             If [F:AUT]ISSDAT <> [0/0/0] and [F:AUT]ISSDAT <= WDDATDERCLOT
                WIENRSEL = G_NON
             Endif
         Endif
     Endif

    If  WIENRSEL = G_OUI
         Gosub RECODIF_ENR_OBJET_AUTRES
    Endif
  Next
  Filter[F:AUT]
Endif
Return
####################################################################################################
## $RECODIF_ENR_OBJET_AUTRES : recodification d'un enregistrement de l'objet AUTRE               ##
####################################################################################################
$RECODIF_ENR_OBJET_AUTRES

Local Integer I
Local Integer WIRECAUTOK
Local Integer WIRELSILENC
Local Integer WINEWCOD

GOK = 1

If [F:CDF]PROSTA = GVML_RECATR
     GTRANS=1
Endif

WIRECAUTOK = G_OUI
WINEWCOD   = G_NON

##------------------------------------------------------------------------------------------------##
## Alimentation des rubriques d'un enregistrement si codes modifiés                               ##
##------------------------------------------------------------------------------------------------##

WIOBCTRT = WIOBCAUT
[F:TRT] = [F:AUT]
Gosub ALIM_NEWCOD_DS_ENREGISTREMENT

# Alimentation du Site financier s'il a changé
If WCNEWFCYFIN <> ""
    WINEWCOD = G_OUI
    [F:TRT]FCY =  WCNEWFCYFIN
Endif

# Numérotation élément physique à partir du bien
##------------------------------------------------------------------------------------------------##
## Si traitement 'Cession intra-groupe' et la localisation a été changée                          ##
##           --> Alimentation du nouveau site géographique                                        ##
##           --> Alimentation du nouveau site financier                                           ##
##------------------------------------------------------------------------------------------------##

[F:AUT] = [F:TRT]

##------------------------------------------------------------------------------------------------##
## Maj du bien si le relevé est validé                                                            ##
##------------------------------------------------------------------------------------------------##

If WINEWCOD =  G_OUI
    #
    WINBMAJLDR +=1
    If WIOBCAUT = GVML_OMBIEN  :  WINBMAJFAS +=1 :  Endif
    If WIOBCAUT = GVML_OMDEPEN :  WINBMAJLOF +=1 :  Endif
    If WIOBCAUT = GVML_OMLOCFI :  WINBMAJLEA +=1 :  Endif
    If WIOBCAUT = GVML_OMSUBV  :  WINBMAJGRT +=1 :  Endif
    If WIOBCAUT = GVMLOMPHY    :  WINBMAJPHY +=1 :  Endif

    #- si pas simu : rewrite----------------------------------------------------------------------##
    If PFLGSIM  = G_NON and  PRETOUROK    = G_OUI
        Rewrite [F:AUT]
        If fstat = 1
                WIRECAUTOK = G_NON
                WCLIGNE= mess(15,GML_MSGREC,1) + '  ' + WCNOMOBJLONG +  '   ' + evalue("[F:AUT]"+WCNOMCLE )
                Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
        Elsif fstat <> 0
                GOK = 0 : Call FSTA("AUT") From GLOCK
                Return
        Endif
        #
    Endif

Endif

Return
####################################################################################################
## EDIT_DEB_COMPTERENDU : Edition du début du compte-rendu                                        ##
####################################################################################################
$EDIT_DEB_COMPTERENDU

Local Char WCDATE1
Local Char WCMESSOBJLDR

WCREFCDF    =  [F:CDF]REFCDF
WCTABNAM    =  [F:CDF]TABNAM
WCREFTRFCMP =  [F:CDF]REFTRFCMP
WIPROSTA    =  [F:CDF]PROSTA
WISTAOLDCOD =  [F:CDF]STAOLDCOD

#--------- Lecture du libelle de la table  -------------------------------------------------------##
Gosub LECT_NOMTABDES

##------------------------------------------------------------------------------------------------##
## - Edition des paramètres de traitement                                                         ##
##------------------------------------------------------------------------------------------------##

## Si cession intra-groupe : on ne réouvre pas la trace car elle est déjà ouverte                 ##
If [F:CDF]PROSTA = GVML_RECATR
   If !GSERVEUR : Call OUVRE_TRACE_FIC (mess(02,GML_MSGREC,1),1) From TRACEABX3 : Endif
Endif

WCLIGNE="===================================================================================================================="
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="                            " + mess(01,GML_MSGREC,1) + "                                             "
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="===================================================================================================================="
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3

If [F:CDF]PROSTA = GVML_RECATR
  WCDESIFIXE= format$("Kb:60X", mess(03,GML_MSGREC,1))
  Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + WCNOMPROG ,0,1) From TRACEABX3
Endif
WCDESIFIXE= format$("Kb:60X", mess(16,GML_MSGREC,1))
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + WCREFCDF - [F:CDF]REFDES ,0,1) From TRACEABX3
WCDESIFIXE= format$("Kb:60X", mess(04,GML_MSGREC,1))
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + WCTABNAM - WCTABNAMDES  ,0,1) From TRACEABX3
If [F:CDF]PROSTA = GVML_RECATR
    #--> Statut du traitement
    WCDESIFIXE= format$("Kb:60X", mess(06,GML_MSGREC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess(WIPROSTA,GML_RECSTA,1) ,0,1) From TRACEABX3
    #--> Statut ancien code
    WCDESIFIXE= format$("Kb:60X", mess(07,GML_MSGREC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess(WISTAOLDCOD,GML_RECANC,1)  ,0,1) From TRACEABX3
Endif

If [F:CDF]STAOLDCOD = GVML_RECSUP
    If [F:CDF]DATENDACT = [0/0/0]
       WCDATE1  = ""
    Else
       WCDATE1  = format$("DD2",[F:CDF]DATENDACT)
    Endif
    #--> Date de fin de validité
    WCDESIFIXE= format$("Kb:60X", mess(08,GML_MSGREC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + WCDATE1 ,0,1 ) From TRACEABX3
Endif

#--> Indicateur maj associations  : oui/non
If [F:CDF]FLGUPDASS = G_OUI   WCOUINON  = mess(2,1,1) Else  WCOUINON  = mess(1,1,1)  Endif
#--> Maj des associations
WCDESIFIXE= format$("Kb:60X", mess(09,GML_MSGREC,1))
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  + " : " + WCOUINON  ,0,1) From TRACEABX3

If [F:CDF]PROSTA = GVML_RECATR
    If PFLGSIM  = G_OUI   WCOUINON  = mess(2,1,1) Else  WCOUINON  = mess(1,1,1)  Endif
    #--> Simulation  : oui/non
    WCDESIFIXE= format$("Kb:60X", mess(10,GML_MSGREC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  + " : " + WCOUINON  ,0,1) From TRACEABX3
     #--> Edition trace  : oui/non
    If WIEDITTRA   = G_OUI   WCOUINON  = mess(2,1,1) Else  WCOUINON  = mess(1,1,1)  Endif
    WCDESIFIXE= format$("Kb:60X", mess(11,GML_MSGREC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE  + " : " + WCOUINON  ,0,1) From TRACEABX3
Endif

If [F:CDF]PROSTA = GVML_RECATR
    If [F:CDF]OBCLDR = 0
       WCMESSOBJLDR = ""
    Else
       WCMESSOBJLDR = mess([F:CDF]OBCLDR,GML_OBJMETIE,1)
    Endif
    # --> Objet maître
    WCDESIFIXE= format$("KB:60X", mess(41,GML_MSGREC,1))
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + WCMESSOBJLDR ,0,1 ) From TRACEABX3
    If [F:CDF]OBCPCDFAS = G_OUI
     # --> Objet sélectionné
      WCDESIFIXE= format$("Kb:62X", mess(42,GML_MSGREC,1))
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess(GVML_OMBIEN,GML_OBJMETIE,1),0,1 ) From TRACEABX3
    Endif
    If [F:CDF]OBCPCDLOF = G_OUI
      WCDESIFIXE= format$("Kb:62X", mess(42,GML_MSGREC,1))
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess(GVML_OMDEPEN,GML_OBJMETIE,1),0,1 ) From TRACEABX3
    Endif
    If [F:CDF]OBCPCDLEA = G_OUI
      WCDESIFIXE= format$("Kb:62X", mess(42,GML_MSGREC,1))
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess(GVML_OMLOCFI,GML_OBJMETIE,1),0,1 ) From TRACEABX3
    Endif
    If [F:CDF]OBCPCDGRT = G_OUI
      WCDESIFIXE= format$("Kb:62X", mess(42,GML_MSGREC,1))
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess(GVML_OMSUBV,GML_OBJMETIE,1),0,1 ) From TRACEABX3
    Endif
    If [F:CDF]OBCPCDPHY = G_OUI
      WCDESIFIXE= format$("Kb:62X", mess(42,GML_MSGREC,1))
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCDESIFIXE + " : " + mess(GVMLOMPHY,GML_OBJMETIE,1),0,1 ) From TRACEABX3
    Endif
Endif

If  [F:CDF]STAOLDCOD <>  GVML_RECSUP and WIEDITTRA     = G_OUI
  #--> LISTE DES ENREGISTREMENTS MIS A JOUR
  WCLIGNE="===================================================================================================================="
  Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE= format$("KB:35X",  "" ) + mess(12,GML_MSGREC,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="===================================================================================================================="
  Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
  #--> Soc. Site Référence Libelle Rubrique Ancienne valeur Nouvelle valeur
  WCLIGNE= mess(16,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
  WCLIGNE="---    ---- ---------           ---------------         -------------    ---------------      ---------------"
  Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
Endif

Return
####################################################################################################
## $LECT_NOMTABDES : Lecture du libelle de la table                                               ##
####################################################################################################
$LECT_NOMTABDES
Local Char    WCTABNAMDES
Local Integer WINUMTEXTE

#*FQ107562
If[F:CDF]TABNAM = 'FAM'
   WINUMTEXTE = 0
   Read [F:ATB]ABRFIC = [F:CDF]TABNAM
   If [S]fstat = 0
      WINUMTEXTE = [F:ATB]INTITFIC
      Read [F:ATX2]= GLANGUE;WINUMTEXTE
      If [S]fstat = 0
        WCTABNAMDES = [F:ATX2]TEXTE
      Endif
   Endif
Elsif [F:CDF]TABNAM = 'FCY'
   WINUMTEXTE = 0
   Read [F:ATB]ABRFIC = [F:CDF]TABNAM
   If [S]fstat = 0
      WINUMTEXTE = [F:ATB]INTITFIC
      Read [F:ATX2]= GLANGUE;WINUMTEXTE
      If [S]fstat = 0
         #-->  (Géographique)
         WCTABNAMDES = [F:ATX2]TEXTE + ' ' + mess(61,GML_MSGREC,1)
      Endif
   Endif
Elsif left$ ([F:CDF]TABNAM,3) = 'CCE'
   Read [F:AST] = GML_AXEANAL; val(mid$([F:CDF]TABNAM,4,1));GLANGUE
   If [S]fstat = 0
      #--> Section (
      WCTABNAMDES = mess(46,GML_MSGREC,1) + [F:AST]LANMES + ')'
   Endif
Elsif [F:CDF]TABNAM <> ''
   Call LECTEXTRA(WCTABNAMDES,"ATABTAB","LNGDES",num$([F:CDF]TABNAM), "" ) From ATEXTRA
Endif

Return
####################################################################################################
## EDIT_FIN_COMPTERENDU : Edition du début du compte-rendu                                            ##
####################################################################################################
$EDIT_FIN_COMPTERENDU

##------------------------------------------------------------------------------------------------##
## - Edition des compteurs  de enregistrement traités                                             ##
##------------------------------------------------------------------------------------------------##
WCLIGNE="===================================================================================================================="
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
#--> STATISTIQUES
WCLIGNE=  format$("KB:35X",  "" ) + mess(17,GML_MSGREC,1)+ format$("KB:25X",  "" )
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
WCLIGNE="===================================================================================================================="
Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3

If  [F:CDF]STAOLDCOD = GVML_RECSUP
    #--> Nombre d'enregistrements pour l'ensemble des objets à traiter
    WCLIGNE= format$("KB:70X", mess(74,GML_MSGREC,1) + ' ') + format$("KB:10X", "" ) + " : " +    num$(WINBTOT)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> Nombre d'enregistrements mis à jour sur l'entité Bien comptable
    WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1) ) + format$("KB:20X",mess(GVML_OMBIEN,GML_OBJMETIE,1) )   + " : " + num$(WINBMAJFAS)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> Nombre d'enregistrements mis à jour sur l'entité Dépense
    WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1) ) + format$("KB:20X",mess(GVML_OMDEPEN,GML_OBJMETIE,1) )  + " : " + num$(WINBMAJLOF)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> Nombre d'enregistrements mis à jour sur l'entité Contrat de location
    WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1) ) + format$("KB:20X",mess(GVML_OMLOCFI,GML_OBJMETIE,1) )  + " : " + num$(WINBMAJLEA)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> Nombre d'enregistrements mis à jour sur l'entité Subventions
    WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1) ) + format$("KB:20X",mess(GVML_OMSUBV,GML_OBJMETIE,1) )   + " : " + num$(WINBMAJGRT)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    #--> Nombre d'enregistrements mis à jour sur l'entité Elément Physique
    WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1) ) + format$("KB:20X",mess(GVMLOMPHY,GML_OBJMETIE,1) )     + " : " + num$(WINBMAJPHY)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
Else
    #--> Nombre de codes à recodifier
    WCLIGNE= format$("KB:80X", mess(13,GML_MSGREC,1)) + " : " +    num$(WINBCODREC)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1) + ' ' + mess(59,GML_MSGREC,1)) + format$("KB:20X",mess([F:CDF]OBCLDR,GML_OBJMETIE,1) ) + " : " + num$(WINBMAJLDR)
    Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3

    WCLIGNE= "" :  Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3

    If [F:CDF]OBCPCDFAS = G_OUI and [F:CDF]OBCLDR <> GVML_OMBIEN
      WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1) ) + format$("KB:20X",mess(GVML_OMBIEN,GML_OBJMETIE,1) ) + " : " + num$(WINBMAJFAS)
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Endif

    If [F:CDF]OBCPCDLOF = G_OUI and [F:CDF]OBCLDR <> GVML_OMDEPEN
      WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1)) + format$("KB:20X",mess(GVML_OMDEPEN,GML_OBJMETIE,1) ) + " : " + num$(WINBMAJLOF)
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Endif

    If [F:CDF]OBCPCDLEA = G_OUI and [F:CDF]OBCLDR <> GVML_OMLOCFI
      WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1)) + format$("KB:20X",mess(GVML_OMLOCFI,GML_OBJMETIE,1) ) + " : " + num$(WINBMAJLEA)
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Endif

    If [F:CDF]OBCPCDGRT = G_OUI and [F:CDF]OBCLDR <> GVML_OMSUBV
      WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1)) + format$("KB:20X",mess(GVML_OMSUBV,GML_OBJMETIE,1) ) + " : " +  num$(WINBMAJGRT)
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Endif

    If [F:CDF]OBCPCDPHY = G_OUI and [F:CDF]OBCLDR <> GVMLOMPHY
      WCLIGNE= format$("KB:60X", mess(43,GML_MSGREC,1)) + format$("KB:20X",mess(GVMLOMPHY,GML_OBJMETIE,1) )    + " : " + num$(WINBMAJPHY)
      Call ECR_TRACE_FIC ("",GTRC_PARAM,WCLIGNE,0,1) From TRACEABX3
    Endif

    WINBMAJIVY   = 0
Endif

Return
####################################################################################################
## $LOCK_ALL : Test si la société est lockée pour l'objet traité                                 ##
####################################################################################################
$LOCK_ALL
Local Char    WCOBJLOCK
Local Char    WCMESS1 (120)
Local Char    WCMESS2 (120)
Local Integer WINAMOBJ

For WISOCLOCK=0 To NBR_CPY-1
    If LIST_CPY(WISOCLOCK) <> ""
        # For WINAMOBJ=1 To 5
        #Fq-52344 For WINAMOBJ=1 To WIMAXOBC
        For WINAMOBJ=0 To WIMAXOBC-1
           WIUNOBJLOCK = G_NON
           If WIOBCSEL (WINAMOBJ) = G_OUI
               WCOBJLOCK = WCOBCSEL (WINAMOBJ)
               #---- Test si la société est lockée pour l'objet a traiter ----------------------#
               Gosub LOCK_SOC_OBJET
               If WIUNOBJLOCK = G_OUI
                   WIALLOBJLOCK = G_OUI
               Endif
           Endif
        Next
     Endif
Next

If WIALLOBJLOCK = G_OUI
    # Les enregistrements de la société sont verrouillés par un autre processus. Il ne peut être utilisé.
    #--> Arrêt du traitement de recodification
    WCMESS1  = mess(70,GML_MSGREC,1)
    #--> Un des objets à traiter est en cours d'utilisation (voir explication dans le compte-rendu)
    WCMESS2  = mess(71,GML_MSGREC,1)
    Errbox  WCMESS1,WCMESS2
    GOK=0
    OK=0
    Gosub UNLOCK_SOC_OBJET
    Return
Endif

Return
####################################################################################################
## LOCK_SOC_OBJET : Lock de la société d'un objet                                                 ##
####################################################################################################
$LOCK_SOC_OBJET
Local Integer WILOCK
Local Char WCOBJLOCKLG
Local Char WCUSERLOCK (80)

#--- Test si les enregistrements de la société déjà lockés (WILOCK =0) ---##
#--- si non , lockage des enregistrements de la société  ---##

WILOCK =  func GLOBIENS.IS_SYMBOLE_LOCKED (WCOBJLOCK , LIST_CPY(WISOCLOCK), "")


If WILOCK = 1
    WILOCK =  func GLOBIENS.LOCK_SYMBOLE (WCOBJLOCK , LIST_CPY(WISOCLOCK), "", 5 )
Elsif WILOCK = 0

    #--- Si le titre des erreurs n'a pas été édité --> edition -------------------------------------------##
    If WIERRTITRE   = G_NON
        WCLIGNE="===================================================================================================================="
        Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
        #--> LISTE DES ERREURS
        WCLIGNE= format$("KB:35X",  "" ) + mess(14,GML_MSGREC,1)
        Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
        WCLIGNE="===================================================================================================================="
        Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
        WIERRTITRE    = G_OUI
    Endif

   #--- Recherche du nom de la table lockée --------------------------------------------------------------##
   Read [F:ATB]ABRFIC = WCOBJLOCK
   If [S]fstat =  0
        # Décodification de l'intitulé qui a été récupéré sous forme de nombre
        Call TEXTE([F:ATB]INTITFIC,WCOBJLOCKLG ) From OBJDIV
   Endif

   #--- Recherche de l'utilisateur qui lock --------------------------------------------------------------##

   WCUSERLOCK = func GLOBIENS.QUI_LOCKE ()
   WIUNOBJLOCK = G_OUI
   #--- Edition de la ligne d'erreur           -----------------------------------------------------------##
   WCLIGNE= mess(2,GML_MSGREC,1) - ' : ' - mess(72,GML_MSGREC,1) -  "'" + WCOBJLOCKLG + "'" + " " + mess(73,GML_MSGREC,1) - LIST_CPY(WISOCLOCK) + '.    ' + WCUSERLOCK
   Call ECR_TRACE_FIC ("",GTRC_CRERREU,WCLIGNE,0,1) From TRACEABX3
Endif

Return

####################################################################################################
## $UNLOCK_ALL : Test si la société est lockée pour l'objet traité                                 ##
####################################################################################################
$UNLOCK_ALL
Local Char    WCOBJLOCK
Local Char    WCMESS1 (120)
Local Char    WCMESS2 (120)
Local Integer WINAMOBJ
Local Integer WIALLOBJLOCK
Local Integer WIUNOBJLOCK

WIUNOBJLOCK= G_NON
WIALLOBJLOCK= G_NON

For WISOCLOCK=0 To NBR_CPY-1
    If LIST_CPY(WISOCLOCK) <> ""
        # For WINAMOBJ=1 To 5
        #Fq-52344 For WINAMOBJ=1 To WIMAXOBC
        For WINAMOBJ=0 To WIMAXOBC-1
           WIUNOBJLOCK = G_NON
           If WIOBCSEL (WINAMOBJ) = G_OUI
               WCOBJLOCK = WCOBCSEL (WINAMOBJ)
               #---- Test si la société est lockée pour l'objet a traiter ----------------------#
               Gosub UNLOCK_SOC_OBJET
           Endif
        Next
     Endif
Next

Return
####################################################################################################
## UNLOCK_SOC_OBJET : Unlock de la société d'un objet                                             ##
####################################################################################################
$UNLOCK_SOC_OBJET

Call  UNLOCK_SYMBOLE (WCOBJLOCK , LIST_CPY(WISOCLOCK), "") From GLOBIENS

Return
####################################################################################################
## TRT_MAJ_ASSOCIATION : Maj des associations on traite la table Famille                          ##
##                       et si la famille est déterminante                                        ##
####################################################################################################
$TRT_MAJ_ASSOCIATION

Local Integer WI8

If [F:CDF]TABNAM = 'FAM'

    If  WIEDITTRA     = G_OUI
       WCLIGNE="===================================================================================================================="
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
       #--> LISTE DES ASSOCIATIONS MISES A JOUR
       WCLIGNE= format$("KB:35X",  "" ) + mess(77,GML_MSGREC,1)
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
       WCLIGNE="===================================================================================================================="
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
       #--> Soc. Objet Rubrique déterminante Ancienne valeur Nouvelle valeur
       WCLIGNE= mess(17,GML_MSGTRC,1)  :  Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
       WCLIGNE="---    -----            ---------------------           ---------------     -------------   "
       Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
    Endif

    ## Boucle sur le tableau des nouveaux codes recodifiés
    For WI8=1 To WINBCODREC

        ## recherche si valeur d'un des postes a recodifer est une valeur déterminante
        Filter[F:RVA] Where ([F:RVA]DETAAS = GVML_DTAFAM and [F:RVA]VALDETAAS = WCMODOLDCOD (WI8))

        For [F:RVA]  With Stability
           # Si dans la liste des sociétés, on retrouve la société qu'on vient de lire par le For --> c'est ok
           #Fq-84345 If find([F:RVA]CPY,LIST_CPY) <> 0
           If find([F:RVA]CPY,LIST_CPY)
              [F:WRVA] = [F:RVA]
              [F:WRVA]VALDETAAS = WCMODNEWCOD (WI8)
              If PFLGSIM     = G_NON and  PRETOUROK    = G_OUI
                 Write [F:WRVA]
                 If [S]fstat <> 0
                   Infbox 'write RVA stat = ' + num$( fstat )
                 Endif
              Endif
              WCLIGNE= format$("KB:7X", [F:RVA]CPY)  + format$("KB:17X", mess([F:RVA]REFOBJ,GML_OBJMETIE,1))
&                    + format$("KB:33X", mess([F:RVA]DETAAS,GML_DETASSO,1)) + format$("KB:19X", WCMODOLDCOD (WI8))
&                    + format$("KB:20X", WCMODNEWCOD (WI8))
              Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
          Endif
        Next #[RVA]
        Filter[F:RVA]

      #*FQ107562 Ajout traitement des associations/ plans
      Filter[F:RVP] Where (DETAAS = GVML_DTAFAM and VALDETAAS = WCMODOLDCOD (WI8))
      For [F:RVP]  With Stability
        If find([F:RVP]CPY,LIST_CPY)
          [F:WRVP] = [F:RVP]
          [F:WRVP]VALDETAAS = WCMODNEWCOD (WI8)
          If PFLGSIM   = G_NON and  PRETOUROK  = G_OUI
            Write [F:WRVP]
            If [S]fstat <> 0
              Infbox 'write RVP stat = ' + num$( fstat )
            Endif
          Endif
          WCLIGNE= format$("KB:7X", [F:RVP]CPY)  + format$("KB:17X", mess([F:RVP]REFOBJ,GML_OBJMETIE,1))
&                + format$("KB:33X", mess([F:RVP]DETAAS,GML_DETASSO,1)) + format$("KB:19X", WCMODOLDCOD (WI8))
&                + format$("KB:20X", WCMODNEWCOD (WI8))
           Call ECR_TRACE_FIC ("",GTRC_CRACTIO,WCLIGNE,0,1) From TRACEABX3
        Endif
      Next #[RVP]
      Filter[F:RVP]  #*FQ107562/
    Next

Endif

Return

