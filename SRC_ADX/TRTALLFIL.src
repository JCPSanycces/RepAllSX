#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque ALLFIL
#CHECK UNUSED_BEGIN
Local Char PARAM(250)(1..20) , SAVACT(10)
PARAM(1) = "SOQ1"
PARAM(2) = num$(0)
PARAM(3) = num$("MAR")
PARAM(4) = num$("A-TS5")
PARAM(5) = num$("CDE001")
Local Decimal VALEUR
#SAVACT = GACTION : GACTION = "SAIALLFIL"
Call SAISIE_NUM(VALEUR,PARAM,"IALLFIL","TRTALLFIL") From GSAISIE
#GACTION = SAVACT
End
#CHECK UNUSED_END

#########################################################################
# TRTALLFIL    Saisie du filtre allocation pour les OF et commandes     #
#              Action : SAIALLFIL                                       #
#########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

#########################################################################
$OUVRE_BOITE
Local  Char     WABMSK : WABMSK  = PARAM(1)
Local  Integer  WNOL   : WNOL    = val(PARAM(2))
Local  Integer  I,J, LRET
Local  Char     WTRUCOD(GLONTRU)
Local  Shortint WA,WQ,WR
Local  Integer  WTRSTYP
Global Integer  GFILTREAQR

#--- Issue X3-4501 : ajout "PJTA1" tache affaire
Case WABMSK
 When "SOH4","SOQ1","PJTA1" : GBIDC1  = mess(2,701,1)
                              GLOCSEL = "[F:STC]LOCCAT<>3&[F:STC]LOCCAT<>4"
 When "MFG2"                : GBIDC1  = mess(10,701,1)
                              GLOCSEL = "[F:STC]LOCCAT<>3"
 When Default               : GBIDC1  = mess(12,107,1)
                              GLOCSEL = "[F:STC]LOCCAT<>3&[F:STC]LOCCAT<>4"
Endcase

If clalev([F:ITM])=0 Local File ITMMASTER  [ITM] Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF] Endif
If clalev([F:ITG])=0 Local File ITMCATEG   [ITG] Endif
If clalev([F:TRU])=0 Local File TABALLRUL  [TRU] Endif
If clalev([F:SRU])=0 Local File TABSTORUL  [SRU] Endif
If clalev([F:STL])=0 Local File STOLOT     [STL] Endif

If PARAM(4)<>[F:ITM]ITMREF
   Read [ITM]ITM0=PARAM(4)
Endif
If PARAM(4)<>[F:ITM]ITMREF | PARAM(3)<>[F:ITF]STOFCY
   Read [ITF]ITF0=PARAM(4);PARAM(3)
Endif
#--- Lecture catégorie article/site
Read [ITG]ITG1=[F:ITM]TCLCOD;PARAM(3)
If fstat
   Read [ITG]ITG1=[F:ITM]TCLCOD;""
   If fstat Raz [F:ITG] Endif
Endif

# Récupération de la règle d'allocation
#--- Issue X3-4501 : ajout "PJTA1" tache affaire
Case WABMSK
 When "SOH4"          : WTRUCOD = [F:ITG]ALLRULORD
                        If [M:SOH0]SOHCAT=2
                           WTRSTYP = 17
                        Else
                           WTRSTYP = 4
                        Endif
 When "SOQ1", "PJTA1" : WTRUCOD = [F:ITG]ALLRULORD
                      : WTRSTYP = 4
 When "MFG2"          : WTRUCOD = [F:ITG]ALLRULMAT
                        If [M:MFG2]SCOFLG(WNOL)=2
                           WTRSTYP = 29
                        Else
                      :    WTRSTYP = 6
                        Endif
 When Default         : WTRUCOD = [F:ITG]ALLRULORD
                      : WTRSTYP = 4
Endcase

Raz [F:TRU]
If WTRUCOD<>""
   # Lecture règle d'allocation
   Read [TRU]TRU0=WTRUCOD
   If fstat Raz WTRUCOD Endif
Endif

If WTRUCOD<>""
   # Statuts autorisés par les règles d'allocation
   For I=0 To dim([F:TRU]STAFLT)-1
      If [F:TRU]STAFLT(I)<>0
         If find([F:TRU]STAFLT(I),1,3,5,7) WA=1  Endif
         If find([F:TRU]STAFLT(I),2,3,6,7) WQ=1  Endif
         If find([F:TRU]STAFLT(I),4,5,6,7) WR=1  Endif
      Endif
   Next I
Else
   WA=1
Endif
GFILTREAQR = WA+2*WQ+4*WR

# Lecture de la règle de gestion à utiliser
Call LECSRU(PARAM(3),[F:ITM]TCLCOD,WTRSTYP,"","",LRET)
&           From STKLIB
If LRET<>0 [F:SRU]AUZSST="" Endif

Gosub FORMAT_INV From STKLIB

# Pas de type d'emplacement en saisie du filtre allocation
GWSINVEMPT = "-"+GSINVEMPT
GWSINTEMPT = ""

Return

#########################################################################
$DEBUT

Raz [M:ALF]

[M:ALF]STOFCY = PARAM(3)
[M:ALF]ITMREF = PARAM(4)
[M:ALF]VCRNUM = PARAM(5)
[M:ALF]VCRTYP = 2
If WABMSK="MFG2" [M:ALF]VCRTYP=10 Endif

If dim([M:ALF]LOT)>0 [M:ALF]LOT=evalue("[M:"+WABMSK+"]LOT("+num$(WNOL)+")") Endif
If dim([M:ALF]LOC)>0 [M:ALF]LOC=evalue("[M:"+WABMSK+"]LOC("+num$(WNOL)+")") Endif
[M:ALF]STA=evalue("[M:"+WABMSK+"]STA("+num$(WNOL)+")")

Affzo [M:ALF]

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR

If dim([M:ALF]LOT)>0
   Assign "[M:"+WABMSK+"]LOT("+num$(WNOL)+")" With [M:ALF]LOT
Endif
If dim([M:ALF]LOC)>0
   Assign "[M:"+WABMSK+"]LOC("+num$(WNOL)+")" With [M:ALF]LOC
Endif
Assign "[M:"+WABMSK+"]STA("+num$(WNOL)+")" With [M:ALF]STA

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

#########################################################################
$FINSAI

If GOK=1 mkstat=4 Endif

Return

#########################################################################
# Action sur les champs de l'écran ALLFIL
#########################################################################

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" & right$(VALEUR,len(VALEUR))<> "*"
   Read [STL]STL0(2)=[M:ALF]ITMREF;VALEUR
   If fstat
      mkstat=2 : GMESSAGE=mess(123,199,1)
   Endif
Endif
End

########################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()
Local Integer I,J,K,L
Local Char    WWSTA(12),  WWSRU(12)
Local Char    WSTA(3)(6), WSRU(3)(6)
Local Char    WSTA2(3)
Local Char    WA(1), WQ(1), WR(1)
Local Char    WCRITSTA(120)

Raz WA,WQ,WR
Case GFILTREAQR
 When 1       : WA="A"
 When 2       : WQ="Q"
 When 3       : WA="A" : WQ="Q"
 When 4       : WR="R"
 When 5       : WA="A" : WR="R"
 When 6       : WQ="Q" : WR="R"
 When 7       : WA="A" : WQ="Q" : WR="R"
 When Default : WA="A"
Endcase

If VALEUR <> ""
   # Si Cde, OF ou tache affaire, contrôle par rapport à la règle d'allocation
   #--- Issue X3-4501
   #If find([M:ALF]VCRTYP,2,10)
   If find([M:ALF]VCRTYP,2,10,40)
   #---
      Gosub CTRL_TRUSTA

   # Pas de règle de gestion ou règle sans contrainte
   # --> contrôle par rapport à la règle d'allocation
   Elsif find([F:SRU]AUZSST,"","*")
      Gosub CTRL_TRUSTA

   # Contrôle par rapport à la règle de gestion
   Else
      VALEUR=toupper(VALEUR)
      WWSTA=VALEUR
      J=instr(J,WWSTA,",")
      While J<>0
         WSTA(I)=left$ (WWSTA,J-1)
         WWSTA  =right$(WWSTA,J+1)
         J=instr(J,WWSTA,",")
         I+=1
      Wend
      J=I
      WSTA(I)=WWSTA
      For I=0 To J
         Raz WCRITSTA
         Call CREE_FORMULE([F:SRU]FORSTA,"WSTA(I)",WCRITSTA) From TRTCATEG
         If !evalue(WCRITSTA)
            mkstat=2 : GMESSAGE=mess(456,199,1)
            Break
         # Le pat ne sait pas contrôler les jokers entre eux
         Elsif right$(WSTA(I),len(WSTA(I)))="*"
            # Dépack des sous-statuts autorisés
            WWSRU=[F:SRU]AUZSST
            L=instr(L,WWSRU,",")
            While L<>0
               WSRU(K)=left$ (WWSRU,L-1)
               WWSRU  =right$(WWSRU,L+1)
               L=instr(L,WWSRU,",")
               K+=1
            Wend
            L=K
            WSRU(K)=WWSRU
            Case len(WSTA(I))
            When 2 : If !find(WSTA(I),WSRU(0..L))
                        mkstat=2 : GMESSAGE=mess(456,199,1)
                        Break
                     Endif
            When 3 : If !find(WSTA(I),WSRU(0..L))
                        WSTA2=left$(WSTA(I),1)+right$(WSTA(I),len(WSTA(I)))
                        If !find(WSTA2,WSRU(0..L))
                           mkstat=2 : GMESSAGE=mess(456,199,1)
                           Break
                        Endif
                     Endif
            Endcase
         Endif
      Next I
   Endif
Endif
End

########################################
$CTRL_TRUSTA

VALEUR=toupper(VALEUR)
WWSTA=VALEUR
J=instr(J,WWSTA,",")
While J<>0
   WSTA(I)=left$ (WWSTA,J-1)
   WWSTA  =right$(WWSTA,J+1)
   J=instr(J,WWSTA,",")
   I+=1
Wend
J=I
WSTA(I)=WWSTA
For I=0 To J
   If !find(left$(WSTA(I),1),WA,WQ,WR)
      mkstat=2 : GMESSAGE=mess(387,199,1)
      Break
   Elsif len(WSTA(I))>GLONSTA
      mkstat=2 : GMESSAGE=mess(456,199,1)-num$(GLONSTA)
      Break
   Endif
Next I

Return

########################################
Subprog IB_LOC
If [M]LOC<>"" Raz GBOUT1 Endif
End

########################################
Subprog B1_LOC(VALEUR)
Variable Char    VALEUR()
Call STKINIEMPS(VALEUR) From STKLOC
End

########################################
Subprog AS_LOC(VALEUR)
Variable Char    VALEUR()
#--- Issue 55261
If dim(GLOCCAT)<0
  Global Char GLOCCAT(4)
  GLOCCAT="12"
Endif
#---
Read [ITF]ITF0=[M:ALF]ITMREF;[M:ALF]STOFCY
If fstat | [F:ITF]LOCMGTCOD<>2
   mkstat=2
Endif
End

########################################
Subprog IB_LOCTYP
If [M]LOCTYP<>"" Raz GBOUT1 Endif
End

########################################
Subprog B1_LOCTYP(VALEUR)
Variable Char    VALEUR()
Call STKINITEMS(VALEUR) From STKLOC
End

########################################
Subprog AS_LOCTYP(VALEUR)
Variable Char    VALEUR()
Read [ITF]ITF0=[M:ALF]ITMREF;[M:ALF]STOFCY
If fstat | [F:ITF]LOCMGTCOD<>2
   mkstat=2
Endif
End

