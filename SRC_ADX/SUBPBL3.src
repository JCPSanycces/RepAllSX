#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque PBL3
##########################################################################################################
Subprog B1_NBPBL
  #Affichage des familles parents.
  [M:PBL3]CHOIX = [M:PBL3]PBL(nolign-1)
  If [M:PBL3]PARENT(nolign-1) <> "" Then
    Read [PBL]PBL0=[M:PBL3]PARENT(nolign-1)
    If fstat = 0 Then
      If [F:PBL]PAEGRPNUM <> "" Then
        [M:PBL3]CHOIX = [F:PBL]PAEGRPNUM
      Else
        [M:PBL3]CHOIX = ""
      Endif
    Else
      [M:PBL3]CHOIX = ""
    Endif
  Else
    [M:PBL3]CHOIX = ""
  Endif
  Gosub LOADTOPFAM From TRTPBL3
  Affzo [M:PBL3]1-99
  #Utilisation de mkstat=1024 pour faire sortir de la saisie fenêtre et repositionnement en ligne 0
  mkstat = 1024
  zonsui = "NBPBL(0)"
End

##########################################################################################################
Subprog B2_NBPBL

  #Affichage des familles filles.
  If [M:PBL3]FILLE(nolign-1) = 1 Then
    [M:PBL3]CHOIX = [M:PBL3]PBL(nolign-1)
    Gosub LOADTOPFAM From TRTPBL3
    Affzo [M:PBL3]1-99
    #Utilisation de mkstat=1024 pour faire sortir de la saisie fenêtre et repositionnement en ligne 0
    mkstat = 1024
    zonsui = "NBPBL(0)"
  Endif
End

##########################################################################################################
Subprog B3_NBPBL

  [M:PBL3]CHOIX = ""
  Gosub LOADTOPFAM From TRTPBL3
  Affzo [M:PBL3]1-99
  #Utilisation de mkstat=1024 pour faire sortir de la saisie fenêtre et repositionnement en ligne 0
  mkstat = 1024
  zonsui = "NBPBL(0)"
End

##########################################################################################################
Subprog IB_NBPBL

  #Gestion du Bouton : Familles parents #mess(265,196,1) #Familles parents.
  #Gestion du Bouton : Familles filles
  #Gestion du bouton : Revenir au sommet #mess(264,196,1) #Revenir au sommet.
  If [M:PBL3]FILLE(nolign-1) = 0 Then
    Raz GBOUT2
  Endif
  If [M:PBL3]PARENT(nolign-1) = "" Then
    Raz GBOUT1
    Raz GBOUT3
  Endif
End
