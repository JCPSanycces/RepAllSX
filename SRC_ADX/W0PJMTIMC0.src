#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTIMC0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CATCOD
mkstat = 0
zoncou = "CATCOD"
indice = 0
WCHAR = [M]CATCOD
If varmode([M]CATCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CATCOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CATCOD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CATCOD" : GZNUM = 52045 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]CATCOD or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_CATCOD([M]CATCOD) From SUBPJTC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CATCOD" : GZNUM = 52045 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
WCHAR = [M]DESAXX
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"PJMTIMCAT","DESAXX",CATCOD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]DESAXX or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_DESAXX([M]DESAXX) From SUBPJTC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone SHOAXX
mkstat = 0
zoncou = "SHOAXX"
indice = 0
WCHAR = [M]SHOAXX
If varinit([M]SHOAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]SHOAXX,"PJMTIMCAT","SHOAXX",CATCOD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHOAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHOAXX" : Gosub ACTION From =IMPTRT
  Endif
  If WCHAR<>[M]SHOAXX or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_SHOAXX([M]SHOAXX) From SUBPJTC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SHOAXX" : GZNUM = 4010 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone RATMUL
mkstat = 0
zoncou = "RATMUL"
indice = 0
WNUM = [M]RATMUL
If varmode([M]RATMUL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RATMUL" : Gosub ACTION From =IMPTRT
 Endif
 If [M]RATMUL<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "RATMUL" : GZNUM = 1003744 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]RATMUL or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_RATMUL([M]RATMUL) From SUBPJTC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "RATMUL" : GZNUM = 1003744 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMTIMC0"
Return

