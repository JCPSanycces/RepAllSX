  Raz GPILOBJ
  Call OBJET("GPC",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE : # FQ98641
 When "SETBOUT"     : Gosub SETBOUT
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase
Return

######################################################################################
#*!
$OUVRE

 If !clalev([M:FPC]) : Local Mask FASPARCPY [FPC] : Endif
 If !clalev([F:LCD]) : Local File LNKCPTABD [LCD] : Endif
 If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif

 Global Char GLIBDEFTAB(30)
 Global Integer GCPTBAT
 Global Integer GTMPTAB          : GTMPTAB=0 #Fq64011
 Global Integer GKEYSTR
 Global Integer GKEYEND
 Global Integer GNBPAGT
 Global Integer GNUMPAG
 Global Char    GTITDIE(20)(15) #Fq69824

# Issue 59028
# Local Char GTABCPTX3 : GTABCPTX3=left$(GTABCPT,instr(1,GTABCPT,"@"))+GDOSX3+"."
# If !clalev([F:ABT]) : Local File =adxmother(1)+"."+"ABATRQT" [ABT] : Endif
# Filter [F:ABT]Where FLAG=2 & TACHE="ACCBATCH"
# Read [F:ABT]First
# If fstat
#  GCPTBAT = 0
# Else
#  GCPTBAT = 1
# Endif
# Filter [F:ABT]

Local Integer WTSK_STA_IS_STOPPED
Call PRESENCE(WTSK_STA_IS_STOPPED) From CPTBATCH
If WTSK_STA_IS_STOPPED
  GCPTBAT = 0
Else
  GCPTBAT = 1
Endif
# End issue 59028

 # CBO 2012.06.29 FQ80506
 Gosub LOAD_PCG_PCE

Return

######################################################################################
$LIENS
 Local Integer LREF
 Filter [F:LCD] Where TYP=[F:LCA]TYP & NUM=[F:LCA]NUM : Read [F:LCD]LCA1 Last : Filter [F:LCD]

 If [F:LCD]NUMENR/dim([M:GC3]EVT)-int([F:LCD]NUMENR/dim([M:GC3]EVT))<>0
  GNBPAGT=1+int([F:LCD]NUMENR/dim([M:GC3]EVT))
 Else
  GNBPAGT=[F:LCD]NUMENR/dim([M:GC3]EVT)
 Endif

 GNUMPAG=1
 GKEYSTR=1
 GKEYEND=dim([M:GC3]EVT)
 LREF =[F:LCA]CPTREF

 Gosub LOAD_PCG_PCE
 # CBO 2012.06.29 FQ80506
 Gosub LOAD_PCE_COM
 # FQ76250 : grosse astuce pour ne pas passer en modif après le changement de type de référentiel
 GOBJET=0
Return

######################################################################################
$SETBOUT
  #Call VIREBOUT(CHAINE,"M") From GOBJET #Dev
  Gosub STATUT_ACC_BATCH

  #fq63269
  If GTMPTAB
   [M:GC0]CPTBAT = mess(129,7778,1) #"Tâche comptabilité"
   Case GCPTBAT
    When 0 : [M:GC0]CPTBATICO = "127"
    When 1 : [M:GC0]CPTBATICO = "129"
    When 2 : [M:GC0]CPTBATICO = "128"
   Endcase
  Else
   [M:GC0]CPTBAT =""
   [M:GC0]CPTBATICO=""
  Endif
  Affzo [M:GC0]CPTBATICO
  Affzo [M:GC0]CPTBAT
Return

######################################################################################
$LOAD_PCG_PCE
 Local Char    LTYP
 Local Char    LNUM
 Local Integer I_LIGNE, I_CCE, LNBLIGANA
 Local Decimal TOTDEB
 Local Decimal TOTCDT
 LTYP    = [M:GC0]TYP
 LNUM    = [M:GC0]NUM
 # CBO 2012.06.29 FQ80506
# Gosub LOAD_PCE_COM
Return

######################################################################################
$LOAD_PCE_COM
 Gosub DEBUT From TRTGPCCAB
 Gosub LOAD_HAE3
Return

######################################################################################
$LOAD_HAE3
 #> Chargement de l'onglet détail :
 Local Integer LNBENR
 Local Integer LNBLIGNE : LNBLIGNE=dim([M:GC3]EVT)
 Local Char    LREQUETE(255)

 LREQUETE = "TYP=[F:LCA]TYP & NUM=[F:LCA]NUM & NUMENR>=GKEYSTR & NUMENR<=GKEYEND"

 Filter [F:LCD] Where evalue(LREQUETE)
 For [F:LCD]LCA1
  If dim(BFIRST)<0
   Local Integer BFIRST
   If [F:LCD]TIMSTP=""
   Else
   Endif
  Endif
  LNBENR+=1
  If LNBENR>dim([M:GC3]EVT)
   [M:GC3]REF(LNBENR-2)="..."
   [M:GC3]DPRPLN(LNBENR-2)=0
   [M:GC3]DPRPLNA(LNBENR-2)=""
   Break
  Endif
  nolign = LNBENR
  [M:GC3]=[F:LCD]
  [M:GC3]DPRPLNA(nolign-1)   = mess([F:LCD]DPRPLN,3101,1)
  [M:GC3]FIYENDDAT(nolign-1) = format$("D:"+GFMDAT4,[F:LCD]FIYENDDAT)
  [M:GC3]PERENDDAT(nolign-1) = format$("D:"+GFMDAT4,[F:LCD]PERENDDAT)

  Gosub SET_GC3_ICONE
 Next
 [M:GC3]NUMPAG=num$(GNUMPAG)-"/"-num$(GNBPAGT)
 [M:GC3]NBLIG=LNBENR
 Filter [F:LCD]
 Affzo [M:GC3] : Diszo [M:GC3]20
Return

######################################################################################
$SET_GC3_ICONE
  #-------------------------------------
  # SOURCE DEPREC OU CCNRPR ou LINK
  #-------------------------------------
  #@fq64544
  If [F:LCD]LNKSRC=GVML_SRCDEP | [F:LCD]LNKSRC=GVML_SRCRPR | [F:LCD]LNKSRC=GVML_SRCLNK
   If !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif
   Read [F:FAS]FAS0=[F:LCD]REF
   If fstat=5
    [M:GC3]DELOBJFLG(nolign-1)=G_OUI
   Elsif !fstat
    [M:GC3]DELOBJFLG(nolign-1)=G_NON
   Else
    [M:GC3]DELOBJFLG(nolign-1)=0
   Endif
  Endif
  #-------------------------------------
  # Source événement
  #-------------------------------------
  If [F:LCD]LNKSRC=GVML_SRCEVT
   Read [F:ADI]CODE=GTD_EVENT;[F:LCD]EVT
   If !fstat
    If clalev([F:EVT]) : Close Local File [F:EVT] : Endif
    Local File = [F:ADI]A2 [F:EVT]
    Read [F:EVT]EVE0=[F:LCD]REF;[F:LCD]TIMSTP
    If fstat=5
     [M:GC3]DELOBJFLG(nolign-1)=G_OUI
    Elsif !fstat
     [M:GC3]DELOBJFLG(nolign-1)=G_NON
    Else
     [M:GC3]DELOBJFLG(nolign-1)=0
    Endif
   Endif
  Endif
  #-------------------------------------
  # Type de source autre : alimentation
  # de la DELOBJFLG par point d'entrée.
  #-------------------------------------
  #CHECK IGNORE_BEGIN
  If [F:LCD]LNKSRC=GVML_SRCOTH
   GPOINT = "CPTDELOBJOTH" : Gosub ENTREE From EXEFNC
  Endif
  #CHECK IGNORE_END
  #-------------------------------------
  # Affichage de l'icone
  #-------------------------------------
  Case [M:GC3]DELOBJFLG(nolign-1)
   When G_OUI   : [M:GC3]DELOBJICO(nolign-1) = "143" # Poubelle
   When G_NON   : [M:GC3]DELOBJICO(nolign-1) = "48"  # Loupe +
   When Default : [M:GC3]DELOBJICO(nolign-1) = ""    # Vide
  Endcase
Return

######################################################################################
$TERMINE
 If dim(GLIBDEFTAB)>0 : Kill GLIBDEFTAB : Endif
 If dim(GCPTBAT)>0    : Kill GCPTBAT    : Endif
 If dim(GTMPTAB)>0    : Kill GTMPTAB    : Endif
 If dim(GKEYSTR)>0    : Kill GKEYSTR    : Endif
 If dim(GKEYEND)>0    : Kill GKEYEND    : Endif
 If dim(GNBPAGT)>0    : Kill GNBPAGT    : Endif
 If dim(GNUMPAG)>0    : Kill GNUMPAG    : Endif
Return


######################################################################################
Funprog GET_ACE_LIB(PTYP,PNUM)
Value Char PTYP
Value Char PNUM

Local Char RACELIB(30)

If !clalev([F:HAT]) : Local File GACCTMP [HAT] : Endif
Read [F:HAT]HAT0=PTYP;PNUM
If fstat
 If clalev([F:HAT])>0: Close Local File [F:HAT] : Endif
 Local File GACCENTRY [HAT]
 Read [F:HAT]HAE0=PTYP;PNUM
Endif

RACELIB = [F:HAT]DESVCR

End RACELIB

######################################################################################
$STATUT_ACC_BATCH

Local Integer MULTI
Local Char    LREQ(50)
Local Integer LNBACCBAT, LNBACTIF, LNBINACTIF, LNBIND, MORT

  If clalev([F:BTC])=0 : Local File =GTABCPT+"BATCH"     [BTC] : Endif
  If clalev([F:ABA])=0 : Local File =GTABCPT+"ABATABT"   [ABA] : Endif # Issue X3-59028

  Call PARAM("","MULBATCH",LREQ) From ADOVAL
  MULTI = (val(LREQ)=2)
  If MULTI
    LREQ = 'COD<>"ACCENTRY"'
  Else
    LREQ = 'COD="ACCENTRY"'
  Endif
  Filter [F:BTC] Where evalue(LREQ) & ACC=2

  For [F:BTC]
    LNBACCBAT+=1
  # Issue X3-59028

    # Recurring task management
    Read [ABA]CODABT = [F:BTC]COD
    If fstat
      LNBIND +=1
    Elsif [F:ABA]ENAFLG  = [V]CST_AYES
      LNBACTIF   += 1
    Else
      LNBINACTIF += 1
    Endif

#  If [F:BTC]PID=""
#   MORT = 1
#  Else
#   Call PROCESS([F:BTC]PID,MORT) From SERVSYS
#  Endif
#  If MORT
#   [F:BTC]STA = 1
#  Else
#   [F:BTC]STA = 2
#  Endif
#  Case [F:BTC]STA
#   When 1 : LNBINACTIF += 1
#   When 2 : LNBACTIF   += 1
#   When Default : LNBIND +=1
#  Endcase
  # End issue X3-59028
 Next

 If LNBINACTIF = LNBACCBAT
  GCPTBAT = 0
 Elsif LNBIND | (LNBACCBAT<>LNBACTIF)
  GCPTBAT = 1
 Elsif LNBACTIF   = LNBACCBAT
  GCPTBAT = 2
 Endif

Return

######################################################################################
######################################################################################

######################################################################################
Subprog AS_NBLIG
 #> Pas de détail si aucune ligne détail
 If nolign=dim([M:GC3]EVT)
  GBOUT1=""
 Endif
 #> Pas de détail si objet correspondant n'existe plus
 If [M:GC3]DELOBJFLG(nolign-1)=G_OUI
  GBOUT1=""
 Endif
End

######################################################################################
Subprog AV_NBLIG
 #FQ54343
 #> Affichage des colonnes en fonction du type de source.
 Case [F:LCA]LNKSRC
  When GVML_SRCEVT
   #> Evénement
   Chgfmt [M:GC3]DPRPLNA   With "K:20X"
   Chgfmt [M:GC3]TIMSTP    With "K:20X"
   Chgfmt [M:GC3]EVT       With "K:20X"
   Chgfmt [M:GC3]FIYENDDAT With "-K:10X"
   Chgfmt [M:GC3]PERENDDAT With "-K:10X"
   Chgfmt [M:GC3]EVT       With "K:20X"
   Chgfmt [M:GC3]PSTDPE    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTEXC    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDER    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDERRVE With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVETRF With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVACRB With "-Nz3:13.2#"
   If G_ACTCCN=G_OUI
    Chgfmt [M:GC3]PSTCADCRB With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTACGRPR With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTFISRPR With "-Nz3:13.2#"
   Endif
   Chgfmt [M:GC3]PSTLNK    With "-Nz3:13.2#"
  When GVML_SRCDEP
   #> Dotations
   Chgfmt [M:GC3]DPRPLNA   With "K:20X"
   Chgfmt [M:GC3]TIMSTP    With "-K:10X"
   Chgfmt [M:GC3]EVT       With "-K:10X"
   Chgfmt [M:GC3]FIYENDDAT With "K:20X"
   Chgfmt [M:GC3]PERENDDAT With "K:20X"
   Chgfmt [M:GC3]PSTDPE    With "Nz3:13.2#"
   Chgfmt [M:GC3]PSTEXC    With "Nz3:13.2#"
   Chgfmt [M:GC3]PSTDER    With "Nz3:13.2#"
   Chgfmt [M:GC3]PSTDERRVE With "Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVETRF With "Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVACRB With "Nz3:13.2#"
   If G_ACTCCN=G_OUI
    Chgfmt [M:GC3]PSTCADCRB With "Nz3:13.2#"
    Chgfmt [M:GC3]PSTACGRPR With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTFISRPR With "-Nz3:13.2#"
   Endif
   Chgfmt [M:GC3]PSTLNK    With "-Nz3:13.2#"
  When GVML_SRCLNK
   #> Ecart entre plans @fq64544
   Chgfmt [M:GC3]DPRPLNA   With "K:20X"
   Chgfmt [M:GC3]TIMSTP    With "-K:20X"
   Chgfmt [M:GC3]EVT       With "-K:20X"
   Chgfmt [M:GC3]FIYENDDAT With "K:10X"
   Chgfmt [M:GC3]PERENDDAT With "K:10X"
   Chgfmt [M:GC3]PSTDPE    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTEXC    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDER    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDERRVE With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVETRF With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVACRB With "-Nz3:13.2#"
   If G_ACTCCN=G_OUI
    Chgfmt [M:GC3]PSTCADCRB With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTACGRPR With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTFISRPR With "-Nz3:13.2#"
   Endif
   Chgfmt [M:GC3]PSTLNK    With "Nz3:13.2#"
  When GVML_SRCOTH
   #> Autres
   Chgfmt [M:GC3]DPRPLNA   With "-K:20X"
   Chgfmt [M:GC3]TIMSTP    With "-K:20X"
   Chgfmt [M:GC3]EVT       With "-K:20X"
   Chgfmt [M:GC3]FIYENDDAT With "-K:10X"
   Chgfmt [M:GC3]PERENDDAT With "-K:10X"
   Chgfmt [M:GC3]PSTDPE    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTEXC    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDER    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDERRVE With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVETRF With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVACRB With "-Nz3:13.2#"
   If G_ACTCCN=G_OUI
    Chgfmt [M:GC3]PSTCADCRB With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTACGRPR With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTFISRPR With "-Nz3:13.2#"
   Endif
   Chgfmt [M:GC3]PSTLNK    With "-Nz3:13.2#"
  When GVML_SRCRPR
   #> Provisions pour renouvellement
   Chgfmt [M:GC3]DPRPLNA   With "-K:20X"
   Chgfmt [M:GC3]TIMSTP    With "-K:20X"
   Chgfmt [M:GC3]EVT       With "-K:20X"
   Chgfmt [M:GC3]FIYENDDAT With "K:10X"
   Chgfmt [M:GC3]PERENDDAT With "K:10X"
   Chgfmt [M:GC3]PSTDPE    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTEXC    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDER    With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTDERRVE With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVETRF With "-Nz3:13.2#"
   Chgfmt [M:GC3]PSTRVACRB With "-Nz3:13.2#"
   If G_ACTCCN=G_OUI
    Chgfmt [M:GC3]PSTCADCRB With "-Nz3:13.2#"
    Chgfmt [M:GC3]PSTACGRPR With "Nz3:13.2#"
    Chgfmt [M:GC3]PSTFISRPR With "Nz3:13.2#"
   Endif
   Chgfmt [M:GC3]PSTLNK    With "-Nz3:13.2#"
  When Default
 Endcase
End

#**
#* Sous-programme choix menu contextuel "Détail"
#* Affiche le plan d'amortissement du bien
#*!
Subprog B1_NBLIG

 Case [M:GC3]LNKSRC(nolign-1)
  When GVML_SRCEVT
   #> Evénements
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   Local Decimal BASPAG
   SAVACT = GACTION : GACTION = "DETEVT"
   PARMSK(1) = [M:GC3]EVT(nolign-1)
   PARMSK(2) = [M:GC3]REF(nolign-1)
   PARMSK(3) = [M:GC3]TIMSTP(nolign-1)
   PARMSK(4) = num$(nolign)
   Call SAISIE_NUM(BASPAG,PARMSK,"DETEVT","TRTDETEVT","") From GSAISIE
   GACTION = SAVACT
  When GVML_SRCDEP, GVML_SRCLNK
   #> Amortissements
   If !clalev([M:FAS0]) : Local Mask FAS0 [FAS0] : Endif
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   Local Decimal BASPAG
   ## Action GOBJETC
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "GOBJETC"
   Call OBJET_CHAR([M:GC3]REF(nolign-1),"DPP",num$([M:GC3]DPRPLN(nolign-1))) From GOBJET
   GACTION = SAVACT
  When GVML_SRCOTH
   #> Autre
   #CHECK IGNORE_BEGIN
   GPOINT = "CPTGACDETOTH" : Gosub ENTREE From EXEFNC
   #CHECK IGNORE_END
  When GVML_SRCRPR
   #> Provisions pour renouvellement
   If !clalev([M:FAS0]) : Local Mask FAS0 [FAS0] : Endif
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   Local Decimal BASPAG
   ## Action GOBJETC
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "GOBJETC"
   Call OBJET_CHAR([M:GC3]REF(nolign-1),"RPR",num$([M:GC3]DPRPLN(nolign-1))) From GOBJET
   GACTION = SAVACT
  When Default
 Endcase
End

#**
#* Sous-programme appelé lors d'un clic sur l'icone première page
#* @param VALEUR
#*!
Subprog CL_FIRPAG(VALEUR)
Variable Char    VALEUR()
 If GNUMPAG=1 : End : Endif
 GNUMPAG=1
 GKEYSTR=1
 GKEYEND=dim([M:GC3]EVT)
 Gosub LOAD_HAE3
End

#**
#* Sous-programme appelé lors d'un clic sur l'icone page précédente
#* @param VALEUR
#*!
Subprog CL_PREPAG(VALEUR)
Variable Char    VALEUR()
 If GNUMPAG=1 : End : Endif
 If GKEYSTR-dim([M:GC3]EVT)>0
  GNUMPAG-=1
  GKEYEND=GKEYSTR-1
  GKEYSTR=GKEYEND-dim([M:GC3]EVT)+1
  Gosub LOAD_HAE3
 Endif
End

#**
#* Sous-programme appelé lors d'un clic sur l'icone page suivante
#* @param VALEUR
#*!
Subprog CL_NEXPAG(VALEUR)
Variable Char    VALEUR()
 If GNUMPAG=GNBPAGT : End : Endif
 Filter [F:LCD] Where TYP=[F:LCA]TYP & NUM=[F:LCA]NUM
 Read [F:LCD]LCA1 Last
 Filter [F:LCD]
 If GKEYEND<=[F:LCD]NUMENR
  GNUMPAG+=1
  GKEYSTR+=dim([M:GC3]EVT)
  GKEYEND+=dim([M:GC3]EVT)
  Gosub LOAD_HAE3
 Endif
End

#**
#* Sous-programme appelé lors d'un clic sur l'icone dernière page.
#* @param VALEUR
#*!
Subprog CL_LSTPAG(VALEUR)
Variable Char    VALEUR()
 If GNUMPAG=GNBPAGT : End : Endif
 Filter [F:LCD] Where TYP=[F:LCA]TYP & NUM=[F:LCA]NUM : Read [F:LCD]LCA1 Last : Filter [F:LCD]
 GNUMPAG=GNBPAGT
 If [F:LCD]NUMENR/dim([M:GC3]EVT)-int([F:LCD]NUMENR/dim([M:GC3]EVT))<>0
  GKEYSTR=1+int([F:LCD]NUMENR/dim([M:GC3]EVT))*dim([M:GC3]EVT)
 Else
  GKEYSTR=[F:LCD]NUMENR-dim([M:GC3]EVT)+1
 Endif
 GKEYEND=[F:LCD]NUMENR
 Gosub LOAD_HAE3
End
#-------------------------------------------------------------------------------
$OUVRE_BOITE
  #-------------------------

  # FQ98641 redéfinition du link du tiroir GP1 pour ajouter le contrôle d'habilitation
  If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF]   : Endif
  If clalev([F:LCA])=0 : Local File LNKCPTABX3 [LCA] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY [CPY]    : Endif
  If clalev([F:FCY])=0 : Local File FACILITY [FCY]   : Endif
  If clalev([F:HAE])=0 : Local File GACCENTRY [HAE]  : Endif
  If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
  If clalev([F:TPE])=0 : Local File TYPACE [TPE]     : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI]    : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA [AXX]    : Endif
  Link [LCA] With
& [AFF]AFF0~=[F:LCA]FCY;GPROFIL;GUSRFCT,
& [CPY]CPY0=[F:LCA]CPY,
& [FCY]FCY0=[F:LCA]FCY,
& [HAE]HAE0=[F:LCA]TYP;[F:LCA]NUM,
& [GTE]GTE0=[F:LCA]TYP,
& [TPE]TPE0=[F:LCA]ACETYP,
& [ADI]CODE=GTD_EVENT;[F:TPE]EVTTYP,
& [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;962;[F:TPE]EVTTYP
& As [GP1]

Return

