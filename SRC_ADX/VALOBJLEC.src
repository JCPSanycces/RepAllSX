#<AdxTL>@(#)2.0.0.0 $Revision$

#---------------------------------------------------------------------------------------------------#
## VALOBJLEC Lecture de l'objet en mémoire
#---------------------------------------------------------------------------------------------------#

#---------------------------------------------------------------------------------------------------#
## Ouverture des tables
#---------------------------------------------------------------------------------------------------#

$OUVFIC
If clalev([F:AOB])=0 : Local File =APPLI+".AOBJET"   [AOB] : Endif
If clalev([F:AOT])=0 : Local File =APPLI+".AOBJTAB"  [AOT] : Endif
If clalev([F:AOL])=0 : Local File =APPLI+".AOBJLST"  [AOL] : Endif
If clalev([F:AOK])=0 : Local File =APPLI+".AOBJLNK"  [AOK] : Endif
If clalev([F:AWI])=0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif
If clalev([F:AWB])=0 : Local File =APPLI+".AWINBRO"  [AWB] : Endif
If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"  [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"  [ATI] : Endif
If clalev([F:AVW])=0 : Local File =APPLI+".AVIEW"    [AVW] : Endif
If clalev([F:ANX])=0 : Local File =APPLI+".AINDEX"   [ANX] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"    [ATY] : Endif
If clalev([F:AML])=0 : Local File =APPLI+".AMENLOC"  [AML] : Endif
If clalev([F:ATX])=0 : Local File =APPLI+".ATEXTE"   [ATX] : Endif
If clalev([F:AMK])=0 : Local File =APPLI+".AMSK"     [AMK] : Endif
If clalev([F:AMZ])=0 : Local File =APPLI+".AMSKZON"  [AMZ] : Endif
If clalev([F:AMP])=0 : Local File =APPLI+".AMSKPAR"  [AMP] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"    [ACV] : Endif
If clalev([F:ATN])=0 : Local File =APPLI+".ATRANSAC" [ATN] : Endif
If clalev([F:AEL])=0 : Local File =APPLI+".AELT"     [AEL] : Endif
If clalev([F:AEK])=0 : Local File =APPLI+".AELTLINK" [AEK] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER           [ADS] : Endif
Return

#---------------------------------------------------------------------------------------------------#
## Déclaration des variables
#---------------------------------------------------------------------------------------------------#

$DEFVAR

Local Integer MAXBRO : MAXBRO = dim([F:AWB]OBJLIS)+1     : # Nb max de browsers (10 avec derlu)
Local Integer MAXFOL : MAXFOL = dim([F:AWI]NOMMSK)+1     : # Nb max de folders (16 avec entête)
Local Integer MAXOPT : MAXOPT = dim([F:AOB]OPTCND)       : # Nb max d'options de sélection (20)
Local Integer MAXFIL : MAXFIL = 100                      : # Nb max de tables liées
Local Integer MAXVUE : MAXVUE = 20                       : # Nb max de vues
Local Integer MAXSEL : MAXSEL = dim([F:AOL]SELZON)       : # Nb max de colonnes dans liste de gauche (16)
Local Integer MAXLIA : MAXLIA = 20                       : # Nb max de liens (explorateur de liaison)
Local Integer MAXCLE : MAXCLE = 16                       : # Nb max de parties de clé
Local Integer MAXLNK : MAXLNK = 12                       : # Nb max de tables liées dans un link (moteur)

#---------------------------------------------------------------------------------------------------#
## En-tête de l'objet
#---------------------------------------------------------------------------------------------------#

Local Schar   AOB_ACV(GLONACV)                           : # Code activité
Local Integer AOB_MOD                                    : # Module
Local Char    AOB_TXT(GLONDES)                           : # Intitulé
Local Integer AOB_GES                                    : # Type de gestion
Local Integer AOB_ORD                                    : # Ascendant/Descendant
Local Schar   AOB_CLE(GLONAVA)                           : # Index
Local Integer AOB_NOI                                    : # Numéro de l'index dans la table
Local Schar   AOB_OPT(20)                                : # Option de sélection
Local Integer AOB_CAR                                    : # Nb de caractères sélection
Local Integer AOB_TRE                                    : # Liste hiérarchisée o/n
Local Char    AOB_URL(250)                               : # Url d'archivage
Local Schar   AOB_FLDFCY(GLONAVA)                        : # Nom du champ site
Local Schar   AOB_FLDACC(GLONAVA)                        : # Nom du champ code accès
Local Schar   AOB_FLDGRF(GLONAVA)                        : # Nom du champ groupe de site
Local Schar   AOB_FLDGRC(GLONAVA)                        : # Nom du champ groupe de société
Local Schar   AOB_FLDLEG(GLONAVA)                        : # Nom du champ législation
Local Integer AOB_DELDEF                                 : # Suppression différée
Local Schar   AOB_RPT1(GLONARP)                          : # Etat liste
Local Schar   AOB_RPT2(GLONARP)                          : # Etat impression
Local Schar   AOB_RQT(GLONALH)                           : # Requête (GEODE)
Local Schar   AOB_BASPAG(GLONAVA)                        : # Nom de la variable bas de tableau
Local Integer AOB_MAXLIG                                 : # Nbr max de lignes (type gestion tableau)
Local Integer AOB_STA                                    : # Tunnel stat
Local Integer AOB_LIBSHO                                 : # Libellé court de l'objet
Local Integer AOB_LIBEL                                  : # Libellé long
Local Integer AOB_LIBPAR                                 : # Libellé du paramètre (clesec)
Local Integer AOB_FCYDEP                                 : # Environnement GEODE
Local Integer AOB_MLOCK                                  : # Lock en modification
Local Integer AOB_DSYPAR                                 : # Paramètre affiché par TRT CONTOBJ
Local Char    AOB_STD(GLONADC)                           : # Nom du traitement standard (SUBxxx)
Local Char    AOB_SPV(GLONADC)                           : # Nom du traitement vertical (SPVxxx)
Local Char    AOB_SPE(GLONADC)                           : # Nom du traitement spécifique (SPExxx)

Local Integer AOB_NBOPT                                  : # Nombre options de sélection
Local Schar   AOB_OPTCND(50)(1..MAXOPT)                  : # Conditions sélection
Local Schar   AOB_OPTCOD(1)(1..MAXOPT)                   : # Code condition
Local Integer AOB_OPTERR(1..MAXOPT)                      : # Libellé de l'erreur
Local Integer AOB_OPTLIB(1..MAXOPT)                      : # Libellé de la condition

Local Integer AOB_NBFIC                                  : # Nombre de tables liées
Local Schar   AOB_FICLNK(GLONATB)(1..MAXFIL)             : # Nom de la table
Local Schar   AOB_EXPLNK(200)(1..MAXFIL)                 : # Expression de lien
Local Integer AOB_OBLLNK(1..MAXFIL)                      : # Lien requis pour les listes de gauche
Local Schar   AOB_CODLNK(GLONADI)(1..MAXFIL)             : # Code liaison
Local Schar   AOB_ABRLNK(GLONABR)(1..MAXFIL)             : # Abréviation de la table liée
Local Schar   AOB_CLELNK(GLONAVA)(1..MAXFIL)             : # Clé de la table liée

Local Integer AOB_NBVUE                                  : # Nombre de vues
Local Schar   AOB_CODVUE(GLONAVW)(1..MAXVUE)             : # Nom de la vue
Local Schar   AOB_ABRVUE(GLONABR)(1..MAXVUE)             : # Abréviation

Local Integer AOB_NBSEL                                  : # Nombre de colonne pour la sélection
Local Schar   AOB_SELZON(GLONAVA)(1..MAXSEL)             : # Nom du champ
Local Schar   AOB_SELFIC(GLONATB)(1..MAXSEL)             : # Nom de la table
Local Schar   AOB_SELABR(GLONABR)(1..MAXSEL)             : # Abréviation de la table
Local Schar   AOB_SELEXP(200)(1..MAXSEL)                 : # Expression
Local Integer AOB_SELDIM(1..MAXSEL)                      : # Dimension
Local Integer AOB_SELINT(1..MAXSEL)                      : # Intitulé de la colonne
Local Schar   AOB_SELTYP(GLONATY)(1..MAXSEL)             : # Type de donnée de la colonne
Local Integer AOB_SELTYPTYP(1..MAXSEL)                   : # Type de la colonne
Local Schar   AOB_SELFMT(30)(1..MAXSEL)                  : # Format de la colonne (html)
Local Schar   AOB_SELFOR(30)(1..MAXSEL)                  : # Format de la colonne (affiché)
Local Integer AOB_SELNOLIB(1..MAXSEL)                    : # No de menu local
Local Schar   AOB_SELOPT(20)(1..MAXSEL)                  : # Option de saisie pour le format de la colonne
Local Decimal AOB_SELLNG(1..MAXSEL)                      : # Longueur du champ (colonne)
If dim([F:AOL]SELPCK)>1
 Local Integer AOB_SELPCK(1..MAXSEL)                     : # Niveau de picking ## GEODE
Endif
Local Schar   AOB_TRNABR(GLONABR)                        : # Abréviation table des transactions
Local Schar   AOB_TRNATB(GLONATB)                        : # Table des transactions
Local Schar   AOB_TRNLEG(GLONAVA)                        : # Nom du champ législation
Local Schar   AOB_TRNCND(250)                            : # Condition table des transactions
Local Schar   AOB_TRNFLD(GLONAVA)                        : # Champ code dans la table des transactions
Local Schar   AOB_TRNTIT(GLONAVA)                        : # Nom du champ intitulé de la transaction
Local Schar   AOB_TRNTYP(GLONATY)                        : # Type de donnée du champ intitulé
Local Schar   AOB_TRNCLE(80)(1..4)                       : # Clé pour lecture du texte traduisible

#---------------------------------------------------------------------------------------------------#
## En-tête de la table liée à l'objet
#---------------------------------------------------------------------------------------------------#

Local Schar   ATB_FIC(GLONATB)                           : # Nom de la table de l'objet
Local Schar   ATB_STD(GLONABR)                           : # Abréviation de cette table dans le dico
Local Schar   ATB_ABR(GLONABR)                           : # Abréviation de cette table dans l'objet
Local Schar   ATB_INT(GLONAVA)                           : # Nom du champ intitulé

#---------------------------------------------------------------------------------------------------#
## Liens
#---------------------------------------------------------------------------------------------------#

Local Schar   AOK_OBJ(GLONAOB)(1..MAXLIA)                : # Objet destination
Local Schar   AOK_FIC(GLONATB)(1..MAXLIA)                : # Nom de table
Local Schar   AOK_LNK(GLONADI)(1..MAXLIA)                : # Code liaison
Local Schar   AOK_CLE(GLONAVA)(1..MAXLIA)                : # Clé de lien
Local Schar   AOK_EXP(50)(1..MAXLIA)                     : # Expression de lien
Local Schar   AOK_ABR(GLONABR)(1..MAXLIA)                : # Abréviation de la table
Local Schar   AOK_INT(GLONAVA)(1..MAXLIA)                : # Intitulé du champ lié
Local Integer AOK_TIT(1..MAXLIA)                         : # Libellé de l'objet lié
Local Schar   AOK_BAS(30)(1..MAXLIA)                     : # Variable de bas de tableau
Local Integer AOK_NBR                                    : # Nombre de liens

#---------------------------------------------------------------------------------------------------#
## En-tête de la fenêtre
#---------------------------------------------------------------------------------------------------#

Local Schar   AWI_BOX(GLONABR)                           : # Abréviation de la boite
Local Integer AWI_TYP                                    : # Type de fenêtre
Local Integer AWI_NBRMSK                                 : # Nombre de masques (n°1 = entête)
Local Schar   AWI_NOMMSK(GLONAMK)(1..MAXFOL)             : # Code du masque
Local Schar   AWI_ABRMSK(GLONABR)(1..MAXFOL)             : # Abréviation du masque
Local Integer AWI_INTMSK(1..MAXFOL)                      : # Intitulé folder
Local Schar   AWI_INTFLD(60)(1..MAXFOL)                  : # Intitulé évalué folder
Local Integer AWI_FLGMSK(1..MAXFOL)                      : # Folder visualisé
Local Integer AWI_ROWMSK(1..MAXFOL)                      : # Numéro d'ordre des folders

#---------------------------------------------------------------------------------------------------#
## Browsers de la fenêtre
#---------------------------------------------------------------------------------------------------#

Local Integer AWB_NBR                                    : # Nombre de browsers
Local Schar   AWB_OBJ(GLONAOB)(1..MAXBRO)                : # Code objet
Local Schar   AWB_CLE(GLONAVA)(1..MAXBRO)                : # Nom de l'index
Local Schar   AWB_IND(250)(1..MAXBRO)                    : # Description de l'index
Local Schar   AWB_FIC(GLONATB)(1..MAXBRO)                : # Nom de la table
Local Integer AWB_NOI(1..MAXBRO)                         : # Numéro de l'index de la table
Local Integer AWB_ORD(1..MAXBRO)                         : # Sens de lecture
Local Integer AWB_TRE(1..MAXBRO)                         : # Type de liste de gauche
Local Integer AWB_BRO(1..MAXBRO)                         : # Type browser (o/n)
Local Integer AWB_CHG(1..MAXBRO)                         : # Option de chargement
Local Schar   AWB_ABR(GLONABR)(1..MAXBRO)                : # Abréviation de la table
Local Schar   AWB_ABB(GLONABR)(1..MAXBRO)                : # Abréviation saisie
Local Schar   AWB_EXP(60)(1..MAXBRO)                     : # Expression de lien
Local Integer AWB_INT(1..MAXBRO)                         : # Intitulé du browser
Local Integer AWB_DER                                    : # Affichage liste de gauche derlu
Local Integer AWB_FIR                                    : # Derniers lus en première position

#---------------------------------------------------------------------------------------------------#
## Variables diverses
#---------------------------------------------------------------------------------------------------#

Local Char    CLEFCY(GLONAVA) , CLEDEP(GLONAVA) : ## GEODE
Local Char    CLEGEO(GLONAVA) , CLESUPP(GLONAVA)(0..MAXCLE) , OPTGEO(10) , OPTSUPP(10)(0..MAXCLE)
Local Char    FORGEO(30) , FORSUPP(30)(0..MAXCLE)
Local Integer TYPGEO , LONGEO , TITGEO , LIBGEO
Local Integer TYPSUPP(0..MAXCLE) , LONSUPP(0..MAXCLE) , TITSUPP(0..MAXCLE) , LIBSUPP(0..MAXCLE)

Local Char    CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..MAXCLE) , OPTPRIM(10) , OPTSEC(10)(0..MAXCLE)
Local Char    FORPRIM(20) , FORSEC(20)(0..MAXCLE)
Local Integer NBCLE
Local Integer TYPPRIM , LONPRIM , TITPRIM , LIBPRIM
Local Integer TYPSEC(0..MAXCLE) , LONSEC(0..MAXCLE) , TITSEC(0..MAXCLE) , LIBSEC(0..MAXCLE)
Local Char    CLE(GLONAVA)(1..MAXCLE)

Local Char    FENETRE(GLONFEN)

Local Char    NOMPROG(GLONADC) , FICSRC(GDIMFIC) , FICADX(GDIMFIC) , MAGIC(80)
Local Char    FICNEW(GDIMFIC) , FICAPL(GDIMFIC)
Local Char    APPVAL(GLONADS)
Local Char    CHAINE(250), NLG(2)
Local Integer I , J , K , L , N , T , P , R , OK , STAT , FLVAL , ER
Local Integer OKTXT, OKACC , OKFCY , OKTRT , OKGRF , OKGRC
Local Char    FLDTXT(GLONAVA)
Local Char    LNKSEL(GLONATB)(1..MAXLIA)
Local Char    TYPFMT(10) , OPTFMT(10) , NUMFMT(10) , CHFMT(30)
Local Integer LNGFMT
Local Char    SELIND(250)
Local Char    LIGNE(250)
Local Integer NBMERE
Local Char    TBMERE(10)(1..10)

Local Char    SAVIFS(5) , SAVIRS(5)
Local Libelle SAVIUM

Local Date    JOUR
Local Char    HEURE(10)

Local Char    TRANSAC(GLONATB) , TABLE(GLONATB)

#---------------------------------------------------------------------------------------------------#
## Initialisations
#---------------------------------------------------------------------------------------------------#

JOUR  = date$
HEURE = time$
MAGIC = mess(77,133,1) : # Superviseur Adonix

Return

#---------------------------------------------------------------------------------------------------#
## Chargement des objets comptables
#---------------------------------------------------------------------------------------------------#

$CHARGE_CPT

Local Schar   OBJCPT(GLONAOB)(1..50) : # Objets comptables susceptibles d'être dans un autre dossier
Local Schar   TABCPT(GLONATB)(1..50) : # Nom de la table gérée par ces objets
Local Integer CPTNB

CPTNB += 1 : OBJCPT(CPTNB) = "GAC"
CPTNB += 1 : OBJCPT(CPTNB) = "CCE"
CPTNB += 1 : OBJCPT(CPTNB) = "CNA"
CPTNB += 1 : OBJCPT(CPTNB) = "DSP"
CPTNB += 1 : OBJCPT(CPTNB) = "CAC"
CPTNB += 1 : OBJCPT(CPTNB) = "CCZ"
CPTNB += 1 : OBJCPT(CPTNB) = "CNZ"

CPTNB += 1 : OBJCPT(CPTNB) = "GTE"
CPTNB += 1 : OBJCPT(CPTNB) = "JOU"
CPTNB += 1 : OBJCPT(CPTNB) = "TVT"
CPTNB += 1 : OBJCPT(CPTNB) = "PER"
CPTNB += 1 : OBJCPT(CPTNB) = "FIY"
CPTNB += 1 : OBJCPT(CPTNB) = "BPR"
CPTNB += 1 : OBJCPT(CPTNB) = "DUD"
CPTNB += 1 : OBJCPT(CPTNB) = "TCK"
CPTNB += 1 : OBJCPT(CPTNB) = "JST"
CPTNB += 1 : OBJCPT(CPTNB) = "PBS"
CPTNB += 1 : OBJCPT(CPTNB) = "GDD"
CPTNB += 1 : OBJCPT(CPTNB) = "GDE"
CPTNB += 1 : OBJCPT(CPTNB) = "NDF"
CPTNB += 1 : OBJCPT(CPTNB) = "GDA"

For I=1 To CPTNB
 Read [AOB]ABREV = OBJCPT(I)
 If !fstat
  TABCPT(I) = [F:AOB]NOMFIC
 Endif
Next I

Return

#---------------------------------------------------------------------------------------------------#
## Lecture de l'objet en mémoire
#---------------------------------------------------------------------------------------------------#

$LECTURE

Gosub CHARGE_CPT

OK = 1
If [F:ADS]DOSSIER<>APPLI
 Read [ADS]DOSSIER = APPLI
 If fstat
  GMESSAGE = APPLI-":"-mess(78,133,1) : # Dossier inexistant
  OK = 0 : Return
 Endif
Endif

Read [AOB]ABREV = OBJET
If fstat
 GMESSAGE = OBJET-":"-mess(16,123,1) : # Objet non défini
 OK = 0 : Return
Elsif [F:AOB]CODACT<>""
 Read [ACV]CODACT = [F:AOB]CODACT
 # Issue X3-75929 - 2018-07-26 by ALSHE : - Split trace in warning and error message
 If fstat
  Call ECR_TRACE(OBJET-":"-mess(8,176,1)-"("+[F:AOB]CODACT+")",1) From GESECRAN : # Non-existent Activity Code
   GMESSAGE = "" : OK = 0 : Return
 Else
  If [F:ACV]FLACT<>2
   Call ECR_TRACE(OBJET-":"-mess(125,133,1)-"("+[F:AOB]CODACT+")",-1) From GESECRAN : # Objet inactif
   GMESSAGE = "" : OK = 0 : Return
  Endif
 Endif
Endif

Gosub CHARGE_OBJ

Read [AOB]ABREV = OBJET

Return

#---------------------------------------------------------------------------------------------------#

$CHARGE_OBJ

AOB_GES    = [F:AOB]TYPGES
AOB_ORD    = [F:AOB]SELORD
AOB_CLE    = [F:AOB]SELCLE
AOB_OPT    = [F:AOB]SELOPT
AOB_CAR    = [F:AOB]SELCAR
AOB_TRE    = [F:AOB]SELTREE
AOB_MOD    = [F:AOB]MODULE
AOB_ACV    = [F:AOB]CODACT
If dim([F:AOB]ARCURL)>0
 AOB_URL   = [F:AOB]ARCURL
Endif
AOB_TXT    = func AFNC.TEXTE([F:AOB]LIBEL)
AOB_STD    = "SUB"+OBJET

If APPLI=nomap
 Call EXISTE_ADX("","","SPE"+OBJET,OKTRT) From ORDSYS
Else
 Call EXISTE_ADX("",APPLI,"SPE"+OBJET,OKTRT) From ORDSYS
 If !OKTRT
  Gosub LEC_MERE From VALOBJSTD
  For J=1 To NBMERE
   Call EXISTE_ADX("",TBMERE(J),"SPE"+OBJET,OKTRT) From ORDSYS
   If OKTRT>0 : Break : Endif
  Next J
 Endif
Endif
If OKTRT>0
 AOB_SPE = "SPE"+OBJET
Endif

If APPLI=nomap
 Call EXISTE_ADX("","","SPV"+OBJET,OKTRT) From ORDSYS
Else
 Call EXISTE_ADX("",APPLI,"SPV"+OBJET,OKTRT) From ORDSYS
 If !OKTRT
  Gosub LEC_MERE From VALOBJSTD
  For J=1 To NBMERE
   Call EXISTE_ADX("",TBMERE(J),"SPV"+OBJET,OKTRT) From ORDSYS
   If OKTRT>0 : Break : Endif
  Next J
 Endif
Endif
If OKTRT>0
 AOB_SPV = "SPV"+OBJET
Endif

If left$([F:AOB]SELCLE,4)="SPE_"
 K = 0
 For [ATI] Where CODFIC=[F:AOB]NOMFIC
  K += 1
 Next
 For [ANX] Where TABLE=[F:AOB]NOMFIC & FLACT=2
  K += 1
  If [F:ANX]CODIND=[F:AOB]SELCLE
   AOB_NOI = K
   Break
  Endif
 Next
Elsif [F:AOB]SELCLE<>""
 Read [ATI]CODIND = [F:AOB]NOMFIC;[F:AOB]SELCLE
 AOB_NOI = [F:ATI]NUMLIG
Else
 AOB_NOI = 1
Endif

AOB_FLDFCY = [F:AOB]ZSITE
AOB_FLDACC = [F:AOB]ZACC
AOB_RPT1   = [F:AOB]RPT1
AOB_RPT2   = [F:AOB]RPT2
AOB_STA    = [F:AOB]STA
AOB_LIBSHO = [F:AOB]LIBSHO
AOB_LIBEL  = [F:AOB]LIBEL
AOB_LIBPAR = [F:AOB]LIBPAR
If dim([F:AOB]DSYPAR)>0
 AOB_DSYPAR = [F:AOB]DSYPAR
Endif
If dim([F:AOB]FCYDEP)>0
 AOB_FCYDEP = [F:AOB]FCYDEP
Endif
If dim([F:AOB]MLOCK)>0
 AOB_MLOCK = [F:AOB]MLOCK
Endif
If dim([F:AOB]RQT)>0
 AOB_RQT = [F:AOB]RQT
Else
 AOB_RQT = "xxx"
Endif

AOB_NBOPT = [F:AOB]NBOPT
For I=1 To [F:AOB]NBOPT
 AOB_OPTCND(I) = [F:AOB]OPTCND(I-1)
 AOB_OPTCOD(I) = [F:AOB]OPTCOD(I-1)
 AOB_OPTERR(I) = [F:AOB]OPTERR(I-1)
 AOB_OPTLIB(I) = [F:AOB]OPTLIB(I-1)
Next I

ATB_FIC = [F:AOB]NOMFIC

Raz AOB_FLDGRF , AOB_FLDLEG , AOB_FLDGRC
If ATB_FIC<>""
 Read [ATB]CODFIC  = ATB_FIC
 If fstat
  GMESSAGE = [F:AOB]NOMFIC-mess(32,133,1) : # Table inexistante
  OK = 0 : Return
 Elsif [F:ATB]CODACT<>""
  Read [ACV]CODACT = [F:ATB]CODACT
  # Issue X3-75929 - 2018-07-26 by ALSHE : - set error status to be able to use it in VALOBJ.PERDU
  #                                        - change message text if activity code doesn't exist
  If fstat
   GMESSAGE = ATB_FIC-":"-mess(8,176,1)-"("+[F:ATB]CODACT+")" : # Non-existent Activity Code
   GERR = 1 : OK = 0 : Return
  Else
   If [F:ACV]FLACT<>2
    GMESSAGE = ATB_FIC-":"-mess(126,133,1)-"("+[F:ATB]CODACT+")" : # Table inactive
    GERR = 3 : OK = 0 : Return
   Endif
  Endif
 Endif
 For [ATZ] Where CODFIC=ATB_FIC
  If AOB_FLDGRF="" & [F:ATZ]CODTYP="AGF"
   AOB_FLDGRF = [F:ATZ]CODZONE
  Endif
  If AOB_FLDGRC="" & [F:ATZ]CODTYP="AGC"
   AOB_FLDGRC = [F:ATZ]CODZONE
  Endif
  If AOB_FLDLEG="" & [F:ATZ]CODTYP="ADI" & func AFNC.ACTIV("LEG")
   Read [AMP]CODPAR=2;ATB_FIC;[F:ATZ]CODZONE;"ADI"
   If !fstat
    Raz CHAINE , ER
    Onerrgo ER
    CHAINE = num$(evalue([F:AMP]VALPAR))
    Onerrgo ERREUR
    If CHAINE="909" & !ER
     AOB_FLDLEG = [F:ATZ]CODZONE
    Endif
   Endif
  Endif
 Next ATZ
Elsif [F:AOB]TYPGES<>4
 GMESSAGE = ATB_FIC-":"-mess(17,123,1) : # Table non définie
 OK = 0 : Return
Else
 Raz [F:ATB]
Endif
If dim([F:AOB]ABRFIC)>0 & [F:AOB]ABRFIC<>""
 ATB_ABR = [F:AOB]ABRFIC
Else
 ATB_ABR = [F:ATB]ABRFIC
Endif
ATB_STD = [F:ATB]ABRFIC
ATB_INT = [F:ATB]INTIT

# Clé

Read [ATI]NUMLIG(2) = ATB_FIC;1
If fstat
 Raz [F:ATI]
Else
 CHAINE = [F:ATI]DESCRIPT
 Raz CLE, NBCLE
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  NBCLE += 1
  If I
   CLE(NBCLE) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE = ""
  Endif
 Wend
 Case NBCLE
  When 1
   CLEPRIM = CLE(1)
  When 2
   If AOB_GES=3
    CLEPRIM = CLE(1) : CLESEC = CLE(2)
   Else
    CLEPRIM = CLE(2) : CLESEC = CLE(1)
   Endif
  When Default
   CLEPRIM = CLE(2) : CLESEC = CLE(1)
   For I=3 To NBCLE
    CLESEC(I-2) = CLE(I)
   Next I
 Endcase
Endif

Read [ATZ]CODZONE = ATB_FIC;CLEPRIM
Read [ATY]CODTYP = [F:ATZ]CODTYP
TYPPRIM = [F:ATY]TYPTYP
TITPRIM = [F:ATZ]NOABREG
OPTPRIM = [F:ATY]OPTION+[F:ATZ]OPTION
FORPRIM = [F:ATY]FORTYP
If [F:ATZ]LONG<>0
 LONPRIM = [F:ATZ]LONG
Elsif [F:ATY]LNGTYP<>0
 LONPRIM = [F:ATY]LNGTYP
Endif
If [F:ATZ]NOLIB<>0
 LIBPRIM = [F:ATZ]NOLIB
Elsif [F:ATY]NOLIB<>0
 LIBPRIM = [F:ATY]NOLIB
Endif
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  Read [ATZ]CODZONE = ATB_FIC;CLESEC(I)
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  TYPSEC(I) = [F:ATY]TYPTYP
  TITSEC(I) = [F:ATZ]NOABREG
  OPTSEC(I) = [F:ATY]OPTION+[F:ATZ]OPTION
  FORSEC(I) = [F:ATY]FORTYP
  If [F:ATZ]LONG<>0
   LONSEC(I) = [F:ATZ]LONG
  Elsif [F:ATY]LNGTYP<>0
   LONSEC(I) = [F:ATY]LNGTYP
  Endif
  If [F:ATZ]NOLIB<>0
   LIBSEC(I) = [F:ATZ]NOLIB
  Elsif [F:ATY]NOLIB<>0
   LIBSEC(I) = [F:ATY]NOLIB
  Endif
 Endif
Next I

# Clé Géode

If AOB_FCYDEP=2 & NBCLE>1
 I = find("FCY",CLE(1..NBCLE-1))
 If I=1
  CLEFCY = CLE(1)
  J = find("DEP",CLE(1..NBCLE-1))
  If J<>2 | J=NBCLE : J=0 : Endif
  If J : CLEDEP = CLE(J) : Endif
  K=1+(J<>0)
  If NBCLE=1+K
   CLEGEO = CLE(K+1)
  Else
   # L = nb de paramètres
   If AOB_LIBPAR=0
    L = 0
   Else
    Call TEXTE(AOB_LIBPAR,CHAINE) From OBJDIV
    L = sigma(1,len(CHAINE),mid$(CHAINE,indcum,1)="~")+1
   Endif
   J = 0
   For I=K+1 To K+L
    CLESUPP(J) = CLE(I) : J += 1
   Next I
   CLEGEO = CLE(K+1+L)
   For I=K+2+L To NBCLE
    CLESUPP(J) = CLE(I) : J += 1
   Next I
  Endif
 Endif
Endif

If CLEGEO<>""
 Read [ATZ]CODZONE = ATB_FIC;CLEGEO
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 TYPGEO = [F:ATY]TYPTYP
 TITGEO = [F:ATZ]NOABREG
 OPTGEO = [F:ATY]OPTION+[F:ATZ]OPTION
 FORGEO = [F:ATY]FORTYP
 If [F:ATZ]LONG<>0
  LONGEO = [F:ATZ]LONG
 Elsif [F:ATY]LNGTYP<>0
  LONGEO = [F:ATY]LNGTYP
 Endif
 If [F:ATZ]NOLIB<>0
  LIBGEO = [F:ATZ]NOLIB
 Elsif [F:ATY]NOLIB<>0
  LIBGEO = [F:ATY]NOLIB
 Endif
 For I=0 To dim(CLESUPP)-1
  If CLESUPP(I)<>""
   Read [ATZ]CODZONE = ATB_FIC;CLESUPP(I)
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   TYPSUPP(I) = [F:ATY]TYPTYP
   TITSUPP(I) = [F:ATZ]NOABREG
   OPTSUPP(I) = [F:ATY]OPTION+[F:ATZ]OPTION
   FORSUPP(I) = [F:ATY]FORTYP
   If [F:ATZ]LONG<>0
    LONSUPP(I) = [F:ATZ]LONG
   Elsif [F:ATY]LNGTYP<>0
    LONSUPP(I) = [F:ATY]LNGTYP
   Endif
   If [F:ATZ]NOLIB<>0
    LIBSUPP(I) = [F:ATZ]NOLIB
   Elsif [F:ATY]NOLIB<>0
    LIBSUPP(I) = [F:ATY]NOLIB
   Endif
  Endif
 Next I
Endif

# Tables liées

If [F:ADS]DOSSIER<>APPLI
 Read [ADS]DOSSIER = APPLI
Endif
J = 0
For [AOT] Where ABREV=OBJET
 K = 1
 If [F:AOT]TABACT<>""
  Read [ACV]CODACT = [F:AOT]TABACT
  If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
 Endif
 If K
  Read [ATB]CODFIC = [F:AOT]TABFIC
  If fstat
   Raz [F:ATB]
  Elsif [F:ATB]CODACT<>""
   Read [ACV]CODACT = [F:ATB]CODACT
   If fstat or [F:ACV]FLACT<>2
    Raz [F:ATB]
   Endif
  Endif
  If [F:ATB]CODFIC<>""
   If J>=MAXFIL
    # Trop de tables dans la gestion de cet objet (#)
    Call ECR_TRACE(func AFNC.MES(mess(202,125,1),num$(J)),-1) From GESECRAN
    Break
   Endif
   J += 1
   AOB_FICLNK(J) = [F:ATB]CODFIC
   If [AOT]TABCLE<>""
    AOB_CLELNK(J) = [F:AOT]TABCLE
   Else
    Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
    AOB_CLELNK(J) = [F:ATI]CODIND
   Endif
   If [F:AOT]TABABR<>""
    AOB_ABRLNK(J) = [F:AOT]TABABR
   Else
    AOB_ABRLNK(J) = [F:ATB]ABRFIC
   Endif
   If [F:AOT]TABLIEN<>""
    AOB_EXPLNK(J) = [F:AOT]TABLIEN
    AOB_OBLLNK(J) = 1
   Else
    AOB_OBLLNK(J) = 0
    Filter [ATZ] Where CODFIC=ATB_FIC & LIEN=[F:ATB]CODFIC
    Read [ATZ]NUMLIG First
    Filter [ATZ]
    If !fstat
     If [F:ATZ]EXPLIEN<>""
      AOB_EXPLNK(J) = vireblc(format$("KT:200X",[F:ATZ]EXPLIEN),2)
     Else
      AOB_EXPLNK(J) = "[F:"+ATB_ABR+"]"+[F:ATZ]CODZONE
     Endif
    Endif
   Endif
  Endif
 Endif
Next AOT
AOB_NBFIC = J

# Nombre de vues

J = 0
For I=0 To [F:AOB]NBVUE-1
 K = 1
 If [F:AOB]VUEACT(I)<>""
  Read [ACV]CODACT = [F:AOB]VUEACT(I)
  If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
 Endif
 If K
  Read [AVW]AVW0 = [F:AOB]VUECOD(I)
  If fstat
   Raz [F:AVW]
  Elsif [F:AVW]CODACT<>""
   Read [ACV]CODACT = [F:AVW]CODACT
   If fstat or [F:ACV]FLACT<>2
    Raz [F:AVW]
   Endif
  Endif
  If [F:AVW]CODVUE<>""
   J += 1
   AOB_CODVUE(J) = [F:AOB]VUECOD(I)
   If [F:AOB]VUEABR(I)<>""
    AOB_ABRVUE(J) = [F:AOB]VUEABR(I)
   Else
    AOB_ABRVUE(J) = [F:AVW]ABRVUE
   Endif
  Endif
 Endif
Next I
AOB_NBVUE = J

# Champs sélection

Read [AOL]AOL0 = OBJET
AOB_DELDEF = [F:AOL]DELDEF

Raz FLDTXT , J , AOB_NBSEL
For I=1 To [F:AOL]NBSEL
 K = 1
 If [F:AOL]SELFIC(I-1)<>"" & [F:AOL]SELZON(I-1)<>""
  Read [ATZ]CODZONE=[F:AOL]SELFIC(I-1);[F:AOL]SELZON(I-1)
  If fstat
   K = 0
  Elsif [F:ATZ]CODTYP="ADI" & !func AFNC.ACTIV("LEG")
   Read [AMP]CODPAR=2;[F:AOL]SELFIC(I-1);[F:AOL]SELZON(I-1);"ADI"
   If !fstat & [F:AMP]VALPAR<>""
    Raz CHAINE , ER
    Onerrgo ER
    CHAINE = num$(evalue([F:AMP]VALPAR))
    Onerrgo ERREUR
    If CHAINE="909" & !ER
     K = 0
    Endif
   Endif
  Endif
 Elsif [F:AOL]SELTYP(I-1)="ALEG" & !func AFNC.ACTIV("LEG")
  K = 0
 Endif
 If K
  AOB_NBSEL += 1
  AOB_SELZON(AOB_NBSEL) = [F:AOL]SELZON(I-1)
  AOB_SELFIC(AOB_NBSEL) = [F:AOL]SELFIC(I-1)
  AOB_SELEXP(AOB_NBSEL) = [F:AOL]SELEXP(I-1)
  AOB_SELTYP(AOB_NBSEL) = [F:AOL]SELTYP(I-1)
  AOB_SELDIM(AOB_NBSEL) = 0
  If AOB_GES=4 & dim(AOB_SELPCK)>0
   AOB_SELPCK(AOB_NBSEL) = [F:AOL]SELPCK(I-1)
  Endif
  K = 1
  If [F:AOL]SELFIC(I-1)<>""
   Read [ATB]CODFIC = [F:AOL]SELFIC(I-1)
   If fstat
    K = 0
   Else
    If [F:AOL]SELFIC(I-1)=ATB_FIC
     AOB_SELABR(AOB_NBSEL) = ATB_ABR
    Endif
    If AOB_SELABR(AOB_NBSEL)=""
     For [AOT] Where ABREV=OBJET & TABFIC=[F:AOL]SELFIC(I-1)
      K = 1
      If [F:AOT]TABACT<>""
       Read [ACV]CODACT = [F:AOT]TABACT
       If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
      Endif
      If K & [F:AOT]TABABR=""
       AOB_SELABR(AOB_NBSEL) = [F:ATB]ABRFIC : Break
      Endif
     Next AOT
    Endif
    If AOB_SELABR(AOB_NBSEL)=""
     For [AOT] Where ABREV=OBJET & TABFIC=[F:AOL]SELFIC(I-1)
      K = 1
      If [F:AOT]TABACT<>""
       Read [ACV]CODACT = [F:AOT]TABACT
       If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
      Endif
      If K & [F:AOT]TABABR<>""
       AOB_SELABR(AOB_NBSEL) = [F:AOT]TABABR : Break
      Endif
     Next AOT
    Endif
    If AOB_SELABR(AOB_NBSEL)=""
     AOB_SELABR(AOB_NBSEL) = [F:ATB]ABRFIC
    Endif

    K = 1
    If [F:AOL]SELZON(I-1)<>""
     Read [ATZ]CODZONE = [F:AOL]SELFIC(I-1);[F:AOL]SELZON(I-1)
     If fstat
      K = 0
     Else
      AOB_SELTYP(AOB_NBSEL) = [F:ATZ]CODTYP
      If [F:ATZ]DIME>0
       AOB_SELDIM(AOB_NBSEL) = [F:ATZ]DIME
      Elsif [F:ATZ]CODACT<>""
       Read [ACV]CODACT = [F:ATZ]CODACT
       If !fstat
        AOB_SELDIM(AOB_NBSEL) = [F:ACV]DIME
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
  If K
   If [F:AOL]SELINT(I-1)<>0
    AOB_SELINT(AOB_NBSEL) = [F:AOL]SELINT(I-1)
   Elsif [F:AOL]SELFIC(I-1)<>""
    AOB_SELINT(AOB_NBSEL) = [F:ATZ]NOCOURT
   Endif
   If AOB_SELTYP(AOB_NBSEL)<>""
    Read [ATY]CODTYP = AOB_SELTYP(AOB_NBSEL)
    AOB_SELTYPTYP(AOB_NBSEL) = [F:ATY]TYPTYP
    If [F:ATY]NOLIB<>0
     AOB_SELNOLIB(AOB_NBSEL) = [F:ATY]NOLIB
    Endif
    If [F:AOL]SELZON(I-1)<>""
     If [F:ATZ]LONG<>0
      AOB_SELLNG(AOB_NBSEL) = [F:ATZ]LONG
     Elsif [F:ATY]LNGTYP<>0
      AOB_SELLNG(AOB_NBSEL) = [F:ATY]LNGTYP
     Endif
     If [F:ATY]OPTION<>""
      AOB_SELOPT(AOB_NBSEL) = [F:ATY]OPTION
     Elsif [F:ATZ]OPTION<>""
      AOB_SELOPT(AOB_NBSEL) = [F:ATZ]OPTION
     Endif
    Else
     If [F:ATY]LNGTYP<>0
      AOB_SELLNG(AOB_NBSEL) = [F:ATY]LNGTYP
     Elsif dim([F:AOL]SELLNG)>0 & [F:AOL]SELLNG(I-1)<>0
      AOB_SELLNG(AOB_NBSEL) = [F:AOL]SELLNG(I-1)
     Endif
     If dim([F:AOL]SELSAI)>0 & [F:AOL]SELSAI(I-1)<>""
      AOB_SELOPT(AOB_NBSEL) = [F:AOL]SELSAI(I-1)
     Endif
    Endif
   Endif
   If AOB_SELZON(AOB_NBSEL)<>""
    If [F:ATY]NOLIB<>0
     AOB_SELNOLIB(AOB_NBSEL) = [F:ATY]NOLIB
    Else
     AOB_SELNOLIB(AOB_NBSEL) = [F:ATZ]NOLIB
    Endif
   Endif
   If [F:AOL]SELFIC(I-1)<>"" & [F:AOL]SELFIC(I-1)=ATB_FIC
    If [F:ATZ]CODTYP="ATX"
     FLDTXT = [F:ATZ]CODZONE
    Endif
   Elsif [F:AOL]SELFIC(I-1)=""
    For [AOT] Where ABREV=OBJET
     If [F:AOT]TABLIEN<>"" & !find([F:AOT]TABFIC,LNKSEL(1..J))
      J += 1
      LNKSEL(J) = [F:AOT]TABFIC
     Endif
    Next AOT
   Elsif !find([F:AOL]SELFIC(I-1),LNKSEL(1..J))
    J += 1
    LNKSEL(J) = [F:AOL]SELFIC(I-1)
   Endif
  Endif
  If AOB_SELNOLIB(AOB_NBSEL)=0 & AOB_SELTYP(AOB_NBSEL)<>""
   Read [ATY]CODTYP=AOB_SELTYP(AOB_NBSEL)
   If !fstat & [F:ATY]TYPTYP=1 & vireblc(tolower(left$(AOB_SELEXP(AOB_NBSEL),4)),2)="mess"
    K = instr(1,AOB_SELEXP(AOB_NBSEL),",")
    L = instr(K+1,AOB_SELEXP(AOB_NBSEL),",")
    AOB_SELNOLIB(AOB_NBSEL) = val(seg$(AOB_SELEXP(AOB_NBSEL),K+1,L-1))
   Endif
  Endif
  If AOB_SELTYP(AOB_NBSEL)="ATX"
   AOB_SELLNG(AOB_NBSEL) = 30
   AOB_SELFMT(AOB_NBSEL) = "K:30X"
   AOB_SELFOR(AOB_NBSEL) = '""'
  Elsif AOB_SELNOLIB(AOB_NBSEL)<>0
   Read [AML]MENLOC=AOB_SELNOLIB(AOB_NBSEL)
   If !fstat & [F:AML]LONG<>0
    AOB_SELLNG(AOB_NBSEL) = [F:AML]LONG
    AOB_SELFMT(AOB_NBSEL) = "LA"+format$("N0:5#",AOB_SELNOLIB(AOB_NBSEL))+":"+num$([F:AML]LONG)+"X"
   Else
    AOB_SELLNG(AOB_NBSEL) = 15
    AOB_SELFMT(AOB_NBSEL) = "LA"+format$("N0:5#",AOB_SELNOLIB(AOB_NBSEL))+":15X"
   Endif
   AOB_SELFOR(AOB_NBSEL) = '""'
  Else
   Case AOB_SELTYPTYP(AOB_NBSEL)
    When 1
     If AOB_SELLNG(AOB_NBSEL)=0
      AOB_SELLNG(AOB_NBSEL) = 4
     Endif
     AOB_SELFMT(AOB_NBSEL) = "N:"+num$(AOB_SELLNG(AOB_NBSEL))+"f"
     AOB_SELFOR(AOB_NBSEL) = '""'
    When 2,3,4,5,6
     If AOB_SELLNG(AOB_NBSEL)<>0
      AOB_SELFMT(AOB_NBSEL) = "N:"+num$(int(AOB_SELLNG(AOB_NBSEL)))+"F"
      Gosub FMTNUM
     Else
      Case AOB_SELTYPTYP(AOB_NBSEL)
       When 2     : AOB_SELLNG(AOB_NBSEL) = 5  : AOB_SELFMT(AOB_NBSEL) = "N:5#"
       When 3     : AOB_SELLNG(AOB_NBSEL) = 8  : AOB_SELFMT(AOB_NBSEL) = "N:8#"
       When 4,5,6 : AOB_SELLNG(AOB_NBSEL) = 15 : AOB_SELFMT(AOB_NBSEL) = "N:15F" : AOB_SELOPT(AOB_NBSEL) += "F"
      Endcase
      AOB_SELFOR(AOB_NBSEL) = '""'
     Endif
    When 8
     If AOB_SELOPT(AOB_NBSEL)<>""
      Gosub FMTDAT
     Else
      AOB_SELLNG(AOB_NBSEL) = func VALMSKLEC.LG(GFMDAT4,10)
      #112877
      #AOB_SELFMT(AOB_NBSEL) = "DZz:"+GFMDAT4
      AOB_SELFMT(AOB_NBSEL) = 'DZz:"+GFMDAT4+"'
      #AOB_SELFOR(AOB_NBSEL) = '"DZz:'+GFMDAT4+'"'
      AOB_SELFOR(AOB_NBSEL) = '"DZz:"+GFMDAT4'
     Endif
    When Default
     If AOB_SELLNG(AOB_NBSEL)<>0
      AOB_SELFMT(AOB_NBSEL) = "K:"+num$(AOB_SELLNG(AOB_NBSEL))+"X"
      Gosub FMTCAR
     Else
      AOB_SELLNG(AOB_NBSEL) = 30
      AOB_SELFMT(AOB_NBSEL) = "K:"+num$(AOB_SELLNG(AOB_NBSEL))+"X"
      AOB_SELFOR(AOB_NBSEL) = '""'
     Endif
   Endcase
  Endif
 Endif
Next I

# Vérification des tables liées

J = 0
For CHAINE=FLDTXT,AOB_FLDACC,AOB_FLDFCY
 J += 1
 If CHAINE<>""
  K = 0
  For I=1 To AOB_NBFIC
   Case J
    When 1 : If AOB_FICLNK(I) = "ATEXTE"   & AOB_ABRLNK(I)="ATX" : K = I : Break : Endif
    When 2 : If AOB_FICLNK(I) = "ACCES"    & AOB_ABRLNK(I)="ACC" : K = I : Break : Endif
    When 3 : If AOB_FICLNK(I) = "AFCTFCY"  & AOB_ABRLNK(I)="AFF" : K = I : Break : Endif
   Endcase
  Next I
  If K
   Dela K,1 AOB_FICLNK , AOB_EXPLNK , AOB_OBLLNK , AOB_CODLNK , AOB_ABRLNK , AOB_CLELNK
   AOB_NBFIC -= 1
  Endif
 Endif
Next CHAINE

# Vérification du nombre de tables liées

J = 0
If FLDTXT<>""     : J += 1 : Endif
If AOB_FLDACC<>"" : J += 1 : Endif
If AOB_FLDFCY<>"" : J += 1 : Endif
If AOB_FLDGRF<>"" : J += 1 : Endif
If AOB_FLDGRC<>"" : J += 1 : Endif
For I=1 To AOB_NBFIC
 If AOB_EXPLNK(I)<>"" & AOB_OBLLNK(I)
  J += 1
 Endif
Next I
If J>MAXLNK
 # Trop de liens sur cette table
 Call ECR_TRACE(ATB_FIC-":"-mess(12,133,1)-"(+"+num$(MAXLNK)+")",-1) From GESECRAN
Endif

# Liens

I = 0
For [AOK]AOK0 Where SRCOBJ=OBJET
 Read [AOB]ABREV  = [F:AOK]DSTOBJ
 If !fstat
  Read [ATB]CODFIC = [F:AOB]NOMFIC
  If !fstat
   Read [ATI]NUMLIG(2) = [F:AOB]NOMFIC;1
   I += 1
   AOK_OBJ(I) = [F:AOK]DSTOBJ
   AOK_LNK(I) = [F:AOK]LNK
   AOK_ABR(I) = [F:AOK]ABRFIC
   AOK_EXP(I) = [F:AOK]EXPLIEN
   AOK_CLE(I) = [F:ATI]CODIND
   AOK_FIC(I) = [F:AOB]NOMFIC
   If [F:ATB]INTIT<>""
    AOK_INT(I) = [F:ATB]INTIT
   Elsif [F:ATB]INTITC<>""
    AOK_INT(I) = [F:ATB]INTITC
   Endif
   AOK_TIT(I) = [F:AOB]LIBEL
   AOK_BAS(I) = [F:AOK]BASPAG
  Endif
 Endif
Next
AOK_NBR = I

# Fenêtre

If AOB_GES=4
 Raz [F:AWI]
Else
 Read [AWI]AWI0 = "O"+OBJET
 If fstat
  Raz [F:AWI]
 Elsif [F:AWI]CODACT<>""
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat or [F:ACV]FLACT<>2
   Raz [F:AWI]
  Endif
 Endif
 If [F:AWI]WIN=""
  I = 0
  For [AWI] Where OBJ=OBJET
   If [F:AWI]CODACT=""
    I = 1 : Break
   Else
    Read [ACV]CODACT = [F:AWI]CODACT
    If !fstat & [F:ACV]FLACT=2
     I = 1 : Break
    Endif
   Endif
  Next AWI
  If !I
   Raz [F:AWI]
  Endif
 Endif
Endif

If [F:AWI]WIN<>""
 FENETRE = [F:AWI]WIN
Endif

If [F:AWI]MSKENT="" & [F:AWI]NBMSK=0
 P = 0
Else
 P = 1
 If [F:AWI]MSKENT=""
  AWI_NOMMSK(P) = ""
  AWI_ABRMSK(P) = ""
  AWI_ROWMSK(P) = -1
 Else
  Read [AMK]CODMSK=[F:AWI]MSKENT
  If fstat
   GMESSAGE = [F:AWI]MSKENT-":"-mess(1,105,1) : # Ecran inexistant
   OK = 0 : Return : # Erreur grave
  Elsif [F:AMK]CODACT<>""
   Read [ACV]CODACT = [F:AMK]CODACT
   # Issue X3-75929 - 2018-07-26 by ALSHE : - set error status to be able to use it in VALOBJ.PERDU
   #                                        - change message text if activity code doesn't exist
   If fstat
    GMESSAGE = [F:AWI]MSKENT-":"-mess(8,176,1)-"("+[F:AMK]CODACT+")" : # Non-existent Activity Code
    GERR = 1 : OK = 0 : Return
   Else
    If [F:ACV]FLACT<>2
     GMESSAGE = [F:AWI]MSKENT-":"-mess(80,133,1)-"("+[F:AMK]CODACT+")" : # Ecran inactif
     GERR = 3 : OK = 0 : Return
    Endif
   Endif
  Endif
  AWI_NOMMSK(P) = [F:AWI]MSKENT
  AWI_FLGMSK(P) = 2
  AWI_ROWMSK(P) = -1
  AWI_INTMSK(P) = 0
  AWI_INTFLD(P) = ""
  AWI_ABRMSK(P) = [F:AMK]ABRMSK
 Endif
 AWI_BOX = ""
 For I=1 To [F:AWI]NBMSK
  K = 1
  If [F:AWI]ACTMSK(I-1)<>""
   Read [ACV]CODACT = [F:AWI]ACTMSK(I-1)
   If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
  Endif
  If K
   Read [AMK]CODMSK=[F:AWI]NOMMSK(I-1)
   If fstat
    Call ECR_TRACE([F:AWI]NOMMSK(I-1)-":"-mess(1,105,1),1) From GESECRAN : # Ecran inexistant
    Raz [F:AMK]
   Elsif [F:AMK]CODACT<>""
    Read [ACV]CODACT = [F:AMK]CODACT
    # Issue X3-75929 - 2018-07-26 by ALSHE : - Split trace in warning and error message
    If fstat
     Call ECR_TRACE([F:AWI]NOMMSK(I-1)-":"-mess(8,176,1)-"("+[F:AMK]CODACT+")",1) From GESECRAN # Non-existent Activity Code
     Raz [F:AMK] : GMESSAGE = ""
    Else
     If [F:ACV]FLACT<>2
      Call ECR_TRACE([F:AWI]NOMMSK(I-1)-":"-mess(80,133,1)-"("+[F:AMK]CODACT+")",-1) From GESECRAN # Masque inactif
      Raz [F:AMK] : GMESSAGE = ""
     Endif
    Endif
   Endif
   If [F:AMK]ABRMSK<>""
    If AWI_BOX = ""
     AWI_BOX = [F:AMK]ABRMSK
    Endif
    If I=1
     If find(AOB_GES,2,3)
      K = 0
      For J=1 To [F:AMK]NBBLOC
       If [F:AMK]TYPBLOC(J-1)=1
        K = J
        Read [AMZ]CODE = [F:AMK]CODMSK;CLE(NBCLE)
        If !fstat & [F:AMZ]NUMBLOC=J
         Break
        Endif
       Endif
      Next J
      If K=0
       GMESSAGE = [F:AMK]CODMSK-":"-mess(140,123,1) : # Variable bas de tableau inexistante
       OK = 0 : Break
      Endif
      AOB_BASPAG = [F:AMK]BASPAG(K-1)
      L = 0
      If [F:AMK]ACTBLOC(K-1)<>""
       Read [ACV]CODACT = [F:AMK]ACTBLOC(K-1)
       If !fstat & [F:ACV]DIME<>0
        L = [F:ACV]DIME
       Endif
      Endif
      If L<>0
       AOB_MAXLIG = L
      Else
       AOB_MAXLIG = [F:AMK]NBLIGT(K-1)
      Endif
     Endif
    Endif
    P += 1
    AWI_NOMMSK(P) = [F:AWI]NOMMSK(I-1)
    AWI_FLGMSK(P) = [F:AWI]FLGMSK(I-1)
    AWI_ROWMSK(P) = [F:AWI]ROWMSK(I-1)
    AWI_INTMSK(P) = [F:AWI]INTMSK(I-1)
    AWI_INTFLD(P) = [F:AWI]INTFOLD(I-1)
    AWI_ABRMSK(P) = [F:AMK]ABRMSK
   Endif
  Endif
 Next I
 If !OK
  Return
 Elsif AWI_NOMMSK(1)<>"" & AWI_BOX=""
  GMESSAGE = [F:AWI]WIN-":"-mess(188,123,1) : # Il doit y avoir un onglet
  OK = 0 : Return
 Endif
Endif
AWI_NBRMSK = P

Sorta AWI_NBRMSK
&     AWI_ROWMSK
&   , AWI_NOMMSK
&   , AWI_FLGMSK
&   , AWI_INTMSK
&   , AWI_INTFLD
&   , AWI_ABRMSK
& Order By AWI_ROWMSK(indice+1)

# Listes de gauche

Read [AWB]AWB0 = FENETRE
If fstat : Raz [F:AWB] : Endif

Raz J, N, R
For I=0 To [F:AWB]NBLIS-1
 If I=0
  If [F:AWB]FIRLIS=2
   Gosub INIVAR_DERLU
  Endif
 Endif
 K = 1
 If [F:AWB]ACTLIS(I)<>""
  Read [ACV]CODACT = [F:AWB]ACTLIS(I)
  If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
 Endif
 If K
  J += 1
  AWB_OBJ(J) = [F:AWB]OBJLIS(I)
  AWB_CLE(J) = [F:AWB]CLELIS(I)
  AWB_ORD(J) = [F:AWB]ORDLIS(I)
  AWB_TRE(J) = [F:AWB]TRELIS(I)
  AWB_CHG(J) = [F:AWB]CHGLIS(I)
  AWB_BRO(J) = [F:AWB]BROLIS(I)
  AWB_EXP(J) = [F:AWB]EXPLIS(I)
  AWB_ABB(J) = [F:AWB]ABRLIS(I)
  AWB_INT(J) = [F:AWB]INTLIS(I)
  Read [AOB]ABREV = [F:AWB]OBJLIS(I)
  If fstat
   Call ECR_TRACE([F:AWB]OBJLIS(I)-mess(161,123,1),1) From GESECRAN : # Objet inexistant
   Raz [F:AOB]
  Elsif [F:AOB]CODACT<>""
   Read [ACV]CODACT = [F:AOB]CODACT
   # Issue X3-75929 - 2018-07-26 by ALSHE : - Split trace in warning and error message
   If fstat
    Call ECR_TRACE([F:AWB]OBJLIS(I)-mess(8,176,1)-"("+[F:AOB]CODACT+")",-1) From GESECRAN : # Non-existent Activity Code
    Raz [F:AOB] : GMESSGE = ""
   Else
    If [F:ACV]FLACT<>2
     Call ECR_TRACE([F:AWB]OBJLIS(I)-mess(125,133,1)-"("+[F:AOB]CODACT+")",-1) From GESECRAN : # Objet inactif
     Raz [F:AOB] : GMESSGE = ""
    Endif
   Endif
  Endif
  If [F:AOB]NOMFIC<>""
   AWB_FIC(J) = [F:AOB]NOMFIC
   Read [ATB]CODFIC = [F:AOB]NOMFIC
   If fstat
    Call ECR_TRACE([F:AOB]NOMFIC-mess(32,133,1),1) From GESECRAN : # Table inexistante
    Raz [F:ATB]
   Elsif [F:ATB]CODACT<>""
    Read [ACV]CODACT = [F:ATB]CODACT
    # Issue X3-75929 - 2018-07-26 by ALSHE : - Split trace in warning and error message
    If fstat
     Call ECR_TRACE([F:AOB]NOMFIC-mess(8,176,1)-"("+[F:ATB]CODACT+")",1) From GESECRAN : # Non-existent Activity Code
     Raz [F:ATB] : GMESSAGE = ""
    Else
     If [F:ACV]FLACT<>2
      Call ECR_TRACE([F:AOB]NOMFIC-mess(126,133,1)-"("+[F:ATB]CODACT+")",-1) From GESECRAN : # Table inactive
      Raz [F:ATB] : GMESSAGE = ""
     Endif
    Endif
   Endif
   If [F:ATB]ABRFIC<>""
    AWB_ABR(J) = [F:ATB]ABRFIC
    If left$([F:AWB]CLELIS(I),4)="SPE_"
     Raz T
     For [ATI]Where CODFIC=[F:AOB]NOMFIC
      T += 1
     Next
     OK = 0
     For [ANX]ANX1 Where TABLE=[F:AOB]NOMFIC & FLACT=2
      T += 1
      If [F:ANX]CODIND=[F:AWB]CLELIS(I)
       AWB_IND(J) = [F:ANX]DESCRIPT
       AWB_NOI(J) = T
       OK = 1
       Break
      Endif
     Next
    Elsif [F:AWB]CLELIS(I)<>""
     Read [ATI]CODIND = [F:AOB]NOMFIC;[F:AWB]CLELIS(I)
     If fstat
      OK = 0
     Else
      AWB_IND(J) = [F:ATI]DESCRIPT
      AWB_NOI(J) = [F:ATI]NUMLIG
     Endif
    Else
     Read [ATI]NUMLIG(1) = [F:AOB]NOMFIC
     AWB_CLE(J) = [F:ATI]CODIND
     AWB_IND(J) = [F:ATI]DESCRIPT
     AWB_NOI(J) = [F:ATI]NUMLIG
    Endif
    If !OK
     GMESSAGE = [F:AOB]NOMFIC-[F:AWB]CLELIS(I)-mess(6,114,1) : # Clé inexistante
     Break
    Endif
   Endif
  Endif
  If [F:AWB]OBJLIS(I)=OBJET & !R
   R = 1
  Else
   N += 1
   If N=9 : N += 1 : Endif
  Endif
  If [F:AWB]OBJLIS(I)=OBJET & [F:AWB]DERLU=2 & [F:AWB]FIRLIS<>2 & !find(OBJET,AWB_OBJ(1..J-1))
   Gosub INIVAR_DERLU
  Endif
 Endif
Next I
If [F:AWB]DERLU=2 & [F:AWB]FIRLIS<>2 & !find(OBJET,[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1))
 Gosub INIVAR_DERLU
Endif
AWB_NBR = J
AWB_DER = [F:AWB]DERLU
AWB_FIR = [F:AWB]FIRLIS

# Intitulé des transactions

Raz AOB_TRNATB , J , TRANSAC , AOB_TRNCND , TABLE , AOB_TRNLEG
For [ATN]ATN1 Where OBJGES=[L]OBJET & OBJ<>""
 If TABLE=""
  Read [AOB]ABREV=[F:ATN]OBJ
  TABLE = [F:AOB]NOMFIC
 Else
  Read [AOB]ABREV=[F:ATN]OBJ
  If [F:AOB]NOMFIC<>TABLE
   J = 1
  Endif
 Endif
 TRANSAC = [F:ATN]COD
 If [F:ATN]CND<>""
  If AOB_TRNCND=""
   AOB_TRNCND = "(("+[F:ATN]CND
  Else
   AOB_TRNCND += ")+("+[F:ATN]CND
  Endif
 Endif
Next ATN
If AOB_TRNCND<>""
 If J
  AOB_TRNCND = "" : # Pas de filtre si plusieurs transactions gèrent le même objet sur des tables différentes
 Else
  AOB_TRNCND += "))"
 Endif
Endif
If TRANSAC<>""
 Read [ATN]ATN0 = TRANSAC
 Read [AOB]ABREV=[F:ATN]OBJ
 If !fstat & [F:AOB]NOMFIC<>""
  Read [ATB]CODFIC=[F:AOB]NOMFIC
  If !fstat
   If func AFNC.ACTIV("LEG")
    For [ATZ] Where CODFIC=[F:AOB]NOMFIC
     If [F:ATZ]CODTYP="ADI"
      Read [AMP]CODPAR=2;[F:AOB]NOMFIC;[F:ATZ]CODZONE;"ADI"
      If !fstat
       Raz CHAINE , ER
       Onerrgo ER
       CHAINE = num$(evalue([F:AMP]VALPAR))
       Onerrgo ERREUR
       If CHAINE="909" & !ER
        AOB_TRNLEG = [F:ATZ]CODZONE : Break
       Endif
      Endif
     Endif
    Next ATZ
   Endif
   If [F:ATB]INTIT<>""
    AOB_TRNATB = [F:AOB]NOMFIC
    AOB_TRNABR = [F:ATB]ABRFIC
    AOB_TRNTIT = [F:ATB]INTIT
    AOB_TRNFLD = [F:ATN]FLDCOD
    Read [ATZ]CODZONE=[F:AOB]NOMFIC;[F:ATB]INTIT
    AOB_TRNTYP = [F:ATZ]CODTYP
    If find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
     For [AMP] Where TYPAFF=2 & CODAFF=[F:AOB]NOMFIC & CODZON=[F:ATB]INTIT
      Case [F:AMP]CODPAR
       When "TABLE1"  : AOB_TRNCLE(1) = [F:AMP]VALPAR
       When "ZONE"    : AOB_TRNCLE(2) = [F:AMP]VALPAR
       When "CLECUR1" : AOB_TRNCLE(3) = [F:AMP]VALPAR
       When "CLECUR2" : AOB_TRNCLE(4) = [F:AMP]VALPAR
       Endcase
     Next AMP
    Endif
   Endif
  Endif
 Endif
Endif

Return

#---------------------------------------------------------------------------------------------------#
# Sous-programmes
#---------------------------------------------------------------------------------------------------#

$INIVAR_DERLU
J += 1
AWB_OBJ(J) = OBJET
AWB_CHG(J) = 2
AWB_BRO(J) = 1
L = find(OBJET,[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1))
If L=0
 AWB_CLE(J) = AOB_CLE
 AWB_ORD(J) = AOB_ORD
 AWB_TRE(J) = AOB_TRE
Else
 AWB_CLE(J) = [F:AWB]CLELIS(L-1)
 AWB_ORD(J) = [F:AWB]ORDLIS(L-1)
 AWB_TRE(J) = [F:AWB]TRELIS(L-1)
Endif
Return


#--------------------------------------------------------------#
# Calcul du format de la colonne
#--------------------------------------------------------------#

$FMTCAR
AOB_SELFOR(AOB_NBSEL) = '"K'
If    instr(1,AOB_SELOPT(AOB_NBSEL),"T") : AOB_SELFOR(AOB_NBSEL) += "T"            : # Tokenisé
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"D") : AOB_SELFOR(AOB_NBSEL) += "TD"           : # Token interdites
Endif
If    instr(1,AOB_SELOPT(AOB_NBSEL),"1") : AOB_SELFOR(AOB_NBSEL) += "1"  : Endif   : # Au moins 1 caractère
If    instr(1,AOB_SELOPT(AOB_NBSEL),"z") : AOB_SELFOR(AOB_NBSEL) += "z"  : Endif   : # Commentaires non affichés
If    instr(1,AOB_SELOPT(AOB_NBSEL),"=") : AOB_SELFOR(AOB_NBSEL) += "="            : # Centré
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"<") : AOB_SELFOR(AOB_NBSEL) += "<"            : # Cadré à gauche
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),">") : AOB_SELFOR(AOB_NBSEL) += ">"            : # Cadré à droite
Endif
If    instr(1,AOB_SELOPT(AOB_NBSEL),"U") : AOB_SELFOR(AOB_NBSEL) += "U" : Endif    : # Format fichier
If    instr(1,AOB_SELOPT(AOB_NBSEL),"W") : AOB_SELFOR(AOB_NBSEL) += "W" : Endif    : # Non creusé
If    instr(1,AOB_SELOPT(AOB_NBSEL),"X") : AOB_SELFOR(AOB_NBSEL) += "X" : Endif    : # Saisie masquée
If    instr(1,AOB_SELOPT(AOB_NBSEL),"c") : AOB_SELFOR(AOB_NBSEL) += "c" : Endif    : # Colorisé
AOB_SELFOR(AOB_NBSEL) += ":"
AOB_SELFOR(AOB_NBSEL) += num$(AOB_SELLNG(AOB_NBSEL))
If instr(1,AOB_SELOPT(AOB_NBSEL),"C")
 AOB_SELFOR(AOB_NBSEL) += "c"
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"A")
 If instr(1,AOB_SELOPT(AOB_NBSEL),"#")
  AOB_SELFOR(AOB_NBSEL) += "B"
 Else
  AOB_SELFOR(AOB_NBSEL) += "A"
 Endif
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"#")
 AOB_SELFOR(AOB_NBSEL) += "#"
Else
 AOB_SELFOR(AOB_NBSEL) += "X"
Endif
AOB_SELFOR(AOB_NBSEL) += '"'
Return

#-----------------#
$FMTNUM
AOB_SELFOR(AOB_NBSEL) = '"N'
If instr(1,AOB_SELOPT(AOB_NBSEL),"+") : AOB_SELFOR(AOB_NBSEL) += "+" : Endif       : # Nb > 0
If instr(1,AOB_SELOPT(AOB_NBSEL),"z") : AOB_SELFOR(AOB_NBSEL) += "z" : Endif       : # Zéro non affiché
If instr(1,AOB_SELOPT(AOB_NBSEL),"0") : AOB_SELFOR(AOB_NBSEL) += "0" : Endif       : # Paddé avec des 0
If instr(1,AOB_SELOPT(AOB_NBSEL),"3") : AOB_SELFOR(AOB_NBSEL) += "3" : Endif       : # Séparateur de 3 chiffres
If instr(1,AOB_SELOPT(AOB_NBSEL),"W") : AOB_SELFOR(AOB_NBSEL) += "W" : Endif       : # Non creusé
If instr(1,AOB_SELOPT(AOB_NBSEL),"-") : AOB_SELFOR(AOB_NBSEL) += "-" : Endif       : # Signe forcé
If instr(1,AOB_SELOPT(AOB_NBSEL),"D") : AOB_SELFOR(AOB_NBSEL) += "D" : Endif       : # Signe après
If instr(1,AOB_SELOPT(AOB_NBSEL),"c") : AOB_SELFOR(AOB_NBSEL) += "c" : Endif       : # Colorisé
AOB_SELFOR(AOB_NBSEL) += ":"
AOB_SELFOR(AOB_NBSEL) += num$(AOB_SELLNG(AOB_NBSEL))
If instr(1,AOB_SELOPT(AOB_NBSEL),"F") & AOB_SELLNG(AOB_NBSEL)=int(AOB_SELLNG(AOB_NBSEL))   : # Flottant si pas de décimales
 AOB_SELFOR(AOB_NBSEL) += "F"
Else
 AOB_SELFOR(AOB_NBSEL) +="#"
Endif
AOB_SELFOR(AOB_NBSEL) += '"'
Return

#-----------------#
$FMTDAT
AOB_SELFOR(AOB_NBSEL) = '"D'
If instr(1,AOB_SELOPT(AOB_NBSEL),"z")  : AOB_SELFOR(AOB_NBSEL) += "z" : Endif       : # Commentaires non affichés
If instr(1,AOB_SELOPT(AOB_NBSEL),"Z")  : AOB_SELFOR(AOB_NBSEL) += "Z" : Endif       : # Date nulle autorisée
If instr(1,AOB_SELOPT(AOB_NBSEL),"W")  : AOB_SELFOR(AOB_NBSEL) += "W" : Endif       : # Non creusé
If instr(1,AOB_SELOPT(AOB_NBSEL),"c")  : AOB_SELFOR(AOB_NBSEL) += "c" : Endif       : # Colorisé
If !instr(1,AOB_SELFOR(AOB_NBSEL),"Z") : AOB_SELFOR(AOB_NBSEL) += "Z" : Endif
If !instr(1,AOB_SELFOR(AOB_NBSEL),"z") : AOB_SELFOR(AOB_NBSEL) += "z" : Endif
AOB_SELFOR(AOB_NBSEL) += ':"'
If    instr(1,AOB_SELOPT(AOB_NBSEL),"1") : AOB_SELFOR(AOB_NBSEL) += '+GFMDAT'  : K = func VALMSKLEC.LG(GFMDAT,8)
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"2") : AOB_SELFOR(AOB_NBSEL) += '+GFMDAT4' : K = func VALMSKLEC.LG(GFMDAT4,10)
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"3") : AOB_SELFOR(AOB_NBSEL) += '+GFMDAT3' : K = func VALMSKLEC.LG(GFMDAT3,15)
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"4") : AOB_SELFOR(AOB_NBSEL) += '+GFMDAT9' : K = func VALMSKLEC.LG(GFMDAT9,20)
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"5") : AOB_SELFOR(AOB_NBSEL) += '+GFMJOU'  : K = func VALMSKLEC.LG(GFMJOU,5)
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"6") : AOB_SELFOR(AOB_NBSEL) += '+GFMMOI'  : K = func VALMSKLEC.LG(GFMMOI,5)
Elsif instr(1,AOB_SELOPT(AOB_NBSEL),"7") : AOB_SELFOR(AOB_NBSEL) += '+GFMMOI4' : K = func VALMSKLEC.LG(GFMMOI4,7)
Else                                     : AOB_SELFOR(AOB_NBSEL) += '+GFMDAT'  : K = func VALMSKLEC.LG(GFMDAT,8)
Endif
AOB_SELLNG(AOB_NBSEL) = K
Return

#-----------#
$ER
ER = errn
Resume

#--------------#
$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
MOK = 0
End

