$ON_CPCDATVAL
Onevent BEFORE_INPUT Call AS_CPCDATVAL(zc) From W1ECP2
Onevent AFTER_CHANGE Gosub AMM_CPCDATVAL From W1ECP2
Onevent BEFORE_AREA Gosub AV_CPCDATVAL From W1ECP2
Return

$AV_CPCDATVAL
Chgfmt [M]CPCDATVAL(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_CPCDATVAL(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_CPCDATVAL(VALEUR) From SUBECP
If mkstat=2
 [M]CPCDATVAL(INDIC) = VALEUR
 Affzo CPCDATVAL(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$AMM_CPCDATVAL
Call AM_CPCDATVAL(zc)
If !mkstat & GOBJET
 zoncou = "CPCDATVAL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPCDATVAL(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_CPCDATVAL(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "CPCDATVAL" : GZNUM = 45890 : Endif
Gosub _AFF
End

