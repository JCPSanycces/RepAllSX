#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:04"
A_USER  = "DOC"
A_STAMP = "20181109230404"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRCPC"
  If [M]NBRCPC=0
  Endif
 When "NBRDLT"
  If [M]NBRDLT=0
  Endif
 When "NBRVAL"
  If [M]NBRVAL=0
  Endif
 When "NBRGRA"
  If [M]NBRGRA=0
  Endif
 When "NBRDLTVAL"
  If [M]NBRDLTVAL=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ECP2 [ECP2]
Gosub HORODAT
Local Inpbox "ECP2" From GFONCTION At A_STAMP With A_WINDPREV Mask [ECP2] As [SIM_]
Grizo [ECP2]5
Grizo [ECP2]10
Grizo [ECP2]15
Grizo [ECP2]20
Grizo [ECP2]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ECP2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=5
X1(1)=1 : X2(1)=0 : Y1(1)=6 : Y2(1)=5
X1(2)=1 : X2(2)=88 : Y1(2)=6 : Y2(2)=10
X1(3)=1 : X2(3)=88 : Y1(3)=11 : Y2(3)=22
X1(4)=1 : X2(4)=0 : Y1(4)=23 : Y2(4)=22
Return

$ON_NBRCPC
Onevent CONTROL Call C_NBRCPC From W1ECP2
Onevent BEFORE_INPUT Call AS_NBRCPC From W1ECP2
Return

Subprog AS_NBRCPC
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45131,GBOUT1) From OBJDIV
Call TEXTE(22067,GBOUT2) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRCPC From W1ECP2
Onkey 130 Titled GBOUT2 Call B2_NBRCPC From W1ECP2
Gosub _AFF
End

Subprog C_NBRCPC
Local Decimal BASPAG
## Action STD
Call C_NBRCPC From SUBECP
If mkstat : GERR = 1 : GZONE = "NBRCPC" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B1_NBRCPC
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC2"
 Call OBJET_CHAR([M]CODSCACPC(nolign-1),"HRSCA","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBRCPC
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC1"
 Call OBJET_CHAR([M]CPC(nolign-1),"CPC","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CPC
Return

$ON_ZCPC
Onevent BEFORE_AREA Gosub AV_ZCPC From W1ECP2
Return

$AV_ZCPC
Call LECTEXTRA(zc,"COMPETENCE","DES",num$([M]CPC(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_LEVCPC
Return

$ON_CPCDAT
Return

$ON_ORICPC
Onevent INIT_AREA Call D_ORICPC(zc) From W1ECP2
Return

Subprog D_ORICPC(VALEUR)
Variable Integer VALEUR
If varinit([M]ORICPC,indice)=0
 VALEUR = 9
Endif
Gosub _AFF
End

$ON_FLGMOD
Onevent INIT_AREA Call D_FLGMOD(zc) From W1ECP2
Return

Subprog D_FLGMOD(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGMOD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_FLGOLD
Onevent INIT_AREA Call D_FLGOLD(zc) From W1ECP2
Return

Subprog D_FLGOLD(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGOLD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CODSCACPC
Return

$ON_CPCDLT
Return

$ON_NBRVAL
Onevent CONTROL Call C_NBRVAL From W1ECP2
Onevent BEFORE_INPUT Call AS_NBRVAL From W1ECP2
Return

Subprog AS_NBRVAL
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45131,GBOUT1) From OBJDIV
Call TEXTE(22067,GBOUT2) From OBJDIV
Call TEXTE(11932,GBOUT3) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRVAL From W1ECP2
Onkey 130 Titled GBOUT2 Call B2_NBRVAL From W1ECP2
Onkey 131 Titled GBOUT3 Call B3_NBRVAL From W1ECP2
Gosub _AFF
End

Subprog C_NBRVAL
Local Decimal BASPAG
## Action STD
Call C_NBRVAL From SUBECP
If mkstat : GERR = 1 : GZONE = "NBRVAL" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B1_NBRVAL
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC2"
 Call OBJET_CHAR([M]CODSCAVAL(nolign-1),"HRSCA","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBRVAL
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC1"
 Call OBJET_CHAR([M]CPCVAL(nolign-1),"CPC","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBRVAL
Local Decimal BASPAG
If !GWEBSERV
 ## Action CPCHIS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CPCHIS"
 PARMSK(1) = [M]CPCVAL(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"CPCHIS","SUBECP","XYSUBECP") From GSAISIE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CPCVAL
Onevent BEFORE_INPUT Call AS_CPCVAL(zc) From W1ECP2
Onevent CONTROL Call C_CPCVAL(zc) From W1ECP2
Onevent AFTER_CHANGE Gosub AMM_CPCVAL From W1ECP2
Return

Subprog AS_CPCVAL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_CPCVAL(VALEUR) From SUBECP
If mkstat=2
 [M]CPCVAL(INDIC) = VALEUR
 Affzo CPCVAL(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_CPCVAL(zc) From W1ECP2
Onkey 144 Titled GBOUTP Call P_CPCVAL(zc) From W1ECP2
Onkey 146 Titled GBOUTA Call SA_CPCVAL(zc) From W1ECP2
Gosub _AFF
End

Subprog C_CPCVAL(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
If !mkstat
 ## Action STD
 Call C_CPCVAL(VALEUR) From SUBECP
 If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CPCVAL
Call AM_CPCVAL(zc)
If !mkstat & GOBJET
 zoncou = "CPCVAL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPCVAL(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CPCVAL(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "CPCVAL" : GZNUM = 22067 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCPCVAL)")>indice
 [M]CPCVAL(indice) = VALEUR
 Affzo ZCPCVAL(indice)
Endif
Gosub _AFF
End

Subprog S_CPCVAL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CPC"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_CPCVAL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPCVAL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCPCVAL
Onevent BEFORE_AREA Gosub AV_ZCPCVAL From W1ECP2
Return

$AV_ZCPCVAL
Call LECTEXTRA(zc,"COMPETENCE","DES",num$([M]CPCVAL(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_LEVCPCVAL
Onevent CONTROL Call C_LEVCPCVAL(zc) From W1ECP2
Onevent BEFORE_INPUT Call AS_LEVCPCVAL(zc) From W1ECP2
Onevent AFTER_CHANGE Gosub AMM_LEVCPCVAL From W1ECP2
Return

Subprog AS_LEVCPCVAL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_LEVCPCVAL(VALEUR) From SUBECP
If mkstat=2
 [M]LEVCPCVAL(INDIC) = VALEUR
 Affzo LEVCPCVAL(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_LEVCPCVAL(zc) From W1ECP2
Gosub _AFF
End

Subprog C_LEVCPCVAL(VALEUR)
Variable Char    VALEUR()
## Action CTLNIV
Call CTLNIV(VALEUR,[M]CPCVAL(nolign-1)) From SUBCPC
If mkstat : GERR = 1 : GZONE = "LEVCPCVAL" : GZNUM = 5230 : Endif
Gosub _AFF
End

$AMM_LEVCPCVAL
Call AM_LEVCPCVAL(zc)
If !mkstat & GOBJET
 zoncou = "LEVCPCVAL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEVCPCVAL(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEVCPCVAL(VALEUR) From SUBECP
If mkstat : GERR = 1 : GZONE = "LEVCPCVAL" : GZNUM = 5230 : Endif
Gosub _AFF
End

Subprog S_LEVCPCVAL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELNIV
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELNIV"
 PARMSK(1) = [M]CPCVAL(nolign-1)
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELNIV","SUBCPC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

