#
########################################################################################################################
If 1=1
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
Endif

If 1=0
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("LOF",GBIDC1,GBIDC2) From GOBJET
Endif

End
######################################################################################

$ACTION
 #If GUSER="GBO" : Infbox ACTION-num$(dim([M:ELT]EVTTYP)) : Endif
 Case ACTION
  When "OUVRE"   : Gosub OUVRE
  When "DEBUT"   : Gosub DEBUT
  When "BOUTON"  : Gosub BOUTON
  When Default
 Endcase
Return

#================================================
$OUVRE
 Global Char    GOBJREF
 Global Integer GOBJLIN
 Global Integer GOBJTYP
 GOBJTYP = val(PARAM(2))
 If GOBJTYP=GVML_OMDEPEN
  GOBJREF=left$(PARAM(1),instr(1,PARAM(1),"~")-1)
  GOBJLIN=val(right$(PARAM(1),instr(1,PARAM(1),"~")+1))
 Else
  GOBJREF = PARAM(1)
 Endif
 If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
Return

#================================================
$DEBUT
 Raz [M:ELT]
 [M:ELT]ALLEVTTYP = G_OUI                : Affzo [M:ELT]ALLEVTTYP
 [M:ELT]ALLDPRPLN = G_OUI                : Affzo [M:ELT]ALLDPRPLN
 [M:ELT]ALLUSR    = G_OUI                : Affzo [M:ELT]ALLUSR
 [M:ELT]ALLCPT    = G_OUI                : Affzo [M:ELT]ALLCPT
 [M:ELT]ALLSNS    = G_OUI                : Affzo [M:ELT]ALLSNS
 Raz [M:ELT]EVTTYP : Grizo [M:ELT]EVTTYP : Affzo [M:ELT]EVTTYP
 Raz [M:ELT]DPRPLN : Grizo [M:ELT]DPRPLN : Affzo [M:ELT]DPRPLN
 Raz [M:ELT]USR    : Grizo [M:ELT]USR    : Affzo [M:ELT]USR
 Raz [M:ELT]CPT    : Grizo [M:ELT]CPT    : Affzo [M:ELT]CPT
 Raz [M:ELT]SNS    : Grizo [M:ELT]SNS    : Affzo [M:ELT]SNS
 Diszo [M:ELT]10
Return

#================================================
$BOUTON
 If BOUT="R"
  Call TEMPON("R") From GESECRAN
  Raz [M:ELT]NBEVT
  Gosub LOOP_EVTLIST
  Call TEMPOFF() From GESECRAN
 Endif
Return

#================================================
$LOOP_EVTLIST
 Local Char LCRITEVTTYP(255)
 Local Char LIBTYP(30)

 If dim(GOBJTYP)<0 | (dim(GOBJTYP)>0 & GOBJTYP=0)
  LCRITEVTTYP="1=1"
 Else
  LCRITEVTTYP="N2=GOBJTYP"
 Endif

 Filter [F:ADI] Where NUMTAB=GTD_EVENT & evalue(LCRITEVTTYP) # Table diverse 962
 For [ADI]
  If find([F:ADI]A2,GTABEVT) : # FQ59900
   If [F:ADI]CODE="FASCHGIMP" | [F:ADI]CODE="FASAFFAGE" | [F:ADI]CODE="FASCCNAGE"
    If clalev([F:EVT2]) : Close Local File [F:EVT2] : Endif
    Local File =[F:ADI]A2 [EVT2]
   Endif
   If [M:ELT]EVTTYP<>"" & [F:ADI]CODE=[M:ELT]EVTTYP
     If clalev([F:EVT]) : Close Local File [F:EVT] : Endif
     Local File =[F:ADI]A2 [EVT]
     Call LECTEXTRA(LIBTYP,"ATABDIV","LNGDES",num$(GTD_EVENT),[F:ADI]CODE) From ATEXTRA # Table diverse 962 #fq64963
     Gosub LOAD_EVTLIST
   Elsif [M:ELT]EVTTYP=""
    If clalev([F:EVT]) : Close Local File [F:EVT] : Endif
    Local File =[F:ADI]A2 [EVT]
    Call LECTEXTRA(LIBTYP,"ATABDIV","LNGDES",num$(GTD_EVENT),[F:ADI]CODE) From ATEXTRA # Table diverse 962
    Gosub LOAD_EVTLIST
   Endif
  Endif
 Next
 Filter [F:ADI]

 Actzo [M:ELT]NBEVT
 Actzo [M:ELT]EVTPRINC
 Affzo [M:ELT]10

Return

#================================================
$LOAD_EVTLIST
 Local Char LCRIT(255)

 #> Préparation du critère de sélection

 LCRIT="REF=GOBJREF"
 If [F:ADI]N2=GVML_OMDEPEN
  LCRIT+="& LIN=GOBJLIN"
 Endif
 If [M:ELT]ALLDPRPLN<>G_OUI : LCRIT += "&DPRPLN=[M:ELT]DPRPLN" : Endif
 If [M:ELT]ALLUSR<>G_OUI    : LCRIT += "&CREUSR=[M:ELT]USR"    : Endif
 If [M:ELT]ALLCPT<>G_OUI    : LCRIT += "&CPTFLG=[M:ELT]CPT"    : Endif
 If [M:ELT]ALLSNS<>G_OUI    : LCRIT += "&SNSEVE=[M:ELT]SNS"    : Endif

 If [F:ADI]CODE="FASCHGIMP" | [F:ADI]CODE="FASAFFAGE" | [F:ADI]CODE="FASCCNAGE"
  Filter [F:EVT] Where evalue(LCRIT) & EVTPRINC=G_OUI Order By TIMSTP
 Else
  Filter [F:EVT] Where evalue(LCRIT) Order By TIMSTP
 Endif

 For [F:EVT]
  If [F:ADI]CODE="FASCHGIMP" | [F:ADI]CODE="FASAFFAGE" | [F:ADI]CODE="FASCCNAGE"
   If [F:EVT]EVTPRINC=G_OUI
    Filter [F:EVT2] Where REF=[F:EVT]REF & EVTPRINC<>G_OUI & TIMSTPP=[F:EVT]TIMSTP
    If rowcount([F:EVT2])
     [M:ELT]EVTPRINC([M:ELT]NBEVT) = "48"
     [M:ELT]PACK([M:ELT]NBEVT)=G_OUI
    Else
     [M:ELT]EVTPRINC([M:ELT]NBEVT) = ""
    Endif
    Filter [F:EVT2]
   Else
    [M:ELT]EVTPRINC([M:ELT]NBEVT) = ""
   Endif
  Else
   [M:ELT]EVTPRINC([M:ELT]NBEVT) = ""
  Endif
  [M:ELT]EVTSECICO([M:ELT]NBEVT) = ""
  [M:ELT]TYP([M:ELT]NBEVT)       = [F:ADI]CODE
  [M:ELT]LIBTYP([M:ELT]NBEVT)    = LIBTYP
  [M:ELT]PLN([M:ELT]NBEVT)       = [F:EVT]DPRPLN
  [M:ELT]CURPERSTR([M:ELT]NBEVT) = [F:EVT]CURPERSTR   : # FQ101826
  [M:ELT]CREUSR([M:ELT]NBEVT)    = [F:EVT]CREUSR
  [M:ELT]CREDAT([M:ELT]NBEVT)    = [F:EVT]CREDAT
  [M:ELT]CRETIM([M:ELT]NBEVT)    = func TRTEVTLIST.TIME_NUM_TO_STRING([F:EVT]CRETIM)
  [M:ELT]EVTDAT([M:ELT]NBEVT)    = [F:EVT]EVTDAT
  [M:ELT]CPTDATINT([M:ELT]NBEVT) = [F:EVT]CPTDATINT
  [M:ELT]CPTFLG([M:ELT]NBEVT)    = [F:EVT]CPTFLG
  [M:ELT]SNSEVE([M:ELT]NBEVT)    = [F:EVT]SNSEVE
  [M:ELT]EVT([M:ELT]NBEVT)       = [F:ADI]CODE
  [M:ELT]REF([M:ELT]NBEVT)       = [F:EVT]REF
  [M:ELT]TIMSTP([M:ELT]NBEVT)    = [F:EVT]TIMSTP

  #@fq65636
  #@fq70466
 #If [F:ADI]CODE="FASMTC" | [F:ADI]CODE="FASREEVAL" | [F:ADI]CODE="FASCHGPPL"
  If find([F:ADI]CODE,GARCEVT)
   If !clalev([F:DEPA]) : Local File DEPRECARC [F:DEPA] : Endif
   Filter [F:DEPA] Where AASREF=[F:EVT]REF&
&                        DPRPLN=[F:EVT]DPRPLN&
&                        EVT=[F:ADI]CODE&
&                        TIMSTP=[F:EVT]TIMSTP
   Read [F:DEPA] First
   If !fstat
    [M:ELT]ARCFLG([M:ELT]NBEVT)="216"
   Endif
   Filter [F:DEPA]
  Endif
  #

  [M:ELT]NBEVT+=1

 Next
 Filter [F:EVT]

Return

#----------
Funprog TIME_NUM_TO_STRING(PTIME)
Value Integer PTIME
Local Char    RTIME

Local Integer HEURE
Local Integer MINUTE
Local Integer SECONDE
Local Integer RESTE

HEURE   = int(PTIME/3600)
MINUTE  = int((PTIME-HEURE*3600)/60)
SECONDE = int(PTIME-HEURE*3600-MINUTE*60)

RTIME   = format$("N0:2",HEURE)+":"+format$("N0:2",MINUTE)+":"+format$("N0:2",SECONDE)

End RTIME

######################################################################################
## Etiquette ajoutée par le superviseur (écran EVTLIST) 25/09/2007 15:11:00 (GBO)
######################################################################################

#-------------------------------------------------------------------------------------
Subprog AM_ALLEVTTYP(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Raz [M:ELT]EVTTYP : Grizo [M:ELT]EVTTYP : Affzo [M:ELT]EVTTYP
 Else
  Raz [M:ELT]EVTTYP : Actzo [M:ELT]EVTTYP : Affzo [M:ELT]EVTTYP
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AM_ALLDPRPLN(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Raz [M:ELT]DPRPLN : Grizo [M:ELT]DPRPLN : Affzo [M:ELT]DPRPLN
 Else
  Raz [M:ELT]DPRPLN : Actzo [M:ELT]DPRPLN : Affzo [M:ELT]DPRPLN
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR

End

#-------------------------------------------------------------------------------------
Subprog AV_TYP(VALEUR)
Variable Char    VALEUR()

 #*Fq-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
 If [M:ELT]CPTFLG(nolign-1)=G_OUI
  Chgstl NBEVT(nolign-1)  With "AWARNHIGH"
  pcolor=GCOUL(1)  # Rouge
 Else
    Chgstl NBEVT(nolign-1)  With "AWARNLOW"
    pcolor=GCOUL(3)  # Bleu
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AM_ALLUSR(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Raz [M:ELT]USR : Grizo [M:ELT]USR : Affzo [M:ELT]USR
 Else
  Raz [M:ELT]USR : Actzo [M:ELT]USR : Affzo [M:ELT]USR
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AM_ALLCPT(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Raz [M:ELT]CPT : Grizo [M:ELT]CPT : Affzo [M:ELT]CPT
 Else
  Raz [M:ELT]CPT : Actzo [M:ELT]CPT : Affzo [M:ELT]CPT
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AS_CPT(VALEUR)
Variable Integer VALEUR
End

#-------------------------------------------------------------------------------------
Subprog AM_ALLSNS(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Raz [M:ELT]SNS : Grizo [M:ELT]SNS : Affzo [M:ELT]SNS
 Else
  Raz [M:ELT]SNS : Actzo [M:ELT]SNS : Affzo [M:ELT]SNS
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AS_SNS(VALEUR)
Variable Integer VALEUR

End

#-------------------------------------------------------------------------------------
Subprog CL_EVTPRINC(VALEUR)
Variable Char    VALEUR()

 #FQ104684 indice manquant
 If [M:ELT]EVTPRINC(nolign-1)<>""
  If [M:ELT]PACK(nolign-1)=G_OUI
   If clalev([F:EVT2]) : Close Local File [F:EVT2] : Endif
   [M:ELT]EVTPRINC(nolign-1)="49"
   [M:ELT]PACK(nolign-1)=G_NON
   Case [M:ELT]TYP(nolign-1)
    When "FASAFFAGE" : Local File EFASAFFAGE [EVT2]
    When "FASCHGIMP" : Local File EFASCHGIMP [EVT2]
    When "FASCCNAGE" : Local File EFASCCNAGE [EVT2]
   Endcase
   Filter [F:EVT2] Where REF=[M:ELT]REF(nolign-1) & TIMSTPP=[M:ELT]TIMSTP(nolign-1)
   Local Integer NBEVTSEC : NBEVTSEC=rowcount([F:EVT2])
   Local Integer I_EVT
   Insa nolign, NBEVTSEC [M:ELT]NBEVT
   I_EVT=nolign
   For [F:EVT2]
    I_EVT+=1
    [M:ELT]EVTSEC(I_EVT-1)    = G_OUI
    [M:ELT]EVTSECICO(I_EVT-1) = "250"
    [M:ELT]TYP(I_EVT-1)       = [M:ELT]TYP(nolign-1)
    [M:ELT]PLN(I_EVT-1)       = [F:EVT2]DPRPLN
    [M:ELT]CREUSR(I_EVT-1)    = [F:EVT2]CREUSR
    [M:ELT]CREDAT(I_EVT-1)    = [F:EVT2]CREDAT
    [M:ELT]CRETIM(I_EVT-1)    = func TRTEVTLIST.TIME_NUM_TO_STRING([F:EVT2]CRETIM)
    [M:ELT]EVTDAT(I_EVT-1)    = [F:EVT2]EVTDAT
    [M:ELT]CPTDATINT(I_EVT-1) = [F:EVT2]CPTDATINT
    [M:ELT]CPTFLG(I_EVT-1)    = [F:EVT2]CPTFLG
    [M:ELT]SNSEVE(I_EVT-1)    = [F:EVT2]SNSEVE
    [M:ELT]EVT(I_EVT-1)       = [M:ELT]EVT(nolign-1)
    [M:ELT]REF(I_EVT-1)       = [F:EVT2]REF
    [M:ELT]TIMSTP(I_EVT-1)    = [F:EVT2]TIMSTP
    [M:ELT]NBEVT+=1
   Next
   Affzo [M:ELT]
  Else
   Local Integer I_EVT, NB_EVTSEC
   For I_EVT=nolign+1 To [M:ELT]NBEVT
    If [M:ELT]EVTSEC(I_EVT-1)<>G_OUI
     Break
    Else
     NB_EVTSEC+=1
    Endif
   Next I_EVT
   [M:ELT]PACK(nolign-1)=G_OUI
   Dela nolign, NB_EVTSEC  [M:ELT]NBEVT
   [M:ELT]NBEVT-=NB_EVTSEC
   Affzo [M:ELT]
  Endif
 Endif



End
