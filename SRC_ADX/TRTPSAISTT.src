#<AdxTL>@(#)8.0.0.0 $Revision$
##################################################################################
# TRTPSAISTT: Action de saisie des article sous-traitée en réception HN 05/03/03 #
# ------------------------------------------------------------------------------ #
# Ce traitement n'est pas un objet mais est utilisé par l'action TRTPSAISTT      #
#           et sert à gérer le masque  écran "PTHPSTT [PSTT]"                    #
##################################################################################

$ACTION
#---------------------------------------#
# Action de saisie TRTPSAIPTT (GTRAITE) #
#---------------------------------------#
Case ACTION
 When "INIT"         : Gosub  INIT               : # GTRAITE
 When "OUVRE_BOITE"  : Gosub  OUVRE_BOITE        : # GSAISIE
 When "TITRE"        : Gosub  TIT                  # FQ 51144
 When "SETBOUT"      : Gosub  SETB_SAISTT        : # GSAISIE
 When "DEBUT"        : Gosub  DEB_SAISTT         : # GSAISIE
 When "AP_CHOIX"     : Gosub  AP_CHOIX
 When "OK"           : Gosub  FIN_SAISTT           # FQ 68578 GA 10/2010
 When "FIN"          : Gosub  FIN_SAISTT           # FQ 68578 GA 10/2010 bouton remplacé par OK (validation nécessaire)
 When "FINSAI"       : Gosub  FINSAI_SAISTT
 When "AAPRES_NBLIG" : Gosub  AAPRES_NBLIG
 When "AB1_LOC"      : Gosub  AB1_LOC
 When "BB1_LOC"      : Gosub  BB1_LOC
Endcase
Return


#-----------------------------------------------#
# Initialisations avant exécution du traitement #
#-----------------------------------------------#
$INIT
#--- Facture à recevoir comptabilisée pour cette réception ! Voulez-vous continuer ? ---#
If GREP=""
  Gosub AVANT_MOD From SUBPTHA : If !OK  FIN=1 : Return : Endif
Endif
#-----
Local Char     LBOI(GLONFEN) : LBOI     =PARAM(1)
BOITE = LBOI
BCRIT = ""
Return


#-----------------------------#
# Avant ouverture de la boite #
#-----------------------------#
$OUVRE_BOITE
Local Char     LBOI(GLONFEN) : LBOI     =PARAM(1)
Local Shortint NOL           : NOL      =val(PARAM(2))
Local Shortint SAVNOLIGN     : SAVNOLIGN=NOL+1
Local Char     LUSCAV(2)
Local Char     LLBEFMT(GLONARP)
Local Integer  LDACCOE
If !clalev([F:PWS])  Local File PWRKSTT    [PWS]  : Endif
If !clalev([F:SCH])  Local File SCHEDULING [SCH]  : Endif
If !clalev([F:MFG])  Local File MFGHEAD    [MFG]  : Endif
If !clalev([F:MFI])  Local File MFGITM     [MFI]  : Endif
If !clalev([F:OPS])  Local File OPERATIONS [OPS]  : Endif
Return

#########################################################################
$TIT       # FQ 51144 Titre traduit pour les transactions V6
    Call LECTEXTRA(TIT,"PURTRS","DESAXX",num$([F:PTR]PTRTYP),[F:PTR]PTRNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:PTR]PTRNUM-":"-TIT
Return
#########################################################################


$SETB_SAISTT
#----------------------------#
# Positionnement des boutons #
#----------------------------#
If REP<>"M"
  Call VIREBOUT(CHBOU,"E")  From GOBJET
Endif
Call VIREBOUT(CHBOU,"A")  From GOBJET
Return


#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAISTT
#----- à cause des problèmes sur diszo
If !GIMPORT
  Raz [M:PSTT]
  [M:PSTT]NBLIG=[M:PTH1]NBWRK : Actzo [M:PSTT]1-99 : Affzo [M:PSTT]1-99
Endif
#-----
Raz [M:PSTT]
GMODIF=2
Call CHARG_STT_OF(NOL) From SUBPTHC
#
If !GIMPORT  Affzo [PSTT]1-99 : Endif
Return

$AP_CHOIX
If REPONSE=GSTAEND
 #GBIDD1=sum(abs([M:PSTT]QTYSTU(0..[M:PSTT]NBLIG-1)))
 #If GBIDD1<=0 : Call ERREUR(mess(9,184,1))   From GESECRAN
  If sum([M:PSTT]QTYSTU(0..[M:PSTT]NBLIG-1))=0
    Call ERREUR(mess(9,184,1))   From GESECRAN
    Raz REPONSE : FIN=0 : Return
  Endif
  #-- Ne pas faire d'autres contrôles on peut sortir même si non renseigné
Endif
Return


#---------------------------------#
# Après l'exécution du bouton FIN #
#---------------------------------#
$FIN_SAISTT
If [M:PSTT]NBLIG=0  Return : Endif
For I=0 To [M:PSTT]NBLIG-1
  If [M:PSTT]QTYSTU(I)=0
    #----- Suppression des enreg écran de stock -----#
    Call DELSTOENTW (I,I,"PSTT",1,1,[M:PSTT]STOFCY,1,"") From STKENT
  Endif
  nolign=I+1 : Gosub ENR_PWS_STT From SUBPTHC
Next I
If !find(0,[M:PSTT]WSTOFLG(0..[M:PSTT]NBLIG-1))
  Gosub MAJ_QTERCP     : # Calcul des quantités en unité de la réception
  Gosub MAJ_LIG_STT    : # Mise à jour de la ligne de réception
Else
  [M:PTH1]WSTOFLG([M:PSTT]ORINOL)=0
Endif
# Issue 95496 - 2014-03-17 by CCC : WOF : there are several [M:PSTT]WSTOSEQ for a [M:PTH1]WSTOSEQ
##GA ajout 05/2006
#[M:PTH1]WSTOSEQ([M:PSTT]ORINOL)=[M:PSTT]WSTOSEQ(0)
If !GIMPORT  FIN=1 : Endif
Return


#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAISTT
nolign=SAVNOLIGN
If !GIMPORT # Issue 96008 GA 10/2014
   Affzo [M:PTH1]ITMREF(nolign-1)
Endif
Return


#######################################################################
#########      Actions champs de l'écran PTHPSTT [PSTT]      ##########
#######################################################################

Subprog IB_NBLIG
#----------------------------------#
# Initialisation des boutons       #
# -------------------------------- #
# B2  Saisie du detail             #
# B3  Info du lot                  #
# B4  Complément lot               #
# B5  Modif de stock               #
# B6  Stock/lot                    #
#----------------------------------#
Local Integer  C, WRETOUR
Local Shortint NOL : NOL=nolign-1
Raz GBOUT1, GBOUT7, GBOUT8, GBOUT9, GBOUT10, GBOUT11, GBOUT12
If [M:PSTT]NBLIG<>0 & NOL<=dim([M:PSTT]ITMREF)-1
  #----- Par sécurité, lecture ITM (SB) -----#
  If [F:ITM]ITMREF<>[M:PSTT]ITMREF(NOL)
    Read [ITM] ITM0=[M:PSTT]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
  Endif
  #----- Lecture aticle-site si nécessaire -----#
  If [F:ITF]ITMREF<>[M:PSTT]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PSTT]STOFCY
    Read [ITF] ITF0=[M:PSTT]ITMREF(NOL);[M:PSTT]STOFCY
    If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
  Endif
  #--- Pour une ligne déjà créée
  If [M:PSTT]CREFLG(NOL)<>0
  #--- Pour une ligne non créée
  Else
    If [F:ITF]STOMGTCOD>1
      Call STKINIBTN(2,5,3,4,"PSTT","PTR",[M:PSTT]ITMREF(NOL) , [M:PSTT]STOFCY) From STKENT
    Endif
  Endif
  If [M:PSTT]QTYSTU(NOL)=0
    Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
  Elsif dim([M:PSTT]LOT)<1 | (dim([M:PSTT]LOT)>0 & [M:PSTT]LOT(NOL)="$")
    #----- Pas de stock par lot si lot inactif ou si lots multiples -----#
    Raz GBOUT6
  Endif
  #----- On les enlève si pas habilité ou en consult
  GBIDC2="M": GFCY=[M:PSTT]STOFCY : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2 | GCONSULT>0
    Raz GBOUT3, GBOUT5
  Endif
Endif
End


$AB2_NBLIG
#----------------------------------------------#
# Avant l'appel à l'écran de saisie des stocks #
#----------------------------------------------#
Local Shortint NOL : NOL=nolign-1
Return


Subprog B2_NBLIG
#----------------------------------------------------#
# Pour signaler au moteur qu'on a fait un clic droit #
#----------------------------------------------------#
GOUVENT=16384 : # =2^14
End


Subprog B4_NBLIG
#---------------------------------------------------------------------#
# Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0) #
#---------------------------------------------------------------------#
GOUVLOT=GOUVLOT-mod(GOUVLOT,2): # Ouvert.compl.lot par clic droit (1er bit de GOUVLOT à 0)
GOUVENT=1                     : # Permet de passer le test ouverture fenêtre complément lot
End


Subprog AVANT_NBLIG
#-------------#
# Avant NBLIG #
#-------------#
Local Shortint NOL : NOL=nolign-1
Local Decimal  NEWMAXQTY, NEWQTE
If [M:PSTT]ITMREF(NOL)=""  GMODIF=1 : Endif
#----- Suppression du texte ligne si la ligne est créée et supprimée -----#
If status=65 | status=68 | status=83
Elsif status=82 | status=73
  If dim([M:PSTT]ITMREF)=nolign
    GERR=1 : GMESSAGE=mess(7,184,1) : # Tableau des entrées plein
  Else
    Call STKACTLIG(NOL) From STKECR
    Actzo [M]ITMREF(NOL),ITMDES1(NOL)
    If dim([M]PCU)>0
      Actzo [M]PCU(NOL),QTYPCU(NOL)
    Elsif dim([M]UOM)>0
      Actzo [M]UOM(NOL),QTYUOM(NOL)
    Endif
    If dim([M]PCUSTUCOE)>0
      Actzo [M]PCUSTUCOE(NOL)
    Endif
    If dim([M]UOMSTUCOE)>0
      Actzo [M]UOMSTUCOE(NOL)
    Endif
    If dim([M]PRIORD)>0
      Actzo [M]PRIORD(NOL)
    Endif
    If dim([M]MVTDES)>0
      Actzo [M]MVTDES(NOL)
    Endif
  Endif
Endif
End


Subprog AS_NBLIG
#----------------------#
# Avant saisie         #
# Conditions de saisie #
#----------------------#
Local Shortint NOL : NOL=nolign-1
If nolign-1<0  End : Endif
If [F:ITM]ITMREF<>[M:PSTT]ITMREF(NOL)
  Read [ITM] ITM0=[M:PSTT]ITMREF(NOL)
  If fstat  Raz [F:ITM] : Endif
Endif
#----- Lecture aticle-site si nécessaire -----#
If [F:ITF]ITMREF<>[M:PSTT]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PSTT]STOFCY
  Read [ITF] ITF0=[M:PSTT]ITMREF(NOL);[M:PSTT]STOFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
End


Subprog C_NBLIG
#-------------------------------------------------#
# Il y a généralement des contrôles pour vérifier #
# qu'on peut annuler ou modifier une ligne        #
#-------------------------------------------------#
GMODIF=2
Local Shortint NOL
Local Decimal  NEWMAXQTY, NEWQTE
If    status=65             : # Annulation simple
      NOL=nolign-1 : Gosub TEST_ANU
Elsif status=68 | status=83 : # Annulation multiple
      For NOL=nolign-1 To nolign1-1
          Gosub TEST_ANU
          If mkstat : Break : Endif
      Next NOL
Endif
If status=75             NOL=nolign-1  : Gosub TEST_MOD    : Endif
If status=73 | status=82 NOL=nolign-1  : Gosub TEST_INSERT : Endif
If find(status,1,4,5,20,21,26,92,93) |
&      (status>128 & status<141)         Gosub TEST_VALID  : Endif
End


Subprog AM_NBLIG
#---------------------------------------------#
# A chaque fois que le nombre de ligne change #
#---------------------------------------------#
End

$TEST_INSERT
#---------------------------------#
# Test pour insertion d'une ligne #
#---------------------------------#
If [M:PSTT]ITMREF(NOL)="" GMODIF=1 : mkstat=2 : Endif
Return

$TEST_ANU
#----------------------------------#
# Test pour annulation de la ligne #
#----------------------------------#
#If [M:PSTT]NBLIG=1
#  GMESSAGE=mess(61,199,1) : GERR=1
#  mkstat=2
#Endif
Return

$TEST_MOD
#------------------------------------#
# Test pour modification d'une ligne #
#------------------------------------#
If [M:PSTT]ITMREF(NOL)="" GMODIF=1 : Endif
If [M:PSTT]QTYSTU(NOL)=0  GMODIF=1 : Endif

Return

$TEST_VALID
#-----------------------------------------------#
# Test et traitement à la validation des lignes #
#-----------------------------------------------#
Return

Subprog APRES_NBLIG
#-------------#
# Apres ligne #
#-------------#
Local Shortint NOL : NOL=nolign-1
Local Shortint I
Local Integer WRETOUR
Local Integer WSTATUS : WSTATUS=status
Local Char    NUMCDE(GLONPOH)
Local Integer NUMLIN
Local Integer NUMSEQ
#----- Si suppression, rien à vérifier
If (status=65 | status=68 | status=83 | status=6 ) : End : Endif
#-----
If [M:PSTT]ITMREF(NOL) ="" : End : Endif
If [F:ITM]ITMREF <> [M:PSTT]ITMREF(NOL)
  Read [ITM]ITM0 = [M:PSTT]ITMREF(NOL)
  If fstat : Raz [F:ITM] : Endif
Endif
#----- Lecture aticle-site si nécessaire -----#
If [F:ITF]ITMREF<>[M:PSTT]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PSTT]STOFCY
  Read [ITF] ITF0=[M:PSTT]ITMREF(NOL);[M:PSTT]STOFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
#- on remet le nolign, car pb dans appel_moteur_stock -#
nolign = NOL + 1
#---
If !GIMPORT
  Affzo [M:PSTT]ITMREF(NOL) : # pour remettre la couleur de l'article à jour
Endif
End

$AAPRES_NBLIG
#-------------------------------------------------#
# Appelé avant l'action SAISTOENT                 #
# Permet de vérifier s'il faut la lancer ou non   #
#-------------------------------------------------#
Local Shortint SRET     # Issue 96008 GA 10/2014 renammed because WRET must be an Integer (IMPPTHS)
Local Char     LSUP(1)
Local Shortint NOL : NOL=nolign-1
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[M:PSTT]ITMREF(NOL)
  Read [ITM] ITM0=[M:PSTT]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
Endif
#----- Lecture aticle-site si nécessaire -----#
If [F:ITF]ITMREF<>[M:PSTT]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PSTT]STOFCY
  Read [ITF] ITF0=[M:PSTT]ITMREF(NOL);[M:PSTT]STOFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
#-----
If [F:ITF]STOMGTCOD<2 : Raz GOUVENT :  Return : Endif
#Read [PWS]PWS0=adxuid(1);[M:PSTT]MFGNUM;[M:PSTT]OPENUM
#If !fstat
#  If [F:PWS]WSTOFLG=1
#    #LSUP="O"
#  Endif
#Endif
Call OUVENT([M:PSTT]STOFCY,"PSTT",5,[M:PSTT]TRSCOD,[M:PSTT]BPRNUM,15,
&           [M:PSTT]IPTDAT,NOL,[M:PSTT]NBLIG,"PTR",LSUP,SRET) From STKENT
If [M:PSTT]QTYSTU(NOL)=0 : [M:PSTT]WSTOFLG(NOL)=1 : Endif
Return

Subprog AV_ITMREF(VALEUR)
#---------------------------------------------------------------------#
# Avant zone                                                          #
# Affichage référence article en rouge si attente de saisie détaillée #
#---------------------------------------------------------------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
If WSTOFLG(NOL)=0 & [M:PSTT]CREFLG(NOL)=0
  pcolor=GCOUL(1) : # Rouge
Else
  pcolor=GCOUL(0) : # Noir
Endif
End

Subprog AS_ITMREF(VALEUR)
#----------------------#
# Avant saisie réf art #
#----------------------#
Variable Char     VALEUR
mkstat=2 : # Pour palier au pb de couleur
End


Subprog AS_UOM(VALEUR)
#------------------#
# Avant saisie UOM #
#------------------#
Variable Char  VALEUR()
Local Shortint NOL : NOL=nolign-1
If GMODIF = 1 : mkstat = 2 : End : Endif
If [M:PSTT]CREFLG (NOL) <> 0 : mkstat = 2 : Endif
End

Subprog AM_UOM(VALEUR)
#-----------------#
# Après modif UOM #
#-----------------#
Variable Char     VALEUR()
Local    Shortint NOL : NOL=nolign-1
Local    Integer  OK, K
Local    Char     WUOM(GLONUOM)
Local    Decimal  WCOEFF, OLDWCOEFF, NEWQTE, NEWMAXQTY
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[M:PSTT]ITMREF(NOL)
  Read [ITM] ITM0=[M:PSTT]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
Endif
#----- Lecture aticle-site si nécessaire -----#
If [F:ITF]ITMREF<>[M:PSTT]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PSTT]STOFCY
  Read [ITF] ITF0=[M:PSTT]ITMREF(NOL);[M:PSTT]STOFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
#-----
If [F:ITP]ITMREF <> [M:PSTT]ITMREF(NOL) | [F:ITP]BPSNUM <> [M:PSTT]BPRNUM
  Read [ITP]ITP0 = [M:PSTT]ITMREF(NOL);[M:PSTT]BPRNUM
  If fstat : Raz [F:ITP] : Endif
Endif
#---------------------------------------------------------------------#
# l'unité saisie fait-elle partie des unités autorisées en fonction   #
# de la transaction uniquement si article géré en stock               #
#---------------------------------------------------------------------#
If [F:PTR]PTRTYP<>6 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
  Read [PTR] PTR0=6;GPTRNUM : If fstat  Raz [F:PTR] : Endif
Endif
If [F:PTR]UOMSAIFLG=1 & [F:ITF]STOMGTCOD>1
  If (VALEUR<>[F:ITP]PUU & [F:ITP]PUU<>"") | VALEUR<>[F:ITM]PUU | VALEUR <> [F:ITM]STU
    mkstat=2 : End
  Endif
Endif
WUOM=VALEUR
WCOEFF=[M:PSTT]UOMSTUCOE(NOL)
OLDWCOEFF=[M:PSTT]UOMSTUCOE(NOL) : # il faut garder l'ancien coeff pour calcul du prix
Gosub DIS_COEFF                  : # From SUBPTHC
If mkstat : End : Endif
[M:PSTT]UOMSTUCOE(NOL)=WCOEFF
#-- Si le coeff est différent recalcul de la quantité en UC à partir de l'US
If WCOEFF<>OLDWCOEFF
  [M:PSTT]QTYUOM(NOL)=[M:PSTT]QTYSTU(NOL)/[M:PSTT]UOMSTUCOE(NOL)
  #-- Arrondi de la quantité en UA pour être au plus juste
  Call QTEARR([M:PSTT]QTYUOM(NOL),WUOM) From TRTDIV
Endif
Affzo [M:PSTT]QTYUOM(NOL), QTYSTU(NOL), UOMSTUCOE(NOL)
nolign=NOL+1
End

Subprog AS_QTYUOM(VALEUR)
#----------------------#
# Avant saisie qté uom #
#----------------------#
Variable Decimal VALEUR
Local    Shortint NOL     : NOL=nolign-1
End

Subprog C_QTYUOM(VALEUR)
#--------------#
# Controle qty #
#--------------#
Variable Decimal  VALEUR
# Suppression de l'option + dans le masque
# Qui n'est pas traitée en import
If VALEUR <= 0 :   GMODIF=1 : End : Endif
End

Subprog AM_QTYUOM(VALEUR)
#-----------------#
# Après modif qty #
#-----------------#
Variable Decimal VALEUR
Local Shortint NOL  : NOL=nolign-1
Local    Integer  OK, WSTAT
Local    Decimal  NEWQTE, NEWCOEFF, NEWMAXQTY
NEWQTE  = VALEUR
If [M:PSTT]QTYSTU(NOL)=0 & NEWQTE<>0
  If [F:ITM]ITMREF<>[M:PSTT]ITMREF(NOL)
    Read [ITM]ITM0=[M:PSTT]ITMREF(NOL)
  Endif
  If [F:PTR]PTRTYP<>6 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
    Read [PTR] PTR0=6;GPTRNUM : If fstat  Raz [F:PTR] : Endif
  Endif
  [M:PSTT]TRSFAM(NOL)=[F:PTR]TRSFAMDEF
  [M:PSTT]MVTDES(NOL)=mess(48,190,1)
  Call STKINISTA([M:PSTT]STA(NOL),[M:PSTT]BPRNUM,[M:PSTT]QUAFLG(NOL)) From STKACT
Endif
If NEWQTE<>0
  NEWCOEFF=[M:PSTT]UOMSTUCOE(NOL)
  #-- Calcul de la quantité max avec contrôle
  Gosub CALCTL_QTYUS
  If mkstat : End : Endif
Else
  [M:PSTT]QTYSTU(NOL)=0
  Raz [M:PSTT]STA(NOL), MVTDES(NOL), TRSFAM(NOL), PJT(NOL)
  If dim([M:PSTT]LOCTYP)>0
      Raz [M:PSTT]LOCTYP(NOL), LOC(NOL)
  Endif
  If dim([M:PSTT]LOT)>0
      Raz [M:PSTT]BPSLOT(NOL), LOT(NOL)
  Endif
  If dim([M:PSTT]NBSLO)>0
      Raz [M:PSTT]NBSLO(NOL), SLO(NOL), SLOF(NOL)
  Endif
  If dim([M:PSTT]SERNUM)>0
      Raz [M:PSTT]SERNUM(NOL), SERNUMF(NOL)
  Endif
Endif
#--- Attention acceptation de la valeur ---#
#--- Les blocages sont effectués avant  ---#
[M:PSTT]QTYUOM(NOL)=VALEUR
If !GIMPORT  Affzo [M:PSTT]QTYSTU(NOL) : Endif
End

$CALCTL_QTYUS
#-----------------------------#
# Calcul des quantités en US  #
# Contrôle des quantités      #
#-----------------------------#
If [M:PSTT]STU (NOL) <> [M:PSTT]UOM (NOL)
  NEWQTE = NEWQTE * NEWCOEFF
Else
  NEWCOEFF = 1
Endif
# Issue 96008 GA 10/2014 no question if GIMPORT
# sr 11.02 demande 16415
# Contrôle pour les déclarations de production si qté supérieure
If NEWQTE<>0 & NEWQTE>[M:PSTT]MAXQTYRCP(NOL) & !GIMPORT
  OK=2 : Call AVERTIR(mess(54,190,1),OK) From GESECRAN
  If OK=1
     mkstat=2
    Return
  Endif
Endif
#-- Si contrôle OK acception de la quantité
#-- Positionnement maxqte
#-- Positionnement du solde
If !mkstat
  [M:PSTT]QTYSTU(NOL)   = NEWQTE
  [M:PSTT]UOMSTUCOE(NOL)= NEWCOEFF
Endif
Return

Subprog AS_UOMSTUCOE(VALEUR)
Variable Decimal  VALEUR        # FGR 19/01/2010 : X3SUIVI60986

#------------------------#
# Avant saisie UOMSTUCOE #
#------------------------#
Local Shortint NOL  : NOL=nolign-1
If [M:PSTT]CREFLG(NOL)<>0
  If [F:ITM]SCSFLG=2
    mkstat=2
  Elsif [F:ITF]STOMGTCOD>1
    mkstat=2
  Endif
Endif
End

Subprog AM_UOMSTUCOE(VALEUR)
#-------------------#
# Après modif coeff #
#-------------------#
Variable Decimal  VALEUR
Local Shortint NOL  : NOL=nolign-1
Local    Integer  OK, WSTAT
Local    Decimal  NEWQTE, NEWCOEFF, NEWMAXQTY
NEWQTE  =[M:PSTT]QTYUOM(NOL)
NEWCOEFF= VALEUR
Gosub CALCTL_QTYUS
If mkstat : End : Endif
Affzo [M:PSTT]QTYSTU(NOL)
End

Subprog AS_LOT(VALEUR)
#-------------------#
# Avant saisie lot  #
#-------------------#
Variable Char    VALEUR()
mkstat = 0
#---------------------------------------------------------------------------------#
#Si lot retenu à la création de l'OF, alors pas de saisie                         #
#---------------------------------------------------------------------------------#
Read [F:MFI]MFI0 = [M:PSTT]MFGNUM;[M:PSTT]MFGLIN(nolign-1)
If fstat : Raz [F:MFI] : Endif
If VALEUR <> "" & VALEUR = [F:MFI]LOT : mkstat = 2 : End : Endif
End

Subprog AM_SLO(VALEUR)
#-------------------------------------------#
# Contrôle sous-lot et positionnement SLOTF #
#-------------------------------------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
If VALEUR<>""
  Call STKCTRSLO(VALEUR, [M:PSTT]NBSLO(NOL), [M:PSTT]LOT(NOL),
&               [M:PSTT]ITMREF(NOL),[M:PSTT]BPSLOT(NOL),[M:PSTT]GESLOT(NOL),"", 0, 0, 0,
&               [M:PSTT]STOFCY, [M:PSTT]SLOF(NOL)) From STKACT
  Affzo [M:PSTT]SLOF(NOL)
Endif
End

Subprog AM_NBSLO(VALEUR)
#--------------------------#
# Après modif nbr sous-lot #
#--------------------------#
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
Call STKCTRNBSLO(VALEUR, [M:PSTT]UOM(NOL), [M:PSTT]QTYUOM(NOL)) From STKACT
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:PSTT]WRH(nolign-1)<>""
   Raz [M:PSTT]LOC(nolign-1)
Endif
End

Subprog C_LOCTYP(VALEUR)
#---------------------------#
# Controle type emplacement #
#---------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
  Read [TLO]TLO0=[M:PSTT]STOFCY;VALEUR
  If fstat mkstat = 2  : End : Endif
# test si type quai autorisé
  If [M:PSTT]SRGWAIFLG <> 2 & [F:TLO]LOCCAT = 2
    GMESSAGE = mess(854,196,1) : mkstat = 2 : End
  Endif
Endif
#--- Bug 72649
If [M:PSTT]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:PSTT]LOC(nolign-1),[M:PSTT]WLOCSEQ(nolign-1)) From STKACT
Endif
End


Subprog AS_TRSFAM(VALEUR)
#--------------------------------#
# Avant saisie famille mouvement #
#--------------------------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
If [F:ITF]STOMGTCOD<2 : mkstat=2 : End : Endif
If [M:PSTT]CREFLG(NOL)<>0 & [F:ITF]STOMGTCOD>1 : mkstat=2 : End : Endif
End


$AB1_LOC
#--------------#
# avant tunnel #
#--------------#
GLOCSEL = "LOCTYP='"+[M:PSTT]LOCTYP(nolign-1)+"'"
Return

$BB1_LOC
#--------------#
# apres tunnel #
#--------------#
Raz GLOCSEL
Return

Subprog PASLINPTH(DISCRGNUM)
#--------------------------------------#
# Avant saisie des remises/frais tarif #
#--------------------------------------#
Value Integer DISCRGNUM
Local    Shortint NOL     : NOL=nolign-1
If DISCRGNUM<1 | DISCRGNUM>9 End : Endif
If GMODIF<>2 | GCOLREM(DISCRGNUM-1)=""
&            | ([M:PSTT]CREFLG(NOL)<>0 & [F:ITF]STOMGTCOD>1) mkstat=2 : Endif
End


$DIS_COEFF
#---------------------------------------------------------------#
# Alimentation du coeff dans WCOEFF et positionnement flag saisi#
# WUOM doit contenir l'unité                                    #
#---------------------------------------------------------------#
If dim(NOL)<0 Local Shortint NOL : Endif
NOL=nolign-1
Local Char LUSCAV(2)
Local Char LLBEFMT(GLONARP)
Local Integer LDACCOE
Call CTLUOM([M:PSTT]ITMREF(NOL),1,[M:PTH0]BPSNUM, [L]WUOM, [L]WCOEFF,
&           LUSCAV, LLBEFMT, LDACCOE) From STKACT
If mkstat : Return : Endif
If LDACCOE=1
  Affzo [PTH1]UOMSTUCOE(NOL) : # pb diszo
  Diszo [PSTT]UOMSTUCOE(NOL)
  Affzo [PTH1]UOMSTUCOE(NOL) : # pb diszo
  [M:PTH1]WSTOSAI(NOL)=left$([M:PSTT]WSTOSAI(NOL),2)+"2"+right$([M:PSTT]WSTOSAI(NOL),4)
Else
  Affzo [PTH1]UOMSTUCOE(NOL) : # pb diszo
  Actzo [PSTT]UOMSTUCOE(NOL)
  Affzo [PTH1]UOMSTUCOE(NOL) : # pb diszo
  [M:PSTT]WSTOSAI(NOL)=left$([M:PSTT]WSTOSAI(NOL),2)+"0"+right$([M:PSTT]WSTOSAI(NOL),4)
Endif
Return



$MAJ_QTERCP
# GA 08/2014 Suite Issue 101375
# Ouverture des tables si nécessaire
Gosub OPEN_FILES_MFG From MFGLIB

#-------------------------------------------------------#
# Calcul de la qté réceptionné de la ligne de réception #
#-------------------------------------------------------#
# Issue 96008 ???? Raz RCPQTYSTU, RCPRQTYSTU
Raz [M:PSTT]RCPQTYSTU, [M:PSTT]RCPRQTYSTU
#-- Mise à jour des info pour ligne RCPQTYSTU de réception
#Read [F:OPS]OPS2= [M:PTH1]POHNUM([M:PSTT]ORINOL);[M:PTH1]POPLIN([M:PSTT]ORINOL);1
#If fstat
#   Raz [F:OPS]
#   # FQ 68578 GA 10/2010 pb si on ne retrouve pas la ligne [F:OPS] (idem FQ 68123 dans SUBPTHC)
#   Read [F:MFO]MFO1=[M:PTH1]POHNUM([M:PSTT]ORINOL);[M:PTH1]POPLIN([M:PSTT]ORINOL);1
#   If !fstat
#     [F:OPS] = [F:MFO]
#   Endif
#Endif
# GH 19/04/2016 bug 115880 [F:MFO] was empty
Read [F:MFO]MFO1=[M:PTH1]POHNUM([M:PSTT]ORINOL);[M:PTH1]POPLIN([M:PSTT]ORINOL);1
If fstat : Raz [F:MFO] : Endif

# FQ 74274 GA 10/2011
If dim(WOPESTUCOE)<0  Local Decimal    WOPESTUCOE       : Endif
If [F:MFO]OPESTUCOE=0 [L]WOPESTUCOE=1
Else [L]WOPESTUCOE=[F:MFO]OPESTUCOE
Endif

For I=0 To [M:PSTT]NBLIG-1
  #----- Il faut réajuster la quantité (sauf si sous-produit)
  # FQ 69508 GA 04/2011 cas des sous-produits, ne pas augmenter la qté de service
  If dim([M:PSTT]ITMTYP(I))<=0 | [M:PSTT]ITMTYP(I)<> 2
    Raz GBIDD1, GBIDD2, GBIDD3
    # FQ 74274 GA 10/2011 OPESTUCOE conversion de l'US article lancé à l'US article sous-traitance
    # llc 04.02, si UA = UO, on convertit par rapport au coeff de l'opération
    #If [F:OPS]OPEUOM = [M:PTH1]PUU([M:PSTT]ORINOL) & [F:OPS]OPESTUCOE > 0
    If [L]WOPESTUCOE<>1
      GBIDD2 = [M:PSTT]QTYSTU(I) * [L]WOPESTUCOE
      Call QTEARR(GBIDD2,[M:PTH1]PUU([M:PSTT]ORINOL)) From TRTDIV
      # GBIDD2 contient la quantité de lig de réception en UA
      #-- Conversion en US de la ligne de réception
      Call PCAL_QTY(GBIDD2,[M:PTH1]PUU([M:PSTT]ORINOL),GBIDD3,[M:PSTT]RCPSTU,
&                   [M:PTH1]ITMREF([M:PSTT]ORINOL),"",0,GBIDD1) From TRTACHQTE1
      [M:PSTT]RCPQTYSTU+= GBIDD3
      Raz GBIDD1, GBIDD2, GBIDD3
      GBIDD2 = [M:PSTT]RRRQTYSTU(I) * [L]WOPESTUCOE
      Call QTEARR(GBIDD2,[M:PTH1]PUU([M:PSTT]ORINOL)) From TRTDIV
      # GBIDD2 contient la quantité en R de lig de réception en UA
      #-- Conversion en US de la ligne de réception
      Call PCAL_QTY(GBIDD2,[M:PTH1]PUU([M:PSTT]ORINOL),GBIDD3,[M:PSTT]RCPSTU,
&                   [M:PTH1]ITMREF([M:PSTT]ORINOL),"",0,GBIDD1) From TRTACHQTE1
      [M:PSTT]RCPRQTYSTU+= GBIDD3
    Else
      Raz GBIDD1, GBIDD2, GBIDD3
      #-- Calcul en unité de stock de la réception de l'ordre de fabrication
      If [F:ITM]ITMREF<>[M:PTH1]ITMREF([M:PSTT]ORINOL)
        Read [ITM]ITM0=[M:PTH1]ITMREF([M:PSTT]ORINOL)
        If fstat : Raz [F:ITM] : Endif
      Endif
  # MBT 14/01/2009 correction SUBPTHC avant  [M:PSTT]ITMREF(NOL),"",0,GBIDD1) From TRTACHQTE1
      Call PCAL_QTY([M:PSTT]QTYSTU(I),[F:MFG]STU,GBIDD2,[F:ITM]STU,
&                   [F:ITM]ITMREF,"",0,GBIDD1) From TRTACHQTE1
      [M:PSTT]RCPQTYSTU+=GBIDD2
      Raz GBIDD2
  # MBT 14/01/2009 correction SUBPTHC avant  [M:PSTT]ITMREF(NOL),"",0,GBIDD1) From TRTACHQTE1
      Call PCAL_QTY([M:PSTT]RRRQTYSTU(I),[F:MFG]STU,GBIDD2,[F:ITM]STU,
&                   [F:ITM]ITMREF,"",0,GBIDD1) From TRTACHQTE1
      [M:PSTT]RCPRQTYSTU+=GBIDD2
    Endif
  Endif
Next I
Return

$MAJ_LIG_STT
#--------------------------------------------------------#
# Mise à jour de la ligne de réception de sous-traitance #
#--------------------------------------------------------#
If dim(SVGNOL) <0  Local Integer    SVGNOL        : Endif
If dim(LLIGDOC)<0  Local Integer    LLIGDOC       : Endif
If dim(LQTYSTU)<0  Local Decimal    LQTYSTU       : Endif
If dim(NEWQTY)<0   Local Decimal    NEWQTY        : Endif
If dim(LABR)<0     Local Char       LABR(4)       : Endif
If dim(LPCU)<0     Local Char       LPCU(GLONUOM) : Endif
If dim(LCOEF)<0    Local Decimal    LCOEF         : Endif
If dim(NOL)<0      Local Shortint   NOL           : Endif
If dim(SENS)<0     Local Shortint   SENS          : Endif
SVGNOL=nolign

# Issue 96008 GA 10/2014 LABR mandatory for IMPPTHS/STKIMPE
Local Char       SVGABR(4) : SVGABR=[L]LABR

LABR   ="PTH1"
LLIGDOC=[M:PSTT]ORINOL
LQTYSTU=[M:PSTT]RCPQTYSTU
LCOEF  =[M:PTH1]UOMSTUCOE(LLIGDOC)
LPCU   =[M:PTH1]UOM(LLIGDOC)
Gosub CTL_LIG_PTH From SUBPTHB
If mkstat : [M:PTH1]WSTOFLG(LLIGDOC)=0 : Return : Endif
NOL=LLIGDOC
SENS=-1 : Gosub MAJ_TOTWEI From SUBPTH : # Soustraction total poids brut et net
Gosub MAJ_LIG_PTH From SUBPTHB
SENS=+1 : Gosub MAJ_TOTWEI From SUBPTH : # Addition total poids brut et net
If [M:PSTT]RCPRQTYSTU<>0
  [M:PTH1]RRRQTYSTU(LLIGDOC)=[M:PSTT]RCPRQTYSTU
  Call AM_RRRQTYSTU([M:PTH1]RRRQTYSTU(LLIGDOC)) From SUBPTH
  Affzo [PTH1]RRRQTYSTU(LLIGDOC)
Else
  Raz [M:PTH1]RRRQTYPUU(LLIGDOC), [M:PTH1]RRRQTYSTU(LLIGDOC)
Endif
[M:PTH1]WSTOFLG(LLIGDOC)=2
nolign=SVGNOL
# Issue 96008 GA 10/2014 LABR mandatory for IMPPTHS/STKIMPE
[L]LABR=SVGABR
Return

