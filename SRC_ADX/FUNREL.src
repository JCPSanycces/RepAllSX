#<AdxTL>@(#)246.0.0.0 $Revision$
######################################################################## 
# FUNREL           ENREGISTREMENT DES RELANCES        SR Décembre 1997 #
#                       AUX APPELS D'OFFRE            HN Janvier  2001 #
# -------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)               #
#   - TRTFUNREL : Fonction de relances aux appels d'offres             #
# -------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GACTION)               #
#   - SELPQF    : Sélection appel d'offre pour relance                 #
# -------------------------------------------------------------------- #
# SOUS-PROGRAMMES                                                      #
#   - LIRE      : Chargement des lignes de réponses à relancer         #
#   - ECRIRE    : Ecriture du flag de relance                          #
########################################################################

$ACTION
#-------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)          #
# ----------------------------------------------------- #
# TRTFUNREL  : Fonction de relances aux appels d'offres #
#-------------------------------------------------------#
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub TERMINE
 When "AB1_NBREL"  : Gosub AB1_NBREL
 When "BB1_NBREL"  : Gosub BB1_NBREL
#-------------------------------------------------------#
# Actions sur la sélection dans une table (GACTION)     #
# ----------------------------------------------------- #
# SELPQF     : Sélection appel d'offre pour relance     #
#-------------------------------------------------------#
 When "SEL_TABLE"
   Case TABLE
     When "SELPQF" : Gosub S_PQF
   Endcase
 When "VERF_TABLE"
   Case TABLE
     When "SELPQF" : Gosub V_PQF
   Endcase
Endcase
Return


#######################################################################
#    Détail des actions liées au traitement standard                  #
#######################################################################

#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
#---------------------------------#
# ouverture des fichiers et ecran #
#---------------------------------#
Local Integer OK 
Local Char SYMBOLE2(30)    
 
If clalev ([F:PQH]) <= 0 : Local File PQUOTAT  [PQH] : Endif
If clalev ([F:PQF]) <= 0 : Local File PQUOTATF [PQF] : Endif
If clalev([F:PPH])  <= 0 : Local File PRESP    [PPH] : Endif
If clalev([F:PQD])  <= 0 : Local File PQUOTATD [PQD] : Endif

Return

#############################################################
# Après déclaration de l'écran mais avant ouverture fenêtre #
#############################################################
$INIT_DIA
Raz [M:DIA]
[M:DIA]DAT = date$
If GHISTO  GCONSDIA=2 : Endif
Return

###########################
# Exécution du traitement #
###########################
$EXEC
#Lock logique de l'entête d'appel d'offre   
If [M:DIA]NBREL <> 0    
  SYMBOLE2 = "PQH"+num$([F:PQF]PQHNUM)    
  Lock = SYMBOLE2 With lockwait = 0    
  If fstat : GERR  = 1 : GMESSAGE =mess(10,100,1)
             OK = 0 : FIN = 1
  Endif 
Endif
Gosub ECRIRE
SYMBOLE2 = "PQH"+num$([F:PQF]PQHNUM)
           Unlock = SYMBOLE2
Return

#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
Return


########################################################################
# S_PQF : Sélection appel d'offre pour relance       action e-commerce #
#                                                          HN 15/10/00 #
########################################################################
# Si on a plusieurs fichiers toujours préciser la classe               #
########################################################################
$S_PQF
If clalev([F:ATZ])=0  Local File ATABZON    [ATZ] : Endif
CRITERE(1)="[F:PQH]RSPNBR<([F:PQH]BPSNBR*[F:PQH]LINNBR)" : # MBT 29/06/2001
START  = '[F:PQH]PQHNUM' : CRITOBJ="[F:PQH]PQHNUM>=[L]VALEUR"
TIT(0) = mess(194,195,1)
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "[PQH]PQHDAT"    
Call TEXTFIC("PQUOTAT","PQHDAT",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[PQH]PQHNUM" 
Call TEXTFIC("PQUOTAT","PQHNUM",1,TIT(NBCOL)) From OBJDIV  
NBCOL += 1 : COL(NBCOL) = "[PQH]PQHFCY" 
Call TEXTFIC("PQUOTAT","PQHFCY",1,TIT(NBCOL)) From OBJDIV  
NBCOL += 1 : COL(NBCOL) = "[PQH]PQHREF" 
Call TEXTFIC("PQUOTAT","PQHREF",1,TIT(NBCOL)) From OBJDIV  
Default File [PQH]
Return

#----------------------------------------------------------------------#
$V_PQF
Read [PQH] PQH0=[F:PQH]PQHNUM : If fstat Raz [F:PQH] : Endif
#--- Si pas habilité sur tous sites  on verifie
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  If !find([F:PQH]PQHFCY,GUSRFCY(1..GNBAUZ))
    GMESSAGE=[F:PQH]PQHFCY-mess(2,104,1) : Return   : # Vous n'avez pas les droits sur ce site
  Endif
Endif
VALEUR =[F:PQH]PQHNUM
Return


##########################################################
# SOUS-PROGRAMMES                                        #
##########################################################
#                                                        #
# LIRE : Chargement des lignes de réponses à relancer    #
##########################################################
$LIRE
nolign=0 
OK=1
For [PQF] PQF0 Where PQHNUM=[M:DIA]PQHNUM
  nolign += 1
  [M:DIA]=[F:PQF]
  If [F:PQF]RSPNBR=0
    [M:DIA]PRO(nolign-1)=2
  Else
    [M:DIA]PRO(nolign-1)=1
  Endif 
Next
[M:DIA]NBREL=nolign
Affzo [DIA]1-99
Return


##########################################################
#                                                        #
# ECRIRE : Ecriture du flag de relances                  #
##########################################################
$ECRIRE
GOK = 1
Trbegin [PQF]

For nolign = 1 To [M:DIA]NBREL
 NOL = nolign-1
 Readlock [PQF] PQF0 = [M:DIA]PQHNUM;[M:DIA]BPSNUM(NOL)
 If fstat = 1 
   GOK = -1 : GLOCK = "$PQUOTATF" : Break 
 Elsif fstat 
   GOK = 0 : Call RSTA("PQF","*") From GLOCK : Break 
 Endif 
 [F:PQF] = [M:DIA]
 If [M:DIA]PRO(NOL) = 2    :# Relance
    [F:PQF]FUPNBR += 1
    [F:PQF]FUPDAT = [M:DIA]DAT
 Endif
 Rewrite
 If fstat
    GOK = 0 : Call FSTA("PQF") From GLOCK : Break 
 Endif
Next

If    GOK < 0 : Goto TR_ROLL
Elsif GOK = 0 : Goto AB_CREAT
Endif

Commit


$FIN_CREAT
Return
                                                    
$TR_ROLL
ROLLBACK
Call ROLL From GLOCK
Goto FIN_CREAT

$AB_CREAT
ROLLBACK
Goto FIN_CREAT
 

$IMPRIME
Return

######################################## ACTIONS SUR CHAMPS ###################################

Subprog AM_PQHNUM(VALEUR)
#----------------------------#
# Controle numéro de demande #
#----------------------------#
Variable Char    VALEUR()
If [F:PQH]PQHNUM <> VALEUR
  Read [PQH] PQH0=VALEUR : If fstat Raz [F:PQH] : Endif
Endif
[M:DIA]PQHFCY = [F:PQH]PQHFCY
[M:DIA]PQHREF = [F:PQH]PQHREF
[M:DIA]PQHDAT = [F:PQH]PQHDAT
[M:DIA]RSPDEA = [F:PQH]RSPDEA
[M:DIA]REQUSR = [F:PQH]REQUSR
#--- Si pas habilité sur tous sites  on verifie
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  If !find([F:PQH]PQHFCY,GUSRFCY(1..GNBAUZ))
   GMESSAGE=[F:PQH]PQHFCY-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
   Effzo [M:DIA]1-99
   mkstat=2 : End
  Endif
Endif
[M:DIA]PQHNUM=VALEUR
Gosub LIRE
If OK = 0 : mkstat = 1 : End : Endif 
If [M:DIA]NBREL = 0
   GERR = 2 : GMESSAGE = mess(99,100,1)
   mkstat = 1  
Endif 
End

Subprog IB_NBREL                    
#-------------------------#
# IB Fenêtre des réponses #
#-------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
If [M:DIA]RSPNBR(nolign-1)<>0 : GBOUT1=mess(445,198,1) : Endif
GBOUT2=mess(35,198,1)-[M:DIA]PQHNUM
End

$AB1_NBREL
#----------------------------------#
# Avant exécution du bouton Tunnel #
#----------------------------------#
Local Char WSCLE2(20)(0..1)
Local Integer WNOL  : WNOL=nolign-1
Filter [PPH] Where [F:PPH]PQHFCY=[M:DIA]PQHFCY & [F:PPH]PQHNUM = [M:DIA]PQHNUM &
&                  [F:PPH]BPSNUM=[M:DIA]BPSNUM(WNOL)
Read [PPH] First
Filter [PPH]
If fstat Raz [F:PPH] : Return : Endif
GFLTBPS   = [M:DIA]BPSNUM(WNOL)
GFLTPQH   = [M:DIA]PQHNUM
WSCLE2(0) = GFLTBPS
WSCLE2(1) = num$([F:PPH]PQDLIN)
Return

$BB1_NBREL
#----------------------------------#
# Apres exécution du bouton Tunnel #
#----------------------------------#
nolign=WNOL+1
Raz GFLTBPS, GFLTPQH
Return
