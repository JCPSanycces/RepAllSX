#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GTUNCPT
Local Char PARAM(10)(1..4)
Call GCONSULT("PCE","",PARAM) From GCONSULT
End

Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"PCE") From SUBGTC
End

$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT # JFL
 When "AUTORIS"    : Gosub AUTORIS
 When "FERME"      : Gosub FERME
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "FIN_CRIT"   : Gosub FIN_CRIT
 When "EXEBOUT2"   : Gosub EXEBOUT2
 When "AB1_NBLIG"  : Gosub AB1_NBLIG
 When "AB2_NBLIG"  : Gosub AB2_NBLIG
 When "BB1_NBLIG"  : Gosub BB_NBLIG
 When "BB2_NBLIG"  : Gosub BB_NBLIG
 When "TRT_DIV"    : Gosub TRT_DIV From CONSSUB
 When "AV_AFFICHE" : Gosub AV_AFFICHE
Endcase
Return

$SETBOUT
# activation du zoom
CHMEN+="12"
Return

$AUTORIS
Local Libelle OTUNCPT : OTUNCPT=GTUNCPT(4)
If GTUNCPT(4)
 Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
 # Une même fonction ne peut pas être appelée deux fois !
Else
 GTUNCPT(4) = 1
Endif
Return

$FERME
If dim(OTUNCPT)>0 : GTUNCPT(4) = OTUNCPT : Endif
Return

$OUVRE
Local Integer I, J, OK, AX, ISITE
Local Decimal EXERCICE, PERIODE
Local Integer NBSITE, NBSOC
# GH 02/02/00 bug 4189
NBSITE = max(1,GNBSITE)
Local Char    DEVSOC(GLONCUR),DEVLED(GLONCUR)
Local Char    TSITE(GLONFCY)(1..NBSITE), TDEVSOC(GLONCUR)(1..NBSITE), TDEVLED(GLONCUR)(1..NBSITE)
NBSITE = 0
Local Date    DDEB, DFIN
Local Char    FILLIG(250) , FILTET(250)
Local Char    DEBCPY(GLONCPY) , FINCPY(GLONCPY)
Local Char    DEBFCY(GLONFCY) , FINFCY(GLONFCY)
Local Char    DEBACC(GLONGAC) , FINACC(GLONGAC)
Local Char    DEBBPR(GLONBPR) , FINBPR(GLONBPR)
Local Date    DEBDAT , FINDAT
Local Integer DEBNUM, FINNUM
Local Libelle GRP

Local Mask VENTILE  [VTL]
Local Mask VENTILE2 [VT2]

Gosub DEFCRIT

# Bug 9630 : Préchargement (CP : 12/07/01)
CHARGMT=1
Return

$DEFCRIT
# Paramètres
# Il faut faire attention à ce que les paramètres restent cohérents entre eux
If [M:PCE1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:PCE1]FCY,GUSRFCY(1..GNBAUZ))
 [M:PCE1]FCY=""
Endif
DDEB=[M:PCE1]DATDEB
DFIN=[M:PCE1]DATFIN

For I=1 To dim(PARAM)
 Case I
  When 1 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:PCE1]FCY = PARAM(I)
     [M:PCE1]CPY = [F:FCY]LEGCPY
     PARAM(2)=""
    Endif
   Endif
  When 2 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:PCE1]CPY = PARAM(I)
     If [M:PCE1]FCY<>""
      Call LECTURE("FCY",[M:PCE1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:PCE1]CPY : [M:PCE1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 3 : # Type de référentiel
   If clalev([GCM])=0 : Local File GACM [GCM] : Endif
   If clalev([LED])=0 : Local File GLED [LED] : Endif
   If val(PARAM(I))<>0
    If [M:PCE1]CPY<>""
     Call LECTURE("CPY",[M:PCE1]CPY,"") From CONTOBJ
     Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
     If [F:GCM]LED(val(PARAM(I))-1)<>""
      Call LECTURE ("LED",[F:GCM]LED(val(PARAM(I))-1),"") From CONTOBJ
      [M:PCE1]LEDTYP = val(PARAM(I))
      [M:PCE1]COA    = [F:LED]COA
     Endif
    Endif
   Endif
  When 4 : # Date début
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:PCE1]DATDEB = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:PCE1]DATDEB = PARAM(I)
    Endif
   Endif
  When 5 : # Date fin
   If instr(1,PARAM(I),"/")
    [M:PCE1]DATFIN = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:PCE1]DATFIN = PARAM(I)
   Endif
  When 6 : Break
 Endcase
Next I

# Valeurs par défaut
Default Mask [PCE1]
Call INIT(DDEB,DFIN) From CONSSUB

Gosub CRITENT From =PROGCNS
Return

$LECTURE
If [M:PCE1]CPY="" or [M:PCE1]DATDEB=[0/0/0] or [M:PCE1]DATFIN=[0/0/0]
 NBLU=0 : Return
Endif

Gosub INIT

Gosub FILTRE

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

If CHGPAG>0
 If [M:CPCE]FILTECT(1)<>""
  Filter [DAE] Where evalue(FILLIG) & evalue([M:CPCE]FILTECT(1))
& Order By Key CLE = CPY;FCYLIN;ACC;BPR;ACCDAT;ACCNUM
 Else
  Filter [DAE] Where evalue(FILLIG)
& Order By Key CLE = CPY;FCYLIN;ACC;BPR;ACCDAT;ACCNUM
 Endif
Else
 If [M:CPCE]FILTECT(1)<>""
  Filter [DAE] Where evalue(FILLIG) & evalue([M:CPCE]FILTECT(1))
& Order By Key CLE = CPY Desc;FCYLIN Desc ;ACC Desc;BPR Desc;ACCDAT Desc;ACCNUM Desc
 Else
  Filter [DAE] Where evalue(FILLIG)
& Order By Key CLE = CPY Desc;FCYLIN Desc ;ACC Desc;BPR Desc;ACCDAT Desc;ACCNUM Desc
 Endif
Endif

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
If CHGPAG<>2 & CHGPAG<>-2
 Raz [M:PCE2]
Endif

If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub SET_FIRST From TRTFIRST
Endif

Case CHGPAG
 When 3
  For [DAE]CLE From DEBCPY;DEBFCY;DEBACC;DEBBPR;DEBDAT;DEBNUM
   Gosub LIRE
   If BR : Break : Endif
  Next
 When 2
  For [DAE]CLE From FINCPY;FINFCY;FINACC;FINBPR;FINDAT;FINNUM+1
   Gosub LIRE
   If BR : Break : Endif
  Next
 When -2
  For [DAE]CLE From DEBCPY;DEBFCY;DEBACC;DEBBPR;DEBDAT;DEBNUM-1 : #To "";"";"";"";[0/0/0];0
   Gosub LIRE
   If BR : Break : Endif
  Next
 When Default
  For [DAE]CLE
   Gosub LIRE
   If BR : Break : Endif
  Next
Endcase
Filter [DAE]

If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub UNSET_FIRST From TRTFIRST
Endif

Return

$LIRE
BR = 0
If GRP
 ISITE = find([F:DAE]FCYLIN,TSITE(1..NBSITE))
 DEVSOC = TDEVSOC(ISITE)
 DEVLED = TDEVLED(ISITE)
Endif
OK = 1
If [M:CPCE]FILTECT(1)<>""
 OK *= evalue([M:CPCE]FILTECT(1))
Endif
If OK & [M:CPCE]FILTECT(2)<>""
 Read [DAA]DAA0 = [F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN;[F:DAE]LEDTYP;1
 If !fstat
  OK *= evalue([M:CPCE]FILTECT(2))
 Else
  OK = 0
 Endif
Endif
If OK
 Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
 If FILTET<>""
  OK *= evalue(FILTET)
 Endif
 If [M:CPCE]FILTECT(0)<>""
  OK *= evalue([M:CPCE]FILTECT(0))
 Endif
Endif
If OK
 If NBLU=1
  If CHGPAG=2 or CHGPAG=-2
   Raz [M:PCE2]
  Endif
  NBLU=2
 Endif
 If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE = 2 : BR = 1 : Return : Endif
  NOL += 1
  If NOL=0
   DEBCPY = [F:DAE]CPY
   DEBFCY = [F:DAE]FCYLIN
   DEBACC = [F:DAE]ACC
   DEBBPR = [F:DAE]BPR
   DEBDAT = [F:DAE]ACCDAT
   DEBNUM = [F:DAE]ACCNUM
  Endif
  FINCPY = [F:DAE]CPY
  FINFCY = [F:DAE]FCYLIN
  FINACC = [F:DAE]ACC
  FINBPR = [F:DAE]BPR
  FINDAT = [F:DAE]ACCDAT
  FINNUM = [F:DAE]ACCNUM
 Else
  If NOL<=0 : RETOUR = 2 : BR = 1 : Return : Endif
  NOL -= 1
  If NOL=MAXLIG-1
   FINCPY = [F:DAE]CPY
   FINFCY = [F:DAE]FCYLIN
   FINACC = [F:DAE]ACC
   FINBPR = [F:DAE]BPR
   FINDAT = [F:DAE]ACCDAT
   FINNUM = [F:DAE]ACCNUM
  Endif
  DEBCPY = [F:DAE]CPY
  DEBFCY = [F:DAE]FCYLIN
  DEBACC = [F:DAE]ACC
  DEBBPR = [F:DAE]BPR
  DEBDAT = [F:DAE]ACCDAT
  DEBNUM = [F:DAE]ACCNUM
 Endif
 nolign = NOL+1
 [M:PCE2] = [F:HAE]
 [M:PCE2] = [F:DAE]
 [M:PCE2]FNLPSTNUMW(NOL)=[F:HAE]FNLPSTNUM([F:DAE]LEDTYP-1)
 [M:PCE2]MLTRAT(NOL) = [F:HAE]RATMLT([F:DAE]LEDTYP-1)
 [M:PCE2]DIVRAT(NOL) = [F:HAE]RATDIV([F:DAE]LEDTYP-1)
 [M:PCE2]CREUSR(NOL) = [F:HAE]CREUSR
 [M:PCE2]UPDUSR(NOL) = [F:HAE]UPDUSR
 LIGANA = 0
 #JHA : 070509 ajout du filtre  sur type de référentiel pour éviter
 #      l'affichage des section de l'analytique, Bug 54064
 For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
  LIGANA += 1
  If LIGANA = 1  # On visualise les sections de la première ligne
   For AX=1 To dim([F:DAA]DIE)
    Assign "[M:PCE2]CCE"+num$(AX)+"("+num$(NOL)+")" With [F:DAA]CCE(AX-1)
   Next AX
   If [F:DAE]DSP<>"" : Break : Endif : # Répartition selon clé
  Else
    [M:PCE2]DSP(NOL) = "$" : Break
  Endif
 Next

 #*YYFIN_X3-50263 The sections are reset to blank if there is an ana distribution for the line of the journal entry
 If   [M:PCE2]DSP(NOL) = "$"
  For AX=1 To dim([F:DAA]DIE)
   Assign "[M:PCE2]CCE"+num$(AX)+"("+num$(NOL)+")" With ""
  Next AX
 Endif #*YYFIN_X3-50263/

 [M:PCE2]CURCPY(NOL) = DEVSOC
 If [F:DAE]SNS=1
  [M:PCE2]DEBIT (NOL)  = [F:DAE]AMTCUR
  [M:PCE2]DEBLED(NOL)  = [F:DAE]AMTLED
 Else
  [M:PCE2]CREDIT(NOL)  = [F:DAE]AMTCUR
  [M:PCE2]CDTLED(NOL)  = [F:DAE]AMTLED
 Endif
Endif
Return

$INIT
Call LECTURE("CPY",[M:PCE1]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
GRP=([F:CPY]CPYLEGFLG=1)
If !GRP
 DEVSOC = [F:CPY]ACCCUR
 DEVLED = [F:GCM]CUR([M:PCE1]LEDTYP-1)
Else
 NBSITE = 0
 For [FGR]FGR0 Where CPY = [M:PCE1]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  If [F:FCY]FINFLG=2
   Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:PCE1]LEDTYP
   Read [FIY]FIY0 First
   If [M:CPCE]DATDEB>=[F:FIY]FIYSTR : DDEB=[M:PCE1]DATDEB : Else DDEB=[F:FIY]FIYSTR : Endif
   Read [FIY]FIY0 Last
   If [M:CPCE]DATFIN<=[F:FIY]FIYEND : DFIN=[M:PCE1]DATFIN : Else DFIN=[F:FIY]FIYEND : Endif
   Filter [FIY]
   If DDEB<=DFIN
    NBSITE+=1
    TSITE(NBSITE) = [F:FGR]FCY
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    TDEVSOC(NBSITE) = [F:CPY]ACCCUR
    Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
    TDEVLED(NBSITE) = [F:GCM]CUR([M:PCE1]LEDTYP-1)
   Endif
  Endif
 Next : # [FGR]
Endif
Return

$FILTRE
If !GRP
 FILLIG = 'CPY="'+[M:CPCE]CPY+'"'
 If [M:CPCE]FCY<>""
  FILLIG -= '& FCYLIN="'+[M:CPCE]FCY+'"'
 Endif
Else
 # Groupement de sites
 FILLIG = "find([F:DAE]FCYLIN,TSITE(1..NBSITE))"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & ([M:CPCE]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
 FILLIG -= '& find([F:DAE]FCYLIN,GUSRFCY(1..GNBAUZ))'
Endif
If [M:CPCE]DATDEB<>[0/0/0]
 FILLIG -= '& ACCDAT>=['+format$(GFMD,[M:CPCE]DATDEB)+']'
Endif
If [M:CPCE]DATFIN<>[0/0/0]
 FILLIG -= '& ACCDAT<=['+format$(GFMD,[M:CPCE]DATFIN)+']'
Endif
If [M:CPCE]COMPTE<>""
 FILLIG -= '& ACC="'+[M:CPCE]COMPTE+'"'
Endif
If [M:CPCE]MTC<>""
 FILLIG -= '& MTC="'+[M:CPCE]MTC+'"'
Endif
If [M:CPCE]TYP<>""
 FILLIG -= '& TYP="'+[M:CPCE]TYP+'"'
Endif
If [M:CPCE]NUMDEB<>""
 FILLIG -= '& NUM>="'+[M:CPCE]NUMDEB+'"'
Endif
If [M:CPCE]NUMFIN<>""
 FILLIG -= '& NUM<="'+[M:CPCE]NUMFIN+'"'
Endif
If [M:CPCE]LEDTYP<>0
 FILLIG -= '& LEDTYP='+num$([M:CPCE]LEDTYP)
Endif

FILTET = ""
If [M:CPCE]JOU<>""
 If FILTET<>"" : FILTET -= "&" : Endif
 FILTET -= '[F:HAE]JOU="'+[M:CPCE]JOU+'"'
Endif
If [M:CPCE]BPRVCR<>""
 If FILTET<>"" : FILTET -= "&" : Endif
 FILTET -= '[F:HAE]BPRVCR="'+[M:CPCE]BPRVCR+'"'
Endif
If [M:CPCE]FNLPSTSTR<>""
 If FILTET<>"" : FILTET -= "&" : Endif
 FILTET -= '[F:HAE]FNLPSTNUM('+num$([M:PCE1]LEDTYP-1)+')>="'+[M:CPCE]FNLPSTSTR+'"'
Endif
If [M:CPCE]FNLPSTEND<>""
 If FILTET<>"" : FILTET -= "&" : Endif
 FILTET -= '[F:HAE]FNLPSTNUM('+num$([M:PCE1]LEDTYP-1)+')<="'+[M:CPCE]FNLPSTEND+'"'
Endif
Return

$DEB_CRIT
Local Char FILTRE(250)(3)
FILTRE(0) = [M:CPCE]FILTECT(0)
If FILTRE(0)<>"" : [M:CPCE]CRITTET=2 : Else [M:CPCE]CRITTET=1 : Endif
FILTRE(1) = [M:CPCE]FILTECT(1)
If FILTRE(1)<>"" : [M:CPCE]CRITLIG=2 : Else [M:CPCE]CRITLIG=1 : Endif
FILTRE(2) = [M:CPCE]FILTECT(2)
If FILTRE(2)<>"" : [M:CPCE]CRITANA=2 : Else [M:CPCE]CRITANA=1 : Endif
Return

$EXEBOUT2
Case BOUT
 When "P" : # En-tête
  If [M:CPCE]FILTECT(0)<>"" & [M:CPCE]CRITTET<>2
   [M:CPCE]CRITTET=2 : GNBAFF=1
  Elsif [M:CPCE]FILTECT(0)="" & [M:CPCE]CRITTET=2
   [M:CPCE]CRITTET=1 : GNBAFF=1
  Endif
 When "Q" : # Ligne
  If [M:CPCE]FILTECT(1)<>"" & [M:CPCE]CRITLIG<>2
   [M:CPCE]CRITLIG=2 : GNBAFF=1
  Elsif [M:CPCE]FILTECT(1)="" & [M:CPCE]CRITLIG=2
   [M:CPCE]CRITLIG=1 : GNBAFF=1
  Endif
 When "O" : # Analytique
  If [M:CPCE]FILTECT(2)<>"" & [M:CPCE]CRITANA<>2
   [M:CPCE]CRITANA=2 : GNBAFF=1
  Elsif [M:CPCE]FILTECT(2)="" & [M:CPCE]CRITANA=2
   [M:CPCE]CRITANA=1 : GNBAFF=1
  Endif
Endcase
Return

$FIN_CRIT
Case REPONSE
 When GSTAOK, GSTARET
  If [M:CPCE]FILTECT(0)<>FILTRE(0) |
&    [M:CPCE]FILTECT(1)<>FILTRE(1) |
&    [M:CPCE]FILTECT(2)<>FILTRE(2)
   [L]CHANGE=2
  Endif
  If [M:CPCE]FILTECT(0)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CPCE]FILTECT(0))
   Onerrgo
  Endif
  If [M:CPCE]FILTECT(1)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CPCE]FILTECT(1))
   Onerrgo
  Endif
  If [M:CPCE]FILTECT(2)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CPCE]FILTECT(2))
   Onerrgo
  Endif

 When GSTAFIN, GSTAESC
  [M:CPCE]FILTECT(0) = FILTRE(0)
  [M:CPCE]FILTECT(1) = FILTRE(1)
  [M:CPCE]FILTECT(2) = FILTRE(2)
Endcase
Return

$ERR_FILTECT
Call ERREUR(mess(33,100,1)) From GESECRAN
[L]CHANGE=1
[M:CPCE]FILTECT(0) = FILTRE(0)
[M:CPCE]FILTECT(1) = FILTRE(1)
[M:CPCE]FILTECT(2) = FILTRE(2)
Resume

$AV_AFFICHE
#Gestion de l'affichage des colonnes lors de changement d'écran
Local Integer I, J
Local Char MSKCOL(17) : MSKCOL=""
Local Char VARMSK(15)(1..3) , VARABR(5)(1..3)
I = 1 : J = 1
Repeat
 If masknam( I ) <> ""
  VARMSK( J ) = masknam( I )
  VARABR( J ) = maskabr( I )
  If VARABR(J)="PCE2"
   MSKCOL="W1"+masknam(I)
  Endif
  J += 1
 Endif
 I += 1
Until I > 3
#Infbox MSKCOL+chr$(10)+VARMSK(1)+"/"+VARABR(1)+chr$(10)+VARMSK(2)+"/"+VARABR(2)+chr$(10)+VARMSK(3)+"/"+VARABR(3)
If MSKCOL<>""
 zoncou = "NBLIG"
 Gosub CHG_FMT From =MSKCOL
 Affzo [M:PCE2]
Endif
Return

#############################################################
##     Etiquettes masques CONSPCE1 & CRITPCE & CONSPCE2    ##
#############################################################

## Ecrans CONSPCE1 & CRITPCE ##

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char SOCIETE(GLONCPY)
Call C_CPY(VALEUR) From CONSSUB
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=0 : #Référentiel tous types
Call LEDTYP_CHOICE([M:PCE1]CPY,OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From CONSSUB
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
End

## Ecran CONSPCE2 ##

Subprog IB_NBLIG
Call IB_NBLIG From CONSSUB
# correction bug 26538
If [M:PCE2]ORIMOD(nolign-1)<>7 # Stocks
 Raz GBOUT5 # suppression tunnel "Mouvements par date"
Endif
# correction bug 26538
If [M:PCE2]ORIMOD(nolign-1)<>8 # GPAO
 Raz GBOUT6 # suppression tunnel "Coût de revient industriel"
Endif
End

## Tunnel vers les pièces
$AB1_NBLIG
Gosub SAV_CONSULT From CONSSUB
Call B1_NBLIG From CONSSUB
Return

## Tunnel vers les factures et règlements
$AB2_NBLIG
Gosub SAV_CONSULT From CONSSUB
Call B2_NBLIG From CONSSUB
Return

$BB_NBLIG
 Gosub RST_CONSULT From CONSSUB
Return

