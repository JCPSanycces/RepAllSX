#<AdxTL>@(#)0.0.0.0 $Revision$ 


$METHODS
Case [L]AMETHOD
  When "EMP_WRKREQ"           : Gosub EMP_WRKREQ
Endcase
Return


$EMP_WRKREQ
[L]ARET_VALUE = [V]CST_ANOTDEFINED
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..

#Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
ALPKEY(0) = this.REFNUM

#Specify function variables
MAIN_CLASSCOD = PMAINCLASS   #The main class that was used to create the ESSXXX Class
CLASSCOD      = PCURRENTCLASS    #The ESS Class where the change occurred
LINSTAT       = PLINSTAT        #This will be used for collection classes - 1,1 can be set fixed - "T"
CTABLE        = PTABLE
CABR          = PABR


#Check if a change occured on the class and then call the workflow
[L]TRG_WRKFLW = func ESS_WRKFLOW_FUNC_HYBRID.CHECK_CLASS_STAT(this, SYSPROP, WRK, LINSTAT)
If [L]TRG_WRKFLW = [V]CST_AYES
  #Trigger the workflow
  [L]ARET_VALUE = func ESS_WRKFLOW_FUNC_HYBRID.GENESSWRKFLOW_ESSWRKEMPKUK(WRK,THISUSR,this,
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
Endif
Return

