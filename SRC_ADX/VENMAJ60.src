End
#####################################################################################
# VENMAJ60 : Mises à jour à effectuer lors du passage à la version 9 Module ventes  #
# --------------------------------------------------------------------------------- #
# Avant mise à jour AVENMAJ60                                                       #
#                                                                                   #
#    - Table SALTRS [SLT]                 : Transactions Ventes                     #
#    - Table STKTRS [SRT]                 : Transactions Stock pour BP              #
#####################################################################################
# --------------------------------------------------------------------------------- #
# Après mise à jour VENMAJ60                                                        #
#                                                                                   #
#####################################################################################
# Issue 115351 - 20160318 by LD : Error return instead of end

#################################################################################
# Moulinettes avec anciens et nouveaux champs màj concernant le module ventes   #
#################################################################################
Subprog AVENMAJ60
Local Integer WOUV_TRACE

  If GTRACE = "" Then
    Call OUVRE_TRACE("VENMAJ60 : Process for sales data") From LECFIC
    WOUV_TRACE=1
  Endif
  #--------------------------------
  Gosub SET_FIRST   From TRTFIRST
  #--------------------------------
  Call AV_SLT : # Moulinette des transactions Ventes
  #--------------------------------
  Gosub UNSET_FIRST   From TRTFIRST
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End

#################################################################################
#    ---> Concerne les transactions VENTES                                      #
#################################################################################
Subprog AV_SLT
Local Shortint INDIC, WI
Local Integer  I
Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Integer  IERR

  #--------------------------------
  # UTIVEN80
  #--------------------------------
  IERR = 0
  If filinfo(filpath("FIL","SALTRS","fde",[F:ADS]DOSSIER),0) <= 0 Then
    # Issue 115351
    #Return
    End
    # End issue 115351
  Endif
  #--------------------------------
  Local File =[F:ADS]DOSSIER+".SALTRS"    [SLT]
  #--------------------------------
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("VENMAJ60 Sales Transactions Process : Update SALTRS") From DOSSUB
  Call ECR_TIME("VENMAJ60 Sales Transactions Process : --- Step 1 ") From DOSSUB
  Gosub TXNSQH  # Transaction pour les devis                                  #
  #
  Call ECR_TIME("VENMAJ60 Sales Transactions Process : --- Step 2 ") From DOSSUB
  Gosub TXNSOH  # Transaction pour les commandes                              #
  #
  Call ECR_TIME("VENMAJ60 Sales Transactions Process : --- Step 3 ") From DOSSUB
  Gosub TXNSOR  # Transaction pour les commandes ouvertes                     #
  #
  Call ECR_TIME("VENMAJ60 Sales Transactions Process : --- Step 4 ") From DOSSUB
  Gosub TXNSDH  # Transaction pour les livraisons                             #
  #
  Call ECR_TIME("VENMAJ60 Sales Transactions Process : --- Step 5 ") From DOSSUB
  Gosub TXNSIH  # Transaction pour les factures                               #
  #--------------------------------
End

#-------------------------------------------------------------------------------#
# Transaction pour les devis                                                    #
#-------------------------------------------------------------------------------#
$TXNSQH
  IERR = 0
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 1
    Raz INDIC
    If dim([F:SLT]ECCCOD) > 0 Then
      If !find([F:SLT]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:SLT]ECCCOD = 3
        [F:SLT]ECCSCR = 1
      Endif
    Endif
    If dim([F:SLT]ECCCODMIN) > 0 Then
      If !find([F:SLT]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:SLT]ECCCODMIN = 3
        [F:SLT]ECCSCRMIN = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        IERR = 1
      Endif
    Endif
  Next
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes                                                #
#-------------------------------------------------------------------------------#
$TXNSOH
  IERR = 0
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 2
    Raz INDIC
    If dim([F:SLT]ECCCOD) > 0 Then
      If !find([F:SLT]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:SLT]ECCCOD = 3
        [F:SLT]ECCSCR = 1
      Endif
    Endif
    If dim([F:SLT]ECCCODMIN) > 0 Then
      If !find([F:SLT]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:SLT]ECCCODMIN = 3
        [F:SLT]ECCSCRMIN = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        IERR = 1
      Endif
    Endif
  Next
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes ouvertes                                       #
#-------------------------------------------------------------------------------#
$TXNSOR
  IERR = 0
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 3
    Raz INDIC
    If dim([F:SLT]ECCCOD) > 0 Then
      If !find([F:SLT]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:SLT]ECCCOD = 3
        [F:SLT]ECCSCR = 1
      Endif
    Endif
    If dim([F:SLT]ECCCODMIN) > 0 Then
      If !find([F:SLT]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:SLT]ECCCODMIN = 3
        [F:SLT]ECCSCRMIN = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        IERR = 1
      Endif
    Endif
  Next
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
Return

#-------------------------------------------------------------------------------#
# Transaction pour les commandes                                                #
#-------------------------------------------------------------------------------#
$TXNSDH
  IERR = 0
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 4
    Raz INDIC
    If dim([F:SLT]ECCCOD) > 0 Then
      If !find([F:SLT]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:SLT]ECCCOD = 3
        [F:SLT]ECCSCR = 1
      Endif
    Endif
    If dim([F:SLT]ECCCODMIN) > 0 Then
      If !find([F:SLT]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:SLT]ECCCODMIN = 3
        [F:SLT]ECCSCRMIN = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        IERR = 1
      Endif
    Endif
  Next
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
Return

#-------------------------------------------------------------------------------#
# Transaction pour les factures et avoirs                                       #
#-------------------------------------------------------------------------------#
$TXNSIH
  IERR = 0
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 5
    Raz INDIC
    If dim([F:SLT]ECCCOD) > 0 Then
      If !find([F:SLT]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:SLT]ECCCOD = 3
        [F:SLT]ECCSCR = 1
      Endif
    Endif
    If dim([F:SLT]ECCCODMIN) > 0 Then
      If !find([F:SLT]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:SLT]ECCCODMIN = 3
        [F:SLT]ECCSCRMIN = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        IERR = 1
      Endif
    Endif
  Next
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
Return

##################################################################################
# Moulinettes avec champs version V9 uniquement màj concernant le module ventes #
##################################################################################
Subprog VENMAJ60

Local Integer WOUV_TRACE

  If GTRACE = "" Then
    Call OUVRE_TRACE("VENMAJ60 : Process for sales data") From LECFIC
    WOUV_TRACE = 1
  Endif
  #--------------------------------
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End

