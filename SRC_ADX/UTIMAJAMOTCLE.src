#<AdxTL>@(#)7.0.0.0 $Revision$
Dbgaff
Call GENE
End

#----------------------------------------------------------------------------------------#
# Création des éléments dans AMOTCLE a partir de tables
#  ATABZON,AMSKZON,ACLAFLD,ASHWFLD
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Creating AMOTCLE...") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIMAJAMOTCLE : Creating AMOTCLE on folder"-DOSSIER,0) From GESECRAN

If DOSSIER=nomap
 Local File AMOTCLE [AMC],ATEXTE [ATX], ADOCFLD [ADZ]
Else
 Local File =DOSSIER+".AMOTCLE" [AMC]
 Local File =DOSSIER+".ATEXTE"  [ATX]
 Local File =DOSSIER+".ADOCFLD" [ADZ]
Endif
Local Integer NOINFBUL,NOINFMOD

Gosub MAJAMOTCLE1
Gosub MAJAMOTCLE2
Gosub MAJAMOTCLE3
Gosub MAJAMOTCLE4

Call ECR_TRACE("UTIMAJAMOTCLE : End creating AMOTCLE on folder"-DOSSIER,0) From GESECRAN
Close Local File [AMC],[ATX],[ADZ]
End

#-------------------#
$MAJAMOTCLE1

Call ECR_TRACE("UTIMAJAMOTCLE : 1/4 Creating AMOTCLE from ATABZON",0) From GESECRAN

If clalev([F:ATZ])<>0 : Close File [ATZ] : Endif

If DOSSIER=nomap
 Local File ATABZON [ATZ]
Else
 Local File =DOSSIER+".ATABZON" [ATZ]
Endif

If dim([F:ATZ]MOTCLE)>0

Trbegin [AMC]
For [ATZ] Where MOTCLE<>""
  Look [AMC]AMC0=1;[F:ATZ]CODFIC;[F:ATZ]CODZONE
  If fstat
    Raz [F:AMC]
    [F:AMC]TYPZON=1
    [F:AMC]IDENT1=[F:ATZ]CODFIC
    [F:AMC]IDENT2=[F:ATZ]CODZONE
    [F:AMC]MOTCLE=[F:ATZ]MOTCLE
    Write [F:AMC]
    If fstat
      Call ERREUR("AMOTCLE 1"-[F:ATZ]CODFIC-[F:ATZ]CODZONE,1) From DOSDIC
    Endif
  Endif
Next ATZ
Commit

Endif

Close Local File [ATZ]
Return

#-------------------#
$MAJAMOTCLE2

Call ECR_TRACE("UTIMAJAMOTCLE : 2/4 Creating AMOTCLE from AMSKZON",0) From GESECRAN

If clalev([F:AMK])<>0 : Close File [AMK] : Endif
If clalev([F:AMZ])<>0 : Close File [AMZ] : Endif

If DOSSIER=nomap
 Local File AMSK [AMK], AMSKZON [AMZ]
Else
 Local File =DOSSIER+".AMSK" [AMK]
 Local File =DOSSIER+".AMSKZON" [AMZ]
Endif

If dim([F:AMZ]MOTCLE)>0

Link [AMZ] With [AMK]CODMSK~=[F:AMZ]CODMSK As [LNK]

Trbegin [AMC],[ADZ]
For [LNK] Where MOTCLE<>"" or INFBUL<>0
  Look [AMC]AMC0=2;[F:AMZ]CODMSK;[F:AMZ]CODZON
  If fstat
    Raz [F:AMC]
    [F:AMC]TYPZON=2
    [F:AMC]IDENT1=[F:AMZ]CODMSK
    [F:AMC]IDENT2=[F:AMZ]CODZON
    [F:AMC]MOTCLE=[F:AMZ]MOTCLE
    If [F:AMZ]INFBUL<>0
       NOINFBUL=[F:AMZ]INFBUL
       NOINFMOD=[F:AMK]MODULE
       Gosub CREER_ADZAUTO
    Endif
    Write [F:AMC]
    If fstat
      Call ERREUR("AMOTCLE 2"-[F:AMZ]CODMSK-[F:AMZ]CODZON,1) From DOSDIC
    Endif
  Endif
Next AMZ
Commit

Endif

Close Local File [AMK],[AMZ]
Return

#-------------------#
$CREER_ADZAUTO
For [ATX] Where NUMERO=NOINFBUL
  Look [ADZ]ADZ0=[F:ATX]LAN;"AMC"+num$(NOINFBUL)
  If fstat
    Raz [ADZ]
    [F:ADZ]LAN=[F:ATX]LAN
    [F:ADZ]MOTCLE="AMC"+num$(NOINFBUL)
    [F:ADZ]MODULE=NOINFMOD
    Setlob [ADZ]TEXTE With [F:ATX]TEXTE
    Write [F:ADZ]
    If fstat
      Call ERREUR("ADOCFLD"-[F:ATX]LAN-"AMC"+num$(NOINFBUL),1) From DOSDIC
    Else
      [F:AMC]INFBUL="AMC"+num$(NOINFBUL)
    Endif
  Else
    # Issue 84444 - 2012-09-11 by VPO : manquait affectation si ADZ déjà créé
    [F:AMC]INFBUL="AMC"+num$(NOINFBUL)
  Endif
Next ATX
Return

#-------------------#
$MAJAMOTCLE3
Call ECR_TRACE("UTIMAJAMOTCLE : 3/4 Creating AMOTCLE from ACLAFLD",0) From GESECRAN

If clalev([F:ACLA])<>0 : Close File [ACLA] : Endif
If clalev([F:ACLAF])<>0 : Close File [ACLAF] : Endif

If DOSSIER=nomap
 Local File ACLASSE [ACLA], ACLAFLD [ACLAF]
Else
 Local File =DOSSIER+".ACLASSE" [ACLA]
 Local File =DOSSIER+".ACLAFLD" [ACLAF]
Endif

If dim([F:ACLAF]MOTCLE)>0
Link [ACLAF] With [ACLA]ACLA0~=[F:ACLAF]CODCLA As [LNK]

Trbegin [AMC],[ADZ]
For [LNK] Where MOTCLE<>"" or INFBUL<>0
  Look [AMC]AMC0=3;[F:ACLAF]CODCLA;[F:ACLAF]FLDCLA
  If fstat
    Raz [F:AMC]
    [F:AMC]TYPZON=3
    [F:AMC]IDENT1=[F:ACLAF]CODCLA
    [F:AMC]IDENT2=[F:ACLAF]FLDCLA
    [F:AMC]MOTCLE=[F:ACLAF]MOTCLE
    If [F:ACLAF]INFBUL<>0
       NOINFBUL=[F:ACLAF]INFBUL
       NOINFMOD=[F:ACLA]MODULE
       Gosub CREER_ADZAUTO
    Endif
    Write [F:AMC]
    If fstat
      Call ERREUR("AMOTCLE 3"-[F:ACLAF]CODCLA-[F:ACLAF]FLDCLA,1) From DOSDIC
    Endif
  Endif
Next AMZ
Commit
Endif
Close Local File [ACLA],[ACLAF]
Return

#-------------------#
$MAJAMOTCLE4
Call ECR_TRACE("UTIMAJAMOTCLE : 4/4 Creating AMOTCLE from ASHWFLD",0) From GESECRAN

If clalev([F:ASW])<>0 : Close File [ASW] : Endif
If clalev([F:ASWF])<>0 : Close File [ASWF] : Endif

If DOSSIER=nomap
 Local File ASHW [ASW], ASHWFLD [ASWF]
Else
 Local File =DOSSIER+".ASHW" [ASW]
 Local File =DOSSIER+".ASHWFLD" [ASWF]
Endif

If dim([F:ASWF]MOTCLE)>0

Link [ASWF] With [ASW]ASW0~=[F:ASWF]CODREP As [LNK]

Trbegin [AMC],[ADZ]
For [LNK] Where MOTCLE<>"" or INFBUL<>0
  Look [AMC]AMC0=4;[F:ASWF]CODREP;[F:ASWF]CODFLD
  If fstat
    Raz [F:AMC]
    [F:AMC]TYPZON=4
    [F:AMC]IDENT1=[F:ASWF]CODREP
    [F:AMC]IDENT2=[F:ASWF]CODFLD
    [F:AMC]MOTCLE=[F:ASWF]MOTCLE
    If [F:ASWF]INFBUL<>0
       NOINFBUL=[F:ASWF]INFBUL
       NOINFMOD=[F:ASW]MODULE
       Gosub CREER_ADZAUTO
    Endif
    Write [F:AMC]
    If fstat
      Call ERREUR("AMOTCLE 4"-[F:ASWF]CODREP-[F:ASWF]CODFLD,1) From DOSDIC
    Endif
  Endif
Next AMZ
Commit
Endif
Close Local File [ASW],[ASWF]
Return
