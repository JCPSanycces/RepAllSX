####################################################################################
# Program Name: NADISPATCH
# Author      : NA Development
# Date        : Nov 19, 2012
####################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End
####################################################################################
# 106901.sn
$ACTION
Case ACTION
 When "OUVRE"
   If (find(VALINT1(nolign+3),"1","3") > 0) # Not started, All
      Raz [M]VALEUR1(nolign+4), [M]VALEUR2(nolign+4)
      Grizo [M]VALEUR1(nolign+4) : Grizo [M]VALEUR2(nolign+4)
   Endif
 When "CONT1"
  If [M]PARCOD(nolign-1)="schsel" # Include operations
    If VALINT1(nolign-1)="2"      # Started
      Actzo [M]VALEUR1(nolign), VALEUR2(nolign)
      If [M]VALINT1(nolign-1)<>VALEUR # To keep LM Literal on Print
        [M]VALEUR1(nolign-1)=VALEUR
      Endif # To keep 'Started' on click of Print
      If [M]VALEUR1(nolign)=""
        [M]VALEUR1(nolign) = format$("D:MM[/]DD[/]YYYY",date$)
        #[M]VALEUR2(nolign) = format$("D:MM[/]DD[/]YYYY",date$)
      Endif
      #Call CHARGE([M]VALEUR1(nolign),[M]VALEUR2(nolign),[M]PARTYP(nolign),[M]NOLIB(nolign),[M]LONG(nolign),[M]VALINT1(nolign),[M]VALINT1(nolign-1),[M]VALEUR(nolign-1)) From FMTVAR #112512.o
      Call CHARGE([M]VALEUR1(nolign),[M]PARTYP(nolign),[M]NOLIB(nolign),[M]LONG(nolign),[M]VALINT1(nolign)) From FMTVAR #112512.n
      Affzo[M]1-99
    Else
      Raz [M]VALEUR1(nolign), [M]VALEUR2(nolign)
      Grizo [M]VALEUR1(nolign) : Grizo [M]VALEUR2(nolign)
      Effzo [M]VALEUR1(nolign) : Effzo [M]VALEUR2(nolign)
      #Affzo[M]1-99 AFFZO here will not allow for proper refresh when changing flag from Started to Not Started using Selection icon
    Endif
  Endif
  If [M]PARCOD(nolign-1)="mfgfcydeb" # Site
    If (find(VALINT1(nolign+2),"1","3") > 0) # Not started, All
      Raz [M]VALEUR1(nolign+3), [M]VALEUR2(nolign+3)
      Grizo [M]VALEUR1(nolign+3) : Grizo [M]VALEUR2(nolign+3)
    Endif
  Endif
 When Default :
Endcase
Return # 106901.en
#####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Local Char TEST(20)

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

[L]CRITERE = "1=1"
[L]CRITEREA = "1=1"


For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "mfgfcydeb"
    [L]CRITERE -= "& [MFO]MFGFCY>='"+[L]VALEUR+"'"
   When "mfgfcyfin"
    [L]CRITERE -= "& [MFO]MFGFCY<='"+[L]VALEUR+"'"
   When "wcgdeb"
    [L]CRITEREA -= "& [MWS]WCR>='"+[L]VALEUR+"'"
   When "wcgfin"
    [L]CRITEREA -= "& [MWS]WCR<='"+[L]VALEUR+"'"
   When "wcdeb"
    [L]CRITEREA -= "& [MWS]WST>='"+[L]VALEUR+"'"
   When "wcfin"
    [L]CRITEREA -= "& [MWS]WST<='"+[L]VALEUR+"'"
   When "datedeb"
    WDATEDEB = [L]VALEUR
   When "datefin"
    WDATEFIN = [L]VALEUR
   When "schsel"
    WSCHEL = [L]VALEUR
   When "numedt"
    [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"
    [L]PARAMETRE(I) = "usr="+GUSER
    [L]USR=GUSER
   When "etat"
    [L]PARAMETRE(I) = "etat="+[L]ETAT
 Endcase
 Endif
Next

[L]CRITERE -= "& [MFO]MFGSTA=1 & [MFO]OPESTA <>5 & [MFO]OPESTA <> 6" #   !Find([MFO]OPESTA,'5','6')"

Lock [ARM]
  Delete[ARM] Where RPTCOD=[L]ETAT and CREDAT<date$-7
Unlock [ARM]

# Write the Operation Records
Gosub ARM_LOOP

End
####################################################################################
$OUVRE

If !clalev([F:SCH])  : Local File SCHEDULING  [SCH]  : Endif
If !clalev([F:MWS])  : Local File WORKSTATIO  [MWS]  : Endif
If !clalev([F:MFO])  : Local File MFGOPE      [MFO]  : Endif

If !clalev([F:TWD])  : Local File TABWEEDIA   [TWD]  : Endif
If !clalev([F:FCY])  : Local File FACILITY    [FCY]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER   [ITM]  : Endif
If !clalev([F:MFG])  : Local File MFGHEAD     [MFG]  : Endif
If !clalev([F:TWC])  : Local File TABWRKCTR   [TWC]  : Endif

If !clalev([F:ARM])  : Local File AREPORTM    [ARM]  : Endif

Local Char    LTYP(3)

Return
####################################################################################
$DECLARE

Local Char    CRITERE(255),CRITEREA(255),PARAM(30),VALEUR(30),ETAT(15),USR(15)
Local Char    VALSTR, VALEND, WTIMEDEB, WTIMEFIN
Local Date    DTEDEB,DTEFIN, WDATEDEB, WDATEFIN #, WTIMEDEB, WTIMEFIN
Local Integer NUMREQ,RFLAG,WNUMLIG

Return
####################################################################################
$ARM_LOOP

Local Integer RCP_IN_RANGE,INV_IN_RANGE,FORMFLG
Local Decimal TOTAL_RECEIPT_QTY,THIS_QTY

#Link [MWS] With [MFO]MFO2(2)=[MWS]WCRFCY;[MWS]WST,[MFO]MFO0(2)=[SCH]MFGNUM;[SCH]OPENUM As [ARM1]
#& Where [L]CRITERE Order By [MWS]WCRFCY

Filter [MFO] Where evalue([L]CRITERE)
For [MFO]
  Filter [MWS] Where evalue([L]CRITEREA) and [MFO]MFGFCY = [MWS]WCRFCY and [MFO]EXTWST = [MWS]WST
    For [MWS]
       Filter [SCH] Where [SCH]MFGNUM = [MFO]MFGNUM and [SCH]OPENUM = [MFO]OPENUM #
       Raz [F:SCH]
       Raz WTIMEDEB, WTIMEFIN
      Read [MFG]MFG0=[MFO]MFGNUM
      For [SCH]
# START / End TIMES
        Call OPETIME([F:SCH]MFGFCY, [F:SCH]CLCWST, [F:SCH]OPESTRDAT, [F:SCH]OPESTRFRD, WTIMEDEB) From JALLIBB
        Call OPETIME([F:SCH]MFGFCY, [F:SCH]CLCWST, [F:SCH]OPEENDDAT, [F:SCH]OPEENDFRD, WTIMEFIN) From JALLIBB
      Filter [SCH]
      Next # SCH
      If (find(WSCHEL,'2') > 0 and year([F:SCH]OPESTRDAT) > year(1,1,1900) and [F:SCH]OPESTRDAT >= WDATEDEB and [F:SCH]OPESTRDAT <= WDATEFIN) or
&        (find(WSCHEL,'1') > 0 and year([F:SCH]OPESTRDAT) < year(1,1,1900)) or
&        (find(WSCHEL,'3') > 0)
      Gosub WRITE_RECORD
      Endif #
    Next # MFO
Next # MWS

Return
####################################################################################
$WRITE_RECORD

Local Decimal LPRI
Local Integer LRET

Readlock [ARM]ARM0=[L]NUMREQ;[L]USR;[L]ETAT;[L]WNUMLIG
If fstat # New record
GOK = 1
Trbegin [ARM]
  WNUMLIG += 1
  Raz [F:ARM]
  If [SCH]MFGNUM <> ""  # Schedule available
     [F:ARM]CLED1   =  [SCH]OPESTRDAT  # start date
     [F:ARM]CLED2   =  [SCH]OPEENDDAT  # end date
    If num$(WTIMEDEB) > num$(0) : [F:ARM]CLEA10  = format$("hh[:]mm",WTIMEDEB) : Endif # start time
    If num$(WTIMEFIN) > num$(0) : [F:ARM]CLEA11  = format$("hh[:]mm",WTIMEFIN) : Endif # end time
  Else
    [F:ARM]CLED1   = [0/0/0]  # start date
    [F:ARM]CLED2   = [0/0/0]  # end date
  Endif
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1   = [MFO]MFGFCY
  [F:ARM]CLEA2   = [MFO]MFGNUM
  [F:ARM]CLEA3   = [MFO]EXTWST
  [F:ARM]CLEN2   = [MFO]OPENUM
  [F:ARM]CLEA4   = [MWS]WCR      # wc group
  [F:ARM]CLEN3   = [MFG]MFGPIO   # priority
  [F:ARM]CLEA6   = [MWS]WST      # wc
  [F:ARM]CLEA7   = [MWS]WSTDES   # wc desc
  [F:ARM]CLEA8   =  [MFO]MFGNUM  # mfgnum
  [F:ARM]CLEA9   = [MFG]ROUNUM   # product number
  [F:ARM]CLEN1   = [MFO]OPENUM   # Operation
  [F:ARM]CLEMD1  = [MFO]EXTOPETIM - [MFO]CPLOPETIM # run time
  [F:ARM]CLEMD2  = [MFO]EXTQTY   # expected qty
  [F:ARM]CLEMD3  = [MFO]EXTSETTIM - [MFO]CPLSETTIM # setup time
  [F:ARM]CLEMD4  = [MFO]EXTQTY - [MFO]CPLQTY       # remaining qty
  [F:ARM]CREDAT  = date$
  [F:ARM]CREUSR  = GUSER
  [F:ARM]RPTCOD  = "NA-DISPATCH"
  Write [ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Rollback : Endif
Endif

If fstat
  Rollback
Else
  Commit
Endif

Return

