#<AdxTL>@(#)0.0.0.0 $Revision$
# -------------------------------------------------------------------- #
#       Traitement lié à la classe de données SORDER                   #
# -------------------------------------------------------------------- #
End

#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - here, I've replaced all calls to SORDERP_CSTD and SORDERQ_CSTD by ones to SORDER_METHODS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AINIT"           : Gosub AINIT                     From SORDER_METHODS
        When "AREAD_AFTER"     : Gosub AREAD_AFTER               From SORDER_METHODS
      Endcase
    When "SOP"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SOP          From SORDER_METHODS
      Endcase
    When "SOP.C_VACITM"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SOP_C_VACITM  From SORDER_METHODS
        When Default
      Endcase
    When "SOP.C_VAT"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SOP_C_VAT     From SORDER_METHODS
        When Default
      Endcase
    When "SOQ"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SOQ          From SORDER_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - replaced
      Endcase
    When "SVV"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SVV          From SORDER_METHODS
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVV           From SORDER_METHODS
        When Default
      Endcase
    When "SVF"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SVF          From SORDER_METHODS
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF           From SORDER_METHODS
        When Default
      Endcase
    When "SVF.C_DTAVAT"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF_C_DTAVAT  From SORDER_METHODS
        When Default
      Endcase
    When Default
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "LOCK_UNLOCK"     : Gosub LOCK_UNLOCK       From SORDER_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - moved from $EVENT
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSCCODADI"  : Gosub INIT_TSCCODADI    From SORDER_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - moved from $EVENT
  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all _LEG calls
  Case CURPTH
    When ""
      Case CURPRO
        When "CPY"                      :  Gosub CPY            From SORDER_PROPERTIES
        When "LEG"                      :  Gosub LEG            From SORDER_PROPERTIES
        When "CPYCUR"                   :  Gosub CPYCUR         From SORDER_PROPERTIES
        When Default
      Endcase
  Endcase
Return

