######################################################
# GETCRYDATA Récupération Langue et devise d'un pays #
# Business partner customer name                     #
######################################################
Funprog GETCRYDATA(SZCRY, SZLAN,SZCUR, SZMESSAGE, IBRETOUR)
Value Char SZCRY
Variable Char SZLAN
Variable Char SZCUR
Variable Char SZMESSAGE
Variable Integer IBRETOUR
IBRETOUR=1
Raz SZLAN
Raz SZCUR
If SZCRY=""
    End
Endif
If !clalev([F:TCY])  Local File TABCOUNTRY [TCY] : Endif
Read [TCY] TCY0=SZCRY
If fstat=0
    SZLAN=[F:TCY]LAN
    SZCUR=[F:TCY]CUR
Endif
End


#################################################
# GETFMTREM Récupération du format des remises  #
# --------------------------------------------- #
# WTYPREM : Type de remise à traiter            #
#           1 = Remise élément facturation pied #
#################################################
Funprog GETFMTREM(WTYPREM)
Value Integer WTYPREM : # Type de remise
#-----
Local Char    WFMTREM(20)
Local Char    WCODTYP(GLONATY)
Local Integer I, J, K : # K = nbre de blancs à afficher après la remise
#----- Valeur par défaut du format des remises -----#
Case [L]WTYPREM
  When 1       : WFMTREM="NZ:3.2#[      ]" : K=6
  When Default : WFMTREM="NZ:3.2#"         : K=0
Endcase
#----- Récupération du format à partir du type de donnée -----#
If !clalev([F:ATY])  Local File ATYPE [ATY] : Endif
Case [L]WTYPREM
  When 1       : [L]WCODTYP="RFI"
  When Default : [L]WCODTYP="RAT"
Endcase
Read [ATY] CODTYP=[L]WCODTYP
If !fstat
  If K & !instr(1,[F:ATY]FORTYP,"[")
    I=instr(1,[F:ATY]FORTYP,".")
    If I
      J =val(mid$([F:ATY]FORTYP,I-1,1)) : #   nbre chiffres entiers
      J+=val(mid$([F:ATY]FORTYP,I+1,1)) : # + nbre chiffres décimales
    Else
      J =val(left$([F:ATY]FORTYP,2))
    Endif
    If J>K+5  J=K+5 : Endif
    WFMTREM="NZ:"+[F:ATY]FORTYP+"["+space$(K+5-J)+"]"
  Else
    WFMTREM="NZ:"+[F:ATY]FORTYP
  Endif
Endif
#-----
End WFMTREM


####################################################
# GETPIVTYP Récupération du type de facture achats #
# ------------------------------------------------ #
# WTYPFAC : Catégorie facture achat                #
#           1 = Facture                            #
#           2 = Facture complémentaire             #
#           3 = Avoir                              #
#           4 = Avoir sur retour                   #
####################################################
Funprog GETPIVTYP(WTYPFAC)
Value Integer WTYPFAC : # Catégorie facture achats
#-----
Local Char    WPIVTYP(GLONTPV)
If !clalev([F:TPV])  Local File TABPIVTYP [TPV] : Endif
If WTYPFAC=0  WTYPFAC=1 : Endif
#----- Lecture des types de facture livrés en standard -----#
Raz [F:TPV]
Case WTYPFAC
  When 1 : WPIVTYP="FAC"
  When 2 : WPIVTYP="FCC"
  When 3 : WPIVTYP="AVO"
  When 4 : WPIVTYP="AVR"
Endcase
Read [TPV] TPV0=WPIVTYP
If !fstat & [F:TPV]PIHTYP=WTYPFAC & [F:TPV]INVTYP<3
  #----- contrôle les groupes de site ??? -----#
  Call CONTSEL("TPV","A",[F:TPV]PIVTYP,"",mkstat) From CONTOBJ
  If mkstat  Raz mkstat, [F:TPV] : Endif
  #-----
Else
  Raz [F:TPV]
Endif
#----- Recherche d'un type de facture pouvant convenir -----#
If [F:TPV]PIVTYP=""
  For [TPV] TPV0 Where PIHTYP=WTYPFAC & INVTYP<3
    #----- contrôle les groupes de site ??? -----#
    Call CONTSEL("TPV","A",[F:TPV]PIVTYP,"",mkstat) From CONTOBJ
    If !mkstat  Break  Else  Raz mkstat : Endif
    #-----
  Next
Endif
WPIVTYP=[F:TPV]PIVTYP
#-----
End WPIVTYP


##############################################################
# CTLFCY Vérifie si le site est autorisé pour l'utilisateur  #
#        GUSRFCY est chargé par les habilitations/fonction   #
#        Renvoie 1 si ok, 0 sinon                            #
##############################################################
Funprog CTLFCY (LFCY)
Value Char LFCY

Local Shortint IOK : IOK=1

# Si l'utilisateur n'est pas autorisé "tous sites", on contrôle
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    If !find(LFCY,GUSRFCY(1..GNBAUZ))
      IOK=0
    Endif
  Endif
End IOK


###############################################
# GETCPY Récupération de la société d'un site #
###############################################
Funprog GETCPY(SITE)
Value    Char    SITE
#-----
If !clalev([F:FCY])  Local File FACILITY [FCY] : Endif
#----- Lecture du site si nécessaire -----#
If [F:FCY]FCY<>SITE
  Read [FCY] FCY0=SITE : If fstat  Raz [F:FCY] : Endif
Endif
#-----
End [F:FCY]LEGCPY

Funprog GETCPYDEF(SITE,DEF)
Value    Char    SITE
Value    Char    DEF
Local Char WLEGCPY(GLONCPY)

WLEGCPY=func GETCPY(SITE)
If WLEGCPY=""
  WLEGCPY=DEF
Endif

End WLEGCPY


##########################################################
# GETCRY Récupération du pays d'un site ou d'une société #
##########################################################
Funprog GETCRY(SITE)
Value    Char    SITE    : # Site ou société
#-----
Local Char PAYS(GLONCRY)
#-----
If !clalev([F:FCY])  Local File FACILITY [FCY] : Endif
If [F:FCY]FCY<>SITE
  Read [FCY] FCY0=SITE
  If !fstat
    PAYS=[F:FCY]CRY
  Else
    Raz [F:FCY]
    If !clalev([F:CPY])  Local File COMPANY [CPY] : Endif
    If [F:CPY]CPY<>SITE
      Read [CPY] CPY0=SITE
      If fstat  Raz [F:CPY] : Endif
    Endif
    PAYS=[F:CPY]CRY
  Endif
Endif
#-----
End PAYS


####################################################################
# GETLEG Récupération de la législation d'un site ou d'une société #
####################################################################
Funprog GETLEG(SITE)
Value    Char    SITE    : # Site ou société
#-----
Local Char LEGISLATION(GLONADI)
#-----
#If !clalev([F:FCY])  Local File FACILITY [FCY] : Endif MAE, bg 97643, ouverture de [F:FCY] en local
Local File FACILITY [FCY]
If [F:FCY]FCY<>SITE
  Read [FCY] FCY0=SITE
  If !fstat
    LEGISLATION=[F:FCY]LEG
  Else
    Raz [F:FCY]
    If !clalev([F:CPY])  Local File COMPANY [CPY] : Endif
    If [F:CPY]CPY<>SITE
      Read [CPY] CPY0=SITE
      If fstat  Raz [F:CPY] : Endif
    Endif
    LEGISLATION=[F:CPY]LEG
  Endif
Else
  LEGISLATION=[F:FCY]LEG
Endif
#-----
End LEGISLATION


###########################################################################
# GETPFIACC Récupération comptes pour éléments facturation achat ventilés #
# ----------------------------------------------------------------------- #
# WVCRTYP : Type de document en cours de traitement                       #
#           3 = Commande                                                  #
#           5 = Commande ouverte                                          #
#           6 = Réception                                                 #
#           8 = Facture/Avoir                                             #
#                                                                         #
# WPFISEQ : Numéro d'ordre de l'élément ventilé (1 à 9)                   #
#                                                                         #
# WTYPACC : Type de compte à récupérer                                    #
#           1 = Compte général                                            #
#           2 = Nature analytique                                         #
#           3 = Compte IAS                                                #
#           4 ... jusqu'à 10                                              #
###########################################################################
Funprog GETPFIACC(WVCRTYP,WPFISEQ,WTYPACC)
Value Integer WVCRTYP
Value Integer WPFISEQ
Value Integer WTYPACC
#-----
Local Char    WVCRNUM(GLONVCR)
Local Integer WVCRSEQ
Local Integer WINVDTA
Local Char    WCOMPTE(GLONGAC)
#-----
If !clalev([F:PVF])  Local File PVCRFOOT  [PVF] : Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#----- Réajustement des paramètres par sécurité -----#
If WPFISEQ<1  WPFISEQ=1  : Endif
If WPFISEQ>9  WPFISEQ=9  : Endif
If WTYPACC<1  WTYPACC=1  : Endif
If WTYPACC>10 WTYPACC=10 : Endif
#-----
Case WVCRTYP
  When 3,5
    #----- Commandes -----#
    WVCRNUM=[F:TB0]POHNUM
    WINVDTA=[F:TB0]INVDTALIN2(WPFISEQ-1)
  When 6
    #----- Réceptions -----#
    WVCRNUM=[F:TB0]PTHNUM
    WINVDTA=[F:TB0]INVDTALIN2(WPFISEQ-1)
  When Default
    #----- factures/Avoirs -----#
    WVCRNUM=[F:TB0]NUM
    WINVDTA=[F:TB0]INVDTALIN2(WPFISEQ-1)
Endcase
#----- Recherche du numéro de ligne de l'élément de facturation -----#
Raz [F:PVF]
For [PVF] PVF0 Where VCRNUM=WVCRNUM & VCRTYP=WVCRTYP & INVDTA=WINVDTA
  WVCRSEQ=[F:PVF]IND : Break
Next
#----- Lecture de la table des lignes comptables analytiques -----#
Read [CAL] CAL0="PVF";WVCRTYP;WVCRNUM;0;WVCRSEQ;"";1
If fstat  Raz [F:CAL] : Endif
WCOMPTE=[F:CAL]ACC(WTYPACC-1)
#-----
End WCOMPTE


###########################################################################
# GETSFIACC Récupération comptes pour éléments facturation vente ventilés #
# ----------------------------------------------------------------------- #
# WVCRTYP : Type de document en cours de traitement                       #
#           1 = Devis                                                     #
#           2 = Livraison                                                 #
#           4 = Facture/Avoir                                             #
#          20 = Commande                                                  #
#                                                                         #
# WSFISEQ : Numéro d'ordre de l'élément ventilé (1 à 9)                   #
#                                                                         #
# WTYPACC : Type de compte à récupérer                                    #
#           1 = Compte général                                            #
#           2 = Nature analytique                                         #
#           3 = Compte IAS                                                #
#           4 ... jusqu'à 10                                              #
###########################################################################
Funprog GETSFIACC(WVCRTYP,WSFISEQ,WTYPACC)
Value Integer WVCRTYP
Value Integer WSFISEQ
Value Integer WTYPACC
#-----
Local Char    WVCRNUM(GLONVCR)
Local Integer WVCRSEQ
Local Char    WCOMPTE(GLONGAC)
#-----
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#----- Réajustement des paramètres par sécurité -----#
If WSFISEQ<1  WSFISEQ=1  : Endif
If WSFISEQ>9  WSFISEQ=9  : Endif
If WTYPACC<1  WTYPACC=1  : Endif
If WTYPACC>10 WTYPACC=10 : Endif
#-----
Case WVCRTYP
  When 1
    #----- Devis -----#
    WVCRNUM=[F:TB1]SQHNUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
  When 2
    #----- Livraisons -----#
    WVCRNUM=[F:TB1]SDHNUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
  When 20
    #----- Commandes -----#
    WVCRNUM=[F:TB1]SOHNUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
  When Default
    #----- factures/Avoirs -----#
    WVCRNUM=[F:TB1]NUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
Endcase
#----- Lecture de la table des lignes comptables analytiques -----#
Read [CAL] CAL0="SVF";WVCRTYP;WVCRNUM;0;WVCRSEQ;"";1
If fstat  Raz [F:CAL] : Endif
WCOMPTE=[F:CAL]ACC(WTYPACC-1)
#-----
End WCOMPTE


#########################################################
# GETNBRPOH Récupération du nombre de commandes d'achat #
#########################################################
Funprog GETNBRPOH(WBPSNUM,WDATMIN,WDATMAX)
Value    Char    WBPSNUM
Value    Date    WDATMIN
Value    Date    WDATMAX
#-----
Local Integer WNBRPOH
Local Char    WCRIT(100)
#-----
If WBPSNUM<>"" & WDATMIN<>[0/0/0] & WDATMAX<>[0/0/0]
  WCRIT="BPSNUM=WBPSNUM & ORDDAT>=WDATMIN & ORDDAT<=WDATMAX"
Elsif WBPSNUM<>"" & WDATMIN<>[0/0/0]
  WCRIT="BPSNUM=WBPSNUM & ORDDAT>=WDATMIN"
Elsif WBPSNUM<>"" & WDATMAX<>[0/0/0]
  WCRIT="BPSNUM=WBPSNUM & ORDDAT<=WDATMAX"
Elsif WBPSNUM<>""
  WCRIT="BPSNUM=WBPSNUM"
Elsif WDATMIN<>[0/0/0] & WDATMAX<>[0/0/0]
  WCRIT="ORDDAT>=WDATMIN & ORDDAT<=WDATMAX"
Elsif WDATMIN<>[0/0/0]
  WCRIT="ORDDAT>=WDATMIN"
Elsif WDATMAX<>[0/0/0]
  WCRIT="ORDDAT<=WDATMAX"
Else
  WCRIT="1=1"
Endif
Local File PORDER [POH] Where evalue(WCRIT) & APPFLG>2
WNBRPOH=rowcount([POH])
Close Local File [POH]
#-----
End WNBRPOH


############################################################
# GETINVBPS Récupération du total facturé d'un fournisseur #
############################################################
Funprog GETINVBPS(WBPSNUM,WDATMIN,WDATMAX)
Value    Char    WBPSNUM
Value    Date    WDATMIN
Value    Date    WDATMAX
#-----
Local    Decimal WTOTINV
Local    Decimal WMT, WMT2
Local    Char    WSITE(GLONFCY)
Local    Char    WCRIT(100)
Local    Integer WRET
#-----
If !clalev([F:FCY])  Local File FACILITY  [FCY] : Endif
If !clalev([F:PIH])  Local File PINVOICE  [PIH] : Endif
#----- Récupération site par défaut, société et devise société -----#
WSITE=GFCYDEF(6)
Call GETFCYDEF(WSITE,"[F:FCY]PURFLG=2") From TRTX3
Call GETDEV(WSITE) From DEVSUB
#-----
WCRIT="1=1"
If WBPSNUM<>""       WCRIT-="& BPR=WBPSNUM"     : Endif
If WDATMIN<>[0/0/0]  WCRIT-="& ACCDAT>=WDATMIN" : Endif
If WDATMAX<>[0/0/0]  WCRIT-="& ACCDAT<=WDATMAX" : Endif
Raz WTOTINV
#-----
For [PIH] PIH1 Where evalue(WCRIT) & STA=3
  If [F:PIH]CUR=GLOCALDEV
    WMT=[F:PIH]AMTNOT*(3-(2*[F:PIH]INVTYP))
  Elsif [F:PIH]CPY=GSOCIETE
    WMT=[F:PIH]AMTNOTL*(3-(2*[F:PIH]INVTYP))
  Else
    WMT=[F:PIH]AMTNOT*(3-(2*[F:PIH]INVTYP))
    Call CONVERT([F:PIH]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                WMT,WMT2,WRET) From TRTDEV
    If WRET  Raz WMT2 : Endif
    WMT=WMT2
  Endif
  WTOTINV+=WMT
Next
#-----
End WTOTINV


###########################################################################
# GETAVEPOH Récupération montant moyen d'une commande chez le fournisseur #
###########################################################################
Funprog GETAVEPOH(WBPSNUM,WDATMIN,WDATMAX)
Value    Char    WBPSNUM
Value    Date    WDATMIN
Value    Date    WDATMAX
#-----
Local    Decimal WAVEAMT
Local    Decimal WCUMPOH, WMT
Local    Char    WSITE(GLONFCY)
Local    Char    WCRIT(100)
Local    Integer WNBRPOH, WRET
#-----
If !clalev([F:FCY])  Local File FACILITY  [FCY] : Endif
If !clalev([F:POH])  Local File PORDER    [POH] : Endif
#----- Récupération site par défaut, société et devise société -----#
WSITE=GFCYDEF(6)
Call GETFCYDEF(WSITE,"[F:FCY]PURFLG=2") From TRTX3
Call GETDEV(WSITE) From DEVSUB
#-----
WCRIT="1=1"
If WBPSNUM<>""       WCRIT-="& BPSNUM=WBPSNUM"  : Endif
If WDATMIN<>[0/0/0]  WCRIT-="& ORDDAT>=WDATMIN" : Endif
If WDATMAX<>[0/0/0]  WCRIT-="& ORDDAT<=WDATMAX" : Endif
Raz WCUMPOH, WNBRPOH
#-----
For [POH] POH1 Where evalue(WCRIT) & APPFLG>2
  If [F:POH]CUR=GLOCALDEV
    WMT=[F:POH]TOTORD
  Elsif [F:POH]CPY=GSOCIETE
    WMT=[F:POH]TOTORDL
  Else
    Call CONVERT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                [F:POH]TOTORD,WMT,WRET) From TRTDEV
    If WRET  Raz WMT : Endif
  Endif
  WCUMPOH+=WMT
  WNBRPOH+=1
Next
If WNBRPOH=0 : End WAVEAMT : Endif              # netvibes
WAVEAMT=WCUMPOH/WNBRPOH
Call ARRDEV(WAVEAMT,GLOCALDEV) From TRTDIV
#-----
End WAVEAMT

###########################################################################
# GETIMGITM Récupération image article                                    #
###########################################################################
Funprog GETIMGITM(WITMREF)
Value   Char     WITMREF
#-----
Local   Blbfile WIMGITM
#-----
If !clalev([F:CBB])  Local File CBLOB  [CBB] : Endif
#----- Récupération image article  -----#
Read [CBB]CBB0="ITM";WITMREF;""
If !fstat
   WIMGITM = [F:CBB]BLOB
Endif
#-----
End WIMGITM


############################################################
# GETCONSOM Consommation des 4 dernieres semaines          #
############################################################
Funprog GETCONSOM(WITMREF,WDATMIN,WDATMAX)
Value    Char    WITMREF
Value    Date    WDATMIN
Value    Date    WDATMAX
#-----
Local    Decimal WCONSOM
Local    Decimal WMT, WMT2
Local    Char    WSITE(GLONFCY)
Local    Char    WCRIT(250)
Local    Integer WRET
#-----
If !clalev([F:STJ])  Local File STOJOU  [STJ] : Endif
WSITE=GFCYDEF(7)
#-----
WCRIT="1=1"
If WITMREF<>""       WCRIT-="& ITMREF=WITMREF"  : Endif
If WDATMIN<>[0/0/0]  WCRIT-="& IPTDAT>=WDATMIN" : Endif
If WDATMAX<>[0/0/0]  WCRIT-="& IPTDAT<=WDATMAX" : Endif
Raz WCONSOM
#-----
Filter [STJ] Where evalue(WCRIT) & UPDCOD=2 & REGFLG <> 2 & (TRSTYP = 4 | TRSTYP = 6)
&            Order By Key STJ2
   For [STJ]
   # Alimentation en positif de la quantité à traiter
       WCONSOM += abs([F:STJ]QTYSTU)
   Next
Filter
#-----
End WCONSOM


########################################
Subprog CTRL_TABLEAU_SAISI(SZCODMSK, SZCODZON)
Value Char SZCODMSK
Value Char SZCODZON

Local Integer INUMBLOC
Local Integer ITBSAISISSABLE

  # FGR 09/10/2009 : X3SUIVI57805
  If GUSRACS <> 2 and inpmode = 2 Then
    If clalev([F:AMZZ])=0 : Local File AMSKZON [AMZZ] : Endif
    If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
    Raz [F:ACC]
    Read [AMZZ]CODE=SZCODMSK;SZCODZON
    INUMBLOC = [F:AMZZ]NUMBLOC
    ITBSAISISSABLE = 1
    # Tous les champs du bloc tableau, saisissable et ayant un code d'accès
    Filter [AMZZ] Where CODMSK = SZCODMSK and CODZON <> SZCODZON and NUMBLOC = INUMBLOC and SAIAFF = 1
    For [AMZZ]
      If [F:AMZZ]CODACC = "" Then
        # Il y en a au moins un sans code d'accès. Il sera saisissable. Il n'y aura pas de problème
        ITBSAISISSABLE = 1
        Break
      Else
        # On regarde si on a les droits avec le code d'accès.
        If [F:ACC]CODACC <> [F:AMZZ]CODACC Then
          Read [ACC]CODACC=GUSER;[F:AMZZ]CODACC
          If fstat Then
            ITBSAISISSABLE = 0
          Endif
        Endif
        If [F:ACC]MODIF <> 2 Then
          ITBSAISISSABLE = 0
        Else
          ITBSAISISSABLE = 1
        Endif
      Endif
    Next
    Filter [AMZZ]
    If ITBSAISISSABLE = 0 Then
      # Si ça vaut 0, c'est que par rapport au code d'accès rien n'est saisissable pour cet utilisateur
      mkstat = 2
      End
    Endif
  Endif
End

# FQ 63906 GA 05/2010 avec script de test ZGA_MFGLOCK
####################################################################
# CHECK_LOCK: Vérifie si un enregistrement d'une table est déjà locké
#               - par un autre process
#               - automatiquement par la gestion objet X3
####################################################################
# Paramètres E : PTABLE     = Table
#                PCLE       = Cle
#                PLOCK      = mettre à 1 pour locker sinon 0
#                PDEJAOK    = renvoie 1 si lock posé, 2 s'il etait déjà ok
# Code retour  : 2 si locké par ailleurs, 1 en cas d'erreur de lock, 0 sinon
####################################################################
Funprog CHECK_LOCK(PTABLE,PCLE, PLOCK, PDEJAOK )
Value    Char    PTABLE
Value    Char    PCLE
Value    Integer PLOCK
Variable Integer PDEJAOK

If clalev([F:ALK])  =0 : Local File APLLCK    [ALK]         : Endif

If PTABLE="" | PCLE="" End 0 Endif
Read [ALK]LCKCLE=PTABLE+PCLE;0
If fstat
# on peut locker si nécessaire
  PDEJAOK = 1
  If PLOCK
      Lock = PTABLE+PCLE With lockwait = 0
      If fstat End 1 Endif
  Endif
Else
# déjà locké
  PDEJAOK = 2
  If [F:ALK]LCKPID <> adxuid(2) End 2 Endif
Endif

End 0

#########################################################
# GETNBRSOH     Nombre de commandes clients par période #
#########################################################
Funprog GETNBRSOH(WBPC,WDATMIN,WDATMAX)
Value    Char    WBPC
Value    Date    WDATMIN
Value    Date    WDATMAX

Local Integer WNBRSOH
Local Char    WCRIT(100)

If WBPC<>"" & WDATMIN<>[0/0/0] & WDATMAX<>[0/0/0]
  WCRIT="BPCORD=WBPC & ORDDAT>=WDATMIN & ORDDAT<=WDATMAX"
Elsif WBPC<>"" & WDATMIN<>[0/0/0]
  WCRIT="BPCORD=WBPC & ORDDAT>=WDATMIN"
Elsif WBPC<>"" & WDATMAX<>[0/0/0]
  WCRIT="BPCORD=WBPC & ORDDAT<=WDATMAX"
Elsif WBPC<>""
  WCRIT="BPCORD=WBPC"
Elsif WDATMIN<>[0/0/0] & WDATMAX<>[0/0/0]
  WCRIT="ORDDAT>=WDATMIN & ORDDAT<=WDATMAX"
Elsif WDATMIN<>[0/0/0]
  WCRIT="ORDDAT>=WDATMIN"
Elsif WDATMAX<>[0/0/0]
  WCRIT="ORDDAT<=WDATMAX"
Else
  WCRIT="1=1"
Endif
Local File SORDER [SOH] Where evalue(WCRIT)
WNBRSOH=rowcount([SOH])
Close Local File [SOH]

End WNBRSOH

#########################################################
# GETCABPC         Chiffre d'affaire client par période #
#########################################################
Funprog GETCABPC(WBPC,WDATMIN,WDATMAX)
Value    Char    WBPC
Value    Date    WDATMIN
Value    Date    WDATMAX

Local    Decimal WTOTINV
Local    Decimal WMT, WMT2
Local    Char    WSITE(GLONFCY)
Local    Char    WCRIT(100)
Local    Integer WRET

If !clalev([F:FCY])  Local File FACILITY  [FCY] : Endif
If !clalev([F:SIH])  Local File SINVOICE  [SIH] : Endif
# Récupération site par défaut, société et devise société
WSITE=GFCYDEF(5)
Call GETFCYDEF(WSITE,"[F:FCY]SALFLG=2") From TRTX3
Call GETDEV(WSITE) From DEVSUB

If WBPC<>"" & WDATMIN<>[0/0/0] & WDATMAX<>[0/0/0]
  WCRIT="BPR=WBPC & ACCDAT>=WDATMIN & ACCDAT<=WDATMAX"
Elsif WBPC<>"" & WDATMIN<>[0/0/0]
  WCRIT="BPR=WBPC & ACCDAT>=WDATMIN"
Elsif WBPC<>"" & WDATMAX<>[0/0/0]
  WCRIT="BPR=WBPC & ACCDAT<=WDATMAX"
Elsif WBPC<>""
  WCRIT="BPR=WBPC"
Elsif WDATMIN<>[0/0/0] & WDATMAX<>[0/0/0]
  WCRIT="ACCDAT>=WDATMIN & ACCDAT<=WDATMAX"
Elsif WDATMIN<>[0/0/0]
  WCRIT="ACCDAT>=WDATMIN"
Elsif WDATMAX<>[0/0/0]
  WCRIT="ACCDAT<=WDATMAX"
Else
  WCRIT="1=1"
Endif

Raz WTOTINV

For [SIH]SIH1 Where evalue(WCRIT) & STA=3 & [F:SIH]INVTYP<3
  If [F:SIH]CUR=GLOCALDEV
    WMT=[F:SIH]AMTNOT*(3-(2*[F:SIH]INVTYP))
  Elsif [F:SIH]CPY=GSOCIETE
    WMT=[F:SIH]AMTNOTL*(3-(2*[F:SIH]INVTYP))
  Else
    WMT=[F:SIH]AMTNOT*(3-(2*[F:SIH]INVTYP))
    Call CONVERT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,
&                WMT,WMT2,WRET) From TRTDEV
    If WRET  Raz WMT2 : Endif
    WMT=WMT2
  Endif
  WTOTINV+=WMT
Next

End WTOTINV


#########################################################################
# GETCOLDIE Récupération de l'intitulé colonne d'un code axe analytique #
#########################################################################
Funprog GETCOLDIE(WDIE)
Value    Char    WDIE    : # Code axe analytique
#-----
Local Char WCOLDIE(20)
#-----
Call LECTEXTRA(WCOLDIE,"GDIE","COLHEA",WDIE,"") From ATEXTRA
#-----
End WCOLDIE

# 95842
############################################################################
# GETSFIVAT Récupération code taxe des éléments facturation vente ventilés #
# ------------------------------------------------------------------------ #
# WVCRTYP : Type de document en cours de traitement                        #
#           1 = Devis                                                      #
#           2 = Livraison                                                  #
#           4 = Facture/Avoir                                              #
#          20 = Commande                                                   #
#                                                                          #
# WSFISEQ : Numéro d'ordre de l'élément ventilé (1 à 9)                    #
#                                                                          #
############################################################################
Funprog GETSFIVAT(WVCRTYP,WSFISEQ)
Value Integer WVCRTYP
Value Integer WSFISEQ
#-----
Local Char    WVCRNUM(GLONVCR)
Local Integer WVCRSEQ
Local Char    WDTAVAT(GLONVAT)
#-----
If !clalev([F:SFI])  Local File SFOOTINV [SFI] : Endif
If !clalev([F:SVF])  Local File SVCRFOOT [SVF] : Endif
#----- Réajustement des paramètres par sécurité -----#
If WSFISEQ<1  WSFISEQ=1  : Endif
If WSFISEQ>9  WSFISEQ=9  : Endif
#-----
Case WVCRTYP
  When 1
    #----- Devis -----#
    WVCRNUM=[F:TB1]SQHNUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
  When 2
    #----- Livraisons -----#
    WVCRNUM=[F:TB1]SDHNUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
  When 20
    #----- Commandes -----#
    WVCRNUM=[F:TB1]SOHNUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
  When Default
    #----- factures/Avoirs -----#
    WVCRNUM=[F:TB1]NUM
    WVCRSEQ=[F:TB1]DDTANUM(WSFISEQ-1)
Endcase
#----- Lecture de l'élément de facturation pour connaître sa règle de taxe -----#
Read [SFI] SFI0=WVCRSEQ
If fstat  Raz [F:SFI] : Endif
If [F:SFI]VATRUL = 1
    # Elt en taux produit : Plusieurs taxes dans SVCRFOOT
    # --> Code taxe = Code taxe de la ligne sur laquelle l'élt est ventilé
    WDTAVAT=[F:TB1]VAT(0)
Else
    # Elt en taux fixe    : Une seule taxe dans SVCRFOOT
    # --> Code taxe = Code taxe présent dans SVCRFOOT
    Read [SVF] SVF0=WVCRNUM;WVCRTYP;WVCRSEQ
    If fstat  Raz [F:SVF] : Endif
    WDTAVAT=[F:SVF]DTAVAT(0)
Endif
#-----
End WDTAVAT
# 95842

#MAE, bug 95318
###############################################################################
# GETPFIVAT Récupération codes taxes pour éléments facturation achat ventilés #
# -----------------------------------------------------------------------     #
# WVCRTYP : Type de document en cours de traitement                           #
#           3 = Commande                                                      #
#           5 = Commande ouverte                                              #
#           6 = Réception                                                     #
#           8 = Facture/Avoir                                                 #
#                                                                             #
# WPFISEQ : Numéro d'ordre de l'élément ventilé (1 à 9)                       #
#                                                                             #
###############################################################################
Funprog GETPFIVAT(WVCRTYP,WPFISEQ)
Value Integer WVCRTYP
Value Integer WPFISEQ
#-----
Local Char    WVCRNUM(GLONVCR)
Local Integer WINVDTA
Local Char    WDTAVAT(GLONVAT)
#-----
If !clalev([F:PVF])  Local File PVCRFOOT  [PVF] : Endif
#----- Réajustement des paramètres par sécurité -----#
If WPFISEQ<1  WPFISEQ=1  : Endif
If WPFISEQ>9  WPFISEQ=9  : Endif

#-----
Case WVCRTYP
  When 3,5
    #----- Commandes -----#
    WVCRNUM=[F:TB0]POHNUM
    WINVDTA=[F:TB0]INVDTALIN2(WPFISEQ-1)
  When 6
    #----- Réceptions -----#
    WVCRNUM=[F:TB0]PTHNUM
    WINVDTA=[F:TB0]INVDTALIN2(WPFISEQ-1)
  When Default
    #----- factures/Avoirs -----#
    WVCRNUM=[F:TB0]NUM
    WINVDTA=[F:TB0]INVDTALIN2(WPFISEQ-1)
Endcase
#----- Recherche du numéro de ligne de l'élément de facturation -----#
#----- Lecture de l'élément de facturation pour connaître sa règle de taxe -----#
Read [PFI] PFI0=WINVDTA
If fstat  Raz [F:PFI] : Endif
If [F:PFI]VATRUL = 1
    # Elt en taux produit : Plusieurs taxes dans PVCRFOOT
    # --> Code taxe = Code taxe de la ligne sur laquelle l'élt est ventilé
    WDTAVAT=[F:TB1]VAT(0)
Else
    # Elt en taux fixe    : Une seule taxe dans PVCRFOOT
    # --> Code taxe = Code taxe présent dans PVCRFOOT
    Raz [F:PVF]
    For [PVF] PVF0 Where VCRNUM=WVCRNUM & VCRTYP=WVCRTYP & INVDTA=WINVDTA
      WDTAVAT=[F:PVF]INVDTAVAT : Break
    Next
Endif
#-----
End WDTAVAT
#fin 95318

#**<br/>----------------------------------------------------------------<br/>
#* @param PFLD = Name field ex: "[M]ECCVALMAJ"
#* @return char value of the field<br>
#*         "" if the field doesn't exist
#**<br/>----------------------------------------------------------------
#*!
# useful to pass parameter value with a field which has activity code
Funprog VALFLD_C(PFLD)
Value Char PFLD
If evalue("dim("+PFLD+")")>0
    End num$(evalue(PFLD))
Endif
End ""

#**<br/>----------------------------------------------------------------<br/>
#* @param PFLD = Name field ex: "[M]NBSLO"
#* @return numeric value of the field<br>
#*         0 if the field doesn't exist
#**<br/>----------------------------------------------------------------
#*!
# useful to pass parameter value with a field which has activity code
Funprog VALFLD_N(PFLD)
Value Char PFLD
If evalue("dim("+PFLD+")")>0
    End val(evalue(PFLD))
Endif
End 0

#**<br/>----------------------------------------------------------------<br/>
#* @param PFLD = Name field ex: "[M]PER"
#* @return date value of the field<br>
#*         [0/0/0] if the field doesn't exist
#**<br/>----------------------------------------------------------------
#*!
# useful to pass parameter value with a field which has activity code
Funprog VALFLD_D(PFLD)
Value Char PFLD
If evalue("dim("+PFLD+")")>0
    End evalue(PFLD)
Endif
End [0/0/0]

#**<br/>----------------------------------------------------------------<br/>
#* @param ITM  = Product
#* @param VMAJ = Major version
#* @param VMIN = Minor version
#* @return pending Change Request ID for a product and version
#**<br/>----------------------------------------------------------------
#*!
Funprog CCMID(ITM,VMAJ,VMIN)
Value Char ITM(), VMAJ(), VMIN()

If ITM="" : End "" : Endif

Local Integer OK
Local Char    CRID(GLONCCMCRID)
Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
OK = fmet CHANGE_REQUEST.CHECK_ACTIVE_CHGREQ_EXISTS(ITM,VMAJ,VMIN,CRID)
FreeGroup CHANGE_REQUEST
End CRID

