#<AdxTL>@(#)3.0.0.0 $Revision$
#############################################################################
# TRTX3FNC           Traitement des fonctions X3        Module Tronc commun #
# ------------------------------------------------------------------------- #
# CNVAMT    : Conversion d'un montant dans une devise                       #
# CNVCPY    : Conversion d'un montant dans la devise de la société          #
# BPRNAM    : Récupération raison sociale business partner                  #
# BPSNAM    : Récupération raison sociale fournisseur                       #
# BPCNAM    : Récupération raison sociale client                            #
# GETCRYDATA: Récupération Langue et devise d'un pays                       #
# GETFMTREM : Récupération du format des remises                            #
# GETPIVTYP : Récupération du type de facture achats                        #
# CTLFCY    : Vérifie si le site est autorisé pour un utilisateur           #
# GETCPY    : Récupération de la société d'un site                          #
# GETCRY    : Récupération du pays d'un site ou d'une société               #
# GETLEG    : Récupération de la législation d'un site ou d'une société     #
# GETPFIACC : Récupération comptes pour éléments facturation achat ventilés #
# GETSFIACC : Récupération comptes pour éléments facturation vente ventilés #
# GETNBRPOH : Récupération nombre de commandes fournisseur / période        #
# GETINVBPS : Récupération Total facturé fournisseur / période              #
# GETAVEPOH : Récupération montant moyen par commande fournisseur           #
# GETIMGITM : Récupération image article                                    #
# GETCONSOM : Consommation des 4 dernieres semaines                         #
# CHECK_LOCK: Contrôle présence d'un lock et ajout si nécessaire            #
# GETNBRSOH : Nombres de commandes clients / période                        #
# GETCABPC  : Chiffre d'affaire client / période                            #
# GETCOLDIE : Récupération de l'intitulé colonne d'un code axe analytique   #
# GETSFIVAT : Récupération code taxe pour élts facturation vente ventilés   # 95842
# GETPFIVAT RÉCUPÉRATION CODES TAXES POUR ÉLÉMENTS FACTURATION ACHAT VENTILÉ#
# VALFLD_C  : Get the value (string) of a field or "" if it doesn't exist   #
# CCMID     : Returns pending Change Request ID for a product and version   #
#############################################################################


##################################################
# CNVAMT Conversion d'un montant dans une devise #
# Amount conversion                              #
##################################################
Funprog CNVAMT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
#-----
Local    Decimal MTDES            : # Montant destination
Local    Integer STAT             : # Status de retour (0=OK)
#-----
Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
If STAT  MTDES=MTORG : Endif
#-----
End MTDES


###############################################################
# CNVCPY Conversion d'un montant dans la devise de la société #
# Amount conversion to company currency                       #
###############################################################
Funprog CNVCPY(SITE,DEVORG,TYPCOURS,DATCOURS,MTORG)
Value    Char    SITE             : # Site
Value    Char    DEVORG           : # Devise d'origine
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
#-----
Local    Char    DEVSOC(GLONCUR)  : # Devise société
Local    Decimal MTDES            : # Montant destination
Local    Integer STAT             : # Status de retour (0=OK)
Local    Char    SAV_GLOCALDEV(GLONCUR)
#-----
SAV_GLOCALDEV=GLOCALDEV
Call GETDEV(SITE) From DEVSUB
#MAE, bg 74320, le 12/07/11
DEVSOC=GLOCALDEV
Call CONVERT(DEVORG,DEVSOC,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV
If STAT  MTDES=MTORG : Endif
GLOCALDEV=SAV_GLOCALDEV
#-----
End MTDES


#######################################################
# BPRNAM Récupération raison sociale business partner #
# Business partner name                               #
#######################################################
Funprog BPRNAM(WBPRNUM)
Value    Char  WBPRNUM
#-----
Local    Char  WBPRNAM(GLONNAM)
#-----
If !clalev([F:BPR])  Local File BPARTNER [BPR] : Endif
If [F:BPR]BPRNUM<>WBPRNUM
  Read [BPR] BPR0=WBPRNUM : If fstat  Raz [F:BPR] : Endif
Endif
WBPRNAM=[F:BPR]BPRNAM
#-----
End WBPRNAM


