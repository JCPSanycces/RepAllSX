#<AdxTL>@(#)7.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

Raz GPILOBJ, GBIDC1, GBIDC2, GNAVIG, GNBMASKOUV
Call OBJET("MCH",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "DEBUT"       : Gosub DEBUT
Endcase
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
Local Char    CRITERE (250), CRITCTR (250)
Local Integer NBPCE, OKC, PAS, T, INTE
Local Integer NBES  : # 66650
Local Char    MATRI(GLONEML) , SYMBOLE(80), CTR(GLONHRCTR), OLDMATRI(GLONEML), OLDCTR(GLONHRCTR)
Local Integer FLGFIRST, SAVFLGFIRST, OKSIM
Local Char    CHREMP (15)(1..500) : # tableau des chronos salariés fictifs (entrants et remplaçants des sorties)
Local Date    DATMAT
Local Char    LESITE(GLONFCY) : #59323
Local Date    PERFIN : #76659

If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif : # Si [RUB] utilisé par rubrique traitement

## LIGHYPO indique si l'on exécute une paie d'une entrée, d'un remplaçant ou d'un salarié sélectionné car modif contrat
If dim(LIGHYPO)<0 : Global Integer LIGHYPO : Endif

## GIHYP=0 et 1 pour les codes budgétaires ATM & AIA. GIHYP=ligne de l'hypothèse+1
If dim(GIHYP)<0 : Global Integer GIHYP : Endif

## Indice 0 et 1 pour les codes budgétaires ATM & AIA. Indice suivant correspond à la ligne de l'hypothèse dans le tableau+1
If dim(GBUDHYP)<0 : Global Char GBUDHYP(GLONADI) (0..func AFNC.ACTIV('MCH')+1) : Endif

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#If clalev([F:HRPEO])=0 : Local File HRPERIOD   [HRPEO] : Endif
#**
#*!
If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
#LIPET - 2017-05-20 - END
Gosub OUVFIC From ="WPMS"+GCURLEG+"PLAN"

TIT = mess(9,10722,1)-[M:MCH0]COD :# "Calcul du scénario"

#57313
Local Integer  I
Local Char     FCYGRP(GLONFCY)(1..999)

#70018
Local Char CRITFCY(250)

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
#end 70018
Return

#######################################################
## Affichage
#######################################################
$DEBUT
Affzo [DIA]
Setmok [DIA] With 0

Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
TMP = 1
TRA = 1
Return

#######################################################
## Prise en compte des critères
#######################################################
$EXEC
# Ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# Verrou
SYMBOLE = "MCH"+[M:MCH0]COD+format$("D:"+GFMDAT4,[M:MCH1]STRDAT)+format$("D:"+GFMDAT4,[M:MCH1]ENDDAT)
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

LIGHYPO = 0
# Mise en place du filtre sur la table des salariés
CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGPAY=2 & [F:ID]FLGINT<>2"

If [M:MCH1]STRMAT<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:MCH1]STRMAT+'"'
Endif
If [M:MCH1]ENDMAT<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:MCH1]ENDMAT+'"'
Endif
# Filtre sur les contrats
CRITCTR = '[F:HRCTR]CTRDAT<=['+num$([M:MCH1]MTHREF)+'] & [F:HRCTR]STACTR=2'
CRITCTR -= '& ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=['+num$([M:MCH1]MTHREF)+'])'

#70018
# Filtre sur les sites
CRITFCY = "1=1"
If [M:MCH1]ALLFCY<>2
 CRITFCY = '[F:HRCTR]ETRFCY="'+[M:MCH1]FCY+'"' :# site
Elsif [M:MCH1]ALLCPY<>2  #société
 Read [CPY]CPY0=[M:MCH1]CPY
 If !fstat & [F:CPY]CPYLEGFLG=2    : # Société juridique
  CRITFCY = '[F:FCY]LEGCPY = "'+[M:MCH1]CPY+'"'
 Elsif !fstat & [F:CPY]CPYLEGFLG=1 : # Société non juridique
  I=1
  For [FGR]FGR0 Where CPY=[M:MCH1]CPY
   If !find([F:FGR]FCY,FCYGRP(1..I))
    FCYGRP(I) = [F:FGR]FCY
    I +=1
   Endif
  Next
  If I>1
   CRITFCY = 'find([F:HRCTR]ETRFCY, FCYGRP(1..'+num$(I-1)+'))'
  Endif
 Endif
Endif
#end 70018

If [M:MCH1]ALLSRV<>2
 CRITCTR -= '& [F:HRCTR]ETRSRV="'+[M:MCH1]SRV+'"' :# service
Endif
If [M:MCH1]ALLPRF<>2
 CRITCTR -= '& [F:HRCTR]PROPRF="'+[M:MCH1]PRF+'"' :# profil
Endif
#70009
If [M:MCH1]ALLJOBPOT<>2
  CRITCTR -= '& [F:HRCTR]JOBPOT="'+[M:MCH1]JOBPOT+'"' :# emploi type
Endif
If [M:MCH1]ALLPOT<>2
  CRITCTR -= '& [F:HRCTR]POT="'+[M:MCH1]POT+'"' :# poste
Endif

#End 70009

If [M:MCH1]POP<>""
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [HRPOA]POA0 = [M:MCH1]POP;[F:HRCTR]REFNUM
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITCTR) & evalue(CRITFCY) & [F:HRPOA]REFNUM<>""
Else
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITCTR) & evalue(CRITFCY)
Endif

Call TEMPON (mess(29,10722,1)) From GESECRAN : # Initialisation du calcul

# Effacement de l'historique MS
Call DEBTRANS From GLOCK
Gosub TR_EFFACE
If GOK<=0 : Return : Endif

Call TEMPON (mess(30,10722,1)) From GESECRAN : # Calcul des hypothèses

# Calcul simulation
Call DEBTRANS From GLOCK
Gosub TR1

Call TEMPON (mess(31,10722,1)) From GESECRAN : # Calcul des hypothèses d'entrée et de remplacement

If GOK>=1  & [M:MCH1]NBLIG>0 :#74219 not useless to call TR2 if there is none hypothesis line
 # Calcul simulation salarié entrant ou remplaçant
 Call DEBTRANS From GLOCK
 Gosub TR2
Endif

If GOK=1
 If !NBPCE
  #Aucun matricule à traiter
  Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN
 Else
  #Opération réalisée"
  Call ECR_TRACE(mess(29,9003,1),0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_MAJSTA
 Endif
Endif

Unlock =SYMBOLE

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

If dim(LIGHYPO)>0 : Kill LIGHYPO : Endif
Return

###########################
$TR_EFFACE
GOK = 1
Trbegin [MHS],[MHA],[MHH]
 # BUD<>"" contient les simulations
 # BUD="" contient l'historique de paie
 #Delete [MHS] Where COD=[F:MCH]COD & BUD<>""
Delete [MHS] Where COD=[F:MCH]COD & SIM = 2
 If fstat=1 | fstat>5
  GOK=-1 : Goto ROLL_TR_EFFACE
 Endif

# Delete [MHA] Where COD=[F:MCH]COD & BUD<>""
 Delete [MHA] Where COD=[F:MCH]COD
 If fstat=1 | fstat>5
  GOK=-1 : Goto ROLL_TR_EFFACE
 Endif

 Delete [MHH] Where COD=[F:MCH]COD
 If fstat=1 | fstat>5
  GOK=-1 : Goto ROLL_TR_EFFACE
 Endif

Commit
Return

###########################
$ROLL_TR_EFFACE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EFFACE: Endif

###########################
$TR1
GOK = 1
#Comments because gives errors
#Call OUVRE_BOITE("Simulation paie de la période...",0) From GESECRAN
#Call SET_BOITE("Simulation paie de la période...",rowcount([LNK])) From GESECRAN

T=0
Trbegin [MHS]
 For [LNK]
  MATRI  = [F:HRCTR]REFNUM
  CTR    = [F:HRCTR]CTRNUM
  DATMAT = [M:MCH1]MTHREF
  Raz CHREMP
  If OLDMATRI<>MATRI | OLDCTR<>CTR
   OLDMATRI = MATRI
   OLDCTR   = CTR
   FLGFIRST = 1
  Else
   FLGFIRST = 0
  Endif
  Gosub LECEMP From WPDEFTABLE
  Call CONTROLE(MATRI,DATMAT,CTR,[M:MCH1]CRI,OKC,1) From DIVPAYE

  If OKC
   T+=1
   #Call AFF_BOITE(MATRI-CTR,T,INTE) From GESECRAN
   TROUVE=0
   # On cherche les périodes de paie sur l'année de simulation
   #59323
   LESITE = [F:HRCTR]ETRFCY
   #LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#   Call PERIO(LESITE,MATRI) From SUBHRPEO
#   Filter [HRPEO] Where PYRDAT>=[M:MCH1]STRDAT & PYRDAT<=[M:MCH1]ENDDAT & FCY=LESITE
#   Look[F:HRPEO]First
#   If fstat
#    Filter [HRPEO] Where PYRDAT>=[M:MCH1]STRDAT & PYRDAT<=[M:MCH1]ENDDAT & FCY=""
#   Endif
#
#   # Simulation
#   For [HRPEO]
#    #77469
#    # on vide la date de sortie car on calcul les bulletins sur toute la période de simulation
#    # même si le contrat réel se termine après la date de référence du scénario.
#    Raz [F:HRCTR]XITDAT
#    #end 77469
#    TROUVE = 1
#    OKSIM  = 1
#    If [M:MCH1]TYPMCH=1
#     SAVFLGFIRST = FLGFIRST
#     # 0 = Scénario initial pas encore calculé alors on fait la simulation ATM
#     # 1 = Scénario initial pas encore calculé alors on fait la simulation AIA
#     For GIHYP=0 To 1
#      GBUDHYP(GIHYP) = [F:MCH]BUD(GIHYP)
#      PAS = -4   :# Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
#      FLGFIRST = SAVFLGFIRST : # Pour repositionner FLGFIRST après maj par PLANMS
#      Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,0,CHREMP,OKSIM) From GPLAN
#      If FLGFIRST=-1 : Break 2 : Endif
#      If GOK<=0 : Break 3 : Endif
#      If GIHYP=0 : Gosub LECEMP From WPDEFTABLE : Endif
#     Next
#    Elsif [M:MCH1]NBLIG>0
#     GIHYP = 2
#     PAS = -4   :# Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
#     Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,0,CHREMP,OKSIM) From GPLAN
#     If FLGFIRST=-1 : Break : Endif
#     If GOK<=0 : Break 2 : Endif
#    Endif
#    If OKSIM
#     Call ECR_TRACE(MATRI-"("+CTR+") :"-num$([F:HRPEO]PYRDAT),0) From GESECRAN
#     NBPCE += 1
#    Endif
#   Next
#**
#*!
   Call PERIO(LESITE,MATRI) From SUBHRPEO
   Filter [HRPEOD] Where PYRDAT>=[M:MCH1]STRDAT & PYRDAT<=[M:MCH1]ENDDAT & PERCOD=[F:HRCTR]PERCOD
   Look[F:HRPEOD]First
   If fstat
    Filter [HRPEOD] Where PYRDAT>=[M:MCH1]STRDAT & PYRDAT<=[M:MCH1]ENDDAT
   Endif

   # Simulation
   For [HRPEOD]
    #77469
    # on vide la date de sortie car on calcul les bulletins sur toute la période de simulation
    # même si le contrat réel se termine après la date de référence du scénario.
    Raz [F:HRCTR]XITDAT
    #end 77469
    TROUVE = 1
    OKSIM  = 1
    If [M:MCH1]TYPMCH=1
     SAVFLGFIRST = FLGFIRST
     # 0 = Scénario initial pas encore calculé alors on fait la simulation ATM
     # 1 = Scénario initial pas encore calculé alors on fait la simulation AIA
     For GIHYP=0 To 1
      GBUDHYP(GIHYP) = [F:MCH]BUD(GIHYP)
      PAS = -4   :# Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
      FLGFIRST = SAVFLGFIRST : # Pour repositionner FLGFIRST après maj par PLANMS
      Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,0,CHREMP,OKSIM) From GPLAN
      If FLGFIRST=-1 : Break 2 : Endif
      If GOK<=0 : Break 3 : Endif
      If GIHYP=0 : Gosub LECEMP From WPDEFTABLE : Endif
     Next
    Elsif [M:MCH1]NBLIG>0
     GIHYP = 2
     PAS = -4   :# Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
     Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,0,CHREMP,OKSIM) From GPLAN
     If FLGFIRST=-1 : Break : Endif
     If GOK<=0 : Break 2 : Endif
    Endif
    If OKSIM
     Call ECR_TRACE(MATRI-"("+CTR+") :"-num$([F:HRPEO]PYRDAT),0) From GESECRAN
     NBPCE += 1
    Endif
   Next

#LIPET - 2017-05-20 - END
   If !TROUVE
    #Pas de période d'extraction des temps
    Call ECR_TRACE([F:HRCTR]REFNUM-":"-mess(92,10703,1),0) From GESECRAN
   Endif
  Endif
 Next

 #82486 : Amélio des perfs
 If dim(GNBRCRB)>=0 : Call KILL_PROFIL(1) From GPLAN : Endif

 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR
 Endif

Commit
#Call FERME_BOITE From GESECRAN :Comments because gives errors
Return

###########################
$TR2
#74219
If [M:MCH1]NBLIG=0 : Return : Endif
Local Integer TBLNUMLIG(1..[M:MCH1]NBLIG)
Local Integer TBLNUMORD(1..[M:MCH1]NBLIG)
Local Integer NUMLIG

Call ORDERHYPO(TBLNUMLIG, TBLNUMORD) From SUBMCH
#end 74219
GOK = 1
Trbegin [MHS]
 # Simulation des hypothèses d'entrée salarié, de remplacement d'un salarié, et de modifs de contrat (pour les salariés
 # dont les modifs de contrats font qu'ils répondent désormais aux critères aux critères=> Pas dans boucle LNK)
 #74219
 #For LIGHYPO=1 To [M:MCH1]NBLIG
 For NUMLIG=1 To [M:MCH1]NBLIG
  LIGHYPO=TBLNUMLIG(NUMLIG)
  #end 74219
  If [M:MCH1]STAHYP(LIGHYPO-1)<>3
   FLGFIRST = 1 : OKSIM = 1
#   Raz CHREMP : IC=0    : # 66650
   IC=0
   Case [M:MCH1]TYPHYP(LIGHYPO-1)
    When 4 : # Entrée
     Filter [MHE] Where COD=[M:MCH1]CODHYP(LIGHYPO-1)
     For [MHE]
      MATRI  = [F:MHE]REFNUM
      CTR    = [F:MHE]CTRNUM
      TROUVE = 0
      DATMAT = [M:MCH1]MTHREF
      NBES   = [F:MHE]NBR : # 66650
      Gosub LECEMP From WPDEFTABLE
      Gosub LIRE_ENT From ='WPMS4'+[F:MHE]COD
      #57181
      #Gosub CTL_SALARIE
      Gosub CTL_SALARIE2
      If OKC
       IC = [F:MHE]NBR
       Gosub CHRONO_SALARIE
       If GOK<=0 : Break 2 : Endif
       #59323
       LESITE = [F:HRCTR]ETRFCY
       #LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#       Call PERIO(LESITE,MATRI) From SUBHRPEO
#       #fin 59323
#       If [M:MCH1]TYPMCH<>3
#        Filter [F:HRPEO] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0]) & FCY=LESITE
#&&      PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#       Else
#        Filter [F:HRPEO] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0]) & FCY=LESITE
#&&      PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#       Endif
#
#       Look[F:HRPEO]First
#
#       If fstat
#        If [M:MCH1]TYPMCH<>3
#         Filter [F:HRPEO] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0]) & FCY=""
#&&       PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#        Else
#         Filter [F:HRPEO] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0]) & FCY=""
#&&       PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#        Endif
#       Endif
#
#       For [HRPEO]
#        TROUVE=1
#        PAS = -4   :#Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
##        Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,[F:MHE]NBR,CHREMP,OKSIM) From GPLAN
#        Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,NBES,CHREMP,OKSIM) From GPLAN : # 66650
#        If FLGFIRST=-1 : Break : Endif
#        If GOK<=0 : Break 3 : Endif
#        If OKSIM=1
#         # Modèle
#         Call ECR_TRACE(mess(23,10722,1)-MATRI-"("+CTR+") :"-num$([F:HRPEO]PYRDAT),0) From GESECRAN
#         NBPCE += 1
#        Endif
#       Next
#       Filter [F:HRPEO]
#**
#*!

       Call PERIO(LESITE,MATRI) From SUBHRPEO
       #fin 59323
       If [M:MCH1]TYPMCH<>3
        Filter [F:HRPEOD] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0]) & PERCOD=[F:HRCTR]PERCOD
&&      PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
       Else
        Filter [F:HRPEOD] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0]) & PERCOD=[F:HRCTR]PERCOD
&&      PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
       Endif

       Look[F:HRPEOD]First

       If fstat
        If [M:MCH1]TYPMCH<>3
         Filter [F:HRPEOD] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0])
&&       PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
        Else
         Filter [F:HRPEOD] Where PYRDAT>=[F:MHE]ENTDAT & (PYRDAT<=[F:MHE]XITDAT | [F:MHE]XITDAT=[0/0/0])
&&       PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
        Endif
       Endif

       For [HRPEOD]
        TROUVE=1
        PAS = -4   :#Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
#        Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,[F:MHE]NBR,CHREMP,OKSIM) From GPLAN
        Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,NBES,CHREMP,OKSIM) From GPLAN : # 66650
        If FLGFIRST=-1 : Break : Endif
        If GOK<=0 : Break 3 : Endif
        If OKSIM=1
         # Modèle
         Call ECR_TRACE(mess(23,10722,1)-MATRI-"("+CTR+") :"-num$([F:HRPEOD]PYRDAT),0) From GESECRAN
         NBPCE += 1
        Endif
       Next
       Filter [F:HRPEOD]
#LIPET - 2017-05-20 - END
       If !TROUVE
        #Pas de période d'extraction des temps
        Call ECR_TRACE([F:HRCTR]REFNUM-":"-mess(92,10703,1),0) From GESECRAN
       Endif
      Endif
     Next
     Filter [MHE]

     #82486 : Amélio des perfs
     If dim(GNBRCRB)>=0 : Call KILL_PROFIL(1) From GPLAN : Endif


    When 5 : # Sortie
     Filter [MHX] Where COD=[M:MCH1]CODHYP(LIGHYPO-1) & DATRPL<>[0/0/0]
     For [MHX]
      MATRI  = [F:MHX]REFRPL
      CTR    = [F:MHX]CTRRPL
      TROUVE = 0
      DATMAT = [M:MCH1]MTHREF
      Gosub LECEMP From WPDEFTABLE
      Gosub LIRE_SOR From ='WPMS5'+[F:MHX]COD
      #57181
      #Gosub CTL_SALARIE
      Gosub CTL_SALARIE2
      If OKC
       IC = 1
       Gosub CHRONO_SALARIE
       If GOK<=0 : Break 2 : Endif
       LESITE = [F:HRCTR]ETRFCY
       #LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#       Call PERIO(LESITE,MATRI) From SUBHRPEO
#       If [M:MCH1]TYPMCH<>3
#        Filter [F:HRPEO] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0]) & FCY=LESITE
#&&      PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#       Else
#        Filter [F:HRPEO] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0]) & FCY=LESITE
#&&      PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#       Endif
#       Look[F:HRPEO]First
#       If fstat
#        If [M:MCH1]TYPMCH<>3
#         Filter [F:HRPEO] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0]) & FCY=""
#&&       PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#        Else
#         Filter [F:HRPEO] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0]) & FCY=""
#&&       PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
#        Endif
#       Endif
#
#       For [HRPEO]
#        TROUVE=1
#        PAS = -4   :#Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
#        Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,1,CHREMP,OKSIM) From GPLAN
#        If FLGFIRST=-1 : Break : Endif
#        If GOK<=0 : Break 3 : Endif
#        If OKSIM=1
#         # Modèle
#         Call ECR_TRACE(mess(23,10722,1)-MATRI-"("+CTR+") :"-num$([F:HRPEO]PYRDAT),0) From GESECRAN
#         NBPCE += 1
#        Endif
#       Next
#       Filter [F:HRPEO]
#**
#*!
       Call PERIO(LESITE,MATRI) From SUBHRPEO
       If [M:MCH1]TYPMCH<>3
        Filter [F:HRPEOD] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0]) & PERCOD=[F:HRCTR]PERCOD
&&      PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
       Else
        Filter [F:HRPEOD] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0]) & PERCOD=[F:HRCTR]PERCOD
&&      PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
       Endif
       Look[F:HRPEOD]First
       If fstat
        If [M:MCH1]TYPMCH<>3
         Filter [F:HRPEOD] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0])
&&       PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
        Else
         Filter [F:HRPEOD] Where PYRDAT>=[F:MHX]DATRPL & (PYRDAT<=[F:HRCTR]XITDAT | [F:HRCTR]XITDAT=[0/0/0])
&&       PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
        Endif
       Endif

       For [HRPEOD]
        TROUVE=1
        PAS = -4   :#Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
        Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,1,CHREMP,OKSIM) From GPLAN
        If FLGFIRST=-1 : Break : Endif
        If GOK<=0 : Break 3 : Endif
        If OKSIM=1
         # Modèle
         Call ECR_TRACE(mess(23,10722,1)-MATRI-"("+CTR+") :"-num$([F:HRPEOD]PYRDAT),0) From GESECRAN
         NBPCE += 1
        Endif
       Next
       Filter [F:HRPEOD]
#LIPET - 2017-05-20 - END
       If !TROUVE
        #Pas de période d'extraction des temps
        Call ECR_TRACE([F:HRCTR]REFNUM-":"-mess(92,10703,1),0) From GESECRAN
       Endif
      Endif
     Next
     Filter [MHX]

     #82486 : Amélio des perfs
     If dim(GNBRCRB)>=0 : Call KILL_PROFIL(1) From GPLAN : Endif

    When 6 : # Modif contrat
     Filter [MHC] Where COD=[M:MCH1]CODHYP(LIGHYPO-1)
     For [MHC]
      MATRI    = [F:MHC]REFNUM
      CTR      = [F:MHC]CTRNUM
      TROUVE   = 0
      DATMAT   = [M:MCH1]MTHREF
      Raz CHREMP  : # 66650
      Gosub LECEMP From WPDEFTABLE
      Gosub CTL_SALARIE
      If !OKC
       # !OKC => Salarié non déja simulé. On prend ses modifs de contrat pour voir s'il répond aux critères du scénario
       Gosub LECTURE From ="WPMS6"+[F:MHC]COD
       Gosub CTL_SALARIE
       If OKC
        LESITE = [F:HRCTR]ETRFCY
        #LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#        Call PERIO(LESITE,MATRI) From SUBHRPEO
#        If [M:MCH1]TYPMCH<>3
#         Filter [HRPEO] Where PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1) & FCY=LESITE
#        Else
#         Filter [HRPEO] Where PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1) & FCY=LESITE
#        Endif
#
#        Look[F:HRPEO]First
#
#        If fstat
#         If [M:MCH1]TYPMCH<>3
#          Filter [HRPEO] Where PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1) & FCY=""
#         Else
#          Filter [HRPEO] Where PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1) & FCY=""
#         Endif
#        Endif
#
#        For [HRPEO]
#         TROUVE=1
#         PAS = -4   :#Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
#         Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,0,CHREMP,OKSIM) From GPLAN
#         If FLGFIRST=-1 : Break : Endif
#         If GOK<=0 : Break 3 : Endif
#         If OKSIM=1
#          # Modèle
#          Call ECR_TRACE(mess(23,10722,1)-MATRI-"("+CTR+") :"-num$([F:HRPEO]PYRDAT),0) From GESECRAN
#          NBPCE += 1
#         Endif
#        Next
#        Filter [F:HRPEO]
#**
#*!
        Call PERIO(LESITE,MATRI) From SUBHRPEO
        If [M:MCH1]TYPMCH<>3
         Filter [HRPEOD] Where PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1) & PERCOD=[F:HRCTR]PERCOD
        Else
         Filter [HRPEOD] Where PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1) & PERCOD=[F:HRCTR]PERCOD
        Endif

        Look[F:HRPEOD]First

        If fstat
         If [M:MCH1]TYPMCH<>3
          Filter [HRPEOD] Where PYRDAT>=[M:MCH1]STRHYP(LIGHYPO-1) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
         Else
          Filter [HRPEOD] Where PYRDAT>=max([M:MCH1]STRHYP(LIGHYPO-1),[M:MCH1]DATREVBUD) & PYRDAT<=[M:MCH1]ENDHYP(LIGHYPO-1)
         Endif
        Endif

        For [HRPEOD]
         TROUVE=1
         PAS = -4   :#Obligé de le refaire à chaque passe car PAS vaut 0 en retour !!!
         Call PLANMS(FLGFIRST,[M:MCH1]TYPMCH,0,CHREMP,OKSIM) From GPLAN
         If FLGFIRST=-1 : Break : Endif
         If GOK<=0 : Break 3 : Endif
         If OKSIM=1
          # Modèle
          Call ECR_TRACE(mess(23,10722,1)-MATRI-"("+CTR+") :"-num$([F:HRPEOD]PYRDAT),0) From GESECRAN
          NBPCE += 1
         Endif
        Next
        Filter [F:HRPEOD]
        #LIPET - 2017-05-20 - END
        If !TROUVE
         #Pas de période d'extraction des temps
         Call ECR_TRACE([F:HRCTR]REFNUM-":"-mess(92,10703,1),0) From GESECRAN
        Endif
       Endif
      Endif
     Next
     Filter [MHC]

     #82486 : Amélio des perfs
     If dim(GNBRCRB)>=0 : Call KILL_PROFIL(1) From GPLAN : Endif

   Endcase
  Endif
 Next
 #74219
 Kill TBLNUMLIG, TBLNUMORD
 #end 74219
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR
 Endif

Commit

Return


###########################
$CTL_SALARIE
OKC=1
# Actif permanent et géré en paie
If [F:ID]ENAFLG<>2 | [F:ID]FLGPAY<>2 | [F:ID]FLGINT=2 | ([M:MCH1]CRI<>"" & !evalue([M:MCH1]CRI))
 OKC= 0 : Return
Endif

# Code d'accès
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  OKC= 0 : Return
 Endif
Endif

# Droits par sites
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If !find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ))
  OKC = 0 : Return
 Endif
Endif

# Droits par service
If GUSRACS<>2 & !find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))
 OKC = 0 : Return
Endif

# Critère de séléction du scénario
Read [FCY]FCY0=[F:HRCTR]ETRFCY
If !evalue(CRITERE) | !evalue(CRITCTR) | !evalue(CRITFCY)
 OKC= 0 : Return
Endif

Return

###########################
$CTL_SALARIE2
OKC=1
# Actif permanent et géré en paie
If [F:ID]ENAFLG<>2 | [F:ID]FLGPAY<>2 | [F:ID]FLGINT=2
 OKC= 0 : Return
Endif

# Code d'accès
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  OKC= 0 : Return
 Endif
Endif

# Droits par sites
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If !find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ))
  OKC = 0 : Return
 Endif
Endif

# Droits par service
If GUSRACS<>2 & !find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))
 OKC = 0 : Return
Endif

Return


###########################
$CHRONO_SALARIE
Raz CHREMP : # 66650
#57181
#While IC & !fstat
While IC
 CHREMP(IC) = format$ ("N0:15", val ([C]MSEMP))
 [C]MSEMP = num$(val([C]MSEMP) + 1)
 #57181
 #If fstat : GOK = 0 : Endif
 If fstat : GOK = 0 : Break : Endif
 IC-=1
Wend
Return

###########################
$TR_MAJSTA
Trbegin [MCH]
Update [MCH] Where COD=[M:MCH0]COD With STA=2
Commit
Return

###########################
$AB_TR
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

###########################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1: Endif

###########################
$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2: Endif

