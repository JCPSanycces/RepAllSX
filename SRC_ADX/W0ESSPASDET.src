#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ESSPASDET 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRPAS
mkstat = 0
zoncou = "NBRPAS"
indice = 0
status = 1
zoncou = "NBRPAS"
If varmode([M]NBRPAS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPAS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRPAS
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRPAS = nolign
   status = 75
   Call SAI_NBRPAS(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRPAS From ESSPASDET
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRPAS" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRPAS(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPAS
mkstat = 0
zoncou = "NBRPAS"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBRPAS From ESSPASDET
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBRPAS" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PASNUM
mkstat = 0
zoncou = "PASNUM"
WCHAR = [M]PASNUM(indice)
If varmode([M]PASNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PASNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]PASNUM(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PASNUM" : GZNUM = 1120 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]PASNUM(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_PASNUM([M]PASNUM(indice)) From ESSPASDET
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PASNUM" : GZNUM = 1120 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PASDTE
mkstat = 0
zoncou = "PASDTE"
WDATE = [M]PASDTE(indice)
If varmode([M]PASDTE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PASDTE" : Gosub ACTION From =IMPTRT
 Endif
 If WDATE<>[M]PASDTE(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PASDTE([M]PASDTE(indice)) From ESSPASDET
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PASDTE" : GZNUM = 212 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PLCISS
mkstat = 0
zoncou = "PLCISS"
WCHAR = [M]PLCISS(indice)
If varmode([M]PLCISS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PLCISS" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]PLCISS(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PLCISS([M]PLCISS(indice)) From ESSPASDET
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PLCISS" : GZNUM = 46425 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PASCRY
mkstat = 0
zoncou = "PASCRY"
WCHAR = [M]PASCRY(indice)
If varinit([M]PASCRY,indice)=0
 [M]PASCRY(indice) = GPAYS
Endif
If varmode([M]PASCRY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PASCRY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]PASCRY(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PASCRY" : GZNUM = 263 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]PASCRY(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_PASCRY([M]PASCRY(indice)) From ESSPASDET
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PASCRY" : GZNUM = 263 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ISSAUZ
mkstat = 0
zoncou = "ISSAUZ"
WCHAR = [M]ISSAUZ(indice)
If varmode([M]ISSAUZ,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ISSAUZ" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]ISSAUZ(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_ISSAUZ([M]ISSAUZ(indice)) From ESSPASDET
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ISSAUZ" : GZNUM = 55127 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PASAMD
mkstat = 0
zoncou = "PASAMD"
IMPENT = [M]PASAMD(indice)
WNUM = IMPENT
If varinit([M]PASAMD,indice)=0
 IMPENT = 1
Endif
[M]PASAMD(indice) = IMPENT

## Zone NBRPAS
mkstat = 0
zoncou = "NBRPAS"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ESSPASDET"
Return

