[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_FLGBULDEM
[L]CURPRO = "FLGBULDEM"
Return

$PROPAGATE_FLGBULDEM
this.isReadonly = 0
[L]CURPRO = "FLGBULDEM"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
