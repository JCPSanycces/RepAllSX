####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 61 : NBCNT Number ( Field C 4)
####################################################################

$SET_NBCNT
If [L]_AOLDVAL<>this.NBCNT
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_NBCNT
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.NBCNT
 Gosub PROPAGATE_NBCNT
Endif
Return

$INIT_NBCNT
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "NBCNT"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_NBCNT
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "NBCNT"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_NBCNT                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_NBCNT                 : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_NBCNT
[L]CURPRO = "NBCNT"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.NBCNT=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_NBCNT
[L]CURPRO = "NBCNT"
Return

$_AOTHERS_NBCNT
[L]CURPRO = "NBCNT"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_NBCNT
[L]CURPRO = "NBCNT"
Return

$PROPAGATE_NBCNT
this.isReadonly = 0
[L]CURPRO = "NBCNT"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_NBCNT
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "NBCNT"
$_LNKPRO_NBCNT
Return


####################################################################
# 63 : FCYORI Initial site ( Field FCY 5)
####################################################################

$SET_FCYORI
If [L]_AOLDVAL<>this.FCYORI
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_FCYORI
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.FCYORI
 Gosub PROPAGATE_FCYORI
Endif
Return

$INIT_FCYORI
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "FCYORI"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_FCYORI
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "FCYORI"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_FCYORI                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_FCYORI                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_FCYORI
[L]CURPRO = "FCYORI"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.FCYORI,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_FCYORI
[L]CURPRO = "FCYORI"
If vireblc(this.FCYORI,2)<>vireblc(format$("K:5c",this.FCYORI),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_FCYORI
[L]CURPRO = "FCYORI"
If vireblc(this.FCYORI,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPFCY.ACTRLREF(this,"FCYORI",this.FCYORI,this.FCYORI,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.FCYORI<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_FCYORI
[L]CURPRO = "FCYORI"
Return

$PROPAGATE_FCYORI
this.isReadonly = 0
[L]CURPRO = "FCYORI"
Gosub _LNKPRO_FCYORI
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_FCYORI
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "FCYORI"
$_LNKPRO_FCYORI
If vireblc(this.FCYORI,2)<>""
 # Link FACILITY
 Local File FACILITY [WFCY]
 Read [F:WFCY]FCY0 = this.FCYORI
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FCYORI","$title",[F:WFCY]FCYSHO)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FCYORI","$description",[F:WFCY]FCYNAM)
 Endif
 LogicClose File [WFCY]
Endif
Return


