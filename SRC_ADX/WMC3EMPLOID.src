[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.FLGBULDEM=0 and fmet this.AGETATTRIBUTE("FLGBULDEM","$isMandatory")="true"
 this.FLGBULDEM = 1
Endif
Return
 
$CONTROL_FLGBULDEM
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "FLGBULDEM"
