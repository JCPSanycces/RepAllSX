If this.FLGBULDEM<0 or this.FLGBULDEM>len(mess(0,10992,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"10992 ->"-num$(this.FLGBULDEM)-mess(99,123,1)):  Return : # Local menu "10992 -> Invalid option
Endif
Return

$_AOTHERS_FLGBULDEM
