#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
#   When "OK"          : Gosub OK
#   When "SORTIE"      : Gosub SORTIE
Endcase

Return


$OUVRE
If clalev([F:AWS])    = 0 : Local File AWRKHISSUI     [AWS]     : Endif
Return

$DEBUT
nolign =0
Filter [F:AWS] Where DEST = GUSER and FLGSIG =3 and (CODEVT="DCG" | CODEVT = "DCGMOD" )
For [F:AWS]AWS0
  nolign +=1
  [M:ESWDG] = [F:AWS]
  [M:ESWDG]NBRLIN = nolign
Next

Affzo [M:ESWDG]1-99

#EXS - Expense note approvals
nolign =0
Filter [F:AWS] Where DEST = GUSER and FLGSIG =3 and (CODEVT="HREXS" | CODEVT = "EXSMOD" )
For [F:AWS]AWS0
  nolign +=1
  [M:ESWXS] = [F:AWS]
  [M:ESWXS]NBRLIN = nolign
Next
Filter [F:AWS]
Affzo [M:ESWXS]1-99
Return




