# Issue X3-66938 - 2017-12-15 by BAKHA : Updating Supplier details in Origin Tab
Local File ATABZON , ATEXTE
Local Char VALEUR(255), PARAM(255)(1..20)

  Call S_TAB_CHAR(VALEUR,PARAM,"SELCHPRD01","CRMSEL001","") From GACTION
  #Infbox VALEUR - [F:ATZ]CODFIC - [F:ATX]TEXTE
End

##########################################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"      : Gosub SEL_TABLE
    When "VERF_TABLE"     : Gosub VERF_TABLE
    When "SEL_LISTE"      : Gosub SEL_LISTE
    When "VERF_LISTE"     : Gosub VERF_LISTE
    When Default
  Endcase
Return

##########################################################################################################
$SEL_TABLE
  Case TABLE
    When "SELCORABR"      : Gosub SEL_SELCORABR
    When "SELAINABR"      : Gosub SEL_SELAINABR
    When "SELTABRD01"     : Gosub SEL_SELTABRD01
    When "SELCHPRD01"     : Gosub SEL_SELCHPRD01
    When "SELOBJ0001"     : Gosub SEL_SELOBJ0001
    When "SELOBJCR01"     : Gosub SEL_SELOBJCR01
    When "SELORIADI"      : Gosub SEL_SELORIADI   # FGR 05/03/2010 : X3SUIVI62924
    When "SELOPPBPR"      : Gosub SEL_SELOPPBPR
    When "SELOPPCCN"      : Gosub SEL_SELOPPCCN
    When "SELBPRADR"      : Gosub SEL_SELBPRADR
    When "SELPBL001"      : Gosub SEL_SELPBL001
    When "SELBPCCNT"      : Gosub SEL_SELBPCCNT   # Issue X3-67019 - 2017-12-15 by JUSYN : Selection Customer Contacts
    When "SELBPSCNT"      : Gosub SEL_SELBPSCNT   # Issue X3-66938
    When Default
  Endcase
Return

##########################################################################################################
$VERF_TABLE
  Case TABLE
    When "SELCORABR"      : Gosub VERF_SELCORABR
    When "SELAINABR"      : Gosub VERF_SELAINABR
    When "SELTABRD01"     : Gosub VERF_SELTABRD01
    When "SELCHPRD01"     : Gosub VERF_SELCHPRD01
    When "SELOBJ0001"     : Gosub VERF_SELOBJ0001
    When "SELOBJCR01"     : Gosub VERF_SELOBJCR01
    When "SELORIADI"      : Gosub VERF_SELORIADI    # FGR 05/03/2010 : X3SUIVI62924
    When "SELOPPBPR"      : Gosub VERF_SELOPPBPR
    When "SELOPPCCN"      : Gosub VERF_SELOPPCCN
    When "SELBPRADR"      : Gosub VERF_SELBPRADR
    When "SELPBL001"      : Gosub VERF_SELPBL001
    When "SELBPCCNT"      : Gosub VERF_SELBPCCNT    # Issue X3-67019 - 2017-12-15 by JUSYN : Selection Customer Contacts
    When "SELBPSCNT"      : Gosub VERF_SELBPSCNT   # Issue X3-66938
    When Default
  Endcase
Return

