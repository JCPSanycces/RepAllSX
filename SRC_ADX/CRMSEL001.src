##########################################################################################################
$SEL_SELSTDCNT
Local Integer Z
Local Char SZTTLLIB
Local Char SZTIT(100)

  #Sélection des contacts d'un tiers
  Z = 0
  SZTTLLIB = ""
  SZTIT = ""
  # Si aucun tiers n'est mentionné, on ne fait rien.
  If PARAM(1) = "" Then
    Return
  Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:BR1]) : Local File BPARTNER[BR1] : Endif
  Filter [CNT] Where [F:CNT]BPANUM = PARAM(1) and [F:CNT]BPATYP = 1
  For [CNT]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:CNT]CCNCRM
    Read [AIN]AIN0=[F:CNT]CCNCRM
    If fstat Then
      TEXTE(Z) = [F:CNT]CCNCRM
    Else
      Call BUILDFULNAM("AIN", TEXTE(Z)) From CRMUTIL140
    Endif
  Next
  Filter [CNT]
  NBTEX = Z
  Read [BR1]BPR0=PARAM(1)
  If fstat Then
    SZTIT = mess(194,196,1) - PARAM(1)
  Else
    SZTIT = mess(194,196,1) - [F:BR1]BPRNAM
  Endif
  TIT = left$(SZTIT, 50)
Return

##########################################################################################################
$VERF_SELSTDCNT
  #Sélection des contacts d'un tiers
  mkstat = 99
Return

