##########################################################################################################
$SEL_SELCRMONGL
Local Integer IINDICE
Local Integer Z
Local Char SZTTLLIB
Local Char SZTIT(100)

  #Sélection des onglets d'une fenetre
  Z = 1
  SZTTLLIB = ""
  SZTIT = ""
  # Si aucune fenetre n'est mentionnée, on ne fait rien.
  If PARAM(1) = "" Then
    Return
  Endif
  If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif
  If !clalev([F:ATX]) : Local File ATEXTE[ATX] : Endif
  Read [AWI]AWI0=PARAM(1)
  If fstat = 0 Then
    For IINDICE = 0 To dim([F:AWI]NOMMSK)-1
      If [F:AWI]NOMMSK(IINDICE) <> "" Then
        TEX(Z) = [F:AWI]NOMMSK(IINDICE)
        Read [ATX]NUMERO=messname;[F:AWI]INTMSK(IINDICE)
        If fstat = 0 Then
          TEXTE(Z) = num$(IINDICE+1) - "-" - [F:ATX]TEXTE
        Endif
        Z += 1
      Endif
    Next
  Endif
  NBTEX = Z-1
  #Liste des onglets
  TIT = left$(mess(520,177,1), 50)
Return

##########################################################################################################
$VERF_SELCRMONGL
  #Sélection des contacts d'un tiers
Return
# Issue X3-67019 - 2017-12-15 by JUSYN : Selection Customer Contacts
##########################################################################################################
# Selection of contacts to a customer
$SEL_SELBPCCNT

If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif

Link [CNT] With
& [AIN]AIN0=[F:CNT]CCNCRM
& As [CONT_]

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:CNT]CCNCRM"    : Call TEXTFIC('CONTACT', 'CCNCRM', 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AIN]CNTETS"    : Call TEXTFIC('CONTACTCRM', 'CNTETS', 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AIN]CNTTTL"    : Call TEXTFIC('CONTACTCRM', 'CNTTTL', 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AIN]CNTLNA"    : Call TEXTFIC('CONTACTCRM', 'CNTLNA', 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AIN]CNTFNA"    : Call TEXTFIC('CONTACTCRM', 'CNTFNA', 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AIN]CNTTYP"    : Call TEXTFIC('CONTACTCRM', 'CNTTYP', 1, TIT(NBCOL)) From OBJDIV

CRITERE = "[F:CNT]BPANUM = '" + PARAM(1) + "'"


Default File [CONT_]
DEFPAG = 1
START = "CCNCRM"
ORDRE = "CCNCRM"
TIT(0) = mess(183,197,1)


Return

##########################################################################################################
$VERF_SELBPCCNT

Return
# End issue X3-67019


