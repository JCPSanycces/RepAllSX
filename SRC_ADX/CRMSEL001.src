##########################################################################################################
$SEL_SELTABRD01
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZWORK(250)
Local Char SZTBTABLE(30)(50)
Local Integer  INBTABLE
Local Char SZOR
Local Integer ILIGNE

  #Sélection liste réduite de table (les tables à affiché sont en paramètre)
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATX]) : Local File ATEXTE [ATX] : Endif
  IBRETOUR = 1
  Raz SZTBTABLE
  INBTABLE = 0
  SZOR = ""
  SZWORK = PARAM(1)
  Call CRMTOKEN (SZWORK, SZTBTABLE, INBTABLE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If INBTABLE > 0 Then
    #Création du critère
    CRITERE = "("
    For ILIGNE = 0 To INBTABLE-1
      CRITERE = CRITERE + SZOR + '[F:ATB]CODFIC="' + SZTBTABLE(ILIGNE) + '"'
      SZOR = " OR "
    Next
    CRITERE = CRITERE + ")"
  Endif
  Link [ATB] With [ATX]NUMERO=messname;[F:ATB]INTITFIC As [ATBX]
  Default File [ATBX]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  START = "CODFIC" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "[F:ATX]TEXTE;[F:ATB]CODFIC"
  TIT(0) = mess(529,177,1) #Liste des tables
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CODFIC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE" : Call TEXTFIC("ATEXTE", "TEXTE", 1, TIT(NBCOL)) From OBJDIV
  #NBCOL += 1 : COL(NBCOL) = "INTITFIC"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  #NBCOL += 1 : COL(NBCOL) = "CONSTRDAT"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  #NBCOL += 1 : COL(NBCOL) = "CONENDDAT"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  #NBCOL += 1 : COL(NBCOL) = "CONAMT"      : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  #NBCOL += 1 : COL(NBCOL) = "CUR"         : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

##########################################################################################################
$VERF_SELTABRD01
Return

##########################################################################################################
$SEL_SELCHPRD01
Local Char SZMESSAGE (250)
Local Integer IBRETOUR
Local Char SZWORK (250)
Local Char SZTBTABLE(30)(50)
Local Integer  INBTABLE
Local Char SZOR
Local Integer ILIGNE

  If !clalev([F:ATZ]) : Local File ATABZON [ATZ]: Endif
  If !clalev([F:ATX]) : Local File ATEXTE [ATX]: Endif
  IBRETOUR = 1
  Raz SZTBTABLE
  INBTABLE = 0
  SZOR = ""
  SZWORK = PARAM(2)
  Call CRMTOKEN (SZWORK , SZTBTABLE, INBTABLE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If INBTABLE > 0 Then
    #Création du critère
    CRITERE = "("
    For ILIGNE = 0 To INBTABLE-1
      CRITERE = CRITERE - SZOR - '[F:ATZ]CODFIC="' + SZTBTABLE(ILIGNE) + '"'
      SZOR = " OR "
    Next
    CRITERE = CRITERE + ")"
  Endif
  Link [ATZ] With [ATX]NUMERO=messname;[F:ATZ]NOLONG As [ATZX]
  Default File [ATZX]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  START = "[F:ATZ]CODZONE" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "[F:ATX]TEXTE;[F:ATZ]CODZONE;[F:ATZ]CODFIC"
  TIT(0) = mess(488,177,1) #Liste des champs
  OBJET = ""
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "[F:ATZ]CODZONE" : Call TEXTFIC("ATABZON", "CODZONE", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:ATZ]CODFIC"  : Call TEXTFIC("ATABZON", "CODFIC", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE"   : Call TEXTFIC("ATEXTE", "TEXTE", 1, TIT(NBCOL)) From OBJDIV
Return

##########################################################################################################
$VERF_SELCHPRD01
  PARAM(1) = [F:ATZ]CODFIC
Return

##########################################################################################################
$SEL_SELOBJ0001
Local Char SZMESSAGE (250)
Local Integer IBRETOUR
Local Char SZWORK (250)
Local Char SZTBOBJET(30)(50)
Local Integer  INBOBJET
Local Char SZOR
Local Integer ILIGNE

  If !clalev([F:AOB]) : Local File AOBJET [AOB]: Endif
  IBRETOUR = 1
  Raz SZTBOBJET
  INBOBJET = 0
  SZOR = ""
  SZWORK = PARAM(1)
  Call CRMTOKEN (SZWORK, SZTBOBJET, INBOBJET, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If INBOBJET > 0 Then
    #Création du critère
    CRITERE = "("
    For ILIGNE = 0 To INBOBJET-1
      CRITERE = CRITERE + SZOR + '[F:AOB]ABREV="' + SZTBOBJET(ILIGNE) + '"'
      SZOR = " OR "
    Next
    CRITERE = CRITERE + ")"
  Endif
  Link [AOB] With [ATX]NUMERO=messname;[F:AOB]LIBEL As [AOBX]
  Default File [AOBX]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  START = "[F:AOB]ABREV"   #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "[F:ATX]TEXTE"
  TIT(0) = mess(488,177,1) #Liste des champs
  OBJET = ""
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "[F:AOB]ABREV" : Call TEXTFIC("AOBJET", "ABREV", 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE" : Call TEXTFIC("ATEXTE", "TEXTE", 1, TIT(NBCOL)) From OBJDIV
Return

##########################################################################################################
$VERF_SELOBJ0001
  PARAM(1) = [F:AOB]ABREV
Return

##########################################################################################################
$SEL_SELOBJCR01
Local Char SZAND(6)

  #Sélection objet
  SZAND = ""
  OBJET = PARAM(1)
  If PARAM(3) <> "" Then
    Case OBJET
      When "SRE"
        CRITERE = 'SREBPC="' + PARAM(3) + '"'
        SZAND = " and "
      When "OMM"
      When "OMP"
        #If PARAM(2) <> "" Then                            # Issue X3-67702 - 2018-03-21 by FGR
        If PARAM(2) <> "" and PARAM(2) <> "#" Then         # Issue X3-67702 - 2018-03-21 by FGR
          CRITERE = PARAM(2)
          SZAND = " and "
        Endif
      When "OMT"
      When "OMN"
      When "FUP"
      When "CMG"
      When "OPP"
        # FGR 20/01/2009 : X3SUIVI33671
        CRITERE = '(OPPCMP="' + PARAM(3) + '" or OPPCMP="")'
        SZAND = " and "
      When Default
    Endcase
  Endif
  # FGR 20/01/2009 : X3SUIVI33671
  If PARAM(4) <> "" Then
    Case OBJET
      When "SRE"
        CRITERE = CRITERE - SZAND - "(SALFCY='" + PARAM(4) + "' or SALFCY='')"    # FGR 03/01/2011 : X3SUIVI70334
      When "OMM"
        CRITERE = CRITERE - SZAND - "(FCY='" + PARAM(4) + "' or FCY='')"          # FGR 03/01/2011 : X3SUIVI70334
      When "OMP"
        CRITERE = CRITERE - SZAND - "(FCY='" + PARAM(4) + "' or FCY='')"          # FGR 03/01/2011 : X3SUIVI70334
      When "OMT"
        CRITERE = CRITERE - SZAND - "(FCY='" + PARAM(4) + "' or FCY='')"          # FGR 03/01/2011 : X3SUIVI70334
      When "OMN"
        CRITERE = CRITERE - SZAND - "(FCY='" + PARAM(4) + "' or FCY='')"          # FGR 03/01/2011 : X3SUIVI70334
      When "FUP"
        # Campagne de relance : Prévu de manière très basic mais jamais utilisée
        # FGR 13/11/2009 : X3SUIV59306 : vu avec JFL
      When "CMG"
        CRITERE = CRITERE - SZAND - "(FCY='" + PARAM(4) + "' or FCY='')"          # FGR 03/01/2011 : X3SUIVI70334
      When "OPP"
        CRITERE = CRITERE - SZAND - "(SALFCY='" + PARAM(4) + "' or SALFCY='')"    # FGR 03/01/2011 : X3SUIVI70334
      When Default
    Endcase
  Endif
Return

##########################################################################################################
$VERF_SELOBJCR01
Local Char SZBPCNUM(GLONBPC)
Local Integer IREPONSE
Local Integer IBMODIFOK

  IBMODIFOK = 0
  If PARAM(2) <> "#" Then    # Issue X3-67702 - 2018-03-21 by FGR : Not in this case
    Case PARAM(1)
      When "SRE"
        SZBPCNUM = [F:SRE]SREBPC
        IBMODIFOK = 1
    Endcase
  Endif
  If PARAM(3) = "" Then
    If IBMODIFOK = 1 Then
      If PARAM(3) <> SZBPCNUM Then
        #Le tiers de l'objet ne correspond pas à celui de l'écran.
        #Voulez-vous affecter le tiers de l'objet à l'écran?
        Call OUINON(mess(525,177,1), IREPONSE) From GESECRAN
        If IREPONSE = 2 Then
          PARAM(3) = SZBPCNUM
        Endif
      Endif
    Endif
  Endif
Return

# FGR 05/03/2010 : # X3SUIVI62924 (début)
##########################################################################################################
$SEL_SELORIADI
Local Char SZAND(6)
Local Char SZAVAFCY(GLONAVA)
Local Char SZAVABPR(GLONAVA)

  # PARAM(1) = Code table diverse 439
  # PARAM(2) = Complément requête
  # PARAM(3) = Tiers
  # PARAM(4) = Site
  If PARAM(1) <> "MAN1" Then
    If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
    If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
    Raz SZAND
    #
    Read [ADI]CODE=439;PARAM(1)
    Read [AOB]ABREV=[F:ADI]A1
    SZAVAFCY = [F:AOB]ZSITE
    SZAVABPR = [F:ADI]A2
    OBJET = [F:ADI]A1
    #
    If PARAM(2) <> "" Then
      # Filtre passé en paramètre
      CRITERE = CRITERE - SZAND - "(" + PARAM(2) + ")"
      SZAND = " and "
    Endif
    If PARAM(3) <> "" and SZAVABPR <> "" Then
      # Filtre sur Tiers
      # Nb. : Pour le tiers il est soit facultatif soit obligatoire dans les objets.
      #       On teste toujours ici l'égalité ou "chaîne vide". C'est l'objet qui s'occupe de faire
      #       que "chaîne vide" est possible ou pas.
      CRITERE = CRITERE - SZAND - "(" + SZAVABPR + "='" + PARAM(3) + "' or "+ SZAVABPR + "='')"
      SZAND = " and "
    Endif
    If PARAM(4) <> "" and SZAVAFCY <> "" Then
      # Filtre sur Site
      # Nb. : Pour le site il est soit facultatif soit obligatoire dans les objets.
      #       On teste toujours ici l'égalité ou "chaîne vide". C'est l'objet qui s'occupe de faire
      #       que "chaîne vide" est possible ou pas.
      CRITERE = CRITERE - SZAND - "(" + SZAVAFCY + "='" + PARAM(4) + "' or "+ SZAVAFCY + "='')"
      SZAND = " and "
    Endif
  Endif
Return

##########################################################################################################
$VERF_SELORIADI
Return
# FGR 05/03/2010 : # X3SUIVI62924 (fin)

##########################################################################################################
#Sélection des affaires par rapport à un tiers
$SEL_SELOPPBPR
Local Char SZBPCNAM(GLONNAM)
Local Char CODFIC

  Raz SZBPCNAM
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ]: Endif
  #Sélection des affaires sur une tâche pour un tiers.
  Read [BPR]BPR0=PARAM(1)
  If fstat = 0 Then
    SZBPCNAM = [F:BPR]BPRNAM
  Endif
  CODFIC = "OPPOR"
  Default File [OPP]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = "[F:OPP]OPPCMP = '" + PARAM(1) + "'"    # FGR 03/01/2011 : X3SUIVI70334
  START = "OPPNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "OPPNUM"
  TIT(0) = mess(413,196,1) - SZBPCNAM #Affaires chez
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "OPPNUM"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPDES"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPCMP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPREP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPTYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPSTE"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "STRSTE"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPCDA"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

##########################################################################################################
$VERF_SELOPPBPR
  mkstat = 99
Return

##########################################################################################################
#Sélection des affaires par rapport à un interlocuteur
$SEL_SELOPPCCN
Local Char SZCCNNAM(GLONNAC)
Local Char CODFIC

  Raz SZCCNNAM
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ]: Endif
  #Sélection des affaires sur une tâche pour un interlocuteur.
  Read [AIN]AIN0=PARAM(1)
  If fstat = 0 Then
    Call BUILDFULNAM("AIN", SZCCNNAM) From CRMUTIL140
  Endif
  CODFIC = "OPPOR"
  Default File [OPP]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = "[F:OPP]OPPMCN = '" + PARAM(1) + "'"    # FGR 03/01/2011 : X3SUIVI70334
  START = "OPPNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "OPPNUM"
  TIT(0) = mess(413,196,1) - SZCCNNAM #Affaires chez
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "OPPNUM"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPDES"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPCMP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPREP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPTYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPSTE"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "STRSTE"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OPPCDA"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

##########################################################################################################
$VERF_SELOPPCCN
  #Sélection des affaires par rapport à un interlocuteur
  mkstat = 99
Return

##########################################################################################################
$SEL_SELBPRADR
Local Char CODFIC

  #Sélection adresse d'un tiers
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ]: Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  CODFIC = "BPADDRESS"
  Default File [BPA]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = "[F:BPA]BPATYP=1 and [F:BPA]BPANUM='" + PARAM(1)+ "'"    # FGR 03/01/2011 : X3SUIVI70334
  START = "BPAADD" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "BPAADD"
  #Liste des adresses
  TIT(0) = mess(535,177,1)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "BPAADD"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "BPADES"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "POSCOD"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CTY"       : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CRY"       : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CRYNAM"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

##########################################################################################################
$VERF_SELBPRADR
Return

##########################################################################################################
$SEL_SELPBL001
  #Sélection objet
  OBJET = "PBL"
  Case val(PARAM(2))
    When 0
      #Compétences hors client
      CRITERE = '[F:PBL]PBLBPC = ""'
    When 1
      #Compétences tous clients
    When 2
      #Compétence client
      If PARAM(3) <> "" Then
        CRITERE = '([F:PBL]PBLBPC="' + PARAM(3) + '" or [F:PBL]PBLBPC="")'    # FGR 03/01/2011 : X3SUIVI70334
      Else
        CRITERE = ' [F:PBL]PBLBPC=""'
      Endif
  Endcase
Return

##########################################################################################################
$VERF_SELPBL001
Return

##########################################################################################################
#                                                                                                        #
#                                                SELECTIONS LISTE                                        #
#                                                                                                        #
##########################################################################################################
##########################################################################################################
$SEL_SELTXTMENU
Local Integer INBMAX
Local Integer IINDICE
Local Integer INBELEMENT
Local Integer INUMCHAP
Local Char ZSTMP(GLONCLX)                         # FGR 15/03/2012 : X3SUIVI80774
Local Integer IBKEEP
Local Char STBVAL(30)(1..50)
Local Integer ITBVALMAX
Local Char SZCHAINE(GLONCLX)                      # FGR 15/03/2012 : X3SUIVI80774
Local Char SZRESULT(GLONCLX)                      # FGR 15/03/2012 : X3SUIVI80774
Local Char SZRESTE(GLONCLX)                       # FGR 15/03/2012 : X3SUIVI80774

  Raz STBVAL
  Raz SZCHAINE
  Raz SZRESULT
  Raz SZRESTE
  If PARAM(3) <> "" Then
    Raz STBVAL
    SZCHAINE = PARAM(3)
    IINDICE = 0
    ITBVALMAX = 0
    While ITBVALMAX < dim(STBVAL)
      IFIND = instr(0, SZCHAINE, ";")
      If IFIND > 0 Then
        #On a trouvé un caractere
        SZRESULT = left$(SZCHAINE, IFIND-1)
        SZRESTE = right$(SZCHAINE, IFIND+1)
      Else
        SZRESULT = SZCHAINE
        SZRESTE = ""
      Endif
      If SZRESULT <> "" Then
        ITBVALMAX += 1
        STBVAL(ITBVALMAX) = SZRESULT
      Endif
      If SZRESTE <> "" Then
        SZCHAINE = SZRESTE
      Else
        Break
      Endif
    Wend
  Endif
  ZSTMP = ""
  INUMCHAP = val(PARAM(2))
  ZSTMP = num$(mess(0,INUMCHAP,1))
  INBMAX = len(ZSTMP)
  IINDICE = 1
  INBELEMENT = 1
  While IINDICE < INBMAX+1
    If mess(IINDICE,INUMCHAP,1) <> "" Then
      IBKEEP = 0
      If ITBVALMAX > 0 Then
        #On test les exclusions
        If find(num$(IINDICE), STBVAL) > 0 Then
          IBKEEP = 0
        Else
          IBKEEP = 1
        Endif
      Else
        IBKEEP = 1
      Endif
      If IBKEEP = 1 Then
        TEXTE(INBELEMENT) = num$(IINDICE) - mess(IINDICE,INUMCHAP,1)
        TEX(INBELEMENT) = mess(IINDICE,INUMCHAP,1)
        NBTEX = INBELEMENT
        INBELEMENT += 1
      Endif
    Endif
    IINDICE += 1
  Wend
Return

##########################################################################################################
$VERF_SELTXTMENU
  PARAM(1) = TEXTE(CHOIX)
  #mkstat = 99     # Issue X3-67702 - 2018-03-20 by FGR : No
Return

