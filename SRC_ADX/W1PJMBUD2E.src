#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD2E 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:46"
A_USER  = "DOC"
A_STAMP = "20181109230546"
Return

$TITRES
Chgtzn [M:PJBU2E]PSCBUDAMT With func SUBPJBU.COL_GET_TITLE_10(4)
Chgtzn [M:PJBU2E]PSCAMT1 With func SUBPJBU.COL_GET_TITLE_10(6)
Chgtzn [M:PJBU2E]PSCAMT2 With func SUBPJBU.COL_GET_TITLE_10(8)
Chgtzn [M:PJBU2E]PSCAMT3 With func SUBPJBU.COL_GET_TITLE_10(10)
Chgtzn [M:PJBU2E]PSCAMT4 With func SUBPJBU.COL_GET_TITLE_10(12)
Chgtzn [M:PJBU2E]PSCAMT5 With func SUBPJBU.COL_GET_TITLE_10(14)
Chgtzn [M:PJBU2E]PSCBUDQTY With func SUBPJBU.COL_GET_TITLE_10(3)
Chgtzn [M:PJBU2E]PSCQTY1 With func SUBPJBU.COL_GET_TITLE_10(5)
Chgtzn [M:PJBU2E]PSCQTY2 With func SUBPJBU.COL_GET_TITLE_10(7)
Chgtzn [M:PJBU2E]PSCQTY3 With func SUBPJBU.COL_GET_TITLE_10(9)
Chgtzn [M:PJBU2E]PSCQTY4 With func SUBPJBU.COL_GET_TITLE_10(11)
Chgtzn [M:PJBU2E]PSCQTY5 With func SUBPJBU.COL_GET_TITLE_10(13)
Chgtzn [M:PJBU2E]PSCREMAMT With func SUBPJBU.COL_GET_TITLE_10(16)
Chgtzn [M:PJBU2E]PSCWIPAMT With func SUBPJBU.COL_GET_TITLE_10(18)
Chgtzn [M:PJBU2E]PSCREMQTY With func SUBPJBU.COL_GET_TITLE_10(15)
Chgtzn [M:PJBU2E]PSCWIPQTY With func SUBPJBU.COL_GET_TITLE_10(17)
Chgtzn [M:PJBU2E]PSCTOTAMT With func SUBPJBU.COL_GET_TITLE_10(20)
Chgtzn [M:PJBU2E]PSCMARGAMT With func SUBPJBU.COL_GET_TITLE_10(23)
Chgtzn [M:PJBU2E]PSCPCTMAMT With func SUBPJBU.COL_GET_TITLE_10(24)
Chgtzn [M:PJBU2E]PSCTOTQTY With func SUBPJBU.COL_GET_TITLE_10(19)
Chgtzn [M:PJBU2E]PSCMARGQTY With func SUBPJBU.COL_GET_TITLE_10(21)
Chgtzn [M:PJBU2E]PSCPCTMQTY With func SUBPJBU.COL_GET_TITLE_10(22)
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMBUD2E [PJBU2E]
Gosub HORODAT
Local Inpbox "PJMBUD2E" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJBU2E] As [SIM_]
Grizo [PJBU2E]5
Grizo [PJBU2E]10
Grizo [PJBU2E]15
Grizo [PJBU2E]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJBU2E]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=197 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=197 : Y1(1)=3 : Y2(1)=5
X1(2)=1 : X2(2)=197 : Y1(2)=6 : Y2(2)=8
X1(3)=1 : X2(3)=197 : Y1(3)=9 : Y2(3)=25
Return

$ON_EXTDAT
Onevent BEFORE_AREA Gosub AV_EXTDAT From W1PJMBUD2E
Return

$AV_EXTDAT
Chgfmt [M]EXTDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_REFRESH
Onevent BEFORE_INPUT Call AS_REFRESH(zc) From W1PJMBUD2E
Onevent INIT_AREA Call D_REFRESH(zc) From W1PJMBUD2E
Return

Subprog D_REFRESH(VALEUR)
Variable Char    VALEUR()
If varinit([M]REFRESH,indice)=0
 VALEUR = "278"
Endif
Gosub _AFF
End

Subprog AS_REFRESH(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_REFRESH(zc) From W1PJMBUD2E
Gosub _AFF
End

Subprog CL_REFRESH(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_REFRESH(VALEUR) From SUBPJBU
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_PSCBUDAMT
Onevent BEFORE_AREA Gosub AV_PSCBUDAMT From W1PJMBUD2E
Return

$AV_PSCBUDAMT
If func SUBPJBU.COLGETFMT_10(4)<>""
 Chgfmt [M]PSCBUDAMT(indice) With func SUBPJBU.COLGETFMT_10(4)
Else
 Chgfmt [M]PSCBUDAMT(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_PSCUR
Return

