$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1HLY1
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_NBRDAY
Onevent BEFORE_INPUT Call AS_NBRDAY From W1HLY1
Return

Subprog AS_NBRDAY
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRDAY From SUBHLY
Gosub _AFF
End

$ON_HLYDAY
Onevent BEFORE_INPUT Call AS_HLYDAY(zc) From W1HLY1
Onevent CONTROL Call C_HLYDAY(zc) From W1HLY1
Onevent AFTER_CHANGE Gosub AMM_HLYDAY From W1HLY1
Onevent BEFORE_AREA Gosub AV_HLYDAY From W1HLY1
Return

$AV_HLYDAY
Chgfmt [M]HLYDAY(indice) With "D:"+GFMJOU
Gosub _AFF
Return

Subprog AS_HLYDAY(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_HLYDAY(VALEUR) From SUBHLY
If mkstat=2
 [M]HLYDAY(INDIC) = VALEUR
 Affzo HLYDAY(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_HLYDAY(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "HLYDAY" : GZNUM = 212 : Endif
If !mkstat
 ## Action STD
 Call C_HLYDAY(VALEUR) From SUBHLY
 If mkstat : GERR = 1 : GZONE = "HLYDAY" : GZNUM = 212 : Endif
Endif
Gosub _AFF
End

$AMM_HLYDAY
Call AM_HLYDAY(zc)
If !mkstat & GOBJET
 zoncou = "HLYDAY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_HLYDAY(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_HLYDAY(VALEUR) From SUBHLY
If mkstat : GERR = 1 : GZONE = "HLYDAY" : GZNUM = 212 : Endif
Gosub _AFF
End

$CHG_STY
Return


