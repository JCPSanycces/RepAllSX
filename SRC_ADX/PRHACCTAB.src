############################################################################################
# générique
$LOAD_PARAMRES
  Local Clbfile WFLTWHR(1)
  Local Integer WNBREAD  : WNBREAD=0        
  Local Integer WSTART   : WSTART=1
  Local Integer WNBREC   : WNBREC=0
  Local Integer WROWPOS   : WROWPOS=0   
  Local Integer WTOTALCOUNT        
  Local Integer WMAXREC 
Return

$MAJ_COMPTEURREQ
Local Integer WI : WI=0
WI = find ("$RET_COUNT", AXPARCOD) 
If WI : AXPARVAL(WI)= num$(WNBREC) : Endif
WI = find ("$TOTAL_COUNT", AXPARCOD) 
If WI : AXPARVAL(WI)=num$(WTOTALCOUNT) : Endif
Return  
##############################################################################################
#
# Code postal
#
##############################################################################################
Subprog RECHCODEPOSTAL(AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
&                ,AXWHRANDOR,AXORDCOD,AXORDTYP
&                ,CRY,POSCOD,POSCTY,POSCTYCOD)
Value Char       AXPARCOD()(1..)
Variable Char    AXPARVAL()(1..)
Value Integer AXWHRLFTBRK(1..)
Value Char    AXWHRCOD()(1..)
Value Integer AXWHROPE(1..)
Value Char    AXWHRCODVAL()(1..)
Value Integer AXWHRRGTBRK(1..)
Value Integer AXWHRANDOR(1..)
Value Char    AXORDCOD()(1..)
Value Integer AXORDTYP(1..)
Variable Char    CRY()(1..)
Variable Char    POSCOD()(1..)
Variable Char    POSCTY()(1..)
Variable Char    POSCTYCOD()(1..)

If !clalev([POS_]) : Local File POSCOD [POS_] : Endif
Default File [POS_]
Gosub LOAD_PARAMRES 
Raz WFLTWHR
WFLTWHR="1=1"
IRES=find("CRY",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(CRY),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif
IRES=find("POSCOD",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(POSCOD),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif
IRES=find("POSCTY",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(POSCTY),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif
IRES=find("POSCTYCOD",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(POSCTYCOD),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif
Filter [POS_] Where evalue(WFLTWHR)  
WTOTALCOUNT = rowcount([POS_])
WMAXREC=dim(POSCOD)

If WTOTALCOUNT >= WSTART  
  For [POS_]
    WNBREAD+=1
    # Job finished
     If WSTART <= WNBREAD
        WNBREC+=1
        WROWPOS=WNBREC 
      CRY(WROWPOS) = [F]CRY
      POSCOD(WROWPOS) = [F]POSCOD
      POSCTY(WROWPOS) = [F]POSCTY
      POSCTYCOD(WROWPOS) = [F]POSCTYCOD
       If WROWPOS >= WMAXREC : Break: Endif
     Endif
    Next
  Endif

Gosub MAJ_COMPTEURREQ

Filter[POS_]
End


##############################################################################################
#
# Liste salarié
#
##############################################################################################
Subprog RECHALLSALARIE(AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
&                ,AXWHRANDOR,AXORDCOD,AXORDTYP
&                ,NAM,REFNUM,SRN)
Value Char       AXPARCOD()(1..)
Variable Char    AXPARVAL()(1..)
Value Integer AXWHRLFTBRK(1..)
Value Char    AXWHRCOD()(1..)
Value Integer AXWHROPE(1..)
Value Char    AXWHRCODVAL()(1..)
Value Integer AXWHRRGTBRK(1..)
Value Integer AXWHRANDOR(1..)
Value Char    AXORDCOD()(1..)
Value Integer AXORDTYP(1..)
Variable Char    NAM()(1..)
Variable Char    REFNUM()(1..)
Variable Char    SRN()(1..)

If !clalev([ID_]) : Local File EMPLOID [ID_] : Endif
Default File [ID_]
Gosub LOAD_PARAMRES 
Raz WFLTWHR
WFLTWHR="ENAFLG=2"
IRES=find("NAM",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(NAM),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif
IRES=find("REFNUM",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(REFNUM),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif
IRES=find("SRN",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(SRN),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif

Filter [ID_] Where evalue(WFLTWHR)  
WTOTALCOUNT = rowcount([ID_])
WMAXREC=dim(NAM)

If WTOTALCOUNT >= WSTART  
  For [ID_]
    WNBREAD+=1
    # Job finished
     If WSTART <= WNBREAD
        WNBREC+=1
        WROWPOS=WNBREC 
      NAM(WROWPOS) = [F]NAM
      REFNUM(WROWPOS) = [F]REFNUM
      SRN(WROWPOS) = [F]SRN
       If WROWPOS >= WMAXREC : Break: Endif
     Endif
    Next
  Endif
Gosub MAJ_COMPTEURREQ
Filter[ID_]
End

##############################################################################################
#
# Liste salarié
#
##############################################################################################

Subprog PRHTESTAUTOCOMP(  AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
&                ,AXWHRANDOR,AXORDCOD,AXORDTYP
&                ,CLEREC,COMMENT,LAN,LONG,NOMOBJ,NOMZON,NUMERO,TEXTE,TYPOBJ,UPDDAT
&                )
# Begining of compulsory technical section
Value Char    AXPARCOD()(1..)
Variable Char    AXPARVAL()(1..)
Value Integer AXWHRLFTBRK(1..)
Value Char    AXWHRCOD()(1..)
Value Integer AXWHROPE(1..)
Value Char    AXWHRCODVAL()(1..)
Value Integer AXWHRRGTBRK(1..)
Value Integer AXWHRANDOR(1..)
Value Char    AXORDCOD()(1..)
Value Integer AXORDTYP(1..)
# End of compulsory technical section
# <XT_SPE>Set new arguments
Variable Char    CLEREC()(1..)
Variable Char    COMMENT()(1..)
Variable Char    LAN()(1..)
Variable Integer LONG(1..)
Variable Char    NOMOBJ()(1..)
Variable Char    NOMZON()(1..)
Variable Integer NUMERO(1..)
Variable Char    TEXTE()(1..)
Variable Integer TYPOBJ(1..)
Variable Date    UPDDAT(1..)


If !clalev([ATX_]) : Local File ATEXTE [ATX_] : Endif
Default File [ATX_]

Gosub LOAD_PARAMRES 
Raz WFLTWHR
WFLTWHR="1=1"
IRES=find("TEXTE",AXWHRCOD)
If IRES : WFLTWHR+=' and pat(toupper(TEXTE),"'+toupper(AXWHRCODVAL(IRES))+'*")=1'
Endif
Filter [ATX_] Where evalue(WFLTWHR)  
WTOTALCOUNT = rowcount([ATX_])
WMAXREC=dim(TEXTE)

If WTOTALCOUNT >= WSTART  
  For [ATX_]
    WNBREAD+=1
    # Job finished
     If WSTART <= WNBREAD
        WNBREC+=1
        WROWPOS=WNBREC 
      CLEREC(WROWPOS) = [F]CLEREC
      COMMENT(WROWPOS) = [F]COMMENT
      LAN(WROWPOS) = [F]LAN
      LONG(WROWPOS) = [F]LONG
      NOMOBJ(WROWPOS) = [F]NOMOBJ
      NOMZON(WROWPOS) = [F]NOMZON
      NUMERO(WROWPOS) = [F]NUMERO
      TEXTE(WROWPOS) = [F]TEXTE
      TYPOBJ(WROWPOS) = [F]TYPOBJ
      UPDDAT(WROWPOS) = [F]UPDDAT
       If WROWPOS >= WMAXREC : Break: Endif
     Endif
    Next
  Endif
Gosub MAJ_COMPTEURREQ
Filter[ATX_]
End
