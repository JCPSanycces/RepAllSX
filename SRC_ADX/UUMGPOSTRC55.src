#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGPOSTRC55                                       Step  Common data   #
#                    Migration Process                                   #
#                                                                        #
#      Parameters Post-migration : Initialize PIVSUP & GASSUP            #
#                                                                        #
##########################################################################
#                                                                        #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSTRC55") From LECFIC
  Endif

  Call MAJ_UUMGPOSTRC55(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End
########################################################################
Subprog RAZ_UUMGPOSTRC55(DOSSIER)
Value Char DOSSIER

Local Integer ERR

Call MIGRAZKEY (DOSSIER,"UUMGPOSTRC55",ERR) From TRTMIG

End
########################################################################
Subprog MAJ_UUMGPOSTRC55(DOSSIER)
Value Char DOSSIER
Local Integer ERR

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC55",2,ERR) From TRTMIG

# Issue 121226
If func DOSVUE.ISVIEW(DOSSIER,"ADOVAL")=1
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC55",3,ERR) From TRTMIG : End
Endif
# End issue 121226

#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC55",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>GMIGX3VER100
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC55",3,ERR) From TRTMIG : End
Endif

#--------------- Opening of files  -----#
If clalev([F:DADW])  = 0 :  Local File =DOSSIER+".ADOVAL"       [DADW]    : Endif     # ADOVAL
If clalev([F:DAW2])  = 0 :  Local File =DOSSIER+".ADOVAL"       [DAW2]    : Endif     # ADOVAL

Trbegin [F:DAW2]
For [F:DADW] Where PARAM="SIVSUP"
  #Fill PIVSUP
  Read [F:DAW2]ADW0=[F:DADW]CMP;[F:DADW]FCY;"PIVSUP"
  If fstat = 0
    [F:DAW2]VALEUR = [F:DADW]VALEUR
    Rewrite [F:DAW2]
    If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,2) From DOSDIC : Endif
  Else
    [F:DAW2] = [F:DADW]
    [F:DAW2]PARAM  = "PIVSUP"
    Write [F:DAW2]
    If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,1) From DOSDIC : Endif
  Endif

  #Fill GASSUP
  Read [F:DAW2]ADW0=[F:DADW]CMP;[F:DADW]FCY;"GASSUP"
  If fstat = 0
    [F:DAW2]VALEUR = [F:DADW]VALEUR
    Rewrite [F:DAW2]
    If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,2) From DOSDIC : Endif
  Else
    [F:DAW2] = [F:DADW]
    [F:DAW2]PARAM  = "GASSUP"
    Write [F:DAW2]
    If fstat : Call ERREUR("ADOVAL"-[F:DAW2]CMP-[F:DAW2]FCY-[F:DAW2]PARAM,1) From DOSDIC : Endif
  Endif
Next

Commit

Close Local File

Call MIGTRTEND (DOSSIER,"UUMGPOSTRC55") From TRTMIG
End
########################################################################
# To autorun patch management                                          #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGPOSTRC55(APPLI)
End

#######################################################################
# For execution since dosmaj (validation file)                        #
#######################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGPOSTRC55(APPLI)
End

