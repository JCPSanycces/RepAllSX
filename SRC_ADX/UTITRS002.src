#<AdxTL>@(#)9.0.0.0 $Revision$
###########################################################################
# UTITRS002   Suppression du paramétrage des fichiers bancaires VIREMENT  #
#             et VIRINTER dans le dossier mère, puis re-création à partir #
#             du paramétrage de ces mêmes fichiers du dossier applicatif  #
# Moulinette exécutée depuis le dossier applicatif                        #
###########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap

  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  
    Call TEMPON("O") From GESECRAN
    If !GSERVEUR
      Call OUVRE_TRACE("Moulinette UTITRS002") From LECFIC
    Endif
  
    If nomap<>GDOSX3 Then
      Call MAJ_UTIFICBAN(nomap)
    Else
      Local Integer OK
      Call OUINON("Exécuter cette moulinette sur l'ensemble des dossiers de la solution",OK) From GESECRAN
      If OK<>2 : End : Endif
      If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
      For [ADS]
        If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
          Call MAJ_UTIFICBAN([F:ADS]DOSSIER)
        Endif
      Next
    Endif

    Call TEMPOFF From GESECRAN
    If !GSERVEUR
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE   From LECFIC
    Endif
  Endif
End

Subprog MAJ_UTIFICBAN(DOSSIER)
Value Char    DOSSIER
Local Integer OK, COMPTEUR

  Call ECR_TRACE("UTITRS002 : Process Start on : "+DOSSIER,0) From GESECRAN

  If clalev([F:TFB])>0 Close Local File [TFB] : Endif
  Local File =DOSSIER+".TABFILBAN" [TFB]

  Trbegin [F:TFB] : GOK=1
#   Delete [F:TFB] Where (COD='VIREMENT' or COD='VIRINTER') and RECTYP=2 and ORDNUM=0
  Delete [F:TFB] Where (COD='VIREMENT' or COD='VIRINTER' or COD='VIRSEPA') and BAN=''
  COMPTEUR = adxdlrec
  If fstat Then GOK=0 Endif
  
$FIN
  If GOK=1
    Commit
  Else
    Rollback
  Endif
 
  #----- Fin du traitement -----#
  Call ECR_TRACE("UTITRS002 : "+num$(COMPTEUR)+" records processed on " + DOSSIER,0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","TABFILBAN","fde",APPLI),0)<=0 : End : Endif
  Call MAJ_UTIFICBAN(APPLI)        
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH_X3(APPLI)
Value Char    APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","TABFILBAN","fde",APPLI),0)<=0 : End : Endif
  Call MAJ_UTIFICBAN(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If [F:ADS]MODULE(2)<>2 : End : Endif
  If filinfo(filpath("FIL","TABFILBAN","fde",APPLI),0)<=0 : End : Endif
  Call MAJ_UTIFICBAN(APPLI)
End

