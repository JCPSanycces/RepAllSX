#<AdxTL>@(#)4.0.0.0 $Revision$
#####################################################################################
# Historisation et Epuration de la table HISTOPAYE en fonction des entêtes de paye  # 
# historisés ou épurés.                                                             # 
#     Index de HISTOPAYE -> EMP+DAT+ROW+TYP                                         #
#     Index de VALEMP    -> EMP+PYRDAT                                              #
# Comme les zones DAT et PYRDAT ont des noms différents, le lien ne peut se faire   #
# par le paramétrage de épurations                                                  #
#####################################################################################


$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "HISTO"    : Gosub HISTO
 When "EPURE"    : Gosub EPURE
 When "FERME"    : Gosub FERME
Endcase
Return


$OUVRE
Local Char HCRIT(50)
If clalev([F:P1])=0 : Local File =[L]APPLI+".HISTOPAYE" [P1] : Endif
If HISTO
 If filinfo(filpath("FIL","HISTOPAYE","FDE",HISAPL),0)<0
  Call CRETABLE(APPLI,HISAPL,TYPDBA,"HISTOPAYE",COEFF,0) From CREHISTO
 Endif
 If clalev([F:O1])=0 : Local File =[L]HISAPL+".HISTOPAYE" [O1] : Endif
 If dim([F:O1]CREHISDAT)>0
  HCRIT = "CREHISDAT<=["+format$(GFMD,date$-TEMPS)+"]"
 Else
  HCRIT = "1=1"
 Endif
Endif
Return


$HISTO
# Si historisation des entêtes de paye, il faut historiser l'historique de paye
For [P1]HSP0 Where EMP=[F1]EMP & DAT=[F1]PYRDAT
 [F:O1] = [F:P1]
 If dim([F:O1]CREHISDAT)>0 : [F:O1]CREHISDAT = date$    : Endif
 If dim([F:O1]CREHISUSR)>0 : [F:O1]CREHISUSR = [V]GUSER : Endif
 If ![L]SIMUL
  Write [O1]
  If fstat
   [V]GOK = 0 : Call FSTA("O1") From GLOCK : Break
  Endif
  Delete [P1]
  If fstat=1
   [V]GOK = -1 : [V]GLOCK = "$HISTOPAYE"-[F1]EMP-num$([F1]PYRDAT) : Break
  Endif
 Endif
Next
Return


$EPURE
If HISTO
 If ![L]SIMUL
  Delete [O1] Where EMP=[F1]EMP & DAT=[F1]PYRDAT & evalue(HCRIT)
  If fstat=1
   [V]GOK = -1 : [V]GLOCK = "$HISTOPAYE"-[F1]EMP-num$([F1]PYRDAT) : Return
  Endif
 Endif
Else
 If ![L]SIMUL
  Delete [P1] Where EMP=[F1]EMP & DAT=[F1]PYRDAT
  If fstat=1
   [V]GOK = -1 : [V]GLOCK = "$HISTOPAYE"-[F1]EMP-num$([F1]PYRDAT) : Return
  Endif
 Endif
Endif
Return


$FERME
If clalev([F:P1])>0 : Close Local File [P1] : Endif
If clalev([F:O1])>0 : Close Local File [O1] : Endif
Return
