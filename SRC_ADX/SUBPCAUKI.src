#
# Library of UKI procedures for Contribution screens
#
# Window  : OPCA
# Screens : PCA0, PCA1
#
############################################################
#ANCOA - 2017-09-18 - X3-22017 - START
Subprog C_BNKACCTYP(VALEUR)
  Variable Integer VALEUR
  If VALEUR=3 # Building Society
    Actzo [M:PCA1]BSOROL(nolign-1)
  Else
    Raz [M:PCA1]BSOROL(nolign-1)
    Grizo [M:PCA1]BSOROL(nolign-1)
  Endif
End

Subprog C_BNKACCNUM(VALEUR)
  Variable Decimal VALEUR
  Local Integer BNKACCTYP
  BNKACCTYP = [M:PCA1]BNKACCTYP(nolign-1)
  If BNKACCTYP=2
    If VALEUR<1
      [V]GMESSAGE=mess(00014,11800,1)
      mkstat     =2
    Endif

    If VALEUR>99999999
      [V]GMESSAGE=mess(00010,11800,1)
      mkstat     =2
    Endif
  Endif
End

Subprog AM_BNKSRTCOD(VALEUR)
  Variable Char    VALEUR()
  Local Char FTWO(5), STWO(5), STR(8)
  FTWO = left$(VALEUR,2) : FTWO = FTWO+"-"
  STWO = right$(left$(VALEUR,4),3) : STWO = STWO+"-"
  STR = FTWO+STWO+right$(VALEUR,5)
  VALEUR = STR
  Affzo [M:PCA1]BNKSRTCOD(nolign-1)
End

Subprog AS_BNKSRTCOD(VALEUR)
Variable Char    VALEUR()
  Local Char LEF(2), MID(2) ,RIG(2)
  LEF = left$(VALEUR,2)
  MID = right$(left$(VALEUR,5),4)
  RIG = right$(VALEUR,7)
  VALEUR = LEF+MID+RIG
  Affzo [M:PCA1]BNKSRTCOD(nolign-1)
End

Subprog C_BNKSRTCOD(VALEUR)
  Variable Char    VALEUR()
  Local Integer BNKACCTYP
  BNKACCTYP = [M:PCA1]BNKACCTYP(nolign-1)
  If BNKACCTYP=2
    If len(VALEUR) <> 6 Then
      GMESSAGE = mess(00013,11800,1)
      mkstat=2
      End
    Endif
  Endif
End

#ANCOA - 2017-09-18 - X3-22017 - END
############################################################

Subprog AM_DEFFND(VALEUR)
  Variable Integer VALEUR
  Local Integer I

  # If selected as default then make sure all other rows are marked as not default
  If VALEUR = 2
    For [L]I=0 To [M:PCA1]TBL-1
      If I <> nolign-1
        [M:PCA1]DEFFND(I) = 1
        Affzo [M:PCA1]DEFFND(I)
      Endif
    Next
  Endif
End

#**
#* Load the extra auto-enrolment details
#* @param LINE_NUMBER Line number to load details for
#*!
Subprog LOAD_AE_DETAILS (LINE_NUMBER)
  Value Integer LINE_NUMBER
  [M:PCA1]DEFEMEPRC(LINE_NUMBER)    = [F:PCA]DEFEMEPRC(LINE_NUMBER)    #Default employee percentage
  [M:PCA1]DEFEMRPRC(LINE_NUMBER)    = [F:PCA]DEFEMRPRC(LINE_NUMBER)    #Default employer percentage
  [M:PCA1]QUASCH(LINE_NUMBER)       = [F:PCA]QUASCH(LINE_NUMBER)       #Qualifying scheme
  [M:PCA1]SALSAC(LINE_NUMBER)       = [F:PCA]SALSAC(LINE_NUMBER)       #Salary sacrifice
  [M:PCA1]DEDLEL(LINE_NUMBER)       = [F:PCA]DEDLEL(LINE_NUMBER)       #Deduct lower earning limit
  [M:PCA1]APPUEL(LINE_NUMBER)       = [F:PCA]APPUEL(LINE_NUMBER)       #Apply upper earnings limit
  [M:PCA1]USEUAP(LINE_NUMBER)       = [F:PCA]USEUAP(LINE_NUMBER)       #Use uppaer accrual point as limit
  [M:PCA1]DEDBASRAT(LINE_NUMBER)    = [F:PCA]DEDBASRAT(LINE_NUMBER)    #Deduct basic rate tax
  [M:PCA1]APPUPPQUAERN(LINE_NUMBER) = [F:PCA]APPUPPQUAERN(LINE_NUMBER) #Apply upper threshold of qualifying earnings
  [M:PCA1]CTRBAS(LINE_NUMBER)       = [F:PCA]CTRBAS(LINE_NUMBER)       #Contract based
  [M:PCA1]BNKACCTYP(LINE_NUMBER)    = [F:PCA]BNKACCTYP(LINE_NUMBER)    #Bank account type
  [M:PCA1]BNKACCNUM(LINE_NUMBER)    = [F:PCA]BNKACCNUM(LINE_NUMBER)    #Account number
  [M:PCA1]BNKSRTCOD(LINE_NUMBER)    = [F:PCA]BNKSRTCOD(LINE_NUMBER)    #Sort Code
  [M:PCA1]BSOROL(LINE_NUMBER)       = [F:PCA]BSOROL(LINE_NUMBER)       #Building society roll number
  [M:PCA1]DEFFND(LINE_NUMBER)       = [F:PCA]DEFFND(LINE_NUMBER)       #Default fund
End

#**
#* Save the extra auto-enrolment details
#* @param ORG_OFFSET Some sort of organisation offset
#*!
Subprog SAVE_AE_DETAILS (ORG_OFFSET)
  Value Integer ORG_OFFSET
  Local Integer I
  For [L]I=0 To [M:PCA1]TBL-1
    [F:PCA]DEFEMEPRC(ORG_OFFSET+[L]I)    = [M:PCA1]DEFEMEPRC([L]I)    #Default employee percentage
    [F:PCA]DEFEMRPRC(ORG_OFFSET+[L]I)    = [M:PCA1]DEFEMRPRC([L]I)    #Default employer percentage
    [F:PCA]QUASCH(ORG_OFFSET+[L]I)       = [M:PCA1]QUASCH([L]I)       #Qualifying scheme
    [F:PCA]SALSAC(ORG_OFFSET+[L]I)       = [M:PCA1]SALSAC([L]I)       #Salary sacrifice
    [F:PCA]DEDLEL(ORG_OFFSET+[L]I)       = [M:PCA1]DEDLEL([L]I)       #Deduct lower earning limit
    [F:PCA]APPUEL(ORG_OFFSET+[L]I)       = [M:PCA1]APPUEL([L]I)       #Apply upper earnings limit
    [F:PCA]USEUAP(ORG_OFFSET+[L]I)       = [M:PCA1]USEUAP([L]I)       #Use uppaer accrual point as limit
    [F:PCA]DEDBASRAT(ORG_OFFSET+[L]I)    = [M:PCA1]DEDBASRAT([L]I)    #Deduct basic rate tax
    [F:PCA]APPUPPQUAERN(ORG_OFFSET+[L]I) = [M:PCA1]APPUPPQUAERN([L]I) #Apply upper threshold of qualifying earnings
    [F:PCA]CTRBAS(ORG_OFFSET+[L]I)       = [M:PCA1]CTRBAS([L]I)       #Contract based
    [F:PCA]BNKACCTYP(ORG_OFFSET+[L]I)    = [M:PCA1]BNKACCTYP([L]I)    #Bank account type
    [F:PCA]BNKACCNUM(ORG_OFFSET+[L]I)    = [M:PCA1]BNKACCNUM([L]I)    #Account number
    [F:PCA]BNKSRTCOD(ORG_OFFSET+[L]I)    = [M:PCA1]BNKSRTCOD([L]I)    #Sort Code
    [F:PCA]BSOROL(ORG_OFFSET+[L]I)       = [M:PCA1]BSOROL([L]I)       #Building society roll number
    [F:PCA]DEFFND(ORG_OFFSET+[L]I)       = [M:PCA1]DEFFND([L]I)       #Default fund
  Next
End

