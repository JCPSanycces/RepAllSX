#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
Endcase
Return
############################################################
$OUVRE
If PARAM(1) = ""
  FIN = 1
Else
  If clalev([F:QLC]) = 0 : Local File QLYCRD    [QLC] : Endif
  If clalev([F:QLQ]) = 0 : Local File QLYCRDQST [QLQ] : Endif    # hcb V6CQ
  If clalev([F:TFO]) = 0 : Local File TABFOR    [TFO] : Endif    # hcb V6CQ

Endif
Return
############################################################
$DEBUT
Raz [M:VQLC]
#
Filter [QLC] Where QLYCRD = PARAM(1)
nolign = 0
For [QLC]
  If nolign < dim([M:VQLC]TEX)-1
    nolign += 1
    [M:VQLC] = [F:QLC]
    Call LECTEXTRA([M:VQLC]TEX(nolign-1),"QLYCRD","QSTTEXAXX",[F:QLC]QLYCRD,num$([F:QLC]NUMLIN)) From ATEXTRA # hcb 115513

    #-- S'il s'agit d'une question            # hcb V6CQ
    If [F:QLC]QSTNUM <> ""                    # hcb V6CQ
       Read [QLQ]QLQ0=[F:QLC]QSTNUM           # hcb V6CQ
       If fstat                               # hcb V6CQ
          Raz [F:QLQ]                         # hcb V6CQ
       Endif                                  # hcb V6CQ
       [M:VQLC] = [F:QLQ]                     # hcb V6CQ
       If [F:QLQ]DEMCTLTYP=2
          If [F:QLQ]DEMASWTYP=1
             [M:VQLC]STRVAL(nolign-1) = [F:QLQ]ALPSTRVAL
             [M:VQLC]ENDVAL(nolign-1) = [F:QLQ]ALPENDVAL
             [M:VQLC]NMNVAL(nolign-1) = [F:QLQ]ALPNMNVAL                   # hcb V6CQ
             If clalev([F:ITF]) > 0 
                If  [F:QLQ]STRVALFOR <> ""  
                    Call VALTFO_CHAR(32,[F:QLQ]STRVALFOR,[M:VQLC]STRVAL(nolign-1)) From SUBTFO
                Endif
                If  [F:QLQ]ENDVALFOR <> ""  
                    Call VALTFO_CHAR(32,[F:QLQ]ENDVALFOR,[M:VQLC]ENDVAL(nolign-1)) From SUBTFO
                Endif
             Endif

          Else
             [M:VQLC]STRVAL(nolign-1) = num$([F:QLQ]NUMSTRVAL)
             [M:VQLC]ENDVAL(nolign-1) = num$([F:QLQ]NUMENDVAL)
             [M:VQLC]NMNVAL(nolign-1) = num$([F:QLQ]NUMNMNVAL)             # hcb V6CQ
             If clalev([F:ITF]) > 0 
                Local Decimal STRVAL 
                If  [F:QLQ]STRVALFOR <> ""  
                    Call VALTFO_NUM(32,[F:QLQ]STRVALFOR,STRVAL) From SUBTFO
                    [M:VQLC]STRVAL(nolign-1) = num$(STRVAL)
                Endif
                If  [F:QLQ]ENDVALFOR <> ""  
                    Raz STRVAL
                    Call VALTFO_NUM(32,[F:QLQ]ENDVALFOR,STRVAL) From SUBTFO
                    [M:VQLC]ENDVAL(nolign-1) = num$(STRVAL)
                Endif
             Endif

          Endif
       Endif
    Endif                                     # hcb V6CQ
  Endif
Next
Filter [QLC]
[M:VQLC]BASTAB = nolign
If [M:VQLC]QLYCRD <> ""
  Affzo [M:VQLC]
Else
  FIN = 1
Endif
Return

########################################
Subprog AS_BASTAB
If [M]QSTNUM(nolign-1) = ""
  GBOUT1 = ""
Endif
End

