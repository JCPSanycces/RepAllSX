#<AdxTL>@(#)9.0.0.0 $Revision$ Consultation AUD
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(10)(1..7)
PARAM(1)= "100101"
PARAM(2)= "100121"
PARAM(3) = "CCL"
PARAM(4) =""
PARAM(5) =""
PARAM(6) =""
PARAM(7) = "1"
GCONSULT = 0
Call GCONSULT("AUH","",PARAM) From GCONSULT
End

$ACTION
Case BOITE
 When "FCNSAUH"
  Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "LECTURE"    : Gosub LECTURE
  Endcase
 When "FCNSAUH2"
  Case ACTION
   When "DEBUT"      : Gosub DEBUT
  Endcase
 When "DCRITAUH"
  Case ACTION
   When "DEB_CRIT"   : Gosub SET_ECRAN
  Endcase
Endcase
Return

$OUVRE
If clalev([F:AUD])=0 : Local File AUDITH  [AUD] : Endif
If clalev([F:AUL])=0 : Local File AUDITL  [AUL] : Endif
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:AOB])=0 : Local File AOBJET  [AOB] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If clalev([F:ACN])=0 : Local File ACONSULT [ACN] : Endif

Local Char    CRITENT(250) , CRITSUI(250)
Local Integer SEQUENCE , MAXLIG , DET
Local Char    CHAMP(20)
Local Integer I,II
Local Char    ACT(10)
MAXLIG = dim([M:CAU2]SEQ)

Gosub DEFCRIT

# init periode
If [M:CAU1]STRDAT=[0/0/0] & [M:CAU1]ENDDAT=[0/0/0]
 [M:CAU1]STRDAT = GDATEDEB
 [M:CAU1]ENDDAT = GDATEFIN
Endif
Return

$DEFCRIT
For I=1 To dim(PARAM)
 Case I
   When 1 : # STRDAT
    If instr(1,PARAM(I),"/")
     [M:CAU1]STRDAT= "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CAU1]STRDAT= PARAM(I)
    Endif
   When 2 : # ENDDAT
    If instr(1,PARAM(I),"/")
     [M:CAU1]ENDDAT= "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CAU1]ENDDAT= PARAM(I)
    Endif
   When 3 : # USER
    If PARAM(I)<>""
     Call LECTURE("AUS",PARAM(I),"") From CONTOBJ
     If !fstat
      [M:CAU1]USER = PARAM(I)
     Endif
    Endif
   When 4 : # TABLE
    If PARAM(I)<>""
     Call LECTURE("ATB",PARAM(I),"") From CONTOBJ
     If !fstat
      [M:CAU1]TABLE= PARAM(I)
     Endif
    Endif
   When 5 : # LOGIN
    [M:CAU1]LOGIN= PARAM(I)
   When 6 : # EVENEMENT
    If PARAM(I) <> ""
     For II=6 To 1 Step-1
      For ACT="INSERT","UPDATE","DELETE"
       If left$(PARAM(I),II)=left$(ACT,II)
        [M:CAU1]EVENEMENT= ACT : Break 2
       Endif
      Next ACT
     Next I
   Endif
   When 7 :
    If PARAM(I) <> "" & dim([M:CAU1]AUDBI)>0
     [M:CAU1]AUDBI= val(PARAM(I))
    Endif
  Endcase
Next
Return

$LECTURE
Gosub CRITENT
Gosub CRITSUI
NOL = 0
SUITE  = 1
RETOUR = 1
If CHGPAG>0
 Filter [AUD] Where evalue(CRITENT) & evalue(CRITSUI)
&             Order By Key CLE=[F:AUD]SEQ
 NOL = 0
 For [AUD]CLE
  If NOL>=MAXLIG
   SUITE = 2 : Break
  Else
   If CHGPAG=2 : RETOUR = 2 : Endif
   NOL += 1
   Gosub CHARGE
  Endif
 Next
 [M:CAU2]NBLIG = NOL
Else
 Filter [AUD] Where evalue(CRITENT) & evalue(CRITSUI)
&             Order By Key CLE=[F:AUD]SEQ Desc
 NOL = MAXLIG+1
 For [AUD]CLE
  If NOL<=1
   RETOUR = 2 : Break
  Else
   If CHGPAG=-2 : SUITE = 2 : Endif
   NOL -= 1
   Gosub CHARGE
  Endif
 Next
 [M:CAU2]NBLIG = MAXLIG
Endif
NOL -= 1
Return

$CHARGE
If NBLU=1
 NBLU = 2
 If CHGPAG=2 or CHGPAG=-2 : Raz [M:CAU2] : Endif
Endif
nolign = NOL
[M:CAU2] = [F:AUD]
Return

$SET_ECRAN
If [M:CAUH]ECRAN = ""
 Call LECTURE("ACN","AUH","") From CONTOBJ
 If !fstat & [ACN]SCRCOD <> ""
  [M:CAUH]ECRAN = [ACN]SCRCOD
 Endif
Endif
Return

$CRITENT
CRITENT = ""
If [M:CAU1]STRDAT<>[0/0/0]
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= "[AUD]DAT>=["+format$(GFMD,[M:CAU1]STRDAT)+"]"
Endif
If [M:CAU1]ENDDAT<>[0/0/0]
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= "[AUD]DAT<=["+format$(GFMD,[M:CAU1]ENDDAT)+"]"
Endif
If [M:CAU1]TABLE<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]TBL="'+[M:CAU1]TABLE+'"'
Endif
If [M:CAU1]USER<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]ADOUSR="'+[M:CAU1]USER+'"'
Endif
If [M:CAU1]LOGIN<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]SYSUSR="'+[M:CAU1]LOGIN+'"'
Endif
If [M:CAU1]EVENEMENT<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AUD]EVT="'+[M:CAU1]EVENEMENT+'"'
Endif
If dim([M:CAU1]AUDBI)>0
 If CRITENT<>"" : CRITENT -= "&" : Endif
 If [M:CAU1]AUDBI=2
  CRITENT -= '[AUD]STABI=2'
 Else
  CRITENT -= '[AUD]STABI<2'
 Endif
Endif
If CRITENT=""
 CRITENT = "1=1"
Endif
Return

$CRITSUI
CRITSUI = ""
Case CHGPAG
 When 2
  If [M:CAU2]NBLIG>0
   SEQUENCE = [M:CAU2]SEQ([M:CAU2]NBLIG-1)
   CRITSUI = '[AUD]SEQ>'+num$(SEQUENCE)
  Endif
 When -2
  If [M:CAU2]NBLIG>0
   SEQUENCE = [M:CAU2]SEQ(0)
   CRITSUI = '[AUD]SEQ<'+num$(SEQUENCE)
  Endif
Endcase
If CRITSUI=""
 CRITSUI = "1=1"
Endif
Return

######################################################################################
## Ecran CAU1
######################################################################################
Subprog C_EVENEMENT(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    ACT(10)
If VALEUR<>""
 mkstat = 2
 For I=6 To 1 Step-1
  For ACT="INSERT","UPDATE","DELETE"
   If left$(VALEUR,I)=left$(ACT,I)
    VALEUR = ACT : mkstat = 0 : Break 2
   Endif
  Next ACT
 Next I
Endif
End

Subprog B1_NBLIG
Local Integer NOL , I , J , K , NBTEX, OBJSEL
Local Char    CLE1(GLONID1) , CLE2(GLONID2)(16)
Local Char    CHAINE(250) , CLE(GLONID1)
Local Char    OBJET(GLONAOB)(1..30) , TEXTE(GLONAOB+1+GLONDES)(1..30)
NOL = nolign-1
Filter [AOB] Where NOMFIC=[M]TBL(NOL)
Case rowcount([F:AOB])
 When 0
  Call MESSAGE(mess(19,137,1)-[M]TBL(NOL)) From GESECRAN : # Objet non trouvé
 When 1
  Read [AOB]NOMFIC(1) = [M]TBL(NOL)
  OBJET(1) = [F:AOB]ABREV
  [L]OBJSEL=1
 When Default
  NBTEX = 0
  For [AOB]
   If NBTEX<dim(TEXTE)
    NBTEX += 1
    Call TEXTE([F:AOB]LIBEL,TEXTE(NBTEX)) From OBJDIV
    OBJET(NBTEX) = [F:AOB]ABREV     # Issue X3-50157 - 2018-06-19 by CCC : store object codes to be able to call the selected one
    TEXTE(NBTEX) = [F:AOB]ABREV-TEXTE(NBTEX)
   Endif
  Next AOB
  Call SAITEX(NBTEX,TEXTE,[L]OBJSEL,mess(4,42,1)) From GESECRAN : # Objets
Endcase
Filter [AOB]
If [L]OBJSEL=0 : End : Endif
If [M]ID2(NOL)=""
 CLE1    = [M]ID1(NOL)
Else
 CLE2(0) = [M]ID1(NOL)
 CHAINE  = [M]ID2(NOL)
 K = 0
 While CHAINE<>""
  I = instr(1,CHAINE,"~")
  If I
   CLE    = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE    = CHAINE
   CHAINE = ""
  Endif
  If K=0
   CLE1 = CLE
  Else
   CLE2(K) = CLE
  Endif
  K += 1
 Wend
Endif

Call OBJET(OBJET([L]OBJSEL),CLE1,CLE2) From GOBJET
End

$DEBUT
Local Integer SEQUENCE
SEQUENCE = [M:CAU2]SEQ(nolign-1)
nolign = 0
For [AUL]AUL0 Where SEQ=SEQUENCE
 nolign += 1
 [M:AU3] = [F:AUL]
Next
If nolign=0
 Call MESSAGE(mess(40,127,1)) From GESECRAN : # Pas de détail
 FIN = 1
Else
 [M:AU3]NBLIG = nolign
 Affzo [AU3]
Endif
Return

