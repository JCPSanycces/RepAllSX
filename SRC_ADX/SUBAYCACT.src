#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
## Xtend:  Gestion Menu Xtend
## Actions X3
#  Version 0001
#
######################################################################################
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 

Case ACTION
 When "OUVRE"            : Gosub OUVRE
 When "DEBUT"            : Gosub DEBUT
 When "END"              : Gosub ENDD
 When "FIN"              : Gosub FIN
 When "SEL_LISTE"        : Gosub SEL_LISTE
 When "TRT_DIV"          : Gosub TRT_DIV
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
#      AYCADDLIN                     Ajout ligne menu
#      AYCADDLIN1                    Ajout plusieurs lignes 
#      AYCMAJLIN                     Modification ligne menu
######################################################################################
$TRT_DIV
Case TRAIT
Endcase
#   When "FIECTL" : Gosub FIE_CTL
Return

$SEL_LISTE
Case LISTE
Endcase
Return


$OUVRE
Case GACTION
  When "AYCADDLIN1": Gosub ADDLIN1_OUV
  When "AYCADDLIN" : Gosub ADDLIN1_OUV
  When "AYCMAJLIN" : Gosub ADDLIN1_OUV
Endcase
Return

$DEBUT
Case GACTION
  When "AYCADDLIN1": Gosub ADDLIN1_DEB
  When "AYCADDLIN" : Gosub ADDLIN_DEB
  When "AYCMAJLIN" : Gosub MAJLIN_DEB
Endcase
Return

$ENDD
Case GACTION
  When "AYCADDLIN1": Gosub ADDLIN1_END
  When "AYCADDLIN" : Gosub ADDLIN_END
  When "AYCMAJLIN" : Gosub ADDLIN1_END
Endcase
Return

$FIN
Case GACTION
  When "AYCADDLIN1": Gosub ADDLIN1_FIN
  When "AYCADDLIN" : Gosub ADDLIN1_FIN
  When "AYCMAJLIN" : Gosub ADDLIN1_FIN
Endcase
Return


#    AYCADDLIN1        Ajout ligne menu
######################################################################################
#    Nota: action suivi d'une action std sur le bouton pour récupérer les infos 
#            de l'écran [AC8]
$ADDLIN1_OUV
#---------------------------------------------------------------#
Local Integer SAVNOL  : SAVNOL  = nolign
Local Integer AYC1NOL : AYC1NOL = SAVNOL-1
Return

$ADDLIN1_DEB
#---------------------------------------------------------------#
Raz [M:AYC8]
[M:AYC8]LNLIBORI_8  = 1
Call LIBORI_8_AFF([M:AYC1]GESOPT,[M:AYC8]LNLIBORI_8 )
Return

$ADDLIN1_END
#---------------------------------------------------------------#
Raz [M:AYC8]    # Arrêt utilisateur, pas d'infos à transmettre
Return

$ADDLIN1_FIN
#---------------------------------------------------------------#
nolign = SAVNOL
Return


#    AYCADDLIN        Ajout n lignes menu
######################################################################################
#    Nota: action suivi d'une action std sur le bouton pour récupérer les infos 
#            de l'écran [AC9]
$ADDLIN_DEB
#---------------------------------------------------------------#
Raz [M:AYC9]
Return

$ADDLIN_END
#---------------------------------------------------------------#
Raz [M:AYC9]    # Arrêt utilisateur, pas d'infos à transmettre
Return



#    AYCMAJLIN        Mise à jour ligne menu
######################################################################################
#    Nota: action suivi d'une action std sur le bouton pour récupérer les infos 
#            de l'écran [AC8]

$MAJLIN_DEB
#---------------------------------------------------------------#
Raz [M:AYC8]
[M:AYC8]LNLIBORI_8  = [M:AYC1]LNLIBORI10(AYC1NOL)
[M:AYC8]LNCHP_8     = [M:AYC1]LNCHP10(AYC1NOL)   
[M:AYC8]LNCHPNUM_8  = [M:AYC1]LNCHPNUM10(AYC1NOL)
[M:AYC8]LNADV_8     = [M:AYC1]LNADV10(AYC1NOL)   
[M:AYC8]LNADI_8     = [M:AYC1]LNADI10(AYC1NOL)   
[M:AYC8]LNADISHO_8  = [M:AYC1]LNADISHO10(AYC1NOL)
[M:AYC8]LNVAL_8     = [M:AYC1]LNVAL10(AYC1NOL)   
[M:AYC8]LNDLK_8     = [M:AYC1]LNDLK10(AYC1NOL)  
[M:AYC8]LNFIECOD_8  = [M:AYC1]LNFIECOD10(AYC1NOL)  

Call LIBORI_8_AFF([M:AYC1]GESOPT,[M:AYC8]LNLIBORI_8)
Case [M:AYC8]LNLIBORI_8
When 1
 [M]WLNCHDES_8 = func CHAP_DES([M:AYC8]LNCHP_8)
 [M]WLNDES_8   = mess([M:AYC8]LNCHPNUM_8, [M:AYC8]LNCHP_8, 1)
When 2
 [M]WLNDES_8  = func ADI_LNDES([M:AYC8]LNADV_8, [M:AYC8]LNADI_8, [M:AYC8]LNADISHO_8)
Endcase
Affzo [M:AYC8]
Return



######################################################################################
## Utilitaires
######################################################################################
# Gestion chps à saisir en fct de l'origine (mode auto, message ou table diverse)
Subprog LIBORI_8_AFF(GESOPT, LNLIBORI_8)
Value Integer    GESOPT
Value Integer    LNLIBORI_8
Raz WLNDES_8
If GESOPT=2
    Grizo [M:AYC8]5,10,20
Else
    If LNLIBORI_8=1
        Raz [M:AYC8]LNADV_8,LNADI_8,LNADISHO_8
        Grizo [M:AYC8]20
        Actzo [M:AYC8]LNCHP_8, LNCHPNUM_8
    Else
        Raz [M:AYC8]LNCHP_8,LNCHPNUM_8
        Grizo [M:AYC8]LNCHP_8,LNCHPNUM_8
        Actzo [M:AYC8]LNADV_8, LNADI_8, LNADISHO_8
    Endif
Endif
End

# Affichage titre d'un chapitre
Funprog CHAP_DES(CHAPITRE)
Value Integer CHAPITRE
Local Char DES (80)
Read [AML]MENLOC = CHAPITRE
If !fstat
    If [AML]MENLOCAL=2
     If CHAPITRE<100 
      Read [AST]CLE = 0;CHAPITRE;GLANGUE 
     Else
      Read [AST]CLE = 200;CHAPITRE-200;GLANGUE 
     Endif
    Else
     Read [AST]CLE = CHAPITRE;0;GLANGUE
    Endif
    If !fstat
     DES = [F:AST]LANMES
    Endif
Endif
End DES

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
## Ecran AYCMAJLIN
######################################################################################
Subprog AM_LNLIBORI_8(VALEUR)
Variable Integer VALEUR
Call LIBORI_8_AFF([M:AYC1]GESOPT,VALEUR)
Affzo 5
End

Subprog AM_LNCHP_8(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
 [M]WLNCHDES_8 = func CHAP_DES(VALEUR)
 If LNCHPNUM_8<>0
   WLNDES_8=mess(LNCHPNUM_8, VALEUR, 1)
 Endif
Else
 WLNDES_8=""
Endif
Affzo 5
End

Subprog AM_LNCHPNUM_8(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 and LNCHP_8<>0
 WLNDES_8=mess(VALEUR, LNCHP_8, 1)
Else
 WLNDES_8=""
Endif
Affzo 5
End

Subprog AS_LNVAL_8(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   If LNLIBORI_8=1    
        VALEUR = num$(LNCHPNUM_8)
   Elsif LNLIBORI_8=2   
        VALEUR = LNADI_8
   Endif
Endif
End

Funprog ADI_LNDES(ADV, ADI, FLGSHO)
Value Integer ADV
Value Char    ADI
Value Integer FLGSHO
Local Char WRES (80)
  If FLGSHO=2
    Call LECTEXTRA(WRES,"ATABDIV","SHODES",num$(ADV),ADI) From ATEXTRA
  Else 
    Call LECTEXTRA(WRES,"ATABDIV","LNGDES",num$(ADV),ADI) From ATEXTRA
  Endif
End WRES

Subprog AM_LNADV_8(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
 If LNADI_8<>""
    WLNDES_8 = func ADI_LNDES(VALEUR, LNADI_8, LNADISHO_8)
 Endif
Else
 WLNDES_8=""
Endif
Affzo [AYC8]WLNDES_8
End

Subprog AM_LNADI_8(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    WLNDES_8 = func ADI_LNDES(LNADV_8, VALEUR, LNADISHO_8)
Else
 WLNDES_8=""
Endif
Affzo [AYC8]WLNDES_8
End

Subprog AM_LNADISHO_8(VALEUR)
Variable Integer VALEUR
WLNDES_8 = func ADI_LNDES(LNADV_8, LNADI_8, VALEUR)
Affzo [AYC8]WLNDES_8
End


######################################################################################
## écran AYCADDLIN [AYC9]
######################################################################################
Subprog AS_LNLIBORI_9(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If NOL=0
    VALEUR=1
Else
    VALEUR=LNLIBORI_9(NOL-1)
Endif
End

Subprog AM_LNLIBORI_9(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If VALEUR=1
    Effzo LNADV_9(NOL),LNADI_9(NOL),LNADISHO_9(NOL)
    Grizo LNADV_9(NOL),LNADI_9(NOL),LNADISHO_9(NOL)
    Actzo LNCHP_9(NOL),LNCHPNUM_9(NOL)
Else
    Effzo LNCHP_9(NOL),LNCHPNUM_9(NOL)
    Grizo LNCHP_9(NOL),LNCHPNUM_9(NOL)
    Actzo LNADV_9(NOL),LNADI_9(NOL),LNADISHO_9(NOL)
Endif
End

Subprog AS_LNCHP_9(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If NOL
    VALEUR=LNCHP_9(NOL-1)
Endif
End

Subprog AM_LNCHP_9(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Effzo WLNDES_9(NOL),LNCHPNUM_9(NOL)
Affzo WLNDES_9(NOL)
End

Subprog AS_LNCHPNUM_9(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If NOL<>0 and VALEUR=0 and LNCHP_9(NOL-1)=LNCHP_9(NOL)    # aide saisie
    # Vérif. existence message suivant
    Local Integer RET
    Read [AST]CLE=LNCHP_9(NOL);LNCHPNUM_9(NOL-1)+1;GLANGUE      # Dossier en-cours
    If fstat=0        # Trouvé
        VALEUR=LNCHPNUM_9(NOL-1)+1
    Endif    
Else
    VALEUR=1
Endif
End

Subprog AM_LNCHPNUM_9(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Local Char WTMP1, WTMP2
Call LNDES(LNLIBORI_9(NOL),LNCHP_9(NOL),VALEUR,LNADV_9(NOL),LNADI_9(NOL),LNADISHO_9(NOL),
&            1,"","","",
&            WLNDES_9(NOL),WTMP1, WTMP2) From SUBAYC
Affzo WLNDES_9(NOL)
End

Subprog AS_LNADV_9(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If NOL
    VALEUR=LNADV_9(NOL-1)
Endif
End

Subprog AM_LNADV_9(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
Effzo WLNDES_9(NOL),LNADI_9(NOL)
Affzo WLNDES_9(NOL)
End

Subprog AM_LNADI_9(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char WTMP1, WTMP2
Call LNDES(LNLIBORI_9(NOL),LNCHP_9(NOL),LNCHPNUM_9(NOL),LNADV_9(NOL),VALEUR,LNADISHO_9(NOL),
&            1,"","","",
&            WLNDES_9(NOL),WTMP1, WTMP2) From SUBAYC
Affzo WLNDES_9(NOL)
End

Subprog AM_LNADISHO_9(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Local Char WTMP1, WTMP2
Call LNDES(LNLIBORI_9(NOL),LNCHP_9(NOL),LNCHPNUM_9(NOL),LNADV_9(NOL),LNADI_9(NOL),VALEUR,
&            1,"","","",
&            WLNDES_9(NOL),WTMP1, WTMP2) From SUBAYC
Affzo WLNDES_9(NOL)
End

Subprog AS_LNVAL_9(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If VALEUR=""
    Case LNLIBORI_9(NOL)
    When 1
        VALEUR = num$(LNCHPNUM_9(NOL))
    When 2
        VALEUR = LNADI_9(NOL)
    Endcase
Endif
End


