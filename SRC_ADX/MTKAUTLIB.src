#**
#* ARRQTY : Arrondi une quantité selon le paramètre PQTYRND (au plus proche, supérieure, inférieure)
#*
#* @param PQTY    = Quantité à arrondir
#* @param PQTYRND = 1: Au plus proche; 2-Supérieure; 3-Inférieure (voir menu local 293)
#* @param PUOM    = Unité donnant le nombre de décimales
#*!
Funprog ARRQTY(PQTY,PQTYRND,PUOM)
Value Decimal PQTY
Value Integer PQTYRND
Value Char    PUOM

Local    Decimal WQTY, WRKN0, WRKN1

If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If PUOM <> "" & PUOM<>[F:TUN]UOM
    Read [TUN]TUN0 = PUOM : If fstat Raz [F:TUN] Endif
Endif

WRKN0 =  PQTY*10^[F:TUN]UOMDEC
WRKN1 = (PQTY*10^[F:TUN]UOMDEC - int(WRKN0))
Case PQTYRND
  When 2 :  # Arrondi supérieur
    If WRKN1 <> 0
        WQTY = (WRKN0 - WRKN1 + 1)*10^-[F:TUN]UOMDEC
    Else
        WQTY = (WRKN0 - WRKN1)*10^-[F:TUN]UOMDEC
    Endif

  When 3 : # arrondi inférieur
    WQTY = (WRKN0 - WRKN1)*10^-[F:TUN]UOMDEC

  When Default :
    WQTY = arr(PQTY,10^-[F:TUN]UOMDEC)
Endcase

End WQTY

