#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SINVOICEV
#######################################################################################
End

#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AREAD_AFTER"             : Gosub AREAD_AFTER                     From SINVOICEV_CSTD_METHODS
          When "AINIT"                   : Gosub AINIT                           From SINVOICEV_CSTD_METHODS
        Endcase
     When "C_PAM"
        Case [L]AEVENT
          When "AREAD_AFTER"             : Gosub AREAD_AFTER_C_PAM               From SINVOICEV_CSTD_METHODS
        Endcase
     When "SIH"
        Case [L]AEVENT
          When "AREAD_BEFORE"            : Gosub AREAD_BEFORE_SIH                From SINVOICEV_CSTD_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
        Endcase
     When "SID.C_VACITM"
        Case [L]AEVENT
          When "AREAD_AFTER"             : Gosub AREAD_AFTER_SID_C_VACITM        From SINVOICEV_CSTD_METHODS # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
        Endcase
     When "SVV"
        Case [L]AEVENT
          When "AREAD_BEFORE"            : Gosub AREAD_BEFORE_SVV                From SINVOICEV_CSTD_METHODS # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
          When "AREAD_AFTER"             : Gosub AREAD_AFTER_SVV                 From SINVOICEV_CSTD_METHODS # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
        Endcase
     When "SVF"
        Case [L]AEVENT
          When "AREAD_BEFORE"            : Gosub AREAD_BEFORE_SVF                From SINVOICEV_CSTD_METHODS # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
          When "AREAD_AFTER"             : Gosub AREAD_AFTER_SVF                 From SINVOICEV_CSTD_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
        Endcase
     When "SVF.C_DTAVAT"
        Case [L]AEVENT
          When "AREAD_AFTER"             : Gosub AREAD_AFTER_SVF_C_DTAVAT        From SINVOICEV_CSTD_METHODS # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSCCODADI"          : Gosub INIT_TSCCODADI                        From SINVOICEV_CSTD_METHODS
  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES

  Case [L]CURPRO
    When "CPY"                     : Gosub CPY                                   From SINVOICEV_CSTD_PROPERTIES # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  Endcase

Return

