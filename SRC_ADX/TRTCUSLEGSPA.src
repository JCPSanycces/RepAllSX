#<AdxTL>@(#)1.0.0.0 $Revision$
############################################################
#
#  Legal spanish customs informations for table PINVOICE
#
# Window AWI=>CUSLEGSPA
# Mask/Screen AMK=>CUSLEGSPA [CUSSP]
#
############################################################


$ACTION
Case ACTION 
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
Endcase
Return

$OUVRE
#----- Paramètres de l'action DATALEG -----#
Local Char INVOICE(GLONVCR)

[L]INVOICE = PARAM(1)

#----- Tables utilisée -----#
If !clalev([F:PIH]) : Local File PINVOICE [PIH] : Endif
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif
If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif

#----- Masque local -----#
Local Mask CUSLEGSPA [CUSSP]

#----- Variables locales pour sauvegarde du masque -----#
Local Date SPACUSDAT
Local Char SPACUS(40)
Local Char SPACUSBPR(GLONBPR)
Return

$DEBUT
#--- Alimentation des champs de l'écran ---#
#Local Libelle TYPLEDGEN,TYPLEDANA
#Local Char CODLED(GLONLED),CURLED(GLONCUR)
#
Read [PIH]PIH0 = [L]INVOICE
If !fstat
 [M:CUSSP] = [F:PIH]
Endif

#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:CUSSP]

Affzo [M:CUSSP]
Return

$ENR
Trbegin [PIH]
Readlock [PIH]PIH0 = [L]INVOICE
If !fstat
 [F:PIH] = [M:CUSSP]
 Rewrite [PIH]
 If fstat
  GOK = 0 : Call FSTA("PIH") From GLOCK : Return
 Endif
Endif
Commit
[L]=[M:CUSSP] : REP=""
Return

$ABA
[M:CUSSP]=[L]
REP=""
Gosub ENR
Affzo [M:CUSSP]
Return

$APRES_MODIF
Read [ALK]LCKCLE="PIH"+[L]INVOICE;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
 GMESSAGE=mess(10,100,1)
 GERR=1
 [M:CUSSP]=[L]
 Affzo [M:CUSSP] :# FIN=1
Else
 REP = "M"
 Local Char SYMB(20)
 SYMB="PIH"+[L]INVOICE
 Lock SYMB With lockwait=0
Endif
Return

$FIN
If dim(SYMB)>0
 Unlock SYMB
Endif
Return
#-------------------------------------------------------------------------------#

