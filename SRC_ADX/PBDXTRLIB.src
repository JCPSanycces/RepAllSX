Funprog TRIGGERING_ACCOUNTS( DBFIELD, ACCDESC )
Value Char DBFIELD
Value Char ACCDESC
    Local Clbfile ACCINCL, ACCEXCL
    Local Char ACC (20)
    Local Integer I, J, K, L

    Append ACCINCL, "1=0"
    Append ACCEXCL, "1=0"
    I = 1
    While I > 0                              # look for next blank as separator
      I = instr( 1, ACCDESC, " " )
      If I > 0                               # blank found -> check account
        ACC     = left$(  ACCDESC, I - 1 )   # get next root account
        ACCDESC = right$( ACCDESC, I + 1 )
      Else
        ACC = ACCDESC                        # no more blank -> get last account
      Endif

      If right$( ACC, len(ACC) ) = "*"
          ACC = left$( ACC, len(ACC) - 1 )
          If right$( ACC, len(ACC) ) = ")"
              J = instr( 1, ACC, "(" )
              Append ACCINCL, " or left$(" + DBFIELD + "," + num$( J - 1 ) + ")='" + left$( ACC, J - 1 ) + "'"
              ACC = left$( ACC, J - 1 ) + mid$( ACC, J + 1, len(ACC) - J - 1 )
              Append ACCEXCL, " or left$(" + DBFIELD + "," + num$( len(ACC) ) + ")='" + ACC + "'"
          Else
              Append ACCINCL, " or left$(" + DBFIELD + "," + num$( len(ACC) ) + ")='" + ACC + "'"
          Endif
      Else
          Append ACCINCL, " or " + DBFIELD + "='" + ACC + "'"
      Endif
    Wend
End "(" + ACCINCL + ") and not (" + ACCEXCL + ")"


Funprog DATA_TO_INCLUDE( PBDCONFIG, ACCROOT, BPR, DOCTYPE, ACCSIGN )
Variable Instance PBDCONFIG Using C_PBDCONFIG
Value Char ACCROOT
Value Char BPR
Value Char DOCTYPE
Value Char ACCSIGN
    Local Clbfile DATINCL
    Local Instance PBDCONFIGLINE Using C_PBDCONFIGD
    Local Char TMPVAL (255)
    If !clalev( [F:PBDBPD] ) : Local File PBDBPGRPD    [PBDBPD] : Endif

    Append DATINCL, "1=0"
    For I = 1 To maxtab( PBDCONFIG.LINESINCL )
        PBDCONFIGLINE = PBDCONFIG.LINESINCL( I )
        If ( PBDCONFIGLINE.ASTALIN <> [V]CST_ADEL )
&          and ( PBDCONFIGLINE.ASTALIN <> [V]CST_ANEWDEL )
            Append DATINCL, " or (1=1"

            # Root account
            TMPVAL = PBDCONFIGLINE.CROOTACC
            If right$( TMPVAL, len(TMPVAL) ) = "*"
                TMPVAL = left$( TMPVAL, len( TMPVAL ) - 1 )
                Append DATINCL, " and left$(" + ACCROOT + "," + num$( len(TMPVAL) ) + ")='" + TMPVAL + "'"
            Else
                Append DATINCL, " and " + ACCROOT + "='" + TMPVAL + "'"
            Endif

            # PBD business partner group
            If ( BPR <> "" ) and ( PBDCONFIGLINE.BPGROUP <> "" )
                Append DATINCL, " and (1=0"
                For [F:PBDBPD]PBDBPD0 Where COD = PBDCONFIGLINE.BPGROUP and LEG = PBDCONFIGLINE.LEG
                    TMPVAL = [F:PBDBPD]BPR
                    If right$( TMPVAL, len(TMPVAL) ) = "*"
                        TMPVAL = left$( TMPVAL, len( TMPVAL ) - 1 )
                        If len(TMPVAL) > 0
                            Append DATINCL, " or left$(" + BPR + "," + num$( len(TMPVAL) ) + ")='" + TMPVAL + "'"
                        Else
                            Append DATINCL, " or 1=1"
                        Endif
                    Else
                        Append DATINCL, " or " + BPR + "='" + TMPVAL + "'"
                    Endif
                Next
                Append DATINCL, ")"
            Endif

            # Document type
            If ( DOCTYPE <> "" ) and ( PBDCONFIGLINE.DOCTYPE <> "" )
                Append DATINCL, " and " + DOCTYPE + "='" + PBDCONFIGLINE.DOCTYPE + "'"
            Endif

            # 'Debit' or 'Credit'?
            If ( ACCSIGN <> "" ) and ( PBDCONFIGLINE.ACCSIGN <> 0 )
                Case PBDCONFIGLINE.ACCSIGN
                      When 1 # Local menu 610 'Debit'
                          Append DATINCL, " and " + ACCSIGN + ">0"
                      When 2 # Local menu 610 'Credit'
                          Append DATINCL, " and " + ACCSIGN + "<0"
                Endcase
            Endif

            Append DATINCL, ")"
        Endif
    Next
End "(" + DATINCL + ")"


Funprog DATA_TO_EXCLUDE( PBDCONFIG, ACCROOT, BPR, DOCTYPE )
Variable Instance PBDCONFIG Using C_PBDCONFIG
Value Char ACCROOT
Value Char BPR
Value Char DOCTYPE
    Local Clbfile DATEXCL
    Local Instance PBDCONFIGLINE Using C_PBDCONFIGD
    Local Char TMPVAL (255)
    If !clalev( [F:PBDBPD] ) : Local File PBDBPGRPD [PBDBPD] : Endif

    Append DATEXCL, "1=0"
    For I = 1 To maxtab( PBDCONFIG.LINESEXCL )
        PBDCONFIGLINE = PBDCONFIG.LINESEXCL( I )
        If ( PBDCONFIGLINE.ASTALIN <> [V]CST_ADEL )
&          and ( PBDCONFIGLINE.ASTALIN <> [V]CST_ANEWDEL )
            Append DATEXCL, " or (1=1"

            # Root account
            TMPVAL = PBDCONFIGLINE.CROOTACC
            If right$( TMPVAL, len(TMPVAL) ) = "*"
                TMPVAL = left$( TMPVAL, len( TMPVAL ) - 1 )
                Append DATEXCL, " and left$(" + ACCROOT + "," + num$( len(TMPVAL) ) + ")='" + TMPVAL + "'"
            Else
                Append DATEXCL, " and " + ACCROOT + "='" + TMPVAL + "'"
            Endif

            # PBD business partner group
            If ( BPR <> "" ) and ( PBDCONFIGLINE.BPGROUP <> "" )
                Append DATEXCL, " and (1=0"
                For [F:PBDBPD]PBDBPD0 Where COD = PBDCONFIGLINE.BPGROUP and LEG = PBDCONFIGLINE.LEG
                    TMPVAL = [F:PBDBPD]BPR
                    If right$( TMPVAL, len(TMPVAL) ) = "*"
                        TMPVAL = left$( TMPVAL, len( TMPVAL ) - 1 )
                        If len(TMPVAL) > 0
                            Append DATEXCL, " or left$(" + BPR + "," + num$( len(TMPVAL) ) + ")='" + TMPVAL + "'"
                        Else
                            Append DATEXCL, " or 1=1"
                        Endif
                    Else
                        Append DATEXCL, " or " + BPR + "='" + TMPVAL + "'"
                    Endif
                Next
                Append DATEXCL, ")"
            Endif

            # Document type
            If ( DOCTYPE <> "" ) and ( PBDCONFIGLINE.DOCTYPE <> "" )
                Append DATEXCL, " and " + DOCTYPE + "='" + PBDCONFIGLINE.DOCTYPE + "'"
            Endif

            Append DATEXCL, ")"
        Endif
    Next
End "not (" + DATEXCL + ")"


Funprog MATCH_DATA_TO_INCLUDE_LINE( PBDCONFIG, ACC, BPR, DOCTYPE, SNS, ECOCOD )
Variable Instance PBDCONFIG Using C_PBDCONFIG
Value Char ACC
Value Char BPR
Value Char DOCTYPE
Value Decimal SNS
Variable Char ECOCOD : Raz ECOCOD
    Local Integer OK
    Local Integer I
    Local Instance PBDCONFIGLINE Using C_PBDCONFIGD
    Local Char TMPVAL (255)

    If !clalev( [F:PBDBPD] ) : Local File PBDBPGRPD    [PBDBPD] : Endif

    For I = 1 To maxtab ( PBDCONFIG.LINESINCL )
        OK = 1
        PBDCONFIGLINE = PBDCONFIG.LINESINCL( I )
        If ( PBDCONFIGLINE.ASTALIN <> [V]CST_ADEL ) and ( PBDCONFIGLINE.ASTALIN <> [V]CST_ANEWDEL )

            # Account
            TMPVAL = PBDCONFIGLINE.CROOTACC
            If ( ( right$( TMPVAL, len(TMPVAL) ) = "*" ) and ( left$( ACC, len( TMPVAL ) - 1 ) = left$( TMPVAL, len( TMPVAL ) - 1 ) ) )
&               or ( ACC = TMPVAL )
            Else
                OK = 0
            Endif

            # BP
            If OK and ( PBDCONFIGLINE.BPGROUP <> "" )
                OK = 0
                For [F:PBDBPD]PBDBPD0 Where COD = PBDCONFIGLINE.BPGROUP and LEG = PBDCONFIGLINE.LEG
                    TMPVAL = [F:PBDBPD]BPR
                    If ( right$( TMPVAL, len(TMPVAL) ) <> "*" )
                        If TMPVAL = BPR
                            ECOCOD = [F:PBDBPD]ECOCOD
                            OK = 1
                            Break
                        Endif
                    Elsif ( TMPVAL = "*" ) or ( left$( TMPVAL, len( TMPVAL ) - 1 ) = left$( BPR, len( TMPVAL ) - 1 ) )
                        ECOCOD = [F:PBDBPD]ECOCOD
                        OK = 1
                        Break
                    Endif
                Next
            Endif

            # Document type
            If OK and ( PBDCONFIGLINE.DOCTYPE <> "" )
                If DOCTYPE <> PBDCONFIGLINE.DOCTYPE
                    OK = 0
                Endif
            Endif

            # Sign (debit or credit or undefined)
            If OK and  ( PBDCONFIGLINE.ACCSIGN <> 3 )
                Case PBDCONFIGLINE.ACCSIGN
                    When 1
                        If SNS < 0
                            OK = 0
                        Endif
                    When 2
                        If SNS > 0
                            OK = 0
                        Endif
                Endcase
            Endif

            If OK
                If PBDCONFIGLINE.PBDECO <> ""
                    ECOCOD = PBDCONFIGLINE.PBDECO
                Endif
                End I
            Endif
        Endif
    Next
End -1


########################################################################################################################
# Get the ISO 3166-1 2-letter code #####################################################################################

Funprog GET_ISO_3166_1_ALPHA2(VCRY)
  Value Char VCRY
  Local File TABCOUNTRY [TCY]
  Read [F:TCY]TCY0 = VCRY
  If fstat <> 0 Then
    End ""
  Endif
End [F:TCY]ISO

########################################################################################################################
# Get the ISO 3166-1 3-letter code #####################################################################################

Funprog GET_ISO3166_1_ALPHA3( CRY )
Value Char CRY
    If !clalev( [F:TCY] ) : Local File TABCOUNTRY [TCY] : Endif

    Read [F:TCY]TCY0 = CRY
    If fstat : End "" : Endif
End [F:TCY]ISOA3


########################################################################################################################
# Apply tax ############################################################################################################
Funprog APPLY_TAX(VLEG, VAMOUNT, VCPY, VVAT, VDAT)
  Value Char VLEG()
  Value Decimal VAMOUNT
  Value Char VCPY()
  Value Char VVAT()
  Value Date VDAT
  Local Decimal RESULT

  # Values of Local Menu 2603 - 'Type of rule'
  # 1 - NORMAL
  # 2 - EXPORT
  # 3 - TAX EXEMPT
  # 4 - EU
  [L]RESULT = VAMOUNT
  If find(func GET_TAX_RULE_TYPE(VLEG, VVAT), 1, 2, 3) <> 0 Then
    # apply the tax rate
    [L]RESULT *= (100 + func GET_TAX_RATE(VLEG, VVAT, VCPY, VDAT)) / 100
  Endif
End [L]RESULT

Funprog GET_TAX_RULE_TYPE(VLEG, VVAT)
  Value Char VLEG()
  Value Char VVAT()
  Local Integer RESULT

  Local File TABVAT [TVT]
  Read [F:TVT]TVT0 = VVAT;VLEG
  If fstat <> 0 Then
    Read [F:TVT]TVT0 = VVAT;""
  Endif
  If fstat = 0 Then
    Local File TABVACBPR [TVB]
    Read [F:TVB]TVB0 = [F:TVT]VATVAC;VLEG
    If fstat <> 0 Then
      Read [F:TVB]TVB0 = [F:TVT]VATVAC;""
    Endif
    If fstat = 0 Then
      # rule type
      [L]RESULT = [F:TVB]REGVAC
    Endif
  Endif
End [L]RESULT

Funprog GET_TAX_RATE(VLEG, VVAT, VCPY, VDAT)
  Value Char VLEG()
  Value Char VVAT()
  Value Char VCPY()
  Value Date VDAT
  Local Decimal RESULT

  [L]RESULT = 0

  Local File TABRATVAT [TRA]
  #TODO(R): order by STRDAT
  Filter [F:TRA] Where [F:TRA]VAT = VVAT and [F:TRA]LEG = VLEG and [F:TRA]CPY = VCPY and [F:TRA]STRDAT <= VDAT
  Read [F:TRA]TRA0 Last
  If fstat = 0 Then
    # rate
    [L]RESULT = [F:TRA]VATRAT
  Else
    Filter [F:TRA] Where [F:TRA]VAT = VVAT and [F:TRA]LEG = VLEG and [F:TRA]CPY = "" and [F:TRA]STRDAT <= VDAT
    Read [F:TRA]TRA0 Last
    If fstat = 0 Then
      # rate
      [L]RESULT = [F:TRA]VATRAT
    Else
      Filter [F:TRA] Where [F:TRA]VAT = VVAT and [F:TRA]LEG = "" and [F:TRA]CPY = VCPY and [F:TRA]STRDAT <= VDAT
      Read [F:TRA]TRA0 Last
      If fstat = 0 Then
        # rate
        [L]RESULT = [F:TRA]VATRAT
      Else
        Filter [F:TRA] Where [F:TRA]VAT = VVAT and [F:TRA]LEG = "" and [F:TRA]CPY = "" and [F:TRA]STRDAT <= VDAT
        Read [F:TRA]TRA0 Last
        If fstat = 0 Then
          # rate
          [L]RESULT = [F:TRA]VATRAT
        Endif
      Endif
    Endif
  Endif
End [L]RESULT
