#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMA5E 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:41"
A_USER  = "DOC"
A_STAMP = "20181109230541"
Return

$TITRES
Chgtzn [M:PJM5E]PSCBUDAMT With func SUBPJMA.COL_GET_TITLE_10(4)
Chgtzn [M:PJM5E]PSCAMT1 With func SUBPJMA.COL_GET_TITLE_10(6)
Chgtzn [M:PJM5E]PSCAMT2 With func SUBPJMA.COL_GET_TITLE_10(8)
Chgtzn [M:PJM5E]PSCAMT3 With func SUBPJMA.COL_GET_TITLE_10(10)
Chgtzn [M:PJM5E]PSCAMT4 With func SUBPJMA.COL_GET_TITLE_10(12)
Chgtzn [M:PJM5E]PSCAMT5 With func SUBPJMA.COL_GET_TITLE_10(14)
Chgtzn [M:PJM5E]PSCBUDQTY With func SUBPJMA.COL_GET_TITLE_10(3)
Chgtzn [M:PJM5E]PSCQTY1 With func SUBPJMA.COL_GET_TITLE_10(5)
Chgtzn [M:PJM5E]PSCQTY2 With func SUBPJMA.COL_GET_TITLE_10(7)
Chgtzn [M:PJM5E]PSCQTY3 With func SUBPJMA.COL_GET_TITLE_10(9)
Chgtzn [M:PJM5E]PSCQTY4 With func SUBPJMA.COL_GET_TITLE_10(11)
Chgtzn [M:PJM5E]PSCQTY5 With func SUBPJMA.COL_GET_TITLE_10(13)
Chgtzn [M:PJM5E]PSCREMAMT With func SUBPJMA.COL_GET_TITLE_10(16)
Chgtzn [M:PJM5E]PSCWIPAMT With func SUBPJMA.COL_GET_TITLE_10(18)
Chgtzn [M:PJM5E]PSCREMQTY With func SUBPJMA.COL_GET_TITLE_10(15)
Chgtzn [M:PJM5E]PSCWIPQTY With func SUBPJMA.COL_GET_TITLE_10(17)
Chgtzn [M:PJM5E]PSCTOTAMT With func SUBPJMA.COL_GET_TITLE_10(20)
Chgtzn [M:PJM5E]PSCMARGAMT With func SUBPJMA.COL_GET_TITLE_10(23)
Chgtzn [M:PJM5E]PSCPCTMAMT With func SUBPJMA.COL_GET_TITLE_10(24)
Chgtzn [M:PJM5E]PSCTOTQTY With func SUBPJMA.COL_GET_TITLE_10(19)
Chgtzn [M:PJM5E]PSCMARGQTY With func SUBPJMA.COL_GET_TITLE_10(21)
Chgtzn [M:PJM5E]PSCPCTMQTY With func SUBPJMA.COL_GET_TITLE_10(22)
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMA5E [PJM5E]
Gosub HORODAT
Local Inpbox "PJMA5E" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJM5E] As [SIM_]
Grizo [PJM5E]5
Grizo [PJM5E]10
Grizo [PJM5E]15
Grizo [PJM5E]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJM5E]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=197 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=197 : Y1(1)=3 : Y2(1)=5
X1(2)=1 : X2(2)=197 : Y1(2)=6 : Y2(2)=8
X1(3)=1 : X2(3)=197 : Y1(3)=9 : Y2(3)=25
Return

$ON_EXTDAT
Onevent BEFORE_AREA Gosub AV_EXTDAT From W1PJMA5E
Return

$AV_EXTDAT
Chgfmt [M]EXTDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_REFRESH
Onevent BEFORE_INPUT Call AS_REFRESH(zc) From W1PJMA5E
Onevent INIT_AREA Call D_REFRESH(zc) From W1PJMA5E
Return

Subprog D_REFRESH(VALEUR)
Variable Char    VALEUR()
If varinit([M]REFRESH,indice)=0
 VALEUR = "278"
Endif
Gosub _AFF
End

Subprog AS_REFRESH(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_REFRESH(zc) From W1PJMA5E
Gosub _AFF
End

Subprog CL_REFRESH(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call CL_REFRESH(VALEUR) From SUBPJM
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_PSCBUDAMT
Onevent BEFORE_AREA Gosub AV_PSCBUDAMT From W1PJMA5E
Return

$AV_PSCBUDAMT
If func SUBPJMA.COLGETFMT_10(4)<>""
 Chgfmt [M]PSCBUDAMT(indice) With func SUBPJMA.COLGETFMT_10(4)
Else
 Chgfmt [M]PSCBUDAMT(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_PSCUR
Return

