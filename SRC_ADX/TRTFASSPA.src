################################################################################
### SAM: 85985
### Calculation of the Short Term debt in the creation of a new Lease Contract
################################################################################

#    MWA - 04.09.2018 X3-104535 Parameters linked to activity code

Funprog CRT_SDEBT(LEAREF)
Value Char LEAREF

Local Decimal AMOUNT: Raz AMOUNT  ## Short term debt
Local Date ENDDAT  ## Final date for Short term debt
Local Char NUMMONTH(2) ## No months


If !clalev([F:LBB]): Local File LEABILBOOK: Endif

Filter [LBB] Where LEAREF=[L]LEAREF
Read [LBB]LBB0 First
If fstat : Filter [LBB] : End AMOUNT: Endif

Local Integer LLEA : # X3-104535
LLEA = func AFNC.ACTIV("LEA")
If LLEA = G_OUI
  Call PARAM([F:LBB]CPY,"PERSHODEBT",NUMMONTH) From ADOVAL
Endif : # X3-104535

AMOUNT=[F:LBB]RMNTPA
ENDDAT=addmonth([F:LBB]STRPERDAT,val(NUMMONTH))

Filter [LBB] Where LEAREF=[L]LEAREF and ENDPERDAT>=ENDDAT
Read [LBB]LBB0 First
If fstat : Filter [LBB]:  End 0: Endif
AMOUNT-=[F:LBB]RMNTPA

Filter [LBB]
End AMOUNT

################################################################################
### SAM: 85985
### Calculation of the Short Term debt in the payment of a Lease Contract
################################################################################
Funprog PAY_SDEBT(LEAREF, TIMSTP)
Value Char LEAREF
Value Char TIMSTP

Local Decimal AMOUNT: Raz AMOUNT  ## Short term debt
Local Date ENDDAT  ## Final date for Short term debt
Local Char NUMMONTH(2) ## No months
Local Integer N

If !clalev([F:LBB]): Local File LEABILBOOK: Endif
If !clalev([F:E44]): Local File ELEAPAY: Endif

Read [E44]EVE0=LEAREF;TIMSTP
If fstat: End 0: Endif

Filter [LBB] Where LEAREF=[L]LEAREF
Read [LBB]LBB0 First
If fstat : Filter [LBB] : End 0: Endif
AMOUNT=[F:LBB]RMNTPA

Local Integer LLEA : # X3-104535
LLEA = func AFNC.ACTIV("LEA")
If LLEA = G_OUI
  Call PARAM([F:LBB]CPY,"PERSHODEBT",NUMMONTH) From ADOVAL
Endif : # X3-104535

For N=1 To 99
    If [F:E44]CPTDATINT>addmonth([F:LBB]STRPERDAT,N*val(NUMMONTH)-1) and [F:E44]CPTDATINT<=addmonth([F:LBB]STRPERDAT,N*val(NUMMONTH))
       Break
    Endif
    If [F:E44]CPTDATINT<=addmonth([F:LBB]STRPERDAT,N*val(NUMMONTH)-1)
       Break
    Endif
Next N
    If [F:E44]CPTDATINT<=addmonth([F:LBB]STRPERDAT,N*val(NUMMONTH)-1) or N=99
      End 0
    Endif



If N>1
   ENDDAT=addmonth([F:LBB]STRPERDAT,(N-1)*val(NUMMONTH))
   Filter [LBB] Where LEAREF=[L]LEAREF and ENDPERDAT>=ENDDAT
   Read [LBB]LBB0 First
   If fstat : Filter [LBB] : End 0: Endif
   AMOUNT=[F:LBB]RMNTPA
Endif

Filter [LBB] Where LEAREF=[L]LEAREF
Read [LBB]LBB0 First

ENDDAT=addmonth([F:LBB]STRPERDAT,N*val(NUMMONTH))
Filter [LBB] Where LEAREF=[L]LEAREF and ENDPERDAT>=ENDDAT
Read [LBB]LBB0 First
If fstat : Filter [LBB] :End 0: Endif
AMOUNT-=[F:LBB]RMNTPA


Filter [LBB]
End AMOUNT

#############################################################################################
### SAM: 89962
### Calculation of the "corporate income tax" from the receipt grant
### This amount is used in the journal entry of "recognition in the passive by deferred tax"
#############################################################################################
Funprog CAL_IS1(COMPANY, GRAAMT, CUR)
Value Char COMPANY
Value Decimal GRAAMT
Value Char CUR

Local Decimal AMOUNT: Raz AMOUNT
Local Char GRTTAXCPY(10)

Local Integer LGRT : # X3-104535
LGRT = func AFNC.ACTIV("GRT")
If LGRT = G_OUI
  Call PARAM(COMPANY,"GRTTAXCPY",GRTTAXCPY) From ADOVAL
  If val(GRTTAXCPY)=0: End 0: Endif

  If !clalev([TCU]):Local File TABCUR: Endif
  Read [TCU]TCU0=CUR
  If fstat: End 0: Endif

  AMOUNT=arr(GRAAMT*val(GRTTAXCPY)/100,[TCU]CURRND)

Endif : # X3-104535

End AMOUNT
############################################################################################################
### SAM: 89962
### Calculation of the "corporate income tax" from the part of subsidy that corresponds to the depreciation
### This amount is used in the journal entry of "cancelation of the part of the passive by deferred tax"
############################################################################################################
Funprog CAL_IS2(COMPANY, CRBGRAAMT, CUR)
Value Char COMPANY
Value Decimal CRBGRAAMT
Value Char CUR

Local Decimal AMOUNT: Raz AMOUNT
Local Char GRTTAXCPY(10)

Local Integer LGRT : # X3-104535
LGRT = func AFNC.ACTIV("GRT")
If LGRT = G_OUI
  Call PARAM(COMPANY,"GRTTAXCPY",GRTTAXCPY) From ADOVAL
  If val(GRTTAXCPY)=0: End 0: Endif

  If !clalev([TCU]):Local File TABCUR: Endif
  Read [TCU]TCU0=CUR
  If fstat: End 0: Endif

  AMOUNT=arr(CRBGRAAMT*val(GRTTAXCPY)/100,[TCU]CURRND)

Endif : # X3-104535

End AMOUNT

############################################################################################################
### SAM: 85884
### Calculation of the accumulated depreciation
### GLE 12/11/2014 95754 Parameter PPLN added
############################################################################################################
Funprog ISS_HELD(REF,ISSDAT1, ISSDAT2, PPLN)
Value Char    REF
Value Date    ISSDAT1
Value Date    ISSDAT2
Value Integer PPLN

Local Date ISSDAT

If ISSDAT1<>[0/0/0]
   ISSDAT=ISSDAT1
Else
   ISSDAT=ISSDAT2
Endif

Local Decimal AMOUNT: Raz AMOUNT
If !clalev([DEPX]): Local File DEPREC [DEPX]: Endif

Filter [DEPX] Where AASREF=REF and DPRPLN=PPLN and PERENDDAT>=ISSDAT
Read [DEPX]DEP0 First
If !fstat
#For [DEPX]DEP0
#   AMOUNT += [F:DEPX]PSTDPE
#Next
    AMOUNT += [F:DEPX]DPRCUM
&               + [F:DEPX]PERCLOCUM
&               + [F:DEPX]PERCLOEXC
&               + [F:DEPX]PERENDDPE
&               + [F:DEPX]PEREXCDPR
&               + [F:DEPX]IMLBLC
&               + [F:DEPX]IML
&               - [F:DEPX]IMLRVE
&               - [F:DEPX]IMLRVETRF
Endif
Filter [DEPX]

End AMOUNT
############################################################################################################
### SAM: 85884
### Calculation of tha accounting date
############################################################################################################
Funprog ISS_HELDDAT(SALCLSDAT,SALCLSDATO)
Value Date SALCLSDAT
Value Date SALCLSDATO

If SALCLSDAT<>[0/0/0]: End SALCLSDAT: Endif
End SALCLSDATO

