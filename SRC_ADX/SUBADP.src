#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ADP",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "INIMOD"       : Gosub INIMOD
 When "INICRE"       : Gosub INICRE
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "APRES_MOD"    : Gosub APRES_MOD
 When "MODIF"        : Gosub MODIF
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "RAZDUP"       : Gosub RAZDUP
 When "RAZCRE"       : Gosub RAZCRE
 When "ABANDON"      : Gosub ABANDON
 When "ANNULE"       : Gosub ANNULE
 When "CHANGE"       : Gosub CHANGE
 When "LIENS"        : Gosub LIENS
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_CHOI"   : Gosub APRES_CHOI
 When "VERF_ANU"     : Gosub VERF_ANU
Endcase
Return

#----------------------------------------------------------#
$OUVRE
Local Char WSCMABR(GLONABR) (1..)
Local Char WSCMTABCLE(GLONAMM) (1..)
Local Char WSCMTABFLG(1) (1..)
Local Integer WSCMNBCLE
#
Local Integer L , FLGMOD, FLGMODCTX
Local Char    MACLCK(250) , USRLCK(250) , MESSA(250)
Local Char    SYMBOLE_AGB(80)
Gosub SET_TRT From SUBAGB
If clalev([F:AGB2])=0 : Local File AGLOBVAR  [AGB2] : Endif
If clalev([F:ACTX])=0 : Local File ACONTEXT  [ACTX] : Endif # KUYAN
If clalev([F:ACTX2])=0 : Local File ACONTEXT  [ACTX2] : Endif # KUYAN
If clalev([F:ADG])=0  : Local File ADOVALGRP [ADG]  : Endif
Return

#----------------------------------------------------------#
$OUVRE_BOITE
Local Char BOXGRP(10) , BOXPAR(10)
BOXGRP = "GAU_CHE"+num$(find("AD2",OBJLIS(1..dim(OBJLIS)-1)))
BOXPAR = "GAU_CHE"+num$(find("AD3",OBJLIS(1..dim(OBJLIS)-1)))
Return

#----------------------------------------------------------#
$VERIF_MOD
FLGMOD = 0
If [M]CODVAR<>""
 Read [ADP]ADP1 = [M]PARAM
 If [F:ADP]TYPVAL<>[M]TYPVAL or [F:ADP]NIVDEF<>[M]NIVDEF or [F:ADP]CODACT<>[M]CODACT
  Read [AGB]AGB0 = [M]CODVAR
  If !fstat
   FLGMOD = 1
   Gosub LCK_GLOB
  Endif
 Endif
Endif
If !OK : Return : Endif

#KUYAN
FLGMODCTX = 0
Local Integer RES_OK
# check the code contexte
If [M]CODCTX<>""
 Read [ACTX]ACTX0=[M]CODCTX
 # case 1 : need to create a new code context
 If fstat
  # Code contexte inexistante\Voulez-vous la créer
  Call AVERTIR([M]CODCTX-":"-mess(289,139,1)+"\"+mess(290,139,1),RES_OK) From GESECRAN
  If RES_OK = 2
   FLGMODCTX = 1
  Else
   [M]CODCTX = "" : Affzo CODCTX
   Effzo CHAPTER
  Endif
 # case 2 : need to update an existing code context
 Else
  Gosub L_CHECK_TYPE # ???
  If K = 1
   # code context: type de donné incompatible
   Call ERREUR(mess(293,139,1)-[M]CODCTX-":"-mess(113,127,1)) From GESECRAN
   OK = 0 : zonsui = "CODCTX" : : Return
  Endif
  # check if code contexte is updated
  If [ACTX]PARAM <> [M]PARAM
   FLGMODCTX = 1
   #Code contexte existe déjà, voulez-vous le redéfinir
   Call AVERTIR([M]CODCTX-":"-mess(291,139,1),RES_OK) From GESECRAN
   If RES_OK<>2
    [M]CODCTX = "" : Affzo CODCTX
    Effzo CHAPTER
    FLGMODCTX = 0
   Else
   Endif
  Else
   Read [ADP]ADP1 = [M]PARAM
   # check if type/level/activity code/Object is updated
   If [F:ADP]TYPVAL<>[M]TYPVAL or [F:ADP]NIVDEF<>[M]NIVDEF or [F:ADP]CODACT<>[M]CODACT or [F:ADP]OBJET<>[M]OBJET
    FLGMODCTX = 1
   Endif
  Endif
 Endif
 If FLGMODCTX = 1
  Gosub LCK_CTX # ???
 Endif
Endif

Return


#----------------------------------------------------------#
$LCK_GLOB
SYMBOLE_AGB = "AGB"+[M]CODVAR
Lock =SYMBOLE_AGB With lockwait=0
If fstat
 Call QUILOCKE(SYMBOLE_AGB,MACLCK,USRLCK) From OBJDIV
 MESSA = mess(122,139,1)-":"-[M]CODVAR
 If USRLCK<>""
  MESSA += "\"+mess(101,126,1)+"\"+[L]USRLCK+"\"+[L]MACLCK : # La fiche est utilisée par
 Else
  MESSA += "\"+mess(98,126,1) : # La fiche est utilisée par un autre utilisateur
 Endif
 Call MESSAGE(MESSA) From GESECRAN
 OK = 0 : Return
Endif
Return


#----------------------------------------------------------#
$LCK_CTX # KUYAN
SYMBOLE_ACTX = "ACTX~"+[M]CODCTX
Lock =SYMBOLE_ACTX With lockwait=0
If fstat
 Call QUILOCKE(SYMBOLE_ACTX,MACLCK,USRLCK) From OBJDIV
 MESSA = mess(293,139,1)-":"-[M]CODCTX
 If USRLCK<>""
  MESSA += "\"+mess(101,126,1)+"\"+[L]USRLCK+"\"+[L]MACLCK : # La fiche est utilisée par
 Else
  MESSA += "\"+mess(98,126,1) : # La fiche est utilisée par un autre utilisateur
 Endif
 Call MESSAGE(MESSA) From GESECRAN
 OK = 0 : Return
Endif
Return

#----------------------------------------------------------#
$MODIF
#SCM
WSCMNBCLE=0
Raz WSCMTABFLG
Raz WSCMTABCLE
Raz WSCMABR
If [F:ADP]NIVDEF=4 & [F:ADP]VALDEF<>2
 Delete [ADW] Where PARAM=[F:ADP]PARAM
Endif
If FLGMOD : Gosub MAJ_GLOB : Endif
If FLGMODCTX : Gosub MAJ_CTX : Endif
Return

#----------------------------------------------------------#
$MAJ_GLOB
Readlock [AGB]AGB0 = [M]CODVAR
If fstat=1
 GOK = -1 : GLOCK="$AGLOBVAR"-[M]CODVAR : Return
Elsif fstat
 Raz [F:AGB]
 [F:AGB]CODVAR = [M]CODVAR
 [F:AGB]INTIT  = [M]NAM
 [F:AGB]PARAM  = [M]PARAM
 [F:AGB]CODACT = [M]CODACT
 [F:AGB]PUBFLG = 1
 Case GPRODUIT
  When -1      : [F:AGB]MODULE = 1
  When 0,2     : [F:AGB]MODULE = 9 : # X3,Paie
  When Default : [F:AGB]MODULE = 2
 Endcase
 [F:AGB]LNGTYP = ""
 Case [F:ADP]TYPVAL
  When 1 : [F:AGB]CODTYP = "A"   : [F:AGB]LNGTYP = "30"
  When 2 : [F:AGB]CODTYP = "DCB"
  When 3 : [F:AGB]CODTYP = "D"
  When 4 : [F:AGB]CODTYP = "M"
 Endcase
 Case [F:ADP]NIVDEF
  When 4       : [F:AGB]TRTSTD = TRTUSR
  When Default : [F:AGB]TRTSTD = TRTVAR
 Endcase
 Filter [AGB2] Where TRTSTD=[F:AGB]TRTSTD
 Read [AGB2]AGB1 Last
 [F:AGB]RANG = [F:AGB2]RANG+10
 Filter [AGB2]
 Write [AGB]
 If fstat
  GOK = 0 : Call FSTA("AGB") From GLOCK : Return
 Endif
Elsif !fstat
 K = 0
 Read [ATY]CODTYP = [F:AGB]CODTYP
 Case [M]TYPVAL
  When 1   : If [F:ATY]TYPTYP<>7                 : K = 1 : Endif
  When 2,4 : If !find([F:ATY]TYPTYP,1,2,3,4,5,6) : K = 1 : Endif
  When 3   : If [F:ATY]TYPTYP<>8                 : K = 1 : Endif
 Endcase
 If K
  [F:AGB]LNGTYP = ""
  Case [F:ADP]TYPVAL
   When 1 : [F:AGB]CODTYP = "A"   : [F:AGB]LNGTYP = "30"
   When 2 : [F:AGB]CODTYP = "DCB"
   When 3 : [F:AGB]CODTYP = "D"
   When 4 : [F:AGB]CODTYP = "M"
  Endcase
 Endif
 L = 0
 Case [F:ADP]NIVDEF
  When 4       : If [F:AGB]TRTSTD<>TRTUSR : L = 1 : Endif
  When Default : If [F:AGB]TRTSTD<>TRTVAR : L = 1 : Endif
 Endcase
 If L
  Case [F:ADP]NIVDEF
   When 4       : [F:AGB]TRTSTD = TRTUSR
   When Default : [F:AGB]TRTSTD = TRTVAR
  Endcase
 Endif
 If K or L or [F:AGB]CODACT<>[M]CODACT or [F:AGB]PARAM<>[M]PARAM
  [F:AGB]PARAM  = [M]PARAM
  # KUYAN - clean the formule/trt d'init
  [F:AGB]TRTINI  = ""
  [F:AGB]FORINI  = ""
  [F:AGB]CODACT = [M]CODACT
  Rewrite [AGB]
  If fstat
   GOK = 0 : Call FSTA("AGB") From GLOCK : Return
  Endif
 Endif
Endif
If GADONIX=2
 #SCM
 WSCMNBCLE+=1
 WSCMABR(WSCMNBCLE)="AGB"
 WSCMTABCLE(WSCMNBCLE)=[F:AGB]CODVAR
 WSCMTABFLG(WSCMNBCLE)="C"
 #Call TRACE_COR("AGB",[F:AGB]CODVAR,"","C") From GOBJET
Endif
Return


#----------------------------------------------------------#
$MAJ_CTX
Readlock [ACTX]ACTX0 = [M]CODCTX
# case 1 :
If fstat=1
 GOK = -1 : GLOCK="$ACONTEXT"-[M]CODVAR : Return
# case 2 : create a new code contexte
Elsif fstat
 Raz [F:ACTX]
 [F:ACTX]CODCTX  = [M]CODCTX
 [F:ACTX]INTIT   = [M]NAM
 [F:ACTX]PARAM   = [M]PARAM
 [F:ACTX]CODACT  = [M]CODACT
 [F:ACTX]PUBFLG  = 1
 [F:ACTX]CHAPTER = [M]CHAPTER
 [F:ACTX]CHGMOD  = 2

 # MODULE
 Case GPRODUIT # ??? KUYAN no more gv
  When -1      : [F:AGB]MODULE = 1
  When 0,2     : [F:AGB]MODULE = 9 : # X3,Paie
  When Default : [F:AGB]MODULE = 2
 Endcase

 # CODTYP
 [F:ACTX]LNGTYP = ""
 Case [F:ADP]TYPVAL
  When 1 : [F:ACTX]CODTYP = "A"   : [F:ACTX]LNGTYP = "30"
  When 2 : [F:ACTX]CODTYP = "DCB"
  When 3 : [F:ACTX]CODTYP = "D"
  When 4 : [F:ACTX]CODTYP = "M"
 Endcase

 # RANG
 Filter [ACTX2] Where CHAPTER = [M]CHAPTER
 Read [ACTX2]ACTX1 Last
 If !fstat
  [F:ACTX2]RANG = [F:ACTX2]RANG+10
 Else
  [F:ACTX2]RANG = 10
 Endif
 Filter [ACTX2]

 Write [ACTX]
 If fstat
  GOK = 0 : Call FSTA("ACTX") From GLOCK : Return
 Endif

# case 3: update an existing code contexte
Elsif !fstat
 # no need to update type since not allowed
 If [F:ACTX]CODACT<>[M]CODACT or [F:ACTX]PARAM<>[M]PARAM
  [F:ACTX]PARAM  = [M]PARAM
  # KUYAN - clean the formule/trt d'init
  [F:ACTX]TRTINI  = ""
  [F:ACTX]FORINI  = ""
  [F:ACTX]CODACT = [M]CODACT
  Rewrite [ACTX]
  If fstat
   GOK = 0 : Call FSTA("ACTX") From GLOCK : Return
  Endif
 Endif
Endif
If GADONIX=2
 #SCM
 WSCMNBCLE+=1
 WSCMABR(WSCMNBCLE)="ACTX"
 WSCMTABCLE(WSCMNBCLE)=[F:ACTX]CODCTX
 WSCMTABFLG(WSCMNBCLE)="C"
 #Call TRACE_COR("ACTX",[F:ACTX]CODCTX,"","C") From GOBJET
Endif
Return

#----------------------------------------------------------#
$AVANT_MODFIC
If [F:ADP]GRPPAR<>[M]GRPPAR
 Update [ADG] Where GRPPAR=[F:ADP]GRPPAR & PARAM=[F:ADP]PARAM With GRPPAR=[M]GRPPAR
 If fstat
  GOK = 0 : Call FSTA("ADG") From GLOCK : Return
 Endif
Endif
Return

#----------------------------------------------------------#
$APRES_MOD
#SCM
Local Integer I
For I=1 To WSCMNBCLE
 Call TRACE_COR(WSCMABR(I),WSCMTABCLE(I),"",WSCMTABFLG(I)) From GOBJET
Next I
If FLGMOD
 Unlock =SYMBOLE_AGB
 Gosub VAL_GLOB
Endif
If FLGMODCTX   #  ??? KUYAN
 Unlock =SYMBOLE_ACTX
 Gosub VAL_CTX
Endif
Return

$VAL_GLOB
Read [AGB]AGB0 = [M]CODVAR
If !fstat
 Call VALIDATION(nomap,TRTUSR,0) From SUBAGB
 Call VALIDATION(nomap,TRTVAR,0) From SUBAGB
 Call VALCHAP(nomap,[F:ADP]CHAPITRE,0) From SUBAGB
Endif
Return


$VAL_CTX
Read [ACTX]ACTX0 = [M]CODCTX
If !fstat
 Call VALIDATION(nomap,"",0) From SUBACTX
Endif
Return

#----------------------------------------------------------#
$VERIF_CRE
Local Integer RES_OK
If [M]CODVAR<>""
 Read [AGB]AGB0=[M]CODVAR
 If fstat
  # Variable globale inexistante\Voulez-vous la créer
  Call AVERTIR([M]CODVAR-":"-mess(178,139,1)+"\"+mess(179,139,1),RES_OK) From GESECRAN
  If RES_OK<>2
   [M]CODVAR = "" : Affzo CODVAR
  Endif
 Else
  Gosub LCK_GLOB
 Endif
Endif

# KUYAN
# check the code contexte
If [M]CODCTX<>""
 Read [ACTX]ACTX0=[M]CODCTX
 # case 1 : need to create a new code contexte
 If fstat
  # Code contexte inexistante\Voulez-vous la créer
  Call AVERTIR([M]CODCTX-":"-mess(289,139,1)+"\"+mess(290,139,1),RES_OK) From GESECRAN
  If RES_OK<>2
   [M]CODCTX = "" : Affzo CODCTX
   Effzo CHAPTER
  Endif
 # case 2 : need to update an existing code contexte
 Else
  Gosub L_CHECK_TYPE
  If K = 1
   # code context: type de donné incompatible
   Call ERREUR(mess(293,139,1)-[M]CODCTX-":"-mess(113,127,1)) From GESECRAN
   OK = 0 : zonsui = "CODCTX" : : Return
  Endif
  # Code contexte existe déjà, voulez-vous le redéfinir
  Call AVERTIR([M]CODCTX-":"-mess(291,139,1),RES_OK) From GESECRAN
  If RES_OK<>2
   [M]CODCTX = "" : Affzo CODCTX
   Effzo CHAPTER
  Else
   Gosub LCK_CTX
  Endif
 Endif

 If [M]CHAPTER = "" # ??? need to be reviewed
  Call L_CHECKCOD([M]CODCTX, RES_OK) From SUBACTX
  If RES_OK = 1
   # Veuillez mettre une valeur pour le chapitre du contexte
   Call ERREUR(mess(127,127,1)) From GESECRAN
   OK = 0 : zonsui = "CHAPTER" : Return
  Endif
 Endif
Endif
Return


# KUYAN
# check if the type of code contexte is coherent with the type defined for the parameter
# K = 0 : OK
# K = 1 : KO
$L_CHECK_TYPE
K = 0
Read [ATY]CODTYP = [F:ACTX]CODTYP
If !fstat
 If [M]OBJET <> "" and [ATY]OBJLIEN <> ""
  # in case an Object is selected, the type of contexte need to be coherent
  If [M]OBJET <> [ATY]OBJLIEN : K = 1 : Endif
 Else
  # in case no Object is selected, check the internal type
  Case [M]TYPVAL
   When 1   : If [F:ATY]TYPTYP<>7                 : K = 1 : Endif
   When 2,4 : If !find([F:ATY]TYPTYP,1,2,3,4,5,6) : K = 1 : Endif
   When 3   : If [F:ATY]TYPTYP<>8                 : K = 1 : Endif
  Endcase
 Endif
Else
 K = 1
Endif
Return

#----------------------------------------------------------#
$CREATION
#SCM
WSCMNBCLE=0
Raz WSCMTABFLG
Raz WSCMTABCLE
Raz WSCMABR
If [M]CODVAR<>""
 Gosub MAJ_GLOB
Endif
If [M]CODCTX<>""
 Gosub MAJ_CTX
Endif
Return

#----------------------------------------------------------#
$APRES_CRE
#SCM
Local Integer I
For I=1 To WSCMNBCLE
 Call TRACE_COR(WSCMABR(I),WSCMTABCLE(I),"",WSCMTABFLG(I)) From GOBJET
Next I
If [M]CODVAR<>""
 Unlock =SYMBOLE_AGB
 Gosub VAL_GLOB
 Diszo [ADP1]CODVAR
Endif
# KUYAN
If [M]CODCTX<>""
 Unlock =SYMBOLE_ACTX
 Gosub VAL_CTX
 Diszo [ADP1]CODCTX # ??? march pas
Endif
Return

#----------------------------------------------------------#
$ABANDON
Raz REP , GREP
Gosub GRISE_CODVAR
Return

#----------------------------------------------------------#
$RAZCRE
$RAZDUP
Gosub GRISE_CODVAR
Gosub GRISE_CODCTX #KUYAN
Return

#----------------------------------------------------------#
$LIENS
# display associated global variable
Read [AGB]AGB2 = [M:ADP1]PARAM
If !fstat
 [M]CODVAR = [F:AGB]CODVAR
Endif
Gosub GRISE_CODVAR

# display associated contexte variable
Read [ACTX]ACTX2 = [M:ADP1]PARAM
If !fstat
 [M]CODCTX = [F:ACTX]CODCTX
 [M]CHAPTER = [F:ACTX]CHAPTER
Endif
Gosub GRISE_CODCTX

If [F:ADP]OBJET<>""
 [M]PAROBJ = [F:ADP]VALUES(0)
 [M]NBVAL = 0     # Issue X3-44568 - 2017-06-12 by CCC : NBVAL=1 if a parameter of object is set
Endif
Call TEXTE([F:ADP]NAM,[M]NAME) From OBJDIV
Gosub GRISE_UTIL
Gosub GRISE_MODIF
Gosub GRISE_NOLIB
Gosub GRISE_OBJ
For nolign=1 To [M]NBVAL
 Gosub CHARGE
 Call CHARGE([M]VALUES(nolign-1),[M]TYP(nolign-1),[M]NLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT(nolign-1))
& From FMTVAR
Next I
Return

$GRISE_CODVAR
Case REP
 When "C" , "D" : Actzo [ADP1]CODVAR
 When Default   : Diszo [ADP1]CODVAR
Endcase
Return

$GRISE_CODCTX
Case REP
 When "C" , "D" :
  Effzo [ADP1]CODCTX
  Actzo [ADP1]CODCTX
  Effzo [ADP1]CHAPTER
  Diszo [ADP1]CHAPTER
 When Default   :
  If [M]CODCTX=""
   Actzo [ADP1]CODCTX
  Else
   Diszo [ADP1]CODCTX
  Endif
  Diszo [ADP1]CHAPTER
Endcase
Return

$GRISE_UTIL
If [M]NIVDEF<>4
 Grizo [M:ADP1]AUSMODIF,VALDEF
 [M:ADP1]AUSMODIF = 1
 [M:ADP1]VALDEF   = 1
 Affzo [ADP1]AUSMODIF,VALDEF
Else
 Actzo [ADP1]AUSMODIF,VALDEF
 Affzo [ADP1]AUSMODIF,VALDEF
Endif
Return

$GRISE_MODIF
If [M]AUSMODIF=2 & [M]NIVDEF=4
 [M:ADP1]MODIF = 2
 Affzo [ADP1]MODIF
 Grizo [ADP1]MODIF
Else
 Actzo [ADP1]MODIF
Endif
Return

$GRISE_NOLIB
If [M]TYPVAL=4
 Actzo NOLIB
Else
 Effzo NOLIB
 Grizo NOLIB
Endif
Return

$GRISE_OBJ
If [M]OBJET=""
 Effzo PAROBJ,SELOPT
 Grizo PAROBJ,SELOPT
Else
 Call LECTURE("AOB",[M]OBJET,"") From CONTOBJ
 If [F:AOB]LIBPAR=0
  Effzo PAROBJ
  Grizo PAROBJ
 Else
  Actzo PAROBJ
 Endif
 If [F:AOB]NBOPT<1
  Effzo SELOPT
  Grizo SELOPT
 Else
  Actzo SELOPT
 Endif
Endif
Return

#------------------------#
$CHARGE
Case [M]TYPVAL
 When 1 : [M]FMT(nolign-1) = "Kf:30X"      : [M]TYP(nolign-1) = "A"   : [M]LONG(nolign-1)  = 30
 When 2 : [M]FMT(nolign-1) = "Nf:10F"      : [M]TYP(nolign-1) = "DCB" : [M]LONG(nolign-1)  = 15
 When 3 : [M]FMT(nolign-1) = "Df:"+GFMDAT4 : [M]TYP(nolign-1) = "D"   : [M]LONG(nolign-1)  = 0
 When 4 : [M]FMT(nolign-1) = "Nf:2#"       : [M]TYP(nolign-1) = "M"   : [M]NLIB(nolign-1) = [M]NOLIB
Endcase
Return

#----------------------------------------------------------#
$FILGAUCHE
FILGAUSUP = FILTRE
Return

#----------------------------------------------------------#
$APRES_CHOI
Case REPONSE
 When GSTASUI  : Gosub SUIVANT   : REPONSE = 0
 When GSTAPRE  : Gosub PRECEDENT : REPONSE = 0
 When GSTAFIR  : Gosub PREMIER   : REPONSE = 0
 When GSTALAS  : Gosub DERNIER   : REPONSE = 0
Endcase
Return

#----------------------------------------------------------#
$SUIVANT
Gosub ABORT From GOBJSUB
If !OK : Return : Endif
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Case currbox
 When BOXGRP : Read [ADP]ADP5 Next
 When BOXPAR : Read [ADP]ADP1 Next
Endcase
Goto SUIVPREC

#----------------------------------------------------------#
$PRECEDENT
Gosub ABORT From GOBJSUB
If !OK : Return : Endif
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Case currbox
 When BOXGRP : Read [ADP]ADP5 Prev
 When BOXPAR : Read [ADP]ADP1 Prev
Endcase
Goto SUIVPREC

#----------------------------------------------------------#
$PREMIER
Gosub ABORT From GOBJSUB
If !OK : Return : Endif
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Case currbox
 When BOXGRP : Read [ADP]ADP5 First
 When BOXPAR : Read [ADP]ADP1 First
Endcase
Goto SUIVPREC

#----------------------------------------------------------#
$DERNIER
Gosub ABORT From GOBJSUB
If !OK : Return : Endif
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Case currbox
 When BOXGRP : Read [ADP]ADP5 Last
 When BOXPAR : Read [ADP]ADP1 Last
Endcase
Goto SUIVPREC

#----------------------#
$SUIVPREC
Filter [F]
If fstat>2
 Call MESSAGE(mess(11,100,1)) From GESECRAN
 Gosub RELIT From GOBJSUB
Else
 Gosub LECTURE From GOBJSUB
Endif
REP = "" : GREP = ""
Return

#----------------------------------------------------------#
$INIMOD
$INICRE
If [M]OBJET<>""
 Raz [F:ADP]VALUES, [F:ADP]NBVAL
 # Issue X3-44568 - 2017-06-12 by CCC : if a parameter of object is set then NBVAL=1
 If [M]PAROBJ<>""
    [F:ADP]NBVAL = 1
 Endif
 [F:ADP]VALUES(0) = [M]PAROBJ
Else
 For I=0 To [M]NBVAL-1
  [F:ADP]VALUES(I) = [M]VALINT(I)
 Next I
Endif
Return

#----------------------------------------------------------#
$ANNULE
# Effacement des valeurs
Delete [ADW] Where PARAM=CODE
If fstat=1
 GOK = -1 : GLOCK="$ADOVAL"-CODE : Return
Endif
Return

#----------------------------------------------------------#
$VERF_ANU
Read [AGB]AGB2 = [L]CODE
If !fstat
 Call ERREURT (mess(1,115,1)+"\"+[L]CODE-":"-mess(229,133,1)-[F:AGB]CODVAR,1) From GESECRAN
 # Suppression impossible / Ce paramètre est utilisé par la variable globale
 OK = 0
Endif
# KUYAN
Read [ACTX]ACTX2 = [L]CODE
If !fstat
 Call ERREURT (mess(1,115,1)+"\"+[L]CODE-":"-mess(292,139,1)-[F:ACTX]CODCTX,1) From GESECRAN
 # Suppression impossible / Ce paramètre est utilisé par la variable contexte
 OK = 0
Endif
Return

#----------------------------------------------------------#
$CHANGE
# Renommage des valeurs
For [ADW]ADW0 Where PARAM=[L]OCODE
 [F:ADW]PARAM = NCODE
 Rewrite [ADW]
 If fstat
  GOK = 0 : Call FSTA("ADW") From GLOCK : Break
 Endif
Next ADW

# Renommage du parametre des variables globales
For [AGB]AGB2 Where PARAM=[L]OCODE
 [F:AGB]PARAM = NCODE
 Rewrite [AGB]
 If fstat
  GOK = 0 : Call FSTA("AGB") From GLOCK : Break
 Endif
Next AGB
Return

#----------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation , Copie
Endif
Return

#----------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ADOPAR  [ADP1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".ADOPAR"  [ADP1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ADOPAR  [ADP2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".ADOPAR"  [ADP2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ADP1], [ATX1], [ADP2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ADP2] , [ATX2]
 Delete [ADP2] Where PARAM=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ADOPAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADP2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ADP1]ADP1 Where PARAM=TABLE
  [F:ADP2] = [F:ADP1]
  Call COPTEXTE([F:ADP1]NAM,[F:ADP2]NAM) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:ADP2]UPDUSR)>0 : [F:ADP2]UPDUSR = GUSER : Endif
  If dim([F:ADP2]UPDDAT)>0 : [F:ADP2]UPDDAT = date$ : Endif
  If dim([F:ADP2]UPDTIM)>0 : [F:ADP2]UPDTIM = time : Endif
  Write [ADP2]
  If fstat
   GOK=0 : Call FSTA("ADP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------------------------#
Subprog C_PARAM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
For [ADP]ADP1 Where PARAM=VALEUR
 If [F:ADP]CHAPITRE<>[M]CHAPITRE
  [M]CHAPITRE = [F:ADP]CHAPITRE
  Affzo CHAPITRE : mkstat = 4 : Break
 Endif
Next ADP
End

Subprog C_TYPVAL(VALEUR)
Variable Integer VALEUR
[M]TYPVAL = VALEUR
Gosub GRISE_NOLIB
End

Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
If [M]TYPVAL<>4
 mkstat=1 : End
Endif
End

Subprog C_VALUES(VALEUR)
Value Char VALEUR
Call UNICITE(VALEUR,[M]VALUES) From OBJDIV
End

Subprog C_TRAIT(VALEUR)
Variable Char    VALEUR()
Local Integer OKTRT
If VALEUR<>""
 Call EXISTE_ADX("","",VALEUR,OKTRT) From ORDSYS
 If !OKTRT
  GMESSAGE = VALEUR-":"-mess(90,123,1) : # Traitement inexistant
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_NBVAL
If [M]OBJET<>"" : mkstat=1 : End : Endif
End

Subprog C_NBVAL
If nolign<=dim([M]VALUES)
 Gosub CHARGE
Endif
End

Subprog C_OBJET(VALEUR)
Variable Char    VALEUR()
[M]OBJET = VALEUR
Gosub GRISE_OBJ
End

Subprog AS_PAROBJ(VALEUR)
Variable Char    VALEUR()
If [M]OBJET="" : mkstat = 1 : End : Endif
Call LECTURE("AOB",[M]OBJET,"") From CONTOBJ
If [F:AOB]LIBPAR=0 : mkstat=1 : End : Endif
End

Subprog AS_SELOPT(VALEUR)
Variable Char    VALEUR()
If [M]OBJET="" : mkstat = 1 : End : Endif
Call LECTURE("AOB",[M]OBJET,"") From CONTOBJ
If [F:AOB]NBOPT<1 : mkstat=1 : End : Endif
End

Subprog C_SELOPT(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AOB",[M]OBJET,"") From CONTOBJ
Local Integer I
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),[F:AOB]OPTCOD(0..[F:AOB]NBOPT-1))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I
End

Subprog S_SELOPT(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , I , VALINT
Local Shortint MAXTEX : MAXTEX = max(20,dim([F:AOB]OPTCOD))
Local Char    TEX(50)(MAXTEX) , TEXTE(50)
NBTEX = 0
For I=0 To [F:AOB]NBOPT-1
 NBTEX += 1
 TEX(NBTEX) = [F:AOB]OPTCOD(I)
 Call TEXTE([F:AOB]OPTLIB(I),TEXTE) From OBJDIV
 TEX(NBTEX) -= TEXTE
Next I
If NBTEX
 Call SAITEX(NBTEX,TEX,VALINT,mess(100,123,1)) From GESECRAN
 # Choix options
 If VALINT<>0 & status<>7 & !instr(1,VALEUR,[F:AOB]OPTCOD(VALINT-1))
  VALEUR += [F:AOB]OPTCOD(VALINT-1)
 Endif
Endif
mkstat = 2
End

Subprog AM_NIVDEF(VALEUR)
Variable Integer  VALEUR
[M]NIVDEF = VALEUR
Gosub GRISE_UTIL
End

Subprog AM_AUSMODIF(VALEUR)
Variable Integer  VALEUR
[M]AUSMODIF = VALEUR : Gosub GRISE_MODIF
End

Subprog C_CODVAR(VALEUR)
Variable Char    VALEUR()
Call CONT_VAR(VALEUR) From SUBAGB
If mkstat : End : Endif
Read [AGB]AGB0=VALEUR
If !fstat & [F:AGB]PARAM<>""
 # Cette variable globale est déjà initialisée par le paramètre
 GMESSAGE = VALEUR-":"-mess(180,139,1)-[F:AGB]PARAM
 mkstat = 2 : End
Endif
End

Subprog C_FLDVAL(VALEUR)
Variable Integer  VALEUR
If [M]OBJET="" & VALEUR<>2 & [M]NBVAL=0 & [M]MODIF=2
 Call ERREUR(mess(210,139,1)) From GESECRAN : # Liste des valeurs non renseignée
 mkstat = 2 : End
Endif
End

Subprog C_VALFLG(VALEUR)
Variable Integer VALEUR
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran ADP1) 23/03/2012 15:12:48 (KUYAN)
######################################################################################
# KUYAN
Subprog C_CODCTX(VALEUR)
Variable Char    VALEUR()
 Read [ACTX]ACTX0=VALEUR
 If !fstat and [F:ACTX]PARAM<>""
  # Contexte code already used by another parameter
  GMESSAGE = VALEUR-":"-mess(288,139,1)-[F:ACTX]PARAM
  [M]CODCTX = "" : Affzo CODCTX
  mkstat = 2 : End
 Endif
End

# KUYAN
Subprog AM_CODCTX(VALEUR)
Variable Char    VALEUR()
 Local Integer OK
 Read[ACTX]ACTX0 = VALEUR
 If !fstat
  [M]CHAPTER = [ACTX]CHAPTER
  Diszo [M]CHAPTER
 Else
  Call L_CHECKCOD([M]CODCTX, OK) From SUBACTX
  If OK
   [M]CHAPTER = ""
   Actzo CHAPTER
  Else
   Effzo [M]CHAPTER
   Diszo [M]CHAPTER
  Endif
 Endif
End


