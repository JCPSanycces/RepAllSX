#<AdxTL>@(#)9.0.0.0 $Revision$

Local Char PARAM(10)(1..2) , VALEUR(10) 
Call TRAITE_CHAR(VALEUR,PARAM,"","AYTWSRGES","AYTWSRGES",3,"") From GTRAITE
End

#####################################################################################
## Xtend: Gestion des Web Services utilisés par un site Xtend
#####################################################################################
##  Gestion Ecran
#    AYTWSRGES
#
##  Actions
#    AYTWSRGES    Gestion Web service
#                    Accès par le menu utilitaire et l'écran des interfaces
#
##  Gosub
#
##  Subprog
#    WSRGES       Trt de gestion WS d'un site Xtend
#
######################################################################################
$ACTION
  Case ACTION
    When "INIT"     : Gosub WSRGES_INI
    When "INIT_DIA" : Gosub WSRGES_DIA
    When "CONTROLE" : Gosub WSRGES_CTL
    When "EXEC"     : Gosub WSRGES_EXEC
    When "SORTIE"   : Gosub WSRGES_SORTIE
  Endcase
Return

######################################################################################
#    AYTWSRGES        Gestion Web service
#                     Ecran AYTWSRGES    
#        Param(1)      Dossier origine
#        Param(2)      Site Xtend origine
#        Param(3)      Dossier destination
#        Parma(4)      Code facultatif d'un interface (utilisé par la fenêtre des interfaces)
# $$$$
######################################################################################
$WSRGES_INI
#-----------------------------
Local Char FCYORG(GLONAYS), WSTR1(200), WDES(50), WMSG(250)
Local Char DOSORG(GDIMFIC), MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000@XTEND ; sodaix01:5000 ; XTEND
Local Char DOSDES(GDIMFIC), MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)
Local Char INTCOD(GLONAYI)
Local Char SAVACTION(10), WSTR(250)
Local Char OPTION(10)(1..10)     : Local Integer OPTIND
Local Integer RET, WI, WRET
Local Decimal WNL
Local Mask AWE0 [AWE0]
Local Mask AWE1 [AWE1]
Local Mask AWE2 [AWE2]

DOSORG = PARAM(1)
FCYORG = PARAM(2)
DOSDES = PARAM(3)
INTCOD = PARAM(4)
Return

$WSRGES_DIA
#-----------------------------
Raz [M:DIA]    # Le mask peut être laisser ouvert par le std - Raz pour INTORG_TBL
               # Effzo ne fonctionne pas dans cette action
[M:DIA]INTCODSEL=INTCOD        # Trt de l'interface demandée uniquement (sinon "")
[M:DIA]FCYORG=FCYORG
[M:DIA]DOSORG=DOSORG
[M:DIA]DOSDES=DOSDES
GDOSPATH=""
#
Call CTL_FCYORG([M:DIA]DOSORG, [M:DIA]FCYORG, WRET)
If !WRET : Return : Endif
If DOSORG<>nomap          
    Local File =DOSORG+".AYTINT"  [AYI1] 
Else
    Local File AYTINT [AYI1] 
Endif
Call INTORG_TBL([M:DIA]DOSORG, [M:DIA]FCYORG, [M:DIA]INTCODSEL)
#
If DOSDES=DOSORG
    [M:DIA]DOSDES =""
Elsif [M:DIA]DOSDES=""
    If GDOSPATH<>"" and DOSDES<>nomap
        WI=GSILENCE : GSILENCE=!WI 
        Call DOSORGDES([M:DIA]DOSORG,GDOSPATH) From DOSCONT
        GSILENCE=WI
        If mkstat
         mkstat = 0
        Else
         [M:DIA]DOSDES = GDOSPATH
        Endif
    Endif
Endif
Call INTDES_TBL([M:DIA]DOSDES)
#
Return

$WSRGES_CTL
#-----------------------------
#
Call COP_CTLFCY([M:DIA]DOSORG, [M:DIA]FCYORG, [M:DIA]DOSDES, RET)
If RET=0 : SAI=1 : Return : Endif
If!find(2,[M:DIA]WSEL)
    GERR=1 : GMESSAGE=mess(187,7900,1)
    SAI=1 : Return
Endif
Return

$WSRGES_EXEC
#-----------------------------
WMSG=mess(183,7900,1)-[M:DIA]FCYORG-"("-[M:DIA]DOSORG-") -> "-[M:DIA]DOSDES-")"
If !GSERVEUR
  TRA=1
  Call TEMPON(WMSG) From GESECRAN 
  Call OUVRE_TRACE(WMSG) From LECFIC
Endif
#
Local Integer WNBWS
For WNL=0 To [M:DIA]NUM-1
    WNBWS+=([M:DIA]WSEL(WNL)=2)
Next
Local Char     INTCOD(GLONAYI)(1..WNBWS)   # Interface de référence avec le WS
WNBWS=0
For WNL=0 To [M:DIA]NUM-1
    If([M:DIA]WSEL(WNL)=2)
        WNBWS+=1
        INTCOD(WNBWS)        =[M:DIA]INTCOD(WNL)
    Endif
Next

Call WSRGES([M:DIA]DOSORG, [M:DIA]FCYORG, [L]INTCOD, [M:DIA]DOSDES, OPTION, RET)       
If RET=0 : FIN=1 : Goto WSRGES_FIN: Endif


$WSRGES_FIN
If !GSERVEUR
  Call TEMPOFF() From GESECRAN 
Endif
Return

$WSRGES_SORTIE
#-----------------------------
If clalev([F:AYS1]) : Close Local File [AYS1] : Endif
If clalev([F:AYS2]) : Close Local File [AYS2] : Endif
If clalev([F:AYI1]) : Close Local File [AYI1] : Endif
If clalev([F:ASU])  : Close Local File [ASU]  : Endif
Return



######################################################################################
### Utilitaires - Gosub et Subprog GUI
######################################################################################

# Ctl sites
# $$$$
#------------------------------------------------------------#
Subprog COP_CTLFCY(DOSORG, FCYORG, DOSDES, RET)
Variable Char    DOSORG()
Variable Char    FCYORG()
Variable Char    DOSDES()
Variable Integer RET        # OK=1
RET=1

# Relecture par sécurité
Call CTL_FCYORG(DOSORG, FCYORG, RET)
If !RET
    Call ECR_TRACE(mess(19,7900,1)-FCYORG,1) From GESECRAN :  End : Endif
 
If DOSORG=DOSDES
        Call ECR_TRACE(mess(184,7900,1),1) From GESECRAN 
        RET=0 : End 
Endif
Call DOSORGDES(DOSORG,DOSDES) From DOSCONT
If mkstat
    RET=0 : mkstat=0 : End 
Endif 
#
End

Subprog CTL_FCYORG(ADOSORG, AFCYORG, RET)
# - - - - - - - - - - - - - - - - - - - - 
Variable Char    ADOSORG()
Variable Char    AFCYORG()
Variable Integer RET        # OK=1
GAYTFCYCOP = AFCYORG
# Infos site
Local Char FCYORG(GLONAYS), DOSORG(GDIMFIC)
[L]DOSORG = ADOSORG : [L]FCYORG = AFCYORG : Gosub  FCYREADORG From AYTCOP      # classe AYS1
RET=(fstat=0)
End

# Chargement du tableau à partir des interfaces du site origine
#--------------------------------------------------------------------------#
Subprog INTORG_TBL(DOSORG, FCYORG, INTCODSEL)
Value Char DOSORG()
Value Char FCYORG()
Local Char WFILT(250)

Effzo [DIA]50    # Rappel Effzo ne fonctionne pas dans l'action INIT_DIA d'où ajout Raz dans celle-ci
If ([L]DOSORG="" or [L]FCYORG="") : End : Endif

Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
WS_DOSDES=[L]DOSORG

WFILT='FCYCOD="'+[L]FCYORG+'"'
If [L]INTCODSEL<>"" : WFILT+=' and INTCOD="'+[L]INTCODSEL+'"' : Endif
For [AYI1]AYI1 Where evalue(WFILT)
    
    WNL=[M:DIA]NUM
    If !find([F:AYI1]WEBSRCCOD, [M:DIA]WEBSRCCOD)
        [M:DIA]WEBSRCCOD(WNL)    =[F:AYI1]WEBSRCCOD
        # Infos WS 
        If [AYI1]WEBSRCCOD="AWRKTAB" : Dbgaff : Endif

        WS_INTTYP=[F:AYI1]TYP : WS_WSRCOD=[F:AYI1]WEBSRCCOD
        Gosub GETWS_INF  From SUBAYIACT 

        If WS_RET<>2 :  # 2 egale probleme avec le trt genenre , on s'en fou !
         [M:DIA]WRETWSORG(WNL)=WS_RET
         [M:DIA]WMSG(WNL)=WS_MES
        Endif

        Case WS_INTTYP
        When 1,4    # Accès généré
            [M:DIA]PRG(WNL)=WS_ASUTRT : [M:DIA]SUBPRG(WNL)=WS_ASUSPG 
            #If WS_RET=2     # Pas de trt: non bloquant car affichage à partir des infos d'ASU
        When 2,20    # Ss-prgm
            [M:DIA]PRG(WNL)=WS_ASUTRT : [M:DIA]SUBPRG(WNL)=WS_ASUSPG 
        When 3, 21    # Objet, liste gauche
            [M:DIA]PRG(WNL)=WS_WXTRT : [M:DIA]SUBPRG(WNL)=WS_WXSPG 
#            [M:DIA]WMSG(WNL)=mess(185,7900,1) : [M:DIA]WRETWSORG(WNL)=99
        Endcase
    Endif
    [M:DIA]INTTYP(WNL)       =[F:AYI1]TYP
    [M:DIA]INTCOD(WNL)       =[F:AYI1]INTCOD
    [M:DIA]NUM+=1
Next
End


# Chargement du tableau selon les informations du site de destination
#--------------------------------------------------------------------------#
Subprog INTDES_TBL(DOSDES)
Value Char DOSDES()

If [L]DOSDES="" : End : Endif

Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF (raz)
WS_DOSDES=[L]DOSDES 
For WNL=0 To [M:DIA]NUM-1
    If [M:DIA]WEBSRCCOD(WNL)<>"" and [M:DIA]WRETWSORG(WNL)=0        # pas d'erreur origine
        # Infos WS 
        WS_INTTYP=[M:DIA]INTTYP(WNL) : WS_WSRCOD=[M:DIA]WEBSRCCOD(WNL)
        Gosub GETWS_INF  From SUBAYIACT 
        [M:DIA]WRETWSDES(WNL)=WS_RET
        If !WS_RET    #  Existe déjà
            [M:DIA]WMSG(WNL)=mess(182,7900,1)
        Endif
    Endif
Next
End

######################################################################################
###     Utilitaires générations subprog et funprog 
######################################################################################
#------------------------------------------------------------#
# Gestion Web service d'un site Xtend
# $$$$
#  Nota: Utilisation de l'interface comme support de la demande 
#        car elle permet de retrouver toutes les informations
#------------------------------------------------------------#
Subprog WSRGES(DOSORG, FCYORG, INTCODORG, DOSDES, OPTION, RET)       
Value Char     DOSORG              # sodaix01:5000@XTEND
Value Char     FCYORG              # 
Value Char     INTCODORG()(1..)    # Code interface - Ce code permet de remonter à toutes les informations
Value Char     DOSDES              # sodaix01:5000@XTEND
Value Char     OPTION()(1..)       # Options 
                                   #   'TRADET'    =Trace détaillée
                                   #   'DESCOP'    =Copie du design
Variable Integer RET : RET=1       # 0:Ko 1: Ok  2: Warning

Local Integer  INTTYP               # Type données interface Xtend (mnl 7912)
Local Char     WEBSRCCOD(12)        # Nom de publication
Local Char     SP_PRG(GLONADC)           # Code trt
Local Char     SP_SUBPRG(GLONASU)   # Code ss-prgm
Local Char     SP_OBJCOD(GLONATB)      # Code de la table ou de la vue (accès généré)
Local Char     OB_COD(GLONAOB)       # Cas objet X3      : code objet
Local Integer  OB_INV                # idem              : zone invisible
Local Char     OB_VAR(10)            # idem              : code variante
Local Integer  WSGEN_TYP            # Type de WS (1 objet, 2 ssprgm)


Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        #  sodaix01:5000 ; XTEND
Local Char MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)

Local Integer TRADETFLG   : TRADETFLG =find("TRADET",OPTION)
Local Char WSTR1(250), WMSG(250), DES(50)
Local Integer WI, WNBELT, WNL, WRET, WOKCREWS

Local Integer STAT, OK, OKTRT
Local Char    FICORG(250) , FICDES(250) , FICLCK(250)

WMSG=mess(183,7900,1)-DOSORG-" -> "-DOSDES
Call ECR_TRACE(WMSG,0) From GESECRAN
#
Call MACHINE([L]DOSORG,MACORG,DOSNAMORG) From ORDSYS
Call MACHINE([L]DOSDES,MACDES,DOSNAMDES) From ORDSYS
#
If DOSORG<>nomap          
    Local File =DOSORG+".AYTINT"  [AYI1] 
Else
    Local File AYTINT [AYI1] 
Endif
#
Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
WS_DOSDES=[L]DOSORG 
#
For WNL=1 To dim(INTCODORG)
    Raz INTTYP, WEBSRCCOD, SP_PRG, SP_SUBPRG, SP_OBJCOD, OB_COD, OB_INV, OB_VAR

    Read [AYI1]AYI0=[L]FCYORG;[L]INTCODORG(WNL)
    If fstat
        Call ECR_TRACE(mess(172,7900,1)-":"-[L]FCYORG-"/"-[L]INTCODORG(WNL),1) From GESECRAN
        RET=2 : Goto NEXTLG
    Endif
    
    # Web service à traiter
    Call TEMPON([AYI1]WEBSRCCOD) From GESECRAN
    WMSG="-->"-mess(186,7900,1)-[AYI1]WEBSRCCOD-"("-mess([AYI1]TYP,7912,1)-")"    
    Call ECR_TRACE(WMSG,0) From GESECRAN
    INTTYP=[AYI1]TYP : WEBSRCCOD=[AYI1]WEBSRCCOD 

    # Infos WS 
    WS_INTTYP=[F:AYI1]TYP : WS_WSRCOD=[F:AYI1]WEBSRCCOD
    Gosub GETWS_INF  From SUBAYIACT 
    If WS_RET<>0 & WS_RET<>2
        Call ECR_TRACE(WS_MES,1) From GESECRAN
        RET=2 : Goto NEXTLG
    Endif
    #

    Case INTTYP
    When 1,4,2,20    # Accès généré table et vue, accès ss-prgm, action ss-prgm 
      # Copie ASU
      SP_PRG = WS_ASUTRT : SP_SUBPRG = WS_ASUSPG   
      Gosub COP_ASU    
      If WRET=0 : RET=2 : Goto NEXTLG : Endif
      # Copie trt : bug  67712 'Fct copie de webservice et fichier source'
      #Call COP_TRT(MACORG,DOSNAMORG,MACDES,DOSNAMDES,[L]SP_PRG,WRET)
      #If WRET=0 : RET=2 : Goto NEXTLG : Endif
      # Compil trt
      #Call COP_TRTGEN(DOSDES,[L]SP_PRG, WRET)
      #If WRET=0 : RET=2 : Goto NEXTLG : Endif

      # Copie trt publication
      #Call COP_TRT(MACORG,DOSNAMORG,MACDES,DOSNAMDES,"WR"+[L]WEBSRCCOD,WRET)
      #If WRET=0 : RET=2 : Goto NEXTLG : Endif
      # Compil trt publication
      #Call COP_TRTGEN(MACDES,DOSNAMDES,"WR"+[L]WEBSRCCOD, WRET)

      # Gestion publication
      WSGEN_TYP=2
      Gosub COP_PUB
      If WRET=0 : RET=2 : Goto NEXTLG : Endif

 #  Autre méthode (possible si lancement sur adonix distant)
 #   A la place de copie, compil et publi
 #
 #       OBJCOD =[AYI1]CODFIC  <-- A récupérer en fct du type d'interface
 #       Gosub COP_XTD    # Génération WS par Xtend
 #       If WRET=0 : RET=2 : Goto NEXTLG : Endif

    When 3,21    # Objet (supposé existant sur la destination...)
      # Gestion publication
      WSGEN_TYP=1
      OB_COD=WS_WXOBJ  : OB_INV=WS_WXINV  : OB_VAR=WS_WXVAR
      Gosub COP_PUB
      If WRET=0 : RET=2 : Goto NEXTLG : Endif

    When Default
        Call ECR_TRACE("Type of interface unknown",1) From GESECRAN
    Endcase

$NEXTLG
Next

$FCYCOPPRG_F
End

######################################################################################
## Gosub
#
#  ATTENTION: en attente d'avoir le lancement sur un moteur distant 
#            --> sinon cela n'est pas stable car la plupart des procédures 
#                    n'utilise pas des tables avec un dossier distant
#
######################################################################################
#------------------------------------------------------------#
# Copie fiche sous-programme
# $$$$
#------------------------------------------------------------#
$COP_ASU
WRET=1
Call ECR_TRACE(mess(188,7900,1)-SP_PRG-"/"-SP_SUBPRG,0) From GESECRAN  
Call COPOBJ([M:DIA]DOSORG,[M:DIA]DOSDES,"ASU",SP_PRG,SP_SUBPRG,"","") From ACOPIE
If GERR : GERR=0 : WRET=0 : Endif
Return

#------------------------------------------------------------#
# Génération WS par Xtend (accès généré)
# $$$$
#------------------------------------------------------------#
$COP_XTD
Call GENSUBPRG([M:DIA]DOSDES, [L]INTTYP, [L]SP_OBJCOD , [L]WEBSRCCOD, WRET) From SUBAYIWSRGE1
Return

#------------------------------------------------------------#
# Copie traitement (repris de COPTRT de SUBADC)
# $$$$
#------------------------------------------------------------#
Subprog COP_TRT(MACORG, DOSNAMORG, MACDES, DOSNAMDES , PRG, RET)
Value Char         MACORG()        # sodaix02:15180
Value Char         DOSNAMORG()     # XTEND
Value Char         MACDES          # sodaix02:15180
Value Char         DOSNAMDES       # XTEND
Value Char         PRG()
Variable Integer   RET : RET=1
Local Integer STAT
Local Char    FICORG(250) , FICDES(250) , FICLCK(250)

Call ECR_TRACE(mess(189,7900,1)-PRG,0) From GESECRAN  

Call PATHFIL(FICLCK,"TRT",PRG,"LCKsrc",DOSNAMDES,"",MACDES) From DOSCONT
If filinfo(FICLCK,0)>=0
 Call ERREUR("|"+FICLCK-"|\"-mess(13,139,1)) From GESECRAN : # Traitement verrouillé
 RET=0 : End
Endif
Call PATHFIL(FICORG,"TRT",PRG,"src",DOSNAMORG,"",MACORG) From DOSCONT
If filinfo(FICORG,0)>=0
 Call PATHFIL(FICDES,"TRT",PRG,"src",DOSNAMDES,"",MACDES) From DOSCONT
 Call COPIE(FICORG,FICDES,STAT) From ORDSYS
 If STAT 
    Call ECR_TRACE( mess(190,7900,1)-[L]PRG,1) From GESECRAN
    RET=0 : End
 Endif
Endif

#Call PATHFIL(FICORG,"TRT",PRG,"xrc",DOSNAMORG,"",MACORG) From DOSCONT
#If filinfo(FICORG,0)>=0
# Call PATHFIL(FICDES,"TRT",PRG,"xrc",DOSNAMDES,"",MACDES) From DOSCONT
# Call COPIE(FICORG,FICDES,STAT) From ORDSYS
#Endif

#Call EXISTE_ADX(MACORG,DOSNAMORG,PRG,OKTRT) From ORDSYS
#If OKTRT>0
# Call EFFACE_ADX(MACDES,DOSDES,PRG,STAT) From ORDSYS : # Pour copier les droits
#Endif
#Call COPIE_ADX(MACORG,DOSNAMORG,PRG,MACDES,DOSNAMDES,PRG,STAT) From ORDSYS
#If GERR : RET=0 : Endif
End

#------------------------------------------------------------#
# Génération traitement adonix
# $$$$    
#------------------------------------------------------------#
Subprog COP_TRTGEN( DOSDES, PRG, RET)
Value Char         DOSDES          # sodaix02:15180@XTEND
Value Char PRG()
Variable Integer RET : RET=1
Local Char    WMSG(250)
Local Integer WSTAT

WMSG=mess(62,7900,1)-[L]PRG
Call ECR_TRACE(WMSG,0) From GESECRAN
Call TEMPON(WMSG) From GESECRAN
Call VALID("TRT",[L]PRG,DOSDES,WSTAT) From VALMSKSUB
If !WSTAT : RET=0 : Endif
End

#------------------------------------------------------------#
# Publication traitement 
#  Génére et crée la fiche de publication si sur machine courante
# $$$$
#------------------------------------------------------------#
$COP_PUB
WRET=1
Call ECR_TRACE(mess(63,7900,1)-WEBSRCCOD,0) From GESECRAN

Call COPOBJ([M:DIA]DOSORG,[M:DIA]DOSDES,"AWE",[L]WEBSRCCOD,"","","") From ACOPIE
If MACDES=""
 [M:AWE0]PUBLI = [L]WEBSRCCOD
 [M:AWE1]PRG   = SP_PRG
 Local Char SUBPRGTT(100) : [L]SUBPRGTT   = SP_SUBPRG
 Gosub CHMAPSPG From SUBAWE
 Call PUBLIWS([L]DOSDES,[L]WEBSRCCOD) From SUBAWE
 If WOKCREWS
  Call ECR_TRACE(mess(207,7900,1)-[L]WEBSRCCOD-"("-num$(WOKCREWS)-")",1) From GESECRAN
  WRET=0
 Endif
Else
 Call ECR_TRACE(mess(191,7900,1)-MACDES,-1) From GESECRAN
Endif
Return

######################################################################################
## Ecran AYTWSRGES
######################################################################################
Subprog C_FCYORG(VALEUR)
Variable Char    VALEUR()
Local Integer RET
# lecture par sécurité
Call CTL_FCYORG(DOSORG, FCYORG, RET)
If !RET
    Call ECR_TRACE(mess(19,7900,1)-FCYORG,1) From GESECRAN
    mkstat=2
Endif
End

Subprog AM_FCYORG(VALEUR)
Variable Char    VALEUR()
Call INTORG_TBL([M:DIA]DOSORG, VALEUR, [M:DIA]INTCODSEL)
Call INTDES_TBL([M:DIA]DOSDES)
Affzo [M:DIA]50
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Local Integer RET
Call COP_CTLFCY([M:DIA]DOSORG, [M:DIA]FCYORG, VALEUR, RET)
If !RET : mkstat=2 : Endif
GDOSPATH = VALEUR
End

Subprog AM_DOSDES(VALEUR)
Variable Char    VALEUR()
Call INTDES_TBL(VALEUR)
Affzo [M:DIA]50
End

Subprog AM_INTCODSEL(VALEUR)
Variable Char    VALEUR()
Call INTORG_TBL([M:DIA]DOSORG, [M:DIA]FCYORG, VALEUR)
Call INTDES_TBL([M:DIA]DOSDES)
Affzo [M:DIA]50
End

# - - - -
Subprog B1_NUM
Local Integer FLGSEL : FLGSEL=2
Gosub SEL_NUM
End

Subprog B2_NUM
Local Integer FLGSEL : FLGSEL=1
Gosub SEL_NUM
End

$SEL_NUM
Local Integer WI
Local Integer  SAVNOL
Local Shortint FLG, WMKSTAT
SAVNOL=nolign
Local Integer WNEW
For nolign=SAVNOL To [M:DIA]NUM
     WNEW=1
     [M:DIA]WSEL(nolign-1)=FLGSEL  
     If FLGSEL=2
        Call AS_WSEL([M:DIA]WSEL(nolign-1))
        If mkstat
            Raz GMESSAGE,GERR,mkstat
            [M:DIA]WSEL(nolign-1)=1  
        Endif
     Endif
Next
nolign=SAVNOL

If WNEW
 Affzo [M:DIA]50
Endif
Return
# - - - -

Subprog AS_WSEL(VALEUR)
Variable Integer VALEUR
If !(WEBSRCCOD(nolign-1)<>"" and WRETWSORG(nolign-1)=0) 
    mkstat=2
Endif
End

Subprog AV_NUM
If nolign=1 : Diszo [DIA]PRG,INTCOD  : Endif    # Menu contextuel
End

Subprog IB_PRG
GBOUTS="":GBOUTA=""
End

Subprog IB_INTCOD
GBOUTS="":GBOUTA=""
End


