######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "AFFMASK"    : Gosub AFFMASK
 When "RAZCRE"     : Gosub RAZCRE
 When Default
Endcase
Return

######################################################################################
$AFFMASK
[M]FILJOUR1=mess(1,291,1) : Affzo [M]FILJOUR1
[M]FILJOUR2=mess(1,291,1) : Affzo [M]FILJOUR2
Return

######################################################################################
$RAZCRE
[M]GRUBOMFLG=1 : Affzo [M]GRUBOMFLG
[M]FILJOUR1=mess(1,291,1) : Affzo [M]FILJOUR1
[M]FILJOUR2=mess(1,291,1) : Affzo [M]FILJOUR2
[M]ORTLTI=60 : Affzo [M]ORTLTI
# Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
#[M]ORTFLG=2 : Affzo [M]ORTFLG
#/ Issue 98933 - 2014-07-04 by RBA : Volumes managment evolution and V7 adaptations
Return

Subprog AM_ORTLTI(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
    [M]ORTLTI=60 : Affzo ORTLTI
Endif
End

