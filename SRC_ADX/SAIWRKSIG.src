#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(250)(1..4) , VALEUR(10)
PARAM(1) = "AOB0"
#Call S_TAB_CHAR(VALEUR,PARAM,"SIGOBJ","SAIWRKSIG","") From GACTION
Raz GPILOBJ
Call OBJET("AMK",GBIDC1,GBIDC2) From GOBJET
PARAM(1) = ""
#Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKPLN","LISWRKTRN",5,"") From GTRAITE
End

#-----------------------------------------------------------#
# Action SIGWRK (signature d'un workflow)
#-----------------------------------------------------------#

Subprog SIGWRK(CHRONO,USRDES,NEWACT)
Value Char CHRONO , USRDES , NEWACT
Local Char PARAM(250)(1..6) , VALEUR(10) , SPETRT(GLONADC)
PARAM(1) = CHRONO
PARAM(2) = USRDES
PARAM(3) = GUSER
PARAM(4) = ""
PARAM(5) = NEWACT
PARAM(6) = "-2"
Call TRTSPE(nomap,"SIGWRK",SPETRT) From SUBACT
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKSIG","",5,SPETRT) From GTRAITE
GOK = val(PARAM(6))
End

#-----------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "CHX_TABLE"   : Gosub CHX_TABLE
Endcase
Return

#--------------- GTRAITE -----------------------------------#
$INIT
Local Integer ERN , ERD , ERT , BATCH , NUM , NBCLE , VERROU , STAT , LEVSIG , OKL
Local Char    CHRONO(GLONVCR) , NUMORG(GLONVCR) , NUMGRP(GLONVCR)
Local Char    USRORG(GLONAUS) , USRDES(GLONAUS) , USRSIG(GLONAUS) , USRMAIL(GLONMAI)
Local Char    WRKORG(GLONAWA) , USRTOP(GLONAUS)
Local Char    ERM(250) , PREF(3)
Local Char    NOMPROG(GLONADC) , NOMPRIG(GLONADC) , PROGOBJ(GLONADC)
Local Char    CHAINE(250) , VALCLE(250) , CLE(GLONID1)(1..16)
Local Char    FILTRE(250) , RESULT(250) , NEWACT(GLONADI)
Local Char    SYMBOLE(80) , POSTE(80) , UTIL(30)
Local Char    VEROBJ(80) , FORMULE(255) , VERHIS(80)
Local Char    REASON(GLONDES) , REACOD(GLONADI)
Local Integer REANUM , OPECAN
Local Char    SAVCOD(GLONAWA) , SAVREG(GLONAWR) , SAVMOD(GLONAWM)
Local Char    S_USER(GLONAUS) , S_CLEOBJ(GLONID2) , S_ABREV(GLONAOB)
Local Integer S_NBRUSR , NBRUSR

If clalev([F:AWA])=0  : Local File AWRKPAR    [AWA]  : Endif
If clalev([F:AWH])=0  : Local File AWRKPARH   [AWH]  : Endif
If clalev([F:AWF])=0  : Local File AWRKPARF   [AWF]  : Endif
If clalev([F:AWV])=0  : Local File AWRKREGVAL [AWV]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif

Local Char    CTX(GLONID1)(1..dim([F:AWF]VARCTX)) , USER(GLONAUS)(1..dim([F:AWV]USER))
Local Integer REPCHR(0..dim([F:AWF]ACTSIG))

CHRONO  = PARAM(1)        : # Chrono de l'évènément sur lequel on va faire la signature
USRDES  = PARAM(2)        : # Code user du destinataire
USRSIG  = PARAM(3)        : # Code user du signataire
USRMAIL = PARAM(4)        : # Adresse email du signataire (utilisateur externe par lien http)
NEWACT  = PARAM(5)        : # Action suivi
BATCH   = (PARAM(6)="-1") : # Cas de la tâche batch qui traite les signatures sur lien http
ACTWRK  = (PARAM(6)="-2") : # Signature déclenchée par l'action SIGWRK
STAT    = 0               : # Erreur Status de fin de signature

# Préservation de l'environnement workflow déclencheur
If ACTWRK
 If clalev([F:AWR])=0 or clalev([F:AWM])=0
  ERM = mess(79,75,1) : # Environnement workflow
  STAT = 2 : Goto ERREUR
 Endif
 SAVCOD = [F:AWA]CODE
 SAVREG = [F:AWR]REGLE
 SAVMOD = [F:AWM]MODELE
Endif

# Chrono à signer
STAT = 4
Read [AWS2]AWS0 = CHRONO;USRDES
If !fstat
 Case [F:AWS2]FLGSIG
  When 1       : STAT = 2
  When 2,3     : STAT = 0
  When 5       : If NEWACT="CAN" : STAT = 0 : Else : STAT = 3 : Endif
  When Default : STAT = 3
 Endcase
Else
 For [AWS2]AWS0 Where [F]CHRONO=[L]CHRONO
  USRDES = [F:AWS2]DEST
  Case [F:AWS2]FLGSIG
   When 1       : STAT = 2
   When 2,3     : STAT = 0
   When 5       : If NEWACT="CAN" : STAT = 0 : Else : STAT = 3 : Endif
   When Default : STAT = 3
  Endcase
  Break
 Next AWS2
Endif
Case STAT
 When 2 : ERM = USRDES-CHRONO-":"-mess(157,75,1) : # Suivi annulé
 When 3 : ERM = USRDES-CHRONO-":"-mess(127,75,1) : # Suivi déjà signé
 When 4 : ERM = USRDES-CHRONO-":"-mess(100,75,1) : # Suivi non trouvé
Endcase
If STAT : Goto ERREUR : Endif

NUMORG = [F:AWS2]NUMORG   : # Chrono de l'évènement d'origine sur lequel a été faite la première signature
USRORG = [F:AWS2]USRORG   : # Destinataire de cet événement
LEVSIG = [F:AWS2]LEVSIG+1 : # Niveau de signature courant (0=évènement d'origine)
USRTOP = [F:AWS2]USRTOP   : # Destinataire principal (les autres sont des délégués)
NUMGRP = [F:AWS2]NUMGRP   : # Groupe de l'évènement à signer
NBRUSR = [F:AWS2]NBRUSR   : # Nbres de signataire définis par la règle du workflow
For J=1 To NBRUSR
 If evalue("dim([F:AWS2]USRSIG"+num$(J)+")")>0
  USER(J) = evalue("[F:AWS2]USRSIG"+num$(J))
 Endif
Next J

Call SET_PREF([F:AWS2]CODWRK,PREF) From SUBAWA
NOMPROG = PREF+[F:AWS2]CODWRK

Read [AWA]AWA0 = [F:AWS2]CODWRK
If fstat
 ERM = [F:AWS2]CODWRK-":"-mess(107,75,1) : # Paramètrage workflow inexistant
 STAT = 2 : Goto ERREUR
Endif
Read [AWF]AWF0 = [F:AWS2]CODWRK

ERD = ([F:AWA]DEBUG=2)
If BATCH : ERD = 1 : Endif
ERN = 0

# Chrono origine
If NUMORG<>""
 Read [AWS2]AWS0 = NUMORG;USRORG
 If fstat
  ERM = NUMORG-USRORG-":"-mess(113,75,1) : # Suivi d'origine non trouvé
  STAT = 2 : Goto ERREUR
 Endif
 Raz REPCHR
 CHAINE = [F:AWS2]NUMGRP
 Read [AWF]AWF0 = [F:AWS2]CODWRK
 Filter [AWS2] Where [F]NUMGRP=CHAINE & [F]CHRONO=[L]NUMORG
 For [AWS2]AWS4(3)
  If [F:AWS2]ACTSIG="" or [F:AWS2]FLGSIG<=3
   REPCHR(0) += 1 : # Nb de réponses qu'il reste à faire
  Else
   K = find([F:AWS2]ACTSIG,[F:AWF]ACTSIG)
   If K
    REPCHR(K) += 1 : # Réponses par code réponse
   Endif
  Endif
 Next AWS2
 Filter [AWS2]
 Read [AWF]AWF0 = [F:AWA]CODE
 Read [AWS2]AWS0 = NUMORG ; USRORG
Else
 Read [AWS2]AWS0 = CHRONO;USRDES
Endif
Call SET_PREF([F:AWS2]CODWRK,PREF) From SUBAWA
NOMPRIG = PREF+[F:AWS2]CODWRK
WRKORG  = [F:AWS2]CODWRK
For I=1 To dim(CTX)
 CTX(I) = evalue("[F:AWS2]VALCTX"+num$(I))
Next I
S_USER   = [F:AWS2]EMETTEUR
S_CLEOBJ = [F:AWS2]CLEDEC
S_ABREV  = [F:AWS2]ABROBJ
S_NBRUSR = [F:AWS2]NBRUSR

# On vérifie que personne n'est en train de signer ces chronos
For SYMBOLE="AWS"+CHRONO,"AWS"+NUMORG
 If len(SYMBOLE)>3
  Call DEBTRANS From GLOCK
  Gosub VERROU
  If !VERROU
   Call QUILOCKE(SYMBOLE,POSTE,UTIL) From OBJDIV
   ERM = mess(82,75,1) : # Signature en cours
   If UTIL<>""
    ERM += "\"+UTIL+"\"+POSTE
   Endif
   ERM += "\("+mess(20,100,1)-mess(56,100,1)+" |"+SYMBOLE+"|)" : # Erreur de verrouillage sur Symbole
   STAT = 1 : Break
  Endif
 Endif
Next SYMBOLE
If STAT : Goto ERREUR : Endif

Gosub LECTURE
If STAT : Goto ERREUR : Endif

Return

#----------------------------------------------------#
$CONTROLE
If GSERVEUR
 If NEWACT=""
  ERM = mess(76,75,1) : # Opération de signature inexistante
  STAT = 2 : Goto ERREUR
 Endif
Else
 If GSTATUT<>28 | VALEUR=""
  ERM = mess(126,75,1) : # Abandon signature
  STAT = 1 : Goto ERREUR
 Else
  NEWACT = VALEUR
 Endif
Endif
Return

#----------------------------------------------------#
$SORTIE
Case STAT
 When 0       : PARAM(6) = num$(GOK) : # Status de transaction
 When 1       : PARAM(6) = "-1"      : # On a le droit de réessayer (Erreur de lock)
 When Default : PARAM(6) = "0"       : # Erreur grave
Endcase
Gosub DEVERROU
If ACTWRK
 Read [AWA]AWA0 = SAVCOD
 Read [AWF]AWF0 = SAVCOD
 Read [AWH]AWH0 = SAVCOD
 If clalev([F:AWR])>0 : Read [AWR]AWR0 = SAVREG : Endif
 If clalev([F:AWM])>0 : Read [AWM]AWM0 = SAVMOD : Endif
Endif
Return

#----------------------------------------------------#
$EXEC

# Trace
If ERD
 If !BATCH & !ACTWRK
  Call OUVRE_TRACE(mess(98,75,1)-CHRONO) From LECFIC : # Signature du suivi
  TRA = 1
 Else
  ERM = string$(80,"-")+"\"+mess(98,75,1)-CHRONO+"\"+string$(80,"-")
  Gosub TRACE
 Endif
Endif

# Chrono origine
If NUMORG<>""
 Read [AWS2]AWS0 = NUMORG;USRORG
Else
 Read [AWS2]AWS0 = CHRONO;USRDES
Endif

# S'il y a un champ à mettre à jour et que l'évènement déclenchant est un objet on locke l'objet
NUM = find(NEWACT,[F:AWF]ACTSIG)
If NUM & [F:AWF]FLDMAJ(NUM-1)<>"" & [F:AWS2]TYPEVT=2 & !ACTWRK
 PROGOBJ = "WO"+[F:AWS2]CODEVT
 Gosub NOMFIC From =PROGOBJ
 Gosub SETCLE From =PROGOBJ
 CHAINE = [F:AWS2]CLEOBJ
 NBCLE = 0
 While CHAINE<>""
  NBCLE += 1
  I = instr(1,CLE,"~")
  If I
   CLE(NBCLE) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE = ""
  Endif
 Wend
 If TYPGES=2
  SYMBOLE = NOMFIC
 Else
  Case NBCLE
   When 1
    SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(1))
   When Default
    If TYPGES=3
     SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(1)+"\"+CLE(2))
    Else
     SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLE(2)+"\"+CLE(1))
    Endif
    For I=3 To NBCLE
     SYMBOLE += "\"+CLE(I)
    Next I
  Endcase
 Endif
 Call DEBTRANS From GLOCK
 Gosub VERROU
 If !VERROU
  Call QUILOCKE(SYMBOLE,POSTE,UTIL) From OBJDIV
  # Fiche $1$ verrouillée dans l'objet $2$
  ERM = func AFNC.MES2(mess(83,143,1),right$(SYMBOLE,len(ABFIC)+1),[F:AWS2]CODEVT)
  If UTIL<>""
   ERM = "\"+UTIL+"\"+POSTE
  Endif
  ERM += "\("+mess(20,100,1)-mess(56,100,1)+" |"+SYMBOLE+"|)" : # Erreur de verrouillage sur Symbole
  STAT = 1 : Goto ERREUR
 Endif
 VEROBJ = SYMBOLE
Endif

# Lecture de la table principale

STAT = 0
Gosub LECTURE
If STAT : Goto ERREUR : Endif

# Ouverture de la table des lignes
If OKL
 Gosub LNKGRP From =NOMPRIG : # Filtre groupe
 CHAINE = [F:AWS2]IDENTGRP
 K = instr(1,CHAINE,"/")
 CHAINE = right$(CHAINE,K+1)
 Raz FILTRE
 For I=1 To dim(DEFGRP)
  If DEFGRP(I)<>""
   K = instr(1,CHAINE,"~")
   If K
    VALCLE = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    VALCLE = CHAINE
    CHAINE = ""
   Endif
   If I>1 : FILTRE += ' & ' : Endif
   FILTRE += DEFGRP(I)+'='
   Case TYPGRP(I)
    When 1,2,3,4,5,6 : FILTRE += VALCLE
    When 8           : FILTRE += '['+right$(VALCLE,7)+'/'+mid$(VALCLE,5,2)+'/'+left$(VALCLE,4)+']'
    When Default     : FILTRE += '"'+VALCLE+'"'
   Endcase
  Endif
 Next I
 If FILTRE="" : FILTRE = "1=1" : Endif
 # Pour se positionner sur un des enregistrements du groupe
 If !ACTWRK
  Gosub LNKLIG From =NOMPRIG : # Ouverture du link
  If clalev([F:LNK_])>0 & ((dim([L]LNKLIG)>0 & [L]LNKLIG>0) or dim([L]LNKLIG)<1)
   For [LNK_] Where evalue(FILTRE)
    Break
   Next LNK_
  Endif
 Endif
Endif

# Evaluation de la formule , modif éventuelle du résultat et saisie éventuelle du motif
Raz RESULT , FORMULE , REASON , REANUM , REACOD
If NUM
 If [F:AWF]EXPVAL(NUM-1)<>""
  FORMULE = format$("KTv2:255X",[F:AWF]EXPVAL(NUM-1))
  Onerrgo RIEN
  RESULT = num$(evalue(FORMULE))
  Onerrgo
  FORMULE = ""
 Endif
 If [F:AWF]MODSIG(NUM-1)=2
  Gosub VALSIG From =NOMPROG
  If !GSERVEUR
   Call SAICAR(RESULT,mess(71,75,1),INTZON,TYPZON,LIBZON,LNGZON,"",OK) From GESECRAN : # Signature
  Endif
 Endif
 If !GSERVEUR
  If [F:AWF]REANUM(NUM-1)<>0
   REANUM = [F:AWF]REANUM(NUM-1)
   Call SAICAR(REACOD,mess(155,75,1),mess(155,75,1),"ADI",REANUM,0,"",OK) From GESECRAN : # Motif réponse
   If REACOD<>""
    Call LECTEXTRA(REASON,"ATABDIV","LNGDES",num$(REANUM),REACOD) From ATEXTRA
   Endif
  Endif
 Endif
Endif

# Transaction de signature
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_SIGNATURE
Else
 Gosub SIGNATURE
Endif

If GOK=1
 ERM = mess(98,75,1)-CHRONO : # Signature du suivi
 Gosub TRACE
Endif

If ERD
 If TRA
  Call FERME_TRACE From LECFIC
 Else
  ERM = string$(80,"-")
  Gosub TRACE
 Endif
Endif

Return

#--------------------------------------#
$LECTURE
Gosub OUVREF From =NOMPRIG
OKL = (TABREF<>"")
#If OKL & !ACTWRK      # 121482 - Allow reading of the data model from SIGWRK- old
If OKL                 # 121482 - Allow reading of the data model from SIGWRK- new
 Gosub LNKREF From =NOMPRIG
 CHAINE = [F:AWS2]IDENTREF
 K = instr(1,CHAINE,"/")
 CHAINE = right$(CHAINE,K+1)
 For I=1 To dim(DEFREF)
  If DEFREF(I)<>""
   K = instr(1,CHAINE,"~")
   If K
    VALCLE = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    VALCLE = CHAINE
    CHAINE = ""
   Endif
   Onerrgo ERR
   Case TYPREF(I)
    When 1,2,3,4,5,6 : Assign ("[F]"+DEFREF(I)) With val(VALCLE)
    When 8           : Assign ("[F]"+DEFREF(I)) With evalue("["+VALCLE+"]")
    When Default     : Assign ("[F]"+DEFREF(I)) With VALCLE
   Endcase
   Onerrgo
   If ERN : ERN = 0 : Break : Endif
  Endif
 Next I
 Read [F] =
 If fstat
  ERM = [F:AWS2]IDENTREF-":"-mess(81,75,1) : # Enregistrement non trouvé
  STAT = 2 : Return
 Endif
 Gosub LECENT From =NOMPRIG : # Lecture des tables 1,1
Endif
Return

#------------------------------------------------------------------------------------#
$TR_SIGNATURE
Trbegin [AWA]
 Gosub SIGNATURE
 If GOK=-1 : Goto ROLL_SIGNATURE
 Elsif GOK<1 : Goto AB_SIGNATURE
 Endif
Commit
Return

$AB_SIGNATURE
Rollback
Return

$ROLL_SIGNATURE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_SIGNATURE : Endif

#------------------------------------------------------#
$SIGNATURE
# Appel du traitement défini dans le workflow
If [F:AWA]ENAACT=2
 Raz FORMULE , ERN
 Gosub EXEACT_SIG From =NOMPROG
 If ERN
  Gosub TRACE
 Elsif CHAINE<>""
  ERM = mess(65,75,1)-CHAINE : # Exécution action
  Gosub TRACE
 Endif
 FORMULE = ""
Endif

# Mise à jour du champ défini dans le paramètrage workflow
If GOK=1 & NUM & [F:AWF]FLDMAJ(NUM-1)<>""
 If clalev([F:LNK_])>0 & ((dim([L]LNKLIG)>0 & [L]LNKLIG>0) or dim([L]LNKLIG)<1)
  Gosub MAJ_LINK : # Mise à jour groupe
 Else
  Gosub MAJ_TABLE : # Mise à jour sur une des tables liées 1,1
 Endif
Endif

# Traitement du workflow associé à l'action
OPECAN = 0
If GOK=1 & NUM & [F:AWF]OPESIG(NUM-1)<>""
 CHAINE  = NUMORG
 CHAINE += "~"+USRORG
 CHAINE += "~"+CHRONO
 CHAINE += "~"+USRDES
 CHAINE += "~"+USRSIG
 CHAINE += "~"+USRMAIL
 CHAINE += "~"+num$(LEVSIG)
 CHAINE += "~"+num$(ACTWRK)
 CHAINE += "~"+REASON
 ERM = mess(124,75,1)-[F:AWF]OPESIG(NUM-1)-CHRONO : # Exécution workflow signature
 Gosub TRACE
 If [F:AWF]OPESIG(NUM-1)="CAN"
  OPECAN = 1
  Call ANUSIG(CHRONO,USRDES) From ANUWRKSIG
 Else
  Call WORKFLOW(9,WRKORG,[F:AWF]OPESIG(NUM-1),CHAINE) From AWRK
 Endif
Endif

# Signature de la ligne du suivi (uniquement signature des suivis du destinataire principal)
If GOK=1 & !OPECAN
 Gosub MAJ_SUI
Endif

Return

#-------------------------------------------------------------------#
$DEVERROU
VERHIS = func GOBJACT.SYMBOLE_VERROU("AWS","")
For SYMBOLE=VERHIS+CHRONO,VERHIS+NUMORG,VEROBJ
 If len(SYMBOLE)>3
  Unlock =SYMBOLE
 Endif
Next SYMBOLE
Return

#-------------------------------------------------------------------#
$VERROU
Lock =SYMBOLE With lockwait=0
If !fstat
 VERROU = 1
Else
 GLOCK = "%"+SYMBOLE
 Call ROLL From GLOCK
 If GROLL
  VERROU = 0
 Else
  Goto VERROU
 Endif
Endif
Return

#----------------------------------------------------#
$RIEN
Resume

#----------------------------------------------------#
$ERR
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
Gosub TRACE
Resume

#----------------------------------------------------#
$TRACE
If ERD
 If FORMULE<>"" and ERN>0 : # 114538 CCL
  ERM += "\"+mess(65,106,1)-"\"+FORMULE : # Erreur en évaluation de la formule
 Endif
 Call ECR_TRACE(ERM,ERN) From GESECRAN
Endif
Return

#----------------------------------------------------#
$ERREUR
If ERM<>""
 Call ECR_TRACE(ERM,STAT) From GESECRAN
Endif
Gosub DEVERROU
FIN = 1
Return

#----------------------------#
$MAJ_LINK
Gosub DEFSUI From =NOMPROG
If TABSUI<>""
 If ACTWRK
  If evalue(FILTRE)
   Gosub REW_LINK
  Endif
 Else
  For [LNK_] Where evalue(FILTRE)
   Gosub REW_LINK
   If GOK<1 : Break : Endif
  Next LNK_
 Endif
Endif
Return

$REW_LINK
Readlock =
If fstat=1
 GOK=-1 : GLOCK="$"+TABSUI : Return
Elsif fstat
 GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
Endif
Onerrgo ERR
Case evalue("type("+[F:AWF]FLDMAJ(NUM-1)+")")
 When 1,2,4,5,6,7 : Assign [F:AWF]FLDMAJ(NUM-1) With val(RESULT)
 When 3           : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
 When Default     : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
Endcase
Onerrgo
If ERN
 Raz ERN : Return
Else
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
 Endif
 ERM = mess(92,75,1)-[F:AWF]FLDMAJ(NUM-1)-"("+RESULT+")" : # Mise à jour du champ
 If CLEGRP<>""
  ERM -= "-"-mess(139,75,1)-evalue(CLEGRP) : # Regroupement
 Endif
 Gosub TRACE
Endif
Return

#----------------------------#
$MAJ_TABLE
Gosub DEFSUI From =NOMPROG
If TABSUI<>""
 Readlock =
 If fstat=1
  GOK=-1 : GLOCK="$"+TABSUI : Return
 Elsif fstat
  GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
 Endif
 Onerrgo ERR
 Case evalue("type("+[F:AWF]FLDMAJ(NUM-1)+")")
  When 1,2,4,5,6,7 : Assign [F:AWF]FLDMAJ(NUM-1) With val(RESULT)
  When 3           : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
  When Default     : Assign [F:AWF]FLDMAJ(NUM-1) With RESULT
 Endcase
 Onerrgo
 If ERN
  Raz ERN
 Else
  Rewrite [F]
  If fstat
   GOK=0 : Call FSTA(ABRSUI) From GLOCK : Return
  Endif
  ERM = mess(92,75,1)-[F:AWF]FLDMAJ(NUM-1)-"("+RESULT+")" : # Mise à jour du champ
  Gosub TRACE
 Endif
Endif
Return

#----------------------------------------------------#
$MAJ_SUI
For [AWS2] Where [F]CHRONO=[L]CHRONO & [F]USRTOP=[L]USRTOP
 Readlock [AWS2]AWS0 Curr
 If fstat=1
  GOK=-1 : GLOCK="$AWRKHISSUI" : Break
 Elsif fstat
  GOK=0 : Call FSTA("AWS") From GLOCK : Break
 Endif
 [F:AWS2]FLGSIG = 5 : # Signé
 [F:AWS2]ACTSIG = NEWACT
 [F:AWS2]USRSIG = USRSIG
 [F:AWS2]MAISIG = USRMAIL
 [F:AWS2]DATSIG = date$
 [F:AWS2]TIMSIG = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
 [F:AWS2]REASON = [L]REASON
 [F:AWS2]REANUM = [L]REANUM
 [F:AWS2]REACOD = [L]REACOD
 Rewrite [AWS2]
 If fstat
  GOK=0 : Call FSTA("AWS") From GLOCK : Break
 Endif
Next AWS2
Return

#--------------- GACTION -----------------------------------#
$SEL_LISTE
Local Char    INTACT(30) , FORMULE(255)
Local Char    NUMGRP(GLONVCR) , CHRONO(GLONVCR)
Local Integer K
Local Integer ERD , ERT, ERN
Local Char    ERM(250)
Local Char    S_USER(GLONAUS) , S_CLEOBJ(GLONID2) , S_ABREV(GLONAOB)
Local Integer S_NBRUSR , NBRUSR

If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
If clalev([F:AWA])=0  : Local File AWRKPAR    [AWA]  : Endif
If clalev([F:AWF])=0  : Local File AWRKPARF   [AWF]  : Endif
If clalev([F:AWV])=0  : Local File AWRKREGVAL [AWV]  : Endif
If clalev([F:AWS3])=0 : Local File AWRKHISSUI [AWS3] : Endif

Local Integer REPCHR(0..dim([F:AWF]ACTSIG))
Local Char    CTX(GLONID1)(1..dim([F:AWF]VARCTX)) , USER(GLONAUS)(1..dim([F:AWV]USER))

If PARAM(5)<>""
 NBTEX = 1
 TEX(NBTEX) = PARAM(5)
 Return
Endif

Read [AWS2]AWS0 = PARAM(1);PARAM(2)
If fstat
 Read [AWS2]AWS0(1) = PARAM(1)
 If fstat
  ERM = PARAM(1)-PARAM(2)-":"-mess(100,75,1) : # Suivi non trouvé
  STAT = 2 : Goto ERREUR
 Endif
Endif

Read [AWA]AWA0 = [F:AWS2]CODWRK
Read [AWF]AWF0 = [F:AWS2]CODWRK

NUMGRP = [F:AWS2]NUMGRP
CHRONO = [F:AWS2]CHRONO
For I=1 To dim(CTX)
 CTX(I) = evalue("[F:AWS2]VALCTX"+num$(I))
Next I
S_USER   = [F:AWS2]EMETTEUR
S_CLEOBJ = [F:AWS2]CLEDEC
S_ABREV  = [F:AWS2]ABROBJ
S_NBRUSR = [F:AWS2]NBRUSR
NBRUSR   = [F:AWS2]NBRUSR
For J=1 To NBRUSR
 If evalue("dim([F:AWS2]USRSIG"+num$(J)+")")>0
  USER(J) = evalue("[F:AWS2]USRSIG"+num$(J))
 Endif
Next J

# Nombre de réponses par code réponse qui ont étés faites sur le chrono
Raz REPCHR
Filter [AWS3] Where [F]NUMGRP=[L]NUMGRP & [F]CHRONO=[L]CHRONO
For [AWS3]AWS4(3)
 If [F:AWS3]ACTSIG="" or [F:AWS3]FLGSIG<=3
  REPCHR(0) += 1 : # Nb de réponses qu'il reste à faire
 Else
  K = find([F:AWS3]ACTSIG,[F:AWF]ACTSIG)
  If K
   REPCHR(K) += 1 : # Réponses par code réponse
  Endif
 Endif
Next AWS3
Filter [AWS3]

# Liste des réponses possibles
ERD = ([F:AWA]DEBUG=2)
Raz NBTEX
For I=1 To [F:AWF]NBRSIG
 K = ([F:AWF]OPESIG(I-1)<>"CAN")
 If K & [F:AWF]CNDSIG(I-1)<>""
  FORMULE = format$("KTv2:250X",[F:AWF]CNDSIG(I-1))
  Onerrgo ERR
  K = val(num$(evalue(FORMULE)))
  Onerrgo
  FORMULE = ""
  If ERN : K = 0 : Endif
 Endif
 If K
  If NBTEX>=dim(TEX)-1 : Break : Endif
  NBTEX += 1
  TEX(NBTEX) = [F:AWF]ACTSIG(I-1)
  Call LECTEXTRA(INTACT,"ATABDIV","LNGDES","54",[F:AWF]ACTSIG(I-1)) From ATEXTRA
  TEXTE(NBTEX) = [F:AWF]ACTSIG(I-1)-INTACT
 Endif
Next I
TIT = mess(73,75,1) : # Choix d'une réponse
Return

#-----------------------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SIGCHR" : Gosub SEL_SIGCHR : # Historique signatures d'un objet
 When "SIGOBJ" : Gosub SEL_SIGOBJ : # Suivis non signés pour un objet
 When "SIGCIR" : Gosub SEL_SIGCIR : # Visualisation circuit de signature
Endcase
Return

#-----------------------------------------------------------------------------------------#
$CHX_TABLE
Case TABLE
 When "SIGCHR" : Gosub CHX_SIGCHR
 When "SIGOBJ" : Gosub CHX_SIGOBJ
 When "SIGCIR" : Gosub CHX_SIGCIR
Endcase
Return

#-------------------------------------#
$SEL_SIGOBJ
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif
If clalev([F:AWU])=0  : Local File AWRKUSR    [AWU]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif

Local Char    AUZ(23) , TABDEL(30)(1..200) , ZON(30)
Local Integer NBDEL
Local Char    WCHRONO(GLONVCR)(1..GNBSEL) , WEMETTEUR(GLONAUS)(1..GNBSEL) , WDEST(GLONAUS)(1..GNBSEL)
Local Char    WTEXSUI(GDIMFIC)(1..GNBSEL) , WUSRSIG(GLONAUS)(1..GNBSEL) , WCLEDEC(GLONDES)(1..GNBSEL)
Local Integer WTYPEVT(1..GNBSEL) , WDELEGUE(1..GNBSEL)
Local Date    WDATENV(1..GNBSEL) , WDATMAXSIG(1..GNBSEL) , WDATSIG(1..GNBSEL)

Local File   (Char CHRONO(GLONVCR) , Date DATENV , Char EMETTEUR(GLONAUS) , Char DEST(GLONAUS)
&           , Integer TYPEVT , Char TEXSUI(GDIMFIC) , Char USRSIG(GLONAUS) , Date DATSIG
&           , Integer DELEGUE , Date DATMAXSIG , Char CLEDEC(GLONDES))
&             From Variable WCHRONO , WDATENV , WEMETTEUR , WDEST , WTYPEVT , WTEXSUI , WUSRSIG
&           , WDATSIG , WDELEGUE , WDATMAXSIG , WCLEDEC As [AW__] Order By CHRONO

NBCOL = 0
For ZON="CHRONO","DATENV","EMETTEUR","DEST","TYPEVT","TEXSUI","USRSIG","DATSIG","DELEGUE","DATMAXSIG","CLEDEC"
 NBCOL += 1
 Case ZON
  When "TYPEVT"
   COL(NBCOL) = "mess([F:AW__]TYPEVT,988,1)"
   COLTYP(NBCOL) = 1
  When "DELEGUE"
   COL(NBCOL) = "mess([F:AW__]DELEGUE,1,1)"
   COLTYP(NBCOL) = 1
  When Default
   COL(NBCOL) = "[F:AW__]"+ZON
   COLTYP(NBCOL) = evalue("type([F:AW__]"+ZON+")")
 Endcase
 Call TITZON("AWRKHISSUI",ZON,TIT(NBCOL)) From CONTOBJ
Next ZON
Call DROITSITEF("SAIWRKPLN","",AUZ,OK) From EXEFNC
If !OK or !instr(1,AUZ,"G") : OK = 0 : Return : Endif
Raz TABDEL
NBDEL = 0
For [AWU] Where TYPDEL=3 & USRDEL=GUSER
 If !find([F:AWU]USER+"~"+[F:AWU]NATURE,TABDEL(1..NBDEL))
  If NBDEL<dim(TABDEL)
   NBDEL += 1
   TABDEL(NBDEL) = [F:AWU]USER+"~"+[F:AWU]NATURE
  Endif
 Endif
Next AWU
CRITERE = '[F:AWS]FLGSIG=3'
CRITERE += ' & (([F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ="'+PARAM(1)+'")'
CRITERE += ' | ([F:AWS]TYPEVT=9 & [F:AWS2]CLEOBJ="'+PARAM(1)+'"))' : # AW2 lien évènement d'origine
Link [AWS] With
& [AWS2]AWS0=[F:AWS]NUMORG;[F:AWS]USRORG
& As [AS__]
& Where evalue(CRITERE)
J = 0
For [AS__]
 K = ([F:AWS]DEST=GUSER)
 If NBDEL
  K += find([F:AWS]DEST+"~",TABDEL(1..NBDEL))
  K += find([F:AWS]DEST+"~"+[F:AWS]NATURE,TABDEL(1..NBDEL))
 Endif
 If K
  If J>=dim(WCHRONO) : Break : Endif
  J += 1
  WCHRONO(J)    = [F:AWS]CHRONO
  WDATENV(J)    = [F:AWS]DATENV
  WEMETTEUR(J)  = [F:AWS]EMETTEUR
  WDEST(J)      = [F:AWS]DEST
  WTYPEVT(J)    = [F:AWS]TYPEVT
  WTEXSUI(J)    = [F:AWS]TEXSUI
  WUSRSIG(J)    = [F:AWS]USRSIG
  WDATSIG(J)    = [F:AWS]DATSIG
  WDELEGUE(J)   = [F:AWS]DELEGUE
  WDATMAXSIG(J) = [F:AWS]DATMAXSIG
  WCLEDEC(J)    = [F:AWS]CLEDEC
 Endif
Next AS_
For I=J+1 To dim(WCLEDEC)
 WCLEDEC(I) = chr$(255)
Next I
If J=0
 Call MESSAGE(mess(106,75,1)) From GESECRAN : # Pas de signature à traiter
 OK = 0 : Return
Endif
adxmxl = J
CRITERE = ""
ORDRE = "CLEDEC Asc;CHRONO Desc"
Default File [AW__]
Return

#-------------------------------------#
$CHX_SIGOBJ
TIT = mess(85,75,1)-PARAM(1) : # Suivis à signer
Return

#-------------------------------------#
$SEL_SIGCHR
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
Local Char WCLEOBJ(GLONID1) , WCLELIG(GLONID1)
WCLEOBJ = PARAM(1)
I = instr(1,WCLEOBJ,'"')
While I
 WCLEOBJ = left$(WCLEOBJ,I-1)+"'"+right$(WCLEOBJ,I+1)
 I = instr(1,WCLEOBJ,'"')
Wend
WCLELIG = PARAM(2)
I = instr(1,WCLELIG,'"')
While I
 WCLELIG = left$(WCLELIG,I-1)+"'"+right$(WCLELIG,I+1)
 I = instr(1,WCLELIG,'"')
Wend
If WCLELIG<>""
 CRITERE = '(([F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ="'+WCLEOBJ+'" & [F:AWS]IDENTGRP="'+WCLELIG+'")'
 CRITERE += ' | ([F:AWS]TYPEVT=9 & [F:AWS2]CLEOBJ="'+WCLEOBJ+'" & [F:AWS2]IDENTGRP="'+WCLELIG+'"))'
Else
 CRITERE = '(([F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ="'+WCLEOBJ+'")'
 CRITERE += ' | ([F:AWS]TYPEVT=9 & [F:AWS2]CLEOBJ="'+WCLEOBJ+'"))' : # AW2 lien évènement d'origine
Endif
OBJET = "AWS"
ORDRE = "[F:AWS]IDENTGRP Asc;[F:AWS]CHRONO Desc"
Return

#-------------------------------------#
$CHX_SIGCHR
TIT = mess(118,75,1)-PARAM(1) : # Historique signatures
Return

#-------------------------------------#
$SEL_SIGCIR
If clalev([F:AWS])=0  : Local File AWRKHISSUI [AWS]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
If clalev([F:AWV])=0  : Local File AWRKREGVAL [AWV]  : Endif

Local Integer NBAUS : NBAUS = dim([F:AWV]USER)
Local Integer NBTOP : NBTOP = 100
Local Char    WCLEOBJ(GLONID1) , WCLELIG(GLONID1) , ZON(30)
Local Char    WTBTOP(GLONAUS)(1..NBTOP)
Local Date    WTBDAT(1..NBTOP)
Local Integer WNBTB
Local Integer WNUM(1..NBAUS) , WFLG(1..NBAUS), WDELEGUE(1..NBAUS)
Local Char    WUSR(GLONAUS)(1..NBAUS) , WUSRSIG(GLONAUS)(1..NBAUS) , WREPSIG(GLONADI)(1..NBAUS)
Local Char    WMOTIF(GLONDES)(1..NBAUS) , WTIMSIG(GLONHS)(1..NBAUS)
Local Date    WDATSIG(1..NBAUS) , WDATMAX(1..NBAUS)
Local Char    WDEST(GLONAUS)(1..NBAUS)

#jira 60352 add column delegate flag + delegate user
#
Local File   (Integer NUM , Char DEST(GLONAUS), Char USER(GLONAUS), Integer DELEGUE ,  Date DATSIG , Char TIMSIG(GLONHS)
&           , Char USRSIG(GLONAUS) , Char ACTSIG(GLONADI) , Integer FLGSIG
&           , Char REASON(GLONDES) , Date DATMAXSIG)
&             From Variable WNUM ,WDEST , WUSR , WDELEGUE , WDATSIG , WTIMSIG , WUSRSIG , WREPSIG , WFLG
&           , WMOTIF , WDATMAX As [AS__] Order By NUM

NBCOL = 0
For ZON="DEST","USER","DELEGUE","DATSIG","TIMSIG","USRSIG","ACTSIG","FLGSIG","REASON","DATMAXSIG"
 NBCOL += 1
 Case ZON
  When "FLGSIG"
   COL(NBCOL) = "mess([F:AS__]FLGSIG,2922,1)"
   COLTYP(NBCOL) = 1
  When "DELEGUE"
   COL(NBCOL) = "mess([F:AS__]DELEGUE,1,1)"
   COLTYP(NBCOL) = 1
  When Default
   COL(NBCOL) = "[F:AS__]"+ZON
   COLTYP(NBCOL) = evalue("type([F:AS__]"+ZON+")")
 Endcase
 Call TITZON("AWRKHISSUI",ZON,TIT(NBCOL)) From CONTOBJ
Next ZON
WCLEOBJ = PARAM(1)
I = instr(1,WCLEOBJ,'"')
While I
 WCLEOBJ = left$(WCLEOBJ,I-1)+"'"+right$(WCLEOBJ,I+1)
 I = instr(1,WCLEOBJ,'"')
Wend
WCLELIG = PARAM(2)
I = instr(1,WCLELIG,'"')
While I
 WCLELIG = left$(WCLELIG,I-1)+"'"+right$(WCLELIG,I+1)
 I = instr(1,WCLELIG,'"')
Wend
If WCLELIG<>""
 CRITERE = '([F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ="'+WCLEOBJ+'" & [F:AWS]IDENTGRP="'+WCLELIG+'")'
Else
 CRITERE = '([F:AWS]TYPEVT=2 & [F:AWS]CLEOBJ="'+WCLEOBJ+'")'
Endif
WNBTB = 0
OK = 0

For [AWS] Where evalue(CRITERE)
 OK = 1 : # Pas de break : on veut le dernier
 If WNBTB>=dim(WTBTOP) : Break : Endif
 WNBTB += 1
 WTBTOP(WNBTB) = [F:AWS]USRTOP
 WTBDAT(WNBTB) = [F:AWS]DATMAXSIG
Next AWS
If !OK : Return : Endif
J = 0
For I=1 To [F:AWS]NBRUSR
 If evalue("[F:AWS]USRSIG"+num$(I))="" : Break : Endif
 WNUM(I) = I
 WUSR(I) = evalue("[F:AWS]USRSIG"+num$(I))
 K = find(WUSR(I),WTBTOP(1..WNBTB))
 If K
  WDATMAX(I) = WTBDAT(K)
 Else
  WDATMAX(I) = [F:AWS]DATMAXSIG
 Endif
 WFLG(I) = 9
 J += 1
Next I
For I=J+1 To dim(WNUM)
 WNUM(I) = 9999
Next I
adxmxl = J
For [AWS]AWS0 Where evalue(CRITERE)
 I = 1
 #jira 60352 add column delegate flag + delegate user
 WDEST  (I)  = [F:AWS]DEST
 If WUSR(I)  = WDEST  (I)
    WUSR(I)  = ""
 Endif
 WUSRSIG(I)  = [F:AWS]USRSIG
 WDELEGUE(I) = [F:AWS]DELEGUE
 WDATSIG(I)  = [F:AWS]DATSIG
 WTIMSIG(I)  = string$([F:AWS]TIMSIG<>"",format$("K:##[:]##[:]##",[F:AWS]TIMSIG))
 WREPSIG(I)  = [F:AWS]ACTSIG
 WFLG(I)     = max(1,[F:AWS]FLGSIG)
 WMOTIF(I)   = [F:AWS]REASON
 While I<J
  I += 1
  For [AWS2]AWS1 Where NUMORG=[F:AWS]CHRONO & LEVSIG=I-1
   WDEST  (I)  = [F:AWS]DEST
   If WUSR(I)  = WDEST  (I)
        WUSR(I)  = ""
   Endif
   WUSRSIG(I)  = [F:AWS2]USRSIG
   WDELEGUE(I) = [F:AWS]DELEGUE
   WDATSIG(I)  = [F:AWS2]DATSIG
   WTIMSIG(I)  = string$([F:AWS2]TIMSIG<>"",format$("K:##[:]##[:]##",[F:AWS2]TIMSIG))
   WREPSIG(I)  = [F:AWS2]ACTSIG
   WFLG(I)     = max(1,[F:AWS2]FLGSIG)
   WMOTIF(I)   = [F:AWS2]REASON
  Next AWS2
 Wend
Next AWS
CRITERE = ""
ORDRE = "NUM"
Default File [AS__]
Return

#-------------------------------------#
$CHX_SIGCIR
TIT = mess(161,75,1) : # Circuit de signature
Return

