#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque HBP2
########################################
Subprog AM_DSYFLG(VALEUR)
Variable Integer VALEUR

Case nolign
    When 1
        GHBP1SQH = VALEUR
        GHBP1SOH = [M:HBP2]DSYFLG(1)
        GHBP1SDH = [M:HBP2]DSYFLG(2)
        GHBP1SIV = [M:HBP2]DSYFLG(3)
        GHBP1BPRSIH = [M:HBP2]DSYFLG(4)
        
    When 2
        GHBP1SQH = [M:HBP2]DSYFLG(0)
        GHBP1SOH = VALEUR
        GHBP1SDH = [M:HBP2]DSYFLG(2)
        GHBP1SIV = [M:HBP2]DSYFLG(3)
        GHBP1BPRSIH = [M:HBP2]DSYFLG(4)

    When 3
        GHBP1SQH = [M:HBP2]DSYFLG(0)
        GHBP1SOH = [M:HBP2]DSYFLG(1)
        GHBP1SDH = VALEUR
        GHBP1SIV = [M:HBP2]DSYFLG(3)
        GHBP1BPRSIH = [M:HBP2]DSYFLG(4)

    When 4
        GHBP1SQH = [M:HBP2]DSYFLG(0)
        GHBP1SOH = [M:HBP2]DSYFLG(1)
        GHBP1SDH = [M:HBP2]DSYFLG(2)
        GHBP1SIV = VALEUR
        GHBP1BPRSIH = [M:HBP2]DSYFLG(4)

    When 5
        GHBP1SQH = [M:HBP2]DSYFLG(0)
        GHBP1SOH = [M:HBP2]DSYFLG(1)
        GHBP1SDH = [M:HBP2]DSYFLG(2)
        GHBP1SIV = [M:HBP2]DSYFLG(3)
        GHBP1BPRSIH = VALEUR

Endcase

#Enregistre les nouveaux paramètres pour cet utilisateur.
Call DEBTRANS From GLOCK
Trbegin [DVA]
Readlock [DVA] DVA0 = "HBP";GUSER
If fstat
    #Enregistrement non trouvé, il faut le créer
    [F:DVA]OBC = "HBP"
    [F:DVA]PARAM = GUSER
    [F:DVA]INTX(0) = GHBP1SQH 
    [F:DVA]INTX(1) = GHBP1SOH
    [F:DVA]INTX(2) = GHBP1SDH
    [F:DVA]INTX(3) = GHBP1SIV
    [F:DVA]INTX(4) = GHBP1BPRSIH
    Write [DVA]
    If fstat
        #Erreur modification
        GMESSAGE = mess(101,141,1)
        GERR = 1
        Unlock [DVA]
        Rollback
    Else
        Commit
        GHBP2PARMOD = 1
    Endif
Else
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:DVA]OBC = "HBP"
    [F:DVA]PARAM = GUSER
    [F:DVA]INTX(0) = GHBP1SQH 
    [F:DVA]INTX(1) = GHBP1SOH
    [F:DVA]INTX(2) = GHBP1SDH
    [F:DVA]INTX(3) = GHBP1SIV
    [F:DVA]INTX(4) = GHBP1BPRSIH
    Rewrite [DVA]
    If fstat
        #Erreur modification
        GMESSAGE = mess(101,141,1)
        GERR = 1
        Unlock [DVA]
        Rollback
    Else
        Commit
        GHBP2PARMOD = 1
    Endif
Endif

#On revient sur du vrai booléen
If GHBP1SQH = 2
    GHBP1SQH = 1
Else
    GHBP1SQH = 0
Endif

If GHBP1SOH = 2
    GHBP1SOH = 1
Else
    GHBP1SOH = 0
Endif

If GHBP1SDH = 2
    GHBP1SDH = 1
Else
    GHBP1SDH = 0
Endif

If GHBP1SIV = 2
    GHBP1SIV = 1
Else
    GHBP1SIV = 0
Endif

If GHBP1BPRSIH = 2
    GHBP1BPRSIH = 1
Else
    GHBP1BPRSIH = 0
Endif

[M:HBP2]DSYFLG(nolign - 1) = VALEUR
Affzo [M:HBP2]DSYFLG(nolign - 1)

End

