#<AdxTL>@(#)10.0.0.0 $Revision$
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
                         #       'AYI_ACCWS'      Génération Web services liés à une interface type Accès généré
                         #       'AYI_ACCWS_Q'    Poser question pour Génération Web services liés à une interface type Accès généréValue Char DOSORG, FCYORG, TIMSTP, MODGEN
                         #       'CHK'            Vérification lien interface (non utilisé)
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissement
#
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer WS_SUBPRG_R, WS_INFOS_RET, WS_GEN_RET    # Code retour  0:Ok 1:Ko
Local Char WSTR1(250), WPUBLI_PREV(12)
Local Char U_TXTTOHEX(250),U_HEXTOTXT(250)
Local Char WS_GRP_PAR(GLONAPU), WS_GRP_WHR, WS_GRP_ORD   # Groupe des champs AXPARCOD, AXWHRCOD, AXORDCOD    

RET=1

Call TITOBJ("AYO","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN 
#If CHKFLG  : Call ECR_TRACE(mess(175,7900,1),0) From GESECRAN : Endif
Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
If DOSORG =nomap 
 Local File AYTPOOWEB  [AYO1] 
 Local File APOOLWS  [APW1] 
Else 
 Local File =[L]DOSORG+".AYTPOOWEB"  [AYO1] 
Local File =[L]DOSORG+".APOOLWS"  [APW1] 
Endif 
Default File "[AYO1],[APW1]"
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_TIMSTP=TIMSTP
XT_XMLID="WSC"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
XT_TY="ELMTS"  : XT_ID=XT_XMLID    : Gosub XMLF_ADD From AYTGEN
For [AYO1]AYO0
    Read [APW1]APW1=[F]POOX3
    If fstat Then
        Call ECR_TRACE(mess(216,7900,1)-[F]POOCOD,1) From GESECRAN
        RET=2    
    Else
    WNBREC+=1
     XT_TY="ELMT"  : XT_ID=[F:AYO1]POOCOD    : XT_VAL=[F:AYO1]POODES         : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="SOL"  : XT_VAL=[F:APW1]SOLUTION                   : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="FLDR"  : XT_VAL=[F:APW1]DOSSIER                   : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="HOST"  : XT_VAL=[F:APW1]SERWEB                    : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="PORT"  : XT_VAL=num$([F:APW1]PORTWEB)             : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="HOSTPUB"  : XT_VAL=[F:APW1]SADDEXT                : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="PORTPUB"  : XT_VAL=num$([F:APW1]PORTWEBEXT)       : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="SECURED"  : XT_VAL=num$([F:AYO1]POOSEC)           : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="POOLALIAS"  : XT_VAL=[F:APW1]POOLALIAS            : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="USER"  : XT_VAL=[F:AYO1]USR                       : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="PWD"  : XT_VAL=[F:AYO1]USRMDP                     : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="LANG"  : XT_VAL=[F:AYO1]USRLAN                    : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"  : XT_ID="TIMEOUT"  : XT_VAL=num$([F:AYO1]POOTIMOUT)        : Gosub XMLF_ADD From AYTGEN
    Endif
Next
$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYO1],[APW1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End
