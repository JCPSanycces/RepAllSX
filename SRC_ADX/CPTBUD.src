#<AdxTL>@(#)7.0.0.0 $Revision$
#####################################################################################
## Vérfication des paramètres du chapitre BUD -> BUPx budgets à contrôler :
##  Subprog VERF_PARAM(PARAM, VALEUR, OK)
##
## Contrôle et lecture budgétaire :
##  Subprog BUDGET(DAT,SITE,LEDTYP,DEVISE,COMPTE,TBDIE,TBCCE,MONTANT,QUANTITE,CONTBUD,OK,MESSA)
##
## Visualisation du budget (idem SAIVISBUD) :
##  Subprog VISU(DAT,SITE,LEDTYP,COMPTE,TBCCE)
##
## Mise à jour budgétaire (balance analytique d'engagement amt+qty) :
##  Subprog MAJBUD(DAT,SITE,LEDTYP,LED,DEVCUR,AMTCUR,AMTLED,QUANTITE,COMPTE,TIERS,TBDIE,TBCCE,SENS,SIGN,TYP,CONTBUD,OK,MESSA)
##
#####################################################################################

#Contrôle des paramètres chapitre BUD, group CMM, BUPx budget à contrôler
Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM
Value Char VALEUR
Variable Integer OK
If !find(PARAM,"BUP1","BUP2","BUP3","BUP4","BUP5","BUP6","BUP7","BUP8","BUP9")
 #Erreur dans le code paramètre
 GMESSAGE = mess(204, 196, 2)
 GERR = 1
 OK = 0
 End
Endif
If !clalev([F:BUP]) : Local File BUDPAR [BUP] : Endif
If VALEUR<>""
 Read [BUP]BUP0 = VALEUR
 If !fstat & [F:BUP]BUDCTL=1
  If func AFNC.ACTIV("GDD") & [F:BUP]GDDFLG=2
   OK=1 : End
  Endif
  #Ce budget ne peut pas être contrôlé car son type de contrôle est à 'Aucun'
  GMESSAGE=VALEUR-mess(264,108,1)
  mkstat=2
  GERR=1
  OK=0
  End
 Endif
Endif
OK=1
End

Subprog BUDGET(DAT,SITE,LEDTYP,DEVISE,COMPTE,TBDIE,TBCCE,MONTANT,QUANTITE,CONTBUD,OK,MESSA)
Value    Date    DAT
Value    Char    SITE
Value    Integer LEDTYP
Value    Char    DEVISE
Value    Char    COMPTE()
Value    Char    TBDIE()(1..)
Value    Char    TBCCE()(1..)
Value    Decimal MONTANT
Value    Decimal QUANTITE
Value    Integer CONTBUD
Variable Integer OK
Variable Char    MESSA()

If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif

If clalev([F:BLA])=0  : Local File BALANA     [BLA]  : Endif
If clalev([F:BLM])=0  : Local File BLACMM     [BLM]  : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY     [BLQ]  : Endif

If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE  [TCH]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
If clalev([F:CLS])=0  : Local File GACCCLS    [CLS]  : Endif

If clalev([F:CRY])=0  : Local File GCCEGRUPYM [CRY]  : Endif
If clalev([F:GRY])=0  : Local File GACCGRUPYM [GRY]  : Endif
If clalev([F:CYK])=0  : Local File GCCEPYMLIK [CYK]  : Endif
If clalev([F:GYK])=0  : Local File GACCPYMLIK [GYK]  : Endif

If clalev([F:DIE])=0  : Local File GDIE       [DIE]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif

If func AFNC.ACTIV("GDD")
 If clalev([F:ENV])=0  : Local File ENVELOPPE  [ENV]  : Endif
 If clalev([F:ENF])=0  : Local File ENVFIY     [ENF]  : Endif
Endif

If clalev([F:LED])=0  : Local File GLED        [LED]  : Endif

If clalev([F:CYK1])=0  : Local File GCCEPYMLIK [CYK1] : Endif
If clalev([F:CYK2])=0  : Local File GCCEPYMLIK [CYK2] : Endif
If clalev([F:CYK3])=0  : Local File GCCEPYMLIK [CYK3] : Endif
If clalev([F:CYK4])=0  : Local File GCCEPYMLIK [CYK4] : Endif
If clalev([F:CYK5])=0  : Local File GCCEPYMLIK [CYK5] : Endif
If clalev([F:CYK6])=0  : Local File GCCEPYMLIK [CYK6] : Endif
If clalev([F:CYK7])=0  : Local File GCCEPYMLIK [CYK7] : Endif
If clalev([F:CYK8])=0  : Local File GCCEPYMLIK [CYK8] : Endif
If clalev([F:CYK9])=0  : Local File GCCEPYMLIK [CYK9] : Endif

Local Char    SOCIETE(GLONCPY)
Local Char    BUDFCY(GLONFCY)
Local Char    BUDACC(GLONGAC)
Local Char    BUDVER(GLONBUV)
Local Char    GRUREF(max(GLONCYR,GLONGRY)) : # Groupe sections/comptes auquel est DIRECTEMENT rattaché la section/compte
Local Char    SECTION(GLONCCE)
Local Char    DEVCPY(GLONCUR) , DEVBUD(GLONCUR)
Local Integer B , AX
Local Integer STA , NBMESSA , OK2 , OKB
Local Integer I1 , I2 , I3 , I4 , I5 , I6 , I7 , I8 , I9 , I10, K , IEXO
Local Decimal EXERCICE , PERIODE, EXODEB, EXOFIN, PERDEB, PERFIN, PER1, PER2
Local Decimal COURS , MTBUD , QTBUD , MTREL , QTREL , MTNEW , QTNEW
Local Decimal MTBLA, QTBLA, MTCMM, QTCMM, MTPRP, QTPRP
Local Decimal SIGN
Local Integer STAT, VU
Local Decimal MNTBUD
Local Char    LED(GLONLED) , DEVLED(GLONCUR) , PLAN(GLONCOA)
Local Char    LEDBUDCCE(GLONCCE)(9)
Local Char    CRITBLA(250)(0..2), CRITPYR(250)(0..2)
Local Integer IBLA, IPYR
Local Char    BUDCCE(GLONCCE)(1..9)
Local Integer I, J, ISITE, ISOC

Local Integer SEP  : # Separator , already written in the Link
Local Integer STAT : # Status
Local Char    FILPROG(GLONADC) , FILSRC(250) , FILADX(250) : # Generation of the Link
Local Integer OKBUDCCE(1..9)  : # =1 : the dimension is not a pyramid or the dimension exists in the pyramid level
Local Integer NUMCCE(1..9)    : # Index of the dimension in the ledger (different from the index in BUDPAR table)
Local Char    ACCSIGN(GLONGAC): # Keep the account to search the sign

#Indispensable mise à jour des globales de paramètrage budgétaire (contrôles)
Call DEFVAR(SITE)

ISITE = find(SITE,GSITE(1..GNBSITE))
If ISITE=0
 MESSA = mess(4,108,1)+"\"+mess(15,104,1)-SITE
 OK = -1 : End
Endif
SOCIETE = GSOCSITE(ISITE)
ISOC = find(SOCIETE,GSOC(1..GNBSOC))
If ISOC=0
 MESSA = mess(4,108,1)+"\"+mess(16,104,1)-SOCIETE
 OK = -1 : End
Endif

DEVCPY = GDEVSOC(ISOC)
Call LECTURE("TCU",DEVCPY,"") From CONTOBJ

Call LECLED(SOCIETE,LEDTYP,LED,DEVLED) From CPTDIV
Call LECPLAN(SOCIETE,LEDTYP,PLAN) From CPTDIV

GPOINT = "BEFACSBUD" : Gosub ENTREE From EXEFNC
BUDACC=COMPTE

OK = 1
Raz MESSA, NBMESSA

##Vérifications/Contrôle des Budgets opérationnels
If func AFNC.ACTIV("GDD")
 Gosub VERF_GDD
 If OK<1 & CONTBUD=2 : GOK = 0 : End : Endif
 OK = 1
Endif
##

For B=1 To GBUDNB
 OKB = 1
 If GBUDGET(B)<>""
  Call LECTURE("BUP",GBUDGET(B),"") From CONTOBJ
  ## Déconnection des budgets flagué Budgets Opérationnels du contrôle standard
  If [F:BUP]GDDFLG<>2
    #--- Contrôle de validité de dates
    Raz mkstat
    Call CTLVLYDAT(DAT,[F:BUP]VLYSTR,[F:BUP]VLYEND) From CPTSUB
    If mkstat : Raz mkstat : Raz GMESSAGE : OKB = 0 : Endif
    If OKB
     # Exercices, périodes
     Case [F:BUP]BUDCTL
      When 2,3 : # Contrôle Annuel et par période
       Call GETPERSOC(SOCIETE,LEDTYP,DAT,EXERCICE,PERIODE) From CPTSUB
       If EXERCICE=0 | PERIODE=0
        MESSA = mess(4,108,1)+"\"+mess(1,104,1)
        # Contrôle budgétaire / Date incorrecte
        OK = -1 : Break
        If CONTBUD=2 : GOK = 0 : Break : Endif
       Endif
       EXODEB = EXERCICE
       EXOFIN = EXERCICE
      When 4   : # Contrôle global
       Call GETPERSOC(SOCIETE,LEDTYP,[F:BUP]VLYSTR,EXODEB,PERDEB) From CPTSUB
       If EXODEB=0 | PERDEB=0
        Filter [PER] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
        Read [PER]PER0 First
        If !fstat
         EXODEB = [F:PER]FIYNUM
         PERDEB = [F:PER]PERNUM
        Endif
       Endif
       If [F:BUP]VLYEND<>[0/0/0]
        Call GETPERSOC(SOCIETE,LEDTYP,[F:BUP]VLYEND,EXOFIN,PERFIN) From CPTSUB
        If EXOFIN=0 | PERFIN=0
         Filter [PER] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & PERSTR<=[F:BUP]VLYEND & PEREND<=[F:BUP]VLYEND
         Read [PER]PER0 Last
         If !fstat
          EXOFIN = [F:PER]FIYNUM
          PERFIN = [F:PER]PERNUM
         Endif
        Endif
       Else
        Gosub DERPEREXO
       Endif
       If EXODEB=0 | PERDEB=0 | EXOFIN=0 | PERFIN=0
        MESSA = mess(4,108,1)+"\"+mess(1,104,1)
        # Contrôle budgétaire / Date incorrecte
        OK = -1 : Break
        If CONTBUD=2 : GOK = 0 : Break : Endif
       Endif
      When 5   : # Contrôle cumulé
       Call GETPERSOC(SOCIETE,LEDTYP,[F:BUP]VLYSTR,EXODEB,PERDEB) From CPTSUB
       If EXODEB=0 | PERDEB=0
        Filter [PER] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
        Read [PER]PER0 First
        If !fstat
         EXODEB = [F:PER]FIYNUM
         PERDEB = [F:PER]PERNUM
        Endif
       Endif
       Call GETPERSOC(SOCIETE,LEDTYP,DAT,EXOFIN,PERFIN) From CPTSUB
       If EXODEB=0 | PERDEB=0 | EXOFIN=0 | PERFIN=0
        MESSA = mess(4,108,1)+"\"+mess(1,104,1)
        # Contrôle budgétaire / Date incorrecte
        OK = -1 : Break
        If CONTBUD=2 : GOK = 0 : Break : Endif
       Endif
     Endcase
    Endif

    DEVBUD = [F:BUP]CUR

    # ARV 060608 Voir à utiliser le plan du paramétrage
    # budget [F:BUP]COA qui serait sans doute plus justifié
    # Vérif que compte ana et sections sont budgétisables

    Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
    If [F:GAC]BUDTRK<>2 : OKB = 0 : Endif

    If OKB
     For AX=1 To dim([F:BUP]DIE)
      If [F:BUP]DIE(AX-1)<>""
       VU = find([F:BUP]DIE(AX-1),TBDIE(1..dim(TBDIE)-1))
       If VU
        If TBCCE(VU) = ""
         OKB = 0 : Break
        Else
         Call LECTURE("CCE",TBCCE(VU),TBDIE(VU)) From CONTOBJ
         If [F:CCE]BUDTRK<>2 : OKB = 0 : Break : Endif
        Endif
       Else
        OKB = 0 : Break
       Endif
      Endif
     Next AX
    Endif

    # Contrôle proprement dit
    If OKB
     If [F:BUP]LEV=1
      BUDFCY = ""
     Else
      BUDFCY = SITE
     Endif

     Gosub LIRE_BUD

     # 06/11/06 - Suite à la demande de PE 34915
     # BUDEXISTS pour PE 'BUDCTL'

     If OKB & (dim([L]BUDEXISTS)<0 | (dim([L]BUDEXISTS)>0 & [L]BUDEXISTS=1))

      Call VERF_BUD(PERIODE,MONTANT,QUANTITE,DEVISE,DEVLED,DEVBUD,DEVCPY,GBUDTYPCUR,DAT
&               ,BUDACC,MTBUD,QTBUD,MTBLA,QTBLA,MTCMM,QTCMM,MTPRP,QTPRP,OK2)

      GPOINT = "AFTBUDCTL" : Gosub ENTREE From EXEFNC

      If OK2=1
       NBMESSA += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(5,108,1)-GBUDGET(B)-GBUDVER(B)-BUDACC
       For I=1 To 9  : MESSA -= BUDCCE(I) : Next
       OK = 0
       If CONTBUD=2 : GOK = 0 : Break : Endif
       If NBMESSA>=6 : Break : Endif
      Elsif OK2=2
       NBMESSA += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(7,108,1)-GBUDGET(B)-GBUDVER(B)-BUDACC
       For I=1 To 9  : MESSA -= BUDCCE(I) : Next
       OK = 0
       If CONTBUD=2 : GOK = 0 : Break : Endif
       If NBMESSA>=3 : Break : Endif
      Elsif OK2=3
       NBMESSA += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(4,108,1)+"\"+mess(4,109,1)-DEVBUD-"=>"-DEVLED
       OK = -1
       If CONTBUD=2 : GOK = 0 : Break : Endif
      Elsif OK2=4
       NBMESSA += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(4,108,1)+"\"+mess(4,109,1)-DEVISE-"=>"-DEVLED
       OK = -1
       If CONTBUD=2 : GOK = 0 : Break : Endif
      Endif
     Endif
    Endif
  Endif :#GDDFLG
 Endif
Next B
If OK=-1 : End : Endif
End

$LIRE_BUD
# Compte ou pyramide de comptes
Raz BUDACC
If [F:BUP]PYMACC=""
 BUDACC = COMPTE
Else
 Filter [GRY] Where PYM=[F:BUP]PYMACC & pat(COMPTE,ACC)<>0
 Read [GRY]GRY0 First
 Filter [GRY]
 If ! fstat
  GRUREF = [F:GRY]GRU
  Filter [GRY] Where PYM=[F:BUP]PYMACC & GRU=GRUREF & LEV=[F:BUP]PYMACCLEV
  Read [GRY]GRY0 First
  Filter [GRY]
  If !fstat
   BUDACC = GRUREF
  Else
   Read [GYK]GYK0=[F:BUP]PYMACC;[F:BUP]PYMACCLEV;COMPTE
   If !fstat
    BUDACC = [F:GYK]GRU
   Else
    Filter [GYK] Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV
    Read [GYK]GYK0 First
    Filter [GYK]
    If !fstat
     BUDACC = [F:GYK]GRU
    Endif
   Endif
  Endif
 Endif
Endif

# Sections & pyramide section
Raz BUDCCE
Raz OKBUDCCE
For AX=1 To dim([F:BUP]DIE)
 If [F:BUP]DIE(AX-1)="" : Break : Endif
 VU = find([F:BUP]DIE(AX-1),TBDIE(1..dim(TBDIE)-1))
 If VU
  BUDCCE(AX) = TBCCE(VU)
 Endif
 If [F:BUP]PYMCCE(AX-1)="" : # pas de pyramide pour cet axe
  If VU
   OKBUDCCE(AX) = 1
  Endif
 Else                      : # pyramide pour cet axe
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(AX-1) & pat(BUDCCE(AX),CCE)<>0
  Read [CRY]CRY0 First
  Filter [CRY]
  If !fstat
   GRUREF = [F:CRY]GRU
   Filter [CRY] Where PYM=[F:BUP]PYMCCE(AX-1) & GRU=GRUREF & LEV=[F:BUP]PYMCCELEV(AX-1)
   Read [CRY]CRY0 First
   Filter [CRY]
   If !fstat
    BUDCCE(AX) = GRUREF
    OKBUDCCE(AX) = 1
   Else
    If BUDCCE(AX)<>""
     Read [CYK]CYK0 = [F:BUP]PYMCCE(AX-1);[F:BUP]PYMCCELEV(AX-1);BUDCCE(AX)
     If !fstat
      BUDCCE(AX) = [F:CYK]GRU
      OKBUDCCE(AX) = 1
     Else
      Filter [CYK] Where PYM=[F:BUP]PYMCCE(AX-1) & LEV=[F:BUP]PYMCCELEV(AX-1)
      Read [CYK]CYK0 First
      Filter [CYK]
      If !fstat
       BUDCCE(AX) = [F:CYK]GRU
       OKBUDCCE(AX) = 1
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Next

If BUDACC="" or sum(OKBUDCCE)<>[F:BUP]DIENBR
 OKB=0 : Return
Endif

# Lecture budget
Raz MTBUD,QTBUD

OKB=0
Gosub INIVAR_LEDBUDCCE
For IEXO=EXODEB To EXOFIN
 Read [BUD]BUD0 = LEDTYP;GBUDGET(B);SOCIETE;BUDFCY;IEXO;GBUDVER(B);BUDACC;
&                 LEDBUDCCE(0);LEDBUDCCE(1);LEDBUDCCE(2);LEDBUDCCE(3);LEDBUDCCE(4);
&                 LEDBUDCCE(5);LEDBUDCCE(6);LEDBUDCCE(7);LEDBUDCCE(8)
 If fstat
  Raz [BUD]
 Else
  OKB=1
 Endif
 GPOINT = "BUDCTL" : Gosub ENTREE From EXEFNC
 Case [F:BUP]BUDCTL
  When 2   : # Annuel
   MTBUD += sum([F:BUD]AMT)
   QTBUD += sum([F:BUD]QTY)
  When 3   :# Par période
   MTBUD += [F:BUD]AMT(PERIODE-1)
   QTBUD += [F:BUD]QTY(PERIODE-1)
  When 4,5 : # Contrôle global et cumulé
   If IEXO=EXODEB & IEXO=EXOFIN
    MTBUD += sum([F:BUD]AMT(PERDEB-1..PERFIN-1))
    QTBUD += sum([F:BUD]QTY(PERDEB-1..PERFIN-1))
   Elsif IEXO=EXODEB
    MTBUD += sum([F:BUD]AMT(PERDEB-1..dim([F:BUD]AMT)-1))
    QTBUD += sum([F:BUD]QTY(PERDEB-1..dim([F:BUD]QTY)-1))
   Elsif IEXO=EXOFIN
    MTBUD += sum([F:BUD]AMT(0..PERFIN-1))
    QTBUD += sum([F:BUD]QTY(0..PERFIN-1))
   Else
    MTBUD += sum([F:BUD]AMT(0..dim([F:BUD]AMT)-1))
    QTBUD += sum([F:BUD]QTY(0..dim([F:BUD]QTY)-1))
   Endif
 Endcase
Next

# Lecture balance
Raz MTBLA,QTBLA,MTCMM,QTCMM,MTPRP,QTPRP
#
# La balance se décompose en 3, balance analytique, balance en quantité et balance d'engagemment
If [F:BUP]PYMACC="" & [F:BUP]PYMCCE(0)="" & [F:BUP]PYMCCE(1)="" & [F:BUP]PYMCCE(2)=""
&                   & [F:BUP]PYMCCE(3)="" & [F:BUP]PYMCCE(4)="" & [F:BUP]PYMCCE(5)=""
&                   & [F:BUP]PYMCCE(6)="" & [F:BUP]PYMCCE(7)="" & [F:BUP]PYMCCE(8)=""

 Raz CRITBLA, IBLA
 Call ADDCRIT(CRITBLA,IBLA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
 Call ADDCRIT(CRITBLA,IBLA,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITBLA,IBLA,"FCY",'FCY="'+BUDFCY+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITBLA,IBLA,"COA",'COA="'+PLAN+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITBLA,IBLA,"ACC",'ACC="'+BUDACC+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITBLA,IBLA,"BPR",'BPR=""'," & ") From GOBJSUB
 For AX=1 To 9
  If LEDBUDCCE(AX-1)<>""
   Call ADDCRIT(CRITBLA,IBLA,"CCE","CCE"+num$(AX)+"='"+LEDBUDCCE(AX-1)+"'"," & ") From GOBJSUB
  Endif
 Next
 Call LEC_GAC(BUDACC,PLAN) From CPTLEC
 Call LEC_COA(PLAN) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
 If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif

 # Parcours des balances
 For IEXO=EXODEB To EXOFIN
  #Balance analytique BALANA [BLA]
  #BLA0=>LEDTYP+CPY+FCY+FIY+ACC+BPR+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9+CUR
  Filter [BLA] Where evalue(CRITBLA) & FIY=IEXO
  For [BLA]BLA0
    Case [F:BUP]BUDCTL
     When 2 : # Annuel
      MTBLA += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
     When 3 :# Par période
      MTBLA += SIGN*([F:BLA]DEBLED(PERIODE)-[F:BLA]CDTLED(PERIODE))
     When 4,5 : # Contrôle global et cumulé
      If IEXO=EXODEB & IEXO=EXOFIN
       PER1 = PERDEB
       PER2 = PERFIN
      Elsif IEXO=EXODEB
       PER1 = PERDEB
       PER2 = dim([F:BLA]DEBLED)-1
      Elsif IEXO=EXOFIN
       PER1 = 1
       PER2 = PERFIN
      Else
       PER1 = 1
       PER2 = dim([F:BLA]DEBLED)-1
      Endif
      MTBLA += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
    Endcase
  Next
  Filter [BLA]
  #Balance analytique en quantité BLAQTY [BLQ]
  #BLQ0=>LEDTYP+CPY+FCY+FIY+ACC+BPR+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9+CUR
  Filter [BLQ] Where evalue(CRITBLA) & FIY=IEXO
  For [BLQ]BLQ0
   Case [F:BUP]BUDCTL
    When 2 : # Annuel
     QTBLA += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
     QTCMM += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
     QTPRP += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
    When 3 :# Par période
     QTBLA += SIGN*[F:BLQ]QTY(PERIODE)
     QTCMM += SIGN*[F:BLQ]QTYCMM(PERIODE)
     QTPRP += SIGN*[F:BLQ]QTYPRP(PERIODE)
    When 4,5 : # Contrôle global et cumulé
     If IEXO=EXODEB & IEXO=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif IEXO=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLQ]QTY)-1
     Elsif IEXO=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLQ]QTY)-1
     Endif
     QTBLA += SIGN*sum([F:BLQ]QTY(PER1..PER2))
     QTCMM += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
     QTPRP += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
   Endcase
  Next
  Filter [BLQ]
  #Balance analytique engagement BLACMM [BLM]
  #BLM0=>LEDTYP+CPY+FCY+FIY+ACC+BPR+CCE1+CCE2+CCE3+CCE4+CCE5+CCE6+CCE7+CCE8+CCE9+CUR
  Filter [BLM] Where evalue(CRITBLA) & FIY=IEXO
  For [BLM]BLM0
   Case [F:BUP]BUDCTL
    When 2 : # Annuel
     MTCMM += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
     MTPRP += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
    When 3 :# Par période
     MTCMM += SIGN*[F:BLM]CMMLED(PERIODE)
     MTPRP += SIGN*[F:BLM]CMMPRPLED(PERIODE)
    When 4,5 : # Contrôle global et cumulé
     If IEXO=EXODEB & IEXO=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif IEXO=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLM]CMMLED)-1
     Elsif IEXO=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLM]CMMLED)-1
     Endif
     MTCMM += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
     MTPRP += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
   Endcase
  Next
  Filter [BLM]
 Next IEXO

Else

 Raz CRITPYR, IPYR
 Call ADDCRIT(CRITPYR,IPYR,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"FCY",'FCY="'+BUDFCY+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"COA",'COA="'+PLAN+'"'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"BPR",'BPR=""'," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"FIY",'FIY>='+num$(EXODEB)," & ") From GOBJSUB
 Call ADDCRIT(CRITPYR,IPYR,"FIY",'FIY<='+num$(EXOFIN)," & ") From GOBJSUB

 If [F:BUP]PYMACC=""
  Call ADDCRIT(CRITPYR,IPYR,"ACC",'ACC="'+BUDACC+'"'," & ") From GOBJSUB
 Endif

 Gosub GENLNK From TRTVISBUD
 Gosub LIENS From =FILPROG
 # Analytical balance
 For [LBLA]CLE(1)
  ACCSIGN = [F:BLA]ACC
  Gosub SEARCH_SIGN From TRTVISBUD
  For [LBLA]CLE
   Case [F:BUP]BUDCTL
    When 2   : # Contrôle annuel
     MTBLA += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
    When 3   : # Contrôle par période
     MTBLA += SIGN*(sum([F:BLA]DEBLED(PERIODE)-[F:BLA]CDTLED(PERIODE)))
    When 4,5 : # Contrôle global et cumulé
     If [F:BLA]FIY=EXODEB & [F:BLA]FIY=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif [F:BLA]FIY=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLA]CDTLED)-1
     Elsif [F:BLA]FIY=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLA]CDTLED)-1
     Endif
     MTBLA += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
   Endcase
  Next
 Next

 # Quantity balance
 For [LBLQ]CLE(1)
  ACCSIGN = [F:BLQ]ACC
  Gosub SEARCH_SIGN From TRTVISBUD
  For [LBLQ]CLE
   Case [F:BUP]BUDCTL
    When 2   : # Contrôle annuel
     QTBLA += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
     QTCMM += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
     QTPRP += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
    When 3   : # Contrôle par période
     QTBLA += SIGN*sum([F:BLQ]QTY(PERIODE))
     QTCMM += SIGN*sum([F:BLQ]QTYCMM(PERIODE))
     QTPRP += SIGN*sum([F:BLQ]QTYPRP(PERIODE))
    When 4,5 : # Contrôle global et cumulé
     If [F:BLQ]FIY=EXODEB & [F:BLQ]FIY=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif [F:BLQ]FIY=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLQ]QTY)-1
     Elsif [F:BLQ]FIY=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLQ]QTY)-1
     Endif
     QTBLA += SIGN*sum([F:BLQ]QTY(PER1..PER2))
     QTCMM += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
     QTPRP += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
   Endcase
  Next : #BLQ
 Next

 # Commitment balance
 For [LBLM]CLE(1)
  ACCSIGN = [F:BLM]ACC
  Gosub SEARCH_SIGN From TRTVISBUD
  For [LBLM]CLE
   Case [F:BUP]BUDCTL
    When 2   : # Contrôle annuel
     MTCMM += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
     MTPRP += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
    When 3   : # Contrôle par période
     MTCMM += SIGN*[F:BLM]CMMLED(PERIODE)
     MTPRP += SIGN*[F:BLM]CMMPRPLED(PERIODE)
    When 4,5 : # Contrôle global et cumulé
     If [F:BLM]FIY=EXODEB & [F:BLM]FIY=EXOFIN
      PER1 = PERDEB
      PER2 = PERFIN
     Elsif [F:BLM]FIY=EXODEB
      PER1 = PERDEB
      PER2 = dim([F:BLM]CMMLED)-1
     Elsif [F:BLM]FIY=EXOFIN
      PER1 = 1
      PER2 = PERFIN
     Else
      PER1 = 1
      PER2 = dim([F:BLM]CMMLED)-1
     Endif
     MTCMM += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
     MTPRP += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
   Endcase
  Next : #BLM
 Next
 If FILSRC<>""
  Call EFFACE(FILSRC,STAT) From ORDSYS
  Call EFFACE(FILADX,STAT) From ORDSYS
 Endif
## YYFIN_104036_US23
Endif
Return

#################################################################
$INIVAR_LEDBUDCCE
Call LEC_LED([L]LED) From CPTLEC
Raz LEDBUDCCE
For AX=1 To dim([F:BUP]DIE)
 If [F:BUP]DIE(AX-1)<>""
  VU = find([F:BUP]DIE(AX-1),[F:LED]DIE(0..[F:LED]DIENBR-1))
  ## YYFIN_104036_US23
  # If VU : LEDBUDCCE(VU-1) = BUDCCE(AX) : Endif
  If VU : LEDBUDCCE(VU-1) = BUDCCE(AX) : NUMCCE(AX) = VU : Endif
  ## End YYFIN_104036_US23
 Endif
Next
Return


Subprog VERF_BUD(PERIODE,MONTANT,QUANTITE,DEVISE,DEVLED,DEVBUD,DEVCPY,TYPCOURS,DATCOURS
&               ,COMPTE,MTBUD,QTBUD,MTBLA,QTBLA,MTCMM,QTCMM,MTPRP,QTPRP,OK)
Value    Integer PERIODE
Value    Decimal MONTANT
Value    Decimal QUANTITE
Value    Char    DEVISE
Value    Char    DEVLED
Value    Char    DEVBUD
Value    Char    DEVCPY
Value    Integer TYPCOURS
Value    Date    DATCOURS
Value    Char    COMPTE
Value    Decimal MTBUD
Value    Decimal QTBUD
Value    Decimal MTBLA
Value    Decimal QTBLA
Value    Decimal MTCMM
Value    Decimal QTCMM
Value    Decimal MTPRP
Value    Decimal QTPRP
Variable Integer OK

OK = 0
Local Decimal MTREL , QTREL , MTNEW
Local Integer STAT

GPOINT = "BEFBUDCTL" : Gosub ENTREE From EXEFNC

# La Gestion de devise a changé :
# Le contrôle va être fait en devise référentiel DEVLED
# Il faut donc convertir si nécessaire le montant du budget MTBUD de DEVBUD vers DEVLED
# Tout comme le montant demandé MONTANT de DEVISE à DEVLED
# Les montants ventilés (Balances) sont déjà calculé en devise référentiel)
#CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)

#Conversion montant budget
Call CONVERT(DEVBUD,DEVLED,DEVCPY,TYPCOURS,DATCOURS,MTBUD,MTBUD,STAT) From TRTDEV
If STAT : OK = 3 : End : Endif
#Conversion montant paramètre (demandé)
Call CONVERT(DEVISE,DEVLED,DEVCPY,TYPCOURS,DATCOURS,MONTANT,MTNEW,STAT) From TRTDEV
If STAT : OK = 4 : End : Endif

MTREL = MTBLA
QTREL = QTBLA
If GBUDENG
 MTREL += MTCMM
 QTREL += QTCMM
Endif
If GBUDPRE
 MTREL += MTPRP
 QTREL += QTPRP
Endif

If GBUDCONTMT
 If MTREL+MTNEW>MTBUD*(1+GBUDPCMT/100)
  OK = 1 : End
 Endif
Endif

If GBUDCONTQT & [F:BUP]QTY=2
 QTNEW = QUANTITE
 If QTREL+QTNEW>QTBUD*(1+GBUDPCQT/100)
  OK = 2 : End
 Endif
Endif
End

########################################################
# Lecture des paramètres
########################################################
Subprog DEFVAR(SITE)
Value Char SITE

If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
If dim([V]GBUDSITE)<=0
 Global Char    GBUDSITE(GLONFCY)             : # Dernier site lu
 Global Integer GBUDNB                        : # Nb de budgets à contrôler
 Global Libelle GBUDCONTMT                    : # Contrôle montant O/N
 Global Decimal GBUDPCMT                      : # % tolérance montant
 Global Libelle GBUDCONTQT                    : # Contrôle qté O/N
 Global Decimal GBUDPCQT                      : # % tolérance qté
 Global Libelle GBUDENG                       : # Engagements O/N
 Global Libelle GBUDPRE                       : # Préengagements O/N
 Global Char    GBUDGET(GLONBUP)(1..10)       : # Codes budgets à contrôler
 Global Char    GBUDVER(GLONBUV)(1..10)       : # Version des budgets à contrôler
 Global Libelle GBUDTYPCUR                    : # Type de cours
Endif
If GBUDSITE<>SITE
 Raz GBUDGET,GBUDVER
 GBUDSITE = SITE
 Local Integer B : B=0
 Local Char    VALPAR(30)
 # Budgets à contrôlés & versions
 For I=1 To 9
  Call PARAM(SITE,"BUP"+num$(I),VALPAR) From ADOVAL
  If VALPAR<>""
   Filter [BUV] Where BUD=VALPAR & CTL=2
   For [BUV]BUV0
    B+=1
    GBUDGET(B)=[F:BUV]BUD
    GBUDVER(B)=[F:BUV]VER
   Next
   Filter [BUV]
  Endif
 Next
 # Nombres de budgets à contrôler
 GBUDNB=B
 # Contrôle en montant O/N
 Call PARAM(SITE,"BUDAMT",VALPAR) From ADOVAL
 GBUDCONTMT = (val(VALPAR)=2)
 If GBUDCONTMT
  # Pourcentage de tolérance montant
  Call PARAM(SITE,"BUDPRCAMT",VALPAR) From ADOVAL
  GBUDPCMT = val(VALPAR)
 Endif
 # Contrôle en qté O/N
 Call PARAM(SITE,"BUDQTY",VALPAR) From ADOVAL
 GBUDCONTQT = (val(VALPAR)=2)
 If GBUDCONTQT
  # Pourcentage de tolérance en quantité
  Call PARAM(SITE,"BUDPRCQTY",VALPAR) From ADOVAL
  GBUDPCQT = val(VALPAR)
 Endif
 # Engagements
 Call PARAM(SITE,"BUDCMM",VALPAR) From ADOVAL
 GBUDENG = (val(VALPAR)=2)
 # Pré-engagements
 Call PARAM(SITE,"BUDCMMPRP",VALPAR) From ADOVAL
 GBUDPRE = (val(VALPAR)=2)
 # Type de cours
 Call PARAM(SITE,"BUDTYPCUR",VALPAR) From ADOVAL
 GBUDTYPCUR = val(VALPAR) : If GBUDTYPCUR=0 : GBUDTYPCUR = 1 : Endif
Endif
End


#####################################################################################
Subprog VISU(DAT,SITE,LEDTYP,COMPTE,TBCCE)
Value    Date    DAT
Value    Char    SITE
Value    Integer LEDTYP
Value    Char    COMPTE
Value    Char    TBCCE()(1..)

End

$DERPEREXO
Filter [PER] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & PERSTA=2
Read [PER]PER0 Last
Filter [PER]
EXOFIN = [F:PER]FIYNUM
PERFIN = [F:PER]PERNUM
Return

####################################################################################
##     Modif du MAJBUD pour mise à jour de la balance d'engagement - 18/04/06     ##
####################################################################################

Subprog MAJBUD(DAT,SITE,LEDTYP,DEVCUR,AMTCUR,AMTLED,QUANTITE
&             ,COMPTE,TIERS,TBDIE,TBCCE,SENS,SIGN,TYP,CONTBUD,OK,MESSA)
Value    Date    DAT
Value    Char    SITE
Value    Integer LEDTYP
Value    Char    DEVCUR        # Devise
Value    Decimal AMTCUR        # Montant
Value    Decimal AMTLED        # Montant référentiel
Value    Decimal QUANTITE
Value    Char    COMPTE
Value    Char    TIERS
Value    Char    TBCCE()(1..)
Value    Char    TBDIE()(1..)
Value    Integer SENS
Value    Integer SIGN
Value    Integer TYP
Value    Integer CONTBUD
Variable Integer OK
Variable Char    MESSA()

Local Integer BALTYP, BALLEDTYP
Local Decimal BALEXE, BALPER
Local Decimal EXERCICE , PERIODE
Local Char    BALCPY(GLONCPY), BALFCY(GLONFCY)
Local Char    BALACC(GLONGAC)
Local Char    BALCUR(GLONCUR), BALCURLED(GLONCUR)
Local Char    BALBPR(GLONBPR)

Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)

Local Char    BALDIE1(GLONCCE) , BALDIE2(GLONCCE) , BALDIE3(GLONCCE)
Local Char    BALDIE4(GLONCCE) , BALDIE5(GLONCCE) , BALDIE6(GLONCCE)
Local Char    BALDIE7(GLONCCE) , BALDIE8(GLONCCE) , BALDIE9(GLONCCE)

Local Char    DEVLED(GLONCUR)
Local Char    BALLED(GLONLED)
Local Char    BALCOA(GLONCOA)
Local Char    BALUOM(GLONUOM)

Local Integer I , ISITE , ISOC

Local Char    BUDCOD(GLONBUP)

If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
If clalev([F:CCE])=0  : Local File CACCE      [CCE]  : Endif
If clalev([F:BLM])=0  : Local File BLACMM     [BLM]  : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY     [BLQ]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
If clalev([F:CLS])=0  : Local File GACCCLS    [CLS]  : Endif

If clalev([F:DIE])=0  : Local File GDIE       [DIE]  : Endif
If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif


OK = 1 : Raz MESSA
BALFCY = SITE
ISITE = find(BALFCY,GSITE(1..GNBSITE))
If !ISITE : End : Endif

BALCPY = GSOCSITE(ISITE)
ISOC = find(BALCPY,GSOC(1..GNBSOC))
If !ISOC : End : Endif

SOCIETE = GSOC(ISOC)
Call GETPERSOC(SOCIETE,LEDTYP,DAT,EXERCICE,PERIODE) From CPTSUB
If EXERCICE=0 | PERIODE=0 : End : Endif

BALEXE    = EXERCICE
BALPER    = PERIODE
BALLEDTYP = LEDTYP
Call LECLED(SOCIETE,BALLEDTYP,BALLED,DEVLED) From CPTDIV
Call LECPLAN(SOCIETE,BALLEDTYP,BALCOA) From CPTDIV
BALACC    = COMPTE

Call LECTURE("GAC",BALACC,BALCOA) From CONTOBJ
BALUOM    = [F:GAC]UOM
BALCUR    = DEVCUR
BALCURLED = DEVLED
BALBPR    = TIERS
BALSNS    = SENS
BALTYP    = TYP

## Vérification budget
If CONTBUD<>0 & SIGN = +1
 Call BUDGET(DAT,BALFCY,LEDTYP,DEVLED,BALACC,TBDIE,TBCCE,AMTLED,QUANTITE,CONTBUD,OK,MESSA)
 If OK<1 & CONTBUD=2 : End : Endif
Endif

## Mise à jour Budgets opérationnels
If func AFNC.ACTIV("GDD")
 If clalev([F:ENV])=0  : Local File ENVELOPPE  [ENV]  : Endif
 If clalev([F:ENF])=0  : Local File ENVFIY     [ENF]  : Endif
 Gosub MAJ_GDD
 If GOK<1 : End : Endif
Endif

## Dimensions & analyticals sections | Axes & Sections analytiques
Local Char    LSTDIE(GLONDIE)(1..9)
Local Integer NBRDIE,INDEX
Call GETLSTAXE(BALCPY,BALLEDTYP,NBRDIE,LSTDIE) From CPTDIV
For I=1 To NBRDIE
 INDEX=find(LSTDIE(I),TBDIE(1..dim(TBDIE)))
 If INDEX
  Assign "BALDIE"+num$(I) With evalue("TBDIE("+num$(INDEX)+")")
  Assign "BALSEC"+num$(I) With evalue("TBCCE("+num$(INDEX)+")")
 Endif
Next

Gosub BAL_ANA_CMM : # Balance ana compte+tiers
If GOK<1 : End : Endif
If BALBPR<>""
 BALBPR = ""
 Gosub BAL_ANA_CMM : # Balance ana du collectif
 If GOK<1 : End : Endif
Endif
End

$BAL_ANA_CMM
## MAJ Société
BALFCY = ""
Gosub MAJBLM
If QUANTITE<>0 : Gosub MAJBLQ : Endif
If GOK<1 : Return : Endif
# MAJ Site
BALFCY = SITE
Gosub MAJBLM
If QUANTITE<>0 : Gosub MAJBLQ : Endif
If GOK<1 : Return : Endif
Return


$MAJBLM
# Mise à jour de la balance analytique d'engagemment
Readlock [BLM]BLM0 = BALLEDTYP;BALCPY;BALFCY;BALEXE;BALACC;BALBPR
&                   ;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6
&                   ;BALSEC7;BALSEC8;BALSEC9;BALCUR
If fstat=1
 GOK = -1
 GLOCK = "$BLACMM"-num$(BALLEDTYP)-BALCPY-BALFCY-num$(BALEXE)-BALACC-BALBPR-BALSEC1
&       -BALSEC2-BALSEC3-BALSEC4-BALSEC5-BALSEC6-BALSEC7-BALSEC8-BALSEC9-BALCUR
 Return
Elsif fstat
 Raz [F:BLM]
 [F:BLM]LEDTYP  = BALLEDTYP
 [F:BLM]CPY     = BALCPY
 [F:BLM]FCY     = BALFCY
 [F:BLM]FIY     = BALEXE
 [F:BLM]BPR     = BALBPR
 [F:BLM]ACC     = BALACC
 [F:BLM]CCE1    = BALSEC1
 [F:BLM]CCE2    = BALSEC2
 [F:BLM]CCE3    = BALSEC3
 [F:BLM]CCE4    = BALSEC4
 [F:BLM]CCE5    = BALSEC5
 [F:BLM]CCE6    = BALSEC6
 [F:BLM]CCE7    = BALSEC7
 [F:BLM]CCE8    = BALSEC8
 [F:BLM]CCE9    = BALSEC9
 [F:BLM]CUR     = BALCUR
 [F:BLM]ACCNUM  = uniqid([F:BLM])
 [F:BLM]LED     = BALLED
 [F:BLM]CURLED  = BALCURLED
 [F:BLM]COA     = BALCOA
 For I=1 To dim([F:BLM]DIE)
  [F:BLM]DIE(I-1) = evalue("BALDIE"+num$(I))
 Next
 Gosub CALBLM
 Write [BLM]
Else
 Gosub CALBLM
 Rewrite [BLM]
Endif
If fstat
 GOK=0 : Call FSTA("BLM") From GLOCK : End
Endif

# Infbox "*MAJBLM* =>ledtyp="-num$(BALLEDTYP)-"/led="-BALLED-"/soc="-BALCPY-"/sit="-BALFCY-"/exe="-num$(BALEXE)-"/acc="-BALACC-"/tiers="-BALBPR
#&      -"/1="-BALSEC1-"/2="-BALSEC2-"/3="-BALSEC3-"/4="-BALSEC4-"/5="-BALSEC5-"/6="-BALSEC6-"/7="-BALSEC7
#&      -"/8="-BALSEC8-"/9="-BALSEC9-"/cur="-BALCUR-"/accnum="-num$([F:BLM]ACCNUM)-"/amtcur="-num$(AMTCUR)-"/amtled="-num$(AMTLED)
#&      +chr$(10)+"sign="+num$(SIGN)
############################### Controle BUDGET - Fin ################################
Return

$CALBLM
If BALTYP = 1      # Pré-engagements
 [F:BLM]CMMPRP(BALPER)     += SIGN*BALSNS*AMTCUR
 [F:BLM]CMMPRPLED(BALPER)  += SIGN*BALSNS*AMTLED
Elsif BALTYP = 2   # Engagements
 [F:BLM]CMM(BALPER)        += SIGN*BALSNS*AMTCUR
 [F:BLM]CMMLED(BALPER)     += SIGN*BALSNS*AMTLED
Endif
Return

$MAJBLQ
# Mise à jour de la balance analytique d'engagemment
Readlock [BLQ]BLQ0 = BALLEDTYP;BALCPY;BALFCY;BALEXE;BALACC;BALBPR
&                   ;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6
&                   ;BALSEC7;BALSEC8;BALSEC9;BALCUR
If fstat=1
 GOK = -1
 GLOCK = "$BLAQTY"-num$(BALLEDTYP)-BALCPY-BALFCY-num$(BALEXE)-BALACC-BALBPR-BALSEC1
&       -BALSEC2-BALSEC3-BALSEC4-BALSEC5-BALSEC6-BALSEC7-BALSEC8-BALSEC9-BALCUR
 Return
Elsif fstat
 Raz [F:BLQ]
 [F:BLQ]LEDTYP  = BALLEDTYP
 [F:BLQ]CPY     = BALCPY
 [F:BLQ]FCY     = BALFCY
 [F:BLQ]FIY     = BALEXE
 [F:BLQ]BPR     = BALBPR
 [F:BLQ]ACC     = BALACC
 [F:BLQ]CCE1    = BALSEC1
 [F:BLQ]CCE2    = BALSEC2
 [F:BLQ]CCE3    = BALSEC3
 [F:BLQ]CCE4    = BALSEC4
 [F:BLQ]CCE5    = BALSEC5
 [F:BLQ]CCE6    = BALSEC6
 [F:BLQ]CCE7    = BALSEC7
 [F:BLQ]CCE8    = BALSEC8
 [F:BLQ]CCE9    = BALSEC9
 [F:BLQ]CUR     = BALCUR
 [F:BLQ]ACCNUM  = uniqid([F:BLQ])
 [F:BLQ]LED     = BALLED
 [F:BLQ]COA     = BALCOA
 [F:BLQ]UOM     = BALUOM
 For I=1 To dim([F:BLQ]DIE)
  [F:BLQ]DIE(I-1) = evalue("BALDIE"+num$(I))
 Next
 Gosub CALBLQ
 Write [BLQ]
Else
 Gosub CALBLQ
 Rewrite [BLQ]
Endif
If fstat
 GOK=0 : Call FSTA("BLQ") From GLOCK : End
Endif

# Infbox "*MAJBLQ*"-num$(BALLEDTYP)-"/"-BALCPY-"/"-BALFCY-"/"-num$(BALEXE)-"/"-BALACC-"/"-BALBPR
#&      -"/"-BALSEC1-"/"-BALSEC2-"/"-BALSEC3-"/"-BALSEC4-"/"-BALSEC5-"/"-BALSEC6-"/"-BALSEC7
#&      -"/"-BALSEC8-"/"-BALSEC9-"/"-BALCUR-"/"-num$([F:BLQ]ACCNUM)-"/"-num$(AMTCUR)-"/"-num$(AMTLED)
############################### Controle BUDGET - Fin ################################
Return

$CALBLQ
 If BALTYP = 1      # Pré-engagements
  [F:BLQ]QTYPRP(BALPER)     += SIGN*BALSNS*QUANTITE
 Elsif BALTYP = 2   # Engagements
  [F:BLQ]QTYCMM(BALPER)     += SIGN*BALSNS*QUANTITE
 Endif
Return

################################################################################FIN ##


################################################################################
## Gestion des dépenses : MAJ des engagements sur les budgets GDD
################################################################################
$MAJ_GDD
Gosub SET_GDD
If OKGDD
 Raz [F:BUD]
 Call LEC_LED(BALLED) From CPTLEC
 If AXENT>0
  I = find(TBDIE(AXENT),[F:LED]DIE(0..[F:LED]DIENBR-1))
  Assign "[F:BUD]CCE"+num$(I) With ENTITY
 Endif
 If AXENV>0
  I = find(TBDIE(AXENV),[F:LED]DIE(0..[F:LED]DIENBR-1))
  Assign "[F:BUD]CCE"+num$(I) With ENVELOP
 Endif
 If AX3>0
  I = find(TBDIE(AX3),[F:LED]DIE(0..[F:LED]DIENBR-1))
  Assign "[F:BUD]CCE"+num$(I) With SECTION3
 Endif
 [F:BUD]LEDTYP = LEDTYP
 [F:BUD]BUD    = BUDCOD
 [F:BUD]CPY    = SOCIETE
 [F:BUD]FCY    = GDDSITE
 [F:BUD]FIY    = EXERCICE
 [F:BUD]VER    = "1"
 [F:BUD]ACC    = COMPTE
 Readlock [BUD]BUD0=
 If fstat=1
  GOK = -1 : GLOCK = "$BUD"-num$([F:BUD]ACCNUM) : Return
 Elsif fstat=0
  If BALTYP = 1      # Pré-engagements
   [F:BUD]AMTCMMPRP += SIGN*BALSNS*AMTLED
  Elsif BALTYP = 2   # Engagements
   [F:BUD]AMTCMM    += SIGN*BALSNS*AMTLED
  Endif
  Rewrite [BUD]
  If fstat
   GOK = 0 : Call FSTA("BUD") From GLOCK : Return
  Endif
 Endif
Endif
Return

$SET_GDD
Local Char ENVELOP(GLONENV),ENTITY(GLONENT),SECTION3(GLONCCE)
Local Char GDDSITE(GLONFCY), BUDCOD(GLONBUP)
Local Integer AXENV , AXENT , AX3 , OKGDD, YEAFLG
Call GETBUOINF(TBDIE,TBCCE,SITE,BUDCOD,ENTITY,AXENT,ENVELOP,AXENV,SECTION3,AX3,OKGDD,YEAFLG,GDDSITE) From TRTGDD
Return

################################################################################
## Vérifications/Contrôle des budgets flagués Budgets opérationnels
################################################################################
$VERF_GDD
Gosub SET_GDD
If OKGDD
 Local Decimal DEMANDE, BUDGET , REALISE , DISPONIBLE, POURCENT
 Local Decimal RAVB , RAVRB , RAVE , RAVRE , LIMITE
 Local Decimal RAVB_BUD , RAVRB_BUD , RAVE_BUD , RAVRE_BUD, LIM_BUDGETE

 Local Char DEVISE_BUD(GLONCUR)
 Local Integer BUDCTL,BUDDEP

 Call LECTURE("ENV",ENVELOP,"") From CONTOBJ
 DEVISE_BUD=[F:ENV]CURENV

 # CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
 Call CONVERT(DEVISE,DEVISE_BUD,DEVCPY,GBUDTYPCUR,DAT,MONTANT,DEMANDE,STAT) From TRTDEV
 If STAT
  NBMESSA += 1
  If MESSA<>"" : MESSA += "\" : Endif
  # Contrôle budgétaire / Pas de cours
  MESSA += mess(4,108,1)+"\"+mess(4,109,1)-DEVISE-"=>"-DEVBUD
  OK = -1
  Return
 Endif

 Call GETPERSOC(SOCIETE,LEDTYP,DAT,EXERCICE,PERIODE) From CPTSUB
 If EXERCICE=0 | PERIODE=0
  MESSA = mess(4,108,1)+"\"+mess(1,104,1)
  # Contrôle budgétaire / Date incorrecte
  OK = -1
  Return
 Endif

 # Existence d'une ligne budgétaire
 Raz [F:BUD]
 Call LEC_LED(LED) From CPTLEC
 If AXENT>0
  I = find(TBDIE(AXENT),[F:LED]DIE(0..[F:LED]DIENBR-1))
  Assign "[F:BUD]CCE"+num$(I) With ENTITY
 Endif
 If AXENV>0
  I = find(TBDIE(AXENV),[F:LED]DIE(0..[F:LED]DIENBR-1))
  Assign "[F:BUD]CCE"+num$(I) With ENVELOP
 Endif
 If AX3>0
  I = find(TBDIE(AX3),[F:LED]DIE(0..[F:LED]DIENBR-1))
  Assign "[F:BUD]CCE"+num$(I) With SECTION3
 Endif
 [F:BUD]LEDTYP = LEDTYP
 [F:BUD]BUD    = [F:ENV]BUD
 [F:BUD]CPY    = SOCIETE
 [F:BUD]FCY    = GDDSITE
 [F:BUD]FIY    = EXERCICE
 [F:BUD]VER    = "1"
 [F:BUD]ACC    = COMPTE
 Read [BUD]BUD0=
 If fstat
  Gosub MESSA_GDD
  MESSA += "\"+mess(176,108,1) : # Pas de ligne budgétaire
  OK = -1
  Return
 Endif

 REALISE = [F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP
 BUDGET = [F:BUD]AMT(0)

 # Contrôle du statut
 # Enveloppe hors budget => pas de contrôle
 If [F:ENV]EXTBUD=2 : Return : Endif

 # Calcul des RAV encours et budgété
 Gosub CAL_RAV
 Gosub CAL_RAV_BUD

 LIM_BUDGETE=0
 LIMITE=0

 # Vérifications en fonction de l'utilisateur
 Local Char VALPAR
 Call PARAMUTIL("GDDBUDDEP",VALPAR,GUSER,SITE) From SUBAUS
 Case val(VALPAR)
  When 1 : # Pas de dépassement
   LIMITE = [F:BUD]AMT(0)-REALISE
   LIM_BUDGETE = [F:BUD]AMT(0)
  When 2 : # Dans la limite du reste à ventiler budget * exercice
   LIMITE = RAVB
   LIM_BUDGETE = RAVB_BUD
  When 3 : # Dans la limite de la réserve budget * exercice
   LIMITE = RAVRB
   LIM_BUDGETE = RAVRB_BUD
  When 4 : # Dans la limite du reste à ventiler enveloppe
   LIMITE=RAVE
   LIM_BUDGETE = RAVE_BUD
  When 5 : # Dans la limite de la réserve enveloppe
   LIMITE = RAVRE
   LIM_BUDGETE = RAVRE_BUD
  When 6 : # Dépassement dans la limite du seuil de tolérance /t à l'enveloppe tjrs
   #-----
   Call LECTURE("ENV",TBCCE(AXENV),"") From CONTOBJ
   BUDGET = [F:ENV]AMTENV
   #------
   If [F:ENV]EXDPRC<>0
    POURCENT = [F:ENV]EXDPRC
   Else
    Call PARAMUTIL("GDDBUDPRC",VALPAR,GUSER,SITE) From SUBAUS
    POURCENT = val(VALPAR)
   Endif
   Call PARAMUTIL("GDDBUDCTL",VALPAR,GUSER,SITE) From SUBAUS
   Case val(VALPAR)
    When 1 : # Ligne
     LIMITE = sum([F:BUD]AMT)*POURCENT/100
     LIM_BUDGETE = LIMITE
    When 2 : # Exercice
     LIMITE = 0
     Read [ENF]ENF0 = TBCCE(AXENV);EXERCICE
     If !fstat
      LIMITE = [F:ENF]AMTBUDFIY
     Endif
     LIMITE *= POURCENT/100
     LIM_BUDGETE = LIMITE
    When 3 : # Enveloppe
     LIMITE = 0
     LIMITE  = [F:ENV]AMTENV
     LIMITE *= POURCENT/100
    When Default
     Local Char ERRMSG(250)
     #Contrôle budgétaire impossible : le paramètre $1$ niveau utilisateur n'est pas correctement définit.
     ERRMSG = mess(271,108,1)
     Call DYNAMIC(ERRMSG,"$1$","GDDBUDCTL") From TEXTE
     GMESSAGE = ERRMSG
     GOK=0 : End
   Endcase
   LIMITE += BUDGET
   DEMANDE += REALISE
   LIM_BUDGETE = LIMITE
  When Default
   Local Char ERRMSG(250)
   #Contrôle budgétaire impossible : le paramètre $1$ niveau utilisateur n'est pas correctement définit.
   ERRMSG = mess(271,108,1)
   Call DYNAMIC(ERRMSG,"$1$","GDDBUDDEP") From TEXTE
   GMESSAGE = ERRMSG
   GOK=0 : End
 Endcase

# Pour message de dépassement
# du fait que dans les cas 1à5 la LIMITE calculé est directement le montant max demandable
# alors que dans le cas 6 c'est le montant max autorisé de la somme demande+realise
Local Decimal DMDMES, TOTMES
Call PARAMUTIL("GDDBUDDEP",VALPAR,GUSER,SITE) From SUBAUS
 Case val(VALPAR)
  When 1,2,3,4,5 :
   DMDMES = DEMANDE
   TOTMES = DEMANDE+REALISE
  When 6 :
   DMDMES = DEMANDE-REALISE
   TOTMES = DEMANDE
 Endcase

 DISPONIBLE=BUDGET-REALISE

 If DEMANDE>LIMITE
  MESSA  = mess(178,108,1)-"/"-mess(179,108,1)-"/"-mess(180,108,1): # Enveloppe / Entité / Compte
  MESSA += "\"+TBCCE(AXENV)-"/"-TBCCE(AXENT)-"/"-COMPTE
  MESSA += "\"+mess(177,108,1)-":" : # Dépassement budgétaire :
  MESSA += "\"+mess(224,108,1)-num$(DMDMES)-"+"-mess(225,108,1)-num$(REALISE) : # Demandé XXXX + Consommé YYYY
  MESSA += "\"+"="-num$(TOTMES)-mess(226,108,1)-num$(LIM_BUDGETE) :# = ZZZZZ > au maximum autorisé WWWWW
  OK = 0
 Endif
Endif

#### Correctif MCL sur calcul des RAV ####
#
# La théorie...
#
#   A l'origine dans le cahier des charges de JC Ridet
#
# Vli = Ventilé ligne d'une ligne budgétaire
#     = Max entre Montant budgété LB et le réalisé
#
# Dli = Disponible ligne d'une ligne budgétaire
#     = Montant budgété LB - Réalisé
#
# VBb = Ventilé budgétaire BUE d'un budget
#     = MAX entre montant du budget et la somme (Vli) des lignes associées
#
# RAVB = Reste à ventiler budget par exercice
#      = Montant du budget - Réserve - Somme (VBb) pour les budgets de l'enveloppe
#
# VRB = Ventilé réserve du budget par exercice
#     = MIN entre RAVB et 0
#
# RAVRB = Reste à ventiler réserve du budget par exercice
#       = Réserve du budget + VRB
#
# RAVE = Reste à ventiler de l'enveloppe
#      = Montant enveloppe - Réserve - Somme (VBb) pour les budgets de l'exercice
#
# VRE = Ventilé réserve de l'enveloppe
#     = MIN entre RAVE et 0
#
# RAVRE = Reste à ventiler réserve de l'enveloppe
#       = Réserve de l'enveloppe + VRE
#
# Calculs mis en place par BY :
#--------------------------------------------------
#  Read [ENF]ENF0 = TBCCE(AXENV);EXERCICE
#  RAVB = [F:ENF]AMTAPPFIY-[F:ENF]AMTRESFIY : # Montant budget exercice - montant réserve
#  For [BUD] Where LEDTYP=[L]LEDTYP & BUD=[F:ENV]BUD & CPY=SOCIETE & FCY=GDDSITE & FIY=EXERCICE & VER="1"
#  &             & CCE2=TBCCE(AXENV)
#   RAVB -= max(sum([F:BUD]AMT),[F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP) : # VLi
#  Next
#  RAVRB = [F:ENF]AMTRESFIY+min(RAVB,0)
#
#  RAVE = [F:ENV]AMTAPP-[F:ENV]AMTRES : # Budget enveloppe - réserve
#  For [ENF]ENF0 Where ENV=TBCCE(AXENV)
#   VBB = 0
#   For [BUD] Where LEDTYP=[L]LEDTYP & BUD=[F:ENV]BUD & CPY=SOCIETE & FCY=GDDSITE & FIY=[F:ENF]FIYNUM & VER="1"
#  &              & CCE2=TBCCE(AXENV)
#    VBB += max(sum([F:BUD]AMT),[F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP) : # VLi
#   Next
#   VBB = max([F:ENF]AMTAPPFIY,VBB)
#   RAVE -= VBB
#  Next
#  RAVRE = [F:ENV]AMTRES+min(RAVE,0)
#----------------------------------------------------
#
# Mais en fait on ne prenait pas en compte ici les cas de dépassement...
# Les calculs ne correspondaient pas à la réalité :
#
# RAVE  corrigé = Montant du budget - réserve du budget - le réalisé
# RAVRB corrigé = Réserve du budget + VRB[Min(RAVB,0)] + Max(RAVB,0)
# RAVE  corrigé = Montant de l'enveloppe - réserve de l'enveloppe - le réalisé
# RAVRE corrigé = Réserve de l'enveloppe + VRE[Min(RAVE,0)] + Max(RAVE,0)
#
# NB:on calcul ici directement le montant maximal que l'on peut demander.

Return

$CAL_RAV
Read [ENF]ENF0 = TBCCE(AXENV);EXERCICE
RAVB  = [F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY-REALISE
RAVRB = [F:ENF]AMTRESFIY+min(RAVB,0)+max(RAVB,0)
RAVE  = [F:ENV]AMTENV-[F:ENV]AMTRES-REALISE
RAVRE = [F:ENV]AMTRES+min(RAVE,0)+max(RAVE,0)
Return

$CAL_RAV_BUD
#Les reste à ventilé budgété au départ (avant ecritures)
Read [ENF]ENF0 = TBCCE(AXENV);EXERCICE
RAVB_BUD  = [F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY
RAVRB_BUD = [F:ENF]AMTBUDFIY
RAVE_BUD  = [F:ENV]AMTENV-[F:ENV]AMTRES
RAVRE_BUD = [F:ENV]AMTENV
Return

$MESSA_GDD
MESSA  = mess(178,108,1)-TBCCE(AXENV)     : # Enveloppe
MESSA += "\"+mess(179,108,1)-TBCCE(AXENT) : # Entité
MESSA += "\"+mess(180,108,1)-COMPTE       : # Compte
If AX3<>0
 Local Char AXE3(30)
 Call LECTEXTRA(AXE3,"GDIE","DESTRA",TBDIE(AX3),"") From ATEXTRA
 MESSA += "\"+AXE3-TBCCE(AX3)       : # Axe3 section3
Endif
Return

#**
#* =================================
#* Subprog : DEL_JOURNAL_ENTRY_FR0M_BUDPURAUD  -
#*           Delete from BUDPURAUD table all the records related to a journal entry
#* ---------------------------------
#* @private
#* @param  PTYP : Entry type
#* @param  PNUM : Document n°.
#*!
Subprog DEL_JOURNAL_ENTRY_FR0M_BUDPURAUD (PTYP, PNUM)
Value Char    PTYP()
Value Char    PNUM()
  # Issue 64338
  If clalev([F:BUA]) = 0  : Local File BUDPURAUD [BUA]  : Endif
  Delete [BUA] Where TYP = 8 and TYPPCE = PTYP and NUM = PNUM
  If fstat = 1
   GOK = -1 : GLOCK = "$BUDPURAUD"-PNUM
   End
  Endif
  # End issue 64338
End

