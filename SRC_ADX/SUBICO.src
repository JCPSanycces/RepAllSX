    LRET = func GETEXE(1,[M:DIA]CPY1,[M:DIA]ITMREF,[M:DIA]STOFCY1,[M:DIA]FIYNUM1,VALEUR,[M:DIA]STRDAT1,[M:DIA]ENDDAT1)
