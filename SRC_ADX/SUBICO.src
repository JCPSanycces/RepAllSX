#<AdxTL>@(#)6.0.0.0 $Revision$
# Lancement Copie (transfert) de coûts    SUBICO
################################################
# En direct ou en batch (ecran ITCCOP0)     TB

$ACTION
Case ACTION
 When "INIT"        Gosub INIT
 When "INIT_DIA"    Gosub INIT_DIA
 When "OUVRE_BATCH" Gosub INIT      # depuis ARQTPAR (requête batch)
 When "CONTROLE"    Gosub CONTROLE
 When "EXEC"        Gosub EXEC
 When "TERMINE"     Gosub TERMINE
 When "SORTIE"      Gosub SORTIE
Endcase
Return

$INIT
Local Integer ITC_OK, ICN_OK, ICC_OK, IWC_OK
Local Integer I
Local Char    ERR_TRA(250)
Local Char    TIT_ECR(50) : TIT_ECR = mess(110,195,1)
Local Char    SYMBOLE(10)
Local Char    FIL_ITC(250), FIL_FCY(250) : #, FIL_FCY(30) # GH 02/10/2015 bug 111435
Local Integer ITC2_YEA,NEW_SEQ  : # car ITC2 sert de buffer (22/05/02)
Local Integer I_MAT               # 20/05/03

If clalev ([F:ITC]) = 0
    Local File ITMCOST     [ITC]     # enregistrement à créer
Else
    If clalev ([F:ITCS]) = 0 Local File ITMCOST    [ITCS] Endif    # sauvegarde de la classe [F:ITC]
    [F:ITCS] = [F:ITC]
Endif # enregistrement à créer
If clalev ([F:ITC2]) = 0 Local File ITMCOST    [ITC2] Endif # table pour recherche dernière séquence
If clalev ([F:ITCO]) = 0 Local File ITMCOST    [ITCO] Endif # enregistrement origine
If clalev ([F:ITM]) = 0 Local File ITMMASTER   [ITM]  Endif
If clalev ([F:FCY1]) = 0 Local File FACILITY   [FCY1] Endif # abrév spéciale à cause du traitement compta
If clalev ([F:ITF]) = 0 Local File ITMFACILIT  [ITF]  Endif
If clalev ([F:PER]) = 0 Local File PERIOD      [PER]  Endif
If clalev ([F:MWS]) = 0 Local File WORKSTATIO  [MWS]  Endif
If clalev ([F:ITV]) = 0 Local File ITMMVT      [ITV]  Endif
If clalev ([F:ICN]) = 0 Local File ITCNAT      [ICN]  Endif # enregistrements natures de FG
If clalev ([F:ICNO]) = 0 Local File ITCNAT     [ICNO] Endif # enregistrements natures de FG lus
If clalev ([F:ICC]) = 0 Local File ITCMAT      [ICC]  Endif # enregistrements composants
If clalev ([F:ICCO]) = 0 Local File ITCMAT     [ICCO] Endif # enregistrements composants
If clalev ([F:IWC]) = 0 Local File ITCWST      [IWC]  Endif # enregistrements postes
If clalev ([F:IWCO]) = 0 Local File ITCWST     [IWCO] Endif # enregistrements postes
If clalev ([F:ITG]) = 0 Local File ITMCATEG    [ITG]  Endif # pour mvt variation valeur
If clalev ([F:TCM]) = 0 Local File TABCOSTMET  [TCM]  Endif # pour mvt variation valeur
If clalev ([F:ITS]) = 0 Local File ITMSALES    [ITS]  Endif # pour filtre
If clalev ([F:AXX]) = 0 Local File ATEXTRA     [AXX]  Endif # pour filtre
# CCC (13/08/07) Bug 42564
If GMODU(7)=2
    If clalev ([F:STJ]) = 0 Local File STOJOU      [STJ]  Endif # pour mvt variation valeur
    If clalev ([F:STJ1]) = 0 Local File STOJOU     [STJ1] Endif # pour mvt variation valeur
    If clalev ([F:ITH]) = 0 Local File ITMMVTHIS   [ITH]  Endif # pour mvt variation valeur
Endif
If clalev ([F:FIY]) = 0 Local File FISCALYEAR  [FIY]  Endif

Return

$INIT_DIA
If val(PARAM(1))=0
    [M:DIA]CSTTYP2 = 1
    [M:DIA]CSTTYP1 = 1
    # Issue 85790 - 2012-11-12 by CCC
    If [M:DIA]STOFCY1<>""
        Call GETSOC([M:DIA]STOFCY1) From DEVSUB
# Issue 91663 - 2014-06-11 by CCC
#        Call GETEXE(GSOCIETE,GTYPGEN,date$,[M:DIA]FIYNUM1) From CPTSUB
#        Call DATEXE(GSOCIETE,GTYPGEN,[M:DIA]FIYNUM1,[M:DIA]STRDAT1,[M:DIA]ENDDAT1) From CPTSUB
        [M:DIA]CPY1 = GSOCIETE
        LRET = func GETEXE(1,[M:DIA]CPY1,[M:DIA]ITMREF,[M:DIA]STOFCY1,[M:DIA]FIYNUM1,[M:DIA]CSTTYP1,[M:DIA]STRDAT1,[M:DIA]ENDDAT1)
        If LRET
            Effzo [M:DIA]FIYNUM1
        Endif
    Else
        Raz [M:DIA]STOFCY2
        [M:DIA]CPY2=[M:DIA]CPY1
    Endif
Else
    [M:DIA]ITMREF  = [F:ITC]ITMREF
    [M:DIA]STOFCY1 = [F:ITC]STOFCY
    [M:DIA]ITCSEQ1 = [F:ITC]ITCSEQ
    [M:DIA]FIYNUM1 = [F:ITC]FIYNUM
    [M:DIA]STRDAT1 = [F:ITC]ITCSTRDAT
    [M:DIA]ENDDAT1 = [F:ITC]ITCENDDAT
    [M:DIA]CSTTYP1 = [F:ITC]CSTTYP

    [M:DIA]STOFCY2 = [M:DIA]STOFCY1
    [M:DIA]FIYNUM2 = val(PARAM(2))
    Call GETSOC([M:DIA]STOFCY2) From DEVSUB
# Issue 91663 - 2014-06-11 by CCC
#    Call DATEXE(GSOCIETE,GTYPGEN,[M:DIA]FIYNUM2,[M:DIA]STRDAT2,[M:DIA]ENDDAT2) From CPTSUB
    [M:DIA]CPY1 = GSOCIETE
    [M:DIA]CPY2 = GSOCIETE
    LRET = func GETEXE(2,[M:DIA]CPY2,[M:DIA]ITMREF,[M:DIA]STOFCY2,[M:DIA]FIYNUM2,[M:DIA]CSTTYP2,[M:DIA]STRDAT2,[M:DIA]ENDDAT2)
    If LRET
        If [M:DIA]ENDDAT1<date$
            Effzo [M:DIA]FIYNUM2,STRDAT2,ENDDAT2
        Else
            [M:DIA]STRDAT2 = max(date$,[M:DIA]STRDAT1)
            [M:DIA]ENDDAT2 = [M:DIA]ENDDAT1
            [M:DIA]FIYNUM2 = [M:DIA]FIYNUM1
        Endif
    Endif
    [M:DIA]CSTTYP2 = val(PARAM(1))
Endif

Return

# Issue 105748 - 2015-09-11 by CCC : done in AS_ITMREF
#$TIT_DIA
#If [M:DIA]STOFCY1=""
#    Grizo [M:DIA]STOFCY2
#    Grizo [M:DIA]CPY2
#    Affzo [M:DIA]CPY2, STOFCY2
#Endif
#Return

$CONTROLE
If  [M:DIA]STRDAT1=[0/0/0]
& | [M:DIA]STRDAT2=[0/0/0]
    GERR=1
    GMESSAGE=mess(6,199,1)  # Incorrect Value
Endif
Return

$EXEC
Local Char LFILITM(250), LCLE1(GLONITM)
Local Integer LSTOP
Raz LSTOP

If !GSERVEUR
   Call OUVRE_TRACE(TIT_ECR) From LECFIC
Endif

# Etablir les filtres (FIL_ITC sert pour types 1 et 3)

# Si SELTYP = 3 FILART est déjà alimenté ; 1 : un article précis ; 2:Tous
If [M:DIA]SELTYP = 1
    [M:DIA]FILART = "ITMREF = [M:DIA]ITMREF"
Elsif [M:DIA]SELTYP = 2
    [M:DIA]FILART = "1=1"
Endif

FIL_ITC = "CSTTYP=[M:DIA]CSTTYP1 & ITMREF=[F:ITM]ITMREF"
# Issue 105748 - 2015-09-10 by CCC : add company in the filter
FIL_FCY = "LEGCPY='"+[M:DIA]CPY1+"'"
If [M:DIA]STOFCY1 <> ""
    FIL_ITC += " & STOFCY=[M:DIA]STOFCY1"
    FIL_FCY += " & FCY=[M:DIA]STOFCY1"
#Else
#    FIL_FCY = "1=1" : # pour traiter tous les sites
Endif

$LOOP_ITM

If LSTOP=1
    LFILITM = "ITMREF>LCLE1"
    LSTOP=0
Else
    LFILITM = "1=1"
Endif
Trbegin [ITC]
Filter [ITM] Where evalue([M:DIA]FILART) & evalue(LFILITM)
Read [ITM]ITM0 First
If !fstat
    I_MAT = [F:ITM]BRDCOD-1 # pour ramener tout dans la famille coût de l'art (20/05/03)
    Gosub MAJ_ITC
    LCLE1=[F:ITM]ITMREF
    LSTOP=1
Endif
Filter [ITM]
If ITC_OK <> 0 & ICN_OK<>0 & ICC_OK<>0 & IWC_OK<>0
    Commit
Else
  # l'erreur est déjà tracée
   Rollback
Endif

If LSTOP>0
    Goto LOOP_ITM
Endif

Return

$TERMINE
TRA = 1
If !GSERVEUR
   Call FERME_TRACE From LECFIC
Endif
Return

$SORTIE
# Issue 79875 - 2012-02-07 by CCC
Raz [M:DIA]
If clalev([F:ITCS]) & [F:ITCS]ITMREF<>""
    Read [ITC]ITC0 = [F:ITCS]STOFCY;[F:ITCS]ITMREF;[F:ITCS]CSTTYP;[F:ITCS]ITCSEQ;[F:ITCS]UID
Endif

Return

# Attention !! le parcours des enregistrements origine est différent selon le type :
# Standard (1) et Budget (3) : pour un site, un article, il n'y a qu'un enregistrement
# Actualisé(2) et simulé (4) : un filtre est nécessaire pour récupérer ensuite le dernier enreg.
# Une transaction par article

$MAJ_ITC
ITC_OK = 1

For [FCY1] Where evalue(FIL_FCY)
    mkstat = 0
    Call CONTFCY([F:FCY1]FCY) From CPTSUB
    If mkstat
        # "Pas les droits sur ce site ..."
        Call ECR_TRACE(GMESSAGE,0) From GESECRAN
    Else
        If [M:DIA]ITCSEQ1=0
            CRITERE="1=1"
            Case [M:DIA]CSTTYP1
                When 1,3 :
                    If [M:DIA]FIYNUM1<>0
                        CRITERE = "FIYNUM=[M:DIA]FIYNUM1"
                    Endif
                When 2,4 :
                    CRITERE = "ITCSTRDAT>=[M:DIA]STRDAT1 & ITCENDDAT<=[M:DIA]ENDDAT1"
            Endcase
            Filter [ITCO] Where STOFCY=[F:FCY1]FCY
&                             & ITMREF=[F:ITM]ITMREF
&                             & CSTTYP=[M:DIA]CSTTYP1
&                             & UID=0
&                             & evalue(CRITERE)
            Read [ITCO] First
            Filter [ITCO]
        Else
            Read [ITCO]ITC0=[F:FCY1]FCY;[F:ITM]ITMREF;[M:DIA]CSTTYP1;[M:DIA]ITCSEQ1;0
        Endif
        If !fstat
            Call GETDEV([F:ITCO]STOFCY) From DEVSUB
            Gosub CHARGE_ITC
        Endif
    Endif
Next

Return

$CHARGE_ITC
Local Char TABCCE(GLONCCE)(GOPTCANA+1)
Local Integer LSEQ, LRET

# Controle préalable que l'article site existe (sinon on ne créé rien : return)
# seulement dans le cas de transfert de site A à B
If [M:DIA]STOFCY2 <> ""
   Read [ITF]ITF0 = [F:ITM]ITMREF;[M:DIA]STOFCY2
   If fstat
      ERR_TRA = mess(139,197,1) - [F:ITM]ITMREF - [M:DIA]STOFCY2
      Call ECR_TRACE(ERR_TRA,[M:DIA]SELTYP=1) From GESECRAN
      ITC_OK = 2
      Return
   Endif
Else
   Read [ITF]ITF0 = [F:ITM]ITMREF;[F:ITCO]STOFCY # v140 pour lire la méthode de valo
Endif
Read [ITG]ITG0 = "";[F:ITM]TCLCOD # enreg utile pour la màj stock (chgt valeur)

# Détermination du n° de séquence
[F:ITC]ITCSEQ = 0
If [M:DIA]STOFCY2<>""
    Filter [ITC] Where ITMREF = [F:ITCO]ITMREF
&                    & STOFCY = [M:DIA]STOFCY2
&                    & CSTTYP = [M:DIA]CSTTYP2
Else
    Filter [ITC] Where ITMREF = [F:ITCO]ITMREF
&                    & STOFCY = [F:ITCO]STOFCY
&                    & CSTTYP = [M:DIA]CSTTYP2
Endif
Read [ITC] First
LSEQ = [F:ITC]ITCSEQ+1
Filter [ITC]

If [M:DIA]AGGCST=2   # CCC modif 16461 13/11/02: ajout de tous les coûts (variables et fixes) dans MATCST(0)

   # modif refaite pour correction Bug 18310 :      20/05/03
    Raz [F:ITC]
    [F:ITC]ITMREF    =     [F:ITCO]ITMREF
    [F:ITC]STOFCY    =     [F:ITCO]STOFCY
    [F:ITC]CLCQTY    =     [F:ITCO]CLCQTY
    # mettre dans la composante matière d'indice BRDCOD
    [F:ITC]MATCST(I_MAT) = [F:ITCO]VLTTOT * [M:DIA]COE # coût total avec FG
    [F:ITC]MATLEV0   =     [F:ITCO]MATLEV0 * [M:DIA]COE
    [F:ITC]MATLEVCST(I_MAT) = [F:ITC]MATCST(I_MAT)
    [F:ITC]MATTOT    =     [F:ITC]MATCST(I_MAT)
    [F:ITC]CSTTOT    =     [F:ITC]MATCST(I_MAT)
    [F:ITC]VLTTOT    =     [F:ITC]MATCST(I_MAT)
Else
    [F:ITC]  = [F:ITCO]  # pour ITMREF et données de paramétrage (déplacée ici 20/05/03)

    [F:ITC]MATLEV0   =     [F:ITCO]MATLEV0 * [M:DIA]COE
    For I = 0 To GACTMAT-1
           [F:ITC]MATCST(I)      = [F:ITCO]MATCST(I) * [M:DIA]COE
           [F:ITC]FXDMATCST(I)   = [F:ITCO]FXDMATCST(I) * [M:DIA]COE
           [F:ITC]MATLEVCST(I)   = [F:ITCO]MATLEVCST(I) * [M:DIA]COE
           [F:ITC]FXDMATLEV(I)   = [F:ITCO]FXDMATLEV(I) * [M:DIA]COE
    Next
    For I = 0 To GACTMAC-1
           [F:ITC]MACCST(I)      = [F:ITCO]MACCST(I) * [M:DIA]COE
           [F:ITC]FXDMACCST(I)   = [F:ITCO]FXDMACCST(I) * [M:DIA]COE
           [F:ITC]MACLEVCST(I)   = [F:ITCO]MACLEVCST(I) * [M:DIA]COE
           [F:ITC]FXDMACLEV(I)   = [F:ITCO]FXDMACLEV(I) * [M:DIA]COE
    Next
    For I = 0 To GACTLAB-1
           [F:ITC]LABCST(I)      = [F:ITCO]LABCST(I) * [M:DIA]COE
           [F:ITC]FXDLABCST(I)   = [F:ITCO]FXDLABCST(I) * [M:DIA]COE
           [F:ITC]LABLEVCST(I)   = [F:ITCO]LABLEVCST(I) * [M:DIA]COE
           [F:ITC]FXDLABLEV(I)   = [F:ITCO]FXDLABLEV(I) * [M:DIA]COE
    Next
    [F:ITC]MATTOT = sum([F:ITC]MATCST)
    [F:ITC]MACTOT = sum([F:ITC]MACCST)
    [F:ITC]LABTOT = sum([F:ITC]LABCST)

    [F:ITC]SCOTOT = [F:ITCO]SCOTOT * [M:DIA]COE
    [F:ITC]OVETOT = [F:ITCO]OVETOT * [M:DIA]COE

    [F:ITC]CSTTOT = [F:ITC]MATTOT+[F:ITC]MACTOT+[F:ITC]LABTOT+[F:ITC]SCOTOT
    [F:ITC]VLTTOT = [F:ITC]CSTTOT + [F:ITC]OVETOT

    [F:ITC]FXDSCOCST   = [F:ITCO]FXDSCOCST * [M:DIA]COE

    [F:ITC]OVEMATCST   = [F:ITCO]OVEMATCST * [M:DIA]COE
    [F:ITC]FXDOVEMAT   = [F:ITCO]FXDOVEMAT * [M:DIA]COE
    [F:ITC]OVEMACCST   = [F:ITCO]OVEMACCST * [M:DIA]COE
    [F:ITC]FXDOVEMAC   = [F:ITCO]FXDOVEMAC * [M:DIA]COE
    [F:ITC]OVELABCST   = [F:ITCO]OVELABCST * [M:DIA]COE
    [F:ITC]FXDOVELAB   = [F:ITCO]FXDOVELAB * [M:DIA]COE
    [F:ITC]OVESCOCST   = [F:ITCO]OVESCOCST * [M:DIA]COE
    [F:ITC]FXDOVESCO   = [F:ITCO]FXDOVESCO * [M:DIA]COE

    [F:ITC]SCOLEVCST   = [F:ITCO]SCOLEVCST * [M:DIA]COE
    [F:ITC]FXDSCOLEV   = [F:ITCO]FXDSCOLEV * [M:DIA]COE
    [F:ITC]OVELEVCST   = [F:ITCO]OVELEVCST * [M:DIA]COE
    [F:ITC]FXDOVELEV   = [F:ITCO]FXDOVELEV * [M:DIA]COE

    # nouvelles zones 140
    [F:ITC]OVEMATLEV   = [F:ITCO]OVEMATLEV * [M:DIA]COE
    [F:ITC]OVEMACLEV   = [F:ITCO]OVEMACLEV * [M:DIA]COE
    [F:ITC]OVELABLEV   = [F:ITCO]OVELABLEV * [M:DIA]COE
    [F:ITC]OVESCOLEV   = [F:ITCO]OVESCOLEV * [M:DIA]COE
    [F:ITC]FXDOVEMATL  = [F:ITCO]FXDOVEMATL * [M:DIA]COE
    [F:ITC]FXDOVEMACL  = [F:ITCO]FXDOVEMACL * [M:DIA]COE
    [F:ITC]FXDOVELABL  = [F:ITCO]FXDOVELABL * [M:DIA]COE
    [F:ITC]FXDOVESCOL  = [F:ITCO]FXDOVESCOL * [M:DIA]COE

Endif

If [M:DIA]STOFCY2 <> ""
     [F:ITC]STOFCY   = [M:DIA]STOFCY2
Endif
[F:ITC]CSTTYP   = [M:DIA]CSTTYP2
[F:ITC]ITCSEQ   = LSEQ
[F:ITC]ITCDAT   = date$
If find([F:ITC]CSTTYP,1,3) & [M:DIA]FIYNUM2<>0
    [F:ITC]FIYNUM = [M:DIA]FIYNUM2
Endif
If [M:DIA]STRDAT2<>[0/0/0] & ENDDAT2<>[0/0/0]
    [F:ITC]ITCSTRDAT = [M:DIA]STRDAT2
    [F:ITC]ITCENDDAT = [M:DIA]ENDDAT2
Endif
#   changer la date et le user (y compris UPD car il y a eu transclasse)
[F:ITC]CREDAT = date$
[F:ITC]CREUSR = GUSER
[F:ITC]EXPNUM = [C]EXPORT
[F:ITC]UPDDAT = [0/0/0]
[F:ITC]UPDUSR = ""
# effacer les zones qui n'ont plus de sens         (20/05/03)
Raz [F:ITC]OLDCST, [F:ITC]OLDDAT, [F:ITC]PHYSTO # et ROUALT, SLTMATCST...?

[F:ITC]UID=0

# Issue 73264 - 2011-09-06 by CCC : Plus d'arrondis par défaut mais possibilité de le faire simplement par PE
If dim(LARRONDI)<=0
    Local Integer LARRONDI
Endif
Raz GPE, LARRONDI

# CCC (27/03/07) PE 40513
GPOINT="CHARGEITC"
Gosub ENTREE From EXEFNC

# Issue 78296 - 2011-11-29 by CCC : Créer le mvt avant l'écriture de ITC
#Gosub WRITE_ITC From TRTCOST
#
#If fstat
#   ERR_TRA = mess(13,100,1) - "ITMCOST" -num$(fstat)- mess(14,100,1) -[F:ITC]STOFCY - [F:ITC]ITMREF - num$([F:ITC]CSTTYP) - num$([F:ITC]ITCSEQ) - num$([F:ITC]UID)
#   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
#   ITC_OK = 0
#Endif
#
#
ICN_OK = 1
ICC_OK = 1
IWC_OK = 1
#If [M:DIA]AGGCST<>2
#    Gosub MAJ_ICN
#    Gosub MAJ_ICC
#    Gosub MAJ_IWC
#Endif

If ITC_OK <> 0 & ICN_OK<>0 & ICC_OK<>0 & IWC_OK<>0
    If [F:ITM]ITMREF<>[F:ITC]ITMREF
        Read [ITM]ITM0 = [F:ITC]ITMREF
    Endif
    If [F:ITF]ITMREF<>[F:ITC]ITMREF | [F:ITF]STOFCY<>[F:ITC]STOFCY
        Read [ITF]ITF0=[F:ITC]ITMREF;[F:ITC]STOFCY
    Endif
    If [F:ITG]TCLCOD<>[F:ITM]TCLCOD
        Read [ITG]ITG0="";[F:ITM]TCLCOD # enreg utile pour la màj stock (chgt valeur)
    Endif
    Call GETTCM([F:ITC]ITMREF,[F:ITC]STOFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM], nécessaire pour conditionner le mvt chgt valeur

    #---- Génération d'un mvt de changement de valeur ou d'un enreg SMI pour création ultérieure du mvt --#
    If find([F:ITC]CSTTYP,[F:TCM]ISSVLTCOD,[F:TCM]ISSVLTCOD(1)) & find([F:ITC]CSTTYP,1,2)
        # Issue 88698 - 2013-03-18 by CCC
        Call GETCPY([F:ITC]STOFCY,"",0,"") From TRTX3CPT

        Call INITCCE(TABCCE) From SUBICC

        # Issue 83536 - 2012-08-10 by CCC
        #Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=1 xor [F:TCM]ISSVLT2=1)+([F:TCM]ISSVLT2=1),TABCCE) From SUBITCB
        Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=[F:ITC]CSTTYP xor [F:TCM]ISSVLTCOD(1)=[F:ITC]CSTTYP)+([F:TCM]ISSVLTCOD(1)=[F:ITC]CSTTYP),TABCCE) From SUBITCB
        If GOK < 1
           # "Erreur à la génération du mouvement de changement de valeur"
           ERR_TRA = mess(200,199,1)
           Call ECR_TRACE(ERR_TRA,1) From GESECRAN
            ITC_OK = 0
        Endif
    Endif

    ERR_TRA = mess(51,197,1)-":"-[F:ITC]STOFCY -[F:ITC]ITMREF- num$([F:ITC]CSTTYP)-num$([F:ITC]ITCSEQ)
    Call ECR_TRACE(ERR_TRA,0) From GESECRAN
Endif

If ITC_OK
    Gosub WRITE_ITC From TRTCOST

    If fstat
       ERR_TRA = mess(13,100,1) - "ITMCOST" -num$(fstat)- mess(14,100,1) -[F:ITC]STOFCY - [F:ITC]ITMREF - num$([F:ITC]CSTTYP) - num$([F:ITC]ITCSEQ) - num$([F:ITC]UID)
       Call ECR_TRACE(ERR_TRA,1) From GESECRAN
       ITC_OK = 0
    Endif


    ICN_OK = 1
    ICC_OK = 1
    IWC_OK = 1
    If [M:DIA]AGGCST<>2
        Gosub MAJ_ICN
        Gosub MAJ_ICC
        Gosub MAJ_IWC
    Endif
Endif
Return

# boucle de mise à jour des détails de Fg par nature
$MAJ_ICN
For [ICNO] Where STOFCY = [F:ITCO]STOFCY & CSTTYP = [F:ITCO]CSTTYP
&        & ITMREF = [F:ITCO]ITMREF & ITCSEQ = [F:ITCO]ITCSEQ & UID=[F:ITCO]UID

    [F:ICN] = [F:ICNO]
    [F:ICN]NATAMTLEV = [F:ICNO]NATAMTLEV * [M:DIA]COE
    [F:ICN]NATAMTSSE = [F:ICNO]NATAMTSSE * [M:DIA]COE
    [F:ICN]FXDAMTLEV = [F:ICNO]FXDAMTLEV * [M:DIA]COE
    [F:ICN]FXDAMTSSE = [F:ICNO]FXDAMTSSE * [M:DIA]COE

    If [M:DIA]STOFCY2 <> ""
        [F:ICN]STOFCY   = [M:DIA]STOFCY2
    Endif
    [F:ICN]CSTTYP   = [M:DIA]CSTTYP2
    [F:ICN]ITCSEQ   = LSEQ
    [F:ICN]UID      = 0

    [F:ICN]EXPNUM = [C]EXPORT
    [F:ICN]UPDDAT = [0/0/0]
    [F:ICN]UPDUSR = ""

    Gosub WRITE_ICN From TRTCOST

    If fstat
        ERR_TRA = mess(13,100,1) - "ITCNAT"-num$(fstat) - mess(14,100,1) - [F:ICN]ITMREF
        ERR_TRA -= [F:ICN]STOFCY-num$([F:ICN]ITCSEQ)-[F:ICN]OVENAT
        Call ECR_TRACE(ERR_TRA,1) From GESECRAN
        ICN_OK = 0
        Break
    Endif
Next

Return

# boucle de mise à jour des coûts composants
$MAJ_ICC
For [ICCO] Where STOFCY = [F:ITCO]STOFCY & CSTTYP = [F:ITCO]CSTTYP
&        & ITMREF = [F:ITCO]ITMREF & ITCSEQ = [F:ITCO]ITCSEQ & UID=[F:ITCO]UID

    Look [ITF]ITF0=[F:ICCO]MATREF;[F:ICCO]STOFCY
    If !fstat
        [F:ICC] = [F:ICCO]
        For I=0 To GACTMAT-1
            [F:ICC]MATCST(I)  = [F:ICCO]MATCST(I) * [M:DIA]COE
        Next
        For I=0 To GACTMAC-1
            [F:ICC]MACCST(I)  = [F:ICCO]MACCST(I) * [M:DIA]COE
        Next
        For I=0 To GACTLAB-1
            [F:ICC]LABCST(I)  = [F:ICCO]LABCST(I) * [M:DIA]COE
        Next
        [F:ICC]SCOCST   = [F:ICCO]SCOCST * [M:DIA]COE
        [F:ICC]OVEMATCST= [F:ICCO]OVEMATCST * [M:DIA]COE
        [F:ICC]OVEMACCST= [F:ICCO]OVEMACCST * [M:DIA]COE
        [F:ICC]OVELABCST= [F:ICCO]OVELABCST * [M:DIA]COE
        [F:ICC]OVESCOCST= [F:ICCO]OVESCOCST * [M:DIA]COE

        If [M:DIA]STOFCY2 <> ""
            [F:ICC]STOFCY   = [M:DIA]STOFCY2
        Endif
        [F:ICC]CSTTYP   = [M:DIA]CSTTYP2
        [F:ICC]ITCSEQ   = LSEQ
        [F:ICC]UID      = 0

        [F:ICC]EXPNUM = [C]EXPORT
        [F:ICC]UPDDAT = [0/0/0]
        [F:ICC]UPDUSR = ""

        Gosub WRITE_ICC From TRTCOST

        If fstat
            ERR_TRA = mess(13,100,1) - "ITCMAT"-num$(fstat) - mess(14,100,1) - [F:ICC]ITMREF
            ERR_TRA -= [F:ICC]STOFCY-num$([F:ICC]ITCSEQ)-[F:ICC]MATREF
            Call ECR_TRACE(ERR_TRA,1) From GESECRAN
            ICC_OK = 0
            Break
        Endif
    Endif
Next

Return

# boucle de mise à jour des coûts opératoires et de sous-traitance
$MAJ_IWC
For [IWCO] Where STOFCY = [F:ITCO]STOFCY & CSTTYP = [F:ITCO]CSTTYP
&        & ITMREF = [F:ITCO]ITMREF & ITCSEQ = [F:ITCO]ITCSEQ & UID=[F:ITCO]UID

    Look [MWS]WST0=[F:IWCO]WST;[F:IWCO]STOFCY
    If !fstat
        [F:IWC] = [F:IWCO]
        [F:IWC]SETCST = [F:IWCO]SETCST * [M:DIA]COE
        [F:IWC]OPECST = [F:IWCO]OPECST * [M:DIA]COE
        [F:IWC]SETAMT = [F:IWCO]SETAMT * [M:DIA]COE
        [F:IWC]OPEAMT = [F:IWCO]OPEAMT * [M:DIA]COE
        [F:IWC]OVEAMT = [F:IWCO]OVEAMT * [M:DIA]COE
        [F:IWC]OVEAMTTOP = [F:IWCO]OVEAMTTOP * [M:DIA]COE
        [F:IWC]PRISCO = [F:IWCO]PRISCO * [M:DIA]COE

        If [M:DIA]STOFCY2 <> ""
            [F:IWC]STOFCY   = [M:DIA]STOFCY2
        Endif
        [F:IWC]CSTTYP   = [M:DIA]CSTTYP2
        [F:IWC]ITCSEQ   = LSEQ
        [F:IWC]UID      = 0

        [F:IWC]EXPNUM = [C]EXPORT
        [F:IWC]UPDDAT = [0/0/0]
        [F:IWC]UPDUSR = ""

        Gosub WRITE_IWC From TRTCOST

        If fstat
            ERR_TRA = mess(13,100,1) - "ITCWST" -num$(fstat)- mess(14,100,1) - [F:IWC]ITMREF
            ERR_TRA -= [F:IWC]STOFCY-num$([F:IWC]ITCSEQ)-[F:IWC]WST
            Call ECR_TRACE(ERR_TRA,1) From GESECRAN
            IWC_OK = 0
            Break
        Endif
    Endif
Next

Return

###########################################################################################
#  Sous-prog d'actions sur zones d'écran
######################################################################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
# Issue 105748 - 2015-09-10 by CCC : update display of site and company fields
Call AFF([M:DIA]CPY1, [M:DIA]STOFCY1, [M:DIA]CPY2, [M:DIA]STOFCY2)
# Initialisation d'affichage qui n'est pas possible dans INIT_DIA
If find([M:DIA]CSTTYP1,1,3)
    Grizo [M:DIA]STRDAT1,ENDDAT1
    Actzo [M:DIA]FIYNUM1
Else
    Grizo [M:DIA]FIYNUM1
    Actzo [M:DIA]STRDAT1,ENDDAT1
Endif
If find([M:DIA]CSTTYP2,1,3)
    # Issue 91663 - 2014-06-11 by CCC
    #Grizo [M:DIA]STRDAT2,ENDDAT2
    Actzo [M:DIA]FIYNUM2
Else
    Grizo [M:DIA]FIYNUM2
    Actzo [M:DIA]STRDAT2,ENDDAT2
Endif
Affzo [M:DIA]STRDAT1,ENDDAT1,STRDAT2,ENDDAT2,FIYNUM1,FIYNUM2
# Issue 79875 - 2012-02-07 by CCC
If [M:DIA]FILART="1=1"
    Raz [M:DIA]FILART
Endif
End

######################################################################################
# Issue 91663 - 2014-06-11 by CCC
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer LRET
LRET = func GETEXE(1,[M:DIA]CPY1,VALEUR,[M:DIA]STOFCY1,[M:DIA]FIYNUM1,[M:DIA]CSTTYP1,[M:DIA]STRDAT1,[M:DIA]ENDDAT1)
If LRET
    Effzo [M:DIA]FIYNUM1
Endif
LRET = func GETEXE(2,[M:DIA]CPY2,VALEUR,[M:DIA]STOFCY2,[M:DIA]FIYNUM2,[M:DIA]CSTTYP2,[M:DIA]STRDAT2,[M:DIA]ENDDAT2)
If LRET
    Effzo [M:DIA]FIYNUM2
Endif

End

###########################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M:DIA]SELTYP = 1 : Affzo SELTYP
Else
  If [M:DIA]FILART <> ""
    If [M:DIA]STAFLT = 0
       mkstat=2
    Else
       [M:DIA]SELTYP = 3 : Affzo SELTYP
    Endif
  Else
    [M:DIA]SELTYP = 2 : Affzo SELTYP
  Endif
Endif
End

######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" & [M:DIA]SELTYP = 1
    GMESSAGE = mess(184,199,1)
    mkstat = 2
  Endif

  If FILART = "" & [M:DIA]SELTYP = 3
    GMESSAGE = mess(608,10033,1)
    mkstat = 2
  Endif

End

######################################################################################
Subprog C_STOFCY1(VALEUR)
Variable Char VALEUR()

If VALEUR <> ""
    Look [FCY1]FCY1=[M:DIA]CPY1;VALEUR
    If fstat
        GMESSAGE = mess(412,199,1)
        mkstat=2
        End
    Endif
Endif

If VALEUR<>"" & [M:DIA]ITMREF<>""
    Look [ITF]ITF0=[M:DIA]ITMREF;VALEUR
    If fstat
        GMESSAGE = mess(25,192,1)
        mkstat=2
    Endif
Endif
End

########################################
Subprog C_STOFCY2(VALEUR)
Variable Char    VALEUR()
Local    Char    DEV1(GLONCUR)
# Soit 2 sites vides (traitemt tous sites) soit 2 sites renseignés
# controler les devises des sites
If VALEUR =  "" & [M:DIA]STOFCY1 <> ""
    mkstat = 2
Endif

If VALEUR <>""
    Look [FCY1]FCY1=[M:DIA]CPY2;VALEUR
    If fstat
        GMESSAGE = mess(412,199,1)
        mkstat=2
        End
    Endif
Endif

If VALEUR <> "" & [M:DIA]ITMREF<>""
    Look [ITF]ITF0=[M:DIA]ITMREF;VALEUR
    If fstat
        GMESSAGE = mess(25,192,1)
        mkstat=2
    Endif

   Call GETDEV([M:DIA]STOFCY1) From DEVSUB
   DEV1 = GLOCALDEV
   Call GETDEV(VALEUR) From DEVSUB
#  "Les 2 sites doivent avoir la même devise"
   If GLOCALDEV <> DEV1
      mkstat = 2
      GMESSAGE = mess(208,199,1)
   Endif
Endif
End

