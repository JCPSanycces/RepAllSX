LRET = func GETEXE(1,[M:DIA]CPY1,[M:DIA]ITMREF,[M:DIA]STOFCY1,VALEUR,[M:DIA]CSTTYP1,LSTR,LEND)
If LRET
    mkstat=2
    If LRET=2
        GMESSAGE=mess(23,100,1)
    Endif
Else
    [M:DIA]STRDAT1 = LSTR
    [M:DIA]ENDDAT1 = LEND
    Affzo [M:DIA]STRDAT1,ENDDAT1
Endif
End

