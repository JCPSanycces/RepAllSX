######################################################################################
Subprog C_STRDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR<date$
    mkstat=2
    GMESSAGE = mess(239,193,1)  # The entered date must not be prior to the current date
Endif
# If fiscal year is known, start date has to be during this FY
If [M:DIA]FIYNUM2<>0
    Local Libelle TYPGEN, TYPANA    # same type as GTYPGEN and GTYPANA
    Local Date LSTR, LEND
    Call SETMAINREF([M:DIA]CPY2,TYPGEN,TYPANA) From CPTDIV
    Call DATEXE([M:DIA]CPY2,TYPGEN,[M:DIA]FIYNUM2,LSTR,LEND) From CPTSUB
    If VALEUR<LSTR | VALEUR>LEND
        GMESSAGE = mess(13,104,1) : # Hors limite des dates de validité
        mkstat = 2
    Endif
Endif
End

Subprog C_ENDDAT2(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]STRDAT2
    mkstat=2
    GMESSAGE = mess(99,177,1)  # The end date must not be less than the start date.
Endif
# If fiscal year is known, start date has to be during this FY
If [M:DIA]FIYNUM2<>0
    Local Libelle TYPGEN, TYPANA    # same type as GTYPGEN and GTYPANA
    Local Date LSTR, LEND
    Call SETMAINREF([M:DIA]CPY2,TYPGEN,TYPANA) From CPTDIV
    Call DATEXE([M:DIA]CPY2,TYPGEN,[M:DIA]FIYNUM2,LSTR,LEND) From CPTSUB
    If VALEUR<LSTR | VALEUR>LEND
        GMESSAGE = mess(13,104,1) : # Hors limite des dates de validité
        mkstat = 2
    Endif
Endif
End

#**#####################################################################################
#* Return fiscal year number with start and end date
#*
#* @param PCPYNUM  : 1=company origin ; 2= company destination
#* @param PCPY     : Company
#* @param PITM     : Item
#* @param PFCY     : Site
#* @param PFIYNUM  : Fiscal year number
#* @param PCSTTYP  : Cost type (1=standard, 2=actual, 3=budget, 4=simulated)
#* @return
#* PSTRDAT : start date <br>
#* PENDDAT : end date<br>
#* If a period is not found for the company an error is returned and dates are null:<br>
#* 1 = end period before today <br>
#* 2 = no cost found for this fiscal year<br>
#* 3 = FY doesn't exist
#*!
Funprog GETEXE(PCPYNUM,PCPY,PITM,PFCY,PFIYNUM,PCSTTYP,PSTRDAT,PENDDAT)
Value Integer PCPYNUM
Value Char    PCPY
Value Char    PITM
Value Char    PFCY
Variable Decimal PFIYNUM
Value Integer PCSTTYP
Variable Date PSTRDAT
Variable Date PENDDAT

Local Libelle TYPGEN, TYPANA    # same type as GTYPGEN and GTYPANA

Raz PSTRDAT, PENDDAT

If PCPYNUM=1
    Call SETMAINREF(PCPY,TYPGEN,TYPANA) From CPTDIV
    If PFIYNUM=0
        Call GETEXE(PCPY,TYPGEN,date$,PFIYNUM) From CPTSUB
    Endif
    Call DATEXE(PCPY,TYPGEN,PFIYNUM,PSTRDAT,PENDDAT) From CPTSUB
    If PFCY<>"" & PITM<>""
            Filter [ITCO] Where STOFCY=PFCY
&                             & ITMREF=PITM
&                             & CSTTYP=PCSTTYP
&                             & UID=0
&                             & ITCSTRDAT>=PSTRDAT
&                             & ITCENDDAT<=PENDDAT
            Read [ITCO] First
            Filter [ITCO]
            If !fstat
                PSTRDAT = [F:ITCO]ITCSTRDAT
                PENDDAT = [F:ITCO]ITCENDDAT
            Else
                Raz PSTRDAT, PENDDAT
                End 2
            Endif
    Endif
Else
    Call SETMAINREF(PCPY,TYPGEN,TYPANA) From CPTDIV
    Call DATEXE(PCPY,TYPGEN,PFIYNUM,PSTRDAT,PENDDAT) From CPTSUB
    If PSTRDAT=[0/0/0] | PENDDAT=[0/0/0]
        # Fiscal year doesn't exist
        End 3
    Endif
    If PENDDAT<date$
        # FY before today
        Raz PSTRDAT, PENDDAT
        End 1
    Endif
    If PSTRDAT<date$
        # start date of FY before today
        PSTRDAT = date$
    Endif
Endif

End 0

# Issue 105748 - 2015-10-05 by CCC : update display of site and company fields
Subprog AFF(PCPY1, PFCY1, PCPY2, PFCY2)
Variable Char PCPY1
Variable Char PFCY1
Variable Char PCPY2
Variable Char PFCY2

If PFCY1=""
    PCPY2=PCPY1
    PFCY2=""
    Diszo [M:DIA]STOFCY2
    Diszo [M:DIA]CPY2
    Affzo [M:DIA]CPY2,STOFCY2
Else
    Actzo [M:DIA]STOFCY2
    Actzo [M:DIA]CPY2
    Affzo [M:DIA]CPY2,STOFCY2
Endif

End

