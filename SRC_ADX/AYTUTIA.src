######################################################################################
## Xtend - 
#    Utilitaires
#      Gosub
#        $TIMING_START          # Gestion timing (accès généré) - Start
#        $TIMING_STOP           # Stop
#
#      Subprog-Funprog
#        SUPFIL_TRACE               # Suppression fichier trace
#        HASCODACT(DOS, CODACT)     # Existence code activité dans dossier
#        CODACT_OK(DOS, CODACT)     # Code activité AYT actif dans dossier
#        GETAYN_X3COD(LINCODTYP)    # Code objet X3 en fct de LINCODTYP de AYN 
#        GETX3COD(MNL7910)          # Code objet X3 en fct du menu 7910 
#        GETMNL7910(X3COD)          # Menu 7910 en fct du Code objet X3
#        GETAYN_7910(LINCODTYP)     # Menu 7910 en fct de LINCODTYP de AYN 
#        Subprog AYT_DEBUG()        # Activation debuger java
#        Subprog MNLCHX(MML,LST)    # Choix à activer dans un menu local
#
#
#    Utilitaires de dépannage
#        - Subprog SETBRWX3()        # Mettre à jour la clé composite pour les browsers X3
#        - Subprog BRWX3UPTWICE()    # Recherche doublon
#        - Subprog AYN_UPPER()       # Mise à jour en uppercase AYN
#        - Subprog AYT_GEN()         # Regénération des trts xtend
#        - Subprog AYN_MOD()         # Modif. de masse AYN
######################################################################################

