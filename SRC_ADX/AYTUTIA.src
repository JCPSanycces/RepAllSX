######################################################################################
## Xtend - Utilitaires 
######################################################################################

#------------------------------------------------------------#
###    Gestion timing (issu du trt TIMING)
# $$$$ Start
#------------------------------------------------------------#
$TIMING_START          # start timing
GTRTIME = filpath("tmp",GUSER,"tra")
GTRSUB  = 1
Openo GTRTIME , 0
Openo
dbgstr(131) = GTRTIME
dbglong(20) = 200
Disable GSTATM1
Enable  GSTATM2
Return     

# Stop timing
# $$$$
#------------------------------------------------------------#
$TIMING_STOP           # stop timing
Call ECR_TRACE("#",0)                 From GESECRAN
Call ECR_TRACE("### Elapsed time: ",0) From GESECRAN
GSERVEUR=1    # Eviter ouverture nelle trace
Call ARRET From TIMING
GSERVEUR=0
Call ECR_TRACE("#",0)                 From GESECRAN
Return     

# Code activité actif dans dossier  (repris Patchabi/Ok_Codact)
# $$$$
#------------------------------------------------------------#
Funprog CODACT_OK(DOS, CODACT)
Value Char    DOS()
Value Char    CODACT()
Value Char       APPLI
Value Char       COD
Local Integer WOK
If CODACT="" : End 1 : Endif
If DOS="" : DOS=nomap : Endif
Local File ADOSACT [ADA3]
Read [ADA3]ADA0=DOS;CODACT
WOK=(!fstat & [F:ADA3]FLACT=2)
Close Local File [ADA3]
End WOK

# Existence code activité dans dossier
# $$$$
#------------------------------------------------------------#
Funprog HASCODACT(DOS, CODACT)
Value Char    DOS()
Value Char    CODACT()
If CODACT="" : End 1 : Endif
If DOS=nomap 
    Local File ACTIV [ACV]
Else
    Local File =DOS+".ACTIV" [ACV]
Endif
Read [ACV]CODACT = CODACT
End (fstat=0)


#------------------------------------------------------------#
# $$$$
Subprog SUPFIL_TRACE(TRANAM)
Value Char GTRACE
Local Char    FICH(GDIMFIC) , NOMFIC(GDIMFIC) , EXT(10)
Local Char    REPERT(GDIMFIC) , APPLI(GLONADS) , MACHINE(GDIMFIC)
Local Integer STA
 REPERT  = "TRA"
 FICH    = TRANAM
 EXT     = "tra"
 MACHINE = adxmac(0)
 APPLI   = nomap
 NOMFIC = filpath(REPERT,FICH,EXT,APPLI,"",MACHINE)
 SAVTRACE = GTRACE
 GTRACE = "" : # JML 24/06/98 pour que ORDSYS ne le recrée pas ...
 Call EFFACE(NOMFIC,STA) From ORDSYS
 GTRACE = SAVTRACE
End

#------------------------------------------------------------#
# $$$$
# Code objet X3 en fct de LINCODTYP de AYN 
#    LINCODTYP- 1: entité 2:Bloc 3:Action, 4: Lien dynamique, 5: Elt.bloc cond., 6: Interface, 7: Menu
Funprog GETAYN_X3COD(LINCODTYP)
Value Integer LINCODTYP
Local Char X3COD
Local Char LST(100)
Local Integer WI
LST='"AYE","AYB","AYA","AYL","AYW","AYI","AYC"' 
WI = 2 + 6*(LINCODTYP-1)
X3COD=seg$(LST,WI, WI+2)
#Infbox X3COD
End X3COD

#------------------------------------------------------------#
# $$$$
# Code objet X3 en fct du menu 7910  (7910- 1:Aucun 2:Sites 3:Alias de page...)
Funprog GETX3COD(MNL7910)
Value Integer MNL7910
Local Char X3COD
Local Char LST(100)
Local Integer WI
LST='"$$$","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYX","AYM","AYI","AYU","AYC"' # liste ci-dessos
WI = 2 + 6*(MNL7910-1)
X3COD=seg$(LST,WI, WI+2)
#Infbox X3COD
End X3COD

#------------------------------------------------------------#
# $$$$
# Menu 7910 en fct du Code objet X3 
Funprog GETMNL7910(X3COD)
End find(X3COD,"$$$","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYX","AYM","AYI","AYU","AYC")

#------------------------------------------------------------#
# $$$$
# Menu 7910 en fct de LINCODTYP de AYN 
Funprog GETAYN_7910(LINCODTYP)
End func GETMNL7910(func GETAYN_X3COD(LINCODTYP))

#------------------------------------------------------------#
# $$$$
# Répertoire en fonction de la racine demandé (menu 7937)
Funprog MNL7937REP(FCYCOD, LAN, MNL7937)
Value Char FCYCOD()
Value Char LAN()
Value Integer MNL7937
Local Char WTMP
Case MNL7937
When 2
 WTMP="DIRPAG"
When 3
 WTMP="DIRFILAPP"
When 4
 WTMP="DIRFILES"
When 5
 WTMP="DIRXTEND"
Endcase
End func AYTGESFILE.GETPATH("",nomap,WTMP,LAN,FCYCOD,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")

#------------------------------------------------------------#
# $$$$
# Activation debugger java
Subprog AYT_DEBUG
If (1=1 and find(GUSER,"JPJ"))
  If GBROWS<>0 : End : Endif
  If dim([V]GIAADXCTX)<0 : Global Char GIAADXCTX(250) : Endif
  [V]GIAADXCTX = "X3_CS:NA1:"               : # entête "X3_CS:session client X3" + "NA1:session primaire"
  Call SET_DEBUG_ON(1) From DEBUGGERJ       : # 0=debugger socket "off"
  Call SET_PORT("1789") From DEBUGGERJ      : # Port*
  
  Local Char RETOUR(200)
  Local Integer K
  #Call SET_HOST("172.28.9.11") From DEBUGGERJ : # @ip du pc
  Call SET_HOST("ecjullienc.sagefr.adinternal.com") From DEBUGGERJ : # dns
endif
End

#------------------------------------------------------------#
# $$$$
# Choix à activer dans un menu local
# MNL   = n° menu local
# LST   = choix à ne pas activer
#   LST(WI)=1 : WI+=1    # Cst
#   LST(WI)=2 : WI+=1    # Chp XTend
#   LST(WI)=3 : WI+=1    # Chp Web
#   LST(WI)=4 : WI+=1    # Javascript
#   LST(WI)=5 : WI+=1    # Code accès
#   LST(WI)=6 : WI+=1    # Saisie
#   LST(WI)=5 : WI+=1    # Bloc
#
Subprog MNLCHX(MNL,LST)
Value Integer    MNL
Value Integer    LST(0..)
Local Integer WI
For WI=1 To len(mess(0,MNL,1))    
    If !find(WI,LST) : GMENLOC(WI)=1 : Endif
Next WI
End

#------------------------------------------------------------#
# $$$$
# Activation debugger java
# SUTIL = nom utilisateur concerné
# BAFF = affichage vrai,faux
Subprog AYT_DEBUGBIS(SUTIL,BAFF)

Value Char    SUTIL()
Value Integer    BAFF
#If (BAFF and GUSER=SUTIL)
If (BAFF)
  #If GBROWS<>0 : End : Endif
  If dim([V]GIAADXCTX)<0 : Global Char GIAADXCTX(250) : Endif
  [V]GIAADXCTX = "X3_CS:NA1:"               : # entête "X3_CS:session client X3" + "NA1:session primaire"
  Call SET_DEBUG_ON(1) From DEBUGGERJ       : # 0=debugger socket "off"
  Call SET_PORT("1789") From DEBUGGERJ      : # Port*
  
  Local Char RETOUR(200)
  Local Integer K
  #Call SET_HOST("172.16.9.153") From DEBUGGERJ : # @ip du pc
  #Call SET_HOST("ecjullienb.sagefr.adinternal.com") From DEBUGGERJ : # dns
  Call SET_HOST("172.28.9.27") From DEBUGGERJ : # dns

endif
End



