# - - - - - - - - - - -
Subprog BRWX3UPTWICE()    # Recherche doublon
Local Integer WI, WNB, WF
Local File AYTELTFLD [AY1]       

WNB= nbrecord([AY1] )
Infbox "Nb d'enreg.:"-num$(WNB)
Local Char TAB(40)(1..WNB)

For [AY1] With Stability 
    WF=find([AY1]BRWX3UP,TAB)
    If WF
        Infbox "Doublon sur clé:" - [AY1]BRWX3UP -" Tab:"- TAB(WF)- " Site/Code" - [AY1]FCYCOD-"/"- [AY1]FIECOD   
        Break
    Endif
    WI+=1
    TAB(WI)=[AY1]BRWX3UP
Next
End

# - - - - - - - - - - -
Subprog AYN_UPPER()    # Forcer la zone LINCOD en majuscule
Local Integer WI, WNB, WF
Local File AYTLINES [AYN1]       
Local File AYTLINES [AYN2]     
#Dbgaff
Trbegin [AYN1]
For [AYN1] With Stability 
    Readlock[AYN2]AYN0=[AYN1]FCYCOD;[AYN1]LINCODTYP;[AYN1]LINCOD;[AYN1]LINTYP;[AYN1]LINNUM               #<--
    If fstat
#        Infbox "Erreur readlock"-num$(fstat)
        Break
    Endif
    [F:AYN2]LINCODSTD=[F:AYN2]LINCOD
    [F:AYN2]LINCOD=toupper([F:AYN2]LINCOD)
    Rewrite [AYN2]
    WI+=1
Next
Commit
Infbox "Nb d'enreg. maj AYTLINES: "-num$(WI)
End

# - - - - - - - - - - -
Subprog AYN_MOD()      # Modif. de masse AYN
Local Integer WI, WNB, WF
Local File AYTLINES [AYN1]       
Local File AYTLINES [AYN2]     
#Dbgaff  
Trbegin [AYN1]
For [AYN1] Where [AYN1]LINCODTYP=7 With Stability 
    Readlock[AYN2]AYN0=[AYN1]FCYCOD;[AYN1]LINCODTYP;[AYN1]LINCOD;[AYN1]LINTYP;[AYN1]LINNUM               #<--
    If fstat
#        Infbox "Erreur readlock"-num$(fstat)
        Break
    Endif
    If [F:AYN2]LINTYP=10
        [F:AYN2]LINTYP=60
    Endif
    Rewrite [AYN2]
    WI+=1
Next
Commit
Infbox "Nb d'enreg. maj AYTLINES: "-num$(WI)
End


# - - - - - - - - - - -
Subprog AYT_GEN()    # Regénération de trt (suite par exemple mise à jour FTP)
Local Char TRT(15),WTIT(200)
Local Integer WRET
Call OUVRE_TRACE("Test AYUTIA") From LECFIC

Local Integer WTH_BASE, WTH_COP, WTH_ACT, WTH_GEN, WTH_AYT, WTH_SPE

WTH_BASE=1 : WTH_COP=0 : WTH_ACT=0 : WTH_GEN=0 : WTH_AYT=0 : WTH_SPE=1

Local Char OBJ

OBJ="AYA" : Gosub AYT_GENOBJ
OBJ="AYB" : Gosub AYT_GENOBJ
OBJ="AYD" : Gosub AYT_GENOBJ
OBJ="AYE" : Gosub AYT_GENOBJ
OBJ="AYF" : Gosub AYT_GENOBJ
OBJ="AYG" : Gosub AYT_GENOBJ
OBJ="AYI" : Gosub AYT_GENOBJ
OBJ="AYL" : Gosub AYT_GENOBJ
OBJ="AYM" : Gosub AYT_GENOBJ
OBJ="AYS" : Gosub AYT_GENOBJ
OBJ="AYU" : Gosub AYT_GENOBJ
OBJ="AYW" : Gosub AYT_GENOBJ
OBJ="AYX" : Gosub AYT_GENOBJ

If WTH_SPE
    TRT="SUBAYEINTSEL" : Gosub AYT_GENTRT
    TRT="SUBAYFTABSEL" : Gosub AYT_GENTRT
    TRT="SUBAYIFIESEL" : Gosub AYT_GENTRT
    TRT="SUBAYIWSRGE1" : Gosub AYT_GENTRT
    TRT="SUBAYIWSRGEN" : Gosub AYT_GENTRT
#    TRT="" : Gosub AYT_GENTRT
Endif

If WTH_AYT
    TRT="AYTCOP"     : Gosub AYT_GENTRT
    TRT="AYTCOPUSG"  : Gosub AYT_GENTRT
    TRT="AYTFCYCOP"  : Gosub AYT_GENTRT
    TRT="AYTFCYDEL"  : Gosub AYT_GENTRT
    TRT="AYTFCYTAR"  : Gosub AYT_GENTRT
    TRT="AYTGEN"     : Gosub AYT_GENTRT
    TRT="AYTGESFILE" : Gosub AYT_GENTRT
    TRT="AYTUTIA"    : Gosub AYT_GENTRT
#    TRT="" : Gosub AYT_GENTRT
Endif

Call FERME_TRACE From LECFIC
Call SUPP_TRACE  From LECFIC
End

$AYT_GENTRT
WTIT="*** Génération de: "+TRT
Call TEMPON(WTIT) From GESECRAN
Call ECR_TRACE(WTIT,0)                 From GESECRAN
Call VALID("TRT",TRT,nomap,WRET) From VALMSKSUB
#If !RET : Goto GEN_F : Endif
Return

$AYT_GENOBJ
If WTH_BASE : TRT="SUB"+OBJ       : Gosub AYT_GENTRT : Endif
If WTH_ACT  : TRT="SUB"+OBJ+"ACT" : Gosub AYT_GENTRT : Endif
If WTH_COP  : TRT="SUB"+OBJ+"COP" : Gosub AYT_GENTRT : Endif
If WTH_GEN  : TRT="SUB"+OBJ+"GEN" : Gosub AYT_GENTRT : Endif
Return


# - - - - - - - - - - -
Subprog MAJTMP()    # Sous-Prgm à modifier
Local Integer WI, WNB, WF
Local File AYTELTFLD [AYF1]       
Local File AYTELTFLD [AYF2]     
#Dbgaff  
Trbegin [AYF1]
For [AYF1] With Stability 
    Readlock[AYF2]AYF0=[AYF1]FCYCOD;[AYF1]FIECOD               #<--
    If fstat
#        Infbox "Erreur readlock"-num$(fstat)
        Break
    Endif
    [F:AYF2]RESRAC=1
    Rewrite [AYF2]
    WI+=1
Next
Commit
Infbox "Nb d'enreg. maj AYTELTFLD : "-num$(WI)
End

#----------------------------------------------------------------------------------------------------#
# Lecture d'un texte traduisible
#----------------------------------------------------------------------------------------------------#

Subprog LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2
If clalev([F:AXX1])=0 : Local File ATEXTRA [AXX1] : Endif
Read [AXX1]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If fstat=0
 VALEUR = [F:AXX1]TEXTE
Else 
 Read [AXX1]AXX0 = TABLE;CHAMP;GLANDEF;CLE1;CLE2
 If fstat=0 
  VALEUR = [F:AXX1]TEXTE 
 Else
  VALEUR = "" 
 Endif
Endif
End
