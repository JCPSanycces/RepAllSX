#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: NCSDOCHDR_CSTD, Non-conformance - Document Collection
# Issue X3-80367 - 2018-06-27 by STWIL : Add functions to check for document number
#                                        and set document links to deleted.
##############################################################################
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase

Return
###############################################################################

# --------------------------------------------------
# Increment collection row's line number (DOCLIN)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

      this.DOCLIN = 1 + max (this.APARENT.NCSDOCHDR(1..maxtab(this.APARENT.NCSDOCHDR)).DOCLIN)

Return

#**--------------------------------------------------------------------------------------------------------<br/>
#* NON_CONFORMANCE_EXISTS : Return whether a non-conformance exists for this trigger document header / line
#**<br/>---------------------------------------------------------------------------------------------------<br/>
#* @param DOCUTYP = Trigger document type (1 = Purchase receipt, 2 = Customer return, 3 = Production tracking, 4 = Quality control)
#* @param DOCUNUM = Trigger document number
#* @param DOCULIN = Trigger document line (0 for header, -1 for both header and detail types)
#* @param NCSMESS = Message displaying the type of non-conformances linked or blank if no non-conformances
#* @param DELETION = Whether the change is a deletion or modification 1 = deletion, 0 = modification
#* @return whether a non-conformance exists 1 = detail only, 2 = header only, 3 = detail and header
#**<br/>---------------------------------------------------------------------------------------------------
#*!
Funprog NON_CONFORMANCE_EXISTS (DOCUTYP, DOCUNUM, DOCULIN, NCSMESS, DELETION)
Value Integer DOCUTYP
Value Char DOCUNUM()
Value Integer DOCULIN
Variable Char NCSMESS()
Value Integer DELETION
Local Integer EXISTS
Local Char SOURCE (50)
Local Char LINKTYPE (50)
Local File NCSDOCHDR [NCSDHD]

    [L]EXISTS = 0

    # The function may be called during a document creation so check if the document number is blank
    If vireblc(DOCUNUM,2) <> ""
        If DOCULIN = -1
            # If we want to check for any (-1) don't filter the line number
            Filter [NCSDHD] Where DOCTYP = DOCUTYP & VCRNUM = DOCUNUM & LINSTA = 1
        Else
            # Otherwise check for this line and for the header
            Filter [NCSDHD] Where DOCTYP = DOCUTYP & VCRNUM = DOCUNUM & VCRLIN = DOCULIN & LINSTA = 1
        Endif

        Look [NCSDHD]NCSDHD1 First
        If fstat = 0
            If DOCULIN = 0
                # Set flag to header only as we are checking for header
                [L]EXISTS = 2
            Else
                [L]EXISTS = 1
            Endif
        Endif

        Filter [NCSDHD]

        # Check if there is a header non-conformance
        If DOCULIN > 0 & EXISTS = 0
            Filter [NCSDHD] Where DOCTYP = DOCUTYP & VCRNUM = DOCUNUM & VCRLIN = 0 & LINSTA = 1

            Look [NCSDHD]NCSDHD1 First
            If fstat = 0
                [L]EXISTS += 2
            Endif

            Filter [NCSDHD]
        Endif

        # setup the message to return, blank means no non-conformances
        If [L]EXISTS > 0
            If [L]EXISTS = 1 & DOCULIN >= 0
                # Non-conformances exist for this document $1$.
                [L]NCSMESS = func ASYRFNC.MES1(mess(48,3702,1),DOCUNUM + " / " + num$(DOCULIN))
            Elsif [L]EXISTS = 2 | ([L]EXISTS = 1 & DOCULIN = -1)
                [L]NCSMESS = func ASYRFNC.MES1(mess(48,3702,1),DOCUNUM)
            Endif
            If DELETION & ([L]EXISTS = 1 | DOCULIN = 0)
                # Deleting this document does not delete the Non-conformances.
                [L]NCSMESS += "\" + mess(49,3702,1)
                # Do you want to confirm your deletion?
                [L]NCSMESS += "\" + mess(50,3702,1)
            Else
                # Modifying this document may create discrepancies in the Non-conformances.
                [L]NCSMESS += "\" + mess(51,3702,1)
                # Do you want to confirm your modification?
                [L]NCSMESS += "\" + mess(52,3702,1)
            Endif
        Endif
    Endif
End EXISTS

#**------------------------------------------------------------------------------------------<br/>
#* DELETE_NON_CONFORMANCE_DOCUMENTS : Set trigger documents on Non-conformances to deleted
#**<br/>-------------------------------------------------------------------------------------<br/>
#* @param DOCUTYP = Trigger document type (1 = Purchase receipt, 2 = Customer return, 3 = Production tracking, 4 = Quality control)
#* @param DOCUNUM = Trigger document number
#* @param DOCULIN = Trigger document line (0 for header, -1 for both header and detail types)
#* @return whether the non-conformance document change had an error
#**<br/>-------------------------------------------------------------------------------------
#*!
Funprog DELETE_NON_CONFORMANCE_DOCUMENTS (DOCUTYP, DOCUNUM, DOCULIN)
Value Integer DOCUTYP
Value Char DOCUNUM()
Value Integer DOCULIN
Local Integer ERROR
Local File NCSDOCHDR [NCSDHD]

    [L]ERROR = 0
    If DOCULIN = -1
        Update [NCSDHD] Where DOCTYP = DOCUTYP & VCRNUM = DOCUNUM With LINSTA = 3
    Else
        Update [NCSDHD] Where DOCTYP = DOCUTYP & VCRNUM = DOCUNUM & VCRLIN = DOCULIN With LINSTA = 3
    Endif

    [L]ERROR = fstat

End ERROR

