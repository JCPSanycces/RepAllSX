      Call AMTNOTFCT([M]AMT(nolign-1),VALEUR,[M]CUR(nolign-1),[M]CURLED(nolign-1),[M]TYPRAT,[M]ACCDAT,[M]NUM(nolign-1),0,[M]AMT(nolign-1),[M]REGAMT(nolign-1),STAT) From NOTRGLT

      Affzo [M]REGAMT(nolign-1)
   Endif
End

