#<AdxTL>@(#)4.0.0.0 $Revision$
########################################################################
# Traitement PWOLIB - Librairie maj table temporaire PWRKORDERS   V150 #
########################################################################
# 
# Subprog EFFACE_PWO(LCODFNC)
#         Effacement lignes temporaires session courante
# 
# Subprog EFFACE_LIGD_PWO(LCODFNC,LLINNUM)
#         Effacement une ligne temporaire session courante
#
# Subprog WRITE_PWO(LCODFNC)
#         Ecriture de la ligne [F:PWO] courante 
#         après avoir contrôlé qu'on soit bien dans une transaction
#
########################################################################

$OPEN_FILES
If clalev([F:PWO])<=0 Local File PWRKORDERS [PWO] : Endif
Return



Subprog EFFACE_PWO(LCODFNC)
Value Char LCODFNC()
#-----------------------------------------------#
# Effacement fichier de travail                 #
# pour l'écran courant et la connexion courante #
#-----------------------------------------------#
Call DEBTRANS From GLOCK
$TR_PWO
GOK=1
Trbegin  [PWO]
  Delete [PWO] Where PRONUM=adxuid(1) & CODFNC=LCODFNC
  If    fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKORDERS"-num$(adxuid(1))-LCODFNC
        Goto ROLL_PWO
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWO",num$(adxuid(1))-"POH") From GLOCK
        Goto AB_PWO
  Endif
Commit
Return
$AB_PWO
Rollback : Return
$ROLL_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_PWO : Endif : Return



#-----------------------------------------------#
# Effacement d'une ligne du fichier de travail  #
# pour l'écran courant et la connexion courante #
#-----------------------------------------------#
Subprog EFFACE_LIGD_PWO(LCODFNC,LLINNUM)
Value Char    LCODFNC()
Value Integer LLINNUM()

Call DEBTRANS From GLOCK
$TR_PWO_LIGD
GOK=1
Trbegin  [PWO]
  Delete [PWO] Where PRONUM=adxuid(1) & CODFNC=LCODFNC & LINNUM=LLINNUM
  If    fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKORDERS"-num$(adxuid(1))-LCODFNC
        Goto ROLL_PWO_LIGD
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWO",num$(adxuid(1))-LCODFNC) From GLOCK
        Goto AB_PWO_LIGD
  Endif
Commit
Return
$AB_PWO_LIGD
Rollback : Return
$ROLL_PWO_LIGD
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_PWO_LIGD : Endif : Return




#-------------------------------------------------#
# Ecriture de la ligne dans le fichier de travail #
# pour l'écran courant et la connexion courante   #
#-------------------------------------------------#
Subprog WRITE_PWO(LCODFNC)
Value Char    LCODFNC()

Local Integer WTRBEGIN
Raz WTRBEGIN

# Si pas de transaction en cours
If adxlog<>1 
   GOK=1
   Trbegin [PWO]
   WTRBEGIN=1
Endif

If [F:PWO]CODFNC=""
   [F:PWO]PRONUM = adxuid(1)
   [F:PWO]CODFNC = LCODFNC
Endif
Write [PWO]

# Si on a ouvert une transaction
If WTRBEGIN=1 
   Commit
   Raz WTRBEGIN
Endif

Return

