#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
#                                                                       #
#     CONTROLE DES TIERS INTER-SITE                                     #
#                                                                       #
#     - Traitement        : FUNCTLBPR                                   #
#     - Action            : TRTCTLBPR (Traitement standard)             #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard 
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "OUVRE_BATCH" : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase
Return

#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################
#########################################################################
$INIT
If GSERVEUR
    Onerrgo ERRBATCH : # En batch , il vaut mieux mettre onerrgo
Endif

Gosub OUVRE
Return
#########################################################################
#########################################################################
$INIT_DIA
[M]SIMU=2
Return
#########################################################################
$CONTROLE
TMP=1

Return
#########################################################################
$EXEC

If !GSERVEUR Call OUVRE_TRACE(TIT) From LECFIC : Endif

Gosub CTL_BPR1 : # Vérification qu'un tiers inter-site a bien un site renseigné                
Gosub CTL_BPR2 : # Vérification du site lié au client ou au fournisseur
Gosub INI_BPD  : # Contrôle et initialisation du site de réception
Gosub INI_BPS  : # Contrôle et Init du tiers facturant et tiers payé

Return

#---------------------------------------------------------------------------------#
# Vérification des tiers inter-site                                               #
#---------------------------------------------------------------------------------#
#     Vérification qu'un tiers inter-site a bien un site renseigné                #
#---------------------------------------------------------------------------------#
$CTL_BPR1

Call ECR_TIME(mess(540,197,1)) From DOSSUB 

For [BPR]BPR2 Where BETFCY=2 & FCY=""
    Call ECR_TRACE(mess(541,197,1)-[F:BPR]BPRNUM,1) From GESECRAN    
Next

Return


#---------------------------------------------------------------------------------#
# Vérification des tiers inter-site                                               #
#---------------------------------------------------------------------------------#
#     Si client      Vérification que le site est site d'achat ou site financier  #
#     Si fournisseur Vérification que le site est site de vente ou site financier #
#---------------------------------------------------------------------------------#
$CTL_BPR2

Call ECR_TIME(mess(542,197,1)) From DOSSUB

For [BPR]BPR2 Where BETFCY=2 & FCY<>""
   If [F:FCY]FCY<>[F:BPR]FCY
       Read [FCY]FCY0=[F:BPR]FCY
       If fstat Raz [F:FCY] Endif
   Endif
   #  Le site rattaché à un client doit être site d'achat ou site financier
   If [F:BPR]BPCFLG=2 & [F:FCY]PURFLG<>2 & [F:FCY]FINFLG<>2
       Call ECR_TRACE(mess(99,197,1)-":"-[F:BPR]BPRNUM-mess(498,197,1)-":"-[F:BPR]FCY-mess(402,199,1),1) From GESECRAN
   Endif
   #  Le site rattaché à un fournisseur doit être site de vente ou site financier
   If [F:BPR]BPSFLG=2 & [F:FCY]SALFLG<>2 & [F:FCY]FINFLG<>2
       Call ECR_TRACE(mess(24,121,1)-":"-[F:BPR]BPRNUM-mess(498,197,1)-":"-[F:BPR]FCY-mess(407,199,1),1) From GESECRAN
   Endif
Next

Return

#-------------------------------------------------------------------------------#
# Contrôle des clients livrés inter-site                                        #
#-------------------------------------------------------------------------------#
#     Contrôle et Init du site de réception                                     #
#-------------------------------------------------------------------------------#
$INI_BPD

Call ECR_TIME(mess(543,197,1)) From DOSSUB

Local Integer COMPTEUR, STOP, NBENR 
Local Char    CLE1 (20)
Local Char    CRITERE (90)

$BOUCLE_BPR1
If STOP=1
  STOP=0 : CRITERE='BETFCY=2 & FCY<>"" & BPCFLG=2 & BPRNUM>"'+CLE1+'"'
Else
  CRITERE='BETFCY=2 & FCY<>""'
Endif

Raz COMPTEUR
Trbegin [BPR]
For [BPR]BPR2 Where evalue(CRITERE)
   If [F:FCY]FCY<>[F:BPR]FCY
       Read [FCY]FCY0=[F:BPR]FCY
       If fstat Raz [F:FCY] Endif
   Endif
   If [F:FCY]WRHFLG=2
#      Si le site lié au client est dépôt, il sert à initialiser le site de réception du client livré
#      --> Ssi Le site n'est pas référencé dans un autre client livré
#      -->  et Le client n'a qu'un seul client livré
       Columns [BPD] (BPCNUM, BPAADD, RCPFCY) 
       Filter [BPD] Where [BPD]RCPFCY=[F:BPR]FCY
       Read [BPD]BPD0 First
       Columns [BPD]
       If fstat 
#          Le site n'est pas référencé sur un autre client livré
           Filter [BPD] Where [BPD]BPCNUM = [F:BPR]BPRNUM
           If [M]SIMU=1 
               Readlock [BPD]BPD0 First
           Else
               Read [BPD]BPD0 First
           Endif
           If !fstat 
           Endif        
           If !fstat & [F:BPD]RCPFCY=""
               Look [BPD]BPD0 Next
               If fstat & [M]SIMU=1
#                  Le client n'a qu'un seul client livré, on est pas en simulation : maj du client livré
                   [F:BPD]RCPFCY=[F:BPR]FCY
                   NBENR+=1
                   Rewrite [BPD]
                   If fstat
                       Call ECR_TRACE("File BPDLVCUST, Error ="-num$(fstat),1) From GESECRAN
                   Else
                       Call ECR_TRACE(mess(42,191,1)-[F:BPD]BPCNUM-[F:BPD]BPAADD-":"-mess(545,197,1)-":"-[F:BPD]RCPFCY,0) From GESECRAN
                       COMPTEUR += 1
                       If COMPTEUR > 499
                           CLE1=[F:BPR]BPRNUM
                           STOP=1 : Filter [BPD] : Break
                       Endif
                   Endif
               Elsif fstat & [M]SIMU=2
#                  Le client n'a qu'un seul client livré, on est en simulation : on trace
                   Call ECR_TRACE(mess(42,191,1)-":"-[F:BPD]BPCNUM-[F:BPD]BPAADD-":"-mess(545,197,1)-":"-[F:BPR]FCY,0) From GESECRAN
               Else
#                  Le client a plusieurs clients livrés : On initisalise rien 
                   If [M]SIMU=1 Unlock [BPD] Endif
                   Gosub CTR_BPD : # On vérifie les clients livrés
               Endif
           Endif
       Else
           Gosub CTR_BPD : # On vérifie les clients livrés
       Endif
       Filter [BPD]
   Else
       Gosub CTR_BPD : # On vérifie les clients livrés
   Endif
Next
Commit
If STOP : Goto BOUCLE_BPR1 : Endif

If [M]SIMU=1 Call ECR_TRACE("Processed records number :"-num$(NBENR),0) From GESECRAN : Endif

Return

#-------------------------------------------------------------------------------#
# Liste les clients livrés sans site de réception                               #
#-------------------------------------------------------------------------------#
$CTR_BPD

For [BPD] Where BPCNUM=[F:BPR]BPRNUM & RCPFCY=""
    Call ECR_TRACE(mess(42,191,1)-[F:BPD]BPCNUM-[F:BPD]BPAADD-":"-mess(544,197,1),1) From GESECRAN    
Next

Return

#-------------------------------------------------------------------------------#
# Contrôle des fournisseurs inter-site                                          #
#-------------------------------------------------------------------------------#
#     Contrôle et Init du tiers facturant et tiers payé                         #
#-------------------------------------------------------------------------------#
$INI_BPS

Call ECR_TIME(mess(546,197,1)) From DOSSUB

Local Integer COMPTEUR, STOP, NBENR, MAJENR
Local Char    CLE1 (20)
Local Char    CRITERE (90)

$BOUCLE_BPR2

If STOP=1
  STOP=0 : CRITERE='BETFCY=2 & FCY<>"" & BPSFLG=2 & BPRNUM>"'+CLE1+'"'
Else
  CRITERE='BETFCY=2 & FCY<>"" & BPSFLG=2'
Endif

Raz COMPTEUR
Trbegin [BPR]
For [BPR]BPR0 Where evalue(CRITERE)
   Read [BPS]BPS0=[F:BPR]BPRNUM
   If fstat Raz [F:BPS] Endif
   Read [FCY]FCY0=[F:BPR]FCY
   If fstat Raz [F:FCY] Endif
   MAJENR=0
   If [F:FCY]FINFLG=2
        # Le site est financier       : le tiers payé et tiers facturant doivent être le fsseur lui-même
        If [F:BPS]BPRPAY<>"" & [F:BPS]BPRPAY<>[F:BPS]BPSNUM 
            # le tiers payé n'est pas le fsseur 
            If [M]SIMU=1 : # On est pas en simulation : Modif du tiers payé
                [F:BPS]BPRPAY=[F:BPS]BPSNUM : MAJENR=1 
            Endif
            Call ECR_TRACE(mess(530,197,1)-":"-[F:BPS]BPSNUM-":"-mess(549,197,1)-":"-[F:BPS]BPRPAY,0) From GESECRAN
        Endif
        If [F:BPS]BPSINV<>"" & [F:BPS]BPSINV<>[F:BPS]BPSNUM 
            # le tiers facturant n'est pas le fsseur 
            If [M]SIMU=1 : # On est pas en simulation : Modif du tiers facturant
                [F:BPS]BPSINV=[F:BPS]BPSNUM : MAJENR=1 
            Endif
            Call ECR_TRACE(mess(530,197,1)-":"-[F:BPS]BPSNUM-":"-mess(550,197,1)-":"-[F:BPS]BPSINV,0) From GESECRAN
        Endif
   Else
        # Le site n'est pas financier : le tiers payé et facturant doit être le fsseur lié au site financier
        # Recherche du tiers lié au site financier
        Read [BPR1] BPR2(2)=2;[F:FCY]FINRSPFCY
        If !fstat
            Read [BPS1]BPS0=[F:BPR1]BPRNUM
            If !fstat & [F:BPS1]ENAFLG=2 
                # Le fsseur lié au site financier existe
                If [F:BPS]BPRPAY="" | [F:BPS]BPRPAY<>[F:BPR1]BPRNUM
                    # le tiers payé n'est pas le fsseur lié au site financier
                    If [M]SIMU=1 : # On est pas en simulation : Modif du tiers payé
                        [F:BPS]BPRPAY=[F:BPR1]BPRNUM : MAJENR=1
                    Endif
                    Call ECR_TRACE(mess(530,197,1)-":"-[F:BPS]BPSNUM-":"-mess(549,197,1)-":"-[F:BPR1]BPRNUM,0) From GESECRAN
                Endif
                If [F:BPS]BPSINV="" | [F:BPS]BPSINV<>[F:BPR1]BPRNUM
                    # le tiers facturant n'est pas le fsseur lié au site financier
                    If [F:BPS1]PLISTC=[F:BPS]PLISTC
                        If [M]SIMU=1 : # On est pas en simulation : Modif du tiers facturant
                            [F:BPS]BPSINV=[F:BPR1]BPRNUM : MAJENR=1
                        Endif
                        Call ECR_TRACE(mess(530,197,1)-":"-[F:BPS]BPSNUM-":"-mess(550,197,1)-":"-[F:BPR1]BPRNUM,0) From GESECRAN
                    Else 
                        # Les structures tarifs ne sont pas identiques
                        Call ECR_TRACE(mess(530,197,1)-":"-[F:BPS]BPSNUM-":"-mess(550,197,1)-":"-[F:BPR1]BPRNUM-":"-mess(141,199,1),1) From GESECRAN
                    Endif
                Endif                
            Else
                # Il n'y a aucun fsseur lié au site financier
                Call ECR_TRACE(mess(530,197,1)-":"-[F:BPS]BPSNUM-":"-mess(462,199,1),1) From GESECRAN
            Endif
        Else
            # Il n'y a aucun fsseur lié au site financier
            Call ECR_TRACE(mess(530,197,1)-":"-[F:BPS]BPSNUM-":"-mess(462,199,1),1) From GESECRAN
        Endif
   Endif
   If MAJENR=1 & [M]SIMU=1
       NBENR+=1
       Rewrite [BPS]
       If fstat
          Call ECR_TRACE("File BPSUPPLIER, Error ="-num$(fstat),1) From GESECRAN
       Else
#          Call ECR_TRACE("BPSUPPLIER="-[F:BPS]BPSNUM,0) From GESECRAN
          COMPTEUR += 1
          If COMPTEUR > 499
             CLE1=[F:BPS]BPSNUM
             STOP=1 : Break
          Endif
       Endif
   Endif
Next
Commit
If STOP : Goto BOUCLE_BPR2 : Endif

If [M]SIMU=1 Call ECR_TRACE("Processed records number :"-num$(NBENR),0) From GESECRAN : Endif

Return


#########################################################################
$TERMINE
Close Local File [BPR]
Close Local File [FCY]
Close Local File [BPD]
Close Local File [BPS]
Close Local File [BPR1]
Close Local File [BPS1]

If !GSERVEUR Call FERME_TRACE From LECFIC : TRA=1 : Endif

Return

#########################################################################
$OUVRE
Local Char    TIT(50), CRITERE(80), CRIT(160)
Local Char    CLE1, CLE2, WSENS(1)
Local Integer I, J, K, OK, STOP

Local File BPARTNER   [BPR]
Local File FACILITY   [FCY]
Local File BPDLVCUST  [BPD]
Local File BPSUPPLIER [BPS]
Local File BPARTNER   [BPR1]
Local File BPSUPPLIER [BPS1]

TIT=mess(539,197,1)

Return

#########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

