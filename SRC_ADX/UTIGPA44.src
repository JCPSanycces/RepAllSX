#<AdxTL>@(#)3.0.0.0 $Revision$  Deletion parameters MAUTFB/MAUTRB
##########################################################################
# UTIGPA44   Deletion parameters MAUTFB/MAUTRB                           #
##########################################################################
# Bug 84721 par GH le 02/04/2014
##########################################################################
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA44: Deletion parameters MAUTFB/MAUTRB") From LECFIC
Call EXE_UTIGPA44(DOSSIER)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##########################################################################
Subprog EXE_UTIGPA44(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIGPA44: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Suppression des fenêtres  -----#

Call ECR_TRACE("Deletion windows DAUTOFB DAUTFMIB",0) From GESECRAN
Call TR_DELWIN("DAUTOFB",DOSSIER) From MSKDIV
Call TR_DELWIN("DAUTFMIB",DOSSIER) From MSKDIV

#----- Suppression des écrans     -----#

Call ECR_TRACE("Deletion screens MAUTFMIB MAUTRELB",0) From GESECRAN
Call TR_DELMSK("MAUTFMIB",DOSSIER) From MSKDIV
Call TR_DELMSK("MAUTRELB",DOSSIER) From MSKDIV

#----- Suppression des paramètres -----#

If filinfo(filpath("FIL","ADOPAR","fde",DOSSIER),0)>0 &
&  filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
   Call ECR_TRACE("Deletion parameters MAUTFB MAUTRB",0) From GESECRAN
   Local File =DOSSIER+".ADOPAR"  [ADP]
   Local File =DOSSIER+".ADOVAL"  [ADW]
   Trbegin [ADP]
     Delete [ADP] Where find(PARAM,'MAUTFB','MAUTRB')<>0
     Delete [ADW] Where find(PARAM,'MAUTFB','MAUTRB')<>0
   Commit
Endif

#----- Suppression des variables globales -----#

If filinfo(filpath("FIL","AGLOBVAR","fde",DOSSIER),0)>0
   Call ECR_TRACE("Deletion global variables GMAUTFB GMAUTRB",0) From GESECRAN
   Local Char TRTW(GLONADC) (2)
   Local File =DOSSIER+".AGLOBVAR"  [AGB]
   Trbegin [AGB]
     Read [AGB]AGB0 = "GMAUTFB"
     If !fstat
        TRTW(0) = [F:AGB]TRTSTD
        Delete [AGB] Where CODVAR = "GMAUTFB"
     Endif
     Read [AGB]AGB0 = "GMAUTRB"
     If !fstat
        TRTW(1) = [F:AGB]TRTSTD
        Delete [AGB] Where CODVAR = "GMAUTRB"
     Endif
   Commit
   If TRTW(0)<>""
      Call VALIDATION(DOSSIER,TRTW(0),1) From SUBAGB
   Endif
   If TRTW(1)<>"" & TRTW(1)<>TRTW(0)
      Call VALIDATION(DOSSIER,TRTW(1),1) From SUBAGB
   Endif
Endif

Call ECR_TRACE("UTIGPA44 : Procces End on",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA44(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3
     End 
Endif

Call EXE_UTIGPA44(APPLI)
End
