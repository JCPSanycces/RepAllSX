#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CEW1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:06"
A_USER  = "DOC"
A_STAMP = "20181109230306"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBDEST"
  If [M]NBDEST=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CEW1 [CEW1]
Gosub HORODAT
Local Inpbox "CEW1" From GFONCTION At A_STAMP With A_WINDPREV Mask [CEW1] As [SIM_]
Grizo [CEW1]10
Grizo [CEW1]20
Grizo [CEW1]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CEW1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=79 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=79 : Y1(1)=3 : Y2(1)=9
X1(2)=1 : X2(2)=79 : Y1(2)=10 : Y2(2)=28
Return

$ON_CODWRK
Onevent CONTROL Call C_CODWRK(zc) From W1CEW1
Onevent BEFORE_INPUT Call AS_CODWRK(zc) From W1CEW1
Onevent AFTER_CHANGE Gosub AMM_CODWRK From W1CEW1
Return

Subprog AS_CODWRK(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(13050,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODWRK(zc) From W1CEW1
Onkey   2 Titled GBOUTS Call S_CODWRK(zc) From W1CEW1
Onkey 144 Titled GBOUTP Call P_CODWRK(zc) From W1CEW1
Onkey 146 Titled GBOUTA Call SA_CODWRK(zc) From W1CEW1
Gosub _AFF
End

Subprog C_CODWRK(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODWRK" : GZNUM = 27065 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("AWA","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODWRK" : GZNUM = 27065 : Endif
Endif
Gosub _AFF
End

$AMM_CODWRK
Call AM_CODWRK(zc)
If !mkstat & GOBJET
 zoncou = "CODWRK" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODWRK(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODWRK)")>indice
 [M]CODWRK(indice) = VALEUR
 Affzo ZCODWRK(indice)
Endif
Gosub _AFF
End

Subprog S_CODWRK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "AWA"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CODWRK(VALEUR)
Variable Char    VALEUR()
Call OBJET("AWA",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CODWRK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "AWA"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODWRK(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("AWA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODWRK
Onevent BEFORE_AREA Gosub AV_ZCODWRK From W1CEW1
Return

$AV_ZCODWRK
Call LECTEXTRA(zc,"AWRKPAR","INTIT",num$([M]CODWRK(indice)),"") From ATEXTRA
Gosub _AFF
Return

