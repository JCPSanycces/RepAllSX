$ON_SUIVI
Onevent CONTROL Call C_SUIVI(zc) From W1CEW1
Onevent INIT_AREA Call D_SUIVI(zc) From W1CEW1
Onevent BEFORE_INPUT Call AS_SUIVI(zc) From W1CEW1
Return

Subprog D_SUIVI(VALEUR)
Variable Integer VALEUR
If varinit([M]SUIVI,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SUIVI(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_SUIVI(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_SUIVI(VALEUR) From SUBCEW
If mkstat : GERR = 1 : GZONE = "SUIVI" : GZNUM = 6386 : Endif
Gosub _AFF
End

$ON_NATURE
Onevent INIT_AREA Call D_NATURE(zc) From W1CEW1
Onevent CONTROL Call C_NATURE(zc) From W1CEW1
Onevent BEFORE_INPUT Call AS_NATURE(zc) From W1CEW1
Return

Subprog D_NATURE(VALEUR)
Variable Char    VALEUR()
If varinit([M]NATURE,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"50","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_NATURE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"50") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NATURE(zc) From W1CEW1
Onkey   2 Titled GBOUTS Call S_NATURE(zc) From W1CEW1
Onkey 144 Titled GBOUTP Call P_NATURE(zc) From W1CEW1
Onkey 146 Titled GBOUTA Call SA_NATURE(zc) From W1CEW1
Gosub _AFF
End

Subprog C_NATURE(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"50","") From SUBADI
If mkstat : GERR = 1 : GZONE = "NATURE" : GZNUM = 42016 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"50",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "NATURE" : GZNUM = 42016 : Endif
Endif
Gosub _AFF
End

Subprog S_NATURE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "50"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_NATURE(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"50") From GOBJET
Gosub _AFF
End

Subprog SA_NATURE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "50"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NATURE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "50"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_OPTDEL
Onevent INIT_AREA Call D_OPTDEL(zc) From W1CEW1
Onevent BEFORE_INPUT Call AS_OPTDEL(zc) From W1CEW1
Return

Subprog D_OPTDEL(VALEUR)
Variable Integer VALEUR
