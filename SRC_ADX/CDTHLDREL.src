#<AdxTL>@(#)2.0.0.0 $Revision$
####################################################################################
# Program Name: CDTHLDREL
####################################################################################

$ACTION

Case ACTION
  When "OUVRE"         : Gosub OUVRE
Endcase

Return

####################################################################################
$OUVRE

If !clalev([F:SOH])  : Local File SORDER     [F:SOH] : Endif

Read [SOH]SOH0=PARAM(1)
If fstat
  Call ERREUR(mess(8,492,1) - PARAM(1)) From GESECRAN
  FIN = 1 : Return
Endif

Return

####################################################################################
Subprog HLDREL_BTN(SOHNUM)
Value    Char    SOHNUM
Local Integer ERR, OK
Local Char MESSAGE(100)

Read [F:SOH]SOH0=SOHNUM  #Make sure we are reading the latest for the record
If find([M:SOH1]CDTSTA,2,3,4)      #If already on Credit Hold, simply release with pop-up.
 MESSAGE = '"'+mess([M:SOH1]CDTSTA,419,1)+'"'
 If [F:SOH]CDTSTAP>1 & [M:SOH1]CDTSTA<>[F:SOH]CDTSTAP
   MESSAGE = MESSAGE-mess(57,147,1)-'"'+mess([F:SOH]CDTSTAP,419,1)+'"'
 Endif
 Call OUINON(mess(19,492,1)-MESSAGE+"?",OK) From GESECRAN
 If OK<>2
   End
 Endif

  TMP_ADXLOG = adxlog
  If !TMP_ADXLOG : Trbegin [SOH] : Endif
  [F:SOH]CDTSTAP = [F:SOH]CDTSTA
  [F:SOH]CDTSTA  = 1
  [M:SOH1]CDTSTA=1
  [F:SOH]UNL     = 2
  [M:SOH2]UNL=2
  Rewrite [F:SOH]
  If fstat
    If !TMP_ADXLOG : Rollback : Endif
    ERR = 1
    ERRMSG = mess(20,492,1) # Unable to update credit status
    Call ERREUR(ERRMSG) From GESECRAN
    End
  Else
    If !TMP_ADXLOG : Commit : Endif
    [M:SOH1]ANOUPDTICK=1
    Affzo [M:SOH1]CDTSTA
    Grizo [M:SOH1]CDTBTN
    Call SDCDTSTA("",[M]BPCORD,[M]CHGTYP,0,[M:SOH1]CUR,[M]ORDDAT,2,1,[M]CDTSTA,[M]OST,[M]OSTAUZ) From TRTVENCDT
    Gosub MANHLD_LIENS From MANHLDLIB
    # 40076 - JOBRO - Entry point - after credit hold released
    GPOINT="AFTCDTREL" : Gosub ENTREE From EXEFNC
  Endif
Endif

End

