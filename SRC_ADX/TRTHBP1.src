#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# Historique prospect/client                                        Module CRM          13 novembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
#PARAM(1) = Type tiers   (BPP ou BPC)
#PARAM(2) = Code tiers
Global Integer GIHBP1BD

  #Si aucun tiers n'est mentionné, on ne fait rien.
  If PARAM(2) = "" Then
    FIN = 1
    GIHBP1BD = 0
    Return
  Endif

Global Char GSZBPRTYP(GLONDCO)
Global Char GSZBPRNUM(GLONBPN)
Global Char GSZHBPREC(GLONVCR)
Global Char GSZHBPTYP(GLONVCR)
Global Integer GIDONE
Global Integer GIFILLDONE
Global Integer GIFILLTODO
Global Integer GHBP1SQH
Global Integer GHBP1SOH
Global Integer GHBP1SDH
Global Integer GHBP1SIV
Global Integer GHBP1BPRSIH

  If PARAM(1) = "BPP" Then
    GSZBPRTYP = mess(240,196,1) #Prospect
  Elsif PARAM(1) = "BPC" Then
    GSZBPRTYP = mess(12,159,1) #Client
  Elsif PARAM(1) = "BPR" Then
    GSZBPRTYP = mess(3,14,1) #Tiers
  Endif
  GSZBPRNUM = PARAM(2)
  GIDONE = 1
  GSZHBPREC = ""
  GSZHBPTYP = ""
  GIFILLDONE = 0
  GIFILLTODO = 0
  If !clalev([F:HST]) : Local File HISTOCRM [HST] : Endif
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:OPPCRM]) : Local File OPPORCRM [OPPCRM] : Endif      # Issue X3-101789 - 2018-07-23 by FGR
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:HIM]) : Local File HISTOOMM [HIM] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:SQH]) : Local File SQUOTE [SQH] : Endif
  If !clalev([F:SOH]) : Local File SORDER [SOH] : Endif
  If !clalev([F:TSO]) : Local File TABSOHTYP [TSO] : Endif
  If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif
  If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
  If !clalev([F:SIV]) : Local File SINVOICEV [SIV] : Endif
  If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  # ---------------------------------------------
  Call RAZ_HST  # FGR 20/11/2013 : X3SUIVI94518
  # ---------------------------------------------
  #Obtient les paramètres personnels de l'utilisateur
  Read [DVA]DVA0="HBP";GUSER
  If fstat Then
    #L'utilisateur ne s'est pas défini de paramètres perso
    #On charge donc les valeurs relatives au comportement par défaut
    GHBP1SQH = 1
    GHBP1SOH = 1
    GHBP1SDH = 0
    GHBP1SIV = 0
    GHBP1BPRSIH = 0
  Else
    If [F:DVA]INTX(0) = 1 Then
      GHBP1SQH = 0
    Else
      GHBP1SQH = 1
    Endif
    If [F:DVA]INTX(1) = 1 Then
      GHBP1SOH = 0
    Else
      GHBP1SOH = 1
    Endif
    If [F:DVA]INTX(2) = 2 Then
      GHBP1SDH = 1
    Else
      GHBP1SDH = 0
    Endif
    If [F:DVA]INTX(3) = 2 Then
      GHBP1SIV = 1
    Else
      GHBP1SIV = 0
    Endif
    If [F:DVA]INTX(4) = 2 Then
      GHBP1BPRSIH = 1
    Else
      GHBP1BPRSIH = 0
    Endif
  Endif
Return

##########################################################################################################
$PREMIER
Local Integer IPBL

  IPBL = 0
  Call RAZHBP
  If GIDONE Then
    Call LOADHBP(0, 0, IPBL)
  Else
    Call LOADHBP(0, 1, IPBL)
  Endif
Return

##########################################################################################################
$PRECEDENT
Return

##########################################################################################################
$SUIVANT
Return

##########################################################################################################
$DERNIER
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If GIDONE Then
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 1
  Else
    ETABOU(GSPE2) = 1
    ETABOU(GSPE3) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer IPBL

  IPBL = 0
  Raz [M:HBP1]
  Read [BPR]BPR0=GSZBPRNUM
  If fstat Then
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  [M:HBP1]BPRNUM = GSZBPRNUM
  [M:HBP1]BPR = [F:BPR]BPRNAM
  [M:HBP1]TTR = mess(349,196,1) #Liste des actions effectuées.
  Call FILLHST(0, IPBL)
  Call FILLHST(1, IPBL)
  Call LOADHBP(0, 0, IPBL)
  GSZHBPREC = [M:HBP1]NUM(0)
  GSZHBPTYP = [M:HBP1]TYP(0)
  GIHBP1BD = 1
  Call TEMPOFF From GESECRAN
  Affzo [M:HBP1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIHBP1BD Then
    Call RAZ_HST
    Raz [M:HBP1]
    Kill GSZBPRTYP
    Kill GSZBPRNUM
    Kill GIDONE
    Kill GSZHBPREC
    Kill GSZHBPTYP
    Kill GIFILLDONE
    Kill GIFILLTODO
    Kill GHBP1SQH
    Kill GHBP1SOH
    Kill GHBP1SDH
    Kill GHBP1SIV
    Kill GHBP1BPRSIH
  Endif
  Kill GIHBP1BD
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "B"
      Gosub ONDONE
    When "C"
      Gosub ONTODO
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Chargement de l'historique
#########################################################
Subprog FILLHST(ITODO, ITRB)
Value Integer ITODO
Variable Integer ITRB

Local Integer ICLSNUM
Local Integer ICOUNTLNS

  ICLSNUM = 0
  ICOUNTLNS = 0
  #---------------------------------------------------#
  #Alimentation des Affaires
  #---------------------------------------------------#
  # Issue X3-101789 - 2018-07-23 by FGR : BEGIN
  #If ITODO Then
  #  Filter [OPP] Where [F:OPP]OPPCMP = GSZBPRNUM and [F:OPP]OPPCLO <> 2 Order By [F:OPP]OPPCDA Asc
  #Else
  #  Filter [OPP] Where [F:OPP]OPPCMP = GSZBPRNUM and [F:OPP]OPPCLO = 2 Order By [F:OPP]OPPREACDA Desc
  #Endif
  Link [OPP] With [OPPCRM]OPPCRM0=[F:OPP]OPPNUM
&              As [LOPP]
  If ITODO Then
    Filter [LOPP] Where [F:OPP]OPPCMP = GSZBPRNUM and [F:OPP]OPPCLO <> 2 Order By [F:OPPCRM]OPPCDA Asc
  Else
    Filter [LOPP] Where [F:OPP]OPPCMP = GSZBPRNUM and [F:OPP]OPPCLO = 2 Order By [F:OPPCRM]OPPREACDA Desc
  Endif
  # Issue X3-101789 - 2018-07-23 by FGR : END
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  #For [OPP] Hint Key OPP4   # Issue X3-101789 - 2018-07-23 by FGR
  For [LOPP] Hint Key OPP4   # Issue X3-101789 - 2018-07-23 by FGR
    If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:OPP]OPPNUM
    If ITODO Then
      [F:HST]RECDAT = [F:OPPCRM]OPPCDA           # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      [F:HST]RECHOU = [F:OPP]CREHOU
    Else
      [F:HST]RECDAT = [F:OPPCRM]OPPREACDA        # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
      [F:HST]RECHOU = "0000"
    Endif
    [F:HST]RECTYP = "OPP"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [LOPP]                                  # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des rendez-vous
  #---------------------------------------------------#
  If ITODO Then
    Filter [BAP] Where [F:BAP]APTCMP = GSZBPRNUM and [F:BAP]APTDON <> 2 Order By [F:BAP]APTDATX Asc
  Else
    Filter [BAP] Where [F:BAP]APTCMP = GSZBPRNUM and [F:BAP]APTDON = 2 Order By [F:BAP]APTDATX Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [BAP] Hint Key APP5
    If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:BAP]APTNUM
    [F:HST]RECDAT = [F:BAP]APTDATX
    [F:HST]RECHOU = [F:BAP]APTHOU
    [F:HST]RECTYP = "BAP"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [BAP]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des appels
  #---------------------------------------------------#
  If ITODO Then
    Filter [CLL] Where [F:CLL]CLLCMP = GSZBPRNUM and [F:CLL]CLLDON <> 2 Order By [F:CLL]CLLDATX Asc
  Else
    Filter [CLL] Where [F:CLL]CLLCMP = GSZBPRNUM and [F:CLL]CLLDON = 2 Order By [F:CLL]CLLDATX Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [CLL] Hint Key CLL2
    If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:CLL]CLLNUM
    [F:HST]RECDAT = [F:CLL]CLLDATX
    [F:HST]RECHOU = [F:CLL]CLLHOU
    [F:HST]RECTYP = "CLL"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [CLL]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des tâches
  #---------------------------------------------------#
  If ITODO Then
    Filter [TSK] Where [F:TSK]TSKCMP = GSZBPRNUM and [F:TSK]TSKDON <> 2 Order By [F:TSK]TSKDAT Asc
  Else
    Filter [TSK] Where [F:TSK]TSKCMP = GSZBPRNUM and [F:TSK]TSKDON = 2 Order By [F:TSK]TSKDAT Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [TSK] Hint Key TSK2
    If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:TSK]TSKNUM
    [F:HST]RECDAT = [F:TSK]TSKDAT
    [F:HST]RECHOU = [F:TSK]CREHOU
    [F:HST]RECTYP = "TSK"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [TSK]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des Demandes de services
  #---------------------------------------------------#
  If ITODO Then
    Filter [SRE] Where [F:SRE]SREBPC = GSZBPRNUM and [F:SRE]SREASS <> 5 Order By [F:SRE]CREDAT Asc; [F:SRE]CREHOU Asc
  Else
    Filter [SRE] Where [F:SRE]SREBPC = GSZBPRNUM and [F:SRE]SREASS = 5 Order By [F:SRE]CREDAT Desc; [F:SRE]CREHOU Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [SRE] Hint Key SRE3
    If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:SRE]SRENUM
    [F:HST]RECDAT = [F:SRE]CREDAT
    [F:HST]RECHOU = [F:SRE]CREHOU
    [F:HST]RECTYP = "SRE"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [SRE]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des interventions
  #---------------------------------------------------#
  If ITODO Then
    Filter [ITN] Where [F:ITN]BPC = GSZBPRNUM and [F:ITN]DON <> 2 Order By [F:ITN]DAT Asc
  Else
    Filter [ITN] Where [F:ITN]BPC = GSZBPRNUM and [F:ITN]DON = 2 Order By [F:ITN]DAT Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICOUNTLNS = 0
  For [ITN] Hint Key ITN2
    If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
      Break
    Endif
    [F:HST]CLSNUM = 0
    If ITODO Then
      [F:HST]DON = 1
    Else
      [F:HST]DON = 2
    Endif
    [F:HST]SSS = GIDENT
    [F:HST]RECNUM = [F:ITN]NUM
    [F:HST]RECDAT = [F:ITN]DAT
    [F:HST]RECHOU = [F:ITN]HOU
    [F:HST]RECTYP = "ITN"
    Write [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICOUNTLNS += 1
  Next
  Filter [ITN]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  #---------------------------------------------------#
  #Alimentation des historique mailing
  #---------------------------------------------------#
  If !ITODO Then
    Filter [HIM] Where [F:HIM]BPRNUM = GSZBPRNUM Order By [F:HIM]DATSND Desc
    Call DEBTRANS From GLOCK
    Trbegin [HST]
    ICOUNTLNS = 0
    For [HIM] Hint Key HIM4
      If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
        Break
      Endif
      [F:HST]CLSNUM = 0
      [F:HST]DON = 2
      [F:HST]SSS = GIDENT
      [F:HST]RECNUM = [F:HIM]HIMNUM
      [F:HST]RECDAT = [F:HIM]DATSND
      [F:HST]RECHOU = "0000"
      [F:HST]RECTYP = "OMM"
      Write [HST]
      If fstat Then
        ITRB = 1
        Break
      Endif
      ICOUNTLNS += 1
    Next
    Filter [HIM]
    #Si une écriture a échoué. On arrête tout.
    If ITRB Then
      GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
      GERR = 1
      Rollback
      End
    Else
      Commit
    Endif
  Endif
  #---------------------------------------------------#
  #Alimentation des devis
  #---------------------------------------------------#
  If GHBP1SQH Then
    If !ITODO Then
      Filter [SQH] Where [F:SQH]BPCORD = GSZBPRNUM Order By [F:SQH]QUODAT Desc
      Call DEBTRANS From GLOCK
      Trbegin [HST]
      ICOUNTLNS = 0
      For [SQH] Hint Key SQH1
        If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
          Break
        Endif
        [F:HST]CLSNUM = 0
        [F:HST]DON = 2
        [F:HST]SSS = GIDENT
        [F:HST]RECNUM = [F:SQH]SQHNUM
        [F:HST]RECDAT = [F:SQH]QUODAT
        [F:HST]RECHOU = "0000"
        [F:HST]RECTYP = "SQH"
        Write [HST]
        If fstat Then
          ITRB = 1
          Break
        Endif
        ICOUNTLNS += 1
      Next
      Filter [SQH]
      #Si une écriture a échoué. On arrête tout.
      If ITRB Then
        GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
        GERR = 1
        Rollback
        End
      Else
        Commit
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #Alimentation des commandes
  #---------------------------------------------------#
  If GHBP1SOH Then
    If !ITODO Then
      Filter [SOH] Where [F:SOH]BPCORD = GSZBPRNUM Order By [F:SOH]ORDDAT Desc
      Call DEBTRANS From GLOCK
      Trbegin [HST]
      ICOUNTLNS = 0
      For [SOH] Hint Key SOH1
        If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
          Break
        Endif
        [F:HST]CLSNUM = 0
        [F:HST]DON = 2
        [F:HST]SSS = GIDENT
        [F:HST]RECNUM = [F:SOH]SOHNUM
        [F:HST]RECDAT = [F:SOH]ORDDAT
        [F:HST]RECHOU = "0000"
        [F:HST]RECTYP = "SOH"
        Write [HST]
        If fstat Then
          ITRB = 1
          Break
        Endif
        ICOUNTLNS += 1
      Next
      Filter [SOH]
      #Si une écriture a échoué. On arrête tout.
      If ITRB Then
        GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
        GERR = 1
        Rollback
        End
      Else
        Commit
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #Alimentation des livraisons
  #---------------------------------------------------#
  If GHBP1SDH Then
    If !ITODO Then
      Filter [SDH] Where [F:SDH]BPCORD = GSZBPRNUM Order By [F:SDH]DLVDAT Desc
      Call DEBTRANS From GLOCK
      Trbegin [HST]
      ICOUNTLNS = 0
      For [SDH] Hint Key SDH1
        If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
          Break
        Endif
        [F:HST]CLSNUM = 0
        [F:HST]DON = 2
        [F:HST]SSS = GIDENT
        [F:HST]RECNUM = [F:SDH]SDHNUM
        [F:HST]RECDAT = [F:SDH]DLVDAT
        [F:HST]RECHOU = "0000"
        [F:HST]RECTYP = "SDH"
        Write [HST]
        If fstat Then
          ITRB = 1
          Break
        Endif
        ICOUNTLNS += 1
      Next
      Filter [SDH]
      #Si une écriture a échoué. On arrête tout.
      If ITRB Then
        GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
        GERR = 1
        Rollback
        End
      Else
        Commit
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #Alimentation des factures
  #---------------------------------------------------#
  If GHBP1SIV Then
    If !ITODO Then
      Filter [SIV] Where [F:SIV]BPCINV = GSZBPRNUM Order By [F:SIV]INVDAT Desc
      Call DEBTRANS From GLOCK
      Trbegin [HST]
      ICOUNTLNS = 0
      For [SIV]
        If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
          Break
        Endif
        [F:HST]CLSNUM = 0
        [F:HST]DON = 2
        [F:HST]SSS = GIDENT
        [F:HST]RECNUM = [F:SIV]NUM
        [F:HST]RECDAT = [F:SIV]INVDAT
        [F:HST]RECHOU = "0000"
        [F:HST]RECTYP = "SIH"
        Write [HST]
        If fstat Then
          ITRB = 1
          Break
        Endif
        ICOUNTLNS += 1
      Next
      Filter [SIV]
      #Si une écriture a échoué. On arrête tout.
      If ITRB Then
        GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
        GERR = 1
        Rollback
        End
      Else
        Commit
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  #Alimentation des factures tiers clients
  #---------------------------------------------------#
  If GHBP1BPRSIH Then
    If !ITODO Then
      Filter [SIH] Where [F:SIH]BPR = GSZBPRNUM Order By [F:SIH]BPRDAT Desc
      Call DEBTRANS From GLOCK
      Trbegin [HST]
      ICOUNTLNS = 0
      For [SIH] Hint Key SIH1
        Read [SIV]SIV0=[F:SIH]NUM
        If fstat Then
          If ICOUNTLNS >= dim([M:HBP1]TYPCLA) Then
            Break
          Endif
          [F:HST]CLSNUM = 0
          [F:HST]DON = 2
          [F:HST]SSS = GIDENT
          [F:HST]RECNUM = [F:SIH]NUM
          [F:HST]RECDAT = [F:SIH]BPRDAT
          [F:HST]RECHOU = "0000"
          [F:HST]RECTYP = "BIC"
          Write [HST]
          If fstat Then
            ITRB = 1
            Break
          Endif
          ICOUNTLNS += 1
        Endif
      Next
      Filter [SIH]
      #Si une écriture a échoué. On arrête tout.
      If ITRB Then
        GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
        GERR = 1
        Rollback
        End
      Else
        Commit
      Endif
    Endif
  Endif
  #---------------------------------------------------#
  Gosub PE_HBP1FILLHST From TRTCRMPE
  #---------------------------------------------------#
  # Affecte les numéros d'ordre
  #---------------------------------------------------#
  If ITODO Then
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON <> 2 Order By [F:HST]RECDAT Asc; [F:HST]RECHOU Asc
  Else
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON = 2  Order By [F:HST]RECDAT Desc; [F:HST]RECHOU Desc
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  ICLSNUM = 0
  For [HST] Hint Key HST2
    [F:HST]CLSNUM = ICLSNUM
    Rewrite [HST]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICLSNUM += 1
  Next
  Filter [HST]
  #Si une réécriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(348,196,1) #Erreur lors du chargement de l'historique.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
  If ITODO Then
    GIFILLTODO = 1
  Else
    GIFILLDONE = 1
  Endif
End

##########################################################################################################
Subprog LOADHBP(ICLS, ITODO, ITRB)
Value Integer ICLS
Value Integer ITODO
Variable Integer ITRB

Local Integer I
Local Char AXX_TSODES(80)
Local Char AXX_TSVDES(80)

  I = 0
  If ITODO Then
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON <> 2 and [F:HST]CLSNUM >= ICLS Order By [F:HST]CLSNUM Asc
  Else
    Filter [HST] Where [F:HST]SSS = GIDENT and [F:HST]DON = 2 and [F:HST]CLSNUM >= ICLS Order By [F:HST]CLSNUM Asc
  Endif
  For [HST] Hint Key HST2
    If I >= dim([M:HBP1]TYPCLA) Then
      Break
    Endif
    [M:HBP1]NUM(I) = [F:HST]RECNUM
    [M:HBP1]CLSNUM(I) = [F:HST]CLSNUM
    [M:HBP1]TYP(I) = [F:HST]RECTYP
    If [M:HBP1]TYP(I) = "OPP" Then
      [M:HBP1]TYPCLA(I) = mess(1,967,1)
      Read [OPP]OPP0=[M:HBP1]NUM(I)
      Read [OPPCRM]OPPCRM0 =[M:HBP1]NUM(I)       # Issue X3-101789 - 2018-07-23 by FGR
      If !fstat Then
        If [F:OPP]OPPTYP = "" Then
          [M:HBP1]CATCLA(I) = ""
        Else
          Call GET_LIB(434, [F:OPP]OPPTYP, [M:HBP1]CATCLA(I)) From CRM_UTIL
        Endif
        If ITODO Then
          [M:HBP1]DAT(I) = [F:OPPCRM]OPPCDA      # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
          [M:HBP1]HOU(I) = "0000"
        Else
          [M:HBP1]DAT(I) = [F:OPPCRM]OPPREACDA   # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]
          [M:HBP1]HOU(I) = "0000"
        Endif
        Read [REP]REP0=[F:OPP]OPPREP
        If !fstat Then
          [M:HBP1]REP(I) = [F:REP]REPNAM
        Endif
        Read [AIN]AIN0=[F:OPP]OPPMCN
        If !fstat Then
          Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
        Endif
        [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
      Endif
    Elsif [M:HBP1]TYP(I) = "BAP" Then
      [M:HBP1]TYPCLA(I) = mess(2,967,1)
      Read [BAP]APP0=[M:HBP1]NUM(I)
      If !fstat Then
        If [F:BAP]APTTYP = "" Then
          [M:HBP1]CATCLA(I) = ""
        Else
          Call GET_LIB(433, [F:BAP]APTTYP, [M:HBP1]CATCLA(I)) From CRM_UTIL
        Endif
        [M:HBP1]DAT(I) = [F:BAP]APTDATX
        [M:HBP1]HOU(I) = [F:BAP]APTHOU
        Read [REP]REP0=[F:BAP]APTREPNUM(0)
        If !fstat Then
          [M:HBP1]REP(I) = [F:REP]REPNAM
        Endif
        Read [AIN]AIN0=[F:BAP]APTCCNNUM(0)
        If !fstat Then
          Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
        Endif
        Read [OPP]OPP0=[F:BAP]APTPJT
        If !fstat Then
          [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
         Endif
       Endif
    Elsif [M:HBP1]TYP(I) = "CLL" Then
      Read [CLL]CLL0=[M:HBP1]NUM(I)
      If !fstat Then
        If [F:CLL]CLLCAT = "" Then
          [M:HBP1]CATCLA(I) = ""
        Else
          Call GET_LIB(432, [F:CLL]CLLCAT, [M:HBP1]CATCLA(I)) From CRM_UTIL
        Endif
        If [F:CLL]CLLTYP = 1 Then
          [M:HBP1]TYPCLA(I) = mess(1,956,1)
        Endif
        If [F:CLL]CLLTYP = 2 Then
          [M:HBP1]TYPCLA(I) = mess(2,956,1)
        Endif
        [M:HBP1]DAT(I) = [F:CLL]CLLDATX
        [M:HBP1]HOU(I) = [F:CLL]CLLHOU
        Read [REP]REP0=[F:CLL]CLLREP
        If !fstat Then
          [M:HBP1]REP(I) = [F:REP]REPNAM
        Endif
        Read [AIN]AIN0=[F:CLL]CLLCCN
        If !fstat Then
          Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
        Endif
        Read [OPP]OPP0=[F:CLL]CLLOPP
        If !fstat Then
          [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
        Endif
      Endif
    Elsif [M:HBP1]TYP(I) = "TSK" Then
      [M:HBP1]TYPCLA(I) = mess(4,967,1)
      Read [TSK]TSK0=[M:HBP1]NUM(I)
      If !fstat Then
        If [F:TSK]TSKTYP = "" Then
          [M:HBP1]CATCLA(I) = ""
        Else
          Call GET_LIB(431, [F:TSK]TSKTYP, [M:HBP1]CATCLA(I)) From CRM_UTIL
        Endif
        [M:HBP1]DAT(I) = [F:TSK]TSKDAT
        [M:HBP1]HOU(I) = "0000"
        Read [REP]REP0=[F:TSK]TSKREP
        If !fstat Then
          [M:HBP1]REP(I) = [F:REP]REPNAM
        Endif
        Read [AIN]AIN0=[F:TSK]TSKCCN
        If !fstat Then
          Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
        Endif
        Read [OPP]OPP0=[F:TSK]TSKPJT
        If !fstat Then
          [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
        Endif
      Endif
    Elsif [M:HBP1]TYP(I) = "SRE" Then
      [M:HBP1]TYPCLA(I) = mess(5,967,1)
      Read [SRE]SRE0=[M:HBP1]NUM(I)
      If !fstat Then
        If [F:SRE]SREGRALEV = "" Then
          [M:HBP1]CATCLA(I) = ""
        Else
          Call GET_LIB(428, [F:SRE]SREGRALEV, [M:HBP1]CATCLA(I)) From CRM_UTIL
        Endif
        [M:HBP1]DAT(I) = [F:SRE]CREDAT
        [M:HBP1]HOU(I) = [F:SRE]CREHOU
        If ITODO Then
          If [F:SRE]SREASS = 2 Then
            Read [AUS]CODUSR=[F:SRE]SREDET
            If !fstat Then
              [M:HBP1]REP(I) = [F:AUS]NOMUSR
            Endif
          Endif
          If [F:SRE]SREASS = 1 Then
            [M:HBP1]REP(I) = mess(1,975,1) #Dispatching
          Elsif [F:SRE]SREASS = 3 Then
            [M:HBP1]REP(I) = mess(3,975,1) #Queue
          Elsif [F:SRE]SREASS = 4 Then
            [M:HBP1]REP(I) = mess(352,196,1) #Service commercial
          Endif
        Else
          If [F:SRE]REP <> "" Then
            Read [AUS]CODUSR=[F:SRE]REP
            If !fstat Then
              [M:HBP1]REP(I) = [F:AUS]NOMUSR
            Endif
          Endif
        Endif
        Read [AIN]AIN0=[F:SRE]SRECCN
        If !fstat Then
          Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
        Endif
        If [F:SRE]SREPJT <> "" Then
          Read [OPP]OPP0=[F:SRE]SREPJT
          If !fstat Then
            #If [F:OPP]OPPDES <> "" Then                                                 # Issue X3-101789 - 2018-07-23 by FGR
              [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
            #Endif                                                                       # Issue X3-101789 - 2018-07-23 by FGR
          Endif
        Endif
      Endif
    Elsif [M:HBP1]TYP(I) = "ITN" Then
      [M:HBP1]TYPCLA(I) = mess(6,967,1)
      Read [ITN]ITN0=[M:HBP1]NUM(I)
      If !fstat Then
        If [F:ITN]TYP = "" Then
          [M:HBP1]CATCLA(I) = ""
        Else
          Call GET_LIB(407, [F:ITN]TYP, [M:HBP1]CATCLA(I)) From CRM_UTIL
        Endif
        [M:HBP1]DAT(I) = [F:ITN]DAT
        [M:HBP1]HOU(I) = [F:ITN]HOU
        Read [AUS]CODUSR=[F:ITN]REP
        If !fstat Then
          [M:HBP1]REP(I) = [F:AUS]NOMUSR
        Endif
        Read [AIN]AIN0=[F:ITN]CCN
        If !fstat Then
          Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
        Endif
        Read [SRE]SRE0=[F:ITN]SRVDEMNUM
        If [F:SRE]SREPJT <> "" Then
          Read [OPP]OPP0=[F:SRE]SREPJT
          If !fstat Then
            #If [F:OPP]OPPDES <> "" Then                                                 # Issue X3-101789 - 2018-07-23 by FGR
              [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
            #Endif                                                                       # Issue X3-101789 - 2018-07-23 by FGR
          Endif
        Endif
      Endif
    Elsif [M:HBP1]TYP(I) = "OMM" Then
      [M:HBP1]TYPCLA(I) = mess(7,967,1)
      Read [HIM]HIM0=[M:HBP1]NUM(I)
      If !fstat Then
        Read [OMM]OMM0=[F:HIM]OMMNUM
        If !fstat Then
          [M:HBP1]CATCLA(I) = mess([F:OMM]SHIMOD,963,1)
        Endif
        [M:HBP1]NUM(I) = [F:HIM]OMMNUM
        [M:HBP1]DAT(I) = [F:HIM]DATSND
        [M:HBP1]HOU(I) = "0000"
        [M:HBP1]REP(I) = ""
        If [F:HIM]CCNNUM <> "" Then
          Read [AIN]AIN0=[F:HIM]CCNNUM
          If !fstat Then
            Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
          Endif
        Else
          [M:HBP1]CCN(I) = ""
        Endif
        [M:HBP1]OPP(I) = ""
      Endif
    Endif
    If GHBP1SQH Then
      If [M:HBP1]TYP(I) = "SQH" Then
        [M:HBP1]CATCLA(I) = ""
        [M:HBP1]TYPCLA(I) = mess(121,198,1)
        [M:HBP1]DAT(I) = [F:HST]RECDAT
        [M:HBP1]HOU(I) = "0000"
        Read [SQH]SQH0=[M:HBP1]NUM(I)
        If fstat Then
          [M:HBP1]REP(I) = ""
        Else
          If dim([F:SQH]REP) > 0 Then
            If [F:SQH]REP = "" Then
              [M:HBP1]REP(I) = ""
            Else
              Read [REP]REP0=[F:SQH]REP
              If fstat Then
                [M:HBP1]REP(I) = ""
              Else
                [M:HBP1]REP(I) = [F:REP]REPNAM
              Endif
            Endif
          Else
            [M:HBP1]REP(I) = ""
          Endif
        Endif
        If [F:SQH]CNCNAM <> "" Then
          Read [AIN]AIN0=[F:SQH]CNCNAM
          If !fstat Then
            Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
          Endif
        Else
          [M:HBP1]CCN(I) = ""
        Endif
        If [F:SQH]PJT <> "" Then
          Read [OPP]OPP0=[F:SQH]PJT
          If !fstat Then
            #If [F:OPP]OPPDES <> "" Then                                                 # Issue X3-101789 - 2018-07-23 by FGR
              [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
            #Endif                                                                       # Issue X3-101789 - 2018-07-23 by FGR
          Endif
        Endif
      Endif
    Endif
    If GHBP1SOH Then
      If [M:HBP1]TYP(I) = "SOH" Then
        [M:HBP1]CATCLA(I) = ""
        [M:HBP1]TYPCLA(I) = mess(48,198,1)
        [M:HBP1]DAT(I) = [F:HST]RECDAT
        [M:HBP1]HOU(I) = "0000"
        Read [SOH]SOH0=[M:HBP1]NUM(I)
        If fstat Then
          [M:HBP1]REP(I) = ""
        Else
          If [F:SOH]SOHTYP <> "" Then
            Read [TSO]TSO0=[F:SOH]SOHTYP
            If !fstat Then
              Call GET_ATEXTRA("TABSOHTYP","DESAXX",GLANGUE,AXX_TSODES) From TRTX3TEX
              If AXX_TSODES = "" Then
                [M:HBP1]CATCLA(I) = mess([F:TSO]SOHCAT,412,1)
              Else
                [M:HBP1]CATCLA(I) = AXX_TSODES
              Endif
            Endif
          Endif
          If dim([F:SOH]REP) > 0 Then
            If [F:SOH]REP = "" Then
              [M:HBP1]REP(I) = ""
            Else
              Read [REP]REP0=[F:SOH]REP
              If fstat Then
                [M:HBP1]REP(I) = ""
              Else
                [M:HBP1]REP(I) = [F:REP]REPNAM
              Endif
            Endif
          Else
            [M:HBP1]REP(I) = ""
          Endif
          If [F:SOH]SOHCAT = 4 Then
            [M:HBP1]TYP(I) = "SOR"
          Endif
        Endif
        If [F:SOH]CNTNAM <> "" Then
          Read [AIN]AIN0=[F:SOH]CNTNAM
          If !fstat Then
            Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
          Endif
        Else
          [M:HBP1]CCN(I) = ""
        Endif
        If [F:SOH]PJT <> "" Then
          Read [OPP]OPP0=[F:SOH]PJT
          If !fstat Then
            #If [F:OPP]OPPDES <> "" Then                                                 # Issue X3-101789 - 2018-07-23 by FGR
              [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
            #Endif                                                                       # Issue X3-101789 - 2018-07-23 by FGR
          Endif
        Endif
      Endif
    Endif
    If GHBP1SDH Then
      If [M:HBP1]TYP(I) = "SDH" Then
        [M:HBP1]CATCLA(I) = ""
        [M:HBP1]TYPCLA(I) = mess(90,198,1)
        [M:HBP1]DAT(I) = [F:HST]RECDAT
        Read [SDH]SDH0=[M:HBP1]NUM(I)
        If fstat Then
          [M:HBP1]REP(I) = ""
          [M:HBP1]HOU(I) = "0000"
        Else
          If [F:SDH]DLVHOU = "" Then
            [M:HBP1]HOU(I) = "0000"
          Else
            [M:HBP1]HOU(I) = [F:SDH]DLVHOU
          Endif
          If dim([F:SDH]REP) > 0 Then
            If [F:SDH]REP = "" Then
              [M:HBP1]REP(I) = ""
            Else
              Read [REP]REP0=[F:SDH]REP
              If fstat Then
                [M:HBP1]REP(I) = ""
              Else
                [M:HBP1]REP(I) = [F:REP]REPNAM
              Endif
            Endif
          Else
            [M:HBP1]REP(I) = ""
          Endif
        Endif
        [M:HBP1]CCN(I) = ""
        If [F:SDH]CNDNAM <> "" Then
          Read [AIN]AIN0=[F:SDH]CNDNAM
          If !fstat Then
            Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
          Endif
        Else
          [M:HBP1]CCN(I) = ""
        Endif
        If [F:SDH]PJT <> "" Then
          Read [OPP]OPP0=[F:SDH]PJT
          If !fstat Then
            #If [F:OPP]OPPDES <> "" Then                                                 # Issue X3-101789 - 2018-07-23 by FGR
              [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
            #Endif                                                                       # Issue X3-101789 - 2018-07-23 by FGR
          Endif
        Endif
      Endif
    Endif
    If GHBP1SIV Then
      If [M:HBP1]TYP(I) = "SIH" Then
        [M:HBP1]CATCLA(I) = ""
        [M:HBP1]TYPCLA(I) = mess(369,198,1)
        [M:HBP1]DAT(I) = [F:HST]RECDAT
        [M:HBP1]HOU(I) = "0000"
        Read [SIV]SIV0=[M:HBP1]NUM(I)
        If fstat Then
          [M:HBP1]REP(I) = ""
        Else
          Read [SIH]SIH0=[M:HBP1]NUM(I)
          If !fstat Then
            If [F:SIH]SIVTYP = "" Then
              [M:HBP1]CATCLA(I) = mess([F:SIH]INVTYP,645,1)
            Else
              Read [TSV]TSV0=[F:SIH]SIVTYP
              If fstat Then
                [M:HBP1]CATCLA(I) = mess([F:SIH]INVTYP,645,1)
              Else
                Call GET_ATEXTRA("TABSIVTYP","DESAXX",GLANGUE,AXX_TSVDES) From TRTX3TEX
                If AXX_TSVDES = "" Then
                  [M:HBP1]CATCLA(I) = mess([F:SIH]INVTYP,645,1)
                Else
                  [M:HBP1]CATCLA(I) = AXX_TSVDES
                Endif
              Endif
            Endif
          Endif
          If dim([F:SIV]REP) > 0 Then
            If [F:SIV]REP = "" Then
              [M:HBP1]REP(I) = ""
            Else
              Read [REP]REP0=[F:SIV]REP
              If fstat Then
                [M:HBP1]REP(I) = ""
              Else
                [M:HBP1]REP(I) = [F:REP]REPNAM
              Endif
            Endif
          Else
            [M:HBP1]REP(I) = ""
          Endif
        Endif
        If [F:SIV]CNDNAM <> "" Then
          Read [AIN]AIN0=[F:SIV]CNINAM
          If !fstat Then
            Call BUILDFULNAM("AIN", [M:HBP1]CCN(I)) From CRMUTIL140
          Endif
        Else
          [M:HBP1]CCN(I) = ""
        Endif
        If [F:SIV]PJT <> "" Then
          Read [OPP]OPP0=[F:SIV]PJT
          If !fstat Then
            #If [F:OPP]OPPDES <> "" Then                                                 # Issue X3-101789 - 2018-07-23 by FGR
              [M:HBP1]OPP(I) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, [F:OPP]OPPNUM) # Issue X3-101789 - 2018-07-23 by FGR : not [F:OPP]OPPDES
            #Endif                                                                       # Issue X3-101789 - 2018-07-23 by FGR
          Endif
        Endif
      Endif
    Endif
    If GHBP1BPRSIH Then
      If [M:HBP1]TYP(I) = "BIC" Then
        [M:HBP1]CATCLA(I) = ""
        [M:HBP1]TYPCLA(I) = mess(43,109,1)
        [M:HBP1]DAT(I) = [F:HST]RECDAT
        [M:HBP1]HOU(I) = "0000"
        [M:HBP1]REP(I) = ""
        [M:HBP1]CCN(I) = ""
        [M:HBP1]OPP(I) = ""
        Read [SIV]SIV0=[M:HBP1]NUM(I)
        If fstat Then
          Read [SIH]SIH0=[M:HBP1]NUM(I)
          If !fstat Then
            If [F:SIH]SIVTYP = "" Then
              [M:HBP1]CATCLA(I) = mess([F:SIH]INVTYP,645,1)
            Else
              Read [TSV]TSV0=[F:SIH]SIVTYP
              If fstat Then
                [M:HBP1]CATCLA(I) = mess([F:SIH]INVTYP,645,1)
              Else
                Call GET_ATEXTRA("TABSIVTYP","DESAXX",GLANGUE,AXX_TSVDES) From TRTX3TEX
                If AXX_TSVDES = "" Then
                  [M:HBP1]CATCLA(I) = mess([F:SIH]INVTYP,645,1)
                Else
                  [M:HBP1]CATCLA(I) = AXX_TSVDES
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    #---------------------------------------------------#
    Gosub PE_HBP1LOADHBP From TRTCRMPE
    #---------------------------------------------------#
    I += 1
  Next
  Filter [HST]
  [M:HBP1]NBHBP = I
  Affzo [M:HBP1]1-99
End

##########################################################################################################
$ONDONE
Local Integer IPBL

  IPBL = 0
  Call RAZHBP
  [M:HBP1]TTR = mess(349,196,1) #Liste des actions effectuées.
  Call LOADHBP(0, 0, IPBL)
  GIDONE = 1
  GSZHBPREC = [M:HBP1]NUM(0)
  GSZHBPTYP = [M:HBP1]TYP(0)
Return

##########################################################################################################
$ONTODO
Local Integer IPBL

  IPBL = 0
  Call RAZHBP
  [M:HBP1]TTR = mess(350,196,1) #Liste des actions à effectuer.
  Call LOADHBP(0, 1, IPBL)
  GIDONE = 0
  GSZHBPREC = [M:HBP1]NUM(0)
  GSZHBPTYP = [M:HBP1]TYP(0)
Return

##########################################################################################################
# Vide la table de gestion associées à l'historique
#########################################################
Subprog RAZ_HST
  Call DEBTRANS From GLOCK
  Trbegin [HST]
  Delete [HST] Where [F:HST]SSS = GIDENT
  If fstat Then
    Rollback
    End
  Endif
  Commit
End

##########################################################################################################
# Vide le tableau d'historique
#########################################################
Subprog RAZHBP
  Raz [M:HBP1]NBHBP
  Raz [M:HBP1]TYPCLA
  Raz [M:HBP1]CATCLA
  Raz [M:HBP1]DAT
  Raz [M:HBP1]HOU
  Raz [M:HBP1]REP
  Raz [M:HBP1]CCN
  Raz [M:HBP1]OPP
  Raz [M:HBP1]TYP
  Raz [M:HBP1]NUM
  Raz [M:HBP1]CLSNUM
End

