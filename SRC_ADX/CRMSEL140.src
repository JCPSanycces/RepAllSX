$SEL_SELITN8CPN
Local Integer Z
Local Integer ITERZ
Local Char SZCPNNAM(40)
Local Char SZSRENUM
Local Integer ITERCHECK
Local Integer IALREADYLOAD

  #Sélection d'un composant concerné
  Z = 0
  ITERZ = 0
  SZCPNNAM = ""
  IALREADYLOAD = 0
  If PARAM(1) = "" Then
    # Si aucune demande de service n'est renseignée
    Return
  Elsif PARAM(2) = "" Then
    # Si aucun parc n'est renseignée
    Return
  Endif
  If !clalev([F:SRN]) : Local File SREMACCPN [SRN] : Endif
  Filter [SRN] Where [F:SRN]SRENUM = PARAM(1) and [F:SRN]MACNUM = PARAM(2)
  For [SRN]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    IALREADYLOAD = 0
    For ITERCHECK = 1 To dim(TEX)-1
      If TEX(ITERCHECK) <> "" Then
        If [F:SRN]CPNITM <> "" Then
          If [F:SRN]CPNITM = TEX(ITERCHECK) Then
            IALREADYLOAD = 1
            Break
          Endif
        Endif
      Endif
    Next
    If IALREADYLOAD = 0 Then
      TEX(Z) = [F:SRN]CPNITM
      #Call LECTEXTRA(SZCPNNAM, "ITMMASTER", "DES1AXX", [F:SRN]CPNITM, "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:SRN]CPNITM,SZCPNNAM, "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      TEXTE(Z) = [F:SRN]CPNITM - "-" - SZCPNNAM
    Endif
  Next
  Filter [SRN]
  NBTEX = Z
  #Sélection du composant concerné
  TIT = mess(199,182,1)
Return

