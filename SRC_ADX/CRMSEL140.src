#####################################################################
$SEL_SELMCC2FIE
Local Integer Z
Local Integer ICANDISP
Local Char SZFIENAM

  #Sélection d'un critère d'agrégation pour la consultation du parc
  Z = 0
  ICANDISP = 0
  SZFIENAM = ""
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Filter [ATZ] Where [F:ATZ]CODFIC = "MACHINES"
  For [ATZ]CODZONE
    #Traitement des exceptions
    Call CHECKFIEMAC([F:ATZ]CODZONE, ICANDISP) From SUBMACB
    If ICANDISP Then
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Call TEXTE([F:ATZ]NOCOURT, SZFIENAM) From OBJDIV
      TEX(Z) = [F:ATZ]CODZONE
      TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZFIENAM
    Endif
  Next
  Filter [ATZ]
  NBTEX = Z
  TIT = mess(37,177,1) #Sélection d'un critère d'agrégation
Return

