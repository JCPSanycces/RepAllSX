#####################################################################
$SEL_SELMGG4QUR
Local Char CODFIC(GLONATB)

  #Sélection d'un ciblage en exécution pour serveur batch
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "MKGQUR"
  Default File [MQR]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = "[F:MQR]QURNUM >= VALEUR"
  START = "QURNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "QURNUM"
  Call TEXTE(19061, TIT(0)) From OBJDIV      #Ciblages
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "QURNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "QURNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "QURCAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CREUSR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CREDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELMGG4QUR
  #Sélection d'un ciblage en exécution pour serveur batch
Return
#####################################################################

#####################################################################
$SEL_SELMAI3QUR
Local Char CODFIC(GLONATB)

  #Sélection d'un ciblage en exécution pour serveur batch
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "MKGQUR"
  Default File [MQR]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  Case PARAM(1)
    When "1"
      CRITERE = '[F:MQR]QURNUM >= VALEUR and ([F:MQR]TGR = "CONTACTCRM" or [F:MQR]TGR = "LEAD")'
    When Default
      CRITERE = '[F:MQR]QURNUM >= VALEUR and [F:MQR]TGR = "CONTACTCRM"'
  Endcase
  START = "QURNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "QURNUM"
  Call TEXTE(19061, TIT(0)) From OBJDIV      #Ciblages
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "QURNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "QURNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "QURCAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "TGR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CREUSR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CREDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELMAI3QUR
  #Sélection d'un ciblage en exécution pour serveur batch
Return
#####################################################################

#####################################################################
$SEL_SELLKP7QUR
Local Char CODFIC(GLONATB)

  #Sélection d'un ciblage en recherche de demande de service sur description
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "MKGQUR"
  Default File [MQR]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = '[F:MQR]TGR = "SERREQUEST" and [F:MQR]QURNUM >= VALEUR'
  START = "QURNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "QURNUM"
  Call TEXTE(19061, TIT(0)) From OBJDIV      #Ciblages
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "QURNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "QURNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "QURCAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CREUSR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CREDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

