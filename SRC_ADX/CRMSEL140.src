##########################################################################################################################
#                                                                                                                        #
#                                                SELECTIONS TABLE                                                        #
#                                                                                                                        #
##########################################################################################################################
#####################################################################
$SEL_SELCUS0TAB
Local Char CODFIC(GLONATB)

  #Sélection des tables de l'agenda X3
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  CODFIC = "ATABLE"
  Default File [ATB]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = '[F:ATB]CODFIC = "BAPPOINT"'
  START = "CODFIC" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "CODFIC"
  TIT(0) = mess(207,196,1)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CODFIC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "INTIT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELCUS0TAB
  #Sélection des tables de l'agenda X3
Return
#####################################################################

#####################################################################
$SEL_SELSRE9ITM
Local Char CODFIC(GLONATB)

  #Sélection des pièces, main d'oeuvres et frais de mission
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If clalev ([F:AXX])=0 : Local File ATEXTRA  [AXX]  : Endif  # FGR 07/06/2009 : X3SUIVI56380
  CODFIC = "ITMMASTER"
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  Link [ITM] With [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"" As [NEW] # FGR 07/06/2009 : X3SUIVI56380
  #Default File [ITM]
  Default File [NEW]                                                  # FGR 07/06/2009 : X3SUIVI56380
  Case PARAM(1)
    When "1"
      CRITERE = '1=1'
      TIT(0) = ""
    When "2"
      CRITERE = '[F:ITM]HDKITMTYP = 2'
      TIT(0) = mess(194,182,1)
    When "3"
      CRITERE = '[F:ITM]HDKITMTYP = 3'
      TIT(0) = mess(195,182,1)
    When "4"
      CRITERE = '[F:ITM]HDKITMTYP = 4'
      TIT(0) = mess(196,182,1)
    When "5"
      CRITERE = '[F:ITM]HDKITMTYP = 5 or [F:ITM]TPLCONSRV<>""'
      TIT(0) = mess(197,182,1)
  Endcase
  START = "ITMREF" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "ITMREF"
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "ITMREF" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  #NBCOL += 1 : COL(NBCOL) = "ITMDES1" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  #NBCOL += 1 : COL(NBCOL) = "DES1AXX" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV : COL(NBCOL)="[F:AXX]TEXTE"  # FGR 07/06/2009 : X3SUIVI56380
  NBCOL += 1 : COL(NBCOL) = "DES1AXX" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV : COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"  # FGR 29/09/2009 : X3SUIVI57887
  COLTYP(NBCOL) = 30  # FGR 01/02/2010  X3SUIVI62036
Return

#####################################################################
$VERF_SELSRE9ITM
  #Sélection des pièces, main d'oeuvres et frais de mission
Return
#####################################################################

#####################################################################
$SEL_SELCONGITM
Local Char CODFIC(GLONATB)

  #Sélection des articles
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If clalev ([F:AXX])=0 : Local File ATEXTRA  [AXX]  : Endif  # FGR 07/06/2009 : X3SUIVI56380
  CODFIC = "ITMMASTER"
  Link [ITM] With [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"" As [NEW] # FGR 07/06/2009 : X3SUIVI56380
  #Default File [ITM]
  Default File [NEW]                                                  # FGR 07/06/2009 : X3SUIVI56380
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = 'ITMREF >= VALEUR'
  #Articles
  Call TEXTE(2061, TIT(0)) From OBJDIV
  START = "ITMREF" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "ITMREF"
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "ITMREF" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  #NBCOL += 1 : COL(NBCOL) = "ITMDES1" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  #NBCOL += 1 : COL(NBCOL) = "DES1AXX" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV : COL(NBCOL)="[F:AXX]TEXTE"  # FGR 07/06/2009 : X3SUIVI56380
  NBCOL += 1 : COL(NBCOL) = "DES1AXX" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV : COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"  # FGR 29/09/2009 : X3SUIVI57887
  COLTYP(NBCOL) = 30  # FGR 01/02/2010  X3SUIVI62036
Return

#####################################################################
$VERF_SELCONGITM
  #Sélection des articles
Return
#####################################################################

#####################################################################
$SEL_SELSRE1SET
Local Char CODFIC(GLONATB)

  #Sélection d'un modèle de demande de service de type prestation
  If !clalev([F:SET]) : Local File SRETEMPL [SET] : Endif
  CODFIC = "SRETEMPL"
  Default File [SET]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = '[F:SET]TPLSVC = 2'
  START = "SETNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "SETNUM"
  #Modèles de demandes de service
  TIT(0) = mess(246,182,1)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "SETNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "TPLNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "TTR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELSRE1SET
  #Sélection d'un modèle de demande de service de type prestation
Return
#####################################################################

#####################################################################
$SEL_SELSRE8OPP
Local Char CODFIC(GLONATB)

  #Sélection d'une affaire sur une demande de service ou un contrat de service
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  CODFIC = "OPPOR"
  Default File [OPP]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  If PARAM(1) = "" Then
    CRITERE = '1=1'
  Else
    CRITERE = '[F:OPP]OPPCMP = PARAM(1)'
  Endif
  START = "OPPNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "OPPNUM"
  TIT(0) = mess(262,182,1) #Sélection d'une affaire
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "OPPNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "OPPDES" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "OPPSTE" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "OPPAMT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CUR"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "OPPCDA" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELSRE8OPP
  #Sélection d'une affaire sur une demande de service
Return
#####################################################################

#####################################################################
$SEL_SELSRE7CON
Local Char CODFIC(GLONATB)

  #Sélection d'un contrat de service sur une demande de service.
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "CONTSERV"
  Default File [CON]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = "[F:CON]CONBPC = [M:SRE0]SREBPC and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2"
  START = "CONNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "CONNUM"
  TIT(0) = mess(293,196,1) #Contrats de service
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CONNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CONTYPCLA" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CONNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CONAMT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CUR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CONENDDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELSRE7CON
  #Sélection d'un contrat de service sur une demande de service
Return
#####################################################################

#####################################################################
$SEL_SELSRE7SOH
Local Char CODFIC(GLONATB)

  #Sélection d'une commande sur une demande de service
  If !clalev([F:SOH]) : Local File SORDER [SOH] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "SORDER"
  Default File [SOH]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = "[F:SOH]BPCORD = [M:SRE0]SREBPC"
  START = "SOHNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "SOHNUM"
  TIT(0) = mess(75,191,1) #Sélection commandes
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "SOHNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "ORDDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "ORDNOT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CUR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "REP" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "PJT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELSRE7SOH
  #Sélection d'une commande sur une demande de service
Return
#####################################################################

#####################################################################
$SEL_SELSRE7COT
Local Char CODFIC(GLONATB)

  #Sélection d'un contrat de prêt sur une demande de service.
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "CONTTEMPL"
  Default File [COT]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = '[F:COT]CONNUM <> ""'
  START = "CONNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "CONNUM"
  TIT(0) = mess(328,196,1) #Modèles de contrat de service
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CONNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "CONTYPCLA" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "TPLNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "EVRPBL" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "EVRMAC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELSRE7COT
  #Sélection d'un contrat de prêt sur une demande de service
Return
