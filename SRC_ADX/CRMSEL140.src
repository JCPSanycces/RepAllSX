#<AdxTL>@(#)6.0.0.0 $Revision$
#############################################################################################
#  Traitement générale pour la gestion des fenêtres de sélection en version 140    Module CRM
#  Créé le 13 novembre 2002
#############################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "VERF_TABLE"  : Gosub VERF_TABLE
    When "SEL_LISTE"   : Gosub SEL_LISTE
    When "VERF_LISTE"  : Gosub VERF_LISTE
    When Default
  Endcase
Return

#############################################################################################
$SEL_TABLE
  Case TABLE
    When "SELCUS0TAB"     : Gosub SEL_SELCUS0TAB
    When "SELSRE9ITM"     : Gosub SEL_SELSRE9ITM
    When "SELCONGITM"     : Gosub SEL_SELCONGITM
    When "SELSRE1SET"     : Gosub SEL_SELSRE1SET
    When "SELSRE8OPP"     : Gosub SEL_SELSRE8OPP
    When "SELSRE7CON"     : Gosub SEL_SELSRE7CON
    When "SELSRE7SOH"     : Gosub SEL_SELSRE7SOH
    When "SELSRE7COT"     : Gosub SEL_SELSRE7COT
    When "SELMGG4QUR"     : Gosub SEL_SELMGG4QUR
    When "SELMAI3QUR"     : Gosub SEL_SELMAI3QUR
    When "SELLKP7QUR"     : Gosub SEL_SELLKP7QUR
    When "SELRQW1SER"     : Gosub SEL_SELRQW1SER
    When "SELINVSSRE"     : Gosub SEL_SELINVSSRE
    When Default
  Endcase
Return

#############################################################################################
$VERF_TABLE
  Case TABLE
    When "SELCUS0TAB"     : Gosub VERF_SELCUS0TAB
    When "SELSRE9ITM"     : Gosub VERF_SELSRE9ITM
    When "SELCONGITM"     : Gosub VERF_SELCONGITM
    When "SELSRE1SET"     : Gosub VERF_SELSRE1SET
    When "SELSRE8OPP"     : Gosub VERF_SELSRE8OPP
    When "SELSRE7CON"     : Gosub VERF_SELSRE7CON
    When "SELSRE7SOH"     : Gosub VERF_SELSRE7SOH
    When "SELSRE7COT"     : Gosub VERF_SELSRE7COT
    When "SELMGG4QUR"     : Gosub VERF_SELMGG4QUR
    When "SELMAI3QUR"     : Gosub VERF_SELMAI3QUR
    When "SELLKP7QUR"     : Gosub VERF_SELLKP7QUR
    When "SELRQW1SER"     : Gosub VERF_SELRQW1SER
    When "SELINVSSRE"     : Gosub VERF_SELINVSSRE
    When Default
  Endcase
Return

#############################################################################################
$SEL_LISTE
