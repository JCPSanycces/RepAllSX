#####################################################################
$SEL_SELSRE9AUS
Local Char SZHDKREP
Local Integer IHDKREP
Local Integer Z

  #Sélection d'un intervenant sur une consommation
  Z = 0
  SZHDKREP = ""
  IHDKREP = 0
  #PARAM(1) = Type de sélection
  If PARAM(1) = "" Then
    Return
  Endif
  If PARAM(1) = "1" Then
    If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
    Filter [AUS] Where [F:AUS]USR > VALEUR
    For [AUS]
      SZHDKREP = ""
      IHDKREP = 1
      Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS]USR, "") From SUBAUS
      If SZHDKREP = "" Then
        IHDKREP = 1
      Else
        IHDKREP = val(SZHDKREP)
      Endif
      If IHDKREP = 2 Then
        Z += 1
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        TEX(Z) = [F:AUS]USR
        TEXTE(Z) = [F:AUS]USR - "-" - [F:AUS]NOMUSR
      Endif
    Next
    Filter [AUS]
  Elsif PARAM(1) = "2" Then
    If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
    Filter [BPR] Where [F:BPR]BPRNUM > VALEUR and [F:BPR]PRVFLG = 2
    For [BPR]
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      TEX(Z) = [F:BPR]BPRNUM
      TEXTE(Z) = [F:BPR]BPRNUM - "-" - [F:BPR]BPRNAM
    Next
    Filter [BPR]
  Endif
  NBTEX = Z
  #Sélection de l'intervenant
  TIT = mess(122,177,1)
Return

#####################################################################
$VERF_SELSRE9AUS
  #Sélection d'un intervenant sur une consommation
Return

#####################################################################
$SEL_SELPHX6QST
Local Integer Z

  #Liste des questions d'un script
  Z = 0
  If !clalev([F:SCQ]) : Local File SCPQST [SCQ] : Endif
  Filter [SCQ] Where [F:SCQ]SCPNUM = PARAM(1) Order By [F:SCQ]QSTNUM Asc
  For [SCQ]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:SCQ]QSTNUM
    If [F:SCQ]STRQST = 2 Then
      TEXTE(Z) = [F:SCQ]QSTNUM - "- START -" - [F:SCQ]QST
    Else
      TEXTE(Z) = [F:SCQ]QSTNUM - "-" - [F:SCQ]QST
    Endif
  Next
  Filter [SCQ]
  NBTEX = Z
  #Liste des questions
  Call TEXTE(25825, TIT) From OBJDIV
Return

#####################################################################
$VERF_SELPHX6QST
  #Liste des questions d'un script
Return
