$SEL_SELCMS6AOB
Local Integer Z
Local Char SZTEXTE

  #Sélection d'un browser sur transaction de demande de service
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  Z = 0
  SZTEXTE = ""
  Filter [AOB] Where [F:AOB]NOMFIC = "SERREQUEST" and [F:AOB]TYPGES = 4 and [F:AOB]ABREV <> "SRE" and [F:AOB]ABREV <> "SR2" and [F:AOB]ABREV <> "SR3"
  For [AOB]NOMFIC
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:AOB]ABREV
    Call TEXTE([F:AOB]LIBEL, SZTEXTE) From OBJDIV
    TEXTE(Z) = [F:AOB]ABREV - "-" - SZTEXTE
  Next
  Filter [AOB]
  NBTEX = Z
  Call TEXTE(24022, TIT) From OBJDIV      #Browsers
Return

