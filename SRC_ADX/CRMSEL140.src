$SEL_SELFLDCUS2
Local Integer Z
Local Char SZTEXTE

  #Sélection d'un libellé sur champ Donneur d'ordre
  If !clalev([F:BPG]) : Local File BPMISCCGF [BPG] : Endif
  Z = 0
  SZTEXTE = ""
  Filter [BPG] Where [F:BPG]BPRTYP = "LIBDOO" and [F:BPG]LAN = GLANGUE and [F:BPG]TTRINT(0) = PARAM(1)
  For [BPG]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:BPG]TTRALH(0)
    TEXTE(Z) = [F:BPG]TTRALH(0)
  Next
  Filter [BPG]
  NBTEX = Z
  TIT = PARAM(2)
Return

