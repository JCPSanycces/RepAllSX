    When "SELCONHCIA"     : Gosub SEL_SELCONHCIA
    When "SELSRE9MAC"     : Gosub SEL_SELSRE9MAC
    When "SELITN8MAC"     : Gosub SEL_SELITN8MAC
    When "SELCMS6AOB"     : Gosub SEL_SELCMS6AOB
    When "SELCMI5AOB"     : Gosub SEL_SELCMI5AOB
    When "SELCMA3AOB"     : Gosub SEL_SELCMA3AOB
    When "SELMCC2FIE"     : Gosub SEL_SELMCC2FIE
