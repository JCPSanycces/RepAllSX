$SEL_SELITAVUOM
Local Integer Z
Local Integer ITYPUOM
Local Char SZTEXTE

  #Sélection des unités de temps
  If !clalev([F:UOT]) : Local File UNITOFTIME [UOT] : Endif
  If !clalev([F:TUN]) : Local File TABUNIT [TUN] : Endif
  Z = 0
  If PARAM(1) = "" Then
    # Si aucun tiers n'est mentionné, on ne fait rien.
    Return
  Endif
  ITYPUOM = val(PARAM(1))
  Filter [UOT] Where [F:UOT]TYPUOM = ITYPUOM
  For [UOT]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:UOT]UOM
    Call LECTEXTRA(SZTEXTE, "TABUNIT", "DES", [F:UOT]UOM, "") From ATEXTRA
    TEXTE(Z) = TEX(Z) - "-" - SZTEXTE
  Next
  Filter [UOT]
  NBTEX = Z
  #Sélection d'une unité de temps
  TIT = mess(218,182,1)
Return

