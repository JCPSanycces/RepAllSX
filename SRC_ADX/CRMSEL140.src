$SEL_SELSRE9MAC
Local Integer Z
Local Integer ITER

  #Sélection d'une fiche parc pour une consommation
  Z = 0
  For ITER = 0 To [M:SRE7]NBMAC-1
    Read[MAC]MAC0=[M:SRE7]MAC(ITER)
    If !fstat Then
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      TEX(Z) = [F:MAC]MACNUM
      TEXTE(Z) = [F:MAC]MACNUM - "-" - [F:MAC]MACPDTCOD
    Endif
  Next
  NBTEX = Z
  TIT = mess(465,182,1) #Sélection d'un parc.
Return

