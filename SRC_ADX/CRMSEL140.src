$SEL_SELCONHCIA
Local Integer Z
Local Char SZADITXT
Local Integer IADINUM

  #Sélection d'une famille commerciale de produit
  Z = 0
  SZADITXT = ""
  IADINUM = 19 + GFAMCIA
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  Filter [ADI] Where [F:ADI]NUMTAB = IADINUM Order By [F:ADI]CODE Asc
  For [ADI]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    SZADITXT = ""
    TEX(Z) = [F:ADI]CODE
    Call GET_LIB(IADINUM, [F:ADI]CODE, SZADITXT) From CRM_UTIL
    TEXTE(Z) = [F:ADI]CODE - "-" - SZADITXT
  Next
  Filter [ADI]
  NBTEX = Z
  TIT = mess(263,182,1) #Famille commerciale de produit.
Return

