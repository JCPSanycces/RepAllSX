#####################################################################
$SEL_SELCCS1FIE
Local Integer Z
Local Char SZTABCOD(GLONATB)

  #Sélection des champs d'une table ou du dictionnaire des critères
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Z = 0
  SZTABCOD = ""
  If PARAM(1) = "" Then
    #Aucun code de table n'a été mentionné.
    GMESSAGE = mess(587,196,1)
    GERR = 3
    Return
  Endif
  Case PARAM(1)
    When "1"
      SZTABCOD = "BAPPOINT"
    When "2"
      SZTABCOD = "INTERVEN"
    When "3"
      SZTABCOD = "INTERVEN"
    When "4"
      SZTABCOD = "SERREQUEST"
    When "5"
      SZTABCOD = "PHONECALL"
    When "6"
      SZTABCOD = "TASK"
    When "7"
      SZTABCOD = "OPPOR"
  Endcase
  Filter [ATZ] Where [F:ATZ]CODFIC = SZTABCOD and [F:ATZ]CODZONE >= VALEUR
  For [ATZ]CODZONE
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    Z += 1
    TEX(Z) = [F:ATZ]CODZONE
    Call TEXTE([F:ATZ]NOLONG, TEXTE(Z)) From OBJDIV
    TEXTE(Z) = [F:ATZ]CODZONE - "-" - TEXTE(Z)
  Next
  Filter [ATZ]
  NBTEX = Z
  TIT = mess(376,196,1) #Liste des champs
Return

#####################################################################
$VERF_SELCCS1FIE
  #Sélection des champs d'une table ou du dictionnaire des critères
Return
#####################################################################

#####################################################################
$SEL_SELSEM0SEM
Local Integer ITER
Local Integer Z

  #Sélection des sémantiques
  Z = 0
  ITER = 1
  While mess(ITER,val(PARAM(1)),1) <> ""
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    Z += 1
    TEX(Z) = num$(ITER)
    TEXTE(Z) = mess(ITER,val(PARAM(1)),1)
    ITER += 1
  Wend
  NBTEX = Z
  Call TEXTE(20518, TIT) From OBJDIV #Sémantiques
Return

#####################################################################
$VERF_SELSEM0SEM
  #Sélection des sémantique
Return
#####################################################################

#####################################################################
$SEL_SELBPRCCN
Local Integer Z
Local Char SZTTLLIB
Local Char SZTIT(100)

  #Sélection des interlocuteurs d'un tiers
  Z = 0
  SZTTLLIB = ""
  SZTIT = ""
  # Si aucun tiers n'est mentionné, on ne fait rien.
  If PARAM(1) = "" Then
    Return
  Endif
  Filter [CNT] Where [F:CNT]BPANUM = PARAM(1) and [F:CNT]BPATYP = 1
  For [CNT]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:CNT]CCNCRM
    Read [AIN]AIN0=[F:CNT]CCNCRM
    If fstat Then
      TEXTE(Z) = [F:CNT]CCNCRM
    Else
      Call BUILDFULNAM("AIN", TEXTE(Z)) From CRMUTIL140
    Endif
  Next
  Filter [CNT]
  NBTEX = Z
  Read [BPR]BPR0=PARAM(1)
  If fstat Then
    SZTIT = mess(194,196,1) + PARAM(1)
  Else
    SZTIT = mess(194,196,1) + [F:BPR]BPRNAM
  Endif
  TIT = left$(SZTIT, 50)
Return

#####################################################################
$VERF_SELBPRCCN
  #Sélection des interlocuteurs d'un tiers
Return
#####################################################################

#####################################################################
$SEL_SELSRE9CPN
Local Integer Z
Local Integer ITERZ
Local Integer ITERCHECK
Local Integer IALREADYLOAD
Local Char SZCPNNAM(40)
Local Char SZSRENUM

  #Sélection d'un composant concerné
  Z = 0
  ITERZ = 0
  SZCPNNAM = ""
  ITERCHECK = 0
  IALREADYLOAD = 0
  If PARAM(3) = "" Then
    # Si aucun parc n'est renseignée
    Return
  Endif
  If GREP = "C" Then
    # Si aucune demande de service n'est renseignée
    If PARAM(2) = "" Then
      Return
    Endif
    SZSRENUM = PARAM(2)
  Elsif GREP = "D" Then
    If PARAM(2) = "" Then
      Return
    Endif
    SZSRENUM = PARAM(2)
  Else
    If PARAM(1) = "" Then
      Return
    Endif
    SZSRENUM = PARAM(1)
  Endif
  If !clalev([F:SRN]) : Local File SREMACCPN [SRN] : Endif
  Filter [SRN] Where [F:SRN]SRENUM = SZSRENUM and [F:SRN]MACNUM = PARAM(3) and [F:SRN]FGVCAH = 0
  For [SRN]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    IALREADYLOAD = 0
    For ITERCHECK = 1 To dim(TEX)-1
      If TEX(ITERCHECK) <> "" Then
        If [F:SRN]CPNITM <> "" Then
          If [F:SRN]CPNITM = TEX(ITERCHECK) Then
            IALREADYLOAD = 1
            Break
          Endif
        Endif
      Endif
    Next
    If IALREADYLOAD = 0 Then
      TEX(Z) = [F:SRN]CPNITM
      #Call LECTEXTRA(SZCPNNAM, "ITMMASTER", "DES1AXX", [F:SRN]CPNITM, "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:SRN]CPNITM,SZCPNNAM, "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      TEXTE(Z) = [F:SRN]CPNITM - "-" - SZCPNNAM
    Endif
  Next
  Filter [SRN]
  NBTEX = Z
  #Sélection du composant concerné
  TIT = mess(199,182,1)
Return

#####################################################################
$VERF_SELSRE9CPN
  #Sélection d'un composant concerné
Return
#####################################################################

