#####################################################################
$SEL_SELRQW1SER
Local Char CODFIC(GLONATB)

  #Sélection d'un numéro de série sur une demande de garantie
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "MACHINES"
  Default File [MAC]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  If PARAM(2) = "" Then
    CRITERE = '[F:MAC]MACPDTCOD = PARAM(1) and [F:MAC]MACITNTYP >= 2 and [F:MAC]MACITNTYP <= 3 '
  Else
    CRITERE = '[F:MAC]MACPDTCOD = PARAM(1) and [F:MAC]MACITNTYP = 2 and [F:MAC]MACRSL = PARAM(2) '
  Endif
  CRITERE += ' and [F:MAC]MACSERNUM >= VALEUR and [F:MAC]MACSERNUM <> ""'
  START = "MACSERNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "MACSERNUM"
  Call TEXTE(3282, TIT(0)) From OBJDIV      #Numéros de série
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "MACPDTCOD" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "MACDES" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "MACSERNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "MACPURDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "MACNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

#####################################################################
$VERF_SELRQW1SER
  #Sélection d'un numéro de série sur une demande de garantie
Return
#####################################################################

#####################################################################
$SEL_SELINVSSRE
Local Char CODFIC(GLONATB)

  #Sélection d'une demande de service en attente de facturation
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "SERREQUEST"
  Default File [SRE]
  DEFPAG = 1 # FGR 03/02/2009 : X3SUIVI52173 : pour que le superviseur gère les pages suivantes
  CRITERE = "[F:SRE]SREASS = 5 and [F:SRE]SREINVFLG = 2"
  START = "SRENUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "SRENUM"
  TIT(0) = mess(67,177,1) #Demandes de service en attente de facturation
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "SRENUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "SRENUMBPC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "SREDOO" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "SREBPC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
  NBCOL += 1 : COL(NBCOL) = "SRETTR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

