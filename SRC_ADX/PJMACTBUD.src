#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# PJMACTBUD
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    # Buttons
    When "NEW"                         : Gosub NEW
    When "APRES_MODIF"                 : Gosub APRES_MODIF
    When "ABA"                         : Gosub ABANDON
    When "FIN"                         : Gosub FIN
    When "ENR"                         : Gosub ENR
    When "SUP"                         : Gosub SUP
    When "AVANT_BOUTON"                : Gosub AVANT_BOUTON          # Issue X3-99928 - 2018-07-19 by FGR
    When "AVANT_MEN"                   : Gosub AVANT_MEN             # Issue X3-99928 - 2018-07-19 by FGR
    When "SETBOUT"                     : Gosub SETBOUT
    When "BOUTON"                      : Gosub BOUTON
    When "MEN"                         : Gosub MENU
    When "AP_CHOIX"                    : Gosub AP_CHOIX
    When Default
  Endcase
Return

###################################################################################################
$OUVRE
# Issue X3-106111 - 2018-08-30 by FGR : BEGIN
Local Integer ITECFINKILL

  ITECFINKILL = [V]CST_ANO
  If dim(TECFINOVE10) < 0 Then
    Global Instance TECFINOVE10 Using C_TECFINOVE
    Global Instance TECFINOVE20 Using C_TECFINOVE

    ITECFINKILL = [V]CST_AYES
  Endif
# Issue X3-106111 - 2018-08-30 by FGR : END

Local Char SAVFONCTION(type(GFONCTION)-1)        # Issue X3-99928 - 2018-07-19 by FGR

  NAVIG = GACTION
  GOK = 1
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN : Load autorization for the current function, after saving formers function...
  SAVFONCTION = GFONCTION
  GFONCTION = "PJMACTBUD"
  Call AUTORIS From EXEFNC
  # Issue X3-99928 - 2018-07-19 by FGR : END
Return

###################################################################################################
$DEBUT
Local Char STUNBUD(GLONPBU)  # Contain the budget given by parameter

  # -----------------------------
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  Raz STUNBUD
  If PARAM(2) <> AVOID.ACHAR Then
    STUNBUD = PARAM(2)
  Endif
  # -----------------------------
  # Issue X3-106111 - 2018-08-30 by FGR : BEGIN
  If ITECFINKILL = [V]CST_AYES Then
    Call LOAD_TITLES_10_20() From SUBPJBU
  Endif
  # Issue X3-106111 - 2018-08-30 by FGR : END
  # -----------------------------
  Effzo [M:PJBU0]1-99
  Effzo [M:PJBU0A]1-99       # Issue X3-99916 - 2018-07-10 by FGR
  #Effzo [M:PJBU0B]1-99       # Issue X3-99916 - 2018-07-10 by FGR   # Issue X3-107733 - 2018-10-09 by FGR :  screen deleted
  Effzo [M:PJBU0C]1-99       # Issue X3-99916 - 2018-07-10 by FGR
  Effzo [M:PJBU1]1-99
  # -----------------------------
  Gosub LOAD_PAGE
  # -----------------------------
Return

###################################################################################################
$NEW
Local Integer NLINE

  NLINE = fmet GZINSPJM.PJM(1).ADDLINE("BUD", [V]CST_ALASTPOS)
  If NLINE <> [V]CST_ANOTDEFINED Then
    [M:PJBU0]LINBUD = NLINE
    Call SHOW_BUDGET(NLINE)
    # ----------------------
    [M:PJBU0]NBLIG += 1
    [M:PJBU0]LINBUDTBL = [M:PJBU0]NBLIG
    Call LOAD_TREE()
    # ----------------------
    REP = "M"
    [M:PJBU0]REP = REP
    # ----------------------
    Actzo [M:PJBU0A]PBUCOD   # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
    Gosub SETBOUT
  Else
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(100,141,1)
    Endif
    GOK = 1
    GERR = 1
    REP = [M:PJBU0]REP
  Endif
Return

###################################################################################################
$APRES_MODIF
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN
  If GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).ASTALIN <> [V]CST_ANEW Then
    If func SUBPJMA.GET_AUTHORIZATION("M") = [V]CST_ANO Then
      # "Save" button
      GMESSAGE = mess(1132,2260,1)
      GOK = 1
      GERR = 1
      Return
    Endif
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : END
  If REP = AVOID.ACHAR Then
    REP = "M"
    [M:PJBU0]REP = REP
  Endif
Return

###################################################################################################
$ABANDON
  STUNBUD = [M:PJBU0A]PBUCOD # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  Gosub RELIT_GZINSPJM From SUBPJMA
  Gosub LOAD_PAGE
  REP = AVOID.ACHAR
  [M:PJBU0]REP = REP
  #[M:PJBU0]LINBUD = 0     # Note FGR : Absolutly not
Return

###################################################################################################
$FIN
Local Integer IRET

  # -------------------------
  If PARAM(2) <> AVOID.ACHAR Then
    PARAM(2) = [M:PJBU0A]PBUCOD        # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  Endif
  If [M:PJBU0]LINBUD > 0 and REP <> AVOID.ACHAR Then
    If GNAVIG(GPILNAV-1) <> "GESPJM" Then
      Gosub RELIT_GZINSPJM From SUBPJMA
    Endif
  Endif
  REP = AVOID.ACHAR
  [M:PJBU0]REP = REP
  # -------------------------
  If dim(GPJMCURKEY) > 0 Then
    If GNAVIG(GPILNAV-1) = "PJMACTTAS" Then
      GPJMCURKEY = [M:PJTA0]KEYCONCAT
    Else
      If dim([M:PJM0]OPPNUM) >= 0 Then
        GPJMCURKEY = [M:PJM0]OPPNUM
      Else
        GPJMCURKEY = AVOID.ACHAR
      Endif
    Endif
  Endif
  # -------------------------
  # Issue X3-106111 - 2018-08-30 by FGR : BEGIN
  If ITECFINKILL = [V]CST_AYES Then
    If TECFINOVE10 <> null Then
      FreeGroup TECFINOVE10
    Endif
    Kill TECFINOVE10
    If TECFINOVE20 <> null Then
      FreeGroup TECFINOVE20
    Endif
    Kill TECFINOVE20
  Endif
  # Issue X3-106111 - 2018-08-30 by FGR : END
  # -------------------------
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN : ...to restaure them at the end
  GFONCTION = SAVFONCTION
  Call AUTORIS From EXEFNC
  # Issue X3-99928 - 2018-07-19 by FGR : END
  # -------------------------
Return

###################################################################################################
$ENR
Local Integer MY_STATUS                          # Hybrid part

  REP = [M:PJBU0]REP
  # -----------------------------------
  # Hybrid part (begin)
  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # -----------------------------------
  [L]MY_STATUS = fmet GZINSPJM.AUPDATE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(159,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      STUNBUD = [M:PJBU0A]PBUCOD       # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
      Gosub LOAD_PAGE
      GERR = 1
      REP = "M"
      Return
    Endif
  Endif
  Gosub RELIT_GZINSPJM From SUBPJMA
  [M:PJBU0]LINBUD = fmet GZINSPJM.PJM(1).BUD_GET_INDEX([M:PJBU0A]PBUCOD)       # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  Call SHOW_BUDGET([M:PJBU0]LINBUD)
  # Hybrid part (end)
  # -----------------------------------
  Call LOAD_TREE()
  REP = AVOID.ACHAR
  [M:PJBU0]REP = REP
  # -----------------------------------
Return

###################################################################################################
$SUP
Local Integer IRET

  IRET = fmet GZINSPJM.PJM(1).ADELLINE("BUD", GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).AORDER)
  If IRET = [V]CST_ANOTDEFINED Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    GOK = 0
    GERR = 1
    Return
  Else
    [M:PJBU0]LINBUD = 0
    Gosub LOAD_PAGE
    REP = "M"
    [M:PJBU0]REP = REP
    Gosub SETBOUT
    zonsui = "[M:PJBU0]NBLIG"          # Issue X3-102520 - 2018-07-27 by FGR
  Endif
Return

###################################################################################################
$AVANT_BOUTON
  # Issue X3-99928 - 2018-07-19 by FGR
  Case BOUT
    When "1"
      # "Task planning"
      # Careful : Authorization to go on "Task planning" is givent on GESPJM function at "5" button level.
      # This is why, for this, I'm using this function which is going to check authorization on another function than
      # the current one.
      # It allow to define an authorization at one place for all where function is called.
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("5") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "2"
      # "Change status"
      If func SUBPJMA.GET_AUTHORIZATION("2") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "3"
      # "Sub Levels"
      If func SUBPJMA.GET_AUTHORIZATION("C") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "4"
      # "Financial overview"
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("1") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "5"
      # "Budget Automation"
      If func SUBPJMA.GET_AUTHORIZATION("5") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "9"
      # "Budget updates"
      If func SUBPJMA.GET_AUTHORIZATION("M") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
  Endcase
Return

###################################################################################################
$AVANT_MEN
  # Issue X3-99928 - 2018-07-19 by FGR
  Case BOUT
    When "6"
      # Saleable products
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("6") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "D"
      # "Project financial overview"
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("1") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
    When "U"
      # "Project overview"
      If func SUBPJMA.GET_AUTHORIZATION_GESPJM("U") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
  Endcase
Return

###################################################################################################
$SETBOUT
  If REP <> AVOID.ACHAR or [M:PJBU0]LINBUD = 0 Then
    If [M:PJBU0]LINBUD = 0 Then
      Call VIREBOUT(CHMEN,"3") From GOBJET       # Sub-level
    Endif
    Call VIREBOUT(CHMEN,"1") From GOBJET         # Tasks
    Call VIREBOUT(CHMEN,"2") From GOBJET         # Status change
    Call VIREBOUT(CHMEN,"4") From GOBJET         # Financial overview
    Call VIREBOUT(CHMEN,"5") From GOBJET         # Budget automation
    Call VIREBOUT(CHMEN,"9") From GOBJET         # Budget updates
    Call VIREBOUT(CHMEN,"6") From GOBJET         # Saleable products
    Call VIREBOUT(CHMEN,"-") From GOBJET         # Sold product management
    Call VIREBOUT(CHMEN,"D") From GOBJET         # Project financial overview
    Call VIREBOUT(CHMEN,"U") From GOBJET         # Project overview
    Call VIREBOUT(CHMEN,"*") From GOBJET         # Time entry
    Call VIREBOUT(CHMEN,"(") From GOBJET         # Enterprise planning
    Call VIREBOUT(CHMEN,"^") From GOBJET         # Inquiries/Sales/Quotes
    Call VIREBOUT(CHMEN,"£") From GOBJET         # Inquiries/Sales/Order
    Call VIREBOUT(CHMEN,"à") From GOBJET         # Inquiries/Sales/Delivery
    Call VIREBOUT(CHMEN,"|") From GOBJET         # Inquiries/Sales/Invoice
    Call VIREBOUT(CHMEN,"\") From GOBJET         # Inquiries/Sales/Return
    Call VIREBOUT(CHMEN,"è") From GOBJET         # Inquiries/Purchasing/RFQ
    Call VIREBOUT(CHMEN,"{") From GOBJET         # Inquiries/Purchasing/Order
    Call VIREBOUT(CHMEN,"}") From GOBJET         # Inquiries/Purchasing/Receipt
    Call VIREBOUT(CHMEN,"_") From GOBJET         # Inquiries/Purchasing/Invoice
    Call VIREBOUT(CHMEN,"ç") From GOBJET         # Inquiries/Purchasing/Return
    Call VIREBOUT(CHMEN,"$") From GOBJET         # Inquiries/Manufactoring/Production reporting
    Call VIREBOUT(CHMEN,"~") From GOBJET         # Inquiries/Manufactoring/Material consumptions
    Call VIREBOUT(CHMEN,"#") From GOBJET         # Inquiries/Manufactoring/List of WOs
  Endif
  # -----------------------------------
  If fmet GZINSPJM.PJM(1).BUD_COUNT() = 0 Then
    # If there is no budget, this action is not available
    Call VIREBOUT(CHMEN,"2") From GOBJET         # Status change
    Call VIREBOUT(CHMEN,"9") From GOBJET         # Budget updates
    Grizo [M:PJBU1]NBLIGNE                       # Grey-out Budget-Line Grid
    Call VIREBOUT(CHBOU,"S") From GOBJET         # To deactive "Delete" button
  Elsif instr(1,CHBOU,"S") <= 0 Then
    CHBOU += "S"                                 # To not deactive "Delete" button
  Endif
  If instr(1,CHBOU,"N") <= 0 Then
    CHBOU += "N"                                 # To not deactive "New" button
  Endif
  # -----------------------------------
  # Issue X3-99928 - 2018-07-19 by FGR : BEGIN
  If func SUBPJMA.GET_AUTHORIZATION("C") = [V]CST_ANO Then
    # "New" button
    Call VIREBOUT(CHBOU,"N") From GOBJET
  Endif
  If func SUBPJMA.GET_AUTHORIZATION("S") = [V]CST_ANO Then
    # "Delete" button
    Call VIREBOUT(CHBOU,"S") From GOBJET
  Endif
  # Issue X3-99928 - 2018-07-19 by FGR : END
  # -----------------------------------
  Gosub SET_BOUT_SPE From GSAISIE
  # -----------------------------------
Return

###################################################################################################
$BOUTON
  Case BOUT
    When "2"
      # Status change
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call SHOW_BUDGET([M:PJBU0]LINBUD)
      Call LOAD_TREE()
    When "3"
      # Sous-niveau
      Gosub SUB_LEVEL
    When "5"
      # Budget automation
      Gosub RELIT_GZINSPJM From SUBPJMA
      If [M:PJBU0]LINBUD > 0 Then
        STUNBUD = [M:PJBU0]KEYBUD([M:PJBU0]LINBUD)
      Endif
      Gosub LOAD_PAGE
  Endcase
Return

###################################################################################################
$MENU
  Case BOUT
    When "6"
      # SPLD Maintenance
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call SHOW_BUDGET([M:PJBU0]LINBUD)
      Call LOAD_TREE()
    When "7"
      # SPLD Automation
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call SHOW_BUDGET([M:PJBU0]LINBUD)
      Call LOAD_TREE()
    When Default
  Endcase
Return

###################################################################################################
$AP_CHOIX
  If REPONSE = GSTAEND Then
    REP = [M:PJBU0]REP
    If [M:PJBU0]REP <> AVOID.ACHAR Then
      GMESSAGE = mess(162,2260,1)
      OK = 1
      Return
    Endif
  Elsif find(REPONSE, GSTANEW) Then
    # To deactivate the question to lost current not updated information
    [M:PJBU0]REP = REP
    Raz REP
  Endif
Return

###################################################################################################
# Subroutines
###################################################################################################
$SUB_LEVEL
Local Integer NLINE
Local Char SPARENT(GLONPBU)

  SPARENT = [M:PJBU0A]PBUCOD           # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  NLINE = fmet GZINSPJM.PJM(1).ADDLINE("BUD", [V]CST_ALASTPOS)
  If NLINE <> [V]CST_ANOTDEFINED Then
    # Issue X3-105216 - 2018-08-17 by FGR : BEGIN
    #[M:PJBU0]LINBUD = NLINE
    GZINSPJM.PJM(1).BUD(NLINE).PBUPAE = SPARENT
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GERR = 1 Then
      IRET = fmet GZINSPJM.PJM(1).ADELLINE("BUD", GZINSPJM.PJM(1).BUD(NLINE).AORDER)
      Return
    Endif
    [M:PJBU0]LINBUD = NLINE
    # Issue X3-105216 - 2018-08-17 by FGR : END
    # ----------------------
    Call SHOW_BUDGET(NLINE)
    # ----------------------
    [M:PJBU0]NBLIG += 1
    [M:PJBU0]LINBUDTBL = [M:PJBU0]NBLIG
    Call LOAD_TREE()
    # ----------------------
    REP = "M"
    [M:PJBU0]REP = REP
    # ----------------------
    Actzo [M:PJBU0A]PBUCOD             # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
    zonsui = "[M:PJBU0A]PBUCOD"        # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  Else
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(100,141,1)
    Endif
    GOK = 1
    GERR = 1
    REP = [M:PJBU0]REP
  Endif
Return

###################################################################################################
$LOAD_PAGE
Local Integer ISHOWLINE

  ISHOWLINE = [M:PJBU0]LINBUD
  Effzo [M:PJBU0]1-99                                      # Issue X3-102520 - 2018-07-27 by FGR must be ! # Issue X3-99916 - 2018-07-10 by FGR
  Effzo [M:PJBU0A]1-99                                     # Issue X3-99916 - 2018-07-10 by FGR
  #Effzo [M:PJBU0B]1-99                                     # Issue X3-99916 - 2018-07-10 by FGR   # Issue X3-107733 - 2018-10-09 by FGR :  screen deleted
  Effzo [M:PJBU0C]1-99                                     # Issue X3-99916 - 2018-07-10 by FGR
  [M:PJBU0]LINBUD = ISHOWLINE
  ISHOWLINE = 0
  Effzo [M:PJBU1]1-99
  [M:PJBU0]OPPNUM = GZINSPJM.OPPNUM
  Call LOAD_TREE()
  If [M:PJBU0]NBLIG > 1 Then
    If STUNBUD <> AVOID.ACHAR Then
      For NI = 0 To [M:PJBU0]NBLIG-1
        If [M:PJBU0]KEYC(NI) = STUNBUD Then
          ISHOWLINE = [M:PJBU0]CLAROW(NI)
          Raz STUNBUD
          Break
        Endif
      Next NI
    Endif
    If ISHOWLINE < 1 Then
      ISHOWLINE = [M:PJBU0]CLAROW([M:PJBU0]FRTLINDSP)      # Issue X3-99916 - 2018-07-10 by FGR : not (1)
    Endif
    Call SHOW_BUDGET(ISHOWLINE)
  Else
    #Diszo [M:PJBU0]10-30                                  # Issue X3-99916 - 2018-07-10 by FGR
    Affzo [M:PJBU0A]15                                     # Issue X3-99916 - 2018-07-10 by FGR
    Affzo [M:PJBU0A]15-20                                  # Issue X3-99916 - 2018-07-10 by FGR
    Diszo [M:PJBU1]10
  Endif
  Affzo [M:PJBU0]1-99
  Affzo [M:PJBU0A]1-99                                     # Issue X3-99916 - 2018-07-10 by FGR
  #Affzo [M:PJBU0B]1-99                                     # Issue X3-99916 - 2018-07-10 by FGR   # Issue X3-107733 - 2018-10-09 by FGR :  screen deleted
  Affzo [M:PJBU0C]1-99                                     # Issue X3-99916 - 2018-07-10 by FGR
  Affzo [M:PJBU1]1-99
Return

###################################################################################################
Subprog SHOW_BUDGET(VNLINE)
Value Integer VNLINE

Local Integer NI

  If VNLINE > 0 Then
    If GZINSPJM.PJM(1).BUD(VNLINE) <> null and find(GZINSPJM.PJM(1).BUD(VNLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      #Effzo [M:PJBU0]10-35  # Issue X3-99916 - 2018-07-10 by FGR
      Effzo [M:PJBU0A]       # Issue X3-99916 - 2018-07-10 by FGR
      #Effzo [M:PJBU0B]       # Issue X3-99916 - 2018-07-10 by FGR   # Issue X3-107733 - 2018-10-09 by FGR :  screen deleted
      Effzo [M:PJBU0C]       # Issue X3-99916 - 2018-07-10 by FGR
      Effzo [M:PJBU1]10
      Call SHOW_BUDGET_HEADER0(VNLINE)
      # Issue X3-106111 - 2018-08-30 by ALMON : BEGIN display KPIs for budget
      Call DISPLAY_10_20()    From SUBPJBU
      Call SET_STYLES_10_20() From SUBPJBU
      # Issue X3-106111 - 2018-08-30 by ALMON : END
      nolign = 0
      For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG)
        If GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(NI) <> null and find(GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          nolign += 1
          Call SHOW_BUDGET_LINE(NI)
        Endif
      Next NI
      [M:PJBU1]NBLIGNE = nolign
      # Issue X3-107733 - 2018-10-09 by FGR : BEGIN : Field removed
      #[M:PJBU0B]CAMTBUDGET = fmet GZINSPJM.PJM(1).BUD_COMPUTE_MNTBUD(GZINSPJM.PJM(1).BUD(VNLINE).PBUCOD)     # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
      # Issue X3-107733 - 2018-10-09 by FGR : END
      [M:PJBU0]CAMTREM = fmet GZINSPJM.PJM(1).BUD_COMPUTE_MNTREMBUD(GZINSPJM.PJM(1).BUD(VNLINE).PBUCOD)
      #Actzo [M:PJBU0]10-30  # Issue X3-99916 - 2018-07-10 by FGR
      Actzo [M:PJBU0A]       # Issue X3-99916 - 2018-07-10 by FGR
      #Actzo [M:PJBU0B]       # Issue X3-99916 - 2018-07-10 by FGR   # Issue X3-107733 - 2018-10-09 by FGR :  screen deleted
      Actzo [M:PJBU1]10
      Affzo [M:PJBU0]1-99
      Affzo [M:PJBU0A]1-99   # Issue X3-99916 - 2018-07-10 by FGR
      #Affzo [M:PJBU0B]1-99   # Issue X3-99916 - 2018-07-10 by FGR   # Issue X3-107733 - 2018-10-09 by FGR :  screen deleted
      Affzo [M:PJBU0C]1-99   # Issue X3-99916 - 2018-07-10 by FGR
      Affzo [M:PJBU1]1-99
      If dim(GPJMCURKEY) > 0 Then
        GPJMCURKEY = [M:PJBU0]KEYCONCAT
      Endif
    Endif
  Endif
End

###################################################################################################
Subprog SHOW_BUDGET_HEADER0(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJBU0] With GZINSPJM.PJM(1).BUD(VNLINE)
  SetInstance [M:PJBU0A] With GZINSPJM.PJM(1).BUD(VNLINE)            # Issue X3-99916 - 2018-07-10 by FGR
  #SetInstance [M:PJBU0B] With GZINSPJM.PJM(1).BUD(VNLINE)            # Issue X3-99916 - 2018-07-10 by FGR   # Issue X3-107733 - 2018-10-09 by FGR :  screen deleted
  SetInstance [M:PJBU0C] With GZINSPJM.PJM(1).BUD(VNLINE)            # Issue X3-99916 - 2018-07-10 by FGR
  [M:PJBU0A]PBUDESAXX = GZINSPJM.PJM(1).BUD(VNLINE).PIMPL.PIMDESAXX  # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  [M:PJBU0A]PBUDESAX1 = GZINSPJM.PJM(1).BUD(VNLINE).PIMPL.PIMDESAX1  # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  [M:PJBU0]LINBUD = VNLINE
  [M:PJBU0A]BTNDC = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJM.ACTX,
&                                                            func PJMBUD_CSTD_PROGS.PBUDESTEX_EXIST(GZINSPJM.ACTX, [M:PJBU0]KEYCONCAT) = [V]CST_AYES or
&                                                            func PJMBUD_CSTD_PROGS.PBUCOMTEX_EXIST(GZINSPJM.ACTX, [M:PJBU0]KEYCONCAT) = [V]CST_AYES)
  # Issue X3-99916 - 2018-07-10 by FGR : not [M:PJBU0] from now
  GFCY = [M:PJBU0A]PBUFCY                                            # Issue X3-99928 - 2018-07-19 by FGR
End

###################################################################################################
Subprog SHOW_BUDGET_HEADER(VNLINE)
Value Integer VNLINE

  Call SHOW_BUDGET_HEADER0(VNLINE)
  Call LOAD_TREE()
End

###################################################################################################
Subprog SHOW_BUDGET_LINE(VNLINE)
Value Integer VNLINE

Local Char KEYCONCAT(250)
Local Integer ISEQNUM

  SetInstance [M:PJBU1]10 With GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(VNLINE)
  [M:PJBU1]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  KEYCONCAT = GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(VNLINE).KEYCONCAT
  ISEQNUM = GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(VNLINE).PLBSEQ
  [M:PJBU1]BTBLIG(nolign-1) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJM.ACTX,
&                                                                       func PJMBUDLIG_CSTD_PROGS.PLBDESTEX_EXIST(GZINSPJM.ACTX, KEYCONCAT, ISEQNUM) = [V]CST_AYES or
&                                                                       func PJMBUDLIG_CSTD_PROGS.PLBCOMTEX_EXIST(GZINSPJM.ACTX, KEYCONCAT, ISEQNUM) = [V]CST_AYES)
End

###################################################################################################
Subprog LOAD_TREE()

Local Integer NI
Local Integer NE
Local Integer NZ
Local Char STBCODE(GLONPBU)(1..)
Local Integer IRET

  Effzo [M:PJBU0]5
  # ------------------------------------
  # root is mandatory : so, this is the project
  NE = 0
  [M:PJBU0]KEYC(NE)   = GZINSPJM.PJM(1).OPPNUM
  [M:PJBU0]EXPFLG(NE) = [V]CST_AYES
  [M:PJBU0]OBJDES(NE) = GZINSPJM.PJM(1).OPPNUM - GZINSPJM.PIMPL.PIMDESAXX
  [M:PJBU0]ICO(NE)    = "Folder.gif"
  [M:PJBU0]CMT1(NE)   = -1
  [M:PJBU0]CMT2(NE)   = -1
  [M:PJBU0]CMT3(NE)   = AVOID.ACHAR
  [M:PJBU0]KEYBUD(NE) = AVOID.ACHAR
  # ------------------------------------
  NE += 1
  For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD)
    If GZINSPJM.PJM(1).BUD(NI) <> null and find(GZINSPJM.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      # Issue X3-70021 - 2018-01-04 by FGR : BEGIN
      If NE >= dim([M:PJBU0]PARKEY) Then
        Call ERREUR(func AFNC.MES1(mess(1020,2260,1), num$(dim([M:PJBU0]PARKEY)))) From GESECRAN
        Break
      Endif
      # Issue X3-70021 - 2018-01-04 by FGR : END
      If GZINSPJM.PJM(1).BUD(NI).PBUPAE <> AVOID.ACHAR Then
        [M:PJBU0]PARKEY(NE) = GZINSPJM.PJM(1).BUD(NI).PBUPAE
      Else
        [M:PJBU0]PARKEY(NE) = [M:PJBU0]KEYC(0)
      Endif
      [M:PJBU0]KEYC(NE)   = GZINSPJM.PJM(1).BUD(NI).PBUCOD
      [M:PJBU0]OBJDES(NE) = GZINSPJM.PJM(1).BUD(NI).PBUCOD - GZINSPJM.PJM(1).BUD(NI).PIMPL.PIMDESAXX
      [M:PJBU0]EXPFLG(NE) = [V]CST_AYES
      If GZINSPJM.PJM(1).BUD(NI).PBUIMP = [V]CST_ANO Then
        [M:PJBU0]ICO(NE) = "Folder.gif"
      Else
        [M:PJBU0]ICO(NE) = "Book.gif"
      Endif
      [M:PJBU0]CLAROW(NE) = NI                               # Numéro de ligne dans la collection
      # Issue X3-99916 - 2018-07-17 by FGR : BEGIN
      [M:PJBU0]GRDLIN(NE) = NE
      If GZINSPJM.PJM(1).BUD(NI).PBUPAE = AVOID.ACHAR Then
        [M:PJBU0]GRDSORKEY(NE) = num$(GZINSPJM.PJM(1).BUD(NI).PBUSOR) + "~" + GZINSPJM.PJM(1).BUD(NI).PBUCOD
        If [M:PJBU0]FRTLINDSP = 0 or ([M:PJBU0]FRTLINDSP > 0 and [M:PJBU0]GRDSORKEY(NE) < [M:PJBU0]GRDSORKEY([M:PJBU0]FRTLINDSP)) Then
          [M:PJBU0]FRTLINDSP = NE
        Endif
      Endif
      # Issue X3-99916 - 2018-07-17 by FGR : END
      # --------------------------
      [M:PJBU0]KEYBUD(NE) = GZINSPJM.PJM(1).BUD(NI).PBUCOD
      # --------------------------
      [M:PJBU0]CMTSOR(NE) = GZINSPJM.PJM(1).BUD(NI).PBUSOR    # Issue X3-91329 - 2018-05-31 by FGR
      [M:PJBU0]CMT1(NE) = GZINSPJM.PJM(1).BUD(NI).PBUSTATE
      [M:PJBU0]CMT2(NE) = GZINSPJM.PJM(1).BUD(NI).PBUIMP
      [M:PJBU0]CMT3(NE) = GZINSPJM.PJM(1).BUD(NI).PBUFCY
      [M:PJBU0]CMT4(NE) = GZINSPJM.CUR
      [M:PJBU0]CMT5(NE) = fmet GZINSPJM.PJM(1).BUD_COMPUTE_MNTBUD(GZINSPJM.PJM(1).BUD(NI).PBUCOD)
      [M:PJBU0]CMT6(NE) = fmet GZINSPJM.PJM(1).BUD_COMPUTE_MNTREMBUD(GZINSPJM.PJM(1).BUD(NI).PBUCOD)
      # --------------------------
      If [M:PJBU0]LINBUD <> NI Then
        [M:PJBU0]EXPFLG(NE) = [V]CST_ANO
      Else
        If GZINSPJM.PJM(1).BUD(NI).PBUPAE <> AVOID.ACHAR and GZINSPJM.PJM(1).BUD(NI).PBUCOD <> AVOID.ACHAR Then
          IRET = fmet GZINSPJM.PJM(1).BUD_GET_PARENTS(GZINSPJM.PJM(1).BUD(NI).PBUCOD, STBCODE)
        Endif
      Endif
      # --------------------------
      NE += 1
    Endif
  Next NI
  [M:PJBU0]NBLIG = NE
  # --------------------------
  Affzo [M:PJBU0]5
  For NI = 0 To [M:PJBU0]NBLIG-1
    If find([M:PJBU0]KEYC(NI), STBCODE(1..maxtab(STBCODE))) > 0 and [M:PJBU0]EXPFLG(NI) = [V]CST_ANO Then
      [M:PJBU0]EXPFLG(NI) = [V]CST_AYES
    Endif
    # --------------------------
    If NI = 0 Then
      NZ = fmet GZINSPJM.PJM(1).SPLD_EXISTING()
    Else
      NZ = fmet GZINSPJM.PJM(1).BUD([M:PJBU0]CLAROW(NI)).SPLD_EXISTING()
    Endif
    # ------------------------------------
    If NZ = [V]CST_AYES Then
      Chgstl [M:PJBU0]OBJDES(NI) With "PJMSPL"
    Endif
    # --------------------------
    If [M:PJBU0]CMT2(NI) = [V]CST_ANO Then
      Chgstl [M:PJBU0]CMT2(NI) With "PJMWHITEB"
      Chgstl [M:PJBU0]CMT3(NI) With "PJMWHITEB"
      Chgstl [M:PJBU0]CMT4(NI) With "PJMWHITEB"
      Chgstl [M:PJBU0]CMT5(NI) With "PJMWHITEB"
      Chgstl [M:PJBU0]CMT6(NI) With "PJMWHITEB"
    Endif
    # --------------------------
    Case [M:PJBU0]CMT1(NI)
      When 1
        # New
        If [M:PJBU0]CMT2(NI) = [V]CST_ANO Then
          Chgstl [M:PJBU0]CMT1(NI) With "PJMNEWB"
        Else
          Chgstl [M:PJBU0]CMT1(NI) With "PJMNEW"
        Endif
      When 2
        # Opened
        If [M:PJBU0]CMT2(NI) = [V]CST_ANO Then
          Chgstl [M:PJBU0]CMT1(NI) With "PJMOPENB"
        Else
          Chgstl [M:PJBU0]CMT1(NI) With "PJMOPEN"
        Endif
      When 3
        # Delivered
        If [M:PJBU0]CMT2(NI) = [V]CST_ANO Then
          Chgstl [M:PJBU0]CMT1(NI) With "PJMDELIVB"
        Else
          Chgstl [M:PJBU0]CMT1(NI) With "PJMDELIV"
        Endif
      When 4
        # Solded
        If [M:PJBU0]CMT2(NI) = [V]CST_ANO Then
          Chgstl [M:PJBU0]CMT1(NI) With "PJMCLOSEB"
        Else
          Chgstl [M:PJBU0]CMT1(NI) With "PJMCLOSE"
        Endif
      When 9
        # Suspended
        If [M:PJBU0]CMT2(NI) = [V]CST_ANO Then
          Chgstl [M:PJBU0]CMT1(NI) With "PJMHOLDB"
        Else
          Chgstl [M:PJBU0]CMT1(NI) With "PJMHOLD"
        Endif
      When Default
        Chgstl [M:PJBU0]CMT1(NI) With AVOID.ACHAR
    Endcase
  Next NI
  Affzo [M:PJBU0]5
  # --------------------------
End

###################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer ASTATUS
Local Integer ILINE
Local Integer NI

  If [M:PJBU0]LINBUD > 0 Then
    For NI = 1 To maxtab(GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG)
      If GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(NI) <> null and find(GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
        ILINE = find(num$(GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(NI).AUUID), [M:PJBU1]AUUID(0..[M:PJBU1]NBLIGNE-1))
        If ILINE = 0 Then
          ILINE = find(NI, [M:PJBU1]COLLIN(0..[M:PJBU1]NBLIGNE-1))
        Endif
        If ILINE = 0 Then
          [L]ASTATUS = fmet GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).ADELLINE("BUDLIG", GZINSPJM.PJM(1).BUD([M:PJBU0]LINBUD).BUDLIG(NI).AORDER)
          If [L]ASTATUS >= [V]CST_AERROR Then
            GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
            GOK = 0
            GERR = 1
            Break
          Endif
        Endif
      Endif
    Next NI
    If GERR = 1 Then
      End
    Endif
  Endif
End

###################################################################################################
Funprog GET_PJMACTSPLD_ORI(VNLINE)
Value Integer VNLINE

Local Char SARENDRE(250)

  # Issue X3-108644 - 2018-10-11 by FGR : called from the screen because field size is not enough
  If VNLINE = 0 Then
    SARENDRE = func PJMACTSPLD.CALLER_PROJECT()
  Else
    SARENDRE = func PJMACTSPLD.CALLER_BUDGET()
  Endif
End SARENDRE

###################################################################################################
Funprog GET_PJMACTSPLD_COD(VNLINE)
Value Integer VNLINE

Local Char SARENDRE(250)

  # Issue X3-108644 - 2018-10-11 by FGR : called from the screen because field size is not enough
  If VNLINE = 0 Then
    SARENDRE = [M:PJBU0]OPPNUM
  Else
    SARENDRE = [M:PJBU0]KEYBUD(VNLINE)
  Endif
End SARENDRE

