#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# PJMFOVDE
# Issue X3-99731 - 2018-08-21 by FGR : Reorganization to have a clean script and fix some issues
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "DEBUT"                       : Gosub DEBUT
    # Buttons
    When "BOUTON"                      : Gosub BOUTON
    When Default
  Endcase
Return

###################################################################################################
$OUVRE
  NAVIG = GACTION
  GOK = 1
Return

###################################################################################################
$DEBUT
   If dim(GZINSPJM) <= 0 or dim(TECFINOVE) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 0
    Return
   Endif
  Call LOAD_PAGE(PARAM(3), PARAM(1), PARAM(2))
Return

###################################################################################################
$BOUTON
  Case BOUT
    When "1"
      # Refresh
      Call LOAD_PAGE([M:PFODE]OPPNUM, [M:PFODE]PBUCOD, [M:PFODE]PCCCOD)
  Endcase
Return

###################################################################################################
# AMK : PJMFOVDE
###################################################################################################
Subprog AM_SHOWQTY(VALEUR)
Variable Integer    VALEUR()

  [M:PFODE]SHOWQTY = VALEUR
  # NEED To DO THE Affzo BECAUSE HIDE/SHOW QUANTITIES/AMOUNTS ARE DYNAMICALLY MANAGED By THE SCREEN”.
  Call CHGSTL_PFODE()        # Issue X3-107215 - 2018-10-04 by FGR
  #Affzo [M:PFODE]1-99       # Issue X3-107215 - 2018-10-04 by FGR
End

###################################################################################################
Subprog AM_SHOWAMT(VALEUR)
Variable Integer    VALEUR()

  [M:PFODE]SHOWAMT = VALEUR
  # NEED To DO THE Affzo BECAUSE HIDE/SHOW QUANTITIES/AMOUNTS ARE DYNAMICALLY MANAGED By THE SCREEN”.
  Call CHGSTL_PFODE()        # Issue X3-107215 - 2018-10-04 by FGR
  #Affzo [M:PFODE]1-99       # Issue X3-107215 - 2018-10-04 by FGR
End

####################################################################################################
Subprog C_NBCAT

  If [M:PFODE]CTRLCNT > 0 or nolign > 1 Then
    Call GET_PJMDE_DET([M:PFODE]CATCOD(nolign-1))
  Else
    [M:PFODE]CTRLCNT = 1
  Endif
End

###################################################################################################
Subprog IB_NBDET

Local Char WDES(60)
Local Char PAROBJ(250)
Local Char PARMSG(250)
Local Integer IRET

  GBOUT1 = AVOID.ACHAR
  [M:PFODE]OBJET = AVOID.ACHAR
  # ---------------------
  IRET = func GET_PJMBUDTRQ_OBJECT(TECFINOVE.SHOWGRP,[M:PFODE]OBJECT(nolign-1),PAROBJ, WDES, PARMSG)
  If IRET = 0 Then
    [M:PFODE]OBJET = PAROBJ
    GBOUT1 = WDES
  Else
    Raz GBOUT1
  Endif
End

###################################################################################################
Subprog B1_NBDET

Local Char VALBOUT(250), PARBOUT(250)(1..20)
Local Char PARMSK(250)(1..20), SAVACT(20)
Local Char OBJCLE(30)
Local Integer MY_STATUS
Local Char SOUTKEY(250)(1..)
Local Integer IRET
Local Instance ZOPPORSAV Using C_OPPOR

  If [M:PFODE]OBJET = "TAC" Then
    Raz ZOPPORSAV
    If TECFINOVE.OPPNUM <> [M:PFODE]OPPNUM Then
      ZOPPORSAV = GZINSPJM
      GZINSPJM = NewInstance C_OPPOR AllocGroup null
      GZINSPJM.TCHTOREAD = "PJM"
      [L]MY_STATUS = fmet GZINSPJM.AREAD([M:PFODE]OPPNUM)
      If [L]MY_STATUS <> [V]CST_AOK Then
        If GMESSAGE = AVOID.ACHAR Then
          GMESSAGE = mess(163,2260,1)
          GERR = 1
          FIN = 0
          End
        Endif
      Endif
    Endif
    Call TUNPJMTSK([M:PFODE]PDEORICOD(nolign-1),[M:PFODE]OPPNUM) From PJMSELECT
    If ZOPPORSAV <> null Then
      FreeGroup GZINSPJM
      GZINSPJM = ZOPPORSAV
    Endif
  Else
    SAVACT = GACTION : GACTION = "GOBJETC0"
    IRET = func PIMPL_CSTD_PROGS.STRING_SPLIT_STD(GACTX, [M:PFODE]PDEORICOD(nolign-1), SOUTKEY)
    Call OBJET_CHAR(SOUTKEY(1),[M:PFODE]OBJET, SOUTKEY(2)) From GOBJET
    GACTION = SAVACT
  Endif
End

###################################################################################################
# Subroutines
###################################################################################################
Funprog COL_GET_TITLE(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.COL_GET_TITLE(TECFINOVE, INDEX)
End SARENDRE

###################################################################################################
Funprog COLGETFMT(INDEX)
Value Integer INDEX

Local Char SARENDRE(250)

  SARENDRE = func TECFINOVE_CSTD_PROGS.GET_FMT_DYN(TECFINOVE, INDEX, [M:PFODE]SHOWAMT, TECFINOVE.CUR, [M:PFODE]SHOWQTY, TECFINOVE.UOM)
End SARENDRE

###################################################################################################
Subprog LOAD_PAGE(PARPRJ, PARBUD, COSTTYPE)
Value Char PARPRJ
Value Char PARBUD
Value Char COSTTYPE

  [M:PFODE]CTRLCNT = 0
  # -------------------------
  Effzo [M:PFODE]10
  [M:PFODE]PCCCOD = COSTTYPE
  [M:PFODE]PBUCOD = PARBUD
  [M:PFODE]OPPNUM = PARPRJ
  [M:PFODE]SHOWQTY = TECFINOVE.SHOWQTY
  [M:PFODE]SHOWAMT = TECFINOVE.SHOWMNT
  Affzo [M:PFODE]10
  # -------------------------
  Call LOAD_TREE()
  # -------------------------
End

###################################################################################################
Subprog LOAD_TREE()

  Call CHGSTL_PFODE()        # Issue X3-106367 - 2018-08-28 by FGR
  Call GET_SUMM_PJMDE()
  Call GET_PJMDE_DET(AVOID.ACHAR)
  Affzo [M:PFODE]10-80
End

###################################################################################################
Subprog GET_PJMDE_DET(CATCODE)
Value Char CATCODE

Local Integer NE
Local Integer IOK

  #--- Get Default Group -----------
  Local File PJMDE[PJDE]
  # -------------------------
  If [M:PFODE]OPPNUM = AVOID.ACHAR Then
    If CATCODE <> AVOID.ACHAR Then
      If [M:PFODE]PBUCOD = AVOID.ACHAR Then
        Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD and [F:PJDE]PDEGRPNUM = CATCODE
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Else
        Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PBUCOD = [M:PFODE]PBUCOD and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD and [F:PJDE]PDEGRPNUM = CATCODE
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Endif
    Else
      If [M:PFODE]PBUCOD = AVOID.ACHAR Then
        Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Else
        Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PBUCOD = [M:PFODE]PBUCOD and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Endif
    Endif
  Else
    If CATCODE <> AVOID.ACHAR Then
      If [M:PFODE]PBUCOD = AVOID.ACHAR Then
        Filter [PJDE] Where [F:PJDE]OPPNUM = [M:PFODE]OPPNUM and [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD and [F:PJDE]PDEGRPNUM = CATCODE
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Else
        Filter [PJDE] Where [F:PJDE]OPPNUM = [M:PFODE]OPPNUM and [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PBUCOD = [M:PFODE]PBUCOD
&                       and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD and [F:PJDE]PDEGRPNUM = CATCODE
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Endif
    Else
      If [M:PFODE]PBUCOD = AVOID.ACHAR Then
        Filter [PJDE] Where [F:PJDE]OPPNUM = [M:PFODE]OPPNUM and [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Else
        Filter [PJDE] Where [F:PJDE]OPPNUM = [M:PFODE]OPPNUM and [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PBUCOD = [M:PFODE]PBUCOD and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&              Order By Key KEY0=[F:PJDE]PDEORICOD;[F:PJDE]PDENUM;[F:PJDE]PDEDAT
      Endif
    Endif
  Endif
  # -------------------------
  Effzo [M:PFODE]20
  NE = 0
  For [PJDE]KEY0
    [M:PFODE]OBJECT(NE) = [F:PJDE]OBJECT
    [M:PFODE]PDEORICOD(NE) = [F:PJDE]PDEORICOD
    [M:PFODE]PDEORIDES(NE) = [F:PJDE]PDEORIDES
    [M:PFODE]PDENUM(NE) = [F:PJDE]PDENUM
    [M:PFODE]PDEAXXD(NE) = [F:PJDE]PDEDES
    [M:PFODE]PDEDAT(NE) = [F:PJDE]PDEDAT
    [M:PFODE]PDEQTY1D(NE) = [F:PJDE]PDEQTY1
    [M:PFODE]PDEAMT1D(NE) = [F:PJDE]PDEAMT1
    [M:PFODE]PDEQTY2D(NE) = [F:PJDE]PDEQTY2
    [M:PFODE]PDEAMT2D(NE) = [F:PJDE]PDEAMT2
    [M:PFODE]PDEQTY3D(NE) = [F:PJDE]PDEQTY3
    [M:PFODE]PDEAMT3D(NE) = [F:PJDE]PDEAMT3
    [M:PFODE]PDEQTY4D(NE) = [F:PJDE]PDEQTY4
    [M:PFODE]PDEAMT4D(NE) = [F:PJDE]PDEAMT4
    [M:PFODE]PDEQTY5D(NE) = [F:PJDE]PDEQTY5
    [M:PFODE]PDEAMT5D(NE) = [F:PJDE]PDEAMT5
    [M:PFODE]PDEQTY6D(NE) = [F:PJDE]PDEFREEC6A
    [M:PFODE]PDEAMT6D(NE) = [F:PJDE]PDEFREEC6B
    [M:PFODE]PDEQTY7D(NE) = [F:PJDE]PDEFREEC7A
    [M:PFODE]PDEAMT7D(NE) = [F:PJDE]PDEFREEC7B
    [M:PFODE]PDEQTY8D(NE) = [F:PJDE]PDEFREEC8A
    [M:PFODE]PDEAMT8D(NE) = [F:PJDE]PDEFREEC8B
    [M:PFODE]PDEQTY9D(NE) = [F:PJDE]PDEFREEC9A
    [M:PFODE]PDEAMT9D(NE) = [F:PJDE]PDEFREEC9B
    [M:PFODE]PDEQTY10D(NE) = [F:PJDE]PDEFREEC10A
    [M:PFODE]PDEAMT10D(NE) = [F:PJDE]PDEFREEC10B
    #
    If NE + 1 > dim([M:PFODE]OBJECT) Then
      IOK = 2
      Call AVERTIR(func AFNC.MES2(mess(1128,2260,1), num$(NE), num$(rowcount([F:PJDE]))), IOK) From GESECRAN
      Break
    Endif
    NE += 1
  Next
  [M:PFODE]NBDET = NE
  # -------------------------
  Filter [PJDE]
  Affzo [M:PFODE]20
End

###################################################################################################
Subprog GET_SUMM_PJMDE()

Local Decimal LGRDQTY1
Local Decimal LGRDAMT1
Local Decimal LGRDQTY2
Local Decimal LGRDAMT2
Local Decimal LGRDQTY3
Local Decimal LGRDAMT3
Local Decimal LGRDQTY4
Local Decimal LGRDAMT4
Local Decimal LGRDQTY5
Local Decimal LGRDAMT5
Local Decimal LGRDQTY6
Local Decimal LGRDAMT6
Local Decimal LGRDQTY7
Local Decimal LGRDAMT7
Local Decimal LGRDQTY8
Local Decimal LGRDAMT8
Local Decimal LGRDQTY9
Local Decimal LGRDAMT9
Local Decimal LGRDQTY10
Local Decimal LGRDAMT10
Local Char COSTCAT(80)
Local Integer NE
Local Integer IOK

  Local File PJMDE[PJDE]
  # -------------------------
  If [M:PFODE]OPPNUM = AVOID.ACHAR Then
    If [M:PFODE]PBUCOD = AVOID.ACHAR Then
      Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&            Order By Key KEY0=[F:PJDE]PCCCOD;[F:PJDE]PDEGRPNUM
    Else
      Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]PBUCOD = [M:PFODE]PBUCOD and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&            Order By Key KEY0=[F:PJDE]PCCCOD;[F:PJDE]PDEGRPNUM
    Endif
  Else
    If [M:PFODE]PBUCOD = AVOID.ACHAR Then
      Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]OPPNUM = [M:PFODE]OPPNUM and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&            Order By Key KEY0=[F:PJDE]PCCCOD;[F:PJDE]PDEGRPNUM
    Else
      Filter [PJDE] Where [F:PJDE]PDESSS = TECFINOVE.SESSION and [F:PJDE]OPPNUM = [M:PFODE]OPPNUM and [F:PJDE]PBUCOD = [M:PFODE]PBUCOD and [F:PJDE]PCCCOD = [M:PFODE]PCCCOD
&            Order By Key KEY0=[F:PJDE]PCCCOD;[F:PJDE]PDEGRPNUM
    Endif
  Endif
  # -------------------------
  Effzo [M:PFODE]15
  NE = 0
  Read [PJDE]First
  While !fstat
    COSTCAT = [F:PJDE]PDEGRPNUM
    [M:PFODE]CATCOD(NE) = [F:PJDE]PDEGRPNUM
    [M:PFODE]CATAXX(NE) = [F:PJDE]PDEGRPDES
    [M:PFODE]PDEGRPDAT(NE) = date$
    LGRDQTY1 = 0
    LGRDAMT1 = 0
    LGRDQTY2 = 0
    LGRDAMT2 = 0
    LGRDQTY3 = 0
    LGRDAMT3 = 0
    LGRDQTY4 = 0
    LGRDAMT4 = 0
    LGRDQTY5 = 0
    LGRDAMT5 = 0
    LGRDQTY6 = 0
    LGRDAMT6 = 0
    LGRDQTY7 = 0
    LGRDAMT7 = 0
    LGRDQTY8 = 0
    LGRDAMT8 = 0
    LGRDQTY9 = 0
    LGRDAMT9 = 0
    LGRDQTY10 = 0
    LGRDAMT10 = 0
    While !fstat and COSTCAT = [F:PJDE]PDEGRPNUM
      LGRDQTY1 += [F:PJDE]PDEQTY1
      LGRDAMT1 += [F:PJDE]PDEAMT1
      LGRDQTY2 += [F:PJDE]PDEQTY2
      LGRDAMT2 += [F:PJDE]PDEAMT2
      LGRDQTY3 += [F:PJDE]PDEQTY3
      LGRDAMT3 += [F:PJDE]PDEAMT3
      LGRDQTY4 += [F:PJDE]PDEQTY4
      LGRDAMT4 += [F:PJDE]PDEAMT4
      LGRDQTY5 += [F:PJDE]PDEQTY5
      LGRDAMT5 += [F:PJDE]PDEAMT5
      LGRDQTY6 += [F:PJDE]PDEFREEC6A
      LGRDAMT6 += [F:PJDE]PDEFREEC6B
      LGRDQTY7 += [F:PJDE]PDEFREEC7A
      LGRDAMT7 += [F:PJDE]PDEFREEC7B
      LGRDQTY8 += [F:PJDE]PDEFREEC8A
      LGRDAMT8 += [F:PJDE]PDEFREEC8B
      LGRDQTY9 += [F:PJDE]PDEFREEC9A
      LGRDAMT9 += [F:PJDE]PDEFREEC9B
      LGRDQTY10 += [F:PJDE]PDEFREEC10A
      LGRDAMT10 += [F:PJDE]PDEFREEC10B
      If [F:PJDE]PDEGRPDAT < [M:PFODE]PDEGRPDAT(NE) and [F:PJDE]PDEGRPDAT <> [0/0/0] Then
        [M:PFODE]PDEGRPDAT(NE) = [F:PJDE]PDEGRPDAT
      Endif
      Read [PJDE]Next
    Wend
    [M:PFODE]PDEQTY1(NE) = LGRDQTY1
    [M:PFODE]PDEAMT1(NE) = LGRDAMT1
    [M:PFODE]PDEQTY2(NE) = LGRDQTY2
    [M:PFODE]PDEAMT2(NE) = LGRDAMT2
    [M:PFODE]PDEQTY3(NE) = LGRDQTY3
    [M:PFODE]PDEAMT3(NE) = LGRDAMT3
    [M:PFODE]PDEQTY4(NE) = LGRDQTY4
    [M:PFODE]PDEAMT4(NE) = LGRDAMT4
    [M:PFODE]PDEQTY5(NE) = LGRDQTY5
    [M:PFODE]PDEAMT5(NE) = LGRDAMT5
    [M:PFODE]PDEQTY6(NE) = LGRDQTY6
    [M:PFODE]PDEAMT6(NE) = LGRDAMT6
    [M:PFODE]PDEQTY7(NE) = LGRDQTY7
    [M:PFODE]PDEAMT7(NE) = LGRDAMT7
    [M:PFODE]PDEQTY8(NE) = LGRDQTY8
    [M:PFODE]PDEAMT8(NE) = LGRDAMT8
    [M:PFODE]PDEQTY9(NE) = LGRDQTY9
    [M:PFODE]PDEAMT9(NE) = LGRDAMT9
    [M:PFODE]PDEQTY10(NE) = LGRDQTY10
    [M:PFODE]PDEAMT10(NE) = LGRDAMT10
    #
    If NE + 1 > dim([M:PFODE]PDEQTY1) Then
      IOK = 2
      Call AVERTIR(func AFNC.MES2(mess(1127,2260,1), num$(NE), num$(rowcount([F:PJDE]))), IOK) From GESECRAN
      Break
    Endif
    NE += 1
  Wend
  [M:PFODE]NBCAT = NE
  # -------------------------
  Affzo [M:PFODE]15
End

###################################################################################################
Funprog GET_PJMBUDTRQ_OBJECT(INGRP,INSQL, OUTOBJ, OUTLABEL, SMESSAGE)
Value Char     INGRP       #  numero groupe dans 388: 10, 20, 30
Value Char     INSQL       #  SQL of request
Variable Char  OUTOBJ      #  Object Abbreviation
Variable Char  OUTLABEL    #  Label of Object
Variable Char  SMESSAGE

Local Char WTMP(60)
Local Integer IARENDRE

  IARENDRE = [V]CST_AFALSE
  # -------------------------
  Local File AOBJET[AOB]
  Local File PJMBUDTRQ[PJQ]
  # -------------------------
  Raz OUTOBJ
  Raz WTMP
  Filter [PJQ] Where [F:PJQ]PBTGRP = INGRP and [F:PJQ]SQLQRY = INSQL
  Read [PJQ]First
  If !fstat Then
    OUTOBJ = PBTOBJ
    # name of request (code in RequeteurSQL)
    Read[AOB]ABREV=OUTOBJ
    If !fstat Then
      Call TEXTE([F:AOB]LIBEL, WTMP) From OBJDIV
      OUTLABEL = WTMP
    Else
      IARENDRE = [V]CST_ATRUE
    Endif
  Else
    IARENDRE = [V]CST_ATRUE
  Endif
  Filter [PJQ]
End IARENDRE

###################################################################################################
Subprog CHGSTL_PFODE()

  # Issue X3-106367 - 2018-08-28 by FGR
  Call CHGSTL_PFODE_NBCAT()
  Call CHGSTL_PFODE_NBDET()
End

###################################################################################################
Subprog CHGSTL_PFODE_NBCAT()

  # Issue X3-106367 - 2018-08-28 by FGR
  Chgfmt [M:PFODE]PDEQTY1 With func PJMFOVDE.COLGETFMT(5)
  Chgfmt [M:PFODE]PDEAMT1 With func PJMFOVDE.COLGETFMT(6)
  Chgfmt [M:PFODE]PDEQTY2 With func PJMFOVDE.COLGETFMT(7)
  Chgfmt [M:PFODE]PDEAMT2 With func PJMFOVDE.COLGETFMT(8)
  Chgfmt [M:PFODE]PDEQTY3 With func PJMFOVDE.COLGETFMT(9)
  Chgfmt [M:PFODE]PDEAMT3 With func PJMFOVDE.COLGETFMT(10)
  Chgfmt [M:PFODE]PDEQTY4 With func PJMFOVDE.COLGETFMT(11)
  Chgfmt [M:PFODE]PDEAMT4 With func PJMFOVDE.COLGETFMT(12)
  Chgfmt [M:PFODE]PDEQTY5 With func PJMFOVDE.COLGETFMT(13)
  Chgfmt [M:PFODE]PDEAMT5 With func PJMFOVDE.COLGETFMT(14)
  Chgfmt [M:PFODE]PDEQTY6 With func PJMFOVDE.COLGETFMT(25)
  Chgfmt [M:PFODE]PDEAMT6 With func PJMFOVDE.COLGETFMT(26)
  Chgfmt [M:PFODE]PDEQTY7 With func PJMFOVDE.COLGETFMT(31)
  Chgfmt [M:PFODE]PDEAMT7 With func PJMFOVDE.COLGETFMT(32)
  Chgfmt [M:PFODE]PDEQTY8 With func PJMFOVDE.COLGETFMT(33)
  Chgfmt [M:PFODE]PDEAMT8 With func PJMFOVDE.COLGETFMT(34)
  Chgfmt [M:PFODE]PDEQTY9 With func PJMFOVDE.COLGETFMT(35)
  Chgfmt [M:PFODE]PDEAMT9 With func PJMFOVDE.COLGETFMT(36)
  Chgfmt [M:PFODE]PDEQTY10 With func PJMFOVDE.COLGETFMT(37)
  Chgfmt [M:PFODE]PDEAMT10 With func PJMFOVDE.COLGETFMT(38)
  Affzo [M:PFODE]15          # Issue X3-107215 - 2018-10-04 by FGR
End

###################################################################################################
Subprog CHGSTL_PFODE_NBDET()

  # Issue X3-106367 - 2018-08-28 by FGR
  Chgfmt [M:PFODE]PDEQTY1D With func PJMFOVDE.COLGETFMT(5)
  Chgfmt [M:PFODE]PDEAMT1D With func PJMFOVDE.COLGETFMT(6)
  Chgfmt [M:PFODE]PDEQTY2D With func PJMFOVDE.COLGETFMT(7)
  Chgfmt [M:PFODE]PDEAMT2D With func PJMFOVDE.COLGETFMT(8)
  Chgfmt [M:PFODE]PDEQTY3D With func PJMFOVDE.COLGETFMT(9)
  Chgfmt [M:PFODE]PDEAMT3D With func PJMFOVDE.COLGETFMT(10)
  Chgfmt [M:PFODE]PDEQTY4D With func PJMFOVDE.COLGETFMT(11)
  Chgfmt [M:PFODE]PDEAMT4D With func PJMFOVDE.COLGETFMT(12)
