#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des contrats de services    Module CRM       4 Septembre 2000
##########################################################################################################
# SETCONKEY     : Calcul une clé unique de contrat lorsqu'il est créé automatiquement depuis une commande.
# SETOLDINF     : Mémorise les infos à récupérer en cas de suppression de la dernière facture d'un contrat.
# SETMTIROIR    : Affecte un tiroir d'affichage au contrat. (Classe écran)
# SETFTIROIR    : Affecte un tiroir d'affichage au contrat. (Classe fichier)
# REWWARRANTY   : Renouvellement automatique des garanties renouvelables.
# SETSIHPRICE   : Calcul le prix d'une échéance de contrat de service
# CPTRVACON     : Programme de calcul d'une base de redevance réévalué en picking de contrat dans les factures
# CHECKREWINV   : Vérifie sur la fréquence de facturation n'est pas supérieure à la fréquence
#                    de renouvellement.
# LOADPIT       : Chargement du relevé des points
# DISPCCN       : Affichage de l'interlocuteur
# SETTZN        : Gestion du nommage des étiquettes de champs
# CHECKRSIFDD   : Gestion de la résiliation ou de la clôture d'un contrat
# INVDTAAMT     : Conversion des éléments de facturation
# SETWTYDEF
# STDRAZCRE : Initialise les valeurs par défaut de l'enregistrement
#
#############################################################################################
##########################################################################################################
# Calcul une clé unique de contrat lorsqu'il est créé automatiquement depuis une commande.
#################################################################################################
Subprog SETCONKEY(SZFCYNUM, SZCONNUM, ISTAOK)
Value Char SZFCYNUM
Variable Char SZCONNUM
Variable Integer ISTAOK

Local Char SZCCONCPT(GLONANM)         # Code compteur pour contrat
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  ISTAOK = 1
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    ISTAOK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(0)
  #  SZCCONCPT = [F:TCA]CODNUM(0)
  If clalev ([F:FCY])<=0 Local File FACILITY [FCY] : Endif
  If clalev ([F:CPY])<=0 Local File COMPANY [CPY] : Endif
  Read [F:FCY]FCY0=SZFCYNUM
  Read [F:CPY]CPY0=[F:FCY]LEGCPY
  Call READ_COUNTER(SZFCYNUM, 12, 0, [F:CPY]CPY, [F:CPY]LEG, SZCCONCPT, GMANCOU) From CRM_UTIL
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK1", SZFCYNUM, SZCCONCPT, date$, "", SZCONNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 0 Then
      # problème lors de la récupération du compteur
      ISTAOK = 0
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      End
    Endif
  Endif
End

##########################################################################################################
# Mémorise les infos à récupérer en cas de suppression de la dernière facture d'un contrat.
##################################################################
Subprog SETOLDINF(SZINVNUM, IREWFLG, IRVAFLG)
Value Char SZINVNUM
Value Integer IREWFLG
Value Integer IRVAFLG

  If SZINVNUM = "" Then
    #L'action ne provient pas d'une création de facture
    If IREWFLG Then
      [F:CON]OREWINV = ""
    Endif
    If IRVAFLG Then
      [F:CON]ORVAINV = ""
    Endif
  Else
    #L'action provient d'une création de facture
    If IREWFLG Then
      #Un renouvellement a été effectué
      [F:CON]OREWINV = SZINVNUM
      [F:CON]OCONSTRDAT = [F:CON]CONSTRDAT
      [F:CON]OCONENDDAT = [F:CON]CONENDDAT
    Endif
    If IRVAFLG Then
      #Une réévaluation a été effectuée
      [F:CON]ORVAINV = SZINVNUM
      [F:CON]OLASVALIDX = [F:CON]LASVALIDX
      [F:CON]OLASIDXDAT = [F:CON]LASIDXDAT
      [F:CON]ORVADAT = [F:CON]RVADAT
      [F:CON]OCONAMT = [F:CON]CONAMT
    Endif
  Endif
End

##########################################################################################################
# Renouvellement automatique des garanties renouvelables.
###############################################################################
Subprog REWWARRANTY
Local Integer ICANREW
Local Integer IERRINF
Local Integer IERR
Local Integer IOK
Local Integer ITER
Local Char SZCLE(GLONVCR)
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
Local Date DLTIDAT
Local Integer IUPDATED

  If GHISTO = 1 Then
    #On est dans le dossier historique
    End
  Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:CRE]) : Local File CONTREW [CRE] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif          # FGR 09/07/2014 : X3SUIVI101294
  ICANREW = 0
  IERRINF = 0
  #Avant tout, on teste si cela n'a pas déjà été fait pour cette journée.
  #Enregistre le nouveau ciblage
  Read [DVA]DVA0="REW";"WARRANTY"
  If fstat Then
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
    [F:DVA]OBC = "REW"
    [F:DVA]PARAM = "WARRANTY"
    [F:DVA]DATX(0) = date$
    Write [DVA]
    If fstat Then
      #La gestion des renouvellements des garanties à tacite reconduction n'a pas pu être configurée.
      GMESSAGE = mess(352,182,1)
      GERR = 1
      Rollback
    Else
      Commit
      ICANREW = 1
    Endif
  Else
    If [F:DVA]DATX(0) < date$ Then
      Call DEBTRANS From GLOCK
      Trbegin [DVA]
      Readlock [DVA]DVA0="REW";"WARRANTY"
      If fstat Then
        #Erreur lors du renouvellement des contrats de garantie à tacite reconduction.
        GMESSAGE = mess(350,182,1)
        GERR = 1
        Rollback
      Else
        [F:DVA]OBC = "REW"
        [F:DVA]PARAM = "WARRANTY"
        [F:DVA]DATX(0) = date$
        Rewrite [DVA]
        If fstat Then
          #Erreur lors du renouvellement des contrats de garantie à tacite reconduction.
          GMESSAGE = mess(350,182,1)
          GERR = 1
          Rollback
          Unlock [DVA]
        Else
          Commit
          Unlock [DVA]
          ICANREW = 1
        Endif
      Endif
    Endif
  Endif
  If ICANREW = 0 Then
    End
  Endif
  #Renouvellement proprement dit
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  IPERF = 0
  INTR = 0
  ITER = 0
  IOK = 1
  IERR = 0
  IUPDATED = 0
  If GREWNBRDAY <= 0 Then
    DLTIDAT = date$
  Else
    DLTIDAT = date$ + GREWNBRDAY
  Endif
  Call TEMPON(mess(351,182,1)) From GESECRAN
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [CON] Where [F:CON]CONENDDAT < DLTIDAT and [F:CON]RSIFLG <> 2 and [F:CON]FDDFLG <> 2 and [F:CON]CONNUM > SZCLE Order By [F:CON]CONNUM Asc
    For [CON]
      SZCLE = [F:CON]CONNUM
      If IPERF = 0 Then
        Trbegin [CON], [CRE]
        INTR = 1
      Endif
      IUPDATED = 0
      Read [BPC]BPC0=[F:CON]CONBPC     # FGR 09/07/2014 : X3SUIVI101294
      If [F:CON]CONCAT = 1 Then
        # Garantie
        If [F:CON]CONENDDAT < date$ Then
          If [F:CON]CONREW = 2 Then
            # CAS RENOUVELLEMENT TACITE
            If [F:BPC]BPCSTA = 2 Then
              # FGR 09/07/2014 : X3SUIVI101294 : seulement pour les clients non pas bloqués
              IUPDATED = 1
              IOK = 1
              Call SETOLDINF("", 1, 0)
              Call REWCONB(IOK) From SUBCONB1
              If !IOK Then
                IERR = 1
                Rollback
                #Erreur lors du renouvellement des contrats de garantie à tacite reconduction.
                GMESSAGE = mess(350,182,1)
                GERR = 1
                INTR = 0
                Break
              Endif
            Else
              # FGR 09/07/2014 : X3SUIVI101294 : Client bloqué on ne renouvelle pas le contrat
              Gosub TRACE_BPC_BLOQUE
            Endif
          Else
            If [F:CON]DSYWND <> 2 Then
              If [F:BPC]BPCSTA = 2 Then
                # FGR 09/07/2014 : X3SUIVI101294 : seulement pour les clients non pas bloqués
                [F:CON]DSYWND = 2
                IUPDATED = 1
              Else
                # FGR 09/07/2014 : X3SUIVI101294 : Client bloqué on ne renouvelle pas le contrat
                Gosub TRACE_BPC_BLOQUE
              Endif
            Endif
          Endif
        Else
          If [F:CON]CONREW <> 2 Then
            If [F:CON]DSYWND <> 4 Then
              If [F:BPC]BPCSTA = 2 Then
                # FGR 09/07/2014 : X3SUIVI101294 : seulement pour les clients non pas bloqués
                [F:CON]DSYWND = 4
                IUPDATED = 1
              Else
                # FGR 09/07/2014 : X3SUIVI101294 : Client bloqué on ne renouvelle pas le contrat
                Gosub TRACE_BPC_BLOQUE
              Endif
            Endif
          Endif
        Endif
      Elsif [F:CON]CONCAT = 4 Then
        #Contrats à points
        If [F:CON]CONENDDAT < date$ Then
          If [F:CON]DSYWND <> 2 Then
            If [F:BPC]BPCSTA = 2 Then
              # FGR 09/07/2014 : X3SUIVI101294 : seulement pour les clients non pas bloqués
              [F:CON]DSYWND = 2
              IUPDATED = 1
            Else
              # FGR 09/07/2014 : X3SUIVI101294 : Client bloqué on ne renouvelle pas le contrat
              Gosub TRACE_BPC_BLOQUE
            Endif
          Endif
        Endif
      Else
        #Maintenance(3) / Entretien(2)
        If [F:CON]CONREW <> 2 Then
          If [F:CON]CONENDDAT < date$ Then
            If [F:CON]DSYWND <> 2 Then
              If [F:BPC]BPCSTA = 2 Then
                # FGR 09/07/2014 : X3SUIVI101294 : seulement pour les clients non pas bloqués
                [F:CON]DSYWND = 2
                IUPDATED = 1
              Else
                # FGR 09/07/2014 : X3SUIVI101294 : Client bloqué on ne renouvelle pas le contrat
                Gosub TRACE_BPC_BLOQUE
              Endif
            Endif
          Else
            If [F:CON]DSYWND <> 4 Then
              If [F:BPC]BPCSTA = 2 Then
                # FGR 09/07/2014 : X3SUIVI101294 : seulement pour les clients non pas bloqués
                [F:CON]DSYWND = 4
                IUPDATED = 1
              Else
                # FGR 09/07/2014 : X3SUIVI101294 : Client bloqué on ne renouvelle pas le contrat
                Gosub TRACE_BPC_BLOQUE
              Endif
            Endif
          Endif
        Else
          # FGR 22/06/2016 : X3SUIVI116932 (début)
          # CAS RENOUVELLEMENT TACITE
          #If [F:CON]CONENDDAT < date$ Then                                         # Issue SAM120356 - 2017-01-09 by FGR
          If [F:CON]CONENDDAT < date$ and [F:CON]CONENDDAT <= [F:CON]NEXINVDAT Then # Issue SAM120356 - 2017-01-09 by FGR
                                                                                    # Il ne faut pas renouveller un contrat qui n'a pas été totalement facturé sur sa durée
            If [F:BPC]BPCSTA = 2 Then
              IUPDATED = 1
              IOK = 1
              Call SETOLDINF("", 1, 0)
              Call REWCONB(IOK) From SUBCONB1
              If !IOK Then
                IERR = 1
                Rollback
                #Erreur lors du renouvellement des contrats de garantie à tacite reconduction.
                GMESSAGE = mess(350,182,1)
                GERR = 1
                INTR = 0
                Break
              Endif
            Else
              Gosub TRACE_BPC_BLOQUE
            Endif
          Endif
          # FGR 22/06/2016 : X3SUIVI116932 (fin)
        Endif
      Endif
      If IUPDATED Then
        Rewrite [CON]
        If fstat Then
          IERR = 1
          #Erreur lors du renouvellement des contrats de garantie à tacite reconduction.
          GMESSAGE = mess(350,182,1)
          GERR = 1
          Rollback
          INTR = 0
          Break
        Else
          If IPERF >= 478 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Else
        If IPERF >= 478 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
    Next
    Filter [CON]
    If IERR Then
      Break
    Endif
  Wend
  If INTR Then
    If !IERR Then
      Commit
    Endif
  Endif
  Call TEMPOFF From GESECRAN
  # FGR 09/07/2014 : X3SUIVI101294 (début)
  If GTRACE <> "" Then
    Call LEC_TRACE From LECFIC
    Call FERME_TRACE From LECFIC
  Endif
  # FGR 09/07/2014 : X3SUIVI101294 (fin)
End

# -------------------------------------------------------------
$TRACE_BPC_BLOQUE
  # FGR 09/07/2014 : X3SUIVI101294
  # Client bloqué on ne renouvelle pas le contrat
  If GTRACE = "" Then
    Call OUVRE_TRACE(mess(672,177,1)) From LECFIC
  Endif
  Call ECR_TRACE ([F:CON]CONBPC - ":" - mess(4,119,1) + "." - [F:CON]CONNUM - ":" - mess(673,177,1), 0) From GESECRAN
Return

##########################################################################################################
# Calcul le prix d'une échéance de contrat de service
##############################################################
Subprog SETSIHPRICE(IPRIX)
Variable Decimal IPRIX

Local Decimal IOLDCONAMT
Local Integer INBDAY
Local Date DDAT1
Local Integer IRVAFLG
Local Decimal IFULLPRICE
Local Integer IOK
Local Date DNDAT
Local Decimal AM
Local Decimal IDECAMOUNT
Local Integer IPEONLY

  AM = 0
  IDECAMOUNT = 0
  DNDAT = [00/00/00]
  DDAT1 = [00/00/00]
  IOK = 1
  IFULLPRICE = 0
  INBDAY = 0
  IPEONLY = 0
  IOLDCONAMT = [F:CON]CONAMT
  #On fait faire tout le travail par un point d'entrée
  Gosub PE_SIHCON From TRTCRMPE
  If IPEONLY Then
    [F:CON]CONAMT = IOLDCONAMT
    End
  Endif
  #Pas de réévaluation
  If [F:CON]RVAFRY <= 0 Then
    IPRIX = arr([F:CON]NEXINVAMT,10^-GDECPRI)
    End
  Endif
  If [F:CON]RVAMET = 1 Then
    #Post-réévaluation
    #-----------------
    IPRIX = arr([F:CON]NEXINVAMT,10^-GDECPRI)
  Elsif [F:CON]RVAMET = 2 Then
    #Pré-réévaluation
    #-----------------
    #REEVALUATION
    #Il faut d'abord vérifier si une réévaluation doit être effectuée.
    IRVAFLG = 0
    If [F:CON]RVAFRY <> 0 Then
      If [F:CON]RVAFRYBAS > 0 Then
        If [F:CON]RVAFRYBAS <> 6 Then
          If [F:CON]RVASSP = 1 Then
            If [F:CON]CONBASIDX <> "" Then
              IRVAFLG = 1
            Endif
          Else
            If [F:CON]CONBASFOR <> "" Then
              IRVAFLG = 1
            Endif
          Endif
        Endif
      Endif
    Endif
    If IRVAFLG Then
      If [F:CON]RVADAT <> [00/00/00] Then
        Call GETNEWDAT([F:CON]RVADAT, [F:CON]RVAFRY, [F:CON]RVAFRYBAS, DNDAT) From SUBCONB1
        If DNDAT <= [F:CON]NEXINVDAT Then
          #Le prix à proposer doit être réévalué.
          IOK = 1
          Call CPTRVACON(IPRIX, IOK)
          If !IOK Then
            Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE) From SUBCONB1
            IPRIX = arr(IFULLPRICE,10^-GDECPRI)
            End
          Endif
        Endif
      Endif
    Endif
    If [F:CON]INVMET = 1 Then
      #Terme à échoir
      #FACTURATION
      If [F:CON]CONREW = 2 Then
        Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE) From SUBCONB1
        IPRIX = arr(IFULLPRICE,10^-GDECPRI)
      Else
        # FGR 29/07/2013 : X3SUIVI91169 : dans ce cas on ne change pas le prix
        Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE) From SUBCONB1
        IPRIX = arr(IFULLPRICE,10^-GDECPRI)
        #Call SNEXINVDAT([F:CON]NEXINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, DDAT1) From SUBCOND
        #If [F:CON]CONENDDAT < DDAT1 Then
        #  INBDAY = nday([F:CON]CONENDDAT) - nday([F:CON]NEXINVDAT)
        #  INBDAY += 1
        #  If INBDAY > 0 Then
        #    AM = [F:CON]CONAMT * [F:CON]INVFRYCOE
        #    IDECAMOUNT = AM * (INBDAY / 365.25)
        #    IPRIX = arr(IDECAMOUNT,10^-GDECPRI)
        #  Else
        #    Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE)  From SUBCONB1
        #    IPRIX = arr(IFULLPRICE,10^-GDECPRI)
        #  Endif
        #Else
        #  Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE) From SUBCONB1
        #  IPRIX = arr(IFULLPRICE,10^-GDECPRI)
        #Endif
      Endif
    Else
      #Terme échu
      #FACTURATION
      If [F:CON]CONREW = 2 Then
        Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE)  From SUBCONB1
        IPRIX = arr(IFULLPRICE,10^-GDECPRI)
      Else
        If [F:CON]CONENDDAT < [F:CON]NEXINVDAT Then
          INBDAY = nday([F:CON]NEXINVDAT) - nday([F:CON]LASINVDAT)
          If INBDAY > 0 Then
            AM = [F:CON]CONAMT * [F:CON]INVFRYCOE
            IDECAMOUNT = AM * (INBDAY / 365.25)
            IPRIX = arr(IDECAMOUNT,10^-GDECPRI)
          Else
            Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE) From SUBCONB1
            IPRIX = arr(IFULLPRICE,10^-GDECPRI)
          Endif
        Else
          Call GETCONAMT([F:CON]CONAMT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]INVFRYCOE, IFULLPRICE) From SUBCONB1
          IPRIX = arr(IFULLPRICE,10^-GDECPRI)
        Endif
      Endif
    Endif
  Endif
  [F:CON]CONAMT = IOLDCONAMT
End

##########################################################################################################
# Programme de calcul d'une base de redevance réévalué en picking de contrat dans les factures
#################################################################################################
Subprog CPTRVACON(IPRIX, ISTAOK)
Variable Decimal IPRIX
Variable Integer ISTAOK

Local Decimal IRVACONPRI
Local Decimal IRVAPRI
Local Integer ISSPFLG
Local Integer IC
Local Integer INEWRECNUM
Local Decimal IIDXVAL
Local Decimal IOLDAMT
Local Decimal INEWAMT
Local Date DIDXDAT
Local Date DOLDDAT
Local Date DNEWDAT

  If !clalev([F:CIX]) : Local File CONTIDX [CIX] : Endif
  ISSPFLG = 0
  IRVACONPRI = 0
  IRVAPRI = [F:CON]CONAMT
  #---------------------------------------------------#
  # Vérifie que l'on a tout ce qu'il faut pour réévaluer à savoir
  #
  # Un indice ou une formule                 : CONBASIDX ou CONBASFOR
  # Une fréquence de réévaluation            : RVAFRY
  # Une base de fréquence de réévaluation    : RVAFRYBAS
  # Une dernière valeur utilisée d'indice    : LASVALIDX
  # Une dernière date d'utilisation d'indice : LASIDXDAT
  # Une dernière date de réévaluation        : RVADAT
  # Une base de redevance annuelle           : CONAMT
  #---------------------------------------------------#
  If [F:CON]RVASSP = 1 Then
    If [F:CON]CONBASIDX <> "" Then
      If [F:CON]LASVALIDX > 0 Then
        If [F:CON]LASIDXDAT <> [00/00/00] Then
          ISSPFLG = 1
        Endif
      Endif
    Endif
  Else
    If [F:CON]CONBASFOR <> "" Then
      ISSPFLG = 1
    Endif
  Endif
  If ISSPFLG Then
    If [F:CON]RVAFRY > 0 Then
      If [F:CON]RVAFRYBAS > 0 Then
        If [F:CON]RVAFRYBAS <> 6 Then
          If [F:CON]RVADAT <> [00/00/00] Then
            If [F:CON]CONAMT > 0 Then
              #On initialise les variables
              DIDXDAT = [00/00/00]
              IC = 0
              INEWRECNUM = 0
              IIDXVAL = 0
              IOLDAMT = 0
              INEWAMT = 0
              DOLDDAT = [00/00/00]
              DNEWDAT = [00/00/00]
            Else
              End
            Endif
          Else
            End
          Endif
        Else
          End
        Endif
      Else
        End
      Endif
    Else
      End
    Endif
  Else
    End
  Endif
  #---------------------------------------------------#
  #
  # Si on a tous les ingrédients, on peut y aller.
  #
  #---------------------------------------------------#
  IOLDAMT = [F:CON]CONAMT
  DOLDDAT = [F:CON]RVADAT
  #Définit la nouvelle date de réévaluation
  Call GETNEWDAT(DOLDDAT, [F:CON]RVAFRY, [F:CON]RVAFRYBAS, DNEWDAT)  From SUBCONB1
  If [F:CON]RVASSP = 1 Then
    #Réévaluation selon indice
    #Définit la nouvelle base de redevance annuelle
    Filter [CIX] Where [F:CIX]IND = [F:CON]CONBASIDX and [F:CIX]INDDAT <= DNEWDAT Order By [F:CIX]INDDAT Desc
    For [CIX] Hint Key CIX1
      IIDXVAL = [F:CIX]INDVAL
      DIDXDAT = [F:CIX]INDDAT
      IC += 1
      Break
    Next
    Filter [CIX]
    If IC > 0 Then
      If IIDXVAL > 0 Then
        If [F:CON]LASVALIDX > 0 Then
          INEWAMT = ([F:CON]CONAMT * IIDXVAL) / [F:CON]LASVALIDX
          IRVAPRI = arr(INEWAMT,10^-GDECPRI)
        Endif
      Endif
    Endif
  Else
    #Réévaluation selon formule
    #Le point d'entrée doit définir la nouvelle base de redevance annuelle
    IRVACONPRI = [F:CON]CONAMT
    Gosub PE_RVACON From TRTCRMPE
    IRVAPRI = arr(IRVACONPRI,10^-GDECPRI)
  Endif
  #Définit le montant de la prochaine facture.
  [F:CON]CONAMT = IRVAPRI
End

##########################################################################################################
#Vérifie sur la fréquence de facturation n'est pas supérieure à la fréquence de renouvellement.
####################################################################################################
$CHECKREWINV
Local Decimal INBINVDAY
Local Decimal INBREWDAY
Local Decimal INBRVADAY

  INBINVDAY = 0
  INBREWDAY = 0
  INBRVADAY = 0
  #Calcul la fréquence de facturation en nombre de jours
  If [M:CON8]INVFRYBAS = 1 Then
    #heure
    If [M:CON8]INVFRY <= 24 Then
      #La fréquence de facturation ne peut pas être inférieure à une journée.
      GMESSAGE = mess(358,182,1)
      GERR = 2
      OK = 0
      Return
    Else
      INBINVDAY = [M:CON8]INVFRY / 24
    Endif
  Elsif [M:CON8]INVFRYBAS = 2 Then
    #jours
    INBINVDAY = [M:CON8]INVFRY
  Elsif [M:CON8]INVFRYBAS = 3 Then
    #semaine
    INBINVDAY = [M:CON8]INVFRY * 7
  Elsif [M:CON8]INVFRYBAS = 4 Then
    #mois
    INBINVDAY = [M:CON8]INVFRY * (365.25 / 12)
  Elsif [M:CON8]INVFRYBAS = 5 Then
    #année
    INBINVDAY = [M:CON8]INVFRY * 365.25
  Elsif [M:CON8]INVFRYBAS = 6 Then
    #vide
    INBINVDAY = 0
  Endif
  #Calcul la fréquence de renouvellement en nombre de jours
  If [M:CON4]REWFRYBAS = 1 Then
    #heure
    If [M:CON4]REWFRY <= 24 Then
      INBREWDAY = 0
    Else
      INBREWDAY = [M:CON4]REWFRY / 24
    Endif
  Elsif [M:CON4]REWFRYBAS = 2 Then
    #jours
    INBREWDAY = [M:CON4]REWFRY
  Elsif [M:CON4]REWFRYBAS = 3 Then
    #semaine
    INBREWDAY = [M:CON4]REWFRY * 7
  Elsif [M:CON4]REWFRYBAS = 4 Then
     #mois
    INBREWDAY = [M:CON4]REWFRY * (365.25 / 12)
  Elsif [M:CON4]REWFRYBAS = 5 Then
    #année
    INBREWDAY = [M:CON4]REWFRY * 365.25
  Elsif [M:CON4]REWFRYBAS = 6 Then
    #vide
    INBREWDAY = 0
  Endif
  #Calcul la fréquence de réévaluation en nombre de jours
  If [M:CON4]RVAFRYBAS = 1 Then
    #heure
    If [M:CON4]RVAFRY <= 24 Then
      INBRVADAY = -1
    Else
      INBRVADAY = [M:CON4]RVAFRY / 24
    Endif
  Elsif [M:CON4]RVAFRYBAS = 2 Then
    #jours
    INBRVADAY = [M:CON4]RVAFRY
  Elsif [M:CON4]RVAFRYBAS = 3 Then
    #semaine
    INBRVADAY = [M:CON4]RVAFRY * 7
  Elsif [M:CON4]RVAFRYBAS = 4 Then
    #mois
    INBRVADAY = [M:CON4]RVAFRY * (365.25 / 12)
  Elsif [M:CON4]RVAFRYBAS = 5 Then
    #année
    INBRVADAY = [M:CON4]RVAFRY * 365.25
  Elsif [M:CON4]RVAFRYBAS = 6 Then
    #vide
    INBRVADAY = 0
  Endif
  If INBREWDAY < 1 Then
    #La fréquence de renouvellement ne peut pas être inférieure à une journée.
    GMESSAGE = mess(359,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  If [M:CON1]CONCAT = 1 Then
    #Garantie
    Return
  Elsif [M:CON1]CONCAT = 4 Then
    #A point
    Return
  Endif
  If INBINVDAY > INBREWDAY Then
    #La fréquence de facturation ne peut pas être supérieure à la fréquence de renouvellement.
    GMESSAGE = mess(357,182,1)
    GERR = 2
    OK = 0
    Return
  Elsif INBRVADAY < 0 Then
    #La fréquence de réévaluation ne peut pas être inférieure à une journée.
    GMESSAGE = mess(360,182,1)
    GERR = 2
    OK = 0
    Return
  Elsif INBRVADAY > 0 Then
    If INBRVADAY < INBINVDAY Then
      #La fréquence de réévaluation ne peut pas être inférieure à la fréquence de facturation.
      GMESSAGE = mess(361,182,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
# Chargement du relevé des points
###################################################################
Subprog LOADPIT(SZCONNUM, IAFFFLG)
Value Char SZCONNUM
Value Integer IAFFFLG

Local Integer ITOTPIT

  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    ITOTPIT = 0
    Raz [M:CONG]PITRER
    Raz [M:CONG]PITCSM
    Raz [M:CONG]PITBLC
    Filter [PCT] Where [F:PCT]CONNUM = SZCONNUM and [F:PCT]FGVCAH = 0
    For [PCT] PCT1
      If [F:PCT]SAT = 2 Then
        [M:CONG]PITCSM += [F:PCT]PIT
      Else
        [M:CONG]PITRER += [F:PCT]PIT
      Endif
    Next
    Filter [PCT]
    ITOTPIT = [M:CONG]PITRER + [M:CONG]PITCSM
    [M:CONG]PITBLC = [M:CON4]PITCDT - ITOTPIT
    If [M:CONG]PITBLC < 0 Then
      [M:CONG]PITBLC = 0
    Endif
    If IAFFFLG Then
      Affzo [M:CONG]20
    Endif
  Endif
End

##########################################################################################################
#Affichage de l'interlocuteur
######################################################
$DISPCCN
  If [M:CON0]CONCCN = "" Then
    [M:CON0]CONCCNCLA = ""
  Else
    Read [AIN]AIN0=[M:CON0]CONCCN
    If fstat Then
      [M:CON0]CONCCNCLA = ""
    Else
      Call BUILDFULNAM("AIN", [M:CON0]CONCCNCLA) From CRMUTIL140
    Endif
  Endif
Return

##########################################################################################################
# Gestion du nommage des étiquettes de champs
######################################################
Subprog SETTZN
Local Char SZREWFRY
Local Char SZAMT
Local Char SZNEXAMT

  If GIMPORT Then
    End
  Endif
  Call TEXTE(16269, SZREWFRY) From OBJDIV      #Fréquence de renouvellement
  Call TEXTE(15658, SZAMT) From OBJDIV         #Base de redevance annuelle
  Call TEXTE(24423, SZNEXAMT) From OBJDIV      #Montant HT prochaine facture
  Chgtzn [M:CON4]REWFRY With SZREWFRY
  Chgtzn [M:CON4]CONAMT With SZAMT
  Chgtzn [M:CON2]NEXINVAMT With SZNEXAMT
  If [M:CON1]CONCAT = 4 Then
    Call TEXTE(14433, SZREWFRY) From OBJDIV      #Durée
    Call TEXTE(3603, SZAMT) From OBJDIV          #Montant
    Chgtzn [M:CON4]REWFRY With SZREWFRY
    Chgtzn [M:CON4]CONAMT With SZAMT
  Else
    If [M:CON4]CONREW <> 2 Then
      Call TEXTE(14433, SZREWFRY) From OBJDIV      #Durée
      Chgtzn [M:CON4]REWFRY With SZREWFRY
    Endif
  Endif
  If [M:CON4]RVAMET = 2 Then
    If [M:CON2]NEXINVAMT <= 0 Then
      Call TEXTE(24424, SZNEXAMT) From OBJDIV      #Montant non prévisible
      Chgtzn [M:CON2]NEXINVAMT With SZNEXAMT
    Endif
  Endif
End

##########################################################################################################
# Gestion de la résiliation ou de la clôture d'un contrat
######################################################
$CHECKRSIFDD
Local Integer IOUINONMESS
Local Char SZOUINONMESS(250)
Local Integer ICURRSIFLG
Local Integer IPRERSIFLG
Local Integer ICURFDDFLG
Local Integer IPREFDDFLG
Local Integer IASKFORRSIFDD

  IASKFORRSIFDD = 0
  SZOUINONMESS = ""
  IOUINONMESS = 0
  If [M:CON5]RSIFLG = 0 Then
    ICURRSIFLG = 1
  Else
    ICURRSIFLG = [M:CON5]RSIFLG
  Endif
  If [M:CON5]FDDFLG = 0 Then
    ICURFDDFLG = 1
  Else
    ICURFDDFLG = [M:CON5]FDDFLG
  Endif
  If [M:CON5]PRERSIFLG = 0 Then
    IPRERSIFLG = 1
  Else
    IPRERSIFLG = [M:CON5]PRERSIFLG
  Endif
  If [M:CON5]PREFDDFLG = 0 Then
    IPREFDDFLG = 1
  Else
    IPREFDDFLG = [M:CON5]PREFDDFLG
  Endif
  #Résiliation
  If IPRERSIFLG <> ICURRSIFLG Then
    If ICURRSIFLG = 2 Then
      IASKFORRSIFDD = 1
    Endif
  Endif
  #Clôture
  If IPREFDDFLG <> ICURFDDFLG Then
    If ICURFDDFLG = 2 Then
      IASKFORRSIFDD = 2
    Endif
  Endif
  If IASKFORRSIFDD = 0 Then
    Return
  Endif
  If [M:CON1]CONCAT > 1 Then
    If [M:CON2]NEXINVDAT <> [00/00/00] Then
      If [M:CON4]CONAMT > 0 Then
        If IASKFORRSIFDD = 1 Then
          #Avertissement. Certaines facturations manuelles complémentaires seront certainement nécessaires.
          #Confirmez-vous la résiliation ?
          SZOUINONMESS = mess(57,177,1) - mess(58,177,1)
        Endif
        If IASKFORRSIFDD = 2 Then
          #Avertissement. Certaines facturations manuelles complémentaires seront certainement nécessaires.
          #Confirmez-vous la clôture ?
          SZOUINONMESS = mess(57,177,1) - mess(59,177,1)
        Endif
        Call OUINON(SZOUINONMESS, IOUINONMESS) From GESECRAN
        If IOUINONMESS <> 2 Then
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Conversion des éléments de facturation
####################################################################
Subprog INVDTAAMT(WOLDCUR, WCUR, WCHGTYP)
Value Char     WOLDCUR
Value Char     WCUR
Value Integer  WCHGTYP

Local Integer I, SPSTAT
Local Integer IJ0

  If [M:CONG]NBFAC = 0 Then
    Local Decimal WMONTORG
    Local Decimal WMONTDES
  Else
    Local Decimal WMONTORG (0..[M:CONG]NBFAC-1)
    Local Decimal WMONTDES (0..[M:CONG]NBFAC-1)
  Endif
  If [M:CONG]NBFAC > 0 Then
    Read [TCU]TCU0=WCUR
    If !fstat Then
      For I = 0 To [M:CONG]NBFAC-1
        If [M:CONG]AMTCOD(I) = 2 Then
          [M:CONG]FORMAT(I) = "NZ:" + [F:TCU]CURFMT1
          WMONTORG (I) = [M:CONG]INVDTAAMT(I)
        Else
          WMONTORG (I) = 0
        Endif
      Next I
      For IJ0 = 0 To dim(WMONTORG)-1
        If WMONTORG(IJ0) <> 0 Then
          Call CONVERT(WOLDCUR,WCUR,GCUR,WCHGTYP,datesyst,WMONTORG(IJ0),WMONTDES(IJ0),SPSTAT) From TRTDEV
          If SPSTAT Then
            Break
          Endif
        Endif
      Next IJ0
      If SPSTAT = 0 Then
        For I = 0 To [M:CONG]NBFAC-1
          If [M:CONG]AMTCOD(I) = 2 Then
            [M:CONG]INVDTAAMT(I) = WMONTDES(I)
            [M:CONG]WWCUR(I) = WCUR
          Endif
        Next I
      Endif
    Endif
  Endif
End

##########################################################################################################
$SETWTYDEF
Local Char SZMODELECON(GLONVCR) # FGR 19/03/2009 : X3SUIVI53591

  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  # FGR 01/02/2008 : X2SUIVI45226 Pour ajout d'un point d'entrée
  If dim(SZTPLCONGUA) <= 0 Then
    Global Char SZTPLCONGUA(GLONVCR)
  Endif
  # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
  If [F:MAC]MACNUM <> GSZMACNUMRULE Then
    #Read [MAC]MAC0=[M:MAC0]MACNUM
    Read [MAC]MAC0=GSZMACNUMRULE
    If fstat Then
      Gosub STDRAZCRE
      Return
    Endif
  Endif
  # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
  #If [M:MAC1]BPCNUM = "" and [M:MAC1]CCNNUM <> "" Then
  If [F:MAC]BPCNUM = "" and [F:MAC]CCNNUM <> "" Then
    Gosub STDRAZCRE
    Return
  Endif
  # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
  #[M:CON0]CONBPC = [M:MAC1]BPCNUM
  [M:CON0]CONBPC = [F:MAC]BPCNUM
  If [M:CON0]CONBPC <> "" Then
    #On teste si le tiers est un client
    Read [BPC]BPC0=[M:CON0]CONBPC
    If fstat Then
      [M:CON0]CONBPC = ""
      Gosub STDRAZCRE
      Return
    Else
      If [F:BPC]BPCTYP = 4 Then
        #C'est un prospect
        [M:CON0]CONBPC = ""
        Gosub STDRAZCRE
        Return
      Else
        Call AM_CONBPC([M:CON0]CONBPC) From SUBCON
      Endif
    Endif
  Endif
  # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
  #[M:CON0]CONCCN = [M:MAC1]CCNNUM
  [M:CON0]CONCCN = [F:MAC]CCNNUM
  # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
  #If [M:MAC1]MACPDTCOD <> "" Then
  If [F:MAC]MACPDTCOD <> "" Then
    # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
    #Read [ITM]ITM0=[M:MAC1]MACPDTCOD
    Read [ITM]ITM0=[F:MAC]MACPDTCOD
    If fstat Then
      Gosub STDRAZCRE
    Else
      If [F:ITM]TPLCONSRV <> "" Then
        Gosub STDRAZCRE
      Else
        If [F:ITM]TPLCONGUA = "" Then
          Gosub STDRAZCRE
        Else
          # FGR 01/02/2008 : X2SUIVI45226 Pour ajout d'un point d'entrée
          SZTPLCONGUA = [F:ITM]TPLCONGUA
          # création CONtrat de SERvice AUTo
          Gosub PE_CONSERAUT From TRTCRMPE
          #
          Read [COT]COT0=SZTPLCONGUA
          If fstat Then
            Gosub STDRAZCRE
          Else
            If [F:COT]CONCAT = 1 Then
              #Création assistée du contrat de garantie
              # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
              #If [M:MAC1]MACITNDAT = [00/00/00] Then
              If [F:MAC]MACITNDAT = [00/00/00] Then
                #If [M:MAC1]MACBPCDAT = [00/00/00] Then
                If [F:MAC]MACBPCDAT = [00/00/00] Then
                  #If [M:MAC1]MACPURDAT = [00/00/00] Then
                  If [F:MAC]MACPURDAT = [00/00/00] Then
                    [M:CON4]SIUDAT = date$
                  Else
                    # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
                    #[M:CON4]SIUDAT = [M:MAC1]MACPURDAT
                    [M:CON4]SIUDAT = [F:MAC]MACPURDAT
                  Endif
                Else
                  # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
                  #[M:CON4]SIUDAT = [M:MAC1]MACBPCDAT
                  [M:CON4]SIUDAT = [F:MAC]MACBPCDAT
                Endif
              Else
                # FGR 16/06/2008 : X3SUIVI48039 On passe maintenant par la classe F
                #[M:CON4]SIUDAT = [M:MAC1]MACITNDAT
                [M:CON4]SIUDAT = [F:MAC]MACITNDAT
              Endif
              [M:CON4]CONSTRDAT = [00/00/00]
              [M:CON4]CONENDDAT = [00/00/00]
              [M:CON5]RSIFLG = 1
              [M:CON5]RSIDAT = [00/00/00]
              [M:CON5]RSIREN = ""
              # FGR 16/06/2008 : X3SUIVI48039 Suite à ajout du point d'entrée (45226) mauvais chargement ici
              #GSZSTPL = [F:ITM]TPLCONGUA
              GSZSTPL = SZTPLCONGUA
              [M:CON1]CONCOT = GSZSTPL : # FGR 19/09/2008 : X3SUIVI49208
              SZMODELECON = [M:CON1]CONCOT # FGR 19/03/2009 : X3SUIVI53591
              #
              [M:CON0]COVLOWLEV = 1
              Gosub ONSELECT From TRTCON9
              [M:CON1]CONCOT = GSZSTPL
              Read [COT]COT0=[M:CON1]CONCOT
              If fstat Then
                [M:CON1]CONCOTNAM = ""
              Else
                [M:CON1]CONCOTNAM = [F:COT]TPLNAM
              Endif
              #Un contrat de type Garantie a été initialisé sur la base du modèle : XXXXX
              GMESSAGE = mess(668,196,1) - '(' + [F:COT]CONNUM + ')' - [F:COT]TPLNAM
              GERR = 3
            Else
              Gosub STDRAZCRE
            Endif
          Endif
        Endif
      Endif
    Endif
  Else
    Gosub STDRAZCRE
  Endif
  # FGR 01/02/2008 : X2SUIVI45226 Pour ajout d'un point d'entrée
  If dim(SZTPLCONGUA) > 0 Then
    Kill SZTPLCONGUA
  Endif
Return

##########################################################################################################
$STDRAZCRE
  #Initialise les valeurs par défaut de l'enregistrement
  [M:CON0]COVLOWLEV = 0
  Raz [M:CON1]CONTYP
  [M:CON1]CONCAT = 1
  [M:CON4]RVAMET = 1
  [M:CON4]RVASSP = 1
  [M:CON8]INVMET = 1
  [M:CON4]SIUDAT = date$
  [M:CON4]CONSTRDAT = [00/00/00]
  [M:CON4]CONENDDAT = [00/00/00]
  [M:CON5]RSIFLG = 1
  [M:CON5]RSIDAT = [00/00/00]
  [M:CON8]INVFRYCOE = 1
  #Effectue le contrôle de grisage des champs
  Call SETGRAY From SUBCONB1
  #Autorise la saisie d'un numéro de commande en cas de création manuelle du contrat
  #[M:CON8]ORDUPDFLG = 2
  GICONCREATION = 1
  GISETFCOT = 0
  Affzo [M:CON0]1-99
  Affzo [M:CON1]1-99
  Affzo [M:CON4]1-99
  Affzo [M:CON8]1-99
  Affzo [M:CONG]1-99
  Affzo [M:CON2]1-99
  Affzo [M:CON5]1-99
Return

