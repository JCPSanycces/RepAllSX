#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# Correction fiche SAM 110921                                            #
# Initialisation à 2 du champ [F:TCY]FLGDUE pour le pays "FR"            #
# DLE                                                                    #
##########################################################################
Call GENE
End

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Update TABCOUNTRY") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#########################################################
Subprog PATCH(DOSSIER)
  Value Char DOSSIER
  Gosub MAJTAB
End

#########################################################
$MAJTAB
  If DOSSIER=nomap
   Local File TABCOUNTRY [TCY]
  Else
   Local File =DOSSIER+".TABCOUNTRY" [TCY]
  Endif

  If dim([F:TCY]FLGDUE) >= 0 Then
    Trbegin [TCY]
    Update [TCY] Where CRY = "FR" With FLGDUE = 2
    If !fstat
      Update [TCY] Where CRY <> "FR" With FLGDUE = 1
    Endif
    If fstat Then
      Call ERREUR("TABCOUNTRY  fstat=" - num$(fstat), 2) From DOSDIC
      Rollback
    Else
      Commit
    Endif
  Endif

  Close Local File [TCY]
Return

