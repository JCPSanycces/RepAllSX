#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTRPEN 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EXCFRMAUTENR
mkstat = 0
zoncou = "EXCFRMAUTENR"
indice = 0
IMPENT = [M]EXCFRMAUTENR
If varinit([M]EXCFRMAUTENR,indice)=0
 IMPENT = 1
Endif
If varmode([M]EXCFRMAUTENR,indice)=0
 [M]EXCFRMAUTENR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXCFRMAUTENR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EXCFRMAUTENR(indice)
 Endif
Endif
[M]EXCFRMAUTENR = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRPEN
mkstat = 0
zoncou = "NBRPEN"
indice = 0
status = 1
zoncou = "NBRPEN"
If varmode([M]NBRPEN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPEN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRPEN
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRPEN = nolign
   status = 75
   Call SAI_NBRPEN(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRSTA
mkstat = 0
zoncou = "NBRSTA"
indice = 0
status = 1
zoncou = "NBRSTA"
If varmode([M]NBRSTA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRSTA" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRSTA
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRSTA = nolign
   status = 75
   Call SAI_NBRSTA(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRPEN(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPEN
mkstat = 0
zoncou = "NBRPEN"

## Zone ORG
mkstat = 0
zoncou = "ORG"
If varmode([M]ORG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ORG" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]ORG(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Local Char    VALEUR(250)
  VALEUR = [M]ORG(indice)
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
  [M]ORG(indice) = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTORG"
   Call CONTORG([M]ORG(indice)) From SUBORG
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_ORG([M]ORG(indice)) From SUBCTR2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ORG" : GZNUM = 1003169 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PENJONDAT
mkstat = 0
zoncou = "PENJONDAT"
If varmode([M]PENJONDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PENJONDAT" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PENJONDAT(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PENJONDAT" : GZNUM = 1003170 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_PENJONDAT([M]PENJONDAT(indice)) From SUBCTR2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PENJONDAT" : GZNUM = 1003170 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PENXITDAT
mkstat = 0
zoncou = "PENXITDAT"
If varmode([M]PENXITDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PENXITDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PENXITDAT([M]PENXITDAT(indice)) From SUBCTR2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PENXITDAT" : GZNUM = 1003171 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone EMEPRC
mkstat = 0
zoncou = "EMEPRC"
If varmode([M]EMEPRC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMEPRC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EMRPRC
mkstat = 0
zoncou = "EMRPRC"
If varmode([M]EMRPRC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMRPRC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone AUTENR
mkstat = 0
zoncou = "AUTENR"
IMPENT = [M]AUTENR(indice)
If varinit([M]AUTENR,indice)=0
 IMPENT = 1
Endif
If varmode([M]AUTENR,indice)=0
 [M]AUTENR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUTENR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AUTENR(indice)
 Endif
Endif
[M]AUTENR(indice) = IMPENT

## Zone REA
mkstat = 0
zoncou = "REA"
IMPENT = [M]REA(indice)
If varinit([M]REA,indice)=0
 IMPENT = 1
Endif
If varmode([M]REA,indice)=0
 [M]REA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "REA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]REA(indice)
 Endif
Endif
[M]REA(indice) = IMPENT

## Zone WRKPOSENDDAT
mkstat = 0
zoncou = "WRKPOSENDDAT"
If varmode([M]WRKPOSENDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WRKPOSENDDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EJHPOSENDDAT
mkstat = 0
zoncou = "EJHPOSENDDAT"
If varmode([M]EJHPOSENDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EJHPOSENDDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone OPTNOTRCV
mkstat = 0
zoncou = "OPTNOTRCV"
If varmode([M]OPTNOTRCV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPTNOTRCV" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone INFGIVDAT
mkstat = 0
zoncou = "INFGIVDAT"
If varmode([M]INFGIVDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "INFGIVDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone OPTOUTNOTEMR
mkstat = 0
zoncou = "OPTOUTNOTEMR"
If varmode([M]OPTOUTNOTEMR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPTOUTNOTEMR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone AUTENROPTOUT
mkstat = 0
zoncou = "AUTENROPTOUT"
IMPENT = [M]AUTENROPTOUT(indice)
If varinit([M]AUTENROPTOUT,indice)=0
 IMPENT = 1
Endif
If varmode([M]AUTENROPTOUT,indice)=0
 [M]AUTENROPTOUT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUTENROPTOUT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AUTENROPTOUT(indice)
 Endif
Endif
[M]AUTENROPTOUT(indice) = IMPENT

## Zone ENTOPT
mkstat = 0
zoncou = "ENTOPT"
IMPENT = [M]ENTOPT(indice)
If varinit([M]ENTOPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENTOPT,indice)=0
 [M]ENTOPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENTOPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENTOPT(indice)
 Endif
Endif
[M]ENTOPT(indice) = IMPENT

## Zone ENTOPTOUT
mkstat = 0
zoncou = "ENTOPTOUT"
IMPENT = [M]ENTOPTOUT(indice)
If varinit([M]ENTOPTOUT,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENTOPTOUT,indice)=0
 [M]ENTOPTOUT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENTOPTOUT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENTOPTOUT(indice)
 Endif
Endif
[M]ENTOPTOUT(indice) = IMPENT

## Zone NONEJHOPT
mkstat = 0
zoncou = "NONEJHOPT"
IMPENT = [M]NONEJHOPT(indice)
If varinit([M]NONEJHOPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]NONEJHOPT,indice)=0
 [M]NONEJHOPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "NONEJHOPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]NONEJHOPT(indice)
 Endif
Endif
[M]NONEJHOPT(indice) = IMPENT

## Zone NONEJHOPTOUT
mkstat = 0
zoncou = "NONEJHOPTOUT"
IMPENT = [M]NONEJHOPTOUT(indice)
If varinit([M]NONEJHOPTOUT,indice)=0
 IMPENT = 1
Endif
If varmode([M]NONEJHOPTOUT,indice)=0
 [M]NONEJHOPTOUT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "NONEJHOPTOUT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]NONEJHOPTOUT(indice)
 Endif
Endif
[M]NONEJHOPTOUT(indice) = IMPENT

## Zone NBRPEN
mkstat = 0
zoncou = "NBRPEN"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRSTA(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRSTA
mkstat = 0
zoncou = "NBRSTA"

## Zone PENSTADAT
mkstat = 0
zoncou = "PENSTADAT"
If varmode([M]PENSTADAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PENSTADAT" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PENSTADAT(indice)=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PENSTADAT" : GZNUM = 57026 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PENSTA
mkstat = 0
zoncou = "PENSTA"
IMPENT = [M]PENSTA(indice)
If varinit([M]PENSTA,indice)=0
 IMPENT = 1
Endif
If varmode([M]PENSTA,indice)=0
 [M]PENSTA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PENSTA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PENSTA(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PENSTA" : GZNUM = 1179 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]PENSTA(indice) = IMPENT

## Zone NBRSTA
mkstat = 0
zoncou = "NBRSTA"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTRPEN"
Return

