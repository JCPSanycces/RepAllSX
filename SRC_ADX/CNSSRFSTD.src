#<AdxTL>@(#)12.0.0.0 $Revision$ Consultation STL
#########################################################################
# CNSSRFSTD : Consultation Fiche qualité                   HN  16/06/04 #
# ECRAN 1   : CONSSRF1                                                  #
# ECRAN 2   : CONSSRF2                                                  #
# ECRAN CRIT: CRITSRF                                                   #
#########################################################################
Local Char PARAM(20)(1..9)
#-- Consult
PARAM(1) = "0"
#-- Article
PARAM(2) = "A-HNFABACH"
#-- Lot
PARAM(3) = "160604-A*"
#-- Demande
PARAM(4) = ""
#-- Question
PARAM(5) = ""
#-- Slo
PARAM(6) = ""
#-- Sernum
PARAM(7) = ""
#-- Filtre
PARAM(8) = ""
Call GCONSULT("SRF","",PARAM) From GCONSULT
End
#########################################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSRF] : Transmask [M:SRF1] To [M:CSRF]# Issue 25606[M:CSRF] = [M:SRF1]
  When "FIN_CRIT"   : [M:SRF1] = [M:CSRF]
  When "AV_MAGNETO" : Gosub AV_MAGNETO
  When Default
Endcase
Return
############################################################
$AV_MAGNETO
Raz [M:CSRF]DEMSEL
If dim([M:CSRF]LOTSEL)>0
    Raz [M:CSRF]LOTSEL
Endif
If dim([M:CSRF]SLOSEL)>0
    Raz [M:CSRF]SLOSEL
Endif
If dim([M:CSRF]SERNUMSEL)
    Raz [M:CSRF]SERNUMSEL
Endif
[M:SRF1] = [M:CSRF]

Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:QLH1])= 0 : Local File STOQLYH    [QLH1]  : Endif
If clalev([F:QLD1])= 0 : Local File STOQLYD    [QLD1]  : Endif
# Issue 111499 - 2015-11-19 by MAE : pagination
If clalev([F:QLA])= 0 : Local File QLYCRDASW    [QLA]  : Endif
Local  Integer WFSTAT, WREAD, WSKIP, WLIG
#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
#Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSRF"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FERME
If clalev([F:QLA]) <> 0 : Filter [QLA] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
#############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SRF1]       = [F:ITM]
        Endif
      Endif
    When 3 :
      If PARAM(I) <> "" & dim([M:SRF1]LOTSEL) > 0
        [M:SRF1]LOTSEL = PARAM(I)
      Endif
    When 4 :
      If PARAM(I) <> ""
        [M:SRF1]DEMSEL = PARAM(I)
      Endif
    When 5 :
      If PARAM(I) <> ""
        Call LECTURE("QLQ",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SRF1]       = [F:QLQ]
        Endif
      Endif
    When 6 :
      If PARAM(I) <> "" & dim([M:CSRF]SLOSEL) > 0
        [M:CSRF]SLOSEL = PARAM(I)
      Endif
    When 7 :
      If PARAM(I) <> "" & dim([M:CSRF]SERNUMSEL) > 0
        # FGR 15/01/2010 : X3SUIVI60986
        #[M:SRF1]SERNUMSEL = PARAM(I)
        [M:CSRF]SERNUMSEL = PARAM(I)
      Endif
    When 8 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSRF]) <> 0 & [M:CSRF]MEMO = "STD"       # hcb 61281
  [M:SRF1] = [M:CSRF]
Endif

Return
############################################################
$LECTURE
NBLU   = 2
If [M:SRF1]ITMREF = "" | [M:SRF1]QSTNUM = ""
  NBLU = 0
  Return
Endif
#
Gosub LOAD_FILTER
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Link [QLA] With [QLD1]QLD0=28;[QLA]QLYCTLDEM;[QLA]VCRLIN
&          As [LNK]

Filter [LNK] Where evalue(WFIL)  &
&                  evalue(WFILS) &
&                  evalue(WFILSPE)
Raz [LNK]
Raz [M:SRF2]
nolign = 0
Columns [STL](BPSLOT)
Columns [QLH1](VCRNUMORI,VCRTYPORI,ENDCTLDAT)
SUITE  = 0 : RETOUR = 0 : NBLU   = 1
Case CHGPAG
When 1 :
  nolign = 1 : WPAGE  = 0
    For [LNK]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
          NBLU    = 2 :  nolign += 1: NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1 :  RETOUR = 1
    If nolign < MAXLIG  SUITE = 1  Endif
When 2 :
    nolign = 1 :  WSKIP = WPAGE * MAXLIG : WLIG  = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU=2:  nolign += 1:  NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
When -1 :
    Effzo [M:SRF2] : WLIG = 0
    For [LNK]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2 : nolign += 1 : NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1 RETOUR = 1 Endif
    SUITE  = 1
  When -2 :
    nolign = 1 : WPAGE -= 1 : WSKIP  = (WPAGE-1) * MAXLIG : WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2 : nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1  RETOUR = 1  Endif
    NOL    = 0 : nolign = MAXLIG
Endcase

Columns [STL]
Columns [QLH1]
Columns [QLD1]
Filter [QLA]
#SUITE = 1
#RETOUR = 1
Return
############################################################
# Issue 111499 - 2015-11-19 by MAE : mise en place de la pagination
$LOA_LIGNE
[M:SRF2] = [F:QLA]
[M:SRF2]MVTSEQ1(nolign-1) = 10000 - [F:QLA]CRDSEQ
Filter [QLH1] Where VCRTYP=28 & VCRNUM=[QLA]QLYCTLDEM
&                   Order By Key QLH0
For [QLH1]
  [M:SRF2]VCRNUMORI(nolign-1) = [F:QLH1]VCRNUMORI
  [M:SRF2]VCRTYPORI(nolign-1) = [F:QLH1]VCRTYPORI
  [M:SRF2]ENDCTLDAT(nolign-1) = [F:QLH1]ENDCTLDAT
  Break
Next
Filter [QLH1]
If [F:QLD1]VCRTYP<>28 | [F:QLD1]VCRNUM<>[F:QLA]QLYCTLDEM | [F:QLD1]VCRLIN<>[F:QLA]VCRLIN
  Read [QLD1]QLD0=28;[F:QLA]QLYCTLDEM;[F:QLA]VCRLIN
    If fstat : Raz [F:QLD1] : Endif
Endif
[M:SRF2]VCRLINORI(nolign-1) = [F:QLD1]VCRLINORI
If dim([M:SRF2]LOT)>0
  [M:SRF2]LOT(nolign-1)      = [F:QLD1]LOT
Endif
If dim([M:SRF2]SLO)>0
  [M:SRF2]SLO(nolign-1)     = [F:QLD1]SLO
Endif
If dim([M:SRF2]LOT)>0 & dim([M:SRF2]SLO)<=0
  For [STL] Where ITMREF=[QLD1]ITMREF & LOT=[QLD1]LOT
    [M:SRF2]BPSLOT(nolign-1)       = [F:STL]BPSLOT
    Break
  Next
Endif
If dim([M:SRF2]LOT)>0 & dim([M:SRF2]SLO)>0
  For [STL] Where ITMREF=[QLD1]ITMREF & LOT=[QLD1]LOT & SLO=[QLD1]SLO
    [M:SRF2]BPSLOT(nolign-1)       = [F:STL]BPSLOT
    Break
  Next
Endif
Read [QLC]QLC0(1)=[F:QLA]QLYCRD
[G:QLC]currlen=0
If fstat = 0
  # FGR 24/09/2009 : X3SUIVI58062
  #[M:SRF2]QLYCRDDES(nolign-1) = [F:QLC]QLYCRDDES
  Call LECTEXTRA([M:SRF2]QLYCRDDES(nolign-1),"QLYCRD","QLYDESAXX",[F:QLC]QLYCRD,"") From ATEXTRA
Endif

Return
############################################################
$LOAD_FILTER
WFIL = "[F:QLA]ITMREF=[M:SRF1]ITMREF&[F:QLA]QSTNUM=[M:SRF1]QSTNUM"
If [M:SRF1]DEMSEL <> ""
  WFIL += "&pat([F:QLA]QLYCTLDEM,[M:SRF1]DEMSEL)"
Endif
If (dim([M:SRF1]LOTSEL) > 0 & [M:SRF1]LOTSEL <> "")
  WFIL += " & pat([F:QLD1]LOT,[M:SRF1]LOTSEL)"
Endif
If (dim([M:CSRF]SLOSEL)>0 & [M:CSRF]SLOSEL<>"")
  WFIL += " & pat([F:QLD1]SLO,[M:CSRF]SLOSEL)"
Endif
If (dim([M:CSRF]SERNUMSEL)>0 & [M:CSRF]SERNUMSEL<>"")
  WFIL += " & pat([F:QLD1]SERNUM,[M:CSRF]SERNUMSEL)"
Endif
Return
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End
############################################################
Subprog C_DEMSEL(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Affzo [M:SRF1]ITMREF
Affzo [M:SRF1]LOTSEL
End
############################################################
Subprog C_QSTNUM(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SRF") From SUBGTC

End

