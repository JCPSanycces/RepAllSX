If !clalev([F:TCY])  Local File =SI_DOSSIER+".TABCOUNTRY" [TCY] : Endif
If !clalev([F:TCO])  Local File =SI_DOSSIER+".TABCOEFF"   [TCO] : Endif
If !clalev([F:TVT])  Local File =SI_DOSSIER+".TABVAT"     [TVT] : Endif
If !clalev([F:GAC])  Local File =SI_DOSSIER+".GACCOUNT"   [GAC] : Endif
