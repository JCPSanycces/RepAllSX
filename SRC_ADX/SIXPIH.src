If !clalev([F:ACV])  Local File =SI_DOSSIER+".ACTIV"      [ACV] : Endif
#-----
If !clalev([F:PIX])
  Link [PIDB] With [PIHB] PIH0=[F:PIDB]NUM As [PIX]
Endif
#----- Test présence avant ouverture car normalement conditionné par GMODU(x) -----#
If filinfo(filpath("FIL","SINVOICE",   "fde",SI_DOSSIER),0)>=0
 If !clalev([F:SIH]) Local File =SI_DOSSIER+".SINVOICE"   [SIH] : Endif
Endif
If filinfo(filpath("FIL","SINVOICEV",  "fde",SI_DOSSIER),0)>=0
 If !clalev([F:SIV]) Local File =SI_DOSSIER+".SINVOICEV"  [SIV] : Endif
Endif
If filinfo(filpath("FIL","SINVOICED",  "fde",SI_DOSSIER),0)>=0
 If !clalev([F:SID]) Local File =SI_DOSSIER+".SINVOICED"  [SID] : Endif
Endif
#--------------------------------------------#
# Ouvertures complémentaires des tables "X3" #
#--------------------------------------------#
If !clalev([F:BPT])  Local File =SI_DOSSIER+".BPCARRIER"  [BPT] : Endif
If !clalev([F:PPL])  Local File =SI_DOSSIER+".PPRICLIST"  [PPL] : Endif
If !clalev([F:GTE])  Local File =SI_DOSSIER+".GTYPACCENT" [GTE] : Endif
If !clalev([F:CCE])  Local File =SI_DOSSIER+".CACCE"      [CCE] : Endif
If !clalev([F:AVN])  Local File =SI_DOSSIER+".AVALNUM"    [AVN] : Endif
If !clalev([F:ANM])  Local File =SI_DOSSIER+".ACODNUM"    [ANM] : Endif
If !clalev([F:AXX])  Local File =SI_DOSSIER+".ATEXTRA"    [AXX] : Endif
If !clalev([F:TCC])  Local File =SI_DOSSIER+".TEXCPT"     [TCC] : Endif
If !clalev([F:TXC])  Local File =SI_DOSSIER+".TEXCLOB"    [TXC] : Endif
If !clalev([F:TVC])  Local File =SI_DOSSIER+".TABVAC"     [TVC] : Endif
If !clalev([F:AGC])  Local File =SI_DOSSIER+".AGRPCPY"    [AGC]  : Endif
Return


############################################################
# CALNBENR : Compte le nombre d'enregistrement déjà traité #
#            et le nombre d'enregistrement total à traiter #
# -------------------------------------------------------- #
# Appelé depuis le traitement SUBSIM                       #
# La clase [M:SIM2] doit être ouverte et chargée           #
# WNOL est l'indice de la ligne en cours de traitement     #
# -------------------------------------------------------- #
# En sortie :                                              #
#    [M:SIM2]NB2TRT chargé avec nbre total à traiter       #
#    LMES chargé avec "nbre traité / nbre total"           #
############################################################
Funprog CALNBENR(WNOL)
Value Integer WNOL
#-----
Local Char    LMES(30)
Local Integer WNBFAC
#-----
If !clalev([F:SPX])  Local File =SI_DOSSIER+".SIPARX3"  [SPX] : Endif
Read [SPX] SPX0 First : If fstat  Raz [F:SPX] : Endif
#----- Nombre total d'enregistrements reste à traiter -----#
Local File XIEPA [XEPA] Where find(TYPPIE,"FF","AF","AA")<>0
&                           & FLGMAJ="C"
&                           & FLGREP<2
&                           & DATPIE>=[F:SPX]STRPER
WNBFAC=rowcount([XEPA])
Close Local File [XEPA]
#-----
LMES=num$(WNBFAC)-"/"
#----- Nombre total d'enregistrements à traiter -----#
Local File XIEPA [XEPA] Where find(TYPPIE,"FF","AF","AA")<>0
&                           & FLGMAJ="C"
&                           & DATPIE>=[F:SPX]STRPER
WNBFAC=rowcount([XEPA])
Close Local File [XEPA]
#-----
LMES-=num$(WNBFAC)
[M:SIM4]NB2TRT(WNOL)=WNBFAC
#-----
End LMES
