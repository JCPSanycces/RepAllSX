######################################################################################
## Etiquette ajoutée par le superviseur (écran SOHA) 09/03/2006 17:53:00 (LD)
######################################################################################
Subprog AV_DISCRGVAL5(VALEUR)
  Variable Decimal VALEUR

  Local Char WSTYLE : WSTYLE="AWARNHIGH"

  #--- Pas de colorisation si derni?re ligne ---#
  If nolign>=[M:SOHA]NBLIG End : Endif

  #--- Si valeur rubrique différente de la ligne suivante alors affichage spécial ---#
  If [M:SOHA]DISCRGVAL5(nolign-1) <> [M:SOHA]DISCRGVAL5(nolign)
      Chgstl [M]DISCRGVAL5(nolign-1) With WSTYLE
  Else
      Chgstl [M]DISCRGVAL5(nolign-1) With ""
  Endif

End

