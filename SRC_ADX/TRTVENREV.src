#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# TRTVENREV         Traitements liés aux avenants         Module VENTES #
#########################################################################
# ACTIONS : VISUREV  (GSAISIE)  Visualisation des avenants              #
#   PARAM(1) = NUM    : Numéro   de la commande                         #
#   PARAM(2) = LIN    : Numéro   de la ligne de commande                #
#   PARAM(3) = SEQ    : Séquence de la ligne de commande                #
#   PARAM(4) = WABMSK : Abréviation du masque écran des lignes          #
#   PARAM(5) = NOLIG  : Numéro de ligne de la commande (nolign-1)       #
#########################################################################

$ACTION
#Infbox ACTION
  Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "TITRE"      : Gosub LETITRE
   When "DEBUT"      : Gosub DEBUT
   When "FINSAI"     : Gosub FINSAI
  Endcase
Return

#########################################################################
#           Actions related to the type of input window                 #
#########################################################################

#--- before defining buttons and opening the window
$OUVRE
  Case GACTION
   When "VISUREV"  : Gosub OUV_VISUREV
   When "VISUREVQ" : Gosub OUV_VISUREVQ
  Endcase
Return

#--- before opening the window
$LETITRE
  Case GACTION
   When "VISUREV"   : TIT=mess(174,195,1)
   When "VISUREVQ"  : TIT=mess(174,195,1)
  Endcase
Return

#--- after opening the window
$DEBUT
  Case GACTION
   When "VISUREV"  : Gosub DEB_VISUREV
   When "VISUREVQ"  : Gosub DEB_VISUREVQ
  Endcase
Return

#--- before returning to previous window
$FINSAI
  Case GACTION
   When "VISUREV"  : Gosub FINSAI_VISUREV
  Endcase
Return






#########################################################################
$OUV_VISUREV
  Local Char     NUMCDE  : NUMCDE = PARAM(1)
  Local Integer  LINCDE  : LINCDE = val(PARAM(2))
  Local Integer  SEQCDE  : SEQCDE = val(PARAM(3))
  Local Char     WABMSK  : WABMSK  = PARAM(4)
  Local Shortint NOL     : NOL    = val(PARAM(5))
  Local Shortint SAVGNOLIGN
  SAVNOLIGN=nolign
  If evalue("[M:"+WABMSK+"]LINREVNUM(NOL)=0") | evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") | GREP="C" | GREP="D"
    FIN=1
  Endif
Return
#########################################################################
$OUV_VISUREVQ
  Local Char     NUMCDE  : NUMCDE = PARAM(1)
  Local Integer  LINCDE  : LINCDE = val(PARAM(2))
  Local Char     WABMSK  : WABMSK  = PARAM(3)
  Local Shortint NOL     : NOL    = val(PARAM(4))
  Local Shortint SAVGNOLIGN
  SAVNOLIGN=nolign
#  If evalue("[M:"+WABMSK+"]LINREVNUM(NOL)=0") | evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") | GREP="C" | GREP="D"
#    FIN=11
#  Endif

Return


#########################################################################
$DEB_VISUREV

  Raz [M:SOHA]
  Call TEMPON("O") From GESECRAN

  #----- Lecture ligne commande ? traiter si nécessaire -------------------
  If [F:SOQ]SOHNUM<>NUMCDE | [F:SOQ]SOPLIN<>LINCDE | [F:SOQ]SOQSEQ<>SEQCDE
    Read [SOQ] SOQ0=NUMCDE;LINCDE;SEQCDE : If fstat Raz [F:SOQ] : Endif
  Endif
  If [F:SOP]SOHNUM<>NUMCDE | [F:SOP]SOPLIN<>LINCDE | [F:SOP]SOPSEQ<>SEQCDE
    Read [SOP] SOP0=NUMCDE;LINCDE;SEQCDE : If fstat Raz [F:SOP] : Endif
  Endif

  #----- Ouverture des fichiers si nécessaire -----------------------------
  If clalev([F:VOQ])<=0 Local File VSORDERQ [VOQ] : Endif
  If clalev([F:VOP])<=0 Local File VSORDERP [VOP] : Endif

  #----- Chargement des zones dans le masque ------------------------------
  nolign=1

  #--- Loading 1st row of the table
  [M:SOHA]=[F:SOQ] : [M:SOHA]=[F:SOP]
  [M:SOHA]LINREVDAT(0) = [F:SOQ]UPDDAT
  [M:SOHA]DSTOFCY(0)   = [F:SOQ]STOFCY
  [M:SOHA]VACITM1(0)   = [F:SOP]VACITM(0)
  [M:SOHA]VACITM2(0)   = [F:SOP]VACITM(1)
  [M:SOHA]VACITM3(0)   = [F:SOP]VACITM(2)
  [M:SOHA]DDLVPIO(0)   = [F:SOQ]DLVPIO
  [M:SOHA]DBPTNUM(0)   = [F:SOQ]BPTNUM
  [M:SOHA]DMDL(0)      = [F:SOQ]MDL
  [M:SOHA]DDRN(0)      = [F:SOQ]DRN
  [M:SOHA]DDEMDLVDAT(0)= [F:SOQ]DEMDLVDAT
  [M:SOHA]DSHIDAT(0)   = [F:SOQ]SHIDAT
  [M:SOHA]DDAYLTI(0)   = [F:SOQ]DAYLTI
  [M:SOHA]DBPAADD(0)   = [F:SOP]BPAADD
  [M:SOHA]DCCLREN(0)   = [F:SOQ]CCLREN
  [M:SOHA]DCCLDAT(0)   = [F:SOQ]CCLDAT

  # 107890 : Scheduled invoices : (LD:04/05/16)
  [M:SOHA]DINVCND(0)   = [F:SOP]INVCND
  # 107890 : Scheduled invoices : (LD:04/05/16)

  # 71065/30 : PJT: Update screens and tables : (LD:04/05/16)
  [M:SOHA]DPJT(0)      = [F:SOQ]PJT
  # 71065/30 : PJT: Update screens and tables : (LD:04/05/16)

  #----- Chargement des comptes et sections analytiques -----#
  Call CHARG_ACCCCE(0,"","","[M:SOHA]CCE","SOP", 0,[F:SOP]SOHNUM,[F:SOP]SOPLIN,[F:SOP]SOPSEQ,"") From TRTX3CPT

  #--- Chargement des autres lignes du tableau
  Filter [VOQ] Where SOHNUM=NUMCDE & SOPLIN=LINCDE Order By Key VOQ0 Desc
  For [VOQ]
    If [F:VOQ]REVCOD="A" Break: Endif
    Read [VOP] VOP0=[F:VOQ]SOHNUM;[F:VOQ]LINREVNUM;LINCDE;[F:VOQ]SOQSEQ
    If fstat Raz [F:VOP] : Endif
    nolign+=1
    [M:SOHA]=[F:VOQ] : [M:SOHA]=[F:VOP]
    [M:SOHA]LINREVDAT(nolign-1) = [F:VOQ]CREDAT
    [M:SOHA]LINREVDAT(nolign-1) = [F:VOQ]UPDDAT
    [M:SOHA]DSTOFCY(nolign-1)   = [F:VOQ]STOFCY
    [M:SOHA]VACITM1(nolign-1)   = [F:VOP]VACITM(0)
    [M:SOHA]VACITM2(nolign-1)   = [F:VOP]VACITM(1)
    [M:SOHA]VACITM3(nolign-1)   = [F:VOP]VACITM(2)
    [M:SOHA]DDLVPIO(nolign-1)   = [F:VOQ]DLVPIO
    [M:SOHA]DBPTNUM(nolign-1)   = [F:VOQ]BPTNUM
    [M:SOHA]DMDL(nolign-1)      = [F:VOQ]MDL
    [M:SOHA]DDRN(nolign-1)      = [F:VOQ]DRN
    [M:SOHA]DDEMDLVDAT(nolign-1)= [F:VOQ]DEMDLVDAT
    [M:SOHA]DSHIDAT(nolign-1)   = [F:VOQ]SHIDAT
    [M:SOHA]DDAYLTI(nolign-1)   = [F:VOQ]DAYLTI
    [M:SOHA]DBPAADD(nolign-1)   = [F:VOP]BPAADD
    [M:SOHA]DCCLREN(nolign-1)   = [F:VOQ]CCLREN
    [M:SOHA]DCCLDAT(nolign-1)   = [F:VOQ]CCLDAT

    # 107890 : Scheduled invoices : (LD:04/05/16)
    [M:SOHA]DINVCND(nolign-1)   = [F:VOP]INVCND
    # 107890 : Scheduled invoices : (LD:04/05/16)

    # 71065/30 : PJT: Update screens and tables : (LD:04/05/16)
    [M:SOHA]DPJT(nolign-1)      = [F:VOQ]PJT
    # 71065/30 : PJT: Update screens and tables : (LD:04/05/16)

    Call CHARG_ACCCCE(nolign-1,"","","[M:SOHA]CCE","VOP", 0,[F:VOP]SOHNUM,[F:VOP]SOPLIN,[F:VOP]SOPSEQ,num$([F:VOP]LINREVNUM)) From TRTX3CPT
    #Fq77211-Gbn-Valeur max en dur remplacée par dim du tableau
    If nolign>=dim([M:SOHA]NOLIGNE) Call MESSAGE(mess(26,100,1)) From GESECRAN : Break : Endif
  Next
  [M:SOHA]NBLIG=nolign

  #--- Chargement zones d'ent?te
  [M:SOHA]SOHNUM = NUMCDE
  [M:SOHA]SOPLIN = LINCDE
  [M:SOHA]ITMREF = evalue("[M:"+WABMSK+"]ITMREF(NOL)")
  # [M:SOHA]CUR    = GCUR
  If WABMSK="SOH4" : [M:SOHA]CUR=[M:SOH0]CUR : Endif
  [M:SOHA]FMTREM = evalue("[M:"+WABMSK+"]FMTREM")

  #----- Affichage foreground ---------------------------------------------
  Filter [VOQ] : Filter [VOP]
  Affzo [SOHA]

Call TEMPOFF From GESECRAN

Return

######################################################################################

$DEB_VISUREVQ
# Issue X3-57674 : X3-71864 - 2018-01-18 by APL

Raz [M:SQHA]

[M:SQHA]SQHNUM = NUMCDE
[M:SQHA]LINE = [M:SQH2]SQDLIN(nolign-1)
[M:SQHA]ITMREFQ = [M:SQH2]ITMREF(nolign-1)
[M:SQHA]CUR = [M:SQH0]CUR


If clalev([F:SQD])<=0 Local File SQUOTED [SQD] : Endif
Filter [SQD] Where [SQD]SQHNUM= [M:SQHA]SQHNUM  & [SQD]SQDLIN = [M:SQHA]LINE
Read [SQD] First

nolign = 1
[M:SQHA] = [F:SQD]
[M:SQHA]LINREVNUM(0) = [F:SQD]LINREVNUM
[M:SQHA]VACITM1(0)   = [F:SQD]VACITM(0)
[M:SQHA]VACITM2(0)   = [F:SQD]VACITM(1)
[M:SQHA]VACITM3(0)   = [F:SQD]VACITM(2)
Filter [SQD]

Filter [VQD]
If clalev([F:VQD])<=0 Local File VSQUOTED [VQD] : Endif
Filter [VQD] Where [F:VQD]SQHNUM=NUMCDE & [VQD]SQDLIN=LINCDE & [F:VQD]REVCOD <> 'B' Order By Key SQD0  Desc

  For [VQD]
    nolign+=1
    [M:SQHA] = [F:VQD]
    [M:SQHA]VACITM1(nolign-1)   = [F:VQD]VACITM(0)
    [M:SQHA]VACITM2(nolign-1)   = [F:VQD]VACITM(1)
    [M:SQHA]VACITM3(nolign-1)   = [F:VQD]VACITM(2)
  Next
[M:SQHA]NBLIG = nolign

Filter [VQD]

Affzo [M:SQHA]1-99

Return

######################################################################################

$FINSAI_VISUREV

nolign=SAVNOLIGN

Return

