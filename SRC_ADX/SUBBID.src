#######################################################################
# SUBBID : Gestion des R.I.B                                          #
#######################################################################
# Gestion des masques BIDBPR, BIDBPC, BIDBPS, BIDBPT                  # 
#######################################################################
# Ces masques sont des copies du masque superviseur BID               #
#######################################################################
# Dans ttes les actions, on pointe sur le trt superviseur TRTBPA      #
#######################################################################
#MAE, le 07/10/08, bg 49160
$ACTION

Return
# --------------------------------------- NBRIB -------------------------------
Subprog IB_NBRIB
Call IB_NBRIB From TRTBPA
End
########################################
Subprog B1_NBRIB
Call B1_NBRIB From TRTBPA
End
########################################
Subprog AVANT_NBRIB
Call AVANT_NBRIB From TRTBPA
End
########################################
Subprog APRES_NBRIB
Call APRES_NBRIB From TRTBPA
End
########################################
Subprog AS_NBRIB
  # FGR 04/01/2010 : X3SUIVI61159 (début)
  If GFONCTION = "GESBPC" Then
    Call CTRL_TABLEAU_SAISI("BIDBPC", "NBRIB") From TRTX3FNC
  Elsif GFONCTION = "GESBPR" Then
    Call CTRL_TABLEAU_SAISI("BIDBPR", "NBRIB") From TRTX3FNC
  Elsif GFONCTION = "GESPBPS" Then
    Call CTRL_TABLEAU_SAISI("BIDBPS", "NBRIB") From TRTX3FNC
  Elsif GFONCTION = "GESBPT" Then
    Call CTRL_TABLEAU_SAISI("BIDBPT", "NBRIB") From TRTX3FNC
  Endif
  If mkstat = 2 Then
    End
  Endif
  # FGR 04/01/2010 : X3SUIVI61159 (fin)
End
########################################
