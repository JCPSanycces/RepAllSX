Call C_BIDBPAADD(VALEUR) From TRTBPA
End
########################################
Subprog CRE_IBAN(IBACOD,CRY,BICCOD,NUMBER)
Variable Char IBACOD()
Value    Char CRY()
Value    Char BICCOD()
Value    Char NUMBER()
Local Char CNUMBERI(34), CI(2), CNUMBERO(50)
Local Integer D, I
Local Decimal INUMBER, INUMBER1, INUMBER2
# Bug 22798 : Le code IBAN est initialisé si le code Pays CEE est renseigné
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    Read [TCY]TCY0 = CRY
# FQ59624 - MABON 06/11/09 - On teste si "Gestion de l'IBAN" est coché pour le pays
#    If fstat | [F:TCY]EECCOD=""
    If fstat | (func FICMAG.TYPID(CRY)="2")
        End
    Endif
# Fin Bug 22798

# <PP 22/07/03> Bug 18910 : Le code BIC ne doit pas se concaténer avec le code RIB pour le calcul du code IBAN
#CNUMBERI = BICCOD+NUMBER+CRY+"00"
CNUMBERI = NUMBER+CRY+"00"
For I=1 To len(CNUMBERI) 
 CI=mid$(CNUMBERI,I,1)
 If CI>"9"
  CI=num$(ascii(CI)-55)
 Endif
 CNUMBERO += CI
Next I
If len(CNUMBERO)<=32
 INUMBER = val(CNUMBERO)
 D = 98-mod(INUMBER,97)
Else
 INUMBER1 = val(left$(CNUMBERO,32))
 INUMBER2 = val(right$(CNUMBERO,33))
 D = mod(mod(INUMBER1,97)*10^^(len(CNUMBERO)-32)+mod(INUMBER2,97),97)
 D = 98-D
Endif
# <PP 22/07/03> Bug 18910 : Le code BIC ne doit pas se concaténer avec le code RIB pour le calcul du code IBAN
# et bug 18965 : Si le digit de contrôle était < à 10, le résultat obtenu était sur 1 caractère et n'était pas préfixé du 0.
#IBACOD = CRY+format$("##",D)+BICCOD+NUMBER
If D<10
 IBACOD = CRY+"0"+num$(D)+NUMBER
Else
 IBACOD = CRY+format$("##",D)+NUMBER
Endif
End

######################################################################################
