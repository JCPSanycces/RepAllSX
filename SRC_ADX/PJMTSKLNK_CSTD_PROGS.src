#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTSKLNK
# Issue X3-26991/X3-43920 - 2017-06-30 by FGR
###################################################################################################
Funprog IS_LINKED_SOMEWHERE_ELSE(ACTX, PROJECT, TASK, RPROJECT, RTASK)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char PROJECT
Value Char TASK
Variable Char RPROJECT
Variable Char RTASK

Local Integer IARENDRE
Local Char SPIMPL(GLONPIM)

  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR
  IARENDRE = [V]CST_ANO
  Raz RPROJECT
  Raz RTASK
  SPIMPL = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(ACTX, PROJECT, TASK)
  Local File PJMTSKLNK [PTLNK]
  Filter [PTLNK] Where [F:PTLNK]OPPNUM <> PROJECT and [F:PTLNK]PIMOPPTASLNK = SPIMPL
  For [PTLNK]
    RPROJECT = [F:PTLNK]OPPNUM
    RTASK = [F:PTLNK]TASCOD
    IARENDRE = [V]CST_AYES
    Break
  Next
  Filter [PTLNK]
End IARENDRE

###################################################################################################
Funprog IS_LINKED(ACTX, PROJECT, TASK, RPROJECT, RTASK)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char PROJECT
Value Char TASK
Variable Char RPROJECT
Variable Char RTASK

Local Integer IARENDRE
Local Char SPIMPL(GLONPIM)

  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR
  IARENDRE = [V]CST_ANO
  Raz RPROJECT
  Raz RTASK
  SPIMPL = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(ACTX, PROJECT, TASK)
  Local File PJMTSKLNK [PTLNK]
  Filter [PTLNK] Where [F:PTLNK]PIMOPPTASLNK = SPIMPL
  For [PTLNK]
    RPROJECT = [F:PTLNK]OPPNUM
    RTASK = [F:PTLNK]TASCOD
    IARENDRE = [V]CST_AYES
    Break
  Next
  Filter [PTLNK]
End IARENDRE

