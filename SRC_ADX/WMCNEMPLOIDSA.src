#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## ACLA-CLASSE ## EMPLOIDSA
# 2018-11-06 07:05:53 527

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOIDSA
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_SECNAM From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_MADNAM From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_DISRSN From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_NBRADD From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_NBRPAS From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_BUSTEL From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_FINTAXCLC From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_RSAID From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_ETHGRP From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_RCEGRP From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_EMPTAXNR From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_LNRSKL From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOIDSA : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOIDSA
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOIDSA
Gosub LNKPRO_REFNUM From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub LNKPRO_DISRSN From WMC1EMPLOIDSA : Gosub TESTALLSTAT
For AINDCLA=1 To 3
 If this.EMPADR(AINDCLA)<>null& find(this.EMPADR(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EMPADR(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 3
 If this.PASDET(AINDCLA)<>null& find(this.PASDET(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.PASDET(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_BUSTEL From WMC1EMPLOIDSA : Gosub TESTALLSTAT
For AINDCLA=1 To 3
 If this.PERCNT(AINDCLA)<>null& find(this.PERCNT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.PERCNT(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_CREUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EMPLOIDSA : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



