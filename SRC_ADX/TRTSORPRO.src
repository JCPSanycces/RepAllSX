#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
# Traitement standard de proposition de sortie                     V140 #
#    Action TRTSORPRO                                                   #
#########################################################################
# Appelé depuis la saisie des sorties TRTSTOSOR      Action SAISTOSOR   #
#########################################################################

#########################################################################
$ACTION
#--- Actions liées au traitement standard TRTSORPRO
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase

#--- Actions liés à la fenêtre de saisie IALLFIL
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
 When "END"         : Gosub ACTEND
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

#########################################################################
$INIT

If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITG])=0  Local File ITMCATEG   [ITG]  Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITV])=0  Local File ITMMVT     [ITV]  Endif
If clalev([F:TRU])=0  Local File TABALLRUL  [TRU]  Endif
If clalev([F:SRU])=0  Local File TABSTORUL  [SRU]  Endif
If clalev([F:STL])=0  Local File STOLOT     [STL]  Endif
If clalev([F:STC])=0  Local File STOLOC     [STC]  Endif

Global Shortint GLFIN   : GLFIN=0

Return

#########################################################################
$OUVRE_BOITE

Local  Integer WA,WQ,WR,LRET
Global Integer GFILTREAQR
Global Char    GTRUCOD(6)
Global Integer GLRET         : Raz GLRET
Global Char    GCHARGRUPT(1)

GBIDC1 = mess([M:SOR]VCRTYP,701,1)

# Lecture des tables article
Call LECITM([M:SOR]STOFCY,[M:SOR]ITMREF,"",0,"",LRET) From STKLIB
If LRET<>0
   FIN=1 : GLRET=1 : Return
Endif

# Récupération de la règle d'allocation
Case [M:SOR]VCRTYP
 When 3,4,5,8        : # Préparation/Livraison sous-traitance
                       If [M:SOR]TRSTYP=20
                          GTRUCOD = [F:ITG]ALLRULSCO
                       # Préparation, Livraison, Facture, Retour fou
                       Else
                          GTRUCOD = [F:ITG]ALLRULSHI
                       Endif
 When 6              : # Réception (conso matières sous-traitance)
                       GTRUCOD = [F:ITG]ALLRULSCC
 When 12             : # Suivi matière (opération de sous-traitance)
                       If [M:SOR]PECSCOLOC=2
                          GTRUCOD = [F:ITG]ALLRULSCC
                       # Suivi matière (interne)
                       Else
                          GTRUCOD = [F:ITG]ALLRULMFG
                       Endif
 When 20,29,31,32,33 : # Sortie diverse, Changement de stock,
                       # Assemblage, Désassemblage, Demande de service
                       GTRUCOD = [F:ITG]ALLRULTRF
 When 34             : # Réappro zones de consommation
                       If [M:ALP]LOCCAT=4
                          GTRUCOD = [F:ITG]ALLRULSCO
                       Else
                          GTRUCOD = [F:ITG]ALLRULTRF
                       Endif
 When Default
Endcase

Raz [F:TRU]
If GTRUCOD<>""
   # Lecture règle d'allocation
   Read [TRU]TRU0=GTRUCOD
   If fstat Raz GTRUCOD Endif
Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([M:SOR]STOFCY,[F:ITM]TCLCOD,[M:SOR]TRSTYP,[M:SOR]TRSCOD,"",LRET) From STKLIB
If LRET<>0
   FIN=1 : GLRET=1 : Return
Endif

# Statuts autorisés par la règle de gestion
If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
GFILTREAQR = WA+2*WQ+4*WR

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Raz [M:ALF]

[M:ALF]STOFCY = [M:SOR]STOFCY
[M:ALF]ITMREF = [M:SOR]ITMREF
[M:ALF]VCRNUM = [M:SOR]VCRNUM
[M:ALF]VCRTYP = [M:SOR]VCRTYP

# Chargement des filtres avec le filtre issu du détail stock
If dim([M:ALF]LOT)>0    [M:ALF]LOT   =[M:SOR]XLOT    Endif
If dim([M:ALF]LOC)>0    [M:ALF]LOC   =[M:SOR]XLOC    Endif
If dim([M:ALF]LOCTYP)>0 [M:ALF]LOCTYP=[M:SOR]XLOCTYP Endif
[M:ALF]STA = [M:SOR]XSTA

Affzo [M:ALF]

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR

If dim([M:ALF]LOT)>0    [M:SOR]XLOT   =[M:ALF]LOT    Endif
If dim([M:ALF]LOC)>0    [M:SOR]XLOC   =[M:ALF]LOC    Endif
If dim([M:ALF]LOCTYP)>0 [M:SOR]XLOCTYP=[M:ALF]LOCTYP Endif
[M:SOR]XSTA = [M:ALF]STA

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

#########################################################################
$ACTEND

GLFIN=1

Return

#########################################################################
$FINSAI

If GOK=1 mkstat=4 Endif

Return

#########################################################################
$CONTROLE

If GLFIN=1 FIN=1 Endif

Return

#########################################################################
$EXEC
Local Integer LRUP, LRET, LFULLTAB
Local Char    WTRUCOD
Local Integer WSTA, WA, WQ, WR, WLOC
Local Integer I, J, K, L
Local Decimal SVGQTY, WSTUACTDIS

# Si problème dans le GSAISIE
If GLRET=1
   FIN=1 : Return
Endif

# Effacement des saisies ou propositions précédentes
Raz [M:SOR]PECQTY,[M:SOR]PECQTYACT,[M:SOR]SHTQTY
Effzo [M:SOR]15

# Rechargement des sorties en cours (SORW)
GCHARGRUPT = "N"
Gosub ALI_MSK_SOR From TRTSTOSOR

# Chargement des paramètres pour l'algorithme d'allocation
Raz [M:ALP]
[M:ALP] = [M:SOR]

[M:ALP]TYPQTY = 2
[M:ALP]QTY    = [M:SOR]SORQTYACT-([M:SOR]PECQTYACT+[M:SOR]SHTQTY)

[M:ALP]ALLQTY = [M:SOR]GLOALLQTY

# Pas de quantité à traiter
If [M:ALP]QTY<=0
   Call MESSAGE(mess(458,199,1)) From GESECRAN
   Goto EXEC_SUITE
Endif

[M:ALP]BESDAT = [M:SOR]RETDAT
[M:ALP]ALLDAT = [31/12/2999]
[M:ALP]PECRER = 1

# Si Suivi OF
If [M:SOR]VCRTYP = 12
   [M:ALP]PECSCOLOC = [M:SOR]PECSCOLOC
# Sinon si réception sous-traitance
Elsif [M:SOR]VCRTYP = 6
   [M:ALP]PECSCOLOC = 2
Else
   [M:ALP]PECSCOLOC = 1
Endif
# Pas de prise en compte du stock en cours d'inventaire
[M:ALP]PECCUNLOK  = 1
# Pas de prise en compte du stock avec demande d'analyse
[M:ALP]PECQLYCTL  = 1
[M:ALP]FILSTO     = ""
[M:ALP]LOT        = [M:SOR]XLOT
[M:ALP]LOC        = [M:SOR]XLOC
[M:ALP]STA        = [M:SOR]XSTA
[M:ALP]LOCTYP     = [M:SOR]XLOCTYP
[M:ALP]WRH        = [M:SOR]XWRH
#--- TS 106217
[M:ALP]ECCVALMAJ  = [M:SOR]WECCVALMAJ

# Récupération règle d'allocation et statuts autorisés
WTRUCOD = GTRUCOD
WSTA    = GFILTREAQR

Raz WLOC
# Prise en compte emplacement quai (en attente de rangement)
If [M:ALP]PECPLFLOC=2 WLOC+=1  Endif
# Prise en compte emplacement sous-traitant
If [M:ALP]PECSCOLOC=2 WLOC+=4  Endif
# Si pas d'emplacements internes
If [M:ALP]PECINTLOC=1 WLOC=WLOC*(-1) Endif
# Calcul stock disponible
Call STODISTOT("",WLOC,WSTA,[M:ALP]PECOWNER,WSTUACTDIS) From STKLIB

# On rajoute l'allouée global (limité à la qté à traiter)
WSTUACTDIS += min([M:ALP]QTY,[M:ALP]ALLQTY)

SVGQTY = [M:ALP]QTY
# Si pas de stock disponible, pas de proposition
If WSTUACTDIS <=0 Goto EXEC_SUITE Endif
# Si quantité disponible < quantité à sortir, on appelle l'algo avec
# comme quantité à sortir, la quantité disponible
If WSTUACTDIS<[M:ALP]QTY [M:ALP]QTY=WSTUACTDIS Endif

LRUP=1
# Appel à l'algorithme d'allocation/sortie
Call STOCKALG(LRUP,WTRUCOD,LFULLTAB,LRET) From STKALL
If LRET<>0 & GMESSAGE<>""
   Call MESSAGE(GMESSAGE) From GESECRAN
   Goto EXEC_SUITE
Endif

K = [M:SOR]NBLIG
For I=0 To [M:ALP]NBLIG-1
   J=[M:ALP]NLIG(I)
   Break ([M:ALP]WFLG(J)=0)
   If [M:ALP]WQTYSTUACT(J)<>0
      Read [STO]STO0=[M:ALP]STOFCY;[M:ALP]WSTOCOU(J)
      If !fstat
         # Recherche si la ligne proposée est déjà dans le tableau
         L=find([M:ALP]WSTOCOU(J),[M:SOR]STOCOU(0..[M:SOR]NBLIG-1))
         # Elle est déjà dans le tableau --> on cumule dessus
         If L>0
            L-=1
            [M:SOR]QTYSTU(L)    += [M:ALP]WQTYSTU(J)
            [M:SOR]QTYSTUACT(L) += [M:ALP]WQTYSTUACT(J)
            If [M:SOR]XPCUSTUCOE(L)=0 [M:SOR]XPCUSTUCOE(L)=1 Endif
            [M:SOR]QTYPCU(L)     = [M:SOR]QTYSTU(L)/[M:SOR]XPCUSTUCOE(L)

            [M:SOR]PECQTY       += [M:ALP]WQTYSTU(J)
            [M:SOR]PECQTYACT    += [M:ALP]WQTYSTUACT(J)
         # C'est une nouvelle ligne
         Else
            If dim([M:SOR]LOT)>0
               [M:SOR]LOT(K) = [F:STO]LOT
               If dim([M:SOR]SLO)>0 [M:SOR]SLO(K)=[F:STO]SLO Endif
               If dim([M:SOR]POT)>0
                  Read [STL]STL0=[M:SOR]ITMREF;[F:STO]LOT;[F:STO]SLO
                  If !fstat
                     If [M:SOR]STOMGTCOD=3
                        [M:SOR]POT(K) = [F:STL]POT
                     Elsif [M:SOR]STOMGTCOD=4
                        [M:SOR]POT(K) = [F:STL]ACT
                     Endif
                  Endif
               Endif
            Endif
            [M:SOR]TOTQTYSTU(K)  = [F:STO]QTYSTU
            If dim([M:SOR]WRH)>0     [M:SOR]WRH(K)    = [M:ALP]WWRH(J)    Endif
            If dim([M:SOR]LOC)>0     [M:SOR]LOC(K)    = [M:ALP]WLOC(J)    Endif
            If dim([M:SOR]SERNUM)>0  [M:SOR]SERNUM(K) = [M:ALP]WSERNUM(J) Endif
            If dim([M:SOR]SERNUMF)>0 [M:SOR]SERNUMF(K)= [M:ALP]WSERNUM(J) Endif
            If dim([M:SOR]SHLDAT)>0  [M:SOR]SHLDAT(K) = [M:ALP]WSHLDAT(J) Endif
            #--- Issue X3-53322
            If dim([M:SOR]LPNNUM)>0  [M:SOR]LPNNUM(K) = [M:ALP]WLPNNUM(J) Endif
            [M:SOR]STA(K)        = [M:ALP]WSTA(J)
            [M:SOR]STOCOU(K)     = [M:ALP]WSTOCOU(J)
            [M:SOR]QTYSTU(K)     = [M:ALP]WQTYSTU(J)
            [M:SOR]QTYSTUACT(K)  = [M:ALP]WQTYSTUACT(J)
            [M:SOR]AVAQTYSTU(K)  = [M:ALP]WQTYSTUAVA(J)
            [M:SOR]XPCU(K)       = [M:ALP]WPCU(J)
            [M:SOR]XPCUSTUCOE(K) = [M:ALP]WPCUSTUCOE(J)
            If [M:SOR]XPCUSTUCOE(K)=0 [M:SOR]XPCUSTUCOE(K)=1 Endif
            [M:SOR]QTYPCU(K)     = [M:SOR]QTYSTU(K)/[M:SOR]XPCUSTUCOE(K)
            [M:SOR]AVAQTYPCU(K)  = [M:SOR]AVAQTYSTU(K)/[M:SOR]XPCUSTUCOE(K)
            Raz [M:SOR]ALLSTU(K), [M:SOR]ALLSTUACT(K)

            [M:SOR]PECQTY    += [M:SOR]QTYSTU(K)
            [M:SOR]PECQTYACT += [M:SOR]QTYSTUACT(K)
            K += 1
         Endif
      Endif
   Endif
Next I

[M:SOR]NBLIG = K

$EXEC_SUITE
[M:ALP]QTY = SVGQTY

# Affichage de la proposition
Affzo [M:SOR]1-99

Return

#########################################################################
$TERMINE

Return

