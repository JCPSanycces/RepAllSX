#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
Subprog CHARGE_RETENUES(CAS,SOCIETE,TYPPAH,NUMPAH,DATPAH,TVCRNUM,TDUDNUM,TDUDLIG,NBDOC)
Value    Integer CAS        : # Cas d'appel : 1:Saisie OP  2:Proposition auto
Value    Char    SOCIETE()
Value    Integer TYPPAH
Value    Char    NUMPAH()
Value    Date    DATPAH()
Value    Char    TVCRNUM()(0..)
Value    Integer TDUDNUM(0..)
Value    Integer TDUDLIG(0..)
Value    Integer NBDOC
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH] : Endif
If clalev([F:PIL])=0  : Local File BPSINVLIG  [PIL] : Endif
If clalev([F:TVT])=0  : Local File TABVAT     [TVT] : Endif
If GMODU(5)=2
 If clalev([F:PID])=0 : Local File PINVOICED [PID] : Endif
Endif
## Chargement des retenues intervenant dans l'ordre de paiement
If TYPPAH = 1 & func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGRTZ",SOCIETE)="2" # Issue X3-107197
 ## Parcours de la table RITDUD avec TYPREC=1 (Enregistrement type 'Détail' (par échéance))
 If clalev([F:RIU])=0 : Local File RITDUD     [RIU] : Endif
 If clalev([F:RTZ])=0 : Local File RITENZIONE [RTZ] : Endif
 Local Integer NUMRET, NOLI, NOL2, X, VU
 Local Decimal AMTREA
 Local Char    PLAN(GLONCOA)
 Local Char    TFCYLIN(GLONFCY)(0..99), TACC(GLONGAC)(0..99)
 Local Decimal TAMTNOTLIN(0..99)
 Local Decimal TAMTVAT(0..99)
 Local Integer NBLIGFAC
 Local Integer INDREF

 Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
 Call LECPLAN(SOCIETE,GTYPGEN,PLAN) From CPTDIV

 Raz [M:PAH3]
 For NOLI=0 To NBDOC

  ## On remet à jour RITDUD (table contenant les codes retenues à appliquer et leurs montants pour l'échéance)
  ## car en fonction de la date réelle du règlement, les retenues à appliquer et leurs montants peuvent ne pas être les
  ## mêmes...
  Read [PIH]PIH0 = TVCRNUM(NOLI)
  If !fstat
   If [F:PIH]ORIMOD = 3
    NBLIGFAC = 0
    For [PIL]PIL0 Where NUM=[F:PIH]NUM
     TFCYLIN(NBLIGFAC)    = [F:PIL]FCYLIN
     Assign "TACC("+num$(NBLIGFAC)+")" With [F:PIL]ACC(GTYPGEN-1)
     TAMTNOTLIN(NBLIGFAC) = [F:PIL]AMTNOTLIN
     TAMTVAT(NBLIGFAC)    = [F:PIL]AMTVAT
     NBLIGFAC += 1
    Next
    Gosub MAJ_RITDUD
   Elsif [F:PIH]ORIMOD = 4
    NBLIGFAC = 0
    ## Parcours des lignes de factures ventes pour initialiser les tableaux suivants :
    ##For [PID]PID0 Where NUM=[F:PIH]NUM
    # TFCYLIN(NBLIGFAC)    = ???
    # TACC(NBLIGAC)        = ???
    # TAMTNOTLIN(NBLIGFAC) = ???
    # TAMTVAT(NBLIGFAC)    = ???
    # Gosub MAJ_RITDUD
    # NBLIGFAC += 1
    ## Next
   Endif
  Endif

  ## Chargement des retenues et des montants dans les masques
  Filter [RIU] Where TYPREC = 1 & NUM = TVCRNUM(NOLI) & DUDNUM = TDUDNUM(NOLI) & DUDLIG = TDUDLIG(NOLI)
  Read [RIU]RIU0 First
  Filter [RIU]
  If !fstat
   For NUMRET=0 To dim([F:RIU]RITCOD)-1
    If [F:RIU]RITCOD(NUMRET)<>""
     VU = find([F:RIU]RITCOD(NUMRET),[M:PAH3]RITCOD(0..[M:PAH3]NBRIT))
     Read [F:RTZ]RTZ0   = [F:RIU]RITCOD(NUMRET)
     If !VU
      Read [PRI]PRI1 = TYPPAH ; NUMPAH ; [F:RIU]RITCOD(NUMRET)
      If !fstat : # Dans ce cas, on est forcément en modif d'un ordre de paiement...
       [M:PAH3]RITNUM(NOL2) = [F:PRI]RITNUM(NUMRET)
      Endif
      [M:PAH3]RITCOD(NOL2) = [F:RIU]RITCOD(NUMRET)
      [M:PAH3]DES(NOL2)    = [F:RTZ]DES
      [M:PAH3]THERITAMT(NOL2) = [F:RIU]THERITAMT(NUMRET)
      [M:PAH3]RITBAS(NOL2)   = [F:RIU]RITBAS(NUMRET)
      [M:PAH3]CURVCR(0) = [F:RIU]CUR : # Ttes les échéances de l'ordre de paiement sont sur la même devise...
      NOL2 += 1
      [M:PAH3]NBRIT=[L]NOL2
     Else
      [M:PAH3]THERITAMT(VU-1) += [F:RIU]THERITAMT(NUMRET)
      [M:PAH3]RITBAS(NOL2)    += [F:RIU]RITBAS(NUMRET)
     Endif
    Endif
   Next
  Endif
 Next
 [M:PAH3]NBRIT=[L]NOL2
 If CAS = 1
  Affzo [M:PAH3]
 Endif
Endif
End


$MAJ_RITDUD
If clalev([F:RIU])=0  : Local File RITDUD     [RIU] : Endif
If clalev([F:RIU2])=0 : Local File RITDUD     [RIU2]: Endif
If clalev([F:RIU3])=0 : Local File RITDUD     [RIU3]: Endif
Local Integer TRANSAC : TRANSAC = 0
If adxlog=0
 GOK=1
 TRANSAC = 1
 Call DEBTRANS From GLOCK
 Trbegin [RIU], [RIU2], [RIU3]
Endif
 Call CALRTZ(2,[F:PIH]BPR,PLAN,TACC,TFCYLIN,[F:PIH]CUR,DATPAH,TAMTNOTLIN,TAMTVAT,NBLIGFAC,TDUDLIG(NOLI)) From CALRTZARG
If TRANSAC=1
 Commit
Endif
Return


Subprog CAL_RETENUES(CAS,TYPPAH,NUMPAH,DATPAH,SOC,TIERS,NDOC,NUMFAC,NUMDUD,LIGDUD,CURPCE,AMTPCE,NBFAC,TABCODRTZ,TABAMT,TABAMTRPT,
&                    TABBAS,TABBASRPT,TABBASCUM,TABRITCUM,TABREPRTZ)
Value    Integer CAS        : # Cas d'appel : 1:Saisie OP  2:Proposition auto
Value    Integer TYPPAH
Value    Char    NUMPAH()
Value    Date    DATPAH
Value    Char    SOC()
Value    Char    TIERS()
Value    Integer NDOC        : # No document (n° ligne)
Value    Char    NUMFAC()
Value    Integer NUMDUD
Value    Integer LIGDUD
Value    Char    CURPCE
Value    Decimal AMTPCE
Value    Integer NBFAC
Variable Char    TABCODRTZ()(0..,0..)
Variable Decimal TABAMT(0..,0..)
Variable Decimal TABAMTRPT(0..,0..)
Variable Decimal TABBAS(0..,0..)
Variable Decimal TABBASRPT(0..,0..)
Variable Decimal TABBASCUM(0..)
Variable Decimal TABRITCUM(0..)
Variable Decimal TABREPRTZ(0..)

## Etiquette appelée pour chaque document appliqué
If TYPPAH <> 1 or
& ((func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGRTZ",[L]SOC)<>"2") or func AFNC.ACTIV("KAG") = 0)
  End
Endif# Issue X3-107197

Local Integer NUMSEUIL
Local Integer NUMRET, NOLI, NOL2, VU, INDRIT, INDRIT2
Local Decimal AMTREA       : # Montant réel retenue en devise échéance
Local Decimal AMTREARPT    : # Montant réel retenue en devise reporting
Local Decimal BASAMTREA    : # Base retenue devise échéance
Local Decimal BASAMTREARPT : # Base retenue devise reporting
Local Decimal TOTAMTREA    : # Montant réel total d'un code retenue en devise échéance
Local Decimal TOTAMTREARPT : # Montant réel total d'un code retenue en devise reporting
Local Decimal BASPAYANT    : # Base imposable des paiements antérieurs
Local Decimal RITPAYANT    : # Retenues des paiements antérieurs
Local Decimal BASNONIMP    : # Base non imposable
Local Decimal BASIMPORD    : # Base imposable de l'ordre de paiement
Local Decimal BASIMP       : # Base imposable
Local Decimal RITCAL       : # Retenue calculée
Local Decimal MOIS         : # Mois correspondant à la date de l'ordre de paiement
Local Decimal ANNEE        : # Année correspondant à la date de l'ordre de paiement
Local Decimal COEFF
Local Decimal AMTPAY, BASRTZPAY, AMTRTZPAY
Local Decimal ARODEV, ARODEV2

Local Decimal AMTRTZCAL, AMTRTZCALR : # Variables utilisées dane le cas de paiement Partiel = "Premier règlement"

If clalev([F:RIU])=0  : Local File RITDUD     [RIU]  : Endif
If clalev([F:RCU])=0  : Local File RITCUM     [RCU]  : Endif
If clalev([F:RIU2])=0 : Local File RITDUD     [RIU2] : Endif
If clalev([F:PRI3])=0 : Local File PAYPTHRIT  [PRI3] : Endif
If clalev([F:RTZ])=0  : Local File RITENZIONE [RTZ]  : Endif

Local Integer NUMDOC : NUMDOC = NDOC-1

Filter [RIU] Where TYPREC = 1 & NUM = NUMFAC & DUDNUM = NUMDUD & DUDLIG = LIGDUD
Read [RIU]RIU0 First
Filter [RIU]
Filter [RIU2] Where TYPREC = 0 & NUM = NUMFAC & DUDNUM = NUMDUD & DUDLIG = 1
Read [RIU2]RIU0 First
Filter [RIU2]

If !fstat : # Facture concernée par les retenues

 TOTAMTREA = 0

 For NUMRET=0 To dim([F:RIU]RITCOD)-1

  If [F:RIU]RITCOD(NUMRET)<>""
   AMTREA = 0  : AMTREARPT = 0 : BASAMTREA = 0 : BASAMTREARPT = 0
   Read [F:RTZ]RTZ0   = [F:RIU]RITCOD(NUMRET)

   ## Calcul montant réel retenues

   ## 1°) Calcul retenues avec méthode 'Taux simple'. Les catégories de retenues paramétrées avec cette méthode sont :
   ##        a) Retencion de IVA (basée sur les montants de TVA)
   ##        b) Retencion de SUSS (basée sur les montants HT)
   ##        c) Retencion de Ingresos Brutos (basée sur les montants HT + dépendant d'une province)
   ##     NB : * Pour les enregistrements de type 'totalisation' (TYPREC=0), qu'on ouvre ici avec l'abréviation [RIU2] :
   ##             - Dans [F:RIU]BASRTZ/RITBASRTZ(0..n), on a les bases de retenues pour la totalité de la facture
   ##             - Dans [F:RIU]THERITAMT(0..n), on a les montants de retenues pour la totalité de la facture
   ##             - Dans [F:RIU]AMTVCR(0), on a indiqué le montant HT du document (facture, avoir, NC ou ND)
   ##             - Dans [F:RIU]AMTVCR(1), on a indiqué le montant TVA du document
   ##          * Pour les enregistrements de type 'détail' (TYPREC=1), qu'on ouvre ici avec l'abréviation [RIU] :
   ##             - Dans [F:RIU]BASRTZ/RITBASRTZ(0..n), on a les bases de retenues pour l'échéance
   ##             - Dans [F:RIU]THERITAMT(0..n), on a les montants de retenues pour l'échéance
   ##             - Dans [F:RIU]AMTVCR(0), on a indiqué le montant TTC de l'échéance


   ## Principe de calcul pour chaque retenue avec méthode 'Taux simple' :
   ##   - Lors de la création de la facture, on calcule et stocke la base + le montant théorique
   ##   de ces retenues en prenant en compte les paramètres "Minimun de base imposable" et "Montant non imposable",
   ##   et "Taux retenue" (=ce qui signifie que les paramètres "Minimun de base imposable" et "Montant non imposable" s'applique
   ##   TOUJOURS sur la facture).
   ##   Les bases retenues et les montants théoriques sont stockés dans les champs [F:RIU]RITBAS et [F:RIU]THERITAMT
   ##   - Lors de la saisie de l'ordre de paiement, on prend le montant théorique (on ne le recalcule pas ici)
   ##   et on regarde si les seuils sont atteints (en prenant en compte les paramètres "Base seuil" et "Montant seuil"
   ##   (Par document/Base corrigible/Par ordre de paiement). Si le seuil de la retenue n'est pas atteint,
   ##   il n'y a pas de retenue (montant retenues = 0)

   INDRIT = find([F:RIU]RITCOD(NUMRET),[M:PAH3]RITCOD(0..[M:PAH3]NBRIT-1))-1
   TABCODRTZ(NUMDOC,INDRIT) = [F:RIU]RITCOD(NUMRET)

   If [F:RTZ]MET = 1

    ## Exemple : L'ordre de paiement est composé de 3 "documents appliqués". Montant : 500 + 500 - 400 = 700
    ##           Soit le code retenue XXRTZ : Base calcul = Montant HT ; Taux retenue = 10% ; Seuil = 70 EUR.
    ##           - Une facture 1000 EUR associée à la retenue XXRTZ, 2 échéances 500 EUR.
    ##             Paiement de la 1ère échéance, soit 500 EUR
    ##           - Une autre facture 1000 EUR associée à la retenue XXRTZ, 2 échéances 500 EUR chacune.
    ##             Paiement de la 1ère échéance, soit 500 EUR
    ##           - Un avoir de 400 EUR associé à la retenue XXRTZ (1 seule échéance), soit -400 EUR

    ## Diverses possibilités :
    ##     a) Base seuil = "Par document" (Total Facture). Dans ce cas, le raisonnement est le suivant :
    ##           - pour la première facture, comme 100 EUR > 70 EUR, le montant réel de retenue
    ##             est 50 EUR (et sera egalement de 50 lors du règlement de la seconde échéance).
    ##           - pour la seconde facture, comme 100 EUR > 70 EUR, le montant réel de retenue
    ##             est 50 EUR (et sera egalement de 50 lors du règlement de la seconde échéance).
    ##           - pour l'avoir, comme -40 EUR < 70 EUR, pas de retenue
    ##           => Montant total retenue XXRTZ + 50 + 50 + 0 = 100 EUR
    ##     b) Base seuil = "Global ordre paiement" : Dans ce cas, le raisonnement est le suivant :
    ##           - Pour la première facture, comme 50 EUR (500%10) < 70 EUR, il n'y a pas de retenue
    ##           - Pour la seconde  facture, comme 50 EUR (500%10) < 70 EUR, il n'y a pas de retenue
    ##           - Pour l'avoir,             comme -40 EUR (-400%10) < 70 EUR, il n'y a pas de retenue
    ##           => Montant total retenue XXRTZ + 0 + 0 + 0 = 0 EUR
    ##        Montant de retenue pour l'ordre de paiement = 50 EUR (500*10%). Comme 50 EUR < 70 EUR, pas de retenue
    ##     c) Base seuil = "Base corrigible". Dans ce cas, le raisonnement est le suivant : on prend le total sans impôt
    ##        du règlement (Factures+ND-NC). La base imposable est donc 600 EUR
    ##        Comme 600*10% < 70, il n'y a pas de retenue

    If (AMTPCE = [F:RIU]AMTVCR(0)) | [F:RIU]AMTVCR(0)=0
     COEFF = 1
    Elsif [F:RTZ]PAYPRT<>1 : # Paiement 'Sur le premier règlement'
     COEFF = 1
    Else
     COEFF = AMTPCE/[F:RIU]AMTVCR(0)
    Endif

    Call LECTURE("TCU",CURPCE,"") From CONTOBJ
    ARODEV = [F:TCU]CURRND
    Call LECTURE("TCU",CURPCE,GCURSHR) From CONTOBJ
    ARODEV2 = [F:TCU]CURRND

    If [F:RTZ]PAYPRT = 1 : # Proportionnel
     AMTREA       = arr([F:RIU]THERITAMT(NUMRET)*COEFF,ARODEV)
     AMTREARPT    = arr([F:RIU]THERITAMTR(NUMRET)*COEFF,ARODEV2)
     BASAMTREA    = arr([F:RIU]RITBAS(NUMRET)*COEFF,ARODEV)
     BASAMTREARPT = arr([F:RIU]RITBASRPT(NUMRET)*COEFF,ARODEV2)
    Else : # Retenue sur le premier règlement
     ## On regarde si dans l'ordre de paiement courant, on a pas déjà calculé la retenue sur la facture sur une précédente
     ## imputation (Exemple : facture à deux échéances et l'ordre de paiement courant règle les deux échéances...)
     AMTRTZCAL = 0 : AMTRTZCALR = 0
     If CAS = 1
      For DOC = 0 To NUMDOC-1
       If [M:PAH1]VCRNUM(DOC) = NUMFAC & [M:PAH1]DUDNUM(DOC) = NUMDUD
        AMTRTZCAL  += TABAMT(DOC,INDRIT)
        AMTRTZCALR += TABAMTRPT(DOC,INDRIT)
       Endif
      Next
     Elsif CAS = 2
      For [PAO]PAO0 Where NUM=NUMPAH & DUDNUM=NUMDUD & DUDLIG<>LIGDUD
       INDRIT2 = find([F:RIU]RITCOD(NUMRET),[F:PAO]RITCOD(0..dim([F:PAO]RITCOD)-1))-1
       AMTRTZCAL  += [F:PAO]RITAMT(INDRIT2)
       AMTRTZCALR += [F:PAO]RITAMT(INDRIT2)
      Next
     Endif
     AMTREA       = arr([F:RIU2]THERITAMT(NUMRET)*COEFF,ARODEV)-[F:RIU2]RITAMT(NUMRET)-AMTRTZCAL
     AMTREARPT    = arr([F:RIU2]THERITAMTR(NUMRET)*COEFF,ARODEV2)-[F:RIU2]RITAMTRPT(NUMRET)-AMTRTZCALR
     BASAMTREA    = arr([F:RIU2]RITBAS(NUMRET)*COEFF,ARODEV)
     BASAMTREARPT = arr([F:RIU2]RITBASRPT(NUMRET)*COEFF,ARODEV2)
    Endif

    ## Pour résoudre les problèmes d'arrondis dans la cas où les échéances ne sont pas payées en totalité
    If COEFF<>1
     AMTPAY = 0 : AMTRTZPAY = 0
     For [PAO]PAO1 Where DUDNUM=NUMDUD & DUDLIG=LIGDUD & NUM<>NUMPAH
      INDRIT2 = find([F:RIU]RITCOD(NUMRET),[F:PAO]RITCOD(0..dim([F:PAO]RITCOD)-1))-1
      AMTPAY += [F:PAO]AMTVCR
      AMTRTZPAY += [F:PAO]RITAMT(INDRIT2)
     Next
     If [F:RIU]AMTVCR(0) = AMTPAY + AMTPCE
      AMTREA = [F:RIU]THERITAMT(NUMRET)-AMTRTZPAY
     Endif
    Endif

    If [F:RTZ]BASTSD = 1 : # Par document
     If [F:RTZ]TSDBKT(0)<>0 & [F:RTZ]TSDBKT(0)>[F:RIU2]AMTVCR([F:RTZ]BASRTZ-1)*[F:RTZ]RAT(0)/100
      AMTREA = 0 : AMTREARPT = 0
     Endif
     TABAMT(NUMDOC,INDRIT)    = arr(AMTREA,ARODEV)
     TABAMTRPT(NUMDOC,INDRIT) = arr(AMTREARPT,ARODEV2)
     TABBAS(NUMDOC,INDRIT)    = arr(BASAMTREA,ARODEV)
     TABBASRPT(NUMDOC,INDRIT) = arr(BASAMTREARPT,ARODEV2)

    Elsif [F:RTZ]BASTSD = 2 # Global pour l'ordre de paiement
     If [F:RTZ]TSDBKT(0)<>0 & [F:RTZ]TSDBKT(0)>[F:RIU]THERITAMTR(NUMRET)
      AMTREA = 0 : AMTREARPT = 0
     Endif
     TABAMT(NUMDOC,INDRIT)    = arr(AMTREA,ARODEV)
     TABAMTRPT(NUMDOC,INDRIT) = arr(AMTREARPT,ARODEV2)
     TABBAS(NUMDOC,INDRIT)    = arr(BASAMTREA,ARODEV)
     TABBASRPT(NUMDOC,INDRIT) = arr(BASAMTREARPT,ARODEV2)
    Endif

    If [F:RTZ]BASTSD = 3 : # Base imposable corrigée
     TABBAS(NUMDOC,INDRIT)    += BASAMTREA
     TABBASRPT(NUMDOC,INDRIT) += BASAMTREARPT
     ## Pour le montant réel, on le calcule plus loin, lors du parcours du dernier document appliqué
    Endif

    If [F:RTZ]PAYPRT = 2 : # Paiement partiel = "Premier règlement"
     ## On contrôle que le montant de retenue ne dépasse pas le montant de règlement de l'échéance
     If TABAMT(NUMDOC,INDRIT) > AMTPCE
      TABAMT(NUMDOC,INDRIT) = AMTPCE
      If CURPCE = GCURSHR
       TABAMTRPT(NUMDOC,INDRIT) =  TABAMT(NUMDOC,INDRIT)
      Else
       Call CONVERT(CURPCE,GCURSHR,DEVLED,1,DATPAH,TABAMT(NUMDOC,INDRIT),TABAMTRPT(NUMDOC,INDRIT),STAT) From TRTDEV
      Endif
     Endif
    Endif
   Endif


   ## 2°) Calcul retenues avec méthode 'Taux par tranche'. Concerne les retenues de GANANCIAS (cumul mensuel)
   ## Principe de calcul pour chaque retenue avec méthode 'Taux par tranche' (concerne les GANANCIAS avec cumul mensuel) :
   ##   - Lors de la création de la facture, on calcule et stocke pour ces retenues la base de retenues en prenant en compte
   ## les paramètres "Minimun de base imposable" et "Montant non imposable" (=ce qui signifie que les
   ## paramètres "Minimun de base imposable" et "Montant non imposable" s'applique TOUJOURS sur la facture)
   ## La base retenue est stockée dans le champ [F:RIU]RITBAS
   ##   - Lors de la saisie de l'ordre de paiement, on calcule la base imposable de l'ordre de paiement (factures-avoirs)
   ## et on calcule le montant de retenue par rapport aux règlements effectués dans le mois

   If [F:RTZ]MET = 2

    If (AMTPCE = [F:RIU]AMTVCR(0)) | [F:RIU]AMTVCR(0)=0
     COEFF = 1
    Else
     COEFF = AMTPCE/[F:RIU]AMTVCR(0)
    Endif

    Call LECTURE("TCU",CURPCE,"") From CONTOBJ
    ARODEV = [F:TCU]CURRND
    Call LECTURE("TCU",CURPCE,GCURSHR) From CONTOBJ
    ARODEV2 = [F:TCU]CURRND

    BASAMTREA    = arr([F:RIU]RITBAS(NUMRET)*COEFF,ARODEV)
    BASAMTREARPT = arr([F:RIU]RITBASRPT(NUMRET)*COEFF,ARODEV2)

    TABBAS(NUMDOC,INDRIT) += BASAMTREA
    TABBASRPT(NUMDOC,INDRIT) += BASAMTREARPT
   Endif
  Endif
 Next
Endif

## Dans le cas des retenues 'Taux simple' et pour lequel le seuil est pris en compte par rapport à la base
## imposable corrigée, il faut calculer le montant retenue réel à la fin, une fois qu'on connaît la base imposable
## corrigée (= une fois qu'on a parcouru tous les documents de l'ordre de paiement)
## Il en est de même pour les retenues de Ganancias
If NUMDOC = NBFAC-1
 For NUMRET = 0 To [M:PAH3]NBRIT-1
  Read [F:RTZ]RTZ0 = [M:PAH3]RITCOD(NUMRET)

  If [F:RTZ]MET = 1 & [F:RTZ]BASTSD = 3 : # Base seuil = "Base imposable corrigée"
   If [F:RTZ]TSDBKT(0)<>0 & [F:RTZ]TSDBKT(0)>sum(TABBASRPT(0..NBFAC-1,NUMRET))*[F:RTZ]RAT(0)/100
    For NOLI=0 To NBFAC-1
     TABAMT(NOLI,NUMRET) = 0
     TABAMTRPT(NOLI,NUMRET) = 0
    Next
   Else
    TOTAMTREA    = sum(TABBAS(0..NBFAC-1,NUMRET))*[F:RTZ]RAT(0)/100
    TOTAMTREARPT = sum(TABBASRPT(0..NBFAC-1,NUMRET))*[F:RTZ]RAT(0)/100
    Gosub REP_DOCORD
   Endif

  ## Calcul retenues Ganancias (cumul mensuel)
  Elsif [F:RTZ]MET = 2
   ANNEE = year(DATPAH)
   MOIS  = month(DATPAH)

   ## Règlements antérieurs :
   ## En modif : on récupère la base et montants cumulés du mois dans la table PAYRITCUM
   If !find(GREP,"C","D")
    For [PRI]PRI1 Where TYP=1 & NUM=NUMPAH & RITCOD = [M:PAH3]RITCOD(NUMRET)
     [M:PAH3]BASANTCUM(NUMRET) = [F:PRI]BASMONCUM : # Base imposable règlements antérieurs du mois (pour retenues Ganancias)
     [M:PAH3]RITANTCUM(NUMRET) = [F:PRI]AMTMONCUM : # Montants retenues règlements antérieurs du mois (pour retenues Ganancias)
    Next
   Endif

   If [M:PAH3]BASANTCUM(NUMRET)<>0
    BASPAYANT = [M:PAH3]BASANTCUM(NUMRET)
    RITPAYANT = [M:PAH3]RITANTCUM(NUMRET)
   Endif

   If BASPAYANT = 0
    ## On est en création ou en modification du premier règlement du mois
    Read [RCU]RCU0 = SOC ; TIERS ; [L]ANNEE ; [L]MOIS ; [M:PAH3]RITCOD(NUMRET)
    If !fstat
     BASPAYANT = [F:RCU]BASMON
     RITPAYANT = [F:RCU]AMTMON
     If !find(GREP,"C","D")
      Read [PRI3]PRI1 = TYPPAH ; NUMPAH ; [M:PAH3]RITCOD(NUMRET)
      If !fstat
       BASPAYANT -= [F:PRI3]BASRTZRPT
       RITPAYANT -= [F:PRI3]AMTRTZRPT
      Endif
     Endif
    Else
     BASPAYANT = 0
     RITPAYANT = 0
    Endif
   Endif

   ## TABBASCUM, TABRITCUM = servent pour le stockage dans PAYPTHRIT
   TABBASCUM(NUMRET) = BASPAYANT
   TABRITCUM(NUMRET) = RITPAYANT

   BASIMPORD = sum(TABBASRPT(0..NBFAC-1,NUMRET))

   # Montant mensuel non assujeti à retenues Ganancias (paramétré dans [F:RTZ]BASEXE)
   If GCURSHR<>CURPCE
    Call CONVERT(GCURSHR,CURPCE,[F:CPY]ACCCUR,1,DATPAH,[F:RTZ]BASEXE,BASNONIMP,STAT) From TRTDEV
   Else
    BASNONIMP = [F:RTZ]BASEXE
   Endif

   ## Nouvelle base imposable = Base imposable de l'ordre de paiement - montant mensuel non sujeti à retenue + base imposable
   ## règlements antérieurs
   BASIMP = sum(TABBASRPT(0..NBFAC-1,NUMRET)) - BASNONIMP + BASPAYANT

   NUMSEUIL = 0 : RITCAL = 0
   If BASIMP>0
    ## BASIMP peut être <0 si la base imposable est inférieure au montant non imposable ([F:RTZ]BASEXE)
    While [F:RTZ]BKT(NUMSEUIL)<>0 and BASIMP>[F:RTZ]BKT(NUMSEUIL)
     [L]NUMSEUIL+=1 # on passe dans la tranche supérieure
    Wend
    If NUMSEUIL = 0
     RITCAL = BASIMP*[F:RTZ]RAT(NUMSEUIL)/100
    Else
     RITCAL = [F:RTZ]AMTFXD(NUMSEUIL)+((BASIMP-[F:RTZ]BKT(NUMSEUIL-1))*([F:RTZ]RAT(NUMSEUIL)/100))
    Endif
   Endif

   If [F:RTZ]TSDBKT(NUMSEUIL)<>0 & [F:RTZ]TSDBKT(NUMSEUIL) > RITCAL - RITPAYANT
    For NOLI=0 To NBFAC-1
     TABAMT(NOLI,NUMRET) = 0
     TABAMTRPT(NOLI,NUMRET) = 0
    Next
   Else
    TOTAMTREARPT = RITCAL - RITPAYANT
    If CURPCE<>GCURSHR
     Call CONVERT(GCURSHR,CURPCE,[F:CPY]ACCCUR,1,DATPAH,TOTAMTREARPT,TOTAMTREA,STAT) From TRTDEV
    Else
     TOTAMTREA = TOTAMTREARPT
    Endif
    Gosub REP_DOCORD
   Endif

  Endif

 Next

 ## Les tableaux TAB* ont été remplis, on alimente et affiche le masque des retenues....
 For NUMRET = 0 To [M:PAH3]NBRIT-1
  [M:PAH3]RITAMT(NUMRET)    = arr(sum(TABAMT(0..NBFAC-1,NUMRET)),ARODEV)
  [M:PAH3]RITAMTRPT(NUMRET) = arr(sum(TABAMTRPT(0..NBFAC-1,NUMRET)),ARODEV2)
  [M:PAH3]RITBAS(NUMRET)    = arr(sum(TABBAS(0..NBFAC-1,NUMRET)),ARODEV)
  [M:PAH3]RITBASRPT(NUMRET) = arr(sum(TABBASRPT(0..NBFAC-1,NUMRET)),ARODEV2)
 Next

Endif

If GOK<1 : End : Endif

If CAS = 1
 Affzo [M:PAH3]
Endif

If CAS = 2
Endif
End


$REP_DOCORD
## Répartition d'un montant total de retenue contenue dans TOTAMTREA sur chaque document appliqué
## En devise échéance...
Raz TABREPRTZ
Local Decimal ARODEV, ARODEV2
TOTVCR = sum(TABBAS(0..NBFAC-1,NUMRET))
Call LECTURE("TCU",CURPCE,"") From CONTOBJ
ARODEV = [F:TCU]CURRND
Call LECTURE("TCU",CURPCE,GCURSHR) From CONTOBJ
ARODEV2 = [F:TCU]CURRND
For NUMDOC = 0 To NBFAC-1
 If NUMDOC+1<>NBFAC
  TABAMT(NUMDOC,NUMRET) = arr((TABBAS(NUMDOC,NUMRET)*TOTAMTREA)/[L]TOTVCR,ARODEV)
  TABREPRTZ(NUMRET) += TABAMT(NUMDOC,NUMRET)
 Else
  TABAMT(NUMDOC,NUMRET) = arr(TOTAMTREA-TABREPRTZ(NUMRET),ARODEV)
 Endif
Next
## En devise reporting...
Raz TABREPRTZ
TOTVCR = TABBASRPT(0..NBFAC-1,NUMRET)
For NUMDOC = 0 To NBFAC-1
 If NUMDOC+1<>NBFAC
  TABAMTRPT(NUMDOC,NUMRET) = arr((TABBASRPT(NUMDOC,NUMRET)*TOTAMTREARPT)/[L]TOTVCR,ARODEV2)
  TABREPRTZ(NUMRET) += TABAMTRPT(NUMDOC,NUMRET)
 Else
  TABAMTRPT(NUMDOC,NUMRET) = arr(TOTAMTREA-TABREPRTZ(NUMRET),ARODEV2)
 Endif
Next
Return

