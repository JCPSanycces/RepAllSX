#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################################
## Xtend: Génération fiche Menu Xtend
#  Version 0002
#
#  E46684     Gestion menu hiérachique
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissement
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBLANFCY, WNBREC, WTMPERRFLG
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Char WSTR1(250), WMSG(250), WMSGERR(250), WRUB
Local Char U_TXTTOHEX(255),U_HEXTOTXT(255)

# Variables ecritures lignes
Local Integer     WC_COD, WC_CODPAR, WC_WL
Local Char        WC_VALEUR(GLONAYR), WC_DLKCOD(GLONAYL), WC_FIECOD(GLONAYF), WC_LIB(250)

RET=1

Call TITOBJ("AYC","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN 

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTMEN    [AYC1] 
 Local File ATEXTRA   [AXX1] 
 Local File APLSTD    [AST1] 
 Local File AYTFCY    [AYS1] 
 Local File AYTLINES  [AYN1] 
 Local File ATABDIV   [ADI1]
Else 
 Local File = [L]DOSORG+".AYTMEN"     [AYC1] 
 Local File = [L]DOSORG+".ATEXTRA"    [AXX1]
 Local File = [L]DOSORG+".APLSTD"     [AST1] 
 Local File = [L]DOSORG+".AYTFCY"     [AYS1] 
 Local File = [L]DOSORG+".AYTLINES"   [AYN1] 
 Local File = [L]DOSORG+".ATABDIV"    [ADI1] 
Endif 
If adxmother=nomap
 Local File APLSTD    [ASTM] 
Else
 Local File =adxmother+".APLSTD"     [ASTM] 
Endif

Default File "[AYC1],[AST1],[AXX1],[AYN1],[ADI1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="MEN"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 

#   Recherche des langues
Read [AYS1]AYS0 = [L]FCYORG
If fstat<>0     # <=> non trouvé
  Call ECR_TRACE(mess(19,7900,1)-[L]FCYORG,1) From GESECRAN
  RET=0
  Goto FFINALLY
Endif
#
Local Char WTABLAN(GLONLAN) (1..dim([F:AYS1]LANADS))    # Tableau des langues Xtend
Local Char WLANDEF(GLONLAN) : WLANDEF=GLANDEF           # Langue par défaut
For WI=0 To [F:AYS1]LANNBR-1
 If !find([F:AYS1]LANCOD(WI),WTABLAN)
    WNBLANFCY+=1
    WTABLAN(WNBLANFCY) = [F:AYS1]LANCOD(WI)
    If [F:AYS1]LANDEF=2 : WLANDEF=[F:AYS1]LANADS : Endif
 Endif
Next

#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYC1]AYC0 Where FCYCOD=FCYORG

 WNBREC+=1
 If TRADETFLG : Call ECR_TRACE(mess(15,7910,1)-":"-[F:AYC1]MENCOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT"  : XT_ID=[F:AYC1]MENCOD 
 Call LECTEXTRA(XT_VAL,"AYTMEN","INTIT",[F]FCYCOD,[F]MENCOD) From AYTUTIA  : Gosub XMLF_ADD From AYTGEN

 # Champs liés par défaut
 XT_TY="TAB"   : XT_ID="FIENBR"                                            : Gosub XMLF_ADD From AYTGEN
 For WI=0 To [F:AYC1]FIENBR-1
  XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
  XT_TY="COL"  : XT_ID="FIECOD"     : XT_VAL=[F:AYC1]FIECOD(WI)                  : Gosub XMLF_ADD From AYTGEN
 Next

 Case [F:AYC1]GESOPT
  When 1    # Manuel
    Gosub LIN_STDAYN
  When 2    # auto
    If [F:AYC1]GESORI=2
        If [F:AYC1]DEPFLG<>2
            Gosub LIN_GESTAB
        Else
            Gosub LIN_GESTABHI 
        Endif
    Else
        Gosub LIN_GESCHP
    Endif
  When 3    # import batch
    #Gosub LIN_STDAYN
     XT_TY="FLD"   : XT_ID="RESRAC"     : XT_VAL=num$([F:AYC1]RESRAC)
                                          XT_LAB=mess([F:AYC1]RESRAC,7937,1)        : Gosub XMLF_ADD From AYTGEN
     XT_TY="FLD"   : XT_ID="RESSUBFIC"  : XT_VAL=[F:AYC1]RESSUBFIC                  : Gosub XMLF_ADD From AYTGEN
    # modif sb ajour check timestamp
    # si non initialisé, on passe à 1 : Oui
    Local Integer WVAL
    If [F:AYC1]RESTIMSTP=0 Then
            WVAL=1
    Else
            WVAL=[F:AYC1]RESTIMSTP
    Endif
    XT_TY="FLD"   : XT_ID="RESTIMSTP"     : XT_VAL=num$(WVAL)
                                          XT_LAB=mess(WVAL,1,1)        : Gosub XMLF_ADD From AYTGEN

    # modif sb ajour check timestamp

 Endcase
Next

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYC1],[AST1],[AXX1],[AYN1],[ADI1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

######################################################################################
## Utilitaires
######################################################################################
# Libellé 
#---------------------------------------------------------------#
Funprog GET_LIBS(LNMEN, LNNUM, LNLIBORI,LNCHP,LNCHPNUM,LNADV,LNADI,LNADISHO, LAN, LANDEF, RET, MSGERR)
Value     Char        LNMEN        
Value     Integer     LNNUM
Value     Integer     LNLIBORI
Value     Integer     LNCHP
Value     Integer     LNCHPNUM
Value     Integer     LNADV
Value     Char        LNADI
Value     Integer     LNADISHO
Value     Char        LAN
Value     Char        LANDEF
Variable  Integer     RET        # 1 Ok  0:Ko 2: avertissement sur une ligne
Variable  Char        MSGERR
Local Char WMSG(250)
RET=1
WMSG = "???"
If LNLIBORI=1
    Gosub CHP_LIBS
Else
    Gosub TABDIV_LIBS
Endif
End WMSG

# Libellé chapitre
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
$CHP_LIBS
If LNCHP<> 0
    Read [AST1]CLE=LNCHP;LNCHPNUM;LAN      # Dossier en-cours
    If fstat=0
         WMSG=[F:AST1]LANMES
    Else
        Read [ASTM]CLE=LNCHP;LNCHPNUM;LAN       # Dossier mère
        If fstat=0
             WMSG=[F:ASTM]LANMES
        Else
            Read [AST1]CLE=LNCHP;LNCHPNUM;LANDEF            # Dossier en-cours - LANDEF
            If !fstat=0
                 WMSG=[F:AST1]LANMES
            Else
                Read [ASTM]CLE=LNCHP;LNCHPNUM;LANDEF      # Dossier mère - LANDEF            
                If fstat=0
                     WMSG=[F:ASTM]LANMES
                Else
                    MSGERR=mess(192,7900,1)-LNMEN-"/"-num$(LNNUM)-"("-num$(LNCHP)-"/"-num$(LNCHPNUM)-"/"-LAN-")"
                    RET=2
                Endif            
            Endif
        Endif        
    Endif
Else
    MSGERR=mess(193,7900,1)-LNMEN-"/"-num$(LNNUM)-"("-num$(LNCHP)-"/"-num$(LNCHPNUM)-")"
    RET=0
Endif
Return


# Libellé Table diverse
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
$TABDIV_LIBS
If LNADISHO=2 : WRUB="SHODES" : Else : WRUB="LNGDES" : Endif
Read [AXX]AXX0 = "ATABDIV";WRUB;LAN;num$(LNADV);LNADI
If fstat=0
 WMSG = [F:AXX]TEXTE
Else 
 Read [AXX]AXX0 = "ATABDIV";WRUB;LANDEF;num$(LNADV);LNADI
 If fstat=0 
  WMSG = [F:AXX]TEXTE 
 Else
  MSGERR= mess(194,7900,1)-LNMEN-"/"-num$(LNNUM)-"("-num$(LNADV)-"/"-LNADI-"/"-LAN-")" 
  RET=2
 Endif
Endif
Return

# Lines - Cas standard
#---------------------------------------------------------------#
$LIN_STDAYN
 # Lignes
 XT_TY="TAB"   : XT_ID="NUM10"    :  XT_VAL="Lines"                 : Gosub XMLF_ADD From AYTGEN
 For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=7
&                       and LINCOD = [F:AYC1]MENCOD and  LINTYP = 60 and LINNUM <> 0
    WC_COD       = [F:AYN1]MENCOD
    WC_CODPAR    = [F:AYN1]MENCODPAR
    WC_VALEUR    = [F:AYN1]VALEUR
    WC_DLKCOD    = [F:AYN1]DLKCOD
    WC_FIECOD    = [F:AYN1]FIECOD
    Gosub ECR_LIN
 Next

 # Libellés
 XT_TY="TAB"   : XT_ID="NUM10LAB"    :  XT_VAL="Labels"             : Gosub XMLF_ADD From AYTGEN
 For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=7
&                       and LINCOD = [F:AYC1]MENCOD and  LINTYP = 60 and LINNUM <> 0
     WC_COD    = [F:AYN1]MENCOD
     For WI=1 To WNBLANFCY
        
        WC_LIB = func GET_LIBS([F:AYC1]MENCOD, [F:AYN1]LINNUM, [F:AYN1]MENLIBORI, [F:AYN1]MENCHP,[F:AYN1]MENCHPNUM
&                    ,[F:AYN1]MENADV,[F:AYN1]MENADI,[F:AYN1]MENADISHO, WTABLAN(WI), WLANDEF, WTMPERRFLG, WMSGERR)
        Gosub ECRLIBS_LIN
        If WTMPERRFLG=0 : Break : Endif
     Next
 Next
Return

# Lines - Cas chapitre auto
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
$LIN_GESCHP
 GBIDI1=0
 For [AST1]LAN Where LAN=GLANGUE and LANCHP=[F:AYC1]GESCHP and LANNUM<>0
  GBIDI1=1
  Break
 Next
 If !GBIDI1
  Call ECR_TRACE(mess(230,7900,1)-":"-num$([F:AYC1]GESCHP),-1) From GESECRAN
 Endif

 # Ordre imposé APLSTD et AYN sur n°ligne sinon pb...
 Link [AST1]  With [AYN1]AYN0 = [L]FCYORG;7;[F:AYC1]MENCOD;10;[F:AST1]LANNUM As [AST_] 
 WC_WL=2
 # Lignes
 XT_TY="TAB"   : XT_ID="NUM10"    :  XT_VAL="Lines"                 : Gosub XMLF_ADD From AYTGEN
 For [AST_] Where LAN=GLANGUE and LANCHP=[F:AYC1]GESCHP and LANNUM<>0
    WC_COD       = WC_WL
    WC_CODPAR    = 1
    WC_VALEUR    = num$([F:AST1]LANNUM)
    WC_DLKCOD    = ""
    WC_FIECOD    = ""
    If [F:AYN1]LINCOD<>""
      WC_VALEUR    = [F:AYN1]VALEUR
      WC_DLKCOD    = [F:AYN1]DLKCOD
      WC_FIECOD    = [F:AYN1]FIECOD
    Endif
    Gosub ECR_LIN
    WC_WL+=1
 Next
 Close File [AST_]

 # Libellés
 WC_WL=2
 XT_TY="TAB"   : XT_ID="NUM10LAB"    :  XT_VAL="Labels"             : Gosub XMLF_ADD From AYTGEN
 For [AST1]LAN  Where LAN=GLANGUE and LANCHP=[F:AYC1]GESCHP and LANNUM<>0
     WC_COD    = WC_WL
     For WI=1 To WNBLANFCY
        WC_LIB = func GET_LIBS([F:AYC1]MENCOD, WC_WL, [F:AYC1]GESORI, [F:AST1]LANCHP,[F:AST1]LANNUM
&                    ,0,"",[F:AYC1]GESADISHO, WTABLAN(WI), WLANDEF, WTMPERRFLG, WMSGERR)
        Gosub ECRLIBS_LIN
        If WTMPERRFLG=0 : Break : Endif
     Next
     WC_WL+=1
 Next

Return

# Lines - Cas table diverse
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
$LIN_GESTAB
 GBIDI1=0
 For [ADI1]CODE Where NUMTAB=[F:AYC1]GESADV
  GBIDI1=1
  Break
 Next
 If !GBIDI1
  Call ECR_TRACE(mess(229,7900,1)-":"-num$([F:AYC1]GESADV),-1) From GESECRAN
 Endif
 Filter [AYN1] Where FCYCOD=[L]FCYORG and LINCODTYP=7 and LINCOD=[F:AYC1]MENCOD and LINTYP=60
 WC_WL=2
 # Lignes
 XT_TY="TAB"   : XT_ID="NUM10"    :  XT_VAL="Lines"                 : Gosub XMLF_ADD From AYTGEN
 For [ADI1]CODE Where NUMTAB=[F:AYC1]GESADV
    WC_COD    = WC_WL
    WC_CODPAR = 1
    WC_VALEUR    = [F:ADI1]CODE
    WC_DLKCOD    = ""
    WC_FIECOD    = ""
    For [AYN1] Where MENADI=[F:ADI1]CODE                    # Ordre non certain
        WC_DLKCOD     = [F:AYN1]DLKCOD
        WC_VALEUR     = [F:AYN1]VALEUR
        WC_FIECOD     = [F:AYN1]FIECOD
        Break
    Next
    Gosub ECR_LIN
    WC_WL+=1
 Next
 Filter [AYN1]

 # Libellés
 WC_WL=2
 XT_TY="TAB"   : XT_ID="NUM10LAB"    :  XT_VAL="Labels"             : Gosub XMLF_ADD From AYTGEN
 For [ADI1]CODE Where NUMTAB=[F:AYC1]GESADV
     WC_COD    = WC_WL
     For WI=1 To WNBLANFCY
        WC_LIB = func GET_LIBS([F:AYC1]MENCOD, WC_WL, [F:AYC1]GESORI, 0,0
&                    ,[F:AYC1]GESADV,[F:ADI1]CODE,[F:AYC1]GESADISHO, WTABLAN(WI), WLANDEF, WTMPERRFLG, WMSGERR)
        Gosub ECRLIBS_LIN
        If WTMPERRFLG=0 : Break : Endif
     Next
     WC_WL+=1
 Next

Return

# Lines - Ecriture
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
$ECR_LIN
   XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="MENCOD"     : XT_VAL=num$(WC_COD)                   : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="MENCODPAR"  : XT_VAL=num$(WC_CODPAR) 
                                       If WC_CODPAR=1 : XT_VAL="" : Endif
                                                                                  : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="VALEUR"     : XT_VAL=WC_VALEUR                           : Gosub XMLF_ADD From AYTGEN
# modif sb, le lien dynamique est masqué
 #  If WC_DLKCOD<>""
 #      XT_TY="COL"  : XT_ID="DLKCOD"     : XT_VAL=WC_DLKCOD                           : Gosub XMLF_ADD From AYTGEN
 #  Endif
#fin sb
   If WC_FIECOD<>""
       XT_TY="COL"  : XT_ID="FIECOD"     : XT_VAL=WC_FIECOD                           : Gosub XMLF_ADD From AYTGEN
   Endif
Return

# Lines - Ecriture libellés
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
$ECRLIBS_LIN
    XT_TY="LIN"                                                      : Gosub XMLF_ADD From AYTGEN
    XT_TY="COL"  : XT_ID="MENCOD"     : XT_VAL=num$(WC_COD)              : Gosub XMLF_ADD From AYTGEN
    XT_TY="COL"  : XT_ID="LANCOD"     : XT_VAL=WTABLAN(WI)               : Gosub XMLF_ADD From AYTGEN
    XT_TY="COL"  : XT_ID="LANFMT" 
           U_HEXTOTXT=WC_LIB : Gosub U_TXTTOHEX From SUBAPSUTI
                                                XT_VAL=U_TXTTOHEX        : Gosub XMLF_ADD From AYTGEN    
    If find (WTMPERRFLG,0,2) : Call ECR_TRACE(WMSGERR,1) From GESECRAN  : RET=2 : Endif
Return


# Lines - Cas table diverse gestion hiérarchique   (E46684)
#  Support mask d'ecran abrev [AYCX]
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
$LIN_GESTABHI
Local Mask AYC1 [AYCX]
Local Integer MSKMAX : MSKMAX=dim([M:AYCX]LNCOD10,1)
If !clalev([F:ADV])   : Local File ATABTAB  [ADV]  : Endif

# Chgt du mask
[M:AYCX]NUM10=1     # Saut ligne entete
Filter [AYN1] Where FCYCOD=[L]FCYORG and LINCODTYP=7 and LINCOD=[F:AYC1]MENCOD and LINTYP=60
Call GET_TABLEV(MSKMAX, "1", "", [F:AYC1]GESADV, [F:AYC1]GESADISHO, [F:AYC1]DEPNIV, 1)
Filter [AYN1] 

# Lignes
XT_TY="TAB"   : XT_ID="NUM10"    :  XT_VAL="Lines"                 : Gosub XMLF_ADD From AYTGEN
For WC_WL=1 To [M:AYCX]NUM10-1
    WC_COD       = val([M:AYCX]LNCOD10(WC_WL))
    WC_CODPAR    = val([M:AYCX]LNPAR10(WC_WL))
    WC_VALEUR    = [M:AYCX]LNVAL10(WC_WL)
    WC_DLKCOD    = [M:AYCX]LNDLK10(WC_WL)
    WC_FIECOD    = [M:AYCX]LNFIECOD10(WC_WL)
    Gosub ECR_LIN
Next

# Libellés
XT_TY="TAB"   : XT_ID="NUM10LAB"    :  XT_VAL="Labels"             : Gosub XMLF_ADD From AYTGEN
For WC_WL=1 To [M:AYCX]NUM10-1
    WC_COD       = val([M:AYCX]LNCOD10(WC_WL))
    For WI=1 To WNBLANFCY
        WC_LIB = func GET_LIBS([F:AYC1]MENCOD, WC_COD, 2, 0,0
&                    ,[M:AYCX]LNADV10(WC_WL),[M:AYCX]LNADI10(WC_WL),[M:AYCX]LNADISHO10(WC_WL)
&                    , WTABLAN(WI), WLANDEF, WTMPERRFLG, WMSGERR)
        Gosub ECRLIBS_LIN
        If WTMPERRFLG=0 : Break : Endif
    Next
Next
Local File [AYC1]
Close Local Mask [AYCX]
Return




# Remplissage du mask [AYCX] pour les tables avec gestion des dépendances (E46684)
#  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  -  - #
Subprog GET_TABLEV(LMAX, FATHKEY, FATHDEPADI, ADVCOD, GESADISHO, NIVMAX, NIVCUR)
Value Integer LMAX           # Nb ligne maxi ecran
Value Char    FATHKEY        # Père - Clé interne
Value Char    FATHDEPADI     # Père - Code ADI ( recherche dépendance)
Value Integer ADVCOD         # Code table diverse
Value Integer GESADISHO      # Intitulé court
Value Integer NIVMAX         # Niveau maxi 
Value Integer NIVCUR         # Niveau demandé

Local Char    WCODDIVCUR     # Code courant de la ligne de la table diverse
Local Integer WLCUR          # Numèro de ligne
Local Integer WFLGDEP        # Traiter les dépendances
Local Char    WEVLDEP(30)    # Filtre dépendance
Local Integer WI

If NIVCUR>NIVMAX : End : Endif

Local Integer ADVCHILDMAX                    # Nb maxi de filles gérées (cas rare...)
ADVCHILDMAX=10
Local Integer ADVCHILDNB                     # Nb de filles gérées 
Local Integer ADVCHILD(1..ADVCHILDMAX)       # Code Tables filles     

# Recherche tables filles 
For [ADV]CODE Where DEPNUM=ADVCOD
    If !find(NUMTAB, ADVCHILD)
        ADVCHILDNB +=1
        ADVCHILD(ADVCHILDNB)=[ADV]NUMTAB
    Endif
Next 

# Filtre dépenance
WEVLDEP="1=1" : If FATHDEPADI<>"" : WEVLDEP='DEPCOD = "' +FATHDEPADI+ '"' : Endif

# boucle
$TABLEV_BCL
WLCUR=[M:AYCX]NUM10
For [ADI1]CODE Where NUMTAB=ADVCOD and CODE > WCODDIVCUR and evalue(WEVLDEP)
     WCODDIVCUR                 = [F:ADI1]CODE
    [M:AYCX]LNCOD10(WLCUR)      = num$(WLCUR+1)
    [M:AYCX]LNPAR10(WLCUR)      = [L]FATHKEY
    [M:AYCX]LNLIBORI10(WLCUR)   = 2            # Origine table diverse
    [M:AYCX]LNCHP10(WLCUR)      = 0
    [M:AYCX]LNCHPNUM10(WLCUR)   = 0
    [M:AYCX]LNADV10(WLCUR)      = ADVCOD
    [M:AYCX]LNADI10(WLCUR)      = [F:ADI1]CODE
    [M:AYCX]LNADISHO10(WLCUR)   = [L]GESADISHO
    [M:AYCX]LNDLK10(WLCUR)      = ""
    [M:AYCX]LNVAL10(WLCUR)      = [F:ADI1]CODE
    [M:AYCX]LNFIECOD10(WLCUR)   = ""
    For [AYN1] Where MENADV=ADVCOD and MENADI=[F:ADI1]CODE                   
        [M:AYCX]LNDLK10(WLCUR)      = [F:AYN1]DLKCOD
        If [F:AYN1]DLKCOD<>"" : [M:AYCX]LNTYP10(WLCUR)      = 2 : Endif
        [M:AYCX]LNVAL10(WLCUR)      = [F:AYN1]VALEUR
        [M:AYCX]LNFIECOD10(WLCUR)   = [F:AYN1]FIECOD
        Break
    Next

    WLCUR+=1
    If WLCUR > LMAX : Break : Endif

    Raz WFLGDEP
    If ADVCHILDNB : WFLGDEP=1 : Break : Endif    # Il faut traiter les tables liées
Next
[M:AYCX]NUM10=WLCUR
If [M:AYCX]NUM10 >= LMAX : Goto TABLEV_END : Endif

# Dépendances
If WFLGDEP
    Raz WFLGDEP
    For WL=1 To ADVCHILDNB 
        Call GET_TABLEV(LMAX, [M:AYCX]LNCOD10(WLCUR-1), [M:AYCX]LNADI10(WLCUR-1), ADVCHILD(WL), GESADISHO, NIVMAX, NIVCUR+1)
        If [M:AYCX]NUM10 >= LMAX : Break : Endif
    Next
    If [M:AYCX]NUM10 >= LMAX : Goto TABLEV_END : Endif
    Goto TABLEV_BCL
Endif

$TABLEV_END
End




