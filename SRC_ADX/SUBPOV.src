#<AdxTL>@(#)85.0.0.0 $Revision$
#########################################################################
# SUBPOV : Visualisation des commandes ouvertes d'achat     CG 15/03/98 #
# --------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'objet "POV et des actions Gosub     #
#                                                                       #
# GSYSCUR = devise dossier                                              #
# GCUR    = devise societe                                              #
# GFINRSP = site financier                                              #
#                                                                       #
# Uniquement de la visu, pas de modif ni de création                    #
#########################################################################

$ACTION
#---------------------------------#
# Actions de l'objet POV (GOBJET) #
#---------------------------------#
Case GACTION
 When "GOBJET", "GOBJETC0"
  Case ACTION
   When "OUVRE"        : Gosub OUVRE
   When "SETBOUT"      : Gosub SETBOUT 
   When "AVANTBOUT"    : Gosub AVANTBOUT
   When "EXEBOUT"      : Gosub EXEBOUT
   When "FILTRE"       : Gosub FILTRE
   When "AV_IMPRIME"   : Gosub AV_IMPRIME
   When "LIENS"        : Gosub LIENS
   When "DEFLIG"       : Gosub DEFLIG
   When "LIENS_LIG"    : Gosub LIENS_LIG
   When "FERME"        : Gosub FERME
   When Default
  Endcase
#---------------------------------------------------------------------#
# Action sur la saisie de fenêtre (GSAISIE)                           #
# VISUETAPOC : Visualisation situation ligne article commande ouverte #
#---------------------------------------------------------------------#
 When "VISUETAPOC"
  Case ACTION
   When "OUVRE"        : Gosub OUVRE_FEN
   When "TITRE"        : Gosub TITRE_FEN
   When "DEBUT"        : Gosub DEBUT_FEN
   When "FINSAI"       : Gosub FINSAI_FEN
   When Default
  Endcase
Endcase
Return


#######################################################################
# Action sur la saisie de fenêtre (GSAISIE)                           #
# ------------------------------------------------------------------- #
# VISUETAPOC : Visualisation situation ligne article commande ouverte #
#######################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE_FEN
Case GACTION
 When "VISUETAPOC" : Gosub OUV_VISUETAPOC 
Endcase
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
Case GACTION
 When "VISUETAPOC" : TIT=mess(46,195,1)-WNUMCDE-num$(WLINCDE)
Endcase
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT_FEN
Case GACTION
 When "VISUETAPOC" : Gosub DEB_VISUETAPOC
Endcase
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FEN
Case GACTION
 When "VISUETAPOC" : Gosub FINSAI_VISUETAPOC
Endcase
Return


####################################################
# Actions sur la gestion de l'objet "POV" (GOBJET) #
####################################################

$OUVRE
#---------------------------------------------------------#
# Pas de transaction pour les demandes de livraisons      #
# Déclaration des variables pour gestion entête et détail #
#---------------------------------------------------------#
If GFONC1<>"GESPOV" 
  Local Integer SAVGCONSULT : SAVGCONSULT=GCONSULT
  GCONSULT=2 
Endif
Gosub DECLARE From TABLEAUX
Global Decimal GPOV_EARQTY
Return


$SETBOUT 
#--------------------------------------# 
# Suppression des boutons Création     # 
#                         Suppression  # 
#                         Duplication  # 
#                         Modification # 
#--------------------------------------# 
Call VIREBOUT (CHAINE,"ACDMH") From GOBJET 
If !CLECUR 
  Call VIREBOUT (CHAINE,"12") From GOBJET 
Endif 
Return 
 

$AVANTBOUT
#-----------------------------# 
# Avant exécution des boutons # 
# --------------------------- #
# 1 = Contrat                 #
# 2 = Situation               #
#-----------------------------#
Case BOUT
  When "1" : Local Char ANC_POHNUM(GLONPOH) : ANC_POHNUM=[M:POV1]POHNUM
Endcase
Return


$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
# 1 = Contrat                        #
# 2 = Situation                      #
#------------------------------------#
Case BOUT
  When "1" : [M:POV1]POHNUM=ANC_POHNUM : Gosub RELIT From GOBJET
Endcase
Return


$FILTRE
#-------------------------------------------------------------#
# Besoin pour activer filtre sur les habilitations opérateurs #
# sinon filtre ne marche pas                                  #
#-------------------------------------------------------------#
Default File [POC]
Return


$AV_IMPRIME
#------------------#
# Avant impression #
#------------------#
Return


$LIENS
#-------------------#
# lecture du PORDER #
#-------------------#
Grizo [POV1]BETFCY
If [F:POH]POHNUM<>[F:POC]POHNUM
  Read [POH] POH0=[F:POC]POHNUM
  If fstat Raz [F:POH] : GMESSAGE=mess(23,100,1) : GERR=1 : OK=0 : Return : Endif
Endif
[M:POV1]ORDDAT = [F:POH]ORDDAT
[M:POV1]ORDREF = [F:POH]ORDREF
If [F:POH]BETFCY=0 [F:POH]BETFCY=1 : Endif
[M:POV1]BETCPY = [F:POH]BETCPY
[M:POV1]BETFCY = [F:POH]BETFCY
[M:POV1]SALFCY = [F:POH]SALFCY
[M:POV1]OCNNUM = [F:POH]OCNNUM
If [F:POH]BETFCY<>2 Grizo [POV1]SALFCY Else Actzo [POV1]SALFCY : Endif
#----- Chargement société, site financier et paramètres -----#
Call DEFSITE([F:POH]POHFCY) From TRTACHDEF1
Call GLOBVAR([F:POH]POHFCY) From WWGLOBACH
Call GLOBVAR(GFINRSP)       From WWGLOBBUD
#----- Relecture des fichiers liés ----#
Call RELEC From SUBPODA
#-----
Raz GPOV_EARQTY
Gosub LIENS From TABLEAUX
#----- Lecture du tiers si besoin -----#
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  Read [BPR] BPR0=[F:POH]BPSNUM : If fstat  Raz [F:BPR] : Endif
Endif
#----- Lecture du fournisseur si nécessaire -----#
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#-----
If [F:POH]BPRNAM(0)=""
  [M:POV1]XBPRNAM=[F:BPS]BPSNAM(0)
Else
  [M:POV1]XBPRNAM=[F:POH]BPRNAM(0)
Endif
If [M:POV1]REVNUM<>0
  [M:POV1]FILLER1="/"
Endif
Return 


$DEFLIG
#--------------------------------------------#
# fichier PORDERP est le fichier par defaut  #
# un seul masque dans cet objet              #
#--------------------------------------------#
Default File [POQ]
#----- On dépositionne un filter au cas où -----#
#-------------------------------------#
Filter [POQ]
#----- Critère de lecture toutes lignes -----#
CRIT='POHNUM="'+[M:POV1]POHNUM+'" & POPLIN='+num$([M:POV1]POPLIN)
#------ fichier details ------#
FICLIG = "PORDERQ"
#------- abreviation ------#
ABLIG = "POQ"
#-------zone ligne --------#
ZONLIG = "POQSEQ"
Return


$LIENS_LIG
#-----------------------------------------------------------#
# ici on se trouve dans la boucle de chargement des details #
# il faut charger certains champs de l ecran                #
#-----------------------------------------------------------#
[M:POV1]XPRHFCY(nolign-1)=[F:POQ]PRHFCY
[M:POV1]USEPLC (nolign-1)=[F:POQ]USEPLC
If [M:POV1]LINSTA(nolign-1)<>3
  If [M:POV1]EXTRCPDAT(nolign-1)<min(date$,[F:POC]ENDDAT)
    [M:POV1]LINSTA(nolign-1)=2
    If [F:POQ]WIPSTA=1  GPOV_EARQTY+=[F:POQ]QTYPUU : Endif
  Else
    [M:POV1]LINSTA(nolign-1)=1
  Endif
Endif
#----- Chargement zone WRCPDAT -----#
Local Shortint WJOUR ,WMOIS ,WANNEE
Local Char WDATE(10)
WANNEE = val(left$([M]EXTRCPDAT (nolign-1),4))
WMOIS  = val(mid$([M]EXTRCPDAT  (nolign-1),5,2))
WJOUR  = val(right$([M]EXTRCPDAT(nolign-1),7))
If [M]CAD (nolign-1)=1           : # cadencement jour
  Gosub DAT8 From SUBPODA
  [M]WRCPDAT (nolign-1)    = WDATE
  [M]STRRCPDAT(nolign -1)  = [M]EXTRCPDAT (nolign-1)
Elsif [M]CAD (nolign-1)=3        : # cadencement mois
  [M]STRRCPDAT (nolign-1) = aweek([M]WEE(nolign-1),[M]YEA(nolign-1))
  Local Char WWMOIS
  If len(num$(WMOIS))= 1
    WWMOIS = "0"+num$(WMOIS)
  Else
    WWMOIS = num$(WMOIS)
  Endif
  WDATE= format$("K:2#[-]4#",WWMOIS+num$(WANNEE))
  [M]WRCPDAT (nolign-1) = WDATE
Else                             : # cadencement semaine
  [M]STRRCPDAT(nolign-1) = aweek([M]WEE(nolign-1),[M]YEA(nolign-1))
  Local Char WSEM
  If len(num$([M]WEE(nolign-1)))= 1
    WSEM = "00"+num$([M]WEE(nolign-1))
  Elsif len(num$([M]WEE(nolign-1)))= 2
    WSEM = "0"+num$([M]WEE(nolign-1))
  Else
    WSEM = num$([M]WEE(nolign-1))
  Endif
  WDATE= format$("K:3#[-]4#",WSEM+num$([M]YEA (nolign-1)))
  [M]WRCPDAT (nolign-1) = WDATE
Endif
Return


$FERME
#-----------#
# Fermeture #
#-----------#
Call IMPSCR From ATRTX3
If GFONC1<>"GESPOV"  GCONSULT=SAVGCONSULT : Endif
If dim(GPOV_EARQTY)>0   Kill GPOV_EARQTY  : Endif
Return


#############################################################################
# SITUATION : S/P visualisation de la situation ligne article cde ouverte   #
#   La classe [F:POC] est chargée par la gestion de l'objet POV             #
# ------------------------------------------------------------------------- #
# Remplacé par l'action VISUETAPOC avec paramètres :           MBT 19/12/00 #
#   PARAM(1) = NUM    : Numéro de la commande ouverte à traiter             #
#   PARAM(2) = LIN    : Numéro de la ligne article de la commande ouverte   #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETAPOC
#----- Variables locales -----#
Local Char     WNUMCDE(GLONPOH) : WNUMCDE=PARAM(1)
Local Integer  WLINCDE          : WLINCDE=val(PARAM(2))
Local Shortint SAVNOLIGN        : SAVNOLIGN=nolign
#----- Lecture si nécessaire de la ligne article contrat -----#
If [F:POC]POHNUM<>WNUMCDE | [F:POC]POPLIN<>WLINCDE
  Read [POC] POC0=WNUMCDE;WLINCDE : If fstat Raz [F:POC] : Endif
Endif
#-----
If [F:POC]EARQTY<>GPOV_EARQTY | [F:POC]EARDAT<>min(date$,[F:POC]ENDDAT)
  Trbegin [POC], [POQ]
  Update [POC] Where POHNUM=WNUMCDE & POPLIN=WLINCDE
&              With  EARQTY=GPOV_EARQTY, EARDAT=min(date$,[F:POC]ENDDAT)
  If fstat
    Call FSTA("POC") From GLOCK : Rollback : Return
  Else
  # Issue 76630 - 2011-09-30 by VPO : pas de Maj si ligne soldée, sinon devient retard
    Update [POQ] Where POHNUM=WNUMCDE & POPLIN=WLINCDE & LINSTA<>3 & EXTRCPDAT<min(date$,[F:POC]ENDDAT)
&                With  LINSTA=2
    If fstat  Call FSTA("POQ") From GLOCK : Rollback : Return : Endif
  Endif
  Commit
  [F:POC]EARQTY=GPOV_EARQTY
  [F:POC]EARDAT=min(date$,[F:POC]ENDDAT)
Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETAPOC
Raz [M:POVD]
[M:POVD]=[F:POC]
Affzo [POVD]
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETAPOC
Default Mask [M:POV1]
nolign=SAVNOLIGN
Return


###############################
# Action sur champ écran POV1 #
###############################

Subprog IB_NBLIG
#------------------------#
# Activation des boutons #
#------------------------#
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
If [M:POV1]NBLIG=0 | dim([M:POV1]WRCPDAT)<nolign  End : Endif
If [M:POV1]WIPSTA(nolign-1)=1 & GMODU(2)=2 & [M:POV1]CMMNUM(nolign-1)<>""
  GBOUT2=mess(160,198,1)-[M:POV1]CMMNUM(nolign-1) : # Engagements
Endif
End
