#<AdxTL>@(#)0.0.0.0 $Revision$Class Project  
# Supervisor
## ACLA-CLASSE ## PROJET
# 2018-11-06 07:13:50 630

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0PROJET
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PRJ From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_DESTRA From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_SHOTRA From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_DESLNG From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_GCF From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_INTGCF From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_INVTYP From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_AIM From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_USR From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_AMTEVAL From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_CUR From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_STUSTR From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_STUEND From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_REASTR From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_REAEND From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_ACS From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_TYP From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_CREDAT From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_CRETIM From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_UPDDAT From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_UPDTIM From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_EXPNUM From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1PROJET : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1PROJET : Gosub TESTALLSTAT
Gosub AINIT From WMC0PROJET : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0PROJET
Gosub _ALOADATTRIBUTE_PRJ From WMC1PROJET : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_GCF From WMC1PROJET : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_USR From WMC1PROJET : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_REASTR From WMC1PROJET : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_REAEND From WMC1PROJET : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0PROJET
Gosub LNKPRO_DESLNG From WMC1PROJET : Gosub TESTALLSTAT
Gosub LNKPRO_INVTYP From WMC1PROJET : Gosub TESTALLSTAT
Gosub LNKPRO_AIM From WMC1PROJET : Gosub TESTALLSTAT
Gosub LNKPRO_USR From WMC1PROJET : Gosub TESTALLSTAT
Gosub LNKPRO_CUR From WMC1PROJET : Gosub TESTALLSTAT
Gosub LNKPRO_ACS From WMC1PROJET : Gosub TESTALLSTAT
For AINDCLA=1 To 10
 If this.COLBPRFIN(AINDCLA)<>null& find(this.COLBPRFIN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.COLBPRFIN(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 24
 If this.COLPER(AINDCLA)<>null& find(this.COLPER(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.COLPER(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.LOT(AINDCLA)<>null& find(this.LOT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.LOT(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.FAS(AINDCLA)<>null& find(this.FAS(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.FAS(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



