#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# Nouvelle gestion des textes en 140                                    #
#########################################################################

#########################################################################
#  TRAITEMENT DES TEXTES                                      TRTX3TEX  #
#                                                                       #
#########################################################################

$ACTION
# Question à choix multiple si qté sélectionnée < qté à traiter
If GACTION="DIVCHX2"
   Case ACTION
    When "OUVRE"    : Gosub OUVRE_DIVCHX2
    When "TITRE"    : Gosub TITRE_DIVCHX2
    When "DEBUT"    : Gosub DEBUT_DIVCHX2
    When "BOUTON"   : Gosub BOUT_DIVCHX2
    When "FINSAI"   : Gosub FINSAI_DIVCHX2
   Endcase
# Saisie texte : actions ACLOB et ACLOB2
Else
   Case ACTION
    When "INIT_DIA" : Gosub INIT_DIA
    When "EXEC"     : Gosub EXEC
   Endcase
Endif
Return

#########################################################################
$INIT_DIA
If !clalev([F:TCC]) Local File TEXCPT  [TCC] Endif
If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif

## GH 13/03/14 bug 97777 déplacé dans EXEC
#Local Integer WDBASE    : # 0=Texte 'document' / 1=Texte 'donnée de base'
#Local Integer WEXIST    : # Existence texte dans [F:TXC] : 0=Non / 1=Oui
#
#If find(PARAM(2),"ITM","ITS","ITU","ITP","BPC","BPS","BPD","BOM","BOD","ROH","ROO","ROT")
#   WDBASE=1
#Else
#   WDBASE=0
#Endif
##

If PARAM(1)<>""
   If !find(PARAM(1),GCLOIDE(1..GCLOMAX))
      Read [TXC]TXC0=PARAM(1)
      If !fstat
         Call RANGE_CLOB([F:TXC]TEXTE,PARAM(1),STAT) From ACLOB
         If STAT=1
            # Taille mémoire des textes dépassée
            Call ERREUR(mess(215,126,1)-"("+num$(GCLOMEM)-"Ko)") From GESECRAN
         Endif
      Endif
   Endif
Endif

Case PARAM(2)
  When "PQD"   : TITCRIT=mess(180,195,1)-num$(nolign)-[M:PQH1]ITMREF(nolign-1)
  When "PSD"   : TITCRIT=mess(180,195,1)-num$(nolign)-[M:PSH1]ITMREF(nolign-1)
  When "POQ"
    If clalev([M:POH2])
                 TITCRIT=mess(180,195,1)-num$(nolign)-[M:POH2]ITMREF(nolign-1)
    Elsif clalev([M:POD1])
                 TITCRIT=mess(180,195,1)-num$(nolign)-[M:POD1]ITMREF
    Endif
  When "POC"   : TITCRIT=mess(180,195,1)-num$([M:POC2]POPLIN)-[M:POC2]ITMREF
  When "PTD"   : TITCRIT=mess(180,195,1)-num$(nolign)-[M:PTH1]ITMREF(nolign-1)
  When "PND"   : TITCRIT=mess(180,195,1)-num$(nolign)-[M:PNH1]ITMREF(nolign-1)
  When "PID"   : TITCRIT=mess(180,195,1)-num$(nolign)-[M:PIH3]ITMREF(nolign-1)
  When "ITU"   :
    If PARAM(4) = "[M:BPC0]" Then
      If [M:BPC6]XITSTEX <> "" Then
        TITCRIT=mess(231,198,1)-evalue(PARAM(4)+"BPCNUM")
      Endif
      If [M:BPC6]XITPTEX <> "" Then
        TITCRIT=mess(229,198,1)-evalue(PARAM(4)+"BPCNUM")
      Endif
    Else
      # Issue X3-71652 - 2018-02-02 by SDEM : begin
      #TITCRIT=mess(229,198,1)-[M:ITU]BPCNUM(nolign-1)
      #TITCRIT=mess(231,198,1)-[M:ITU]BPCNUM(nolign-1)
      If GACTION="ACLOB2"
        TITCRIT=mess(229,198,1)-[M:ITU]BPCNUM(nolign-1)
      Elsif GACTION="ACLOB"
        TITCRIT=mess(231,198,1)-[M:ITU]BPCNUM(nolign-1)
      Endif
      # Issue X3-71652 - 2018-02-02 by SDEM : end
    Endif
  Endcase
Return

#########################################################################
$EXEC
Local Integer I, WTEXSEQ
Local Char    WTEXTE

## GH 13/03/14 bug 97777 déplacé depuis INIT_DIA
Local Integer WDBASE    : # 0=Texte 'document' / 1=Texte 'donnée de base'
Local Integer WEXIST    : # Existence texte dans [F:TXC] : 0=Non / 1=Oui

# WDBASE = (find(PARAM(2),"ITM","ITS","ITU","ITP","BPC","BPS","BPD","BOM","BOD","ROH","ROO","ROT")<>0) : # GH 02/03/15 bug 106673
WDBASE = (find(PARAM(2),"ITM","ITS","ITU","ITP","BPC","BPS","BPD","BOH","BOD","ROH","ROO","ROT")<>0)
##

# Le clob a été modifié
If [M:ACL]CLOBSVG <> [M:ACL]CLOB

   # Le texte modifié existe-t-il déjà dans [F:TXC]
   Raz WEXIST
   If PARAM(1)<>""
      Read [TXC]TXC0=PARAM(1)
      If !fstat WEXIST=1 Endif
   Endif

   Setlob WTEXTE With [M:ACL]CLOB

   # Le texte a été supprimé
   If len(WTEXTE)=0
      # Si texte 'donnée de base'
      If WDBASE=1
         # L'identifiant du clob existe déjà dans [F:TXC]
         If WEXIST=1
            # Question
            If val(PARAM(6))=2
               Local Char    PARMSK(250)(1..20) , SAVACT(20)
               SAVACT = GACTION : GACTION = "DIVCHX2"
               PARMSK(1) = "882"
               PARMSK(2) = "3"
               PARMSK(3) = "196"
               Call SAISIE_NUM(GBIDD1,PARMSK,"ICHX2","TRTX3TEX","") From GSAISIE
               GACTION = SAVACT
               # On raz l'identifiant du clob
               If PARMSK(4)="A"
                  Raz PARAM(1)
               Endif
            # On raz l'identifiant du clob
            Else
               Raz PARAM(1)
            Endif
         # L'identifiant du clob n'existe pas dans [F:TXC]
         Else
            Raz PARAM(1)
         Endif
      # Sinon texte 'document'
      # L'identifiant du clob est un lien --> on raz le lien
      Elsif PARAM(2)<>left$(PARAM(1),3)
         Raz PARAM(1)
      # Sinon on supprime le clob
      Else
         Call VIRE_CLOB(PARAM(1),STAT) From ACLOB
         Raz PARAM(1)
      Endif
   # Le texte a été modifié
   Else
      # Si texte 'donnée de base'
      If WDBASE=1
         # Pas d'identifiant du clob
         If PARAM(1)=""
            Raz STAT
            Call NUM_TXC(PARAM(2),WTEXSEQ,STAT)
            If STAT=0
               PARAM(1)=PARAM(2)+"~"+format$("N0:8#",num$(WTEXSEQ))
            Endif
         # L'identifiant du clob existe déjà dans [F:TXC]
         Elsif WEXIST=1
            # Question
            If val(PARAM(6))=2
               Local Char    PARMSK(250)(1..20) , SAVACT(20)
               SAVACT = GACTION : GACTION = "DIVCHX2"
               PARMSK(1) = "882"
               PARMSK(2) = "3"
               PARMSK(3) = "196"
               Call SAISIE_NUM(GBIDD1,PARMSK,"ICHX2","TRTX3TEX","") From GSAISIE
               GACTION = SAVACT
               # Création nouveau texte
               If PARMSK(4)="A"
                  Raz STAT
                  Call NUM_TXC(PARAM(2),WTEXSEQ,STAT)
                  If STAT=0
                     PARAM(1)=PARAM(2)+"~"+format$("N0:8#",num$(WTEXSEQ))
                  Endif
               Endif
            # Création nouveau texte
            Else
               Raz STAT
               Call NUM_TXC(PARAM(2),WTEXSEQ,STAT)
               If STAT=0
                  PARAM(1)=PARAM(2)+"~"+format$("N0:8#",num$(WTEXSEQ))
               Endif
            Endif
         Endif
      # Sinon texte 'document'
      # Pas d'identifiant du clob ou l'identifiant du clob est un lien
      # --> on écrit un nouveau texte
      Elsif PARAM(2)<>left$(PARAM(1),3)
         Raz STAT
         Call NUM_TXC(PARAM(2),WTEXSEQ,STAT)
         If STAT=0
            PARAM(1)=PARAM(2)+"~"+format$("N0:8#",num$(WTEXSEQ))
         Endif
      Endif
   Endif

   # Si texte ligne --> positionnement flag modification
   If val(PARAM(5))<>0
      I=val(PARAM(5))
      If evalue("dim([M:"+PARAM(4)+"]UPDFLG)")>0
         Assign "[M:"+PARAM(4)+"]UPDFLG(I-1)" With 1
      Endif
   Endif
   mkstat=4
Endif

Return

#########################################################################
#########################################################################
#########################################################################

##########################################################################
# Action DIVCHX2 : Choix texte                                           #
#   PARAM(1) = NUMTEX  : Numéro du premier texte à afficher              #
#   PARAM(2) = NBTEX   : Nombre de texte à afficher                      #
#   PARAM(3) = NUMCHAP : Numéro du chapitre (des textes)                 #
#   PARAM(4) = WBOUT   : (A,B,F)                                         #
##########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE_DIVCHX2
Local Char     WBOUT(1)
Local Shortint WNUMTEX  : WNUMTEX =val(PARAM(1))
Local Shortint WNBTEX   : WNBTEX  =val(PARAM(2))
Local Shortint WNUMCHAP : WNUMCHAP=val(PARAM(3))
Local Char     WTEXCLOB(240)
Local Integer  I
Return
#---------------------#
# Titre de la fenêtre #
#---------------------#
$TITRE_DIVCHX2
TIT=mess(10,188,1)
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT_DIVCHX2
If WNBTEX=0 Return Endif
For I=0 To WNBTEX-1
   WTEXCLOB += mess(WNUMTEX+I,WNUMCHAP,1)+chr$(13)
Next I
Setlob [M:CHT]TEX With WTEXCLOB
Affzo [CHT]1-99
Return
#--------#
# Bouton #
#--------#
$BOUT_DIVCHX2
WBOUT=BOUT : FIN=1
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_DIVCHX2
PARAM(4)=WBOUT
Return

#########################################################################
#########################################################################
#########################################################################

#########################################################################
# CRE_CLOB : Création d'un clob dont le texte est stocké en mémoire
#------------------------------------------------------------------------
# Exemples d'utilisation
#        - En création ou modification d'un document
#          (si l'identifiant du clob correspond à l'abréviation du fichier
#           du document traité)
#------------------------------------------------------------------------
# Entrée : CODETEX : Identifiant du clob à créer
#          STAT    : Status de sortie
#                       1 = OK
#                       0 = Erreur
#                      -1 = Enregistrement bloqué
#########################################################################
Subprog CRE_CLOB(CODETEX,STAT)
Value    Char    CODETEX
Variable Integer STAT

#MAE, bg 56988 Local    Clbfile CLOB(6)
Local    Clbfile CLOB(GLONACB)

# Rien à créer : on considère que ce n'est pas une erreur
If CODETEX="" : STAT=1 : End : Endif

Raz STAT
If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif

If find(CODETEX,GCLOIDE(1..GCLOMAX))

   Call LIRE_CLOB(CLOB,CODETEX,STAT) From ACLOB
   If STAT=0
      Readlock [TXC]TXC0=CODETEX
      # L'enregistrement est bloqué
      If fstat=1
         STAT=-1 : GLOCK="$TEXCLOB"-CODETEX : End
      # Le clob n'existe pas, on l'écrit
      Elsif fstat
         [F:TXC]CODE   = CODETEX
         [F:TXC]TEXTE  = CLOB
         [F:TXC]IDENT1 = ""
         [F:TXC]IDENT2 = ""
         [F:TXC]IDENT3 = [F:TXC]CODE
         [F:TXC]CREUSR = GUSER
         [F:TXC]CREDAT = date$
         [F:TXC]CRETIM = time
         # Issue 88469 - 2013-06-06 by MAE : Mise à jour des textes
         GPOINT = "MAJTEXCLOB" : Gosub ENTREE From EXEFNC
         Write [TXC]
         If fstat
            STAT=0 : Call FSTA("TXC") From GLOCK : End
         Endif
      # Le clob existe déjà, on le réécrit
      Else
         [F:TXC]TEXTE  = CLOB
         # Issue 88469 - 2013-06-06 by MAE : Mise à jour des textes
         GPOINT = "MAJTEXCLOB" : Gosub ENTREE From EXEFNC
         Rewrite [TXC]
         If fstat
            STAT=0 : Call FSTA("TXC") From GLOCK : End
         Endif
      Endif
      # Nettoyage du texte du clob de la mémoire
      Call VIRE_CLOB(CODETEX,STAT) From ACLOB
      STAT=1
   Endif
Else
   STAT=1
Endif

End

#########################################################################
# DUP_CLOB : Dupplication d'un clob
#------------------------------------------------------------------------
# Exemples d'utilisation
#        - En création d'un document
#          (si l'identifiant du clob origine correspond à l'abréviation
#           du fichier du document d'origine)
#        - En initialisation de dupplication d'une donnée de base (RAZDUP)
#        - En initialisation de dupplication d'un document (RAZDUP)
#          (si l'identifiant du clob origine n'est pas un lien)
#        - Dans les automatismes de création d'un document à partir d'un autre
#          (si l'identifiant du clob origine n'est pas un lien)
#------------------------------------------------------------------------
# Entrée : ABRFIC  : Abréviation de la table de référence du clob à créer
#          CODETEX : Identifiant du clob origine (à duppliquer)
# Sortie : CODETEX : Identifiant du clob créer
#          STAT    : Status de sortie
#                       1 = OK
#                       0 = Erreur
#########################################################################
Subprog DUP_CLOB(ABRFIC,CODETEX,STAT)
Value    Char    ABRFIC
Variable Char    CODETEX
Variable Integer STAT

Local Integer WTEXSEQ

# Rien à duppliquer : on considère que ce n'est pas une erreur
If CODETEX="" : STAT=1 : End : Endif

Raz STAT
If !clalev([F:TCC]) Local File TEXCPT  [TCC] Endif
If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif

Read [TXC]TXC0=CODETEX
If !fstat
   Call NUM_TXC(ABRFIC,WTEXSEQ,STAT)
   If STAT=0
      [F:TXC]CODE = ABRFIC+"~"+format$("N0:8#",num$(WTEXSEQ))
      Raz [F:TXC]IDENT1
      Raz [F:TXC]IDENT2
      [F:TXC]IDENT3=[F:TXC]CODE
      [F:TXC]CREUSR=GUSER
      [F:TXC]CREDAT=date$
      [F:TXC]CRETIM=time
      # Issue 88469 - 2013-06-06 by MAE : Mise à jour des textes
      GPOINT = "MAJTEXCLOB" : Gosub ENTREE From EXEFNC
      Write [TXC]
      If fstat
         STAT=0 : Call FSTA("TXC") From GLOCK
         Raz CODETEX : End
      Else
         CODETEX = [F:TXC]CODE
      Endif
      STAT=1
   Else
      STAT=0
   Endif
Else
   # On considère que ce n'est pas une erreur
   Raz CODETEX : STAT=1
Endif

End

#########################################################################
# SUP_CLOB : Suppression d'un clob
#------------------------------------------------------------------------
# Exemples d'utilisation
#        - En abandon de dupplication d'une donnée de base
#        - En abandon de dupplication d'un document
#          (si l'identifiant du clob n'est pas un lien)
#        - En suppression d'un document
#          (si l'identifiant du clob n'est pas un lien)
#------------------------------------------------------------------------
# Entrée : CODETEX : Identifiant du clob à supprimer
# Sortie : STAT    : Status de sortie
#                       1 = OK
#                       0 = Erreur
#########################################################################
Subprog SUP_CLOB(CODETEX,STAT)
Value    Char    CODETEX
Variable Integer STAT

Local Integer ASTAT # Return code of the supervisor subprog Gbn-87769

STAT=1

# Rien à supprimer : on considère que ce n'est pas une erreur
If CODETEX="" End Endif

If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif

Readlock [TXC]TXC0=CODETEX
If !fstat
   # Issue 79018 - 2012-01-05 by VPO : dde de liv, on perd les textes lors de la renumérot des lignes
   # Gbn-87769- Using the local variable ASTAT instead of STAT to avoid values confusion.
   Call RANGE_CLOB([F:TXC]TEXTE,CODETEX,ASTAT) From ACLOB
   If ASTAT=1
      # Taille mémoire des textes dépassée
      Call ERREUR(mess(215,126,1)-"("+num$(GCLOMEM)-"Ko)") From GESECRAN
      STAT=0 #Gbn-87769
   Elsif ASTAT>1
    STAT=0
   Endif
   #
   Delete [TXC]
   If fstat
      STAT=0 : Call FSTA("TXC") From GLOCK
   Endif
Endif

End


#########################################################################
# CRE_CLOB_ACL : Création d'un clob dont le texte est stocké
#                dans [M:ACL]CLOB (ecran standard de saisie des textes)
#------------------------------------------------------------------------
# Exemples d'utilisation
#        - En création automatique des factures de service FUNAUTINVS
#------------------------------------------------------------------------
# Entrée : CHAMPLIEN : Nom champ contenant le lien (recepteur du code texte)
#          T_OK      : Status de sortie
#                       1 = OK
#                       0 = Erreur
#                      -1 = Enregistrement bloqué
#########################################################################

Subprog CRE_CLOB_ACL(CHAMPLIEN,T_OK)
Value    Char    CHAMPLIEN
Variable Integer T_OK

Local Integer WTEXSEQ, STAT
# Issue 108342 - 2015-11-06 by MAE : ABRFIC passage de 3 à 8
#Local Char    ABRFIC (3)
Local Char    ABRFIC (GLONABR)

Local    Integer WADXLOG     : # valeur de adxlog en entree du s/p
WADXLOG=adxlog

ABRFIC=evalue(CHAMPLIEN)
Raz T_OK

#        le champ lien parametre n existe pas (rien a creer, pas d erreur)
If evalue("dim("+CHAMPLIEN+")")<=0         : T_OK=1 : Goto FIN_CCA : Endif
#        le champ lien est vide (rien a creer, pas d erreur)
If CHAMPLIEN=""        : Assign CHAMPLIEN With "" : T_OK=1 : Goto FIN_CCA : Endif
#        le masque standard de saisie des textes est absent (erreur)
If dim([M:ACL]CLOB)<=0 : Assign CHAMPLIEN With "" : T_OK=0 : Goto FIN_CCA : Endif
#        le champ clob du masque est vide (rien a creer, pas d erreur)
Local Char SZTESTCLOB
Raz SZTESTCLOB
Setlob SZTESTCLOB With [M:ACL]CLOB
If SZTESTCLOB=""      : Assign CHAMPLIEN With "" : T_OK=1 : Goto FIN_CCA : Endif

If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif

Call NUM_TXC(ABRFIC,WTEXSEQ,STAT) From TRTX3TEX

#  erreur sur recherche no de sequence
If STAT<>0 : T_OK=0 : Assign CHAMPLIEN With "" : Goto FIN_CCA : Endif

#  creation du clob
If !WADXLOG                  : # si adxlog=1 on est deja dans une transaction
   Trbegin [TXC]
Endif

Assign CHAMPLIEN With ABRFIC+"~"+format$("N0:8#",num$(WTEXSEQ))

[F:TXC]CODE   = ABRFIC+"~"+format$("N0:8#",num$(WTEXSEQ))
[F:TXC]TEXTE  = [M:ACL]CLOB
[F:TXC]IDENT1 = ""
[F:TXC]IDENT2 = ""
[F:TXC]IDENT3 = [F:TXC]CODE
[F:TXC]CREUSR = GUSER
[F:TXC]CREDAT = date$
[F:TXC]CRETIM = time
Write [TXC]
If fstat
   T_OK=0 : Assign CHAMPLIEN With ""
Endif

If !WADXLOG
   Commit
Endif

$FIN_CCA

End


#########################################################################
# NUM_TXC : Attribution d'un numéro identifiant un clob stocké dans TEXCLOB
#------------------------------------------------------------------------
# Entrée : WABRFIC  : Abréviation de la table de référence du clob à créer
# Sortie : WTEXSEC  : Numéro attribué
#          WRETOUR  : Status de sortie
#                       0  = OK
#                       99 = Erreur
#########################################################################
Subprog NUM_TXC(WABRFIC,WTEXSEQ,WRETOUR)
Value    Char    WABRFIC
Variable Integer WTEXSEQ
Variable Integer WRETOUR

Local    Integer WADXLOG     : # valeur de adxlog en entree du s/p
WADXLOG=adxlog

If clalev([F:TCC])=0 : Local File TEXCPT [TCC] : Endif

# ----------
$TR_NUM_TXC
If !WADXLOG                  : # si adxlog=1 on est deja dans une transaction
    Trbegin [TCC]
Endif

Readlock [TCC]TCC0 = WABRFIC
If fstat = 1
   GOK=-1 : GLOCK = "$TEXCPT"-num$(ABRFIC) : Goto ROL_NUM_TXC
Elsif fstat                  : # il faut créer enr. avec le chrono = 1
   WTEXSEQ = 1
   Raz [F:TCC]
   [F:TCC]ABRFIC = WABRFIC
   [F:TCC]TEXSEQ = WTEXSEQ
         Write [TCC]
Else                         : # on a trouvé un chrono
   WTEXSEQ       = [F:TCC]TEXSEQ + 1
   [F:TCC]TEXSEQ = WTEXSEQ
   Rewrite [TCC]
Endif

If fstat
   GOK=0 : Call FSTA("TCC") From GLOCK : WRETOUR = 99 : Goto AB_NUM_TXC
Endif

If !WADXLOG
    Commit
Endif

End

# ----------
$ROL_NUM_TXC
If !WADXLOG
   Rollback
   Call ROLL From GLOCK
   If GROLL
      WRETOUR=99 : Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
   Else
      Goto TR_NUM_TXC
   Endif
Endif
End

# ----------
$AB_NUM_TXC
If !WADXLOG
   Rollback
   Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
End


##########################################################################################
## Appelé en validation dossier
## Pour copier les textes Clob d'une table ( ex: clients, fournisseurs..)
## Attention : Il ne doit pas y avoir de textes dans TEXCLOB pour la table concernée
##########################################################################################
#
# Tout refaire de la façon suivante :
#  - modifier l'appel TXC_OF_FIC ( remplace ZONTEST ) : Textes de la table xxx
#                     TXC_OF_ABR ( remplace VALTEST ) : Abr de la table ayant les textes
#  - rechercher dans ATABZON les zones textes a copier de TXC_OF_FIC
#    - mettre dans un tableau les champs ayant CODFIC=TXC_OF_FIC & CODTYP="TXC"
#  - Faire une boucle sur les enr. de la table TXC_OF_FIC pour copier les textes.
#    - cette boucle peut être faite :
#      - pour gerer tous les textes ( reprise complète du traitement )
#      - pour gerer uniquement les textes ayant les anciennes cles ( complement au traitement actuel )
##########################################################################################

Subprog COPIE(TABLE,ZONTEST,VALTEST)
Value Char    TABLE     : # Code de la table ( toujours TEXCLOB )
Value Char    ZONTEST   : # Nom du champ a tester
Value Char    VALTEST   : # valeur a tester

If TABLE<>"TEXCLOB" : End : Endif

Local Integer  NBREC , MAXREC
Local Integer  I , J , K , T , D , OK

Local Char     CRITERE (100)
Local Integer  LASTCPT                            : # no ordre maxi pour maj compteur
Local Integer  CURRCPT                            : # no ordre enregistrement en copie
Local Integer  IJ

MAXREC = 1000

If TABLE="" | ZONTEST=""
 End
Elsif filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSSIER),0)<=0  : # dossier destination
 End
Endif

OK = 1
If filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSCOP),0)>=0    : # dossier origine
 Local File =[F:ADS]DOSCOP+"."+TABLE  [F1]                   : # ( en cascade )
Elsif filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSREF),0)>=0 : # DOSCOP --> DOSREF --> GDOSX3
 Local File =[F:ADS]DOSREF+"."+TABLE  [F1]
Elsif filinfo(filpath("FIL",TABLE,"fde",GDOSX3),0)>=0
 Local File =GDOSX3+"."+TABLE [F1]
Else
 OK = 0
Endif

# --- pour mise a jour de l'enregistrement compteur clob
#     ( il faut actualiser l'enregistrement du compteur lie a la table )
If OK
   If filinfo(filpath("FIL","TEXCPT","fde",[F:ADS]DOSSIER),0)>=0
      Local File =[F:ADS]DOSSIER+".TEXCPT"  [TCC]
   Else
      OK=0
   Endif
Endif
# ---

If OK & evalue("dim([F:F1]"+ZONTEST+")")<=0
 OK = 0
Endif
If OK
 Local File =[F:ADS]DOSSIER+"."+TABLE [F2]

 If GINFO
  # Copie des données - Table
  Call AFF_VLC(mess(30,125,1),mess(56,123,1)-TABLE) From GESECRAN
 Endif
 # Table
 Call ECR_TRACE(mess(56,123,1)-TABLE,0) From GESECRAN
 NBREC = 0

# --- Constitution du critere
 CRITERE="1=1"
 CRITERE +=" & CODE>'"+VALTEST+"~00000000' & CODE<'"+VALTEST+"~99999999'"
# ---

 Trbegin [F2]
  Raz LASTCPT
  For [F1]  Where evalue (CRITERE)
   OK = 1
#  --- pour insertion eventuelle de filtres
   If OK
#   --- stockage du plus grand no ordre du compteur
    IJ=instr(1,[F:F2]CODE,"~") : Raz CURRCPT
    If IJ : CURRCPT=val(right$([F:F2]CODE,IJ+1)) : Endif
    If CURRCPT>LASTCPT : LASTCPT=CURRCPT : Endif
#   ---
    If NBREC>=MAXREC
     Gosub COPIE_MAJ_TCC
     Commit
     Trbegin [F2]
     NBREC = 0
    Endif

    NBREC += 1
    [F:F2] = [F:F1]

    Write [F2]
    If fstat
     Call ERREUR(TABLE,1) From DOSDIC
    Endif
   Endif
  Next F1
 Gosub COPIE_MAJ_TCC
 Commit

# --- il faut reprendre les textes stockés avec une ancienne clé xx_ ( xx=no module )
 Gosub COPIE_OLD_TEX
# ---

 Close Local File [F1] , [F2], [TCC]
Endif
End

#------------------------------------------------------------------------
$COPIE_MAJ_TCC
Readlock [F:TCC]TCC0=VALTEST
If !fstat
  If LASTCPT>[F:TCC]TEXSEQ
    [F:TCC]TEXSEQ=LASTCPT
    Rewrite [TCC]
  Endif
Endif
Return

#------------------------------------------------------------------------
$COPIE_OLD_TEX

#    DEFINIR AVANT CE QU'IL FAUT FAIRE
#    DERNIERE MINUTE : COPIER TOUS LES TEXTES TC (09_xxxxxx)
Return

Case VALTEST
     When "BPC"  Gosub C_TEX_BPC
     When "BPC"  Gosub C_TEX_BPD
     When "BPC"  Gosub C_TEX_BPS
Endcase
Return

$C_TEX_BPC
   If filinfo(filpath("FIL","BPCUSTOMER","fde",[F:ADS]DOSSIER),0)>=0
      Local File =[F:ADS]DOSSIER+".BPCUSTOMER"  [F3]
   Else
      Return
   Endif
Return

$C_TEX_BPD
   If filinfo(filpath("FIL","BPDLVCUST","fde",[F:ADS]DOSSIER),0)>=0
      Local File =[F:ADS]DOSSIER+".BPDLVCUST"  [F3]
   Else
      Return
   Endif
Return

$C_TEX_BPS
   If filinfo(filpath("FIL","BPSUPPLIER","fde",[F:ADS]DOSSIER),0)>=0
      Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [F3]
   Else
      Return
   Endif
Return

#########################################################################################
# Sous-programme appelé sur action CHANGE                                               #
#    Permet de faire suivre les textes traduits lors d'un changement de clé             #
#  SZTABLE   = [AXX]CODFIC                                                              #
#  SZOIDENT1 = [AXX]IDENT1   => Ancienne valeur                                         #
#  SZOIDENT2 = [AXX]IDENT2   => Ancienne valeur (peut être à vide)                      #
#  SZNIDENT1 = [AXX]IDENT1   => Nouvelle valeur                                         #
#  SZNIDENT2 = [AXX]IDENT2   => Nouvelle valeur (à vide si SZOIDENT2 à vide)            #
#########################################################################################
Subprog CHANGE_AXX (SZTABLE, SZOIDENT1, SZOIDENT2, SZNIDENT1, SZNIDENT2)
Value Char SZTABLE     # FGR 01/02/2010 : X3SUIVI60986
Value Char SZOIDENT1   # FGR 01/02/2010 : X3SUIVI60986
Value Char SZOIDENT2   # FGR 01/02/2010 : X3SUIVI60986
Value Char SZNIDENT1   # FGR 01/02/2010 : X3SUIVI60986
Value Char SZNIDENT2   # FGR 01/02/2010 : X3SUIVI60986

  # FGR 10/12/2008 : Changement de code et textes traduisibles
  # FGR 19/02/2013 : X3SUIVI71937 (début) : traiter systématiquement les deux clés à cause du multileg.
  #If SZOIDENT2 = "" Then
  #  Update [AXX] Where CODFIC = SZTABLE and IDENT1 = SZOIDENT1 With IDENT1 = SZNIDENT1
  #Else
  #  Update [AXX] Where CODFIC = SZTABLE and IDENT1 = SZOIDENT1 and IDENT2 = SZOIDENT2 With IDENT1 = SZNIDENT1, IDENT2 = SZNIDENT2
  #Endif
  Update [AXX] Where CODFIC = SZTABLE and IDENT1 = SZOIDENT1 and IDENT2 = SZOIDENT2 With IDENT1 = SZNIDENT1, IDENT2 = SZNIDENT2
  # FGR 19/02/2013 : X3SUIVI71937 (fin) : traiter systématiquement les deux clés à cause du multileg.
  If fstat = 1 Then
    GOK = -1
    #GLOCK = "$ATEXTRA" - SZTABLE - [L]OCODE
    GLOCK = "$ATEXTRA" - SZTABLE - "[" + SZOIDENT1 + "/" + SZOIDENT2 + "]"
  Elsif fstat Then
    GOK = 0
    #Call RSTA("AXX", SZTABLE - [L]OCODE) From GLOCK
    Call RSTA("AXX", SZTABLE - "[" + SZOIDENT1 + "/" + SZOIDENT2 + "]") From GLOCK
  Endif
End
#########################################################################################

#########################################################################################
#########################################################################################
# GET_ATEXTRA : S/P de récupération d'un texte traduit à partir de la table ATEXTRA     #
# ------------------------------------------------------------------------------------- #
# Paramètres E : TABLE  = Nom de la table contenant le texte                            #
#                ZONE   = Nom du champ contenant le texte                               #
#                LANGUE = Code langue                                                   #
#            S : TEXTE  = Contient le texte récupéré de ATEXTRA                         #
#                                                                                       #
# Prérequis    : La buffer de "TABLE" doit être ouvert et chargé !                      #
# ------------------------------------------------------------------------------------- #
# TABLES         ZONES possibles                                                        #
# ------------   ---------------                                                        #
# ATABDIV        LNGDES      SHODES                                                     #
# ATABTAB        LNGDES      SHODES      ALPDES1      ALPDES2     NUMDES1     NUMDES2   #
# CFGQST         SALTXT                                                                 #
# CRMTRS         DESAXX                                                                 #
# HDKTRS         DESAXX                                                                 #
# IMTMASTER      DES1AXX     DES2AXX     DES3AXX                                        #
# PFOOTINV       DESAXX      SHOAXX                                                     #
# PPRICCONF      DESAXX                                                                 #
# PPREASON       DESAXX                                                                 #
# PRICSTRUCT     DESAXX(0-8) SHOAXX(0-8)                                                #
# PURTRS         DESAXX                                                                 #
# SALTRS         DESAXX                                                                 #
# MFGTRS         DESAXX                                                                 #
# BENCHTRS       DESAXX                                                                 #
# SFOOTINV       DESAXX      SHOAXX                                                     #
# SPRICCONF      DESAXX                                                                 #
# SPREASON       DESAXX                                                                 #
# SPPRTCONF      DESAXX                                                                 #
# STKTRS         DESAXX                                                                 #
# TABCOEFF       COEAX2      COEAX1                                                     #
# TABCATBPS      DESAXX      SHOAXX                                                     #
# TABMODELIV     DESAXX      SHOAXX                                                     #
# TABDEPAGIO     DESAXX      SHOAXX                                                     #
# TABPACKAGE     DESAXX      SHOAXX                                                     #
# TABPAYTERM     DESAXX      SHOAXX                                                     #
# TABPIVTYP      DESAXX      SHOAXX                                                     #
# TABSIVTYP      DESAXX      SHOAXX                                                     #
# TABSOHTYP      DESAXX      SHOAXX                                                     #
# TABUNAVAIL     DESAXX      SHOAXX                                                     #
# TABUNIT        DES         DESSHO                                                     #
# TABCOUNTRY     CRYDES      ETANAM      ETANAM2                                        #
# TABVAT         DESAXX      SHOAXX                                                     #
# TABVATSEL      DESAXX      SHOAXX                                                     #
# BPCCATEG       DESAXX      SHOAXX                                                     #
# BPSCATEG       DESAXX      SHOAXX                                                     #
#                                                                                       #
#########################################################################################
Subprog GET_ATEXTRA(TABLE,ZONE,LANGUE,TEXTE)
Value    Char    TABLE
Value    Char    ZONE
Value    Char    LANGUE
Variable Char    TEXTE()
#----- Variables locales -----#
Local    Char    IDENT1(GLONID1)
Local    Char    IDENT2(GLONID2)
#-----
If !clalev([F:AXX])  Local File ATEXTRA [AXX] : Endif
#-----
If LANGUE=""  LANGUE=GLANDEF : Endif
Raz TEXTE, [L]IDENT1, [L]IDENT2
Case TABLE
  When "ATABDIV"     : [L]IDENT1=num$([F:ADI]NUMTAB) : [L]IDENT2=[F:ADI]CODE
  When "ATABTAB"     : [L]IDENT1=num$([F:ADV]NUMTAB) : [L]IDENT2=""
  When "BENCHTRS"    : [L]IDENT1=num$([F:BTS]BTSTYP) : [L]IDENT2=[F:BTS]BTSNUM
  When "CFGABQ"      : [L]IDENT1=[F:CAB]ABQNUM       : [L]IDENT2=""
  When "CFGLNK"      : [L]IDENT1=[F:CLN]CLE1         : [L]IDENT2=[F:CLN]CLE2
  When "CFGMAC"      : [L]IDENT1=[F:CFM]MACNUM       : [L]IDENT2=""
  When "CFGOPTVAR"   : [L]IDENT1=[F:COV]SELNUM       : [L]IDENT2=num$([F:COV]SELSEQ)
  When "CFGQST"      : [L]IDENT1=[F:CQU]QSTNUM       : [L]IDENT2=""
  When "CFGSCE"      : [L]IDENT1=[F:CSC]SCENUM       : [L]IDENT2=""
  When "CFGSEL"      : [L]IDENT1=[F:CSE]SELNUM       : [L]IDENT2=""
  When "CFGSHA"      : [L]IDENT1=[F:CSH]SHACAT       : [L]IDENT2=[F:CSH]SHANUM
  When "CRMTRS"      : [L]IDENT1=num$([F:CTR]CTRTYP) : [L]IDENT2=[F:CTR]CTRNUM
  When "HDKTRS"      : [L]IDENT1=num$([F:HTR]HTRTYP) : [L]IDENT2=[F:HTR]HTRNUM
  When "ITMMASTER"   : [L]IDENT1=[F:ITM]ITMREF       : [L]IDENT2=""
  When "ITMCATEG"    : [L]IDENT1=[F:ITG]TCLCOD       : [L]IDENT2=""
  When "MFGTRS"      : [L]IDENT1=num$([F:MTS]MTSTYP) : [L]IDENT2=[F:MTS]MTSNUM
  When "OVENAT"      : [L]IDENT1=[F:ONA]OVENAT       : [L]IDENT2=""
  When "OVERHEAD"    : [L]IDENT1=[F:OVE]OVECOD       : [L]IDENT2=""
  When "PFOOTINV"    : [L]IDENT1=num$([F:PFI]PFINUM) : [L]IDENT2=""
  When "PPRICCONF"   : [L]IDENT1=[F:PPC]PLI          : [L]IDENT2=""
  When "PPREASON"    : [L]IDENT1=num$([F:PPR]PRIREN) : [L]IDENT2=""
  When "PRICSTRUCT"  : [L]IDENT1=num$([F:PRS]BPCBPS) : [L]IDENT2=[F:PRS]PLISTC
  When "PURTRS"      : [L]IDENT1=num$([F:PTR]PTRTYP) : [L]IDENT2=[F:PTR]PTRNUM
  When "SALTRS"      : [L]IDENT1=num$([F:SLT]STRTYP) : [L]IDENT2=[F:SLT]STRNUM
  When "SFOOTINV"    : [L]IDENT1=num$([F:SFI]SFINUM) : [L]IDENT2=""
  When "SPRICCONF"   : [L]IDENT1=[F:SPC]PLI          : [L]IDENT2=""
  When "SPPRTCONF"   : [L]IDENT1=[F:SPP]COD          : [L]IDENT2=""
  When "SPREASON"    : [L]IDENT1=num$([F:SPR]PRIREN) : [L]IDENT2=""
  When "STKTRS"      : [L]IDENT1=num$([F:SRT]SRTTYP) : [L]IDENT2=[F:SRT]SRTNUM
  When "TABALLRUL"   : [L]IDENT1=[F:TRU]TRUCOD       : [L]IDENT2=""
  When "TABCOEFF"    : [L]IDENT1=[F:TCO]UOM1         : [L]IDENT2=[F:TCO]UOM2
  When "TABCOSTMET"  : [L]IDENT1=[F:TCM]VLTCOD       : [L]IDENT2=""
  When "TABDEPAGIO"  : [L]IDENT1=[F:TDA]DEP          : [L]IDENT2=[F:TDA]LEG  :#--CPO 71937 TABDEPAGIO
  When "TABLINCFG"   : [L]IDENT1=[F:TLP]CFGLIN       : [L]IDENT2=""
  When "TABMODELIV"  : [L]IDENT1=[F:TMD]MDL          : [L]IDENT2=""
  When "TABPACKAGE"  : [L]IDENT1=[F:TPA]PCK          : [L]IDENT2=""
  When "TABPIVTYP"   : [L]IDENT1=[F:TPV]PIVTYP       : [L]IDENT2=[F:TPV]LEG  :#--CPO 71937 18/12/2014 Ajout de [F:TPV]LEG
  When "TABPRECOD"   : [L]IDENT1=[F:TPC]PRECOD       : [L]IDENT2=[F:TPC]STOFCY
  When "TABREOPOL"   : [L]IDENT1=[F:TRP]REOPOL       : [L]IDENT2=""
  When "TABSAFSTO"   : [L]IDENT1=[F:TSA]SRVRAT       : [L]IDENT2=""
  When "TABSIVTYP"   : [L]IDENT1=[F:TSV]SIVTYP       : [L]IDENT2=[F:TSV]LEG  :#--CPO 71937 18/12/2014 Ajout de [F:TSV]LEG
  When "TABSOHTYP"   : [L]IDENT1=[F:TSO]SOHTYP       : [L]IDENT2=[F:TSO]LEG  :# FGR 19/11/2012 : X3SUIVI71937 Ajout de [F:TSO]LEG
  When "TABSDHTYP"   : [L]IDENT1=[F:TSD]SDHTYP       : [L]IDENT2=[F:TSD]LEG  :#--CPO 75115
  When "TABSTASTO"   : [L]IDENT1=[F:TST]STASTO       : [L]IDENT2=""
  When "TABUNAVAIL"  : [L]IDENT1=[F:TUV]UVYCOD       : [L]IDENT2=""
  When "TABUNIT"     : [L]IDENT1=[F:TUN]UOM          : [L]IDENT2=""
  When "TABCOUNTRY"  : [L]IDENT1=[F:TCY]CRY          : [L]IDENT2=""
  When "TABVAC"      : [L]IDENT1=[F:TVC]COD          : [L]IDENT2=[F:TVC]LEG  :#--JDE 71937
  When "TABVAT"      : [L]IDENT1=[F:TVT]VAT          : [L]IDENT2=[F:TVT]LEG  :#--CPO 71937 TVT
  When "TABVATSEL"   : [L]IDENT1=[F:TVS]COD          : [L]IDENT2="" #CHECK IGNORE_LINE
  When "BPCCATEG"    : [L]IDENT1=[F:BCG]BCGCOD       : [L]IDENT2=""
  When "BPSCATEG"    : [L]IDENT1=[F:BSG]BSGCOD       : [L]IDENT2=""
  When "TABPRTCOD"   : [L]IDENT1=[F:TPM]TPMCOD       : [L]IDENT2=""
  When "TABVACITM"   : [L]IDENT1=[F:TVI]VACITM       : [L]IDENT2=[F:TVI]LEG  :#--JDE 71937
  When "TABVACBPR"   : [L]IDENT1=[F:TVB]VACBPR       : [L]IDENT2=[F:TVB]LEG  :#--LD  71937
  When "TABPAYTERM"  : [L]IDENT1=[F:TPT]PTE          : [L]IDENT2=[F:TPT]LEG  :#--CPO 71937 20.02.2013 [L]IDENT2=num$([F:TPT]PTELIN)
  When "TABEECSCH"   : [L]IDENT1=[F:TSC]EECSCH       : [L]IDENT2=[F:TSC]LEG  :#--CPO 71937 20.02.2013
  When "TABEECNAT"   : [L]IDENT1=[F:TEC]EECNAT       : [L]IDENT2=[F:TEC]LEG  :#--CPO 71937 20.02.2013
  When "TABSQHTYP"   : [L]IDENT1=[F:TSQ]SQHTYP       : [L]IDENT2=[F:TSQ]LEG  :# FGR 19/02/2015 : X3SUIVI104383
  When "TABSOHTYP"   : [L]IDENT1=[F:TSO]SOHTYP       : [L]IDENT2=[F:TSO]LEG  :# FGR 20/02/2015 : X3SUIVI104383
  When "TABINVCND"   : [L]IDENT1=[F:INVCND]INVCND    : [L]IDENT2=[F:INVCND]LEG  :# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
Endcase
If [L]IDENT1="" & [L]IDENT2=""  End : Endif
Read [AXX] AXX0=TABLE;ZONE;LANGUE;IDENT1;IDENT2
If fstat
  Read [AXX] AXX0=TABLE;ZONE;GLANDEF;IDENT1;IDENT2
  If fstat
    Raz [F:AXX]
  Else
    TEXTE=[F:AXX]TEXTE
  Endif
Else
  TEXTE=[F:AXX]TEXTE
Endif
End

#**
#* FILL_EMPTY_DES - Fill empty records in atextra with the "To be defined" label.
#*                  Create missing records in ATEXTRA with the text "To be defined"
#*                  The text comes from the local menu 187, text n°174
#*
#* @param   PFOLDER
#* @param   PTABLE
#* @param   PFIELD
#* @param   PKEY1
#* @param   PKEY2
#*
#* @return  RCOD
#*            1 : PFOLDER doesn't exist
#*!
Subprog FILL_EMPTY_DES(PFOLDER, PTABLE, PFIELD, PKEY1, PKEY2, RCOD)
Value Char       PFOLDER
Value Char       PTABLE
Value Char       PFIELD
Value Char       PKEY1
Value Char       PKEY2
Variable Integer RCOD

Local Char SFOLDER, SGLANGNUE

# ADOSSIER record : save and read
If clalev([F:ADS])=0
 Local File =GDOSX3+".ADOSSIER" [ADS]
Else
 If [F:ADS]DOSSIER<>"" : SFOLDER=[F:ADS]DOSSIER : Endif
Endif
If [F:ADS]DOSSIER<>PFOLDER
 Read [F:ADS]DOSSIER=PFOLDER
 If fstat=5
  RCOD=1
  End
 Endif
Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Local Integer LOPENAXX : Endif

# looking for empty texts or missing records in ATEXTRA
SGLANGUE=GLANGUE
For ILAN=1 To dim([F:ADS]LAN)
 If [F:ADS]LAN(ILAN-1)="" : Break : Endif
 GLANGUE=[F:ADS]LAN(ILAN-1)
 Read [F:AXX]AXX0=PTABLE;PFIELD;[F:ADS]LAN(ILAN-1);PKEY1;PKEY2
 If fstat=5 | (!fstat & [F:AXX]TEXTE="")
  Call MAJTEXTRA(func APLSTD.TEXMEN([F:ADS]DOSSIER,187,174,[F:ADS]LAN(ILAN-1)),PTABLE,PFIELD,PKEY1,PKEY2) From ATEXTRA
 Endif
Next ILAN
GLANGUE=SGLANGUE

If [F:ADS]DOSSIER<>SFOLDER
 Read [F:ADS]DOSSIER=SFOLDER
Endif

End

#-------------------------------------------------------------------------------------------------------#
# IDEM COPTEXTRA DE ACOPIE sf que :
# Copie des textes du dossier origine sans supprimer les autres textes du dossier destination
# Dans le cas particulier où dossier destination monoleg et leg à copier différente
# Si les textes n'existent pas on les copie en changeant la clé
#-------------------------------------------------------------------------------------------------------#
Subprog COPTEXTRA1(TABLE,CHAMP,CLE1,CLE2,CLE2DES)
Value    Char    TABLE, CHAMP, CLE1, CLE2, CLE2DES
For [AXX1] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
 Read [F:AXX2]AXX0 = TABLE;CHAMP;[F:AXX1]LANGUE;CLE1;CLE2DES
 If !fstat
  [F:AXX2]TEXTE = [F:AXX1]TEXTE
  Call FLDUPD("AXX2") From OBJDIV
  Rewrite [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Else
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT2=CLE2DES
  Call FLDUPD("AXX2") From OBJDIV
  Write [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Endif
Next
End

