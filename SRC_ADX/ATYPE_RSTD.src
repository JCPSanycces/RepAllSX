#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation ATYPE

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "ATY.TYPTYP"                   : Gosub ATY_TYPTYP
  When "ATY.LNGTYP"                   : Gosub ATY_LNGTYP
  When "ATY.OPTTAB"                   : Gosub ATY_OPTTAB
  When "ATY.PARTAB"                   : Gosub ATY_PARTAB
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


$AREAD_AFTER
#Local menu data type
If this.ATY.TYPTYP = 1
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("NOLIB","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("NOLIB","$isDisabled","true")
Endif

# Enable Adonix format field
If this.ATY.LNGTYP > 0
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("FORTYP","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("FORTYP","$isDisabled","true")
Endif

# Enable variable
If this.ATY.OPTTAB<>[V]CST_AYES
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("PARTAB","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("PARTAB","$isDisabled","true")
Endif

# Enable variable
If this.ATY.PARTAB=""
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("VARTAB","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ATY.ASETATTRIBUTE("VARTAB","$isDisabled","true")
Endif

Return



$ATY_TYPTYP
Case [L]ARULE
  When "PROPAGATE"                : Gosub ATY_TYPTYP_PROPAGATE
Endcase
Return


$ATY_LNGTYP
Case [L]ARULE
  When "PROPAGATE"                : Gosub ATY_LNGTYP_PROPAGATE
Endcase
Return

$ATY_OPTTAB
Case [L]ARULE
  When "PROPAGATE"                : Gosub ATY_OPTTAB_PROPAGATE
Endcase
Return

$ATY_PARTAB
Case [L]ARULE
  When "PROPAGATE"                : Gosub ATY_PARTAB_PROPAGATE
Endcase
Return

$ATY_TYPTYP_PROPAGATE
# Enable local menu field
If this.TYPTYP = 1
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NOLIB","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NOLIB","$isDisabled","true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NOLIB","$isMandatory","false")
Endif
Return

$ATY_LNGTYP_PROPAGATE
# Enable Adonix format field
If this.LNGTYP > 0
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FORTYP","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FORTYP","$isDisabled","true")
Endif
Return

$ATY_OPTTAB_PROPAGATE
# Enable parameter
If this.OPTTAB<>[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("PARTAB","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("PARTAB","$isDisabled","true")
Endif
Return

$ATY_PARTAB_PROPAGATE
# Enable variable
If this.PARTAB=""
  [L]ASTATUS = fmet this.ASETATTRIBUTE("VARTAB","$isDisabled","false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("VARTAB","$isDisabled","true")
Endif
Return


