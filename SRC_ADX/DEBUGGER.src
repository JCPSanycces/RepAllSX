######################################################################
# Calcul de l'expression de chacune des variable en tenant compte de
# l'utilisation des variables sauvegardées...
######################################################################
Subprog CALC_EXPVARS(DBGS_VARS,DBGS_NBVAR,DBGS_TABZONSVG,DBGS_EXPVARS)
  Value Char DBGS_VARS()()
  Value Integer DBGS_NBVAR
  Value Char DBGS_TABZONSVG()()
  Variable Char DBGS_EXPVARS()()
  Local Integer WI
  [L]WI=0
  # On rafraichit les variables...
  While [L]WI < [L]DBGS_NBVAR
      #If [LDB]DBG_TRACON=1
      #  [LDB]DBG_TRACE = ".CALC_EXPVARS"
      #  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"idx",num$([L]WI) )
      #  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"exp",[L]DBGS_VARS([L]WI) )
      #  Call TRACE([LDB]DBG_TRACE)
      #Endif
      Call CALC_EXPVAR([L]DBGS_VARS([L]WI),[L]DBGS_TABZONSVG,[L]DBGS_EXPVARS([L]WI) )
      #If [LDB]DBG_TRACON=1
      #  [LDB]DBG_TRACE = ".CALC_EXPVARS"
      #  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"idx",num$([L]WI) )
      #  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"new",[L]DBGS_EXPVARS([L]WI) )
      #  Call TRACE([LDB]DBG_TRACE)
      #Endif
      [L]WI+=1
  Wend
End
######################################################################
# Calcul d'une expression en tenant compte de l'utilisation
# des variable système sauvegardé...
######################################################################
Subprog CALC_EXPVAR(DBGS_VAR,DBGS_TABZONSVG,DBGS_EXP)
  Value Char DBGS_VAR()
  Value Char DBGS_TABZONSVG()()
  Variable Char DBGS_EXP()
  Local Char WZONSVG(7)
  Local Char WZONLOC(20)
  Local Integer WI
  Local Integer WJ
  Local Integer WK
  Local Integer WFOUND
  [L]WI=0
  [L]WK=1
  # boucle sur les noms des variables système sauvegardées
  While [L]WI < [LDB]DBG_NBZONSVG
    [L]WZONSVG = [L]DBGS_TABZONSVG([L]WI)
    [L]WJ = instr([L]WK,[L]DBGS_VAR,[L]WZONSVG)
    If [L]WJ
      [L]WFOUND= 1
      If [L]WFOUND & [L]WJ >1
        Call ISNOTCHARIDENT ( seg$([L]DBGS_VAR,[L]WJ-1,[L]WJ-1) , [L]WFOUND )
      Endif
      If [L]WFOUND & [L]WJ + len([L]WZONSVG) < len([L]DBGS_VAR)
        Call ISNOTCHARIDENT ( seg$([L]DBGS_VAR,[L]WJ+len([L]WZONSVG),[L]WJ+len([L]WZONSVG) ) , [L]WFOUND )
      Endif
      If [L]WFOUND
        [L]WZONLOC = "[LDB]DBG_"+toupper([L]WZONSVG)
        #If [LDB]DBG_TRACON=1
        #  [LDB]DBG_TRACE = ".CALC_EXPVAR"
        #  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"found",[L]WZONSVG )
        #  Call TRACE_ADDPARAM([LDB]DBG_TRACE,"replace",[L]WZONLOC )
        #  Call TRACE([LDB]DBG_TRACE)
        #Endif
        Call REPLACEINSTR([L]DBGS_VAR,[L]WJ-1,[L]WJ+len([L]WZONSVG),[L]WZONLOC  )
        [L]WK = [L]WJ + len([L]WZONLOC) :# pour chercher après le remplacement
      Else
        [L]WK = [L]WJ + len([L]WZONSVG)
        # pour chercher après la sequence de car correspondant au nom de la variable svg
      Endif
    Else
      [L]WI +=1
      [L]WK = 1 :# pour recommencer à chercher à partir du début
    Endif
  Wend
  [L]DBGS_EXP = [L]DBGS_VAR
End
######################################################################
# retourne faux (0) si le caractère peut faire partie d'un identifiant de variable
######################################################################
Subprog ISNOTCHARIDENT ( DBGS_CHAR,DBGS_MATCH)
  Value Char DBGS_CHAR()
  Variable Integer DBGS_MATCH
  [L]DBGS_MATCH = 1
  If [L]DBGS_MATCH & pat(left$(DBGS_CHAR,1) , "#")
    [L]DBGS_MATCH = 0
  Endif
  If [L]DBGS_MATCH & pat(left$(DBGS_CHAR,1) , "!")
    [L]DBGS_MATCH = 0
  Endif
  If [L]DBGS_MATCH & left$(DBGS_CHAR,1) = "_"
    [L]DBGS_MATCH = 0
  Endif

  If [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".TESTCHAR"
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"char",left$([L]DBGS_CHAR,1) )
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"ascii",num$( ascii(left$(DBGS_CHAR,1))) )
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"match",num$([L]DBGS_MATCH) )
    Call TRACE([LDB]DBG_TRACE)
  Endif
End
######################################################################
# REPLACE_IN_STRING
# remplace une portion d'une chaine par une autre
######################################################################
Subprog REPLACEINSTR(IACTX_STR,IACTX_START,IACTX_END,IACTX_VALUE)
  Variable Char    IACTX_STR()
  Value    Integer IACTX_START
  Value    Integer IACTX_END
  Value    Char    IACTX_VALUE()

  Local Char WSTR(250)
  WSTR =  left$([L]IACTX_STR,[L]IACTX_START)
  WSTR += [L]IACTX_VALUE
  WSTR += right$([L]IACTX_STR,[L]IACTX_END)
  [L]IACTX_STR = WSTR
End
######################################################################
# Envoi de la déclaration de toutes les variables (n commande 31) ...
# cf. utilisé suite à un load contexte.
######################################################################
Subprog SEND_ADDVARS(DBGS_VARS,DBGS_NBVAR)
  Value Char DBGS_VARS()()
  Value Integer DBGS_NBVAR
  Local Integer WI
  [L]WI=0
  # On déclare les variables...
  While [L]WI < [L]DBGS_NBVAR
    #envoi de la commande "VAR_ADD = 31"
    Call SEND_MESS1("34",[L]DBGS_VARS([L]WI) )
    [L]WI+=1
  Wend
End
######################################################################
# Envoi de la déclaration de touts les break points (n commande 21) ...
# cf. utilisé suite à un load contexte.
######################################################################
Subprog SEND_ADDBKPS(DBGS_BKPS,DBGS_NBBKP)
  Value Char DBGS_BKPS()()
  Value Integer DBGS_NBBKP
  Local Char WBUFF1(250)
  Local Integer WNUMLINE
  Local Integer WI
  [L]WI=0
  # On déclare les variables...
  While [L]WI < [L]DBGS_NBBKP
    #envoi de la commande "BKP_ADD = 21"
    [L]WBUFF1 =[L]DBGS_BKPS([L]WI)
    If left$([L]WBUFF1 ,1)=chr$(1)
      [L]WNUMLINE = -1
      [L]WBUFF1 = right$([L]WBUFF1,2)
    Elsif left$([L]WBUFF1 ,1)=chr$(2)
      [L]WNUMLINE = -2
      [L]WBUFF1 = right$([L]WBUFF1,2)
    Elsif left$([L]WBUFF1 ,1)=chr$(3)
      [L]WNUMLINE = -3
      [L]WBUFF1 = right$([L]WBUFF1,2)
    Else
      Local Integer WJ
      [L]WJ= instr(1,[L]WBUFF1,":")
      If [L]WJ
       [L]WNUMLINE = val(right$([L]WBUFF1,[L]WJ+1))
       [L]WBUFF1 = left$([L]WBUFF1,[L]WJ-1)
      Else
      Endif
    Endif

    Call SEND_MESS2("23",[L]WBUFF1,[L]WNUMLINE )

    [L]WI+=1
  Wend
End
######################################################################
# Envoi de la déclaration de tous les sources (n commande 11) ...
# cf. utilisé suite à un load contexte.
######################################################################
Subprog SEND_ADDSRCS(DBGS_SRCS,DBGS_NBSRC)
  Value Char DBGS_SRCS()()
  Value Integer DBGS_NBSRC
  Local Char WAPPLI(10)
  Local Char WSRCNAME(10)
  Local Char WSRCFIC(250)
  Local Integer WI
  Local Integer WJ
  Local Integer WK
  Local Integer WSRCSIZE
  [L]WI=0
  # On déclare les variables...
  While [L]WI < [L]DBGS_NBSRC
    [L]WSRCFIC = [L]DBGS_SRCS([L]WI)
    [L]WJ = instr( 1, [L]WSRCFIC , ".TRT/" )
    If  [L]WJ =0 : [L]WJ = instr( 1, [L]WSRCFIC , ".TRT\" ) : Endif
    [L]WAPPLI = seg$([L]WSRCFIC,2,[L]WJ-1) :# après le '@' et avant ".TRT/" ou ".TRT\"
    [L]WK = instr( 1, [L]WSRCFIC, '$' )
    [L]WSRCNAME= seg$([L]WSRCFIC ,[L]WJ+5,[L]WK-1):# après le  ".TRT/" ou ".TRT\" et avant le '$'
    [L]WSRCFIC = filpath("TRT",[L]WSRCNAME,"src")
    [L]WSRCSIZE  = filinfo([L]WSRCFIC,7)
    If [LDB]DBG_TRACON=1
      [LDB]DBG_TRACE = ".SEND_ADDSRCS"
      Call TRACE_ADDPARAM([LDB]DBG_TRACE,"prg",[L]DBGS_SRCS([L]WI) )
      Call TRACE_ADDPARAM([LDB]DBG_TRACE,"file",[L]WSRCFIC )
      Call TRACE_ADDPARAM([LDB]DBG_TRACE,"size",num$([L]WSRCSIZE ))
      Call TRACE([LDB]DBG_TRACE)
    Endif
    #envoi de la commande "SRC_ADD = 11"
    Call SEND_SOURCE([L]DBGS_SRCS([L]WI),[L]WSRCFIC ,[L]WSRCSIZE )
    [L]WI+=1
  Wend
End
######################################################################
# Envoi d'un source (commande 11)
######################################################################
Subprog SEND_SOURCE1(DBGS_FICHIER,DBGS_SRCFIC,DBGS_SRCFIC_SIZE,DBG_DSC)
  Value Char DBGS_FICHIER()
  Value Char DBGS_SRCFIC(),DBG_DSC()
  Value Integer DBGS_SRCFIC_SIZE
Goto SEND_SOURCE_S

Subprog SEND_SOURCE(DBGS_FICHIER,DBGS_SRCFIC,DBGS_SRCFIC_SIZE)

  Value Char DBGS_FICHIER()
  Value Char DBGS_SRCFIC()
  Value Integer DBGS_SRCFIC_SIZE

$SEND_SOURCE_S:
  Local Char WCHAINE (250)
  Local Char WABS(100)
  Local Integer WNUM,SIZE,WFSTAT,SABS
  #Local Clbfile WCLOB(9)

  # calcul flag dispo du source
  [L]SABS=instr(1,[L]DBGS_SRCFIC,"DEBUGABS")

  # si "source absent" ?
  If [L]SABS<>0
    [L]WABS="Source code not available"+chr$(10)
    [L]DBGS_SRCFIC_SIZE=len(WABS)
    [L]SIZE=len(WABS)+len([L]DBG_DSC)+5

  # sinon, si "source présent"
  Else
    [L]WABS=""
    [L]SIZE=DBGS_SRCFIC_SIZE
  Endif

  # Envoi de la commande Add source
  [L]WCHAINE = [L]DBGS_FICHIER+ [LDB]DBG_SEPAR + num$([L]DBGS_SRCFIC_SIZE) + [LDB]DBG_SEPAR
  [L]WNUM = len([L]WCHAINE ) + [L]SIZE
  [L]WCHAINE   = chr$(7)+"A"+format$("N0:6#",[L]WNUM )+ "110"+ [L]WCHAINE

  Local Char    WBUFFER(len([L]WCHAINE))     : # Pour envoyer une chaine taillée sur mesure dans la socket !
  [L]WBUFFER = [L]WCHAINE
  Wrseq [L]WBUFFER Using [OPS]

  # si "source présent" => ouverture source pour chargement
  If [L]SABS=0
    Openi [L]DBGS_SRCFIC Using [SRC]
    Iomode adxium GUTF8 Using [SRC]
#    Iomode adxirs "" Using  [SRC]
    Iomode adxirs chr$(10) Using  [SRC]
    Iomode adxifs "" Using  [SRC]

    [L]WNUM = 0

    Local Schar WLINE(250)
    Local Integer WLENOFLINE

    Repeat
      Rdseq [L]WLINE Using [SRC]
      [L]WFSTAT  = fstat : # fstat = 1 si la fin de fichier est atteinte !
      [L]WLENOFLINE= len([L]WLINE)
#      If ([L]WLENOFLINE>0)
        Local Char    WBUFFER([L]WLENOFLINE+1) : # Pour envoyer une chaine taillée sur mesure dans la socket !
        [L]WBUFFER = [L]WLINE+chr$(10)
        Wrseq [L]WBUFFER Using [OPS]
        [L]WNUM += [L]WLENOFLINE+1 :# cumul des caractères envoyés
#      Endif
    Until [L]WFSTAT <> 0 : # si la fin de fichier est atteinte !

# protection: si on a envoyé moins de caractère que la longueur du fichier envoyée dans l'entête (1ere passe)
    If [L]WNUM< [L]DBGS_SRCFIC_SIZE
      Local Integer WTOSEND
      [L]WTOSEND = [L]DBGS_SRCFIC_SIZE- [L]WNUM :# calcul de la longueur manquante  à envoyer
      If ([L]WTOSEND >250)
        Local Char    WBUFFER(250)          :# Pour envoyer une chaine de 250 caractères dans la socket !
        [L]WBUFFER = space$(250)            :# valorisation avec 250 espaces
        Local Integer WSENT
        [L]WSENT = 0
        Repeat
          Wrseq [L]WBUFFER  Using [OPS]
          WSENT +=250
        Until WSENT > [L]WTOSEND - 250
        [L]WNUM += WSENT
      Endif
    Endif
# protection: si on a envoyé moins de caractère que la longueur du fichier envoyée dans l'entête (2eme passe)
    If [L]WNUM< [L]DBGS_SRCFIC_SIZE
      [L]WNUM = [L]DBGS_SRCFIC_SIZE- [L]WNUM :# calcul de la longueur manquante à envoyer
      Local Char    WBUFFER([L]WNUM)          :# Pour envoyer une chaine taillée sur mesure dans la socket !
      [L]WBUFFER = space$([L]WNUM)            :# valorisation avec n espace(s)
      Wrseq [L]WBUFFER  Using [OPS]
     Endif
    Seek 0 Using [OPS] : # C'est le flush final...


    Openi Using [SRC] :# fermeture du fichier

  Else     : # on n'a pas le source
     Local Char    WBUFFER(len([L]WABS))     : # Pour envoyer une chaine taillée sur mesure dans la socket !
     [L]WBUFFER = WABS
     Wrseq [L]WBUFFER  Using [OPS]
     [L]WNUM += len([L]WBUFFER) :# cumul des caractères envoyés
     Local Char    WBUFFER(len([L]DBG_DSC)+5)
     [L]WBUFFER = format$("NO:####",[LDB]DGNOLIGN)+":"+[L]DBG_DSC
     Wrseq [L]WBUFFER  Using [OPS]
     [L]WNUM += len([L]WBUFFER) :# cumul des caractères envoyés
  Endif

  Seek 0 Using [OPS] : # C'est le flush final...

  If [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "=>"
    Call TRACE_ADDCMDELIB([LDB]DBG_TRACE,"11")
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"id",[L]DBGS_SRCFIC)
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"num",num$([L]DBGS_SRCFIC_SIZE))
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"data","src...")
    Call TRACE ([LDB]DBG_TRACE)
  Endif
End
######################################################################
# Envoi d'un message de commande au debugger Java sans paramètre
######################################################################
Subprog SEND_MESS0(DBGM_CMDE)
  Value    Char    DBGM_CMDE()
  Call SEND_MESS4(DBGM_CMDE,"",0,"","")
End
######################################################################
# Envoi d'un message de commande au debugger Java avec un paramètre
######################################################################
Subprog SEND_MESS1(DBGM_CMDE,DBGM_ID)
  Value    Char    DBGM_CMDE()
  Value    Char    DBGM_ID()
  Call SEND_MESS4(DBGM_CMDE,[L]DBGM_ID,0,"","")
End
######################################################################
# Envoi d'un message de commande au debugger Java avec deux paramètres
######################################################################
Subprog SEND_MESS2(DBGM_CMDE,DBGM_ID,DBGM_NUM)
  Value    Char    DBGM_CMDE()
  Value    Char    DBGM_ID()
  Value    Integer DBGM_NUM
  Call SEND_MESS4(DBGM_CMDE,[L]DBGM_ID,[L]DBGM_NUM,"","")
End
######################################################################
# Envoi d'un message de commande au debugger Java avec trois paramètres
######################################################################
Subprog SEND_MESS3(DBGM_CMDE,DBGM_ID,DBGM_NUM,DBGM_DATA)
  Value    Char    DBGM_CMDE()
  Value    Char    DBGM_ID()
  Value    Integer DBGM_NUM
  Value    Char    DBGM_DATA()
  Call SEND_MESS4(DBGM_CMDE,[L]DBGM_ID,[L]DBGM_NUM,DBGM_DATA,"")
End
######################################################################
# Envoi d'un message de commande au debugger socket avec quatres paramètres
# exemple:
# (1)[(#BEL)](10)[A000017020](17)[Adonix.exe¤¨¤0¤¨¤]
#
######################################################################
Subprog SEND_MESS4(DBGM_CMDE,DBGM_ID,DBGM_NUM,DBGM_DATA1,DBGM_DATA2)
  Value    Char    DBGM_CMDE()
  Value    Char    DBGM_ID()
  Value    Integer DBGM_NUM
  Value    Char    DBGM_DATA1()
  Value    Char    DBGM_DATA2()

  Local Integer WLONG
  Local Char WMESS(250)
  Local Char WNUM(20)

  [L]DBGM_CMDE = left$([L]DBGM_CMDE,2) :# protection !
  [L]WNUM = num$([L]DBGM_NUM)
  # longueur utile
  [L]WLONG = len([L]DBGM_ID) + len([LDB]DBG_SEPAR) + len([L]WNUM)+ len([LDB]DBG_SEPAR)
  [L]WLONG += len([L]DBGM_DATA1) + len([L]DBGM_DATA2)

  # envoi de l'entête ID , NUM et des deux séparateurs ( < 250 caractères !)
  [L]WMESS  = chr$(7) + "A" + format$("N0:6#",[L]WLONG ) + [L]DBGM_CMDE  + "0"
  [L]WMESS  += [L]DBGM_ID +[LDB]DBG_SEPAR + [L]WNUM + [LDB]DBG_SEPAR
  Call SEND_BUFFER([L]WMESS)

  # envoi des valeurs
  If len([L]DBGM_DATA1)>0 : Call SEND_BUFFER([L]DBGM_DATA1) : Endif
  If len([L]DBGM_DATA2)>0 : Call SEND_BUFFER([L]DBGM_DATA2) : Endif

  If [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = "=>"
    Call TRACE_ADDCMDELIB([LDB]DBG_TRACE,DBGM_CMDE)
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"id",DBGM_ID)
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"num",[L]WNUM)
    Call TRACE_ADDPARAM([LDB]DBG_TRACE,"data",DBGM_DATA1)
    Call TRACE ([LDB]DBG_TRACE)
  Endif

End
######################################################################
#
######################################################################
Subprog SEND_BUFFER(DBGM_DATA)
  Value    Char    DBGM_DATA()
  Wrseq [L]DBGM_DATA  Using [OPS]
  Seek 0 Using [OPS]
End
######################################################################
#
######################################################################
$ERREUR_VAR_VALUE
  Call SEND_MESS3("33",[LDB]DBG_TRAEXP([L]DBG_I),0,"Can't evaluate. ("-errmes$(errn)-")" )
Resume
######################################################################
#
######################################################################
$ERR_AFFECT_NOTOK
  [L]DBG_J = 0 :#indicateur comme quoi l'affectation s'est mal passé
Resume

######################################################################
#Extraction des paramètres Host,Port,trt,sub et line de la copie de l'adxctx
#ADAPI:NA1:debug.on=on;debug.trt=;debug.sub=;debug.line=tata;
#debug.host=;debug.port=1789;trace.on=off;trace.filepath=%24HOME%2Ftmp;trace.dbglong=200;
######################################################################
Subprog READ_ADXCTX
  Local Integer WI
  Local Integer WJ

  #trace entrée spgm
  If [LDB]DBG_TRACON=1 : Call TRACE(".READ_ADXCTX Start") : Endif

  Raz [LDB]DBG_ON
  Raz [LDB]DBG_HOST
  Raz [LDB]DBG_PORT
  Raz [LDB]DBG_SESTYP
  Raz [LDB]DBG_SESWEI

  WI = instr(1,[LDB]DBG_ADXCTX,"debug.on=on")
  If WI
   [LDB]DBG_ON = 1
  Endif

  WI = instr(1,[LDB]DBG_ADXCTX,"debug.host=")
  If WI
   WJ = instr(WI,[LDB]DBG_ADXCTX,";")
   If WJ
    [LDB]DBG_HOST = seg$([LDB]DBG_ADXCTX,WI+11,WJ-1)
   Endif
  Endif

  WI = instr(1,[LDB]DBG_ADXCTX,"debug.port=")
  If WI
   WJ = instr(WI,[LDB]DBG_ADXCTX,";")
   If WJ
    [LDB]DBG_PORT = seg$([LDB]DBG_ADXCTX,WI+11,WJ-1)
   Endif
  Endif

  If [LDB]DBG_HOST=""
    WI = instr(1,[LDB]DBG_ADXCTX,"address=")
    If WI
      WJ = instr(WI,[LDB]DBG_ADXCTX,";")
      If WJ
       [LDB]DBG_HOST = seg$([LDB]DBG_ADXCTX,WI+8,WJ-1)
       [LDB]DBG_PORT = "1789"
      Endif
    Endif
  Endif

  If [LDB]DBG_HOST<>"" and [LDB]DBG_PORT<>"" : [LDB]DBG_ON = 1 : Endif


  [LDB]DBG_SESTYP = left$([LDB]DBG_ADXCTX,5)
  [LDB]DBG_SESWEI = mid$([LDB]DBG_ADXCTX,7,3)


  #trace sortie spgm
  If [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".READ_ADXCTX parametres:"
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Debugger_On",num$([LDB]DBG_ON))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Host",[LDB]DBG_HOST)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Port",[LDB]DBG_PORT)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Type",[LDB]DBG_SESTYP )
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"Poids",[LDB]DBG_SESWEI )
    Call TRACE ([LDB]DBG_TRACE)
    Call TRACE (".READ_ADXCTX - end")
  Endif

End

######################################################################
#
######################################################################
$ERREUR_DBG
  If [LDB]DBG_TRACON=1
   [LDB]DBG_TRACE = ".ERREUR_DBG "-errmes$(errn)-errp+"("+num$(errl)+")"
    Call TRACE([LDB]DBG_TRACE)
  Endif
  dbgmode(1)=0 :# arrêt du mode debug
  End
Resume


######################################################################
# Ajoute Cmde=[XXX_Y] dans la ligne de trace en fonction du numéro de commande
######################################################################
Subprog TRACE_ADDCMDELIB(DBGT_LINE,DBGT_CMDEID)
  Variable Char    DBGT_LINE()
  Value    Char    DBGT_CMDEID()
  Case toupper([L]DBGT_CMDEID)
    When "01" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","OPEN_1")
    When "02" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","CLOSE_2")
    When "03" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","CLEAN_3")
    When "04" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","MESSAGE_4")
    When "05" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SAVE_5")
    When "06" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","LOAD_6")
    When "07" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","CANTCLOSE_7")

    When "99" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","USER_99")

    When "11" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_ADD_11")
    When "12" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_REMOVE_12")
    When "13" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_SETL_13")
    When "15" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_NEXTL_15")
    When "16" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_NEXTBKP_16")
    When "17" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_RUN_17")
    When "18" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_OPEN_18")

    When "41" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_STEP_IN_41")
    When "42" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_STEP_OVER_42")
    When "43" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_STEP_OUT_43")
    When "44" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_NEXTBKP_44")
    When "45" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_RUN_45")
    When "46" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","SOURCE_RUN_DBGOFF_46")

    When "21" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","BKP_ADD_21")
    When "22" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","BKP_REMOVE_22")
    When "23" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","BKP_CLIENT_ADD_23")
              : # Ajout d'un point d'arrêt par le client
    When "24" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","BKP_CLIENT_REMOVE_24")
              : # Suppression d'un point d'arrêt par le client

    When "31" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","VAR_ADD_31")
    When "32" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","VAR_REMOVE_32")
    When "33" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","VAR_VALUE_33")
    When "34" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","VAR_CLIENT_ADD_34")
              : # Ajout d'une variable par le client
    When "35" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","VAR_CLIENT_REMOVE_35")
              : # Suppression d'une variable par le client
    When "36" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","VAR_AFFECT_36")

    When "51" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","STATE_ASK_51")
    When "52" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","STATE_VAL_52")
    When "53" : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","STATE_SHOW_53")



    When Default : Call TRACE_ADDPARAM([L]DBGT_LINE,"Cmde","Unknown_"+DBGT_CMDEID)
  Endcase
End

######################################################################
# Ajoute " lib=[value]" à la fin d'une line
######################################################################
Subprog TRACE_ADDPARAM( DBGT_LINE,DBGT_LIB, DBGT_VALUE )
  Variable    Char    DBGT_LINE()
  Value    Char    DBGT_LIB()
  Value    Char    DBGT_VALUE()
  DBGT_LINE += " " + DBGT_LIB + "=[" + DBGT_VALUE +"]"
End

######################################################################
# Ajoute une ligne "lib=[value]" à la fin du fichier de trace TRA/X3DEBUG_"adxusr".tra
######################################################################
Subprog TRACE_ONEPARAM( DBGT_LIB, DBGT_VALUE )
  Value    Char    DBG_LIB()
  Value    Char    DBG_VALUE()
  Call TRACE (DBGT_LIB + "=[" + DBGT_VALUE +"]" )
End
######################################################################
# Ajoute une ligne à la fin du fichier de trace TRA/X3DEBUG_"adxusr".tra
######################################################################
Subprog TRACE(DBGT_LINE)
  Value    Char    DBGT_LINE()
  Openo filpath("TRA","X3DEBUG_"+ctrans(adxusr,".\/|*@","______"),"tra",0),-1 Using [TEST]
  Wrseq DBGT_LINE+chr$(13) Using [TEST]
  Openo Using [TEST]
End
######################################################################
# vide le fichier de trace  TRA/X3DEBUG_"adxusr".tra
######################################################################
Subprog TRACE_CLEAR
 Openo filpath("TRA","X3DEBUG_"+adxusr,"tra",0),0 Using [TEST]
 Openo Using [TEST]
End

######################################################################
# sauvegarde du contexte de debug dans un fichier
# ...DOSSIER/tmp/DBG_user_NAME.ctx
######################################################################
Subprog CONTEXT_SAVE (DBGC_NAME,DBGC_BKPS,DBGC_NBBKP,DBGC_VARS,DBGC_NBVAR,DBGC_SRCS,DBGC_NBSRC)
  Value Char DBGC_NAME()
  Value Char DBGC_BKPS()()
  Value Integer DBGC_NBBKP
  Value Char DBGC_VARS()()
  Value Integer DBGC_NBVAR
  Value Char DBGC_SRCS()()
  Value Integer DBGC_NBSRC
  Local Integer WI
  Local Char WLINE(250)


  If [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".CONTEXT_SAVE Parameters:"
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"FileName",[L]DBGC_NAME)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"NbBkps",num$([L]DBGC_NBBKP))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"NbVars",num$([L]DBGC_NBVAR))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"NbSrcs",num$([L]DBGC_NBSRC))
    Call TRACE ([LDB]DBG_TRACE)
  Endif

  Local Char    WSAVIRS(10), WSAVIFS(10)
  Local Integer WSAVIUM
  [L]WSAVIRS=adxirs  : [L]WSAVIFS=adxifs : [L]WSAVIUM=adxium
  adxifs=","         :  adxirs=chr$(10)

  Openo [L]DBGC_NAME,0 Using [DBGX]
  Wrseq "NBBKP";[L]DBGC_NBBKP Using [DBGX]
  [L]WI=0
  While [L]WI < [L]DBGC_NBBKP
    Wrseq  [L]DBGC_BKPS([L]WI) Using [DBGX]
    [L]WI += 1
  Wend
  Wrseq "NBVAR";[L]DBGC_NBVAR Using [DBGX]
  [L]WI=0
  While [L]WI < [L]DBGC_NBVAR
    Wrseq [L]DBGC_VARS([L]WI) Using [DBGX]
    [L]WI += 1
  Wend
  Wrseq "NBSRC";[L]DBGC_NBSRC Using [DBGX]
  [L]WI=0
  While [L]WI < [L]DBGC_NBSRC
    Wrseq [L]DBGC_SRCS([L]WI) Using [DBGX]
    [L]WI += 1
  Wend
  Openo  Using [DBGX]
  adxifs=[L]WSAVIFS  :  adxirs=[L]WSAVIRS : adxium=[L]WSAVIUM
End
######################################################################
# lecture du contexte de debug dans un fichier
# ...DOSSIER/tmp/DBG_user_NAME.ctx
# rechargement du contexte en passant
# le nom du contxte
# le tableaux des breakpoints, le nombre de breakpoint(s)
# le tableaux des variables, le nombre de variable(s)
# la pile des sources, le nombre de source(s)
######################################################################
Subprog CONTEXT_LOAD (DBGC_NAME,DBGC_BKPS,DBGC_NBBKP,DBGC_VARS,DBGC_NBVAR,DBGC_SRCS,DBGC_NBSRC)
  Value Char DBGC_NAME()
  Value Char DBGC_BKPS()()
  Value Integer DBGC_NBBKP
  Value Char DBGC_VARS()()
  Value Integer DBGC_NBVAR
  Value Char DBGC_SRCS()()
  Value Integer DBGC_NBSRC
  #Raz [L]DBGC_BKPS,[L]DBGC_NBBKP,[L]DBGC_VARS,[L]DBGC_NBVAR,[L]DBGC_SRCS,[L]DBGC_NBSRC
  #Raz directe des variables LDB a cause du bug !!
  Raz [LDB]DBG_TRABPT,[LDB]DBG_TRABNB,[LDB]DBG_TRAEXP,[LDB]DBG_TRAVNB,[LDB]PIL_DGNOMPRG,[LDB]NB_DGNOMPRG
  Local Integer WI
  Local Char WBUFF1(10)
  Local Char WBUFF2(250)

  Local Char    WSAVIRS(10), WSAVIFS(10)
  Local Integer WSAVIUM
  [L]WSAVIRS=adxirs  : [L]WSAVIFS=adxifs : [L]SAVIUM=adxium
  adxifs=","         :  adxirs=chr$(10)

  Openi [L]DBGC_NAME Using [DBGX]
  Rdseq [L]WBUFF1,[L]WBUFF2 Using [DBGX] :# lecture du nombre de break dans une ligne "NBBKP,2"
  [L]DBGC_NBBKP = val([L]WBUFF2)
  [LDB]DBG_TRABNB = [L]DBGC_NBBKP :# a cause du bug !!
  [L]WI=0
  While [L]WI < [L]DBGC_NBBKP
    #Rdseq [L]DBGC_BKPS([L]WI )  Using [DBGX]
    Rdseq [LDB]DBG_TRABPT([L]WI) Using [DBGX]:# a cause du bug !!
    [L]WI += 1
  Wend
  Rdseq [L]WBUFF1,[L]WBUFF2 Using [DBGX] :# lecture du nombre de variable dans une ligne "NBVAR,2"
  [L]DBGC_NBVAR = val([L]WBUFF2)
  [LDB]DBG_TRAVNB = [L]DBGC_NBVAR :# a cause du bug !!
  [L]WI=0
  While [L]WI < [L]DBGC_NBVAR
    #Rdseq [L]DBGC_VARS([L]WI )   Using [DBGX]
    Rdseq [LDB]DBG_TRAEXP([L]WI) Using [DBGX] :# a cause du bug !!
    [L]WI += 1
  Wend
  Rdseq [L]WBUFF1,[L]WBUFF2 Using [DBGX]:# lecture du nombre de source dans une ligne "NBSRC,2"
  [L]DBGC_NBSRC = val([L]WBUFF2)
  [LDB]NB_DGNOMPRG = [L]DBGC_NBSRC :# a cause du bug !!
  [L]WI=0
  While [L]WI < [L]DBGC_NBSRC
    #Rdseq [L]DBGC_SRCS([L]WI ) Using [DBGX]
    Rdseq  [LDB]PIL_DGNOMPRG([L]WI) Using [DBGX] :# a cause du bug !!
    [L]WI += 1
  Wend
  Openi  Using [DBGX]
  adxifs=[L]WSAVIFS  :  adxirs=[L]WSAVIRS : adxium=[L]WSAVIUM
  If [LDB]DBG_TRACON=1
    [LDB]DBG_TRACE = ".CONTEXT_LOAD Parameters:"
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"FileName",[L]DBGC_NAME)
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"NbBkps",num$([L]DBGC_NBBKP))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"NbVars",num$([L]DBGC_NBVAR))
    Call TRACE_ADDPARAM ([LDB]DBG_TRACE,"NbSrcs",num$([L]DBGC_NBSRC))
    Call TRACE ([LDB]DBG_TRACE)
  Endif
End
######################################################################
# lecture du contexte de debug dans un fichier
# ...DOSSIER/tmp/DBG_user_NAME.ctx
######################################################################
Subprog BUILD_CTXFILENAME (DBGC_NAME)
  Variable Char DBGC_NAME()

  [L]DBGC_NAME= filpath("tmp","DBG_"+adxusr+"_"+[L]DBGC_NAME,"ctx")
End
