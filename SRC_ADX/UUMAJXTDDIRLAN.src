#<AdxTL>@(#)4.0.0.0 $Revision$
#-------------------------------------------------------------------------------------------------------------#
# Champ DIRLAN
#-------------------------------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Maj DIRLAN") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Break
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##################################################
Subprog PATCH_X3(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTELTFLD","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Call MAJAYSDIRLAN(APPLI)
End

##################################################
Subprog PATCH(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTELTFLD","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Call MAJAYSDIRLAN(APPLI)
End

##################################################
Subprog MAJAYSDIRLAN(APPLI)
Value Char APPLI

Local File =APPLI+".AYTFCY"      [AYS]

If dim([F:AYS]DIRLAN)<0 : End : Endif

Trbegin [AYS]
Update [AYS] Where DIRLAN=0 With [F:AYS]DIRLAN=2
Commit
End

