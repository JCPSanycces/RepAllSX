#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################################################
$METHODS
Case [L]AMETHOD
  When "EXPENSESESS_VALID"  : Gosub EXPENSESESS_VALID
  When "DEL_ATT"            : Gosub DELETE_ATTACHMENT
Endcase
Return
###########################################################################################################################
$EXPENSESESS_VALID
#Manage Duplication on collections - mobile only
Return
###########################################################################################################################
$DELETE_ATTACHMENT

  Local Integer RET_STAT
  Local Char    RET_MSG(255)

  Call REMOVE_FILE("HREXS",this.REFNUM,this.EXSNUM,this.UID,RET_MSG,RET_STAT) From PRHPORATT_SOA
  ASTATUS = fmet this.ASETERROR("TCH_ATTACH",RET_MSG,RET_STAT)
  If RET_STAT = [V]CST_AINFO
    Raz this.TCH_ATTACH
  Endif

Return
###########################################################################################################################

