#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJC1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:01:10"
A_USER  = "DOC"
A_STAMP = "20181109230110"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask AJC1 [AJC1]
Gosub HORODAT
Local Inpbox "AJC1" From GFONCTION At A_STAMP With A_WINDPREV Mask [AJC1] As [SIM_]
Grizo [AJC1]5
Grizo [AJC1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [AJC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=83 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=83 : Y1(1)=4 : Y2(1)=28
Return

$ON_AJCCOD
Onevent AFTER_CHANGE Gosub AMM_AJCCOD From W1AJC1
Onevent BEFORE_INPUT Call AS_AJCCOD(zc) From W1AJC1
Onevent CONTROL Call C_AJCCOD(zc) From W1AJC1
Return

Subprog AS_AJCCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_AJCCOD(zc) From W1AJC1
Onkey 144 Titled GBOUTP Call P_AJCCOD(zc) From W1AJC1
Onkey 146 Titled GBOUTA Call SA_AJCCOD(zc) From W1AJC1
Gosub _AFF
End

Subprog C_AJCCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "AJCCOD" : GZNUM = 42109 : Endif
Gosub _AFF
End

$AMM_AJCCOD
Call AM_AJCCOD(zc)
If !mkstat & GOBJET
 zoncou = "AJCCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_AJCCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTOBJ
Call C_CLE("AJC") From GOBJET
If mkstat : GERR = 1 : GZONE = "AJCCOD" : GZNUM = 42109 : Endif
Gosub _AFF
End

Subprog S_AJCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "AJC"
PARMSK(2) = "$"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_AJCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "AJC"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_AJCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("AJC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_AJCDESZ
Onevent BEFORE_INPUT Call AS_AJCDESZ(zc) From W1AJC1
Onevent AFTER_AREA Call AP_AJCDESZ(zc) From W1AJC1
Return

Subprog AS_AJCDESZ(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
If !GWEBSERV
 ## Action ABRINI
 Call INIABR From SUBAAB
 If mkstat=2
  [M]AJCDESZ(INDIC) = VALEUR
  Affzo AJCDESZ(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

Subprog AP_AJCDESZ(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TXTCONT
 Call TXTCONT(VALEUR,[M]AJCDESZ,[M]AJCDES,30,1,[M]AJCCOD,"AJCDES") From OBJDIV
 If mkstat : GERR = 1 : GZONE = "AJCDESZ" : GZNUM = 8 : Endif
Endif
Gosub _AFF
End

$ON_ENAFLG
Onevent INIT_AREA Call D_ENAFLG(zc) From W1AJC1
Onevent BEFORE_INPUT Call AS_ENAFLG(zc) From W1AJC1
Return

Subprog D_ENAFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]ENAFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CODACT
Onevent CONTROL Call C_CODACT(zc) From W1AJC1
Onevent AFTER_CHANGE Gosub AMM_CODACT From W1AJC1
Onevent BEFORE_INPUT Call AS_CODACT(zc) From W1AJC1
Return

Subprog AS_CODACT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(186,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODACT(zc) From W1AJC1
Onkey   2 Titled GBOUTS Call S_CODACT(zc) From W1AJC1
Onkey 144 Titled GBOUTP Call P_CODACT(zc) From W1AJC1
Onkey 146 Titled GBOUTA Call SA_CODACT(zc) From W1AJC1
Gosub _AFF
End

Subprog C_CODACT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ACV","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
If !mkstat
 ## Action STD
 Call C_CODACT(VALEUR) From SUBAJC
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
Endif
Gosub _AFF
End

$AMM_CODACT
Call AM_CODACT(zc)
If !mkstat & GOBJET
 zoncou = "CODACT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODACT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CODACT(VALEUR) From SUBAJC
If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCODACT)")>indice
 [M]CODACT(indice) = VALEUR
 Affzo ZCODACT(indice)
Endif
Gosub _AFF
End

Subprog S_CODACT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ACV"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CODACT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ACV",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CODACT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ACV"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODACT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ACV",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODACT
Onevent BEFORE_AREA Gosub AV_ZCODACT From W1AJC1
Return

$AV_ZCODACT
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
Call LECTURE("ACV",[M]CODACT(indice),"") From CONTOBJ
Call TEXTE([F:ACV]LIBACT,zc) From OBJDIV
Gosub _AFF
Return

$ON_MODULE
Onevent INIT_AREA Call D_MODULE(zc) From W1AJC1
Onevent BEFORE_INPUT Call AS_MODULE(zc) From W1AJC1
Onevent CONTROL Call C_MODULE(zc) From W1AJC1
Return

Subprog D_MODULE(VALEUR)
Variable Integer VALEUR
If varinit([M]MODULE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_MODULE(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "MODULE" : GZNUM = 943 : Endif
Gosub _AFF
End

$ON_AJCDEVMOD
Onevent INIT_AREA Call D_AJCDEVMOD(zc) From W1AJC1
Onevent BEFORE_INPUT Call AS_AJCDEVMOD(zc) From W1AJC1
Return

Subprog D_AJCDEVMOD(VALEUR)
Variable Integer VALEUR
If varinit([M]AJCDEVMOD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_AJCDEVMOD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_AJCHTPVER
Onevent INIT_AREA Call D_AJCHTPVER(zc) From W1AJC1
Return

Subprog D_AJCHTPVER(VALEUR)
Variable Decimal VALEUR
If varinit([M]AJCHTPVER,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_AJCXSD
Onevent AFTER_CHANGE Gosub AMM_AJCXSD From W1AJC1
Onevent CONTROL Call C_AJCXSD(zc) From W1AJC1
Return

Subprog C_AJCXSD(VALEUR)
Variable Clbfile VALEUR
## Action %OBLIG
If len(VALEUR)=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "AJCXSD" : GZNUM = 0 : Endif
Gosub _AFF
End

$AMM_AJCXSD
Call AM_AJCXSD(zc)
If !mkstat & GOBJET
 zoncou = "AJCXSD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_AJCXSD(VALEUR)
Variable Clbfile VALEUR
## Action STD
Call AM_AJCXSD(VALEUR) From SUBAJC
If mkstat : GERR = 1 : GZONE = "AJCXSD" : GZNUM = 0 : Endif
Gosub _AFF
End

$CHG_STY
Return


