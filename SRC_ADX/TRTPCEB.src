#<AdxTL>@(#)3.0.0.0 $Revision$
##############################################################
## Gestion des codes comptables par produit
##############################################################
$CODE_COMPTABLE
Case [F:GAD]TYPACCCOD(K)
 When 1 : # Article
  If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
  Call LEC_ITM(CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:ITM]ACCCOD : Endif
 When 2 : # Client
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
  Call LEC_BPC(CLECPT) From CPTLEC
  Call INIT_COMPTE(CLECPT,GSOCIETE,"C",CODCPT) From CPTSUB
 When 3 : # Fournisseur
  If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
  Call LEC_BPS(CLECPT) From CPTLEC
  Call INIT_COMPTE(CLECPT,GSOCIETE,"F",CODCPT) From CPTSUB
 When 4 : # Représentants
  If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif
  Call LECTURE("REP",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:REP]ACCCOD : Endif
 When 5 : # Acheteurs/utilisateurs
  If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
  Call LECTURE("AUS",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:AUS]ACCCOD : Endif
 When 6 : # Pièces
  If dim([F:TB1]ACCCOD)>0
   CODCPT = [F:TB1]ACCCOD
  Elsif dim([F:TB0]ACCCOD)>0
   CODCPT = [F:TB0]ACCCOD
  Endif
 When 7 : # Société
  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
  Call LEC_CPY(CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:CPY]ACCCOD : Endif
 When 8 : # Site
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  Call LEC_FCY(CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:FCY]ACCCOD : Endif
 When 9 : # Devise
  If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
  Call LEC_TCU(CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:TCU]ACCCOD : Endif
 When 10 : # Taxes
  If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif
  Call LEC_TVT_LEG(GCURLEG,CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:TVT]ACCCOD : Endif
 When 11 : # Pieds de facture ventes
  If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif
  Call LECTURE("SFI",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:SFI]ACCCOD : Endif
 When 12 : # Escomptes
  If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
  Call LEC_TDA(GCURLEG,CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:TDA]ACCCOD : Endif
 When 13 : # Banque
  If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
  Call LEC_BAN(CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:BAN]ACCCOD : Endif
 When 14 : # Règlement
  If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif
  Call LEC_CPY(GSOCIETE) From CPTLEC
  Call LEC_CDA_LEG([F:CPY]LEG,CLECPT) From CPTLEC
  If fstat : CODCPT = "" : Else : CODCPT = [F:CDA]ACCCOD : Endif
 When 15 : # Immos
  CODCPT = CLECPT : # c'est un peu spécial car la clé immo a 2 parties
 When 16 : # Pieds de facture achats
  If clalev([F:PFI])=0 : Local File PFOOTINV [PFI] : Endif
  Call LECTURE("PFI",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:PFI]ACCCOD : Endif
 When 17 : # Tiers divers
  If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
  Call LECTURE("BPR",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:BPR]ACCCOD : Endif
 When 18 : # Sections de valorisation
  If clalev([F:MWC])=0 : Local File WORKCOST [MWC] : Endif
  # adaptation pour renseigner les 2 parties de la clé (10/09/03 - TB)
  L = instr(1,CLECPT,"~")
  If L > 1
    CLECPT1 = evalue(left$(CLECPT,L-1))
    CLECPT2 = evalue(right$(CLECPT,L+1))
    Call LECTURE("MWC",CLECPT2,CLECPT1) From CONTOBJ
    If fstat : CODCPT = "" : Else : CODCPT = [F:MWC]ACCCOD : Endif
  Else
    CODCPT = ""
  Endif
 When 19 : # Frais généraux
  If clalev([F:ONA])=0 : Local File OVENAT[ONA] : Endif
  Call LECTURE("ONA",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:ONA]ACCCOD : Endif
 When 20 : # Frais pour note de frais
  If clalev([F:TES])=0 : Local File TABEXPENS [TES] : Endif
  Call LECTURE("TES",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:TES]ACCCOD : Endif
 When 21 : # Factor
  If clalev([F:FCT])=0 : Local File FACTOR [FCT] : Endif
  Call LECTURE("FCT",CLECPT,"") From CONTOBJ
  If fstat : CODCPT = "" : Else : CODCPT = [F:FCT]ACCCOD : Endif
 When 22 : # Contrat de location financement
  CODCPT = CLECPT
 When 23 : # Subvention
  CODCPT = CLECPT
 When 24 : # Contrats de concession
  CODCPT = CLECPT
Endcase
GPOINT = "INIACCCOD" : Gosub ENTREE From EXEFNC : # Demande 18985
Return

