#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FCHQNUM","MODCHQNUM","") From GSAISIE
#Subprog SAISIE_CHAR(VALEUR,PARAM,BOITE,PROG,PROGSPE)

End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "ENR"          : Gosub ENREG
 When "ABA"          : Gosub ABANDON
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "MEN"          : Gosub MENU
 When Default
Endcase
Return


$OUVRE
Local Char    NUMCHE(15), PREV_NUMCHE(15), FIRST_CHQ(15)
Local Char    BANQUE(GLONBAN)
Local Integer NOL
Local Integer CHQ, NBCHQ
Local Integer MODIF
If clalev([CHB])=0 : Local File CHQBOK  [CHB] : Endif
If clalev([CHN])=0 : Local File CHQNUM  [CHN] : Endif
Return


$DEBUT
BANQUE = PARAM(1)
FIRST_CHQ = PARAM(2)
NBCHQ = val(PARAM(3))
Raz [M:CHN]
Gosub LECTURE
Return


$LECTURE
Raz nolign
[L]PREV_NUMCHE = FIRST_CHQ
For CHQ = 0 To NBCHQ-1
 If nolign=dim([M:CHN]CHQNUM)
  GMESSAGE = mess(26,100,1)
  GERR=1 : Break
 Endif
 NOL=nolign : nolign += 1
 If CHQ = 0
  NUMCHE = FIRST_CHQ
 Else
#  Call INCSERIE(NUMCHE,[L]PREV_NUMCHE) From EDITCHE
  Call INCSERIE(NUMCHE,[L]PREV_NUMCHE,1) From CHKLIB
 Endif
 [L]PREV_NUMCHE = [L]NUMCHE
 Read [CHN]CHN0 = BANQUE ; NUMCHE
 If !fstat
  [M:CHN]            = [F:CHN]
  [M:CHN]CHQNUM(NOL) = [L]NUMCHE
  [M:CHN]STA(NOL)    = [F:CHN]STA
  [M:CHN]PAYNUM(NOL) = [F:CHN]PAYNUM
  [M:CHN]POSPAYCREDAT(NOL) = [F:CHN]POSPAYCREDAT        # RBU: 80148 - Positive Pay
  [M:CHN]POSPAYSEQ(NOL)    = [F:CHN]POSPAYSEQ           # RBU: 80148 - Positive Pay
 Else
  nolign -= 1
 Endif
Next
[M:CHN]NBRCHQ = nolign

# GRNA 20/06/2011
Gosub LECTURE From CHKLIB

Affzo [CHN]
MODIF = 0
Return

$SETBOUT
Raz ETABOU

# GRNA 20/06/2011
Gosub SETBOUT From CHKLIB

If MODIF
 ETABOU(GENRE) = 1
 ETABOU(GABAN) = 1
Endif
ETABOU(GBFIN) = 1

Return


$APRES_MODIF
If COUZON="STA"
  MODIF = 1
Endif

# GRNA 20/06/2011
Gosub APRES_MODIF From CHKLIB

Return


$MENU
Gosub MENU From CHKLIB
Return


$ENREG
Call DEBTRANS From GLOCK
Gosub TR1
Gosub LECTURE
Return


$TR1
GOK = 1
Trbegin [CHN]
 For NOL = 0 To [M:CHN]NBRCHQ-1
  Readlock [CHN]CHN0 = [M:CHN]BAN;[M:CHN]CHQNUM(NOL)
  If fstat=1
   GOK=-1 : GLOCK="$CHQNUM"-[M:CHN]BAN-[M:CHN]CHQNUM(NOL) : Break
  Elsif fstat
   GOK=0 : Call RSTA("CHN",[M:CHN]BAN-[M:CHN]CHQNUM(NOL)) From GLOCK : Break
  Endif
  [F:CHN]STA    = [M:CHN]STA(NOL)
  [F:CHN]PAYNUM = [M:CHN]PAYNUM(NOL)
  [F:CHN]POSPAYSEQ    = [M:CHN]POSPAYSEQ(NOL)           # ROSCH: 80148 - Positive Pay
  [F:CHN]POSPAYCREDAT = [M:CHN]POSPAYCREDAT(NOL)        # ROSCH: 80148 - Positive Pay
  Rewrite [CHN]
  If fstat
   GOK=0 : Call FSTA("CHN") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


$ABANDON
Gosub LECTURE
Return


######################################################################################
Subprog AS_STA(VALEUR)
Variable Integer VALEUR
#If VALEUR = 4
# mkstat = 2 : End
#Endif

# GRNA 08/07/2011
Call AS_STA(VALEUR) From CHKLIB
If mkstat : End : Endif

If [M:CHN]CHQNUM(nolign-1) = ""
 mkstat = 1 : End
Endif

End


# GRNA 20/07/2011
######################################################################################
Subprog AM_STA(VALEUR)
Variable Integer VALEUR
Call AM_STA(VALEUR) From CHKLIB
End
