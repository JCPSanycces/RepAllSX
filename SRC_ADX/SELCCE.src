#<AdxTL>@(#)10.0.0.0 $Revision$
GBIDC1="" : GBIDC2="" : GFLAG="ANA"
Call OBJET("GAS",GBIDC1,GBIDC2) From GOBJET
End
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE

Local Char PARAM(30)(1..10) , VALEUR(10)

PARAM(1) = "PRO"
PARAM(2) = "PAR"
PARAM(3) = "20000828"
PARAM(4) = "0"
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
Call S_TAB_CHAR(VALEUR,PARAM,"SELCCE","SELCCE","") From GACTION
End

#######################################################################
# Action SELCCE modélisée
#######################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
    When "SELCCE" : Gosub SELCCE
  Endcase
 When "SEL_LISTE" : Gosub SEL_LISTE
Endcase
Return

$SELCCE
Local Integer ERR , I , J , K , MAXLNK, NBRLNK, IND1, IND2

Local Char    DIEAZC(GLONDIE)   : # Axe de la sélection
Local Char    FCY(GLONFCY)      : # le site
Local Date    DAT               : # la date
Local Integer NOL               : # le numéro de ligne dans le tableau
Local Char    LSTDIE(255)       : # Permet de déterminer les axes               Exemple : "[M]DIE#", # indique zone indicée
Local Char    LSTCCE(255)       : # Permet de déterminer les sections           Exemple : "[M]CCE#", # indique zone indicée
Local Char    LSTCOA(150)       : # Permet de déterminer les plans de compte    Exemple : "[M]COA#", # indique zone indicée
Local Char    LSTACC(150)       : # Permet de déterminer les comptes            Exemple : "[M]ACC#", # indique zone indicée

#Pour ne pas s'arrêter au numéro d'axe en cours. Besoin de toutes la liste la
#selection et le contrôle des sections budgets opérationnels (entité et enveloppe)
Local Integer CAS_GDD : CAS_GDD=0

If clalev([F:DIE])=0 : Local File GDIE [DIE] : Endif
If clalev([F:CCE])=0 : Local File CACCE    [CCE] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
DIEAZC = PARAM(1)
FCY    = PARAM(2)
If PARAM(3)<>""
 DAT = gdat$(PARAM(3))
Else
 DAT = [0/0/0]
Endif
NOL = val(PARAM(4))

LSTDIE = PARAM(5)
LSTCCE = PARAM(6)
LSTCOA = PARAM(7)
LSTACC = PARAM(8)

#--------------------------------------------------------------------------------------------------
## Spécifique budgets opérationnels : On passe directement à l'action suite de SELCCE
#--------------------------------------------------------------------------------------------------
If func AFNC.ACTIV("GDD")
 Call LEC_DIE(PARAM(1)) From CPTLEC
 If [F:DIE]ENT=2 | [F:DIE]ENV=2
  OK=0 : Return
 Endif
Endif

#--------------------------------------------------------------------------------------------------
## Position et taille de la fenêtre
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOCCE
For I=1 To NBSEL
 COL(I) = SELZON(I)
 TIT(I) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
Endif
Next I
NBCOL  = NBSEL
SIZCOL = 240
SIZLIG = 100
TIT(0) = mess(12,123,1)-mess(36,103,1) : # Choix Sections analytiques
START  = "[F:CCE]CCE"
ORDRE  = "[F:CCE]DIE;[F:CCE]CCE"
OBJET  = ""


#--------------------------------------------------------------------------------------------------
## Critères pour la sélection standard
#--------------------------------------------------------------------------------------------------

## Critères de sélection
## Le link fait des liaisons "externes gauches"
## Toute la subtilité de la chose est de mettre des fonctions qui
## ne sont pas transmises à la base de données : len() , num$()
## sinon celle-ci ne renvoie rien du tout...sniff

CRITERE(1)   = "[F:CCE]ENAFLG=2"
CRITERE(1)  -= " & [F:CCE]DIE='"+[L]DIEAZC+"'"

If [L]FCY<>""
 CRITERE(1) -= '& ([F:CCE]FCY="" | [F:CCE]FCY="'+[L]FCY+'" | [F:FGR]CPY<>"")'
Endif

If DAT<>[0/0/0]
 CRITERE(1) -= '& ([F:CCE]VLYSTR=[0/0/0] | [F:CCE]VLYSTR<=['+format$(GFMD,DAT)+'])'
 CRITERE(1) -= '& ([F:CCE]VLYEND=[0/0/0] | [F:CCE]VLYEND>=['+format$(GFMD,DAT)+'])'
Endif

CRITERE(2) = '& (GUSRACS=2 | [F:CCE]ACS="" | num$([F:ACC]EXEC)="2")'

If dim(SELCAR)>0 & SELCAR<>0
 CRITERE(2) -= '& left$([F:CCE]CCE,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

#--------------------------------------------------------------------------------------------------
## Critères pour la sélection spécifique
#--------------------------------------------------------------------------------------------------
#
If GFONCTION="BUDGET" or GFONCTION="GESBUC" or GFONCTION="GESBDO"
 CRITERE(1) -= " & [F:CCE]BUDTRK=2"
Else
 CRITERE(1) -= " & [F:CCE]IPT=2"
Endif

#--------------------------------------------------------------------------------------------------
## Liste des comptes et plans de compte associés
## Evaluation des codes interdiction comptes/sections =>  Identifie le nombre de compte à gérer
## Liste des sections et axes associés
## Evaluation des codes interdiction sections/sections =>  Identifie le nombre d'axes à gérer
#
# Nb: sortie de cet étiquette pour *BUO Budgets opérationnels, car besoin d'acces depuis $SELCCE et subprog CTLCCE From TRTGDD
#--------------------------------------------------------------------------------------------------
#
Gosub EVAL_CAZ

#--------------------------------------------------------------------------------------------------
## Link du filtre
#--------------------------------------------------------------------------------------------------
#-- Nombre de liens à faire selon la présence des codes interdiction (comptes/sections + sections/sections)
NBRLNK = [L]NBAUZCPT+[L]NBAUZCCE
#-- Nombre maximum de link est 12... donc au niveau des codes interdictions,
#   le maxi qu'on peut linker [AUZ] avec [CCE] est 8
MAXLNK = 4

## Si liens avec les codes interdictions, il risque d'y avoir un problème de nombre de fichiers ouverts
If NBRLNK
 ERR = 0
 Onerrgo ERROUV
 For I=1 To min(MAXLNK,NBRLNK)
  Case I
   When 1 : Local File CAAUZ [CA1] : Columns [CA1] (TYP,AUZ1,AUZ2)
   When 2 : Local File CAAUZ [CA2] : Columns [CA2] (TYP,AUZ1,AUZ2)
   When 3 : Local File CAAUZ [CA3] : Columns [CA3] (TYP,AUZ1,AUZ2)
   When 4 : Local File CAAUZ [CA4] : Columns [CA4] (TYP,AUZ1,AUZ2)
   When 5 : Local File CAAUZ [CA5] : Columns [CA5] (TYP,AUZ1,AUZ2)
   When 6 : Local File CAAUZ [CA6] : Columns [CA6] (TYP,AUZ1,AUZ2)
   When 7 : Local File CAAUZ [CA7] : Columns [CA7] (TYP,AUZ1,AUZ2)
   When 8 : Local File CAAUZ [CA8] : Columns [CA8] (TYP,AUZ1,AUZ2)
  Endcase
 Next I
 Onerrgo
 If ERR
  # Si problème, on se déroute sur le select standard
  OBJET = "CCE"
  Return
 Endif
Endif

## A ce stade, l'option est de privilégier les codes intersections comptes/sections puis sections/sections.
Local Integer NBRAUZ
Local Char    TOTAUZ(5)(1..MAXLNK)
Local Integer TYPAUZ(1..MAXLNK)

NBRAUZ = 0
For I=1 To [L]NBAUZCPT
 If NBRAUZ<MAXLNK
  NBRAUZ += 1
  CRITERE(3) -= '& string$(1,[F:CA'+num$(NBRAUZ)+']AUZ1)=""'
  TYPAUZ(NBRAUZ) = 2
  TOTAUZ(NBRAUZ) = [L]AUZCPT(I-1)
 Endif
Next I
For I=1 To [L]NBAUZCCE
 If NBRAUZ<MAXLNK
  NBRAUZ += 1
  CRITERE(3) -= '& string$(1,[F:CA'+num$(NBRAUZ)+']AUZ1)=""'
  TYPAUZ(NBRAUZ) = 1
  TOTAUZ(NBRAUZ) = [L]AUZCCE(I-1)
 Endif
Next I

Case NBRAUZ
 When 0
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&  As [LNC]

 When 1
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&  As [LNC]

 When 2
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&  As [LNC]

 When 3
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&  As [LNC]


 When 4
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&  As [LNC]

 When 5
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&  As [LNC]

 When 6
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&               , [CA6]CAZ0     = [L]TYPAUZ(6);TOTAUZ(6);[F:CCE]AUZ
&  As [LNC]

 When 7
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&               , [CA6]CAZ0     = [L]TYPAUZ(6);TOTAUZ(6);[F:CCE]AUZ
&               , [CA7]CAZ0     = [L]TYPAUZ(7);TOTAUZ(7);[F:CCE]AUZ
&  As [LNC]

 When 8
  Link [CCE] With [AXX]AXX0     ="CACCE";"DESTRA";GLANGUE;[F:CCE]DIE;[F:CCE]CCE
&               , [ACC]CODACC   = GUSER;[F:CCE]ACS
&               , [FGR]FGR1     = [L]FCY;[F:CCE]FCY
&               , [CA1]CAZ0     = [L]TYPAUZ(1);TOTAUZ(1);[F:CCE]AUZ
&               , [CA2]CAZ0     = [L]TYPAUZ(2);TOTAUZ(2);[F:CCE]AUZ
&               , [CA3]CAZ0     = [L]TYPAUZ(3);TOTAUZ(3);[F:CCE]AUZ
&               , [CA4]CAZ0     = [L]TYPAUZ(4);TOTAUZ(4);[F:CCE]AUZ
&               , [CA5]CAZ0     = [L]TYPAUZ(5);TOTAUZ(5);[F:CCE]AUZ
&               , [CA6]CAZ0     = [L]TYPAUZ(6);TOTAUZ(6);[F:CCE]AUZ
&               , [CA7]CAZ0     = [L]TYPAUZ(7);TOTAUZ(7);[F:CCE]AUZ
&               , [CA8]CAZ0     = [L]TYPAUZ(8);TOTAUZ(8);[F:CCE]AUZ
&  As [LNC]


Endcase

Default File [LNC]
DEFPAG = 1
Return


$EVAL_CAZ
#--------------------------------------------------------------------------------------------------
# Liste des comptes, plans, sections, axes et évaluations des codes interdictions impliqués
# NB: déporté de $SELCCE pour être utilisable dans l'action SELCCEGDD (#  BUO Budgets opérationnels-04/02/09)
#--------------------------------------------------------------------------------------------------

## Evaluation des codes interdiction comptes/sections =>  Identifie le nombre de compte à gérer
##################################################################################################################
Local Char ACC(GLONGAC)(0..9), COA(GLONCOA)(0..9)
Local Integer NBCPT
Raz [L]COA, ACC

If instr(1,[L]LSTACC,";")
 #----------------------------------------------------------------------------------------------------
 # CAS 1 : le [L]LSTACC contient une liste de compte séparée par des ";"
 #       & le [L]LSTCOA contient les plans de compte associé au compte (idem séparée par des ";")
 #----------------------------------------------------------------------------------------------------
 While [L]LSTACC<>""
  J = instr(1,[L]LSTCOA,";")
  I = instr(1,[L]LSTACC,";")
  If I
   [L]COA([L]NBCPT) = left$([L]LSTCOA,J-1) : [L]LSTCOA = vireblc(right$([L]LSTCOA,J+1),2)
   [L]ACC([L]NBCPT) = left$([L]LSTACC,I-1) : [L]LSTACC = vireblc(right$([L]LSTACC,I+1),2)
  Else
   [L]COA([L]NBCPT) = [L]LSTCOA : [L]LSTCOA = ""
   [L]ACC([L]NBCPT) = [L]LSTACC : [L]LSTACC = ""
  Endif
 [L]NBCPT += 1
 Wend
Elsif instr(1,[L]LSTACC,"#")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 2 : le [L]LSTACC contient par exemple [M]ACC# ce qui entraine la lecture de [M]ACC1, [M]ACC2... [M]ACC10
 #       & le [L]LSTCOA est soit sur le même principe
 #                          soit la liste de plan de compte séparée par des ";"
 #                          soit une variable dimentionnée par exemple [M]COA(x  (où x indique le début de lecture 0 ou1)
 #------------------------------------------------------------------------------------------------------------
 Raz ACC
 K = instr(1,[L]LSTACC,"#")
 For I=0 To 9
  Onerrgo ERROUV
  ERR = 0
  [L]ACC(I) = evalue(left$([L]LSTACC,K-1)+num$(I+1)+"("+num$(NOL)+")")
  Onerrgo
  If ERR : Break : Endif
 Next
 Raz COA
 K = instr(1,[L]LSTCOA,"#")
 If K
  For I=0 To 9
   Onerrgo ERROUV
   ERR = 0
   [L]COA(I) = evalue(left$([L]LSTCOA,K-1)+num$(I+1)+"("+num$(NOL)+")")
   If [L]COA(I)="" : [L]NBCPT=I : Break : Endif
   Onerrgo
   If ERR : Break : Endif
  Next
 Elsif instr(1,[L]LSTCOA,";")
  While [L]LSTCOA<>""
   J = instr(1,[L]LSTCOA,";")
   If J
    [L]COA([L]NBCPT) = left$([L]LSTCOA,J-1) : [L]LSTCOA = vireblc(right$([L]LSTCOA,J+1),2)
   Else
    [L]COA([L]NBCPT) = [L]LSTCOA : [L]LSTCOA = ""
   Endif
   [L]NBCPT += 1
  Wend
 Elsif instr(1,[L]LSTCOA,"(")
  K = instr(1,[L]LSTCOA,"(")
  IND1 = val(mid$([L]LSTCOA,K+1,1))
  [L]LSTCOA = left$([L]LSTCOA,K-1)
  Raz IND2
  If IND1=0 : IND2=9 :Endif
  If IND1=1 : IND2=10 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]COA([L]NBCPT) = evalue([L]LSTCOA+"("+num$(I)+")")
   #09/12/09
   #Je commente la ligne suivante certainement ajoutée en création pour optimiser le traitement
   # or pour les engagements multi-référentiel, il est nécessaire de continuer le parcours
   #If  [L]COA([L]NBCPT)="" : Break : Endif
   [L]NBCPT += 1
   Onerrgo
   If ERR : Break : Endif
  Next
 Endif
Elsif instr(1,[L]LSTACC,"(")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 3 : le [L]LSTACC contient une parenthèse... par exemple [M]ACC(x ce qui entraine la lecture de [M]ACC(0), [M]ACC(1)... x indique le début de lecture.
 #       & le [L]LSTCOA est sur le même principe
 #------------------------------------------------------------------------------------------------------------
  K = instr(1,[L]LSTACC,"(")
  IND1 = val(mid$([L]LSTACC,K+1,1))
  [L]LSTACC = left$([L]LSTACC,K-1)
  Raz IND2
  If IND1=0 : IND2=9 :Endif
  If IND1=1 : IND2=10 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]ACC(NBCPT) = evalue([L]LSTACC+"("+num$(I)+")")
   If  [L]ACC([L]NBCPT)="" : Break : Endif
   [L]NBCPT += 1
   Onerrgo
   If ERR : Break : Endif
  Next
  Raz NBCPT
  K = instr(1,[L]LSTCOA,"(")
  IND1 = val(mid$([L]LSTCOA,K+1,1))
  [L]LSTCOA = left$([L]LSTCOA,K-1)
  Raz IND2
  If IND1=0 : IND2=9 :Endif
  If IND1=1 : IND2=10 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]COA(NBCPT) = evalue([L]LSTCOA+"("+num$(I)+")")
   If  [L]COA([L]NBCPT)="" : Break : Endif
   [L]NBCPT += 1
   Onerrgo
   If ERR : Break : Endif
  Next
Elsif [L]LSTACC<>""
 #------------------------------------------------------------------------------------------------------------------
 # CAS 4 : le [L]LSTACC contient une seul compte
 #       & le [L]LSTCOA contient le plan de compte lié au compte
 #------------------------------------------------------------------------------------------------------------
 [L]NBCPT = 1
 [L]ACC = [L]LSTACC
 [L]COA = [L]LSTCOA
Endif

# Compte renseigné, lecture des codes interdictions.
Local Char COAAUZ(GLONCOA)(0..9), CPTAUZ(GLONGAC)(0..9),  AUZCPT(5)(0..9)
Local Integer NBAUZCPT
Raz COAAUZ,CPTAUZ,AUZCPT,NBAUZCPT
For I=0 To [L]NBCPT-1
 If [L]COA(I)<>"" & [L]ACC(I)<>""
  Read [GAC]GAC0 = [L]COA(I);[L]ACC(I)
  If !fstat
   [L]COAAUZ([L]NBAUZCPT) = [F:GAC]COA
   [L]CPTAUZ([L]NBAUZCPT) = [F:GAC]ACC
   [L]AUZCPT([L]NBAUZCPT) = [F:GAC]AUZ
   [L]NBAUZCPT+=1
  Endif
 Endif
Next

## Evaluation des codes interdiction sections/sections =>  Identifie le nombre d'axes à gérer
##################################################################################################################
Local Char CCE(GLONCCE)(0..19), DIE(GLONDIE)(0..19)
Local Integer NBCCE
Raz [L]CCE, DIE

If instr(1,[L]LSTCCE,";")
 #----------------------------------------------------------------------------------------------------
 # CAS 1 : le [L]LSTCCE contient une liste de sections séparée par des ";"
 #       & le [L]LSTDIE contient les axes associé aux sections (idem séparée par des ";")
 #----------------------------------------------------------------------------------------------------
 While [L]LSTCCE<>""
  J = instr(1,[L]LSTCCE,";")
  I = instr(1,[L]LSTDIE,";")
  If I
   [L]CCE([L]NBCCE) = left$([L]LSTCCE,J-1) : [L]LSTCCE = vireblc(right$([L]LSTCCE,J+1),2)
   [L]DIE([L]NBCCE) = left$([L]LSTDIE,I-1) : [L]LSTDIE = vireblc(right$([L]LSTDIE,I+1),2)
  Else
   [L]DIE([L]NBCCE) = [L]LSTDIE : [L]LSTDIE = ""
   [L]CCE([L]NBCCE) = [L]LSTCCE : [L]LSTCCE = ""
  Endif
 [L]NBCCE += 1
 Wend
Elsif instr(1,[L]LSTCCE,"#")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 2 : le [L]LSTCCE contient par exemple [M]CCE# ce qui entraine la lecture de [M]CCE1, [M]CCE2... [M]CCE10
 #       & le [L]LSTDIE est soit sur le même principe
 #                          soit la liste des axes séparée par des ";"
 #                          soit une variable dimentionnée par exemple [M]DIE(x  (où x indique le début de lecture 0 ou1)
 #------------------------------------------------------------------------------------------------------------
 Raz CCE
 K = instr(1,[L]LSTCCE,"#")
 For I=0 To 19
  Onerrgo ERROUV
  ERR = 0
  [L]CCE(I) = evalue(left$([L]LSTCCE,K-1)+num$(I+1)+"("+num$(NOL)+")")
  Onerrgo
  If ERR : Break : Endif
 Next

 Raz DIE
 K = instr(1,[L]LSTDIE,"#")
 If K
  For I=0 To 19
   Onerrgo ERROUV
   ERR = 0
   [L]DIE(I) = evalue(left$([L]LSTDIE,K-1)+num$(I+1)+"("+num$(NOL)+")")
   If  [L]DIE(I)=""        : [L]NBCCE = I   : Break : Endif
   If  [L]DIE(I)=[L]DIEAZC & !CAS_GDD : [L]NBCCE = I+1 : Break : Endif
   Onerrgo
   If ERR : Break : Endif
  Next
 Elsif instr(1,[L]LSTDIE,";")
  While [L]LSTDIE<>""
   J = instr(1,[L]LSTDIE,";")
   If J
    [L]DIE([L]NBCCE) = left$([L]LSTDIE,J-1) : [L]LSTDIE = vireblc(right$([L]LSTDIE,J+1),2)
   Else
    [L]DIE([L]NBCCE) = [L]LSTDIE : [L]LSTDIE = ""
   Endif
  If [L]DIE([L]NBCCE)=[L]DIEAZC & !CAS_GDD : Break : Endif
  [L]NBCCE += 1
  Wend
 Elsif instr(1,[L]LSTDIE,"(")
  K = instr(1,[L]LSTDIE,"(")
  IND1 = val(mid$([L]LSTDIE,K+1,1))
  [L]LSTDIE = left$([L]LSTDIE,K-1)
  Raz IND2
  If IND1=0 : IND2=19 :Endif
  If IND1=1 : IND2=20 :Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]DIE([L]NBCCE) = evalue([L]LSTDIE+"("+num$(I)+")")
   If  [L]DIE([L]NBCCE)=[L]DIEAZC & !CAS_GDD : Break : Endif
   [L]NBCCE+=1
   Onerrgo
   If ERR : Break : Endif
  Next
 Endif
Elsif instr(1,[L]LSTCCE,"(")
 #------------------------------------------------------------------------------------------------------------------
 # CAS 3 : le [L]LSTCCE contient une parenthèse... par exemple [M]CCE(x ce qui entraine la lecture de [M]CCE(0), [M]CCE(1)... x indique le début de lecture.
 #       & le [L]LSTDIE est soit sur le même principe
 #------------------------------------------------------------------------------------------------------------------
  K = instr(1,[L]LSTCCE,"(")
  IND1 = val(mid$([L]LSTCCE,K+1,1))
  [L]LSTCCE = left$([L]LSTCCE,K-1)
  Raz IND2
  If IND1=0 : IND2=19 : Endif
  If IND1=1 : IND2=20 : Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]CCE(I) = evalue([L]LSTCCE+"("+num$(I)+")")
   Onerrgo
   If ERR : Break : Endif
  Next
  K = instr(1,[L]LSTDIE,"(")
  IND1 = val(mid$([L]LSTDIE,K+1,1))
  [L]LSTDIE = left$([L]LSTDIE,K-1)
  Raz IND2
  If IND1=0 : IND2=19 : Endif
  If IND1=1 : IND2=20 : Endif
  For I=IND1 To IND2
   Onerrgo ERROUV
   ERR = 0
   [L]DIE([L]NBCCE) = evalue([L]LSTDIE+"("+num$(I)+")")
   If  [L]DIE([L]NBCCE)=[L]DIEAZC & !CAS_GDD : Break : Endif
   [L]NBCCE+=1
   Onerrgo
   If ERR : Break : Endif
  Next
Elsif [L]LSTCCE<>""
 #------------------------------------------------------------------------------------------------------------------
 # CAS 4 : le [L]LSTCCE contient une seule section
 #       & le [L]LSTDIE contient l'axe
 #------------------------------------------------------------------------------------------------------------
 [L]NBCCE = 1
 [L]CCE = [L]LSTCCE
 [L]DIE = [L]LSTDIE
Endif

# Sections renseignés, lecture des codes interdictions.
Local Char DIEAUZ(GLONDIE)(0..19), CCEAUZ(GLONCCE)(0..19), AUZCCE(GLONADI)(0..19)
Local Integer NBAUZCCE

Raz DIEAUZ, CCEAUZ, AUZCCE, NBAUZCCE
For I=0 To [L]NBCCE-1
 If [L]DIE(I)<>"" & [L]CCE(I)<>""
  Read [CCE]CCE0 = [L]DIE(I);[L]CCE(I)
  If !fstat
   [L]DIEAUZ([L]NBAUZCCE) = [F:CCE]DIE
   [L]CCEAUZ([L]NBAUZCCE) = [F:CCE]CCE
   [L]AUZCCE([L]NBAUZCCE) = [F:CCE]AUZ
   [L]NBAUZCCE+=1
  Endif
 Endif
Next
Return

$ERROUV
ERR = errn
Resume

#--------------------------------------------------------------------------------------------------
# Budgets opérationnels
# Traitement de l'action SELCCEGDD
#--------------------------------------------------------------------------------------------------

$SEL_LISTE
Case LISTE
 When "SELCCE" : Gosub S_CCEBUO
Endcase
Return

$S_CCEBUO
#Pour budgets opérationnels
If !func AFNC.ACTIV("GDD")
 OK=0 : Return
Endif
#--------------------------------------------------------------------------------------------------
# séléction des sections entités et enveloppes dans le cadre des budgets opérationnels (used in DA)
#--------------------------------------------------------------------------------------------------
Local Char    DIEAZC(GLONDIE)   : # Axe de la sélection
Local Char    FCY(GLONFCY)      : # le site
Local Date    DAT               : # la date
Local Integer NOL               : # le numéro de ligne dans le tableau
Local Char    LSTDIE(255)       : # Permet de déterminer les axes               Exemple : "[M]DIE#", # indique zone indicée
Local Char    LSTCCE(255)       : # Permet de déterminer les sections           Exemple : "[M]CCE#", # indique zone indicée
Local Char    LSTCOA(150)       : # Permet de déterminer les plans de compte    Exemple : "[M]COA#", # indique zone indicée
Local Char    LSTACC(150)       : # Permet de déterminer les comptes            Exemple : "[M]ACC#", # indique zone indicée

Local Integer CAS :# 1 on est sur une section entité, 2 on est sur une section enveloppe
Local Integer CAS_GDD : CAS_GDD=0

#Paramètre de bébrayage du circuit d'appro (ligne) en fonction de l'utilisateur
Local Integer DEBAPP
Local Char PARDEBAPP
If func AFNC.ACTIV("GDD")   # Issue X3-107197
Call PARAMUTIL("GDDDEBAPP",PARDEBAPP,"","") From SUBAUS
Endif   # Issue X3-107197
DEBAPP=val(PARDEBAPP)

If clalev([F:DIE])=0 : Local File GDIE     [DIE] : Endif
If clalev([F:CCE])=0 : Local File CACCE    [CCE] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
DIEAZC = PARAM(1)
FCY    = PARAM(2)
If PARAM(3)<>""
 DAT = gdat$(PARAM(3))
Else
 DAT = [0/0/0]
Endif
NOL = val(PARAM(4))

LSTDIE = PARAM(5)
LSTCCE = PARAM(6)
LSTCOA = PARAM(7)
LSTACC = PARAM(8)

#--------------------------------------------------------------------------------------------------
# Vérification si cas Budget Op. (présence axe entité ou enveloppe)
#--------------------------------------------------------------------------------------------------
Call LEC_DIE(DIEAZC) From CPTLEC
CAS=0
If [F:DIE]ENT=2 : CAS=1 : Endif
If [F:DIE]ENV=2 : CAS=2 : Endif
If !CAS
 OK=0 : Return
Else
 CAS_GDD=1
Endif

#--------------------------------------------------------------------------------------------------
# Récupération du compte ana et des axes et sections enveloppe et entité
#--------------------------------------------------------------------------------------------------
Gosub DEFVAR_CCE_SEL_CTL

#--------------------------------------------------------------------------------------------------
# construction de la selection section pour les achats
#--------------------------------------------------------------------------------------------------
If clalev([F:BUD])=0 : Local File BUD        [BUD] : Endif
If clalev([F:ENT])=0 : Local File ENTITE     [ENT] : Endif
If clalev([F:ENV])=0 : Local File ENVELOPPE  [ENV] : Endif

Local Char SOCIETE(GLONCPY), CRITENV(100), CRITENT(100), CRITBUD(150)
Local Decimal EXERCICE
Local Libelle LEDTYPGEN, LEDTYPANA
Local Char    APPNIV(3)
Local Integer INDENV, INDENT, INDCCE3
Local Char CRITBUDCCE(250)

If LSTACC<>""
 CRITBUD = 'STA=3 & ACC="'+[L]CPTANA+'"'
Else
 CRITBUD = 'STA=3'
Endif

Call LEC_FCY([L]FCY) From CPTLEC
SOCIETE=[F:FCY]LEGCPY
Call SETGLBAPP(SOCIETE,APPNIV) From TRTGDD
Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
Call GETEXE(SOCIETE,LEDTYPANA,DAT,EXERCICE) From CPTSUB
Call GETGDDINDDIE(SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

CRITENV = '(FCY="'+[L]FCY+'" | FCY="'+SOCIETE+'")'
CRITENT = 'CPY="'+SOCIETE+'" | CPY=""'
CRITBUD -= '& FIY='+num$(EXERCICE)+' & (CPY="'+SOCIETE+'" | FCY="'+FCY+'")'

If DEBAPP<>2 & left$(APPNIV,1)="2"
 CRITENV -= '& STA=3'
Endif

Local Integer NBENV : NBENV=0
Local Char TEXTE(GLONDES)(1..500,1..2)
Local Char TEX(GLONDES)(1..500)
TIT = mess(40,100,1) :# Choix
TIT(2)=mess(3,113,1) :# Intitulé
Case CAS
 When 1 :# Entité
  TIT(1)=mess(179,108,1) :# Entité
  For [ENT]ENT0 Where evalue(CRITENT)
   CRITBUDCCE="1=1"
   If INDENT : [L]CRITBUDCCE += "& [F:BUD]CCE"+num$(INDENT)+"='"+[F:ENT]ENT+"'" : Endif
   If CCEENV<>""
    If INDENV : [L]CRITBUDCCE += "& [F:BUD]CCE"+num$(INDENV)+"='"+CCEENV+"'" : Endif
   Endif

   Filter [BUD] Where evalue(CRITBUD) & evalue(CRITBUDCCE)
   Read [BUD]BUD0 First
   If !fstat
    NBTEX += 1
    TEX(NBTEX)   = [F:ENT]ENT
    TEXTE(NBTEX,1) = [F:ENT]ENT
    Call LECTEXTRA(TEXTE(NBTEX,2),"ENTITE","DESTRA",[F:ENT]ENT,"") From ATEXTRA
   Endif
   Filter [BUD]
  Next
  If NBTEX=0
   #Aucune ligne budgétaire approuvée n'est définie pour ces entité et enveloppe sur ce compte analytique
   Call MESSAGE(mess(223,108,1)) From GESECRAN
  Endif
 When 2 :# Enveloppe
  TIT(1)=mess(178,108,1) :# Enveloppe
  For [ENV]ENV0 Where evalue(CRITENV)
   NBENV+=1
   CRITBUDCCE = "1=1"
   If INDENV : [L]CRITBUDCCE += "& [F:BUD]CCE"+num$(INDENV)+"='"+[F:ENV]ENV+"'" : Endif
   If CCEENT<>""
    If INDENT : [L]CRITBUDCCE += "& [F:BUD]CCE"+num$(INDENT)+"='"+CCEENT+"'" : Endif
   Endif

   Filter [BUD] Where evalue(CRITBUD) & evalue(CRITBUDCCE)
   Read [BUD]BUD0 First
   If !fstat
    NBTEX += 1
    TEX(NBTEX)   = [F:ENV]ENV
    TEXTE(NBTEX,1) = [F:ENV]ENV
    Call LECTEXTRA(TEXTE(NBTEX,2),"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
   Endif
   Filter [BUD]
  Next
  If NBENV=0 & DEBAPP<>2
   #Aucune enveloppe approuvée n'est définie sur ce site
   Call MESSAGE(mess(235,108,1)) From GESECRAN
  Elsif NBTEX=0
   #Aucune ligne budgétaire approuvée n'est définie pour ces entité et enveloppe sur ce compte analytique
   Call MESSAGE(mess(223,108,1)) From GESECRAN
  Endif
Endcase
Return

#--------------------------------------------------------------------------------------------------
# Contrôle des sections entités et enveloppes dans le cadre des budgets opérationnels (used in DA)
#--------------------------------------------------------------------------------------------------
Subprog CTLCCE(VALEUR,DIE,FCY,DAT,NOL,LSTDIE,LSTCCE,LSTCOA,LSTACC)
Variable Char VALEUR()
Value Char    DIE()
Value Char    FCY()
Value Date    DAT
Value Integer NOL
Value Char    LSTDIE()
Value Char    LSTCCE()
Value Char    LSTCOA()
Value Char    LSTACC()

If VALEUR="" | !func AFNC.ACTIV("GDD") : End : Endif
#Dmd 60160 : Sur les axe et section d'en-tête le controle des sections
# ne devrait pas se faire
If LSTACC="" : End : Endif
#---------
Local Integer CAS :# 1 on est sur une section entité, 2 on est sur une section enveloppe
Local Integer BOTH : BOTH=0 :#0 on a l'un ou l'autre , 1 on a les deux (entité et enveloppe)
Local Integer CAS_GDD : CAS_GDD=0
Local Char DIEAZC : DIEAZC=VALEUR

If clalev([F:DIE])=0 : Local File GDIE     [DIE] : Endif
If clalev([F:CCE])=0 : Local File CACCE    [CCE] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif

#--------------------------------------------------------------------------------------------------
# Vérification si cas Budget Op. (présence axe entité ou enveloppe)
#--------------------------------------------------------------------------------------------------
Call LEC_DIE(DIE) From CPTLEC
CAS=0
If [F:DIE]ENT=2 : CAS=1 : Endif
If [F:DIE]ENV=2 : CAS=2 : Endif
If !CAS
 End
Else
 CAS_GDD=1
Endif

#Paramètre de bébrayage du circuit d'appro (ligne) en fonction de l'utilisateur
Local Integer DEBAPP
Local Char PARDEBAPP
If func AFNC.ACTIV("GDD")   # Issue X3-107197
  Call PARAMUTIL("GDDDEBAPP",PARDEBAPP,"","") From SUBAUS
Endif   # Issue X3-107197
DEBAPP=val(PARDEBAPP)

If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If clalev([F:ENV])=0 : Local File ENVELOPPE [ENV] : Endif
Local Char SOCIETE(GLONCPY), CRITENV(100), CRITBUD(200)
Local Decimal EXERCICE,ENVFIY
Local Libelle LEDTYPGEN, LEDTYPANA
Local Integer OK_GESPIH

Call LEC_FCY([L]FCY) From CPTLEC
SOCIETE=[F:FCY]LEGCPY
Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
Call GETEXE(SOCIETE,LEDTYPANA,DAT,EXERCICE) From CPTSUB

Local Integer INDENV, INDENT, INDCCE3
Call GETGDDINDDIE(SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

CRITENV = '(FCY="'+[L]FCY+'" | FCY="'+SOCIETE+'")'

#------------------------------------------------------------------------#
# Récupération du compte ana et des axes et sections enveloppe et entité #
#------------------------------------------------------------------------#
Gosub DEFVAR_CCE_SEL_CTL

#--------------------------------------------------------------------#
# Pour le pb de date sur la ligne ne correspondant pas à l'enveloppe #
#--------------------------------------------------------------------#
If CCEENV<>""
 If !clalev([F:ENV])  : Local File ENVELOPPE [ENV]  : Endif
 If !clalev([F:BUT])  : Local File BUDTYP    [BUT]  : Endif
 If !clalev([F:CMDX]) : Local File GCOMMIT   [CMDX] : Endif
 Call LECTURE("ENV",CCEENV,"") From CONTOBJ
 Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
 #différencier enveloppe annuelle de pluriannuelle
 If [F:BUT]YEAFLG=1
  ##Annuelle
  #vérifier la cohérence entre la date passée et la date de l'enveloppe*
  Call GETEXE(SOCIETE,LEDTYPANA,[F:ENV]REASTR,ENVFIY) From CPTSUB
  If EXERCICE < ENVFIY
    EXERCICE=ENVFIY
  Endif
 Else
  If dim([M]CMMPRPNUM)>0
   ##Enveloppe pluriannuelle
   #vérifier la cohérence entre la date passée et la date de l'enveloppe*
   #(*dans le cas pluri-annuelle, voir si un report à eu lieu sur l'engagement pour récupérer la date à traiter)
   Local File GCOMMITD [CMD2]
   Filter [CMD2] Where NUM=[M:PSH1]CMMPRPNUM(NOL) & GRDPCE=6
   Read [CMD2]CMD0 Last
   If !fstat
    Call GETEXE(SOCIETE,LEDTYPANA,[F:CMD2]ACCDAT,ENVFIY) From CPTSUB
    If EXERCICE < ENVFIY
     EXERCICE=ENVFIY
    Endif
   Endif
   Filter [CMD2]
  Endif
 Endif
Endif
#------------------------------------------------------------------------#
If clalev([F:BUD])=0 : Local File BUD [BUD] : Endif

CRITBUD = 'FIY='+num$(EXERCICE)+' & (CPY="'+SOCIETE+'" | FCY="'+FCY+'")'
CRITBUD -= '& ACC="'+[L]CPTANA+'"'

Case CAS
 When 1 :# Entité
  CRITBUD -='& CCE'+num$(INDENT)+'="'+VALEUR+'"'
  If CCEENV<>""
   CRITBUD -='& CCE'+num$(INDENV)+'="'+CCEENV+'"'
   BOTH=1
  Endif
 When 2 :# Enveloppe
  CRITBUD -='& CCE'+num$(INDENV)+'="'+VALEUR+'"'
  If CCEENT<>""
   CRITBUD -='& CCE'+num$(INDENT)+'="'+CCEENT+'"'
   BOTH=1
  Endif
Endcase

#----------------- 79607 ----------------------#
# On ne doit pas bloqué la création d'une facture sur une pièce d'achat existente
# Même si l'enveloppe ou la ligne budgétaire associée est fermé ou non-approuvée
OK_GESPIH=1
If GFONCTION = "GESPIH"
 If GREP<>""
  Case [M]TYPORI(nolign-1)
   When 1 :#Order/Commande
    Local File PORDER [POH]
    Look [POH]POH0 = [M]NUMORI(nolign-1)
    If !fstat : OK_GESPIH=0 : Endif
   When 2 :#Receipt/Réception
    Local File PRECEIPT [PTH]
    Look [PTH]PTH0 = [M]NUMORI(nolign-1)
    If !fstat : OK_GESPIH=0 : Endif
  Endcase
 Elsif clalev([F:PID])>0
  Case [F:PID]TYPORI
   When 1 :#Order/Commande
    Local File PORDER [POH]
    Look [POH]POH0 = [F:PID]NUMORI
    If !fstat : OK_GESPIH=0 : Endif
   When 2 :#Receipt/Réception
    Local File PRECEIPT [PTH]
    Look [PTH]PTH0 = [F:PID]NUMORI
    If !fstat : OK_GESPIH=0 : Endif
  Endcase
 Endif
Endif
#----------------------------------------------#

#---------#
# Control #
#---------#
If CAS=2

 #84682
 Local Char   APPNIV(3)
 Call SETGLBAPP(SOCIETE,APPNIV) From TRTGDD

 Call LECTURE("ENV",VALEUR,"") From CONTOBJ

 If [F:ENV]STA=4 & OK_GESPIH=1
  #Enveloppe incorrecte : Fermée
  GMESSAGE=mess(234,108,1)-":"-mess([F:ENV]STA,2691,1)
  mkstat=2 : End

 Elsif [F:ENV]STA<>3 & DEBAPP<>2 & left$(APPNIV,1)="2" & OK_GESPIH=1 : #Si le débrayage des lignes était inactif nous n'aurions pas besoin de contrôler que l'enveloppe est approuvée
  #Enveloppe non approuvée
  GMESSAGE=[F:ENV]ENV-":"-mess(182,108,1)
  mkstat=2 : End
 Endif
Endif

Filter [BUD] Where evalue(CRITBUD)
If BOTH
 #On a Compte/entité/enveloppe => donc une seule et unique ligne budgétaire possible
 Read [BUD]BUD0 First
 If !fstat
  If [F:BUD]STA=4 & OK_GESPIH=1
    #Entité/Enveloppe incorrecte : Ligne budgétaire Fermée
   GMESSAGE=mess(232+CAS,108,1)-":"-mess(494,198,1)-mess([F:BUD]STA,2691,1)
   mkstat=2
  Elsif [F:BUD]STA<>3
   Local Integer POS
   POS = instr(1,mess(254,108,1),":")
   #Entité/Enveloppe incorrecte : Ligne budgétaire non approuvée
   GMESSAGE=mess(232+CAS,108,1)-":"-right$(mess(254,108,1),POS+1)
   mkstat=2
  Endif
 Else
  #Entité/Enveloppe incorrecte : Aucune Ligne trouvée
  GMESSAGE=mess(232+CAS,108,1)-":"-mess(22,110,1)
  mkstat=2
 Endif
Else
 # Nous n'avons ici qu'une des deux sections enveloppe ou entité,
 # donc potentiellement plusieurs lignes budgétaire possible
 Local Integer BUDEXIST,BUDOK
 BUDOK=0
 BUDEXIST=0
 For [BUD]BUD0
  BUDEXIST=1
  If [F:BUD]STA=3
   BUDOK=1 : Break
  Endif
 Next
 If !BUDEXIST
 #Entité/Enveloppe incorrecte : Aucune Ligne trouvée
  GMESSAGE=mess(232+CAS,108,1)-":"-mess(22,110,1)
  mkstat=2
 Else
  If !BUDOK
   #Entité/Enveloppe incorrecte : Aucune ligne budgétaire approuvée n’est définie pour cette entité, cette enveloppe et ce compte analytique
   GMESSAGE=mess(232+CAS,108,1)-":"-mess(223,108,1)
   mkstat=2
  Endif
 Endif
Endif
Filter [BUD]

#Bug 57549/57524 Signalé par MCL puis MBT
#L'erreur doit être non bloquante si saisie en mode fiche uniquement...
If mkstat & GSCRDIE=2
 Raz mkstat : GERR=2 : GMESSAGE=mess(278,199,1)+"\"+GMESSAGE
Endif
End

#---------------------------------------------------------------------------------------------
# Definitions des variables utiles aux budgets opérationnels Axe&Section Entité & Enveloppe
#---------------------------------------------------------------------------------------------
$DEFVAR_CCE_SEL_CTL
Local Integer ERR , I , J , K , IND1, IND2
#--------------------------------------------------------------------------------------------------
## Liste des comptes et plans de compte associés NBCPT,ACC,COA
## Evaluation des codes interdiction comptes/sections =>  Identifie le nombre de compte à gérer
## Liste des sections et axes associés NBCCE,CCE,DIE
## Evaluation des codes interdiction sections/sections =>  Identifie le nombre d'axes à gérer
#--------------------------------------------------------------------------------------------------
Gosub EVAL_CAZ

#Récupération du compte analytique
Local Char PLAN(GLONCOA), CPTANA(GLONGAC)
Call LEC_FCY([L]FCY) From CPTLEC
Call LECMAINPLAN(2,[F:FCY]LEGCPY,PLAN) From CPTDIV
I = find(PLAN,COA(0..dim([L]COA)-1))
If I
 CPTANA=ACC(I-1)
Endif

#récupération des sections entité et enveloppe
Local Char DIEENT(GLONDIE), DIEENV(GLONDIE), CCEENT(GLONCCE), CCEENV(GLONCCE)
For J=0 To dim([L]DIE)-1
 Call LECTURE("DIE",DIE(J),"") From CONTOBJ
 If [F:DIE]ENT=2
  DIEENT=DIE(J)
  CCEENT=CCE(J)
 Elsif [F:DIE]ENV=2
  DIEENV=DIE(J)
  CCEENV=CCE(J)
 Endif
Next
#--------------------------------------------------------------------------------------------------
# On a maintenant DIEENT, CCEENT, DIEENV, CCEENV
#--------------------------------------------------------------------------------------------------
Return

#--------------------------------------------------------------------------------------------------
# Fin  Budgets opérationnels
#--------------------------------------------------------------------------------------------------

