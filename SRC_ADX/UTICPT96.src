#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT96   UTI process                                    Module CPT   #
#            correction utility
# Create 24/01/2018 By Befou
# For MAJ ORIGIN ORICOD on Migration with FLGGEN
#
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("MAJ UTICPT956 - HAE Table : Update of Oricod") From LECFIC
  Call MAJ_UTICPT96(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT96(DOSSIER)
Value Char DOSSIER

# Issue X3-56195 - 2017-09-15 by GLE : Do not perform on archive folders
If (func DOSSUB.ISHISTFOLD(DOSSIER))
  Call ECR_TRACE("UTICPT96 : Not to perform on archive folder : "+DOSSIER,0) From GESECRAN
  End
Endif

Local Integer WCOMPTEUR_OUI
Local Integer WCOMPTEUR_NON

Call ECR_TRACE("UTICPT96 : HAE Update: Update of ORIGIN records",0) From GESECRAN
Call ECR_TRACE("UTICPT96 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:HAE])  =0  Local File =DOSSIER+".GACCENTRY"   [HAE] : Endif

WCOMPTEUR_1 = 0
WCOMPTEUR_2 = 0
Call DEBTRANS From GLOCK

Trbegin [HAE]
#[F:HAE]ORIGIN = [F:HAEM]FLGGEN
  Update [HAE] Where FLGGEN=2 With ORIGIN=2
  If !fstat
    WCOMPTEUR_OUI = [S]adxuprec
  Endif
  Update [HAE] Where FLGGEN=1 With ORIGIN=1
  If !fstat
    WCOMPTEUR_NON = [S]adxuprec
  Endif

Commit

Close Local File [HAE]

Call ECR_TRACE("UTICPT96 : "+num$(WCOMPTEUR_OUI)+" records updated to YES",0) From GESECRAN
Call ECR_TRACE("UTICPT96 : "+num$(WCOMPTEUR_NON)+" records updated to NO ",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # module compta

Call MAJ_UTICPT96(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # module compta

Call MAJ_UTICPT96(APPLI)
End

