#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
#                                                                       #
#    MODELISATION E-COMMERCE                                            #
#                                                                       #
# ACTION  : TRTTDUCAP  : Action traitement de variation de capacité des #
# postes                                                                #
#                                                      08.02 MM         #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################


$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie

Case ACTION
 When "SETBOUT"       : Gosub SETBOUT
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "ENR"           : Gosub ENREGISTRE
 When "ABA"           : Gosub ABORT
 When "FIN"           : Gosub FIN
 When Default
Endcase

Return
#########################################################################
#    Actions liées au type traitement et affichage divers               #
#########################################################################
$INIT
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:OPS]) = 0 : Local File OPERATIONS  [OPS] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO  [MWS] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY  [FCY] : Endif
If clalev([F:MFO]) = 0 : Local File MFGOPE [MFO] : Endif
# llc 12.02 16779
If clalev([F:PJA]) = 0 : Local File PARJAL   [PJA]  : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR   [TFO]  : Endif

# X3-25623 - STWIL - Need MFGHEAD and ORDERS to filter out Production Scheduler operations
If clalev([F:MFG]) = 0 : Local File MFGHEAD  [MFG]  : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS   [ORD]  : Endif

Local Mask JALK [JALK]


Return
#########################################################################
$INIT_DIA
Local Char    TIT(50) : TIT = mess(234,195,1)
Local Char LFCY (GLONFCY): LFCY= PARAM(1)
Local Char LWST (GLONWST): LWST= PARAM(2)
Local Char LSTRDAT : LSTRDAT = PARAM(3)
Local Char LENDDAT : LENDDAT = PARAM(4)

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM                 # mm 12.02

Raz [M:DIA]
If LFCY <>"" : [M:DIA]MFGFCY = LFCY
Else [M:DIA]MFGFCY    = GFCY  Endif
If LWST <>"" : [M:DIA]EXTWST = LWST : Endif
If LSTRDAT <> ""
    If instr(1,LSTRDAT,"/")
        [M:DIA]STRDAT = "["+LSTRDAT+"]"
    Else
        [M:DIA]STRDAT = LSTRDAT
    Endif
Endif

If LENDDAT <> ""
    If instr(1,LENDDAT,"/")
        [M:DIA]ENDDAT = "["+LENDDAT+"]"
    Else
        [M:DIA]ENDDAT = LENDDAT
    Endif
Endif

Return

#########################################################################
$TERMINE
TRA=1
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return

#########################################################################
$SETBOUT

ETABOU(GENRE) = 1
ETABOU(GABAN) = 1

Return

#########################################################################
$OUVRE
Local Char     CRITERE(250), CRITERE1(250), CRITERE2(250)
Local Char     WMESS1(80) , WCLE(80)
Local Integer  WERR
Local Integer  NBOPS , NBMFO , NBOF
Global Char    FORMULE1(255)

Gosub SEL_OPS

Return
#########################################################################
$SEL_OPS
#--> critères de saisie
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz FORMULE1
CRITERE2 = "1=1"

# ferme
If [M:DIA]OWF=2
    CRITERE = "([F:OPS]OPSTYP=1&[F:OPS]OPSSTA =1)"
    Gosub LOAD_CRITERE
Endif

# planifié
If [M:DIA]OWP=2
    CRITERE = "([F:OPS]OPSTYP=1&[F:OPS]OPSSTA =2)"
    Gosub LOAD_CRITERE
Endif

# suggéré
If [M:DIA]OWS=2
    CRITERE = "([F:OPS]OPSTYP=1&[F:OPS]OPSSTA =3)"
    Gosub LOAD_CRITERE
Endif
CRITERE1 += ")"

# site
If [M:DIA]MFGFCY <> ""
   CRITERE2 -= '& MFGFCY = "'+[M:DIA]MFGFCY+'"'
Endif

# poste
If [M:DIA]EXTWST <> ""
   CRITERE2 -= '& EXTWST ="'+[M:DIA]EXTWST+'"'
Endif

# date
If [M:DIA]STRDAT<>[0/0/0]
    CRITERE2 -= '& OPESTR>=[M:DIA]STRDAT '
Endif
If [M:DIA]ENDDAT<>[0/0/0]
    CRITERE2-= '& OPEEND<=[M:DIA]ENDDAT'
Endif

# nb exemplaire
If [M:DIA]VARWSTNBR <>0
    CRITERE2 -= '& EXTWSTNBR= [M:DIA]VARWSTNBR'
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif


Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return




#######################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE

Return
#######################################################################
$DEBUT

Default File [OPS]
Default Mask [M:TAP2]

Local Integer WMAX : WMAX = dim([M]MFGNUM)     # llc 04.03 17909

Gosub LIRE
If [M:TAP2]NBLIG=0
    GERR=2 : GMESSAGE=mess(358,197,1)
    FIN=1
Endif

Return
#######################################################################
$LIRE

# X3-25623 - STWIL - Create a flag to hold whether operation is in Production Scheduler
Local Integer OPTIMIZED

Raz [M:TAP2]
nolign=0
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif

[M:TAP2]MFGFCY = [M:DIA]MFGFCY
[M:TAP2]EXTWST = [M:DIA]EXTWST
Call LECTURE("FCY",[M:DIA]MFGFCY,"") From CONTOBJ
[M:TAP2]FCYDES = [F:FCY]FCYNAM

# X3-25623 - STWIL - Link work order header to test if wo is in Production Scheduler
If func AFNC.ACTIV("POPS")
    Link [OPS] With
&      [MFG]MFG0=[OPS]MFGNUM
&   As [OPS_]

    Filter [OPS_] Where evalue (CRITERE1) & evalue (CRITERE2)  & evalue (FORMULE1) Order By OPESTR Asc;OPSNUM Asc
    For  [OPS_]
        [L]OPTIMIZED = 0
        # Check suggestions
        If [M:DIA]OWS=2 & [F:OPS]OPSSTA = 3
            For [ORD] Where WIPTYP = 5 & WIPSTA = 3 & VCRNUM = [F:OPS]MFGNUM
                If [F:ORD]OPTFLG = 2
                    OPTIMIZED = 1
                Endif
                Break
            Next
        # Check work orders
        Elsif [F:MFG]SCDFLG = 4 | [F:MFG]OPTFLG = 2
            OPTIMIZED = 1
        Endif
        If OPTIMIZED = 0
            nolign+=1
            If nolign = WMAX : Break : Endif    # llc 04.03 17909
            Gosub SETGRID
        Endif
    Next

    Filter [OPS_]
Else
    Filter [OPS] Where evalue (CRITERE1) & evalue (CRITERE2)  & evalue (FORMULE1) Order By OPESTR Asc;OPSNUM Asc
    For  [OPS]
        nolign+=1
        If nolign = WMAX : Break : Endif    # llc 04.03 17909
        Gosub SETGRID
    Next

    Filter [OPS]
Endif

[M:TAP2]NBLIG  = nolign

Affzo [M:TAP2]

If nolign = WMAX : Call MESSAGE(mess(168,190,1)) From GESECRAN: Endif   # llc 04.03 17909
Return

# X3-25623 - STWIL - Move the content of the for loop so we do not duplicate code
$SETGRID
  [M:TAP2]TYPORD(nolign-1)     = mess([F:OPS]OPSTYP,351,1) + mess([F:OPS]OPSSTA,342,1)
  [M:TAP2]MFGNUM(nolign-1)     = [F:OPS]MFGNUM
  [M:TAP2]OPSNUM(nolign-1)     = [F:OPS]OPSNUM
  [M:TAP2]OPENUM(nolign-1)     = [F:OPS]OPENUM
  [M:TAP2]OPESTR(nolign-1)     = [F:OPS]OPESTR
  [M:TAP2]OPEEND(nolign-1)     = [F:OPS]OPEEND
  [M:TAP2]EXTWSTNBR(nolign-1)  = [F:OPS]EXTWSTNBR
  [M:TAP2]EXTLABNBR(nolign-1)  = [F:OPS]EXTLABNBR
  [M:TAP2]SETTIM(nolign-1)     = [F:OPS]EXTSETTIM - [F:OPS]CPLSETTIM
  [M:TAP2]OPETIM(nolign-1)     = [F:OPS]EXTOPETIM - [F:OPS]CPLOPETIM
  [M:TAP2]OPEUOM(nolign-1)     = [F:OPS]OPEUOM
  [M:TAP2]QTY(nolign-1)        = [F:OPS]EXTQTY -[F:OPS]CPLQTY
  [M:TAP2]OPSSTA(nolign-1)     = [F:OPS]OPSSTA
Return

#########################################################################
$ENREGISTRE
OK =1
Call OUINON(mess(20,196,1), OK) From GESECRAN
If OK<> 2  : FIN = 0 :  GERR = 2 : Return : Endif
Gosub MODIF
FIN=1
GERR=2
GMESSAGE=mess(363,197,1)

Return

#########################################################################
# Enregistrement des modifications
$MODIF
Call TEMPON("V") From GESECRAN
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
Gosub MODOPS
If !NBOPS
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif

If GOK =1
 Gosub MODMFO
Endif

If GOK = 1
 Gosub MAJJAL
 WMESS1= num$(NBOF) -mess(374,197,1)
 Call ECR_TRACE (WMESS1,0) From GESECRAN
Endif


Call TEMPOFF From GESECRAN
Return

#########################################################################
# Mise à jour table des OP
$MODOPS

# pour copier l'écran dans la trace
Call PRTSCR("TDUCAP1","DIA","",0,1) From ATRTX3
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(464,197,1),0) From GESECRAN

Gosub MAJOPS
If NBOPS
    WMESS1=num$(NBOPS)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif

Return

#########################################################################
$MODMFO
Gosub MAJMFO
WMESS1=num$(NBMFO)-mess(364,197,1)
Call ECR_TRACE (WMESS1,0) From GESECRAN

Return
#########################################################################
#MAJ de la table OPERATIONS
$MAJOPS
NBOPS = 0

Call DEBTRANS From GLOCK
GOK=1
Trbegin [OPS]
    For nolign=1 To [M:TAP2]NBLIG
      If [M:TAP2]FMODIF(nolign-1) =2
        Read [OPS]OPS0 = [M:TAP2]OPSNUM(nolign-1)
        If fstat : Goto NXTOPS2 : Endif
        # pas la peine de modifier si rien n'a changé
        If   [M:TAP2]EXTWSTNBR(nolign-1)  = [F:OPS]EXTWSTNBR &
&          [M:TAP2]EXTLABNBR(nolign-1)  = [F:OPS]EXTLABNBR
            Goto NXTOPS2
        Endif
$NTXOPS1
        WMESS1=mess(169,190,1)-[M:TAP2]MFGFCY+"/"+[M:TAP2]MFGNUM(nolign-1)+"/"+num$([M:TAP2]OPENUM(nolign-1))
        Call ECR_TRACE(WMESS1,0) From GESECRAN
        Readlock [OPS]OPS0 = [M:TAP2]OPSNUM(nolign-1)
        If fstat =1
            GOK =-1 : GLOCK = "$OPERATIONS"+[M:TAP2]OPSNUM(nolign-1)
            Goto ROLL_MODOPS
        Endif
        If fstat
            GOK = 0 : Call RSTA("OPS", [M:TAP2]OPSNUM(nolign-1)) From GLOCK
            Goto AB_MOD
        Endif
        [F:OPS]EXTWSTNBR  = [M:TAP2]EXTWSTNBR(nolign-1)
        If [F:OPS]EXTLAB <>"" : [F:OPS]EXTLABNBR  = [M:TAP2]EXTLABNBR(nolign-1) : Endif
        Rewrite [OPS]
        If fstat
            GOK = 0 : Call FSTA("OPS") From GLOCK
            Goto AB_MOD
        Endif
        NBOPS +=1
      Endif
$NXTOPS2
    Next nolign
If GOK =1 : Commit : Endif

Return

#########################################################################
#MAJ de la table MFGOPE
$MAJMFO

NBMFO=0
GOK=1

Call ECR_TRACE(" ",0)From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(465,197,1),0) From GESECRAN

Call DEBTRANS From GLOCK
GOK=1
Trbegin [MFO]
    For nolign=1 To [M:TAP2]NBLIG
        If [M:TAP2]FMODIF(nolign-1)=2
          For [MFO]MFO0 Where MFGNUM= [M:TAP2]MFGNUM(nolign-1) & OPENUM=[M:TAP2]OPENUM(nolign-1)
            If [F:MFO]OPSNUM = [M:TAP2]OPSNUM(nolign-1)
                # pas la peine de modifier si rien n'a changé
                If  [M:TAP2]EXTWSTNBR(nolign-1)  = [F:MFO]EXTWSTNBR &
&                   [M:TAP2]EXTLABNBR(nolign-1)  = [F:MFO]EXTLABNBR
                    Goto NEXTOF
                Endif
                WMESS1=mess(49,190,1)-[M:TAP2]MFGNUM(nolign-1)+"/"+num$([M:TAP2]OPENUM(nolign-1))
                Call ECR_TRACE(WMESS1,0) From GESECRAN
                Readlock [MFO]MFO0 = [M:TAP2]MFGNUM(nolign-1);[M:TAP2]OPENUM(nolign-1)
                If fstat
                    WCLE= [M:TAP2]MFGNUM(nolign-1)-num$([M:TAP2]OPENUM(nolign-1))-num$([F:MFO]OPESPLNUM)
                    GOK = 0 : Call RSTA("MFO", WCLE ) From GLOCK
                    Goto AB_MOD
                Endif
                [F:MFO]EXTWSTNBR  = [M:TAP2]EXTWSTNBR(nolign-1)
                If [F:MFO]EXTLAB<>"" : [F:MFO]EXTLABNBR  = [M:TAP2]EXTLABNBR(nolign-1) : Endif
                Rewrite [MFO]
                If fstat
                    GOK = 0 : Call FSTA("MFO") From GLOCK
                    Goto AB_MOD
                Endif
                NBMFO +=1
            Endif
          $NEXTOF
          Next
        Endif
    Next nolign
If GOK =1 : Commit : Endif


Return


#########################################################################
$MAJJAL

NBOF= 0
Call ECR_TRACE(" ",0)From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(466,197,1),0) From GESECRAN

#Déjalonnement
Raz [M:JALK]
For nolign=1 To [M:TAP2]NBLIG
 If [M:TAP2]FMODIF(nolign-1)=1 : Goto NEXTSTATION : Endif

 [M:JALK]CODORI =1
 [M:JALK]CODMAJ =0
 [M:JALK]CODTRS =1
 [M:JALK]MFGFCY = [M:TAP2]MFGFCY
 [M:JALK]MFGNUM = [M:TAP2]MFGNUM(nolign-1)
 [M:JALK]MFGSTA = [M:TAP2]OPSSTA(nolign-1)
 Call DEJALONNE From JALLIBA
 If [M:JALK]CODRET <> 0 : Call ERREUR(mess(78,193,1)) From GESECRAN :  Return : Endif

$NEXTSTATION
Next nolign


# Rejalonnement
For nolign=1 To [M:TAP2]NBLIG
 If [M:TAP2]FMODIF(nolign-1)=1 : Goto NEXTSTATION2 : Endif

 [M:JALK]CODORI =1
 [M:JALK]CODMAJ =0
 [M:JALK]CODTRS =3
 [M:JALK]MFGFCY = [M:TAP2]MFGFCY
 [M:JALK]MFGNUM = [M:TAP2]MFGNUM(nolign-1)
 [M:JALK]MFGSTA = [M:TAP2]OPSSTA(nolign-1)
 # llc 12.02 16779
 If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
     Read [PJA]PJA0=[M:JALK]MFGFCY
     If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
 Endif

 WMESS1=mess(373,197,1)-num$([M:TAP2]MFGNUM(nolign-1))
 Call ECR_TRACE(WMESS1,0) From GESECRAN

 Call JALONNE From JALLIB
 # Issue 111414 - 2016-01-22 by CCC : continue process for next WO even if current WO failed
 #If [M:JALK]CODRET <> 0 : Break : Endif
 If [M:JALK]CODRET <> 0 : WERR=1 : Endif

 NBOF += 1

$NEXTSTATION2
Next nolign
# Issue 111414 - 2016-01-22 by CCC
#If [M:JALK]CODRET <> 0 : Call ERREUR(mess(78,193,1)) From GESECRAN : Return : Endif
If WERR : Call ERREUR(mess(78,193,1)) From GESECRAN : Return : Endif

Return
#########################################################################
$ROLL_MODOPS
Rollback
Call ROLL From GLOCK
If GROLL
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : End
Else : Goto MAJOPS : Endif


#########################################################################
$AB_MOD
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

#########################################################################
$ABORT

Raz [M:TAP2]
Affzo [M:TAP2]
Gosub LIRE
Return

#########################################################################
$FIN
If dim(FORMULE1)>0 : Kill  FORMULE1  : Endif
#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3

Return

########################################################################
# mm 12.02
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################



########################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If [M:DIA]STRDAT=[0/0/0] : [M:DIA]ENDDAT= VALEUR  : Endif
If [M:DIA]ENDDAT< VALEUR : [M:DIA]ENDDAT = VALEUR : Endif
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

If VALEUR < [M:DIA]STRDAT : GERR=1 :  mkstat=2 : GMESSAGE = mess(44,199,1) : Endif
End


########################################
Subprog C_OWF(VALEUR)
Variable Integer VALEUR

If VALEUR<>2 & [M:DIA]OWS <>2 & [M:DIA]OWP<>2
  GERR=1 : mkstat=2 : GMESSAGE = mess(83,123,1)
Endif

End


########################################
Subprog C_EXTWSTNBR(VALEUR)
Variable Decimal VALEUR

Read [OPS]OPS0 = [M:TAP2]OPSNUM(nolign-1)
If fstat : GERR=1 : GMESSAGE = mess(297,196,1) : End : Endif

If VALEUR =0 : GERR=1 : mkstat = 2 : GMESSAGE = mess(201,193,1): End: Endif
If [M:TAP2]FMODIF(nolign-1)<>2
    If (VALEUR <> [F:OPS]EXTWSTNBR) | ([M:TAP2]EXTLABNBR(nolign-1)<> [F:OPS]EXTLABNBR)
        [M:TAP2]FMODIF(nolign-1) = 2 : Endif
Endif
Affzo [M:TAP2]FMODIF(nolign-1)

End

########################################
Subprog AV_EXTLABNBR(VALEUR)
Variable Decimal VALEUR

# Seuls les postes MA peuvent avoir un poste MO
Read [OPS]OPS0 = [M:TAP2]OPSNUM(nolign-1)
If  [F:OPS]EXTWSTTYP <>1  : mkstat =2 : Endif

End


########################################
Subprog AS_FMODIF(VALEUR)
Variable Integer VALEUR
Read [OPS]OPS0 = [M:TAP2]OPSNUM(nolign-1)
If fstat : GERR=1 : GMESSAGE = mess(297,196,1) : End : Endif

# si le nombre d'exempl. a été modifié, on interdit de décocher la case
If ([M:TAP2]EXTWSTNBR(nolign-1) <> [F:OPS]EXTWSTNBR) |([M:TAP2]EXTLABNBR(nolign-1) <> [F:OPS]EXTLABNBR)
   mkstat=2 : GERR=1 : GMESSAGE =mess(170,190,1)
Endif

End

########################################
Subprog C_EXTLABNBR(VALEUR)
Variable Decimal VALEUR
Read [OPS]OPS0 = [M:TAP2]OPSNUM(nolign-1)
If fstat : GERR=1 : GMESSAGE = mess(297,196,1) : End : Endif

If [M:TAP2]FMODIF(nolign-1)<>2
    If (VALEUR <> [F:OPS]EXTLABNBR) | ([M:TAP2]EXTWSTNBR(nolign-1)<>[F:OPS]EXTWSTNBR)
        [M:TAP2]FMODIF(nolign-1) = 2 : Endif
Endif
Affzo [M:TAP2]FMODIF(nolign-1)

End

########################################
Subprog C_VARWSTNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR =0 : GERR=1 : mkstat = 2 : GMESSAGE = mess(201,193,1): End: Endif
End

########################################
# mm 12.02
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY
    GFCY=VALEUR
    Gosub CHARG_PARAM
Endif
End





