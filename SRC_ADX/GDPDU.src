#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*


#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "INIT"        : Gosub INIT From GDPDU1
        When "EXEC"        : Gosub EXEC
        When "SORTIE"      : Gosub CLEANUP From GDPDU1
        When Default
    Endcase
Return


#** #####################################################################################
#*
#* Sub chunk:  EXEC
#*
#* Purpose:    Handler for the OK button. Does some checking and executes the GDPdU export.
#*
#*
#*! #####################################################################################

$EXEC
    Gosub GETDATAFROMSCREEN
    Gosub CREATEINDEXXML From GDPDU1
Return


#** #####################################################################################
#*
#* Sub chunk:  GETDATAFROMSCREEN
#*
#* Purpose:    Get the data from the dialog window and setup the export parameters.
#*
#*! #####################################################################################

$GETDATAFROMSCREEN
    EXPORTDIR  = [M]NAMEXP                # Export directory (on the server!)
    EXPORTCPY  = [M]CPY                   # Company
    EXPDATSTR  = [M]DATSTR                # Export start date
    EXPDATEND  = [M]DATEND                # Export end date
    FLGFINANCE = [M]FLGFINANCE - 1        # Flag: Export fincance data?
    FLGHISTDAT = [M]FLGHISTDAT  - 1       # Flag: Export historical data?
    FLGFA      = [M]FLGFA - 1             # Flag: Export fixed asset data?
    FLGANACC   = [M]FLGANACC - 1          # Flag: Export analytical accounting data?
    TYPEXP     = [M]TYPEXP                # Selector: Export to server (2) or client (1)

    # Add possible missing directory separator to the export path.
    If right$( EXPORTDIR, len( EXPORTDIR ) ) <> DIRSEP
        EXPORTDIR += DIRSEP
    Endif
Return



# ############################################################################################# #
# ##########                                                                                    #
# ########## Screen/Window handling                                                             #
# ##########                                                                                    #
# ##########                                                                                    #
# ##########                                                                                    #
# ############################################################################################# #


# ############################################################################################# #
# ##########                                                                                    #
# ########## Check that module FIXED ASSETS is activated. Otherwise grey the FA option.         #
# ##########                                                                                    #
# ############################################################################################# #

Subprog AV_FLGFA(VALEUR)
Variable Integer VALEUR

    # Check GMODU(14) for the presence of the FA module and gray the corresponding
    # checkbox otherwise.
    If !( GMODU(14) - 1 ) : Grizo [M]FLGFA : Endif
End


# ############################################################################################# #
# ##########                                                                                    #
# ########## Warn that exporting historical open items will lead to a much longer export time.  #
# ##########                                                                                    #
# ############################################################################################# #

Subprog AM_FLGHISTDAT(VALEUR)
Variable Integer VALEUR

    Local Libelle RETC : RETC = 2                # Return code of the warning box

    If VALEUR = 2                                # Checkbox checked?
        Wrnbox mess(179,121,1) Using RETC        # Display a warning message.
        Case RETC
            When 1       :                       # OK button pressed: Let the checkbox be checked.
            When Default : VALEUR = 1            # Reset the checkbox to unchecked.
        Endcase
    Endif
End


# ############################################################################################# #
# ##########                                                                                    #
# ########## Make sure that begin date is before end date.                                      #

# ##########                                                                                    #
# ############################################################################################# #

Subprog AM_DATSTR(VALEUR)
Variable Date VALEUR

  If VALEUR > [M]DATEND
      GMESSAGE= mess(33,177,1) # "The start date of the period is greater than the end date of the period."
      mkstat = 2
      End
  Endif
End


# ############################################################################################# #
# ##########                                                                                    #
# ########## Make sure that begin date is before end date.                                      #

# ##########                                                                                    #
# ############################################################################################# #

Subprog AM_DATEND(VALEUR)
Variable Date VALEUR

  If [M]DATSTR > VALEUR
      GMESSAGE= mess(34,177,1) # "The end date of the period is less than the start date of the period."
      mkstat = 2
      End
  Endif
End


# ############################################################################################# #
# ##########                                                                                    #
# ########## Update path information according to the client/server setting.                    #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

    If GBATCH and ( VALEUR = 1 )
        GMESSAGE = mess(163,141,1)  # 'The client workstation is not accessible in batch mode'
        mkstat = 2
    Endif
End


# ############################################################################################# #
# ##########                                                                                    #
# ########## Update path information according to the client/server setting.                    #
# ##########                                                                                    #
# ############################################################################################# #

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

    [M]VOLEXP = "[TMP]"
    [M]NAMEXP = func ASYRSTO.GETFULLPATH( [M]VOLEXP, "" )
    If VALEUR = 1 # Client
        Call SET_NAMCLI( [M]NAMEXP ) From ORDSYS
        Affzo [M]NAMEXP, VOLEXP
        Grizo [M]VOLEXP
    Else # Server
        Actzo [M]VOLEXP
        Affzo [M]NAMEXP, VOLEXP
    Endif
End


# ############################################################################################# #
# ##########                                                                                    #
# ########## Handle automatic volumne --> file/directory name conversion.                       #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_VOLEXP(VALEUR)
Variable Char VALEUR()

    Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
    mkstat = func ASYRSTO.CTL_VOLFIL( [M]TYPEXP, VALEUR, [M]NAMEXP, E_TYPE_FOLDER, GMESSAGE )
    Affzo [M]NAMEXP
End

