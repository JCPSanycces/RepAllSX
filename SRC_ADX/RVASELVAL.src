#<AdxTL>@(#)11.0.0.0 $Revision$
################################################################################
#    GESTION DES SELECTIONS POUR LA SAISIE DES VALEURS DES ASSOCIATIONS
#    MDR
#    Création le : 06/2003
#    Modification le : 06/2003
#    MDJ - 19.03.2014  (FQ 95899)  Listes des coeff.actualisation en fonction du paramétrage (par défaut/société)
#    CBO - 29.04.2014  (FQ 69690)  Objet FAM
#    MDJ - 12.07.2013  (FQ 89249)  Sélection s/famille en fonction législation
#    MDJ - 11.06.2009  (FQ 54343)  Provisions pour renouvellement (ajout associations pour concessions)
#-------------------------------------------------------------------------------
#    ****  SELECTION DANS LISTE *****
#
#    RVALLST2  Liste des valeurs des rubriques déterminées (type de donnée M)
#              + zones libres.
#
#    ****  SELECTION DANS TABLE ******
#
#    RVALTAB   Liste des familles comptables ou codes comptables ou organismes
#              pour la valeur du déterminant
#    RVALTAB2  Liste des Comptes et des codes comptables pour la valeur
#              des rubriques déterminées
#
#-------------------------------------------------------------------------------

$ACTION
Case ACTION
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "CHX_TABLE"   : Gosub CHX_TABLE
Endcase
Return

#-------------------------------------------------------------------------------
$SEL_LISTE
Case LISTE
  When "RVALLST2"    :   Gosub RVALLST2
Endcase
Return

#-------------------------------------------------------------------------------
$SEL_TABLE
Case TABLE
  When "RVALTAB"     :   Gosub RVALTAB
  When "RVALTAB2"    :   Gosub RVALTAB2
Endcase
Return

#-------------------------------------------------------------------------------
$CHX_TABLE
Case TABLE
 When "RVALTAB"     :   Gosub TIT_VALTAB
Endcase
Return

#---------------------------------------------------------------------------------------------
# RVALLST2 : sélection des différentes valeurs des rubriques déterminées
#            dans les menus locaux correspondants
#---------------------------------------------------------------------------------------------
$RVALLST2

Local Integer J, NOLIB, NBTEX
J=99

NOLIB=0

# Récupération du n° de menu local associé à la rubrique déterminée
# Ce numéro est stocké dans la table diverse 951

Read[ADI]CODE=GTD_ASSORUB; [M]RUBRAS(nolign-1)
If fstat=0
  If [F:ADI]N2<> 0
    NOLIB=[F:ADI]N2
    [M:RVA1]NOLIB(nolign-1)=[F:ADI]N2
  Endif
Endif

If left$([M]RUBRAS(nolign-1),7)= "USRFLDA"
  J=val(right$([M]RUBRAS(nolign-1),8))
  J-=1
Endif

If NOLIB > 0
  TIT = mess(NOLIB,0,1)
  NBTEX = len(mess(0,NOLIB,1))
  For I=1 To NBTEX
    TEX(I) = num$(I)
    TEXTE(I) = mess(I,NOLIB,1)
  Next I

Endif

#*-----------------------------------------------------------------------
#* Recherche de la table associée à chacune des zones libres
#* + récupération du n° de menu local pour chaque rubrique déterminée
#* hors zones libres
#*------------------------------------------------------------------------
If J < 99 Gosub RECH_ALPHA
Endif
#*FQ95899 déplacé depuis RVALTAB2 dans RVALLST2 et adapté
# Liste des codes actualisation en fonction du niveau de paramétrage de l'association
If [M]RUBRAS(nolign-1) = "CCNACTCOD"

   If clalev([F:COE])=0    : Local File = "CCNCOE" [COE]   :  Endif # Paramétrage Coeff. actualisation
   If clalev([F:COEB])=0   : Local File = "CCNCOE" [COEB]  :  Endif # Paramétrage Coeff. actualisation

   Local Char TEX(30)(1..nbrecord([F:COE])), TEXTE(GLONDES)(1..nbrecord([F:COE]),1..100)
   Local Char TIT(GLONDES)(0..5)
   Local Integer NBTEX
   Local Char    LCPY
   Local Char    WCCNACTCOD
   Local Integer I
   LCPY=[M]CPY # Société
   I = 0
   For [COE]COE0 Where (CPY=LCPY or CPY="")
      If [F:COE]CPY ="" and LCPY<> ""
         Read[COEB]COE0= LCPY;[F:COE]CCNACTCOD
         If fstat
            I += 1
            TEX(I)   =   [F:COE]CCNACTCOD
            TEXTE(I,2) =  [F:COE]DES1
            TEXTE(I,3) =  num$([F:COE]CCNACTCOE)
            TEXTE(I,4) = mess(923 ,GML_MSGFAS,1)  # Param. défaut
         Endif
      Else
         I += 1
         TEX(I)   = [F:COE]CCNACTCOD
         TEXTE(I,2) =  [F:COE]DES1
         TEXTE(I,3) =  num$([F:COE]CCNACTCOE)
         If [F:COE]CPY <> ""
            TEXTE(I,4) = [F:COE]CPY
         Else
            TEXTE(I,4) = mess(923 ,GML_MSGFAS,1)  # Param. défaut
         Endif
      Endif
   Next

    NBTEX = I

   TIT(0) = mess(922,GML_MSGFAS,1)  # Liste des codes actualisation
   TIT(1) = mess(37,100,1)          # Code
   TIT(2) = mess(251,GML_MSGFAS,1)  # Désignation
   TIT(3) = mess(511,GML_MSGFAS,1)  # Coefficient
   TIT(4) = mess(143,GML_MSGFAS,1)  # Société

Endif

Return
#*-----------------------------------------------------------------------------------------------
#* Recherche dans la table FREFLD du n° de table diverse associée à chacune des zones libres
#* puis récupération des libellés dans cette table diverse
#*-----------------------------------------------------------------------------------------------
$RECH_ALPHA

Local Integer NBTEX
Local Char  LNUMTAB
Local Integer I
I = 0

Read [FRF]FRF0 = [M:RVA1]REFOBJ;[M:RVA1]CPY
If fstat<>0
  Read [FRF]FRF0 = [M:RVA1]REFOBJ;""
Endif
If [F:FRF]ALPREF(J)>0
    LNUMTAB =num$([F:FRF]ALPREF(J))
    CODE=[M:RVA1]VALDETEAS(nolign-1)
    Filter [ADI] Where [F:ADI]NUMTAB = [F:FRF]ALPREF(J) Order By [F:ADI]CODE Asc
     For [ADI]
       I += 1
       If I >= dim(TEX) - 1
             Break
       Endif
       TEX(I) = [F:ADI]CODE
       IDENT2  = [F:ADI]CODE
           Call LECTEXTRA (TEXTE(I),"ATABDIV","LNGDES",LNUMTAB,IDENT2) From ATEXTRA
           TEXTE(I) = format$("Kbn:15X",TEX(I))+ " "+ TEXTE(I)
     Next
     TIT = mess(45,7770,1)-LNUMTAB
    Filter [ADI]
Endif

    NBTEX = I
Return

#---------------------------------------------------------------------------------------------
# RVALTAB : sélection saisie valeur de déterminant
#           PARAM(1) contient la rubrique déterminante
#---------------------------------------------------------------------------------------------
$RVALTAB
Local Integer PDETAAS
PDETAAS=val(PARAM(1))
Case PDETAAS
  When GVML_DTACCO
    OBJET = "CAC"
    CRITERE = "TYP = GVML_COGIMMO & COA="+"GCOAR"
  #FQ69690 faut-il mettre GFY et LEG dans CRITERE ?
  When GVML_DTAFAM
    OBJET = "FAM"
    CRITERE = ""
#  When GVML_DTAFAM
#    PARAM(1)=num$(GTD_FAMCPT)
#    PARAM(2) = ""
#    PARAM(3) = [M]LEG
#    If [M]CPY <> ""
#       GSOCIETE = [M]CPY
#    Else
#        #FQ-89249  GSOCIETE = [M]LEG
#        GCURLEG = [M]LEG
#    Endif
#    Gosub SELADI From SUBADI
  When GVML_DTAORG
    PARAM(1)="617"
    PARAM(2)=""
    Gosub SELADI From SUBADI
Endcase
PARAM(1)=num$(PDETAAS)
Return

$TIT_VALTAB
# Pour écraser le titre "Choix table diverse" donné par le modèle
 Case PDETAAS
   When GVML_DTAFAM, GVML_DTAORG
     TIT = mess(12,123,1)-mess(PDETAAS,3113,1) : # Choix Famille comptable ou Choix Organisme
   When Default
 Endcase
Return

#----------------------------------------------------------------------------------------------------
# RVALTAB2 : sélection - des comptes comptables de la table GACCCOUNT
#                      - des  codes comptables de la table GACCCODE
#                      - des  codes actualisation de la table CCNCOE #*Fq-54343
#           pour le choix des  valeurs des déterminés
#---------------------------------------------------------------------------------------------------
$RVALTAB2

 If [M]RUBRAS(nolign-1) = "GAC" or [M]RUBRAS(nolign-1) = "IASACC"
    OBJET = "GAC"
    Case [M]RUBRAS(nolign-1)
      When "GAC"
        If find("GACACN",[M]RUBRAS(0..nolign-1)) & [M]VALDETEAS(find("GACACN",[M]RUBRAS(0..nolign-1))-1) <> ""
          CRITERE = "COA="+"GCOAR"
          CRITERE -= "& GACACN="+[M]VALDETEAS(find("GACACN",[M]RUBRAS(0..nolign-1))-1)
        Endif
      When "IASACC"
        If find("IASACN",[M]RUBRAS(0..nolign-1)) & [M]VALDETEAS(find("IASACN",[M]RUBRAS(0..nolign-1))-1) <> ""
          CRITERE = "COA ="+"GCOARIAS"
          CRITERE -= "& GACACN="+[M]VALDETEAS(find("IASACN",[M]RUBRAS(0..nolign-1))-1)
        Endif
    Endcase
 Endif

 If [M]RUBRAS(nolign-1) = "ACCCOD"
    OBJET = "CAC"
    CRITERE = "TYP = GVML_COGIMMO & COA="+"GCOAR"
 Endif
 #*Fq-54343
#FQ95899 #*FQ95899 déplacé dans RVALLST2 et adapté
# If [M]RUBRAS(nolign-1) = "CCNACTCOD"
##

#  LCPY=[M]CPY # Société
#
# # ******  Description de la table
#  Local Char CODFIC  : CODFIC = "CCNCOE" : # Séléction sur table

# Default File [COE]

#
#  DEFPAG = 1
#
#  # ******  Description de la table
#  # ...................
#  CRITERE = "CPY='"+LCPY+"' or CPY=''"      : # Critères de sélection
#  ORDRE = "CCNACTCOD"   : # Clause order by
#  TIT(0)  = mess(691,GML_MSGFAS,1) : # Liste des codes actualisation
#  SIZLIG  = 80              : # Défaut 80  (10 lig en 8eme de ligne)
#  SIZCOL  = 240             : # Défaut 240 (60 col en quart de colonne)
#  NBCOL   = 0
#  NBCOL  += 1 : COL(NBCOL) = "CCNACTCOD"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
#  NBCOL  += 1 : COL(NBCOL) = "CPY"           : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
#  NBCOL  += 1 : COL(NBCOL) = "DES1"          : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
#  NBCOL  += 1 : COL(NBCOL) = "CCNACTCOE"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
#  START   = "CCNACTCOD"     : # Colonne à récupérer suite au choix
#Endif #FQ95899 END


Return
