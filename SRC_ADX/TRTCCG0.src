#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque CANCELCCG0
#
#                         T R T C C G 0
#          Annulation de l'engagement en prod d'un OF complet / d'une phase
#          Etape préalable à l'annulation d'une pesée
#
#########################################################################################

#########################################################################################
# Fonction Annulation l'engagement           pesée           GPAO                     #
# Paramètre général l'engagement permet 2 valeurs : "1: Par OF"; "2: Par Phase"       #
#                                                                                       #
# LFCY  = Site de production: "" = tous sites                                           #
#########################################################################################


$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When Default
Endcase
Return


#########################################################
$OUVRE

# Ouverture des fichiers utilisés
If clalev([F:MFG])  <= 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  <= 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:WGG])  <= 0 : Local File WEIGHING    [WGG]  : Endif


Return

#########################################################
$SETBOUT


If ![M:CCG0]NBLIG
  ETABOU(GSPE1) = 0
Elsif [M:CCG0]NBLIG
  ETABOU(GSPE1) = 1
Endif

Return

#########################################################
$AVANT_BOUTON
Local Integer OK

Case BOUT
     When "a" : If [M:CCG0]NBLIG =0 : Return : Endif
                If [M:CCG0]NBLIG <> [M:CCG0]WCPTENR
                  GMESSAGE  = mess(66,2324,1)+num$([M:CCG0]WCPTENR-[M:CCG0]NBLIG)
                  GERR = 1
                  Return
                Endif
Endcase

Return

#########################################################
$BOUTON
Case BOUT
     When "a": Gosub TRT_ANNULER
     When "b": Gosub TRT_ABANDON
     When Default
Endcase
Return

#########################################################
$TRT_ABANDON
Raz [M:CCG0]
Affzo [M:CCG0]
Return

#########################################################
$TRT_ANNULER
Local Integer I

# Petit message de confirmation avant de tout annuler
OK=1
Call OUINON(mess( 67,2324,1),OK) From GESECRAN
If OK= 1
  Call MESSAGE (mess(68,2324,1)) From GESECRAN
  Return
Endif

# MAJ [WGG]
#  lecture historique
If [M:CCG0]NBLIG <> 0
  Call DEBTRANS From GLOCK
  Trbegin [WGG]

    For I=0 To [M:CCG0]NBLIG-1
          Readlock [WGG]WGG0 = [M:CCG0]MFGNUM;[M:CCG0]BOMOPE(I);[M:CCG0]ITMREF(I);[M:CCG0]MFGLIN(I);[M:CCG0]BOMSEQ(I);[M:CCG0]CBTDAT(I);[M:CCG0]MVTSEQ(I)
          If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-[M:CCG0]MFGNUM : Gosub TRT_ROLL : Break
          Elsif fstat GOK=0  : Call RSTA("WGG",[M:CCG0]MFGNUM) From GLOCK :  Gosub TRT_ROLL : Break
          Endif

          [F:WGG]ENGCOD = 1
          [F:WGG]ENGDAT = [0/0/0]
          [F:WGG]ENGDATSUP = date$
          [F:WGG]ENGUSRSUP = GUSER
          [F:WGG]ENGTIMSUP =  mid$(time$,1,2)+mid$(time$,4,2)
          Rewrite [F:WGG]
          If fstat
             GOK = 0 : Call FSTA("WGG") From GLOCK : Break                                        # FQ 69909 Ctrl des sources avant Return
          Endif
     Next I

    Commit
    Gosub MAJ_MFM
    Raz [M:CCG0]
    Affzo  [M:CCG0]
    ACTION = "SETBOUT" : Gosub ACTION
Endif
Return

#########################################################
$MAJ_MFM

Call DEBTRANS From GLOCK
Trbegin [MFM]

# MAJ [MFM]
For [MFM]MFM0 Where MFGFCY = [M:CCG0]MFGFCY     &
&                   MFGNUM = [M:CCG0]MFGNUM     &
&                   MATSTA <> 4                 &
&                   WGGSTA = 7                  &
&                   find([F:MFM]PKC,2,4,6)      &
&    ([V]GENGAGE<>2 | BOMOPE = [M:CCG0]BOMOPE0)

      Readlock [F:MFM] Curr
      If fstat=1     GOK=-1 : GLOCK="$MFM"- [M:CCG0]MFGNUM : Gosub  TRT_ROLL : Break            # FQ 69909 Ctrl des sources avant Return
      Elsif fstat GOK=0  : Call RSTA("MFM", [M:CCG0]MFGNUM) From GLOCK : Gosub TRT_ROLL : Break # FQ 69909 Ctrl des sources avant Return
      Endif
      WOK = 0
      For [WGG]WGG0 Where MFGNUM = [M:CCG0]MFGNUM     &
&                         MFGLIN = [F:MFM]MFGLIN      &
&                         ITMREF = [F:MFM]ITMREF      &
&                         BOMSEQ = [F:MFM]BOMSEQ      &
&                         BOMOPE = [F:MFM]BOMOPE      &
&                         WEIWEI <> 0                 &
&                         WEIFLG <> 4                 &
&                         WEIFLG <> 5

         If [F:WGG]RCLCOD =  2 &  [F:WGG]RCLDAT <> [0/0/0] : WOK = 1 : Break : Endif                     # 04.02
      Next

      If WOK = 1
          [F:MFM]WGGSTA = 5     # réconciliée
      Else
          [F:MFM]WGGSTA = 3     # pesée
      Endif
      Rewrite [F:MFM]
      If fstat       GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub TRT_ROLL : Break         # FQ 69909 Ctrl des sources avant Return
      Endif
Next

Commit
Gosub MAJ_ENTETE

Return

#########################################################
$MAJ_ENTETE

Call DEBTRANS From GLOCK
Trbegin [MFG]


WOK =0
# l'ensemble des matières doit être réconcilié pour  que le statut de l'entête = réconcilié.
# sinon =  fin de pesée
For [MFM]MFM0 Where  MFGFCY = [M:CCG0]MFGFCY     &
&                    MFGNUM = [M:CCG0]MFGNUM     &
&                    MATSTA <> 4                 &
&                    find([F:MFM]PKC,2,4,6)

    WOK = 0
    If [F:MFM]WGGSTA <> 5 : WOK = 9 : Break : Endif
Next
# statut de l'entête = fin de pesée
If WOK = 9
   Call MAJ_FICHIERS ("MFG",5,8,[M:CCG0]MFGNUM,"",0,0) From SCALEXCHAN
Else
# statut de l'entête = réconcilié
  Call MAJ_FICHIERS ("MFG",6,8,[M:CCG0]MFGNUM,"",0,0) From SCALEXCHAN
Endif

If GOK < 1  Gosub  TRT_ROLL
Else Commit
      Call MESSAGE (mess(65,2324,1)) From GESECRAN
Endif

Return
#########################################################
$TRT_ROLL
Rollback
Return


######################################################################################
## Check value of MFGFCY
######################################################################################
# Issue 104011 - 2015-02-24 by FRHOL : The value entered was only checked if the value changes. It has to be checked always.
Subprog C_MFGFCY(VALEUR)
Variable Char    VALEUR()

  # Read Parameter ENGAGE
  Local Char VALPAR(20)
  Call PARAM(VALEUR,"ENGAGE",[L]VALPAR) From ADOVAL
  [V]GENGAGE = val([L]VALPAR)

  If  [V]GENGAGE=2
    Actzo[M:CCG0]BOMOPE0
  Else
    Raz[M:CCG0]BOMOPE0
    Grizo[M:CCG0]BOMOPE0
  Endif

  # Engage = par pesée -> annulation impossible
  If  [V]GENGAGE=3 :
    GMESSAGE = mess(69,2324,1)
    GERR =2 : mkstat = 2 : End
  Endif

End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CANCELCCG0) 02/07/2013 15:31:38 (MM)
######################################################################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M:CCG0]MFGNUM : End : Endif

Read [MFG]MFG0 = VALEUR
If !fstat
 [M:CCG0]WGGSTA = [F:MFG]WGGSTA
 [M:CCG0]WGGFLG = [F:MFG]WGGFLG
Endif
Affzo [M:CCG0]WGGSTA,WGGFLG
Gosub ETI_MFGNUM
End

######################################################################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()

Raz [M:CCG0]BOMOPE0
Raz [M:CCG0]NBLIG
Affzo BOMOPE0
Affzo [M:CCG0]15
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CANCELCCG0) 02/07/2013 15:32:57 (MM)
######################################################################################
Subprog AS_BOMOPE0(VALEUR)
Variable Decimal VALEUR

If [M:CCG0]NBLIG>0
   Grizo[M:CCG0]BOMOPE0
Else
   Actzo[M:CCG0]BOMOPE0
Endif

End

######################################################################################
Subprog C_BOMOPE0(VALEUR)
Variable Decimal VALEUR

If [V]GENGAGE=2 & VALEUR=0
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
    End
Endif
Gosub ETI_BOMOPE
End


######################################################################################
#       sous prog ETIQUETTES
######################################################################################
$ETI_MFGNUM

Read [MFG]MFG0 = VALEUR
If fstat :             GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]MFGSTA = 4 : GMESSAGE = mess(114,193,1) : GERR =2 : mkstat = 2 : Return : Endif

If [V]GENGAGE = 1
  For [MFM]MFM0 Where MFGFCY = [M:CCG0]MFGFCY    &
&                   MFGNUM = VALEUR             &
&                   MATSTA <> 4                 &
&                   find([F:MFM]PKC,2,4,6)
      WOK = 1
      If [F:MFM]WGGSTA <> 7 : WOK = 6 : Break : Endif
  Next
  If WOK =6  GMESSAGE = mess(70,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
Endif

[M:CCG0]MFGNUM = VALEUR
Gosub CALCUL_NBPESEE
If [M:CCG0]WCPTENR > dim([M:CCG0]ITMREF)
    GMESSAGE = mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:CCG0]MFGNUM
Endif

Return

#####################################################################################
$CALCUL_NBPESEE

Raz [M:CCG0]WCPTENR
For [WGG]WGG0 Where MFGNUM = [M:CCG0]MFGNUM         &
&                   WEIWEI <> 0                     &
&                   CCLDAT = [0/0/0]                &
&                   ENGCOD =  2                     &
&                   ENGDAT <> [0/0/0]               &
&                   WEIFLG <> 4                     &
&                   WEIFLG <> 5                     &
&                   find([F:WGG]PKC,2,4,6)          &
&   ([V]GENGAGE=2 & (BOMOPE = [M:CCG0]BOMOPE0)|([V]GENGAGE<>2 & [M:CCG0]BOMOPE0=0))
  [M:CCG0]WCPTENR +=1
Next
Affzo  [M:CCG0]WCPTENR
Return

######################################################################################
$ETI_BOMOPE

# Réconciliation par phase

WOK = 0
If [V]GENGAGE=2
  For [MFM]MFM0 Where MFGFCY = [M:CCG0]MFGFCY     &
&                       MFGNUM = [M:CCG0]MFGNUM     &
&                       BOMOPE = VALEUR             &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
     WOK = 1
     If [F:MFM]WGGSTA <>  7 : WOK = 6 : Break : Endif
  Next

  If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
  If WOK = 6  GMESSAGE = mess(71,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

Endif

[M:CCG0]BOMOPE0 = VALEUR
Gosub CALCUL_NBPESEE
If [M:CCG0]WCPTENR > dim([M:CCG0]ITMREF)
    GMESSAGE = mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:CCG0]MFGNUM
Endif

Return

#####################################################################################
$ETI_MFGTRKNUM
Local Integer NOL   : [L]NOL=nolign-1


Filter[F:WGG]  Where  MFGNUM    = [M:CCG0]MFGNUM             &
&                            FCY=[M:CCG0]MFGFCY              &
&                            MFGTRKNUM = VALEUR              &
&                            WEIWEI    <> 0                  &
&                            CCLDAT    = [0/0/0]             &
&                            ENGDAT    <> [0/0/0]            &
&                            WEIFLG    <> 4                  &
&                            WEIFLG    <> 5                  &
&                            find([F:WGG]PKC,2,4,6)          &
&   ([V]GENGAGE<>2 | BOMOPE = [M:CCG0]BOMOPE0)

 Read[F:WGG]WGG0 First
    If !fstat
      [M:CCG0]ITMREF(NOL) = [F:WGG]ITMREF
      [M:CCG0]BOMOPE(NOL) = [F:WGG]BOMOPE
      [M:CCG0]LOT(NOL)    = [F:WGG]LOT
      [M:CCG0]WEIWEI(NOL) = [F:WGG]WEIWEI
      [M:CCG0]WEU(NOL)    = [F:WGG]WEU
      Affzo[M:CCG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)

      If [M:CCG0]SAISIE(NOL)=1 : # Par n° de pesée
        [M:CCG0]MFGLIN(NOL) = [F:WGG]MFGLIN
        [M:CCG0]BOMSEQ(NOL) = [F:WGG]BOMSEQ
        [M:CCG0]CBTDAT(NOL) = [F:WGG]CBTDAT
        [M:CCG0]MVTSEQ(NOL) = [F:WGG]MVTSEQ
        Affzo[M:CCG0]MFGLIN(NOL),BOMSEQ(NOL),CBTDAT(NOL),MVTSEQ(NOL)
      Endif
      Grizo [M:CCG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    Else
       GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
    Endif
Filter[F:WGG]

Return


#####################################################################################
$ETI_LOT

If [M:CCG0]SAISIE(nolign-1)=1 : # Par pesée
   Return
Endif
#
GOK =1
# saisie détail
Raz[M:CCG0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)

For [WGG]WGG0 Where MFGNUM = [M:CCG0]MFGNUM               &
&                   BOMOPE = [M:CCG0]BOMOPE(nolign-1)     &
&                   WEIWEI <> 0                 &
&                   ITMREF = [M:CCG0]ITMREF(nolign-1)     &
&                   LOT    = VALEUR             &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD =  2                 &
&                   RCLDAT <> [0/0/0]           &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5
    Read[F:WGG]WGG0 First
    If !fstat
       [M:CCG0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
       [M:CCG0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
       [M:CCG0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
       [M:CCG0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
       [M:CCG0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM
       [M:CCG0]WEU(nolign-1)        = [F:WGG]WEU
       Affzo[M:CCG0]15
       GOK=0 : Break
    Endif
Next
If !GOK : Return : Endif

GMESSAGE = mess(16,2324,1) : VALEUR = ""
Return

######################################################################################
$ETI_WEIWEI
Raz[M:CCG0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)
GOK =1

For [WGG]WGG0 Where MFGNUM = [M:CCG0]MFGNUM               &
&                   BOMOPE = [M:CCG0]BOMOPE(nolign-1)     &
&                   ITMREF = [M:CCG0]ITMREF(nolign-1)     &
&                   LOT    = [M:CCG0]LOT(nolign-1)        &
&                   WEIWEI = VALEUR             &
&                   CCLDAT = [0/0/0]            &
&                   ENGCOD =  2                 &
&                   ENGDAT <> [0/0/0]           &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5
    Read[F:WGG]WGG0 First
    If !fstat
      [M:CCG0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
      [M:CCG0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
      [M:CCG0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
      [M:CCG0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
      [M:CCG0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM
      Affzo[M:CCG0]15
      GOK=0 : Break
    Endif
Next
If !GOK : Return : Endif

GMESSAGE = mess(16,2324,1) : Raz VALEUR
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran CANCELCCG0) 05/07/2013 09:11:39 (MM)
######################################################################################
Subprog AM_SAISIE(VALEUR)
Variable Integer VALEUR
Local Integer NOL   : [L]NOL=nolign-1
# saisie par n° de pesée
If VALEUR=1
    Raz[M:CCG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
Else
# saisie détaillée
    Raz[M:CCG0]MFGTRKNUM(NOL)
    Actzo[M:CCG0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    zonsui = "ITMREF(" + num$(NOL) + ")"
Endif
End

######################################################################################
Subprog C_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
Local Integer K
Local Integer NOL : [L]NOL=nolign-1

If [M:CCG0]SAISIE(NOL)=1 & VALEUR=""
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
Else
  If [M:CCG0]NBLIG<>0 & VALEUR<>""
    For K=0 To [M:CCG0]NBLIG-1
      If K<>[L]NOL & ([M:CCG0]MFGTRKNUM(K)=VALEUR |[M:CCG0]MFGTRKNUM1(K)= VALEUR  )
        GMESSAGE = mess(43,2324,1)+num$([L]K+1) : GERR =2 : mkstat = 2 : Break
      Endif
    Next
  Endif
Endif

End

######################################################################################
Subprog AM_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
Gosub ETI_MFGTRKNUM
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CANCELCCG0) 05/07/2013 15:58:19 (MM)
######################################################################################
Subprog AS_BOMOPE(VALEUR)
Variable Decimal VALEUR
If [M:CCG0]BOMOPE0<>0
    VALEUR = [M:CCG0]BOMOPE0
Endif
End

Subprog C_BOMOPE(VALEUR)
Variable Decimal VALEUR
If [V]GENGAGE=2 & VALEUR <> [M:CCG0]BOMOPE0
    GMESSAGE = mess(6,2324,1)  : GERR =2 : mkstat = 2
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran CANCELCCG0) 05/07/2013 16:07:53 (MM)
######################################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Gosub ETI_LOT
If VALEUR = "" : GERR =2 : mkstat = 2 : End : Endif
[M:CCG0]LOT(nolign-1) = VALEUR
Affzo  [M:CCG0]LOT(nolign-1)
End

Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
Affzo  [M:CCG0]WEIWEI(nolign-1)
Affzo  [M:CCG0]WEU(nolign-1)
End

Subprog C_WEIWEI(VALEUR)
Variable Decimal VALEUR
Gosub ETI_WEIWEI
If !VALEUR : GERR =2 : mkstat = 2 : End : Endif
[M:CCG0]WEIWEI(nolign-1) = VALEUR
Affzo  [M:CCG0]WEIWEI(nolign-1)
End

Subprog AM_WEIWEI(VALEUR)
Variable Decimal VALEUR
End
