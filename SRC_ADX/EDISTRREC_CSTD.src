#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Classe EDISTRREC                                                            #
# Author : RBA                                                                #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When "EMSG"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EMSG_ADDLINE_AFTER
      Endcase
    When "EINS"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EINS_ADDLINE_AFTER
      Endcase
    When "EFIL"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EFIL_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_RECEIPT_INIT"               : Gosub MET_RECEIPT_INIT
    When "MET_RECEIPT_CREATE_FLOW_LIST"   : Gosub MET_RECEIPT_CREATE_FLOW_LIST
    When "MET_RECEIPT_DECODE_FILES"       : Gosub MET_RECEIPT_DECODE_FILES
    When "MET_RECEIPT_PROCESS"            : Gosub MET_RECEIPT_PROCESS
    When "MET_RECEIPT_LOG_RESUME"         : Gosub MET_RECEIPT_LOG_RESUME
    When "MET_RECEIPT_IMPORT_FILES"       : Gosub MET_RECEIPT_IMPORT_FILES
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "FLOCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub FLOCOD_PROPAGATE
      Endcase
    When "FLOREL"
      Case [L]ARULE
        When "PROPAGATE" : Gosub FLOREL_PROPAGATE
      Endcase
    When "PTCCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PTCCOD_PROPAGATE
      Endcase
    When "EMSG.MSGCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EMSG_MSGCOD_PROPAGATE
      Endcase
    When "EMSG.MSGREL"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EMSG_MSGREL_PROPAGATE
      Endcase
    When "EMSG.MSGFILNOR"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EMSG_MSGFILNOR_PROPAGATE
      Endcase
  Endcase
Return

###################################################################

$FLOCOD_PROPAGATE
  If this.FLOCOD <> "" and this.FLOREL <> ""
    Gosub GET_FLOW_PROPERTIES
  Endif
Return

###################################################################

$FLOREL_PROPAGATE
  If this.FLOCOD <> "" and this.FLOREL <> ""
    Gosub GET_FLOW_PROPERTIES
  Endif
Return

###################################################################

$PTCCOD_PROPAGATE
  If this.PTCCOD <> ""
    Local File EDIPTC [EPT]
    Read [F:EPT]EPT0 = this.PTCCOD
    If !fstat
      this.PTC_UUID = [EPT]CACHEUUID
      this.IMPORTPATH = func EDIPTC_CSTD.GET_IMPORTPATH(this.PTCCOD)
    Else
      this.PTC_UUID = NullUuid()
      this.IMPORTPATH = ""
    Endif
    LogicClose File [EPT]
  Endif
Return

###################################################################

$EMSG_MSGCOD_PROPAGATE
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Gosub GET_MSG_PROPERTIES
  Endif
Return

###################################################################

$EMSG_MSGREL_PROPAGATE
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Gosub GET_MSG_PROPERTIES
  Endif
Return

###################################################################

$EMSG_MSGFILNOR_PROPAGATE
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Gosub GET_MSG_PROPERTIES
  Endif
Return

###################################################################

$GET_FLOW_PROPERTIES
#flow properties
  Local File EDIFLO [EFL]
  Read [F:EFL]EFL0 = this.FLOCOD;this.FLOREL
  If !fstat
    this.FLO_UUID = [EFL]CACHEUUID
    this.PTCCOD   = [EFL]PTCCOD
    this.CATTYP   = [EFL]CATTYP
  Else
    this.FLO_UUID = NullUuid()
    this.PTCCOD   = ""
    this.CATTYP   = 0
  Endif
  LogicClose File [EFL]

  Local Integer WPOS
  #rev RBA
  Local Integer WPOSMSG
  Local File EDIFLOD [EFLD]
  Filter [EFLD] Where FLOCOD =  this.FLOCOD and FLOREL = this.FLOREL
  For [EFLD]
    WPOS = fmet this.ADDLINE("EMSG", [V]CST_ALASTPOS)
    this.EMSG(WPOS).MSGCOD    = [EFLD]MSGCOD
    this.EMSG(WPOS).MSGREL    = [EFLD]MSGREL
    this.EMSG(WPOS).MSGFILNOR = [EFLD]MSGFILNOR
    this.EMSG(WPOS).MSGTYP    = [EFLD]MSGTYP
    this.EMSG(WPOS).MSGFOR    = [EFLD]MSGFOR  ##112148

    If this.EMSG(WPOS).MSGFOR =1   ## 112148
      Local File EDISEQFIL [ESF]
      Read [F:ESF]ESF0 = [EFLD]MSGCOD;[EFLD]MSGREL;[EFLD]MSGFILNOR
      If !fstat
        this.EMSG(WPOS).SEQ_UUID = [ESF]CACHEUUID
      Else
       this.EMSG(WPOS).SEQ_UUID  = NullUuid()
      Endif
      LogicClose File [ESF]
    Else    ## Ini 112148
      Local File EDIXMLFIL [EXF]
      Read [F:EXF]EXF0 = [EFLD]MSGCOD;[EFLD]MSGREL;[EFLD]MSGFILNOR
      If !fstat
        this.EMSG(WPOS).SEQ_UUID = [EXF]CACHEUUID
      Else
        this.EMSG(WPOS).SEQ_UUID = NullUuid()
      Endif
      LogicClose File [EXF]
    Endif   ## End 112148

    Local File EDIMSGA [EMSA]
    Filter [EMSA] Where MSGCOD = [EFLD]MSGCOD and MSGREL = [EFLD]MSGREL
    For [EMSA]
      Call DELETELINES(this.EMSG(WPOS), "EKEY") From EDILIBA
      Local File EDICATREF [ECR]    #110811 US11

      If this.CATTYP=1 and this.CATCOD="FACTURAER"
        this.CATTRGTAB="PINVOICE"
      Endif

      Read[ECR]ECR0=this.CATTYP;this.CATTRGTAB
      If fstat=[V]CST_AOK
        If [EMSA]CODE=[F:ECR]AUTCOD1:WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS)
          this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = [F:ECR]AUTCOD1 : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
        Endif
        If [EMSA]CODE=[F:ECR]AUTCOD2:WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS)
          this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = [F:ECR]AUTCOD2 : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
         Endif
        If [EMSA]CODE=[F:ECR]AUTCOD3:WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS)
          this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = [F:ECR]AUTCOD3 : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
        Endif
        If [EMSA]CODE=[F:ECR]AUTCOD4:WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS)
          this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = [F:ECR]AUTCOD4 : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
        Endif
        If [EMSA]CODE=[F:ECR]AUTCOD5:WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS)
          this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = [F:ECR]AUTCOD5 : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
        Endif
      Else    #110811 US11
        Case [EMSA]CODE
          When "FCY"    : WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = "FCY"    : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
          When "BPANUM" : WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = "BPANUM" : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
          When "BPAADD" : WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = "BPAADD" : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
#          When "CPY"    : WPOSMSG = fmet this.EMSG(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_COD = "CPY"    : this.EMSG(WPOS).EKEY(WPOSMSG).KEY_FLD = [EMSA]CODPRO
# #SAM 114061
        Endcase
      Endif
      LogicClose File [ECR]   #110811 US11
    Next
  Next
  LogicClose File [EFLD]
Return

###################################################################

$GET_MSG_PROPERTIES
  Local File EDIMSG [EMS]
  Read [F:EMS]EMS0 = this.MSGCOD;this.MSGREL
  If !fstat
    this.MSG_UUID  = [EMS]CACHEUUID
    this.REPCOD    = [EMS]REPCOD
    this.FLGMUXIMP = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "FLGMUXIMP")
  Else
    this.MSG_UUID  = NullUuid()
    this.REPCOD    = ""
    this.FLGMUXIMP = [V]CST_ANO
  Endif
  LogicClose File [EMS]

  If this.FLGMUXIMP=0: this.FLGMUXIMP=1: Endif    # to be sure the parameter value
Return

###################################################################

$EMSG_ADDLINE_AFTER
  this.NUMBATCH  = this.APARENT.NUMBATCH
  this.FLO_UUID  = this.APARENT.FLO_UUID
Return

###################################################################

$EINS_ADDLINE_AFTER
  this.NUMBATCH  = this.APARENT.NUMBATCH
  this.FLO_UUID  = this.APARENT.FLO_UUID
Return

###################################################################

$EFIL_ADDLINE_AFTER
  this.NUMBATCH = this.APARENT.NUMBATCH
  this.FLO_UUID = this.APARENT.FLO_UUID
Return




#********************************************************************
# Method MET_RECEIPT_INIT
#********************************************************************
#
#* @param WNUMBATCH
#* @param WEDIRUN
#* @return WOK
#*!
$MET_RECEIPT_INIT
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  this.NUMBATCH  = WNUMBATCH
  this.X3FOLDER  = [S]nomap
  this.CATTYP    = fmet WEDIRUN.ACTX.ACACHE.ECA.AGETVALNUM(WEDIRUN.CATCOD,"CATTYP")
  this.CATTRGTAB = fmet WEDIRUN.ACTX.ACACHE.ECA.AGETVALCHAR(WEDIRUN.CATCOD,"CATTRGTAB")
  this.PARCOD    = WEDIRUN.PARCOD
  this.CATCOD    = WEDIRUN.CATCOD
  this.ALLFLO    = WEDIRUN.ALLFLO

  ARET_VALUE = WRET_VALUE
Return


#********************************************************************
# Method MET_RECEIPT_CREATE_FLOW_LIST
#********************************************************************
#
#* @param WFLOCOD_TAB
#* @param WFLOREL_TAB
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_RECEIPT_CREATE_FLOW_LIST
  Local File EDITMPDOC [ETC] #Issue X3-7673 - 2017-09-06 by RBA - CRUD
  Trbegin [ETC]
    Delete [ETC] Where CREUSR=WEDIRUN.ACTX.USER
  Commit
  LogicClose File [ETC]

  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer I, WNBFLOW
  this.NBFLOW = 0

  WOK = fmet WMYLOG.APUTLINE(mess(34,2007,1)-":",[V]CST_AINFO) #"Recovering flows properties
  Call ASYNCTRACK(WEDIRUN.ACTX, "(1)", mess(34,2007,1), 10) From ASYRASYNC #Recovering flows properties

  If WEDIRUN.ALLFLO = 2
    Local File EDIPARTNERD [EPRD]
    Filter [EPRD] Where [EPRD]PARCOD = WEDIRUN.PARCOD and [EPRD]CATCOD = WEDIRUN.CATCOD and [EPRD]CATACT = WEDIRUN.CATACT
    For [EPRD]
      If func EDIRUN_CSTD.TEST_EDIFLO([EPRD]FLOCOD, [EPRD]FLOREL) = [V]CST_AINFO
        this.NBFLOW = this.NBFLOW + 1
        WFLOCOD_TAB(this.NBFLOW) = [EPRD]FLOCOD
        WFLOREL_TAB(this.NBFLOW) = [EPRD]FLOREL
        #"Valid and active flow"
        WERR = mess(99,2006,1)-":"-[EPRD]FLOCOD+"~"+[EPRD]FLOREL
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
      Endif
    Next
    Filter [EPRD]
    LogicClose File [EPRD]
  Else
    If func EDIRUN_CSTD.TEST_EDIFLO(WEDIRUN.FLOCOD, WEDIRUN.FLOREL) = [V]CST_AINFO
      this.NBFLOW = this.NBFLOW + 1
      WFLOCOD_TAB(this.NBFLOW)   = WEDIRUN.FLOCOD
      WFLOREL_TAB(this.NBFLOW)   = WEDIRUN.FLOREL
      #"Valid and active flow"
      WERR = mess(99,2006,1)-":"-WEDIRUN.FLOCOD+"~"+WEDIRUN.FLOREL
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    Else
      #"Invalid flow"
      WERR = mess(41,2006,1)-":"-WEDIRUN.FLOCOD+"~"+WEDIRUN.FLOREL
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    Endif
  Endif

  #"Number of valid and active flows found"
  WERR = mess(53,2007,1)-":"-num$(this.NBFLOW)
  If this.NBFLOW = 0
    Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
  Else
    Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Endif
#Issue 110811 US9
  WNBFLOW=func EDIRUN_CSTD.CHECK_AUTHORIZATION(this.ACTX.USER,this.CATCOD)

  If WNBFLOW=0
    WERR = mess(74,100,1)    #Unauthorized Function
    Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    this.NBFLOW=0
  Endif
#/Issue 110811 US9

  If this.NBFLOW > 0
    WRET_VALUE = [V]CST_AOK
  Else
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return


#********************************************************************
# Method MET_RECEIPT_DECODE_FILES
#********************************************************************
#
#*
#* @param WPOS_MSG
#* @param WPROTOTYPE_JSON
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_RECEIPT_DECODE_FILES
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WOK
  Local Integer I, J
  Local Char WERR(250)

  Local Clbfile WRESHEAD
  Local Clbfile WRESBODY
  Local Clbfile WARGUMENTS(4)
  Local Clbfile WOPTION(4)
  Local Integer WSTATUSCODE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WMOVEEND(5) : WMOVEEND = func GET_MOVEEND(this.PTCCOD)

  If this.EMSG(WPOS_MSG).REPCOD <> ""
    Local Instance WMYREP Using ="R_"+this.EMSG(WPOS_MSG).REPCOD
    WMYREP = NewInstance With ="R_"+this.EMSG(WPOS_MSG).REPCOD
    Call ASYNCTRACK(WEDIRUN.ACTX, "(2)", mess(37,2007,1), 30) From ASYRASYNC #generation liste doc a traiter
    WOK = func ASYREIP.EXPORT_PROTOTYPE(WMYREP, [V]CST_AFAC_DETAILS, WPROTOTYPE_JSON, WERR)
    If WOK = [V]CST_AOK
      If this.EMSG(WPOS_MSG).MSGFOR=1     ## 112148
        WOPTION ='{'+
&             '  "messageMapping" : "'+num$(this.EMSG(WPOS_MSG).MSG_UUID)+'",'+
&             '  "sequentialFile" : "'+num$(this.EMSG(WPOS_MSG).SEQ_UUID)+'",'+
&             '  "protocol" : "'+num$(this.PTC_UUID)+'",'+
&             '  "flow" : "'+num$(this.FLO_UUID)+'",'+
&             '  "repName" : "'+num$(this.EMSG(WPOS_MSG).REPCOD)+'",'+
&             '  "prototype" : '+WPROTOTYPE_JSON+','+
&             '  "folder" : "'+this.X3FOLDER+'",'+
&             '  "keepCache" : true,'+
&             '  "moveEnd" : '+WMOVEEND+
&             '}'
      Else                ## Ini 112148
        WOPTION ='{'+
&             '  "messageMapping" : "'+num$(this.EMSG(WPOS_MSG).MSG_UUID)+'",'+
&             '  "xmlFile" : "'+num$(this.EMSG(WPOS_MSG).SEQ_UUID)+'",'+
&             '  "protocol" : "'+num$(this.PTC_UUID)+'",'+
&             '  "flow" : "'+num$(this.FLO_UUID)+'",'+
&             '  "repName" : "'+num$(this.EMSG(WPOS_MSG).REPCOD)+'",'+
&             '  "prototype" : '+WPROTOTYPE_JSON+','+
&             '  "folder" : "'+this.X3FOLDER+'",'+
&             '  "keepCache" : true,'+
&             '  "moveEnd" : '+WMOVEEND+
&             '}'

      Endif               ## End 112148

     WARGUMENTS = '"'+this.NUMBATCH+'",'+WOPTION
     #Issue 112470 - 2015-11-12 by RBA - renaming JS module
     WSTATUSCODE = func ASYRWEBSER.EXEC_JS("syracuse-edi/lib/edi_Process", "decodeEdiFiles", "wait", WARGUMENTS,  "0,0", 0, "", "0", WRESHEAD, WRESBODY)
     #/Issue 112470

     #INI X3-70672 Error volume management EDI (JUCON 01/03/2018)
     If WRESBODY <>""
       Local Integer WFPOS, WLFPOS, WNPOS, WNBFILES, WSEQ
       # checking the number of the files
       WFPOS=1
       Repeat
       WFPOS=instr(WFPOS,WRESBODY,"destination")
       If WFPOS>0:  WNBFILES+=1: WFPOS+=1: Endif
       Until WFPOS=0
       If WNBFILES>0
         # reading the file names
         Local Char WINIFILE(250)(1..WNBFILES), WERRFILE(250)(1..WNBFILES), WERRDIR(250)(1..WNBFILES) , WSEP(1),  WMERR(250)

         For K=1 To WNBFILES
           WFPOS=1
           If K>1: WFPOS=WFLPOS: Endif
           WFPOS=instr(WFPOS,WRESBODY,"destination")
           If WFPOS<>0
             WSEP=seg$(WRESBODY,WFPOS+14,WFPOS+15)
             If WSEP<>"/" or WSEP <>"\"  #X3-111531 EDI destination error in windows environment (JUCON 03/10/18)
               WSEP=seg$(WRESBODY,WFPOS+16,WFPOS+17)
             Endif
             WFLPOS=instr(WFPOS+14,WRESBODY,"filename")
             If WFLPOS<>0
               WINIFILE(K)=seg$(WRESBODY,WFPOS+14, WFLPOS-4)
               WSEQ = fmet this.ADDLINE('EFILERR',[V]CST_ALASTPOS)
               this.EFILERR(K).FILEORI=WINIFILE(K)
             Endif
             Repeat
               WFPOS=WNPOS+1
               WFPOS=instr(WFPOS,WINIFILE(K),WSEP)
               If WFPOS<>0: WNPOS=WFPOS: WFPOS+=1: Endif
             Until WFPOS=0
             WERRFILE(K)=seg$(WINIFILE(K),WNPOS+1,len(WINIFILE(K)))+"_err"
             Local File EDIPTCD [PTCD]
             Read [PTCD]EPTD0=this.PTCCOD;4
             If fstat=[V]CST_AOK
               If [F:PTCD]PTCLINVAL<>""
                 WERRDIR(K)=[F:PTCD]PTCLINVAL+WSEP+WERRFILE(K)
                 this.EFILERR(K).FILERROR=WERRDIR(K)
               Endif
             Endif
             LogicClose File [PTCD]
           Endif
         Next
       Endif
       #END X3-70672 Error volume management EDI (JUCON 01/03/2018)

       #INI X3_70673_Improvement_in_error_messages_management_EDI (JUCON 16/03/2018)
       Local Integer WMPOS, WLMPOS, WNPOS, WNBMSG, WSEQ
       # checking the number of the messages
#       WNPOS=1
       Repeat
       Raz WMPOS
       WMPOS=instr(WNPOS,WRESBODY,"$message")
       If WMPOS>0:  WNBMSG+=1: WNPOS=WMPOS+11: Endif
       Until WMPOS=0
       If WNBMSG>0
       # reading the messages
        Local Char WINMSG(250)(1..WNBMSG), WERRSTA(50)(1..WNBMSG), WMERR(250), WUUID(250)
        Local Integer WSTA
        WUUID=seg$(WRESBODY,11,46)
        For K=1 To WNBMSG
          WMPOS=1
          If K>1: WMPOS=WMLPOS: Endif
          WMPOS=instr(WMPOS,WRESBODY,"message")
          If WMPOS<>0
            WMLPOS=instr(WMPOS+11,WRESBODY,'"')
            WINMSG(WNBMSG) =seg$(WRESBODY,WMPOS+10,WMLPOS-1)
            WMPOS=WMLPOS
            WMLPOS=instr(WMPOS,WRESBODY,"}")
            WERRSTA(WNBMSG)=seg$(WRESBODY,WMPOS+15,WMLPOS-2)
            #sending message to monitor and trace
            WERR = WINMSG(WNBMSG)
            If WERRSTA(WNBMSG)="warning"
              WSTA = [V]CST_AWARNING
#              WOK = func EDISTO_CSTD.SAS_INSERT_ERROR_JS(this.NUMBATCH, WDOCID_TAB(I), WSTA, WERR, WSTA, WUUID, WMYLOG)
            Endif
            Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,WSTA) From ASYRASYNC
            WOK = fmet WMYLOG.APUTLINE(WERR,WSTA)
          Endif
##          Raz WSTA
        Next
      Endif
      #INI X3_70673_IMPROVEMENT_IN_ERROR_MESSAGES_MANAGEMENT_EDI (JUCON 16/03/2018)
    Endif

    If WSTATUSCODE=200    ## 112148
      Local Char WRES_JSON_ID_TAB(36)(1..)      # to recover the JSON
      Local Char WRES_JSON_EXTID_TAB(36)(1..)      # to recover the JSON
      Local Char WRES_UUID_TAB(36)(1..)         # to recover the UUID
      Local Integer WRES_STA_TAB(1..)           # to recover the status list created
      Local Char WRES_JSON_ERR(250)              # to recover the error message

      If WERR<>""   #X3-89940 Warning message in SAS (JUCON 04/05/18)
        WRES_STA_TAB(1)=WSTA
        WRES_JSON_ERR=WERR
      Endif         #X3-89940 Warning message in SAS (JUCON 04/05/18)

      WOK = func EDILIBB.PARSE_JS_DECODE_EDI_FILES(WSTATUSCODE, WRESHEAD, WRESBODY, this.NUMBATCH, WRES_JSON_ID_TAB,WRES_JSON_EXTID_TAB, WRES_UUID_TAB, WRES_STA_TAB, WMYLOG, WRES_JSON_ERR)

      If WOK = [V]CST_AOK or WOK =[V]CST_AWARNING  #X3-89940 Warning message in SAS (JUCON 04/05/18)
        Local File EDITMPDOC [ETC]

        For J = 1 To maxtab(WRES_JSON_ID_TAB())
          Trbegin [ETC]
          [ETC]NUMBATCH    = this.NUMBATCH
           If WRES_JSON_EXTID_TAB(J)="" and WEDIRUN.PARCOD="FACTURAE"    # 112148
            [ETC]DOCID    = WRES_JSON_ID_TAB(J)  # 112148
          Else
            [ETC]DOCID       = WRES_JSON_EXTID_TAB(J)
          Endif
          [ETC]CATACT      = 2 #receive
          [ETC]EXTDOCID    = WRES_JSON_ID_TAB(J)
          [ETC]UUID_JSON   = WRES_UUID_TAB(J)
          [ETC]UUID_PTC    = num$(this.PTC_UUID)
          [ETC]UUID_FLO    = num$(this.FLO_UUID)
          [ETC]UUID_MSG    = num$(this.EMSG(WPOS_MSG).MSG_UUID)
          [ETC]UUID_SEQ    = num$(this.EMSG(WPOS_MSG).SEQ_UUID)
          [ETC]REP_ID      = this.EMSG(WPOS_MSG).REPCOD
          [ETC]CATTYP      = this.CATTYP
          [ETC]FLOCOD      = this.FLOCOD
          [ETC]FLOREL      = this.FLOREL
          [ETC]FOLDERX3    = this.X3FOLDER
          [ETC]PATH        = this.IMPORTPATH
          [ETC]FLGVALIDDOC = WRES_STA_TAB(J)
          [ETC]MSGCOD      = this.EMSG(WPOS_MSG).MSGCOD
          [ETC]MSGREL      = this.EMSG(WPOS_MSG).MSGREL
          [ETC]MSGFILNOR   = this.EMSG(WPOS_MSG).MSGFILNOR
          [ETC]FLGMUXIMP   = this.EMSG(WPOS_MSG).FLGMUXIMP
          [ETC]CREUSR      = this.ACTX.USER # X3-86941: Creusr of EDITMPDOC is not fed
          Write [ETC]
          If !fstat
            Commit
          Else
            #"Insertion into temporary log : failed"
            WERR = mess(38,2007,1)-":"-mess(9,2007,1)
#            ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AERROR)
            Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
            WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
            WRET_VALUE = [V]CST_AERROR #sur ?
            Rollback
          Endif
        Next J
        LogicClose File [ETC]
      Else
        #"Decoding : failed"
        WERR = mess(35,2007,1)-":"-mess(9,2007,1)+"."-WRES_JSON_ERR
        Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AWARNING) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
        WRET_VALUE = [V]CST_AERROR
      Endif
    Else  ## Ini 112148 message when WSTATUSCODE<>200
      #"Decoding : failed"
      Local Integer WPOS, WFIN
      Local Char WJSERR(250)

      WERR = mess(35,2007,1)-":"-mess(9,2007,1)+"."  # Decoding failed
      If this.EMSG(WPOS_MSG).MSGFOR=2 and WRESHEAD=""
        WERR =WERR+ "."-mess(184,2006,1)  ## XML mapping validation error
      Endif
      WPOS=instr(35,WRESHEAD,"Error:")
      If WPOS<>0
        WFIN=instr(WPOS,WRESHEAD,",")
        If WFIN>WPOS
          WJSERR=seg$(WRESHEAD,WPOS,WFIN-2)
        Else
          WPOS=instr(35,WRESHEAD,",")
          WJSERR=seg$(WRESHEAD,32,WPOS-2)
        Endif
        WERR = WERR+"."- WJSERR
      Else
        WPOS=instr(35,WRESHEAD,",")
        WERR = WERR+"."- seg$(WRESHEAD,32,WPOS-2)
      Endif
      Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AWARNING) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
      WRET_VALUE = [V]CST_AERROR
    Endif  ## End 112148
  Else
      #"Generating prototype : failed"
      WERR = mess(36,2007,1)-":"-mess(9,2007,1)-"["+WERR+"]"
      Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AWARNING) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
      WRET_VALUE = [V]CST_AERROR
    Endif
    FreeGroup WMYREP : WMYREP = null
  Endif

  ARET_VALUE = WRET_VALUE
Return



#********************************************************************
# Method MET_RECEIPT_IMPORT_FILES
#********************************************************************
#
#*
#* @param WPOS_MSG
#* @param WDOCID_TAB
#* @param WSTEP
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_RECEIPT_IMPORT_FILES
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)
  #get files and doc id to import
  Local Integer I, J, K, L
  Local Char WIMP_FILE_TAB(100)(1..)  #file name
  Local Char WIMP_DOCID_TAB(100)(1..) #doc
  Local Char WIMP_EXT_TAB(100)(1..)   #model import

  Call ASYNCTRACK(WEDIRUN.ACTX, "(4)", mess(20,2017,1), 60) From ASYRASYNC #'Génération du fichier d'import EDI'

  J = 0
  K = 0
  Local File EDISTOU [ESTU]
  For I = 1 To maxtab(WDOCID_TAB)
    Filter [ESTU] Where NUMBATCH = this.NUMBATCH and KEYDOC = WDOCID_TAB(I) and [ESTU]CODE = "PHYFILE"+num$(WPOS_MSG)
    For [ESTU]
      J = J + 1
      WIMP_DOCID_TAB(J) = WDOCID_TAB(I)
      WIMP_FILE_TAB(J)  = [ESTU]DOCKEY
    Next
    J = maxtab(WIMP_EXT_TAB())
    Filter [ESTU]
    Filter [ESTU] Where NUMBATCH = this.NUMBATCH and KEYDOC = WDOCID_TAB(I) and [ESTU]CODE = "EDIMSG"+num$(WPOS_MSG)
    For [ESTU]
      J = J + 1
      For K = 1 To len([ESTU]DOCKEY)
        If mid$([ESTU]DOCKEY, K, 1) = "~"
          WIMP_EXT_TAB(J) = fmet this.ACTX.ACACHE.EMS.AGETVALCHAR(left$([ESTU]DOCKEY,K-1), right$([ESTU]DOCKEY,K+1),"MSGTPL")
          Break
        Endif
      Next K
    Next

  Next I
  LogicClose File [ESTU]

  Local Char WERR_TAB(250)(1..)
#  #create paramteres for import
  Local Char WPAR_IMP_DIR(250)  : WPAR_IMP_DIR = this.IMPORTPATH
  Local Char WPAR_NUMBATCH(250) : WPAR_NUMBATCH = this.NUMBATCH
  Local Integer WPAR_CATTYP : WPAR_CATTYP = this.CATTYP
  Local Char WPAR_IMP_EXT_TAB(100)(1..)   #model import
  J = 0
  For I = 1 To maxtab(WIMP_EXT_TAB)
    If !find(WIMP_EXT_TAB(I), WPAR_IMP_EXT_TAB())
      J = J +1
      WPAR_IMP_EXT_TAB(J) = WIMP_EXT_TAB(I)
    Endif
  Next I
  K = 0
  WRET_VALUE = func EDI_BATCH_IMPORT_PREPARE(WPAR_NUMBATCH, WIMP_DOCID_TAB, WPAR_CATTYP, WPAR_IMP_DIR, WPAR_IMP_EXT_TAB(1), WIMP_FILE_TAB, WERR_TAB, WEDIRUN.TESTFLG, WSTEP, WEDIRUN, WMYLOG)
  For L = 1 To maxtab(WERR_TAB)
    WOK = fmet WMYLOG.APUTLINE(WERR_TAB(L),[V]CST_AINFO)
  Next L

  ARET_VALUE = WRET_VALUE
Return


#********************************************************************
# Method MET_RECEIPT_LOG_RESUME
#********************************************************************
#
#*
#* @param WDOCID_TAB
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_RECEIPT_LOG_RESUME
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)
  Local Integer WOK
  Local Integer WNBLEFT
  Local Integer WNBRIGHT

  Local Integer WFLG_IMPORT : WFLG_IMPORT = [V]CST_AFALSE
   For I = 1 To maxtab(this.EINS)
     If this.EINS(I)<>null and find(this.EINS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and this.EINS(I).MSGTYP = 1 #Query
      Local File EDIMSGD [EMSD]#detail fichier d'import]
      Filter [EMSD] Where MSGCOD = this.EINS(I).MSGCOD and MSGREL = this.EINS(I).MSGREL
      For [EMSD]
        WFLG_IMPORT = [V]CST_ATRUE
        Break
      Next
      Filter [EMSD]
      LogicClose File [EMSD]
    Endif
  Next

  Call ASYNCTRACK(WEDIRUN.ACTX, "(5)", mess(50,2006,1), 80) From ASYRASYNC #log

  WERR = " "+mess(28,2007,1)+" " #Processing the document list
  WNBLEFT = abs((115-len(WERR))/2)
  WNBRIGHT = 115-len(WERR)-WNBLEFT
  WOK = fmet WMYLOG.APUTLINE(string$(WNBLEFT,"-")+WERR+string$(WNBRIGHT,"-"),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)

  WOK = fmet WEDIRUN.MET_LOG_DUMP(this.NUMBATCH, WDOCID_TAB(), WMYLOG)

  WERR = " "+mess(27,2007,1)+" " #Summary of global process
  WNBLEFT = abs((115-len(WERR))/2)
  WNBRIGHT = 115-len(WERR)-WNBLEFT
  WOK = fmet WMYLOG.APUTLINE(string$(WNBLEFT,"-")+WERR+string$(WNBRIGHT,"-"),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)

#"Number of document successfully saved in storage space :"
  WERR = format$("4X","")+format$("60X",mess(49,2007,1))+" : "+num$(this.NBSAS_OK)+"/"+num$(this.NBSAS_OK+this.NBSAS_KO)
  If this.NBSAS_OK = 0
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Else
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Endif

  #"Number of document successfully saved in Mongo :"
  If this.NBENT_OK + this.NBENT_KO = 0
    WERR = format$("4X","")+format$("60X",mess(48,2007,1))+" : "+num$(0)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Elsif this.NBENT_OK = 0 and this.NBENT_KO <> 0
    WERR = format$("4X","")+format$("60X",mess(48,2007,1))+" : "+num$(this.NBENT_OK)+"/"+num$(this.NBENT_OK + this.NBENT_KO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Elsif this.NBENT_OK <> 0 and this.NBENT_KO = 0
    WERR = format$("4X","")+format$("60X",mess(48,2007,1))+" : "+num$(this.NBENT_OK)+"/"+num$(this.NBENT_OK + this.NBENT_KO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Else
    WERR = format$("4X","")+format$("60X",mess(48,2007,1))+" : "+num$(this.NBENT_OK)+"/"+num$(this.NBENT_OK + this.NBENT_KO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
  Endif

  Local Integer WCRUD_SUCCESS : WCRUD_SUCCESS = [V]CST_AFALSE

  #"Number of document successfully instantiated :"
  If this.NBINS_OK + this.NBINS_KO = 0
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(0)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    WCRUD_SUCCESS = [V]CST_ATRUE
  Elsif this.NBINS_OK = 0 and this.NBINS_KO <> 0
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(this.NBINS_OK)+"/"+num$(this.NBINS_OK + this.NBINS_KO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Elsif this.NBINS_OK <> 0 and this.NBINS_KO = 0
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(this.NBINS_OK)+"/"+num$(this.NBINS_OK + this.NBINS_KO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    WCRUD_SUCCESS = [V]CST_ATRUE
  Else
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(this.NBENT_OK)+"/"+num$(this.NBINS_OK + this.NBINS_KO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
  Endif

  Local Integer WIMPORT_SUCCESS : WIMPORT_SUCCESS = [V]CST_AFALSE

  #only for Importation, not for CRUD
  If WFLG_IMPORT = [V]CST_ATRUE  #Issue X3-7673 - 2017-09-06 by RBA - CRUD
  #  #"Number of document successfully generated in import file :"
    If this.NBFIL_IMP_OK + this.NBFIL_IMP_KO = 0
      WERR = format$("4X","")+format$("60X",mess(44,2007,1))+" : "+num$(0)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
      WIMPORT_SUCCESS = [V]CST_ATRUE
    Elsif this.NBFIL_IMP_OK = 0 and this.NBFIL_IMP_KO <> 0
      WERR = format$("4X","")+format$("60X",mess(44,2007,1))+" : "+num$(this.NBFIL_IMP_OK)+"/"+num$(this.NBFIL_IMP_OK + this.NBFIL_IMP_KO)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
    Elsif this.NBFIL_IMP_OK <> 0 and this.NBFIL_IMP_KO = 0
      WERR = format$("4X","")+format$("60X",mess(44,2007,1))+" : "+num$(this.NBFIL_IMP_OK)+"/"+num$(this.NBFIL_IMP_OK + this.NBFIL_IMP_KO)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
      WIMPORT_SUCCESS = [V]CST_ATRUE
    Else
      WERR = format$("4X","")+format$("60X",mess(44,2007,1))+" : "+num$(this.NBFIL_IMP_OK)+"/"+num$(this.NBFIL_IMP_OK + this.NBFIL_IMP_KO)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
    Endif
  Endif

  Local Integer WSUCCESS : WSUCCESS = [V]CST_AFALSE

  #Issue X3-7673 - 2017-09-06 by RBA - CRUD
  If WEDIRUN.TESTFLG = [V]CST_AYES
    If WIMPORT_SUCCESS = [V]CST_ATRUE # and (WFLG_IMPORT = [V]CST_ATRUE and WIMPORT_SUCCESS = [V]CST_ATRUE) or (WFLG_IMPORT = [V]CST_AFALSE and WCRUD_SUCCESS = [V]CST_ATRUE) #Issue X3-XXXX -
# 2018-09-07 by RBA - CRUD
      #Mode test activé, aucun document enregistré
      WERR = format$("4X","")+format$("60X",mess(92,2007,1))
      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
      WSUCCESS = [V]CST_ATRUE
    Endif
  Else #not test mode
    If WFLG_IMPORT = [V]CST_AFALSE  #Issue X3-107857 EDI reception without CRUD - 2018-09-07 by RBA
    #Nombre de document enregistré
      If this.NBFIL_REC_OK + this.NBFIL_REC_KO = 0
        WERR = format$("4X","")+format$("60X",mess(93,2007,1))+" : "+num$(0)
        Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
      Elsif this.NBFIL_REC_OK = 0 and this.NBFIL_REC_KO <> 0
        WERR = format$("4X","")+format$("60X",mess(93,2007,1))+" : "+num$(this.NBFIL_REC_OK)+"/"+num$(this.NBFIL_REC_OK + this.NBFIL_REC_KO)
        Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
      Elsif this.NBFIL_REC_OK <> 0 and this.NBFIL_REC_KO = 0
        WERR = format$("4X","")+format$("60X",mess(93,2007,1))+" : "+num$(this.NBFIL_REC_OK)+"/"+num$(this.NBFIL_REC_OK + this.NBFIL_REC_KO)
  #      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_ASUCCESS) From ASYRASYNC
        Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
        WSUCCESS = [V]CST_ATRUE
      Else
        WERR = format$("4X","")+format$("60X",mess(93,2007,1))+" : "+num$(this.NBFIL_REC_OK)+"/"+num$(this.NBFIL_REC_OK + this.NBFIL_REC_KO)
        Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
      Endif
    Else
      If WIMPORT_SUCCESS = [V]CST_ATRUE
        WSUCCESS = [V]CST_ATRUE
      Endif #Issue X3-107857 EDI reception without CRUD - 2018-09-07 by RBA
    Endif
  Endif
  #"Process EDI terminé"
# If WSUCCESS = [V]CST_ATRUE
#    WERR = format$("4X","")+format$("60X",mess(94,2007,1))
#    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_ASUCCESS) From ASYRASYNC
#    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
#  Elsif this.NBFIL_IMP_OK = 0 and this.NBFIL_IMP_KO <> 0
#    WERR = format$("4X","")+format$("60X",mess(44,2007,1))+" : "+num$(this.NBFIL_IMP_OK)+"/"+num$(this.NBFIL_IMP_OK + this.NBFIL_IMP_KO)
#    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
#    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
#  Elsif this.NBFIL_IMP_OK <> 0 and this.NBFIL_IMP_KO = 0
#    WERR = format$("4X","")+format$("60X",mess(44,2007,1))+" : "+num$(this.NBFIL_IMP_OK)+"/"+num$(this.NBFIL_IMP_OK + this.NBFIL_IMP_KO)
#    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_ASUCCESS) From ASYRASYNC
#    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
#  Else
#    WERR = format$("4X","")+format$("60X",mess(44,2007,1))+" : "+num$(this.NBFIL_IMP_OK)+"/"+num$(this.NBFIL_IMP_OK + this.NBFIL_IMP_KO)
#    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
#    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
 # Endif
  If WSUCCESS = [V]CST_ATRUE
    WERR = format$("4X","")+format$("60X",mess(94,2007,1))
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_ASUCCESS) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
#    WRET_VALUE = [V]CST_AOK
  Else
    WERR = format$("4X","")+format$("60X",mess(94,2007,1))
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
#    WRET_VALUE = [V]CST_AERROR
  Endif
  #/Issue X3-7673 - 2017-09-06 by RBA - CRUD

  ARET_VALUE = WRET_VALUE
Return



Funprog GET_MOVEEND(WPTCCOD)
Value Char WPTCCOD
  Local Char WRET_VALUE(10)
  Local Integer WFLG_MOVEEND : WFLG_MOVEEND = [V]CST_AFALSE
  WFLG_MOVEEND = func EDIPTC_CSTD.GET_MOVEEND_FLG(WPTCCOD)
  Case WFLG_MOVEEND
    When [V]CST_ATRUE  : WRET_VALUE = "true"
    When [V]CST_AFALSE : WRET_VALUE = "false"
  Endcase
End WRET_VALUE

#********************************************************************
# Funprog EDI_BATCH_IMPORT_PREPARE
#********************************************************************
#*
#*
#*
#********************************************************************
#* @param WPAR_NUMBATCH
#* @param WPAR_CATTYP
#* @param WPAR_IMP_DIR
#* @param WPAR_IMP_EXT
#* @param WPAR_IMP_FILE_TAB
#* @param WERR_TAB
#* @return WOK
#*!
Funprog EDI_BATCH_IMPORT_PREPARE(WPAR_NUMBATCH, WDOCID_TAB, WPAR_CATTYP, WPAR_IMP_DIR, WPAR_IMP_EXT, WPAR_IMP_FILE_TAB, WERR_TAB, WTEST, WSTEP, WEDIRUN, WMYLOG)
Value Char WPAR_NUMBATCH()
Value Char WDOCID_TAB()
Value Integer WPAR_CATTYP
Value Char WPAR_IMP_DIR()
Value Char WPAR_IMP_EXT()
Value Char WPAR_IMP_FILE_TAB()(1..)
Variable Char WERR_TAB()(1..)
Value Integer WTEST #[V]CST_ANO / [V]CST_AYES, AYES TEST doesn't work...
Value Integer WSTEP
Variable Instance WEDIRUN Using C_EDIRUN
Variable Instance WMYLOG Using C_ALOG

  Local Integer WNBIMPFILE : WNBIMPFILE = maxtab(WPAR_IMP_FILE_TAB) #total nb of files to treat
  Local Integer WNBMAX     : WNBMAX     = func GET_EDINI() #get limit of nb files per lot
  Local Integer WNBLOT     : WNBLOT     = 0 #counts nb lots
  Local Integer WNBFIL     : WNBFIL     = 0 #counts nb files per lot
  Local Integer WNBPAR     : WNBPAR     = 0 #counts nb paramters per lot
  Local Integer WOK        : WOK        = [V]CST_AOK #returns function status
  Local Integer I          : I          = 0 #counts nb files to treat
  Local Integer J          : J          = 0 #counts nb files to treat per lot, calculated

  Local Char    WTAB_PAR(30)(1..)  # parameters to send to the request
  Local Char    WTAB_VAL(250)(1..) # values for each paramters to send to the request
  Local Char    WRET_MESSAGE(250)  # returned message
  Local Integer WRET_REQUESTID     # returned request id

  For I = 1 To WNBIMPFILE
    Case mod(I, WNBMAX)
      When 1 :       J = 1
      When 0 :       J = J + 1
      When Default : J = mod(I-1, WNBMAX) + 1
    Endcase

    #lot's header
    If J = 1
      WNBPAR = 0
      WNBFIL = 0
      Raz WTAB_PAR()
      Raz WTAB_VAL()
      WNBPAR = WNBPAR + 1 : WTAB_PAR(WNBPAR) = "NUMBATCH"  : WTAB_VAL(WNBPAR) = WPAR_NUMBATCH #"EDI-150305-085824751"
      WNBPAR = WNBPAR + 1 : WTAB_PAR(WNBPAR) = "CATTYP"    : WTAB_VAL(WNBPAR) = num$(WPAR_CATTYP)  #1...
      WNBPAR = WNBPAR + 1 : WTAB_PAR(WNBPAR) = "PATH"      : WTAB_VAL(WNBPAR) = WPAR_IMP_DIR  #"/home1/adonix/GX3APP/EDI/IMPORT"
      WNBPAR = WNBPAR + 1 : WTAB_PAR(WNBPAR) = "EXT"       : WTAB_VAL(WNBPAR) = WPAR_IMP_EXT  #"EDISOH"
      WNBPAR = WNBPAR + 1 : WTAB_PAR(WNBPAR) = "TEST"      : WTAB_VAL(WNBPAR) = num$(WTEST) #1/[V]CST_ANO - 2/[V]CST_AYES, AYES doesn't work...
      WNBPAR = WNBPAR + 1 : WTAB_PAR(WNBPAR) = "FLOSTEP"   : WTAB_VAL(WNBPAR) = num$(WSTEP)
    Endif

    #lot's lines
    WNBPAR = WNBPAR + 1 : WTAB_PAR(WNBPAR) = "FIL("+num$(WNBFIL)+")" : WTAB_VAL(WNBPAR) = WPAR_IMP_FILE_TAB(I) : WNBFIL = WNBFIL + 1

    #lot's request execution
    If J = WNBMAX or I = WNBIMPFILE
      WRET_MESSAGE   = ""
      WRET_REQUESTID = 0
      WOK = func EDI_BATCH_IMPORT_RUN(1, WTAB_PAR, WTAB_VAL, WNBPAR, WRET_REQUESTID, WRET_MESSAGE)
      WNBLOT = WNBLOT + 1
      If WOK = [V]CST_AOK
        WERR_TAB(WNBLOT) = mess(34,134,1)-"#"+num$(WRET_REQUESTID)-mess(64,2007,1)      #Process num  launched successfully ## 112148
      Else
        WERR_TAB(WNBLOT) = mess(34,134,1)-mess(290,196,1)-"("-WRET_MESSAGE+")"  # Process has failed  ## 112148
      Endif
    Else ## Ini SAM 122810 (JUCON 05/05/17)
      WOK = [V]CST_AERROR
      WRET_MESSAGE="EDI batch task is not executed."
      WERR_TAB(WNBLOT) = "Request Failed ("-WRET_MESSAGE+")"
    Endif
  Next I

  If WNBIMPFILE=0
    WOK = [V]CST_AERROR
    WERR_TAB="EDI batch task is not executed."
  Endif
  ##End SAM 122810 (JUCON 05/05/17)

End WOK

#********************************************************************
# Funprog EDI_BATCH_IMPORT_RUN
#********************************************************************
#*
#*
#*
#********************************************************************
#* @param WOFFSET
#* @param WTAB_PAR
#* @param WTAB_VAL
#* @param WNBPAR
#* @param WRET_REQUESTID
#* @param WRET_MESSAGE
#* @return WOK
#*!
Funprog EDI_BATCH_IMPORT_RUN(WOFFSET, WTAB_PAR, WTAB_VAL, WNBPAR, WRET_REQUESTID, WRET_MESSAGE)
Value Integer WOFFSET
Value Char WTAB_PAR()(1..)
Value Char WTAB_VAL()(1..)
Value Integer WNBPAR
Variable Integer WRET_REQUESTID
Variable Char WRET_MESSAGE

  Local Integer WOK

  Local Char    WBAT_TIME(8) : WBAT_TIME = num$(time$)
  Local Integer WTIME        : WTIME = val(right$(WBAT_TIME,7)) + (val(mid$(WBAT_TIME,4,2)) * 60) + (val(left$(WBAT_TIME,2)) * 60 * 60) + WOFFSET
  WBAT_TIME = format$("N0:2",int(WTIME/3600))+":"+format$("N0:2",mod(int(WTIME/60),60))+":"+format$("N0:2",mod(WTIME,60))

  ASTATUS = func ASYRMNGTREQ.CRERQT(GACTX, [S]nomap, GACTX.USER, "EDIIMP", date$, WBAT_TIME, WTAB_PAR, WTAB_VAL, WNBPAR, WRET_REQUESTID, WRET_MESSAGE)

  If ASTATUS=0
    WOK = [V]CST_AOK
  Else
    WOK = [V]CST_AERROR
  Endif
End WOK

#********************************************************************
# Funprog GET_EDINI
#********************************************************************
#*
#*
#*
#********************************************************************
#* @return WNBMAX
#*!
Funprog GET_EDINI()
  Local Integer WNBMAX
  Local File ACTIV [ACV]
  Read [ACV]CODACT = "EDINI"
  If !fstat and [ACV]FLACT = [V]CST_AYES
    WNBMAX = [ACV]DIME
  Else
    WNBMAX = 1
  Endif
  LogicClose File [ACV]
End WNBMAX


#********************************************************************
# Method MET_RECEIPT_PROCESS
#********************************************************************
#
#*
#* @param WPOS_MSG
#* @param WPROTOTYPE_JSON
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_RECEIPT_PROCESS
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer I, WPOS, WPOS_ORDERED : WPOS_ORDERED = 0
  Local Char WERR(250)
  Local Integer WNBFIL : WNBFIL = 0
  Local Integer WFLG_GO_TO_NEXT_FLOW_STEP : WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_AFALSE
  Local Integer WFLG_REP_INSTANCIATED     : WFLG_REP_INSTANCIATED     = [V]CST_AFALSE
  Local Integer WFLGMUX
  Local Integer WSTEP
  WSTEP = 3 #from previous... to change)
  Local Char WENTITY_ETAG(50)          : WENTITY_ETAG = "" #etag of entity when it's stored
  Local Char WENTITY_TYPE(30)          : WENTITY_TYPE = "instance"
  Local Clbfile WRES_JSON_INS_CLOB     : WRES_JSON_INS_CLOB = "" #to recover the JSON file of instance
  Local Char    WRES_JSON_INS_UUID(36) : WRES_JSON_INS_UUID = "" #returned
  Local Char WIMP_SAVED_TAB_JSON_UUID(50)(1..)
  Local Char WIMP_SAVED_TAB_DOCID(36)(1..)
  Local Char WNEWDOCID_CRUD_TAB(36)(1..) #RBA
  Local Char WIMP_REAL_TAB_DOCID(36)(1..)     #111044
  Local Integer WIMP_SAVED_TAB_NUMLIN(1..)
  Local Char WIMPFILE(200) #import filename to build
  Local Integer WFLGMUXIMP

  Local Integer WFLG_IMPORT : WFLG_IMPORT = [V]CST_AFALSE #Issue X3-7673 - 2017-09-06 by RBA - CRUD

  Local File EDITMPDOC [ETC]
  Call ASYNCTRACK(WEDIRUN.ACTX, "(3)", mess(28,2007,1), 40) From ASYRASYNC #'Traitement de la liste des documents'

  Gosub RECEIPT_PROCESS_GET_MSG
  # Step 2 : for each message of the collection EINS, process

  For I = 1 To maxtab(this.EINS)
    If this.EINS(I)<>null and find(this.EINS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and this.EINS(I).MSGTYP = 1 #Query
      WSTEP = 3 #from previous... to change)
      WPOS_ORDERED = WPOS_ORDERED + 1
      Gosub RECEIPT_PROCESS_CONTROL_TESTFLG
      Gosub RECEIPT_PROCESS_SAS_CREATE
      Gosub RECEIPT_PROCESS_SAS_READ
      Gosub RECEIPT_PROCESS_REP_GET
      Gosub RECEIPT_PROCESS_REP_INSTANCIATE

      Gosub RECEIPT_PROCESS_REP_INSTANCIATED_EXPORT
      Gosub RECEIPT_PROCESS_REP_INSTANCIATED_SAVE
      Gosub RECEIPT_PROCESS_REP_INSTANCIATED_SAVE_UUID_IN_SAS
      Gosub RECEIPT_PROCESS_CONTROL_AUTHORIZATIONS
      Gosub RECEIPT_PROCESS_REP_CRUD #Issue X3-7673 - 2017-09-06 by RBA - CRUD
      Gosub RECEIPT_PROCESS_REP_INSTANCIATED_FREE
      Gosub RECEIPT_PROCESS_EDITMPDOC_UPDATE
      Gosub RECEIPT_PROCESS_GENERATE_IMPORT_FILE_FOR_CURRENT



    Endif
  Next I
  Gosub RECEIPT_PROCESS_SAS_FREE

  LogicClose File [ETC]

  Gosub RECEIPT_PROCESS_GENERATE_IMPORT_FILE_FOR_ALL
  Gosub RECEIPT_PROCESS_IMPORT
  Gosub RECEIPT_PROCESS_RESUME


  Gosub RECEIPT_PROCESS_RECEIPT_CRUD_END #RBA

  #INI X3-70672 Error volume management EDI (JUCON 01/03/2018)
  If WRET_VALUE<>[V]CST_AOK
    Local Char WMERR(250)
    For K=1 To maxtab(this.EFILERR)
      WOK=func ASYRSYS.COPYFILE(this.EFILERR(K).FILEORI,this.EFILERR(K).FILERROR,WMERR)
      If WMERR<>""
        Call ADDDIAGNOSE(WEDIRUN.ACTX,WMERR,[V]CST_AWARNING) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WMERR,[V]CST_AWARNING)
        WRET_VALUE = [V]CST_AERROR
      Endif
    Next
  Endif
  #END X3-70672 Error volume management EDI (JUCON 01/03/2018)

  ARET_VALUE = WRET_VALUE
Return



$RECEIPT_PROCESS_GET_MSG

  # For the current message mapping in EMSG, create the collection EINS with all corresponding documents in EDITMPDOC
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLOCOD = this.FLOCOD and [ETC]FLOREL = this.FLOREL
&      and [ETC]MSGCOD = this.EMSG(WPOS_MSG).MSGCOD and [ETC]MSGREL = this.EMSG(WPOS_MSG).MSGREL
  Call DELETELINES(this, "EINS") From EDILIBA

  For [ETC] #in V1, only one line sequential with Query : WNBMSG = 1 max
    WPOS = fmet this.ADDLINE("EINS", [V]CST_ALASTPOS)
    this.EINS(WPOS).DOCID     = [ETC]DOCID
    this.EINS(WPOS).MSG_UUID  = this.EMSG(WPOS_MSG).MSG_UUID
    this.EINS(WPOS).SEQ_UUID  = this.EMSG(WPOS_MSG).SEQ_UUID
    this.EINS(WPOS).MSGCOD    = this.EMSG(WPOS_MSG).MSGCOD
    this.EINS(WPOS).MSGREL    = this.EMSG(WPOS_MSG).MSGREL
    this.EINS(WPOS).MSGFILNOR = this.EMSG(WPOS_MSG).MSGFILNOR
    this.EINS(WPOS).MSGTYP    = this.EMSG(WPOS_MSG).MSGTYP #1 #Query
    this.EINS(WPOS).RES_STA   = [ETC]FLGVALIDDOC
    this.EINS(WPOS).INS_UUID  = toUuid([ETC]UUID_JSON)
    this.EINS(WPOS).REPCOD    = this.EMSG(WPOS_MSG).REPCOD
    Local Integer WPOS_KEY_MSG
    Call DELETELINES(this.EINS(WPOS), "EKEY") From EDILIBA
    For WPOS_KEY_MSG = 1 To maxtab (this.EMSG(WPOS_MSG).EKEY)
      WPOS_KEY_INS = fmet this.EINS(WPOS).ADDLINE("EKEY", [V]CST_ALASTPOS) :
      this.EINS(WPOS).EKEY(WPOS_KEY_INS).KEY_COD = this.EMSG(WPOS_MSG).EKEY(WPOS_KEY_MSG).KEY_COD
      this.EINS(WPOS).EKEY(WPOS_KEY_INS).KEY_FLD = this.EMSG(WPOS_MSG).EKEY(WPOS_KEY_MSG).KEY_FLD
    Next WPOS_KEY_MSG
    WFLGMUXIMP = this.EMSG(WPOS_MSG).FLGMUXIMP
    this.EINS(WPOS).FLGMUXIMP = WFLGMUXIMP #fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "FLGMUXIMP")
  Next
  Filter [ETC]
Return

$RECEIPT_PROCESS_CONTROL_TESTFLG
  WSTEP = WSTEP + 1 #20
  #12 - in case of test mode
  If WEDIRUN.TESTFLG = [V]CST_AYES
    #events
    WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 28, mess(2,8,1), WMYLOG)   # Active   ## 112148
  Else
    WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 28, mess(1,8,1), WMYLOG)   # Inactive ## 112148
  Endif
Return

$RECEIPT_PROCESS_SAS_CREATE
  WSTEP = WSTEP + 1 #4
  Read [ETC]ETC0 = this.NUMBATCH; this.EINS(I).DOCID
  If !fstat
    #1 - creation of the SAS
    Local Instance WMYEDISTO Using C_EDISTO
    WMYEDISTO = NewInstance C_EDISTO AllocGroup null
    WOK = fmet WMYEDISTO.AINIT()
    WMYEDISTO.NUMBATCH  = this.NUMBATCH
    WMYEDISTO.KEYDOC    = this.EINS(I).DOCID #will be replaced further by the X3 id after importation
    WMYEDISTO.EXTKEYDOC = this.EINS(I).DOCID
    WMYEDISTO.FLOCOD    = this.FLOCOD
    WMYEDISTO.FLOREL    = this.FLOREL
    WMYEDISTO.TESTFLG   = WEDIRUN.TESTFLG
    WOK = fmet WMYEDISTO.AINSERT()
    If WOK = [V]CST_AOK #WERR = "SAS creation"
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
      this.NBSAS_OK = this.NBSAS_OK + 1
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 10, mess(7,2007,1), WMYLOG)
    Else #WERR = "SAS creation"
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE
      this.NBSAS_KO = this.NBSAS_KO + 1
      this.EINS(I).RES_STA = [V]CST_ANO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 10, mess(9,2007,1), WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif
Return

$RECEIPT_PROCESS_SAS_READ
  #2- Read the created SAS
  If WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
    WSTEP = WSTEP + 1 #5
    WOK = fmet WMYEDISTO.AREAD(this.NUMBATCH, this.EINS(I).DOCID)
    If WOK = [V]CST_AOK #WERR = "SAS accessibility" #reading created SAS
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 12, mess(7,2007,1), WMYLOG)
    Else                #WERR = "SAS accessibility" #error reading created SAS
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE
      this.EINS(I).RES_STA = [V]CST_ANO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 12, mess(9,2007,1), WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif
Return

$RECEIPT_PROCESS_REP_GET
  #3- Get the Representation JSON and update the SAS with its uuid
  If WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
    WSTEP = WSTEP + 1 #6

    WOK = func ASYREIP.MDB_GET_EDI_ENTITY_UUID(num$(this.EINS(I).INS_UUID), WRES_JSON_INS_CLOB, WERR)
    If WOK = [V]CST_AOK and len(WRES_JSON_INS_CLOB) > 2 #{} #Getting entity
      this.NBENT_OK = this.NBENT_OK + 1
      For J = 1 To maxtab(WMYEDISTO.ESTU)
        If WMYEDISTO.ESTU(J).CODE = "REPCOD"+num$(WPOS_ORDERED)
          WMYEDISTO.ESTU(J).DOCUUID = this.EINS(I).INS_UUID
          Break
        Endif
      Next J
      WOK = fmet WMYEDISTO.AUPDATE()
      If WOK = [V]CST_AOK #WERR = "SAS update UUID of instance"
        WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 34, mess(2,2003,1), WMYLOG)
      Else
        WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE
        this.EINS(I).RES_STA = [V]CST_ANO
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 34, mess(2,2003,1), WMYLOG)
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
        WRET_VALUE = [V]CST_AERROR
      Endif
    Else
      this.NBENT_KO = this.NBENT_KO + 1
      this.EINS(I).RES_STA = [V]CST_ANO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 13, mess(9,2007,1), WMYLOG)
      WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif
Return

$RECEIPT_PROCESS_REP_INSTANCIATE
  #4- instanciate the representation and load data from the clob file
  If WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
    WSTEP = WSTEP + 1 #7
    Local Instance WMYREP Using ="R_"+this.EINS(I).REPCOD
    WMYREP = NewInstance With ="R_"+this.EINS(I).REPCOD
    WFLG_REP_INSTANCIATED = [V]CST_ATRUE
     WOK = func ASYREIP.LOAD_REPRESENTATION(WMYREP, WRES_JSON_INS_CLOB, WERR)

    If WOK = [V]CST_AOK #Loading representation
      this.NBINS_OK = this.NBINS_OK + 1
      ###########################
      Local Char WRET_ERR(250)
      Local Shortint WRET_TEST    #111044
      If this.NBINS_OK=1
        Local Shortint WRET_RUN
        WRET_RUN = WEDIRUN.TESTFLG
      Endif
        WRET_TEST= WRET_RUN            #111044
       WOK = fmet WMYREP.AINIT() #Issue X3-7673 - 2017-09-06 by RBA - CRUD
  #     WOK = fmet WMYREP.MET_AFTER_LOAD_REPRESENTATION(WEDIRUN.CATACT, WEDIRUN.CATCOD, WEDIRUN.PARCOD, WEDIRUN.DUPLICATEFLG, WEDIRUN.TESTFLG, WRET_ERR)
       #WOK = fmet WMYREP.MET_AFTER_LOAD_REPRESENTATION(WEDIRUN.CATACT, WEDIRUN.CATCOD, WEDIRUN.PARCOD, WEDIRUN.DUPLICATEFLG, WRET_TEST, WRET_ERR) #111044
      WOK = fmet WMYREP.MET_AFTER_LOAD_REPRESENTATION(WEDIRUN.CATACT, WEDIRUN.CATCOD, WEDIRUN.PARCOD, WEDIRUN.DUPLICATEFLG, WRET_TEST, "", WRET_ERR) #Issue X3-112583 - 2018-10-11 by RBA - 7 parameters
# in method

      If WOK = [V]CST_AOK
        If WRET_TEST=1 and WRET_RUN<>2 : WEDIRUN.TESTFLG=1: Else WEDIRUN.TESTFLG=2 Endif  #111044
        WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 13, mess(7,2007,1), WMYLOG)
      Else
        WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE
#        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 13, WRET_ERR, WMYLOG)
         #Issue X3-7673 - 2017-09-06 by RBA - CRUD
        If WRET_ERR <> ""
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 13, mess(9,2007,1)-":"-WRET_ERR, WMYLOG)
        Else
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 13, mess(9,2007,1), WMYLOG)
        Endif #/Issue X3-7673 - 2017-09-06 by RBA - CRUD
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
        WRET_VALUE = [V]CST_AERROR
      Endif
      ###########################

    Else #Loading representation failed
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE #
      this.NBINS_KO = this.NBINS_KO + 1
      this.EINS(I).RES_STA = [V]CST_ANO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 13, mess(9,2007,1), WMYLOG)
      WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif
Return

$RECEIPT_PROCESS_REP_INSTANCIATED_EXPORT
  #5- export the loaded representation instance into a clob
  If WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
    WSTEP = WSTEP + 1 #8
    WRES_JSON_INS_CLOB=  ""
    WOK = func ASYREIP.EXPORT_DATA_DETAIL(WMYREP, [V]CST_ANO, WRES_JSON_INS_CLOB, WERR)
    If WOK = [V]CST_AOK and maxtab(WRES_JSON_INS_CLOB) > 0
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 26, mess(7,2007,1), WMYLOG)
    Else
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 26, mess(9,2007,1), WMYLOG)
      WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif
Return

$RECEIPT_PROCESS_REP_INSTANCIATED_SAVE
  #6- save the clob loaded representation instance in MongoDB
  If WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
    WSTEP = WSTEP + 1 #9
    WOK = func ASYREIP.MDB_CREATE_EDI_ENTITY(WRES_JSON_INS_CLOB, this.NUMBATCH+"~"+this.EINS(I).DOCID, WENTITY_TYPE, WENTITY_ETAG, WRES_JSON_INS_UUID, WERR)
    If WOK = [V]CST_AOK
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 27, mess(7,2007,1), WMYLOG)
    Else
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 27, mess(9,2007,1), WMYLOG)
      WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif
Return

$RECEIPT_PROCESS_REP_INSTANCIATED_SAVE_UUID_IN_SAS
  #7- update SAS with instance uuid
  If WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
    WSTEP = WSTEP + 1 #10
    WPOS = fmet WMYEDISTO.ADDLINE("ESTU", [V]CST_ALASTPOS)
    WMYEDISTO.ESTU(WPOS).CODE     = "INSFILE"+num$(WPOS_MSG)  #"INSFILE"+num$(WPOS_ORDERED) #Issue 111819 - 2015-10-20
    WMYEDISTO.ESTU(WPOS).DOCDES   = "Data / Instance"
    WMYEDISTO.ESTU(WPOS).DOCKEY   = this.EINS(I).DOCID
    WMYEDISTO.ESTU(WPOS).DOCUUID  = toUuid(WRES_JSON_INS_UUID)
    WMYEDISTO.ESTU(WPOS).DOCCLASS = ""
    WMYEDISTO.TESTFLG = WEDIRUN.TESTFLG  #111044
    WMYEDISTO.STA = 2 #2-In progress
    WOK = fmet WMYEDISTO.AUPDATE()
    If WOK = [V]CST_AOK #WERR = SAS update status
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 34, mess(2,2003,1), WMYLOG)
    Else #WERR = SAS update status
      WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_AFALSE
      this.EINS(I).RES_STA = [V]CST_ANO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 34, mess(2,2003,1), WMYLOG)
      WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif
Return


$RECEIPT_PROCESS_CONTROL_AUTHORIZATIONS
  #8- controls autorizations
  If WFLG_GO_TO_NEXT_FLOW_STEP    = [V]CST_ATRUE
    Local Integer WPOS_KEY_INS
    WRET_VALUE = [V]CST_AOK
    Trbegin [ETC]

    For WPOS_KEY_INS = 1 To maxtab (this.EINS(I).EKEY)
      Case this.EINS(I).EKEY(WPOS_KEY_INS).KEY_COD
        When "FCY"    :
            If this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD = ""
              [ETC]FCY = ""
              WERR = mess(25,2006,1) #"Site code must be defined"
              WOK = fmet WMYLOG.APUTLINE(mess(115,2006,1)-":"-WERR,[V]CST_AERROR)  #  Message mapping   ## 112148
              WRET_VALUE = [V]CST_AERROR
            Else
              [ETC]FCY = evalue("WMYREP."+this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD)
              If [ETC]FCY = ""
                WERR = mess(25,2006,1) #"Site code must be defined"
#                WOK = fmet WMYLOG.APUTLINE("Data : "+WERR,[V]CST_AERROR) ## 112148
                WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)  ## 112148
                WRET_VALUE = [V]CST_AERROR
              Else
                Local File FACILITY [FCY]
                Read [FCY]FCY0=[ETC]FCY
                If fstat=[V]CST_AOK
                  [ETC]CPY= [F:FCY]LEGCPY
                Endif
                LogicClose File [FCY]
              Endif
            Endif

        When "BPANUM" :
            If this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD = ""
              [ETC]BPRNUM = ""
              WERR = mess(5,2006,1) #"Business partner must be defined"
              WOK = fmet WMYLOG.APUTLINE(mess(115,2006,1)-":"-WERR,[V]CST_AERROR)  #  Message mapping   ## 112148
              WRET_VALUE = [V]CST_AERROR
            Else
              [ETC]BPRNUM = evalue("WMYREP."+this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD)
              If [ETC]BPRNUM = ""
                WERR = mess(5,2006,1) #"Business partner must be defined"
                WOK = fmet WMYLOG.APUTLINE("Data : "+WERR,[V]CST_AERROR)
                WRET_VALUE = [V]CST_AERROR
              Endif
            Endif

        When "BPAADD" :
            If this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD = ""
              [ETC]BPAADD = ""
              WERR = mess(4,2006,1) #"Business partner address code must be defined"
              WOK = fmet WMYLOG.APUTLINE(mess(115,2006,1)-":"-WERR,[V]CST_AERROR)  #  Message mapping   ## 112148
              WRET_VALUE = [V]CST_AERROR
            Else
              [ETC]BPAADD = evalue("WMYREP."+this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD)
              If [ETC]BPAADD = ""
                WERR = mess(4,2006,1) #"Business partner address code must be defined"
                WOK = fmet WMYLOG.APUTLINE("Data : "+WERR,[V]CST_AERROR)
                WRET_VALUE = [V]CST_AERROR
              Endif
            Endif
#        When "CPY"    :## 112148
#            If this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD = ""
#              [ETC]CPY = ""
#              WERR = mess(15,2006,1)
#              WOK = fmet WMYLOG.APUTLINE("Message mapping : "+WERR,[V]CST_AERROR)#"Company must be defined"
#              WRET_VALUE = [V]CST_AERROR
#            Else
#              [ETC]CPY = evalue("WMYREP."+this.EINS(I).EKEY(WPOS_KEY_INS).KEY_FLD)
#              If [ETC]CPY = ""
#                WERR = mess(15,2006,1) #"Company must be defined"
#                WOK = fmet WMYLOG.APUTLINE("Data : "+WERR,[V]CST_AERROR)
#                WRET_VALUE = [V]CST_AERROR
#              Endif
#            Endif
      Endcase
    Next WPOS_KEY_INS
    Rewrite [ETC]
    If !fstat
      Commit
    Else
      Rollback
      WRET_VALUE = [V]CST_AERROR
    Endif

    ###########################################
    #1 - controls autorizations
    WSTEP = WSTEP + 1 ##11
    If WRET_VALUE = [V]CST_AERROR
      this.EINS(I).RES_STA = [V]CST_ANO #not authorized
      WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
    Else
      #1-1 Checking Company autorization
      Trbegin [ETC]
      [ETC]FLGEDICPY = func EDIRUN_CSTD.TEST_EDICPYPAR([ETC]CPY, this.PARCOD)
      Rewrite [ETC]
      If !fstat
        Commit
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [ETC]FLGEDICPY, 1, [ETC]CPY, WMYLOG)
      Else
        Rollback
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 1, [ETC]CPY, WMYLOG)
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      Endif

      #1-2 Checking Site autorization
      WSTEP = WSTEP + 1 ##12
      Trbegin [ETC]
      [ETC]FLGEDIFCY = func EDIRUN_CSTD.TEST_EDIFCYPAR([ETC]FCY, this.PARCOD)
      Rewrite [ETC]
      If !fstat
        Commit
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [ETC]FLGEDIFCY, 2, [ETC]FCY, WMYLOG)
      Else
        Rollback
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 2, [ETC]FCY, WMYLOG)
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      Endif

      #1-3 Checking BP/Address autorization"
      WSTEP = WSTEP + 1 ##13
      Trbegin [ETC]
      [ETC]FLGEDIBPR = func EDIRUN_CSTD.TEST_EDIBPRPAR([ETC]BPRNUM, [ETC]BPAADD, this.PARCOD)
      Rewrite [ETC]
      If !fstat
        Commit
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [ETC]FLGEDIBPR, 3, [ETC]BPRNUM+"~"+[ETC]BPAADD, WMYLOG)
       Else
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 3, [ETC]BPRNUM+"~"+[ETC]BPAADD, WMYLOG)
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
        Rollback
      Endif

      #1-4 Checking Flow association with BP/Company
      WSTEP = WSTEP + 1 ##14
      Local Char WMSGCOD(20)
      Local Char WMSGREL(5)
      Local Char WMSGFILNOR(20)
      Local Char WPTC(20)
      Local Integer WFLG
      WFLG = func EDIRUN_CSTD.TEST_EDIBPRCPY([ETC]BPRNUM, [ETC]CPY, this.PARCOD, this.CATCOD, this.FLOCOD, this.FLOREL)
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, WFLG, 4, [ETC]BPRNUM+"~"+[ETC]CPY, WMYLOG)
      If WFLG = [V]CST_AINFO
        WOK = func EDIRUN_CSTD.GET_EDISEQFIL_FROM_EDIFLO(this.FLOCOD, this.FLOREL, this.CATCOD, WMSGCOD, WMSGREL, WMSGFILNOR, WFLGMUX, WPTC)
        WSTEP = WSTEP + 1 ##15
        If WOK = [V]CST_AOK
          Trbegin [ETC]
          [ETC]FLOCOD    = this.FLOCOD
          [ETC]FLOREL    = this.FLOREL
          [ETC]MSGCOD    = WMSGCOD
          [ETC]MSGREL    = WMSGREL
          [ETC]MSGFILNOR = WMSGFILNOR
          [ETC]PTCCOD    = WPTC
          [ETC]FLGEDIBPRCPY = [V]CST_AINFO
          Rewrite [ETC]
          If !fstat
            Commit
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 5, this.FLOCOD+"~"+this.FLOREL, WMYLOG)
          Else
            Rollback
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 5, this.FLOCOD+"~"+this.FLOREL, WMYLOG)
            WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
          Endif
        Else
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 5, this.FLOCOD+"~"+this.FLOREL, WMYLOG)
          WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
        Endif
      Else
         WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)  ##pte v9
      Endif

      #1-5 Checking Flow setup
      WSTEP = WSTEP + 1 ##16
      Trbegin [ETC]
      [ETC]FLGVALIDFLO  = func EDIRUN_CSTD.TEST_EDIFLO(this.FLOCOD, this.FLOREL)
      Rewrite [ETC]
      If !fstat
        Commit
        Case [ETC]FLGVALIDFLO
          When [V]CST_AINFO    :
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [ETC]FLGVALIDFLO, 6, mess(99,2006,1), WMYLOG) # Valid and activated flow
          When [V]CST_AWARNING :
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [ETC]FLGVALIDFLO, 6, mess(41,2006,1), WMYLOG) # Invalid flow
            WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
          When [V]CST_AERROR   :
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [ETC]FLGVALIDFLO, 6, mess(2,2333,1)+mess(00066,02006,1) , WMYLOG)
            WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)                 # Incorrect Flow
        Endcase
      Else
    #      WERR = "Flow controls while updating the documents list"
        Rollback
        #WERR = "Checking Flow setup"
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 6, this.FLOCOD+"~"+this.FLOREL, WMYLOG)
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
      Endif

      #1-6 Set document status resulting from CTRL
      If [ETC]FLGEDICPY = [V]CST_AINFO
&       and [ETC]FLGEDIFCY    = [V]CST_AINFO
&       and [ETC]FLGEDIBPR    = [V]CST_AINFO
&       and [ETC]FLGEDIBPRCPY = [V]CST_AINFO
&       and [ETC]FLGVALIDFLO  = [V]CST_AINFO
        this.EINS(I).RES_STA = [V]CST_AYES #authorized
      Else
        this.EINS(I).RES_STA = [V]CST_ANO #not authorized
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, 4, WMYLOG)    # X3-44530 Check error status in EDI partner/BP autorizations
      Endif
    Endif
  Endif
Return


#Issue X3-7673 - 2017-09-06 by RBA - CRUD
$RECEIPT_PROCESS_REP_CRUD
  If WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_ATRUE
    WSTEP = WSTEP + 1
    #tester si on est en CRUD
    #verifier dans la collection du seq file s'il existe du paramétrage : si NON alors CRUD pour le moment INSERT
    Local File EDIMSGD [EMSD]#detail fichier d'import]
    Filter [EMSD] Where MSGCOD = this.EINS(I).MSGCOD and MSGREL = this.EINS(I).MSGREL
    For [EMSD]
      WFLG_IMPORT = [V]CST_ATRUE
      Break
    Next
    Filter [EMSD]
    LogicClose File [EMSD]

    If WFLG_IMPORT = [V]CST_AFALSE #donc c'est CRUD
      If WEDIRUN.TESTFLG <> [V]CST_AYES

        #abreviation de la representation
        Local Char WABRCLA(8) : WABRCLA = ""
        Local File ASHW [ASW]
        Read [ASW]ASW0 = right$(WMYREP.AINF.NAMCLA,3)
        If !fstat
          WABRCLA = [ASW]ABRCLA
        Endif
        LogicClose File [ASW]
# Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
#        #recuperer les valeurs de FLG_DELETE et FLG_UPDATE (plus tard) et determine FLG_INSERT
#        Local Integer WFLG_CREATE : WFLG_CREATE = [V]CST_AYES # by default
#        Local Integer WFLG_DELETE : WFLG_DELETE = [V]CST_ANO
#        Local Integer WFLG_UPDATE : WFLG_UPDATE = [V]CST_ANO
#        Local File EDIMSG [EMS]
#        Read [F:EMS]EMS0 = this.EINS(I).MSGCOD;this.EINS(I).MSGREL
#        If !fstat
#          WFLG_DELETE = [F:EMS]FLGDELETE
#          WFLG_UPDATE = [F:EMS]FLGUPDATE
#          If WFLG_DELETE = [V]CST_AYES or WFLG_UPDATE = [V]CST_AYES
#            WFLG_CREATE = [V]CST_ANO
#          Endif
#        Endif
#        LogicClose File [EMS]
#
#
#        If WFLG_DELETE = [V]CST_AYES
#          Gosub RECEIPT_PROCESS_REP_CRUD_DELETE
#        Elsif WFLG_UPDATE = [V]CST_AYES
#          Gosub RECEIPT_PROCESS_REP_CRUD_UPDATE
#        Else #If WFLG_INSERT = [V]CST_AYES # c'est du create (insert)
#          Gosub RECEIPT_PROCESS_REP_CRUD_CREATE
#        Endif
#        #/ Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements

        # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
        Case WEDIRUN.CATOPE
          When 1 : #Read --> Error
            #erreur
            WOK = [V]CST_AERROR
          When 4 : #Update
            Gosub RECEIPT_PROCESS_REP_CRUD_UPDATE
          When 3 : #Delete
            Gosub RECEIPT_PROCESS_REP_CRUD_DELETE
          When Default : #0, 2 : #Create
            Gosub RECEIPT_PROCESS_REP_CRUD_CREATE
        Endcase
        #/ Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements

        If WOK > [V]CST_AOK
          this.NBFIL_REC_KO = this.NBFIL_REC_KO + 1
          Gosub REPRESENTATION_ERROR_STRUCTURE
          WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
        Else
          this.NBFIL_REC_OK = this.NBFIL_REC_OK + 1
          WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, 3, WMYLOG)
          #il faut récuperer la clé et faire le duplicate SAS en fin de traitement ---> dans EDIRUN / $RUN_RECEIPT_PROCESS / new : step 10
          WOK = fmet WMYEDISTO.AREAD(this.NUMBATCH, [ETC]DOCID)
          If WOK = [V]CST_AOK #WERR = "SAS accessibility" #reading created SAS
            WPOS = fmet WMYEDISTO.ADDLINE("ESTU", [V]CST_ALASTPOS)
            WMYEDISTO.ESTU(WPOS).CODE     = "CRUDFILE"+num$(1)
            WMYEDISTO.ESTU(WPOS).DOCDES   = mess(5,7959,1)-"/"-"CRUD" #"Data / CRUD"
            WMYEDISTO.ESTU(WPOS).DOCCLASS = ""
            WMYEDISTO.ESTU(WPOS).DOCKEY   = [ETC]DOCID
            WOK = fmet WMYEDISTO.AUPDATE()
            If WOK = [V]CST_AOK
              Local Char WKEY_FIELD(50)
              Local Char WSTR_MYREP_KEYS(150)
              WSTR_MYREP_KEYS = 'WMYREP.'+WABRCLA+'.AKEYS()'
              Local Integer WINT_MAX_KEYS
              WINT_MAX_KEYS = evalue('maxtab('+WSTR_MYREP_KEYS+')')
              For WI = 1 To WINT_MAX_KEYS
                If WI = 1
                  WSTR_MYREP_KEYS = 'WMYREP.'+WABRCLA+'.AKEYS('+num$(WI)+')'
                  WKEY_FIELD = evalue(WSTR_MYREP_KEYS)
                  WNEWDOCID_CRUD_TAB(this.NBFIL_REC_OK) = evalue('WMYREP.'+WABRCLA+'.'+WKEY_FIELD)
                Else
                  WSTR_MYREP_KEYS = 'WMYREP.'+WABRCLA+'.AKEYS('+num$(WI)+')'
                  WKEY_FIELD = evalue(WSTR_MYREP_KEYS)
                  WNEWDOCID_CRUD_TAB(this.NBFIL_REC_OK) = WNEWDOCID_CRUD_TAB(this.NBFIL_REC_OK) +"~"+ evalue('WMYREP.'+WABRCLA+'.'+WKEY_FIELD)
                Endif
              Next WI
              Gosub RECEIPT_PROCESS_REP_CRUD_TRK
            Endif
          Endif
        Endif

      Else
        this.NBFIL_REC_KO = this.NBFIL_REC_KO + 1
        #mode test
        WERR = mess(152,2006,1)# Test mode enabled - Importation won't be done #=># Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements changer le texte plus generique
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
        Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AINFO) From ASYRASYNC
      Endif

    Endif
  Endif
Return

$RECEIPT_PROCESS_REP_CRUD_DELETE
  WOK = evalue('fmet WMYREP.'+WABRCLA+'.ADELETE()')
Return

$RECEIPT_PROCESS_REP_CRUD_UPDATE
  #not implemented yet
  WOK = [V]CST_AERROR #en attendant
Return

$RECEIPT_PROCESS_REP_CRUD_CREATE
  WOK = evalue('fmet WMYREP.'+WABRCLA+'.AINSERT()')
Return

