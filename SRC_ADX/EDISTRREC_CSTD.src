#         WOK = fmet this.MET_RECEIPT_IMPORT_FILES(WPOS_MSG, WIMP_SAVED_TAB_DOCID, WSTEP, WEDIRUN, WMYLOG)
#        Next
#      Endif
#      #111044
#    Else
#      #mode test
#      WERR =mess(152,2006,1)# Test mode enabled - Importation won't be done
#      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
##      WOK = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
#      Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AINFO) From ASYRASYNC
#    Endif
##  Endif      ##SAM 122810 (JUCON 05/05/17)
Return

$RECEIPT_PROCESS_RESUME
  I = 0
  Raz WIMP_SAVED_TAB_DOCID()
  Local File EDITMPDOC [ETC]

  Filter [ETC] Where NUMBATCH = this.NUMBATCH and FLOCOD = this.FLOCOD and FLOREL = this.FLOREL
  For [ETC]
    I = I + 1  #111044
#    I=1
    WIMP_SAVED_TAB_DOCID(I) = [ETC]DOCID

#    WOK = fmet this.MET_RECEIPT_LOG_RESUME(WIMP_SAVED_TAB_DOCID, WEDIRUN, WMYLOG)   #111044
  Next
  Filter [ETC]
  LogicClose File [ETC]

  WOK = fmet this.MET_RECEIPT_LOG_RESUME(WIMP_SAVED_TAB_DOCID, WEDIRUN, WMYLOG) #111044

Return


$RECEIPT_PROCESS_RECEIPT_CRUD_END
#      Call ADDDIAGNOSE(WEDIRUN.ACTX,"coucou",[V]CST_AINFO) From ASYRASYNC
 #il faut récuperer la clé et faire le ducplicate SAS en fin de traitement
  If WFLG_IMPORT = [V]CST_AFALSE
    Char WERR_TAB(250)(1..)
    Local Integer WJ, WK
    #  Dbgaff
    For WJ  = 1 To maxtab(WIMP_SAVED_TAB_DOCID)
      Local Instance WMYEDISTO Using C_EDISTO
      WMYEDISTO = NewInstance C_EDISTO AllocGroup null
      WOK = fmet WMYEDISTO.AREAD(this.NUMBATCH, WIMP_SAVED_TAB_DOCID(WJ))
      If WEDIRUN.TESTFLG = [V]CST_ANO
        If WEDIRUN.CATOPE = 3 # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
          WOK = func SUBEIP.DUPLICATE_SAS_AND_DELETE_TRK(this.NUMBATCH, this.CATTYP, WIMP_SAVED_TAB_DOCID(WJ), WNEWDOCID_CRUD_TAB(WJ), WERR_TAB(), WSTEP)
        Else #by default is creation
          WOK = func SUBEIP.DUPLICATE_SAS(this.NUMBATCH, this.CATTYP, WIMP_SAVED_TAB_DOCID(WJ), WNEWDOCID_CRUD_TAB(WJ), WERR_TAB(), WSTEP)
        Endif

        If WOK <> [V]CST_AOK
##        Call ECR_TRACE("Launching receipt process"-WNUMBATCH-"(external reference :"-WOLDDOCID+") : failed",1) From GESECRAN  # Issue 116335- 2016-04-29 by RBA : txt
#         Call ECR_TRACE(mess(41,2007,1)-WNUMBATCH-"("+mess(6,772,1)-":"-WOLDDOCID+") :"-mess(9,2007,1),1) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
         WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, "Not applicable") #WOLDDOCID+"->"+WNEWDOCID
          For WK = 1 To maxtab(WERR_TAB)
#          Call ECR_TRACE(""+WERR_TAB(J),1) From GESECRAN
           WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, WERR_TAB(J)) #WOLDDOCID+"->"+WNEWDOCID
          Next WK
        Else
##        Call ECR_TRACE("Launching receipt process"-WNUMBATCH-"(external reference :"-WOLDDOCID+") -> (X3 reference :"-WNEWDOCID+") : succeeded",0) From GESECRAN
#         Call ECR_TRACE(mess(41,2007,1)-WNUMBATCH-"("+mess(6,772,1)-":"-WOLDDOCID+") -> ("+mess(6,3701,1)-" :"-WNEWDOCID+") :"-mess(7,2007,1),0) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
         WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, WERR_TAB(J)) #WOLDDOCID+"->"+WNEWDOCID
        Endif


#        If WOK <> [V]CST_AOK
##        Call ECR_TRACE("Launching receipt process"-WNUMBATCH-"(external reference :"-WOLDDOCID+") : failed",1) From GESECRAN  # Issue 116335- 2016-04-29 by RBA : txt
#         Call ECR_TRACE(mess(41,2007,1)-WNUMBATCH-"("+mess(6,772,1)-":"-WOLDDOCID+") :"-mess(9,2007,1),1) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
#         WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, "Not applicable") #WOLDDOCID+"->"+WNEWDOCID
#          For WK = 1 To maxtab(WERR_TAB)
##          Call ECR_TRACE(""+WERR_TAB(J),1) From GESECRAN
#           WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, WERR_TAB(J)) #WOLDDOCID+"->"+WNEWDOCID
#          Next WK
#        Else
##        Call ECR_TRACE("Launching receipt process"-WNUMBATCH-"(external reference :"-WOLDDOCID+") -> (X3 reference :"-WNEWDOCID+") : succeeded",0) From GESECRAN
#         Call ECR_TRACE(mess(41,2007,1)-WNUMBATCH-"("+mess(6,772,1)-":"-WOLDDOCID+") -> ("+mess(6,3701,1)-" :"-WNEWDOCID+") :"-mess(7,2007,1),0) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
#         WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, WERR_TAB(J)) #WOLDDOCID+"->"+WNEWDOCID
#        Endif
#          Raz WERR_TAB()

        #/ Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
      Else
#      Dbgaff

        If WOK = [V]CST_AOK
          WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, "Not applicable") #WOLDDOCID+"->"+WNEWDOCID
          WSTEP = WSTEP + 1 #RBA
          WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 11, mess(3,2003,1)) #Terminated
          WMYEDISTO.STA = 3
          WOK = fmet WMYEDISTO.AUPDATE()
        Endif
      Endif
      FreeGroup WMYEDISTO : WMYEDISTO = null
    Next WJ
  Endif
Return

##********************************************************************
## RECEIPT_GENERATE_IMP_FILE
##********************************************************************
##* @param WPOS_MSG
##* @param WDOCID_TAB
##* @param WUUID_TAB
##* @param WPROTOTYPE_JSON
##* @param WFLGMUX
##* @param WEDIRUN
##* @param WSTEP
##* @param WMYLOG
##* @return WOK
##*!
Funprog RECEIPT_GENERATE_IMP_FILE(WPOS_MSG, WDOCID_TAB, WUUID_TAB, WPROTOTYPE_JSON, WFLGMUX, WEDISTRREC, WEDIRUN, WSTEP, WMYLOG)
Value Integer WPOS_MSG
Value Char WDOCID_TAB()(1..)
Value Char WUUID_TAB()(1..)
Value Clbfile WPROTOTYPE_JSON
Value Integer WFLGMUX
Variable Instance WEDISTRREC Using C_EDISTRREC
Variable Instance WEDIRUN Using C_EDIRUN
Variable Integer WSTEP
Variable Instance WMYLOG Using C_ALOG

  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WFLG_OK_TO_IMPORT_TAB(1..)
  Local Integer WLIMIT : WLIMIT = 10
  Local Integer WFLG_OK_TO_COPY_TAB(1..)

  Local Char WIMPFILE(100) #import filename to build
  If WFLGMUX = [V]CST_AYES
    WIMPFILE = WEDISTRREC.NUMBATCH+".dat"
  Else
    WIMPFILE = WEDISTRREC.NUMBATCH+"_"+WDOCID_TAB(1)+".dat"
  Endif

  If WEDISTRREC.NBDOC_IMP > 0
    Local Clbfile WRESHEAD
    Local Clbfile WRESBODY
    Local Clbfile WARGUMENTS
    Local Clbfile WOPTION
    Local Integer WSTATUSCODE
    Local Integer WOK

    Local Clbfile WJSON_UUID_LIST #tableau char 36 JSON
    For I = 1 To maxtab(WUUID_TAB())-1
      WJSON_UUID_LIST = WJSON_UUID_LIST + '"'+WUUID_TAB(I)+'",'
    Next I
    WJSON_UUID_LIST = WJSON_UUID_LIST + '"'+WUUID_TAB(I)+'"'
    WJSON_UUID_LIST = '['+WJSON_UUID_LIST+']'

    Local Char WTEST(5)
    Case WEDIRUN.TESTFLG
      When [V]CST_AYES : WTEST = "true"
      When [V]CST_ANO  : WTEST = "false"
    Endcase

    WOPTION ='{'+
&             '  "messageMapping" : "'+num$(WEDISTRREC.EMSG(WPOS_MSG).MSG_UUID)+'",'+
&             '  "sequentialFile" : "'+num$(WEDISTRREC.EMSG(WPOS_MSG).SEQ_UUID)+'",'+
&             '  "flow" : "'+num$(WEDISTRREC.FLO_UUID)+'",'+
&             '  "protocol" : "'+num$(WEDISTRREC.PTC_UUID)+'",'+
&             '  "prototype" : '+WPROTOTYPE_JSON+','+
&             '  "repName" : "'+WEDISTRREC.EMSG(WPOS_MSG).REPCOD+'",'+
&             '  "folder" : "'+WEDISTRREC.X3FOLDER+'",'+
&             '  "uuid" : '+WJSON_UUID_LIST+','+
&             '  "fileName" : "'+WIMPFILE+'",'+
&             '  "keepCache" : true,'+
&             '  "test" : '+WTEST+
&             '}'

    WARGUMENTS = '"'+WEDISTRREC.NUMBATCH+'",'+WOPTION
    #Issue 112470 - 2015-11-12 by RBA - renaming JS module
    WSTATUSCODE = func ASYRWEBSER.EXEC_JS("syracuse-edi/lib/edi_Process", "generateImportFiles", "wait", WARGUMENTS, "0,0", 0, "", "0", WRESHEAD, WRESBODY)
    #/Issue 112470
    Local Char WRES_FILENAME_TAB(250)(1..,1..WLIMIT)
    Local Char WRES_UUID_TAB(36)(1..)         # to recover the UUID
    Local Integer WRES_STA_TAB(1..)           # to recover the status list created
    Local Char WRES_DIAG_SEVERITY_TAB(250)(1..,1..WLIMIT)      # to recover the severity (error) of each failed document
    Local Char WRES_DIAG_MESSAGE_TAB(250)(1..,1..WLIMIT)       # to recover the error message of each failed document

    Local Integer WPOS

    WOK = func EDILIBB.PARSE_JS_GENERATE_IMPORT_FILES(WSTATUSCODE, WRESHEAD, WRESBODY, WEDISTRREC.NUMBATCH, WDOCID_TAB, WRES_FILENAME_TAB, WRES_UUID_TAB, WRES_STA_TAB, WRES_DIAG_SEVERITY_TAB,
& WRES_DIAG_MESSAGE_TAB , WMYLOG)
    If WOK = [V]CST_AOK
      For J = 1 To maxtab(WRES_UUID_TAB())
        WSTEP = WSTEP + 1 #17
        Local File EDITMPDOC [ETC]
        Read [ETC]ETC0 = WEDISTRREC.NUMBATCH;WDOCID_TAB(J)
        If !fstat
          Local File EDITRKDOC [EDK]
          Trbegin [EDK]
          [EDK]DOCID     = WDOCID_TAB(J)
          [EDK]NUMBATCH  = WEDISTRREC.NUMBATCH
          [EDK]NUMLIN    = func EDIRUN_CSTD.GET_EDITRKDOC_NUMLIN(WDOCID_TAB(J), WEDISTRREC.CATTYP)
          [EDK]EXTID     = WDOCID_TAB(J)
          [EDK]FLOCOD    = WEDISTRREC.FLOCOD
          [EDK]FLOREL    = WEDISTRREC.FLOREL
          [EDK]CPY       = [ETC]CPY
          [EDK]FCY       = [ETC]FCY
          [EDK]BPRNUM    = [ETC]BPRNUM
          [EDK]BPAADD    = [ETC]BPAADD
          [EDK]CATTYP    = WEDISTRREC.CATTYP
          [EDK]NUM       = WEDIRUN.NUM
          [EDK]CATACT    = [ETC]CATACT
          [EDK]CATCOD    = WEDISTRREC.CATCOD
          [EDK]RUNDATE   = WEDIRUN.LASRUNDAT
          [EDK]TESTFLG   = WEDIRUN.TESTFLG
          [EDK]TRKSTA    = 1 #Pending
          [EDK]FLGUPD    = 1
          [EDK]PTCCOD    = [ETC]PTCCOD  #Issue 111819 - 2015-10-20
          Write [EDK]
          If !fstat
            Commit
            WERR = ""
            WOK = fmet WEDIRUN.MET_LOG_MSG(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, [V]CST_AINFO, 7, WDOCID_TAB(J), WMYLOG)
            WRET_VALUE = [V]CST_AOK
          Else
            Rollback
            WERR = ""
            WOK = fmet WEDIRUN.MET_LOG_MSG(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, [V]CST_AERROR, 7, WDOCID_TAB(J), WMYLOG)
            WRET_VALUE = [V]CST_AERROR
          Endif

          LogicClose File [EDK]
          LogicClose File [ETC]
          WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
        Else
          #pas d'enregistrement dans EDITMPDOC  !
          WRET_VALUE = [V]CST_AERROR
        Endif

        WSTEP = WSTEP + 1
        If WRET_VALUE = [V]CST_AOK
          WOK = fmet WEDIRUN.MET_LOG_MSG(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, [V]CST_AINFO, 20, mess(7,2007,1), WMYLOG)
          If WRES_STA_TAB(J) = [V]CST_AYES
            WEDISTRREC.NBFIL_IMP_OK = WEDISTRREC.NBFIL_IMP_OK + 1
            WFLG_OK_TO_IMPORT_TAB(J) = [V]CST_ATRUE
            For K = 1 To WLIMIT #here there will be only 1 import file
              If WRES_FILENAME_TAB(J,K) <> ""
        #      ADD To EFIL COLLECTION
                WPOS = fmet WEDISTRREC.ADDLINE("EFIL", [V]CST_ALASTPOS)
                WEDISTRREC.EFIL(WPOS).NUMBATCH     = WEDISTRREC.NUMBATCH
                WEDISTRREC.EFIL(WPOS).DOCID        = WDOCID_TAB(J)
                WEDISTRREC.EFIL(WPOS).CATTYP       = WEDISTRREC.CATTYP
                WEDISTRREC.EFIL(WPOS).RES_UUID     = toUuid(WRES_UUID_TAB(J))
                WEDISTRREC.EFIL(WPOS).RES_FILENAME = WRES_FILENAME_TAB(J,K)
                WEDISTRREC.EFIL(WPOS).RES_STA      = WRES_STA_TAB(J)

                Local Instance WMYEDISTO Using C_EDISTO
                WMYEDISTO = NewInstance C_EDISTO AllocGroup null
                WOK = fmet WMYEDISTO.AREAD(WEDISTRREC.NUMBATCH, WDOCID_TAB(J))
                If WOK = [V]CST_AOK #WERR = "SAS accessibility" #reading created SAS
                  WPOS = fmet WMYEDISTO.ADDLINE("ESTU", [V]CST_ALASTPOS)
                  WMYEDISTO.ESTU(WPOS).CODE     = "PHYFILE"+num$(K)
                  WMYEDISTO.ESTU(WPOS).DOCDES   = mess(5,7959,1)-"/"-mess(116,2006,1) #"Data / Physical file"
                  WMYEDISTO.ESTU(WPOS).DOCCLASS = ""
                  WMYEDISTO.ESTU(WPOS).DOCKEY   = WRES_FILENAME_TAB(J,K)
                  WOK = fmet WMYEDISTO.AUPDATE()
                Endif
                FreeGroup WMYEDISTO : WMYEDISTO = null
              Endif
            Next K

          Else
            WFLG_OK_TO_IMPORT_TAB(J) = [V]CST_AFALSE
            WFLG_OK_TO_COPY_TAB(J) = [V]CST_AFALSE
            WEDISTRREC.NBFIL_IMP_KO = WEDISTRREC.NBFIL_IMP_KO + 1
            WOK = fmet WEDIRUN.MET_LOG_MSG(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, [V]CST_AERROR, 20, mess(9,2007,1), WMYLOG)
            #SAS & TRK update status = 4 - Error
            WOK = fmet WEDIRUN.MET_UPDATE_STA(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, 4, WMYLOG)
            WRET_VALUE = [V]CST_AERROR
          Endif
        Else
          WOK = fmet WEDIRUN.MET_LOG_MSG(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, [V]CST_AERROR, 20, mess(9,2007,1), WMYLOG)
          #error
          WFLG_OK_TO_IMPORT_TAB(J) = [V]CST_AFALSE
          WFLG_OK_TO_COPY_TAB(J) = [V]CST_AFALSE
          WEDISTRREC.NBFIL_IMP_KO = WEDISTRREC.NBFIL_IMP_KO + 1
          WSTEP = WSTEP + 1
          WOK = fmet WEDIRUN.MET_LOG_MSG(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, [V]CST_AERROR, 20, mess(9,2007,1), WMYLOG)
          #SAS & TRK update status = 4 - Error
          WOK = fmet WEDIRUN.MET_UPDATE_STA(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, 4, WMYLOG)
          WRET_VALUE = [V]CST_AERROR
        Endif

      Next J
    Else
      #error generate import files
      For J = 1 To maxtab(WDOCID_TAB())
        WFLG_OK_TO_IMPORT_TAB(J) = [V]CST_AFALSE
        WFLG_OK_TO_COPY_TAB(J) = [V]CST_AFALSE
        WEDISTRREC.NBFIL_IMP_KO = WEDISTRREC.NBFIL_IMP_KO + 1
        WOK = fmet WEDIRUN.MET_LOG_MSG(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, [V]CST_AERROR, 20, mess(9,2007,1), WMYLOG)
        #SAS & TRK update status = 4 - Error
        WOK = fmet WEDIRUN.MET_UPDATE_STA(WEDISTRREC.NUMBATCH, WDOCID_TAB(J), WEDISTRREC.CATTYP, WSTEP, 4, WMYLOG)

      Next J

      WRET_VALUE = [V]CST_AERROR
    Endif
  Else
    WRET_VALUE = [V]CST_AERROR
  Endif

End WRET_VALUE


################################################

