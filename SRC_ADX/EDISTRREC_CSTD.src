##        WERRSTR = WERRSTR + "origin environment="+ERR_ENV
##      Endif
#    Else
#      WFLG_ERR = [V]CST_AFALSE
#    Endif
#  Wend
#  Kill WABRCLA
#
#  For WNB_ERR = 1 To maxtab(ERR_MESS_TAB)
#    WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 7, ERR_PROP_TAB(WNB_ERR) - ERR_MESS_TAB(WNB_ERR), WMYLOG)
#  Next
##/Issue X3-7673 - 2017-09-06 by RBA - CRUD
#Return

$RECEIPT_PROCESS_REP_CRUD_TRK
If WFLG_IMPORT = [V]CST_AFALSE
WSTEP = WSTEP + 1
  Local File EDITRKDOC [EDK]
  Trbegin [EDK]
  [EDK]DOCID     = [ETC]DOCID
  [EDK]NUMBATCH  = this.NUMBATCH
  [EDK]NUMLIN    = func EDIRUN_CSTD.GET_EDITRKDOC_NUMLIN([ETC]DOCID, this.CATTYP)
  [EDK]EXTID     = [ETC]DOCID
  [EDK]FLOCOD    = this.FLOCOD
  [EDK]FLOREL    = this.FLOREL
#  [EDK]FLGMUX    = WFLGMUX  #
  [EDK]CPY       = [ETC]CPY
  [EDK]FCY       = [ETC]FCY
  [EDK]BPRNUM    = [ETC]BPRNUM
  [EDK]BPAADD    = [ETC]BPAADD
  [EDK]CATTYP    = this.CATTYP
  [EDK]NUM       = WEDIRUN.NUM
  [EDK]CATACT    = [ETC]CATACT
  [EDK]CATCOD    = this.CATCOD
  [EDK]RUNDATE   = WEDIRUN.LASRUNDAT
  [EDK]TESTFLG   = WEDIRUN.TESTFLG
  [EDK]TRKSTA    = 1 #Pending
  [EDK]FLGUPD    = 1
  [EDK]PTCCOD    = [ETC]PTCCOD  #Issue 111819 - 2015-10-20
  Write [EDK]
  If !fstat
    Commit
    WERR = ""
    WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 7, [ETC]DOCID, WMYLOG)
#      WRET_VALUE = [V]CST_AOK
  Else
    Rollback
    WERR = ""
    WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 7, [ETC]DOCID, WMYLOG)
#      WRET_VALUE = [V]CST_AERROR
  Endif

  LogicClose File [EDK]
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
Endif
Return

$REPRESENTATION_ERROR_STRUCTURE
  WSTEP = WSTEP + 1
  # Fill the error structure
  Local Integer WNB_ERR  : WNB_ERR  = 0
  Local Integer WFLG_ERR : WFLG_ERR = [V]CST_AFALSE

  Local Integer IF_ERROR
  Local Integer ERR_STAT, ERR_CAT
  Local Char ERR_PROP(250), ERR_LAB(250), ERR_MESS(250), ERR_ENV(250)
  Local Char ERR_PROP_TAB(250)(1..), ERR_MESS_TAB(250)(1..)

  Local Char WABRCLA(8) : WABRCLA = ""
  Local File ASHW [ASW]
  Read [ASW]ASW0 = right$(WMYREP.AINF.NAMCLA,3) #R_EDISDNO
  If !fstat
    WABRCLA = [ASW]ABRCLA
  Endif
  LogicClose File [ASW]

#  IF_ERROR = fmet WMYREP.SDN.ASEARCHINFOS([V]CST_ALL,"",[V]CST_AINFO,[V]CST_AGREATER)
  IF_ERROR = evalue('fmet WMYREP.'+WABRCLA+'.ASEARCHINFOS([V]CST_ALL,"",[V]CST_AINFO,[V]CST_AGREATER)')
  # Display an error header log
  If IF_ERROR = [V]CST_AOK
    WFLG_ERR = [V]CST_ATRUE
#    WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 7, "Error stack generated", WMYLOG)
  Endif
  While WFLG_ERR = [V]CST_ATRUE #IF_ERROR <> [V]CST_AOK
#    IF_ERROR = fmet WMYREP.SDN.AGETNEXTINFOS(ERR_STAT, ERR_PROP, ERR_LAB, ERR_MESS, ERR_CAT, ERR_ENV)
    IF_ERROR = evalue('fmet WMYREP.'+WABRCLA+'.AGETNEXTINFOS(ERR_STAT, ERR_PROP, ERR_LAB, ERR_MESS, ERR_CAT, ERR_ENV)')
    If IF_ERROR = [V]CST_AOK
      WNB_ERR = WNB_ERR + 1
      Case ERR_STAT
        When [V]CST_AERROR   : ERR_MESS_TAB(WNB_ERR) = "Error :"-ERR_MESS
        When [V]CST_AWARNING : ERR_MESS_TAB(WNB_ERR) = "Warning :"-ERR_MESS
        When [V]CST_AFATAL   : ERR_MESS_TAB(WNB_ERR) = "Fatal error :"-ERR_MESS
      Endcase
      ERR_PROP_TAB(WNB_ERR) = ERR_PROP
#      If ERR_CAT <> 0
#        WERRSTR = WERRSTR + "application category="+num$(ERR_CAT)
#      Endif
#      If ERR_ENV<>""
#        WERRSTR = WERRSTR + "origin environment="+ERR_ENV
#      Endif
    Else
      WFLG_ERR = [V]CST_AFALSE
    Endif
  Wend
  #Kill WABRCLA

  For WNB_ERR = 1 To maxtab(ERR_MESS_TAB)
    WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(I).DOCID, this.CATTYP, WSTEP, [V]CST_AERROR, 7, ERR_PROP_TAB(WNB_ERR) - ERR_MESS_TAB(WNB_ERR), WMYLOG)
  Next
#/Issue X3-7673 - 2017-09-06 by RBA - CRUD
Return

$RECEIPT_PROCESS_REP_INSTANCIATED_FREE
  #9- free instance
  If WFLG_REP_INSTANCIATED = [V]CST_ATRUE
    FreeGroup WMYREP : WMYREP = null
    WFLG_REP_INSTANCIATED = [V]CST_AFALSE
  Endif
Return

$RECEIPT_PROCESS_EDITMPDOC_UPDATE
  #10- MAJ document status in EDITMPDOC
  Trbegin [ETC]
  [ETC]FLGVALIDDOC  = this.EINS(I).RES_STA
  [ETC]UUID_INSJSON = WRES_JSON_INS_UUID
  Rewrite [ETC]
  If !fstat
    Commit
  Else
    Rollback
  Endif
Return

$RECEIPT_PROCESS_GENERATE_IMPORT_FILE_FOR_CURRENT
#If WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_ATRUE
  If WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_ATRUE and WFLG_IMPORT = [V]CST_ATRUE #Issue X3-7673 - 2017-09-06 by RBA - CRUD
    If this.EINS(I).RES_STA = [V]CST_AYES
      If WFLGMUXIMP = [V]CST_ANO
        If WEDIRUN.TESTFLG = [V]CST_ANO      #111044
          WNBFIL = WNBFIL + 1
          WIMP_REAL_TAB_DOCID(WNBFIL)     = this.EINS(I).DOCID
        Endif
        this.NBDOC_IMP = 1
        WIMP_SAVED_TAB_JSON_UUID(this.NBDOC_IMP) = WRES_JSON_INS_UUID
        WIMP_SAVED_TAB_DOCID(this.NBDOC_IMP)     = this.EINS(I).DOCID

  #        WNBFIL = WNBFIL + 1
  #        WNBFIL = 1         #111044
  #        WIMP_SAVED_TAB_JSON_UUID(WNBFIL) = WRES_JSON_INS_UUID
  #        WIMP_SAVED_TAB_DOCID(WNBFIL)     = this.EINS(I).DOCID

  #        WRET_VALUE = func RECEIPT_GENERATE_IMP_FILE(WPOS_MSG, this.EINS(I).DOCID, WRES_JSON_INS_UUID, WPROTOTYPE_JSON, WFLGMUXIMP, this, WEDIRUN, WSTEP, WMYLOG)    #111044
        WRET_VALUE = func RECEIPT_GENERATE_IMP_FILE(WPOS_MSG, WIMP_SAVED_TAB_DOCID, WIMP_SAVED_TAB_JSON_UUID, WPROTOTYPE_JSON, WFLGMUXIMP, this, WEDIRUN, WSTEP, WMYLOG)


        If WRET_VALUE <> [V]CST_AERROR
          If WEDIRUN.TESTFLG = [V]CST_AYES:   WSTEP = WSTEP + 1
             WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, WIMP_SAVED_TAB_DOCID, this.CATTYP, WSTEP, 3, WMYLOG)
           Endif

        Else
          WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, WIMP_SAVED_TAB_DOCID, this.CATTYP, WSTEP, 4, WMYLOG)
        Endif
      Endif
    Else
      WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_AFALSE
    Endif
  Endif
#  Endif
Return

$RECEIPT_PROCESS_GENERATE_IMPORT_FILE_FOR_ALL
  If WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_ATRUE ##SAM 122810 (JUCON 05/05/17)
    WRET_VALUE=[V]CST_AOK
#    If WEDIRUN.TESTFLG = [V]CST_AFALSE #12 - in case of test mode
    Local File EDITMPDOC [ETC]
#    If [ETC]FLGMUXIMP = [V]CST_AYES  #111044   # X3-97498 JUCON(21/06/18)
    If WFLGMUXIMP = [V]CST_AYES                # ini X3-97498 JUCON(21/06/18)

#      If WEDIRUN.TESTFLG = [V]CST_AYES #12 - in case of test mode #111044
#        WSTEP = WSTEP + 1 #20
#
#        Filter [ETC] Where NUMBATCH = this.NUMBATCH and FLOCOD = this.FLOCOD and FLOREL = this.FLOREL and FLGMUXIMP = [V]CST_AYES and FLGVALIDDOC = [V]CST_AYES
#        For [ETC]
#          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 28, "", WMYLOG)
#          WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, 3, WMYLOG)
#        Next
#        Filter [ETC]
#
#        WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_AFALSE
#     Endif

#     Else     #End X3-97498 JUCON(21/06/18)

        this.NBDOC_IMP = 0
#        Local File EDITMPDOC [ETC] # X3-97498 JUCON(21/06/18)
        Filter [ETC] Where NUMBATCH = this.NUMBATCH and FLOCOD = this.FLOCOD and FLOREL = this.FLOREL and FLGMUXIMP = [V]CST_AYES and FLGVALIDDOC = [V]CST_AYES
        For [ETC]
          If WEDIRUN.TESTFLG = [V]CST_AYES #12 - in case of test mode #111044
            WSTEP = WSTEP + 1 #20
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, [V]CST_AINFO, 28, "", WMYLOG)
            WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, [ETC]DOCID, this.CATTYP, WSTEP, 3, WMYLOG)
            WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_AFALSE
          Endif
          this.NBDOC_IMP = this.NBDOC_IMP + 1
          WIMP_SAVED_TAB_JSON_UUID(this.NBDOC_IMP) = [ETC]UUID_INSJSON
          WIMP_SAVED_TAB_DOCID(this.NBDOC_IMP)     = [ETC]DOCID
        Next
        Filter [ETC]

#        LogicClose File [ETC]  # ini X3-97498 JUCON(21/06/18)
        WRET_VALUE = func RECEIPT_GENERATE_IMP_FILE(WPOS_MSG, WIMP_SAVED_TAB_DOCID, WIMP_SAVED_TAB_JSON_UUID, WPROTOTYPE_JSON, WFLGMUXIMP, this, WEDIRUN, WSTEP, WMYLOG)
        If WRET_VALUE=[V]CST_AOK
          this.NBFIL_IMP_OK=this.NBINS_OK
        Endif
      Endif
    #Endif    # end X3-97498 JUCON(21/06/18)
    LogicClose File [ETC]
#  Else     ##SAM 122810 (JUCON 05/05/17)
#    WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_AFALSE
  Endif  ##SAM 122810 (JUCON 05/05/17)
Return

$RECEIPT_PROCESS_SAS_FREE
  If this.NBSAS_OK > 0
    FreeGroup WMYEDISTO : WMYEDISTO = null
  Endif
Return

$RECEIPT_PROCESS_IMPORT
  If WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_ATRUE and WFLG_IMPORT = [V]CST_ATRUE #Issue X3-7673 - 2017-09-06 by RBA - CRUD
    If WEDIRUN.TESTFLG = [V]CST_ANO and WRET_VALUE <> [V]CST_AERROR   #111044
    If WNBFIL>0
      For K=1 To WNBFIL
        WIMP_SAVED_TAB_DOCID=WIMP_REAL_TAB_DOCID(K)
        WOK = fmet this.MET_RECEIPT_IMPORT_FILES(WPOS_MSG, WIMP_SAVED_TAB_DOCID, WSTEP, WEDIRUN, WMYLOG)
      Next                #111044
    Else
      #mode test
      WERR =mess(152,2006,1)# Test mode enabled - Importation won't be done
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
#      WOK = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AINFO) From ASYRASYNC
    Endif
  Endif
Endif
##  If WFLG_GO_TO_NEXT_FLOW_STEP = [V]CST_ATRUE    ##SAM 122810 (JUCON 05/05/17)
#    If WEDIRUN.TESTFLG = [V]CST_ANO and WRET_VALUE <> [V]CST_AERROR
#      #111044
