#********************************************************************
# proc RAZ_FLOW
#********************************************************************
#*
#* Set default values
#*
#********************************************************************
#*
#*!
$RAZ_FLOW
  this.FLOCOD = ""
  this.FLOREL = ""
  this.ALLFLO = 1
Return



###################################################################################
# PROCESS EXECUTION FUNCTIONS
###################################################################################

#********************************************************************
# Method RUN_ISSUE_PROCESS
#********************************************************************
#
#********************************************************************
#*!
$RUN_ISSUE_PROCESS
  Gosub PROCESS_GET_NUMBATCH        # step 1 : Get a batch number
  Gosub PROCESS_LOG_CREATE          # step 2 : Log instanciation
  Gosub PROCESS_LOG_PARAMETERS      # step 3 : Log parameters
  Gosub PROCESS_LOG_ACCESS_KEYS     # step 4 : Get EDI access rights keys in category's setup
  Gosub PROCESS_LOG_START           # step 5 : Log start
  Gosub PROCESS_ISSUE
  Gosub PROCESS_LOG_CLOSE           # step 7 : Log closure
  Gosub PROCESS_EDITMPLOG_DELETE    # step 8 : Delete log table content
  Gosub PROCESS_EDITMPDOC_DELETE    # step 8 : Delete working table  # 112149 deleting records of this launching in the working table
  Gosub PROCESS_LOG_END             # step 9 : Log end
Return



#********************************************************************
# Method RUN_RECEIPT_PROCESS
#********************************************************************
#
#
#
#
#********************************************************************
#*!
$RUN_RECEIPT_PROCESS
  Gosub PROCESS_GET_NUMBATCH          # step 1 : Get a batch number
  Gosub PROCESS_LOG_CREATE            # step 2 : Log instanciation
  Gosub PROCESS_LOG_PARAMETERS        # step 3 : Log parameters
#  Gosub PROCESS_LOG_ACCESS_KEYS       # step 4 : Get EDI access rights keys in category's setup NO NEEDED IN RECEIPT
  Gosub PROCESS_LOG_START             # step 5 : Log start
  Gosub PROCESS_RECEIPT
  Gosub PROCESS_LOG_CLOSE             # step 7 : Log closure
  Gosub PROCESS_EDITMPLOG_DELETE      # step 8 : Delete log table content
  Gosub PROCESS_EDITMPDOC_DELETE      # step 8 : Delete working table  # 112149 deleting records of this launching in the working table
  Gosub PROCESS_LOG_END               # step 9 : Log end
Return


#********************************************************************
# PROCESS_GET_NUMBATCH - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Get a batch number
#********************************************************************
#*!
$PROCESS_GET_NUMBATCH
  Local Char WNUMBATCH(20)
  WNUMBATCH = func GET_EDI_COUNTER()
Return

#********************************************************************
# PROCESS_LOG_CREATE - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Log instanciation
#********************************************************************
#*!
$PROCESS_LOG_CREATE
  Local Integer WNBLEFT
  Local Integer WNBRIGHT
  Local Char WERR(250)

  Local Instance WMYLOG Using C_ALOG
  WMYLOG = NewInstance C_ALOG AllocGroup null
  WOK = fmet WMYLOG.ASETNAME(num$(WNUMBATCH))

  WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)
  If this.CATACT = 1 #only for Issue sense
    WERR = mess(40,2007,1)-num$(WNUMBATCH) #Launching EDI issue processing
    WNBLEFT = abs((115-len(WERR))/2)
    WNBRIGHT = 115-len(WERR)-WNBLEFT
    WOK = fmet WMYLOG.APUTLINE(string$(WNBLEFT," ")+WERR+string$(WNBRIGHT," "),[V]CST_AINFO)
  Else
    WERR = mess(41,2007,1)-num$(WNUMBATCH) #Launching EDI receipt processing
    WNBLEFT = abs((115-len(WERR))/2)
    WNBRIGHT = 115-len(WERR)-WNBLEFT
    WOK = fmet WMYLOG.APUTLINE(string$(WNBLEFT," ")+WERR+string$(WNBRIGHT," "),[V]CST_AINFO)
  Endif
  WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
Return


#********************************************************************
# PROCESS_LOG_PARAMETERS - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Log parameters
#********************************************************************
#*!
$PROCESS_LOG_PARAMETERS
  # Open the log file
  Local Char TIT(50), TEXTE(115)
  Local Char LAN(3)
  LAN=this.ACTX.LAN

  #IDENTIFICATION
  Call TEXTELAN(3563,TIT,LAN) From OBJDIV
  WOK = fmet WMYLOG.APUTLINE("*"-toupper(TIT),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)
  #Number
  Call TEXTELAN(171,TIT,LAN) From OBJDIV
  TEXTE = format$("20X",TIT)+": "+num$(this.NUM)+" / "+this.RUNDES
  WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)

  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)

  #PARAMETERS
  Call TEXTELAN(881,TIT,LAN) From OBJDIV
  WOK = fmet WMYLOG.APUTLINE("*"-toupper(TIT),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"="),0)
  #EDI partner
  Call TEXTELAN(52054,TIT,LAN) From OBJDIV
  TEXTE = format$("20X",TIT)+": "+this.PARCOD-"/"-this.PARDES
  #EDI partner type
  Call TEXTELAN(52059,TIT,LAN) From OBJDIV
  TEXTE = format$("60X",TEXTE)+format$("20X",TIT)+":"-mess(this.PARTYP,2009,1)
  WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)
  #Category code
  Call TEXTELAN(52045,TIT,LAN) From OBJDIV
  TEXTE = format$("20X",TIT)+": "+this.CATCOD-"/"-this.CATDES
  #Category type
  Call TEXTELAN(3399,TIT,LAN) From OBJDIV
  TEXTE = format$("60X",TEXTE)+format$("20X",TIT)+":"-mess(this.CATTYP,2012,1)
  WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)
  If this.ALLFLO=2
    #All flows
    Call TEXTELAN(51141,TIT,LAN) From OBJDIV
    TEXTE = format$("20X",TIT)+":"-mess(this.ALLFLO,1,1)
    WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)
  Else
    #Flow ID
    Call TEXTELAN(50172,TIT,LAN) From OBJDIV
    TEXTE = format$("20X",TIT)+": "+ this.FLOCOD
    #Release
    Call TEXTELAN(1281,TIT,LAN) From OBJDIV
    TEXTE = format$("60X",TEXTE)+format$("20X",TIT)+":"-this.FLOREL-"/"-this.FLODES
    WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)
  Endif
  #Duplicate
  Call TEXTELAN(42492,TIT,LAN) From OBJDIV
  TEXTE = format$("20X",TIT)+":"-mess(this.DUPLICATEFLG,1,1)
  WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)
  #Test
  Call TEXTELAN(1485,TIT,LAN) From OBJDIV
  TEXTE = format$("20X",TIT)+":"-mess(this.TESTFLG,1,1)
  WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
  If this.CATACT = 1 #only for Issue sense
    #FILTERS
    Call TEXTELAN(11526,TIT,LAN) From OBJDIV
    WOK = fmet WMYLOG.APUTLINE("*"-toupper(TIT),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)
    #field
    Call TEXTELAN(1261,TIT,LAN) From OBJDIV
    TEXTE = format$("13X",TIT)
    #Description
    Call TEXTELAN(14410,TIT,LAN) From OBJDIV
    TEXTE += format$("25X",TIT)
    #Mandatory
    Call TEXTELAN(717,TIT,LAN) From OBJDIV
    TEXTE += format$("12X",TIT)
    #Operator
    Call TEXTELAN(36873,TIT,LAN) From OBJDIV
    TEXTE += format$("15X",TIT)
    #Start
    Call TEXTELAN(828,TIT,LAN) From OBJDIV
    TEXTE += format$("25X",TIT)
    #End
    Call TEXTELAN(829,TIT,LAN) From OBJDIV
    TEXTE += format$("25X",TIT)

    WOK = fmet WMYLOG.APUTLINE(TEXTE,0)
    WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)

    For I=1 To maxtab(this.EDRD)
      If this.EDRD(I)<>null and find(this.EDRD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        TEXTE=format$("13X",this.EDRD(I).FLD)+format$("25X",this.EDRD(I).FLDNAM)
        TEXTE+=format$("12X",mess(this.EDRD(I).MANDATORY,2018,1))+format$("15X",mess(this.EDRD(I).OPERATOR,2023,1))
        TEXTE+=format$("25X",this.EDRD(I).FLDVAL1)+format$("25X",this.EDRD(I).FLDVAL2)
        WOK = fmet WMYLOG.APUTLINE(TEXTE,[V]CST_AINFO)
      Endif
    Next
    WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
  Endif
Return

#********************************************************************
# PROCESS_LOG_ACCESS_KEYS - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Get EDI access rights keys in category's setup
#********************************************************************
#*!
$PROCESS_LOG_ACCESS_KEYS
  Local Char WCODE_DOCID(20)  : Local Char WFLD_DOCID(100)
  Local Char WCODE_CPY(20)    : Local Char WFLD_CPY(20)
  Local Char WCODE_FCY(20)    : Local Char WFLD_FCY(20)
  Local Char WCODE_BPANUM(20) : Local Char WFLD_BPANUM(20)
  Local Char WCODE_BPAADD(20) : Local Char WFLD_BPAADD(20)
  Local Char WCODE_EXTID(100) : Local Char WFLD_EXTID(100)
  Local Integer WSEVERITY
  Local Char WCATTRGTAB (20)

  #KEYS
  TIT = mess(1,2006,1) #"Access keys"
  WOK = fmet WMYLOG.APUTLINE("*"-toupper(TIT),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)
  #Key
  TIT = mess(55,123,1)
  TEXTE = format$("13X",TIT)
  #field
  Call TEXTELAN(1261,TIT,LAN) From OBJDIV
  TEXTE += format$("50X",TIT)
  WOK = fmet WMYLOG.APUTLINE(TEXTE,WOK)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)

  #new index management
  Local File EDICAT [ECA]
  Read [ECA]ECA0 = this.CATCOD
  If !fstat #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#    If [F:ECA]CATTYP>5
#      WERR = mess(8,2006,1)+"."-mess(170,2006,1) #Category not allowed
#      Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
#      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
#      Return
#    Endif
    WCATTRGTAB = [F:ECA]CATTRGTAB
    WCODE_DOCID  = "DOCID"
    WFLD_DOCID  = [ECA]DESCRIPT #gerer le cas où il y a des +
    If WFLD_DOCID  = "" : WSEVERITY = [V]CST_AWARNING : Else WSEVERITY = 0 : Endif
    TEXTE=format$("13X",WCODE_DOCID)+format$("50X",WFLD_DOCID)
    WOK = fmet WMYLOG.APUTLINE(TEXTE,WSEVERITY)
  Else
    WERR = mess(20,2007,1) #"No index defined in category setup"
    #ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Endif
LogicClose File [ECA]
  #/new index management
#110811_US11
  Local File EDICATK [ECK]
#  Filter [ECK] Where [ECK]CATCOD = this.CATCOD
  Filter [ECK] Where [ECK]CATCOD = this.CATCOD and [ECK]FLD <> "" # X3-97369 (JUCON 21/06/18)
  For [ECK]
#    If [ECK]FLD <> "" # X3-97369 (JUCON 21/06/18)
      Local File EDICATREF [ECR]    #110811 US11
      Read[ECR]ECR0=this.CATTYP;WCATTRGTAB
      If fstat=[V]CST_AOK
        If [ECR]CTRLGRP = "1"
          Case [ECK]CODE
            When "FCY"    : WCODE_FCY    = [ECK]CODE : WFLD_FCY    = [ECK]FLD
                           If WFLD_FCY    = "" : WSEVERITY = [V]CST_AWARNING : Else WSEVERITY = 0 : Endif
                           TEXTE=format$("13X",WCODE_FCY)+format$("13X",WFLD_FCY)
                           WOK = fmet WMYLOG.APUTLINE(TEXTE,WSEVERITY)
            When "BPANUM" : WCODE_BPANUM = [ECK]CODE : WFLD_BPANUM = [ECK]FLD
                            If WFLD_BPANUM = "" : WSEVERITY = [V]CST_AWARNING : Else WSEVERITY = 0 : Endif
                            TEXTE=format$("13X",WCODE_BPANUM)+format$("13X",WFLD_BPANUM)
                            WOK = fmet WMYLOG.APUTLINE(TEXTE,WSEVERITY)
            When "BPAADD" : WCODE_BPAADD = [ECK]CODE : WFLD_BPAADD = [ECK]FLD
                            If WFLD_BPAADD = "" : WSEVERITY = [V]CST_AWARNING : Else WSEVERITY = 0 : Endif
                            TEXTE=format$("13X",WCODE_BPAADD)+format$("13X",WFLD_BPAADD)
                            WOK = fmet WMYLOG.APUTLINE(TEXTE,WSEVERITY)
          Endcase
        Elsif [ECR]CTRLGRP = "2" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
          Case [ECK]CODE
            When "FCY"    : WCODE_CPY    = [ECK]CODE : WCODE_CPY    = [ECK]FLD
                           If WCODE_CPY    = "" : WSEVERITY = [V]CST_AWARNING : Else WSEVERITY = 0 : Endif
                           TEXTE=format$("13X",WCODE_CPY)+format$("13X",WCODE_CPY)
                           WOK = fmet WMYLOG.APUTLINE(TEXTE,WSEVERITY)
          Endcase
        Else #When control group is no 1 or 2 . Future development
          WOK = fmet WMYLOG.APUTLINE(mess(169,2006,1)+"."-mess(170,2006,1),[V]CST_AERROR)  #### Authorizations not defined
          WOK = fmet WMYLOG.APUTLINE("",[V]CST_AERROR)
        Endif
      Else
        WOK = fmet WMYLOG.APUTLINE(mess(169,2006,1)+"."-mess(170,2006,1),[V]CST_AERROR)  #### Authorizations not defined
        WOK = fmet WMYLOG.APUTLINE("",[V]CST_AERROR)
      Endif
    LogicClose File [ECR]
#    Endif  # X3-97369 (JUCON 21/06/18)
  Next
  Filter [ECK]
  LogicClose File [ECK]
  WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),WOK)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
Return


#********************************************************************
# PROCESS_LOG_START - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Log start
#********************************************************************
#*!
$PROCESS_LOG_START
  TIT = mess(25,2007,1) #"Processing"
  WOK = fmet WMYLOG.APUTLINE("*"-toupper(TIT),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
Return

#********************************************************************
# PROCESS_ISSUE - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Start new Issue process working with EDISTRISS class
#********************************************************************
#*!
$PROCESS_ISSUE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Instance WMYEDISTRISS Using C_EDISTRISS
  WMYEDISTRISS = NewInstance C_EDISTRISS AllocGroup null

  WOK = fmet WMYEDISTRISS.AINIT()
  WOK = fmet WMYEDISTRISS.MET_ISSUE_INIT(WNUMBATCH, this)

  WOK = fmet WMYEDISTRISS.MET_ISSUE_CREATE_QUERY(this, WMYLOG)
  If WOK = [V]CST_AOK
    WOK = fmet WMYEDISTRISS.MET_ISSUE_CONTROLS(this, WMYLOG)
    If WOK = [V]CST_AOK

      WOK = fmet WMYEDISTRISS.MET_ISSUE_STACK_CREATE(this, WMYLOG)
      If WOK = [V]CST_AOK
        WOK = fmet WMYEDISTRISS.MET_ISSUE_PROCESS(this, WMYLOG)
        If WOK = [V]CST_AOK
          #Process terminated successfully
          #nothing more to do
        Else
          #Process terminated with errors
          WRET_VALUE = [V]CST_AERROR
        Endif
      Else
        #Process terminated with errors
        WRET_VALUE = [V]CST_AERROR
      Endif
    Else
      #Process terminated with errors
      WRET_VALUE = [V]CST_AERROR
    Endif
  Else
    #Process terminated with errors
    WRET_VALUE = [V]CST_AERROR
  Endif
  FreeGroup WMYEDISTRISS : WMYEDISTRISS = null

  If WRET_VALUE = [V]CST_AOK
    # WOK = fmet this.ASETERROR("", mess(32,2017,1), [V]CST_AINFO) #"Process terminated successfully"
    Call ASYNCTRACK(this.ACTX, "", mess(32,2017,1), 100) From ASYRASYNC
#    Call ADDDIAGNOSE(this.ACTX,mess(32,2017,1),[V]CST_AINFO) From ASYRASYNC
  Else
    #WOK = fmet this.ASETERROR("", mess(33,2017,1), [V]CST_AWARNING) #"Process terminated with errors"
    Call ADDDIAGNOSE(this.ACTX,mess(33,2017,1),[V]CST_AWARNING) From ASYRASYNC
  Endif

Return

$PROCESS_RECEIPT
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Instance WMYEDISTRREC Using C_EDISTRREC
  WMYEDISTRREC = NewInstance C_EDISTRREC AllocGroup null
  WOK = fmet WMYEDISTRREC.AINIT()
  WOK = fmet WMYEDISTRREC.MET_RECEIPT_INIT(WNUMBATCH, this)

  Local Char WFLOCOD_TAB(100)(1..)
  Local Char WFLOREL_TAB(6)(1..)
  Local Clbfile WPROTOTYPE_JSON
  Local Char WERR(250)

  WOK = fmet WMYEDISTRREC.MET_RECEIPT_CREATE_FLOW_LIST(WFLOCOD_TAB, WFLOREL_TAB, this, WMYLOG)
  If WOK = [V]CST_AOK
    For I = 1 To WMYEDISTRREC.NBFLOW
      Call DELETELINES(WMYEDISTRREC,"EMSG") From EDILIBA
      WMYEDISTRREC.FLOCOD    = WFLOCOD_TAB(I)
      WMYEDISTRREC.FLOREL    = WFLOREL_TAB(I)
      For J = 1 To maxtab(WMYEDISTRREC.EMSG)
        If WMYEDISTRREC.EMSG(J)<>null and find(WMYEDISTRREC.EMSG(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and WMYEDISTRREC.EMSG(J).MSGTYP = 1 #Query
          WOK = fmet WMYEDISTRREC.MET_RECEIPT_DECODE_FILES(J, WPROTOTYPE_JSON, this, WMYLOG)
          If WOK = [V]CST_AOK

            WOK = fmet WMYEDISTRREC.MET_RECEIPT_PROCESS(J, WPROTOTYPE_JSON, this, WMYLOG)
            If WOK = [V]CST_AOK
              #Message J of flow I : Process terminated successfully
              #nothing more to do
            Else
              #Message J of flow I : Process terminated with errors
              WRET_VALUE = [V]CST_AERROR
            Endif
          Else
            #Message J of flow I : Process terminated with errors
            WRET_VALUE = [V]CST_AERROR
          Endif
        Endif
      Next J
    Next I
  Else
    #Process terminated with errors
    WRET_VALUE = [V]CST_AERROR
  Endif
  FreeGroup WMYEDISTRREC : WMYEDISTRREC = null

  If WRET_VALUE = [V]CST_AOK
    #WOK = fmet this.ASETERROR("", mess(32,2017,1), [V]CST_AINFO) #"Process terminated successfully"
     Call ASYNCTRACK(this.ACTX, "", mess(32,2017,1), 100) From ASYRASYNC
  Else
    #WOK = fmet this.ASETERROR("", mess(33,2017,1), [V]CST_AWARNING) #"Process terminated with errors"
    Call ADDDIAGNOSE(this.ACTX,mess(33,2017,1),[V]CST_AWARNING) From ASYRASYNC
  Endif
Return

#********************************************************************
# PROCESS_LOG_CLOSE - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Log closure
#********************************************************************
#*!
$PROCESS_LOG_CLOSE
  WERR = "* "+toupper(mess(26,2007,1)) #End of process"
  WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)

  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
  WERR = "["+mess(55,2007,1)+"]" #"End of log file"
  WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  WOK = fmet WMYLOG.AENDLOG()
Return

#********************************************************************
# PROCESS_LOG_END - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Log closure
#********************************************************************
#*!
$PROCESS_LOG_END
  FreeGroup WMYLOG : WMYLOG = null
  #ASTATUS = fmet this.ASETERROR("", mess(50,2006,1)-WNUMBATCH, [V]CST_AINFO) #"Log file"
  Call ADDLINKDOWNLOAD(this.ACTX,"ATYPE7","[TRA]/"+WNUMBATCH+".tra") From ASYRASYNC
Return


#********************************************************************
# PROCESS_EDITMPLOG_DELETE - Subprog of Method MET_RUN_PROCESS
#********************************************************************
# Delete all existing records in log table
#********************************************************************
#*!
$PROCESS_EDITMPLOG_DELETE
  Local File EDITMPLOG [EDL]
  Trbegin [EDL]
  Delete [EDL] Where [EDL]NUMBATCH = WNUMBATCH
  If !fstat
    Commit
  Else
    #"Deleting temporary log : failed"
    WERR = mess(11,2007,1)-":"-mess(9,2007,1)
    #ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AWARNING)
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
    Rollback
  Endif
  LogicClose File [EDL]
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
Return


################################################
$PROCESS_EDITMPDOC_DELETE     # 112149 deleting records of this launching in the working table
  Local File EDITMPDOC [ETC]
  Trbegin [ETC]
    Delete [ETC] Where  NUMBATCH=WNUMBATCH
  Commit
  LogicClose File [ETC]

Return


######################################################################
## EDIRUN FUNCTIONS
######################################################################

#********************************************************************
# Funprog GET_EDI_COUNTER
# Generate a SAS counter in this format : EDI-[YYMMDD]-[HHMMSSmmm] in GMT
# ex : EDI-130313-111628469
#********************************************************************
#*
#*
#*
#********************************************************************
#@return WCOUNTER
#*!
Funprog GET_EDI_COUNTER()
  Local Char    WCOUNTER(20)
  Local Decimal WTIMESTAMP_IN_MILLISECOND #trop grand pour un integer donc decimal
  Local Decimal WTIMESTAMP_IN_DAY
  Local Date    WDATE
  Local Decimal WTIME
  Local Decimal WMILLISECOND

  WTIMESTAMP_IN_MILLISECOND = val(timestamp$)
  WTIMESTAMP_IN_DAY         = WTIMESTAMP_IN_MILLISECOND/(24*3600*1000)
  WDATE                     = [1/1/1970] + int(WTIMESTAMP_IN_DAY)
  WTIME                     = mod(WTIMESTAMP_IN_MILLISECOND/1000,24*3600)
  WMILLISECOND              = WTIME-int(WTIME)

  WCOUNTER        = "EDI-"
&                  + format$("D:2Y2M2D",WDATE)
&                  + "-"
&                  + format$("N0:2#",int(WTIME/3600))
&                  + format$("N0:2#",int(mod(WTIME,3600)/60))
&                  + format$("N0:2#",int(mod(WTIME,60)))
&                  + format$("N0:3#",right$(left$(num$(WMILLISECOND), 5), 3))

End WCOUNTER


#********************************************************************
# Funprog CHECK_FLDVAL
#********************************************************************
#*
#* Check values entered according to the operator
#*
#********************************************************************
#* @param CURPRO  --> Char [L]CURPRO
#* @param WOBJECT --> C_EDIRUN
#* @return WOK    --> Boolean [V]ATRUE/[V]AFALSE
#*!
Funprog CHECK_FLDVAL(CURPRO,WOBJECT,WERRMSG)
Value  Char CURPRO
Variable Instance WOBJECT Using OBJECT
Variable Char WERRMSG
  Local Integer WOK
  WOK = [V]CST_AOK

  Case WOBJECT.OPERATOR
    When 1 : #1 - Borne de valeur
      If WOBJECT.FLDVAL2 < WOBJECT.FLDVAL1 and CURPRO="EDRD.FLDVAL2"
#         WERRFLD = "FLDVAL2"
          If WOBJECT.FLDTYPTYP<>8       #SAM 111252
            WERRMSG = mess(44,199,1)
            WOK = [V]CST_AERROR: End WOK
          Endif                         #SAM 111252
#         ASTATUS = fmet WOBJECT.ASETERROR(WERRFLD, WERRMSG, [V]CST_AERROR)
      Endif

      If WOBJECT.MANDATORY = 2 and WOBJECT.FLDVAL1 = "" and WOBJECT.FLDVAL2 = "" and CURPRO="EDRD.FLDVAL2"
#        WERRFLD = "FLDVAL1"
        WERRMSG = mess(103,2006,1)
#        ASTATUS = fmet WOBJECT.ASETERROR(WERRFLD, WERRMSG, [V]CST_AERROR)
        WOK = [V]CST_AERROR: End WOK
      Endif
    When 2,3,4 : #2 - Equal, Greater o equal, less o equal
      If WOBJECT.MANDATORY = 2 and WOBJECT.FLDVAL1 = "" and CURPRO="EDRD.FLDVAL1"
        WERRMSG = mess(103,2006,1)
        WOK = [V]CST_AERROR: End WOK
      Endif
  Endcase

#INI SAM 111252
  If WOBJECT.FLDTYPTYP=8      # Aditional control when field of the filter is a date
    Local Integer NOK
    Local Char MSGDATE(80)
    Local Date WDAT1, WDAT2

    If WOBJECT.FLDVAL1<>"" and CURPRO="EDRD.FLDVAL1"
      If len(WOBJECT.FLDVAL1)<>10: NOK=2: Endif
      Case mid$(adxfmt2,3,1)  # Find date format by connection : D =DDMMYYYY; M =MMDDYYYY ; Y =YYYYMMDD
        When "D":   If val(format$("D:DDMMYYYY",WOBJECT.FLDVAL1))=0 or NOK=2: NOK=1: MSGDATE= mess(35,2006,1)- ":"- mess(29,151,1): Endif
        When "M":   If val(format$("D:MMDDYYYY",WOBJECT.FLDVAL1))=0 or NOK=2: NOK=1: MSGDATE= mess(35,2006,1)- ":"- mess(30,151,1): Endif
        When "Y":   If instr(1,WOBJECT.FLDVAL1,"/")<>5 and instr(6,WOBJECT.FLDVAL1,"/")<>8: NOK=2 : Endif
                    If val(format$("D:YYYYMMDD",WOBJECT.FLDVAL1))=0 or NOK=2: NOK=1: MSGDATE= mess(35,2006,1)- ":"- "yyyy/mm/dd"  : Endif
        When Default: NOK=1: MSGDATE= mess(35,2006,1)- ":"- mess(29,151,1)
      Endcase
    Endif
    If WOBJECT.FLDVAL2<>"" and CURPRO="EDRD.FLDVAL2"
      If len(WOBJECT.FLDVAL2)<>10: NOK=2: Endif
      Case mid$(adxfmt2,3,1)
        When "D":   If val(format$("D:DDMMYYYY",WOBJECT.FLDVAL2))=0 or NOK=2 : NOK=1: MSGDATE= mess(35,2006,1)- ":"- mess(29,151,1): Endif
                    If NOK=0
                      WDAT1= gdat$(val(mid$(WOBJECT.FLDVAL1,1,2)),val(mid$(WOBJECT.FLDVAL1,4,5)),val(mid$(WOBJECT.FLDVAL1,7,10)))
                      WDAT2= gdat$(val(mid$(WOBJECT.FLDVAL2,1,2)),val(mid$(WOBJECT.FLDVAL2,4,5)),val(mid$(WOBJECT.FLDVAL2,7,10)))
                    Endif
        When "M":   If val(format$("D:MMDDYYYY",WOBJECT.FLDVAL2))=0 or NOK=2: NOK=1: MSGDATE= mess(35,2006,1)- ":"- mess(30,151,1): Endif
                    If NOK=0
                      WDAT1= gdat$(val(mid$(WOBJECT.FLDVAL1,4,5)),val(mid$(WOBJECT.FLDVAL1,1,2)),val(mid$(WOBJECT.FLDVAL1,7,10)))
                      WDAT2= gdat$(val(mid$(WOBJECT.FLDVAL2,4,5)),val(mid$(WOBJECT.FLDVAL2,1,2)),val(mid$(WOBJECT.FLDVAL2,7,10)))
                    Endif
        When "Y":   If instr(1,WOBJECT.FLDVAL1,"/")<>5 and instr(6,WOBJECT.FLDVAL1,"/")<>8: NOK=2 : Endif
                    If val(format$("D:YYYYMMDD",WOBJECT.FLDVAL2))=0 or NOK=2: NOK=1: MSGDATE= mess(35,2006,1)- ":"- "yyyy/mm/dd"  : Endif
                    If NOK=0
                      WDAT1= gdat$(val(mid$(WOBJECT.FLDVAL1,9,10)),val(mid$(WOBJECT.FLDVAL1,6,7)),val(mid$(WOBJECT.FLDVAL1,1,4)))
                      WDAT2= gdat$(val(mid$(WOBJECT.FLDVAL2,9,10)),val(mid$(WOBJECT.FLDVAL2,6,7)),val(mid$(WOBJECT.FLDVAL2,1,4)))
                    Endif
        When Default: NOK=1: MSGDATE= mess(35,2006,1)- ":"- mess(29,151,1)
      Endcase
    Endif
    If WDAT2<WDAT1: NOK=1: MSGDATE=mess(44,199,1): Endif
    If NOK=1:  WERRMSG = MSGDATE :  WOK = [V]CST_AERROR: End WOK: Endif # Incorrect date. Correct format is XXXXXXXXX
  Endif
#END SAM 111252

End WOK

#********************************************************************
# Funprog TEST_FLOCOD
#********************************************************************
#*
#* Test FLOCOD according to CATTYP, VALID and ACTIV, and set 1st FLOREL found
#*
#********************************************************************
#* @param WFLOCOD
#* @param WPARCOD
#* @param WCATCOD
#* @param WFLOREL
#* @param WERR
#* @return WOK
#*!
Funprog TEST_FLOCOD(WFLOCOD, WPARCOD, WCATCOD, WFLOREL, WERR)
Value Char WFLOCOD
Value Char WPARCOD
Value Char WCATCOD
Variable Char WFLOREL
Variable Char WERR

  Local Integer WOK    : WOK = [V]CST_AOK
  WERR = ""

  Local Integer WSET_CATCOD   : WSET_CATCOD   = [V]CST_AFALSE
  Local Integer WSET_FLOCOD   : WSET_FLOCOD   = [V]CST_AFALSE
  Local Integer WFOUND_FLOCOD : WFOUND_FLOCOD = [V]CST_AFALSE
  Local Integer WFOUND_PARCOD : WFOUND_PARCOD = [V]CST_AFALSE
  Local Integer WFOUND_CATCOD : WFOUND_CATCOD = [V]CST_AFALSE
  Local Integer WFOUND_FLGACT : WFOUND_FLGACT = [V]CST_AFALSE
  Local Integer WFOUND_VALID  : WFOUND_VALID  = [V]CST_AFALSE

  WFLOREL = ""

  If WCATCOD <> ""
    WSET_CATCOD = [V]CST_ATRUE

    If WFLOCOD <> ""
      WSET_FLOCOD = [V]CST_ATRUE

      Local File EDIFLO [EFL]
      Filter [EFL] Where [EFL]FLOCOD = WFLOCOD
      For [EFL]
        WFOUND_FLOCOD = [V]CST_ATRUE
        Break
      Next
      Filter [EFL]

      If WFOUND_FLOCOD = [V]CST_ATRUE
        Filter [EFL] Where [EFL]FLOCOD = WFLOCOD and [EFL]PARCOD = WPARCOD
        For [EFL]
          WFOUND_PARCOD = [V]CST_ATRUE
          Break
        Next
        Filter [EFL]
      Endif

      If WFOUND_PARCOD = [V]CST_ATRUE
        Filter [EFL] Where [EFL]FLOCOD = WFLOCOD and [EFL]PARCOD = WPARCOD and [EFL]CATCOD = WCATCOD
        For [EFL]
          WFOUND_CATCOD = [V]CST_ATRUE
          Break
        Next
        Filter [EFL]
      Endif

      If WFOUND_CATCOD = [V]CST_ATRUE
        Filter [EFL] Where [EFL]FLOCOD = WFLOCOD and [EFL]PARCOD = WPARCOD and [EFL]CATCOD = WCATCOD and [EFL]VALID = [V]CST_AYES
        For [EFL]
          WFLOREL = [EFL]FLOREL
          WFOUND_VALID = [V]CST_ATRUE
          Break
        Next
        Filter [EFL]
        If WFOUND_VALID <> [V]CST_ATRUE
          Filter [EFL] Where [EFL]FLOCOD = WFLOCOD and [EFL]PARCOD = WPARCOD and [EFL]CATCOD = WCATCOD
          For [EFL]
            WFLOREL = [EFL]FLOREL
            Break
          Next
          Filter [EFL]
        Endif
      Endif

      If WFOUND_VALID = [V]CST_ATRUE
        Filter [EFL] Where [EFL]FLOCOD = WFLOCOD and [EFL]PARCOD = WPARCOD and [EFL]CATCOD = WCATCOD and [EFL]VALID = [V]CST_AYES and [EFL]FLGACT = [V]CST_AYES
        For [EFL]
          WFLOREL = [EFL]FLOREL #get the 1st release activated and valid found
          WFOUND_FLGACT = [V]CST_ATRUE
          Break
        Next
        Filter [EFL]
      Endif
      LogicClose File [EFL]
    Endif
  Endif

  If WSET_CATCOD = [V]CST_AFALSE
    WOK = [V]CST_AERROR : WERR = mess(10,2006,1) #"Category not defined"
  Elsif WSET_FLOCOD = [V]CST_AFALSE
    WOK = [V]CST_AERROR : WERR = mess(31,2006,1) #"Flow not defined"
  Elsif WFOUND_FLOCOD = [V]CST_AFALSE
    WOK = [V]CST_AERROR : WERR = mess(66,2006,1) #"Nonexistent flow"
  Elsif WFOUND_PARCOD = [V]CST_AFALSE
    WOK = [V]CST_AERROR : WERR = mess(30,2006,1) #"Flow not assigned to the EDI partner"
  Elsif WFOUND_CATCOD = [V]CST_AFALSE
    WOK = [V]CST_AERROR : WERR = mess(29,2006,1) #"Flow not assigned to the category"
  Elsif WFOUND_VALID  = [V]CST_AFALSE
    WOK = [V]CST_AERROR : WERR = mess(41,2006,1) #"Invalid flow"
  Elsif WFOUND_FLGACT = [V]CST_AFALSE
    WOK = [V]CST_AERROR : WERR = mess(33,2006,1) #"Inactive flow"
  Else
    WOK = [V]CST_AOK
  Endif
End WOK

#********************************************************************
# Funprog TEST_FLOREL
#********************************************************************
#*
#* Test FLOCOD+FLOREL according to CATCOD, VALID and ACTIV
#*
#********************************************************************
#* @param WFLOCOD
#* @param WPARCOD
#* @param WCATCOD
#* @param WFLOREL
#* @param WERR
#* @return WOK
#*!
Funprog TEST_FLOREL(WFLOCOD, WPARCOD, WCATCOD, WFLOREL, WERR)
Value Char WFLOCOD
Value Char WPARCOD
Value Char WCATCOD
Value Char WFLOREL
Variable Char WERR

  Local Integer WOK    : WOK = [V]CST_AOK
  WERR = ""

  If WCATCOD <> ""
    If WFLOCOD <> ""
      If WFLOREL <> ""
        Local File EDIFLO [EFL]
        Read [EFL]EFL0 = WFLOCOD; WFLOREL
        If fstat = [V]CST_AOK
          #on verifie que le FLO+REL correspond au CATCOD+PARCOD et est actif et valide
          If [F:EFL]CATCOD = WCATCOD and [F:EFL]PARCOD = WPARCOD and [F:EFL]FLGACT = [V]CST_AYES
            If [F:EFL]VALID = 2
              WOK = [V]CST_AOK
            Else
              WERR = mess(46,2006,1) #"Invalid version"
              WOK = [V]CST_AERROR
            Endif
          Else
            WERR = mess(106,2006,1) #"Version not activated"
            WOK = [V]CST_AERROR
          Endif
        Else
          WERR = mess(66,2006,1) #"Nonexistent flow"
          WOK = [V]CST_AERROR
        Endif
        LogicClose File [EFL]
      Else
        WERR = mess(107,2006,1) #"Version not defined"
        WOK = [V]CST_AERROR
      Endif
    Endif
  Endif

End WOK


#********************************************************************
# Funprog TEST_VALID_CATEGORY
#********************************************************************
#*
#*
#*
#********************************************************************
#* @param WCATCOD
#* @param WERR
#* @return WOK true/false
#*!
Funprog TEST_VALID_CATEGORY(WCATCOD, WERR)
Value Char WCATCOD
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AFALSE
  WERR = ""
  Local File EDICAT [ECA]
  Read [ECA]ECA0 = WCATCOD
  If fstat = [V]CST_AOK
    If [F:ECA]VALID = [V]CST_AYES
      WOK = [V]CST_ATRUE
    Else
      WERR = mess(40,2006,1) #"Invalid category"
      WOK = [V]CST_AFALSE
    Endif
  Else
    WERR = mess(64,2006,1) #"Nonexistent category"
    WOK = [V]CST_AFALSE
  Endif
  LogicClose File [ECA]

End WOK

#********************************************************************
# Subprog TEST_ACTIV_EDIPARTNER
#********************************************************************
#*
#*
#*
#********************************************************************
#* @param WPARCOD
#* @param WERR
#* @return WOK true/false
#*!
Funprog TEST_ACTIV_EDIPARTNER(WPARCOD, WERR)
Value Char WPARCOD
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AFALSE
  WERR = ""
  Local File EDIPARTNER [EPR]
  Read [EPR]EPR0 = WPARCOD
  If fstat = [V]CST_AOK
    If [F:EPR]FLGACT = [V]CST_AYES
      WOK = [V]CST_ATRUE
    Else
      WERR = mess(20,2006,1) #"EDI partner not active"
      WOK = [V]CST_AFALSE
    Endif
  Else
    WERR = mess(65,2006,1) #"Nonexistent EDI partner"
    WOK = [V]CST_AFALSE
  Endif
  LogicClose File [EPR]

End WOK

#********************************************************************
# Subprog TEST_ACTIV_AND_VALID_EDIFLO
#********************************************************************
#*
#*
#*
#********************************************************************
#* @param WFLOCOD
#* @param WFLOREL
#* @param WERR
#* @return WOK true/false
#*!
Funprog TEST_ACTIV_AND_VALID_EDIFLO(WFLOCOD, WFLOREL, WERR)
Value Char WFLOCOD
Value Char WFLOREL
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AFALSE
  WERR = ""
  Local File EDIFLO [EFL]
  Read [EFL]EFL0 = WFLOCOD;WFLOREL
  If fstat = [V]CST_AOK
    If [F:EFL]FLGACT = [V]CST_AYES
        If [F:EFL]VALID = [V]CST_AYES
          WOK = [V]CST_ATRUE
        Else
          WERR = mess(41,2006,1) #"Invalid flow"
          WOK = [V]CST_AFALSE
        Endif
    Else
      WERR = mess(33,2006,1) #"Inactive flow"
      WOK = [V]CST_AFALSE
    Endif
  Else
    WERR = mess(66,2006,1) #"Nonexistent flow"
    WOK = [V]CST_AFALSE
  Endif
  LogicClose File [EFL]

End WOK



