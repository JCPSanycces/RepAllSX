#@param WPARCOD
#@return WOK
#*!
Funprog TEST_EDICPYPAR(WCPY, WPARCOD)
Value Char WCPY
Value Char WPARCOD
  Local Integer WOK : WOK = [V]CST_AERROR
  Local File EDICPYPAR [ECP]
  Read [ECP]ECP0 = WCPY;WPARCOD
  If !fstat
    If [F:ECP]VALID = [V]CST_AYES
      WOK = [V]CST_AINFO #2 #info
    Else
      WOK = [V]CST_AWARNING #3 #warning
    Endif
  Else
#    WOK = [V]CST_AERROR #4 #error  SAM 114061
    WOK = [V]CST_AWARNING #3 #warning  SAM 114061
  Endif
  LogicClose File [ECP]
End WOK

