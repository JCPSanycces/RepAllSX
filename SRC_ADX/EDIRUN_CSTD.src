#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Class EDIRUN                                                                #
# Author : RBA + JUCON                                                        #
###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "AREAD_AFTER"            : Gosub AREAD_AFTER
      Endcase
    When "EDRD"
      Case [L]AEVENT
        When "AREAD_AFTER"            : Gosub EDRD_AREAD_AFTER
        When "ADDLINE_AFTER"          : Gosub EDRD_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_SET_FILTER"         : Gosub MET_SET_FILTER
    When "MET_GET_FILTER"         : Gosub MET_GET_FILTER
    When "MET_GET_FORM"           : Gosub MET_GET_FORM
    When "MET_RUN_PROCESS"        : Gosub MET_RUN_PROCESS
    When "MET_RUN_PROCESS_DIRECT" : Gosub MET_RUN_PROCESS_DIRECT
    When "MET_RUN_PROCESS_BATCH"  : Gosub MET_RUN_PROCESS_BATCH
    When "MET_UPDATE_STA"         : Gosub MET_UPDATE_STA
    When "MET_LOG_MSG"            : Gosub MET_LOG_MSG
    When "MET_LOG_DUMP"           : Gosub MET_LOG_DUMP
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "OPE_RUN_PROCESS"            : Gosub OPE_RUN_PROCESS
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "LASRUNDAT"
      Case [L]ARULE
        When "INIT" : Gosub LASRUNDAT_INIT
      Endcase
    When "PARCOD"
      Case [L]ARULE
        When "CONTROL"   : Gosub PARCOD_CONTROL
        When "PROPAGATE" : Gosub PARCOD_PROPAGATE
      Endcase
    When "PARTYP"
      Case [L]ARULE
        When "INIT"      : Gosub PARTYP_INIT
        When "PROPAGATE" : Gosub PARTYP_PROPAGATE
      Endcase
    When "CATCOD"
      Case [L]ARULE
        When "INIT"      : Gosub CATCOD_INIT
        When "CONTROL"   : Gosub CATCOD_CONTROL
        When "PROPAGATE" : Gosub CATCOD_PROPAGATE
      Endcase
    When "FLOCOD"
      Case [L]ARULE
        When "CONTROL"   : Gosub FLOCOD_CONTROL
        When "PROPAGATE" : Gosub FLOCOD_PROPAGATE
      Endcase
    When "FLOREL"
      Case [L]ARULE
        When "CONTROL"   : Gosub FLOREL_CONTROL
        When "PROPAGATE" : Gosub FLOREL_PROPAGATE
      Endcase
    When "ALLFLO"
      Case [L]ARULE
        When "INIT"      : Gosub ALLFLO_INIT
        When "PROPAGATE" : Gosub ALLFLO_PROPAGATE
      Endcase
    When "EDRD.FLDVAL1"
      Case [L]ARULE
        When "CONTROL"   : Gosub EDRD_FLDVAL1_CONTROL
        When "PROPAGATE" : Gosub EDRD_FLDVAL1_PROPAGATE
      Endcase
    When "EDRD.FLDVAL2"
      Case [L]ARULE
        When "CONTROL"   : Gosub EDRD_FLDVAL2_CONTROL
        When "PROPAGATE" : Gosub EDRD_FLDVAL2_PROPAGATE
      Endcase
    When "EDRD.REPFLDVAL1" :
      Case [L]ARULE
        When "CONTROL"   : Gosub EDRD_REPFLDVAL1_CONTROL
        When "PROPAGATE" : Gosub EDRD_REPFLDVAL1_PROPAGATE
      Endcase
    When "EDRD.REPFLDVAL2" :
      Case [L]ARULE
        When "CONTROL"   : Gosub EDRD_REPFLDVAL2_CONTROL
        When "PROPAGATE" : Gosub EDRD_REPFLDVAL2_PROPAGATE
      Endcase
  Endcase
Return

####################################################################

$LASRUNDAT_INIT
#  this.LASRUNDAT = [0/0/0]
Return

###################################################################

$PARCOD_CONTROL
  Local Integer WOK    : WOK = [V]CST_AFALSE
  Local Char WERR(250) : WERR = ""

  #test if the category is activ or not
  If this.PARCOD <> ""
    this.PARCOD = func EDILIBA.FORMATVAL("PARCOD", this.PARCOD)
    WOK = func TEST_ACTIV_EDIPARTNER(this.PARCOD, WERR)
    If WOK = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AWARNING)
    Endif
  Endif
Return

$PARCOD_PROPAGATE
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.PARTYP = fmet this.ACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP")

  Call DELETELINES(this, "EDRD") From EDILIBA
  Gosub RAZ_FLOW
  this.CATCOD = ""
Return

###################################################################

$PARTYP_INIT
  this.PARTYP = 2
Return

$PARTYP_PROPAGATE
Return

###################################################################

$CATCOD_INIT
  this.CATCOD = ""
Return

$CATCOD_CONTROL
  Local Integer WOK    : WOK = [V]CST_AFALSE
  Local Char WERR(250) : WERR = ""
  #test if the category is valid or not
  If this.CATCOD <> ""
    this.CATCOD = func EDILIBA.FORMATVAL("CATCOD", this.CATCOD)
    WOK = func TEST_VALID_CATEGORY(this.CATCOD, WERR)
    If WOK = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("CATCOD",WERR,[V]CST_AWARNING)
    Endif
  Endif
Return

$CATCOD_PROPAGATE
  Gosub RAZ_FLOW

  Local Integer WOK    : WOK = [V]CST_AOK
  Local Char WERR(250) : WERR = ""

  If this.PARCOD <> "" and this.CATCOD <> ""
    If func EDILIBA.CATEGORY_IS_AUTHORIZED(this.PARCOD, this.CATCOD, WERR) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("CATCOD",WERR,[V]CST_AERROR)
    Else
      this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
      Call DELETELINES(this, "EDRD") From EDILIBA
      If this.PARCOD <> "" #and this.CATACT = 1 #issue only
        WOK = fmet this.MET_GET_FORM()
      Endif
    Endif
  Endif

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif
  this.CATACT = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATACT")
Return

###################################################################

$FLOCOD_CONTROL
  If this.FLOCOD <> ""
  #  this.FLOCOD = format$("Kv4:20B",toupper(this.FLOCOD))
    this.FLOCOD = func EDILIBA.FORMATVAL("FLOCOD", this.FLOCOD)
  Endif
Return

$FLOCOD_PROPAGATE
  Local Integer WOK
  Local Char WERR(250)
  Local Char WFLOREL(5)
  If this.FLOCOD <> ""
    WOK = func TEST_FLOCOD(this.FLOCOD, this.PARCOD, this.CATCOD, WFLOREL, WERR)
    If WOK = [V]CST_AOK
      this.FLOREL = WFLOREL
    Else
      this.FLOREL = WFLOREL
      ASTATUS = fmet this.ASETERROR("FLOCOD",WERR,[V]CST_AWARNING)
    Endif
  Else
    this.FLOREL = ""
  Endif
Return

###################################################################

$FLOREL_CONTROL
  If this.FLOCOD <> ""
    If this.FLOREL <> ""
    #  this.FLOREL = format$("Kv4:5B",toupper(this.FLOREL))
      this.FLOREL = func EDILIBA.FORMATVAL("FLOREL", this.FLOREL)
    Endif

    Local Integer WOK
    Local Char WERR(250)
    If this.PARCOD <> "" and this.CATCOD <> ""
      WOK = func TEST_FLOREL(this.FLOCOD, this.PARCOD, this.CATCOD, this.FLOREL, WERR)
      If WOK <> [V]CST_AOK
        ASTATUS = fmet this.ASETERROR("FLOREL",WERR,[V]CST_AWARNING)
      Endif
    Endif
  Endif
Return

$FLOREL_PROPAGATE
  If this.FLOCOD <> "" and this.FLOREL <> ""
    this.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"FLODES")
  Else
    this.FLODES = ""
  Endif
Return

###################################################################

$ALLFLO_INIT
#  If this.CATTYP > 5
    this.ALLFLO = 1
#  Endif
Return

$ALLFLO_PROPAGATE
  If this.CATACT = 2 #receipt
    this.ALLFLO = 1 #ALLFLO can not be set in Receipt process (field is not on the facet of representation)
  Endif

  If this.ALLFLO=2
    this.FLOCOD = ""
    this.FLOREL = ""
    this.FLODES = ""
  Endif
Return

#********************************************************************
# Event AREAD_AFTER
#********************************************************************
#*
#*!
$AREAD_AFTER
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"FLODES")
Return

#********************************************************************
# Method AINSERT_CONTROL_BEFORE
#********************************************************************
#*
#*!
$AINSERT_CONTROL_BEFORE
  Local File EDIRUN [EDR]
  If this.NUM=0
    Read [EDR]EDR0 Last
    If fstat
      this.NUM=1
    Else
      this.NUM=[EDR]NUM+1
    Endif
  Endif
  LogicClose File [EDR]

  Gosub AINSERT_OR_AUPDATE_CONTROL_AFTER
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#*
#*!
$AUPDATE_CONTROL_AFTER
  Gosub AINSERT_OR_AUPDATE_CONTROL_AFTER
Return

#********************************************************************
# Prog AINSERT_OR_AUPDATE_CONTROL_AFTER
#********************************************************************
#*
#*!
$AINSERT_OR_AUPDATE_CONTROL_AFTER
  Local Char WERR(250)

  If this.ALLFLO = [V]CST_ANO
    If this.FLOCOD = "" or this.FLOREL = ""
      #"Value is mandatory"
      ASTATUS = fmet this.ASETERROR("FLOCOD", mess(103,2006,1), [V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$EDRD_REPFLDVAL1_CONTROL
  WOK = fmet this.ADELETERROR("REPFLDVAL1")
  WOK = fmet this.ADELETERROR("REPFLDVAL2")
  Local Char WERR(80)
  Local Integer WOK
  If this.REPFLDVAL1 <> ""
    this.REPFLDVAL1 = func EDILIBA.FORMATVAL("FLDVAL1", this.REPFLDVAL1)
    Case this.FLDTYPTYP
      When 8 #date
        WOK = func TEST_FORMAT_DATE(this.REPFLDVAL1, this.ACTX.AINTL.SHORTDATE, WERR)
        If WOK <> [V]CST_AOK
          ASTATUS = fmet this.ASETERROR("REPFLDVAL1", WERR, [V]CST_AERROR)
        Endif
      When 7 #alpha
        #nothing to do
      When 1,2,3,4,5,6 #numerics
        #check numbers
        WOK = func TEST_FORMAT_NUMERIC(this.REPFLDVAL1, WERR)
        If WOK <> [V]CST_AOK
          ASTATUS = fmet this.ASETERROR("REPFLDVAL1", WERR, [V]CST_AERROR)
        Endif
    Endcase
  Else
    If this.MANDATORY = [V]CST_AYES
      ASTATUS = fmet this.ASETERROR("REPFLDVAL1", mess(103,2006,1), [V]CST_AERROR)
    Endif
  Endif

Return

$EDRD_REPFLDVAL1_PROPAGATE
  Case this.FLDTYPTYP
    When 8 #date
      this.FLDVAL1 = func FORMAT_DATE_LOCAL_TO_UNIVERSAL(this.REPFLDVAL1, this.ACTX.AINTL.SHORTDATE)
    When 1,2,3,4,5,6 #numeric
      this.FLDVAL1 = func FORMAT_NUMERIC(this.REPFLDVAL1)
    When 7 #char
      this.FLDVAL1 = this.REPFLDVAL1
    When Default
      this.FLDVAL1 = this.REPFLDVAL1
  Endcase

  If this.OPERATOR = 1 #1 - Borne de valeur
    If this.REPFLDVAL2 = ""
      this.REPFLDVAL2 = this.REPFLDVAL1
    Endif
  Endif

  If this.UPDFLG = [V]CST_ANO
#      ASTATUS = fmet this.ASETERROR("REPFLDVAL1", "Modification interdite", [V]CST_AERROR) #Issue 116455
    ASTATUS = fmet this.ASETERROR("REPFLDVAL1", mess(437,192,1), [V]CST_AERROR)
  Endif
Return

####################################################################

$EDRD_REPFLDVAL2_CONTROL
  Local Char WERR(80)
  Local Integer WOK
  WOK = fmet this.ADELETERROR("REPFLDVAL1")
  WOK = fmet this.ADELETERROR("REPFLDVAL2")
  If this.REPFLDVAL2 <> ""
    this.REPFLDVAL2 = func EDILIBA.FORMATVAL("FLDVAL2", this.REPFLDVAL2)
    Case this.FLDTYPTYP
      When 8 #date
        WOK = func TEST_FORMAT_DATE(this.REPFLDVAL2, this.ACTX.AINTL.SHORTDATE, WERR)
        If WOK <> [V]CST_AOK
          ASTATUS = fmet this.ASETERROR("REPFLDVAL2", WERR, [V]CST_AERROR)
        Endif
      When 7 #alpha
        #nothing to do
      When 1,2,3,4,5,6 #numerics
        WOK = func TEST_FORMAT_NUMERIC(this.REPFLDVAL2, WERR)
        If WOK <> [V]CST_AOK
          ASTATUS = fmet this.ASETERROR("REPFLDVAL2", WERR, [V]CST_AERROR)
        Endif
    Endcase
  Else
    If this.MANDATORY = [V]CST_AYES and this.OPERATOR = 1
      ASTATUS = fmet this.ASETERROR("REPFLDVAL2", mess(103,2006,1), [V]CST_AERROR)
    Endif
  Endif
Return

$EDRD_REPFLDVAL2_PROPAGATE
  Case this.FLDTYPTYP
    When 8 #date
      this.FLDVAL2 = func FORMAT_DATE_LOCAL_TO_UNIVERSAL(this.REPFLDVAL2, this.ACTX.AINTL.SHORTDATE)
    When 1,2,3,4,5,6 #numeric
      this.FLDVAL2 = func FORMAT_NUMERIC(this.REPFLDVAL2)
    When 7 #char
      this.FLDVAL2 = this.REPFLDVAL2
    When Default
      this.FLDVAL2 = this.REPFLDVAL2
  Endcase

  If this.UPDFLG = [V]CST_ANO
#    ASTATUS = fmet this.ASETERROR("REPFLDVAL2", "Modification interdite", [V]CST_AERROR) #Issue 116455
    ASTATUS = fmet this.ASETERROR("REPFLDVAL2", mess(437,192,1), [V]CST_AERROR)
  Endif
Return

####################################################################

$EDRD_FLDVAL1_CONTROL
  If this.FLDVAL1 <> ""
    If this.OPERATOR = 1 #1 - Borne de valeur
      If this.FLDVAL1 > this.FLDVAL2
        ASTATUS = fmet this.ASETERROR("REPFLDVAL2", mess(44,199,1), [V]CST_AERROR)
      Endif
    Endif
  Endif
Return

$EDRD_FLDVAL1_PROPAGATE
Return

####################################################################

$EDRD_FLDVAL2_CONTROL
  If this.OPERATOR = 1 #1 - Borne de valeur
    If this.FLDVAL2 < this.FLDVAL1
      ASTATUS = fmet this.ASETERROR("REPFLDVAL2", mess(44,199,1), [V]CST_AERROR)
    Endif
  Endif
Return

$EDRD_FLDVAL2_PROPAGATE
Return

####################################################################

#********************************************************************
# Method EDRD_AREAD_AFTER
#********************************************************************
#*
#*!
$EDRD_AREAD_AFTER
  If this.FLDVAL1 <> ""
    Case this.FLDTYPTYP
      When 8 #date
        this.REPFLDVAL1 = func FORMAT_DATE_UNIVERSAL_TO_LOCAL(this.FLDVAL1, this.ACTX.AINTL.SHORTDATE)
      When 1,2,3,4,5,6 #numeric
        this.REPFLDVAL1 = this.FLDVAL1
      When 7 #char
        this.REPFLDVAL1 = this.FLDVAL1
      When Default
        this.REPFLDVAL1 = this.FLDVAL1
    Endcase
  Endif

  If this.FLDVAL2 <> "" and this.OPERATOR = 1
    Case this.FLDTYPTYP
      When 8 #date
        this.REPFLDVAL2 = func FORMAT_DATE_UNIVERSAL_TO_LOCAL(this.FLDVAL2, this.ACTX.AINTL.SHORTDATE)
      When 1,2,3,4,5,6 #numeric
        this.REPFLDVAL2 = this.FLDVAL2
      When 7 #char
        this.REPFLDVAL2 = this.FLDVAL2
      When Default
        this.REPFLDVAL2 = this.FLDVAL2
    Endcase
  Else
    this.REPFLDVAL2 = ""
  Endif
Return


#********************************************************************
# Method EDRD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EDRD_ADDLINE_AFTER
  #Manage key identifiers

  #on ajoute une ligne
  this.NUMLIN    = 1 + max(this.APARENT.EDRD(1..maxtab(this.APARENT.EDRD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EDRD)
    If this.APARENT.EDRD(I) <> null
      If this.APARENT.EDRD(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EDRD(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EDRD(AFT_LINE).SORT
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EDRD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EDRD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EDRD)
        If this.APARENT.EDRD(I) <> null
          OFFSET_LINE = this.APARENT.EDRD(I).AORDER - this.AORDER
#          If this.APARENT.EDRD(I).AORDER >= this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.EDRD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EDRD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EDRD(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif
Return

#********************************************************************
# Method MET_SET_FILTER
#********************************************************************
#
#* Set values
#* @param WFILTER
#* @param WVALUE1
#* @param WVALUE2 can be empty ""
#* @return WOK
#*!
$MET_SET_FILTER
  Local Integer WOK    : WOK = [V]CST_AERROR
  Local Integer I

  For I = 1 To maxtab(this.EDRD())
    If this.EDRD(I).FLD = WFILTER
      this.EDRD(I).FLDVAL1 = WVALUE1
      If this.EDRD(I).OPERATOR <> 2 #equal to"
        this.EDRD(I).FLDVAL2 = WVALUE2
      Endif
      WOK = [V]CST_AOK
      Break
    Endif
  Next I
  ARET_VALUE = WOK
Return


#********************************************************************
# Method MET_GET_FILTER
#********************************************************************
#
#* Get values
#* @param WFILTER
#* @param WVALUE1
#* @param WVALUE2
#* @return WOK
#*!
$MET_GET_FILTER
  Local Integer WOK    : WOK = [V]CST_AERROR
  Local Integer I

  For I = 1 To maxtab(this.EDRD())
    If this.EDRD(I).FLD = WFILTER
      WVALUE1 = this.EDRD(I).FLDVAL1
      If this.EDRD(I).OPERATOR <> 2 #equal to"
        WVALUE2 = this.EDRD(I).FLDVAL2
      Endif
      WOK = [V]CST_AOK
      Break
    Endif
  Next I
#End WOK
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_GET_FORM
#********************************************************************
#
#* Get form
#*
#* @return WOK
#*!
$MET_GET_FORM

  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer I , WPOS

  #2-remplir le formulaire
  Local Instance MY_EDICAT Using C_EDICAT
  MY_EDICAT = NewInstance C_EDICAT AllocGroup null
  WOK = fmet MY_EDICAT.AREAD(this.CATCOD)
  If WOK = [V]CST_AOK
    this.CATTYP = MY_EDICAT.CATTYP
    If this.CATACT = 1 #issue only
      Local File ATABZON [ATZ]
      Local File ATYPE [ATY]
      Local File ATEXTE [ATX]

      #Ajoute les lignes
      For I = 1 To maxtab(MY_EDICAT.ECAD)
        WPOS = fmet this.ADDLINE('EDRD', [V]CST_ALASTPOS)
        this.EDRD(WPOS).FLD       = MY_EDICAT.ECAD(I).FLD
        this.EDRD(WPOS).MANDATORY = MY_EDICAT.ECAD(I).MANDATORY
        this.EDRD(WPOS).OPERATOR  = MY_EDICAT.ECAD(I).OPERATOR
        this.EDRD(WPOS).FLDVAL1   = MY_EDICAT.ECAD(I).FLDVAL1
        this.EDRD(WPOS).FLDVAL2   = MY_EDICAT.ECAD(I).FLDVAL2
        this.EDRD(WPOS).UPDFLG    = MY_EDICAT.ECAD(I).UPDFLG
        #check zone
        Read [ATZ]CODZONE = MY_EDICAT.CATTRGTAB;MY_EDICAT.ECAD(I).FLD
        If fstat
          #Nonexistent Field
          ASTATUS = fmet this.ASETERROR("FLD",mess(8,124,1),[V]CST_AERROR)
        Else
          #get type
          Read [ATY]CODTYP = [F:ATZ]CODTYP
          If fstat
            #Incorrect Field Type
            ASTATUS = fmet this.ASETERROR("FLDTYP",mess(10,124,1),[V]CST_AERROR)
          Else
            this.EDRD(WPOS).FLDTYPTYP = [F:ATY]TYPTYP
            If this.EDRD(WPOS).FLDTYPTYP = 8 # date
              this.EDRD(WPOS).REPFLDVAL1 = func FORMAT_DATE_UNIVERSAL_TO_LOCAL(MY_EDICAT.ECAD(I).FLDVAL1, this.ACTX.AINTL.SHORTDATE)
              this.EDRD(WPOS).REPFLDVAL2 = func FORMAT_DATE_UNIVERSAL_TO_LOCAL(MY_EDICAT.ECAD(I).FLDVAL2, this.ACTX.AINTL.SHORTDATE)
            Else
              this.EDRD(WPOS).REPFLDVAL1 = MY_EDICAT.ECAD(I).FLDVAL1
              this.EDRD(WPOS).REPFLDVAL2 = MY_EDICAT.ECAD(I).FLDVAL2
            Endif
            this.EDRD(WPOS).FLDCODTYP = [F:ATZ]CODTYP
            this.EDRD(WPOS).FLDNOLIB  = [F:ATZ]NOLIB
          Endif
        Endif
      Next I
      LogicClose File [ATZ]
      LogicClose File [ATY]
      LogicClose File [ATX]
    Endif
  Endif
  FreeGroup MY_EDICAT : MY_EDICAT = null

  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_UPDATE_STA
#********************************************************************
#
#*
#* @param char WNUMBATCH
#* @param char WDOCID
#* @param Integer WCATTYP
#* @param Integer WSTEP
#* @param Integer WSTATUS
#* @param WMYLOG Using C_ALOG
#*!
$MET_UPDATE_STA

  Local Char WINFO(250)
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WOK
  Case WSTATUS
    When 2 : WINFO = mess(2,2003,1)
    When 3 : WINFO = mess(3,2003,1)
    When 4 : WINFO = mess(4,2003,1)
    When Default : WINFO = ""
  Endcase
  WOK = func EDISTO_CSTD.SAS_UPDATE_STA(WNUMBATCH, WDOCID, WSTATUS)
  #WERR = "SAS update : status"
  If WOK = [V]CST_AOK
    WOK = fmet this.MET_LOG_MSG(WNUMBATCH, WDOCID, WCATTYP, WSTEP, [V]CST_AINFO, 11, WINFO, WMYLOG)
    WOK = func EDITRKDOC_CSTD.TRK_UPDATE_STA(WDOCID, WCATTYP, WSTATUS)
    WRET_VALUE = [V]CST_AOK
  Else #error
    WOK = fmet this.MET_LOG_MSG(WNUMBATCH, WDOCID, WCATTYP, WSTEP, [V]CST_AERROR, 11, WINFO, WMYLOG)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return



#********************************************************************
# Method MET_LOG_MSG
#********************************************************************
#
#*
#* @param char WNUMBATCH
#* @param char WDOCID
#* @param Integer WCATTYP
#* @param Integer WFLOSTP
#* @param Integer WSEV
#* @param Integer WMSGNUM #ML
#* @param Char WINFO
#* @param WMYLOG Using C_ALOG
#*!
$MET_LOG_MSG
  Local Char WKEY1(100): WKEY1 = ""
  Local Integer WSORT
  Local Integer WOK    : WOK = [V]CST_AOK
  Local Integer WFOUND : WFOUND = [V]CST_AFALSE

  Local File EDITMPLOG [EDL]
  Filter [EDL] Where [EDL]NUMBATCH = WNUMBATCH and [EDL]DOCID = WDOCID Order By Key EDL0 Desc
  For [EDL]
    WFOUND = [V]CST_ATRUE
    #le 1e à l'envers est lu
    WSORT = [EDL]SORT + 10
    Break
  Next
  If WFOUND = [V]CST_AFALSE
    WSORT = 10
  Endif
  Filter [EDL]
  LogicClose File [EDL]

  If WDOCID <> ""
    WKEY1 = WNUMBATCH+'~'+WDOCID
  Else
    WKEY1 = WNUMBATCH
  Endif

  Local File EDITMPLOG [EDL]
  Trbegin [EDL]
  [EDL]NUMBATCH  = WNUMBATCH
  [EDL]DOCID     = WDOCID
  [EDL]CATTYP    = WCATTYP
  [EDL]SORT      = WSORT
  [EDL]TIMESTAMP = datetime$
  [EDL]KEY1      = WKEY1
#  [EDL]KEY2      = WKEY2
  [EDL]FLOSTP    = WFLOSTP
#  [EDL]ERR       = WERR
#  [EDL]ERRSTA    = WERRSTA
  [EDL]SEV       = WSEV
  [EDL]MSGNUM    = WMSGNUM
  [EDL]INFO      = WINFO
#  [EDL]ERRCOD    = WERRCOD

  Write [EDL]
  If !fstat
    Commit
    WOK = [V]CST_AOK

#    If this.CATACT = 1 #"send"
      If WSEV <> [V]CST_AINFO
        If WSEV=3  #INI X3-44530 Check error status in EDI partner/BP autorizations
#          Call ADDDIAGNOSE(this.ACTX,mess(WMSGNUM,2017,1)-":"-WNUMBATCH-"/"-WDOCID-":"-WINFO, CST_AERROR) From ASYRASYNC
          WOK = fmet WMYLOG.APUTLINE(mess(WMSGNUM,2017,1)-":"-WNUMBATCH-"/"-WDOCID-":"-WINFO, [V]CST_AERROR) #Issue X3-93866 by RBA : if direct launching then ADDIAGNOSE fails
        Else      #END X3-44530 Check error status in EDI partner/BP autorizations
#          Call ADDDIAGNOSE(this.ACTX,mess(WMSGNUM,2017,1)-":"-WNUMBATCH-"/"-WDOCID-":"-WINFO, WSEV) From ASYRASYNC
          WOK = fmet WMYLOG.APUTLINE(mess(WMSGNUM,2017,1)-":"-WNUMBATCH-"/"-WDOCID-":"-WINFO, WSEV) #Issue X3-93866 by RBA : if direct launching then ADDIAGNOSE fails
      Endif
    Else
    Endif

  Else
    #error to log in trace file only
    WOK = fmet WMYLOG.APUTLINE(mess(54,2007,1) -":"- mess(9,2007,1), [V]CST_AERROR) #"Creation of a log line : failed"
    Rollback
    WOK = [V]CST_AERROR
  Endif

  LogicClose File [EDL]
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_LOG_DUMP
#********************************************************************
#
#*
#* @param char WNUMBATCH
#* @param char WDOCID
#* @param WMYLOG Using C_ALOG
#*!
$MET_LOG_DUMP
  Local Integer WOK : WOK = [V]CST_AOK
  Local Char WERR(250)

  Local Char WFORMAT1(3) : WFORMAT1 = "10X"
  Local Char WFORMAT2(3) : WFORMAT2 = "45X"
  Local Char WFORMAT3(3) : WFORMAT3 = "54X"
  Local Char WMSGSTA(10)
  Local Char WFLOSTP(2)

  Local Integer WFLG_FIRSTLINE : WFLG_FIRSTLINE = [V]CST_AYES

  Local File EDITMPLOG [EDL]

  Local Instance WMYEDISTO Using C_EDISTO     # X3-97369 performance JUCON 12/07/2018
  WMYEDISTO = NewInstance C_EDISTO AllocGroup null    # X3-97369 performance JUCON 12/07/2018

  For I = 1 To maxtab(WDOCID_TAB())
 #   Local Instance WMYEDISTO Using C_EDISTO        # X3-97369 performance JUCON 12/07/2018
 #  WMYEDISTO = NewInstance C_EDISTO AllocGroup null    # X3-97369 performance JUCON 12/07/2018

    #1/summary of query/checked docs
    Filter [EDL] Where [EDL]NUMBATCH = WNUMBATCH and [EDL]DOCID = WDOCID_TAB(I) Order By Key EDL3 Asc # and [EDL]FLOSTP = 0 Order By Key EDL3 Asc   # X3-97369 performance JUCON 12/07/2018)
    If rowcount([F:EDL])>0 & WNUMBATCH <> "" & WDOCID_TAB(I) <> ""    # X3-97369 performance JUCON 12/07/2018
       WOK = fmet WMYEDISTO.AREAD(WNUMBATCH, WDOCID_TAB(I))           # X3-97369 performance JUCON 12/07/2018
    Endif                                                             # X3-97369 performance JUCON 12/07/2018
    For [EDL]
      If [EDL]FLOSTP = 0
        #1/summary of query/checked docs
        WERR = mess([EDL]MSGNUM,2017,1)-":"-[EDL]INFO
        WOK = fmet WMYLOG.APUTLINE(WERR, [EDL]ERRSTA)
      Else
      #2/events
        If WFLG_FIRSTLINE = [V]CST_AYES
          WFLG_FIRSTLINE = [V]CST_ANO
          WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)
          WERR = mess(59,2007,1)+" : "+[EDL]DOCID # "Processing document :"
          WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AINFO)
          WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)

          #get events already stored into the SAS but not yet in the trace file
          Local File EDISTOE [ESTE]
          Local Integer WNUM # X3-97369 performance JUCON 12/07/2018
          Filter [ESTE] Where [ESTE]NUMBATCH = WNUMBATCH and [ESTE]KEYDOC = WDOCID_TAB(I) # Order By [ESTE]SORT Asc
#        Filter [ESTE] Where [ESTE]NUMBATCH = WNUMBATCH and [ESTE]KEYDOC = WDOCID_TAB(I) Order By [ESTE]SORT Asc    # X3-97369 performance JUCON 12/07/2018
          WNUM=rowcount([F:ESTE])   # X3-97369 performance JUCON 12/07/2018
          For [ESTE]
            If len([ESTE]INFO) > 54
              [ESTE]INFO = left$([ESTE]INFO,51)+"..."
            Endif
            WFLOSTP = ""
            If [ESTE]FLOSTP < 10
              WFLOSTP = "0"+num$([ESTE]FLOSTP)
            Else
              WFLOSTP = num$([ESTE]FLOSTP)
            Endif
            WERR = format$(WFORMAT1,mess(60,2007,1)-WFLOSTP)+" : "+ format$(WFORMAT2,mess([ESTE]MSGNUM,2017,1))+" : "+format$(WFORMAT3,[ESTE]INFO) #-WNUMBATCH+"~"+WDOCID

            WOK = fmet WMYLOG.APUTLINE(WERR, [ESTE]ERRSTA)

          Next
          Filter [ESTE]
          LogicClose File [ESTE]
        Endif

        #events lines for each document
        If len([EDL]INFO) > 54
          [EDL]INFO = left$([EDL]INFO,51)+"..."
        Endif
        WFLOSTP = ""
        If [EDL]FLOSTP < 10
          WFLOSTP = "0"+num$([EDL]FLOSTP)
        Else
          WFLOSTP = num$([EDL]FLOSTP)
        Endif
        WERR = format$(WFORMAT1,mess(60,2007,1)-WFLOSTP)+" : "+ format$(WFORMAT2,mess([EDL]MSGNUM,2017,1))+" : "+format$(WFORMAT3,[EDL]INFO) #-WNUMBATCH+"~"+WDOCID
        WOK = fmet WMYLOG.APUTLINE(WERR, [EDL]ERRSTA)

# ini X3-97369 performance JUCON 12/07/2018
#        #3/now log the event in the SAS
#        If [EDL]NUMBATCH <> "" and [EDL]DOCID <> ""
#          WOK = fmet WMYEDISTO.AREAD([EDL]NUMBATCH, [EDL]DOCID)
#          If WOK = [V]CST_AOK
#            WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT([EDL]TIMESTAMP, [EDL]FLOSTP, [EDL]SEV, [EDL]MSGNUM, [EDL]INFO)
#          Endif
#        Endif

       #3/now log the event in the SAS
        Local File EDISTOE [ESTE]
        Read [ESTE]ESTE0= WNUMBATCH;WDOCID_TAB(I);WNUM
        If fstat=[V]CST_AOK
          Trbegin [ESTE]
            WNUM+=1
            [ESTE]NUMLIN    = WNUM
            [ESTE]SORT      = WNUM*100
            [ESTE]TIMESTAMP = [EDL]TIMESTAMP
            [ESTE]FLOSTP    = [EDL]FLOSTP
            Case [EDL]SEV
              When [V]CST_AINFO    : [ESTE]SEV       = 1
              When [V]CST_AWARNING : [ESTE]SEV       = 2
              When [V]CST_AERROR   : [ESTE]SEV       = 3
              When Default :         [ESTE]SEV       = 1
            Endcase

            [ESTE]MSGNUM    = [EDL]MSGNUM
            If [EDL]SEV = [V]CST_AERROR
              [ESTE]ERRSTA    = [V]CST_AYES
            Else
             [ESTE]ERRSTA    = [V]CST_ANO
            Endif
            [ESTE]INFO      = [EDL]INFO
            Write [ESTE]
            If fstat: Rollback
            Else :    Commit
            Endif
        Endif
        LogicClose File [ESTE]
      Endif
    Next
    Filter [EDL]
    WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)
#    FreeGroup WMYEDISTO : WMYEDISTO = null  # X3-97369 performance JUCON 12/07/2018

    WFLG_FIRSTLINE = [V]CST_AYES
  Next I
  LogicClose File [EDL]
  FreeGroup WMYEDISTO : WMYEDISTO = null  # X3-97369 performance JUCON 12/07/2018
  ARET_VALUE = [V]CST_AOK #WOK
Return


#********************************************************************
# Operation RUN_PROCESS
#********************************************************************
#
#* @param NUM
#* @return WOK
#*!
$OPE_RUN_PROCESS
  Local Integer WOK
  WOK = fmet this.AREAD(NUM)
  If WOK = [V]CST_AOK
    WOK = fmet this.MET_RUN_PROCESS()
  Endif

  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_RUN_PROCESS_BATCH
#********************************************************************
#
#* @param WNUMBATCH
#* @return WOK
#*!
$MET_RUN_PROCESS_BATCH
  Local Char WNUMBATCH(20)
  Local Integer WOK    : WOK    = [V]CST_AOK
  Local Char WERR(250) : WERR   = ""
  Local Integer WNBERR : WNBERR = 0

#  Call ASYNCTRACK(this.ACTX, "Preprocessing", "Controlling the launching setup", 0) From ASYRASYNC #Issue 116455
  Call ASYNCTRACK(this.ACTX, mess(25,2007,1), mess(195,195,1), 0) From ASYRASYNC

  If this.DIRECTFLG = 2
    WOK = [V]CST_AERROR
#    WERR = "Impossible to launch a direct process" #Issue 116455
#    WERR = mess(3,7902,1) #lancement impossible
    WERR = mess(187,2006,1)                        # Impossible to launch a direct process #SAM 116455
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    ARET_VALUE = WOK
    Return
  Endif

  If this.PARCOD <> "" and this.CATCOD <> "" and ((this.FLOCOD <> "" and this.FLOREL <> "") or this.ALLFLO = 2)
    #test EDIPARTNER Activated
    WOK = func TEST_ACTIV_EDIPARTNER(this.PARCOD, WERR)
    If WOK = [V]CST_AFALSE
      WNBERR = WNBERR + 1
      #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    Endif

    #test EDICAT Valid
    WOK = func TEST_VALID_CATEGORY(this.CATCOD, WERR)
    If WOK = [V]CST_AFALSE
      WNBERR = WNBERR + 1
      #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    Endif

    #test EDIFLO if ALLFLO not checked
    If this.ALLFLO = [V]CST_ANO
       # Test signed EDIFLO  SAM 110812 XML Signature
#      WOK = func TEST_ACTIV_AND_VALID_EDIFLO(this.FLOCOD, this.FLOREL, WERR)  SAM 110812 XML Signature
      WOK = func TEST_SIGNED_EDIFLO(this.FLOCOD, this.FLOREL, WERR)     # SAM 110812 XML Signature
      If WOK = [V]CST_AFALSE
        WNBERR = WNBERR + 1
        #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
        Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
      Endif
    Else
      this.PROBATCH = [V]CST_AYES    # SAM 110812 XML Signature
      ## All flows will be checked below
    Endif
      Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
    If WNBERR = 0
      this.LASRUNDAT = datetime$
      WOK = fmet this.AUPDATE()
      Case this.CATACT
        When 1 : Gosub RUN_ISSUE_PROCESS    # Issue
        When 2 : Gosub RUN_RECEIPT_PROCESS  # Receipt
      Endcase
#      WOK = [V]CST_AOK #returned value to method
      WOK = WRET_VALUE #returned value to method BUG RBA
    Else
      WOK = [V]CST_AERROR
      #Error : process not executed
    Endif
  Else
    WOK = [V]CST_AERROR
    #"All parameters have to be defined"
    WERR = mess(3,2006,1)
    #ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
  Endif

  WRET_NUMBATCH = WNUMBATCH
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_RUN_PROCESS_DIRECT
#********************************************************************
#
#* @param WNUMBATCH
#* @return WOK
#*!
$MET_RUN_PROCESS_DIRECT
  Local Char WNUMBATCH(20)
  Local Integer WOK    : WOK    = [V]CST_AOK
  Local Char WERR(250) : WERR   = ""
  Local Integer WNBERR : WNBERR = 0
#  Call ASYNCTRACK(this.ACTX, "Preprocessing", "Controlling the launching setup", 0) From ASYRASYNC #Issue 116455
  Call ASYNCTRACK(this.ACTX, mess(25,2007,1), mess(195,195,1), 0) From ASYRASYNC

  If this.DIRECTFLG <> 2
    WOK = [V]CST_AERROR
#    WERR = "Impossible to launch a non direct process" #Issue 116455
    WERR = mess(3,7902,1) #lancement impossible
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    ARET_VALUE = WOK
    Return
  Endif

  If this.PARCOD <> "" and this.CATCOD <> "" and ((this.FLOCOD <> "" and this.FLOREL <> "") or this.ALLFLO = 2)
    #test EDIPARTNER Activated
    WOK = func TEST_ACTIV_EDIPARTNER(this.PARCOD, WERR)
    If WOK = [V]CST_AFALSE
      WNBERR = WNBERR + 1
      #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    Endif

    #test EDICAT Valid
    WOK = func TEST_VALID_CATEGORY(this.CATCOD, WERR)
    If WOK = [V]CST_AFALSE
      WNBERR = WNBERR + 1
      #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    Endif

    #test EDIFLO if ALLFLO not checked
    If this.ALLFLO = 1
      WOK = func TEST_ACTIV_AND_VALID_EDIFLO(this.FLOCOD, this.FLOREL, WERR)
      If WOK = [V]CST_AFALSE
        WNBERR = WNBERR + 1
        #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
        Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
      Endif
    Endif
    If WNBERR = 0
      this.LASRUNDAT = datetime$
      WOK = fmet this.AUPDATE()
      Case this.CATACT
        When 1 : Gosub RUN_ISSUE_PROCESS    # Issue
        When 2 : Gosub RUN_RECEIPT_PROCESS  # Receipt
      Endcase
#      WOK = [V]CST_AOK #returned value to method
      WOK = WRET_VALUE #returned value to method BUG RBA
    Else
      WOK = [V]CST_AERROR
      #Error : process not executed
    Endif
  Else
    WOK = [V]CST_AERROR
    #"All parameters have to be defined"
    WERR = mess(3,2006,1)
    #ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
  Endif

  WRET_NUMBATCH = WNUMBATCH
  ARET_VALUE = WOK
Return

#********************************************************************
# Method RUN_PROCESS
#********************************************************************
#
#* @return WOK
#*!
$MET_RUN_PROCESS
#
#Local Char WERR(250)
#WERR = "test"
#
#        Local File EDITMPDOC [ETC]
#          Trbegin [ETC]
#          [ETC]NUMBATCH    = "EDI-170901-143840911"
#          [ETC]DOCID       = "NOTIFICATION01"
#          [ETC]CATACT      = 2 #receive
#          [ETC]EXTDOCID    = ""
#          [ETC]UUID_JSON   = "789f1e4a-ed07-41d5-bd23-86ee6b8dca3a"
#          [ETC]UUID_PTC    = "883557e6-cf84-4e88-96b4-b027f0420f7c"
#          [ETC]UUID_FLO    = "67a78d4e-605d-4893-9873-f0a080df8253"
#          [ETC]UUID_MSG    = "a4ac1e14-8924-4f3a-ad8c-6eec26952057"
#          [ETC]UUID_SEQ    = "baf3f265-e34a-472d-b59f-11a8fdd55a87"
#          [ETC]REP_ID      = "EDISDNO"
#          [ETC]CATTYP      = 7
#          [ETC]FLOCOD      = "SDELIVERYNO"
#          [ETC]FLOREL      = "1"
#          [ETC]FOLDERX3    = "REPOSX3"
#          [ETC]PATH        = "/folders/REPOSX3/tmp"
#          [ETC]FLGVALIDDOC = 0
#          [ETC]MSGCOD      = "SDELIVERYNO"
#          [ETC]MSGREL      = "1"
#          [ETC]MSGFILNOR   = "EF1"
#          [ETC]FLGMUXIMP   = 1
#          Write [ETC]
#          If !fstat
#            Commit
#            ASTATUS = fmet this.ASETERROR("", "ok done", [V]CST_AINFO)
#          Else
#            #"Insertion into temporary log : failed"
#            WERR = mess(38,2007,1)-":"-mess(9,2007,1)-"("+num$(fstat)+")"
#            ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
##            Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
##            WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
##            WRET_VALUE = [V]CST_AERROR #sur ?
#            Rollback
#          Endif
#          LogicClose File [ETC]
#Return


  Local Integer WOK    : WOK    = [V]CST_AOK
  Local Char WERR(250) : WERR   = ""
  Local Integer WNBERR : WNBERR = 0

#  Call ASYNCTRACK(this.ACTX, "Preprocessing", "Controlling the launching setup", 0) From ASYRASYNC #Issue 116455
  Call ASYNCTRACK(this.ACTX, mess(25,2007,1), mess(195,195,1), 0) From ASYRASYNC

  If this.DIRECTFLG = 2
    WOK = [V]CST_AERROR
#    WERR = "Impossible to launch a direct process" #Issue 116455
    WERR = mess(3,7902,1) #lancement impossible
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    ARET_VALUE = WOK
    Return
  Endif

  If this.PARCOD <> "" and this.CATCOD <> "" and ((this.FLOCOD <> "" and this.FLOREL <> "") or this.ALLFLO = 2)
    #test EDIPARTNER Activated
    WOK = func TEST_ACTIV_EDIPARTNER(this.PARCOD, WERR)
    If WOK = [V]CST_AFALSE
      WNBERR = WNBERR + 1
      #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    Endif

    #test EDICAT Valid
    WOK = func TEST_VALID_CATEGORY(this.CATCOD, WERR)
    If WOK = [V]CST_AFALSE
      WNBERR = WNBERR + 1
      #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    Endif

    #test EDIFLO if ALLFLO not checked
    If this.ALLFLO = 1
      WOK = func TEST_ACTIV_AND_VALID_EDIFLO(this.FLOCOD, this.FLOREL, WERR)
      If WOK = [V]CST_AFALSE
        WNBERR = WNBERR + 1
        #ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
        Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
      Endif
    Endif
    If WNBERR = 0
      this.LASRUNDAT = datetime$
      WOK = fmet this.AUPDATE()
      Case this.CATACT
        When 1 : Gosub RUN_ISSUE_PROCESS    # Issue
        When 2 : Gosub RUN_RECEIPT_PROCESS  # Receipt
      Endcase
#      WOK = [V]CST_AOK #returned value to method
      WOK = WRET_VALUE #returned value to method BUG
    Else
      WOK = [V]CST_AERROR
      #Error : process not executed
    Endif
  Else
    WOK = [V]CST_AERROR
    #"All parameters have to be defined"
    WERR = mess(3,2006,1)
    #ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(this.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
  Endif


  ARET_VALUE = WOK
Return



