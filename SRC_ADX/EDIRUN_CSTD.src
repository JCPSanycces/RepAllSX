#********************************************************************
# Funprog TEST_EDIFLO
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WFLOCOD
#@param WFLOREL
#@return WOK
#*!
Funprog TEST_EDIFLO(WFLOCOD, WFLOREL)
Value Char WFLOCOD
Value Char WFLOREL

  Local Integer WOK : WOK = [V]CST_AERROR
  Local Integer WFOUND_FLO : WFOUND_FLO = [V]CST_AERROR

  Local File EDIFLO [EFL]
  Read [EFL]EFL0 = WFLOCOD;WFLOREL
  If !fstat
    If [F:EFL]VALID = [V]CST_AYES and [F:EFL]FLGACT = [V]CST_AYES
      WOK = [V]CST_AINFO
    Else
      WOK = [V]CST_AWARNING #not valid or activ
    Endif
  Else
    WOK = [V]CST_AERROR #don't exist
  Endif
  LogicClose File [EFL]

End WOK

#********************************************************************
# Funprog EDIFLO_PTCCOD
#********************************************************************
#*
#*
#*
#********************************************************************
#@param WFLOCOD
#@param WFLOREL
#@return WPTCOK
#*!
Funprog EDIFLO_PTCCOD(WFLOCOD, WFLOREL)
Value Char WFLOCOD
Value Char WFLOREL

  Local Char WPTCOK(20)

  Local File EDIFLO [EFL]
  Read [EFL]EFL0 = WFLOCOD;WFLOREL
  If fstat=[V]CST_AOK
    If [F:EFL]VALID = [V]CST_AYES and [F:EFL]FLGACT = [V]CST_AYES
      WPTCOK=[F:EFL]PTCCOD
    Endif
  Endif
  LogicClose File [EFL]

End WPTCOK


#********************************************************************
# Funprog TEST_EDICPYPAR
#********************************************************************
#*
#*
#*
#********************************************************************
