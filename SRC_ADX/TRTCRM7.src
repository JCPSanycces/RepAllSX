#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Saisie d'un compte-rendu à partir du plan de travail               Module CRM         26 juillet 2000
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "AVANT_MEN"    : Gosub AVANT_MEN
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
#PARAM(1) = Code tiers
#PARAM(2) = Date rdv, appel, ou tâche
#PARAM(3) = Heure rdv ou appel
#PARAM(4) = Code rdv, appel ou tâche.
#PARAM(5) = Code interlocuteur.
#PARAM(6) = Code de l'objet TSK,CLL,BAP
#PARAM(7) = numéro de la ligne courante

##########################################################################################################
$OUVRE
Local Integer ISAOBLOCKED

  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:HD4]) : Local File HD4CLOB [HD4] : Endif
  ISAOBLOCKED = 0
  If PARAM(4) = "" Then
    #Aucun identifiant d'action n'a été communiqué. La saisie du compte-rendu est impossible.
    GMESSAGE = mess(972,182,1)
    GERR = 2
    FIN = 1
    Return
  Endif

Global Char GRPOTTR
Global Integer ISCRMGDIRTY
Global Integer GICRMGHBDISP

  GICRMGHBDISP = 0
  ISCRMGDIRTY = 0
  GRPOTTR = ""
  #Définit l'intitulé évalué du bloc compte-rendu
  Case PARAM(6)
    When "BAP"
      GRPOTTR = mess(241,196,1) #Compte-rendu du rendez-vous
    When "CLL"
      GRPOTTR = mess(242,196,1) #Compte-rendu de l'appel
    When "TSK"
      GRPOTTR = mess(243,196,1) #Compte-rendu de la tâche
    When Default
  Endcase
  #Vérification du lock superviseur posé sur l'enregistrement
  Call ISAOB2LOCKED(PARAM(4), PARAM(6), ISAOBLOCKED) From CRMUTIL140
  If ISAOBLOCKED Then
    #Modification en cours sur un autre poste.
    GMESSAGE = mess(10,100,1)
    GERR = 2
    FIN = 1
    Return
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  ETAMEN(1) = 1
  ETAMEN(2) = 1
  ETAMEN(3) = 1
  ETAMEN(4) = 1
  ETAMEN(5) = 1
  ETAMEN(6) = 1
  ETAMEN(7) = 1
  If GMODU(12) = 2 Then
    ETAMEN(8) = 1
  Endif
  If ISCRMGDIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:CRMG]RPORECFLG = 0
  [M:CRMG]VCRNUM = PARAM(4)
  #Définit le type de l'action traitée
  Case PARAM(6)
    When "BAP"
      [M:CRMG]VCRTYP = "BAPRPO"
    When "CLL"
      [M:CRMG]VCRTYP = "CLLRPO"
    When "TSK"
      [M:CRMG]VCRTYP = "TSKRPO"
    When Default
  Endcase
  Raz [M:CRMG]RPOICO
  [M:CRMG]CRMGGREP = ""
  If PARAM(1) <> "" Then
    [M:CRMG]BPRNAM = PARAM(1)
  Else
    If PARAM(5) <> "" Then
      Read [AIN]AIN0=PARAM(5)
      If !fstat Then
        Call BUILDFULNAM("AIN", [M:CRMG]BPRNAM) From CRMUTIL140
      Endif
    Endif
  Endif
  [M:CRMG]DAT = nday$(val(PARAM(2)))
  [M:CRMG]HOU = PARAM(3)
  GICRMGHBDISP = 1
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$AVANT_MEN
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  If GICRMGHBDISP Then
    If [M:CRMG]RPORECFLG Then
      #Rafraichit le plan de travail.
      Gosub ONLOAD From TRTCRMAGD
    Endif
    Raz [M:CRMG]
  Endif
  Kill GRPOTTR
  Kill ISCRMGDIRTY
  Kill GICRMGHBDISP
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  ISCRMGDIRTY = 1
  [M:CRMG]CRMGGREP = "C"
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  #Case GTYPREC
  Case PARAM(6)
    When "BAP"
      Gosub ONSAVEBAP
    When "CLL"
      Gosub ONSAVECLL
    When "TSK"
      Gosub ONSAVETSK
    When Default
  Endcase
  FIN = 0
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Traitement du bouton Enregistrer le rendez-vous
$ONSAVEBAP
Local Instance GZINSOPP Using C_OPPOR
Local Integer IRET
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call DEBTRANS From GLOCK
  Trbegin [BAP]
  Readlock [BAP]APP0=[M:CRMG]VCRNUM
  If fstat Then
    GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
    GERR = 1
    Rollback
    Return
  Endif
  [F:BAP]APTDON = 2
  [F:BAP]APTRPO = [M:CRMG]RPO
  [F:BAP]TYPFULRPO = [M:CRMG]VCRTYP
  [F:BAP]NUMFULRPO = [M:CRMG]VCRNUM
  [F:BAP]RPOFLG = [M:CRMG]RPOFLG
  Rewrite [BAP]
  If fstat Then
    Rollback
    GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
    GERR = 1
    Return
  Else
    Gosub SAVEHD4
    If GERR Then
      Return
    Endif
    #Incrémentation des étapes avant-vente de l'affaire
    # --------------------------------------
    # FGR 12/08/2015 : X3SUIVI108275 (début)
    #    Call ADDOPPSTE("BAPRPO", "", [F:BAP]APTPJT, [F:BAP]APTNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
    #    If IBRETOUR = 0 Then
    #      GMESSAGE = SZMESSAGE
    #      GERR = 1
    #      GOK = 0
    #      Rollback
    #      Return
    #    Endif
    If [F:BAP]APTPJT <> "" Then
      GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
      IRET = fmet GZINSOPP.CRM_ADD_STEPB([F:BAP]APTPJT, "BAP", [F:BAP]APTNUM, "")
      If IRET <> [V]CST_AOK Then
        GMESSAGE = [F:BAP]APTPJT - ":" - func LCCLIB.MAXMSG(GZINSOPP)
        FreeGroup GZINSOPP
        GERR = 1
        GOK = 0
        Return
      Endif
      FreeGroup GZINSOPP
    Endif
    # FGR 12/08/2015 : X3SUIVI108275 (fin)
    # --------------------------------------
  Endif
  [M:CRMG]RPORECFLG = 1
  [M:CRMG]CRMGGREP = ""
  ISCRMGDIRTY = 0
  ETABOU(GSPE1) = 0
  Commit
Return

##########################################################################################################
# Traitement du bouton Enregistrer l'appel
$ONSAVECLL
Local Instance GZINSOPP Using C_OPPOR
Local Integer IRET
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call DEBTRANS From GLOCK
  Trbegin [CLL]
  Readlock [CLL]CLL0=[M:CRMG]VCRNUM
  If fstat Then
    GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
    GERR = 1
    Rollback
    Return
  Endif
  [F:CLL]CLLDON = 2
  [F:CLL]CLLRPO = [M:CRMG]RPO
  [F:CLL]TYPFULRPO = [M:CRMG]VCRTYP
  [F:CLL]NUMFULRPO = [M:CRMG]VCRNUM
  [F:CLL]RPOFLG = [M:CRMG]RPOFLG
  Rewrite [CLL]
  If fstat Then
    Rollback
    Unlock [CLL]
    GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
    GERR = 1
    Return
  Else
    Gosub SAVEHD4
    If GERR Then
      Return
    Endif
    #Incrémentation des étapes avant-vente de l'affaire
    # --------------------------------------
    # FGR 12/08/2015 : X3SUIVI108275 (début)
    #    Call ADDOPPSTE("CLLRPO", "", [F:CLL]CLLOPP, [F:CLL]CLLNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
    #    If IBRETOUR = 0 Then
    #      GMESSAGE = SZMESSAGE
    #      GERR = 1
    #      GOK = 0
    #      Rollback
    #      Return
    #    Endif
    If [F:CLL]CLLOPP <> "" Then
      GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
      IRET = fmet GZINSOPP.CRM_ADD_STEPB([F:CLL]CLLOPP, "CLL", [F:CLL]CLLNUM, "")
      If IRET <> [V]CST_AOK Then
        GMESSAGE = [F:CLL]CLLOPP - ":" - func LCCLIB.MAXMSG(GZINSOPP)
        FreeGroup GZINSOPP
        GERR = 1
        GOK = 0
        Rollback
        Return
      Endif
      FreeGroup GZINSOPP
    Endif
    # FGR 12/08/2015 : X3SUIVI108275 (fin)
    # --------------------------------------
  Endif
  #Gère le nombre d'appel effectués et restant à effectuer pour une opération marketing associée à un appel.
  Read [CLL]CLL0=PARAM(4)
  If !fstat Then
    Call MNGOMP([F:CLL]CLLOPGTYP, [F:CLL]CLLOPGNUM, "ADD") From SUBCLLB
    If GOK < 1 Then
      Rollback
      Return
    Endif
  Endif
  [M:CRMG]RPORECFLG = 1
  [M:CRMG]CRMGGREP = ""
  ISCRMGDIRTY = 0
  ETABOU(GSPE1) = 0
  Commit
Return

##########################################################################################################
# Traitement du bouton Enregistrer la tâche
$ONSAVETSK
  Call DEBTRANS From GLOCK
  Trbegin [TSK]
  Readlock [TSK]TSK0=[M:CRMG]VCRNUM
  If fstat Then
    GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
    GERR = 1
    Rollback
    Return
  Endif
  [F:TSK]TSKDON = 2
  [F:TSK]TSKRPO = [M:CRMG]RPO
  [F:TSK]TYPFULRPO = [M:CRMG]VCRTYP
  [F:TSK]NUMFULRPO = [M:CRMG]VCRNUM
  [F:TSK]RPOFLG = [M:CRMG]RPOFLG
  Rewrite [TSK]
  If fstat Then
    Rollback
    Unlock [TSK]
    GMESSAGE = mess(227,196,1) #Erreur lors de l'enregistrement. Transaction abandonnée.
    GERR = 1
    Return
  Else
    Gosub SAVEHD4
    If GERR Then
      Return
    Endif
  Endif
  [M:CRMG]RPORECFLG = 1
  [M:CRMG]CRMGGREP = ""
  ISCRMGDIRTY = 0
  ETABOU(GSPE1) = 0
  Commit
Return

##########################################################################################################
#Affichage des icônes en en-tête
######################################################
$DISPICON
Local Char SZDESCTL(250)

  #Synthèse
  Gosub DEFICONNUM From CRMUTIL150
  Raz SZDESCTL
  Setlob SZDESCTL With [M:CRMG]FULRPO
  If SZDESCTL = "" Then
    [M:CRMG]RPOICO = ""
    [M:CRMG]RPO = ""
  Else
    If len(SZDESCTL) > GLONCLE Then
      If [M:CRMG]RPOFLG Then
        [M:CRMG]RPOICO = SZICOSYNDON
      Else
        [M:CRMG]RPOICO = SZICOSYN
        [M:CRMG]RPO = SZDESCTL
      Endif
    Else
      [M:CRMG]RPO = SZDESCTL
      [M:CRMG]RPOICO = ""
    Endif
  Endif
Return

##########################################################################################################
#Enregistrement du CLOB compte-rendu
######################################################
$SAVEHD4
Local Char SZCTLCLOB(250)

  Delete [HD4] Where [F:HD4]NUM = [M:CRMG]VCRNUM and [F:HD4]TYP = [M:CRMG]VCRTYP
  If fstat Then
    #Erreur lors de la suppression du compte-rendu de l'action. Transaction abandonnée.
    GMESSAGE = mess(973,182,1)
    GERR = 1
    Rollback
    Return
  Endif
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:CRMG]FULRPO
  If SZCTLCLOB <> "" Then
    Raz [F:HD4]
    [F:HD4]NUM = [M:CRMG]VCRNUM
    [F:HD4]TYP = [M:CRMG]VCRTYP
    [F:HD4]CLOB = [M:CRMG]FULRPO
    Write [HD4]
    If fstat Then
      #Erreur lors de l'enregistrement du compte-rendu de l'action. Transaction abandonnée.
      GMESSAGE = mess(974,182,1)
      GERR = 1
      Rollback
      Return
    Endif
  Endif
Return

