#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("AMD",GBIDC1,GBIDC2) From GOBJET
End

##############################################################################################
# TRADUCTION des ecrans
#                     fonction webisée                                                    cg #
##############################################################################################
$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "SETBOUT"      : Gosub SETBOUT
  When "EXEBOUT"      : Gosub EXEBOUT
  When "LIENS"        : Gosub LIENS
                        Affzo [M:AMD]
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0
  When "AVANT_MODFIC" : Gosub AVANT_MODFIC
  When "APRES_MOD"    : Gosub APRES_MODFIC
  When "FERME"        : Gosub FERME

Endcase

############################################################
$SETBOUT
Call VIREBOUT(CHAINE,"CDAHS") From GOBJET
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"BV4") From GOBJET : # Validation, Copie, Visu
Else
 If GVIRTDIR=""
   Call VIREBOUT(CHAINE,"4") From GOBJET : # Pas de répertoire de publication défini
 Endif
  If GBROWS <> 0
   Call VIREBOUT(CHAINE,"B") From GOBJET : # en web pas de visu client/cs
  Endif
Endif
Return

###########################################################
$EXEBOUT
Local Char WAPPLI
Case REP
 When "B" : # Visu de l'ecran dans la langue de traduction en client serveur
  If [M:AMD]CODMSK<>"" & [M:AMD]LANTRAD<>""
   Call VISUM([M]CODMSK) From SUBAMK
  Endif
 When "V" : # Validation toutes langues
  If [M:AMD]CODMSK<>""
   Read [ADS]DOSSIER = nomap
   Call VALID(CLECUR1,nomap,[F:ADS]NBRLAN,[F:ADS]LAN,0,OK) From VALMSK
  Endif
 When "4"
  Call VISUMWEB([M]CODMSK) From SUBAMK
Endcase
Return

############################################################
$OUVRE
Gosub DEFVAR From ATRANSLATION

If !clalev([F:ATX]) : Local File ATEXTE   [ATX] : Endif
If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif

Local File AMSK    [XMK]
Local File AMSKZON [XMZ]

Local File ATEXTE  [ATX2]
Call OUVRE_TRACE(mess(207,100,1)) From LECFIC

#-----------------------------
# prog spe a chaque produit opdadx sur indusprd.....
# test si ca marche ou pas la remontée ..
#-----------------------------
Local Integer WOK
WOK = 0

Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
If WOK = 1
   WOK =0
   WNBRFOLDER= 0
   Call OUVRE_FIC (GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WOK) From ATRANSLATIONB
Endif


Return

############################################################
$FERME
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Call IMPSCR From ATRTX3
Return

############################################################
$COP_ECRAN
Call PRTSCR("AMKTRAD","","",0,0) From ATRTX3
Return

############################################################
$LIENS
Local Integer I, J, K
Local Char WGLAN

[M:AMD]        = [F:TLA]
[M:AMD]LANTRAD = GLANTRAD
[M:AMD]LAN     = GLANREF
Read [XMK]CODMSK = [M]CODMSK
If fstat : Raz [F:XMK] : Endif

# -------------------------------------------------------#
# on doit afficher le libelle dans la langue de reference
# -------------------------------------------------------#
WGLAN   = GLANGUE
GLANGUE = [M:AMD]LAN
Call TEXTE([M:AMD]INTMSK,[M:AMD]ZINTMSK) From OBJDIV
GLANGUE = WGLAN

Effzo [M:AMD]10

[M:AMD]BASPAG2 = 0
nolign         = 0

Read [TLA]TLA0 = [M:AMD]LAN
If fstat
 Call MESSAGE("Code language don't exist") From GESECRAN
 Return
Endif

# Chargement texte titre écran
Call LOA_LIGNE([F:XMK]INTMSK,mess(2,42,1),0,0)

# Chargement textes titres blocs (sauf invisibles)
For I = 0 To [F:XMK]NBBLOC-1
 If [F:XMK]TYPBLOC(I) <> 5 & [F:XMK]TITBLOC(I) <> 0
  Call LOA_LIGNE([F:XMK]TITBLOC(I),mess(15,115,1),I+1,0)
 Endif
Next I

# Chargement textes champs (sauf invisibles)
Filter [XMZ] Where CODMSK = [F:XMK]CODMSK & INTIT <> 0  & SAIAFF < 3
&            Order By Key CODZON
For [XMZ]
 Call LOA_LIGNE([F:XMZ]INTIT,mess(17,115,1),[F:XMZ]NUMBLOC,[F:XMZ]NOZONE)
Next
Filter [XMZ]
Return

############################################################
$AVANT_MODFIC
Local Integer I, J, K
If [M]LANTRAD <> ""
 J = 0
 For I = 0 To [M:AMD]BASPAG2-1
  If [M:AMD]TXTTRA(I) <> [M:AMD]TXTTRAOLD(I)
   J += 1
  Endif
 Next I
 If J <> 0
  K = 2
  Call AVERTIR(mess(206,100,1)-num$(J),K) From GESECRAN
  If K = 2
   Gosub TRT_MAJ
   #Gosub LIENS
  Endif
 Endif
Endif
Return

############################################################
$TRT_MAJ
Local Char MESSAGE(250)
Local Integer ASTATUS

For I = 0 To [M:AMD]BASPAG2-1
 If [M:AMD]TXTTRA(I) <> [M:AMD]TXTTRAOLD(I)

    If [M]LANTRAD = GFRA
            #115210/6
            If [M]TXTNUM (I) > GMAXTXTSTD & [M]TXTNUM (I)<GNEWTXTSTD
                Gosub BOUCLE_TEXT
                If GOK = 0 : Break : Endif
            Endif
    Else
            Gosub BOUCLE_TEXT
            If GOK = 0 : Break : Endif
    Endif

 Endif
Next I

# Trace
For I = 0 To [M:AMD]BASPAG2-1
 If [M:AMD]TXTTRA(I) <> [M:AMD]TXTTRAOLD(I)
  If GOK = 1
   WMSG = [M:AMD]CODMSK-format$("K:30X",[M:AMD]TXT(I))-
&         format$("K:30X",[M:AMD]TXTTRA(I))+" ("+num$([M:AMD]TXTNUM(I))+")"
   Call ECR_TRACE(WMSG,0) From GESECRAN
  Else
   WMSG = [M:AMD]CODMSK-format$("K:30X",[M:AMD]TXT(I))-
&         mess(17,107,1)
   Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
 Endif
Next I
Return


############################################################
$BOUCLE_TEXT

  # on enregistre le texte dans la langue de traduction
  WLAN= [M:AMD]LANTRAD
  Read [ATX]NUMERO = WLAN;[M:AMD]TXTNUM(I)
  If fstat=0
       [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([M:AMD]TXTTRA(I))),4),20)  #cn 290102 maj de clerec
       [F:ATX]TEXTE  = [M:AMD]TXTTRA(I)
       [F:ATX]LANORI= ""
       Call FLDUPD("ATX") From OBJDIV
       Rewrite [ATX]
       If fstat : GOK = 0 : Call FSTA("ATX") From GLOCK : Endif
       #115210
       If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD)
         ASTATUS = func ATXTSVC.TRANSLATE_ONETEXT_CHAR(GPRODUIT, [F:ATX]NUMERO, [F:ATX]LAN, [F:ATX]TEXTE,[F:ATX]COMMENT,MESSAGE)
         If ASTATUS<>[V]CST_AOK
          GMESSAGE=MESSAGE : GOK=0
         Endif
       Endif
  Else
       #------------------------------------#
       # vérif si enre existe en fra
       #------------------------------------#
       # Issue 85648 - 2012-11-05 by VPO : pb si langue de trad=FRA, le texte n'existe pas
       # on doit donc reprendre le texte dans la langue de ref
       #Read [ATX2]NUMERO = GFRA;[M:AMD]TXTNUM(I)
       Read [ATX2]NUMERO = [M:AMD]LAN;[M:AMD]TXTNUM(I)
       If fstat=0
        [F:ATX]       = [F:ATX2]
        [F:ATX]LAN    = [M:AMD]LANTRAD
        [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([M:AMD]TXTTRA(I))),4),20)  #cn 290102 maj de clerec
        [F:ATX]TEXTE  = [M:AMD]TXTTRA(I)
        [F:ATX]LANORI= ""
        Call FLDCRE("ATX") From OBJDIV
        Write [ATX]
        If fstat : GOK = 0 : Call FSTA("ATX") From GLOCK : Endif
        #115210
        If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD)
          ASTATUS = func ATXTSVC.TRANSLATE_ONETEXT_CHAR(GPRODUIT, [F:ATX]NUMERO, [F:ATX]LAN, [F:ATX]TEXTE,[F:ATX]COMMENT,MESSAGE)
          If ASTATUS<>[V]CST_AOK
           GMESSAGE=MESSAGE : GOK=0
          Endif
        Endif
       Endif
  Endif
Return
###########################################################
$MAJTX
#----------------------------
# mise a jour des envir indus en interne
# apres le commit dans le dossier en cours car cette partie se lance depusi indusprd
If WNBRFOLDER <> 0
        Local Integer WOK
        WOK = 0
        Local Char WTRACE
        Raz WTRACE
        Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
        If WOK = 1
            # on boucle idem sur le tableau
            For I = 0 To [M:AMD]BASPAG2-1
             If [M:AMD]TXTTRA(I) <> [M:AMD]TXTTRAOLD(I)
                If [M]LANTRAD <> GFRA
                    #115210/6
                    If [M]TXTNUM (I) < GMAXTXTSTD | [M]TXTNUM (I)>GNEWTXTSTD
                           # si tout est ok alors là on met a jour les autres envri..
                            # a faire apres le commit.... sur indusprd
                            WOK = 0
                            Call MAJ_TRADTEX([M]TXTNUM (I),[M]LANTRAD,GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WTRACE,WOK) From ATRANSLATIONB
                     Endif
                Endif
             Endif
            Next I
         Endif
 Endif
Return

############################################################
$APRES_MODFIC
Gosub MAJTX
Gosub LIENS
Affzo [M:AMD]10
Return

#####################################################################################################
############################ SUBPROG                #################################################
#####################################################################################################
############################################################
Subprog LOA_LIGNE(LNUM,LINT,LBLO,LZON)
Value Integer LNUM
Value Char    LINT
Value Integer LBLO
Value Decimal LZON
Local Char    WLAN(GLONLAN)
#
nolign         += 1
[M:AMD]BASPAG2 += 1

[M:AMD]FLDINT(nolign-1) = LINT
[M:AMD]BLONUM(nolign-1) = LBLO
[M:AMD]ZONNUM(nolign-1) = LZON

# 25.09.00 on affiche les textes dans la langue de référence

WLAN = [M:AMD]LAN
Read [ATX]NUMERO = WLAN;LNUM
Case fstat
    When 0 :
           [M:AMD]TXT(nolign-1) = [F:ATX]TEXTE
           [M:AMD]COMMENT(nolign-1) = [F:ATX]COMMENT
    When Default :
           [M:AMD]TXT(nolign-1) = ""
           [M:AMD]COMMENT(nolign-1) = ""
Endcase

# on force les textes dans la langue de traduction
WLAN= [M:AMD]LANTRAD
Read [ATX]NUMERO = WLAN;LNUM
Case fstat
    When 0 :
      [M:AMD]TXTTRA(nolign-1) = [F:ATX]TEXTE
    When Default :
      [M:AMD]TXTTRA(nolign-1) = ""
Endcase
[M:AMD]TXTTRAOLD(nolign-1) = [M:AMD]TXTTRA(nolign-1)
[M:AMD]TXTNUM(nolign-1)    = LNUM
[M:AMD]UPDFLG (nolign-1)   = 1
#
End

########################################################################
Subprog VISU_TRAD
End

Local Char WGLAN
Local Char WLANTRAD
WLANTRAD = [M]LANTRAD
# visualisation dans la langue de traduction
WGLAN = GLANGUE
GLANGUE     = WLANTRAD
adxrob(0)   = "E"+GLANGUE
messname(0) = GLANGUE
adxtms      = nomap+".APLSTD"
adxmbm      = adxmbm
Call VISUM([M]CODMSK) From SUBAMK
GLANGUE     = WGLAN
adxrob(0)   = "E"+GLANGUE
messname(0) = GLANGUE
adxtms      = "APLSTD"
adxmbm      = adxmbm
End

########################################################################
########################################################################
Subprog ATEXTE_X3IND130 (WAPPLI,WIND)
Value Char WAPPLI
Value Integer WIND

If WIND < 0 : End : Endif
If [M:AMD]TXTNUM(WIND) = 0     : End : Endif
#115210/6
If [M:AMD]TXTNUM(WIND) > GMAXTXTSTD & [M:AMD]TXTNUM(WIND)<GNEWTXTSTD: End : Endif

Local Char WLANTRAD

WLANTRAD = [M]LANTRAD

# Mise a jour fichier ATEXTE pour X3IND130


# on enregistre le texte dans la langue de traduction
# mais avant on controle que le fra de X3IND130 = fra du dossier ref
# sinon on ne copie pas X3IND130 car dossier ref pas a jour

Local Char WTEXTE_FRA(150)
Local Char WTEXT_INDUS(150)
Local Char WCOMMENT_INDUS(80)

Local Char WLAN_INDUS(GLONLAN)
Local Integer WNUM_INDUS


Local Char WTEXTE_COMMENT(40)


Read [XTX]NUMERO = GFRA;[M:AMD]TXTNUM(WIND)
If fstat = 0
    WTEXTE_FRA = [F:XTX]TEXTE
    WTEXTE_COMMENT = [F:XTX]COMMENT
Else
    # on ne met rien a jour car pas present dans x3ind130
    End
Endif

# lecture de fra dans le dossier ref
# n'existe pas encore .. dossier n'est pas a jour
Read [ATX2]NUMERO = GFRA;[M:AMD]TXTNUM(WIND)
If fstat = 0
    If [F:ATX2]TEXTE <> WTEXTE_FRA
      Call ECR_TRACE("INDUS FOLDER will not be updated, contact ADONIX indus from gaillard",1) From GESECRAN
      End
    Endif
Else
      Call ECR_TRACE("INDUS FOLDER will not be updated, contact ADONIX indus from GAILLARD",1) From GESECRAN
      End
Endif


# ici on continue tout va bien
Read [XTX]NUMERO = WLANTRAD;[M:AMD]TXTNUM(WIND)
Case fstat
        When 0 :
           [F:XTX]CLEREC  = left$(vireblc(toupper(ctrans([M:AMD]TXTTRA(WIND))),4),20)
           [F:XTX]TEXTE  = [M:AMD]TXTTRA(WIND)
           [F:XTX]LANORI= ""
           Call FLDUPD("XTX") From OBJDIV
           Rewrite [XTX]
           If fstat : GOK = 0 : Call FSTA("XTX") From GLOCK : Endif
           WTEXT_INDUS =  [M:AMD]TXTTRA(WIND)
           WTEXT_LAN = [M:AMD]LANTRAD
           WNUM_INDUS= [M:AMD]TXTNUM(WIND)
           WLAN_INDUS = [M:AMD]LANTRAD
           WCOMMENT_INDUS=""
           # 7 sept 2007
           # sur la v140 on ne remonte pas le GER
           # idem pour arabe
           If [M:AMD]LANTRAD <> "GER" and [M:AMD]LANTRAD <> "POL" and [M:AMD]LANTRAD <> "RUS" and [M:AMD]LANTRAD <> "ARB"
               Gosub MAJSUPER_140 From ASUPERV140
           Endif
           # 26 octobre 2009 idem pour polonais et russe en v5
           # idem pour arabe
           If [M:AMD]LANTRAD <> "POL" and [M:AMD]LANTRAD <> "RUS" and [M:AMD]LANTRAD <> "ARB"
               Gosub MAJSUPER_150 From ASUPERV150
           Endif
           # idem pour arabe
           If [M:AMD]LANTRAD <> "ARB"
               Gosub MAJSUPER_160 From ASUPERV160
           Endif
           Gosub MAJSUPER_170 From ASUPERV170
           Gosub MAJSUPER_180 From ASUPERV180
           Gosub MAJSUPER_190 From ASUPERV190
        When 4, 5 :
           #------------------------------------#
           # vérif si enre existe en fra
           #------------------------------------#
           WLANTRAD = GFRA
           Read [ATX2]NUMERO = WLANTRAD;[M:AMD]TXTNUM(WIND)
              Case fstat
                When 0 :
                    [F:XTX]       = [F:ATX2]
                    [F:XTX]LAN    = [M:AMD]LANTRAD
                    [F:XTX]CLEREC  = left$(vireblc(toupper(ctrans([M:AMD]TXTTRA(WIND))),4),20)
                    [F:XTX]TEXTE  = [M:AMD]TXTTRA(WIND)
                    [F:XTX]LANORI= ""
                    Call FLDCRE("XTX") From OBJDIV
                    Write [XTX]
                    If fstat : GOK = 0 : Call FSTA("XTX") From GLOCK  : Endif
                    # dans le cas du BRI on met a jour egalement langue USA uniquement en creation
                  # suite a demande (2007) sophie rebeyrotte : inversion
                  # c'est maintenant le ENG qui est maitre et qui met a jour le bri

                    If GUSER = "XENG" and [M:AMD]LANTRAD = "ENG"
                        Read [XTX]NUMERO = "BRI";[M:AMD]TXTNUM(WIND)
                        Case fstat
                            When 4, 5 :
                                Read [ATX2]NUMERO = WLANTRAD;[M:AMD]TXTNUM(WIND)
                                [F:XTX]       = [F:ATX2]
                                [F:XTX]LAN    = "BRI"
                                [F:XTX]CLEREC  = left$(vireblc(toupper(ctrans([M:AMD]TXTTRA(WIND))),4),20)
                                [F:XTX]TEXTE  = [M:AMD]TXTTRA(WIND)
                                [F:XTX]LANORI= ""
                                Call FLDCRE("XTX") From OBJDIV
                                Write [XTX]
                                If fstat : GOK = 0 : Call FSTA("XTX") From GLOCK  : Endif
                        Endcase
                    Endif
                    WLANTRAD = [M]LANTRAD
                    WTEXT_INDUS = [M:AMD]TXTTRA(WIND)
                    WTEXT_LAN = [M:AMD]LANTRAD
                    WNUM_INDUS= [M:AMD]TXTNUM(WIND)
                    WLAN_INDUS = [M:AMD]LANTRAD
                    WCOMMENT_INDUS=""
                    # 7 sept 2007
                    # sur la v140 on ne remonte pas le GER
                    # idem pour arabe
                    If [M:AMD]LANTRAD <> "GER" and [M:AMD]LANTRAD <> "POL" and [M:AMD]LANTRAD <> "RUS" and [M:AMD]LANTRAD <> "ARB"
                       Gosub MAJSUPER_140 From ASUPERV140
                    Endif
                    # 26 octobre 2009 idem pour polonais et russe en v5
                    # idem arabe
                    If [M:AMD]LANTRAD <> "POL" and [M:AMD]LANTRAD <> "RUS" and [M:AMD]LANTRAD <> "ARB"
                        Gosub MAJSUPER_150 From ASUPERV150
                    Endif
                    # idem arabe
                    If [M:AMD]LANTRAD <> "ARB"
                        Gosub MAJSUPER_160 From ASUPERV160
                    Endif
                    Gosub MAJSUPER_170 From ASUPERV170
                    Gosub MAJSUPER_180 From ASUPERV180
                    Gosub MAJSUPER_190 From ASUPERV190
              Endcase
             WLANTRAD = [M]LANTRAD
        When Default :
            GOK = 0
            Call FSTA("XTX") From GLOCK
Endcase

End
##########################################################################################################
###############Etiquettes ecrans       ###################################################################
##########################################################################################################

Subprog AS_CODMSK(VALEUR)
Variable Char    VALEUR()
End

############################################################
Subprog C_CODMSK(VALEUR)
Variable Char    VALEUR()
If  [M:AMD]LANTRAD = " " or [M:AMD]LAN = ""
      mkstat = 2
Else
    # appel action de controle dans ecran
    Read [XMK]CODMSK = VALEUR
    If fstat : Raz [XMK] : mkstat = 2 : Endif
Endif
End

############################################################
Subprog AV_BASPAG2
If nolign > 0
  If [M:AMD]TXTTRA(nolign-1) <> [M:AMD]TXTTRAOLD(nolign-1)
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End

############################################################
Subprog APRES_BASPAG2
If [M:AMD]TXTTRA(nolign-1) <> [M:AMD]TXTTRAOLD(nolign-1)
   pcolor = GCOUL(1)
  [M:AMD]UPDFLG(nolign-1) = 2
Else
  pcolor = GCOUL(0)
  [M:AMD]UPDFLG(nolign-1) = 1
Endif
Affzo [M:AMD]TXTTRA(nolign-1)
Affzo [M:AMD]UPDFLG(nolign-1)
End

############################################################
Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M]LANTRAD
  mkstat = 2
  End
Endif
End

############################################################
Subprog AV_LAN(VALEUR)
Variable Char    VALEUR()
#Par défautr langue de reference = Glangue
If VALEUR = ""
        VALEUR = GLANREF
Endif
End

#############################################################
Subprog AM_LANTRAD(VALEUR)
Variable Char     VALEUR()
GLANTRAD = VALEUR
If [M:AMD]CODMSK <> ""
  Gosub LIENS
  Affzo [M:AMD]10
Endif
End

############################################################
Subprog B1_TXTTRA(VALEUR)
Variable Char    VALEUR()
Local Integer WNUM
End

############################################################
Subprog AS_TXTTRA(VALEUR)
Variable Char    VALEUR()

# rien a saisir si langue fra et numero <  50000
# modif du texte fra unqiuemeent si texte spécifique
If [M]LANTRAD = GFRA
    #115210/6
    If [M]TXTNUM (nolign -1) < GMAXTXTSTD | [M]TXTNUM (nolign -1)>GNEWTXTSTD
        mkstat = 2
        End
    Endif
Endif


End

########################################
Subprog AV_LANTRAD(VALEUR)
Variable Char    VALEUR()

#Par défautr langue de reference = Glangue
If VALEUR = ""
        VALEUR = GLANTRAD
Endif

End

########################################
Subprog C_LANTRAD(VALEUR)
Variable Char    VALEUR()

If VALEUR=[M]LAN
    mkstat = 2
    End
Endif


Read [TLA]TLA0 = VALEUR
If fstat
    mkstat = 2
    End
Endif


End

########################################
Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
#Global Char GLANREF
GLANREF = VALEUR
# attention la classe M n'est pas encore chargée
End

########################################
Subprog AP_LAN(VALEUR)
Variable Char    VALEUR()
End

