If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ADDSTRNAM From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ADDSTRNAM From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ADDSUB From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ADDSUB From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ADDTWN From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ADDTWN From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT :  Endif
