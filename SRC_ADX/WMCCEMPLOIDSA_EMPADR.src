Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ADDPRI From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ADDPRI From WMC1EMPLOIDSA_EMPADR : Gosub TESTALLSTAT :  Endif
