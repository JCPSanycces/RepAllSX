#<AdxTL>@(#)0.0.0.0 $Revision$
#**###########################################################
#
#  Legal datas for legislation SPA for table TABVAT
#
# Window AWI=>TVTLEGSPA
# Mask/Screen AMK=>TVTLEGSPA [TVTSPA]
# SAM 108172
############################################################**!


$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN

 When "AS_SPAVAT"     : Gosub S_SPAVAT
Endcase
Return


$OUVRE
#----- Paramètres de l'action DATALEG -----#
Local Char LEG(GLONADI)
#Local Char COD(max(GLONTVB,GLONVAT,5))
Local Char COD(GLONVAT)
[L]LEG = PARAM(1)
[L]COD = PARAM(2)

#----- Tables utilisée -----#
If !clalev([F:TVT]) : Local File TABVAT [TVT] : Endif
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif

#----- Masque local -----#
Local Mask TVTLEGSPA [TVTSPA]

[M]CURLEG=[L]LEG
#----- Variables locales pour sauvegarde du masque -----#
Local Char SPAVAT(GLONVAT)
Local Integer SPAEXEVAT
Local Integer SPAIMPVAT
Local Integer SPAPURTAG
Local Integer SPAIVT303
Local Integer SPAPRA303
Local Integer SPAAGRVAT
Local Integer SPAUSEPDT
Local Integer SPANRS
Local Integer SPARNT
Local Integer SPAINR
Local Integer SPASPETAX     # SAM 108172
Return

$DEBUT
Local Integer WRET :#--CPO 71937

#--- Alimentation des champs de l'écran ---#
#--CPO 71937 TVT and LEG as part of the key
Call LEC_TVT_LEG([L]LEG,[L]COD,WRET) From TRTLECLEG
If WRET : Raz [F:TVT] Endif
[M:TVTSPA] = [F:TVT]
#Read [TVT]TVT0 = [L]COD;[L]LEG
#If !fstat
# [M:TVTSPA] = [F:TVT]
#Endif
#--/CPO
#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:TVTSPA]

Affzo [M:TVTSPA]
Setmok [M:TVTSPA] With 0
Return

$ENR
Trbegin [TVT]
Readlock [TVT]TVT0 = [L]COD;[L]LEG
#--CPO 71937
If fstat=5
  Readlock [TVT]TVT0 = [L]COD;""
Endif
#--/CPO
If !fstat
 [F:TVT]SPAVAT    = [M:TVTSPA]SPAVAT
 [F:TVT]SPAEXEVAT = [M:TVTSPA]SPAEXEVAT
 [F:TVT]SPAIMPVAT = [M:TVTSPA]SPAIMPVAT
 [F:TVT]SPAPURTAG = [M:TVTSPA]SPAPURTAG
 [F:TVT]SPAIVT303 = [M:TVTSPA]SPAIVT303
 [F:TVT]SPAPRA303 = [M:TVTSPA]SPAPRA303
 [F:TVT]SPAAGRVAT = [M:TVTSPA]SPAAGRVAT
 [F:TVT]SPAUSEPDT = [M:TVTSPA]SPAUSEPDT
 [F:TVT]SPANRS    = [M:TVTSPA]SPANRS
 [F:TVT]SPARNT    = [M:TVTSPA]SPARNT
 [F:TVT]SPAINR    = [M:TVTSPA]SPAINR
 [F:TVT]SPASPETAX = [M:TVTSPA]SPASPETAX     # SAM 108172

 Rewrite [TVT]
 If fstat
  GOK = 0 : Call FSTA("TVT") From GLOCK : Return
 Endif
Endif
Commit
[L]=[M:TVTSPA] : REP=""
Return

$ABA
[M:TVTSPA]=[L] : REP=""
Gosub ENR
Affzo [M:TVTSPA]
Return

$APRES_MODIF
Read [ALK]LCKCLE="TVT"+[L]LEG+"\"+[L]COD;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
 GMESSAGE=mess(10,100,1)
 GERR=1
 [M:TVTSPA]=[L]
 Affzo [M:TVTSPA] :# FIN=1
Else
 REP = "M"
 Local Char SYMB(20)
 SYMB="TVT"+[L]LEG+"\"+[L]COD
 Lock SYMB With lockwait=0
Endif
Return

$FIN
If dim(SYMB)>0
 Unlock SYMB
Endif
Return

$S_SPAVAT
START   = "[F:TVT]VAT"
ORDRE   = "[F:TVT]VAT;[F:TVT]LEG"
Return
######################################################################################
## Etiquettes écran TVTLEGSPA
######################################################################################
Subprog IB_SPAVAT
Raz GBOUT1
End

Subprog AS_SPAVAT(VALEUR)
Variable Char    VALEUR()
 If dim([M:TVT1]VATTYP)>0 & [M:TVT1]VATTYP<>2
  Grizo [M]SPAVAT
  mkstat=1
 Else
  Actzo [M]SPAVAT
 Endif
End

Subprog C_SPAVAT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer CODOK : CODOK=0
 Local Integer CODEXIST : CODEXIST=0
 Read [TVT]TVT0=VALEUR;[M]CURLEG
 If fstat
  Filter [TVT] Where VAT=VALEUR
  For [TVT]TVT0
   CODEXIST+=1
   If [F:TVT]LEG=[M]CURLEG | [F:TVT]LEG=""
    CODOK=1
   Endif
  Next
  Filter [TVT]
 Else
  CODEXIST=1
  CODOK=1
 Endif
 If !CODEXIST
  GMESSAGE = mess(23,100,1) : # Fiche inexistante
  mkstat = 2 : End
 Elsif [M]CURLEG<>""
  If !CODOK
   # Fiche inexistante pour la législation courante
   GMESSAGE = mess(232,107,1)-"["+[M]CURLEG+"]"
   mkstat=2 : End
  Endif
 Endif
Else
 If dim([M:TVT1]VATTYP)>0 & [M:TVT1]VATTYP=2
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2
 Endif
Endif
End
