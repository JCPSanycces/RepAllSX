#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
######################################################################################
### DCLTYP -> 1 Periodic; 2 Annual; 3 Recap; 4 European serv.
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FILTRE"     : Gosub FILTRE
  When "RAZCRE"     : Gosub RAZCRE
  When "INICRE"     : Gosub INICRE
  When "CREATION"   : Gosub CREATION
  When "APRES_CRE"  : Gosub APRES_CRE
  When "APRES_MOD"  : Gosub APRES_MOD
  When "INIMOD"     : Gosub INIMOD
  When "MODIF"      : Gosub MODIF
  When "EXEBOUT"    : Gosub EXEBOUT
  When "LIENS"      : Gosub LIENS
  When "ANNULE"     : Gosub ANNULE
  When "MODIF"      : Gosub MODIF
  When "SETBOUT"    : Gosub SETBOUT
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

If !clalev([F:CPY])   :  Local File COMPANY     [CPY]         : Endif
If !clalev([F:DVPB])  :  Local File DCLVATPORB  [DVPB]        : Endif
If !clalev([F:DVPF])  :  Local File DCLVATPORF  [DVPF]        : Endif
If !clalev([F:DVPL])  :  Local File DCLVATPORL  [DVPL]        : Endif
If !clalev([F:DVPP])  :  Local File DCLVATPORP  [DVPP]        : Endif
If !clalev([F:TCA])   :  Local File TABCOUAFF   [TCA]         : Endif
If !clalev([F:TCY])   :  Local File TABCOUNTRY  [TCY]         : Endif

Local Char LNUM(GLONVCR)
Local Char SITE(GLONFCY)

Local Integer I, RCOUNT, STAT

Gosub DEC_COM_VARS From CALVATPOR

Return
######################################################################################
######################################################################################
$FILTRE

FILTSUP = "[F:DVPH]DCLTYP = 4"

Return
######################################################################################
######################################################################################
$RAZCRE

[M:DVPHE0]DCLTYP = 4

Return
######################################################################################
######################################################################################
$INICRE

Gosub GET_CPYVARS

Call LECTCA(2,OK) From SUBTCA
If fstat | !OK
  GERR=1 : GMESSAGE=mess(58,105,1)-mess(2,14,1)-mess(250,199,1) : Return
Endif

GMANCOU = [F:TCA]MANCOU(14)
GCPT    = [F:TCA]CODNUM(14)
STAT    = 0

If  GMANCOU <> 2 | (GMANCOU=2 & vireblc([M:DVPHE0]DCLNUM,2)="")
  Call NUMERO (GCPT,SITE,[F:DVPH]STRDAT,"",LNUM,STAT) From SUBANM
  If GOK>0 & STAT=0
      [F:DVPH]DCLNUM   = LNUM
      [M:DVPHE0]DCLNUM = LNUM
      Affzo [M:DVPHE0]DCLNUM
  Else
     Local Char MESSA(80)
     GMESSAGE=mess(60,199,1)-"("+GCPT+") : "
     Gosub MESSAGE From SUBANM
     GMESSAGE-=MESSA : GERR=1 : GOK=0 : Return
  Endif
Endif

Gosub COMMON_INISAVE

Return
######################################################################################
######################################################################################
$INIMOD

Gosub COMMON_INISAVE

Return
######################################################################################
######################################################################################
$COMMON_INISAVE


Read [F:DVPP]DVPP0=[M:DVPHE0]CPY;year([M:DVPHE0]STRDAT)
If fstat : Raz [F:DVPP] : Endif

If [M:DVPHE1]DCLMON>0
  [F:DVPH]FPERIOD = format$("N0:2", [M:DVPHE1]DCLMON)
Elsif [M:DVPHE1]DCLQUA>0
  Case [M:DVPHE1]DCLQUA
    When 1 : [F:DVPH]FPERIOD = "03T"
    When 2 : [F:DVPH]FPERIOD = "06T"
    When 3 : [F:DVPH]FPERIOD = "09T"
    When 4 : [F:DVPH]FPERIOD = "12T"
  Endcase
Endif

If [M:DVPHE1]FIRDCL =2
  [F:DVPH]FTIPENT = 1
Else
  [F:DVPH]FTIPENT = 2
Endif

Return
######################################################################################
######################################################################################
$EXEBOUT

Case BOUT
  When "1"
    Gosub RELIT From GOBJSUB
Endcase

Return
######################################################################################
######################################################################################
$LIENS

GSOCIETE = [F:DVPH]CPY

Gosub GET_CPYVARS

Gosub LOAD_LISTS

Gosub LOAD_FIELDS

If [M:DVPHE1]FIRDCL = 2
  Diszo [M:DVPHE1]AMTSBS
Else
  If [M:DVPHE1]PERCHG = 2
    Actzo [M:DVPHE1]AMTSBS
  Else
    Diszo [M:DVPHE1]AMTSBS
  Endif
Endif

[M:DVPHE0]CUR          = [F:CPY]ACCCUR

Return
######################################################################################
######################################################################################
$LOAD_LISTS

Raz [M:DVPHE2]
Filter [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM  & [F:DVPL]LINTYP = 11 Order By Key DVPL0
For [F:DVPL]
  [M:DVPHE2]CRY([M:DVPHE2]NBLIG)    = [F:DVPL]CRY
  [M:DVPHE2]EECNUM([M:DVPHE2]NBLIG) = [F:DVPL]EECNUM
  [M:DVPHE2]AMT([M:DVPHE2]NBLIG)    = [F:DVPL]AMTBAS
  [M:DVPHE2]OPETYP([M:DVPHE2]NBLIG) = [F:DVPL]OPETYP
  [M:DVPHE2]NBLIG                  += 1
Next
Filter [F:DVPL]

Affzo [M:DVPHE2]

Return
######################################################################################
######################################################################################
$LOAD_FIELDS

Read [F:DVPF]DVPF0 = [F:DVPH]DCLNUM;1;"010" : If fstat : Raz [F:DVPF] : Endif
[M:DVPHE2]FLD10 = [F:DVPF]AMT : Affzo [M:DVPHE2]FLD10
Read [F:DVPF]DVPF0 = [F:DVPH]DCLNUM;1;"011" : If fstat : Raz [F:DVPF] : Endif
[M:DVPHE2]FLD11 = [F:DVPF]AMT : Affzo [M:DVPHE2]FLD11
Read [F:DVPF]DVPF0 = [F:DVPH]DCLNUM;1;"017" : If fstat : Raz [F:DVPF] : Endif
[M:DVPHE2]FLD17 = [F:DVPF]AMT : Affzo [M:DVPHE2]FLD17
Read [F:DVPF]DVPF0 = [F:DVPH]DCLNUM;1;"018" : If fstat : Raz [F:DVPF] : Endif
[M:DVPHE2]FLD18 = [F:DVPF]AMT : Affzo [M:DVPHE2]FLD18
Read [F:DVPF]DVPF0 = [F:DVPH]DCLNUM;1;"019" : If fstat : Raz [F:DVPF] : Endif
[M:DVPHE2]FLD19 = [F:DVPF]AMT : Affzo [M:DVPHE2]FLD19

Return
######################################################################################
######################################################################################
$CREATION

Gosub COMMON_SAVE

Return
######################################################################################
######################################################################################
$MODIF

Gosub COMMON_SAVE

Return
######################################################################################
######################################################################################
$COMMON_SAVE

Gosub SAVE_LISTS

Gosub SAVE_FIELDS

Return
######################################################################################
######################################################################################
$SAVE_FIELDS

[L]DCLNUM = [M:DVPHE0]DCLNUM

#field 11
Read [F:DVPF]DVPF0 = [M:DVPHE0]DCLNUM;1;"011"
If fstat
  [F:DVPF]DCLNUM = [M:DVPHE0]DCLNUM
  [F:DVPF]DCLPAG = 1
  [F:DVPF]DCLFLD = "011"
  [F:DVPF]AMT    = [M:DVPHE2]FLD11
  Write [F:DVPF]
Else
  [F:DVPF]AMT = [M:DVPHE2]FLD11
  Rewrite [F:DVPF]
Endif
If fstat
  GOK = 0 : Call FSTA("DVPF") From GLOCK
Endif

If GOK=0 : Return : Endif

Gosub PROC_FIELDS From CALVATPORE
If OK = 0
  GOK = 0
Endif

##field 10
#Read [F:DVPF]DVPF0 = [M:DVPHE0]DCLNUM;1;"010"
#If fstat
#  [F:DVPF]DCLNUM = [M:DVPHE0]DCLNUM
#  [F:DVPF]DCLPAG = 1
#  [F:DVPF]DCLFLD = "010"
#  [F:DVPF]AMT    = [M:DVPHE2]FLD10
#  Write [F:DVPF]
#Else
#  [F:DVPF]AMT = [M:DVPHE2]FLD10
#  Rewrite [F:DVPF]
#Endif
#

#
##field 17
#Read [F:DVPF]DVPF0 = [M:DVPHE0]DCLNUM;1;"017"
#If fstat
#  [F:DVPF]DCLNUM = [M:DVPHE0]DCLNUM
#  [F:DVPF]DCLPAG = 1
#  [F:DVPF]DCLFLD = "017"
#  [F:DVPF]AMT    = [M:DVPHE2]FLD17
#  Write [F:DVPF]
#Else
#  [F:DVPF]AMT = [M:DVPHE2]FLD17
#  Rewrite [F:DVPF]
#Endif
#
##field 18
#Read [F:DVPF]DVPF0 = [M:DVPHE0]DCLNUM;1;"018"
#If fstat
#  [F:DVPF]DCLNUM = [M:DVPHE0]DCLNUM
#  [F:DVPF]DCLPAG = 1
#  [F:DVPF]DCLFLD = "018"
#  [F:DVPF]AMT    = [M:DVPHE2]FLD18
#  Write [F:DVPF]
#Else
#  [F:DVPF]AMT = [M:DVPHE2]FLD18
#  Rewrite [F:DVPF]
#Endif

Return
######################################################################################
######################################################################################
$SAVE_LISTS

#--- lists
[L]RCOUNT = 1
Delete [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHE0]DCLNUM & [F:DVPL]LINTYP = 11
If fstat=1 : GOK=-1 : GLOCK="$DVPL" : Return : Endif

For I = 0 To [M:DVPHE2]NBLIG-1

  [F:DVPL]DCLNUM = [M:DVPHE0]DCLNUM
  [F:DVPL]LINTYP = 11
  [F:DVPL]LSTLIN = [L]RCOUNT
  [F:DVPL]CRY    = [M:DVPHE2]CRY(I)
  [F:DVPL]EECNUM = [M:DVPHE2]EECNUM(I)
  [F:DVPL]AMTBAS = [M:DVPHE2]AMT(I)
  [F:DVPL]OPETYP = [M:DVPHE2]OPETYP(I)

  Write [F:DVPL]
  If fstat
    GOK = 0 : Call FSTA("DVPL") From GLOCK : Break
  Endif

  [L]RCOUNT += 1
Next

Return
######################################################################################
######################################################################################
$APRES_CRE

Gosub COMMON_APRESAV

Return
######################################################################################
######################################################################################
$APRES_MOD

Gosub COMMON_APRESAV

Return
######################################################################################
######################################################################################
$COMMON_APRESAV

[L]DCLNUM = [M:DVPHE0]DCLNUM

Call DEBTRANS From GLOCK
Trbegin [F:DVPF]

Gosub FIELD_TOTALS From CALVATPORE

If !GOK
  Goto AB_APRESSAV
Endif

Commit

Gosub LOAD_FIELDS
Affzo [M:DVPHE2]

Return
######################################################################################
######################################################################################
$AB_APRESSAV

Rollback

Return
######################################################################################
######################################################################################
$ANNULE

Delete [F:DVPB] Where [F:DVPB]DCLNUM = [M:DVPHE0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORB" - [M:DVPHE0]DCLNUM : Return : Endif
Delete [F:DVPF] Where [F:DVPF]DCLNUM = [M:DVPHE0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORF" - [M:DVPHE0]DCLNUM : Return : Endif
Delete [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHE0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORL" - [M:DVPHE0]DCLNUM : Return : Endif

Return
######################################################################################
######################################################################################
$SETBOUT

If GREP <> "" | !CLECUR
  Call  VIREBOUT(CHAINE,"12")  From GOBJET
Endif

Return
######################################################################################
######################################################################################
$GET_CPYVARS

If [F:CPY]CPY <> GSOCIETE
  Read [F:CPY]CPY0 = GSOCIETE
  If fstat : Raz [F:CPY] : Endif
Endif

GCURLEG = [F:CPY]LEG
SITE   = [F:CPY]MAIFCY
If SITE = "" : SITE = GSOCIETE : Endif #RMA * 102701

Return
######################################################################################
######################################################################################
## Section automatically added (screen DVPHA0) 26-10-2012 01:00:21 (RMA)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

GSOCIETE = VALEUR

Gosub GET_CPYVARS

[M:DVPHE0]CUR          = [F:CPY]ACCCUR
Affzo [M:DVPHE0]CUR

End
######################################################################################
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("PORVAT",VALEUR)<>"2"
  mkstat = 2
  GMESSAGE = func AFNC.MES2(mess(00218,00125,1), "PORVAT", mess(1,1,1))
Endif

End
######################################################################################
######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

Read [F:DVPP]DVPP0 = [M:DVPHE0]CPY;year(VALEUR)
If fstat
  mkstat = 2
  GMESSAGE = mess(13,7710,1)
  End
Endif

[M:DVPHE1]HQRLOC = [F:DVPP]HQRLOC
[M:DVPHE1]AN1LOC = [F:DVPP]AN1LOC
[M:DVPHE1]AN2LOC = [F:DVPP]AN2LOC

Affzo [M:DVPHE1]

End
######################################################################################
######################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR

[M:DVPHE1]DCLYEA = year([M:DVPHE0]STRDAT)
If month(VALEUR) - month([M:DVPHE0]STRDAT) = 0
  [M:DVPHE1]DCLMON = month(VALEUR)
  [M:DVPHE1]DCLQUA = 0
Else
  [M:DVPHE1]DCLMON = 0
  If month(VALEUR)<4
    [M:DVPHE1]DCLQUA = 1
  Elsif month(VALEUR)>=4 & month(VALEUR)<7
    [M:DVPHE1]DCLQUA = 2
  Elsif month(VALEUR)>=7 & month(VALEUR)<10
    [M:DVPHE1]DCLQUA = 3
  Else
    [M:DVPHE1]DCLQUA = 4
  Endif
Endif

Affzo [M:DVPHE1]DCLYEA
Affzo [M:DVPHE1]DCLMON
Affzo [M:DVPHE1]DCLQUA

End
######################################################################################
######################################################################################
Subprog D_FIRDCL(VALEUR)
Variable Integer VALEUR

VALEUR = 2
[M]AMTSBS = 1  : Diszo [M]AMTSBS

End
######################################################################################
######################################################################################
Subprog AM_FIRDCL(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  [M]AMTSBS = 1  : Diszo [M]AMTSBS
Else
  If [M]PERCHG = 2
    Affzo [M]AMTSBS : Actzo [M]AMTSBS
  Else
    [M]AMTSBS = 1   : Diszo [M]AMTSBS
  Endif
Endif

End
######################################################################################
######################################################################################
Subprog AM_PERCHG(VALEUR)
Variable Integer VALEUR

If [M]FIRDCL = 1
  If VALEUR = 2
    Affzo [M]AMTSBS : Actzo [M]AMTSBS
  Else
    [M]AMTSBS = 1   : Diszo [M]AMTSBS
  Endif
Endif
End
######################################################################################
######################################################################################
Subprog AS_OPETYP(VALEUR)
Variable Integer VALEUR

GMENLOC(2)=1
GMENLOC(3)=1

End
######################################################################################
######################################################################################

######################################################################################
## Section automatically added (screen DVPHE2) 08/03/2018 14:25:15 (VAVIL)
######################################################################################
Subprog C_EECNUM(VALEUR)
Variable Char    VALEUR()

Local Char NUMTVA,PAYS : [L]NUMTVA = "" : [L]PAYS = ""
[L]PAYS   = [M:DVPHE2]CRY(nolign-1) : [L]NUMTVA = [L]PAYS + VALEUR
Call CONTTVA([L]NUMTVA,[L]PAYS) From CONTNUM
End


######################################################################################

