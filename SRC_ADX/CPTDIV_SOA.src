################################################################################
##  Position des devises (transaction et référentiels) par rapport à l'Euro
################################################################################
######################################################################################
# get global values for the following:
#
# - SOA_GCURFLG
#Global Libelle  GCURFLG             : # Réservé X3
#
# - SOA_GDEVISE
#Global Char     GDEVISE(GLONCUR)(1..GDIMDEV) : # Codes devises
#
# - SOA_GDIMDEV
#Global Integer  GDIMDEV             : # Dimension variables devises
#Local Integer II
#If clalev([F:TCU])=0
# Local File TABCUR   [TCU]
# II = 2
#Endif
#GDIMDEV = max(nbrecord([TCU])+20,100)
#
# - SOA_GNBDEV
#Global Integer  GNBDEV              : # Nombre de devises
#
# - SOA_GDEVDAT
#Global Date     GDEVDAT(1..GDIMDEV) : # Date de passage à l'euro
#
######################################################################################
Subprog SETFLGDEV(DEV,SOC,DAT)
Value Char    DEV()         : # Devise (transaction)
Value Char    SOC()         : # Société
Value Date    DAT           : # Date

Local Char    DEVLED(GLONCUR)
Local Integer I, IREF

Local Libelle SOA_GCURFLG   : # Réservé X3
Call GCURFLG(DEV,DAT,SOA_GCURFLG) From ESSGLOB_SOA

Local Integer  SOA_GDIMDEV        : # Dimension variables devises
Call GDIMDEV(SOA_GDIMDEV) From ESSGLOB_SOA

Local Date SOA_GDEVDAT(1..SOA_GDIMDEV) : # Date de passage à l'euro
Local Char SOA_GDEVISE(GLONCUR)(1..SOA_GDIMDEV)  : # Codes devises
Local Integer SOA_GNBDEV : # Nombre de devises
Call GDEVISE(SOA_GNBDEV,SOA_GDEVDAT,SOA_GDEVISE) From ESSGLOB_SOA

Local Libelle SOA_GLEDFLG(1..len(mess(0,2644,1))) : # Positionnement de la devise de référentiel (In ou Out) # Positioning the Repository Currency  #???
Local Char SOA_GTABCPT(80) : Call GTABCPT(SOA_GTABCPT) From ESSGLOB_SOA

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:GCM]) : Local File =SOA_GTABCPT+"GACM"    [GCM] : Endif

# Devise des référentiels
Call LEC_CPY(SOC) From CPTLEC_SOA            # Lecture de la société juridique # Reading the legal company
Call LEC_GCM([F:CPY]ACM) From CPTLEC_SOA     # Lecture du modèle comptable     # Reading the accounting model

# The usage for the below code is not know at this point.   #Commented out because it's not being used
#For IREF=1 To len(mess(0,2644,1))
# SOA_GLEDFLG(IREF) = 1
# I = find([F:GCM]CUR(IREF-1),SOA_GDEVISE(1..SOA_GNBDEV))
# If !I
#  SOA_GLEDFLG(IREF)=0
# Else
#  If SOA_GDEVDAT(I)<=DAT : SOA_GLEDFLG(IREF)=2 : Endif
# Endif
#Next
End
###########################################################################################
## Plans de comptes et axes à saisir pour un modéle comptable  (Idem SETPLAN sauf qu'ici on
## renvoie tous les axes même ceux qui sont déflagués 'Saisie en amont' SETPLAN2 sert
## notamment pour l'affichage des axes des fiches sociétés et site (sections par défaut)
###########################################################################################
Subprog SETPLAN2(MODELE,NBPLAN,PLAN,REFTYP,NBAXE,AXE,OBLIG)
Value    Char    MODELE         : # Modèle comptable
Variable Integer NBPLAN         : # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..)    : # Plans (COA) (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer REFTYP(1..)    : # Types référentiels (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer NBAXE          : # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)     : # Axes (DIE)
Variable Integer OBLIG(1..)     : # Obligatoire (O/N)
Local Integer SAI_AMONT : SAI_AMONT = 0
Local Integer INI_AXE   : INI_AXE = 1
Gosub SET_PLAN
End
#------------------------------------------------------------------------------------------
$SET_PLAN
#
# Sharvin - need to SOA the following globals
# - GOPTCANA      done
# - GTABCPT       done
# - GSOCIETE      done
# - GGCM           - SETGLBGCM  done
# - GGCMNBR        - SETGLBGCM  done
# - GLEDTYPGEN     - SETGLBGCM  done
# - GLEDGEN        - SETGLBGCM  done
# - GLEDTYPANA     - SETGLBGCM  done
# - GLEDANA        - SETGLBGCM  done
# - GLEDNBR        - SETGLBLED  done
# - GLED           - SETGLBLED  done
# - GLEDCOA        - SETGLBLED  done
# - GLEDDIENBR     - SETGLBLED  done
# - GDIE           - SETGLBLED  declared in SETGLBLED_SOA
Local Integer SOA_GOPTCANA    : Call GOPTCANA(SOA_GOPTCANA) From ESSBLOB_SOA
Local Char    SOA_GTABCPT(80) : Call GTABCPT(SOA_GTABCPT) From ESSGLOB_SOA
Local Char    SOA_GSOCIETE(5) : Call GSOCIETE(SOA_GSOCIETE) From ESSGLOB_SOA
Local Char    SOA_GGCM(GLONGCM)(1..SOA_GGCMNBR)
Local Integer SOA_GGCMNBR
Local Libelle SOA_GLEDTYPGEN(1..SOA_GGCMNBR)
Local Char    SOA_GLEDGEN(GLONLED)(1..SOA_GGCMNBR)
Local Libelle SOA_GLEDTYPANA(1..SOA_GGCMNBR)
Local Char    SOA_GLEDANA(GLONLED)(1..SOA_GGCMNBR)
Local Integer SOA_GLEDNBR
Local Char    SOA_GLED(SOA_GLONLED)(1..SOA_GLEDNBR)
Local Char    SOA_GLEDCOA(SOA_GLONCOA)(1..SOA_GLEDNBR)
Local Integer SOA_GLEDDIENBR(1..SOA_GLEDNBR)
Local Char    SOA_GDIE1(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 1
Local Char    SOA_GDIE2(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 2
Local Char    SOA_GDIE3(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 3
Local Char    SOA_GDIE4(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 4
Local Char    SOA_GDIE5(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 5
Local Char    SOA_GDIE6(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 6
Local Char    SOA_GDIE7(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 7
Local Char    SOA_GDIE8(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 8
Local Char    SOA_GDIE9(GLONDIE)(1..SOA_GLEDNBR)   : # Axe 9

Local Integer IGCM , ILED , IREF , IDIE , NBREF
Local Char    REFER(GLONLED)(1..max(1,len(mess(0,2644,1))))
Local Char    CODAXE(GLONDIE) , REF(GLONLED)
#use clalev
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File =SOA_GTABCPT+"GACM"    [GCM] : Endif
Raz NBPLAN
If INI_AXE : Raz NBAXE : Endif
If dim([L]SOCIETE)>0 & SOCIETE<>""            #check to see where [L]SOCIETE comes from
 Call LEC_CPY(SOCIETE) From CPTLEC_SOA        #done
Else
 Call LEC_CPY(SOA_GSOCIETE) From CPTLEC_SOA       #done
Endif
Call LEC_GCM(MODELE) From CPTLEC_SOA              #done
IGCM   = find(MODELE,SOA_GGCM(1..SOA_GGCMNBR))
If !IGCM
 #Call GLOBVAR From SETGLBGCM
 Gosub GLOBVAR_SOA From SETGLBGCM_SOA             # use Gosub - too many global variables returned
 IGCM   = find(MODELE,SOA_GGCM(1..SOA_GGCMNBR))
Endif
If IGCM
 NBREF    = 1
 REFTYP(NBREF) = SOA_GLEDTYPGEN(IGCM)
 REFER(NBREF)  = SOA_GLEDGEN(IGCM)
 If SOA_GLEDTYPGEN(IGCM)<>SOA_GLEDTYPANA(IGCM)
  NBREF+=1
  REFTYP(NBREF) = SOA_GLEDTYPANA(IGCM)
  REFER(NBREF) = SOA_GLEDANA(IGCM)
 Endif
 For IREF=1 To NBREF
  NBPLAN += 1
  ILED = find(REFER(IREF),GLED(1..SOA_GLEDNBR))
  If !ILED
   #Call GLOBVAR From SETGLBLED
   Gosub GLOBVAR_SOA From SETGLBLED_SOA                  #use Gosub - too many global variables returned
   ILED = find(REFER(IREF),SOA_GLED(1..SOA_GLEDNBR))
  Endif
  If ILED
   PLAN(IREF) = SOA_GLEDCOA(ILED)
   Gosub AXES
  Endif
 Next IREF
 For IREF=1 To len(mess(0,2644,1))
  If !find(IREF,SOA_GLEDTYPGEN(IGCM),SOA_GLEDTYPANA(IGCM))
   REF = evalue("SOA_GLED"+num$(IREF)+"("+num$(IGCM)+")")
   If REF<>"" & !find(REF,REFER(1..NBREF))
    If [F:GCM]CFMAUT(IREF-1)<>2
     NBREF += 1
     REFER(NBREF) = REF
     ILED = find(REF,SOA_GLED(1..SOA_GLEDNBR))
     If !ILED
      #Call GLOBVAR From SETGLBLED
      Gosub GLOBVAR_SOA From SETGLBLED_SOA              #done-see above
      ILED = find(REF,SOA_GLED(1..SOA_GLEDNBR))
     Endif
     If ILED
      NBPLAN      += 1
      PLAN(NBPLAN) = SOA_GLEDCOA(ILED)
      Gosub AXES
     Endif
     REFTYP(NBPLAN) = IREF
    Endif
   Endif
  Endif
 Next IREF
Endif
Return
#---------------------------------------------------------------------
$AXES

If !INI_AXE : Return : Endif
If NBAXE>=SOA_GOPTCANA : Return : Endif
Local Integer VU
Local Integer SAIAXE
For IDIE=1 To SOA_GLEDDIENBR(ILED)
 CODAXE = evalue("SOA_GDIE"+num$(IDIE)+"("+num$(ILED)+")")
 VU = find(CODAXE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
 If VU<>0
  SAIAXE = [F:CPY]DACDIE(VU-1)
 Else
  SAIAXE = 2 : # Sait-on jamais...
 Endif
 If CODAXE<>"" & !find(CODAXE,AXE(1..NBAXE)) & NBAXE<dim(AXE) & (!SAI_AMONT | SAIAXE=2)
  NBAXE       += 1
  AXE(NBAXE)   = CODAXE
  VU = find(CODAXE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
  If VU<>0
   OBLIG(NBAXE) = [F:CPY]OBYDIE(VU-1)
  Else
   OBLIG(NBAXE) = 1 : # Sait-on jamais...
  Endif
  If NBAXE>=SOA_GOPTCANA : Break : Endif
 Endif
Next IDIE
Return
########################################################################
## Modèle comptable pour une société ou un site
########################################################################
Subprog SETGCM(SOCIETE,MODELE)
Value    Char    SOCIETE   : # Société ou site
Variable Char    MODELE    : # Modèle comptable
Local Integer ISOC, ISITE

# Sharvin to SOA globals
#Local Char SOA_GSOC       - done
#Local Integer SOA_GNBSOC  - done
#Local Char SOA_GSITE      - done
#Local Char SOA_GSOCSITE   - done
#Local Integer SOA_GGCMSOC - done

Local Char    SOA_GSOCIETE(5)                      : Call GSOCIETE(SOA_GSOCIETE) From ESSGLOB_SOA
Local Integer SOA_GDIMSOC                          : Call GDIMSOC(SOA_GDIMSOC) From ESSGLOB_SOA
Local Char    SOA_GSOC(GLONCPY)(1..SOA_GDIMSOC)    : Call GSOC(SOA_GSOC) From ESSGLOB_SOA
Local Char    SOA_GGCMSOC(GLONGCM)(1..SOA_GDIMSOC) : Call GGCMSOC(SOA_GGCMSOC) From ESSGLOB_SOA
Local Integer SOA_GNBSOC                           : Call GNBSOC(SOA_GNBSOC) From ESSGLOB_SOA
Local Integer SOA_GNBSITE                          : Call GNBSITE(SOA_GNBSITE) From ESSGLOB_SOA
Local Integer SOA_GDIMSIT                          : Call GDIMSIT(SOA_GDIMSIT) From ESSGLOB_SOA
Local Char    SOA_GSITE(GLONFCY)(1..SOA_GDIMSIT)   : Call GSITE(SOA_GSITE)  From ESSGLOB_SOA

ISOC   = find(SOCIETE,SOA_GSOC(1..SOA_GNBSOC))  #???? GNBSOC
If !ISOC
 ISITE = find(SOCIETE,SOA_GSITE(1..SOA_GNBSITE))
 If !ISITE : End : Endif
 ISOC = find(SOA_GSOCSITE(ISITE),SOA_GSOC(1..SOA_GNBSOC))
 If !ISOC : End : Endif
Endif
MODELE = SOA_GGCMSOC(ISOC)
End

########################################################################

