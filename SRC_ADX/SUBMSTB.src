#<AdxTL>@(#)4.0.0.0 $Revision$
#############################################################################################
#   Programmes utilitaires pour la gestion des secteurs de marchés
#
# INITFORMULE  : Initialisation table pour formule
# LOAD_MDF     : Chargement de la définitions des secteurs
# VERIF_MDF    : Vérification de la définitions des secteurs
# SAVE_MDF     : Sauvegarde de la définitions des secteurs
# REGROUPEMENT : Génération de la chaine de regroupement
# LOAD_REP     : Chargement du tableau des affectations de représentants.
# SAVE_REP     : Enregistrement du tableau des affectations de représentants.
# SAVECLOB     : Enregistrement des CLOBs
# DELCLOB      : Suppression des CLOBs
# LOADCLOB     : Chargement du CLOB
#############################################################################################
##########################################################################################################
#Initialisation table pour formule
$INITFORMULE
  [M:MST2]MSTFILTAB = 'pat(ABRFIC,"BPR")<>0 or pat(ABRFIC,"BPC")<>0 or pat(ABRFIC,"BPA")<>0'
Return

##########################################################################################################
# Chargement de la définitions des secteurs
$LOAD_MDF
Local Integer ILIGNE
Local Date DTDATE

  ILIGNE = 0
  Raz DTDATE
  [M:MST2]NBCRI = 0
  Filter [MDF] Where MARSCTNUM = [M:MST0]MARSCTNUM
  For [MDF]MDF1
    [M:MST2]CRINUM(ILIGNE) = [F:MDF]CRINUM 
    [M:MST2]MARSCTOPD(ILIGNE) = [F:MDF]MARSCTOPD
    [M:MST2]NBPARDEB(ILIGNE) = [F:MDF]NBPARDEB
    If [F:MDF]NBPARDEB <> 0 Then
      [M:MST2]PARDEB(ILIGNE) = string$ ([F:MDF]NBPARDEB,"(")
    Else
      [M:MST2]PARDEB(ILIGNE) = ""
    Endif
    [M:MST2]MDFABRFIC(ILIGNE) = [F:MDF]MDFABRFIC
    [M:MST2]MDFTAB(ILIGNE) = [F:MDF]MDFTAB
    [M:MST2]MARSCTFIE(ILIGNE) = [F:MDF]MARSCTFIE
    [M:MST2]MDFFIETYP(ILIGNE) = [F:MDF]MDFFIETYP
    [M:MST2]MDFINDOK(ILIGNE) = [F:MDF]MDFINDOK
    [M:MST2]MDFINDNUM(ILIGNE) = [F:MDF]MDFINDNUM
    [M:MST2]MARSCTCND(ILIGNE) = [F:MDF]MARSCTCND
    [M:MST2]MDFVAL(ILIGNE) = [F:MDF]MDFVAL
    [M:MST2]VALECR(ILIGNE) = [F:MDF]MDFVAL  # FGR 21/10/2009 : X3SUIVI58010
    #
    Read [ATZ]CODZONE=[M:MST2]MDFTAB(ILIGNE);[M:MST2]MARSCTFIE(ILIGNE)
    If fstat = 0 Then
      [M:MST2]VALCODTYP(ILIGNE) = [F:ATZ]CODTYP
      [M:MST2]VALLONG(ILIGNE) = [F:ATZ]LONG
      [M:MST2]VALNOLIB(ILIGNE) = [F:ATZ]NOLIB
      [M:MST2]VALTCT(ILIGNE) = ""
      [M:MST2]VALSUPP(ILIGNE) = ""
      [M:MST2]VALOPTION(ILIGNE) = ""
    Endif
    If [M:MST2]MDFVAL(ILIGNE) <> "" Then
      # FGR 21/10/2009 : X3SUIVI58010
      Call CHARGE([M:MST2]VALECR(ILIGNE),[M:MST2]VALCODTYP(ILIGNE),[M:MST2]VALNOLIB(ILIGNE),0,[M:MST2]MDFVAL(ILIGNE)) From ASELOBJ
      #Case [M:MST2]MDFFIETYP(ILIGNE)
      #  When 2
      #    [M:MST2]VALECR(ILIGNE) = num$(evalue([M:MST2]MDFVAL(ILIGNE)))
      #  When 3 
      #    Call CONVID([M:MST2]MDFVAL(ILIGNE), DTDATE) From CRMUTIL150
      #    [M:MST2]VALECR(ILIGNE) = format$(GFMDAT4, DTDATE)
      #  When Default    
      #    [M:MST2]VALECR(ILIGNE) = [M:MST2]MDFVAL(ILIGNE)
      #Endcase
    Endif
    [M:MST2]NBPARFIN(ILIGNE) = [F:MDF]NBPARFIN
    If [F:MDF]NBPARFIN <> 0 Then
      [M:MST2]PARFIN(ILIGNE) = string$([F:MDF]NBPARFIN,")")
    Else
      [M:MST2]PARFIN(ILIGNE) = ""
    Endif
    ILIGNE += 1
  Next
  Filter [MDF]
  [M:MST2]NBCRI = ILIGNE
Return

##########################################################################################################
# vérification de la définitions des secteurs
$VERIF_MDF
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Integer INBPARENTHESE
Local Char SZRESULT
Local Integer INBLIGNE
Local Integer ILIGNE
Local Integer INOLIGNSAVE
Local Integer IBERROR
Local Integer INBPARDEB
Local Integer INBPARFIN

  Raz SZMESSAGE
  IBRETOUR = 1
  INBPARENTHESE = 0
  Raz SZRESULT
  INBLIGNE = 0
  ILIGNE = 0
  INOLIGNSAVE = nolign
  IBERROR = 0
  INBPARDEB = 0
  INBPARFIN = 0
  If [M:MST0]MSTCRI = 1 or [M:MST0]MSTCRI = 3 Then
    While ILIGNE < [M:MST2]NBCRI
      INBLIGNE = INBLIGNE + 1
      [M:MST2]CRINUM(ILIGNE) = ILIGNE
      If ILIGNE = 0 Then
        [M:MST2]MARSCTOPD(ILIGNE) = 1
      Endif
      If ILIGNE <> 0 Then
        If [M:MST2]MARSCTOPD(ILIGNE) <> 2 and [M:MST2]MARSCTOPD(ILIGNE) <> 3 Then
          IBERROR = 1
          #L'opérateur est obligatoire.
          GMESSAGE = mess(530,177,1)
          Break
        Endif
      Endif
      Call GETNBPARENTHESE ([M:MST2]PARDEB(ILIGNE), 0, INBPARENTHESE, SZRESULT, SZMESSAGE, IBRETOUR) From CRMUTIL150
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        IBERROR = 1
        Break
      Endif
      [M:MST2]PARDEB(ILIGNE) = SZRESULT
      [M:MST2]NBPARDEB(ILIGNE) = INBPARENTHESE
      INBPARDEB = INBPARDEB + [M:MST2]NBPARDEB(ILIGNE)           
      If [M:MST2]MDFTAB(ILIGNE) = "" Then
        IBERROR = 1
        #La table est obligatoire.
        GMESSAGE = mess(531,177,1)
        Break
      Endif
      If [M:MST2]MDFTAB(ILIGNE) <> "" Then
        Read [ATB]CODFIC=[M:MST2]MDFTAB(ILIGNE)
        If fstat = 0 Then
          [M:MST2]MDFABRFIC(ILIGNE)=[F:ATB]ABRFIC
        Else
          IBERROR = 1
          #Erreur lecture table des tables
          GMESSAGE = mess(558,177,1)
          Break
        Endif    
      Endif
      If [M:MST2]MARSCTFIE(ILIGNE) = "" Then
        IBERROR = 1
        #Le champ est obligatoire.
        GMESSAGE = mess(532,177,1)
        Break
      Endif
      If [M:MST2]MARSCTFIE(ILIGNE) <> "" and [M:MST2]MDFTAB(ILIGNE) <> "" Then
        Read [ATZ]CODZONE=[M:MST2]MDFTAB(ILIGNE);[M:MST2]MARSCTFIE(ILIGNE)
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur le champs ne correspond pas à la table
          GMESSAGE = mess(567,177,1)
          Break
        Endif
      Endif
      If [M:MST2]MARSCTCND(ILIGNE) = 0 Then
        IBERROR = 1
        #La condition est obligatoire.
        GMESSAGE = mess(533,177,1)
        Break
      Endif
      Call GETNBPARENTHESE ([M:MST2]PARFIN(ILIGNE), 1, INBPARENTHESE, SZRESULT, SZMESSAGE, IBRETOUR) From CRMUTIL150
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        IBERROR = 1
        Break
      Endif
      [M:MST2]PARFIN(ILIGNE) = SZRESULT
      [M:MST2]NBPARFIN(ILIGNE) = INBPARENTHESE
      INBPARFIN = INBPARFIN + [M:MST2]NBPARFIN(ILIGNE)
      If INBPARFIN > INBPARDEB Then
        #Erreur dans la répartition des parenthèses ouvrantes et fermantes.
        GMESSAGE = mess(543,177,1)
        IBERROR = 1
        Break
      Endif
      ILIGNE += 1
    WEND
    If IBERROR = 0 Then
      If INBPARDEB <> INBPARFIN Then
        #Il n'y a pas le même nombre de parenthèses ouvrantes et fermantes.
        GMESSAGE = mess(534,177,1)
        IBERROR = 1
      Endif
    Endif
  Endif
  If IBERROR = 0 Then
    If [M:MST0]MSTCRI = 3 Then
      # FGR 13/01/2010 : X3SUIVI60986
      #If [M:MST0]MSTFOROPD = 0 or [M:MST0]MSTFOROPD = 1 Then
      If [M:MST2]MSTFOROPD = 0 or [M:MST2]MSTFOROPD = 1 Then
        #Vous devez préciser un opérateur de liaison entre les critères et la formule.
        GMESSAGE = mess(560,177,1)
        IBERROR = 1
      Endif   
      If IBERROR = 0 Then
        If [M:MST2]MSTFOR = "" Then
          #Vous ne pouvez pas lier les critères avec une formule vide.
          GMESSAGE = mess(562,177,1)
          IBERROR = 1
        Endif
      Endif
    Endif
  Endif
  If IBERROR = 1 Then
    GERR = 2
    OK = 0
    GOK = 0
  Endif    
Return

##########################################################################################################
# Sauvegarde de la définitions des secteurs
$SAVE_MDF
Local Integer ILIGNE
Local Integer INOLIGNSAVE
Local Integer IBERROR

  ILIGNE = 0
  INOLIGNSAVE = nolign
  IBERROR = 0
  Delete  [MDF] Where MARSCTNUM=[M:MST0]MARSCTNUM
  If fstat <> 0 Then
    #Erreur lors de la suppression des critères
    GMESSAGE = mess(538,177,1)
    GOK = 0
    Return
  Endif
  While ILIGNE < [M:MST2]NBCRI
    [F:MDF]MARSCTNUM  = [M:MST0]MARSCTNUM
    [F:MDF]CRINUM     = [M:MST2]CRINUM(ILIGNE)
    [F:MDF]MARSCTOPD  = [M:MST2]MARSCTOPD(ILIGNE)
    [F:MDF]NBPARDEB   = [M:MST2]NBPARDEB(ILIGNE)
    [F:MDF]MDFABRFIC  = [M:MST2]MDFABRFIC(ILIGNE)
    [F:MDF]MDFTAB     = [M:MST2]MDFTAB(ILIGNE)
    [F:MDF]MARSCTFIE  = [M:MST2]MARSCTFIE(ILIGNE)
    [F:MDF]MDFFIETYP  = [M:MST2]MDFFIETYP(ILIGNE)
    [F:MDF]MDFINDOK   = [M:MST2]MDFINDOK(ILIGNE)
    [F:MDF]MDFINDNUM  = [M:MST2]MDFINDNUM(ILIGNE)
    [F:MDF]MARSCTCND  = [M:MST2]MARSCTCND(ILIGNE)
    [F:MDF]MDFVAL     = [M:MST2]MDFVAL(ILIGNE)
    [F:MDF]NBPARFIN   = [M:MST2]NBPARFIN(ILIGNE)
    [F:MDF]CREUSR     = GUSER    
    [F:MDF]CREDAT     = date$    
    Write [MDF]
    If fstat <> 0 Then
      #Erreur lors de l'écriture d'un critère. 
      GMESSAGE = mess(539,177,1)
      GOK = 0
      IBERROR = 1
      Break
    Endif
    ILIGNE += 1
  Wend
Return

##########################################################################################################
# Génération de la chaine de regroupement
$REGROUPEMENT
Local Integer ILIGNESAVE
Local Char SZREGROUPE (250)
Local Char SZREGROUPETRAD (250)
Local Integer ILIGNE
Local Char SZOPER
Local Char SZOPERTRAD
Local Char SZFORMULE
Local Char SZFORMULETRAD
Local Char SZNUMCRI
Local Integer INBLIGNEMAX

  ILIGNESAVE = nolign
  Raz SZREGROUPE
  Raz SZREGROUPETRAD
  Raz SZOPER
  Raz SZOPERTRAD
  Raz SZFORMULE
  Raz SZFORMULETRAD
  Raz SZNUMCRI
  ILIGNE = 0
  INBLIGNEMAX = max(ILIGNESAVE-1, [M:MST2]NBCRI)
  While ILIGNE < dim([M:MST2]MARSCTOPD(ILIGNE))
    If [M:MST2]MARSCTOPD(ILIGNE) > 0 Then
      If [M:MST2]MARSCTOPD(ILIGNE) = 1 Then
        SZOPER = ""
        SZOPERTRAD = ""
      Else
        SZOPERTRAD = " " + mess([M:MST2]MARSCTOPD(ILIGNE), 2959,1) + " "
        Case [M:MST2]MARSCTOPD(ILIGNE)
          When 2
            SZOPER = " and "   # FGR 09/04/2010 : X3SUIVI63982 et pas " or "
          When 3
            SZOPER = " or "    # FGR 09/04/2010 : X3SUIVI63982 et pas " and "          
        Endcase
      Endif
      SZNUMCRI = num$(ILIGNE+1)
      SZREGROUPE = SZREGROUPE + SZOPER + [M:MST2]PARDEB(ILIGNE) + SZNUMCRI +[ M:MST2]PARFIN(ILIGNE)
      SZREGROUPETRAD = SZREGROUPETRAD + SZOPERTRAD + [M:MST2]PARDEB(ILIGNE) + SZNUMCRI + [M:MST2]PARFIN(ILIGNE)
    Endif
    ILIGNE += 1
  Wend
  nolign = ILIGNESAVE
  SZFORMULE = "(FORMU)"
  SZFORMULETRAD = "(" + mess(561,177,1) + ")"
  If [M:MST0]MSTCRI = 1 Then
    #Critère uniquement
    [M:MST2]GRUDEF = SZREGROUPE 
    [M:MST2]MSTSYN = SZREGROUPETRAD
  Endif
  If [M:MST0]MSTCRI = 2 Then
    #Formule
    If [M:MST2]MSTFOR <> "" Then
      [M:MST2]GRUDEF = SZFORMULE
      [M:MST2]MSTSYN = SZFORMULETRAD
    Else
      [M:MST2]GRUDEF = ""
      [M:MST2]MSTSYN = ""
    Endif
  Elsif [M:MST0]MSTCRI = 3 Then
    Case [M:MST2]MSTFOROPD
      When 2
        SZOPER = " and "   # FGR 09/04/2010 : X3SUIVI63982 et pas " or "
      When 3
        SZOPER = " or "    # FGR 09/04/2010 : X3SUIVI63982 et pas " and "
      When Default 
        SZOPER = " "
    Endcase
    If [M:MST2]MSTFOR <> "" Then
      [M:MST2]GRUDEF = SZREGROUPE + SZOPER + SZFORMULE
      [M:MST2]MSTSYN = SZREGROUPETRAD - mess([M:MST2]MSTFOROPD,2955,1) - SZFORMULETRAD
    Else
      [M:MST2]GRUDEF = SZREGROUPE
      [M:MST2]MSTSYN = SZREGROUPETRAD
    Endif
  Endif
Return
    
##########################################################################################################
# Chargement du tableau des affectations de représentants.
###########################################################
$LOAD_REP
Local Integer INBLIG
Local Integer IADINUM

  IADINUM = 19 + GFAMCIA
  INBLIG = 0
  Raz [M:MST3]NBREP
  Raz [M:MST3]SCTREPSEC
  Raz [M:MST3]SCTREPMSS
  Raz [M:MST3]SCTREPITM
  Raz [M:MST3]SCTITMCLA
  #Filter [MRS] Where [F:MRS]MARSCTNUM = [M:MST0]MARSCTNUM Order By [F:MRS]SCTREPSEC Asc
  Filter [MRS] Where [F:MRS]MARSCTNUM = [M:MST0]MARSCTNUM
  For [MRS]MRS1
    If INBLIG >= dim([M:MST3]SCTREPSEC)-1 Then
      Break
    Endif
    [M:MST3]SCTREPSEC(INBLIG) = [F:MRS]SCTREPSEC
    [M:MST3]SCTREPMSS(INBLIG) = [F:MRS]SCTREPMSS
    [M:MST3]SCTREPITM(INBLIG) = [F:MRS]SCTREPITM
    #Affiche le libellé en clair de la famille de produit.
    If [M:MST3]SCTREPITM(INBLIG) = "" Then
      [M:MST3]SCTITMCLA(INBLIG) = ""
    Else
      Call GET_LIB(IADINUM, [M:MST3]SCTREPITM(INBLIG), [M:MST3]SCTITMCLA(INBLIG)) From CRM_UTIL
    Endif
    INBLIG += 1
  Next
  [M:MST3]NBREP = INBLIG 
  Filter [MRS]
Return

##########################################################################################################
# Enregistrement du tableau des affectations de représentants.
###########################################################
$SAVE_REP
Local Integer ILIGNE

  ILIGNE = 0
  Delete [MRS] Where [F:MRS]MARSCTNUM = [M:MST0]MARSCTNUM
  If fstat <> 0 Then
    #Erreur lors de la mise à jour des affectations des représentants (suppression).
    GMESSAGE = mess(563,177,1)
    GERR = 1
    GOK = 0
    Return
  Endif
  While ILIGNE < [M:MST3]NBREP
    [F:MRS]MARSCTNUM = [M:MST0]MARSCTNUM
    [F:MRS]SCTREPSEC = [M:MST3]SCTREPSEC(ILIGNE)
    [F:MRS]SCTREPMSS = [M:MST3]SCTREPMSS(ILIGNE)
    [F:MRS]SCTREPITM = [M:MST3]SCTREPITM(ILIGNE)
    Write [MRS]
    If fstat Then
      #Erreur lors de la mise à jour des affectations des représentants (création)
      GMESSAGE = mess(564,177,1)
      GERR = 1
      GOK = 0
      Break
    Endif
    ILIGNE += 1
  Wend
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  If [M:MST1]FULDES <> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:MST1]NUMFULDES
    [F:HD6]TYP = [M:MST1]TYPFULDES
    [F:HD6]CLOB = [M:MST1]FULDES
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement de la description du secteur de marché. Transaction abandonnée.
      GMESSAGE = mess(893,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD6] Where [F:HD6]NUM = [M:MST1]NUMFULDES and [F:HD6]TYP = [M:MST1]TYPFULDES
  If fstat Then
    #Erreur lors de la suppression de la description du secteur de marché. Transaction abandonnée.
    GMESSAGE = mess(894,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:MST1]NUMFULDES = "" Then
    Raz [M:MST1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If [M:MST1]TYPFULDES = "" Then
    Raz [M:MST1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6]HD60=[M:MST1]NUMFULDES;[M:MST1]TYPFULDES
    If fstat Then
      Raz [M:MST1]FULDES
    Else
      [M:MST1]FULDES = [F:HD6]CLOB
    Endif
  Endif
Return
