#<AdxTL>@(#)1.0.0.0 $Revision$
#------------------------------------------------------------#
# Request edit management (PUT)
#------------------------------------------------------------#
$PUT

#----------------------------#
# Define data Instance
#----------------------------#
Local Instance REP Using C_AREPENT        : # Representation containing metadatas

#--------------------------------------------------#
# Load json presentation (metadata & data)
#--------------------------------------------------#

PRGREP = func SUBASW.PREFIX_TRT+REPRESENTATION : # WMREP

REPNAM = "REP"
GRPINS = REPNAM
ERRNUM = 0
Onerrgo ERR_LOAD_DESCRIPTION From ASYRERR
Call DESCRIPTION_REPRESENTATION(REP,"REP") From =PRGREP
Onerrgo
If ERRNUM
 Goto ERR_DETAIL
Endif

PRGEXE = func SUBACLA.PREFIX_EXE+REP.CLA : # WML

# Track Id
If func ASYRMAIN.PARVAL(ARCV,"trackingId")<>""
 Assign "PSYR.WRKUID" With toUuid(func ASYRMAIN.PARVAL(ARCV,"trackingId"))
Else
 PSYR.WRKUID = NullUuid
Endif

# Create instance class

Local Instance WCLA Using ="C_"+REP.CLA
WCLA = evalue ("NEWINSTANCE ["+REPNAM+"] , C_"+REP.CLA+'(GACTX,UIDINS,NUMLIN,INSFAT,Null,"'+REP.ICL+'",0)')

# Create instance representation
Local Instance WREP Using ="R_"+REP.REP
If maxtab(WCLA)=1
 WREP = evalue ("Newinstance ["+REPNAM+"] , R_"+REP.REP+'(WCLA,GACTX,UIDINS,NUMLIN,INSFAT,0)')
 #load representation's parameters
 Call SET_REP_PARAMETERS(WREP,ARCV) From ASYRMAIN
Else
 For I=1 To maxtab(WCLA)
  WREP(I) = evalue ("Newinstance ["+REPNAM+"] , R_"+REP.REP+'(WCLA("+num$(I)+"),GACTX,UIDINS,NUMLIN,INSFAT,0)')
  #load representation's parameters
  Call SET_REP_PARAMETERS(WREP(I),ARCV) From ASYRMAIN
 Next I
Endif

# Load data (Read from CRUD)

Raz ASTATUS
Call TRACE("_AREADSUP before: KEYS="+KEYS) From ASYRCOM
Call _AREADSUP(WCLA,KEYS,ASTATUS) From =PRGEXE
Call TRACE("_AREADSUP after: ASTATUS="+num$(ASTATUS)) From ASYRCOM
If ASTATUS>0
 ASTATUS = fmet WCLA._AERROR(GACTX,2)
 ERRNUM = 9999
 Goto ERR_DETAIL
Endif


# Init representation

[L]ASTATUS = fmet WREP.ACTION("LOAD")

WREP.accessorEnabled = 0

Local Integer I
For I=1 To maxtab(REP.PRO)
 If REP.PRO(I).PRO = PROPERTY
  Break
 Endif
Next I

WREP.accessorEnabled = 1

#------------------------------------------#
# Prepare response (OK)
#------------------------------------------#
ASND.STAT     = 200
ASND.URL      = ""
ASND.CONTTYPE = ""
ASND.DATA     = ""
Return

#------------------------------------------#
# Error response
#------------------------------------------#
$ERR_DETAIL
Return
