#<AdxTL>@(#)2.0.0.0 $Revision$
Call UTIMAJ90338
End

#----------------------------------------------------------------------------------------#
#
# MAJ des messages cf 90338
#
#----------------------------------------------------------------------------------------#

# execute this treatement in all the folders
Subprog UTIMAJ90338
Call OUVRE_TRACE("Update messages") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File APLSTD [AST]
 Local File AMENLOC [AML]
Else
 Local File =DOSSIER+".APLSTD" [AST]
 Local File =DOSSIER+".AMENLOC" [AML]
Endif


#Gosub MAJ1

Gosub MAJ2

Close Local File [AST],[AML]
End

#----------------------------------------------#
$MAJ2
Trbegin [AML],[AST]

Delete [AST] Where LANCHP=30000
Delete [AML] Where MENLOC=30000
Delete [AST] Where LANCHP=200 & LANNUM=30000-200

Delete [AST] Where LANCHP=22222
Delete [AML] Where MENLOC=22222
Delete [AST] Where LANCHP=200 & LANNUM=22222-200

Commit
Return

#----------------------------------------------#
$MAJ1
Trbegin [AML],[AST]
Delete [AST] Where LANCHP=152 & LANNUM>10

Delete [AST] Where LANCHP=153 & LANNUM>22 & LANNUM<50
Delete [AST] Where LANCHP=153 & LANNUM>52 & LANNUM<501

Delete [AST] Where LANCHP=942 & LANNUM>3
Delete [AST] Where LANCHP=2903 & LANNUM>3

Delete [AST] Where LANCHP=7829 & LAN<>"FRA"
Delete [AST] Where LANCHP=200 & LANNUM=7829-200 & LAN<>"FRA"

Delete [AST] Where LANCHP=7833 & LANNUM>2

Delete [AST] Where LANCHP=7958 & LAN<>"FRA"
Delete [AST] Where LANCHP=200 & LANNUM=7958-200 & LAN<>"FRA"

Delete [AST] Where LANCHP=1989
Delete [AML] Where MENLOC=1989
Delete [AST] Where LANCHP=200 & LANNUM=1989-200

Delete [AST] Where LANCHP>=64 & LANCHP<=73
Delete [AML] Where MENLOC>=64 & MENLOC<=73
Delete [AST] Where LANCHP=0 & (LANNUM>=64 & LANNUM<=73)

Delete [AST] Where LANCHP=2904
Delete [AML] Where MENLOC=2904
Delete [AST] Where LANCHP=200 & LANNUM=2904-200

Delete [AST] Where LANCHP=7842
Delete [AML] Where MENLOC=7842
Delete [AST] Where LANCHP=200 & LANNUM=7842-200

Delete [AST] Where LANCHP=7962
Delete [AML] Where MENLOC=7962
Delete [AST] Where LANCHP=200 & LANNUM=7962-200

Delete [AST] Where LANCHP=901
Delete [AML] Where MENLOC=901
Delete [AST] Where LANCHP=200 & LANNUM=901-200

Delete [AST] Where LANCHP=100 & LANNUM=237 & LAN<>"FRA"

If GPRODUIT<>-1
Delete [AST] Where LANCHP=63
Delete [AML] Where MENLOC=63
Delete [AST] Where LANCHP=0 & (LANNUM=63)
Endif

Commit
Return

