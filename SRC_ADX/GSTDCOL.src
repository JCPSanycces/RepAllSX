#<AdxTL>@(#)0.0.0.0 $Revision$ Maintenance en colonne
Call GSTDCOL
End

Subprog GSTDCOL()
Local Char PARAM(30)(1..3)
Local Char VALEUR
Call TRAITE_CHAR(VALEUR,PARAM,"STDCOL","GSTDCOL","STDCOLCRIT",4,"") From GTRAITE
End

#-----------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"            : Gosub INIT
 When "AVANT_PAR"       : Gosub AVANT_PAR
 When "CONTROLE"        : Gosub CONTROLE
 When "EXEC"            : Gosub EXEC
 When Default
  Case BOITE
   When "STDCOLCRIT"    : # Gsaisie des critères
    Case ACTION
     When "DEBUT"       : Gosub DEBUT_CRIT
    Endcase
   When Default
    If dim([M:DIA]TRANSAC)>0 & BOITE=[M:DIA]TRANSAC  : # Gsaisie de la maintenance
     Case ACTION
      When "OUVRE"       : Gosub OUVRE
      When "DEBUT"       : Gosub DEBUT
      When "AP_CHOIX"    : Gosub AP_CHOIX
      When "APRES_MODIF" : Gosub APRES_MODIF
      When "FIR"         : Gosub PREMIER
      When "LAS"         : Gosub DERNIER
      When "SUI"         : Gosub SUIVANT
      When "PRE"         : Gosub PRECEDENT
      When "ENR"         : Gosub ENREGISTRER
      When "ABA"         : Gosub ABANDON
      When "FIN"         : Gosub FIN
      When "BOUTON"      : Gosub BOUTON
      When "SEL"         : Gosub SELECTION
      When "SETBOUT"     : Gosub SETBOUT
      When "TITRE"       : Gosub TIT
     Endcase
    Endif
  Endcase
Endcase
Return

#-----------------------------------------------------------------------------------#
# GTRAITE
#-----------------------------------------------------------------------------------#

$INIT
Local Char MOTIF(GLONADI)
#F_add_admca_managment
#If GPROFIL<>GSUPER                       # Issue 109484 - 121082-revert
If GPROFIL<>GSUPER  & GPROFIL<>"ADMCA"    # End issue 109484 -121082 - revert
 Call ERREUR(mess(145,124,1)) From GESECRAN  : # Fonction réservée à l'administrateur
 FIN = 1 : Return
Elsif GHISTO<>0
 Call ERREUR(mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
 FIN = 1 : Return
Endif
If func AFNC.PARAMUTIL("ASIGMNT","","")="2"
 Local Char VALSIG(10) , PARSIG(30)(1..2)
 PARSIG(1) = nomap
 PARSIG(2) = ""
 mkstat = 0
 If GFUSION>0
  Call SAISIE_CHAR(VALSIG,PARSIG,"APASSMNTSYRA","APASSMNTSYRA","") From GSAISIE
 Else
  Call SAISIE_CHAR(VALSIG,PARSIG,"APASSWDMNT","APASSWDMNT","") From GSAISIE
 Endif
 MOTIF = PARSIG(2)
 If mkstat : FIN = 1 : Return : Endif
Endif
GMODIF = 0
Return

#---------------------------#
$AVANT_PAR
If clalev([DIA])=0 : Local Mask STDCOLCRIT [DIA] : Endif
[M:DIA]MOTIF = MOTIF
Return

#---------------------------#
$CONTROLE
If find(GSTATUT,GSTAEND,GSTAFIN,GSTAESC)
 FIN = 1 : Return
Endif
Local Char    SYMBOLE(80)
Local Integer VERROU
If [M]CODFIC<>"AESPION" & !GHISTO & [M]UNIQUE
 Gosub VERROU
 If !VERROU
  For I=[M]NBCLE+1 To [M]NBRLIG
   If [M]SAIAFF(I-1)=1
    [M]SAIAFF(I-1) = 2
   Endif
  Next I
 Endif
Endif
Call GENTRANS(OK)
If !OK
 Gosub DEVERROU
 SAI = 1 : Return
Endif
BOITE = [M]TRANSAC
PARAM(1) = SYMBOLE
PARAM(2) = num$(VERROU)
PARAM(3) = [M:DIA]MOTIF
Return

#---------------------------#
$EXEC
Gosub DEVERROU
If GSTATUT=GSTABOU2+1 : SAI = 1 : Endif
MOTIF = [M:DIA]MOTIF
GMODIF = 0
Return

#---------------------------#
$VERROU
SYMBOLE = "GSTDCOL/"+[M]CODFIC
Lock =SYMBOLE From =[M]DOSSIER : # Pour interdire la maintenance en colonne en modif sur la même table
If fstat=1
 VERROU = 0
Else
 VERROU = 1
Endif
Return

#---------------------------#
$DEVERROU
If VERROU
 Unlock =SYMBOLE From =[M]DOSSIER
 VERROU = 0
Endif
Return

#-----------------------------------------------------------------------------------#
# GSAISIE STDCOLCRIT
#-----------------------------------------------------------------------------------#

$DEBUT_CRIT
If [M]CODFIC<>""
 Affzo [M:DIA]
 If [M]CODFIC="AESPION" or GHISTO or ![M]UNIQUE
  Grizo 20
 Else
  Gosub GRISE_CLE
 Endif
Endif
Return

#---------------------------#
$GRISE_CLE
For I=0 To [M]NBCLE-1 : #On grise les clés
 Grizo [M]CHAMPDSP(I), INTITLONG(I), SAIAFF(I)
Next I
Return

#-----------------------------------------------------------------------------------#
# GSAISIE STDCOL
#-----------------------------------------------------------------------------------#

$OUVRE
If [M:DIA]CODFIC<>"AESPION"
 If [M:DIA]DOSSIER=nomap
  Local File AESPION   [AES]
 Else
  Local File =[M:DIA]DOSSIER+".AESPION"   [AES]
 Endif
Endif
If [M:DIA]DOSSIER=nomap
 If clalev([PPP_])=0 : Local File =[M:DIA]CODFIC [PPP_] : Endif
 If clalev([DDD_])=0 : Local File =[M:DIA]CODFIC [DDD_] : Endif
 If clalev([AAA_])=0 : Local File =[M:DIA]CODFIC [AAA_] : Endif
Else
 If clalev([PPP_])=0 : Local File =[M:DIA]DOSSIER+"."+[M:DIA]CODFIC [PPP_] : Endif
 If clalev([DDD_])=0 : Local File =[M:DIA]DOSSIER+"."+[M:DIA]CODFIC [DDD_] : Endif
 If clalev([AAA_])=0 : Local File =[M:DIA]DOSSIER+"."+[M:DIA]CODFIC [AAA_] : Endif
Endif
Local Mask =[M:DIA]TRANSAC [STD]
Return

#---------------------------#
$TIT
TIT = mess(181,123,1)-[M:DIA]CODFIC : # Maintenance de la table
If instr(1,[M:DIA]DOSSIER,"@")
 TIT -= "("+[M:DIA]DOSSIER+")"
Elsif adxmac(0)<>""
 TIT -= "("+adxmac(0)+"@"+[M:DIA]DOSSIER+")"
Else
 TIT -= "("+[M:DIA]DOSSIER+")"
Endif
Return

#---------------------------#
$DEBUT
Local Char    CHAINE(255), CRITERE(GDIMFIC)
Local Char    FILSUITE(250)(1..8)
Local Char    VAL1(250), VAL2(250)
Local Integer PREC, SUIV, PREM, DER, ENR, DEB, NBLIGT, IFILSUITE
Local Char    SAVIRS(5) , SAVIFS(5)
Local Integer M , SAVIUM
Local Integer NBCLE
Local Char    CLELIS(20)(1..16) , MOTIF(GLONADI)
Local Char    CLEPRIM(GLONAVA), CLESEC(GLONAVA)(0..16), CLEESP(GLONID)

SYMBOLE = PARAM(1)
VERROU  = val(PARAM(2))
NBLIGT  = [M:DIA]NBLIGT
NBCLE   = [M:DIA]NBCLE
For I=1 To NBCLE
 CLELIS(I) = [M:DIA]CLE(I-1)
Next I
Call SETCLE([M:DIA]DOSSIER,[M:DIA]CODFIC,CLELIS,NBCLE,CLEPRIM,CLESEC) From GSTD0

For I=1 To [M:DIA]NBCOL
 CHAINE = "[M:STD]"+[M:DIA]COLONNE(I-1)
 Grizo =CHAINE
Next I

If clalev([M:CRIT])= 0 : Local Mask CRITSEL [CRIT] : Endif
CRITERE = [M:DIA]FORCND
Gosub PREMIER
DEB = 1
Return

#---------------------------#
$AP_CHOIX
If REPONSE=GSTACLK+3
 Call QUILOCKDOS([M:DIA]DOSSIER,SYMBOLE,MACLCK,USRLCK) From OBJDIV
 If USRLCK<>""
  # Maintenance de la table x\Opération en cours sur un autre poste
  Call MESSAGE(mess(181,123,1)-[M:DIA]CODFIC+"\"+mess(30,100,1)+"\"+USRLCK+"\"+MACLCK) From GESECRAN
 Else
  Call MESSAGE(mess(181,123,1)-[M:DIA]CODFIC+"\"+mess(30,100,1)) From GESECRAN
 Endif
 REPONSE = 0
Endif
Return

#---------------------------#
$APRES_MODIF
#CHECK UNUSED_END
[M:STD]FLMODIF(nolign-1) = 1
#CHECK UNUSED_BEGIN
REP = "M"
Return

#---------------------------#
$ABANDON
Case REP
 When ""  : Gosub PREMIER
 When "M" : Gosub PREMIER : REP = ""
Endcase
Return

#---------------------------#
$BOUTON
Case BOUT
 When "T" :
  If func AFNC.PARAMUTIL("ASIGMNT","","")="2"
   Local Char VALSIG(10) , PARSIG(30)(1..2)
   PARSIG(1) = [M:DIA]DOSSIER
   PARSIG(2) = [M:DIA]MOTIF
   If GFUSION>0
    Call SAISIE_CHAR(VALSIG,PARSIG,"APASSMNTSYRA","APASSMNTSYRA","") From GSAISIE
   Else
    Call SAISIE_CHAR(VALSIG,PARSIG,"APASSWDMNT","APASSWDMNT","") From GSAISIE
   Endif
   If mkstat : Return : Endif
   [M:DIA]MOTIF = PARSIG(2)
  Endif
  FIN = 1
Endcase
Return

#---------------------------#
$SETBOUT
If (REP<>"") : Call VIREBOUT(CHMEN,"T") From GOBJET : Endif
If (DEB=2) : Call VIREBOUT(CHBOU,"0<>9") From GOBJET : Endif
If (PREM=1 or PREC=2) : Call VIREBOUT(CHBOU,"0<") From GOBJET : PREM = 0 : Endif
If (DER=1  or SUIV=2) : Call VIREBOUT(CHBOU,"9>") From GOBJET : DER  = 0 : Endif
If !VERROU
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
PREC = 0
SUIV = 0
DEB  = 0
Return

#---------------------------#
$FIN
Close Local File [PPP_] , [DDD_] , [AAA_]
If [M:DIA]CODFIC<>"AESPION"
 Close Local File [AES]
Endif
Close Local Mask [STD]
Call TEMPON(mess(54,125,1)-[M:DIA]TRANSAC) From GESECRAN : # Suppression écran
Call TR_DELMSK([M:DIA]TRANSAC,nomap) From MSKDIV
Call TEMPON(mess(98,125,1)-[M:DIA]TRANSAC) From GESECRAN : # Suppression fenêtre
Call TR_DELWIN([M:DIA]TRANSAC,nomap) From MSKDIV
Call TEMPOFF From GESECRAN
BOX = 0
Return

#---------------------------#
$PREMIER
REP = ""
If CRITERE <> ""
 Filter [AAA_] Where evalue(CRITERE)
Else
 Filter [AAA_]
Endif
Read [AAA_] First
If !fstat
 Gosub CHARGE_TAB
 PREM = 1
Endif
Filter [AAA_]
Return

#---------------------------#
$DERNIER
If CRITERE<>""
 Filter [AAA_] Where evalue(CRITERE)
Else
 Filter [AAA_]
Endif
REP = ""
Read [AAA_] Last
If !fstat
 For I=1 To NBLIGT
  Read [AAA_] Prev
  If fstat
   Break
  Endif
 Next I
Endif
Read [AAA_] Next
If !fstat
 Gosub CHARGE_TAB
 DER = 1
Endif
Filter [AAA_]
Return

#---------------------------#
$SUIVANT
REP = ""
SUIV = 1
[AAA_] = [DDD_]
Call FILTRE(CLELIS,NBCLE,">",NBLIGT,CRITERE,IFILSUITE,FILSUITE)
If CRITERE<>""
 Filter [AAA_] Where evalue(FILSUITE) & evalue(CRITERE)
Else
 Filter [AAA_] Where evalue(FILSUITE)
Endif
Read [AAA_] First
If !fstat
 Gosub CHARGE_TAB
Else
 SUIV += 1
Endif
Filter [AAA_]
Return

#---------------------------#
$PRECEDENT
REP = ""
PREC = 1
[AAA_] = [PPP_]
Call FILTRE(CLELIS,NBCLE,"<",NBLIGT,CRITERE,IFILSUITE,FILSUITE)
If CRITERE<>""
 Filter [AAA_] Where evalue(FILSUITE) & evalue(CRITERE)
Else
 Filter [AAA_] Where evalue(FILSUITE)
Endif
Read [AAA_] First
If !fstat
 Gosub CHARGE_TAB
Endif
Filter [AAA_]
Return

#---------------------------#
$CHARGE_TAB
Raz [M:STD]
[PPP_] = [AAA_]
For W=0 To NBLIGT-1
 If W>0 : Read [AAA_] Next : Endif
 If !fstat
  # On alimente toutes les colonnes
  For I=0 To [M:DIA]NBRLIG-1
   If  [M:DIA]SAIAFF(I)<3
# Issue 85821 - 2012-11-12 by VPO : maintenance en col sur UUID et DATETIME
#     When 1,2,3,4,5,6 :
    Case [M:DIA]TYPTYP(I)
     When 1,2,3,4,5,6,11,12 :
      Assign("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(W)+")")
&     With num$(evalue("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")"))
     When Default
      Assign("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(W)+")")
&     With evalue("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")")
    Endcase
   Endif
  Next I
 Else
  If DEB  : DEB  += 1 : Endif
  If PREC : PREC += 1 : Endif
  If SUIV : SUIV += 1 : Endif
  Break
 Endif
Next W
[DDD_] = [AAA_]
[M:STD]NBLIG = W
Affzo [M:STD]
Return

#----------------------------------------------------------------------------------------#
Subprog FILTRE(CLELIS,NBCLE,SENS,NBLIGT,CRITERE,IFILSUITE,FILSUITE)
Value    Char    CLELIS()(1..)
Value    Integer NBCLE
Value    Char    SENS
Value    Integer NBLIGT
Value    Char    CRITERE
Variable Integer IFILSUITE
Variable Char    FILSUITE()()
Local Integer I , J , K , T
Local Char    VALC(GLONID)(1..16) , FILTRE(250) , ACTION(20)
Local Char    CHAINE(250)
Local Integer ICRITBUF , IFILPREV , DIMS , DIMB
DIMS = dim(FILSUITE)-1
DIMB = dim(CRITERE)
Local Char    CRITBUF(250)(0..DIMB)
Local Char    FILSAV(250)(0..DIMS) , FILPREV(250)(0..DIMS)
Gosub FILSUITE
If SENS="<"
 Raz CRITBUF, ICRITBUF
 Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",CRITERE,"&") From GOBJSUB
 If CRITBUF = "" : CRITBUF = "1=1" : Endif
 CHAINE = ""
 For I=1 To NBCLE
  If CLELIS(I)<>""
   If CHAINE<>""
    CHAINE += ";"
   Endif
   CHAINE += CLELIS(I)+" Desc"
  Endif
 Next I
 If CRITBUF="" : CRITBUF = "1=1" : Endif
 If FILPREV="" : FILPREV = "1=1" : Endif
 Filter [AAA_] Where evalue(CRITBUF) & evalue(FILPREV) Order With CHAINE
 K = 0
 For [AAA_]
  K += 1
  If K>=NBLIGT : Break : Endif
 Next
 Read [AAA_] Next
 If fstat>2
  Raz FILSUITE, IFILSUITE
  FILSUITE = "1=1"
 Else
  Gosub FILSUITE
 Endif
 Filter [AAA_]
Endif
End

$FILSUITE
Raz FILSUITE, FILPREV, IFILSUITE, IFILPREV
K = 0
If dim([L]CLEVALEUR)>0
 If [L]CLEFCY<>"" & [L]CLELIS(1)=[L]CLEFCY & GFCY<>""
  K += 1
 Endif
 If [L]CLEDEP<>"" & [L]CLELIS(2)=[L]CLEDEP & GDEP<>""
  K += 1
 Endif
Endif
NBCLE = K
For I=1+K To dim(CLELIS)
 If CLELIS(I)="" : Break : Endif
 NBCLE += 1
 If instr(1,CLELIS(I),"]")
  CHAINE = CLELIS(I)
 Else
  CHAINE = "[F:AAA_]"+CLELIS(I)
 Endif
 T = evalue("type("+CHAINE+")")
 Case T
  When 1,2,4,5,6,7,8,9
   VALC(I) = num$(evalue(CHAINE))
  When 3
   If evalue(CHAINE)=[0/0/0]
    VALC(I) = '[0/0/0]'
   Else
    VALC(I) = '['+format$(GFMD,evalue(CHAINE))+']'
   Endif
  When Default
   VALC(I) = evalue(CHAINE)
   If instr(1,VALC(I),"'") & instr(1,VALC(I),'"')
    VALC(I) = ctrans(VALC(I),"'","&")
    VALC(I) = ctrans(VALC(I),'"',"!")
    VALC(I) = '"'+VALC(I)+'"'
   Elsif instr(1,VALC(I),'"') & !instr(1,VALC(I),"'")
    VALC(I) = "'"+VALC(I)+"'"
   Else
    VALC(I) = '"'+VALC(I)+'"'
   Endif
 Endcase
 If I=1+K
  FILSUITE = CHAINE+">"+VALC(I)
  FILPREV  = CHAINE+"<"+VALC(I)
 Else
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE","| (","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV","| (","") From GOBJSUB
  If FILPREV="" : Break : Endif
  For J=1+K To I-1
   If instr(1,CLELIS(J),"]")
    FILTRE = CLELIS(J)+"="+VALC(J)
   Else
    FILTRE = "[F:AAA_]"+CLELIS(J)+"="+VALC(J)
   Endif
   Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",FILTRE-"& ","") From GOBJSUB
   If FILSUITE="" : Break 2 : Endif
   Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",FILTRE-"& ","") From GOBJSUB
   If FILPREV="" : Break 2 : Endif
  Next J
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",CHAINE+">"+VALC(I)+")","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",CHAINE+"<"+VALC(I)+")","") From GOBJSUB
  If FILPREV="" : Break : Endif
 Endif
Next I
If FILSUITE=""   : Raz FILPREV
Elsif FILPREV="" : Raz FILSUITE
Endif
Return

#---------------------------#
$ENREGISTRER
Call DEBTRANS From GLOCK
Gosub TR3
If GOK=1
 REP = ""
Endif
Return

$TR3
Trbegin [AAA_]
 For indice =0 To [M:STD]NBLIG-1
  #CHECK UNUSED_BEGIN
  If [M:STD]FLMODIF(indice) = 1
   ENR = 1
   For I=1 To NBCLE
    Case [M:DIA]TYPTYP(I-1)
     When 1,2,3,4,5,6
      Assign("[F:AAA_]"+[M:DIA]CHAMP(I-1)+"("+num$([M:DIA]DIMIND(I-1))+")")
&     With val(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I-1)+"("+num$(indice)+")"))
# Issue 85821 - 2012-11-12 by VPO : maintenance en col sur UUID et DATETIME
     When 11
      Assign("[F:AAA_]"+[M:DIA]CHAMP(I-1)+"("+num$([M:DIA]DIMIND(I-1))+")")
&     With toUuid(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I-1)+"("+num$(indice)+")"))
     When 12
      Assign("[F:AAA_]"+[M:DIA]CHAMP(I-1)+"("+num$([M:DIA]DIMIND(I-1))+")")
&     With gdatetime$(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I-1)+"("+num$(indice)+")"))
     When Default
      Assign("[F:AAA_]"+[M:DIA]CHAMP(I-1)+"("+num$([M:DIA]DIMIND(I-1))+")")
&     With evalue("[M:STD]"+[M:DIA]CHAMPDIM(I-1)+"("+num$(indice)+")")
    Endcase
   Next I
   Readlock [AAA_] =
   If fstat=1
    GOK=-1 : GLOCK="$"+[M:DIA]CODFIC : Goto ROLL_TR3
   Elsif fstat
    GOK=0 : Call RSTA("AAA_","") From GLOCK : Goto AB_TR3
   Endif
   M = 0
   For I=0 To [M:DIA]NBRLIG-1
    If  [M:DIA]SAIAFF(I)<3
     VAL1 = num$(evalue("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")"))
     VAL2 = num$(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(indice)+")"))
     If VAL1<>VAL2 : M = 1 : Endif
    Endif
   Next I
   If M
    # Inspiré de TRT GOBJSUB/$SET_CLE et GOBJTXT/Subprog IDENT3
    CLEESP = num$(evalue("[F:AAA_]"+CLEPRIM))
    For I=0 To dim(CLESEC)-1
     If CLESEC(I)<>""
      CLEESP += "~"+num$(evalue("[F:AAA_]"+CLESEC(I)))
     Endif
    Next I
    Call ESPION([M:DIA]CODFIC+"~"+MOTIF,2,CLEESP,"") From ESPION
    Call TRACE([M:DIA]DOSSIER,[M:DIA]CODFIC+"~"+MOTIF,CLEESP,mess(2,83,1),"GSTDCOL") From ESPION : # Modif
    If GOK<1 : Break : Endif
   Endif
   For I=0 To [M:DIA]NBRLIG-1
    If  [M:DIA]SAIAFF(I)<3
     Case [M:DIA]TYPTYP(I)
      When 1,2,3,4,5,6
       Assign("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")")
&      With val(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(indice)+")"))
# Issue 85821 - 2012-11-12 by VPO : maintenance en col sur UUID et DATETIME
      When 11
       Assign("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")")
&       With toUuid(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(indice)+")"))
      When 12
       Assign("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")")
&       With gdatetime$(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(indice)+")"))
      When Default
       Assign("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")")
&      With evalue("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(indice)+")")
     Endcase
    Endif
   Next I
   Rewrite [AAA_]
   If fstat
    GOK=0 : Call RSTA("AAA_","") From GLOCK : Break
   Endif
  Endif
  #CHECK UNUSED_END
 Next indice
 If GOK=0     : Goto AB_TR3
 Elsif GOK=-1 : Goto ROLL_TR3
 Endif
Commit
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

$AB_TR3
Rollback
Return

#---------------------------#
$TRACE_ESPION
Local Char    VAL1(250), VAL2(250)
Local Integer I
For I=0 To [M:DIA]NBRLIG-1
 If  [M:DIA]SAIAFF(I)<3
  VAL1 = num$(evalue("[F:AAA_]"+[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")"))
  VAL2 = num$(evalue("[M:STD]"+[M:DIA]CHAMPDIM(I)+"("+num$(indice)+")"))
  If VAL1<>VAL2
   Wrseq format$("K:15X",[M:DIA]CHAMP(I)+"("+num$([M:DIA]DIMIND(I))+")"); Using [AESP]
   Wrseq "   "; Using [AESP]
   Wrseq format$("K:30X",VAL1); Using [AESP]
   Wrseq format$("K:30X",VAL2); Using [AESP]
   Wrseq Using [AESP]
  Endif
 Endif
Next I
Wrseq string$(75,"-") Using [AESP]
Return

#---------------------------#
$SELECTION
CRITERE = [M:CRIT]CRITERE
Gosub PREMIER
Return

#-----------------------------------------------------------------------------------------#
Subprog GENTRANS(OK)
Variable Integer OK

Local Char     CHAINE(GDIMFIC)     : # Chaine à tripoter
Local Char     TYPFMT(10) , OPTFMT(10) , NUMFMT(10) :# pour rechercher le format
Local Char     FORMAT(20) , INTIT(20) , CHFMT(30)
Local Integer  LGMAX , LONG, NBDIM, NB_LIGMAX
Local Integer  I , J , K , T , CPT
Local Char     TRANSAC(GLONAMK)

NB_LIGMAX = 50

OK = 1
CPT = 0
For I=1 To [M:DIA]NBRLIG
 If [M:DIA]SAIAFF(I-1)<=2
  CPT += 1
 Endif
 If CPT>NB_LIGMAX
  Call ERREUR(mess(54,126,1)-": "-num$(NB_LIGMAX)) From GESECRAN : # Nb maxi de lignes dépassé
  OK = 0
  Break
 Endif
Next I
If !OK : End : Endif

If clalev([F:AMK])=0  : Local File AMSK     [AMK]  : Endif
If clalev([F:AMK2])=0 : Local File AMSK     [AMK2] : Endif
If clalev([F:AMZ])=0  : Local File AMSKZON  [AMZ]  : Endif
If clalev([F:AMZ2])=0 : Local File AMSKZON  [AMZ2] : Endif
If clalev([F:AMA])=0  : Local File AMSKACT  [AMA]  : Endif
If clalev([F:AMA2])=0 : Local File AMSKACT  [AMA2] : Endif
If clalev([F:AWI])=0  : Local File AWINDOW  [AWI]  : Endif
If clalev([F:AWP])=0  : Local File AWINPAR  [AWP]  : Endif
If clalev([F:AWB])=0  : Local File AWINBRO  [AWB]  : Endif
If clalev([F:AWT])=0  : Local File AWINBOUT [AWT]  : Endif

If [M]DOSSIER=nomap
 If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
 If clalev([F:ATI])=0 : Local File ATABIND   [ATI] : Endif
 If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
 If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
 If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
Else
 If clalev([F:ATB])=0 : Local File =[M]DOSSIER+".ATABLE"  [ATB] : Endif
 If clalev([F:ATI])=0 : Local File =[M]DOSSIER+".ATABIND" [ATI] : Endif
 If clalev([F:ATZ])=0 : Local File =[M]DOSSIER+".ATABZON" [ATZ] : Endif
 If clalev([F:ATY])=0 : Local File =[M]DOSSIER+".ATYPE"   [ATY] : Endif
 If clalev([F:ACV])=0 : Local File =[M]DOSSIER+".ACTIV"   [ACV] : Endif
Endif

# get the screen model "STDCOL"
Read [AMK]CODMSK = "STDCOL"
If !fstat
 If [F:AMK]ACTBLOC(0) <> ""
  Read [ACV]CODACT = [F:AMK]ACTBLOC(0)
  If !fstat
   # get the total number of lines from the "code d'activité"
   [M:DIA]NBLIGT = [ACV]DIME
  Endif
 Else
  # if no "code d'activité" defined, try to get the total number from block configuration
  [M:DIA]NBLIGT = [F:AMK]NBLIGT
 Endif
Endif

Read [ATB]CODFIC = [M:DIA]CODFIC
T = 0

TRANSAC = "WMC"+[F:ATB]ABRFIC
Read [AMK]CODMSK = TRANSAC
While !fstat
 T += 1
 TRANSAC = "WMC"+[F:ATB]ABRFIC+num$(T)
 Read [AMK]CODMSK = TRANSAC
Wend
[M:DIA]TRANSAC = TRANSAC

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : OK = 0 : End : Endif
Call VALID(TRANSAC,nomap,1,GLANGUE,0,OK) From VALMSK
If !OK : End : Endif

Read [AWI]AWI0 = TRANSAC
If !fstat
 Call TR_DELWIN(TRANSAC,nomap) From MSKDIV
Endif
Call DEBTRANS From GLOCK
Gosub TR2
If GOK<1 : OK = 0 : End : Endif
Call VALID(TRANSAC,nomap,0,OK) From VALWIN
If !OK : End : Endif

Filter [AMZ2] Where [F:AMZ2]CODMSK=[M:DIA]TRANSAC
[M:DIA]NBCOL = 0
For [AMZ2]
 If [F:AMZ2]SAIAFF=2
  [M:DIA]NBCOL += 1
  [M:DIA]COLONNE([M:DIA]NBCOL-1) = [F:AMZ2]CODZON
 Endif
Next
Filter [F:AMZ2]
OK = 1
End

#---------------------------#
$TR1
NBDIM = 0
Trbegin [AMK2],[AMZ2],[AMA2]
 Gosub EN_TETE
 If GOK=1
  Gosub FIRST_LIGNE
  If GOK=1
   Gosub NEXT_LIGNE
  Endif
 Endif
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#---------------------------#
$EN_TETE
Read [AMK]CODMSK = "STDCOL"
If !fstat
 [F:AMK2] = [F:AMK]
 [F:AMK2]MDL    = 1
 [F:AMK2]CODMSK = TRANSAC
 [F:AMK2]CREDAT = date$
 [F:AMK2]CREUSR = GUSER
 [F:AMK2]UPDDAT = date$
 [F:AMK2]UPDUSR = GUSER
 Write [F:AMK2]
 If fstat
  GOK=0 : Call FSTA("AMK2") From GLOCK
 Endif
Endif
Return

#---------------------------#
$FIRST_LIGNE
Read [F:AMZ]CODE ="STDCOL";"NBLIG"
If !fstat
 [F:AMZ2] = [F:AMZ]
 [F:AMZ2]CODMSK = TRANSAC
 Write [F:AMZ2]
 If fstat
  GOK=0 : Call FSTA("AMZ2") From GLOCK
 Endif
Endif
Return

#---------------------------#
$NEXT_LIGNE
J = 2
For I=0 To [M:DIA]NBRLIG-1
 If [M:DIA]SAIAFF(I)<3
  Read [ATZ]CODZONE = [M:DIA]CODFIC;[M:DIA]CHAMP(I)
  If !fstat
   [F:AMZ2]        = [F:ATZ]
   [F:AMZ2]NOZONE  = J
   [F:AMZ2]CODZON  = [M:DIA]CHAMPDIM(I)
   [F:AMZ2]INTIT   = [F:ATZ]NOCOURT
   [F:AMZ2]NUMBLOC = 1
   [F:AMZ2]CODTYP  = "A"
   [F:AMZ2]NOLIB   = 0
   [F:AMZ2]LONG    = 250
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   Gosub FORMAT From GSTD0
   [F:AMZ2]OPTSAI  ="$"
   [F:AMZ2]OPTFOR  = '="'+FORMAT+'"'
   K = 1
   If [F:AMZ2]CODACT<>""
    Read [F:ACV]CODACT=[F:AMZ2]CODACT
    If fstat | [F:ACV]FLACT<>2
     K = 0
    Endif
   Endif
   If K
    [F:AMZ2]SAIAFF  = [M:DIA]SAIAFF(I)
   Else
    [F:AMZ2]CODACT = ""
    [F:AMZ2]SAIAFF = 3
   Endif
   Write [F:AMZ2]
   J += 1
   If fstat
    GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
   Endif
  Endif
 Endif
Next I
If GOK<1 : Return : Endif
###Dernière ligne le flag de modification
[F:AMZ2]NOZONE  = J
[F:AMZ2]CODZON  = "FLMODIF"
[F:AMZ2]INTIT   = 0
[F:AMZ2]NUMBLOC = 1
[F:AMZ2]CODTYP  = "C"
[F:AMZ2]LONG    = 1
[F:AMZ2]OPTFOR  = ""
[F:AMZ2]SAIAFF  = 3
Write [F:AMZ2]
If fstat
 GOK=0 : Call FSTA("AMZ2") From GLOCK
Endif
Return

#---------------------------#
$TR2
Trbegin [AWI]
 Read [AWI]AWI0 = "STDCOL"
 [F:AWI]NOMMSK(0) = TRANSAC
 [F:AWI]WIN = TRANSAC
 [F:AWI]MDL = 1
 Write [AWI]
 If fstat
  GOK=0 : Call FSTA("AWI") From GLOCK : Return
 Endif
 Read [AWB]AWB0 = "STDCOL"
 [F:AWB]WIN = TRANSAC
 Write [AWB]
 If fstat
  GOK=0 : Call FSTA("AWB") From GLOCK : Return
 Endif
 For [AWP] Where WIN="STDCOL"
  [F:AWP]WIN = TRANSAC
  Write [AWP]
  If fstat
   GOK=0 : Call FSTA("AWP") From GLOCK : Break
  Endif
 Next AWP
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 For [AWT] Where WIN="STDCOL"
  [F:AWT]WIN = TRANSAC
  Write [AWT]
  If fstat
   GOK=0 : Call FSTA("AWT") From GLOCK : Break
  Endif
 Next AWT
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#--------------------------------------------------------------------------------------------------#
Subprog CHARGE_CRIT(DOSSIER,TABLE)
Value Char DOSSIER,TABLE

# Remplissage du tableau

Local Char      NOM_CHP(50)                : # Pour éviter doublons sur zone indicée
Local Char      CHAINE(GDIMFIC)            : # Pour décomposition CLE1+CLE2...
Local Integer   I , J , K , CHP_IND
Local Integer   DIMS , AFF , NB
Local Char      CLEPRIM(GLONAVA)           : # 1ère composante de clé pour GOBJET
Local Char      CLESEC(GLONAVA)(0..16)     : # Suites des composantes pour GOBJET
Local Integer   POS_CLEPRIM
Local Integer   POS_CLESEC

If DOSSIER=nomap
 If clalev([F:ATB])=0 :  Local File ATABLE      [ATB] : Endif
 If clalev([F:ATZ])=0 :  Local File ATABZON     [ATZ] : Endif
 If clalev([F:ATX])=0 :  Local File ATEXTE      [ATX] : Endif
 If clalev([F:ATI])=0 :  Local File ATABIND     [ATI] : Endif
 If clalev([F:ATY])=0 :  Local File ATYPE       [ATY] : Endif
 If clalev([F:ACV])=0 :  Local File ACTIV       [ACV] : Endif
Else
 If clalev([F:ATB])=0 :  Local File =DOSSIER+".ATABLE"      [ATB] : Endif
 If clalev([F:ATZ])=0 :  Local File =DOSSIER+".ATABZON"     [ATZ] : Endif
 If clalev([F:ATX])=0 :  Local File =DOSSIER+".ATEXTE"      [ATX] : Endif
 If clalev([F:ATI])=0 :  Local File =DOSSIER+".ATABIND"     [ATI] : Endif
 If clalev([F:ATY])=0 :  Local File =DOSSIER+".ATYPE"       [ATY] : Endif
 If clalev([F:ACV])=0 :  Local File =DOSSIER+".ACTIV"       [ACV] : Endif
Endif

If DOSSIER=nomap
 Local File =TABLE [AAA_]
Else
 Local File =DOSSIER+"."+TABLE [AAA_]
Endif

Read [ATI]NUMLIG(2) = TABLE;1
[M]UNIQUE = ([F:ATI]HOMONYM=1)
If TABLE="AESPION" | ![M]UNIQUE
 AFF = 2 : # Affiché
Else
 AFF = 3 : # Invisible
Endif

Effzo [M]20

Read [ATB]CODFIC = TABLE
[M]INTITFIC = [F:ATB]INTITFIC

NB = 0
For [ATZ]CODZONE Where CODFIC=TABLE
 DIMS = evalue("dim([F:AAA_]"+[F:ATZ]CODZONE+")")
 If DIMS>0
  K = 1
  If [F:ATZ]CODACT<>""
   Read [F:ACV]CODACT=[F:ATZ]CODACT
   If fstat | [F:ACV]FLACT<>2
    K = 0
   Endif
  Endif
  If K
   Read [ATY]CODTYP=[F:ATZ]CODTYP
# Issue 85821 - 2012-11-12 by VPO : maintenance en col sur UUID et DATETIME
#   If !fstat & [F:ATY]TYPTYP<=8 & find([F:ATY]CODTYP,"AXX","AX1","AX2","AX3")=0
   If !fstat & find([F:ATY]CODTYP,"AXX","AX1","AX2","AX3")=0
&   & ([F:ATY]TYPTYP<=8 | [F:ATY]TYPTYP=11 | [F:ATY]TYPTYP=12 )
    # Pas de Blob ni textes traduisibles
    [M]CHAMP([M]NBRLIG)     = [F:ATZ]CODZONE
    [M]CHAMPDSP([M]NBRLIG)  = [F:ATZ]CODZONE
    [M]CHAMPDIM([M]NBRLIG)  = "Z"+format$("N0:3#",NB)
    Call TEXTE([F:ATZ]NOLONG,[M]INTITLONG([M]NBRLIG)) From OBJDIV
    [M]DIME([M]NBRLIG)      =  DIMS
    [M]TYPTYP([M]NBRLIG)    = [F:ATY]TYPTYP
    [M]CODTYP([M]NBRLIG)    = [F:ATZ]CODTYP
    [M]SAIAFF([M]NBRLIG)    = AFF
    [M]KEYORD([M]NBRLIG)    = 99
    # Cas des champs dimensionnés
    If DIMS>1
     CHAINE = [M]INTITLONG([M]NBRLIG)
     NOM_CHP = [M]CHAMPDSP([M]NBRLIG)
     For I=0 To DIMS-1
      [M]DIMIND([M]NBRLIG)    = I
      [M]CHAMP([M]NBRLIG)     = NOM_CHP : #+"_"+format$("N0:2#",I)
      [M]CHAMPDIM([M]NBRLIG)  = "Z"+format$("N0:3#",NB)
      [M]CHAMPDSP([M]NBRLIG)  = NOM_CHP+"("+format$("N0:2#",I)+")"
      [M]INTITLONG([M]NBRLIG) = CHAINE
      [M]SAIAFF([M]NBRLIG)    = AFF
      [M]KEYORD([M]NBRLIG)    = 99
      [M]TYPTYP([M]NBRLIG)    = [F:ATY]TYPTYP
      [M]CODTYP([M]NBRLIG)    = [F:ATZ]CODTYP
      [M]NBRLIG += 1
      NB += 1
     Next I
     [M]NBRLIG -= 1
    Endif
   [M]NBRLIG += 1
   Endif
   NB += 1
  Endif
 Endif
Next ATZ

Gosub CHARGE_CLE

# Recherche des composantes de clé

Raz POS_CLEPRIM, POS_CLESEC
For I=1 To [M]NBCLE
 J = find([M]CLE(I-1),[M]CHAMP(0..[M]NBRLIG-1))
 If J
  [M]SAIAFF(J-1) = 2 : # ML 35 Affiché
  [M]KEYORD(J-1) = I
  If CLESEC(0)<>"" & CLEPRIM=[M]CLE(I-1)
   POS_CLEPRIM = J-1
  Elsif CLESEC(0)<>"" & CLESEC(0)=[M]CLE(I-1)
   POS_CLESEC  = J-1
  Endif
 Endif
Next I
If POS_CLESEC
 [M]KEYORD(POS_CLEPRIM) = 1
 [M]KEYORD(POS_CLESEC)  = 2
Endif

### Un tri pour voir la clé en premier

Sorta [M]NBRLIG [M]NBRLIG Order By [M]KEYORD([S]indice) , [M]CHAMPDSP([S]indice)
For I=1 To [M]NBRLIG
 If [M]KEYORD(I-1)=99
  [M]KEYORD(I-1) = 0
 Endif
Next I

End

#---------------------------#
$CHARGE_CLE
Read [ATI]NUMLIG(2) = TABLE;1
CHAINE = [F:ATI]DESCRIPT
Raz [M]CLE, [M]NBCLE
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 [M]NBCLE += 1
 If I
  [M]CLE([M]NBCLE-1) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  [M]CLE([M]NBCLE-1) = CHAINE
  CHAINE = ""
 Endif
Wend
For I=1 To [M]NBCLE
 If I=1
  CLEPRIM = [M]CLE(0)
 Else
  CLESEC(I-2) = [M]CLE(I-1)
 Endif
Next I
Return

#----------------------------------------------------------------------------------------#
Subprog D_DOSSIER(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSSIER(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog AM_DOSSIER(VALEUR)
Variable Char   VALEUR()
[M]CODFIC = "" : Affzo [M]CODFIC
End

Subprog AS_CODFIC(VALEUR)
Variable Char     VALEUR
If GFILPATH="" : End : Endif
If [M]DOSSIER=nomap
 Local File ATABLE [ATB]
Else
 Local File =[M]DOSSIER+".ATABLE" [ATB]
Endif
Read [ATB]CODFIC = GFILPATH
If !fstat
 VALEUR = GFILPATH
Endif
End

Subprog C_CODFIC(VALEUR)
Variable Char VALEUR()
Local Integer I , J , NBCLE , MAXCLE
Local Char    FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , APPLI(GDIMFIC) , VOLUME(GDIMFIC)
Local Char    CHAINE(250) , MESSA(80)
If VALEUR="AESPION"
 Call MESSAGE(mess(190,133,1)) From GESECRAN : # Maintenance interdite sur cette table
 End
Endif
If [M:DIA]DOSSIER=nomap
 Local File ATABIND [ATI]
 Local File ATABLE  [ATB]
Else
 Local File =[M:DIA]DOSSIER+".ATABIND" [ATI]
 Local File =[M:DIA]DOSSIER+".ATABLE"  [ATB]
Endif
Read [ATB]CODFIC = VALEUR
If fstat
 # Table non déclarée dans le dictionnaire
 Call ERREUR(VALEUR-mess(158,115,1)) From GESECRAN : mkstat=2 : End
Endif
Call MACHINE([M]DOSSIER,MACHINE,APPLI) From ORDSYS
Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS
FICHIER = filpath("FIL",VALEUR,"fde",APPLI,VOLUME,MACHINE)
If filinfo(FICHIER,0)<0
 Call ERREUR("|"+FICHIER-":"-mess(124,124,1)) From GESECRAN : # Table inexistante
 mkstat=2 : End
Endif
Read [ATI]NUMLIG(2) = VALEUR;1
CHAINE = [F:ATI]DESCRIPT
NBCLE = 0
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CHAINE = right$(CHAINE,I+1)
 Else
  CHAINE = ""
 Endif
Wend
MAXCLE = 10
If NBCLE>MAXCLE
 MESSA = mess(29,176,1) : # Trop de composantes de clé (maximum #)
 I = instr(1,MESSA,"#")
 If I : MESSA = left$(MESSA,I-1)+num$(MAXCLE)+right$(MESSA,I+1) : Endif
 Call ERREUR(MESSA) From GESECRAN
 mkstat = 2 : End
Endif
If [F:ATI]HOMONYM<>1
 Call MESSAGE(mess(168,115,1)+"\"+mess(190,133,1)) From GESECRAN
 # La clé primaire de cette table accepte des homonymes/Il peut y avoir des pb d'affichage
 # Maintenance interdite sur cette table
 End
Endif
GFILPATH = VALEUR
End

Subprog AM_CODFIC(VALEUR)
Variable Char VALEUR()
Call CHARGE_CRIT([M]DOSSIER,VALEUR)
Affzo [M]20
Actzo [M]20
If VALEUR="AESPION" | ![M]UNIQUE
 Grizo 20
Else
 Gosub GRISE_CLE
Endif
zonsui = "NBRLIG"
End

Subprog AS_SAIAFF(VALEUR)
Variable Integer VALEUR()
# Issue 85821 - 2012-11-12 by VPO : maintenance en col sur UUID et DATETIME
If [M]TYPTYP(nolign-1)=11
GMENLOC(1) = 1
Endif
GMENLOC(4) = 1
End

Subprog AS_NBRLIG
GBOUT1 = mess(202,123,1) : # Tout Invisible
GBOUT2 = mess(203,123,1) : # Tout Affiché
GBOUT3 = mess(204,123,1) : # Tout Saisi
End

Subprog B1_NBRLIG
Local Integer LIGNE
If nolign>[M]NBCLE
 LIGNE = nolign
Else
 LIGNE = [M]NBCLE+1
Endif
For I=LIGNE To [M]NBRLIG
 [M]SAIAFF(I-1) = 3 : # Invisible
Next I
Affzo [M]SAIAFF
End

Subprog B2_NBRLIG
Local Integer LIGNE
If nolign>[M]NBCLE
 LIGNE = nolign
Else
 LIGNE = [M]NBCLE+1
Endif
For I=LIGNE To [M]NBRLIG
 [M]SAIAFF(I-1) = 2 : # Affiché
Next I
Affzo [M]SAIAFF
End

Subprog B3_NBRLIG
Local Integer LIGNE
If nolign>[M]NBCLE
 LIGNE = nolign
Else
 LIGNE = [M]NBCLE+1
Endif
For I=LIGNE To [M]NBRLIG
 # Issue 85821 - 2012-11-12 by VPO : maintenance en col sur UUID et DATETIME
 If [M]TYPTYP(I-1)=11
 [M]SAIAFF(I-1) = 2 : # Affiché
 Else
 [M]SAIAFF(I-1) = 1 : # Saisie
 Endif
Next I
Affzo [M]SAIAFF
End

Subprog C_FORCND(VALEUR)
Variable Char    VALEUR()
Local Integer ER
If VALEUR <> ""
 ER = 0
 If [M:DIA]DOSSIER=nomap
  If clalev([AAA_])=0 : Local File =[M:DIA]CODFIC   [AAA_] : Endif
 Else
  If clalev([AAA_])=0 : Local File =[M:DIA]DOSSIER+"."+[M:DIA]CODFIC [AAA_] : Endif
 Endif
 Onerrgo ERRSEL
 Filter [AAA_] Where evalue(VALEUR)
 For [AAA_]
  Break
 Next
 Onerrgo
 If ER
  Call ERREUR(mess(33,100,1)+"\"+errmes$(ER)+"\|"+errm+"|") From GESECRAN : # Erreur sur critère de sélection
  Filter [F:AAA_]
  mkstat = 2
 Endif
Endif
End

$ERRSEL
ER = errn
Resume

