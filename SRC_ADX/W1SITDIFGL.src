#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SITDIFGL 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:28"
A_USER  = "DOC"
A_STAMP = "20181109230628"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask SITDIFGL [SIL]
Gosub HORODAT
Local Inpbox "SITDIFGL" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIL] As [SIM_]
Grizo [SIL]5
Grizo [SIL]10
Grizo [SIL]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [SIL]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=20 : X2(0)=93 : Y1(0)=12 : Y2(0)=14
X1(1)=20 : X2(1)=56 : Y1(1)=15 : Y2(1)=17
X1(2)=57 : X2(2)=93 : Y1(2)=15 : Y2(2)=17
Return

$ON_INI
Onevent INIT_AREA Call D_INI(zc) From W1SITDIFGL
Return

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If varinit([M]INI,indice)=0
 ## Action STD
 Call D_INI(VALEUR) From SITDGL
Endif
Gosub _AFF
End

$ON_ALLJOU
Onevent CONTROL Call C_ALLJOU(zc) From W1SITDIFGL
Onevent INIT_AREA Call D_ALLJOU(zc) From W1SITDIFGL
Onevent BEFORE_INPUT Call AS_ALLJOU(zc) From W1SITDIFGL
Return

Subprog D_ALLJOU(VALEUR)
Variable Integer VALEUR
If varinit([M]ALLJOU,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_ALLJOU(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_ALLJOU(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ALLJOU" : GZNUM = 6055 : Endif
If !mkstat
 ## Action STD
 Call C_ALLJOU(VALEUR) From SITDGL
 If mkstat : GERR = 1 : GZONE = "ALLJOU" : GZNUM = 6055 : Endif
Endif
Gosub _AFF
End

$ON_JOUSTR
Onevent CONTROL Call C_JOUSTR(zc) From W1SITDIFGL
Onevent BEFORE_INPUT Call AS_JOUSTR(zc) From W1SITDIFGL
Onevent AFTER_CHANGE Gosub AMM_JOUSTR From W1SITDIFGL
Return

Subprog AS_JOUSTR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(4314,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_JOUSTR(VALEUR) From SITDGL
If mkstat=2
 [M]JOUSTR(INDIC) = VALEUR
 Affzo JOUSTR(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_JOUSTR(zc) From W1SITDIFGL
Onkey   2 Titled GBOUTS Call S_JOUSTR(zc) From W1SITDIFGL
Onkey 144 Titled GBOUTP Call P_JOUSTR(zc) From W1SITDIFGL
Onkey 146 Titled GBOUTA Call SA_JOUSTR(zc) From W1SITDIFGL
Gosub _AFF
End

Subprog C_JOUSTR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "JOUSTR" : GZNUM = 1400 : Endif
If !mkstat
 ## Action CONTJOU
 Call CONTJOU(VALEUR,"","") From SUBJOU
 If mkstat : GERR = 1 : GZONE = "JOUSTR" : GZNUM = 1400 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "JOUSTR" : GZNUM = 1400 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_JOUSTR
Call AM_JOUSTR(zc)
If !mkstat & GOBJET
 zoncou = "JOUSTR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_JOUSTR(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZJOUSTR)")>indice
 [M]JOUSTR(indice) = VALEUR
 Affzo ZJOUSTR(indice)
Endif
Gosub _AFF
End

Subprog S_JOUSTR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELJOU
 Call SELJOU(VALEUR,"") From SUBJOU
Endif
Gosub _AFF
End

Subprog B1_JOUSTR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNJOU
 Call TUNJOU(VALEUR,"") From SUBJOU
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_JOUSTR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "JOU"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_JOUSTR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("JOU",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZJOUSTR
Onevent BEFORE_AREA Gosub AV_ZJOUSTR From W1SITDIFGL
Return

$AV_ZJOUSTR
Call LECTEXTRA(zc,"GJOURNAL","DESTRA",num$([M]JOUSTR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_JOUEND
Return

$ON_ALLPER
Onevent CONTROL Call C_ALLPER(zc) From W1SITDIFGL
Onevent INIT_AREA Call D_ALLPER(zc) From W1SITDIFGL
Onevent BEFORE_INPUT Call AS_ALLPER(zc) From W1SITDIFGL
Return

Subprog D_ALLPER(VALEUR)
Variable Integer VALEUR
If varinit([M]ALLPER,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_ALLPER(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_ALLPER(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_ALLPER(VALEUR) From SITDGL
If mkstat : GERR = 1 : GZONE = "ALLPER" : GZNUM = 32401 : Endif
Gosub _AFF
End

$ON_PERSTR
Onevent BEFORE_INPUT Call AS_PERSTR(zc) From W1SITDIFGL
Onevent CONTROL Call C_PERSTR(zc) From W1SITDIFGL
Onevent BEFORE_AREA Gosub AV_PERSTR From W1SITDIFGL
Return

$AV_PERSTR
Chgfmt [M]PERSTR(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog AS_PERSTR(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_PERSTR(VALEUR) From SITDGL
If mkstat=2
 [M]PERSTR(INDIC) = VALEUR
 Affzo PERSTR(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_PERSTR(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PERSTR" : GZNUM = 1400 : Endif
If !mkstat
 ## Action STD
 Call C_PERSTR(VALEUR) From SITDGL
 If mkstat : GERR = 1 : GZONE = "PERSTR" : GZNUM = 1400 : Endif
Endif
Gosub _AFF
End

$ON_PEREND
Onevent BEFORE_INPUT Call AS_PEREND(zc) From W1SITDIFGL
Onevent CONTROL Call C_PEREND(zc) From W1SITDIFGL
Onevent BEFORE_AREA Gosub AV_PEREND From W1SITDIFGL
Return

$AV_PEREND
Chgfmt [M]PEREND(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog AS_PEREND(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_PEREND(VALEUR) From SITDGL
If mkstat=2
 [M]PEREND(INDIC) = VALEUR
 Affzo PEREND(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_PEREND(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PEREND" : GZNUM = 1260 : Endif
If !mkstat
 ## Action STD
 Call C_PEREND(VALEUR) From SITDGL
 If mkstat : GERR = 1 : GZONE = "PEREND" : GZNUM = 1260 : Endif
 If !mkstat
  ## Action DATDEBFIN
  Call DATDEBFIN(VALEUR,[M:SIL]PERSTR) From EXEFNC
  If mkstat : GERR = 1 : GZONE = "PEREND" : GZNUM = 1260 : Endif
 Endif
Endif
Gosub _AFF
End

