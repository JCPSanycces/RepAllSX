# Supervisor
## CRUD-CLASSE ## ESSWRKEMP
# 2018-10-23 06:53:22 208


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(ESSWRKEMP,ASTATUS)
Variable Instance ESSWRKEMP Using C_ESSWRKEMP
Variable Integer ASTATUS

If ESSWRKEMP = null : End : Endif

Gosub _AVARIABLES From WMC00ESSWRKEMP

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_ESSWRKEMP

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(ESSWRKEMP,ASTATUS)
Variable Instance ESSWRKEMP Using C_ESSWRKEMP
Variable Integer ASTATUS

If ESSWRKEMP = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKEMP
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_ESSWRKEMP
Else
 Gosub AINSERT_ESSWRKEMP
Endif

Gosub _AINSERT_AFTER
[L]A_I = ESSWRKEMP.freeSnapshot
ESSWRKEMP.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKEMP._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKEMP._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKEMP._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If ESSWRKEMP.ASTALIN = [V]CST_ANEWDEL : Return : Endif
ESSWRKEMP.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_ESSWRKEMP
Trbegin [F:EWID]
 Gosub AINSERT_ESSWRKEMP
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_ESSWRKEMP
Raz [F:EWID]
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00ESSWRKEMP._MAJSQL_ESSWRKEMP(ESSWRKEMP))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If ESSWRKEMP.snapshotEnabled=1
 [L]A_RETIK = ESSWRKEMP.revertUpdTick
Endif
[L]ASTATUS = max(fmet ESSWRKEMP.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(ESSWRKEMP.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 ESSWRKEMP.ASTALIN = [V]CST_ALL
Endif
Return



