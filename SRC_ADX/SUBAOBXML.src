###############################################################################################################
#
#   Génération XML d'un objet X3                                                  Version 140
#   Module CRM                             
#   
###############################################################################################################

###############################################################################################################
Subprog EASYCRMXML(SZAOB, SZRECNUM, SZRETFILENAME)
Value Char SZAOB
Value Char SZRECNUM
Variable Char SZRETFILENAME

If SZAOB = "" : End : Endif
If SZRECNUM = "" : End : Endif

Local Integer IGENERICFILENAME
Local Char SZXSLSHEET
Local Char SZPECONTEXT
Local Char SZFULLRETFILE(250)
Local Integer ICHAPTER
Local Integer IERRINF
IGENERICFILENAME = 1
SZXSLSHEET = ""
SZPECONTEXT = ""
SZFULLRETFILE = ""
SZRETFILENAME = ""
ICHAPTER = 0
IERRINF = 0

Call AOBINXML(SZAOB, SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)

End

###############################################################################################################
Subprog AOBINXML(SZAOB, SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE,
&       SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZAOB
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

Case SZAOB    
    When "ITN"
Call ITNINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBITNXML

    When "SRE"
Call SREINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBSREXML

    When "SOL"
Call SOLINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBSOLXML

    When "TSK"
Call TSKINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBTSKXML

    When "CLL"
Call CLLINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBCLLXML

    When "OPP"
Call OPPINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBOPPXML

    When "BAP"
Call BAPINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBBAPXML

    When "BPR"
Call BPRINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBBPRXML

Endcase

End



###############################################################################################################
Subprog AOBLISTXML(SZAOB, SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE,
&       SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZAOB
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

Case SZAOB    
    When "ITN"
Call ITNLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBITNXML

    When "SRE"
Call SRELISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBSREXML

    When "SOL"
Call SOLLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBSOLXML

    When "TSK"
Call TSKLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBTSKXML

    When "CLL"
Call CLLLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBCLLXML

    When "OPP"
Call OPPLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBOPPXML

    When "BAP"
Call BAPLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBBAPXML

    When "BPR"
Call BPRLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
&       From SUBBPRXML

Endcase

End


###############################################################################################################
Subprog EASYCRMLXML(SZAOB, SZFILTER, SZRETFILENAME)
Value Char SZAOB
Variable Char SZFILTER
Variable Char SZRETFILENAME

If SZAOB = "" : End : Endif
If SZFILTER = "1=1" : End : Endif

Local Char SZCUSTFILENAME
Local Char SZXSLSHEET
Local Char SZPECONTEXT
Local Char SZFULLRETFILE(250)
Local Integer ICHAPTER
Local Integer IERRINF
SZCUSTFILENAME = ""
SZXSLSHEET = ""
SZPECONTEXT = ""
SZFULLRETFILE = ""
SZRETFILENAME = ""
ICHAPTER = 0
IERRINF = 0

Call AOBLISTXML(SZAOB, SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)

End
