# Classe TABPLACE
# Issue 113105 - 2016-01-13 by MAE : Refactoring code
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "TPC.TPCTYP"     : Gosub TPC_TPCTYP
Endcase
Return



#$METHODS
#Case [L]CURPTH
#   When ""
#      Case [L]ACTION
#      Endcase
#Endcase
#Return
##############################################################################################
$TPC_TPCTYP
Case [L]ARULE
 When "PROPAGATE"   : Gosub TPC_TPCTYP_PROPAGATE
Endcase
Return
##############################################################################################
$TPC_TPCTYP_PROPAGATE

For I=1 To maxtab(this.BPA)
    WRET = fmet this.ADELLINE("BPA",I)
Next
If this.TPCTYP = 6
#  #Disable of all adress field if place type is site or supplier
  this.BPSNUM = AVOID.ACHAR
  ASTATUS = fmet this.ASETATTRIBUTE("BPSNUM","$isDisabled","true")
  ASTATUS = fmet this.ASETATTRIBUTE("FCY","$isDisabled","false")
Elsif this.TPCTYP = 7
#  #Enable of all adress field if place type is not site or supplier
  this.FCY = AVOID.ACHAR
  ASTATUS = fmet this.ASETATTRIBUTE("FCY","$isDisabled","true")
  ASTATUS = fmet this.ASETATTRIBUTE("BPSNUM","$isDisabled","false")
Else
  this.BPSNUM = AVOID.ACHAR
  this.FCY = AVOID.ACHAR
  ASTATUS = fmet this.ASETATTRIBUTE("BPSNUM","$isDisabled","true")
  ASTATUS = fmet this.ASETATTRIBUTE("FCY","$isDisabled","true")
Endif
Return
##############################################################################################

