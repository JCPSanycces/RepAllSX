###################################################################################################
###################################################################################################
# Textes du dictionnaire (ATEXTE)
Funprog RDT(I)
Value Integer I
 If clalev([ZATX])=0 : Local File ATEXTE [ZATX] : Endif
 Read [ZATX]NUMERO=GLANGUE;I
 If fstat<>0
    If GLANGUE<>"FRA"
        Read [ZATX]NUMERO="FRA";I
        If fstat=0
            [ZATX]TEXTE="["+[ZATX]TEXTE+"]"
        Else
            Raz [ZATX]
        Endif
    Else
        Raz [ZATX]
    Endif
 Endif
End [ZATX]TEXTE

# Textes du dictionnaire par référence au champ d'un écran
# (ou au titre de l'écran si le champ est vide, ou au titre du bloc si on retrouve un champ numérique)
# A utiliser dès qu'on a besoin d'un texte "constant" déjà traduit (le numéro de ATEXTE n'est pas constant)
#
Funprog RDM(MASQ,CHAMP)
Value Char MASQ(),CHAMP()

 If clalev([AMK1])=0 : Local File AMSK [AMK1] : Endif
 If clalev([AMZ1])=0 : Local File AMSKZON [AMZ1] : Endif
 If pat(CHAMP,"#*")
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]TITBLOC(val(CHAMP))<>0
            End func ORAPRO.RDT([AMK1]TITBLOC(val(CHAMP)))
        Endif
    Endif
 Elsif CHAMP<>""
    Read [AMZ1]CODE=MASQ;CHAMP
    If fstat=0
        If [AMZ1]INTIT<>0
            End func ORAPRO.RDT([AMZ1]INTIT)
        Endif
    Endif
 Else
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]INTMSK<>0
            End func ORAPRO.RDT([AMK1]INTMSK)
        Endif
    Endif
  Endif
End ""


###################################################################################################
###################################################################################################
Subprog TUER_PRO1(TYPKILL,ERR)
Variable Integer TYPKILL
Variable Integer ERR

#############################################################
## Pour Oracle
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20) , WORDRE(250)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    RESTE(250), LIGNE(250)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) ,SQLDBA(50) , IRS(2), OS(10)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS="unix"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SQLDBA = "sqlplus" : # Ca existe dans les 2 versions
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""

 FICSQL = filpath("tmp","orapro"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","orapro"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 If toupper([M:PRO4]USR)="SYS"
     If left$([M:PRO0]VER,1)="8"
       Wrseq "connect SYS/"+[M:PRO4]PWD
     Else
       Wrseq "connect SYS/"+[M:PRO4]PWD-"as SYSDBA"
     Endif
 Else
     Wrseq "connect "+[M:PRO4]USR+"/"+[M:PRO4]PWD
 Endif
 If TYPKILL=2
    Wrseq "ALTER SYSTEM DISCONNECT SESSION '"+num$([M:PRO1]SID(nolign-1))+","+[M:PRO1]SERIAL(nolign-1)+"' POST_TRANSACTION;"
 Else
    Wrseq "ALTER SYSTEM KILL SESSION '"+num$([M:PRO1]SID(nolign-1))+","+[M:PRO1]SERIAL(nolign-1)+"';"
 Endif
 Wrseq "exit"
 Openo
 WORDRE = SQLDBA-'/NOLOG @'+SQLFIC
 Call SYSTEME(MACHINE,WORDRE,"",ERR) From ORDSYS
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If left$(LIGNE,4) = "ORA-"
      Errbox LIGNE
      ERR=1
      Break
   Elsif left$(LIGNE,4) = "SP2-"
      Errbox LIGNE
      ERR=1
      Break
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
Endif
$FIN_TUER
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End


###################################################################################################
###################################################################################################
$ERR_SQL_PRO2
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
    GMESSAGE += "\"+"V$SQLTEXT_WITH_NEWLINES, V$SESSION"
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End

###################################################################################################
###################################################################################################
Subprog CHARGE_PRO2(ERR)
Variable Integer ERR

Local Char SQLREQ (150) (2)
Local Char SQLREQ1 (150)
Local Integer NBPIECE

SQLREQ1(0) ="select count(piece) from V$SQLTEXT_WITH_NEWLINES t,V$SESSION s "
SQLREQ1(0)+="where t.address=s.sql_address and t.hash_value=s.sql_hash_value "
SQLREQ1(0)+="and s.sid="+num$([M:PRO2]SID)

Onerrgo ERR_SQL_PRO2

For (Integer VNBPIECE) From '3' Sql SQLREQ1 As [BZZ]
     NBPIECE = [BZZ]VNBPIECE
    Break
Next

If NBPIECE=0
   Setlob [M:PRO2]SQLTXT With ""
   Goto FIN_PRO2
Endif

Local Char CHAINE(70) (1..NBPIECE)

SQLREQ(0)  = "select distinct piece, t.sql_text "
SQLREQ(0) +="from V$SQLTEXT_WITH_NEWLINES t,V$SESSION s "
SQLREQ(0) +="where t.address=s.sql_address and t.hash_value=s.sql_hash_value "
SQLREQ(1) = "and s.sid="+num$([M:PRO2]SID)
SQLREQ(1) +=" order by piece ASC"

For (Integer VPIECE,Char VTXT(100)) From '3' Sql SQLREQ As [BXX]
    CHAINE([BXX]VPIECE+1)=[BXX]VTXT
Next

Setlob [M:PRO2]SQLTXT With CHAINE(1..NBPIECE)

$FIN_PRO2
Onerrgo
End


###################################################################################################
###################################################################################################
$ERR_SQL_PRO3
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
    GMESSAGE += "\"+"DBA_OBJECTS, V$LOCK, V$SESSION"
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End

###################################################################################################
###################################################################################################
Subprog CHARGE_PRO3(ERR)
Variable Integer ERR

Local Char SQLREQ (150) (4)
Local Integer J

Onerrgo ERR_SQL_PRO3
SQLREQ(0) = "select nvl(B.SID,0),DECODE(B.ID2, 0, A.OBJECT_NAME,'Trans-'||to_char(B.ID1)),"
SQLREQ(0) +="B.TYPE,B.LMODE,B.REQUEST,B.BLOCK,nvl(CTIME,0),"
SQLREQ(1) = "(select nvl(W.SID,0) from V$LOCK W where W.LMODE <> 0 and W.ID1=B.ID1 and B.REQUEST<>0) "
SQLREQ(2) = ",DECODE(B.ID2, 0, A.OWNER,NULL) "
#VPO 28/04/06 supp jointure avec v$session pour perf
#SQLREQ(2) +="From DBA_OBJECTS A,V$LOCK B,V$SESSION s "
SQLREQ(2) +="From DBA_OBJECTS A,V$LOCK B "
#VPO 28/04/06 supp jointure avec v$session pour perf
#SQLREQ(3) = "where A.OBJECT_ID(+) = B.ID1 and B.SID=s.sid "
SQLREQ(3) = "where A.OBJECT_ID(+) = B.ID1 "
#VPO 28/04/06 supp jointure avec v$session pour perf
#If [M:PRO1]FLT=1
#    SQLREQ(3) += "and s.USERNAME='"+nomap+"' "
#Endif
SQLREQ(3) +="order by 1,2,B.ID2"

Raz [M:PRO3]

nolign = 0

For (Integer VSID,Char VOBJ(100),Char VLCK(5),Integer VLMODE,Integer VREQUEST,
&    Integer VBLOCK,Integer VCTIME,Integer VLSID,Char VOWN(30)) From '3' Sql
&    SQLREQ
&    As [BXX]
    J=find([BXX]VSID,[M:PRO1]SID(0..[M:PRO1]NBPRO-1))
    If J>0
      If [M:PRO1]DBUSR(J-1)<>""
        # Issue 84811 - 2012-10-01 by VPO : nb de lignes dans les tableaux
        If nolign>=dim([M:PRO3]SID)
          Call ERREUR(mess(513,153,1)-mess(26,100,1)) From GESECRAN
          Break
        Endif
        nolign +=1
        [M:PRO3]SID(nolign-1)=[BXX]VSID
        [M:PRO3]DBUSR(nolign-1)=[M:PRO1]DBUSR(J-1)
        [M:PRO3]OSUSR(nolign-1)=[M:PRO1]OSUSR(J-1)
        [M:PRO3]OBJOWN(nolign-1)=[BXX]VOWN
        [M:PRO3]OBJNAM(nolign-1)=[BXX]VOBJ
        Case [BXX]VLMODE
            When 1 : [M:PRO3]LMOD(nolign-1)="No Lock (NULL)"
            When 2 : [M:PRO3]LMOD(nolign-1)="Row Share (SS)"
            When 3 : [M:PRO3]LMOD(nolign-1)="Row Exclusive (SX)"
            When 4 : [M:PRO3]LMOD(nolign-1)="Share (S)"
            When 5 : [M:PRO3]LMOD(nolign-1)="Share Row Exclusive (SSX)"
            When 6 : [M:PRO3]LMOD(nolign-1)="Exclusive (X)"
            When Default : [M:PRO3]LMOD(nolign-1)="none"
        Endcase
        If VBLOCK <>0
            [M:PRO3]BLOCK(nolign-1)=2
        Else
            [M:PRO3]BLOCK(nolign-1)=1
        Endif
        [M:PRO3]WAIT(nolign-1)=[BXX]VLSID
        [M:PRO3]CTIM(nolign-1)=[BXX]VCTIME
        Case [BXX]VREQUEST
            When 1 : [M:PRO3]RMOD(nolign-1)="No Lock (NULL)"
            When 2 : [M:PRO3]RMOD(nolign-1)="Row Share (SS)"
            When 3 : [M:PRO3]RMOD(nolign-1)="Row Exclusive (SX)"
            When 4 : [M:PRO3]RMOD(nolign-1)="Share (S)"
            When 5 : [M:PRO3]RMOD(nolign-1)="Share Row Exclusive (SSX)"
            When 6 : [M:PRO3]RMOD(nolign-1)="Exclusive (X)"
            When Default : [M:PRO3]RMOD(nolign-1)="none"
        Endcase
        [M:PRO3]LCK(nolign-1)=[BXX]VLCK
        Case [BXX]VLCK
              When "TX": [M:PRO3]LCKTYP(nolign-1) ="TRANSACTION ROW-LEVEL"
              When "TS": [M:PRO3]LCKTYP(nolign-1) ="TEMPORARY SEGMENT"
              When "TD": [M:PRO3]LCKTYP(nolign-1) ="TABLE LOCK"
              When "TM": [M:PRO3]LCKTYP(nolign-1) ="ROW LOCK"
        Endcase
        Case [BXX]VLCK
            When "TM": [M:PRO3]LCKDES(nolign-1) ="DML enqueue"
            When "TX": [M:PRO3]LCKDES(nolign-1) ="Transaction enqueue"
            When "UL": [M:PRO3]LCKDES(nolign-1) ="User supplied"
            When "BL": [M:PRO3]LCKDES(nolign-1) ="Buffer hash table instance"
            When "CF": [M:PRO3]LCKDES(nolign-1) ="Control file schema global enqueue"
            When "PF": [M:PRO3]LCKDES(nolign-1) ="Password File"
            When "CI": [M:PRO3]LCKDES(nolign-1) ="Cross-instance function invocation instance"
            When "PI": [M:PRO3]LCKDES(nolign-1) ="Parallel operation"
            When "PS": [M:PRO3]LCKDES(nolign-1) ="Parallel operation"
            When "CU": [M:PRO3]LCKDES(nolign-1) ="Cursor bind"
            When "PR": [M:PRO3]LCKDES(nolign-1) ="Process startup"
            When "DF": [M:PRO3]LCKDES(nolign-1) ="Data file instance"
            When "DL": [M:PRO3]LCKDES(nolign-1) ="Direct loader parallel index create"
            When "RT": [M:PRO3]LCKDES(nolign-1) ="Redo thread global enqueue"
            When "DM": [M:PRO3]LCKDES(nolign-1) ="Mount/startup db primary/secondary instance"
            When "SC": [M:PRO3]LCKDES(nolign-1) ="System commit number instance"
            When "DR": [M:PRO3]LCKDES(nolign-1) ="Distributed recovery process"
            When "SM": [M:PRO3]LCKDES(nolign-1) ="SMON"
            When "DX": [M:PRO3]LCKDES(nolign-1) ="Distributed transaction entry"
            When "SN": [M:PRO3]LCKDES(nolign-1) ="Sequence number instance"
            When "FS": [M:PRO3]LCKDES(nolign-1) ="File set"
            When "SQ": [M:PRO3]LCKDES(nolign-1) ="Sequence number enqueue"
            When "HW": [M:PRO3]LCKDES(nolign-1) ="Space management operations on a specific segment"
            When "SS": [M:PRO3]LCKDES(nolign-1) ="Sort segment"
            When "IN": [M:PRO3]LCKDES(nolign-1) ="Instance number"
            When "ST": [M:PRO3]LCKDES(nolign-1) ="Space transaction enqueue"
            When "IR": [M:PRO3]LCKDES(nolign-1) ="Instance recovery serialization global enqueue"
            When "SV": [M:PRO3]LCKDES(nolign-1) ="Sequence number value"
            When "IS": [M:PRO3]LCKDES(nolign-1) ="Instance state"
            When "TA": [M:PRO3]LCKDES(nolign-1) ="Generic enqueue"
            When "IV": [M:PRO3]LCKDES(nolign-1) ="Library cache invalidation instance"
            When "TS": [M:PRO3]LCKDES(nolign-1) ="Temporary segment enqueue (ID2=0)"
            When "JQ": [M:PRO3]LCKDES(nolign-1) ="Job queue"
            When "TS": [M:PRO3]LCKDES(nolign-1) ="New block allocation enqueue (ID2=1)"
            When "KK": [M:PRO3]LCKDES(nolign-1) ="Thread kick"
            When "TT": [M:PRO3]LCKDES(nolign-1) ="Temporary table enqueue"
            When "UN": [M:PRO3]LCKDES(nolign-1) ="User name"
            When "MM": [M:PRO3]LCKDES(nolign-1) ="Mount definition global enqueue"
            When "US": [M:PRO3]LCKDES(nolign-1) ="Undo segment DDL"
            When "MR": [M:PRO3]LCKDES(nolign-1) ="Media recovery"
            When "WL": [M:PRO3]LCKDES(nolign-1) ="Being-written redo log instance"
            When Default:
                 If left$([BXX]VLCK,1)="L"
                     [M:PRO3]LCKDES(nolign-1) ="Library cache lock instance lock (A..P = namespace)"
                 Elsif left$([BXX]VLCK,1)="L"
                     [M:PRO3]LCKDES(nolign-1) ="Row cache instance (A..Z = cache)"
                 Elsif left$([BXX]VLCK,1)="N"
                     [M:PRO3]LCKDES(nolign-1) ="Library cache pin instance (A..Z = namespace)"
                 Endif
        Endcase
      Endif
    Endif
Next
[M:PRO3]NBLOCK = nolign
Onerrgo

#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR & [M:PRO3]NBLOCK>0
    Call ECR_TRACE("",0) From GESECRAN

    Call ECR_TRACE(mess(513,153,1) ,0) From GESECRAN
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

    Call ECR_TRACE_F(format$("K:8X",func RDM("ORAPRO3","SID")),format$("K:20X",func RDM("ORAPRO3","DBUSR"))+" "+format$("K:30X",func RDM("ORAPRO3","OSUSR")),
& format$("K:50X",func RDM("ORAPRO3","OBJNAM")),format$("K:30X",func RDM("ORAPRO3","OBJOWN")),
& "",
& 9,52,51,31,0,0) From GESECRAN
    Call ECR_TRACE_F(string$(8,"_"),string$(20,"_")+" "+string$(30,"_"),
& string$(50,"_"),string$(30,"_"),
& "",
& 9,52,51,31,0,0) From GESECRAN

    Call ECR_TRACE_F("",
& format$("K:2X",func RDM("ORAPRO3","LCK")),
& format$("K:60X",func RDM("ORAPRO3","LCKTYP")),
& format$("K:60X",func RDM("ORAPRO3","LCKDES")),"",
& 61,3,61,61,0,0) From GESECRAN
    Call ECR_TRACE_F("",
& string$(2,"_"),
& string$(60,"_"),
& string$(60,"_"),"",
& 61,3,61,61,0,0) From GESECRAN

    Call ECR_TRACE_F("",
& format$("K:30X",func RDM("ORAPRO3","LMOD"))+" "+format$("K:15X",func RDM("ORAPRO3","BLOCK")),
& format$("K:30X",func RDM("ORAPRO3","RMOD")),
& format$("K:8X",func RDM("ORAPRO3","WAIT")),
& format$("K:8X",func RDM("ORAPRO3","CTIM")),
& 61,47,31,9,9,0) From GESECRAN
    Call ECR_TRACE_F("",
& string$(30,"_")+" "+string$(15,"_"),
& string$(30,"_"),
& string$(8,"_"),string$(8,"_"),
& 61,47,31,9,9,0) From GESECRAN

    For I=0 To [M:PRO3]NBLOCK-1

        Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

        Call ECR_TRACE_F(format$("N:8",[M:PRO3]SID(I)),format$("K:20X",[M:PRO3]DBUSR(I))+" "+format$("K:30X",[M:PRO3]OSUSR(I)),
& format$("K:50X",[M:PRO3]OBJNAM(I)),format$("K:30X",[M:PRO3]OBJOWN(I)),
& "",
& 9,52,51,31,0,0) From GESECRAN

        Call ECR_TRACE_F("",
& [M:PRO3]LCK(I),
& [M:PRO3]LCKTYP(I),
& [M:PRO3]LCKDES(I),"",
& 61,3,61,61,0,0) From GESECRAN

        Call ECR_TRACE_F("",
& format$("K:30X",[M:PRO3]LMOD(I))+" "+format$("K:15X",mess([M:PRO3]BLOCK(I),1,1)),
& format$("K:30X",[M:PRO3]RMOD(I)),
& format$("N:8",[M:PRO3]WAIT(I)),
& format$("N:8",[M:PRO3]CTIM(I)),
& 61,47,31,9,9,0) From GESECRAN

    Next I
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endif
End

