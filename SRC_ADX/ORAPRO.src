#<AdxTL>@(#)3.0.0.0 $Revision$
Close Local Mask
Call ORAPRO(nomap)
End

########################################################################
Subprog ORAPRO(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"ORAPRO","ORAPRO","") From GSAISIE
End

######################################################################################
# Gestion des masques ORAPRO0,ORAPRO2,ORAPRO3,ORAPRO4
####################
$ACTION
If GACTION="ORAPRO4" or GACTION="ORAPRO5"
    Case ACTION
     When "INIT" : Gosub INIT45
     When "INIT_DIA" : Gosub INIT_DIA45
     When "EXEC"     : Gosub EXEC45
     When "TERMINE"  : Gosub TERMINE45
     When Default
    Endcase
Elsif GACTION="ORAPRO2"
    Case ACTION
     When "INIT_DIA" : Gosub INIT_DIA2
     When Default
    Endcase
Else
    Case ACTION
     When "OUVRE"        : Gosub OUVRE
     When "DEBUT"        : Gosub DEBUT
     When "SETBOUT"      : Gosub SETBOUT
     When "RAF"          : Gosub RAF
     When "BOUTON"       : Gosub BOUTON
     When "FIN"          : Gosub FIN
     When "EXEC"         : Gosub EXEC_BATCH
     When Default
    Endcase
Endif
Return

####################
$INIT45
Local Char TXT (255)
TXT="\"+num$([M:PRO1]SID(nolign-1))-"/"-[M:PRO1]DBUSR(nolign-1)-"/"-[M:PRO1]OSUSR(nolign-1)
# Déconnecter après transaction
If GACTION="ORAPRO4"
OK = 1 : Call OUINON(mess(221,100,1)+TXT,OK) From GESECRAN
Else
OK = 1 : Call OUINON(mess(222,100,1)+TXT,OK) From GESECRAN
Endif
If OK<>2
    FIN=1
Endif
Return

####################
$INIT_DIA45
Local Char TXT (255)
TXT=":"-num$([M:PRO1]SID(nolign-1))-"/"-[M:PRO1]DBUSR(nolign-1)-"/"-[M:PRO1]OSUSR(nolign-1)
If GACTION="ORAPRO4"
# Déconnecter après transaction
[M:PRO4]TXT1=mess(221,100,1)+TXT
Else
# Déconnecter immédiat
[M:PRO4]TXT1=mess(222,100,1)+TXT
Endif

[M:PRO4]TXT2=space$(30)+mess(224,100,1)
[M:PRO4]QST=mess(225,100,1)
#[M:PRO4]USR="SYSTEM"
# voir ici a recup authenfication login
# Récupération du passwd authenfication login
# jira X3-86047 86048 86049
Local Integer ERRDOS
Call PASSWD("database.software.sqlsystemlogin",[M:PRO4]USR,ERRDOS) From DOSBASE

Return


####################
$EXEC45
Local Integer TYPKILL
If GACTION="ORAPRO4"
    # Déconnecter après transaction
    TYPKILL=2
Else
    # Déconnecter immédiat
    TYPKILL=3
Endif
Call TEMPON("") From GESECRAN
Call TUER_PRO1(TYPKILL,FIN)
Call TEMPOFF From GESECRAN
Return

####################
$TERMINE45
Gosub ACTUALISER
Return


####################
$INIT_DIA2
Local Integer J

[M:PRO2]SID=val(PARAM(1))
J=find([M:PRO2]SID,[M:PRO1]SID(0..[M:PRO1]NBPRO-1))
If J>0
    [M:PRO2]DBUSR=[M:PRO1]DBUSR(J-1)
    [M:PRO2]LASDAT=[M:PRO1]LASDAT(J-1)
    [M:PRO2]LASHOU=[M:PRO1]LASHOU(J-1)
    [M:PRO2]OSUSR=[M:PRO1]OSUSR(J-1)
    Call CHARGE_PRO2(FIN)
Endif
Return

####################
$OUVRE
If GTYPDBA<>1
    FIN=1
    Return
Endif
Return

####################
$EXEC_BATCH
#VPO 22/12/08 49736 rendre fonction batchable
If !GSERVEUR
    Return
Else
Local Mask ORAPRO0 [PRO0],ORAPRO1[PRO1],ORAPRO3[PRO3]
Endif
####################
$DEBUT
If GTYPDBA<>1
    Call ERREUR(mess(108,115,1)) From GESECRAN : # La base de données n'est pas oracle
    FIN=1
    Return
Endif

#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR
Call OUVRE_TRACE(mess(90,134,1)-mess(GTYPDBA,57,1)) From LECFIC
Endif


Raz [M:PRO0]
Raz [M:PRO1]
[M:PRO1]FLT=1
[M:PRO1]TRI=1
[M:PRO1]TYPTRI=1
Call VERS_ORA([M:PRO0]BDDNAM,[M:PRO0]VER,[M:PRO0]VERDES,FIN) From ORAPROP
If FIN : Return : Endif

#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE(func RDM("ORAPRO0","BDDNAM")-":"-[M:PRO0]BDDNAM,0) From GESECRAN
    Call ECR_TRACE(func RDM("ORAPRO0","VER")-":"-[M:PRO0]VER-[M:PRO0]VERDES,0) From GESECRAN
Endif

Gosub ACTUALISER
Return

####################
$FIN
#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR
Call FERME_TRACE From LECFIC
Endif
Return

####################
$BOUTON
Case BOUT
   When "A" : Gosub ACTUALISER
Endcase
Return

#########
$SETBOUT
Call VIREBOUT(CHMEN,"A") From GOBJET

#on affiche toujours Actualiser
CHMEN+="A"
CHBOU += "=" : # Raffraîchir

Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$RAF
$ACTUALISER
Call TEMPON("L") From GESECRAN
Call CHARGE_PRO1(FIN)
Call CHARGE_PRO3(FIN)
Affzo [M:PRO1]
Affzo [M:PRO3]
Call TEMPOFF From GESECRAN
Return

###################################################################################################
###################################################################################################
Subprog CHARGE_PRO1(ERR)
Variable Integer ERR

Local Char SQLREQ (200) (9)

Local Char SQLREQ1 (200)(2)
Local Integer TRI,TYPTRI,FLT

Raz SQLREQ
Raz SQLREQ1
SQLREQ1(0)="select DECODE(name,'CPU used by this session','1','session pga memory','2',"
SQLREQ1(0)+="'physical reads','3','session logical reads','4','parse count (hard)',5),"
SQLREQ1(0)+="to_char(statistic#) from V$STATNAME "
SQLREQ1(1) ="Where name in ('CPU used by this session','session pga memory','physical reads',"
SQLREQ1(1)+="'session logical reads','parse count (hard)') order by name"

Onerrgo ERR_SQL_PRO1_1

For (Char VNAME(3),Char VNUM(80)) From '3' Sql SQLREQ1 As [BZZ]
   Case [BZZ]VNAME
    When '1' : SQLREQ(2)=",(select t.value from V$SESSTAT t where t.sid=s.sid and t.statistic#='"+[BZZ]VNUM+"')"
    When '2' : SQLREQ(3)=",(select t.value from V$SESSTAT t where t.sid=s.sid and t.statistic#='"+[BZZ]VNUM+"')"
    When '3' : SQLREQ(4)=",(select t.value from V$SESSTAT t where t.sid=s.sid and t.statistic#='"+[BZZ]VNUM+"')"
    When '4' : SQLREQ(5)=",(select t.value from V$SESSTAT t where t.sid=s.sid and t.statistic#='"+[BZZ]VNUM+"')"
    When '5' : SQLREQ(6)=",(select t.value from V$SESSTAT t where t.sid=s.sid and t.statistic#='"+[BZZ]VNUM+"')"
   Endcase
Next
SQLREQ(0) = "select p.SPID,s.OSUSER,nvl(s.sid,0),s.USERNAME,s.MACHINE,"
SQLREQ(0) +="TO_CHAR(s.LOGON_TIME,'YYYYMMDD'),TO_CHAR(s.LOGON_TIME,'HH24:MI:SS'),s.STATUS,"
SQLREQ(0) +="DECODE(nvl(p.background,0),0,1,2),to_char(nvl(s.command, 0))"
SQLREQ(1) = ",s.program,to_char(s.serial#)"
SQLREQ(1) +=",to_char(SYSDATE - (s.last_call_et / 86400),'YYYYMMDD')"
SQLREQ(1) +=",to_char(SYSDATE - (s.last_call_et / 86400),'HH24:MI:SS')"
SQLREQ(7) = " From V$PROCESS p, V$SESSION s Where p.addr(+)=s.paddr and s.sid is not null "
If [M:PRO1]FLT=1
    SQLREQ(7) += "and s.USERNAME='"+nomap+"' "
Endif
Case [M:PRO1]TRI
    When 2: SQLREQ(8)="Order by s.USERNAME"
    When 3: SQLREQ(8)="Order by s.LOGON_TIME"
    When 4: SQLREQ(8)="Order by s.STATUS"
    When 5: SQLREQ(8)="Order by s.program"
    When 6: SQLREQ(8)="Order by s.OSUSER"
    When 7: SQLREQ(8)="Order by p.SPID"
    When 8: SQLREQ(8)="Order by s.MACHINE"
    When 9: SQLREQ(8)="Order by 15"
    When 10: SQLREQ(8)="Order by 16"
    When 11: SQLREQ(8)="Order by 17"
    When 12: SQLREQ(8)="Order by 18"
    When 13: SQLREQ(8)="Order by 19"
    When 14: SQLREQ(8)="Order by 9"
    When 15: SQLREQ(8)="Order by (SYSDATE - (s.last_call_et / 86400))"
    When Default: SQLREQ(8)="Order by s.sid"
Endcase
Case [M:PRO1]TYPTRI
    When 2: SQLREQ(8)-="DESC"
    When Default: SQLREQ(8)-="ASC"
Endcase
SQLREQ(8) += ",s.sid,program,p.username,s.username,SPID"
Onerrgo ERR_SQL_PRO1_2

FLT = [M:PRO1]FLT
TRI = [M:PRO1]TRI
TYPTRI = [M:PRO1]TYPTRI
Raz [M:PRO1]
[M:PRO1]FLT=FLT
[M:PRO1]TRI=TRI
[M:PRO1]TYPTRI=TYPTRI
nolign = 0

For (Char VSPID(20),Char VOSUSER(30),Integer VSID,Char VUSER(30),Char VMAC(70),
&  Char VLOGDAT(10),Char VLOGHEU(10),Char VSTA(10),
&  Integer VBCK,Char VCOM(20),Char VPROG(50),Char VSERIAL(20),
&  Char VLASDAT(10),Char VLASHEU(10),
&  Integer VCPU,Integer VPGAMEM,Integer VPHYREAD,Integer VLOGREAD,Integer VHPARSE) From '3' Sql
&  SQLREQ
&   As [BXX]
  If [BXX]VSID<>0
    # Issue 84811 - 2012-10-01 by VPO : nb de lignes dans les tableaux
    If nolign>=dim([M:PRO1]SID)
      Call ERREUR(mess(88,134,1)-mess(26,100,1)) From GESECRAN
      Break
    Endif
    nolign +=1
    [M:PRO1]OSPRO(nolign-1)=[BXX]VSPID
    [M:PRO1]OSUSR(nolign-1)=[BXX]VOSUSER
    [M:PRO1]SID(nolign-1)=[BXX]VSID
    [M:PRO1]DBUSR(nolign-1)=[BXX]VUSER
    [M:PRO1]MAC(nolign-1)=[BXX]VMAC
    [M:PRO1]LOGDAT(nolign-1)=format$("DZ<:YYYYMMDD",[BXX]VLOGDAT)
    [M:PRO1]LOGHOU(nolign-1)=[BXX]VLOGHEU
    [M:PRO1]LASDAT(nolign-1)=format$("DZ<:YYYYMMDD",[BXX]VLASDAT)
    [M:PRO1]LASHOU(nolign-1)=[BXX]VLASHEU
    [M:PRO1]STA(nolign-1)=[BXX]VSTA

    [M:PRO1]BCKGRD(nolign-1)=[BXX]VBCK
    [M:PRO1]APP(nolign-1)=[BXX]VPROG

    [M:PRO1]SERIAL(nolign-1)=[BXX]VSERIAL
    [M:PRO1]CPU(nolign-1)=[BXX]VCPU
    [M:PRO1]PGAMEM(nolign-1)=[BXX]VPGAMEM
    [M:PRO1]PHYREAD(nolign-1)=[BXX]VPHYREAD
    [M:PRO1]LOGREAD(nolign-1)=[BXX]VLOGREAD
    [M:PRO1]HPARSE(nolign-1)=[BXX]VHPARSE

    [M:PRO1]TYPSQL(nolign-1)=""
    Case val([BXX]VCOM)
        When   1:  [M:PRO1]TYPSQL(nolign-1)+='CREATE TABLE'
        When   2:  [M:PRO1]TYPSQL(nolign-1)+='INSERT'
        When   3:  [M:PRO1]TYPSQL(nolign-1)+='SELECT'
        When   4:  [M:PRO1]TYPSQL(nolign-1)+='CREATE CLUSTER'
        When   5:  [M:PRO1]TYPSQL(nolign-1)+='ALTER CLUSTER'
        When   6:  [M:PRO1]TYPSQL(nolign-1)+='UPDATE'
        When   7:  [M:PRO1]TYPSQL(nolign-1)+='DELETE'
        When   8:  [M:PRO1]TYPSQL(nolign-1)+='DROP CLUSTER'
        When   9:  [M:PRO1]TYPSQL(nolign-1)+='CREATE INDEX'
        When  10:  [M:PRO1]TYPSQL(nolign-1)+='DROP INDEX'
        When  11:  [M:PRO1]TYPSQL(nolign-1)+='ALTER INDEX'
        When  12:  [M:PRO1]TYPSQL(nolign-1)+='DROP TABLE'
        When  13:  [M:PRO1]TYPSQL(nolign-1)+='CREATE SEQUENCE'
        When  14:  [M:PRO1]TYPSQL(nolign-1)+='ALTER SEQUENCE'
        When  15:  [M:PRO1]TYPSQL(nolign-1)+='ALTER TABLE'
        When  16:  [M:PRO1]TYPSQL(nolign-1)+='DROP SEQUENCE'
        When  17:  [M:PRO1]TYPSQL(nolign-1)+='GRANT OBJECT'
        When  18:  [M:PRO1]TYPSQL(nolign-1)+='REVOKE OBJECT'
        When  19:  [M:PRO1]TYPSQL(nolign-1)+='CREATE SYNONYM'
        When  20:  [M:PRO1]TYPSQL(nolign-1)+='DROP SYNONYM'
        When  21:  [M:PRO1]TYPSQL(nolign-1)+='CREATE VIEW'
        When  22:  [M:PRO1]TYPSQL(nolign-1)+='DROP VIEW'
        When  23:  [M:PRO1]TYPSQL(nolign-1)+='VALIDATE INDEX'
        When  24:  [M:PRO1]TYPSQL(nolign-1)+='CREATE PROCEDURE'
        When  25:  [M:PRO1]TYPSQL(nolign-1)+='ALTER PROCEDURE'
        When  26:  [M:PRO1]TYPSQL(nolign-1)+='LOCK'
        When  27:  [M:PRO1]TYPSQL(nolign-1)+='NO-OP'
        When  28:  [M:PRO1]TYPSQL(nolign-1)+='RENAME'
        When  29:  [M:PRO1]TYPSQL(nolign-1)+='COMMENT'
        When  30:  [M:PRO1]TYPSQL(nolign-1)+='AUDIT OBJECT'
        When  31:  [M:PRO1]TYPSQL(nolign-1)+='NOAUDIT OBJECT'
        When  32:  [M:PRO1]TYPSQL(nolign-1)+='CREATE DATABASE LINK'
        When  33:  [M:PRO1]TYPSQL(nolign-1)+='DROP DATABASE LINK'
        When  34:  [M:PRO1]TYPSQL(nolign-1)+='CREATE DATABASE'
        When  35:  [M:PRO1]TYPSQL(nolign-1)+='ALTER DATABASE'
        When  36:  [M:PRO1]TYPSQL(nolign-1)+='CREATE ROLLBACK SEG'
        When  37:  [M:PRO1]TYPSQL(nolign-1)+='ALTER ROLLBACK SEG'
        When  38:  [M:PRO1]TYPSQL(nolign-1)+='DROP ROLLBACK SEG'
        When  39:  [M:PRO1]TYPSQL(nolign-1)+='CREATE TABLESPACE'
        When  40:  [M:PRO1]TYPSQL(nolign-1)+='ALTER TABLESPACE'
        When  41:  [M:PRO1]TYPSQL(nolign-1)+='DROP TABLESPACE'
        When  42:  [M:PRO1]TYPSQL(nolign-1)+='ALTER SESSION'
        When  43:  [M:PRO1]TYPSQL(nolign-1)+='ALTER USER'
        When  44:  [M:PRO1]TYPSQL(nolign-1)+='COMMIT'
        When  45:  [M:PRO1]TYPSQL(nolign-1)+='ROLLBACK'
        When  46:  [M:PRO1]TYPSQL(nolign-1)+='SAVEPOINT'
        When  47:  [M:PRO1]TYPSQL(nolign-1)+='PL/SQL EXECUTE'
        When  48:  [M:PRO1]TYPSQL(nolign-1)+='SET TRANSACTION'
        When  49:  [M:PRO1]TYPSQL(nolign-1)+='ALTER SYSTEM'
        When  50:  [M:PRO1]TYPSQL(nolign-1)+='EXPLAIN'
        When  51:  [M:PRO1]TYPSQL(nolign-1)+='CREATE USER'
        When  52:  [M:PRO1]TYPSQL(nolign-1)+='CREATE ROLE'
        When  53:  [M:PRO1]TYPSQL(nolign-1)+='DROP USER'
        When  54:  [M:PRO1]TYPSQL(nolign-1)+='DROP ROLE'
        When  55:  [M:PRO1]TYPSQL(nolign-1)+='SET ROLE'
        When  56:  [M:PRO1]TYPSQL(nolign-1)+='CREATE SCHEMA'
        When  57:  [M:PRO1]TYPSQL(nolign-1)+='CREATE CONTROL FILE'
        When  59:  [M:PRO1]TYPSQL(nolign-1)+='CREATE TRIGGER'
        When  60:  [M:PRO1]TYPSQL(nolign-1)+='ALTER TRIGGER'
        When  61:  [M:PRO1]TYPSQL(nolign-1)+='DROP TRIGGER'
        When  62:  [M:PRO1]TYPSQL(nolign-1)+='ANALYZE TABLE'
        When  63:  [M:PRO1]TYPSQL(nolign-1)+='ANALYZE INDEX'
        When  64:  [M:PRO1]TYPSQL(nolign-1)+='ANALYZE CLUSTER'
        When  65:  [M:PRO1]TYPSQL(nolign-1)+='CREATE PROFILE'
        When  66:  [M:PRO1]TYPSQL(nolign-1)+='DROP PROFILE'
        When  67:  [M:PRO1]TYPSQL(nolign-1)+='ALTER PROFILE'
        When  68:  [M:PRO1]TYPSQL(nolign-1)+='DROP PROCEDURE'
        When  70:  [M:PRO1]TYPSQL(nolign-1)+='ALTER RESOURCE COST'
        When  71:  [M:PRO1]TYPSQL(nolign-1)+='CREATE SNAPSHOT LOG'
        When  72:  [M:PRO1]TYPSQL(nolign-1)+='ALTER SNAPSHOT LOG'
        When  73:  [M:PRO1]TYPSQL(nolign-1)+='DROP SNAPSHOT LOG'
        When  74:  [M:PRO1]TYPSQL(nolign-1)+='CREATE SNAPSHOT'
        When  75:  [M:PRO1]TYPSQL(nolign-1)+='ALTER SNAPSHOT'
        When  76:  [M:PRO1]TYPSQL(nolign-1)+='DROP SNAPSHOT'
        When  77:  [M:PRO1]TYPSQL(nolign-1)+='CREATE TYPE'
        When  78:  [M:PRO1]TYPSQL(nolign-1)+='DROP TYPE'
        When  79:  [M:PRO1]TYPSQL(nolign-1)+='ALTER ROLE'
        When  80:  [M:PRO1]TYPSQL(nolign-1)+='ALTER TYPE'
        When  81:  [M:PRO1]TYPSQL(nolign-1)+='CREATE TYPE BODY'
        When  82:  [M:PRO1]TYPSQL(nolign-1)+='ALTER TYPE BODY'
        When  83:  [M:PRO1]TYPSQL(nolign-1)+='DROP TYPE BODY'
        When  84:  [M:PRO1]TYPSQL(nolign-1)+='DROP LIBRARY'
        When  85:  [M:PRO1]TYPSQL(nolign-1)+='TRUNCATE TABLE'
        When  86:  [M:PRO1]TYPSQL(nolign-1)+='TRUNCATE CLUSTER'
        When  91:  [M:PRO1]TYPSQL(nolign-1)+='CREATE FUNCTION'
        When  92:  [M:PRO1]TYPSQL(nolign-1)+='ALTER FUNCTION'
        When  93:  [M:PRO1]TYPSQL(nolign-1)+='DROP FUNCTION'
        When  94:  [M:PRO1]TYPSQL(nolign-1)+='CREATE PACKAGE'
        When  95:  [M:PRO1]TYPSQL(nolign-1)+='ALTER PACKAGE'
        When  96:  [M:PRO1]TYPSQL(nolign-1)+='DROP PACKAGE'
        When  97:  [M:PRO1]TYPSQL(nolign-1)+='CREATE PACKAGE BODY'
        When  98:  [M:PRO1]TYPSQL(nolign-1)+='ALTER PACKAGE BODY'
        When  99:  [M:PRO1]TYPSQL(nolign-1)+='DROP PACKAGE BODY'
        When 100:  [M:PRO1]TYPSQL(nolign-1)+='LOGON'
        When 101:  [M:PRO1]TYPSQL(nolign-1)+='LOGOFF'
        When 102:  [M:PRO1]TYPSQL(nolign-1)+='LOGOFF BY CLEANUP'
        When 103:  [M:PRO1]TYPSQL(nolign-1)+='SESSION REC'
        When 104:  [M:PRO1]TYPSQL(nolign-1)+='SYSTEM AUDIT'
        When 105:  [M:PRO1]TYPSQL(nolign-1)+='SYSTEM NOAUDIT'
        When 106:  [M:PRO1]TYPSQL(nolign-1)+='AUDIT DEFAULT'
        When 107:  [M:PRO1]TYPSQL(nolign-1)+='NOAUDIT DEFAULT'
        When 108:  [M:PRO1]TYPSQL(nolign-1)+='SYSTEM GRANT'
        When 109:  [M:PRO1]TYPSQL(nolign-1)+='SYSTEM REVOKE'
        When 110:  [M:PRO1]TYPSQL(nolign-1)+='CREATE PUBLIC SYNONYM'
        When 111:  [M:PRO1]TYPSQL(nolign-1)+='DROP PUBLIC SYNONYM'
        When 112:  [M:PRO1]TYPSQL(nolign-1)+='CREATE PUBLIC DATABASE LINK'
        When 113:  [M:PRO1]TYPSQL(nolign-1)+='DROP PUBLIC DATABASE LINK'
        When 114:  [M:PRO1]TYPSQL(nolign-1)+='GRANT ROLE'
        When 115:  [M:PRO1]TYPSQL(nolign-1)+='REVOKE ROLE'
        When 116:  [M:PRO1]TYPSQL(nolign-1)+='EXECUTE PROCEDURE'
        When 117:  [M:PRO1]TYPSQL(nolign-1)+='USER COMMENT'
        When 118:  [M:PRO1]TYPSQL(nolign-1)+='ENABLE TRIGGER'
        When 119:  [M:PRO1]TYPSQL(nolign-1)+='DISABLE TRIGGER'
        When 120:  [M:PRO1]TYPSQL(nolign-1)+='ENABLE ALL TRIGGERS'
        When 121:  [M:PRO1]TYPSQL(nolign-1)+='DISABLE ALL TRIGGERS'
        When 122:  [M:PRO1]TYPSQL(nolign-1)+='NETWORK ERROR'
        When 123:  [M:PRO1]TYPSQL(nolign-1)+='EXECUTE TYPE'
        When 157:  [M:PRO1]TYPSQL(nolign-1)+='CREATE DIRECTORY'
        When 158:  [M:PRO1]TYPSQL(nolign-1)+='DROP DIRECTORY'
        When 159:  [M:PRO1]TYPSQL(nolign-1)+='CREATE LIBRARY'
        When 160:  [M:PRO1]TYPSQL(nolign-1)+='CREATE JAVA'
        When 161:  [M:PRO1]TYPSQL(nolign-1)+='ALTER JAVA'
        When 162:  [M:PRO1]TYPSQL(nolign-1)+='DROP JAVA'
        When 163:  [M:PRO1]TYPSQL(nolign-1)+='CREATE OPERATOR'
        When 164:  [M:PRO1]TYPSQL(nolign-1)+='CREATE INDEXTYPE'
        When 165:  [M:PRO1]TYPSQL(nolign-1)+='DROP INDEXTYPE'
        When 167:  [M:PRO1]TYPSQL(nolign-1)+='DROP OPERATOR'
        When 168:  [M:PRO1]TYPSQL(nolign-1)+='ASSOCIATE STATISTICS'
        When 169:  [M:PRO1]TYPSQL(nolign-1)+='DISASSOCIATE STATISTICS'
        When 170:  [M:PRO1]TYPSQL(nolign-1)+='CALL METHOD'
        When 171:  [M:PRO1]TYPSQL(nolign-1)+='CREATE SUMMARY'
        When 172:  [M:PRO1]TYPSQL(nolign-1)+='ALTER SUMMARY'
        When 173:  [M:PRO1]TYPSQL(nolign-1)+='DROP SUMMARY'
        When 174:  [M:PRO1]TYPSQL(nolign-1)+='CREATE DIMENSION'
        When 175:  [M:PRO1]TYPSQL(nolign-1)+='ALTER DIMENSION'
        When 176:  [M:PRO1]TYPSQL(nolign-1)+='DROP DIMENSION'
        When 177:  [M:PRO1]TYPSQL(nolign-1)+='CREATE CONTEXT'
        When 178:  [M:PRO1]TYPSQL(nolign-1)+='DROP CONTEXT'
        When 179:  [M:PRO1]TYPSQL(nolign-1)+='ALTER OUTLINE'
        When 180:  [M:PRO1]TYPSQL(nolign-1)+='CREATE OUTLINE'
        When 181:  [M:PRO1]TYPSQL(nolign-1)+='DROP OUTLINE'
        When 182:  [M:PRO1]TYPSQL(nolign-1)+='UPDATE INDEXES'
        When 183:  [M:PRO1]TYPSQL(nolign-1)+='ALTER OPERATOR'
        When Default : [M:PRO1]TYPSQL(nolign-1)+='---------------'
    Endcase
    # VPO 05/05/06 ajout recherche texte pour avoir TYPSQL plus precis
    If [M:PRO1]TYPSQL(nolign-1)="" or [M:PRO1]TYPSQL(nolign-1)='---------------'
        Onerrgo ERR_SQL_PRO2
        Raz SQLREQ1
        SQLREQ1(0)  = "select UPPER(substr(TRIM(replace(replace(t.sql_text,CHR(10),' '),CHR(13),' ')),1,30))"
        SQLREQ1(0) -="from V$SQLTEXT_WITH_NEWLINES t,V$SESSION s"
        SQLREQ1(0) -="where t.address=s.sql_address and t.hash_value=s.sql_hash_value "
        SQLREQ1(1) = "and s.sid="+num$([BXX]VSID)
        SQLREQ1(1) -="and piece=0"

        For (Char VTXT(100)) From '3' Sql SQLREQ1 As [BZZ]
            J = instr(1,[BZZ]VTXT," ")
            If J
               [M:PRO1]TYPSQL(nolign-1) = left$([BZZ]VTXT,J-1)
            Else
               [M:PRO1]TYPSQL(nolign-1) = [BZZ]VTXT
            Endif
        Next
        Onerrgo ERR_SQL_PRO1_2
    Endif
  Endif
Next
[M:PRO1]NBPRO = nolign
Onerrgo

#VPO 22/12/08 49736 rendre fonction batchable
If GSERVEUR & [M:PRO1]NBPRO>0
    Call ECR_TRACE("",0) From GESECRAN

    Call ECR_TRACE(mess(90,134,1),0) From GESECRAN
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

    Call ECR_TRACE_F(format$("K:8X",func RDM("ORAPRO1","SID")),format$("K:20X",func RDM("ORAPRO1","DBUSR"))+" "+format$("K:30X",func RDM("ORAPRO1","OSUSR")),
& format$("K:20X",func RDM("ORAPRO1","LOGDAT")),format$("K:15X",func RDM("ORAPRO1","STA"))+" "+format$("K:30X",func RDM("ORAPRO1","APP")),
& "",
& 9,52,21,47,0,0) From GESECRAN
    Call ECR_TRACE_F(string$(8,"_"),string$(20,"_")+" "+string$(30,"_"),
& string$(20,"_"),string$(15,"_")+" "+string$(30,"_"),
& "",
& 9,52,21,47,0,0) From GESECRAN

    Call ECR_TRACE_F("",
& format$("K:20X",func RDM("ORAPRO1","LASDAT"))+" "+format$("K:30X",func RDM("ORAPRO1","TYPSQL")),
& "","","",
& 61,52,0,0,0,0) From GESECRAN
    Call ECR_TRACE_F("",
& string$(20,"_")+" "+string$(30,"_"),
& "","","",
& 61,52,0,0,0,0) From GESECRAN

    Call ECR_TRACE_F("",format$("K:20X",func RDM("ORAPRO1","OSPRO")),
& format$("K:15X",func RDM("ORAPRO1","BCKGRD"))+" "+format$("K:40X",func RDM("ORAPRO1","MAC")),
& "","",
& 61,21,57,0,0,0) From GESECRAN
    Call ECR_TRACE_F("",string$(20,"_"),
& string$(15,"_")+" "+string$(40,"_"),
& "","",
& 61,21,57,0,0,0) From GESECRAN

    Call ECR_TRACE_F("",
& format$("K:8X",func RDM("ORAPRO1","CPU"))+" "+format$("K:8X",func RDM("ORAPRO1","PGAMEM"))+" "+format$("K:8X",func RDM("ORAPRO1","PHYREAD")),
& format$("K:8X",func RDM("ORAPRO1","LOGREAD"))+" "+format$("K:8X",func RDM("ORAPRO1","HPARSE")),"","",
& 61,27,17,0,0,0) From GESECRAN
    Call ECR_TRACE_F("",
& string$(8,"_")+" "+string$(8,"_")+" "+string$(8,"_"),
& string$(8,"_")+" "+string$(8,"_"),"","",
& 61,27,18,0,0,0) From GESECRAN


    For I=0 To [M:PRO1]NBPRO-1

        Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN

        Call ECR_TRACE_F(format$("N:8",[M:PRO1]SID(I)),format$("K:20X",[M:PRO1]DBUSR(I))+" "+format$("K:30X",[M:PRO1]OSUSR(I)),
& format$("K:20X",format$("D:"+GFMDAT,[M:PRO1]LOGDAT(I))-[M:PRO1]LOGHOU(I)),format$("K:15X",[M:PRO1]STA(I))+" "+format$("K:30X",[M:PRO1]APP(I)),
& "",
& 9,52,21,47,0,0) From GESECRAN

        Call ECR_TRACE_F("",
& format$("K:20X",format$("D:"+GFMDAT,[M:PRO1]LASDAT(I))-[M:PRO1]LASHOU(I))+" "+format$("K:30X",[M:PRO1]TYPSQL(I)),
& "","","",
& 61,52,0,0,0,0) From GESECRAN

        Call ECR_TRACE_F("",format$("K:20X",[M:PRO1]OSPRO(I)),
& format$("K:15X",mess([M:PRO1]BCKGRD(I),1,1))+" "+format$("K:40X",[M:PRO1]MAC(I)),
& "","",
& 61,21,57,0,0,0) From GESECRAN

        Call ECR_TRACE_F("",
& format$("N:8",[M:PRO1]CPU(I))+" "+format$("N:8",[M:PRO1]PGAMEM(I))+" "+format$("N:8",[M:PRO1]PHYREAD(I)),
& format$("N:8",[M:PRO1]LOGREAD(I))+" "+format$("N:8",[M:PRO1]HPARSE(I)),"","",
& 61,27,18,0,0,0) From GESECRAN

    Next I
    Call ECR_TRACE_F(string$(160,"_"),"","","","",160,0,0,0,0,0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endif
End

