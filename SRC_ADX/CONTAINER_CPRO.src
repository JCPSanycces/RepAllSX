#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Container properties
#*!
$TCTRNUM_PROPAGATE
Local File TABCONTAINER[TCTR]
Read [TCTR]TCTR0=this.TCTRNUM
If fstat = [V]CST_AOK
  this.MAXWEI = [F:TCTR]MAXWEI
  this.USFVOL = [F:TCTR]USFVOL
  #MAE,Exi 110713
  this.DSPWEU    = [F:TCTR]WEU
  this.DSPVOU    = [F:TCTR]VOU
  #MAE,Fin Exi 110713
  # Issue 111256 US2
  this.TCTRVOL = [F:TCTR]TCTRVOL
  this.TARWEI = [F:TCTR]TARWEI
Endif
Return
#######################################################################################

