#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OTXC

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:15:29"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OTXC",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="TXC0;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "TXC"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 2
DESLIS(0) = "REFNUM+DOCCLA+CTRDAT+CTRNUM+ORDCLA"
If clalev([M:TXC0])=0 : Local Mask TXC0 [TXC0] : Endif
Gosub TIT
nolign = 1
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:AD1])=0 : Local file ADOVAL [AD1] : Endif
If clalev([F:AD2])=0 : Local file ADOVAL [AD2] : Endif
Link [HRTXC] With
& [AFF]AFF0~=[F:HRTXC]ETRFCY;GPROFIL;GUSRFCT,
& [FGR]FGR0=GGRPFCY;[F:HRTXC]ETRFCY,
& [ID]ID0=[F:HRTXC]REFNUM,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [ECT]ECT0=[F:HRTXC]REFNUM;[F:HRTXC]CTRNUM,
& [FCY]FCY0=[F:HRTXC]ETRFCY,
& [AD1]ADW0='*';[F:FCY]LEG;'TYPDOC',
& [AD2]ADW0='';'';'TYPDOC'
& As [HRTXC_]
& Order By Key TXC1
Return

$DEF_BOITE
Gosub HORODAT From WGOTXC
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OTXC" From GFONCTION At A_STAMP With A_WINDPREV Mask [TXC0]
&  Treebox [HRTXC_] GAU_CHE
&   [F:HRTXC]REFNUM-[F:ID]NAM-[F:ID]SRN Using "" Titled TITSEL(1) ,
&   string$(val([F:AD1]VALEUR)<>0,mess([F:HRTXC]DOCCLA,val([F:AD1]VALEUR),1))+ string$(val([F:AD1]VALEUR)=0 & val([F:AD2]VALEUR)<>0,mess([F:HRTXC]DOCCLA,val([F:AD2]VALEUR),1)) Using "K:10X" Titled TITSEL(2) ,
&   format$("D:MM[/]DD[/]YYYY",CTRDAT) Using "DZz:"+GFMDAT4 Titled TITSEL(3) ,
&   [F:HRTXC]CTRNUM Using "K:20X" Titled TITSEL(4) ,
&   [F:HRTXC]CODCLA
&   Titled ""
&  Listbox [HRTXC9] GAU_CHE9
&   [L]SAIRAP(1) = [F:HRTXC9]A_TAB1 Using "" Titled TITSEL9(1) ,
&   [L]SAIRAP(2) = [F:HRTXC9]A_TAB2 Using "K:10X" Titled TITSEL9(2) ,
&   [L]SAIRAP(3) = [F:HRTXC9]A_TAB3 Using "DZz:"+GFMDAT4 Titled TITSEL9(3)  ,
&   [L]SAIRAP(4) = [F:HRTXC9]A_TAB4 Using "K:20X" Titled TITSEL9(4)  ,
&   [L]SAIRAP(5) = [F:HRTXC9]A_TAB5 Using "K:10B" Titled TITSEL9(5) 
& As [TXC0]
Titled [TXC0] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOTXC
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OTXC" From GFONCTION At A_STAMP With A_WINDPREV Mask [TXC0]
& As [TXC0]
Titled [TXC0] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [TXC0] 
Return

$SAISIE_BOITE
Boxinp [TXC0] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [TXC0]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(5169,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITSEL(30)(1..5)
Call TEXTE(44921,TITSEL(1)) From OBJDIV
Call TEXTE(5169,TITSEL(2)) From OBJDIV
Call TEXTE(212,TITSEL(3)) From OBJDIV
Call TEXTE(5481,TITSEL(4)) From OBJDIV
Call TEXTE(5296,TITSEL(5)) From OBJDIV
Local Char TITSEL9(30)(1..5)
Call TEXTE(44921,TITSEL9(1)) From OBJDIV
Call TEXTE(5169,TITSEL9(2)) From OBJDIV
Call TEXTE(212,TITSEL9(3)) From OBJDIV
Call TEXTE(5481,TITSEL9(4)) From OBJDIV
Call TEXTE(5296,TITSEL9(5)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(5169,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [HRTXC_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order By Key TXC1
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [TXC0] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [TXC0] GAU_CHE
 Else
  Fillbox [TXC0] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [HRTXC_]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 2
SNSLIS = 1
LENLIS = 5
GAUTRELIS = 2
CLELISTE = "REFNUM;DOCCLA;CTRDAT;CTRNUM;ORDCLA"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [HRTXC_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Setlbox [TXC0] GAU_CHE
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [TXC0] GAU_CHE9
Endcase
Return

$SETORDER
Case currbox
Endcase
Return

$ENDORDER
Case currbox
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(1) = "TXC0"         : ABMSK(1)  = "TXC0"     : AMA(1) = 1
NBMASK = 1
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 1 : If clalev([M:TXC0])>0 : Default Mask [TXC0] : Endif
Endcase
Return

$TITMASK
Case MA
 When 1 : If clalev([M:TXC0])>0 : Gosub TITRES From W1TXC0 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:TXC0])>0 : Close Local Mask [TXC0] : Endif
Return

$RAZMASK
Case MA
 When 1 : If clalev([M:TXC0])>0 : Raz [M:TXC0] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 1 : If clalev([M:TXC0])>0 : Affzo [M:TXC0] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 1 : If clalev([M:TXC0])>0 : [F:HRTXC] = [M:TXC0] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 1 : If clalev([M:TXC0])>0 : [M:TXC0] = [F:HRTXC] : Endif
Endcase
Return

$GRISE_CLE
Grizo [TXC0]CTRNUM,REFNUM,CTRDAT,DOCCLA,CODCLA
Return

$DEGRISE_CLE
Actzo [TXC0]CTRNUM,REFNUM,CTRDAT,DOCCLA,CODCLA
Return

$BOUTON
STDBOUT = "ESAN09<>RILJMP"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


