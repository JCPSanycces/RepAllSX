#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## ACLA-CLASSE ## EDIPTC
# 2018-11-06 07:04:55 789

#-------------------------------------------------------#
$METHODS
$EVENTS
Case [L]AEVENT
 When "ADDLINE_AFTER"
  Case [L]CURPTH
   When "EPTD"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$namProParent","PTCCOD")
    this.PTCCOD = this.APARENT.PTCCOD
   When "EPTM"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("PTCCOD","$namProParent","PTCCOD")
    this.PTCCOD = this.APARENT.PTCCOD
   When Default
  Endcase
 When Default
Endcase
Return

#-------------------------------------------------------#
$PROPERTIES
Local Integer ALINE
Case [L]CURPRO
 When "PTCCOD" : Gosub PRO_PTCCOD
Endcase
Return

#-------------------------------------------------------#
$PRO_PTCCOD
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.EPTD)
   If this.EPTD([L]ALINE)<>null
    this.EPTD([L]ALINE).PTCCOD = this.PTCCOD
   Endif
  Next
  For ALINE=1 to maxtab(this.EPTM)
   If this.EPTM([L]ALINE)<>null
    this.EPTM([L]ALINE).PTCCOD = this.PTCCOD
   Endif
  Next
Endcase
Return



