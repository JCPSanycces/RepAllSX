#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Suppression des paramètres de niveaux législation dans un dossier mono-législation
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Suppression des paramètres de niveaux législation dans un dossier mono-législation") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub SUPVAL
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub SUPVAL
End

#-------------------#
$SUPVAL

Local Integer LEG
LEG = func AFNC.ACTIVDOS(DOSSIER,"LEG")
If LEG : Return : Endif

Local File =DOSSIER+".ADOVAL"   [ADW]

# Mise à jour de la table ADOVAL
Call ECR_TRACE(mess(81,125,1)-"ADOVAL:"-time$,0) From GESECRAN
Trbegin [ADW]
 For [ADW]ADW0 Where CMP="*"
  Delete [ADW] Curr
 Next
Commit

Close Local File [ADW]

Return
