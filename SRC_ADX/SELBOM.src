#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# Traitement SELBOM - Librairie d'actions de sélection tronc commun BOM #
#########################################################################
#######################################################
# Subprog SELBOM(ITM,ALT,TYP)  Sélection d'entete nomenclature
# Subprog CONTBOM(ITM,ALT,TYP)  Controle sur entete nomenclature (inutilisé)
################################################################
Local Char ITM(GLONITM)
Local Decimal ALT
Call SELBOM(ITM,ALT,2)
End

Subprog SELBOM(ITM,ALT,TYP)
Variable Char    ITM
Variable Decimal ALT   : # à ramener dans une zone écran
Value    Integer TYP

Local Integer RELIT
Onerrgo ERREUR From CONTROLE
If clalev([F:BOH])=0
 Local File BOM[BOH]
Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

GBOMALT(0) = ALT : # pour le filtre de SUBBODA

If TYP = 1
   Call SELNUM("BOD","A",ALT,"") From SELOBJ
Elsif TYP = 2
   Call SELNUM("BOD","B",ALT,"") From SELOBJ
Endif
If [F:BOH]ITMREF <> ""
 ITM = [F:BOH]ITMREF
 ALT = [F:BOH]BOMALT
Endif
Raz GBOMALT
End

Subprog CONTBOM(ITM,ALT,TYP)
Variable Char    ITM
Value    Decimal ALT
Value    Integer TYP

Local Integer RELIT
Onerrgo ERREUR From CONTROLE
If clalev([F:BOH])=0
 Local File BOM[BOH]
Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

#If TYP=1 OPTION = "A" : Else  OPTION = "B" : Endif
#Call CONTNUM("BOD",OPTION,ALT,ITM,mkstat) From CONTOBJ
Read [BOH]BOH0 = ITM;ALT;TYP
If fstat
  GMESSAGE = mess(23,100,1)
  mkstat = 2
Endif
End

