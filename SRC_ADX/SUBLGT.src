#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################################################################
# Modifications :
# -------------
#
# - GLE - 14.02.2013 - Fq 88093 : possibilité de mettre des zones indicés dans les regroupements
#                                 (fontionne avec une modification du masque FXDLGT1)
# - MDJ - 08.01.2013 - Fq 85123 : champ REQUETE sans délimiteurs
########################################################################################################################
Call OBJET("LGT",GBIDC1,GBIDC2) From GOBJET

######################################################################################
## Etiquette ajoutée par le superviseur (Objet LGT) 23/03/2012 11:16:06 (CBO)
######################################################################################
$ACTION

Case ACTION
    When "OUVRE"     :        Gosub OUVRE
    When "RAZCRE"    :        Gosub RAZCRE
    When "RAZDUP"    :        Gosub RAZDUP
    When "LIENS"     :        Gosub LIENS
    When "INICRE"    :        Gosub INICRE
    When "INIMOD"    :        Gosub INIMOD
    When "AFFMASK"   :        Gosub AFFMASK
    When Default
Endcase

Return
######################################################
$OUVRE
    If !clalev([F:ATZ])    :     Local File ATABZON [ATZ]   :    Endif
    If !clalev([F:ATY])    :     Local File ATYPE [ATY]     :    Endif
    If !clalev([F:ATX])    :     Local File ATEXTE [ATX]    :    Endif

    Local Decimal WDIMEMAX, WTYPTYP
    Local Char WDESI, WCHAMP, SV_EXP1(250)
    Local Integer SV_GCASSE


$OUVRE_ASEL

    If clalev([M:ASL])  :     Close Mask [M:ASL]       :    Endif
    If dim(PARAM) < 0   :     Local Char PARAM(30)(10) :    Endif
    If clalev([F:AOB])  :     Close File [F:AOB]       :    Endif
    If clalev([F:ATB])  :     Close File [F:ATB]       :    Endif
    If clalev([F:ATZ])  :     Close File [ATZ]         :    Endif
    If clalev([F:ATY])  :     Close File [ATY]         :    Endif
    If clalev([F:ACV])  :     Close File [ACV]         :    Endif

    PARAM(1) = "LOF"
    #=> Appel de l'init de l'onglet sélection supplémentaire (Traitement superviseur)
    Gosub OUVRE From ASELOBJ
    Gosub DEBUT From ASELOBJ

Return
######################################################
$CHG_ASEL

    If clalev([F:AOB])= 0    :  Local File AOBJET [AOB]    :    Endif
    If clalev([F:ATB])= 0  :  Local File ATABLE [ATB]    :    Endif
    If clalev([F:ATZ])= 0  :  Local File ATABZON [ATZ]   :    Endif
    If clalev([F:ATY])= 0  :  Local File ATYPE [ATY]     :    Endif
    If clalev([F:ACV])= 0  :  Local File ACTIV [ACV]     :    Endif

    If clalev([F:AOT])=0  : Local File AOBJTAB [AOT]  : Endif
    If clalev([F:ATX])=0  : Local File ATEXTE  [ATX]  : Endif
    If clalev([F:AOS])=0  : Local File AOBJSEL [AOS]  : Endif
    If clalev([F:AUS1])=0 : Local File AUTILIS [AUS1] : Endif
    If clalev([F:AGB])=0  : Local File AGLOBVAR [AGB] : Endif

    If PARAM(1)<>""
        Read [AOB]ABREV = PARAM(1)
        TABLE = [F:AOB]NOMFIC
    Else
        TABLE = PARAM(4)
    Endif
    Gosub PARMSK From ASELOBJ

Return
######################################################
$AFFMASK
    Gosub PARMSK From ASELOBJ
Return
######################################################
$LIENS
Local Integer I
    Local Char    WCHAR              : # Contient le champ de regroupement moins un éventuel indiçage FQ88093
    Local Integer NCHAR              : # Rang dans la chaine de la première parenthèse ouvrante       FQ88093

    Gosub CHG_ASEL
    I = 0
    [M:ASL]TBL1 = [F:AOB]NOMFIC
    [M:ASL]FLD1 = [F:LFG]FLD(I)
    Call LIRECHAMP("", [F:LFG]FLD(I), WDIMEMAX, WTYPTYP, WDESI)
    [M:ASL]DES1 = WDESI
    [M:ASL]OPE1 = [F:LFG]OPE(I)
    [M:ASL]VAL1 = [F:LFG]VALE(I)
    [M:ASL]VALI1 = [F:LFG]VALE(I)
    I += 1
    [M:ASL]ANDOR2 = [F:LFG]ANDOR(I)
    [M:ASL]TBL2 = [F:AOB]NOMFIC
    [M:ASL]FLD2 = [F:LFG]FLD(I)
    Call LIRECHAMP("", [F:LFG]FLD(I), WDIMEMAX, WTYPTYP, WDESI)
    [M:ASL]DES2 = WDESI
    [M:ASL]OPE2 = [F:LFG]OPE(I)
    [M:ASL]VAL2 = [F:LFG]VALE(I)
    [M:ASL]VALI2 = [F:LFG]VALE(I)
    I += 1
    [M:ASL]ANDOR3 = [F:LFG]ANDOR(I)
    [M:ASL]TBL3 = [F:AOB]NOMFIC
    [M:ASL]FLD3 = [F:LFG]FLD(I)
    Call LIRECHAMP("", [F:LFG]FLD(I), WDIMEMAX, WTYPTYP, WDESI)
    [M:ASL]DES3 = WDESI
    [M:ASL]OPE3 = [F:LFG]OPE(I)
    [M:ASL]VAL3 = [F:LFG]VALE(I)
    [M:ASL]VALI3 = [F:LFG]VALE(I)
    I += 1
    [M:ASL]ANDOR4 = [F:LFG]ANDOR(I)
    [M:ASL]TBL4 = [F:AOB]NOMFIC
    [M:ASL]FLD4 = [F:LFG]FLD(I)
    Call LIRECHAMP("", [F:LFG]FLD(I), WDIMEMAX, WTYPTYP, WDESI)
    [M:ASL]DES4 = WDESI
    [M:ASL]OPE4 = [F:LFG]OPE(I)
    [M:ASL]VAL4 = [F:LFG]VALE(I)
    [M:ASL]VALI4 = [F:LFG]VALE(I)
    I += 1
    [M:ASL]ANDOR5 = [F:LFG]ANDOR(I)
    [M:ASL]TBL5 = [F:AOB]NOMFIC
    [M:ASL]FLD5 = [F:LFG]FLD(I)
    Call LIRECHAMP("", [F:LFG]FLD(I), WDIMEMAX, WTYPTYP, WDESI)
    [M:ASL]DES5 = WDESI
    [M:ASL]OPE5 = [F:LFG]OPE(I)
    [M:ASL]VAL5 = [F:LFG]VALE(I)
    [M:ASL]VALI5 = [F:LFG]VALE(I)

    nolign = 1
    I = 0
    While I < 10
        If [F:LFG]CODZON(I) <> ""
            [M:LGT1]CODZON(nolign-1) = [F:LFG]CODZON(I)

            # FQ88093 : on enlève un éventuel indiçage pour le contrôle de la présence du champ dans la table
            NCHAR = instr(1,[M:LGT1]CODZON(nolign-1),"(")
            If NCHAR
              WCHAR = seg$([M:LGT1]CODZON(nolign-1), 1, NCHAR-1)
            Else
              WCHAR = [M:LGT1]CODZON(nolign-1)
            Endif

            #Call LIRECHAMP("", [F:LFG]CODZON(I), WDIMEMAX, WTYPTYP, WDESI) : # FQ88093
            Call LIRECHAMP("", WCHAR, WDIMEMAX, WTYPTYP, WDESI) : # FQ88093

            [M:LGT1]DESI(nolign-1) = WDESI
            nolign += 1
        Endif
        I += 1
    Wend
    [M:LGT1]NBCRIT = nolign-1
    Affzo [M:LGT1]NBCRIT

    # Il faut faire le remplissage et le grisage du tableau en deux fois sinon ça ne marche pas bien
    For nolign = 1 To [M:LGT1]NBCRIT
        If [M:LGT1]CODZON(nolign-1) = "CPY" or
&          [M:LGT1]CODZON(nolign-1) = "FCY" or
&          [M:LGT1]CODZON(nolign-1) = "ACT"
            Grizo [M:LGT1]CODZON(nolign-1)
        Else
            Actzo [M:LGT1]CODZON(nolign-1)
        Endif
    Next

Return
######################################################
$RAZCRE

    Gosub CHG_ASEL

    # création de 3 critères obligatoires (société, site et secteur TVA)
    nolign = 1
    [M:LGT1]CODZON(nolign - 1) =  "CPY"
    Call LIRECHAMP("LAYOUTFAS", [M:LGT1]CODZON(nolign-1), WDIMEMAX, WTYPTYP, WDESI)
    [M:LGT1]DESI(nolign-1)     = WDESI
    nolign += 1

    [M:LGT1]CODZON(nolign - 1) =  "FCY"
    Call LIRECHAMP("LAYOUTFAS", [M:LGT1]CODZON(nolign-1), WDIMEMAX, WTYPTYP, WDESI)
    [M:LGT1]DESI(nolign-1)     = WDESI
    nolign += 1

    [M:LGT1]CODZON(nolign - 1) =  "ACT"
    Call LIRECHAMP("LAYOUTFAS", [M:LGT1]CODZON(nolign-1), WDIMEMAX, WTYPTYP, WDESI)
    [M:LGT1]DESI(nolign-1)     = WDESI
    nolign += 1

    [M:LGT1]NBCRIT = nolign - 1
    Affzo [M:LGT1]

    # Il faut faire le remplissage et le grisage du tableau en deux fois sinon ça ne marche pas bien
    For nolign = 1 To [M:LGT1]NBCRIT
        If [M:LGT1]CODZON(nolign-1) = "CPY" or
&          [M:LGT1]CODZON(nolign-1) = "FCY" or
&          [M:LGT1]CODZON(nolign-1) = "ACT"
            Grizo [M:LGT1]CODZON(nolign-1)
            If [M:LGT1]CODZON(nolign-1) <> "ACT"
            Endif
        Else
            Actzo [M:LGT1]CODZON(nolign-1)
        Endif
    Next

Return
######################################################
$RAZDUP
Return
######################################################
$INIMOD
    Gosub INICRE
Return
######################################################
$INICRE
Local Integer I

    I = 0
    [F:LFG]FLD(I) = [M:ASL]FLD1
    [F:LFG]OPE(I) = [M:ASL]OPE1
    [F:LFG]VALE(I) = [M:ASL]VALI1
    I += 1
    [F:LFG]ANDOR(I) = [M:ASL]ANDOR2
    [F:LFG]FLD(I) = [M:ASL]FLD2
    [F:LFG]OPE(I) = [M:ASL]OPE2
    [F:LFG]VALE(I) = [M:ASL]VALI2
    I += 1
    [F:LFG]ANDOR(I) = [M:ASL]ANDOR3
    [F:LFG]FLD(I) = [M:ASL]FLD3
    [F:LFG]OPE(I) = [M:ASL]OPE3
    [F:LFG]VALE(I) = [M:ASL]VALI3
    I += 1
    [F:LFG]ANDOR(I) = [M:ASL]ANDOR4
    [F:LFG]FLD(I) = [M:ASL]FLD4
    [F:LFG]OPE(I) = [M:ASL]OPE4
    [F:LFG]VALE(I) = [M:ASL]VALI4
    I += 1
    [F:LFG]ANDOR(I) = [M:ASL]ANDOR5
    [F:LFG]FLD(I) = [M:ASL]FLD5
    [F:LFG]OPE(I) = [M:ASL]OPE5
    [F:LFG]VALE(I) = [M:ASL]VALI5

    For I = 0 To 4
        If [F:LFG]FLD(I) = ""
            [F:LFG]VALE(I) = ""
        Endif
    Next I

    SV_EXP1 = [M:ASL]EXP1
    SV_TBL1 = [M:ASL]TBL1
    Raz [M:ASL]EXP1
    #Gosub EXPRESSION From ASELOBJ
    Gosub EXPRESSION

    [F:LFG]REQUETE = [M]EXPRESSION
    [M:ASL]EXP1 = SV_EXP1
    [M:ASL]TBL1 = SV_TBL1
  #  Par défaut : "Modification réussie"
    GMODOK = G_OUI

    I = 0
    For nolign = 1 To [M:LGT1]NBCRIT
        [F:LFG]CODZON(I) = [M:LGT1]CODZON(nolign - 1)
        I += 1
    Next

    If !GOK :   Return :     Endif

Return
######################################################
Subprog LIRECHAMP(PTABLE, PCODZONE, RDIMEMAX, RTYPTYP, RDESI)
Value Char PTABLE, PCODZONE
Variable Decimal RDIMEMAX, RTYPTYP
Variable Char RDESI

Local Integer I

    If PTABLE = ""
        PTABLE = "LAYOUTFAS"
    Endif
    RDIMEMAX = 1
    RTYPTYP  = 0
    RDESI = ""

    If PCODZONE = "" :    End :     Endif
    Read [ATZ]CODZONE = PTABLE; PCODZONE
    If fstat  :   End :   Endif

    RDIMEMAX = [F:ATZ]DIME

    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If fstat
        RTYPTYP = [F:ATZ]CODTYP
    Else
        RTYPTYP = [F:ATY]TYPTYP
    Endif

    If left$(PCODZONE,  6) = "USRFLD"
        Call LECTEXTRA(RDESI, "FREFLD", PCODZONE, "1", GABZLCPY) From ATEXTRA
    Else
        Read [ATX]NUMERO = GLANGUE ; [F:ATZ]NOCOURT
        If fstat = 0
            RDESI = [F:ATX]TEXTE
        Endif
    Endif

    If RDESI = ""
        RDESI = PCODZONE
    Endif

End
######################################################
Subprog C_CODZON(VALEUR)
Variable Char    VALEUR()

    Local Decimal WDIMEMAX, WTYPTYP
    Local Char WDESI
    Local Char    WCHAR              : # Contient VALEUR moins un éventuel indiçage FQ88093
    Local Integer I

    # FQ88093 : on enlève un éventuel indiçage pour le contrôle de la présence du champ dans la table
    I = instr(1,VALEUR,"(")
    If I
      WCHAR = seg$(VALEUR, 1, I-1)
    Else
      WCHAR = VALEUR
    Endif

    #Call LIRECHAMP("", VALEUR, WDIMEMAX, WTYPTYP, WDESI) : # FQ88093
    Call LIRECHAMP("", WCHAR, WDIMEMAX, WTYPTYP, WDESI)
    [M:LGT1]DESI(nolign-1) = WDESI
    If WDESI = ""
        GMESSAGE = mess(41,100,1) : # Champ inexistant
        mkstat = 2
    Endif

    # verif qu'il ne soit pas déjà paramétré
    I = 0
    For I = 1 To [M:LGT1]NBCRIT
        If VALEUR = [M:LGT1]CODZON(I - 1) and I <> nolign
            GMESSAGE = mess(278,123,1)-mess(61,100,1)-num$(I) # Champ déjà existant ligne no xx
            mkstat = 2
            Break
        Endif
    Next

End
######################################################
Subprog AV_NBCRIT


    If [M:LGT1]CODZON(nolign-1) = "CPY" or
&          [M:LGT1]CODZON(nolign-1) = "FCY" or
&          [M:LGT1]CODZON(nolign-1) = "ACT"
        Disable 65 # suppression ligne
        Disable 73 # insertion ligne
    Else
        Enable 65 # suppression ligne
        Enable 73 # insertion ligne
    Endif

End
######################################################
$EXPRESSION

If dim([M]EXPRESSION)<0
 Local Integer XFLG
 Local Char    EXPRESSION(250)
Endif

XFLG = 0
EXPRESSION = ""
If [M]FLD1<>""
   #*Fq-85123 [M]TBL1=" "
   #*Fq-85123 on doit passer le nom de la table pour pouvoir récupérer le type de donnée lié au champ de la sélection
   [M]TBL1="LAYOUTFAS"
   [L]ABR=""
   Call ADDCRIT(EXPRESSION,[M]TBL1,[L]ABR,[M]FLD1,[M]OPE1,[M]VALI1,XFLG,[M]OBJ ) From ASELOBJ
   If [M]FLD2<>""
      #*Fq-85123 [M]TBL2=" "
      [M]TBL2="LAYOUTFAS"
      [L]ABR=""
      Call ADDETOU(EXPRESSION,[M]ANDOR2,[M]TBL2,[L]ABR,[M]FLD2,[M]OPE2,[M]VALI2,XFLG,[M]OBJ)  From ASELOBJ
      If [M]FLD3<>""
         #*Fq-85123[M]TBL3=" "
         [M]TBL3="LAYOUTFAS"
         [L]ABR=""
         Call ADDETOU(EXPRESSION,[M]ANDOR3,[M]TBL3,[L]ABR,[M]FLD3,[M]OPE3,[M]VALI3,XFLG,[M]OBJ)  From ASELOBJ
         If [M]FLD4<>""
            #*Fq-85123  [M]TBL4=" "
            [M]TBL4="LAYOUTFAS"
            [L]ABR=""
            Call ADDETOU(EXPRESSION,[M]ANDOR4,[M]TBL4,[L]ABR,[M]FLD4,[M]OPE4,[M]VALI4,XFLG,[M]OBJ)  From ASELOBJ
            If [M]FLD5<>""
               #*Fq-85123[M]TBL5=" "
               [M]TBL5="LAYOUTFAS"
               [L]ABR=""
               Call ADDETOU(EXPRESSION,[M]ANDOR5,[M]TBL5,[L]ABR,[M]FLD5,[M]OPE5,[M]VALI5,XFLG,[M]OBJ)  From ASELOBJ
               EXPRESSION += ")"
            Endif
            EXPRESSION += ")"
         Endif
         EXPRESSION += ")"
      Endif
      EXPRESSION += ")"
   Endif
Endif

If [M]EXP1<>""
   If EXPRESSION<>""
      EXPRESSION -= "&"
   Endif
   EXPRESSION -= "("+[M]EXP1+")"
Endif

Return
######################################################
