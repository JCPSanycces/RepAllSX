#<AdxTL>@(#)0.0.0.0 $Revision$
#JASMI - 2017-01-10 - START
########################################
#Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
#MIPEA - 2016-10-10 - X3PEOP-751 - START

  If func DIVPAYE.EXISTE_KXX("WTRTATSHIDE") : Call HIDE_ACTIVITYFIELDS From WTRTATSHIDE : Endif
  If func DIVPAYE.EXISTE_KXX("WTRTATSSHOW") : Call SHOW_LEGACTCALLS From WTRTATSSHOW : Endif

#show all SPECIFIC fields
  Gosub SHOW_ALL_SPECIFIC

#hide SPECIFIC fields
  Gosub HIDE_SPECIFIC

End

$SHOW_ALL_SPECIFIC
  If dim([M:DIA]FLGAED)>0 : Chgfmt [M:DIA]FLGAED  With "LA:1"  : Endif
  If dim([M:DIA]DNAYEA)>0 : Chgfmt [M:DIA]DNAYEA  With "K:4X"  : Endif
  If dim([M:DIA]N4DVER)>0 : Chgfmt [M:DIA]N4DVER  With "K:10X" : Endif

#reset block titles
  If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
  Local Integer WNUMLIBEL
  Read [F:AMKW]CODMSK = "TRTATS"

  WNUMLIBEL=[F:AMKW]TITBLOC(2)
  Chgtbk [M:DIA]15  With func AFNC.TEXTE(WNUMLIBEL)

Return

$HIDE_SPECIFIC
  If !func DIVPAYE.IS_KFR_LEG(GCURLEG)
  #hide block and contents
    Chgtbk [M:DIA]15      With ""

    If dim([M:DIA]FLGAED)>0 : Chgfmt [M:DIA]FLGAED  With "-LA:1"  : Raz [M:DIA]FLGAED : Endif
    If dim([M:DIA]DNAYEA)>0 : Chgfmt [M:DIA]DNAYEA  With "-K:4X"  : Raz [M:DIA]DNAYEA : Endif
    If dim([M:DIA]N4DVER)>0 : Chgfmt [M:DIA]N4DVER  With "-K:10X" : Raz [M:DIA]N4DVER : Endif
  Endif

Return
#JASMI - 2017-01-10 - END

