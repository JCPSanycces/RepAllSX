#**
#* Grisage si on vient des inscriptions ou des sessions
#*!
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()

  Call AV_CPY(VALEUR, "GESINS") From TOOLSVAR
  Call AV_CPY(VALEUR, "GESHRSES") From TOOLSVAR

  If GFONCTION="GESINS" Then
    Read [F:ID]ID0=[F:INS]REFNUM
    # FQ72351 - MABON 15/03/11 - On relit l'inscription, avant de ré-afficher la fenêtre de critères. Sinon,
    # si dans la simulation, on a modifié TRFTPS ou TRFREQ, les cases vont être décochées à tort
    Read [F:INS]INS0=[F:INS]STG;[F:INS]SES;[F:INS]REFNUM
    If [F:INS]TRFTPS=2 | [F:ID]FLGTPS<>2 Then : # Si le salarié n'est pas géré en temps, on ne peut pas le transférer dans la gestion des temps
      [M:DIA]FLGSTT=1 : Grizo [M:DIA]FLGSTT
    Endif
    If [F:INS]TRFREQ=2 Then
      [M:DIA]FLGHTT=1 : Grizo [M:DIA]FLGHTT
    Endif
  Endif
End

