  Call INIT_ZONE(VALEUR, "STGSTR") From TOOLSVAR
End

Subprog AS_SESEND(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "SESSTR") From TOOLSVAR
End

Subprog AS_DOMEND(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "DOMSTR") From TOOLSVAR
End

Subprog AS_THMEND(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "THMSTR") From TOOLSVAR
End

Subprog AS_TYPEND(VALEUR)
#ADNGO - 2017-07-05 - X3-29559 - START
#Variable Integer VALEUR
Variable Char VALEUR
#ADNGO - 2017-07-05 - X3-29559 - END
#ADNGO - 2017-07-05 - X3-29559 - START
  #Call INIT_ZONE_I(VALEUR, "TYPSTR") From TOOLSVAR
  Call INIT_ZONE(VALEUR, "TYPSTR") From TOOLSVAR
#ADNGO - 2017-07-05 - X3-29559 - END
End

#**#####################################################################################
#* Contrôle que la borne fin est supérieure à la borne début
#* et qu'elle est inférieure à la date du jour
#*!
Subprog C_DATEND(VALEUR)
Variable Date    VALEUR

  Call CTLDATV(VALEUR, [M:DIA]DATSTR) From CONTDIV
  If VALEUR>date$ Then
    GMESSAGE = mess(181,10717,1) : # La date doit être inférieure ou égale à la date du jour
    mkstat=2
  Endif
End

#**#####################################################################################
#* Contrôle que la borne début est inférieure à la date du jour
#*!
Subprog C_DATSTR(VALEUR)
Variable Date    VALEUR

  If VALEUR>date$ Then
    GMESSAGE = mess(181,10717,1) : # La date doit être inférieure ou égale à la date du jour
    mkstat=2
  Endif
End

#**#####################################################################################
#* Contrôle que la borne fin est supérieure à la borne début
#*!
Subprog C_CTRNUMEND(VALEUR)
Variable Char    VALEUR()

  Call C_CTRNUMEND(VALEUR) From TOOLSVAR
End

Subprog C_MATEND(VALEUR)
Variable Char    VALEUR()

  Call C_MATEND(VALEUR) From TOOLSVAR
End

Subprog C_STGEND(VALEUR)
Variable Char    VALEUR()

  # SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif

  Call C_STGEND(VALEUR) From TOOLSVAR
End

Subprog C_SESEND(VALEUR)
Variable Char    VALEUR()

  Call C_SESEND(VALEUR) From TOOLSVAR
End

Subprog C_DOMEND(VALEUR)
Variable Char    VALEUR()

  Call C_DOMEND(VALEUR) From TOOLSVAR
End

Subprog C_THMEND(VALEUR)
Variable Char    VALEUR()

  Call C_THMEND(VALEUR) From TOOLSVAR
End

Subprog C_TYPEND(VALEUR)
#ADNGO - 2017-07-05 - X3-29559 - START
#Variable Integer VALEUR
Variable Char VALEUR
#ADNGO - 2017-07-05 - X3-29559 - END
  Call C_TYPEND(VALEUR) From TOOLSVAR
End

