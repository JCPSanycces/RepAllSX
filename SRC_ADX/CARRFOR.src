#**
#* La date de demande doit être inférieure ou égale à la date du jour
#*
#* @param VALEUR
#*!
Subprog C_DEMDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR>date$ Then
    GMESSAGE = mess(181,10717,1) : # La date doit être inférieure ou égale à la date du jour
    mkstat=2
  Endif
End

#**
#* La date d'application doit être une date d'extraction
#*
#* @param VALEUR
#*!
Subprog C_DAT(VALEUR)
Variable Date    VALEUR

#  Call C_DAT(VALEUR) From TOOLSVAR
  If VALEUR<>[0/0/0] Then
    VALEUR=gdat$(1,month(VALEUR),year(VALEUR))
  Endif
End

Subprog AS_DATAPLEND(VALEUR)
Variable Date    VALEUR
#ADNGO - 2017-05-20 - START
  #** V7 : Waiting Time Mangement **#
#**  If [M:DIA]DAT<>[0/0/0] Then
#**    If clalev([F:PEO])=0 : Local File PERIOD [PEO] : Endif
#**    Filter [F:PEO] Where PYRDAT=[M:DIA]DAT and FCY=''
#**    If rowcount([F:PEO])=0 Then
#**      Filter [F:PEO] Where PYRDAT>=[M:DIA]DAT and FCY='' Order By PYRDAT
#**      Read [F:PEO] First
#**      If !fstat Then
#**        VALEUR=[F:PEO]PYRDAT
#**      Endif
#**      Filter [F:PEO]
#**    Endif
#**    Filter [F:PEO]
#**  Endif
#*!
  If [M:DIA]DAT<>[0/0/0] Then
    If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
#    Filter [F:HRPEOD] Where PYRDAT=[M:DIA]DAT and FCY=''
#    If rowcount([F:HRPEOD])=0 Then
#      Filter [F:HRPEOD] Where PYRDAT>=[M:DIA]DAT and FCY='' Order By PYRDAT
    Filter [F:HRPEOD] Where PYRDAT>=[M:DIA]DAT and PERCOD = [F:HRCTR]PERCOD  Order By PYRDAT
      Read [F:HRPEOD] First
      If !fstat Then
        VALEUR=[F:HRPEOD]PYRDAT
      Endif
      Filter [F:HRPEOD]
    Endif
    Filter [F:HRPEOD]
#  Endif
#ADNGO - 2017-05-20 - END
  fstat=0
End

Subprog C_DATAPLEND(VALEUR)
Variable Date    VALEUR

  Call C_DAT(VALEUR) From TOOLSVAR
End

