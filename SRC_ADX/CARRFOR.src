#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque HRARRFOR
# Création
#     MABON - 28/09/10 - EXI 66191 LOT 14
#              - Arrêté de formation
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
#     SEGAY - 23/02/11 bug 71824 Suppression des return dans CRE_REQ
# Modification :
#     SEGAY - 06/09/11 - FQ75536 - Nom-Prénom
#     MABOS - 26/07/13 - FQ81085 - US1833 - memo + modif "first entry" in the action
######################################################################################

$ACTION
#    When "INIT_DIA"   : Gosub INIT_DIA :#MABOS-26/07/13-FQ81085-US1833-mémo
# modify action depending on the type of the action
  Case ACTION
    When "INIT"       : Gosub INIT :#MABOS-26/07/13-FQ81085-US1833
    When "CONTROLE"   : Gosub CONTROLE
    When "BOUTON"     : Gosub BOUTON
    When "DEBUT"      : Gosub DEBUT
    When "OK"         : Gosub OK
    When "EXEC"       : Gosub EXEC
    When "FIN"        : Gosub FIN
  Endcase
Return

#**#####################################################################################
#*
#*!
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
#$INIT_DIA
$INIT
Local Mask LISINS [LINS]
Local Mask HRARRFOR [DIA]
Raz [M:DIA]
#end MABOS-26/07/13-FQ81085-US1833

  # Ouverture des tables utilisées
  If clalev([F:INS])=0    : Local File INSCRIPT      [INS]    : Endif
  If clalev([F:INJ])=0    : Local File INSJOU        [INJ]    : Endif
  If clalev([F:INJ2])=0   : Local File INSJOU        [INJ2]   : Endif
  If clalev([F:STG])=0    : Local File STAGE         [STG]    : Endif
  If clalev([F:HRSES])=0  : Local File SESSIONS      [HRSES]  : Endif
  If clalev([F:FCY])=0    : Local File FACILITY      [FCY]    : Endif
  If clalev([F:CPY])=0    : Local File COMPANY       [CPY]    : Endif
  #ADNGO - 2017-05-23 - START
#  If clalev([F:TIM])=0    : Local File TIMCOD        [TIM]    : Endif
#  If clalev([F:TIP])=0    : Local File TIMEMP        [TIP]    : Endif
   If clalev([F:TIM])=0    : Local File TIMCOD        [TIM]    : Endif
   If clalev([F:TIP])=0    : Local File TIMEMP        [TIP]    : Endif
  #ADNGO - 2017-05-23 - END
  #
  If clalev([F:HRPOA])=0  : Local File POPULA        [HRPOA]  : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR      [HRCTR]  : Endif
  If clalev([F:ID])=0     : Local File EMPLOID       [ID]     : Endif
  If clalev([F:AD])=0     : Local File EMPLOAD       [AD]     : Endif
  If clalev([F:CPT])=0    : Local File EMPLOCPT      [CPT]    : Endif
  If clalev([F:RIB])=0    : Local File EMPLORIB      [RIB]    : Endif
  If clalev([F:MED])=0    : Local File EMPLOMED      [MED]    : Endif
  #ADNGO - 2017-05-23 - START
  #If clalev([F:HRPEO])=0  : Local File HRPERIOD      [HRPEO]  : Endif
  If clalev([F:HRPEOD])=0  : Local File HRPEODET      [HRPEOD]  : Endif
  #ADNGO - 2017-05-23 - END
  If GPAYE Then
    If clalev([F:HRPPH])=0: Local File PPREQUESTH  [HRPPH]: Endif
    If clalev([F:HRPPD])=0: Local File PPREQUESTD  [HRPPD]: Endif
    If clalev([F:VEP])=0  : Local File VALEMP      [VEP]  : Endif
    If clalev([F:VEP2])=0 : Local File VALEMP      [VEP2] : Endif
    If clalev([F:PVR])=0  : Local File PARVAR      [PVR]  : Endif
  Endif
  # Tables utilisées dans le sous-pro GENERE du traitement TRTFOR
  If clalev([F:CPR])=0    : Local File EMPLOCTRCPT   [CPR]    : Endif
  If clalev([F:FCY])=0    : Local File FACILITY      [FCY]    : Endif

  #ADNGO - 2017-05-23 - START
  If clalev([F:HRSUS])=0 : Local File HRSYSUSED    [HRSUS] : Endif
  #ADNGO - 2017-05-23 - END

#  If clalev([F:VRA])=0  : Local File VARIA         [VRA]  : Endif
#  If clalev([F:NAT])=0  : Local File NATACTIV      [NAT]  : Endif
#  If clalev([F:AD])=0   : Local File EMPLOAD       [AD]   : Endif

#  If GTPS=1 Then
#    If clalev([F:TIG])=0 : Local File TIMREGUL [TIG] : Endif
#  Else
#    If clalev([F:TIG])=0 : Local File TIMEMP   [TIG] : Endif
#  Endif

  [M:DIA]DATSTR = gdat$(1, 1, year(date$))
  If GFONCTION="GESINS" Then
    Call CALC_CFY([F:INS]REFNUM, [F:INS]CTRNUM, [F:HRSES]STRDAT, [M:DIA]FCY, [M:DIA]CPY)
    If [M:DIA]CPY<>"" Then [M:DIA]ALLCPY=1 : Endif
    If [M:DIA]FCY<>"" Then [M:DIA]ALLFCY=1 : Endif

    Filter [F:HRCTR] Where REFNUM=[F:INS]REFNUM & CTRNUM=[F:INS]CTRNUM Order By CTRDAT Desc
    Read [F:HRCTR] First
    Filter [F:HRCTR]

    [M:DIA]DATSTR    = [F:HRSES]ENDDAT
    [M:DIA]DATEND    = [F:HRSES]ENDDAT

    [M:DIA]CTRNUMSTR = [F:INS]CTRNUM
    [M:DIA]CTRNUMEND = [F:INS]CTRNUM

    [M:DIA]MATSTR    = [F:INS]REFNUM
    [M:DIA]MATEND    = [F:INS]REFNUM
    [M:DIA]LEG = GCURLEG
    If [F:HRCTR]CLLCVT<>"" Then
      [M:DIA]ALLCLLCVT = 1
      [M:DIA]CLLCVT    = [F:HRCTR]CLLCVT
    Endif

    If [F:HRCTR]PROPRF<>"" Then
      [M:DIA]ALLPRF    = 1
      [M:DIA]PRF       = [F:HRCTR]PROPRF
    Endif

    If [F:HRCTR]ETRSRV<>"" Then
      [M:DIA]ALLSRV    = 1
      [M:DIA]SRV       = [F:HRCTR]ETRSRV
    Endif

    [M:DIA]STGSTR    = [F:INS]STG
    [M:DIA]STGEND    = [F:INS]STG

    [M:DIA]SESSTR    = [F:INS]SES
    [M:DIA]SESEND    = [F:INS]SES

    If [F:INS]STA=1 Then [M:DIA]STASAI=2 : [M:DIA]STAENC=1 : [M:DIA]STACONF=1 : [M:DIA]STACLO=1 Endif
    If [F:INS]STA=2 Then [M:DIA]STASAI=1 : [M:DIA]STAENC=2 : [M:DIA]STACONF=1 : [M:DIA]STACLO=1 Endif
    # FQ80921 - MABON 22/03/12 - Le menu local 459 a évolué
#    If [F:INS]STA=3 Then [M:DIA]STASAI=1 : [M:DIA]STAENC=1 : [M:DIA]STACONF=2 : [M:DIA]STACLO=1 Endif
#    If [F:INS]STA=4 Then [M:DIA]STASAI=1 : [M:DIA]STAENC=1 : [M:DIA]STACONF=1 : [M:DIA]STACLO=2 Endif
    If [F:INS]STA=5 Then [M:DIA]STASAI=1 : [M:DIA]STAENC=1 : [M:DIA]STACONF=2 : [M:DIA]STACLO=1 Endif
    If [F:INS]STA=6 Then [M:DIA]STASAI=1 : [M:DIA]STAENC=1 : [M:DIA]STACONF=1 : [M:DIA]STACLO=2 Endif
    # Fin MABON

    [M:DIA]DOMSTR    = [F:HRSES]DOM
    [M:DIA]DOMEND    = [F:HRSES]DOM

    [M:DIA]THMSTR    = [F:HRSES]THM
    [M:DIA]THMEND    = [F:HRSES]THM

    [M:DIA]TYPSTR    = [F:HRSES]TYPFRT
    [M:DIA]TYPEND    = [F:HRSES]TYPFRT
  Endif

  If GFONCTION="GESHRSES" Then
    [M:DIA]DATSTR = [M:HRSES1]STRDAT
    [M:DIA]DATEND = [M:HRSES1]ENDDAT

    [M:DIA]STGSTR = [M:HRSES0]STG
    [M:DIA]STGEND = [M:HRSES0]STG

    [M:DIA]SESSTR = [M:HRSES0]COD
    [M:DIA]SESEND = [M:HRSES0]COD

    [M:DIA]STASAI=1 : [M:DIA]STAENC=1 : [M:DIA]STACONF=1 : [M:DIA]STACLO=2

    [M:DIA]DOMSTR = [M:HRSES1]DOM
    [M:DIA]DOMEND = [M:HRSES1]DOM

    [M:DIA]THMSTR = [M:HRSES1]THM
    [M:DIA]THMEND = [M:HRSES1]THM

    [M:DIA]TYPSTR = [M:HRSES1]TYPFRT
    [M:DIA]TYPEND = [M:HRSES1]TYPFRT
  Endif

  #MABOS-26/07/13-FQ81085-US1833-mémo
  If !(GFONCTION="GESINS" | GFONCTION="GESHRSES" ) Then
    Call LECMEMO("STD","[M:DIA]","hrafo") From GMEMO
    Call AFF_MEMO From DIVPAYE

  Endif
  #end MABOS-FQ81085-US1833

  [M:DIA]DEMDAT = date$
  # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#  [M:DIA]DAT    = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
  If func DIVPAYE.INIPARUSR("DATPAY","","")<>[0/0/0] Then
    [M:DIA]DAT       = gdat$(1,month(func DIVPAYE.INIPARUSR("DATPAY","","")),year(func DIVPAYE.INIPARUSR("DATPAY","","")))
    [M:DIA]DATAPLEND = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
  Endif
  # Fin MABON
Return

#####################################
$CONTROLE
#MABOS-26/07/13-FQ81085-US1833 - modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "HRARRFOR"
  If [M:DIA]FLGSTT<>2 & [M:DIA]FLGHTT<>2 Then
    GMESSAGE = mess(157,10717,1) : # Vous devez cocher au moins l'une des deux cases Génération
    GERR=1 : SAI=1 : Return
  Endif

  If [M:DIA]STASAI<>2 & [M:DIA]STAENC<>2 & [M:DIA]STACONF<>2 & [M:DIA]STACLO<>2 Then
    GMESSAGE = mess(225,10717,1) : # Vous devez cocher au moins l'une des cases Statut
    GERR=1 : SAI=1 : Return
  Endif
Endcase
#end MABOS-26/07/13-FQ81085-US1833

If GSTATUT<>GSTAOK or OK=0 Then
  FIN = 1
Else
  TMP = 1
  TRA = 1
Endif

Return

#**
#* Dans le cadre du STT, le dispositif de formation correspond à une nature d'événement
#*
#* @param TYPFRT : dispositif de la session
#*!
Funprog CALC_TIM(TYPFRT)
#ADNGO -2017-05-23 - START
#Value Integer TYPFRT
Value Char TYPFRT
#Local Char    TIM
Local Char    TIM(GLONTPS)
#ADNGO -2017-05-23 - END
  # FQ72840 - MABON 31/03/11 - Les paramètres événements sont renommés
#  Case TYPFRT
#    When 1 : TIM=TIMPLNFOR
#    When 2 : TIM=TIMCIF
#    When 3 : TIM=TIMDIF
#    When 4 : TIM=TIMALT
#    When 5 : TIM=TIMCTRPRO
#    When 6 : TIM=TIMPERPRO
#    When 7 : TIM=TIMAUTRE
#    When 8 : TIM=TIMCIFCDD
#    When 9 : TIM=TIMNONDEF
#  Endcase
#ADNGO -2017-05-23 - START
#  Case TYPFRT
#    When 1 : TIM=TIM1
#    When 2 : TIM=TIM2
#    When 3 : TIM=TIM3
#    When 4 : TIM=TIM4
#    When 5 : TIM=TIM5
#    When 6 : TIM=TIM6
#    When 7 : TIM=TIM7
#    When 8 : TIM=TIM8
#    When 9 : TIM=TIM9
#  Endcase
#End TIM

If TYPFRT<>"" Then
   #ADNGO - 2017-07-05 - X3-29559 - START
   #Read [F:HRSUS]HRSUS0=GDOSLEG(1);TYPFRT
   Read [F:HRSUS]HRSUS0=GCURLEG;TYPFRT
   #ADNGO - 2017-07-05 - X3-29559 - END
   If !fstat Then
     TIM=[F:HRSUS]TIMSUS
   Endif
Endif
  fstat=0
End TIM
#ADNGO -2017-05-23 - END
#**
#* Recherche du site et de la société relatifs au contrat
#*
#* @param MAT    : matricule
#* @param CTR    : n° de contrat
#* @param STRDAT : date début de session
#*!
Subprog CALC_CFY(MAT, CTR, STRDAT, FCY, CPY)
Value    Char MAT, CTR
Value    Date STRDAT
Variable Char FCY, CPY

  # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#  Filter [F:HRCTR] Where REFNUM=MAT and CTRNUM=CTR and CTRDAT<=STRDAT Order By CTRDAT Desc
  Filter [F:HRCTR] Where REFNUM=MAT and CTRNUM=CTR and (CTRDAT<=STRDAT | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=STRDAT)) Order By CTRDAT Desc
  Read [F:HRCTR] First
  If !fstat Then
    FCY = [F:HRCTR]ETRFCY
  Else
    Read [F:ID]ID0=MAT
    If !fstat Then
      FCY = [F:ID]FCY
    Endif
  Endif
  Filter [F:HRCTR]

  Call LECTURE("FCY", FCY, "") From CONTOBJ
  If !fstat Then CPY = [F:FCY]LEGCPY : Endif
  fstat=0
End

#**
#* Calcul de la date de paie dans TIMREGUL
#*
#* @param WFCY : site
#* @param MAT  : matricule
#*!
#ADNGO - 2017-05-23 - START
#Funprog CALC_PYRDAT(WFCY, MAT, CRITDAT)
Funprog CALC_PYRDAT(CTRPERCOD, MAT, CRITDAT)
#ADNGO - 2017-05-23 - END
#ADNGO - 2017-05-23 - START
#Value Char    WFCY(), MAT(), CRITDAT()
Value Char    CTRPERCOD(), MAT(), CRITDAT()
#ADNGO - 2017-05-23 - END
Local Date    PYRDAT
  #ADNGO - 2017-05-23 - START
  #Call PERIO(WFCY, MAT) From SUBHRPEO
  #ADNGO - 2017-05-23 - END
#ADNGO - 2017-05-20 - START
  #** V7 : Waiting Time Mangement **#
#**  Filter [HRPEO] Where FCY=WFCY & evalue(CRITDAT) Order By PYRDAT Desc
#**  If rowcount([F:HRPEO])>0 Then
#**    Read [F:HRPEO] First
#**  Else
#**    Filter [HRPEO] Where FCY="" & evalue(CRITDAT) Order By PYRDAT Desc
#**    Read [F:HRPEO] First
#**  Endif
#**  If !fstat Then
#**    PYRDAT = [F:HRPEO]PYRDAT
#**  Else
#**    fstat=0
#**  Endif
#**  Filter [HRPEO]
#*!
  #ADNGO - 2017-05-23 - START
  #Filter [HRPEOD] Where FCY=WFCY & evalue(CRITDAT) Order By PYRDAT Desc
  Filter [HRPEOD] Where PERCOD=CTRPERCOD & evalue(CRITDAT) Order By PYRDAT Desc
  #ADNGO - 2017-05-23 - END
  If rowcount([F:HRPEOD])>0 Then
    Read [F:HRPEOD] First
  #ADNGO - 2017-05-23 - START
#  Else
#    Filter [HRPEOD] Where FCY="" & evalue(CRITDAT) Order By PYRDAT Desc
#    Read [F:HRPEOD] First
  #ADNGO - 2017-05-23 - END
  Endif
  If !fstat Then
      PYRDAT = [F:HRPEOD]PYRDAT
  Else
    fstat=0
  Endif
  Filter [HRPEOD]
#ADNGO - 2017-05-20 - END
End PYRDAT

#**
#* Etiquette générique qui appelle le sous-pro FIND_REQNUM
#* Permet que le sous-pro CRE_REQ qui y fait référence puisse être appelé depuis un autre traitement, dans lequel
#* la recherche du numéro de bordereau pourra être surchargé
#*!
$FIND_REQ

  Call FIND_REQNUM(CRITTPS, WREFNUM, WREQNUM)
Return

#**
#* Recherche de l'enregistrement de HRPPH qui contient le bon numéro de bordereau
#*
#* @param CRITTPS : critère de temps, STT ou HTT
#* @param WREFNUM : matricule
#*!
Subprog FIND_REQNUM(CRITTPS, WREFNUM, WREQNUM)
Value    Integer CRITTPS
Variable Char    WREQNUM
Value    Char    WREFNUM
Local    Integer FOUND

  If rowcount([F:HRPPH])=1 Then
    Read [F:HRPPH] First
  Else
    # On a déjà généré les deux bordereaux, l'un pour le HTT, l'autre pour le STT.
    # Il faut donc retrouver le bordereau correspondant (soit STT, soit HTT suivant ce qu'on veut)
    FOUND=1
    For [F:HRPPH]
      If [F:HRPPH]CRITTPS=CRITTPS Then
        FOUND=2 : Break
      Endif
    Next
    # Si on ne l'a pas trouvé, c'est qu'on a déjà généré un bordereau pour le HTT et le STT dans la même session,
    # mais pour un autre salarié. Il faut donc retrouver le bordereau pour le salarié en cours
    If FOUND=1 Then
      For [F:HRPPH]
        Filter [F:HRPPD] Where REQNUM=[F:HRPPH]REQNUM
        For [F:HRPPD]
          If [F:HRPPD]REFNUM=WREFNUM Then
            FOUND=2 : Break 2
          Endif
        Next
        Filter [F:HRPPD]
      Next
      If FOUND=1 Then : # Si on ne l'a toujours pas trouvé, on prend le 1er
        Read [F:HRPPH] First
      Endif
    Endif
  Endif
  WREQNUM=[F:HRPPH]REQNUM
End

#**
#* Etiquette générique qui appelle le sous-pro CALC_VRACOD
#* Permet que le sous-pro CRE_REQ qui y fait référence puisse être appelé depuis un autre traitement, dans lequel
#* le calcul de la variable de paie pourra être surchargé
#*!
$CALC_VRA

  Call CALC_VRACOD(CRITTPS, WVRACOD)
Return

#**
#* Calcul de la variable de paie relative au dispositif de la formation et à la catégorie d'action
#*
#* @param CRITTPS : critère de temps, STT ou HTT
#* @param VRACOD  : variable de paie trouvée
#*!
Subprog CALC_VRACOD(CRITTPS, VRACOD)
Value    Integer CRITTPS
Variable Char    VRACOD
#ADNGO - 2017-05-23 - START
#Local    Integer TYPFRT, CATACN
Local    Char TYPFRT(GLONHRSUS), CATACN(GLONHRCAN)
#ADNGO - 2017-05-23 - END

  CATACN = [F:INS]DESCATACN
  TYPFRT = [F:TBD]TYPFRT
  VRACOD = ""
  #ADNGO - 2017-05-23 - START
  #If TYPFRT=0 Then TYPFRT=len(mess(0,10455,1)) : Endif
  #ADNGO - 2017-05-23 - END
  # FQ66382 - MABON 10/05/11 - Recherche de la variable de paie selon le niveau, dans l'ordre suivant :
  #   Contrat - Salarié - Profil - Service - Convention - Site - Société - Population - Dossier
#  Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS
  Filter [F:HRCTR] Where REFNUM=[F:INS]REFNUM & CTRNUM=[F:INS]CTRNUM Order By CTRDAT Desc
  Read [F:HRCTR] First
  Filter [F:HRCTR]
  If fstat Then
    Raz [F:HRCTR]
  Else
    Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
    If fstat Then Raz [F:FCY] : Endif
  Endif

  Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;6;"";"";"";"";"";[F:INS]CTRNUM;"";"";""             : # Niveau Contrat
  If fstat Then
    Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;5;"";"";"";"";[F:INS]REFNUM;"";"";"";""           : # Niveau Salarié
    If fstat Then
      Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;9;"";"";"";"";"";"";"";"";[F:HRCTR]PROPRF         : # Niveau Profil
      If fstat Then
        Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;7;"";"";"";"";"";"";[F:HRCTR]ETRSRV;"";""       : # Niveau Service
        If fstat Then
          Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;8;"";"";"";"";"";"";"";[F:HRCTR]CLLCVT;""     : # Niveau Convention collective
          If fstat Then
            Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;4;"";"";"";[F:HRCTR]ETRFCY;"";"";"";"";""   : # Niveau Site
            If fstat Then
              Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;3;"";"";[F:FCY]LEGCPY;"";"";"";"";"";"" : # Niveau Société
              If fstat Then
                Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;2;"";[M:DIA]POP;"";"";"";"";"";"";""  : # Niveau Population
                If fstat Then
                  Read [F:PVR]PVR0=TYPFRT;CATACN;CRITTPS;1;nomap;"";"";"";"";"";"";"";""     : # Niveau Dossier
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  # Fin MABON

  If !fstat Then
    VRACOD=[F:PVR]VRACOD
  Else
    VRACOD=""
    If !find([F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM+"~"+num$(TYPFRT)+"~"+num$(CATACN)+"~"+num$(CRITTPS), [M:LINS]KEYFRT) Then
      # Stage Session / Matricule : Correspondance Dispositif/ Action non définie
      Call ECR_TRACE(mess(33,10717,1)-[F:INS]STG-mess(34,10717,1)-[F:INS]SES-"/"-[F:INS]REFNUM-":"-mess(183,10717,1),0) From GESECRAN
      [M:LINS]KEYFRT(ILIG)=[F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM+"~"+num$(TYPFRT)+"~"+num$(CATACN)+"~"+num$(CRITTPS)
    Endif
  Endif
  fstat=0
End

#**
#* Etiquette générique qui appelle le sous-pro CALC_ACPAMT
#* Permet que le sous-pro CRE_REQ qui y fait référence puisse être appelé depuis un autre traitement, dans lequel
#* le calcul du montant du bordereau pourra être surchargé
#*!
$CALC_AMT

  Call CALC_ACPAMT(CRITTPS, ACPAMT)
Return

#**
#* Surcharge de l'étiquette CALC_CTRDAT appelée par CRE_REQ de TOOLSVAR
#*!
$CAL_CTRDAT

If GUSER='MABON' Dbgaff Endif
  Filter [F:INJ2] Where REFNUM=[F:INS]REFNUM & SES=[F:INS]SES
  Read [F:INJ2] Last
  Filter [F:INJ2]
  WCTRDAT=func TPSSTD.CALC_CTRDATDEF([F:INS]REFNUM,[F:INS]CTRNUM,[M:DIA]DATAPLEND,[M:DIA]DATAPLEND,[F:INJ2]DAT,1)
Return

#**
#* Calcul du montant du bordereau
#*
#* @param CRITTPS
#* @param ACPAMT
#*!
Subprog CALC_ACPAMT(CRITTPS, ACPAMT)
Value    Integer CRITTPS
Variable Decimal ACPAMT

  If CRITTPS=1 Then : # Si on est en STT, on récupère le nombre d'heures STT
    # FQ71989 - MABON 01/03/11 - Les montants doivent être positifs dans le bordereau
#    ACPAMT  = (-1)*[F:TBD]NBRHOUREA
    ACPAMT  = [F:TBD]NBRHOUREA
  Else              : # Si on est en HTT, on récupère le nombre d'heures HTT
    # FQ71989 - MABON 01/03/11 - Les montants doivent être positifs dans le bordereau
#    ACPAMT  = (-1)*[F:TBD]NBRHOUREA2
    ACPAMT  = [F:TBD]NBRHOUREA2
  Endif
End

#**
#* Détermine :
#*    - la nature d'événement TIM
#*    - si le jour de présence est sur le bulletin en cours ou non
#*    - la date de paie PYRDAT
#*
#* @param TYPFRT  : dispositif
#* @param WFCY    : site
#* @param REFNUM  : matricule salarié
#* @param TIM     : nature d'événement
#* @param BUL_ENC : flag bulletin en cours ou non
#* @param PYRDAT  : date de paie
#*!
Subprog CALC_TYP_INJ(TYPFRT, WFCY, REFNUM, TIM, BUL_ENC, PYRDAT)
#Value    Integer TYPFRT
Value    Char TYPFRT
Value    Char    WFCY, REFNUM
Variable Char    TIM
Variable Integer BUL_ENC
Variable Date    PYRDAT
Local    Char    CRITDAT(255)
Local    Date    DATREF

  #ADNGO - 2017-05-23 - START
  #If TYPFRT=0 Then TYPFRT=len(mess(0,10455,1)) : Endif
  #ADNGO - 2017-05-23 - END
  TIM = func CALC_TIM(TYPFRT) : # Le dispositif correspond à une nature d'événement
  If TIM<>"" Then
    #ADNGO - 2017-05-23 - START
    #Call LECTURE("TIM", TIM, "") From CONTOBJ
    Call LECTURE("HRTIM", TIM, GCURLEG) From CONTOBJ
    #ADNGO - 2017-05-23 - END
    If [F:TIM]MONDAC=1 Then : # L'événement a comme période de saisie "Extraction temps"
      CRITDAT = "[F:INJ]DAT>=PERSTR(0) & [F:INJ]DAT<=PEREND(0)"
    Else : # L'événement a comme période de saisie "Calendaire"
      CRITDAT = "[F:INJ]DAT>=PERSTR(0) & [F:INJ]DAT<=PEREND(1)"
    Endif
    BUL_ENC=1
    #ADNGO - 2017-05-23 - START
    #PYRDAT = func CALC_PYRDAT(WFCY, [F:INS]REFNUM, CRITDAT)
    PYRDAT = func CALC_PYRDAT([F:HRCTR]PERCOD, [F:INS]REFNUM, CRITDAT)
    #ADNGO - 2017-05-23 - END
    ##71976 : GMOIPAY is now in 'Common module'
    #If GPAYE Then
      DATREF=GMOIPAY
    #Else
    #  DATREF=gdat$(01,month(date$),year(date$))
    #Endif
    If PYRDAT>=DATREF Then BUL_ENC=2 : Endif
  Elsif !find([F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM+"~"+num$(TYPFRT), [M:LINS]KEYFRT) Then
    # Stage Session / Matricule : Correspondance Dispositif / Evénement non définie
    Call ECR_TRACE(mess(33,10717,1)-[F:INS]STG-mess(34,10717,1)-[F:INS]SES-"/"-[F:INS]REFNUM-":"-mess(185,10717,1),0) From GESECRAN
    [M:LINS]KEYFRT(ILIG)=[F:INS]STG+"~"+[F:INS]SES+"~"+[F:INS]REFNUM+"~"+num$(TYPFRT)
  Endif
End

#**
#* Maj des flags du suivi des temps
#*!
$MAJ_SUI_TPS

  If NBPCE & GPAYE Then
    #ADNGO - 2017-07-05 - X3-29559 - START
      Local Integer VEP_UNI
      [L]VEP_UNI=0
    #ADNGO - 2017-07-05 - X3-29559 - END
    # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#    Filter [VEP] Where EMP=[F:INS]REFNUM & PYRDAT=[M:DIA]DAT & CTRNUM=[F:INS]CTRNUM
    Filter [VEP] Where EMP=[F:INS]REFNUM & PYRDAT=[M:DIA]DATAPLEND & CTRNUM=[F:INS]CTRNUM
    # Fin MABON
    #ADNGO - 2017-07-05 - X3-29559 - START
    If rowcount([VEP])=1 Then
      [L]VEP_UNI=1
    Endif
    #ADNGO - 2017-07-05 - X3-29559 - END
    Read [VEP]VEP0 Last
    Filter [VEP]
    If !fstat Then
      #ADNGO - 2017-07-05 - X3-29559 - START
      If  [L]VEP_UNI
        Global Char GNUMBUL (GLONVCR)
        GNUMBUL=[F:VEP]BUL
      Endif
      #ADNGO - 2017-07-05 - X3-29559 - END
#      # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
##      Call MAJFLGTPS(MATRI,[M:DIA]DAT,CTR,1,1,[0/0/0]) From SUBVEP :# Génération auto
##      Call MAJFLGTPS(MATRI,[M:DIA]DAT,CTR,2,1,[0/0/0]) From SUBVEP :# Synthèse
##      Call MAJFLGTPS(MATRI,[M:DIA]DAT,CTR,3,1,[0/0/0]) From SUBVEP :# Maj variables
##      Call MAJFLGTPS(MATRI,[M:DIA]DAT,CTR,4,1,[0/0/0]) From SUBVEP :# Maj analytique
      Call MAJFLGTPS(MATRI,[M:DIA]DATAPLEND,CTR,1,1,[0/0/0]) From SUBVEP :# Génération auto
      Call MAJFLGTPS(MATRI,[M:DIA]DATAPLEND,CTR,2,1,[0/0/0]) From SUBVEP :# Synthèse
      Call MAJFLGTPS(MATRI,[M:DIA]DATAPLEND,CTR,3,1,[0/0/0]) From SUBVEP :# Maj variables
      Call MAJFLGTPS(MATRI,[M:DIA]DATAPLEND,CTR,4,1,[0/0/0]) From SUBVEP :# Maj analytique
#      # Fin MABON
      #ADNGO - 2017-07-05 - X3-29559 - START
      If  [L]VEP_UNI
         Kill GNUMBUL
      Endif
      #ADNGO - 2017-07-05 - X3-29559 - END
    Endif
    fstat=0
  Endif
Return

#**
#* Mise à jour des événements sur temps de travail
#*!
$MAJ_STT
# Variables utilisées dans TRTFOR
Local Integer OK, NBPCE, MITPS, CRESES
Local Decimal JOUR(1..2) , HEURE(1..2)
Local Decimal JPASS
Local Decimal HPASS
Local Decimal NBRDAY
Local Decimal NBRHOU
Local Date    DEBDAT, FINDAT
Local Decimal VALPAR
#
Local Date    PYRDAT, SAU_DAT
Local Integer BUL_ENC, NUMLIG, AUZCFY
#ADNGO - 2017-07-05 - X3-29559 - START
#Local Char    CRITDAT(255), MATRI, CTR, SAU_TIM
Local Char    CRITDAT(255), MATRI(GLONEML), CTR(GLONHRCTR), SAU_TIM(GLONTPS)
#ADNGO - 2017-07-05 - X3-29559 - END
Local Integer RET

  GOK=1
  # FQ82073 - MABON 31/01/13 - Initialisation de la date de début de période
#  SAU_TIM = ""        : SAU_DAT = [M:DIA]DAT
  SAU_TIM = ""        : SAU_DAT = [M:DIA]DATAPLEND
  # Fin MABON
  MATRI=[F:INS]REFNUM : CTR=[F:INS]CTRNUM

  # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#  Filter [HRCTR] Where [F:HRCTR]REFNUM=MATRI & [F:HRCTR]CTRNUM=CTR & [F:HRCTR]CTRDAT<=[M:DIA]DATEND
  Filter [HRCTR] Where [F:HRCTR]REFNUM=MATRI & [F:HRCTR]CTRNUM=CTR & ([F:HRCTR]CTRDAT<=[M:DIA]DATEND | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:DIA]DATEND))
  Read [HRCTR]CTR0 Last
  Filter [F:HRCTR]

  Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
  AUZCFY = func SUBHRSES.GET_AUZ([F:FCY]LEGCPY, [F:HRCTR]ETRFCY, "HRARRFOR")
  If AUZCFY=2 Then
    # Je suis obligée de faire deux boucles sur les jours de présence, car on peut avoir les deux gestions (Régularisation ou Bulletin),
    # et comme je fais une rupture par Matricule+session...
    For [F:INJ]INJ1(2) Where STG=[F:INS]STG & REFNUM=[F:INS]REFNUM & SES=[F:INS]SES
      Call CALC_TYP_INJ([F:INJ]TYPFRT, WFCY, [F:INS]REFNUM, TIM, BUL_ENC, PYRDAT)
      # FQ82073 - MABON 31/01/13 - Initialisation de la date de début de période
#      [M:DIA]DAT=PYRDAT
      [M:DIA]DATAPLEND=PYRDAT
      # Fin MABON
      If TIM<>"" Then
        For [INJ]INJ1
          Call CALC_TYP_INJ([F:INJ]TYPFRT, WFCY, [F:INS]REFNUM, TIM, BUL_ENC, PYRDAT)
          If BUL_ENC=2 Then : # Si le jour de présence est sur le mois en cours, on crée sur le bulletin en cours
            Gosub GENERE From TRTFOR
            If GOK=0 Then Call FSTA("TIP") From GLOCK : Break 2 : Endif
          Endif
          # FQ82073 - MABON 31/01/13 - Initialisation de la date de début de période
#          If [M:DIA]DAT<>PYRDAT Then
          If [M:DIA]DATAPLEND<>PYRDAT Then
          # Fin MABON
            Gosub MAJ_SUI_TPS
            # FQ82073 - MABON 31/01/13 - Initialisation de la date de début de période
#            [M:DIA]DAT=PYRDAT
            [M:DIA]DATAPLEND=PYRDAT
            # Fin MABON
          Endif
        Next
        If DEBDAT<>[0/0/0] Then
          If [F:STG]TYPSTG=2 Then FINDAT = [F:INJ]DATEND : Endif
          Gosub CRE_TPS From TRTFOR
        Endif
        Gosub MAJ_SUI_TPS
      Endif
    Next

    Filter [F:INJ] Where STG=[F:INS]STG & REFNUM=[F:INS]REFNUM & SES=[F:INS]SES Order By DAT
    For [F:INJ]
      Call CALC_TYP_INJ([F:INJ]TYPFRT, WFCY, MATRI, TIM, BUL_ENC, PYRDAT)
      If TIM<>"" Then
        If BUL_ENC=1 Then : # Si le jour de présence n'est pas sur le mois en cours, on crée une régularisation
          CRITDAT = "[F:INJ]DAT>=PERSTR(2) & [F:INJ]DAT<=PEREND(2)"
          #ADNGO - 2017-05-23 - START
          #PYRDAT  = func CALC_PYRDAT(WFCY, [F:INS]REFNUM, CRITDAT)
          PYRDAT  = func CALC_PYRDAT([HRCTR]PERCOD, [F:INS]REFNUM, CRITDAT)
          #ADNGO - 2017-05-23 - END
          If TIM<>SAU_TIM Then
            # FQ74044 - MABON 13/02/12 - Ajout vérification du nouveau champ FILTRE
            RET=0
            If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
              Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[F:INS]REFNUM,[F:INS]CTRNUM,RET) From DIVPAYE
              If RET>0 Then
                Call ECR_TRACE([F:INS]REFNUM-TIM-":"-mess(320,199,1)-TIM,0) From GESECRAN
              Endif
            Endif
            If !RET Then
            # Fin MABON
              If NUMLIG>0 Then
                # On ne peut pas faire un Read sur l'index TIG0 car si GTPS=0, TIG=TIMEMP où TIG0 n'existe pas
                # Read [F:TIG]TIG0=NUMLIG
                Filter [F:TIG] Where LIG=NUMLIG
                If rowcount([F:TIG])>0 Then
                  # xxx : Régularisation xx/xx/xx - xx/xx/xx
                  Read [F:TIG] First
                  Call ECR_TRACE(MATRI-":"-mess(10,10316,1)-SAU_TIM-format$("D:"+GFMDAT,[F:TIG]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIG]ENDDAT),0) From GESECRAN
                Endif
                Filter [F:TIG]
              Endif
              SAU_TIM=TIM
              Raz [F:TIG]
              [F:TIG]REFNUM  = [F:INS]REFNUM
              [F:TIG]CTRNUM  = [F:INS]CTRNUM
              # FQ82073 - MABON 31/01/13 - Initialisation de la date de début de période
              [F:TIG]CTRDAT = func TPSSTD.CALC_CTRDATDEF([F:INS]REFNUM,[F:INS]CTRNUM,[F:INJ]DAT,PYRDAT,[F:INJ]DAT,1)
              # Fin MABON
              [F:TIG]LIG     = uniqid([TIG])
              NUMLIG         = [F:TIG]LIG
              # FQ71989 - MABON 01/03/11 - Les montants doivent être positifs dans la régul
  #            [F:TIG]NBRDAY  = (-1)*[F:INJ]NBRDAYREA
  #            [F:TIG]NBRHOU  = (-1)*[F:INJ]NBRHOUREA
              [F:TIG]NBRDAY  = [F:INJ]NBRDAYREA
              [F:TIG]NBRHOU  = [F:INJ]NBRHOUREA
              [F:TIG]FLGBUL  = 2
              [F:TIG]STRDAT  = [F:INJ]DAT
              [F:TIG]ENDDAT  = [F:INJ]DAT
              [F:TIG]TIM     = TIM
              [F:TIG]DATPYR  = PYRDAT
              [F:TIG]CREDAT  = date$
              [F:TIG]CRETIM  = time
              [F:TIG]CREUSR  = GUSER
              If [M:DIA]SIMUL=1 Then
                Write [F:TIG]
              Endif
              If fstat Then GOK=0 : Call FSTA("TIG") From GLOCK : Break : Endif
            Endif
          Else
            # On ne peut pas faire un Read sur l'index TIG0 car si GTPS=0, TIG=TIMEMP où TIG0 n'existe pas
            # Read [F:TIG]TIG0=NUMLIG
            Filter [F:TIG] Where LIG=NUMLIG
            If rowcount([F:TIG])>0 Then
              Read [F:TIG] First
              # FQ71989 - MABON 01/03/11 - Les montants doivent être positifs dans la régul
#              [F:TIG]NBRDAY += (-1)*[F:INJ]NBRDAYREA
#              [F:TIG]NBRHOU += (-1)*[F:INJ]NBRHOUREA
              [F:TIG]NBRDAY += [F:INJ]NBRDAYREA
              [F:TIG]NBRHOU += [F:INJ]NBRHOUREA
              [F:TIG]ENDDAT  = [F:INJ]DAT
              [F:TIG]DATPYR  = PYRDAT
              [F:TIG]UPDDAT  = date$
              [F:TIG]UPDTIM  = time
              [F:TIG]UPDUSR  = GUSER
              If [M:DIA]SIMUL=1 Then
                Rewrite [F:TIG]
              Endif
              If fstat Then GOK=0 : Call FSTA("TIG") From GLOCK : Break : Endif
            Endif
            Filter [F:TIG]
          Endif
        Endif
      Endif
    Next
    If NUMLIG>0 Then
      # xxx : Régularisation xx/xx/xx - xx/xx/xx
      Call ECR_TRACE(MATRI-":"-mess(10,10316,1)-TIM-format$("D:"+GFMDAT,[F:TIG]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIG]ENDDAT),0) From GESECRAN
    Endif
    Filter [F:INJ]
    # FQ82073 - MABON 31/01/13 - Initialisation de la date de début de période
#    [M:DIA]DAT = SAU_DAT
    [M:DIA]DATAPLEND = SAU_DAT
    # Fin MABON

    # Mise à jour du flag "Transféré temps" de l'inscription
    If GOK Then
      [F:INS]TRFTPS=2
      If [M:DIA]SIMUL=1 Then
        Rewrite [F:INS]
      Endif
      If fstat Then
        GOK=0 : Call FSTA("INS") From GLOCK
      Else
        NBENREG_STT += 1
      Endif
    Endif
  Endif
Return

#**
#* Mise à jour des événements hors temps de travail
#*!
$MAJ_HTT
Local Integer NBD, AUZCFY
#ADNGO - 2017-07-05 - X3-29559 - START
#Local Char    WREQNUM
Local Char    WREQNUM(GLONVCR)
#ADNGO - 2017-07-05 - X3-29559 - END
Local Char    MESST(255), DESREQ(255)

  GOK=1

  # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#  Filter [HRCTR] Where [F:HRCTR]REFNUM=[F:INS]REFNUM & [F:HRCTR]CTRNUM=[F:INS]REFNUM & [F:HRCTR]CTRDAT<=[M:DIA]DATEND
  Filter [HRCTR] Where [F:HRCTR]REFNUM=[F:INS]REFNUM & [F:HRCTR]CTRNUM=[F:INS]REFNUM & ([F:HRCTR]CTRDAT<=[M:DIA]DATEND | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:DIA]DATEND))
  Read [HRCTR]CTR0 Last
  Filter [F:HRCTR]

  Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
  AUZCFY = func SUBHRSES.GET_AUZ([F:FCY]LEGCPY, [F:HRCTR]ETRFCY, "HRARRFOR")

  If AUZCFY=2 Then
    # On ne fait une régul que si :
    #   - on demande du HTT et il y a du HTT dans l'inscription
    #   - ou on demande du STT car c'est un Autre stage, et il y a du STT dans l'inscription
    If ([M:DIA]FLGHTT=2 & ([F:INS]NBRDAY2>0 | [F:INS]NBRHOUIPT2>0))
&    | ([M:DIA]FLGSTT=2 & ([F:INS]NBRDAY>0  | [F:INS]NBRHOUIPT>0) & [F:STG]TYPSTG=2)  Then
      # On cherche si le bordereau existe déjà, et on crée un nouveau bordereau :
      #   - s'il n'existe pas encore
      #   - ou si on change de session
      #   - ou si on traite le HTT et le STT séparément
  #    CRITERE = "SES_ENC<>'"+[F:HRSES]COD+"' | "+num$([M:DIA]FLGSTT)+"<>"+num$([M:DIA]FLGHTT)
      CRITERE = "SES_ENC<>'"+[F:HRSES]COD+"'"
      DESREQ  = mess(175,10717,1) : # Arrêté formation
      If [M:DIA]FLGSTT<>[M:DIA]FLGHTT Then
        If [M:DIA]FLGSTT=2 Then
          DESREQ -= mess(179,10717,1) : # pour le STT
        Else
          DESREQ -= mess(180,10717,1) : # pour le HTT
        Endif
      Endif
      # Création du borderau et de ses lignes
      # Le manager est en fait le REFNUM du user qui saisit l'arrêté de formation (donc variable globale GREFNUM
      # en paramètre de CRE_REQ)
      If clalev([F:TBD])=0 : Local File INSJOU [TBD] : Endif
      Filter [F:TBD] Where REFNUM=[F:INS]REFNUM & SES=[F:INS]SES
      # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#      Call CRE_REQ(GREFNUM, CODPVH, [M:DIA]DAT, evalue(CRITERE), WFCY, CRITTPS, DESREQ, [F:INS]REFNUM, [F:INS]CTRNUM, "CARRFOR", NBD, WREQNUM) From TOOLSVAR
      Call CRE_REQ(GREFNUM, CODPVH, [M:DIA]DAT, [M:DIA]DATAPLEND, evalue(CRITERE), WFCY, CRITTPS, DESREQ, [F:INS]REFNUM, [F:INS]CTRNUM, "CARRFOR", NBD, WREQNUM) From TOOLSVAR
      # Fin MABON
      Filter [F:TBD]
      SES_ENC=[F:HRSES]COD
    Endif

    If GOK & NBD>0 Then
      # Mise à jour du flag "Transféré temps" et du numéro de bordereau STT de l'inscription
      If CRITTPS=1 Then
        [F:INS]TRFTPS=2
        If WREQNUM<>"" Then
          [F:INS]REQNUMSTT=WREQNUM
          # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#          MESST = [F:INS]REFNUM-":"-mess(193,10702,1)-mess(179,10717,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT) : # Bordereau préparatoire pour le STT
          MESST = [F:INS]REFNUM-":"-mess(193,10702,1)-mess(179,10717,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT)-format$("D:"+GFMDAT,[M:DIA]DATAPLEND) : # Bordereau préparatoire pour le STT
          # Fin MABON
        Endif
      Endif
      # Mise à jour du flag "Transféré bordereau" et du numéro de bordereau HTT de l'inscription
      If CRITTPS=2 Then
        [F:INS]TRFREQ=2
        If WREQNUM<>"" Then
          [F:INS]REQNUMHTT=WREQNUM
          # FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#          MESST = [F:INS]REFNUM-":"-mess(193,10702,1)-mess(180,10717,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT)  : # Bordereau préparatoire pour le HTT
          MESST = [F:INS]REFNUM-":"-mess(193,10702,1)-mess(180,10717,1)-WREQNUM-format$("D:"+GFMDAT,[M:DIA]DAT)-format$("D:"+GFMDAT,[M:DIA]DATAPLEND)  : # Bordereau préparatoire pour le HTT
          # Fin MABON
        Endif
      Endif
      If [M:DIA]SIMUL=1 Then
        Rewrite [F:INS]
      Endif
      If fstat Then
        GOK=0 : Call FSTA("INS") From GLOCK
      Else
        If CRITTPS=1 Then NBENREG_STT += 1 : Endif
        If CRITTPS=2 Then NBENREG_HTT += 1 : Endif
        If WREQNUM<>"" Then
          # xxx : Bordereau préparatoire xxx xx/xx/xx
          Call ECR_TRACE(MESST,0) From GESECRAN
        Endif
      Endif
    Endif
  Endif
Return

#**
#* Boutons "Tout cocher" et "Tout décocher"
#*!
$BOUTON
#MABOS-26/07/13-FQ81085-US1833-mémo + modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "HRARRFOR"
    Case BOUT
      When "R" : Call AFF_MEMO From DIVPAYE    : # Button "Rappel MEMO"
    Endcase
  When "LISINS"
#end MABOS-26/07/13-FQ81085-US1833
    Case BOUT
      When "C" : For I=0 To [M:LINS]NBINS-1 : [M:LINS]SELFLG(I)=2 : Next
      When "D" : For I=0 To [M:LINS]NBINS-1 : [M:LINS]SELFLG(I)=1 : Next
    Endcase
    Affzo [M:LINS]
Endcase :#MABOS-26/07/13-FQ81085-US1833
Return


#**
#* Calcul des critères de sélection
#*!
$CALC_CRIT
Local Integer ONE_CRIT, I
Local Char    LIS_CPY(GLONCPY)(0..100)

  CRITAUT="1=1"
#  If [M:DIA]ALLCPY<>2       Then CRITAUT  -= "& WCPY='"+[M:DIA]CPY+"'"                                     : Endif
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITAUT -= "& find(WCPY,"
      For K=0 To I-1
        CRITAUT += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITAUT += "," : Endif
      Next
      CRITAUT += ")>0"
    Endif
  Endif
  If [M:DIA]ALLFCY<>2       Then CRITAUT  -= "& WFCY='"+[M:DIA]FCY+"'"                                     : Endif
  If [M:DIA]POP<>""         Then CRITAUT  -= "& [F:HRPOA]COD='"+[M:DIA]POP+"'"                               : Endif
  If [M:DIA]ALLSRV<>2       Then CRITAUT  -= "& [F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"                            : Endif
  If [M:DIA]ALLPRF<>2       Then CRITAUT  -= "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"                            : Endif
  If [M:DIA]CLLCVT<>""      Then CRITAUT  -= "& [F:HRCTR]CLLCVT='"+[M:DIA]CLLCVT+"'"                         : Endif

  CRITERE1 = "1=1"
  #ADNGO - 2017-05-23 - START
  #If [M:DIA]DATSTR<>[0/0/0] Then CRITERE1 -= "& [F:HRSES]ENDDAT>=["+format$("D:"+GFMDAT4,[M:DIA]DATSTR)+"]"  : Endif
  #If [M:DIA]DATEND<>[0/0/0] Then CRITERE1 -= "& [F:HRSES]ENDDAT<=["+format$("D:"+GFMDAT4,[M:DIA]DATEND)+"]"  : Endif
  If [M:DIA]DATSTR<>[0/0/0] Then CRITERE1 -= "& [F:HRSES]ENDDAT>=[M:DIA]DATSTR"  : Endif
  If [M:DIA]DATEND<>[0/0/0] Then CRITERE1 -= "& [F:HRSES]ENDDAT<=[M:DIA]DATEND"  : Endif
  #ADNGO - 2017-05-23 - END
  If [M:DIA]MATSTR<>""      Then CRITERE1 -= "& [F:INS]REFNUM>='"+[M:DIA]MATSTR+"'"                        : Endif
  If [M:DIA]MATEND<>""      Then CRITERE1 -= "& [F:INS]REFNUM<='"+[M:DIA]MATEND+"'"                        : Endif

  CRITERE3 = "1=1"
  If [M:DIA]STGSTR<>""      Then CRITERE3 -= "& [F:INS]STG>='"+[M:DIA]STGSTR+"'"                           : Endif
  If [M:DIA]STGEND<>""      Then CRITERE3 -= "& [F:INS]STG<='"+[M:DIA]STGEND+"'"                           : Endif
  If [M:DIA]SESSTR<>""      Then CRITERE3 -= "& [F:INS]SES>='"+[M:DIA]SESSTR+"'"                           : Endif
  If [M:DIA]SESEND<>""      Then CRITERE3 -= "& [F:INS]SES<='"+[M:DIA]SESEND+"'"                           : Endif

  CRITERE2 = "1=1"
  If find(2, [M:DIA]STASAI, [M:DIA]STAENC, [M:DIA]STACONF, [M:DIA]STACLO)>0 Then
    ONE_CRIT  = 1
    CRITERE2 -= "& find([F:INS]STA,"
    If [M:DIA]STASAI=2      Then ONE_CRIT=2 : CRITERE2 -= "1"                                              : Endif
    If [M:DIA]STAENC=2      Then If ONE_CRIT=2 Then CRITERE2 -= "," : Endif : ONE_CRIT=2 : CRITERE2 -= "2" : Endif
    # FQ80921 - MABON 22/03/12 - Le menu local 459 a évolué
#    If [M:DIA]STACONF=2     Then If ONE_CRIT=2 Then CRITERE2 -= "," : Endif : ONE_CRIT=2 : CRITERE2 -= "3" : Endif
#    If [M:DIA]STACLO=2      Then If ONE_CRIT=2 Then CRITERE2 -= "," : Endif : ONE_CRIT=2 : CRITERE2 -= "4" : Endif
    If [M:DIA]STACONF=2     Then If ONE_CRIT=2 Then CRITERE2 -= "," : Endif : ONE_CRIT=2 : CRITERE2 -= "5" : Endif
    If [M:DIA]STACLO=2      Then If ONE_CRIT=2 Then CRITERE2 -= "," : Endif : ONE_CRIT=2 : CRITERE2 -= "6" : Endif
    # Fin MABON
    CRITERE2 +=")>0"
  Endif
  If [M:DIA]DOMSTR<>""      Then CRITERE2 -= "& [F:HRSES]DOM>='"+[M:DIA]DOMSTR+"'"                           : Endif
  If [M:DIA]DOMEND<>""      Then CRITERE2 -= "& [F:HRSES]DOM<='"+[M:DIA]DOMEND+"'"                           : Endif
  If [M:DIA]THMSTR<>""      Then CRITERE2 -= "& [F:HRSES]THM>='"+[M:DIA]THMSTR+"'"                           : Endif
  If [M:DIA]THMEND<>""      Then CRITERE2 -= "& [F:HRSES]THM<='"+[M:DIA]THMEND+"'"                           : Endif
  #ADNGO - 2017-05-23 - START
  #If [M:DIA]TYPSTR>0        Then CRITERE2 -= "& [F:HRSES]TYPFRT>="+num$([M:DIA]TYPSTR)                       : Endif
  #If [M:DIA]TYPEND>0        Then CRITERE2 -= "& [F:HRSES]TYPFRT<="+num$([M:DIA]TYPEND)                       : Endif
  If [M:DIA]TYPSTR<>""      Then CRITERE2 -= "& [F:HRSES]TYPFRT>='"+[M:DIA]TYPSTR+"'"                        : Endif
  If [M:DIA]TYPEND<>""      Then CRITERE2 -= "& [F:HRSES]TYPFRT<='"+[M:DIA]TYPEND+"'"                        : Endif
  #ADNGO - 2017-05-23 - END
Return

#**
#* Affichage de la fenêtre de sélection des inscriptions
#*!
$DEBUT
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "HRARRFOR"
      Affzo [M:DIA]
      Setmok [M:DIA] With 0

  When "LISINS"
     #end MABOS-26/07/13-FQ81085-US1833-mémo
    Local Char    CRITERE1(250), CRITERE2(250), CRITERE3(250), CRITAUT(250)
    Local Char    WFCY([V]GLONFCY), WCPY([V]GLONCPY)
    Local Integer I, OKPAY

    Gosub CALC_CRIT
#    Link [F:INS] With [F:HRSES]SES0=[F:INS]SES As [IN_] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)
Link [F:INS] With [F:HRSES]SES0=[F:INS]SES As [IN_] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & [F:FCY]LEG=GCURLEG
&                   Order By [F:INS]SES
    I=0
    Raz [M:LINS]
    For [F:IN_]
      # Détermination des données relatives au matricule de l'inscription, afin d'évaluer CRITAUT
      Call CALC_CFY([F:INS]REFNUM, [F:INS]CTRNUM, [F:HRSES]STRDAT, WFCY, WCPY)
      Call LECTURE("STG", [F:INS]STG, "") From CONTOBJ
      # Lecture de la population pour alimenter [F:HRPOA] utilisé dans CRITAUT
      If [M:DIA]POP<>"" Then
        Read [F:HRPOA]POA0=[M:DIA]POP;[F:INS]REFNUM
        If fstat Then Raz [F:HRPOA] : Endif
      Endif
      # Lecture du contrat pour alimenter [F:HRCTR] utilisé dans CRITAUT
      Filter [F:HRCTR] Where REFNUM=[F:INS]REFNUM & CTRNUM=[F:INS]CTRNUM Order By CTRDAT Desc
      Read [F:HRCTR] First
      If fstat Then Raz [F:HRCTR] : Endif
      Filter [F:HRCTR]

      OKPAY=1
      If [M:DIA]CRI<>"" Then
        # Lecture des enregistrements des tables EMPLOxxx pour évaluation de [M:DIA]CRI
        Read [F:ID]ID0=[F:INS]REFNUM
        Read [F:AD]AD0=[F:INS]REFNUM
        Read [F:CPT]CPT0=[F:INS]REFNUM
        Filter [F:RIB] Where REFNUM=[F:INS]REFNUM
        Read [F:RIB] Last
        Filter [F:RIB]
        Filter [F:MED] Where REFNUM=[F:INS]REFNUM
        Read [F:MED] Last
        Filter [F:MED]
        Call CONTROLE([F:INS]REFNUM,[F:HRCTR]CTRDAT,[F:INS]CTRNUM,[M:DIA]CRI,OKPAY,0) From DIVPAYE
      Endif
      If OKPAY & evalue(CRITAUT)>0 Then
        If ([M:DIA]FLGSTT=2 & [F:INS]TRFTPS<>2 & ([F:STG]TYPSTG=1 | [F:INS]REQNUMSTT=""))
&      | ([M:DIA]FLGHTT=2 & [F:INS]REQNUMHTT="" & [F:INS]TRFREQ<>2) Then
          If I<dim([M:LINS]SELFLG) Then
            [M:LINS]SELFLG(I) = 2
            [M:LINS]STG(I)    = [F:INS]STG
            [M:LINS]SES(I)    = [F:INS]SES
            [M:LINS]REFNUM(I) = [F:INS]REFNUM
  #segay 06/09/11 75536
            Read [F:ID]ID0=[F:INS]REFNUM
            [M:LINS]NAM(I)    = [F:ID]NAM-[F:ID]SRN
  #END 06/09/11 75536
            [M:LINS]CTRNUM(I) = [F:INS]CTRNUM
            [M:LINS]STA(I)    = [F:INS]STA
            [M:LINS]KEYFRT(I) = ""

            Filter [F:INJ] Where REFNUM=[F:INS]REFNUM & SES=[F:INS]SES Order By DAT
            If rowcount([F:INJ])>0 Then
              Read [F:INJ] First : If !fstat Then [M:LINS]DATSTR(I) = [F:INJ]DAT : Endif
              If [F:STG]TYPSTG=2 Then
                [M:LINS]DATEND(I) = [F:INJ]DATEND
              Else
                Read [F:INJ] Last  : If !fstat Then [M:LINS]DATEND(I) = [F:INJ]DAT : Endif
              Endif
            Endif
            Filter [F:INJ]
            fstat=0

            I += 1
          Endif
        Endif
      Endif
    Next
    [M:LINS]NBINS=I
    Affzo [M:LINS]
Endcase  :#MABOS-26/07/13-FQ81085-US1833
Return



#**#####################################################################################
#* Exécution de l'action
#*!
$OK
#MABOS-26/07/13-FQ81085-US1833 - modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "LISINS"
    Local  Char    TIM
    # FQ72840 - MABON 31/03/11 - Les paramètres événements sont renommés
    #Global Char    TIMPLNFOR, TIMCIF, TIMDIF, TIMALT, TIMCTRPRO
    #Global Char    TIMPERPRO, TIMAUTRE, TIMCIFCDD, TIMNONDEF
    #ADNGO - 2017-05-23 - START
    #Global Char    TIM1, TIM2, TIM3, TIM4, TIM5, TIM6, TIM7, TIM8, TIM9
    #ADNGO - 2017-05-23 - END
    #ADNGO - 2017-07-05 - X3-29559 - START
    #Local  Char    CODPVH
    Local  Char    CODPVH(GLONPVH)
    #ADNGO - 2017-07-05 - X3-29559 - END
    Local  Char    SES_ENC(GLONHRSES)
    Local  Integer LOK, NBENREG_STT, NBENREG_HTT, CRITTPS
    Global Integer ILIG

    If !find(2, [M:LINS]SELFLG) Then
      Infbox mess(55,10717,1) : # Aucune inscription à traiter
      Return
    Endif

    If [M:DIA]SIMUL=1 Then
      Call OUINON(mess(191,10717,1), LOK) From GESECRAN : # Ce traitement est un traitement réel. Confirmez-vous ?
      If LOK = 1 Then Return : Endif
    Endif

    TIT=mess(178,10717,1) : # Arrêté de formation
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(TIT,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    #MABOS-22/04/13-FQ86015-US1531
    Call LIB_CRIT("[M:DIA]","HRARRFOR")From DIVPAYE
    If [M:DIA]SIMUL=2 Then
      Call ECR_TRACE(toupper(mess(27,107,1)),0) From GESECRAN : # SIMULATION
      Call ECR_TRACE("------------------------------------",0) From GESECRAN
    Endif
    #ADNGO - 2017-05-23 - START
    # Lecture des paramètres événements
#    If [M:DIA]FLGSTT=2 Then
#      Call PARAM( "", "EVT1", TIM1) From ADOVAL : # Dispositif Plan de formation
#      Call PARAM( "", "EVT2", TIM2) From ADOVAL : # Dispositif CIF
#      Call PARAM( "", "EVT3", TIM3) From ADOVAL : # Dispositif DIF
#      Call PARAM( "", "EVT4", TIM4) From ADOVAL : # Dispositif Alternance
#      Call PARAM( "", "EVT5", TIM5) From ADOVAL : # Dispositif Contrat professionnalisation
#      Call PARAM( "", "EVT6", TIM6) From ADOVAL : # Dispositif Période professionnalisation
#      Call PARAM( "", "EVT7", TIM7) From ADOVAL : # Dispositif Autre
#      Call PARAM( "", "EVT8", TIM8) From ADOVAL : # Dispositif CIF CDD
#      Call PARAM( "", "EVT9", TIM9) From ADOVAL : # Dispositif Non défini
#    Endif
    #ADNGO - 2017-05-23 - END
    # Récupération du code liste à utiliser pour le bordereau de formation
    Call PARAM(GCURLEG, "CODPVH", CODPVH) From ADOVAL
    SES_ENC=""

    If [M:LINS]NBINS>0 and find(2, [M:LINS]SELFLG)>0 Then
      GOK=1
      If GPAYE Then
  #      Trbegin [F:TIG], [F:TIP], [F:INS], [F:HRPPH], [F:HRPPD], [F:VEP2]
        Trbegin [F:INS], [F:HRPPH], [F:HRPPD], [F:VEP2]
      Else
  #      Trbegin [F:TIG], [F:TIP], [F:INS]
        Trbegin [F:INS]
      Endif
      For I=0 To [M:LINS]NBINS-1
        If [M:LINS]SELFLG(I)=2 Then
          ILIG = I
          # Relecture des enregistrements relatifs à la ligne en cours
          Call LECTURE("INS",   [M:LINS]REFNUM(I), [M:LINS]SES(I)) From CONTOBJ
          Call LECTURE("HRSES", [M:LINS]SES(I), "") From CONTOBJ
          Call LECTURE("STG",   [M:LINS]STG(I), "") From CONTOBJ

          # On ne peut générer un événement STT que si l'inscription n'a pas encore été transférée en saisie des temps
          # et que c'est un stage court

          If [M:DIA]FLGSTT=2 & [F:INS]TRFTPS<>2 & [F:STG]TYPSTG=1 Then
          #ADNGO - 2017-05-23 - START
  #          Gosub MAJ_STT : If GOK=0 Then Break : Endif
            Gosub MAJ_STT : If GOK=0 Then Break : Endif #This was commented out, on U9 the code is not commented out.
          #ADNGO - 2017-05-23 - END
          Endif

          # Dans le cadre des Autres stages, on génère forcément un bordereau,
          # si l'inscription n'a pas encore été transférée et n'a pas encore de n° de bordereau STT
          If [M:DIA]FLGSTT=2 & [F:INS]TRFTPS<>2 & [F:INS]REQNUMSTT="" & [F:STG]TYPSTG=2 Then
            CRITTPS = 1
            Gosub MAJ_HTT : If GOK=0 Then Break : Endif
          Endif

          # On ne peut générer un événement HTT que si l'inscription n'a pas encore été transférée, et
          # n'a pas encore de numéro de bordereau HTT
          If [M:DIA]FLGHTT=2 & [F:INS]TRFREQ<>2 & [F:INS]REQNUMHTT="" Then
            CRITTPS = 2
            Gosub MAJ_HTT : If GOK=0 Then Break : Endif
          Endif
        Endif
      Next

      If GOK Then
        If [M:DIA]SIMUL=1 Then
          Commit
        Else
          Rollback
        Endif
      Else
        Rollback
      Endif
    Endif

    # Gestion de la trace
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    If NBENREG_STT>0 | NBENREG_HTT>0 Then
      If NBENREG_STT>0 Then
        Call ECR_TRACE(mess(54,10717,1)-mess(179,10717,1)-":"-num$(NBENREG_STT),0) From GESECRAN : # Nombre d'inscriptions mises à jour pour le STT
      Endif
      If NBENREG_HTT>0 Then
        Call ECR_TRACE(mess(54,10717,1)-mess(180,10717,1)-":"-num$(NBENREG_HTT),0) From GESECRAN : # Nombre d'inscriptions mises à jour pour le HTT
      Endif
    Else
      Call ECR_TRACE(mess(55,10717,1),0) From GESECRAN : # Aucune inscription à traiter
    Endif
    Call FERME_TRACE From LECFIC
    # FQ72152 - MABON 08/03/11 - Lecture de la trace, sinon avec la nouvelle étiquette EXEC, on ne la voit pas
    Call LEC_TRACE From LECFIC
    GMESSAGE=""
Endcase :#MABOS-26/07/13-FQ81085-US1833
Return

# FQ72152 - MABON 07/03/11 - On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
# en réel après l'avoir lancé en simulation)
$EXEC
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "LISINS"
    SAI=1
Endcase
Return

$FIN
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "LISINS"
  If dim(ILIG)>0 Then Kill ILIG : Endif
  # FQ72840 - MABON 31/03/11 - Les paramètres événements sont renommés
#  If dim(TIMPLNFOR)>0 Then Kill TIMPLNFOR : Endif
#  If dim(TIMCIF)>0    Then Kill TIMCIF    : Endif
#  If dim(TIMDIF)>0    Then Kill TIMDIF    : Endif
#  If dim(TIMALT)>0    Then Kill TIMALT    : Endif
#  If dim(TIMCTRPRO)>0 Then Kill TIMCTRPRO : Endif
#  If dim(TIMPERPRO)>0 Then Kill TIMPERPRO : Endif
#  If dim(TIMAUTRE)>0  Then Kill TIMAUTRE  : Endif
#  If dim(TIMCIFCDD)>0 Then Kill TIMCIFCDD : Endif
#  If dim(TIMNONDEF)>0 Then Kill TIMNONDEF : Endif
#ADNGO - 2017-05-23 - START
#  If dim(TIM1)>0 Then Kill TIM1 : Endif
#  If dim(TIM2)>0 Then Kill TIM2 : Endif
#  If dim(TIM3)>0 Then Kill TIM3 : Endif
#  If dim(TIM4)>0 Then Kill TIM4 : Endif
#  If dim(TIM5)>0 Then Kill TIM5 : Endif
#  If dim(TIM6)>0 Then Kill TIM6 : Endif
#  If dim(TIM7)>0 Then Kill TIM7 : Endif
#  If dim(TIM8)>0 Then Kill TIM8 : Endif
#  If dim(TIM9)>0 Then Kill TIM9: Endif
#ADNGO - 2017-05-23 - END
Endcase

Return


########################################################################################
#                       GESTION DE L'ECRAN
########################################################################################

#**#####################################################################################
#* Initialisation de la borne fin par la borne début
#*!
Subprog AS_DATEND(VALEUR)
Variable Date    VALEUR

  Call INIT_ZONE_DA(VALEUR, "DATSTR") From TOOLSVAR
End

Subprog AS_CTRNUMEND(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "CTRNUMSTR") From TOOLSVAR
End

Subprog AS_MATEND(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "MATSTR") From TOOLSVAR
End

Subprog AS_STGEND(VALEUR)
