#<AdxTL>@(#)10.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

######################################

$ACTION
Case ACTION
 When "OUVRE"             : Gosub OUVRE
 When "SAISIE"            : Gosub SAISIE
 When "DESTINATION"       : Gosub DESTINATION
 When "EXEC"              : Gosub EXEC
 When "FIN"               : Gosub FIN
 When "IMPRIMANTE"        : Gosub IMPRIMANTE
 When "MESSAGERIE"        : Gosub MESSAGERIE
 When "FICHIER"           : Gosub FICHIER
 When "INIPAR"            : Gosub INIPAR
Endcase
Return

######################################
$OUVRE
Return

######################################
$SAISIE
If GISND = 1
    [M:RPT]IMPRIME = 1
Endif
If GISND = 2
    [M:RPT]IMPRIME = 3
Endif
If GISND = 3
    [M:RPT]IMPRIME = 2
Endif
OK = 0
Return

######################################
$DESTINATION
If GISND = 1
    [M:RPT]IMPRIME = 1
Endif
If GISND = 2
    [M:RPT]IMPRIME = 3
Endif
If GISND = 3
    [M:RPT]IMPRIME = 2
Endif
OK = 0
Return

######################################
$EXEC
Return

######################################
$FIN
Return

######################################
$IMPRIMANTE
If GISND = 3
    #"On imprime sur ActiveFax"
    Local Integer IN
    For IN = 1 To NBPAR
        If left$(PARAMETRE(IN),13)="_PrinterName="
           PARAMETRE(IN) = "_PrinterName="+chr$(1)+"ActiveFax"
           Break 
        Endif
    Next IN
    #PARAMETRE pour ne ouvrir la boite de dialogue
    NBPAR += 1
    PARAMETRE(NBPAR) = "_NoVisible="+chr$(1)+"1"
Endif
Return

######################################
$MESSAGERIE
PARAMETRE(1) = "_EMailToList="+chr$(1)+GSZMREWEB
PARAMETRE(2) = "_EMailCCList="+chr$(1)+""
PARAMETRE(3) = "_EMailSubject="+chr$(1)+GSZEMAOBC
PARAMETRE(4) = "_EMailMessage="+chr$(1)+GSZEMATEX
NBPAR = 4
OK = 0
Return

######################################
$FICHIER
NBPAR += 1
PARAMETRE(NBPAR) = "_FormatExport="+chr$(1)+num$(3)
OK = 0
Return

######################################
$INIPAR
Return
