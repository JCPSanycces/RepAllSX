#<AdxTL>@(#)1.0.0.0 $Revision$
###################################################
## Intégration d'une fonction
###################################################
$FONCTION
FICHIER = "AFONCTION" : ABR = "AFC"
Read [AFC]CODINT = NOMOBJ
# Gestion du numéro de fonction
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  If [F:AFC]CODINT<"X"
   Filter [AFC] Where NUMFNC<5000
   Read [AFC]NUMFNC Last
   Filter [AFC]
   If fstat>2
    Read [AFC]NUMFNC Last
   Endif
   If fstat>2 : NUMACT = 1 : Else : NUMACT = [F:AFC]NUMFNC+1 : Endif
  Else
   Read [AFC]NUMFNC Last
   If fstat>2 : NUMACT = 1 : Else : NUMACT = [F:AFC]NUMFNC+1 : Endif
  Endif
  Call CLEAN_GROUPS("[F:AFC]","CODPAR,VALPAR,ACTVAR,VALEUR,VARIA") From PATCH  #{X3-43086
  If NUMACT>=9001 & NUMACT<=9999
   NUMACT = 10000
  Endif
 Elsif dim([F:AFC]CODACT)>0 & [F:AFC]CODACT>="X" & !find([F:AFC]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Return
 Else
  NEWOBJ = 0
  NUMACT = [F:AFC]NUMFNC
  [F:AFC2] = [F:AFC]
  Call CLEAN_GROUPS("[F:AFC]","CODPAR,VALPAR,ACTVAR,VALEUR,VARIA") From PATCH  #{X3-43086
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_AFC
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_AFC
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Return

$TR_AFC
Local Integer AVR : AVR=0
Trbegin [AFC]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
      When "AFC"  : Gosub AFC1
      When "AVR"  : AVR=1 : Gosub AVR1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AFC",[F:AFC]CODINT,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
If AVR & [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AVR",num$(2),[F:AFC]CODINT,"C") From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return

$DEL_AFC
Trbegin [AFC]
 Delete [AFC] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AFONCTION"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AFC",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$AFC1
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If [L]ISFULLMOD<>2 : # U11 SCM
 [F:AFC]NUMFNC = NUMACT
Endif
MODOBJ = max(1,[F:AFC]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:AFC]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If dim(ISNEWFUN)>0 : ISNEWFUN+=1 : Endif   : # CC 12/09/2002 flag pour générer le profil après le patch
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  If dim([F:AFC]CREDAT)>0 : [F:AFC]CREDAT = date$ : Endif
  If dim([F:AFC]CREUSR)>0 : [F:AFC]CREUSR = GUSER : Endif
  If dim([F:AFC]CRETIM)>0 : [F:AFC]CRETIM = time  : Endif
  If dim([F:AFC]UPDDAT)>0 : [F:AFC]UPDDAT = date$ : Endif
  If dim([F:AFC]UPDUSR)>0 : [F:AFC]UPDUSR = GUSER : Endif
  If dim([F:AFC]UPDTIM)>0 : [F:AFC]UPDTIM = time  : Endif
 Endif
 Write [AFC]
Else
 For B=0 To [F:AFC2]NBOPT-1
  If [F:AFC2]ACTOPT(B)>="X" & !find([F:AFC2]ACTOPT(B),ACTIV(1..NBACT))
   L = find([F:AFC2]FLAG(B),[F:AFC]FLAG(0..[F:AFC]NBOPT-1))
   If !L
    [F:AFC]NBOPT += 1
    L = [F:AFC]NBOPT
   Endif
   [F:AFC]FLAG(L-1)   = [F:AFC2]FLAG(B)
   [F:AFC]ACTOPT(L-1) = [F:AFC2]ACTOPT(B)
   [F:AFC]OPTION(L-1) = [F:AFC2]OPTION(B)
   [F:AFC]FNCOPT(L-1) = [F:AFC2]FNCOPT(B)
  Endif
 Next B
 For B=0 To [F:AFC2]NBVAR-1
  If [F:AFC2]ACTVAR(B)>="X" & !find([F:AFC2]ACTVAR(B),ACTIV(1..NBACT))
   L = find([F:AFC2]VARIA(B),[F:AFC]VARIA(0..[F:AFC]NBVAR-1))
   If !L
    [F:AFC]NBVAR += 1
    L = [F:AFC]NBVAR
   Endif
   [F:AFC]ACTVAR(L-1) = [F:AFC2]ACTVAR(B)
   [F:AFC]VARIA(L-1)  = [F:AFC2]VARIA(B)
   [F:AFC]VALEUR(L-1) = [F:AFC2]VALEUR(B)
  Endif
 Next B
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  If dim([F:AFC]UPDDAT)>0 : [F:AFC]UPDDAT = date$ : Endif
  If dim([F:AFC]UPDUSR)>0 : [F:AFC]UPDUSR = GUSER : Endif
  If dim([F:AFC]UPDTIM)>0 : [F:AFC]UPDTIM = time  : Endif
 Endif
 Rewrite [AFC]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AFONCTION"-NOMOBJ : Return
Endif

If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
 Delete [AVR] Where TYP = 2 & FCT = NOMOBJ
 If fstat : GOK = 0 : ER = 99 : ERFIC = "AVARLOC"-NOMOBJ : Endif
Endif
If NEWOBJ
 If [F:AFC]TYPTRAIT<>2 and [F:AFC]FCYAUZ=2
  # Validation des fonctions
  Call ECR_TRACE("---"-mess(68,126,1)-"("+[F:AFC]CODINT+")",0) From GESECRAN
  Call VALCREFNC(APPLI,[F:AFC]CODINT,[F:AFC]TYP,[F:AFC]NBOPT,[F:AFC]FLAG)
 Endif
Elsif [F:AFC2]TYP<>[F:AFC]TYP or [F:AFC2]FCYAUZ<>[F:AFC]FCYAUZ or sum([F:AFC2]FLAG)<>sum([F:AFC]FLAG)
 # Validation des fonctions
 Call ECR_TRACE("---"-mess(68,126,1)-"("+[F:AFC]CODINT+")",0) From GESECRAN
 Call VALMODFNC(APPLI,[F:AFC]CODINT,[F:AFC]TYP,[F:AFC]FCYAUZ,[F:AFC]NBOPT,[F:AFC]FLAG
&                                  ,[F:AFC2]TYP,[F:AFC2]FCYAUZ,[F:AFC2]NBOPT,[F:AFC2]FLAG)
Endif
Return

$AVR1
FICHIER = "AVARLOC" : ABR = "AVR"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
 [F:AVR]UPDDAT = date$
 [F:AVR]UPDUSR = GUSER
 If dim([F:AVR]UPDTIM)>0 : [F:AVR]UPDTIM = time  : Endif
 [F:AVR]CREDAT = date$
 [F:AVR]CREUSR = GUSER
 If dim([F:AVR]CRETIM)>0 : [F:AVR]CRETIM = time  : Endif
Endif
Write [AVR]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AVARLOC"-[ARV]FCT : Return
Endif
Return

$ABORT
Rollback
Return

Subprog VALCREFNC(APPLI,FCT,TYP,NBR,OPT)
Value Char    APPLI , FCT
Value Integer TYP , NBR
Value Char    OPT()(0..)
Local File =APPLI+".AFCTFCY" [AFF], =APPLI+".AFCTFCT" [AFT], =APPLI+".FACILITY"  [FCY]
Call CREATIONFONCTION(FCT,TYP,NBR,OPT) From SUBAFP2
Close Local File
End

Subprog VALMODFNC(APPLI,FCT,TYP,AUZ,NBR,OPT,CURTYP,CURAUZ,CURNBR,CUROPT)
Value Char    APPLI , FCT
Value Integer TYP , AUZ , NBR
Value Char    OPT()(0..)
Value Integer CURTYP , CURAUZ , CURNBR
Value Char    CUROPT()(0..)
Local File =APPLI+".AFCTPRF"   [AFP1] , =APPLI+".AFCTFCY"   [AFF]
&        , =APPLI+".AFCTFCT"   [AFT]  , =APPLI+".FACILITY"  [FCY]
Call MODIFONCTION(FCT,TYP,AUZ,NBR,OPT,CURTYP,CURAUZ,CURNBR,CUROPT) From SUBAFP2
Close Local File
End

