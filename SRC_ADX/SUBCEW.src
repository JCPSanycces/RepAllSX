#<AdxTL>@(#)4.0.0.0 $Revision$
# Gestion du masque GENDEM
#     SEGAY - 03/07/13 - DEM 90783 : grisé des niveaux
######################################################################################

Raz [V]GPILOBJ, [V]GBIDC1, [V]GBIDC2, [V]GPILNAV, [V]GNBMASKOUV
#[V]GBIDC1 ="ASN200200000014"
Call OBJET("CEW",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
Case ACTION
 When "OUVRE"     : Gosub OUVRE

 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : [L]CHAINE+="A"
 When "INICRE"    : [F:CEW]UID=uniqid([CEW])
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
Endcase
Return

$OUVRE
If clalev([F:ID3])=0    : Local File EMPLOID  [ID3]   : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
Return

# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
$LIENS
Call INIT_LEV() # 90783
Call UPD_NAMSRN([M:CEW1]REFNUM,"[M:CEW1]","NAM","SRN",0,0) From DIVPAYE
Return

$VERIF_CRE
$VERIF_MOD
If ![M:CEW1]NBDEST
 [V]GMESSAGE=mess(178,123,1) : # Il doit y avoir au moins une ligne
 [L]OK      =0
Endif
Return
# 90783
Subprog INIT_LEV()
Local Integer WLEV
WLEV=0
If [CEW1]CPY <> ""
   WLEV=1
Elsif [CEW1]FCY <> ""
   WLEV=2
Elsif [CEW1]SRV <> ""
   WLEV=3
Elsif [CEW1]POP <> ""
   WLEV=4
Elsif [CEW1]REFNUM <> ""
   WLEV=5
Elsif [CEW1]CTRNUM <> ""
   WLEV=6
Endif
Call GRISE_LEV(WLEV)
End

# 90783
Subprog GRISE_LEV(VALEUR)
Value Integer VALEUR
Case VALEUR
 When 0
  Actzo [CEW1]CPY,FCY,SRV,POP,REFNUM,CTRNUM
 When 1
  Effzo [CEW1]FCY,SRV,POP,REFNUM,CTRNUM,ZFCY,ZSRV,ZPOP,NAM,SRN
  Grizo [CEW1]FCY,SRV,POP,REFNUM,CTRNUM
  Actzo [CEW1]CPY
 When 2
  Effzo [CEW1]CPY,SRV,POP,REFNUM,CTRNUM,ZCPY,ZSRV,ZPOP,NAM,SRN
  Grizo [CEW1]CPY,SRV,POP,REFNUM,CTRNUM
  Actzo [CEW1]FCY
 When 3
  Effzo [CEW1]CPY,FCY,POP,REFNUM,CTRNUM,ZCPY,ZFCY,ZPOP,NAM,SRN
  Grizo [CEW1]CPY,FCY,POP,REFNUM,CTRNUM
  Actzo [CEW1]SRV
 When 4
  Effzo [CEW1]CPY,FCY,SRV,REFNUM,CTRNUM,ZCPY,ZFCY,ZSRV,NAM,SRN
  Grizo [CEW1]CPY,FCY,SRV,REFNUM,CTRNUM
  Actzo [CEW1]POP
 When 5
  Effzo [CEW1]CPY,FCY,SRV,POP,CTRNUM,ZCPY,ZFCY,ZSRV,ZPOP
  Grizo [CEW1]CPY,FCY,SRV,POP,CTRNUM
  Actzo [CEW1]REFNUM
 When 6
  Effzo [CEW1]CPY,FCY,SRV,POP,REFNUM,ZCPY,ZFCY,ZSRV,ZPOP,NAM,SRN
  Grizo [CEW1]CPY,FCY,SRV,POP,REFNUM
Endcase
End

################################################################################
#
# Actions
#
################################################################################

Subprog CIRCUIT(NIVEAU,CLE,WRF,USR)
Value    Char    NIVEAU, CLE, WRF
Variable Char    USR()(0..)

Local Char    CPY([V]GLONCPY), FCY([V]GLONFCY), SRV([V]GLONSRV), REFNUM([V]GLONEML)
Local Char    CTRNUM([V]GLONHRCTR), CHEF([V]GLONEML)
Local Char    POP([V]GLONPOP)(0..500)
Local Libelle I
# 57258
Local Integer J

If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif

Case [L]NIVEAU
When "CTR"
 Local File EMPLOCTR [CTR1]
 Filter [CTR1] Where CTRNUM=[L]CLE & CTRDAT<=date$ Order By Key CLE=CTRDAT Desc
 Read [CTR1] First
 Filter [CTR1]
 [L]CTRNUM=[F:CTR1]CTRNUM
 [L]REFNUM=[F:CTR1]REFNUM
 [L]SRV   =[F:CTR1]ETRSRV
 [L]FCY   =[F:CTR1]ETRFCY
 Filter [HRPOA] Where REFNUM=[F:CTR1]REFNUM
When "MAT"
 If !clalev([F:ID]) | [F:ID]REFNUM<>[L]CLE
  Local File EMPLOID [ID]
  Read [ID]ID0=[L]CLE
 Endif
 [L]REFNUM=[F:ID]REFNUM
 [L]SRV   =[F:ID]SRV
 [L]FCY   =[F:ID]FCY
 Filter [HRPOA] Where REFNUM=[F:ID]REFNUM
When Default
 End
Endcase

[L]CPY=func DIVPAYE.GETSOC([L]FCY)

# 57258
J = 0
For [HRPOA]
 [L]POP(J)= [F:HRPOA]COD
 J +=1
Next
Filter [HRPOA]
# fin 57258

If !clalev([F:CEW]) : Local File CHEFWRK [CEW] : Endif

Filter [CEW] Where CODWRK=[L]WRF & find(CPY,[L]CPY,"")<>0 & find(FCY,[L]FCY,"")<>0
&                & find(SRV,[L]SRV,"")<>0 & find(REFNUM,[L]REFNUM,"")<>0
&                & find(CTRNUM,[L]CTRNUM,"")<>0 & find(POP,[L]POP(0..J),"")<>0
&     Order By Key CLE=CTRNUM Desc;REFNUM Desc;SRV Desc;FCY Desc;CPY Desc
Read [CEW]CLE First
Filter [CEW]
If fstat : End : Endif

If !clalev([F:ADU]) : Local File ADOVALAUS [ADU] : Endif

For I=0 To [F:CEW]NBDEST-1
 If [L]NIVEAU="CTR"
  [L]CHEF=[F:CTR1]CHEFCTR([F:CEW]RESPO(I)-1)
  Gosub ADDUSR
 Endif
 If [L]USR(I)=""
  If !clalev([F:AD]) | [F:AD]REFNUM<>[L]REFNUM
   Local File EMPLOAD [AD]
   Read [AD]AD0=[L]REFNUM
  Endif
  [L]CHEF=[F:AD]CHEF([F:CEW]RESPO(I)-1)
  Gosub ADDUSR
 Endif
 If [L]USR(I)=""
  If !clalev([F:SRV]) | [F:SRV]COD<>[L]SRV
   Local File SERVICE [SRV]
   Read [SRV]SRV0=[L]SRV
  Endif
  [L]CHEF=[F:SRV]CHEF([F:CEW]RESPO(I)-1)
  Gosub ADDUSR
 Endif
 If [L]USR(I)=""
  If !clalev([F:FCY]) | [F:FCY]FCY<>[L]FCY
   Local File FACILITY [FCY]
   Read [FCY]FCY0=[L]FCY
  Endif
  [L]CHEF=[F:FCY]CHEF([F:CEW]RESPO(I)-1)
  Gosub ADDUSR
 Endif
Next

End

#-------------------------------------------------------------------------------
$ADDUSR
If [L]CHEF="" : Return : Endif
Filter [ADU] Where PARAM="REFNUM" & VALEUR=[L]CHEF
Read [ADU]ADU1 First
Filter [ADU]
If !fstat : [L]USR(I)=[F:ADU]CODUSR : Endif
Return

################################################################################
#
# Etiquettes de l'écran CEW1
#
################################################################################

########################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
#If [L]VALEUR>"" : Effzo [CEW1] FCY, ZFCY, SRV, ZSRV, POP, ZPOP, REFNUM, ZREFNUM, CTRNUM : Endif
#If [L]VALEUR>"" : Effzo [CEW1] FCY, ZFCY, SRV, ZSRV, POP, ZPOP, REFNUM, CTRNUM, SRN, NAM : Endif
# 90783
If [L]VALEUR>"" : Call GRISE_LEV(1) : Else Call GRISE_LEV(0) : Endif

End

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, SRV, ZSRV, POP, ZPOP, REFNUM, ZREFNUM, CTRNUM : Endif
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, SRV, ZSRV, POP, ZPOP, REFNUM, CTRNUM, SRN, NAM : Endif
# 90783
If [L]VALEUR>"" : Call GRISE_LEV(2) : Else Call GRISE_LEV(0) : Endif

End

########################################
Subprog AM_SRV(VALEUR)
Variable Char    VALEUR()
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, FCY, ZFCY, POP, ZPOP, REFNUM, ZREFNUM, CTRNUM : Endif
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, FCY, ZFCY, POP, ZPOP, REFNUM, CTRNUM, SRN, NAM : Endif
# 90783
If [L]VALEUR>"" : Call GRISE_LEV(3) : Else Call GRISE_LEV(0) : Endif

End

#########################################
Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, FCY, ZFCY, SRV, ZSRV, REFNUM, ZREFNUM, CTRNUM : Endif
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, FCY, ZFCY, SRV, ZSRV, REFNUM, CTRNUM, SRN, NAM : Endif
# 90783
If [L]VALEUR>"" : Call GRISE_LEV(4) : Else Call GRISE_LEV(0) : Endif

End

########################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, FCY, ZFCY, SRV, ZSRV, POP, ZPOP, CTRNUM : Endif
# 90783
If [L]VALEUR>"" : Call GRISE_LEV(5) : Else Call GRISE_LEV(0) : Endif
Call UPD_NAMSRN(VALEUR,"[M:CEW1]","NAM","SRN",0,0) From DIVPAYE
End

########################################
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, FCY, ZFCY, SRV, ZSRV, POP, ZPOP, REFNUM,  ZREFNUM : Endif
#If [L]VALEUR>"" : Effzo [CEW1] CPY, ZCPY, FCY, ZFCY, SRV, ZSRV, POP, ZPOP, REFNUM, SRN, NAM : Endif
# 90783
If [L]VALEUR>"" : Call GRISE_LEV(6) : Else Call GRISE_LEV(0) : Endif

End

########################################
Subprog C_SUIVI(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=1 & [M:CEW1]ENVOI(nolign-1)<2
 [V]GMESSAGE=mess(74,10701,1)
 #           Le responsable doit recevoir au moins un mail ou une notification
 mkstat     =2
Elsif nolign>1 & [L]VALEUR=3 & [M:CEW1]SUIVI(nolign-2)<3
 [V]GMESSAGE=mess(75,10701,1)
 #           La cascade de signature a été interrompue la ligne précédente
 mkstat     =2
Endif

End
########################################
