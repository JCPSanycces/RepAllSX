#<AdxTL>@(#)1.0.0.0 $Revision$
#################################################################################
## VALMSKSTD Ecriture des traitements standard et spécifique
#################################################################################
$VALTRT

#################################################################################
## Ecriture du traitement standard
#################################################################################

OK = 1

# Présence d'au moins 1 action STD

If !find("STD",ACT_ACT(1..NBACT))
 OK = 0
Endif

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

Raz ACT_OK
If OK
 If APPLI=nomap
  FICSRC = filpath("TRT",TET_STD,"src")
 Else
  FICSRC = filpath("TRT",TET_STD,"src",APPLI)
  If filinfo(FICSRC,0)<0
   Gosub LEC_MERE
   For J=1 To NBMERE
    FICSRC = filpath("TRT",TET_STD,"src",TBMERE(J))
    If filinfo(FICSRC,0)>=0 : Break : Endif
   Next J
  Endif
 Endif

 FLVAL = 0
 If filinfo(FICSRC,0)<0
  If APPLI=nomap
   Call EXISTE_ADX("","",TET_STD,OKTRT) From ORDSYS
  Else
   Call EXISTE_ADX("",APPLI,TET_STD,OKTRT) From ORDSYS
   If !OKTRT
    Gosub LEC_MERE
    For J=1 To NBMERE
     Call EXISTE_ADX("",TBMERE(J),TET_STD,OKTRT) From ORDSYS
     If OKTRT>0 : Break : Endif
    Next J
   Endif
  Endif
  If !OKTRT 
   FLVAL = 2
  Endif
 Else
  Openi FICSRC
  Rdseq LIGNE
  While fstat=0
   ETQSUB = ""
   If left$(vireblc(LIGNE,2),7)="Subprog"
    LIGNE = vireblc(LIGNE,2)
    J = instr(8,LIGNE,"(")
    If J=0
     J = instr(8,LIGNE,":")
     If J=0
      J = instr(8,LIGNE,"#")
      If J=0
       J = len(LIGNE)+1
      Endif
     Endif
    Endif
    ETQSUB = toupper(vireblc(seg$(LIGNE,8,J-1),2))
   Elsif left$(vireblc(LIGNE,2),1)="$"
    LIGNE = vireblc(LIGNE,2)
    J = instr(2,LIGNE,":")
    If J=0
     J = instr(2,LIGNE,"#")
     If J=0
      J = len(LIGNE)+1
     Endif
    Endif
    ETQSUB = toupper(vireblc(seg$(LIGNE,2,J-1),2))
   Endif
   If ETQSUB<>""
    For A=1 To NBACT
     If ACT_ACT(A)="STD" & ETQSUB=ACT_SPR(A)
      ACT_OK(A) = 1 : Break
     Endif
    Next A
   Endif
   Rdseq LIGNE
  Wend
  Openi
  For A=1 To NBACT
   If ACT_ACT(A)="STD" & ACT_OK(A)=0
    FLVAL = 1 : Break
   Endif
  Next A  
 Endif

 If FLVAL
  If GADONIX=2 : # A Sophia, on valide dans l'appli courante
   APPVAL = APPLI
   If GTRACE<>"" & APPLI<>GDOSX3
    # Traitement $1$ modifié dans le dossier $2$
    Call ECR_TRACE(func AFNC.MES2(mess(87,127,1),TET_STD,APPLI),1) From GESECRAN
   Endif 
  Elsif FLVAL=2 : # Ailleurs, on crée dans le dossier superviseur si le SUB est introuvable
   Call PARAM("","SUPDOS",APPVAL) From ADOVAL
   If APPVAL="" : FLVAL = 0 : Endif
  Else
   FLVAL = 0
  Endif
 Endif

 If FLVAL
  FICNEW = filpath("TRT",TET_STD,"new",APPVAL)
  Openo FICNEW , 0
  PREM = 1
  If FLVAL=2
   Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
   Wrseq "#"-mess(15,123,1)-ECRAN : # Gestion du masque
   Wrseq
   If left$(TET_STD,3)="SUB" & len(TET_STD)<=6 : # Ca va servir pour un Objet
    Gosub AJOUT
    Gosub ACTION
   Endif
  Else
   Openi FICSRC
   Rdseq LIGNE
   While fstat=0
    Wrseq LIGNE
    Rdseq LIGNE
   Wend
   Openi
  Endif
  For A=1 To NBACT
   If ACT_ACT(A)="STD" & ACT_OK(A)=0
    Gosub AJOUT
    Gosub ETIQ
   Endif
  Next A
  If !PREM
   Wrseq
   Wrseq "######################################################################################"
   Wrseq
  Endif
  Openo
  FICSRC = filpath("TRT",TET_STD,"src",APPVAL)
  Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
  If STAT
   Call ECR_TRACE(mess(6,123,1)+num$(STAT)-"MOVE"+"\|"+FICNEW+"\|"+FICSRC,1) From GESECRAN : # Erreur
  Endif
  Call MAJDICTRT(TET_STD,APPVAL,TET_TXT,TET_MOD,TET_ACV) From SUBADC
  Call VALID("TRT",TET_STD,APPVAL,OK) From VALMSKSUB
 Endif
Endif

#################################################################################
## Ecriture du traitement vertical
#################################################################################

OK = 1

# Présence d'au moins 1 action SPV

If !find("SPV",ACT_ACT(1..NBACT))
 OK = 0
Endif

Raz ACT_OK
If OK
 If APPLI=nomap
  FICSRC = filpath("TRT",TET_SPV,"src")
 Else
  FICSRC = filpath("TRT",TET_SPV,"src",APPLI)
  If filinfo(FICSRC,0)<0
   Gosub LEC_MERE
   For J=1 To NBMERE
    FICSRC = filpath("TRT",TET_SPV,"src",TBMERE(J))
    If filinfo(FICSRC,0)>=0 : Break : Endif
   Next J
  Endif
 Endif

 FLVAL = 0
 If filinfo(FICSRC,0)<0
  If APPLI=nomap
   Call EXISTE_ADX("","",TET_SPV,OKTRT) From ORDSYS
  Else
   Call EXISTE_ADX("",APPLI,TET_SPV,OKTRT) From ORDSYS
   If !OKTRT
    Gosub LEC_MERE
    For J=1 To NBMERE
     Call EXISTE_ADX("",TBMERE(J),TET_SPV,OKTRT) From ORDSYS
     If OKTRT>0 : Break : Endif
    Next J
   Endif
  Endif
  If !OKTRT 
   FLVAL = 2
  Endif
 Else
  Openi FICSRC
  Rdseq LIGNE
  While fstat=0
   ETQSUB = ""
   If left$(vireblc(LIGNE,2),7)="Subprog"
    LIGNE = vireblc(LIGNE,2)
    J = instr(8,LIGNE,"(")
    If J=0
     J = instr(8,LIGNE,":")
     If J=0
      J = instr(8,LIGNE,"#")
      If J=0
       J = len(LIGNE)+1
      Endif
     Endif
    Endif
    ETQSUB = toupper(vireblc(seg$(LIGNE,8,J-1),2))
   Elsif left$(vireblc(LIGNE,2),1)="$"
    LIGNE = vireblc(LIGNE,2)
    J = instr(2,LIGNE,":")
    If J=0
     J = instr(2,LIGNE,"#")
     If J=0
      J = len(LIGNE)+1
     Endif
    Endif
    ETQSUB = toupper(vireblc(seg$(LIGNE,2,J-1),2))
   Endif
   If ETQSUB<>""
    For A=1 To NBACT
     If ACT_ACT(A)="SPV" & ETQSUB=ACT_SPR(A)
      ACT_OK(A) = 1 : Break
     Endif
    Next A
   Endif
   Rdseq LIGNE
  Wend
  Openi
  For A=1 To NBACT
   If ACT_ACT(A)="SPV" & ACT_OK(A)=0
    FLVAL = 1 : Break
   Endif
  Next A
 Endif

 If FLVAL
  FICNEW = filpath("TRT",TET_SPV,"new",APPLI)
  PREM = 1
  Openo FICNEW , 0
  If FLVAL=2
   Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
   Wrseq "#"-mess(15,123,1)-ECRAN-"("+mess(125,139,1)+")" : # Gestion du masque (vertical)
   Wrseq
   If left$(TET_SPV,3)="SPV" & len(TET_SPV)<=6 : # Ca va servir pour un Objet
    Gosub AJOUT
    Gosub ACTION
   Endif
  Else
   Openi FICSRC
   Rdseq LIGNE
   While fstat=0
    Wrseq LIGNE
    Rdseq LIGNE
   Wend
   Openi
  Endif
  For A=1 To NBACT
   If ACT_ACT(A)="SPV" & ACT_OK(A)=0
    Gosub AJOUT
    Gosub ETIQ
   Endif
  Next A
  If !PREM
   Wrseq
   Wrseq "######################################################################################"
   Wrseq
  Endif
  Openo
  FICSRC = filpath("TRT",TET_SPV,"src",APPLI)
  Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
  If STAT
   Call ECR_TRACE(mess(6,123,1)+num$(STAT)-"MOVE"+"\|"+FICNEW+"\|"+FICSRC,1) From GESECRAN : # Erreur
  Endif
  Call MAJDICTRT(TET_SPV,APPLI,TET_TXT,TET_MOD,TET_ACV) From SUBADC
  Call VALID("TRT",TET_SPV,APPLI,OK) From VALMSKSUB
 Endif
Endif

#################################################################################
## Ecriture du traitement spécifique
#################################################################################

OK = 1

# Présence d'au moins 1 action SPE

If !find("SPE",ACT_ACT(1..NBACT))
 OK = 0
Endif

Raz ACT_OK
If OK
 If APPLI=nomap
  FICSRC = filpath("TRT",TET_SPE,"src")
 Else
  FICSRC = filpath("TRT",TET_SPE,"src",APPLI)
  If filinfo(FICSRC,0)<0
   Gosub LEC_MERE
   For J=1 To NBMERE
    FICSRC = filpath("TRT",TET_SPE,"src",TBMERE(J))
    If filinfo(FICSRC,0)>=0 : Break : Endif
   Next J
  Endif
 Endif

 FLVAL = 0
 If filinfo(FICSRC,0)>=0
  Openi FICSRC
  Rdseq LIGNE
  While fstat=0
   ETQSUB = ""
   If left$(vireblc(LIGNE,2),7)="Subprog"
    LIGNE = vireblc(LIGNE,2)
    J = instr(8,LIGNE,"(")
    If J=0
     J = instr(8,LIGNE,":")
     If J=0
      J = instr(8,LIGNE,"#")
      If J=0
       J = len(LIGNE)+1
      Endif
     Endif
    Endif
    ETQSUB = toupper(vireblc(seg$(LIGNE,8,J-1),2))
   Elsif left$(vireblc(LIGNE,2),1)="$"
    LIGNE = vireblc(LIGNE,2)
    J = instr(2,LIGNE,":")
    If J=0
     J = instr(2,LIGNE,"#")
     If J=0
      J = len(LIGNE)+1
     Endif
    Endif
    ETQSUB = toupper(vireblc(seg$(LIGNE,2,J-1),2))
   Endif
   If ETQSUB<>""
    For A=1 To NBACT
     If ACT_ACT(A)="SPE" & ETQSUB=ACT_SPR(A)
      ACT_OK(A) = 1 : Break
     Endif
    Next A
   Endif
   Rdseq LIGNE
  Wend
  Openi
  For A=1 To NBACT
   If ACT_ACT(A)="SPE" & ACT_OK(A)=0
    FLVAL = 1 : Break
   Endif
  Next A
 Else
  FLVAL = 2
 Endif

 If FLVAL
  FICNEW = filpath("TRT",TET_SPE,"new",APPLI)
  PREM = 1
  Openo FICNEW , 0
  If FLVAL=2
   Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
   Wrseq "#"-mess(15,123,1)-ECRAN-"("+mess(126,139,1)+")" : # Gestion du masque (spécifique)
   Wrseq
   If left$(TET_SPE,3)="SPE" & len(TET_SPE)<=6 : # Ca va servir pour un Objet
    Gosub AJOUT
    Gosub ACTION
   Endif
  Else
   Openi FICSRC
   Rdseq LIGNE
   While fstat=0
    Wrseq LIGNE
    Rdseq LIGNE
   Wend
   Openi
  Endif
  For A=1 To NBACT
   If ACT_ACT(A)="SPE" & ACT_OK(A)=0
    Gosub AJOUT
    Gosub ETIQ
   Endif
  Next A
  If !PREM
   Wrseq
   Wrseq "######################################################################################"
   Wrseq
  Endif
  Openo
  FICSRC = filpath("TRT",TET_SPE,"src",APPLI)
  Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS
  If STAT
   Call ECR_TRACE(mess(6,123,1)+num$(STAT)-"MOVE"+"\|"+FICNEW+"\|"+FICSRC,1) From GESECRAN : # Erreur
  Endif
  Call MAJDICTRT(TET_SPE,APPLI,TET_TXT,TET_MOD,TET_ACV) From SUBADC
  Call VALID("TRT",TET_SPE,APPLI,OK) From VALMSKSUB
 Endif
Endif

Return

################################
$AJOUT
If PREM
 Wrseq "######################################################################################"
 Wrseq "##"-mess(81,133,1)-"("+mess(50,139,1)-MASQUE+")"-format$("D:"+GFMDAT4,date$)-time$-"("+GUSER+")"
 Wrseq "######################################################################################"
 # Etiquette ajoutée par le superviseur
 PREM = 0
Endif
Return

################################
$ACTION
Wrseq "$ACTION"
Wrseq "Case ACTION"
Wrseq " When default"
Wrseq "Endcase"
Wrseq "Return"
Wrseq
Return

################################
$ETIQ
If ACT_PAR(A)=0
 Wrseq "Subprog"-ACT_SPR(A)
Else
 Wrseq "Subprog"-ACT_SPR(A)+"(VALEUR)"
 Case PAR_TYP(A,1)
  When 2,5     : Wrseq "Variable Integer VALEUR"
  When 1       : Wrseq "Variable Char    VALEUR()"
  When 4       : Wrseq "Variable Date    VALEUR"
  When 6       : Wrseq "Variable Clbfile VALEUR"
  When Default : Wrseq "Variable Decimal VALEUR"
 Endcase
Endif
Wrseq "End"
Wrseq
Return

################################
$LEC_MERE
If NBMERE = 0
 FICAPL = filpath("","APL","ini",APPLI)
 If filinfo(FICAPL,0)>=0
  Openi FICAPL
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If left$(LIGNE,10)="adxmother("
    J = instr(1,LIGNE,"=")
    If J
     LIGNE = vireblc(right$(LIGNE,J+1),2)
     LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
     If LIGNE<>APPLI & !find(LIGNE,TBMERE(1..NBMERE)) & filinfo(filpath("","","",LIGNE),0)>=0
      NBMERE += 1
      TBMERE(NBMERE) = LIGNE
     Endif
    Endif
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
Endif
Return
