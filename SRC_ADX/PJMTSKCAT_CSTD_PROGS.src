#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSKCAT
###################################################################################################
# PROGS
###################################################################################################
Funprog GET_COST_EFFECTIVE_RATE(STCACOD, PCCCOD, UOM, CUR, SMESSAGE)
Value Char STCACOD
Variable Char PCCCOD
Variable Char UOM
Variable Char CUR
Variable Char SMESSAGE

Local Integer IARENDRE

  # ----------------------------
  Raz SMESSAGE
  IARENDRE = [V]CST_AOK
  Raz PCCCOD
  Raz UOM
  Raz CUR
  # ----------------------------
  Local File PJMTSKCAT [PTC]
  Local File PJMCOSTCTR [PJCC]
  # ----------------------------
  Read [PTC]CTA0=STCACOD
  If fstat = 0 Then
    If [F:PTC]PCCCOD <> AVOID.ACHAR Then
      Read [PJCC]PCC0=[F:PTC]PCCCOD
      If fstat = 0 Then
        PCCCOD = [F:PTC]PCCCOD
        UOM = [F:PJCC]PCCU
        CUR = [F:PJCC]PCCCUR
      Else
        IARENDRE = [V]CST_AERROR
        SMESSAGE = func AFNC.MES1(mess(248,2260,1), [F:PTC]PCCCOD)
      Endif
    Else
      IARENDRE = [V]CST_AERROR
      SMESSAGE = func AFNC.MES1(mess(250,2260,1), [F:PTC]TCACOD)
    Endif
  Else
    IARENDRE = [V]CST_AERROR
    SMESSAGE = func AFNC.MES1(mess(249,2260,1), this.TCACOD)
  Endif
End IARENDRE

