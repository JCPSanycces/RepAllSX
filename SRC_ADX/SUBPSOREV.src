#<AdxTL>@(#)0.0.0.0 $Revision$ Object management PSOREV
##########################################################################################################
# Objet PSOREV
# Issue X3-95322 - 2018-07-05 by FGR
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "LIENS"      : Gosub LIENS
    When "FILTRE"     : Gosub FILTRE
    When "EXEBOUT"    : Gosub EXEBOUT
    When "STYLE"      : Gosub STYLE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  # -----------------------------
  Local File PJMSOLITMD [PSOD]
  Local File PJMSOLITMH [PSOH]
  Local File PJMSOLITMO [PSOO]
  Local File VPJMSOLITMD [VPSOD]
  Local File VPJMSOLITMO [VPSOO]
  # -----------------------------
  GCONSULT = 1
Return

##########################################################################################################
$LIENS
  If [F:VPSOH]CURREVFLG = [V]CST_AYES Then
    Read [F:PSOH]PSOH0=[F:VPSOH]PSONUM
    If clalev([M:REVPSO0]) > 0 : [M:REVPSO0] = [F:PSOH] : Endif
    If clalev([M:REVPSO1]) > 0 : [M:REVPSO1] = [F:PSOH] : Endif
    If clalev([M:REVPSO2]) > 0 : [M:REVPSO2] = [F:PSOH] : Endif
    If clalev([M:REVPSO3]) > 0 : [M:REVPSO3] = [F:PSOH] : Endif
  Endif
  Call LOAD_CURRENT_VPJMSOLITMO([F:VPSOH]PSONUM, [F:VPSOH]REVNUM)
  Call LOAD_CURRENT_VPJMSOLITMD([F:VPSOH]PSONUM, [F:VPSOH]REVNUM)
  Call LOAD_PREVIOUS_REVISION([F:VPSOH]PSONUM, [F:VPSOH]REVNUM)
Return

##########################################################################################################
$FILTRE
Return

##########################################################################################################
$EXEBOUT
  Case BOUT
    When "1"
      # resynchronization
      Call RESYNCHRONIZATION()
  Endcase
Return

##########################################################################################################
$STYLE
  Call CHGSTL_ALL([M:REVPSO0]REVNUM)
Return

##########################################################################################################
# SUBROUTINES
##########################################################################################################
Subprog RESYNCHRONIZATION()

Local Integer IERR
Local Integer ICOUNT
Local Integer ICOUNTTOT
Local Integer IADXLOG
Local Integer IPSOREV

  # ----------------------
  Local File FACILITY    [FCY]
  Local File VPJMSOLITMH [VPSOH]
  Local File PJMSOLITMH  [PSOH]
  # ----------------------
  IERR = 0
  IADXLOG = (adxlog = 1)
  # ----------------------
  Call OUVRE_TRACE(mess(1097,2260,1)) From LECFIC
  # ----------------------
  ICOUNTTOT = 0
  Filter [FCY] Where [F:FCY]SALFLG = [V]CST_AYES
  For [FCY]
    IPSOREV = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, [F:FCY]FCY, "PSOREV")
    If IPSOREV = 2 or IPSOREV = 3 Then
      If IADXLOG = [V]CST_AFALSE Then
        Trbegin [VPSOH]
      Endif
      # ----------------------
      ICOUNT = 0
      Delete [VPSOH] Where [F:VPSOH]SALFCY = [F:FCY]FCY and [F:VPSOH]CURREVFLG = [V]CST_AYES
      For [PSOH] Where [F:PSOH]SALFCY = [F:FCY]FCY
        Raz [F:VPSOH]
        [F:VPSOH]PSONUM = [F:PSOH]PSONUM
        [F:VPSOH]REVNUM = [F:PSOH]REVNUM
        [F:VPSOH]SALFCY = [F:PSOH]SALFCY
        [F:VPSOH]CURREVFLG = [V]CST_AYES
        Write [VPSOH]
        If fstat <> [V]CST_AOK Then
          Call ECR_TRACE([F:FCY]FCY - ":" - mess(1098,2260,1), 1) From GESECRAN
          IERR = 1
          Break
        Endif
        ICOUNT += 1
      Next
      # ----------------------
      If IERR = 0 Then
        If ICOUNT > 0
          Call ECR_TRACE(func AFNC.MES2(mess(1099,2260,1), num$(ICOUNT), [F:FCY]FCY), 0) From GESECRAN
        Endif
        If IADXLOG = [V]CST_AFALSE Then
          Commit
        Endif
      Else
        If IADXLOG = [V]CST_AFALSE Then
          Rollback
        Endif
      Endif
      ICOUNTTOT += ICOUNT
    Endif
  Next
  Filter [FCY]
  # ----------------------
  If IERR = 0 Then
    Call ECR_TRACE(func AFNC.MES1(mess(1100,2260,1), num$(ICOUNTTOT)), 0) From GESECRAN
  Endif
  # ----------------------
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

##########################################################################################################
Subprog LOAD_CURRENT_VPJMSOLITMO(SPSONUM, IREVNUM)
Value Char SPSONUM
Value Integer IREVNUM

Local Integer IFOUND

  # ----------------------
  Local File VPJMSOLITMO [VPSOO]
  IFOUND = [V]CST_ANO
  Filter [VPSOO] Where [F:VPSOO]PSONUM = SPSONUM and [F:VPSOO]REVNUM = IREVNUM and [F:VPSOO]REVCOD <> "A"
  For [VPSOO]
    IFOUND = [V]CST_AYES
    Break
  Next
  Filter [VPSOO]
  # ----------------------
  If IFOUND = [V]CST_AYES Then
    Local File VPJMSOLITMO [PSOO] Where [F:PSOO]PSONUM = SPSONUM and [F:PSOO]REVNUM = IREVNUM Order By Key KEY0=[F:PSOO]PSONUM;[F:PSOO]PSOLIN
  Else
    Local File PJMSOLITMO [PSOO] Where [F:PSOO]PSONUM = SPSONUM Order By Key KEY0=[F:PSOO]PSONUM;[F:PSOO]PSOLIN
  Endif
  #
  Effzo [M:REVPSO2]
  nolign = 0
  For [PSOO]KEY0
    nolign += 1
    [M:REVPSO2] = [F:PSOO]
    [M:REVPSO2]KEYCONCAT(nolign-1) = func SUBPSOA.GET_PSO2_KEYCONCAT([M:REVPSO2]PBUCOD(nolign-1), [M:REVPSO2]TASCOD(nolign-1), [M:REVPSO2]SEQNUM(nolign-1))
    If [M:REVPSO2]REVCOD(nolign-1) = "A" Then
      [M:REVPSO2]TXTCOD(nolign-1) = mess(1101,2260,1)
    Else
      [M:REVPSO2]TXTCOD(nolign-1) = mess(1102,2260,1)
    Endif
    If [F:PSOO]TASCOD <> AVOID.ACHAR Then
      [M:REVPSO2]TASDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [F:PSOO]OPPNUM, [F:PSOO]TASCOD))
    Endif
    If [F:PSOO]PBUCOD <> AVOID.ACHAR Then
      [M:REVPSO2]PBUDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [F:PSOO]OPPNUM, [F:PSOO]PBUCOD))
    Endif
  Next
  # ----------------------
  If IFOUND = [V]CST_ANO Then
    Filter [VPSOO] Where [F:VPSOO]PSONUM = SPSONUM and [F:VPSOO]REVNUM = IREVNUM and [F:VPSOO]REVCOD = "A" Order By Key KEY0=[F:VPSOO]PSONUM;[F:VPSOO]PSOLIN
    For [VPSOO]KEY0
      nolign += 1
      [M:REVPSO2] = [F:VPSOO]
      [M:REVPSO2]KEYCONCAT(nolign-1) = func SUBPSOA.GET_PSO2_KEYCONCAT([M:REVPSO2]PBUCOD(nolign-1), [M:REVPSO2]TASCOD(nolign-1), [M:REVPSO2]SEQNUM(nolign-1))
      If [M:REVPSO2]REVCOD(nolign-1) = "A" Then
        [M:REVPSO2]TXTCOD(nolign-1) = mess(1101,2260,1)
      Else
        [M:REVPSO2]TXTCOD(nolign-1) = mess(1102,2260,1)
      Endif
      If [F:VPSOO]TASCOD <> AVOID.ACHAR Then
        [M:REVPSO2]TASDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [F:VPSOO]OPPNUM, [F:VPSOO]TASCOD))
      Endif
      If [F:VPSOO]PBUCOD <> AVOID.ACHAR Then
        [M:REVPSO2]PBUDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [F:VPSOO]OPPNUM, [F:VPSOO]PBUCOD))
      Endif
    Next
    Filter [VPSOO]
  Endif
  # ----------------------
  [M:REVPSO2]NBLIG2 = nolign
End

##########################################################################################################
Subprog LOAD_CURRENT_VPJMSOLITMD(SPSONUM, IREVNUM)
Value Char SPSONUM
Value Integer IREVNUM

Local Integer IFOUND

  # ----------------------
  Local File VPJMSOLITMD [VPSOD]
  IFOUND = [V]CST_ANO
  Filter [VPSOD] Where [F:VPSOD]PSONUM = SPSONUM and [F:VPSOD]REVNUM = IREVNUM
  For [VPSOD]
    IFOUND = [V]CST_AYES
    Break
  Next
  Filter [VPSOD]
  # ----------------------
  If IFOUND = [V]CST_AYES Then
    Local File VPJMSOLITMD [PSOD] Where [F:PSOD]PSONUM = SPSONUM and [F:PSOD]REVNUM = IREVNUM Order By Key KEY0=[F:PSOD]PSONUM;[F:PSOD]SEQNUM
  Else
    Local File PJMSOLITMD [PSOD] Where [F:PSOD]PSONUM = SPSONUM Order By Key KEY0=[F:PSOD]PSONUM;[F:PSOD]SEQNUM
  Endif
  #
  Effzo [M:REVPSO3]
  nolign = 0
  For [PSOD]KEY0
    nolign += 1
    [M:REVPSO3] = [F:PSOD]
    If [F:PSOD]TASCOD <> AVOID.ACHAR Then
      [M:REVPSO3]TASDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(GACTX, [F:PSOD]OPPNUM, [F:PSOD]TASCOD))
    Endif
    If [F:PSOD]PBUCOD <> AVOID.ACHAR Then
      [M:REVPSO3]PBUDES(nolign-1) = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(GACTX, [F:PSOD]OPPNUM, [F:PSOD]PBUCOD))
    Endif
  Next
  [M:REVPSO3]NBLIG3 = nolign
End

##########################################################################################################
Subprog LOAD_PREVIOUS_REVISION(SPSONUM, IREVNUM)
Value Char SPSONUM
Value Integer IREVNUM

Local Integer IPRECREVNUM

  IPRECREVNUM = IREVNUM - 1
  # ----------------------
  Effzo [M:REVPSOH0]
  Effzo [M:REVPSOH1]
  Effzo [M:REVPSOH2]
  Effzo [M:REVPSOH3]
  # ----------------------
  If IPRECREVNUM >= 0 Then
    Local File VPJMSOLITMH [VPSOH]
    # ----------------------
    Read [VPSOH]VPSOH0=SPSONUM;IPRECREVNUM
    [M:REVPSOH0] = [F:VPSOH]
    [M:REVPSOH1] = [F:VPSOH]
    #
    Call LOAD_PREVIOUS_VPJMSOLITMO(SPSONUM, IPRECREVNUM)
    Call LOAD_PREVIOUS_VPJMSOLITMD(SPSONUM, IPRECREVNUM)
  Else
    [M:REVPSOH0] = [M:REVPSO0]
    [M:REVPSOH1] = [M:REVPSO1]
    [M:REVPSOH2] = [M:REVPSO2]
    [M:REVPSOH3] = [M:REVPSO3]
  Endif
End

##########################################################################################################
Subprog LOAD_PREVIOUS_VPJMSOLITMO(SPSONUM, IREVNUM)
Value Char SPSONUM
Value Integer IREVNUM

Local Integer IFOUND

  # ----------------------
  Local File VPJMSOLITMO [VPSOO]
  IFOUND = [V]CST_ANO
  Filter [VPSOO] Where [F:VPSOO]PSONUM = SPSONUM and [F:VPSOO]REVNUM = IREVNUM
  For [VPSOO]
    IFOUND = [V]CST_AYES
    Break
  Next
  Filter [VPSOO]
  # ----------------------
  If IFOUND = [V]CST_AYES Then
    Local File VPJMSOLITMO [PSOO] Where [F:PSOO]PSONUM = SPSONUM and [F:PSOO]REVNUM = IREVNUM Order By Key KEY0=[F:PSOO]PSONUM;[F:PSOO]PSOLIN
  Else
    Local File PJMSOLITMO [PSOO] Where [F:PSOO]PSONUM = SPSONUM Order By Key KEY0=[F:PSOO]PSONUM;[F:PSOO]PSOLIN
  Endif
  #
  Effzo [M:REVPSOH2]
  nolign = 0
  For [PSOO]KEY0
    nolign += 1
    [M:REVPSOH2] = [F:PSOO]
    [M:REVPSOH2]KEYCONCAT(nolign-1) = func SUBPSOA.GET_PSO2_KEYCONCAT([M:REVPSOH2]PBUCOD(nolign-1), [M:REVPSOH2]TASCOD(nolign-1), [M:REVPSOH2]SEQNUM(nolign-1))
  Next
  [M:REVPSOH2]NBLIG2 = nolign
End

##########################################################################################################
Subprog LOAD_PREVIOUS_VPJMSOLITMD(SPSONUM, IREVNUM)
Value Char SPSONUM
Value Integer IREVNUM

Local Integer IFOUND

  # ----------------------
  Local File VPJMSOLITMD [VPSOD]
  IFOUND = [V]CST_ANO
  Filter [VPSOO] Where [F:VPSOO]PSONUM = SPSONUM and [F:VPSOO]REVNUM = IREVNUM
  For [VPSOO]
    IFOUND = [V]CST_AYES
    Break
  Next
  Filter [VPSOO]
  # ----------------------
  If IFOUND = [V]CST_AYES Then
    Local File VPJMSOLITMD [PSOD] Where [F:PSOD]PSONUM = SPSONUM and [F:PSOD]REVNUM = IREVNUM Order By Key KEY0=[F:PSOD]PSONUM;[F:PSOD]SEQNUM
  Else
    Local File PJMSOLITMD [PSOD] Where [F:PSOD]PSONUM = SPSONUM Order By Key KEY0=[F:PSOD]PSONUM;[F:PSOD]SEQNUM
  Endif
  #
  Effzo [M:REVPSOH3]
  nolign = 0
  For [PSOD]KEY0
    nolign += 1
    [M:REVPSOH3] = [F:PSOD]
  Next
  [M:REVPSOH3]NBLIG3 = nolign
End

##########################################################################################################
Subprog CHGSTL_ALL(IREVNUM)
Value Integer IREVNUM

  Call CHGSTL_HEADER("REVPSO0", "REVPSOH0", IREVNUM, 0, "PJMWARN1")
  Call CHGSTL_HEADER("REVPSO1", "REVPSOH1", IREVNUM, 0, "PJMWARN1")
  #
  Call CHGSTL_GRID("REVPSO2", "REVPSOH2", IREVNUM, 0, "KEYCONCAT", "PJMWARN1")
End

##########################################################################################################
Subprog CHGSTL_HEADER(ABRCUR, ABRPRV, REVNUM, BLKNUM, STYLE)
Value Char ABRCUR
Value Char ABRPRV
Value Integer REVNUM
Value Integer BLKNUM
Value Char STYLE

Local Char NOMZON(GLONAVA)
Local Char FULFIELD(250)
Local Char FULFIELD1(250)
Local Char FULFIELD2(250)
Local Integer MA
Local Integer NI

  Local File AMSKZON [AMZ]
  # ------------------------------
  # For not miss : mandatory to have this part because of "Chgstl"
  Gosub DEFVAR From WGOPSOREV
  For MA = 0 To NBMASK
    If ABMSK(MA) = [L]ABRCUR Then
      Gosub SETMASK From WGOPSOREV
      Break
    Endif
  Next MA
  # ------------------------------
  If BLKNUM <> 0 Then
    Filter [AMZ] Where [AMZ]CODMSK = [L]ABRCUR and [F:AMZ]SAIAFF < 3 and [F:AMZ]NUMBLOC = BLKNUM   # specific block
  Else
    Filter [AMZ] Where [AMZ]CODMSK = [L]ABRCUR and [F:AMZ]SAIAFF < 3                               # all blocks in screen
  Endif
  # ------------------------------
  For [AMZ]
    NOMZON = [F:AMZ]CODZON
    FULFIELD = "[M:" + [L]ABRCUR + "]" + [L]NOMZON
    For NI = 0 To evalue("dim(" + FULFIELD + ")") - 1
      FULFIELD1 = "[M:" + [L]ABRCUR + "]" + [L]NOMZON + "(" + num$(NI) + ")"
      FULFIELD2 = "[M:" + [L]ABRPRV + "]" + [L]NOMZON + "(" + num$(NI) + ")"
      If (evalue("dim(" + FULFIELD1 + ")") >= 0) and (evalue("dim(" + FULFIELD2 + ")") >= 0) Then
          If evalue(FULFIELD1) <> evalue(FULFIELD2) and [L]REVNUM > 0 Then
            Chgstl =FULFIELD1 With STYLE
          Else
            Chgstl =FULFIELD1 With ""
          Endif
        Endif
    Next NI
  Next
  # ------------------------------
  Filter [AMZ]
End

##########################################################################################################
Subprog CHGSTL_GRID(ABRCUR, ABRPRV, REVNUM, BLKNUM, SFLDLIN, STYLE)
Value Char ABRCUR
Value Char ABRPRV
Value Integer REVNUM
Value Integer BLKNUM
Value Char SFLDLIN
Value Char STYLE

Local Char NOMZON(GLONAVA)
Local Char FULFIELD(250)
Local Char FULFIELD1(250)
Local Char FULFIELD2(250)
Local Char FULCMP1(250)
Local Char FULCMP2(250)
Local Char SNBLIG(250)
Local Integer NBLINCMP2
Local Integer LINCMP2
Local Integer MA
Local Integer NI

  Local File AMSKZON [AMZ]
  # ------------------------------
  # For not miss : mandatory to have this part because of "Chgstl"
  Gosub DEFVAR From WGOPSOREV
  For MA = 0 To NBMASK
    If ABMSK(MA) = [L]ABRCUR Then
      Gosub SETMASK From WGOPSOREV
      Break
    Endif
  Next MA
  # ------------------------------
  If BLKNUM <> 0 Then
    Filter [AMZ] Where [AMZ]CODMSK = [L]ABRCUR and [F:AMZ]CODTYP = "ABS" and [F:AMZ]SAIAFF < 3 and [F:AMZ]NUMBLOC = BLKNUM Order By [F:AMZ]NUMLIG
  Else
    Filter [AMZ] Where [AMZ]CODMSK = [L]ABRCUR and [F:AMZ]CODTYP = "ABS" and [F:AMZ]SAIAFF < 3  Order By [F:AMZ]NUMLIG
  Endif
  For [AMZ]
    SNBLIG = [F:AMZ]CODZON
  Next
  # ------------------------------
  If BLKNUM <> 0 Then
    Filter [AMZ] Where [AMZ]CODMSK = [L]ABRCUR and [F:AMZ]SAIAFF < 3 and [F:AMZ]NUMBLOC = BLKNUM and CODTYP <> "ABS"   # specific block
  Else
    Filter [AMZ] Where [AMZ]CODMSK = [L]ABRCUR and [F:AMZ]SAIAFF < 3 and CODTYP <> "ABS"                               # all blocks in screen
  Endif
  # ------------------------------
  For [AMZ]
    [L]NOMZON = [F:AMZ]CODZON
    [L]FULFIELD = "[M:" + [L]ABRCUR + "]" + [L]NOMZON
    For NI = 0 To evalue("[M:" + [L]ABRCUR + "]" + [L]SNBLIG) - 1
      # --------------------------
      [L]FULCMP1 = "[M:" + [L]ABRCUR + "]" + [L]SFLDLIN + "(" + num$(NI) + ")"
      [L]FULCMP2 = "[M:" + [L]ABRPRV + "]" + [L]SFLDLIN
      [L]NBLINCMP2 = evalue("[M:" + [L]ABRPRV + "]" + [L]SNBLIG) - 1
      [L]LINCMP2 = evalue("find(" + [L]FULCMP1 + ", [M:" + [L]ABRPRV + "]" + [L]SFLDLIN + "(0.." + num$([L]NBLINCMP2) + "))") - 1
      # --------------------------
      FULFIELD1 = "[M:" + [L]ABRCUR + "]" + [L]NOMZON + "(" + num$(NI) + ")"
      If LINCMP2 < 0 or ([L]NOMZON = "TXTCOD" and evalue("[M:" + [L]ABRCUR + "]TXTCOD(" + num$(NI) + ")") = mess(1101,2260,1)) Then
        [L]FULFIELD2 = [L]FULFIELD1
      Else
        [L]FULFIELD2 = "[M:" + [L]ABRPRV + "]" + [L]NOMZON + "(" + num$([L]LINCMP2) + ")"
      Endif
      If (evalue("dim(" + [L]FULFIELD1 + ")") >= 0) and (evalue("dim(" + [L]FULFIELD2 + ")") >= 0) Then
        If [L]REVNUM > 0 and (([L]FULFIELD2 = [L]FULFIELD1) or
&                             (evalue([L]FULFIELD1) <> evalue([L]FULFIELD2)) or
&                             (evalue("[M:" + [L]ABRCUR + "]TXTCOD(" + num$(NI) + ")") = mess(1101,2260,1)))
&       Then
          Chgstl =[L]FULFIELD1 With STYLE
        Else
          Chgstl =[L]FULFIELD1 With ""
        Endif
      Endif
    Next NI
  Next
  # ------------------------------
  Filter [AMZ]
End

