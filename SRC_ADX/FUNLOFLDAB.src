# $SET_PICKING_QVB
# $REMPLACE_PRINCIPALE
#
########################################################################################################################
# Modifications :
# -------------
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc
#
# MWA   04.09.2018 X3-104535 Parameters linked to activity code
# CBO   24.11.2017 X3-57687  performance : qq ajouts
# MDJ   26.07.2017 X3-8326   EN COURS : SPIKE performance (cf SAM 119974) : spike devenu développement
# MWA   10.03.2016 115001    Division par 0 lors de la création d'un bien comptable à partir d'une dépense (crédit bail)
# MWA   19.02.2016 114606    Devise inconnue en création de bien comptable
# MDJ   28.01.2016 114002    Si GREP<>"C" ne pas jouer l'alimentation auto des zones libres
# GLE   01.07.2015 108951    Mauvaise affectation des sections si l'ordre des axes est différent entre la dépense principale et le bien
# GLE   01.04.2015 106665    Mêmes critères de rapprochement quelle que soit la législation
# CBO   17.02.2015 100398/13 Liaison FXD PHY
# CBO   28.11.2014 104360    Undo a linked expense when balance sht val is changed
# MDJ   16.06.2014 98116     Deductible VAT recalculated when capitalizing Expense
# GLE   04.07.2014 69052     Suppression des critères de rapprochement sur les coefficients de TVA
# CBO   29.04.2014 69690     objet FAM + BACFLG
# MDJ   26.02.2014 95888     Ajout du code comptable dans les événements LOFCIM*
# MDJ   12.02.2014 93763     Champ Immatriculable si CAB à Oui sur famille
# MDJ   18.12.2013 94340     Mise à jour du plan de renouvellement quand ajout de dépense
# GLE   04.12.2013 94306     Ajout du point d'entrée LOFTOFAS dans la boucle d'alimentation du bien à partir des dépenses
# MWA   15.10.2013 93517     Perte des axes analytiques au delà du neuvième.
# CBO   15.10.2013 93595     erreur conversion pour 1 dépense en devise /plan IAS
# MDJ   02.08.2013 91554     Mise en service   : cohérence dates dans événements LOFCIM & FASCHGIMP
# CBO   10.07.2013 90537     Meilleure gestion de la présence de code comptable via les associations
# GLE   08.07.2013 90968     Lorsque le paramètre LOFIASAMT est à "Oui" la valorisation IAS sur le bien est doublée
#                            et lorsqu'on ajoute une dépense ce n'est pas le montant IAS actualisé qui est présenté
# MDJ   12.03.2013 88454     Activation durée en fonction paramétrage associations
# MWA   20.02.2013 67615_8   Ventilation analytiques biens POOL & LVA
# MWA   30.10.2012 85501     Immobilisation avec changement de SA pas d'evt ELOFCIM pas de régul tva LOFVATREG
# GLE   04.10.2012 84794     Gestion d'un montant IAS pour éviter une double conversion si devise IAS = devise pièce
# CBO   03.10.2012 67615     low value asset
# GLE   26.04.2012 81867     Valorisation modifiable pour l'IAS
# GLE   03.04.2012 80615     Suite à modif 79622, pas d'alimentation de certains champs en création du bien
# GLE   08.03.2012 76672     Controle base amort & échéances contrat uniquement si société de législation française
# MDJ   02.03.2012 79509     Saisie d'une famille impossible si pas d'associations
# MDJ   22.02.2012 79622     Modif. dates à tort qd immobilisation dépense sur un bien non valorisé
# MDJ   09.11.2011 77197     Date compta Evts chgt imp.cpta toujours égale à date début période courante
# GLE   01.09.2011 74813     Ajout d'un point d'entrée pour la détermination du code comptable
# GLE   01.06.2011 60710     Optimisation
# GBO   28.01.2010 67577     Modernisation Polonaise
# GLE   16.11.2010 69052     Suppression du critère de rapprochement sur DEDVATRAT
# GLE   15.10.2010 69158     L'option "Ou vide" dans le paramétrage des liens Dépenses/BCO ne fonctionne pas
# GBO   17.09.2010 67270     Lien Dépense/BCO   : prise en cpte champs dimensionnés
# GBO   26.07.2010 65896     Point d'entrée BEFLOADLOF pour ajouter un filtre Spé sur les dépenses immobilisables
# MDJ   20.07.2010 59892     Comptes et natures d'origine sauvegardés lors du détachement d'une dépense
# MDJ   06.05.2010 60838     "Tout" retirer" interdit en modification par rattachement de dépenses supplémentaires
# MDJ   19.04.2010 64059     CALCUL_VALEUR_BILAN transféré de SUBFAS vers TRTFAS
# MDJ   11.02.2010 59277     Ajout paramètre "type de détention"   : passé au traitement des associations.
# GLE   08.01.2010 61251     Suite FQ60984
# GLE   17.12.2009 60984     Critères de sélection des dépenses à partir des champs du bien lorsque c'est possible
# GLE   07.09.2009 57624     Standard Edition
######################################################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
$ACTION
  Case ACTION
    When "DEBUT"          : Gosub DEBUT
    When "SETBOUT"        : Gosub SETBOUT         : # Enable/Disable des boutons
    When "AVANTBOUT"      : Gosub AVANT_BOUTON    : # Controle bouton
    When "BOUTON"         : Gosub BOUTON          : # Exécution bouton
    When "APRES_MODIF"    : Gosub APRES_MODIF
  Endcase

Return
################################################################################
#-------------------------------------------------------------------------------
$DEBUT
  #------------------------------
  If clalev([F:LDA])=0  : Local File PARLDAP      [LDA]  : Endif : # Paramétrage liaison dépense à bien
  If clalev([F:TZL])=0  : Local File PARTRZL      [TZL]  : Endif : # Paramétrage transite zones
  If clalev([F:TZD])=0  : Local File PARTRZLDET   [TZD]  : Endif : # Paramétrage transit zones détail
  If clalev([F:LOF])=0  : Local File LAYOUTFAS    [LOF]  : Endif : # Dépense
  If clalev([F:LOFP])=0 : Local File LAYOUTFAS    [LOFP] : Endif : # Dépense principale
  If clalev([F:ATY])=0  : Local File ATYPE        [ATY]  : Endif : # Types de données
  If clalev([F:ATZ])=0  : Local File ATABZON      [ATZ]  : Endif : # dictionnaire des champs de table
  If clalev([F:DEP])=0  : Local File DEPREC       [DEP]  : Endif : # Plans d'amortissement du bien comptable

  #------------------------------
  Global Char    GLDAPCRIT(250)     : # Critère de sélection des dépenses à immobiliser
  Global Integer GLDAPSTAR          : # statut de retour de la fenêtre critère
  Global Integer GFIN                 # G_OUI ==> on est passé par le bouton FIN
  Global Integer GLOFIASAMT         : # Paramètre autorisant le forçage du montant HT IAS FQ81867
  #------------------------------
  Local  Integer LCURLINE            : # Ligne de la dépense principale
  Local  Integer LERROR
  #------------------------------
  Local  Integer  PCG_CNX
  Local  Integer  IAS_CNX
  Global Date     WCNXDAT (1..5)
  Global Date     WCNXDATI(1..5)
  Local  Integer  WRET, WCNXCPT, WCNXIAS  #Fq-77197

  # FQ67615
  Global Integer GWDEJAMSGDEPASSE, GW_LVA_TYP_PRIN, GWLVALIM,
&                GWVIALIGNE, GWMSGUNIQUE
  Global Date GWDATSTRFIY, GWDATENDFIY
  Local Char WCH
  GWDEJAMSGDEPASSE = 0
  GWVIALIGNE = 0
  GWMSGUNIQUE = G_NON

  #------------------------------
  If ( GREP = "C" and [M:LOF6]NBDEST = 0 )  : Raz [M:LOF6]: Endif
  #------------------------------
  [M:LOF6]NBSRCE = 0
  #------------------------------
  # On arrive par l'écran des biens : donc soit modif soit création d'un bien
  [M:LOF6]CPY      = [M:FAS0]CPY
  [M:LOF6]FCY      = [M:FAS0]FCY
  [M:LOF6]AASREF   = [M:FAS0]AASREF
  [M:LOF6]AASDES1B = [M:FAS0]AASDES1
  [M:LOF6]DEVIAS   = [M:FAS1]IASCUR

  Call GET_CNX_FROM_PLAN ([M:LOF6]CPY, G301CPT, WCNXCPT ) From GLOBIENS #Fq-77197
  Call GET_CNX_FROM_PLAN ([M:LOF6]CPY, G301IAS, WCNXIAS ) From GLOBIENS #Fq-77197

  If  WCNXCPT > 0
      Call GET_CNX_DAT([M:LOF6]CPY, WCNXCPT, WCNXDAT, WRET ) From GLOBIENS
       Endif
  If  WCNXIAS > 0
     Call GET_CNX_DAT([M:LOF6]CPY, WCNXIAS, WCNXDATI, WRET ) From GLOBIENS
     [M:LOF6]DEVIAS = GCNXCURIAS
  Else
    [M:LOF6]DEVIAS = ""
  Endif

  # FQ81867 : modification du montant IAS
  Local Char LPARM(10)
  Call PARAM("","LOFIASAMT",LPARM) From ADOVAL
  GLOFIASAMT = val(LPARM)
  If (GCNXPROIAS = G_OUI) and (GLOFIASAMT = G_OUI)
    Actzo [M:LOF6]CUMAMTIAS
  Else
    Diszo [M:LOF6]CUMAMTIAS
  Endif

  If ( GREP <> "C" )
    [M:LOF6]ACCCODV = [M:FAS1]ACCCOD
    [M:LOF6]GACV    = [M:FAS1]GAC
    [M:LOF6]GACACNV = [M:FAS1]GACACN
    [M:LOF6]IASACCV = [M:FAS1]IASACC
    [M:LOF6]IASACNV = [M:FAS1]IASACN
    [M:LOF6]ACGGRPV = [M:FAS1]ACGGRP
  Endif
  # Remplissage auto du tableau des dépenses immobilisables
  GLDAPCRIT = ""
  GLDAPSTAR = 0
  Gosub REMPLI_SOURCE
  Call AS_NBSRCE From W1LOFLDAB
  #------------------------------
  Affzo [M:LOF6]FCY
  Affzo [M:LOF6]CPY
  Affzo [M:LOF6]DEVIAS
  Affzo [M:LOF6]ACCCODV
  Affzo [M:LOF6]GAC
  Affzo [M:LOF6]GACACN
  Affzo [M:LOF6]IASACC
  Affzo [M:LOF6]IASACN
  Affzo [M:LOF6]ACGGRPV
  #------------------------------
  If ( GREP <> "C"   or  GLDABAPPL = G_OUI )
    # Quand on n'est pas en création, tous les changements relatifs aux comptes doivent
    # se faire par la transaction qui va bien.
    # Idem, quand on a déjà fait Appliquer : il faut alors faire des
    # modifications, directement sur l'écran des biens comptables.
    # Ici tout est disable !
    Diszo [M:LOF6]ACCCODV
    Diszo [M:LOF6]ACGGRPV
  Else
    Actzo [M:LOF6]ACCCODV
    Actzo [M:LOF6]ACGGRPV
  Endif
  #------------------------------
  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   Gosub DEBUT_LOFLDAB From TRTFASMDR
  Endif
  #------------------------------
  If ( GACCCOD_ASSO = G_NON )
    Diszo [M:LOF6]ACCCODV
  Endif

  # FQ67615 : recharge les infos nécessaires aux LVA
  If [M:LOF6]NBDEST > 0
    GWDEJAMSGDEPASSE = func CTRL_LVA_PRINCIPAL([M:FPC]LEG, [M:FPC]COA(0), [M:LOF6]GACV,
&     [M:LOF6]CPY, G300CPFI, [F:LOFP]DATIMP, 0,
&     GW_LVA_TYP_PRIN, GWLVALIM, GWDATSTRFIY, GWDATENDFIY)
    GWDEJAMSGDEPASSE = 0
  Endif

  Local Integer LGRT : # X3-104535
  LFAS = func AFNC.ACTIV("FAS")
  If LFAS = G_OUI
    Call PARAM([M:FPC]LEG, "LVAMSG", WCH) From ADOVAL
  Endif : # X3-104535

  If WCH = ""
    GWMSGUNIQUE = G_NON
  Else
    GWMSGUNIQUE = val(WCH)
  Endif

  #------------------------------ FQ84794
  Local Integer N_I
  For N_I = 0 To [M:LOF6]NBDEST-1
    Diszo [M:LOF6]AMTNOTIAS(N_I)
  Next
  #------------------------------
  Affzo [M:LOF6]1-99
  #------------------------------
  Gosub LIRE_PARLDAP_SOC
  #------------------------------
Return
#-------------------------------------------------------------------------------
$SETBOUT
  #---------------------------------------------
  # Codes des boutons spécifiques à la liaison LDAB
  # 2 - Appliquer
  #---------------------------------------------

Local Integer I

  # Obligé de restaurer GREP, il est réinitialisé dans GSAISIE. Ca n'était pas le cas avant !
  GREP = SAVGREP
  #---------------------------------------------
  # On ne désactive pas le bouton parce qu'on ne sait pas bien se mettre en modification
  # par programme lorsqu'on a ajouté une ligne avec le bouton B1.
  # On fait juste le test concernant le nombre de ligne à lier
  If ( GLDABAPPL = G_OUI )
     Call VIREBOUT (CHMEN, "2") From GOBJET  : FIN=0 : Return  # Appliquer
  Endif

Return
#-------------------------------------------------------------------------------
$AVANT_BOUTON

  Case BOUT
    When "2"
      # Appliquer
      Gosub CTRL_LDAB
    When Default
  Endcase

Return
#-------------------------------------------------------------------------------
$BOUTON

 #Fq67577-Pologne
 If G_ACTKPL=G_OUI
  GOK=1 : Gosub BOUTON_LOFLDAB From TRTFASMDR : If GOK=0 : Return : Endif
 Endif

 Local Integer J

 Case BOUT
   When "2"        : # Appliquer
     J = find(G_OUI, [M:LOF6]MAIVCR(0..[M:LOF6]NBDEST))
     If ( J = 0 )
       GERR     = 1
       GMESSAGE = mess(59,GML_MSGLOF,1)  # Vous devez d'abord choisir une dépense principale
       Call VIREBOUT (CHMEN, "2") From GOBJET  : FIN=0 : Return  # Appliquer
     Endif
     If (((GREP = "" or GREP="M") and [M:LOF6]NBDEST>GNBDEPLIEES and GNBDEPLIEES > 0) or
&        (GREP="C" and [M:LOF6]NBDEST>0))
       If ( GLDABAPPL = G_OUI )
         # On ne peut appliquer qu'une seule fois !
         GERR     = 1
         GMESSAGE = mess(35,GML_MSGLOF,1)    : # On ne peut appliquer qu'une seule fois
         FIN      = 0  : Return       : # pour ne pas quitter la fenêtre d'éclatement
       Endif
     Endif
     Gosub APPLIQUER_LDAB
     FIN = 1
   When Default
 Endcase

Return
#---------------------------------#
# BOUTON FIN                      #
#---------------------------------#
$FIN

  If ( GREP <> "M"  and GLDABAPPL <> G_OUI )
    [M:LOF6]NBSRCE = 0
    [M:LOF6]NBDEST = 0

    Effzo [M:LOF6]25
    Effzo [M:LOF6]30
    Effzo [M:LOF6]35

    Raz [M:LOF6]
    Affzo [M:LOF6]
  Endif
Return

#-------------------------------------------------------------------------------
$CTRL_LDAB
Local Integer N_I, J

  If (((GREP = "" or GREP="M") and [M:LOF6]NBDEST>GNBDEPLIEES and GNBDEPLIEES > 0) or
&     (GREP="C" and [M:LOF6]NBDEST>0))
    If ( GLDABAPPL = G_OUI )
      # On ne peut applique qu'une seule fois !
      GERR     = 1
      GMESSAGE = mess(35,GML_MSGLOF,1)
      FIN      = 0              : # pour ne pas quitter la fenêtre
    Endif
  Else
    # Il faut avoir au moins une ligne de dépense à lier
    GERR     = 1
    GMESSAGE = mess(24,GML_MSGLOF,1)
    FIN      = 0
  Endif
  #------------------------------
  If ( [M:LOF6]ACCCODV = "" )
    # Le code comptable ne peut être vide
    GERR     = 1
    GMESSAGE = mess(33,GML_MSGLOF,1)
    FIN      = 0
  Endif
#------------------------------
$CTRL_LDAB_BIS
  For N_I = 1 To [M:LOF6]NBDEST-1
    If ( [M:LOF6]FLGLIKAAS(N_I-1) = G_NON )
      #------------------------------
      Raz [LOF]
      Read [LOF]LOF0=[M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)
      #------------------------------
      If (fstat)
        # Erreur en lecture de la dépense
        GMESSAGE  = mess(28,GML_MSGLOF,1)-num$(fstat)
        GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
        GOK       = 0
        Call FSTA("LOF") From GLOCK
        Return
      Else
        If (GCNXPROIAS = G_OUI)
          If  ([F:LOF]GACACN = GVML_NICHARG and [M:LOF6]IASACNV = GVML_NICHARG)
&          or ([F:LOF]IASACN = GVML_NICHARG and [M:LOF6]GACACNV = GVML_NICHARG)
            # Les deux natures de compte ne peuvent pas être "Charge"
            GMESSAGE  = mess(29,GML_MSGLOF,1)
            GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
            GOK       = 0
            Call FSTA("LOF") From GLOCK
            Return
          Endif
        Else
          If ([M:LOF6]GACACNV = GVML_NICHARG)
            # S'il n'y a pas de plan IAS : le compte doit obligatoirement être immo
            # La nature de compte ne peut pas être dépense
            GMESSAGE  = mess(30,GML_MSGLOF,1)
            GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
            GOK       = 0
            Call FSTA("LOF") From GLOCK
            Return
          Endif
        Endif
      Endif
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I
  #------------------------------
Return

#-------------------------------------------------------------------------------
$APRES_MODIF

If ( COUZON = "MAIVCR" )
  LCURLINE = nolign
  Gosub LIRE_DEPENSE_PRIN
Elsif ( COUZON = "FCY" )
  Gosub LIRE_PARLDAP_SOC
Endif

Return
#-------------------------------------------------------------------------------
$REMPLI_SOURCE
Local Char LCOND(250)
Local Char LCONDA(250)(2) : # Pour pouvoir dépasser la limite des 255 caractères par chaine,
                            # on utilise un tableau de deux chaines
Local Char    LCOND1(250)
Local Char    LCODLOF
Local Integer LLINLOF
Local Integer I
Local Integer LPRVUPD, CDRET           : # Paramètre de remise en cause subvention ant.
Local Char    LPARAM                   : # Paramètre de remise en cause subvention ant.
Local Integer LDEPOK : LDEPOK=G_OUI
Local Decimal MNTDES                   : # FQ84794
Local Integer STAT                     : # FQ84794

I=0
LCODLOF =""
LLINLOF = 0

GPOINT="BEFLOADLOF" : Gosub ENTREE From EXEFNC #@fq65896

# Recherche de la dépense pricipale
If [M:LOF6]NBDEST > 0
 I = find(G_OUI, [M:LOF6]MAIVCR(0..[M:LOF6]NBDEST))
 If I <>  0
   LCODLOF= [M:LOF6]CODLOF(I-1)
   LLINLOF= [M:LOF6]LINLOF(I-1)
 Endif
Endif

  Gosub GET_CND_DEP_PRINC

  If ( GLDAPCRIT = "" )
    GLDAPCRIT = '1=1'
  Endif
  [M:LOF6]NBSRCE = 0
  nolign = 1
  Effzo [M:LOF6]15
  #------------------------------
  LCOND1  = "([F:LOF]GACACN=GVML_NIENCOU|[F:LOF]GACACN=GVML_NIENSER"
  If ( GCNXPROIAS = G_OUI )
    LCOND1 += "|[F:LOF]IASACN=GVML_NIENCOU|[F:LOF]IASACN=GVML_NIENSER"
  Endif
  LCOND1 += ")"

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   Gosub REMPLI_SOURCE From TRTFASMDR
  Endif

  # >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  For [LOF]LOF0 Where [F:LOF]CPY=[M:LOF6]CPY and [F:LOF]FCY=[M:LOF6]FCY and [F:LOF]FLGLIKAAS=G_NON and [F:LOF]FLGVAL=G_OUI and
&     evalue(GLDAPCRIT) and evalue(LCOND) and evalue(LCONDA(0)) and evalue(LCONDA(1)) and evalue(LCOND1)
      # On ne recharge pas la dépense pricipale dans le tableau Source
      If ( ([F:LOF]CODLOF=LCODLOF and [F:LOF]LINLOF=LLINLOF) or GLDABAPPL =  G_OUI )
      Else
        [M:LOF6]CODLOFS(nolign-1)    = [F:LOF]CODLOF
        [M:LOF6]LINLOFS(nolign-1)    = [F:LOF]LINLOF
        [M:LOF6]GACS(nolign-1)       = [F:LOF]GAC
        [M:LOF6]GACACNS(nolign-1)    = [F:LOF]GACACN
        If ( GCNXPROIAS = G_OUI )
          [M:LOF6]IASACCS(nolign-1)  = [F:LOF]IASACC
          [M:LOF6]IASACNS(nolign-1)  = [F:LOF]IASACN
        Else
          [M:LOF6]IASACCS(nolign-1)  = ""
          [M:LOF6]IASACNS(nolign-1)  = 0
        Endif
        [M:LOF6]AMTNOTCPYS(nolign-1) = [F:LOF]AMTNOTCPY
        # FQ84794
        If GCNXPROIAS = G_OUI
          If [F:LOF]AMTNOTIAS = 0
            # Gestion de l'IAS
            If [F:LOF]CUR = GCNXCURIAS
              # Même devise que la devise pièce
              [M:LOF6]AMTNOTIASS(nolign-1)  = [F:LOF]AMTNOTCUR
              [M:LOF6]AMTVATIASS(nolign-1)  = [F:LOF]AMTVATCUR  : # FQ98116
              [M:LOF6]AMTVATRIASS(nolign-1) = [F:LOF]AMTVATRCUR : # FQ98116
            Elsif GCNXCURIAS = GCNXCURCPF
              # Même devise que la devise PCG
              [M:LOF6]AMTNOTIASS(nolign-1)  = [F:LOF]AMTNOTCPY
              [M:LOF6]AMTVATIASS(nolign-1)  = [F:LOF]AMTVATCPY  : # FQ98116
              [M:LOF6]AMTVATRIASS(nolign-1) = [F:LOF]AMTVATRCPY : # FQ98116
            Else
              # Il faut convertir
              MNTDES = 0
              Call CONVERT3([F:LOF]CUR,
&                          GCNXCURIAS,
&                          GCNXCURCPF,
&                          [F:LOF]CURTYP,
&                          [F:LOF]DATVCR,
&                          [F:LOF]AMTNOTCUR,
&                          MNTDES,
&                          0,
&                          STAT) From CPTSUB
              If STAT
                Infbox(mess(34,110,1)-[F:LOF]CODLOF-num$([F:LOF]LINLOF)-[F:LOF]CUR-GCNXCURIAS-num$(STAT))
              Endif
              Call GET_MNT_ARRONDI (MNTDES, GCNXCURIAS, MNTDES) From GLOBIENS
              [M:LOF6]AMTNOTIASS(nolign-1) = MNTDES
              #----------------------- FQ98116
              MNTDES = 0
              Call CONVERT3([F:LOF]CUR,
&                          GCNXCURIAS,
&                          GCNXCURCPF,
&                          [F:LOF]CURTYP,
&                          [F:LOF]DATVCR,
&                          [F:LOF]AMTVATCUR,
&                          MNTDES,
&                          0,
&                          STAT) From CPTSUB
              If STAT
                Infbox(mess(34,110,1)-[F:LOF]CODLOF-num$([F:LOF]LINLOF)-[F:LOF]CUR-GCNXCURIAS-num$(STAT))
              Endif
              Call GET_MNT_ARRONDI (MNTDES, GCNXCURIAS, MNTDES) From GLOBIENS
              [M:LOF6]AMTVATIASS(nolign-1) = MNTDES
              #----------------------- FQ98116
              MNTDES = 0
              Call CONVERT3([F:LOF]CUR,
&                          GCNXCURIAS,
&                          GCNXCURCPF,
&                          [F:LOF]CURTYP,
&                          [F:LOF]DATVCR,
&                          [F:LOF]AMTVATRCUR,
&                          MNTDES,
&                          0,
&                          STAT) From CPTSUB
              If STAT
                Infbox(mess(34,110,1)-[F:LOF]CODLOF-num$([F:LOF]LINLOF)-[F:LOF]CUR-GCNXCURIAS-num$(STAT))
              Endif
              Call GET_MNT_ARRONDI (MNTDES, GCNXCURIAS, MNTDES) From GLOBIENS
              [M:LOF6]AMTVATRIASS(nolign-1) = MNTDES
            Endif
          Else
            [M:LOF6]AMTNOTIASS(nolign-1)  = [F:LOF]AMTNOTIAS
            [M:LOF6]AMTVATIASS(nolign-1)  = [F:LOF]AMTVATIAS  : # FQ98116
            [M:LOF6]AMTVATRIASS(nolign-1) = [F:LOF]AMTVATRIAS : # FQ98116
          Endif
        Endif
        [M:LOF6]DESS(nolign-1)       = [F:LOF]DES
        [M:LOF6]ACGGRPS(nolign-1)    = [F:LOF]ACGGRP
        [M:LOF6]AMTNOTCURS(nolign-1) = [F:LOF]AMTNOTCUR
        [M:LOF6]CURCPYS(nolign-1)    = GCNXCURCPF     : # FQ84794
        [M:LOF6]CURIASS(nolign-1)    = GCNXCURIAS     : # FQ84794
        [M:LOF6]CURS(nolign-1)       = [F:LOF]CUR     : # FQ84794
        #------------------------------
        [M:LOF6]SELFLG(nolign-1)    = G_NON
        nolign += 1
        If ( nolign > min(dim([M:LOF6]CODLOFS),dim([M:LOF6]CODLOF))-1  )
          # "Nombre de lignes maximum dépassé"
          Call MESSAGE(mess(54,126,1)) From GESECRAN
          Break
        Endif
     Endif
  Next
  # <<<<<<<<<<<<<<<<<<<<<<<<<<<<<
  [M:LOF6]NBSRCE = nolign-1

Return
#-------------------------------------------------------------------------------
$LIRE_DEPENSE_PRIN

  If ( ([F:LOFP]CODLOF<>[M:LOF6]CODLOF(LCURLINE-1) or [F:LOFP]LINLOF<>[M:LOF6]LINLOF(LCURLINE-1)) and
&      [M:LOF6]MAIVCR(LCURLINE-1)=G_OUI  )
    Raz [LOFP]
    Read [LOFP]LOF0=[M:LOF6]CODLOF(LCURLINE-1);[M:LOF6]LINLOF(LCURLINE-1)
  Endif

Return

#-------------------------------------------------------------------------------
$LIRE_PARLDAP_SOC
Local Integer N_I

  GLOFLDAB = ""
  #------------------------------
  Raz [LDA]
  Filter [LDA] Where CPY=GCOUSOC
  Read [LDA]LDA0 Last
  Filter [LDA]
  If ( fstat > 2 )
    # S'il n'existe pas sur la société on regarde en paramètre par défaut
    Filter [LDA] Where CPY=""
    Read [LDA]LDA0 Last
    Filter [LDA]
  Endif
  #------------------------------
  For N_I = 0 To [F:LDA]NBLDAP-1
    GLOFLDAB += "num$([F:LOF]"+[F:LDA]CODZON(N_I)+")"
    #------------------------------
    # Champ dimensionné : on supprime les parenthèse pour récupérer le type physique correctement
    Local Char LFIELD
    If pat([F:LDA]CODZON(N_I),"*(*")
     LFIELD=seg$([F:LDA]CODZON(N_I),1,instr(1,[F:LDA]CODZON(N_I),'(')-1)
    Else
     LFIELD=[F:LDA]CODZON(N_I)
    Endif
    #------------------------------
    GPARTYPPHY(N_I) = func GLOBIENS.GET_TYPE_PHYSIQUE ("LAYOUTFAS", LFIELD)
    #------------------------------
    # Suite de la boucle
  Next N_I
  #------------------------------
Return

#-------------------------------------------------------------------------------
$GET_CND_DEP_PRINC
Local Integer N_I, N_J
Local Char    CLASS(8) : # FQ60984

  LCOND = ""
  For N_J = 0 To 1
    LCONDA(N_J) = ""
  Next
  #- 1 -----------------------------------
  If ( [M:LOF6]NBDEST > 0 )
    # Le secteur d'activité doit être identique sur toutes les dépenses regroupées
    # Le taux de TVA récupérée doit être le même sur toutes les dépenses regroupées
    # Si le critère de rapprochement existe dans le bien, on utilise plutôt la valorisation du bien
    If GLOFPREAD=G_OUI and [F:LOFP]FLGLIKAAS=G_OUI : # FQ61251
      CLASS="[F:FAS]"
      # FQ106665 : Mêmes critères de rapprochement quelle que soit la législation
      LCOND="[F:LOF]FLGVAL=G_OUI & [F:LOF]ACT="+CLASS+"AASBUS"
    Else
      CLASS="[F:LOFP]"
      # FQ106665 : Mêmes critères de rapprochement quelle que soit la législation
      LCOND="[F:LOF]FLGVAL=G_OUI & [F:LOF]ACT="+CLASS+"ACT"
    Endif

    # FQ69052 04.07.2014 : suppression des critères de rapprochement concernant la TVA. Ces coefficients ne s'appliquant qu'à la France,
    #                      la condition est supprimée dans tous les cas
    ## Nouvelles règles TVA
    ## Les différents coefficients ( assuj., taxation, admission) doivent être identiques.
    #LCOND += " & [F:LOF]ASJCOE="+CLASS+"ASJCOE & [F:LOF]TAXCOE="+CLASS+"TAXCOE & [F:LOF]ADMCOE="+CLASS+"ADMCOE"

    If evalue(CLASS+"GACACN = GVML_NICHARG")
      # Si la nature PCG de la dépense principale est CHARGE, la nature PCG de toutes les dépenses
      # regroupées doit aussi être CHARGE
      If ( LCOND <> "" )
        LCOND += "&"
      Endif
      LCOND += "[F:LOF]GACACN=GVML_NICHARG"
    Endif

    If evalue("GCNXPROIAS = G_OUI and "+CLASS+"IASACN = GVML_NICHARG")
      # Si la nature IAS de la dépense principale est CHARGE, la nature IAS de toutes les dépenses
      # regroupées doit aussi être CHARGE
      If ( LCOND <> "" )
        LCOND += "&"
      Endif
      LCOND += "[F:LOF]IASACN=GVML_NICHARG"
    Endif

    N_J = 0

    For N_I = 0 To [F:LDA]NBLDAP-1
      If ( len(LCONDA(N_J)) > 180 )
        # La chaine est pleine, on change d'occurence
        N_J += 1

        If ( N_J > 1 )
          # Plus de place pour stocker les critères
          # Trop de critères dans le paramétrage "Lien Dépenses-Bien Comptable".
          Call MESSAGE(mess(66,GML_MSGLOF,1)) From GESECRAN
          LCONDA(N_J-1)="1=0" : # on empêche toute sélection de dépenses supplémentaires
          Break
        Endif
      Endif

      If ( LCONDA(N_J) <> "" )
        LCONDA(N_J) += "&"
      Endif
      If ( [F:LDA]ORNUL(N_I) = G_OUI and GPARTYPPHY(N_I) > 0 )
        LCONDA(N_J) += "("
      Endif

      # Si le critère de rapprochement existe dans le bien, on utilise plutôt la valorisation du bien
      If GLOFPREAD=G_OUI and [F:LOFP]FLGLIKAAS=G_OUI : # FQ61251
        If evalue("dim([F:FAS]"+[F:LDA]CODZON(N_I)+")")<0
          CLASS="[F:LOFP]"
        Else
          CLASS="[F:FAS]"
        Endif
      Else
        CLASS="[F:LOFP]"
      Endif

      LCONDA(N_J) += "[F:LOF]"+[F:LDA]CODZON(N_I)+"="+CLASS+[F:LDA]CODZON(N_I)

      If ( [F:LDA]ORNUL(N_I) = G_OUI and GPARTYPPHY(N_I) > 0 )
        LCONDA(N_J) += "|[F:LOF]"+[F:LDA]CODZON(N_I)+"="
        If ( GPARTYPPHY(N_I) = GNUMBER )
          # Numérique
          LCONDA(N_J) += "0"
        Elsif ( GPARTYPPHY(N_I) = GALPHA )
          # Alpha-numérique
          LCONDA(N_J) += "''"
        Elsif ( GPARTYPPHY(N_I) = GDATE )
          # Date
          LCONDA(N_J) += "[0/0/0]"
        Endif
        #------------------------------
        LCONDA(N_J) += ")"
      Endif
      #------------------------------
      # Suite de la boucle
    Next N_I
    #------------------------------
  Endif

  If ( LCOND = "" )
    LCOND = "1=1"
  Else
    LCOND = "("+LCOND+")"
  Endif

  For N_J = 0 To 1
    If ( LCONDA(N_J) = "" )
      LCONDA(N_J) = "1=1"
    Else
      LCONDA(N_J) = "("+LCONDA(N_J)+")"
    Endif
  Next
Return

#-------------------------------------------------------------------------------
$DELOCK_TBL_DEST
Local Integer N_I
Local Char LKEY(200)

  For N_I = 1 To [M:LOF6]NBDEST
    LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:LOF6]CODLOF(N_I-1), [M:LOF6]LINLOF(N_I-1))
    Call UNLOCK_SYMBOLE ("LOF", [M:FAS0]CPY, LKEY) From GLOBIENS
    #------------------------------
    # Suite de la boucle
  Next N_I

Return

################################################################################
# APPLIQUER LIAISON DEPENSE A BIEN
################################################################################
#-------------------------------------------------------------------------------
$APPLIQUER_LDAB

Local Integer N_I, N_E, J
Local Integer LMAXCHM : LMAXCHM = 200
Local Integer LNBTRAN, OK

Local Char    LCHMSRC  (10)(LMAXCHM) : # Champ source
Local Char    LCHMDES  (10)(LMAXCHM) : # Champ destination
Local Integer LCUMUL       (LMAXCHM) : # Champ à cumuler (uniquement pour les rubriques numériques)
Local Integer LLTTVLEG     (LMAXCHM) : # Champ transit si tt les valeurs sont identique à dépense principale
Local Integer LORNUL       (LMAXCHM) : # Associé à LLTTVLEG et si LLTTVLEG=OUI ou NULL
Local Integer LVIDPRI      (LMAXCHM) : # Vide ou Principal
Local Char    LCNTVAL(20)(0..LMAXCHM): # Constante
Local Integer LRUBMNT      (LMAXCHM) : # Rubriques montant (HT,TVA,TTC) mises à 1 sinon 0 permet de traiter l'IAS
Local Integer LTYPPHY      (LMAXCHM) : # Type physique du champ source (initialisé slt si LLTTVLEG=OUI et LVIDPRI=VIDE)
Local Integer LTTVEVID     (LMAXCHM) : # Si mis à 1 si condition non remplie du coup on vide LCHMDES et on ne le remplis plus
                                       # (utilisé slt si LLTTVLEG=OUI et LVIDPRI=VIDE)
Local Integer LPRIBCO      (LMAXCHM) : # Si mis à 2 le champ du BCO n'est pas alimenté par celui de la dépense lorsque
                                       # le bien a été crée en autonome et qu'on lui rattache une première dépense
Local Integer LERROR, LSTAT
Local Char    LCODGAC                : # Réception du code comptable
Local Integer FLGASS
Local Decimal LMNTCONV
Local Char    LBOITE

  Call TEMPON('C') From GESECRAN
  #------------------------------

  Gosub CHRG_PAR_TRANSIT_STD
  # >>>>>>>>>
  For N_I = 1 To [M:LOF6]NBDEST
    If ( [M:LOF6]MAIVCR(N_I-1) = G_OUI )
      # On relit la dépense principale pour être sur qu'elle soit bien en mémoire
      Raz [LOFP]
      Read [LOFP]LOF0=[M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)
      Break
    Endif
  Next N_I
  # <<<<<<<<<

  Raz LTTVEVID
  #> 1 >>>>>>>>>>>>>>>>>>>>>>>>>
  For N_I = 1 To [M:LOF6]NBDEST
    #- 2 ------------------
    If ( [M:LOF6]FLGLIKAAS(N_I-1) = G_NON )
      # Si on est en modif quand[M:LOF6]FLGLIKASS(N_I-1)=G_OUI c'est la dépense principale d'origine.
      # On ne refait rien la concernant
      #------------------------------
      Raz [LOF]
      Read [LOF]LOF0=[M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)
      If (fstat)
        GMESSAGE  = mess(28,GML_MSGLOF,1)-num$(fstat)
        GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
        GOK       = 0
        Call FSTA("LOF") From GLOCK
        Return
      Endif

      If ( [M:LOF6]MAIVCR(N_I-1) = G_OUI )
        [M:FAS1]ACGGRP = [M:LOF6]ACGGRPV   :  Affzo [M:FAS1]ACGGRP
        [M:FAS1]ACCCOD = [M:LOF6]ACCCODV   :  Affzo [M:FAS1]ACCCOD
        [M:FAS1]GACACN = [M:LOF6]GACACNV   :  Affzo [M:FAS1]GACACN
        [M:FAS1]GAC    = [M:LOF6]GACV      :  Affzo [M:FAS1]GAC
        [M:FAS1]IASACN = [M:LOF6]IASACNV   :  Affzo [M:FAS1]IASACN
        [M:FAS1]IASACC = [M:LOF6]IASACCV   :  Affzo [M:FAS1]IASACC

        # FQ67615
        If GW_LVA_TYP_PRIN > GVML_GLVAAUC and GREP = "C"
          If GW_LVA_TYP_PRIN = GVML_GLVALVA
            [M:FAS1]CMPSTA = GVML_SBLVA
          Elsif GW_LVA_TYP_PRIN = GVML_GLVAPOOL
            [M:FAS1]CMPSTA = GVML_SBPOOL
          Endif
        Endif
      Endif
      #> 3 >>>>>>>>>>>>>>>>>>>>>
      For N_E = 0 To LNBTRAN
        If not(((LPRIBCO(N_E) = G_OUI) & (GREP <> "C") & (GLOFPREAD   = G_NON))
&           or ((GLOFPREAD    = G_OUI) & (GREP <> "C") & (LCUMUL(N_E) = G_NON)))
          # - On ne traite pas les imputations si le bien a été crée en autonome et qu'on lui rattache
          #   une première dépense
          # - On ne traite que les cumuls si le bien a été créé et possède déjà une dépense principale

          If ( LCUMUL(N_E) = G_OUI )
            # On cumule
            # Ici faut faire gaffe aux montants PCG et IAS en fonction de la nature du compte :
            # On ne prend pas les montants si le compte est de charge
            If ( LRUBMNT(N_E) = 0 )
              # Toute rubrique numérique non identifiée comme étant un montant
              Assign '[M]'+LCHMDES(N_E) With evalue('[M]'+LCHMDES(N_E)) + evalue('[F:LOF]'+LCHMSRC(N_E))
            Else
              If LRUBMNT(N_E) = 1
                # Rubriques Montant PCG
                # -----------------------------------------------------------------------------------------
                # Pour prendre la valeur, il faut :
                #   Si le compte PCG de la dépense principale est :
                #       - Charge : alors on ne prend pas le montant de la dépense liée
                #                 (normalement on ne peut pas avoir sélectionné une dépense avec un compte
                #                  immo dans cette situation)
                #       - Immobilisation : alors on prend le montant de la dépense liée s'il est immo aussi
                #                 (ça, ça peut tout à fait se produire).
                # -----------------------------------------------------------------------------------------
                If [F:LOFP]GACACN <> GVML_NICHARG and [F:LOF]GACACN <> GVML_NICHARG
                  Assign '[M]'+LCHMDES(N_E) With evalue('[M]'+LCHMDES(N_E)) + evalue('[F:LOF]'+LCHMSRC(N_E))
                Endif
              Elsif LRUBMNT(N_E) = 2
               #Fq67577-Pologne
               If G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI)
                # Rubriques Montant IAS
                # -----------------------------------------------------------------------------------------
                #   Comportement idem ci-dessus, mais appliqué au compte IAS
                # ... en plus faut tenir compte de la devise du plan IAS qui peut être différente !
                # -----------------------------------------------------------------------------------------
                If [F:LOFP]IASACN <> GVML_NICHARG and [F:LOF]IASACN <> GVML_NICHARG
                   If GCNXCURIAS <> GCNXCURCPF  and GCNXCURIAS <> "" and  GCNXPROIAS = G_OUI
                     If [M:FAS1]IASRATCUR = 0
                       Call CDVCAL( [M:FAS1]IASRATCUR, GCOUDEV, GCNXCURIAS, GCOUSOC, [M:FAS1]IASCURTYP, [F:LOFP]DATVCR) From TRTDIV
                     Endif
                     Call CONVERT3( GCOUDEV, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [F:LOFP]DATVCR,
&                                  evalue('[F:LOF]'+LCHMSRC(N_E)), LMNTCONV, [M:FAS1]IASRATCUR,
&                                  LSTAT) From CPTSUB
                     Assign '[M]'+LCHMDES(N_E) With evalue('[M]'+LCHMDES(N_E)) + LMNTCONV
                   Else
                     Assign '[M]'+LCHMDES(N_E) With evalue('[M]'+LCHMDES(N_E)) + evalue('[F:LOF]'+LCHMSRC(N_E))
                   Endif
                Endif
               Endif #Fq67577-Fin
              Else
                # Bizarre on devrait jamais se retrouve ici, mais on prend tout !
                Assign '[M]'+LCHMDES(N_E) With evalue('[M]'+LCHMDES(N_E)) + evalue('[F:LOF]'+LCHMSRC(N_E))
              Endif
            Endif
          Else
            If LLTTVLEG(N_E) = G_NON   #---- "Même valeur" = NON
              If LCNTVAL(N_E) <> ""
                # on regarde s'il y a une constante, si oui on la prend
                If LTYPPHY(N_E) = GNUMBER
                  Assign '[M]'+LCHMDES(N_E) With val(LCNTVAL(N_E))
                Elsif LTYPPHY(N_E) = GALPHA
                  Assign '[M]'+LCHMDES(N_E) With num$(LCNTVAL(N_E))
                Elsif LTYPPHY(N_E) = GDATE
                  Assign '[M]'+LCHMDES(N_E) With evalue('['+LCNTVAL(N_E)+']')
                Endif
              Else
                # sinon on prend celle de la dépense principale
                # les infos analytiques du bien ont pu être modifiées,
                # on ne les écrase pas si on n'est pas en création.
                  #*Fq-79622 idem pour les dates dans le cas d'un rattachement de dépense à 1 bien non-valorisé
                  #*Fq-79622 If !(((LCHMDES(N_E) = "DSP") | (left$(LCHMDES(N_E),3) = "CCE")) and (GREP <> "C"))
                 If GREP <> "C"
                    If  ( ( LCHMDES(N_E) <> "DSP" ) and ( left$(LCHMDES(N_E),3) <> "CCE" ))  and
&                         ( LCHMDES(N_E) <> "PURDAT" )  and ( LCHMDES(N_E) <> "AASIPTDAT" ) and ( LCHMDES(N_E) <> "ITSDAT" )
                      Assign '[M]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
                    Endif
                 Else : # FQ80615
                    Assign '[M]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
                 Endif
              Endif
              #----
            Else  #---- "Même valeur"  = OUI
              If (LVIDPRI(N_E) = GVML_VPPRINC) or ([M:LOF6]NBDEST=1)
                 #*Fq-79622 pas de maj des dates si rattachement de dépense à 1 bien non-valorisé
                 If GREP <> "C"
                    If ( ( LCHMDES(N_E) = "DSP" ) or ( left$(LCHMDES(N_E),3) = "CCE" ))  or
&                      ( LCHMDES(N_E) = "PURDAT" )  or ( LCHMDES(N_E) = "AASIPTDAT" ) or( LCHMDES(N_E) = "ITSDAT" )
                    Else
                      # "Principale" ou bien une seule dépense ==> "Principale"
                      # Dans ce cas on prend tj la principale
                      Assign '[M]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
                    Endif  #*Fq-79622
                 Else
                # "Principale" ou bien une seule dépense ==> "Principale"
                # Dans ce cas on prend tj la principale
                Assign '[M]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
                 Endif
              Else
                # Dans ce cas il faut regarder si les valeurs sont différentes entre la principale
                # et les autres, et éventuellement on met vide si c'est différent
                # Tenir compte du cas où le paramétrage définit la valeur NULL
                # comme non différente de la principale
                #------------------------------
                If (LVIDPRI(N_E) = GVML_VPVIDE)
                  # Pas la peine de regarder si on sait déjà qu'avant c'était pas bon !
                  If evalue('[F:LOF]'+LCHMSRC(N_E)) <> evalue('[F:LOFP]'+LCHMSRC(N_E))
                    If LORNUL(N_E) = G_OUI
                      # Ca peut être nul : on regarde si c'est le cas !
                      If LTYPPHY(N_E) = GNUMBER
                        If evalue('[F:LOF]'+LCHMSRC(N_E)) = 0
                          LTTVEVID(N_E) = 1
                        Endif
                      Elsif LTYPPHY(N_E) = GALPHA
                        If evalue('[F:LOF]'+LCHMSRC(N_E)) = ""
                          LTTVEVID(N_E) = 1
                        Endif
                      Elsif LTYPPHY(N_E) = GDATE
                        If evalue('[F:LOF]'+LCHMSRC(N_E)) = [0/0/0]
                          LTTVEVID(N_E) = 1
                        Endif
                      Endif
                    Else
                      # Strictement identique : c'est pas le cas on efface !
                      LTTVEVID(N_E) = 1
                    Endif
                  Endif
                Endif
                #------------------------------
                If LTTVEVID(N_E) = 0
                  Assign '[M]'+LCHMDES(N_E) With evalue('[F:LOFP]'+LCHMSRC(N_E))
                Else
                  # On vide la rubrique
                  If LTYPPHY(N_E) = GNUMBER
                    Assign '[M]'+LCHMDES(N_E) With 0
                  Elsif LTYPPHY(N_E) = GALPHA
                    Assign '[M]'+LCHMDES(N_E) With ""
                  Elsif LTYPPHY(N_E) = GDATE
                    Assign '[M]'+LCHMDES(N_E) With [0/0/0]
                  Endif
                Endif
                #------------------------------
              Endif
            Endif
          Endif
          If left$(LCHMDES(N_E), 7) = 'USRFLDA'
            Call GERE_REFTAB (LCHMDES(N_E), evalue('[M]'+LCHMDES(N_E))) From SUBFRZ
          Endif
        Endif
      Next N_E

#     # FQ90968 : déjà fait ci-dessous par [M:FAS1]IASETRNOT += [M:LOF6]CUMAMTIAS
#      # FQ84794
#      If (GCNXPROIAS = G_OUI) and (G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI))
#        # Rubriques Montant IAS
#        [M:FAS1]IASETRNOT  += [M:LOF6]AMTNOTIAS(N_I-1)
#
#        L_AMTVATIAS = [M:LOF6]AMTNOTIAS(N_I-1) * ([F:LOF]RATVAT / 100 )
#        Call GET_MNT_ARRONDI (L_AMTVATIAS, [M:LOF6]CURIAS(N_I-1), L_AMTVATIAS) From GLOBIENS
#        [M:FAS1]IVCVATAMTI += L_AMTVATIAS
#
#        L_AMTVATRIAS = L_AMTVATIAS * ([F:LOF]RATVATREC / 100 )
#        Call GET_MNT_ARRONDI (L_AMTVATRIAS, [M:LOF6]CURIAS(N_I-1), L_AMTVATRIAS) From GLOBIENS
#        [M:FAS1]DEDVATAMTI += L_AMTVATRIAS
#      Endif
      #< 3 <<<<<<<<<<<<<<<<<<<<

      #------------------------------ FQ94306
      GPOINT = "LOFTOFAS" : Gosub ENTREE From EXEFNC
    Endif
    #- 2 ------------------
  Next N_I
  #< 1 <<<<<<<<<<<<<<<<<

  # Issue 108951
  If (GREP = "C")
    For N_I = 0 To [M]NBRCCE-1
      If (find([M]DIE(N_I),[F:LOFP]DIE))
        [M]CCE(N_I) = [F:LOFP]CCE(find([M]DIE(N_I),[F:LOFP]DIE)-1)
      Endif
    Next
  Endif
  # End issue 108951

  GNBDEPLIEES = [M:LOF6]NBDEST
  #------------------------------
  # FQ98116 : en création, les montants du bien sont forcés.
  If ( GREP = "C" )
    [M:FAS1]IVCVATFLG  = G_OUI
    [M:FAS1]DEDVATFLG  = G_OUI
    If (GCNXPROIAS = G_OUI)
      [M:FAS1]IVCVATFLGI  = G_OUI
      [M:FAS1]DEDVATFLGI  = G_OUI
    Endif
  Endif
  #------------------------------
  If ( GREP = "C" )
    Call AM_PURDAT([M:FAS1]PURDAT) From SUBFAS
  Elsif (GLOFPREAD = G_NON)
    # Mise à jour des dates de référence de régul TVA et de +/- value dans le cas où on immobilise une dépense
    # sur un bien crée en autonome
    If (GKFR = G_OUI) : [M:FAS5]VATREGDAT = [M:FAS1]PURDAT : Endif # FQ57624
    [M:FAS4]GALREFDAT = [M:FAS1]PURDAT
  Endif
  #------------------------------
  If ( GBOITE = "DLOFLDAB" )  : # Utilisation du bouton "Appliquer" sur la fenêtre "Immobiliser Dépenses"
    LBOITE = SAVBOITE
  Else                        : # Utilisation du bouton "Appliquer" sur la fenêtre "Bien comptable"
    LBOITE = GBOITE
  Endif
  #------------------------------
  If GREP="C"
   Call GERER_ASSOCIATION([M:LOF6]ACGGRPV,"FAM","FAS",[M:FAS1]OWNTYP,LBOITE,FLGASS) From TRTASSO
   [M:FAS1]ACGGRP=[M:LOF6]ACGGRPV
   #FQ93763 Récupération "Immatriculable"
   Affzo [M:FAS1]ACGGRP

   If ([M:FAS1]ACCCOD <> "") & ([M:FAS1]ACCCOD <> [M:LOF6]ACCCODV)
     # "l'application de l'association va modifier l'imputation comptable saisie"
     Call MESSAGE(mess(371,GML_MSGFAS,1)) From GESECRAN
     [M:LOF6]ACCCODV = [M:FAS1]ACCCOD
     Affzo [M:LOF6]ACCCODV
     Call AM_ACCCODV([M:LOF6]ACCCODV)
     Affzo [M:FAS1]GACACN
     Affzo [M:FAS1]GAC
     Affzo [M:FAS1]IASACN
     Affzo [M:FAS1]IASACC
     Affzo [M:FAS1]ACGGRP
   Endif
   Call GERER_ASSOCIATION([M:FAS1]ACCCOD,"COD","FAS",[M:FAS1]OWNTYP, LBOITE,FLGASS) From TRTASSO
  Endif
  #------------------------------
  # FQ98116 : on relance le calcul du montant de TVA récupéré en cas d'ajout d'une dépense. Si le montant
  #           est forcé il ne se passera rien. Si le montant a été déforcé par modification d'un coefficient par exemple,
  #           Il est recalculé
  Gosub TVA_REC_PCG From SUBFAS
  #------------------------------ FQ81867
  #If (GCNXPROIAS = G_OUI) and (GLOFIASAMT = G_OUI) : # FQ90968
  If (GCNXPROIAS = G_OUI) and (G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI))
    If ( GREP = "C" ) : # FQ90968
      # En création, les associations jouées ci-dessus peuvent avoir modifié les coefficients d'assujettissement,
      # de taxation et d'admission, ce qui provoque un recalcul du montant IAS HT et fait perdre les modifications
      # éventuelles de l'utilisateur. En création on écrase le montant HT IAS par le cumul à l'écran, les coefficients
      # étant bien appliqués par les appels à TVA_FAC_IAS et TVA_REC_IAS de SUBFAS
      [M:FAS1]IASETRNOT   = [M:LOF6]CUMAMTIAS
      [M:FAS1]IVCVATAMTI  = [M:LOF6]CUMVATIAS    : # FQ98116
      [M:FAS1]DEDVATAMTI  = [M:LOF6]CUMVATRIAS   : # FQ98116
    Else
      [M:FAS1]IASETRNOT  += [M:LOF6]CUMAMTIAS
      [M:FAS1]IVCVATAMTI += [M:LOF6]CUMVATIAS    : # FQ98116
      If ([M:FAS1]DEDVATFLGI=G_OUI)              : # FQ98116
        [M:FAS1]DEDVATAMTI += [M:LOF6]CUMVATRIAS : # FQ98116
      Else                                       : # FQ98116
        Gosub TVA_REC_IAS From SUBFAS            : # FQ98116
      Endif
    Endif
  Endif
  #------------------------------
  If dim(GFLGASS)<0 : Global Integer GFLGASS : Endif  #Fq-88454
  GFLGASS = FLGASS                                    #Fq-88454

  # FQ115001
  If ( GREP = "C" and G_PLNIAS and [M:FAS1]IASRATCUR = 0 ) Then
    # ------------ Détermination du taux
    Call CDVCAL( [M:FAS1]IASRATCUR, [M:FAS1]ACGCUR, [M:FAS1]IASCUR, [M:FAS0]CPY,
&                [M:FAS1]IASCURTYP, [M:FAS1]PURDAT ) From TRTDIV
  Endif

  #------------------------------
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
  #------------------------------
  # Mise à jour des dates de début d'amortissement
  Local Integer I
  If (FLGASS=G_OUI) | ((GREP <> "C") & (GLOFPREAD = G_NON))
   For I = 1 To [M:FAS3]NBLIG1
    Case func TRTFAS.GET_DPRSTRDAT_TYP([M:FAS3]DPM(I-1), [M:FAS0]CPY)
     When GVML_TPURDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]PURDAT
     When GVML_TITSDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]ITSDAT
     When GVML_TACCDAT : [M:FAS3]STRDPRDAT(I-1) = [M:FAS1]AASIPTDAT
     When Default
    Endcase

    If [M:FAS3]DPRRAT(I-1)<> 0 and [M:FAS3]DPRDUR(I-1)= 0
      [M:FAS3]DPRRATFLG(I-1)= G_OUI
    Endif
    Affzo [M:FAS3]STRDPRDAT(I-1)
   Next I
  Endif
  #------------------------------
  #FQ94340 Updating the plan for provision for renewal
  If ( G_ACTCCN = G_OUI )
     For I = 1 To [M:FAS3]NBLIG1
        If [M:FAS3]DPRPLN(I-1) = G301CPT
           If clalev([F:RPR]) =0    : Local File CCNRPR        [RPR]    : Endif
           Local Decimal L_GLOCOE
           Read[RPR]RPR0 =[M:FAS0]AASREF;[M:FAS3]FIYENDDAT(I-1);[M:FAS3]PERENDDAT(I-1)
           If fstat=0
              #* Initial DPRBAS    =  [M:LOF6]CUMIMMVCR
              #* Updated DPRBAS    =  [M:LOF6]CUMPREVCR
              #* Gap               =  [M:LOF6]CUMAMTVCR
              # Purchase date in the fiscal current year
              If [M:FAS1]PURDAT >= [M:FAS3]FIYSTRDAT(I-1)
                 If [F:RPR]RNWVALFLG <> G_OUI
                    # Replacement amount start of exercise  = Updated DPRBAS
                    [F:RPR]STRRNWVAL = [M:LOF6]CUMPREVCR
                 Endif
           Else
              If [F:RPR]RNWVALFLG <> G_OUI and [M:LOF6]CUMIMMVCR <> 0
                 L_GLOCOE =   arr([F:RPR]STRRNWVAL/[M:LOF6]CUMIMMVCR , 0.000001)
                 # Replacement amount start of exercise = DPRBAS updated*New value coeff
                 [F:RPR]STRRNWVAL = [M:LOF6]CUMPREVCR*L_GLOCOE
              Endif
           Endif
           Rewrite [RPR]
           If fstat
              GMESSAGE  = mess(104,GML_MSGFAS,1)-"CCNRPR Fstat="-num$(fstat)+" "-[F:RPR]AASREF
              Call FSTA("RPR") From GLOCK
              Break
           Endif
        Endif
        Break
     Endif
   Next I
  Endif #FQ94340 END
  #------------------------------

  For I = 1 To [M:FAS3]NBLIG1
   [M:FAS3]DEPSTA(I-1)=GVML_SCNOCAL
   [M:FAS0]FLGCLC                            = G_OUI
   [M:FAS0]FLGCNXCLC([M:FAS3]CNX(I-1)-1)     = G_OUI
  Next I

  # FQ67615_8
  If (GREP = "C" and find( [M:FAS1]CMPSTA, GVML_SBLVA, GVML_SBPOOL )) Then
    [M:FAS2]DSP = ""
#    Local Integer N_S
#    For N_S = 1 To [M:FAS2]NBRCCE : CCE(N_S-1)= "" : Next
    Raz CCE
  Endif

  #------------------------------
  GOK    = 1
  GPOINT = "APLOFLDAB" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
  If GOK < 1 : Return : Endif
  #------------------------------
  Affzo [M:FAS0]1-99
  Affzo [M:FAS1]1-99
  Affzo [M:FAS2]1-99
  Affzo [M:FAS4]1-99
  If !clalev([M:FRZ9])
    Affzo [M:FAS9]1-99
  Else
    Affzo [M:FRZ9]1-99
  Endif
  #------------------------------
  Gosub RUBRIQUES_IMMO_DEPENSE From SUBFAS2
  #Fq-88454 ----------------------------------------
  If ( GREP = "C" and GFLGASS= G_OUI) Then
    #>>>>>>>>>>>>>>>>>
    For I = 1 To [M:FAS3]NBLIG1
      PLIGNE=I
      Call  RUBRIQUES_DETERMINEES_PMR(GVML_OMBIEN, [M:FAS0]CPY, "FAM", [M:FAS3]DPRPLN(I-1), "FAS3", PLIGNE) From TRTASSO
      Call  RUBRIQUES_DETERMINEES_PMR(GVML_OMBIEN, [M:FAS0]CPY, "COD", [M:FAS3]DPRPLN(I-1), "FAS3", PLIGNE) From TRTASSO
    Next I
    #<<<<<<<<<<<<<<<<<
  Endif #Fq-88454
  #------------------------------
  GLDABAPPL = G_OUI : # Appliqué
  #------------------------------
  Call TEMPOFF() From GESECRAN
  #------------------------------
Return

#-------------------------------------------------------------------------------
$CHRG_PAR_TRANSIT_STD

# LCHMSRC  : Champ source
# LCHMDES  : Champ destination
# LCUMUL   : Champ à cumuler (uniquement pour les rubriques numériques)
# LLTTVLEG : Champ transit si tt les valeurs sont identique à dépense principale
# LORNUL   : Associé à LLTTVLEG et si LLTTVLEG=OUI ou NULL
# LVIDPRI  : Vide ou Principal
# LCNTVAL  : Constante
# LRUBMNT  : Rubriques montant (HT,TVA,TTC) mises à 1 sinon 0 permet de traiter l'IAS
# LTYPPHY  : Type physique du champ source (initialisé slt si LLTTVLEG=OUI et LVIDPRI=VIDE)
# LTTVEVID : Si mis à 1 si condition non remplie du coup on vide LCHMDES et on ne le remplis plus
#            (utilisé slt si LLTTVLEG=OUI et LVIDPRI=VIDE)
# LPRIBCO  : Si mis à 2 le champ du BCO n'est pas alimenté par celui de la dépense lorsque
#            le bien a été crée en autonome et qu'on lui rattache une première dépense

  Local Integer N_I

  LNBTRAN =-1
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='DES'      : LCHMDES(LNBTRAN)='AASDES1'  : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPPRINC :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='DES2'     : LCHMDES(LNBTRAN)='AASDES2'  : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPPRINC :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='ORDBUY'   : LCHMDES(LNBTRAN)='ORDREF'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPVIDE  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='DATVCR'   : LCHMDES(LNBTRAN)='PURDAT'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPPRINC :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='DATIMP'   : LCHMDES(LNBTRAN)='AASIPTDAT': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPPRINC :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='DATVCR'   : LCHMDES(LNBTRAN)='ITSDAT'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPPRINC :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON

  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='UOM'      : LCHMDES(LNBTRAN)='AASUOM'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPPRINC :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='QTY'      : LCHMDES(LNBTRAN)='AASQTY'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON

  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='BPR'      : LCHMDES(LNBTRAN)='BPR'      : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPVIDE  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='IASCGU'   : LCHMDES(LNBTRAN)='IASCGU'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI

  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='DSP'      : LCHMDES(LNBTRAN)='DSP'      : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI

  # Issue 108951 La gestion des axes sort de cette mécanique
  #For N_I = 1 To GOPTCANA
  #  LNBTRAN = LNBTRAN + 1
  #  LRUBMNT(LNBTRAN)  = 0
  #  LCHMSRC(LNBTRAN)  = 'CCE('+num$(N_I-1)+')'
  #  LCHMDES(LNBTRAN)  = 'CCE('+num$(N_I-1)+')'
  #  LCUMUL(LNBTRAN)   = G_NON
  #  LLTTVLEG(LNBTRAN) = G_NON
  #  LORNUL(LNBTRAN)   = G_NON
  #  LVIDPRI(LNBTRAN)  = 0
  #  LCNTVAL(LNBTRAN)  = ""
  #  LPRIBCO(LNBTRAN)  = G_OUI
  #Next N_I
  # End issue 108951

# FQ98116 : les coefficients de TVA sont ceux de la dépense principale
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='ASJCOE'    : LCHMDES(LNBTRAN)='ASJCOE'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='TAXCOE'    : LCHMDES(LNBTRAN)='TAXCOE'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='TAXCOEFLG' : LCHMDES(LNBTRAN)='TAXCOEFLG': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="1": LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='ADMCOE'    : LCHMDES(LNBTRAN)='ADMCOE'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON

# FQ98116 : les taux de TVA facturée et récupérée sont ceux de la dépense principale
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='RATVAT'    : LCHMDES(LNBTRAN)='IVCVATRAT': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='FLGVATFCR' : LCHMDES(LNBTRAN)='IVCVATFLG': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="1" : LPRIBCO(LNBTRAN)=G_NON
# FQ98116 : DEDVATFLG est toujours forcé
#  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='FLGRECFVR' : LCHMDES(LNBTRAN)='DEDVATFLG': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
#& LCNTVAL(LNBTRAN)="1" : LPRIBCO(LNBTRAN)=G_NON

  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='RATVATREC' : LCHMDES(LNBTRAN)='DEDVATRAT': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0  :
& LCNTVAL(LNBTRAN)=""  : LPRIBCO(LNBTRAN)=G_NON

  # Traitement de la valorisation PCG
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=1 : LCHMSRC(LNBTRAN)='AMTNOTCPY' : LCHMDES(LNBTRAN)='ACGETRNOT': LCUMUL(LNBTRAN)=G_OUI: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=1 : LCHMSRC(LNBTRAN)='AMTVATCPY' :  LCHMDES(LNBTRAN)='IVCVATAMT': LCUMUL(LNBTRAN)=G_OUI: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=1 : LCHMSRC(LNBTRAN)='AMTVATRCPY': LCHMDES(LNBTRAN)='DEDVATAMT': LCUMUL(LNBTRAN)=G_OUI: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON

  If GCNXPROIAS = G_OUI
    # Traitement de la valorisation IAS
    # FQ98116 : les taux de TVA facturée et récupérée sont ceux de la dépense principale
    LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='RATVAT'     : LCHMDES(LNBTRAN)='IVCVATRATI': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0
& : LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
    LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='FLGVATFCR'  : LCHMDES(LNBTRAN)='IVCVATFLGI': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0
& : LCNTVAL(LNBTRAN)="1" : LPRIBCO(LNBTRAN)=G_NON
    LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='RATVATREC'  : LCHMDES(LNBTRAN)='DEDVATRATI': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0
& : LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
# FQ98116 : DEDVATFLGI est toujours forcé
#    LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='FLGRECFVR'  : LCHMDES(LNBTRAN)='DEDVATFLGI': LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0
#& : LCNTVAL(LNBTRAN)="1" : LPRIBCO(LNBTRAN)=G_NON

# FQ84794
#    If GLOFIASAMT <> G_OUI : # FQ81867
#      LNBTRAN+=1: LRUBMNT(LNBTRAN)=2 : LCHMSRC(LNBTRAN)='AMTNOTCPY'  : LCHMDES(LNBTRAN)='IASETRNOT' : LCUMUL(LNBTRAN)=G_OUI: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0
#&   : LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
#      LNBTRAN+=1: LRUBMNT(LNBTRAN)=2 : LCHMSRC(LNBTRAN)='AMTVATCPY'  : LCHMDES(LNBTRAN)='IVCVATAMTI': LCUMUL(LNBTRAN)=G_OUI: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0
#&   : LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
#      LNBTRAN+=1: LRUBMNT(LNBTRAN)=2 : LCHMSRC(LNBTRAN)='AMTVATRCPY' : LCHMDES(LNBTRAN)='DEDVATAMTI': LCUMUL(LNBTRAN)=G_OUI: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0
#&   : LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_NON
#    Endif
  Endif

  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='ACT'        : LCHMDES(LNBTRAN)='AASBUS'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='ACGGRP'     : LCHMDES(LNBTRAN)='ACGGRP'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_NON: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=0            :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI

  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='PLNINV'     : LCHMDES(LNBTRAN)='INVPLN'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPVIDE  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='BUDINV'     : LCHMDES(LNBTRAN)='BUDREF'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPVIDE  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='FIYBUD'     : LCHMDES(LNBTRAN)='BUDFIY'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPVIDE  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='DEMINV'     : LCHMDES(LNBTRAN)='INVREQ'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPVIDE  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  LNBTRAN+=1: LRUBMNT(LNBTRAN)=0 : LCHMSRC(LNBTRAN)='CONNUM'     : LCHMDES(LNBTRAN)='CONNUM'   : LCUMUL(LNBTRAN)=G_NON: LLTTVLEG(LNBTRAN)=G_OUI: LORNUL(LNBTRAN)=G_NON : LVIDPRI(LNBTRAN)=GVML_VPVIDE  :
& LCNTVAL(LNBTRAN)="" : LPRIBCO(LNBTRAN)=G_OUI
  #------------------------------
  # Issue 114002 : if we are not in creation we don't apply the free fields loading parameter
  If GREP <> "C" : Return : Endif

  Gosub CHRG_PAR_TRANSIT_SPE
  #------------------------------
  Raz LTYPPHY
  For N_I = 0 To LNBTRAN
    If (LLTTVLEG(N_I)=G_OUI and LVIDPRI(N_I)=GVML_VPVIDE) or LCNTVAL(N_I)<>""
      # Uniquement dans ce cas on aura besoin du type physique
      LTYPPHY(N_I) = func GLOBIENS.GET_TYPE_PHYSIQUE ("LAYOUTFAS", LCHMSRC(N_I))
    Endif
    #----------------------------
    # Suite de la boucle
  Next N_I
  #------------------------------
Return

#-------------------------------------------------------------------------------
$CHRG_PAR_TRANSIT_SPE
Local Char LIDENT

  #------------------------------
  # A ce point précis, [M:LOF6]CPY ne contient pas toujours la bonne société
  # ==> on ne lit pas le bon paramétrage car souvent le champ contient la société sur
  # laquelle on était positionné avant de démarrer la création du nouveau bien
  Call GET_IDENT_TZL ([M:FAS0]CPY, GVML_OMDEPEN, GVML_OMBIEN, LIDENT) From SUBTZL
  Read [TZL]TZL0=LIDENT
  If fstat
    # Si un paramétrage TZL n'existe pas sur la société, on le recherche par défaut
    Call GET_IDENT_TZL ("", GVML_OMDEPEN, GVML_OMBIEN, LIDENT) From SUBTZL
    Read [TZL]TZL0=LIDENT
    If fstat
      Return
    Endif
  Endif
  #------------------------------
  For [TZD] Where KEYTZL=LIDENT
    LNBTRAN          += 1
    LRUBMNT(LNBTRAN)  = 0
    LCHMSRC(LNBTRAN)  = [F:TZD]CODZONSRC
    LCHMDES(LNBTRAN)  = [F:TZD]CODZONDES
    LCUMUL(LNBTRAN)   = [F:TZD]CUM
    LLTTVLEG(LNBTRAN) = [F:TZD]ALLVALEQU
    LORNUL(LNBTRAN)   = [F:TZD]ORNUL
    LVIDPRI(LNBTRAN)  = [F:TZD]FREMAI
    LCNTVAL(LNBTRAN)  = [F:TZD]CNSVAL
    LPRIBCO(LNBTRAN)  = G_NON
    #----------------------------
    # Suite de la boucle
  Next
  #------------------------------
Return

#-------------------------------------------------------------------------------
$MARQUE_DEPENSE_LIEES
#-> Variables pour générations événements sur dépenses
Local Integer  MOD_NAT_PCG, MOD_ACC_PCG, MOD_NAT_IAS, MOD_ACC_IAS, CDRET, MOD_ACT
Local Integer  N_I
Global Integer G_SV_GACACN, G_SV_IASACN
Global Char    G_SV_GACACC, G_SV_IASACC
Global Char    G_FASACCCOD #*FQ95888
Local Date     WDATEFF, WACCDAT
Local Integer VB_CHANGED # FQ104360

  # FQ104360
  [L]VB_CHANGED = 0
  If GREP = "C" # only in fixed asset's creation : otherwise we can change
    Gosub VB_CHANGED
  Endif
  # end  FQ104360

  For N_I = 1 To [M:LOF6]NBDEST
    MOD_NAT_PCG = 0
    MOD_ACC_PCG = 0
    MOD_NAT_IAS = 0
    MOD_ACC_IAS = 0
    #------------------------------
    If [M:LOF6]FLGLIKAAS(N_I-1) = G_NON
      # Si on est en modif quand[M:LOF6]FLGLIKAAS(N_I-1)=2 c'est la dépense principale d'origine.
      # On ne refait rien la concernant
      #------------------------------
      Raz [LOF]
      Read [LOF]LOF0=[M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)
      #------------------------------
      If fstat
        # Erreur en lecture de la dépense
        GMESSAGE  = mess(28,GML_MSGLOF,1)-num$(STAT)
        GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
        GOK       = 0
        Call FSTA("LOF") From GLOCK
        Return
      Endif

        [F:LOF]AASREF    = [M:FAS0]AASREF
         # FQ85501
        #[F:LOF]FLGLIKAAS = G_OUI

        [F:LOF]FLGLOFMAI = [M:LOF6]MAIVCR(N_I-1)

        If [L]VB_CHANGED # FQ104360
          [F:LOF]FLGDETEXP = G_NON
        Else
          If [F:LOF]FLGDETEXP <> G_NON
            [F:LOF]FLGDETEXP = G_OUI
          Endif
        Endif

        #------------------------------
        # On planque les imputation d'origine pour pouvoir générer les bons événements
        G_SV_GACACN      = [F:LOF]GACACN
        G_SV_GACACC      = [F:LOF]GAC
        If GCNXPROIAS = G_OUI
          G_SV_IASACN    = [F:LOF]IASACN
          G_SV_IASACC    = [F:LOF]IASACC
        Endif
        #------------------------------
        #*FQ98116 Il ne faut pas recalculer les montants de TVA récupérée si le montant de TVA récupérée du bien est forcé
        If ([F:LOF]ACT = "") and ([M:FAS1]DEDVATFLG<>G_OUI)
          [F:LOF]ACT = [M:FAS1]AASBUS
          If  ([F:LOF]ASJCOE<>[M:FAS1]ASJCOE or [F:LOF]TAXCOE<>[M:FAS1]TAXCOE or [F:LOF]ADMCOE<>[M:FAS1]ADMCOE)
            [F:LOF]ASJCOE    = [M:FAS1]ASJCOE
            [F:LOF]TAXCOE    = [M:FAS1]TAXCOE
            [F:LOF]TAXCOEFLG = [M:FAS1]TAXCOEFLG
            [F:LOF]ADMCOE    = [M:FAS1]ADMCOE
            #> Récupération du nouveau taux
            Local Decimal LTXTVAREC
            Call TVA_COE_DEDUCTION ( [F:LOF]ASJCOE, [F:LOF]TAXCOE, [F:LOF]ADMCOE, LTXTVAREC ) From TRTFAS
            LTXTVAREC = LTXTVAREC * 100.
            If ( [F:LOF]RATVATREC <> LTXTVAREC )
              Global Decimal G_DEDVAT, G_CRBVAT, G_INIDEDAMT
              G_INIDEDAMT=[F:LOF]AMTVATRCPY
              Call GET_ELEM_REG_TVA([F:LOF]CPY) From TRTFAS
              Call REGUL_TVA_DEPENSE("FUNLOFLDAB", "[F:LOF]", [F:LOF]CPY, G_DEDVAT, [F:LOF]RATVATREC, G_INIDEDAMT, CDRET) From TRTFAS
              If ( CDRET )
                MOD_ACT = 0
                CDRET = 0  : # FQ85501
              Else
                If G_DEDVAT<0 : G_CRBVAT=abs(G_DEDVAT) : G_DEDVAT=0 : Endif
                MOD_ACT = 1
              Endif
              Kill G_ECIMPBAS, G_ECVARPRO, G_TENCOURS, G_REGULIAS
            Else
              MOD_ACT = 0
            Endif
          Endif
        Else
          MOD_ACT = 0
        Endif
        [F:LOF]FLGLIKAAS = G_OUI  :  # FQ85501
        # Si modif du secteur d'activité => modif du taux de récup de TVA :
        # Génération d'un événement de régul de TVA.
        If MOD_ACT
          If !clalev([F:MAS1])  : Local File LAYOUTFAS [MAS1] : Endif
          [F:MAS1]=[F:LOF]
          # FQ85501
          Call GENER_EVE(GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFVATREG1",[M:FAS1]AASIPTDAT,[0/0/0],CDRET) From GENEVE
          If CDRET > 20
            GMESSAGE  = mess(40,GML_MSGLOF,1)-"LOFVATREG1"-num$(CDRET) : # Erreur lors de la génération de l'événement PCG
            GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
            GOK       = 0
            Call FSTA("LOF") From GLOCK
            Return
          Endif
          If GCNXPROIAS = G_OUI
            # FQ85501
            Call GENER_EVE(GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFVATREG6",[M:FAS1]AASIPTDAT,[0/0/0],CDRET) From GENEVE
            If CDRET > 20
              GMESSAGE  = mess(41,GML_MSGLOF,1)-"LOFVATREG6"-num$(CDRET) : # Erreur lors de la génération de l'événement IAS
              GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
              GOK       = 0
              Call FSTA("LOF") From GLOCK
              Return
            Endif
          Endif
        Endif
        If dim(G_DEDVAT)>0    : Kill G_DEDVAT    : Endif
        If dim(G_CRBVAT)>0    : Kill G_CRBVAT    : Endif
        If dim(G_INIDEDAMT)>0 : Kill G_INIDEDAMT : Endif

        #------------------------------
        If GCNXPROIAS = G_OUI
          # S'il y a un plan IAS
          # Si les natures de compte et compte (PCG ou IAS) sont différents sur la dépense
          # de ce qui sera sur le bien, il faut recaler la dépense avec le bien
          #------------------------------
          If [F:LOF]GACACN = GVML_NIENSER or [F:LOF]GACACN  = GVML_NIENCOU
            If [F:LOF]GACACN <> [M:LOF6]GACACNV
              [F:LOF]GACACN = [M:LOF6]GACACNV
              [F:LOF]GACORI = [F:LOF]GAC      #*FQ-59892
              [F:LOF]GAC    = [M:LOF6]GACV
              MOD_NAT_PCG   = 1
            Elsif [F:LOF]GAC <> [M:LOF6]GACV
              [F:LOF]GACORI = [F:LOF]GAC       #*FQ-59892
              [F:LOF]GAC    = [M:LOF6]GACV
              MOD_ACC_PCG   = 1
            Endif
          Endif
          #------------------------------
          If [F:LOF]IASACN = GVML_NIENSER or [F:LOF]IASACN  = GVML_NIENCOU
            If [F:LOF]IASACN <> [M:LOF6]IASACNV
              [F:LOF]IASACN = [M:LOF6]IASACNV
              [F:LOF]IASACCORI = [F:LOF]IASACC   #*FQ-59892
              [F:LOF]IASACC = [M:LOF6]IASACCV
              MOD_NAT_IAS   = 1
            Elsif [F:LOF]IASACC <> [M:LOF6]IASACCV
              [F:LOF]IASACCORI = [F:LOF]IASACC   #*FQ-59892
              [F:LOF]IASACC = [M:LOF6]IASACCV
              MOD_ACC_IAS   = 1
            Endif
            #------------------------------ FQ84794
            # Stockage pour détachement de la valorisation IAS
            [F:LOF]AMTNOTIAS = [M:LOF6]AMTNOTIAS(N_I-1)

            #L_AMTVATIAS = [M:LOF6]AMTNOTIAS(N_I-1) * ([F:LOF]RATVAT / 100 )
            #Call GET_MNT_ARRONDI (L_AMTVATIAS, GCNXCURIAS, L_AMTVATIAS) From GLOBIENS
            #[F:LOF]AMTVATIAS = L_AMTVATIAS
            [F:LOF]AMTVATIAS = [M:LOF6]AMTVATIAS(N_I-1) : # FQ98116

            #L_AMTVATRIAS = L_AMTVATIAS * ([F:LOF]RATVATREC / 100 )
            #Call GET_MNT_ARRONDI (L_AMTVATRIAS, GCNXCURIAS, L_AMTVATRIAS) From GLOBIENS
            #[F:LOF]AMTVATRIAS = L_AMTVATRIAS
            [F:LOF]AMTVATRIAS = [M:LOF6]AMTVATRIAS(N_I-1) : # FQ98116
            #------------------------------ FQ84794
          Endif
        Else
          # S'il n'y a pas de plan IAS
          # Si les nature de compte et compte (PCG) sont différents sur la dépense
          # de ce qui sera sur le bien, il faut recaler la dépense avec le bien
          If [F:LOF]GACACN = GVML_NIENSER or [F:LOF]GACACN  = GVML_NIENCOU
            If [F:LOF]GACACN <> [M:LOF6]GACACNV
              [F:LOF]GACACN = [M:LOF6]GACACNV
              [F:LOF]GACORI = [F:LOF]GAC       #*FQ-59892
              [F:LOF]GAC    = [M:LOF6]GACV
              MOD_NAT_PCG   = 1
            Elsif [F:LOF]GAC <> [M:LOF6]GACV
              [F:LOF]GACORI = [F:LOF]GAC       #*FQ-59892
              [F:LOF]GAC    = [M:LOF6]GACV
              MOD_ACC_PCG   = 1
            Endif
          Endif
        Endif
        #------------------------------
        If MOD_NAT_PCG | MOD_ACC_PCG
           #*FQ-91554---------------------------
           If MOD_NAT_PCG
              WDATEFF = [M:FAS1]ITSDAT
              WACCDAT = max(WCNXDAT(3)  , [M:FAS1]ITSDAT)
           Else
              WDATEFF =  [M:FAS1]AASIPTDAT
              WACCDAT = WCNXDAT(3)
           Endif
           G_FASACCCOD  = [M:FAS1]ACCCOD  #*FQ95888
           #*FQ-91554---------------------------
           #*FQ-91554 WDATEFF = [M:FAS1]AASIPTDAT
           #*Fq-77197 WACCDAT = max(WCNXDAT(3)  , [M:FAS1]AASIPTDAT)
           #*FQ-91554 WACCDAT = WCNXDAT(3)
           Call GENER_EVE
&            (GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM1",WDATEFF,WACCDAT, CDRET)
&         From GENEVE
          If CDRET > 20
            # Erreur lors de la génération de l'événement PCG
            GMESSAGE  = mess(40,GML_MSGLOF,1)-num$(CDRET) :
            GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
            GOK       = 0
            Call FSTA("LOF") From GLOCK
            Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
            Return
          Endif
        Endif
        #------------------------------
        If MOD_NAT_IAS | MOD_ACC_IAS
           #*FQ-91554 WDATEFF = [M:FAS1]AASIPTDAT
           #*Fq-77197 WACCDAT = max(WCNXDATI(3), [M:FAS1]AASIPTDAT)
           #*FQ-91554 WACCDAT = WCNXDATI(3)
           #*FQ-91554 ----------------------------
           If MOD_NAT_IAS
              WDATEFF = [M:FAS1]ITSDAT
              WACCDAT = max(WCNXDATI(3)  , [M:FAS1]ITSDAT)
           Else
              WDATEFF = [M:FAS1]AASIPTDAT
              WACCDAT = WCNXDATI(3)
           Endif
           G_FASACCCOD  = [M:FAS1]ACCCOD  #*FQ95888
           #*FQ-91554---------------------------
          Call GENER_EVE
&            (GVML_OMDEPEN,[F:LOF]CPY,[F:LOF]FCY,[F:LOF]CODLOF,[F:LOF]LINLOF,"LOFCIM6", WDATEFF ,WACCDAT, CDRET)
&         From GENEVE
          If CDRET > 20
            # Erreur lors de la génération de l'événement IAS
            GMESSAGE  = mess(41,GML_MSGLOF,1)-num$(CDRET)
            GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
            GOK       = 0
            Call FSTA("LOF") From GLOCK
            Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
            Return
          Endif
        Endif
        #------------------------------
        If G_ACTKPL=G_OUI
           Gosub MARQUE_DEPENSE_LIEES From TRTFASMDR
        Endif
        #------------------------------
        #*FQ67615_8
        # Ventilation analytique des biens POOL ou LVA
        If ( find ([M:FAS1]CMPSTA, GVML_SBPOOL, GVML_SBLVA) > 0 ) Then
          Local Integer I_S
          Local Char    RAASDSP
          Local Char PDIE (3)  (0..19)
          Local Char PCCE (15) (0..19)
          For I_S = 1 To 20
            PDIE(I_S-1) = [F:LOF]DIE(I_S-1)
            PCCE(I_S-1) = [F:LOF]CCE(I_S-1)
          Next
          Local Char RERRMES(250)
          Call LVA_MAJ_ANALYTIQUE ( "+", [M:FAS0]AASREF, [M:FAS2]DSP, [M:FAS0]CPY, [M:FAS0]FCY, [F:LOF]DSP,
&              [M:FPC]NBDIE, PDIE, PCCE, [F:LOF]AMTNOTCUR, [F:LOF]CUR, RAASDSP, RERRMES )  From TRTFAS2
          If (RERRMES <> "") Then
            GMESSAGE = RERRMES
            GOK = 0
            Break
          Endif

          Local Integer B_DSP_EMPTY  : B_DSP_EMPTY = 0
          If (RAASDSP <> "" and func TRTFAS2.IS_DSP_EMPTY(RAASDSP)) Then
            B_DSP_EMPTY = 1
          Endif

          If ([F:FAS]DSP <> RAASDSP or B_DSP_EMPTY ) Then
            Read [FAS]FAS0=[M:FAS0]AASREF
            [F:FAS]DSP  = RAASDSP
            [M:FAS2]DSP = RAASDSP
            If (B_DSP_EMPTY) Then : [F:FAS]DSP = "": Endif
            Rewrite [FAS]
            If fstat
              # Erreur réécriture bien
              GMESSAGE  = mess(104,GML_MSGFAS,1)-"FXDASSETS Fstat="-num$(fstat)+" "-[F:FAS]AASREF
              Call FSTA("FAS") From GLOCK
              Return
            Endif
          Endif
        Endif

        Rewrite [LOF]
        If fstat
          # Erreur réécriture dépense
          GMESSAGE  = mess(27,GML_MSGLOF,1)-num$(STAT)
          GMESSAGE += ' '-num$([M:LOF6]CODLOF(N_I-1))-num$([M:LOF6]LINLOF(N_I-1))
          GOK       = 0
          Call FSTA("LOF") From GLOCK
          Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
          Return
        Endif
        #------------------------------
    Endif
    #------------------------------


    # Suite de la boucle
  Next N_I


  #Fq67577
  If G_ACTKPL=G_OUI
   [M:LOF6]MDRFLG=G_NON
  Endif

  Kill G_SV_GACACN, G_SV_IASACN, G_SV_GACACC, G_SV_IASACC
  Kill G_FASACCCOD  #*FQ95888
  #------------------------------
  Gosub DELOCK_TBL_DEST
  #------------------------------
Return

# FQ104360
# To know if (one of) the balance sheet values of fixed asset is changed.
$VB_CHANGED

Local Integer I_PLN, STAT # FQ100398/13
Local Decimal MTDES, WRATCUR

  # same algorithm as in $CALCUL_VALEUR_BILAN from TRTFAS
  For I_PLN = 1 To [M:FAS3]NBLIG1

    If [M:FAS3]DPRPLN(I_PLN-1) = G301SUB
    Else
      If [M:FAS3]ORIBAS(I_PLN-1) = GVML_OBIAS
        If [M:FAS3]DPRBAS(I_PLN-1) <> [M:FAS1]IASBSEVAL
          [L]VB_CHANGED = 1
          Break
        Endif
      Elsif [M:FAS3]ORIBAS(I_PLN-1) = GVML_OBSAI
      Else
        # FQ114606
        If ([M:FAS3]DEVORG(I_PLN-1) = "") Then : [M:FAS3]DEVORG(I_PLN-1) = [M:FAS1]ACGCUR : Endif
        # Détermination du taux
        Call CDVCAL( WRATCUR, [M:FAS3]DEVORG(I_PLN-1), [M:FAS3]CUR(I_PLN-1),
&                [M:FAS0]CPY, [M:FAS3]CURTYP(I_PLN-1), [M:FAS1]PURDAT  ) From TRTDIV

        If WRATCUR = 1
          If [M:FAS3]DPRBAS(I_PLN-1) <> [M:FAS1]ACGBSEVAL
            [L]VB_CHANGED = 1
            Break
          Endif

        Else

          # Conversion en devise plan
          MTDES = [M:FAS1]ACGBSEVAL
          Call CONVERT3([M:FAS3]DEVORG(I_PLN-1), [M:FAS3]CUR(I_PLN-1), GCOUDEV, [M:FAS3]CURTYP(I_PLN-1), [M:FAS1]PURDAT,
&                  MTDES, MTDES, WRATCUR, STAT) From CPTSUB

          If ( STAT = 0 )  Then
            Call GET_MNT_ARRONDI (MTDES, [M:FAS3]CUR(I_PLN-1), MTDES) From GLOBIENS
#       If G_ACTKPL=G_OUI & GREP<>"C" : Gosub MAJ_MDR_INF From TRTFASMDR : Endif #Fq67577-Pologne
#    Else
#       GERR= 1: GMESSAGE = mess(18,GML_MSGFAS,1)
#       mkstat = 2 : End
          Endif

          If [M:FAS3]DPRBAS(I_PLN-1) <> MTDES
            [L]VB_CHANGED = 1
            Break
          Endif

        Endif
      Endif
    Endif

  Next I_PLN

Return
################################################################################
# ACTIONS EXTERIEURES
################################################################################
#-------------------------------------------------------------------------------
$RAZ_PICKING

  #------------------------------
  Gosub DELOCK_TBL_DEST
  #------------------------------
  Raz [LOFP]
  [M:LOF6]NBDEST    = 0
  #YYFIN_MDJ_X3-8326 Call ACTION_BLOCK (ACB_EFFZO, "LOFLDAB", "MAIVCR") From GLOBIENS
  Effzo [M:LOF6]20
  #------------------------------
  [M:LOF6]ACCCODV   = ""
  [M:LOF6]GACACNV   = 0
  [M:LOF6]GACV      = ""
  [M:LOF6]IASACNV   = 0
  [M:LOF6]IASACCV   = ""
  [M:LOF6]ACGGRPV   = ""
  Affzo [M:LOF6]ACCCODV
  If dim([M:LOF6]ZACCCODV)>0  : Affzo [M:LOF6]ZACCCODV : Endif
  Call AFFICHE_COMPTES()
  #------------------------------
  [M:LOF6]CUMIMMVCR = 0
  [M:LOF6]CUMIMMIAS = 0
  [M:LOF6]CUMAMTVCR = 0
  [M:LOF6]CUMAMTIAS = 0
  [M:LOF6]CUMVATIAS = 0 : # FQ98116
  [M:LOF6]CUMVATRIAS= 0 : # FQ98116
  Affzo [M:LOF6]CUMAMTVCR
  Affzo [M:LOF6]CUMAMTIAS
  Affzo [M:LOF6]CUMIMMVCR
  Affzo [M:LOF6]CUMIMMIAS
  Call VALEUR_IMMO_ACT ()
  GLDABAPPL         = G_NON             : # Non appliqué
  GACCCOD_ASSO      = G_OUI             : # Pas déterminé par code comptable
  #------------------------------
  If !GIMPORT and currbox = LTI_DEPIMMO
    # Si on est en ajout de dépense sur un bien, on doit remettre la dépense principale
    # déjà stockée en base.
    Gosub READ_DEP_PRINCIPALE From FUNLOFLDAB
    Gosub FILGAUCHE From SUBFAS
    Gosub REMPLIT_3 From WGOFAS
     #YYFIN_MDJ_X3-8326 Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBDEST") From GLOBIENS
     Affzo [M:LOF6]20
  Endif
  #------------------------------
Return

#-------------------------------------------------------------------------------
$READ_DEP_PRINCIPALE
  # Paramètre autorisant le forçage du montant HT IAS FQ81867
  Global Integer GLOFIASAMT         :
  Local Char LPARM(10)
  Call PARAM("","LOFIASAMT",LPARM) From ADOVAL
  GLOFIASAMT = val(LPARM)
  #------------------------------
  GLOFPREAD         = G_NON
  GNBDEPLIEES       = 0
  #------------------------------
  [M:LOF6]CUMIMMVCR = 0
  [M:LOF6]CUMIMMIAS = 0
  [M:LOF6]CUMAMTVCR = 0
  [M:LOF6]CUMAMTIAS = 0
  [M:LOF6]CUMVATIAS = 0 : # FQ98116
  [M:LOF6]CUMVATRIAS= 0 : # FQ98116
  Affzo [M:LOF6]CUMAMTVCR
  Affzo [M:LOF6]CUMAMTIAS
  Affzo [M:LOF6]CUMIMMVCR
  Affzo [M:LOF6]CUMIMMIAS
  #------------------------------
  Raz [LOFP]
  Filter [LOFP] Where AASREF=[M:FAS0]AASREF & FLGLIKAAS=G_OUI & FLGLOFMAI=G_OUI
  #Read [LOFP]LOF0 Last : # FQ60710
  Read [LOFP] First Hint Key LOF6
  Filter [LOFP]
  #------------------------------
  If fstat>2
    # Il n'y a pas de dépense liée au bien : le bien a été créé indépendemment de tout
    GLOFPREAD       = G_NON
    GINDLOFPRI      = -1
    GNBDEPLIEES     = 0
  Else
    # Le bien est lié à une (plusieurs) dépense(s) : on relit la dépense principale
    GLOFPREAD       = G_OUI
    [M:LOF6]CPY     = [M:FAS0]CPY
    [M:LOF6]FCY     = [M:FAS0]FCY
    Affzo [M:LOF6]FCY
    Affzo [M:LOF6]CPY

    [M:LOF6]ACCCODV = [M:FAS1]ACCCOD
    [M:LOF6]GACACNV = [M:FAS1]GACACN
    [M:LOF6]GACV    = [M:FAS1]GAC
    [M:LOF6]IASACNV = [M:FAS1]IASACN
    [M:LOF6]IASACCV = [M:FAS1]IASACC
    [M:LOF6]ACGGRPV = [M:FAS1]ACGGRP
    Affzo [M:LOF6]ACCCODV
    Affzo [M:LOF6]GACACNV
    Affzo [M:LOF6]GACV
    Affzo [M:LOF6]IASACNV
    Affzo [M:LOF6]IASACCV
    Affzo [M:LOF6]ACGGRPV

    Gosub LIRE_PARLDAP_SOC
    [F:LOF] = [F:LOFP]
    Call AJOUTE_UNE_DEPENSE ()
    LCURLINE        = [M:LOF6]NBDEST
    GINDLOFPRI      = LCURLINE
    #------------------------------
    # Lecture de toutes les dépenses déjà immobilisées sur le bien
    For [LOF] Hint Key LOF6 Where [F:LOF]AASREF=[M:FAS0]AASREF &[F:LOF]FLGLIKAAS=G_OUI &FLGLOFMAI=G_NON
      Call AJOUTE_UNE_DEPENSE ()
      #------------------------------
      # Suite de la boucle
    Next
    #------------------------------
    GNBDEPLIEES = [M:LOF6]NBDEST
  Endif
Return

#-------------------------------------------------------------------------------
$SET_PICKING_QVB
# Positionne en coché les dépenses qui vont bien
Local Integer N_I

  For N_I = 1 To [M:LOF6]NBDEST
    If [M:LOF6]FLGLIKAAS(N_I-1) = G_NON
      [F:LO2]CPY    = [M:LOF6]CPY
      [F:LO2]FCY    = [M:LOF6]FCY
      [F:LO2]CODLOF = [M:LOF6]CODLOF(N_I-1)
      [F:LO2]LINLOF = [M:LOF6]LINLOF(N_I-1)
      Gosub REPICK From WGOFAS : # Resélectionne la ligne identifiée dans [LOF]
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I
Return


# CBO FQ67615
# contrôle des autres dépenses (non principale)
$CTRL_LVA_AUTRE

  If GW_LVA_TYP_PRIN = GVML_GLVAPOOL

    GMESSAGE = ""
    Local Integer WRES, WG_LVA_TYP_AUT
    GERR = 0
#GFASLEDSOC [M:FPC]COA(0)
    WG_LVA_TYP_AUT = func GLOBIENS.GET_LVATYP_FROM_GAC ([M:LOF6]GACS(PLIGNE-1), [M:FPC]COA(0))
    If WG_LVA_TYP_AUT > GVML_GLVAAUC and WG_LVA_TYP_AUT <> GW_LVA_TYP_PRIN
# laisser tmp celui là comme ça...
      GMESSAGE = "La dépense est sur un compte incompatible avec celui de la dépense principale."
      GERR= 1
      mkstat = 2
      Return
    Endif

    If [F:LOFP]DATIMP < GWDATSTRFIY or [F:LOFP]DATIMP > GWDATENDFIY
#      GMESSAGE = "La dépense est dans un exercice différent de celui de la dépense principale."
      GMESSAGE = mess(95, GML_MSGLOF, 1)
      GERR= 1
      mkstat = 2
      Return
    Endif

    If [M:LOF6]AMTNOTCPYS(PLIGNE-1) > GWLVALIM and GWDEJAMSGDEPASSE = 0
#      Wrnbox "Le montant de la dépense dépasse le seuil, confirmez-vous ?" Using WRES
      Wrnbox mess(96, GML_MSGLOF, 1) Using WRES
      If WRES <> 1
        GERR = 1
        Return
      Endif
      If GWMSGUNIQUE = G_OUI
        GWDEJAMSGDEPASSE = 1
      Endif
    Endif

  Elsif GW_LVA_TYP_PRIN = GVML_GLVALVA

    GMESSAGE = ""
    Local Integer WRES, WG_LVA_TYP_AUT
    GERR = 0

    WG_LVA_TYP_AUT = func GLOBIENS.GET_LVATYP_FROM_GAC ([M:LOF6]GACS(PLIGNE-1), [M:FPC]COA(0))
  # si prin = LVA  : si dépense > - si total > - si même type
    If WG_LVA_TYP_AUT > GVML_GLVAAUC and WG_LVA_TYP_AUT <> GW_LVA_TYP_PRIN
# laisser tmp celui là comme ça...
      GMESSAGE = "La dépense est sur un compte incompatible avec celui de la dépense principale."
      GERR= 1
      mkstat = 2
      Return
    Endif

    If [F:LOFP]DATIMP < GWDATSTRFIY or [F:LOFP]DATIMP > GWDATENDFIY
#      GMESSAGE = "La dépense est dans un exercice différent de celui de la dépense principale."
      GMESSAGE = mess(95, GML_MSGLOF, 1)
      GERR= 1
      mkstat = 2
      Return
    Endif

    If [M:LOF6]AMTNOTCPYS(PLIGNE-1) > GWLVALIM and GWDEJAMSGDEPASSE = 0
#      Wrnbox "Le montant de la dépense dépasse le seuil, confirmez-vous ?" Using WRES
      Wrnbox mess(96, GML_MSGLOF, 1) Using WRES
      If WRES <> 1
        GERR = 1
        Return
      Endif
      If GWMSGUNIQUE = G_OUI
        GWDEJAMSGDEPASSE = 1
      Endif
    Endif

    If ([M:LOF6]CUMPREVCR + [M:LOF6]AMTNOTCPYS(PLIGNE-1)) > GWLVALIM and GWDEJAMSGDEPASSE = 0
#      Wrnbox "La valeur immobilisée actualisée est supérieure au seuil, confirmez-vous ?" Using WRES
      Wrnbox mess(97, GML_MSGLOF, 1) Using WRES
      If WRES <> 1
        GERR = 1
        Return
      Endif
      If GWMSGUNIQUE = G_OUI
        GWDEJAMSGDEPASSE = 1
      Endif
    Endif

  Endif

Return

Funprog CTRL_LVA_PRINCIPAL(PLEG, PCOA, PACC, PCPY, PCNX, PDATIMP,
& PMONTANT, RLVATYP, RLVALIM,
& RDATSTRFIY, RDATENDFIY)
Value Char PLEG(), PCOA(), PACC(), PCPY()
Value Integer PCNX
Value Date PDATIMP
Value Decimal PMONTANT
Variable Integer RLVATYP, RLVALIM
Variable Date RDATSTRFIY, RDATENDFIY

Local Integer WRES
  # règles uniquement sur les législations GER et AUT
  If (PLEG <> "GER" and PLEG <> "AUT")
    End 0
  Endif

  GMESSAGE = ""
# lecture du compte pour voir
# si dépend de LVA POOL
# si Ok pour le ctx ds l'exercice
  If !clalev([F:GAC])
    Local File GACCOUNT [GAC]
  Endif
  Read [GAC]GAC0 = PCOA; PACC
  If fstat
    GMESSAGE = mess(044, 102, 1)
    GERR = 1
    End -1
  Endif

  # Ce n'est pas un compte concerné
  If [F:GAC]LVATYP <= GVML_GLVAAUC
    End 0
  Endif

  If !clalev([F:FIS])
    Local File FISCYEAR [FIS]
  Endif

  Filter [FIS] Where CPY = PCPY and CNX = PCNX and DATSTRFIY <= PDATIMP and DATENDFIY >= PDATIMP
  Read [FIS]FIY0 First
  If fstat
    Filter [FIS]
    GMESSAGE = mess(052, 116, 1)

    GERR = 1
    End -1
  Endif
  Filter [FIS]
  If [F:GAC]LVATYP <> [F:FIS]LVATYP
#    GMESSAGE = "Le type LVA du compte est différent de celui de l'exercice du contexte comptable."
    GMESSAGE = mess(98, GML_MSGLOF, 1)
    GERR = 1
    End 1
  Endif

  # Interdiction de créer un 2° bien pool dans un exercice
  If GREP = "C" and [F:GAC]LVATYP = GVML_GLVAPOOL
    If func GLOBIENS.EXISTEBIENLVA(GVML_SBPOOL, [F:FIS]DATSTRFIY, [F:FIS]DATENDFIY, PCPY)
#      GMESSAGE = "Un bien de type Pool existe déjà dans l'exercice."
      GMESSAGE = mess(99, GML_MSGLOF, 1)
      GERR = 1
      mkstat = 2
      End 2
    Endif
  Endif

  # Avertissement pour un LVA si le montant dépasse la limite
#  If [F:FIS]LVATYP = GVML_GLVALVA and PMONTANT > [F:FIS]LVALIM and GWDEJAMSGDEPASSE = 0
  If PMONTANT > [F:FIS]LVALIM and GWDEJAMSGDEPASSE = 0
#    Wrnbox "Le montant de la dépense dépasse le seuil, confirmez-vous ?" Using WRES
    Wrnbox mess(96, GML_MSGLOF, 1) Using WRES
    If WRES <> 1
      GERR = 1
      End 3
    Endif
    If GWMSGUNIQUE = G_OUI
      GWDEJAMSGDEPASSE = 1
    Endif
  Endif

  # mémo des infos pour contrôler les autres liges
  RLVATYP = [F:FIS]LVATYP
  RLVALIM = [F:FIS]LVALIM
  RDATSTRFIY = [F:FIS]DATSTRFIY
  RDATENDFIY = [F:FIS]DATENDFIY
End 0

################################################################################
# SOUS-PROGRAMMES
################################################################################
########################################
Subprog IS_DEPENSE_COMPATIBLE (RCOMPAT)
# Controle la compatibilité de la dépense en [LOF] avec la dépense principale [LOFP]
# [LOF] et [LOFP] sont considérés comme lus
Variable Integer RCOMPAT

Local Integer N_I
Local Char LCOND(250)

  If [F:LOF]CODLOF = [F:LOFP]CODLOF and [F:LOF]LINLOF = [F:LOFP]LINLOF
    RCOMPAT = G_OUI
  Else
    RCOMPAT = G_OUI
    If [F:LOFP]GACACN = GVML_NICHARG and [F:LOF]GACACN <> GVML_NICHARG
      # Si la nature PCG de la dépense principale est CHARGE, la nature PCG de toutes les dépenses
      # regroupées doit aussi être CHARGE
      RCOMPAT = G_NON
      End
    Endif
    #
    If GCNXPROIAS = G_OUI and [F:LOFP]IASACN = GVML_NICHARG and [F:LOF]IASACN <> GVML_NICHARG
      # Si la nature IAS de la dépense principale est CHARGE, la nature IAS de toutes les dépenses
      # regroupées doit aussi être CHARGE
      RCOMPAT = G_NON
      End
    Endif
    #
    For N_I = 0 To [F:LDA]NBLDAP-1
      #------------------------------
      LCOND = ""
      #------------------------------
      If [F:LDA]ORNUL = G_OUI and GPARTYPPHY(N_I) > 0
        LCOND += "("
      Endif
      LCOND += "[F:LOF]"+[F:LDA]CODZON(N_I)+"=[F:LOFP]"+[F:LDA]CODZON(N_I)
      If [F:LDA]ORNUL = G_OUI and GPARTYPPHY(N_I) > 0
        LCOND += "|[F:LOF]"+[F:LDA]CODZON(N_I)+"="
        If GPARTYPPHY(N_I) = GNUMBER
          # Numérique
          LCOND += "0"
        Elsif GPARTYPPHY(N_I) = GALPHA
          # Alpha-numérique
          LCOND += "''"
        Elsif GPARTYPPHY(N_I) = GDATE
          # Date
          LCOND += "[0/0/0]"
        Endif
        #------------------------------
        LCOND += ")"
      Endif
      #------------------------------
      If evalue(LCOND) = 0
        RCOMPAT = G_NON
        Break
      Endif
      #------------------------------
      # Suite de la boucle
    Next N_I
  Endif
End

########################################
Subprog IS_REFERENCE_EXISTE (PCODLOF, PLINLOF, REXISTE)
Value Char PCODLOF
Value Integer PLINLOF
Variable Integer REXISTE

Local Integer N_I

  If [M:LOF6]NBDEST < min(dim([M:LOF6]CODLOFS),dim([M:LOF6]CODLOF))
    REXISTE = G_NON
    For N_I = 1 To [M:LOF6]NBDEST
      If [M:LOF6]CODLOF(N_I-1) = PCODLOF and [M:LOF6]LINLOF(N_I-1) = PLINLOF
        REXISTE = G_OUI
        Break
      Endif
      #------------------------------
      # Suite de la boucle
    Next N_I
  Else
    # On a rempli le tableau (max=999 lignes). On fait comme si la ligne existait déjà
    REXISTE = G_OUI
  Endif
End

########################################
Subprog AFFICHE_COMPTES()

  Affzo [M:LOF6]GACACNV
  Affzo [M:LOF6]GACV
  Affzo [M:LOF6]IASACNV
  Affzo [M:LOF6]IASACCV
  If dim([M:LOF6]ZGACV)>0  : Affzo [M:LOF6]ZGACV : Endif
  If dim([M:LOF6]ZIASACCV)>0  : Affzo [M:LOF6]ZIASACCV : Endif
End

########################################
Subprog AJOUTE_UNE_LIGNE (PLIGNE, PAFF_TOTAUX)
Value Integer PLIGNE            # °ligne de la dépense à ajouter
Value Integer PAFF_TOTAUX

Local Integer N_I               # nombre de dépenses déjà retenues
Local Integer J                 # n°ligne de la dépense principale
Local Integer LERROR
Local Integer STAT
Local Char LCODGAC
Local Char LKEY(200)
Local Decimal MNTIAS
Local Decimal RIASRATCUR

If  [M:LOF6]CODLOFS(PLIGNE-1)="" :  End  :   Endif

LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:LOF6]CODLOFS(PLIGNE-1), [M:LOF6]LINLOFS(PLIGNE-1))
If func GLOBIENS.LOCK_SYMBOLE ("LOF", [M:LOF6]CPY, LKEY, 0) = 0
  # l'enregistrement est locké ailleurs : on ne peut pas le choisir
  Infbox mess(34,GML_MSGLOF,1)-[M:LOF6]CODLOFS(PLIGNE-1)-num$([M:LOF6]LINLOFS(PLIGNE-1))
Else
  If G_ACTLEA=G_OUI and [M:FAS2]LEAREF <> ""
    MNTIAS = 0
    If G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI)
     If [M:LOF6]IASACNS(PLIGNE-1) = GVML_NIENCOU or [M:LOF6]IASACNS(PLIGNE-1) = GVML_NIENSER
       If ( GCNXPROIAS = G_OUI and [M:FAS1]IASCUR<> "" )
         # ------------- Conversion en devise IAS --------------------------------
         # 1 -  Détermination du taux en fonction du nouveau type de cours
         #------------------------------------------------------------------------
         RIASRATCUR = [M:FAS1]IASRATCUR
         If [M:FAS1]IASRATCUR = 0
           Call CDVCAL(RIASRATCUR, [M:FAS1]ACGCUR, [M:FAS1]IASCUR, [M:FAS0]CPY, [M:FAS1]IASCURTYP,
&                     [F:LOFP]DATVCR ) From TRTDIV
         Endif
         #------------------------------------------------------------------------
         # 2 - Conversion du montant en devise IAS
         #------------------------------------------------------------------------
           Call CONVERT3 ( GCOUDEV, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [F:LOFP]DATVCR,
&                         [M:LOF6]AMTNOTCPYS(PLIGNE-1), MNTIAS, RIASRATCUR, STAT) From CPTSUB
           If STAT = 0
             Call GET_MNT_ARRONDI (MNTIAS, [M:FAS1]IASCUR, MNTIAS) From GLOBIENS
           Endif
       Else
          MNTIAS = [M:LOF6]AMTNOTCPYS(PLIGNE-1)
       Endif
     Endif
    Endif #FQ67577 fin

    Local Decimal SCUMIASBSE
    Local Decimal SCUMRNT
    Read[LEA]LEA0 = [M:FAS2]LEAREF
    If fstat = 0
      SCUMIASBSE = [F:LEA]CUMIASBSE + [M:LOF6]CUMAMTIAS + MNTIAS
      SCUMRNT =  [F:LEA]CUMRNTAMT
      #FQ76672 Ctrl uniquement si FRADGI = "OUI" ==> si LEG ="FRA"
      If func GLOBIENS.FRADGI([M:FAS0]CPY)
        If SCUMRNT <  SCUMIASBSE
          #Le cumul des bases des biens rattachés au contrat de location dépasse le cumul des redevances du contrat.
          GERR= 1: GMESSAGE = mess(806,GML_MSGFAS,1)
          mkstat = 2
          End
        Endif
      Endif
    Endif
  Endif

  #------------------------------
  N_I = [M:LOF6]NBDEST+1
  If N_I = 1
    [M:LOF6]MAIVCR(N_I-1)  = G_OUI
    GINDLOFPRI             = N_I
  Else
    [M:LOF6]MAIVCR(N_I-1)  = G_NON
    If (GREP = "C")
        J = find(G_OUI, [M:LOF6]MAIVCR(0..[M:LOF6]NBDEST))
        #**************************************************************************************
        # La dépense principale cochée peut être remplacée par la dépense ajoutée
        # en fonction des nature de cette nouvelle dépense
        # test si la dépense à ajouter a mêmes imputations que la dépense principale
        #**************************************************************************************
        If J <> 0  & ([M:LOF6]GACACN(J-1) <> [M:LOF6]GACACNS(PLIGNE-1)  or  [M:LOF6]IASACN(J-1) <> [M:LOF6]IASACNS(PLIGNE-1))
&                  & GLDABAPPL = G_NON
          #**=======================================================================
          #** 1- la dépense principale actuelle n'a aucune nature "en service"
          #**=======================================================================
          If [M:LOF6]GACACN(J-1) <> GVML_NIENSER &  [M:LOF6]IASACN(J-1) <> GVML_NIENSER
            If [M:LOF6]GACACNS(PLIGNE-1) = GVML_NIENSER and [M:LOF6]IASACNS(PLIGNE-1) = GVML_NIENSER
              #***======================================================
              #*** 1a la nouvelle dépense a les 2 natures "en service"
              #***======================================================
              [M:LOF6]MAIVCR(N_I-1)     = G_OUI
              GINDLOFPRI               = N_I
              # l'ancienne dépense principale est déclassée
              [M:LOF6]MAIVCR(J-1)       = G_NON
            Else
              If [M:LOF6]GACACNS(PLIGNE-1) = GVML_NIENSER or [M:LOF6]IASACNS(PLIGNE-1) = GVML_NIENSER
                #***==========================================================
                #*** 1b la nouvelle dépense a au moins une nature "en service"
                #***==========================================================
                If [M:LOF6]GACACNS(PLIGNE-1) = GVML_NIENSER & [M:LOF6]IASACNS(PLIGNE-1) <> GVML_NIENSER
                  #***
                  # - 1b1 c'est la nature PCG qui est "en service"
                  #***
                  # la nouvelle dépense devient la principale
                  [M:LOF6]MAIVCR(N_I-1)     = G_OUI
                  GINDLOFPRI               = N_I
                  # l'ancienne dépense principale est déclassée
                  [M:LOF6]MAIVCR(J-1)       = G_NON
                Else
                  If [M:LOF6]GACACNS(PLIGNE-1) <> GVML_NIENSER and [M:LOF6]IASACNS(PLIGNE-1) =  GVML_NIENSER
                    #***
                    # - 1b2 c'est la nature IAS/IFRS qui est "en service"
                    #***
                    # la nouvelle dépense devient la principale
                    [M:LOF6]MAIVCR(N_I-1)     = G_OUI
                    GINDLOFPRI               = N_I
                    # l'ancienne dépense principale est déclassée
                    [M:LOF6]MAIVCR(J-1)       = G_NON
                  Endif # fin 1c
                Endif
              Else
              # Remplacement à tort d'une dépense principale en cours/en cours par une dépense en cours/charge
                 If [M:LOF6]GACACN(J-1) <>  GVML_NIENCOU or  [M:LOF6]IASACN(J-1) <>  GVML_NIENCOU
&                  & ([M:LOF6]GACACNS(PLIGNE-1) = GVML_NIENCOU & [M:LOF6]IASACNS(PLIGNE-1) =  GVML_NIENCOU)
                  # la nouvelle dépense devient la principale
                  [M:LOF6]MAIVCR(N_I-1)     = G_OUI
                  GINDLOFPRI               = N_I
                  # l'ancienne dépense principale est déclassée
                  [M:LOF6]MAIVCR(J-1)       = G_NON
                Endif
              Endif
            Endif
          Else
            #**=======================================================================
            #** 2- la dépense principale actuelle a une nature IFRS "en service"
            #**=======================================================================
            If [M:LOF6]GACACN(J-1) <> GVML_NIENSER &  [M:LOF6]IASACN(J-1) = GVML_NIENSER
              #***==========================================================
              #*** 2a la nouvelle dépense a une nature PCG "en service"
              #***==========================================================
              If [M:LOF6]GACACNS(PLIGNE-1) = GVML_NIENSER
                # la nouvelle dépense devient la principale
                [M:LOF6]MAIVCR(N_I-1)     = G_OUI
                 GINDLOFPRI               = N_I
                # l'ancienne dépense principale est déclassée
                [M:LOF6]MAIVCR(J-1)       = G_NON
              Endif
            Else
              #**=======================================================================
              #** 3- la dépense principale actuelle a une nature PCG "en service"
              #**=======================================================================
              If [M:LOF6]GACACN(J-1) = GVML_NIENSER &  [M:LOF6]IASACN(J-1) <>  GVML_NIENSER
                #***==========================================================
                #*** 3a la nouvelle dépense a une nature IFRS "en service"
                #***==========================================================
                If [M:LOF6]IASACNS(PLIGNE-1) = GVML_NIENSER
                  # la nouvelle dépense devient la principale
                  [M:LOF6]MAIVCR(N_I-1)     = G_OUI
                  GINDLOFPRI               = N_I
                  # l'ancienne dépense principale est déclassée
                  [M:LOF6]MAIVCR(J-1)       = G_NON
                Endif
              Else
                #**===========================================================================
                #** 4- la dépense principale a une nature PCG et une nature IFRS "en service"
                #**===========================================================================
                # on ne la remplace pas par la nouvelle dépense
                [M:LOF6]MAIVCR(N_I-1)       = G_NON
              Endif
            Endif
          Endif
        Endif
    Endif
  Endif

  # CBO FQ67615
  Read [LOFP]LOF0 = [M:LOF6]CODLOFS(PLIGNE-1) ; [M:LOF6]LINLOFS(PLIGNE-1)

  If ([M:LOF6]MAIVCR(N_I-1) = G_OUI)
    GWVIALIGNE = 1
    If func CTRL_LVA_PRINCIPAL([M:FPC]LEG, [M:FPC]COA(0), [M:LOF6]GACS(PLIGNE-1),
&     [M:LOF6]CPY, G300CPFI, [F:LOFP]DATIMP,
&     [M:LOF6]AMTNOTCPYS(PLIGNE-1),
&     GW_LVA_TYP_PRIN, GWLVALIM, GWDATSTRFIY, GWDATENDFIY)

      GWVIALIGNE = 0
# Issue X3-57687
      [M:LOF6]SELFLG(PLIGNE-1) = G_NON
      Affzo [M:LOF6]SELFLG(PLIGNE-1)
#      For J = 0 To [M:LOF6]NBSRCE - 1
#        [M:LOF6]SELFLG(J) = G_NON
#      Next J
#      Affzo [M:LOF6]SELFLG
# End Issue X3-57687
      mkstat = 2
      End
    Endif
    GWVIALIGNE = 0

  Else

    Gosub CTRL_LVA_AUTRE
    If GERR
# Issue X3-57687
      [M:LOF6]SELFLG(PLIGNE-1) = G_NON
      Affzo [M:LOF6]SELFLG(PLIGNE-1)
#      For J = 0 To [M:LOF6]NBSRCE - 1
#        [M:LOF6]SELFLG(J) = G_NON
#      Next J
#      Affzo [M:LOF6]SELFLG
# End Issue X3-57687
      mkstat = 2
      End
    Endif
  Endif

  #------------------------------
  [M:LOF6]CODLOF(N_I-1)       = [M:LOF6]CODLOFS(PLIGNE-1)
  [M:LOF6]LINLOF(N_I-1)       = [M:LOF6]LINLOFS(PLIGNE-1)
  [M:LOF6]GACACN(N_I-1)       = [M:LOF6]GACACNS(PLIGNE-1)
  [M:LOF6]GAC(N_I-1)          = [M:LOF6]GACS(PLIGNE-1)
  [M:LOF6]IASACN(N_I-1)       = [M:LOF6]IASACNS(PLIGNE-1)
  [M:LOF6]IASACC(N_I-1)       = [M:LOF6]IASACCS(PLIGNE-1)
  [M:LOF6]ACGGRP(N_I-1)       = [M:LOF6]ACGGRPS(PLIGNE-1)
  [M:LOF6]AMTNOTCPY(N_I-1)    = [M:LOF6]AMTNOTCPYS(PLIGNE-1)
  [M:LOF6]AMTNOTIAS(N_I-1)    = [M:LOF6]AMTNOTIASS(PLIGNE-1)  : # FQ84794
  [M:LOF6]AMTVATIAS(N_I-1)    = [M:LOF6]AMTVATIASS(PLIGNE-1)  : # FQ98116
  [M:LOF6]AMTVATRIAS(N_I-1)   = [M:LOF6]AMTVATRIASS(PLIGNE-1) : # FQ98116
  [M:LOF6]AMTNOTCUR(N_I-1)    = [M:LOF6]AMTNOTCURS(PLIGNE-1)  : # FQ84794
  [M:LOF6]CURCPY(N_I-1)       = [M:LOF6]CURCPYS(PLIGNE-1)     : # FQ84794
  [M:LOF6]CURIAS(N_I-1)       = [M:LOF6]CURIASS(PLIGNE-1)     : # FQ84794
  [M:LOF6]CUR(N_I-1)          = [M:LOF6]CURS(PLIGNE-1)        : # FQ84794
  [M:LOF6]DES(N_I-1)          = [M:LOF6]DESS(PLIGNE-1)
  [M:LOF6]FLGLOFMAI(N_I-1)    = G_NON
  [M:LOF6]FLGLIKAAS(N_I-1)    = G_NON
  #------------------------------
  [M:LOF6]NBDEST              = N_I

  # FQ67615 lecture remontée avant le test LVA
#  Read [LOFP]LOF0=[M:LOF6]CODLOF(N_I-1);[M:LOF6]LINLOF(N_I-1)

  # On ne récupère les imputations comptables de la dépense principale que si on est au moment de la création
  # du bien.  Sinon, c'est qu'on ajoute une dépense sur un bien créé en autonome.
  If ([M:LOF6]MAIVCR(N_I-1) = G_OUI) & !((GREP <> "C")  & (GLOFPREAD = G_NON))
    # On recherche le code comptable par rapport au compte PCG.
    # On ne fait ça que par rapport à la dépense principale
    [M:LOF6]GACACNV         = [F:LOFP]GACACN
    [M:LOF6]GACV            = [F:LOFP]GAC
    [M:LOF6]IASACNV         = [F:LOFP]IASACN
    [M:LOF6]IASACCV         = [F:LOFP]IASACC
    [M:LOF6]ACGGRPV         = [F:LOFP]ACGGRP
    Affzo [M:LOF6]ACGGRPV
    Call AFFICHE_COMPTES()
    Call RECUP_CODE_COMPTABLE()
  Endif

  If [M:LOF6]GACACN(N_I-1) = GVML_NIENCOU or [M:LOF6]GACACN(N_I-1) = GVML_NIENSER
    [M:LOF6]CUMAMTVCR += [M:LOF6]AMTNOTCPY(N_I-1)
  Endif
  # FGR pour le moment je prend tj l'IAS, mais après à revoir

  #FQ67577-Pologne
  If G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI)
   If [M:LOF6]IASACN(N_I-1) = GVML_NIENCOU or [M:LOF6]IASACN(N_I-1) = GVML_NIENSER

     # FQ84794
#     If ( GCNXPROIAS = G_OUI and [M:FAS1]IASCUR<> "")
#       # ------------- Conversion en devise IAS --------------------------------
#       # 1 -  Détermination du taux en fonction du nouveau type de cours
#       #------------------------------------------------------------------------
#       If [M:FAS1]IASRATCUR = 0
#         Call CDVCAL(RIASRATCUR, [M:FAS1]ACGCUR, [M:FAS1]IASCUR, [M:FAS0]CPY, [M:FAS1]IASCURTYP,
#&                    [F:LOFP]DATVCR ) From TRTDIV
#         [M:FAS1]IASRATCUR = RIASRATCUR
#       Endif
#       #------------------------------------------------------------------------
#       # 2 - Conversion du montant en devise IAS
#       #------------------------------------------------------------------------
#         Call CONVERT3 ( GCOUDEV, GCNXCURIAS, GCOUDEV, [M:FAS1]IASCURTYP, [F:LOFP]DATVCR,
#&                        [M:LOF6]AMTNOTCPY(N_I-1), MNTIAS, [M:FAS1]IASRATCUR, STAT) From CPTSUB
#         If STAT = 0
#           Call GET_MNT_ARRONDI (MNTIAS, [M:FAS1]IASCUR, MNTIAS) From GLOBIENS
#           [M:LOF6]CUMAMTIAS += MNTIAS
#         Endif
#     Else
#       [M:LOF6]CUMAMTIAS        += [M:LOF6]AMTNOTCPY(N_I-1)
#     Endif
      [M:LOF6]CUMAMTIAS  += [M:LOF6]AMTNOTIAS(N_I-1)
      [M:LOF6]CUMVATIAS  += [M:LOF6]AMTVATIAS(N_I-1)  : # FQ98116
      [M:LOF6]CUMVATRIAS += [M:LOF6]AMTVATRIAS(N_I-1) : # FQ98116
   Endif
  Endif #FQ67577 fin

  If PAFF_TOTAUX = G_OUI
    Affzo [M:LOF6]CUMAMTVCR
    Affzo [M:LOF6]CUMAMTIAS
    Call VALEUR_IMMO_ACT ()
  Endif
Endif


End
#--------------------------------------------------
$REMPLACE_PRINCIPALE

# la nouvelle dépense a au moins une nature en service : elle devient la principale
  [M:LOF6]MAIVCR(N_I-1)     = G_OUI
  GINDLOFPRI                = N_I

# l'ancienne dépense principale est déclassée
  [M:LOF6]MAIVCR(J-1)       = G_NON

Return
########################################
Subprog AJOUTE_UNE_DEPENSE ()

Local Char LCODGAC
Local Char LKEY(200)
Local Integer N_I, LEXISTE
Local Integer LERROR
Local Integer STAT
Local Decimal MTDES
Local Decimal RIASRATCUR

# Détermination du taux en fonction du nouveau type de cours
If [M:FAS1]IASRATCUR = 0 and [M:FAS1]IASCUR<> ""
  Call CDVCAL(RIASRATCUR, [M:FAS1]ACGCUR, [M:FAS1]IASCUR, [M:FAS0]CPY, [M:FAS1]IASCURTYP,
&                   [F:LOFP]DATVCR ) From TRTDIV
  [M:FAS1]IASRATCUR = RIASRATCUR
Endif

  Call IS_REFERENCE_EXISTE ([F:LOF]CODLOF, [F:LOF]LINLOF, LEXISTE)
  If LEXISTE = G_NON
    #------------------------------
    LREMPLIR = 1
    If [F:LOF]FLGLIKAAS = G_NON
      LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:LOF]CODLOF, [F:LOF]LINLOF)
      If func GLOBIENS.LOCK_SYMBOLE ("LOF", [F:LOF]CPY, LKEY, 0) = 0
        # l'enregistrement est locké ailleurs : on ne peut pas le choisir
        Infbox mess(34,GML_MSGLOF,1)-[F:LOF]CODLOF-num$([F:LOF]LINLOF)
        LREMPLIR = 0
      Endif
    Endif
    #------------------------------
    If LREMPLIR = 1
      #------------------------------
      N_I = [M:LOF6]NBDEST+1
      If N_I = 1
        [M:LOF6]MAIVCR(N_I-1)  = G_OUI
        GINDLOFPRI             = N_I

        # on ne récupère les imputations comptables de la dépense principale qu'au moment de la création
        # du bien. Sinon, c'est qu'on ajoute une dépense sur un bien créé en autonome.
        If !((GREP <> "C") & (GLOFPREAD = G_NON))
          [M:LOF6]GACACNV        = [F:LOF]GACACN
          [M:LOF6]GACV           = [F:LOF]GAC
          [M:LOF6]IASACNV        = [F:LOF]IASACN
          [M:LOF6]IASACCV        = [F:LOF]IASACC
          [M:LOF6]ACGGRPV        = [F:LOF]ACGGRP
          Call AFFICHE_COMPTES()
          Call RECUP_CODE_COMPTABLE ()
        Endif
      Else
        [M:LOF6]MAIVCR(N_I-1)  = G_NON
      Endif
      #------------------------------
      [M:LOF6]CODLOF(N_I-1)    = [F:LOF]CODLOF
      [M:LOF6]LINLOF(N_I-1)    = [F:LOF]LINLOF
      [M:LOF6]GACACN(N_I-1)    = [F:LOF]GACACN
      [M:LOF6]GAC(N_I-1)       = [F:LOF]GAC
      [M:LOF6]IASACN(N_I-1)    = [F:LOF]IASACN
      [M:LOF6]IASACC(N_I-1)    = [F:LOF]IASACC
      [M:LOF6]ACGGRP(N_I-1)    = [F:LOF]ACGGRP
      [M:LOF6]AMTNOTCPY(N_I-1) = [F:LOF]AMTNOTCPY
      [M:LOF6]AMTNOTIAS(N_I-1) = [F:LOF]AMTNOTIAS  : # FQ84794
      [M:LOF6]AMTVATIAS(N_I-1) = [F:LOF]AMTVATIAS  : # FQ98116
      [M:LOF6]AMTVATRIAS(N_I-1)= [F:LOF]AMTVATRIAS : # FQ98116
      [M:LOF6]AMTNOTCUR(N_I-1) = [F:LOF]AMTNOTCUR  : # FQ84794
      [M:LOF6]CURCPY(N_I-1)    = GCNXCURCPF        : # FQ84794
      [M:LOF6]CURIAS(N_I-1)    = GCNXCURIAS        : # FQ84794
      [M:LOF6]CUR(N_I-1)       = [F:LOF]CUR        : # FQ84794
      [M:LOF6]DES(N_I-1)       = [F:LOF]DES
      [M:LOF6]FLGLOFMAI(N_I-1) = [F:LOF]FLGLOFMAI
      [M:LOF6]FLGLIKAAS(N_I-1) = [F:LOF]FLGLIKAAS
      #------------------------------
      [M:LOF6]NBDEST           = N_I
      #------------------------------
      If [M:LOF6]FLGLIKAAS(N_I-1) = G_NON

        If [M:LOF6]GACACN(N_I-1) = GVML_NIENCOU or [M:LOF6]GACACN(N_I-1) = GVML_NIENSER
          [M:LOF6]CUMAMTVCR    += [M:LOF6]AMTNOTCPY(N_I-1)
        Endif

        #FQ67577-Pologne
        If G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI)
         If [M:LOF6]IASACN(N_I-1) = GVML_NIENCOU or [M:LOF6]IASACN(N_I-1) = GVML_NIENSER
           # FQ84794
#           If ( GCNXPROIAS = G_OUI & [M:FAS1]IASCUR <> "")
#             # ------------- Conversion en devise IAS
#             Call CONVERT3([M:FAS1]ACGCUR, [M:FAS1]IASCUR, GCOUDEV, [M:FAS1]IASCURTYP, [M:FAS1]PURDAT,
#&                          [M:LOF6]AMTNOTCPY(N_I-1), MTDES, [M:FAS1]IASRATCUR, STAT) From CPTSUB
#             If STAT = 0
#               Call GET_MNT_ARRONDI (MTDES, [M:FAS1]IASCUR, MTDES) From GLOBIENS
#               [M:LOF6]CUMAMTIAS += MTDES
#             Endif
#           Else
#             [M:LOF6]CUMAMTIAS    += [M:LOF6]AMTNOTCPY(N_I-1)
#           Endif
           [M:LOF6]CUMAMTIAS  += [M:LOF6]AMTNOTIAS(N_I-1)
           [M:LOF6]CUMVATIAS  += [M:LOF6]AMTVATIAS(N_I-1)  : # FQ98116
           [M:LOF6]CUMVATRIAS += [M:LOF6]AMTVATRIAS(N_I-1) : # FQ98116
           Affzo [M:LOF6]CUMAMTIAS
         Endif
        Endif
        #FQ67577-Fin
        Affzo [M:LOF6]CUMAMTVCR
      Else
        If [M:LOF6]GACACN(N_I-1) = GVML_NIENCOU or [M:LOF6]GACACN(N_I-1) = GVML_NIENSER
         [M:LOF6]CUMIMMVCR    +=  [M:LOF6]AMTNOTCPY(N_I-1)
        Endif
# FQ84794
#         If ( GCNXPROIAS = G_OUI  and [M:FAS1]IASCUR <> "")
#           Call CONVERT3([M:FAS1]ACGCUR, [M:FAS1]IASCUR, GCOUDEV, [M:FAS1]IASCURTYP, [M:FAS1]PURDAT,
#&                         [M:LOF6]AMTNOTCPY(N_I-1), MTDES, [M:FAS1]IASRATCUR, STAT) From CPTSUB
#           If STAT = 0
#             Call GET_MNT_ARRONDI (MTDES, [M:FAS1]IASCUR, MTDES) From GLOBIENS
#          Endif
#        Endif
#
        #FQ67577
        If G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI)

          # FQ90968 : si LOFIASAMT est à Oui il ne faut pas cumuler les montants IAS des dépenses mais prendre le montant
          #           qui est sur le bien
#         # FQ84794
#         # FQ81867
         If GLOFIASAMT <> G_OUI
          [M:LOF6]CUMIMMIAS   += [M:LOF6]AMTNOTIAS(N_I-1)
         Else
           [M:LOF6]CUMIMMIAS  = [M:FAS1]IASETRNOT
         Endif
          Affzo [M:LOF6]CUMIMMIAS
        Endif
        #FQ67577-Fin

        Affzo [M:LOF6]CUMIMMVCR
      Endif
      Call VALEUR_IMMO_ACT ()
    Endif
  Endif
End

########################################
Subprog RECUP_CODE_COMPTABLE ()
# Récupère le code comptable à partir du compte PCG et aussi des info IAS si besoin

Local Integer LERROR
Local Char    LCODGAC
Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN

  If GREP = "C" or (GREP = "M" and [M:LOF6]ACCCODV = "")
    # Regarder si une association "FAMILLE" permet de déterminer le code comptable.
    # Si OUI : c'est l'association qui gagne. classe [F:LOFP] Famille ACGGRP
    # Si NON : On fait comme maintenant.
    # On ne cherche une association pour déterminer le compte que si la famille
    # de la dépense principale est renseignée
    If [M:LOF6]ACGGRPV <> ""
      Call DETER_ACCCOD([F:LOFP]ACGGRP, [M:FAS0]CPY, LCODGAC, GACCCOD_ASSO) From TRTASSO
    Else
      LCODGAC = ""
    Endif
    If LCODGAC = ""
      # Pas d'association sur code comptable : on en cherche un à partir des comptes de la dépense principale
      If GCNXPROIAS = G_OUI
        LCODGAC = func GLOBIENS.GET_GACCCODE (GVML_COGIMMO, GGACIMMO, [M:LOF6]GACV, GIASIMMO, [M:LOF6]IASACCV, LERROR)
      Else
        LCODGAC = func GLOBIENS.GET_GACCCODE (GVML_COGIMMO, GGACIMMO, [M:LOF6]GACV, -1, "", LERROR)
      Endif
    Else
      # -----------------------------------------------------
      # On a le code comptable : faut retrouver les comptes !
      Call AM_ACCCODV(LCODGAC)
      # -----------------------------------------------------
    Endif
    # FQ74813 : détermination du code comptable par un point d'entrée. La variable LCODGAC contient
    #           en entrée le résultat de la détermination automatique et doit être mis à jour par
    #           le point d'entrée si nécessaire.
    GPOINT="DET_ACCCOD" : Gosub ENTREE From EXEFNC
    If LCODGAC <> ""
      Call AM_ACCCODV(LCODGAC)
    Endif
    #
    If LCODGAC = ""
      # Aucun code comptable n'a été trouvé pour ce compte :
      Infbox(mess(71,GML_MSGLOF,1)-[M:LOF6]GACV)
      [M:LOF6]ACCCODV = ""
    Else
      [M:LOF6]ACCCODV = LCODGAC
    Endif
    Affzo [M:LOF6]ACCCODV
    If dim([M:LOF6]ZACCCODV) > 0
      Affzo [M:LOF6]ZACCCODV
    Endif
    # FQ90537
#    If GACCCOD_ASSO = G_NON
    If GACCCOD_ASSO <> G_OUI
      Actzo [M:LOF6]ACCCODV
    Endif
  Endif
End

########################################
Subprog VALEUR_IMMO_ACT ()

  [M:LOF6]CUMPREVCR = [M:LOF6]CUMIMMVCR + [M:LOF6]CUMAMTVCR
  Affzo [M:LOF6]CUMPREVCR
  [M:LOF6]CUMPREIAS = [M:LOF6]CUMIMMIAS + [M:LOF6]CUMAMTIAS
  Affzo [M:LOF6]CUMPREIAS
End

# Issue X3-57687
$MASQUE_COL_IAS
  If GCNXPROIAS <> G_OUI

    # Masquage des champs IAS dans le tableau des dépenses immobilisables
    Chgfmt [M:LOF6]IASACCS    With "-K:1X"
    Chgfmt [M:LOF6]AMTNOTIASS With "-Nz3F:11.2"
    Chgfmt [M:LOF6]CURIASS    With "-KC:3"

    # Masquage des champs IAS dans le tableaux des dépenses retenues
    Chgfmt [M:LOF6]IASACC     With "-K:1X"
    Chgfmt [M:LOF6]AMTNOTIAS  With "-Nz3F:11.2"
    Diszo  [M:LOF6]AMTNOTIAS
    Chgfmt [M:LOF6]CURIAS     With "-KC:3"

  Endif
Return
# End Issue X3-57687

################################################################################
# ECRAN : LOFLDAB
################################################################################

#Fq67577-Pologne
######################################################################################
Subprog C_MDRFLG(VALEUR)
Variable Integer VALEUR
 Call C_MDRFLG(VALEUR) From TRTFASMDR
End

Subprog AM_MDRFLG(VALEUR)
Variable Integer VALEUR
 Call AM_MDRFLG(VALEUR) From TRTFASMDR
End

########################################
Subprog AS_NBSRCE

  If [M:LOF6]NBSRCE = 0
    # Si la liste source est vide, on ne peut pas ajouter.
    #GBOUT3 = ""
    GBOUT4 = ""
  Endif
  If [M:LOF6]NBDEST = 0
    # Si il n'y a pas de ligne destination : on ne peut pas tout ajouter
    # il n'y a pas de dépense de référence, on ne peut donc pas contrôler si les
    # dépenses sont compatibles
    GBOUT4 = ""
  Endif
  If GLDABAPPL = G_OUI
    # Si on a fait "Appliquer", on ne peut plus ajouter de lignes
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT4 = ""
  Endif

#  For nolign=1 To [M:LOF6]NBSRCE # Issue X3-57687 : not absolutary necessary
#    If [M:LOF6]CODLOFS(nolign-1) = ""
#      [M:LOF6]NBSRCE -=1
#    Endif
#  Next nolign
  Enable 65
  # End Issue X3-57687

  Gosub MASQUE_COL_IAS

End
########################################
Subprog B1_NBSRCE
# Remplir la liste avec tout ce qui est immobilisable (sans critère)

  GLDAPCRIT = ""
  GLDAPSTAR = 0
  Gosub REMPLI_SOURCE
  Call AS_NBSRCE From W1LOFLDAB
   #YYFIN_MDJ_X3-8326Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBSRCE") From GLOBIENS
  Affzo [M:LOF6]15
End

########################################
Subprog B3_NBSRCE

# Ajouter
Local Integer NEXISTE
Local Integer NDSREXISTE

If (nolign > [M:LOF6]NBSRCE)  & ([M:LOF6]CODLOFS(nolign-1)= "")  &  ([M:LOF6]NBDEST=0)
  GBOUT3 = "" : Disable GSTABOU+1 : mkstat = 0 : End
Else
  If GLDABAPPL = G_NON
    Enable GSTABOU+1
  Endif
  If [M:LOF6]CODLOFS(nolign-1) <> "" or 1=1
    Call IS_REFERENCE_EXISTE ([M:LOF6]CODLOFS(nolign-1), [M:LOF6]LINLOFS(nolign-1), NEXISTE)
    If NEXISTE = G_NON
      If [M:LOF6]NBDEST = 0
        NDSREXISTE = 1
      Else
        NDSREXISTE = 2
      Endif
      Call AJOUTE_UNE_LIGNE (nolign, G_OUI)
      Dela nolign-1, 1 [M:LOF6]NBSRCE
      If [M:LOF6]NBSRCE > 0
        [M:LOF6]NBSRCE -= 1
      Endif
      #Fq67577
      If G_ACTKPL=G_OUI
       Gosub DISABLE_MDRFLG From TRTFASMDR
      Endif
      If NDSREXISTE = 1
        Gosub REMPLI_SOURCE
        Call AS_NBSRCE From W1LOFLDAB
      Endif
    Endif
  Endif
  #YYFIN_MDJ_X3-8326Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBSRCE") From GLOBIENS
  #YYFIN_MDJ_X3-8326Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBDEST") From GLOBIENS
  #YYFIN_MDJ_X3-8326Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "MAIVCR") From GLOBIENS
  #YYFIN_MDJ_X3-8326
  Affzo  [M:LOF6]15
  Affzo  [M:LOF6]20
Endif

End

########################################
Subprog B4_NBSRCE
# Tout ajouter
Local Integer N_I
Local Integer NEXISTE

  Call TEMPON('C') From GESECRAN

  For N_I = 1 To [M:LOF6]NBSRCE
    Call IS_REFERENCE_EXISTE ([M:LOF6]CODLOFS(N_I-1), [M:LOF6]LINLOFS(N_I-1), NEXISTE)
    If NEXISTE = G_NON
      If N_I < [M:LOF6]NBSRCE
        Call AJOUTE_UNE_LIGNE (N_I, G_NON)
      Else
        Call AJOUTE_UNE_LIGNE (N_I, G_OUI)
      Endif
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I
  [M:LOF6]NBSRCE = 0
  #YYFIN_MDJ_X3-8326Call ACTION_BLOCK (ACB_EFFZO, "LOFLDAB", "NBSRCE") From GLOBIENS
  #YYFIN_MDJ_X3-8326 Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "MAIVCR") From GLOBIENS
  #YYFIN_MDJ_X3-8326
  Affzo  [M:LOF6]15
  Call TEMPOFF() From GESECRAN
End

########################################
Subprog AS_NBDEST

  If [M:LOF6]NBDEST = 0
    # Si la liste destination est vide, on ne peut pas retirer.
    GBOUT1 = ""
    GBOUT2 = ""
  Endif
  If GLDABAPPL = G_OUI
    # Si on a fait "Appliquer", on ne peut plus remettre en cause les lignes de destination
    GBOUT1 = ""
    GBOUT2 = ""
  Endif
  If [M:LOF6]FLGLIKAAS(nolign-1) = G_OUI
    # On ne peut pas retirer une dépense déjà rattachée à un bien existant.
    GBOUT1 = ""
    GBOUT2 = ""
  Endif
  #Fq-60838
  If GREP <> "C"
      GBOUT2=""
  Endif  #Fq-60838

End

########################################
Subprog B1_NBDEST
# Retirer
Local Integer NPRINCIP
Local Integer STAT
Local Decimal MNTIAS
Local Decimal RIASRATCUR
Local Char LKEY(200)

  If [M:LOF6]FLGLIKAAS(nolign-1) = G_OUI
    # On ne peut pas détruire une ligne déjà principale en base : elle n'est ici que pour mémoire
    GMESSAGE = mess(25,GML_MSGLOF,1) : # Le statut principal de cette dépense ne peut lui être retiré
    GERR=1
    mkstat = 2
    End
  Endif

  # Détermination du taux en fonction du nouveau type de cours
  If [M:FAS1]IASRATCUR = 0 and  [M:FAS1]IASCUR <> ""
    Call CDVCAL(RIASRATCUR, [M:FAS1]ACGCUR, [M:FAS1]IASCUR, [M:FAS0]CPY, [M:FAS1]IASCURTYP,
&                   [M:FAS1]PURDAT ) From TRTDIV
    [M:FAS1]IASRATCUR = RIASRATCUR
  Endif

If [M:LOF6]FLGLIKAAS(nolign-1) = G_NON

  If [M:LOF6]GACACN(nolign-1) = GVML_NIENCOU or [M:LOF6]GACACN(nolign-1) = GVML_NIENSER
    [M:LOF6]CUMAMTVCR    -= [M:LOF6]AMTNOTCPY(nolign-1)
  Endif

  #Fq67577-Pologne
  If G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI)
   If [M:LOF6]IASACN(nolign-1) = GVML_NIENCOU or [M:LOF6]IASACN(nolign-1) = GVML_NIENSER
     # FQ84794
#     If ( GCNXPROIAS = G_OUI  & [M:FAS1]IASCUR <> "")
#       # ------------- Conversion en devise IAS
#       Call CONVERT3([M:FAS1]ACGCUR, [M:FAS1]IASCUR, GCOUDEV, [M:FAS1]IASCURTYP, [M:FAS1]PURDAT,
#&                      [M:LOF6]AMTNOTCPY(nolign-1), MNTIAS, [M:FAS1]IASRATCUR, STAT) From CPTSUB
#       If STAT = 0
#         Call GET_MNT_ARRONDI (MNTIAS, [M:FAS1]IASCUR, MNTIAS) From GLOBIENS
#        [M:LOF6]CUMAMTIAS -= MNTIAS
#       Endif
#     Else
#       [M:LOF6]CUMAMTIAS    -= [M:LOF6]AMTNOTCPY(nolign-1)
#     Endif
     [M:LOF6]CUMAMTIAS  -= [M:LOF6]AMTNOTIAS(nolign-1)
     [M:LOF6]CUMVATIAS  -= [M:LOF6]AMTVATIAS(nolign-1)  : # FQ98116
     [M:LOF6]CUMVATRIAS -= [M:LOF6]AMTVATRIAS(nolign-1) : # FQ98116
   Endif
  Endif
  #Fq67577-Fin

  Affzo [M:LOF6]CUMAMTVCR
  Affzo [M:LOF6]CUMAMTIAS
Else

  If [M:LOF6]GACACN(nolign-1) = GVML_NIENCOU or [M:LOF6]GACACN(nolign-1) = GVML_NIENSER
    [M:LOF6]CUMIMMVCR    -= [M:LOF6]AMTNOTCPY(nolign-1)
  Endif

  #Fq67577-Pologne
  If G_ACTKPL<>G_OUI | (G_ACTKPL=G_OUI & [M:LOF6]MDRFLG<>G_OUI)
   If [M:LOF6]IASACN(nolign-1) = GVML_NIENCOU or [M:LOF6]IASACN(nolign-1) = GVML_NIENSER
     If ( GCNXPROIAS = G_OUI  & [M:FAS1]IASCUR <> "")
       # ------------- Conversion en devise IAS
       Call CONVERT3([M:FAS1]ACGCUR, [M:FAS1]IASCUR, GCOUDEV, [M:FAS1]IASCURTYP, [M:FAS1]PURDAT,
&                      [M:LOF6]AMTNOTCPY(nolign-1), MNTIAS, [M:FAS1]IASRATCUR, STAT) From CPTSUB
       If STAT = 0
         Call GET_MNT_ARRONDI (MNTIAS, [M:FAS1]IASCUR, MNTIAS) From GLOBIENS
        [M:LOF6]CUMIMMIAS -= MNTIAS
       Endif
     Else
       [M:LOF6]CUMIMMIAS    -= [M:LOF6]AMTNOTCPY(nolign-1)
     Endif
   Endif
  Endif
  #Fq67577-Fin

  Affzo [M:LOF6]CUMIMMVCR
  Affzo [M:LOF6]CUMIMMIAS
Endif

  Call VALEUR_IMMO_ACT ()

  If [M:LOF6]MAIVCR(nolign-1) = G_OUI
    NPRINCIP = G_OUI
  Else
    NPRINCIP = G_NON
  Endif

  LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:LOF6]CODLOF(nolign-1), [M:LOF6]LINLOF(nolign-1))
  Call UNLOCK_SYMBOLE ("LOF", [M:FAS0]CPY, LKEY) From GLOBIENS

  # La dépense retirée du tableau des dépenses retenues
  # est ré-insérée dans le tableau des dépenses immobilisables
  If  [M:LOF6]NBSRCE > 0 and [M:LOF6]CODLOFS(0) <> ""
    Insa NBSRCE, 1  NBSRCE
    [M:LOF6]SELFLG(NBSRCE)     = G_NON
    [M:LOF6]CODLOFS(NBSRCE)    = [M:LOF6]CODLOF(nolign-1)
    [M:LOF6]LINLOFS(NBSRCE)    = [M:LOF6]LINLOF(nolign-1)
    [M:LOF6]AMTNOTCPYS(NBSRCE) = [M:LOF6]AMTNOTCPY(nolign-1)
    [M:LOF6]GACS(NBSRCE)       = [M:LOF6]GAC(nolign-1)
    [M:LOF6]DESS(NBSRCE)       = [M:LOF6]DES(nolign-1)
    [M:LOF6]IASACCS(NBSRCE)    = [M:LOF6]IASACC(nolign-1)
    [M:LOF6]GACACNS(NBSRCE)    = [M:LOF6]GACACN(nolign-1)
    [M:LOF6]IASACNS(NBSRCE)    = [M:LOF6]IASACN(nolign-1)
    [M:LOF6]ACGGRPS(NBSRCE)    = [M:LOF6]ACGGRP(nolign-1)
    [M:LOF6]AMTNOTIASS(NBSRCE) = [M:LOF6]AMTNOTIAS(nolign-1)  : # FQ84794
    [M:LOF6]AMTVATIASS(NBSRCE) = [M:LOF6]AMTVATIAS(nolign-1)  : # FQ98116
    [M:LOF6]AMTVATRIASS(NBSRCE)= [M:LOF6]AMTVATRIAS(nolign-1) : # FQ98116
    [M:LOF6]AMTNOTCURS(NBSRCE) = [M:LOF6]AMTNOTCUR(nolign-1)  : # FQ84794
    [M:LOF6]CURCPYS(NBSRCE)    = [M:LOF6]CURCPY(nolign-1)     : # FQ84794
    [M:LOF6]CURIASS(NBSRCE)    = [M:LOF6]CURIAS(nolign-1)     : # FQ84794
    [M:LOF6]CURS(NBSRCE)       = [M:LOF6]CUR(nolign-1)        : # FQ84794
  Else
    [M:LOF6]SELFLG(0)     = G_NON
    [M:LOF6]CODLOFS(0)    = [M:LOF6]CODLOF(nolign-1)
    [M:LOF6]LINLOFS(0)    = [M:LOF6]LINLOF(nolign-1)
    [M:LOF6]AMTNOTCPYS(0) = [M:LOF6]AMTNOTCPY(nolign-1)
    [M:LOF6]GACS(0)       = [M:LOF6]GAC(nolign-1)
    [M:LOF6]DESS(0)       = [M:LOF6]DES(nolign-1)
    [M:LOF6]IASACCS(0)    = [M:LOF6]IASACC(nolign-1)
    [M:LOF6]GACACNS(0)    = [M:LOF6]GACACN(nolign-1)
    [M:LOF6]IASACNS(0)    = [M:LOF6]IASACN(nolign-1)
    [M:LOF6]ACGGRPS(0)    = [M:LOF6]ACGGRP(nolign-1)
    [M:LOF6]AMTNOTIASS(0) = [M:LOF6]AMTNOTIAS(nolign-1)   : # FQ84794
    [M:LOF6]AMTVATIASS(0) = [M:LOF6]AMTVATIAS(nolign-1)   : # FQ98116
    [M:LOF6]AMTVATRIASS(0)= [M:LOF6]AMTVATRIAS(nolign-1)  : # FQ98116
    [M:LOF6]AMTNOTCURS(0) = [M:LOF6]AMTNOTCUR(nolign-1)   : # FQ84794
    [M:LOF6]CURCPYS(0)    = [M:LOF6]CURCPY(nolign-1)      : # FQ84794
    [M:LOF6]CURIASS(0)    = [M:LOF6]CURIAS(nolign-1)      : # FQ84794
    [M:LOF6]CURS(0)       = [M:LOF6]CUR(nolign-1)         : # FQ84794
  Endif

  # Issue X3-57687
  [M:LOF6]SELFLG(nolign-1) = G_NON
  #  For I = 1 To  [M:LOF6]NBSRCE
  #    [M:LOF6]SELFLG(I-1) = G_NON
  #  Next I
  # End Issue X3-57687

  [M:LOF6]NBSRCE +=1

  Dela nolign-1, 1 [M:LOF6]NBDEST
  [M:LOF6]NBDEST -= 1

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI
   Gosub ENABLE_MDRFLG From TRTFASMDR
  Endif

  If NPRINCIP = G_OUI and [M:LOF6]NBDEST > 0
    # Si on a détruit la dépense principale, on positionne la première ligne
    # en dépense principale (par défaut)
    [M:LOF6]MAIVCR(0) = G_OUI
    GINDLOFPRI = 1
    Affzo [M:LOF6]MAIVCR(0)
    Read [LOFP]LOF0=[M:LOF6]CODLOF(0);[M:LOF6]LINLOF(0)
  Endif

  # Si le bien a été créé en autonome, on ne touche pas aux imputations comptables
  If ([M:LOF6]NBDEST = 0) & !((GREP <> "C") & (GLOFPREAD = G_NON))
    #Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "ACCCODV") From GLOBIENS
    #Call ACTION_BLOCK (ACB_EFFZO, "LOFLDAB", "ACCCODV") From GLOBIENS
    Affzo [M:LOF6]35
    Effzo [M:LOF6]35
  Endif

  If[M:LOF6]NBDEST=0
    Gosub REMPLI_SOURCE
    Call AS_NBSRCE From W1LOFLDAB
  Endif

  #Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBSRCE") From GLOBIENS
  #Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBDEST") From GLOBIENS
  Affzo [M:LOF6]15
  Affzo [M:LOF6]20
End

########################################
Subprog B2_NBDEST
# Tout retirer
Local Integer N_I
Local Char LKEY(200)

  For N_I = 1 To [M:LOF6]NBDEST
    LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([M:LOF6]CODLOF(N_I-1), [M:LOF6]LINLOF(N_I-1))
    Call UNLOCK_SYMBOLE ("LOF", [M:FAS0]CPY, LKEY) From GLOBIENS
    #------------------------------
    # Suite de la boucle
  Next N_I

  [M:LOF6]NBDEST = 0

  # Si le bien a été créé en autonome, on ne touche pas aux imputations comptables
  If !((GREP <> "C") & (GLOFPREAD = G_NON))
    #Call ACTION_BLOCK (ACB_EFFZO, "LOFLDAB", "ACCCODV") From GLOBIENS
    Effzo [M:LOF6]35
  Endif

  [M:LOF6]CUMIMMVCR = 0
  Affzo [M:LOF6]CUMIMMVCR
  [M:LOF6]CUMIMMIAS = 0
  Affzo [M:LOF6]CUMIMMIAS
  [M:LOF6]CUMAMTVCR = 0
  Affzo [M:LOF6]CUMAMTVCR
  [M:LOF6]CUMAMTIAS = 0
  Affzo [M:LOF6]CUMAMTIAS
  [M:LOF6]CUMVATIAS  = 0 : # FQ98116
  [M:LOF6]CUMVATRIAS = 0 : # FQ98116
  Call VALEUR_IMMO_ACT ()

  If [F:LOFP]FLGLOFMAI = G_OUI
    # Si on est en ajout de dépense sur un bien, on doit remettre la dépense principale
    # déjà stockée en base.
    Gosub DECLARE_TIROIRS From SUBFAS
    Gosub RAZ_PICKING From FUNLOFLDAB
    Gosub READ_DEP_PRINCIPALE From FUNLOFLDAB
  Endif

  GLDAPCRIT = ""
  GLDAPSTAR = 0
  Gosub REMPLI_SOURCE
  Call AS_NBSRCE From W1LOFLDAB
  #Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBSRCE") From GLOBIENS
  #Call ACTION_BLOCK (ACB_EFFZO, "LOFLDAB", "NBDEST") From GLOBIENS
  Affzo [M:LOF6]15
  Effzo [M:LOF6]20
End

######################################################################################
Subprog AM_SELFLG(VALEUR)
Variable Integer VALEUR

Local Integer NEXISTE, I
Local Integer NDSREXISTE

  # Après un premier ajout, le double-clic ne fonctionne pas sur la ligne de même rang
  # il faut un double double-clic ==> si modif du flag on le positionne automatiquement à G_OUI

  If (dim([M:LOF6]SELFLG(nolign-1))>0)
    [M:LOF6]SELFLG(nolign-1) = G_OUI
  Endif

  # Ajouter
  If (nolign > [M:LOF6]NBSRCE)  or ([M:LOF6]CODLOFS(nolign-1)= "")
    GBOUT3 = "" :      Disable GSTABOU+1 : : mkstat = 0
    [M:LOF6]SELFLG(nolign-1) = G_NON : Affzo [M:LOF6]SELFLG(nolign-1)
    End
  Else
    If GLDABAPPL = G_NON
      Enable GSTABOU+1
    Endif
    If [M:LOF6]CODLOFS(nolign-1) <> "" or 1=1
      Call IS_REFERENCE_EXISTE ([M:LOF6]CODLOFS(nolign-1), [M:LOF6]LINLOFS(nolign-1), NEXISTE)
      If NEXISTE = G_NON
        If [M:LOF6]NBDEST = 0
          NDSREXISTE = 1
        Else
          NDSREXISTE = 2
        Endif
        Call AJOUTE_UNE_LIGNE (nolign, G_OUI)
        If G_ACTKPL=G_OUI
          Gosub DISABLE_MDRFLG From TRTFASMDR #Fq67577-Pologne
        Endif
        # --- on supprime la dépense ajoutée du tableau source
# FQ67615 : ne pas supprimer la dépense en cas d'erreur
        If GERR = 0
          Dela nolign-1, 1 [M:LOF6]NBSRCE
          If [M:LOF6]NBSRCE > 0
            [M:LOF6]NBSRCE -= 1
          Endif
# Issue X3-57687
          Raz [M:LOF6]SELFLG  # Here, it's absolutly necessary to re-initialize
          #          For I = 1 To  [M:LOF6]NBSRCE
          #            [M:LOF6]SELFLG(I-1) = G_NON
          #          Next I
# End Issue X3-57687
          If NDSREXISTE = 1
            Gosub REMPLI_SOURCE
            Call AS_NBSRCE From W1LOFLDAB
          Endif
        # FQ67615
        Endif
      Endif
      #Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBSRCE") From GLOBIENS
      #Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBDEST") From GLOBIENS
      Affzo [M:LOF6]15
      Affzo [M:LOF6]20
    Endif
  Endif

End
########################################
Subprog AV_MAIVCR(VALEUR)
Variable Integer VALEUR

  If [M:LOF6]FLGLIKAAS(nolign-1) = G_OUI  and  [M:LOF6]MAIVCR(nolign-1)= G_OUI
   #*FQ82871
   #* - on garde les pcolor pour l'appli. C/S
   #* - on ajoute un chgstl pour Convergence
    Chgstl NBDEST(nolign-1) With "AWARNLOW"
    pcolor = GCOUL(3) : # Bleu
  Else
    Chgstl NBDEST(nolign-1) With ""
    pcolor = GCOUL(0) : # Normal
    Affzo  [M:LOF6]NBDEST
  Endif

End

########################################
Subprog AS_MAIVCR(VALEUR)
Variable Integer VALEUR

  If (GLOFPREAD = G_OUI)
    # Il y a déjà une dépense principale en base : on ne peut pas en changer
    GMESSAGE = mess(26,GML_MSGLOF,1) : # Ce bien a déjà une dépense principale.
    GERR     = 1
    mkstat   = 2
    End
  Endif

  # Si on ne gère pas l'IAS, pas de pb, on peut tj changer de dépense principale
  # parce qu'on ne peut pas créer de bien avec un compte de charges
  If GCNXPROIAS = G_OUI
    # Si la nature PCG de la principale était "En cours" ou "En service", pas possible de choisir
    # une dépense "Charge" comme principale.
    If ([F:LOFP]GACACN=GVML_NIENCOU or [F:LOFP]GACACN=GVML_NIENSER)
&      and ([M:LOF6]GACACN(nolign-1)<>GVML_NIENCOU and [M:LOF6]GACACN(nolign-1)<>GVML_NIENSER)
      # Impossible de changer la dépense princip. en optant pour une dépense ayant cette nature de compte PCG
      GMESSAGE = mess(51,GML_MSGLOF,1)
      GERR     = 1
      mkstat   = 2
      End
    Endif

    # Si la nature IFRS de la principale était "En cours" ou "En service", pas possible de choisir
    # une dépense "Charge" comme principale. L'ancienne principale (voire d'autres) ne serait plus
    # comptatible
    If ([F:LOFP]IASACN=GVML_NIENCOU or [F:LOFP]IASACN=GVML_NIENSER)
&      and ([M:LOF6]IASACN(nolign-1)<>GVML_NIENCOU and [M:LOF6]IASACN(nolign-1)<>GVML_NIENSER)
      # Impossible de changer la dép. principale en optant pour une dépense ayant cette nature de compte IAS
      GMESSAGE = mess(52,GML_MSGLOF,1) :
      GERR     = 1
      mkstat   = 2
      End
    Endif

    # Si la nature PCG et la nature IFRS de la principale étaient  "En service",
    # il n'est pas possible de choisir une dépense ayant une nature PCG ou IFRS différente de "En service"
    If ( [F:LOFP]GACACN=GVML_NIENSER and [F:LOFP]IASACN=GVML_NIENSER)
&      and ([M:LOF6]GACACN(nolign-1) <> GVML_NIENSER or [M:LOF6]GACACN(nolign-1) <> GVML_NIENSER)
      # Impossible de changer la dépense principale en optant pour une dépense ayant ces natures de compte
      GMESSAGE = mess(61,GML_MSGLOF,1)
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif


End
########################################
Subprog C_MAIVCR(VALEUR)
Variable Integer VALEUR

End

########################################
Subprog AM_MAIVCR(VALEUR)
Variable Integer VALEUR

Local Integer N_I, I, J
Local Integer OK
Local Integer NOL

If [M:LOF6]NBDEST =1 & VALEUR = G_NON
  # Le statut principal de cette dépense ne peut lui être retiré
  GMESSAGE = mess(25,GML_MSGLOF,1)
  GERR     = 1
  mkstat   = 2
  End
Endif


If (VALEUR <>  [M:LOF6]MAIVCR(nolign-1)) and  ([M:LOF6]MAIVCR(nolign-1) = G_OUI and VALEUR = G_NON)
  # Il doit y avoir une ligne principale Pour en changer sélectionnez en une autre
  GMESSAGE = mess(23,GML_MSGLOF,1)
  GERR     = 1
  mkstat   = 2
  End
Endif

 # on décoche l'ancienne dépense principale si elle existe
 For J = 1 To [M:LOF6]NBDEST-1
   If  [M:LOF6]MAIVCR(J-1) = G_OUI and J <> nolign
     [M:LOF6]MAIVCR(J-1) = G_NON
     Affzo [M:LOF6]MAIVCR(J-1)
     Break
   Endif
   #------------------------------
   # Suite de la boucle
 Next J

  # la dépense principale choisie n'a pas de nature "en service" alors que celle qu'elle est
  # sensée remplacer a au moins une nature d'immo en service ==> demande de confirmation

  If ([M:LOF6]GACACN(J-1) = GVML_NIENSER or [M:LOF6]IASACN(J-1) = GVML_NIENSER)
&  & ([M:LOF6]GACACN(nolign-1) <> GVML_NIENSER and [M:LOF6]IASACN(nolign-1) <> GVML_NIENSER)
    #  mess(60,GML_MSGLOF)- Vous allez opter pour une dépense principale n'ayant pas de nature d'immobilisation
    #  en service. Confirmez-vous ?
    Call OUINON(mess(60,GML_MSGLOF,1),OK) From GESECRAN
    If OK=1
      # Si non, on ne tient pas compte du changement de dépense principale
      [M:LOF6]MAIVCR(nolign-1) = G_NON
      [M:LOF6]MAIVCR(J-1) = G_OUI
      Affzo [M:LOF6]MAIVCR(nolign-1)
      Affzo [M:LOF6]MAIVCR(J-1)
    Else
      # si oui, on remplace la dépense principale par la nouvelle
      [M:LOF6]MAIVCR(nolign-1) = G_OUI
      [M:LOF6]MAIVCR(J-1) = G_NON
      Affzo [M:LOF6]MAIVCR(nolign-1)
      Affzo [M:LOF6]MAIVCR(J-1)

      # - on ne récupère les imputations comptables de la dépense principale que si on est au moment de la création
      #   du bien. Sinon, c'est qu'on ajoute une dépense sur un bien créé en autonome.
      If (GREP = "C")
        [M:LOF6]GACACNV  = [M:LOF6]GACACN(nolign-1)
        [M:LOF6]GACV     = [M:LOF6]GAC(nolign-1)
        [M:LOF6]IASACNV  = [M:LOF6]IASACN(nolign-1)
        [M:LOF6]IASACCV  = [M:LOF6]IASACC(nolign-1)
        [M:LOF6]ACGGRPV  = [M:LOF6]ACGGRP(nolign-1)
        # CBO FQ67615
        If func CTRL_LVA_PRINCIPAL([M:FPC]LEG, [M:FPC]COA(0), [M:LOF6]GACV,
&                            [M:LOF6]CPY, G300CPFI, [F:LOFP]DATIMP,
&                            [M:LOF6]AMTNOTCPY(nolign - 1), GW_LVA_TYP_PRIN,
&                            GWLVALIM, GWDATSTRFIY, GWDATENDFIY)
          End
        Endif
      Endif

      GINDLOFPRI = nolign
    Endif
  Else
    [M:LOF6]MAIVCR(nolign-1) = G_OUI
    [M:LOF6]MAIVCR(J-1) = G_NON
    Affzo [M:LOF6]MAIVCR(nolign-1)
    Affzo [M:LOF6]MAIVCR(J-1)

    # - on ne récupère les imputations comptables de la dépense principale que si on est au moment de la création
    #   du bien.  Sinon, c'est qu'on ajoute une dépense sur un bien créé en autonome.
    If (GREP = "C")
      [M:LOF6]GACACNV  = [M:LOF6]GACACN(nolign-1)
      [M:LOF6]GACV     = [M:LOF6]GAC(nolign-1)
      [M:LOF6]IASACNV  = [M:LOF6]IASACN(nolign-1)
      [M:LOF6]IASACCV  = [M:LOF6]IASACC(nolign-1)
      [M:LOF6]ACGGRPV  = [M:LOF6]ACGGRP(nolign-1)
      # CBO FQ67615
      If func CTRL_LVA_PRINCIPAL([M:FPC]LEG, [M:FPC]COA(0), [M:LOF6]GACV,
&                          [M:LOF6]CPY, G300CPFI, [F:LOFP]DATIMP,
&                          [M:LOF6]AMTNOTCPY(nolign - 1), GW_LVA_TYP_PRIN,
&                          GWLVALIM, GWDATSTRFIY, GWDATENDFIY)
        End
      Endif
    Endif

    GINDLOFPRI = nolign
  Endif

  # On ne récupère les imputations comptables de la dépense principale que si on est au moment de la création
  # du bien. Sinon, c'est qu'on ajoute une dépense sur un bien créé en autonome.
  If (GREP = "C")
    # affichage des comptes et de leur intitulé
    Call AFFICHE_COMPTES()
    Affzo [M:LOF6]ACGGRPV
    # remise à blanc du code comptable
    [M:LOF6]ACCCODV  = ""
    Affzo [M:LOF6]ACCCODV
    Call RECUP_CODE_COMPTABLE ()
  Endif
End

#########################################
Subprog AM_ACGGRPV(VALEUR)
Variable Char    VALEUR()

Local Integer     PUPDFLG
Local Char        PACCCOD

  If VALEUR <> ""
    Call DETER_ACCCOD(VALEUR, [M:LOF6]CPY, PACCCOD, PUPDFLG) From TRTASSO
    #Fq-79509 If PUPDFLG=G_OUI
    If PUPDFLG=G_OUI  and PACCCOD <> ""
      [M:LOF6]ACCCODV = PACCCOD
      Affzo [M:LOF6]ACCCODV
      # -----------------------------------------------------
      # On a le code comptable : faut retrouver les comptes !
      Call AM_ACCCODV([M:LOF6]ACCCODV)
    Endif
  Endif

End

######################################################################
Subprog C_ACGGRPV(VALEUR)
Variable Char    VALEUR()

  Local File FASFAM [FAM]

  Read [F:FAM]FAM0 = VALEUR
#  Read [ADI]CODE = GTD_FAMCPT;VALEUR
  If fstat=0
    If   !(func TRTFAS.IS_LEG_ACGGRP_OK([M:FPC]LEG, VALEUR))
      GERR= 1: GMESSAGE = mess(683,GML_MSGFAS,1)-" "-[M:FPC]LEG
      mkstat = 2 : End
    Endif
  Endif
End

########################################
Subprog AM_ACCCODV(VALEUR)
Variable Char    VALEUR()

Local Char LGAC, LIASACC
Local Integer LGACACN, LIASACN

  If VALEUR <> "" and [M:LOF6]NBDEST = 0
    [M:LOF6]GACACNV  = 0
    [M:LOF6]GACV     = ""
    [M:LOF6]IASACNV  = 0
    [M:LOF6]IASACCV  = ""
    Call AFFICHE_COMPTES()
    # Vous devez d'abord choisir une dépense principale
    GMESSAGE = mess(59,GML_MSGLOF,1)
    [M:LOF6]ACCCODV  = ""
    Affzo [M:LOF6]ACCCODV
    Disable  GSTABOU+1
    GERR     = 1
    mkstat   = 2
    End
  Endif
  Enable  GSTABOU+1

  If VALEUR = "" and [M:LOF6]NBDEST > 0
    # Le code comptable est obligatoire lorsque au moins une dépense est retenue.
    GMESSAGE = mess(258,GML_MSGFAS,1)
    Disable  GSTABOU+1
    GERR     = 1
    mkstat   = 2
    End
  Else
  Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, VALEUR, GGACIMMO, GIASIMMO, LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS
  # 2 cas d'erreurs possibles 1) compte PCG absent ou 2) nature invalide
  # si compte PCG absent ou nature = 0 (quand nature = 0, le sous-pro renvoie LGAC à blanc)
  If LGACACN = 0
    # Le compte d'immobilisation PCG associé au code comptable est invalide ou sa nature est incorrecte.
    GMESSAGE = mess(422,GML_MSGFAS,1)
    GERR     = 1
    mkstat   = 2
    End
  Endif:
  If GCNXPROIAS = G_OUI
  # 2 cas d'erreurs possible 1) compte IFRS absent ou 2) nature invalide
  # si compte IFRS absent ou nature = 0 (quand nature = 0, le sous-pro renvoie LIASACC à blanc)
    If LIASACN = 0
      # Le compte d'immo. IFRS associé au code comptable est invalide ou sa nature est incorrect
      GMESSAGE = mess(423,GML_MSGFAS,1)
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif
  # ----------------------------------------
  # La nature du compte PCG déduit du code comptable doit être compatible avec celle de la dépense princip.
  #    * Nature PCG dépense principale = Dépense, nature du compte PCG déduit du code comptable aussi
  If [M:LOF6]GACACNV = GVML_NIENCOU or [M:LOF6]GACACNV = GVML_NIENSER
    # C'est une nature IMMOBILISATION
    If LGACACN <> GVML_NIENCOU and LGACACN <> GVML_NIENSER
      # Nature compte PCG issu du Code comptable incompatible avec Nature compte PCG de la dépense princip.
      GMESSAGE = mess(283,GML_MSGFAS,1)
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Else
    # C'est une nature CHARGE
    If LGACACN = GVML_NIENCOU or LGACACN = GVML_NIENSER
      # Nature compte PCG issu du Code comptable incompatible avec Nature compte PCG de la dépense princip.
      GMESSAGE = mess(283,GML_MSGFAS,1)
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif
  #
  If GCNXPROIAS = G_OUI
    # Idem pour l'IAS
    If [M:LOF6]IASACNV = GVML_NIENCOU or [M:LOF6]IASACNV = GVML_NIENSER
      # C'est une nature IMMOBILISATION
      If LIASACN <> GVML_NIENCOU and LIASACN <> GVML_NIENSER
        # Nature compte IFRS issu du code comptable incompatible avec Nature compte IFRS de la dépense princ
        GMESSAGE = mess(284,GML_MSGFAS,1)
        GERR     = 1
        mkstat   = 2
        End
      Endif
    Else
      # C'est une nature CHARGE
      If LIASACN = GVML_NIENCOU or LIASACN = GVML_NIENSER
        # Nature compte IFRS issu du code comptable incompatible avec Nature compte IFRS de la dépense princ
        GMESSAGE = mess(284,GML_MSGFAS,1)
        GERR     = 1
        mkstat   = 2
        End
      Endif
    Endif
  Endif
  # ----------------------------------------
  [M:LOF6]GACACNV   = 0
  [M:LOF6]GACV      = ""
  If LGACACN <> 0
    [M:LOF6]GACACNV = LGACACN
    [M:LOF6]GACV    = LGAC
    [M:FAS1]GACACN  = LGACACN
    [M:FAS1]GAC     = LGAC
  Endif

  [M:LOF6]IASACNV     = 0
  [M:LOF6]IASACCV     = ""
  If GCNXPROIAS = G_OUI
    If LIASACN <> 0
      [M:LOF6]IASACNV = LIASACN
      [M:LOF6]IASACCV = LIASACC
      [M:FAS1]IASACN  = LIASACN
      [M:FAS1]IASACC  = LIASACC
    Endif
  Endif
  Call AFFICHE_COMPTES()
  If GLDABAPPL=G_NON
    Enable  GSTABOU+1
  Endif
  Endif

  # CBO FQ67615
  If GWVIALIGNE = 0
    If func CTRL_LVA_PRINCIPAL([M:FPC]LEG, [M:FPC]COA(0), [M:LOF6]GACV,
&                        [M:LOF6]CPY, G300CPFI, [F:LOFP]DATIMP,
&                        0, GW_LVA_TYP_PRIN,
&                        GWLVALIM, GWDATSTRFIY, GWDATENDFIY)
      End
    Endif
  Endif
End

######################################################################################
Subprog CL_SELICO(VALEUR)
Variable Char    VALEUR()

Local Integer NEXISTE
Local Integer NDSREXISTE

  # Ajouter
  If (nolign > [M:LOF6]NBSRCE)  or ([M:LOF6]CODLOFS(nolign-1)= "")
    GBOUT3 = "" :      Disable GSTABOU+1 : : mkstat = 0
    End
  Else
    If GLDABAPPL = G_NON
      Enable GSTABOU+1
    Endif
    If [M:LOF6]CODLOFS(nolign-1) <> "" or 1=1
      Call IS_REFERENCE_EXISTE ([M:LOF6]CODLOFS(nolign-1), [M:LOF6]LINLOFS(nolign-1), NEXISTE)
      If NEXISTE = G_NON
        If [M:LOF6]NBDEST = 0
          NDSREXISTE = 1
        Else
          NDSREXISTE = 2
        Endif
        Call AJOUTE_UNE_LIGNE (nolign, G_OUI)
       # Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBDEST") From GLOBIENS
        Affzo [M:LOF6]20
        Dela nolign-1, 1 [M:LOF6]NBSRCE

        If [M:LOF6]NBSRCE > 0
          [M:LOF6]NBSRCE -= 1
        Endif
        If NDSREXISTE = 1
          Gosub REMPLI_SOURCE
          Call AS_NBSRCE From W1LOFLDAB
        Endif
      Endif
    Endif
  Endif

  #Call ACTION_BLOCK (ACB_AFFZO, "LOFLDAB", "NBSRCE") From GLOBIENS
  Affzo [M:LOF6]20
End


###################################################################################### FQ81867
Subprog AM_CUMAMTIAS(VALEUR)
Variable Decimal VALEUR
  [M:LOF6]CUMAMTIAS = VALEUR
  Call VALEUR_IMMO_ACT ()
End

###################################################################################### FQ84794
Subprog AM_AMTNOTIAS(VALEUR)
Variable Decimal VALEUR

 If GCNXPROIAS <>  G_OUI : End : Endif  ##YYFIN-X3-8326

  # Cumul
  [M:LOF6]CUMAMTIAS = [M:LOF6]CUMAMTIAS - [M:LOF6]AMTNOTIAS(nolign-1) + VALEUR
  Call VALEUR_IMMO_ACT ()
  Affzo [M:LOF6]CUMAMTIAS

  # FQ98116 : calcul des montants de TVA facturée et récupérée à partir des taux
  Raz [LOF]
  Read [LOF]LOF0=[M:LOF6]CODLOF(nolign-1);[M:LOF6]LINLOF(nolign-1)
  If fstat
    End
  Endif

  [M:LOF6]CUMVATIAS  -= [M:LOF6]AMTVATIAS(nolign-1)
  [M:LOF6]CUMVATRIAS -= [M:LOF6]AMTVATRIAS(nolign-1)

  Call GET_MNT_ARRONDI (VALEUR * [F:LOF]RATVAT / 100, [F:LOF]CUR, [M:LOF6]AMTVATIAS(nolign-1)) From GLOBIENS
  Call GET_MNT_ARRONDI ([M:LOF6]AMTVATIAS(nolign-1) * [F:LOF]RATVATREC / 100, [F:LOF]CUR, [M:LOF6]AMTVATRIAS(nolign-1)) From GLOBIENS

  [M:LOF6]CUMVATIAS  += [M:LOF6]AMTVATIAS(nolign-1)
  [M:LOF6]CUMVATRIAS += [M:LOF6]AMTVATRIAS(nolign-1)
End

