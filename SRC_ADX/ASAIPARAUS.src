#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("AUS",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
Endcase
Return

#----------------------#
$ACTIONB
Local Integer PSUBB
Call EXISTE_ADX("","","ASAIPARAUSB",PSUBB) From ORDSYS
If PSUBB
 Gosub ACTION From ASAIPARAUSB
Endif
Return

#------------------------------------------------#
$OUVRE
Local Char CHAPITRE(GLONADI) , GROUPE(GLONADI) , PARLIG(GLONADP)
CHAPITRE = PARAM(1)
GROUPE   = PARAM(2)
PARLIG   = PARAM(3)
Return

#------------------------------------------------#
$DEBUT
Raz [M:AUSP] , I
[M:AUSP]USR = [M:AUS0]USR
[M:AUSP]CHAPITRE = [L]CHAPITRE
[M:AUSP]GRPPAR = [L]GROUPE
For [ADP]ADP5 Where CHAPITRE=[L]CHAPITRE & GRPPAR=[L]GROUPE
 K = find([F:ADP]PARAM,[M:AUS7]PARAM)
 If K
  I += 1
  [M:AUSP]PARAM(I-1)    = [M:AUS7]PARAM(K-1)
  [M:AUSP]NAME(I-1)     = [M:AUS7]NAME(K-1)
  [M:AUSP]VALEUR(I-1)   = [M:AUS7]VALEUR(K-1)
  [M:AUSP]NIVDEF(I-1)   = [M:AUS7]NIVDEF(K-1)
  [M:AUSP]NIVEAU(I-1)   = [M:AUS7]NIVEAU(K-1)
  [M:AUSP]VALINT(I-1)   = [M:AUS7]VALINT(K-1)
  [M:AUSP]TYP(I-1)      = [M:AUS7]TYP(K-1)
  [M:AUSP]NOLIB(I-1)    = [M:AUS7]NOLIB(K-1)
  [M:AUSP]LONG(I-1)     = [M:AUS7]LONG(K-1)
  [M:AUSP]FMT(I-1)      = [M:AUS7]FMT(K-1)
  [M:AUSP]SITE(I-1)     = [M:AUS7]SITE(K-1)
  [M:AUSP]SOCIETE(I-1)  = [M:AUS7]SOCIETE(K-1)
  If dim([M]LEG)>0
   [M:AUSP]LEG(I-1)     = [M:AUS7]LEG(K-1)
  Endif
  [M:AUSP]VALDEF(I-1)   = [M:AUS7]VALDEF(K-1)
  [M:AUSP]AUSMODIF(I-1) = [M:AUS7]AUSMODIF(K-1)
  [M:AUSP]GRPDEF(I-1)   = [M:AUS7]GRPDEF(K-1)
  If dim([M:AUSP]AUTMOD)>0
   [M:AUSP]AUTMOD(I-1)  = [M:AUS7]AUTMOD(K-1)
  Endif
 Endif
Next ADP
[M:AUSP]NBVAR = I
Affzo

#### Vérification de la possibilité de modification du champ
:#F_add_admca_managment
If clalev([F:AUS2])=0 : Local File AUTILIS [AUS2] : Endif                            # Issue 109555
Read [F:AUS2]CODUSR=[M:AUSP]USR                                                      # End issue 109555

For I=1 To [M:AUSP]NBVAR
 If dim([M:AUSP]AUTMOD)>0 & [M:AUSP]AUTMOD(I-1)=0
  Diszo [AUSP]VALEUR(I-1)
# Elsif [M:AUSP]USR=GSUPER & GUSER=GSUPER                                            # Issue 109555
 Elsif ([M:AUSP]USR=GSUPER & GUSER=GSUPER) | ([M:AUSP]USR="ADMCA" & GUSER="ADMCA")   # End issue 109555
  Case [M:AUSP]PARAM(I-1)
   When "AUZFCT"
    [M:AUSP]VALEUR(I-1) = "*"
    Diszo [AUSP]VALEUR(I-1)
   When Default
    Actzo [AUSP]VALEUR(I-1)
  Endcase
# Elsif (GPROFIL=GSUPER)                                                             # Issue 109555
 Elsif (GPROFIL=GSUPER) | (GPROFIL="ADMCA" & [F:AUS2]PRFFCT<>GSUPER)                 # End issue 109555
  Actzo [AUSP]VALEUR(I-1)
 Elsif [M:AUSP]AUSMODIF(I-1)<>2
  Grizo [AUSP]VALEUR(I-1)
 Else
  Actzo [AUSP]VALEUR(I-1)
 Endif
Next I

If PARLIG<>""
 I = find(PARLIG,[M:AUSP]PARAM)
 If I
  zonsui = "[M:AUSP]NBVAR("+num$(I-1)+")"
 Endif
Endif
Return

#------------------------------------------------#
$OK
For I=1 To [M:AUSP]NBVAR
 K = find([M:AUSP]PARAM(I-1),[M:AUS7]PARAM)
 If K
  [M:AUS7]GRPDEF(K-1) = [M:AUSP]GRPDEF(I-1)
  [M:AUS7]VALEUR(K-1) = [M:AUSP]VALEUR(I-1)
  [M:AUS7]VALINT(K-1) = [M:AUSP]VALINT(I-1)
  [M:AUS7]NIVEAU(K-1) = [M:AUSP]NIVEAU(I-1)
 Endif
Next I
mkstat = 4
Return

#------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "SELADGAUS" : Gosub SEL_ADG
Endcase
Return

#------------------------------------------------#
$VERF_LISTE
Case LISTE
 When "SELADGAUS" : Gosub VERF_ADG
Endcase
Return

#------------------------------------------------#
$SEL_ADG
If clalev([F:ADG])=0 : Local File ADOVALGRP [ADG] : Endif
Local Char CRITERE(250)
CRITERE = 'CHAPITRE="'+PARAM(1)+'" & GRPPAR="'+PARAM(2)+'"'
Raz NBTEX
K = 0
For I=1 To [M:AUSP]NBVAR
 If dim([M:AUSP]AUTMOD)>0 & [M:AUSP]AUTMOD(I-1)=0
  K = I : Break
 Endif
Next I
If K
 Call MESSAGE([M:AUSP]PARAM(K-1)-":"-mess(59,143,1)) From GESECRAN : # Paramètre non modifiable
Else
 For [ADG]ADG1(1) Where evalue(CRITERE)
  NBTEX += 1
  TEX(NBTEX) = [F:ADG]GRPDEF
  Call LECTEXTRA(TEXTE(NBTEX),"ATABDIV","LNGDES","912",[F:ADG]GRPDEF) From ATEXTRA
  TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
 Next ADG
 If NBTEX=0
  Call MESSAGE(mess(107,139,1)) From GESECRAN : # Aucun jeu disponible
 Endif
Endif
FORCE = 1
Call TITOBJ("ADG","",TIT) From CONTOBJ
Return

#------------------------------------------------#
$VERF_ADG
For I=1 To [M:AUSP]NBVAR
 [M:AUSP]GRPDEF(I-1) = TEX(CHOIX)
 Read [ADG]ADG1 = TEX(CHOIX);[M:AUSP]CHAPITRE;[M:AUSP]GRPPAR;[M:AUSP]PARAM(I-1)
 If !fstat
  [M:AUSP]VALINT(I-1) = [F:ADG]VALEUR
  [M:AUSP]VALEUR(I-1) = [F:ADG]VALEUR
  Call CHARGE([M:AUSP]VALEUR(I-1),[M:AUSP]TYP(I-1),[M:AUSP]NOLIB(I-1)
&            ,[M:AUSP]LONG(I-1),[M:AUSP]VALINT(I-1)) From FMTVAR
  [M:AUSP]NIVEAU(I-1) = 4
 Endif
Next I
Affzo
Return

#-----------------------------------------------#
# Gestion du masque AUSP
#-----------------------------------------------#

Subprog IB_NBVAR
If GPROFIL<>GSUPER
 Raz GBOUT1 , GBOUT2
Endif
End

Subprog B1_NBVAR
Local Decimal BASPAG
Local Char    PARMSK(250)(1..20)
PARMSK(1) = [M]CHAPITRE
PARMSK(2) = [M]GRPPAR
Call S_LIS_NUM(BASPAG,PARMSK,"SELADGAUS","ASAIPARAUS","") From GACTION
End

Subprog B2_NBVAR
Local Char CHP(GLONADI) , JEU(GLONADP)
Gosub SETNOL
CHP = [M]CHAPITRE
JEU = [M]GRPDEF(NOL)
If JEU=""
 For I=1 To [M]NBVAR
  If [M]GRPDEF(I-1)<>""
   JEU = [M]GRPDEF(I-1)
   Break
  Endif
 Next I
 If JEU=""
  Filter [ADG] Where CHAPITRE=[M]CHAPITRE & GRPPAR=[M]GRPPAR
  Read [ADG] First
  If !fstat
   JEU = [F:ADG]GRPDEF
  Endif
  Filter [ADG]
 Endif
Endif
Call OBJET_CHAR(CHP,"ADG",[M]GRPPAR+"~"+JEU) From GOBJET
End

Subprog B3_NBVAR
Hlpbox "ADP_"+[M]CHAPITRE+"_"+[M]PARAM(nolign-1)
End

#------------------------------------------------#
Subprog AS_VALEUR(VALEUR)
Variable Char    VALEUR()
GMODIF = 4
End

#------------------------------------------------#
Subprog C_VALEUR(VALEUR)
Variable Char VALEUR
If VALEUR <> ""
 Call C_VALEUR(VALEUR) From ASAIPARVAL
Endif
If mkstat : End : Endif
Case [M]PARAM(nolign-1)
 When "NBRCHOOSE","LFTBOX"
  If val(VALEUR)>500
   Local Integer OK
   OK = 1
   Call AVERTIR(mess(44,130,1),OK) From GESECRAN : # Attention aux performances
   If OK<>2
    mkstat = 2 : End
   Endif
  Endif
 When "AGRPDEV"
  If GADONIX=2
   If VALEUR="SAGE" : Call ERREUR(VALEUR-":"-mess(25,126,1)) From GESECRAN : mkstat=2 : Endif : #  : Code incorrect
  Endif
Endcase
Local Char ACTION(20)
ACTION = "C_VALEUR" : Gosub ACTIONB
End

#------------------------------------------------#
Subprog AM_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Case GMODIF
 When 1 : [M]NIVEAU(NOL) = 1 : # Dossier
 When 2 : [M]NIVEAU(NOL) = 2 : # Société
 When 3 : [M]NIVEAU(NOL) = 3 : # Site
 When 4 : [M]NIVEAU(NOL) = 4 : # Utilisateur
 When 5 : [M]NIVEAU(NOL) = 5 : # Législation
Endcase
[M]VALEUR(NOL) = VALEUR
For I=1 To [M]NBVAR
 [M]GRPDEF(I-1) = ""
Next I
Affzo 20
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

#------------------------------------------------#
Subprog IB_VALEUR
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
Read [ADP]ADP1 = [M]PARAM(nolign-1)
If  [F:ADP]NBVAL<>0
& & [F:ADP]OBJET=""    # Issue X3-44568 - 2017-06-12 by CCC : NBVAL=1 if parameter of object
 GBOUT6 = mess(133,126,1) : # Liste de valeurs
Endif
If [F:ADP]VALDEF=2
 If [M]SITE(nolign-1)<>""
  Read [ADW]ADW0 = "";[M]SITE(nolign-1);[M]PARAM(nolign-1)
  If !fstat
   GBOUT5 = mess(288,123,1) : # Valeur standard
  Endif
 Endif
 If [M]SOCIETE(nolign-1)<>"" & GBOUT5=""
  Read [ADW]ADW0 = [M]SOCIETE(nolign-1);"";[M]PARAM(nolign-1)
  If !fstat
   GBOUT4 = mess(288,123,1)  : # Valeur standard
  Endif
 Endif
 If dim([M]LEG)>0 & [M]LEG(nolign-1)<>"" & sum(GBOUT5+GBOUT4)=""
  Read [ADW]ADW0 = "*";[M]LEG(nolign-1);[M]PARAM(nolign-1)
  If !fstat
   GBOUT3 = mess(288,123,1)  : # Valeur standard
  Endif
 Endif
 If sum(GBOUT5+GBOUT4+GBOUT3)="" : # Dossier
  Read [ADW]ADW0 = "";"";[M]PARAM(nolign-1)
  If !fstat
   GBOUT2 = mess(288,123,1)  : # Valeur standard
  Endif
 Endif
Endif
End

#------------------------------------------------#
Subprog B1_VALEUR(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(250)(1..10)
Read [ADP]ADP1 = [M]PARAM(nolign-1)
PARAM(1) = [M]TYP(nolign-1)
If left$([F:ADP]VALUES(0),1)="="
 Onerrgo RIEN
 PARAM(2) = evalue(right$([F:ADP]VALUES(0),2))
 Onerrgo
Else
 PARAM(2) = [F:ADP]VALUES(0)
Endif
Call S_AFF_CHAR(VALEUR,PARAM,"AFMTB1","FMTVAR","") From GACTION
End

#------------------------------------------------#
$RIEN
Resume

#------------------------------------------------#
Subprog B2_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = "";"";[M]PARAM(NOL) : # Charge la valeur "dossier" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 1
 mkstat = 4
Endif
End

#------------------------------------------------#
Subprog B3_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = "*";[M]LEG(NOL);[M]PARAM(NOL) : #  Charge la valeur "législation" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 5
 mkstat = 4
Endif
End

#------------------------------------------------#
Subprog B4_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = [M]SOCIETE(NOL);"";[M]PARAM(NOL) : #  Charge la valeur "société" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 2
 mkstat = 4
Endif
End

#------------------------------------------------#
Subprog B5_VALEUR(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Read [ADW]ADW0 = "";[M]SITE(NOL);[M]PARAM(NOL) : #  Charge la valeur "site" du paramètre
If !fstat
 VALEUR = [F:ADW]VALEUR
 Call CHARGE(VALEUR,[M]TYP(NOL),[M]NOLIB(NOL),[M]LONG(NOL),[M]VALINT(NOL)) From FMTVAR
 GMODIF = 3
 mkstat = 4
Endif
End

