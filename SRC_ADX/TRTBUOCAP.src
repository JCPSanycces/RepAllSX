#<AdxTL>@(#)4.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Fonction : CCLCAP - Annulation Approbation Budget
#   Action   : CCLCAP
#   Ecran concerné : CAP1
#   Description : Pour annuler une approbation effectuée.
#                 Pour l'instant objet par objet, mais on pourrais faire
#                 par numéro d'approbation et ainsi désapprouvé plusieurs
#                 objets en même temps dans les cas multiples
#--------------------------------------------------------------------------

Local Char PARAM(10)(1..5) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"CCLCAP","TRTBUOCAP","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "AVANT_OK"     : Gosub AVANT_OK
 When "OK"           : Gosub OK
 When "SETBOUT"      : Gosub SETBOUT
 When Default
Endcase
Return

######################################################################################
$OUVRE
#Récup du paramétrage du niveau d'approbation
Global Char GAPPNIV(3)

#Entité de l'utilisateur courant (GUSER)
Global Char GENTUSR
#Paramétrage des niveaux d'approbation autorisés de l'utilisateur
Global Integer GAPPUSRENV,GAPPUSRBUD,GAPPUSRLIG
Local Char PARAPPENV,PARAPPBUD,PARAPPLIG
Call PARAMUTIL("GDDENTUSR",GENTUSR,"","") From SUBAUS
Call PARAMUTIL("USRAPPENV",PARAPPENV,"","") From SUBAUS
Call PARAMUTIL("USRAPPBUD",PARAPPBUD,"","") From SUBAUS
Call PARAMUTIL("USRAPPLIG",PARAPPLIG,"","") From SUBAUS
GAPPUSRENV=val(PARAPPENV)
GAPPUSRBUD=val(PARAPPBUD)
GAPPUSRLIG=val(PARAPPLIG)

#Paramètre de débrayage du circuit d'appro (ligne) en fonction de l'utilisateur
Global Integer GDEBAPP
Local Char PARDEBAPP
Call PARAMUTIL("GDDDEBAPP",PARDEBAPP,"","") From SUBAUS
GDEBAPP=val(PARDEBAPP)

#Tables utiles
If !clalev([AUS]) : Local File AUTILIS    [AUS] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([LED]) : Local File GLED       [LED] : Endif
If !clalev([GCM]) : Local File GACM       [GCM] : Endif
If !clalev([CCE]) : Local File CACCE      [CCE] : Endif
If !clalev([CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([TCA]) : Local File TABCOUAFF  [TCA] : Endif
If !clalev([FIY]) : Local File FISCALYEAR [FIY] : Endif
#Masque
Local Mask CAP1
#Variables locales
Local Integer STAT
Local Char NUMAPP
Local Char APPCPT(GLONANM)
Local Integer OKTCA
Local Integer OKACS, CTLACS
Return
######################################################################################

$DEBUT
Raz [M:CAP1]
Return

$AVANT_OK
Local Integer OK,COCHE : COCHE=0
For I=0 To [M]NBLIG-1
 If [M]ANU(I)=2
  COCHE=1 : Break
 Endif
Next
If !COCHE
 #Vous n'avez rien coché. Souhaitez-vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Endif
Return

$OK
#Ecriture d'une approbation pour tracer les annulations
Local Char LISTENVAPP(GLONENV)(1..[M]NBLIG)
Local Char LISTAPPMUL(GLONENV)(1..[M]NBLIG)
Local Char ENVCUR(GLONENV)
Local Integer NBENVAPP : NBENVAPP=0
Local Integer NBAPPMUL : NBAPPMUL=0
Local Integer I, J, X, NB
Local Integer INDENV, INDENT, INDCCE3

#Etablissement de la liste des enveloppes dont au moins un objet et soumis à approbation
For J=0 To [M]NBLIG-1
 If [M]ANU(J)=2
  If !find([M]ENV(J),LISTENVAPP(1..[M]NBLIG))
   NBENVAPP+=1
   LISTENVAPP(NBENVAPP)=[M]ENV(J)
   ENVCUR=[M]ENV(J)
  Endif
 Endif
Next
#Etablissement de la liste des enveloppes dont plusieurs objets sont soumis à approbation
For X=1 To NBENVAPP
 NB=0
 For I=0 To [M]NBLIG-1
  If [M]ANU(I)=2 & [M]ENV(I)=LISTENVAPP(X) : NB+=1 : Endif
 Next
 If NB>1
  NBAPPMUL+=1
  LISTAPPMUL(NBAPPMUL)=LISTENVAPP(X)
 Endif
Next

Local Char ALREADY_DONE(GLONENV)(1..[M]NBLIG)
Local Integer Q : Q=1
Local Integer NIVEAU
Call DEBTRANS From GLOCK
Gosub TR_OK
Return

$TR_OK
GOK=1
Trbegin [BOA],[BAD]
 For I=0 To [M]NBLIG-1
  If [M]ANU(I)=2
   If !find([M]ENV(I),LISTAPPMUL(1..[M]NBLIG))
    NIVEAU=[M]NIV(I)
    Gosub CRE_APPRO
   Elsif !find([M]ENV(I),ALREADY_DONE(1..[M]NBLIG))
    ALREADY_DONE(Q)=[M]ENV(I)
    Q+=1
    NIVEAU=4
    Gosub CRE_APPRO
   Endif
  Endif
  If GOK<1 : Break : Endif
 Next

 If GOK<1 : Goto AB_TR_OK : Endif

 #Réécriture des objets
 For I=0 To [M]NBLIG-1
  If [M]ANU(I)=2
   Case [M]NIV(I)
    When 1 :#Enveloppe
     Gosub RW_ENV
     If GOK<1 : Break : Endif
    When 2 :#Budget exercice
     Gosub RW_ENF
     If GOK<1 : Break : Endif
    When 3 :#lignes budgétaires
     Gosub RW_BUD
     If GOK<1 : Break : Endif
   Endcase
  Endif
 Next
 If GOK<0 : Goto ROLL_TR_OK
 Elsif !GOK : Goto AB_TR_OK
 Endif
Commit
Return

$CRE_APPRO
#Lecture affectation compteur
[L]APPCPT = ""
GSOCIETE  = [M]CPY
Call LECTCA(2,OKTCA)From SUBTCA
If OKTCA : [L]APPCPT = [F:TCA]CODNUM(9) : Endif
If [L]APPCPT="" : [L]APPCPT="BOA" : Endif
Call NUMERO(APPCPT,[M:CAP1]FCY,date$,"",[L]NUMAPP,STAT) From SUBANM
If STAT
 Gosub MESSAGE From SUBANM
 GMESSAGE=mess(60,199,1)-"("+APPCPT+") : "+MESSA
 GOK = 0
Endif

[F:BOA]NUM    = [L]NUMAPP
[F:BOA]TYP    = NIVEAU
[F:BOA]ENV    = [M]ENV(I)
[F:BOA]PRJ    = [M]PRJ(I)
[F:BOA]FIY    = [M]FIY(I)
[F:BOA]CUR    = [M]CUR(I)
If NIVEAU=4
 #Création des éléments dans BUDAPPDET
 L=0
 For J=0 To [M]NBLIG
  If [M]ENV(J)=[M]ENV(I) & [M]ANU(J)=2
   L+=1
   [F:BAD]NUMERO = L
   [F:BAD]NUMAPP = [L]NUMAPP
   [F:BAD]TYP    = [M]NIV(J)
   [F:BAD]ENV    = [M]ENV(J)
   [F:BAD]FIY    = [M]FIY(J)
   [F:BAD]ACCNUM = [M]ACCNUM(J)
   [F:BAD]ACC    = [M]ACC(J)
   [F:BAD]COA    = [M]COA(J)
   [F:BAD]AMT    = [M]AMT(J)
   [F:BAD]CUR    = [M]CUR(J)
   Write [BAD]
   If fstat
    GOK=0 : Call FSTA("BAD") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
Else
 [F:BOA]AMT    = [M]AMT(I)
Endif
[F:BOA]ACCNUM = [M]ACCNUM(I)
[F:BOA]ACC    = [M]ACC(I)
[F:BOA]COA    = [M]COA(I)
[F:BOA]STA    = 4
[F:BOA]DMDDAT = date$
[F:BOA]CREDAT = date$
[F:BOA]CREUSR = GUSER
Write [BOA]
If fstat
 GOK=0 : Call FSTA("BOA") From GLOCK : Return
Endif
Return

$RW_ENV
Readlock [ENV]ENV0 = [M]ENV(I)
If fstat=1
 GOK=-1 : GLOCK="$ENVELOPPE"-[M]ENV(I) : Return
Elsif fstat
 GOK=0 : Call FSTA("ENV") From GLOCK : Return
Endif
[F:ENV]STA    = 1
[F:ENV]AMTAPP = 0
[F:ENV]APPDAT = [0/0/0]
Call FLDUPD("ENV") From OBJDIV
Rewrite [ENV]
If fstat
 GOK=0 : Call FSTA("ENV") From GLOCK : Return
Endif

#Passage du status des budgets et des lignes budgétaires à "à annuler" selon le paramètrage
If [M]APPNIV="212" | [M]APPNIV="211"
 Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
 For [ENF]ENF0 Where ENV=[M]ENV(I) & STAFIY=3
  Readlock [ENF]ENF0=[F:ENF]ENV;[F:ENF]FIYNUM
  If fstat=1
   GOK=-1 : GLOCK="$ENVFIY"-[F:ENF]ENV-num$([F:ENF]FIYNUM) : Break
  Elsif fstat
   GOK=0 : Call FSTA("ENF") From GLOCK : Break
  Else
   [F:ENF]STAFIY=1
   [F:ENF]AMTAPPFIY = 0
   [F:ENF]APPDATFIY = [0/0/0]
   Call FLDUPD("ENF") From OBJDIV
   Rewrite [ENF]
   If fstat
    GOK=0 : Call FSTA("ENF") From GLOCK : Break
   Endif
  Endif

  If [M]APPNIV="211"
   For [BUD] Where evalue('CCE'+num$(INDENV))=[M]ENV(I) & FIY=[F:ENF]FIYNUM & STA=3
    Readlock [BUD]BUD1=[F:BUD]ACCNUM
    If fstat=1
     GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM : Break 2
    Elsif fstat
     GOK=0 : Call FSTA("BUD") From GLOCK : Break 2
    Else
     [F:BUD]STA=1
     [F:BUD]AMTAPP = 0
     [F:BUD]APPDAT = [0/0/0]
     Call FLDUPD("BUD") From OBJDIV
     Rewrite [BUD]
     If fstat
      GOK=0 : Call FSTA("BUD") From GLOCK : Break 2
     Endif
    Endif
   Next
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
Return

$RW_ENF
Readlock [ENF]ENF0 = [M]ENV(I);[M]FIY(I)
If fstat=1
 GOK=-1 : GLOCK="$ENVFIY"-[M]ENV(I)-num$([M]FIY(I)) : Return
Elsif fstat
 GOK=0 : Call FSTA("ENF") From GLOCK : Return
Endif
[F:ENF]STAFIY    = 1
[F:ENF]AMTAPPFIY = 0
[F:ENF]APPDATFIY = [0/0/0]
Call FLDUPD("ENF") From OBJDIV
Rewrite [ENF]
If fstat
 GOK=0 : Call FSTA("ENF") From GLOCK : Return
Endif

#Passage du status de la ligne budgétaire à "à annuler" selon le paramètrage
If [M]APPNIV="121" | [M]APPNIV="221"
 Call LEC_ENV([F:ENF]ENV)From CPTLEC
 Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

 For [BUD] Where evalue('CCE'+num$(INDENV))=[M]ENV(I) & FIY=[M]FIY(I) & STA=3
  Readlock [BUD]BUD1=[F:BUD]ACCNUM
  If fstat=1
   GOK=-1 : GLOCK="$BUD"-num$([F:BUD]ACCNUM) : Break
  Elsif fstat
   GOK=0 : Call FSTA("BUD") From GLOCK : Break
  Else
   [F:BUD]STA=1
   [F:BUD]AMTAPP = 0
   [F:BUD]APPDAT = [0/0/0]
   Rewrite [BUD]
   If fstat
    GOK=0 : Call FSTA("BUD") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
Return


$RW_BUD
Readlock [F:BUD]BUD1 = [M]ACCNUM(I)
If fstat=1
 GOK=-1 : GLOCK="$BUD"-num$([M]ACCNUM(I)) : Return
Elsif fstat
 GOK=0 : Call FSTA("BUD") From GLOCK : Return
Endif
[F:BUD]STA    = 1
[F:BUD]AMTAPP = 0
[F:BUD]APPDAT = [0/0/0]
Call FLDUPD("BUD") From OBJDIV
Rewrite [BUD]
If fstat
 GOK=0 : Call FSTA("BUD") From GLOCK : Return
Endif
Return

$AB_TR_OK
Rollback
Return

$ROLL_TR_OK
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_OK : Endif

$SETBOUT
If [M]NBLIG<=0
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
Return
######################################################################################
############################# Gestion du masque CAP1 #################################
######################################################################################

Subprog C_CFY(VALEUR)
Variable Char    VALEUR()
Local Integer ISOC, ISITE
Raz [M]FCY
ISOC   = find(VALEUR,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find(VALEUR,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 [M]FCY=VALEUR
 #06/10/09-Dmd54223:Autorisation site
 Call CONTFCY(VALEUR) From CPTSUB
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Else
 #06/10/09-Dmd54223:Autorisation site
 Call CONTCPY(VALEUR) From CPTSUB
Endif
[M]CPY=GSOC(ISOC)
Call SETGLBAPP(GSOC(ISOC),GAPPNIV) From TRTGDD
[M]APPNIV=GAPPNIV
Affzo [M]
End

Subprog AM_CFY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]CFY=VALEUR
 Raz [M]CRIPRJ
 Raz [M]ENTMSTR,ENTMEND
 Raz [M]ENTASTR,ENTAEND
 Raz [M]ENVSTR,ENVEND
 Raz [M]NBLIG
 Call DATDEFSOC([M]CPY,[M]DATSTR,[M]DATEND) From CONSSUB
Endif
End

Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]CFY<>""
 Gosub CHARGEMENT
 If [M]NBLIG>0 : mkstat=4 : Endif
Endif
End

Subprog C_CRIPRJ(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRJ]) = 0 : Local File PROJET [PRJ] : Endif
Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
If !fstat & [F:PRJ]ACS<>""
 Local Integer OKACC
 Call LECACC([F:PRJ]ACS,OKACC) From CPTSUB
 If !OKACC
  Call MESSAGE(mess(4,104,1)) From GESECRAN
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTMSTR<>""
 VALEUR=[M]ENTMSTR
 Affzo [M]ENTMEND
Endif
End

Subprog C_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTMSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog AS_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTASTR<>""
 VALEUR=[M]ENTASTR
 Affzo [M]ENTAEND
Endif
End

Subprog C_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTASTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End


Subprog C_ENVSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif

  If [F:ENV]FCY<>[M]CFY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CFY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
Endif
End

Subprog AS_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENVSTR<>""
 VALEUR=[M]ENVSTR
 Affzo [M]ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [F:ENV]FCY<>[M]CFY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CFY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
 If VALEUR<[M]ENVSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE=mess(44,199,1)
  mkstat=2 :End
 Endif
Endif
End

Subprog IB_NBLIG
If [M]NIV(nolign-1)<>3
 Raz GBOUT2
Else
 Raz GBOUT1
Endif
#If [M]TYP(nolign-1)<>4
# Raz GBOUT3
#Endif
End
######################################################################################

$CHARGEMENT
Local Integer I : I=0
Local Libelle LEDTYPGEN, LEDTYPANA
Raz [M]NBLIG
Local Integer SOC,J,ACHAT
Local Char LISTFCY(GLONFCY)(1..GNBSITE)
Local Integer OKACS, CTLACS
Local Integer INDENV, INDENT, INDCCE3
CTLACS = 1

SOC=find([M]CFY,GSOC(1..GNBSOC))
J=1
If SOC
 For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
  LISTFCY(J)=[F:FCY]FCY
  J+=1
 Next
Endif

Local Char CRITENV(250)
CRITENV="1=1"
CRITENV-= '& (FCY="'+[M]CFY+'" | find(FCY,LISTFCY(1..J)))'

If [M]CRIPRJ<>""
 CRITENV -='& PRJ="'+[M]CRIPRJ+'"'
Endif

If [M]ENTMSTR<>""
 CRITENV -= '& ENTMNA>="'+[M]ENTMSTR+'" & ENTMNA<="'+[M]ENTMEND+'"'
Endif
If [M]ENTASTR<>""
 CRITENV -= '& ENTAPP>="'+[M]ENTASTR+'" & ENTAPP<="'+[M]ENTAEND+'"'
Endif
If [M]ENVSTR<>""
 CRITENV -= '& ENV>="'+[M]ENVSTR+'" & ENV<="'+[M]ENVEND+'"'
Endif
If [M]DATSTR<>[0/0/0] & [M]DATEND<>[0/0/0]
 CRITENV -='& REASTR<=['+format$(GFMD,[M]DATEND)+'] & REAEND>=['+format$(GFMD,[M]DATSTR)+']'
Endif

Local Char INTENV(30)

For [ENV]ENV0 Where evalue(CRITENV)
 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif
 If OKACS
  #Pour intitulé exercice
  Call SETMAINREF([F:ENV]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV

  Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA

  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

  Call VERFLIGACH([F:ENV]ENV,0,INDENV,ACHAT)
  If !ACHAT & [F:ENV]STA=3  & (GAPPNIV="211" | GAPPNIV="212" | GAPPNIV="221" | GAPPNIV="222") & GAPPUSRENV=2
   [M]NIV(I)    = 1
   [M]ENV(I)    = [F:ENV]ENV
   [M]AMT(I)    = [F:ENV]AMTENV
   [M]CUR(I)    = [F:ENV]CURENV
   [M]ENVINT(I) = INTENV
   [M]PRJ(I)    = [F:ENV]PRJ
   [M]ENTMNA(I) = [F:ENV]ENTMNA
   Raz [M]FIY(I), ACC(I), ACCNUM(I), ENTMNA(I),[M]ENTDEN(I),[M]LOT(I), [M]COA(I)
   [M]ANU(I)=1
   I+=1
  Endif
  #Les budgets exercices
  For [ENF]ENF0 Where ENV=[F:ENV]ENV
   Call VERFLIGACH([F:ENF]ENV,[F:ENF]FIYNUM,INDENV,ACHAT)
   If !ACHAT & [F:ENF]STAFIY=3 & (GAPPNIV="121" | GAPPNIV="122" | GAPPNIV="221" | GAPPNIV="222") & GAPPUSRBUD=2
    [M]NIV(I)    = 2
    [M]ENV(I)    = [F:ENF]ENV
    [M]FIY(I)    = [F:ENF]FIYNUM
    [M]INTFIY(I) = num$([F:ENF]FIYNUM)
    Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:ENF]FIYNUM
    If !fstat
     [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
    Endif
    [M]AMT(I)    = [F:ENF]AMTBUDFIY
    [M]CUR(I)    = [F:ENV]CURENV
    [M]ENVINT(I) = INTENV
    [M]PRJ(I)    = [F:ENV]PRJ
    [M]ENTMNA(I) = [F:ENV]ENTMNA
    Raz ACC(I), ACCNUM(I), [M]ENTDEN(I),[M]LOT(I),[M]COA(I)
    [M]ANU(I)=1
    I+=1
   Endif
   #Les Lignes Budgétaires
   For [BUD] Where STA=3 & evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM &
&                      AMTREA=0 & AMTCMM=0 & AMTCMMPRP=0
    If (GAPPNIV="112" | GAPPNIV="122" | GAPPNIV="212" | GAPPNIV="222")  & GAPPUSRLIG=2 | GDEBAPP=2
     [M]NIV(I)    = 3
     [M]ENV(I)    = evalue('[F:BUD]CCE'+num$(INDENV))
     [M]FIY(I)    = [F:BUD]FIY
     [M]INTFIY(I) = num$([F:BUD]FIY)
     Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:BUD]FIY
     If !fstat
      [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
     Endif
     [M]ACCNUM(I) = [F:BUD]ACCNUM
     [M]AMT(I)    = [F:BUD]AMT(0)
     [M]CUR(I)    = [F:BUD]CUR
     [M]ENTDEN(I) = evalue('[F:BUD]CCE'+num$(INDENT))
     [M]ACC(I)    = [F:BUD]ACC
     [M]COA(I)    = [F:BUD]COA
     [M]LOT(I)    = [F:BUD]LOT
     [M]ENVINT(I) = INTENV
     [M]PRJ(I)    = [F:ENV]PRJ
     [M]ENTMNA(I) = [F:ENV]ENTMNA
     [M]ANU(I)    = 1
     I+=1
    Endif
   Next
  Next
 Endif
Next

If I=0
 #Aucun objet ne satisfait ces critères de sélection
 Call MESSAGE(mess(218,108,1)) From GESECRAN
 Return
Endif

[M]NBLIG=I
Affzo [M]
If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
Gosub COLORIZE
Return

$COLORIZE
Local Integer K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M]ENV(0)
For I=0 To [M]NBLIG-1
 If [M]ENV(I)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M]NBLIG(I) With "GDD"+num$(K)
 Else
  Chgstl [M]NBLIG(I) With "GDD"+num$(K)
 Endif
 ENVCUR=[M]ENV(I)
Next
Affzo [M]
Return

Subprog VERFLIGACH(ENVELOPPE,EXERCICE,I_ENV,ACHAT)
Value Char       ENVELOPPE()
Value Integer    EXERCICE
Value Integer    I_ENV
Variable Integer ACHAT

ACHAT=0
Local Char CRIT(100)
CRIT = 'CCE'+num$(I_ENV)+'="'+ENVELOPPE+'"'
If EXERCICE<>0
 CRIT += '& FIY='+num$(EXERCICE)
Endif
For [BUD]BUD0 Where evalue(CRIT)
 If [F:BUD]AMTREA<>0 | [F:BUD]AMTCMM<>0 | [F:BUD]AMTCMMPRP<>0
  ACHAT=1 : Break
 Endif
Next
End ACHAT

######################################################################################

Subprog C_ANU(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 #Selection automatique des objets en dessous
 Case NIV(nolign-1)
   When 1 : #Enveloppe
   For J=0 To [M]NBLIG-1
    If [M]NIV(J)<>1 & [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1) & [M]ANU(J)<>2
     [M]ANU(J)=2
     Affzo [M]
    Endif
   Next
  When 2 : #Budget exercice
   For J=0 To [M]NBLIG-1
    If [M]NIV(J)>2 & [M]ENV(J)=[M]ENV(nolign-1) & [M]FIY(J)=[M]FIY(nolign-1) & J<>(nolign-1) & [M]ANU(J)<>2
     [M]ANU(J)=2
     Affzo [M]
    Endif
   Next
 Endcase
Else
 #Désélection automatique des objets supérieur
 Case NIV(nolign-1)
  When 2 : #Budget exercice
   For J=0 To [M]NBLIG-1
    If [M]NIV(J)<2 & [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1) & [M]ANU(J)=2
     [M]ANU(J)=1
     Affzo [M]
    Endif
   Next
  When 3 : #Ligne
   If GDEBAPP=1
    For J=0 To [M]NBLIG-1
     If [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1) & [M]ANU(J)=2
      If ([M]NIV(J)=2 & [M]FIY(J)=[M]FIY(nolign-1)) | [M]NIV(J)=1
       [M]ANU(J)=1
      Endif
     Endif
     Affzo [M]
    Next
   Endif
 Endcase
Endif
[M]ANU(nolign-1)=VALEUR
Affzo [M]
End

Subprog CL_COCHER(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]ANU(0)=1
  COCHE=2
 Else
  COCHE=1
 Endif
 For I=0 To [M]NBLIG-1
  [M]ANU(I)=COCHE
 Next
 Affzo [M]
Endif
End

