#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Copy the operation from old table ACLAOPE to table ACLAMET
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Copy Operation from table ACLAOPE to ACLAMET") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#

$MAJTAB

Local Integer OPEN_FILE_KO
Raz OPEN_FILE_KO

Onerrgo FILE_OPEN_ERR
If DOSSIER=nomap
 Local File ACLAMET [ACLAM]
 Local File ACLAMET [ACLAM2]
 Local File ACLAOPE [ACLAO]
Else
 Local File =DOSSIER+".ACLAMET" [ACLAM]
 Local File =DOSSIER+".ACLAMET" [ACLAM2]
 Local File =DOSSIER+".ACLAOPE" [ACLAO]
Endif
Onerrgo

If OPEN_FILE_KO : Return : Endif

If dim([F:ACLAM]FLGOPE)<0
 Return
Endif

Local Char L_CURRENT_CLA(30)
Local Integer L_NBOPE

Filter [ACLAO] Order By Key ACLAO1
Trbegin [ACLAO]
 For [ACLAO]
  Read [ACLAM2]ACLAM0 = [F:ACLAO]CODCLA;[F:ACLAO]CODOPE
  If !fstat
   Call ECR_TRACE("Classe: "+[F:ACLAO]CODCLA-"Operation: "+[F:ACLAO]CODOPE- "n'est pas copiée",0) From GESECRAN
  Else
   Raz [F:ACLAM]
   If [ACLAO]CODCLA <> L_CURRENT_CLA
    L_CURRENT_CLA = [ACLAO]CODCLA
    L_NBOPE = func GET_NBMET(L_CURRENT_CLA)
   Endif
   L_NBOPE += 1
   [F:ACLAM]CODCLA = [F:ACLAO]CODCLA
   [F:ACLAM]NOMET  = L_NBOPE
   [F:ACLAM]CODMET = [F:ACLAO]CODOPE
   [F:ACLAM]DONMET = [F:ACLAO]DONOPE
   [F:ACLAM]INTMET = [F:ACLAO]INTOPE
   [F:ACLAM]ACTMET = [F:ACLAO]ACTOPE
   [F:ACLAM]ACSOPE = [F:ACLAO]ACSOPE
   [F:ACLAM]INDOPE = [F:ACLAO]INDOPE
   [F:ACLAM]FLGOPE = 2
   [F:ACLAM]CREUSR = [F:ACLAO]CREUSR
   [F:ACLAM]UPDUSR = [F:ACLAO]UPDUSR
   [F:ACLAM]CREDATTIM = [F:ACLAO]CREDATTIM
   [F:ACLAM]UPDDATTIM = [F:ACLAO]UPDDATTIM
   [F:ACLAM]AUUID = [F:ACLAO]AUUID
   Write [ACLAM]
   If fstat
    Call ERREUR("ACLAMET"-[F:ACLAM]CODCLA-num$([F:ACLAM]NOMET)-[F:ACLAM]CODMET,3) From DOSDIC
   Endif
  Endif
 Next
Commit
Filter [ACLAO]

Close Local File [ACLAM],[ACLAO]

Return


$FILE_OPEN_ERR
 OPEN_FILE_KO = 1
Resume

Funprog GET_NBMET(CODCLA)
Value Char CODCLA
 Local Integer RES_NBMET
 Local File ACLAMET [ACLAM3]
 For [F:ACLAM3] Where CODCLA = [L]CODCLA
  If [F:ACLAM3]NOMET > RES_NBMET
   RES_NBMET = [F:ACLAM3]NOMET
  Endif
 Next
 Close Local File [ACLAM3]
End RES_NBMET
