#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
## Appelé depuis l'étiquette AV_AXX de TRCMAJ30
## Transfert des intitulés et désignations dans ATEXTRA
#########################################################################
$MAJ_AXX
#---- Màj des intitulés traduisibles de la table des Règles d'affectation PARMTO 
If filinfo(filpath("FIL","PARMTO","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".PARMTO"   [PTO] 
  For [PTO]
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:PTO]PTODES,"PARMTO","PTODESAXX",[F:PTO]PTOCOD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"PARMTO PTODESAXX"-[F:PTO]PTOCOD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:PTO]PTOSHO,"PARMTO","PTOSHOAXX",[F:PTO]PTOCOD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"PARMTO PTOSHOAXX"-[F:PTO]PTOCOD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
  Next      
  Close Local File [PTO]
Endif
#---- fin MAJ Table PARMTO
#---- Màj des intitulés traduisibles de la table des Guides opérateurs USERGUIDES 
If filinfo(filpath("FIL","USERGUIDES","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".USERGUIDES"   [UGD]         

  For [UGD]
