#-------------------------------------------------------#
# Mise à jour de l'onglet sélection des objets modifiés #
#-------------------------------------------------------#
$MAJ_AOBJET
Local Char WOBJET(GLONAOB)
Local Integer WNBR

  # FGR 08/07/2009 : X3SUIVI56335
  Local File =[F:ADS]DOSSIER+".AOBJET" [AOB]
  #
  For WOBJET="BCG", "BOD", "BPC", "BCG", "BOD", "BPC", "BPS", "BSG", "CAB", "CAD", "CFG", "CFM", "CGD",
&            "CO1", "COV", "CQU", "CQV", "CQW", "CSE", "CSH", "CTC", "CTN", "DEB", "DIH", "FID", "FPT", "HSH",
&            "ITF", "ITM", "ITS", "MFG", "MST", "MWC", "MWI", "MWS", "OPP", "PR2", "QST", "ROU", "SBX", "SCP",
&            "SD1", "SES", "SLE", "SND", "SNE", "SNX", "SSP", "ST1", "ST2", "STE", "STO", "STX", "TBO", "TCN",
&            "TCT", "TGL", "TGP", "TGT", "TLO", "TRU", "TSA", "TUV", "TWC", "TWD", "UGD"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL([F:ADS]DOSSIER,WOBJET) From PATCHAOB
    Endif
  Next WOBJET
  #
  Close Local File [AOB]
Return

