&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:UGD]UGDSHO,"USERGUIDES","UGDSHOAXX",[F:UGD]UGD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"USERGUIDES UGDSHOAXX"-[F:UGD]UGD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
  Next 
     
  Close Local File [UGD]
Endif
#---- fin MAJ Table USERGUIDES
