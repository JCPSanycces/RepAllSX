#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# FINANCE OPERATING BUDGET
#
# CTL_BUOCCE : Controls the dimensions that belong to an entity or envelope dimension type.
# Runs in a classic environment. This sub-program is called if the activity code GDD is enabled
#
# CTL_BUOCCESYRA : Controls the dimensions that belong to an entity or envelope dimension type.
# Runs in a syracuse environment. This sub-program is called if the activity code GDD is enabled
#
#
# Private routines :
# _CTL_BUOCCE
#
# GET_BUOINF : Returns from the arrays of dimensions and dimension types:
# the entity, the envelope, the third dimension, the envelope type, the budget code, the budget site
# and a flag that indicates if it is an operation budget
##############################################################################################################
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE

##############################################################################################################
# CTL_BUOCCE - Called from classic environment
##############################################################################################################
#**
#* Controls the dimensions that belong to an entity or envelope dimension type.<br>
#* Runs in a classic environment. This sub-program is called if the activity code GDD is enabled
#*
#* @param ACTX   Context
#* @param VALCCE Value of the dimension to control
#* @param DIECOD Dimension type of the VALCCE dimension
#* @param FCY    Site
#* @param DAT    Date
#* @param NOL    Number of the current line
#* @param LSTDIE List of the other dimension types
#* @param LSTCCE List of the other dimensions
#* @param LSTCOA List of the charts of account of all the ledgers
#* @param LSTACC List of the accounts of all the ledgers
#* @param ERRMES Error message
#*!
Funprog CTL_BUOCCE(ACTX,VALCCE,DIECOD,FCY,DAT,NOL,LSTDIE,LSTCCE,LSTCOA,LSTACC,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     VALCCE()    : # Value of the dimension to control
Value    Char     DIECOD()    : # Dimension type of the VALCCE dimension
Value    Char     FCY()       : # Site
Value    Date     DAT         : # Date
Value    Integer  NOL         : # Number of the current line
Value    Char     LSTDIE()    : # List of the other dimension types
Value    Char     LSTCCE()    : # List of the other dimensions
Value    Char     LSTCOA()    : # List of the charts of account of all the ledgers
Value    Char     LSTACC()    : # List of the accounts of all the ledgers

Variable Char     ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If VALCCE="" | !func AFNC.ACTIV("GDD") : End [L]ASTATUS : Endif

Local Char    DIEENV(GLONDIE)    : # Envelope dimension type
Local Char    DIEENT(GLONENT)    : # Entity dimension type
Local Char    CCEENV(GLONCCE)    : # Envelope dimension
Local Char    CCEENT(GLONCCE)    : # Entity dimension
Local Char    COAANA(GLONCOA)    : # Chart of the analytical account
Local Char    ACCANA(GLONGAC)    : # Analytical account
Local Char    NUMCMMPRP(GLONVCR) : # Pre commitment number
Local Char    NUMORI(GLONVCR)    : # Original number document in a purchasing invoice
Local Integer TYPORI             : # Type of the original document (1=Order, 2=Receipt, 3=Return ..)
Local Char    COMPANY(GLONCPY)   : # Company

# To call EVAL_CAZ
Local Integer CAS_GDD            : CAS_GDD = 0
Local Char    DIEAZC(GLONCCE)    : DIEAZC  = DIECOD
Local Integer ERR , I , J , K , IND1, IND2

If adxtyp=33 | !clalev([F:DIE]) : Local File GDIE     [DIE] : Endif
If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT [GAC] : Endif
If adxtyp=33 | !clalev([F:CCE]) : Local File CACCE    [CCE] : Endif
If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

If LSTACC="" : End [L]ASTATUS : Endif

Raz DIEENV, DIEENT, CCEENV, CCEENT, COAANA, ACCANA

# Translate LSTDIE LSTCCE LSTCOA LSTACC and populate DIE CCE COA ACC variables
Call LEC_DIE([L]DIECOD) From CPTLEC
If [F:DIE]ENT=2 | [F:DIE]ENV=2
 CAS_GDD = 1
Else
 End [L]ASTATUS
Endif

Gosub EVAL_CAZ From SELCCE

# Find the analytical account
I = fmet ACTX.ACACHE.AFCY.AGETINDEX([L]FCY)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = [L]FCY-mess(15,104,1) : End [L]ASTATUS
Endif
[L]COMPANY = fmet ACTX.ACACHE.AFCY.AGETVALCHAR([L]FCY, "LEGCPY")

[L]ASTATUS = func FINACC_SYRA.GET_MAICOA(ACTX,2,[L]COMPANY,COAANA,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

I = find(COAANA,COA(0..dim([L]COA)-1))
If I
 ACCANA=ACC(I-1)
Endif

# Find the entity dimension and the envelope dimension
For I=0 To dim([L]DIE)-1
 Call LEC_DIE(DIE(I)) From CPTLEC
 If [F:DIE]ENT=2
  DIEENT = DIE(I)
  CCEENT = CCE(I)
 Elsif [F:DIE]ENV=2
  DIEENV = DIE(I)
  CCEENV = CCE(I)
 Endif
Next

If dim([M:PSH1]CMMPRPNUM)>0 : NUMCMMPRP = [M:PSH1]CMMPRPNUM(NOL) Else  NUMCMMPRP="" : Endif

If GFONCTION = "GESPIH"
 If GREP<>""
  TYPORI = [M]TYPORI(NOL)
  NUMORI = [M]NUMORI(NOL)
 Elsif clalev([F:PID])>0
  TYPORI = [F:PID]TYPORI
  NUMORI = [F:PID]NUMORI
 Endif
Endif

[L]ASTATUS = func _CTL_BUOCCE(ACTX,VALCCE,DIECOD,FCY,DAT,DIEENV,CCEENV,DIEENT,CCEENT,COAANA,ACCANA,NUMORI,TYPORI,NUMCMMPRP,ERRMES)
End [L]ASTATUS


##############################################################################################################
# CTL_BUOCCESYRA - Called from syracuse environment
##############################################################################################################
#**
#* Controls the dimensions that belong to an entity or envelope dimension type.<br>
#* Runs in a syracuse environment. This sub-program is called if the activity code GDD is enabled
#* @param ACTX     Context
#* @param COL_COA  Instance of chart of accounts
#* @param COL_DIE  Instance od dimension types
#* @param VALCCE   Value of the dimension to control
#* @param DIECOD   Dimension type of the VALCCE dimension
#* @param FCY      Site
#* @param DAT      Date
#* @param NUMORI   Original number document in a purchasing invoice
#* @param TYPORI   Type of the original document (1=Order, 2=Receipt, 3=Return ..)
#* @param ERRMES   Error message
#*!
Funprog CTL_BUOCCESYRA(ACTX,COL_COA,COL_DIE,VALCCE,DIECOD,FCY,DAT,NUMORI,TYPORI,ERRMES)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Instance COL_COA Using OBJECT
Value    Instance COL_DIE Using OBJECT
Value    Char     VALCCE()    : # Value of the dimension to control
Value    Char     DIECOD()    : # Dimension type of the VALCCE dimension
Value    Char     FCY()       : # Site
Value    Date     DAT         : # Date
Value    Char     NUMORI      : # Original number document in a purchasing invoice
Value    Integer  TYPORI      : # Type of the original document (1=Order, 2=Receipt, 3=Return ..)
Variable Char     ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If VALCCE="" | !func AFNC.ACTIV("GDD") : End [L]ASTATUS : Endif

Local Char    DIEENV(GLONDIE)    : # Envelope dimension type
Local Char    DIEENT(GLONENT)    : # Entity dimension type
Local Char    CCEENV(GLONCCE)    : # Envelope dimension
Local Char    CCEENT(GLONCCE)    : # Entity dimension
Local Char    COAANA(GLONCOA)    : # Chart of the analytical account
Local Char    ACCANA(GLONGAC)    : # Analytical account
Local Char    COMPANY(GLONCPY)   : # Company
Local Char    NUMCMMPRP(GLONVCR) : # Pre commitment number
Local Integer I

If adxtyp=33 | !clalev([F:DIE]) : Local File GDIE     [DIE] : Endif
If adxtyp=33 | !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

If COL_COA=AVOID.AINS : End [L]ASTATUS : Endif

Raz DIEENV, DIEENT, CCEENV, CCEENT, COAANA, ACCANA

# Find the analytical account
I = fmet ACTX.ACACHE.AFCY.AGETINDEX([L]FCY)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = [L]FCY-mess(15,104,1) : End [L]ASTATUS
Endif
[L]COMPANY = fmet ACTX.ACACHE.AFCY.AGETVALCHAR([L]FCY, "LEGCPY")
[L]ASTATUS = func FINACC_SYRA.GET_MAICOA(ACTX,2,COMPANY,COAANA,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

For I=1 To maxtab(COL_COA)
 If COL_COA(I)<>null & COL_COA(I).COA<>AVOID.ACHAR & !find(COL_COA(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & COAANA=COL_COA(I).COA
  ACCANA = COL_COA(I).ACC
  Break
 Endif
Next

# Find the entity dimension and the envelope dimension
For I=1 To maxtab(COL_DIE)
 If COL_DIE(I)<>null & COL_DIE(I).DIE<>AVOID.ACHAR & !find(COL_DIE(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
  Call LEC_DIE(COL_DIE(I).DIE) From CPTLEC
  If [F:DIE]ENT=2
   DIEENT = COL_DIE(I).DIE
   CCEENT = COL_DIE(I).CCE
  Elsif [F:DIE]ENV=2
   DIEENV = COL_DIE(I).DIE
   CCEENV = COL_DIE(I).CCE
  Endif
 Endif
Next

If dim(COL_DIE.APARENT.APARENT.CMMPRPNUM)>0 : NUMCMMPRP = COL_DIE.APARENT.APARENT.CMMPRPNUM Else NUMCMMPRP="" : Endif

[L]ASTATUS = func _CTL_BUOCCE(ACTX,VALCCE,DIECOD,FCY,DAT,DIEENV,CCEENV,DIEENT,CCEENT,COAANA,ACCANA,NUMORI,TYPORI,NUMCMMPRP,ERRMES)
End [L]ASTATUS


######################################################################################################
# _CTL_BUOCCE
######################################################################################################
#**
#* @private
#*
#* @param ACTX      Context
#* @param VALCCE    Value of the dimension to control
#* @param DIE       Dimension type of the VALCCE dimension
#* @param FCY       Site
#* @param DAT       Date
#* @param DIEENV    Envelope dimension type
#* @param CCEENV    Envelope dimension
#* @param DIEENT    Entity dimension type
#* @param CCEENT    Entity dimension
#* @param COAANA    Chart of the analytical account
#* @param ACCANA    Analytical account
#* @param NUMORI    Original number document in a purchasing invoice
#* @param TYPORI    Type of the original document (1=Order, 2=Receipt, 3=Return ..)
#* @param NUMCMMPRP Pre commitment number
#* @param ERRMES    Error message
#*!
Funprog _CTL_BUOCCE(ACTX,VALCCE,DIE,FCY,DAT,DIEENV,CCEENV,DIEENT,CCEENT,COAANA,ACCANA,NUMORI,TYPORI,NUMCMMPRP,ERRMES)
Variable Instance ACTX   Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     VALCCE()    : # Value of the dimension to control
Value    Char     DIE()       : # Dimension type of the VALCCE dimension
Value    Char     FCY()       : # Site
Value    Date     DAT         : # Date
Value    Char     DIEENV()    : # Envelope dimension type
Value    Char     CCEENV()    : # Envelope dimension
Value    Char     DIEENT()    : # Entity dimension type
Value    Char     CCEENT()    : # Entity dimension
Value    Char     COAANA()    : # Chart of the analytical account
Value    Char     ACCANA()    : # Analytical account
Value    Char     NUMORI()    : # Original number document in a purchasing invoice
Value    Integer  TYPORI      : # Type of the original document (1=Order, 2=Receipt, 3=Return ..)
Value    Char     NUMCMMPRP() : # Pre commitment number
Variable Char     ERRMES()    : # Error message

Local Integer  ASTATUS : [L]ASTATUS = [V]CST_AOK

Local Shortint FLGDIE            : # 1=Entity dimension type /  2=Envelope dimension type
Local Shortint NOAPPROVAL        : # Value of the parameter GDDDEBAPP(=Approval non application)
Local Char     COMPANY(GLONCPY)  : # Company
Local Integer  FIY               : # Fiscal year of the company that matches the DAT
Local Integer  ENVFIY            : # Fiscal year of the envelope
Local Tinyint  LEDTYPGEN         : # Main general ledger type of the company
Local Tinyint  LEDTYPANA         : # Main analytical ledger type of the company
Local Tinyint  LEDTYPIAS         : # Main ias ledger type of the company
Local Char     NUMCMMPRP(GLONVCR): # Number of the pre commitment
Local Char     CRITBUD(250)      : # Search criteria for the budget
Local Shortint BOTH              : # The line contains an envelope dimension and an entity dimension
Local Integer  FLGBUD            : # 1=The budget line exists / 2=The budget line is approved
Local Integer  FCTPIH            : # 1=A purchasing invoice is being created from an existing invoice document.
                                   # Then we do not control the status of both the envelope and the budget line
Local Integer I
Local Integer INDENT, INDENV, INDCCE3 : # Index of the entity, envelop and CCE3 in the ledger

If VALCCE="" | !func AFNC.ACTIV("GDD") : End [L]ASTATUS : Endif

If adxtyp=33 | !clalev([F:DIE])  : Local File GDIE      [DIE]  : Endif
If adxtyp=33 | !clalev([F:CCE])  : Local File CACCE     [CCE]  : Endif
If adxtyp=33 | !clalev([F:GAC])  : Local File GACCOUNT  [GAC]  : Endif
If adxtyp=33 | !clalev([F:FCY])  : Local File FACILITY  [FCY]  : Endif
If adxtyp=33 | !clalev([F:ENV])  : Local File ENVELOPPE [ENV]  : Endif
If adxtyp=33 | !clalev([F:BUT])  : Local File BUDTYP    [BUT]  : Endif
If adxtyp=33 | !clalev([F:CMD2]) : Local File GCOMMITD  [CMD2] : Endif
If adxtyp=33 | !clalev([F:BUD])  : Local File BUD       [BUD]  : Endif

# The dimension type is dedicated to the operation budgets if it is ticked "entity" or "envelope"
Call LEC_DIE([L]DIE) From CPTLEC
[L]FLGDIE = 0
If [F:DIE]ENT=2 : [L]FLGDIE = 1 : Endif
If [F:DIE]ENV=2 : [L]FLGDIE = 2 : Endif
If ![L]FLGDIE : End [L]ASTATUS : Endif

# User parameter GDDDEBAPP(=The budget line approval is detached or not detached from the approval of the concerned envelope)
# [V]CST_AYES : Do not check the envelope is approved.
# [V]CST_ANO  : Checks the envelope is approved
If func AFNC.ACTIV("GDD")   # Issue X3-107197
  [L]NOAPPROVAL = val(fmet ACTX.APARAM.AGETUSERVALCHAR("GDDDEBAPP"))
Endif   # Issue X3-107197

# Search the fiscal year
I = fmet ACTX.ACACHE.AFCY.AGETINDEX([L]FCY)
If I=[V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = [L]FCY-mess(15,104,1) : End [L]ASTATUS
Endif
[L]COMPANY = fmet ACTX.ACACHE.AFCY.AGETVALCHAR([L]FCY, "LEGCPY")

[L]ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(ACTX,COMPANY,LEDTYPGEN,LEDTYPANA,LEDTYPIAS,ERRMES)
If [L]ASTATUS : End [L]ASTATUS : Endif
[L]ASTATUS = func FINPER_SYRA.GET_FIY(ACTX, COMPANY, LEDTYPANA, DAT, FIY, ERRMES)
If [L]ASTATUS : End [L]ASTATUS : Endif

If CCEENV<>""
 Call LEC_ENV(CCEENV) From CPTLEC
 Call LEC_BUT([F:ENV]BUDTYP) From CPTLEC
 If [F:BUT]YEAFLG=1
  #-- Budget category=Annual
  #-- Take the fiscal year of the date of the envelope if this date belongs to a later fiscal year
  [L]ASTATUS =  func FINPER_SYRA.GET_FIY(ACTX, COMPANY, LEDTYPANA, [F:ENV]REASTR, ENVFIY, ERRMES)
  If [L]ASTATUS=[V]CST_AOK & FIY<ENVFIY
    FIY = ENVFIY
  Endif
 Else
  #-- Budget category=Multiannual
  #-- If a carry forward was done on the pre commitment (GRDPCE=6), take the fiscal year of the date of the pre commitment
  If NUMCMMPRP<>""
   Raz [F:CMD2]
   # Instead of Read[CMD2]CMD0 Last
   Filter [CMD2] Where NUM=NUMCMMPRP & GRDPCE=6 Order By Key CMD0 Desc
   For [CMD2]CMD0
    Break
   Next
   Filter [CMD2]
   If [F:CMD2]ACCDAT<>AVOID.ADATE
    [L]ASTATUS =  func FINPER_SYRA.GET_FIY(ACTX, COMPANY, LEDTYPANA, [F:CMD2]ACCDAT, ENVFIY, ERRMES)
    If [L]ASTATUS=[V]CST_AOK & FIY<ENVFIY
     FIY = ENVFIY
    Endif
   Endif
  Endif
 Endif
Endif

#Criteria for the budget search.
CRITBUD = 'FIY='+num$(FIY)+' & (CPY="'+COMPANY+'" | FCY="'+FCY+'")'
CRITBUD -= '& ACC="'+ACCANA+'"'

Call GETGDDINDDIE([L]COMPANY,"",INDENV,INDENT,INDCCE3) From TRTGDD

Case FLGDIE
 When 1 :# Entity
  If INDENT>0 : CRITBUD -='& CCE'+num$(INDENT)+'="'+VALCCE+'"' : Endif
  If CCEENV<>"" & INDENV>0
   CRITBUD -='& CCE'+num$(INDENV)+'="'+CCEENV+'"'
   BOTH = 1
  Endif
 When 2 :# Envelope
  If INDENV>0 : CRITBUD -='& CCE'+num$(INDENV)+'="'+VALCCE+'"' : Endif
  If CCEENT<>"" & INDENV<>0
   CRITBUD -='& CCE'+num$(INDENT)+'="'+CCEENT+'"'
   BOTH = 1
  Endif
Endcase

FCTPIH = 1
Case TYPORI
 When 1 :#Order/Commande
  Local File PORDER [POH]
  Look [POH]POH0 = NUMORI
  If !fstat : FCTPIH = 0 : Endif
 When 2 :#Receipt/Réception
  Local File PRECEIPT [PTH]
  Look [PTH]PTH0 = NUMORI
  If !fstat : FCTPIH = 0 : Endif
Endcase

#-- Checks that the envelope is not closed
#-- Checks that the envelope is approved if the parameters GDDDEBAPP=No and GDDAPPENV=Yes
If FLGDIE=2 : # Envelope
 Call LEC_ENV(VALCCE) From CPTLEC
 If [F:ENV]STA=4 & FCTPIH=1
  ERRMES = mess(234,108,1)-":"-mess([F:ENV]STA,2691,1)
  [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
# Elsif [F:ENV]STA<>3 & [L]NOAPPROVAL<>[V]CST_AYES & FCTPIH=1 & fmet ACTX.APARAM.AGETVALNUM(2,COMPANY,"GDDAPPENV")=[V]CST_AYES
 Elsif [F:ENV]STA<>3 & [L]NOAPPROVAL<>[V]CST_AYES & FCTPIH=1 &
&      func AFNC.ACTIV(" GDD") and fmet ACTX.APARAM.AGETVALNUM(2,COMPANY,"GDDAPPENV")=[V]CST_AYES   # Issue X3-107197
  ERRMES = [F:ENV]ENV-":"-mess(182,108,1)
  [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
 Endif
Endif

#-- Checks that an approved budget line exists for the entity and/or envelope
Filter [BUD] Where evalue(CRITBUD)
If BOTH
 #-- Account/Entity dimension/envelope dimension are populated => One only budget line is possible
 Raz [F:BUD]
 For [BUD]BUD0
  Break
 Next
 Filter [BUD]
 If [F:BUD]BUD<>""
  If [F:BUD]STA=4 & FCTPIH=1
   ERRMES = mess(232+FLGDIE,108,1)-":"-mess(494,198,1)-mess([F:BUD]STA,2691,1)
   [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
  Elsif [F:BUD]STA<>3
   Local Integer POS
   POS = instr(1,mess(254,108,1),":")
   ERRMES = mess(232+FLGDIE,108,1)-":"-right$(mess(254,108,1),POS+1)
   [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
  Endif
 Else
  ERRMES = mess(232+FLGDIE,108,1)-":"-mess(22,110,1)
  [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
 Endif
Else
 #-- Either the entity dimension or the envelope dimension is populated => Many budget lines are possible
 FLGBUD = 0
 For [BUD]BUD0
  FLGBUD = 1
  If [F:BUD]STA=3 :# Approved
   FLGBUD = 2 : Break
  Endif
 Next
 Filter [BUD]
 If !FLGBUD
  ERRMES = mess(232+FLGDIE,108,1)-":"-mess(22,110,1)
  [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
 Else
  If FLGBUD<>2
   ERRMES = mess(232+FLGDIE,108,1)-":"-mess(223,108,1)
   [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
  Endif
 Endif
Endif
End [L]ASTATUS


######################################################################################################
# GET_BUOINF
######################################################################################################
#**
#* From the arrays of dimensions and dimension types, this program returns :<ul>
#* <li>the entity, the envelope, the third dimension, the envelope type, the budget code
#* <li>the OK variable is set to 1 if it is an operation budget
#* <li>the site of the budget - FCYBUD -if the definition level of the budget is the site
#* </ul>
#*
#* @private
#*
#* @param DIE      Array of the dimension types
#* @param CCE      Array of the dimensions
#* @param SIT      Site
#* @param BUDCOD   Budget linked to the envelope
#* @param CCE1     Entity dimension
#* @param N1       Entity dimension type
#* @param CCE2     Envelope dimension
#* @param N2       Envelope dimension type
#* @param CCE3     The third dimension of the budget
#* @param N3       The third dimension type of the budget
#* @param OK       It is an operational budget
#* @param YEAFLG   Category of the budget ML 2692
#* @param SITBUD   Site of the budget if the defiition level of the budget is "site"
#*!
Subprog GET_BUOINF(DIE,CCE,SIT,BUDCOD,CCE1,N1,CCE2,N2,CCE3,N3,OK,YEAFLG,SITBUD)
Value Char       DIE()(1..)  # Array of the dimension types
Value Char       CCE()(1..)  # Array of the dimensions
Value Char       SIT()       # Site
Variable Char    BUDCOD()    # Budget linked to the envelope
Variable Char    CCE1()      # Entity dimension
Variable Integer N1          # Entity dimension type
Variable Char    CCE2()      # Envelope dimension
Variable Integer N2          # Envelope dimension type
Variable Char    CCE3()      # The third dimension of the budget
Variable Integer N3          # The third dimension type of the budget
Variable Integer OK          # It is an operational budget
Variable Integer YEAFLG      # Category of the budget ML 2692
Variable Char    SITBUD      # Site of the budget if the defiition level of the budget is "site"

If adxtyp=33 | !clalev([F:DIE]) : Local File GDIE      [DIE] : Endif
If adxtyp=33 | !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
If adxtyp=33 | !clalev([F:BUP]) : Local File BUDPAR    [BUP] : Endif
If adxtyp=33 | !clalev([F:BUT]) : Local File BUDTYP    [BUT] : Endif

OK = 0
SITBUD = SIT
For I=1 To dim(DIE)
 If DIE(I)<>"" & CCE(I)<>""
  Read [DIE]DIE0 = DIE(I)
  If !fstat
   If [F:DIE]ENT=2 : N1 = I : Endif
   If [F:DIE]ENV=2 : N2 = I : Endif
  Else
   Break
  Endif
 Endif
Next I
If N1 & N2
 CCE1 = CCE(N1)
 CCE2 = CCE(N2)

 Read [ENV]ENV0 = CCE2
 If !fstat
  OK = 1
  BUDCOD = [F:ENV]BUD
  Read [BUP]BUP0 = BUDCOD
  If !fstat
   # If the definition level of the budget is "company", then the site must be empty
   If [F:BUP]LEV=1
    SITBUD = ""
   Endif
   If [F:BUP]DIE(2)<>""
    N3 = find([F:BUP]DIE(2),DIE)
    If N3=0
     OK = 0
    Else
     CCE3 = CCE(N3)
    Endif
   Endif
  Endif

  Read [BUT]BUT0 = [F:ENV]BUDTYP
  If !fstat
   YEAFLG=[F:BUT]YEAFLG
  Endif
 Endif
