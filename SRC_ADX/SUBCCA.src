End




######################################################################################
## Sous programme & fonctions
######################################################################################

#=====================================================================
#
$AUZ_CPY
  # Habilitation : Contrôle de l'habilitation / société
  If ( GNBAUZ <> GNBSITE ) Then : # Pas d'habilitation tous sites
    If ( L_CPY <> "" ) Then
      mkstat = 0
      Call CONTALLFCY(L_CPY) From SUPCPT
      If mkstat : OK = 0 : mkstat = 0 : Endif
    Else
      # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
      OK=0 : GMESSAGE=mess(113,7770,1)
    Endif
  Endif
Return


########################################
Funprog CCA_DEFINI(PACTCOD)
# Reçoit un code actualisation
#    rend = 0 si le mode n'est pas défini
#    rend > 0 si le mode est défini
#    rend 1 si le mode est défini par défaut
#    rend 2 si le mode est défini pour au moins une société particulière
# ------------------------------------------------------------------------------

Value Char PACTCOD
Local Integer RRET

  Filter [COE] Where CCNACTCOD = PACTCOD
  Read [COE]COE0 First
  Filter [COE]
  If (fstat) Then
    RRET = 0
  Elsif ([F:COE]CPY="") Then
    RRET = 1
  Else
    RRET = 2
  Endif

End RRET


########################################
Funprog FAS_UTILISE_ACTCOD(PACTCOD,PCPY)
# Reçoit un code actualisation
# et rend 1 si le code est utilisé par un bien comptable
# ou rend 0 dans le cas contraire
# ------------------------------------------------------------------------------

Value Char  PACTCOD, PCPY

Local Integer RRET : RRET = 0

# FQ97351 DEBUT
#Local Char CRITERE
#
#  RRET = 0
#  CRITERE = 'CCNACTCOD=PACTCOD'
#  If ( PCPY <> "" ) Then : CRITERE += ' & CPY=PCPY' : Endif
#
#  For [FAS]FAS8 Where evalue(CRITERE)
#    RRET=1
#    Break
#  Next

  If ( PCPY <> "" )
    # Le coefficient est défini pour une société. On regarde si au moins un bien de la société l'utilise
    For [FAS]FAS1 Where CPY=PCPY and CCNACTCOD=PACTCOD
      RRET=1
      Break
    Next
  Else
    # Le coefficient est défini par défaut. Pour savoir si au moins un bien l'utilise on va comparer le nombre biens utilisant le coefficient
    # défini au niveau de leur société avec le nombre total de biens utilisant le coefficient. La différence des deux donne le nombre de
    # biens utilisant le coefficient au niveau par défaut
    Local File CCNCOE [WCOE]

    Link [F:FAS] With [F:WCOE]COE0~=[F:FAS]CPY;[F:FAS]CCNACTCOD As [LNK]
&   Where [F:FAS]CCNACTCOD=PACTCOD

    Filter [FAS] Where CCNACTCOD=PACTCOD

    If rowcount([F:LNK]) <> rowcount([F:FAS])
      RRET=1
    Endif

    Filter [FAS]
  Endif
# FQ97351 FIN
End RRET
