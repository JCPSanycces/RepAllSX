#*********************************************************************
#
#                    GESTION DES CODES ACTUALISATIONS
#
#*********************************************************************
#    Création
#    MWA - 03.06.2009
#
#*********************************************************************
#    Modification
#
#  GLE - 20.03.2014 - FQ97351   Le contrôle lors de la suppression tient compte de la modification FQ95899
#  GLE - 18.02.2014 - FQ95899   Il est possible de définir un code à la fois au niveau société et au niveau "par défaut"
#  MWA - 27.08.2010 - FQ66599   Après maj du coef.,les biens sortis dans Exe cour ou suiv ne sont plus à recalculer
#
#*********************************************************************
#
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("CCA",GBIDC1,GBIDC2) From GOBJET
End

#*********************************************************************
#
$ACTION
 #Infbox num$(ACTION)

  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "VERROU"           : Gosub VERROU
    When "DEVERROU"         : Gosub DEVERROU

    When "LIENS"            : Gosub LIENS

    When "APRES_MODIF"      : Gosub APRES_MODIF
    When "SETBOUT"          : Gosub SETBOUT

    When "CREATION"         : Gosub CREATION

    When "AVANT_MOD"        : Gosub AVANT_MOD
    When "VERIF_MOD"        : Gosub VERIF_MOD
    When "MODIF"            : Gosub MODIF

    When "VERF_ANU"         : Gosub VERF_ANU
    When "ABANDON"          : Gosub ABANDON

    When "FERME"            : Gosub FERME
    When Default
  Endcase
Return

#
#*********************************************************************
#

#
#=====================================================================
#
$OUVRE

Global Integer G_VERROU

Local Integer STAT                   : # Code retour / call VERFALLCPY
Local Char    L_CPY(GLONCPY)         : # Société pour contrôle habilitation

  # Gestion des fichiers
  If clalev([F:CNX])  =0     : Local File CONTEXT       [CNX]     : Endif
  If clalev([F:FAS])  =0     : Local File FXDASSETS     [FAS]     : Endif

Return

#=====================================================================
#
$VERROU


Return

#=====================================================================
#
$DEVERROU

Return

#=====================================================================
#
$AVANT_MOD

  # Habilitations : Contrôle habilitation / société
  L_CPY=[M:CCA0]CPY
  Gosub AUZ_CPY
Return

#=====================================================================
#
$APRES_MODIF

  # --------------------------
  # Contrôle habilitation / société
  If ( COUZON="CPY" ) Then
    L_CPY = CZ
    Gosub AUZ_CPY
    If !OK Then
      Return
    Endif
  Endif

Return


#=====================================================================
#
$SETBOUT

  # Désactivation des actions   "Changer de clé"
  Call VIREBOUT(CHAINE,"H") From GOBJET

  # Pas de suppression du paramétrage par défaut si pas d'habilitation "tous sites du dossier"
  If ( [M:CCA0]CPY="" ) Then
    If ( GUSRFCY(1) <> "\" and GNBAUZ <> GNBSITE ) Then
      Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif
  Else
    # Pas de suppression du paramétrage d'une société si pas d'habilitation "tous sites de la société"
      Call VERFALLFCY([M:CCA0]CPY,[L]STAT) From SUPCPT
      If ( [L]STAT < 1 ) Then : Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
  Endif

Return


#=====================================================================
#
$LIENS

  # Coefficient d'actualisation utilisé par un bien
  # le code actualisation est utilisé par au moins un des biens de la société.
  If ( func FAS_UTILISE_ACTCOD([M:CCA0]CCNACTCOD, [M:CCA0]CPY ) ) Then
    [M:CCA0]UTILISE = G_OUI
  Else
    [M:CCA0]UTILISE = G_NON
  Endif

Return

#-------------------------------------------------------------------------------
$VERF_ANU


Local Char LTBCPY(GLONCPY)(0..100)
Local Integer LNBCPY
Local Integer LUSED


  # La suppression d'un code actualisation est interdite lorsque
  # le mode est utilisé par au moins un bien comptable.
  If ( [M:CCA0]UTILISE = G_OUI  ) Then
    GERR= 1 : GMESSAGE= mess(254,7770,1) :  OK = 0
    zonsui = "[M:CCA0]CCNACTCOD"
    Return
  Endif

Return

#-------------------------------------------------------------------------------
$CREATION


Return

#-------------------------------------------------------------------------------
$VERIF_MOD

  #---------------
  # Verrouillage ( avant TRBEGIN du modèle objet)
  #---------------
  Call CCN_LOCK_FAS ( "", [M:CCA0]CCNACTCOD, G_VERROU) From GLOCCN


Return

#-------------------------------------------------------------------------------
$MODIF


  Local Integer BOK
  BOK = 1
  If (G_VERROU) Then : BOK = 0 : Endif
  If clalev([F:FAS1])=0  : Local File FXDASSETS     [FAS1]  :  Endif

  # Plus contraignant mais plus sur
  Local Date    TABDEB(1..func AFNC.ACTIV("SOC"))
  Local Char    TABCPY(GLONCPY)(1..func AFNC.ACTIV("SOC"))
  Local Integer NB_CPY, I_CPY

  Raz TABDEB
  Raz TABCPY
  NB_CPY = 0


  Filter [FAS1] Where CCNACTCOD=[M:CCA0]CCNACTCOD
&   Order By Key CLE=CCNACTCOD;CPY;AASREF Desc
  #> 1 >>>>>>>>>>>>>>>>>
  For [FAS1] CLE(2)
    #> 2 >>>>>>>>>>>>>>>>>
    For [FAS1] CLE
      NB_CPY += 1
      TABCPY(NB_CPY)= [F:FAS1]CPY
      # Récupération date début exercice courant contexte fiscal & comptable
      Local Date    RDATE(1..5)
      Local Integer CDRET
      Call GET_CNX_DAT([F:FAS1]CPY,G300CPFI,RDATE,CDRET) From GLOBIENS
      TABDEB(NB_CPY)= RDATE(1)
      Break 1
    Next
    #> 2 >>>>>>>>>>>>>>>>>
  Next
  #> 1 >>>>>>>>>>>>>>>>>
  Filter [FAS1]

  #---------------
  # Mise à jour
  #---------------
  If (BOK) Then
    For [FAS1]FAS9 Where CCNACTCOD= [M:CCA0]CCNACTCOD   With Stability
      # FQ66599
      # If ( [F:FAS1]ISSDAT = [0/0/0] or [F:FAS1]ISSDAT >= TABDEB(find([F:FAS1]CPY,TABCPY))  ) Then
      If ( [F:FAS1]ISSDAT = [0/0/0] ) Then
        [F:FAS1]FLGCLC                = G_OUI
        [F:FAS1]FLGCNXCLC(G300CPFI-1) = G_OUI
        [F:FAS1]FLGRPRCLC             = G_OUI
        Rewrite [FAS1]
        If (fstat) Then
          GOK = 0
          Call RSTA("FAS","") From GLOCK
          Break
        Endif
      Endif
    Next
  Else
    GOK = 0
    Errbox mess(693,7773,1)
    Return
  Endif

  #---------------
  Gosub DEVERROUILLAGE
  #---------------

Return

$DEVERROUILLAGE
  #---------------
  # Déverrouillage
  #---------------
  Call UNLOCK_SYMBOLE ("FAS", "", "") From GLOBIENS
Return

#-------------------------------------------------------------------------------
$ANNULE
Return
#-------------------------------------------------------------------------------
$ABANDON

Return
#-------------------------------------------------------------------------------
$FERME
  If dim(G_VERROU)>0      : Kill G_VERROU      : Endif
Return

######################################################################################
## Ecran CCA0
######################################################################################


#----------------------------------------------
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  If (VALEUR <> "") Then
    # Le niveau de paramétrage de cette société ne permet pas l'utilisation de la transaction
    Read [F:CNX]CNX0=VALEUR;G300CPFI
    If ( fstat ) Then
      GERR= 1 : GMESSAGE= mess(244,7770,1)
      mkstat = 2 : End
    Else
      If ( [F:CNX]CCNFLG = G_NON or [F:CNX]CCNMOD <> GVML_GCRNW ) Then
        GERR= 1 : GMESSAGE= mess(244,7770,1)
        mkstat = 2 : End
      Endif
    Endif
  Endif

  # FQ95899
#  # Un code ne peut pas être à la fois défini "par défaut" et pour une société en particulier
#  If (VALEUR <> "") Then
#    If (func CCA_DEFINI([M:CCA0]CCNACTCOD) = 1) Then
#      GERR= 1 : GMESSAGE= mess(243,7770,1)
#      mkstat = 2 : End
#    Endif
#  Else
#    If (func CCA_DEFINI([M:CCA0]CCNACTCOD) = 2) Then
#      GERR= 1 : GMESSAGE= mess(243,7770,1)
#      mkstat = 2 : End
#    Endif
#  Endif

End

