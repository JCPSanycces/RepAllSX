#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPRES","ACOPRES",3,"") From GTRAITE
End

#-------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "EXEC"       : Gosub EXEC
Endcase
Return

#-------------------------------------------------------------------#
$INIT
Local Mask ACOPRES [COP]
Raz [M:COP]
Return

$EXEC
Local Char    FICHIER(GDIMFIC)
Local Integer ER , I
I = 0
Onerrgo ER
For FICHIER=[M:COP]DOSORG+".ACTLDEV",[M:COP]DOSDES+".ACTLDEV"
 I += 1 
 Case I
  When 1 : Local File =FICHIER [ACD]
  When 2 : Local File =FICHIER [ACD9]
 Endcase
 If ER
  GMESSAGE = FICHIER-":"-errmes$(ER)
  GERR = 1 :  FIN = 1 : Break
 Endif
Next FICHIER
If nomap<>GDOSX3 : Local File =GDOSX3+".ATEXTRA" [AXX] : Endif
Onerrgo
If FIN : Return : Endif
If !GSERVEUR
 Call OUVRE_TRACE("") From LECFIC
 Call TEMPON("O") From GESECRAN
Endif
For [ACD]
 Call ECR_TRACE([F:ACD]COD-func AFNC.TEXTRA("ACTLDEV","INTCOD",[F:ACD]COD,""),0) From GESECRAN
 Call COPOBJ([M:COP]DOSORG,[M:COP]DOSDES,"ACD",[F:ACD]COD,"","","") From ACOPIE
Next ACD
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call TEMPOFF From GESECRAN
Endif
TRA = 1
Return

$ER
ER = errn
Resume

#-------------------------------------------------------------------#
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
Call D_DOSORG(VALEUR) From ACOPIE
End

Subprog AV_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AV_DOSORG(VALEUR) From ACOPIE
End

Subprog AM_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AM_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AS_DOSORG(VALEUR) From ACOPIE
End

Subprog IB_DOSDES
Call IB_DOSDES From ACOPIE
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
Call AS_DOSDES(VALEUR) From ACOPIE
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call C_DOSDES(VALEUR) From ACOPIE
End

