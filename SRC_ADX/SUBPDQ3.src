#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
# SUBPDQ3 : Affichage de la situation d'une commande        MBT 22/12/98 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p           #
# d'affichage "SITUATION_CDE" et ne sert qu'à gérer le masque            #
# écran "PDSYPOH [PDQ3]".                                                #
##########################################################################

$ACTION
#---------------------------------#
# Actions de l'objet POH (GOBJET) #
#---------------------------------#
Case ACTION
  When "AB2_NBLIG"   : Gosub AB2_NBLIG
  When "BB2_NBLIG"   : Gosub BB2_NBLIG
Endcase
Return


$AB2_NBLIG
#----------------------------------------------#
# Avant exécution du bouton tunnel sur facture #
#----------------------------------------------#
Local Char    WCLE(GLONPIH)
If instr(1,[M:PDQ3]INVNUM(nolign-1)," ")
  WCLE=mid$([M:PDQ3]INVNUM(nolign-1),1,instr(1,[M:PDQ3]INVNUM(nolign-1)," ")-1)
Else
  WCLE=[M:PDQ3]INVNUM(nolign-1)
Endif
Return


$BB2_NBLIG
#----------------------------------------------#
# Avant exécution du bouton tunnel sur facture #
#----------------------------------------------#
Return


Subprog IB_NBLIG
#----------------------------------------------------------#
# Avant zone : Activation boutons "Réception" et "Facture" #
#----------------------------------------------------------#
Raz GBOUT1, GBOUT2
If [M:PDQ3]PTHNUM(nolign-1)<>"" & GFONC1<>"GESPTH"
  GBOUT1=mess(117,198,1)-[M:PDQ3]PTHNUM(nolign-1)
Endif
If [M:PDQ3]INVNUM(nolign-1)<>"" & GFONC1<>"GSPIH"
  Local Char    WCLE(GLONPIH)
  If instr(1,[M:PDQ3]INVNUM(nolign-1)," ")
    WCLE=mid$([M:PDQ3]INVNUM(nolign-1),1,instr(1,[M:PDQ3]INVNUM(nolign-1)," ")-1)
  Else
    WCLE=[M:PDQ3]INVNUM(nolign-1)
  Endif
  GBOUT2=mess(55,198,1)-WCLE
Endif
End
