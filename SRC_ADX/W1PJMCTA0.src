$ON_ENAFLG
Onevent AFTER_CHANGE Gosub AMM_ENAFLG From W1PJMCTA0
Onevent INIT_AREA Call D_ENAFLG(zc) From W1PJMCTA0
Onevent BEFORE_INPUT Call AS_ENAFLG(zc) From W1PJMCTA0
Return

Subprog D_ENAFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]ENAFLG,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_ENAFLG
Call AM_ENAFLG(zc)
If !mkstat & GOBJET
 zoncou = "ENAFLG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_ENAFLG(VALEUR) From SUBCTA
If mkstat : GERR = 1 : GZONE = "ENAFLG" : GZNUM = 188 : Endif
Gosub _AFF
End

$CHG_STY
Return


