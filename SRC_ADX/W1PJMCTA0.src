#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMCTA0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:46"
A_USER  = "DOC"
A_STAMP = "20181109230546"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMCTA0 [CTA0]
Gosub HORODAT
Local Inpbox "PJMCTA0" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTA0] As [SIM_]
Grizo [CTA0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTA0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=94 : Y1(0)=1 : Y2(0)=5
Return

$ON_TCACOD
Onevent AFTER_CHANGE Gosub AMM_TCACOD From W1PJMCTA0
Onevent CONTROL Call C_TCACOD(zc) From W1PJMCTA0
Return

Subprog C_TCACOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TCACOD" : GZNUM = 707 : Endif
Gosub _AFF
End

$AMM_TCACOD
Call AM_TCACOD(zc)
If !mkstat & GOBJET
 zoncou = "TCACOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TCACOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TCACOD(VALEUR) From SUBCTA
If mkstat : GERR = 1 : GZONE = "TCACOD" : GZNUM = 707 : Endif
Gosub _AFF
End

$ON_TCADESAXX
Onevent INIT_AREA Call D_TCADESAXX(zc) From W1PJMCTA0
Onevent AFTER_CHANGE Gosub AMM_TCADESAXX From W1PJMCTA0
Onevent BEFORE_INPUT Call AS_TCADESAXX(zc) From W1PJMCTA0
Onevent CONTROL Call C_TCADESAXX(zc) From W1PJMCTA0
Return

Subprog IB_TCADESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_TCADESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]TCADESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMTSKCAT","TCADESAXX",[M:CTA0]TCACOD,"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_TCADESAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_TCADESAXX(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_TCADESAXX(zc) From W1PJMCTA0
Gosub _AFF
End

Subprog C_TCADESAXX(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TCADESAXX" : GZNUM = 282 : Endif
Gosub _AFF
End

$AMM_TCADESAXX
Call AM_TCADESAXX(zc)
If !mkstat & GOBJET
 zoncou = "TCADESAXX" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TCADESAXX(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TCADESAXX(VALEUR) From SUBCTA
If mkstat : GERR = 1 : GZONE = "TCADESAXX" : GZNUM = 282 : Endif
Gosub _AFF
End

Subprog B1_TCADESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_TCADESAXX" : PROGSUB = "SUBCTA" : PROGSPE = "SPECTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMTSKCAT"
 PARMSK(2) = "TCADESAXX"
 PARMSK(3) = [M:CTA0]TCACOD
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_TCADESAXX" : PROGSUB = "SUBCTA" : PROGSPE = "SPECTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

