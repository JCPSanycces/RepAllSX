###################################################################################################
#                                                                                                 #
# Traitement TRTVENSTK - Librairie de composants stock pour les ventes  V140                      #
#                                                                                                 #
###################################################################################################
# Sous-programmes                                                                                 #
#-------------------------------------------------------------------------------------------------#
# Entrée                                                                                          #
#-------------------------------------------------------------------------------------------------#
#                                                                                                 #
# STKRAZGRILIG  : Effacement et grisage des champs stock d'une ligne document                     # 
# STKGRILIG     : Grisage des champs stock d'une ligne document                                   #
# STKDISZONPIC  : Désactivation des champs stock après picking d'une ligne document               #
#                                                                                                 #
#-------------------------------------------------------------------------------------------------#
#                                                                                                 #
# Etiquettes appelées par SUBSDHA, SUBSIHA, SUBSRH, SUBSRL,                                       #
#                                                                                                 #
#  $VERIF_TRSFAM    : Vérification du champs TRSFAM paramétré dans une transaction                #
#  $VERIF_TRSCOD    : Vérification du champs TRSCOD paramétré dans une transaction                #
#                                                                                                 #
###################################################################################################
###############################################################################
# STKRAZGRILIG : Efface et grise les champs stock d'une ligne document        #
###############################################################################
Subprog STKRAZGRILIG(LABR, NL)
Value Char    LABR
Value Integer NL

If evalue("dim([M:"+LABR+"]STA)")>=0     Raz [M]STA(NL)    : Grizo [M]STA(NL)    : Affzo [M]STA(NL) : Endif
If evalue("dim([M:"+LABR+"]LOCTYP)")>=0  Raz [M]LOCTYP(NL) : Grizo [M]LOCTYP(NL) : Affzo [M]LOCTYP(NL): Endif
If evalue("dim([M:"+LABR+"]LOC)")>=0     Raz [M]LOC(NL)    : Grizo [M]LOC(NL)    : Affzo [M]LOC(NL) : Endif
If evalue("dim([M:"+LABR+"]BPSLOT)")>=0  Raz [M]BPSLOT(NL) : Grizo [M]BPSLOT(NL) : Affzo [M]BPSLOT(NL): Endif
If evalue("dim([M:"+LABR+"]LOT)")>=0     Raz [M]LOT(NL)    : Grizo [M]LOT(NL)    : Affzo [M]LOT(NL) : Endif
If evalue("dim([M:"+LABR+"]NBSLO)")>=0   Raz [M]NBSLO(NL)  : Grizo [M]NBSLO(NL)  : Affzo [M]NBSLO(NL): Endif
If evalue("dim([M:"+LABR+"]SLO)")>=0     Raz [M]SLO(NL)    : Grizo [M]SLO(NL)    : Affzo [M]SLO(NL) : Endif
If evalue("dim([M:"+LABR+"]SLOF)")>=0    Raz [M]SLOF(NL)   : Affzo [M]SLOF(NL)   : Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>=0  Raz [M]SERNUM(NL) : Grizo [M]SERNUM(NL) : Affzo [M]SERNUM(NL): Endif
If evalue("dim([M:"+LABR+"]SERNUMF)")>=0 Raz [M]SERNUMF(NL): Affzo [M]SERNUMF(NL): Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>=0  Raz [M]PALNUM(NL) : Grizo [M]PALNUM(NL) : Affzo [M]PALNUM(NL): Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>=0  Raz [M]CTRNUM(NL) : Grizo [M]CTRNUM(NL) : Affzo [M]CTRNUM(NL): Endif
If evalue("dim([M:"+LABR+"]PRIORD)")>=0  Raz [M]PRIORD(NL) : Grizo [M]PRIORD(NL) : Affzo [M]PRIORD(NL): Endif
If evalue("dim([M:"+LABR+"]MVTDES)")>=0  Raz [M]MVTDES(NL) : Grizo [M]MVTDES(NL) : Affzo [M]MVTDES(NL): Endif
If evalue("dim([M:"+LABR+"]WRH)")>=0     Raz [M]WRH(NL)    : Grizo [M]WRH(NL)    : Affzo [M]WRH(NL) : Endif

If evalue("dim([M:"+LABR+"]WSTOSAI)")>NL  [M]WSTOSAI(NL)="000222222222222" : Endif

End
###############################################################################
# STKGRILIG : Grise les champs stock d'une ligne document                     #
###############################################################################
Subprog STKGRILIG(LABR, NL)
Value Char    LABR
Value Integer NL

If evalue("dim([M:"+LABR+"]STA)")>=0     : Grizo [M]STA(NL)    : Endif
If evalue("dim([M:"+LABR+"]LOCTYP)")>=0  : Grizo [M]LOCTYP(NL) : Endif
If evalue("dim([M:"+LABR+"]LOC)")>=0     : Grizo [M]LOC(NL)    : Endif
If evalue("dim([M:"+LABR+"]BPSLOT)")>=0  : Grizo [M]BPSLOT(NL) : Endif
If evalue("dim([M:"+LABR+"]LOT)")>=0     : Grizo [M]LOT(NL)    : Endif
If evalue("dim([M:"+LABR+"]NBSLO)")>=0   : Grizo [M]NBSLO(NL)  : Endif
If evalue("dim([M:"+LABR+"]SLO)")>=0     : Grizo [M]SLO(NL)    : Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>=0  : Grizo [M]SERNUM(NL) : Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>=0  : Grizo [M]PALNUM(NL) : Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>=0  : Grizo [M]CTRNUM(NL) : Endif
If evalue("dim([M:"+LABR+"]PRIORD)")>=0  : Grizo [M]PRIORD(NL) : Endif
If evalue("dim([M:"+LABR+"]MVTDES)")>=0  : Grizo [M]MVTDES(NL) : Endif
If evalue("dim([M:"+LABR+"]WRH)")>=0     : Grizo [M]WRH(NL)    : Endif

If evalue("dim([M:"+LABR+"]WSTOSAI)")> NL [M]WSTOSAI(NL)="000222222222222" : Endif

End
###############################################################################################
# STKDISZONPIC : Désactivation des champs stock après picking d'une ligne document            #
#                                                                                             #   
# Après picking d'une ligne de facture   dans les avoirs                                      #
# Après picking d'une ligne de livraison dans les retours                                     #
#       Désactive les champs sur la ligne de document                                         #
#                                                                                             #   
# LECFICENT a déjà été fait                                                                   #
#                                                                                             #   
###############################################################################################
Subprog STKDISZONPIC(LABR, NL)
Value Char    LABR
Value Integer NL

Local Char LMSKCOU : LMSKCOU = func STKLIB.MSKDEF
Default Mask "["+LABR+"]"

If evalue("dim([M:"+LABR+"]BPSLOT)")>=0  Diszo [M]BPSLOT(NL) : Endif
If evalue("dim([M:"+LABR+"]LOT)")>=0     Diszo [M]LOT(NL)    : Endif
If evalue("dim([M:"+LABR+"]NBSLO)")>=0   Diszo [M]NBSLO(NL)  : Endif
If evalue("dim([M:"+LABR+"]SLO)")>=0     Diszo [M]SLO(NL)    : Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>=0  Diszo [M]SERNUM(NL) : Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>=0  Diszo [M]PALNUM(NL) : Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>=0  Diszo [M]CTRNUM(NL) : Endif
If evalue("dim([M:"+LABR+"]PRIORD)")>=0  Diszo [M]PRIORD(NL) : Endif

Default Mask LMSKCOU

End
###############################################################################################
# VERIF_TRSFAM : Vérification du champs TRSFAM paramétré dans une transaction                 #
#                                                                                             #   
# Après Sélection de la txn dans la gestion des factures, avoirs, retours et retours de prêt  #
#                 vérif que TRSFAM existe tjs dans la table diverse                           #
#                                                                                             #   
# Dans SALTRS Sur TRSFAM : On a enlevé l'option RAZ sur Annulation pour mettre Autre          #
#                          (Car TRSFAM dépasse le 255 ème champs de la table SALTRS)          #
#                          ==> Qd on supprime un code ds la table diverse, il reste ds SALTRS #  
#                                                                                             #   
# WSLTTRSFAM doit contenir TRSFAM                                                             #   
###############################################################################################
$VERIF_TRSFAM

If WSLTTRSFAM="" Return Endif
If clalev ([F:ADI])=0 Local File ATABDIV [ADI] Endif

If [F:ADI]NUMTAB<>9 | [F:ADI]CODE<>WSLTTRSFAM
    Read [ADI]CODE=9;WSLTTRSFAM
    If fstat Raz WSLTTRSFAM Endif
Endif
Return
###############################################################################################
# VERIF_TRSCOD : Vérification du champs TRSCOD paramétré dans une transaction                 #
#                                                                                             #   
# Après Sélection de la txn dans la gestion des factures, avoirs, retours et retours de prêt  #
#                 vérif que TRSCOD existe tjs dans la table diverse                           #
#                                                                                             #   
# Dans SALTRS Sur TRSCOD : On a enlevé l'option RAZ sur Annulation pour mettre Autre          #
#                          (Car TRSCOD dépasse le 255 ème champs de la table SALTRS)          #
#                          ==> Qd on supprime un code ds la table diverse, il reste ds SALTRS #  
#                                                                                             #   
# WSLTTRSCOD doit contenir TRSCOD                                                             #   
###############################################################################################
$VERIF_TRSCOD

If WSLTTRSCOD="" Return Endif
If clalev ([F:ADI])=0 Local File ATABDIV [ADI] Endif

If [F:ADI]NUMTAB<>14 | [F:ADI]CODE<>WSLTTRSCOD
    Read [ADI]CODE=14;WSLTTRSCOD
    If fstat Raz WSLTTRSCOD Endif
Endif
Return
