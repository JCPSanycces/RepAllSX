$_GET_BUDLIG_PLBU
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Value Char SPCCCOD ()
#Local Char ARET_VALUE(250)

Local Integer IPLBSEQ

  [L]ARET_VALUE = this.UOM          # Default value
  #--------------------------
  If this.ISBUDUPD = [V]CST_AYES Then
    If SPBUCOD <> AVOID.ACHAR and SPBUCOD <> fmet this._GET_EMPTY_STRING() and SPCCCOD <> AVOID.ACHAR Then
      # Issue X3-68131 - 2018-02-12 by FGR : BEGIN
      #IPLBSEQ = func PJMBUDLIG_CSTD_PROGS.GET_PLBSEQ_FROM_PCCCOD(SOPPNUM, SPBUCOD, SPCCCOD)
      #[L]ARET_VALUE =  func PJMBUDLIG_CSTD_PROGS.GET_PLBU(SOPPNUM, SPBUCOD, IPLBSEQ)
      IPLBSEQ = func PJMBUDLIG_CSTD_PROGS.GET_PLBSEQ_FROM_PCCCOD(this.ACTX, SOPPNUM, SPBUCOD, SPCCCOD)
      [L]ARET_VALUE =  func PJMBUDLIG_CSTD_PROGS.GET_PLBU(this.ACTX, SOPPNUM, SPBUCOD, IPLBSEQ)
      # Issue X3-68131 - 2018-02-12 by FGR : END
    Endif
  Endif
  #--------------------------
Return

