###################################################################################################
$_GET_EMPTY_STRING
#Local Char ARET_VALUE(250)

  [L]ARET_VALUE = "<Empty>"
Return

###################################################################################################
$SQL_CLEAN_COMMENTS
#Variable Clbfile WCLOB
#Local Integer ARET_VALUE

Local Integer J
Local Integer K

  [L]ARET_VALUE = [V]CST_AOK
  #--------------------------
  # Remove comments
  If left$(WCLOB,1) = "#" Then
    J = 1
  Else
    J = instr(1,WCLOB,chr$(10)+"#")
  Endif
  #------------------------------------
  While J
    K = instr(J+2,WCLOB,chr$(10))
    If K Then
      WCLOB = left$(WCLOB,J-1) + right$(WCLOB,K)
    Endif
    J = instr(1,WCLOB,chr$(10)+"#")
  Wend
  # replace TAB by space
  WCLOB = ctrans(WCLOB,chr$(9)," ")
  #------------------------------------
Return

###################################################################################################
$SQL_REPLACE_WORD_CLOB
#Value Clbfile ACLOB
#Value Char ACH1 ()
#Value Char ACH2 ()
#Variable Clbfile PCLOB
#Local Integer ARET_VALUE

Local Integer I
Local Integer LW
Local Clbfile WCLOB(5) #----5*512   16384 chars max (16384/255 = 64)

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  Raz PCLOB
  WCLOB = ACLOB
  LW = len(ACH1)
  I = instr(1,WCLOB,ACH1)
  If I = 0 Then
    PCLOB = ACLOB
  Else
    PCLOB += left$(WCLOB,I-1)
    WCLOB = seg$(WCLOB,I+LW,len(WCLOB))
    I = instr(1,WCLOB,ACH1)
    If I = 0 Then
      PCLOB += ACH2 + WCLOB
    Else
      #--- call recursif itself ------------------------
      [L]ARET_VALUE = fmet this.SQL_RECURSIVITE_WORD_CLOB(WCLOB, ACH1, ACH2, PCLOB, I)
    Endif
  Endif
Return

###################################################################################################
$SQL_RECURSIVITE_WORD_CLOB
#Value Clbfile ACLOB
#Value Char ACH1 ()
#Value Char ACH2 ()
#Variable Clbfile PCLOB
#Value Integer IND
#Local Integer ARET_VALUE

Local Integer I
Local Integer LW
Local Clbfile WCLOB(5)   #----5*512  16384 chars max  (16384/255 = 64)

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  I = IND
  LW = len(ACH1)
  WCLOB = ACLOB
  PCLOB += ACH2 + left$(WCLOB,I-1)
  WCLOB = seg$(WCLOB,I+LW,len(WCLOB))
  I = instr(1,WCLOB,ACH1)
  If I = 0 Then
    PCLOB += ACH2 + WCLOB
  Else
    #--- call recursif itself ------------------------
    [L]ARET_VALUE = fmet this.SQL_RECURSIVITE_WORD_CLOB(WCLOB, ACH1, ACH2, PCLOB, I)
  Endif
Return

###################################################################################################
$SQL_READ_CLOB
#Value Char SQLQRY ()
#Variable Clbfile WCLOB
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  Local File ACLOB [WACB]
  # -----------------------------
  Read [WACB]ACB0="RQ_ALH";SQLQRY;"";""
  # Issue X3-5283/119037 - 2016-10-11 by FGR : Manage fstat value
  If fstat Then
    [L]ARET_VALUE = fmet this.ASETERROR("", func AFNC.MES1(mess(431,2260,1), SQLQRY), [V]CST_AERROR)
  Else
    WCLOB = [F:WACB]CLOB
    # -----------------------------
    [L]ARET_VALUE = fmet this.SQL_CLEAN_COMMENTS(WCLOB)
  Endif
  # -----------------------------
Return

###################################################################################################
$SQL_GET_TYPDBA
  [L]ARET_VALUE = num$((fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "TYPDBA") * 2) + 1)
Return

###################################################################################################
$GET_SUM_PSCQTYX
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-29 by FGR
#Value Char SPBUCOD ()
#Value Char SPCCCOD ()
#Local Decimal ARET_VALUE

  [L]ARET_VALUE = 0
  # -----------------------------
  Local File PJMSC [PJC]
  # -----------------------------
  #Filter [PJC] Where PSCSSS = this.SESSION and PBUCOD = SPBUCOD and PCCCOD = SPCCCOD                        # Issue X3-46735 - 2017-06-29 by FGR
  Filter [PJC] Where PSCSSS = this.SESSION and OPPNUM = SOPPNUM and PBUCOD = SPBUCOD and PCCCOD = SPCCCOD    # Issue X3-46735 - 2017-06-29 by FGR
  For [PJC]
    [L]ARET_VALUE += [F:PJC]PSCQTY1 + [F:PJC]PSCQTY2 + [F:PJC]PSCQTY3 + [F:PJC]PSCQTY4 + [F:PJC]PSCQTY5
  Next
  Filter [PJC]
  # -----------------------------
Return

###################################################################################################
$GET_SUM_PSCAMTX
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-29 by FGR
#Value Char SPBUCOD ()
#Value Char SPCCCOD ()
#Local Decimal ARET_VALUE

  [L]ARET_VALUE = 0
  # -----------------------------
  Local File PJMSC [PJC]
  # -----------------------------
  #Filter [PJC] Where PSCSSS = this.SESSION and PBUCOD = SPBUCOD and PCCCOD = SPCCCOD                        # Issue X3-46735 - 2017-06-29 by FGR
  Filter [PJC] Where PSCSSS = this.SESSION and OPPNUM = SOPPNUM and PBUCOD = SPBUCOD and PCCCOD = SPCCCOD    # Issue X3-46735 - 2017-06-29 by FGR
  For [PJC]
    [L]ARET_VALUE += [F:PJC]PSCAMT1 + [F:PJC]PSCAMT2 + [F:PJC]PSCAMT3 + [F:PJC]PSCAMT4 + [F:PJC]PSCAMT5
  Next
  Filter [PJC]
  # -----------------------------
Return

###################################################################################################
$GET_PCCCOD
#Value Shortint ATYPE
#Value Char SITMREF ()
#Value Char SATCLCOD ()
#Value Char APIMNUM ()
#Value Char APCCCOD ()
#Local Char ARET_VALUE(250)

Local Integer IRET

  Raz [L]ARET_VALUE
  # ----------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("GET_PCCCOD : ATYPE=" + num$(ATYPE) - "SITMREF=" + SITMREF - "SATCLCOD=" + SATCLCOD - "APIMNUM=" + APIMNUM - "APCCCOD=" + APCCCOD, [V]CST_AINFO)
  Endif
  # ----------------------------
  Local File PJMTSK [TAS]
  Local File PJMTSKCAT [CTA]
  # ----------------------------
  Case ATYPE
    When 1
      #-- MO main d'oeuvre - workstation or Categ of task get pcccod
      [L]ARET_VALUE = fmet this._GET_MWS_PCCCOD(SATCLCOD)
    When 2
      #-- Article (Achat,commende ,facture..ect)
      [L]ARET_VALUE = fmet this._GET_ITM_PCCCOD(SITMREF, SATCLCOD)
    When 3
      #-- Frais  a implementer : a creer le traitement  TRTBOFIN (frais et finance)
      [L]ARET_VALUE = fmet this._GET_TES_PCCCOD(SATCLCOD)
    When 4
      #-- Finance : nothing to do here
      [L]ARET_VALUE = APCCCOD
    When 5
      #-- Time entry :
      [L]ARET_VALUE = SATCLCOD
  Endcase
  # ----------------------------
  If [L]ARET_VALUE = AVOID.ACHAR Then
    Filter [TAS] Where [F:TAS]KEYCONCAT = APIMNUM
    For [TAS]
      Read[CTA]CTA0=[F:TAS]TCACOD
      [L]ARET_VALUE = [F:CTA]PCCCOD
      Break
    Next
    Filter [TAS]
    If [L]ARET_VALUE = AVOID.ACHAR Then
      [L]ARET_VALUE = APCCCOD
      If [L]ARET_VALUE = AVOID.ACHAR Then
        Case ATYPE
          When 1, 5
            #-- MO main d'oeuvre or Time entry - workstation or Categ of task get pcccod
            [L]ARET_VALUE = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PCCCOD")
          When 2
            #-- Article (Achat,commende ,facture..ect)
            [L]ARET_VALUE = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PCCCODDEF")
          When 3, 4
            #-- Frais or Finance a implementer : a creer le traitement  TRTBOFIN (frais et finance)
            [L]ARET_VALUE = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PCCCODFIN")
        Endcase
      Endif
    Endif
  Endif
  # ----------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("GET_PCCCOD : ARET_VALUE=" + ARET_VALUE, [V]CST_AINFO)
  Endif
  # ----------------------------
Return

###################################################################################################
$_GET_ITM_PCCCOD
#Value Char SITMREF ()
#Value Char SATCLCOD ()
#Local Char ARET_VALUE(250)

  Raz [L]ARET_VALUE
  # ----------------------------
  Local File ITMMASTER [ITM]
  # ----------------------------
  Read [ITM]ITM0=SITMREF
  If !fstat Then
    [L]ARET_VALUE = [F:ITM]PCCCOD
  Endif
Return

###################################################################################################
$_GET_MWS_PCCCOD
#Value Char AWST ()
#Local Char ARET_VALUE(250)

Local Char WFCY(GLONFCY)

  Raz [L]ARET_VALUE
  # ----------------------------
  Local File WORKSTATIO [MWS]
  # ----------------------------
  For WFCY = this.FCY, ""
    Read [F:MWS]WST0=AWST;WFCY
    If !fstat Then
      [L]ARET_VALUE = [F:MWS]PCCCOD
      Break
    Endif
  Next
Return

###################################################################################################
$_GET_TES_PCCCOD
#Value Char SCODEXP ()
#Local Char ARET_VALUE(250)

  Raz [L]ARET_VALUE
  # ----------------------------
  If this.ACTX.AFOLD.AMODULE(3) = [V]CST_AYES Then
    # If "A/P-A/R accounting" module is enable
    # ----------------------------
    Local File TABEXPENS [TES]
    # ----------------------------
    Read [TES]TES0=SCODEXP
    If !fstat Then
      [L]ARET_VALUE = [F:TES]PCCCOD
    Endif
  Endif
  # ----------------------------
Return

###################################################################################################
$_GET_PCCCOD_GRP
#Value Char PARFCY ()
#Value Char PARPCCCOD ()
#Variable Char PARGRP ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  PARGRP = ""
  # ----------------------------
  Local File PJMCOSTCTR [PJCC]
  # ----------------------------
  Read [PJCC]PCC0=PARPCCCOD
  If fstat Then
    [L]ARET_VALUE = fmet this.ASETERROR("_GET_PCCCOD_GRP", mess(23,100,1) - PARPCCCOD, [V]CST_AERROR)
    Return
  Endif
  If [PJCC]PCCGRP <> AVOID.ACHAR Then
    PARGRP = [F:PJCC]PCCGRP
  Endif
Return

###################################################################################################
$_GET_DEFAULT_GRP
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  #--- Get Default Group ---------------
  Local File ATABDIV [ADI]
  # ----------------------------
  Filter [ADI] Where [F:ADI]NUMTAB = 388 and [F:ADI]N1 = [V]CST_AYES and [F:ADI]ENAFLG = [V]CST_AYES
  Read [ADI]First
  If !fstat Then
    this.SHOWGRP = [F:ADI]CODE
    this.SHOWQTY = [F:ADI]N2
    this.SHOWMNT = [F:ADI]N3
  Else
    Filter [ADI] Where NUMTAB=388 Order By CODE
    Read [ADI]First
    If !fstat Then
      this.SHOWGRP = [F:ADI]CODE
      this.SHOWQTY = [F:ADI]N2
      this.SHOWMNT = [F:ADI]N3
      this.ADVINCL = [F:ADI]N6
    Endif
  Endif
  Filter [ADI]
Return

###################################################################################################
$_GET_SELECTED_GRP
#Value Char PARGRP ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  #--- Get Default Group ---------------
  Local File ATABDIV[ADI]
  # ----------------------------
  Filter [ADI] Where [F:ADI]NUMTAB = 388 and [F:ADI]CODE = PARGRP and [F:ADI]ENAFLG = [V]CST_AYES
  Read [ADI]First
  If !fstat Then
    this.SHOWGRP = [F:ADI]CODE
    this.SHOWQTY = [F:ADI]N2
    this.SHOWMNT = [F:ADI]N3
    this.ADVINCL = [F:ADI]N6
  Endif
  Filter [ADI]
Return

