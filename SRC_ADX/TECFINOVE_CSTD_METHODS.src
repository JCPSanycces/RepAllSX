###################################################################################################
$_DATA_EXTRACT_PJMSCCT_MULPRJ
#Local Integer ARET_VALUE

Local Char SREQ(255)(20)
Local Integer IREQ

  # Issue X3-46735 - 2017-06-28 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT_MULPRJ : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  If this.MULPRJ = [V]CST_AYES Then
    # Agregate at cost types level without project
    # ---------------------------
    Local File PJMSCCT [PJCCTW]
    # ---------------------------
    SREQ(0)  = "SELECT PCCCOD_0,            PCCGRP_0,           PCCGRPSOR_0"
    SREQ(1)  =       ",sum(PSCQTY1_0),      sum(PSCAMT1_0),      sum(PSCQTY2_0),     sum(PSCAMT2_0),   sum(PSCQTY3_0),   sum(PSCAMT3_0)"
    SREQ(2)  =       ",sum(PSCQTY4_0),      sum(PSCAMT4_0),      sum(PSCQTY5_0),     sum(PSCAMT5_0)"
    SREQ(3)  =       ",sum(PSCBUDQTY_0),    sum(PSCBUDAMT_0),    sum(PSCTOTQTY_0),   sum(PSCTOTAMT_0), sum(PSCREMQTY_0), sum(PSCREMAMT_0)"
    SREQ(4)  =       ",sum(PSCMARGQTY_0),   sum(PSCMARGAMT_0),   sum(PSCPCTMQTY_0),  sum(PSCPCTMAMT_0)"
    SREQ(5)  =       ",sum(PSCESTTOTQTY_0), sum(PSCESTTOTAMT_0), sum(PSCWIPQTY_0),   sum(PSCWIPAMT_0) "
    SREQ(6)  =       ",sum(PSCFREEC6A_0),   sum(PSCFREEC6B_0),   sum(PSCFREEC7A_0),  sum(PSCFREEC7B_0) "
    SREQ(7)  =       ",sum(PSCFREEC8A_0),   sum(PSCFREEC8B_0),   sum(PSCFREEC9A_0),  sum(PSCFREEC9B_0) "
    SREQ(8)  =       ",sum(PSCFREEC10A_0),  sum(PSCFREEC10B_0),  sum(PSCMARGBUD6_0), sum(PSCMARGTOT6_0) "
    SREQ(9)  = " From PJMSCCT"
    SREQ(10) = " where PSCSSS_0=" + num$(this.SESSION) + " and OPPNUM_0 <> ' '"
    SREQ(11) = " and PBUPAE_0 = ' ' and PBUCOD_0 = ' '"
    SREQ(12) = " GROUP BY PCCCOD_0, PCCGRP_0, PCCGRPSOR_0"
    SREQ(13) = " ORDER BY PCCCOD_0, PCCGRP_0, PCCGRPSOR_0"
    # ----------------------------
    For (Char WPCCCOD(GLONPJCC),Char WPCCGRP(GLONADI), Integer WPCCGRPSOR,
&        Decimal WQ1,           Decimal WA1,           Decimal WQ2,        Decimal WA2,        Decimal WQ3,    Decimal WA3,
&        Decimal WQ4,           Decimal WA4,           Decimal WQ5,        Decimal WA5,        Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&        Decimal WRQT,          Decimal WRAM,          Decimal WMQT,       Decimal WMAM,       Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&        Decimal WIPQT,         Decimal WIPAM,         Decimal WC6QT,      Decimal WC6AM,      Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&        Decimal WC9QT,         Decimal WC9AM,         Decimal WC10QT,     Decimal WC10AM,     Decimal WMBUD6, Decimal WTBUD6)
&   From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
      # ----------------------------
      Raz [F:PJCCTW]
      # ----------------------------
      [F:PJCCTW]PCCCOD       = [F:WWW]WPCCCOD
      [F:PJCCTW]PCCGRP       = [F:WWW]WPCCGRP
      [F:PJCCTW]PCCGRPSOR    = [F:WWW]WPCCGRPSOR
      # ----------------------------
      Gosub SET_PJCCTW_FROM_WWW From TECFINOVE_CSTD_PROGS
      # ---------------------------
      [F:PJCCTW]PSCSSS   = this.SESSION
      this.TECPSCCTSEQ  += 1
      [F:PJCCTW]PSCSEQ   = this.TECPSCCTSEQ
      # ---------------------------
      Write [F:PJCCTW]
      If fstat <> 0 Then
        [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSCCT_MULPRJ", mess(352,2260,1) - "PJMSCCT(W)-b", [V]CST_AERROR)
        Break
      Endif
    Next
  Endif
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT_MULPRJ : End this.TECPSCSEQ :" - num$(this.TECPSCCTSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT_MULPRJ : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
Return

###################################################################################################
$_EXIST_PCCCOD
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Value Char SPCCCOD ()
#Local Integer ARET_VALUE

  Raz [L]ARET_VALUE
  Local File PJMSC [PJC]
  #Filter [PJC] Where OPPNUM = this.OPPNUM and PBUCOD = SPBUCOD and PCCCOD = SPCCCOD and PSCSSS = this.SESSION and PSCIMG = this.AIMG      # Issue X3-46735 - 2017-06-28 by FGR
  Filter [PJC] Where OPPNUM = SOPPNUM and PBUCOD = SPBUCOD and PCCCOD = SPCCCOD and PSCSSS = this.SESSION and PSCIMG = this.AIMG           # Issue X3-46735 - 2017-06-28 by FGR
  For [PJC]
    [L]ARET_VALUE = [F:PJC]PSCSEQ
    Break
  Next
Return

###################################################################################################
$TITLE_EXTRACT
#Local Integer ARET_VALUE

Local Integer NI
Local Integer ILINE
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("TITLE_EXTRACT : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  For NI = 1 To 40
    ILINE = fmet this.ADDLINE("TITLE", [V]CST_ALASTPOS)
    If ILINE > 0 Then
      this.TITLE(ILINE).USE = [V]CST_ANO
      this.TITLE(ILINE).TVARTIDYN = ""
    Endif
  Next NI
  # ---------------------------
  #[ALMON] - Start Load Titles
  Local File PJMBUDTRS [TRS]
  Local File PJMBUDTRQ [PJQ]
  # ---------------------------
  Filter [TRS] Where [F:TRS]PBTGRP = this.SHOWGRP Order By PBTCOD
  Read [F:TRS]First
  NI = 1
  While fstat = 0
    # ----------------
    Read [PJQ]PTQ0=[F:TRS]PBTGRP;[F:TRS]PBTCOD
    If fstat Then
      Raz [F:PJQ]
    Endif
    # ----------------
    If this.TITLE(NI) <> null Then
      this.TITLE(NI).TVARTIDYN = func PJMBUDTRS_CSTD_PROGS.GET_SCOL1(this, [F:TRS]PBTGRP, [F:TRS]PBTCOD)
      this.TITLE(NI).USE = [F:TRS]DSPLY #[V]CST_AYES
    Else
      this.TITLE(NI).USE = [V]CST_ANO
    Endif
    this.TITLE(NI).COLTYP = [F:TRS]COL1TYP
    # -----
    NI += 1
    If this.TITLE(NI) <> null Then
      this.TITLE(NI).TVARTIDYN = func PJMBUDTRS_CSTD_PROGS.GET_SCOL2(this, [F:TRS]PBTGRP, [F:TRS]PBTCOD)
      this.TITLE(NI).USE = [F:TRS]DSPLY #[V]CST_AYES
    Else
      this.TITLE(NI).USE = [V]CST_ANO
    Endif
    this.TITLE(NI).COLTYP = [F:TRS]COL2TYP
    # -----
    Read [F:TRS]Next
    NI += 1
  Wend
  Filter [TRS]
  #[ALMON] - End Load Titles
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("TITLE_EXTRACT : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # --------
Return

###################################################################################################
$EXTRACT_ALL
#Local Integer ARET_VALUE

Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  # Issue X3-46735 - 2017-06-28 by FGR : BEGIN
  #If 1=1 Then
  #  this.CRELOGFILE = [V]CST_AYES
  #Endif
  this.CRELOGFILE = [V]CST_ANO
  If fmet this.ACTX.APARAM.AGETUSERVALNUM("PJMLOGFIL") = [V]CST_AYES Then
    this.CRELOGFILE = [V]CST_AYES
  Endif
  # Issue X3-46735 - 2017-06-28 by FGR : END
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRETLOG = fmet this.LOGFILE.ABEGINLOG(mess(367,2260,1))
  Endif
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("EXTRACT_ALL : Time begin :" - num$(ITIME) - time$, [V]CST_AINFO)
  Endif
  # ---------------------------------
  [L]ARET_VALUE = fmet this.CHECK_INPUT_DATA()
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = fmet this.DATA_EXTRACT()
    If [L]ARET_VALUE = [V]CST_AOK Then
      [L]ARET_VALUE = fmet this.TITLE_EXTRACT()
    Endif
  Endif
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("EXTRACT_ALL : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)" - time$, [V]CST_AINFO)
  Endif
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    If [L]ARET_VALUE <> [V]CST_AOK Then
      Call MSGSTACK_DUMP_MESSAGES_INTO_LOG(this, this.LOGFILE) From SYRSTACKTOOLS
    Endif
  Endif
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRETLOG = fmet this.LOGFILE.AFLUSHLOG()
    IRETLOG = fmet this.LOGFILE.AENDLOG()
  Endif
  # ---------------------------------
Return

###################################################################################################
$DELETE_PIMPLSEL
#Local Integer ARET_VALUE

Local Integer IADXLOG
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  #--------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("DELETE_PIMPLSEL : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  #--------------------------
  Local File PIMPLSEL [PIS]
  #--------------------------
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [PIS]
  Endif
  #--------------------------
  Delete [PIS] Where [F:PIS]PIMSSS = this.SESSION or [F:PIS]CREDATTIM < gdatetime$(date$-2)
  If fstat Then
    [L]ARET_VALUE = fmet this.ASETERROR("DELETE_PIMPLSEL", mess(815,196,1), [V]CST_AERROR)
    If IADXLOG = 0 Then
      Rollback
    Endif
  Else
    If IADXLOG = 0 Then
      Commit
    Endif
  Endif
  #--------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("DELETE_PIMPLSEL : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  #--------------------------
Return

