###################################################################################################
$DELETE_ALL
#Local Integer ARET_VALUE

Local Integer IADXLOG
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  #--------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("DELETE_ALL : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  #--------------------------
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Local File PIMPLSEL [PIS]
    Trbegin [PIS]
  Endif
  #--------------------------
  [L]ARET_VALUE = fmet this.DELETE_PIMPLSEL()
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = fmet this.DELETE_PJMDE()
    If [L]ARET_VALUE = [V]CST_AOK Then
      [L]ARET_VALUE = fmet this.DELETE_PJMSC()
      If [L]ARET_VALUE = [V]CST_AOK Then
        [L]ARET_VALUE = fmet this.DELETE_PJMSCCT()
      Endif
    Endif
  Endif
  #--------------------------
  If IADXLOG = 0 Then
    If [L]ARET_VALUE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  #--------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("DELETE_ALL : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  #--------------------------
Return

###################################################################################################
$LOAD_PRJLST
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IMULTI
Local Char SMESS(250)        # Issue X3-67352 - 2017-12-11 by FGR

  # Issue X3-46735 - 2017-06-28 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  #--------------------------
  Local File OPPORSBB [OBB]
  #--------------------------
  ILINE = fmet this.ADDLINE("PRJLST", [V]CST_ALASTPOS)
  this.PRJLST(ILINE).OPPLST = this.OPPNUM
  #
  If this.PBUCOD = AVOID.ACHAR Then
    IMULTI = [V]CST_ANO
    If this.MULPRJ = [V]CST_AYES Then
      # Issue X3-87228 - 2018-06-14 by AMO : Added CONSFLG to filtering
      Filter [OBB] Where [F:OBB]OPPNUM = this.OPPNUM and [F:OBB]CONSFLG = [V]CST_AYES
      For [OBB]
        If find(func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(this.ACTX, [F:OBB]SBBPJT, AVOID.ACHAR, AVOID.ACHAR, SMESS), 2, 3) Then     # Issue X3-67352 - 2017-12-11 by FGR
          ILINE = fmet this.ADDLINE("PRJLST", [V]CST_ALASTPOS)
          this.PRJLST(ILINE).OPPLST = [F:OBB]SBBPJT
          IMULTI = [V]CST_AYES
        Endif
      Next
      Filter [OBB]
    Endif
    If IMULTI = [V]CST_ANO Then
      this.MULPRJ = [V]CST_ANO
    Endif
  Else
    # Extract on a budget is mandatory not multi-project.
    this.MULPRJ = [V]CST_ANO
  Endif
Return

