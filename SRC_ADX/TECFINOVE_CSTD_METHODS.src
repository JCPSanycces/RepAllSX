#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe TECFINOVE
###################################################################################################
$CHECK_INPUT_DATA
#Local Integer ARET_VALUE

Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  # Issue X3-46735 - 2017-06-28 by FGR : BEGIN
  If this.MULPRJ <> [V]CST_ANO and this.MULPRJ <> [V]CST_AYES Then
    #this.MULPRJ = [V]CST_ANO
    this.MULPRJ = [V]CST_AYES
  Endif
  # Issue X3-46735 - 2017-06-28 by FGR : END
  # ---------------------------
  If this.CUR = AVOID.ACHAR Then
    [L]ARET_VALUE = fmet this.ASETERROR("CUR", mess(368,2260,1), [V]CST_AERROR)
  Endif
  If this.ISBUDUPD = [V]CST_ANO Then     # Issue X3-6096/119481 - 2016-10-28 by FGR : Global UOM is not mandatory in this case. We will take it on the budget line
    If this.UOM = AVOID.ACHAR Then
      [L]ARET_VALUE = fmet this.ASETERROR("UOM", mess(371,2260,1), [V]CST_AERROR)
    Endif
  Endif
  If this.OPPNUM = AVOID.ACHAR Then
    [L]ARET_VALUE = fmet this.ASETERROR("OPPNUM", mess(369,2260,1), [V]CST_AERROR)
  Endif
  If [L]ARET_VALUE = [V]CST_AOK Then
    # ---------------------------
    this.SESSION = func TECFINOVE_CSTD_PROGS.GET_UNIC_ID()
    this.AIMG = 0                # FGR : I don't know what is ?
    this.AIMGDATE = date$        # FGR : I don't know what is ?
    # ---------------------------
    Local File OPPOR [OPP]
    Local File OPPORPJM [OPPPJM]
    Read [OPP]OPP0=this.OPPNUM
    Read [OPPPJM]OPPPJM0=this.OPPNUM
    # ---------------------------
    this.OPPCUR = [F:OPP]CUR
    this.CHGTYP = [F:OPP]CHGTYP
    this.FCY = [F:OPP]SALFCY
    this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"LEGCPY")
    this.CPYCUR = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"RGCCUR")
    this.OPPPROACTIV = [F:OPPPJM]OPPPROACTIV
    # ---------------------------
    #[L]ARET_VALUE = fmet this._LOAD_PROJECT()   # Issue X3-46735 - 2017-06-28 by FGR : not necessary now
    # ---------------------------
  Endif
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : ------------------------------------------" , [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.CUR :" - this.CUR, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.UOM :" - this.UOM, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.OPPNUM :" - this.OPPNUM, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.MULPRJ :" - num$(this.MULPRJ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.PBUCOD :" - this.PBUCOD, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.SHOWGRP :" - this.SHOWGRP, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.ADVINCL :" - num$(this.ADVINCL), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.SESSION :" - num$(this.SESSION), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.OPPCUR :" - this.OPPCUR, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.CPYCUR :" - this.CPYCUR, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.CHGTYP :" - num$(this.CHGTYP), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.FCY :" - this.FCY, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : TECFINOVE.CPY :" - this.CPY, [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : ------------------------------------------" , [V]CST_AINFO)
  Endif
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("CHECK_INPUT_DATA : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------
Return

###################################################################################################
$DATA_EXTRACT
#Local Integer ARET_VALUE

Local Integer ITIME
Local Integer IRET
Local Integer IADXLOG        # Issue X3-64481 - 2018-01-11 by FGR

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("DATA_EXTRACT : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  # Necessary to have the Trbegin on the higher level, to be able to commit/rollback everything on the same time
  Local File PIMPLSEL [PIS]
  # Issue X3-64481 - 2018-01-11 by FGR : BEGIN
  #Trbegin [PIS]
  IADXLOG = (adxlog = 1)
  If IADXLOG = [V]CST_AFALSE Then
    Trbegin [PIS]
  Endif
  # Issue X3-64481 - 2018-01-11 by FGR : END
  # ---------------------------
  [L]ARET_VALUE = fmet this.LOAD_PRJLST()        # Issue X3-46735 - 2017-06-28 by FGR
  If [L]ARET_VALUE = [V]CST_AOK Then             # Issue X3-46735 - 2017-06-28 by FGR
    [L]ARET_VALUE = fmet this.DELETE_ALL()
    If [L]ARET_VALUE = [V]CST_AOK Then
      # ---------------------------
      this.TECPDESEQ = 0
      this.TECPSCSEQ = 0
      this.TECPSCCTSEQ = 0
      # ---------------------------
      # Call all necessary PRIVATE methods to do the extract in 1-PIMPLSEL, 2-PJMDE and 3-PJMSC
      [L]ARET_VALUE = fmet this._DATA_EXTRACT_PIMPLSEL()
      If [L]ARET_VALUE = [V]CST_AOK Then
        [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMDE()
        If [L]ARET_VALUE = [V]CST_AOK Then
          [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC()
          If this.ISBUDUPD = [V]CST_ANO Then
            # PJMSCCT table is not necessary in YES case
            If [L]ARET_VALUE = [V]CST_AOK Then
              [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSCCT()
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif                                          # Issue X3-46735 - 2017-06-28 by FGR
  # ---------------------------
  If IADXLOG = [V]CST_AFALSE Then                # Issue X3-64481 - 2018-01-11 by FGR
    If [L]ARET_VALUE = [V]CST_AOK Then
      Commit
    Else
      Rollback
    Endif
  Endif
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("DATA_EXTRACT : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PIMPLSEL
#Local Integer ARET_VALUE

Local Integer ISEQ
Local Integer ITIME
Local Integer IRET
Local Integer NI                       # Issue X3-46735 - 2017-06-28 by FGR
Local Integer NE                       # Issue X3-46735 - 2017-06-28 by FGR
Local Char TBPBUCOD(GLONPBU)(1..)
Local Char TBOPPNUM(GLONOPP)(1..)

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PIMPLSEL : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # Doing the job to extract data in PIMPLSEL. Others PRIVATE methods could be necessary
  # ---------------------------
  Local File PIMPL [PIM]
  Local File PIMPLSEL [PIS]
  # ---------------------------
  # Issue X3-46735 - 2017-06-28 by FGR : BEGIN
  NE = 0
  Raz TBOPPNUM
  For NI = 1 To maxtab(this.PRJLST)
    If this.PRJLST(NI) <> null and find(this.PRJLST(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NE += 1
      TBOPPNUM(NE) = this.PRJLST(NI).OPPLST
    Endif
  Next NI
  # Issue X3-46735 - 2017-06-28 by FGR : END
  ISEQ = 0
  If this.PBUCOD = AVOID.ACHAR Then
    # All of the project
    #Filter [PIM] Where [F:PIM]OPPNUM = this.OPPNUM and find([F:PIM]PIMTYP,4,5,6,7)<>0                                           # Issue X3-46735 - 2017-06-28 by FGR
    Filter [PIM] Where find([F:PIM]OPPNUM,TBOPPNUM)<>0 and find([F:PIM]PIMTYP,4,5,6,7)<>0                                        # Issue X3-46735 - 2017-06-28 by FGR
  Else
    # Only what is linked to a budget on the project
    #IRET = fmet this.PROJECT.PJM(1).BUD_GET_FAMILY(this.PBUCOD, TBPBUCOD)                                                       # Issue X3-46735 - 2017-06-28 by FGR
    IRET = func PJMBUD_CSTD_PROGS.GET_FAMILY(this.OPPNUM, this.PBUCOD, TBPBUCOD)                                                 # Issue X3-46735 - 2017-06-28 by FGR
    #Filter [PIM] Where [F:PIM]OPPNUM = this.OPPNUM and find([F:PIM]PIMTYP,4,5,6,7)<>0 and find([F:PIM]PBUCOD,TBPBUCOD)<>0       # Issue X3-46735 - 2017-06-28 by FGR
    Filter [PIM] Where find([F:PIM]OPPNUM,TBOPPNUM)<>0 and find([F:PIM]PIMTYP,4,5,6,7)<>0 and find([F:PIM]PBUCOD,TBPBUCOD)<>0    # Issue X3-46735 - 2017-06-28 by FGR
  Endif
  For [PIM]
    Raz [F:PIS]
    [F:PIS] = [F:PIM]
    [F:PIS]PIMSSS = this.SESSION
    # ---------------------------
    Raz [F:PIS]CREUSR
    Raz [F:PIS]UPDUSR
    Raz [F:PIS]AUUID
    Raz [F:PIS]UPDDATTIM
    Raz [F:PIS]CREDATTIM
    # ---------------------------
    ISEQ += 1
    [F:PIS]SEQ = ISEQ
    Write [PIS]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PIMPLSEL", mess(352,2260,1) - "PIMPLSEL (a)", [V]CST_AERROR)
      Break
    Endif
  Next
  Filter [PIM]
  # ---------------------------
  # In all cases, the project itself
  #Filter [PIM] Where [F:PIM]OPPNUM = this.OPPNUM and find([F:PIM]PIMTYP,2,3)<>0                                                 # Issue X3-46735 - 2017-06-28 by FGR
  Filter [PIM] Where find([F:PIM]OPPNUM,TBOPPNUM)<>0 and find([F:PIM]PIMTYP,2,3)<>0                                              # Issue X3-46735 - 2017-06-28 by FGR
  For [PIM]
    Raz [F:PIS]
    [F:PIS] = [F:PIM]
    [F:PIS]PIMSSS = this.SESSION
    # ---------------------------
    Raz [F:PIS]CREUSR
    Raz [F:PIS]UPDUSR
    Raz [F:PIS]AUUID
    Raz [F:PIS]UPDDATTIM
    Raz [F:PIS]CREDATTIM
    # ---------------------------
    ISEQ += 1
    [F:PIS]SEQ = ISEQ
    Write [PIS]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PIMPLSEL", mess(352,2260,1) - "PIMPLSEL (b)", [V]CST_AERROR)
      Break
    Endif
  Next
  Filter [PIM]
  # ---------------------------
  For NI = 1 To maxtab(TBOPPNUM)
    If TBOPPNUM(NI) <> AVOID.ACHAR Then
      #Filter [PIM] Where [F:PIM]OPPNUM = this.OPPNUM and find([F:PIM]PIMTYP,4)<>0                                               # Issue X3-46735 - 2017-06-28 by FGR
      Filter [PIM] Where [F:PIM]OPPNUM = TBOPPNUM(NI) and find([F:PIM]PIMTYP,4)<>0                                               # Issue X3-46735 - 2017-06-28 by FGR
      For [PIM]
        Raz [F:PIS]
        [F:PIS] = [F:PIM]
        [F:PIS]PIMSSS = this.SESSION
        [F:PIS]PBUCOD = fmet this._GET_EMPTY_STRING()
        # ---------------------------
        Raz [F:PIS]CREUSR
        Raz [F:PIS]UPDUSR
        Raz [F:PIS]AUUID
        Raz [F:PIS]UPDDATTIM
        Raz [F:PIS]CREDATTIM
        # ---------------------------
        ISEQ += 1
        [F:PIS]SEQ = ISEQ
        Write [PIS]
        If fstat <> 0 Then
          [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PIMPLSEL", mess(352,2260,1) - "PIMPLSEL (a)", [V]CST_AERROR)
          Break
        Endif
        Break
      Next
      Filter [PIM]
    Endif
  Next NI
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PIMPLSEL : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMDE
#Local Integer ARET_VALUE

Local Instance WSTRREQ Using C_PJMBUDTRQ
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMDE : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # -----------------------
  Local File PJMBUDTRQ [PJQ]
  # -----------------------
  Filter [PJQ] Where [F:PJQ]PBTGRP = this.SHOWGRP and [F:PJQ]ACTIVE = [V]CST_AYES and [F:PJQ]SQLQRY <> "" and [F:PJQ]DEFCTYPE <> "" and [F:PJQ]PJMPBTCOD <> ""
  For [PJQ]
    WSTRREQ = NewInstance C_PJMBUDTRQ AllocGroup null
    [L]ARET_VALUE = fmet WSTRREQ.AREAD([F:PJQ]PBTGRP, [F:PJQ]PBTCOD)
    If [L]ARET_VALUE <> [V]CST_AOK Then
      [L]ARET_VALUE = fmet this.ASETERROR("_DATA_EXTRACT_PJMDE", mess(351,2260,1) - "PJMBUDTRQ", [V]CST_AERROR)
    Else
      [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMDE_EXECUTE(WSTRREQ)
    Endif
    FreeGroup WSTRREQ
    If [L]ARET_VALUE <> [V]CST_AOK Then
      Break
    Endif
  Next
  Filter [PJQ]
  # -----------------------
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMDE_PROV()
  Endif
  # -----------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMDE : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ----------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMDE_EXECUTE
#Variable Instance WSTRREQ Using C_PJMBUDTRQ : #
#Local Integer ARET_VALUE

Local Clbfile WCLOBORI(6)
Local Clbfile WCLOBLAN(6)
Local Clbfile WCLOB(6)
Local Char AREQ(250)(0..)
Local Decimal IORIPSDUQTY
Local Decimal WPSDUQTY
Local Decimal WAMTRESULT
Local Integer ISTAT
Local Integer ITIME
Local Integer IRET
Local Char UOMTOUSE(GLONUOM)
Local Integer ICOL1TYP
Local Integer ICOL2TYP

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMDE_EXECUTE : Time begin :" - num$(ITIME) - WSTRREQ.SQLQRY, [V]CST_AINFO)
  Endif
  # -----------------------
  Local File PJMDE [PJE]
  Local File PJMBUDTRS [PJS]
  # -----------------------
  Read [PJS]PTS0=WSTRREQ.PBTGRP;WSTRREQ.PJMPBTCOD
  If fstat Then
    ICOL1TYP = 2
    ICOL2TYP = 1
  Else
    ICOL1TYP = [F:PJS]COL1TYP
    ICOL2TYP = [F:PJS]COL2TYP
  Endif
  # -----------------------
  [L]ARET_VALUE = fmet this.SQL_READ_CLOB(WSTRREQ.SQLQRY, WCLOBORI)                      #--Call Read Clob
  If [L]ARET_VALUE = [V]CST_AOK Then
    WVALUE = "'" + this.ACTX.LAN + "'"
    [L]ARET_VALUE = fmet this.SQL_REPLACE_WORD_CLOB(WCLOBORI, "%2%", WVALUE, WCLOBLAN)   #--Call Replace Word Clob
    If [L]ARET_VALUE = [V]CST_AOK Then
      # -----------------------
      WVALUE = num$(this.SESSION)
      [L]ARET_VALUE = fmet this.SQL_REPLACE_WORD_CLOB(WCLOBLAN, "%1%", WVALUE, WCLOB)    #--Call Replace Word Clob
      If [L]ARET_VALUE = [V]CST_AOK Then
        #----------------------------------WCLOB contains the executable request--------------------------------
        #------------------------------------Data mount 18 fields +1=WUNIT =19----------------------------------
        Raz AREQ
        Setlob AREQ With WCLOB
        For (Char WOPPNUM(GLONOPP), Char WTASCOD(GLONTAC), Char WPBUCOD(GLONPBU), Char WPIMNUM(GLONPIM), Char WPSDNUM(GLONDES),
&            Char WPSDDES(GLONDES), Date WPSDDAT,          Decimal WPSDQTY,       Decimal WPSDAMT,       Char WCURIN(GLONCUR),
&            Integer WCHGTYP,       Decimal WCHGCOE,       Char WPSHNUM(250),     Char WTSKDES(GLONDCO), Char WREQUSR(GLONDCO),
&            Char WTCLCOD(GLONDES), Char WTCLDES(GLONDCO), Date WGRPDAT,          Char WUNIT(GLONUOM)
&           )
&           From fmet this.SQL_GET_TYPDBA() Sql AREQ As [WWW]
          # Issue X3-56789 - 2018-07-17 by ALMON : replaced WPSHNUM(GLONVCR) by WPSHNUM(250)
          #-----------------------------------Building the list of results--------------------------------------
          Raz [F:PJE]
          [F:PJE]PIMNUM     = [F:WWW]WPIMNUM
          [F:PJE]OPPNUM     = [F:WWW]WOPPNUM
          If [F:WWW]WPBUCOD = AVOID.ACHAR Then
            [F:PJE]PBUCOD   = fmet this._GET_EMPTY_STRING()
          Else
            [F:PJE]PBUCOD   = [F:WWW]WPBUCOD
          Endif
          #
          [F:PJE]PDENUM     = [F:WWW]WPSDNUM
          If [F:WWW]WPSDNUM <> AVOID.ACHAR Then
            If [F:WWW]WPSDDES <> AVOID.ACHAR Then
              [F:PJE]PDEDES = [F:WWW]WPSDDES
            Else
              [F:PJE]PDEDES = func AFNC.MES1(mess(387,2260,1), [F:WWW]WPSDNUM)
            Endif
          Endif
          #
          [F:PJE]PDEDAT     = [F:WWW]WPSDDAT
          [F:PJE]PDEORICOD  = [F:WWW]WPSHNUM
          [F:PJE]OBJECT     = WSTRREQ.SQLQRY
          If [F:WWW]WTSKDES <> "" Then
            [F:PJE]PDEORIDES = [F:WWW]WTSKDES
          Else
            [F:PJE]PDEORIDES = WSTRREQ.CODDES
          Endif
          #
          [F:PJE]PDEGRPNUM  = [F:WWW]WTCLCOD
          If [F:WWW]WTCLCOD <> AVOID.ACHAR Then
            If [F:WWW]WTCLDES <> AVOID.ACHAR Then
              [F:PJE]PDEGRPDES  = [F:WWW]WTCLDES
            Else
              [F:PJE]PDEGRPDES  = func AFNC.MES1(mess(387,2260,1), [F:WWW]WTCLCOD)
            Endif
          Endif
          #
          [F:PJE]PDEGRPDAT  = [F:WWW]WGRPDAT
          [F:PJE]PDEIMG     = this.AIMG
          [F:PJE]PDEWQA     = WSTRREQ.CUMSCOL
          [F:PJE]PDEWWIPA   = WSTRREQ.CUMRTCO
          [F:PJE]PDETYP     = 1
          If WSTRREQ.FREECOL > 5 Then
            [F:PJE]PDETYP = 2
          Endif
          If [F:WWW]WCURIN = "" Then
            [F:WWW]WCURIN = this.CPYCUR
          Endif
          If [F:WWW]WCHGTYP = 0 Then
            [F:WWW]WCHGTYP = this.CHGTYP
          Endif
          [F:PJE]PDEU = [F:WWW]WUNIT
          #---------------------------------------Get Cost Type------------------------------------------
          #-- ACTX =1 for Main d'oeuvre, 2 for Article(Achat,Commande,Facture etc), 3 for Frais
          [F:PJE]PCCCOD = fmet this.GET_PCCCOD(WSTRREQ.CONTXT, [F:WWW]WPSDNUM, [F:WWW]WTCLCOD, [F:WWW]WPIMNUM, WSTRREQ.DEFCTYPE)
          # -------------------------------------------------------
          #UOMTOUSE = fmet this._GET_BUDLIG_PLBU([F:PJE]PBUCOD, [F:PJE]PCCCOD)                     # Issue X3-46735 - 2017-06-28 by FGR
          UOMTOUSE = fmet this._GET_BUDLIG_PLBU([F:PJE]OPPNUM, [F:PJE]PBUCOD, [F:PJE]PCCCOD)       # Issue X3-46735 - 2017-06-28 by FGR
          # -------------------------------------------------------
          WPSDUQTY = [F:WWW]WPSDQTY
          If WSTRREQ.FREECOL <= 5 Then
            #--------------------------------------Unit Conversion-----------------------------------------
            If [F:WWW]WUNIT <> UOMTOUSE and [F:WWW]WUNIT <> AVOID.ACHAR Then
               #-- Convertion AUNIT unite input from interface --
              Call CONVERT_QTY(this.ACTX, [F:WWW]WUNIT, UOMTOUSE, WPSDUQTY) From TRTX3_SYRA
            Endif
            #-------------------------------------Amount Conversion----------------------------------------
            Call CONVERT(this.ACTX, [F:WWW]WCURIN, this.CUR, this.CPYCUR, [F:WWW]WCHGTYP, [F:WWW]WPSDDAT, [F:WWW]WPSDAMT, WAMTRESULT, ISTAT) From TRTDEV_SYRA
            If this.CRELOGFILE = [V]CST_AYES Then
              IRET = fmet this.LOGFILE.APUTLINE("  _DATA_EXTRACT_PJMDE_EXECUTE : [F:WWW]WCURIN=" + [F:WWW]WCURIN -
&                                               "this.CUR=" + this.CUR -
&                                               "this.CPYCUR=" + this.CPYCUR -
&                                               "[F:WWW]WCHGTYP=" + num$([F:WWW]WCHGTYP) -
&                                               "[F:WWW]WPSDDAT=" + num$([F:WWW]WPSDDAT) -
&                                               "[F:WWW]WPSDAMT=" + num$([F:WWW]WPSDAMT) -
&                                               "WAMTRESULT=" + num$(WAMTRESULT) -
&                                               "ISTAT=" + num$(ISTAT)
&                                               , [V]CST_AINFO)
            Endif
          Else
            # --------------------------
            If ICOL1TYP = 1 Then
              # Quantity
              If [F:WWW]WUNIT <> UOMTOUSE and [F:WWW]WUNIT <> AVOID.ACHAR Then
                Call CONVERT_QTY(this.ACTX, [F:WWW]WUNIT, UOMTOUSE, WPSDUQTY) From TECFINOVE_CSTD_PROGS
              Endif
            Else
              # Amount
              IORIPSDUQTY = WPSDUQTY
              Call CONVERT(this.ACTX, [F:WWW]WCURIN, this.CUR, this.CPYCUR, [F:WWW]WCHGTYP, [F:WWW]WPSDDAT, IORIPSDUQTY, WPSDUQTY, ISTAT) From TRTDEV_SYRA
              [F:WWW]WPSDQTY = WPSDUQTY
              If this.CRELOGFILE = [V]CST_AYES Then
                IRET = fmet this.LOGFILE.APUTLINE("  _DATA_EXTRACT_PJMDE_EXECUTE (COL1TYP=2) : [F:WWW]WCURIN=" + [F:WWW]WCURIN -
&                                                   "this.CUR=" + this.CUR -
&                                                   "this.CPYCUR=" + this.CPYCUR -
&                                                   "[F:WWW]WCHGTYP=" + num$([F:WWW]WCHGTYP) -
&                                                   "[F:WWW]WPSDDAT=" + num$([F:WWW]WPSDDAT) -
&                                                   "IORIPSDUQTY=" + num$(IORIPSDUQTY) -
&                                                   "WPSDUQTY=" + num$(WPSDUQTY) -
&                                                   "ISTAT=" + num$(ISTAT)
&                                                   , [V]CST_AINFO)
              Endif
            Endif
            # --------------------------
            If ICOL2TYP = 1 Then
              # Quantity
              WAMTRESULT = [F:WWW]WPSDAMT
              Call CONVERT_QTY(this.ACTX, [F:WWW]WUNIT, UOMTOUSE, WAMTRESULT) From TECFINOVE_CSTD_PROGS
            Else
              # Amount
              Call CONVERT(this.ACTX, [F:WWW]WCURIN, this.CUR, this.CPYCUR, [F:WWW]WCHGTYP, [F:WWW]WPSDDAT, [F:WWW]WPSDAMT, WAMTRESULT, ISTAT) From TRTDEV_SYRA
              If this.CRELOGFILE = [V]CST_AYES Then
                IRET = fmet this.LOGFILE.APUTLINE("  _DATA_EXTRACT_PJMDE_EXECUTE (COL2TYP=2) : [F:WWW]WCURIN=" + [F:WWW]WCURIN -
&                                                 "this.CUR=" + this.CUR -
&                                                 "this.CPYCUR=" + this.CPYCUR -
&                                                 "[F:WWW]WCHGTYP=" + num$([F:WWW]WCHGTYP) -
&                                                 "[F:WWW]WPSDDAT=" + num$([F:WWW]WPSDDAT) -
&                                                 "[F:WWW]WPSDAMT=" + num$([F:WWW]WPSDAMT) -
&                                                 "WAMTRESULT=" + num$(WAMTRESULT) -
&                                                 "ISTAT=" + num$(ISTAT)
&                                                 , [V]CST_AINFO)
              Endif
            Endif
            # --------------------------
          Endif
          #-------------------------------------Set Column Values----------------------------------------
          Call COLUMN_SET_VALUES(WSTRREQ.POSVAL, WSTRREQ.FREECOL, [F:WWW]WPSDQTY, WPSDUQTY, WAMTRESULT) From TECFINOVE_CSTD_PROGS
          #--------------------------------------Write to Class------------------------------------------
          [F:PJE]PDESSS     = this.SESSION
          this.TECPDESEQ   += 1
          [F:PJE]PDESEQ     = this.TECPDESEQ
          #
          Write [PJE]
          If fstat <> 0 Then
            [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMDE_EXECUTE", mess(352,2260,1) - "PJMDE", [V]CST_AERROR)
            Break
          Endif
        Next
      Endif
    Endif
  Endif
  # ----------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMDE_EXECUTE : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ----------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMDE_PROV
#Local Integer ARET_VALUE

Local Char REQ(255)(10)
Local Integer ISTAT
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.OPPPROACTIV <> [V]CST_AYES Then
    Return
  Endif
  # -------------------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMDE_PROV : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # -------------------------------------------
  Local File PJMDE [PJE]
  # -------------------------------------------
  [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMDE_PROV_SQL(REQ)
  # -------------------------------------------
  For (Char WOPP(GLONOPP),      Char WPBU(GLONPBU),     Char WPCCCOD(GLONPJCC), Char WPCCCOD2(GLONPJCC), Char WPCC2COD(GLONPJCC),
&      Decimal WPCCPRTC,        Date WDAT,              Decimal WWIPA,          Decimal WAMT1,           Decimal WAMT2,
&      Decimal WAMT3,           Decimal WAMT4,          Decimal WAMT5
&     )
&     From fmet this.SQL_GET_TYPDBA() Sql REQ As [WWW]
    #---datas ok --------------------------------------------------
    #-- prepare for class create now : only one line for provision
    #--------------------------------------------------------------
    Raz [F:PJE]
    [F:PJE]OPPNUM = [F:WWW]WOPP
    [F:PJE]PBUCOD = [F:WWW]WPBU
    [F:PJE]PCCCOD = [F:WWW]WPCCCOD
    [F:PJE]PDENUM = [F:WWW]WPCCCOD2
    [F:PJE]PDEDES = func PJMCOSTCTR_CSTD_PROGS.GET_DESAXX(this, [F:WWW]WPCCCOD)
    #
    [F:PJE]PDEIMG = this.AIMG
    #
    [F:PJE]PDEAMT1 = [F:WWW]WAMT1
    [F:PJE]PDEAMT2 = [F:WWW]WAMT2
    [F:PJE]PDEAMT3 = [F:WWW]WAMT3
    [F:PJE]PDEAMT4 = [F:WWW]WAMT4
    [F:PJE]PDEAMT5 = [F:WWW]WAMT5
    # Issue X3-15236/121351 - 2017-02-03 by FGR : END
    #
    [F:PJE]PDEGRPNUM = [F:WWW]WPCC2COD
    [F:PJE]PDEGRPDES = func PJMCOSTCTR_CSTD_PROGS.GET_DESAXX(this, [F:WWW]WPCC2COD)
    #
    [F:PJE]PDEORICOD = ""
    [F:PJE]PDEORIDES = ""
    #--null PIMNUM ??------------
    [F:PJE]PIMNUM = ""
    [F:PJE]PDEDAT = [F:WWW]WDAT
    [F:PJE]PDEGRPDAT = [0/0/0]
    [F:PJE]PDEQTY1 = 0
    [F:PJE]PDEQTY2 = 0
    [F:PJE]PDEQTY3 = 0
    [F:PJE]PDEQTY4 = 0
    [F:PJE]PDEQTY5 = 0
    #--------------init ---------------------------
    [F:PJE]PDEFREEC6A = 0
    [F:PJE]PDEFREEC6B = 0
    [F:PJE]PDEFREEC7A = 0
    [F:PJE]PDEFREEC7B = 0
    [F:PJE]PDEFREEC8A = 0
    [F:PJE]PDEFREEC8B = 0
    [F:PJE]PDEFREEC9A = 0
    [F:PJE]PDEFREEC9B = 0
    [F:PJE]PDEFREEC10A = 0
    [F:PJE]PDEFREEC10B = 0
    #-- les autre Oui(Yes)=2, Non(No)=1
    #-- Because decode PDEWQA=1  then show 0
    #-- pas de null , on met 0 à la place pour provision si PDEWQA=1: not show
    [F:PJE]PDEWQA = 1
    #-- prevision pas de Accu.encours
    [F:PJE]PDEWWIPA = [F:WWW]WWIPA
    #--- type 1 (col 1..5)
    [F:PJE]PDETYP = 1
    #--------------------------------------Write to Class------------------------------------------
    [F:PJE]PDESSS     = this.SESSION
    this.TECPDESEQ   += 1
    [F:PJE]PDESEQ     = this.TECPDESEQ
    #
    Write [PJE]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMDE_PROV", mess(352,2260,1) - "PJMDE", [V]CST_AERROR)
      Break
    Endif
  Next
  # -------------------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMDE_PROV : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # -------------------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMDE_PROV_SQL
#Variable Char SREQ ()(0..)
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  Raz SREQ
  SREQ(0)  = "SELECT PDE.OPPNUM_0,PDE.PBUCOD_0,PCC1.PCCCOD_0"
  SREQ(0) += ",PCC2.PCCCOD2_0,PCC2.PCCCOD_0"
  SREQ(0) += ",PCC2.PCCPRCT_0,max(PDE.PDEDAT_0),PDE.PDEWWIPA_0"
  SREQ(1)  = ",sum(PDE.PDEAMT1_0)*PCC2.PCCPRCT_0/100,sum(PDE.PDEAMT2_0)*PCC2.PCCPRCT_0/100 "
  SREQ(1) += ",sum(PDE.PDEAMT3_0)*PCC2.PCCPRCT_0/100,sum(PDE.PDEAMT4_0)*PCC2.PCCPRCT_0/100 "
  SREQ(2)  = ",sum(PDE.PDEAMT5_0)*PCC2.PCCPRCT_0/100 "
  SREQ(2) += " From PJMCOSTCTR PCC1,PJMCOSTCTR PCC2,PJMDE PDE "
  SREQ(2) += " Where PCC1.PCCCOD_0=PCC2.PCCCOD2_0 and PDE.PCCCOD_0=PCC2.PCCCOD_0 and PCC2.PCCCOD2_0<>' ' "
  SREQ(3)  = " and PDE.PDEIMG_0=" + num$(this.AIMG) + " and PDE.PDESSS_0=" + num$(this.SESSION) + " and PDE.PDETYP_0=1"
  SREQ(3) += " Group by PDE.OPPNUM_0,PDE.PBUCOD_0,PCC1.PCCCOD_0 "
  SREQ(3) += ",PCC2.PCCCOD2_0,PCC2.PCCCOD_0,PCC2.PCCPRCT_0,PDE.PDEDAT_0,PDE.PDEWWIPA_0"
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC
#Local Integer ARET_VALUE

Local Char SPBUCOD(GLONPBU)
Local Char SOPPNUM(GLONOPP)  # Issue X3-46735 - 2017-06-28 by FGR
Local Integer ITIME
Local Integer IRET
Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # -------------------------------------------
  Local File PIMPLSEL [PIS]
  # -------------------------------------------
  Raz SOPPNUM                                                                            # Issue X3-46735 - 2017-06-28 by FGR
  Raz SPBUCOD
  For NI = 1 To maxtab(this.PRJLST)
    If this.PRJLST(NI) <> null and find(this.PRJLST(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      #Filter [PIS] Where [F:PIS]PIMSSS = this.SESSION and [F:PIS]PBUCOD <> "" Order By Key KEY0=[F:PIS]PBUCOD                  # Issue X3-46735 - 2017-06-28 by FGR
      Filter [PIS] Where [F:PIS]PIMSSS = this.SESSION and [F:PIS]OPPNUM = this.PRJLST(NI).OPPLST and [F:PIS]PBUCOD <> "" Order By Key KEY0=[F:PIS]PBUCOD
      For [PIS]KEY0
        If SPBUCOD <> [F:PIS]PBUCOD Then
          SOPPNUM = [F:PIS]OPPNUM                                                            # Issue X3-46735 - 2017-06-28 by FGR
          SPBUCOD = [F:PIS]PBUCOD
          # -------------------------------------------
          #[L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_EXECUTE(SPBUCOD)                    # Issue X3-46735 - 2017-06-28 by FGR
          [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_EXECUTE(SOPPNUM, SPBUCOD)            # Issue X3-46735 - 2017-06-28 by FGR
          If [L]ARET_VALUE = [V]CST_AERROR Then
            Break
          Endif
          # -------------------------------------------
          #[L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_QTYAMT(SPBUCOD)                     # Issue X3-46735 - 2017-06-28 by FGR
          [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_QTYAMT(SOPPNUM, SPBUCOD)             # Issue X3-46735 - 2017-06-28 by FGR
          If [L]ARET_VALUE = [V]CST_AERROR Then
            Break
          Endif
          # -------------------------------------------
          #[L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_PROV(SPBUCOD)                       # Issue X3-46735 - 2017-06-28 by FGR
          [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_PROV(SOPPNUM, SPBUCOD)               # Issue X3-46735 - 2017-06-28 by FGR
          If [L]ARET_VALUE = [V]CST_AERROR Then
            Break
          Endif
          # -------------------------------------------
          #[L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_SUM_TOTAUX(SPBUCOD)                 # Issue X3-46735 - 2017-06-28 by FGR
          [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_SUM_TOTAUX(SOPPNUM, SPBUCOD)         # Issue X3-46735 - 2017-06-28 by FGR
          If [L]ARET_VALUE = [V]CST_AERROR Then
            Break
          Endif
        Endif
      Next
      Filter [PIS]
    Endif
    If [L]ARET_VALUE = [V]CST_AERROR Then
      Break
    Endif
  Next NI
  # -------------------------------------------
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_CONSOLIDAT()
  Endif
  # -------------------------------------------
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_RATIO()
  Endif
  # -------------------------------------------
  # Issue X3-46735 - 2017-06-28 by FGR : BEGIN
  If [L]ARET_VALUE <> [V]CST_AERROR Then
    [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_MULPRJ()
  Endif
  # Issue X3-46735 - 2017-06-28 by FGR : END
  # -------------------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # -------------------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_GET_SQL
#Variable Char SREQ ()(0..)
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  Raz SREQ
  # -------------------------------------------
  SREQ(0)  = "SELECT A.PCCCOD_0 "
  SREQ(0) += ",SUM(A.QTY1),SUM(A.AMT1),SUM(A.QTY2),SUM(A.AMT2),SUM(A.QTY3),SUM(A.AMT3),SUM(A.QTY4),SUM(A.AMT4)"
  SREQ(0) += ",SUM(A.QTY5),SUM(A.AMT5),SUM(A.WIPQTY),SUM(A.WIPAMT) "
  SREQ(0) += ",SUM(A.FREE6A),SUM(A.FREE6B),SUM(A.FREE7A),SUM(A.FREE7B),SUM(A.FREE8A),SUM(A.FREE8B)"
  SREQ(1)  = ",SUM(A.FREE9A),SUM(A.FREE9B),SUM(A.FREE10A),SUM(A.FREE10B) "
  SREQ(1) += "FROM (SELECT PCCCOD_0,PDEWQA_0,PDEWWIPA_0, "
  SREQ(1) += "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEUQTY1_0) END QTY1,SUM(PDEAMT1_0) AMT1,"
  SREQ(2)  = "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEUQTY2_0) END QTY2,SUM(PDEAMT2_0) AMT2,"
  SREQ(2) += "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEUQTY3_0) END QTY3,SUM(PDEAMT3_0) AMT3,"
  SREQ(2) += "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEUQTY4_0) END QTY4,SUM(PDEAMT4_0) AMT4,"
  SREQ(3)  = "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEUQTY5_0) END QTY5, SUM(PDEAMT5_0) AMT5,"
  SREQ(3) += "CASE WHEN PDEWQA_0=1 THEN 0 ELSE "
  SREQ(4)  = "CASE WHEN PDEWWIPA_0=1 THEN 0 ELSE "
  SREQ(4) += "SUM(PDEUQTY1_0)+SUM(PDEUQTY2_0)+SUM(PDEUQTY3_0)+SUM(PDEUQTY4_0)+SUM(PDEUQTY5_0) END END WIPQTY,"
  SREQ(5)  = "CASE WHEN PDEWWIPA_0 = 1 THEN 0 "
  SREQ(5) += "ELSE SUM(PDEAMT1_0)+SUM(PDEAMT2_0)+SUM(PDEAMT3_0)+SUM(PDEAMT4_0)+SUM(PDEAMT5_0) END WIPAMT,"
  SREQ(6)  = "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEFREEC6A_0)  END FREE6A, SUM(PDEFREEC6B_0) FREE6B,"
  SREQ(6) += "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEFREEC7A_0) END FREE7A,SUM(PDEFREEC7B_0) FREE7B,"
  SREQ(7)  = "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEFREEC8A_0)  END FREE8A,SUM(PDEFREEC8B_0) FREE8B,"
  SREQ(7) += "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEFREEC9A_0) END FREE9A,SUM(PDEFREEC9B_0) FREE9B,"
  SREQ(8)  = "CASE WHEN PDEWQA_0=1 THEN 0 ELSE SUM(PDEFREEC10A_0) END FREE10A,SUM(PDEFREEC10B_0) FREE10B"
  #SREQ(8) += " FROM PJMDE WHERE PBUCOD_0='" + SPBUCOD + "'"                                       # Issue X3-46735 - 2017-06-28 by FGR
  SREQ(8) += " FROM PJMDE WHERE PBUCOD_0='" + SPBUCOD + "' and OPPNUM_0='" + SOPPNUM + "'"         # Issue X3-46735 - 2017-06-28 by FGR
  SREQ(9)  = " AND PDEIMG_0=" + num$(this.AIMG) + " AND PDESSS_0=" + num$(this.SESSION)
  SREQ(9) += " GROUP BY PCCCOD_0 ,PDEWQA_0,PDEWWIPA_0"
  SREQ(9) += ") A GROUP BY A.PCCCOD_0 "
  # -------------------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_EXECUTE
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

Local Char REQ(255)(10)
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_EXECUTE : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------------
  Local File PJMSC [PJC]
  Local File PJMCOSTCTR [PJCC]
  Local File ATABDIV [ADI]
  # ---------------------------------
  #[L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_GET_SQL(REQ, SPBUCOD)         # Issue X3-46735 - 2017-06-28 by FGR
  [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_GET_SQL(REQ, SOPPNUM, SPBUCOD) # Issue X3-46735 - 2017-06-28 by FGR
  # ---------------------------------
  For (Char WPCCCOD(GLONPJCC), Decimal WQTY1,    Decimal WAMT1,   Decimal WQTY2,   Decimal WAMT2,
&      Decimal WQTY3,          Decimal WAMT3,    Decimal WQTY4,   Decimal WAMT4,   Decimal WQTY5,
&      Decimal WAMT5,          Decimal WIPQTY,   Decimal WIPAMT,  Decimal WFREE6A, Decimal WFREE6B,
&      Decimal WFREE7A,        Decimal WFREE7B,  Decimal WFREE8A, Decimal WFREE8B, Decimal WFREE9A,
&      Decimal WFREE9B,        Decimal WFREE10A, Decimal WFREE10B
&     )
&     From fmet this.SQL_GET_TYPDBA() Sql REQ As [WWW]
    # ---------------------------------
    Raz [F:PJC]
    #[F:PJC]OPPNUM = this.OPPNUM                                               # Issue X3-46735 - 2017-06-28 by FGR
    [F:PJC]OPPNUM = SOPPNUM                                                    # Issue X3-46735 - 2017-06-28 by FGR
    [F:PJC]PBUCOD = SPBUCOD
    [F:PJC]PBUSOR = func PJMBUD_CSTD_PROGS.GET_PBUSOR([F:PJC]OPPNUM, [F:PJC]PBUCOD)      # Issue X3-91329 - 2018-06-01 by FGR
    [F:PJC]PCCCOD = [F:WWW]WPCCCOD
    Gosub GET_PJC_PCCGRP_PCCGRPSOR From TECFINOVE_CSTD_PROGS
    #--- Qty 1..5 --------------------------------------------------------
    [F:PJC]PSCQTY1 = [F:WWW]WQTY1
    [F:PJC]PSCQTY2 = [F:WWW]WQTY2
    [F:PJC]PSCQTY3 = [F:WWW]WQTY3
    [F:PJC]PSCQTY4 = [F:WWW]WQTY4
    [F:PJC]PSCQTY5 = [F:WWW]WQTY5
    #--- montants 1..5 ------------------------------
    [F:PJC]PSCAMT1 = [F:WWW]WAMT1
    [F:PJC]PSCAMT2 = [F:WWW]WAMT2
    [F:PJC]PSCAMT3 = [F:WWW]WAMT3
    [F:PJC]PSCAMT4 = [F:WWW]WAMT4
    [F:PJC]PSCAMT5 = [F:WWW]WAMT5
    #---- Accu. encours --------------------------------------------------
    [F:PJC]PSCWIPQTY = [F:WWW]WIPQTY
    #-- 02/2013 : Manager Unit from Input
    If [F:WWW]WIPQTY <> 0 Then
      [F:PJC]PSCU = this.UOM
    Else
      #[F:PJC]PSCU = ""
      [F:PJC]PSCU  = this.UOM          # Issue X3-46735 - 2017-06-28 by FGR
    Endif
    #
    [F:PJC]PSCWIPAMT = [F:WWW]WIPAMT
    #---- 6 ..10
    [F:PJC]PSCFREEC6A = [F:WWW]WFREE6A
    [F:PJC]PSCFREEC6B = [F:WWW]WFREE6B
    [F:PJC]PSCFREEC7A = [F:WWW]WFREE7A
    [F:PJC]PSCFREEC7B = [F:WWW]WFREE7B
    [F:PJC]PSCFREEC8A = [F:WWW]WFREE8A
    [F:PJC]PSCFREEC8B = [F:WWW]WFREE8B
    [F:PJC]PSCFREEC9A = [F:WWW]WFREE9A
    [F:PJC]PSCFREEC9B = [F:WWW]WFREE9B
    [F:PJC]PSCFREEC10A = [F:WWW]WFREE10A
    [F:PJC]PSCFREEC10B = [F:WWW]WFREE10B
    # ---------------------------------
    #[F:PJC]PBUPAE = func PJMBUD_CSTD_PROGS.GET_APARENT(this.OPPNUM, SPBUCOD)  # Issue X3-46735 - 2017-06-28 by FGR
    [F:PJC]PBUPAE = func PJMBUD_CSTD_PROGS.GET_APARENT(SOPPNUM, SPBUCOD)       # Issue X3-46735 - 2017-06-28 by FGR
    # ---------------------------------
    Gosub SET_PJC_PSCPCTMBUD6_PSCPCTMTOT6 From TECFINOVE_CSTD_PROGS
    # ---------------------------------
    [F:PJC]PSCSSS   = this.SESSION
    this.TECPSCSEQ += 1
    [F:PJC]PSCSEQ   = this.TECPSCSEQ
    # ---------------------------------
    Write [PJC]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSC_EXECUTE", mess(352,2260,1) - "PJMSC", [V]CST_AERROR)
      Break
    Endif
    # ---------------------------------
  Next
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_EXECUTE : End this.TECPSCSEQ :" - num$(this.TECPSCSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_EXECUTE : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_PROV
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

Local Char REQ(255)(4)
Local Integer ISTAT
Local Integer ISEQ
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------------------------------
  If this.OPPPROACTIV <> [V]CST_AYES Then
    Return
  Endif
  # -------------------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_PROV : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # -------------------------------------------
  Local File PJMSC [PJC]
  Local File PJMSC [PJCU]
  Local File PJMCOSTCTR [PJCC]
  Local File ATABDIV [ADI]
  # -------------------------------------------
  #[L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_PROV_SQL(REQ, SPBUCOD)                  # Issue X3-46735 - 2017-06-28 by FGR
  [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_PROV_SQL(REQ, SOPPNUM, SPBUCOD)          # Issue X3-46735 - 2017-06-28 by FGR
  # -------------------------------------------
  For (Char WPCCCOD(GLONPJCC), Char WPCCCOD2(GLONPJCC), Decimal WPCCPRCT, Decimal WPROVAMT, Decimal WPROVAMTEST, Date WDATBUD, Char CUR(GLONCUR))
&      From fmet this.SQL_GET_TYPDBA() Sql REQ As [WWW]
    # ---------------------------------
    Raz [F:PJC]
    #[F:PJC]OPPNUM = this.OPPNUM                                                         # Issue X3-46735 - 2017-06-28 by FGR
    [F:PJC]OPPNUM = SOPPNUM                                                              # Issue X3-46735 - 2017-06-28 by FGR
    [F:PJC]PBUCOD = SPBUCOD
    [F:PJC]PBUSOR = func PJMBUD_CSTD_PROGS.GET_PBUSOR([F:PJC]OPPNUM, [F:PJC]PBUCOD)      # Issue X3-91329 - 2018-06-01 by FGR
    [F:PJC]PSCIMG = this.AIMG
    [F:PJC]PCCCOD = [F:WWW]WPCCCOD2
    [F:PJC]PSCU   = this.UOM # Issue X3-46735 - 2017-06-28 by FGR
    Gosub GET_PJC_PCCGRP_PCCGRPSOR From TECFINOVE_CSTD_PROGS
    # ---------------------------------
    Call CONVERT(this.ACTX, [F:WWW]CUR, this.CUR, this.CPYCUR, this.CHGTYP, [F:WWW]WDATBUD, [F:WWW]WPROVAMT, [F:PJC]PSCBUDAMT, ISTAT) From TRTDEV_SYRA
    Call CONVERT(this.ACTX, [F:WWW]CUR, this.CUR, this.CPYCUR, this.CHGTYP, [F:WWW]WDATBUD, [F:WWW]WPROVAMTEST, [F:PJC]PSCESTTOTAMT, ISTAT) From TRTDEV_SYRA
    # ---------------------------------
    #ISEQ = fmet this._EXIST_PCCCOD(SPBUCOD, [F:PJC]PCCCOD)                              # Issue X3-46735 - 2017-06-28 by FGR
    ISEQ = fmet this._EXIST_PCCCOD(SOPPNUM, SPBUCOD, [F:PJC]PCCCOD)                      # Issue X3-46735 - 2017-06-28 by FGR
    If ISEQ > 0 Then
      Update [PJCU]
&     Where [F:PJCU]PSCSSS = this.SESSION and [F:PJCU]PSCSEQ = ISEQ
&     With [F:PJCU]PSCBUDAMT += [F:PJC]PSCBUDAMT, [F:PJCU]PSCESTTOTAMT += [F:PJC]PSCESTTOTAMT
    Else
      # ---------------------------------
      [F:PJC]PSCSSS   = this.SESSION
      this.TECPSCSEQ += 1
      [F:PJC]PSCSEQ   = this.TECPSCSEQ
      # ---------------------------------
      Write [PJC]
      If fstat <> 0 Then
        [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSC_PROV", mess(352,2260,1) - "PJMSC", [V]CST_AERROR)
        Break
      Endif
    Endif
    # ---------------------------------
  Next
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_PROV : End this.TECPSCSEQ :" - num$(this.TECPSCSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_PROV : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_PROV_SQL
#Variable Char SREQ ()(0..)
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  Raz SREQ
  SREQ(0)  = "SELECT PCC.PCCCOD_0, PCC.PCCCOD2_0"
  SREQ(0) += ",PCC.PCCPRCT_0"
  SREQ(1) += ",LIG.PLBAMT_0*PCC.PCCPRCT_0/100 "
  SREQ(1) += ",LIG.PLBAMTEST_0*PCC.PCCPRCT_0/100, LIG.PLBDATBUD_0, LIG.CUR_0 "
  SREQ(2)  = " From PJMCOSTCTR PCC,PJMBUDLIG LIG "
  SREQ(2) += " Where PCC.PCCCOD2_0<>' ' and PCC.PCCCOD_0=LIG.PCCCOD_0  "
  #SREQ(3)  = " and LIG.OPPNUM_0='" + this.OPPNUM + "' and LIG.PBUCOD_0='" + SPBUCOD + "' "        # Issue X3-46735 - 2017-06-28 by FGR
  SREQ(3)  = " and LIG.OPPNUM_0='" + SOPPNUM + "' and LIG.PBUCOD_0='" + SPBUCOD + "' "             # Issue X3-46735 - 2017-06-28 by FGR
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_QTYAMT
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

Local Char REQ(255)(4)
Local Integer ISTAT
Local Integer ISEQ
Local Integer ITIME
Local Integer IRET

Local Decimal NPSCBUDQTY
Local Decimal NPSCBUDAMT
Local Decimal NPSCESTTOTQTY
Local Decimal NPSCESTTOTAMT
Local Char UOMTOUSE(GLONUOM)

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_QTYAMT : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # -------------------------------------------
  Local File PJMSC [PJC]
  Local File PJMCOSTCTR [PJCC]
  Local File ATABDIV [ADI]
  # -------------------------------------------
  #[L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_QTYAMT_SQL(REQ, SPBUCOD)                # Issue X3-46735 - 2017-06-28 by FGR
  [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSC_QTYAMT_SQL(REQ, SOPPNUM, SPBUCOD)        # Issue X3-46735 - 2017-06-28 by FGR
  # -------------------------------------------
#  For (Char WPCCCOD(GLONPJCC), Decimal WPLBQTY,    Decimal WPLBAMT, Decimal WPLBQTYEST, Decimal WPLBAMTEST,
#&      Date WDATBUD,           Char WUNIT(GLONUOM)
#&     )
#&     From fmet this.SQL_GET_TYPDBA() Sql REQ As [WWW]
  For (Char WPCCCOD(GLONPJCC), Decimal WPLBQTY,     Decimal WPLBAMT, Decimal WPLBQTYEST, Decimal WPLBAMTEST,
&      Date WDATBUD,           Char WUNIT(GLONUOM), Char CUR(GLONCUR)
&     )
&     From fmet this.SQL_GET_TYPDBA() Sql REQ As [WWW]                                   # Issue X3-46735 - 2017-06-28 by FGR
    # ---------------------------------
    Raz [F:PJC]
    #[F:PJC]OPPNUM       = this.OPPNUM                                                   # Issue X3-46735 - 2017-06-28 by FGR
    [F:PJC]OPPNUM       = SOPPNUM                                                        # Issue X3-46735 - 2017-06-28 by FGR
    [F:PJC]PBUCOD       = SPBUCOD
    [F:PJC]PBUSOR       = func PJMBUD_CSTD_PROGS.GET_PBUSOR(SOPPNUM, SPBUCOD)            # Issue X3-91329 - 2018-06-01 by FGR
    [F:PJC]PCCCOD       = [F:WWW]WPCCCOD
    Gosub GET_PJC_PCCGRP_PCCGRPSOR From TECFINOVE_CSTD_PROGS
    # ---------------------------------
    [F:PJC]PSCBUDQTY    = [F:WWW]WPLBQTY
    [F:PJC]PSCESTTOTQTY = [F:WWW]WPLBQTYEST
    # Issue X3-46735 - 2017-06-28 by FGR : BEGIN
    #[F:PJC]PSCU         = [F:WWW]WUNIT
    If [F:WWW]WUNIT <> AVOID.ACHAR Then
      [F:PJC]PSCU         = [F:WWW]WUNIT
    Else
      [F:PJC]PSCU         = this.UOM
    Endif
    # Issue X3-46735 - 2017-06-28 by FGR : END
    # ---------------------------------
    #Call CONVERT(this.ACTX, [F:WWW]CUR, this.CPYCUR, this.CPYCUR, this.CHGTYP, [F:WWW]WDATBUD, [F:WWW]WPLBAMT, [F:PJC]PSCBUDAMT, ISTAT) From TRTDEV_SYRA       # Issue X3-46735 - 2017-06-28 by FGR
    #Call CONVERT(this.ACTX, [F:WWW]CUR, this.CPYCUR, this.CPYCUR, this.CHGTYP, [F:WWW]WDATBUD, [F:WWW]WPLBAMTEST, [F:PJC]PSCESTTOTAMT, ISTAT) From TRTDEV_SYRA # Issue X3-46735 - 2017-06-28 by FGR
    Call CONVERT(this.ACTX, this.CPYCUR, this.CUR, this.CPYCUR, this.CHGTYP, [F:WWW]WDATBUD, [F:WWW]WPLBAMT, [F:PJC]PSCBUDAMT, ISTAT) From TRTDEV_SYRA          # Issue X3-70668 - 2018-01-30 by FGR
    Call CONVERT(this.ACTX, this.CPYCUR, this.CUR, this.CPYCUR, this.CHGTYP, [F:WWW]WDATBUD, [F:WWW]WPLBAMTEST, [F:PJC]PSCESTTOTAMT, ISTAT) From TRTDEV_SYRA    # Issue X3-70668 - 2018-01-30 by FGR
    # ---------------------------------
    #UOMTOUSE = fmet this._GET_BUDLIG_PLBU([F:PJC]PBUCOD, [F:PJC]PCCCOD)                 # Issue X3-46735 - 2017-06-28 by FGR
    UOMTOUSE = fmet this._GET_BUDLIG_PLBU([F:PJC]OPPNUM, [F:PJC]PBUCOD, [F:PJC]PCCCOD)   # Issue X3-46735 - 2017-06-28 by FGR
    If [F:WWW]WUNIT <> UOMTOUSE Then
      Call CONVERT_QTY(this.ACTX, [F:WWW]WUNIT, UOMTOUSE, [F:PJC]PSCBUDQTY) From TRTX3_SYRA
      Call CONVERT_QTY(this.ACTX, [F:WWW]WUNIT, UOMTOUSE, [F:PJC]PSCESTTOTQTY) From TRTX3_SYRA
    Endif
    # ---------------------------------
    NPSCBUDQTY = [F:PJC]PSCBUDQTY
    NPSCBUDAMT = [F:PJC]PSCBUDAMT
    NPSCESTTOTQTY = [F:PJC]PSCESTTOTQTY
    NPSCESTTOTAMT = [F:PJC]PSCESTTOTAMT
    # ---------------------------------
    #ISEQ = fmet this._EXIST_PCCCOD(SPBUCOD, [F:PJC]PCCCOD)                              # Issue X3-46735 - 2017-06-28 by FGR
    ISEQ = fmet this._EXIST_PCCCOD(SOPPNUM, SPBUCOD, [F:PJC]PCCCOD)                      # Issue X3-46735 - 2017-06-28 by FGR
    If ISEQ > 0 Then
      Update [PJC]
&     Where [F:PJC]PSCSSS = this.SESSION and PSCSEQ = ISEQ
&     With [F:PJC]PSCBUDQTY += NPSCBUDQTY,
&          [F:PJC]PSCBUDAMT += NPSCBUDAMT,
&          [F:PJC]PSCESTTOTQTY += NPSCESTTOTQTY,
&          [F:PJC]PSCESTTOTAMT += NPSCESTTOTAMT
    Else
      # ---------------------------------
      #[F:PJC]PBUPAE = func PJMBUD_CSTD_PROGS.GET_APARENT(this.OPPNUM, SPBUCOD)          # Issue X3-46735 - 2017-06-28 by FGR
      [F:PJC]PBUPAE = func PJMBUD_CSTD_PROGS.GET_APARENT(SOPPNUM, SPBUCOD)               # Issue X3-46735 - 2017-06-28 by FGR
      # ---------------------------------
      [F:PJC]PSCSSS   = this.SESSION
      this.TECPSCSEQ += 1
      [F:PJC]PSCSEQ   = this.TECPSCSEQ
      # ---------------------------------
      Write [PJC]
      If fstat <> 0 Then
        [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSC_QTYAMT", mess(352,2260,1) - "PJMSC", [V]CST_AERROR)
        Break
      Endif
    Endif
  Next
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_QTYAMT : End this.TECPSCSEQ :" - num$(this.TECPSCSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_QTYAMT : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_QTYAMT_SQL
#Variable Char SREQ ()(0..)
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  Raz SREQ
  SREQ(0)  = "SELECT PCCCOD_0 "
  SREQ(0) += ",sum(PLBQTY_0),sum(PLBAMT_0),sum(PLBQTYEST_0),sum(PLBAMTEST_0),max(PLBDATBUD_0) "
  #SREQ(1)  = ",max(PLBU_0) From PJMBUDLIG "                                                                 # Issue X3-46735 - 2017-06-28 by FGR
  #SREQ(2)  = " Where OPPNUM_0='" + this.OPPNUM + "' and PBUCOD_0='" + SPBUCOD + "' group by PCCCOD_0"       # Issue X3-46735 - 2017-06-28 by FGR
  SREQ(1)  = ",max(PLBU_0), CUR_0 From PJMBUDLIG "                                                           # Issue X3-46735 - 2017-06-28 by FGR
  SREQ(2)  = " Where OPPNUM_0='" + SOPPNUM + "' and PBUCOD_0='" + SPBUCOD + "' group by PCCCOD_0, CUR_0"     # Issue X3-46735 - 2017-06-28 by FGR
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_SUM_TOTAUX
#Value Char SOPPNUM ()       # Issue X3-46735 - 2017-06-28 by FGR
#Value Char SPBUCOD ()
#Local Integer ARET_VALUE

Local Decimal WPSCAMT
Local Decimal WPSCQTY
Local Decimal WBUDAMT
Local Integer ITIME
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_SUM_TOTAUX : Time begin :" - num$(ITIME) - "SPBUCOD=" + SPBUCOD, [V]CST_AINFO)
  Endif
  # ---------------------------------
  Local File PJMSC [PJC]
  Local File PJMSC [PJCU]
  # ---------------------------------
  #Filter [PJC] Where PBUCOD = SPBUCOD and PSCSSS = this.SESSION and PSCIMG = this.AIMG                      # Issue X3-46735 - 2017-06-28 by FGR
  Filter [PJC] Where OPPNUM = SOPPNUM and PBUCOD = SPBUCOD and PSCSSS = this.SESSION and PSCIMG = this.AIMG  # Issue X3-46735 - 2017-06-28 by FGR
  For [PJC]
    Raz [F:PJCU]
    #--------- encours get -----------------------------
    [F:PJCU] = [F:PJC]
    #-----------------------
    WBUDAMT = [F:PJC]PSCBUDAMT
    #--------------------------- sum set ---------------------------------------------
    WPSCQTY = [F:PJC]PSCQTY1 + [F:PJC]PSCQTY2 + [F:PJC]PSCQTY3 + [F:PJC]PSCQTY4 + [F:PJC]PSCQTY5
    WPSCAMT = [F:PJC]PSCAMT1 + [F:PJC]PSCAMT2 + [F:PJC]PSCAMT3 + [F:PJC]PSCAMT4 + [F:PJC]PSCAMT5
    #--- quantite totale set for update ---------------
    If [F:PJC]PSCESTTOTQTY <> 0 Then
      If [F:PJC]PSCESTTOTQTY >= WPSCQTY Then
        [F:PJCU]PSCTOTQTY = [F:PJC]PSCESTTOTQTY
      Else
        [F:PJCU]PSCTOTQTY = WPSCQTY
      Endif
    Else
      [F:PJCU]PSCTOTQTY = WPSCQTY
    Endif
    #---amount, montant total set for update -----------------
    If [F:PJC]PSCESTTOTAMT <> 0 Then
      If [F:PJC]PSCESTTOTAMT >= WPSCAMT Then
        [F:PJCU]PSCTOTAMT = [F:PJC]PSCESTTOTAMT
      Else
        [F:PJCU]PSCTOTAMT = WPSCAMT
      Endif
    Else
      [F:PJCU]PSCTOTAMT = WPSCAMT
    Endif
    # --------------------------------------------------
    #--- quantite reste totale set for update ----------
    # --------------------------------------------------
    [F:PJCU]PSCREMQTY = [F:PJCU]PSCTOTQTY - WPSCQTY
    #--- zero si negatif
    If [F:PJCU]PSCREMQTY < 0 Then
      [F:PJCU]PSCREMQTY = 0
    Endif
    # --------------------------------------------------
    #--- montant reste totale set for update -----------
    # --------------------------------------------------
    [F:PJCU]PSCREMAMT = [F:PJCU]PSCTOTAMT - WPSCAMT
    #--- zero si negatif
    If [F:PJCU]PSCREMAMT < 0 Then
      [F:PJCU]PSCREMAMT = 0
    Endif
    # --------------------------------------------------
    #-- Quantite marge totale
    [F:PJCU]PSCMARGQTY = [F:PJC]PSCBUDQTY - [F:PJCU]PSCTOTQTY
    #-- Montant marge totale
    [F:PJCU]PSCMARGAMT = WBUDAMT - [F:PJCU]PSCTOTAMT
    #-- % Marge sur qty
    If [F:PJC]PSCBUDQTY <> 0 Then
      [F:PJCU]PSCPCTMQTY = ar2(([F:PJCU]PSCMARGQTY * 100) / [F:PJC]PSCBUDQTY)
    Endif
    #-- % Marge sur montant
    If WBUDAMT <> 0 Then
      [F:PJCU]PSCPCTMAMT = ar2(([F:PJCU]PSCMARGAMT * 100) / WBUDAMT)
    Endif
    # --------------------------------------------------
    Update [PJC]
&   Where PSCSSS = this.SESSION and PSCSEQ = [F:PJCU]PSCSEQ
&   With PSCTOTQTY  = [F:PJCU]PSCTOTQTY,                     PSCTOTAMT = [F:PJCU]PSCTOTAMT,
&        PSCREMQTY  = [F:PJCU]PSCREMQTY,                     PSCREMAMT = [F:PJCU]PSCREMAMT,
&        PSCMARGQTY = [F:PJCU]PSCMARGQTY,                    PSCMARGAMT = [F:PJCU]PSCMARGAMT,
&        PSCPCTMQTY = [F:PJCU]PSCPCTMQTY,                    PSCPCTMAMT = [F:PJCU]PSCPCTMAMT,
&        PSCWIPQTY  = [F:PJCU]PSCBUDQTY - [F:PJCU]PSCWIPQTY,
&        PSCWIPAMT  = [F:PJCU]PSCBUDAMT - [F:PJCU]PSCWIPAMT
#&        PSCWIPQTY  = [F:PJCU]PSCWIPQTY + [F:PJCU]PSCREMQTY,  # Issue X3-55055 - 2017-12-07 by FGR
#&        PSCWIPAMT  = [F:PJCU]PSCWIPAMT + [F:PJCU]PSCREMAMT   # Issue X3-55055 - 2017-12-07 by FGR
    # --------------------------------------------------
  Next
  Filter [PJC]
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_SUM_TOTAUX : End this.TECPSCSEQ :" - num$(this.TECPSCSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_SUM_TOTAUX : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_RATIO
#Local Integer ARET_VALUE

Local Integer ITIME
Local Char TBPBUCOD(GLONPBU)(1..)

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_RATIO : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  Local File PJMSC [PJC]
  # ---------------------------
  Filter [PJC] Where [F:PJC]PSCSSS = this.SESSION and [F:PJC]PSCFREEC6B <> 0 and ([F:PJC]PSCBUDAMT <> 0 or [F:PJC]PSCTOTAMT <> 0)
  For [PJC]
    # ---------------------------
    If [F:PJC]PSCFREEC6B <> 0 and [F:PJC]PSCBUDAMT <> 0 Then
      [F:PJC]PSCMARGBUD6 = [F:PJC]PSCFREEC6B - [F:PJC]PSCBUDAMT
    Endif
    If [F:PJC]PSCFREEC6B <> 0 and [F:PJC]PSCTOTAMT <> 0 Then
      [F:PJC]PSCMARGTOT6 = [F:PJC]PSCFREEC6B - [F:PJC]PSCTOTAMT
    Endif
    Gosub SET_PJC_PSCPCTMBUD6_PSCPCTMTOT6 From TECFINOVE_CSTD_PROGS
    # ---------------------------
    Rewrite [PJC]
  Next
  Filter [PJC]
  # ---------------------------
  If this.PBUCOD <> AVOID.ACHAR Then
    # ---------------------------
    #IRET = fmet this.PROJECT.PJM(1).BUD_GET_FAMILY(this.PBUCOD, TBPBUCOD)                         # Issue X3-46735 - 2017-06-28 by FGR
    IRET = func PJMBUD_CSTD_PROGS.GET_FAMILY(this.OPPNUM, this.PBUCOD, TBPBUCOD)                   # Issue X3-46735 - 2017-06-28 by FGR
    # Issue X3-46735 - 2017-06-28 by FGR : BEGIN
    # TODO : FGR To confirm that
    #Delete [PJC] Where [F:PJC]PSCSSS = this.SESSION and (find([F:PJC]PBUCOD,TBPBUCOD)=0 and not ([F:PJC]PBUCOD = AVOID.ACHAR and [F:PJC]PCCCOD = AVOID.ACHAR))
    Delete [PJC] Where [F:PJC]PSCSSS = this.SESSION and
&                      (([F:PJC]OPPNUM = this.OPPNUM and find([F:PJC]PBUCOD,TBPBUCOD)=0 and not ([F:PJC]PBUCOD = AVOID.ACHAR and [F:PJC]PCCCOD = AVOID.ACHAR)) or
&                      ([F:PJC]OPPNUM <> this.OPPNUM))
    # Issue X3-46735 - 2017-06-28 by FGR : END
    # ---------------------------
    # If the starting budget is a children, in this case it doesn't have a parent
    # Issue X3-46735 - 2017-06-28 by FGR : BEGIN
    # TODO : FGR To confirm that
    #Update [PJC] Where [F:PJC]PSCSSS = this.SESSION and PBUCOD = this.PBUCOD and PBUPAE <> AVOID.ACHAR With PBUPAE = AVOID.ACHAR
    Update [PJC] Where [F:PJC]PSCSSS = this.SESSION and [F:PJC]OPPNUM = this.OPPNUM and [F:PJC]PBUCOD = this.PBUCOD and [F:PJC]PBUPAE <> AVOID.ACHAR With PBUPAE = AVOID.ACHAR
    # Issue X3-46735 - 2017-06-28 by FGR : END
    # ---------------------------
  Endif
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_RATIO : End this.TECPSCSEQ :" - num$(this.TECPSCSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_RATIO : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------
Return

###################################################################################################
# Issue X3-46735 - 2017-06-28 by FGR : BEGIN
$_DATA_EXTRACT_PJMSC_CONSOLIDAT
#Local Integer ARET_VALUE

Local Integer ITIME
Local Integer IRET
Local Integer NI
Local Integer NE
Local Integer NZ
Local Integer INDEX
Local Char STPBUCOD(GLONPBU)(1..)
Local Char SREQ(255)(10)

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_CONSOLIDAT : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  Local File PJMSC [PJC]
  Local File PJMBUD [PJBU]
  # ---------------------------
  For NZ = 1 To maxtab(this.PRJLST)
    If this.PRJLST(NZ) <> null and find(this.PRJLST(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      Filter [PJBU] Where [F:PJBU]OPPNUM = this.PRJLST(NZ).OPPLST
      For [F:PJBU]
        If [F:PJBU]PBUPAE = AVOID.ACHAR Then
          [L]ARET_VALUE = func PJMBUD_CSTD_PROGS.GET_FAMILY([F:PJBU]OPPNUM, [F:PJBU]PBUCOD, STPBUCOD)
          If [L]ARET_VALUE <> [V]CST_AOK Then
            Break
          Endif
          # ----------------------------
          For NE = 1 To maxtab(STPBUCOD)
            If STPBUCOD(NE) <> AVOID.ACHAR Then
              If func PJMBUD_CSTD_PROGS.IS_PARENT(this.ACTX, [F:PJBU]OPPNUM, STPBUCOD(NE)) = [V]CST_ANO Then
                # This is not a parent budget : Sum PCCCOD<>"" on PCCCOD=""
                Raz SREQ
                SREQ(0)  = "SELECT sum(PSCQTY1_0),sum(PSCAMT1_0),sum(PSCQTY2_0),sum(PSCAMT2_0),sum(PSCQTY3_0),sum(PSCAMT3_0)"
                SREQ(0) += ",sum(PSCQTY4_0),sum(PSCAMT4_0),sum(PSCQTY5_0),sum(PSCAMT5_0)"
                SREQ(1)  = ",sum(PSCBUDQTY_0),sum(PSCBUDAMT_0),sum(PSCTOTQTY_0),sum(PSCTOTAMT_0),sum(PSCREMQTY_0),sum(PSCREMAMT_0)"
                SREQ(1) += ",sum(PSCMARGQTY_0),sum(PSCMARGAMT_0),sum(PSCPCTMQTY_0),sum(PSCPCTMAMT_0)"
                SREQ(2)  = ",sum(PSCESTTOTQTY_0),sum(PSCESTTOTAMT_0),sum(PSCWIPQTY_0),sum(PSCWIPAMT_0) "
                SREQ(2) += ",sum(PSCFREEC6A_0),sum(PSCFREEC6B_0),sum(PSCFREEC7A_0),sum(PSCFREEC7B_0) "
                SREQ(3)  = ",sum(PSCFREEC8A_0),sum(PSCFREEC8B_0),sum(PSCFREEC9A_0),sum(PSCFREEC9B_0) "
                SREQ(3) += ",sum(PSCFREEC10A_0),sum(PSCFREEC10B_0),sum(PSCMARGBUD6_0),sum(PSCMARGTOT6_0) "
                SREQ(4)  = " From PJMSC where PSCSSS_0=" + num$(this.SESSION)
                SREQ(5)  = " and OPPNUM_0='" + this.PRJLST(NZ).OPPLST + "'"
                SREQ(6)  = " and PBUCOD_0='" + STPBUCOD(NE) + "' and PCCCOD_0 <> ' '"
                # ----------------------------
                Raz [F:PJC]
                For (Decimal WQ1,   Decimal WA1,   Decimal WQ2,    Decimal WA2,    Decimal WQ3,    Decimal WA3,
&                    Decimal WQ4,   Decimal WA4,   Decimal WQ5,    Decimal WA5,    Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&                    Decimal WRQT,  Decimal WRAM,  Decimal WMQT,   Decimal WMAM,   Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&                    Decimal WIPQT, Decimal WIPAM, Decimal WC6QT,  Decimal WC6AM,  Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&                    Decimal WC9QT, Decimal WC9AM, Decimal WC10QT, Decimal WC10AM, Decimal WMBUD6, Decimal WTBUD6)
&               From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
                  # ----------------------------
                  [F:PJC]OPPNUM       = this.PRJLST(NZ).OPPLST
                  [F:PJC]PBUCOD       = STPBUCOD(NE)
                  [F:PJC]PBUSOR       = func PJMBUD_CSTD_PROGS.GET_PBUSOR([F:PJC]OPPNUM, [F:PJC]PBUCOD)  # Issue X3-91329 - 2018-06-01 by FGR
                  [F:PJC]PBUPAE       = func PJMBUD_CSTD_PROGS.GET_APARENT([F:PJBU]OPPNUM, STPBUCOD(NE))
                  [F:PJC]PSCU         = this.UOM # Issue X3-46735 - 2017-06-28 by FGR
                  # ----------------------------
                  Gosub SET_PJC_FROM_WWW From TECFINOVE_CSTD_PROGS
                Next
                # ----------------------------
                [F:PJC]PSCSSS   = this.SESSION
                this.TECPSCSEQ += 1
                [F:PJC]PSCSEQ   = this.TECPSCSEQ
                # ----------------------------
                Write [PJC]
                If fstat <> 0 Then
                  [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSC_CONSOLIDAT", mess(352,2260,1) - "PJMSC (a)", [V]CST_AERROR)
                  Break
                Endif
                # ----------------------------
              Endif
              # ----------------------------
              If func PJMBUD_CSTD_PROGS.IS_PARENT(this.ACTX, [F:PJBU]OPPNUM, STPBUCOD(NE)) = [V]CST_AYES Then
                Raz SREQ
                SREQ(0)  = "SELECT sum(PSCQTY1_0),sum(PSCAMT1_0),sum(PSCQTY2_0),sum(PSCAMT2_0),sum(PSCQTY3_0),sum(PSCAMT3_0)"
                SREQ(0) += ",sum(PSCQTY4_0),sum(PSCAMT4_0),sum(PSCQTY5_0),sum(PSCAMT5_0)"
                SREQ(1)  = ",sum(PSCBUDQTY_0),sum(PSCBUDAMT_0),sum(PSCTOTQTY_0),sum(PSCTOTAMT_0),sum(PSCREMQTY_0),sum(PSCREMAMT_0)"
                SREQ(1) += ",sum(PSCMARGQTY_0),sum(PSCMARGAMT_0),sum(PSCPCTMQTY_0),sum(PSCPCTMAMT_0)"
                SREQ(2)  = ",sum(PSCESTTOTQTY_0),sum(PSCESTTOTAMT_0),sum(PSCWIPQTY_0),sum(PSCWIPAMT_0) "
                SREQ(2) += ",sum(PSCFREEC6A_0),sum(PSCFREEC6B_0),sum(PSCFREEC7A_0),sum(PSCFREEC7B_0) "
                SREQ(3)  = ",sum(PSCFREEC8A_0),sum(PSCFREEC8B_0),sum(PSCFREEC9A_0),sum(PSCFREEC9B_0) "
                SREQ(3) += ",sum(PSCFREEC10A_0),sum(PSCFREEC10B_0),sum(PSCMARGBUD6_0),sum(PSCMARGTOT6_0) "
                SREQ(4)  = " From PJMSC where PSCSSS_0=" + num$(this.SESSION)
                SREQ(5)  = " and OPPNUM_0='" + this.PRJLST(NZ).OPPLST + "'"
                SREQ(6)  = " and ((PBUPAE_0='" + STPBUCOD(NE) + "' and PCCCOD_0 = ' ') or (PBUCOD_0='" + STPBUCOD(NE) + "' and PCCCOD_0 <> ' '))"
                # ----------------------------
                Raz [F:PJC]
                For (Decimal WQ1,   Decimal WA1,   Decimal WQ2,    Decimal WA2,    Decimal WQ3,    Decimal WA3,
&                    Decimal WQ4,   Decimal WA4,   Decimal WQ5,    Decimal WA5,    Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&                    Decimal WRQT,  Decimal WRAM,  Decimal WMQT,   Decimal WMAM,   Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&                    Decimal WIPQT, Decimal WIPAM, Decimal WC6QT,  Decimal WC6AM,  Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&                    Decimal WC9QT, Decimal WC9AM, Decimal WC10QT, Decimal WC10AM, Decimal WMBUD6, Decimal WTBUD6)
&               From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
                  # ----------------------------
                  [F:PJC]OPPNUM       = this.PRJLST(NZ).OPPLST
                  [F:PJC]PBUCOD       = STPBUCOD(NE)
                  [F:PJC]PBUSOR       = func PJMBUD_CSTD_PROGS.GET_PBUSOR([F:PJC]OPPNUM, [F:PJC]PBUCOD)      # Issue X3-91329 - 2018-06-01 by FGR
                  [F:PJC]PBUPAE       = func PJMBUD_CSTD_PROGS.GET_APARENT([F:PJBU]OPPNUM, STPBUCOD(NE))
                  [F:PJC]PSCU         = this.UOM # Issue X3-46735 - 2017-06-28 by FGR
                  # ----------------------------
                  Gosub SET_PJC_FROM_WWW From TECFINOVE_CSTD_PROGS
                Next
                # ----------------------------
                [F:PJC]PSCSSS   = this.SESSION
                this.TECPSCSEQ += 1
                [F:PJC]PSCSEQ   = this.TECPSCSEQ
                # ----------------------------
                Write [PJC]
                If fstat <> 0 Then
                  [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSC_CONSOLIDAT", mess(352,2260,1) - "PJMSC (b)", [V]CST_AERROR)
                  Break
                Endif
              Endif
            Endif
          Next NE
          # ----------------------------
          If [L]ARET_VALUE <> [V]CST_AOK Then
            Break
          Endif
        Endif
        If [L]ARET_VALUE <> [V]CST_AOK Then
          Break
        Endif
      Next
      Filter [PJBU]
      # ---------------------------------
      If [L]ARET_VALUE = [V]CST_AOK Then
        Raz SREQ
        SREQ(0)  = "SELECT sum(PSCQTY1_0),sum(PSCAMT1_0),sum(PSCQTY2_0),sum(PSCAMT2_0),sum(PSCQTY3_0),sum(PSCAMT3_0)"
        SREQ(0) += ",sum(PSCQTY4_0),sum(PSCAMT4_0),sum(PSCQTY5_0),sum(PSCAMT5_0)"
        SREQ(1)  = ",sum(PSCBUDQTY_0),sum(PSCBUDAMT_0),sum(PSCTOTQTY_0),sum(PSCTOTAMT_0),sum(PSCREMQTY_0),sum(PSCREMAMT_0)"
        SREQ(1) += ",sum(PSCMARGQTY_0),sum(PSCMARGAMT_0),sum(PSCPCTMQTY_0),sum(PSCPCTMAMT_0)"
        SREQ(2)  = ",sum(PSCESTTOTQTY_0),sum(PSCESTTOTAMT_0),sum(PSCWIPQTY_0),sum(PSCWIPAMT_0) "
        SREQ(2) += ",sum(PSCFREEC6A_0),sum(PSCFREEC6B_0),sum(PSCFREEC7A_0),sum(PSCFREEC7B_0) "
        SREQ(3)  = ",sum(PSCFREEC8A_0),sum(PSCFREEC8B_0),sum(PSCFREEC9A_0),sum(PSCFREEC9B_0) "
        SREQ(3) += ",sum(PSCFREEC10A_0),sum(PSCFREEC10B_0),sum(PSCMARGBUD6_0),sum(PSCMARGTOT6_0) "
        SREQ(4)  = " From PJMSC where PSCSSS_0=" + num$(this.SESSION)
        SREQ(5)  = " and OPPNUM_0='" + this.PRJLST(NZ).OPPLST + "'"
        SREQ(6)  = " and PBUPAE_0 = ' ' and PBUCOD_0 <> ' ' and (PCCCOD_0 = ' ' or PBUCOD_0 = '<Empty>')"
        # ----------------------------
        Raz [F:PJC]
        For (Decimal WQ1,   Decimal WA1,   Decimal WQ2,    Decimal WA2,    Decimal WQ3,    Decimal WA3,
&            Decimal WQ4,   Decimal WA4,   Decimal WQ5,    Decimal WA5,    Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&            Decimal WRQT,  Decimal WRAM,  Decimal WMQT,   Decimal WMAM,   Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&            Decimal WIPQT, Decimal WIPAM, Decimal WC6QT,  Decimal WC6AM,  Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&            Decimal WC9QT, Decimal WC9AM, Decimal WC10QT, Decimal WC10AM, Decimal WMBUD6, Decimal WTBUD6)
&       From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
          # ----------------------------
          [F:PJC]OPPNUM       = this.PRJLST(NZ).OPPLST
          [F:PJC]PBUCOD       = AVOID.ACHAR
          [F:PJC]PBUPAE       = AVOID.ACHAR
          [F:PJC]PSCU         = this.UOM # Issue X3-46735 - 2017-06-28 by FGR
          # ----------------------------
          Gosub SET_PJC_FROM_WWW From TECFINOVE_CSTD_PROGS
        Next
        # ----------------------------
        [F:PJC]PSCSSS   = this.SESSION
        this.TECPSCSEQ += 1
        [F:PJC]PSCSEQ   = this.TECPSCSEQ
        # ----------------------------
        Write [PJC]
        If fstat <> 0 Then
          [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSC_CONSOLIDAT", mess(352,2260,1) - "PJMSC (c)", [V]CST_AERROR)
        Endif
        # ----------------------------
      Endif
    Endif
  Next NZ
  # ---------------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_CONSOLIDAT : End this.TECPSCSEQ :" - num$(this.TECPSCSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_CONSOLIDAT : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
  # ---------------------------------
Return

###################################################################################################
$_DATA_EXTRACT_PJMSC_MULPRJ
#Local Integer ARET_VALUE

Local Integer ITIME
Local Char SREQ(255)(20)

  # Issue X3-46735 - 2017-06-28 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_MULPRJ : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  If this.MULPRJ = [V]CST_AYES Then
    # Agregate at cost types level without project
    Local File PJMSC [PJC]
    # ---------------------------
    Raz SREQ
    SREQ(0)  = "SELECT sum(PSCQTY1_0),sum(PSCAMT1_0),sum(PSCQTY2_0),sum(PSCAMT2_0),sum(PSCQTY3_0),sum(PSCAMT3_0)"
    SREQ(0) += ",sum(PSCQTY4_0),sum(PSCAMT4_0),sum(PSCQTY5_0),sum(PSCAMT5_0)"
    SREQ(1)  = ",sum(PSCBUDQTY_0),sum(PSCBUDAMT_0),sum(PSCTOTQTY_0),sum(PSCTOTAMT_0),sum(PSCREMQTY_0),sum(PSCREMAMT_0)"
    SREQ(1) += ",sum(PSCMARGQTY_0),sum(PSCMARGAMT_0),sum(PSCPCTMQTY_0),sum(PSCPCTMAMT_0)"
    SREQ(2)  = ",sum(PSCESTTOTQTY_0),sum(PSCESTTOTAMT_0),sum(PSCWIPQTY_0),sum(PSCWIPAMT_0) "
    SREQ(2) += ",sum(PSCFREEC6A_0),sum(PSCFREEC6B_0),sum(PSCFREEC7A_0),sum(PSCFREEC7B_0) "
    SREQ(3)  = ",sum(PSCFREEC8A_0),sum(PSCFREEC8B_0),sum(PSCFREEC9A_0),sum(PSCFREEC9B_0) "
    SREQ(3) += ",sum(PSCFREEC10A_0),sum(PSCFREEC10B_0),sum(PSCMARGBUD6_0),sum(PSCMARGTOT6_0) "
    SREQ(4)  = " From PJMSC where PSCSSS_0=" + num$(this.SESSION)
    SREQ(5)  = " and OPPNUM_0 <> ' '"
    SREQ(6)  = " and PBUPAE_0 = ' ' and PBUCOD_0 = ' '"
    # ----------------------------
    For (Decimal WQ1,   Decimal WA1,   Decimal WQ2,    Decimal WA2,    Decimal WQ3,    Decimal WA3,
&        Decimal WQ4,   Decimal WA4,   Decimal WQ5,    Decimal WA5,    Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&        Decimal WRQT,  Decimal WRAM,  Decimal WMQT,   Decimal WMAM,   Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&        Decimal WIPQT, Decimal WIPAM, Decimal WC6QT,  Decimal WC6AM,  Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&        Decimal WC9QT, Decimal WC9AM, Decimal WC10QT, Decimal WC10AM, Decimal WMBUD6, Decimal WTBUD6)
&   From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
      Raz [F:PJC]
      [F:PJC]PSCU       = this.UOM
      Gosub SET_PJC_FROM_WWW From TECFINOVE_CSTD_PROGS
      # ----------------------------
      [F:PJC]PSCSSS   = this.SESSION
      this.TECPSCSEQ += 1
      [F:PJC]PSCSEQ   = this.TECPSCSEQ
      # ----------------------------
      Write [PJC]
      If fstat <> 0 Then
        [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSC_CONSOLIDAT", mess(352,2260,1) - "PJMSC (c)", [V]CST_AERROR)
      Endif
    Next
  Endif
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_MULPRJ : End this.TECPSCSEQ :" - num$(this.TECPSCSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSC_MULPRJ : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
Return

###################################################################################################
# Issue X3-46735 - 2017-06-28 by FGR : BEGIN
$_DATA_EXTRACT_PJMSCCT
#Local Integer ARET_VALUE

Local Char SPBUCOD(GLONPBU)
Local Char SREQ(255)(20)
Local Integer IREQ
Local Integer ISEQSTART
Local Integer IINTOLOOP
Local Integer ITREEBDG
Local Integer ILINE
Local Char STPBUCOD(GLONPBU)(1..)
Local Integer NI
Local Integer NLOOP
Local Integer ISEQSTART0
Local Integer ISEQSTART1
Local Integer ISEQSTART2

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    ITIME = time
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : Time begin :" - num$(ITIME), [V]CST_AINFO)
  Endif
  # ---------------------------
  Local File PJMSC [PJC]
  Local File PJMSCCT [PJCCT]
  Local File PJMSCCT [PJCCTW]
  Local File PJMSCCT [PJCCTX]
  # ---------------------------
  # 1°) Get the original values on which level they are
  Filter [PJC] Where [F:PJC]PSCSSS = this.SESSION and [F:PJC]OPPNUM <> ""
&                and ([F:PJC]PCCCOD <> "" or ([F:PJC]PCCCOD = "" and [F:PJC]PBUCOD = "" and [F:PJC]PCCGRP = ""))
&              Order By [F:PJC]OPPNUM
  For [PJC]
    Raz [F:PJCCT]
    [F:PJCCT] = [F:PJC]
    # ---------------------------
    Raz [F:PJCCT]CREUSR
    Raz [F:PJCCT]UPDUSR
    Raz [F:PJCCT]AUUID
    Raz [F:PJCCT]UPDDATTIM
    Raz [F:PJCCT]CREDATTIM
    # ---------------------------
    [F:PJCCT]PSCSSS   = this.SESSION
    this.TECPSCCTSEQ += 1
    [F:PJCCT]PSCSEQ   = this.TECPSCCTSEQ
    # ---------------------------
    Write [PJCCT]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSCCT", mess(352,2260,1) - "PJMSCCT", [V]CST_AERROR)
      Break
    Endif
    # ---------------------------
  Next
  Filter [PJC]
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : End step 1 this.TECPSCCTSEQ :" - num$(this.TECPSCCTSEQ), [V]CST_AINFO)
  Endif
  # ---------------------------
  # 2°) Agregate values on the parents levels
  For NI = 1 To maxtab(this.PRJLST)
    If this.PRJLST(NI) <> null and find(this.PRJLST(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ISEQSTART = 1
      Repeat
        If this.CRELOGFILE = [V]CST_AYES Then
          IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : this.PRJLST(NI).OPPLST=" + this.PRJLST(NI).OPPLST -
&                                           "this.TECPSCCTSEQ :" - num$(this.TECPSCCTSEQ) -
&                                           "ISEQSTART :" - num$(ISEQSTART) - string$(10, "-")
&                                           , [V]CST_AINFO)
        Endif
        IINTOLOOP = [V]CST_ANO
        Filter [PJCCT] Where [F:PJCCT]PSCSSS = this.SESSION and [F:PJCCT]PSCSEQ >= ISEQSTART and
&                            [F:PJCCT]PBUPAE <> "" and [F:PJCCT]OPPNUM = this.PRJLST(NI).OPPLST
        For [PJCCT]
          # Issue X3-55055 - 2017-12-07 by FGR : BEGIN was missing
          If IINTOLOOP = [V]CST_ANO Then
            IINTOLOOP = [V]CST_AYES
            ISEQSTART = this.TECPSCCTSEQ + 1
          Endif
          # Issue X3-55055 - 2017-12-07 by FGR : END
          Raz [F:PJCCTW]
          [F:PJCCTW] = [F:PJCCT]
          [F:PJCCTW]PBUCOD = [F:PJCCT]PBUPAE
          [F:PJCCTW]PBUPAE = func PJMBUD_CSTD_PROGS.GET_APARENT([F:PJCCTW]OPPNUM, [F:PJCCTW]PBUCOD)
          # ---------------------------
          IPJCCTX_FOUND = [V]CST_ANO
          Filter [PJCCTX] Where [F:PJCCTX]PSCSSS = this.SESSION and
&                               [F:PJCCTX]OPPNUM = [F:PJCCTW]OPPNUM and [F:PJCCTX]PBUCOD = [F:PJCCTW]PBUCOD and
&                               [F:PJCCTX]PCCCOD = [F:PJCCTW]PCCCOD
          For [PJCCTX]
            IPJCCTX_FOUND = [V]CST_AYES
            Gosub SUM_PJCCTX_WITH_PJCCTW From TECFINOVE_CSTD_PROGS
            Rewrite [F:PJCCTX]
            If fstat <> 0 Then
              [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSCCT", mess(352,2260,1) - "PJMSCCT(X)", [V]CST_AERROR)
              Break
            Endif
            Break
          Next
          Filter [PJCCTX]
          # ---------------------------
          If IPJCCTX_FOUND = [V]CST_ANO Then
            Gosub RAZ_PJCCTW_TECH_PROP From TECFINOVE_CSTD_PROGS
            # ---------------------------
            [F:PJCCTW]PSCSSS   = this.SESSION
            this.TECPSCCTSEQ  += 1
            [F:PJCCTW]PSCSEQ   = this.TECPSCCTSEQ
            # ---------------------------
            Write [F:PJCCTW]
            If fstat <> 0 Then
              [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSCCT", mess(352,2260,1) - "PJMSCCT(W)", [V]CST_AERROR)
              Break
            Endif
          Endif
          # ---------------------------
          If this.CRELOGFILE = [V]CST_AYES Then
            IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : [F:PJCCTW]PBUCOD=" + [F:PJCCTW]PBUCOD -
&                                             "[F:PJCCTW]PBUPAE=" + [F:PJCCTW]PBUPAE - "this.TECPSCCTSEQ :" - num$(this.TECPSCCTSEQ) -
&                                             "IPJCCTX_FOUND :" - num$(IPJCCTX_FOUND) + ":" + mess(IPJCCTX_FOUND,1,1)
&                                             , [V]CST_AINFO)
          Endif
        Next
        Filter [PJCCT]
        #ISEQSTART = this.TECPSCCTSEQ  # Issue X3-55055 - 2017-12-07 by FGR
      Until IINTOLOOP = [V]CST_ANO
    Endif
  Next NI
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : End step 2 this.TECPSCCTSEQ :" - num$(this.TECPSCCTSEQ), [V]CST_AINFO)
  Endif
  # ---------------------------
  # 3°) Agregate each levels without parent on a global one, without budget
  Raz SREQ
  SREQ(0)  = "SELECT OPPNUM_0,            PCCCOD_0,            PCCGRP_0,           PCCGRPSOR_0"
  SREQ(1)  =       ",sum(PSCQTY1_0),      sum(PSCAMT1_0),      sum(PSCQTY2_0),     sum(PSCAMT2_0),   sum(PSCQTY3_0),   sum(PSCAMT3_0)"
  SREQ(2)  =       ",sum(PSCQTY4_0),      sum(PSCAMT4_0),      sum(PSCQTY5_0),     sum(PSCAMT5_0)"
  SREQ(3)  =       ",sum(PSCBUDQTY_0),    sum(PSCBUDAMT_0),    sum(PSCTOTQTY_0),   sum(PSCTOTAMT_0), sum(PSCREMQTY_0), sum(PSCREMAMT_0)"
  SREQ(4)  =       ",sum(PSCMARGQTY_0),   sum(PSCMARGAMT_0),   sum(PSCPCTMQTY_0),  sum(PSCPCTMAMT_0)"
  SREQ(5)  =       ",sum(PSCESTTOTQTY_0), sum(PSCESTTOTAMT_0), sum(PSCWIPQTY_0),   sum(PSCWIPAMT_0) "
  SREQ(6)  =       ",sum(PSCFREEC6A_0),   sum(PSCFREEC6B_0),   sum(PSCFREEC7A_0),  sum(PSCFREEC7B_0) "
  SREQ(7)  =       ",sum(PSCFREEC8A_0),   sum(PSCFREEC8B_0),   sum(PSCFREEC9A_0),  sum(PSCFREEC9B_0) "
  SREQ(8)  =       ",sum(PSCFREEC10A_0),  sum(PSCFREEC10B_0),  sum(PSCMARGBUD6_0), sum(PSCMARGTOT6_0) "
  SREQ(9)  = " From PJMSCCT"
  SREQ(10) = " where PSCSSS_0=" + num$(this.SESSION) + " and OPPNUM_0 <> ' '"
  SREQ(11) = " and PBUPAE_0 = ' ' and not(PCCCOD_0 = ' ' and PBUCOD_0 = ' ' and PCCGRP_0 = ' ')"
  SREQ(12) = " GROUP BY OPPNUM_0, PCCCOD_0, PCCGRP_0, PCCGRPSOR_0"
  SREQ(13) = " ORDER BY OPPNUM_0, PCCCOD_0, PCCGRP_0, PCCGRPSOR_0"
  # ----------------------------
  For (Char WOPPNUM(GLONOPP), Char WPCCCOD(GLONPJCC), Char WPCCGRP(GLONADI), Integer WPCCGRPSOR,
&      Decimal WQ1,           Decimal WA1,           Decimal WQ2,        Decimal WA2,        Decimal WQ3,    Decimal WA3,
&      Decimal WQ4,           Decimal WA4,           Decimal WQ5,        Decimal WA5,        Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&      Decimal WRQT,          Decimal WRAM,          Decimal WMQT,       Decimal WMAM,       Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&      Decimal WIPQT,         Decimal WIPAM,         Decimal WC6QT,      Decimal WC6AM,      Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&      Decimal WC9QT,         Decimal WC9AM,         Decimal WC10QT,     Decimal WC10AM,     Decimal WMBUD6, Decimal WTBUD6)
&   From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
    # ----------------------------
    Raz [F:PJCCTW]
    # ----------------------------
    [F:PJCCTW]OPPNUM       = [F:WWW]WOPPNUM
    [F:PJCCTW]PCCCOD       = [F:WWW]WPCCCOD
    [F:PJCCTW]PCCGRP       = [F:WWW]WPCCGRP
    [F:PJCCTW]PCCGRPSOR    = [F:WWW]WPCCGRPSOR
    # ----------------------------
    Gosub SET_PJCCTW_FROM_WWW From TECFINOVE_CSTD_PROGS
    # ---------------------------
    [F:PJCCTW]PSCSSS   = this.SESSION
    this.TECPSCCTSEQ  += 1
    [F:PJCCTW]PSCSEQ   = this.TECPSCCTSEQ
    # ---------------------------
    Write [F:PJCCTW]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSCCT", mess(352,2260,1) - "PJMSCCT(W)-b", [V]CST_AERROR)
      Break
    Endif
    # ---------------------------
  Next
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : End step 3 this.TECPSCCTSEQ :" - num$(this.TECPSCCTSEQ), [V]CST_AINFO)
  Endif
  # ---------------------------
  # 4°) Agregate each levels at PCCGRP level
  Raz SREQ
  SREQ(0)  = "SELECT OPPNUM_0,            PBUPAE_0,            PBUCOD_0,           PCCGRP_0,         PCCGRPSOR_0"
  SREQ(1)  =       ",sum(PSCQTY1_0),      sum(PSCAMT1_0),      sum(PSCQTY2_0),     sum(PSCAMT2_0),   sum(PSCQTY3_0),   sum(PSCAMT3_0)"
  SREQ(2)  =       ",sum(PSCQTY4_0),      sum(PSCAMT4_0),      sum(PSCQTY5_0),     sum(PSCAMT5_0)"
  SREQ(3)  =       ",sum(PSCBUDQTY_0),    sum(PSCBUDAMT_0),    sum(PSCTOTQTY_0),   sum(PSCTOTAMT_0), sum(PSCREMQTY_0), sum(PSCREMAMT_0)"
  SREQ(4)  =       ",sum(PSCMARGQTY_0),   sum(PSCMARGAMT_0),   sum(PSCPCTMQTY_0),  sum(PSCPCTMAMT_0)"
  SREQ(5)  =       ",sum(PSCESTTOTQTY_0), sum(PSCESTTOTAMT_0), sum(PSCWIPQTY_0),   sum(PSCWIPAMT_0) "
  SREQ(6)  =       ",sum(PSCFREEC6A_0),   sum(PSCFREEC6B_0),   sum(PSCFREEC7A_0),  sum(PSCFREEC7B_0) "
  SREQ(7)  =       ",sum(PSCFREEC8A_0),   sum(PSCFREEC8B_0),   sum(PSCFREEC9A_0),  sum(PSCFREEC9B_0) "
  SREQ(8)  =       ",sum(PSCFREEC10A_0),  sum(PSCFREEC10B_0),  sum(PSCMARGBUD6_0), sum(PSCMARGTOT6_0) "
  SREQ(9)  = " From PJMSCCT"
  SREQ(10) = " where PSCSSS_0=" + num$(this.SESSION) + " and OPPNUM_0 <> ' '"
  SREQ(11) = " and not(PCCCOD_0 = ' ' and PBUCOD_0 = ' ' and PCCGRP_0 = ' ')"
  SREQ(12) = " GROUP BY OPPNUM_0, PBUPAE_0, PBUCOD_0, PCCGRP_0, PCCGRPSOR_0"
  SREQ(13) = " ORDER BY OPPNUM_0, PBUPAE_0, PBUCOD_0, PCCGRP_0, PCCGRPSOR_0"
  # ----------------------------
  For (Char WOPPNUM(GLONOPP), Char WPBUPAE(GLONPBU), Char WPBUCOD(GLONPBU), Char WPCCGRP(GLONADI),           Integer WPCCGRPSOR,
&      Decimal WQ1,           Decimal WA1,           Decimal WQ2,        Decimal WA2,        Decimal WQ3,    Decimal WA3,
&      Decimal WQ4,           Decimal WA4,           Decimal WQ5,        Decimal WA5,        Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&      Decimal WRQT,          Decimal WRAM,          Decimal WMQT,       Decimal WMAM,       Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&      Decimal WIPQT,         Decimal WIPAM,         Decimal WC6QT,      Decimal WC6AM,      Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&      Decimal WC9QT,         Decimal WC9AM,         Decimal WC10QT,     Decimal WC10AM,     Decimal WMBUD6, Decimal WTBUD6)
&   From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
    # ----------------------------
    Raz [F:PJCCTW]
    # ----------------------------
    [F:PJCCTW]OPPNUM       = [F:WWW]WOPPNUM
    [F:PJCCTW]PBUPAE       = [F:WWW]WPBUPAE
    [F:PJCCTW]PBUCOD       = [F:WWW]WPBUCOD
    [F:PJCCTW]PCCGRP       = [F:WWW]WPCCGRP
    [F:PJCCTW]PCCGRPSOR    = [F:WWW]WPCCGRPSOR
    # ----------------------------
    Gosub SET_PJCCTW_FROM_WWW From TECFINOVE_CSTD_PROGS
    # ---------------------------
    [F:PJCCTW]PSCSSS   = this.SESSION
    this.TECPSCCTSEQ  += 1
    [F:PJCCTW]PSCSEQ   = this.TECPSCCTSEQ
    # ---------------------------
    Write [F:PJCCTW]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSCCT", mess(352,2260,1) - "PJMSCCT(W)-b", [V]CST_AERROR)
      Break
    Endif
    # ---------------------------
  Next
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : End step 4 this.TECPSCCTSEQ :" - num$(this.TECPSCCTSEQ), [V]CST_AINFO)
  Endif
  # ---------------------------
  # 5°) Agregate each levels at budget level
  Raz SREQ
  SREQ(0)  = "SELECT OPPNUM_0,            PBUPAE_0,            PBUCOD_0"
  SREQ(1)  =       ",sum(PSCQTY1_0),      sum(PSCAMT1_0),      sum(PSCQTY2_0),     sum(PSCAMT2_0),   sum(PSCQTY3_0),   sum(PSCAMT3_0)"
  SREQ(2)  =       ",sum(PSCQTY4_0),      sum(PSCAMT4_0),      sum(PSCQTY5_0),     sum(PSCAMT5_0)"
  SREQ(3)  =       ",sum(PSCBUDQTY_0),    sum(PSCBUDAMT_0),    sum(PSCTOTQTY_0),   sum(PSCTOTAMT_0), sum(PSCREMQTY_0), sum(PSCREMAMT_0)"
  SREQ(4)  =       ",sum(PSCMARGQTY_0),   sum(PSCMARGAMT_0),   sum(PSCPCTMQTY_0),  sum(PSCPCTMAMT_0)"
  SREQ(5)  =       ",sum(PSCESTTOTQTY_0), sum(PSCESTTOTAMT_0), sum(PSCWIPQTY_0),   sum(PSCWIPAMT_0) "
  SREQ(6)  =       ",sum(PSCFREEC6A_0),   sum(PSCFREEC6B_0),   sum(PSCFREEC7A_0),  sum(PSCFREEC7B_0) "
  SREQ(7)  =       ",sum(PSCFREEC8A_0),   sum(PSCFREEC8B_0),   sum(PSCFREEC9A_0),  sum(PSCFREEC9B_0) "
  SREQ(8)  =       ",sum(PSCFREEC10A_0),  sum(PSCFREEC10B_0),  sum(PSCMARGBUD6_0), sum(PSCMARGTOT6_0) "
  SREQ(9)  = " From PJMSCCT"
  SREQ(10) = " where PSCSSS_0=" + num$(this.SESSION) + " and OPPNUM_0 <> ' '"
  SREQ(11) = " and PBUCOD_0 <> ' ' and PCCCOD_0 <> ' '"
  SREQ(12) = " GROUP BY OPPNUM_0, PBUPAE_0, PBUCOD_0"
  SREQ(13) = " ORDER BY OPPNUM_0, PBUPAE_0, PBUCOD_0"
  # ----------------------------
  For (Char WOPPNUM(GLONOPP), Char WPBUPAE(GLONPBU), Char WPBUCOD(GLONPBU),
&      Decimal WQ1,           Decimal WA1,           Decimal WQ2,        Decimal WA2,        Decimal WQ3,    Decimal WA3,
&      Decimal WQ4,           Decimal WA4,           Decimal WQ5,        Decimal WA5,        Decimal WBQTY,  Decimal WBAMT, Decimal WTTQT, Decimal WTTAM,
&      Decimal WRQT,          Decimal WRAM,          Decimal WMQT,       Decimal WMAM,       Decimal WPQT,   Decimal WPAM,  Decimal WEQT,  Decimal WEAM,
&      Decimal WIPQT,         Decimal WIPAM,         Decimal WC6QT,      Decimal WC6AM,      Decimal WC7QT,  Decimal WC7AM, Decimal WC8QT, Decimal WC8AM,
&      Decimal WC9QT,         Decimal WC9AM,         Decimal WC10QT,     Decimal WC10AM,     Decimal WMBUD6, Decimal WTBUD6)
&   From fmet this.SQL_GET_TYPDBA() Sql SREQ As [WWW]
    # ----------------------------
    Raz [F:PJCCTW]
    # ----------------------------
    [F:PJCCTW]OPPNUM       = [F:WWW]WOPPNUM
    [F:PJCCTW]PBUPAE       = [F:WWW]WPBUPAE
    [F:PJCCTW]PBUCOD       = [F:WWW]WPBUCOD
    # ----------------------------
    Gosub SET_PJCCTW_FROM_WWW From TECFINOVE_CSTD_PROGS
    # ---------------------------
    [F:PJCCTW]PSCSSS   = this.SESSION
    this.TECPSCCTSEQ  += 1
    [F:PJCCTW]PSCSEQ   = this.TECPSCCTSEQ
    # ---------------------------
    Write [F:PJCCTW]
    If fstat <> 0 Then
      [L]ARET_VALUE = this.ASETERROR("_DATA_EXTRACT_PJMSCCT", mess(352,2260,1) - "PJMSCCT(W)-b", [V]CST_AERROR)
      Break
    Endif
    # ---------------------------
  Next
  # ---------------------------
  If [L]ARET_VALUE = [V]CST_AOK Then
    [L]ARET_VALUE = fmet this._DATA_EXTRACT_PJMSCCT_MULPRJ()
  Endif
  # ---------------------------
  If this.CRELOGFILE = [V]CST_AYES Then
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : End step 5 this.TECPSCCTSEQ :" - num$(this.TECPSCCTSEQ), [V]CST_AINFO)
    IRET = fmet this.LOGFILE.APUTLINE("_DATA_EXTRACT_PJMSCCT : Time end :" - num$(time) - "Duration : " - num$(time-ITIME) - "second(s)", [V]CST_AINFO)
  Endif
Return

