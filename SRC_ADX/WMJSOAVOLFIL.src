$GET_JSON_STRUCTURE
Local Integer PC(1..17),DC(1..17)
PC(1)  = 1
PC(2)  = (instr(1,"qbl",AF)>0)
PC(4)  = (instr(1,"de",AF)>0)
PC(5)  = (instr(1,"deqb",AF)>0)
PC(6)  = (instr(1,"qbls",AF)>0)
PC(7)  = (instr(1,"qb",AF)>0)
PC(8)  = (instr(1,"ls",AF)>0)
PC(9)  = (instr(1,"",AF)>0)
PC(10) = (instr(1,"deqbls",AF)>0)
PC(11) = (instr(1,"dqbe",AF)>0)
PC(12) = (instr(1,"dqb",AF)>0)
