#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:46 290


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub _AVARIABLES From WMC00BSIIMPTC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_BSIIMPTC

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub AVARIABLES From WMC00BSIIMPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_BSIIMPTC
Else
 Gosub ADELETE_BSIIMPTC
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(BSIIMPTC,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If BSIIMPTC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
BSIIMPTC.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(BSIIMPTC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.LINES(A_N2) <> null
& and BSIIMPTC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If BSIIMPTC.LINES(A_N2).ASTALIN<>[V]CST_ANEW
   BSIIMPTC.LINES(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
For A_N2=1 To maxtab(BSIIMPTC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.LINES(A_N2) <> null
& and BSIIMPTC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_BSIIMPTC
Trbegin [F:BSITC]
 Gosub ADELETE_BSIIMPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_BSIIMPTC
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#-----------------------------------------------------#
For A_N2=1 To maxtab(BSIIMPTC.LINES)
 If BSIIMPTC.LINES(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  BSIIMPTC.LINES(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00BSIIMPTC._MAJSQL_BSIITCD(BSIIMPTC.LINES(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(BSIIMPTC,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00BSIIMPTC._MAJSQL_BSIIMPTC(BSIIMPTC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If BSIIMPTC.snapshotEnabled=1
 [L]A_RETIK = BSIIMPTC.revertUpdTick
Endif
[L]ASTATUS = max(fmet BSIIMPTC.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



