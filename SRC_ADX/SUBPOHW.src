########################################################################
Subprog C_NUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]NUMDEB : GMESSAGE = mess(044,199,1) : mkstat = 1 : Endif
End

########################################
Subprog C_FCYFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]FCYDEB : GMESSAGE = mess(044,199,1) : mkstat = 1 : Endif
End

########################################
Subprog C_BPCFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]BPCDEB : GMESSAGE = mess(044,199,1) : mkstat = 1 : Endif
End

########################################
Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]DATDEB : GMESSAGE = mess(044,199,1) : mkstat = 1 : Endif
End

########################################
Subprog AV_NUMDEB(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = GNUMCDE : Endif
End

########################################
Subprog AV_NUMFIN(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = GNUMCDE : Endif
End

########################################
Subprog AV_FCYDEB(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = [F:SOH]SALFCY : Endif
End

########################################
Subprog AV_FCYFIN(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = [F:SOH]SALFCY : Endif
End

########################################
Subprog AV_BPCDEB(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = [F:SOH]BPCORD : Endif
End

########################################
Subprog AV_BPCFIN(VALEUR)
Variable Char    VALEUR()
If GNUMCDE <> "" : VALEUR = [F:SOH]BPCORD : Endif
End

########################################
Subprog AV_DATDEB(VALEUR)
Variable Date    VALEUR
If GNUMCDE <> "" : VALEUR = [F:SOH]ORDDAT : Endif
End

########################################
Subprog AV_DATFIN(VALEUR)
Variable Date    VALEUR
If GNUMCDE <> "" : VALEUR = [F:SOH]ORDDAT : Endif
End

########################################
Subprog AM_NUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" & [M]NUMFIN="" | [M]NUMFIN < VALEUR
  [M]NUMFIN = VALEUR
Endif
End

########################################
Subprog AM_FCYDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" & [M]FCYFIN="" | [M]FCYFIN < VALEUR
  [M]FCYFIN = VALEUR
Endif
End

########################################
Subprog AM_BPCDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" & [M]BPCFIN="" | [M]BPCFIN < VALEUR
  [M]BPCFIN = VALEUR
Endif
End

########################################
Subprog AM_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] & ([M]DATFIN=[0/0/0] | [M]DATFIN < VALEUR)
  [M]DATFIN = VALEUR
Endif
End

########################################
Subprog D_FCYDEB(VALEUR)
Variable Char    VALEUR()
VALEUR=GFCYDEF
End

########################################
Subprog D_FCYFIN(VALEUR)
Variable Char    VALEUR()
VALEUR=GFCYDEF
End


Subprog AM_PRTFLG(VALEUR)
#-------------------------------------------------#
# Après modification de l'indicateur d'impression #
#-------------------------------------------------#
Variable Integer VALEUR
If VALEUR=2
  Actzo DOCNAM, PRTCOD
Else
  Effzo DOCNAM, PRTCOD, PRTSRV, PRTNAM
  Diszo DOCNAM, PRTCOD
Endif
End

Subprog C_DOCNAM(VALEUR)
#--------------------#
# Contrôle code état #
#--------------------#
Variable Char    VALEUR()
#----- Si impression à Oui, le code état par défaut est obligatoire -----#
If [M]PRTFLG=2 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
End

Subprog AM_DOCNAM(VALEUR)
#--------------------------#
# Après modif du code état #
#--------------------------#
Variable Char    VALEUR()
Call AIMDEF([M]PRTCOD,VALEUR,GBIDC1,GBIDC2)  From IMPRIME
Call CONTROLE("AIM","!A",[M]PRTCOD,"",mkstat) From CONTOBJ
If mkstat
  [M]PRTCOD="" : Raz mkstat
Else
  [M]PRTSRV=[F:AIM]PRTSRV
  [M]PRTNAM=[F:AIM]PRTNAM
  Affzo PRTCOD
  If dim([M]ZPRTCOD)>0  Affzo ZPRTCOD : Endif 
  Affzo PRTSRV, PRTNAM
Endif
End

Subprog C_PRTCOD(VALEUR)
#-----------------------------------#
# Contrôle destination (imprimante) #
#-----------------------------------#
Variable Char    VALEUR()
#----- Si impression à Oui, la destination par défaut est obligatoire -----#
If [M]PRTFLG=2 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
End

Subprog AM_PRTCOD(VALEUR)
#--------------------------------------#
# Après modification de la destination #
#--------------------------------------#
Variable Char    VALEUR()
#----- Affichage du serveur et de l'imprimante -----#
[M]PRTSRV=[F:AIM]PRTSRV
[M]PRTNAM=[F:AIM]PRTNAM
Affzo PRTSRV, PRTNAM
End
