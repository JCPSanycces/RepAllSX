#<AdxTL>@(#)9.0.0.0 $Revision$
## Action TRTPPHACC : Traitement standard / saisie de fenêtre initiale
Local Char    PARMSK(250)(1..20) , SAVACT(20), VALEUR(250)
SAVACT = GACTION : GACTION = "TRTPPHACC"
Call TRAITE_CHAR(VALEUR,PARMSK,"","TRTPPHACC","TRTPPHACC",4,"XYTRTPPHACC") From GTRAITE
GACTION = SAVACT

End

$ACTION
Case [L]ACTION
    When "INIT", "OUVRE_BATCH"       : Gosub OUVRE
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "DEBUT"       : Gosub DEBUT
    When "TERMINE"     : Gosub TERMINE
Endcase
Return

$OUVRE
Local Char MESSAGE(250), EVT(10)
Local Mask TRTPPHACC [DIA]
Local File PPREQUESTH [WHRPPH]
Local File PPREQUESTD [WPPD]
Gosub GET_PPDSTA From TRTPREPAY
Return

$CONTROLE
If [V]GSTATUT <> [V]GSTAOK
    [L]FIN = 1
Else
    [L]TMP = 1 : [L]TRA = 1
Endif
Return

Return

$TERMINE
Close Local File [WHRPPH], [WPPD]
Return

$EXEC

# Balayage de tous les bordereaux demandés, si lignes à l'état "demande" on bascule le statut dans
# l'état indiqué

[L]MESSAGE = mess(193,10702,1)
[L]MESSAGE -= mess(194,10702,1)

Call OUVRE_TRACE([L]MESSAGE) From LECFIC

##**82073
For [F:WHRPPH] Where [F:WHRPPH]DEMDAT >= [M:DIA]DEMDATDEB & [F:WHRPPH]DEMDAT <= [M:DIA]DEMDATFIN
&                    & [F:WHRPPH]APLDAT >= [M:DIA]APLSTR & [F:WHRPPH]APLSTR <= [M:DIA]APLDAT
&                    & [F:WHRPPH]REQSTA < 3
    For [F:WPPD]PPD0 Where [F:WPPD]REQNUM = [F:WHRPPH]REQNUM
&                        & [F:WPPD]STA = [L]PPDSTA_DEMANDE

        [L]MESSAGE = [F:WPPD]REQNUM
        [L]MESSAGE -= num$([F:WPPD]NUMLIG)
        [L]MESSAGE -= [F:WPPD]REFNUM
        [L]MESSAGE -= [F:WPPD]VRACOD
        [L]MESSAGE -= num$([F:WPPD]DEMAMT)
        Call ECR_TRACE([L]MESSAGE, 0) From GESECRAN

        Raz [L]EVT

        Case [M:DIA]STA
            When [L]PPDSTA_ACCEPTE
                [L]EVT = "VIS"
            When [L]PPDSTA_REFUSE
                [L]EVT = "REF"
        Endcase

        Call WRKSIG([L]EVT, "D", [F:WPPD]REQNUM, num$([F:WPPD]NUMLIG), num$([F:WPPD]IDPPD),
&                    [F:WPPD]REFNUM, [F:WPPD]VRACOD, [F:WPPD]CHRONO) From SUBHRPPH
    Next
Next

Call FERME_TRACE From LECFIC
If not [V]GSERVEUR
    Call LEC_TRACE From LECFIC
Endif

Return

$DEBUT

Gosub GET_PPDSTA From TRTPREPAY

If GPAYE=1
 ##**82073
 [M:DIA]APLSTR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
 [M:DIA]APLDAT = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
Endif

If [M:DIA]DEMDATFIN = [0/0/0]
    [M:DIA]DEMDATFIN = datesyst - 7
Endif

[M:DIA]STA = [L]PPDSTA_ACCEPTE

Affzo [M:DIA]
Setmok [M:DIA] With 0

Return

# Gestion du masque TRTPPHACC

Subprog AS_STA(VALEUR)
Variable Integer VALEUR

Gosub GET_PPDSTA From TRTPREPAY

[V]GMENLOC([L]PPDSTA_BROUILLON) = 1
[V]GMENLOC([L]PPDSTA_INACTIF) = 1
[V]GMENLOC([L]PPDSTA_DEMANDE) = 1
[V]GMENLOC([L]PPDSTA_PRISENCOMPTE) = 1

End

######################################################################################
##**82073
######################################################################################
Subprog AS_DEMDATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=datesyst : Endif
End

Subprog AS_DEMDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M]DEMDATDEB : Endif
End

Subprog AS_APLSTR(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR= gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
Endif
End

Subprog AS_APLDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR= gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
Endif
End

Subprog C_APLDAT(VALEUR)
Variable Date     VALEUR
If [L]VALEUR < [M]DEMDATFIN
    GMESSAGE = mess(200,126,1)-'"'+mess(164,10701,1)+'"'
    mkstat = 2 :    End
Endif
End

######################################################################################
