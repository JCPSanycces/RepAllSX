#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","LETTSUB","DMTCAUTO",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "CONTROLE"    : Gosub CONTROLE
 When "OK"          : GOK = 1 : FIN = 1
 When "END"         : GOK = 0 : FIN = 1
Endcase
Return

$OUVRE
If clalev([F:CPY])=0  : Local File COMPANY     [CPY]   : Endif
If clalev([F:FCY])=0  : Local File FACILITY    [FCY]   : Endif
If clalev([F:GCM])=0  : Local File GACM        [GCM]   : Endif
If clalev([F:LED])=0  : Local File GLED        [LED]   : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR  [FIY]   : Endif
If clalev([F:PER])=0  : Local File PERIOD      [PER]   : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC]   : Endif
If clalev([F:BAL])=0  : Local File BALANCE     [BAL]   : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY   [HAE]   : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD  [DAE]   : Endif
If clalev([F:DAE5])=0 : Local File GACCENTRYD  [DAE5]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE  [DUD]   : Endif
If clalev([F:ADW])=0  : Local File ADOVAL      [ADW]   : Endif
If clalev([F:DAE3])=0 : Local File GACCENTRYD  [DAE3]  : Endif
If clalev([F:DAE4])=0 : Local File GACCENTRYD  [DAE4]  : Endif
If clalev([F:DAE5])=0 : Local File GACCENTRYD  [DAE5]  : Endif

Filter [DAE4] Order By Key CLE = CPY;FCYLIN;LEDTYP;ACC;BPR;MTC
Return

$OUVRE_BATCH
Gosub OUVRE
Local Mask LETTCRIT [LTC], LETTCRIT [DIA]
Return

$INIT
Local Mask LETTAUTO [LTA] , LETTCRIT [LTC]
Gosub OUVRE
TMP = 1
Return

$INIT_DIA
If val(PARAM(1))<1 : PARAM(1) = "1" : Endif
[M]LEDTYP = val(PARAM(1))
If dim([M]NBSOC)>0 : Raz NBSOC, SOC : Endif
Return

$DEBUT
Affzo
Return

$SETBOUT
CHMEN = ""
If [M]CRIT=2
 CHMEN += "S"
Endif
CHBOU = "O"
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return

$CONTROLE
If GSERVEUR : [M:LTC] = [M:LTA] : Endif
Return

$EXEC
If GOK
 Call LETTAUTO([M:LTA]LEDTYP,[M:LTA]NBSOC,[M:LTA]SOC,[M:LTA]SITE,[M:LTA]CRIT
&             ,[M:LTA]CPTDEB,[M:LTA]CPTFIN,[M:LTA]BPRDEB,[M:LTA]BPRFIN
&             ,[M:LTA]DATDEB,[M:LTA]DATFIN )
 TRA = 1
Endif
Return

#########################################################
## Lettrage automatique                                ##
#########################################################
Subprog LETTAUTO(REFERENTIEL,NBSOC,SOCIETE,SIT,CRIT,CPTDEB,CPTFIN,BPRDEB,BPRFIN,DATDEB,DATFIN)
Value Integer REFERENTIEL
Value Integer NBSOC
Value Char    SOCIETE()(1..)
Value Char    SIT
Value Integer CRIT
Value Char    CPTDEB
Value Char    CPTFIN
Value Char    BPRDEB
Value Char    BPRFIN
Value Date    DATDEB
Value Date    DATFIN

Local Integer OK , FLCPT , CAS , OKSOC
Local Char    SOC(GLONCPY) , SITE(GLONFCY) , COMPTE(GLONGAC) , TIERS(GLONBPR) , LETTRE(5)
Local Date    DATMIN , DATMAX, DATD, DATF
Local Char    CRITERE(250) , SYMBCPT(30)
Local Char    PLAN(GLONCOA)

CRIT = (CRIT=2)

Gosub OUVRE

If !GSERVEUR
 Call OUVRE_TRACE(mess(9,110,1)) From LECFIC : # Lettrage automatique
Endif

DATD = DATDEB
DATF = DATFIN

If NBSOC=1 & SIT<>""
 Call LECTURE("FCY",SIT,"") From CONTOBJ
 SOC = [F:FCY]LEGCPY : Gosub TRTSOC
Elsif NBSOC>0
 SIT = ""
 For ISOC=1 To NBSOC
  SOC = SOCIETE(ISOC) : Gosub TRTSOC
 Next
Else
 Call LECTURE("FCY",SIT,"") From CONTOBJ
 SOC = [F:FCY]LEGCPY : Gosub TRTSOC
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
GOK = 1
End

$TRTSOC
Call LOCKCPY(SOC,OKSOC) From AX3MONO
If !OKSOC : Return : Endif
Call LECTURE("CPY",SOC,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
If [F:GCM]LED(REFERENTIEL-1)=""
 Return
Endif
Call LECTURE("LED",[F:GCM]LED(REFERENTIEL-1),"") From CONTOBJ
PLAN = [F:LED]COA
If [F:LED]GEN=2
 If clalev([F:BAL2])=0 : Local File BALANCE [BAL2] : Endif
Else
 If clalev([F:BAL2])=0 : Local File BALANA  [BAL2] : Endif
Endif
If SIT=""
 For [FCY]FCY1 Where LEGCPY=SOC & FINFLG=2
  SITE = [F:FCY]FCY : Gosub TRTSITE
 Next
Else
 SITE = SIT : Gosub TRTSITE
Endif
Call UNLOCKCPY From AX3MONO
Return

$TRTSITE
Call LECTURE("FCY",SITE,"") From CONTOBJ
Call LECTURE("GAC",CPTDEB,PLAN) From CONTOBJ
If fstat=0 & [F:GAC]SAC=2
 COMPTE = CPTDEB
 If BPRFIN="" : BPRFIN = "zzz" : Endif
 Filter [BAL2] Where LEDTYP=REFERENTIEL & CPY=SOC & FCY=SITE & ACC=CPTDEB & BPR>=BPRDEB & BPR<=BPRFIN
&              Order By Key CLE=BPR
 For [BAL2]CLE(1)
 #KC 57060 : manquer la clé sur le filtre et boucle sur BPR. Ne passer pas au next BPR
 #For [BAL2]BAL0(5)
  TIERS = [F:BAL2]BPR : Gosub TRTCOMPTE
 Next
Else
 TIERS = ""
 If CPTFIN="" : CPTFIN = "zzz" : Endif
 Filter [BAL2] Where LEDTYP=REFERENTIEL & CPY=SOC & FCY=SITE & ACC>=CPTDEB & ACC<=CPTFIN
&              Order By Key CLE=ACC
 For [BAL2]CLE(1)
  COMPTE = [F:BAL2]ACC : Gosub TRTCOMPTE
 Next
Endif
Filter [BAL2]
#Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Return

$TRTCOMPTE
Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
If [F:GAC]MTC<>2 : Return : Endif : # Compte non lettrable
GPE = 0
GPOINT = "BEFAUTMTC" : Gosub ENTREE From EXEFNC
If GPE : Return : Endif
SYMBCPT = "MTC"-SITE-COMPTE-TIERS
Lock =SYMBCPT
If fstat=1
 Call ECR_TRACE(COMPTE-TIERS-mess(30,100,1),1) From GESECRAN
Else
 Call LETCPT(REFERENTIEL,SITE,COMPTE,TIERS,2,0,CRIT, DATD, DATF)
 Unlock =SYMBCPT
Endif
Return

########################################################
## Lettrage d'un compte en automatique                ##
########################################################
Subprog LETCPT(REFERENTIEL,SITE,COMPTE,TIERS,FLTRACE,TIMING,CRITERES,DEBDAT,FINDAT)
Value Integer REFERENTIEL
Value Char    SITE
Value Char    COMPTE
Value Char    TIERS
Value Integer FLTRACE
Value Integer TIMING
Value Integer CRITERES
Value Date    DEBDAT
Value Date    FINDAT

If clalev([M:LTR])=0 : Local Mask LETTRAGE [LTR] : Endif
If clalev([M:LTE])=0 : Local Mask LETTRECH [LTE] : Endif
If clalev([M:LTC])=0 : Local Mask LETTCRIT [LTC] : Endif

If CRITERES=0 : # Rechargement des critères
 Gosub INIPAR From LETTRAGE
Endif

Local Integer MAXECT
Local Char    PARAM(10)
Call PARAM("","MTCNBR",PARAM) From ADOVAL
MAXECT = val(PARAM)
If MAXECT<1000 : MAXECT = 1000 : Endif
Local Char    SOCIETE(GLONCPY) , PRIO(5)
Local Integer N , ND , NC , P , Q , Z , OK , FLCPT
Local Integer PT(1..MAXECT) , PZ(1..MAXECT) , PTD(1..MAXECT) , PTC(1..MAXECT)
Local Integer X(1..MAXECT) , Y(1..MAXECT) , XD(1..9) , XC(1..9)
Local Decimal MONT(1..MAXECT) , MONTD(1..MAXECT) , MONTC(1..MAXECT)
Local Char    REF(GLONREF)(1..MAXECT)
Local Char    FREREF(GLONREF)(1..MAXECT) # FREREF est désormais de type REF...
Local Char    DES(GLONDES)(1..MAXECT)
Local Decimal MONTLET
Local Integer I , J , K
Local Integer I0, I1 , I2 , I3 , I4 , I5 , I6 , I7 , I8 , I9
Local Decimal TOTAL1 , TOTAL2 , TOTAL3 , TOTAL4 , TOTAL5
Local Decimal TOTAL6 , TOTAL7 , TOTAL8 , TOTAL9
Local Integer LETREF , LNGREF , LNGDES , LETMIN, LETFREREF, LNGFREREF
Local Decimal TP , OTP , TPP , TT , TPM
Local Integer TIMDEB , HH , MM , SS
Local Integer AFFICHE , MINTIME , MODTIME
Local Integer STOP , INTERRUPT , CHARGE , TRACE
Local Char    CRITERE(250)
Local Integer FLDEV , NBDEV , IDEV
Local Char    DEVISE(GLONCUR) , TBDEV(GLONCUR)(1..200)
Local Char    FILT(250)

If clalev([F:CPY])=0  : Local File COMPANY     [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY    [FCY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR  [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD      [PER]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR      [TCU]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE  [DUD]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE     [BAL]  : Endif
If clalev([F:MTC])=0  : Local File MATCHCODE   [MTC]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY   [HAE]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD  [DAE]  : Endif
If clalev([F:DAE3])=0 : Local File GACCENTRYD  [DAE3] : Endif
If clalev([F:DAE4])=0 : Local File GACCENTRYD  [DAE4] : Endif
Filter [DAE4] Order By Key CLE = CPY;FCYLIN;LEDTYP;ACC;BPR;MTC
If clalev([F:DAE5])=0 : Local File GACCENTRYD  [DAE5] : Endif

If GBROWS : TIMING = 0 : Endif : # Dangereux en web

Call LECTURE("FCY",SITE,"") From CONTOBJ
SOCIETE = [F:FCY]LEGCPY
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
TRACE = (FLTRACE=2)
FLCPT = 0

####################################
MINTIME = 1000000
MODTIME = 100000
####################################
If [M:LTC]MTCREF>=3
 LNGREF = [M:LTC]MTCREF
Endif

If [M:LTC]MTCFREREF>=3
 LNGFREREF = [M:LTC]MTCFREREF
Endif

If [M:LTC]MTCDES>=3
 LNGDES = [M:LTC]MTCDES
Endif

NPRI = dim([M:LTC]PIO)
Local Integer PRI1(1..NPRI) , PRI2(1..NPRI)
For J=1 To NPRI
 PRI1(J) = [M:LTC]PIO(J-1)
 PRI2(J) = J
Next J
Sorta NPRI PRI1,PRI2
For J=1 To NPRI
 If PRI1(J)>0
  Case PRI2(J)
   When 1
    If [M:LTC]MTCAMT>=2
     PROFOND = [M:LTC]MTCAMT
     Gosub LETMONT
    Endif
   When 2
    If [M:LTC]MTCCUR>=2
     Gosub LETDEV
    Endif
   When 3
    If [M:LTC]MTCSOL2=2
     Gosub SOLDNUL
    Endif
   When 4
    If [M:LTC]MTCSOL1>0
     Gosub RECHSOLDE
    Endif
   When 5
    If [M:LTC]MTCREF>=3
     LETREF = 1
     LETMIN = [M:LTC]MTCLOW
     Gosub LETREF
    Endif
   When 6
    If [M:LTC]MTCDES>=3
     LETREF = 2
     LETMIN = [M:LTC]MTCLOW
     Gosub LETREF
    Endif
   When 7
    If [M:LTC]MTCFREREF>=3
     LETREF = 3
     LETMIN = [M:LTC]MTCLOW
     Gosub LETREF
    Endif
  Endcase
 Endif
Next J
If TRACE & FLCPT
 Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Endif
End

#######################################################
## Lettrage par passage à un solde nul             ####
######################################################
$SOLDNUL
Raz Z , MONTLET
Gosub FILTRE
Filter [DAE3] Where evalue(CRITERE) and evalue(FILT) & (MTC<"A" | MTC>"ZZZZZ")
For [DAE3]DAE1
 Gosub TEST
 If OK
  Z += 1
  If Z>=MAXECT : Break : Endif
  PZ(Z)   = [F:DAE3]ACCNUM
  MONT(Z) = [F:DAE3]SNS*[F:DAE3]AMTLED
  MONTLET += MONT(Z)
  If MONTLET=0
   Gosub LETTRAGE
   Raz Z
  Endif
 Endif
Next
Filter [DAE3]
CHARGE=0
Return

$FILTRE
CRITERE  = 'LEDTYP='+num$(REFERENTIEL)
CRITERE -= '& CPY="'+SOCIETE+'"'
CRITERE -= '& FCYLIN="'+SITE+'"'
CRITERE -= '& ACC="'+COMPTE+'"'
CRITERE -= '& BPR="'+TIERS+'"'

If DEBDAT<>[0/0/0]
 CRITERE -= '& ACCDAT>=['+format$(GFMD,DEBDAT)+']'
Endif
If FINDAT<>[0/0/0]
 CRITERE -= '& ACCDAT<=['+format$(GFMD,FINDAT)+']'
Endif

Gosub FILTRE_SPE From LETTRAGE
Return

$TEST
OK = 1
If [F:DAE3]SNS>0
 If [M:LTC]DEBDATDEB<>[0/0/0]
  OK *= [F:DAE3]ACCDAT>=[M:LTC]DEBDATDEB
 Endif
 If [M:LTC]DEBDATFIN<>[0/0/0]
  OK *= [F:DAE3]ACCDAT<=[M:LTC]DEBDATFIN
 Endif
Else
 If [M:LTC]CREDATDEB<>[0/0/0]
  OK *= [F:DAE3]ACCDAT>=[M:LTC]CREDATDEB
 Endif
 If [M:LTC]CREDATFIN<>[0/0/0]
  OK *= [F:DAE3]ACCDAT<=[M:LTC]CREDATFIN
 Endif
Endif
If OK
 Read [HAE]HAE0 = [F:DAE3]TYP;[F:DAE3]NUM
 OK *= ([F:HAE]CAT=1)
 OK *= ([F:HAE]FLGREP<>2)
 If FLDEV=1
  OK *= ([F:HAE]CUR=DEVISE)
 Endif
Endif
Return

#######################################################
## Lettrage par recherche du solde                  ###
#######################################################
$RECHSOLDE
Raz N, MONTLET, NC, ND
Gosub FILTRE
Filter [DAE3] Where evalue(CRITERE) and evalue(FILT) & (MTC<"A" | MTC>"ZZZZZ")
For [DAE3]DAE1
 Gosub TEST
 If OK
  N += 1
  If N>=MAXECT : Break : Endif
  PT(N)   = [F:DAE3]ACCNUM
  MONT(N) = [F:DAE3]SNS*[F:DAE3]AMTLED
  MONTLET += MONT(N)
  If MONT(N)>0
   ND += 1 : MONTD(ND) = MONT(N) : PTD(ND) = N
  Elsif MONT(N)<0
   NC += 1 : MONTC(NC) = MONT(N) : PTC(NC) = N
  Endif
 Endif
Next
Filter [DAE3]
AFFICHE=0
If TIMING
 TT = 0 : TIMDEB = time
 Call CUMTT(N,1,[M:LTC]MTCSOL1,TT)
 If TT>MINTIME
  AFFICHE = 1
  Call OUVRE_BOITE(mess(13,110,1),TT) From GESECRAN
# Recherche de solde
  TP = 0
 Endif
Endif

MONTLET = -MONTLET
For P=1 To [M:LTC]MTCSOL1
 Gosub EQUILIBRE
 If OK
  Z = 0
  For I=1 To N
   If !find(I,X(1..P))
    Z += 1 : PZ(Z) = PT(I)
   Endif
  Next I
  Gosub LETTRAGE
  Break
 Elsif STOP
  Break
 Endif
Next P
If AFFICHE
 Call FERME_BOITE From GESECRAN
Endif
CHARGE=0
Return

############################################################################
## Lettrage par référence pièce et ou libellé ou référence libre          ##
############################################################################
$LETREF
If !CHARGE : Gosub CHARGE : Endif

AFFICHE = 0
If TIMING & N>1000
 Case LETREF
  When 1 : Call OUVRE_BOITE(mess(14,110,1),N) From GESECRAN
#          Lettrage par référence
  When 2 : Call OUVRE_BOITE(mess(15,110,1),N) From GESECRAN
#          Lettrage par libellé
  When 3 : Call OUVRE_BOITE(mess(50,110,1),N) From GESECRAN
#          Lettrage par référence libre
 Endcase
 AFFICHE = 1
 TP = 0
Endif
Case LETREF
 When 1 : Sorta N  REF,DES,FREREF,PT,MONT Order By REF(indice+1)
 When 2 : Sorta N  DES,REF,FREREF,PT,MONT Order By DES(indice+1)
 When 3 : Sorta N  FREREF,DES,REF,PT,MONT Order By FREREF(indice+1)
Endcase

# 1) Recherche d'un groupe minuscule ayant déjà la même référence

For [DAE4]CLE(6) Where evalue(CRITERE) & MTC>="a" & MTC<="zzzzz" & evalue(FILT)
 Z = 0 : P = 0 : MONTLET = 0 : OKREF = 1
 For [DAE4]CLE
  P += 1
  If LETREF=1
   Read [HAE]HAE0 = [F:DAE4]TYP;[F:DAE4]NUM
   If P=1
    REFMIN = left$(vireblc(toupper(ctrans([F:HAE]REF)),4),LNGREF)
    If REFMIN="" : OKREF = 0 : Break : Endif
   Elsif REFMIN<>left$(vireblc(toupper(ctrans([F:HAE]REF)),4),LNGREF)
    OKREF = 0 : Break
   Endif
  Elsif LETREF=2
   If P=1
    REFMIN = left$(vireblc(toupper(ctrans([F:DAE4]DES)),4),LNGDES)
    If REFMIN="" : OKREF = 0 : Break : Endif
   Elsif REFMIN<>left$(vireblc(toupper(ctrans([F:DAE4]DES)),4),LNGDES)
    OKREF = 0 : Break
   Endif
  Elsif LETREF=3
   Read [HAE]HAE0 = [F:DAE4]TYP;[F:DAE4]NUM
   If P=1
    REFMIN = left$(vireblc(toupper(ctrans([F:DAE4]FREREF)),4),LNGFREREF)
    If REFMIN="" : OKREF = 0 : Break : Endif
   Elsif REFMIN<>left$(vireblc(toupper(ctrans([F:DAE4]FREREF)),4),LNGFREREF)
    OKREF = 0 : Break
   Endif
  Endif
  Z += 1
  If Z>=MAXECT : Break : Endif
  PZ(Z) = [F:DAE4]ACCNUM
  MONTLET += [F:DAE4]SNS*[F:DAE4]AMTLED
 Next
 If OKREF
  If LETREF=1
   I1 = find(REFMIN,REF(1..N))
  Elsif LETREF=2
   I1 = find(REFMIN,DES(1..N))
  Elsif LETREF=3
   I1 = find(REFMIN,FREREF(1..N))
  Endif
  If I1
   I2 = I1
   While I2<N & ((LETREF=1 & REF(I1)=REF(I2+1)) | (LETREF=2 & DES(I1)=DES(I2+1)) | (LETREF=3 & FREREF(I1)=FREREF(I2+1)))
    I2 += 1
   Wend
   P = 0
   For I3=I1 To I2
    Z += 1
    If Z>=MAXECT : Break : Endif
    PZ(Z) = PT(I3)
    P += 1
    X(P) = I3
   Next I3
   If LETMIN=2 | sum(MONT(I1..I2))+MONTLET=0
    Gosub LETTRAGE
    If GOK>0 : Gosub VIRETAB : Else : Endif
   Endif
  Endif
 Endif
Next

# 2) Il reste les non lettrées

I1 = 1
While I1<=N & ((LETREF=1 & REF(I1)="") | (LETREF=2 & DES(I1)="") | (LETREF=3 & FREREF(I1)=""))
 I1 += 1
Wend
While I1<N
 I2 = I1
 While I2<N & ((LETREF=1 & REF(I1)=REF(I2+1)) | (LETREF=2 & DES(I1)=DES(I2+1)) | (LETREF=3 & FREREF(I1)=FREREF(I2+1)))
  I2 += 1
 Wend
 If I2>I1
  Z = 0 : P = 0
  For I3=I1 To I2
   Z += 1
   If Z>=MAXECT : Break : Endif
   PZ(Z) = PT(I3)
   P += 1
   X(P) = I3
  Next I3
  If LETMIN=2 | sum(MONT(I1..I2))=0
   Gosub LETTRAGE
   If GOK>0 : Gosub VIRETAB : Else : I1 = I2+1 : Endif
  Else
   I1 = I2+1
  Endif
  If AFFICHE
   TP = I2 : TPP = 1 : Gosub AFFICHE
   If STOP : Break : Endif
  Endif
 Else
  I1 = I2+1
 Endif
Wend
If AFFICHE : Call FERME_BOITE From GESECRAN : Endif
Return

$CHARGE
N = 0 : ND = 0 : NC = 0
Gosub FILTRE
Filter [DAE3] Where evalue(CRITERE) and evalue(FILT) & MTC=""
If !FLDEV : NBDEV = 0 : Endif
For [DAE3]DAE1
 Gosub TEST
 If OK
  N += 1
  If N>=MAXECT : Break : Endif
  PT(N)   = [F:DAE3]ACCNUM
  REF(N) = left$(vireblc(toupper(ctrans([F:HAE]REF)),4),LNGREF)
  DES(N) = left$(vireblc(toupper(ctrans([F:DAE3]DES)),4),LNGDES)
  FREREF(N) = left$(vireblc(toupper(ctrans([F:DAE3]FREREF)),4),LNGFREREF)
  Case FLDEV
   When 0 : MONT(N) = [F:DAE3]SNS*[F:DAE3]AMTLED
    If !find([F:HAE]CUR,[F:DAE3]CURLED,TBDEV(1..NBDEV))
     NBDEV += 1 : TBDEV(NBDEV) = [F:HAE]CUR
    Endif
   When 1 : MONT(N) = [F:DAE3]SNS*[F:DAE3]AMTCUR
  Endcase
  If MONT(N)>0
   ND += 1 : MONTD(ND) = MONT(N) : PTD(ND) = N
  Elsif MONT(N)<0
   NC += 1 : MONTC(NC) = MONT(N) : PTC(NC) = N
  Endif
 Endif
Next
Filter [DAE3]
CHARGE = 1
Return

######################################################
## Lettrage par analogie de montant                 ##
######################################################
$LETMONT
If !CHARGE : Gosub CHARGE : Endif
Gosub FILTRE
AFFICHE=0
If TIMING
 TT = 0
 For [DAE4]CLE(6) Where evalue(CRITERE) & MTC>="a" & MTC<="zzzzz" & evalue(FILT)
  Q = 0
  For [DAE4]CLE
   If FLDEV=1 & [F:DAE4]CUR<>DEVISE
    Q = -1 : Break
   Endif
   Q += 1
  Next
  If Q>-1 & Q<PROFOND
   Call CUMTT(N,1,PROFOND-Q,TT)
  Endif
 Next
 Call CUMTT(N,2,PROFOND,TT)
 If TT>MINTIME
  AFFICHE = 1
  # Lettrage par montant
  Case FLDEV
   When 1 : Call OUVRE_BOITE(mess(16,110,1)-DEVISE,TT) From GESECRAN
   When 0 : Call OUVRE_BOITE(mess(16,110,1)-mess(2,45,1),TT) From GESECRAN : # Société
  Endcase
  TP = 0 : OTP = 0
 Endif
Endif
TIMDEB = time
Gosub LETMIN
If STOP : Goto F_LETMONT : Endif
# Réajustement de l'estimation
If AFFICHE
 TT = TP : Call CUMTT(N,2,PROFOND,TT) : [M:BOI]MAXI = TT
# Ce qu'on a déjà fait (TP) + combinatoire de 2 à profond
Endif
Gosub NONLET

$F_LETMONT
If AFFICHE
 Call FERME_BOITE From GESECRAN
Endif
Return

############# Lettrage d'un groupe de minuscule avec d'autres non lettrées
$LETMIN
For [DAE4]CLE(6) Where evalue(CRITERE) & MTC>="a" & MTC<="zzzzz" & evalue(FILT)
 MONTLET = 0
 Q = 0
 For [DAE4]CLE
  If FLDEV=1 & [F:DAE4]CUR<>DEVISE
   Q = -1 : Break
  Else
   Case FLDEV
    When 0 : MONTLET += [F:DAE4]SNS*[F:DAE4]AMTLED
    When 1 : MONTLET += [F:DAE4]SNS*[F:DAE4]AMTCUR
   Endcase
  Endif
  Q += 1
  If Q>=MAXECT : Break : Endif
  Y(Q) = [F:DAE4]ACCNUM
 Next
 If Q>-1 & MONTLET=0 & Q<=MAXECT : # Groupe équilibré par hasard!!
  Z = 0
  For I1=1 To Q
   Z += 1 : PZ(Z) = Y(I1)
  Next I1
  Gosub LETTRAGE
 Elsif Q>-1 & ((MONTLET>0 & NC>0) | (MONTLET<0 & ND>0))
  For P = 1 To PROFOND-Q
   Gosub EQUILIBRE
   If OK
    Z = 0
    For I1=1 To Q
     Z += 1 : PZ(Z) = Y(I1)
    Next I1
    For I1=1 To P
     Z += 1 : PZ(Z) = PT(X(I1))
    Next I1
    Gosub LETTRAGE
    Gosub VIRETAB
    Break
   Elsif STOP
    Break 2
   Endif
  Next P
 Endif
Next
Return

################# Lettrage d'un groupe non lettré
$NONLET
MONTLET = 0
For P=2 To PROFOND
 OK = 1
 While OK
  Gosub EQUILIBRE
  If OK
   Z = 0
   For I1=1 To P
    Z += 1 : PZ(Z) = PT(X(I1))
   Next I1
   Gosub LETTRAGE
   Gosub VIRETAB
   If NC=0 | ND=0 : Break 2 : Endif
   If AFFICHE
# Réajustement
    TT = TP : Call CUMTT(N,P,PROFOND,TT) : [M:BOI]MAXI = TT
#   Total = déjà fait + combinatoire P..PROFOND
   Endif
  Elsif STOP
   Break 2
  Endif
 Wend
Next P
Return

################################################################
## Recherche d'équilibre                                      ##
################################################################
$EQUILIBRE
OK = 0
If P>N : Return : Endif

If sgn(MONTLET)>0     : # Il faut au moins 1 crédit
 For PD=0 To P-1
  PC = P-PD
  Gosub EQUILD
  If OK : Break : Endif
 Next PD
Elsif sgn(MONTLET)<0  : # Il faut au moins 1 débit
 For PD=1 To P
  PC = P-PD
  Gosub EQUILD
  If OK : Break : Endif
 Next PD
Else                  : # Il faut au moins 1 débit et un crédit
 For PD=1 To P-1
  PC = P-PD
  Gosub EQUILD
  If OK : Break : Endif
 Next PD
Endif
Return

$EQUILD
Case PD
 When 0
  TOTALD = MONTLET
  Gosub EQUILC
 When 1
  TOTALD1 = MONTLET
  For ID1=1 To ND
   TOTALD = TOTALD1+MONTD(ID1)
   Gosub EQUILC
   If OK : XD(1) = ID1 : Break : Endif
  Next
 When 2
  TOTALD1 = MONTLET
  For ID1=1 To ND-1
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND
    TOTALD = TOTALD2+MONTD(ID2)
    Gosub EQUILC
    If OK : XD(1) = ID1 : XD(2) = ID2 : Break 2 : Endif
   Next ID2
  Next ID1
 When 3
  TOTALD1 = MONTLET
  For ID1=1 To ND-2
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND-1
    TOTALD3 = TOTALD2+MONTD(ID2)
    For ID3=ID2+1 To ND
     TOTALD = TOTALD3+MONTD(ID3)
     Gosub EQUILC
     If OK : XD(1) = ID1 : XD(2) = ID2 : XD(3) = ID3 : Break 3 : Endif
    Next ID3
   Next ID2
  Next ID1
 When 4
  TOTALD1 = MONTLET
  For ID1=1 To ND-3
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND-2
    TOTALD3 = TOTALD2+MONTD(ID2)
    For ID3=ID2+1 To ND-1
     TOTALD4 = TOTALD3+MONTD(ID3)
     For ID4=ID3+1 To ND
      TOTALD = TOTALD4+MONTD(ID4)
      Gosub EQUILC
      If OK : XD(1) = ID1 : XD(2) = ID2 : XD(3) = ID3 : XD(4) = ID4 : Break 4 : Endif
     Next ID4
    Next ID3
   Next ID2
  Next ID1
 When 5
  TOTALD1 = MONTLET
  For ID1=1 To ND-4
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND-3
    TOTALD3 = TOTALD2+MONTD(ID2)
    For ID3=ID2+1 To ND-2
     TOTALD4 = TOTALD3+MONTD(ID3)
     For ID4=ID3+1 To ND-1
      TOTALD5 = TOTALD4+MONTD(ID4)
      For ID5=ID4+1 To ND
       TOTALD = TOTALD5+MONTD(ID5)
       Gosub EQUILC
       If OK : XD(1) = ID1 : XD(2) = ID2 : XD(3) = ID3 : XD(4) = ID4 : XD(5) = ID5 : Break 5 : Endif
      Next ID5
     Next ID4
    Next ID3
   Next ID2
  Next ID1
 When 6
  TOTALD1 = MONTLET
  For ID1=1 To ND-5
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND-4
    TOTALD3 = TOTALD2+MONTD(ID2)
    For ID3=ID2+1 To ND-3
     TOTALD4 = TOTALD3+MONTD(ID3)
     For ID4=ID3+1 To ND-2
      TOTALD5 = TOTALD4+MONTD(ID4)
      For ID5=ID4+1 To ND-1
       TOTALD6 = TOTALD5+MONTD(ID5)
       For ID6=ID5+1 To ND
        TOTALD = TOTALD6+MONTD(ID6)
        Gosub EQUILC
        If OK : XD(1) = ID1 : XD(2) = ID2 : XD(3) = ID3 : XD(4) = ID4 : XD(5) = ID5
                XD(6) = ID6
                Break 6
        Endif
       Next ID6
      Next ID5
     Next ID4
    Next ID3
   Next ID2
  Next ID1
 When 7
  TOTALD1 = MONTLET
  For ID1=1 To ND-6
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND-5
    TOTALD3 = TOTALD2+MONTD(ID2)
    For ID3=ID2+1 To ND-4
     TOTALD4 = TOTALD3+MONTD(ID3)
     For ID4=ID3+1 To ND-3
      TOTALD5 = TOTALD4+MONTD(ID4)
      For ID5=ID4+1 To ND-2
       TOTALD6 = TOTALD5+MONTD(ID5)
       For ID6=ID5+1 To ND-1
        TOTALD7 = TOTALD6+MONTD(ID6)
        For ID7=ID6+1 To ND
         TOTALD = TOTALD7+MONTD(ID7)
         Gosub EQUILC
         If OK : XD(1) = ID1 : XD(2) = ID2 : XD(3) = ID3 : XD(4) = ID4 : XD(5) = ID5
                 XD(6) = ID6 : XD(7) = ID7
                 Break 6
         Endif
        Next ID7
       Next ID6
      Next ID5
     Next ID4
    Next ID3
   Next ID2
  Next ID1
 When 8
  TOTALD1 = MONTLET
  For ID1=1 To ND-7
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND-6
    TOTALD3 = TOTALD2+MONTD(ID2)
    For ID3=ID2+1 To ND-5
     TOTALD4 = TOTALD3+MONTD(ID3)
     For ID4=ID3+1 To ND-4
      TOTALD5 = TOTALD4+MONTD(ID4)
      For ID5=ID4+1 To ND-3
       TOTALD6 = TOTALD5+MONTD(ID5)
       For ID6=ID5+1 To ND-2
        TOTALD7 = TOTALD6+MONTD(ID6)
        For ID7=ID6+1 To ND-1
         TOTALD8 = TOTALD7+MONTD(ID7)
         For ID8=ID7+1 To ND
          TOTALD = TOTALD8+MONTD(ID8)
          Gosub EQUILC
          If OK : XD(1) = ID1 : XD(2) = ID2 : XD(3) = ID3 : XD(4) = ID4 : XD(5) = ID5
                  XD(6) = ID6 : XD(7) = ID7 : XD(8) = ID8
                  Break 6
          Endif
         Next ID8
        Next ID7
       Next ID6
      Next ID5
     Next ID4
    Next ID3
   Next ID2
  Next ID1
 When 9
  TOTALD1 = MONTLET
  For ID1=1 To ND-8
   TOTALD2 = TOTALD1+MONTD(ID1)
   For ID2=ID1+1 To ND-7
    TOTALD3 = TOTALD2+MONTD(ID2)
    For ID3=ID2+1 To ND-6
     TOTALD4 = TOTALD3+MONTD(ID3)
     For ID4=ID3+1 To ND-5
      TOTALD5 = TOTALD4+MONTD(ID4)
      For ID5=ID4+1 To ND-4
       TOTALD6 = TOTALD5+MONTD(ID5)
       For ID6=ID5+1 To ND-3
        TOTALD7 = TOTALD6+MONTD(ID6)
        For ID7=ID6+1 To ND-2
         TOTALD8 = TOTALD7+MONTD(ID7)
         For ID8=ID7+1 To ND-1
          TOTALD9 = TOTALD8+MONTD(ID8)
          For ID9=ID8+1 To ND
           TOTALD = TOTALD9+MONTD(ID9)
           Gosub EQUILC
           If OK : XD(1) = ID1 : XD(2) = ID2 : XD(3) = ID3 : XD(4) = ID4 : XD(5) = ID5
                   XD(6) = ID6 : XD(7) = ID7 : XD(8) = ID8 : XD(9) = ID9
                   Break 6
           Endif
          Next ID9
         Next ID8
        Next ID7
       Next ID6
      Next ID5
     Next ID4
    Next ID3
   Next ID2
  Next ID1
Endcase
If OK
 For I0=1 To PD
  X(I0) = PTD(XD(I0))
 Next I0
 For I0=1 To PC
  X(I0+PD) = PTC(XC(I0))
 Next I0
Endif
Return

$EQUILC
Case PC
 When 0
  If TOTALD=0 : OK = 1 : Endif
  If AFFICHE : TPP = 1 : Gosub AFFICHE : Endif
 When 1
  I0 = find(-TOTALD,MONTC(1..NC))
  If I0
   OK = 1 : XC(1) = I0
  Endif
  If AFFICHE : TPP = NC : Gosub AFFICHE : Endif
 When 2
  For IC1=1 To NC-1
   I0 = find(-MONTC(IC1)-TOTALD,MONTC(IC1+1..NC))
   If I0
    OK = 1 : XC(1) = IC1 : XC(2) = IC1+I0
    Break
   Endif
   If AFFICHE : TPP = NC-IC1 : Gosub AFFICHE : If STOP : Break 1 : Endif : Endif
  Next IC1
 When 3
  For IC1=1 To NC-2
   TOTALC1 = MONT(IC1)+TOTALD
   For IC2=IC1+1 To NC-1
    I0 = find(-TOTALC1-MONT(IC2),MONTC(IC2+1..NC))
    If I0
     OK = 1 : XC(1) = IC1 : XC(2) = IC2 : XC(3) = IC2+I0
     Break 2
    Endif
   Next IC2
   If AFFICHE : TPP = (NC-IC1-1)*(NC-IC1)/2 : Gosub AFFICHE : If STOP : Break 2 : Endif : Endif
  Next IC1
 When 4
  For IC1=1 To NC-3
   TOTALC1 = MONTC(IC1)+TOTALD
   For IC2=IC1+1 To NC-2
    TOTALC2 = TOTALC1+MONTC(IC2)
    For IC3=IC2+1 To NC-1
     I0 = find(-TOTALC2-MONTC(IC3),MONTC(IC3+1..NC))
     If I0
      OK = 1 : XC(1) = IC1 : XC(2) = IC2 : XC(3) = IC3 : XC(4) = IC3+I0
      Break 3
     Endif
    Next IC3
    If AFFICHE : TPP = (NC-IC2-1)*(NC-IC2)/2 : Gosub AFFICHE : If STOP : Break 3 : Endif : Endif
   Next IC2
  Next IC1
 When 5
  For IC1=1 To NC-4
   TOTALC1 = MONTC(IC1)+TOTALD
   For IC2=IC1+1 To NC-3
    TOTALC2 = TOTALC1+MONTC(IC2)
    For IC3=IC2+1 To NC-2
     TOTALC3 = TOTALC2+MONTC(IC3)
     For IC4=IC3+1 To NC-1
      I0 = find(-TOTALC3-MONTC(IC4),MONTC(IC4+1..NC))
      If I0
       OK = 1 : XC(1) = IC1 : XC(2) = IC2 : XC(3) = IC3 : XC(4) = IC4 : XC(5) = IC4+I0
       Break 4
      Endif
     Next IC4
     If AFFICHE : TPP = (NC-IC3-1)*(NC-IC3)/2 : Gosub AFFICHE : If STOP : Break 4 : Endif : Endif
    Next IC3
   Next IC2
  Next IC1
 When 6
  For IC1=1 To NC-5
   TOTALC1 = MONTC(IC1)+TOTALD
   For IC2=IC1+1 To NC-4
    TOTALC2 = TOTALC1+MONTC(IC2)
    For IC3=IC2+1 To NC-3
     TOTALC3 = TOTALC2+MONTC(IC3)
     For IC4=IC3+1 To NC-2
      TOTALC4 = TOTALC3+MONTC(IC4)
      For IC5=IC4+1 To NC-1
       I0 = find(-TOTALC4-MONTC(IC5),MONTC(IC5+1..NC))
       If I0
        OK = 1 : XC(1) = IC1 : XC(2) = IC2 : XC(3) = IC3 : XC(4) = IC4 : XC(5) = IC5
        XC(6) = IC5+I0
        Break 5
       Endif
      Next IC5
      If AFFICHE : TPP = (NC-IC4-1)*(NC-IC4)/2 : Gosub AFFICHE : If STOP : Break 5 : Endif : Endif
     Next IC4
    Next IC3
   Next IC2
  Next IC1
 When 7
  For IC1=1 To NC-6
   TOTALC1 = MONTC(IC1)+TOTALD
   For IC2=IC1+1 To NC-5
    TOTALC = TOTALC1+MONTC(IC2)
    For IC3=IC2+1 To NC-4
     TOTALC3 = TOTALC2+MONTC(IC3)
     For IC4=IC3+1 To NC-3
      TOTALC4 = TOTALC3+MONTC(IC4)
      For IC5=IC4+1 To NC-2
       TOTALC5 = TOTALC4+MONTC(IC5)
       For IC6=IC5+1 To NC-1
        I0 = find(-TOTALC5-MONTC(IC6),MONTC(IC6+1..NC))
        If I0
         OK = 1 : XC(1) = IC1 : XC(2) = IC2 : XC(3) = IC3 : XC(4) = IC4
         XC(5) = IC5 : XC(6) = IC6 : XC(7) = IC6+I0
         Break 6
        Endif
       Next IC6
       If AFFICHE : TPP = (NC-IC5-1)*(NC-IC5)/2 : Gosub AFFICHE : If STOP : Break 6 : Endif : Endif
      Next IC5
     Next IC4
    Next IC3
   Next IC2
  Next IC1
 When 8
  For IC1=1 To NC-7
   TOTALC1 = MONTC(IC1)+TOTALD
   For IC2=IC1+1 To NC-6
    TOTALC2 = TOTALC1+MONTC(IC2)
    For IC3=IC2+1 To NC-5
     TOTALC3 = TOTALC2+MONTC(IC3)
     For IC4=IC3+1 To NC-4
      TOTALC4 = TOTALC3+MONTC(IC4)
      For IC5=IC4+1 To NC-3
       TOTALC5 = TOTALC4+MONTC(IC5)
       For IC6=IC5+1 To NC-2
        TOTALC6 = TOTALC5+MONTC(IC6)
        For IC7=IC6+1 To NC-1
         I0 = find(-TOTALC6-MONTC(IC7),MONTC(IC7+1..NC))
         If I0
          OK = 1 : XC(1) = IC1 : XC(2) = IC2 : XC(3) = IC3 : XC(4) = IC4
          XC(5) = IC5 : XC(6) = IC6 : XC(7) = IC7 : XC(8) = IC7+I0
          Break 7
         Endif
        Next IC7
        If AFFICHE : TPP = (NC-IC6-1)*(NC-IC6)/2 : Gosub AFFICHE : If STOP : Break 7 : Endif : Endif
       Next IC6
      Next IC5
     Next IC4
    Next IC3
   Next IC2
  Next IC1
 When 9
  For IC1=1 To NC-8
   TOTALC1 = MONTC(IC1)+TOTALD
   For IC2=IC1+1 To NC-7
    TOTALC2 = TOTALC1+MONTC(IC2)
    For IC3=IC2+1 To NC-6
     TOTALC3 = TOTALC2+MONTC(IC3)
     For IC4=IC3+1 To NC-5
      TOTALC4 = TOTALC3+MONTC(IC4)
      For IC5=IC4+1 To NC-4
       TOTALC5 = TOTALC4+MONTC(IC5)
       For IC6=IC5+1 To NC-3
        TOTALC6 = TOTALC5+MONTC(IC6)
        For IC7=IC6+1 To NC-2
         TOTALC7 = TOTALC6+MONTC(IC7)
         For IC8=IC7+1 To NC-1
          I0 = find(-TOTALC7-MONTC(IC8),MONTC(IC8+1..NC))
          If I0
           OK = 1 : XC(1) = IC1 : XC(2) = IC2 : XC(3) = IC3 : XC(4) = IC4
           XC(5) = IC5 : XC(6) = IC6 : XC(7) = IC7 : XC(8) = IC8 : XC(9) = IC8+I0
           Break 8
          Endif
         Next IC8
         If AFFICHE : TPP = (NC-IC7-1)*(NC-IC7)/2 : Gosub AFFICHE : If STOP : Break 8 : Endif : Endif
        Next IC7
       Next IC6
      Next IC5
     Next IC4
    Next IC3
   Next IC2
  Next IC1
Endcase
Return

##############################################################
## Lettrage en devises                                      ##
##############################################################
$LETDEV
If !CHARGE : Gosub CHARGE : Endif
For IDEV=1 To NBDEV
 FLDEV   = 1
 DEVISE  = TBDEV(IDEV)
 PROFOND = [M:LTC]MTCCUR
 CHARGE  = 0
 Gosub LETMONT
Next IDEV
If NBDEV : CHARGE = 0 : FLDEV = 0 : Endif
Return

##############################################################
## Sous-programme de lettrage                               ##
##############################################################
$LETTRAGE
If TRACE & FLCPT=0
 FLCPT = 1
 Call ECR_TRACE(time$-mess(2,116,1)-SOCIETE-mess(5,116,1)-SITE-mess(8,104,1)-COMPTE-TIERS,0) From GESECRAN
#               Société               Site               Compte
Endif
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [DAE] , [DUD] , [MTC]
 CAS = 1+(FLDEV=1)
 ## Si toutes les pièces du groupe sont sur la même devise, on lettre en devise de pièce (comme en lettrage
 ## manuel...)
 Local Char    DEVPCE(GLONCUR)
 Local Integer INDZ, OKDEV : OKDEV = 1
 Read [DAE5]DAE2 = PZ(1)
 If !fstat : DEVPCE = [F:DAE5]CUR : Endif
 For INDZ=2 To Z
  Read [DAE5]DAE2 = PZ(INDZ)
  If !fstat & [F:DAE5]CUR<>DEVPCE
   OKDEV = 0 : Break
  Endif
 Next
 If OKDEV : CAS = 2 : Endif
 Call LETAUTO(Z,PZ,CAS,TRACE) From LETTRAGE
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

# On vire du tableau ce qui est lettré
$VIRETAB
K = 0
For I=1 To N
 If find(I,X(1..P))
  K += 1
 Elsif K
  PT(I-K)   = PT(I)
  MONT(I-K) = MONT(I)
  REF(I-K)  = REF(I)
  DES(I-K)  = DES(I)
  FREREF(I-K)  = FREREF(I)
 Endif
Next I
N -= P
ND = 0 : NC = 0
For I=1 To N
 If MONT(I)>0
  ND += 1 : MONTD(ND) = MONT(I) : PTD(ND) = I
 Else
  NC += 1 : MONTC(NC) = MONT(I) : PTC(NC) = I
 Endif
Next I

Return

########################################################
## Affichage boite de progression                     ##
########################################################
$AFFICHE
TP += TPP
If TT<>0 & (TP>OTP+MODTIME | TP>=TT)
 [M:BOI]PCENT = fix(100*TP/TT)
 [M:BOI]MES  = num$(TP)-"/"-num$(TT)
 [M:BOI]BARRE = [M:BOI]PCENT
 If TP<>0
  SS = (time-TIMDEB)*(TT-TP)/TP
  HH = int(SS/3600)
  MM = int((SS-3600*HH)/60)
  SS = mod(SS,60)
#  [M:BOI]MES = mess(15,190,1)-":" : # Temps
  [M:BOI]MES += " ("
  If HH
   [M:BOI]MES += num$(HH)+"h"-num$(MM)+"mn"
  Elsif MM
   [M:BOI]MES += num$(MM)+"mn"-num$(SS)+"s"
  Else
   [M:BOI]MES += num$(SS)+"s"
  Endif
  [M:BOI]MES += ")"
 Endif
 Affzo [BOI]
 OTP = TP
Endif
Return


Subprog CUMTT(N,P1,P2,TT)
Value    Integer N
Value    Integer P1
Value    Integer P2
Variable Decimal TT
Local Integer PP
For PP=P1 To P2
 If N>=PP & N>0 & PP>=0
  TT += cnp(N,PP)
 Endif
Next PP
End

Subprog OUVRE_BOITE(TEXTE,NOMBRE)
Value Char    TEXTE
Value Decimal NOMBRE
If GSERVEUR : End : Endif
Global Mask VALPCENT2 [BOI]
Global Mesbox Mask [BOI] Titled TEXTE As [BOI]
Raz [M:BOI]
[M:BOI]MAXI = NOMBRE
Boxact [BOI]
End

