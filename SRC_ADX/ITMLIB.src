#<AdxTL>@(#)7.0.0.0 $Revision$
###############################################################
# ITMLIB:
# Fonctions unitaires d'accès / contrôle d'une référence ITMREF
#
# Funprog GET_STOMGTCOD (WITMREF, WFCY): renvoie ITF.STOMGTCOD
# Funprog GET_PTOCOD (WITMREF, WFCY)   : renvoie ITF.PTOCOD
# Funprog IS_ACTIVE     : Contrôle si article actif ITM.ITMSTA
# Funprog IS_BOUGHT     : Contrôle si l'article peut être acheté
# Funprog IS_SOLD       : Contrôle si l'article peut être vendu
# Funprog IS_DELIVERABLE: Contrôle si l'article est livrable
# Funprog IS_ITS_OK     : Contrôle si l'article peut être vendu
# Funprog IS_ITU_OK     : Contrôle si article/client ok
# Funprog IS_ITP_OK     : Contrôle si article/fournisseur ok
# Funprog IS_ITF_OK     : Contrôle si article/site ok
#
# Funprog READ_ITM_ITF  : Lecture ITM et ITF (facultatif)
#
# $READ_ITM             : Lecture ITM référence WITMREF
# $READ_ITS             : Lecture ITS référence WITMREF
#
# $READ_ITF             : Lecture ITF référence WITMREF+WFCY
# $READ_ITG             : Lecture ITG référence WTCLCOD
#
# $READ_ITU             : Lecture ITU référence WITMREF+WBPRNUM
# $READ_ITP             : Lecture ITP référence WITMREF+WBPRNUM
###############################################################

Funprog IS_ACTIVE(WITMREF)
Variable Char WITMREF
Local Integer WOK : WOK=2

#----- Article -----#
Gosub READ_ITM

#----- Contrôle si article actif ? -----#
If [F:ITM]ITMSTA=3
  Call AVERTIR(WITMREF-mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")",WOK ) From GESECRAN
  If WOK =1 :  mkstat=1 : Endif
Elsif [F:ITM]ITMSTA<>1
  Call ERREUR(WITMREF-mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")") From GESECRAN
  WOK =1 :  mkstat=1
Endif
If ([F:ITM]LIFSTRDAT <> [0/0/0] & [F:ITM]LIFSTRDAT > date$)  |
&  ([F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$)
# L'article est en statut non utilisable,périmé ou non renouvelé
  Call AVERTIR(WITMREF-mess(382,199,1),WOK ) From GESECRAN
  If WOK =1 :  mkstat=1 : Endif
Endif

End WOK

###############################################################
Funprog IS_BOUGHT(WITMREF)
Variable Char WITMREF
Local Integer WOK : WOK=2

#----- Article -----#
Gosub READ_ITM

#----- Contrôle si article acheté ? CLSTYP=1, 3 ou 4 -----#
# can this article be bought ?
#GA 05/12/2005 If find([F:ITM]CLSTYP,2,7)
#GA 09/01/2006 idem condition "Acheté" dans l'objet ITM
If [F:ITM]PURFLG  = 2 | [F:ITM]SCSFLG=2 | [F:ITM]GENFLG=2 | [F:ITM]TOOFLG=2
  WOK=2
Else
# Article non acheté
  Call ERREUR(mess(70,197,1)-" "-WITMREF ) From GESECRAN
  WOK =1 :  mkstat=1
Endif

End WOK

###############################################################
Funprog IS_SOLD(WITMREF)
Variable Char WITMREF
Local Integer WOK : WOK=2

Local Char WTCLCOD

#----- Article   -----#
Gosub READ_ITM

#----- Catégorie -----#
WTCLCOD = [F:ITM]TCLCOD
Gosub READ_ITG

#----- Contrôle si article vendu -----#
# can this article be sold ?
If [F:ITM]SALFLG = 2 | [F:ITG]SALFLG = 2
  WOK=2
Else
# L'article doit être de catégorie vendue
  Call ERREUR(WITMREF-mess(221,199,1)-WTCLCOD ) From GESECRAN
  WOK =1 :  mkstat=1
Endif

End WOK

###############################################################
Funprog IS_DELIVERABLE(WITMREF)
Variable Char WITMREF
Local Integer WOK : WOK=2

#----- Article -----#
Gosub READ_ITM

#----- Contrôle si article livrable ? -----#
# is this article deliverable ?
If [F:ITM]DLVFLG  = 2 | [F:ITM]SALFLG=2
  WOK=2
Else
# L'article doit être vendu ou livrable
  Call ERREUR(WITMREF-mess(515,199,1) ) From GESECRAN
  WOK =1 :  mkstat=1
Endif

End WOK



###############################################################
Funprog IS_ITS_OK(WITMREF)
Variable Char WITMREF
Local Integer WOK : WOK=2

#----- Article de vente -----#
Gosub READ_ITS

#----- Contrôle si article vendu ? -----#
If fstat
# L'article doit être de catégorie vendue: ok ou annuler ?
  Call AVERTIR(mess(221,199,1)-" "-WITMREF,WOK ) From GESECRAN
  If WOK =1 :  mkstat=1 : Endif
Endif

End WOK

###############################################################

Funprog IS_ITU_OK(WITMREF, WBPRNUM)
Variable Char WITMREF
Variable Char WBPRNUM
Local Integer WOK : WOK=2
#----- Article vendu au client ? -----#
Gosub READ_ITM
Gosub READ_ITU
# FQ 66830 GA 09/2010 ctrl des sources erreur [F:ITU]BPSNUM
If [F:ITU]ITMREF<>WITMREF | [F:ITU]BPCNUM<>WBPRNUM
      #----- Sinon on vérifie si article générique -----#
      If [F:ITM]GENFLG<>2
       # L'article n'est pas référencé chez le client.
         WOK=2
         Call AVERTIR(mess(302,192,1)-" "-WITMREF,WOK) From GESECRAN
         If WOK=1 : mkstat=1 : Endif
      Endif
Endif
End WOK

###############################################################
Funprog IS_ITF_OK(WITMREF,WFCY)
Variable Char WITMREF
Variable Char WFCY
Local Integer WOK : WOK=2

Gosub READ_ITM
If WFCY="" : End WOK : Endif
Gosub READ_ITF
#----- Article/site existant ? -----#
If [F:ITF]ITMREF<>WITMREF | [F:ITF]STOFCY<>WFCY
# Article inexistant sur le site
  GMESSAGE=WITMREF-mess(25,192,1)-WFCY : GERR=1
  WOK=1
Endif

End WOK


###############################################################
# Issue X3-55891 - 2018-09-12 by MUARN : exploitation table article/fournisseur/site ajout de WFCY et WBETFCY
Funprog IS_ITP_OK(WITMREF, WBPRNUM, WFCY, WBETFCY)
Variable Char    WITMREF
Variable Char    WBPRNUM
Value    Char    WFCY
Value    Integer WBETFCY

Local Integer WOK : WOK=2

# Issue X3-55891 - 2018-09-12 by MUARN : exploitation table article/fournisseur/site
Local Integer WITMBPS : WITMBPS = 0
Local Integer WRETOUR

# FQ 58234 GA 09/2009 pas de ctrl si référence non renseignée ou incomplète
If WITMREF="" | WBPRNUM="" End WOK Endif

#----- Article référencé chez le fournisseur ? -----#
Gosub READ_ITM
Gosub READ_ITP
# Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
Gosub READ_BPS
# Issue X3-55891 - 2018-09-12 by MUARN : exploitation table article/fournisseur/site
#----- Si fournisseur <> Divers -----#
#If [F:BPS]BPSTYP<>3
#  If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPRNUM
#     #----- Sinon on vérifie si article générique -----#
#     If [F:ITM]GENFLG<>2
#      # L'article n'est pas référencé chez le fournisseur.
#        If GITMBPS=1 GMESSAGE=mess(8,194,1)-" "-WITMREF : GERR=1 : WOK=1
#               mkstat=1 : Endif
#        If GITMBPS=2
#           WOK=2
#           Call AVERTIR(mess(8,194,1)-" "-WITMREF,WOK) From GESECRAN
#           If WOK=1 : mkstat=1 : Endif
#        Endif
#      Endif
#  Endif
#Endif
If WOK<>1
   # Issue X3-55891 - 2018-08-21 by MUARN : exploitation table article/fournisseur/site
   #----- Article douteux pour ce fournisseur ? -----#
   #If [F:ITP]DOUFLG=2
   #   Call AVERTIR(mess(9,194,1),WOK) From GESECRAN
   #Endif
   #If [F:ITP]DOUFLG=3
   #   GMESSAGE=mess(9,194,1) : GERR=1
   #   WOK = 1
   #Endif
   If WBETFCY = 1
     Call CTRL_DOUFLG(1,WITMREF,WBPRNUM,WFCY,WITMBPS,WRETOUR) From TRTACHCTL1
   Else
     Call CTRL_DOUFLG(2,WITMREF,WBPRNUM,WFCY,WITMBPS,WRETOUR) From TRTACHCTL1
   Endif
   If WRETOUR <> 0
     mkstat=1 : WOK = 1 : GERR=1
   Endif
Endif
End WOK

###############################################################

Funprog GET_STOMGTCOD (WITMREF, WFCY)
Variable Char WITMREF
Variable Char WFCY
Local    Integer WSTOMGTCOD : WSTOMGTCOD=2

Gosub READ_ITM From ITMLIB
WSTOMGTCOD = [F:ITM]STOMGTCOD

Gosub READ_ITF From ITMLIB
If GOK = 1 & [F:ITF]STOMGTCOD<>0 : WSTOMGTCOD = [F:ITF]STOMGTCOD : Endif

End WSTOMGTCOD

###############################################################
# V6 Affectations
Funprog GET_PTOCOD (WITMREF, WFCY)
Value Char WITMREF
Value Char WFCY
Local Char WPTOCOD(GLONPTO)

# GH 19/11/13 bug 94472
#WPTOCOD=GDEFPTO
#Gosub READ_ITM From ITMLIB
#If dim([F:ITM]PTOCOD)>0 & [F:ITM]PTOCOD<>""
#   WPTOCOD = [F:ITM]PTOCOD
#Endif

Gosub READ_ITF From ITMLIB
If GOK = 1 & [F:ITF]PTOCOD<>"" : WPTOCOD = [F:ITF]PTOCOD : Endif

# GH 19/11/13 bug 94472
If WPTOCOD=""
   #Call PARAM(WFCY,"DEFPTO",WPTOCOD) From ADOVAL     # FGR 24/07/2015 : X3SUIVI109796 : Optimisation
   Call PARAML(WFCY,"DEFPTO",WPTOCOD) From ADOVAL     # FGR 24/07/2015 : X3SUIVI109796 : Optimisation
Endif

End WPTOCOD

###############################################################

Funprog READ_ITM_ITF(WITMREF, WFCY)
Variable Char      WITMREF
Variable Char      WFCY
Local Integer WOK : WOK=2

GOK=1
#----- Lecture fichier article et article-site -----#
Gosub READ_ITM From ITMLIB
#If GOK=-1 : WOK=1 : Infbox "Article non trouvé:"-WITMREF : End WOK : Endif
If GOK=-1 : WOK=1 : End WOK : Endif

Gosub READ_ITF From ITMLIB
If GOK=-1 : WOK=1 : End WOK : Endif

End WOK

###############################################################

$READ_ITM
If dim(WITMREF)>0
  If clalev([F:ITM])=0 : Local File ITMMASTER   [ITM] : Endif
  If [F:ITM]ITMREF <> WITMREF
     Read [ITM]ITM0=WITMREF
     If fstat Raz [F:ITM] : GMESSAGE=mess(212,199,1)-WITMREF : GOK=-1 : Endif
  Else
     # Issue 111235 - 2016-02-29 by JUSYN : lead time from already read ITM can only be taken when returned OK
     GOK = 1
     fstat=0   # FQ 55071 pour les tests lecture ok via fstat
  Endif
Else
  Infbox "Ligne ITM non lue !"
Endif
Return

###############################################################

$READ_ITS
If dim(WITMREF)>0
  If clalev([F:ITS])=0 : Local File ITMSALES  : Endif
  If [F:ITS]ITMREF <> WITMREF
     Read [ITS]ITM0=WITMREF
     If fstat Raz [F:ITS] : GMESSAGE=mess(212,199,1)-WITMREF : GOK=-1 : Endif
  Else
     fstat=0   # FQ 55071 pour les tests lecture ok via fstat
  Endif
Else
  Infbox "Ligne ITS non lue !"
Endif
Return

###############################################################


$READ_ITF
If dim(WITMREF)>0 & dim(WFCY)>0
  If clalev([F:ITF])=0 : Local File ITMFACILIT  [ITF] : Endif
  If WFCY<>"" & ( [F:ITF]ITMREF<>WITMREF | [F:ITF]STOFCY<>WFCY )

    # Issue 83440 & 86065 GA 11/2012 pour les ctrl [F:ITF]
    If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
    If [F:FCY]FCY<>WFCY
       Read [FCY]FCY0=WFCY
       If fstat : Raz [F:FCY] : Endif
    Endif
    Read [ITF]ITF0=WITMREF;WFCY
    If fstat
        Raz [F:ITF]
        # If [F:FCY]WRHFLG=2 & ([F:ITM]STOMGTCOD > 1 | [F:ITF]STOMGTCOD > 1 )
        If [F:FCY]FCY=WFCY & [F:FCY]WRHFLG=2 & [F:ITM]ITMREF=WITMREF & [F:ITM]STOMGTCOD>1
        # seuls les articles gérés en stock sont obligatoires dans ITF
        # ne pas planter si article non géré en stock et ITF non trouvé
          GMESSAGE=WITMREF-mess(25,192,1)-WFCY: GOK=-1
        Else
          fstat=0
        Endif
     Endif
  Else
     fstat=0   # FQ 55071 pour les tests lecture ok via fstat
  Endif
Else
  Infbox "Ligne ITF non lue !"
Endif
Return

###############################################################

$READ_ITG
If dim(WTCLCOD)>0 & WTCLCOD<>""
  If clalev([F:ITG])=0 : Local File ITMCATEG  [ITG] : Endif
  If [F:ITG]TCLCOD<>WTCLCOD
     Read [ITG]ITG0=WTCLCOD
     If fstat Raz [F:ITG] Endif
  Else
     fstat=0   # FQ 55071 pour les tests lecture ok via fstat
  Endif
Else
  Infbox "Ligne ITG non lue !"
Endif
Return


###############################################################

$READ_BPS
If dim(WBPRNUM)>0
  If clalev([F:BPS])=0 Local File BPSUPPLIER    [BPS] : Endif
  If [F:BPS]BPSNUM<>WBPRNUM
    Read [BPS] BPS0=WBPRNUM : If fstat Raz [F:BPS] : Endif
  Else
     fstat=0   # FQ 55071 pour les tests lecture ok via fstat
  Endif
Else
  Infbox "Ligne BPS non lue !"
Endif
Return

###############################################################

$READ_ITP
If dim(WITMREF)>0 & dim(WBPRNUM)>0
  If clalev([F:ITP])=0 Local File ITMBPS    [ITP] : Endif
  If [F:ITP]ITMREF <> WITMREF | [F:ITP]BPSNUM <> WBPRNUM
     Read [ITP] ITP0=WITMREF;WBPRNUM
     If fstat : Raz [F:ITP] : Endif
  Else
     fstat=0   # FQ 55071 pour les tests lecture ok via fstat
  Endif
Else
  Infbox "Ligne ITP non lue !"
Endif
Return

###############################################################

$READ_ITU
If dim(WITMREF)>0 & dim(WBPRNUM)>0
  If clalev([F:ITU])=0 Local File ITMBPC [ITU] Endif
  # FQ 66830 GA 09/2010 ctrl des sources erreur [F:ITU]BPSNUM
  If [F:ITU]ITMREF <> WITMREF | [F:ITU]BPCNUM <> WBPRNUM
     Read [ITU] ITU0=WITMREF;WBPRNUM
     If fstat : Raz [F:ITU] : Endif
  Else
     fstat=0   # FQ 55071 pour les tests lecture ok via fstat
  Endif
Else
  Infbox "Ligne ITU non lue !"
Endif
Return

