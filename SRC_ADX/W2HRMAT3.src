#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_NBRCHEF
Onevent INIT_AREA Call D_NBRCHEF From W2HRMAT3
Return

Subprog D_NBRCHEF
Local Decimal BASPAG
If varinit([M]NBRCHEF)=0
 [M]NBRCHEF = len(mess(0,50,1))
Endif
Gosub _AFF
End

$ON_RESPO
Onevent INIT_AREA Call D_RESPO(zc) From W2HRMAT3
Return

Subprog D_RESPO(VALEUR)
Variable Integer VALEUR
If varinit([M]RESPO,indice)=0
 VALEUR = nolign
Endif
Gosub _AFF
End

$ON_CHEF
Onevent CONTROL Call C_CHEF(zc) From W2HRMAT3
Onevent BEFORE_INPUT Call AS_CHEF(zc) From W2HRMAT3
Return

Subprog AS_CHEF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CHEF(zc) From W2HRMAT3
Gosub _AFF
End

Subprog C_CHEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
Endif
If !mkstat
 ## Action STD
 Call C_CHEF(VALEUR) From SUBEML2
 If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action DROITEMP
  Call DROIT(VALEUR,"","",[M:EMP0]REFNUM) From DIVPAYE
  If mkstat : GERR = 1 : GZONE = "CHEF" : GZNUM = 10793 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CHEF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCHFLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCHFLEG"
 PARMSK(1) = [M:EMP0]REFNUM
 PARMSK(2) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELCHFLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_CHEFNAM
Onevent BEFORE_AREA Gosub AV_CHEFNAM From W2HRMAT3
Return

$AV_CHEFNAM
## Action STD
Call AV_CHEFNAM(zc) From SUBEML2
Gosub _AFF
Return

$ON_ITMTYP
Onevent INIT_AREA Call D_ITMTYP(zc) From W2HRMAT3
Onevent CONTROL Call C_ITMTYP(zc) From W2HRMAT3
Onevent BEFORE_INPUT Call AS_ITMTYP(zc) From W2HRMAT3
Return

Subprog D_ITMTYP(VALEUR)
Variable Char    VALEUR()
If varinit([M]ITMTYP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11732","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_ITMTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11732") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ITMTYP(zc) From W2HRMAT3
Onkey   2 Titled GBOUTS Call S_ITMTYP(zc) From W2HRMAT3
Onkey 144 Titled GBOUTP Call P_ITMTYP(zc) From W2HRMAT3
Onkey 146 Titled GBOUTA Call SA_ITMTYP(zc) From W2HRMAT3
Gosub _AFF
End

Subprog C_ITMTYP(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11732","") From SUBADI
If mkstat : GERR = 1 : GZONE = "ITMTYP" : GZNUM = 22928 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11732",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ITMTYP" : GZNUM = 22928 : Endif
Endif
Gosub _AFF
End

Subprog S_ITMTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11732"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_ITMTYP(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11732") From GOBJET
Gosub _AFF
End

Subprog SA_ITMTYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11732"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ITMTYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11732"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_DATISS
Onevent BEFORE_AREA Gosub AV_DATISS From W2HRMAT3
Return

$AV_DATISS
## Action STD
Call AV_DATISS(zc) From SUBEML2
Chgfmt [M]DATISS(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATRTR
Onevent BEFORE_AREA Gosub AV_DATRTR From W2HRMAT3
Return

$AV_DATRTR
## Action STD
Call AV_DATRTR(zc) From SUBEML2
Chgfmt [M]DATRTR(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$CHG_STY
Return


