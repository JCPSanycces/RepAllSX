## Etiquette ajoutée par le superviseur (écran CONSCPO1) 18/03/2013 14:38:23 (MAE)
######################################################################################
Subprog AS_POHNUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]POHNUMDEB
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITCPO) 22/04/2013 14:58:58 (MUARN)
######################################################################################
# Issue 89502 - 2013-04-22 by MUARN : landed cost - code regroupement
Subprog AM_GPGCODDEB(VALEUR)
Variable Char    VALEUR()
If [M]GPGCODFIN="" [M]GPGCODFIN=VALEUR : Affzo [M]GPGCODFIN : Endif
If [M]GPGCODFIN < VALEUR [M]GPGCODFIN = VALEUR : Affzo [M]GPGCODFIN : Endif
End

Subprog C_GPGCODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]GPGCODDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif

End


