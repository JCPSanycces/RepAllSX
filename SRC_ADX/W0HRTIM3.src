#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTIM3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone AUZPRH
mkstat = 0
zoncou = "AUZPRH"
indice = 0
IMPENT = [M]AUZPRH
If varinit([M]AUZPRH,indice)=0
 IMPENT = 1
Endif
If varmode([M]AUZPRH,indice)=0
 [M]AUZPRH(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUZPRH" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AUZPRH(indice)
 Endif
Endif
[M]AUZPRH = IMPENT

## Zone DESIGN
mkstat = 0
zoncou = "DESIGN"
indice = 0
If varinit([M]DESIGN,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]DESIGN,"10701","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESIGN,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESIGN" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]DESIGN,"10701","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]DESIGN,"10701",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone AUZCAL
mkstat = 0
zoncou = "AUZCAL"
indice = 0
IMPENT = [M]AUZCAL
WNUM = IMPENT
If varinit([M]AUZCAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]AUZCAL,indice)=0
 [M]AUZCAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUZCAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AUZCAL(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_AUZCAL(IMPENT) From SUBHRTIM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "AUZCAL" : GZNUM = 55898 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]AUZCAL = IMPENT

## Zone DSPSLD
mkstat = 0
zoncou = "DSPSLD"
indice = 0
IMPENT = [M]DSPSLD
If varinit([M]DSPSLD,indice)=0
 IMPENT = 1
Endif
If varmode([M]DSPSLD,indice)=0
 [M]DSPSLD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DSPSLD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DSPSLD(indice)
 Endif
Endif
[M]DSPSLD = IMPENT

## Zone JUSTIF
mkstat = 0
zoncou = "JUSTIF"
indice = 0
IMPENT = [M]JUSTIF
If varinit([M]JUSTIF,indice)=0
 IMPENT = 1
Endif
If varmode([M]JUSTIF,indice)=0
 [M]JUSTIF(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "JUSTIF" : Gosub ACTION From =IMPTRT
  IMPENT = [M]JUSTIF(indice)
 Endif
Endif
[M]JUSTIF = IMPENT

## Zone DSPSUBTYP
mkstat = 0
zoncou = "DSPSUBTYP"
indice = 0
IMPENT = [M]DSPSUBTYP
If varinit([M]DSPSUBTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]DSPSUBTYP,indice)=0
 [M]DSPSUBTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DSPSUBTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DSPSUBTYP(indice)
 Endif
Endif
[M]DSPSUBTYP = IMPENT

## Zone OVERWR
mkstat = 0
zoncou = "OVERWR"
indice = 0
IMPENT = [M]OVERWR
If varinit([M]OVERWR,indice)=0
 IMPENT = 1
Endif
If varmode([M]OVERWR,indice)=0
 [M]OVERWR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OVERWR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OVERWR(indice)
 Endif
Endif
[M]OVERWR = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRTIM3"
Return

