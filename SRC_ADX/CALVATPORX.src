#<AdxTL>@(#)5.0.0.0 $Revision$
#################################################################################################
#################################################################################################
$ACTION

Case ACTION
  When "INIT"        : Gosub INIT
  When "INIT_DIA"    : Gosub INIT_DIA
  When "OUVRE_BATCH" : Gosub INIT
  When "EXEC"        : Gosub EXEC
  When "SORTIE"      : Gosub SORTIE
Endcase

Return
#################################################################################################
#################################################################################################
$INIT

Local Integer OK
Local Integer STAT

Return
#################################################################################################
#################################################################################################
$INIT_DIA

Raz [M:DIA]

Local Char    DIR_FIC(GDIMFIC)
Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Record separator
Local Char    OS(20)
Local Integer OK
Local Integer ERR

Call SETPARAM(DIR_FIC,MACHIN,IRS,OS,OK)
If OK

  If MACHIN<>""
    [M:DIA]FILNAM = MACHIN+"@"
  Endif

  [M:DIA]FILNAM += DIR_FIC

  ERR = 0
  If filinfo(filpath("DEC","","",nomap),0)<0
    Call CREREP(filpath("DEC","","",nomap),ERR) From DOSAPL
  Endif

  If !ERR

    If OS="unix"
      [M:DIA]FILNAM += "/"+GDIRDEC
    Else
      [M:DIA]FILNAM += "\"+GDIRDEC
    Endif

  Endif

Else
  [M:DIA]FILNAM = filpath(GDIRDEC,"","")
Endif

Call PARAMUTIL("FILVATDEF",[M:DIA]NOMFIC,"","") From SUBAUS

Return
#################################################################################################
#################################################################################################
Subprog SETPARAM(DIR_FIC,MACHIN,IRS,OS,OK)
Variable Char DIR_FIC()
Variable Char MACHIN()
Variable Char IRS()
Variable Char OS()
Variable Integer OK
Local Integer I

OK=1

DIR_FIC = filpath("","","")

I = instr(1,DIR_FIC,"@")
If I
  MACHIN = left$(DIR_FIC,I-1)
  DIR_FIC = right$(DIR_FIC,I+1)
Else
  MACHIN = ""
Endif

Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
  When "unix"  : IRS = chr$(10)
  When Default : IRS = chr$(13)+chr$(10)
Endcase

End
#################################################################################################
#################################################################################################
$EXEC

Call VATDCLEXP(PARAM(1),[M:DIA]TYPEXP,[M:DIA]FILNAM)

Return
#################################################################################################
#################################################################################################
Subprog VATDCLEXP(DCLNUM, TYPEXP, FILNAM)
Value Char    DCLNUM
Value Integer TYPEXP
Value Char    FILNAM

If [L]DCLNUM = "" : End : Endif

Gosub OPEN_TABLES
Gosub DECLARE_VARS

Read [F:DVPH]DVPH0 = [L]DCLNUM
If fstat : End : Endif

Read [F:CPY]CPY0 = [F:DVPH]CPY
If fstat : End : Endif

Gosub OPEN_FILE

Case [F:DVPH]DCLTYP
  When 1
    Gosub EXPORT From CALVATPORPX
  When 4
    Gosub EXPORT From CALVATPOREX
Endcase

Gosub CLOSE_FILE

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

End
#################################################################################################
#################################################################################################
$OPEN_TABLES

Local File DCLVATPORH [DVPH]
Local File DCLVATPORL [DVPL]
Local File DCLVATPORF [DVPF]
Local File COMPANY    [CPY]

Return
#################################################################################################
#################################################################################################
$DECLARE_VARS

Local Char    FILEPATHTMP(GDIMFIC)
Local Integer STAT

Return
#################################################################################################
#################################################################################################
$OPEN_FILE

Onerrgo $ERROR
#opening file to write to (on temporary folder)
[L]FILEPATHTMP = filpath('tmp','VAT_'+[F:DVPH]CPY+"_"+num$([F:DVPH]DCLTYP)+"_"+format$("D:DDMMYYYYhhmmss", date$),'txt')

#empty file if exists
Openo [L]FILEPATHTMP, 0         Using [VATF]

Onerrgo

Return
#################################################################################################
#################################################################################################
$ERROR

GMESSAGE = mess(93,100,1)- num$(errl) - "("+errp+"):" - errmes$(errn)+"\"+errm
OK = 0

Resume
#################################################################################################
#################################################################################################
$CLOSE_FILE

Openo Using [VATF]

If [L]TYPEXP=1 : # Client
  Call MOVCLI([L]FILEPATHTMP,[L]FILNAM,[L]STAT) From ORDSYS
  If [L]STAT=1
    Call ERREUR(mess(164,141,1)) From GESECRAN
  Elsif [L]STAT>1
    Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  Endif
Else
  Call MOVE([L]FILEPATHTMP, [L]FILNAM, [L]STAT) From ORDSYS
  If [L]STAT : Call ERREUR (mess(23,7711,1) + " ("+num$([L]STAT)+")") From GESECRAN : Endif
Endif

Return
###########################################################################
Subprog IMPRBK(FICHIER,BANQUE)
###########################################################################
Variable Char FICHIER()
Variable Char BANQUE()

Gosub DECLARE

Call MACHINE(FICHIER,MACHIN,DIR_FIC) From ORDSYS
Call GET_OS(MACHIN,OS) From ORDSYS
Case OS
 When "unix"  : IRS        = chr$(10)
                SEP_CHEMIN = "/"
 When Default : IRS        = chr$(13)+chr$(10)
                SEP_CHEMIN = "\"
Endcase

End
#################################################################################################
#################################################################################################
$DECLARE
Return
#################################################################################################
#################################################################################################
$SORTIE
Return
#################################################################################################
#################################################################################################
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If left$([M]FILNAM ,1)="#" : [M]TYPEXP=1 Else [M]TYPEXP=2 : Endif
Call AM_TYPEXP([M]TYPEXP)
End
#################################################################################################
#################################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End
#################################################################################################
#################################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  If [M:DIA]FILNAM=""
    Call SET_NAMCLI([M]FILNAM) From ORDSYS
  Endif
  Grizo [M]FILNAM
  End
Else
  If [M:DIA]FILNAM=""
    [M:DIA]FILNAM = filpath(GDIRDEC,"","")
  Endif
  Actzo [M]FILNAM
Endif

End
#################################################################################################
#################################################################################################
Subprog AM_FILNAM(VALEUR)
Variable Char    VALEUR()
End
#################################################################################################
#################################################################################################
Subprog C_FILNAM(NOMFIC)
Variable Char     NOMFIC()

If NOMFIC="" : mkstat=1 : End : Endif

Local Integer ER
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)

Call MACHINE(NOMFIC,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat=2
Endif

If !mkstat
 Call EXISTE(NOMFIC,ER) From ORDSYS
 Case ER
  When 2
   GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
   mkstat = 2
 Endcase
Endif

End
#################################################################################################
#################################################################################################
