#<AdxTL>@(#)0.0.0.0 $Revision$ 
$FONCTION
Case [L]FONCTION
 When "EXS"   : [V]GFONCTION="PRHEXS"
 When "DPI"   : [V]GFONCTION="PRHDPI"
 When "DCG"   : [V]GFONCTION="PRHDCG"
 When Default : [V]GFONCTION="GESEML"
Endcase
Call AUTORIS From EXEFNC
Return

################################################################################
#
# Renvoie les  sociétés
#
################################################################################

#71094
#
# Amélioration GETLSTSOC. Si WITHCP = 1 alors inclue les sociétés
# des dossier comptable. Utile pour les notes de frais
#
Subprog GETLSTSOC (USER,FONCTION, WITHCP, CPY,CPYNAM)
Value    Char USER(), FONCTION()
Value    Integer WITHCP
Variable Char CPY()(0..), CPYNAM()(0..)
Local Char LSTFDRX3 (80)(0..)
Local Integer J


If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

Local Char UTILIS([V]GLONAUS)
[L]UTILIS=[V]GUSER
[V]GUSER =[L]USER
Gosub FONCTION
[V]GUSER=[L]UTILIS

If dim(N)<1 :Local Integer N : N=0 :Endif

Link [F:FCY] With [F:CPY]CPY0=[F:FCY]LEGCPY As [LNK] Order By Key CLE=[F:CPY]CPY
Raz J
For [LNK]CLE Where find([F:FCY]FCY,[V]GUSRFCY) & [F:CPY]CPYLEGFLG=2
 If N>=dim([L]CPY)
  [V]GERR=1
  Break
 Else
  If !find([F:CPY]CPY,[L]CPY)
   [L]CPY   (N)=[F:CPY]CPY
   [L]CPYNAM(N)=[F:CPY]CPYNAM
   N+=1
   If WITHCP & [F:CPY]FDRX3 <> "" & !find([F:CPY]FDRX3, [L]LSTFDRX3)
      [L]LSTFDRX3(J)= [F:CPY]FDRX3
      J+=1
   Endif
  Endif
 Endif
Next
If WITHCP & N<dim([L]CPY) & [L]LSTFDRX3<>""
  Gosub GETSOCCPT
Endif

If [V]GERR
 [V]GMESSAGE="GETLSTSOC :"-func AFNC.MES1(mess(80,10701,1),num$(N))
Endif
End

$GETSOCCPT
  For I=0 To J
    Onerrgo NOTHING
      Local File = [L]LSTFDRX3(I)+".COMPANY"  [CPY2]
      Local File = [L]LSTFDRX3(I)+".FACILITY" [FCY2]

      Link [F:FCY2] With [F:CPY2]CPY0=[F:FCY2]LEGCPY As [LNK2] Order By Key CLE=[F:CPY2]CPY
      For [LNK2]CLE Where find([F:FCY2]FCY,[V]GUSRFCY) & [F:CPY2]CPYLEGFLG=2
        If N>=dim([L]CPY)
          [V]GERR=1
          Close Local File [CPY2], [FCY2]
          Break 2
        Else
          If !find([F:CPY2]CPY,[L]CPY)
            [L]CPY   (N)=[F:CPY2]CPY
            [L]CPYNAM(N)=[F:CPY2]CPYNAM
            N+=1
          Endif
        Endif
      Next
      Close Local File [CPY2], [FCY2]
    Onerrgo
    I+=1
  Next
Return

$NOTHING
Resume
#end 71094


################################################################################
#
# Renvoie les sites
#
################################################################################

Subprog GETLSTSITE(USER,FONCTION,SOCIETE,FCY,FCYNAM)
Value    Char USER(), FONCTION(),SOCIETE()
Variable Char FCY()(0..), FCYNAM()(0..)

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

Local Char UTILIS([V]GLONAUS)
[L]UTILIS=[V]GUSER
[V]GUSER =[L]USER
Gosub FONCTION
[V]GUSER=[L]UTILIS
# sba variable non déclarée
If dim(N)<1 :Local Integer N : N=0 :Endif
For [FCY]FCY0 Where find(FCY,[V]GUSRFCY) & (LEGCPY=[L]SOCIETE | [L]SOCIETE="")
#60812
# If N>=dim([L]CPY)
 If N>=dim([L]FCY)
  [V]GERR=1
 Else
  [L]FCY   (N)=[F:FCY]FCY
  [L]FCYNAM(N)=[F:FCY]FCYNAM
 Endif
 N+=1
Next

If [V]GERR
 [V]GMESSAGE="GETLSTSITE :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables inférieure à $1$
Endif

End

################################################################################
#
# Action de signature
#
################################################################################

Subprog SIGWRK(CHRONO,USRDES,NEWACT,CMT)
Value Char CHRONO , USRDES , NEWACT , CMT
Local Char PARAM(250)(1..6) , VALEUR(10) , SPETRT(GLONADC)
PARAM(1) = CHRONO
PARAM(2) = USRDES
PARAM(3) = GUSER
PARAM(4) = ""
PARAM(5) = NEWACT
PARAM(6) = ""

#Call DEBUG_TRACE(1, "ESS", "SIGWRK " + num$(CHRONO) + " " + num$(USRDES) + " " + num$(NEWACT)) From DEBUGTRACE


If dim(GCOMMENTSIG)> 0 : GCOMMENTSIG = CMT : Endif


#Call DEBUG_TRACE(1, "ESS", "Call TRTSPE") From DEBUGTRACE

Call TRTSPE(nomap,"SIGWRK",SPETRT) From SUBACT

#Call DEBUG_TRACE(1, "ESS", "SPETRT: " + num$(SPETRT)) From DEBUGTRACE

#Call DEBUG_TRACE(1, "ESS", "Call TRAITE_CHAR") From DEBUGTRACE

Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKSIG","",5,SPETRT) From GTRAITE


GOK = val(PARAM(6))

#Call DEBUG_TRACE(1, "ESS", "GOK " + num$(GOK)) From DEBUGTRACE


Raz GCOMMENTSIG

End

################################################################################
#
# Renvoie les suivis workflows
#
################################################################################

Subprog MESFLUX( MATRICULE,DATDEB,DATFIN,EVENEMENT,ETAT,DEMANDE, FONCTION,DATENV,CODEVT
&              , TEXSUI,ETAPE,CHRONO,VALCTX1,VALCTX2,VALCTX3,VALCTX4,VALCTX5,VALCTX6
&              )
Value    Char    MATRICULE, EVENEMENT, FONCTION
Value    Date    DATDEB, DATFIN
Value    Integer ETAT
Value    Char    DEMANDE()    : # 74301
Variable Date    DATENV(0..)
Variable Char    CODEVT()(0..), TEXSUI()(0..), ETAPE()(0..), CHRONO()(0..)
Variable Char    VALCTX1()(0..), VALCTX2()(0..), VALCTX3()(0..), VALCTX4()(0..)
Variable Char    VALCTX5()(0..), VALCTX6()(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:AWS]) : Local File AWRKHISSUI [AWS] : Endif
If !clalev([F:AUS]) : Local File AUTILIS    [AUS] : Endif

Local Char     CRITERE(250)
Local Shortint N

If [L]MATRICULE>""   : [L]CRITERE-="& VALCTX1='"+[L]MATRICULE+"'"               : Endif
If [L]DATDEB>[0/0/0] : [L]CRITERE-="& DATENV>=["+format$([V]GFMD,[L]DATDEB)+"]" : Endif
If [L]DATFIN>[0/0/0] : [L]CRITERE-="& DATENV<=["+format$([V]GFMD,[L]DATFIN)+"]" : Endif
If [L]EVENEMENT>""   : [L]CRITERE-="& CODEVT='"+[L]EVENEMENT+"'"                : Endif

Case [L]ETAT
 When 1 : [L]CRITERE-="& FLGSIG=3"
 When 2 : [L]CRITERE-="& FLGSIG=5 & ACTSIG='REF'"
 When 3 : [L]CRITERE-="& FLGSIG=5 & ACTSIG='VIS'"
Endcase
#74301 If [L]DEMANDE>0 & [L]FONCTION>""
# [L]CRITERE-="& VALCTX2='"+num$([L]DEMANDE)+"' & ABROBJ='"+[L]FONCTION+"'"
#Else
# [L]CRITERE -= "& (ABROBJ = 'DCG' | ABROBJ = 'DPI' | ABROBJ = 'EXS')"  : # 62590
#endif
If [L]DEMANDE <> "" & [L]FONCTION<>""
 [L]CRITERE-="& VALCTX2='"+[L]DEMANDE+"' & ABROBJ='"+[L]FONCTION+"'"
Else
 [L]CRITERE -= "& (ABROBJ = 'DCG' | ABROBJ = 'DPI' | ABROBJ = 'EXS'"  : # 62590
 [L]CRITERE -= "| ABROBJ = 'HRPPH')"
Endif
# 62075
[L]CRITERE -=  "& (ABROBJ <> 'DPI' | VALCTX3 <> '1')" : # On affiche pas les saisies DPI en C/S

If [L]CRITERE="" : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif

Filter [AWS] Order By Key CLE=DATENV Desc;TIMENV Desc
For [AWS] Where evalue([L]CRITERE)
  If N>=dim([L]CHRONO)
   [V]GERR=1
  Else
   [L]DATENV (N)=[F:AWS]DATENV
   [L]CODEVT (N)=[F:AWS]CODEVT
   [L]TEXSUI (N)=[F:AWS]TEXSUI
   [L]CHRONO (N)=[F:AWS]CHRONO
   [L]VALCTX1(N)=[F:AWS]VALCTX1
   [L]VALCTX2(N)=[F:AWS]VALCTX2
   [L]VALCTX3(N)=[F:AWS]VALCTX3
   [L]VALCTX4(N)=[F:AWS]VALCTX4
   [L]VALCTX5(N)=[F:AWS]VALCTX5
   [L]VALCTX6(N)=[F:AWS]VALCTX6
   [L]ETAPE(N)  =mess([F:AWS]FLGSIG,2922,1)    : # 62113
   Case [F:AWS]FLGSIG
    When 5
     Case [F:AWS]ACTSIG
      When "REF" : [L]ETAPE(N)=mess(4,10743,1)
      When "VIS" : [L]ETAPE(N)=mess(3,10743,1)
      When "ANN" : [L]ETAPE(N)=mess(1,2922,1)  : # 62113
     Endcase
    When 3
     Read [AUS]CODUSR=evalue("[F:AWS]USRSIG"+num$([F:AWS]LEVSIG+1))
     [L]ETAPE(N)=func AFNC.MES3( mess(67,10701,1),num$([F:AWS]LEVSIG+1),num$([F:AWS]NBRUSR)
&                            , [F:AUS]NOMUSR
&                            )
   #                           Etape $1$ sur $2$, en attente de la signature de $3$
   Endcase
  Endif
  N+=1
Next
Filter [AWS]

If [V]GERR
 [V]GMESSAGE="MESFLUX :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables inférieure à $1$
Endif

End

################################################################################
#
# Renvoie les suivis workflows bis (avec moins d'infos et moins de critères de sélection)
#
################################################################################

Subprog FLUX(MAT,DEB,FIN,EVT,ETAT,EMETTEUR,REFNUM,DATENV,CODEVT,TEXSUI,ETAPE,CHRONO)
Value    Char    MAT, EVT
Value    Date    DEB, FIN
Value    Integer ETAT
Variable Date    DATENV(0..)
Variable Char    EMETTEUR()(0..), REFNUM()(0..), CODEVT()(0..), TEXSUI()(0..)
Variable Char    ETAPE()(0..), CHRONO()(0..)

If [V]GFONCTION<>"GESEML"
 [V]GFONCTION="GESEML"
 Call AUTORIS From EXEFNC
Endif

If !clalev([F:AWS]) : Local File AWRKHISSUI [AWS] : Endif
If !clalev([F:AUS]) : Local File AUTILIS    [AUS] : Endif
If !clalev([F:ADU]) : Local File ADOVALAUS  [ADU] : Endif

Local Char     CRITERE(250)
Local Shortint N

If [L]MAT>"" : [L]CRITERE-="& pat(CLEOBJ,'*"+[L]MAT+"')" : Endif
If [L]DEB>[0/0/0] : [L]CRITERE-="& DATENV>=["+format$([V]GFMD,[L]DEB)+"]" : Endif
If [L]FIN>[0/0/0] : [L]CRITERE-="& DATENV<=["+format$([V]GFMD,[L]FIN)+"]" : Endif
If [L]EVT>"" : [L]CRITERE-="& CODEVT='"+[L]EVT+"'" : Endif
Case [L]ETAT
 When 1 : [L]CRITERE-="& FLGSIG=3"
 When 2 : [L]CRITERE-="& FLGSIG=5 & ACTSIG='REF'"
 When 3 : [L]CRITERE-="& FLGSIG=5 & ACTSIG='VIS'"
Endcase

# 62590
[L]CRITERE -= "& (ABROBJ = 'DCG' | ABROBJ = 'DPI' | ABROBJ = 'EXS')"
# 62075
[L]CRITERE -= "& (ABROBJ <> 'DPI' | VALCTX3 <> '1')" : # On affiche pas les saisies DPI en C/S

If [L]CRITERE="" : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif

Link [AWS] With [ADU]ADU1="REFNUM";EMETTEUR As [LNK]

For [LNK]AWS0 Where evalue([L]CRITERE)
 If N>=dim([L]REFNUM)
  [V]GERR=1
 Else
  [L]REFNUM  (N)=right$([F:AWS]CLEOBJ,1+instr(1,[F:AWS]CLEOBJ,"~"))
  [L]DATENV  (N)=[F:AWS]DATENV
  [L]CODEVT  (N)=[F:AWS]CODEVT
  [L]TEXSUI  (N)=[F:AWS]TEXSUI
  [L]CHRONO  (N)=[F:AWS]CHRONO
  [L]EMETTEUR(N)=[F:ADU]VALEUR
  [L]ETAPE(N)   =mess([F:AWS]FLGSIG,2922,1) : # 62113
  Case [F:AWS]FLGSIG
  When 5
   Case [F:AWS]ACTSIG
    When "REF" : [L]ETAPE(N)=mess(4,10743,1) : # Refusé
    When "VIS" : [L]ETAPE(N)=mess(3,10743,1) : # Validé
    When "ANN" : [L]ETAPE(N)=mess(1,2922,1)  : # 62113
   Endcase
  When 3
   Read [AUS]CODUSR=evalue("[F:AWS]USRSIG"+num$([F:AWS]LEVSIG+1))
   [L]ETAPE(N)=func AFNC.MES3( mess(67,10701,1),num$([F:AWS]LEVSIG),num$([F:AWS]NBRUSR)
&                            , [F:AUS]NOMUSR
&                            )
   #                           Etape $1$ sur $2$, en attente de la signature de $3$
  Endcase
 Endif
 N+=1
Next

If [V]GERR
 [V]GMESSAGE="FLUX :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables inférieure à $1$
Endif

End

################################################################################
#
# Renvoie l'intitulé "Etape $1$ sur $2$, en attente de la signature de $3$"
#
################################################################################

Funprog GETETAPE(NBRSIG,NBRUSR,NAMUSR)
Value Integer NBRSIG,NBRUSR
Value Char NAMUSR()
End func AFNC.MES3( mess(67,10701,1),num$([L]NBRSIG+1),num$([L]NBRUSR),[L]NAMUSR)

####################################################
## Accès à un évènement pour un salarié donné
####################################################
Funprog EVTEMP(EMP,EVT)
Value Char EMP , EVT

If clalev([F:ADU3])=0 : Local File ADOVALAUS [ADU3] : Endif
If clalev([F:AUS3])=0 : Local File AUTILIS   [AUS3] : Endif
If clalev([F:TIM3])=0 : Local File TIMCOD    [TIM3] : Endif
If clalev([F:ACC3])=0 : Local File ACCES     [ACC3] : Endif

Filter [F:ADU3] Where PARAM="REFNUM" & VALEUR=EMP
Read [F:ADU3]ADU1 First
Filter [F:ADU3]
If fstat : End 0 : Endif

Read [F:AUS3]CODUSR=[F:ADU3]CODUSR
If fstat : End 0 : Endif

Read [F:TIM3]TIM0=EVT
If fstat : End 0 : Endif

If  [F:AUS3]ALLACS = 2 | [F:TIM3]ACS ="" : End 1 : Endif

Read [ACC3]CODACC = [F:AUS3]USR;[F:TIM3]ACS
If fstat : End 0 : Endif

End ([F:ACC3]CONSUL=2)

####################################################
## Renvoie le code utilisateur (pas le login!) pour un salarié donné
####################################################
Funprog EMPUSR(EMP,USR)
Value Char EMP
Value Char USR
Local Char VALRET (max(GLONEML,GLONAUS))
Local Char CRITVAL (100)

If clalev([F:ADU3])=0 : Local File ADOVALAUS [ADU3] : Endif
If clalev([F:AUS3])=0 : Local File AUTILIS   [AUS3] : Endif
If clalev([F:ID3])=0  : Local File EMPLOID   [ID3]  : Endif

Link [AUS3] With  [ADU3]ADU0 = USR;"REFNUM"
&               , [ID3]ID0 = [ADU3]VALEUR
&           As    [LNK3]
&           Where [AUS3]ENAFLG = 2
&           Order By Key CLE=[AUS3]USR

Raz VALRET

If EMP <> ""
 CRITVAL = '[ADU3]VALEUR=[L]EMP'
Else
 CRITVAL = '[ADU3]CODUSR=[L]USR'
Endif

Filter [LNK3] Where evalue(CRITVAL)
Read [LNK3]CLE First

If EMP <> ""
 VALRET  = [AUS3]USR
Else
 VALRET  = [ID3]REFNUM
Endif

Filter [LNK3]

End VALRET

#########################################################################################################
## Contrôle en saisie du paramètre PRHDEST
#########################################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM()
Value    Char    VALEUR()
Variable Integer OK
If VALEUR="" : End : Endif
If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
OK = 1
Read [F:AIM]AIM0 = VALEUR
If [F:AIM]PRT <> 3
 GMESSAGE = mess(1,10723,1) : # La sortie n'est pas de type 'MESSAGE' sur cette destination
 OK = 0
Elsif PRTSRV = ""
 GMESSAGE = mess(2,10723,1) : # Il n'y a pas de serveur d'édition associé à cette destination
 OK=0
Endif
If OK=0 : mkstat=2 : End : Endif
End


################################################################################
#
# Edite un état dans une destination message
#                                                               WGA
################################################################################

Subprog PRTMSG(CODRPT,TBPAR,TBVAL)
Value  Char CODRPT()
Value  Char TBPAR()(0..)
Value  Char TBVAL()(0..)

Local  Char DESTINATION (GLONAIM)

# Le paramètre général ASAIDEST doit être à "Non"
# Il doit exister une règle de workflow d'édition d'état (voir modèle AIMP,évènmt type 'Divers' Code 'ARP')
# Paramètre 'Destination portail' doit être valorisé (chap.'TC' , grp 'RPT')

If GPRHDEST = ""
 GMESSAGE = mess(3,10723,1) : # Destination non définie
 GERR = 1
Else
 DESTINATION = GPRHDEST
Endif

Call ETAT(CODRPT,DESTINATION,[V]GLANGUE,0,"",TBPAR,TBVAL) From AIMP3

End

################################################################################
#
# Modification du mot de passe
#                                                               WGA
################################################################################

Subprog NEWPASS(OLD,NEW1,NEW2)
Value  Char OLD()
Value  Char NEW1()
Value  Char NEW2()

Local Integer OK

Call MAJ_NEWPASSE(GUSER,OLD,NEW1,NEW2,0,OK) From PASSE

If !OK
 Call ADDMESSERR(GMESSAGE) From AWEB
 GERR = 1
Else
  Call ADDMESSINF(mess(82,100,1)) From AWEB : #  Nouveau mot de passe enregistré 63639
Endif

End

################################################################################
#
# Annulation du mot de passe
#                                                               WGA
################################################################################

Subprog GENPASS(CODUSR)
Value Char CODUSR()

Global Char    CLECUR1(GLONID1)

If clalev([F:AUS])=0  : Local File AUTILIS  [AUS]    : Endif
If clalev([M:AUS0])=0 : Local Mask AUS0     [M:AUS0] : Endif
If clalev([M:AUS1])=0 : Local Mask AUS1     [M:AUS1] : Endif

Gosub OUVRE From WOAUS
Gosub OUVRE From SUBAUS

Read [ADW]ADW0 = "";"";"PASSWD"
If !fstat : PASOBLI = val([F:ADW]VALEUR) : Endif

If CODUSR = ""
 CLECUR1 = GUSER
Else
 CLECUR1 = CODUSR
Endif

Read [AUS]CODUSR = CLECUR1
If fstat
 GMESSAGE = mess(24,100,1) : # Code utilisateur incorrect
 GOK = 0
Else

 [M:AUS0] = [F:AUS] : # Pour le workflow
 [M:AUS1] = [F:AUS]

 Call  DEBTRANS From GLOCK
 Gosub TR_PASSE From SUBAUS
 If GOK
 # Pour avertir l'utilisateur il faut obligatoirement une règle de workflow type divers
 # pour évènt PWD et une adresse mail sur la fiche utilisateur
  Gosub MES_PASSWD From SUBAUS
 Endif

Endif

If !GOK
 Call ADDMESSERR(GMESSAGE) From AWEB
 GERR = 1
Else
 If (PASOBLI=2 or func ARECAUO.USRSAG([F:AUS]USR)) : # 66565
   If MAIL & [F:AUS]ADDEML<>""
 # Nouveau mot de passe attribué à ..(Envoi mail) 63639
     Call ADDMESSINF(mess(86,154,1)-[F:AUS]LOGIN-"("+mess(66,75,1)+")") From AWEB
   Endif
 Else
 # Annulation du mot de passe de ..(Envoi mail) 63639
     Call ADDMESSINF(mess(54,100,1)-[F:AUS]LOGIN) From AWEB
 Endif
Endif

End

#########################################################################################################
## Lecture d'une table diverse
#########################################################################################################
Subprog LEC_ADI(NUMADI,TBCOD,TBLIB,TBSHO,TBA1,TBA2,TBN1,TBN2)
Value     Integer NUMADI
Variable  Char    TBCOD()(0..)
Variable  Char    TBLIB()(0..)
Variable  Char    TBSHO()(0..)
Variable  Char    TBA1()(0..)
Variable  Char    TBA2()(0..)
Variable  Integer TBN1(0..)
Variable  Integer TBN2(0..)

If NUMADI=0 : End : Endif
Local Integer I
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
For [ADI]CODE Where NUMTAB=NUMADI
 TBCOD(I) = [F:ADI]CODE
 Call LECTEXTRA(TBLIB(I),"ATABDIV","LNGDES",num$(NUMADI),TBCOD(I)) From ATEXTRA
 Call LECTEXTRA(TBSHO(I),"ATABDIV","SHODES",num$(NUMADI),TBCOD(I)) From ATEXTRA
 TBA1(I) = [F:ADI]A1
 TBA2(I) = [F:ADI]A2
 TBN1(I) = [F:ADI]N1
 TBN2(I) = [F:ADI]N2
 I+=1
Next
End

################################################################################
# Liste des utilisateurs délégués d'un salarié
# - On échange des matricules avec le portail,
# - on les converti en codes utilisateurs
#   pour HRM
################################################################################

Subprog GETLSTDELWRK(MATRICULE,NODEL,DELEGUE,DELNAM,STRDAT,ENDDAT,NATWRK,TYPDEL,EMLDEL)
Value    Char    MATRICULE
Variable Char    DELEGUE()(0..) , DELNAM()(0..) , NATWRK()(0..) , EMLDEL()(0..)
Variable Date    STRDAT(0..) , ENDDAT(0..)
Variable Integer TYPDEL(0..),NODEL(0..)

Local Char USRMAT (GLONAUS)

Local Char    SYMBOLE(100) , CLECUR2(30)(1..4) , CRITERE (250)
Local Integer N

If !clalev([F:AWU]) : Local File AWRKUSR  [AWU] : Endif
If !clalev([F:ID])  : Local File EMPLOID  [ID]  : Endif
If !clalev([F:AUS]) : Local File AUTILIS  [AUS]  : Endif

USRMAT = func PORSUP.EMPUSR(MATRICULE,"")

If USRMAT = ""
 GMESSAGE = mess(99,10709,1) : # Le salarié n'est pas rattaché à un utilisateur
 GERR    =1
 End
Endif

For [F:AWU] Where USER=USRMAT
 If N >= dim(DELEGUE)
  GERR = 1
  Break
 Endif
 [L]NODEL  (N) = [F:AWU]NUMDEL
 [L]DELEGUE(N) = func PORSUP.EMPUSR("",[F:AWU]USRDEL)
 [L]NATWRK (N) = [F:AWU]NATURE
 [L]TYPDEL (N) = [F:AWU]TYPDEL
 [L]STRDAT (N) = [F:AWU]VLYSTR
 [L]ENDDAT (N) = [F:AWU]VLYEND
 Read [ID]ID0  = DELEGUE(N)
 [L]DELNAM (N) = [ID]NAM-[ID]SRN
 Read [AUS]CODUSR=[F:AWU]USRDEL
 [L]EMLDEL (N) = [F:AUS]ADDEML
 N += 1
Next

If GERR
 GMESSAGE="GETLSTDELWRK :"-func AFNC.MES1(mess(318,199,1),num$(N))
 #           Zone d'échange pleine  ( $1$ )
Endif

End

################################################################################
#
# Mise à jour Délégués workflow
# - On reçoit un matricule de délégué et on crée avec le code utilisateur associé
#   sur la fiche du code utilisateur courant
################################################################################

Subprog SETDELEGWRK(ACTION,MATRICULE,NODEL,DELEGUE,DELNAM,STRDAT,ENDDAT,NATWRK,TYPDEL,EMLDEL)
Value    Char    ACTION
Variable Char    MATRICULE , DELEGUE , DELNAM , NATWRK , EMLDEL
Variable Date    STRDAT , ENDDAT
Variable Integer TYPDEL , NODEL

Local Char USRMAT (GLONAUS)
Local Char USRCOD (GLONAUS)

Local Char SYMBOLE(100) , CLECUR2(30)(1..4) , CRITERE (250)

If !clalev([F:AWU]) : Local File AWRKUSR  [AWU] : Endif
If !clalev([F:ID])  : Local File EMPLOID  [ID]  : Endif
If !clalev([F:AUS]) : Local File AUTILIS  [AUS]  : Endif

USRMAT = func PORSUP.EMPUSR(MATRICULE,"")
USRCOD = func PORSUP.EMPUSR(DELEGUE,"")

If !find([L]ACTION,"DELETE","READ") & USRCOD = ""
  GMESSAGE = mess(99,10709,1) : # Le salarié n'est pas rattaché à un utilisateur
  GERR    =1
  End
Endif

If ACTION<>"CREATE"
 Filter [AWU] Where USER = USRMAT & NUMDEL = [L]NODEL
 Read [AWU] First
 Filter [AWU]
 If fstat
  GMESSAGE=mess(23,100,1) : # Fiche inexistante
  GERR    =1
  End
 Endif
Endif

If !find([L]ACTION,"CREATE","READ")
 SYMBOLE="AWU"+USRMAT
 Lock =SYMBOLE
 If fstat
  GMESSAGE=mess(98,126,1) : # La fiche est utilisée par un autre utilisateur
  GERR    =1
  End
 Endif
Endif

Case [L]ACTION
When "CREATE"
 Trbegin [F:AWU]
  Filter [F:AWU] Where USER=USRMAT
  Read [F:AWU] Last
  If fstat
   NODEL = 1
   fstat = 0
  Else
   NODEL = [F:AWU]NUMDEL + 1
  Endif
  Filter [F:AWU]
  Raz [F:AWU]
  [F:AWU]USER   = USRMAT
  [F:AWU]NUMDEL = [L]NODEL
  [F:AWU]USRDEL = [L]USRCOD
  [F:AWU]NATURE = [L]NATWRK
  [F:AWU]TYPDEL = [L]TYPDEL
  [F:AWU]VLYSTR = [L]STRDAT
  [F:AWU]VLYEND = [L]ENDDAT
  Write [AWU]
 Commit
  If !fstat
   Gosub WORKFLOW
  Else
   GMESSAGE = mess(35,114,1) : # Erreur en transaction de création
   GERR     = 1
  Endif

When "MODIFY"
 Trbegin [AWU]
  Update [AWU] Where USER  = USRMAT & NUMDEL = [L]NODEL
&               With [F:AWU]USRDEL = [L]USRCOD
&                  , [F:AWU]NATURE = [L]NATWRK
&                  , [F:AWU]TYPDEL = [L]TYPDEL
&                  , [F:AWU]VLYSTR = [L]STRDAT
&                  , [F:AWU]VLYEND = [L]ENDDAT
 Commit
 If !fstat
  Gosub WORKFLOW
 Else
  GMESSAGE = mess(50,176,1) : # Erreur lors de la mise à jour
  GERR     = 1
 Endif

When "DELETE"
 Delete [AWU] Where USER=USRMAT & NUMDEL = [L]NODEL

When "READ"
  Filter [F:AWU] Where USER=USRMAT & NUMDEL = [L]NODEL
  Read [F:AWU] First
  [L]DELEGUE= func PORSUP.EMPUSR("",[F:AWU]USRDEL)
  [L]NATWRK = [F:AWU]NATURE
  [L]TYPDEL = [F:AWU]TYPDEL
  [L]STRDAT = [F:AWU]VLYSTR
  [L]ENDDAT = [F:AWU]VLYEND
  Filter [F:AWU]

Endcase

If ACTION <> "DELETE"
 Read [ID]ID0 = DELEGUE
 [L]DELNAM = [ID]NAM-[ID]SRN
 Read [AUS]CODUSR=[F:AWU]USRDEL
 [L]EMLDEL = [F:AUS]ADDEML
Endif

$DELOCK
If SYMBOLE>"" : Unlock=SYMBOLE : Endif

End

$WORKFLOW
# On lance un workflow manuel
Local Integer  SAVSIL
Local Char     PARAM(250)(1..4) , VALEUR(GLONAWA)
Local Mask     AWAM [AWAM]

SAVSIL = GSILENCE
GSILENCE = 1

PARAM(1)  = 'DELEGWRK'              : # Code du workflow manuel
PARAM(2)  = '[F:AWU]USER = "'+[L]USRMAT+'"'
PARAM(2) -= '& [F:AWU]USRDEL = "'+[L]USRCOD+'"'
PARAM(3)  = "1"
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKMAN","SAIWRKMAN",1,"") From GTRAITE

GSILENCE = SAVSIL

Return

#71094
#-------------------------------------------
# Liste des profils
#-------------------------------------------
Subprog GETLSTPRF(USER,FONCTION,NOTSUPP,PRFCOD,PRFDES)
Value Char USER(), FONCTION()
Value Integer NOTSUPP
Variable Char PRFCOD()(0..), PRFDES()(0..)
Local Char     CRITERE(250)

If !clalev([F:PRF]) : Local File PROFIL [PRF] : Endif

Local Char UTILIS([V]GLONAUS)
[L]UTILIS=[V]GUSER
[V]GUSER =[L]USER
Gosub FONCTION
[V]GUSER=[L]UTILIS

# sba variable non déclarée
If dim(N)<1 :Local Integer N : Endif
N=0

[L]CRITERE = "ENAFLG=2"
If [L]NOTSUPP : [L]CRITERE -="& FLGSUP<2" : Endif

For [PRF] Where evalue([L]CRITERE)
 If N>=dim([L]PRFCOD)
  [V]GERR=1
 Else
  [L]PRFCOD(N) = [F:PRF]PRFCOD
  Call LECTEXTRA([L]PRFDES(N),"PROFIL","PRFDES",[F:PRF]LEG,[F:PRF]PRFCOD) From ATEXTRA
 Endif
 N+=1
Next

If [V]GERR
 [V]GMESSAGE="GETLSTPROFILS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables inférieure à $1$
Endif

End
#End 71094

#-------------------------------------------
# Liste des actions workflow possibles
#-------------------------------------------
Subprog GETACTVAL(CHRNO,DST,ANSWER)
Value    Char    CHRNO()
Value    Char    DST()
Variable Char    ANSWER()(0..)

Local Char    PARAM(255)(1..6)
Local Integer NBTEX , I , J , NBCOL , STAT
Local Char    TEX(50)(0..200) , TEXTE(80)(0..200) , TIT(50)(0..5) , VEROBJ(80) , ERM(80)

PARAM(1) = [L]CHRNO
PARAM(2) = [L]DST

Gosub SEL_LISTE From SAIWRKSIG

If STAT <> 0 | ERM <> ""
 GERR = 1
 GMESSAGE = ERM
 End
Endif

Raz ANSWER , I , J
For I = 1 To NBTEX
 If TEX(I) <> ""
  ANSWER(J) = TEX(I)
  J+=1
 Endif
Next I

End

##################################################
Subprog WRKFINRER(CHRONO,ADEST)
Value    Char    CHRONO(), ADEST()
  Update [F:AWS2] Where CHRONO = CHRONO & DEST = ADEST
&                 With  VALCTX8 = ""
End

#**
#* Retourne le nom-prénom d'un matricule
#*
#* @param REFNUM : matricule à rechercher
#*!
Funprog NAMREFNUM(REFNUM)
Value Char REFNUM()
Local Char RET(250)

  If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
  Read [F:ID]ID0=REFNUM
  If !fstat Then
    RET=[F:ID]NAM-[F:ID]SRN
  Endif
End RET



