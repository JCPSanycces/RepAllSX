Funprog IS_SUPPLIER_INVOICE(INV)
  Value Char INV
  Local Integer EXIST
  EXIST = 0

  If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif

  For [TPV] Where GTE=INV
    EXIST += 1
  Break
  Next

  If EXIST = 0
    End 0
  Else
    End 1
  Endif
End


#*****************************************************************************************************
Funprog STRIP_ZEROS(STRING)
Value Char STRING
Local Integer I
Local Char TMPSTR(200)
TMPSTR = STRING
# delete leading zeros from STRING
Repeat
  I = instr(1,TMPSTR,"0")
  If I = 1                   # first character is "0"
     If len(TMPSTR) > 1
        TMPSTR = right$(TMPSTR,2)
     Else
        TMPSTR = ""
     Endif
  Else
     I = 0
  Endif
Until I = 0

End TMPSTR


#*****************************************************************************************************
Subprog GET_LEG(CPY,LEG)
Variable Char CPY
Variable Char LEG

If CPY <> ""
   If clalev([F:CPY])  & [F:CPY]CPY = CPY
      LEG = [F:CPY]LEG
   Else
      If !clalev([F:XCPY])  : Local File COMPANY  [XCPY]  : Endif
      Read [F:XCPY]CPY0 = CPY
      If !fstat
          LEG = [F:XCPY]LEG
      Endif
   Endif
Endif
End

#-----------------------------------------------------------------------------------------------------
# MODULOR: Recursive modulo 10 for ISR
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
Subprog MODULOR(ENTREE,SORTIE)
Variable Char ENTREE
Variable Char SORTIE
Local Decimal NBCAR
NBCAR = len(ENTREE)
BVRR=0
For I=1 To NBCAR
  BVRR=val(mid$("0946827135",mod(val(mid$(ENTREE,I,1))+BVRR,10)+1,1))
Next I
SORTIE=num$(mod(10-BVRR,10))
End
#-----------------------------------------------------------------------------------------------------



#*****************************************************************************************************
Funprog GET_PAYBAN(CPY, FCY, BPRPAY)
Value Char CPY
Value Char FCY
Value Char BPRPAY
Local Char PAYBAN(GLONBID)

PAYBAN = ""
# if activity code MUL is set, check if paying bank is set in table BPEXCEPT for paying company and business partner
If func AFNC.ACTIV("MUL")
  If !clalev([F:BPE])  : Local File BPEXCEPT [BPE] : Endif
  Read [F:BPE]BPE0 = BPRPAY;CPY
  If !fstat
    PAYBAN = [F:BPE]PAYBANBVR
  Endif
Endif
# if paying bank is not found, check paying bank of paying customer
If PAYBAN = ""
  If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC] : Endif
  Read [F:BPC]BPC0 = BPRPAY
  If !fstat
    PAYBAN = [F:BPC]PAYBAN
  Endif
Endif
# if paying bank is not found, check paying bank of facility
If PAYBAN = ""
  If !clalev([F:FCY])  : Local File FACILITY [FCY] : Endif
  Read [F:FCY]FCY0 =  FCY
  If !fstat
    PAYBAN = [F:FCY]PAYBAN
  Endif
Endif
End PAYBAN


#*****************************************************************************************************
Funprog BUILD_BVRREFNUM(FCY,BVRNUM,BPRPAY,ACCDAT,INVNUM)
Value Char FCY
Value Char BVRNUM
Value Char BPRPAY
Value Date ACCDAT
Value Char INVNUM

Local Char REFNUM(27)
Local Integer START_(4) # array of 4 elements for the start positions
Local Integer END_(4)   # array of 4 elements for the end positions
Local Char TYPE_(4)(4)  # array of 4 elements for the type of the element (either invoice number, customer, date or ISR identifier)
Local Char TMP_(26)
Local Char MODULO10_(255)
Local Integer I

    # get parameter values for the start/end positions of the fields invoice number, customer, date and ISR identifier in the ISR
    TYPE_(0)  = "INV"
    START_(0)= int(val(func AFNC.PARAM("BVRSTRINV", FCY)))   # start position of invoice number in ISR
    END_(0)  = int(val(func AFNC.PARAM("BVRENDINV", FCY)))   # end position of invoice number in ISR
    TYPE_(1)  = "BPC"
    START_(1)= int(val(func AFNC.PARAM("BVRSTRBPC", FCY)))   # start position of customer number in ISR
    END_(1)  = int(val(func AFNC.PARAM("BVRENDBPC", FCY)))   # end position of customer number in ISR
    TYPE_(2)  = "DAT"
    START_(2)= int(val(func AFNC.PARAM("BVRSTRDAT", FCY)))   # start position of date in ISR
    END_(2)  = int(val(func AFNC.PARAM("BVRENDDAT", FCY)))   # end position of date in ISR
    TYPE_(3)  = "IDT"
    START_(3)= int(val(func AFNC.PARAM("BVRSTRIDT", FCY)))   # start position of ISR identifier in ISR
    END_(3)  = int(val(func AFNC.PARAM("BVRENDIDT", FCY)))   # end position of ISR identifier in ISR

    Sorta START_, END_, TYPE_     # sort the arrays by position

    Raz TMP_
    For I = 0 To 3
        Gosub ADD_COMPONENT
    Next I

    If END_(3)<26                 # add zeros if shorter than 26
        TMP_+=string$((26-END_(3)),"0")
    Endif

    Call MODULOR(TMP_,MODULO10_)  # calculate check digit
    REFNUM = TMP_ + MODULO10_     # add check digit
End REFNUM



#*****************************************************************************************************
$ADD_COMPONENT
    If START_(I)>0
       If I = 0                          # first component -> no filling zeros necessary
          TMP_=string$(START_(I)-1,"0")
       Else                              # from second component -> check if gap between previous and actual component
          If START_(I)-END_(I-1)>1       # gap found -> add zeros
             TMP_+=string$((START_(I)-END_(I-1)-1),"0")
          Endif
       Endif
       Case TYPE_(I)
           When "DAT" : TMP_+=format$("N0:"+num$(END_(I)-START_(I)+1),mid$(format$("D:DDMMYYYY",ACCDAT),1,END_(I)-START_(I)+1))
           When "BPC" : TMP_+=format$("N0:"+num$(END_(I)-START_(I)+1),mid$(BPRPAY,1,END_(I)-START_(I)+1))
           When "INV" : TMP_+=format$("N0:"+num$(END_(I)-START_(I)+1),mid$(INVNUM,1,END_(I)-START_(I)+1))
           When "IDT" : TMP_+=format$("N0:"+num$(END_(I)-START_(I)+1),mid$(BVRNUM,1,END_(I)-START_(I)+1))
       Endcase
    Endif
Return


# 2016-01-12 DNE INSERT BEGIN (SAM #99458) ##############################
#*****************************************************************************************************
$FILL_BVRREFNUM_INVTOTAL_PAYBAN
    If func AFNC.ACTIV( "KSW" ) and ( "2" = func AFNC.PARAM( "SWICUSBVR", [F:SIH]FCY ) )

        # BVR reference num for BVR line on BVR form.
        [F:ARM]CLEA5 = [F:SIH]BVRREFNUM

        # BVR type (fixed as "01"), invoice total and check sum for BVR line on BVR form.
        Local Char STRTMP( 1 )
        [F:ARM]CLEA6 =  "01"
        [F:ARM]CLEA6 += format$( "N0:8", int( [F:SIH]AMTATI ) )
        [F:ARM]CLEA6 += format$("N0:2", num$( int( ( [F:SIH]AMTATI - int( [F:SIH]AMTATI ) ) * 100 ) ) )
        Call MODULOR( [F:ARM]CLEA6, STRTMP ) From SWILIB0
        [F:ARM]CLEA6 += STRTMP

        # Paying bank
        [F:ARM]CLEA7 = [F:SIH]PAYBAN
    Endif
Return
# 2016-01-12 DNE INSERT END #############################################


# 2016-01-26 DNE INSERT BEGIN (SAM #99457) ##############################
$SWI_RAPPEN_ROUNDING
    If func AFNC.ACTIV( "KSW" ) and ( [M:SIH0]CUR = "CHF" ) and ( "2" = func AFNC.PARAM( "SWIRNDSIH", [M:SIH0]SALFCY ) )
        Local Integer SIHRNDNEG : SIHRNDNEG = val( func AFNC.PARAM( "SIHRNDNEG", [M:SIH0]SALFCY ) )
        Local Integer SIHRNDPOS : SIHRNDPOS = val( func AFNC.PARAM( "SIHRNDPOS", [M:SIH0]SALFCY ) )
        Local Decimal SWIINVATI, SWIDIGITAMT
        Local Integer SWIDIGIT, SWIPOS, SWICOUNT

  # 2016-02-01 DNE INSERT BEGIN
        # Parameter/invoicing element consistency checks
        #
        # Note: We create 2 database connectons for to cache both invoicing elements.
        #       So we don't have to read the database for every change of up and down
        #       rounding.
        #
        If !clalev([F:SWISFI1]) : Local File SFOOTINV [SWISFI1] : Endif
        If !clalev([F:SWISFI2]) : Local File SFOOTINV [SWISFI2] : Endif

        # If necessary read invoicing elements. (Otherwise use "cache".)
        If SIHRNDNEG <> [F:SWISFI1]SFINUM
            Read [F:SWISFI1]SFI0 = SIHRNDNEG
            If fstat
                Call ECR_TRACE( func AFNC.MES2( mess(82,3648,1), num$( SIHRNDNEG), "SIHRNDNEG" ), 2 ) From GESECRAN
                                # 'Please check setup for invoicing element $1$ for use with parameter $2$.
                Return
            Endif
        Endif
        If SIHRNDPOS <> [F:SWISFI2]SFINUM
            Read [F:SWISFI2]SFI0 = SIHRNDPOS
            If fstat
                Call ECR_TRACE( func AFNC.MES2( mess(82,3648,1), num$( SIHRNDPOS), "SIHRNDPOS" ), 2 ) From GESECRAN
                                # 'Please check setup for invoicing element $1$ for use with parameter $2$.
                Return
            Endif
        Endif
  # 2016-02-01 DNE INSERT END

        # Get the line count for invoicing element grid:
        # Find first empty element in the invoicing elements (XFNUM with 0).
        # Otherwise take into account the whole grid.
        SWICOUNT = find( 0, [M:SIHV]XFNUM(0..WNBXFNUM) )
        If SWICOUNT
            SWICOUNT -= 1
        Else
            SWICOUNT = WNBXFNUM
        Endif

        # Remove old rounding entries by setting them to zero.
        SIHRNDNEG = find( SIHRNDNEG, [M:SIHV]XFNUM(0..SWICOUNT) ) - 1
        If SIHRNDNEG >= 0
            [M:SIHV]XFNOT( SIHRNDNEG ) = 0
            [M:SIHV]XFATI( SIHRNDNEG ) = 0
        Endif
        SIHRNDPOS = find( SIHRNDPOS, [M:SIHV]XFNUM(0..SWICOUNT) ) - 1
        If SIHRNDPOS >= 0
            [M:SIHV]XFNOT( SIHRNDPOS ) = 0
            [M:SIHV]XFATI( SIHRNDPOS ) = 0
        Endif

        # Recalculate the invoice gross amount and the correction base value.
        SWIINVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)
        SWIDIGIT = mod( ar2( SWIINVATI ), 0.05 ) * 100

        # Set new rounding values.
        If SWIDIGIT
            Case SWIDIGIT
                When 1, 2
                    SWIDIGIT = 0 - SWIDIGIT
                    SWIPOS = SIHRNDNEG
                When 3, 4
                    SWIDIGIT = 5 - SWIDIGIT
                    SWIPOS = SIHRNDPOS
            Endcase
            If SWIPOS >= 0
                If [M:SIHV]XFTAX( SWIPOS ) = "" : [M:SIHV]XFTAX( SWIPOS ) = GEXETAX : Endif # Fallback.
                SWIDIGITAMT                  = SWIDIGIT * 0.01
                [M:SIHV]XFNOT(      SWIPOS ) = SWIDIGITAMT # Set to 0 if "- VAT" is to be set to 0.
                [M:SIHV]XFNOTP(     SWIPOS ) = SWIDIGITAMT # Set to 0 if "- VAT" is to be set to 0.
                [M:SIHV]XFATI(      SWIPOS ) = SWIDIGITAMT
                [M:SIHV]XFATIP(     SWIPOS ) = SWIDIGITAMT
                [M:SIHV]XFSMI(      SWIPOS ) = SWIDIGITAMT # Set to 0 if "- VAT" is to be set to 0.
                [M:SIHV]XFSMIP(     SWIPOS ) = SWIDIGITAMT # Set to 0 if "- VAT" is to be set to 0.
                [M:SIHV]DTANET01(   SWIPOS ) = SWIDIGITAMT
                [M:SIHV]DTANOT01(   SWIPOS ) = SWIDIGITAMT # Set to 0 if "- VAT" is to be set to 0.
                [M:SIHV]XFDTAAMT(   SWIPOS ) = SWIDIGITAMT
                [M:SIHV]DTAVAT01(   SWIPOS ) = [M:SIHV]XFTAX( SWIPOS )
                [M:SIHV]DTAVATRT01( SWIPOS ) = [M:SIHV]XFRAT( SWIPOS )
            Endif
        Endif
    Endif
Return
# 2016-01-26 DNE INSERT END #############################################

# 2016-02-03 DNE INSERT BEGIN (SAM #101378) #############################
$SWI_CONT_BVR_ISSUES
    If [M:DIA]SNS = 1 and [M:DI2]PAYDUD <> 2 and func AFNC.ACTIV( "KSW" )
&      and ( "2" = func AFNC.PARAM( "SWIPAYBVR", [M:DIA]CPY) or "2" = func AFNC.PARAM( "SWIPAYQR", [M:DIA]CPY ) )
        Local Libelle SWIRETC : Raz SWIRETC

        If [M:DI1]ALLPAM = 2
            Qstbox mess(84,3648,1) - mess(85,3648,1) - mess(104,3648,1) - mess(205,100,1) Using [L]SWIRETC
        Else
            If !clalev([F:CPY])    : Local File COMPANY     [CPY] : Endif
            If !clalev([F:SWITAM]) : Local File TABPAM [F:SWITAM] : Endif

            Call LEC_CPY( [M:DIA]CPY ) From CPTLEC
            Filter [F:SWITAM] Where PAM = [M:DI1]PAM and ( LEG = [F:CPY]LEG or LEG = "" ) and SWIPAMBVR >= 3
&                             Order By PAM; LEG Desc
            Read [F:SWITAM] First
            # X3-29237
            If !fstat
&              If ( ( [F:SWITAM]SWIPAMBVR = 3 and [F:SWITAM]TYP = 826 ) or
&                    ( [F:SWITAM]SWIPAMBVR = 4 and [F:SWITAM]TYP = 28  ) or
&                    ( [F:SWITAM]SWIPAMBVR = 5 and [F:SWITAM]TYP = 1   )                                                       )
                  Qstbox mess(86,3648,1) - mess(87,3648,1) - mess(205,100,1) Using [L]SWIRETC
               Elsif ( [F:SWITAM]SWIPAMBVR = 5 and [F:SWITAM]TYP = 3   )  # maybe QR-bill payment
                  Qstbox mess(100,3648,1) - mess(99,3648,1) - mess(205,100,1) Using [L]SWIRETC
               Endif
            Endif
            Filter [F:SWITAM]
        Endif
        If [L]SWIRETC = 2
           FIN = 1 : Return
        Endif
    Endif
Return
# 2016-02-03 DNE INSERT END #############################################

