# Gestion du masque ORDCALC




##########################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If (VALEUR < [M:ORL]STRDAT & VALEUR <>[0/0/0])
    GMESSAGE = mess(44,199,1) 
    mkstat = 2: GERR=1
Endif
End


##########################################################################
Subprog C_PERQTY(VALEUR)
Variable Decimal VALEUR
  If [M:ORL]ENDDAT < [M:ORL]STRDAT
    GMESSAGE = mess(40,187,1)
    mkstat = 2 :GERR=1
  Endif
End



