#<AdxTL>@(#)0.0.0.0 $Revision$
# dbgmode=1 : Dbgaff
Call AMIGPOR

End

Subprog AMIGPOR

Local Char VALEUR(10), PARAM(10)(1.1)
Call TRAITE_CHAR(VALEUR,PARAM,"","AMIGPOR","AMIGPOR",3,"SPEAMIGPOR") From GTRAITE
End

#####################
$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#####################
$INIT_DIA
[M]STARTUSR="" : [M]ENDUSR="" : [M]STARTME="" : [M]ENDME="" : [M]TRACE=2 : [M]FICJSON="#@C:\temp\" : zonsui="STARTUSR"
Return

#####################
$TERMINE
Return

$EXEC

  Local Integer ERR,N1,N2,N3
  Local Clbfile WCLOB(8)
  If !clalev([AUS]) : Local File AUTILIS : Endif
  If !clalev([AME]) : Local File AMETUTI : Endif
  ##MDP  instanciation C_Alog
  #Dbgaff
  Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance With C_ALOG
  ERR=fmet MYLOG.ABEGINLOG("Portal migration")
  ## end mdp
  If [M]TRACE=2
    Call OUVRE_TRACE("Syracuse transition for users and trade codes"-[M]DOSSIER) From LECFIC
  Endif

  For [AUS]CODUSR Where USR>=[M]STARTUSR and USR<=[M]ENDUSR and ENAFLG=2
    Call ECR_TRACE("**** GENERATION FOR USER"-[AUS]USR-"****",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN

    ##Call GENERATION([AUS]USR,ERR,TRACE,[M]FICJSON+"PORTUSR_"+[AUS]USR+".json") From AMIGSYRPORT
    ## MDP debugging Migration portal
    Call GENERATION([AUS]USR,MYLOG,TRACE,WCLOB,ERR,N1,N2,N3) From AMIGSYRPORT
    Call ECR_TRACE("**** END OF GENERATION FOR USER"-[AUS]USR-"****",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
  Next

  For [AME]AME0 Where CODMET>=[M]STARTME and CODMET<=[M]ENDME
    Call ECR_TRACE("**** GENERATION FOR TRADE CODE"-[AME]CODMET-"****",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    Call GENERATION("_"+[AME]CODMET,ERR,TRACE,[M]FICJSON+"PORTMET_"+[AME]CODMET+".json") From AMIGSYRPORT
    Call ECR_TRACE("**** END OF GENERATION FOR TRADE CODE"-[AME]CODMET-"****",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
  Next

  If [M]TRACE=2
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran AMIGPOR) 07/06/2012 11:17:17 (DOM)
######################################################################################
Subprog D_DOSSIER(VALEUR)
Variable Char    VALEUR()
 VALEUR=nomap
End

Subprog C_TRACE(VALEUR)
Variable Integer VALEUR
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran AMIGPOR) 07/06/2012 13:51:08 (DOM)
######################################################################################
Subprog AS_ENDUSR(VALEUR)
Variable Char    VALEUR()
If [M]STARTUSR<>"" : VALEUR=[M]STARTUSR : Endif
End

Subprog AS_ENDME(VALEUR)
Variable Char    VALEUR()
If [M]STARTME<>"" : VALEUR=[M]STARTME : Endif
End


######################################################################################
