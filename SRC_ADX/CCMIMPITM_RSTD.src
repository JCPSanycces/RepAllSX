#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMIMPITM_CCMIITMD

$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AREAD_AFTER"
          Gosub GET_CHANGE_REQUEST_DETAILS
          Gosub IS_IMPACT_AVAILABLE
      Endcase
Endcase
Return

# Using CRID, get change request details
$GET_CHANGE_REQUEST_DETAILS
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  ASTATUS = fmet SELCHGREQ.AREAD(this.CCMIITM.CRID)
  If  ASTATUS<>[V]CST_AOK
    ASTATUS = fmet  this.ASETERROR ("", "", [V]CST_AERROR)
  Else
    this.PRODUCT = SELCHGREQ.PRODUCT
    this.CRSTATUS = SELCHGREQ.CRSTATUS
    this.CCMUSRID = SELCHGREQ.CCMUSRID
  Endif
  FreeGroup SELCHGREQ
Return

# ------------------------------------------------------
# Subroutine: IS_IMPACT_AVAILABLE
#
# Called from this Script.
# Is Impact Analysis available?
#
$IS_IMPACT_AVAILABLE

  Local Integer LOCAL_STATUS

  If (this.CCMIITM.IMPACTANAL = 0)
    LOCAL_STATUS = fmet this.ASETERROR("", mess(69,2038,1), CST_AWARNING)
  Elsif (this.CCMIITM.IMPACTANAL = 1)
    LOCAL_STATUS = fmet this.ASETERROR("", mess(68,2038,1), CST_AWARNING)
  Endif

Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
