#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
###################################################################################
#
#  Balance sheet inquiry
#
###################################################################################
###################################################################################
#--- Direct execution
###################################################################################
###################################################################################
Raz GNBMASKOUV
Local Char PARAM(10)(1..7)
Call GCONSULT("BSE","",PARAM) From GCONSULT
End
###################################################################################
###################################################################################
#--- Patch integration. Inquiry screens validation
###################################################################################
###################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"BSE") From SUBGTC

End
###################################################################################
###################################################################################
$ACTION

Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "LECTURE"     : Gosub LECTURE
  When "LISTE1"      : Gosub LISTE1
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "FERME"       : Gosub FERME
  When "SEL_LISTE"   : Gosub SEL_LISTE
  When "DEB_CRIT"    : Gosub DEB_CRIT
Endcase

Return
###################################################################################
###################################################################################
$OUVRE

Local Integer SPSTAT, TYPBAL, SLEDTYP
Local Char    TYPDEV(1), LASTGRU(GLONGRY)
Local Integer I, J, K, CTLACS, CTLFIRSTLECT, WILD_CHARS
Local Integer NOL
Local Integer DERPER, MAXPER(0..50)
Local Integer E, EDEB, EFIN, PDEB, PFIN, BDEB, BFIN, CRENOGRUFLG, GRYACCFLG, VOIACCFLG
Local Libelle XDEV, PLEIN, GRP, LIG, COHGRP
Local Decimal EXERCICE, PERIODE, MONTANT, MT
Local Char    FILBAL(250), FILBSI(250), FILGRY(250), FILGYK(250), FILGYK_VOID(250), FILACC_VOID(250)
Local Char    RACDEB(GLONGAC), RACFIN(GLONGAC), CPDEB(GLONGAC), CPFIN(GLONGAC), GADEB(50), GAFIN(50), ACCGRYDEB(GLONGAC), ACCGRYFIN(GLONGAC)
Local Char    SACCUR(GLONSAC), CPTCUR(GLONGAC), COLL(GLONGAC), DEVLEC(GLONCUR), DEVSOC(GLONCUR),DEVLED(GLONCUR)
Local Date    DDEB, DFIN, DEBEX
Local Integer NBSITE, COURTYP

CTLFIRSTLECT = 0

NBSITE = max(1,GNBSITE)
Local Integer TPDEB(1..NBSITE) , TPFIN(1..NBSITE)
Local Integer TEDEB(1..NBSITE) , TEFIN(1..NBSITE) , TMAXPER(0..50,1..NBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE), TSOCIETE(GLONCPY)(1..NBSITE)

Local Char    TDEVLEC(GLONCUR)(1..NBSITE) , TDEVSOC(GLONCUR)(1..NBSITE)
Local Char    TDEVLED(GLONCUR)(1..NBSITE)

NBSITE = 0
Local Decimal DEB, CRE, DEBANT, CREANT
Local Decimal DEBLED, CRELED, DEBANTLED, CREANTLED
RACDEB=""
DERPER = dim([F:BAL]DEB)-1

#--- Tables
If !clalev([F:BSI])  : Local File BSEINQ     [BSI]  : Endif
If !clalev([F:BSI2]) : Local File BSEINQ     [BSI2] : Endif
If !clalev([F:GRY])  : Local File GACCGRUPYM [GRY]  : Endif
If !clalev([F:GYK])  : Local File GACCPYMLIK [GYK]  : Endif

#--- Variables
Local Integer LINCOUNTER
Local Integer ASTATUS

Gosub DEFCRIT

Return
###################################################################################
###################################################################################
$DEFCRIT

If [M:BSE1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:BSE1]FCY,GUSRFCY(1..GNBAUZ))
 [M:BSE1]FCY=""
Endif
DDEB=[M:BSE1]DATDEB
DFIN=[M:BSE1]DATFIN
For I=1 To dim(PARAM)
 Case I
  When 1 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BSE1]CPY = PARAM(I)
     If [M:BSE1]FCY<>""
      Call LECTURE("FCY",[M:BSE1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:BSE1]CPY : [M:BSE1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 2 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:BSE1]FCY = PARAM(I)
     [M:BSE1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
   Endif
  When 3 : # Type de référentiel
   If clalev([GCM])=0 : Local File GACM [GCM] : Endif
   If clalev([LED])=0 : Local File GLED [LED] : Endif
   If val(PARAM(I))<>0
    If [M:BSE1]CPY<>""
     Call LECTURE("CPY",[M:BSE1]CPY,"") From CONTOBJ
     Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
     If [F:GCM]LED(val(PARAM(I))-1)<>""
      Call LECTURE ("LED",[F:GCM]LED(val(PARAM(I))-1),"") From CONTOBJ
      [M:BSE1]LEDTYP = val(PARAM(I))
      [M:BSE1]COA    = [F:LED]COA
     Endif
    Endif
   Endif
   If [M:BSE1]LEDTYP = 0 :  [M:BSE1]LEDTYP = 1 : Endif
  When 4 : # Collectif
   If PARAM(I)<>""
    Read [GAC]GAC1 = [M:BSE1]COA;PARAM(I)
    If !fstat & [F:GAC]SAC=2 : [M:BSE1]SAC = PARAM(I) : Endif
   Endif
  When 5 : # Filtre
   If PARAM(I)<>""
    mkstat=0 : Call C_CPDEB(PARAM(I))
    If !mkstat : [M:BSE1]CPDEB = PARAM(I) : Endif
   Endif
  When 6 : # Date début
   If instr(1,PARAM(I),"/")
    [M:BSE1]DATDEB = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:BSE1]DATDEB = PARAM(I)
   Endif
  When 7 : # Date fin
   If instr(1,PARAM(I),"/")
    [M:BSE1]DATFIN = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:BSE1]DATFIN = PARAM(I)
   Endif
  When 8 : Break
 Endcase
Next I

# Valeurs par défaut
Default Mask [BSE1]
Call INIT(DDEB,DFIN) From CONSSUB
[L]ASTATUS = func FINACC_SYRA.GET_LEDCOA(GACTX,[M:BSE1]CPY,[M:BSE1]LEDTYP,[M:BSE1]COA,GMESSAGE)
If [F:COA]COA <> [M:BSE1]COA
  Read [F:COA]COA0 = [M:BSE1]COA
Endif
[M:BSE1]GYM = [F:COA]PYRREF
If [M:BSE1]DETAIL<>2 : Diszo [M:BSE1]VOIVAL, OUTPYR : Affzo [M:BSE1]VOIVAL, OUTPYR : Endif

If [M:CBSE]HBILAN=0  : [M:CBSE]HBILAN  = 2 : Endif
If [M:CBSE]ANOUV=0   : [M:CBSE]ANOUV   = 2 : Endif
If [M:CBSE]CLOTURE=0 : [M:CBSE]CLOTURE = 2 : Endif

Gosub CRITENT From =PROGCNS

Return
###################################################################################
###################################################################################
$DEB_CRIT
If [M]DETAIL<>2 : Diszo [M]VOIVAL, OUTPYR : Affzo [M]VOIVAL, OUTPYR : Endif
Return
###################################################################################
###################################################################################
$LECTURE
If [M:BSE1]CPY=""  | [M:BSE1]DATDEB=[0/0/0] | [M:BSE1]DATFIN=[0/0/0] | ([M:BSE1]GYM="" & [M:BSE1]SAC="") : NBLU=0 : Return : Endif

If [M:BSE1]LEVEL = 0 & [M:BSE1]DETAIL <> 2 & [M:BSE1]MULLEV <> 2 & CTLFIRSTLECT = 1 & [M:BSE1]SAC=""
  Call MESSAGE(mess(65,109,1)) From GESECRAN
  Return
Endif

CTLFIRSTLECT = 1

Effzo [M:BSE2]5
XDEV = 0
Call LECTURE("CPY",[M:BSE1]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG<>2
 # On ne ifie plus que la cohérence des débuts de période (exercices décalés autorisés)
 Call CNTCOHPERV6([M:BSE1]CPY,[M:BSE1]LEDTYP,[M:BSE1]DATDEB,[M:BSE1]DATFIN,SPSTAT,GMESSAGE) From CPTCNT
 If SPSTAT=0 : Return : Endif
Endif

Gosub INIT
If GRP & !COHGRP & (CHGPAG=1 or CHGPAG=3)
 Call MESSAGE(mess(62,109,1)) From GESECRAN : # Les exercices de ce groupe sont décalés, pas de soldes antérieurs
Endif

##################################################################
# Cas des Regroupements de sites :                               #
#  Si on ne posséde pas une devise unique pour l'ensemble des    #
#  sociétés juridiques des sites faisant partie du regroupement  #
#  &  que la devise souhaitée est non renseignée (cas=1) alors   #
#  aucune lecture de la balance n'est possible                   #
##################################################################
If [M:BSE1]CUR="" & XDEV
 GERR=1
 # Devises hétérogènes pour ce regroupement
 GMESSAGE = mess(54,109,1)-[M:BSE1]CPY : Return
Endif

If [M:BSE1]SAC<>""
 Read [GAC]GAC1 = [M:BSE1]COA;[M:BSE1]SAC
 TYPBAL = 2 : COLL = [F:GAC]ACC
Else
 TYPBAL = 1 : COLL = ""
Endif
If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

WILD_CHARS = instr(1,[M:BSE1]CPDEB,"*")
K = instr(1,[M:BSE1]CPDEB,"?")

If     WILD_CHARS & K : WILD_CHARS = min(WILD_CHARS,K)
Elsif !WILD_CHARS & K : WILD_CHARS = K
Endif

If WILD_CHARS
 RACDEB = left$([M:BSE1]CPDEB,WILD_CHARS-1)
 If RACDEB<>""
  RACFIN = left$(RACDEB,len(RACDEB)-1)+chr$(ascii(mid$(RACDEB,len(RACDEB),1))+1)
 Endif
Endif

If [M:BSE1]OUTPYR = 2
  CRENOGRUFLG = 1
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:BSE2] : Endif
If CHGPAG=1 #& [M:BSE1]GYM <> ""
  Gosub INI_PYR_DATA
  If !GRP
    Gosub LECT
  Else
    Gosub LECT_GRP
  Endif
  If OK : Gosub GRU_TOTAUX : Endif
  If [M:BSE1]VOIVAL = 2 & OK & [M:BSE1]SAC="" : Gosub VOIVAL : Endif
Endif
Gosub PRESENT_RESULTS
SACCUR = [M:BSE1]SAC
CPTCUR = [M:BSE1]CPDEB

## Demande de modif 14308 (CP : 04/12/03)
If !CTLACS
 # Vos résultats sont restreints à vos droits utilisateurs
 Call MESSAGE(mess(55,109,1)) From GESECRAN
 Return
Endif

Return
###################################################################################
###################################################################################
# Inquiry for a legal company
###################################################################################
$LECT

Gosub FILTRE

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

If CHGPAG>0
 Filter [BAL] Where evalue(FILBAL)
&             Order By Key CLE = LEDTYP;CPY;FCY;ACC;BPR;FIY;CUR
Else
 Filter [BAL] Where evalue(FILBAL)
&             Order By Key CLE = LEDTYP Desc;CPY Desc;FCY Desc; ACC Desc;BPR Desc;FIY Desc;CUR Desc
Endif

CTLACS = 1
For [BAL]CLE(5) : # BPR
 OK = 1
 If TYPBAL=1
  Read [GAC]GAC0 = [M:BSE1]COA;[F:BAL]ACC
  If !fstat
   If [F:GAC]CLSCOD<>"" & [M:CBSE]HBILAN<>2
    Call LECTURE("COA",[F:GAC]COA,"") From CONTOBJ
    Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
    If [F:CLS]TYP=2
     OK = 0
    Endif
   Endif
  Endif
  If [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT : OK = 0  : CTLACS = 0 : Endif
  Endif
 Endif
 If [M:BSE1]SAC=""
   GRYACCFLG = 0
   Gosub CHECK_ACC_GYM
   If [M:BSE1]OUTPYR <> 2 & GRYACCFLG = 0 : OK = 0 : Endif
   If [M:BSE1]OUTPYR = 2 & [L]CRENOGRUFLG = 1 & GRYACCFLG = 0 : Gosub CRENOGRU : Endif
 Endif
 If OK
  Gosub RAZE
  For [BAL]CLE(6) : # FIY
   For [BAL]CLE
    Gosub CALCUL
   Next : # CLE(6)
  Next : # CLE
  If LIG
   Gosub TOTAUX
   If !OK : Break : Endif
  Endif
 Endif : # (OK)
Next : # CLE
Filter [BAL]

Return
###################################################################################
###################################################################################
# Inquiry for a non legal company
###################################################################################
$LECT_GRP

Gosub FILT_GRP

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

If CHGPAG>0

 Link [BAL] With [FGR]FGR0=[M]CPY;[F:BAL]FCY , [GAC]GAC0=[F:BAL]COA;[F:BAL]ACC
&              , [BPR]BPR0=[F:BAL]BPR , [LED]LED0=[F:BAL]LED
&  As [LNK]
& Where evalue(FILBAL)
& Order By Key CLE2 = LEDTYP;ACC;BPR;CPY;FCY;FIY;CUR

Else

 Link [BAL] With [FGR]FGR0=[M]CPY;[F:BAL]FCY , [GAC]GAC0=[F:BAL]COA;[F:BAL]ACC
&              , [BPR]BPR0=[F:BAL]BPR , [LED]LED0=[F:BAL]LED
&  As [LNK]
& Where evalue(FILBAL)
& Order By Key CLE2 =  LEDTYP Desc; ACC Desc;BPR Desc;CPY Desc;FCY Desc;FIY Desc;CUR Desc

Endif

CTLACS = 1
For [LNK]CLE2(3) : # Compte/tiers
 OK = 1
 If TYPBAL=1
  If [F:GAC]CLSCOD<>"" & [M:CBSE]HBILAN<>2
   Call LECTURE("COA",[F:GAC]COA,"") From CONTOBJ
   Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
   If [F:CLS]TYP=2
    OK = 0
   Endif
  Endif
  If [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT : OK = 0  : CTLACS = 0 : Endif
  Endif
 Endif
 If [M:BSE1]SAC=""
   GRYACCFLG = 0
   Gosub CHECK_ACC_GYM
   If [M:BSE1]OUTPYR <> 2 & GRYACCFLG = 0 : OK = 0 : Endif
   If [M:BSE1]OUTPYR = 2 & [L]CRENOGRUFLG = 1 : Gosub CRENOGRU : Endif
 Endif
 If OK
  Gosub RAZE
  For [LNK]CLE2
   I = find([F:BAL]FCY,TSITE(1..NBSITE))
   If I
    DEVSOC=TDEVSOC(I)
    DEVLED=TDEVLED(I)
    EDEB = TEDEB(I) : EFIN = TEFIN(I) : PDEB = TPDEB(I) : PFIN = TPFIN(I)
    For E=EDEB To EFIN : MAXPER(E) = TMAXPER(E,I) : Next E
    If [F:BAL]FIY>=EDEB & [F:BAL]FIY<=EFIN
     Gosub CALCUL
     If !OK : Break 2 : Endif
    Endif
   Endif
  Next : # [BAL]
  If LIG
   Gosub TOTAUX
  Endif
 Endif
Next

Return
###################################################################################
## Calculs
###################################################################################
$RAZE
Raz LIG
Raz DEB, CRE, DEBANT, CREANT
Raz DEBLED, CRELED, DEBANTLED, CREANTLED
Return

$CALCUL
#
# Pointeurs de la balance
#
E = [F:BAL]FIY
#
# Exercice intermédiaire, on prend tout
#
BDEB = 1
BFIN = MAXPER(E)
#
# 1er Exercice, plus d'à-nouveaux, il y a une colonne spéciale
#
If E=EDEB
 BDEB = PDEB
Endif
#
# Dernier exercice, on ajoute la clôture (sauf société avec exercices décalés)
#
If E=EFIN
 If PFIN=MAXPER(E) & [M:CBSE]CLOTURE=2 & COHGRP : BFIN = DERPER
 Else                                           : BFIN = PFIN
 Endif
Endif
#
# Pour l'Italie, on prend en compte tous les à-nouveaux ????
#
#If [F:LED]ENDVCR=2 & E<>EDEB : # voir CONSBAF
# If BDEB=1 & [M:CBSE]ANOUV=2 : BDEB = 0 : Endif
#Endif

Case TYPDEV

 When "1","2" :
  #cas1 => On renseigne tous les champs (doublons)
  #cas2 => On renseigne les champs normaux dans cette devise ET les champs en devise référentiel

  If COHGRP & E=EDEB
   DEBANT    += sum([F:BAL]DEB(1..BDEB-1))
   CREANT    += sum([F:BAL]CDT(1..BDEB-1))
   DEBANTLED += sum([F:BAL]DEBLED(1..BDEB-1))
   CREANTLED += sum([F:BAL]CDTLED(1..BDEB-1))
   If [M:CBSE]ANOUV=2
    DEBANT    += [F:BAL]DEB(0)
    CREANT    += [F:BAL]CDT(0)
    DEBANTLED += [F:BAL]DEBLED(0)
    CREANTLED += [F:BAL]CDTLED(0)
    #Si ANOUV et que FINEX executer alors on affiche pas cette ligne ds la balance
    If DEBANTLED=CREANTLED
     DEBANTLED=0
     CREANTLED=0
     LIG=0
    Endif
   Endif
  Endif
  DEB       += sum([F:BAL]DEB(BDEB..BFIN))
  CRE       += sum([F:BAL]CDT(BDEB..BFIN))
  DEBLED    += sum([F:BAL]DEBLED(BDEB..BFIN))
  CRELED    += sum([F:BAL]CDTLED(BDEB..BFIN))

 When "3" :

  #cas3 => On ne renseigne que les champs en devise référentiel
  If COHGRP & E=EDEB
   DEBANTLED += sum([F:BAL]DEBLED(1..BDEB-1))
   CREANTLED += sum([F:BAL]CDTLED(1..BDEB-1))
   If [M:CBSE]ANOUV=2
    DEBANTLED += [F:BAL]DEBLED(0)
    CREANTLED += [F:BAL]CDTLED(0)
    #Si ANOUV et que FINEX executer alors on affiche pas cette ligne ds la balance
    If DEBANTLED=CREANTLED
     DEBANTLED=0
     CREANTLED=0
     LIG=0
    Endif
   Endif
  Endif
  DEBLED    += sum([F:BAL]DEBLED(BDEB..BFIN))
  CRELED    += sum([F:BAL]CDTLED(BDEB..BFIN))

Endcase


If   DEB<>0    or CRE<>0    or DEBANT<>0    or CREANT<>0
& or DEBLED<>0 or CRELED<>0 or DEBANTLED<>0 or CREANTLED<>0
  LIG = 1
Endif

Return
###################################################################################
## Totals, Soldes
###################################################################################
$TOTAUX

Raz [F:BSI]
[L]LINCOUNTER += 1

[F:BSI]ANTDEB    = DEBANT
[F:BSI]ANTCDT    = CREANT
[F:BSI]DEB       = DEB
[F:BSI]CDT       = CRE
[F:BSI]ANTDEBLED = DEBANTLED
[F:BSI]ANTCDTLED = CREANTLED
[F:BSI]DEBLED    = DEBLED
[F:BSI]CDTLED    = CRELED

Case TYPDEV
 When "1","2" :

# Totaux en devises

  If [F:BSI]ANTDEB>[F:BSI]ANTCDT
   [F:BSI]ANTDEB = [F:BSI]ANTDEB-[F:BSI]ANTCDT
   [F:BSI]ANTCDT = 0
  Else
   [F:BSI]ANTCDT = [F:BSI]ANTCDT-[F:BSI]ANTDEB
   [F:BSI]ANTDEB = 0
  Endif
  If [F:BSI]DEB>[F:BSI]CDT
   [F:BSI]SOLDEB = [F:BSI]DEB-[F:BSI]CDT
   [F:BSI]SOLCDT = 0
  Else
   [F:BSI]SOLCDT = [F:BSI]CDT-[F:BSI]DEB
   [F:BSI]SOLDEB = 0
  Endif
  [F:BSI]SOLPER = [F:BSI]SOLDEB-[F:BSI]SOLCDT

  [F:BSI]FINDEB = [F:BSI]ANTDEB-[F:BSI]ANTCDT+[F:BSI]SOLDEB-[F:BSI]SOLCDT
  If [F:BSI]FINDEB<0
   [F:BSI]FINCDT = -[F:BSI]FINDEB
   [F:BSI]FINDEB = 0
  Endif
  [F:BSI]SOLFIN = [F:BSI]FINDEB-[F:BSI]FINCDT

# Totaux en devise référentiel

  If [F:BSI]ANTDEBLED>[F:BSI]ANTCDTLED
   [F:BSI]ANTDEBLED = [F:BSI]ANTDEBLED-[F:BSI]ANTCDTLED
   [F:BSI]ANTCDTLED = 0
  Else
   [F:BSI]ANTCDTLED = [F:BSI]ANTCDTLED-[F:BSI]ANTDEBLED
   [F:BSI]ANTDEBLED = 0
  Endif
  If [F:BSI]DEBLED>[F:BSI]CDTLED
   [F:BSI]SOLDEBLED = [F:BSI]DEBLED-[F:BSI]CDTLED
   [F:BSI]SOLCDTLED = 0
  Else
   [F:BSI]SOLCDTLED = [F:BSI]CDTLED-[F:BSI]DEBLED
   [F:BSI]SOLDEBLED = 0
  Endif
  [F:BSI]SOLPERLED = [F:BSI]SOLDEBLED-[F:BSI]SOLCDTLED

  [F:BSI]FINDEBLED = [F:BSI]ANTDEBLED-[F:BSI]ANTCDTLED+[F:BSI]SOLDEBLED-[F:BSI]SOLCDTLED
  If [F:BSI]FINDEBLED<0
   [F:BSI]FINCDTLED = -[F:BSI]FINDEBLED
   [F:BSI]FINDEBLED = 0
  Endif
  [F:BSI]FINSALLED = [F:BSI]FINDEBLED-[F:BSI]FINCDTLED

 When "3" :

# Totaux en devise référentiel

  If [F:BSI]ANTDEBLED>[F:BSI]ANTCDTLED
   [F:BSI]ANTDEBLED = [F:BSI]ANTDEBLED-[F:BSI]ANTCDTLED
   [F:BSI]ANTCDTLED = 0
  Else
   [F:BSI]ANTCDTLED = [F:BSI]ANTCDTLED-[F:BSI]ANTDEBLED
   [F:BSI]ANTDEBLED = 0
  Endif
  If [F:BSI]DEBLED>[F:BSI]CDTLED
   [F:BSI]SOLDEBLED = [F:BSI]DEBLED-[F:BSI]CDTLED
   [F:BSI]SOLCDTLED = 0
  Else
   [F:BSI]SOLCDTLED = [F:BSI]CDTLED-[F:BSI]DEBLED
   [F:BSI]SOLDEBLED = 0
  Endif
  [F:BSI]SOLPERLED = [F:BSI]SOLDEBLED-[F:BSI]SOLCDTLED

  [F:BSI]FINDEBLED = [F:BSI]ANTDEBLED-[F:BSI]ANTCDTLED+[F:BSI]SOLDEBLED-[F:BSI]SOLCDTLED
  If [F:BSI]FINDEBLED<0
   [F:BSI]FINCDTLED = -[F:BSI]FINDEBLED
   [F:BSI]FINDEBLED = 0
  Endif
  [F:BSI]FINSALLED = [F:BSI]FINDEBLED-[F:BSI]FINCDTLED

Endcase
Local Integer DIV
If [M:BSE1]DIVISE<>0
 DIV = [M:BSE1]DIVISE
Else
 DIV = 1
Endif

[F:BSI]ANTDEB    /= DIV
[F:BSI]ANTCDT    /= DIV
[F:BSI]DEB       /= DIV
[F:BSI]CDT       /= DIV
[F:BSI]DEBLED    /= DIV
[F:BSI]CDTLED    /= DIV
[F:BSI]FINDEB    /= DIV
[F:BSI]FINCDT    /= DIV
[F:BSI]SOLFIN    /= DIV

[F:BSI]ANTDEBLED /= DIV
[F:BSI]ANTCDTLED /= DIV
[F:BSI]SOLDEB    /= DIV
[F:BSI]SOLCDT    /= DIV
[F:BSI]SOLPER    /= DIV
[F:BSI]SOLDEBLED /= DIV
[F:BSI]SOLCDTLED /= DIV
[F:BSI]SOLPERLED /= DIV
[F:BSI]FINDEBLED /= DIV
[F:BSI]FINCDTLED /= DIV
[F:BSI]FINSALLED /= DIV

Gosub OTHER_FIELDS

Write [F:BSI]
If fstat
  OK = 0 : Call FSTA("BSI") From GLOCK
Endif

Return
###################################################################################
###################################################################################
$OTHER_FIELDS

[F:BSI]PRONUM = adxuid(2)
[F:BSI]LINNUM = [L]LINCOUNTER
[F:BSI]CPY    = [M:BSE1]CPY
[F:BSI]FCY    = [M:BSE1]FCY
[F:BSI]COA    = [M:BSE1]COA

If [M:BSE1]SAC=""
  [F:BSI]BPR = ""
Else
  [F:BSI]BPR = [F:BAL]BPR
Endif

Case TYPBAL
  When 1
    [F:BSI]ACC    = [F:BAL]ACC
    [F:BSI]GRUACC = [F:BAL]ACC
    Call LECTEXTRA([F:BSI]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  When 2
    [F:BSI]GRUACC = [F:BAL]BPR
    [F:BSI]DES    = [F:BPR]BPRNAM
Endcase

If [M:BSE1]OUTPYR = 2 & GRYACCFLG = 0
  [F:BSI]ORDFLD = string$(GLONGAC+1,"Z")+[F:BSI]GRUACC
Else
  [F:BSI]ORDFLD = [F:BSI]GRUACC
Endif

Return
###################################################################################
###################################################################################
$GRU_TOTAUX

Call DEBTRANS From GLOCK
Trbegin [F:BSI]

For [F:BSI] Where [F:BSI]PRONUM=adxuid(2) and [F:BSI]ACC = "" & [F:BSI]GRU <> ""

  For [F:GYK] Where [F:GYK]PYM = [M:BSE1]GYM & [F:GYK]GRU = [F:BSI]GRU
    For [F:BSI2] Where [F:BSI2]PRONUM = [F:BSI]PRONUM & [F:BSI2]ACC = [F:GYK]ACC & !(len([F:BSI2]ORDFLD)>=GLONGAC+1 & left$([F:BSI2]ORDFLD,GLONGAC+1)=string$(GLONGAC+1,"Z"))
        [F:BSI]ANTDEB    += [F:BSI2]ANTDEB
        [F:BSI]ANTCDT    += [F:BSI2]ANTCDT
        [F:BSI]DEB       += [F:BSI2]DEB
        [F:BSI]CDT       += [F:BSI2]CDT
        [F:BSI]SOLDEB    += [F:BSI2]SOLDEB
        [F:BSI]SOLCDT    += [F:BSI2]SOLCDT
        [F:BSI]SOLPER    += [F:BSI2]SOLPER
        [F:BSI]FINDEB    += [F:BSI2]FINDEB
        [F:BSI]FINCDT    += [F:BSI2]FINCDT
        [F:BSI]SOLFIN    += [F:BSI2]SOLFIN

        [F:BSI]ANTDEBLED += [F:BSI2]ANTDEBLED
        [F:BSI]ANTCDTLED += [F:BSI2]ANTCDTLED
        [F:BSI]DEBLED    += [F:BSI2]DEBLED
        [F:BSI]CDTLED    += [F:BSI2]CDTLED
        [F:BSI]SOLDEBLED += [F:BSI2]SOLDEBLED
        [F:BSI]SOLCDTLED += [F:BSI2]SOLCDTLED
        [F:BSI]SOLPERLED += [F:BSI2]SOLPERLED
        [F:BSI]FINDEBLED += [F:BSI2]FINDEBLED
        [F:BSI]FINCDTLED += [F:BSI2]FINCDTLED
        [F:BSI]FINSALLED += [F:BSI2]FINSALLED

    Next
  Next

#  If [F:BSI]ANTDEB>[F:BSI]ANTCDT
#   [F:BSI]ANTDEB = [F:BSI]ANTDEB-[F:BSI]ANTCDT
#   [F:BSI]ANTCDT = 0
#  Else
#   [F:BSI]ANTCDT = [F:BSI]ANTCDT-[F:BSI]ANTDEB
#   [F:BSI]ANTDEB = 0
#  Endif
#  If [F:BSI]ANTDEBLED>[F:BSI]ANTCDTLED
#   [F:BSI]ANTDEBLED = [F:BSI]ANTDEBLED-[F:BSI]ANTCDTLED
#   [F:BSI]ANTCDTLED = 0
#  Else
#   [F:BSI]ANTCDTLED = [F:BSI]ANTCDTLED-[F:BSI]ANTDEBLED
#   [F:BSI]ANTDEBLED = 0
#  Endif
#
#  If [F:BSI]SOLDEB>[F:BSI]SOLCDT
#   [F:BSI]SOLDEB = [F:BSI]SOLDEB-[F:BSI]SOLCDT
#   [F:BSI]SOLCDT = 0
#  Else
#   [F:BSI]SOLCDT = [F:BSI]SOLCDT-[F:BSI]SOLDEB
#   [F:BSI]SOLDEB = 0
#  Endif
#  If [F:BSI]SOLDEBLED>[F:BSI]SOLCDTLED
#   [F:BSI]SOLDEBLED = [F:BSI]SOLDEBLED-[F:BSI]SOLCDTLED
#   [F:BSI]SOLCDTLED = 0
#  Else
#   [F:BSI]SOLCDTLED = [F:BSI]SOLCDTLED-[F:BSI]SOLDEBLED
#   [F:BSI]SOLDEBLED = 0
#  Endif
#
#  If [F:BSI]FINDEB>[F:BSI]FINCDT
#   [F:BSI]FINDEB = [F:BSI]FINDEB-[F:BSI]FINCDT
#   [F:BSI]FINCDT = 0
#  Else
#   [F:BSI]FINCDT = [F:BSI]FINCDT-[F:BSI]FINDEB
#   [F:BSI]FINDEB = 0
#  Endif
#  If [F:BSI]FINDEBLED>[F:BSI]FINCDTLED
#   [F:BSI]FINDEBLED = [F:BSI]FINDEBLED-[F:BSI]FINCDTLED
#   [F:BSI]FINCDTLED = 0
#  Else
#   [F:BSI]FINCDTLED = [F:BSI]FINCDTLED-[F:BSI]FINDEBLED
#   [F:BSI]FINDEBLED = 0
#  Endif

  Rewrite [F:BSI]
  If fstat
    GOK = 0 : Call FSTA("BSI") From GLOCK : Goto AB_BSI
  Endif

Next

Commit

Return
######################################################################################
######################################################################################
$VOIVAL

Gosub FILTER_GYK_VOI
Gosub FILTER_ACC_VOI

Call DEBTRANS From GLOCK
Trbegin [F:BSI]

Raz [F:BSI]
For [F:GAC]GAC0 Where [F:GAC]COA = [M:BSE1]COA & evalue(FILACC_VOID)

  Read [F:BSI2]BSI1 = adxuid(2);[F:GAC]ACC
  If fstat <> 0

    If [M:BSE1]LEVEL <> 0 | [M:BSE1]CPDEB <> ""
      Gosub CHECK_ACC_VOI
      If VOIACCFLG = 0 : Goto NEXT_ACC : Endif
    Endif

    GRYACCFLG = 0
    Gosub CHECK_ACC_GYM
    If [M:BSE1]OUTPYR <> 2 & GRYACCFLG = 0 : Goto NEXT_ACC : Endif
    If [M:BSE1]OUTPYR = 2 & [L]CRENOGRUFLG = 1 & GRYACCFLG = 0 : Gosub CRENOGRU : Endif

    [L]LINCOUNTER += 1

    [F:BSI]PRONUM = adxuid(2)
    [F:BSI]LINNUM = [L]LINCOUNTER
    [F:BSI]CPY    = [M:BSE1]CPY
    [F:BSI]FCY    = [M:BSE1]FCY
    [F:BSI]COA    = [M:BSE1]COA
    [F:BSI]ACC    = [F:GAC]ACC
    [F:BSI]GRUACC = [F:GAC]ACC
    If GRYACCFLG = 1
      [F:BSI]ORDFLD = [F:BSI]GRUACC
    Else
      [F:BSI]ORDFLD = string$(GLONGAC+1,"Z")+[F:BSI]GRUACC
    Endif
    Call LECTEXTRA([F:BSI]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    Write [F:BSI]
    If fstat
      GOK = 0 : Call FSTA("BSI") From GLOCK : Goto AB_BSI
    Endif

    $NEXT_ACC
  Endif

Next
Commit

Return
######################################################################################
$CRENOGRU

Raz [F:BSI]

[L]LINCOUNTER += 1

[F:BSI]PRONUM = adxuid(2)
[F:BSI]LINNUM = [L]LINCOUNTER
[F:BSI]CPY    = [M:BSE1]CPY
[F:BSI]FCY    = [M:BSE1]FCY
[F:BSI]COA    = [M:BSE1]COA
[F:BSI]LEV    = 0
[F:BSI]ACC    = ""
[F:BSI]GRUACC = ""
[F:BSI]ORDFLD = string$(GLONGAC+1,"Z")
[F:BSI]DES    = mess(67,109,1)
Write [F:BSI]
If fstat
  GOK = 0 : Call FSTA("BSI") From GLOCK : Goto AB_BSI
Endif

Raz [F:BSI]
CRENOGRUFLG = 0

Return
######################################################################################
## Filtre pour une société juridique
######################################################################################
$FILTRE
FILBAL = 'LEDTYP='+num$([M:BSE1]LEDTYP)
Case [M:BSE1]CUR
 When "" :
  TYPDEV = "3"
  FILBAL -= ""
 When [M:BSE1]CURLED :
  TYPDEV = "1"
  FILBAL -= '& CUR="'+[M:BSE1]CUR+'"'
 When Default :
  TYPDEV = "2"
  FILBAL -= '& CUR="'+[M:BSE1]CUR+'"'
Endcase
FILBAL -= '& FCY="'+[M:BSE1]FCY+'"'
FILBAL -= '& CPY="'+[M:BSE1]CPY+'"'
FILBAL -= '& FIY>='+num$(EDEB)+' & FIY<='+num$(EFIN)

# Plus d'autorisation site. On vérifie qu'on a droit à ce qu'on demande

Case TYPBAL
 When 1
  FILBAL -= '& BPR=""'
  If WILD_CHARS
   If RACDEB<>"" : FILBAL -= '& ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& ACC<"'+RACFIN+'"' : Endif
   FILBAL -= '& pat(ACC,"'+[M:BSE1]CPDEB+'")'
  Elsif [M:BSE1]CPDEB<>""
   FILBAL -= '& ACC>="'+[M:BSE1]CPDEB+'"'
  Endif
 When 2
  FILBAL -= '& ACC="'+COLL+'" & BPR<>""'
  If WILD_CHARS
   If RACDEB<>"" : FILBAL -= '& BPR>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& BPR<"'+RACFIN+'"' : Endif
   FILBAL -= '& pat(BPR,"'+[M:BSE1]CPDEB+'")'
  Elsif [M:BSE1]CPDEB<>""
   FILBAL -= '& BPR>="'+[M:BSE1]CPDEB+'"'
  Endif
Endcase
If SACCUR=[M:BSE1]SAC & CPTCUR=[M:BSE1]CPDEB
 Case CHGPAG
  When 3 : # Rafraichissement
   Case TYPBAL
    When 1 : FILBAL -= '& ACC>="'+CPDEB+'"'
    When 2 : FILBAL -= '& BPR>="'+CPDEB+'"'
   Endcase
  When 2 : # Suite
   Case TYPBAL
    When 1 : FILBAL -= '& ACC>"'+CPFIN+'"'
    When 2 : FILBAL -= '& BPR>"'+CPFIN+'"'
   Endcase
  When -2 : # Retour
   Case TYPBAL
    When 1 : FILBAL -= '& ACC<"'+CPDEB+'"'
    When 2 : FILBAL -= '& BPR<"'+CPDEB+'"'
   Endcase
 Endcase
Endif

Return
######################################################################################
## Filtre pour des groupements de sites
######################################################################################
$FILT_GRP
FILBAL   = '[F:BAL]LEDTYP='+num$([M:BSE1]LEDTYP)
FILBAL  -= '& [F:BAL]COA="'+[M:BSE1]COA+'"'
Case [M:BSE1]CUR
 When "" :
  TYPDEV = "3"
 When [M:BSE1]CURLED :
  TYPDEV = "1"
  FILBAL -= '& [F:BAL]CUR="'+[M:BSE1]CUR+'"'
 When Default :
  TYPDEV = "2"
  FILBAL -= '& [F:BAL]CUR="'+[M:BSE1]CUR+'"'
Endcase
FILBAL -= '& [F:FGR]CPY="'+[M]CPY+'"'
FILBAL -= '& [F:BAL]FCY<>""'

Case TYPBAL
 When 1
  FILBAL -= '& [F:BAL]BPR=""'
  If WILD_CHARS
   If RACDEB<>"" : FILBAL -= '& [F:BAL]ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& [F:BAL]ACC<"'+RACFIN+'"'  : Endif
   FILBAL -= '& pat([F:BAL]ACC,"'+[M:BSE1]CPDEB+'")<>0'
  Elsif [M:BSE1]CPDEB<>""
   FILBAL -= '& [F:BAL]ACC>="'+[M:BSE1]CPDEB+'"'
  Endif
 When 2
  FILBAL -= '& [F:BAL]BPR<>""'
  FILBAL -= '& [F:BAL]ACC="'+COLL+'"'
  If WILD_CHARS
   FILBAL -= '& pat([F:BAL]BPR,"'+[M:BSE1]CPDEB+'")<>0'
   If RACDEB<>"" : FILBAL -= '& [F:BAL]BPR>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILBAL -= '& [F:BAL]BPR<"'+RACFIN+'"' : Endif
  Elsif [M:BSE1]CPDEB<>""
   FILBAL -= '& [F:BAL]BPR>="'+[M:BSE1]CPDEB+'"'
  Endif
Endcase

If SACCUR=[M:BSE1]SAC & CPTCUR=[M:BSE1]CPDEB
 Case CHGPAG
  When 3 : # Rafraichissement
   Case TYPBAL
    When 1 : FILBAL -= '& [F:BAL]ACC>="'+CPDEB+'"'
    When 2 : FILBAL -= '& [F:BAL]BPR>="'+CPDEB+'"'
   Endcase
  When 2 : # Suite
  Case TYPBAL
   When 1 : FILBAL -= '& [F:BAL]ACC>"'+CPFIN+'"'
   When 2 : FILBAL -= '& [F:BAL]BPR>"'+CPFIN+'"'
  Endcase
  When -2 : # Retour
   Case TYPBAL
    When 1 : FILBAL -= '& [F:BAL]ACC<"'+CPDEB+'"'
    When 2 : FILBAL -= '& [F:BAL]BPR<"'+CPDEB+'"'
   Endcase
 Endcase
Endif

Return
###################################################################################
###################################################################################
$INIT
Raz MAXPER
Call LECTURE("CPY",[M:BSE1]CPY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
Call LECTURE("LED",[F:GCM]LED([M:BSE1]LEDTYP-1),"") From CONTOBJ

GRP = ([F:CPY]CPYLEGFLG=1)
If !GRP
 [M:BSE1]COA = [F:LED]COA
 Call GETPERSOC([M:BSE1]CPY,[M:BSE1]LEDTYP,[M:BSE1]DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 PDEB = PERIODE

 Call GETPERSOC([M:BSE1]CPY,[M:BSE1]LEDTYP,[M:BSE1]DATFIN,EXERCICE,PERIODE) From CPTSUB
 EFIN = EXERCICE
 PFIN = PERIODE

 Read [FIY]FIY0 = [M:BSE1]CPY;[M:BSE1]LEDTYP;EXERCICE
 For EXERCICE=EDEB To EFIN
  Filter [PER] Where CPY=[M:BSE1]CPY & LEDTYP=[M:BSE1]LEDTYP & FIYNUM=EXERCICE
  Read [PER]PER0 Last
  MAXPER(EXERCICE) = [F:PER]PERNUM
 Next
 Filter [PER]
 DEVLED = [F:GCM]CUR([M:BSE1]LEDTYP-1)
 DEVSOC = DEVLED : # Il n'y a plus de DEVSOC!
 XDEV   = 0
 COHGRP = 1

Else

 XDEV   = 0 : # Même devise pour les # sites
 COHGRP = 1 : # Cohérence des exercices
 NBSITE = 0
 For [FGR]FGR0 Where CPY = [M:BSE1]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ

  # On borne par rapport aux premier et dernier exercice

  Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:BSE1]LEDTYP
  Read [FIY]FIY0 First
  If [M:BSE1]DATDEB>=[F:FIY]FIYSTR : DDEB = [M:BSE1]DATDEB : Else : DDEB = [F:FIY]FIYSTR : Endif
  Read [FIY]FIY0 Last
  If [M:BSE1]DATFIN<=[F:FIY]FIYEND : DFIN = [M:BSE1]DATFIN : Else : DFIN = [F:FIY]FIYEND : Endif
  Filter [FIY]

  # On ne prend en compte le site que si la période est mouvementée

  If DDEB<=DFIN
   NBSITE += 1
   TSITE(NBSITE) = [F:FGR]FCY
   Call GETPERSOC([F:FCY]LEGCPY,[M:BSE1]LEDTYP,DDEB,EXERCICE,PERIODE) From CPTSUB
   TEDEB(NBSITE) = EXERCICE
   TPDEB(NBSITE) = PERIODE
   Read [FIY]FIY0 = [F:FCY]LEGCPY;[M:BSE1]LEDTYP;EXERCICE
   If NBSITE=1
    DEBEX = [F:FIY]FIYSTR
   Elsif DEBEX<>[F:FIY]FIYSTR
    COHGRP = 0
   Endif
   Call GETPERSOC([F:FCY]LEGCPY,[M:BSE1]LEDTYP,DFIN,EXERCICE,PERIODE) From CPTSUB
   TEFIN(NBSITE) = EXERCICE
   TPFIN(NBSITE) = PERIODE
   For EXERCICE=TEDEB(NBSITE) To TEFIN(NBSITE) : # voir CONSBAF
    Filter [PER] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:BSE1]LEDTYP & FIYNUM=EXERCICE
    Read [PER]PER0 Last
    TMAXPER(EXERCICE,NBSITE) = [F:PER]PERNUM
    Filter [PER]
   Next
   TSOCIETE(NBSITE) = [F:FCY]LEGCPY
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   TDEVSOC(NBSITE) = [F:CPY]ACCCUR
   Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
   TDEVLED(NBSITE) = [F:GCM]CUR([M:BSE1]LEDTYP-1)
   TDEVSOC(NBSITE) = TDEVLED(NBSITE) : # Il n'y a plus de DEVSOC!
   If NBSITE>1 & TDEVSOC(NBSITE)<>TDEVSOC(1) : XDEV = 1 : Endif
   Call LECTURE("LED",[F:GCM]LED([M:BSE1]LEDTYP-1),"") From CONTOBJ
   [M:BSE1]COA = [F:LED]COA
  Endif
 Next : # [FGR]
Endif

If [M:BSE1]GYM = "" & [M:BSE1]SAC =""
  If [F:COA]COA <> [M:BSE1]COA
    Read [F:COA]COA0 = [M:BSE1]COA
  Endif

  [M:BSE1]GYM = [F:COA]PYRREF
  Affzo [M:BSE1]GYM
Endif

Return

$LISTE1
If [M:BSE1]SAC<>""
 #RPTCOD = "BALGRPAUX"
 #RPTCOD="CNSBALAUX"
Else
 #RPTCOD = "BALGRP"
 #RPTCOD="CNSBALGRP"
Endif
Return
##################################################################################################
##################################################################################################
$APRES_MODIF

If COUZON="NBLIG"
 Call LECTURE("GAC",[M]COMPTE(nolign-1),[M:BSE1]COA) From CONTOBJ
 If [F:GAC]SAC=2
  [M:BSE1]SAC   = [F:GAC]ACCSHO
  [M:BSE1]CPDEB = ""
  CHGPAG=1
  Default [L] : # Sinon c'est la classe [M] dans cette étiquette
  Gosub LECTURE From GCONSULT
  Gosub SETBOUT From GCONSULT
  Gosub DISZO_SAC
  Affzo
 Endif
Endif

Return
##################################################################################################
##################################################################################################
$FERME

Delete [F:BSI] Where [F:BSI]PRONUM = adxuid(2)

Return
##################################################################################################
##################################################################################################
$FILTER_BSI
FILBSI = "[F:BSI]PRONUM = adxuid(2)"

If [M:BSE1]DETAIL <> 2
  FILBSI += " & [F:BSI]ACC = ''"
Endif

Case CHGPAG
  When 3 #Refresh
    #If GADEB<>"" : FILBSI += " & [F:BSI]GRUACC >= '"+GADEB+"'" : Endif
    #If GAFIN<>"" : FILBSI += " & [F:BSI]GRUACC <= '"+GAFIN+"'" : Endif
    If GADEB<>"" : FILBSI += " & [F:BSI]ORDFLD >= '"+GADEB+"'" : Endif
    If GAFIN<>"" : FILBSI += " & [F:BSI]ORDFLD <= '"+GAFIN+"'" : Endif
  When 2
    #If GAFIN<>"" : FILBSI += " & [F:BSI]GRUACC > '"+GAFIN+"'" : Endif
    If GAFIN<>"" : FILBSI += " & [F:BSI]ORDFLD > '"+GAFIN+"'" : Endif
  When -2
    #If GAFIN<>"" : FILBSI += " & [F:BSI]GRUACC < '"+GADEB+"'" : Endif
    If GAFIN<>"" : FILBSI += " & [F:BSI]ORDFLD < '"+GADEB+"'" : Endif
Endcase

Return
##################################################################################################
##################################################################################################
$FILTER_GYK
#To filter data to retrieve from GYK when initializing data from pyramid
If [M:BSE1]SAC <> ""
  FILGYK = "1=2" : Return
Endif

If [M:BSE1]GYM = ""
  FILGYK = "1=2" : Return
Else
  FILGYK = "[F:GYK]PYM = '"+[M:BSE1]GYM+"'"
Endif

If [M:BSE1]LEVEL <> 0
  If [M:BSE1]MULLEV = 2
    FILGYK += " & [F:GYK]LEV<="+num$([M:BSE1]LEVEL)
  Else
    FILGYK += " & [F:GYK]LEV="+num$([M:BSE1]LEVEL)
  Endif
Else
  If [M:BSE1]MULLEV <> 2 #No level and no Multilevel
    FILGYK += " & 1 = 2"
  Endif
Endif

If [M:BSE1]CPDEB<>""
  If WILD_CHARS
   If RACDEB<>"" : FILGYK -= '& [F:GYK]ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILGYK -= '& [F:GYK]ACC<"'+RACFIN+'"' : Endif
   FILGYK -= '& pat([F:GYK]ACC,"'+[M:BSE1]CPDEB+'")'
  Elsif [M:BSE1]CPDEB<>""
   FILGYK -= '& [F:GYK]ACC>="'+[M:BSE1]CPDEB+'"'
  Endif
Endif

#If [M:BSE1]CPDEB<>""
#  ACCGYKDEB = RACDEB
#  ACCGYKFIN = RACFIN
#  If ACCGYKDEB = "" | ACCGYKFIN = ""
#    J = instr(1,[M:BSE1]CPDEB+"*","*")
#    K = instr(1,[M:BSE1]CPDEB+"?","?")
#    J = min(J,K)
#    ACCGYKDEB = left$([M:BSE1]CPDEB,J-1)
#    ACCGYKFIN = left$(ACCGYKDEB,len(ACCGYKDEB)-1)+chr$(ascii(mid$(ACCGYKDEB,len(ACCGYKDEB),1))+1)
#  Endif
#  FILGYK += " & [F:GYK]ACC>='"+ACCGYKDEB+"' & [F:GYK]ACC<'"+ACCGYKFIN+"'"
#Endif

Return
##################################################################################################
##################################################################################################
$FILTER_GYK_VOI
#To check if void account is to be selected based on the selected level
#If [M:BSE1]SAC <> ""
#  FILGYK = "1=2" : Return
#Endif

If [M:BSE1]GYM = ""
  FILGYK_VOID = "1=2" : Return
Else
  FILGYK_VOID = "[F:GYK]PYM = '"+[M:BSE1]GYM+"'"
Endif

If [M:BSE1]LEVEL <> 0
  If [M:BSE1]MULLEV = 2
    FILGYK_VOID += " & [F:GYK]LEV<="+num$([M:BSE1]LEVEL)
  Else
    FILGYK_VOID += " & [F:GYK]LEV="+num$([M:BSE1]LEVEL)
  Endif
#Else
#  If [M:BSE1]MULLEV <> 2 #No level and no Multilevel
#    FILGYK_VOID += " & 1 = 2"
#  Endif
Endif

Return
##################################################################################################
##################################################################################################
$FILTER_ACC_VOI

FILACC_VOID = "1=1"

If [M:BSE1]CPDEB<>""
  If WILD_CHARS
   If RACDEB<>"" : FILACC_VOID -= '& [F:GAC]ACC>="'+RACDEB+'"' : Endif
   If RACFIN<>"" : FILACC_VOID -= '& [F:GAC]ACC<"'+RACFIN+'"' : Endif
   FILACC_VOID -= '& pat([F:GAC]ACC,"'+[M:BSE1]CPDEB+'")'
  Elsif [M:BSE1]CPDEB<>""
   FILACC_VOID -= '& [F:GAC]ACC>="'+[M:BSE1]CPDEB+'"'
  Endif
Endif

Return
##################################################################################################
##################################################################################################
$FILTER_GRY
#To filter data to retrieve from GRY when initializing data from pyramid
If [M:BSE1]SAC <> ""
  FILGRY = "1=2" : Return
Endif

If [M:BSE1]GYM = ""
  FILGRY = "1=2" : Return
Else
  FILGRY = "[F:GRY]PYM = '"+[M:BSE1]GYM+"'"
Endif

If [M:BSE1]LEVEL <> 0
  If [M:BSE1]MULLEV = 2
    FILGRY += " & [F:GRY]LEV<="+num$([M:BSE1]LEVEL)
  Else
    FILGRY += " & [F:GRY]LEV="+num$([M:BSE1]LEVEL)
  Endif
Else
  If [M:BSE1]MULLEV <> 2 #No level and no Multilevel
    FILGRY += " & 1 = 2"
  Endif
Endif

If [M:BSE1]CPDEB<>""
  ACCGRYDEB = RACDEB
  ACCGRYFIN = RACFIN
  If ACCGRYDEB = "" | ACCGRYFIN = ""
    J = instr(1,[M:BSE1]CPDEB+"*","*")
    K = instr(1,[M:BSE1]CPDEB+"?","?")
    J = min(J,K)
    ACCGRYDEB = left$([M:BSE1]CPDEB,J-1)
    ACCGRYFIN = left$(ACCGRYDEB,len(ACCGRYDEB)-1)+chr$(ascii(mid$(ACCGRYDEB,len(ACCGRYDEB),1))+1)
  Endif
  FILGRY += " & [F:GRY]ACC>='"+ACCGRYDEB+"' & [F:GRY]ACC<'"+ACCGRYFIN+"'"
Endif

Return
##################################################################################################
##################################################################################################
$INI_PYR_DATA

#get the total level
Raz [M:BSE1]TOTLEV
Filter [F:GYK] Where [F:GYK]PYM = [M:BSE1]GYM Order By [F:GYK]PYM Asc ; [F:GYK]LEV Asc
Read [F:GYK]First
If fstat=0 : [M:BSE1]TOTLEV = [F:GYK]LEV : Endif
Filter [F:GYK]

[L]LINCOUNTER = 0
Gosub FILTER_GYK

Call DEBTRANS From GLOCK
Trbegin [F:BSI]

Delete [F:BSI] Where [F:BSI]PRONUM = adxuid(2) or [F:BSI]CREDAT < date$ -1
If fstat = [V]CST_ALOCK : GOK = -1 : GLOCK = "$BSEINQ" : Goto ROLL_BSI : Endif

Raz LASTGRU
Raz [F:BSI]
[F:BSI]CPY    = [M:BSE1]CPY
[F:BSI]FCY    = [M:BSE1]FCY
[F:BSI]COA    = [M:BSE1]COA
Filter [F:GYK] Where evalue(FILGYK) Order By [F:GYK]GRU Asc
For [F:GYK]
  If LASTGRU <> [F:GYK]GRU
    [L]LINCOUNTER += 1
    [F:BSI]PRONUM  = adxuid(2)
    [F:BSI]LINNUM  = [L]LINCOUNTER
    [F:BSI]GRUACC  = [F:GYK]GRU
    [F:BSI]LEV     = [F:GYK]LEV
    [F:BSI]GRU     = [F:GYK]GRU
    [F:BSI]ORDFLD  = [F:BSI]GRUACC
    Call LECTEXTRA([F:BSI]DES,"GACCGRUPYM","DESTRA",[M:BSE1]GYM,[F:GYK]GRU) From ATEXTRA
    #[F:BSI]GRU     = [M:BSE1]COA
    Write [F:BSI]
    If fstat
      GOK = 0 : Call FSTA("BSI") From GLOCK : Goto AB_BSI
    Endif
  Endif
  LASTGRU = [F:GYK]GRU
Next
Commit
Filter [F:GYK]
Return
##################################################################################################
##################################################################################################
$INI_PYR_DATA_OLD

[L]LINCOUNTER = 0
Gosub FILTER_GRY

Call DEBTRANS From GLOCK
Trbegin [F:BSI]

Delete [F:BSI] Where [F:BSI]PRONUM = adxuid(2) or [F:BSI]CREDAT < date$ -1
If fstat = [V]CST_ALOCK : GOK = -1 : GLOCK = "$BSEINQ" : Goto ROLL_BSI : Endif

Raz [F:BSI]
[F:BSI]CPY    = [M:BSE1]CPY
[F:BSI]FCY    = [M:BSE1]FCY
[F:BSI]COA    = [M:BSE1]COA
For [F:GRY]GRY0(2) Where evalue(FILGRY)
  [L]LINCOUNTER += 1
  [F:BSI]PRONUM  = adxuid(2)
  [F:BSI]LINNUM  = [L]LINCOUNTER
  [F:BSI]GRUACC  = [F:GRY]GRU
  [F:BSI]LEV     = [F:GRY]LEV
  [F:BSI]GRU     = [F:GRY]GRU
  [F:BSI]ORDFLD  = [F:BSI]GRUACC
  Call LECTEXTRA([F:BSI]DES,"GACCGRUPYM","DESTRA",[M:BSE1]GYM,[F:GRY]GRU) From ATEXTRA
  #[F:BSI]GRU     = [M:BSE1]COA
  Write [F:BSI]
  If fstat
    GOK = 0 : Call FSTA("BSI") From GLOCK : Goto AB_BSI
  Endif
Next
Commit
Return
##################################################################################################
##################################################################################################
$ROLL_BSI
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto INI_PYR_DATA : Endif
##################################################################################################
##################################################################################################
$AB_BSI
Rollback
Filter [F:GYK]
Return
##################################################################################################
##################################################################################################
$PRESENT_RESULTS

Gosub FILTER_BSI

Raz [M:BSE2]
nolign=0

If CHGPAG>0
 Filter [BSI] Where evalue(FILBSI)
&             Order By Key CLE = ORDFLD Asc; LEV Desc #GRUACC Asc; LEV Desc
Else
 Filter [BSI] Where evalue(FILBSI)
&             Order By Key CLE = ORDFLD Desc; LEV Asc #GRUACC Desc; LEV Asc
Endif

For [F:BSI]

  If NBLU=1
    If CHGPAG=2 or CHGPAG=-2 : Raz [M:BSE2] : Endif
    NBLU = 2
  Endif

  If CHGPAG>0
    If NOL>=MAXLIG-1 : SUITE = 2 : Break : Endif
    NOL += 1
    Case TYPBAL
     When 1
      #If NOL=0 : GADEB = [F:BSI]GRUACC : Endif
      #GAFIN = [F:BSI]GRUACC
      If NOL=0 : GADEB = [F:BSI]ORDFLD : Endif
      GAFIN = [F:BSI]ORDFLD
     When 2
      If NOL=0 : GADEB = [F:BSI]BPR : Endif
      GAFIN = [F:BSI]BPR
    Endcase
  Else
    If NOL<=0 : RETOUR = 2 : Break : Endif
    NOL -= 1
    Case TYPBAL
     When 1
#      If NOL=MAXLIG-1 : GAFIN = [F:BSI]GRUACC : Endif
#      GADEB = [F:BSI]GRUACC
      If NOL=MAXLIG-1 : GAFIN = [F:BSI]ORDFLD : Endif
      GADEB = [F:BSI]ORDFLD
     When 2
      If NOL=MAXLIG-1 : GAFIN = [F:BSI]BPR : Endif
      GADEB = [F:BSI]BPR
    Endcase
  Endif

  nolign=NOL+1
  [M:BSE2] = [F:BSI]
  [M:BSE2]COMPTE(NOL) = [F:BSI]GRUACC
  [M:BSE2]INTIT(NOL) = [F:BSI]DES

  #If nolign >= MAXLIG : Break : Endif

Next

Filter [BSI]

[M:BSE2]NBLIG = nolign

Affzo [M:BSE2]

Return
###################################################################################
###################################################################################
$INIT_ACC_FLDS

Call LECTURE("CPY",[M:BSE1]CPY,"") From CONTOBJ
Call LEDTYP_CHOICE([M]CPY,1) From CPTDIV
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
Call LECTURE("LED",[F:GCM]LED(SLEDTYP-1),"") From CONTOBJ
Call LECTURE("COA",[F:LED]COA,"") From CONTOBJ
[M:BSE1]COA = [F:LED]COA
[M:BSE1]GYM = [F:COA]PYRREF
Affzo [M:BSE1]GYM, COA

Return
###################################################################################
###################################################################################
$SEL_LISTE

Case LISTE
 When "SELLEVGYM"
  Gosub SEL_LEV
Endcase

Return
$SEL_LEV
If PARAM(1) = "" : Return : Endif
If !clalev([F:GRY]) : Local File GACCGRUPYM [GRY] : Endif

TIT = mess(102,103,1)
NBTEX = 0    #- Number of lines

For [F:GRY]GRY1(2) Where [F:GRY]PYM=PARAM(1)
  NBTEX += 1
  TEX(NBTEX)   = num$([F:GRY]LEV)
  TEXTE(NBTEX) = num$([F:GRY]LEV)
Next

Return
##################################################################################################
##################################################################################################
$SET_SLEDTYP

Local Integer SLEDTYP
SLEDTYP = [M:BSE1]LEDTYP

Return
##################################################################################################
##################################################################################################
$CHECK_ACC_GYM

For [F:GYK] Where [F:GYK]PYM = [M:BSE1]GYM & [F:GYK]ACC = [F:GAC]ACC
  GRYACCFLG = 1
  Break
Next

Return
##################################################################################################
##################################################################################################
$CHECK_ACC_VOI

VOIACCFLG = 0

For [F:GYK] Where evalue(FILGYK_VOID)
  VOIACCFLG = 1
  Break
Next

Return
##################################################################################################
##################################################################################################
$DISZO_SAC

Diszo [M]GYM, DETAIL, LEVEL, MULLEV, VOIVAL, OUTPYR

Return
##################################################################################################
##################################################################################################
$AFFZO_SAC

Affzo [M]GYM, DETAIL, LEVEL, MULLEV, VOIVAL, OUTPYR

Return
##################################################################################################
##################################################################################################
##################################################################################################
##                                                                                              ##
## Screen subprogs - CONSBSE1, CONSBSE2 & CRITBSE                                               ##
##                                                                                              ##
##################################################################################################
##################################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

Local Char CPYSVE(GLONCPY)
CPYSVE= [M]CPY
Call C_CPY(VALEUR) From CONSSUB
# Remise à vide du chmp CUR, ne doit pas être initialisé par CONSSUB car ici le chp CUR est
# le champ de devise d'affichage et pas la devise de la société.On devrait renomer le champ CUR en CURDSP par exemple.
If [M:BSE1]CPY <> CPYSVE : [M]CUR="" : Affzo [M]CUR : Endif
## Si on a saisi un regroupement de sites, on contrôle qu'on ait accès à tous les sites du regroupement
Call LEC_CPY(VALEUR) From CPTLEC
If [F:CPY]CPYLEGFLG<>2
 Call CONTALLFCY(VALEUR) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

Local Char PFCY(GLONFCY) : PFCY = [M]FCY

Call C_FCY(VALEUR) From CONSSUB
If !mkstat & VALEUR <> PFCY
  Gosub SET_SLEDTYP
  Gosub INIT_ACC_FLDS
Endif

End
######################################################################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=1 : # # Référentiels flagués 'Général'
Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
End
######################################################################################
Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From CONSSUB
End
######################################################################################
Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
End
######################################################################################
Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
If mkstat : End : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Filter [PER] Where CPY=[F:CPY]CPY & LEDTYP=[M]LEDTYP & PERSTR<=VALEUR
 Read [PER]PER0 Last
 Filter [PER]
 If fstat<=2
  VALEUR = [F:PER]PERSTR
 Endif
Else
Endif
End
######################################################################################
Subprog AS_DATFIN(VALEUR)
Variable Date    VALEUR
End
######################################################################################
Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
If mkstat : End : Endif
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
If [F:CPY]CPYLEGFLG=2
 Filter [PER] Where CPY=[F:CPY]CPY & LEDTYP=[M]LEDTYP & PEREND>=VALEUR
 Read [PER]PER0 First
 Filter [PER]
 If fstat<=2
  VALEUR = [F:PER]PEREND
 Endif
Else
Endif
End
######################################################################################
Subprog C_SAC(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
  If [M]SAC <> VALEUR
   Read [GAC]GAC1 = [M:BSE1]COA;VALEUR
   If [F:GAC]ACS<>""
    Local Integer DROIT
    Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
    If !DROIT
     # Vous n'avez pas les droits pour ce code
     GMESSAGE = mess(4,104,1)
     mkstat = 2 : End
    Endif
   Endif
   Raz [M]GYM, DETAIL, LEVEL, MULLEV, VOIVAL, OUTPYR
   Gosub DISZO_SAC
 Endif
Else
 Actzo [M]GYM, DETAIL, LEVEL, MULLEV
 If [M]DETAIL = 2
  Actzo [M]OUTPYR, VOIVAL
 Else
  Diszo [M]OUTPYR, VOIVAL
 Endif
Endif
Gosub AFFZO_SAC
End
######################################################################################
Subprog C_CPDEB(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Integer I
Local Char    LISTE(50)
LISTE = "ABCDEFGHIJKLMNOPQRSTUVWXYZ*?0123456789."
For I=1 To len(VALEUR)
 If !instr(1,LISTE,mid$(VALEUR,I,1))
  mkstat = 1 : Break
 Endif
Next I
Read [GAC]GAC0 = [M:BSE1]COA;VALEUR
If !fstat & [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   # Vous n'avez pas les droits pour ce code
   GMESSAGE = mess(4,104,1)
   mkstat = 2 : End
  Endif
Endif
End
######################################################################################
Subprog IB_CPDEB
Raz GBOUT1, GBOUT2
If [M]SAC=""
 GBOUT1 = mess(8,31,1)   # Sélection
Else
 GBOUT2 = mess(8,31,1)   # Sélection
Endif
End
######################################################################################
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2
If nolign-1>=[M]NBLIG | [M:BSE2]COMPTE(nolign-1)="" | [M:BSE2]LEV(nolign-1)<>0 : End : Endif
If !GTUNCPT(1)
 If [M:BSE1]SAC<>""
  GBOUT1 = mess(25,109,1)  # Compte
 Else
  Call LECTURE("GAC",[M:BSE2]COMPTE(nolign-1),[M:BSE1]COA) From CONTOBJ
  If [F:GAC]SAC<>2
   GBOUT1 = mess(25,109,1)  # Compte
  Else
   GBOUT2 = mess(25,109,1)  # Compte
  Endif
 Endif
Endif
End
######################################################################################
Subprog B2_NBLIG
Call LECTURE("GAC",[M]COMPTE(nolign-1),[M:BSE1]COA) From CONTOBJ
If [F:GAC]SAC=2
 mkstat = 4
Endif
End
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Gosub SET_SLEDTYP
Gosub INIT_ACC_FLDS
End
######################################################################################
Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer SLEDTYP : SLEDTYP = VALEUR
Gosub INIT_ACC_FLDS
End
######################################################################################
## Section automatically added (screen CONSBSE2) 07/10/2016 18:36:09 (RMA)
######################################################################################
Subprog AV_COMPTE(VALEUR)
Variable Char    VALEUR()

If [M:BSE1]SAC = ""
  If [M:BSE2]LEV(nolign-1) = 0 & [M:BSE2]INTIT(nolign-1)<> mess(67,109,1)
    Chgstl [M:BSE2]NBLIG(nolign-1) With "BACKYELLOW"
  Elsif [M:BSE1]TOTLEV <> 0 & [M:BSE2]LEV(nolign-1) = [M:BSE1]TOTLEV
    Chgstl [M:BSE2]NBLIG(nolign-1) With "BACKGREEN"
#  Elsif [M:BSE2]INTIT(nolign-1) = mess(67,109,1)
#    Chgstl [M:BSE2]NBLIG(nolign-1) With "BACKGREEN"
  Endif
Endif

End
######################################################################################
## Section automatically added (screen CONSBSE1) 10/10/2016 12:23:36 (RMA)
######################################################################################
Subprog C_GYM(VALEUR)
Variable Char    VALEUR()

If !clalev([F:GYM]) : Local File GACCPYM [F:GYM] : Endif

If VALEUR<>""
 Call LECTURE("GYM",VALEUR,"") From CONTOBJ
 If [F:GYM]COA<>[M]COA
  GMESSAGE = mess(185,105,1)-"("+[F:GYM]COA+")" : # Plan comptable incompatible
  mkstat = 2
  End
 Endif
Endif

End
######################################################################################
## Section automatically added (screen CONSBSE1) 10/10/2016 12:28:08 (RMA)
######################################################################################
Subprog C_LEVEL(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0 : End : Endif

If !clalev([F:GRY]) : Local File GACCGRUPYM [F:GRY] : Endif

Read [F:GRY]GRY1(2) = [M]GYM;VALEUR
If fstat <> 0
    GMESSAGE = mess(8,9137,1) #Incorrect value
    mkstat = 2
Endif

End
######################################################################################
######################################################################################
Subprog AM_DETAIL(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Actzo [M]VOIVAL, OUTPYR
Else
  Raz   [M]VOIVAL, OUTPYR
  Diszo [M]VOIVAL, OUTPYR
Endif
Affzo [M]VOIVAL, OUTPYR

End
######################################################################################
######################################################################################
Subprog D_VOIVAL(VALEUR)
Variable Integer VALEUR

If [M]DETAIL<>2 : Diszo [M]VOIVAL, OUTPYR : Endif

End
