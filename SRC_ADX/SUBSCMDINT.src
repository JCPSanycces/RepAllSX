If [M:DIA]TYPEXP = 1
    Grizo [M:DIA]DRTISS
    [S]mkstat=2
Endif
End

Subprog C_DRTISS(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End


######################################################################################

Subprog CONTREP(NAMEREP)
Variable Char NAMEREP()
Local Integer ER
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
  If left$(NAMEREP,1)="#"
   GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
   mkstat   = 2
   End
  Endif
  Call MACHINE(NAMEREP,MACHINE,REPERT) From ORDSYS
  Call GET_OS(MACHINE,OS) From ORDSYS
  If OS="" Then
    GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
    mkstat=2 : End
  Endif
  Call EXISTE(NAMEREP,ER) From ORDSYS
  If ER<>2 Then
    GERR=1
    GMESSAGE = mess(9,141,1) :  # Répertoire inexistant
    mkstat = 2 : End
  Endif
End

