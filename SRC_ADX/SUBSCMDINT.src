#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBSCMDINT","SCMDINT",4,"SPESCMDINT") From GTRAITE
End

# Gestion du masque SCMDINT
$ACTION
#Infbox "ACTION="+ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE : #entrée en Batch
 When "INIT"         : Gosub OUVRE : #entrée en Interactif
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "SETBOUT"    : Gosub SETBOUT
 When default
Endcase
Return

######################################################################################
$SETBOUT
If [M]HISSDHFLG=2
    Actzo [M]SDHFOR
Else
    Grizo [M]SDHFOR
Endif
Return


######################################################################################
$OUVRE
Local Integer NBERR : NBERR=0
Local Integer OK , STAT
Local Char   FICREF(GDIMFIC),FICREJ(GDIMFIC), WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(GDIMFIC)

Local Mask SCMDINT [DIA] : # Saisie paramètres 
Raz [M:DIA]
If clalev ([F:SDP]) = 0 : Local File SCMDPAR [SDP] : Endif
Call GET_DERLU([M:DIA]ID,"SMP","")
If [M:DIA]ID<>""
    Call AP_ID([M:DIA]ID)
Endif
[M:DIA]TRACE=2
Return

$DEBUT
Affzo [M:DIA]
Return

#######################################################
$CONTROLE
If GSTATUT=7
 FIN = 1 : # Sortie du GSAISIE par la touche FIN
 Return
Endif
If !GSERVEUR
 TMP = 1
Endif
If [M:DIA]TYPEXP=2 & [M:DIA]DRTRCP=[M:DIA]DRTSTO # FQ 64723 GA 05/2010 DRTWRK devient DRTRCP
    ##Les répertoires indiqués doivent être différents
    GERR=1
    SAI=1
    GMESSAGE=mess(44,7710,1)
    Return
Endif

# FQ 64765 GA 05/2010 champs trop longs pour la V5 
# FLGITMFCYPIT=>FLGITMFCYP, FLGHISSOHPIT=>FLGHISSOHP
If [M:DIA]FLGITMPIT=1  &
&  [M:DIA]FLGITMFCYP=1 &
&  [M:DIA]FLGBPCPIT=1  &
&  [M:DIA]FLGFCYPIT=1  &
&  [M:DIA]FLGHISSOHP=1 &
&  [M:DIA]FLGSOHPIT=1  &
&  [M:DIA]FLGSOSPIT=1
    ##Il faut demander au moins le traitement d'un fichier
    GERR=1
    SAI=1
    GMESSAGE=mess(36,7710,1)
    Return
Endif

If [M:DIA]SOHGRU=0
    [M:DIA]SOHGRU=1
Endif

# FQ 64765 GA 05/2010 champs trop longs pour la V5 
# FLGITMFCYPIT=>FLGITMFCYP, FLGHISSOHPIT=>FLGHISSOHP
If [M:DIA]FLGHISSOHP=2
    If [M:DIA]HSOHENDDAT<>[0/0/0] & [M:DIA]HSOHSTRDAT>[M:DIA]HSOHENDDAT & [M:DIA]HSOHSTRDAT<>[0/0/0]
        GERR=1
        SAI=1
        GMESSAGE=mess(99,177,1)
        Return
    Endif
    If [M:DIA]HSOHEDTFLG=2 & [M:DIA]HSOHSTRDAT>date$ & [M:DIA]HSOHSTRDAT<>[0/0/0]
        GERR=1
        SAI=1
        GMESSAGE=mess(99,177,1)
        Return
    Endif
Endif

If [M:DIA]SOSDLTFLG=0
    [M:DIA]SOSDLTFLG=1
Endif

Return

###############################################################
$TERMINE
  If !GSERVEUR & ( [M:DIA]TRACE=2 | NBERR>0)
    TRA = 1
  Else
    TRA = 0
  Endif
  ###Gosub SUP_VAR
Return

###############################################################
$EXEC
Local Char     WMESS(150)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Date WDEBUT,WFIN

TIT  = mess(73,7710,1) # interface SCM

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
##Call PRTSCR("SCMDINT","DIA","",0,1) From ATRTX3
Call TRACE_MASQUE("SCMDINT","DIA",nomap) From GTRAITE 
Call ECR_TRACE(string$(100,"="),0) From GESECRAN

# lecture en cours
Call TEMPON(mess(3,100,1)) From GESECRAN           
###
# FQ 64765 GA 05/2010 champs trop longs pour la V5 
# FLGITMFCYPIT=>FLGITMFCYP, FLGHISSOHPIT=>FLGHISSOHP
If [M:DIA]FLGITMPIT=2 | [M:DIA]FLGITMFCYP=2
    WITMPIT=""
    If [M:DIA]FLGITMPIT=2
        WITMPIT=[M:DIA]ITMPIT
    Endif
    WTCOITMPIT=""
    WCRIITMPIT=""
    WFCYITMPIT=""
    If [M:DIA]FLGITMFCYP=2
        WFCYITMPIT=[M:DIA]ITMFCYPIT
    Endif
    Call TRT_ITM('SCMD',[M:DIA]ID,WITMPIT,[M:DIA]ITMFOR,"[F:ITG]SALFLG=2",WTCOITMPIT,WCRIITMPIT,WFCYITMPIT,OK) From PITITM
Endif
If [M:DIA]FLGBPCPIT=2
    Call TRT_BPC('SCMD',[M:DIA]ID,[M:DIA]BPCPIT,"1=1","",OK) From PITBPC
Endif
If [M:DIA]FLGFCYPIT=2
    Call TRT_FCY('SCMD',[M:DIA]ID,[M:DIA]FCYPIT,"WRHFLG=2","",OK) From PITFCY
Endif
Gosub TRF_FILES
# FQ 64765 GA 05/2010 champs trop longs pour la V5 
# FLGITMFCYPIT=>FLGITMFCYP, FLGHISSOHPIT=>FLGHISSOHP
If [M:DIA]FLGHISSOHP=2 & [M:DIA]HISSOHFLG=2
    WDEBUT=[M:DIA]HSOHSTRDAT
    WNBJOUR=[M:DIA]HSOHNDSTR
    If [M:DIA]HSOHEDTFLG=2
        WFIN=date$
    Else
        WFIN=[M:DIA]HSOHENDDAT
    Endif
    WCRIT="SOQSTA=3 & (ODLQTY+DLVQTY+INVQTY)>0"
    WAGREG=[M:DIA]SOHGRU
    Call TRT_SOQ('SCMD',[M:DIA]ID,[M:DIA]HISSOHPIT,[M:DIA]SOHFOR,WCRIT,"DEMDLVDAT",WDEBUT,WNBJOUR,WFIN,WAGREG,OK) From PITSOH
    Gosub TRF_FILES_HISSOH
Elsif [M:DIA]FLGHISSOHP=2 & [M:DIA]HISSDHFLG=2
    WDEBUT=[M:DIA]HSOHSTRDAT
    WNBJOUR=[M:DIA]HSOHNDSTR
    If [M:DIA]HSOHEDTFLG=2
        WFIN=date$
    Else
        WFIN=[M:DIA]HSOHENDDAT
    Endif
    WCRIT="1=1"
    WAGREG=[M:DIA]SOHGRU
    Call TRT_VSDQ('SCMD',[M:DIA]ID,[M:DIA]HISSOHPIT,[M:DIA]SDHFOR,WCRIT,WDEBUT,WNBJOUR,WFIN,WAGREG,OK) From PITVSDQ
    Gosub TRF_FILES_VSDQ
Endif
If [M:DIA]FLGSOHPIT=2
    Raz WDEBUT,WFIN
    WNBJOUR=0
    WCRIT="SOQSTA<>3"
    WAGREG=[M:DIA]SOHGRU
    Call TRT_SOQ('SCMD',[M:DIA]ID,[M:DIA]SOHPIT,[M:DIA]SOHFOR,WCRIT,"EXTDLVDAT",WDEBUT,WNBJOUR,WFIN,WAGREG,OK) From PITSOH
    Gosub TRF_FILES_SOH
Endif
Call TEMPOFF From GESECRAN

# Ecriture en cours
Call TEMPON(mess(4,100,1)) From GESECRAN
Gosub INI_VAR
If [M:DIA]FLGSOSPIT=2
    Gosub TRAIT_SOS
Endif
Gosub FIN_CPTRENDU

Call TEMPOFF From GESECRAN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

######################################################################################
$TRAIT_SOS
If [M:DIA]TYPEXP=1
    WFICCLI = "scmdsos.csv"
    FICREJ = "scmdsos_rej.csv"
    FICREF = "scmdrefsos.csv"
    Call SET_FICNAM(WFICCLI,WFICHIER,URL) From ORDSYS
    Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
    If STAT : Return : Endif
    Call IMPORT("SCMDSOS",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Else
    WFICCLI = ""
    FICREJ = ""
    FICREF = ""
    WFICHIER=[M:DIA]DRTRCP   # FQ 64723 GA 05/2010 avant DRTWRK
    Call IMPORT("SCMDSOS",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
    Call IMPORT("scmdsos",WFICHIER,WFICCLI,FICREJ,FICREF,NBERR)
Endif
Return



######################################################################################
Subprog IMPORT(NOMBASE,FICBASE,FICCLI,FICREJ,FICREF,NBERR)
Value    Char    NOMBASE(),FICBASE(),FICCLI(),FICREJ(),FICREF()
Variable Integer NBERR
#----------------------#
Local Char     MACHINE(GDIMFIC) , MACFIC(GDIMFIC),WFICREF(GDIMFIC),WFICREJ(GDIMFIC),WFICTMP(GDIMFIC)
Local Char     OS(20)(1..2)
Local Integer  TYPFIC,NBTRAIT
Local Shortint MAXFIL : MAXFIL = 1000
Local Char     TRAIT(200)(1..MAXFIL), EXT(30)

WDATBAS=format$("D:YYYYMMDDhhmmss",date$)

CONPROG="CONNECTSOS"
CONPIT=[M:DIA]SOSPIT
REJ=1
REF=0

If find(right$(FICBASE,len(FICBASE)),"\","/")
 FICBASE= left$(FICBASE,len(FICBASE)-1)
Endif

Call MACHINE(FICBASE,MACHINE,MACFIC) From ORDSYS
Call EXISTE(FICBASE,TYPFIC) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
Case TYPFIC
 When 2 : # C'est un répertoire
  EXT = "csv"
  Call SYSTEME2(MACHINE,'lsadx "'+MACFIC+'" "'+NOMBASE+"*."+EXT+'"','',NBTRAIT,TRAIT) From ORDSYS
  If NBTRAIT>dim(TRAIT)
   Call ECR_TRACE(mess(29,139,1)-"."+EXT-"("+num$(NBTRAIT)+"/"+num$(dim(TRAIT))+")",1) From GESECRAN : # Trop de fichiers
   NBERR+=1
   End
  Endif
 When 1 : # C'est un fichier normal
  NBTRAIT  = 1
  If FICCLI<>""
   Call SETNAM(FICCLI,TRAIT(1),EXT) From GOBJTXT
  Else
      #Call REPERT(FICBASE,FICBASE,TRAIT(1),EXT)
      Call ECR_TRACE("|"+FICBASE-":"-mess(159,141,1),1) From GESECRAN : # Fichier ou répertoire inexistant
      NBERR+=1
      End
  Endif
 When Default : # Ca n'existe pas
      Call ECR_TRACE("|"+FICBASE-":"-mess(159,141,1),1) From GESECRAN : # Fichier ou répertoire inexistant
      NBERR+=1
      End
Endcase

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium

For P=1 To NBTRAIT
 If FICCLI<>""
      FICCSV = FICBASE
      WFICREF= FICBASE+"_ref"
      WFICREJ= FICBASE+"_rej"
 Else 
    J=instr(1,TRAIT(P),EXT)
    If J>2
        TRAIT(P)=left$(TRAIT(P),J-2)
    Endif
    FICCSV = filpath(FICBASE,TRAIT(P),EXT,"","",MACHINE)
    Call MACHINE([M:DIA]DRTISS,MACHINE,MACFIC) From ORDSYS
    WFICREF= filpath([M:DIA]DRTISS,"REF"+TRAIT(P)+WDATBAS,EXT,"","",MACHINE)
    Call MACHINE([M:DIA]DRTSTO,MACHINE,MACFIC) From ORDSYS
    WFICREJ= filpath([M:DIA]DRTSTO,TRAIT(P)+WDATBAS+"_rej",EXT,"","",MACHINE)
 Endif
 TAILFIC = filinfo(FICCSV,7)
 If TAILFIC<0 : # Il aurait pu disparaître!!
  Call ECR_TRACE("|"+FICCSV-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
  NBERR+=1
 Else
  Gosub INTEGRE
 Endif

Next P
Openi

adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End

######################################################################################
$INTEGRE
Local Integer ERR : ERR=0
Local Integer ERRNOFIC : ERRNOFIC=0
Local Integer OK , STAT

 Raz ERR,ERRNOFIC
 Call TRAITE("SCMD",OS(1),FICCSV,FICCLI,CONPIT,[M:DIA]ID,[M:DIA]SOSDLTFLG,[M:DIA]SOSRAZFLG,REJ,WFICREJ,REF,WFICREF,ERR,ERRNOFIC) From=CONPROG
 If ERR
    #erreur sur un des fichiers
    NBERR+=1
 Endif
 #on doit basculer le fichier dans le repertoire des fichiers traites ssi sur serveur
 If FICCLI="" & !ERRNOFIC
    WFICTMP= filpath([M:DIA]DRTSTO,TRAIT(P)+WDATBAS,EXT,"","",MACHINE)
    Call MOVE_EMPTY(FICCSV,WFICTMP,STAT) From ORDSYS
 Endif
 #si fichier des rejets, on doit le recuperer
 If FICCLI<>"" & REJ=1
      Call MOVCLI(WFICREJ,FICREJ,STAT) From ORDSYS
 Endif
 #si fichier des references, on doit le récuperer
 If FICCLI<>"" & REF=1
      Call MOVCLI(WFICREF,FICREF,STAT) From ORDSYS
 Endif
Return




######################################################################################
$INI_VAR
# Déclaration des variables globales
Gosub INIVARNB From CONNECTSOS
Return

$SUP_VAR
# Désallocation des variables globales
Gosub SUPVARNB From CONNECTSOS
Return


#######################################################
$FIN_CPTRENDU
Local Char WCLIGNE (100)
WCLIGNE="======================================================================" 

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
############
# Import des prévisions de ventes
Call ECR_TRACE("=========="-mess(74,7710,1),0) From GESECRAN
# nombre de fichiers traités
Call ECR_TRACE(mess(2,7710,1)-':'-num$(GCONSOS_NBF),0) From GESECRAN
For I=1 To GCONSOS_NBF
    Call ECR_TRACE('          '+ctrans(GCONSOS_FIC(I),"\","/"),0) From GESECRAN
Next I
Call ECR_TRACE("",0) From GESECRAN

# nombre d'enreg lus
Call ECR_TRACE(mess(3,7710,1)-':'-num$(GCONSOS_ENR),0) From GESECRAN
# nombre d'enreg importés en insertion
Call ECR_TRACE('     '+mess(4,7710,1)-':'-num$(GCONSOS_NEW),0) From GESECRAN
# nombre d'enreg importés en maj
##Call ECR_TRACE('     '+mess(5,7710,1)-':'-num$(GCONSOS_MAJ),0) From GESECRAN
# nombre d'enreg rejetés
If GCONSOS_REJ > 0
Call ECR_TRACE('     '+mess(6,7710,1)-':'-num$(GCONSOS_REJ),-1) From GESECRAN
Else
Call ECR_TRACE('     '+mess(6,7710,1)-':'-num$(GCONSOS_REJ),0) From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN

#########"
Call ECR_TRACE(WCLIGNE,0) From GESECRAN
#Call ECR_TRACE(WCLIGNE,0) From GESECRAN
Return


########################################################################
# transfert fichiers serveur vers client
$TRF_FILES_SOH
Local Char PATH (GDIMFIC)
Local Char WFICHIER (GDIMFIC)
Local Integer STAT

Local Char MACHINE(GDIMFIC) , MACFIC(GDIMFIC)
Call MACHINE([M:DIA]DRTISS,MACHINE,MACFIC) From ORDSYS

#on doit basculer le fichier dans le repertoire des fichiers destination

# en-cours commandes
PATH = filpath("tmp",tolower([M:DIA]ID)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitsoq")
WFICHIER = filpath([M:DIA]DRTISS,"SCMDSOH","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
    Call MOVCLI(PATH ,WFICHIER ,STAT) From ORDSYS
Elsif [M:DIA]TYPEXP=2
