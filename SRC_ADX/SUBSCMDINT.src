######################################################################################


Subprog AS_DRTRCP(VALEUR)
Variable Char    VALEUR()
If [M:DIA]TYPEXP = 1
    Grizo [M:DIA]DRTRCP
    [S]mkstat=2
Endif
End

Subprog C_DRTRCP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End

Subprog AS_DRTSTO(VALEUR)
Variable Char    VALEUR()
If [M:DIA]TYPEXP = 1
    Grizo [M:DIA]DRTSTO
    [S]mkstat=2
Endif
End

Subprog C_DRTSTO(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End


Subprog AS_DRTISS(VALEUR)
