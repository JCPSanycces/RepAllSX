Subprog C_HSOHENDDAT(VALEUR)
Variable Date    VALEUR
If [M:DIA]HSOHSTRDAT>VALEUR & VALEUR<>[0/0/0]
    GERR=1
    GMESSAGE=mess(99,177,1)
    mkstat=2
Endif
End


Subprog AM_HSOHENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
    [M]HSOHEDTFLG=1 : Affzo [M]HSOHEDTFLG
    Grizo [M]HSOHEDTFLG
Else
    [M]HSOHEDTFLG=2 : Affzo [M]HSOHEDTFLG
    Actzo [M]HSOHEDTFLG
Endif
End


Subprog AM_HSOHEDTFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 
    [M]HSOHENDDAT=[0/0/0] : Affzo [M]HSOHENDDAT
    Grizo [M]HSOHENDDAT
Else
    If [M]HSOHENDDAT=[0/0/0] : [M]HSOHENDDAT=date$ : Endif
    Affzo [M]HSOHENDDAT
    Actzo [M]HSOHENDDAT
Endif
End

Subprog AM_HSOHSTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] 
    Raz [M]HSOHNDSTR: Affzo [M]HSOHNDSTR
    Grizo [M]HSOHNDSTR
Else
    Actzo [M]HSOHNDSTR
Endif
End

Subprog AM_HSOHNDSTR(VALEUR)
Variable Decimal VALEUR
If VALEUR>0 
    [M]HSOHSTRDAT=[0/0/0] : Affzo [M]HSOHSTRDAT
    Grizo [M]HSOHSTRDAT
Else
    Actzo [M]HSOHSTRDAT
Endif
End


######################################################################################
Subprog AM_SOSDLTFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]SOSRAZFLG=2
    [M]SOSRAZFLG=1 : Affzo [M]SOSRAZFLG
Endif
End

Subprog AM_SOSRAZFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M]SOSDLTFLG=2
    [M]SOSDLTFLG=1 : Affzo [M]SOSDLTFLG
Endif
End


