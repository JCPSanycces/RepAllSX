#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","UTIFIYPER","UTIFIYPER",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "EXEC"        : Gosub EXEC
 When Default
Endcase
Return


$OUVRE
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:FIY2])=0 : Local File FISCALYEAR [FIY2] : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:PER2])=0 : Local File PERIOD     [PER2] : Endif

Local Integer NBLED
Return


$EXEC
TIT = mess(2,45,1)-[M:DIA]CPY-":"-mess(189,107,1)-mess([M:DIA]LEDTYP,2644,1) : # Création des exercices et périodes sur référentiel
Call OUVRE_TRACE(TIT) From LECFIC

Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 

Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1 : Return : Endif

Call LEC_TRACE From LECFIC
Call FERME_TRACE From LECFIC
Return


$TR1
GOK = 1
Trbegin [FIY], [PER]
 ## Les exercices et périodes du nouveau reférentiel sont créées à partir du référentiel général principal et en conservant la même
 ## définition des exercices/périodes
 ## En revanche, un exercice 'fermé' sur le référentiel général principal est créé avec le statut 'Ouvert' sur le nouveau type référentiel 
 ## Creation for the ledger entered but also for all the automatics ledgers which original ledger type is the ledger entered
 Read [CPY]CPY0 = [M]CPY
 Read [GCM]GCM0 = [F:CPY]ACM

 For NBLED = 1 To len(mess(0,2644,1))
  If (NBLED=[M:DIA]LEDTYP & [F:GCM]CFMAUT(NBLED-1)<>2)
&  | ([F:GCM]ORILEDTYP(NBLED-1)=[M:DIA]LEDTYP & [F:GCM]CFMAUT(NBLED-1)=2)
   For [FIY2]FIY0 Where CPY=[M:DIA]CPY & LEDTYP=GTYPGEN
    Raz [F:FIY]
    [F:FIY] = [F:FIY2]
    [F:FIY]LEDTYP = NBLED
    [F:FIY]LEDTYPAUT = [F:GCM]CFMAUT(NBLED-1)
    If [F:FIY2]FIYSTA = 3
     [F:FIY]FIYSTA = 2
    Endif
    Write [FIY]
    If fstat 
     GOK=0 : Call FSTA("FIY") From GLOCK : Break 2
    Endif
    For [PER2]PER0 Where CPY=[M]CPY & FIYNUM=[F:FIY2]FIYNUM & LEDTYP=GTYPGEN
     Raz [F:PER]
     [F:PER] = [F:PER2]
     [F:PER]LEDTYP = NBLED
     [F:PER]LEDTYPAUT = [F:GCM]CFMAUT(NBLED-1)
     If [F:PER2]PERSTA = 3
      [F:PER]PERSTA = 2
     Endif
     Write [PER]
     If fstat 
      GOK=0 : Call FSTA("PER") From GLOCK : Break 3
     Endif
    Next
    ## Création exercices et périodes sur référentiel
    Call ECR_TRACE(mess(189,107,1)-mess(NBLED,2644,1)-format$(GFMDAT,[F:FIY]FIYSTR)-format$(GFMDAT,[F:FIY]FIYEND)-mess([F:FIY]FIYSTA,2618,1),0) From GESECRAN
   Next
  Endif
 Next
 If GOK<0    : Goto ROLL_TR1
 Elsif !GOK  : Goto AB_TR1
 Endif
Commit
Return


$ROLL_TR1
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif 
 
$AB_TR1
Rollback 
Return  
 

######################################################################################
## Etiquettes écran UTIFIYPER
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer NBLED, OKLED
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
Raz OKLED
Read [CPY]CPY0 = VALEUR
Read [GCM]GCM0 = [F:CPY]ACM
If !fstat
 For NBLED = 1 To len(mess(0,2644,1))
  If [F:GCM]LED(NBLED-1)<>"" & [F:GCM]CFMAUT(NBLED-1)<>2
   Filter [FIY] Where CPY=VALEUR & LEDTYP=NBLED
   Read [FIY]FIY0 First
   Filter [FIY]
   If fstat : OKLED =1 : Break : Endif  
  Endif 
 Next
Endif
If !OKLED
 # Tous les exercices et les périodes sont déjà ouvertes 
 GMESSAGE = mess(62,101,1) : mkstat = 2  : End
Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
## On inhibe les types référentiels pour lesquels des exercices ont déjà été définis pour
## la société
## On inhibe les référentiels automatiques
Local Integer NBLED
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
Raz GMENLOC
Read [CPY]CPY0 = [M]CPY
Read [GCM]GCM0 = [F:CPY]ACM
If !fstat
 For NBLED = 1 To len(mess(0,2644,1))
  If [F:GCM]LED(NBLED-1)="" | [F:GCM]CFMAUT(NBLED-1)=2
   GMENLOC(NBLED)=1
  Endif
  Filter [FIY] Where CPY=[M]CPY & LEDTYP=NBLED
  Read [FIY]FIY0 First
  Filter [FIY]
  If !fstat
   GMENLOC(NBLED)=1
  Endif  
 Next
Endif
End


#########################################################################################################
## Traitement qui commence par UTI mais qui n'est pas un utilitaire à lancer par patch
########################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI      
End

