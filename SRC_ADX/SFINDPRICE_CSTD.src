#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe FINDPRICE_C_PLI


$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AINIT"                :
                                         Gosub _AINIT
                                         Return
        When "FINDPRICE"            :
                                         #--Call to price search with empty instance of FINDPRICE (to be loaded)
                                         Gosub FINDPRICE
                                         Return
        When "FINDPRICE_OP"         :
                                         #--This calls direclty the library func TRTVENTAR_SYRA.SEARCHPRICE
                                         Gosub FINDPRICE_OP
                                         Return
        When "FINDPRICE_RESTRICTED" :
                                         Gosub FINDPRICE_RESTRICTED
                                         Return
        When "LOADPARAM"            :
                                         Gosub _LOADPARAM
                                         Return
        When "INITPARAM"            :
                                         Gosub _INITPARAM
                                         Return
        When Default                :
      Endcase
Endcase

Return
#--------------------------------------------------------------------------------------------------
$PROPERTIES
  Case [L]CURPRO

  Endcase

Return
#--------------------------------------------------------------------------------------------------
$_AINIT

  Gosub _INITPARAM

Return
#--------------------------------------------------------------------------------------------------
#--Call for price searche with instance of SFINDPRICE to be loaded
#--Input parameters : GENERIC_OBJ => instance of OBJECT class
#--Output           : status
#--Price search in 3 steps :
#   1) Call of LOADPARAM method who do a call back to a LOADPARAMFROMDOC meth of the calling object
#      during this callback the instance of FINDPRICE is loaded
#   2) Call to the library  func TRTVENTAR_SYRA.SEARCHPRICE
#      in return, one instance of RESULTPRICE class is loaded with the results
#   3) Call to LOADFROMRESULT method of RESULTPRICE instance that does a callback to a method LOADDOCFROMRESULT #
#      of the GENERIC_OBJ calling object
$FINDPRICE
#Variable Instance GENERIC_OBJ Using OBJECT
#Value    Integer  INDEXLINE
  If dim(INDEXLINE)<1
    Local Integer INDEXLINE
  Endif
  If INDEXLINE = 0 :INDEXLINE = 1 : Endif

#    this.setAccessorEnabled        = 0
#    GENERIC_OBJ.setAccessorEnabled = 0

  Local Integer WRET
  Local Char    WMESSA(250)
  #--First, we need to initialize/load the properties
  #--Call to a private methode in order to instantiate all needed collection within this (if not done yet)
  WRET = fmet this.INITPARAM()
  If WRET >= [V]CST_AERROR
    WMESSA = mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM"
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif

  #--It's done by calling the "private" method LOADPARAM, by passing on the MyDOC pointer
  WRET = fmet this.LOADPARAM(GENERIC_OBJ, INDEXLINE)
  If WRET >= [V]CST_AERROR
    WMESSA = mess(68,123,1)-":"-mess(1,7845,1)-"LOADPARAM"
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif

  #--New instance of the Result class
  #--It will be loaded by the SEARCHPRICE method called just bellow
  Local Instance MYRESULT Using C_RESULTPRICE
  MYRESULT = NewInstance C_RESULTPRICE AllocGroup null

  MYRESULT.setAccessorEnabled = 0
  #--The black box for Price searching (in fact it's the future "syracusation" of the TARIFRECH subroutine from TRTVENPRI
  #--We pass in the pointer to the result class

  WRET = func TRTVENTAR_SYRA.SEARCHPRICE(this,INDEXLINE, MYRESULT)
  If WRET >= [V]CST_AERROR
    WMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"SEARCHPRICE"
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
    Goto END_FINDPRICE
  Endif

  #--Loading the Document from the Result class (Help yourself...)
  WRET = fmet MYRESULT.LOADFROMRESULT(GENERIC_OBJ, INDEXLINE, this)
  If WRET >= [V]CST_AERROR
    WMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"LOADFROMRESULT"
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
    Goto END_FINDPRICE
  Endif


$END_FINDPRICE
  #--Free the instance MYRESULT...
  #FreeInstance =MYRESULT.AllocGrp
  FreeGroup MYRESULT
  [L]ARET_VALUE = [L]ASTATUS
#  this.setAccessorEnabled = 1
#  GENERIC_OBJ.setAccessorEnabled = 1

Return
#--------------------------------------------------------------------------------------------------
#--This calls direclty the library func TRTVENTAR_SYRA.SEARCHPRICE
#--Input parameters : MYPARAM  => already loaded instance of SFINDPRICE class
#--Output           : MYRESULT => result of the price search fonction loaded into an instance of RESULTPRICE class
$FINDPRICE_OP
#Variable Instance MYPARAM  Using SFINDPRICE
#Variable Instance MYRESULT Using RESULTPRICE

  If MYPARAM = null
    [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "MYPARAM :"-mess(18,9137,1), [V]CST_AWARNING)
    Return
  Endif

  Local Integer WRET
  Local Char    WMESSA(250)

  If dim(INDEXLINE)<1
    Local Integer INDEXLINE
  Endif
  If INDEXLINE = 0 :INDEXLINE = 1 : Endif

  #---- initialisation
  If MYRESULT=null
    MYRESULT = NewInstance C_RESULTPRICE AllocGroup MYPARAM
  Endif

  #--The black box for Price searching (in fact it's the future "syracusation" of the TARIFRECH subroutine from TRTVENPRI
  #--We pass in the pointer to the result class
  WRET = func TRTVENTAR_SYRA.SEARCHPRICE(MYPARAM, INDEXLINE, MYRESULT)
  If WRET >= [V]CST_AERROR
    WMESSA = mess(68,123,1)-":"-mess(2,7845,1)-"SEARCHPRICE"
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif

Return
#--------------------------------------------------------------------------------------------------
$_INITPARAM
#--No Input parameters
  Local Integer WRET

  #--Normaly, it's done by the supervisor (1 to 1 collection)
  If this.C_SPKH(1) = null
    WRET = fmet this.ADDLINE("C_SPKH",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_SPKH","SFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  #--Mandatory to have at list 1 item it this collection
  If this.C_LINE(1) = null
    WRET = fmet this.ADDLINE("C_LINE",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_LINE","SFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  #--Normaly, it's done by the supervisor (1 to 1 collection)
  If this.C_LINE(1).C_SPKD(1) = null
    WRET = fmet this.C_LINE(1).ADDLINE("C_SPKD",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_SPKD","SFINDPRICE.C_LINE(1)"), [V]CST_AERROR)
      Return
    Endif
  Endif

  #--The PLI collection is filled by the calling object instance
  #--(it contains the price lists compatible with the current company as for the price structure)
  If this.PLI(1) = null
    WRET = fmet this.ADDLINE("PLI",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"PLI","SFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

  #--The FMTCOLREM collection is filled by the calling object instante trought the LOADPARAMFROMDOC method
  If this.FMTCOLREM(1) = null
    WRET = fmet this.ADDLINE("FMTCOLREM",1)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"FMTCOLREM","SFINDPRICE"), [V]CST_AERROR)
      Return
    Endif
  Endif

Return
#--------------------------------------------------------------------------------------------------
#--LOADPARAMFROMDOC => sort of "interface" method
#--We ask the calling object to fill us
#--The object must therefor implement this method in order to be able to call the FINDPRICE method
$_LOADPARAM
#Variable Instance GENERIC_OBJ Using OBJECT
#Value    Integer  INDEXLINE
  If dim(INDEXLINE)<1
    Local Integer INDEXLINE
  Endif
  If INDEXLINE = 0 :INDEXLINE = 1 : Endif

  Local Integer WRET
  Local Char    WMESSA(250)

  If GENERIC_OBJ=null
  	[L]ASTATUS = fmet this.ASETERROR ("", "GENERIC_OBJ"-mess(18,9137,1), [V]CST_AERROR)
    Return
  Endif

  Local Instance MYDOC Using =GENERIC_OBJ.ObjectType

  MYDOC = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

  #--We ask the calling object to fill us
  #--The object must therefor implement this method in order to be able to call the FINDPRICE method
  #--We pass in a pointer to the current instance
  #Onerrgo ERR_LOADPARAMFROMDOC_METHNOTSUPPORTED
    WRET = fmet MYDOC.LOADPARAMFROMDOC(this, INDEXLINE)
  #Onerrgo
  If WRET >= [V]CST_AERROR
    WMESSA = mess(68,123,1)-":"-mess(1,7845,1)-"LOADPARAMFROMDOC"
    [L]ASTATUS = fmet this.ASETERROR ("", WMESSA, WRET)
    Return
  Endif

Return

$ERR_LOADPARAMFROMDOC_METHNOTSUPPORTED

#  [L]ASTATUS = fmet this.ASETERROR ("", "Class"-MYDOC.ObjectType-" : No such method defined LOADPARAMFROMDOC", [V]CST_AERROR)

Resume
#--------------------------------------------------------------------------------------------------
$FINDPRICE_RESTRICTED
#Variable Instance GENERIC_OBJ Using OBJECT
#Value    Integer  INDEXLINE

    If dim(INDEXLINE)<1
      Local Integer INDEXLINE
    Endif
    If INDEXLINE = 0 :INDEXLINE = 1 : Endif

    Local Integer WRET
    Local Char    WMESSAGE(250)
    Local Integer WSAVE_PLITYP

    #--First, we need to initialize/load the properties
    #--Call to a private methode in order to instantiate all needed collection within this (if not done yet)
    WRET = fmet this.INITPARAM()
    If WRET >= [V]CST_AERROR
      WMESSAGE = mess(68,123,1)-":"-mess(1,7845,1)-"INITPARAM"
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif

    #--It's done by calling the "private" method LOADPARAM, by passing on the MyDOC pointer
    WRET = fmet this.LOADPARAM(GENERIC_OBJ, INDEXLINE)
    If WRET >= [V]CST_AERROR
      WMESSAGE = mess(68,123,1)-":"-mess(1,7845,1)-"LOADPARAM"
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
      [L]ARET_VALUE = [L]ASTATUS
      Return
    Endif

    WSAVE_PLITYP = this.PLITYP
    this.PLITYP  = 3 :# Price type : restricted

    #--The black box for Price searching (in fact it's the future "syracusation" of the TARIFRECH subroutine from TRTVENPRI
    #--We pass in the pointer to the result class

    WRET = func TRTVENTAR_SYRA.SEARCHPRICE_RESTRICTED(this, 1, WMESSAGE)
    If WRET >= [V]CST_AINFO
      If WMESSAGE=""
        WMESSAGE = mess(68,123,1)-":"-mess(2,7845,1)-"SEARCHPRICE_RESTRICTED"
      Endif
      [L]ASTATUS = fmet this.ASETERROR ("", WMESSAGE, WRET)
      [L]ARET_VALUE = [L]ASTATUS
      this.PLITYP = WSAVE_PLITYP
      Return
    Endif

    this.PLITYP = WSAVE_PLITYP

Return

