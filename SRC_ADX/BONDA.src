#<AdxTL>@(#)5.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR 
Variable Char    PARAMETRE()()
Local Integer IMPR
# ajout borne dates de demande achat 23/04/2008 SYMEU
Local Date DATREF

Gosub OUVRE 
If GERREUR : GERREUR=0 : End : Endif 
Gosub DECLARE 
 
[L]CRITERE = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
 #[L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "sitedeb"         : [L]CRITERE -= "& PSHFCY>='"+[L]VALEUR+"'"
   When "sitefin"         : [L]CRITERE -= "& PSHFCY<='"+[L]VALEUR+"'" 
   When "signedeb"        : [L]CRITERE -= "& APPFLG>="+num$([L]VALEUR)
   When "signefin"        : [L]CRITERE -= "& APPFLG<="+num$([L]VALEUR)
   When "demandedeb"      : [L]CRITERE -= "& PSHNUM>='"+[L]VALEUR+"'" 
   When "demandefin"      : [L]CRITERE -= "& PSHNUM<='"+[L]VALEUR+"'"
   # ajout borne dates de demande achat 23/04/2008 SYMEU
   When "datedeb"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE -= "& PRQDAT >=["+format$(GFMD,[L]DATREF)+']'
   When "datefin"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE -= "& PRQDAT <=["+format$(GFMD,[L]DATREF)+']'
   When "codimp"          : [L]CRITERE -= "& PRNFLG="+num$([L]VALEUR)
                            [L]IMPR     = val([L]VALEUR) 
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
 Endcase
 Endif
Next
#----- Filtre signature intégré ci-dessus -----#
# [L]CRITERE -= "& APPFLG>"+num$(2)
#----------------------------------------------#
# Issue 89114 - 2013-04-04 by SR : etat enchaine
Look [ARM]ARM0 = [L]NUMREQ;GUSER;[F:ARP]RPTCOD;1
If !fstat
  # Enreg trouvé, car lancement enchainé
  # On bloque la boucle
  End
  #On laisse GOK=1 sinon l'état ne sort pas
Endif

Filter [PSH] Where evalue([L]CRITERE)
Gosub TRT_PSH
  
End

###################################################################
###################################################################

$TRT_PSH
Raz WNUMLIG 
Default File [PSH]
For [PSH] PSH0
   Call DEBTRANS From GLOCK 
   If [L]IMPR = 1 Gosub TR1
   Else           Gosub TR2
   Endif 
Next 
Return

##########################################################################

$TR1
Trbegin [PSH] , [ARM] 

# Mise à jour table entête DA si demande d'impression
If [L]IMPR = 1
 Readlock [PSH] PSH0 Curr
 If fstat = 1 : GOK = -1 : GLOCK = "$PREQUIS" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("PSH","*") From GLOCK : Goto AB_TR1
 Endif
 [F:PSH]PRNFLG = 2
 Rewrite [PSH]   
 If fstat=1 
  GOK=-1 : GLOCK="$PREQUIS"-[F:PSH]PSHNUM
  Goto ROLL_TR1 
 Elsif fstat 
  GOK=0 : Call RSTA("PREQUIS",[F:PSH]PSHNUM) From GLOCK : Goto AB_TR1 
 Endif  
Endif
 
#Création de l'enregistrement dans la table AREPORTM
WNUMLIG      += 1

Raz [F:ARM]
[F:ARM]USR     = GUSER
[F:ARM]RPTCOD  = [F:ARP]RPTCOD
[F:ARM]NUMREQ  = [L]NUMREQ
[F:ARM]NUMLIG  = WNUMLIG
[F:ARM]CLEA1   = [F:PSH]PSHNUM
[F:ARM]CREDAT  = date$
Write [F:ARM]   
If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
Commit 
Return 
 
$ROLL_TR1
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif 
 
$AB_TR1 
Rollback 
Return 

##############################
$TR2
Trbegin [ARM]
#Création de l'enregistrement dans la table AREPORTM
WNUMLIG      += 1

Raz [F:ARM]
[F:ARM]USR     = GUSER
[F:ARM]RPTCOD  = [F:ARP]RPTCOD
[F:ARM]NUMREQ  = [L]NUMREQ
[F:ARM]NUMLIG  = WNUMLIG
[F:ARM]CLEA1   = [F:PSH]PSHNUM
[F:ARM]CREDAT  = date$
Write [F:ARM]   
If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
Commit 
Return 
 
$ROLL_TR2
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR2 : Endif 
 
$AB_TR2 
Rollback 
Return 

########################################################################### 
 
$OUVRE 
Local File PREQUIS [PSH], AREPORTM [ARM]
Return 
 
$DECLARE 
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP)
Local Integer WNUMLIG, NUMREQ 
Return 
 
