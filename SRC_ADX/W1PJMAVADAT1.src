#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMAVADAT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:43"
A_USER  = "DOC"
A_STAMP = "20181109230543"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMAVADAT1 [PAVD1]
Gosub HORODAT
Local Inpbox "PJMAVADAT1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PAVD1] As [SIM_]
Grizo [PAVD1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PAVD1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1PJMAVADAT1
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(5562,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1PJMAVADAT1
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = [M:PAVD1]KEYCOD(nolign-1)
 Call OBJET_CHAR(OBJCLE,[M:PAVD1]AOBCOD(nolign-1),"") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_AOB
Onevent INIT_AREA Call D_AOB(zc) From W1PJMAVADAT1
Return

Subprog D_AOB(VALEUR)
Variable Integer VALEUR
If varinit([M]AOB,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_KEYCOD
Return

$ON_QTY
Onevent BEFORE_AREA Gosub AV_QTY From W1PJMAVADAT1
Return

$AV_QTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PAVD1]UOM(nolign-1),GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]QTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_UOM
Return

$ON_QTYITM
Onevent BEFORE_AREA Gosub AV_QTYITM From W1PJMAVADAT1
Return

$AV_QTYITM
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PAVD1]UOMITM(nolign-1),GUNITE(1..GNBUNT)),1))
Endif
Gosub _AFF
Return

$ON_UOMITM
Return

$ON_DAT
Onevent BEFORE_AREA Gosub AV_DAT From W1PJMAVADAT1
Return

$AV_DAT
Chgfmt [M]DAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_BPSNUM
Return

$ON_AVADATSTA
Onevent INIT_AREA Call D_AVADATSTA(zc) From W1PJMAVADAT1
Return

Subprog D_AVADATSTA(VALEUR)
Variable Integer VALEUR
If varinit([M]AVADATSTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_AOBCOD
Return

$ON_POHNUM
Return

$ON_MFGNUM
Return

$ON_SCONUM
Return

$CHG_STY
Return


