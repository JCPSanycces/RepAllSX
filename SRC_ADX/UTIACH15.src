##########################################################################
# UTIACH15      Utilitaire de rÃĐcupÃĐration du bug ?????     Module ACHAT #
# ---------------------------------------------------------------------- #
# ProblÃĻme Ã  rÃĐsoudre :                                                  #
#   Pour les demandes de livraison inter-sites, le numÃĐro de sÃĐquence de #
#      la demande de livraison vente a ÃĐtÃĐ perdu lors du passage de la   #
#      version 130 Ã  140.                                                #
#   L'utilitaire a pour but de mettre Ã  jour ce numÃĐro de sÃĐquence       #
#      champ [F:POQ]OCNSEQ.                                              #
##########################################################################

Call MAJ_UTIACH15
End

Subprog MAJ_UTIACH15
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH15 - RÃĐcup. Bug ?????") From SAIDOS
If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH15 : Utilitaire rÃĐajustement sÃĐquence lien inter-sites ventes") From LECFIC
  Call EXE_UTIACH15(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End

Subprog EXE_UTIACH15(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90), CRITERE(100)
Local Char     CLE1(GLONPOH)
Local Integer COMPTEUR, STOP
Local Integer  NBENR, NBCOR
Local Char     WPOHNUM(GLONPOH)
Local Integer  WPOPLIN
Local Integer  WPOQSEQ
#-----
Call ECR_TIME("UTIACH15 : DÃĐbut traitement du dossier "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:POH])  Local File =DOSSIER+".PORDER"    [POH] : Endif
If !clalev([F:POQ])  Local File =DOSSIER+".PORDERQ"   [POQ] : Endif
If !clalev([F:SOQ])  Local File =DOSSIER+".SORDERQ"   [SOQ] : Endif
#----- DÃĐbut du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, NBENR, NBCOR, STOP
Raz WPOHNUM, WPOPLIN, WPOQSEQ
#-----
$BOUCLE_POH
If STOP=1
  STOP=0 : CRITERE ='POHNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [POQ]
  For [POH] POH0 Where evalue(CRITERE) & POHTYP=2 & BETFCY=2
    For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM & LINOCNNUM<>""
      NBENR+=1
      If OCNSEQ=0
        WPOHNUM=[F:POQ]POHNUM
        WPOPLIN=[F:POQ]POPLIN
        WPOQSEQ=[F:POQ]POQSEQ
        Filter [SOQ] Where SOHNUM=[F:POQ]LINOCNNUM
&                        & SOPLIN=[F:POQ]OCNLIN
&                        & POHNUM=[F:POQ]POHNUM
&                        & POPLIN=[F:POQ]POPLIN
&                        & POQSEQ=[F:POQ]POQSEQ
        Read [SOQ] SOQ0 First
        If !fstat
          COMPTEUR+=1
          Update [POQ] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POQSEQ=WPOQSEQ
&                      With  OCNSEQ=[F:SOQ]SOQSEQ
          If fstat
            Call ECR_TRACE("Update PORDERQ"-WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
           #If fstat=3  GOK=0 : Break 2 : Endif : # Pour l'instant on continue en cas d'erreur !
          Else
            NBCOR+=1
            WMSG =WPOHNUM
            WMSG+=space$(9-len(num$(WPOPLIN)))+num$(WPOPLIN)
            WMSG+=space$(9-len(num$(WPOQSEQ)))+num$(WPOQSEQ)-[F:POQ]ITMREF
            WMSG+=space$(GLONITM-len([F:POQ]ITMREF))
            WMSG+="SÃĐquence ventes :"-num$([F:SOQ]SOQSEQ)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
        Endif
      Endif
    Next
    #-----
    If COMPTEUR>GMAXUPDTRS
      CLE1=WPOHNUM
      STOP=1 : Break
    Endif
  Next
  If GOK<1  Rollback : Goto FIN_UTIACH15 : Endif
Commit
If STOP  Goto BOUCLE_POH : Endif
#----- Fin du traitement -----#
$FIN_UTIACH15
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH15 : Nbre d'enregistrements traitÃĐs :"-num$(NBENR)
WMSG+=" dont corrigÃĐs :"-num$(NBCOR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [POH], [POQ], [SOQ]
End
