#<AdxTL>@(#)5.0.0.0 $Revision$
#Close Local File
Raz GPILOBJ,GNBMASKOUV
#GCONSULT = 0
#Call OBJET("ALT",GBIDC1,GBIDC2) From GOBJET
#End

###########################################################
## Action CALALH
###########################################################

Local Char PARAM(250)(1..3) , VALEUR(250)
PARAM(1) = ""
PARAM(2) = "1"
PARAM(3) = "1"
If GPRODUIT=1 : [V]GCHGENV=2 : Endif
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBALH9","ALH9",4,"SPEALH") From GTRAITE
End

###########################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "OUVRE_BATCH" : Gosub DECLARE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
 When "CONTPAR1"    : Gosub CONTPAR1
 When "CONTPAR2"    : Gosub CONTPAR2
 When "MODIFPAR1"   : Gosub MODIFPAR1
Endcase
Return

###########################################################
$INIT
Gosub DECLARE
Local Mask ALH9 [DIA]
LISTE  = PARAM(1)      : # Code requête
CHGLIS = val(PARAM(2)) : # Autorisation choix d'une autre requête
AFF    = val(PARAM(3)) : # 0 trace, 1 affichage calcul requête
If dim(PARAM)>=7
 [L]MAXLIG = val(PARAM(7))
Endif
Read [ALH]ALH0 = LISTE
If !fstat
 If [L]MAXLIG>0
  If [F:ALH]MAXLIG>0 : [L]MAXLIG = min([F:ALH]MAXLIG,[L]MAXLIG) : Endif
 Else
  [L]MAXLIG = [F:ALH]MAXLIG
 Endif
Endif

If !GSERVEUR & LISTE="" & !CHGLIS
 FIN = 1 : Return
Elsif LISTE<>""
 Gosub CONTROLES From SUBALH2
 If GERR
  If !CHGLIS
   FIN = 1 :  Return
  Else
   LISTE = ""
  Endif
 Endif
Endif

If BCRIT="" : # Pour calculer directement sans saisir les paramètres
 If LISTE<>""
  Gosub CHARGE
  [M:DIA]COD = LISTE
 Else
  FIN = 1 : Return
 Endif
Endif

TMP=1
Return

$DEBUT
Local Integer NOL
If PARAM(1)<>""
 Local Char LISTE(GLONALH)
 LISTE = PARAM(1)
 Gosub CHARGE
 [M:DIA]COD = LISTE
 If [M:DIA]COD<>"" : Grizo [M:DIA]COD : Endif
 Gosub REMPLIT_PLAG
 Affzo
Endif
Return

##############

$REMPLIT_PLAG
Local Integer I,J,K
For K=1 To [M:DIA]NBPLAG
 J=0
 For I=0 To [M:DIA]NBPLAG-1
  If [M:DIA]INTIT(K-1) = [M:DIA]PARPLAG(I)
   J+=1
  Endif
 Next I
 If J>1
  Chgstl [M:DIA]DEB(K-1) With "APARPLAG"
  Chgstl [M:DIA]FIN(K-1) With "APARPLAG"
  Affzo
 Endif
Next K
Return

##############

$DECLARE
If clalev([F:ALH])=0  : Local File ALISTEH  [ALH]  : Endif
If clalev([F:ALD])=0  : Local File ALISTED  [ALD]  : Endif
Gosub ALISTER From SUBALH2
If clalev([F:ATY])=0  : Local File ATYPE    [ATY]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET   [AOB]  : Endif
If clalev([F:ACC])=0  : Local File ACCES    [ACC]  : Endif
If clalev([F:ARV])=0  : Local File AREPORTV [ARV]  : Endif
If filinfo(filpath("FIL","AVIEWTAB","fde"),0)<0
 Local File ATABLE [AVWT]
Else
 Local File AVIEWTAB [AVWT]
Endif

Local Integer MAXCOL , NIVCUM
MAXCOL = 100
NIVCUM = 16
Local Integer CHGLIS
Local Integer I , J , K , ER , NOL , NBCRIT , GRAPH , OKTRT , OKCONT , ERCONT
Local Integer T , TF , TD
Local Char    LISTE(GLONALH) , WPROG(GLONADC) , MASQUE(GLONAMK) , TIMED(4)
Local Date    DATED
Local Char    CDEB(GLONAVR)(1..MAXCOL) , CFIN(GLONAVR)(1..MAXCOL)
Local Integer NIVEAU , NBGRP , NBLIG , NBCOL , TIM , TEMPO , MAXTIM , MAXLIG , TRI(1..NIVCUM)
Local Integer NB , PAGE , DEBLIG , FINLIG , MAXPAG , PLEIN , TYP
Local Integer CUM(1..MAXCOL) , GRP(1..MAXCOL) , TBTYP(1..MAXCOL) , COLGRP , SNSGRP
Local Integer NBB(1..NIVCUM) , ONB(1..NIVCUM)
Local Decimal TBNUM(1..MAXCOL,1..NIVCUM)
Local Date    TBDAT(1..MAXCOL,1..NIVCUM)
Local Char    TBVLR(GLONAVR)(1..MAXCOL,1..NIVCUM)
Local Char    CRITERE(250)(0..3) , CHAMP(30)
Local Integer ICRIT
Local Char    SAV_CHAR(50)
Local Decimal SAV_DECI
Local Date    SAV_DATE
Local Integer FLPOS
Local Integer DEBUG
Local Integer TBNIV(1..MAXCOL)
Local Char    UTIL(15), UTIL0(15)
Local Char    FILTRE(250)
Local Char    AOBSIT(GLONAVA), AOBACC(GLONAVA), AOBFIC(GLONABR)
Local Char    VALCHP(GLONAVR),VALCHP1(GLONAVR),VALCHP2(GLONAVR) : # mb 13.9.2 bug 15714
Local Integer AFF
Local Char    SYMBOLE(GLONASYM), SYMBOLE2(GLONASYM), SAVFONC(GLONAFC)
Local Integer EXEC : # pour $CONTROLES de SUBALH2
Local Char    CRITENV(100), LNKFIC(GLONABR)
Local Char    CRITSUP(250)(1..5) , CRITNXT(250)
#### Variable pour les valeurs multiples
Local Char    INTPLAG(80)(1..MAXCOL),DEBPLAG(GLONAVR)(1..MAXCOL),FINPLAG(GLONAVR)(1..MAXCOL),CRITPLAG(250)
Local Integer BORNPLAG(1..MAXCOL),NBPLAGE
Local Char    WCOD(30),CHAINE(250)
Local Integer NBRWRITE , MAXWRITE

SAVFONC = GFONCTION
DEBUG = 0

Return

###########################################################
$SET_UTIL
If [F:ALH]ALLUSR=2 | UTIL0="" : UTIL=GUSER
Else                          : UTIL=UTIL0
Endif

GPOINT = "SET_UTIL" : Gosub ENTREE From EXEFNC
Return

###########################################################
$CHARGE
Local Integer NOL , K , OKDEF
Local Char    UTIL(15) , CRITPLAG(250)
Local Char    DESAX(40)

Gosub SET_ENV From SUBALH2
If dim([M:LST]USR)>0 : UTIL=[M:LST]USR
Else  UTIL=""
Endif

Read [ALH]ALH0 = LISTE
If dim(GFCTIMP)>0 &  GFCTIMP<>""
 If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
  If [F:ALH]ALLUSR=2
   Read [ALR]ALR0(3) = LISTE;LFCY;LDEP
  Else
   Read [ALR]ALR0(4) = LISTE;LFCY;LDEP;GUSER
  Endif
 Elsif [F:ALH]ALLUSR=2
  Read [ALR]ALR0(1) = LISTE
 Else
  Read [ALR]ALR0(2) = LISTE;GUSER
 Endif
 If !fstat
  UTIL = [F:ALR]USR
 Else
  UTIL = ""
 Endif
Endif

# Les valeurs par défaut ne sont pas chargés:
# - en consultation de critères sauf si la requête n'a jamais été calculée
# - si on vient d'un menu Fichier/imprimer

OKDEF = 0
If GACTION<>"CALALH" & (dim(GFCTIMP)<1 or GFCTIMP="") or UTIL=""
 For [ALD]ALD0 Where COD=[F:ALH]COD & find(STREND,2,3)<>0
  If [F:ALD]VALDEB<>"" or [F:ALD]VALFIN<>""
   OKDEF = 1 : Break
  Endif
 Next ALD
Endif

NOL = 0
Raz [M:DIA]
For [ALD]ALD0 Where COD=[F:ALH]COD & find(STREND,2,3)<>0
 If dim([F:ALD]NUMTEX)>0 and [F:ALD]NUMTEX>0
  Call LECTEXTRA([M:DIA]INTIT(NOL),"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]NUMTEX)) From ATEXTRA
 Else
  Call LECTEXTRA([M:DIA]INTIT(NOL),"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]LIG)) From ATEXTRA
 Endif
 Read [AVWT]CODFIC = [F:ALD]TBL
 If [F:ALD]CODTYP="ATX"
  [M:DIA]TABFLD(NOL) = "[F:AX"+num$([F:ALD]LIG+10)+"]TEXTE"
 Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")
  [M:DIA]TABFLD(NOL) = "[F:AY"+num$([F:ALD]LIG+10)+"]TEXTE"
 Else
  [M:DIA]TABFLD(NOL) = "[F:"+[F:AVWT]ABRFIC+"]"+[F:ALD]FLD
 Endif
 Read [ATY]CODTYP = [F:ALD]CODTYP
 If find([F:ATY]CODTYP,"ATX","AXX","AX1","AX2","AX3")
  [M:DIA]CODTYP(NOL) = "A"
  [M:DIA]TYP(NOL)    = 7
  [M:DIA]LONG(NOL)   = 30
 Else
  [M:DIA]CODTYP(NOL) = [F:ALD]CODTYP
  [M:DIA]TYP(NOL)    = [F:ATY]TYPTYP
  If [F:ATY]LNGTYP<>0
   [M:DIA]LONG(NOL) = [F:ATY]LNGTYP
  Else
   [M:DIA]LONG(NOL) = [F:ALD]LNG
  Endif
  [M:DIA]NOLIB(NOL)  = [F:ALD]NOLIB
  Case [F:ATY]TYPTYP
   When 1
    [M:DIA]FMT(NOL) = "Nz+:3#"
   When 2
    [M:DIA]FMT(NOL) = "Nz:5#"
   When 3
    [M:DIA]FMT(NOL) = "Nz:8#"
   When 7
    If [F:ATY]FORTYP<>""
     [M:DIA]FMT(NOL) = "K:"+[F:ATY]FORTYP
    Else
     [M:DIA]FMT(NOL) = "K:20X"
    Endif
   When 8
    [M:DIA]FMT(NOL) = "DzZ:"+GFMDAT
   When Default
    [M:DIA]FMT(NOL) = "Nz:15F"
  Endcase
 Endif

 If OKDEF
  If [F:ALD]VALDEB<>""
   ERCONT = 0
   Onerrgo CONT
   [M:DIA]DEB(NOL) = num$(evalue([F:ALD]VALDEB))
   Onerrgo
   If !ERCONT
    Call CHARGE([M:DIA]DEB(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALDEB(NOL)) From FMTVAR
   Endif
  Endif
  If [F:ALD]VALFIN<>""
   ERCONT = 0
   Onerrgo CONT
   [M:DIA]FIN(NOL) = num$(evalue([F:ALD]VALFIN))
   Onerrgo
   If !ERCONT
    Call CHARGE([M:DIA]FIN(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALFIN(NOL)) From FMTVAR
   Endif
  Endif
 Endif

 If UTIL<>"" & !OKDEF
  If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
   Read [ALR]ALR0 = LISTE;LFCY;LDEP;UTIL;998;NOL+1;1
   CRITPLAG = "COD=LISTE & FCY=LFCY & DEP=LDEP & USR=UTIL & NIV=998 & LIG=NOL+1"
  Else
   Read [ALR]ALR0 = LISTE;UTIL;998;NOL+1;1
   CRITPLAG = " COD=LISTE & USR=UTIL & LIG=NOL+1 & NIV=998"
  Endif
  If !fstat
   J=0
   Filter [F:ALR] Where evalue(CRITPLAG)
   For [ALR]
    [M:DIA]NBPLAG += 1
    J+=1
    If instr(0,[F:ALR]VLR,"&~")
     [M:DIA]PARPLAG([M:DIA]NBPLAG-1)  = [M:DIA]INTIT(NOL)
     [M:DIA]BORPLAG([M:DIA]NBPLAG-1)  = 2
     [M:DIA]VALPLAG1([M:DIA]NBPLAG-1) = left$([F:ALR]VLR,instr(0,[F:ALR]VLR,"&~")-1)
     [M:DIA]VALPLAG2([M:DIA]NBPLAG-1) = right$([F:ALR]VLR,instr(0,[F:ALR]VLR,"&~")+2)
    Else
     [M:DIA]PARPLAG([M:DIA]NBPLAG-1)  = [M:DIA]INTIT(NOL)
     [M:DIA]BORPLAG([M:DIA]NBPLAG-1)  = 1
     [M:DIA]VALPLAG1([M:DIA]NBPLAG-1) = [F:ALR]VLR
     [M:DIA]VALPLAG2([M:DIA]NBPLAG-1) = ""
    Endif
   Next
   Filter [ALR]
   If J=1
    [M:DIA]DEB(NOL) = [M:DIA]VALPLAG1([M:DIA]NBPLAG-1)
    Call CHARGE([M:DIA]DEB(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALDEB(NOL)) From FMTVAR
    [M:DIA]FIN(NOL) = [M:DIA]VALPLAG2([M:DIA]NBPLAG-1)
    Call CHARGE([M:DIA]FIN(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALFIN(NOL)) From FMTVAR
   Endif
  Else
   If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
    Read [ALR]ALR0 = LISTE;LFCY;LDEP;UTIL;999;1;NOL+1
   Else
    Read [ALR]ALR0 = LISTE;UTIL;999;1;NOL+1
   Endif
   If !fstat
    [M:DIA]DEB(NOL) = [F:ALR]VLR
    Call CHARGE([M:DIA]DEB(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALDEB(NOL)) From FMTVAR
   Endif
   If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
    Read [ALR]ALR0 = LISTE;LFCY;LDEP;UTIL;999;2;NOL+1
   Else
    Read [ALR]ALR0 = LISTE;UTIL;999;2;NOL+1
   Endif
   If !fstat
    [M:DIA]FIN(NOL) = [F:ALR]VLR
    Call CHARGE([M:DIA]FIN(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALFIN(NOL)) From FMTVAR
   Endif
  Endif
 Endif

 If dim(GFCTIMP)>0 & GFCTIMP<>"" : # On vient de Fichier/Imprimer
  If [V]GTYPIMP=2
   Read[ARV]ARV0 = [V]GFCTIMP;[V]GTYPIMP;PARAM(1);[F:ALD]TBL+"~"+[ALD]FLD
  Elsif [V]GTYPIMP=3
   Read[ARV]ARV0 = [V]GFCTIMP;[V]GTYPIMP;PARAM(1);[ALD]LIG
  Endif
  If !fstat
   J= find([M:DIA]INTIT(NOL),[M:DIA]PARPLAG(0..[M:DIA]NBPLAG))
   While J
    Dela J-1 , 1 [M:DIA]PARPLAG, [M:DIA]VALPLAG1 , [M:DIA]VALPLAG2 , [M:DIA]BORPLAG
    If [M:DIA]NBPLAG > 0 : [M:DIA]NBPLAG -= 1 : Endif
    J= find([M:DIA]INTIT(NOL),[M:DIA]PARPLAG(0.. [M:DIA]NBPLAG))
   Wend
   If [F:ARV]VALDEF1 <> ""
    Call EVALE([F:ARV]VALDEF1,[M:DIA]DEB(NOL),[M:DIA]TYP(NOL)) From AIMP1
    Call CHARGE([M:DIA]DEB(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALDEB(NOL)) From FMTVAR
   Endif
   If [F:ARV]VALDEF2 <> ""
    Call EVALE([F:ARV]VALDEF2,[M:DIA]FIN(NOL),[M:DIA]TYP(NOL)) From AIMP1
    Call CHARGE([M:DIA]FIN(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALFIN(NOL)) From FMTVAR
   Endif
   If [F:ARV]VALDEF1<>"" | [F:ARV]VALDEF2<>""
    [M:DIA]NBPLAG += 1
    [M:DIA]PARPLAG([M:DIA]NBPLAG-1)  = [M:DIA]INTIT(NOL)
    [M:DIA]BORPLAG([M:DIA]NBPLAG-1)  = 2
    [M:DIA]VALPLAG1([M:DIA]NBPLAG-1) = [M:DIA]VALDEB(NOL)
    [M:DIA]VALPLAG2([M:DIA]NBPLAG-1) = [M:DIA]VALFIN(NOL)
   Endif
  Endif
 Endif
 NOL += 1
Next ALD
[M:DIA]NBLIG = NOL
Return

###########################################################
$SORTIE
If !AFF
 If SYMBOLE<>""
  Unlock =SYMBOLE
  SYMBOLE=""
 Endif
Elsif !FIN
 GOK = 1
Else
 GOK = 0
Endif
GFONCTION = SAVFONC
Return

##########################################################
$REMPLACE_SUP
Local Integer JJ
Local Char    CC(250)
For JJ=1 To dim(CRITSUP)
 CC = ctrans(CRITSUP(JJ),'¨','"')
 Gosub REMPLACE
 CRITSUP(JJ) = CC
Next JJ
If sum(CRITSUP)=""
 CRITSUP = "1=1"
Endif
Return

###################################
$REMPLACE_NXT
Local Char CC(250)
CC = ctrans(CRITNXT,'¨','"')
Gosub REMPLACE
CRITNXT = CC
If CRITNXT=""
 CRITNXT = "1=1"
Endif
Return

###################################
$REMPLACE
Local Integer KK , LL , NN , ER
Local Char    FF(250)
KK = instr(1,CC,"%")
While KK
 LL = instr(KK+1,CC,"%")
 If LL
  ER = 0
  Onerrgo ER
  FF = seg$(CC,KK+1,LL-1)
  If find(left$(FF,1),"D","F") & val(right$(FF,2))>=1 and val(right$(FF,2))<=dim(PARTYP) & len(FF)<=len(num$(dim(PARTYP)))+1
   NN = val(right$(FF,2))
   Case left$(FF,1)
    When "D" : FF = [M:DIA]DEB(NN-1)
    When "F" : FF = [M:DIA]FIN(NN-1)
   Endcase
   Case PARTYP(NN)
    When 7
     FF = '"'+FF+'"'
    When 8
     If FF="" : FF = "00/00/00" : Endif
     FF = "["+FF+"]"
   Endcase
  Else
   FF = num$(evalue(FF))
  Endif
  Onerrgo
  If ER
   FF = ""
  Endif
  CC = left$(CC,KK-1)+FF+right$(CC,LL+1)
 Endif
 KK = instr(KK+1,CC,"%")
Wend
Return

$ER
ER = ERN
Resume

###########################################################
$CONTROLE
If BCRIT<>"" & GSTATUT<>GSTAOK : FIN=1 : Return : Endif

LISTE = [M:DIA]COD
If GSERVEUR : Call ECR_TRACE(mess(204,126,1)-LISTE,0) From GESECRAN : Endif
If LISTE=""
 FIN = 1
 Return
Elsif SYMBOLE=""
 Gosub CONTROLES From SUBALH2
 If GERR
  FIN = 1
  Return
 Endif
Endif

If [F:ALH]ALLUSR=2
 SYMBOLE2 = "ALH9"-LISTE-GDIV(0)
 Lock =SYMBOLE2
 If fstat
  Call ECR_TRACE(mess(10,100,1),1) From GESECRAN : # Modif en cours
  FIN=1 : Return
 Endif
 Call QUILOCKE("ALH"-LISTE-"",ER,GCLE)
 If ER
  Gosub DEVERROU2
  # Fiche utilisée par un autre utilisateur
  Call ECR_TRACE(mess(98,126,1)-string$(GCLE<>"","("+GCLE+")"),1) From GESECRAN
  FIN=1 : Return
 Endif
Endif

Gosub SETPRG From SUBALH
Gosub SETMSK From SUBALH
WPROG   = PREFPRG+LISTE
MASQUE  = PREFMSK+LISTE

NBCRIT = 0
K = 0
For [ALD] Where COD=LISTE
 K += 1
 TBNIV(K) = [F:ALD]NIV
 If find([F:ALD]STREND,2,3)
  NBCRIT += 1
 Endif
Next

Gosub DEFVAR From =WPROG
Return

###########################################################
$EXEC

# Calcul requête
If !GSERVEUR & !AFF
 Call OUVRE_TRACE(mess(204,126,1)-LISTE) From LECFIC : TRA=1
Endif
If clalev([F:LNK])>0 : Close Local File [LNK] : Endif

Gosub CRITERES

Raz CRITERE
ICRIT = 0
Gosub SET_ENV From SUBALH2

CRITENV = "1=1"
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 If dim([L]PARAM)<6 | !find([L]PARAM(6),'0','1','2')
  CHAMP = num$([F:ALH]TYPENV)
 Else
  CHAMP= [L]PARAM(6)
 Endif
 Case CHAMP
  When '0'     : CRITENV = "1=1"
  When '1'     : CRITENV = "["+LNKFIC+"]FCY='"+[L]LFCY+"'"
  When '2'     : CRITENV = "["+LNKFIC+"]FCY='"+[L]LFCY+"' & ["+LNKFIC+"]DEP='"+[L]LDEP+"'"
 Endcase
Endif

If dim([L]PARAM)>3 & PARAM(4)<>""
 Call ADDCRIT(CRITERE,ICRIT,"CRITERE",PARAM(4),"&") From GOBJSUB
Endif
If dim([L]PARAM)>4 & PARAM(5)<>""
 Call ADDCRIT(CRITERE,ICRIT,"CRITERE",PARAM(5),"&") From GOBJSUB
Endif

# Filtre d'après les bornes de la requête
I=0
For [ALD]ALD0 Where COD=[F:ALH]COD & find(STREND,2,3)<>0
 I += 1
 If dim([F:ALD]NUMTEX)>0 and [F:ALD]NUMTEX>0
  Call LECTEXTRA(WCOD,"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]NUMTEX)) From ATEXTRA
 Else
  Call LECTEXTRA(WCOD,"ALISTED","INTITLIG",[F:ALD]COD,num$([F:ALD]LIG)) From ATEXTRA
 Endif
 Read [ATY]CODTYP = [F:ALD]CODTYP
 Read [AVWT]CODFIC = [F:ALD]TBL
 If find(WCOD,INTPLAG(1..NBPLAGE)) or CDEB(I)<>"" or CFIN(I)<>""
  If [F:ALD]CODTYP="ATX"
   CHAMP = "[F:AX"+num$([F:ALD]LIG+10)+"]TEXTE"
   TYP = 7
  Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")
   CHAMP = "[F:AY"+num$([F:ALD]LIG+10)+"]TEXTE"
   TYP = 7
  Else
   CHAMP = "[F:"+[F:AVWT]ABRFIC+"]"+[F:ALD]FLD
   TYP = [F:ATY]TYPTYP
  Endif
 Else
  CHAMP = "[F:"+[F:AVWT]ABRFIC+"]"+[F:ALD]FLD
  TYP = [F:ATY]TYPTYP
 Endif
 If find(WCOD,INTPLAG(1..NBPLAGE))
  K=0
  For J=1 To NBPLAGE
   If WCOD = INTPLAG(J)
    If BORNPLAG(J) <> 2
     T = 0
     Case TYP
      When 7       : If DEBPLAG(J)<>"" : T = 1 : Endif
      When 8       : If (DEBPLAG(J)<>"" and DEBPLAG(J)<>"00000000") : T = 1 : Endif
      When Default : If (DEBPLAG(J)<>"" and DEBPLAG(J)<>"0") : T = 1 : Endif
     Endcase
     If T
      Call VALEUR(DEBPLAG(J),TYP,VALCHP1)
      K += 1
      If K=1
       Call ADDCRIT(CRITERE,ICRIT,"CRITERE","("+CHAMP+"="+VALCHP1,"&") From GOBJSUB
      Else
       Call ADDCRIT(CRITERE,ICRIT,"CRITERE",CHAMP+"="+VALCHP1,"|") From GOBJSUB
      Endif
     Endif
    Else
     T = 0
     TF = 0
     TD = 0
     Case TYP
      When 7       : If DEBPLAG(J)<>"" or FINPLAG(J)<>"" : T = 1 : Endif
                   : If FINPLAG(J)="" : TF = 1 : Endif : If DEBPLAG(J)="" : TD = 1 : Endif
      When 8       : If (DEBPLAG(J)<>"" and DEBPLAG(J)<>"00000000") or (FINPLAG(J)<>"" and FINPLAG(J)<>"00000000") : T = 1 : Endif
                   : If FINPLAG(J)="" or FINPLAG(J)="00000000" : TF = 1 : Endif
                   : If DEBPLAG(J)="" or DEBPLAG(J)="00000000" : TD = 1 : Endif
      When Default : If (DEBPLAG(J)<>"" and DEBPLAG(J)<>"0") or (FINPLAG(J)<>"" and FINPLAG(J)<>"0") : T = 1 : Endif
                   : If FINPLAG(J)="" or FINPLAG(J)="0" : TF = 1 : Endif
                   : If DEBPLAG(J)="" or DEBPLAG(J)="0" : TD = 1 : Endif
     Endcase
     If T
      If DEBPLAG(J) = FINPLAG(J)
       Call VALEUR(DEBPLAG(J),TYP,VALCHP1)
       CRITPLAG = CHAMP+"="+VALCHP1
      Else
       If TF
        Call VALEUR(DEBPLAG(J),TYP,VALCHP1)
        CRITPLAG = CHAMP+">="+VALCHP1
       Elsif TD
        Call VALEUR(FINPLAG(J),TYP,VALCHP2)
        CRITPLAG = CHAMP+"<="+VALCHP2
       Else
        Call VALEUR(DEBPLAG(J),TYP,VALCHP1)
        Call VALEUR(FINPLAG(J),TYP,VALCHP2)
        CRITPLAG = CHAMP+">="+VALCHP1+"&"+CHAMP+"<="+VALCHP2
       Endif
      Endif
      K += 1
      If K=1
       Call ADDCRIT(CRITERE,ICRIT,"CRITERE","(("+CRITPLAG+")","&") From GOBJSUB
      Else
       Call ADDCRIT(CRITERE,ICRIT,"CRITERE","("+CRITPLAG+")","|") From GOBJSUB
      Endif
     Endif
    Endif
   Endif
  Next
  If K>0
   Call ADDCRIT(CRITERE,ICRIT,"CRITERE",")","") From GOBJSUB
  Endif
 Else
  T = 0
  TD = 0
  TF = 0
  Case TYP
   When 7       : If CDEB(I)<>"" or CFIN(I)<>"" : T = 1 : Endif
                : If CDEB(I)<>"" : TD = 1 : Endif
   When 8       : If (CDEB(I)<>"" and CDEB(I)<>"00000000") or (CFIN(I)<>"" and CFIN(I)<>"00000000") : T = 1 : Endif
                : If CDEB(I)<>"" and CDEB(I)<>"00000000" : TD = 1 : Endif
                : If CFIN(I)<>"" and CFIN(I)<>"00000000" : TF = 1 : Endif
   When Default : If (CDEB(I)<>"" and CDEB(I)<>"0") or (CFIN(I)<>"" and CFIN(I)<>"0") : T = 1 : Endif
                : If CDEB(I)<>"" and CDEB(I)<>"0" : TD = 1 : Endif
                : If CFIN(I)<>"" and CFIN(I)<>"0" : TF = 1 : Endif
  Endcase
  If T
   If CDEB(I)=CFIN(I)
    Call VALEUR(CDEB(I),TYP,VALCHP)
    Call ADDCRIT(CRITERE,ICRIT,"CRITERE",CHAMP+"="+VALCHP,"&") From GOBJSUB
   Else
    If TD
     Call VALEUR(CDEB(I),TYP,VALCHP)
     Call ADDCRIT(CRITERE,ICRIT,"CRITERE",CHAMP+">="+VALCHP,"&") From GOBJSUB
    Endif
    If TF
     Call VALEUR(CFIN(I),TYP,VALCHP)
     Call ADDCRIT(CRITERE,ICRIT,"CRITERE",CHAMP+"<="+VALCHP,"&") From GOBJSUB
    Endif
   Endif
  Endif
 Endif
Next

# Filtre sur sites
If GUSRFCY(1)<>"\" & [L]AOBSIT<>"" & GNBAUZ<>GNBSITE
 FILTRE = '([F:'+[L]AOBFIC+']'+[L]AOBSIT+'="" or find([F:'+[L]AOBFIC+']'+[L]AOBSIT+',GUSRFCY(1..GNBAUZ))<>0)'
 Call ADDCRIT(CRITERE,ICRIT,"CRITERE",FILTRE,"&") From GOBJSUB
Endif

# Filtre sur codes d'accès
FILTRE = ""
If GUSRACS<>2 & dim([L]AOBACC)>0 & [L]AOBACC<>""
 FILTRE = '([F:'+[L]AOBFIC+']'+[L]AOBACC+'="" or [F:ACC]CONSUL=2)'
Endif
GPOINT = "FILTER" : Gosub ENTREE From EXEFNC
Call ADDCRIT(CRITERE,ICRIT,"CRITERE",FILTRE,"&") From GOBJSUB

# Filtre sur les rôles
If [L]AOBFIC<>""
 I = 1
 While I<=GNBROLUSR
  K = find(GROLUSR(I)-[F:ALH]OBJLNK,GROLE(1..GNBROLE))
  If K
   T = evalue('type([F:'+[L]AOBFIC+']'+GFLDROLE(K)+')')
   If I<GNBROLUSR & GROLUSR(I+1)=GROLUSR(I)
    Call ADDCRIT(CRITERE,ICRIT,"CRITERE",'find([F:'+[L]AOBFIC+']'+GFLDROLE(K),"&") From GOBJSUB
    J = I
    While GROLUSR(I)=GROLUSR(J)
     FILTRE = GROLCLE(I)
     If left$(FILTRE,1)="="
      FILTRE = right$(FILTRE,2)
     Elsif !find(T,1,2,4,5,6,7,8)
      FILTRE = '"'+FILTRE+'"'
     Endif
     Call ADDCRIT(CRITERE,ICRIT,"CRITERE",','+FILTRE,"") From GOBJSUB
     I += 1
    Wend
    FILTRE = ")"
    Call ADDCRIT(CRITERE,ICRIT,"CRITERE",FILTRE,"") From GOBJSUB
   Else
    FILTRE = GROLCLE(I)
    If left$(FILTRE,1)="="
     FILTRE = right$(FILTRE,2)
    Elsif !find(T,1,2,4,5,6,7,8)
     FILTRE = '"'+FILTRE+'"'
    Endif
    Call ADDCRIT(CRITERE,ICRIT,"CRITERE",'[F:'+[L]AOBFIC+']'+GFLDROLE(K)+'='+FILTRE,"&") From GOBJSUB
    I += 1
   Endif
  Else
   I += 1
  Endif
 Wend
Endif

If CRITERE="" : CRITERE = "1=1" : Endif
If DEBUG : # Critères de sélection
 Call ECR_TRACE(mess(174,124,1)-sum(CRITERE)-"&"-CRITENV,0) From GESECRAN
Endif
ER = 0

Gosub SET_UTIL
Onerrgo ERREXP
Gosub PARAM From =WPROG
Gosub OUVRE From =WPROG
Onerrgo
If ER
 PLEIN = 3
Else
 Call DEBTRANS From GLOCK
 If AFF
  Effzo [M:LST]LIG, PAG, PAGMAX
 Endif
 DATED = date$
 TIMED = left$(time$,2)+mid$(time$,4,2)

# Gestion du "Writeb" et "trbegin/commit" multiples
 adxftl = 50
 adxwrb = 50
 NBRWRITE = 0
 MAXWRITE = 1000

 GPOINT = "AV_EXEREQ" : Gosub ENTREE From EXEFNC
 Gosub UPDATE_ALR
 GPOINT = "AP_EXEREQ" : Gosub ENTREE From EXEFNC
Endif
Gosub DEVERROU2

Case PLEIN
 When 0
  If !AFF
   Call ECR_TRACE(mess(33,9003,1)-num$(sum(NBB)),0) From GESECRAN : # Nb de lignes
  Endif
 When 1
  Call ECR_TRACE(mess(54,126,1)-"("+num$(MAXLIG)+")",0) From GESECRAN
  # Nb de lignes maximum dépassé
 When 2
  Call ECR_TRACE(mess(53,126,1)-"("+num$(MAXTIM)+")",0) From GESECRAN
  # Temps maximum dépassé
 When 3
  Call ECR_TRACE(GMESSAGE,0) From GESECRAN
  Raz NBB
  # Erreur sur formule
Endcase
If TRA : Call FERME_TRACE From LECFIC : Endif
Read [ALH]ALH0 = LISTE : # mb 12.7.2 bug 15111
# Pour ne pas planter dans GSAISIE(154) : # bug 27280
# If clalev([F:LNK])>0 : Close Local File [LNK] : Endif

Return

$DEVERROU2
If SYMBOLE2<>""
 Unlock =SYMBOLE2
 SYMBOLE2=""
Endif
Return

#------------------------#
$UPDATE_ALR
FILTRE = "COD='"+LISTE+"'"
GCLE=LISTE
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 FILTRE-= "& FCY='"+LFCY+"' & DEP='"+LDEP+"'"
 GCLE-=LFCY-LDEP
Endif
If [F:ALH]ALLUSR<>2
 FILTRE-= "& USR='"+UTIL+"'"
 GCLE-=UTIL
Endif
Gosub DELETE_ALR
If GOK<1 : Return : Endif
Gosub TR1
If GOK<1
 Gosub DELETE_ALR
Endif
Return

#---------------------------------------------#
$DELETE_ALR
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [ALR]
 Delete [ALR] Where evalue(FILTRE)
 If fstat=1
  GOK = -1 : GLOCK = "$ALISTER"-GCLE : Goto ROLL_TR2
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#--------------------------------#
$WRITE_ALR
#118076 add entry point
GPE=0
GPOINT = "WRITE_ALR" : Gosub ENTREE From EXEFNC
If GPE=0
 WriteB [ALR]
 If fstat
  GOK = 0 : Call FSTA("ALR") From GLOCK : Return
 Endif
 NBRWRITE += 1
 If NBRWRITE>MAXWRITE
  NBRWRITE = 0
  Flush [ALR]
  If fstat
   GOK = 0 : Rollback : Return
  Endif
  Commit
  Trbegin [ALR]
 Endif
Endif
Return

#---------------------#
$TR1
GOK = 1
Trbegin [ALR]
 NOL = 0
 Raz NBB
 NIVEAU = 0
 PLEIN = 0
 TIM = time
 MAXTIM = [F:ALH]MAXTIM
 ER = 0
 If DEBUG
  dbgstr(129) = "/u/by/tmp"
 Endif
 OK = 1
 Gosub NIVEAU
 If GOK<1 : Goto AB_TR1 : Endif
 TEMPO = time-TIM
 If DEBUG
  dbgstr(129) = ""
 Endif
 Raz [F:ALR]
 [F:ALR]COD    = LISTE
 [F:ALR]USR    = UTIL
 Gosub ENVALR
 [F:ALR]LIG    = 0
 [F:ALR]COL    = 0
 [F:ALR]CREDAT = DATED
 [F:ALR]CRETIM = TIMED # Issue 102310 - 2018-08-20 by MGO : Showing execution time
 [F:ALR]VLR    = num$(TEMPO)
 For NIVEAU=1 To NBGRP+1
  [F:ALR]NIV    = NIVEAU
  [F:ALR]NUM    = NBB(NIVEAU)
  Gosub WRITE_ALR
  If GOK<1 : Break : Endif
 Next NIVEAU
 If GOK<1 : Goto AB_TR1 : Endif
 Raz [F:ALR]
 [F:ALR]COD    = LISTE
 [F:ALR]USR    = UTIL
 Gosub ENVALR
 [F:ALR]NIV    = 999
 [F:ALR]CREDAT = DATED
 [F:ALR]CRETIM = TIMED # Issue 102310 - 2018-08-20 by MGO : Showing execution time
 For K=1 To NBCRIT
  If CDEB(K)<>"" or CFIN(K)<>""
   [F:ALR]COL    = K
   [F:ALR]LIG    = 1
   [F:ALR]VLR    = CDEB(K)
   Gosub WRITE_ALR
   If GOK<1 : Break : Endif
   [F:ALR]LIG    = 2
   [F:ALR]VLR    = CFIN(K)
   Gosub WRITE_ALR
   If GOK<1 : Break : Endif
  Endif
 Next K
 Raz [F:ALR]
 [F:ALR]COD    = LISTE
 [F:ALR]USR    = UTIL
 Gosub ENVALR
 [F:ALR]NIV    = 998
 [F:ALR]CREDAT = DATED
 [F:ALR]CRETIM = TIMED # Issue 102310 - 2018-08-20 by MGO : Showing execution time
 CHAINE = ""
 For K=1 To NBPLAGE
  If CHAINE=INTPLAG(K)
   [F:ALR]COL +=1
  Else
   [F:ALR]COL = 1
   CHAINE = INTPLAG(K)
  Endif
  I = find(INTPLAG(K),[M:DIA]INTIT(0..[M:DIA]NBLIG))
  [F:ALR]LIG     = I
  If BORNPLAG(K) = 2
   [F:ALR]VLR    = DEBPLAG(K)+"&~"+FINPLAG(K)
  Else
   [F:ALR]VLR    = DEBPLAG(K)
  Endif
  Gosub WRITE_ALR
  If GOK<1 : Break : Endif
 Next K
If GOK<1
 Goto AB_TR1
Else
 Flush [ALR]
 If fstat
  GOK = 0 : Rollback : Return
 Endif
Endif
Commit
Return

#-------------#
$AB_TR1
Rollback
Return

#----------------------#
$NIVEAU
NIVEAU += 1
If NIVEAU=NBGRP+1
 For [LNK]CLE
  If MAXLIG>0 & NBB(NIVEAU)>=MAXLIG
   PLEIN = 1 : Break
  Elsif MAXTIM>0 & time-TIM>MAXTIM
   PLEIN = 2 : Break
  Endif
  Raz [F:ALR]
  [F:ALR]COD    = LISTE
  [F:ALR]USR    = UTIL
  Gosub ENVALR
  [F:ALR]NIV    = NIVEAU
  [F:ALR]CREDAT = DATED
  [F:ALR]CRETIM = TIMED # Issue 102310 - 2018-08-20 by MGO : Showing execution time
  Gosub LIENS From =WPROG
  Onerrgo CONT
  Gosub CONT From =WPROG
  Onerrgo
  If OKCONT or ERCONT
   NBB(NIVEAU) += 1
   [F:ALR]LIG    = NBB(NIVEAU)
   If AFF & mod(NBB(NIVEAU),100)=0
    [M:LST]LIG   = NBB(NIVEAU)
    [M:LST]TEMPO = time-TIM
    Affzo [LST] LIG, TEMPO
    Envzo
   Endif
   For I=1 To NBCOL
    Raz [F:ALR]NUM, [F:ALR]DAT, [F:ALR]VLR
    [F:ALR]COL = I
    Onerrgo ERREXP
    Gosub LECTURE From =WPROG
    Onerrgo
    If ER : PLEIN = 3 : GOK = 0 : Break 2 : Endif
    Gosub WRITE_ALR
    If GOK<1 : Break 2 : Endif
    For J=1 To NIVEAU-1
     If CUM(I)
      TBNUM(I,J) += [F:ALR]NUM
     Else
      TBNUM(I,J) = [F:ALR]NUM
      TBDAT(I,J) = [F:ALR]DAT
      TBVLR(I,J) = [F:ALR]VLR
     Endif
    Next J
    TBTYP(I) = [F:ALR]TYP
   Next I
   Gosub ENVCOL
  Endif
 Next
Else
 Onerrgo ERREXP
 If NIVEAU=1 & MAXLIG<>0
  For [LNK]CLE(NIVEAU) Maxrows MAXLIG
   Gosub NIVEAU2
   If PLEIN or GOK<1 : Break : Endif
  Next
 Else
  For [LNK]CLE(NIVEAU)
   Gosub NIVEAU2
   If PLEIN or GOK<1 : Break : Endif
  Next
 Endif
 Onerrgo
 If ER : PLEIN = 3 : GOK = 0 : Endif
Endif
NIVEAU -= 1
Return

#---------------------#
$NIVEAU2
For I=1 To NBCOL
 TBNUM(I,NIVEAU) = 0
Next I
ONB(NIVEAU) = NBB(NBGRP+1)
Gosub NIVEAU
If NBB(NBGRP+1)>ONB(NIVEAU)
 If GOK<1 : Return : Endif
 NBB(NIVEAU) += 1
 Raz [F:ALR]
 [F:ALR]COD    = LISTE
 [F:ALR]USR    = UTIL
 Gosub ENVALR
 [F:ALR]NIV    = NIVEAU
 [F:ALR]LIG    = NBB(NIVEAU)
 [F:ALR]CREDAT = DATED
 [F:ALR]CRETIM = TIMED # Issue 102310 - 2018-08-20 by MGO : Showing execution time
 For I=1 To NBCOL
  Raz [F:ALR]NUM, [F:ALR]DAT, [F:ALR]VLR
  [F:ALR]COL    = I
  If CUM(I)
   [F:ALR]NUM    = TBNUM(I,NIVEAU)
  Elsif (GRP(I)<>0 & GRP(I)<=NIVEAU) or TBNIV(I)<=NIVEAU
   [F:ALR]NUM    = TBNUM(I,NIVEAU)
   [F:ALR]VLR    = TBVLR(I,NIVEAU)
   [F:ALR]DAT    = TBDAT(I,NIVEAU)
  Endif
  [F:ALR]TYP    = TBTYP(I)
  Gosub WRITE_ALR
  If GOK<1 : Break : Endif
 Next I
 Gosub ENVCOL
Endif
Return

#----------------------#
$ENVALR
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 [F:ALR]FCY    = LFCY
 [F:ALR]DEP    = LDEP
Endif
Return

#-----------------------#
$ENVCOL
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 If type([F:LNK]FCY)>=10
  [F:ALR]COL = -1
  [F:ALR]TYP = 7
  [F:ALR]VLR = [F:LNK]FCY
  Gosub WRITE_ALR
  If GOK<1 : Return : Endif
 Endif
 If type([F:LNK]DEP)>=10
  [F:ALR]COL = -2
  [F:ALR]TYP = 7
  [F:ALR]VLR = [F:LNK]DEP
  Gosub WRITE_ALR
  If GOK<1 : Return : Endif
 Endif
Endif
Return

#---------------#
$RIEN
Resume

$CONT
ERCONT = errn
Resume

$ERREXP
ER = errn
GMESSAGE = mess(147,100,1)+"\"+errp-"("+num$(errl)+")\"+errmes$(errn)+"\"+errm
Resume

#-----------------------------------------#
$CRITERES
For I=1 To [M:DIA]NBLIG
 CDEB(I) = [M:DIA]VALDEB(I-1)
 CFIN(I) = [M:DIA]VALFIN(I-1)
 Case [M:DIA]TYP(I-1)
  When 7
  When 8
   If left$(CDEB(I),6)="000000" : CDEB(I) = "" : Endif
   If left$(CFIN(I),6)="000000" : CFIN(I) = "" : Endif
  When Default
   If val(CDEB(I))=0 : CDEB(I) = "" : Endif
   If val(CFIN(I))=0 : CFIN(I) = "" : Endif
 Endcase
Next I
NBCRIT = [M:DIA]NBLIG
### Valeurs multiples
For I=1 To [M:DIA]NBPLAG
 INTPLAG(I)  = [M:DIA]PARPLAG(I-1)
 DEBPLAG(I)  = [M:DIA]VALPLAG1(I-1)
 BORNPLAG(I) = [M:DIA]BORPLAG(I-1)
 FINPLAG(I)  = [M:DIA]VALPLAG2(I-1)
Next I
NBPLAGE = [M:DIA]NBPLAG
Return

#---------------------------------------------------------------------------------------#
Subprog VALEUR(CHAINE,TYP,VALEUR)
Value    Char    CHAINE
Value    Integer TYP
Variable Char    VALEUR()
Case TYP
 When 7
  VALEUR = '"'+CHAINE+'"'
 When 8
  If CHAINE="" : CHAINE = "00000000" : Endif
  VALEUR = "["+format$(GFMD,gdat$(CHAINE))+"]"
 When Default : VALEUR = CHAINE
Endcase
End

###########################################################
Subprog QUILOCKE(SYMBOLE,VERROU,USR)
Value    Char    SYMBOLE
Variable Integer VERROU
Variable Char    USR
VERROU = 0
Local File APLLCK [LKK]
For [LKK]LCKCLE Where LCKPID<>adxuid(2) & left$(LCKSYM,len([L]SYMBOLE))=[L]SYMBOLE
 If dim([L]NBUSR)<0
  Local Integer I , NBUSR
  Local Char TBUSR(12)(1..2000) , PROCESS(20)
  If func ASESSIONS.ISMNGSESSIONS
   Call LIST_UID(TBUSR,NBUSR) From ASESSIONS
  Else
   Local Char SID(12) , SCLI(80) , SUSR(30) , SUID(12)
   Local File (SID,SCLI,SUSR,SUID) From System adxmac(0)+"@psadx -ig" As [SYS_]
   NBUSR = 0
   For [SYS_]
    NBUSR += 1 : TBUSR(NBUSR) = [F:SYS_]SUID
   Next SYS_
   Close Local File [SYS_]
  Endif
 Endif
 PROCESS = num$([F:LKK]LCKPID)
 For I=1 To NBUSR
  If TBUSR(I)=PROCESS
   VERROU = 1
   USR = right$([F:LKK]LCKSYM,len([L]SYMBOLE)+1)
   Break
  Endif
 Next I
Next
End

###############################################
## Etiquettes écran critères ALH9
###############################################
# PARAM(1) = [M:DIA]CODTYP(nolign-1)
# PARAM(2) = num$([M:DIA]LONG(nolign-1))
# PARAM(3) = num$([M:DIA]NOLIB(nolign-1))
# PARAM(4) = ""
# PARAM(5) = ""
# PARAM(6) = ""
# PARAM(7) = "[M:DIA]NBPLAG"
# PARAM(8) = "[M:DIA]PARPLAG"
# PARAM(9) = "[M:DIA]VALPLAG1"
# PARAM(10) = "[M:DIA]VALPLAG2"
# PARAM(11) = "[M:DIA]BORPLAG"
# PARAM(12) = "SUBALH9"
# [M]VALEUR4 : PARAM(13) = num$([m:dia]typ(nolign-1))
# PARAM(14) = ""
# PARAM(15) = ""
# PARAM(16) = ""
# PARAM(17) = ""
# PARAM(18) = ""
# PARAM(19) = [M:DIA]INTIT(nolign-1)

$CONTPAR1
Call CONTPAD([M:APG]CODTYP,[M:APG]VALINT1(nolign-1),VALEUR)
Return

$CONTPAR2
Call CONTPAD([M:APG]CODTYP,[M:APG]VALINT2(nolign-1),VALEUR)
Call CONTFIN(val([M]VALEUR4),[M:APG]VALINT1(nolign-1),[M:APG]VALINT2(nolign-1))
Return

$MODIFPAR1
Call INIFIN(val([M:APG]VALEUR4),[M:APG]VALINT1(nolign-1),[M:APG]CODTYP,[M:APG]LONG,[M:APG]NOLIB,
&           [M:APG]VALINT2(nolign-1),[M:APG]VALEUR2(nolign-1),VALEUR)
If !mkstat
 Affzo [M:APG]VALEUR2(nolign-1)
Endif
Return

Subprog C_COD(VALEUR)
Variable Char     VALEUR
Local Char LISTE(GLONALH)
Local Integer OK
LISTE = VALEUR
If LISTE=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat =2 : End
Endif
For [ALH]ALH0 Where TYP=1 or TYP=3
 If [F:ALH]COD=LISTE
  OK =1
  Break
 Endif
Next
If !OK
 GMESSAGE = mess(119,133,1) : # REQUêTE INEXISTANTE
 mkstat =2 : End
Endif
Gosub CHARGE
Affzo 20
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
Local Char    TEX(GLONDES)(1..500,1..3) , TIT(GLONDES)(0..3)
Local Integer NBTEX , CHOI, OK
For [ALH]ALH0 Where TYP=1 or TYP=3
 NBTEX+= 1
 TEX(NBTEX,1) =  [F:ALH]COD
 Call LECTEXTRA(TEX(NBTEX,2),"ALISTEH","INTIT",[ALH]COD,"") From ATEXTRA
 If [F:ALH]TYP=1
  TEX(NBTEX,3) =  mess(00277,00139,1) : # Requête standard
 Elsif [F:ALH]TYP=3
  TEX(NBTEX,3) =  mess(00276,00139,1) : # Requête graphique
 Endif
 If TEX(NBTEX,1)= VALEUR
  CHOI = NBTEX
 Endif
Next
TIT(0) = mess(18,134,1)
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
TIT(3) = mess(59,100,1) : # Type
Call SAITEX_COL(NBTEX,TEX,CHOI,TIT) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
Endif
End

Subprog IB_DEB
Local Integer I,J
For I=0 To [M:DIA]NBPLAG-1
 If [M:DIA]INTIT(nolign-1) = [M:DIA]PARPLAG(I)
  J+=1
 Endif
Next I
If J>1
 GBOUTS = ""
 GBOUT1 = ""
Endif
End

Subprog AV_DEB(VALEUR)
Variable Char    VALEUR()
GFMT="" :#SAM 120240
End

Subprog C_DEB(VALEUR)
Variable Char    VALEUR()
Call CONTPAD([M]CODTYP(nolign-1),[M]VALDEB(nolign-1),VALEUR)
End

Subprog AM_DEB(VALEUR)
Variable Char    VALEUR()
Local Integer OK,I
Call INIFIN([M]TYP(nolign-1),[M]VALDEB(nolign-1),[M]CODTYP(nolign-1),[M]LONG(nolign-1),[M]NOLIB(nolign-1)
&          ,[M]VALFIN(nolign-1),[M]FIN(nolign-1),VALEUR)
If !mkstat
 Affzo [M]FIN(nolign-1)
Endif
For I=0 To [M:DIA]NBPLAG-1
 If [M]INTIT(nolign-1) = evalue("[M:DIA]PARPLAG"+"("+num$(I)+")")
  OK += 1
 Endif
Next I
If OK=1
 I=find([M]INTIT(nolign-1),[M]PARPLAG(0..[M]NBPLAG))
 If I : [M]VALPLAG1(I-1) = [M]VALDEB(nolign-1): Endif
Endif
End

Subprog AS_FIN(VALEUR)
Variable Char     VALEUR
Local Integer OK,I
For I=0 To [M:DIA]NBPLAG-1
 If [M]INTIT(nolign-1) = evalue("[M:DIA]PARPLAG"+"("+num$(I)+")")
  OK += 1
 Endif
Next I
If OK>1
 Chgstl [M]DEB(nolign-1) With "APARPLAG"
 [M]DEB(nolign-1) = ""
 Affzo [M]DEB
 Chgstl [M]FIN(nolign-1) With "APARPLAG"
 VALEUR = ""
 Diszo [M]DEB(nolign-1)
 mkstat = 1
 End
Else
 Actzo  [M]DEB(nolign-1)
 If OK=1
  I= find([M]INTIT(nolign-1),[M]PARPLAG(0..[M]NBPLAG))
  If I
   [M]VALDEB(nolign-1) = [M]VALPLAG1(I-1)
   [M]DEB(nolign-1)    = [M]VALPLAG1(I-1)
  Endif
 Endif
 Chgstl [M]DEB(nolign-1) With ""
 Chgstl [M]FIN(nolign-1) With ""
Endif
End

Subprog C_FIN(VALEUR)
Variable Char VALEUR()
Local Integer K
Call CONTPAD([M]CODTYP(nolign-1),[M]VALFIN(nolign-1),VALEUR)
Call CONTFIN([M]TYP(nolign-1),[M]VALDEB(nolign-1),[M]VALFIN(nolign-1))
If ([M]DEB(nolign-1)<>"" & [M]DEB(nolign-1)<>"00000000") | VALEUR <> ""
 For I=0 To [M:DIA]NBPLAG-1
  If [M]INTIT(nolign-1) = evalue("[M:DIA]PARPLAG"+"("+num$(I)+")")
   K += 1
  Endif
 Next I
 If K<2
  If K=0 : K=[M]NBPLAG : [M]NBPLAG += 1
  Elsif K=1 : K =find([M:DIA]INTIT(nolign-1),[M:DIA]PARPLAG(0..[M:DIA]NBPLAG))-1
  Endif
  [M]BORPLAG(K)  = 2
  [M]PARPLAG(K)  = [M]INTIT(nolign-1)
  [M]VALPLAG1(K) = [M]VALDEB(nolign-1)
  [M]VALPLAG2(K) = [M]VALFIN(nolign-1)
 Endif
Elsif ([M]DEB(nolign-1) = "" or [M]DEB(nolign-1)="00000000")  & VALEUR = ""
 J= find([M:DIA]INTIT(nolign-1),[M:DIA]PARPLAG(0..[M:DIA]NBPLAG))
 While J
  Dela J-1 , 1 [M:DIA]PARPLAG, [M:DIA]VALPLAG1 , [M:DIA]VALPLAG2 , [M:DIA]BORPLAG
  If [M:DIA]NBPLAG> 0 : [M:DIA]NBPLAG-= 1 : Endif
  J= find([M:DIA]INTIT(nolign-1),[M:DIA]PARPLAG(0.. [M:DIA]NBPLAG))
 Wend
Endif
End

Subprog CONTPAD(CODTYP,VALS,VALEUR)
Value    Char CODTYP
Variable Char VALS
Variable Char VALEUR
If GPRODUIT=1 : ## GEODE
 Call LECTURE("ATY",[L]CODTYP,"") From CONTOBJ
 I=0
 #--- JDE X3Suivi:32616   14/11/2006  ---#
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM7  ---#
 If I=0
  I=find("PADNUM7",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM7(VALEUR) From LOGDIV
   [L]VALS = VALEUR
  Endif
 Endif
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM8  ---#
 If I=0
  I=find("PADNUM8",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM8(VALEUR) From LOGDIV
   [L]VALS = VALEUR
  Endif
 Endif
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM9  ---#
 If I=0
  I=find("PADNUM9",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM9(VALEUR) From LOGDIV
   [L]VALS = VALEUR
  Endif
 Endif
 #--- Formatage de Valeur si le type de données a un controle avec PADNUM10 ---#
 If I=0
  I=find("PADNUM10",[F:ATY]ACTION(0..[F:ATY]NBTYP-1))
  If I & [F:ATY]ACTTYP(I-1)=5
   Call PADNUM10(VALEUR) From LOGDIV
   [L]VALS = VALEUR
  Endif
 Endif
Endif
End

Subprog CONTFIN(TYP,VALDEB,VALFIN)
Value Integer TYP
Value Char    VALDEB
Value Char    VALFIN
Onerrgo RIEN
Case [L]TYP
 When 8
  If gdat$(format$("D:",[L]VALFIN))<>[0/0/0] & gdat$(format$("D:",[L]VALFIN))<gdat$(format$("D:",[L]VALDEB))
   mkstat = 1 : End
  Endif
 When 7
  If [L]VALFIN<>"" & [L]VALFIN<[L]VALDEB : mkstat = 1 : Endif
 When Default
  If val([L]VALFIN)<>0 & val([L]VALFIN)<val([L]VALDEB) : mkstat = 1 : End : Endif
Endcase
Onerrgo
End

Subprog INIFIN(TYP,VALDEB,CODTYP,LONG,NOLIB,VALFIN,FIN,VALEUR)
Value Integer TYP
Value Char    VALDEB
Value Char    CODTYP
Value Integer LONG
Value Integer NOLIB
Variable Char VALFIN
Variable Char FIN
Variable Char VALEUR
Local Integer INF
INF = 0
Onerrgo RIEN
Case [L]TYP
 When 8
  If gdat$(format$("D:",[L]VALFIN))<gdat$(format$("D:",[L]VALDEB))
   INF = 1
  Endif
 When 7
  If [L]VALFIN<[L]VALDEB : INF = 1 : Endif
 When Default
  If val([L]VALFIN)<val([L]VALDEB) : INF = 1 : Endif
Endcase
If INF
 [L]FIN = VALEUR
 Call CONTROLE([L]FIN,[L]CODTYP,[L]NOLIB,[L]LONG,[L]VALFIN) From FMTVAR
Endif
Onerrgo
End

