#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FJH1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:18"
A_USER  = "DOC"
A_STAMP = "20181109230418"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIGRSP"
  If [M]NBLIGRSP=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask FJH1 [FJH1]
Gosub HORODAT
Local Inpbox "FJH1" From GFONCTION At A_STAMP With A_WINDPREV Mask [FJH1] As [SIM_]
Grizo [FJH1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [FJH1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_TYPMGR
Onevent CONTROL Call C_TYPMGR(zc) From W1FJH1
Onevent INIT_AREA Call D_TYPMGR(zc) From W1FJH1
Onevent BEFORE_INPUT Call AS_TYPMGR(zc) From W1FJH1
Return

Subprog D_TYPMGR(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPMGR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPMGR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TYPMGR(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_TYPMGR(VALEUR) From SUBFJH
If mkstat : GERR = 1 : GZONE = "TYPMGR" : GZNUM = 10981 : Endif
Gosub _AFF
End

$CHG_STY
Return


