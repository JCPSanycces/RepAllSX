#######################################################################################
$PROPERTIES
  Case CURPTH
    When ""
      Case CURPRO
        When "BPADEFFLG"                : Gosub PROPERTIES_BPADEFFLG
        When "TELTYP1"                  : Gosub PROPERTIES_TELTYP1
        When "TELTYP2"                  : Gosub PROPERTIES_TELTYP2
        When "TELTYP3"                  : Gosub PROPERTIES_TELTYP3
        When "TELTYP4"                  : Gosub PROPERTIES_TELTYP4
        When "TELTYP5"                  : Gosub PROPERTIES_TELTYP5
        When "WEBADRTYP1"               : Gosub PROPERTIES_WEBADRTYP1
        When "WEBADRTYP2"               : Gosub PROPERTIES_WEBADRTYP2
        When "WEBADRTYP3"               : Gosub PROPERTIES_WEBADRTYP3
        When "WEBADRTYP4"               : Gosub PROPERTIES_WEBADRTYP4
        When "WEBADRTYP5"               : Gosub PROPERTIES_WEBADRTYP5
        When Default
      Endcase
    When Default
  Endcase
Return

#######################################################################################
$PROPERTIES_BPADEFFLG
  Case ACTION
    When "GET"                         : Gosub GET_BPADEFFLG
    When Default                       : Return
  Endcase
Return

#######################################################################################
$GET_BPADEFFLG
  If this.APARENT = null Then
    Return
  Endif
  # -----------------------------------
  Case this.APARENT.OBJECTTYPE
    When "C_BPARTNER"
      If this.APARENT.APARENT = null Then
        # On peut être soit en lecture de classe BPARTNER toute seule dans un traitement...
        If this.APARENT.CNTNAM = this.BPAADD Then
          this.BPADEFFLG = [V]CST_AYES
        Else
          this.BPADEFFLG = [V]CST_ANO
        Endif
      Else
        Case this.APARENT.APARENT.OBJECTTYPE
          When "R_BPARTNER"
            # ... soit en affichage de classe BPARTNER dans une représentation
            If this.APARENT.BPAADD = this.BPAADD Then
              this.BPADEFFLG = [V]CST_AYES
            Else
              this.BPADEFFLG = [V]CST_ANO
            Endif
          When "C_BPCUSTOMER"
            If this.APARENT.APARENT.BPAADD = this.BPAADD Then
              this.BPADEFFLG = [V]CST_AYES
            Else
              this.BPADEFFLG = [V]CST_ANO
            Endif
          When Default
        Endcase
      Endif
    When Default
  Endcase
Return

