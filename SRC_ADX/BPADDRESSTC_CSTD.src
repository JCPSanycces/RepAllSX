#######################################################################################
Funprog GET_TEL(SZBPA, IIND)
Value Instance SZBPA Using C_BPADDRESS
Value Integer IIND

Local Char SARENDRE(GLONTEL)

  If SZBPA.COLTEL(IIND) <> null Then
    SARENDRE = SZBPA.COLTEL(IIND).TELNUM
  Endif
End SARENDRE

