#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################
# UUMGTRTSAL06   Squelette pour Moulinette de Migration      Module Ventes #
#            Migration des livraisons                                      #
############################################################################
# Issue 115758 - 2016190416 by LD : Migration V6->PU9 : error with SQHTYP

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTSAL06") From LECFIC
  Endif
  #Call RAZ_UUMGTRTSAL06(DOSSIER)
  Call MAJ_UUMGTRTSAL06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


##########################################################################
Subprog MAJ_UUMGTRTSAL06(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N = no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMSDHM,WNAMSDDM
Call MIGTABNAME (DOSSIER,"SDELIVERY",WNAMSDHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SDELIVERYD",WNAMSDDM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

If filinfo(filpath("FIL",WNAMSDHM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSDDM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",2,ERR) From TRTMIG : #2=En cours
Gosub MIG_OUVRE From TRTMIG #Gbn-108768

###################

Local Char WTAB_SDH (30) (adxwrb)
Local Char WTAB_SDD (90) (adxwrb)
Local Char WTAB_SVF (90) (adxwrb)
Local Char WTAB_CAL (120) (adxwrb)
Local Shortint WCPT_SDH,WCPT_SDD,WCPT_SVF,WCPT_CAL

Call ECR_TIME("UUMGTRTSAL06 Sales Delivery Process : Update SDELIVERYD") From DOSSUB
Call ECR_TRACE("UUMGTRTSAL06 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"SDELIVERY",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"SDELIVERYD",ERR) From TRTMIG
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Call MIGTABINIT (DOSSIER,"SPACK",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"SPACKD",ERR) From TRTMIG
If func DOSVUE.ISVIEW(DOSSIER,"SPACK")<> 1
    Call MIGTABINIT (DOSSIER,"SPACK",ERR) From TRTMIG
    Call MIGTABINIT (DOSSIER,"SPACKD",ERR) From TRTMIG
Endif
# Issue 106947 - 20150811 by LD

#----- Ouverture des fichiers -----#
If clalev([F:SDH])  = 0 : Local File =DOSSIER+".SDELIVERY"    [SDH]  : Endif   # Fichier X3 "Vide"
If clalev([F:SDD])  = 0 : Local File =DOSSIER+".SDELIVERYD"   [SDD]  : Endif   # Fichier X3 "Vide"

If clalev([F:SDHM]) = 0 : Local File =DOSSIER+"."+WNAMSDHM   [SDHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SDDM]) = 0 : Local File =DOSSIER+"."+WNAMSDDM   [SDDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Issue 115758
# SDHTYP value search :
# Tables are opened in the migrated folder
If !clalev([F:FGRM]) : Local File =DOSSIER+".FACGROUP"  [FGRM]        : Endif
If !clalev([F:TSDM]) : Local File =DOSSIER+".TABSDHTYP" [TSDM]        : Endif
# Tables are opened in the reference folder (in case we don't find anything in the migrated folder)
If !clalev([F:FGRR]) : Local File =[F:ADS]DOSREF+".FACGROUP"  [FGRR]  : Endif
If !clalev([F:TSDR]) : Local File =[F:ADS]DOSREF+".TABSDHTYP" [TSDR]  : Endif
Local Char SGCURLEG(GLONADI), SGCURFCY(GLONFCY)
Local Char WSDHTYP(GLONTSD), WSDHTYPNOR(GLONTSD),  WSDHTYPLND(GLONTSD),  WSDHTYPSCO(GLONTSD)
Local Char WPARSDHTYP(GLONTSD)
Local Integer WSDHCAT
# End issue 115758

# 100121
Local Char WPARAM(GLONADP)

# Déclaration des variables communes de travail
Local Integer I, J

#déclaration des variables locales de travail
Local Char     S_SALFCY : Raz S_SALFCY
Local Decimal  WCOURS
Local Integer  WVCRTYP, WRET
Local Char     WVCRNUM

Gosub OUVRE_SAL From UUMGTRTSAL00
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif
Gosub OUVRE_SAL06
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTSAL06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

# Dde 81811 : Optimisation
#If NBCOMMIT=0
#  #----- Suppression des incohérences entre tables avant migration -----#
#  Gosub TRT_SQL
#  If GOK<1 : Goto FIN : Endif
#Endif
# Dde 81811 : Optimisation

#-----  Lien des tables entête & lignes -----#
#----- on met le numero de ligne dans le tri car on a besoin des lignes triées
Link [SDDM] With [SDHM]SDH0~=[F:SDDM]SDHNUM, [ITM]ITM0=[F:SDDM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:SDDM]STOFCY;[F:SDDM]SDHNUM;[F:SDDM]SDDLIN

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTSAL06" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_SAL06
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:SDDM]STOFCY=TABMIGKEY(1) & [F:SDDM]SDHNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:SDDM]STOFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [SDH],[SDD],[SPH],[SPD]
GOK = 1

For [LNK]CLE(2)  Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  #rupture par site,livraison
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
    FLUX="UUMGTRTSAL06" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  #Raz [F:SDH]
  Gosub RAZ_SDH
  [F:SDH] = [F:SDHM]

  If WSITE<>[F:SDDM]STOFCY
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:SDDM]STOFCY) From TRTX3CPT
      WSITE=[F:SDDM]STOFCY
      #108649.so
      #If GACTKUS
      #    Call PARAM([F:SDDM]STOFCY,"USATAX",WPARAM) From ADOVAL
      #    GLOCUSATAX=val(WPARAM)
      #    If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
      #Else
      #    Raz GLOCUSATAX
      #Endif
      #108649.eo

      # Issue 115758
      If VERSION<GMIGX3VER70
        Gosub RECSDHTYP
      Endif
      # End issue 115758
  Endif

  If dim([F:SDH]DIE)>0 & [F:SDH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
          [F:SDH]DIE(I-1)=GDIE(I)
      Next I
  Endif

  # On essaie de ne pas l'appeler à chaque fois
  If S_SALFCY<>[F:SDH]SALFCY Call GLOBVAR([F:SDH]SALFCY) From WWGLOBVEN : S_SALFCY=[F:SDH]SALFCY : Endif

  # Version of the origin folder < V6
  If VERSION<GMIGX3VER60
      Gosub MAJ60_SDH
      If GOK<1 : Break : Endif
  Endif

  # Version of the origin folder < V7
  If VERSION<GMIGX3VER70
      Gosub MAJ70_SDH
      If GOK<1 : Break : Endif
  Endif

  #101380 SST Line Level Override .sn
  # Source folder version before V8 [AKIRA]
  If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
      Gosub MAJ80_SDH
      If GOK<1 : Break : Endif
  Endif
  #101380 SST Line Level Override .en

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de facture
    #Raz [F:SDD]
    Gosub RAZ_SDD
    [F:SDD] = [F:SDDM]

    # Version of the origin folder < V6
    If VERSION<GMIGX3VER60
        Gosub AMAJ60_SDD
        If GOK<1 : Break : Endif
        Gosub MAJ60_SDDSDH
        If GOK<1 : Break : Endif
    Endif

    # Version of the origin folder < V7
    If VERSION<GMIGX3VER70
        Gosub MAJ70_SDDSDH
        If GOK<1 : Break : Endif
    Endif

    #101380 SST Line Level Override .sn
    # Source folder version before V8 [AKIRA]
    If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
        Gosub MAJ80_SDDSDH
        If GOK<1 : Break : Endif
    Endif
    #101380 SST Line Level Override .en

    # 71065 : PJT
    # Source folder version before V11 (before CHALLENGER)
    If VERSION<GMIGX3VER110
      Gosub MAJ110_SDDSDH
      If GOK<1 : Break : Endif
    Endif
    # 71065 : PJT

    # Issue X3-69499
    # Source folder version before V120
    If VERSION<GMIGX3VER120
      Gosub MAJ120_SDDSDH
      If GOK<1 : Break : Endif
    Endif
    # End issue X3-69499

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub SDD_STK : # pour stocker ref
#        WriteB [SDD]
#    Else
#        Write [SDD]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File SDELIVERYD, Error ="-num$(fstat),1) From GESECRAN
#          Gosub SDD_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File SDELIVERYD(SDHNUM/SDDLIN)"-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
    Gosub SDD_STK : # pour stocker ref
    WriteB [SDD]
    If fstat
        Call ECR_TRACE("File SDELIVERYD, Error ="-num$(fstat),1) From GESECRAN
        Gosub SDD_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
    # Issue 106947 - 20150811 by LD
  Next
  If GOK<1 : Break : Endif

  If VERSION<GMIGX3VER60
      Gosub SUITE_MAJ60_SDH
      If nolign>=dim([M:SDH1]UPDFLG)
          Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM-":"-mess (26,100,1)-mess(224,139,1)-":"-"SDH",1) From GESECRAN
      Endif
      If GOK<1 : Break : Endif
  Endif

   # --- alimentation des champs et écriture enreg
  # Issue 106947 - 20150811 by LD : Migration of historic folder
#  If NEWMOTEUR
#      Gosub SDH_STK : # pour stocker ref
#      WriteB [F:SDH]
#  Else
#      Write [F:SDH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File SDELIVERY, Error ="-num$(fstat),1) From GESECRAN
#      Gosub SDH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File SDELIVERY(SDHNUM)"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub SDH_STK : # pour stocker ref
  WriteB [F:SDH]
  If fstat
    Call ECR_TRACE("File SDELIVERY, Error ="-num$(fstat),1) From GESECRAN
    Gosub SDH_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  # Issue 106947 - 20150811 by LD

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:SDDM]STOFCY
    TABMIGKEY(2) = [F:SDDM]SDHNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",7,ERR) From TRTMIG : #7=Erreur
Else
  #If NEWMOTEUR & adxwrb>1   :   # Issue 106947 - 20150811 by LD : Migration of historic folder
    Flush [F:SDH]
    If fstat
        Call ECR_TRACE("File SDELIVERY, Error ="-num$(fstat),1) From GESECRAN
        Gosub SDH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:SDD]
    If fstat
        Call ECR_TRACE("File SDELIVERYD, Error ="-num$(fstat),1) From GESECRAN
        Gosub SDD_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:SVF]
    If fstat
        Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub SVF_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #Endif                     :   # Issue 106947 - 20150811 by LD : Migration of historic folder
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
      TABMIGKEY(3)=num$(STOP)
  Else
      Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTSAL06",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTSAL06",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_SAL06
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN
Close Local File [SDD], [SDH],[SPH],[SPD], [SOH], [SOP], [SOQ]
Close Local File [SDDM], [SDHM]

Call ECR_TIME("UUMGTRTSAL06 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"SDELIVERY",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"SDELIVERYD",ERR) From TRTMIG
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Call MIGTABEND (DOSSIER,"SPACK",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"SPACKD",ERR) From TRTMIG
If func DOSVUE.ISVIEW(DOSSIER,"SPACK")<> 1
    Call MIGTABEND (DOSSIER,"SPACK",ERR) From TRTMIG
    Call MIGTABEND (DOSSIER,"SPACKD",ERR) From TRTMIG
Endif
# Issue 106947 - 20150811 by LD
Call MIGTRTEND (DOSSIER,"UUMGTRTSAL06") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGTRTSAL06(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

#Gbn-101445
##1.1 - Récupération du n° de version
#####################################
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMSDHM,WNAMSDDM
Call MIGTABNAME (DOSSIER,"SDELIVERY",WNAMSDHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SDELIVERYD",WNAMSDDM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMSDHM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSDDM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################
Call MIGTABRAZ (DOSSIER,"SDELIVERY",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"SDELIVERYD",ERR) From TRTMIG

#Gbn-101445
If val(VERSION)<GMIGX3VER60
  Local File =DOSSIER+".CPTANALIN"  [CAL]
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="SDD"
  Commit

  Local File =DOSSIER+".SVCRVAT"    [SVV]
  Trbegin [SVV]
  Delete [SVV] Where VCRTYP=2
  Commit

  Local File =DOSSIER+".SVCRFOOT"   [SVF]
  Trbegin [SVF]
  Delete [SVF] Where VCRTYP=2
  Commit
Endif

Call MIGRAZKEY (DOSSIER,"UUMGTRTSAL06",ERR) From TRTMIG

End
##############################################################################################
$OUVRE_SAL06
If clalev([F:SPH])  = 0 : Local File =DOSSIER+".SPACK"        [SPH]  : Endif
If clalev([F:SPD])  = 0 : Local File =DOSSIER+".SPACKD"       [SPD]  : Endif

Local File =DOSSIER+".SORDER"       [SOH]
Local File =DOSSIER+".SORDER"       [SOH1]            : # Dde 81811 : Optimisation
Local File =DOSSIER+".SORDERP"      [SOP]
Local File =DOSSIER+".SORDERQ"      [SOQ]

# Dde 81811 : Optimisation
# Validation des écrans
#Call VALIDDIRECT ("SDH0",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SDH1",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SDH2",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SDH3",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
#Call VALIDDIRECT ("SFITRF",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
#If GOK<>1
#  Return
#Endif
# Dde 81811 : Optimisation

# Issue 106947 - 20150811 by LD : Migration of historic folder
# Version of the origin folder < V6
If VERSION<GMIGX3VER60
    #Local Mask =DOSSIER+".SDH0"    [SDH0]
    #Local Mask =DOSSIER+".SDH1"    [SDH1]
    #Local Mask =DOSSIER+".SDH2"    [SDH2]
    #Local Mask =DOSSIER+".SDH3"    [SDH3]
    #Local Mask =DOSSIER+".SFITRF"  [SFIT]
    #Local Mask =DOSSIER+".SFITRF"  [SFI2]
    Local Mask =WHISTFOLD+".SDH0"    [SDH0]
    Local Mask =WHISTFOLD+".SDH1"    [SDH1]
    Local Mask =WHISTFOLD+".SDH2"    [SDH2]
    Local Mask =WHISTFOLD+".SDH3"    [SDH3]
    Local Mask =WHISTFOLD+".SFITRF"  [SFIT]
    Local Mask =WHISTFOLD+".SFITRF"  [SFI2]
Endif
# Issue 106947 - 20150811 by LD

Return
################################################
$RAZ_SDH
Raz [F:SDH]BPAINV
Raz [F:SDH]CCE
Raz [F:SDH]CPY
Raz [F:SDH]DIE
Raz [F:SDH]DLVATIL
Raz [F:SDH]DLVINVATI
Raz [F:SDH]DLVINVATIL
Raz [F:SDH]DLVINVNOT
Raz [F:SDH]DLVINVNOTL
Raz [F:SDH]DLVNOTL
Raz [F:SDH]DSPTOTQTY
Raz [F:SDH]DSPTOTVOL
Raz [F:SDH]DSPTOTWEI
Raz [F:SDH]DSPVOU
Raz [F:SDH]DSPWEU
Raz [F:SDH]EECNUMDEB
Raz [F:SDH]FFWADD
Raz [F:SDH]FFWNUM
Raz [F:SDH]ICTCTY
Raz [F:SDH]INVDTADSP
Raz [F:SDH]INVDTATYP
Raz [F:SDH]SFISSTCOD #gbn-101380
Raz [F:SDH]PLISTC
Raz [F:SDH]WRHE
Return
################################################
$RAZ_SDD
Raz [F:SDD]CPY
Raz [F:SDD]DDTANOT
Raz [F:SDD]DDTANUM
Raz [F:SDD]DSPLINFLG
Raz [F:SDD]DSPLINVOL
Raz [F:SDD]DSPLINWEI
Raz [F:SDD]DSPVOU
Raz [F:SDD]DSPWEU
Raz [F:SDD]IMPNUMLIG
Raz [F:SDD]PACQTYSTU
If dim([F:SDD]PCKFLG)>0 : Raz [F:SDD]PCKFLG : Endif
Raz [F:SDD]PRELIN
Raz [F:SDD]PRHNUM
Raz [F:SDD]VCRLINORI
Raz [F:SDD]VCRNUMORI
Raz [F:SDD]VCRSEQORI
Raz [F:SDD]VCRTYPORI
Raz [F:SDD]WRH
Return
################################################
$SDH_STK
Call STK (WTAB_SDH,WCPT_SDH,[F:SDH]SDHNUM) From TRTMIG
Return
$SDD_STK
Call STK (WTAB_SDD,WCPT_SDD,[F:SDD]SDHNUM-'/'-num$([F:SDD]SDDLIN)) From TRTMIG
Return
$SVF_STK
Call STK (WTAB_SVF,WCPT_SVF,[F:SVF]VCRNUM-'/'-num$([F:SVF]VCRTYP)-'/'-num$([F:SVF]DTA)) From TRTMIG
Return
$CAL_STK
Call STK (WTAB_CAL,WCPT_CAL,[F:CAL]ABRFIC-'/'-num$([F:CAL]VCRTYP)-'/'-[F:CAL]VCRNUM-'/'-num$([F:CAL]VCRLIN)-'/'-num$([F:CAL]VCRSEQ)-'/'-[F:CAL]CPLCLE-'/'-num$([F:CAL]ANALIG)) From TRTMIG
Return
##############################################################################################
##############################################################################################
$SDH_ERRTRA
Call ERRTRA (WTAB_SDH,WCPT_SDH,"File SDELIVERY(SDHNUM)=") From TRTMIG
Return
$SDD_ERRTRA
Call ERRTRA (WTAB_SDD,WCPT_SDD,"File SDELIVERYD(SDHNUM/SDDLIN)=") From TRTMIG
Return
$SVF_ERRTRA
Call ERRTRA (WTAB_SVF,WCPT_SVF,"File SVCRFOOT(VCRNUM/VCRTYP/DTA)=") From TRTMIG
Return
$CAL_ERRTRA
Call ERRTRA (WTAB_CAL,WCPT_CAL,"File CPTANALIN(ABRFIC/VCRTYP/VCRNUM/VCRLIN/VCRSEQ/CPLCLE/ANALIG)=") From TRTMIG
Return

########################################################################
# Migration to v6.0 - Delivery header
########################################################################
$MAJ60_SDH
      [F:SDH]CPY=GSOCIETE
      If len([F:SDH]EECNAT)>2 & left$([F:SDH]EECNAT,1)="0" : [F:SDH]EECNAT=right$([F:SDH]EECNAT,2) : Endif
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI=0 To dim([F:SDH]INVDTA)-1
          If [F:SDH]INVDTA(WI)<>0
              [F:SDH]INVDTATYP(WI)=1
              WJ=find([F:SDH]INVDTA(WI),WSFINUM(0..WNBSFI))
              If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:SDH]INVDTATYP(WI)=3 Endif
          Endif
      Next
      # Renseignement des unités de répartition
      [F:SDH]DSPWEU=GSALDSPWEU
      [F:SDH]DSPVOU=GSALDSPVOU
      Raz [F:SDH]DSPTOTQTY, [F:SDH]DSPTOTWEI, [F:SDH]DSPTOTVOL
      # Pour les livraisons non validées et les livraisons validées non facturées :
      # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
#      If ([F:SDH]CFMFLG=1 | ([F:SDH]CFMFLG=2 & [F:SDH]INVFLG=1)
      If [F:SDH]INVFLG=1
          # Valorisation
          #--- entete
          Raz [M:SDH0], [M:SDH1], [M:SDH2], [M:SDH3]
          [M:SDH0]=[F:SDH]
          [M:SDH1]=[F:SDH]
          # Pour l'alim du tableau des éléments voir s'il faut appeler SAISFOOT
          [M:SDH2]=[F:SDH]
          [M:SDH3]=[F:SDH]
          nolign=0
      Endif
Return

########################################################################
# Migration to v7 - Delivery header
########################################################################
$MAJ70_SDH
       # New field SCO initilization
       If [F:SDHM]SDHCAT=2
        [F:SDH]SCO=2
       Else
        [F:SDH]SCO=1
       Endif
       # Modification of the SDHCAT field content
       [F:SDH]SDHCAT=1
       If [F:SDH]SCO=2 & [F:SDH]LND<>2 : [F:SDH]SDHCAT=3 : Endif
       If [F:SDH]LND=2 & [F:SDH]SCO<>2 : [F:SDH]SDHCAT=2 : Endif

# Issue 115758
# It is not necessary to search SDHTYP value for each SDELIVERY
# It is necessary to do it each time SALFCY has changed

#       # New field SDHTYP initialization
#       Local Char    SGCURLEG : SGCURLEG=GCURLEG
#       Local Char    SGCURFCY : SGCURFCY=GCURFCY
#       Local Integer SGDLVTYP : SGDLVTYP=GDLVTYP
#       Local Char    WSDHTYP
#       Local Integer WSDHCAT, WSCO, WLND
#       GCURLEG=GLEGSOC(find([F:SDH]CPY,GSOC)) : GDLVTYP=[F:SDH]SDHCAT : GCURFCY=[F:SDH]SALFCY
#       Gosub SDHTYP From TRTVENLIV
#       If WSDHTYP<>""
#        [F:SDH]SDHTYP=WSDHTYP
#       Else
#        GOK=0 : Call ECR_TRACE("     1-File SDELIVERY"-[F:SDH]SDHNUM+", Error : Impossible to défine a delivery type",1) From GESECRAN
#       Endif
#       GCURLEG=SGCURLEG : GDLVTYP=SGDLVTYP : GCURFCY=SGCURFCY

Case [F:SDH]SDHCAT
    When 1       : # Livraison normale
      If WSDHTYPNOR<>""
        [F:SDH]SDHTYP=WSDHTYPNOR
      Endif
    When 2       : # Livraison de prêt
      If WSDHTYPLND<>""
        [F:SDH]SDHTYP=WSDHTYPLND
      Endif
    When 3       : # Livraison pour sous-traitance
      If WSDHTYPSCO<>""
        [F:SDH]SDHTYP=WSDHTYPSCO
      Endif
    When Default : # Au cas où...
      If WSDHTYPNOR<>""
        [F:SDH]SDHTYP=WSDHTYPNOR
      Endif
Endcase

If [F:SDH]SDHTYP=""
    GOK=0 : Call ECR_TRACE("     1-File SDELIVERY"-[F:SDH]SDHNUM+", Error : Impossible to défine a delivery type",1) From GESECRAN
Endif
# End issue 115758

Return

# Issue 115758
########################################################################
$RECSDHTYP

Local Integer  CATEG

SGCURLEG=GCURLEG : SGCURFCY=GCURFCY
GCURLEG=GLEGSOC(find(GSOCIETE,GSOC)) : GCURFCY=[F:SDHM]SALFCY

# Initialisation du type de livraison pour les livraisons normales          : SDHCAT=1
Raz WSDHTYP, WSDHTYPNOR, WSDHTYPLND, WSDHTYPSCO
CATEG=1 : Gosub SDHTYP : WSDHTYPNOR=WSDHTYP
# Initialisation du type de livraison pour les livraisons de prêt           : SDHCAT=2
Raz WSDHTYP
CATEG=2 : Gosub SDHTYP : WSDHTYPLND=WSDHTYP
# Initialisation du type de livraison pour les livraisons de sous-traitance : SDHCAT=3
Raz WSDHTYP
CATEG=3 : Gosub SDHTYP : WSDHTYPSCO=WSDHTYP

GCURLEG=SGCURLEG : GCURFCY=SGCURFCY

Return
########################################################################
$SDHTYP

# ----------------------------------------------------- #
# First, we search delivery type in the migrated folder #
# ----------------------------------------------------- #
Link [TSDM] With [FGRM]FGR0=[F:TSDM]GFY;GCURFCY As [KTSDM]

Case CATEG
    When 1       : # Livraison normale
        Call PARAM([F:SDHM]SALFCY,"SDHTYPNOR",WPARSDHTYP) From ADOVAL
    When 2       : # Livraison de pret
        Call PARAM([F:SDHM]SALFCY,"SDHTYPLND",WPARSDHTYP) From ADOVAL
    When 3       : # Livraison de sous-traitance
        Call PARAM([F:SDHM]SALFCY,"SDHTYPSCO",WPARSDHTYP) From ADOVAL
    When Default
        Call PARAM([F:SDHM]SALFCY,"SDHTYPNOR",WPARSDHTYP) From ADOVAL
Endcase

If WPARSDHTYP<>""
  # The parameter value SDHTYP (NOR LND or SCO) is fed :
  # --> Check if this delivery type exists and if it is consistent with the legislation and company / site restrictions
  Filter [KTSDM] Where SDHCAT=CATEG & [TSDM]SDHTYP=WPARSDHTYP & ([TSDM]GFY="" | [FGRM]FCY=GCURFCY) & ([TSDM]LEG=GCURLEG | [TSDM]LEG="" )
  Read [KTSDM]TSD0 First
  If fstat=0
     WSDHTYP = [F:TSDM]SDHTYP
     WSDHCAT = [F:TSDM]SDHCAT
  Endif
  Filter [KTSDM]
Endif

# If no parameter value found or the delivery type given by the parameter can't be used
# --> We try to find a compatible delivery type

# First, we search delivery type for the legislation
If WSDHTYP=""
    Filter [KTSDM] Where SDHCAT=CATEG & ([TSDM]GFY="" | [FGRM]FCY=GCURFCY) & [TSDM]LEG=GCURLEG
    Read [KTSDM]TSD0 First
    If fstat=0
        WSDHTYP = [F:TSDM]SDHTYP
        WSDHCAT = [F:TSDM]SDHCAT
    Endif
    Filter [KTSDM]
Endif

# No delivery type found for the legislation, we search delivery type with no legislation
If WSDHTYP=""
    Filter [KTSDM] Where SDHCAT=CATEG & ([TSDM]GFY="" | [FGRM]FCY=GCURFCY) & [TSDM]LEG=""
    Read [KTSDM]TSD0 First
    If fstat=0
        WSDHTYP = [F:TSDM]SDHTYP
        WSDHCAT = [F:TSDM]SDHCAT
    Endif
    Filter [KTSDM]
Endif

# -------------------------------------------------------------------------------- #
# No delivery type found in the migrated folder, we search in the reference folder #
# -------------------------------------------------------------------------------- #
# First, we search delivery type for the legislation
If WSDHTYP=""
    Link [TSDR] With [FGRR]FGR0=[F:TSDR]GFY;GCURFCY As [KTSDR]
    Filter [KTSDR] Where SDHCAT=CATEG & ([TSDR]GFY="" | [FGRR]FCY=GCURFCY) & [TSDR]LEG=GCURLEG
    Read [KTSDR]TSD0 First
    If fstat=0
       WSDHTYP = [F:TSDR]SDHTYP
       WSDHCAT = [F:TSDR]SDHCAT
    Endif
    Filter [KTSDR]
Endif

# No delivery type found for the legislation, we search delivery type with no legislation
If WSDHTYP=""
    Filter [KTSDR] Where SDHCAT=CATEG & ([TSDR]GFY="" | [FGRR]FCY=GCURFCY) & [TSDR]LEG=""
    Read [KTSDR]TSD0 First
    If fstat=0
       WSDHTYP = [F:TSDR]SDHTYP
       WSDHCAT = [F:TSDR]SDHCAT
    Endif
    Filter [KTSDR]
Endif
Return
# End issue 115758

########################################################################
# Migration to V6 - Delivery lines
########################################################################
$MAJ60_SDDSDH
      # Pour les livraisons non validées et les livraisons validées non facturées :
      # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
#      If ([F:SDH]CFMFLG=1 | ([F:SDH]CFMFLG=2 & [F:SDH]INVFLG=1)
      If [F:SDH]INVFLG=1
              If nolign>=dim([M:SDH1]UPDFLG) Return Endif        : # Bug 69648
              nolign += 1
              [M:SDH1]=[F:SDD]
              WFICD="SDD" : WFICD1="SDD" : WFICE="SDH" : Gosub ALIM_FICD
              [M:SDH1]VAT1(nolign-1)    = [F:SDD]VAT(0)
              [M:SDH1]VAT2(nolign-1)    = [F:SDD]VAT(1)
              [M:SDH1]VAT3(nolign-1)    = [F:SDD]VAT(2)
              [M:SDH1]VACITM1(nolign-1) = [F:SDD]VACITM(0)
              [M:SDH1]VACITM2(nolign-1) = [F:SDD]VACITM(1)
              [M:SDH1]VACITM3(nolign-1) = [F:SDD]VACITM(2)
              [M:SDH1]NBLIG+=1
      Else
              WFICD="SDD" : WFICD1="SDD" : WFICE="SDH" : Gosub ALIM_FICD
      Endif
Return

########################################################################
# Migration to V7 - Delivery lines
########################################################################
$MAJ70_SDDSDH
      # Modification of the SDHCAT field content
      [F:SDD]SDHCAT=[F:SDH]SDHCAT
Return

# 71065 : PJT
########################################################################
# Initialization of the new fields for V11 (Delivery lines) [CHALLENGER]
########################################################################
$MAJ110_SDDSDH

[F:SDD]PJT = [F:SDH]PJT

Return
# 71065 : PJT

# Issue X3-69499
########################################################################
# Initialization of the new fields for V120 (Delivery lines)
########################################################################
$MAJ120_SDDSDH

If [F:SDH]CFMFLG=2
   [F:SDD]LINCFMFLG=2
Else
   [F:SDD]LINCFMFLG=1
Endif

Return
# End issue X3-69499

########################################################################
# Migration to V6 - Delivery Header - After lines updates
########################################################################
$SUITE_MAJ60_SDH
      # Pour les livraisons non validées et les livraisons validées non facturées :
      # Valorisation pour alimentation des tables SVCRFOOT et SVCRVAT
#      If ([F:SDH]CFMFLG=1 | ([F:SDH]CFMFLG=2 & [F:SDH]INVFLG=1)
      If [F:SDH]INVFLG=1
          # Bug 69648
          If nolign>=dim([M:SDH1]UPDFLG)
              Call ECR_TRACE("File SDELIVERY"-[F:SDH]SDHNUM-":"-mess (26,100,1)-mess(224,139,1)-":"-"SDH",1) From GESECRAN
          Else
          # Bug 69648
              [M:SIH0]ORICLC="GESSDHF"
              #Call CHARG_SIHX From TRTVENFACC : # Bug 70931
              Gosub CHARG_TABLEAUX  From TRTVENFACC
              If [M:SIH4]NBLIG>0
                 Gosub CAL_FACTURE     From TRTVENFACC
              Endif
              #-- création des enr dans les tables SVCRVAT et SVCRFOOT à partir de l'écran [M:SIHV]
              WVCRTYP=2 : WVCRNUM=[F:SDH]SDHNUM
              # Faut-il systématiquement supprimer
              ## Delete [SVF] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#              If fstat=1
#                  GOK=-1 : GLOCK="$SVCRFOOT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#              Endif
              ## Delete [SVV] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
#              If fstat=1
#                  GOK=-1 : GLOCK="$SVCRVAT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
#              Endif
              Gosub UPD_SVF_SIHV : Gosub UPD_SVV_SIHV
              [F:SDH]DLVINVNOT=[M:SIHV]INVNOT
              [F:SDH]DLVINVATI=[M:SIHV]INVATI
              [F:SDH]DLVINVNOTL=[M:SIHV]INVNOTRPT
              [F:SDH]DLVINVATIL=[M:SIHV]INVATIRPT
#              Call ECR_TRACE("SDELIVERY : "-[F:SDH]SDHNUM,1) From GESECRAN
          Endif :  # Bug 69648
      Endif
      # Alimentation des montants en devise société
      Call COURMNT([F:SDH]CUR,GLOCALDEV,GLOCALDEV,[F:SDH]CHGTYP,[F:SDH]DLVDAT,1,
&                  [F:SDH]DLVNOT,[F:SDH]DLVNOTL,[F:SDH]CHGRAT,WRET) From TRTDEV
      If WRET <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     1-File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(WRET),-1) From GESECRAN
      Endif
      Call COURMNT([F:SDH]CUR,GLOCALDEV,GLOCALDEV,[F:SDH]CHGTYP,[F:SDH]DLVDAT,1,
&                  [F:SDH]DLVATI,[F:SDH]DLVATIL,[F:SDH]CHGRAT,WRET) From TRTDEV
      If WRET <> 0 Then
        # FGR 12/01/2010 : X3SUIVI61184
        Call ECR_TRACE("     2-File SDELIVERY"-[F:SDH]SDHNUM+", Error ="-num$(WRET),-1) From GESECRAN
      Endif
      # ACA Gestion des adresses BPAPYR+BPY*
      Gosub RECUP_BPR

      If [F:SDH]PACFLG=2                                       : # livraison colisée
          # Issue 106947 - 20150811 by LD : Migration of historic folder
          #Update [SPH] Where CPY='' & VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM With CPY=[F:SDH]CPY
          #If fstat
          #   Call ECR_TRACE("File SPACK - of delivery"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
          #Endif
          #Update [SPD] Where CPY='' & VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM With CPY=[F:SDH]CPY
          #If fstat
          #   Call ECR_TRACE("File SPACKD - of delivery"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
          #Endif
          If func DOSVUE.ISVIEW(DOSSIER,"SPACK")<> 1
              Update [SPH] Where CPY='' & VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM With CPY=[F:SDH]CPY
              If fstat
                 Call ECR_TRACE("File SPACK - of delivery"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
              Endif
              Update [SPD] Where CPY='' & VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM With CPY=[F:SDH]CPY
              If fstat
                 Call ECR_TRACE("File SPACKD - of delivery"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
              Endif
          Endif
          # Issue 106947 - 20150811 by LD
      Endif
Return

########################################################################
$RECUP_BPR

    If [F:SDH]BPAINV=""
      # ACA Gestion des adresses +BPAINV
      If [F:BPC]BPCNUM<>[F:SDH]BPCINV
        Read [BPC]BPC0=[F:SDH]BPCINV
        If fstat Raz [F:BPC] Endif
      Endif
#     [F:SDH]BPAINV=[F:BPC]BPAINV
      If [F:SDH]BPCINV=[F:BPC]BPCINV
          [F:SDH]BPAINV=[F:BPC]BPAINV
      Else
          If [BPR]BPRNUM<>[F:SDH]BPCINV
            Read [BPR]BPR0=[F:SDH]BPCINV
            If fstat Raz [F:BPR] Endif
          Endif
          [F:SDH]BPAINV=[F:BPR]BPAADD
      Endif
    Endif

Return

########################################################################
$AMAJ60_SDD
    Gosub UPD_CAL_SDD
    #If dim([F:SDDM]MFGNUM)>0                     : # 88714
    If dim([F:SDDM]MFGNUM)>0 & [F:SDDM]MFGNUM<>"" : # 88714
        [F:SDD]VCRTYPORI=10
        [F:SDD]VCRNUMORI=[F:SDDM]MFGNUM
        [F:SDD]VCRLINORI=[F:SDDM]MFGLIN
        [F:SDD]VCRSEQORI=[F:SDDM]BOMSEQ
    Endif
Return

########################################################################
$MAJ80_SDH
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:SDH]CPY,GSOC)) #108649.n
      For I=0 To dim([F:SDH]INVDTA)-1
          If [F:SDH]INVDTA(I)<>0
              Local Integer WJ
              WJ=find([F:SDH]INVDTA(I),WSFINUM(0..WNBSFI))
              If WJ>0 : [F:SDH]SFISSTCOD(I)=WSFISSTCOD(WJ-1) : Endif
          Endif
      Next
  Endif
Return

########################################################################
$MAJ80_SDDSDH
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:SDH]CPY,GSOC)) #108649.n
      If [F:SDD]ITMREF<>""
          Gosub READ_ITM
          If [F:ITM]SSTCOD<>""
              [F:SDD]SSTCOD = [F:ITM]SSTCOD
          Endif
      Endif
  Endif
Return

# -------------------------------------------------- #
# Création des enregistrements de la table CPTANALIN #
# -------------------------------------------------- #
$UPD_CAL_SDD

##Look [CAL] CAL0="SDD";0;[F:SDD]SDHNUM;[F:SDD]SDDLIN;0;"";1
##If fstat
    Raz [F:CAL]
    [F:CAL]ABRFIC="SDD"
    [F:CAL]VCRNUM=[F:SDD]SDHNUM
    [F:CAL]VCRLIN=[F:SDD]SDDLIN
    [F:CAL]ANALIG=1
    For J=1 To max(GNBCOA,2)
        [F:CAL]LED(J-1)=GLEDSOC(J)
        [F:CAL]COA(J-1)=GCOA(J)
    Next J
    For J=1 To max(GNBDIE,GOPTCANA)
        [F:CAL]DIE(J-1)=GDIE(J)
        If evalue("dim([F:SDDM]CCE"+num$(J)+")")>0
            [F:CAL]CCE(J-1)=evalue("[F:SDDM]CCE"+num$(J))
        Endif
    Next J

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub CAL_STK : # pour stocker ref
#        WriteB [F:CAL]
#    Else
#        Write [F:CAL]
#    Endif
#    If fstat
#      If NEWMOTEUR & adxwrb>1
#        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#        Gosub CAL_ERRTRA : # pour afficher les ref
#      Else
#        Call ECR_TRACE("File CPTANALIN SDD 0"-[F:SDH]SDHNUM-num$([F:SDD]SDDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#      Endif
#      GOK=0 : Return
#    Endif
    Gosub CAL_STK : # pour stocker ref
    WriteB [F:CAL]
    If fstat
      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA : # pour afficher les ref
      GOK=0 : Return
    Endif
    # Issue 106947 - 20150811 by LD
##Endif

Return


# ---------------------------------------------------- #
# Creation dans la table SVCRFOOT à partir de [M:SIHV] #
# ---------------------------------------------------- #
$UPD_SVF_SIHV
# On boucle sur la table des élements de pied
For JL=0 To dim([M:SIHV]XFNUM)-1
#  If [M:SIHV]XFNUM(JL)<>0                              : # Issue 74556 - Optimisation
  If [M:SIHV]XFNUM(JL)<>0 & [M:SIHV]XFNOT(JL)<>0        : # Issue 74556 - Optimisation
##     Look [SVF] SVF0=WVCRNUM;WVCRTYP;[M:SIHV]XFNUM(JL)
##     If fstat
         Raz [F:SVF]
         [F:SVF]VCRTYP=WVCRTYP : [F:SVF]VCRNUM=WVCRNUM

         [F:SVF]CPY=GSOCIETE
         [F:SVF]CUR=[M:SIHV]VCUR

#         If evalue("dim([F:SVF]CREDAT)")>0
#              Assign "[F:SVF]CREDAT" With date$
#         Endif
#         If evalue("dim([F:SVF]CREUSR)")>0
#              Assign "[F:SVF]CREUSR" With GUSER
#         Endif

         [F:SVF]CREDAT = date$
         [F:SVF]CREUSR = GUSER

         [F:SVF]DTA        = [M:SIHV]XFNUM(JL)
         [F:SVF]DTAAMT     = [M:SIHV]XFDTAAMT(JL)
         [F:SVF]DTATYP     = [M:SIHV]CLCBAS(JL)
         [F:SVF]DTANOT     = [M:SIHV]XFNOT(JL)

         For I=0 To dim([F:SVF]DTANET)-1
             [F:SVF]DTAVATNOT(I) = evalue ("[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTANET(I)    = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVAT(I)    = evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVATRAT(I) = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
             [F:SVF]DTAVATAMT(I) = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
         Next

         [F:SVF]CLCORD     = [M:SIHV]CLCORD(JL)
         [F:SVF]AMTCOD     = [M:SIHV]AMTCOD(JL)
         [F:SVF]DTADSP     = [M:SIHV]DSP(JL)

         # Issue 106947 - 20150811 by LD : Migration of historic folder
#          If NEWMOTEUR
#              Gosub SVF_STK : # pour stocker ref
#              WriteB [F:SVF]
#          Else
#              Write [F:SVF]
#          Endif
#          If fstat
#            If NEWMOTEUR & adxwrb>1
#              Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
#              Gosub SVF_ERRTRA : # pour afficher les ref
#            Else
#              Call ECR_TRACE("File SVCRFOOT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XFNUM(JL))+", Error ="-num$(fstat),1) From GESECRAN
#            Endif
#            GOK=0 : Break
#          Endif
         Gosub SVF_STK : # pour stocker ref
         WriteB [F:SVF]
         If fstat
            Call ECR_TRACE("File SVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
            Gosub SVF_ERRTRA : # pour afficher les ref
            GOK=0 : Break
         Endif
         # Issue 106947 - 20150811 by LD
     Endif
##  Endif
Next JL

Return

# --------------------------------------------------- #
# Creation dans la table SVCRVAT à partir de [M:SIHV] #
# --------------------------------------------------- #
$UPD_SVV_SIHV
Local Integer I
Local Char    WVAT (GLONVAT)

Raz [F:SVV]        : # Dde 81811 : Optimisation
# On boucle sur la table des taxes liées aux produits
For JL=0 To dim ([M:SIHV]XVTAX)-1
  If [M:SIHV]XVTAX(JL)<>""
##     Look [SVV] SVV0=WVCRTYP;WVCRNUM;[M:SIHV]XVTAX(JL)
##     If fstat
         #Raz [F:SVV]        : # Dde 81811 : Optimisation
         [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

         [F:SVV]CPY=GSOCIETE
         [F:SVV]CUR=[M:SIHV]VCUR

#         If evalue("dim([F:SVV]CREDAT)")>0
#             Assign "[F:SVV]CREDAT" With date$
#         Endif
#         If evalue("dim([F:SVV]CREUSR)")>0
#             Assign "[F:SVV]CREUSR" With GUSER
#         Endif

         [F:SVV]CREDAT = date$
         [F:SVV]CREUSR = GUSER

         [F:SVV]VAT       = [M:SIHV]XVTAX(JL)
         [F:SVV]VATTYP    = [M:SIHV]XVTYP(JL)
         [F:SVV]VATRAT    = [M:SIHV]XVRAT(JL)

         [F:SVV]VATGRO    = [M:SIHV]XVNOT(JL)
         [F:SVV]VATNET    = [M:SIHV]XVSMI(JL)
         [F:SVV]VATAMT    = [M:SIHV]XVAMT(JL)
         [F:SVV]VATSUPAMT = [M:SIHV]XVSUP(JL)

         [F:SVV]BASTAX    = [M:SIHV]XVSMI(JL)
         [F:SVV]AMTTAX    = [M:SIHV]XVAMT(JL)

         Write [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Endif
##  Endif
Next JL

# On boucle sur la table des éléments de pied
For JL=0 To dim([M:SIHV]XFTAX)-1
  If [M:SIHV]XFTAX(JL)<>""
     Read [SVV]SVV0=WVCRTYP;WVCRNUM;[M:SIHV]XFTAX(JL)
     If fstat
         Raz [F:SVV]
         [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

         [F:SVV]CPY=GSOCIETE
         [F:SVV]CUR=[M:SIHV]VCUR

#         If evalue("dim([F:SVV]CREDAT)")>0
#             Assign "[F:SVV]CREDAT" With date$
#         Endif
#         If evalue("dim([F:SVV]CREUSR)")>0
#             Assign "[F:SVV]CREUSR" With GUSER
#         Endif

         [F:SVV]CREDAT = date$
         [F:SVV]CREUSR = GUSER

         [F:SVV]VAT    = [M:SIHV]XFTAX(JL)
         [F:SVV]VATTYP = 1
         [F:SVV]VATRAT = [M:SIHV]XFRAT(JL)

         [F:SVV]BASTAX = [M:SIHV]XFSMI(JL)
         [F:SVV]AMTTAX = [M:SIHV]XFVATAMT(JL)

         Write [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Else
         [F:SVV]BASTAX += [M:SIHV]XFSMI(JL)
         [F:SVV]AMTTAX += [M:SIHV]XFVATAMT(JL)

         Rewrite [F:SVV]
         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
     Endif
  Elsif [M:SIHV]XFVATAMT(JL)<>0
     For I=0 To dim([M:SIHV]XVTAX)-1
         If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",I+1)+")")>0
             If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")") <> ""
                 WVAT=evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
#################Gbn-82996-Deb
#                 If VCRTYP<>WVCRTYP | VCRNUM<>WVCRNUM | VAT<>WVAT        : # Dde 81811 : Optimisation
#                     Read [SVV]SVV0=WVCRTYP;WVCRNUM;WVAT
#                 Endif                                                   : # Dde 81811 : Optimisation
#                 If fstat
#                     Raz [F:SVV]
#                     [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM
#
#                     [F:SVV]CPY=GSOCIETE
#                     [F:SVV]CUR=[M:SIHV]VCUR
#
##                     If evalue("dim([F:SVV]CREDAT)")>0
##                         Assign "[F:SVV]CREDAT" With date$
##                     Endif
##                     If evalue("dim([F:SVV]CREUSR)")>0
##                         Assign "[F:SVV]CREUSR" With GUSER
##                     Endif
#
#                     [F:SVV]CREDAT = date$
#                     [F:SVV]CREUSR = GUSER
#
#                     [F:SVV]VAT    = WVAT
#                     [F:SVV]VATTYP = 1
#                     [F:SVV]VATRAT = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
#
#                     [F:SVV]BASTAX = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
#                     [F:SVV]AMTTAX = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
#
#                     Write [F:SVV]
#                     If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
#                 Else
#                     [F:SVV]BASTAX += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
#                     [F:SVV]AMTTAX += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
#
#                     Rewrite [F:SVV]
#                     If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
#                 Endif
                 #-------
                 If [F:SVV]VCRTYP<>WVCRTYP | [F:SVV]VCRNUM<>WVCRNUM | [F:SVV]VAT<>WVAT        : # Dde 81811 : Optimisation
                     Read [SVV]SVV0=WVCRTYP;WVCRNUM;WVAT
                     If fstat=5
                         Raz [F:SVV]
                         [F:SVV]VCRTYP=WVCRTYP : [F:SVV]VCRNUM=WVCRNUM

                         [F:SVV]CPY=GSOCIETE
                         [F:SVV]CUR=[M:SIHV]VCUR

                         [F:SVV]CREDAT = date$
                         [F:SVV]CREUSR = GUSER

                         [F:SVV]VAT    = WVAT
                         [F:SVV]VATTYP = 1
                         [F:SVV]VATRAT = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                         [F:SVV]BASTAX = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                         [F:SVV]AMTTAX = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                         Write [F:SVV]
                         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                     Elsif fstat
                         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                     Else
                         [F:SVV]BASTAX += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                         [F:SVV]AMTTAX += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                         Rewrite [F:SVV]
                         If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                     Endif
                 Else
                     [F:SVV]BASTAX += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                     [F:SVV]AMTTAX += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")

                     Rewrite [F:SVV]
                     If fstat Call ECR_TRACE("File SVCRVAT"-WVCRNUM-num$(WVCRTYP)-num$([M:SIHV]XVTAX(JL))+", Error ="-num$(fstat),1) From GESECRAN Endif
                 Endif                                                   : # Dde 81811 : Optimisation
             #Gbn-82996-Fin
             Endif
         Endif
     Next
  Endif
Next JL

Return


$READ_ITM
WITMREF = [F:SDD]ITMREF
If [F:ITM]ITMREF<>WITMREF
    Read [F:ITM]ITM0 = WITMREF : If fstat Raz [ITM] Endif
Endif
Return

$ALIM_FICD

[F:SDD]CPY= [F:SDH]CPY

[F:SDD]DSPLINFLG= 2

Gosub READ_ITM

WMNTCALC = [F:ITM]ITMWEI * [F:SDD]QTY * [F:SDD]SAUSTUCOE
WUOM1=[F:ITM]WEU
WUOM2=GSALDSPWEU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,WMNTCALC)
Gosub CONVERT_QTY From UUMGTRTSAL00
WMNTCALC=WQTY
[F:SDD]DSPLINWEI= WMNTCALC

WMNTCALC = [F:ITM]ITMVOU * [F:SDD]QTY * [F:SDD]SAUSTUCOE
WUOM1=[F:ITM]VOU
WUOM2=GSALDSPVOU
WQTY=WMNTCALC
#Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,WMNTCALC)
Gosub CONVERT_QTY From UUMGTRTSAL00
WMNTCALC=WQTY
[F:SDD]DSPLINVOL= WMNTCALC

[F:SDD]DSPWEU= [F:SDH]DSPWEU
[F:SDD]DSPVOU= [F:SDH]DSPVOU

WMONT  = [F:SDH]DSPTOTQTY
# Issue 115758
#If WFICD<>"SQD"
If WFICD<>"SDD"
# End issue 115758
    WMONT += [F:SDD]QTYSTU
Else
    WMONT += [F:SDD]QTY
Endif
[F:SDH]DSPTOTQTY= WMONT

WMONT  = [F:SDH]DSPTOTWEI
WMONT += [F:SDD]DSPLINWEI
[F:SDH]DSPTOTWEI= WMONT

WMONT  = [F:SDH]DSPTOTVOL
WMONT += [F:SDD]DSPLINVOL
[F:SDH]DSPTOTVOL= WMONT

Return

########################################################################
#----- Suppression des incohérences entre tables avant migration -----#
########################################################################
$TRT_SQL

 #-----  Déclaration des variables -----#

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 Trbegin [SDDM]
 GOK = 1

 Gosub TRT_SQL1

 If GOK<1
  Rollback
 Else
  Commit
 Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
# Mise à jour STOFCY SDELIVERYD à partir de STOFCY SDELIVERY
########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSDDM+" SET STOFCY_0="
REQSQL(1)="(SELECT SDH.STOFCY_0 FROM"-DOSSIER+"."+WNAMSDHM+" SDH Where SDH.SDHNUM_0="+WNAMSDDM+".SDHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSDDM+".STOFCY_0<>(SELECT SDH.STOFCY_0 From"-DOSSIER+"."+WNAMSDHM+" SDH Where SDH.SDHNUM_0="+WNAMSDDM+".SDHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGTRTSAL06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSAL06(APPLI)
End

