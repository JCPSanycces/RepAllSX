#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(20)(1) , VALEUR(20)
End

$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    #When "LECTURE"     : Gosub LECTURE
    When Default
  Endcase

Return

$OUVRE
If !clalev([F:ID])  : Local File EMPLOID   [ID]  : Endif
If !clalev([F:CNG]) : Local File CNGCPY    [CNG] : Endif
If !clalev([F:TIM]) : Local File TIMCOD    [TIM] : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
If !clalev([F:HSP]) : Local File HISTOPAYE [HSP] : Endif
If !clalev([F:VEP]) : Local File VALEMP    [VEP] : Endif
If !clalev([F:DCG]) : Local File DEMCONGE  [DCG] : Endif
If !clalev([F:HRPEOD]) : Local File HRPEODET    [HRPEOD] : Endif

Return

$DEBUT

#Save parameter values
If PARAM(1) = "" #Employee code - set from logged in user
PARAM(1) = fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
Endif

Raz [M:DLS1]
[M:DLS1]REFNUM = PARAM(1)

#Set screen style

Return




$LECTURE
  If [M:DLS1]CTRNUM=""
    Call AM_REFNUM([M:DLS1]REFNUM)
    Call AS_DATPYR([M:DLS1]DATPYR)
  Endif

#clear grids
  Raz [M:DLS2]
  nolign = 0


If [M:DLS1]REFNUM="" | [M:DLS1]CTRNUM="" | [M:DLS1]DATPYR=[0/0/0] : Return : Endif

Local Date DATSTR, DATEND

#get contract and site
#ADNGO - 2016-12-12 - X3-11347 - START
#  Link [CTR]    With  [FCY]FCY0=[CTR]ETRFCY
#&               As    [LNK]
#  Filter [LNK]  Where [CTR]REFNUM=[M:DLS1]REFNUM
#& &                   [CTR]CTRNUM=[M:DLS1]CTRNUM
#& &                   [CTR]CTRDAT<[M:DLS1]DATPYR
#&               Order By Key CLE = [CTR]REFNUM;[CTR]CTRNUM;[CTR]CTRDAT
  Link [HRCTR]    With  [FCY]FCY0=[HRCTR]ETRFCY
&               As    [LNK]
  Filter [LNK]  Where [HRCTR]REFNUM=[M:DLS1]REFNUM
& &                   [HRCTR]CTRNUM=[M:DLS1]CTRNUM
& &                   [HRCTR]CTRDAT<[M:DLS1]DATPYR
&               Order By Key CLE = [HRCTR]REFNUM;[HRCTR]CTRNUM;[HRCTR]CTRDAT
#ADNGO - 2016-12-12 - X3-11347 - END
  Read [LNK] Last
  Filter [LNK]

#get annual leave period
Local Char CRITERE(200)

  CRITERE=""
  If [M:DLS1]LEAFLG=2 : CRITERE="[TIM]CATTIM=3" : Endif
  If [M:DLS1]ABSFLG=2
    If CRITERE<>"" : CRITERE-="|" : Endif
    CRITERE-="[TIM]CATTIM=2"
  Endif
#JASMI - 2016-08-18 - X3PEOP-1288 - START
#  If CRITERE="" : CRITERE="1=1" : Endif
  If CRITERE="" : Return : Endif
#JASMI - 2016-08-18 - X3PEOP-1288 - END

#ADNGO - 2016-12-12 - X3-11347 - START
#Link [CNG]    With  [TIM]TIM0=[CNG]TIM
#ADNGO - 2016-12-12 - X3-11347 - END
  Link [CNG]    With  [TIM]TIM0=GCURLEG;[CNG]TIM
&               As    [LNK]
  Filter [LNK]  Where [CNG]CPY=[FCY]LEGCPY
& &                   [CNG]YEA=year([M:DLS1]DATPYR)
& &                   evalue(CRITERE)

#JASMI - 2016-08-18 - X3PEOP-1288 - START
##clear grid
#  Raz [M:DLS2]
#  nolign = 0
#
#  [M:DLS2]NUMPLN=0
#  [M:DLS2]NUMATT=0
#JASMI - 2016-08-18 - X3PEOP-1288 - END

Local Decimal TAKEN_PREVIOUS

#populate grid
  For [LNK]
    nolign += 1
    [M:DLS2]TIM(nolign-1) = [CNG]TIM
  #JASMI - 2015-11-05 - Req. No. 111578 - START
    #ADNGO - 2016-12-12 - X3-11347 - START
    #If func AFNC.ACTIV("KSA")>0
    If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
    #ADNGO - 2016-12-12 - X3-11347 - END
      [M:DLS2]LVESEL(nolign-1) = [CNG]LVESEL
      [M:DLS2]LVETRM(nolign-1) = [CNG]LVETRM
    Endif
  #JASMI - 2015-11-05 - Req. No. 111578 - END

    Local Integer NEWYEA : [L]NEWYEA = 0
  #JASMI - 2016-08-24 - START
#    Call CALC_LVE_DATES_KSA([CNG]TIM,[FCY]LEGCPY,[CNG]YEA,[CTR]REFNUM,[CTR]CTRNUM,
#&                           [L]DATSTR,[L]DATEND,
#&                           [M:DLS2]CYCSTRDAT(nolign-1),[M:DLS2]CYCENDDAT(nolign-1),
#&                           [0/0/0],[L]NEWYEA) From SUBCNEKSA
    #ADNGO - 2016-12-12 - X3-11347 - START
    #Call CALC_LVE_DATES_KSA([CNG]TIM,[FCY]LEGCPY,[CNG]YEA,[HRCTR]REFNUM,[HRCTR]CTRNUM,
    Call CALC_LVE_DATES_KSA([CNG]TIM,[FCY]LEGCPY,[CNG]YEA,[HRCTR]REFNUM,[HRCTR]CTRNUM,
&                           [L]DATSTR,[L]DATEND,
&                           [M:DLS2]CYCSTRDAT(nolign-1),[M:DLS2]CYCENDDAT(nolign-1),
&                           [M:DLS1]DATPYR,[L]NEWYEA) From SUBCNEKSA
     #ADNGO - 2016-12-12 - X3-11347 - END
  #JASMI - 2016-08-24 - END

  #JASMI - 2015-11-05 - Req. No. 111578 - START
    #ADNGO - 2016-01-17 - X3-11347 - START
    #If func AFNC.ACTIV("KSA")=0
#JASMI - 2017-05-12 - START
#    If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
    If !func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#JASMI - 2017-05-12 - END
      [M:DLS2]CYCSTRDAT(nolign-1)=[CNG]DEBDAT
      [M:DLS2]CYCENDDAT(nolign-1)=[CNG]FINDAT
    Endif
  #JASMI - 2015-11-05 - Req. No. 111578 - END
    #ADNGO - 2016-01-17 - X3-11347 - END
  #MTD accummulated
    [M:DLS2]MTDACQCUM(nolign-1) = [CNG]CUM
    Call GET_PAYROLL_AMOUNT([M:DLS1]CURBUL,[M:DLS2]MTDACQCUM(nolign-1),[M:DLS2]MTDACQ(nolign-1))

  #YTD accummulated
    [M:DLS2]YTDACQCUM(nolign-1) = [CNG]CUMACQ(0)
    Call GET_PAYROLL_AMOUNT([M:DLS1]CURBUL,[M:DLS2]YTDACQCUM(nolign-1),[M:DLS2]YTDACQ(nolign-1))

  #accummulated at start of month
    [M:DLS2]YTDACQ(nolign-1)-=[M:DLS2]MTDACQ(nolign-1)

  #YTD taken
    [M:DLS2]YTDTAKCUM(nolign-1) = [CNG]CUMPRI(0)
    Call GET_PAYROLL_AMOUNT([M:DLS1]CURBUL,[M:DLS2]YTDTAKCUM(nolign-1),[M:DLS2]YTDTAK(nolign-1))

  #YTD taken at start of month
    [L]TAKEN_PREVIOUS=0
    Call GET_PAYROLL_AMOUNT([M:DLS1]PREBUL,[M:DLS2]YTDTAKCUM(nolign-1),[L]TAKEN_PREVIOUS)

  #calc taken this month
  #JASMI - 2016-08-24 - START
    If month([M:DLS1]DATPYR)=month([M:DLS2]CYCSTRDAT(nolign-1))
      [L]TAKEN_PREVIOUS=0
    Endif
  #JASMI - 2016-08-24 - END
    If [L]TAKEN_PREVIOUS<=[M:DLS2]YTDTAK(nolign-1)
      [M:DLS2]MTDTAK(nolign-1)=[M:DLS2]YTDTAK(nolign-1)-[L]TAKEN_PREVIOUS
      [M:DLS2]YTDTAK(nolign-1)=[M:DLS2]YTDTAK(nolign-1)-[M:DLS2]MTDTAK(nolign-1)
    Else
      [M:DLS2]MTDTAK(nolign-1)=[M:DLS2]YTDTAK(nolign-1)
    Endif

  #calc balance
    [M:DLS2]BALENDPER(nolign-1)=[M:DLS2]YTDACQ(nolign-1)+[M:DLS2]MTDACQ(nolign-1)
&                              -[M:DLS2]YTDTAK(nolign-1)-[M:DLS2]MTDTAK(nolign-1)
    Gosub GET_LEAVE_REQUESTS
  Next
  [M:DLS2]NBLIG=nolign
  Filter [LNK]

#JASMI - 2016-08-18 - X3PEOP-1288 - START
#  Affzo [M:DLS2]
#JASMI - 2016-08-18 - X3PEOP-1288 - END

  For nolign=1 To [M:DLS2]NUMATT
    If [M:DLS2]ATTHIS(nolign-1)=2
    #change background colour to red
      Chgstl [M:DLS2]TIMATT(nolign-1)     With "PLGCUR"
      Chgstl [M:DLS2]STRDATATT(nolign-1)  With "PLGCUR"
      Chgstl [M:DLS2]ENDDATATT(nolign-1)  With "PLGCUR"
      Chgstl [M:DLS2]NUMDAYATT(nolign-1)  With "PLGCUR"
      Chgstl [M:DLS2]ATTHIS(nolign-1)     With "PLGCUR"
    Else
    #change background colour to red
      Chgstl [M:DLS2]TIMATT(nolign-1)     With ""
      Chgstl [M:DLS2]STRDATATT(nolign-1)  With ""
      Chgstl [M:DLS2]ENDDATATT(nolign-1)  With ""
      Chgstl [M:DLS2]NUMDAYATT(nolign-1)  With ""
      Chgstl [M:DLS2]ATTHIS(nolign-1)     With ""
    Endif
  Next nolign

#JASMI - 2016-08-18 - X3PEOP-1288 - START
  Affzo [M:DLS2]
#JASMI - 2016-08-18 - X3PEOP-1288 - END

Return

Subprog GET_PAYROLL_AMOUNT(THIS_BUL,USERUB,CALC_AMOUNT)
Value Char        THIS_BUL,USERUB
Variable Decimal  CALC_AMOUNT

  Filter [HSP] Where [HSP]BUL=THIS_BUL & [HSP]RUB=USERUB
  For [HSP]
    CALC_AMOUNT+=[HSP]AMT
  Next
  Filter [HSP]

End

$GET_LEAVE_REQUESTS
#future leave requests
  [M:DLS2]PLN(nolign-1)=0 : [M:DLS2]FUTATT(nolign-1)=0
  Filter [DCG] Where [DCG]REFNUM=[M:DLS1]REFNUM & [DCG]TIM=[M:DLS2]TIM(nolign-1)
& &                  UID>0 & [DCG]STRDAT > [M:DLS1]DATPYR
  For [DCG]
    If [DCG]STA=2
      [M:DLS2]FUTATT(nolign-1)+=[DCG]NBRDAY
    #add pending item to grid
      [M:DLS2]TIMATT([M:DLS2]NUMATT)=[DCG]TIM
      [M:DLS2]STRDATATT([M:DLS2]NUMATT)=[DCG]STRDAT
      [M:DLS2]ENDDATATT([M:DLS2]NUMATT)=[DCG]ENDDAT
      [M:DLS2]NUMDAYATT([M:DLS2]NUMATT)=[DCG]NBRDAY
      [M:DLS2]ATTHIS([M:DLS2]NUMATT)=1
      [M:DLS2]NUMATT+=1
    Endif
    If find([DCG]STA,3,5,7)
      [M:DLS2]PLN(nolign-1)+=[DCG]NBRDAY
    #add planned item to grid
      [M:DLS2]TIMPLN([M:DLS2]NUMPLN)=[DCG]TIM
      [M:DLS2]STRDATPLN([M:DLS2]NUMPLN)=[DCG]STRDAT
      [M:DLS2]ENDDATPLN([M:DLS2]NUMPLN)=[DCG]ENDDAT
      [M:DLS2]NUMDAYPLN([M:DLS2]NUMPLN)=[DCG]NBRDAY
      [M:DLS2]NUMPLN+=1
    Endif
  Next
  Filter [DCG]

#past leave requests
  [M:DLS2]PSTATT(nolign-1)=0
  Filter [DCG] Where [DCG]REFNUM=[M:DLS1]REFNUM & [DCG]TIM=[M:DLS2]TIM(nolign-1)
& &                  UID>0 & [DCG]STRDAT <= [M:DLS1]DATPYR
& &                  [DCG]STA=2
  For [DCG]
    [M:DLS2]PSTATT(nolign-1)+=[DCG]NBRDAY
  #add pending item to grid
    [M:DLS2]TIMATT([M:DLS2]NUMATT)=[DCG]TIM
    [M:DLS2]STRDATATT([M:DLS2]NUMATT)=[DCG]STRDAT
    [M:DLS2]ENDDATATT([M:DLS2]NUMATT)=[DCG]ENDDAT
    [M:DLS2]NUMDAYATT([M:DLS2]NUMATT)=[DCG]NBRDAY
    [M:DLS2]ATTHIS([M:DLS2]NUMATT)=2
    [M:DLS2]NUMATT+=1
  Next
  Filter [DCG]

Return

######################################################################################
## Section automatically added (screen CONSDLS1) 10/22/2015 11:52:32 (JASMI)
######################################################################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> ""
    Raz [M:DLS1]CTRNUM
    If [M:DLS1]WDATDEB=[0/0/0] and [M:DLS1]CTRNUM = ""
      Call AS_DATPYR([M:DLS1]DATPYR)
      #ADNGO - 2016-12-09 - X3-11347 - START
        #[M:DLS1]WDATDEB = [F:PEO]PERSTR(0)
        [M:DLS1]WDATDEB = [F:HRPEOD]PERSTR(0)
      #ADNGO - 2016-12-09 - X3-11347 - END
    Endif
    If [M:DLS1]DATPYR<>[0/0/0]
      Call SELCTR(VALEUR,[M:DLS1]DATPYR,[M:DLS1]WDATDEB,[M:DLS1]CTRNUM) From DIVPAYE
    Else
      Call SELCTR(VALEUR,datesyst,[M:DLS1]WDATDEB,[M:DLS1]CTRNUM) From DIVPAYE
    Endif
    Affzo [M:DLS1]CTRNUM

  #JASMI - 2016-08-18 - X3PEOP-1288 - START
    If [M:DLS1]CTRNUM<>""
    #ADNGO - 2016-12-09 - X3-11347 - START
      #[M:DLS1]CTRDAT=[F:CTR]CTRDAT
      [M:DLS1]CTRDAT=[F:HRCTR]CTRDAT
    #ADNGO - 2016-12-09 - X3-11347 - END
      Affzo [M:DLS1]CTRDAT
    Endif
  #JASMI - 2016-08-18 - X3PEOP-1288 - END
  #ADNGO - 2016-12-09 - X3-11347 - START
    #If [F:FCY]FCY <> [F:CTR]ETRFCY
    If [F:FCY]FCY <> [F:HRCTR]ETRFCY
      #Call LECTURE("FCY",[F:CTR]ETRFCY,"") From CONTOBJ
      Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  #ADNGO - 2016-12-09 - X3-11347 - END
    Endif
  Endif

End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
#ADNGO - 2016-12-14 - X3-11347 - START
  GCURLEG = ""
#ADNGO - 2016-12-14 - X3-11347 - END
  If [M:DLS1]WDATDEB=[0/0/0] and [M:DLS1]CTRNUM = ""
    Call AS_DATPYR([M:DLS1]DATPYR)
    #ADNGO - 2016-12-09 - X3-11347 - START
      #[M:DLS1]WDATDEB = [F:PEO]PERSTR(0)
      [M:DLS1]WDATDEB = [F:HRPEOD]PERSTR(0)
    #ADNGO - 2016-12-09 - X3-11347 - END
  Endif

End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = ""
  #ADNGO - 2016-12-09 - X3-11347 - START
    #Raz [F:CTR]
    Raz [F:HRCTR]
  #ADNGO - 2016-12-09 - X3-11347 - END
    Raz [M:DLS1]CTRDAT
  Endif
#ADNGO - 2016-12-14 - X3-11347 - START
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] First
    Filter [HRCTR2]
    [M:DLS1]REFNUM = [F:HRCTR2]REFNUM
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:DLS1]LEG = GCURLEG
    Affzo [M:DLS1]LEG
    Endif
 #ADNGO - 2016-12-14 - X3-11347 - END
End

Subprog AS_DATPYR(VALEUR)
Variable Date    VALEUR
#Infbox "AS"
  If VALEUR = [00/00/0000] or VALEUR > eomonth(GMOIPAY)
    VALEUR = eomonth(GMOIPAY)
  Endif
  Gosub RECH_DAT_PAI
  GMESSAGE =""
  mkstat = 0

  If [M:DLS1]CTRNUM <> ""
  #ADNGO - 2016-12-09 - X3-11347 - START
   #[M:DLS1]CTRDAT = [F:CTR]CTRDAT
   [M:DLS1]CTRDAT = [F:HRCTR]CTRDAT
  #ADNGO - 2016-12-09 - X3-11347 - END
   Affzo [M:DLS1]CTRDAT
  Endif

End

$RECH_DAT_PAI
Local Date    CRITDAT

  [L]CRITDAT = VALEUR
  #ADNGO - 2016-12-09 - X3-11347 - START
  #Call CADRE_PYRDAT(VALEUR,[F:CTR]ETRFCY) From TPSSUB
  #Call CADRE_PYRDAT(VALEUR,[F:HRCTR]ETRFCY) From TPSSUB

  Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
  #ADNGO - 2016-12-09 - X3-11347 - END

  I=0
  While VALEUR > [L]CRITDAT & !mkstat
    I+=1
    VALEUR = [L]CRITDAT - I
    #ADNGO - 2016-12-09 - X3-11347 - START
    #Call CADRE_PYRDAT(VALEUR,[F:CTR]ETRFCY) From TPSSUB
    #Call CADRE_PYRDAT(VALEUR,[F:HRCTR]ETRFCY) From TPSSUB
    Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
    #ADNGO - 2016-12-09 - X3-11347 - END
  Wend

Return

Subprog C_DATPYR(VALEUR)
Variable Date    VALEUR

#JASMI - 2016-08-18 - X3PEOP-1288 - START
  Raz [M:DLS1]CURBUL, [M:DLS1]PREBUL
#JASMI - 2016-08-18 - X3PEOP-1288 - END

#JASMI - 2016-08-18 - X3PEOP-1288 - START
#  Filter [VEP] Where [VEP]EMP    =  [M:DLS1]REFNUM
#&                  & [VEP]PYRDAT =  VALEUR
#&              Order By [VEP]BUL Desc

  Filter [VEP] Where [VEP]EMP    =  [M:DLS1]REFNUM
&                  & month([VEP]PYRDAT) =  month(VALEUR)
&                  & year([VEP]PYRDAT) =  year(VALEUR)
&              Order By [VEP]BUL Desc
#JASMI - 2016-08-18 - X3PEOP-1288 - END
  Read   [VEP] First
  Filter [VEP]
  If fstat
    mkstat = 1
    #ADNGO - 2016-12-12 - X3-11347 - START
    #GMESSAGE =mess(24,702,1)-num$(VALEUR) : # Paie non calculée au
    GMESSAGE =mess(24,10702,1)-num$(VALEUR) : # Paie non calculée au
    #ADNGO - 2016-12-12 - X3-11347 - END
    End
  Endif
  [M:DLS1]CURBUL=[VEP]BUL

#JASMI - 2016-08-18 - X3PEOP-1288 - START
#  Filter [VEP] Where [VEP]EMP    =  [M:DLS1]REFNUM
#&                  & [VEP]PYRDAT <  VALEUR
#&              Order By [VEP]BUL Desc
  Filter [VEP] Where [VEP]EMP    =  [M:DLS1]REFNUM
&                  & month([VEP]PYRDAT) =  month(addmonth(VALEUR,-1))
&                  & year([VEP]PYRDAT) =  year(addmonth(VALEUR,-1))
&              Order By [VEP]BUL Desc
#JASMI - 2016-08-18 - X3PEOP-1288 - END
  Read   [VEP] First
  Filter [VEP]
  If fstat
    End
  Endif
  [M:DLS1]PREBUL =[VEP]BUL
#Infbox "C"
  Gosub RECH_DAT_PAI
  If mkstat : End : Endif
  #ADNGO - 2016-12-09 - X3-11347 - START
    #[M:DLS1]WDATDEB = [F:PEO]PERSTR(0)
    [M:DLS1]WDATDEB = [F:HRPEOD]PERSTR(0)
  #ADNGO - 2016-12-09 - X3-11347 - END

End

Subprog AM_DATPYR(VALEUR)
Variable Date    VALEUR

  Call SELCTR([M:DLS1]REFNUM,VALEUR,[M:DLS1]WDATDEB,[M:DLS1]CTRNUM) From DIVPAYE
  If [M:DLS1]CTRNUM <> ""
   #ADNGO - 2016-12-09 - X3-11347 - START
    #[M:DLS1]CTRDAT = [F:CTR]CTRDAT
    [M:DLS1]CTRDAT = [F:HRCTR]CTRDAT
   #ADNGO - 2016-12-09 - X3-11347 - END
  Else
  #ADNGO - 2016-12-09 - X3-11347 - START
    #Raz [F:CTR]
    Raz [F:HRCTR]
  #ADNGO - 2016-12-09 - X3-11347 - END
    Raz [M:DLS1]CTRDAT
  Endif
  Affzo [M:DLS1]CTRNUM

End


######################################################################################

