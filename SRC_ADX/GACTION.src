Variable Decimal VALEUR()
Variable Char    PARAM()(1..)
Value    Char    TRAIT
Value    Char    PROG
Value    Char PROGSPP
Local Integer TYPARG : TYPARG = 2
Goto S_AFF

Subprog S_AFF_DAT(VALEUR,PARAM,TRAIT,PROG,PROGSPP)
Variable Date    VALEUR()
Variable Char    PARAM()(1..)
Value    Char    TRAIT
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 3
Goto S_AFF

Subprog S_AFF_LIB(VALEUR,PARAM,TRAIT,PROG,PROGSPP)
Variable Integer VALEUR()
Variable Char    PARAM()(1..)
Value    Char    TRAIT
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 4
Goto S_AFF

Subprog S_AFF_BLOB(VALEUR,PARAM,TRAIT,PROG,PROGSPP)
Variable Blbfile VALEUR()
Variable Char    PARAM()(1..)
Value    Char    TRAIT
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 5
Goto S_AFF

Subprog S_AFF_CLOB(VALEUR,PARAM,TRAIT,PROG,PROGSPP)
Variable Clbfile VALEUR()
Variable Char    PARAM()(1..)
Value    Char    TRAIT
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 6
Goto S_AFF

#-----------------------------#
$S_AFF
Local Integer I , OK
Local Char    ACTION(20)
Local Char    WINPROG(GLONADC)
Local Integer PSPP

## Vérification des paramètres
Gosub VERIF
If !OK : End : Endif

Call NOMTRTWINOPT(GBOITE,WINPROG) From MSKDIV

ACTION = "TRT_DIV" : Gosub ACTION
If !GIMPORT : Gosub ERR From GSAISIE : Endif

End

