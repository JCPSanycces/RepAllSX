Onerrgo
GSTATUT = status*(ER=0)
currbox = SAVBOX

#-------------------------------#
$REPONSE
Case GSTATUT
 When 0
  If ER
   Call ERREUR(mess(33,100,1)+":\"+errmes$(ER)) From GESECRAN : # Erreur sur critère de sélection
  Else
   Call MESSAGE(mess(99,100,1)) From GESECRAN : # Pas de fiche sélectionnée
  Endif
  mkstat = 2
 When GSTASRA : # Sélection rapide
  Raz FILSUITE , IFILSUITE
  Gosub SELRAP
  ACTION = "BOUT_TABLE" : Gosub ACTION
  Goto SELECT
 When GSTAESC
  Raz [F]
  mkstat=2
 When GSTASVG : # Suivant
  OK = 1
  ACTION = "BOUT_TABLE" : Gosub ACTION
  If OK & (OBJET<>"" | DEFPAG)
   Call SUIGAUCHE(">",OBJET,ORDRE,SENS,CRITERE,CRITOBJ,CRITRAP,IFILSUITE,FILSUITE,OK)
  Endif
  If OK : EXPSTART = "1=1" : Endif
  CRITCAR = "1=1"
  Goto SELECT
 When GSTAPRG : # Précédent
  OK = 1
  ACTION = "BOUT_TABLE" : Gosub ACTION
  If OK & (OBJET<>"" | DEFPAG)
   Call SUIGAUCHE("<",OBJET,ORDRE,SENS,CRITERE,CRITOBJ,CRITRAP,IFILSUITE,FILSUITE,OK)
  Endif
  If OK : EXPSTART = "1=1" : Endif
  CRITCAR = "1=1"
  Goto SELECT
 When Default : # Sélection
  If OBJET<>""
   Gosub VERF_SEL
   If !OK : Goto SELECT : Endif
  Endif
  Onerrgo SELECT_ERR :  # <MG> 10/07/00
  Read [F] =
  Onerrgo            :  # <MG> 10/07/00
  GERR = 0
  # Ne pas tester le fstat car pb sur les tables liées
  ACTION = "VERF_TABLE" : Gosub ACTION
  If GERR
   Gosub ERR From GSAISIE
  Else
   Onerrgo RIEN
   If !find(type([L]VALEUR),522,523)
    If find(left$(START,3),"[F]","[F:")
     [L]VALEUR = evalue(START)
    Elsif left$(START,1)="["
     [L]VALEUR = evalue("[F:"+right$(START,2))
    Elsif START<>""
     [L]VALEUR = evalue("[F]"+START)
    Endif
   Endif
   Onerrgo
  Endif
Endcase
If dim(SAVFCY)>0 : GFCY=SAVFCY : Endif
If dim(SAVDEP)>0 : GDEP=SAVDEP : Endif
ACTION = "FIN_TABLE" : Gosub ACTION
adxmxl = SAVMXL
End

$SELECT_ERR : # <MG> 10/07/00
Resume      : # <MG> 10/07/00

#--------------------------------------------#
$VERF_SEL
OK = 1
Gosub DEFAUT_LISTE From =PROGOBJ
If dim([L]CLEVALEUR)>0 : ## GEODE
 If CLEFCY<>"" & GFCY<>""
  Assign "[F:"+ABFIC+"]"+CLEFCY With GFCY
 Endif
 If CLEDEP<>"" & GDEP<>""
  Assign "[F:"+ABFIC+"]"+CLEDEP With GDEP
 Endif
 GMESSAGE=""
 For I=0 To dim(CLESUPP)-1
  If CLESUPP(I)<>"" & VALSUPP(I)<>""
&  & !instr(1,[L]CRITOBJ,'[F:'+ABFIC+']'+CLESUPP(I)+'=')
&  & num$(evalue("[F]"+CLESUPP(I)))<>VALSUPP(I)
   Call TEXTFIC(NOMFIC,CLESUPP(I),1,NOMZON) From OBJDIV
   If GMESSAGE<>"" : GMESSAGE+="\" : Endif
   GMESSAGE+=NOMZON-"<>"
   Case evalue("type([F:"+ABFIC+"]"+CLESUPP(I)+")")
    When 1,2,4,5,6,7,8,9
     GMESSAGE -= VALSUPP(I)
    When 3
     GMESSAGE -= "["+format$(GFMD,gdat$(VALSUPP(I)))+"]"
    When Default
     GMESSAGE -= "'"+VALSUPP(I)+"'"
   Endcase
  Endif
 Next I
 If GMESSAGE<>""
  Call ERREUR(GMESSAGE) From GESECRAN
  GMESSAGE="" : OK = 0 : Return
 Endif
Elsif CLESEC<>"" & SUPP<>""
& & !instr(1,[L]CRITOBJ,'[F:'+ABFIC+']'+CLESEC+'=')
& & num$(evalue("[F:"+ABFIC+"]"+CLESEC))<>SUPP
 Call TEXTFIC(NOMFIC,CLESEC,1,GMESSAGE) From OBJDIV
 GMESSAGE-="<>"
 Case evalue("type([F:"+ABFIC+"]"+CLESEC+")")
  When 1,2,4,5,6,7,8,9
   GMESSAGE -= SUPP
  When 3
   GMESSAGE -= "["+format$(GFMD,gdat$(SUPP))+"]"
  When Default
   GMESSAGE -= "'"+SUPP+"'"
 Endcase
Endif
Assign "[G:"+ABFIC+"]currind" With 1
If TYPGES<>3
 Assign "[G:"+ABFIC+"]currlen" With 0
Elsif !(dim(CLEVALEUR)>0 & CLEVALEUR=CLELIG)
 Assign "[G:"+ABFIC+"]currlen" With dim(CLESEC)
Endif
Return

#--------------------------------------------#
$SELRAP
Raz CRITRAP , ICRITRAP
GPE =0
GPOINT = "SELRAP" : Gosub ENTREE From EXEFNC : # mb 28.5.8 demande 47600/47597
If GPE : Return : Endif
For I=1 To NBCOL
 If [L]SAIRAP(I)<>""
  Raz T, CRIRAP, NOLIB
  Onerrgo ERRRAP
  RAPVAR = COL(I)
  If (COLTYP(I)=1 | COLTYP(I)=0) & left$(COL(I),4) = "mess"
   T = 1
   J = instr(1,COL(I),"(")
   K = instr(1,COL(I),",")
   RAPVAR = seg$(COL(I),J+1,K-1)
   J = instr(K+1,COL(I),",")
   NOLIB = val(seg$(COL(I),K+1,J-1))
  Elsif COLTYP(I)<>0
   T = COLTYP(I)
  Else
   If left$(COL(I),1) = "["
    T = evalue("type("+COL(I)+")")
   Elsif evalue("dim([F]"+COL(I)+")")>0
    T = evalue("type([F]"+COL(I)+")")
   Else
    T = evalue("type("+COL(I)+")")
   Endif
  Endif
  Onerrgo
  If T=0 & OBJET<>""
&  & (format$("KTv2:250X",SELEXP(I))=format$("KTv2:250X",COL(I))
&  |  format$("KTv2:250X",TRIZON(I))=format$("KTv2:250X",COL(I)))
   Case SELTYP(I)
    When 1       : T = 1  : NOLIB = val(right$(SELFMT(I),3))
    When 7       : T = 11
    When 8       : T = 3
    When Default : T = 2
   Endcase
  Endif
  SIGRAP = ""
  REFRAP = [L]SAIRAP(I)
  For J=1 To 2
   If find(mid$([L]SAIRAP(I),J,1),"=",">","<")
    SIGRAP += mid$([L]SAIRAP(I),J,1)
    REFRAP = right$([L]SAIRAP(I),J+1)
   Endif
  Next J
  Case T
   When 0
   When 1
    If SIGRAP="" : SIGRAP = "=" : Endif
    If num$(val(REFRAP))=REFRAP & REFRAP>="0" & REFRAP<="999"
     CRIRAP = RAPVAR+SIGRAP+REFRAP
    Else
     For J=1 To len(mess(0,NOLIB,1))
      K = 0
      If instr(1,REFRAP,"*") or instr(1,REFRAP,"?")
       If pat(toupper(ctrans(mess(J,NOLIB,1))),toupper(ctrans(REFRAP)))
        K = 1
       Endif
      Else
       If evalue("left$(toupper(ctrans(mess(J,NOLIB,1))),len(REFRAP))"+SIGRAP+"toupper(ctrans(REFRAP))")
        K = 1
       Endif
      Endif
      If K & len(CRIRAP)<200
       If CRIRAP=""
        CRIRAP = "("
       Else
        CRIRAP += "|"
       Endif
       CRIRAP += RAPVAR+"="+num$(J)
      Endif
     Next J
     If CRIRAP<>""
      CRIRAP += ")"
     Else
      CRIRAP = RAPVAR+SIGRAP+"9999" : # Critère incorrect : la sélection ne ramènera rien
     Endif
    Endif
   When 2,4,5,6,7,8,9
    REFRAP = ctrans(REFRAP,",",".")
    If val(REFRAP)<>0
     If SIGRAP="" : SIGRAP = "=" : Endif
     CRIRAP = RAPVAR+SIGRAP+REFRAP
    Endif
   When 3
    GERR = 0
    Call CHARGE(REFRAP,"D",0,0,RAPCAR) From FMTVAR
    If GERR
     Call ERREUR(GMESSAGE) From GESECRAN
     Raz GMESSAGE
    Else
     Onerrgo RIEN
     RAPDAT = RAPCAR
     Onerrgo
     If RAPDAT<>[0/0/0]
      If SIGRAP="" : SIGRAP = "=" : Endif
      CRIRAP = RAPVAR+SIGRAP+'['+format$(GFMD,RAPDAT)+']'
     Endif
    Endif
   When Default
    RAPCAR = REFRAP
    J = instr(1,RAPVAR,"+")
    K = instr(1,RAPVAR,"-")
    If J=0 & K<>0
     RAPVAR = left$(RAPVAR,K-1)
    Elsif J<>0 & K=0
     RAPVAR = left$(RAPVAR,J-1)
    Elsif J<>0 & K<>0
     RAPVAR = left$(RAPVAR,min(J,K)-1)
    Endif
    If dim([V]GCASSE)>0 & GCASSE=1
     RAPCAR = toupper(RAPCAR)
     RAPVAR = "toupper("+RAPVAR+")"
    Endif
    K = instr(1,RAPCAR,'"')
    J = instr(1,RAPCAR,"'")
    If K & J
     Repeat
      K = instr(1,RAPCAR,'"')
      If K : RAPCAR = left$(RAPCAR,K-1)+right$(RAPCAR,K+1) : Endif
     Until K=0
    Elsif K
     CAR = "'"
    Else
     CAR = '"'
    Endif
    If RAPCAR<>""
     Case left$(SIGRAP,1)
      When ">","<"
       CRIRAP = RAPVAR+SIGRAP+CAR+RAPCAR+CAR
      When Default
       J = instr(1,RAPCAR,"*")
       K = instr(1,RAPCAR,"?")
       If J or K
        If K or J<>len(RAPCAR)
         If instr(1,RAPVAR,"string$") & 1=0 : # mb 5.5.9 bug 54938/mb 10.11.9 bug 59771
          # Erreur sur critère de sélection
          # Du fait du type de cette colonne vous ne pouvez utiliser qu'un seul joker '*' en fin de chaîne
          Call ERREUR(mess(33,100,1)+":\"+mess(275,139,1)) From GESECRAN
          Raz CRITRAP , ICRITRAP : Break
         Endif
         CRIRAP = 'pat('+RAPVAR
         If !instr(1,RAPVAR,"(") : CRIRAP += '(0)' : Endif
         If CAR='"'
          CRIRAP += ',"'+RAPCAR+'")=1'
         Else
          CRIRAP += ",'"+RAPCAR+"')=1"
         Endif
        Endif
        If     J & K : J = min(J,K)
        Elsif !J & K : J = K
        Endif
        If J>1
         If CRIRAP<>"" : CRIRAP += "&" : Endif
         If CAR='"'
          CRIRAP += RAPVAR+'>="'+left$(RAPCAR,J-1)+'"'
          CRIRAP += "&"
          CRIRAP += RAPVAR+'<"'+left$(RAPCAR,J-2)+chr$(ascii(mid$(RAPCAR,J-1,1))+1)+'"'
         Else
          CRIRAP += RAPVAR+">='"+left$(RAPCAR,J-1)+"'"
          CRIRAP += "&"
          CRIRAP += RAPVAR+"<'"+left$(RAPCAR,J-2)+chr$(ascii(mid$(RAPCAR,J-1,1))+1)+"'"
         Endif
        Endif
       Else
        If CAR='"'
         CRIRAP = RAPVAR+'="'+RAPCAR+'"'
        Else
         CRIRAP = RAPVAR+"='"+RAPCAR+"'"
        Endif
       Endif
     Endcase
    Endif
  Endcase
  Call ADDCRIT(CRITRAP,ICRITRAP,"CRITRAP",CRIRAP,"&") From GOBJSUB
 Endif
Next I
Return

$ERRRAP
T = 40
Resume

#---------------------------------------------------------------------------------------------#
Subprog SUIGAUCHE(SENS,OBJET,ORDRE,SNSLIS,CRITERE,CRITOBJ,CRITRAP,IFILSUITE,FILSUITE,OK)
Value    Char    SENS
Value    Char    OBJET
Value    Char    ORDRE
Value    Integer SNSLIS
Value    Char    CRITERE()(1..)
Value    Char    CRITOBJ()()
Value    Char    CRITRAP
Variable Integer IFILSUITE
Variable Char    FILSUITE()()
Variable Integer OK

Local Char    PROGOBJ(GLONADC)
Local Integer I , J , K , T , NBCLE
Local Char    VALC(80)(1..16) , ACTION(20)
Local Char    CLELIS(30)(1..16) , ASCDES(10) , CHAINE(250),CLELISORD(30)(1..16)
Local Char    ZONCLE(250) , ZONCLE2(250)
Local Integer ICRITBUF , IFILPREV , IFILSAV, DIMS , DIMB , PRE

DIMS = dim(FILSUITE)-1
DIMB = dim(CRITERE)+dim(CRITRAP)+dim(CRITOBJ)
Local Char    CRITBUF(250)(0..DIMB)
Local Char    FILTRE(250)(0..DIMS), FILSAV(250)(0..DIMS) , FILPREV(250)(0..DIMS)

If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub SET_FIRST From GOBJACT
Endif

If OBJET<>""
 PROGOBJ = "WO"+OBJET
 Gosub NOMFIC From =PROGOBJ
Endif

Raz CLELIS, NBCLE
CHAINE = ORDRE
While CHAINE<>""
 I = instr(1,CHAINE,";")
 NBCLE += 1
 If I
  CLELIS(NBCLE) = vireblc(left$(CHAINE,I-1),2)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLELIS(NBCLE) = vireblc(CHAINE,2)
  CHAINE = ""
 Endif
 K = instr(1,CLELIS(NBCLE)," ")
 If K
  For ASCDES = "desc", "asc"
   I = instr(K+1,tolower(CLELIS(NBCLE)),ASCDES)
   If I
    CLELIS(NBCLE) = vireblc(left$(CLELIS(NBCLE),I-1),2)
    CLELISORD(NBCLE) = ASCDES
   Endif
  Next ASCDES
 Endif
Wend
If SENS=">"
 IFILSAV = IFILSUITE
 For I=0 To dim(FILSUITE)-1
  FILSAV(I) = FILSUITE(I)
 Next I
Endif

Gosub FILSUITE

If OBJET<>""
 Gosub DEFAUT_LISTE From =PROGOBJ
Endif

Raz CRITBUF, ICRITBUF
For I=1 To dim(CRITERE)
 Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",CRITERE(I),"&") From GOBJSUB
Next I
For I=0 To dim(CRITOBJ)-1
 If I=0
  Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",CRITOBJ(I),"&") From GOBJSUB
 Else
  Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",CRITOBJ(I),"") From GOBJSUB
 Endif
Next I
Call ADDCRIT(CRITBUF,ICRITBUF,"CRITBUF",CRITRAP,"&") From GOBJSUB
If CRITBUF="" : CRITBUF = "1=1" : Endif
If SENS="<"
 If SNSLIS=2
  CHAINE = ORDRE
 Else
  Call CHANGE_SENS(ORDRE,CHAINE) From GOBJACT
 Endif
 If FILPREV="" : FILPREV = "1=1" : Endif
 Filter [F] Where evalue(CRITBUF) & evalue(FILPREV) Order With CHAINE
Else
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [F] Where evalue(CRITBUF) & evalue(FILSUITE) Order With ORDRE
Endif
K = 0
PRE = 0
If dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 For [F] Hint Key=""
  K += 1
  If K>adxmxl
   PRE = 1 : Break
  Elsif K=adxmxl & SENS=">"
   Break
  Endif
 Next
Else
 For [F]
  K += 1
  If K>adxmxl
   PRE = 1 : Break
  Elsif K=adxmxl & SENS=">"
   Break
  Endif
 Next
Endif
If SENS="<"
 If !PRE
  Raz FILSUITE, IFILSUITE
  FILSUITE = "1=1"
 Else
  Gosub FILSUITE
 Endif
Elsif !K : # pas d'enreg suivant
 IFILSUITE = IFILSAV
 For I=0 To dim(FILSUITE)-1
  FILSUITE(I) = FILSAV(I)
 Next I
 OK = 0
Endif
Filter [F]
If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 Gosub UNSET_FIRST From GOBJACT
Endif
End

$FILSUITE
Raz FILSUITE, FILPREV, IFILSUITE, IFILPREV
NBCLE = 0
For I=1 To dim(CLELIS)
 If CLELIS(I)="" : Break : Endif
 NBCLE += 1
 If instr(1,CLELIS(I),"]")
  ZONCLE = CLELIS(I)
 Elsif dim(ABFIC)>0 & ABFIC<>""
  ZONCLE = "[F:"+ABFIC+"]"+CLELIS(I)
 Else
  ZONCLE = "[F]"+CLELIS(I)
 Endif
 T = evalue("type("+ZONCLE+")")
 Case T
  When 1,2,4,5,6,7,8,9
   VALC(I) = num$(evalue(ZONCLE))
  When 3
   If evalue(ZONCLE)=[0/0/0]
    VALC(I) = '[0/0/0]'
   Else
    VALC(I) = '['+format$(GFMD,evalue(ZONCLE))+']'
   Endif
  When Default
   VALC(I) = evalue(ZONCLE)
   If instr(1,VALC(I),"'") & instr(1,VALC(I),'"')
    VALC(I) = ctrans(VALC(I),"'","&")
    VALC(I) = ctrans(VALC(I),'"',"!")
    VALC(I) = '"'+VALC(I)+'"'
   Elsif instr(1,VALC(I),'"') & !instr(1,VALC(I),"'")
    VALC(I) = "'"+VALC(I)+"'"
   Else
    VALC(I) = '"'+VALC(I)+'"'
   Endif
 Endcase
 If I=1
  If CLELISORD(I)="desc"
   FILSUITE = ZONCLE+"<"+VALC(I)
   FILPREV  = ZONCLE+">"+VALC(I)
  Else
   FILSUITE = ZONCLE+">"+VALC(I)
   FILPREV  = ZONCLE+"<"+VALC(I)
  Endif
 Else
  Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE","| (","") From GOBJSUB
  If FILSUITE="" : Break : Endif
  Call ADDCRIT(FILPREV,IFILPREV,"FILPREV","| (","") From GOBJSUB
  If FILPREV="" : Break : Endif
  For J=1 To I-1
   If instr(1,CLELIS(J),"]")
    ZONCLE2 = CLELIS(J)+"="+VALC(J)
   Elsif dim(ABFIC)>0 & ABFIC<>""
    ZONCLE2 = "[F:"+ABFIC+"]"+CLELIS(J)+"="+VALC(J)
   Else
    ZONCLE2 = "[F]"+CLELIS(J)+"="+VALC(J)
   Endif
   Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE2-"& ","") From GOBJSUB
   If FILSUITE="" : Break 2 : Endif
   Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE2-"& ","") From GOBJSUB
   If FILPREV="" : Break 2 : Endif
  Next J
  If CLELISORD(I)="desc"
   Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE+"<"+VALC(I)+")","") From GOBJSUB
   If FILSUITE="" : Break : Endif
   Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE+">"+VALC(I)+")","") From GOBJSUB
   If FILPREV="" : Break : Endif
  Else
   Call ADDCRIT(FILSUITE,IFILSUITE,"FILSUITE",ZONCLE+">"+VALC(I)+")","") From GOBJSUB
   If FILSUITE="" : Break : Endif
   Call ADDCRIT(FILPREV,IFILPREV,"FILPREV",ZONCLE+"<"+VALC(I)+")","") From GOBJSUB
   If FILPREV="" : Break : Endif
  Endif
 Endif
Next I
If    FILSUITE="" : Raz FILPREV
Elsif FILPREV=""  : Raz FILSUITE
Endif
If SNSLIS=2
 For I=0 To dim(FILSUITE)-1
  FILTRE(I)   = FILSUITE(I)
  FILSUITE(I) = FILPREV(I)
  FILPREV(I)  = FILTRE(I)
 Next I
Endif
Return

#--------------------------------------------#
$ACTION
GPE = 0
If dim(PSPP)>0 & PSPP
 Gosub ACTION From =PROGSPP
Endif
If !GPE & dim(PROG)>0 & PROG<>""
 Gosub ACTION From =PROG
Endif
Return

#--------------------------------------------#
$VERIF
OK = 1
PSPP = 0
If PROGSPP<>""
 Call EXISTE_ADX("","",PROGSPP,PSPP) From ORDSYS
Endif
Return

#-------------------------------------------------------------------------------#
## Sélection dans une liste
#-------------------------------------------------------------------------------#

Subprog S_LIS_CHAR(VALEUR,PARAM,LISTE,PROG,PROGSPP)
Variable Char VALEUR()
Variable Char PARAM()(1..)
Value    Char LISTE
Value    Char PROG
Value    Char PROGSPP
Local Integer TYPARG : TYPARG = 1
Goto S_LIS

Subprog S_LIS_NUM(VALEUR,PARAM,LISTE,PROG,PROGSPP)
Variable Decimal VALEUR()
Variable Char    PARAM()(1..)
Value    Char    LISTE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 2
Goto S_LIS

Subprog S_LIS_DAT(VALEUR,PARAM,LISTE,PROG,PROGSPP)
Variable Date VALEUR()
Variable Char PARAM()(1..)
Value    Char LISTE
Value    Char PROG
Value    Char PROGSPP
Local Integer TYPARG : TYPARG = 3
Goto S_LIS

Subprog S_LIS_LIB(VALEUR,PARAM,LISTE,PROG,PROGSPP)
Variable Integer VALEUR()
Variable Char    PARAM()(1..)
Value    Char    LISTE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 4
Goto S_LIS

Subprog S_LIS_BLOB(VALEUR,PARAM,LISTE,PROG,PROGSPP)
Variable Blbfile VALEUR()
Variable Char    PARAM()(1..)
Value    Char    LISTE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 5
Goto S_LIS

Subprog S_LIS_CLOB(VALEUR,PARAM,LISTE,PROG,PROGSPP)
Variable Clbfile VALEUR()
Variable Char    PARAM()(1..)
Value    Char    LISTE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 6
Goto S_LIS

#---------------------------------#
$S_LIS
Local Integer  NBTEX , I , CHOIX , OK , FORCE , NBCOL
Local Char     TEX(50)(0..200) , TEXTE(80)(0..200)
Local Char     TIT(50)(0..5) , ACTION(20)
Local Integer  PSPP

## Vérification des paramètres
Gosub VERIF
If !OK : End : Endif

NBTEX = 0 : FORCE = 0
ACTION = "SEL_LISTE" : Gosub ACTION

Onerrgo ERDIM
NBCOL = dim(TEXTE,2)
Onerrgo

For I=1 To NBTEX
 If NBCOL
  Onerrgo RIEN
  If TEXTE(I,1)="" : TEXTE(I,1) =  TEX(I) : Endif
  Onerrgo
 Else
  If TEXTE(I)="" : TEXTE(I) = TEX(I) : Endif
 Endif
Next I
If NBTEX=0
 If GERR
  Gosub ERR From GSAISIE
 Endif
 End
Elsif NBTEX=1 & !FORCE
 Case TYPARG
  When 1   : VALEUR = TEX(1)
  When 2,4 : VALEUR = val(TEX(1))
  When 3   : Onerrgo RIEN : VALEUR = gdat$(TEX(1)) : Onerrgo
 Endcase
 GERR = 0
 CHOIX = 1
 GSTATUT = 28
 ACTION = "VERF_LISTE" : Gosub ACTION
 If GERR
  Gosub ERR From GSAISIE
 Endif
Else
 CHOIX = find(num$(VALEUR),TEX(1..NBTEX))
 If CHOIX=0 : CHOIX=1 : Endif
 If NBCOL
  If dim(SIZCOL)>0 or dim(SIZLIG)>0
   Call SAITEX_COL_MAX(NBTEX,TEXTE,CHOIX,TIT,SIZCOL,SIZLIG) From GESECRAN
  Else
   Call SAITEX_COL(NBTEX,TEXTE,CHOIX,TIT) From GESECRAN
  Endif
 Else
  Call SAITEX(NBTEX,TEXTE,CHOIX,TIT) From GESECRAN
 Endif
 GSTATUT = status
 If status<>7 & CHOIX<>0
  Case TYPARG
   When 1   : VALEUR = TEX(CHOIX)
   When 2,4 : VALEUR = val(TEX(CHOIX))
   When 3   : Onerrgo RIEN : VALEUR = gdat$(TEX(CHOIX)) : Onerrgo
  Endcase
  GERR = 0
  ACTION = "VERF_LISTE" : Gosub ACTION
  If GERR
   Gosub ERR From GSAISIE
  Endif
 Else
  mkstat = 2
 Endif
Endif
ACTION = "FIN_LISTE" : Gosub ACTION
End

$RIEN
Resume

$ERR
ER = errn
Resume

$ERDIM
NBCOL = 0
Resume

