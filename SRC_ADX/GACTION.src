#<AdxTL>@(#)9.0.0.0 $Revision$
Close Local File
Local Char VALEUR(255), PARAM(255)(1..20)
Call S_TAB_CHAR(VALEUR,PARAM,"GACSELSHO","SUBGAC","")
End

#--------------------------------------------------------------------------#
## Sélection dans une table
#--------------------------------------------------------------------------#

Subprog S_TAB_CHAR(VALEUR,PARAM,TABLE,PROG,PROGSPP)
Variable Char VALEUR()
Variable Char PARAM()(1..)
Value    Char TABLE
Value    Char PROG
Value    Char PROGSPP
Local Integer TYPARG : TYPARG = 1
Goto S_TAB

Subprog S_TAB_NUM(VALEUR,PARAM,TABLE,PROG,PROGSPP)
Variable Decimal VALEUR
Variable Char    PARAM()(1..)
Value    Char    TABLE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 2
Goto S_TAB

Subprog S_TAB_DAT(VALEUR,PARAM,TABLE,PROG,PROGSPP)
Variable Date VALEUR()
Variable Char PARAM()(1..)
Value    Char TABLE
Value    Char PROG
Value    Char PROGSPP
Local Integer TYPARG : TYPARG = 3
Goto S_TAB

Subprog S_TAB_LIB(VALEUR,PARAM,TABLE,PROG,PROGSPP)
Variable Integer VALEUR()
Variable Char    PARAM()(1..)
Value    Char    TABLE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 4
Goto S_TAB

Subprog S_TAB_BLOB(VALEUR,PARAM,TABLE,PROG,PROGSPP)
Variable Blbfile VALEUR
Variable Char    PARAM()(1..)
Value    Char    TABLE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 5
Goto S_TAB

Subprog S_TAB_CLOB(VALEUR,PARAM,TABLE,PROG,PROGSPP)
Variable Clbfile VALEUR
Variable Char    PARAM()(1..)
Value    Char    TABLE
Value    Char    PROG
Value    Char    PROGSPP
Local Integer TYPARG : TYPARG = 6
Goto S_TAB

#-----------------------#
$S_TAB
Local Char    CRITERE(250)(1..7) , CRITRAP(250) , CRITOBJ(250)(0..1) , FILSUITE(250)(0..5)
Local Char    FILROLE(250)(0..5)
Local Char    CRITCAR(250) , CAR(1)
Local Integer ICRITERE , ICRITRAP , ICRITOBJ , IFILSUITE , ICRITCAR , IFILROLE
Local Char    CRIRAP(250) , RAPVAR(50) , RAPCAR(50) , REFRAP(50) , SIGRAP(2)
Local Date    RAPDAT
Local Char    ORDRE(250) , ORDTRI(250) , ORDCHO(250)
Local Integer MAXCOL : MAXCOL = 16
Local Char    COL(250)(1..MAXCOL) , TIT(50)(0..MAXCOL)
Local Schar   FMTCOL(30)(1..MAXCOL)
Local Integer COLTYP(1..MAXCOL)
Local Char    SAIRAP(30)(1..MAXCOL)
Local Char    START(250) , OBJET(GLONAOB) , SUPP(250)(16) , OPTIONS(20) , ACTION(20)
Local Char    EXPSTART(250)
Local Integer NBCOL , OK , SENS , SIZCOL , SIZLIG , SAVMXL
Local Char    VALCHAR(250)
Local Decimal VALNUM
Local Date    VALDAT
Local Integer I , J , K , T , ER , NOLIB , DEFPAG
Local Integer OUVRE , FILT
Local Char    SAVBOX(20)
Local Char    OPER(2)
Local Integer FIXSUPP
Local Char    VALSUPP(GLONID2)(0..16), NOMZON(30) , CHAINE(250)
Local Integer PSPP
Local Integer PSUB, PSPE, PSTD, PSPV
Local Char    PROGOBJ(GDIMFIC) , PROGSUB(GDIMFIC) , PROGSPE(GDIMFIC) , PROGSPV(GDIMFIC)(1..50)
Local Integer COL1
Local Char    V_OPE(1) :#121907

## Vérification des paramètres
Gosub VERIF
If !OK : End : Endif

SAVBOX = currbox
SIZCOL = 240
SIZLIG = 80
SAVMXL = adxmxl
adxmxl = GNBSEL
FIXSUPP= 1
COL1   = 1

OK = 1
ACTION = "SEL_TABLE" : Gosub ACTION
If !OK : End : Endif

If OBJET<>""

 Call SETPROG(OBJET,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
 If !PSTD : End : Endif

 Call TITOBJ(OBJET,"!",TIT(0)) From CONTOBJ
 TIT(0)  = mess(12,123,1)-TIT(0) : # Choix
 Gosub NOMFIC From =PROGOBJ
 Gosub SETCLE From =PROGOBJ
 If SENS=0 : SENS = SELORD : Endif
 If dim(SELIND)>0 & SELIND<>"" & ORDRE=""
  ORDRE = SELIND : # mb 16.10.2 bug 16154
 Endif
 I = instr(1,OPTIONS,"$")
 If I
  OUVRE = 1
  OPTIONS = left$(OPTIONS,I-1)+right$(OPTIONS,I+1)
 Endif
 I = instr(1,OPTIONS,"#")
 If I
  FILT = 0
 Else
  FILT = 1
 Endif

 If find(OBJET,"CPY","FCY") & dim(GGRPFCY)>0 & GGRPFCY<>""
  If OBJET="CPY"
   If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
   If clalev([F:AGC])=0 : Local File AGRPCPY [AGC]  : Endif
   Link [CPY] With [AGC]AGC0~=GGRPFCY;[F:CPY]CPY As [CPY_]
   Default File [CPY_]
   START = "[CPY]CPY"
  Elsif OBJET="FCY"
   If ZSITE<>""
    Local File FACILITY [FCY], COMPANY  [CPY3], FACGROUP [FGR], AFCTFCY  [AFF]
    Link [FCY] With [AFF]AFF0~=[F:FCY]FCY;GPROFIL;GUSRFCT, [FGR]FGR0~=GGRPFCY;[F:FCY]FCY, [CPY3]CPY0=[F:FCY]LEGCPY As [FCY_]
   Else
    Local File FACILITY [FCY], COMPANY  [CPY3], FACGROUP [FGR]
    Link [FCY] With [FGR]FGR0~=GGRPFCY;[F:FCY]FCY, [CPY3]CPY0=[F:FCY]LEGCPY As [FCY_]
   Endif
   Default File [FCY_]
   ORDRE = "[F:FCY]FCY"
   START = "[F:FCY]FCY"
  Endif
 Elsif find(OBJET,GABRCPT(1..GNBTABCPT)) & GDOSCPT<>""
  If clalev([F:ATX]) : Close Local File [ATX] : Endif

  If clalev([F:AXX])  : Close Local File [AXX] : Endif
  If clalev([F:AX1])  : Close Local File [AX1] : Endif
  If clalev([F:AX2])  : Close Local File [AX2] : Endif
  If clalev([F:AX3])  : Close Local File [AX3] : Endif
  If clalev([F:AXX1]) : Close Local File [AXX1] : Endif
  If clalev([F:AXX2]) : Close Local File [AXX2] : Endif
  If clalev([F:AXX3]) : Close Local File [AXX3] : Endif

  Local File =GTABCPT+"ACCES"  [ACC] : # Pour le link dans OUVRE_LISTE : même base
  Local File =GTABCPT+"ATEXTE" [ATX] : # Pour avoir les bons textes dans le titre des colonnes

  Local File =GTABCPT+"ATEXTRA" [AXX]
  Local File =GTABCPT+"ATEXTRA" [AX1]
  Local File =GTABCPT+"ATEXTRA" [AX2]
  Local File =GTABCPT+"ATEXTRA" [AX3]
  Local File =GTABCPT+"ATEXTRA" [AXX1]
  Local File =GTABCPT+"ATEXTRA" [AXX2]
  Local File =GTABCPT+"ATEXTRA" [AXX3]

  Local File =GTABCPT+NOMFIC
  Gosub OUVFIC_LISTE From =PROGOBJ
 Else
  If OUVRE or evalue("clalev([F:"+ABFIC+"])")=0
   Gosub OUVFIC From =PROGOBJ
   Gosub OUVFIC_LISTE From =PROGOBJ
  Endif
 Endif
 Gosub OUVRE_LISTE From =PROGOBJ

 If dim([L]CLEVALEUR)<0
  If ORDRE=""
   If instr(1,OPTIONS,"|")
    ORDRE = '[F:'+ABFIC+']'+CLESEC+';'+'[F:'+ABFIC+']'+CLEPRIM
   Else
    ORDRE = '[F:'+ABFIC+']'+CLEPRIM
    If CLESEC<>""
     ORDRE += ';[F:'+ABFIC+']'+CLESEC
    Endif
   Endif
   For I=1 To dim(CLESEC)-1
    If CLESEC(I)<>"" & CLESEC(I)<>CLELIG
     ORDRE += ';[F:'+ABFIC+']'+CLESEC(I)
    Endif
   Next I
  Endif
  If FIXSUPP & !instr(1,OPTIONS,"|")
   For I=0 To dim(CLESEC)-1
    If CLESEC(I)<>"" & SUPP(I)<>""
     Case evalue("type([F:"+ABFIC+"]"+CLESEC(I)+")")
      When 1,2,4,5,6,7,8,9
       Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLESEC(I)+'='+SUPP(I),"&") From GOBJSUB
     When 3
       Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLESEC(I),"&") From GOBJSUB
       If instr(1,SUPP(I),"/")
        Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'['+SUPP(I)+']',"=") From GOBJSUB
       Elsif SUPP(I)="00000000"
        Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[0/0/0]',"=") From GOBJSUB
       Else
        Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'['+format$(GFMD,gdat$(SUPP(I)))+']',"=") From GOBJSUB
       Endif
     When Default
       Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLESEC(I)+'="'+SUPP(I)+'"',"&") From GOBJSUB
     Endcase
    Endif
   Next I
  Endif
 Else : ## GEODE
  Call SUPPN(SUPP,VALSUPP) From CONTOBJ
  J = sigma(1,len(SUPP),mid$(SUPP,indcum,1)="~")
  If !J & SUPP<>"" : J = 1 : Elsif J : J += 1 : Endif
  K = (ORDRE="")
  For I=0 To dim(CLESUPP)-1
   If CLESUPP(I)<>""
    If I<=J-1
     If FIXSUPP
      Case evalue("type([F:"+ABFIC+"]"+CLESUPP(I)+")")
       When 1,2,4,5,6,7,8,9
        Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLESUPP(I)+'='+VALSUPP(I),"&") From GOBJSUB
       When 3
        Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLESUPP(I),"&") From GOBJSUB
        If instr(1,VALSUPP(I),"/")
         Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'['+VALSUPP(I)+']',"=") From GOBJSUB
        Elsif VALSUPP(I)="00000000"
         Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[0/0/0]',"=") From GOBJSUB
        Else
         Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'['+format$(GFMD,gdat$(VALSUPP(I)))+']',"=") From GOBJSUB
        Endif
       When Default
        Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLESUPP(I)+'="'+VALSUPP(I)+'"',"&") From GOBJSUB
      Endcase
     Endif
    Elsif K & (TYPGES<>3 | CLESUPP(I)<>CLELIG)
     ORDRE += '[F:'+ABFIC+']'+CLESUPP(I)+";"
    Endif
   Endif
  Next I
  If K
   ORDRE += '[F:'+ABFIC+']'+CLEVALEUR
   If TYPGES=3 & (evalue("type([F:"+ABFIC+"]"+CLELIG+")")>=10
&              |  evalue("type([F:"+ABFIC+"]"+CLELIG+")")=3)
    ORDRE+=';[F:'+ABFIC+']'+CLELIG
   Endif
  Endif
  K = NBCOL
  If CLEFCY<>""
   If dim([M]FCY)>0
    Local Char SAVFCY(GLONFCY)
    SAVFCY = GFCY
    If dim([M]FCY)>1 : GFCY = [M]FCY(nolign-1)
    Else             : GFCY = [M]FCY
    Endif
   Endif
   If GFCY<>""
    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLEFCY+'="'+GFCY+'"',"&") From GOBJSUB
   Elsif !find("[F:"+ABFIC+"]"+CLEFCY,SELZON(1..NBSEL))
    NBCOL += 1 : COL(NBCOL) = "[F:"+ABFIC+"]"+CLEFCY
    TIT(NBCOL) = mess(1,310,1) : # Site
    COL1 += 1
   Endif
  Endif
  If CLEDEP<>""
   If dim([M]DEP)>0
    Local Char SAVDEP(GLONDEP)
    SAVDEP = GDEP
    If dim([M]DEP)>1 : GDEP = [M]DEP(nolign-1)
    Else             : GDEP = [M]DEP
    Endif
   Endif
   If GDEP<>""
    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLEDEP+'="'+GDEP+'"',"&") From GOBJSUB
   Elsif !find("[F:"+ABFIC+"]"+CLEDEP,SELZON(1..NBSEL))
    NBCOL += 1 : COL(NBCOL) = "[F:"+ABFIC+"]"+CLEDEP
    TIT(NBCOL) = mess(2,310,1) : # Déposant
    COL1 += 1
   Endif
  Endif
  For I=NBCOL To K+1 Step -1
   ORDRE=COL(I)+";"+ORDRE
  Next I
 Endif

 # Filtre sur les n premiers caractères
 If dim(SELCAR)>0 & SELCAR<>0
  CHAINE = ""
  If dim([L]CLEVALEUR)<0
   If instr(1,OPTIONS,"|") & CLESEC<>""
    If evalue("type([F:"+ABFIC+"]"+CLESEC+')')>10
     CHAINE = '[F:'+ABFIC+']'+CLESEC+'>="'+left$(SUPP,SELCAR)+'"'
    Elsif find(evalue("type([F:"+ABFIC+"]"+CLESEC+')'),1,2,4,5,6,7,9)
     CHAINE = 'left$(num$([F:'+ABFIC+']'+CLESEC+'),'+num$(SELCAR)+')>="'+left$(SUPP,SELCAR)+'"'
    Endif
   Elsif !find(type(VALEUR),522,523)
    If evalue("type([F:"+ABFIC+"]"+CLEPRIM+')')>10 & type(VALEUR)>10
     CHAINE = '[F:'+ABFIC+']'+CLEPRIM+'>="'+left$(VALEUR,SELCAR)+'"'
    Elsif find(evalue("type([F:"+ABFIC+"]"+CLEPRIM+')'),1,2,4,5,6,7,9) & type(VALEUR)>10
     I = len(num$(int(val(VALEUR))))
     If I>SELCAR
      CHAINE = '[F:'+ABFIC+']'+CLEPRIM+'>='
      CHAINE += num$(val(left$(VALEUR,SELCAR))*10^(I-SELCAR))
     Endif
    Elsif find(evalue("type([F:"+ABFIC+"]"+CLEPRIM+')'),1,2,4,5,6,7,9) & find(type(VALEUR),1,2,4,5,6,7,9)
     I = len(num$(int(VALEUR)))
     If I>SELCAR
      CHAINE = '[F:'+ABFIC+']'+CLEPRIM+'>='
      CHAINE += num$(val(left$(num$(VALEUR),SELCAR))*10^(I-SELCAR))
     Endif
    Endif
   Endif
  Else : ## GEODE
   If evalue("type([F:"+ABFIC+"]"+CLEVALEUR+')')>10 & type(VALEUR)>10
    CHAINE = '[F:'+ABFIC+']'+CLEVALEUR+'>="'+left$(VALEUR,SELCAR)+'"'
   Elsif find(evalue("type([F:"+ABFIC+"]"+CLEVALEUR+')'),1,2,4,5,6,7,9) & type(VALEUR)>10
    I = len(num$(int(val(VALEUR))))
    If I>SELCAR
     CHAINE = '[F:'+ABFIC+']'+CLEVALEUR+'>='
     CHAINE += num$(val(left$(VALEUR,SELCAR))*10^(I-SELCAR))
    Endif
   Elsif find(evalue("type([F:"+ABFIC+"]"+CLEVALEUR+')'),1,2,4,5,6,7,9) & find(type(VALEUR),1,2,4,5,6,7,9)
    I = len(num$(int(VALEUR)))
    If I>SELCAR
     CHAINE = '[F:'+ABFIC+']'+CLEVALEUR+'>='
     CHAINE += num$(val(left$(num$(VALEUR),SELCAR))*10^(I-SELCAR))
    Endif
   Endif
  Endif
  Call ADDCRIT(CRITCAR,ICRITCAR,"CRITCAR",CHAINE,"&") From GOBJSUB
 Endif

 # Options de sélection
 If OPTIONS<>""
  Gosub OPTIONS From =PROGOBJ
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
 Endif
 If FILT & evalue("dim([F:"+ABFIC+"]ENAFLG)")>0 & ABFIC<> "ADI"
  Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+'ENAFLG=2',"&") From GOBJSUB
 Endif

 # Filtre par groupe de sites
 If dim([L]FLDGRF)>0 & [L]FLDGRF<>""
  J = evalue("dim([F:"+ABFIC+"]"+FLDGRF+")")
  If FILT & dim([V]GCURFCY)>0 & GCURFCY<>"" & J>0
   Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+FLDGRF+'="" | [F:FGR]FCY="'+GCURFCY+'")',"&") From GOBJSUB
  Endif
 Endif

 # Filtre par groupe de société
 If dim([L]FLDGRC)>0 & [L]FLDGRC<>""
  J = evalue("dim([F:"+ABFIC+"]"+FLDGRC+")")
  If FILT & dim([V]GSOCIETE)>0 & GSOCIETE<>"" & J>0
   Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+FLDGRC+'="" | [F:AGC]CPY="'+GSOCIETE+'")',"&") From GOBJSUB
  Endif
 Endif

 # Filtre par groupe de législation
 K = 0
 If dim([L]FLDLEG)>0 & [L]FLDLEG<>"" & !find(GABREV,"FCY","CPY") & !find(ABFIC,"FCY","CPY")
  J = evalue("dim([F:"+ABFIC+"]"+FLDLEG+")")
  If FILT & J>0 & dim([V]GCURLEG)>0 & GCURLEG<>""
   K = 1
   If J=1
    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+FLDLEG+'="" | [F:'+ABFIC+']'+FLDLEG+'="'+GCURLEG+'")',"&") From GOBJSUB
   Elsif J>1
    Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+FLDLEG+'(0)="" | find(GCURLEG,[F:'+ABFIC+']'
&               +FLDLEG+'(0..dim([F:'+ABFIC+']'+FLDLEG+'))))>=1',"&") From GOBJSUB
   Endif
  Endif
 Endif

 # Filtre sur la législation préférée de l'utilisateur
 If !K & dim([L]FLDLEG)>0 & [L]FLDLEG<>"" & dim(GLEGFIL)>0 & GLEGFIL<>"" & GNBLEG>1
  J = evalue("dim([F:"+ABFIC+"]"+FLDLEG+")")
  If J=1
   Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+FLDLEG+'="" | [F:'+ABFIC+']'+FLDLEG+'="'+GLEGFIL+'")',"&") From GOBJSUB
  Elsif J>1
   Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+FLDLEG+'(0)="" | find(GLEGFIL,[F:'+ABFIC+']'
&                +FLDLEG+'(0..dim([F:'+ABFIC+']'+FLDLEG+'))))>=1',"&") From GOBJSUB
  Endif
 Endif

 # Objets combinés
 If TYPGES=3 & evalue("type([F:"+ABFIC+"]"+CLELIG+")")<10
&            & evalue("type([F:"+ABFIC+"]"+CLELIG+")")<>3
&            & !(dim(CLEVALEUR)>0 & CLEVALEUR=CLELIG)
  Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:'+ABFIC+']'+CLELIG+"=1","&") From GOBJSUB
 Endif

 # Filtre sur droit d'accès
 If GUSRACS<>2 & dim(ZACC)>0 & ZACC<>""
  Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+ZACC+'="" or [F:ACC]CONSUL=2)',"&") From GOBJSUB
 Endif

 # Filtre sur les rôles
 Call FILROLE(OBJET,FILROLE) From SUBARL
 If FILROLE<>"" & FILROLE<>"1=1"
  V_OPE="&" :#121907
  For I=0 To dim(FILROLE)-1
   If FILROLE(I)="" : Break : Endif
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),V_OPE) From GOBJSUB
   Raz V_OPE
  Next I
 Endif

 # Filtre standard
 FILTSUP = ""
 If FILT
  ACTION = "FILTRE" : Gosub ACTION From GOBJET
 Endif
 If FILTSUP<>"" & FILTSUP<>"1=1"
  Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ","("+FILTSUP+")","&") From GOBJSUB
 Endif

 # Remplissage des colonnes
 J = NBCOL
 For I=1 To NBSEL
  If J<dim(COL) & I<=dim(SELEXP)
   J += 1
   If SELEXP(I)<>""
    COL(J) = SELEXP(I)
   Else
    COL(J) = SELZON(I)
   Endif
   TIT(J) = SELLIB(I)
   If left$(SELFMT(I),2)="LA"
    COL(J) = "mess("+COL(J)+","+num$(val(right$(SELFMT(I),3)))+",1)"
   Endif
   If dim(SELFOR)>0
    FMTCOL(J) = SELFOR(I)
   Endif
  Endif
 Next I
 NBCOL = J

 # Champ de référence pour le Starting at
 If START=""
  If dim(CLEVALEUR)<0
   If instr(1,OPTIONS,"|")
    START = '[F:'+ABFIC+']'+CLESEC
   Else
    START = '[F:'+ABFIC+']'+CLEPRIM
   Endif
  Else : ## GEODE
   START = '[F:'+ABFIC+']'+CLEVALEUR
  Endif
 Endif

 # Default file
 If evalue("clalev([F:"+ABFIC+"_])")>0
  Gosub DEFAUT_LISTE From =PROGOBJ
 Else
  Gosub DEFAUT From =PROGOBJ
 Endif

Endif

If NBCOL=0 : End : Endif

# Clé et sens
If SENS<>2  : SENS  = 1      : Endif
If SENS=1   : OPER  = ">="   : Else : OPER = "<=" : Endif
If START="" : START = COL(COL1) : Endif
If ORDRE=""
 For I=1 To NBCOL
  If left$(COL(I),1)="[" | (left$(COL(I),1)>="A" & left$(COL(I),1)<="Z")
   If ORDRE<>"" : ORDRE += ";" : Endif
   ORDRE += COL(I)
  Elsif left$(COL(I),4)="mess"
   If ORDRE<>"" : ORDRE += ";" : Endif
   J = instr(1,COL(I),"(")
   K = instr(1,COL(I),",")
   ORDRE += seg$(COL(I),J+1,K-1)
  Endif
 Next I
Endif

# Starting at

If EXPSTART = ""
 If find(type([L]VALEUR),522,523) : # Blob , clob
  EXPSTART = "1=1"
 Elsif type([L]VALEUR)>10 & (instr(1,[L]VALEUR,"'") | instr(1,[L]VALEUR,'"'))
  EXPSTART = "1=1"
 Elsif evalue("type("+START+")")=type([L]VALEUR)
  EXPSTART = START+OPER+"[L]VALEUR"
 Else
  Case evalue("type("+START+")")
   When 1,2,4,5,6,7,8,9
    If num$([L]VALEUR)=""
     EXPSTART = START+OPER+"0"
    Else
     EXPSTART = START+OPER+num$([L]VALEUR)
    Endif
   When 3
    EXPSTART = START+OPER+"[0/0/0]"
   When 522,523
    EXPSTART = START+OPER+'""'
   When Default
    Case TYPARG
     When 2,3,4   : EXPSTART = START+OPER+'"'+num$([L]VALEUR)+'"'
     When 1       : EXPSTART = START+OPER+'"'+[L]VALEUR+'"'
     When Default : EXPSTART = START+OPER+'""'
    Endcase
  Endcase
 Endif
Endif

#--------------------------------------------#
$SELECT
If CRITERE=""  : CRITERE  = "1=1" : Endif
If CRITOBJ=""  : CRITOBJ  = "1=1" : Endif
If CRITCAR=""  : CRITCAR  = "1=1" : Endif
If CRITRAP=""  : CRITRAP  = "1=1" : Endif
If FILSUITE="" : FILSUITE = "1=1" : Endif

ACTION = "CHX_TABLE" : Gosub ACTION
ER = 0
Onerrgo ERR
Case SENS
 When 1 : ORDCHO = ORDRE
 When 2 : Call CHANGE_SENS(ORDRE,ORDTRI) From GOBJACT : ORDCHO = ORDTRI
Endcase
Case NBCOL
 When 1
  Choose [F]
& Where evalue(CRITERE) & evalue(CRITRAP) & evalue(CRITOBJ) & evalue(CRITCAR) & evalue(FILSUITE)
& Order With ORDCHO
& Using [L]SAIRAP(1) = evalue(COL(1)) Using FMTCOL(1)  Titled TIT(1)
& Sized (SIZLIG,SIZCOL)
& Starting At evalue([L]EXPSTART)
& Titled TIT(0)
 When 2
  Choose [F]
& Where evalue(CRITERE) & evalue(CRITRAP) & evalue(CRITOBJ) & evalue(CRITCAR) & evalue(FILSUITE)
& Order With ORDCHO
& Using [L]SAIRAP(1) = evalue(COL(1)) Using FMTCOL(1)  Titled TIT(1)
&     , [L]SAIRAP(2) = evalue(COL(2)) Using FMTCOL(2)  Titled TIT(2)
& Sized (SIZLIG,SIZCOL)
& Starting At evalue([L]EXPSTART)
& Titled TIT(0)
