#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
#    SELECTION DANS TABLE CONCERNANT LES BIENS COMPTABLES
#    MWA
#    Création le : 14/03/2003
#    Modification le : 14/03/2003
#-------------------------------------------------------------------------------
# CBO   09.11.2017 X3-8349  IFRS 16
# MDJ   10.08.2015 109321   When no coef exists ==> error
# MDJ   19.03.2014 95899    Listes des coeff.actualisation en fonction du paramétrage (par défaut/société)
# MWA   04.10.2012 67615    Low Value Assets.
# GBO   23.09.2010 67524    Ajout PE dans l'action de sélection SELRNWFAS.
#
#-------------------------------------------------------------------------------
#    ****  SELECTION DANS TABLE  *****
#
#    SELFASSET      BIENS APPARTENANT AU MÊME ENSEMBLE
#    SELFASCMP      BIENS COMPOSANT DU MÊME PRINCIPAL
#    SELCMPFAS      BIENS PRINCIPAUX POTENTIELS
#    SELSETFAS      BIENS ENSEMBLES POTENTIELS
#    SELCPYDPP      PLANS D'UNE SOCIETE
#    SELLEAFAS      CONTRATS DE LOC. FIN. POUR RATTACHEMENT AU BIEN
#    SELPPLFAS      PLAN DE PRODUCTION POUR RATTACHEMENT AU BIEN
#    SELCCNFAS      CONCESSION DU SITE DE LA SOCIETE DU BIEN
#    SELCCN         CONCESSION DU SITE DE LA SOCIETE DU BIEN (Concédant)
#    SELCCAFAS      CODE ACTUALISATION DE LA SOCIETE DU BIEN
#    SELPSEFAS      PLAN DE SAISONNALITE DE LA SOCIETE DU BIEN
#    SELRNWFAS      CONCESSIONS : BIEN FILS
#    SELFASIML      DEPRECIATION
#
#-------------------------------------------------------------------------------

#  Appel direct d'une sélection sur table
  Local Char VALEUR(10),PARAM(10)(1..2)
  PARAM(1) = "Z02"
  PARAM(2) = "01"
  Call S_TAB_CHAR(VALEUR,PARAM,"SELCMPFAS","SELTABFAS","") From GACTION
  End


################################################################################
$ACTION
  If clalev([F:FAS]) =0                          : Local File FXDASSETS     [FAS] : Endif
  If clalev([F:FCY]) =0                          : Local File FACILITY      [FCY] : Endif

  If (G_ACTLEA = G_OUI) and (clalev([F:LEA]) =0) : Local File LEASE         [LEA] : Endif

 #Infbox num$(ACTION)
  Case ACTION
    When  "SEL_TABLE"      : Gosub SEL_TABLE
    When  "SEL_LISTE"      : Gosub SEL_LISTE    #FQ95899
    When  "VERF_TABLE"     : Gosub VERF_TABLE
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$SEL_TABLE

  Case TABLE
    When "SELFASSET"    : Gosub SET_FASSET
    When "SELFASCMP"    : Gosub SET_FASCMP
    When "SELSETFAS"    : Gosub SET_SETFAS
    When "SELCMPFAS"    : Gosub SET_CMPFAS
    When "SELCPYDPP"    : Gosub SET_CPYDPP
    When "SELLEAFAS"    : Gosub SET_LEAFAS
    When "SELPPLFAS"    : Gosub SET_PPLFAS
    When "SELCCNFAS"    : Gosub SET_CCNFAS
    When "SELCCN"       : Gosub SET_CCN
    When "SELCCAFAS"    : Gosub SET_CCAFAS
    When "SELPSEFAS"    : Gosub SET_PSEFAS
    When "SELFASIML"    : Gosub SET_FASIML
    When "SELFCYFIN"    : Gosub SET_FCYFIN
    When "SELRNWFAS"    : Gosub SET_RNWFAS
  Endcase
Return

#FQ95899
$SEL_LISTE

Case LISTE
    When "LISCCAFAS"    : Gosub LISCCAFAS
  Endcase
Return #FQ95899

#-------------------------------------------------------------------------------
$VERF_TABLE
  Case TABLE
    When "SELFASSET"    : Gosub VERF_FASSET
    When "SELFASCMP"    : Gosub VERF_FASCMP
    When "SELSETFAS"    : Gosub VERF_SETFAS
    When "SELCPYDPP"    : Gosub VERF_CPYDPP
  Endcase
Return


#-------------------------------------------------------------------------------
$SET_FASSET

 # ******  Biens de l'ensemble  *************

 # ******  Description de la table

  Local Char CODFIC  : CODFIC = "FXDASSETS" : # Séléction sur table
  Default File [FAS] :                        # ...................

  CRITERE = "CPY=LCPY and FCY=LFCY and SET= LSET  ":  # Critères de sélection
  ORDRE = "FCY; AASREF":           # Clause order by
  TIT(0) = mess(4,GML_MSGFAS,1) :         # Liste des biens - Ensemble
  SIZLIG = 120  # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220  # Défaut 240 (60 col en quart de colonne)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "FCY"       : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "AASREF"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "AASDES1"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OWNTYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(OWNTYP, 3171, 1)"               : # Récupération du libellé du code
  NBCOL += 1 : COL(NBCOL) = "ACGETRNOT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "format$('N:'+GFMT3, ACGETRNOT)":      # Affichage montant selon format devise
  START   = "SET" :             # Colonne à récupérer suite au choix

 # ******  Description de la table


  Local Char LCPY, LFCY, LAASREF, LSET
  LCPY = PARAM(1):      # Récupération paramètre
  LFCY = PARAM(2)
  LSET = PARAM(3)
  LAASREF = PARAM(4)

Return


#-------------------------------------------------------------------------------
$SET_FASCMP


 # ******  Biens composants du bien principal  *************


 # ******  Description de la table


  Local Char LCPY, LFCY, LAASREF, LCMP
  LCPY = PARAM(1):      # Récupération paramètre
  LFCY = PARAM(2)
  LAASREF = PARAM(3)
  LCMP = PARAM(4)

 # ******  Description de la table

  Local Char CODFIC  : CODFIC = "FXDASSETS" : # Séléction sur table
  Default File [FAS] :
  # ...................
  If ( LCMP = '' ) Then
    CRITERE = "CPY= LCPY and FCY= LFCY and  CMP = LAASREF "
  Else
    CRITERE = "CPY= LCPY and FCY= LFCY and ( CMP = LCMP or AASREF = LCMP ) and  AASREF <> LAASREF"
  Endif
  ORDRE = "FCY; CMPSTA; AASREF":           # Clause order by
  TIT(0) = mess(9,GML_MSGFAS,1) :         # Liste des biens - composants
  SIZLIG = 120  # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220  # Défaut 240 (60 col en quart de colonne)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "FCY"       : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "AASREF"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "AASDES1"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CMPSTA"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(CMPSTA, 3229, 1)"               : # Récupération du libellé du code
  NBCOL += 1 : COL(NBCOL) = "OWNTYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(OWNTYP, 3171, 1)"               : # Récupération du libellé du code
  NBCOL += 1 : COL(NBCOL) = "ACGETRNOT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "format$('N:'+GFMT3, ACGETRNOT)":      # Affichage montant selon format devise
  START   = "CMP" :                        # Colonne à récupérer suite au choix

Return



#-------------------------------------------------------------------------------
$SET_SETFAS

 # ******  Liste des ensembles potentiels  *************


 # ******  Description de la table

  Local Char CODFIC  : CODFIC = "FXDASSETS" : # Séléction sur table
  Default File [FAS] :                        # ...................

  CRITERE =   "CPY=LCPY and FCY=LFCY and  SET = AASREF "
  CRITERE +=  "and (OWNTYP <> 4 or OWNTYP <> 6) ":  # Critères de sélection
  ORDRE = "FCY; AASREF":           # Clause order by
  TIT(0) = mess(7,GML_MSGFAS,1) :         # Liste des biens - Ensemble
  SIZLIG = 120  # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220  # Défaut 240 (60 col en quart de colonne)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "AASREF"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "AASDES1"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OWNTYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(OWNTYP, 3171, 1)"               : # Récupération du libellé du code
  START   = "AASREF"                                : # Colonne à récupérer suite au choix

 # ******  Description de la table


  Local Char LCPY, LFCY, LAASREF
  LCPY = PARAM(1):      # Récupération paramètre
  LFCY = PARAM(2)
  LAASREF = PARAM(3)
Return


#-------------------------------------------------------------------------------
$SET_CMPFAS
 # ******  Liste des biens principaux potentiels *************

 # ******  Description de la table

  Local Char LCPY, LFCY, LAASREF, LIASSEC, LIASCGU
  LCPY    = PARAM(1):      # Récupération paramètre
  LFCY    = PARAM(2)
  LAASREF = PARAM(3):      # 2004/11/26 : GLE - ajout de ce paramètre pour correction fiche 26379


 # ******  Description de la table

  Local Char CODFIC  : CODFIC = "FXDASSETS" : # Séléction sur table
  Default File [FAS] :                        # ...................

  CRITERE =  "CPY=LCPY and FCY=LFCY  and AASREF <> LAASREF and CMPSTA = GVML_SBPRINC and ISSDAT = [0/0/0] "
  CRITERE += "and OWNTYP <> GVML_TDPREVU and  OWNTYP <> GVML_TDMODEL "
  ORDRE = "PURDAT Desc ; AASREF":           # Clause order by
  TIT(0) = mess(6,GML_MSGFAS,1) :         # Liste des biens - principaux
  SIZLIG = 120  # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220  # Défaut 240 (60 col en quart de colonne)
  START   = "AASREF" :             # Colonne à récupérer suite au choix
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "AASREF"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "AASDES1"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PURDAT"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "OWNTYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(OWNTYP, 3171, 1)"               : # Récupération du libellé du code


Return


#-------------------------------------------------------------------------------
$SET_CPYDPP

 # ******  Liste des plans d'amortissements d'une société  *************

 # ******  Description de la table

  Local Char CRITERE(250)
  Local Char CLS
  Local Char CODFIC  : CODFIC = "PLNCAA" : # Séléction sur table

  If clalev([F:PLC])=0 : Local File = "PLNCAA" [PLC]:   Endif
  Default File [PLC]

  # ...................

  CRITERE = "CPY=LCPY and PLNPRO=2"   : # Critères de sélection
  ORDRE = "CNX; PLNCAA"   : # Clause order by
  TIT(0) = mess(26,GML_MSGFAS,1) : # Liste des plans d'amortissement
  SIZLIG = 80             : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 240            : # Défaut 240 (60 col en quart de colonne)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CPY"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PLNCAA"  : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(PLNCAA, 3101, 1)" : # Récupération du libellé du code
  START   = "PLNCAA"                  : # Colonne à récupérer suite au choix

  # ******  Description de la table

  Local Char LCPY
  LCPY = PARAM(1) : # Récupération paramètre

Return

#-------------------------------------------------------------------------------
$SET_LEAFAS

 # ******  Liste des contrats de location financement potentiels *************

 # ******  Description de la table


  Local Char LCPY, LFCY, LLEAREF, LOWNTYP
  Local Date LDAT

# Récupération paramètre
  LCPY     = PARAM(1)
  LDAT     = PARAM(2)
  LFCY     = PARAM(3)
  LOWNTYP  = PARAM(4)


 # ******  Description de la table

  Local Char CODFIC  : CODFIC = "LEASE" : # Séléction sur table
  Default File [LEA]
# ...................
#* critères = société du contrat = société du bien et statut du contrat "à valider" ou "encours"
#* et type de contrat correspond au type de détention du bien
#* et date d'achat du bien comprise entre les date début et date fin du contrat
#*

 CRITERE =  "CPY=LCPY & FCY=LFCY  & (LEASTA = GVML_STAVAL  or  LEASTA = GVML_STENCOU)"
#Fq 27719 & (STRLEADAT <= LDAT)& (ENDLEADAT >= LDAT)"

 If LOWNTYP = num$(GVML_TDCBAIL)
    CRITERE  -= "& LEATYP = GVML_CREBAIL"
 Elsif LOWNTYP = num$(GVML_TDLOCAT)
#    CRITERE  -= "& LEATYP = GVML_LOCLDUR" # X3-8349
    CRITERE  -= "& (LEATYP = GVML_LOCLDUR or LEATYP = GVML_LOCATION)" # X3-8349
 Else
    Return
 Endif

  ORDRE = "FCY; LEAREF":           # Clause order by
  TIT(0) = mess(55,GML_MSGFAS,1) :        # Liste des contrats de location-financement
  SIZLIG = 120  # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220  # Défaut 240 (60 col en quart de colonne)
  START   = "LEAREF" :             # Colonne à récupérer suite au choix
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "LEAREF"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "LEADES"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "LEATYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(LEATYP, 3224, 1)"               : # Récupération du libellé du code
  NBCOL += 1 : COL(NBCOL) = "STRLEADAT"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ENDLEADAT"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV

Return


#-------------------------------------------------------------------------------
$SET_PPLFAS

 # ******  Liste des plans de production potentiels *************

 # ******  Description de la table


  Local Char LCPY, LFCY

# Récupération paramètre
  LCPY     = PARAM(1)
  LFCY     = PARAM(2)



 # ******  Description de la table

  Local Char CODFIC  : CODFIC = "PROPLNH" : # Séléction sur table
  Default File [PPH]
# ...................
#* critères =
#* société du plan de production = société du bien ET
#* date de fin du plan de production > = à la date de début d'exercice courant du contexte gérant les UO
#*

  CRITERE =  "CPY=LCPY and FCY=LFCY and ( PPLENDDAT0 >= GDEBEXEUO or PPLENDDAT0 = [0/0/0] )"

  ORDRE = "FCY; PROPLN"    :        # Clause order by
  TIT(0) = mess(583,GML_MSGFAS,1) :        # Liste des plans de production
  SIZLIG = 120  # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220  # Défaut 240 (60 col en quart de colonne)
  START   = "PROPLN" :             # Colonne à récupérer suite au choix
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "PROPLN"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PLNDES1"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV

Return


#-------------------------------------------------------------------------------
$SET_CCNFAS

 # ******  Liste des concession de la société   *************

 # ******  Description de la table
  Local Char CLS
  Local Char CODFIC  : CODFIC = "CONCESSION" : # Séléction sur table


  Local Char LCPY
  Local Char LFCY
  LCPY    = PARAM(1) : # Société
  LFCY    = PARAM(2) : # Site

  DEFPAG = 1

  If clalev([F:CCN])=0 : Local File = "CONCESSION" [CCN]:   Endif
  Default File [CCN]
  # ******  Description de la table
  # ...................
  # Critères de sélection
  CRITERE = "CCNSTA = GVML_CSACTI "
  If LCPY="" & LFCY="" Then : CRITERE +='(GUSRFCY(1)="\" | find(FCY,GUSRFCY(1..GNBAUZ)))' : Endif #FQ62862
  If ( LCPY     <> "") Then : CRITERE += " and CPY   ='"+LCPY+"'"    : Endif
  If ( LFCY     <> "") Then : CRITERE += " and FCY   ='"+LFCY+"'"    : Endif
  ORDRE   = "CCNREF"        : # Clause order by
  TIT(0)  = mess(261,GML_MSGFAS,1) : # Liste des concessions
  SIZLIG  = 80              : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL  = 240             : # Défaut 240 (60 col en quart de colonne)
  NBCOL   = 0
  NBCOL  += 1 : COL(NBCOL) = "CCNREF"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "CCNDES1"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  # FQ50972
  NBCOL  += 1 : COL(NBCOL) = "string$([F:CCN]DFTCCNFLG<>G_OUI,'')+string$([F:CCN]DFTCCNFLG=G_OUI,mess([F:CCN]DFTCCNFLG,1,1))"  : Call TEXTFIC(CODFIC, "DFTCCNFLG", 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "STRCCNDAT"  : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "ENDCCNDAT"  : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  START   = "CCNREF"                  : # Colonne à récupérer suite au choix


  Local Char LCPY
  Local Char LFCY
  LCPY = PARAM(1) : # Société
  LFCY = PARAM(2) : # Site


Return

#-------------------------------------------------------------------------------
$SET_CCN

 # FQ54343

  DEFPAG = 1

  # ******  Liste des concessions ( Société, Site, Concédant )  *************
  Local Char LCPY
  Local Char LFCY
  Local Char LCCNUSR
  LCPY    = PARAM(1) : # Société
  LFCY    = PARAM(2) : # Site
  LCCNUSR = PARAM(3) : # Concédant

  # ******  Description de la table
  Local Char CLS
  Local Char CODFIC  : CODFIC = "CONCESSION" : # Séléction sur table

  If clalev([F:CCN])=0 : Local File = "CONCESSION" [CCN]:   Endif
  Default File [CCN]

  # ******  Description de la table
  # ...................
  CRITERE = "CCNSTA <> GVML_CSPREP " : # Critères de sélection
  If LCPY="" & LFCY="" Then : CRITERE +='  and (GUSRFCY(1)="\" | find(FCY,GUSRFCY(1..GNBAUZ)))' : Endif #FQ62862
  If ( LCPY     <> "") Then : CRITERE += " and CPY   ='"+LCPY+"'"    : Endif
  If ( LFCY     <> "") Then : CRITERE += " and FCY   ='"+LFCY+"'"    : Endif
  If ( LCCNUSR  <> "") Then : CRITERE += " and CCNUSR='"+LCCNUSR+"'" : Endif
  ORDRE   = "CCNREF"        : # Clause order by
  TIT(0)  = mess(261,GML_MSGFAS,1) : # Liste des concessions
  SIZLIG  = 80              : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL  = 240             : # Défaut 240 (60 col en quart de colonne)
  NBCOL   = 0
  NBCOL  += 1 : COL(NBCOL) = "CCNREF"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "CCNDES1"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "string$([F:CCN]DFTCCNFLG<>G_OUI,'')+string$([F:CCN]DFTCCNFLG=G_OUI,mess([F:CCN]DFTCCNFLG,1,1))"  : Call TEXTFIC(CODFIC, "DFTCCNFLG", 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "STRCCNDAT"  : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "ENDCCNDAT"  : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  START   = "CCNREF"                  : # Colonne à récupérer suite au choix



Return

#-------------------------------------------------------------------------------
$SET_CCAFAS

 # FQ54343

 # ******  Liste des codes actualisation de la société   *************

  Local Char LCPY
  LCPY = PARAM(1) : # Société

 # ******  Description de la table
  Local Char CLS
  Local Char CODFIC  : CODFIC = "CCNCOE" : # Séléction sur table

  If clalev([F:COE])=0 : Local File = "CCNCOE" [COE]:   Endif
  Default File [COE]

  DEFPAG = 1

  # ******  Description de la table
  # ...................
  CRITERE = "CPY='"+LCPY+"' or CPY=''"      : # Critères de sélection
  ORDRE   = "CCNACTCOD"     : # Clause order by
  TIT(0)  = mess(691,GML_MSGFAS,1) : # Liste des codes actualisation
  SIZLIG  = 80              : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL  = 240             : # Défaut 240 (60 col en quart de colonne)
  NBCOL   = 0
  NBCOL  += 1 : COL(NBCOL) = "CCNACTCOD"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "DES1"          : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "CCNACTCOE"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  START   = "CCNACTCOD"     : # Colonne à récupérer suite au choix


Return


#-------------------------------------------------------------------------------
$SET_PSEFAS

 # FQ59941

 # ******  Liste des plans de saisonnalité   *************

  Local Char LCPY
  LCPY = PARAM(1) : # Société

 # ******  Description de la table
  Local Char CLS
  Local Char CODFIC  : CODFIC = "PSEPLN" : # Séléction sur table

  If clalev([F:PSE])=0 : Local File = "PSEPLN" [PSE]:   Endif
  Default File [PSE]

  DEFPAG = 1

  # ******  Description de la table
  # ...................
  CRITERE = "CPY='"+LCPY+"' or CPY=''"      : # Critères de sélection
  ORDRE   = "PSEPLN"     : # Clause order by
  TIT(0)  = mess(691,GML_MSGFAS,1) : # Liste des codes actualisation
  SIZLIG  = 80               : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL  = 240              : # Défaut 240 (60 col en quart de colonne)
  NBCOL   = 0
  NBCOL  += 1 : COL(NBCOL) = "PSEPLN"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "DES1"       : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  START   = "PSEPLN"     : # Colonne à récupérer suite au choix


Return

#-------------------------------------------------------------------------------
$SET_FASIML
Local Char LCPY
 # ******  Biens autonomes et principaux (éventuellement d'une société)  *************
 # ******  Description de la table
  #Dbgaff
  If PARAM(1) <> "" Then
    LCPY = PARAM(1)                                       : # Récupération paramètre
  Else
    LCPY = ""
  Endif
 # ******  Description de la table
  Local Char CODFIC  : CODFIC = "FXDASSETS"               : # Séléction sur table
  Default File [FAS]
  #
  # FQ67615
  #CRITERE = "(CMPSTA=GVML_SBAUTON or CMPSTA=GVML_SBPRINC) and IASCGU=''"
  CRITERE = "(CMPSTA=GVML_SBAUTON or CMPSTA=GVML_SBPOOL or CMPSTA=GVML_SBLVA or CMPSTA=GVML_SBPRINC) and IASCGU=''"
  If LCPY <> "" Then
    CRITERE += "&CPY='"+LCPY+"'"
  Endif
  If LCPY <> "" Then
    ORDRE = "CPY;AASREF"                                  : # Clause order by
  Else
    ORDRE = "AASREF"                                      : # Clause order by
  Endif

  TIT(0) = mess(268,GML_MSGFAS,1)                                : # Liste des biens - composants
  SIZLIG = 120                                            : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220                                            : # Défaut 240 (60 col en quart de colonne)
  NBCOL = 0
  If LCPY = "" Then
    NBCOL += 1 : COL(NBCOL) = "CPY"       : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  Endif
  NBCOL   += 1 : COL(NBCOL) = "FCY"       : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL   += 1 : COL(NBCOL) = "AASREF"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL   += 1 : COL(NBCOL) = "AASDES1"   : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL   += 1 : COL(NBCOL) = "CMPSTA"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(CMPSTA, 3229, 1)"                     : # Récupération du libellé du code
  NBCOL += 1 : COL(NBCOL) = "OWNTYP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "mess(OWNTYP, 3171, 1)"                     : # Récupération du libellé du code
  NBCOL += 1 : COL(NBCOL) = "ACGETRNOT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  COL(NBCOL) = "format$('N:'+GFMT3, ACGETRNOT)"           : # Affichage montant selon format devise
  START   = "AASREF"                                      : # Colonne à récupérer suite au choix
Return
#-------------------------------------------------------------------------------
$SET_FCYFIN


 # ******  Description de la table

  Local Char CODFIC  : CODFIC = "FACILITY" : # Séléction sur table
  Default File [FCY] :
  # ...................

  CRITERE = "FINFLG= 2"
  ORDRE = "FCY; CPY; AASREF":           # Clause order by
  TIT(0) = "Liste sites financiers"
  SIZLIG = 120  # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 220  # Défaut 240 (60 col en quart de colonne)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "FCY"        : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CPY"        : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "FCYNAM"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  START   = "FCY" :                        # Colonne à récupérer suite au choix

Return

