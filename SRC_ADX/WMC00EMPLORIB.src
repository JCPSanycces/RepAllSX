# Supervisor
## CRUD-CLASSE ## EMPLORIB
# 2018-11-06 07:06:27 575

Gosub TEST From WMCR_EMPLORIB : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM,NUMLIG)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLORIB : EMPLORIB
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLORIB._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLORIB.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLORIB.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLORIB [RIB]
 Local File EMPLORIB [AAA_]
Else
 Local File =EMPLORIB.ACTX.AFOLDER+".EMPLORIB" [RIB]
 Local File =EMPLORIB.ACTX.AFOLDER+".EMPLORIB" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [RIB] With
& [AAA_]RIB0 = REFNUM+NUMLIG
& As [LNK_]
Return

############################################################################################
### EMPLORIB(WRIB)
############################################################################################
Funprog  _MAJSQL_EMPLORIB(WRIB)
Variable Instance WRIB Using C_EMPLORIB
Local Integer ASTATUS,A_I,A_J
Default File [F:RIB]
If WRIB.ASTALIN=[V]CST_ANEW
 Call INICRE(WRIB) From ASYRSUB
 SetInstance [F:RIB] With WRIB
 Write [F:RIB]
 If fstat
  Call FSTA("RIB",WRIB,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WRIB.updTick = [F:RIB]updTick
Elsif WRIB.ASTALIN=[V]CST_ALL or WRIB.ASTALIN=[V]CST_AUPD
 Call INIUPD(WRIB) From ASYRSUB
 SetInstance [F:RIB] With WRIB
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WRIB,"EMPLORIB")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:RIB]RIB0 = [F:RIB]REFNUM;[F:RIB]NUMLIG
 If fstat
  Call FSTA("RIB",WRIB,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WRIB.updTick = [F:RIB]updTick
Elsif WRIB.ASTALIN=[V]CST_ADEL
 SetInstance [F:RIB] With WRIB
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WRIB,"EMPLORIB")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:RIB]RIB0 = [F:RIB]REFNUM;[F:RIB]NUMLIG
 If fstat
  Call FSTA("RIB",WRIB,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



