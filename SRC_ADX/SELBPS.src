#<AdxTL>@(#)0.0.0.0 $Revision$
# Suppliers selections                                                               SMI 24/06/18 #
###################################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "VERF_TABLE"  : Gosub VERF_TABLE
    When Default
  Endcase
Return


###################################################################################################
# Table selection                                                                    SMI 24/06/18 #
###################################################################################################
$SEL_TABLE
  Case TABLE
    When "SELBPSITM3"     : Gosub SEL_SELBPSITM3
    When Default
  Endcase

$VERF_TABLE
  Case TABLE
    When "SELBPSITM3"     : Gosub VERF_SELBPSITM3
    When Default
  Endcase
Return

######################################################################
# SELBPSITM : Select a supplier for an product         SMI 24/06/18  #
######################################################################
$SEL_SELBPSITM3
Local Char    WITMREF(GLONITM)

If clalev([F:ITP])=0 Local File ITMBPS [ITP]     : Endif
If clalev([F:BPS])=0 Local File BPSUPPLIER [BPS] : Endif

WITMREF=PARAM(1)
CODFIC = "ITMBPS"       #MAIN TABLE To WORK ON
DEFPAG = 1                 #STILL PUT 1. ALLOW To MANAGE Next/PREVIOUS PAGES
SIZLIG = 120               #height of the selection table
SIZCOL = 400               #weight of the selection table list window
CRITERE -= " [F:ITP]ITMREF = '" + WITMREF + "'"
START  = "[F:ITP]BPSNUM"    # Return value. Allow to not have it at the first place on the object
ORDRE  = "[F:ITP]BPSNUM"    # Allow to define a sort order which is not the object default one

Link [ITP] With [BPS]BPS0=[F:ITP]BPSNUM As [ITP1]
Default File [ITP1]

TIT(0) = mess(5,195,1)
NBCOL =0
NBCOL += 1 : COL(NBCOL) = "[F:ITP]BPSNUM"                   : Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSNAM"                   : Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSSHO"                   : Call TEXTFIC("BPSUPPLIER","BPSSHO",1,TIT(NBCOL)) From OBJDIV
Return

$VERF_SELBPSITM3
Return

