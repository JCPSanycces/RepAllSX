#############################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SGRHSDH2) 05/01/2007 14:47:59 (LD)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
#  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
  GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]STOFCY = ""
  # Mail CH : 03/03/04
  #  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  #  Raz [M]CURS
#  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
  GSOCIETE="" : GLOCALDEV=""
Endif
End
############################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Affzo ZCPY
Raz [M]STOFCY, ZSTOFCY
Affzo STOFCY,ZSTOFCY
If VALEUR<>"" : GSOCIETE=VALEUR : Endif
End
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    Affzo [M]CPY, ZCPY
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
#    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
    GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End
############################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Affzo CPY, ZCPY
Endif
End
############################################################
Subprog AM_SDHNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SDHNUMFIN= VALEUR : Endif
End
######################################################################################
#                                                                                    #
##     Etiquettes masques SGRHSDH1,SGD1,SGD3                                        ##
#                                                                                    #
######################################################################################
######################################################################################
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : # Quinzaine
GMENLOC(8)=1 : # Décade
End
########################################
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
# -- Recalcul du nbre de périodes
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo [M]PERNBR
# -- Recalcul date début en fonction de la périodicité et du nbre de périodes
Local Date WDATE
Call CALDATPER(VALEUR,[M]PERNBR,"-",[0/0/0],[M]DLVDATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]DLVDATDEB=WDATE : Affzo [M]DLVDATDEB
Endif
End
########################################
Subprog C_PERNBR(VALEUR)
Variable Decimal VALEUR
#If VALEUR<1 | VALEUR>24 mkstat=2 Endif
End
########################################
Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
# -- Recalcul date début en fonction de la périodicité et du nbre de périodes
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"-",[0/0/0],[M]DLVDATFIN,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]DLVDATDEB=WDATE : Affzo [M]DLVDATDEB
Endif
End
######################################################################################
######################################################################################
#                                                                                    #
##     Etiquettes masques SGRHSDH1,SGRHSDH2,SGD1,SGD2,SGD3                          ##
#                                                                                    #
######################################################################################
########################################
Subprog AM_DLVDATDEB(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  # -- Recalcul date fin en fonction de la périodicité et du nbre de périodes
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]DLVDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]DLVDATFIN=WDATE : Affzo [M]DLVDATFIN
  Endif
  #-----
#Elsif VALEUR>[M]DATFIN
#  [M]DATFIN=VALEUR
Elsif VALEUR <> [0/0/0]
  [M]DLVDATFIN= VALEUR
Endif
End
########################################
Subprog AM_DLVDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)>0
  #----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]DLVDATFIN,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]DLVDATDEB=WDATE : Affzo [M]DLVDATDEB
  Endif
  #-----
Endif
End
