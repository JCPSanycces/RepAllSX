#<AdxTL>@(#)6.0.0.0 $Revision$
#####################################################################################
#                                       Module Ventes - Janvier  2007               #
#                                                                                   #
#                 CONSULTATIONS GRAPHIQUES LIVRAISONS                               #
#                                                                                   #
#####################################################################################
#                                                                                   #
#                                                                                   #
#            Livraisons par période                                                 #
#            ----------------------                                                 #
# GACTION  : TRTGRHSDH1 : Sélections                                                #
#            (Fenêtre : DGRHSDH1)                                                   #
#            (Ecran   : SGRHSDH1 DIA)                                               #
#            VISUGRHSD1 : HT / Catégorie                                            #
#            (Fenêtre : IGRHSDH1)                                                   #
#            (Ecran   : SGD1    SGD1)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (par catégorie=1)                     #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
# GACTION  : VISUGRHSD3 : HT Facturé et HT Retourné                                 #
#            (Fenêtre : IGRHSDH3                                                    #
#            (Ecran   : SGD3    SGD3)                                               #
#            (Param ABREV : Abrév du masque contenant les critères)                 #
#            (Param TYPCOD: Type de graphique (facturé=2,retourné=3)                #
#            (Param DATDEB: Date début)                                             #
#            (Param DATFIN: Date fin)                                               #
#                                                                                   #
#            Palmarès Motifs retours                                                #
#            -----------------------                                                #
# GACTION  : TRTGRHSDH2 : Sélections                                                #
#            (Fenêtre : DGRHSDH2)                                                   #
#            (Ecran   : SGRHSDH2 DIA)                                               #
#            VISUGRHSD2 : Palmarès                                                  #
#            (Fenêtre : IGRHSDH2)                                                   #
#            (Ecran   : SGD2    SGD2)                                               #
#            (Param ABREV   : Abrév du masque contenant les critères)               #
#            (Param TYPTIERS: Type de graphique (palmarès clt=1 ou représentant=2)  #
#            (Param DATDEB  : Date début)                                           #
#            (Param DATFIN  : Date fin)                                             #
#                                                                                   #
#                                                                                   #
#####################################################################################
# Prérequis VISUGRHSD1 et 2 et 3 : Le masque contenant les critères doit être ouvert#
#####################################################################################
#####################################################################################
$ACTION
Case ACTION
    When "OUVRE"          :
        Case GACTION
            When "TRTGRHSDH1"  :  Gosub OUVRE_TRTGRHSDH
            When "VISUGRHSD1"  :  Gosub OUVRE_VISUGRHSD1
            When "VISUGRHSD3"  :  Gosub OUVRE_VISUGRHSD1
            When "TRTGRHSDH2"  :  Gosub OUVRE_TRTGRHSDH
            When "VISUGRHSD2"  :  Gosub OUVRE_VISUGRHSD2
        Endcase
    When "DEBUT"          :
        Case GACTION
            When "TRTGRHSDH1"  :  Gosub DEBUT_TRTGRHSDH1
            When "VISUGRHSD1"  :  Gosub DEBUT_VISUGRHSD1
            When "VISUGRHSD3"  :  Gosub DEBUT_VISUGRHSD1
            When "TRTGRHSDH2"  :  Gosub DEBUT_TRTGRHSDH2
            When "VISUGRHSD2"  :  Gosub DEBUT_VISUGRHSD2
        Endcase
    When "TITRE"
        Case GACTION
            When "VISUGRHSD1"  :  Gosub TIT_VISUGRHSD1
            When "VISUGRHSD3"  :  Gosub TIT_VISUGRHSD1
            When "VISUGRHSD2"  :  Gosub TIT_VISUGRHSD2
        Endcase
    When "SETBOUT"          :
        Case GACTION
            When "TRTGRHSDH2"  :  Gosub SETB_TRTGRHSDH2
        Endcase
    When "BOUTON"
        Case GACTION
            When "TRTGRHSDH1"  :  Gosub BOUT_TRTGRHSDH
            When "VISUGRHSD1"  :  Gosub BOUT_VISUGRHSD1
            When "VISUGRHSD3"  :  Gosub BOUT_VISUGRHSD1
            When "VISUGRHSD2"  :  Gosub BOUT_VISUGRHSD2
        Endcase
    When "FIN"
        Case GACTION
            When "VISUGRHSD1"  :  Gosub FIN_VISUGRHSD1
            When "VISUGRHSD3"  :  Gosub FIN_VISUGRHSD1
            When "VISUGRHSD2"  :  Gosub FIN_VISUGRHSD2
        Endcase
    When "OK"
        Case GACTION
            When "TRTGRHSDH2"  :  Gosub OK_TRTGRHSDH2
        Endcase
    When Default
Endcase
Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSDH1                       #
#                                TRTGRHSDH2                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_TRTGRHSDH

Gosub OUVRE

Return
###################################################################


###################################################################
$OUVRE

If clalev([F:SDH])=0 Local File SDELIVERY  [SDH]  : Endif
If clalev([F:SDD])=0 Local File SDELIVERYD [SDD]  : Endif
If clalev([F:SRD])=0 Local File SRETURND   [SRD]  : Endif
If clalev([F:BPC])=0 Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:CPY])=0 Local File COMPANY    [CPY]  : Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU]  : Endif
If clalev([F:PER])=0 Local File PERIOD     [PER]  : Endif
If clalev([F:ACN])=0 Local File ACONSULT   [ACN]  : Endif

Return
###################################################################
$DEBUT

[M]STOFCY=GFCYDEF(7)
If [M]STOFCY <> "" : # Parametre Site
    If [F:FCY]FCY <> [M]STOFCY  Read [F:FCY]FCY0 = [M]STOFCY
                                If fstat Raz [F:FCY], [M]STOFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M]STOFCY,GUSRFCY(1..GNBAUZ))
        If [M]STOFCY <> ""
             Call GETDEV([M]STOFCY) From DEVSUB
             [M]CPY  = GSOCIETE
        Endif
    Endif
Endif

Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSDH1                       #
#                                                                 #
#                    HT par catégorie ou facturé ou retourné      #
#                                                                 #
###################################################################
###################################################################
$DEBUT_TRTGRHSDH1

Raz [M:DIA]

[M]PERCOD=4         : # Init. de la périodicité au mois
[M]PERNBR=3         : # Init. du nombre de période à 3
[M]DLVDATFIN=eomonth(date$)
[M]DLVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

[M:DIA]LNDN=2    :    # On prend les livraisons normales
[M:DIA]LNDO=2    :    # On prend les livraisons de prêt

[M:DIA]CFMFLGO=2 :    # On prend les livraisons validées
[M:DIA]CFMFLGN=2 :    # On prend les livraisons non validées

[M:DIA]INVFLGO=2 :    # On prend les livraisons facturées
[M:DIA]INVFLGN=2 :    # On prend les livraisons non facturées

[M:DIA]RTNFLGO=2 :    # On prend les livraisons retournées
[M:DIA]RTNFLGN=2 :    # On prend les livraisons non retournées

#Gbn-Fq75851
[M:DIA]BETFCYFLG=1 :  # On ne prend pas les livraisons inter-site
[M:DIA]SCOFLG=1 :  # On ne prend pas les livraisons pour sous-traitance

# X3-1152 : Non billable deliveries
[M:DIA]NONINV=1 : # Only billable deliveries

Gosub DEBUT

Call LECMEMO ("STD","[M:DIA]","vg5") From GMEMO

Affzo [DIA]1-99

Return
###################################################################
###################################################################
# -------------------------------------------------------------------------- #
# Réaffichage de l'écran de sélection                                        #
# -------------------------------------------------------------------------- #
$BOUT_TRTGRHSDH

Case BOUT
    When "1", "2" :
        Affzo [M:DIA]1-99
Endcase

Return
###################################################################
#                                                                 #
#                                                                 #
#        TRAITEMENTS LIES ACTION TRTGRHSDH2                       #
#                                                                 #
#                    Palmarès Motif retour                        #
#                                                                 #
###################################################################
###################################################################
$DEBUT_TRTGRHSDH2

Raz [M:DIA]

[M]DLVDATFIN=eomonth(date$)
[M]DLVDATDEB=gdat$(01,month(addmonth(date$,-5)),year(addmonth(date$,-5)))

If val(PARAM(2))=1
    [M:DIA]LNDO=2    :   # Palmarès motif retour : On ne prend pas les livraisons prêt
Else
    [M:DIA]LNDN=2    :   # Autre                 : On prend les livraisons non prêt
Endif

[M:DIA]CFMFLGO=2    :    # On prend les livraisons validées
If val(PARAM(2))=1
    [M:DIA]CFMFLGN=1 :   # Palmarès motif retour : On ne prend pas les livraisons non validées
Else
    [M:DIA]CFMFLGN=1 :   # Autre                 : On prend les livraisons non validées
Endif

[M:DIA]INVFLGO=2    :    # On prend les livraisons facturées
[M:DIA]INVFLGN=2    :    # On prend les livraisons non facturées

[M:DIA]RTNFLGO=2    :    # On prend les livraisons retournées (flag retourné non géré pour les livraisons normales)
[M:DIA]RTNFLGN=2    :    # On prend les livraisons non retournées

Gosub DEBUT

Call LECMEMO ("STD","[M:DIA]","vg6") From GMEMO

Affzo [DIA]1-99

Return
###################################################################
$SETB_TRTGRHSDH2


Return
###################################################################
# -------------------------------------------------------------------------- #
# Réaffichage de l'écran de sélection                                        #
# -------------------------------------------------------------------------- #
$OK_TRTGRHSDH2
Affzo [M:DIA]1-99
FIN=0
Return
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSD1 VISUGRHSD2 VISUGRHSD3 #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSD1

Local Integer  WSAVPERCOD, WPERCOD : # Périodicité 1=jour,2=Semaine,3=Quinz.,4=Mois,5=Trimestre,6=Semestre,7=Année,8=Décade
Local Date     WSAVDATDEB, WDATDEB : # Date début
Local Date     WSAVDATFIN, WDATFIN : # Date fin
Local Integer  WSAVPERNBR          : # Nombre de période

Local Char     WCURS(GLONCUR)    : # Devise société
Local Char     WCURD(GLONCUR)    : # Devise dossier

Local Char     WPROGSPE(GLONADC) : # Nom du programme spécifique
Local Integer  WOK

# Variables communes avec la consultation commande
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSD")
# -- > "DIA"  : On vient de la fonction graphique montant HT commande
# -- > "CCSD" : On vient de la consultation commandes
Local Char    WABREV : WABREV=PARAM(1)
# Type de graphique
# -- > 1 : Montant HT par catégorie
# -- > 2 : Montant HT facturé
# -- > 3 : Montant HT retourné
Local Integer WTYP : WTYP=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations livraisons
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSD"
   If !clalev([M:CSD1])  Local Mask CONSCSD1 [CSD1] : Endif
   If !clalev([M:CCSD])  Local Mask CRITCSD  [CCSD] : Endif
Endif

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #

If evalue("dim([M:"+WABREV+"]PERCOD)")>0
    WPERCOD=evalue("[M:"+WABREV+"]PERCOD")
    WSAVPERCOD=WPERCOD
Else
    WPERCOD=4
Endif
If evalue("dim([M:"+WABREV+"]DLVDATDEB)")>0
    WDATDEB=evalue("[M:"+WABREV+"]DLVDATDEB")
    WSAVDATDEB=WDATDEB
    If WPERCOD=4 WDATDEB=gdat$(01,month(WDATDEB),year(WDATDEB)) : Endif
Else
    WDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
Endif
If evalue("dim([M:"+WABREV+"]DLVDATFIN)")>0
    WDATFIN=evalue("[M:"+WABREV+"]DLVDATFIN")
    WSAVDATFIN=WDATFIN
    If WPERCOD=4 WDATFIN=eomonth(WDATFIN) Endif
Else
    WDATFIN=eomonth(date$)
Endif

If evalue("dim([M:"+WABREV+"]PERNBR)")>0
    WPERNBR=evalue("[M:"+WABREV+"]PERNBR")
    WSAVPERNBR=WPERNBR
Else
#    WPERNBR=3
    If year(WDATFIN)=year(WDATDEB)
        WPERNBR=month(WDATFIN)-month(WDATDEB)+1
    Else
        WPERNBR=13-month(WDATDEB)+month(WDATFIN)
    Endif
    WPERNBR=max(1,WPERNBR)
Endif

Gosub CHARGE_CCSD

Return
###################################################################
$TIT_VISUGRHSD1
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #

If WTYP=1
    If [M:CCSD]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSD]BPCORD Endif
Elsif WTYP=2
    TIT=mess(276,195,1)
    If [M:CCSD]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSD]BPCORD Endif
Elsif WTYP=3
    TIT=mess(277,195,1)
    If [M:CCSD]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSD]BPCORD Endif
Endif

Return

###################################################################
$DEBUT_VISUGRHSD1

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #
Raz [M]
[M]CPY=[M:CCSD]CPY
[M]PERCOD=WPERCOD
[M]DLVDATDEB=WDATDEB
[M]DLVDATFIN=WDATFIN
[M]PERNBR=WPERNBR
[M]CURS=WCURS
[M]WTYP=WTYP
If [M]WTYP=2
    [M]WLIBAMT1=mess(669,197,1)
    [M]WLIBAMT2=mess(682,197,1)
Elsif WTYP=3
    [M]WLIBAMT1=mess(90,198,1)
    [M]WLIBAMT2=mess(370,198,1)
Endif

# Si la société est renseignée, le cdé HT est dans la devise société sinon il est en devise dossier
If [M:CCSD]CPY<>"" [M]CUR=[M]CURS Else [M]CUR=GSYSCUR Endif

# -- Chargement des périodes
Effzo [M]10
Gosub CHARGE_PERIODE_SGD1

[M:CCSD]DLVDATDEB=[M]DLVDATDEB
[M:CCSD]DLVDATFIN=[M]DLVDATFIN
Gosub ENTCRIT From WWCNSCSD    : # Charge [M:CSD1] à partir de [M:CCSD]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSDSTD
# -- HT Facturé
# --> Il faut que les livraisons soient validées
If WTYP=2 WFIL += "&[F:SDH]CFMFLG=2" Endif

If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGD1] ou [M:SGD3]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M]WFIL =WFIL
[M]WFIL1=WFIL1
[M]WFIL2=WFIL2
# -- Chargement des données
Gosub CHARGE_DONNEES_SGD1

Affzo [M]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSD1

Case BOUT
    When "R" :         # -- Rechargement du tableau
        # -- Chargement des périodes
        Effzo [M]10
        Gosub CHARGE_PERIODE_SGD1
        [M:CCSD]DLVDATDEB=[M]DLVDATDEB
        [M:CCSD]DLVDATFIN=[M]DLVDATFIN
        Gosub ENTCRIT From WWCNSCSD    : # Charge [M:CSD1] à partir de [M:CCSD]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGD1
        Affzo [M]10
Endcase

Return
###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSD1
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
PARAM(5)=num$(WSAVPERCOD)
PARAM(6)=num$(WSAVPERNBR)
Return

###################################################################

# -------------------------------------- #
# Chargement des périodes                #
# -------------------------------------- #
$CHARGE_PERIODE_SGD1
Local Date    WDTE
Local Integer WPER, WMOIS
Local Char    WLIB
Local Integer I, WNBPER, WCOUNT

Effzo [M]10

WDTE=[M]DLVDATDEB
WPER=[M]PERCOD

# X3-1152 : Non invoiceable deliveries
#If WTYP=3 WNBPER=([M]PERNBR-1)*3
If WTYP=3 WNBPER=([M]PERNBR-1)*4
# X3-1152 : Non invoiceable deliveries
Else      WNBPER=[M]PERNBR-1
Endif

For I = 0 To WNBPER
     If I > dim([M]WABS) - 1 : Break Endif
       WCOUNT+=1
    [M]WSTRDAT(I) = WDTE
    Gosub DET_PER_LIB From TRTVENGRH : [M]WABS(I)=WLIB
#    [M]WABS(I) = format$("D:"+GFMDAT,[M]WSTRDAT(I))
    If WTYP=3 [M]WABS(I)=[M]WABS(I)-"/"-mess(683,197,1) Endif :   # Livraisons normales

    Case [M]PERCOD
        When 1 : [M]WENDDAT(I) = WDTE                                 : # jour
        When 2 : [M]WENDDAT(I) = WDTE + (7-dayn(WDTE))                : # Semaine
        When 3 :                                                      : # Quinzaine
        When 4 : [M]WENDDAT(I) = eomonth([M]WSTRDAT(I))               : # Mois
        When 5 : WMOIS=month([M]WSTRDAT(I))                           : # Trimestre
                 Case WMOIS
                    When 1,2,3    : [M]WENDDAT(I)=gdat$(31,03,year([M]WSTRDAT(I)))
                    When 4,5,6    : [M]WENDDAT(I)=gdat$(30,06,year([M]WSTRDAT(I)))
                    When 7,8,9    : [M]WENDDAT(I)=gdat$(30,09,year([M]WSTRDAT(I)))
                    When 10,11,12 : [M]WENDDAT(I)=gdat$(31,12,year([M]WSTRDAT(I)))
                 Endcase
        When 6 : WMOIS=month([M]WSTRDAT(I))                           : # Semestre
                 Case WMOIS
                    When 1,2,3,4,5,6    : [M]WENDDAT(I)=gdat$(30,06,year([M]WSTRDAT(I)))
                    When 7,8,9,10,11,12 : [M]WENDDAT(I)=gdat$(31,12,year([M]WSTRDAT(I)))
                 Endcase
        When 7 : [M]WENDDAT(I) = gdat$(31,12,year([M]WSTRDAT(I)))     : # Année
        When 8 :                                                      : # Décade
    Endcase
    WDTE = [M]WENDDAT(I) + 1

    If WTYP=3
        I+=1 :    # Livraisons de prêt
        [M]WSTRDAT(I) = [M]WSTRDAT(I-1)
        [M]WENDDAT(I) = [M]WENDDAT(I-1)
#        [M]WABS(I)    = format$("D:"+GFMDAT,[M]WSTRDAT(I))-"/"-mess(684,197,1)
        [M]WABS(I)=WLIB-"/"-mess(684,197,1)
        I+=1 :    # Livraisons de sous-traitance
        [M]WSTRDAT(I) = [M]WSTRDAT(I-1)
        [M]WENDDAT(I) = [M]WENDDAT(I-1)
#        [M]WABS(I)    = format$("D:"+GFMDAT,[M]WSTRDAT(I))-"/"-mess(685,197,1)
        [M]WABS(I)=WLIB-"/"-mess(685,197,1)
        # X3-1152 : Non invoiceable deliveries
        I+=1
        [M]WSTRDAT(I) = [M]WSTRDAT(I-1)
        [M]WENDDAT(I) = [M]WENDDAT(I-1)
        [M]WABS(I)=WLIB-"/"-mess(4,490,1)
        # X3-1152 : Non invoiceable deliveries
    Endif
Next I
  [M]NBLIGG=WCOUNT
  # X3-1152 : Non invoiceable deliveries
  If WTYP=3
    [M]NBLIGG=WCOUNT * 4
  Endif
  # X3-1152 : Non invoiceable deliveries
Return
###################################################################
# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGD1

Local Decimal WNORAMT,WLNDAMT,WSSTAMT
Local Decimal WNINAMT           # X3-1152 : Non invoiceable deliveries
Local Decimal WINVAMT,WNINVAMT
# X3-1152 : Non invoiceable deliveries
Local Decimal WRTNAMT,WRTNNORAMT,WRTNLNDAMT,WRTNSSTAMT
Local Decimal WRTNNINAMT        # X3-1152 : Non invoiceable deliveries
Local Decimal WCNOAMT

# X3-1152 : Non invoiceable deliveries
#Local Decimal WMNTORG(0..5), WMNTDES(0..5)
Local Decimal WMNTORG(0..7), WMNTDES(0..7)
# X3-1152 : Non invoiceable deliveries

Local Integer SPSTAT, WI, WJ
Local Char    WCUR

#If GUSER="LD" Dbgaff Endif

#-- Application des Filtres
Filter [SDH] Where evalue([M]WFIL) & evalue([M]WFIL1) & evalue([M]WFIL2)

#-- lecture
$BOUCLE_SDH1
For [SDH] With Nohint

    # Filtre sur la Société
    If [M]CPY <> ""
        If [F:FCY]FCY <> [F:SDH]STOFCY  Read [F:FCY]FCY0 = [F:SDH]STOFCY
                                        If fstat  Raz [F:FCY] : Endif
                                        Endif
        If [F:FCY]LEGCPY <> [M:CCSD]CPY Goto SUIV_SDH1 : Endif
    Endif
    If [M]CPY="" & [M:CCSD]STOFCY=""
        Call GETDEV([F:SDH]STOFCY) From DEVSUB
        WCUR=GLOCALDEV
    Else
        WCUR=[M]CURS
    Endif
    Raz WNORAMT, WLNDAMT, WSSTAMT
    Raz WNINAMT       # X3-1152 : Non invoiceable deliveries
    Raz WINVAMT, WNINVAMT
    Raz WRTNNORAMT, WRTNLNDAMT, WRTNSSTAMT
    Raz WRTNNINAMT    # X3-1152 : Non invoiceable deliveries
    Case WTYP
      When 1 :
        # --------------------- #
        # HT par catégorie      #
        # --------------------- #
        # X3-1152 : Non invoiceable deliveries
        If [F:SDH]SDHCAT=4
          WNINAMT = [F:SDH]DLVNOT
        Else
        # X3-1152 : Non invoiceable deliveries
          If [F:SDH]LND=2
            WLNDAMT = [F:SDH]DLVNOT
          Elsif [F:SDH]SCO=2
            WSSTAMT = [F:SDH]DLVNOT
          Else
            WNORAMT = [F:SDH]DLVNOT
          Endif
        # X3-1152 : Non invoiceable deliveries
        Endif
        # X3-1152 : Non invoiceable deliveries
      When 2 :
        # --------------------- #
        # HT facturé/facturable #
        # --------------------- #

#Dbgaff
      # X3-1152 : Non invoiceable deliveries
      If [F:SDH]SDHCAT<>4
      # X3-1152 : Non invoiceable deliveries
        If [F:SDH]SCO<>2 & ([F:SDH]LND<>2 | ([F:SDH]LND=2 & [F:SDH]RTNSTA<>3 & [F:SDH]LNDRTNDAT<=date$))

            # Livraison normale ou Livraison de prêt non totalement retournée
            # Calcul du montant retourné
            Raz WRTNAMT
            For [F:SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM & RTNQTY<>0
                WRTNAMT+= [F:SDD]RTNQTY * [F:SDD]NETPRINOT
            Next
            Call ARRDEV (WRTNAMT, [F:SDH]CUR) From TRTDIV

            If [F:SDH]LND<>2
                # Livraison normale
                If [F:SDH]INVFLG=1
                    # Livraison non facturée : Facturable = Livré - Retourné
                    WNINVAMT=[F:SDH]DLVNOT-WRTNAMT
                Elsif WRTNAMT=0
                    # Livraison facturée et Rien n'est retourné
                    # Facturé = Livré
                    WINVAMT=[F:SDH]DLVNOT
                Else
                    # Livraison facturée et Il y a des retours
                    # Facturé = Livré - ce qui a été déduit de la facture ou ce qui a fait l'objet d'un avoir
                    Raz WCNOAMT
                    For [F:SRD]SRD1 Where SDHNUM=[F:SDH]SDHNUM & (RTNINVUPD=2 | SIHNUM<>"")
                        WCNOAMT+=[F:SRD]QTY*[F:SRD]NETPRINOT
                    Next
                    Call ARRDEV (WCNOAMT, [F:SDH]CUR) From TRTDIV
                    WINVAMT=[F:SDH]DLVNOT-WCNOAMT
                Endif
            Else
                # Livraison de prêt non retournée ou partiellement retournée
                If [F:SDH]INVFLG=1
                    # Livraison non facturée : Facturable : Livré - Retourné
                    WNINVAMT=[F:SDH]DLVNOT-WRTNAMT
                Else
                    # Livraison facturée     : Facturé    : Livré - Retourné
                    WINVAMT =[F:SDH]DLVNOT-WRTNAMT
                Endif
            Endif
        Endif
      # X3-1152 : Non invoiceable deliveries
      Endif
      # X3-1152 : Non invoiceable deliveries
      When 3 :
        # --------------------- #
        # HT retourné           #
        # --------------------- #
        # Calcul du montant retourné
        Raz WRTNAMT
        For [F:SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM & RTNQTY<>0
            WRTNAMT+= [F:SDD]RTNQTY * [F:SDD]NETPRINOT
        Next
        Call ARRDEV (WRTNAMT, [F:SDH]CUR) From TRTDIV

        # X3-1152 : Non invoiceable deliveries
        If [F:SDH]SDHCAT<>4
        # X3-1152 : Non invoiceable deliveries
            If [F:SDH]LND=2
              WLNDAMT    = [F:SDH]DLVNOT
              WRTNLNDAMT = WRTNAMT*-1
            Elsif [F:SDH]SCO=2
              WSSTAMT    = [F:SDH]DLVNOT
              WRTNSSTAMT = WRTNAMT*-1
            Else
              WNORAMT    = [F:SDH]DLVNOT
              WRTNNORAMT = WRTNAMT*-1
            Endif
        # X3-1152 : Non invoiceable deliveries
        Else
           WNINAMT    = [F:SDH]DLVNOT     ## #--LCC 107909- Nonbillable deliveries
           WRTNNINAMT = WRTNAMT*-1
        Endif
        # X3-1152 : Non invoiceable deliveries
    Endcase

    # Recherche de la période à laquelle appartient la livraison
    For WJ=0 To [M]NBLIGG-1
        If [F:SDH]DLVDAT>=[M]WSTRDAT(WJ) & [F:SDH]DLVDAT<=[M]WENDDAT(WJ) Break Endif
    Next
    If [M]WTYP=3
        # X3-1152 : Non invoiceable deliveries
        If [F:SDH]SDHCAT<>4
        # X3-1152 : Non invoiceable deliveries
          If [F:SDH]LND=2 WJ+=1 Endif
          If [F:SDH]SCO=2 WJ+=2 Endif
        # X3-1152 : Non invoiceable deliveries
        Else
          WJ+=3
        Endif
        # X3-1152 : Non invoiceable deliveries
    Endif

    If WJ<[M]NBLIGG & WJ>=0
        # Conversion des montants calculés dans la devise d'affichage
        Case WTYP
            When 1 :
                If [F:SDH]CUR <> [M]CUR
                    WMNTORG (0) = WLNDAMT
                    WMNTORG (1) = WSSTAMT
                    WMNTORG (2) = WNORAMT
                    # X3-1152 : Non invoiceable deliveries
                    WMNTORG (3) = WNINAMT
                    # X3-1152 : Non invoiceable deliveries
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(2), WMNTDES(2),SPSTAT) From TRTDEV
                    # X3-1152 : Non invoiceable deliveries
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(3), WMNTDES(3),SPSTAT) From TRTDEV # MGG
                    # X3-1152 : Non invoiceable deliveries
                    If [F:TCU]CUR <> [M]CUR
                        Read [F:TCU]TCU0 = [M]CUR
                        If fstat Raz [F:TCU] : Endif
                    Endif
                    [M:SGD1]WLNDAMT(WJ) += arr(WMNTDES(0),[F:TCU]CURRND)
                    [M:SGD1]WSSTAMT(WJ) += arr(WMNTDES(1),[F:TCU]CURRND)
                    [M:SGD1]WNORAMT(WJ) += arr(WMNTDES(2),[F:TCU]CURRND)
                    # X3-1152 : Non invoiceable deliveries
                    [M:SGD1]WNINAMT(WJ) += arr(WMNTDES(3),[F:TCU]CURRND)
                    # X3-1152 : Non invoiceable deliveries
                Else
                    [M:SGD1]WLNDAMT(WJ) += WLNDAMT
                    [M:SGD1]WSSTAMT(WJ) += WSSTAMT
                    [M:SGD1]WNORAMT(WJ) += WNORAMT
                    # X3-1152 : Non invoiceable deliveries
                    [M:SGD1]WNINAMT(WJ) += WNINAMT
                    # X3-1152 : Non invoiceable deliveries
                Endif
            When 2 :
                If [F:SDH]CUR <> [M]CUR
                    WMNTORG (0) = WINVAMT
                    WMNTORG (1) = WNINVAMT
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
                    If [F:TCU]CUR <> [M]CUR
                        Read [F:TCU]TCU0 = [M]CUR
                        If fstat Raz [F:TCU] : Endif
                    Endif
                    [M]WAMT1(WJ) += arr(WMNTDES(0),[F:TCU]CURRND)
                    [M]WAMT2(WJ) += arr(WMNTDES(1),[F:TCU]CURRND)
                Else
                    [M]WAMT1(WJ) += WINVAMT
                    [M]WAMT2(WJ) += WNINVAMT
                Endif
            When 3
                If [F:SDH]CUR <> [M]CUR
                    WMNTORG (0) = WNORAMT
                    WMNTORG (1) = WRTNNORAMT
                    WMNTORG (2) = WLNDAMT
                    WMNTORG (3) = WRTNLNDAMT
                    WMNTORG (4) = WSSTAMT
                    WMNTORG (5) = WRTNSSTAMT
                    # X3-1152 : Non invoiceable deliveries
                    WMNTORG (6) = WNINAMT
                    WMNTORG (7) = WRTNNINAMT
                    # X3-1152 : Non invoiceable deliveries
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(2), WMNTDES(2),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(3), WMNTDES(3),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(4), WMNTDES(4),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(5), WMNTDES(5),SPSTAT) From TRTDEV
                    # X3-1152 : Non invoiceable deliveries
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(6), WMNTDES(6),SPSTAT) From TRTDEV
                    Call CONVERT2([F:SDH]CUR, [M]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(7), WMNTDES(7),SPSTAT) From TRTDEV
                    # X3-1152 : Non invoiceable deliveries
                    If [F:TCU]CUR <> [M]CUR
                        Read [F:TCU]TCU0 = [M]CUR
                        If fstat Raz [F:TCU] : Endif
                    Endif
                    [M]WAMT1(WJ) += arr(WMNTDES(0),[F:TCU]CURRND)
                    [M]WAMT2(WJ) += arr(WMNTDES(1),[F:TCU]CURRND)
                    [M]WAMT1(WJ) += arr(WMNTDES(2),[F:TCU]CURRND)
                    [M]WAMT2(WJ) += arr(WMNTDES(3),[F:TCU]CURRND)
                    [M]WAMT1(WJ) += arr(WMNTDES(4),[F:TCU]CURRND)
                    [M]WAMT2(WJ) += arr(WMNTDES(5),[F:TCU]CURRND)
                    # X3-1152 : Non invoiceable deliveries
                    [M]WAMT1(WJ) += arr(WMNTDES(6),[F:TCU]CURRND)
                    [M]WAMT2(WJ) += arr(WMNTDES(7),[F:TCU]CURRND)
                    # X3-1152 : Non invoiceable deliveries
                Else
                    [M]WAMT1(WJ) += WNORAMT
                    [M]WAMT2(WJ) += WRTNNORAMT
                    [M]WAMT1(WJ) += WLNDAMT
                    [M]WAMT2(WJ) += WRTNLNDAMT
                    [M]WAMT1(WJ) += WSSTAMT
                    [M]WAMT2(WJ) += WRTNSSTAMT
                    # X3-1152 : Non invoiceable deliveries
                    [M]WAMT1(WJ) += WNINAMT
                    [M]WAMT2(WJ) += WRTNNINAMT
                    # X3-1152 : Non invoiceable deliveries
                Endif
        Endcase
    Endif

  $SUIV_SDH1
Next
Filter [SDH]

Return

###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSD2                       #
#                                                                 #
###################################################################
###################################################################
$OUVRE_VISUGRHSD2

Local Date    WSAVDATDEB            :    # Date début
Local Date    WSAVDATFIN            :    # Date fin

Local Char    WCURS(GLONCUR)        :    # Devise société
Local Char    WCURD(GLONCUR)        :    # Devise dossier

Local Char    WPROGSPE(GLONADC)     :    # Nom du programme spécifique
Local Integer WOK

# Variables communes avec la consultation commande
Local Integer  CHGPAG      : CHGPAG=1
Local Char     WFIL(250), WFIL1(250), WFIL2(250)

# Abréviation du masque contenant les critères ("DIA" ou "CCSD")
# -- > "DIA"  : On vient de la fonction graphique Palmarès livraison
# -- > "CCSD" : On vient de la consultation livraison
Local Char WABREV : WABREV=PARAM(1)
# -- > 1 : Palmarès motif retour
Local Integer WTYPTIERS : WTYPTIERS=val(PARAM(2))

Gosub OUVRE

# Ouverture systématique des écrans consultations livraisons
# --> Pour pouvoir exploiter l'action FILTRE spécifique
# --> (Pour pouvoir évaluer   les filtres depuis les actions champs)
If WABREV<>"CCSD"
   If !clalev([M:CSD1])  Local Mask CONSCSD1 [CSD1] : Endif
   If !clalev([M:CCSD])  Local Mask CRITCSD  [CCSD] : Endif
Endif

# -------------------------------------------------------------------------- #
# Récupération des paramètres de l'écran                                     #
# -------------------------------------------------------------------------- #
Gosub CHARGE_CCSD

WSAVDATDEB=evalue("[M:"+WABREV+"]DlVDATDEB")
WSAVDATFIN=evalue("[M:"+WABREV+"]DLVDATFIN")

Return
###################################################################
$TIT_VISUGRHSD2
# -------------------------------------------------------------------------- #
# Changement du titre de la fenêtre                                          #
# -------------------------------------------------------------------------- #

If WTYPTIERS=1 TIT=mess(278,195,1) Endif
If [M:CCSD]BPCORD<>"" TIT=TIT-mess(99,197,1)-[M:CCSD]BPCORD Endif

Return

###################################################################
$DEBUT_VISUGRHSD2

# -------------------------------------------------------------------------- #
# Chargement de l'écran graphique                                            #
# -------------------------------------------------------------------------- #
Raz [M:SGD2]
[M:SGD2]CPY=[M:CCSD]CPY
[M:SGD2]DLVDATDEB=[M:CCSD]DLVDATDEB
[M:SGD2]DLVDATFIN=[M:CCSD]DLVDATFIN
[M:SGD2]CURS=WCURS
[M:SGD2]WTYPTIERS=WTYPTIERS

# Si la société est renseignée, le montant HT est dans la devise société sinon il est en devise dossier
If [M:CCSD]CPY<>"" [M:SGD2]CUR=[M:SGD2]CURS Else [M:SGD2]CUR=GSYSCUR Endif

Gosub ENTCRIT From WWCNSCSD    : # Charge [M:CSD1] à partir de [M:CCSD]
# -- Positionnement des Filtres
Gosub LOAD_FILTER From CNSCSDSTD
# -- Palmarès représentant

If WPROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =WPROGSPE
Endif
# -- Sauvegarde des filtres ds [M:SGD2]
# --> Pr pouvoir les utiliser depuis les actions chps (Periodicité, date début, nbr période)
[M:SGD2]WFIL =WFIL
[M:SGD2]WFIL1=WFIL1
[M:SGD2]WFIL2=WFIL2
# -- Chargement des données
Gosub CHARGE_DONNEES_SGD2

Affzo [M:SGD2]1-99

Return

###################################################################
# -------------------------------------------------------------------------- #
# Rechargement du tableau des donnees                                        #
# -------------------------------------------------------------------------- #
$BOUT_VISUGRHSD2

Case BOUT
    When "R" :
        # -- Chargement des données
        [M:CCSD]DLVDATDEB=[M:SGD2]DLVDATDEB
        [M:CCSD]DLVDATFIN=[M:SGD2]DLVDATFIN
        Gosub ENTCRIT From WWCNSCSD    : # Charge [M:CSD1] à partir de [M:CCSD]
        # -- Chargement des données
        Gosub CHARGE_DONNEES_SGD2

        Affzo [M:SGD2]10
Endcase

Return

###################################################################
# -------------------------------------------------------------------------- #
# Restitution des critères de date de départ                                 #
# -------------------------------------------------------------------------- #
$FIN_VISUGRHSD2
PARAM(3)=WSAVDATDEB
PARAM(4)=WSAVDATFIN
Return

###################################################################
# -------------------------------------- #
# Chargement des données                 #
# -------------------------------------- #
$CHARGE_DONNEES_SGD2

Local Decimal WRTNAMT

Local Decimal WMNTORG(0..2), WMNTDES(0..2)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR

Local Char    WRTNREN(GLONADI)

#Dbgaff
Effzo [M:SGD2]10
#-- Application des Filtres
Case [M:SGD2]WTYPTIERS
    When 1 :
        Filter [SDH] Where evalue([M:SGD2]WFIL) & evalue([M:SGD2]WFIL1) & evalue([M:SGD2]WFIL2)
&                    Order By Key SDH1
Endcase
#-- lecture
$BOUCLE_SDH2
For [SDH] With Nohint

    # Filtre sur la société
    If [M:SGD2]CPY <> ""
        If [F:FCY]FCY <> [F:SDH]STOFCY  Read [F:FCY]FCY0 = [F:SDH]STOFCY
                                        If fstat  Raz [F:FCY] : Endif
                                        Endif
        If [F:FCY]LEGCPY <> [M:CCSD]CPY Goto SUIV_SDH2 : Endif
    Endif

    If [M:SGD2]CPY="" & [M:CCSD]STOFCY=""
        Call GETDEV([F:SDH]STOFCY) From DEVSUB
        WCUR=GLOCALDEV
    Else
        WCUR=[M:SGD2]CURS
    Endif

    For [F:SRD]SRD0 Where SDHNUM=[F:SDH]SDHNUM & RTNREN<>""

        WRTNAMT= [F:SRD]QTY * [F:SRD]NETPRINOT
        WJ=find ([F:SRD]RTNREN, [M:SGD2]WABS(0..[M:SGD2]NBLIGG-1))
        If WJ=0 & [M:SGD2]NBLIGG<dim([M:SGD2]WABS)
            [M:SGD2]NBLIGG+=1
            WJ=[M:SGD2]NBLIGG
            [M:SGD2]WABS(WJ-1)=[F:SRD]RTNREN
        Endif
        If WJ>0
            # Conversion des montants calculés dans la devise d'affichage
            If [F:SDH]CUR <> [M:SGD2]CUR
                Case WTYPTIERS
                    When 1 :
                        WMNTORG (0) = WRTNAMT
                        Call CONVERT2([F:SDH]CUR, [M:SGD2]CUR, WCUR, [F:SDH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
                        If [F:TCU]CUR <> [M:SGD2]CUR
                            Read [F:TCU]TCU0 = [M:SGD2]CUR
                            If fstat Raz [F:TCU] : Endif
                        Endif
                        [M:SGD2]WAMT(WJ-1) += arr(WMNTDES(0),[F:TCU]CURRND)
                Endcase
            Else
                Case WTYPTIERS
                    When 1 :
                        [M:SGD2]WAMT(WJ-1) += WRTNAMT
                Endcase
            Endif
        Endif
    Next

    $SUIV_SDH2
Next
Filter [SDH]

# Une fois le chargement terminé, il faut enlever les valeurs négatives du graph
If [M:SGD2]NBLIGG>0
    Sorta [M:SGD2]NBLIGG [M:SGD2]NBLIGG Order By [M:SGD2]WAMT(indice)*-1
    While [M:SGD2]WAMT([M:SGD2]NBLIGG-1)<0
        #Raz [M:SGD2]WAMT([M:SGD2]NBLIGG-1), [M:SGD2]WABSBPR([M:SGD2]NBLIGG-1)
        Raz [M:SGD2]WAMT([M:SGD2]NBLIGG-1), [M:SGD2]WABS([M:SGD2]NBLIGG-1)     # FGR 22/12/2009 : X3SUIVI60986
        [M:SGD2]NBLIGG-=1
        If [M:SGD2]NBLIGG=0 Break Endif
    Wend
Endif

Return
###################################################################
###################################################################
#                                                                 #
#        TRAITEMENTS LIES ACTION VISUGRHSD1 VISUGRHSD3            #
#                                VISUGRHSD2                       #
#                                                                 #
###################################################################

# -------------------------------------------------------------------------- #
# Chargement systématique des écrans consultations livraison                 #
# --> Pour pouvoir exploiter l'action FILTRE spécifique                      #
# --> Pour pouvoir évaluer   les filtres depuis les actions champs           #
# -------------------------------------------------------------------------- #
$CHARGE_CCSD

If WABREV<>"CCSD"
   [M:CCSD]CPY      =evalue("[M:"+WABREV+"]CPY")
   [M:CCSD]STOFCY   =evalue("[M:"+WABREV+"]STOFCY")
   [M:CCSD]BPCORD   =evalue("[M:"+WABREV+"]BPCORD")
   [M:CCSD]SDHNUMDEB=evalue("[M:"+WABREV+"]SDHNUMDEB")
   [M:CCSD]SDHNUMFIN=evalue("[M:"+WABREV+"]SDHNUMFIN")
   [M:CCSD]DLVDATDEB=evalue("[M:"+WABREV+"]DLVDATDEB")
   [M:CCSD]DLVDATFIN=evalue("[M:"+WABREV+"]DLVDATFIN")
   [M:CCSD]LNDO     =evalue("[M:"+WABREV+"]LNDO")
   [M:CCSD]LNDN     =evalue("[M:"+WABREV+"]LNDN")
   [M:CCSD]CFMFLGO  =evalue("[M:"+WABREV+"]CFMFLGO")
   [M:CCSD]CFMFLGN  =evalue("[M:"+WABREV+"]CFMFLGN")
   [M:CCSD]INVFLGO  =evalue("[M:"+WABREV+"]INVFLGO")
   [M:CCSD]INVFLGN  =evalue("[M:"+WABREV+"]INVFLGN")
   [M:CCSD]RTNFLGO  =evalue("[M:"+WABREV+"]RTNFLGO")
   [M:CCSD]RTNFLGN  =evalue("[M:"+WABREV+"]RTNFLGN")
   #Gbn-Fq75851
   If evalue("dim([M:"+WABREV+"]BETFCYFLG)>0")
    [M:CCSD]BETFCYFLG = evalue("[M:"+WABREV+"]BETFCYFLG")
   Endif
   If evalue("dim([M:"+WABREV+"]SCOFLG)>0")
    [M:CCSD]SCOFLG = evalue("[M:"+WABREV+"]SCOFLG")
   Endif
   # X3-1152 : Non invoiceable deliveries
   If evalue("dim([M:"+WABREV+"]NONINV)>0")
    [M:CCSD]NONINV = evalue("[M:"+WABREV+"]NONINV")
   Endif
   # X3-1152 : Non invoiceable deliveries
Endif

If !find([M:CCSD]LNDO,1,2)    : [M:CCSD]LNDO = 2    : Endif
If !find([M:CCSD]LNDN,1,2)    : [M:CCSD]LNDN = 2    : Endif
If !find([M:CCSD]CFMFLGO,1,2) : [M:CCSD]CFMFLGO = 2 : Endif
If !find([M:CCSD]CFMFLGN,1,2) : [M:CCSD]CFMFLGN = 2 : Endif
If !find([M:CCSD]INVFLGO,1,2) : [M:CCSD]INVFLGO = 2 : Endif
If !find([M:CCSD]INVFLGN,1,2) : [M:CCSD]INVFLGN = 2 : Endif
If !find([M:CCSD]RTNFLGO,1,2) : [M:CCSD]RTNFLGO = 2 : Endif
If !find([M:CCSD]RTNFLGN,1,2) : [M:CCSD]RTNFLGN = 2 : Endif
If !find([M:CCSD]BETFCYFLG,1,2) : [M:CCSD]BETFCYFLG = 2 : Endif #Gbn-Fq75851
If !find([M:CCSD]SCOFLG,1,2) : [M:CCSD]SCOFLG = 2 : Endif #Gbn-Fq75851
If !find([M:CCSD]NONINV,1,2) : [M:CCSD]NONINV = 2 : Endif # X3-1152 : Non invoiceable deliveries

# -- Récupération du nom du traitement spécifique pour pouvoir utiliser l'action FILTRE
Read [ACN] ACN0="CSD" : If fstat  Raz [F:ACN] : Endif
WPROGSPE=[F:ACN]PRGSPE
If WPROGSPE<>""
  Call EXISTE_ADX("","",WPROGSPE,WOK) From ORDSYS
  If !WOK  WPROGSPE="" : Endif
Endif

# -------------------------------------------------------------------------- #
# Analyse paramères, initialisations                                         #
# -------------------------------------------------------------------------- #
If [M:CCSD]STOFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CCSD]STOFCY,GUSRFCY(1..GNBAUZ)) [M:CCSD]STOFCY="" Endif

If [M:CCSD]BPCORD <> "" : # Parametre Client
    If [F:BPC]BPCNUM<>[M:CCSD]BPCORD Read [F:BPC]BPC0 = [M:CCSD]BPCORD
                                     If fstat Raz [F:BPC], [M:CCSD]BPCORD Endif
    Endif
Endif

If [M:CCSD]STOFCY <> "" : # Paramètre Site
    If [F:FCY]FCY <> [M:CCSD]STOFCY  Read [F:FCY]FCY0 = [M:CCSD]STOFCY
                                     If fstat Raz [F:FCY], [M:CCSD]STOFCY Endif
    Endif
    If GUSRFCY(1)="\" | find([M:CCSD]STOFCY,GUSRFCY(1..GNBAUZ))
        If [M:CCSD]STOFCY <> ""
             Call GETDEV([M:CCSD]STOFCY) From DEVSUB
             [M:CCSD]CPY  = GSOCIETE
             WCURS = GLOCALDEV
        Endif
    Endif
Elsif [M:CCSD]CPY<>""
    If [F:CPY]CPY <> [M:CCSD]CPY  Read [F:CPY]CPY0 = [M:CCSD]CPY
                           If fstat Raz [F:CPY], [M:CCSD]CPY Endif
    Endif
    WCURS = [F:CPY]ACCCUR
Endif

Return

