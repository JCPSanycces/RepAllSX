End

#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK
Local Integer COUNT

ERROR = func ASYRDELSYS.CREATE_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT,PSYR.CODREP,PSYR.SELREP,"UPDATE")
If ERROR = [V]CST_AOK
 ERROR = func  UPD(ACTX,ASWK(COUNT),PSYR,ARCV,JSON,ASND)
Endif
End ERROR

#**
#* Funprog HANDLER_GET()
#* Request update management for mobiles (GET)
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Instance LASWK  Using C_ASYRWRK
Local Instance  JSON        Using C_ASYRJSO
JSON = null

LASWK = NewInstance  C_ASYRWRK AllocGroup null
LASWK.TRCKID  = NullUuid
LASWK.NUMWRK  = -1
LASWK.REPRES  = PSYR.CODREP
LASWK.REPNAM  = "REP0"
LASWK.KEYURL  = PSYR.SELREP
LASWK.REQUEST = "UPDATE"
LASWK.NUMWRK  = 0
ERROR = func  UPD(ACTX,LASWK,PSYR,ARCV,JSON,ASND)

FreeGroup LASWK

End ERROR

#------------------------------------------------------------#
# Request update management (POST)
#------------------------------------------------------------#

#------------------------------------------------------#
# Update
#------------------------------------------------------#

Funprog UPD(ACTX,ASWK,PSYR,ARCV,NODE,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK Using C_ASYRWRK
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance NODE Using C_ASYRJSO
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK


Local Integer I , J , NUMLIN , ASTATUS, ASTAERR
Local Uuident UIDINS , UID
Local Char    INSFAT(250)
Local Char    REPNAM(20) , GRPINS(20)
Local Char    PRGREP(30) , PRGEXE(30)
Local Char    CHAINE(250)

Raz ASND.DATA

Local Instance REP      Using C_AREPENT
Local Instance WREP     Using ="R_"+ASWK.REPRES
Local Instance UPD(1..) Using C_ADELTA    : # Delta values of properties initialized
Local Instance BUT(1..) Using C_ADELTABUT : # Delta button
Local Instance ULN(1..) Using C_ADELTALIN : # Uncommitted lines of collection by the serveur

#--------------------------------------------------#
# Load json presentation (metadata & data)
#--------------------------------------------------#
PRGREP = func SUBASW.PREFIX_TRT+ASWK.REPRES : # WMREP

REPNAM = ASWK.REPNAM
GRPINS = REPNAM
Call DESCRIPTION_REPRESENTATION(REP,REPNAM) From =PRGREP

If dim(REP.AENAFAC)>0 & REP.AENAFAC(2)>=1 & REP.AENAFAC(2)<>2
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_CONFLICT,func ASYRFNC.MES2(mess(14,149,1),PSYR.CODFAC,PSYR.CODREP))
 Goto RESPONSE
Endif

ASWK.METCLA = REP

PRGEXE = func ACLAVALCRUD.GET_PREFIX_REP_READ+REP.REP

# Create instance representation

WREP = evalue ("Newinstance ["+REPNAM+"] , R_"+REP.REP+'(GACTX,UIDINS,NUMLIN,null,"")')
ASWK.DATCLA = WREP

# Load parameters of url

Call SET_REP_PARAMETERS(WREP,ARCV) From ASYRMAIN

# Load data (Read from CRUD)
Call _AREADSUP(WREP,ASWK.KEYURL,ASTATUS) From =PRGEXE
Gosub ATEST_AERROR

ASTATUS = fmet WREP.AGETWRIGHTU
Gosub ATEST_AERROR

# Control lock record X3 session (to do)

WREP.setAccessorEnabled = 0

# uuid instance
CHAINE = "WREP."+REP.ICL+".AUUID"
If evalue("dim("+CHAINE+")")>0
 UID = evalue(CHAINE)
Else
 UID = NullUuid
Endif

#-----------------------------------------------------------------------#
# Deltas returned by Syracuse (in the case of a broken working copy)
#-----------------------------------------------------------------------#

If NODE<>null
 ASTATUS = func ASYRDEL.PARSEDELTA(GACTX,NODE,UPD)
 If GTRASYR : Gosub TRACE_RECEIVE_DELTA : Endif

 If maxtab(UPD)>0
  WREP.setAccessorEnabled = 1
  Call SET_SYSSNAPSHOT(WREP,1) From ASYRDELSYS
  Call SET_REPRESENTATION(REP,WREP,UPD,ULN) From ASYRDELCLI
  FreeInstance [UPD]
  Local Instance  UPD(1..) Using C_ADELTA
  Call LOAD_DELTA(WREP,REP,UPD,ULN) From ASYRDELSRV
  Call SET_SYSSNAPSHOT(WREP,0) From ASYRDELSYS
  WREP.setAccessorEnabled = 0
  FreeInstance [UPD]
  Local Instance  UPD(1..) Using C_ADELTA
 Endif
Endif

#--------------------------------------------------------------------------#
# Load delta classe with contents classe data and representation
#--------------------------------------------------------------------------#

Call COLLECTION_UUID(REP,WREP,UPD,"",UID) From ASYRUID

#------------------------------#
# Load buttons from prototype
#------------------------------#

Call LOAD_BUTTON(UPD,REP) From ASYRDELSYS

#---------------------------------------------#
# Disable key properties (isReadOnly=true)
#---------------------------------------------#

#For I=1 To maxtab(REP.CLE)
# If REP.CLE(I).PRO<>""
#  Call MAJ_ATTRIBUT(UPD,1,0,NullUuid,UID,0,"",REP.CLE(I).PRO,func ASYRSUB.CODATT("R"),func ASYRSUB.BOOLEAN_TO_SYR(2)) From ASYRDELSYS
# Endif
#Next I

# BUG 101750 CCL
For I=1 To maxtab(REP.PRO)
 If REP.PRO(I).PRO<>"" & REP.PRO(I).REP<>""
  For J=1 To maxtab(REP.CLE)
   If REP.ICL+"."+REP.CLE(J).PRO = REP.PRO(I).PTH
    Call MAJ_ATTRIBUT(UPD,1,0,NullUuid,UID,0,"",REP.PRO(I).PRO,func ASYRSUB.CODATT("R"),func ASYRSUB.BOOLEAN_TO_SYR(2)) From ASYRDELSYS
   Endif
  Next
 Endif
Next I



#--------------------------------------------------------------------------------------#
# Enable buttons ($save, $abort, etc.) & choices of buttons ($detail, $query, etc.)
#--------------------------------------------------------------------------------------#

# Where is the link ?
#--------------------------
# 1 Property
# 2 Line de collection
# 3 Collection
# 4 Page
# 5 Fiche/Enregistrement

# Links Type
#----------------------------#
# 1 Link
# 2 Method
# 3 Operation
# 4 Link X3

For I=1 To maxtab(REP.LNK)
 # Method or $links with action=save,abort
 If REP.LNK(I)<>null & find(REP.LNK(I).AFF,4,5) & REP.LNK(I).EDT=2
&                    & (REP.LNK(I).TYP=2 or (REP.LNK(I).TYP=1 & find(REP.LNK(I).CMP,17,18)))
  # isHidden/false
  Call MAJ_ATTRIBUT(UPD,3,0,NullUuid,UID,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
  # isDisable/false
  Call MAJ_ATTRIBUT(UPD,3,0,NullUuid,UID,0,"",REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
  For J=1 To maxtab(REP.LNK(I).LNK)
   If REP.LNK(I).LNK(J)<>null
    # isHidden/false
    Call MAJ_ATTRIBUTLNK(UPD,3,0,NullUuid,UID,0,"",REP.LNK(I).COD,REP.LNK(I).LNK(J).COD,func ASYRSUB.CODATT("H")
&   ,func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
   Endif
  Next J
 Endif
Next I

#------------------------------------------#
# JSON generation
#------------------------------------------#

ASWK.NUMWRK += 1
Call DETAIL_JSON(REP,WREP,ASWK,PSYR,UPD,ASND.DATA) From ASYRDATDEL

WREP.setAccessorEnabled = 1

#----------------------------------------------------------#
# Send delta init properties of representation
#----------------------------------------------------------#
ASND.URL      = PSYR.PREFIX+'/'+PSYR.URLUPD+"('"+num$(ASWK.TRCKID)+"')"+PSYR.URLREP+ASWK.REPRES+".$edit"
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+ASWK.REPRES+".$edit"

$RESPONSE
End ERROR

#------------------------------------------#
# Error response
#------------------------------------------#



$ATEST_AERROR
ASTAERR = fmet WREP._AERROR(ACTX,2)
If ASTATUS>CST_AOK :  Goto RESPONSE : Endif
Return

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

$LEC_UPD
Call OUVRE_TRACE("test classe delta") From LECFIC
Local Char WCHAINE(110)
For I=1 To maxtab(UPD)
 If UPD(I)<>null
  WCHAINE = "col="+UPD(I).COL-"index="+num$(UPD(I).IND)-"pro="+UPD(I).PRO
  If UPD(I).CHR<>null
   WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR)
  Endif
  WCHAINE -= "cat="+num$(UPD(I).CAT)
  WCHAINE -= "uuid="+num$(UPD(I).UID)
  If left$(num$(UPD(I).UIDPAR),4)<>"0000"
   WCHAINE -= "uuid parent="+num$(UPD(I).UIDPAR)
  Endif
  Call ECR_TRACE(WCHAINE,-1) From GESECRAN
  For J=1 To maxtab(UPD(I).ATT)
   Call ECR_TRACE("att="+UPD(I).ATT(J).COD+"/"+UPD(I).ATT(J).ATT,0) From GESECRAN
  Next J
  For J=1 To maxtab(UPD(I).ERR)
   Call ECR_TRACE("err="+num$(UPD(I).ERR(J).STA)+"/"+UPD(I).ERR(J).MES+"/"+num$(UPD(I).ERR(J).NUM),0) From GESECRAN
  Next J
 Endif
Next I
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

#--------------------------------#
$TRACE_RECEIVE_DELTA
Call TRACE("asyrupd-receive-delta"-"MAXTAB(upd)="+num$(maxtab(UPD))) From ASYRCOM

$TRACE
For I=1 To maxtab(UPD)
 WCHAINE = "col="+UPD(I).COL-"pro="+UPD(I).PRO-"ind="+num$(UPD(I).IND)-"cat="+num$(UPD(I).CAT)
 WCHAINE -= "uuid="+num$(UPD(I).UID)-"uuif="+num$(UPD(I).UIDPAR)
 If UPD(I).CHR<>null : WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR) : Endif
 Call TRACE(WCHAINE) From ASYRCOM
 For J=1 To maxtab(UPD(I).ATT)
  Call TRACE("att"-UPD(I).ATT(J).COD-"value="+UPD(I).ATT(J).ATT) From ASYRCOM
 Next J
 For J=1 To maxtab(UPD(I).ERR)
  Call TRACE("err"-UPD(I).ERR(J).MES-"sta="+num$(UPD(I).ERR(J).STA)-"num="+num$(UPD(I).ERR(J).NUM)) From ASYRCOM
 Next J
Next I
Call TRACE("end data") From ASYRCOM
Return
