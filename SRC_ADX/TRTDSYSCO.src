#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# TRTDSYSCO: Affichage situation d'un article lancé SCO    selon SUBPDQ6 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action         #
# VISUETASCO et sert à gérer le masque  écran "PDSYSCO [PDQ6]"           #
# GA 09/2006 remplacement de "PDSYSCO [PDQ6]"                            #
#            par PDSYSCO0 [PDS0]     Situation Article lancé             #
#                PDSYSCO1 [PDS1]     Commandes/Factures                  #
#                PDSYSCO3 [PDS3]     Liv/Retours matières 03/2009        #
#                PDSYSCO2 [PDS2]     Réceptions/Retours                  #
##########################################################################
# Issue GA 06/2014 new action for WO: VISUETASST
##########################################################################
$ACTION
#---------------------------------------------------------------------#
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# VISUETASCO : Affichage situation ordre de sous-traitance            #
#---------------------------------------------------------------------#
Case GACTION
   When "VISUETASCO" :
      Case ACTION
       When "OUVRE"       : Gosub OUV_VISUETASCO
       When "TITRE"       : Gosub TITRE_VISUETASCO
       When "DEBUT"       : Gosub DEB_VISUETASCO
       When "FINSAI"      : Gosub FINSAI_VISUETASCO
       When "BB1_NBCOM"   : Gosub BB1_NBCOM
      Endcase
   When "VISUETASST" :
      Case ACTION
       When "OUVRE"       : Gosub OUV_VISUETASST
       When "TITRE"       : Gosub TITRE_VISUETASST
       When "DEBUT"       : Gosub DEB_VISUETASST
       When "FINSAI"      : Gosub FINSAI_VISUETASST
       When "BB1_NBCOM"   : Gosub BB1_NBCOM
      Endcase
Endcase
Return

#############################################################################
# Remplacé par l'action VISUETASCO avec paramètres :                        #
#   PARAM(1) = SCONUM : Numéro   de l'ordre de sous-traitance à traiter     #
#   PARAM(2) = SCILIN : Numéro   de la ligne article                        #
#   PARAM(3) = WABMSK : Abréviation du masque écran contenant les lignes    #
#   PARAM(4) = NOLIG  : Numéro de ligne tableau lignes commande (nolign-1)  #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETASCO
#----- Variables locales -----#
Local Char     WVCRNUM(GLONVCR) : WVCRNUM=PARAM(1)
Local Integer  WVCRLIN          : WVCRLIN=val(PARAM(2))
Local Char     WABMSK(4)        : WABMSK =PARAM(3)
#Local Shortint NOL             : NOL=val(PARAM(4))
Local Decimal  WPUUSTUCOE       : WPUUSTUCOE = 1
Local Char     WPUU(GLONUOM), WSTU(GLONUOM)
Local Shortint SAVGNOLIGN, I, J, CPT, LIG_CPT
Local Shortint ICOM,IRCP,IRET,IFAC
Local Shortint ISDH,ISRH           # FQ 52924 GA 05/03/2009
#SAVNOLIGN=nolign
#If evalue("[M:"+WABMSK+"]NBLIG=0") |
#&  evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") | GREP="C" | GREP="D"
If evalue("[M:"+WABMSK+"]BPRNUM=''") |
&  evalue("[M:"+WABMSK+"]ITMREF=''") |
&  evalue("[M:"+WABMSK+"]SCONUM=''") | GREP="C" | GREP="D"
  FIN=1
Endif
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_VISUETASCO
TIT=mess(348,194,1)- " " -[F:SCI]SCONUM - " " - [F:SCI]ITMREF
# Issue 100671 GA 12/2014 done also in Action TITRE else field title is not ok
[M:PDS0]VCRTYP=36
[M:PDS0]VCRNUM=WVCRNUM
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETASCO
Raz [M:PDS0] :
Raz [M:PDS1] : Raz [M:PDS2]
Raz [M:PDS3] # Issue 86702 GA 12/2012 :-(
Call TEMPON("O") From GESECRAN

Gosub OPEN_FILES_PUR

#----- Lecture ordre de sous-traitance si nécessaire -----#
If [F:SCO]SCONUM<>WVCRNUM
  Read [SCO] SCO0=WVCRNUM  : If fstat Raz [F:SCO] : Endif
Endif
#----- Lecture article lancé à traiter si nécessaire -----#
If [F:SCI]SCONUM<>WVCRNUM | [F:SCI]SCILIN<>WVCRLIN
  Read [SCI] SCI0=WVCRNUM;WVCRLIN  : If fstat Raz [F:SCI] : Endif
Endif
#----- Lecture du Service si nécessaire -----# FQ 56565 GA 07/2009
If [F:SCS]SCONUM<>WVCRNUM | [F:SCI]SCILIN<>WVCRLIN
  Read [SCS] SCS0(2)=WVCRNUM;WVCRLIN  : If fstat Raz [F:SCS] : Endif
Endif
#----- Chargement des zones dans le masque -----#
[M:PDS0]=[F:SCI]
# done also in Action TITRE else field title is not ok
[M:PDS0]VCRTYP=36
[M:PDS0]VCRNUM=WVCRNUM

# TEMPORAIRE: Coef/Unité => Conversions à revoir ...
WPUU = [F:SCI]PUU
WSTU = [F:SCI]STU
WPUUSTUCOE = [F:SCI]PUUSTUCOE
If WPUUSTUCOE=0 : WPUUSTUCOE=1 : Endif
# TEMPORAIRE: Fin

If [F:ITF]ITMREF<>[F:SCI]ITMREF | [F:ITF]STOFCY<>[F:SCI]PRHFCY
  Read [ITF]ITF0=[F:SCI]ITMREF;[F:SCI]PRHFCY
  If fstat : Raz [F:ITF]ITMREF : Endif
Endif

#--- Pour les articles gérés en stock on regarde les mouvements
If [F:ITF]STOMGTCOD>1
  Raz GBIDD1, GBIDD2, GBIDD3
# VCRTYP Menu 701 => 6=Réception fournisseur
  For [STJ1]STJ1 Where STOFCY    = [F:SCI]PRHFCY &
&                      VCRTYP    = 6             &
&                      VCRTYPORI = 36            &
&                      VCRNUMORI = [F:SCI]SCONUM &
&                      VCRLINORI = [F:SCI]SCILIN &
&                      ITMREF    = [F:SCI]ITMREF &
&                      UPDCOD = 2                &
&                      REGFLG <>2
    If [F:STJ1]QTYSTU<>0
      If left$([F:STJ1]STA,1)="A"
        GBIDD1+=[F:STJ1]QTYSTU
      Elsif left$([F:STJ1]STA,1)="Q"
        GBIDD2+=[F:STJ1]QTYSTU
      Elsif left$([F:STJ1]STA,1)="R"
        GBIDD3-=[F:STJ1]QTYSTU         # FQ 51330 GA 01/2009 le signe est inversé -1/+1
      Endif

# Issue 94690 GA 11/2013 tenir compte LOT/SLO
#     VCRTYP Menu 701 => 8=Retour fournisseur rattaché à la Rcp courante GA 11/2008
      For [STJ2]STJ1 Where STOFCY    = [F:STJ1]STOFCY &
&                          VCRTYP    = 8              &
&                          VCRTYPORI = 6              &
&                          VCRNUMORI = [F:STJ1]VCRNUM &
&                          VCRLINORI = [F:STJ1]VCRLIN &
&                          ITMREF    = [F:STJ1]ITMREF &
&                          LOT       = [F:STJ1]LOT    &
&                          SLO       = [F:STJ1]SLO    &
&                          UPDCOD = 2                 &
&                          REGFLG <>2
        If [F:STJ2]QTYSTU<>0
          If left$([F:STJ2]STA,1)="A"
            GBIDD1+=[F:STJ2]QTYSTU
          Elsif left$([F:STJ2]STA,1)="Q"
            GBIDD2+=[F:STJ2]QTYSTU
          Elsif left$([F:STJ2]STA,1)="R"
            GBIDD3-=[F:STJ2]QTYSTU         # FQ 51330 GA 01/2009 le signe est inversé -1/+1
          Endif
        Endif

      Next
    Endif
  Next
#
  [M:PDS0]AAAQTY   =GBIDD1
  GBIDD1=GBIDD1/WPUUSTUCOE
  Call QTEARR(GBIDD1, WPUU) From TRTDIV
  [M:PDS0]AAAQTYPUU=GBIDD1
#
  [M:PDS0]QQQQTY   =GBIDD2
  GBIDD2=GBIDD2/WPUUSTUCOE
  Call QTEARR(GBIDD2, WPUU) From TRTDIV
  [M:PDS0]QQQQTYPUU=GBIDD2
#
  [M:PDS0]RRRQTY   =GBIDD3
  GBIDD3=GBIDD3/WPUUSTUCOE
  Call QTEARR(GBIDD3, WPUU) From TRTDIV
  [M:PDS0]RRRQTYPUU=GBIDD3
#
Else
#--- Pour les autres, seule la quantité en A et R
  [M:PDS0]AAAQTY   = [F:SCI]CPLQTY-[F:SCI]REJCPLQTY
  GBIDD1           =([F:SCI]CPLQTY-[F:SCI]REJCPLQTY)/WPUUSTUCOE
  Call QTEARR(GBIDD1, WPUU) From TRTDIV
  [M:PDS0]AAAQTYPUU=GBIDD1
#
  Raz [M:PDS0]QQQQTY, [M:PDS0]QQQQTYPUU
#
  [M:PDS0]RRRQTY   = [F:SCI]REJCPLQTY
  GBIDD3           = [F:SCI]REJCPLQTY/WPUUSTUCOE
  Call QTEARR(GBIDD3, WPUU) From TRTDIV
  [M:PDS0]RRRQTYPUU=GBIDD3
Endif

Call QTEARR([M:PDS0]AAAQTY,[M:PDS0]STU) From TRTDIV
Call QTEARR([M:PDS0]QQQQTY,[M:PDS0]STU) From TRTDIV
Call QTEARR([M:PDS0]RRRQTY,[M:PDS0]STU) From TRTDIV
#-- Si quantité facturée >= quantité de la réception
###If [F:SCI]INVQTY>0 & [F:SCI]INVQTY>=[F:SCI]CPLQTY
###  [M:PDS0]WLININVFLG=3 : # Totalement facturée
###Elsif [F:SCI]INVQTY<=0
###  [M:PDS0]WLININVFLG=1 : # Non facturée
###Elsif [F:SCI]INVQTY>=0
###  [M:PDS0]WLININVFLG=2 : # Facturation partielle
###Endif
Raz ICOM,IRCP,IRET,IFAC
Raz GERR

Default Mask [PDS1]
# Chargement des Commandes pour cet ordre de sous-traitance / article lancé
Gosub CHARG_SCO_COM

Default Mask [PDS2]
# Chargement des Réceptions pour les commandes trouvées
Gosub CHARG_COM_RCP

Default Mask [PDS2]
# Chargement des Retours pour les Réceptions trouvées
Gosub CHARG_RCP_RET

Default Mask [PDS1]
# Chargement des Factures pour les commandes trouvées
Gosub CHARG_COM_FAC

# Chargement des Factures pour les Réceptions trouvées
Gosub CHARG_RCP_FAC

# Chargement des Avoirs c/les retours trouvés
Gosub CHARG_RET_FAC

# Chargement des factures liées aux factures trouvées
Gosub CHARG_AUTRE_FAC

# FQ 52924 demande CH
# Synthèse des livraisons/retours matières mises à dispo du sous-traitant
Default Mask [PDS3]
# Chargement des Livraisons matières pour sous-traitance pour cet ordre de sous-traitance / article lancé
Gosub CHARG_SCO_SDD
# Chargement des Retours pour les Livraisons matières pour sous-traitance trouvées
Gosub CHARG_SDD_SRD

Default Mask [PDS0]
[M:PDS0]NBLIG=5
Local Integer I
For I=0 To [M:PDS0]NBLIG-1
  [M:PDS0]PUU(I)=[F:SCI]PUU
  [M:PDS0]STU(I)=[F:SCI]STU
  [M:PDS0]CUR(I)=[F:SCO]CUR
Next I

# Total qté lancée
I=0
[M:PDS0]DOCUMENT(I)= mess(9,517,1) : # Ordre de sous-traitance
[M:PDS0]QTYPUU(I)  = [F:SCI]QTYPUU
[M:PDS0]QTYSTU(I)  = [F:SCI]EXTQTY
# Issue 94690 suite GA 12/2013 tenir compte des valeurs matières aussi
#GBIDD1=[F:SCS]NETPRI*[F:SCS]EXTSTRQTY
#Call ARRDEV(GBIDD1,[F:SCO]CUR) From TRTDIV
GBIDD1=[F:SCS]LINAMT                 # Issue 100967 GA 06/2014
[M:PDS0]LINAMT(I)  = GBIDD1          # Issue 94690 before [F:SCI]NETPRI * [F:SCI]QTYPUU
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   GBIDD1=[F:SCS]LINAMTL
   [M:PDS0]LINAMTL(I)+=GBIDD1
Endif
Filter [SCM] Where SCONUM=WVCRNUM & SCILIN=WVCRLIN
For [SCM]
    #GBIDD1=[F:SCM]REFPRI * max([F:SCM]RETQTY,[F:SCM]USEQTY)
    #Call ARRDEV(GBIDD1,[F:SCO]CUR) From TRTDIV
    GBIDD1=[F:SCM]LINAMT      # Issue 100967 GA 06/2014
    [M:PDS0]LINAMT(I)+=GBIDD1
    If dim([M:PDS0]LINAMTL)>=0 # Issue 101179 & 100967 GA 07/2014
       GBIDD1=[F:SCM]LINAMTL
       [M:PDS0]LINAMTL(I)+=GBIDD1
    Endif
Next
Filter [SCM]
[M:PDS0]NBDOC(I)   = 1

# Total qté commandée
I=1
[M:PDS0]DOCUMENT(I)=mess(3,517,1)  : # Commande standard
[M:PDS0]QTYSTU(I)  = sum([M:PDS1]COMQTYSTU(0..[M:PDS1]NBCOM-1))# Issue 94690 before [F:SCI]ORDQTY
[M:PDS0]QTYPUU(I)  = sum([M:PDS1]COMQTYPUU(0..[M:PDS1]NBCOM-1))# Issue 94690 before [F:SCI]ORDQTY/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS1]COMLINAMT(0..[M:PDS1]NBCOM-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS1]COMLINAMTL(0..[M:PDS1]NBCOM-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS1]NBCOM

# FQ 56565 GA 07/2009 [F:SCI]INVQTY n'est pas renseignée car la facture porte sur le Service
# Total qté facturée
I=2
[M:PDS0]DOCUMENT(I)=mess(8,517,1)  : # Facture / avoir
[M:PDS0]QTYSTU(I)  = sum([M:PDS1]FACQTYSTU(0..[M:PDS1]NBFAC-1)) # Issue 94690 before max([F:SCS]INVQTY,[F:SCI]INVQTY)
[M:PDS0]QTYPUU(I)  = sum([M:PDS1]FACQTYPUU(0..[M:PDS1]NBFAC-1)) # Issue 94690 before [M:PDS0]QTYSTU(I)/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS1]FACLINAMT(0..[M:PDS1]NBFAC-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS1]FACLINAMTL(0..[M:PDS1]NBFAC-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS1]NBFAC

# Total qté réceptionnée
I=3
[M:PDS0]DOCUMENT(I)=mess(6,517,1)  : # Réception
[M:PDS0]QTYSTU(I)  = sum([M:PDS2]RCPQTYSTU(0..[M:PDS2]NBRCP-1)) # Issue 94690 before [F:SCI]CPLQTY
[M:PDS0]QTYPUU(I)  = sum([M:PDS2]RCPQTYPUU(0..[M:PDS2]NBRCP-1)) # Issue 94690 before [F:SCI]CPLQTY/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS2]RCPLINAMT(0..[M:PDS2]NBRCP-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS2]RCPLINAMTL(0..[M:PDS2]NBRCP-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS2]NBRCP

# Total qté rejetée
I=4
[M:PDS0]DOCUMENT(I)=mess(7,517,1)  : # Retour
[M:PDS0]QTYSTU(I)  = sum([M:PDS2]RTNQTYSTU(0..[M:PDS2]NBRET-1)) # Issue 94690 before [F:SCI]REJCPLQTY
[M:PDS0]QTYPUU(I)  = sum([M:PDS2]RTNQTYPUU(0..[M:PDS2]NBRET-1)) # Issue 94690 before [F:SCI]REJCPLQTY/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS2]RTNLINAMT(0..[M:PDS2]NBRET-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS2]RTNLINAMTL(0..[M:PDS2]NBRET-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS2]NBRET

#----- Affichage foreground -----#
Filter [POQ] : Filter [PTD] : Filter [PID] : Filter [PND]

Affzo [PDS0] : Affzo [PDS1] : Affzo [PDS2] : Affzo [PDS3]
Call TEMPOFF From GESECRAN
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETASCO
Raz [M:PDS0] : Raz [M:PDS1] : Raz [M:PDS2]
Raz [M:PDS3] # Issue 86702 GA 12/2012 :-(
nolign=SAVNOLIGN
Return



#############################################################################
# Remplacé par l'action VISUETASST avec paramètres :                        #
#   PARAM(1) = MFGNUM : Numéro   de l'ordre de fabrication à traiter        #
#   PARAM(2) = OPENUM : Numéro   de l'opération de sous-traitance           #
#   PARAM(3) = WABMSK : Abréviation du masque écran contenant les lignes    #
#   PARAM(4) = NOLIG  : Numéro de ligne tableau lignes commande (nolign-1)  #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETASST
#----- Variables locales -----#
Local Char     WVCRNUM(GLONVCR) : WVCRNUM=PARAM(1)
Local Integer  WVCRLIN          : WVCRLIN=val(PARAM(2))
Local Integer  WVCRSEQ          : WVCRSEQ=val(PARAM(3))
Local Char     WABMSK(4)        : WABMSK =PARAM(4)
Local Shortint NOL              : NOL    =val(PARAM(5))
Local Decimal  WPUUSTUCOE       : WPUUSTUCOE = 1
Local Char     WPUU(GLONUOM), WSTU(GLONUOM)
Local Shortint SAVGNOLIGN, I, J, CPT, LIG_CPT
Local Shortint ICOM,IRCP,IRET,IFAC
Local Shortint ISDH,ISRH           # FQ 52924 GA 05/03/2009

#SAVNOLIGN=nolign
#If evalue("[M:"+WABMSK+"]BPRNUM=''") |
#&  evalue("[M:"+WABMSK+"]ITMREF=''") |
#& evalue("[M:"+WABMSK+"]MFGNUM=''") | GREP="C" | GREP="D"
If WVCRNUM="" | GREP="C" | GREP="D" | GVERSION<"1.8.0"
  FIN=1
Endif
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_VISUETASST
TIT=mess(348,194,1)- mess(156,197,1) -[F:MFG]MFGNUM
[M:PDS0]VCRTYP=10
[M:PDS0]VCRNUM=WVCRNUM
If dim([M:PDS0]LVCRLIN)>0 & WVCRLIN<>0
  [M:PDS0]LVCRLIN=mess(209,197,1) - num$(WVCRLIN)-"/"- num$(WVCRSEQ)
Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETASST
Raz [M:PDS0] : Raz [M:PDS1] : Raz [M:PDS2] : Raz [M:PDS3]
Call TEMPON("O") From GESECRAN

Gosub OPEN_FILES_PUR

# .................
#----- Lecture ordre de fabrication si nécessaire -----#
If [F:MFG]MFGNUM<>WVCRNUM
  Read [MFG]MFG0=WVCRNUM  : If fstat Raz [F:MFG] : Endif
Endif
#----- Lecture 1er article lancé à traiter si nécessaire -----#
If [F:MFI]MFGNUM<>WVCRNUM
  Read [MFI]MFI0(1)=WVCRNUM : If fstat Raz [F:MFI] : Endif
Endif
#----- Lecture opé de sous-traitance si nécessaire -----#
If [F:MFO]MFGNUM<>WVCRNUM
  If WVCRLIN<>0
     Read [MFO]MFO0=WVCRNUM;WVCRLIN;WVCRSEQ  : If fstat Raz [F:MFO] : Endif
  Else
    For [MFO] Where MFGNUM=WVCRNUM & SCOITMREF<>"" & find(OPESTA,5,7)
        Break
    Next
  Endif
Endif
#----- Chargement des zones dans le masque -----#
[M:PDS0]=[F:MFI]
# done also in Action TITRE else field title is not ok
[M:PDS0]VCRTYP=10
[M:PDS0]VCRNUM=WVCRNUM
If dim([M:PDS0]LVCRLIN)>0 & WVCRLIN<>0
  [M:PDS0]LVCRLIN=mess(209,197,1) - num$(WVCRLIN)-"/"- num$(WVCRSEQ)
Endif

# TEMPORAIRE: Coef/Unité => Conversions à revoir ...
WPUU = [F:MFI]UOM
WSTU = [F:MFI]STU
WPUUSTUCOE = [F:MFI]UOMSTUCOE
If WPUUSTUCOE=0 : WPUUSTUCOE=1 : Endif
# TEMPORAIRE: Fin

If [F:ITF]ITMREF<>[F:MFI]ITMREF | [F:ITF]STOFCY<>[F:MFI]MFGFCY
  Read [ITF]ITF0=[F:MFI]ITMREF;[F:MFI]MFGFCY
  If fstat : Raz [F:ITF]ITMREF : Endif
Endif

#--- Pour les articles gérés en stock on regarde les mouvements
If [F:ITF]STOMGTCOD>1
  Raz GBIDD1, GBIDD2, GBIDD3
# VCRTYP Menu 701 => 15=Réception fournisseur, tous articles de l'OF
  For [STJ1]STJ1 Where STOFCY    = [F:MFI]MFGFCY &
&                      VCRTYP    = 15            &
&                      VCRTYPORI = 10            &
&                      VCRNUMORI = [F:MFI]MFGNUM &
&                      UPDCOD = 2                &
&                      REGFLG <>2
    If [F:STJ1]QTYSTU<>0
      If left$([F:STJ1]STA,1)="A"
        GBIDD1+=[F:STJ1]QTYSTU
      Elsif left$([F:STJ1]STA,1)="Q"
        GBIDD2+=[F:STJ1]QTYSTU
      Elsif left$([F:STJ1]STA,1)="R"
        GBIDD3-=[F:STJ1]QTYSTU         # FQ 51330 GA 01/2009 le signe est inversé -1/+1
      Endif

# Issue 94690 GA 11/2013 tenir compte LOT/SLO
#     VCRTYP Menu 701 => 8=Retour fournisseur rattaché à la Rcp courante GA 11/2008
      For [STJ2]STJ1 Where STOFCY    = [F:STJ1]STOFCY &
&                          VCRTYP    = 8              &
&                          VCRTYPORI = 6              &
&                          VCRNUMORI = [F:STJ1]VCRNUM &
&                          VCRLINORI = [F:STJ1]VCRLIN &
&                          ITMREF    = [F:STJ1]ITMREF &
&                          LOT       = [F:STJ1]LOT    &
&                          SLO       = [F:STJ1]SLO    &
&                          UPDCOD = 2                 &
&                          REGFLG <>2
        If [F:STJ2]QTYSTU<>0
          If left$([F:STJ2]STA,1)="A"
            GBIDD1+=[F:STJ2]QTYSTU
          Elsif left$([F:STJ2]STA,1)="Q"
            GBIDD2+=[F:STJ2]QTYSTU
          Elsif left$([F:STJ2]STA,1)="R"
            GBIDD3-=[F:STJ2]QTYSTU         # FQ 51330 GA 01/2009 le signe est inversé -1/+1
          Endif
        Endif

      Next
    Endif
  Next
#
  [M:PDS0]AAAQTY   =GBIDD1
  GBIDD1=GBIDD1/WPUUSTUCOE
  Call QTEARR(GBIDD1, WPUU) From TRTDIV
  [M:PDS0]AAAQTYPUU=GBIDD1
#
  [M:PDS0]QQQQTY   =GBIDD2
  GBIDD2=GBIDD2/WPUUSTUCOE
  Call QTEARR(GBIDD2, WPUU) From TRTDIV
  [M:PDS0]QQQQTYPUU=GBIDD2
#
  [M:PDS0]RRRQTY   =GBIDD3
  GBIDD3=GBIDD3/WPUUSTUCOE
  Call QTEARR(GBIDD3, WPUU) From TRTDIV
  [M:PDS0]RRRQTYPUU=GBIDD3
#
Else
#--- Pour les autres, seule la quantité en A et R
  [M:PDS0]AAAQTY   = [F:MFI]CPLQTY-[F:MFI]REJCPLQTY
  GBIDD1           =([F:MFI]CPLQTY-[F:MFI]REJCPLQTY)/WPUUSTUCOE
  Call QTEARR(GBIDD1, WPUU) From TRTDIV
  [M:PDS0]AAAQTYPUU=GBIDD1
#
  Raz [M:PDS0]QQQQTY, [M:PDS0]QQQQTYPUU
#
  [M:PDS0]RRRQTY   = [F:MFI]REJCPLQTY
  GBIDD3           = [F:MFI]REJCPLQTY/WPUUSTUCOE
  Call QTEARR(GBIDD3, WPUU) From TRTDIV
  [M:PDS0]RRRQTYPUU=GBIDD3
Endif

Call QTEARR([M:PDS0]AAAQTY,[M:PDS0]STU) From TRTDIV
Call QTEARR([M:PDS0]QQQQTY,[M:PDS0]STU) From TRTDIV
Call QTEARR([M:PDS0]RRRQTY,[M:PDS0]STU) From TRTDIV
Raz ICOM,IRCP,IRET,IFAC
Raz GERR

Default Mask [PDS1]
# Chargement des Commandes pour cet ordre de fabrication / opération sous-traitance
Gosub CHARG_WOF_COM

Default Mask [PDS2]
# Chargement des Réceptions pour les commandes trouvées
Gosub CHARG_COM_RCP

Default Mask [PDS2]
# Chargement des Retours pour les Réceptions trouvées
Gosub CHARG_RCP_RET

Default Mask [PDS1]
# Chargement des Factures pour les commandes trouvées
Gosub CHARG_COM_FAC

# Chargement des Factures pour les Réceptions trouvées
Gosub CHARG_RCP_FAC

# Chargement des Avoirs c/les retours trouvés
Gosub CHARG_RET_FAC

# Chargement des factures liées aux factures trouvées
Gosub CHARG_AUTRE_FAC

# Synthèse des livraisons/retours matières mises à dispo du sous-traitant
Default Mask [PDS3]
# Chargement des Livraisons matières pour sous-traitance pour cet ordre de fabrication / article lancé
Gosub CHARG_WOF_SDD
# Chargement des Retours pour les Livraisons matières pour sous-traitance trouvées
Gosub CHARG_SDD_SRD

Default Mask [PDS0]
[M:PDS0]NBLIG=5
Local Integer I
For I=0 To [M:PDS0]NBLIG-1
  [M:PDS0]PUU(I)=[F:MFG]STU      # global qty for WOF i stock unit
  [M:PDS0]STU(I)=[F:MFG]STU
  [M:PDS0]CUR(I)=GLOCALDEV
Next I

# Total qté lancée
I=0
[M:PDS0]DOCUMENT(I)= mess(156,197,1) : # Work order
[M:PDS0]QTYPUU(I)  = [F:MFG]EXTQTY     # global qty for WOF
[M:PDS0]QTYSTU(I)  = [F:MFG]EXTQTY
If [F:MFO]CPLPRI<>0
  GBIDD1=[F:MFO]CPLPRI*[F:MFO]EXTSTRQTY
Else
  GBIDD1=[F:MFO]REFPRI*[F:MFO]EXTSTRQTY
Endif
Call ARRDEV(GBIDD1,GLOCALDEV) From TRTDIV
[M:PDS0]LINAMT(I)  = GBIDD1
If dim([M:PDS0]LINAMTL)>=0   # no currency conversion for instance
   #GBIDD1=[F:MFO]LINAMTL
   [M:PDS0]LINAMTL(I)+=GBIDD1
Endif
Filter [MFM] Where MFGNUM=WVCRNUM & 1=2
For [MFM]
    #GBIDD1=[F:MFM]LINAMT # no amount on [F:MFM]
    GBIDD1=0              # ??????
    [M:PDS0]LINAMT(I)+=GBIDD1
    If dim([M:PDS0]LINAMTL)>=0 # no currency conversion for instance
       #GBIDD1=[F:MFM]LINAMTL
       [M:PDS0]LINAMTL(I)+=GBIDD1
    Endif
Next
Filter [MFM]
[M:PDS0]NBDOC(I)   = 1

# Total qté commandée
I=1
[M:PDS0]DOCUMENT(I)=mess(3,517,1)  : # Commande standard
[M:PDS0]QTYSTU(I)  = sum([M:PDS1]COMQTYSTU(0..[M:PDS1]NBCOM-1))# Issue 94690 before [F:MFI]ORDQTY
[M:PDS0]QTYPUU(I)  = sum([M:PDS1]COMQTYPUU(0..[M:PDS1]NBCOM-1))# Issue 94690 before [F:MFI]ORDQTY/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS1]COMLINAMT(0..[M:PDS1]NBCOM-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS1]COMLINAMTL(0..[M:PDS1]NBCOM-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS1]NBCOM

# FQ 56565 GA 07/2009 [F:MFI]INVQTY n'est pas renseignée car la facture porte sur le Service
# Total qté facturée
I=2
[M:PDS0]DOCUMENT(I)=mess(8,517,1)  : # Facture / avoir
[M:PDS0]QTYSTU(I)  = sum([M:PDS1]FACQTYSTU(0..[M:PDS1]NBFAC-1)) # Issue 94690 before max([F:MFO]INVQTY,[F:MFI]INVQTY)
[M:PDS0]QTYPUU(I)  = sum([M:PDS1]FACQTYPUU(0..[M:PDS1]NBFAC-1)) # Issue 94690 before [M:PDS0]QTYSTU(I)/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS1]FACLINAMT(0..[M:PDS1]NBFAC-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS1]FACLINAMTL(0..[M:PDS1]NBFAC-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS1]NBFAC

# Total qté réceptionnée
I=3
[M:PDS0]DOCUMENT(I)=mess(6,517,1)  : # Réception
[M:PDS0]QTYSTU(I)  = sum([M:PDS2]RCPQTYSTU(0..[M:PDS2]NBRCP-1)) # Issue 94690 before [F:MFI]CPLQTY
[M:PDS0]QTYPUU(I)  = sum([M:PDS2]RCPQTYPUU(0..[M:PDS2]NBRCP-1)) # Issue 94690 before [F:MFI]CPLQTY/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS2]RCPLINAMT(0..[M:PDS2]NBRCP-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS2]RCPLINAMTL(0..[M:PDS2]NBRCP-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS2]NBRCP

# Total qté rejetée
I=4
[M:PDS0]DOCUMENT(I)=mess(7,517,1)  : # Retour
[M:PDS0]QTYSTU(I)  = sum([M:PDS2]RTNQTYSTU(0..[M:PDS2]NBRET-1)) # Issue 94690 before [F:MFI]REJCPLQTY
[M:PDS0]QTYPUU(I)  = sum([M:PDS2]RTNQTYPUU(0..[M:PDS2]NBRET-1)) # Issue 94690 before [F:MFI]REJCPLQTY/WPUUSTUCOE
[M:PDS0]LINAMT(I)  = sum([M:PDS2]RTNLINAMT(0..[M:PDS2]NBRET-1))
If dim([M:PDS0]LINAMTL)>=0            # Issue 101179 & 100967 GA 07/2014
   [M:PDS0]LINAMTL(I)=sum([M:PDS2]RTNLINAMTL(0..[M:PDS2]NBRET-1))
Endif
[M:PDS0]NBDOC(I)   = [M:PDS2]NBRET

#----- Affichage foreground -----#
Filter [POQ] : Filter [PTD] : Filter [PID] : Filter [PND]

Affzo [PDS0] : Affzo [PDS1] : Affzo [PDS2] : Affzo [PDS3]
Call TEMPOFF From GESECRAN
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETASST
Raz [M:PDS0] : Raz [M:PDS1] : Raz [M:PDS2]
Raz [M:PDS3] # Issue 86702 GA 12/2012 :-(
nolign=SAVNOLIGN
Return


###############################################################################################

$CHARG_SCO_COM
#------------------------------------------#
# Chargement des Commandes pour cet ordre
# de sous-traitance / article lancé
#------------------------------------------#
   #----- Chargement des commandes enregistrées sur l'article lancé LINTYP=2 -----#
   #GA TEMPORAIRE LINTYP n'est pas ok si commande créée par PBENCHW4 modif MBT en attente
   #Filter [POQ] Where VCRTYPORI=36 & VCRNUMORI=[F:SCI]SCONUM & VCRLINORI=[F:SCI]SCILIN & LINTYP=2
   Filter [POQ] Where VCRTYPORI=36 & VCRNUMORI=[F:SCI]SCONUM & VCRLINORI=[F:SCI]SCILIN & ITMREF=[F:SCI]ITMREF
   For [POQ]
       Gosub CHARG_LIG_COM
       If GERR<>0 Break : Endif
   Next
   Filter [POQ]
Return

###############################################################################################
$CHARG_WOF_COM                                                      # Issue 100671 GA 12/2014
#------------------------------------------#
# Chargement des Commandes pour cette opé
# de sous-traitance / article lancé
#------------------------------------------#
   #----- Chargement des commandes enregistrées sur l'article lancé LINTYP=2 -----#
 If WVCRLIN<>0
   Filter [POQ] Where VCRTYPORI=10 & VCRNUMORI=WVCRNUM & VCRLINORI=WVCRLIN & VCRSEQORI=WVCRSEQ
 Else
   Filter [POQ] Where VCRTYPORI=10 & VCRNUMORI=WVCRNUM  # all what concerns this WO
 Endif
 For [POQ]
     Gosub CHARG_LIG_COM
     If GERR<>0 Break : Endif
 Next
 Filter [POQ]
Return

$CHARG_COM_RCP
#------------------------------------------#
# Chargement des Réceptions
# pour les commandes trouvées
#------------------------------------------#
For CPT=0 To [M:PDS1]NBCOM-1
   IRCP=[M:PDS2]NBRCP
   #----- Chargement des réceptions enregistrées sur la commande d'achat -----#
   Filter [PTD] Where POHNUM=[M:PDS1]POHNUM(CPT)
&                   & POPLIN=[M:PDS1]POPLIN(CPT)
&                   & POQSEQ=[M:PDS1]POQSEQ(CPT)
&               Order By Key PTD1
   For [PTD]
       Gosub CHARG_LIG_RCP
       If GERR<>0 Break : Endif
   Next
   Filter [PTD]
Next CPT
Return


$CHARG_RCP_FAC
Local Integer SAV_NBFAC : SAV_NBFAC=[M:PDS1]NBFAC
#------------------------------------------#
# Chargement des Factures
# pour les Réceptions trouvées
#------------------------------------------#
For CPT=0 To [M:PDS2]NBRCP-1
   IFAC=[M:PDS1]NBFAC
   #----- Chargement des factures enregistrées sur la réception -----#
  # FQ 53937
   #Filter [PID] Where TYPORI=2 & NUMORI=[M:PDS2]PTHNUM(CPT) & LINORI=[M:PDS2]PTDLIN(CPT) & SEQORI=0
   Filter [PID] Where TYPORI=2 & NUMORI=[M:PDS2]PTHNUM(CPT) & LINORI=[M:PDS2]PTDLIN(CPT)
&               Order By Key PID1
   For [PID]
       Gosub CHARG_LIG_FAC
       If GERR<>0 Break : Endif
   Next
   Filter [PID]
Next CPT

#-----------------------------------------#
# Chargement avoirs s/fac normales        #
#-----------------------------------------#
For CPT=SAV_NBFAC To [M:PDS1]NBFAC-1
   IFAC=[M:PDS1]NBFAC
   Filter [PID] Where TYPORI=4 & NUMORI=[M:PDS1]NUM(CPT) & LINORI=[M:PDS1]PIDLIN(CPT)
&                Order By Key PID1
   For [PID]
     Gosub CHARG_LIG_FAC
     If  GERR=2 : Break : Endif
   Next
   Filter [PID]
Next CPT
Return


$CHARG_COM_FAC
Local Integer SAV_NBFAC : SAV_NBFAC=[M:PDS1]NBFAC
#------------------------------------------#
# Chargement des Factures
# pour les Commandes trouvées
#------------------------------------------#
For CPT=0 To [M:PDS1]NBCOM-1
  IFAC=[M:PDS1]NBFAC
  #----- Chargement des factures enregistrées sur la ligne de commande -----#
  # FQ 53937
  #Filter [PID] Where TYPORI=1 & NUMORI=[M:PDS1]POHNUM(CPT) & LINORI=[M:PDS1]POPLIN(CPT) & SEQORI=0
  Filter [PID] Where TYPORI=1 & NUMORI=[M:PDS1]POHNUM(CPT) & LINORI=[M:PDS1]POPLIN(CPT)
&              Order By Key PID1
  For [PID]
    Gosub CHARG_LIG_FAC
    If GERR<>0 Break : Endif
  Next
  Filter [PID]
Next CPT

#-----------------------------------------#
# Chargement avoirs s/fac normales        #
#-----------------------------------------#
For CPT=SAV_NBFAC To [M:PDS1]NBFAC-1
   IFAC=[M:PDS1]NBFAC
   Filter [PID] Where TYPORI=4 & NUMORI=[M:PDS1]NUM(CPT) & LINORI=[M:PDS1]PIDLIN(CPT)
&                Order By Key PID1
   For [PID]
     Gosub CHARG_LIG_FAC
     If  GERR=2 : Break : Endif
   Next
   Filter [PID]
Next CPT
Return

$CHARG_RCP_RET
#-------------------------------------------#
# Chargement des retours sur les receptions #
#-------------------------------------------#
For CPT=0 To [M:PDS2]NBRCP-1
   IRET=[M:PDS2]NBRET
   Filter [PND] Where PTHNUM=[M:PDS2]PTHNUM(CPT) & PTDLIN=[M:PDS2]PTDLIN(CPT)
&            Order By Key PND1
   For [PND]
     Gosub CHARG_LIG_RET
     If GERR<>0 : Break : Endif
   Next
   Filter [PND]
Next CPT
Return

$CHARG_RET_FAC
#----------------------------------#
# Chargement des avoirs c/retours  #
#----------------------------------#
For CPT=0 To [M:PDS2]NBRET-1
  If [M:PDS2]XLININVFLG(IRET)>1
    IFAC=[M:PDS1]NBFAC
    Filter [PID] Where TYPORI=3 & PNHNUM=[M:PDS2]PNHNUM(CPT) & PNDLIN=[M:PDS2]PNDLIN(CPT)
&             Order By Key PID1
    For [PID]
     Gosub CHARG_LIG_FAC
     If GERR<>0 : Break : Endif
    Next
    Filter [PID]
  Endif
  If GERR<>0 : Break : Endif
Next CPT
Return

$CHARG_AUTRE_FAC
Local Integer SAV_NBFAC : SAV_NBFAC=[M:PDS1]NBFAC
#-------------------------------------#
# Chargement factures complémentaires #
#-------------------------------------#
For CPT=0 To [M:PDS1]NBFAC-1
   IFAC=[M:PDS1]NBFAC
   Filter [PID] Where TYPORI=4 & NUMORI=[M:PDS1]NUM(CPT) & LINORI=[M:PDS1]PIDLIN(CPT)
&                Order By Key PID1
   For [PID]
     Gosub CHARG_LIG_FAC
     If  GERR=2 : Break : Endif
   Next
   Filter [PID]
Next CPT
# Issue 102605 GA 13/10/2014
#-----------------------------------------#
# Chargement avoirs s/fac complémentaires #
#-----------------------------------------#
For CPT=SAV_NBFAC To [M:PDS1]NBFAC-1
   IFAC=[M:PDS1]NBFAC
   Filter [PID] Where TYPORI=4 & NUMORI=[M:PDS1]NUM(CPT) & LINORI=[M:PDS1]PIDLIN(CPT)
&                Order By Key PID1
   For [PID]
     Gosub CHARG_LIG_FAC
     If  GERR=2 : Break : Endif
   Next
   Filter [PID]
Next CPT

Return

#---------------------------#
# Chargement ligne commande #
#---------------------------#
$CHARG_LIG_COM
[M:PDS1]POHNUM(ICOM)   =[F:POQ]POHNUM
[M:PDS1]POPLIN(ICOM)   =[F:POQ]POPLIN
[M:PDS1]POQSEQ(ICOM)   =[F:POQ]POQSEQ
[M:PDS1]ORDDAT(ICOM)   =[F:POQ]ORDDAT
If dim([M:PDS1]COMLINAMTL)>0   # Issue 101179 & 100967 GA 07/2014
  Call CALC_POQ_LINAMTL([M:PDS1]COMLINAMT(ICOM),[M:PDS1]COMLINAMTL(ICOM)) From TRTACHSCO1
  [M:PDS1]COMCPRCUR(ICOM)=[F:POQ]CPRCUR
Else
  Call CALC_POQ_LINAMT([M:PDS1]COMLINAMT(ICOM)) From TRTACHSCO1 # [F:POQ]LINAMT
Endif
[M:PDS1]COMPUU(ICOM)   =[F:POQ]PUU  # chargé avant les champs QTYxxx
[M:PDS1]COMSTU(ICOM)   =[F:POQ]STU
[M:PDS1]COMQTYPUU(ICOM)=[F:POQ]QTYPUU
[M:PDS1]COMQTYSTU(ICOM)=[F:POQ]QTYSTU

If [F:POH]POHNUM<>[F:POQ]POHNUM
  Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
Endif
[M:PDS1]COMCUR(ICOM)=[F:POH]CUR
[M:PDS1]POHFCY(ICOM)=[F:POH]POHFCY
If dim([M:PDS1]COMBPRNUM)>0
  [M:PDS1]VCRLIN(ICOM)=[F:POQ]VCRLINORI  # Issue 100671
  [M:PDS1]VCRSEQ(ICOM)=[F:POQ]VCRSEQORI  # Issue 100671
  [M:PDS1]COMBPRNUM(ICOM)=[F:POH]BPSNUM  # Issue 100671
Endif

ICOM+=1 : [M:PDS1]NBCOM=ICOM
If ICOM>dim([M:PDS1]POHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Return

#--------------------------#
# Chargement ligne facture #
#--------------------------#
$CHARG_LIG_FAC
If IFAC>dim([M:PDS1]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
# Cas particulier: on vérifie si la facture est deja dans la liste
OK=1
# Issue 82180 - 2012-05-22 by CCC : CPT est déjà utilisé
#For CPT=0 To [M:PDS1]NBFAC-1
For LIG_CPT=0 To [M:PDS1]NBFAC-1
  If [M:PDS1]NUM(LIG_CPT)=[F:PID]NUM & [M:PDS1]PIDLIN(LIG_CPT)=[F:PID]PIDLIN
    OK=0
  Endif
  If OK=0 Break : Endif
Next LIG_CPT
If OK<>0
  [M:PDS1]TYPORI(IFAC)   =[F:PID]TYPORI
  [M:PDS1]NUM(IFAC)      =[F:PID]NUM
  [M:PDS1]PIDLIN(IFAC)   =[F:PID]PIDLIN
  [M:PDS1]FCY(IFAC)      =[F:PID]FCY
  [M:PDS1]FACPUU(IFAC)   =[F:PID]PUU  # chargé avant les champs QTYxxx
  [M:PDS1]FACSTU(IFAC)   =[F:PID]STU
  [M:PDS1]FACQTYPUU(IFAC)=[F:PID]QTYPUU
  If [F:PID]PIHTYP>2 [M:PDS1]FACQTYPUU(IFAC)=0-[M:PDS1]FACQTYPUU(IFAC) : Endif
  [M:PDS1]FACQTYSTU(IFAC)=[F:PID]QTYSTU
  If [F:PID]PIHTYP>2 [M:PDS1]FACQTYSTU(IFAC)=0-[M:PDS1]FACQTYSTU(IFAC) : Endif
  [M:PDS1]NETPRI(IFAC)   =[F:PID]NETPRI
  If dim([M:PDS1]FACLINAMTL)>0     # Issue 101179 & 100967 GA 07/2014
    Call CALC_PID_LINAMTL([M:PDS1]FACLINAMT(IFAC),[M:PDS1]FACLINAMTL(IFAC)) From TRTACHSCO1
    [M:PDS1]FACCPRCUR(IFAC)=[F:PID]CPRCUR
  Else
    Call CALC_PID_LINAMT([M:PDS1]FACLINAMT(IFAC)) From TRTACHSCO1 # [F:PID]AMTNOTLIN
  Endif
  If [F:PID]PIHTYP>2   # credit invoice
     [M:PDS1]FACLINAMT(IFAC) *= -1
     If dim([M:PDS1]FACLINAMTL)>0 [M:PDS1]FACLINAMTL(IFAC)*= -1 Endif
  Endif

  If [F:PIH]NUM<>[F:PID]NUM
    Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
  Endif
  If dim([M:PDS1]FACBPRNUM)>0
    [M:PDS1]FACBPRNUM(ICOM)=[F:PIH]BPR  # Issue 100671
  Endif
  [M:PDS1]ACCDAT(IFAC)   =[F:PIH]ACCDAT
  [M:PDS1]FACCUR(IFAC)   =[F:PIH]CUR

  IFAC+=1 : [M:PDS1]NBFAC=IFAC
  If IFAC>dim([M:PDS1]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Endif
Return

#----------------------------#
# Chargement ligne réception #
#----------------------------#
$CHARG_LIG_RCP
[M:PDS2]PTHNUM(IRCP)   =[F:PTD]PTHNUM
[M:PDS2]PTDLIN(IRCP)   =[F:PTD]PTDLIN
[M:PDS2]RCPDAT(IRCP)   =[F:PTD]RCPDAT
[M:PDS2]RCPPUU(IRCP)   =[F:PTD]PUU  # chargé avant les champs QTYxxx
[M:PDS2]RCPSTU(IRCP)   =[F:PTD]STU
[M:PDS2]RCPQTYPUU(IRCP)=[F:PTD]QTYPUU
[M:PDS2]RCPQTYSTU(IRCP)=[F:PTD]QTYSTU
If dim([M:PDS2]RCPLINAMTL)>0   # Issue 101179 & 100967 GA 07/2014
  Call CALC_PTD_LINAMTL([M:PDS2]RCPLINAMT(IRCP),[M:PDS2]RCPLINAMTL(IRCP)) From TRTACHSCO1
  [M:PDS2]RCPCPRCUR(IRCP)=[F:PTD]CPRCUR
Else
  Call CALC_PTD_LINAMT([M:PDS2]RCPLINAMT(IRCP)) From TRTACHSCO1 # [F:PTD]LINAMT
Endif
If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
  Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
Endif
[M:PDS2]PRHFCY(IRCP)   =[F:PTH]PRHFCY
[M:PDS2]RCPCUR(IRCP)   =[F:PTH]CUR
IRCP+=1 : [M:PDS2]NBRCP=IRCP
If IRCP>dim([M:PDS2]PTHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Return

#----------------------------#
# Chargement ligne de retour #
#----------------------------#
$CHARG_LIG_RET
[M:PDS2]PNHNUM(IRET)=[F:PND]PNHNUM
[M:PDS2]PNDLIN(IRET)=[F:PND]PNDLIN
[M:PDS2]RTNDAT(IRET)=[F:PND]RTNDAT
[M:PDS2]PNHFCY(IRET)=[F:PND]PNHFCY
[M:PDS2]RTNQTYPUU(IRET)=[F:PND]QTYPUU   # chargé avant les champs QTYxxx
[M:PDS2]RTNQTYSTU(IRET)=[F:PND]QTYSTU
[M:PDS2]RTNPUU(IRET)=[F:PND]PUU
[M:PDS2]RTNSTU(IRET)=[F:PND]STU
If dim([M:PDS2]RTNLINAMTL)>0   # Issue 101179 & 100967 GA 07/2014
  Call CALC_PND_LINAMTL([M:PDS2]RTNLINAMT(IRET),[M:PDS2]RTNLINAMTL(IRET)) From TRTACHSCO1
  [M:PDS2]RTNCPRCUR(IRET)=[F:PND]CPRCUR
Else
  Call CALC_PND_LINAMT([M:PDS2]RTNLINAMT(IRET)) From TRTACHSCO1 # [F:PND]LINAMT
Endif
#-- Si quantité facturée >= quantité de la réception
If [F:PND]INVQTYPUU>=[F:PND]QTYPUU
  [M:PDS2]XLININVFLG(IRET)=3 : # Totalement facturée
Elsif [F:PND]INVQTYPUU<=0
  [M:PDS2]XLININVFLG(IRET)=1 : # Non facturée
Elsif [F:PND]INVQTYPUU>=0
  [M:PDS2]XLININVFLG(IRET)=2 : # Facturation partielle
Endif
IRET+=1 : [M:PDS2]NBRET=IRET
If IRET>dim([M:PDS2]PNHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Return

###############################################################################################
$CHARG_SCO_SDD
#------------------------------------------#
# Chargement des Livraisons pour cet ordre
# de sous-traitance / article lancé
# Matières pour sous-traitance
#------------------------------------------#
   #----- Chargement des livraisons enregistrées sur l'article lancé -----#
   Filter [SDD] Where VCRTYPORI=36 & VCRNUMORI=[F:SCI]SCONUM & VCRLINORI=[F:SCI]SCILIN
   For [SDD]
       Gosub CHARG_LIG_SDD
       If GERR<>0 Break : Endif
   Next
   Filter [SDD]  # Issue 86702 GA 12/2012 before [SDH]
Return
###############################################################################################
$CHARG_WOF_SDD                                                      # Issue 100671 GA 12/2014
#------------------------------------------#
# Chargement des Livraisons pour cet ordre
# de fabrication / article lancé
# Matières pour sous-traitance
#------------------------------------------#
   #----- Chargement des livraisons enregistrées sur l'article lancé -----#
   Filter [SDD] Where VCRTYPORI=10 & VCRNUMORI=[F:MFI]MFGNUM & VCRLINORI=[F:MFI]MFGLIN
   For [SDD]
       Gosub CHARG_LIG_SDD
       If GERR<>0 Break : Endif
   Next
   Filter [SDD]  # Issue 86702 GA 12/2012 before [SDH]
Return

# FQ 52924
#----------------------------#
# Chargement ligne livraison #
#----------------------------#
$CHARG_LIG_SDD
[M:PDS3]SDHNUM(ISDH)   =[F:SDD]SDHNUM
[M:PDS3]SDDLIN(ISDH)   =[F:SDD]SDDLIN
[M:PDS3]SDHITMREF(ISDH)=[F:SDD]ITMREF
[M:PDS3]SDHPUU(ISDH)   =[F:SDD]SAU  # chargé avant les champs QTYxxx
[M:PDS3]SDHSTU(ISDH)   =[F:SDD]STU
[M:PDS3]SDHQTYPUU(ISDH)=[F:SDD]QTY
[M:PDS3]SDHQTYSTU(ISDH)=[F:SDD]QTYSTU
#[M:PDS3]SDHLINAMT(ISDH)=[F:SDD]NETPRIATY ???
If [F:SDH]SDHNUM<>[F:SDD]SDHNUM
  Read [SDH] SDH0=[F:SDD]SDHNUM : If fstat Raz [F:SDH] : Endif
Endif
[M:PDS3]SDHSALFCY(ISDH)=[F:SDH]SALFCY
[M:PDS3]SDHCUR(ISDH)   =[F:SDH]CUR
[M:PDS3]SDHDAT(ISDH)   =[F:SDH]DLVDAT
ISDH+=1 : [M:PDS3]NBSDH=ISDH
If ISDH>dim([M:PDS3]SDHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Return

$CHARG_SDD_SRD
#------------------------------------------#
# Chargement des Retours de Livraisons
# Matières pour sous-traitance
#------------------------------------------#
For CPT=0 To [M:PDS3]NBSDH-1
   ISRH=[M:PDS3]NBSRH
   Filter [SRD] Where SDHNUM=[M:PDS3]SDHNUM(CPT) & SDDLIN=[M:PDS3]SDDLIN(CPT)
&            Order By Key SRD1
   For [SRD]
     Gosub CHARG_LIG_SRD
     If GERR<>0 : Break : Endif
   Next
Filter [SRD]
Next CPT
Return

# FQ 52924
#----------------------------#
# Chargement ligne livraison #
#----------------------------#
$CHARG_LIG_SRD
[M:PDS3]SRHNUM(ISRH)   =[F:SRD]SRHNUM
[M:PDS3]SRDLIN(ISRH)   =[F:SRD]SRDLIN
[M:PDS3]SRHITMREF(ISRH)=[F:SRD]ITMREF
[M:PDS3]SRHPUU(ISRH)   =[F:SRD]SAU  # chargé avant les champs QTYxxx
[M:PDS3]SRHSTU(ISRH)   =[F:SRD]STU
[M:PDS3]SRHQTYPUU(ISRH)=[F:SRD]QTY
[M:PDS3]SRHQTYSTU(ISRH)=[F:SRD]QTYSTU
[M:PDS3]SRHCUR(ISRH)   =[F:SRD]CUR
#[M:PDS3]SRHLINAMT(ISRH)=[F:SRD]NETPRIATY ???
If [F:SRH]SRHNUM<>[F:SRD]SRHNUM
  Read [SRH] SRH0=[F:SRD]SRHNUM : If fstat Raz [F:SRH] : Endif
Endif
[M:PDS3]SRHSALFCY(ISRH)=[F:SRH]SALFCY
[M:PDS3]SRHDAT(ISRH)   =[F:SRH]RTNDAT
ISRH+=1 : [M:PDS3]NBSRH=ISRH
If ISRH>dim([M:PDS3]SRHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Return : Endif
Return

$BB1_NBCOM
## GH 28/02/2013 bug 88285
If GFONCTION="GESSCO" & dim([M:SCO1]POHNUM)>0 & [M:SCO1]POHNUM=[M:PDS1]POHNUM(nolign-1)
   GMODIF=2
Endif
Return

##########################################################################
$OPEN_FILES_PUR
#----- Ouverture des fichiers si nécessaire ----#
If clalev([F:POH])<=0 Local File PORDER    [POH] : Endif
If clalev([F:POQ])<=0 Local File PORDERQ   [POQ] : Endif
If clalev([F:PTH])<=0 Local File PRECEIPT  [PTH] : Endif
If clalev([F:PTD])<=0 Local File PRECEIPTD [PTD] : Endif
If clalev([F:PNH])<=0 Local File PRETURN   [PNH] : Endif
If clalev([F:PND])<=0 Local File PRETURND  [PND] : Endif
If clalev([F:PIH])<=0 Local File PINVOICE  [PIH] : Endif
If clalev([F:PID])<=0 Local File PINVOICED [PID] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER [ITM] : Endif
If clalev([F:STJ1])<=0 Local File STOJOU   [STJ1]: Endif
If clalev([F:STJ2])<=0 Local File STOJOU   [STJ2]: Endif

If clalev([F:SDH])<=0 Local File SDELIVERY [SDH] : Endif
If clalev([F:SDD])<=0 Local File SDELIVERYD[SDD] : Endif
If clalev([F:SRH])<=0 Local File SRETURN   [SRH] : Endif
If clalev([F:SRD])<=0 Local File SRETURND  [SRD] : Endif
Return

##########################################################################

Subprog IB_NBCOM
#--------------------------------------------#
# Avant zone : Activation bouton "Commande"  #
#--------------------------------------------#
Raz GBOUT1
If dim([M:PDS1]POHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDS1]POHNUM(nolign-1)<>"" & GFONC1<>"GESPOH"
  GBOUT1=mess(191,198,1)-[M:PDS1]POHNUM(nolign-1)
Endif
End

Subprog IB_NBRCP
#--------------------------------------------#
# Avant zone : Activation bouton "Réception" #
#--------------------------------------------#
Raz GBOUT1
If dim([M:PDS2]PTHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDS2]PTHNUM(nolign-1)<>"" & GFONC1<>"GESPTH"
  GBOUT1=mess(117,198,1)-[M:PDS2]PTHNUM(nolign-1)
Endif
End


Subprog IB_NBRET
#--------------------------------------------#
# Avant zone : Activation bouton "Retour"    #
#--------------------------------------------#
Raz GBOUT1
If dim([M:PDS2]PNHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDS2]PNHNUM(nolign-1)<>"" & GFONC1<>"GESPNH"
  GBOUT1=mess(192,198,1)-[M:PDS2]PNHNUM(nolign-1)
Endif
End

Subprog IB_NBFAC
#------------------------------------------#
# Avant zone : Activation bouton "Facture" #
#------------------------------------------#
Raz GBOUT1
If dim([M:PDS1]NUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDS1]NUM(nolign-1)<>"" & GFONC1<>"GESPIH"
  GBOUT1=mess(193,198,1)-[M:PDS1]NUM(nolign-1)
Endif
End

Subprog IB_NBSDH
#--------------------------------------------#
# Avant zone : Activation bouton "Livraison" #
#--------------------------------------------#
Raz GBOUT1
If dim([M:PDS3]SDHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDS3]SDHNUM(nolign-1)<>"" & GFONC1<>"GESSDH"
  GBOUT1=mess(129,197,1)-[M:PDS3]SDHNUM(nolign-1)
Endif
End

Subprog IB_NBSRH
#------------------------------------------------#
# Avant zone : Activation bouton "Retour client" #
#------------------------------------------------#
Raz GBOUT1
If dim([M:PDS3]SRHNUM)<nolign End : Endif : # Maximum lignes atteint
If [M:PDS3]SRHNUM(nolign-1)<>"" & GFONC1<>"GESSRH"
  GBOUT1=mess(458,198,1)-[M:PDS3]SRHNUM(nolign-1)
Endif
End
