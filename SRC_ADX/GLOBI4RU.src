#########################################################
Subprog  CAL_EVALUE_BONUS ( PBASE, PTAUX, PCUR, RBONUS)
#
# - Objet  : Calcule le montant du Bonus
#            pour les modes russes FQ59941
#
# - Entrée :
#            Base   (DPRBAS du plan fiscal)
#            Taux   (DPRRAT2)
#            Devise du contexte fical & comptable
#
# - Sortie : Bonus
#
#
  Value    Decimal PBASE
  Value    Decimal PTAUX
  Value    Char    PCUR
  Variable Decimal RBONUS

  RBONUS = 0
  If ( PTAUX <> 0 and PBASE <> 0 ) Then
    # Bonus = Base X Coefficient bonus
    RBONUS = PBASE * PTAUX

    # Arrondi en fonction de la devise du contexte
    Local Integer I_CUR
    I_CUR  = find( PCUR, GDEVISE(1..GNBDEV))
    RBONUS = arr(RBONUS, GDEVRND(I_CUR))
  Endif
End



#------------------------
$PLAFONNEMENT_A_VLNAMT
  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  If ( (abs([M:DIV]DOTEXE) + abs([M:DIV]AMTEXC) + abs(WDOTSUP)) > abs([M:DIV]VLNAMT) ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Dotation > Valeur nette => Ajustement ") From =G_GLOB0
    If ( abs([M:DIV]DOTEXE) + abs([M:DIV]AMTEXC ) > abs([M:DIV]VLNAMT)) Then
      [M:DIV]DOTSUP = 0
      WDOTSUP       = [M:DIV]DOTSUP : # FQ67110
      If ( abs([M:DIV]DOTEXE) > abs([M:DIV]VLNAMT) ) Then
        [M:DIV]DOTEXE = [M:DIV]VLNAMT
        [M:DIV]AMTEXC = 0
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Dotation exercice ajustée =" + num$([M:DIV]DOTEXE)) From =G_GLOB0
      Else
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Dotation > Valeur nette => Solde ") From =G_GLOB0
        [M:DIV]AMTEXC = [M:DIV]VLNAMT - [M:DIV]DOTEXE
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Amort. Except. ajusté =" + num$([M:DIV]AMTEXC)) From =G_GLOB0
      Endif
    Else
      [M:DIV]DOTSUP = [M:DIV]VLNAMT - ( [M:DIV]DOTEXE + [M:DIV]AMTEXC )
      WDOTSUP       = [M:DIV]DOTSUP : # FQ67110
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE - Dotation additionnelle  ajustée =" + num$([M:DIV]DOTSUP)) From =G_GLOB0
    Endif
  Endif

  [M:DIV]DOTEXE = [M:DIV]DOTEXE + WDOTSUP : # FQ67110
Return


#########################################################
Subprog  KRU_DUR_DET ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3,
&                      E04DTFN4, E04DTFN5, E04TYPPRODAT, E04PSEPLN, E04SESFLG, S04DURDET)
#
# - Objet  : Calcule la durée de détention dans l'intervalle (exercice ou période) qui correspond
#            à un nombre de jours, de semaines de mois ou d'année selon le type prorata
#
# - Rem.   : Date de début 1 et Date de fin 1 doivent être obligatoirement renseignées
#            Si l'une ou l'autre est nulle alors la durée de détention sera nulle
#
#
# - Entrée :
#            Date de début de l'intervalle (période ou exercice ) (obligatoire)
#            Date de fin de l'intervalle (période ou exercice)    (obligatoire)
#            Date de début divers
#            Date de fin divers
#            Date de début d'amortissement
#            Date de fin d'amortissement
#            Date de sortie
#            Date de classement du bien comme détenu pour la vente
#            Plan de saisonnalité
#
# - Sortie : Durée de détention
#
#   Boite noire gcfcd3
#
Value Date         E04DTDB1, E04DTDB2, E04DTDB3, E04DTFN1, E04DTFN2, E04DTFN3, E04DTFN4, E04DTFN5
Value Char         E04TYPPRODAT, E04PSEPLN
Value Integer      E04SESFLG
Variable Decimal   S04DURDET : S04DURDET = 0


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E04
Goto $DEB_KRU_DUR_DET
$GSB_KRU_DUR_DET
  # Déclaration des paramètres en entrée
  Local Date      E04DTDB1        : E04DTDB1     = [M:DIV]PD(0)
  Local Date      E04DTFN1        : E04DTFN1     = [M:DIV]PD(1)
  Local Date      E04DTDB2        : E04DTDB2     = [M:DIV]PD(2)
  Local Date      E04DTFN2        : E04DTFN2     = [M:DIV]PD(3)
  Local Date      E04DTDB3        : E04DTDB3     = [M:DIV]PD(4)
  Local Date      E04DTFN3        : E04DTFN3     = [M:DIV]PD(5)
  Local Date      E04DTFN4        : E04DTFN4     = [M:DIV]PD(6)
  Local Date      E04DTFN5        : E04DTFN5     = [M:DIV]PD(7)
  Local Char      E04TYPPRODAT    : E04TYPPRODAT = [M:DIV]PC(0)
  Local Char      E04PSEPLN       : E04PSEPLN    = [M:DIV]PC(1)
  Local Integer   E04SESFLG       : E04SESFLG    = [M:DIV]PE(0)
  Local Decimal   S04DURDET

$DEB_KRU_DUR_DET
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Date    L04DTDBDET , L04DTFNDET


  # Date de début & fin dans l'intervalle (exercice ou période)
  #Call CAL_DAT_BORNES
  #&    ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3, E04DTFN4,
  #&      E04DTFN5, L04DTDBDET, L04DTFNDET) From =G_GLOB9
  [M:DIV]PD(0)= E04DTDB1 : [M:DIV]PD(1)= E04DTFN1 : [M:DIV]PD(2)= E04DTDB2 : [M:DIV]PD(3)= E04DTFN2
  [M:DIV]PD(4)= E04DTDB3 : [M:DIV]PD(5)= E04DTFN3 : [M:DIV]PD(6)= E04DTFN4 : [M:DIV]PD(7)= E04DTFN5
  Gosub GSB_CAL_DAT_BORNES From =G_GLOB9
  L04DTDBDET = [M:DIV]RD(1)
  L04DTFNDET = [M:DIV]RD(2)
  If ([M:DIV]ERROR) Then :  If (dim(CALL_E04)<0) Then : Return : Else : End : Endif :   Endif

  # -1 --------------------------
  # Contrôle des dates obtenues
  If ( L04DTDBDET > L04DTFNDET ) Then
    S04DURDET = 0
  # -1 --------------------------
  Else
    If ( E04PSEPLN <> "" and E04SESFLG = G_OUI ) Then
      Local Integer IM
      S04DURDET = sigma( IM= month(L04DTDBDET), month(L04DTFNDET), [F:PSE]ACTFLG(IM-1) =G_OUI)
    Else
      # Durée de détention selon type de prorata
      #Call CAL_DAT_DIFF( L04DTDBDET, L04DTFNDET, PTYPPRODAT, S04DURDET ) From =G_GLOB9
      [M:DIV]PD(0)= L04DTDBDET : [M:DIV]PD(1)= L04DTFNDET : [M:DIV]PC(0)= E04TYPPRODAT
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : S04DURDET = [M:DIV]RV(0)
    Endif
  Endif
  # -1 --------------------------

  # Déduction de la durée de détention du nonbre de mois d'arret dans la période P1 à Pc de l'exercice
  Call ECR_FICH("FS1", 9, "KRU_DUR_DET - Durée de détention              = " + num$(S04DURDET)  ) From =G_GLOB0
  S04DURDET = S04DURDET - [F:DEPC]KFIYNBMSTP
  If ( S04DURDET < 0 ) Then : S04DURDET = 0 : Endif
  Call ECR_FICH("FS1", 9, "KRU_DUR_DET - Nombre de mois d'arrêt          = " + num$([F:DEPC]KFIYNBMSTP) ) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "KRU_DUR_DET - Durée de détention retraitée    = " + num$(S04DURDET)  ) From =G_GLOB0


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E04)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RV(1) = S04DURDET
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%



End

#
#########################################################
Subprog  KRU_DUR_REST_AMT (PDTDBAMT, PDTDB, PDTFNAMT, PPSEPLN, PSESFLG, RDUR_REST_AMT)
#
# - Objet  : Calcule la durée restant à amortir qui correspond à un nombre de mois
#            restant à courir jusqu'à la fin de l'amortissement
#
# - Entrée :
#
# - Sortie : Durée restant à amortir
#   Boite noire calc_dur_rest_amt (gcfc10)
#

Value     Date     PDTDBAMT, PDTDB, PDTFNAMT
Value     Char     PPSEPLN
Value     Integer  PSESFLG
Variable  Decimal  RDUR_REST_AMT : RDUR_REST_AMT = 0

Local     Date     LDAT

  LDAT = max(PDTDBAMT, PDTDB)
  # Si date de début > fin d'amortissement
  # la durée restant à amortir est nulle
  # ---------------------------
  If ( LDAT <= PDTFNAMT ) Then
    If ( PPSEPLN <> "" and PSESFLG = G_OUI ) Then
      # Durée restant à amortir selon type de prorata
      Local Integer IM
      If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
        # La date de fin d'amortissement est dans l'exercice
        RDUR_REST_AMT = sigma( IM= month(LDAT), month(PDTFNAMT), [F:PSE]ACTFLG(IM-1) =G_OUI)
      Else
        # Durée restant à amortir selon type de prorata
        #Call CAL_DAT_DIFF(LDAT, PDTFNAMT, PTYPPRODAT, RDUR_REST_AMT ) From =G_GLOB9
        [M:DIV]PD(0)= LDAT: [M:DIV]PD(1)= PDTFNAMT : [M:DIV]PC(0)= "M"
        Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : RDUR_REST_AMT = [M:DIV]RV(0)
      Endif
    Else
      # Durée restant à amortir selon type de prorata
      #Call CAL_DAT_DIFF(LDAT, PDTFNAMT, PTYPPRODAT, RDUR_REST_AMT ) From =G_GLOB9
      [M:DIV]PD(0)= LDAT: [M:DIV]PD(1)= PDTFNAMT : [M:DIV]PC(0)= "M"
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : RDUR_REST_AMT = [M:DIV]RV(0)
    Endif
  Endif
  # ---------------------------

  # Déduction de la durée de détention du nonbre de mois d'arret dans la période P1 à Pc de l'exercice
  Call ECR_FICH("FS1", 9, "KRU_DUR_REST_AMT - Durée de détention              = " + num$(RDUR_REST_AMT)  ) From =G_GLOB0
  RDUR_REST_AMT = RDUR_REST_AMT - [F:DEPC]KFIYNBMSTP
  If ( RDUR_REST_AMT < 0 ) Then : RDUR_REST_AMT = 0 : Endif
  Call ECR_FICH("FS1", 9, "KRU_DUR_REST_AMT - Nombre de mois d'arrêt          = " + num$([F:DEPC]KFIYNBMSTP)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "KRU_DUR_REST_AMT - Durée de détention retraitée    = " + num$(RDUR_REST_AMT)  ) From =G_GLOB0

End


#
#########################################################
Subprog CAL_DATE_FIN_AMORT_MODE_LR ( PDTDBAMT, PDURAMT, PTYPPRO,  RDTFNAMT )
#
# - Objet  : Renvoie la date de fin d'amortissement lorsque le mode LR
#            en fonction du type de prorata, de la date de début d'amortissement et d'une durée
#
#
# - Entrée :
#            Date de début d'amortissement (fichier)
#            Durée d'amortissement
#            Type de prorata
# - Sortie :
#            Date de fin d'amortissement

#   Boite noire
#
Value    Date      PDTDBAMT
Value    Decimal   PDURAMT
Value     Integer  PTYPPRO
Variable Date      RDTFNAMT

 #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # La saisonnalité est-elle à appliquer pour le plan
  Local Integer L_SESFLG
  L_SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))

  # Nombre de mois d'amortissement
  Local Decimal LNBM
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", PDURAMT, DUREM, PDURAMT, DUREM ) From =G_GLOB9

  # FQ67459
  If ( L_SESFLG = G_OUI ) Then
    LNBM = DUREM / [F:DEPC]ACLCOE * ( [M:DIV]PSEMOPN /12 )
  Else
    LNBM = DUREM / [F:DEPC]ACLCOE
  Endif
  Local    Decimal   LDECI   : LDECI = LNBM - fix(LNBM)
  Local    Decimal   LENT    : LENT  = LNBM - LDECI
  If (LDECI <> 0 ) Then : LENT = LENT + 1 :   Endif


  # Répartition du nombre de mois d'amortissement (LENT) selon la saisonnalité
  IMMAX = (LENT+1)*12
  IMCUR = month(PDTDBAMT)
  Local Integer IM : IM = 0
  For IMREG = 1 To IMMAX
    If ( [M:DIV]PSEPLN <> "" and L_SESFLG = G_OUI ) Then
      If ( [F:PSE]ACTFLG(IMCUR-1) = G_OUI ) Then
        IM = IM+1
        If (IM = LENT) Then : Break : Endif
      Endif
      IMCUR = IMCUR +1
      If (IMCUR = 13) Then : IMCUR = 1 : Endif
    Else
      IMREG = LENT : Break
    Endif
  Next IMREG

  # Détermination de la date de fin d'amortissement
  RDTFNAMT = PDTDBAMT - 1
  RDTFNAMT = addmonth(RDTFNAMT, IMREG + [F:DEPC]KNBMSTPDEP)


End


#########################################################
Subprog  CAL_DOT_EXE_LR
#
# - Objet  : Calcule la dotation de l'exercice selon le mode LR
#            Linéaire russe FQ59941
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir

  # If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  #FQ67110
  #[M:DIV]DOTSUP = 0
  If ( [F:DEPC]ACLCOE = 0. ) Then : [F:DEPC]ACLCOE = 1. : Endif

  # La saisonnalité est-elle à appliquer pour le plan
  Local Integer L_SESFLG
  L_SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))

  # Valeur amortissable
  Local Decimal L_VALAMT
  L_VALAMT      = [M:DIV]VALAMT
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Valeur amortissable           =" + num$(L_VALAMT)   ) From =G_GLOB0

  #=================
  # Bonus
  #=================
  # Si (bonus & plan fiscal) valeur amortissable est diminuée de n% de la base (DPRRAT2)
  If ([M:DIV]BBONUS) Then :  L_VALAMT -= [M:DIV]BONUS  : Endif
  # FQ67110 Rattrapage du bonus en cas sortie
  Local Decimal WDOTSUP : WDOTSUP = 0.

  If ( (not([M:DIV]BBONUS) and [M:DIV]VLNAMT = 0) or ([M:DIV]BBONUS and ([M:DIV]VLNAMT-[M:DIV]BONUS)=0) ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Valeur nette amortissable déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_LR - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Bonus                 =" + num$([M:DIV]BONUS)      ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LR - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================
  # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
  [F:DEPC]DPRDUR = [M:DIV]DURAMTREG
  # Nombre de mois d'amortissement
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:DIV]DURAMTREG, DUREM, [F:DEPC]DPRDUR, DUREM ) From =G_GLOB9

  # Taux d'amortissement mensuel (pour stockage et affichage)
  [M:DIV]TXAMT = arr( (1/DUREM)*[F:DEPC]ACLCOE, 0.000001)
  # Taux d'amortissement mensuel ( non arrondi pour calcul)
  Local Decimal L_TXMAMT
  L_TXMAMT = (1/DUREM)*[F:DEPC]ACLCOE
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Durée d'amort (mois)  =" + num$(DUREM)          ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Coef. d'accélèration  =" + num$([F:DEPC]ACLCOE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Taux mensuel = (1/ Durée ) * Coef.accél."       ) From =G_GLOB0

  # Mensualité
  If ( [M:DIV]PSEPLN <> "" and L_SESFLG = G_OUI ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Nbr mois actifs Exe.  =" + num$([M:DIV]PSEMOPN) ) From =G_GLOB0
    [M:DIV]DOTPSE = (( L_VALAMT * L_TXMAMT ) * 12 ) / [M:DIV]PSEMOPN
  Else
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Nbr mois actifs Exe.  =" + num$(12) ) From =G_GLOB0
    [M:DIV]DOTPSE = L_VALAMT * L_TXMAMT
  Endif
  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTPSE, [M:DIV]CUR, [M:DIV]DOTPSE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTPSE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTPSE = [M:DIV]RV(1)
  Call ECR_FICH("FS1",7, "Mensualité = (Val. amort. * Taux mensuel) * 12 / Nbr mois actifs Exe. " ) From =G_GLOB0
  Call ECR_FICH("FS1",7, "CAL_DOT_EXE_LR - Mensualité            ="+ num$([M:DIV]DOTPSE) ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  Gosub CAL_DATE_FIN_AMORT_LR From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)   ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Stop dépréciation - Si l'amortissement du bien est suspendu
  If ( [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Amortissement suspendu"  ) From =G_GLOB0
    [M:DIV]AMTEXC = [F:DEPC]PERCLOEXC
    [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Val. amortissable     =" + num$(L_VALAMT)       ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Taux mensuel          =" + num$(L_TXMAMT)       ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  KRU_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DATNUL, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, [M:DIV]PSEPLN, L_SESFLG, WDURDET) From =G_GLOB4RU
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= L_SESFLG
  Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Durée Détention Exe.        =" + num$(WDURDET) ) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice
  #---------------------------------------------
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
    # La date de fin d'amortissement appartient à l'exercice
    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir

    Call  KRU_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]PSEPLN, L_SESFLG,  WDURRES)
&   From =G_GLOB4RU
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1",7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée residuelle)  " ) From =G_GLOB0
      [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      [M:DIV]DOTEXE = 0
    Endif
  Else
    Call ECR_FICH("FS1",7,
&     "Dotation exercice = Mensualité * Nombre de mois ouverts de l'Exe  " ) From =G_GLOB0
    [M:DIV]DOTEXE = [M:DIV]DOTPSE * WDURDET
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301FIS) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Calcul dotation additionnelle en cas de sortie d'un bien bénéficiant d'un bonus dans les 5 ans après sa mise en service
  # Le plan minimum est considéré à l'identique du plan fiscal hors bonus
  Local Integer BDOTSUP : BDOTSUP = 0
  If ( [M:DIV]BBONUS and [M:DIV]PLNMIN ) Then
    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
      If ( func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTDBAMTREG, 5, "Y" ) > [M:DIV]DATSORREG ) Then
        If ( abs([M:PMIN]DPRCUM([M:DIV]DL-1) + [M:PMIN]ENDDPE([M:DIV]DL-1)) > abs([F:DEPC]DPRCUM + [M:DIV]DOTEXE) ) Then
          [M:DIV]DOTSUP = ([M:PMIN]DPRCUM([M:DIV]DL-1)+[M:PMIN]ENDDPE([M:DIV]DL-1))-([F:DEPC]DPRCUM+[M:DIV]DOTEXE)
          WDOTSUP = [M:DIV]DOTSUP : #FQ67110
          BDOTSUP = 1
          Call ECR_FICH("FS1",7, "CAL_DOT_EXE_LR - Dotation suppl.       ="+ num$([M:DIV]DOTSUP) ) From =G_GLOB0
        Endif
      Endif
    Endif
  Endif

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  If (!BDOTSUP and [M:DIV]BBONUS) Then : [M:DIV]VLNAMT -= [M:DIV]BONUS : Endif
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4RU

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LR - Dotation exe.            =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End



#########################################################
Subprog  CAL_DOT_EXE_CR
#
# - Objet  : Calcule la dotation de l'exercice selon le mode CR
#            Dégressif russe FQ59941
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#

Local Integer I_P
Local Decimal L_VALNET

  # If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  [M:DIV]DOTEXE = 0.
  [M:DIV]AMTEXC = 0
  # FQ67110
  # [M:DIV]DOTSUP = 0
  If ( [F:DEPC]ACLCOE = 0. ) Then : [F:DEPC]ACLCOE = 1. : Endif

  # Initialisation du tableau des périodes du masque CALDIV (Dotation exercice = somme des dotations période
  #    ***************
  Call CAL_INI_PER_EXE ( [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT ) From =G_GLOB7
 #    ***************

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Aide fiscale          =" + num$([M:DIV]AFI)        ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Déb. Exercice  résid. =" + num$([M:DIV]EXEDATREF)  ) From =G_GLOB0
  Endif

  # Valeur nette
  Local Decimal L_VLNAMT
  L_VLNAMT = [M:DIV]VLNAMT
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Valeur nette amortissable =" + num$(L_VLNAMT)   ) From =G_GLOB0

  #=================
  # Bonus
  #=================
  # la valeur nette amortissable est diminuée de n% de la base (DPRRAT2)
  If ([M:DIV]BBONUS and L_VLNAMT <> 0 ) Then
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Bonus                         = " + num$([M:DIV]BONUS)        ) From =G_GLOB0
    L_VLNAMT -= [M:DIV]BONUS
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Valeur nette retraitée        =" + num$(L_VLNAMT)   ) From =G_GLOB0
  Endif
  # FQ67110 Rattrapage du bonus en cas sortie
  Local Decimal WDOTSUP : WDOTSUP = 0.

  If ( L_VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CR - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_CR - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Pour le calcul, la valeur nette est diminuée de l'écart sur cumul E-1
  # car cet écart est forcemment rattrapé dans la période dans laquelle
  # a eu lieu le changement de méthode : il est ajouté soit à la dotation de la période
  # à l'amortissement exceptionnel de la période.
  If ( [F:DEPC]FIYENDDAT  = [M:FIY]DATENDFIY([M:DIV]FEC-1) ) Then
    L_VLNAMT -= [M:DIV]ECACUME_1R
  Endif
  L_VALNET  = L_VLNAMT

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
  [F:DEPC]DPRDUR = [M:DIV]DURAMTREG
  # Nombre de mois d'amortissement
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:DIV]DURAMTREG, DUREM, [F:DEPC]DPRDUR, DUREM ) From =G_GLOB9

  If   ( DUREM > 360 ) Then
    [F:DEPC]DPRRAT = 0.007
  Elsif( DUREM > 300 ) Then
    [F:DEPC]DPRRAT = 0.008
  Elsif( DUREM > 240 ) Then
    [F:DEPC]DPRRAT = 0.01
  Elsif( DUREM > 180 ) Then
    [F:DEPC]DPRRAT = 0.013
  Elsif( DUREM > 120 ) Then
    [F:DEPC]DPRRAT = 0.018
  Elsif( DUREM > 84 ) Then
    [F:DEPC]DPRRAT = 0.027
  Elsif( DUREM > 60 ) Then
    [F:DEPC]DPRRAT = 0.038
  Elsif( DUREM > 36 ) Then
    [F:DEPC]DPRRAT = 0.056
  Elsif( DUREM > 24 ) Then
    [F:DEPC]DPRRAT = 0.088
  Else
    [F:DEPC]DPRRAT = 0.143
  Endif

  [M:DIV]TXAMT = arr( [F:DEPC]DPRRAT * [F:DEPC]ACLCOE, 0.000001)
  Local Decimal L_TXAMT
  L_TXAMT = [F:DEPC]DPRRAT * [F:DEPC]ACLCOE
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CR - Taux selon durée      =" + num$([F:DEPC]DPRRAT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CR - Coef. accélération    =" + num$([F:DEPC]ACLCOE)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CR - Taux  d'amortissement =" + num$(L_TXAMT)     ) From =G_GLOB0


  #=================
  # Date Fin Amort. (toujours à [0/0/0])
  #=================
  Gosub CAL_DATE_FIN_AMORT_CR From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CR - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0


  # Prise en compte des amortissements déjà constatés sur les périodes closes
  I_P = find([F:DEPC]PERSTRDAT-1, [M:DIV2]PERENDDAT)
  If ([F:DEPC]PERCLOCUM <> 0) Then
    [M:DIV2]DOTPER(I_P-1) = [F:DEPC]PERCLOCUM
    [M:DIV2]DOT1AP(I_P-1) = [F:DEPC]PERCLOCUM : # FQ82485
    [M:DIV]DOTEXE        = [F:DEPC]PERCLOCUM
    L_VALNET             = L_VALNET - [F:DEPC]PERCLOCUM
  Endif


  # Calcul pour les prériodes restants à clore
  #>>>>>>>>>>>>>>>>>
  For I_P = 1 To [M:DIV2]NB_PER
    #- 1 -------------------------
    If ( [M:DIV]DTDBAMTREG < [M:DIV2]PERENDDAT(I_P-1) ) Then
    If ( [M:DIV2]PERSTRDAT(I_P-1) >= [F:DEPC]PERSTRDAT ) Then
      #- 2 -------------------------
      If ( [M:DIV]DATSORREG = [0/0/0] or [M:DIV]DATSORREG >= [M:DIV2]PERENDDAT(I_P-1)  ) Then
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Déb. Période          =" + num$([M:DIV2]PERSTRDAT(I_P-1))    ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Fin. Période          =" + num$([M:DIV2]PERENDDAT(I_P-1))    ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Valeur nette          =" + num$(L_VALNET)                   ) From =G_GLOB0
        # Dotation période
        If ( [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
          # Amortissement suspendu
          [M:DIV2]DOTPER(I_P-1) =  0.
        Else
          [M:DIV2]DOTPER(I_P-1) =  L_VALNET * [M:DIV]TXAMT
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT ([M:DIV2]DOTPER(I_P-1), [M:DIV]CUR, [M:DIV2]DOTPER(I_P-1)) From =G_GLOB8
          [M:DIV]PV(0)= [M:DIV2]DOTPER(I_P-1) : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV2]DOTPER(I_P-1) = [M:DIV]RV(1)
        Endif
        # Entretien valeur nette
        If ( abs([M:DIV2]DOTPER(I_P-1)) > abs(L_VALNET)) Then
          [M:DIV2]DOTPER(I_P-1) = L_VALNET
        Endif
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Dotation période      =" + num$([M:DIV2]DOTPER(I_P-1))  ) From =G_GLOB0
        # La dotation exercice est le total des dotations des périodes
        [M:DIV]DOTEXE          += [M:DIV2]DOTPER(I_P-1)
        # La valeur nette est diminuée de la dotation de la période
        L_VALNET               -= [M:DIV2]DOTPER(I_P-1)
        # Entretien Cumul 1 à Pc
        If (I_P > 1 ) Then :  [M:DIV2]DOT1AP((I_P-1)) = [M:DIV2]DOT1AP((I_P-2)) : Endif
        [M:DIV2]DOT1AP((I_P-1)) += [M:DIV2]DOTPER(I_P-1)
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Cumul 1 à P           =" + num$([M:DIV2]DOT1AP(I_P-1))  ) From =G_GLOB0
      Endif
      #- 2 -------------------------
    Endif
    Endif
    #- 1 -------------------------
  Next I_P
  #>>>>>>>>>>>>>>>>>

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  Call ECR_FICH
& ("FS1", 7, "CAL_DOT_EXE_CR - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0

  # Calcul dotation additionnelle en cas de sortie d'un bien bénéficiant d'un bonus dans les 5 ans après sa mise en service
  # Le plan minimum est considéré à l'identique du plan fiscal hors bonus
  Local Integer BDOTSUP : BDOTSUP = 0
  If ( [M:DIV]BBONUS and [M:DIV]PLNMIN ) Then
    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
      If ( func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTDBAMTREG, 5, "Y" ) > [M:DIV]DATSORREG ) Then
        If ( abs([M:PMIN]DPRCUM([M:DIV]DL-1) + [M:PMIN]ENDDPE([M:DIV]DL-1)) > abs([F:DEPC]DPRCUM + [M:DIV]DOTEXE) ) Then
          [M:DIV]DOTSUP = ([M:PMIN]DPRCUM([M:DIV]DL-1)+[M:PMIN]ENDDPE([M:DIV]DL-1)) - ([F:DEPC]DPRCUM + [M:DIV]DOTEXE)
          WDOTSUP = [M:DIV]DOTSUP : # FQ67110
          BDOTSUP = 1
          Call ECR_FICH("FS1",7, "CAL_DOT_EXE_CR - Dotation suppl.       ="+ num$([M:DIV]DOTSUP)) From =G_GLOB0
          # Dotation supplémentaire  sur Pc ou sur la période de sortie si celle-ci est ulérieure à la Pc
          [M:DIV]DOTEXE  = [M:DIV]DOTEXE + [M:DIV]DOTSUP
          If ( [M:DIV]DATSORREG > [M:DEP]PERENDDAT([M:DIV]DPC-1) ) Then
            I_P = func GLOBB9.CAL_LOCALISE_DAT ([M:DIV]DATSORREG, [M:DIV2]PERSTRDAT, [M:DIV2]PERENDDAT, 0, [M:DIV2]NB_PER-1)
            [M:DIV2]DOTPER(I_P) = [M:DIV2]DOTPER(I_P) + [M:DIV]DOTSUP
            [M:DIV2]DOT1AP(I_P) = [M:DIV2]DOT1AP(I_P) + [M:DIV]DOTSUP
          Else
            I_P = func GLOBB9.CAL_LOCALISE_DAT ([M:DEP]PERENDDAT([M:DIV]DPC-1), [M:DIV2]PERSTRDAT, [M:DIV2]PERENDDAT, 0, [M:DIV2]NB_PER-1)
            [M:DIV2]DOTPER(I_P) = [M:DIV2]DOTPER(I_P) + [M:DIV]DOTSUP
            [M:DIV2]DOT1AP(I_P) = [M:DIV2]DOT1AP(I_P) + [M:DIV]DOTSUP
          Endif
        Endif
      Endif
    Endif
  Endif

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  If (!BDOTSUP) Then : [M:DIV]VLNAMT = L_VLNAMT : Endif
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4RU

  # Solde de l'amortissement
  If ( [M:DIV]DOTEXE = 0 and abs([M:DIV]VLNAMT) < 1.00 ) Then
    [M:DIV]DOTEXE    = [M:DIV]VLNAMT
    [M:DIV2]DOTPER(0) = [M:DIV]VLNAMT
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_CR - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End



#########################################################
Subprog  CAL_DOT_EXE_UR
#
# - Objet  : Calcule la dotation de l'exercice selon le mode Unité d'oeuvre
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire GCFC50
#

Local Decimal WVALNET  : WVALNET  = 0.  : # Valeur nette début d'exercice
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation de l'exercice
Local Decimal WQTE     : WQTE     = 0.  : # Nombre d'UO de référence pour la période/exercice
Local Decimal WDURREF  : WDURREF  = 0.  : # Durée de la période/exercice
Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans la période/exercice
Local Decimal WUOEXE   : WUOEXE   = 0.  : # Nombre d'UO pour l'exercice résiduel

Local Integer IPP      : # Indice plan de production
Local Integer IPC      : # Indice période courante
Local Integer IDBE     : # Indice début exercice
Local Integer IFNE     : # Indice fin exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  #FQ67110
  #[M:DIV]DOTSUP = 0
  Local Decimal WDOTSUP : WDOTSUP = 0

  #=================
  # Taux / Duree
  #=================
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
  [M:DIV]TXAMT     = 0.
  #---------------------

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]PERSTRDAT = [01/01/2010] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_UR From =G_GLOB8
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UR - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Si fin du plan de production est renseignée et antérieure au début d'amortissement
  # Pas de calcul, la dotation exercice est égale à 0
  If ( [M:DIV]DTFNPPL <> [0/0/0] and [M:DIV]DTFNPPL < [M:DIV]DTDBAMTREG ) Then
    [F:DEPC]FIYQTY = 0
    Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Incohérence Amortissement & Plan de Production "  ) From =G_GLOB0
    Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Fin plan production   ="+ num$([M:DIV]DTFNPPL   )  ) From =G_GLOB0
    Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Début d'amort.        ="+ num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
    Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UR - UO exercice           =" + num$([F:DEPC]FIYQTY  ) ) From =G_GLOB0
    Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UR - Dotation exe.         =" + num$([M:DIV]DOTEXE   ) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
   End
  # ***
  Endif

  #====================
  # Plan de production
  #====================


  # Indice période courante
  IPC  = find([F:DEPC]PERENDDAT, [M:PPL]PERENDDAT)
  # Indice début exercice courant
  IDBE  = find([F:DEPC]FIYSTRDAT, [M:PPL]PERSTRDAT)
  If (IDBE = 0 ) Then : IDBE = 1 : Endif
  # Indice fin exercice courant
  IFNE  = find([F:DEPC]FIYENDDAT, [M:PPL]PERENDDAT)

  #-1 -------------------------
  If ( [M:DIV]BCALPPL ) Then
    [M:DIV] BCALPPL = 0
    [M:PPL]IPSO = 0
    Raz [M:PPL]IFNA
    Raz [M:PPL]PERQTY
    Raz [M:PPL]RSDQTY

    # UO période jusqu'à fin d'amortissement ( UO période déb amort proratée selon la détention )
    # >>>>>>>>>>>>
    For IPP = 1 To [M:PPL]NB_PPL
      # UO période référence : Prévues/Réalisées
      If ( [M:PPL]CPLQTY(IPP-1) <> 0 ) Then
        WQTE = [M:PPL]CPLQTY(IPP-1)
      Else
        WQTE = [M:PPL]EXTQTY(IPP-1)
      Endif
      # Durée de détention dans la période/exercice ( sans tenir compte de la date de sortie)
#      Call CAL_DUR_DET
#&         ([M:PPL]PERSTRDAT(IPP-1),  [M:PPL]PERENDDAT(IPP-1), [M:DIV]DATNUL, [M:DIV]DATNUL,
#&          [M:DIV]DTDBAMTREG, [M:DIV]DTFNAMT, [M:DIV]DATNUL, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET
#&         ) From =G_GLOB8
      [M:DIV]PD(0)= [M:PPL]PERSTRDAT(IPP-1) : [M:DIV]PD(1)= [M:PPL]PERENDDAT(IPP-1)
      [M:DIV]PD(2)= [M:DIV]DATNUL  : [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG
      [M:DIV]PD(5)= [M:DIV]DTFNAMT : [M:DIV]PD(6)= [M:DIV]DATNUL : [M:DIV]PD(7)= [M:DIV]DETVTEDAT
      [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif

      # Durée de la période/exercice
      Call CAL_DAT_DIFF( [M:PPL]PERSTRDAT(IPP-1), [M:PPL]PERENDDAT(IPP-1), [M:DIV]TYPPRODAT,
&                        WDURREF ) From =G_GLOB9
      # UO période pour le plan
      [M:PPL]PERQTY(IPP-1) = WQTE * ( WDURDET / WDURREF )
      Call QTEARR([M:PPL]PERQTY(IPP-1), [M:PPL]UOM) From TRTDIV

      If ( [M:DIV]NIVDET > 9 ) Then
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UR - Evaluation à borne d'amortissement" )           From =G_GLOB0
        Call ECR_FICH("FS1", 10,
&           "CAL_DOT_EXE_UR - "-num$([M:PPL]PERSTRDAT(IPP-1))-"-"-num$([M:PPL]PERENDDAT(IPP-1)) ) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UR - UO pér. prod. ="  + num$(WQTE)                ) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UR - Dur détention ="  + num$(WDURDET)             ) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UR - Dur référence ="  + num$(WDURREF)             ) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UR - UO période    ="  + num$([M:PPL]PERQTY(IPP-1))) From =G_GLOB0
        Call ECR_FICH("FS1", 10,"CAL_DOT_EXE_UR - -------------------------" )                    From =G_GLOB0
      Endif
      # Indice fin d'amortissement
      If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:PPL]PERSTRDAT(IPP-1),
&                                                    [M:PPL]PERENDDAT(IPP-1),"I")) Then
        [M:PPL]IFNA = IPP
        Break
      Endif
    Next IPP
    # <<<<<<<<<<<<


    If ( [M:PPL]IFNA = 0 ) Then
      # Si la date de fin d'amortissement est au delà de l'horizon du plan de production
      # L'indice récupére l'horizon du plan de production
      [M:PPL]IFNA = [M:PPL]NB_PPL
    Endif


    #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

    # UO résiduelle début de période
    # Début de période courante
    [M:PPL]RSDQTY(IPC-1)= sum( [M:PPL]PERQTY (IPC-1..[M:PPL]IFNA-1) )
    #-----------------------
    If ( IPC <> [M:PPL]IFNA ) Then
      # >>>>>>>>>>>>
      For IPP = IPC+1 To [M:PPL]IFNA
        # début de période n
        [M:PPL]RSDQTY(IPP-1) = [M:PPL]RSDQTY(IPP-2) - [M:PPL]PERQTY(IPP-2)
        If ([M:DIV]NIVDET > 8 ) Then
        Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - "
&                      + format$([M:DIV]DATFMT,[M:PPL]PERSTRDAT(IPP-1)) + " - "
&                      + format$([M:DIV]DATFMT,[M:PPL]PERENDDAT(IPP-1))                         ) From =G_GLOB0
        Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - UO résid déb per ="+ num$([M:PPL]RSDQTY(IPP-1))) From =G_GLOB0
        Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - UO période       ="+ num$([M:PPL]PERQTY(IPP-1))) From =G_GLOB0
        Endif
        # Indice période de Sortie
        If ( [M:DIV]DATSOREXE <> [0/0/0] and
&            func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSOREXE,[M:PPL]PERSTRDAT(IPP-1),
&                                                        [M:PPL]PERENDDAT(IPP-1),"I")) Then
          [M:PPL]IPSO = IPP
        Endif
      Next IPP
      # <<<<<<<<<<<<
    Endif
    #-----------------------

    # UO période de Sortie
    If ([M:PPL]IPSO) Then
      # Durée de détention dans la période/exercice
#     Call  CAL_DUR_DET
#&         ([M:PPL]PERSTRDAT([M:PPL]IPSO-1),  [M:PPL]PERENDDAT([M:PPL]IPSO-1), [M:DIV]DATNUL, [M:DIV]DATNUL,
#&          [M:DIV]DTDBAMTREG, [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET
#&         ) From =G_GLOB8
      [M:DIV]PD(0)= [M:PPL]PERSTRDAT([M:PPL]IPSO-1) : [M:DIV]PD(1)= [M:PPL]PERENDDAT([M:PPL]IPSO-1)
      [M:DIV]PD(2)= [M:DIV]DATNUL  : [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG
      [M:DIV]PD(5)= [M:DIV]DTFNAMT : [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT
      [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      # Durée de la période/exercice
      Call CAL_DAT_DIFF( [M:PPL]PERSTRDAT([M:PPL]IPSO-1), [M:PPL]PERENDDAT([M:PPL]IPSO-1), [M:DIV]TYPPRODAT,
&                        WDURREF ) From =G_GLOB9
      [M:PPL]PERQTY([M:PPL]IPSO-1) = [M:PPL]PERQTY([M:PPL]IPSO-1) * ( WDURDET / WDURREF )
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - Evaluation UO pour la période de sortie"        ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,
&         "CAL_DOT_EXE_UR - "-num$([M:PPL]PERSTRDAT([M:PPL]IPSO-1))-"-"-num$([M:PPL]PERENDDAT([M:PPL]IPSO-1))) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - UO pér. prod. ="  + num$([M:PPL]PERQTY([M:PPL]IPSO-1)) ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - Dur détention ="  + num$(WDURDET)               ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - Dur référence ="  + num$(WDURREF)               ) From =G_GLOB0
      Call ECR_FICH("FS1", 9,"CAL_DOT_EXE_UR - UO période    ="  + num$([M:PPL]PERQTY([M:PPL]IPSO-1)) ) From =G_GLOB0
    Endif
  Endif
  #-1 -------------------------


  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  If ([M:PPL]IPSO) Then
    # Nombre d'UO pour l'exercice résiduel
    WUOEXE = sum([M:PPL]PERQTY(IPC-1..min([M:PPL]IPSO, IFNE,[M:PPL]IFNA)-1))
    # UO exercice complet
    [F:DEPC]FIYQTY = sum([M:PPL]PERQTY(IDBE-1..min([M:PPL]IPSO, IFNE,[M:PPL]IFNA)-1))
  Else
    # Nombre d'UO pour l'exercice résiduel
    WUOEXE = sum([M:PPL]PERQTY(IPC-1..min(IFNE,[M:PPL]IFNA)-1))
    # UO exercice complet
    [F:DEPC]FIYQTY = sum([M:PPL]PERQTY(IDBE-1..min(IFNE,[M:PPL]IFNA)-1))
  Endif

  # Valeur nette
  Local Decimal L_VLNAMT
  L_VLNAMT = [M:DIV]VLNAMT
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Valeur nette amortissable =" + num$(L_VLNAMT)   ) From =G_GLOB0

  If ( L_VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UR - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_UR - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ([M:DIV]NIVDET > 6 ) Then
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Déb. Exercice         ="+ num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Fin  Exercice         ="+ num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Début d'amort.        ="+ num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Fin   d'amort.        ="+ num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Date de sortie        ="+ num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Date de sortie Exe    ="+ num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Base                  ="+ num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Valeur résiduelle     ="+ num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Cumul  E-1            ="+ num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - Durée                 ="+ num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Call ECR_FICH("FS1",8, "CAL_DOT_EXE_UR - UO exercice           ="+ num$([F:DEPC]FIYQTY)    ) From =G_GLOB0
  Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UR - Valnet amort déb exe  ="+ num$(L_VLNAMT)          ) From =G_GLOB0
  Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UR - UO exercice résiduel  ="+ num$(WUOEXE)            ) From =G_GLOB0
  Call ECR_FICH("FS1",7, "CAL_DOT_EXE_UR - UO Résiduel déb pér.  ="+ num$([M:PPL]RSDQTY(IPC-1))) From =G_GLOB0
  Endif

  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  # calcul de la dotation exercice
  If ( [M:PPL]RSDQTY(IPC-1)<> 0 ) Then
    Call ECR_FICH("FS1", 7,
&   "Dotation exercice = Val. nette déb. exe. * ( UO exercice résiduel / UO Résiduel déb pér.)") From =G_GLOB0
    WDOTEXE = L_VLNAMT * WUOEXE / [M:PPL]RSDQTY(IPC-1)
  Else
    WDOTEXE = 0
  Endif
  #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4RU

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_UR - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_SR
#
# - Objet  : Calcule la dotation de l'exercice selon le mode "SOFTY russe"
#
# - Entrée : [M:DEPC] Structure
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE  Dotation de l'exercice
#   [M:DIV]TXAMT   Taux d'amortissement
#
#   Boite noire gcfc40
#

Local Decimal WDURDET  : WDURDET  = 0.       : # Durée de détention dans l'exercice partie 1
Local Decimal WDURRES  : WDURRES  = 0.       : # Durée restant à amortir
Local Decimal WDURANN  : WDURANN  = 0.       : # Durée annuité
Local Decimal WDOTEXE  : WDOTEXE  = 0.       : # Dotation de l'exercice
Local Decimal WDOTEX1  : WDOTEX1  = 0.       : # Dotation de l'exercice partie 1
Local Decimal WDOTEX2  : WDOTEX2  = 0.       : # Dotation de l'exercice partie 2
Local Integer WANN     : WANN     = 0        : # Annuité courante
Local Decimal WSOFTY   : WSOFTY   = 0        : # Somme des années (Durée 3 / SOFTY = 6 i.e 1+2+3)

Local Date    LDTDB    : LDTDB    = [0/0/0]  : # Date début annuité partie 1
Local Date    LDTFN    : LDTFN    = [0/0/0]  : # Date fin annuité partie 1
Local Date    LDTDB2   : LDTDB2   = [0/0/0]  : # Date début annuité partie 2
Local Date    LDATSAV  : LDATSAV  = [0/0/0]  : # Date sauvegardée


  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  #FQ67110
  #[M:DIV]DOTSUP = 0
  Local Decimal WDOTSUP : WDOTSUP = 0
  WDOTEX1       = 0.
  WDOTEX2       = 0.

  #=================
  # Durée Fin Amort.
  #=================
  # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
  [F:DEPC]DPRDUR = [M:DIV]DURAMTREG

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_SR From =G_GLOB8


  # Valeur amortissable
  Local Decimal L_VALAMT
  L_VALAMT = [M:DIV]VALAMT
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Valeur amortissable           =" + num$(L_VALAMT)   ) From =G_GLOB0

  #---------------------
  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Base                  =" + num$(L_VALAMT)          ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Valeur amortissable   =" + num$(L_VALAMT) ) From =G_GLOB0

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  # Somme des années : Ex. Durée 3 ans => SOFTY = 6 (1+2+3) équivalent à (n+(n+1))/2 avec n= durée  + éventuelle partie décimale
  Local    Decimal   LDECI   : LDECI = [M:DIV]DURAMTREG - fix([M:DIV]DURAMTREG)
  Local    Decimal   LENT    : LENT  = [M:DIV]DURAMTREG - LDECI
  # Nombre de mois de la partie décimale
  Local Integer L_NBM
  Local Decimal L_DUR
  Call CAL_DUREE_OU_NBMOIS ( "D", LDECI, L_NBM, L_DUR, L_NBM) From =G_GLOB9
  # L_NBM/12 est plus précis que LDECI
  WSOFTY  = (LENT *(LENT+1) )/2 + (L_NBM/12)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Somme des années      =" + num$(WSOFTY) ) From =G_GLOB0


  #----------------------------------------
  # Recherche de l'année courante (WANN)
  #           de la date de début pour calcul 1ère partie de la dotation (LDTDB)
  #           de la date de début pour calcul 2ème partie de la dotation (LDTDB2)
  LDTDB  = [M:DIV]DTDBAMTREG
  WANN = 1
  #While ( LDTDB < [M:DIV]DTDBEXE )
  #While ( LDTDB + [F:DEPC]KNBMSTPDEP < [M:DIV]DTDBEXE )
  # FQ66518
  Local Date WDTDB : WDTDB = addmonth(LDTDB, [F:DEPC]KNBMSTPDEP)
  While ( WDTDB < [M:DIV]DTDBEXE )
    WANN += 1 : LDATSAV = LDTDB
    LDTDB = func GLOBB9.CAL_DAT_PLUS( LDTDB, 1, "Y" )
    WDTDB = func GLOBB9.CAL_DAT_PLUS( WDTDB, 1, "Y" )
  Wend
  If ( LDTDB <> [M:DIV]DTDBAMTREG and LDTDB <> [M:DIV]DTDBEXE ) Then
    WANN -= 1 : LDTDB = LDATSAV
  Endif
  # Date de début pour calcul 2ème partie de la dotation
  LDTDB2 = func GLOBB9.CAL_DAT_PLUS( LDTDB,  1, "Y" )
  # Ajout du nombre de mois d'arrêt
  LDTDB2 = func GLOBB9.CAL_DAT_PLUS( LDTDB2,  [F:DEPC]KNBMSTPDEP, "M" )
  # Date de fin pour calcul 1ère partie de la dotation
  LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTDB2, -1, "D" )
  [M:DIV]DTFN1  = LDTFN : # Pour calcul périodique
  # Ajustement du nombre d'année en fonction du nombre de mois d'arrêt
  WANN = WANN - fix([F:DEPC]KNBMSTPDEP/12)
  #----------------------------------------

  # Valeur nette amortissable nulle
  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Valeur nette amortissable déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_SR - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Stop dépréciation - Si l'amortissement du bien est suspendu
  If (  [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Amortissement suspendu"  ) From =G_GLOB0
    [M:DIV]AMTEXC = [F:DEPC]PERCLOEXC
    [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #-0 --------------------
  If (LDECI = 0) Then
    # Equivalent au SOFTY ( nombre d'année entière )
    #-1 --------------------
    If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
      # La date de fin d'amortissement n'appartient pas à l'exercice

      # --------------
      # --- Partie 1
      # --------------
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Annuité partie 1           =" + num$(WANN) ) From =G_GLOB0
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date début Partie 1        =" + num$(LDTDB ) ) From =G_GLOB0
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date fin partie 1          =" + num$(LDTFN ) ) From =G_GLOB0
      # Durée de détention dans l'exercice
  #   Call  KRU_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,    LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
  #&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
      [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée Détention partie 1   =" + num$(WDURDET) ) From =G_GLOB0
      # Calcul de la durée de l'exercice selon le type de prorata
      Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée annuité partie 1     =" + num$(WDURANN) ) From =G_GLOB0

      # calcul de la dotation exercice partie 1
      If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
        [M:DIV]TXAMT1 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Taux amort. partie 1       =" + num$([M:DIV]TXAMT1) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8,
&       "Dotation partie 1 = Val.amort. * Taux amort.partie 1 * (Dur. Dét. partie 1 / Dur. annuité partie 1)") From =G_GLOB0
        WDOTEX1 = L_VALAMT * [M:DIV]TXAMT1   * ( WDURDET / WDURANN )
        #Call CAL_ARRONDI_MNT (WDOTEX1, [M:DIV]CUR , WDOTEX1) From =G_GLOB8
        [M:DIV]PV(0)= WDOTEX1: [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX1 = [M:DIV]RV(1)
      Else
        WDOTEX1 = 0
      Endif
      Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_SR - Dotation exercice partie 1 =" + num$(WDOTEX1) ) From =G_GLOB0

      # --------------
      # --- Partie 2
      # --------------
      While ( [M:DIV]DTFNEXE > LDTFN  and
&             ( [M:DIV]DATSOREXE = [0/0/0] or  [M:DIV]DATSOREXE  > LDTFN )   )
        WANN += 1 : LDTDB = LDTDB2
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Annuité partie 2          =" + num$(WANN) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date début partie 2       =" + num$(LDTDB ) ) From =G_GLOB0
        # Date de fin pour calcul 2ème partie de la dotation
        LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTDB,   1, "Y" )
        LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTFN,  -1, "D" )
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date fin   partie 2       =" + num$(LDTFN ) ) From =G_GLOB0
        # Durée de détention dans l'exercice
  #     Call  KRU_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,   LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
  #&          [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
        [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
        WDURDET = [M:DIV]RV(1)
        If ([M:DIV]ERROR) Then : End : Endif
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée Détention partie 2  =" + num$(WDURDET) ) From =G_GLOB0
        # Calcul de la durée de l'annuité selon le type de prorata
        Call CAL_DUR_EXE_REF (LDTDB, LDTFN, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
        Call ECR_FICH("FS1", 8, "   Durée annuité partie 2     =" + num$(WDURANN) ) From =G_GLOB0

        # calcul de la dotation exercice partie 2
        If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
          [M:DIV]TXAMT2 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Taux amort. partie 2       =" + num$([M:DIV]TXAMT2) ) From =G_GLOB0
          Call ECR_FICH("FS1", 8,
&         "Dotation partie 2 = Val. amort. * Taux amort.partie 2 * (Dur. Dét. partie 2 / Dur. annuité partie 2)") From =G_GLOB0
          WDOTEX2 = L_VALAMT * [M:DIV]TXAMT2 * ( WDURDET / WDURANN )
          #Call CAL_ARRONDI_MNT (WDOTEX2, [M:DIV]CUR , WDOTEX2) From =G_GLOB8
          [M:DIV]PV(0)= WDOTEX2: [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX2 = [M:DIV]RV(1)
        Else
          WDOTEX2 = 0
        Endif
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Dotation exercice partie 2 =" + num$(WDOTEX2) ) From =G_GLOB0
      Wend
      # --------------
      # --- Dotation
      # --------------
      # Dotation exercice = Dotation partie 1  + Dotation partie 2
      WDOTEXE = WDOTEX1 + WDOTEX2
      # Solde de la valeur nette lorsque la dotation est > à la valeur nette
      If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
        WDOTEXE = [M:DIV]VLNAMT
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Solde du reste à amortir ") From =G_GLOB0
      Endif

    #-1 --------------------
    Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
      # La fin d'amortissement a lieu dans l'exercice
      # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
      # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

      # Taux Partie 1 & partie 2 pour périodique
      [M:DIV]TXAMT1 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
      [M:DIV]TXAMT2 = 0.

      # Durée de détention dans l'exercice
  #   Call  CAL_KRU_DET
  #&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
  #&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
      WDURDET = [M:DIV]RV(1)
      # Calcul de la durée restant à amortir
      Call  CAL_DUR_REST_AMT
&           ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&     From =G_GLOB8
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Durée Détention Exe.  =" +  num$(WDURDET) ) From =G_GLOB0
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0
      If ([M:DIV]ERROR) Then : End : Endif

      #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
      # calcul de la dotation exercice
      If ( WDURRES <> 0 ) Then
        Call ECR_FICH("FS1", 7,
&       "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
        WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        WDOTEXE = 0
      Endif
      #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

    Endif
    #-1 --------------------
  Endif
  #-0 --------------------

  #-0 --------------------
  If (LDECI <> 0) Then
    #-1 --------------------
    If ( WANN < fix([M:DIV]DURAMTREG) ) Then
      # Cas correspondant à l'amortissement du nombre entier d'année

      # --------------
      # --- Partie 1
      # --------------
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Annuité partie 1           =" + num$(WANN) ) From =G_GLOB0
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date début Partie 1        =" + num$(LDTDB ) ) From =G_GLOB0
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date fin partie 1          =" + num$(LDTFN ) ) From =G_GLOB0
      # Durée de détention dans l'exercice
  #   Call  KRU_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,    LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
  #&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
      [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée Détention partie 1   =" + num$(WDURDET) ) From =G_GLOB0
      # Calcul de la durée de l'exercice selon le type de prorata
      Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
      Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée annuité partie 1     =" + num$(WDURANN) ) From =G_GLOB0

      # calcul de la dotation exercice partie 1
      If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
        [M:DIV]TXAMT1 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Taux amort. partie 1       =" + num$([M:DIV]TXAMT1) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8,
&       "Dotation partie 1 = Val.amort. * Taux amort.partie 1 * (Dur. Dét. partie 1 / Dur. annuité partie 1)") From =G_GLOB0
        WDOTEX1 = L_VALAMT * [M:DIV]TXAMT1   * ( WDURDET / WDURANN )
        #Call CAL_ARRONDI_MNT (WDOTEX1, [M:DIV]CUR , WDOTEX1) From =G_GLOB8
        [M:DIV]PV(0)= WDOTEX1: [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX1 = [M:DIV]RV(1)
      Else
        WDOTEX1 = 0
      Endif
      Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_SR - Dotation exercice partie 1 =" + num$(WDOTEX1) ) From =G_GLOB0

      # --------------
      # --- Partie 2
      # --------------
      While ( [M:DIV]DTFNEXE > LDTFN  and
&           ( [M:DIV]DATSOREXE = [0/0/0] or  [M:DIV]DATSOREXE  > LDTFN )   )
        WANN += 1 : LDTDB = LDTDB2
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Annuité partie 2          =" + num$(WANN) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date début partie 2       =" + num$(LDTDB ) ) From =G_GLOB0
        # Date de fin pour calcul 2ème partie de la dotation
        LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTDB,   1, "Y" )
        LDTFN  = func GLOBB9.CAL_DAT_PLUS( LDTFN,  -1, "D" )
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date fin   partie 2       =" + num$(LDTFN ) ) From =G_GLOB0
        # Durée de détention dans l'exercice
  #     Call  KRU_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,   LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
  #&          [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
        [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
        WDURDET = [M:DIV]RV(1)
        If ([M:DIV]ERROR) Then : End : Endif
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée Détention partie 2  =" + num$(WDURDET) ) From =G_GLOB0
        # Calcul de la durée de l'annuité selon le type de prorata
        Call CAL_DUR_EXE_REF (LDTDB, LDTFN, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
        Call ECR_FICH("FS1", 8, "   Durée annuité partie 2     =" + num$(WDURANN) ) From =G_GLOB0

        # calcul de la dotation exercice partie 2
        If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
          [M:DIV]TXAMT2 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Taux amort. partie 2       =" + num$([M:DIV]TXAMT2) ) From =G_GLOB0
          Call ECR_FICH("FS1", 8,
&         "Dotation partie 2 = Val. amort. * Taux amort.partie 2 * (Dur. Dét. partie 2 / Dur. annuité partie 2)") From =G_GLOB0
          WDOTEX2 = L_VALAMT * [M:DIV]TXAMT2 * ( WDURDET / WDURANN )
          #Call CAL_ARRONDI_MNT (WDOTEX2, [M:DIV]CUR , WDOTEX2) From =G_GLOB8
          [M:DIV]PV(0)= WDOTEX2: [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX2 = [M:DIV]RV(1)
        Else
          WDOTEX2 = 0
        Endif
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Dotation exercice partie 2 =" + num$(WDOTEX2) ) From =G_GLOB0
      Wend
      # --------------
      # --- Dotation
      # --------------
      # Dotation exercice = Dotation partie 1  + Dotation partie 2
      WDOTEXE = WDOTEX1 + WDOTEX2
      # Solde de la valeur nette lorsque la dotation est > à la valeur nette
      If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
        WDOTEXE = [M:DIV]VLNAMT
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Solde du reste à amortir ") From =G_GLOB0
      Endif

    #-1 --------------------
    Else
      # Cas correspondant à l'amortissement de la partie décimale
      # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
      # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

      #-2 ---------------------
      If (WANN = fix([M:DIV]DURAMTREG)) Then
        # --------------
        # --- Partie 1
        # --------------
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Annuité partie 1           =" + num$(WANN) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date début Partie 1        =" + num$(LDTDB ) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Date fin partie 1          =" + num$(LDTFN ) ) From =G_GLOB0
        # Durée de détention dans l'exercice
#       Call  KRU_DUR_DET ( [M:DIV]EXEDATREF, [M:DIV]DTFNEXE,    LDTDB, LDTFN, [M:DIV]DTDBAMTREG,
#&            [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB
        [M:DIV]PD(3)= LDTFN         : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
        WDURDET = [M:DIV]RV(1)
        If ([M:DIV]ERROR) Then : End : Endif
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée Détention partie 1   =" + num$(WDURDET) ) From =G_GLOB0
        # Calcul de la durée de l'exercice selon le type de prorata
        Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDURANN) From =G_GLOB8
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Durée annuité partie 1     =" + num$(WDURANN) ) From =G_GLOB0

        # calcul de la dotation exercice partie 1
        If ( WDURANN <> 0 and WSOFTY <> 0 ) Then
          [M:DIV]TXAMT1 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_SR - Taux amort. partie 1       =" + num$([M:DIV]TXAMT1) ) From =G_GLOB0
          Call ECR_FICH("FS1", 8,
&         "Dotation partie 1 = Val.amort. * Taux amort.partie 1 * (Dur. Dét. partie 1 / Dur. annuité partie 1)") From =G_GLOB0
          WDOTEX1 = L_VALAMT * [M:DIV]TXAMT1   * ( WDURDET / WDURANN )
          #Call CAL_ARRONDI_MNT (WDOTEX1, [M:DIV]CUR , WDOTEX1) From =G_GLOB8
          [M:DIV]PV(0)= WDOTEX1: [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEX1 = [M:DIV]RV(1)
        Else
          WDOTEX1 = 0
        Endif
        Call ECR_FICH("FS1", 7,"CAL_DOT_EXE_SR - Dotation exercice partie 1 =" + num$(WDOTEX1) ) From =G_GLOB0
        # Taux Partie 1 & partie 2 pour périodique
        [M:DIV]TXAMT1 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY
        # [M:DIV]TXAMT2 = LDECI / WSOFTY
        # [M:DIV]TXAMT2 = (L_NBM/12) / WSOFTY
        # FQ67972
        [M:DIV]TXAMT2 = (fix([M:DIV]DURAMTREG)+1 - WANN) / WSOFTY

        # --------------
        # --- Partie 2
        # --------------


        # Durée de détention dans l'exercice
    #   Call  KRU_DUR_DET
    #&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, LDTDB2, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
    #&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= LDTDB2
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
        WDURDET = [M:DIV]RV(1)
        If ([M:DIV]ERROR) Then : End : Endif
        # Calcul de la durée restant à amortir
        Call  CAL_DUR_REST_AMT
&             ([M:DIV]DTDBAMTREG, LDTDB2, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES) From =G_GLOB8
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Dur Dét Exe Partie 2  =" +  num$(WDURDET) ) From =G_GLOB0
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Dur Résid.  Partie 2  =" +  num$(WDURRES) ) From =G_GLOB0

        #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
        # calcul de la dotation exercice
        If ( WDURRES <> 0 ) Then
          Call ECR_FICH("FS1", 7,
&         "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
          WDOTEX2 = ( [M:DIV]VLNAMT - WDOTEX1 )  * ( WDURDET / WDURRES)
        Else
          WDOTEX2 = 0
        Endif
      #-1 --------------------
      Else
        # Au delà

        # Durée de détention dans l'exercice
    #   Call  KRU_DUR_DET
    #&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, LDTDB2, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
    #&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4RU
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_KRU_DUR_DET From =G_GLOB4RU
        WDURDET = [M:DIV]RV(1)
        If ([M:DIV]ERROR) Then : End : Endif
        # Calcul de la durée restant à amortir
        Call  CAL_DUR_REST_AMT
&             ([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES) From =G_GLOB8
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Durée Détention Exe.  =" +  num$(WDURDET) ) From =G_GLOB0
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Durée Résid. à amort. =" +  num$(WDURRES) ) From =G_GLOB0

        #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
        # calcul de la dotation exercice
        If ( WDURRES <> 0 ) Then
          Call ECR_FICH("FS1", 7,
&         "Dotation exercice = Val. nette déb. exe. * (Durée Détention Exe. / Durée residuelle)") From =G_GLOB0
          WDOTEX2 = ( [M:DIV]VLNAMT - WDOTEX1 )  * ( WDURDET / WDURRES)
        Else
          WDOTEX2 = 0
        Endif
      Endif
      #-2 ---------------------
      #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
      # --------------
      # --- Dotation
      # --------------
      # Dotation exercice = Dotation partie 1  + Dotation partie 2
      WDOTEXE = WDOTEX1 + WDOTEX2
      # Solde de la valeur nette lorsque la dotation est > à la valeur nette
      If ( abs([M:DIV]VLNAMT) < abs(WDOTEXE) ) Then
        WDOTEXE = [M:DIV]VLNAMT
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Solde du reste à amortir ") From =G_GLOB0
      Endif

    Endif
    #-1 --------------------
  Endif
  #-0 --------------------


  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4RU

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_SR - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Pas de Taux d'amortissement
  [M:DIV]TXAMT = 0.

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_DR
#
# - Objet  : Calcule la dotation de l'exercice selon le mode DR
#            Dégressif russe FQ59941
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#


Local Decimal WNBM       : WNBM        = 0.     : # Nombre de mois

  # If ( [M:DIV]BDEBUG  and [F:DEPC]DPRPLN = G301CPT and [F:DEPC]FIYSTRDAT = [01/01/2012] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  # If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.
  #FQ67110
  #[M:DIV]DOTSUP = 0
  Local Decimal WDOTSUP : WDOTSUP = 0
  If ( [F:DEPC]ACLCOE = 0. ) Then : [F:DEPC]ACLCOE = 1. : Endif

  # Initialisation du tableau des périodes du masque CALDIV (Dotation exercice = somme des dotations période
  #    ***************
  Call CAL_INI_PER_EXE ( [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT ) From =G_GLOB7

  # If ( [M:DIV]BDEBUG  and [F:DEPC]DPRPLN = G301CPT and [F:DEPC]FIYSTRDAT = [01/01/2012] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  # Intialisation Valeurs nettes
  Local Decimal L_VLNANI
  Local Decimal L_VALNET
  L_VLNANI = [F:DEPC]KBIRNBV - [F:DEPC]RSDVAL
  L_VALNET = [M:DIV]VLNAMT

  For I_P = 1 To [M:DIV2]NB_PER
    If ( [M:DIV]DTDBAMTREG < [M:DIV2]PERENDDAT(I_P-1) & [M:DIV2]PERSTRDAT(I_P-1) >= [F:DEPC]PERSTRDAT ) Then
      [M:DIV2]BIRNBV((I_P-1)) = [F:DEPC]KBIRNBV - [F:DEPC]RSDVAL
    Endif
  Next I_P


  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_DR - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Valeur nette amort.   =" + num$(L_VALNET)          ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Déb. Exercice  résid. =" + num$([M:DIV]EXEDATREF)  ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================
  #---------------------
  # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
  [F:DEPC]DPRDUR = [M:DIV]DURAMTREG
  # Nombre de mois d'amortissement
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:DIV]DURAMTREG, DUREM, [F:DEPC]DPRDUR, DUREM ) From =G_GLOB9
  # Taux d'amortissement (pour stockage et affichage)
  [M:DIV]TXAMT =  arr((12/DUREM) * [F:DEPC]ACLCOE, 0.000001)
  # Taux d'amortissement mensuel ( non arrondi pour calcul)
  Local Decimal L_TXAMT
  L_TXAMT = (12/DUREM) * [F:DEPC]ACLCOE


  #---------------------

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Durée d'amortissement =" + num$([M:DIV]DURAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Coef. d'accélèration  =" + num$([F:DEPC]ACLCOE)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Taux  d'amortissement =" + num$(L_TXAMT)     ) From =G_GLOB0

  #=================
  # Date Fin Amort. (toujours à [0/0/0])
  #=================
  Gosub CAL_DATE_FIN_AMORT_DR From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  #---------------------

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #-0 -------------------------------------------------------
  If ( [F:DEPC]FIYSTRDAT = [F:DEPC]PERSTRDAT and [F:DEPC]FIYENDDAT = [F:DEPC]PERENDDAT ) Then
    # Une période d'un exercice
    [M:DIV]AMTEXC = 0.
    If ( [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
      # Amortissement suspendu
      [M:DIV]DOTEXE =  0.
    Else
      [M:DIV]DOTEXE = [M:DIV]VLNAMT * L_TXAMT
    Endif
  #-0 -------------------------------------------------------
  Else
    # Prise en compte des amortissements déjà constatés sur les périodes closes
    I_P = find([F:DEPC]PERSTRDAT-1, [M:DIV2]PERENDDAT)
    If ([F:DEPC]PERCLOCUM <> 0) Then
      [M:DIV2]DOTPER(I_P-1) = [F:DEPC]PERCLOCUM
      [M:DIV2]DOT1AP(I_P-1) = [F:DEPC]PERCLOCUM
      [M:DIV]DOTEXE        = [F:DEPC]PERCLOCUM
      L_VALNET             = L_VALNET - [F:DEPC]PERCLOCUM
     Endif
    # Calcul pour les prériodes restants à clore
    #>>>>>>>>>>>>>>>>>
    For I_P = 1 To [M:DIV2]NB_PER
      #- 1 -------------------------
      If ( [M:DIV]DTDBAMTREG < [M:DIV2]PERENDDAT(I_P-1) ) Then
      If ( [M:DIV2]PERSTRDAT(I_P-1) >= [F:DEPC]PERSTRDAT ) Then
        #- 2 -------------------------
        If ( [M:DIV]DATSORREG = [0/0/0] or [M:DIV]DATSORREG >= [M:DIV2]PERENDDAT(I_P-1)  ) Then
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Déb. Période          =" + num$([M:DIV2]PERSTRDAT(I_P-1))    ) From =G_GLOB0
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Fin. Période          =" + num$([M:DIV2]PERENDDAT(I_P-1))    ) From =G_GLOB0
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Valeur nette anniv.   =" + num$(L_VLNANI)                   ) From =G_GLOB0
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_DR - Valeur nette          =" + num$(L_VALNET)                   ) From =G_GLOB0

          # Valeur nette anniversaire
          [M:DIV2]BIRNBV(I_P-1) =  L_VLNANI + [F:DEPC]RSDVAL

          # Dotation période
          If ( [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
            # Amortissement suspendu
            [M:DIV2]DOTPER(I_P-1) =  0.
          Else
            [M:DIV2]DOTPER(I_P-1) =  L_VLNANI * L_TXAMT / 12
            # Arrondi dans la devise du contexte
            #Call CAL_ARRONDI_MNT ([M:DIV2]DOTPER(I_P-1), [M:DIV]CUR, [M:DIV2]DOTPER(I_P-1)) From =G_GLOB8
            [M:DIV]PV(0)= [M:DIV2]DOTPER(I_P-1) : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV2]DOTPER(I_P-1) = [M:DIV]RV(1)
          Endif
          If ( abs([M:DIV2]DOTPER(I_P-1)) > abs(L_VALNET)) Then
            [M:DIV2]DOTPER(I_P-1) = L_VALNET
          Endif
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Dotation période      =" + num$([M:DIV2]DOTPER(I_P-1))  ) From =G_GLOB0
          # La dotation exercice est le total des dotations des périodes
          [M:DIV]DOTEXE          += [M:DIV2]DOTPER(I_P-1)
          # La valeur nette est diminuée de la dotation de la période
          L_VALNET               -= [M:DIV2]DOTPER(I_P-1)
          # Entretien Cumul 1 à Pc
          If (I_P > 1 ) Then :  [M:DIV2]DOT1AP((I_P-1)) = [M:DIV2]DOT1AP((I_P-2)) : Endif
          [M:DIV2]DOT1AP((I_P-1)) += [M:DIV2]DOTPER(I_P-1)
          Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_CR - Cumul 1 à P           =" + num$([M:DIV2]DOT1AP(I_P-1))  ) From =G_GLOB0

          # Entretien valeur nette anniversaire si l'amortissement n'est pas suspendu
          If not ([M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0) Then
            #Call CAL_DAT_DIFF( [M:DIV]DTDBAMTREG, [M:DIV2]PERENDDAT((I_P-1)), "M" , WNBM ) From =G_GLOB9
            [M:DIV]PD(0)= [M:DIV]DTDBAMTREG : [M:DIV]PD(1)= [M:DIV2]PERENDDAT((I_P-1)) : [M:DIV]PC(0)= "M"
            Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WNBM = [M:DIV]RV(0)
            WNBM = WNBM - [F:DEPC]KNBMSTPDEP
            If ( mod(WNBM, 12) = 0 ) Then
              L_VLNANI = L_VALNET + [F:DEPC]RSDVAL
            Endif
          Endif

        Endif
        #- 2 -------------------------
      Endif
      Endif
      #- 1 -------------------------
    Next I_P
    #>>>>>>>>>>>>>>>>>
  Endif
  #-0 -------------------------------------------------------

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4RU

  # Solde de l'amortissement
  If ( [M:DIV]DOTEXE = 0 and abs([M:DIV]VLNAMT) < 1.00 ) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Endif


  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_DR - Dotation exe.            =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End
