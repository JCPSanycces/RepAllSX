#########################################################
$KRU_LEC_PSEPLN
#
# - Objet  : Lecture du plan de saisonnalité
#
# - Entrée : Société, Référence plan
#
#
# - Sortie :
#   Boite noire
#
  If ( [M:DIV]PSEPLN <> "" ) Then
    If clalev([F:PSE]) =0 : Local File PSEPLN    [PSE]  : Endif      : # Société

    Read [F:PSE]PSE0= [M:DIV]SOC;[M:DIV]PSEPLN
    If (fstat) Then
      Read [F:PSE]PSE0= "";[M:DIV]PSEPLN
      If (fstat) Then
        [M:DIV]ERROR = 9
        [M:DIV]ERRID = 9 : Call ERRFND From =G_GLOB0 : Return : # Dépilement suite à erreur logique
      Endif
    Endif

    [M:DIV]SESTYP  = [F:PSE]SESTYP
    Local Integer IM
    [M:DIV]PSEMOPN = sigma(IM = 1,12, [F:PSE]ACTFLG(IM-1) = G_OUI)
  Else
    [M:DIV]SESTYP  = 0
    [M:DIV]PSEMOPN = 12
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return

