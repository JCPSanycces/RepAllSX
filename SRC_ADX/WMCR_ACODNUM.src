#<AdxTL>@(#)0.0.0.0 $Revision$Class Doc sequence numbers
# Supervisor
## CRUD-CLASSE ## ACODNUM
# 2018-11-06 07:00:51 754


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File ACODNUM [ANM_]

If !SILENCE : Call TRACE("2 --> Local Instance C_ACODNUM") From ASYRCOM : Endif
Local Instance ACODNUM Using C_ACODNUM

If !SILENCE : Call TRACE("3 --> New Instance C_ACODNUM") From ASYRCOM : Endif
ACODNUM = NewInstance C_ACODNUM AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [ANM_]ANM0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of ACODNUM") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet ACODNUM.AREAD([ANM_]CODNUM))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("ACODNUM.CODNUM ="-num$(ACODNUM.CODNUM)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(ACODNUM.AKEYS)
  Call TRACE("-"-num$(I)-":"-ACODNUM.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [ANM_]
FreeGroup ACODNUM
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(ACODNUM,ACLE,ASTATUS,_ETAG)
Variable Instance ACODNUM Using C_ACODNUM
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _CODNUM(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CODNUM = num$([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File ACODNUM [ANM]
Default File [F:ANM]
Read [F:ANM]ANM0 = [L]_CODNUM
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:ANM]UPDTICK)>0
 [L]_ETAG = num$([F:ANM]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(ACODNUM,ACLE,ASTATUS)
Variable Instance ACODNUM Using C_ACODNUM
Value Char ACLE
Variable Integer ASTATUS
Local Char _CODNUM(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CODNUM = num$([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet ACODNUM.AREAD([L]_CODNUM))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(ACODNUM,_CODNUM,ASTATUS)
Variable Instance ACODNUM Using C_ACODNUM
Value Char _CODNUM
Variable Integer ASTATUS

If ACODNUM = null : End : Endif

Gosub AVARIABLES From WMC00ACODNUM
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If ACODNUM.APARENT=null
 [L]A_I = ACODNUM.freeSnapshot
 ACODNUM.snapshotEnabled = 0
 ACODNUM.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & ACODNUM.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet ACODNUM._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If ACODNUM.APARENT=null
 ACODNUM.snapshotEnabled = 1
 ACODNUM.setAccessorEnabled = 1
Endif
LogicClose File [ANM]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet ACODNUM._ACTION_PARAM("AREAD_BEFORE",[L]_CODNUM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:ANM]
Read [F:ANM]ANM0 = [L]_CODNUM
If fstat
[L]A_ERROR = [L]_CODNUM
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(ACODNUM,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:ANM]AUUID)>0 & [F:ANM]AUUID=NullUuid
 [F:ANM]AUUID = getUuid
Endif
SetInstance ACODNUM With [F:ANM]
ACODNUM.ASTALIN = [V]CST_ALL

[L]A_NEWCOL = 0
For [L]A_I=1 To min(10,ACODNUM.NBPOS)
 [L]A_NEWCOL += 1
 ACODNUM.NBCOMPONENT(A_NEWCOL) = NewInstance  C_ACODNUM_NBCOMPONENT(ACODNUM.ACTX,NullUuid,[L]A_I,ACODNUM,"NBCOMPONENT") AllocGroup ACODNUM
 ACODNUM.NBCOMPONENT(A_NEWCOL).POSTYP = [F:ANM]POSTYP([L]A_I-1)
 ACODNUM.NBCOMPONENT(A_NEWCOL).POSLNG = [F:ANM]POSLNG([L]A_I-1)
 ACODNUM.NBCOMPONENT(A_NEWCOL).POSCTE = [F:ANM]POSCTE([L]A_I-1)
 [L]ASTATUS = max([L]ASTATUS,fmet ACODNUM.NBCOMPONENT(A_NEWCOL).ACTION("AREAD_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet ACODNUM.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [AXX] Where CODFIC="ACODNUM" & ZONE="DES" & IDENT1=ACODNUM.CODNUM & IDENT2=""
 Call ASETTEXTRA(ACODNUM.AXX,ACODNUM.AllocGrp(),"DES",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
 ACODNUM.AXX(maxtab(ACODNUM.AXX)).FLG = 0
Next AXX
If !len(fmet ACODNUM.AGETTEXTRA("DES"))
 Call ASETTEXTRA(ACODNUM.AXX,ACODNUM.AllocGrp(),"DES",
& fmet ACODNUM.AGETTEXTRALAN("DES",ACODNUM.ACTX.AFOLD.ALANGDEF),
& ACODNUM.ACTX.LAN) From ASYRSUB
Endif

Return



