#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#Case ACTION
# When "INIT"        : Gosub INIT
#Endcase
Return

$INIT

Gosub PAYSLIP_VIEW
Return

$PAYSLIP_VIEW
Local Char CPY_PARAM(GLONCPY)
Local File FACILITY [F:FCY2]

Read [FCY2]FCY0 = PARAM(4)
If fstat = [V]CST_AOK
  CPY_PARAM = [F:FCY2]LEGCPY
Endif

LogicClose File [F:FCY2]

#Parameters - PARAM(0...)
#BUL
#RPTBUL
#CPY
#FCY
#REFNUM
#CTRNUM
#CTRDAT
#PRTDRV
#LEG


Local Char TBPAR(80)(1..)
Local Char TBVAL(20)(1..)
Local Char FILNAM(100)
Local Char IMPRIMANTE(30)
Local Char FUNCMESS(250)
#Destination
IMPRIMANTE = PARAM(8)
GFONCTION=""
GERR=0

#Site range
TBPAR(8) = "FCYDEB"
TBPAR(9) = "FCYFIN"
TBVAL(8) = PARAM(4)
TBVAL(9) = PARAM(4)

#Company
TBPAR(7) = "CPY"
TBVAL(7) = CPY_PARAM

#Employee range
TBPAR(5) = "MATDEB"
TBPAR(6) = "MATFIN"
TBVAL(5) = PARAM(5)
TBVAL(6) = PARAM(5)

#Pay date range
TBPAR(1) = "DATDEB"
TBPAR(2) = "DATFIN"
TBVAL(1) = ""
TBVAL(2) = ""

#Department
TBPAR(10) = "SRV"
TBVAL(10) = ""

#Population
TBPAR(11) = "POP"
TBVAL(11) = ""

#Payslip number
TBPAR(3) = "BULDEB"
TBPAR(4) = "BULFIN"
TBVAL(3) = PARAM(1)
TBVAL(4) = PARAM(1)

#Legislation
TBPAR(12) = "LEG"
TBVAL(12) = PARAM(9)

#FILNAM = func GETFILNAME(REFNUM , CTRNUM ,BUL)
#PDFFILPAT = func GETDEFDIR()+FILNAM
# if the mask is declare
Local Integer NBPLAG
Local    Integer DIFF
Local Char    NOJOB(30)

Local Char COMPLEMENT(10)
Gosub DECLARE From AIMP1
Gosub OUVRE From AIMP1
ETAT = PARAM(2)

Call CONT_RPTCOD(ETAT,FUNCMESS,STAT) From AIMP1
mkstat = STAT
If mkstat
 ER = 1 : Goto FIN_ETAT
Endif
For I=1 To min(dim([M:AIP]TBPAR),dim(TBPAR))
 [M:AIP]TBPAR(I-1) = TBPAR(I)
 [M:AIP]TBVAL(I-1) = TBVAL(I)
Next I
If dim([L]PARPLAG)>0
 For I=0 To dim([L]PARPLAG)
  If [L]PARPLAG(I) = "" : Break : Endif
  [M]PARPLAG(I)  = [L]PARPLAG(I)
  [M]VALPLAG1(I) = [L]VALPLAG1(I)
  [M]VALPLAG2(I) = [L]VALPLAG2(I)
  If [M]VALPLAG1(I) = [M]VALPLAG2(I) & [M]VALPLAG2(I) <> ""
   [M]BORPLAG(I)  = 1
  Else
   [M]BORPLAG(I)  = 2
  Endif
 Next I
 [M]NBPLAG = I
Endif
Call CHANGE_RPTCOD(ETAT,GFONCTION) From AIMP1
Call COMPLEMENT(COMPLEMENT) From AIMP1
Call SETIMP(ETAT,GUSER,COMPLEMENT,IMPRIMANTE) From IMPRIME
[M]PRT = IMPRIMANTE
Call AIMCONT(IMPRIMANTE,ETAT,([M]BATCH<>0) or ([M]DIFFERE=2)) From IMPRIME
If mkstat
 ER = 1 : Goto FIN_ETAT
Endif
[M]FICHIER    = ""
[M]IMPRIME    = [F:AIM]PRT
[M]SERVEUR    = [F:AIM]PRTSRV
[M]IMPRIMANTE = [F:AIM]PRTNAM
[M]PRTPOR     = [F:AIM]PRTPOR
[M]PRTDRV     = [F:AIM]PRTDRV
Raz [M]PRTDES
[M]FMTFIC    = [F:AIM]PRTFMT
[M]PRTORIENT     = [F:ARP]ORIENT
[M]DIFFERE = 1
[M]LANGUE = GLANGUE
Call IMPRIME([M]RPTCOD,[M]LANGUE,[M]NBRPAR,[M]PARCOD,[M]TYP,[M]PARTYP,[M]NOLIB
&           ,[M]DEBFIN,[M]VALINT1,[M]VALINT2,[M]DIFFERE
&           ,[M]IMPRIME,[M]SERVEUR,[M]IMPRIMANTE,[M]PRTPOR,[M]PRTDRV
&           ,[M]PRTDES,[M]NBRCPY,[M]ASSCPY,[M]PAGDEB,[M]PAGFIN,[M]FICHIER,[M]FMTFIC
&           ,[M]NBSEG,[M]VALSEG,[M]DIFDAT,[M]DIFTIM,[M]DIFSRVC,[M]FORPAP
&           ,[M:AIP]TBPAR,[M:AIP]TBVAL,[M]MESSAGE,[M]NBPLAG,[M]PARPLAG,[M]BORPLAG,[M]VALPLAG1,[M]VALPLAG2,NOJOB,ER)
& From AIMP3
$FIN_ETAT
Return

