#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPCHIS 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:28"
A_USER  = "DOC"
A_STAMP = "20181109230328"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRHIS"
  If [M]NBRHIS=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPCHIS [CPH]
Gosub HORODAT
Local Inpbox "CPCHIS" From GFONCTION At A_STAMP With A_WINDPREV Mask [CPH] As [SIM_]
Grizo [CPH]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CPH]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=17 : X2(0)=96 : Y1(0)=2 : Y2(0)=26
Return

$ON_NBRHIS
Onevent CONTROL Call C_NBRHIS From W1CPCHIS
Return

Subprog C_NBRHIS
Local Decimal BASPAG
## Action STD
Call C_NBRHIS From SUBECP
If mkstat : GERR = 1 : GZONE = "NBRHIS" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_CPCHIS
Return

$ON_ZCPCHIS
Onevent BEFORE_AREA Gosub AV_ZCPCHIS From W1CPCHIS
Return

$AV_ZCPCHIS
Call LECTEXTRA(zc,"COMPETENCE","DES",num$([M]CPCHIS(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_LEVCPCHIS
Return

$ON_CPCDATHIS
Onevent BEFORE_AREA Gosub AV_CPCDATHIS From W1CPCHIS
Return

$AV_CPCDATHIS
Chgfmt [M]CPCDATHIS(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_ORICPCHIS
Onevent INIT_AREA Call D_ORICPCHIS(zc) From W1CPCHIS
Return

Subprog D_ORICPCHIS(VALEUR)
Variable Integer VALEUR
If varinit([M]ORICPCHIS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


