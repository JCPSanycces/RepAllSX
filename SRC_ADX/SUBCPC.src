#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################################
# Modification :
#     SEGAY - 06/12/12 - 78468 (portail formation)
#     Comme le champ de saisie AFF_LEVDES est un clob et que la sauvegarde est alpha de 250
#     MABOS - 11/04/13 - FQ86658 - US 1529 - when a skill has no legislation, Nature & Scale must be blank only.
#     SBA :   06/08/13   US 1840-81085 : réinitialisation des champs sur changement de législation
##############################################################################################################################

Raz GPILOBJ
Call OBJET("CPC",GBIDC1,"") From GOBJET
End

#Sélection d'un niveau de compétence

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "ABANDON"    : Gosub ABANDON
 When "LIENS"      : Gosub LIENS
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "CREATION"   : Gosub CRE_MOD
 When "MODIF"      : Gosub CRE_MOD
 When "RAZCRE"     : Gosub RAZCRE

Endcase
Return


# PCA 03/07/12 - Field LEG has been added
$OUVRE


If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

# PCA 03/07/12 - Field LEG has been added
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

# PCA 04/07/12 - Field LEG has been added
$ABANDON
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

# PCA 04/07/12 - Clear the LEG
$RAZCRE
 GCURLEG = ""
 Return


$SEL_LISTE
If clalev([F:CPC])=0 : Local File COMPETENCE [CPC] : Endif
If clalev([F:HRSCA])=0 : Local File SCALE      [HRSCA] : Endif

NBTEX = 0
If PARAM(1)<>""
 Read [F:CPC]CPC0=PARAM(1)
Else
 Read [F:CPC]CPC0=GBIDC1
Endif
If !fstat
 Read [HRSCA]SCA0=[F:CPC]CODSCA
 If !fstat
  For I=0 To dim([F:HRSCA]LEV)-1
   If [F:HRSCA]LEV(I)<>""
    NBTEX += 1
    TEX(NBTEX) =[F:HRSCA]LEV(I)
    If NBTEX>=dim(TEX)-1 : Break : Endif
   Endif
  Next
 Endif
Endif
Return
##################################################
# JML 27/07/10
$LIENS
Read [HRSCA]SCA0=[M]CODSCA
If !fstat
 Gosub CHARGE_SCA
Endif



#04/07/12 PCA DES, LONDES and SHO becomes a translatable text
GCURLEG = [F:CPC]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M]DES,"COMPETENCE","DES",[M]COD,"") From ATEXTRA
Call LECTEXTRA([M]SHO,"COMPETENCE","SHO",[M]COD,"") From ATEXTRA

For I=0 To dim(LONDES)-1
Call LECTEXTRA([M]LONDES(I),"COMPETENCE","LONDES_"+num$(I),[M]COD,"") From ATEXTRA
Next

Return
#
$CHARGE_SCA
For nolign=1 To dim([F:HRSCA]LEV)
 If [F:HRSCA]LEV(nolign-1)="" : Break : Endif
# [M] = [F:HRSCA] : # Impossible to do that
 [M:CPC0]LEV(nolign-1)    = [F:HRSCA]LEV(nolign-1)
 [M:CPC0]LEVREF(nolign-1) = [F:HRSCA]LEVREF(nolign-1)
 If dim([M:CPC0]LEVDES)>0
  Read [HRSDD]SDD0=[F:HRSCA]COD;nolign
  If !fstat
   [M:CPC0]LEVDES(nolign-1) = [F:HRSDD]LEVDES
  Endif
 Endif
 Read [CPD]CPD0=[M:CPC0]COD;nolign
 If !fstat
  [M:CPC0]LEVDESCPC(nolign-1) = [F:CPD]LEVDESCPC
 Endif
Next nolign
[M:CPC0]NBSCA = nolign-1
Return
##################################################
$CRE_MOD
Delete [CPD] Where [CPD]CPC=[M:CPC0]COD
If fstat=1 : GOK = -1 : Call RSTA("CPD",[M:CPC0]COD) From GLOCK : Return : Endif

#PCA 05/07/12 DES, LONDES and SHO becomes a translatable text
If GREP="D"
 ## In duplication mode we keep the translated text
 Call DUPTEXTRA("COMPETENCE","DES",   CLECUR1,"","COMPETENCE","DES",   [F:CPC]COD,"")  From ATEXTRA
 Call DUPTEXTRA("COMPETENCE","SHO",CLECUR1,"","COMPETENCE","SHO",[F:CPC]COD,"")  From ATEXTRA
For I=0 To dim(LONDES)-1
Call DUPTEXTRA("COMPETENCE","LONDES_"+num$(I),CLECUR1,"","COMPETENCE","LONDES_"+num$(I),[F:CPC]COD,"")  From ATEXTRA
Next

Endif

Call MAJTEXTRA([M:CPC0]DES,"COMPETENCE","DES",[F:CPC]COD,"") From ATEXTRA
Call MAJTEXTRA([M:CPC0]SHO,"COMPETENCE","SHO",[F:CPC]COD,"") From ATEXTRA
For I=0 To dim(LONDES)-1
Call MAJTEXTRA([M:CPC0]LONDES(I),"COMPETENCE","LONDES_"+num$(I),[F:CPC]COD,"") From ATEXTRA
Next


###############################

For nolign=1 To [M:CPC0]NBSCA
 # JML We write even when it's empty for Crystal report !
 Raz [F:CPD]
 [F:CPD] = [M:CPC0]
 [F:CPD]CPC = [M:CPC0]COD
 [F:CPD]NUMLIG = nolign
 Write [CPD]
 If fstat
  GOK = 0 : Call FSTA("CPD") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif

Return
##################################################
Subprog CTLNIV(AZC,COD)
Variable Char    AZC()
Value    Char    COD

Local Integer I,J
#61855
#Local Char    VALCHAR (10)
Local Char    VALCHAR (GLONNIV)
If clalev([F:CPC])=0 : Local File COMPETENCE [CPC] : Endif
If clalev([F:HRSCA])=0 : Local File SCALE      [HRSCA] : Endif

If AZC="" : End : Endif

If COD<>""
 Read [F:CPC]CPC0=COD
Elsif GBIDC1<>""
 Read [F:CPC]CPC0=GBIDC1
Else
 End
Endif
If !fstat
 Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
 #Egalité parfaite
 For I=0 To dim([F:HRSCA]LEV)-1
  If toupper(ctrans([F:HRSCA]LEV(I)))=toupper(ctrans(AZC))
   VALCHAR=[F:HRSCA]LEV(I) : Break
  Endif
 Next
 If VALCHAR=""
  #Débute par...
  For I=len(AZC) To 1 Step -1
   For J=0 To dim([F:HRSCA]LEV)-1
    If [F:HRSCA]LEV(J)="" : Break : Endif
    If left$(toupper(ctrans([F:HRSCA]LEV(J))),I)=toupper(ctrans(AZC))
     VALCHAR=[F:HRSCA]LEV(J)
     Break 2
    Endif
   Next J
  Next I
 Endif
 If VALCHAR=""
  # Niveau inexistant
  GMESSAGE = mess(1,10720,1)
  mkstat = 2 : End
 Else
  AZC = VALCHAR
 Endif
Endif
End

##################################################
## Recherche du plus petit niveau d'une compétence
##################################################
Subprog BASNIVCPC(CPC,NIVEAU)
Value    Char CPC
Variable Char NIVEAU
Local Integer I,J

If clalev([F:CPC])=0 : Local File COMPETENCE [CPC] : Endif
If clalev([F:HRSCA])=0 : Local File SCALE      [HRSCA] : Endif

# Afficher le plus petit niveau
Read [CPC]CPC0=CPC
If !fstat
 Read [HRSCA]SCA0=[F:CPC]CODSCA
 If !fstat
  J = find("",[F:HRSCA]LEV)
  I = find(min([F:HRSCA]LEVREF(0..J-2)),[F:HRSCA]LEVREF)
  #LIPET - X3-29311 - 13-03-2017 - START
  # FQ89881 - 13/05/13 - Ajout test sur I
  If I>0 Then
    NIVEAU = [F:HRSCA]LEV(I-1)
  Endif
  #LIPET - X3-29311 - 13-03-2017 - END
 Endif
Endif
End

######################################################################################
## Etiquette écran CPC0
######################################################################################
#MABOS-11/04/13-FQ86658-US1529
# when a skill has no legislation, Nature must be blank only.
Subprog C_NATCPC(VALEUR)
Variable Char    VALEUR()
If VALEUR <>"" Then
If clalev([F:ADI])=0    : Local File ATABDIV      [ADI]    : Endif
     Read [F:ADI]CODE=10456;VALEUR
      If !fstat Then
        #LIPET - 2017-09-27 - X3-29311 - START
        #If [F:ADI]LEG <> ""  & GCURLEG="" Then
        If [F:ADI]LEG <> ""  & GCURLEG<>"" & [F:ADI]LEG<>[V]GCURLEG Then
        #LIPET - 2017-09-27 - X3-29311 - END
            mkstat=2 : GMESSAGE = func TOOLSHRLEG.LIB_FIELD(maskcou,zoncou)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-":"- [F:ADI]LEG : End
        Endif
      Endif
Endif

End

#MABOS-11/04/13-FQ86658-US1529-
#when a competency has no legislation, the Scale, must be blank only.
Subprog C_CODSCA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:HRSCA])=0 : Local File SCALE [F:HRSCA] : Endif
 Read [F:HRSCA]SCA0=VALEUR
 If !fstat
 #ADNGO - 2017-09-26 - X3-55393 - START
  #If dim([V]GCURLEG)>0 & [V]GCURLEG = "" & [F:HRSCA]LEG <> [V]GCURLEG
  If [F:HRSCA]LEG <> [V]GCURLEG and [F:HRSCA]LEG <> "" and [V]GCURLEG<>""
 #ADNGO - 2017-09-26 - X3-55393 - END
    GMESSAGE =func TOOLSHRLEG.LIB_FIELD(maskcou,zoncou)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-":"-[F:HRSCA]LEG : # Réservé à la législation
    mkstat = 2
    GERR=1
    End
  Endif
 Endif
Endif
End

Subprog AM_CODSCA(VALEUR)
Variable Char    VALEUR()

Local Char    FIC (GLONATB)
Local Char    NOMZON (GLONAVA)
Local Integer TROUVE : TROUVE = 0
# FQ78547 FRRIC 15/12/2011

# Recherche si l'échelle est déjà utilisée dans une compétence
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
# FQ78547 FRRIC 15/12/2011
If clalev([F:CPE])=0  : Local File  CPCEMP     [CPE] : Endif
Filter [ATZ] Where CODTYP="CPC"
For [ATZ]CODTYP Where !find([F:ATZ]CODFIC,"COMPETENCE","COMPETENCED")
 # JML 28/07/10 LOT P02 ignore COMPETENCE, we're working on it...
 FIC    = [F:ATZ]CODFIC
 NOMZON = [F:ATZ]CODZONE
 Local File =FIC [F1]
 Filter [F1] Where evalue(NOMZON)=[M:CPC0]COD
 For [F1]
  TROUVE = 1
  Break
 Next
 Filter [F1]
 Close Local File [F1]
 If TROUVE=1 : Break : Endif
Next
Filter [ATZ]
# FQ78547 FRRIC 15/12/2011
Filter [CPE] Where CPC=[M:CPC0]COD & CPCDAT<>[0/0/0]
Read [CPE]CPE2 First
If !fstat
   # Cette compétence a déjà été saisie en compétences par salarié
   #GMESSAGE = mess(35,720,1)-FIC
   GMESSAGE = mess(78,10720,1)-[F:CPE]REFNUM
   Filter [CPE]
   mkstat = 2 : End
Endif
Filter [CPE]
#If TROUVE=1
If TROUVE=1
 # Un niveau a déjà été saisi pour cette compétence dans la table xxxx
 GMESSAGE = mess(35,10720,1)-FIC
 mkstat = 2 : End
Endif
Gosub CHARGE_SCA
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CPC0) 20/08/2010 08:08:03 (JML)
######################################################################################
Subprog AV_NBSCA
Local Integer L_NOL : L_NOL = nolign-1
[M]AFF_LEVDES = [M]LEVDESCPC(L_NOL)
[M]NUMLIG     = L_NOL
Affzo AFF_LEVDES
End

Subprog AM_AFF_LEVDES(VALEUR)
Variable Clbfile VALEUR
[M]LEVDESCPC([M]NUMLIG) = VALEUR
Affzo LEVDESCPC([M]NUMLIG)
# segay 06/12/12 78468 comme le champ de saisie est un clob et que la sauvegarde est alpha de 250
VALEUR = [M]LEVDESCPC([M]NUMLIG)
[M]AFF_LEVDES = VALEUR
Affzo [M]AFF_LEVDES
End


######################################################################################
## 03/07/2012 PCA Set the LEG value
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#If VALEUR <> ""
GCURLEG = VALEUR
#SBA : US 1840-81085
Call REINI_FLDSLEG(VALEUR)
#Endif
End
######################################################################################
#SBA : US 1840-81085
Subprog REINI_FLDSLEG(VALEUR)
Value Char VALEUR
Local Char RESULT(10)
Local Integer WOK
# nature
If [M:CPC0]NATCPC <> ""
  Call GET_LEGADI("10456",[M:CPC0]NATCPC,WOK,RESULT,WOK)From TOOLSHRLEG
  If(WOK)
    If (func CHECK_FORCEBLANK(VALEUR,RESULT) or func CHECK_LEGOK(VALEUR,RESULT) )
      Effzo [M:CPC0]NATCPC,ZNATCPC
    Endif
  Endif
Endif

If([M:CPC0]CODSCA<>"")
   If clalev([F:HRSCA])=0 : Local File SCALE [F:HRSCA] : Endif
   Read [F:HRSCA]SCA0=[M:CPC0]CODSCA
    If !fstat
      RESULT= [F:HRSCA]LEG
      If (func CHECK_FORCEBLANK(VALEUR,RESULT) or func CHECK_LEGOK(VALEUR,RESULT) )
        Effzo [M:CPC0]CODSCA,ZCODSCA
      Endif
    Endif
Endif
End


Funprog CHECK_FORCEBLANK(LEG1,LEG2)
Value Char LEG1(),LEG2()
End (LEG1=""and LEG2<>"")

Funprog CHECK_LEGOK(LEG1,LEG2)
Value Char LEG1(),LEG2()
End (LEG2<>"" and LEG1 <>"" and LEG2 <>LEG1)

