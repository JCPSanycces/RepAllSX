#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du fichier APRTPAGE
Raz GPILOBJ
Call OBJET("APS",GBIDC1,GBIDC2) From GOBJET
End

##################################################
$ACTION
Case ACTION
 When "CREATION" : Gosub MAJ_TEXTRA
 When "MODIF"    : Gosub MAJ_TEXTRA
 When "ANNULE"   : Gosub ANNULE
 When "CHANGE"   : Gosub CHANGE
 When default
Endcase
Return

######################################################################################
$MAJ_TEXTRA
Call MAJTEXTRA([M]APSINTIT,"APTLPAGE","APSINTIT",[M]APSPAG,"") From ATEXTRA
Return

$ANNULE
#suppresion texte traduisible
Delete [AXX] Where CODFIC="APTLPAGE"  & IDENT1=[L]CODE & ZONE ="APSINTIT"
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[M]APSPAG) From GLOCK 
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="APTLPAGE"  & IDENT1=[L]OCODE & ZONE ="APSINTIT" With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA APTLPAGE"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return


######################################################################################
## Etiquette 
######################################################################################
Subprog AM_APSPRE(VALEUR)
Variable Integer VALEUR
Read [ASB]ASB0 = "APS";"APS"+num$(VALEUR)
If !fstat
 [M:APS1]APSPIC = [F:ASB]BLOB
Endif
End

Subprog D_APSPIC
Read [ASB]ASB0= "APS";"APS"+num$([M:APS1]APSPRE)
If !fstat
 [M:APS1]APSPIC = [F:ASB]BLOB
Endif
End

######################################################################################

