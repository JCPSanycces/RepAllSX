#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201806001
# Issue X3-87228 - 2018-06-26 by FGR/ALMON
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201806001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201806001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Char SOLDIDENT1(GLONID1)
Local Char SNEWIDENT1(GLONID1)

  Call ECR_TRACE("UTIPJM201806001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".OPPORSBB" [OBB]
  Local File =DOSSIER + ".PIMPL"    [PIM]
  Link [OBB] With [F:PIM]PIM0=[F:OBB]OPPNUM As [LNK]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [OBB]
  Filter [LNK] Where [F:OBB]CONSFLG = 0
  For [LNK]
    COMPTEUR += 1
    If [F:PIM]PIMTYP = 1 Then
      [F:OBB]CONSFLG = 1
    Else
      [F:OBB]CONSFLG = 2
    Endif
    Rewrite [F:OBB]
    If fstat Then
      Call ECR_TRACE("File OPPORSBB" - [F:OBB]OPPNUM - [F:OBB]SBBPJT + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [LNK]
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201806001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201806001 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","OPPORSBB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORSBB") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201806001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","OPPORSBB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORSBB") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201806001(APPLI)
End

