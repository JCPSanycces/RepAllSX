Subprog AS_ENDDATPEN(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action SUBCTRLEG
Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
If mkstat=2
 [M]ENDDATPEN(INDIC) = VALEUR
 Affzo ENDDATPEN(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_ENDDATPEN(VALEUR)
Variable Date    VALEUR
## Action CTLDATV
Call CTLDATV(VALEUR,[M:CTRB]STRDATPEN(nolign-1)) From CONTDIV
If mkstat : GERR = 1 : GZONE = "ENDDATPEN" : GZNUM = 1806 : Endif
If !mkstat
 ## Action STD
 Call C_ENDDATPEN(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "ENDDATPEN" : GZNUM = 1806 : Endif
Endif
Gosub _AFF
End

$AMM_ENDDATPEN
Call AM_ENDDATPEN(zc)
If !mkstat & GOBJET
 zoncou = "ENDDATPEN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ENDDATPEN(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_ENDDATPEN(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "ENDDATPEN" : GZNUM = 1806 : Endif
Gosub _AFF
End

