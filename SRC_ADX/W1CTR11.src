#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR11 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:41"
A_USER  = "DOC"
A_STAMP = "20181109230341"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRPEN"
  If [M]NBRPEN=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR11 [CTRB]
Gosub HORODAT
Local Inpbox "CTR11" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTRB] As [SIM_]
Grizo [CTRB]5
Grizo [CTRB]10
Grizo [CTRB]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTRB]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=41 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=0 : Y1(1)=3 : Y2(1)=2
X1(2)=42 : X2(2)=107 : Y1(2)=1 : Y2(2)=23
Return

$ON_FLGEXCPEN
Onevent BEFORE_INPUT Call AS_FLGEXCPEN(zc) From W1CTR11
Onevent AFTER_CHANGE Gosub AMM_FLGEXCPEN From W1CTR11
Onevent INIT_AREA Call D_FLGEXCPEN(zc) From W1CTR11
Return

Subprog D_FLGEXCPEN(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGEXCPEN,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGEXCPEN(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_FLGEXCPEN(VALEUR) From SUBCTR
If mkstat=2
 [M]FLGEXCPEN(INDIC) = VALEUR
 Affzo FLGEXCPEN(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_FLGEXCPEN
Call AM_FLGEXCPEN(zc)
If !mkstat & GOBJET
 zoncou = "FLGEXCPEN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_FLGEXCPEN(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_FLGEXCPEN(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "FLGEXCPEN" : GZNUM = 55208 : Endif
Gosub _AFF
End

$ON_NBRPEN
Onevent BEFORE_INPUT Call AS_NBRPEN From W1CTR11
Return

Subprog AS_NBRPEN
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBRPEN From SUBCTR
Gosub _AFF
End

$ON_PEN
Onevent INIT_AREA Call D_PEN(zc) From W1CTR11
Onevent CONTROL Call C_PEN(zc) From W1CTR11
Onevent AFTER_CHANGE Gosub AMM_PEN From W1CTR11
Onevent BEFORE_INPUT Call AS_PEN(zc) From W1CTR11
Return

Subprog D_PEN(VALEUR)
Variable Char    VALEUR()
If varinit([M]PEN,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"410","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_PEN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"410") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PEN(zc) From W1CTR11
Onkey   2 Titled GBOUTS Call S_PEN(zc) From W1CTR11
Onkey 144 Titled GBOUTP Call P_PEN(zc) From W1CTR11
Onkey 146 Titled GBOUTA Call SA_PEN(zc) From W1CTR11
If VALEUR="" : Call INIADI(VALEUR,"410") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_PEN(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"410","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"410",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_PEN
Call AM_PEN(zc)
If !mkstat & GOBJET
 zoncou = "PEN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PEN(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PEN(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "PEN" : GZNUM = 55018 : Endif
Gosub _AFF
End

Subprog S_PEN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "410"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PEN(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"410") From GOBJET
Gosub _AFF
End

Subprog SA_PEN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "410"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PEN(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "410"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_STRDATPEN
Onevent INIT_AREA Call D_STRDATPEN(zc) From W1CTR11
Onevent BEFORE_INPUT Call AS_STRDATPEN(zc) From W1CTR11
Onevent CONTROL Call C_STRDATPEN(zc) From W1CTR11
Onevent AFTER_CHANGE Gosub AMM_STRDATPEN From W1CTR11
Onevent BEFORE_AREA Gosub AV_STRDATPEN From W1CTR11
Return

$AV_STRDATPEN
Chgfmt [M]STRDATPEN(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog D_STRDATPEN(VALEUR)
Variable Date    VALEUR
If varinit([M]STRDATPEN,indice)=0
 ## Action STD
 Call D_STRDATPEN(VALEUR) From SUBCTR
Endif
Gosub _AFF
End

Subprog AS_STRDATPEN(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action SUBCTRLEG
Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
If mkstat=2
 [M]STRDATPEN(INDIC) = VALEUR
 Affzo STRDATPEN(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_STRDATPEN(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "STRDATPEN" : GZNUM = 1805 : Endif
If !mkstat
 ## Action STD
 Call C_STRDATPEN(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "STRDATPEN" : GZNUM = 1805 : Endif
Endif
Gosub _AFF
End

$AMM_STRDATPEN
Call AM_STRDATPEN(zc)
If !mkstat & GOBJET
 zoncou = "STRDATPEN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_STRDATPEN(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_STRDATPEN(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "STRDATPEN" : GZNUM = 1805 : Endif
Gosub _AFF
End

