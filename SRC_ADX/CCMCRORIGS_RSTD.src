#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMCRORIGS_RSTD, Change Request - Originator Supplier Collection
# Issue 109094/19 - 2015-11-27 by BAKHA : For non-conformance, check for QA manager

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When "CCMCR.CCMCRORIGS" , "NCSREC.CCMCRORIGS"   # Issue 109094/19
      Case ACTION
        When "AREAD_AFTER"
          Gosub POPULATE_ORIGINATOR_SUPPLIER
          Gosub POPULATE_ORIGINATOR_CONTACT
          Gosub ACTIVATE_FIELDS
        When "ADDLINE_BEFORE"
          Gosub CHECK_STATUS
        When "ADELLINE_BEFORE"
          Gosub CHECK_ADELLINE
      Endcase
  Endcase

Return

# --------------------------------------------------
# Populate originator supplier display only properties.
$POPULATE_ORIGINATOR_SUPPLIER
  Local Integer LOCSTATUS
  Local Instance BPSUPPLIER Using C_BPSUPPLIER

  BPSUPPLIER = NewInstance C_BPSUPPLIER AllocGroup null
  LOCSTATUS = fmet BPSUPPLIER.AREAD(this.BPSNUM)
  If (LOCSTATUS = [V]CST_AOK)
    this.BPSNAM = BPSUPPLIER.BPSNAM
  Endif
  FreeGroup BPSUPPLIER

Return

# --------------------------------------------------
# Populate originator supplier contact display only properties.
$POPULATE_ORIGINATOR_CONTACT
  Local Integer LOCSTATUS
  Local Instance SELCONTACT Using C_CONTACTCRM

  SELCONTACT = NewInstance C_CONTACTCRM AllocGroup null
  LOCSTATUS = fmet SELCONTACT.AREAD(this.SUPPCONTACT)
  If (LOCSTATUS = [V]CST_AOK)
    this.SUPPCNTNAME = mess(SELCONTACT.CNTTTL,941,1) - SELCONTACT.CNTFNA - SELCONTACT.CNTLNA
    this.SUPPCNTEMA = SELCONTACT.CNTEMA
    this.SUPPCNTETS = SELCONTACT.CNTETS
  Endif
  FreeGroup SELCONTACT

Return

# --------------------------------------------------
# Enable / disable approver fields at a child class level.
$ACTIVATE_FIELDS

  Local Integer LOCSTATUS, MANAGER

  # Issue 109094/19 - check for either Change manager or QA Manager
  MANAGER = CST_AFALSE
  If (this.APARENT.NCSREC = 2)
    If (this.ACTX.USER = this.APARENT.NCSMANAGER)
      MANAGER = CST_ATRUE
    Endif
  Else
    If (this.ACTX.USER = this.APARENT.CCMUSRID)
      MANAGER = CST_ATRUE
    Endif
  Endif
  # End issue 109094/19


  LOCSTATUS = fmet this.ASETATTRIBUTE("SUPPCNTEMA",   "$isDisabled",  "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("SUPPCNTETS",   "$isDisabled",  "true")

  # disable or enable fields depending on who can amend
  # Issue 109094/19
  If (this.APARENT.CRSTATUS = 7 or (MANAGER = CST_AFALSE  and this.ACTX.USER <> this.CREUSR))
  # End issue 109094/19
    LOCSTATUS = fmet this.ASETATTRIBUTE("BPSNUM",      "$isDisabled",  "true")
    LOCSTATUS = fmet this.ASETATTRIBUTE("SUPPCONTACT", "$isDisabled",  "true")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("BPSNUM",      "$isDisabled",  "false")
    LOCSTATUS = fmet this.ASETATTRIBUTE("SUPPCONTACT", "$isDisabled", "false")
  Endif

Return

# --------------------------------------------------
# Clear (any) errors.
$CLEAR_ERRORS

  ASTATUS = fmet this.ADELETEERROR ("")

Return

# --------------------------------------------------
# Check the change request is not Rejected (3), Completed (6) or Closed (7).
$CHECK_STATUS

  Gosub CLEAR_ERRORS
  If (this.CRSTATUS = 7)
      ASTATUS = fmet this.ASETERROR ("", mess(8,2038,1), [V]CST_AERROR)
  Endif

Return

# --------------------------------------------------
# Supplier collection: before ADELLINE check the logged-in user is the Change Manager ...
$CHECK_ADELLINE

  Local Char MESSAGE(100)

  Gosub CLEAR_ERRORS
  If (this.CRSTATUS = 7)
      ASTATUS = fmet this.ASETERROR ("", mess(8,2038,1), [V]CST_AERROR)
  Else
    # Issue 109094/19 - check for either Change manager or QA Manager
    If (this.NCSREC = 2)
      If (this.ACTX.USER <> this.NCSMANAGER and this.ACTX.USER <> this.CCMCRORIGS.CREUSR)
        ASTATUS = fmet this.ASETERROR ("", mess(76,2038,1), [V]CST_AERROR)
      Endif
    Else
      If (this.ACTX.USER <> this.CCMUSRID and this.ACTX.USER <> this.CCMCRORIGS.CREUSR)
        ASTATUS = fmet this.ASETERROR ("", mess(76,2038,1), [V]CST_AERROR)
      Endif
    Endif
    # End issue 109094/19
   Endif

Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Case CURPRO
    When "CCMCR.CCMCRORIGS.BPSNUM" , "NCSREC.CCMCRORIGS.BPSNUM" # Issue 109094/19
      Case ACTION
        When "PROPAGATE"
          Gosub POPULATE_ORIGINATOR_SUPPLIER
      Endcase
    When "CCMCR.CCMCRORIGS.SUPPCONTACT" , "NCSREC.CCMCRORIGS.SUPPCONTACT"  # Issue 109094/19
      Case ACTION
        When "PROPAGATE"
          Gosub POPULATE_ORIGINATOR_CONTACT
      Endcase
  Endcase

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

