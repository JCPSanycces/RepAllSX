#<AdxTL>@(#)12.0.0.0 $Revision$
#GBIDC1 = func AECLIDBG.LISDBG
GBIDC1 = func SETDBG("")
End

#------------------------------------------------------------------------------------------#
# SETDBG : Forcer le débuggeur Eclipse pour un utilisateur pour la session courante
# ADDDBG : Ajout d'une session débug
# ANUDBG : Suppression
# EPUDBG : Epuration journalière
# LISDBG : Visualisation
#------------------------------------------------------------------------------------------#

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "RAF"         : Gosub RAF
 When "OK"          : Gosub OK
 When "FIN"         : Gosub DEVERROU
Endcase
Return

#-------------------------------------------------------------------#
$OUVRE
Local Char    TIMAFF(250)
Local Integer HH , MM , SS , TEMPS , PLEIN
If clalev([F:AEG])=0 : Local File AECLIDBG [AEG] : Endif
Gosub VERROU
Return

#----------------#
$VERROU
Local Char SYMBOLE(30)
Local Integer VERROU
SYMBOLE = "AECLIDBG"
Lock =SYMBOLE
If fstat : VERROU = 1 : Endif
Return

#----------------#
$DEVERROU
Unlock =SYMBOLE
Return

#----------------#
$SETBOUT
CHBOU += "="
If PLEIN or VERROU or REP<>"M"
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
Return

#----------------#
$APRES_MODIF
REP = "M"
Return

#----------------#
$RAF
Gosub CHARGE
Affzo
If PLEIN or VERROU : Diszo : Endif
Return

#----------------------------------------------------------#
$DEBUT
PLEIN = 0
Gosub CHARGE
Affzo
If PLEIN or VERROU : Diszo : Endif
Return

#----------------#
$CHARGE
nolign = 0
For [AEG]AEG0
 If nolign+1>=dim([M:AEG1]NUMLIG)
  PLEIN = 1 : Break
 Endif
 nolign += 1
 [M:AEG1] = [F:AEG]
 TEMPS = [F:AEG]HEUDEB : Gosub HEURE : [M:AEG1]DEBAFF(nolign-1) = TIMAFF
 TEMPS = [F:AEG]HEUFIN : Gosub HEURE : [M:AEG1]FINAFF(nolign-1) = TIMAFF
 If dim([F:AEG]CRETIM)>0 : TEMPS = [F:AEG]CRETIM : Gosub HEURE : [M:AEG1]CREAFF(nolign-1) = TIMAFF : Endif
 If dim([F:AEG]UPDTIM)>0 : TEMPS = [F:AEG]UPDTIM : Gosub HEURE : [M:AEG1]UPDAFF(nolign-1) = TIMAFF : Endif
Next AEG
[M:AEG1]NBLIG = nolign
Return

#----------------#
$HEURE
If TEMPS<>0
 HH = int(TEMPS/3600)
 MM = int(mod(TEMPS,3600)/60)
 SS = mod(TEMPS,60)
Endif
TIMAFF = string$(TEMPS<>0,format$("N0:##",HH)+":"+format$("N0:##",MM)+":"+format$("N0:##",SS))
Return

#----------------#
$OK
GOK = 1
Trbegin [AEG]
 Delete [AEG] Where 1=1
 For nolign=1 To [M:AEG1]NBLIG
  [F:AEG] = [M:AEG1]
  Write [AEG]
  If fstat
   GOK=0 : Call FSTA("AEG") From GLOCK : Break
  Endif
 Next nolign
 If GOK<>1 : Goto AB_OK : Endif
Commit
Return

$AB_OK
Rollback
Return

#----------------#
$SET_LOGIN
Local Char    LOGIN(GLONALO) , APPLI(GLONADS)
LOGIN = tolower(adxusr)
APPLI = toupper(nomap)
Return

#---------------------------------------------------------#
# Forcer débuggeur Eclipse
#---------------------------------------------------------#

Funprog SETDBG(USR)
Value Char USR
If USR=""
 USR = GUSER
Endif
#If func AFNC.PARAMUTIL("AECLIDBG",USR,"")<>"2"
# Call MAJPARUSR("AECLIDBG",USR,"2")
#Endif
[S]adxdpg = func AECLIDBG.NAMDBG
End ""

#---------------------------#
Funprog NAMDBG
End "DEBUGGER"

