Local    Char    WART : WART = VALEUR
Local    Char    WUSR : WUSR = ""

If VALEUR = "" : End : Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
Endif

If WFCY <> ""
    Call CTLPLNFLT(WFCY, WART, WUSR) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
    Endif
Endif



End

