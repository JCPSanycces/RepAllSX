End

#Cancelation without return button
########################################
Subprog B1_NBLIG
Local Integer WMODE
If [M:MWH2]CCLDAT(nolign-1) <> [0/0/0] : End : Endif

# 89315 mm 05.2013
# on interdit d'annuler une pesée qui est réconciliée ou engagée.
If [M:MWH2]RCLCOD(nolign-1) =2
 GMESSAGE= mess(63,2324,1)
 End
Endif

If [M:MWH2]ENGCOD(nolign-1) =2
 GMESSAGE= mess (64,2324,1)
 End
Endif

# Annulation sans réintégration
If [M:MWH2]WEIWEI(nolign-1) = 0
    WMODE = 3
    Gosub TRT_ANNULATION
Else
    WMODE = 2
    Gosub TRT_ANNULATION
Endif
mkstat = 4
End

#Cancelation with return button
########################################
Subprog B2_NBLIG
# Annulation avec réintégration
Local Integer WMODE

# 89315 mm 05.2013
# on interdit d'annuler une pesée qui est réconciliée ou engagée.
If [M:MWH2]RCLCOD(nolign-1) =2
 GMESSAGE= mess(63,2324,1)
 End
Endif

If [M:MWH2]ENGCOD(nolign-1) =2
 GMESSAGE= mess(64,2324,1)
 End
Endif

WMODE =1
Gosub TRT_ANNULATION
mkstat = 4

End

