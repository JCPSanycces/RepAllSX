##########################################################################
## Etiquette ajoutée par le superviseur 28/11/2003 16:33:04 (SR)
##########################################################################
Subprog IB_NBLIG
GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
GBOUT4 = ""
GBOUT5 = ""
GBOUT6 = ""
GBOUT7 = ""
GBOUT8 = ""
GBOUT9 = ""
GBOUT10 = ""
GBOUT11 = ""

If [M:MWH2]NBLIG = 0  : End : Endif
# 48158 mm 07.08
# (Ré)impression étiquette de pesée disponible seulement en cas de pesée partielle ou complète
If find ([M:MWH2]WEIFLG(nolign-1),2,3)
    GBOUT3 = mess(487,198,1)  # (Ré)impression étiquette de pesée
Endif

If GFONC1 <> "FUNADP" : End : Endif
If [M:MWH2]CCLDAT(nolign-1) <> [0/0/0] : End : Endif

# sr 02.02 pour les excipient, QSP et matières rectificatives soldées sans consommation
# on propose l'annulation de solde
# sr 03.02 sinon pour les mouvements de type "fin de contenant" on ne propose rien
# sr 09.02 ni pour les mouvements d'inventaire
If  [M:MWH2]WEIWEI(nolign-1) = 0
    GBOUT1 = mess(400,198,1)
Elsif [M:MWH2]WEIFLG(nolign-1) < 4
    GBOUT1 = mess(29,2324,1)  # Annulation sans réintégration
    GBOUT2 = mess(30,2324,1)  # Annulation avec réintégration
Endif

End


##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 29-11-2003 16:05:01 (MB)
##########################################################################
Subprog AS_NBLIG
End

##########################################################################
$MAJ_WGG
# 48158 mm 07.08 - Mise à jour de [WGG]

Call DEBTRANS From GLOCK
Trbegin [WGG]
Readlock [F:WGG]WGG0 = [M:MWH2]MFGNUM(nolign-1);[M:MWH2]BOMOPE(nolign-1);[M:MWH2]ITMREF(nolign-1);
&    [M:MWH2]MFGLIN(nolign-1);[M:MWH2]BOMSEQ(nolign-1);[M:MWH2]CBTDAT(nolign-1);[M:MWH2]MVTSEQ(nolign-1)
If fstat=1     GOK=-1 : GLOCK="$WGG"- [M:MWH2]MFGNUM(nolign-1) : Goto AB_ETIPESEE
Elsif fstat GOK=0  : Call RSTA("WGG", [M:MWH2]MFGNUM(nolign-1)) From GLOCK : Goto AB_ETIPESEE
Endif

#flag etiquette pesée ré-imprimée
If [F:WGG]LBEPRNCOD = 2
    [F:WGG]LBEPRNCOD = 3
Elsif [F:WGG]LBEPRNCOD = 3
    [F:WGG]LBEPRNCOD = 4
Endif

Rewrite [F:WGG]
If fstat : Goto AB_ETIPESEE
Else
    Commit
Endif

Return

######################################
$AB_ETIPESEE
Rollback
Return

# FQ 57754 Module GPAO GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"MWH") From SUBGTC

End

