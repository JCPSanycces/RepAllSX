#<AdxTL>@(#)5.0.0.0 $Revision$ Consultation MWH
############################################################################
#                        Consultation                                       #
#                        Situation de pesée HISTORIQUE                      #
#                                                                GPAO       #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site           /SITE                                                 #
# 2  = article        /ART                                                  #
# 3  = phase          /PHASE                                                #
# 4  = pièce          /VCRNUM                                               #
# 5  = date pesee     /DATPES                                               #
# 6  = lieu           /LIEU                                                 #
# 7  = box            /BOX                                                  #
# 8  = reconciliation /RECONCIL                                             #
# 9 = tri             /TRI                                                  #
# 10 = sequence nomenclature /BOMSEQ                                        #
#############################################################################
Local Char PARAM(20)(1..13)  # CATUA X3-68727.n
PARAM(1) = "GAL"
PARAM(2) = ""
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
PARAM(9) = "1"
PARAM(10) = ""
PARAM(11) = "" # CATUA X3-68727.n
Call GCONSULT("SHO","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$OUVRE
Local  Integer WSRT,WRET
Local  Char    CRITERE(255)
Local  Char    CRITERE1(255)
Local  Char    CRITERE2(255)
Local  Char    CRITERE3(255)
Local  Char    FORMULE1(250)
Global Char    GMMLNUM(GLONTRS)

If clalev ([F:ITM])  <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:FCY])  <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:TFO])  <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:TUN])  <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:STX])  <= 0 : Local File STATION    [STX] : Endif
If clalev ([F:SBX])  <= 0 : Local File STATIONBOX [SBX] : Endif
If clalev ([F:SLE])  <= 0 : Local File SCALES     [SLE] : Endif
If clalev ([F:CTN])  <= 0 : Local File CONTAINERS [CTN] : Endif
If clalev ([F:TKS])  <= 0 : Local File TANKS      [TKS] : Endif
If clalev ([F:HSH])  <= 0 : Local File HANDLING   [HSH] : Endif
If clalev ([F:WGG])  <= 0 : Local File WEIGHING   [WGG] : Endif
If clalev ([F:MFG])  <= 0 : Local File MFGHEAD    [MFG] : Endif
If clalev ([F:MFM])  <= 0 : Local File MFGMAT     [MFM] : Endif
If clalev ([F:MFM1])  <= 0 : Local File MFGMAT    [MFM1] : Endif
 # 48158 mm 07.08
If clalev([F:ARP])   <=0  : Local File AREPORT    [ARP] : Endif
If clalev([F:AUS])   <=0  : Local File AUTILIS    [AUS] : Endif
If clalev([F:AIA])   <=0  : Local File APRTAUS    [AIA] : Endif


Gosub DEFCRIT
If !find([M:CMWH]TRI,1,2,3,4,5) : [M:CMWH]TRI = 1 : Endif
If GFONC1 = "FUNADP" [M:CMWH]CCL  = 1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMWH"
Return

#############################################################################
$FERME
Return

############################################################################
$FIN_CRIT
Return

#############################################################################
# analyse paramètres
$DEFCRIT

Local Integer WOPE
Local Integer WSTA
Local Integer WSEQ
Local Integer WINV
Local Char    WCTN(8)


For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     If !fstat & [F:FCY]MFGFLG = 2 : [M:MWH1]MFGFCY = PARAM(I) : Endif
                 Endif
        When 2 : # article
                 If PARAM(I) <> ""
                     Read [ITM]ITM0 = PARAM(I)
                     If !fstat
                         [M:MWH1]ITMREFSTR = PARAM(I)
                         [M:MWH1]ITMREFEND = PARAM(I)
                     Endif
                 Endif
        When 3 : # Phase
                 If PARAM(I) <> ""
                     WOPE = val(PARAM(I))

                     [M:MWH1]BOMOPESTR = WOPE
                     [M:MWH1]BOMOPEEND = WOPE
                 Endif

        When 4 : # Piece
                 If PARAM(I) <> ""
                     [M:MWH1]MFGNUMSTR = PARAM(I)
                 Endif
        When 5 : # date pesee
                 If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:CMWH]CBTDATSTR = "["+PARAM(I)+"]"
                         [M:CMWH]CBTDATEND = "["+PARAM(I)+"]"
                     Else
                         [M:CMWH]CBTDATSTR = PARAM(I)
                         [M:CMWH]CBTDATEND = PARAM(I)
                     Endif
                 Endif
       When 6 : # Lieu
                 If PARAM(I) <> ""
                     [M:CMWH]STISTR    = PARAM(I)
                     [M:CMWH]STIEND    = PARAM(I)
                 Endif
       When 7 : # Box
                 If PARAM(I) <> ""
                     [M:CMWH]BOXSTR    = PARAM(I)
                     [M:CMWH]BOXEND    = PARAM(I)
                 Endif


        When 8 : # Reconciliation
                 If PARAM(I) <> ""
                     WSTA = val(PARAM(I))

                     [M:CMWH]RCLCODSTR = WSTA
                     [M:CMWH]RCLCODEND = WSTA
                 Endif

        When 9 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 5  : WSRT = 1 : Endif
                     [M:CMWH]TRI = WSRT
                 Endif
        When 10 : # sequence nomenclature
                 If PARAM(I) <> ""
                     WSEQ = val(PARAM(I))
                     [M:CMWH]BOMSEQ = WSEQ
                 Endif
       # CATUA X3-68727.sn Add the ability to filter by container
        When 11 : # container
                 If PARAM(I) <> "" & dim([M:MWH1]CTNSTR)>0
                     WCTN = PARAM(I)
                     [M:MWH1]CTNSTR = WCTN
                     [M:MWH1]CTNEND = WCTN
                 Endif
        # CATUA X3-68727.en

        When 13 : # mvt redressement
                 If PARAM(I) <> ""
                     WINV = val(PARAM(I))
                     [M:CMWH]INVMVT = WINV
                 Endif


        When Default: Break
    Endcase
Next I
# copie de l'écran critères (CMWH) vers le masque 0 (MWH1)
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE

# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MWH1]MFGFCY = ""  : NBLU = 0 : Return : Endif
# si le tri n'est pas passé en paramètre, pas de chargement automatique
If PARAM(9) = "" : NBLU=0 : PARAM(9) = "1" : Return : Endif

#If PARAM(9) = "" : PARAM(9) = "1" : Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

# application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CMWH]TRI
      When 1 : # tri par OF
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key WGG0
      When 2 : # tri par phase
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE = [F:WGG]BOMOPE
      When 3 : # tri par composant
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:WGG]ITMREF
      When 4 : # tri par date pesee
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:WGG]CBTDAT
      When 5: # tri par Lieu
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:WGG]STI

    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CMWH]TRI

      When 1 : # tri par OF
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key WGG0 Desc
      When 2 : # tri par phase
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE = [F:WGG]BOMOPE Desc
      When 3 : # tri par composant
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:WGG]ITMREF Desc
      When 4 : # tri par date pesee
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:WGG]CBTDAT Desc
      When 5: # tri par Lieu
             Filter [WGG] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:WGG]STI Desc

    Endcase
Endif

# raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 : Raz [M:MWH2] : Endif

# lecture
$BOUCLE

For [WGG]


      If NBLU = 1
         If CHGPAG = 2 | CHGPAG = -2 : Raz [M:MWH2] : Endif
      NBLU = 2
      Endif

      If CHGPAG > 0
         If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
      NOL    += 1
      If NOL=0
         DEBNUM = [F:WGG]MFGNUM
         DEBPHA = [F:WGG]BOMOPE
         DEBITM = [F:WGG]ITMREF
         DEBDAT = [F:WGG]CBTDAT
         DEBSTI = [F:WGG]STI
      Endif
      FINNUM = [F:WGG]MFGNUM
      FINPHA = [F:WGG]BOMOPE
      FINITM = [F:WGG]ITMREF
      FINDAT = [F:WGG]CBTDAT
      FINSTI = [F:WGG]STI

   Else
      If NOL <= 0 : RETOUR = 2 : Break : Endif
      NOL    -= 1
      If NOL = MAXLIG-1
      FINNUM = [F:WGG]MFGNUM
      FINPHA = [F:WGG]BOMOPE
      FINITM = [F:WGG]ITMREF
      FINDAT = [F:WGG]CBTDAT
      FINSTI = [F:WGG]STI

     Endif
         DEBNUM = [F:WGG]MFGNUM
         DEBPHA = [F:WGG]BOMOPE
         DEBITM = [F:WGG]ITMREF
         DEBDAT = [F:WGG]CBTDAT
         DEBSTI = [F:WGG]STI


  Endif
  nolign = NOL+1

  Gosub FILLTAB

$SUIV
Next
 Filter [WGG]
Return

#############################################################################
# Chargements spéciaux
$FILLTAB
[M:MWH2] = [F:WGG]
# Lecture ITMMASTER
# 03.09 mm - libellé traduisible
#Call LECTEXTRA ([M:MWH2]ITMDES1(nolign-1),"ITMMASTER","DES1AXX",[M:MWH2]ITMREF(nolign-1),"") From ATEXTRA
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:MWH2]ITMREF(nolign-1),[M:MWH2]ITMDES1(nolign-1), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296

# Lecture STATION
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]STXDES(nolign-1),"STATION","STXDESAXX",[M:MWH2]STI(nolign-1),"") From ATEXTRA


# Lecture STATIONBOX
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]DES(nolign-1),"STATIONBOX","DESAXX",[M:MWH2]BOX(nolign-1),[M:MWH2]FCY(nolign-1)) From ATEXTRA


# Lecture BALANCE PREVUE
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]EXTSLEDES(nolign-1),"SCALES","DESAXX",[M:MWH2]EXTSLE(nolign-1),[M:MWH2]FCY(nolign-1)) From ATEXTRA

# Lecture BALANCE UTILISEE
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]USESLEDES(nolign-1),"SCALES","DESAXX",[M:MWH2]USESLE(nolign-1),[M:MWH2]FCY(nolign-1)) From ATEXTRA

# Lecture RECIPIENT PREVU
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]EXTCTNDES(nolign-1),"CONTAINERS","CTNDESAXX",[M:MWH2]EXTCTN(nolign-1),"") From ATEXTRA

# Lecture RECIPIENT UTILISE
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]USECTNDES(nolign-1),"CONTAINERS","CTNDESAXX",[M:MWH2]USECTN(nolign-1),"") From ATEXTRA


# Lecture TANKS
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]TKSDES(nolign-1),"TANKS","TKSDESAXX",[M:MWH2]TKS(nolign-1),[M:MWH1]MFGFCY) From ATEXTRA


# Lecture HANDLING
# 03.09 mm - libellé traduisible
Call LECTEXTRA ([M:MWH2]ISMDES(nolign-1),"HANDLING","DESAXX",[M:MWH2]ISM(nolign-1),"") From ATEXTRA


[M:MWH2]REIOK(nolign-1) = 1


Return

#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

# site
If [M:MWH1]MFGFCY <> ""
   CRITERE = "[F:WGG]FCY=[M:MWH1]MFGFCY"
   Gosub LOAD_CRITERE1
Endif

If [M:CMWH]CCL = 1
   CRITERE = "[F:WGG]CCLDAT = [0/0/0]"
   Gosub LOAD_CRITERE1
Endif

# si menu annulation on permet l of à blanc

If GFONC1 = "FUNADP" & [M:MWH1]MFGNUMSTR = "" Goto LOAD_100 : Endif

CRITERE = "[F:WGG]MFGNUM=[M:MWH1]MFGNUMSTR"          # filtre numero ordre
Gosub LOAD_CRITERE1

$LOAD_100

# composant
If [M:MWH1]ITMREFSTR <> ""
   CRITERE = "[F:WGG]ITMREF>=[M:MWH1]ITMREFSTR"       # borne debut composant
   Gosub LOAD_CRITERE1
Endif
If [M:MWH1]ITMREFEND <> ""
   CRITERE = "[F:WGG]ITMREF<=[M:MWH1]ITMREFEND"       # borne fin composant
   Gosub LOAD_CRITERE1
Endif
# phase
If [M:MWH1]BOMOPESTR <> 0
   CRITERE = "[F:WGG]BOMOPE>=[M:MWH1]BOMOPESTR"       # borne debut phase
   Gosub LOAD_CRITERE1
Endif
If [M:MWH1]BOMOPEEND <> 0
   CRITERE = "[F:WGG]BOMOPE<=[M:MWH1]BOMOPEEND"       # borne fin phase
   Gosub LOAD_CRITERE1
Endif

If [M:CMWH]BOMSEQ <> 0
   CRITERE = "[F:WGG]BOMSEQ=[M:CMWH]BOMSEQ"           # sequance nomenclature
  Gosub LOAD_CRITERE1
Endif


# date de pesee

# si menu annulation initialisation des dates à la date du jour

If GFONC1 = "FUNADP" & [M:CMWH]CBTDATSTR = [0/0/0]
                       [M:CMWH]CBTDATSTR = date$
Endif

If [M:CMWH]CBTDATSTR <> [0/0/0]
   CRITERE = "[F:WGG]CBTDAT>=[M:CMWH]CBTDATSTR"       # borne debut date pesee
   Gosub LOAD_CRITERE2
Endif

If GFONC1 = "FUNADP" & [M:CMWH]CBTDATEND = [0/0/0]
                       [M:CMWH]CBTDATEND = date$
Endif

If [M:CMWH]CBTDATEND <> [0/0/0]
   CRITERE = "[F:WGG]CBTDAT<=[M:CMWH]CBTDATEND"       # borne fin date pesee
   Gosub LOAD_CRITERE2
Endif
# lieu
If [M:CMWH]STISTR <> ""
   CRITERE = "[F:WGG]STI>=[M:CMWH]STISTR"       # borne debut lieu
   Gosub LOAD_CRITERE2
Endif
If [M:CMWH]STIEND <> ""
   CRITERE = "[F:WGG]STI<=[M:CMWH]STIEND"       # borne fin lieu
   Gosub LOAD_CRITERE2
Endif
# box
If [M:CMWH]BOXSTR <> ""
   CRITERE = "[F:WGG]BOX>=[M:CMWH]BOXSTR"       # borne debut box
   Gosub LOAD_CRITERE2
Endif
If [M:CMWH]BOXEND <> ""
   CRITERE = "[F:WGG]BOX<=[M:CMWH]BOXEND"       # borne fin box
   Gosub LOAD_CRITERE2
Endif
# reconciliation
If [M:CMWH]RCLCODSTR <> 0
   CRITERE = "[F:WGG]RCLCOD>=[M:CMWH]RCLCODSTR"       # borne debut reconciliation
   Gosub LOAD_CRITERE2
Endif
If [M:CMWH]RCLCODEND <> 0
   CRITERE = "[F:WGG]RCLCOD<=[M:CMWH]RCLCODEND"       # borne fin reconciliation
   Gosub LOAD_CRITERE2
Endif

# CATUA X3-68727.sn Add the ability to filter by container
# container
If dim([M:MWH1]CTNSTR)>0
  If [M:MWH1]CTNSTR <> ""
     CRITERE = "[F:WGG]CTN>=[M:MWH1]CTNSTR"             # container start
     Gosub LOAD_CRITERE2
  Endif
  If [M:MWH1]CTNEND <> ""
     CRITERE = "[F:WGG]CTN<=[M:MWH1]CTNEND"             # container end
     Gosub LOAD_CRITERE2
  Endif
Endif
# CATUA X3-68727.en
# sequence nomenclature

If [M:CMWH]INVMVT <> 2
   CRITERE = "[F:WGG]WEIFLG <> 5"                     # ne pas voir les mouvements de redressement
   Gosub LOAD_CRITERE2
Endif


Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CMWH]TRI
       When 1 : # tri par of
           CRITERE = "[F:WGG]MFGNUM>=DEBNUM"
           Gosub LOAD_CRITERE3
       When 2 : # tri par phase
           CRITERE = "[F:WGG]BOMOPE>=DEBPHA"
           Gosub LOAD_CRITERE3
       When 3 : # tri par composant
           CRITERE = "[F:WGG]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
       When 4 : # tri par date pesee
           CRITERE = "[F:WGG]CBTDAT>=DEBDAT"
           Gosub LOAD_CRITERE3
       When 5 : # tri par lieu
           CRITERE = "[F:WGG]STI>=DEBSTI"
           Gosub LOAD_CRITERE3


     Endcase
   When 2 : # suite
     Case [M:CMWH]TRI
        When 1 : # tri par of
           CRITERE = "[F:WGG]MFGNUM>=FINNUM"
           Gosub LOAD_CRITERE3
       When 2 : # tri par phase
           CRITERE = "[F:WGG]BOMOPE>=FINPHA"
           Gosub LOAD_CRITERE3
       When 3 : # tri par composant
           CRITERE = "[F:WGG]ITMREF>=FINITM"
           Gosub LOAD_CRITERE3
       When 4 : # tri par date pesee
           CRITERE = "[F:WGG]CBTDAT>=FINDAT"
           Gosub LOAD_CRITERE3
       When 5 : # tri par lieu
           CRITERE = "[F:WGG]STI>=FINSTI"
           Gosub LOAD_CRITERE3
     Endcase

   When -2 : # retour
     Case [M:CMWH]TRI
       When 1 : # tri par of
           CRITERE = "[F:WGG]MFGNUM>=DEBNUM"
           Gosub LOAD_CRITERE3
       When 2 : # tri par phase
           CRITERE = "[F:WGG]BOMOPE>=DEBPHA"
           Gosub LOAD_CRITERE3
       When 3 : # tri par composant
           CRITERE = "[F:WGG]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
       When 4 : # tri par date pesee
           CRITERE = "[F:WGG]CBTDAT>=DEBDAT"
           Gosub LOAD_CRITERE3
       When 5 : # tri par lieu
           CRITERE = "[F:WGG]STI>=DEBSTI"
           Gosub LOAD_CRITERE3
     Endcase
Endcase
If CRITERE1 = "" : CRITERE1 = "1=1" : Endif
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif
If CRITERE3 = "" : CRITERE3 = "1=1" : Endif

# analyse présence formule de sélection
If [M:CMWH]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=12;[M:CMWH]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif

Return

#############################################################################
$LOAD_CRITERE1
If len(CRITERE1)<>0 : CRITERE1 += "&" : Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return

############################################################
# taitement
############################################################
$TRT_ANNULATION

Local  Integer     VALOK, LRETOK, RETOUR
Local  Char        WFONCTION, WFONC1, CODE
Local  Char        LFCY, LVCR, LMTK, LITM
Local  Integer     LLIN, LSEQ
Local  Integer     WNOLIGN
Local  Integer     WEXIST, WBOMSEQ
Local  Decimal     WRETQTY, WRETQTYORI
Local  Char        WPARAM(GLONVCR)(1..6) , WVALEUR(10)
Local  Char        WCCE(15)

  VALOK = 1

  If WMODE = 3
    Call OUINON(mess(31,2324,1)+num$(nolign)+"  "+"("+mess(35,2324,1)+")",VALOK) From GESECRAN
  Endif

  If WMODE = 2
    Call OUINON(mess(31,2324,1)+num$(nolign)+"  "+"("+mess(29,2324,1)+")",VALOK) From GESECRAN
  Endif

  If WMODE = 1
    Call OUINON(mess(31,2324,1)+num$(nolign)+"  "+"("+mess(30,2324,1)+")",VALOK) From GESECRAN
  Endif

  If VALOK = 1 : Return : Endif

  Gosub OPEN_FILE

  Read [F:MFG]MFG0 = [M:MWH2]MFGNUM(nolign-1)

  # on ne peut Annulation une pesée sur un of clos
  # Cannot cancel if status is closed
  If [F:MFG]MFGSTA = 4 : Call ERREUR(mess(32,2324,1)) From GESECRAN : Return : Endif

  Read [F:WGG]WGG0 = [M:MWH2]MFGNUM(nolign-1);[M:MWH2]BOMOPE(nolign-1);
&                      [M:MWH2]ITMREF(nolign-1);[M:MWH2]MFGLIN(nolign-1);
&                      [M:MWH2]BOMSEQ(nolign-1);[M:MWH2]CBTDAT(nolign-1);
&                      [M:MWH2]MVTSEQ(nolign-1)

  If fstat : Return : Endif

  If [F:WGG]CCLDAT <> [0/0/0] : Call MESSAGE(mess(33,2324,1)) From GESECRAN : Return : Endif

  Case WMODE
    When 1 #Cancelation with return
      Close Local Mask [M:MFG1]
      WFONCTION = GFONCTION
      WFONC1    = GFONC1
      GFONCTION = "FUNBENCHR"
      GFONC1    = "FUNBENCHR"
      WNOLIGN   = nolign
      WPARAM(1) = [M:MWH1]MFGFCY
      WPARAM(2) = ""
      WPARAM(3) = [M:MWH2]MFGTRKNUM(nolign-1)
      WPARAM(4) = ""
      WPARAM(5) = GUSER
      WPARAM(6) = num$([M:MWH2]REIOK(nolign-1))
      Call TRAITE_CHAR(WVALEUR,WPARAM,"IMBR","FUNBENCHR","",5,"SPEBENCHR") From GTRAITE
      nolign = WNOLIGN
      [M:MWH2]REIOK(nolign-1)= val(WPARAM(6))
      GFONCTION = WFONCTION
      GFONC1    = WFONC1
      If clalev([M:MFG1]) = 0 : Local Mask MFG1 [MFG1] : Endif
      If [M:MWH2]REIOK(nolign-1) <> 2 : Return : Endif
      # desallocation totale de la matière
      LVCR = [F:WGG]MFGNUM
      LITM = [F:WGG]ITMREF
      LLIN = [F:WGG]MFGLIN
      LSEQ = [F:WGG]BOMSEQ
      Call DES_ALLOCATION_A (LVCR, LITM, LLIN, LSEQ)   From SCALEXCHAN
      nolign = WNOLIGN #CATUA X3-99630 Reinitialize nolign in order properly read the grid and proceed with updates of WGG and MFG tables
      Call DEBTRANS From GLOCK
      Trbegin [WGG]
      Read [F:MFM]MFM0 = [F:WGG]MFGNUM;[F:WGG]MFGLIN;[F:WGG]BOMSEQ;[F:WGG]ITMREF
      If !fstat
        Case [F:MFM]MFMTRKFLG :
          When 4 :
            Call MAJ_FICHIERS ("MFM",2,0,[F:WGG]MFGNUM,[F:WGG]ITMREF,[F:WGG]MFGLIN,[F:WGG]BOMSEQ) From SCALEXCHAN
          When Default:
            Call MAJ_FICHIERS ("MFM",1,0,[F:WGG]MFGNUM,[F:WGG]ITMREF,[F:WGG]MFGLIN,[F:WGG]BOMSEQ) From SCALEXCHAN
        Endcase
      Endif
      If GOK < 1 : Gosub AB_TRT :  Return : Endif

    When 2  #Cancelation without return (Weight recorded <> 0)
      # Correspond à une creation de ligne dans mfgmat
      # créé une seule ligne pour toutes les annulations portant sur une même ligne d'origine
      # Corresponds to line creation
      # Create all cancellations on the same original line
      Call DEBTRANS From GLOCK
      Trbegin [WGG]
      WNOLIGN = nolign

      Call MAJ_FICHIERS ("MFM",0,0,[F:WGG]MFGNUM,[F:WGG]ITMREF,[F:WGG]MFGLIN,[F:WGG]BOMSEQ) From SCALEXCHAN
      If GOK < 1 : Gosub AB_TRT :  Return : Endif
      WRETQTYORI = [F:MFM]RETQTY

      Filter [F:MFM1] Where MFGNUM = [F:MFM]MFGNUM & ITMREF = [F:MFM]ITMREF &
&                         MFGLIN = [F:MFM]MFGLIN & BOMSEQORI = [F:MFM]BOMSEQ
      Read [F:MFM1]MFM0 First
      If fstat : Raz [F:MFM1]: WEXIST  = 0
      Else                   : WEXIST = 1
      Endif

      Local Decimal  F_WEIWEI_US
      Local Decimal  F_POT

      # Calcul unite de poid en unite de stoc
      # Unit weight calculation
      Call CAL_QUANTITE ([F:WGG]ITMREF,F_WEIWEI_US,[F:WGG]WEIWEI) From SCALEXCHAN

      If WEXIST = 1
        Readlock [F:MFM]MFM0 = [F:MFM1]MFGNUM;[F:MFM1]MFGLIN;[F:MFM1]BOMSEQ;[F:MFM1]ITMREF
        If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:MFM1]MFGNUM -[F:MFM1]ITMREF : Gosub AB_TRT : Return
        Elsif fstat GOK=0  : Call RSTA("MFG",[F:MFM1]MFGNUM) From GLOCK : Gosub AB_TRT : Return
        Endif
      Endif

      If [F:MFM]STOMGTCOD = 3
        F_POT = [F:WGG]POT
        If F_POT = 0 : F_POT  = 100 : Endif
        WRETQTY  = (F_WEIWEI_US * F_POT ) / 100
        Call QTEARR(WRETQTY, [F:WGG]STU) From TRTDIV
      Else
        WRETQTY  = F_WEIWEI_US
      Endif

      If WEXIST
        [F:MFM]RETQTY    += WRETQTY
        If [F:MFM]RETQTY > [F:MFM]RETQTYORI
          [F:MFM]RETQTY  = [F:MFM]RETQTYORI
        Endif
        [F:MFM]STDQTY     = [F:MFM]RETQTY
        [F:MFM]UPDUSR     = GUSER
        [F:MFM]UPDDAT     = date$
      Else
        [F:MFM]CPNTYP        = 1

        If !find([F:MFM]PKC,4,5)
          [F:MFM]RETQTY        = WRETQTY
        Endif

        If [F:MFM]RETQTY > WRETQTYORI
          [F:MFM]RETQTY  = WRETQTYORI
        Endif

        [F:MFM]STDQTY        =[F:MFM]RETQTY
        [F:MFM]USEQTY        = 0
        [F:MFM]ALLQTY        = 0
        [F:MFM]ALLSTA        = 1
        [F:MFM]CREDAT        = date$
        [F:MFM]CREUSR        = GUSER
        [F:MFM]EXPNUM        = [C]EXPORT
        [F:MFM]WGGSTA        = 1
        [F:MFM]MFMTRKFLG     = 1
        [F:MFM]MATSTA        = 1
        [F:MFM]PRPSTA        = 1
        [F:MFM]TRKFIRST      = [0/0/0]
        [F:MFM]TRKLAST       = [0/0/0]
        [F:MFM]RETQTYORI     = WRETQTYORI
        [F:MFM]BOMSEQORI     = [F:MFM]BOMSEQ
      Endif

      GPOINT  = "RPLMFM" : Gosub ENTREE From EXEFNC

      Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
      If fstat : Raz[F:MFI] : Endif

      [M:MFG0]          = [F:MFG]
      [M:MFG1]          = [F:MFG]
      [M:MFG1]NBLIG     = 1
      [M:MFG1]ITMREF(0) = [F:MFI]ITMREF
      [M:MFG1]BPCNUM(0) = [F:MFI]BPCNUM

      If !WEXIST
        $NEX_BOMSEQ
        WBOMSEQ              = [F:MFM]BOMSEQ +1
        [F:MFM]BOMSEQ        = WBOMSEQ
        Write [MFM]
        If fstat = 3 Goto NEX_BOMSEQ
        Elsif fstat : GOK=0 : Call FSTA("MFM") From GLOCK : Gosub AB_TRT :  Return
        Endif
        Gosub MAJMFM_CPTANALIN  From MFGAUTLIB

        Readlock [F:MFG]MFG0 = [F:MFM]MFGNUM
        If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MFM]MFGNUM : Gosub AB_TRT : Return
        Elsif fstat GOK=0  : Call RSTA("MFG",[F:MFM]MFGNUM) From GLOCK : Gosub AB_TRT : Return
        Endif
        [F:MFG]MATLINNBR += 1
        Rewrite [F:MFG]
        If fstat
          GOK = 0 : Call FSTA("MFG") From GLOCK : Return
        Endif

        # on se repositionne sur la matière
        Readlock [F:MFM]MFM0 = [F:WGG]MFGNUM;[F:WGG]MFGLIN;WBOMSEQ;[F:WGG]ITMREF
        If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:MFM]MFGNUM- [F:MFM]ITMREF : Gosub AB_TRT : Return
        Elsif fstat GOK=0  : Call RSTA("MFM",[F:MFM]MFGNUM) From GLOCK : Gosub AB_TRT : Return
        Endif
      Endif

      If WEXIST = 1
        If [F:MFM]ALLSTA <> 1
          Call UPDATE_MFX("M", [F:MFI]PJT, [F:MFI]BOMALT, 1) From MFGLIBM
        Else
          Call UPDATE_MFX("M", [F:MFI]PJT, [F:MFI]BOMALT, 0) From MFGLIBM
        Endif
      Else
        Call UPDATE_MFX("C", [F:MFI]PJT, [F:MFI]BOMALT, 0) From MFGLIBM
      Endif

      Rewrite [F:MFM]
      If fstat : GOK=0 : Call FSTA("MFM") From GLOCK : Gosub AB_TRT :  Return : Endif
      #----- Mise à jour statistiques matière -----#
      # Update material statistics
      Call VALSTA("MFM",1) From SUBPS2 : If GOK<1 : Gosub AB_TRT :  Return : Endif
      nolign = WNOLIGN

    When 3 #Cancelation without return (Weight recorded = 0)
      Local Integer WAUTO, WMATCLENBR
      Local    Integer  MEMSTA
      Gosub DECL_VAR From SUBMTKC
      Call DEBTRANS From GLOCK
      Trbegin [WGG]

      Call MAJ_FICHIERS ("MFM",1,0,[F:WGG]MFGNUM,[F:WGG]ITMREF,[F:WGG]MFGLIN,[F:WGG]BOMSEQ) From SCALEXCHAN
      If GOK < 1 : Gosub AB_TRT :  Return : Endif

      Readlock[F:MFM]MFM0 = [F:WGG]MFGNUM;[F:WGG]MFGLIN;[F:WGG]BOMSEQ;[F:WGG]ITMREF
      If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[F:WGG]ITMREF : Gosub AB_TRT : Return
      Elsif fstat GOK=0  : Call RSTA("MFM",[F:WGG]ITMREF) From GLOCK : Gosub AB_TRT : Return
      Endif
      MEMSTA = [F:MFM]ALLSTA # mémo statut
      Raz WMATCLENBR
      WAUTO = 1

      Gosub DESOLDE_MAT From FUNMFGS
      If GOK < 1 : Gosub AB_TRT : Return : Endif
      If [F:MFM]MFGLIN <> 0
        Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
        If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Gosub AB_TRT : Return : Endif
      Else
        Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
        Read [F:MFI]MFI0 First
        If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Gosub AB_TRT : Return : Endif
        Filter [F:MFI]
      Endif
      If [F:MFM]MATSTA = 3
        Call UPDATE_MFX("A", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
      Else
        Call UPDATE_MFX("C", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
      Endif
      Rewrite [F:MFM]
      If fstat
        GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub AB_TRT : Return
      Endif

      Readlock [F:MFG]MFG0 = [F:MFM]MFGNUM
      If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$([F:MFM]MFGNUM) : Gosub AB_TRT : Return
      Elsif fstat GOK=0  : Call RSTA("MFG",num$([F:MFM]MFGNUM)) From GLOCK : Gosub AB_TRT : Return
      Endif
      [F:MFG]MATCLENBR += WMATCLENBR
      If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&      [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&      [F:MFG]MATCLENBR = [F:MFG]MATLINNBR : [F:MFG]MFGTRKFLG = 5
      Else                                 : [F:MFG]MFGTRKFLG = 4
      Endif
      If [F:MFM]MATSTA < 3 : Gosub MAJMFG  From SUBMFS3 : Endif
      Rewrite [F:MFG]
      If fstat
        GOK = 0 : Call FSTA("MFG") From GLOCK : Gosub AB_TRT : Return
      Endif
  Endcase

  Readlock [F:WGG]WGG0 = [M:MWH2]MFGNUM(nolign-1);[M:MWH2]BOMOPE(nolign-1);
&                      [M:MWH2]ITMREF(nolign-1);[M:MWH2]MFGLIN(nolign-1);
&                      [M:MWH2]BOMSEQ(nolign-1);[M:MWH2]CBTDAT(nolign-1);
&                      [M:MWH2]MVTSEQ(nolign-1)
  If fstat=1     GOK=-1 : GLOCK="$WGG"-[M:MWH2]MFGNUM(nolign-1) : Return
  Elsif fstat GOK=0  : Call RSTA("WGG",[M:MWH2]MFGNUM(nolign-1)) From GLOCK
    Return
  Endif

  If [F:WGG]CCLDAT <> [0/0/0] : Call ERREUR(mess(33,2324,1)) From GESECRAN : Gosub AB_TRT : Return : Endif

  [F:WGG]CCLWGGOPT = WMODE
  [F:WGG]CCLDAT    = date$
  [F:WGG]CCLUSR    = GUSER

  # une pesée annulée devient reconcilié mais sans date pour les distinguées
  # Cancelled state. Reconciled without date
  [F:WGG]RCLCOD    = 2
  # une pesée annulée devient engagée mais sans date pour la distinguer d'une vraie pesée engagée
  # Cancelled state. Committed without date
  [F:WGG]ENGCOD    = 2

  Rewrite [F:WGG]
  If fstat
    GOK = 0 : Call FSTA("WGG") From GLOCK : Return
  Endif

  Readlock [F:MFG]MFG0 = [F:WGG]MFGNUM
  If fstat=1     GOK=-1 : GLOCK="$MFGHEAD"-[F:WGG]MFGNUM  : Gosub AB_TRT :  Return
  Elsif fstat GOK=0  : Call RSTA("MFG",[F:WGG]MFGNUM) From GLOCK : Gosub AB_TRT :  Return
  Endif

  # annulation de pesée ne doit pas sortir l'OF du plan de pesée
  # Cancelled state. Set MFGHEAD.WGGFLG status back to Weighing Plan
  #[F:MFG]WGGFLG     = 2
  [F:MFG]WGGFLG     = 3

  Case [M:MWH2]PKC(nolign-1)
    When 2,4,6  :  [F:MFG]WGGSTA  = 2
    When 3,5,7  :  [F:MFG]WGGSTA  = 4
    When 8,9,10 :  [F:MFG]WGGSTA  = 6
  Endcase

  Rewrite [F:MFG]
  If fstat
    GOK = 0 : Call FSTA("MFG") From GLOCK : Gosub AB_TRT : Return
  Endif

$FIN_ANNULATION
  Commit
  [M:MWH2]CCLDAT(nolign-1) = [F:WGG]CCLDAT
Return


# abandon
$AB_TRT
Rollback
Return

###################################################################################
# ouverture fichiers
$OPEN_FILE
If clalev([M:MFG1]) = 0 : Local Mask MFG1 [MFG1] : Endif
If clalev([M:MFG0]) = 0 : Local Mask MFG0 [MFG0] : Endif

If clalev([M:ORDK]) = 0 : Local Mask ORDK [ORDK] : Endif       # pour générer encours
If clalev([M:OPSK]) = 0 : Local Mask OPSK [OPSK] : Endif       # masque encours charge
# ouverture tables si nécessaire
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif  # ordre de fabrication
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:MFI]) = 0 : Local File MFGITM     [MFI] : Endif  # articles lancés
If clalev([F:MFM]) = 0 : Local File MFGMAT     [MFM] : Endif  # matières OF
If clalev([F:MFO]) = 0 : Local File MFGOPE     [MFO] : Endif  # opérations OF
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif  # poste de charge
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif  # article
If clalev([F:MTK]) = 0 : Local File MFGHEADTRK [MTK] : Endif  # suivi de fabrication
If clalev([F:MKI]) = 0 : Local File MFGITMTRK  [MKI] : Endif  # suivi articles lancés
If clalev([F:MKM]) = 0 : Local File MFGMATTRK  [MKM] : Endif  # suivi matières OF
If clalev([F:MKO]) = 0 : Local File MFGOPETRK  [MKO] : Endif  # suivi opérations OF
If clalev([F:STA]) = 0 : Local File STOALL     [STA] : Endif  # allocations
#If clalev([F:STW]) = 0 : Local File STOWRK     [STW] : Endif  # Fichier de travail stock
If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
If clalev([F:CAL]) = 0 : Local File CPTANALIN  [CAL] : Endif  # Axes analytiques 150
Return


