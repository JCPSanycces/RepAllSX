IMPTBL = 0

## Zone PRXFLD1
mkstat = 0
zoncou = "PRXFLD1"
indice = 0
If varmode([M]PRXFLD1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRXFLD1" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_PRXFLD1([M]PRXFLD1) From SUBSIP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PRXFLD1" : GZNUM = 27404 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

