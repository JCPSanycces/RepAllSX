#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet TSI
################################################################################
#    PARAMETRAGE TRANSACTION SAISIE DES OBJETS METIERS
#    GBN
#    Création le : 09/07/2003 (Origine SUBTOM - GBN)
#    Modification le : 09/07/2003
#                      05/02/2004 -> Tableaux invisibles + MZS + révision générale!
#-------------------------------------------------------------------------------
#    Objet TSI - permet la gestion des personnalisations champs sur chaque
#                onglet déclaré comme visible de la transaction
#   MDJ - 12.06.2013  (Fq 82871) : Adaptations pour Convergence (pcolor)
################################################################################
Call OBJET("TSI",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
$ACTION
  #If ACTION<>"LIENS" : Infbox ACTION : Endif
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "FILTRE"           : Gosub FILTRE
    When "LIENS"            : Gosub LIENS
    When "LIENS2"           : Gosub LIENS2
    When "SETBOUT"          : Gosub SETBOUT
    When "AVANTBOUT"        : Gosub AVANTBOUT
    When "FILGAUCHE"        : Gosub FILGAUCHE
    When "FILTRE"           : Gosub FILTRE
    When "FIN"              : Kill G_TRS_DEB
    When default
  Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE

  If clalev([F:SAI])=0  : Local File SAITRS    [SAI]  : Endif : # En-tête transaction
  If clalev([F:DST])=0  : Local File SAITRSDET [DST]  : Endif : # Détail transaction
  Global Integer G_TRS_DEB : G_TRS_DEB=1                        # Pour le choix du S_MASK dans $LIENS2

 Local Char    TABREF
 Local Char    OBJREF

 Case [F:SAI]REFOBJ
  When GVML_OMBIEN   : OBJREF="FAS"
  When GVML_OMDEPEN  : OBJREF="LOF"
  When GVML_OMSUBV   : OBJREF="GRT"
  When GVML_OMLOCFI  : OBJREF="LEA"
  When Default       : Raz OBJREF
 Endcase

 If OBJREF<>""
  Read [AOBB]ABREV=OBJREF
  If !fstat
   TABREF=[F:AOBB]NOMFIC
  Endif
 Endif

Return

#-------------------------------------------------------------------------------
$FILTRE
 FILTSUP+="REFOBJ=[F:SAI]REFOBJ & TRSCOD=[F:SAI]TRSCOD"
Return

#-------------------------------------------------------------------------------
$LIENS

 Local Integer ZONINTIT
 Local Char S_CODMSK : S_CODMSK=[F:DST]CODMSK

 #-> Récupération de l'intitulé du champ

 If [M:TSD0]ZINTIT (nolign-1) = ""
  If [F:DST]CODTYP="ABS"
   [M:TSD0]ZINTIT(nolign-1)="-> Bloc tableau"
  Else
   If [F:DST]INTIT
    Call DECODE_TEXTE([F:DST]INTIT,[M:TSD0]ZINTIT(nolign-1)) From GLOBIENS
   Endif
   If TABREF<>""
    Read [ATZB]CODZONE=TABREF;[F:DST]CODZON
    If !fstat
     If [F:ATZB]NOCOURT
      ZONINTIT=[F:ATZB]NOCOURT
      Call DECODE_TEXTE(ZONINTIT,[M:TSD0]ZINTIT(nolign-1)) From GLOBIENS
     Elsif [F:ATZB]NOABREG
      ZONINTIT=[F:ATZB]NOABREG
      Call DECODE_TEXTE(ZONINTIT,[M:TSD0]ZINTIT(nolign-1)) From GLOBIENS
     Endif
    Endif
   Endif
   If [M:TSD0]ZINTIT(nolign-1)=""
    [M:TSD0]ZINTIT(nolign-1)=[M:TSD0]CODZON(nolign-1)
   Endif
  Endif
 Endif

 If [F:DST]BROMSK="" & dim([M:TSD0]BROMSK)>0
  [M:TSD0]BROMSK(nolign-1)=num$([F:DST]NUMMSK)-[F:DST]CODMSK
 Endif

Return

#-------------------------------------------------------------------------------
$LIENS2
#-> Tri du tableau sur le code bloc puis le champs par ordre alpha
 Sorta [M:TSD0]NBRCHA [M:TSD0]NBRCHA Order By [M:TSD0]NUMBLOC([S]indice),[M:TSD0]ZINTIT([S]indice)

#-> Désactivation des champs des tableaux dont la variable ABS est en invisible
 For nolign=1 To [M:TSD0]NBRCHA

  If [M:TSD0]CODTYP(nolign-1)="ABS"
   Call ACT_DIS_ABS(nolign,[M:TSD0]SAIAFF(nolign-1))
  Endif

  # Si "Saisi" et "Obligatoire" par défaut, on ne peut rien modifier
  If [M:TSD0]SAIAFFORI(nolign-1) = 1 & [M:TSD0]OBLIGORI(nolign-1) = G_OUI
   Diszo [M:TSD0]SAIAFF(nolign-1)
  Else
   Actzo [M:TSD0]SAIAFF(nolign-1)
  Endif

  If [M:TSD0]OBLIGORI(nolign-1) = G_OUI
   Diszo [M:TSD0]OBLIG(nolign-1)
  Else
   Actzo [M:TSD0]OBLIG(nolign-1)
  Endif

 Next nolign

 [M:TSD0]DES    =[F:SAI]DES

#-> Affichage du masque

 Affzo [M:TSD0]NBRCHA

Return

#-------------------------------------------------------------------------------
$SETBOUT
  If GREP<>"M" Then
   Call VIREBOUT (CHAINE, "1") From GOBJET : # Défaut
   Call VIREBOUT (CHAINE, "E") From GOBJET : # Enregistrer
  Endif
Return

#-------------------------------------------------------------------------------
$AVANTBOUT
  Case BOUT
    When "1"        : # Bouton "Défaut" -> Restauration des valeurs d'origine
     Gosub LOAVALORI
    When default
  Endcase
Return

#-------------------------------------------------------------------------------
$FILGAUCHE
 If currbox="GAU_CHE1"
  FILGAUSUP+="REFOBJ=[F:SAI]REFOBJ & TRSCOD=[F:SAI]TRSCOD"
 Endif
Return

################################################################################
# S/P - routines communes
################################################################################

Subprog ACT_DIS_ABS(PLIGNE,PACTION)
Value Integer PLIGNE
Value Integer ACTION
Local Integer I
 For I=1 To [M:TSD0]NBRCHA
  If !(I=PLIGNE)
   If [M:TSD0]NUMBLOC(I-1)=[M:TSD0]NUMBLOC(PLIGNE-1)
    If PACTION=3
     Diszo [M:TSD0]SAIAFF(I-1)
     Diszo [M:TSD0]OBLIG(I-1)
     #Diszo [M:TSD0]VALDEF(I-1)
    Else
     Actzo [M:TSD0]SAIAFF(I-1)
     Actzo [M:TSD0]OBLIG(I-1)
     #Actzo [M:TSD0]VALDEF(I-1)
    Endif
   Endif
  Endif
 Next I
End

#-------------------------------------------------------------------------------
$LOAVALORI
For nolign=1 To [M:TSD0]NBRCHA
 If [M:TSD0]MODFLG(nolign-1)=2
  [M:TSD0]SAIAFF(nolign-1)=[M:TSD0]SAIAFFORI(nolign-1)
  [M:TSD0]OBLIG (nolign-1)=[M:TSD0]OBLIGORI(nolign-1)
  [M:TSD0]VALDEF(nolign-1)=[M:TSD0]VALDEFORI(nolign-1)
  [M:TSD0]MODFLG(nolign-1)=1
 Endif
Next nolign
Affzo [M:TSD0]
Return

################################################################################
# ECRAN : TSD0
################################################################################

# Changement de couleur si le champ est une variable de bas de tableau

 #*Fq-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
Subprog AV_ZINTIT(VALEUR)
Variable Char    VALEUR()
 If [M:TSD0]CODTYP(nolign-1)="ABS"
    Chgstl NBRCHA(nolign-1)  With "AWARNLOW"
    pcolor=GCOUL(3)  # Bleu
 Else
    Chgstl NBRCHA(nolign-1)  With ""
    pcolor=GCOUL(0)  # Normal
 Endif
End

# Avant-saisie SAIAFF

Subprog AS_SAIAFF(VALEUR)
Variable Integer VALEUR
  # Suppression de la valeur "Technique"
  GMENLOC(4)=1
  # Si type saisie affiché : on ne peut mettre que la même chose ou invisible
  If [M:TSD0]SAIAFFORI(nolign-1) = 2 | [M:TSD0]SAIAFFORI(nolign-1) = 3 : GMENLOC(1)=1 : Endif
  # Si variable de bas de tableau ne peut être que "Saisi" ou "Invisible"
  If [M:TSD0]CODTYP(nolign-1)="ABS" : GMENLOC(2)=1 : Endif
End

# Après modification SAIAFF

Subprog AM_SAIAFF(VALEUR)
Variable Integer VALEUR
 If [M:TSD0]CODTYP(nolign-1)="ABS"
  Call ACT_DIS_ABS(nolign,VALEUR)
 Endif
End

# Avant saisie OBLIG

Subprog AS_OBLIG(VALEUR)
Variable Integer VALEUR
 If [M:TSD0]CODTYP(nolign-1)<>"ABS"
  If [M:TSD0]SAIAFF(nolign-1) = 2 | [M:TSD0]SAIAFF(nolign-1) = 3 Then
   mkstat=1
  Endif
  #GBN-Bug 24739-08092004
  #If [M:TSD0]OBLIGORI(nolign-1) = 1
  # GMENLOC(2)=1
  #Endif
  #GBN-Bug 24739-08092004-Fin
 Else
  mkstat=1
 Endif
End


# Avant Saisie Mode

Subprog AS_MODE(VALEUR)
Variable Integer VALEUR
 If [M:TSD0]MODEORI(nolign-1)<1
  mkstat=1
 Endif
End

# Avant saisie VALDEF

Subprog AS_VALDEF(VALEUR)
Variable Char    VALEUR()
 If [M:TSD0]CODTYP(nolign-1)="ABS"
  mkstat=1
 Endif
End

# Avant zone MODFLG

Subprog AV_MODFLG(VALEUR)
Variable Integer VALEUR
 If [M:TSD0]SAIAFF(nolign-1)<>[M:TSD0]SAIAFFORI(nolign-1)
& | [M:TSD0]OBLIG (nolign-1)<>[M:TSD0]OBLIGORI (nolign-1)
& | [M:TSD0]VALDEF(nolign-1)<>[M:TSD0]VALDEFORI(nolign-1)
  VALEUR=2
 Else
  VALEUR=1
 Endif
End
