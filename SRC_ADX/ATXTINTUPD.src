#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"         Gosub OUVRE
 When "LIENS"         Gosub LIENS
 When "SETBOUT"       Gosub SETBOUT
 When "BOUTON"        Gosub BOUTON
 When "ENR"           Gosub ENR
 When "ABA"           Gosub ABA
 When "APRES_MODIF"   Gosub APRES_MODIF
 When Default
Endcase
Return

$OUVRE
# Limit use to supervisor team
If !find(GUSER,"VPO","ERB","RBU","CG","CCL","LSE", "DLE", "CCC")
  GMESSAGE="Don't use this function, you must contact SUPERVISOR TEAM"
  GERR=1
  [L]FIN = [V]CST_ATRUE
  Return
Endif
If !clalev([F:TLA]) : Local File TABLAN [TLA]  : Endif
If !clalev([F:ATX2]): Local File ATEXTE [ATX2] : Endif
Return

$LIENS
Call GET_TEXT([M:ATIU]NUMERO,[M:ATIU]LAN)
Return

$APRES_MODIF
If COUZON="NUMERO" | COUZON="LAN"
  Raz REP,GREP
Elsif find(COUZON,"UPDLANORI","UPDTEXTE","UPDCOMMENT")
  REP="M" : GREP="M"
Endif
Return

$SETBOUT
# Do not reset GREP if already in modify mode - GREP will be set if one of the update fields has been modified
If GREP="M"
  Return
Endif

# Check Test server valuds against ATEXTE values if different set "Save" and "Cancel" button
If ([M:ATIU]TXTSRVLANORI<>[M:ATIU]ATXLANORI | [M:ATIU]TXTSRVTEXTE<>[M:ATIU]ATXTEXTE | [M:ATIU]TXTSRVCOMENT<>[M:ATIU]ATXCOMMENT) & BOUT<>"A"
  REP="M"
Else
  REP=""
Endif
GREP=REP
Return


# Do not use button
$BOUTON
Case BOUT
  When "a"    : Gosub TEXT_DO_NOT_USE
Endcase
Return

$ENR
Gosub TEXT_MODIF
Return

#**
#* TEXT_MODIF - Update ATEXTE and text server to new text for the language being displayed
#*!
$TEXT_MODIF
If !adxlog
  Trbegin [ATX2]
Endif

Local Char MESSAGE(250)
Local Integer ASTATUS

# Update/insert text into ATEXTE
Readlock [F:ATX2]NUMERO=[M:ATIU]LAN;[M:ATIU]NUMERO
If fstat & fstat<>[V]CST_ANOREC
  Rollback
  GERR=1
  GMESSAGE=mess(20,100,1) -"ATEXTE"
  Return
Elsif fstat=[V]CST_ANOREC
  [F:ATX2]LAN     = [M:ATIU]LAN
  [F:ATX2]NUMERO  = [M:ATIU]NUMERO
  [F:ATX2]LANORI  = [M:ATIU]UPDLANORI
  [F:ATX2]TEXTE   = [M:ATIU]UPDTEXTE
  [F:ATX2]COMMENT = [M:ATIU]UPDCOMMENT
  [F:ATX2]LONG    = 30
  [F:ATX2]CLEREC  = left$(vireblc(toupper(ctrans([F:ATX2]TEXTE)),4),20)
  Write [F:ATX2]
  If fstat
    Rollback
    GERR=1
    GMESSAGE=mess(7,123,1)-"ATEXTE"
    Return
  Endif
Else
  [F:ATX2]LANORI  = [M:ATIU]UPDLANORI
  [F:ATX2]TEXTE   = [M:ATIU]UPDTEXTE
  [F:ATX2]COMMENT = [M:ATIU]UPDCOMMENT
  Rewrite [F:ATX2]
  If fstat
    Rollback
    GERR=1
    GMESSAGE=mess(9,123,1)-"ATEXTE"
    Return
  Endif
Endif

# Update/insert text in text server
[L]ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR([M:ATIU]TXTPDTCOD, [M:ATIU]NUMERO, [M:ATIU]LAN, [M:ATIU]UPDTEXTE,  [M:ATIU]UPDCOMMENT, [M:ATIU]UPDLANORI, MESSAGE)
If [L]ASTATUS<>[V]CST_AOK
  Rollback
  GERR=1
  GMESSAGE=mess(9,123,1)-"Text Server"-[L]MESSAGE
  Return
Endif

Commit

# Display updated texts
Call GET_TEXT([M:ATIU]NUMERO,[M:ATIU]LAN)

#manually clear modif flags
Raz REP,GREP
Return

# Abandon changes
$ABA
Raz REP,GREP
Call GET_TEXT([M:ATIU]NUMERO,[M:ATIU]LAN)
Return

#**
#* TEXT_DO_NOT_USE - from button "a" - remove all languages
#* Delete from text server
#* Set ATEXTE to "DON'T USE"
#*!
$TEXT_DO_NOT_USE
Local Char MESSAGE(250)
Local Integer ASTATUS
If !adxlog
  Trbegin [ATX2]
Endif
Update [F:ATX2] Where NUMERO=[M:ATIU]NUMERO With LANORI="", TEXTE="DON'T USE", COMMENT="DON'T USE"
If fstat
  Rollback
  GMESSAGE=mess(9,123,1)-"ATEXTE"
  GERR=1
  Return
Else
  [L]ASTATUS = func ATXTSVC.DELETE_TEXT([M:ATIU]TXTPDTCOD, [M:ATIU]NUMERO, [L]MESSAGE)
  If [L]ASTATUS<>[V]CST_AOK
    Rollback
    GMESSAGE=mess(9,123,1)-"Text Server"-[L]MESSAGE
    GERR=1
    Return
  Endif
Endif

Commit

# Display updated texts
Call GET_TEXT([M:ATIU]NUMERO,[M:ATIU]LAN)
Return

#**
#* GET_TEXT-Retrieve text from ATEXTE and text server
#*
#* @param NUMERO = Text number
#* @param LAN = Text language
#*!
Subprog GET_TEXT(NUMERO,LAN)
Value Integer NUMERO
Value Char LAN

Local Integer ASTATUS
Local Char MESSAGE(250)

If [L]NUMERO>0 and [L]LAN<>""
  Read [F:ATX2]NUMERO=[L]LAN;[L]NUMERO
  If !fstat
    [M:ATIU]ATXLANORI  =[F:ATX2]LANORI
    [M:ATIU]ATXTEXTE   =[F:ATX2]TEXTE
    [M:ATIU]ATXCOMMENT =[F:ATX2]COMMENT
  Else
    Raz [M:ATIU]ATXLANORI,[M:ATIU]ATXTEXTE,[M:ATIU]ATXCOMMENT,[F:ATX2]
  Endif

  [L]ASTATUS = func GET_TXTSVR_TEXT([L]NUMERO,[L]LAN,[M:ATIU]TXTSRVLANORI,
&              [M:ATIU]TXTSRVTEXTE,[M:ATIU]TXTSRVCOMENT,[L]MESSAGE)
  If [L]ASTATUS<>[V]CST_AOK
    GMESSAGE=[L]MESSAGE
  Endif
Endif

If [M:ATIU]TXTSRVLANORI<>"" | [M:ATIU]TXTSRVTEXTE<>"" | [M:ATIU]TXTSRVCOMENT<>""
  [M:ATIU]UPDLANORI=[M:ATIU]TXTSRVLANORI
  [M:ATIU]UPDTEXTE=[M:ATIU]TXTSRVTEXTE
  [M:ATIU]UPDCOMMENT=[M:ATIU]TXTSRVCOMENT
Else
  [M:ATIU]UPDLANORI=[M:ATIU]ATXLANORI
  [M:ATIU]UPDTEXTE=[M:ATIU]ATXTEXTE
  [M:ATIU]UPDCOMMENT=[M:ATIU]ATXCOMMENT
Endif
Affzo [M:ATIU]

End

#**
#* Retrieve LANORI,TEXTE,COMMENT from text server for a specific language and number
#*
#* @param NUMERO - number of the text to retrieve
#* @param LAN    - language of the text
#* @return LANORI - Original language
#* @return TEXTE  - Text
#* @return COMMENT - Comment
#* @return MESSAGE - Message on an error
#* @return ASTATUS - [V]CST_AOK or error number
#*!
Funprog GET_TXTSVR_TEXT(NUMERO,LAN,LANORI,TEXTE,COMMENT,MESSAGE)
Value Integer NUMERO
Value Char LAN
Variable Char LANORI,TEXTE,COMMENT,MESSAGE

Local Integer ASTATUS,COUNT,I
Local Char TBLAN(GLONLAN)(1..)
Local Char TBTEXT(80)(1..)
Local Char TBCOM(80)(1..)
Local Char TBLANORI(GLONLAN)(1..)

Raz [L]LANORI,[L]TEXTE,[L]COMMENT,[L]MESSAGE

[L]ASTATUS = func ATXTSVC.GET_TEXTINFO([M:ATIU]TXTPDTCOD, [L]NUMERO, COUNT, TBLAN, TBTEXT, TBCOM, TBLANORI, [L]MESSAGE)
If [L]ASTATUS=[V]CST_AOK
  I=find([L]LAN,[L]TBLAN)
  If I
    [L]LANORI  = [L]TBLANORI(I)
    [L]TEXTE   = [L]TBTEXT(I)
    [L]COMMENT = [L]TBCOM(I)
  Endif
Endif
End [L]ASTATUS

Subprog AM_NUMERO(VALEUR)
Variable Decimal VALEUR

If VALEUR>= 1000000
  #All product only
  [M:ATIU]TXTPDTCODA="-2" : [M:ATIU]TXTPDTCOD=-2
  Diszo [M:ATIU]TXTPDTCODA
Else
  #All product not allowed
  [M:ATIU]TXTPDTCODA=num$(GPRODUIT) : [M:ATIU]TXTPDTCOD=GPRODUIT
  Actzo [M:ATIU]TXTPDTCODA
Endif
Call GET_PDT([M:ATIU]TXTPDTCOD) From ATXTINTMNU

Call GET_TEXT(VALEUR,[M:ATIU]LAN)
End

Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
Call GET_TEXT([M:ATIU]NUMERO,VALEUR)
End

Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
Read [TLA]TLA0 = VALEUR
If !fstat & [TLA]LANSTD<>2
 GMESSAGE = func ASYRFNC.MES1(mess(144,127,1),VALEUR) # The language $1$ is not a standard one
 mkstat =2 : End
Endif
End

Subprog S_LAN(VALEUR)
Variable Char VALEUR
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..,1..5) , TIT(GLONDES)(0..5) , CRITERE(250)

Filter [F:TLA] Where [TLA]LANSTD=2 Order By LAN
For [F:TLA]
 NBTEX+=1
 TEX(NBTEX,1) = [F:TLA]LAN
 TEX(NBTEX,2) = func ASYRFNC.TEXTRA("TABLAN","INTDES",[F:TLA]LAN,"")
 TEX(NBTEX,3) = func ASYRFNC.TEXTRA("TABLAN","INTSHO",[F:TLA]LAN,"")
Next

CHOI = 0
TIT(0) = func ASYRFNC.TEXTE(18654)          # All the standard languages
TIT(1) = func ASYRFNC.TEXTE(15057)          # Standard language
TIT(2) = mess(36,105,1)                     # Description
TIT(3) = func ASYRFNC.TEXTE(4010)           # Short title
If NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Endif
Filter [F:TLA]
End

Subprog B1_NUMERO(VALEUR)
Variable Decimal VALEUR
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..,1..5) , TIT(GLONDES)(0..5) , CRITERE(250)

If !clalev([TLA]) : Local File TABLAN [TLA] : Endif
Link [F:ATX2] With [F:TLA]TLA0=[F:ATX2]LAN As [LNK1] Where [F:TLA]LANSTD=2 & [F:ATX2]NUMERO=VALEUR Order By [F:ATX2]LAN
For [LNK1]
 NBTEX+=1
 TEX(NBTEX,1) = num$([F:ATX2]NUMERO)
 TEX(NBTEX,2) = [F:ATX2]LAN
 TEX(NBTEX,3) = [F:ATX2]TEXTE
 TEX(NBTEX,4) = [F:ATX2]COMMENT
 TEX(NBTEX,5) = [F:ATX2]LANORI
Next

CHOI = 0
TIT(0) = func ASYRFNC.TEXTE(22656)          # ATEXTE link
TIT(1) = mess(29,123,1)                     # Text number
TIT(2) = mess(259,123,1)                    # Language"
TIT(3) = mess(4,38,1)                       # Text
TIT(4) = mess(123,124,1) :                  # Comment
TIT(5) = func AMK_TOOL.GET_FIELD_LABEL("ATEXTE","LANORI") :          # Original language
If NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = val(TEX(CHOI,1))
  [M:ATIU]LAN = TEX(CHOI,2) : Affzo [M:ATIU]LAN
 Endif
Else
  GMESSAGE=mess(96,115,15)                  # Text not found
  GERR=1
Endif
LogicClose File [LNK1]
End

Subprog B2_NUMERO(VALEUR)
Variable Decimal VALEUR
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..,1..5) , TIT(GLONDES)(0..5) , CRITERE(250)
Local Integer ASTATUS,COUNT,I
Local Char TBLAN(GLONLAN)(1..)
Local Char TBTEXT(80)(1..)
Local Char TBCOM(80)(1..)
Local Char TBLANORI(GLONLAN)(1..)
Local Char MESSAGE(250)
If VALEUR<>0
  [L]ASTATUS = func ATXTSVC.GET_TEXTINFO(GPRODUIT, VALEUR, COUNT, TBLAN, TBTEXT, TBCOM, TBLANORI, MESSAGE)
  If [L]ASTATUS<>[V]CST_AOK
    GMESSAGE = [L]MESSAGE
    GERR=1            #
    End
  Endif
Endif

# Sort the arrays by language
If COUNT>1
  Sorta COUNT TBLAN,TBTEXT,TBCOM,TBLANORI
Endif

For I=1 To COUNT
 NBTEX+=1
 TEX(NBTEX,1) = num$([M:ATIU]NUMERO)
 TEX(NBTEX,2) = TBLAN(I)
 TEX(NBTEX,3) = TBTEXT(I)
 TEX(NBTEX,4) = TBCOM(I)
 TEX(NBTEX,5) = TBLANORI(I)
Next

CHOI = 0
TIT(0) = func ASYRFNC.TEXTE(1000834)        # Text server
TIT(1) = mess(29,123,1)                     # Text number
TIT(2) = mess(259,123,1)                    # Language"
TIT(3) = mess(4,38,1)                       # Text
TIT(4) = mess(123,124,1) :                  # Comment
TIT(5) = func AMK_TOOL.GET_FIELD_LABEL("ATEXTE","LANORI") :          # Original language

If NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = val(TEX(CHOI,1))
  [M:ATIU]LAN = TEX(CHOI,2)
  [M:ATIU]TXTSRVLANORI=TBLANORI(CHOI)
  [M:ATIU]TXTSRVTEXTE=TBTEXT(CHOI)
  [M:ATIU]TXTSRVCOMENT=TBCOM(CHOI)
  Read [F:ATX2]NUMERO=[M:ATIU]LAN;[M:ATIU]NUMERO
  If !fstat
    [M:ATIU]ATXLANORI = [F:ATX2]LANORI
    [M:ATIU]ATXTEXTE  = [F:ATX2]TEXTE
    [M:ATIU]ATXCOMMENT= [F:ATX2]COMMENT
  Else
    Raz [M:ATIU]ATXLANORI,[M:ATIU]ATXTEXTE,[M:ATIU]ATXCOMMENT
  Endif
  Affzo [M:ATIU]
 Endif
Else
  GMESSAGE=mess(96,115,15)                  # Text not found
  GERR=1
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ATXTINTUPD) 22/06/2017 13:40:21 (DLE)
######################################################################################
Subprog C_TXTPDTCODA(VALEUR)
Variable Char VALEUR()

  If VALEUR<>"0" & val(VALEUR)=0
    GMESSAGE=mess(112,123,1)
    mkstat = 2 : End
  Endif

  If val(VALEUR)<>-2 & func ATXTSVC.ADD_PRODUCT(val(VALEUR))=""
    GMESSAGE=mess(84,141,1)
    mkstat = 2 : End
  Endif

  If val(VALEUR)=-2 & [M:ATIU]NUMERO<1000000
    GMESSAGE=mess(25,126,1)
    mkstat = 2 : End
  Endif
End

Subprog AM_TXTPDTCODA(VALEUR)
Variable Char VALEUR()

  Call AM_TXTPDTCODA(VALEUR) From ATXTINTMNU
End


