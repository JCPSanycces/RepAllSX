#<AdxTL>@(#)0.0.0.0 $Revision$
# SUBMWI : Consultation des en cours d'OF WIPCOST
# Gestion des masque MWI0 - MWI8
# l'objet porte sur la table MFGWIP [MWH]
##########################################################################
## Etiquette ajoutée par le superviseur 11/06/2003 16:21:23 (TB)
##########################################################################
$ACTION
Case ACTION
 When "FILTRE"   Gosub FILTRE
 When "FILGAUCHE"   Gosub FILGAUCHE
 When "LIENS"    Gosub LIENS
 When "OUVRE"    Gosub OUVRE
 When "SETBOUT"  Gosub SETBOUT
 When Default
Endcase
Return

# JFL - 11/09/06 - correction bug 37598
$GESTUN
# si je viens de la consultation des pièces comptables (via tunnel)
If GTUNCPT(4)=1
 N=0
# modif JFL 26/09/08 suite à une demande de Gilles LEFEBVRE
# For [MWI] Where [F:MWI]JOUNUM=[M:PCE2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:PCE2]TYP(NOLIGN2-1) and [F:MWI]MFGFCY=[M:PCE2]FCYLIN(NOLIGN2-1)
 For [MWI] Where [F:MWI]JOUNUM=[M:PCE2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:PCE2]TYP(NOLIGN2-1)
  If(!find([F:MWI]VCRNUM, TABNUM(1..N)))
   N=N+1
   TABNUM(N) = [F:MWI]VCRNUM
  Endif
  If N>=dim(TABNUM) : Call AVERTIR(mess(26,100,1), R) From GESECRAN : Break : Endif
 Next
 NBNUM=N
Elsif GTUNCPT(1)=1 # consultation de comptes
 N=0
# modif JFL 26/09/08 suite à une demande de Gilles LEFEBVRE
# For [MWI] Where [F:MWI]JOUNUM=[M:CPT2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:CPT2]TYP(NOLIGN2-1) and [F:MWI]MFGFCY=[M:CPT2]FCYLIN(NOLIGN2-1)
 For [MWI] Where [F:MWI]JOUNUM=[M:CPT2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:CPT2]TYP(NOLIGN2-1)
  If(!find([F:MWI]VCRNUM, TABNUM(1..N)))
   N=N+1
   TABNUM(N) = [F:MWI]VCRNUM
  Endif
  If N>=dim(TABNUM) : Call AVERTIR(mess(26,100,1), R) From GESECRAN : Break : Endif
 Next
 NBNUM=N
Endif
Return

# JFL - 11/09/06 - correction bug 37598
$FILTRE
If GTUNCPT(4)=1
 FILTSUP = "find([F:MWH]VCRNUM, [L]TABNUM(1..nbnum))" # bug 37598 - 08/09/06
Elsif GTUNCPT(1)=1 # consultation de comptes
 FILTSUP = "find([F:MWH]VCRNUM, [L]TABNUM(1..nbnum))" # bug 37598 - 08/09/06
Endif
Return

$FILGAUCHE
Raz GBIDI1
Call ADDCRIT(FILGAUCHE,GBIDI1,"","VCRTYP=10","&") From GOBJSUB
Return

$OUVRE
If GMODU(8)=2 : # Module GP actif
   Gosub OPEN_FILES_MFG From MFGLIB
Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:TCM])=0 : Local File TABCOSTMET [TCM] : Endif
If clalev([F:MFC])=0 : Local File MFGCOST    [MFC] : Endif
If clalev([F:ITC])=0 : Local File ITMCOST    [ITC] : Endif
If clalev([F:MCN])=0 : Local File MFCNAT     [MCN] : Endif
If clalev([F:ICN])=0 : Local File ITCNAT     [ICN] : Endif

If GMODU(6)=2 : # Module Achats actif
   Gosub OPEN_FILES_SCO From SCOLIB
Endif

# JFL - 11/09/06 - correction bug 37598
# on doit récupérer la valeur de nolign dans l'écran d'où on arrive en tunnel
Local Integer NOLIGN2, N, R, NBNUM
Local Char TABNUM(250)(1..500)

If GTUNCPT(1)=1 or GTUNCPT(4)=1 # tunnel à partir des consultations de pièces ou consultations de comptes
 # on sauvegarde la valeur nolign de l'écran d'où l'on vient
 NOLIGN2 = nolign
Endif
Gosub GESTUN
Return

$LIENS
# > attention MWH n'a pas forcément toutes ses zones renseignées (dates, CPLQTY...)
# l'objet porte sur MFGWIP ; lire l'OF s'il existe
[M:MWI0]=[F:MWH]
Case [F:MWH]VCRTYP
    When 10:
        If GMODU(8)=2 : # Module GP actif
            [M:MWI0]VCRTYP=10
            Read [MFG]MFG0 = [F:MWH]VCRNUM
            If !fstat
              [M:MWI0]EXTQTY = [F:MFG]EXTQTY
              [M:MWI0]CPLQTY = [F:MFG]CPLQTY  # qté totale réalisée
              # qté "rejetée" par rapport au rebut OPERATOIRE !!
              For [MFO]MFO0 Where MFGNUM = [M:MWI0]VCRNUM
                If [F:MFO]OPESTUCOE <> 0
                  [M:MWI0]SCRAP += [F:MFO]REJCPLQTY / [F:MFO]OPESTUCOE # attention à l'unité
                Endif
              Next
            Endif
            Read [MFI]MFI0 = [M:MWI0]VCRNUM  ## << le 1er article !!
            If !fstat
                Read [ITF]ITF0 = [F:MFI]ITMREF;[M:MWI0]MFGFCY
                If !fstat
                  If dim([M:MWI0]PROPER)>0
                    [M:MWI0]PROPER    = [F:ITF]PROPER  # selon code activité MPR
                  Endif
                  Call GETTCM([F:MFI]ITMREF,[M:MWI0]MFGFCY,[M:MWI0]VLTCOD,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM]
                  If !GBIDI1
                  # afficher les valorisations principales : zones mises en invisible !
                    [M:MWI0]RCPVLTCOD = [F:TCM]RCPVLTCOD
                    [M:MWI0]ISSVLTCOD = [F:TCM]ISSVLTCOD
                    [M:MWI0]PRIREG    = [F:TCM]PRIREG
                  Endif
                Endif
            Endif
        Endif
Endcase
# seulement pour les suivis sur OF
If [F:MWH]TRKTYP = 1
 If [M:MWI0]EXTQTY >= [M:MWI0]CPLQTY + [M:MWI0]SCRAP
   [M:MWI0]RMNEXTQTY = [M:MWI0]EXTQTY - [M:MWI0]CPLQTY - [M:MWI0]SCRAP
 Endif
Else
 [M:MWI0]RMNEXTQTY = 0
Endif

Affzo [M:MWI0]SCRAP
Affzo [M:MWI0]RMNEXTQTY
Affzo [M:MWI0]RCPVLTCOD
Affzo [M:MWI0]ISSVLTCOD
Affzo [M:MWI0]PRIREG
If dim([M:MWI0]PROPER)>0
  Affzo [M:MWI0]PROPER
Endif

Diszo [MWI0]10,15,20

Call GETDEV([M:MWI0]MFGFCY) From DEVSUB  # charge GLOCALDEV
[M:MWI0]CUR = GLOCALDEV

Call LOAD_SCRNS([M:MWI0]VCRTYP,[M:MWI0]VCRNUM)          # fait ici plutôt qu'en action s/champ

Return

$SETBOUT
Call VIREBOUT(CHAINE,"CMDH") From GOBJET # aucune écriture en table !
Gosub GESTUN
Return

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:MWI0]VCRTYP=10
End



###########################################################################
#  LOAD_SCRNS : Call the individual tab functions to load their screen values
###########################################################################
Subprog LOAD_SCRNS(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM  # FGR 25/01/2010 : X3SUIVI60986

# Open tables
If clalev([F:MWI])=0 : Local File WIPCOST    [MWI] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
Case I_VCRTYP
    When 10 : Gosub OPEN_FILES_MFG From MFGLIB
Endcase


# Initialize Screens
Raz [M:MWI1], [M:MWI2], [M:MWI3], [M:MWI4], [M:MWI5], [M:MWI6], [M:MWI7], [M:MWI8]

# Place calls to load screens
Call LOAD_SUM(I_VCRTYP, I_VCRNUM)
Call LOAD_ITM(I_VCRTYP, I_VCRNUM)
Call LOAD_MAT(I_VCRTYP, I_VCRNUM)
Call LOAD_LAB(I_VCRTYP, I_VCRNUM)
Call LOAD_MAC(I_VCRTYP, I_VCRNUM)
Call LOAD_SUB(I_VCRTYP, I_VCRNUM)
Call LOAD_OVE(I_VCRTYP, I_VCRNUM)
Call LOAD_REAL_THEO_COST

#X3-101694.sn MJH
[M:MWI1]NBLIG = 7
[M:MWI2]NBLIG = 7

For I=0 To 6
  [M:MWI1]DESCR(I) = mess(I+1,2361,1)
  [M:MWI2]DESCR(I) = mess(I+1,2361,1)
Next
#X3-101694.en

# Display screens
Affzo [M:MWI1]
Affzo [M:MWI2]
Affzo [M:MWI3]
Affzo [M:MWI4]
Affzo [M:MWI5]
Affzo [M:MWI6]
Affzo [M:MWI7]
Affzo [M:MWI8]

End

###########################################################################
#  LOAD_SUM  : Load the variables to display the Summary tab
###########################################################################
Subprog LOAD_SUM(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

Local Integer    I
# seulement pour les suivis sur OF
If [F:MWH]TRKTYP = 1
  Case I_VCRTYP
      When 10 :
          Read [MFI]MFI0 = I_VCRNUM  # le premier !
          If fstat : End : Endif
          Read [ITM]ITM0 = [F:MFI]ITMREF
          If fstat : End : Endif
  Endcase
  Else
  Read [ITM]ITM0 = [F:MWH]ITMREF # article produit (depuis plan de suivi)
Endif
Read [ITF]ITF0 = [F:ITM]ITMREF;[M:MWI0]MFGFCY
If !fstat
  Call GETTCM([F:ITM]ITMREF,[M:MWI0]MFGFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM]
  # selon la valorisation principale, afficher le solde
Endif

# Read all of WIPCOST records for the Work Order
For [MWI]MWI5 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM

    # Process the WIPCOST records based on the Transaction Type
    Case [F:MWI]TXNTYP
    When 1                # Material
        [M:MWI1]ACTCST(0) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:MWI2]ACTCST(0) += [F:MWI]AMOUNT : Endif

    When 2                # Labor
        [M:MWI1]ACTCST(1) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:MWI2]ACTCST(1) += [F:MWI]AMOUNT : Endif

    When 3                # Machine
        [M:MWI1]ACTCST(2) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:MWI2]ACTCST(2) += [F:MWI]AMOUNT : Endif

    When 4                # Subcontracting
        [M:MWI1]ACTCST(3) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:MWI2]ACTCST(3) += [F:MWI]AMOUNT : Endif

    When 5,6,7,8          # Overhead
        [M:MWI1]ACTCST(4) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:MWI2]ACTCST(4) += [F:MWI]AMOUNT : Endif

    When 9                # Material Variance
        If [F:MFG]MFGTRKFLG = 6  # Costed
            [M:MWI1]VARCST(0) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:MWI2]VARCST(0) += [F:MWI]AMOUNT : Endif
        Endif

    When 10                # Labor Variance
        If [F:MFG]MFGTRKFLG = 6  # Costed
            [M:MWI1]VARCST(1) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:MWI2]VARCST(1) += [F:MWI]AMOUNT : Endif
        Endif

    When 11                # Machine Variance
        If [F:MFG]MFGTRKFLG = 6  # Costed
            [M:MWI1]VARCST(2) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:MWI2]VARCST(2) += [F:MWI]AMOUNT : Endif
        Endif

    When 12                # Subcontracting Variance
        If [F:MFG]MFGTRKFLG = 6  # Costed
            [M:MWI1]VARCST(3) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:MWI2]VARCST(3) += [F:MWI]AMOUNT : Endif
        Endif

    When 13                # Overhead Variance
        If [F:MFG]MFGTRKFLG = 6  # Costed
            [M:MWI1]VARCST(4) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:MWI2]VARCST(4) += [F:MWI]AMOUNT : Endif
        Endif

    When 14               # Production Receipt  # distinguer le cas du sous-produit
        If [F:MWI]ITMTYP = 1
          If [F:MWI]OVENAT=""
              For I = 0 To 3
                [M:MWI1]STDCST(I) -= [F:MWI]CSTELM(I)
                If [F:MWI]GLPSTA = 2 : [M:MWI2]STDCST(I) -= [F:MWI]CSTELM(I) : Endif
              Next I
              # CCC (2009-12-08) Bug 60252 : Depuis la modif 46145 les CSTELM(4..7) sont nuls mais il faut toujours pourvoir consulter les anciens enreg
              [M:MWI1]STDCST(4) += sum([F:MWI]CSTELM(4..7))
              If [F:MWI]GLPSTA = 2 : [M:MWI2]STDCST(4) += sum([F:MWI]CSTELM(4..7)) : Endif
          Else
              [M:MWI1]STDCST(4) -= [F:MWI]AMOUNT
              If [F:MWI]GLPSTA = 2 : [M:MWI2]STDCST(4) -= [F:MWI]AMOUNT : Endif
          Endif
          [M:MWI1]STDCST(5) -= [F:MWI]AMOUNT
          If [F:MWI]GLPSTA = 2 : [M:MWI2]STDCST(5) -= [F:MWI]AMOUNT : Endif
        Elsif [F:MWI]ITMTYP = 2
          [M:MWI1]ACTCST(0) += [F:MWI]AMOUNT # sous-pdt en déduction de la matière dépensée
          If [F:MWI]GLPSTA = 2 : [M:MWI2]ACTCST(0) += [F:MWI]AMOUNT : Endif
        Endif
    When 15                # Balance Adjustment
        [M:MWI1]VARCST(6) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:MWI2]VARCST(6) += [F:MWI]AMOUNT : Endif
    When 16                # WIP Scrap
        If [F:MWI]OVENAT=""
            For I = 0 To 3
                [M:MWI1]REJCST(I) += [F:MWI]CSTELM(I)
                If [F:MWI]GLPSTA = 2 : [M:MWI2]REJCST(I) += [F:MWI]CSTELM(I) : Endif
            Next I
            # CCC (2009-12-08) Bug 60252 : Depuis la modif 46145 les CSTELM(4..7) sont nuls mais il faut toujours pourvoir consulter les anciens enreg
            [M:MWI1]REJCST(4) += sum([F:MWI]CSTELM(4..7))
            If [F:MWI]GLPSTA = 2 : [M:MWI2]REJCST(4) += sum([F:MWI]CSTELM(4..7)) : Endif
        Else
            [M:MWI1]REJCST(4) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:MWI2]REJCST(4) += [F:MWI]AMOUNT : Endif
        Endif
        [M:MWI1]REJCST(5) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:MWI2]REJCST(5) += [F:MWI]AMOUNT : Endif

    When 17                # Actual Cost
        If [F:MWI]OVENAT=""
            [M:MWI1]VARCST(5) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:MWI2]VARCST(5) += [F:MWI]AMOUNT : Endif
        Endif

    Endcase
Next

# Calculate the Totals
[M:MWI1]ACTCST(5)   += sum([M:MWI1]ACTCST(0..4))
[M:MWI2]ACTCST(5)   += sum([M:MWI2]ACTCST(0..4))

If [F:MFG]MFGTRKFLG = 6  & [F:TCM]RCPVLTCOD < 3  # Standard Costed (:il y a eu des enreg écarts 9-13)
    For I = 0 To 4
       [M:MWI1]VARCST(5)  += [M:MWI1]VARCST(I)
       [M:MWI2]VARCST(5)  += [M:MWI2]VARCST(I)
    Next I
Endif

# Calculate the Balances if the Work Order is Actual Costed
If [F:MFG]MFGTRKFLG = 6  & [F:TCM]RCPVLTCOD > 2  # Actual Costed ("réel" : pas d'enreg d'écart)
    For I = 0 To 4
        [M:MWI1]VARCST(I) = ([M:MWI1]ACTCST(I) - [M:MWI1]STDCST(I) + [M:MWI1]REJCST(I)) * (-1)
        [M:MWI2]VARCST(I) = ([M:MWI2]ACTCST(I) - [M:MWI2]STDCST(I) + [M:MWI2]REJCST(I)) * (-1)
    Next I
Endif

# Calculate the Balances if the Work Order is not costed
If [F:MFG]MFGTRKFLG < 6 & [F:MWH]TRKTYP = 1 # que pour les suivis sur OF
    For I = 0 To 5
        [M:MWI1]VARCST(I) = ([M:MWI1]ACTCST(I) - [M:MWI1]STDCST(I) + [M:MWI1]REJCST(I)) * (-1)
        [M:MWI2]VARCST(I) = ([M:MWI2]ACTCST(I) - [M:MWI2]STDCST(I) + [M:MWI2]REJCST(I)) * (-1)
    Next I
Endif
# Calculate the percent if the Work Order is costed
If [F:MFG]MFGTRKFLG = 6
    Actzo [M:MWI1]VARPCT
    For I = 0 To 5
        If [M:MWI1]STDCST(I) <> 0
            # Issue 79940 - 2012-02-07 by CCC : Arrondir sinon, dans le cas de valeurs très petites, la valeur affichée peut être trompeuse
            #[M:MWI1]VARPCT(I) = [M:MWI1]VARCST(I) / [M:MWI1]STDCST(I) * 100
            [M:MWI1]VARPCT(I) = arr([M:MWI1]VARCST(I) / [M:MWI1]STDCST(I) * 100,0.01)
        Endif
    Next
    Affzo [M:MWI1]VARPCT
Else
    Grizo [M:MWI1]VARPCT
    Effzo [M:MWI1]VARPCT
Endif

End


###########################################################################
#  LOAD_REAL_THEO_COST : Load the variables to display the Real Costs and Theoritical Costs
#  Equipe de Bordeaux le 16/10/2008
###########################################################################
Subprog LOAD_REAL_THEO_COST()
# Camembert pour le coût réel
For I = 0 To 4
  [M:MWI1]DESCST(I)=mess(I+1,2361,1)
  [M:MWI1]AMTCSTREL(I)=max(0,[M:MWI1]ACTCST(I))
  [M:MWI1]AMTCSTTHE(I)=max(0,[M:MWI1]STDCST(I))
Next I
[M:MWI1]NBLIGCST = 5

# Diagrammes pour la comparaison coût réel / coût théorique par type de répartition
# Coût réel
[M:MWI1]DESCSTCMP(0)=mess(8,2361,1)
[M:MWI1]AMTCSTMAT(0)=[M:MWI1]ACTCST(0)
[M:MWI1]AMTCSTLAB(0)=[M:MWI1]ACTCST(1)
[M:MWI1]AMTCSTMAC(0)=[M:MWI1]ACTCST(2)
[M:MWI1]AMTCSTSCO(0)=[M:MWI1]ACTCST(3)
[M:MWI1]AMTCSTOVE(0)=[M:MWI1]ACTCST(4)
[M:MWI1]AMTCSTTOT(0)=[M:MWI1]ACTCST(5)

# Coût théorique
[M:MWI1]DESCSTCMP(1)=mess(9,2361,1)
[M:MWI1]AMTCSTMAT(1)=[M:MWI1]STDCST(0)
[M:MWI1]AMTCSTLAB(1)=[M:MWI1]STDCST(1)
[M:MWI1]AMTCSTMAC(1)=[M:MWI1]STDCST(2)
[M:MWI1]AMTCSTSCO(1)=[M:MWI1]STDCST(3)
[M:MWI1]AMTCSTOVE(1)=[M:MWI1]STDCST(4)
[M:MWI1]AMTCSTTOT(1)=[M:MWI1]STDCST(5)

[M:MWI1]NBLIGCMP = 2

End
###########################################################################
#  LOAD_ITM : Load the variables to display the Products tab
###########################################################################
Subprog LOAD_ITM(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

# CCC (2009-07-28) Bug 56811 : le cumul se fait par mfglin/article
Local Char TMP_KEY(8+1+GLONITM)  : TMP_KEY = ""
Local Integer I     : I = -1

Filter [MWI] Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 14 | (TXNTYP = 5 & MATOVETYP = 1) | TXNTYP = 17)
&            Order By VCRLIN;ITMREF
For [MWI]
    # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
    If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
        Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
    Else
        Raz fstat
    Endif
    If !fstat
        If TMP_KEY <> num$([F:MWI]VCRLIN) + "~" + [F:MWI]ITMREF
            I += 1
            TMP_KEY = num$([F:MWI]VCRLIN) + "~" + [F:MWI]ITMREF
            [M:MWI3]VCRLIN(I)        = [F:MWI]VCRLIN
            [M:MWI3]ITMREF(I)        = [F:MWI]ITMREF
            [M:MWI3]ITMTYP(I)        = [F:MWI]ITMTYP # type : Normal / Sous-produit
            [M:MWI3]STU(I)           = [F:MWI]STU
            # 104939
            If dim([M:MWI3]ECCVALMAJ)>0
                [M:MWI3]ECCVALMAJ(I) = [F:MWI]ECCVALMAJ
                [M:MWI3]ECCVALMIN(I) = [F:MWI]ECCVALMIN
            Endif
        Endif

        If [F:MWI]TXNTYP = 14
            [M:MWI3]QUANTITY(I)  += [F:MWI]QTY
            [M:MWI3]AMOUNT(I)    += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2
                [M:MWI3]AMTPOST(I)  += [F:MWI]AMOUNT
            Endif
        Elsif ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP = 1)
           [M:MWI3]OVERHEAD(I)    += [F:MWI]AMOUNT
           If [F:MWI]GLPSTA = 2
                [M:MWI3]OVEPOST(I)  += [F:MWI]AMOUNT
           Endif
        Elsif [F:MWI]TXNTYP = 17
            [M:MWI3]CSTADJ(I)    += [F:MWI]AMOUNT
        Endif
    Endif
Next
Filter [MWI]
nolign = I + 1
[M:MWI3]NBLIG = I + 1

End

###########################################################################
#  LOAD_MAT  : Load the variables to display the Material tab
###########################################################################
Subprog LOAD_MAT(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

Local Char TMP_KEY(250)  : TMP_KEY = ""
Local Integer I     : I = -1

Filter [MWI] Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 1 | (TXNTYP = 5 & MATOVETYP = 2))
&            Order By VCRTYP;VCRNUM;VCRLIN;BOMSEQ;ITMREF;ECCVALMAJ;ECCVALMIN
For [MWI]
    # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
    If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
        Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
    Else
        Raz fstat
    Endif
    If !fstat
        If TMP_KEY <> num$([F:MWI]VCRLIN) + num$([F:MWI]BOMSEQ) + [F:MWI]ITMREF + [F:MWI]ECCVALMAJ +"~"+ [F:MWI]ECCVALMIN
            I += 1
            TMP_KEY = num$([F:MWI]VCRLIN) + num$([F:MWI]BOMSEQ) + [F:MWI]ITMREF + [F:MWI]ECCVALMAJ +"~"+ [F:MWI]ECCVALMIN
            [M:MWI4]VCRLIN(I)        = [F:MWI]VCRLIN
            [M:MWI4]BOMSEQ(I)        = [F:MWI]BOMSEQ
            [M:MWI4]ITMREF(I)        = [F:MWI]ITMREF
            Read [ITM]ITM0 = [F:MWI]ITMREF
       ##      # récupérer la désignation traduisible si le lien auto ne se fait pas
       ##     [M:MWI4]ITMDES(I)        = [F:ITM]ITMDES1
            [M:MWI4]STU(I)           = [F:MWI]STU
            # 104939
            If dim([M:MWI4]ECCVALMAJ)>0
                [M:MWI4]ECCVALMAJ(I) = [F:MWI]ECCVALMAJ
                [M:MWI4]ECCVALMIN(I) = [F:MWI]ECCVALMIN
            Endif
        Endif

       If [F:MWI]TXNTYP = 1
           [M:MWI4]QUANTITY(I)  += [F:MWI]QTYACT    # CCC (08/11/04) Bug 26297
           [M:MWI4]AMOUNT(I)    += [F:MWI]AMOUNT
           If [F:MWI]GLPSTA = 2
                [M:MWI4]AMTPOST(I)  += [F:MWI]AMOUNT
           Endif
        Elsif ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP = 2)
           [M:MWI4]OVERHEAD(I)    += [F:MWI]AMOUNT
           If [F:MWI]GLPSTA = 2
                [M:MWI4]OVEPOST(I)  += [F:MWI]AMOUNT
           Endif
        Endif
    Endif
Next
Filter [MWI]
nolign = I + 1
[M:MWI4]NBLIG = I + 1

End

###########################################################################
#  LOAD_LAB  : Load the variables to display the Material tab
###########################################################################
Subprog LOAD_LAB(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

Local Char TMP_KEY  : TMP_KEY = ""
Local Integer I     : I = -1

Case [F:MWH]VCRTYP
    When 10:
    For [MWI]MWI3 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 2 | TXNTYP = 6)
        # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
        If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
            Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
        Else
            Raz fstat
        Endif
        If !fstat
            If TMP_KEY <> num$([F:MWI]OPENUM) + num$([F:MWI]OPESPLNUM) + [F:MWI]STU
                I += 1
                TMP_KEY = num$([F:MWI]OPENUM) + num$([F:MWI]OPESPLNUM) + [F:MWI]STU
                [M:MWI5]OPENUM(I)        = [F:MWI]OPENUM
                [M:MWI5]OPESPLNUM(I)     = [F:MWI]OPESPLNUM
                [M:MWI5]STU(I)           = [F:MWI]STU
                For [MKO] Where MFGNUM    = [F:MWI]VCRNUM
&                             & OPENUM    = [F:MWI]OPENUM
&                             & OPESPLNUM = [F:MWI]OPESPLNUM
                    [M:MWI5]QUANTITY(I)  += [F:MKO]CPLQTY
                    [M:MWI5]REJECTED(I)  += [F:MKO]REJCPLQTY
                Next
            Endif

           If [F:MWI]TXNTYP = 2
               [M:MWI5]SETUP(I)     += [F:MWI]CPLSETTIM
               [M:MWI5]OPETIM(I)    += [F:MWI]CPLOPETIM
               [M:MWI5]AMOUNT(I)    += [F:MWI]AMOUNT
               If [F:MWI]GLPSTA = 2
                    [M:MWI5]AMTPOST(I)  += [F:MWI]AMOUNT
               Endif
            Elsif [F:MWI]TXNTYP = 6
               [M:MWI5]OVERHEAD(I)    += [F:MWI]AMOUNT
               If [F:MWI]GLPSTA = 2
                    [M:MWI5]OVEPOST(I)  += [F:MWI]AMOUNT
               Endif
            Endif
        Endif
    Next
Endcase
nolign = I + 1
[M:MWI5]NBLIG = I + 1

End


###########################################################################
#  LOAD_MAC  : Load the variables to display the Machine tab
###########################################################################
Subprog LOAD_MAC(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

Local Char TMP_KEY  : TMP_KEY = ""
Local Integer I     : I = -1

For [MWI]MWI3 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 3 | TXNTYP = 7)
    # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
    If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
        Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
    Else
        Raz fstat
    Endif
    If !fstat
        If TMP_KEY <> num$([F:MWI]OPENUM) + num$([F:MWI]OPESPLNUM) + [F:MWI]STU
            I += 1
            TMP_KEY = num$([F:MWI]OPENUM) + num$([F:MWI]OPESPLNUM) + [F:MWI]STU
            [M:MWI6]OPENUM(I)        = [F:MWI]OPENUM
            [M:MWI6]OPESPLNUM(I)     = [F:MWI]OPESPLNUM
            [M:MWI6]STU(I)           = [F:MWI]STU
        Endif

       If [F:MWI]TXNTYP = 3
           [M:MWI6]QUANTITY(I)  += [F:MWI]QTY
           [M:MWI6]REJECTED(I)  += [F:MWI]REJQTY
           [M:MWI6]SETUP(I)     += [F:MWI]CPLSETTIM
           [M:MWI6]OPETIM(I)    += [F:MWI]CPLOPETIM
           [M:MWI6]AMOUNT(I)    += [F:MWI]AMOUNT
           If [F:MWI]GLPSTA = 2
                [M:MWI6]AMTPOST(I)  += [F:MWI]AMOUNT
           Endif
        Elsif [F:MWI]TXNTYP = 7
           [M:MWI6]OVERHEAD(I)    += [F:MWI]AMOUNT
           If [F:MWI]GLPSTA = 2
                [M:MWI6]OVEPOST(I)  += [F:MWI]AMOUNT
           Endif
        Endif
    Endif
Next
nolign = I + 1
[M:MWI6]NBLIG = I + 1

End


###########################################################################
#  LOAD_SUB  : Load the variables to display the Subcontracting tab
###########################################################################
Subprog LOAD_SUB(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

Local Char TMP_KEY  : TMP_KEY = ""
Local Integer I     : I = -1

For [MWI]MWI3 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 4 | TXNTYP = 8)
    # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
    If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
        Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
    Else
        Raz fstat
    Endif
    If !fstat
        If TMP_KEY <> num$([F:MWI]OPENUM) + num$([F:MWI]OPESPLNUM) + [F:MWI]STU
            I += 1
            TMP_KEY = num$([F:MWI]OPENUM) + num$([F:MWI]OPESPLNUM) + [F:MWI]STU
            [M:MWI7]OPENUM(I)        = [F:MWI]OPENUM
            [M:MWI7]OPESPLNUM(I)     = [F:MWI]OPESPLNUM
            [M:MWI7]STU(I)           = [F:MWI]STU
            [M:MWI7]SCOITMREF(I)     = [F:MWI]ITMREF
        Endif

        If [F:MWI]TXNTYP = 4

           # CCC (31/08/05) Bug 31709
           # Les enregistrements de type 4 qui proviennent d'une régul de prix sont repérés par CSTTYP=0
           [M:MWI7]QUANTITY(I)  += [F:MWI]QTY * ([F:MWI]CSTTYP<>0)
           [M:MWI7]REJECTED(I)  += [F:MWI]REJQTY * ([F:MWI]CSTTYP<>0)
           [M:MWI7]SETUP(I)     += [F:MWI]CPLSETTIM * ([F:MWI]CSTTYP<>0)
           [M:MWI7]OPETIM(I)    += [F:MWI]CPLOPETIM * ([F:MWI]CSTTYP<>0)
           [M:MWI7]AMOUNT(I)    += [F:MWI]AMOUNT
           If [F:MWI]GLPSTA = 2
                [M:MWI7]AMTPOST(I)  += [F:MWI]AMOUNT
           Endif
        Elsif [F:MWI]TXNTYP = 8
           [M:MWI7]OVERHEAD(I)    += [F:MWI]AMOUNT
           If [F:MWI]GLPSTA = 2
                [M:MWI7]OVEPOST(I)  += [F:MWI]AMOUNT
           Endif
        Endif
    Endif
Next
nolign = I + 1
[M:MWI7]NBLIG = I + 1

End

###########################################################################
#  LOAD_OVE  : Load the variables to display the Overhead tab
###########################################################################
Subprog LOAD_OVE(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM
Local Integer OH_POS, I, J
Local Decimal LPRI
Local Integer LRET

# Read all of WIPCOST records for the Work Order
For [MWI]MWI5 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP > 4 & TXNTYP <= 17) & OVENAT<>""

    # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
    If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
        Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
    Else
        Raz fstat
    Endif
    If !fstat
        # Process the WIPCOST records based on the Transaction Type
        Case [F:MWI]TXNTYP
        When 5                # Material Overhead
           # trouver la nature dans le tableau pour y cumuler le mnt ou rajouter une ligne
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]MATERIAL(OH_POS-1) += [F:MWI]AMOUNT
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]MATERIAL([M:MWI8]NBLIG-1) = [F:MWI]AMOUNT
           Endif

        When 6                # Labor Overhead
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]LABOR(OH_POS-1) += [F:MWI]AMOUNT
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]LABOR([M:MWI8]NBLIG-1)    = [F:MWI]AMOUNT
           Endif

        When 7                # Machine  Overhead
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]MACHINE(OH_POS-1) += [F:MWI]AMOUNT
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]MACHINE([M:MWI8]NBLIG-1) = [F:MWI]AMOUNT
           Endif

        When 8                # Subcontracting Overhead
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]SUBCONT(OH_POS-1) += [F:MWI]AMOUNT
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]SUBCONT([M:MWI8]NBLIG-1) = [F:MWI]AMOUNT
           Endif

        When 14                # Production Receipt
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]STANDARD(OH_POS-1) += [F:MWI]AMOUNT
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]STANDARD([M:MWI8]NBLIG-1) = [F:MWI]AMOUNT
           Endif

        When 9,10,11,12,13     # Variance
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]VARIANCE(OH_POS-1) += [F:MWI]AMOUNT
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]VARIANCE([M:MWI8]NBLIG-1) = [F:MWI]AMOUNT
           Endif

        When 16                # Rebut
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]SCRAP(OH_POS-1) += [F:MWI]AMOUNT
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]SCRAP([M:MWI8]NBLIG-1)    = [F:MWI]AMOUNT
           Endif

        When 17     # Variance
           OH_POS = find([F:MWI]OVENAT,[M:MWI8]OVENAT)
           If OH_POS > 0
             [M:MWI8]VARIANCE(OH_POS-1) += sum([F:MWI]CSTELM(4..7))
           Else
             # rajouter en fin de tableau 1 ligne avec cette nature
             [M:MWI8]NBLIG += 1
             [M:MWI8]OVENAT([M:MWI8]NBLIG-1)   = [F:MWI]OVENAT
             [M:MWI8]VARIANCE([M:MWI8]NBLIG-1) = sum([F:MWI]CSTELM(4..7))
           Endif


        Endcase
    Endif
Next

[M:MWI8]OVENAT([M:MWI8]NBLIG) = mess(200,197,1) #"Totaux". Ligne supplémentaire pour totaux :
For I = 0 To [M:MWI8]NBLIG - 1
    [M:MWI8]TOTAL(I) = [M:MWI8]MATERIAL(I) + [M:MWI8]LABOR(I) + [M:MWI8]MACHINE(I) + [M:MWI8]SUBCONT(I)
    #[M:MWI8]VARIANCE(I) = [M:MWI8]TOTAL(I) - [M:MWI8]STANDARD(I)
Next
[M:MWI8]MATERIAL([M:MWI8]NBLIG) = sum([M:MWI8]MATERIAL(0..[M:MWI8]NBLIG - 1))
[M:MWI8]LABOR([M:MWI8]NBLIG)    = sum([M:MWI8]LABOR(0..[M:MWI8]NBLIG - 1))
[M:MWI8]MACHINE([M:MWI8]NBLIG)  = sum([M:MWI8]MACHINE(0..[M:MWI8]NBLIG - 1))
[M:MWI8]SUBCONT([M:MWI8]NBLIG)  = sum([M:MWI8]SUBCONT(0..[M:MWI8]NBLIG - 1))
[M:MWI8]TOTAL([M:MWI8]NBLIG)    = sum([M:MWI8]TOTAL(0..[M:MWI8]NBLIG - 1))
[M:MWI8]STANDARD([M:MWI8]NBLIG) = sum([M:MWI8]STANDARD(0..[M:MWI8]NBLIG - 1))
[M:MWI8]SCRAP([M:MWI8]NBLIG)    = sum([M:MWI8]SCRAP(0..[M:MWI8]NBLIG - 1))
[M:MWI8]VARIANCE([M:MWI8]NBLIG) = sum([M:MWI8]VARIANCE(0..[M:MWI8]NBLIG - 1))

[M:MWI8]NBLIG += 1

End

