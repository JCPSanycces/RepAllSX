$UPDATE_ABLOB

#Local variables
Local Integer TRAN_PEND
Local Integer UPDATE_STAT

[L]TRAN_PEND = adxlog

If ![L]TRAN_PEND
  Trbegin [F:ABB3]
Endif

Read [F:ABB3]ABB0 = I_ESSUSRTRK.HRESSATT(NI).ABREV;I_ESSUSRTRK.HRESSATT(NI).IDENT1;I_ESSUSRTRK.HRESSATT(NI).IDENT2;num$(NI)
If !fstat
  #re-write
  Gosub SET_HRESSATT_FIELDS
  Rewrite [F:ABB3]
  If fstat : [L]UPDATE_STAT = 1 : Endif
Else
  #write
  Raz [F:ABB3]
  Gosub SET_HRESSATT_FIELDS
  Write [F:ABB3]
  If fstat : [L]UPDATE_STAT = 1 : Endif
Endif

If ![L]TRAN_PEND
  If ![L]UPDATE_STAT
    Commit
  Else
    Rollback
  Endif
Endif

Return

$SET_HRESSATT_FIELDS
[F:ABB3]CODBLB        = I_ESSUSRTRK.HRESSATT(NI).ABREV
[F:ABB3]IDENT1        = I_ESSUSRTRK.HRESSATT(NI).IDENT1
[F:ABB3]IDENT2        = I_ESSUSRTRK.HRESSATT(NI).IDENT2
[F:ABB3]IDENT3        = num$(NI)
[F:ABB3]NAMBLB        = I_ESSUSRTRK.HRESSATT(NI).DOCNAM
[F:ABB3]BLOB          = I_ESSUSRTRK.HRESSATT(NI).BLOB
[F:ABB3]TYPBLB        = I_ESSUSRTRK.HRESSATT(NI).TYPBLB
[F:ABB3]CNTTYP        = I_ESSUSRTRK.HRESSATT(NI).CNTTYP
Return

$_UPDATE_MONGO
#Create the file in mongo
Local Char PROPS_COD(20)(1..2)
Local Char PROPS_VAL(100)(1..2)
Local Clbfile RESHEAD(0), DATA(0), TEXT(0)
Local Char ID(50)
Local Char _DOCNAM_DESC(30)
Local Char _FILENAME(50)
Local Char _CONTENT_TYPE(GLONATYP)
Local Blbfile _BYTES(0)
Local Char _VOLUME(10)
Local Integer OK


# Let's create a document now
  Raz PROPS_COD, PROPS_VAL



#Update the document property variables
#PROPS_COD(1)    = "documentDate"
#PROPS_VAL(1)    = format$("D:YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$)
_BYTES          = [F:ABB3]BLOB
_FILENAME       = [F:ABB3]IDENT2+"_"+[F:ABB3]IDENT2+".pdf"
_CONTENT_TYPE   = [F:ABB3]CNTTYP
_DOCNAM_DESC    = [F:ABB3]IDENT2+"_"+[F:ABB3]IDENT2+".pdf"
_VOLUME         = "HRESSATT"

Infbox _FILENAME
Infbox _CONTENT_TYPE
Infbox "DOCNAM"+_DOCNAM_DESC
Infbox _VOLUME

# Let's create the document

  ID=''
  OK = func ASYRSAREA.WRITEALL(_BYTES,_DOCNAM_DESC,
&                                _FILENAME, "application/pdf", PROPS_COD, PROPS_VAL,
&                                ID, _VOLUME, 0, RESHEAD, DATA)

# If OK is equal to 200, ID contains the UUID of the newly created document
Infbox num$(OK)
Infbox num$(ID)


Return

$_READ_MONGO
Local Integer OK
Local Char VID(100)
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Char RECORDSEP(1)
Local Clbfile VARTXT(0)

VID="8811c154-b183-4037-baeb-ffc20230bf37"

 OK=func ASYRSAREA.OPENDOC(VID, "HRESSATT", RECORDSEP, 0, RESHEAD, RESBODY)

OK = func ASYRSAREA.READSEQ(VID, 36, 0, RESHEAD, VARTXT)
 Infbox "HEAD"+num$(RESHEAD)
 Infbox "BODY"+num$(RESBODY)
Infbox num$(OK)
Return


# The corresponding funprog
Funprog GET_DOC(NAME,VOLUME, DOCUMENT)
Value Char NAME()
Value Char VOLUME()
Variable Blbfile DOCUMENT()(1..)

Local Clbfile FILTERS(0)
Local Clbfile RESHEAD(0)
Local Char ID(36)
Local Char EXPECTED_PROPS(20)(1..1)
Local Integer I, OK, K

# Let's list at most the maximum number of document expected + 1
# in order to give the indication that documents weren't read
Local Char VALUES(36)(1..dim(DOCUMENT)+1,1..1)

# First, let's list the documents to get their uuid
# Filters assignment
  FILTERS="fileName eq '"+NAME+"'"
  FILTERS-="and volume.code eq'"+VOLUME+"'"

# Property assignment: we need only the UUID
  EXPECTED_PROPS(1)="$uuid"

# Let's call the list API
  OK=func ASYRSAREA.LIST(FILTERS, EXPECTED_PROPS, 0, RESHEAD, VALUES)

# If OK is not 200, return an error
# RESHEAD is ignored here
  If OK<>200
    End -1 : # An error occured
  Endif

# Let's count the number of documents found
# Count is limited to VALUES dimension: when an empty string is found, no more document is there
  I=find("",VALUES,"")

# If at least a document was found, get them
  If I>1
    For K=1 To min(I-1,dim(DOCUMENT))
      OK = func ASYRSAREA.READALL(VALUES(K), 0, RESHEAD, DOCUMENT(K))
      Break (OK<>200)
    Next K
    If OK<>200
      End -1
    Endif
  Endif
End I-1





$GET_REP_URL
## Let's create a URL that accesses a given BANK detail.
#Local Char BBASEURL(250)
#
#If baseUrl<>""
# BBASEURL = baseUrl
#Else
# BBASEURL = fmet I_ESSUSRTRK.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,I_ESSUSRTRK.AFOLDER,"AWRKSYRA")
#Endif
#
## For syracuse switch to sdata
#BBASEURL = func ASHWJSO.GET_SYRA_URL(BBASEURL)
#
#Infbox BBASEURL


Local Char TABKEY(50)(1..10),TABKEYVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
Local Char REPRESENTATION(30)
Local Integer ASTATUS, FULLURL
Local Clbfile WURL
REPRESENTATION = "ESSUSRTRK"
TABKEY(1)="USR" : TABKEYVAL(1)=GUSER
#TABKEY(2)="BAN" : TABKEYVAL(2)="69490000"

FULLURL=[V]CST_ATRUE
ASTATUS = func ASYRFNC.AGET_SYRAURL(
&         I_ESSUSRTRK.ACTX,FULLURL,REPRESENTATION,[V]CST_AFAC_DETAILS,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)


# Let's imagine that the server address is http://my_server:8124, and the endpoint is MYFOLD
# After the execution of AGET_SYRURL function, WURL contains the following value:
# http://my_server:8124/syracuse-main/html/main.html?url=/sdata/x3/erp/MYFOLD/ABANK('DE~69490000')?representation=ABANK.$details

FULLURL=[V]CST_AFALSE
ASTATUS = func ASYRFNC.AGET_SYRAURL(
&        I_ESSUSRTRK.ACTX,FULLURL,REPRESENTATION,[V]CST_AFAC_DETAILS,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)

Infbox num$(WURL)

# Now, because FULLUSR is false, the result is:
# /sdata/x3/erp/MYFOLD/ABANK('DE~69490000')?representation=ABANK.$details
Return

$ON_NBRATT
Call D_NBRATT(zc)
Return

Subprog D_NBRATT(VALEUR)
Variable Clbfile VALEUR
If varinit([M]NBRATT)=0
 Call INITURL(VALEUR,"HRESSATT","","") From INTRUTILA
Endif
Gosub _AFF
End

$DISPLAY_ATT_ICON
Local Integer READSTAT
READSTAT = func PRHPORATT.FILTER_AOX("DCG",[M:ESDCGV]REFNUM,[M:ESDCGV]DEM,[M:ESDCGV]UID)
If READSTAT = 1
  [M:ESDCGV]ATTICO="175"
Else
  Raz [M:ESDCGV]ATTICO
  Chgfmt [M:ESDCGV]ATTICO With '-K:3'
Endif

Return

$REFRESHLVESUBNNR
Local Integer LP,M,DR
If !clalev([F:HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif
If !clalev([F:DCG]) : Local File DEMCONGE [DCG] : Endif

[M]LVESUBNNR = 0

If [M]CTRNUM<>""
  Local Integer PRAT, LINENUM
  Read [F:DCG]DCG3=[M]REFNUM;[M]UID
  If fstat : Return : Endif
  nolign=0

  For LP=1 To dim([F:DCG]LVESUBTYP)
    Filter [F:HRLSTH] Where COD=[F:DCG]LVESUBTYP(LP-1)
    Read [F:HRLSTH] First
    If [F:DCG]LVESUBTYP(LP-1) <> ""
      nolign +=1
      Call LECTEXTRA([M]DES(LINENUM),"HRLVESUBHEA","DES",GCURLEG,[F:DCG]LVESUBTYP(LP-1)) From ATEXTRA
      [M]WLVESUBTYP(nolign-1) = [F:DCG]LVESUBTYP(LP-1)
      [M]WLVESUBBAL(nolign-1)  = [F:DCG]LVESUBBAL(LP-1)
      If [F:DCG]NBRDAY > 0
        [M]WNBRHOU(nolign-1)  = ([F:DCG]LVESUBBAL(LP-1)/[F:DCG]NBRDAY)*[F:DCG]NBRHOU
      Endif
      If [F:DCG]LVESUBBAL(LP-1) > 0
      PRAT = evalue("[F:DCG]LVESUBRAT(" + num$(LP-1) + ")")
       [M]WLVESUBRAT(nolign-1) = PRAT
        If PRAT > 0 & PRAT <> 99
          [M]LVERATDES(nolign-1) = [F:HRLSTH]LVEPAYDES(PRAT-1)
        Endif
      Endif
    Endif
  Next LP
  [M]LVESUBNNR = nolign
Endif
Return

