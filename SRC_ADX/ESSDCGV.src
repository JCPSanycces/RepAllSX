#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION

Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
Endcase
Return


$OUVRE
Call MANAGE_LOCALISATION("ESSDCGV") From DIVPAYE

$OUVRE_OUT
If clalev([F:DCG])    = 0 : Local File DEMCONGE     [DCG]     : Endif

Return

$DEBUT

Local Char VPARAM1(100)
Local Char VPARAM2(100)

Local Integer MY_STATUS
Local Integer USERTRCK_STAT
Local Char ATT_ID1(GLONID1)
Local Char ATT_ID2(GLONID2)


VPARAM1 = PARAM(1)
VPARAM2 = PARAM(2)

If PARAM(5)="ESSWRKDCG"
  Gosub SET_DCGPARAM
  Gosub UPDATE_FROM_DEMCONGE
Else
  Gosub UPDATE_FROM_DEMCONGEESS
Endif

#Display fields
Affzo [M:ESDCGV]STRDAY
Affzo [M:ESDCGV]ENDDAY

[M:ESDCGV]STRDAYMSG = func ESSDCG.SHIFT_MSG([M:ESDCGV]STRDAY,[M:ESDCGV]STRDAT,[M:ESDCGV]ENDDAT,1)
[M:ESDCGV]ENDDAYMSG = func ESSDCG.SHIFT_MSG([M:ESDCGV]ENDDAY,[M:ESDCGV]STRDAT,[M:ESDCGV]ENDDAT,2)


#Save paramaters for other actions
[M:ESDCGV]DEST      = PARAM(3)
[M:ESDCGV]CHRONO    = PARAM(4)

#Setting GCURLEG
[V]GCURLEG = [M:ESDCGV]LEG

#GLM Leave sub type display
If func AFNC.ACTIV("GLM")>0
  Gosub REFRESHLVESUBNNR
Endif

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSDCGVHIDE
Call SHOW_LEGACTCALLS From WESSDCGVSHOW

#Update User tracking - used for attachment handling in classes
[L]ATT_ID1 = "DCG"+"~"+I_DEMCONGEESS.REFNUM+"~"+num$(I_DEMCONGEESS.DEM)
[L]ATT_ID2 = num$(I_DEMCONGEESS.UID)
[L]USERTRCK_STAT = func ESS_FUNCTIONS.UPDATE_ESSURSTRK(GUSER, "EML",[L]ATT_ID1, [L]ATT_ID2, "","ESSDCG",2,I_DEMCONGEESS.REFNUM,I_DEMCONGEESS.UID,I_DEMCONGEESS.CTRNUM)

#Update attachment icon
Gosub DISPLAY_ATT_ICON

Affzo [M:ESDCGV]1-99
Return

$SET_DEBUT
Return

$SETBOUT

If REPONSE = 1101
  Call VIREBOUT(CHMEN,"1") From GOBJET
Endif

If [M:ESDCGV]STA <> 2 and [M:ESDCGV]STA <> 3
  Call VIREBOUT(CHMEN,"1") From GOBJET
Endif
Return



$UPDATE_FROM_DEMCONGEESS

#Instantiate the DEMCONGE class
Local Instance I_DEMCONGEESS Using C_DEMCONGEESS

#Read the data from the class and transfer to the mask
Local Integer MY_STATUS
If I_DEMCONGEESS <> null Then
  FreeGroup I_DEMCONGEESS
Endif

I_DEMCONGEESS = NewInstance C_DEMCONGEESS AllocGroup null
[L]MY_STATUS = fmet I_DEMCONGEESS.AREAD(VPARAM1,val(VPARAM2))
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Filter [F:DCG]
    Return
  Endif
Endif

#Transfer data
#Load the data from the class to the screen
SetInstance [M:ESDCGV] With I_DEMCONGEESS

#Updating addtional technical fields
[M:ESDCGV]SRNNAM  = I_DEMCONGEESS.TCH_NAMSRN
[M:ESDCGV]LEG     = I_DEMCONGEESS.TCH_LEG

Filter [F:DCG]
Return

$UPDATE_FROM_DEMCONGE

Filter [F:DCG] Where REFNUM = VPARAM1 and UID = val(VPARAM2)
If rowcount([F:DCG])=0
  Filter [F:DCG]
  Return
Endif

#Instantiate the DEMCONGE class
Local Instance I_DEMCONGE Using C_DEMCONGE

#Read the data from the class and transfer to the mask
Local Integer MY_STATUS
If I_DEMCONGE <> null Then
  FreeGroup I_DEMCONGE
Endif

I_DEMCONGE = NewInstance C_DEMCONGE AllocGroup null
[L]MY_STATUS = fmet I_DEMCONGE.AREAD(VPARAM1,val(VPARAM2))
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC_DCG(I_DEMCONGE)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Filter [F:DCG]
    Return
  Endif
Endif

#Transfer data
#Load the data from the class to the screen
SetInstance [M:ESDCGV] With I_DEMCONGE

#Updating addtional technical fields
[M:ESDCGV]SRNNAM  = I_DEMCONGE.TCH_NAMSRN
[M:ESDCGV]LEG     = I_DEMCONGE.TCH_LEG

#Updating the function icons
#[M:ESDCGV]WPEN = "53"
#[M:ESDCGV]WHIS = "54"

Filter [F:DCG]
Return


Subprog RECOVERS_ERROR_IN_CLASSIC(I_DEMCONGEESS)
Variable Instance I_DEMCONGEESS Using C_DEMCONGEESS

Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(I_DEMCONGEESS, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#


# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(I_DEMCONGEESS) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet I_DEMCONGEESS.ADELETERRORALL()
End

SET_DCGPARAM
If clalev([F:AWS1])    = 0 : Local File AWRKHISSUI     [AWS1]     : Endif
Read [AWS1]AWS0 = PARAM(4);PARAM(3)
If !fstat
  VPARAM1 = [F:AWS1]VALCTX1
  VPARAM2 = [F:AWS1]VALCTX4
Endif


Return

Subprog RECOVERS_ERROR_IN_CLASSIC_DCG(I_DEMCONGE)
Variable Instance I_DEMCONGE Using C_DEMCONGE

Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(I_DEMCONGE, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#


# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(I_DEMCONGE) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet I_DEMCONGE.ADELETERRORALL()
End


