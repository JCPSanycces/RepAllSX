#<AdxTL>@(#)0.0.0.0 $Revision$

##################################################################################
## Remplissage des temps issus de la formation
##################################################################################

Subprog MAJ(MATRI,DATPAY,CTR,DATDEB,DATFIN,DETAIL)
Value Char    MATRI, CTR
Value Date    DATPAY, DATDEB, DATFIN
Value Integer DETAIL

Local Char    CRITERE(250)
Local Char    TIMDIF(GLONTPS), TIMFOR(GLONTPS), TIM(GLONTPS)
Local Integer OK, NBPCE, MITPS, CRESES
Local Decimal JOUR(1..2) , HEURE(1..2)
Local Decimal JPASS  : # Nombre de jours déjà saisis dans les temps pour le jour de la formation
Local Decimal HPASS  : # Nombre d'heures déjà saisies dans les temps pour le jour de la formation
Local Decimal NBRDAY : # Nombre de jours de formation (de 0 à 1) dans la date de formation
Local Decimal NBRHOU : # Nombre d'heures de formation dans la date de formation
Local Date    DEBDAT, FINDAT
Local Decimal VALPAR

If clalev([F:INJ])=0  : Local File INSJOU    [INJ]  : Endif
If clalev([F:INS])=0  : Local File INSCRIPT  [INS]  : Endif

# (C) PROSPER 27/07/10 - Prise en compte des infos comptables au contrat
#                        => On en profite pour mettre le contrat en ligne à toutes fins utiles
#                        (genre INISEC From TPSSUB).
#                        On prends le dernier contrat avant la date de fin de la formation
#                        Bug potentiel : formation s'étendant sur plusieurs chrono contrat
#                        (ctrnum identiques, ctrdat différentes) voire sur plusieurs contrat
#                        (mais problème dès l'appel de la fonction avec un CTR unique)
#MIPEA - 2017-02-01- X3-12122- START
If clalev([F:HRCTR]) = 0 : Local File EMPLOCTR    [HRCTR] : Endif
#If clalev([F:CTR]) = 0 : Local File EMPLOCTR    [CTR] : Endif
#MIPEA - 2017-02-01- X3-12122- END
If clalev([F:CPR]) = 0 : Local File EMPLOCTRCPT [CPR] : Endif

#MIPEA - 2017-02-01- X3-12122- START
Filter [HRCTR] Where [F:HRCTR]REFNUM = [L]MATRI & [F:HRCTR]CTRNUM = [L]CTR
&                     & [F:HRCTR]CTRDAT <= [L]DATFIN
Read [HRCTR]CTR0 Last
Filter [F:HRCTR]
#Filter [CTR] Where [F:CTR]REFNUM = [L]MATRI & [F:CTR]CTRNUM = [L]CTR
#&                     & [F:CTR]CTRDAT <= [L]DATFIN
#Read [CTR]CTR0 Last
#Filter [F:CTR]
#MIPEA - 2017-02-01- X3-12122- END

OK = 1
Gosub CONTROLE
If OK=0 : End : Endif

# Critère sur les inscriptions non validées
CRITERE = '[F:INJ]REFNUM=MATRI'
CRITERE -= '& [F:INJ]DAT>=DATDEB'
CRITERE -= '& [F:INJ]DAT<=DATFIN'

Call DEBTRANS From GLOCK
Gosub TR1
End


$CONTROLE
#MIPEA - 2017-02-01- X3-12122- START
If [F:HRPEOD]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6")
 # Période non ouverte à la saisie
 Call ECR_TRACE(mess(58,10709,1),1) From GESECRAN
#If [F:PEO]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6")
# # Période non ouverte à la saisie
# Call ECR_TRACE(mess(58,709,1),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
 OK = 0 : Return
Endif

# Contrôle que le code évènement de la formation DIF existe (DIF pendant temps de travail)
Call PARAM("","EVTDIF",TIMDIF) From ADOVAL
If TIMDIF=""
 # Paramètre non renseigné
 Call ECR_TRACE("EVTDIF : "-mess(171,133,1),1) From GESECRAN
 OK = 0 : Return
Endif

# Contrôle que le code évènement de la formation hors DIF existe
Call PARAM("","EVTFOR",TIMFOR) From ADOVAL
If TIMFOR=""
 # Paramètre non renseigné
 Call ECR_TRACE("EVTFOR : "-mess(171,133,1),1) From GESECRAN
 OK = 0 : Return
Endif

# Contrôle que les codes sont actifs et accessibles
For [TIM]TIM0 Where COD=TIMDIF or COD=TIMFOR
 If [F:TIM]ENAFLG<>2
  # Code temps inactif
#MIPEA - 2017-02-01- X3-12122- START
  Call ECR_TRACE([F:TIM]COD-":"-mess(5,10709,1),1) From GESECRAN
#  Call ECR_TRACE([F:TIM]COD-":"-mess(5,709,1),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
  OK = 0 : Break
 Endif
 If [F:TIM]ACS<>"" & GUSRACS<>2
  Read [ACC]CODACC = GUSER;[F:TIM]ACS
  If fstat or [F:ACC]EXEC<>2
   # Vous n'avez pas accès à ce code
#MIPEA - 2017-02-01- X3-12122- START
   Call ECR_TRACE([F:TIM]COD-":"-mess(61,10709,1),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
   OK = 0 : Break
  Endif
 Endif
Next

If OK=0 : Return : Endif

Return



$TR1
Trbegin [TIP],[INS]
 NBPCE = 0
 Filter [INJ] Where evalue(CRITERE)
 For [INJ]INJ1(2) : # Rupture sur Matricule+session
  Read[INS]INS1=[F:INJ]SES;MATRI
  #58583
  #If !fstat & [F:INS]STA<>3 & [F:INS]FLGTPS=2
  # FQ66191 - MABON 29/10/10 - Ajout d'un état donc décalage pour le clôturé
#  If !fstat & [F:INS]STA<>3 & [F:INS]FLGTPS=2 & [F:INS]CTRNUM=[L]CTR
   # Inscription non cloturée et cochée "à valider en saisie des temps"
#  If !fstat & [F:INS]STA<>4 & [F:INS]FLGTPS=2 & [F:INS]CTRNUM=[L]CTR
  # FQ66191 - MABON 29/10/10 - Le flag FLGTPS n'est plus géré
  #ADNGO - 2017-02-03- X3-12122- START
  #If !fstat & [F:INS]STA<>len(mess(0,459,1)) & [F:INS]CTRNUM=[L]CTR
  If !fstat & [F:INS]STA<>len(mess(0,10459,1)) & [F:INS]CTRNUM=[L]CTR
  #ADNGO - 2017-02-03- X3-12122- END
   If GTRACE<>""
    # xxxx : session yyyy
#MIPEA - 2017-02-01- X3-12122- START
    Call ECR_TRACE([F:ID]REFNUM-[F:ID]NAM-":"-mess(34,10717,1)-[F:INJ]SES-mess(156,10702,1)-CTR,0) From GESECRAN
#    Call ECR_TRACE([F:ID]REFNUM-[F:ID]NAM-":"-mess(34,717,1)-[F:INJ]SES-mess(156,702,1)-CTR,0) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
   Endif
   CRESES = 0
   Raz DEBDAT, FINDAT

   # Parcours des jours de présence
   For [INJ]INJ1
    If [F:INJ]TYPFRT=3
     TIM = TIMDIF
    Else
     TIM = TIMFOR
    Endif
#MIPEA - 2017-02-01- X3-12122- START
    Call LECTURE("HRTIM",TIM,GCURLEG) From CONTOBJ
#    Call LECTURE("TIM",TIM,"") From CONTOBJ
#MIPEA - 2017-02-01- X3-12122- END
    Gosub GENERE
    If GOK=0 : Call FSTA("TIP") From GLOCK : Break 2 : Endif
   Next

   # Intervalle de date avec date de fin = dernier jour de présence de l'inscription
   If DEBDAT<>[0/0/0]
    Gosub CRE_TPS
   Endif

   # Mise à jour du statut de l'inscription
   If CRESES=1
    Readlock [INS]INS1=[F:INJ]SES;[F:INJ]REFNUM
    If !fstat
     [F:INS]STA = 2 : # On passe l'inscription à en-cours
     Rewrite [INS]
     If fstat
      GOK = 0 : Call FSTA("INS") From GLOCK : Break
     Endif
    Else
     GOK = 0 : Call FSTA("INS") From GLOCK : Break
    Endif
   Endif

  Endif
 Next : # CLE1(2)

 Filter [INJ]

 If NBPCE & GPAYE
  #57223 : Add evalue(CRITVEP)& GNUMBUL

  # FQ93131 - 08/10/13 - Pour un même salarié, avec plusieurs périodes d'activité, on peut avoir plusieurs bulletins avec la même date
  # de paie. Dans ce cas, pour affecter les valeurs sur le bon bulletin, il faut ajouter la date du contrat dans le critère de filtre
  Local Date CTRDAT_VEP
#MIPEA - 2017-02-01- X3-12122- START
  If clalev([F:HRCTR])>0 Then CTRDAT_VEP=[F:HRCTR]CTRDAT : Endif
#  If clalev([F:CTR])>0 Then CTRDAT_VEP=[F:CTR]CTRDAT : Endif
#MIPEA - 2017-02-01- X3-12122- END
  # fin FQ91313
  # FQ91472 US2857/58 - SEGAY 02/09/14
  Local Date    DATPAY2
  [L]DATPAY2=[M:DIA]DAT
#MIPEA - 2017-02-01- X3-12122- START
  Call TPSDATPAY(MATRI,CTR,[F:HRCTR]CTRDAT,[F:HRCTR]XITDAT,[M:DIA]DAT,[F:HRCTR]ETRFCY,[L]DATPAY2,[F:HRCTR]PERCOD) From TRTTPS
#  Call TPSDATPAY(MATRI,CTR,[F:CTR]CTRDAT,[F:CTR]XITDAT,[M:DIA]DAT,[F:CTR]ETRFCY,[L]DATPAY2) From TRTTPS
#MIPEA - 2017-02-01- X3-12122- END

  Gosub FILTRE_VEP From TRTTPS
  Filter [VEP] Where EMP=MATRI & PYRDAT=[L]DATPAY2 & CTRNUM=CTR & evalue(CRITVEP)
  Read [VEP]VEP0 Last
  Filter [VEP]
  If !fstat
   Global Char GNUMBUL (GLONVCR)
   GNUMBUL=[F:VEP]BUL
   Call MAJFLGTPS (MATRI,[L]DATPAY2,CTR,1,1,[0/0/0]) From SUBVEP :# Génération auto
   Call MAJFLGTPS (MATRI,[L]DATPAY2,CTR,2,1,[0/0/0]) From SUBVEP :# Synthèse
   Call MAJFLGTPS (MATRI,[L]DATPAY2,CTR,3,1,[0/0/0]) From SUBVEP :# Maj variables
   Call MAJFLGTPS (MATRI,[L]DATPAY2,CTR,4,1,[0/0/0]) From SUBVEP :# Maj analytique
   Kill GNUMBUL
  Endif
 Endif

Commit
Return

$AB_TR1
Rollback
Return



$GENERE
Local Char MESSAGE(255)
# Temps de formation saisi pendant les heures de travail
If ([F:INJ]NBRHOUREA<>0 & [F:TIM]HOUDAC=2) | ([F:INJ]NBRDAYREA<>0 & [F:TIM]DAYDAC=2)
 JPASS = 0
 HPASS = 0
 # Si on relance la mise à jour, on efface les évènements formation
 # Hypothèse : Pas deux formations différentes le même jour

 Delete [TIP] Where REFNUM=MATRI & STRDAT<=[F:INJ]DAT & ENDDAT>=[F:INJ]DAT & TIM=[L]TIM & CTRNUM=CTR

 # Recherche des temps saisis sur le jour

 For [TIP] Where REFNUM=MATRI & STRDAT<=[F:INJ]DAT & ENDDAT>=[F:INJ]DAT & CTRNUM=CTR
  JPASS += [F:TIP]NBRDAY
  HPASS += [F:TIP]NBRHOU
 Next

#MIPEA - 2017-02-01- X3-12122- START
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
# Read [SIT]SIT0=[F:CTR]ETRFCY
#MIPEA - 2017-02-01- X3-12122- END
#MIPEA - 2017-02-01- X3-12122- START
 Call VALORIS([F:INJ]DAT,[F:INJ]DAT,MATRI,TIM,JOUR,HEURE,[F:HRCTR]ETRFCY,CTR) From SUBPLN
# Call VALORIS([F:INJ]DAT,[F:INJ]DAT,MATRI,TIM,JOUR,HEURE,[F:CTR]ETRFCY,CTR) From SUBPLN
#MIPEA - 2017-02-01- X3-12122- END

 If JPASS>=JOUR : # Temps déjà saisis sur ce jour
  # 39198
  If JPASS=0
   If GTRACE<>""
    # Création impossible de l'évènement FOR : Jour non travaillé
    MESSAGE=""
    If clalev([F:INS]) Then MESSAGE=[F:INS]REFNUM : Endif
#MIPEA - 2017-02-01- X3-12122- START
    MESSAGE -= format$("D:"+GFMDAT,[F:INJ]DAT)-mess(62,10717,1)-[L]TIM-":"-mess(153,10709,1)
#    MESSAGE -= format$("D:"+GFMDAT,[F:INJ]DAT)-mess(62,717,1)-[L]TIM-":"-mess(153,709,1)
#MIPEA - 2017-02-01- X3-12122- END
    Call ECR_TRACE(MESSAGE,1) From GESECRAN
   Endif
  Else
  # fin 39198
   If GTRACE<>""
    # Création impossible de l'évènement FOR : Evènement xx xx/xx/xx - xx/xx/xx
    MESSAGE=""
    If clalev([F:INS]) Then MESSAGE=[F:INS]REFNUM : Endif
#MIPEA - 2017-02-01- X3-12122- START
    MESSAGE -= format$("D:"+GFMDAT,[F:INJ]DAT)-mess(62,10717,1)-[L]TIM-":"-mess(110,10709,1)-[F:TIP]TIM
&             -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT)
#    MESSAGE -= format$("D:"+GFMDAT,[F:INJ]DAT)-mess(62,717,1)-[L]TIM-":"-mess(110,709,1)-[F:TIP]TIM
#&             -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT)
#MIPEA - 2017-02-01- X3-12122- END
    Call ECR_TRACE(MESSAGE,1) From GESECRAN
   Endif
  Endif
  # Création des lignes de temps antèrieur à ce jour
  If DEBDAT<>[0/0/0]
   Gosub CRE_TPS
  # 39198
  Else
   CRESES = 1
  # fin 39198
  Endif
  Return
 Else
  If [F:TIM]HOUDAC=2 : # Saisie en heures
   If HEURE=0 : # jour non travaillé où il y a eu de la formation
    If GTRACE<>""
     # Evènement non prévu le
#MIPEA - 2017-02-01- X3-12122- START
     Call ECR_TRACE(mess(68,10709,1)-day$([F:INJ]DAT)-format$("D:"+GFMDAT4,[F:INJ]DAT),1) From GESECRAN
#     Call ECR_TRACE(mess(68,709,1)-day$([F:INJ]DAT)-format$("D:"+GFMDAT4,[F:INJ]DAT),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
    Endif
    NBRDAY = 0
    NBRHOU = [F:INJ]NBRHOUREA
   Else
    NBRDAY = min(JOUR-JPASS,ar2([F:INJ]NBRHOUREA*JOUR/HEURE))
    NBRHOU = [F:INJ]NBRHOUREA
   Endif
  Elsif [F:TIM]DAYDAC=2 : # Saisie en jours
   If JOUR=0
    If GTRACE<>""
     # Evènement non prévu le
#MIPEA - 2017-02-01- X3-12122- START
     Call ECR_TRACE(mess(68,10709,1)-day$([F:INJ]DAT)-format$("D:"+GFMDAT4,[F:INJ]DAT),1) From GESECRAN
#     Call ECR_TRACE(mess(68,709,1)-day$([F:INJ]DAT)-format$("D:"+GFMDAT4,[F:INJ]DAT),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
    Endif
    NBRDAY = [F:INJ]NBRDAYREA
    NBRHOU = 0
   Else
    NBRDAY = min(JOUR-JPASS,[F:INJ]NBRDAYREA)
    NBRHOU = ar2(HEURE*NBRDAY/JOUR)
   Endif
  Endif
 Endif

#MIPEA - 2017-02-01- X3-12122- START
 VALPAR= val(func AFNC.PARAM("HOUDAYLEG",[F:FCY]FCY))
# VALPAR= val(func AFNC.PARAM("HOUDAYLEG",[F:SIT]FCY))
#MIPEA - 2017-02-01- X3-12122- END
 If VALPAR>0 & HPASS+NBRHOU>VALPAR
  If GTRACE<>""
   # Maximum d'heures par jour
#MIPEA - 2017-02-01- X3-12122- START
   Call ECR_TRACE(mess(4,10709,1)-":"-num$(VALPAR),1) From GESECRAN
#   Call ECR_TRACE(mess(4,709,1)-":"-num$(VALPAR),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
  Endif
  # Création des lignes de temps antèrieur à ce jour
  If DEBDAT<>[0/0/0]
   Gosub CRE_TPS
  Endif
  Return
 Endif

# NBRDAY<1 : A cette date, le nombre de jour de formation est <1
# => On crée les temps qui précèdent cette date (lignes groupées)
# => On crée une ligne pour cette date car jour incomplet

 If NBRDAY<1 & DEBDAT<>[0/0/0]
  # Création des lignes de temps antèrieur à ce jour
  Gosub CRE_TPS
 Endif
 If NBRDAY<1
  DEBDAT = [F:INJ]DAT
  FINDAT = [F:INJ]DAT
  MITPS = 1
  Gosub CRE_TPS
  Raz NBRDAY
 Else
  If DEBDAT=[0/0/0]
   DEBDAT = [F:INJ]DAT
   FINDAT = [F:INJ]DAT
  # 59128
  Elsif FINDAT+1<[F:INJ]DAT
   Gosub CRE_TPS
   DEBDAT = [F:INJ]DAT
   FINDAT = [F:INJ]DAT
  # fin 59128
  Else
   FINDAT = [F:INJ]DAT
  Endif
 Endif

Elsif DEBDAT<>[0/0/0]

 Gosub CRE_TPS

Endif

Return


$CRE_TPS
GOK=1
Raz [F:TIP]
[F:TIP]REFNUM = MATRI
[F:TIP]CTRNUM = CTR
# FQ82073 - MABON 31/01/13 - Initialisation de la date de début de période
[F:TIP]CTRDAT = func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,FINDAT,[M:DIA]DATAPLEND,FINDAT,1)
# Fin MABON
[F:TIP]STRDAT = DEBDAT
[F:TIP]ENDDAT = FINDAT
# FQ82073 - MABON 31/01/13 - La date d'application devient une période d'application
#[F:TIP]DATPYR = [M:DIA]DAT
[F:TIP]DATPYR = [M:DIA]DATAPLEND
# Fin MABON
[F:TIP]LIG    = uniqid([F:TIP])
[F:TIP]TIM    = TIM
#MIPEA - 2017-02-01- X3-12122- START
[F:TIP]CMT    = mess(88,10717,1) :# Génération de la formation
#[F:TIP]CMT    = mess(88,717,1) :# Génération de la formation
#MIPEA - 2017-02-01- X3-12122- END
If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT = date$ : Endif
If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR = GUSER : Endif
If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM = time  : Endif
#MIPEA - 2017-02-01- X3-12122- START
[F:TIP]FCY = [F:HRCTR]ETRFCY
#[F:TIP]FCY = [F:CTR]ETRFCY
#MIPEA - 2017-02-01- X3-12122- END
[F:TIP]CPY = [F:FCY]LEGCPY
#MIPEA - 2017-02-01- X3-12122- START
[F:TIP]SRV = [F:HRCTR]ETRSRV
#[F:TIP]SRV = [F:CTR]ETRSRV
#MIPEA - 2017-02-01- X3-12122- END
If MITPS=1
 [F:TIP]NBRDAY = NBRDAY
 [F:TIP]NBRHOU = NBRHOU
Else
 Call VALORIS([F:TIP]STRDAT,[F:TIP]ENDDAT,MATRI,TIM,JOUR,HEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
 If [F:STG]TYPSTG=2 Then
  HEURE(1)=[F:INJ]NBRHOUREA
 Endif
 [F:TIP]NBRDAY = JOUR(1)
 [F:TIP]NBRHOU = HEURE(1)
Endif
Gosub INISEC From TPSSUB

# 64928 Point d'entrée
GPOINT = "MAJTIP" : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif

Raz MITPS
Raz DEBDAT

Write [TIP]
If fstat
 GOK = 0 : Call FSTA("TIP") From GLOCK : Return
Endif
NBPCE +=1
CRESES = 1
If GTRACE<>""
 # xxx : Evènement générée xxx xx/xx/xx - xx/xx/xx
#MIPEA - 2017-02-01- X3-12122- START
 Call ECR_TRACE(MATRI-":"-mess(37,10709,1)-TIM
&    -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT),0) From GESECRAN
# Call ECR_TRACE(MATRI-":"-mess(37,709,1)-TIM
#&    -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT),0) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
Endif
Return

