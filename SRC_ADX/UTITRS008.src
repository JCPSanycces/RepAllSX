#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITRS008   UTI process                                   Module TRS   #
#   Cancellation of Obselete's screen and windows for object TPY         #
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTITRS008(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS008(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTITRS008 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:TPY])=0  : Local File =DOSSIER+".TABPAYTYP"   [TPY] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Local Char OLDMSK1(12), OLDMSK2(12), OLDWIN(12)

For [TPY]
 # Suppression des masques
 OLDMSK1 = "WMPY1"+[F:TPY]PAYTYP
 OLDMSK2 = "WMPY2"+[F:TPY]PAYTYP
 Call TR_DELMSK(OLDMSK1,DOSSIER) From MSKDIV
 Call TR_DELMSK(OLDMSK2,DOSSIER) From MSKDIV
 # Suppression des fenêtres
 OLDWIN = "WOPY"+[F:TPY]PAYTYP
 Call TR_DELWIN(OLDWIN,DOSSIER) From MSKDIV
 WCOMPTEUR+=1
Next

Close Local File [TPY]
Call ECR_TRACE("UTITRS008 : "+num$(WCOMPTEUR)+" Objects(settlement) records riffled",0) From GESECRAN
End


########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS008 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS008(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS008(APPLI)
End
