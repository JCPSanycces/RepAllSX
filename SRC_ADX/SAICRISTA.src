#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"DCRISTA","SAICRISTA","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"   : Gosub DEBUT
 When "OK"      : Gosub OK
 When Default
Endcase
Return

$DEBUT
[M:DIA] = [M:SAP]
Affzo
Return

$OK
[M:SAP] = [M:DIA]
Return


#####################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M]COD<>""
 Call LECTURE("PS2",[M]COD,"") From CONTOBJ
 If [F:PS2]UPDLEV<2 : mkstat = 1 : End : Endif
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If [F:PS2]UPDLEV=2
 If VALEUR=""
  GMESSAGE = mess(10,123,1)+"\"+mess(46,104,1)-":"-mess([F:PS2]UPDLEV,45,1) : # Zone obligatoire/Niveau x
  mkstat = 1 : End
 Else
  Call CONTALLFCY(VALEUR) From EXEFNC
 Endif
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]COD<>""
 Call LECTURE("PS2",[M]COD,"") From CONTOBJ
 If [F:PS2]UPDLEV<3 : mkstat = 1 : End : Endif
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CPY=""
 GMESSAGE = mess(21,104,1) : # Société ou site inexistant
 mkstat = 2 : End
Endif
End

Subprog D_DATDEB(VALEUR)
Variable Date     VALEUR
If GDATEDEB<>[0/0/0]
 VALEUR = GDATEDEB
Else
 VALEUR = gdat$(1,1,year(datesyst))
Endif
End

Subprog D_DATFIN(VALEUR)
Variable Date     VALEUR
If GDATEFIN<>[0/0/0]
 VALEUR = GDATEFIN
Else
 VALEUR = gdat$(31,12,year(datesyst))
Endif
End

Subprog C_DATFIN(VALEUR)
Value Date DATFIN
End

