#<AdxTL>@(#)8.0.0.0 $Revision$
$LEC_UPD
Call OUVRE_TRACE("test classe delta") From LECFIC
Local Char WCHAINE(110)
For I=1 To maxtab(UPD)
 If UPD(I)<>null
  WCHAINE = "col="+UPD(I).COL-"index="+num$(UPD(I).IND)-"pro="+UPD(I).PRO
  If UPD(I).CHR<>null
   WCHAINE -= "value="+func ASYRSUB.AGETCHR(UPD(I).CHR)
  Endif
  WCHAINE -= "uuid="+num$(UPD(I).UID)
  If left$(num$(UPD(I).UIDPAR),4)<>"0000"
   WCHAINE -= "uuid parent="+num$(UPD(I).UIDPAR)
  Endif
  Call ECR_TRACE(WCHAINE,-1) From GESECRAN
  For J=1 To maxtab(UPD(I).ATT)
   Call ECR_TRACE("att="+UPD(I).ATT(J).COD+"/"+UPD(I).ATT(J).ATT,0) From GESECRAN
  Next J
  For J=1 To maxtab(UPD(I).ERR)
   Call ECR_TRACE("err="+num$(UPD(I).ERR(J).STA)+"/"+UPD(I).ERR(J).MES+"/"+num$(UPD(I).ERR(J).NUM),0) From GESECRAN
  Next J
 Endif
Next I
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

#-------------------------------------------------------------------#
# Set DELTA classe with all instances of uuid's collection
#-------------------------------------------------------------------#

Subprog COLLECTION_UUID(REP,WREP,UPD,COLLECTION,UID)
Variable Instance  REP      Using C_AREPENT
Variable Instance  WREP     Using OBJECT
Variable Instance  UPD(1..) Using C_ADELTA
Value    Char      COLLECTION
Value    Uuident   UID

Local Integer I , J , K
Local Char    INS(250) , INSCOL(250) , NAMCOL(30)
Local Uuident UIF

# Name of collection instance
If COLLECTION<>""
 For I=1 To maxtab(REP.COL)
  If ctrans(REP.COL(I).GRI,".","")=COLLECTION
   NAMCOL = COLLECTION
   Break
  Endif
 Next I
Endif

Call FIND_UUID(WREP,UID,INS)
If INS=""
 End
Endif

UIF = NullUuid
If INS=""
 INSCOL = "WREP"
Elsif !instr(1,INS,".")
 If COLLECTION=""
  INSCOL = "WREP"
 Elsif NAMCOL<>""
  INSCOL = "WREP."+INS
 Else : # Variables
  If find(COLLECTION,REP.COL(1..maxtab(REP.COL)).GRI)
   INSCOL = "WREP"
  Else
   INSCOL = "WREP."+INS
  Endif
 Endif
Else
 INSCOL = "WREP."+INS
 UIF = func UUID_PARENT(WREP,INSCOL)
 If COLLECTION=""
  NAMCOL = func COLLECTION_OF_INSTANCE(REP,INSCOL)
 Endif
Endif

# Create delta instance parent if not found in delta class
Call UPDATE_PARENT(WREP,REP,UPD,UIF) From ASYRDELSRV

Call COLLECTION_INS(REP,WREP,UPD,INSCOL,NAMCOL,UIF,0) :#SAM 117778

End

#---------------------------------------#
Funprog UUID_PARENT(WREP,INS)
Variable Instance WREP Using OBJECT
Value Char INS
Local Uuident UIF
Local Integer I
Local Char    INSPAR(250)
INSPAR =""
For I=len(INS) To 1 Step -1
 If mid$(INS,I,1)="."
  INSPAR = left$(INS,I-1)
  If evalue("dim("+INSPAR+".AUUID)")>0
   UIF = evalue(INSPAR+".AUUID")
   Break
  Endif
 Endif
Next I
If INSPAR=""
 UIF = NullUuid
Endif
End UIF

#------------------------------------------------------------------------#
Subprog COLLECTION_INS(REP,WREP,UPD,REF,COL,UIF,INDPAR) :#SAM 117778
Variable Instance  REP      Using C_AREPENT
Variable Instance  WREP     Using OBJECT
Variable Instance  UPD(1..) Using C_ADELTA
Value    Char      REF , COL
Value    Uuident   UIF
Value Integer INDPAR :#SAM 117778

Local Integer I , J , K , P , F , A , M , N , DEBUT
Local Char    INS(250) , INM(250) , PRO(250) , WINS(250)
Local Char    NAM(30) , DES(30) , COLSYR(50)
Local Uuident UID
Local Integer IND , TYP , NBG
Local Clbfile CLOB
Local Char    VRA(250) , VRB(250) , VRC(250) , VRK(80)
Local Char    WVALUE(250) , WCHAINE(250)
Local Integer VRO , VRI
Local Uuident VRU , VRF , UIP , UII
Local Integer NBC , GRN , PRE , ONE

Gosub SYSTEM_INSTANCES

If right$(REF,len(REF))=")"
 INS = REF
 Gosub COLLECTION_UPD
Else
 M = evalue('maxtab('+REF+')')
 If M>1
  For N=1 To M
   INS = REF+'('+num$(N)+')'
   Gosub COLLECTION_UPD
  Next N
 Else
  INS = REF
  Gosub COLLECTION_UPD
 Endif
Endif
End

#------------------------------#
$COLLECTION_UPD
If evalue(INS)=null or find(evalue(INS+".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL)
 Return
Endif

Call COLSYR(REP,INS,COLSYR,ONE) From ASYRDELSRV

# Special properties
If INS="WREP"
 WINS = "WREP."+REP.ICL
Else
 WINS = INS
Endif
If evalue("dim("+WINS+".AUUID)")>0
 UID = evalue(WINS+".AUUID")
Else
 UID = getUuid
Endif
#{SAM 117778
If ONE :# Use IND set for the parent: UPD is sorted against uuids and indexes
 IND = INDPAR
 #SAM 117778}
Elsif evalue("dim("+WINS+".AORDER)")>0
 IND = evalue(WINS+".AORDER")
Else
 IND = 0
Endif

UIP = UIF
UII = UID
If INS<>"WREP"
 Call UUID_JSON(REP,WREP,WINS,UIP,UII)
Endif

# First properties not reference & not in collection
For F=1 To maxtab(REP.PRO)
 If REP.PRO(F)<>null & ctrans(REP.PRO(F).GRI,".","")=COL
  If REP.PRO(F).EDT=2 & REP.PRO(F).PLK<>2
   Gosub PRO
  Endif
 Endif
Next P

# Second others properties & variables collection
For F=1 To maxtab(REP.PRO)
 If REP.PRO(F)<>null & ctrans(REP.PRO(F).GRI,".","")=COL
  If REP.PRO(F).EDT=2 & REP.PRO(F).PLK=2
   Gosub REF
  Endif
 Endif
Next P

# Third others instances collections
While 1=1
 DEBUT = 0
 For P=1 To evalue(INS+'.Objectnbs')
  PRO = evalue(INS+'.Objectvar('+num$(P)+')')
  K = evalue('type('+INS+'.'+PRO+')')
  If K=524 & !find(PRO,NAMSYS(1..NBRSYS))
   If INS="WREP" & PRO=REP.ICL
    DEBUT = 1
   Else
    GRP = func COLLECTION_OF_INSTANCE(REP,INS+"."+PRO)
    If GRP<>""
     K = 0
     For I=1 To maxtab(REP.COL)
      If ctrans(REP.COL(I).GRI,".","")=GRP
       K = 1 : Break
      Endif
     Next I
     If K
      Call COLLECTION_INS(REP,WREP,UPD,INS+'.'+PRO,GRP,UID,IND) :#SAM 117778
     Endif
    Endif
   Endif
  Endif
 Next P
 If DEBUT
  INS += "."+REP.ICL
 Else
  Break
 Endif
Wend

Return

#-----------------------------------------------------#
# Find uuid father & current in case collection 1,1
#-----------------------------------------------------#

Subprog UUID_JSON(REP,WREP,INS,UIP,UII)
Variable Instance REP  Using C_AREPENT
Variable Instance WREP Using OBJECT
Value    Char     INS
Variable Uuident  UIP , UII
Local Char    INSPAR(250)
Local Integer I
INSPAR = INS
Call SEARCH_INSTANCE_NO_ONE(REP,INSPAR)
If find(INSPAR,"WREP."+REP.ICL,"WREP")
 UII = evalue("WREP."+REP.ICL+".AUUID")
 UIP = NullUuid
Else
 UII = evalue(INSPAR+".AUUID")
 For I=len(INSPAR) To 1 Step -1
  If mid$(INSPAR,I,1)="."
   INSPAR = left$(INSPAR,I-1)
   Break
  Endif
 Next I
 If find(INSPAR,"WREP."+REP.ICL,"WREP")
  UIP = evalue("WREP."+REP.ICL+".AUUID")
 Else
  Call SEARCH_INSTANCE_NO_ONE(REP,INSPAR)
  UIP = evalue(INSPAR+".AUUID")
 Endif
Endif
End

Subprog SEARCH_INSTANCE_NO_ONE(REP,INSPAR)
Variable Instance REP  Using C_AREPENT
Variable Char     INSPAR
Local Char    COLSYR(250)
Local Integer I , ONE
While INSPAR<>"" & !find(INSPAR,"WREP."+REP.ICL,"WREP")
 Call COLSYR(REP,INSPAR,COLSYR,ONE) From ASYRDELSRV
 If !ONE : Break : Endif
 For I=len(INSPAR) To 1 Step -1
  If mid$(INSPAR,I,1)="."
   INSPAR = left$(INSPAR,I-1)
   Break
  Endif
 Next I
Wend
End

#---------------------------------------------#
# Find Name collection from instance
#---------------------------------------------#

Funprog COLLECTION_OF_INSTANCE(REP,INS)
Variable Instance  REP  Using C_AREPENT
Value Char INS
Local Char    ICL(250) , COL(250)
Local Integer I , J
ICL = INS
If ICL="WREP" or ICL="WREP."+REP.ICL
 ICL = ""
Elsif left$(ICL,4)="WREP"
 ICL = right$(ICL,6)
Endif
I = instr(1,ICL,"(")
While I
 J = instr(I,ICL,")")
 ICL = left$(ICL,I-1)+right$(ICL,J+1)
 I = instr(1,ICL,"(")
Wend
COL = ctrans(ICL,".","")
End COL

#---------------------#
$PRO
VRI = F    : # Indice in dictionary
TYP = REP.PRO(VRI).TYP
VRK = COLSYR
VRO = IND
VRU = UII
VRF = UIP
VRB = func ASYRDATDET.PATH_PROPERTY(INS,REP.PRO(F).PTH) : # Name of property in class
VRA = REP.PRO(VRI).PRO
VRC = VRA  : # Name of property in json
Gosub CODPRO_VALUE
Call MAJ_FIELD(UPD,1,0,VRF,VRU,VRO,VRK,VRC,TYP,CLOB) From ASYRDELSYS
Gosub ATTRIBUTE
Return

#---------------------#
$REF
VRI = F
TYP = REP.PRO(VRI).TYP
VRK = COLSYR
VRO = IND
VRU = UII
VRF = UIP
VRB = func ASYRDATDET.PATH_PROPERTY(INS,REP.PRO(VRI).PTH)
VRA = REP.PRO(VRI).PRO
VRC = VRA
Gosub CODPRO_VALUE
Call MAJ_FIELD(UPD,2,0,VRF,VRU,VRO,VRK,VRC,TYP,CLOB) From ASYRDELSYS
Gosub ATTRIBUTE
Return

#--------------------------#
$ATTRIBUTE
Local Instance INSATT Using OBJECT
Local Char WCODE(20)
Local  Instance PATTRIBUTES Using C_ATTRIBUTES
Local Integer AAM,AAI,ATTTYP
Local Char ATT(250)
Local Char LISTATT(20)(1..)
Local Instance DELTA Using C_ADELTA : DELTA=null
WCHAINE = func ASYRDATDET.INSTANCE_CLASS(REP.PRO(VRI).TPC,INS,REP.PRO(VRI).PTH)
[L]INSATT = evalue(WCHAINE)

If func ASYRSUB.AGETPROATTRIBUTES([L]INSATT,func ASYRDATDET.PROPERTY_CLASS(REP.PRO(VRI).PTH),PATTRIBUTES)
 AAM = func ASYRSUB.AGETLISTATT(LISTATT)
 For AAI=1 To AAM
  WCODE = LISTATT(AAI)
  If func ASYRSUB.AGETPROATTRIBUTE(PATTRIBUTES,WCODE,ATT,ATTTYP)
   If DELTA = null
    Call ADD_DELTA(UPD,2,0,VRF,VRU,VRO,VRK,VRC,DELTA) From ASYRDELSYS
   Endif
   If DELTA <> null
    Call SETATTRIBUTE(DELTA,WCODE,ATT) From ASYRDELSYS
   Endif
  Endif
 Next AAI
Endif
Return

#--------------------------------------------------------------#
# Search path instance of representation by uuid
#--------------------------------------------------------------#

Subprog FIND_UUID(WREP,UID,INS)
Variable Instance WREP Using OBJECT : # Instance représention begin
Value Uuident UID : # Where is this uuid
Variable Char INS : # Path instance found
Local Char ENF(250)
Call SEARCH_INS(WREP,ENF,UID,INS)
End

#---------------------------------------#
Subprog SEARCH_INS(WREP,ENF,UID,REF)
Variable Instance WREP Using OBJECT
Value    Char ENF
Value Uuident UID
Variable Char REF
Local Integer I , J , K , P , E
Local Char    INS(250) , INM(250) , PRO(250)
Local Char    NAM(30) , DES(30)
Gosub SYSTEM_INSTANCES
If ENF<>""
 INM = ENF
Else
 INM = "WREP"
Endif
J = evalue('maxtab('+INM+')')
If J>1
 For I=1 To J
  INS = INM+'('+num$(I)+')'
  Gosub INS_UID
 Next I
Else
 INS = INM
 Gosub INS_UID
Endif
If left$(REF,4)="WREP"
 REF = right$(REF,6)
Endif
End

#------------------------------#
$INS_UID
If evalue(INS)=null
 Return
Endif
For P=1 To evalue(INS+'.Objectnbs')
 PRO = evalue(INS+'.Objectvar('+num$(P)+')')
 K = evalue('type('+INS+'.'+PRO+')')
 If K=524 & !find(PRO,NAMSYS(1..NBRSYS))
  Call SEARCH_INS(WREP,INS+'.'+PRO,UID,REF)
 Elsif PRO="AUUID"
  If evalue(INS+'.AUUID')=UID
   REF = INS
  Endif
 Endif
 If REF<>"" : Break : Endif
Next P
Return

#---------------------------------------------------#
# Find name of instance by uuid property
#---------------------------------------------------#

Subprog FIND_UUID_INSTANCE(WREP,UUID,INS,NAMINS)
Variable Instance WREP Using OBJECT
Value Uuident UUID
Value    Char INS
Variable Char NAMINS
If INS=""
 INS = "WREP"
Elsif UUID=NullUuid
 INS = "WREP"
Endif
NAMINS = ""
Gosub SYSTEM_INSTANCES
Call LOOP_FIND_UUID(WREP,UUID,INS,NAMSYS,NBRSYS,NAMINS)
End

#---------------------------------------------------------#
Subprog LOOP_FIND_UUID(WREP,UUID,INS,NAMSYS,NBRSYS,NAMINS)
Variable Instance WREP Using OBJECT
Value Uuident UUID
Value Char    INS
Value Char    NAMSYS()(1..)
Value Integer NBRSYS
Variable Char NAMINS
Local Integer M , N
M = evalue('maxtab('+INS+')')
If M>1
 For N=1 To M
  Call INSTANCE_FIND_UUID(WREP,UUID,INS+'('+num$(N)+')',NAMSYS,NBRSYS,NAMINS)
  If NAMINS<>"" : Break : Endif
 Next N
Else
 Call INSTANCE_FIND_UUID(WREP,UUID,INS,NAMSYS,NBRSYS,NAMINS)
Endif
End

#------------------------------------------------------------------#
Subprog INSTANCE_FIND_UUID(WREP,UUID,INS,NAMSYS,NBRSYS,NAMINS)
Variable Instance WREP Using OBJECT
Value Uuident UUID
Value Char    INS
Value Char    NAMSYS()(1..)
Value Integer NBRSYS
Variable Char NAMINS
Local Char    PRO(30)
Local Integer P , K
If NAMINS<>"" or evalue(INS)=null
 End
Endif
If evalue("dim("+INS+".AUUID)")>0 & evalue(INS+".AUUID")=[L]UUID
 NAMINS = INS
Else
 For P=1 To evalue(INS+'.Objectnbs')
  PRO = evalue(INS+'.Objectvar('+num$(P)+')')
  If !find(PRO,NAMSYS(1..NBRSYS))
   K = evalue('type('+INS+'.'+PRO+')')
   If K=524
    Call LOOP_FIND_UUID(WREP,UUID,INS+'.'+PRO,NAMSYS,NBRSYS,NAMINS)
    If NAMINS<>"" : Break : Endif
   Endif
  Endif
 Next P
Endif
End

#------------------------------#
$SYSTEM_INSTANCES
Local Char    NAMSYS(30)(1..17)
Local Integer NBRSYS
NBRSYS = 1  : NAMSYS(NBRSYS) = "AERROR"
NBRSYS += 1 : NAMSYS(NBRSYS) = "ATT"
NBRSYS += 1 : NAMSYS(NBRSYS) = "LNK"
NBRSYS += 1 : NAMSYS(NBRSYS) = "ATX"
NBRSYS += 1 : NAMSYS(NBRSYS) = "AXX"
NBRSYS += 1 : NAMSYS(NBRSYS) = "AINF"
NBRSYS += 1 : NAMSYS(NBRSYS) = "AREPLNK"
NBRSYS += 1 : NAMSYS(NBRSYS) = "APARENT"
NBRSYS += 1 : NAMSYS(NBRSYS) = "ACTX"
NBRSYS += 1 : NAMSYS(NBRSYS) = "_APARAMURL"
NBRSYS += 1 : NAMSYS(NBRSYS) = "AATTRIBUTES"
NBRSYS += 1 : NAMSYS(NBRSYS) = "_ASTADETLNK"

# Properties
NBRSYS += 1 : NAMSYS(NBRSYS) = "_AFCRIGHT"
NBRSYS += 1 : NAMSYS(NBRSYS) = "ASTALIN"
NBRSYS += 1 : NAMSYS(NBRSYS) = "AORDER"
NBRSYS += 1 : NAMSYS(NBRSYS) = "AKEYS"
NBRSYS += 1 : NAMSYS(NBRSYS) = "AUUID"
Return

#---------------------------#
# Value typed Syracuse
#---------------------------#

$CODPRO_VALUE
Local Char WCNT(100)
Onerrgo ERROR_VALUE
Case TYP
 When 8,9 : # Clob
  WVALUE = '{}' : #WVALUE = '{ "$contentType":"text/plain" }'
  WCNT=evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(VRB)+'.AGETATTRIBUTE("'+func ASYRDATDET.FINAL_INSTANCE(VRB)+'","$isLobFound")')
  #106100
  #If WCNT="false" | evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(VRB)+'.AGETATTRIBUTE("'+func ASYRDATDET.FINAL_INSTANCE(VRB)+'","$isHidden")')="true"
  If WCNT="false"
   WVALUE = func ASYRSUB.SYR_NULL
  Else
   WCNT=evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(VRB)+'.AGETATTRIBUTE("'+func ASYRDATDET.FINAL_INSTANCE(VRB)+'","$contentType")')
   If WCNT<>"" : WVALUE = '{ "$contentType":"'+WCNT+'" }' : Endif
  Endif
 When 25 : # Textes superviseur
  WVALUE = evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(VRB)+'.AGETTEXT("'+func ASYRDATDET.FINAL_INSTANCE(VRB)+'")')
 When Default
  WVALUE = num$(evalue(VRB))
Endcase
Onerrgo
CLOB = WVALUE
Return

#---------------------------#
$ERROR_VALUE
WVALUE = VRB+'<error'-errmes$(errn)+'>'
Resume

#**
#* BUILD_CLAIDX :
#* Builds the REP classes index CLAIDX
#*
#* @param REP
#* @param FATHER
#* @param INSNAME
#*!
Subprog BUILD_CLAIDX(REP,FATHER,INSNAME)
Variable Instance REP  Using C_AREPENT
Value Instance FATHER Using C_ASYRJSO
Value Char INSNAME

Local Integer AC
Local Char NAME(250)

If FATHER = null
 REP.CLAIDX(maxtab(REP.CLAIDX)+1)    = NewInstance C_ASYRJSO AllocGroup REP
 REP.CLAIDX(maxtab(REP.CLAIDX)).PRO = INSNAME
 REP.CLAIDX(maxtab(REP.CLAIDX)).TYP = 1

 REP.CLAIDX(maxtab(REP.CLAIDX)+1)    = NewInstance C_ASYRJSO AllocGroup REP
 INSNAME += "." + REP.ICL
 REP.CLAIDX(maxtab(REP.CLAIDX)).PRO = INSNAME
 REP.CLAIDX(maxtab(REP.CLAIDX)).TYP = 1
 REP.CLAIDX(maxtab(REP.CLAIDX)-1).SUB = REP.CLAIDX(maxtab(REP.CLAIDX))
 Call  BUILD_CLAIDX(REP,REP.CLAIDX(maxtab(REP.CLAIDX)),INSNAME)
Else
 For AC = 1 To maxtab(REP.COL)
  NAME = REP.CLAIDX(1).PRO + '.' + REP.COL(AC).ICL
  If instr(1,NAME,INSNAME+".") = 1 & instr(len(INSNAME)+2,NAME,'.')  = 0
   REP.CLAIDX(maxtab(REP.CLAIDX)+1)    = NewInstance C_ASYRJSO AllocGroup REP
   REP.CLAIDX(maxtab(REP.CLAIDX)).PRO  = NAME
   REP.CLAIDX(maxtab(REP.CLAIDX)).TYP = 2
   If FATHER.SUB = null
    FATHER.SUB = REP.CLAIDX(maxtab(REP.CLAIDX))
   Else
    REP.CLAIDX(maxtab(REP.CLAIDX)).NEX = FATHER.SUB
    FATHER.SUB = REP.CLAIDX(maxtab(REP.CLAIDX))
   Endif
   Call  BUILD_CLAIDX(REP,REP.CLAIDX(maxtab(REP.CLAIDX)),REP.CLAIDX(maxtab(REP.CLAIDX)).PRO)
  Endif
 Next AC
Endif
End

#**
#* FIND_UUID_INSTANCE_EX
#* Looks for an instance in the REPRESENTATION tree
#*
#* @param WREP
#* @param REP
#* @param FATHER
#* @param UUID
#* @param INSPATH
#* @param WINS
#*!
Funprog FIND_UUID_INSTANCE_EX(WREP,REP,_FATHER,UUID,INSPATH,WINS)
Variable Instance  WREP     Using OBJECT
Variable Instance REP  Using C_AREPENT
Value    Instance _FATHER Using C_ASYRJSO
Variable Uuident UUID
Value     Char INSPATH
Variable Char WINS

Local Integer FOUND : FOUND=0
Local Instance CHILD Using C_ASYRJSO
Local Integer AC
Local Char LWINS(250)

Local Instance FATHER Using C_ASYRJSO

If _FATHER = null
 Raz WINS
 If REP.CLAIDX(1) = null
  Call BUILD_CLAIDX(REP,null,INSPATH)
 Endif
 FATHER = REP.CLAIDX(1)
Else
 FATHER = _FATHER
Endif

If !len(WINS)
 WINS = REP.CLAIDX(1).PRO
Endif

If FATHER.TYP = 1
  If  evalue(WINS+".AUUID")=[L]UUID
   End 1
  Elsif FATHER.SUB <> null
   # The object has children :
   CHILD = FATHER.SUB
   While CHILD <> null
    LWINS = WINS + right$(CHILD.PRO,len(FATHER.PRO)+1)
    FOUND = func FIND_UUID_INSTANCE_EX(WREP,REP,CHILD,UUID,INSPATH,LWINS)
    If FOUND
     WINS =LWINS
     End 1
    Endif
    CHILD = CHILD.NEX
   Wend
 Endif
Elsif FATHER.TYP = 2
 FOUND =  evalue("find(UUID,"+WINS+"(1..maxtab("+WINS+")).AUUID)")
 If FOUND
  WINS = WINS + '(' + num$(FOUND) + ')'
  End 1
 Elsif FATHER.SUB <> null
    # The object has children :
   CHILD = FATHER.SUB
   While CHILD <> null
    For AC = 1 To evalue("maxtab("+WINS+")")
     LWINS = WINS + "(" + num$(AC) + ')' + right$(CHILD.PRO,len(FATHER.PRO)+1)
     FOUND = func FIND_UUID_INSTANCE_EX(WREP,REP,CHILD,UUID,INSPATH,LWINS)
     If FOUND
      WINS = LWINS
      End 1
     Endif
    Next AC
    CHILD = CHILD.NEX
   Wend
 Endif
Endif
If !FOUND & _FATHER = null
 Raz WINS
Endif
End FOUND

#**
#* FIND_UUID_INSTANCE_EX
#*
#* @param WREP
#* @param REP
#* @param _FATHER
#* @param UUID
#* @param INSPATH
#* @param WINS
#* @param IDXUUID
#* @param IDXINS
#* @param IDXCOUNT
#*!
Funprog FIND_UUID_INSTANCE_EX2(WREP,REP,_FATHER,UUID,INSPATH,WINS,IDXUUID,IDXINS,IDXCOUNT)
Variable Instance  WREP     Using OBJECT
Variable Instance REP  Using C_AREPENT
Value    Instance _FATHER Using C_ASYRJSO
Variable Uuident UUID
Value     Char INSPATH
Variable Char WINS
Variable Char IDXUUID()(1..)
Variable Char IDXINS()(1..)
Variable Integer IDXCOUNT

Local Integer FOUND : FOUND= 0
Local Integer AF

If UUID = NullUuid
 WINS= INSPATH
 End 1
Endif

AF =  find(num$(UUID),IDXUUID)
If AF
 #check that the object still exists :
 If evalue("dim("+IDXINS(AF)+")>0") & UUID = evalue(IDXINS(AF)+".AUUID")
  WINS = IDXINS(AF)
  FOUND = 1
 Else
  IDXINS(AF) = num$(AF)
  IDXINS (AF) = num$(AF)
  FOUND = 0
 Endif
Endif
If !FOUND
 Call FIND_UUID_INSTANCE_EX(WREP,REP,_FATHER,UUID,INSPATH,WINS) From ASYRUID
 If len(WINS)
  IDXCOUNT += 1
  IDXUUID(IDXCOUNT) = num$(UUID)
  IDXINS(IDXCOUNT)  = WINS
 Endif
Endif
End FOUND
