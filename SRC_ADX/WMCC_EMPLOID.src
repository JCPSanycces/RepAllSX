############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLOID,ASTATUS)
Variable Instance EMPLOID Using C_EMPLOID
Variable Integer ASTATUS

If EMPLOID = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOID

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLOID

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLOID,ASTATUS)
Variable Instance EMPLOID Using C_EMPLOID
Variable Integer ASTATUS

If EMPLOID = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOID
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLOID
Else
 Gosub AINSERT_EMPLOID
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLOID.freeSnapshot
EMPLOID.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOID._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOID._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOID._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLOID.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOID.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOID.PASDET)
 If EMPLOID.PASDET([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PASDET([L]A_I).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOID.PERCNT)
 If EMPLOID.PERCNT([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PERCNT([L]A_I).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
A_N2=1
If EMPLOID.EMPLOIDSA(A_N2) <> null
& and !find(EMPLOID.EMPLOIDSA(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._AINSERT_CONTROL_BEFORE)
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).EMPADR)
  If EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I).ACTION("AINSERT_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PASDET)
  If EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I).ACTION("AINSERT_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PERCNT)
  If EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I).ACTION("AINSERT_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
A_N2=1
If EMPLOID.EMPLOIDUKI(A_N2) <> null
& and !find(EMPLOID.EMPLOIDUKI(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLORIB) : # EMPLORIB -- 4
 If EMPLOID.EMPLORIB(A_N2) <> null
& and !find(EMPLOID.EMPLORIB(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._AINSERT_CONTROL_BEFORE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOCHD) : # EMPLOCHD -- 5
 If EMPLOID.EMPLOCHD(A_N2) <> null
& and !find(EMPLOID.EMPLOCHD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._AINSERT_CONTROL_BEFORE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOJNT) : # EMPLOJNT -- 6
 If EMPLOID.EMPLOJNT(A_N2) <> null
& and !find(EMPLOID.EMPLOJNT(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._AINSERT_CONTROL_BEFORE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOEXM) : # EMPLOEXM -- 7
 If EMPLOID.EMPLOEXM(A_N2) <> null
& and !find(EMPLOID.EMPLOEXM(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._AINSERT_CONTROL_BEFORE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOTRY) : # EMPLOTRY -- 8
 If EMPLOID.EMPLOTRY(A_N2) <> null
& and !find(EMPLOID.EMPLOTRY(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._AINSERT_CONTROL_BEFORE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER
A_N2=1
If EMPLOID.EMPLOIDSA(A_N2) <> null
& and !find(EMPLOID.EMPLOIDSA(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._AINSERT_CONTROL_AFTER)
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).EMPADR)
  If EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I).ACTION("AINSERT_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PASDET)
  If EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I).ACTION("AINSERT_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PERCNT)
  If EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I).ACTION("AINSERT_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
A_N2=1
If EMPLOID.EMPLOIDUKI(A_N2) <> null
& and !find(EMPLOID.EMPLOIDUKI(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLORIB) : # EMPLORIB -- 4
 If EMPLOID.EMPLORIB(A_N2) <> null
& and !find(EMPLOID.EMPLORIB(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._AINSERT_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOCHD) : # EMPLOCHD -- 5
 If EMPLOID.EMPLOCHD(A_N2) <> null
& and !find(EMPLOID.EMPLOCHD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._AINSERT_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOJNT) : # EMPLOJNT -- 6
 If EMPLOID.EMPLOJNT(A_N2) <> null
& and !find(EMPLOID.EMPLOJNT(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._AINSERT_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOEXM) : # EMPLOEXM -- 7
 If EMPLOID.EMPLOEXM(A_N2) <> null
& and !find(EMPLOID.EMPLOEXM(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._AINSERT_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOTRY) : # EMPLOTRY -- 8
 If EMPLOID.EMPLOTRY(A_N2) <> null
& and !find(EMPLOID.EMPLOTRY(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._AINSERT_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_I=1 To maxtab(EMPLOID.PASDET)
 If EMPLOID.PASDET([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PASDET([L]A_I).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOID.PERCNT)
 If EMPLOID.PERCNT([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PERCNT([L]A_I).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLOID
Trbegin [F:ID]
 Gosub AINSERT_EMPLOID
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLOID
Raz [F:ID]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOID._MAJSQL_EMPLOID(EMPLOID))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]A_TYPMAJ=[V]CST_ANEW

#-----------------------------------------------------#
A_N2=1
If EMPLOID.EMPLOIDSA(A_N2) <> null and 
& EMPLOID.EMPLOIDSA(A_N2).ASTALIN=[V]CST_ALL
EMPLOID.EMPLOIDSA(A_N2).ASTALIN = [V]CST_AUPD
Endif
If EMPLOID.EMPLOIDSA(A_N2) <> null and
& (EMPLOID.EMPLOIDSA(A_N2).ASTALIN=[L]A_TYPMAJ or
& EMPLOID.EMPLOIDSA(A_N2).ASTALIN=[V]CST_ALL)
 If EMPLOID.EMPLOIDSA(A_N2).ASTALIN=[L]A_TYPMAJ
  Case EMPLOID.EMPLOIDSA(A_N2).ASTALIN
   When [V]CST_AUPD  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._AUPDATE)
   When [V]CST_ANEW : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._AINSERT)
   When [V]CST_ADEL  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._ADELETE)
  Endcase
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
A_N2=1
If EMPLOID.EMPLOIDUKI(A_N2) <> null and 
& EMPLOID.EMPLOIDUKI(A_N2).ASTALIN=[V]CST_ALL
EMPLOID.EMPLOIDUKI(A_N2).ASTALIN = [V]CST_AUPD
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLORIB)
 If EMPLOID.EMPLORIB(A_N2) <> null and
& (EMPLOID.EMPLORIB(A_N2).ASTALIN=[L]A_TYPMAJ or
& EMPLOID.EMPLORIB(A_N2).ASTALIN=[V]CST_ALL)
  If EMPLOID.EMPLORIB(A_N2).ASTALIN=[L]A_TYPMAJ
   Case EMPLOID.EMPLORIB(A_N2).ASTALIN
    When [V]CST_AUPD  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._AUPDATE)
    When [V]CST_ANEW : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._AINSERT)
    When [V]CST_ADEL  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._ADELETE)
   Endcase
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOCHD)
 If EMPLOID.EMPLOCHD(A_N2) <> null and
& (EMPLOID.EMPLOCHD(A_N2).ASTALIN=[L]A_TYPMAJ or
& EMPLOID.EMPLOCHD(A_N2).ASTALIN=[V]CST_ALL)
  If EMPLOID.EMPLOCHD(A_N2).ASTALIN=[L]A_TYPMAJ
   Case EMPLOID.EMPLOCHD(A_N2).ASTALIN
    When [V]CST_AUPD  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._AUPDATE)
    When [V]CST_ANEW : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._AINSERT)
    When [V]CST_ADEL  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._ADELETE)
   Endcase
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOJNT)
 If EMPLOID.EMPLOJNT(A_N2) <> null and
& (EMPLOID.EMPLOJNT(A_N2).ASTALIN=[L]A_TYPMAJ or
& EMPLOID.EMPLOJNT(A_N2).ASTALIN=[V]CST_ALL)
  If EMPLOID.EMPLOJNT(A_N2).ASTALIN=[L]A_TYPMAJ
   Case EMPLOID.EMPLOJNT(A_N2).ASTALIN
    When [V]CST_AUPD  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._AUPDATE)
    When [V]CST_ANEW : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._AINSERT)
    When [V]CST_ADEL  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._ADELETE)
   Endcase
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOEXM)
 If EMPLOID.EMPLOEXM(A_N2) <> null and
& (EMPLOID.EMPLOEXM(A_N2).ASTALIN=[L]A_TYPMAJ or
& EMPLOID.EMPLOEXM(A_N2).ASTALIN=[V]CST_ALL)
  If EMPLOID.EMPLOEXM(A_N2).ASTALIN=[L]A_TYPMAJ
   Case EMPLOID.EMPLOEXM(A_N2).ASTALIN
    When [V]CST_AUPD  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._AUPDATE)
    When [V]CST_ANEW : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._AINSERT)
    When [V]CST_ADEL  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._ADELETE)
   Endcase
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOTRY)
 If EMPLOID.EMPLOTRY(A_N2) <> null and
& (EMPLOID.EMPLOTRY(A_N2).ASTALIN=[L]A_TYPMAJ or
& EMPLOID.EMPLOTRY(A_N2).ASTALIN=[V]CST_ALL)
  If EMPLOID.EMPLOTRY(A_N2).ASTALIN=[L]A_TYPMAJ
   Case EMPLOID.EMPLOTRY(A_N2).ASTALIN
    When [V]CST_AUPD  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._AUPDATE)
    When [V]CST_ANEW : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._AINSERT)
    When [V]CST_ADEL  : [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._ADELETE)
   Endcase
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
 If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLOID.snapshotEnabled=1
 [L]A_RETIK = EMPLOID.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOID.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLOID.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOID.ASTALIN = [V]CST_ALL
Endif
For [L]A_I=1 To maxtab(EMPLOID.PASDET)
 If EMPLOID.PASDET([L]A_I)<>null
  If EMPLOID.PASDET([L]A_I).ASTALIN=[V]CST_ADEL or EMPLOID.PASDET([L]A_I).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EMPLOID.PASDET([L]A_I)
   EMPLOID.PASDET([L]A_I) = null
  Elsif EMPLOID.PASDET([L]A_I).ASTALIN <> [V]CST_ALL
   EMPLOID.PASDET([L]A_I).ASTALIN = [V]CST_ALL
  Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif
For [L]A_I=1 To maxtab(EMPLOID.PERCNT)
 If EMPLOID.PERCNT([L]A_I)<>null
  If EMPLOID.PERCNT([L]A_I).ASTALIN=[V]CST_ADEL or EMPLOID.PERCNT([L]A_I).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EMPLOID.PERCNT([L]A_I)
   EMPLOID.PERCNT([L]A_I) = null
  Elsif EMPLOID.PERCNT([L]A_I).ASTALIN <> [V]CST_ALL
   EMPLOID.PERCNT([L]A_I).ASTALIN = [V]CST_ALL
  Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif
Local Integer ASTATUS2
A_N2=1
If EMPLOID.EMPLOIDSA(A_N2) <> null
 [L]ASTATUS2 = fmet EMPLOID.EMPLOIDSA(A_N2)._AINSERT_AFTER
