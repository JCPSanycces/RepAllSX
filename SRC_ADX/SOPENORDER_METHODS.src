$AREAD_AFTER
  # -----------------------------------
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACBPR, DEP, PTE
  Call LOAD_VACBPR_LEG(this) From SORDER_PROPERTIES
  Call LOAD_DEP_LEG(this) From SORDER_PROPERTIES
  Call LOAD_PTE_LEG(this) From SORDER_PROPERTIES
  Call LOAD_SOHTYP_LEG(this) From SORDER_PROPERTIES
 Return
