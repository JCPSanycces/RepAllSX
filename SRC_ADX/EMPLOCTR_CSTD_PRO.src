#<AdxTL>@(#)0.0.0.0 $Revision$


#Handle all property code for EMPLOCTR
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "ETRFCY"           : Gosub EMPLOCTR_ETRFCY
Endcase
Return

$EMPLOCTR_ETRFCY
Case [L]ARULE
  When "CONTROL"    : Gosub EMPLOCTR_ETRFCY_CONTROL
Endcase
Return

$EMPLOCTR_ETRFCY_CONTROL
Local    Char    NUMLIB(10), LEGC(GLONADI), LEGF(GOONADI)
Local    Integer OK
Local File EMPLOCTR [CTR1]
Local File FACILITY [FCY1]

Filter [CTR1] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<[M]CTRDAT
Read [CTR1]CTR1 Last
Filter [CTR1]
If fstat = [V]CST_AOK Then
  #Leg of the current contract
  Read [FCY]FCY0 = this.ETRFCY
  If fstat = [V]CST_AOK
    [L]LEGC = [F:FCY]LEG
  Endif
  #Leg of another existing contract with the same contract chrono
  Read [FCY]FCY0 = [F:CTR1]ETRFCY
  If fstat = [V]CST_AOK
    [L]LEGF = [F:FCY]LEG
  Endif

  If [L]LEGC<>[L]LEGF Then
    ASTATUS = fmet this.ASETERROR([L]CURPRO,mess(128,10701,1)-"("+LEGF+")",[V]CST_AERROR)
  Endif
Endif

Filter [CTR1]
LogicClose File [CTR1]
Filter [FCY1]
LogicClose File [FCY1]

Return

