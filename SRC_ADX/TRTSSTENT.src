#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
#########################################################################
#                                                                       #
#     Synchronize BP Ship to SST Entity/use code with documents         #
#                                                                       #
#                                                                       #
#########################################################################

#--- Actions liées au traitement standard
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase
Return


#########################################################################
$TERMINE
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  TRA = 1
Endif
Return


#########################################################################
$INIT


Gosub OUVRE_LTA From TRTTAXUSA

If !clalev([F:BPD])  Local File BPDLVCUST  [BPD] : Endif
If !clalev([F:SQH])  Local File SQUOTE     [SQH] : Endif
If !clalev([F:SOH])  Local File SORDER     [SOH] : Endif
If !clalev([F:SDH])  Local File SDELIVERY  [SDH] : Endif
If !clalev([F:SIH])  Local File SINVOICE   [SIH] : Endif
If !clalev([F:SRE])  Local File SERREQUEST [SRE] : Endif
If !clalev([F:CON])  Local File CONTSERV   [CON] : Endif

Local Mask SSTENT [SSTI]



Return


#########################################################################
$INIT_DIA

[M]ALLCLIENT=2
Diszo [M]CLIENT

[M]ALLSOC=2
Diszo [M]SOC
Return


#########################################################################
$EXEC
 Call SYNCHRO_SSTENTUSE([M]ALLSOC,[M]SOC,[M]ALLCLIENT,[M]CLIENT,[M]ALLSQH,[M]ALLSOH,[M]ALLSDH,[M]ALLSIH,[M]ALLSRE,[M]ALLCON, [M]SIMUL)
 Return
#**

#**
#*
#*
#* @param ALLSOC
#* @param SOC
#* @param ALLCLIENT
#* @param CLIENT
#* @param ALLSQH
#* @param ALLSOH
#* @param ALLSDH
#* @param ALLSIH
#* @param ALLSRE
#* @param ALLCON
#* @param SiMUL
#*!
Subprog SYNCHRO_SSTENTUSE(ALLSOC,SOC,ALLCLIENT,CLIENT,ALLSQH, ALLSOH, ALLSDH, ALLSIH, ALLSRE, ALLCON, SIMUL)
Value Integer  ALLSOC,ALLCLIENT,ALLSQH, ALLSOH, ALLSDH, ALLSIH, ALLSRE, ALLCON, SIMUL
Value Char     SOC,CLIENT

Local Char CRIT1(255)

If !GSERVEUR
      Call OUVRE_TRACE(mess(87,191,1)) From LECFIC
      Call ECR_TRACE(" ",0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call PRTSCR("SSTENT","SSTI","",0,1) From ATRTX3
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE(" ",0) From GESECRAN

      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      If [L]SIMUL=2
        Call ECR_TRACE(mess(31,15,1),0) From GESECRAN
      Else
        Call ECR_TRACE(mess(45,9901,1),0) From GESECRAN
      Endif

      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

      Call ECR_TRACE(" ",0) From GESECRAN

Endif

Read [LTP]LTP0=nomap
If fstat : Call FSTA("LTA") From GLOCK : End : Endif

CRIT='1=1'


# Add client to parameters if specified in selection
If [L]CLIENT<>""
  CRIT+=' & [F:BPD]BPCNUM=[L]CLIENT'
Endif

GOK=1
If  [L]ALLSQH=2 Gosub ALL_SQH : Endif
If  GOK & [L]ALLSOH=2 Gosub ALL_SOH : Endif
If  GOK & [L]ALLSDH=2 Gosub ALL_SDH : Endif
If  GOK & [L]ALLSIH=2 Gosub ALL_SIH : Endif
If  GOK & [L]ALLSRE=2 Gosub ALL_SRE : Endif
If  GOK & [L]ALLCON=2 Gosub ALL_CON : Endif

End

$ALL_SQH
  If [L]SIMUL<>2
    Trbegin [SQH]
  Endif

  CRIT1=CRIT

  # Check company against  SST parameters
  If [L]SOC<>""
    CRIT1 = CRIT+' & [F:SQH]CPY=[L]SOC'
  Endif

  Link [F:SQH] With [F:BPD]BPD0=[F:SQH]BPCORD;[F:SQH]BPAADD As [LNK] Where [F:SQH]QUOSTA<>3 & [F:SQH]SSTENTCOD<>[F:BPD]SSTENTCOD & evalue(CRIT1)

  For [LNK]
    Call ECR_TRACE(mess(9,477,1)-"["-[F:SQH]SQHNUM -"]"-mess(78,117,1)+"["-[F:SQH]BPCORD-[F:SQH]BPAADD-"]",0) From GESECRAN
    If [L]SIMUL<>2
      [F:SQH]SSTENTCOD=[F:BPD]SSTENTCOD
      Rewrite [F:SQH]
      If fstat : GOK=0  : Call RSTA("SQH",[F:SIV]NUM) From GLOCK : Break : Endif
    Endif
  Next
  If [L]SIMUL<>2
    If GOK
      Commit
    Else
      Rollback
    Endif
  Endif
  Call ECR_TRACE(" ",0) From GESECRAN
Return

#########################################################################
$ALL_SOH
  If [L]SIMUL<>2
    Trbegin [SOH]
  Endif

  CRIT1=CRIT

  # Check company against  SST parameters
  If [L]SOC<>""
    CRIT1 = CRIT+' & [F:SOH]CPY=[L]SOC'
  Endif

  Link [F:SOH] With [F:BPD]BPD0=[F:SOH]BPCORD;[F:SOH]BPAADD As [LNK] Where [F:SOH]ORDSTA=1 & [F:SOH]SSTENTCOD<>[F:BPD]SSTENTCOD & evalue(CRIT1)

  For [LNK]
    Call ECR_TRACE(mess(196,197,1)-"["-[F:SOH]SOHNUM -"]"-mess(78,117,1)+"["-[F:SOH]BPCORD-[F:SOH]BPAADD-"]",0) From GESECRAN
    If [L]SIMUL<>2
      [F:SOH]SSTENTCOD=[F:BPD]SSTENTCOD
      Rewrite [F:SOH]
      If fstat : GOK=0  : Call RSTA("SOH",[F:SOH]SOHNUM) From GLOCK : Break : Endif
    Endif
  Next
  If [L]SIMUL<>2
    If GOK
      Commit
    Else
      Rollback
    Endif
  Endif
  Call ECR_TRACE(" ",0) From GESECRAN
Return

#########################################################################
$ALL_SDH
  If [L]SIMUL<>2
    Trbegin [SDH]
  Endif

  CRIT1=CRIT

  # Check company against  SST parameters
  If [L]SOC<>""
    CRIT1 = CRIT+' & [F:SDH]CPY=[L]SOC'
  Endif

  Link [F:SDH] With [F:BPD]BPD0=[F:SDH]BPCORD;[F:SDH]BPAADD As [LNK] Where [F:SDH]CFMFLG<>2 & [F:SDH]SSTENTCOD<>[F:BPD]SSTENTCOD & evalue(CRIT1)

  For [LNK]
    Call ECR_TRACE(mess(25,159,1)-"["-[F:SDH]SDHNUM -"]"+ mess(78,117,1)+"["-[F:SDH]BPCORD-[F:SDH]BPAADD-"]",0) From GESECRAN
    If [L]SIMUL<>2
      [F:SDH]SSTENTCOD=[F:BPD]SSTENTCOD
      Rewrite [F:SDH]
      If fstat : GOK=0  : Call RSTA("SDH",[F:SDH]SDHNUM) From GLOCK : Break : Endif
    Endif
  Next
  If [L]SIMUL<>2
    If GOK
      Commit
    Else
      Rollback
    Endif
  Endif
  Call ECR_TRACE(" ",0) From GESECRAN
Return

#########################################################################
$ALL_SIH
# All Invoices are to be posted prior to installing SST Taxing.
Return

#########################################################################
$ALL_SRE
  If [L]SIMUL<>2
    Trbegin [SRE]
  Endif

  Link [F:SRE] With [F:BPD]BPD0=[F:SRE]SREBPC;[F:SRE]SREBPAADD As [LNK] Where [F:SRE]SREASS<>5 & [F:SRE]SSTENTCOD<>[F:BPD]SSTENTCOD & evalue(CRIT)

  For [LNK]
    Call ECR_TRACE(mess(8,413,1)-"["-[F:SRE]SRENUM -"]"+ mess(78,117,1)+"["-[F:SRE]SREBPC-[F:SRE]SREBPAADD-"]",0) From GESECRAN
    If [L]SIMUL<>2
      [F:SRE]SSTENTCOD=[F:BPD]SSTENTCOD
      Rewrite [F:SRE]
      If fstat : GOK=0  : Call RSTA("SRE",[F:SRE]SRENUM) From GLOCK : Break : Endif
    Endif
  Next
  If [L]SIMUL<>2
    If GOK
      Commit
    Else
      Rollback
    Endif
  Endif
  Call ECR_TRACE(" ",0) From GESECRAN
Return

#########################################################################
$ALL_CON
  Local Char TMPBPC(GLONBPC)
  If [L]SIMUL<>2
    Trbegin [CON]
  Endif

  CRIT1 = '1=1'

  If [L]CLIENT<>""
    CRIT1+=' & [F:BPD]BPCNUM=[L]CLIENT'
  Endif

  # Check company against  SST parameters
  If [L]SOC<>""
    CRIT1 += ' & [F:CON]CPY=[L]SOC'
  Endif

  Link [F:CON] With [F:BPD]BPD0(1)=[F:CON]CONBPC As [LNK] Where [F:CON]FDDFLG<>2 & [F:CON]RSIFLG<>2 & [F:CON]SSTENTCOD<>[F:BPD]SSTENTCOD & evalue(CRIT1)
  Raz TMPBPC

  For [LNK]
    If TMPBPC<>[F:BPD]BPCNUM
      TMPBPC=[F:BPD]BPCNUM
      Call ECR_TRACE(mess(161,183,1)-"["-[F:CON]CONNUM -"]"+ mess(78,117,1)+"["-[F:CON]CONBPC-"]",0) From GESECRAN
      If [L]SIMUL<>2
        [F:CON]SSTENTCOD=[F:BPD]SSTENTCOD
        Rewrite [F:CON]
        If fstat : GOK=0  : Call RSTA("CON",[F:CON]CONNUM) From GLOCK : Break : Endif
      Endif
    Endif
  Next
  If [L]SIMUL<>2
    If GOK
      Commit
    Else
      Rollback
    Endif
  Endif
  Call ECR_TRACE(" ",0) From GESECRAN
Return


######################################################################################
Subprog AV_ALLSOC(VALEUR)
Variable Integer VALEUR

If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  VALEUR = 1
  Call INICPY([M]SOC) From CPTSUB
  Affzo [M]SOC
  Diszo [M]ALLSOC,SOC
Else
  Diszo [M]SOC
Endif

End

######################################################################################
Subprog AP_ALLSOC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]SOC
  Diszo [M]SOC
Else
  Actzo [M]SOC
Endif


End

######################################################################################
Subprog AV_ALLCLIENT(VALEUR)
Variable Integer VALEUR

Diszo [M]CLIENT

End


######################################################################################
Subprog AP_ALLCLIENT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]CLIENT
  Diszo [M]CLIENT
Else
  Actzo [M]CLIENT
Endif
End
