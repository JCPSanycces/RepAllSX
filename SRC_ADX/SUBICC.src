#<AdxTL>@(#)12.0.0.0 $Revision$
Local Decimal LPRI
#Dbgaff
LPRI = func STKVAL.GETPRITAR("CCMAT","","","CCP", "CCP", 65, [01/01/2007], [01/01/2007], "", "" )
Infbox num$(LPRI)
End

# Lancement calcul de coûts -                      #
####################################################
# Traitement unique pour les 4 fonctions de calcul #
# de coût CALCSTSTD,CALCSTCUT,CALCSTBUD,CALCSTSIM  #
####################################################

$ACTION
Case ACTION
 When "TIT_DIA"     Gosub TIT_DIA
 When "INIT"        Gosub INIT
 When "INIT_DIA"    Gosub INIT_DIA
 When "OUVRE_BATCH" Gosub INIT  # depuis ARQTPAR (requête batch)
 When "CONTROLE"    Gosub CONTROLE
 When "EXEC"        Gosub EXEC
 When "TERMINE"     Gosub TERMINE
 When "SORTIE"      Raz GFONC1 : Raz [M:DIA]
 When "BB2_FILART"  Gosub BB2_FILART
Endcase
Return

###################################################################
$INIT
Local Integer CTL_OK, OK
Local Integer BOM_OK
Local Char    SYMBOLE(10)
Local Char    LPAR(10)

Local Integer I, T_ALT(3) : # pour conserver les alternatives associées à ROUALT
Local Integer T_USE(3)    : # pour conserver les usages des alternatives

If !clalev([F:FIY]) : Local File FISCALYEAR    [FIY] : Endif
If !clalev([F:PER]) : Local File PERIOD        [PER] : Endif
If clalev ([F:ITM]) = 0 Local File ITMMASTER   [ITM] Endif
If clalev ([F:ITF]) = 0 Local File ITMFACILIT  [ITF] Endif
If clalev ([F:ITV]) = 0 Local File ITMMVT      [ITV] Endif
If GMODU(8) = 2
  If clalev ([F:TRO]) = 0 Local File TABROUALT [TRO] Endif #  NECESSITE MODULE GP !
Endif
If clalev ([F:BOH]) = 0 Local File BOM         [BOH] Endif
If clalev ([F:TBO]) = 0 Local File TABBOMALT   [TBO] Endif
If clalev ([F:ITC]) = 0 Local File ITMCOST     [ITC] Endif
If clalev ([F:ITC2]) = 0 Local File ITMCOST    [ITC2] Endif
If clalev ([F:ITB]) = 0 Local File ITMBOM      [ITB] Endif
If clalev ([F:ITG]) = 0 Local File ITMCATEG    [ITG] Endif # pour mvt variation valeur
If clalev ([F:TCM]) = 0 Local File TABCOSTMET  [TCM] Endif # pour mvt variation valeur
# CCC (13/08/07) Bug 42564
If GMODU(7)=2
    If clalev ([F:STJ]) = 0 Local File STOJOU      [STJ] Endif # pour mvt variation valeur
    If clalev ([F:STJ1]) = 0 Local File STOJOU     [STJ1] Endif # pour mvt variation valeur
    If clalev ([F:ITH]) = 0 Local File ITMMVTHIS   [ITH] Endif # pour mvt variation valeur
Endif
If clalev ([F:MAW]) = 0 Local File MATCSTW     [MAW] Endif
If clalev ([F:TUN]) = 0 Local File TABUNIT     [TUN] Endif
If clalev ([F:TCU]) = 0 Local File TABCUR      [TCU] Endif

If clalev ([F:ICN]) = 0 Local File ITCNAT      [ICN] Endif # pour détails natures de FG ( 03/05/00)
If clalev ([F:ICN2]) = 0 Local File ITCNAT     [ICN2] Endif
If clalev ([F:ICNW]) = 0 Local File ITCNAT     [ICNW] Endif
If !clalev([F:ICC]) : Local File ITCMAT        [ICC] : Endif
If !clalev([F:ICC2]) : Local File ITCMAT       [ICC2] : Endif
If !clalev([F:ICCW]) : Local File ITCMAT       [ICCW] : Endif
If !clalev([F:IWC]) : Local File ITCWST        [IWC] : Endif
If !clalev([F:IWC2]) : Local File ITCWST       [IWC2] : Endif
If !clalev([F:IWCW]) : Local File ITCWST       [IWCW] : Endif

If clalev ([F:BOD]) = 0  Local File BOMD       [BOD]  Endif

If clalev ([F:OVE]) = 0 Local File OVERHEAD    [OVE] Endif
If clalev ([F:TFO]) = 0 Local File TABFOR      [TFO] Endif
If GMODU(8) = 2
  If clalev ([F:ROH]) = 0  Local File ROUTING    [ROH] Endif
  If clalev ([F:ROO]) = 0  Local File ROUOPE     [ROO] Endif
  If clalev ([F:MWC]) = 0  Local File WORKCOST   [MWC] Endif
  If clalev ([F:MWS]) = 0  Local File WORKSTATIO [MWS] Endif
Endif

If clalev ([F:EVL]) = 0 Local File ECCVAL     [EVL] Endif
## GH 20/07/2016 bug 117716 - crash for a folder without ECC activity code
#If clalev ([F:EVL3])= 0 Local File ECCVAL3   [EVL3] Endif    # View for ECCSTA

If clalev ([F:AOT]) = 0 Local File AOBJTAB    [AOT] Endif
If clalev ([F:ATB]) = 0 Local File ATABLE     [ATB] Endif

If !clalev([M:CTP])  : Local Mask CLCCSTPAR : Endif : # GH 19/03/2014 bug 86229

# Modifié le 12/04/02 car l'action déclarait (depuis le 14/12/01)à tort une saisie fenêtre (13893)
# Si on vient du configurateur
If clalev([M:CFV4]) <> 0
  Local Mask ITCCLC0 [DIA]  # ouvert avant car BCRIT est inhibé par CFG_CSTINIT
  Gosub CFG_CSTINIT From CFGLIBD
  Gosub INIT_DIA
  [M:DIA] = [M:CFV4]        # pour site ...
Endif
Return

###################################################################
$INIT_DIA
For [AOT]ABREV Where ABREV="ITM" & TABLIEN<>""
  [M:DIA]NBTBL += 1
  [M:DIA]TBTBL([M:DIA]NBTBL) = [F:AOT]TABFIC
  [M:DIA]ABTBL([M:DIA]NBTBL) = [F:AOT]TABABR
Next AOT

# affecter le titre selon PARAM(1)= paramètre CSTTYP
[M:DIA]CSTTYPA=PARAM(1)
Case [M:DIA]CSTTYPA
 When "STD"   TIT = mess(75,195,1)
 When "CUT"   TIT = mess(76,195,1)
 When "BUD"   TIT = mess(77,195,1)
 When "SIM"   TIT = mess(78,195,1)
 When Default TIT = mess(75,195,1)
Endcase
[M:DIA]ITMREF = PARAM(2)
If [M:DIA]ITMREF<>""
    [M:DIA]TOUS=1
Endif
If PARAM(3)=""
    [M:DIA]STOFCY = GFCYDEF(0)
Else
    [M:DIA]STOFCY = PARAM(3)
Endif
If dim([M:DIA]ECCVALMAJ)>0
    [M:DIA]ECCVALMAJ = PARAM(4)
    [M:DIA]ECCVALMIN = PARAM(5)
Endif
Call GETDEV([M:DIA]STOFCY) From DEVSUB
[M:DIA]ITCDAT = date$
[M:DIA]BOMALTTYP = 2

# Issue 87576 - 2014-03-27 by CCC : load parameter value corresponding to site
#[M:DIA]SLTMATCST = evalue("GCLC"+[M:DIA]CSTTYPA+"MAT")
#[M:DIA]VLTCCERAT = evalue("GCLC"+[M:DIA]CSTTYPA+"RAT")
#[M:DIA]SLTOVECOL = evalue("GOVECOL"+[M:DIA]CSTTYPA)
# Issue 103861 - 2014-11-28 by JUSYN : Parameter read according to type of screen
# Call PARAM([M:DIA]STOFCY, "CLCSTDMAT", LPAR) From ADOVAL
# [M:DIA]SLTMATCST = val(LPAR)
# Issue 87576 - 2015-04-08 by JUSYN : Initialisation of cost fields has to be done when screen first opens but when site changes as well
#Case [M:DIA]CSTTYPA
#    When "STD"
#        Call PARAM([M:DIA]STOFCY, "CLCSTDMAT", LPAR) From ADOVAL
#    When "CUT"
#        Call PARAM([M:DIA]STOFCY, "CLCCUTMAT", LPAR) From ADOVAL
#    When "BUD"
#        Call PARAM([M:DIA]STOFCY, "CLCBUDMAT", LPAR) From ADOVAL
#    When "SIM"
#        Call PARAM([M:DIA]STOFCY, "CLCSIMMAT", LPAR) From ADOVAL
#    When Default
#        Call PARAM([M:DIA]STOFCY, "CLCSTDMAT", LPAR) From ADOVAL
#Endcase
#[M:DIA]SLTMATCST = val(LPAR)
#
## Issue 87576 - 2015-04-02 by JUSYN : Parameter for costing rate read according to type of screen as well.
## Call PARAM([M:DIA]STOFCY, "CLCSTDRAT", LPAR) From ADOVAL
## [M:DIA]VLTCCERAT = val(LPAR)
#Case [M:DIA]CSTTYPA
#    When "STD"
#        Call PARAM([M:DIA]STOFCY, "CLCSTDRAT", LPAR) From ADOVAL
#    When "CUT"
#        Call PARAM([M:DIA]STOFCY, "CLCCUTRAT", LPAR) From ADOVAL
#    When "BUD"
#        Call PARAM([M:DIA]STOFCY, "CLCBUDRAT", LPAR) From ADOVAL
#    When "SIM"
#        Call PARAM([M:DIA]STOFCY, "CLCSIMRAT", LPAR) From ADOVAL
#    When Default
#        Call PARAM([M:DIA]STOFCY, "CLCSTDRAT", LPAR) From ADOVAL
#Endcase
#[M:DIA]VLTCCERAT = val(LPAR)
#
## Issue 87576 - 2015-04-02 by JUSYN : Parameter for overhead column read according to type of screen as well to avoid next error
## Call PARAM([M:DIA]STOFCY, "OVECOLSTD", LPAR) From ADOVAL
## [M:DIA]SLTOVECOL = val(LPAR)
#Case [M:DIA]CSTTYPA
#    When "STD"
#        Call PARAM([M:DIA]STOFCY, "OVECOLSTD", LPAR) From ADOVAL
#    When "CUT"
#        Call PARAM([M:DIA]STOFCY, "OVECOLCUT", LPAR) From ADOVAL
#    When "BUD"
#        Call PARAM([M:DIA]STOFCY, "OVECOLBUD", LPAR) From ADOVAL
#    When "SIM"
#        Call PARAM([M:DIA]STOFCY, "OVECOLSIM", LPAR) From ADOVAL
#    When Default
#        Call PARAM([M:DIA]STOFCY, "OVECOLSTD", LPAR) From ADOVAL
#Endcase
#[M:DIA]SLTOVECOL = val(LPAR)

Call INIT_COST_CALC([M:DIA]STOFCY)

[M:DIA]CSTTYP    = find([M:DIA]CSTTYPA,"STD","CUT","BUD","SIM") # type 1,2,3 ou 4

If find([M:DIA]CSTTYPA,"STD","BUD")
    Affzo [M:DIA]ITCSTRDAT,ITCENDDAT
    Grizo [M:DIA]ITCSTRDAT,ITCENDDAT
    Affzo [M:DIA]ITCSTRDAT,ITCENDDAT
    Call GETEXE(GSOCIETE,GTYPGEN,date$,[M:DIA]FIYNUM) From CPTSUB
    [M:DIA]ITCSTRDAT=date$
    Call DATEXE(GSOCIETE,GTYPGEN,[M:DIA]FIYNUM,GBIDA1,[M:DIA]ITCENDDAT) From CPTSUB
Endif

# positionner un champ quand on paramètre l'abonnement  # 14918 (09/07/02)
If clalev([M:ABA1]) > 0 [M:DIA]ABT = 1  Endif
Return

###################################################################
$TIT_DIA
If !GBATCH : ## GH 23/01/13 bug 87263 ajout test sur GBATCH
   Raz [M:DIA] : Gosub INIT_DIA
Endif
Return

###################################################################
$CONTROLE
CTL_OK = 1
TMP = 1

# Seule la màj immédiate permet d'écraser le coût précédent
If [M:DIA]MAJ<3
    [M:DIA]RPLPRVCST = 1
Endif

# Controles préalables avant lancement calcul ... ET MODIF EVENTUELLE de [M]ITCDAT et BOMALT

# Forcer ITCDAT à la date du jour quand la requête est abonnée
If [M:DIA]ABT = 1 & [M:DIA]ITCDAT < date$               # 14918 (09/07/02)
  [M:DIA]ITCDAT = date$
Endif

# Controler qu'il n'y a pas un calcul déjà fait (non màj) pour cet article ...
# ecrasement possible du ficher provisoire ITC, donc non bloquant
Filter [ITC] Where STOFCY=[M:DIA]STOFCY
&                & ITMREF=[M:DIA]ITMREF
&                & CSTTYP=[M:DIA]CSTTYP
&                & ITCSTRDAT=[M:DIA]ITCSTRDAT
&                & ITCENDDAT=[M:DIA]ITCENDDAT
&                & UID<>0
&                & UPDFLG<>1
For [ITC]
    If GSERVEUR
        ERR_TRA = mess(132,197,1)
        Call ECR_TRACE(ERR_TRA,0)
    Else
        If clalev([M:CFV4]) = 0
         GMESSAGE = mess(132,197,1) : GERR = 2  # info
        Endif
    Endif
    Break
Next
Filter [ITC]

# Rechercher l'alternative de nomenclature correspondant à ROUALT
# conserver en tableau les alternatives OK       (modif 12/05/00)
# en principe elles sont tassées dans TABROUALT
If [M:DIA]ROUALT = 0 Goto LCK_SYM Endif

# en batch revérifier que l'alternative saisie est encore "bonne", sinon la réaffecter
# selon l'ordre prioritaire des alternatives associées à l'alternative de gamme
If GSERVEUR
   If [M:DIA]BOMALT<>0
     Call C_BOMALT([M:DIA]BOMALT)
     If mkstat=0 Goto LCK_SYM Endif
     Call C_BOMALTTYP([M:DIA]BOMALTTYP)
     If mkstat=0 Goto LCK_SYM Endif
   Endif
Else
   Goto LCK_SYM  # correction 22120  20/04/04 : en interactif on ne recontrole pas
Endif

Read [TRO]TRO0 = [M:DIA]ROUALT
I = 0
If [F:TRO]BOMALT1 <> 0
 Read [TBO]TBO0 = 2;[F:TRO]BOMALT1
 If [F:TBO]FCY = "" or [F:TBO]FCY = [M:DIA]STOFCY
   T_ALT(I) = [F:TRO]BOMALT1
   T_USE(I) = [F:TBO]CSTUSE
   I += 1
 Endif
Endif
If [F:TRO]BOMALT2 <> 0
 Read [TBO]TBO0 = 2;[F:TRO]BOMALT2
 If [F:TBO]FCY = "" or [F:TBO]FCY = [M:DIA]STOFCY
   T_ALT(I) = [F:TRO]BOMALT2
   T_USE(I) = [F:TBO]CSTUSE
   I += 1
 Endif
Endif
If [F:TRO]BOMALT3 <> 0
 Read [TBO]TBO0 = 2;[F:TRO]BOMALT3
 If [F:TBO]FCY = "" or [F:TBO]FCY = [M:DIA]STOFCY
   T_ALT(I) = [F:TRO]BOMALT3
   T_USE(I) = [F:TBO]CSTUSE
 Endif
Endif

If T_ALT(0) = 0
   #  AUCUNE alternative de nomenclature n'est valide pour le site sélectionné"
      CTL_OK = 0
      If GSERVEUR
        ERR_TRA = mess(141,197,1)
        Call ECR_TRACE(ERR_TRA,1)
      Else
        GERR = 1 : GMESSAGE = mess(141,197,1)
      Endif
      Goto LCK_SYM  # (le reste est inutile ! 05/2000)
Endif

#  Vérifier que l'usage de l'alternative vaut 2(OUI) bug 5802 (24/07/2000)
#  vider l'alternative du tableau si elle ne convient pas
If T_USE(0) = 1
  Raz T_ALT(0)
Else
  [M:DIA]BOMALT = T_ALT(0)
Endif
If T_USE(1) = 1
  Raz T_ALT(1)
Elsif [M:DIA]BOMALT=0
  [M:DIA]BOMALT = T_ALT(1)
Endif
If T_USE(2) = 1
  Raz T_ALT(2)
Elsif [M:DIA]BOMALT=0
  [M:DIA]BOMALT = T_ALT(2)
Endif
If sum(T_ALT) = 0
      # "Aucune alternative pour ce site n'est dédiée aux coûts"
      CTL_OK = 0
      If GSERVEUR
        ERR_TRA = mess(345,197,1)
        Call ECR_TRACE(ERR_TRA,1)
      Else
        GERR = 1 : GMESSAGE = mess(345,197,1)
      Endif
      Goto LCK_SYM
Endif
If [M:DIA]ITMREF = "" Goto LCK_SYM Endif

# vérifier l'existence de la nomenclature     (modif 12/05/00)
For I = 0 To 2
 Read [BOH]BOH0= [M:DIA]ITMREF;T_ALT(I);2
 If !fstat & [F:BOH]BOHSTRDAT <= [M:DIA]ITCDAT & ([F:BOH]BOHENDDAT >= [M:DIA]ITCDAT | [F:BOH]BOHENDDAT=[0/0/0])
    BOM_OK = 1
    Break
 Endif
Next I

# cette erreur n'a de sens que si on calcule un SF (alt de gamme renseignée)
If BOM_OK = 0 & [M:DIA]ROUALT <> 0
   CTL_OK = 0
   If GSERVEUR
     ERR_TRA = mess(312,197,1)
     Call ECR_TRACE(ERR_TRA,1)
   Else
     # " Aucune  nomenclature ne correspond"
     GERR = 1 : GMESSAGE = mess(312,197,1)
   Endif
Else
   [M:DIA]BOMALT = [F:BOH]BOMALT : # l'entête lue avec succès
Endif

$LCK_SYM
# Contrôler qu'il n'y a pas un autre calcul sur le site
# calcul complet sur un PF ou calcul de TOUS les articles : EXCLUSIF
If CTL_OK = 1 & ([M:DIA]DESCEND = 2 | [M:DIA]TOUS >= 2)
  SYMBOLE = "ITCCLC" + [M:DIA]STOFCY
  Lock =SYMBOLE With lockwait = 0
  If fstat
    CTL_OK = 0
    If GSERVEUR
      ERR_TRA = mess(218,199,1)
      Call ECR_TRACE(ERR_TRA,1)
    Else
      GERR = 1 : GMESSAGE = mess(218,199,1)
    Endif
  Endif
Endif

If !GSERVEUR & clalev([M:CFV4]) = 0
    Affzo BOMALT
Endif

# Si pb: en batch la trace sera écrite, on sort ; en direct on revient en saisie
If CTL_OK = 0
  If GSERVEUR FIN=1 Else SAI=1 Endif
Endif
Return

$EXEC
Local Char ERR_TRA(132)
Local Integer LRET
Local Integer NB_ERR     # bug 16821 11/12/02
Local Integer MAJ_OK
Local Decimal LPRI
Local Integer LCAL    # Indique si un article est sélectionnable

Global Decimal GQTY
Global Integer GNIV
Local  Decimal QTY_TOT : # pour l'appel du sous-pro pour chaque composant
Local Char     LARRQTYCPN
Local Char LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)

# CCC 22/06/04 : Demande PE 22340 reportée en 140 au cas où
GPOINT = "DECLARE" :  Gosub ENTREE From EXEFNC

If !GSERVEUR
  If GTRACE=""
   Call OUVRE_TRACE(mess(74+[M:DIA]CSTTYP,195,1)) From LECFIC
  Else
   Call ECR_TRACE(mess(74+[M:DIA]CSTTYP,195,1),0) # la trace est déjà ouverte dans le configurateur
  Endif
Endif

If GSTOTRACE=4
    Call PRTSCR("ITCCLC0", "", "", 0, 1) From ATRTX3
    Call ECR_TRACE("=========================================================",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endif

## GH 19/03/2014 bug 97454
# Local Integer TABUID(500), NB
Local Integer NB
NB=nbruser+10 : # GH 28/01/2016 +10 for security
If NB<1 : NB=500 : Endif
Local Integer TABUID(1..NB)
NB=0
##
Call UIDADX(TABUID,NB) From TRTX3

## GH 19/03/2014 Bug 97454 ajout d'une transaction séparée la purge les coûts inutiles
Call DEBTRANS From GLOCK
Trbegin [ITC]
  # Delete all costs calculated and useless.
  # Do not use find(...)=0 because the number of users can be to high for it
  For [ITC] Where !find(UID,TABUID(1..NB)) & UPDFLG=1
      Delete [ICN] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
      Delete [ICC] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
      Delete [IWC] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
      Delete [ITC] Curr
  Next
  # Issue 85159 - 2012-10-19 by CCC
  For [ITC] Where STOFCY=[M:DIA]STOFCY & CSTTYP=[M:DIA]CSTTYP & UID=adxuid(1) & UPDFLG=1
      Delete [ICN] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
      Delete [ICC] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
      Delete [IWC] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
      Delete [ITC] Curr
  Next
Commit

# GH 19/03/2014 Bug 86229
# Issue 72002 - 2011-03-01 by CCC
#Update [ITC] Where STOFCY=[M:DIA]STOFCY
#&                & PRNUID=adxuid(1)
#&             With PRNUID=0

Call GETDEV([M:DIA]STOFCY) From DEVSUB : #pour récupérer GLOCALDEV pour arrondis
# Flag de calcul bien déroulé ; mis à jour avant l'appel de COUTELEM
# si une seule erreur se produit l'éventuelle Màj de ITC ne se fera pas
# (pour éviter les incohérences entre des articles)

Call DEBTRANS From GLOCK
Trbegin [MAW]
# Effacer les enregistrements restant éventuellement d'un lancement antérieur
Delete [MAW] Where !find(MAWUID,TABUID(1..NB))
Delete [MAW] Where MAWUID = adxuid(1) & STOFCY = [M:DIA]STOFCY
If [M:DIA]TOUS >= 2
  If [M:DIA]TOUS = 2 : [M:DIA]FILART = "1=1" : Endif
  # Chargement de tous les articles selon le filtre dans MAW
  # dans le cas de sélection FILART est déjà alimenté

  Gosub OUVFIC_LISTE From WOITM   # Crée le lien entre les tables définies dans l'objet ITM

  For [ITM_] Where evalue([M:DIA]FILART)
    # sr 09.02 pour imprimer les articles réellement traités et pas les autres demande 15841
    If [M:DIA]ITMREF = "" : [M:DIA]ITMREF = [F:ITM]ITMREF : Endif
    [M:DIA]ITMREFF = [F:ITM]ITMREF

    Read [ITF]ITF0 = [F:ITM]ITMREF;[M:DIA]STOFCY
    If !fstat
        If [F:ITM]ECCFLG=2
            ## GH 20/07/2016 bug 117716 - here, we are sure the folder is with ECC activity code
            If !clalev([F:EVL3]) : Local File ECCVAL3   [EVL3] : Endif    # View for ECCSTA
            # sorted with EVL1 to order with ECCTYP (priority for BOM and after stock)
            Link [EVL] With [EVL3]EVL30~=[F:ITM]ITMREF;[F:EVL]ECCVALMAJ;[F:EVL]ECCVALMIN
&                         As [LNKE]
&                         Where [EVL]ITMREF=[F:ITM]ITMREF
&                             & STRDAT<=[M:DIA]ITCDAT
&                             & (ENDDAT>=[M:DIA]ITCDAT | ENDDAT=[0/0/0])
&                             & find([EVL]ECCTYP,4,[M:DIA]BOMALTTYP)<>0
&                             & [EVL3]ECCSTA<>3
&                         Order By Key LNKE0=ITMREF;ECCVALMAJ;ECCVALMIN;ECCTYP
            For [LNKE]LNKE0(3)
                Look [MAW]MAW0(5)=adxuid(1);[M:DIA]STOFCY;[F:ITM]ITMREF;[F:EVL]ECCVALMAJ;[F:EVL]ECCVALMIN
                Filter [MAW]
                If fstat
                    Gosub ECR_MAW
                Endif
                For [LNKE]LNKE0
                    Break
                Next
            Next
        Else
            Raz [F:EVL]
            Gosub ECR_MAW
        Endif
    Endif
  Next

Else   : # TOUS = 'Non': Unique
  Raz LECCMAJ, LECCMIN
  If  dim([M:DIA]ECCVALMAJ)>0 : # GH 21/07/2016 bug 117726 : # dim([M:DIA]ECCVALMAJ)<>0
     LECCMAJ = [M:DIA]ECCVALMAJ
     LECCMIN = [M:DIA]ECCVALMIN
  Endif
  [M:DIA]ITMREFF = [M:DIA]ITMREF
# ecrire d'abord l'article à calculer  (LLC sera à 0 : le plus haut)
  Read [ITM]ITM0 = [M:DIA]ITMREF
  Raz [F:MAW]
  [F:MAW]MAWUID = adxuid(1)
  [F:MAW]ITMREF = [M:DIA]ITMREF
  [F:MAW]ECCVALMAJ = LECCMAJ
  [F:MAW]ECCVALMIN = LECCMIN
  [F:MAW]STOFCY = [M:DIA]STOFCY
  [F:MAW]CSTUPD = 1       : # 'calculé' puisqu'on est arrivé à cet endroit !

  [F:MAW]STU    = [F:ITM]STU
#CCC (30/07/04) bug 23924 :  [F:MAW]PRIDIV = [F:ITM]PRIDIV
  [F:MAW]BRDCOD = [F:ITM]BRDCOD
  [F:MAW]OVECOD = [F:ITF]OVECOD
  [F:MAW]MATQTYTOP = [M:DIA]CLCQTY
  If dim(GITCSHR) > 0
      If GITCSHR = 1 : [F:MAW]MATQTYTOP *= 1 + [F:ITF]SHR/100 : Endif
  Endif
  [F:MAW]CREDAT = date$
  [F:MAW]CREUSR = GUSER
  Write [MAW]
  If fstat
    # erreur d'écriture sur le fichier MAW (bloquante)     (20/08/01)
    ERR_TRA = mess(13,100,1)-"MATCSTW :"- [M:DIA]ITMREF
    Call ECR_TRACE(ERR_TRA,1)
    Rollback
    Return
  Endif
  # Si FLAG DESCENTE NOMENCLATURE :
  # Descendre la nomenclature de l'article
  # Fichier de travail qui contiendra tous les composants
  # Attention le classe ITM sera écrasée !!
  If [M:DIA]DESCEND = 2
     GQTY = [M:DIA]CLCQTY
     Call PARAM([M:DIA]STOFCY, "ARRQTYCPN", LARRQTYCPN) From ADOVAL
     # Issue 104223 - 2015-03-26 by CCC : add of starting LLC
     #Call DESCEND([M:DIA]ITMREF,[M:DIA]STOFCY,[M:DIA]ITCDAT,[M:DIA]BOMALT,[M:DIA]BOMALTTYP,[M:DIA]FXDCSTDSP,val(LARRQTYCPN),OK) From TRTCOST
     Call DESCEND([M:DIA]ITMREF,LECCMAJ,LECCMIN,[M:DIA]STOFCY,[M:DIA]ITCDAT,[M:DIA]BOMALT,[M:DIA]BOMALTTYP,0,[M:DIA]FXDCSTDSP,val(LARRQTYCPN),OK) From TRTCOST
     # --> traiter le cas d'erreur (OK=0 en retour)
     If OK = 0
        ERR_TRA = mess(154,197,1) : # Erreur en descente de nomenclature
        Call ECR_TRACE(ERR_TRA,0)
        Rollback  : # modifié le 07/06/99 (TB)
        Return
     Endif
  Endif
Endif
Commit

# Issue 84066 - 2014-07-03 by CCC : ITCDAT instead of ITCSTRDAT (ITCSTRDAT <= ITCDAT <= ITCENDDAT)
## On met ITCSTRDAT dans CLCDAT pour pouvoir récupérer les prix calculés sur les composants pour cette date
## Par contre dans [ITC], ITCDAT reçoit la date du jour
Call TRAIT_MAW([M:DIA]STOFCY,[M:DIA]CSTTYP,[M:DIA]BOMALT,[M:DIA]BOMALTTYP,[M:DIA]ROUALT,[M:DIA]ITCDAT,[M:DIA]SLTMATCST,[M:DIA]VLTCCERAT, [M:DIA]DESCEND)

Gosub FIN_CLC

Return


$ECR_MAW
        # CCC (2010-04-29) Bug 64240 : Sélectionner uniquement les alternatives valables pour le site
        # CCC (2009-11-30) Bug 60417 : Ce ne sont que les alternatives de coût qui doivent être vérifiées
        # CCC (05/01/07) Bug 39137 : si un article possède une alternative quelconque => ce n'est pas une matière...
        LCAL=0
        # Issue 75479 - 2011-09-07 by CCC : Les coûts paramétrés "Saisi" ne doivent pas être calculés
        If evalue("[F:ITF]"+[M:DIA]CSTTYPA+"CSTUPD")<>2
            If [F:EVL]ECCTYP=4
                LCAL=1      # No BOM => it's a material
            Else
                # on vérifie qu'il possède une nomenclature valide.
                Link [BOH] With [TBO]TBO0~=[F:BOH]BOMALTTYP;[F:BOH]BOMALT
&                          As [LNK]
&                          Where [BOH]ITMREF = [F:ITM]ITMREF
&                            and [F:BOH]BOMALTTYP = [M:DIA]BOMALTTYP
&                            and [TBO]CSTUSE = 2
&                            and ([TBO]FCY=[F:ITF]STOFCY | [TBO]FCY="")
&                            and ([F:BOH]BOHSTRDAT = [0/0/0] | [F:BOH]BOHSTRDAT <= [M:DIA]ITCDAT)
&                            and ([F:BOH]BOHENDDAT >= [M:DIA]ITCDAT | [F:BOH]BOHENDDAT=[0/0/0])
                Look [LNK] First
                If !fstat
                    # Si une nomenclature de coût existe on ne calcule que si l'alternative demandée en fait partie
                    For [LNK] Where [BOH]BOMALT=[M:DIA]BOMALT
                        LCAL=1
                        Break
                    Next
                Else
                    # Si c'est une matière (pas de nomenclature) on calcule
                    LCAL=1
                Endif
            Endif
        Endif

        # CCC (28/01/08) DM 45509
        GPOINT = "CALITC"
        Gosub ENTREE From EXEFNC

        If LCAL
          Raz [MAW]
          [F:MAW]ITMREF = [F:ITM]ITMREF
          [F:MAW]ECCVALMAJ = [F:EVL]ECCVALMAJ
          [F:MAW]ECCVALMIN = [F:EVL]ECCVALMIN
          [F:MAW]STOFCY = [M:DIA]STOFCY
          [F:MAW]STU    = [F:ITM]STU      # rajouté 21/06/01
          [F:MAW]BRDCOD = [F:ITM]BRDCOD
          [F:MAW]MAWUID = adxuid(1)
          [F:MAW]CSTUPD = evalue("[F:ITF]"+[M:DIA]CSTTYPA+"CSTUPD")
          [F:MAW]OVECOD = [F:ITF]OVECOD
          If [F:ITF]REOMINQTY > 0
            [F:MAW]MATQTYTOP = [F:ITF]REOMINQTY/(([F:ITM]DEFPOT=0)+[F:ITM]DEFPOT/100) :# calcul pour la qté economique
          Elsif [F:ITF]MFGLOTQTY > 0
            [F:MAW]MATQTYTOP = [F:ITF]MFGLOTQTY/(([F:ITM]DEFPOT=0)+[F:ITM]DEFPOT/100) :# calcul pour le lot technique
          Else
            [F:MAW]MATQTYTOP = 1  : # ou ERREUR !?
          Endif
          If dim(GITCSHR) > 0
              If GITCSHR = 1 : [F:MAW]MATQTYTOP *= (1+[F:ITF]SHR/100) : Endif
          Endif

          # Dem 17308 Prendre la quantité de calcul ailleurs  (11/02/03)
          GPOINT = "QTYCALC"
          Gosub ENTREE From EXEFNC

          Read [ITB]ITB0 = [F:ITM]ITMREF;[M:DIA]BOMALT;2
          If fstat [F:MAW]LLC = 99 Else [F:MAW]LLC = [F:ITB]LLC Endif
          [F:MAW]CREDAT = date$
          [F:MAW]CREUSR = GUSER
                      # écrire aussi les art avec coût bloqué pour l'édition matière

          Write [MAW]
          If fstat
            # erreur d'écriture sur le fichier MAW (non bloquante) (20/08/01)
            ERR_TRA = mess(13,100,1)-"MATCSTW :"- [F:ITM]ITMREF
            Call ECR_TRACE(ERR_TRA,0)
          Endif
        Endif
Return


Subprog TRAIT_MAW(PFCY,PCSTTYP,PBOM,PBOMTYP,PROU,PDAT,PSLTMAT,PVLTCCE,PDESC)
Value Char    PFCY
Value Integer PCSTTYP
Value Integer PBOM
Value Integer PBOMTYP
Value Integer PROU
Value Date    PDAT
Value Integer PSLTMAT
Value Integer PVLTCCE
Value Integer PDESC     # Indique si le calcul se fait dans le cadre d'une descente de nomclature (2) ou non (1)

# Traitement du fichier de travail par code de + bas niveau DECROISSANT
# valable pour le calcul de TOUS les articles ou pour un PF complet

If !clalev([M:CST0]) : Local Mask CLCCST0   : Endif
If !clalev([M:CST])  : Local Mask CLCCST    : Endif
If !clalev([M:CTP])  : Local Mask CLCCSTPAR : Endif
If !clalev([M:SDP])  : Local Mask SAIDECPRI  : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:BOH]) : Local File BOM        [BOH] : Endif

Local Integer LRET
Local Decimal LPRI
Local Integer LCSTCOD
Local Integer I
Local Integer LMATFLG   # is the item a raw material ?
Local Integer LROUFLG   # has a routing to be found ?

[M:CTP]PRNNUM = uniqid([F:ITC]) : # GH 19/03/2014 bug 86229
# Impossible d'entrer -LLC+ITMREF dans le descripteur d'index donc clé temporaire
Filter [MAW] Where MAWUID = adxuid(1) & STOFCY = PFCY Order By Key CLE = LLC Desc;ITMREF;ECCVALMAJ;ECCVALMIN
For [MAW]CLE
    Trbegin [ITC]
      # Some records can still exist (for example with updflg=2 ("Deferred"))
      For [ITC] Where STOFCY=[F:MAW]STOFCY & CSTTYP=PCSTTYP & ITMREF=[F:MAW]ITMREF & UID=adxuid(1)
&                   & ECCVALMAJ=[F:MAW]ECCVALMAJ & ECCVALMIN=[F:MAW]ECCVALMIN
          Delete [ICN] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
          Delete [ICC] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
          Delete [IWC] Where STOFCY=[F:ITC]STOFCY & CSTTYP=[F:ITC]CSTTYP & ITMREF=[F:ITC]ITMREF & ITCSEQ=[F:ITC]ITCSEQ & UID=[F:ITC]UID
          Delete [ITC] Curr
      Next
    Commit

    If GSTOTRACE=4
        Call ECR_TRACE("-------------------------------------------------------------",0) From GESECRAN
        Call ECR_TRACE(mess(74+PCSTTYP,195,1)-":"-[F:MAW]STOFCY-[F:MAW]ITMREF,0) From GESECRAN
    Endif

    I = [M:CTP]PRNNUM      : # GH 19/03/2014 bug 86229
    Raz [M:CST],[M:CST0],[M:CTP]
    [M:CTP]PRNNUM    = I   : # GH 19/03/2014 bug 86229
    [M:CTP]TYPCST    = 1
    [M:CST0]AFFZON   = 1
    [M:CST0]STOFCY   = [F:MAW]STOFCY
    [M:CTP]ITMREF    = [F:MAW]ITMREF
    [M:CTP]ECCVALMAJ = [F:MAW]ECCVALMAJ
    [M:CTP]ECCVALMIN = [F:MAW]ECCVALMIN
    [M:CTP]BOMALT    = PBOM
    [M:CTP]BOMALTTYP = PBOMTYP
    [M:CTP]ROUALT    = PROU
    [M:CTP]UID       = adxuid(1)
    [M:CTP]QTYCLC    = [F:MAW]MATQTYTOP + [F:MAW]MATQTYSSE
    [M:CTP]FXDCSTDSP = [M:DIA]FXDCSTDSP   # CCC (2010-01-28) Bug 61969 : Tenir compte du paramètre dans l'écran de lancement
    [M:CTP]CLCDAT    = PDAT
    [M:CTP]SLTOVECOL = [M:DIA]SLTOVECOL   # CCC (2010-04-14) Bug 62306 : Tenir compte du paramètre dans l'écran de lancement
    If clalev([M:CFV4]) > 0
        [M:CTP]TRANIV    = 3  # Trace configurateur
    Else
        [M:CTP]TRANIV    = 2  # Trace tout
    Endif

    Call LOADITM(LRET) From SUBCSTB
    If LRET
        Call ECRTRACE([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE,1) From TRTCST
        Raz GMESSAGE
        Goto NEXT_MAW
    Endif

    # If no BOM version exists for the date, the item has to be considered as a raw material
    If [M:CTP]ECCVALMAJ<>""
        Filter [EVL] Where ITMREF=[M:CTP]ITMREF
&                        & STRDAT<=[M:CTP]CLCDAT
&                        & (ENDDAT>=[M:CTP]CLCDAT or ENDDAT=[0/0/0])
&                        & ECCVALMAJ = [M:CTP]ECCVALMAJ
&                        & ECCVALMIN = [M:CTP]ECCVALMIN
&                        & find(ECCTYP,2,3)<>0
        Look [EVL] First
        Filter [EVL]
    Else
        fstat = 0
    Endif

    If !fstat
        Filter [BOD] Where ITMREF = [M:CTP]ITMREF
&                        & BOMALTTYP = [M:CTP]BOMALTTYP
&                        & BOMALT = [M:CTP]BOMALT
&                        & BOMSTRDAT<=[M:CTP]CLCDAT
&                        & (BOMENDDAT>=[M:CTP]CLCDAT | BOMENDDAT=[0/0/0])
        # Issue 83939 - 2012-08-20 by CCC
        Look [BOD] First
        If fstat & [M:DIA]TOUS=1    # If no BOM exist for type required at top level => material
            Filter [BOD] Where ITMREF = [M:CTP]ITMREF
&                            & BOMALTTYP = 5-[M:CTP]BOMALTTYP
&                            & BOMALT = [M:CTP]BOMALT
&                            & BOMSTRDAT<=[M:CTP]CLCDAT
&                            & (BOMENDDAT>=[M:CTP]CLCDAT | BOMENDDAT=[0/0/0])
        Endif
        Read [BOD] First
        Filter [BOD]
        If fstat
            LMATFLG=1
            Look [BOH]BOH0=[M:CTP]ITMREF;[M:CTP]BOMALT;[M:CTP]BOMALTTYP
            If fstat
                Look [BOH]BOH0=[M:CTP]ITMREF;[M:CTP]BOMALT;5-[M:CTP]BOMALTTYP
            Endif
            # S'il existe une nomenclature mais aucun composant valide
            If !fstat
                Call ECRTRACE(mess(140,197,1) -":"- [M:CTP]ITMREF - num$([M:CTP]BOMALT),0) From TRTCST
            Endif
        Else
            LMATFLG=0
        Endif
    Else
        LMATFLG=1
    Endif

    # Issue 89664 - 2014-09-10 by CCC
    LROUFLG=0
    If [M:CTP]ROUALT=0 & [M:CTP]BOMALTTYP=3 & [F:BOD]BOMALTTYP=2
&    | [M:CTP]BOMALTTYP=2 & [M:CTP]ROUALT<>0
        LROUFLG = 1
    Endif

    GPOINT="INIMATFLG"
    Gosub ENTREE From EXEFNC

    If LMATFLG=0
        Call LOADBOM(LRET) From SUBCSTB
        If LRET
            Call ECRTRACE([F:MAW]ITMREF-[F:MAW]STOFCY-": (BOM-"+num$(LRET)+")"-GMESSAGE,1) From TRTCST
            Raz GMESSAGE
            Goto NEXT_MAW
        Endif
        If LROUFLG
            Call LOADROU(LRET) From SUBCSTB
            If LRET
                Call ECRTRACE([F:MAW]ITMREF-[F:MAW]STOFCY-":(ROU-"+num$(LRET)+")"-GMESSAGE,1) From TRTCST
                Raz GMESSAGE
                Goto NEXT_MAW
            Endif
        Endif
    Elsif LMATFLG=1
        Raz [M:SDP]
        If PSLTMAT=8
            LPRI = func STKVAL.GETPRITAR([M:CST]ITMREF(0),[M:CST]IECCVALMAJ(0),[M:CST]IECCVALMIN(0),[M:CST0]STOFCY, [M:CST0]STOFCY, [M:CST]IQTYSTU(0), [M:CTP]CLCDAT, [M:CTP]CLCDAT+[F:ITM]OFS, "", "" )
        Else
            # PSLTMAT  --> LCSTCOD
            # Menu 384 --> 480
            Case PSLTMAT
                When 1,2    : LCSTCOD = PSLTMAT     # Std ou std actualisé
                When 3,4    : LCSTCOD = PSLTMAT+7   # Std budget ou simulé
                When 7      : LCSTCOD = 9           # Dernier prix d'achat
                When Default: LCSTCOD = PSLTMAT-2   # Dernier prix et PMP
            Endcase
            Call GETPRI([M:CST]ITMREF(0),[M:CST]IECCVALMAJ(0),[M:CST]IECCVALMIN(0),[M:CST0]STOFCY,[M:CTP]CLCDAT,adxuid(1),"","",LCSTCOD,LPRI,LRET) From STKVAL
            # Issue 84715 - 2012-11-27 by CCC
            # (DM 19829) Dans le cas du calcul de coût standard, si on ne trouve pas de prix pour la matière on se rabat sur le coût standard existant
            If LPRI=0
                Call ECRTRACE(mess(386,197,1) - ":"- [M:CST]ITMREF,0) From TRTCST # Valorisation nulle pour la matière (valeur de repli : coût standard)
                If LCSTCOD<>1
                    Call GETPRI([M:CST]ITMREF(0),[M:CST]IECCVALMAJ(0),[M:CST]IECCVALMIN(0),[M:CST0]STOFCY,[M:CTP]CLCDAT,adxuid(1),"","",1,LPRI,LRET) From STKVAL
                Endif
            Endif
        Endif
        If !LRET
            Call COPSDP2CST("I",[M:CST]NBITM-1,0,[M:CST]IQTYSTU(0)) From TRTCST
            [M:CST]IMATLEV0(0) = sigma(0,GACTMAT-1,[M:CST]IMATCST(indcum) + [M:CST]ISMATCST(indcum))
            [M:CST]IFMATLEV0(0) = sigma(0,GACTMAT-1,[M:CST]IFMATCST(indcum) + [M:CST]IFSMATCST(indcum))
            Raz [M:CST]IOVEMATCST,[M:CST]IOVEMACCST,[M:CST]IOVELABCST,[M:CST]IOVESCOCST
        Endif
    Endif

    [M:CTP]NIV       = 1
    # CCC (2010-05-19) Bug 64883 : Imposer le coût standard comme méthode de valo du sous-produit
    For I=0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(I)=2
            # Issue 66059 - 2010-08-16 by CCC : Le menu local de la valo des sous-produits est 705 et non pas 480
            Case [M:DIA]CSTTYPA
                When "STD" : [M:CST]ICSTCOD(I) = 1+1
                When "CUT" : [M:CST]ICSTCOD(I) = 2+1
                When "BUD" : [M:CST]ICSTCOD(I) = 10+1
                When "SIM" : [M:CST]ICSTCOD(I) = 11+1
            Endcase
        Endif
    Next
    For I=0 To [M:CST]NBMAT-1
        Case [M:DIA]CSTTYPA
            When "STD" : [M:CST]MCSTCOD(I) = 1
            When "CUT" : [M:CST]MCSTCOD(I) = 2
            When "BUD" : [M:CST]MCSTCOD(I) = 10
            When "SIM" : [M:CST]MCSTCOD(I) = 11
        Endcase
    Next
    For I=0 To [M:CST]NBWST-1
        [M:CST]WRATCOD(I) = PVLTCCE
    Next
    For I=0 To [M:CST]NBSCO-1
        [M:CST]SRATCOD(I) = PVLTCCE
        If [M:CST]PRISCO(I)=0
            Case PSLTMAT
                When 1,2: [M:CST]SCSTCOD(I) = PSLTMAT
                When 3,4: [M:CST]SCSTCOD(I) = PSLTMAT+7
            Endcase
        Endif
    Next

    If GSTOTRACE=4
        Call PRTSCR("CLCCST", "", "", 0, 1) From ATRTX3
    Endif

    Call CLCCST  From TRTCST

    If clalev([M:DIA])
        Call SAVITC(PCSTTYP,[M:DIA]FIYNUM,[M:DIA]ITCSTRDAT,[M:DIA]ITCENDDAT,[M:DIA]MAJ,[M:DIA]SLTMATCST,[M:DIA]VLTCCERAT,[M:DIA]DESCEND,LRET) From TRTCOST
    Else
        Call SAVITC(PCSTTYP,0,PDAT,PDAT,1,PSLTMAT,PVLTCCE,PDESC,LRET) From TRTCOST
    Endif
    If LRET : Break : Endif

    [M:CTP]NIV       = 2
    Call CLCCST  From TRTCST

    If clalev([M:DIA])
        Call SAVITC(PCSTTYP,[M:DIA]FIYNUM,[M:DIA]ITCSTRDAT,[M:DIA]ITCENDDAT,[M:DIA]MAJ,[M:DIA]SLTMATCST,[M:DIA]VLTCCERAT,[M:DIA]DESCEND,LRET) From TRTCOST
    Else
        Call SAVITC(PCSTTYP,0,PDAT,PDAT,1,PSLTMAT,PVLTCCE,PDESC,LRET) From TRTCOST
    Endif
    If LRET : Break : Endif

    Call SAVICN(LRET) From TRTCOST
    If LRET : Break : Endif

    Call SAVICC(LRET) From TRTCOST
    If LRET : Break : Endif

    Call SAVIWC(LRET) From TRTCOST
    If LRET : Break : Endif

    GPOINT = "APCLCITC"
    Gosub ENTREE From EXEFNC
    $NEXT_MAW
Next

Filter [MAW]

Filter [ITC]

End


$FIN_CLC

GPOINT="FINCLCICC"
Gosub ENTREE From EXEFNC

# Mise à jour immédiate de la table ITC #
# ------------------------------------- #
If [M:DIA]MAJ = 3
  If NB_ERR > 0
    # "Le résultat est resté dans la table provisoire"
    ERR_TRA = mess(134,197,1)
    Call ECR_TRACE(ERR_TRA,0)
    Return
  Endif

  Local Decimal OLD_CST
  Local Date    OLD_DAT
  Local Decimal PHY_STO      # pour l'interface des coûts std (29/03/01)

  If clalev([F:ITC2]) <= 0 Local File ITMCOST [ITC2] Endif # pour recherche
  If clalev([F:ITCW]) <= 0 Local File ITMCOST [ITCW] Endif # pour écriture ITC définitif
  MAJ_OK = 0

  Trbegin [ITCW]
# transfert des enregistrements provisoires qui ont le flag Màj=immédiate
# pour éviter de passer des enregistrements provisoires d'un autre lancement
  For [ITC] Where STOFCY = [M:DIA]STOFCY & CSTTYP = [M:DIA]CSTTYP & UPDFLG = 3 & UID=adxuid(1)
      Call UPDITC([M:DIA]RPLPRVCST<>2,MAJ_OK)
      If MAJ_OK : Break : Endif
  Next

  If MAJ_OK <> 0
    ERR_TRA = mess(13,100,1) - "ITMCOST"
    ERR_TRA -= [M:DIA]STOFCY - [F:ITC]ITMREF - num$([F:ITC]ITCSEQ)
    Call ECR_TRACE(ERR_TRA,1)
    # "Le résultat est resté dans la table"
    ERR_TRA = mess(134,197,1)
    Call ECR_TRACE(ERR_TRA,1)
    Rollback
  Else

    Commit
  Endif
Endif

Return

$TERMINE
# Si on vient du configurateur
If clalev([M:CFV4]) <> 0
  Gosub CFG_CSTTERMINE From CFGLIBD
Endif
# sr 10.02 n'imprimer que si quelque chose a été traité demande 16083
# sr 10.02 RAPPEL : même si pas d'article saisi mais filtre, on a renseigne [M:DIA]ITMREF avec le
# sr 10.02 1er article traité (demande 15841).Donc si rien de traité, rien dans [M:DIA]ITMREF
If !GSERVEUR & clalev([M:CFV4]) = 0
   If  [M:DIA]ITMREF <> ""
       Call FERME_TRACE From LECFIC
       If !GINTRA
           Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
           Raz GBIDI1
           If [M:DIA]MAJ<>3
               GBIDI1+=1 : TBPAR(GBIDI1) = "uid" : TBVAL(GBIDI1) = num$(adxuid(1))
           Endif
           #GBIDI1+=1 : TBPAR(GBIDI1) = "prnuid": TBVAL(GBIDI1) = num$(adxuid(1))  # Issue 74298 - 2011-10-04 by CCC
           GBIDI1+=1 : TBPAR(GBIDI1) = "prnuid": TBVAL(GBIDI1) = num$([M:CTP]PRNNUM)  # GH 19/03/2014 bug 86229

           GPE = 0
           # CCC 22/06/04 : Demande PE 22340 reportée en 140 au cas où
           GPOINT = "ITCIMP" : Gosub ENTREE From EXEFNC
           If !GPE
               Call ETAT("ITMCOST","CALCSTSTD",TBPAR,TBVAL) From ETAT
           Endif
       Endif
       SAI = 1
       TRA = 1
   Else
       Call MESSAGE(mess(104,199,1)) From GESECRAN
       TRA = 0
   Endif
Endif

$UNLCK_SYM
# débloquer le verrou d'exclusivité sur le site
If [M:DIA]DESCEND = 2 | [M:DIA]TOUS >= 2
  SYMBOLE = "ITCCLC" + [M:DIA]STOFCY
  Unlock =SYMBOLE
Endif
Return

########################################
# <MG> Pour redirection erreurs dans configurateur
Subprog ECR_TRACE(TEX,ERR)
Value    Char    TEX() : # Texte du message
Value    Integer ERR   : # 0=Information, <>0=Erreur
If clalev([M:CFV4]) > 0
  Call CFG_CSTERR(TEX,ERR) From CFGLIBD
Else
  Call ECR_TRACE(TEX,ERR) From GESECRAN
Endif
End
########################################
# ACTIONS SUR ZONES DE SELECTIONS
########################################
Subprog B2_ITMREF(VALEUR)
Variable Char  VALEUR
End
########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   # controler que l'article-site existe
   Call CONTROLE("ITF","",[M:DIA]STOFCY,VALEUR,mkstat) From CONTOBJ
   If mkstat End Endif

   # controler que l'article n'a pas un code 'Saisi' pour ce type de cout
   Read [ITF]ITF0 = VALEUR;[M:DIA]STOFCY
   If evalue("[F:ITF]"+[M:DIA]CSTTYPA+"CSTUPD") = 2
     GMESSAGE = mess(131,197,1)
     mkstat = 2
   Else
     If [M:DIA]ROUALT = 0
       [M:DIA]ROUALT = [F:ITF]CSTROUALT  # (si elle n'est pas déjà renseignée)
       Affzo ROUALT
     Endif
   Endif
   [M:DIA]TOUS = 1
   Raz [M:DIA]FILART # et effacer la réf article si on veut faire un filtre !
   Actzo DESCEND, CLCQTY
#Elsif [M:DIA]FILART <> "" & [M:DIA]STAFLT = 1  ## oté 15/01/02
#   [M:DIA]TOUS = 3 : Affzo TOUS : Effzo ITMREF, ZITMREF
#   If !GINTRA  zonsui = "YEA" Endif
#   [M:DIA]DESCEND = 1
#   Affzo DESCEND
#   Grizo DESCEND, CLCQTY
Else
    GMESSAGE = mess(184,199,1)
    mkstat = 2
Endif
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ITM",VALEUR,"") From CONTOBJ
[M:DIA]STU  = [F:ITM]STU
[M:DIA]STU2 = [F:ITM]STU
If VALEUR <> ""
    Call CTLREW([M:DIA]STOFCY,VALEUR,[M:DIA]CSTTYP,[M:DIA]ITCSTRDAT,[M:DIA]ITCENDDAT)
Else
#     Dans le cas d'une sélection ou du lancement de TOUS les articles :
#     "Si un des coûts correspondant à ces sélections existe déjà, il sera écrasé à la mise à jour du calcul"
    GMESSAGE = mess(233,199,1) : GERR = 2
Endif

# affecter la qté de calcul... pour correction du 18584 (13/06/03)
If VALEUR <> ""
  Call LECTURE("ITF",[M:DIA]STOFCY,VALEUR) From CONTOBJ # sûrement en ligne !
  If [F:ITF]REOMINQTY <> 0
    [M:DIA]CLCQTY = [F:ITF]REOMINQTY/(([F:ITM]DEFPOT=0)+[F:ITM]DEFPOT/100)
  Elsif [F:ITF]MFGLOTQTY > 0
    [M:DIA]CLCQTY = [F:ITF]MFGLOTQTY/(([F:ITM]DEFPOT=0)+[F:ITM]DEFPOT/100) :# calcul pour le lot technique
  Else
    [M:DIA]CLCQTY = 1
  Endif
  Affzo [M:DIA]CLCQTY
Endif

Call AM_ITMREF(VALEUR) From SUBICCECC
End
########################################
Subprog C_ITCDAT(VALEUR)
Variable Date     VALEUR
# Issue 84066 - 2014-07-03 by CCC : ITCDAT has to be between ITCSTRDAT and ITCENDDAT
#If VALEUR < date$
#    If !(GBATCH & VALEUR=[0/0/0])
#        mkstat = 2
#    Endif
#Endif
If VALEUR < [M:DIA]ITCSTRDAT or [M:DIA]ITCENDDAT < VALEUR
    GMESSAGE = mess(1,104,1)
    mkstat=2
Endif
End

########################################
Subprog AS_ROUALT(VALEUR)
Variable Decimal  VALEUR
If GMODU(8) < 2 | [M]BOMALTTYP<>2 mkstat = 2  Endif
End
########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal  VALEUR
Local    Integer  BOM_OK, I, T_ALT(3), T_USE(3)

If VALEUR <> 0
    If [F:TRO]FCY <> "" & [F:TRO]FCY <> [M:DIA]STOFCY
      mkstat=2 : GMESSAGE = mess(48,193,1) : End
    Endif

    # "Alternative non utilisable pour les coûts"
    If [F:TRO]CSTUSE <> 2
      mkstat=2 : GMESSAGE = mess(141,193,1) : End
    Endif

    I = 0
    If [F:TRO]BOMALT1 <> 0
     Read [TBO]TBO0 = 2;[F:TRO]BOMALT1
     If [F:TBO]FCY = "" or [F:TBO]FCY = [M:DIA]STOFCY
       T_ALT(I) = [F:TRO]BOMALT1
       T_USE(I) = [F:TBO]CSTUSE
       I += 1
     Endif
    Endif
    If [F:TRO]BOMALT2 <> 0
     Read [TBO]TBO0 = 2;[F:TRO]BOMALT2
     If [F:TBO]FCY = "" or [F:TBO]FCY = [M:DIA]STOFCY
       T_ALT(I) = [F:TRO]BOMALT2
       T_USE(I) = [F:TBO]CSTUSE
       I += 1
     Endif
    Endif
    If [F:TRO]BOMALT3 <> 0
     Read [TBO]TBO0 = 2;[F:TRO]BOMALT3
     If [F:TBO]FCY = "" or [F:TBO]FCY = [M:DIA]STOFCY
       T_ALT(I) = [F:TRO]BOMALT3
       T_USE(I) = [F:TBO]CSTUSE
     Endif
    Endif

    If T_ALT(0) = 0
       #  AUCUNE alternative de nomenclature n'est valide pour le site sélectionné"
          Effzo BOMALT
          GMESSAGE = mess(141,197,1)
          mkstat = 2
          End
    Endif

    #  Vérifier que l'usage de l'alternative vaut 2(OUI) bug 5802 (24/07/2000)
    #  vider l'alternative du tableau si elle ne convient pas
    If T_USE(0) = 1
      Raz T_ALT(0)
    Else
      [M:DIA]BOMALT = T_ALT(0)
    Endif
    If T_USE(1) = 1
      Raz T_ALT(1)
    Elsif [M:DIA]BOMALT=0
      [M:DIA]BOMALT = T_ALT(1)
    Endif
    If T_USE(2) = 1
      Raz T_ALT(2)
    Elsif [M:DIA]BOMALT=0
      [M:DIA]BOMALT = T_ALT(2)
    Endif

    If sum(T_ALT) = 0
      # "Aucune alternative pour ce site n'est dédiée aux coûts"
      GMESSAGE = mess(345,197,1)
      mkstat = 2
    Endif

    If [M:DIA]ITMREF = "" Affzo BOMALT : End Endif
    Actzo DESCEND

    # vérifier l'existence de la nomenclature     (modif 12/05/00)
    For I = 0 To 2
     Read [BOH]BOH0= [M:DIA]ITMREF;T_ALT(I);2
     If !fstat & [F:BOH]BOHSTRDAT <= [M:DIA]ITCDAT & ([F:BOH]BOHENDDAT > [M:DIA]ITCDAT | [F:BOH]BOHENDDAT=[0/0/0])
        BOM_OK = 1
        Break
     Endif
    Next I

    If BOM_OK = 0
        # Pas de nomenclature associée à cette gamme !
        GMESSAGE = mess(200,193,1)
        mkstat = 2
    Else
       [M:DIA]BOMALT = [F:BOH]BOMALT : # l'entête lue avec succès
       Affzo BOMALT
    Endif

Elsif [M]BOMALTTYP=2
#   pas de gamme : "Attention valorisation de matière seulement ou calcul sur nomenclature!"
    GMESSAGE = mess(209,199,1) : GERR = 2
###    [M:DIA]DESCEND = 1
###    Effzo [M:DIA]BOMALT, ZBOMALT  # pour éviter ambiguité (30/08/00)
###    Grizo DESCEND  # oté pour permettre saisie   (bug 8374)
Endif
End

########################################
Subprog D_TOUS(VALEUR)
Variable Integer VALEUR
    Call AM_TOUS(VALEUR)
End

Subprog AM_TOUS(VALEUR)
Variable Integer VALEUR
If VALEUR >= 2
    [M:DIA]DESCEND = 1 : [M:DIA]CLCQTY = 0
    Affzo DESCEND
    Grizo DESCEND, CLCQTY
    Effzo ITMREF
    Grizo [M:DIA]ITMREF
    If VALEUR=2
        Effzo [M:DIA]FILART
        Grizo [M:DIA]FILART
    Else
        Actzo [M:DIA]FILART
    Endif
Else
    Actzo [M:DIA]ITMREF
    Actzo DESCEND, CLCQTY
    Effzo [M:DIA]FILART
    Grizo [M:DIA]FILART
Endif

Call AM_TOUS(VALEUR) From SUBICCECC
End



Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
    # Cela ne fonctionne pas dans INIT_DIA
    If find([M:DIA]CSTTYPA,"STD","BUD")
        Grizo [M:DIA]ITCSTRDAT,ITCENDDAT
    Endif
    If clalev([M:ICD0]) | clalev([M:ICA0])
        Diszo [M:DIA]ITMREF,STOFCY,TOUS
        If dim([M:DIA]ECCVALMAJ)>0
            Diszo [M:DIA]ECCVALMAJ,ECCVALMIN
        Endif

        mkstat=2
    Endif
    If [M:DIA]MAJ<3
        [M:DIA]RPLPRVCST = 1
        Diszo [M:DIA]RPLPRVCST
    Endif

    # Issue X3-55212: To ensure proper screen setup, call these two screen actions
    # when coming from recurring tasks. Are not called during normal flow in that case
    If GBATCH & dim([M:DIA]ECCVALMAJ)>0
      Local Integer LACTMAJ, LACTMIN, LECC
      If [M:DIA]ITMREF<> "" : LECC = func ECCLIB.NBRCPNCST([M:DIA]ITMREF) : Endif
      Case LECC
        When 0 : LACTMAJ = 0 : LACTMIN = 0
        When 1 : LACTMAJ = 1 : LACTMIN = 0
        When 2 : LACTMAJ = 1 : LACTMIN = 1
      Endcase
      If !LACTMAJ : Grizo [M:DIA]ECCVALMAJ : Endif
      If !LACTMIN : Grizo [M:DIA]ECCVALMIN : Endif
    Endif

End

########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

Call GLOBVAR(VALEUR) From WWGLOBGPA : # pour charger les valeurs de paramètres
If [M:DIA]CSTTYP=1 | [M:DIA]CSTTYP=3
    If [M:DIA]ITMREF <> ""
        Call CTLREW(VALEUR,[M:DIA]ITMREF,[M:DIA]CSTTYP,[M:DIA]ITCSTRDAT,[M:DIA]ITCENDDAT)
    Elsif [M:DIA]TOUS > 1
#     Dans le cas d'une sélection ou du lancement de TOUS les articles :
#     "Si un des coûts correspondant à ces sélections existe déjà, il sera écrasé à la mise à jour du calcul"
        GMESSAGE = mess(233,199,1) : GERR = 2
    Endif

    Read [FIY]FIY0=GSOCIETE;1;[M:DIA]FIYNUM
    If fstat | [F:FIY]FIYEND<date$
        Call GETEXE(GSOCIETE,GTYPGEN,date$,[M:DIA]FIYNUM) From CPTSUB
        [M:DIA]ITCSTRDAT=date$
        Call DATEXE(GSOCIETE,GTYPGEN,[M:DIA]FIYNUM,GBIDA1,[M:DIA]ITCENDDAT) From CPTSUB
        Affzo [M:DIA]ITCSTRDAT,ITCENDDAT,FIYNUM
    Endif
Endif

# Issue 87576 - 2015-04-08 by JUSYN : Initialisation of cost fields has to be done when screen first opens but when site changes as well.
Call INIT_COST_CALC(VALEUR)

End

########################################
Subprog AV_CLCQTY(VALEUR)
Variable Decimal  VALEUR
# "initialiser" par la qté de lot economique
If VALEUR = 0 & [M:DIA]ITMREF <> ""
  Call LECTURE("ITF",[M:DIA]STOFCY,[M:DIA]ITMREF) From CONTOBJ # sûrement en ligne !
  If [F:ITF]REOMINQTY <> 0
    VALEUR = [F:ITF]REOMINQTY/(([F:ITM]DEFPOT=0)+[F:ITM]DEFPOT/100)
  Elsif [F:ITF]MFGLOTQTY > 0
    VALEUR = [F:ITF]MFGLOTQTY/(([F:ITM]DEFPOT=0)+[F:ITM]DEFPOT/100) :# calcul pour le lot technique
  Else
    VALEUR = 1
  Endif
Endif
End


########################################
Subprog AS_ITCDAT(VALEUR)
Variable Date    VALEUR
End

########################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
    [M:DIA]DESCEND = 1 # Issue 103831 - 2014-12-12 by ALSHE
    Affzo DESCEND      # Issue 103831 - 2014-12-12 by ALSHE
    Grizo DESCEND
    If [M:DIA]TOUS >= 2
      mkstat = 2 # il en faut une obligatoirement pour les LLC
    Endif
    End
Elsif [M:DIA]TOUS=1     # CCC 2014-05-21 : DESCEND field can be activated only if calculation is from a unique product
    Actzo DESCEND      # Issue 103831 - 2014-12-12 by ALSHE
Endif
# recherche de la nomenclature  !!Attention sous-pro réutilisé en CONTROLE !
Read [TBO]TBO0=[M:DIA]BOMALTTYP;VALEUR
If [F:TBO]FCY <> "" & [F:TBO]FCY <> [M:DIA]STOFCY
   GMESSAGE = mess(48,193,1) : mkstat = 2 : End
Endif
If [F:TBO]CSTUSE < 2
   GMESSAGE = mess(141,193,1) : mkstat = 2 : End
Endif
If [M:DIA]ITMREF <> ""
  Read [BOH]BOH0= [M:DIA]ITMREF;VALEUR;[M:DIA]BOMALTTYP
  If fstat
     GMESSAGE = mess(95,193,1) :   GERR=1
  Elsif ([F:BOH]BOHSTRDAT <> [0/0/0] & [F:BOH]BOHSTRDAT > [M:DIA]ITCDAT)
&     | ([F:BOH]BOHENDDAT < [M:DIA]ITCDAT & [F:BOH]BOHENDDAT<>[0/0/0])
     GMESSAGE = mess(54,199,1) # "Nomenclature pas valide à la date indiquée"
  Endif
Endif
If GMESSAGE<>""  mkstat = 2 Endif
End

##################################################
Subprog INITCCE(TABCCE)
Variable Char TABCCE

Local Integer I
Local Char    LSEC(GLONCCE)
    # Issue 77417 - 2012-02-01 by CCC
    #For I=1 To max(GNBDIE,GOPTCANA)
    For I=1 To GNBDIE
        # Issue 76083 - 2011-09-22 by CCC
        #Call INISEC (LSEC, "STJVALAUT", num$(I)) From SUBCDE
        Raz LSEC
        Call INISEC (LSEC, "STJVALAUT", I) From TRTX3CPT
        TABCCE(I-1) = LSEC
    Next
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ITCCLC0) 16/02/2006 17:37:14 (CCC)
######################################################################################
Subprog C_FIYNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : Raz [F:FIY] : End : Endif
Call GETSOC([M:DIA]STOFCY) From DEVSUB
Read [FIY]FIY0=GSOCIETE;1;VALEUR
If fstat
    GMESSAGE = mess(6,199,1)
    mkstat = 2
    End
Endif
If [F:FIY]FIYEND<date$
    GMESSAGE = mess(6,199,1)
    mkstat = 2
    End
Endif

If [M:DIA]TOUS=1
    Call C_FIYNUM(VALEUR) From SUBICDECC
Endif
End

Subprog AM_FIYNUM(VALEUR)
Variable Decimal VALEUR
If [F:FIY]FIYSTR<>[0/0/0]
    [M:DIA]ITCSTRDAT = max(date$,[F:FIY]FIYSTR)
    [M:DIA]ITCENDDAT = [F:FIY]FIYEND
    Affzo [M:DIA]ITCSTRDAT,ITCENDDAT
    Call CTLREW([M:DIA]STOFCY,[M:DIA]ITMREF,[M:DIA]CSTTYP,[M:DIA]ITCSTRDAT,[M:DIA]ITCENDDAT)
Endif

If [M:DIA]TOUS=1
    Call AM_FIYNUM(VALEUR) From SUBICDECC
Endif
End

Subprog C_ITCSTRDAT(VALEUR)
Variable Date    VALEUR

If [M:DIA]TOUS=1
    Call C_ITCSTRDAT(VALEUR) From SUBICDECC
Endif

End

Subprog AM_ITCSTRDAT(VALEUR)
Variable Date    VALEUR
    If [M:DIA]ITCENDDAT<VALEUR
        If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif

        Call GETSOC([M:DIA]STOFCY) From DEVSUB
        Filter [FIY] Where CPY=GSOCIETE & FIYSTR<=VALEUR & FIYEND>=VALEUR
        Read [FIY] First
        If !fstat
            [M:DIA]ITCENDDAT = [F:FIY]FIYEND
        Else
            Case [M:DIA]CSTTYPA
                When "STD", "BUD"
                    [M:DIA]ITCENDDAT = [M:DIA]ITCSTRDAT+365
                When "CUT", "SIM"
                    [M:DIA]ITCENDDAT = [M:DIA]ITCSTRDAT+30
            Endcase
        Endif
    Endif
Affzo [M:DIA]ITCENDDAT
End

Subprog C_ITCENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <= [M:DIA]ITCSTRDAT | VALEUR<date$
    GMESSAGE = mess(6,199,1)
    mkstat = 2
    End
Endif
End


######################################################################################
Subprog C_BOMALTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 0
    If [M:DIA]TOUS >= 2
      mkstat = 2 # il en faut une obligatoirement pour les LLC
    Endif
    End
Endif

If VALEUR<>2
    Effzo [M:DIA]ROUALT
Endif

If [M:DIA]BOMALT=0 End Endif

# recherche de la nomenclature  !!Attention sous-pro réutilisé en CONTROLE !
Read [TBO]TBO0=VALEUR;[M:DIA]BOMALT
If [F:TBO]FCY <> "" & [F:TBO]FCY <> [M:DIA]STOFCY
   GMESSAGE = mess(48,193,1) : mkstat = 2 : End
Endif
If [F:TBO]CSTUSE < 2
   GMESSAGE = mess(141,193,1) : mkstat = 2 : End
Endif
If [M:DIA]ITMREF <> ""
  Read [BOH]BOH0= [M:DIA]ITMREF;[M:DIA]BOMALT;VALEUR
  If fstat
     GMESSAGE = mess(95,193,1) : GERR=1
  Elsif ([F:BOH]BOHSTRDAT <> [0/0/0] & [F:BOH]BOHSTRDAT > [M:DIA]ITCDAT)
&     | ([F:BOH]BOHENDDAT < [M:DIA]ITCDAT & [F:BOH]BOHENDDAT<>[0/0/0])
     GMESSAGE = mess(54,199,1) # "Nomenclature pas valide à la date indiquée"
  Endif
Endif
#If GMESSAGE<>""  mkstat = 2 Endif
End


######################################################################################


######################################################################################

$BB2_FILART
Affzo [M]FILART
Return

######################################################################################
Subprog C_FILART(VALEUR)
Variable Char    VALEUR()
 Local Integer I , K , ER
 Local Char    CHAINE(80)
 For I=1 To [M:DIA]NBTBL
  Read [ATB]CODFIC=[M:DIA]TBTBL(I)
  If ([M:DIA]ABTBL(I)="" | ([M:DIA]ABTBL(I)=[F:ATB]ABRFIC)) & evalue("clalev([F:"+[F:ATB]ABRFIC+"])")=0
   Local File =[M:DIA]TBTBL(I)
  Endif
 Next I
 Default File [ITM] : # Pour l'avoir par défaut
 Default [F] , [V] , [L] , [S]
 Onerrgo ERREXP
 ER = 0
 K = evalue([L]VALEUR)
 Onerrgo
 If ER
  mkstat = 2 : End
 Endif

End

$ERREXP
ER = errn
GMESSAGE = mess(37,124,1)+"\"+errmes$(ER)+"\"+errm
ER=1
# Expression incorrecte
Resume



######################################################################################
Subprog CTLREW(PFCY,PITM,PTYP,PSTR,PEND)
Value Char    PFCY
Value Char    PITM
Value Integer PTYP
Value Date    PSTR
Value Date    PEND

    Filter [ITC] Where STOFCY = PFCY
&                    & ITMREF = PITM
&                    & CSTTYP = PTYP
&                    & UID    = 0
&                    & ITCSTRDAT<=PEND
&                    & ITCENDDAT>=PSTR    # c'est bien croisé !
    Look [ITC] First
    Filter [ITC]
    If !fstat
        #  "Le coût existe déjà, il sera écrasé à la mise à jour du calcul"
        GMESSAGE = mess(232,199,1) : GERR = 2
    Endif

End

Subprog AS_BOMALTTYP(VALEUR)
Variable Integer  VALEUR
    GMENLOC(1)=1
End


##################################################################################
#**
#* Passe le champ UID d'un coût standard à 0
#*
#* @param PNEW (E) : indique si l'activation du coût doit obligatoirement créer un nouveau n° de séquence
#* @param PERR (S) : code erreur (0=OK; 1=Erreur)
#*<pre>
#* Les tables suivantes doivent de préférence être ouvertes:
#*   ITM;ITF;ITG;ITCW;ICC;ICCW;ICN;ICNW;IWC;IWCW
#* La table ITC doit être chargée
#* </pre>
#*!
Subprog UPDITC(PNEW,PERR)
Value Integer PNEW
Variable Integer PERR

Local Char TABCCE(GLONCCE)(max(GNBDIE,GOPTCANA,1))    # +1 pour éviter un éventuel problème si GOPTCANA=0
Local Integer LITCSEQ

Raz PERR

If !clalev([F:ITM])  : Local File ITMMASTER   [ITM]  : Endif
If !clalev([F:ITF])  : Local File ITMFACILIT  [ITF]  : Endif
If !clalev([F:ITG])  : Local File ITMCATEG    [ITG]  : Endif
If !clalev([F:TCM])  : Local File TABCOSTMET  [TCM]  : Endif
If !clalev([F:ITG])  : Local File ITMCATEG    [ITG]  : Endif
If !clalev([F:ITCW]) : Local File ITMCOST     [ITCW] : Endif
If !clalev([F:ICNW]) : Local File ITCNAT      [ICNW] : Endif
If !clalev([F:ICC])  : Local File ITCMAT      [ICC]  : Endif
If !clalev([F:ICCW]) : Local File ITCMAT      [ICCW] : Endif
If !clalev([F:IWC])  : Local File ITCWST      [IWC]  : Endif
If !clalev([F:IWCW]) : Local File ITCWST      [IWCW] : Endif

    If [F:ITM]ITMREF<>[F:ITC]ITMREF
        Read [ITM]ITM0 = [F:ITC]ITMREF
    Endif
    If [F:ITF]ITMREF<>[F:ITC]ITMREF | [F:ITF]STOFCY<>[F:ITC]STOFCY
        Read [ITF]ITF0=[F:ITC]ITMREF;[F:ITC]STOFCY
    Endif
    If [F:ITG]TCLCOD<>[F:ITM]TCLCOD
        Read [ITG]ITG0="";[F:ITM]TCLCOD # enreg utile pour la màj stock (chgt valeur)
    Endif
    Call GETTCM([F:ITC]ITMREF,[F:ITC]STOFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM], nécessaire pour conditionner le mvt chgt valeur

    #---- Génération d'un mvt de changement de valeur ou d'un enreg SMI pour création ultérieure du mvt --#
    If find([F:ITC]CSTTYP,[F:TCM]ISSVLTCOD,[F:TCM]ISSVLTCOD(1)) & find([F:ITC]CSTTYP,1,2)
        # Issue 88698 - 2013-03-18 by CCC
        Call GETCPY([F:ITC]STOFCY,"",0,"") From TRTX3CPT

        Call INITCCE(TABCCE)

        Call STK_CHG_VAL(([F:TCM]ISSVLTCOD=[F:ITC]CSTTYP xor [F:TCM]ISSVLTCOD(1)=[F:ITC]CSTTYP)+([F:TCM]ISSVLTCOD(1)=[F:ITC]CSTTYP),TABCCE) From SUBITCB
        If GOK < 1
           # "Erreur à la génération du mouvement de changement de valeur"
           ERR_TRA = mess(200,199,1)
           Call ECR_TRACE(ERR_TRA,1)
           PERR = 1
           End
        Endif
    Endif

    If !PNEW
        LITCSEQ = func GETITCSEQ([F:ITC]STOFCY,[F:ITC]ITMREF,[F:ITC]CSTTYP,[F:ITC]ITCSTRDAT,[F:ITC]ITCENDDAT,[F:ITC]ECCVALMAJ,[F:ITC]ECCVALMIN)
    Endif
    If PNEW | LITCSEQ = 0 | LITCSEQ = [F:ITC]ITCSEQ
        LITCSEQ = [F:ITC]ITCSEQ
    Endif

        # Effacement de l'ancien coût
        Delete [ITCW] Where [ITCW]STOFCY = [F:ITC]STOFCY
&                         & [ITCW]ITMREF = [F:ITC]ITMREF
&                         & [ITCW]CSTTYP = [F:ITC]CSTTYP
&                         & [ITCW]ITCSEQ = LITCSEQ
&                         & [ITCW]UID    = 0

        Delete [ICNW] Where [ICNW]STOFCY = [F:ITC]STOFCY
&                         & [ICNW]ITMREF = [F:ITC]ITMREF
&                         & [ICNW]CSTTYP = [F:ITC]CSTTYP
&                         & [ICNW]ITCSEQ = LITCSEQ
&                         & [ICNW]UID    = 0

        Delete [ICCW] Where [ICCW]STOFCY = [F:ITC]STOFCY
&                         & [ICCW]ITMREF = [F:ITC]ITMREF
&                         & [ICCW]CSTTYP = [F:ITC]CSTTYP
&                         & [ICCW]ITCSEQ = LITCSEQ
&                         & [ICCW]UID    = 0

        Delete [IWCW] Where [IWCW]STOFCY = [F:ITC]STOFCY
&                         & [IWCW]ITMREF = [F:ITC]ITMREF
&                         & [IWCW]CSTTYP = [F:ITC]CSTTYP
&                         & [IWCW]ITCSEQ = LITCSEQ
&                         & [IWCW]UID    = 0

    Update [ITCW] Where [ITCW]STOFCY = [F:ITC]STOFCY
&                     & [ITCW]ITMREF = [F:ITC]ITMREF
&                     & [ITCW]CSTTYP = [F:ITC]CSTTYP
&                     & [ITCW]ITCSEQ = [F:ITC]ITCSEQ
&                     & [ITCW]UID    = [F:ITC]UID
&                 With ITCSEQ = LITCSEQ, UID = 0

    Update [ICNW] Where [ICNW]STOFCY = [F:ITC]STOFCY
&                     & [ICNW]ITMREF = [F:ITC]ITMREF
&                     & [ICNW]CSTTYP = [F:ITC]CSTTYP
&                     & [ICNW]ITCSEQ = [F:ITC]ITCSEQ
&                     & [ICNW]UID    = [F:ITC]UID
&                 With ITCSEQ = LITCSEQ, UID = 0

    Update [ICCW] Where [ICCW]STOFCY = [F:ITC]STOFCY
&                     & [ICCW]ITMREF = [F:ITC]ITMREF
&                     & [ICCW]CSTTYP = [F:ITC]CSTTYP
&                     & [ICCW]ITCSEQ = [F:ITC]ITCSEQ
&                     & [ICCW]UID    = [F:ITC]UID
&                 With ITCSEQ = LITCSEQ, UID = 0

    Update [IWCW] Where [IWCW]STOFCY = [F:ITC]STOFCY
&                     & [IWCW]ITMREF = [F:ITC]ITMREF
&                     & [IWCW]CSTTYP = [F:ITC]CSTTYP
&                     & [IWCW]ITCSEQ = [F:ITC]ITCSEQ
&                     & [IWCW]UID    = [F:ITC]UID
&                 With ITCSEQ = LITCSEQ, UID = 0

    If GSTOTRACE=4
        Call ECR_TRACE([F:ITC]ITMREF-[F:ITC]STOFCY-[F:ITC]ECCVALMAJ-[F:ITC]ECCVALMIN-"ITCSEQ : "+num$([F:ITC]ITCSEQ)-"-->"-num$(LITCSEQ),0) From GESECRAN
    Endif

    # On affecte les nouvelles valeurs à la classe [F:ITC] pour quelles soient connues ensuite
    [F:ITC]ITCSEQ = LITCSEQ
    [F:ITC]UID    = 0

    # Dem 20484 et 22000 Pour mises à jour spécifiques  (13/04/04)
    GPOINT = "APMAJITC"
    Gosub ENTREE From EXEFNC

End


Funprog GETITCSEQ(PFCY,PITM,PCSTTYP,PSTRDAT,PENDDAT,PECCMAJ,PECCMIN)
Value Char    PFCY
Value Char    PITM
Value Integer PCSTTYP
Value Date    PSTRDAT
Value Date    PENDDAT
Value Char    PECCMAJ
Value Char    PECCMIN

Local Integer LSEQ
LSEQ=0

If clalev([F:ITC2]) <= 0 Local File ITMCOST [ITC2] Endif

Filter [ITC2] Where STOFCY = PFCY
&                 & ITMREF = PITM
&                 & CSTTYP = PCSTTYP
&                 & UID=0
&                 & ITCSTRDAT = PSTRDAT
&                 & ITCENDDAT = PENDDAT
&                 & ECCVALMAJ = PECCMAJ
&                 & ECCVALMIN = PECCMIN
Read [ITC2] First
Filter [ITC2]
If !fstat
    LSEQ = [F:ITC2]ITCSEQ
Endif
End LSEQ

######################################################################################
## Etiquette ajoutée par le superviseur (écran ITCCLC0) 22/10/2010 15:15:34 (CCC)
######################################################################################
Subprog AM_MAJ(VALEUR)
Variable Integer VALEUR
If VALEUR=3
    Actzo [M:DIA]RPLPRVCST
Else
    [M:DIA]RPLPRVCST = 1
    Diszo [M:DIA]RPLPRVCST
Endif
End

# Issue 87576 - 2015-04-08 by JUSYN : Initialisation of cost fields has to be done when screen first opens but when site changes as well.
Subprog INIT_COST_CALC(PFCY)
Value Char PFCY
Local Char LPAR(10)

Case [M:DIA]CSTTYPA
    When "STD"
        Call PARAM(PFCY, "CLCSTDMAT", LPAR) From ADOVAL
    When "CUT"
        Call PARAM(PFCY, "CLCCUTMAT", LPAR) From ADOVAL
    When "BUD"
        Call PARAM(PFCY, "CLCBUDMAT", LPAR) From ADOVAL
    When "SIM"
        Call PARAM(PFCY, "CLCSIMMAT", LPAR) From ADOVAL
    When Default
        Call PARAM(PFCY, "CLCSTDMAT", LPAR) From ADOVAL
Endcase
[M:DIA]SLTMATCST = val(LPAR)

Case [M:DIA]CSTTYPA
    When "STD"
        Call PARAM(PFCY, "CLCSTDRAT", LPAR) From ADOVAL
    When "CUT"
        Call PARAM(PFCY, "CLCCUTRAT", LPAR) From ADOVAL
    When "BUD"
        Call PARAM(PFCY, "CLCBUDRAT", LPAR) From ADOVAL
    When "SIM"
        Call PARAM(PFCY, "CLCSIMRAT", LPAR) From ADOVAL
    When Default
        Call PARAM(PFCY, "CLCSTDRAT", LPAR) From ADOVAL
Endcase
[M:DIA]VLTCCERAT = val(LPAR)

Case [M:DIA]CSTTYPA
    When "STD"
        Call PARAM(PFCY, "OVECOLSTD", LPAR) From ADOVAL
    When "CUT"
        Call PARAM(PFCY, "OVECOLCUT", LPAR) From ADOVAL
    When "BUD"
        Call PARAM(PFCY, "OVECOLBUD", LPAR) From ADOVAL
    When "SIM"
        Call PARAM(PFCY, "OVECOLSIM", LPAR) From ADOVAL
    When Default
        Call PARAM(PFCY, "OVECOLSTD", LPAR) From ADOVAL
Endcase
[M:DIA]SLTOVECOL = val(LPAR)

Affzo [M:DIA]SLTMATCST , VLTCCERAT , SLTOVECOL

End
######################################################################################

