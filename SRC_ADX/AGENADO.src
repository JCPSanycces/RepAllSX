#<AdxTL>@(#)6.0.0.0 $Revision$
###################################################################
# AGENADO : Programme Commun V5-V6 (PLUS V7)
###################################################################
# Génération de doc finale à partir de la table ADOCUMENT stockant les documents en blob,
# et des tables compléments fonction / objet
#
#
# Sont prises en compte les documentations suivantes  :
#     Documentation fonctionnelle (répertoire FCT, code=code de la fonction)
#     Aide sur actions (répertoire OBJ, code ACT_action)
#     Aide sur codes activité (répertoire OBJ, code ACV_code)
#     Aide sur variables de dimensionnement (répertoire OBJ, code ADM_variable)
#     Aide sur paramètres (répertoire OBJ, code ADP_chapitre_paramètre)
#     Aide sur modèles d'import/export (répertoire OBJ, code AOE_modèle)
#     Aide sur états (répertoire OBJ, code ARP_état)
#     Aide sur règles Workflow (répertoire OBJ, code AWA_règle)
#     Aide sur destinations comptables (répertoire OBJ, code CDA_destination)
#     Aide sur sections par défaut (répertoire OBJ, code CDE_section)
#     Aides diverses (répertoire FCT, code égal à la clé de la fiche)
#     Aide sur pièces automatiques (répertoire OBJ, code GAU_pièce)
#     Aide sur événements déclenchants de stats (répertoire PS1, code ACT_événement)
#     Menus intermédiaires de l'aide fonctionnelle (répertoire FCT, codes fonctions)
#     Dictionnaire des données (répertoire MCD, code de la table)
#     Menus intermédiaires (types APM, codes XXX_module ou XXX_groupe, XXX_0 étant le premier)
#
#
# ATTENTION !! On n'est pas loin de la limite en nombre d'instructions du traitement...
###################################################################
Local Char PARAM(30)(1..3) , VALEUR(30)
Call TRAITE_CHAR(VALEUR,PARAM,"","AGENADO","AGENDOC",3,"") From GTRAITE
End

###################################################################
$ACTION
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "CONTROLE"    : Gosub CONTROLE
 When "CONT_BATCH"  : Gosub CONT_BATCH
 When "SORTIE"      : Gosub FERME
 When "TERMINE"     : Gosub FIN
Endcase
Return

$OUVRE_BATCH
#JPGA 25/05/2010 BUG-64975 : Affichage informatif du Répertoire de génération en Requète BATCH selon le USER/DOSSIER
If GBATCH
 If USER<>"" & DOSSIER<>""
  Gosub RECH_DIRDOC_USER
 Endif
Endif
Return

$CONT_BATCH
# Pas de génération sur le poste client en batch
If GBATCH
 If USER<>"" & DOSSIER<>""
  Gosub RECH_DIRDOC_USER
  Gosub CONTROLE_PAR_LAN
 Endif
Endif
Return

$CONTROLE
  Gosub RECH_DIRDOC
  Gosub CONTROLE_PAR_LAN
Return

###################################################################
$FERME
# cg mai  2013
# il faut killer les var globales crée via prog
Gosub FERME_KILL From AGENLIBA
Return

###################################################################
$FIN
# cg mai  2013
# il faut remettre vide la var globale des codes iso
If dim (GISO_COD_LAN) >=0
    GISO_COD_LAN =  ""
Endif
Return
###################################################################

# Recherche du Parametre DIRDOC au niveau Utilsiateur : Ouverture préliminaires des tables du Dossier
$RECH_DIRDOC_USER
  If clalev([F:ADU])=0 : Local File =DOSSIER+".ADOVALAUS" [ADU] : Endif
  If clalev([F:AFT])=0 : Local File =DOSSIER+".AFCTFCT"   [AFT] : Endif
  If clalev([F:ADP])=0 : Local File =DOSSIER+".ADOPAR"    [ADP] : Endif
  If clalev([F:AUS])=0 : Local File =DOSSIER+".AUTILIS"   [AUS] : Endif
  If clalev([F:ADW])=0 : Local File =DOSSIER+".ADOVAL"    [ADW] : Endif

  Gosub RECH_DIRDOC
Return

$RECH_DIRDOC
  Local Char REPDOC(GDIMFIC)

  If GBATCH
     Call PARAMUTIL("DIRDOC", REPDOC, USER, "") From SUBAUS
  Else
     Call PARAMUTIL("DIRDOC", REPDOC, "", "")   From SUBAUS
  Endif
Return

#JPGA 13/10/2010 BUG-68216 : Génération HTML "Toutes Langues" sur serveur Unix : Vérification/Création par langue à faire
$CONTROLE_PAR_LAN
  # Controle de la disponibilité des répertoires pour chaque langue sélectionnée avec création Par langue
  Gosub DECL_COMVAR           From AGENLIBA
  Gosub GENE_ADOCUMENT_CHAMPS From AGENDOCA
  If !clalev([AD1])  :  Local File ADOCUMENT [AD1] : Endif

  EVALTYP=string$([M:DIA]ALLLAN=1,"LAN=[V]COD_LAN")
  EVALTYP+=string$(EVALTYP="","1=1")
  For [AD1]ADO0(1) Where evalue(EVALTYP)
    [V]COD_LAN=[AD1]LAN
    # cg mai 2013 ici prob pour nouvelle generation sur rep avec code iso
    # mais n est valable que pour html ?????
    # on ne peut pas ouvrir table des langues avec declare tables sinon on plante plus loin
    # et donc giso_cod_lan est vide  il faut donc init du code iso en fct du code langue cod_lan
    # si code iso vide on laisse le code langue comme avant....
    Gosub INIT_COD_ISO From AGENDOCA
    #
    Gosub CONT From AGENDOCA
    # cg mai  2013 on remet blanc dans code iso pour le recharger plus tard
    GISO_COD_LAN = ""
    #
    If FIN : Break : Endif  :  # En cas d'erreur, on sort sans continuer sur les autres langues
  Next
  If clalev([AD1])  :   Close File [AD1] : Endif
Return

$INIT_DIA
Raz [M:DIA]
[M:DIA]LAN     = GLANGUE
If PARAM(3)<>"" : ## VPO 26/09/07 BUG43186
    [M:DIA]LAN = PARAM(3)
Endif
[M:DIA]ALLTYP  = 1
[M:DIA]TYPEDOC = PARAM(1)
[M:DIA]FUNDEB  = PARAM(2)
If GABREV="ADO"
 [M:DIA]GENDOC = 1 : # Non
 If adxmother=nomap
  [M:DIA]GENFIN = 2 : # Complète (standard)
 Else
  [M:DIA]GENFIN = 3 : # Selon code activité (y compris spécifiques)
 Endif
Else
 [M:DIA]GENDOC = 2 : # Toutes
 [M:DIA]GENFIN = 1 : # Non
Endif

# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:DIA]ALLCREGRP") From AGENLIBA
#JPGA 25/05/2010 BUG-64975 : Affichage informatif du Répertoire de génération en Requète BATCH selon le USER/DOSSIER
If dim([L]REPDOC)>0
   [M:DIA]REPERT=[L]REPDOC
Else
   # JPGA 09/04/2010 Bug-51883-63972 : Appel à la procédure de recherche du Répertoire xml d'extraction
   Call INIT_REPERT_LAN([M:DIA]REPERT,"html") From AGENLIBA
Endif
Return

$EXEC
Call AGENADO
Return

#################################################################
# La fonction de génération principale
#################################################################

Subprog AGENADO
# on augmente adxmto
If adxmto<150 : adxmto=150 : Endif
Gosub DECL_COMVAR             From AGENLIBA

# Déclaration des tables
If clalev([ADB2])=0 : Gosub DECLARE_TABLES From AGENLIBA : Endif

# apres ouvertures des tables
# Fixons les paramètres...
  Gosub GENE_ADOCUMENT_CHAMPS From AGENDOCA


# Génération de ADOC
  If GEN_DOC>=2
    Gosub DECL_VARTRA From AGENLIBA
    Gosub GEN_ADOC    From AGENDOCA
  Endif

#
# Le sous-programme de génération de la documentation finale
# Rajout : les paragraphes associés au code activité FAL ne sont jamais générés
#
$GEN_DOCF
  # La condition sur les paragraphes de doc
  EVALTYP =string$(ALL_LAN=1,"LAN=[V]COD_LAN")
  EVALTYP+=string$(ALL_TYP=1,string$(EVALTYP<>""," & ")+"TYP=COD_TYP & COD>=DOC_DEB & COD<=DOC_FIN")
  EVALTYP+=string$(EVALTYP<>""," & ")+"LAN<>'' & TYP<>'' & COD<>''"  : # JPGA 20/08/2012 BUG-84088 : Vérification LAN & TYP & COD non Vide
  EVALTYP+=string$(GADONIX=2 and (ALL_LAN=2 or ALL_TYP=2), string$(EVALTYP<>"","&")+"(TYP='AD' or (COD>='A' and COD<'X') or pat(COD,'_*') or TYP='AML')")
  #JPGA 28/09/2010 BUG-67149 : Restructuration boucle Principale
  EVALTYP+=string$(GEN_FIN=2,string$(EVALTYP<>""," & ")+"(CODACT<>'FAL') & (CODACT<'X')")
  EVALTYP+=string$(EVALTYP="","1=1")
  OLDLAN=""  :  GENFPLA=0

  Case GEN_FIN
      When 2 # Génération HTML standard Complète   . La boucle principale si on crée une documentation "standard"
         Filter [ADO]
         For [ADO]ADO0(3) Where evalue(EVALTYP)
             Gosub GEN_DOCF_PARDOC
         Next
      When 3 # Génération HTML selon Code activité . La boucle principale si on crée des docs limitées aux codes activités actifs
         Local File ACTIV [ACV2]
         Link [ADO] With [ACV2]CODACT=[ADO]CODACT As [ADO0] Where ([ACV2]FLACT=2 or [ADO]CODACT="") and ([ADO]CODACT<>"FAL")
                        #VPO 26/05/08 47503 generation avec code activite
                        #                                                                           and ([ADO]LEV=10 & [ADO]SUBLEV=10 & [ADO]PAR='TIT')
         For [ADO0]ADO0(3) Where evalue(EVALTYP)
             Gosub GEN_DOCF_PARDOC
         Next
  Endcase

  If [M:DIA]HLPFLD=2
    #VPO 04/01/08 BUG44500
    EVALTYP =string$(ALL_LAN=1,"LAN=[V]COD_LAN")
    EVALTYP+=string$(EVALTYP<>""," & ")+"LAN<>''"     : # JPGA 20/08/2012 BUG-84088 : Vérification Langue non Vide
    EVALTYP+=string$(EVALTYP<>""," & ")+"MOTCLE>=HLP_DEB & MOTCLE<=HLP_FIN"
    EVALTYP+=string$(EVALTYP<>""," & ")+"MOTCLE<>''"  : # JPGA 20/08/2012 BUG-84088 : Vérification Mot clé non Vide
    EVALTYP+=string$(EVALTYP="","1=1")

    # JPGA 20/08/2012 BUG-84088 : Génération toutes Langues HTML sur Dossier SUP
    If GDOSX3<>nomap
      For [ADZ4] Where evalue(EVALTYP)
          [ADZ]=[ADZ4]
          Gosub GEN_DOCF_FLD From AGENLIBA
      Next ADZ4
    Endif

    # JPGA 20/08/2012 BUG-84088 : Génération toutes Langues HTML sur Dossier Courant
    For [ADZ] Where evalue(EVALTYP)
        Gosub GEN_DOCF_FLD From AGENLIBA
    Next ADZ
  Endif
End

$GEN_DOCF_PARDOC
  FICHIER_CREE=-1                                   : # VPO 26/09/07 BUG43211
  [V]COD_LAN=[ADO]LAN
  Gosub INIT_COD_ISO From AGENDOCA                  : # TCH SI023 95209_1 : code iso doit etre en phase avec COD_LAN

  Gosub LIREWIN                                     : # Lecture des caractéristiques de la fonction, y compris sa fenêtre principale
  Gosub CREE_FIC                                    : # Création du fichier de doc
  If FICHIER_CREE & (NOMDOC<>"" | [ADO]TYP<>'ADP')  : # VPO 18/12/07 BUG44894
     If [ADO]TYP='PLA' : GENFPLA=1 : Endif          : # VPO 07/01/08 evol 45065
     Gosub PRQ_DEBUT From AGENLIBA                  : # Ecriture du Début du fichier des PRE-REQUIS
     Case GEN_FIN
       When 2                                       : # Génération HTML standard Complète
              For [ADO]ADO0(4)                      : # Boucles sur les paragraphes
                  Gosub GEN_DOCF_PARLEV
              Next
       When 3                                       : # Génération HTML standard Code activité
              For [ADO0]ADO0(4)                     : # Boucles sur les paragraphes
                  Gosub GEN_DOCF_PARLEV
              Next
     Endcase
     Gosub FIN_FIC   From AGENLIBA                  : # Ecriture de la fin du fichier de doc
     Gosub PRQ_FIN   From AGENLIBA                  : # Ecriture de la fin du fichier des PRE-REQUIS

     If [M]HLPLNKFLD=2                              : # VPO 11/01/07 traiter les champs liés
        Gosub GEN_DOCF_LNKFLD From AGENLIBA
     Endif
  Endif

  If OLDLAN<>[V]COD_LAN & GENFPLA=1                 : #VPO 07/01/08 evol 45065
     GENFPLA=0  :  OLDLAN=[V]COD_LAN
     Gosub CREE_FIC_PLA
  Endif
Return

$GEN_DOCF_PARLEV
  RONG=0
  Gosub TABLE_MAT                                   : # Génération de la table des matières intermédiaires
  Raz RONG

  Gosub PRQ_PARAGRAPHE_DEBUT  From AGENLIBA         : # Ecriture eventuelle du paragaphe dans un autre fichier HTML pour les PRE-REQUIS
  Case GEN_FIN
    When 2                                          : # Génération HTML standard Complète
         For [ADO]ADO0
             Gosub PARAGRAPHE                       : # Génération d'un paragraphe
             Gosub PCEJOIN From AGENLIBA            : # Extraction des fichiers joints
         Next
    When 3                                          : # Génération HTML standard Code activité
         For [ADO0]ADO0
             Gosub PARAGRAPHE                       : # Génération d'un paragraphe
             Gosub PCEJOIN From AGENLIBA             : # Extraction des fichiers joints
         Next
  Endcase
  Gosub PRQ_PARAGRAPHE_FIN    From AGENLIBA
Return


#
# Détermination du répertoire et du nom du fichier
#
$REPNOM_FIC
# Détermination du nom du fichier doc à générer et traitement des variables associées au type de doc
#JPGA 02/04/2010 BUG-57951 : Initialisation de NOMDOC a vide pour les ADP inexistants : cela ecrase sinon le fichier HTML precedent
  CH3="" : LIENSGEN="" : CH2=[ADO]COD : NOMDOC=""
  Case [ADO]TYP
    When "AFC" : # Doc fonctionnelle
                 Case TYPEFONC
                   When 6 :       Return             : # Les menus sont générés avec le type APM
                   When 1 :       LIENSGEN="OBJWEB"  : # Modif le 19 mars 2007
                   When 2 :       LIENSGEN="CONS"
                   When Default:  LIENSGEN="TRT"
                 Endcase
    When "ADI" : Return  : #VPO 30/06/08 48129 : ajout liste des tables diverses
    When "ADP" : Read [ADP]ADP1=[ADO]COD
                 If fstat : # VPO 18/12/07 BUG44894 si le param n'existe pas, on ne genère pas la doc
                    #JPGA 28/09/2010 BUG-67149 : Génération HTML KO en Wrseq sur documentation de type ADP si parametre inexistant
                    FICHIER_CREE=0  :  Return
                 Endif
                 CH3="ADP_"+[ADP]CHAPITRE
    #VPO 19/06/08 39766 ajout ATD: différences de tables #VPO 27/10/08 49955 ajout AT3: différences de tables 130
    When "APM","ATD","AT3","ATB","AML","ATY","DI","FI" : # Rien à faire
                 # Les documentations reprises au fur et à mesure sont gérées en testant s'il existe plus d'un paragraphe de titre
                 # C'est le cas pour L4G, points d'entrée
    When "AD","AM","CS","IN","DL","PA"
                 # S'il n'existe pas de sous-paragraphe de niveau plus élevé que le titre, on ne crée pas de fichier (on suppose alors que c'est une pièce jointe)
                 Gosub RECH_LEVEL
                 If [ADO]TYP="AD"
                    If pat(CH2,"*_D") : CH2=left$(CH2,len(CH2)-2)+"$" : Endif
                    If pat(CH2,"A_*") : CH2=right$(CH2,3) : Endif
                 Endif
    When "ADC" : Read [ADC]ADC0=[ADO]COD
                 If fstat : # VPO 18/12/07 BUG78592 si le traitement n'existe pas dans le dictionnaire des traitements, on ne genère pas la doc
                    #JPGA 28/09/2010 BUG-67149 : Génération HTML KO en Wrseq sur documentation de type ADC si traitement inexistant
                    FICHIER_CREE=0  :  Return
                 Endif
                 # S'il n'existe pas de sous-paragraphe de niveau plus élevé que le titre, on ne crée pas de fichier (on suppose alors que c'est une pièce jointe)
                 Gosub RECH_LEVEL
                 #JPGA 22/12/2011 BUG-78592 : Génération HTML quand même si une doc n'a pas de paragraphe TIT ou PRE
                 If CH2=""
                    Look [AD1]ADO1 = [ADO]LAN ;[ADO]TYP;[ADO]COD;"TIT"
                    If fstat
                      Look [AD1]ADO1 = [ADO]LAN ;[ADO]TYP;[ADO]COD;"PRE"
                      If fstat
                        CH2=[ADO]COD
                      Endif
                    Endif
                 Endif
    When "PLA"   : # PLA (Aide sur Plan de paie) #VPO 07/01/08 evol 45065
                 #JPGA 18/03/2010 BUG-59115: On élimine les caractères ASCII genant avec les accents pour que le nom du fichier sorte sans
                 Gosub CORRIGE_PLA

    # Par défaut, il s'agit d'une aide sur objet
    # Aujourd'hui sont notamment concernés :
    # ADC (Aide sur points d'entrée)
    # ADM (Aide sur variables de dimensionnement)
    # ACT (Aide sur actions)
    # ACV (Aide sur codes activité)
    # AOE (Aide sur modèles d'import/export)
    # ARP (Aide sur états)
    # AWA (Aide sur règles Workflow)
    # CDA (Aide sur destinations comptables)
    # CDE (Aide sur sections par défaut)
    # GAU (Aide sur pièces automatiques)
    # PS1 (Aide sur événements déclenchants de stats)
    # ASU (Aide sur sous-programmes)
    # AGB (Aide sur variables globales)
    # Dans ce cas, rien n'est à faire !
    When Default:
  Endcase
  CH1=[ADO]TYP : Gosub REP_NOM_FIC : SOUS_REPERT=CH4 : NOMDOC=CH5
Return

$RECH_LEVEL
  CH2=""
  For [AD1] Where [AD1]TYP=[ADO]TYP and [AD1]COD=[ADO]COD and (([AD1]LEV>=[ADO]LEV and [AD1]SUBLEV>[ADO]SUBLEV) or ([AD1]LEV>[ADO]LEV))
    CH2=[ADO]COD  :  Break
  Next
Return

#JPGA 18/03/2010 BUG-59115: Remplacement des caracteres speciaux des noms de fichiers pour les type PLA
$CORRIGE_PLA
    RECH='&'   :  AREMP='et'  :  Gosub ONSUPP
    RECH='"'   :  AREMP=''    :  Gosub ONSUPP
    RECH="'"   :  AREMP=''    :  Gosub ONSUPP
    RECH='à'   :  AREMP='a'   :  Gosub ONSUPP
    RECH='â'   :  AREMP='a'   :  Gosub ONSUPP
    RECH='ä'   :  AREMP='a'   :  Gosub ONSUPP
    RECH='é'   :  AREMP='e'   :  Gosub ONSUPP
    RECH='è'   :  AREMP='e'   :  Gosub ONSUPP
    RECH='ê'   :  AREMP='e'   :  Gosub ONSUPP
    RECH='ë'   :  AREMP='e'   :  Gosub ONSUPP
    RECH='ï'   :  AREMP='i'   :  Gosub ONSUPP
    RECH='î'   :  AREMP='i'   :  Gosub ONSUPP
    RECH='ö'   :  AREMP='o'   :  Gosub ONSUPP
    RECH='ô'   :  AREMP='o'   :  Gosub ONSUPP
    RECH='ù'   :  AREMP='u'   :  Gosub ONSUPP
    RECH='ü'   :  AREMP='u'   :  Gosub ONSUPP
    RECH='û'   :  AREMP='u'   :  Gosub ONSUPP
    RECH='ç'   :  AREMP='c'   :  Gosub ONSUPP
Return

#JPGA 18/03/2010 BUG-59115: Remplacement des caracteres speciaux des noms de fichiers pour les type PLA
$ONSUPP
    J=instr(1,CH2,RECH)
    While J>0
        CH2_TMP=left$(CH2,J-1)+AREMP+right$(CH2,J+len(RECH))
        CH2=CH2_TMP
        J=instr(1,CH2,RECH)
    Wend
Return

#
# Définition du répertoire et du nom du fichier (CH1=type,CH2=code, CH3=complément, CH4=répertoire, CH5=nom)
# Sous-programme générique
#
$REP_NOM_FIC
  Case CH1
    When "AFC","DI" : CH4="FCT" : CH5=CH2
    When "CS" : CH4="CONSOLE" : CH5=CH2
    #VPO 11/02/08 45883 ne pas generer les doc de type PA dans INSTALLATION
    When "PA" : CH4="" : CH5=CH2
    When "IN" : CH4="INSTALLATION" : CH5=CH2
    When "DL" : CH4="DLT" : CH5=CH2
    When "ADP" : CH4="OBJ"
                 CH5=CH3+"_"+CH2
#VPO 04/09/08 48971 ajout ABF et ABM
    When "APM" : If find(left$(CH2,4),
&                 "ACT_","ACV_","ADM_","ADP_","ARP_","AOE_","PS1_","AWA_","CDA_","CDE_","GAU_","ADC_","AGB_",
&                 "ASU_","ABO_","ABF_","ABM_","AHI_")
                   CH4="OBJ"
                 #VPO 30/06/08 48129 : ajout liste des tables diverses
                 Elsif find(left$(CH2,4),"ATB_","AML_","ATY_","ADI_")
                   CH4="MCD"
                 Else
                   CH4="FCT"
                 Endif
                 CH5=CH2
    #VPO 19/06/08 39766 ajout ATD: différences de tables
    #VPO 27/10/08 49955 ajout AT3: différences de tables 130
    When "ATD","AT3" : CH4="MCD" : CH5=string$(CH2<>"",CH1+"_"+CH2)
    When "ATB" : CH4="MCD" : CH5=CH2 : # Aide sur tables
    When "MC"  : CH4="MCD" : CH5=CH2 : # Aide sur tables
    When "AML" : CH4="MCD" : CH5="MEN"+func AGENLIBA.FORMAT_AML(val(CH2))
    When "ATY" : CH4="MCD" : CH5="ATY_"+CH2
    When "AD" : CH4="L4G" : CH5=CH2
    When "AM" : CH4="MODEL" : CH5=CH2
    When "FI" : CH4=vireblc(vireblc(ctrans(CH2,"_"," "),3),2) : CH4=string$(CH4<>"A",CH4) : CH5=""
    # PLA (Aide sur Plan de paie) #VPO 07/01/08 evol 45065
    When "PLA" : CH4="OBJ" : CH5=CH2

    # Par défaut, il s'agit d'une aide sur objet
    # Aujourd'hui sont notamment concernés :
    # ADC (Aide sur points d'entrée)
    # ADM (Aide sur variables de dimensionnement)
    # ACT (Aide sur actions)
    # ACV (Aide sur codes activité)
    # AOE (Aide sur modèles d'import/export)
    # ARP (Aide sur états)
    # AWA (Aide sur règles Workflow)
    # CDA (Aide sur destinations comptables)
    # CDE (Aide sur sections par défaut)
    # GAU (Aide sur pièces automatiques)
    # PS1 (Aide sur événements déclenchants de stats)
    # ASU (Aide sur sous-programmes)
    # AGB (Aide sur variables globales)
    When Default: CH4="OBJ" : CH5=string$(CH2<>"",CH1+"_"+CH2)
  Endcase
Return

#
# Création du fichier de doc finale, écriture de l'en-tête et de la structure principale
# pour les menus des docs de type PLA
#VPO 07/01/08 evol 45065
#VPO 07/07/08 evol 48427 ajout par="LNK"
$CREE_FIC_PLA
Local Char PLATABOBJ(GLONAOB) (1..1000) : Raz PLATABOBJ
Local Integer PLANBOBJ : PLANBOBJ=0
Local Integer PLAIOBJ

  [ADO]COD="PLA_0"
  [ADO]TIT=""
  [ADO]PAR="TIT"
  Gosub CREE_FIC_PLA0

  If clalev([ADO3])=0 : Local File ADOCUMENT [ADO3] : Endif
  OLDPLA=""
  For [ADO3]ADO0(3) Where LAN=[ADO]LAN & TYP=[ADO]TYP & PAR="TIT" & (CODACT<>"FAL")
    If OLDPLA<>left$([ADO3]COD,3)
        OLDPLA=left$([ADO3]COD,3)
        Read [AOB]ABREV=OLDPLA
        If fstat=0
            PLANBOBJ+=1
            PLATABOBJ(PLANBOBJ)=OLDPLA
        Endif
    Endif
  Next
  For PLAIOBJ=1 To PLANBOBJ
    Filter [ADO3] Where LAN=[ADO]LAN & TYP=[ADO]TYP & LEV=10 & PAR="LNK" & (CODACT<>"FAL") & left$(COD,3)=PLATABOBJ(PLAIOBJ)  Order By TIT;COD
    OLDPLA=""
    For [ADO3]
        If OLDPLA<>[ADO3]TIT
            OLDPLA=[ADO3]TIT
            [ADO]=[ADO3]
            [ADO]COD=PLATABOBJ(PLAIOBJ)+"_"+[ADO3]TIT+"_0"
            Gosub CREE_FIC_PLA0
        Endif
    Next
    Filter [ADO3]
    [ADO]COD=PLATABOBJ(PLAIOBJ)+"_0"
    [ADO]TIT=""
    [ADO]PAR="TIT"
    Gosub CREE_FIC_PLA0
  Next PLAIOBJ
Return

$CREE_FIC_PLA0
# Détermination du nom et du répertoire
  Gosub REPNOM_FIC
  Gosub RECHTIT From AGENLIBA

# Constitution de la pile de menus qui sera ensuite affichée dans le bandeau ( menu1 > menu 2 > Fonction...)
  Gosub PILE_MENUS From AGENDOCA

# Recherche du répertoire par langue
  Gosub REPERT_LAN From AGENDOCA
  # JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.
  REPERT_DOC=func AGENLIBA.REMPLACE_VOLUME (REPERT_DOC)

# Sur une doc de type "AD", le nom est vide et on ne génère rien
  If NOMDOC="" : Return : Endif

# Ouverture du fichier doc
  FICOUV=REPERT_DOC+SLASH+SOUS_REPERT+SLASH+NOMDOC+".htm"
  Gosub FICOUV_OPEN From AGENLIBA
  FICHIER_CREE=1
# Ecriture de l'en-tête  #VPO 27/09/07 BUG42102 tenir compte du type de doc pour header
  [L]MODULED=[ADO]MODULE : ECR_HEADER_DOC=1 : ECR_HEADER_FLD=0 : Gosub ECR_HEADER  From AGENLIBA

# Début du texte principal
  Wrseq '    <div id="supportingText">' Using [DOC]

  Gosub INCL_PLA
  Gosub FIN_FIC From AGENLIBA : # Ecriture de la fin du fichier de doc
Return

#
# Création du fichier de doc finale, écriture de l'en-tête et de la structure principale
#
$CREE_FIC
#on regarde si un fichier est a générer
#VPO 19/06/08 39766 ajout ATD: différences de tables
#VPO 27/10/08 49955 ajout AT3: différences de tables 130
If [ADO]TYP="ATD" | [ADO]TYP="AT3"
  Read [AD1]ADO0=[ADO]LAN;[ADO]TYP;[ADO]COD;10;20
  If fstat
     FICHIER_CREE=0  :  Return
  Elsif [AD1]PAR<>"UPD"
     FICHIER_CREE=0  :  Return
  Else
    ADO_ABREV=[AD1]TIT
  Endif
Endif

# Détermination du nom et du répertoire
  Gosub REPNOM_FIC
  #JPGA 28/09/2010 BUG-67149 : Génération HTML KO en Wrseq sur documentation de type ADP si parametre inexistant
  If ! FICHIER_CREE :  Return  :  Endif

  #VPO 04/09/08 49010 uniquement doc avec PRE validé
  Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"PRE"
  If !fstat
     If ! func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
        FICHIER_CREE=0  :  Return
     Endif
  Endif

# On recherche les éléments de titre :
# - intitulé = titre
# - texte = mots-clés
# On teste si le titre n'est pas géré avec un code activité inactif dans le cas d'une génération partielle
# Si c'est le cas, on s'arrête tout de suite
  Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"TIT"
  If fstat
    Gosub RECHTIT From AGENLIBA
  Else
    If [AD1]CODACT<>"" and GEN_FIN<>2
        Read [ACV]CODACT=[AD1]CODACT
        If [ACV]FLACT<>2
            FICHIER_CREE=0
            Return
        Endif
    #VPO 15/01/08 41383 on ne prend que les doc qui ont un titre en 10/10
    Elsif [AD1]CODACT="FAL"
            FICHIER_CREE=0
            Return
    #VPO 29/01/08 45567 uniquement les documentations validées
    Else
        If ! func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
           FICHIER_CREE=0  :  Return
        Endif
    Endif

    # 18/8/2006 Si le titre n'est pas saisi, on le retrouve si possible dans le contexte
    #(fonctions RPT* par exemple)
    If [AD1]TIT<>""
        TITRED=[AD1]TIT
    Else
        Gosub RECHTIT From AGENLIBA
    Endif
  Endif
  #VPO 19/06/08 39766 ajout ATD: différences de tables
  #VPO 27/10/08 49955 ajout AT3: différences de tables 130
  #on construit un titre
  If [ADO]TYP="ATD" | [ADO]TYP="AT3"
        TITRED=func AGENADO.RDM("AOB2","SELFIC")-[ADO]COD-"["+ADO_ABREV+"]"-[AD1]TIT
  Endif

# Constitution de la pile de menus qui sera ensuite affichée dans le bandeau ( menu1 > menu 2 > Fonction...)
# S'il existe un titre et s'il existe un paragraphe lien au même niveau, on l'utilise pour définir la
# pile de menus en tête. Sinon, on reprend les liens standard
  I_LEV=10
  #VPO 07/07/08 evol 48427 ajout par="LNK"
  If [ADO]TYP<>"PLA"
      Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"TIT"
      If fstat=0
          I_LEV=[AD1]LEV
          For [AD1] Where LAN=[ADO]LAN and TYP=[ADO]TYP and COD=[ADO]COD and PAR="LNK" and LEV=I_LEV
            Raz I_LEV
            Break
          Next
          If I_LEV=0
            Gosub PILE_MENLNK From AGENDOCA
          Endif
      Endif
  Endif

# Pile de menus par défaut si elle n'a pas été trouvée par ailleurs
# L'enregistrement de titre est stocké dans [AD1] quand il existe
  Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"TIT"
  If fstat
    Raz [AD1]
  Endif
  If I_LEV
      Gosub PILE_MENUS From AGENDOCA
  Endif

# Le paragraphe TIT contient des mots-clés, sauf pour les menus, où il peut donner un complément de liens
# et pour les tables et tables diverses et types,
# où il peut donner une explication complémentaire de la structure
  Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"TIT"
#VPO 19/06/08 39766 ajout ATD: différences de tables
#VPO 27/10/08 49955 ajout AT3: différences de tables 130
  If fstat=0 & find([ADO]TYP,"APM","ATD","AT3","ATB","AML")=0
      Gosub LEC_AD1 From AGENDOCA
      KEYWORDS=ctrans(TEXTES(1),'<>"',"   ") : # Pour éviter des caractères interdits
  Endif

# Recherche du répertoire par langue
  Gosub REPERT_LAN From AGENDOCA
  # JPGA-EXI-85524-28 02/04/2014 : Pour la V7 et +, Implémentation de l'utilisation de VOLUME dans les nom de répertoires.
  REPERT_DOC=func AGENLIBA.REMPLACE_VOLUME (REPERT_DOC)

# Sur une doc de type "AD", le nom est vide et on ne génère rien
  If NOMDOC="" : Return : Endif

# Ouverture du fichier doc
  FICOUV=REPERT_DOC+SLASH+SOUS_REPERT+SLASH+NOMDOC+".htm"
  Gosub FICOUV_OPEN From AGENLIBA
  FICHIER_CREE=1
# Ecriture de l'en-tête  #VPO 27/09/07 BUG42102 tenir compte du type de doc pour header
  [L]MODULED=[ADO]MODULE : ECR_HEADER_DOC=1 : ECR_HEADER_FLD=0 : Gosub ECR_HEADER  From AGENLIBA

# Ecriture du paragraphe de Présentation
  Gosub ECR_PARAGRAPHE_PRE

# Début du texte principal
  Wrseq '    <div id="supportingText">' Using [DOC]
Return

# Paragraphe Présentation
$ECR_PARAGRAPHE_PRE
# II=0 tant que l'intro n'est pas écrite (WR_INTRO)
  II=0

# On cherche s'il existe un code présentation
# A défaut, on cherche le premier code "INC" et on regarde s'il chaîne sur une introduction
  Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"PRE"
  If fstat
    Raz I_TYP,I_COD,I_LEV,I_SUBLEV
    For [AD1]ADO0 Where LAN=[ADO]LAN and TYP=[ADO]TYP and COD=[ADO]COD and PAR="INC"
      Gosub LEC_AD1 From AGENDOCA
      I_LEV=[AD1]LEV : I_SUBLEV=[AD1]SUBLEV : Gosub RECH_INCL From AGENDOCA
      Break (fstat=0)
    Next
    Read [AD1]ADO0=[ADO]LAN;I_TYP;I_COD;I_LEV;I_SUBLEV
    If fstat or [AD1]PAR<>"PRE"
      Raz [AD1]
    Endif
  Endif

  # Lecture du CLOB de présentation
  Gosub LEC_AD1 From AGENDOCA
  If TEXBASE
    Gosub WR_INTRO
    Gosub WR_TEX From AGENDOCA
  Elsif [ADO]TYP="ACV"         : # Cas particulier : présentation "par défaut" pour les codes activités dépendants
    Read [ACV]CODACT=[ADO]COD
    If fstat=0 & [ACV]DEP>1
      Gosub WR_INTRO
      If [ACV]DEP=4              : # 'Ce code activité est purement technique et est évalué par la formule'
        Wrseq "<p>"+func AGENADO.MST(141,142)-[ACV]ACTFOR+"</p>" Using [DOC]
      Else                       : # 'Ce code activité est purement technique et dépend du code activité'
        Wrseq "<p>"+func AGENADO.MST(142,142)-'<a href="../OBJ/ACV_'+[ACV]ACTDEP+'.htm"</a>'+[ACV]ACTDEP+"</p>" Using [DOC]
      Endif
    Endif
  Elsif [ADO]TYP="ACT"         : # Cas particulier : présentation "par défaut" pour les actions sans commentaire
    Gosub WR_INTRO
    Wrseq "<p>"+func AGENADO.MST(176,142)+".</p>" Using [DOC] : # 'Cette action est interne...'
  Elsif [ADO]TYP="ASU"         : # Cas particulier : présentation "par défaut" pour les sous-programmes sans commentaire
    Gosub WR_INTRO
    Wrseq "<p>"+func AGENADO.MST(175,142)+".</p>" Using [DOC] : # 'Ce sous-programme est interne...'
  Elsif [ADO]TYP="AGB"         : # Cas particulier : présentation "par défaut" pour les variables sans commentaire
    Gosub WR_INTRO
    Wrseq "<p>"+func AGENADO.MST(174,142)+".</p>" Using [DOC] : # 'Cette variable est interne...'
  Endif

  # Fin du Paragraphe de Présentation
  If II
      Wrseq '      </div>' Using [DOC]
      Wrseq '    </div>' Using [DOC]
  Endif
Return

# Table des matières intermédiaire, obtenue par rupture sur le second niveau de rang
$TABLE_MAT

# On ne fait rien pour FI ( et AD et ADC si NOMDOC est vide)
  If ([ADO]TYP="FI") or (NOMDOC="") : Return : Endif

  #VPO 06/11/08 47899 deplier fonctions accessibles par clic droit
  If IF_DOCV5=0 & BOT_G=1 & (find([ADO]PAR,"BOT","MIS","MIN")=0 | [ADO]LEV<>BOT_LEV)
    BOT_G=0
    Call FIN_PAR_BOT(BOT_PAR) From AGENLIBA
  Endif
  If BOU_G=1 & ([ADO]PAR="BOU" | [ADO]LEV<>BOU_LEV)
      BOU_G=0
      Call FIN_PAR_BOU From AGENLIBA
  Endif

  Filter [AD1] Where [AD1]LAN=[ADO]LAN and [AD1]TYP=[ADO]TYP and [AD1]COD=[ADO]COD and [AD1]LEV=[ADO]LEV
  I=0
  For [AD1]ADO0(5)
    Gosub FIL_PAR From AGENLIBA
    I+=(II<>0)
  Next
  #VPO 10/01/08 43608 pour avoir ---+++--- entre les paragraphes de niveaux différents
  If I<>0
    # Si la table des matières précède un bloc de style 3 (ou 0), on place ici le stdBloc
    # et on signale ce fait par BLK_MAT=1
    If find([ADO]STY,0,3)
      If FIRST_BLK<>1
         Wrseq '      </div>' Using [DOC]
         FIRST_BLK=0
      Endif
      Wrseq '      <div class="stdBloc">' Using [DOC]
      BLK_MAT=1
    Endif
  Endif
  If I>2 : # Une table des matières n'a de sens que s'il y a au moins deux items (en plus du 1er)
    Wrseq '      <div class="links">' Using [DOC]
    Wrseq '        <h3 class="g1"><span></span></h3>' Using [DOC]
    Wrseq '        <ul>' Using [DOC]
    I=0
    For [AD1]ADO0(5)
        Gosub FIL_PAR           From AGENLIBA
        Gosub REINIT_TABLE_STD  From AGENLIBA
        If II : # L'entrée n'est pas filtrée
            If I : # On saute le premier
                Wrseq '          <li>' Using [DOC]
                Call ANCRE(NOMANCR,[AD1]PAR,[AD1]LEV,[AD1]SUBLEV) From AGENDOCA

                # Si le paragraphe est de type INC, il faut rechercher le paragraphe inclus
                # mais on gardera le titre du paragraphe d'origine, et l'écran correspondant
                # s'ils existent
                If [AD1]PAR="INC"
                    Gosub LEC_AD1 From AGENDOCA
                    I_LEV=[AD1]LEV : I_SUBLEV=[AD1]SUBLEV : Gosub RECH_INCL From AGENDOCA
                    Read [ADO2]ADO0=[AD1]LAN;I_TYP;I_COD;I_LEV;I_SUBLEV
                    [AD1]PAR=[ADO2]PAR
                    If [AD1]TIT="" : [AD1]TIT=[ADO2]TIT : Endif
                    If [AD1]MSK="" : [AD1]MSK=[ADO2]MSK : Endif
                Endif

                # Gestion particulière des titres des onglets
                If pat([AD1]PAR,"ON*")
                    RONG+=1
                    If [AD1]TIT=""
                        [AD1]TIT=func AGENADO.MST(146,142)-num$(RONG) : # "Onglet numéro"
                    Else
                        #VPO 07/11/08 47899 enlever italique
                        If IF_DOCV5=0
                        [AD1]TIT=func AGENADO.MST(63,142)-[AD1]TIT : # "Onglet"
                        Else
                        [AD1]TIT=func AGENADO.MST(63,142)-"<i>"+[AD1]TIT+"</i>" : # "Onglet"
                        Endif
                    Endif
                Endif
                Call TITANC([AD1]PAR,[AD1]TIT) From AGENDOCA
                Wrseq '            <a href="#'+NOMANCR+'">'+[AD1]TIT+'</a>' Using [DOC]
                Wrseq '          </li>' Using [DOC]
            Endif
            I=1
        Endif
    Next
    Wrseq '        </ul>' Using [DOC]
    Wrseq '      </div>' Using [DOC]
  Endif
  Filter [AD1]
Return

#
# Génération de chaque paragraphe de la documentation
# Le type de paragraphe est déterminé par [ADO]PAR
# Le type de documentation est défini par [ADO]TYP
# Si aide fonctionnelle :
#   - la variable TYPEFONC est renseignée,
#   - les classes [AFC],[AOB],[ACN],[AWI] sont déjà en ligne
#
# Ce sous-programme appelle des sous-programmes spécialisés INCL_xxx lorsque la mise en forme est particulière
# Il appelle également par Call des sous-programmes pour :
#   - déterminer le code exact de l'ancre (ANCRE) lorsque le paragraphe est multiple
#   - écrire les en-têtes de paragraphe (ENT_PAR, ENT_BOU pour les boutons)
#
# En fin de traitement, il écrit le texte trouvé dans le clob si le flag INCLUT_TEXTE vaut 1
#

$PARAGRAPHE
# On ne fait pas de génération dans le cas des types de doc AD et FI
  If ([ADO]TYP="FI") or ([ADO]TYP="AD" and NOMDOC="") : Return : Endif

# Si le paragraphe UTI est vide, on ne le génère pas
  If [ADO]PAR="UTI"
    Gosub LEC_ADO From AGENDOCA
    If TEXBASE=0
        Return
    Endif
  Endif

  If    [ADO]TYP="APM" & [ADO]PAR="TIT" : # Dans le cas d'une documentation de type menu, le paragraphe TIT donne lieu à une génération particulière
    Gosub INCL_APM  :  Return
  Elsif [ADO]TYP="ATB" & [ADO]PAR="TIT" : # Idem dans la cas d'une documentation de type table
    Gosub INCL_DIC  :  Return
  Elsif [ADO]TYP="AML" & [ADO]PAR="TIT" : # Idem dans la cas d'une documentation de type menu local
    Gosub INCL_AML  :  Return
  Elsif [ADO]TYP="ATY" & [ADO]PAR="TIT" : # Idem dans la cas d'une documentation de type type de données
    Gosub INCL_ATY  :  Return
  Endif

# Pour certains paragraphes, il n'y a rien à écrire
  If find([ADO]PAR,"TIT","PRE")
    Return
  Endif

# Si le paragraphe est de type LNK et qu'un titre existe au même niveau, on ne génère rien
  If [ADO]PAR="LNK"
    Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO]COD;"TIT"
    If fstat=0 & [AD1]LEV=[ADO]LEV
        Return
    Endif
  Endif

# Calcul de l'ancre (modification : on la calcule avant le remplacement du code INC (20/3/2006)
  Call ANCRE(NOMANCR,[ADO]PAR,[ADO]LEV,[ADO]SUBLEV) From AGENDOCA

# Si le code du paragraphe est INC (inclusion), on lit le paragraphe correspondant s'il existe
# Ce paragraphe contient la clé du paragraphe à inclure sous la forme type/cle/niveau/sous-niveau
# Si un titre, un style, et un masque existent dans le paragraphe d'origine, on les garde
  If [ADO]PAR="INC"
    Gosub LEC_ADO From AGENDOCA
    I_LEV=[ADO]LEV : I_SUBLEV=[ADO]SUBLEV : Gosub RECH_INCL From AGENDOCA
    If fstat
        Return
    Else
        Read [AD1]ADO0=[ADO]LAN;I_TYP;I_COD;I_LEV;I_SUBLEV
        If fstat : Return : Endif
        If [AD1]CODACT="FAL" : Return : Endif : # Rajout 18/8/06
        If [AD1]PAR="PRE" : Return : Endif : # Paragraphe de présentation déjà traité
        [ADO]TYP=[AD1]TYP
        [ADO]COD=[AD1]COD
        If [ADO]MSK="" : [ADO]MSK=[AD1]MSK : Endif
        [ADO]PAR=[AD1]PAR
        [ADO]CODACT=[AD1]CODACT
        If [ADO]STY=0 : [ADO]STY=[AD1]STY : Endif
        If [ADO]TIT="" : [ADO]TIT=[AD1]TIT : Endif
        [ADO]LEV=[AD1]LEV
        [ADO]SUBLEV=[AD1]SUBLEV
    Endif
  Endif

# Dans la cas d'un paragraphe de liens, on se contente d'insérer les liens et on s'arrête
  If [ADO]PAR="LNK"
    Gosub INCL_LNK  :  Return
  Endif

# Style par défaut = style 3
  If [ADO]STY=0 : [ADO]STY=3 : Endif

# Flag "Inclusion du texte" (1 par défaut)
#    mais sait-on jamais...
  INCLUT_TEXTE=1

  If BOU_G=1 & ([ADO]PAR="BOU" | [ADO]LEV<>BOU_LEV)
      BOU_G=0
      Call FIN_PAR_BOU From AGENLIBA
  Endif

# Ouverture de la balise du bloc
  If [ADO]STY=3 and ([ADO]PAR<>"BOU" or BOUTBAS=0) and [ADO]PAR<>"MIN"
      If BLK_MAT<>1
         If FIRST_BLK<>1
            Wrseq '      </div>' Using [DOC]
         Endif
         Wrseq '      <div class="stdBloc">' Using [DOC]
      Endif
#     Wrseq "<p>FIRST_BLK="+num$(FIRST_BLK)+"</p>" Using [DOC]
      FIRST_BLK=0
##VPO 11/03/08 bug45426 on se retrouve avec +sieurs séparateurs de paragraphe (----- + + + + +  --------)
##  Endif
##  If [ADO]PAR="ERR" and BOUTBAS<>0 and [ADO]STY=3
  Elsif [ADO]PAR="ERR" and BOUTBAS<>0 and [ADO]STY=3
      Wrseq '      </div>' Using [DOC]
      Wrseq '      <div class="stdBloc">' Using [DOC]
  Endif

  #VPO 06/11/08 47899 deplier fonctions accessibles par clic droit
  If IF_DOCV5=0 & BOT_G=1 & (find([ADO]PAR,"BOT","MIS","MIN")=0 | [ADO]LEV<>BOT_LEV)
    BOT_G=0
    Call FIN_PAR_BOT(BOT_PAR) From AGENLIBA
  Endif

# Si le paragraphe définit des boutons sur onglets et si aucun bouton n'a encore été donné sur cet onglet
# Il faut intercaler le titre correspondant
  If [ADO]PAR="BOT" & BOT_G=0
    BOT_G=1
    Call ENT_PAR("",[ADO]STY-1,func AGENADO.MST(73,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Fonctions accessibles par clic droit sur tableau"
  Endif

# Si le paragraphe définit des éléments de l'interface comptable, il faut intercaler si nécessaire le
# titre correspondant
  If find([ADO]PAR,"CDE","GAU")<>0 & INTCPT=0
    INTCPT=1
    Call ENT_PAR("",[ADO]STY-1,func AGENADO.MST(21,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Interface comptabilité"
  Endif

# En-tête de paragraphe avec une mise en forme spéciale pour les boutons
  If [ADO]PAR="BOU"
    BOU_G=1
    BOU_LEV=[ADO]LEV
    If BOUTBAS=0
        If [ADO]TIT=""
            Call ENT_PAR(NOMANCR,0,func AGENADO.MST(94,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Boutons spécifiques"
        Else
            Call ENT_PAR(NOMANCR,0,[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA : #!#
        Endif
        BOUTBAS=1
    Else
        Call ENT_PAR(NOMANCR,-1,[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA
    Endif

# Barre de menu : le premier est une introduction, les suivants sont le détail
  Elsif [ADO]PAR="BME"

# Gestion du premier paragraphe de ce type
    If BARREME=0
        If [ADO]TIT=""
            Call ENT_PAR(NOMANCR,0,func AGENADO.MST(90,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Barre de menus"
        Else
            Call ENT_PAR(NOMANCR,0,[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA
        Endif
        BARREME=1

# Si aucun texte n'existe, on met un texte standard, sinon on reprendra le texte qui s'y trouve
        Gosub LEC_ADO From AGENDOCA
        If TEXTES(1)=""
            # "Les opérations suivantes sont possibles à partir de la barre de menus"
            Wrseq '        <p>'+func AGENADO.MST(91,142)+" :</p>" Using [DOC]
            INCLUT_TEXTE=0
        Endif

# Les autres paragraphes sont gérés normalement
    Else
        Call ENT_PAR(NOMANCR,0,[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA
    Endif

# Pour les onglets, on fait précéder du texte Onglet et on met le titre en italique
# Sauf si le titre est vide (on met alors Onglet 1, 2... 10 dans l'ordre des rangs d'apparition)
  Elsif pat([ADO]PAR,"ON*")
    RONG+=1
    If [ADO]TIT=func AGENADO.MST(83,142) : # "Ecran de saisie"
        Call ENT_PAR(NOMANCR,0,func AGENADO.MST(83,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Ecran de saisie"
    Elsif [ADO]TIT<>""
        #VPO 07/11/08 47899 enlever italique
        If IF_DOCV5=0
        Call ENT_PAR(NOMANCR,0,func AGENADO.MST(63,142)-[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Onglet"
        Else
        Call ENT_PAR(NOMANCR,0,func AGENADO.MST(63,142)-"<i>"+[ADO]TIT+"</i>",INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Onglet"
        Endif
    Else
        Call ENT_PAR(NOMANCR,0,func AGENADO.MST(146,142)-num$(RONG),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Onglet numéro"
    Endif

# Si le titre est vide, ou si on génère ERR, le sous-programme de génération spécialisé prendra le relais
  #VPO 19/06/08 39766 ajout ATD: différences de tables (PAR=UPD)
  Elsif [ADO]TIT<>"" and [ADO]PAR<>"ERR" and [ADO]PAR<>"UPD"
    # Le titre "!" est ignoré dans les paragraphes de type MIN
    If [ADO]TIT<>"!" or [ADO]PAR<>"MIN"
        Call ENT_PAR(NOMANCR,0,[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA
    Endif
  Endif

# Rajout de l'ancre dans le cas du paragraphe MIN (pour pouvoir se brancher dessus)
  If [ADO]PAR="MIN"
     Wrseq '<a name="MIN_'+num$([ADO]LEV)+"_"+num$([ADO]SUBLEV)+'"></a>' Using [DOC]
  Endif


# Si le paragraphe est un onglet dans une aide fonction, maj du flag bouton sur onglets
  If [ADO]PAR="ECR" or [ADO]PAR="ENT" or pat([ADO]PAR,"ON*")
    BOT_G=0
    BOT_PAR=[ADO]PAR
    BOT_LEV=[ADO]LEV
  Endif

# Si le paragraphe donne une série de codes activités liés, il faut les mettre en forme
  If [ADO]PAR="ACV"     :  Gosub INCL_ACV
# Si le paragraphe définit des paramètres concernés, il faut les mettre en forme
# (sans pour autant inhiber le texte qui suit)
  Elsif [ADO]PAR="ADP"  :  Gosub INCL_ADP
# Si le paragraphe définit des paramètres de l'action, il faut les mettre en forme
# (sans pour autant inhiber le texte qui suit)
  Elsif [ADO]PAR="PAR"  :  Gosub INCL_PAR
# Si le paragraphe définit les habilitations, on le fait précéder de commentaires automatiques
  Elsif [ADO]PAR="HAB"  :  Gosub INCL_HAB
# Si le paragraphe définit des événements workflow concernés, il faut les mettre en forme
# (sans pour autant inhiber le texte qui suit)
  Elsif [ADO]PAR="AWA"  :  Gosub INCL_AWA
# Si le paragraphe définit des pré-requis divers, on le fait précéder de commentaires automatiques
  Elsif [ADO]PAR="PRD"  :  Gosub INCL_PRD
# Si le paragraphe définit les erreurs, on le fait précéder de commentaires automatiques
  Elsif [ADO]PAR="ERR"  :  Gosub INCL_ERR
# Si le paragraphe définit les écritures générées, on le fait précéder de commentaires automatiques
  Elsif [ADO]PAR="ECG"  :  Gosub INCL_ECG
# Si le paragraphe définit des compteurs, il faut les mettre en forme
  Elsif [ADO]PAR="ANM"  :  Gosub INCL_ANM
# Si le paragraphe définit des pièces automatiques, il faut les mettre en forme
  Elsif [ADO]PAR="GAU"  :  Gosub INCL_GAU
# Si le paragraphe définit des sections par défaut, il faut les mettre en forme
  Elsif [ADO]PAR="CDE"  :  Gosub INCL_CDE
# Si le paragraphe définit des états, il faut les mettre en forme
  Elsif [ADO]PAR="ARP"  :  Gosub INCL_ARP
# Si le paragraphe définit des transactions de saisie, il faut les mettre en forme
  Elsif [ADO]PAR="TRS"  :  Gosub INCL_TRS
# Si le paragraphe définit des écrans de consultation paramétrables, il faut les mettre en forme
  Elsif [ADO]PAR="GTC"  :  Gosub INCL_GTC
# Si le paragraphe définit des tâches batch associées, il faut les mettre en forme
  Elsif [ADO]PAR="ABT"  :  Gosub INCL_ABT
# Si le paragraphe définit les tables mises à jour, il faut les mettre en forme
  Elsif [ADO]PAR="ATB"  :  Gosub INCL_ATB
# Si le paragraphe définit les fonctions concernées, il faut les mettre en forme
  Elsif [ADO]PAR="AFC"  :  Gosub INCL_AFC
# Si le paragraphe définit les actions liées, il faut les mettre en forme
  Elsif [ADO]PAR="ACT"  :  Gosub INCL_ACT
# Si la paragraphe définit le niveau et les variables associées, il faut le mettre en forme
# (sans pour autant inhiber le texte qui suit)
  Elsif [ADO]PAR="LEV"  :  Gosub INCL_LEV
# Si le paragraphe définit les critères de l'état ou les paramètres d'un sous-programme,
# on génère la liste avant d'inclure le texte qui suit
  Elsif [ADO]PAR="CRI"  :
    If [ADO]TYP="ASU"
        Gosub INCL_ASUCRI
    Else
        Gosub INCL_CRI
    Endif
# Si le paragraphe définit les valeurs recommandées d'un paramètre de dimensionnement, on génère une phrase
# avant d'inclure le texte qui suit
  Elsif [ADO]PAR="REC" & [ADO]TYP="ADM"
    Gosub INCL_REC
# Si le paragraphe définit le contexte d'un déclencheur stat, on intègre des éléments du dictionnaire
# avant d'inclure le texte qui suit
  Elsif [ADO]PAR="CTX"
    If [ADO]TYP="PS1"
        Gosub INCL_PS1CT
    Elsif [ADO]TYP="AWA"
        Gosub INCL_AWACT
    Elsif [ADO]TYP="ADC"
        Gosub INCL_ADCCT
    Endif
# Si le paragraphe décrit un point d'entrée, on note simplement son code pour en tenir compte dans les
# paragraphes décrivant le contexte...
  Elsif [ADO]PAR="APE"
    LAST_APE=vireblc(ctrans([ADO]TIT," (","  "),3)
# Sur le paragraphe Critères, on met juste un texte introductif
  Elsif [ADO]PAR="TRG"
    Call PAR_PAR(func AGENADO.MST(152,142)-":") From AGENLIBA: # "Les critères complémentaires de déclenchement sont les suivants"
# Sur le paragraphe Destinataires, on met juste un texte introductif
  Elsif [ADO]PAR="DST"
    Call PAR_PAR(func AGENADO.MST(151,142)-":") From AGENLIBA : # "Le choix des destinataires est défini de la façon suivante"
# Sur le paragraphe Signatures, on met juste un texte introductif
  Elsif [ADO]PAR="SIG"
    Call PAR_PAR(func AGENADO.MST(149,142)-":") From AGENLIBA : # "Les différents choix de signatures possibles sont"
  Endif

# Inclusion du texte du CLOB s'il n'est pas vide
  If INCLUT_TEXTE
    Gosub LEC_ADO From AGENDOCA
    If TEXBASE
        If pat(vireblc(toupper(TEXTES(1)),0),"<P*")=0
            Wrseq '        <p>' Using [DOC]
        Endif
        Gosub WR_TEX From AGENDOCA
        If pat(vireblc(toupper(TEXTES(1)),0),"<P*")=0
            Wrseq '        </p>' Using [DOC]
        Endif
    Endif
  Endif

# Fin du paragraphe
  ##Call FIN_PAR_BOU From AGENLIBa

Return

#
# Sous-programmes de génération des paragraphes nécessitant une mise en page particulière
#
# Inclusion du paragraphe décrivant les éléments rattachées au menu PLA
#VPO 07/07/08 evol 48427 ajout par="LNK"
$INCL_PLA
# Début de la liste des éléments
  Wrseq '        <ul>' Using [DOC]

  If [ADO]COD="PLA_0"
    OLD=""
    For [ADO2] Where LAN=[ADO]LAN & TYP=[ADO]TYP & PAR="TIT" & (CODACT<>"FAL")
        If OLD<>left$([ADO2]COD,3)
            OLD=left$([ADO2]COD,3)
            Read [AOB]ABREV=OLD
            If fstat=0
            Wrseq '        <li><a href="../OBJ/'+left$([ADO2]COD,3)+'_0.htm">'+func AGENADO.RDT([AOB]LIBEL)+'</a></li>' Using [DOC]
            Endif
        Endif
    Next
  Else
    If pat([ADO]COD,"???_0")
        Filter [ADO2] Where LAN=[ADO]LAN & TYP=[ADO]TYP & LEV=10 & PAR="LNK" & (CODACT<>"FAL") & left$(COD,3)=left$([ADO]COD,3)  Order By TIT;COD
        OLDPLA=""
        For [ADO2]
            If OLDPLA<>[ADO2]TIT
                OLDPLA=[ADO2]TIT
                #JPGA 18/03/2010 BUG-59115: On élimine les caractères ASCII genant avec les accents pour que le nom du fichier sorte sans
                CH2=[ADO2]TIT  :  Gosub CORRIGE_PLA
                Wrseq '        <li><a href="../OBJ/'+left$([ADO]COD,3)+"_"+CH2+'_0.htm">'+[ADO2]TIT+'</a></li>' Using [DOC]
            Endif
        Next
        Filter [ADO2]
    Else
        For [ADO2] Where LAN=[ADO]LAN & TYP=[ADO]TYP & PAR="LNK" & (CODACT<>"FAL") & left$(COD,3)=left$([ADO]COD,3) & TIT=[ADO]TIT
            Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO2]COD;"TIT"
            If fstat=0
            Wrseq '        <li><a href="../OBJ/'+[ADO2]COD+'.htm">'+right$([AD1]COD,5)-[AD1]TIT+'</a></li>' Using [DOC]
            Endif
        Next
    Endif

    Wrseq '        </ul><P></P>' Using [DOC]
    Wrseq '        <ul>' Using [DOC]

    If pat([ADO]COD,"???_0")
        For [ADO2] Where LAN=[ADO]LAN & TYP=[ADO]TYP & PAR="TIT" & (CODACT<>"FAL") & left$(COD,3)=left$([ADO]COD,3)
            Read [AD1]ADO1=[ADO]LAN;[ADO]TYP;[ADO2]COD;"LNK"
            If fstat
            Wrseq '        <li><a href="../OBJ/'+[ADO2]COD+'.htm">'+right$([ADO2]COD,5)-[ADO2]TIT+'</a></li>' Using [DOC]
            Endif
        Next
    Endif
  Endif

  Wrseq '        </ul>' Using [DOC]

Return

# Inclusion du paragraphe décrivant les code activités
$INCL_ACV

  # On recherche les valeurs dans le dictionnaire
  If [ADO]TYP="AFC"
    Gosub RECH_ACV
  Elsif [ADO]TYP="ACV"
    II=0
    Gosub ACV_ACV
  Elsif [ADO]TYP="ADP"
    Gosub LIT_VALEURS
    Gosub ACV_ADP
  Endif

# Suppression des codes activités internes au superviseur
  Gosub ELIMINE_ACV From AGENDOCA

  # On recherche les dépendants en cascade
  If [ADO]TYP<>"ACV"
      JJ=1
      While JJ<II
          Read [ACV]CODACT=VALEURS(JJ)
          If [ACV]DEP=2 or [ACV]DEP=3
            II+=1
            VALEURS(II)=[ACV]ACTDEP
            II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
          Elsif [ACV]DEP=4
            CH7=vireblc(vireblc(ctrans([ACV]ACTFOR,"=<>^*-+/()[]!1234567890",space$(40)),5),2)
            While CH7<>""
                Read [ACV]CODACT=vireblc(CH7,3)
                If fstat=0
                    II+=1
                    VALEURS(II)=[ACV]ACTDEP
                    II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
                Endif
                CH7=right$(CH7,len(vireblc(CH7,3))+2)
            Wend
          Endif
          JJ+=1
      Wend
   Endif

  # Le type correspond au menu local 93, mais on force type=0 pour les codes activités dépendants
  # On recompte les valeurs dans II
  KK=II : II=0
  For JJ=1 To KK
    Read [ACV]CODACT=VALEURS(JJ)
    If fstat=0
        II+=1
        VALEURS(II)=VALEURS(JJ)
        TYPINS(II)=([ACV]DEP=1)*[ACV]TYP
    Endif
  Next JJ

  # A ce stade, le tableau VALEUR, TYPINS est rempli
  # On le trie par type, pour créer un inter-titre si plusieurs types existent
  If II>0

    Sorta II TYPINS,VALEURS

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("ACV",0,func AGENADO.MST(6,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA
    Endif

    # Le petit bout de phrase introductif...
    If [ADO]TYP='ACV'
        If min(TYPINS(1..II))<>max(TYPINS(1..II))
            # "Les codes activités techniques suivants sont liés au code"
            Call PAR_PAR(func AGENADO.MST(154,142)-[ADO]COD+".") From AGENLIBA
        Else
            # "Les codes activités techniques suivants sont liés au code"
            # "Ces codes ne sont jamais saisis en gestion de dossier, car leur valeur est calculée"
            Call PAR_PAR(func AGENADO.MST(154,142)-[ADO]COD+"."+func AGENADO.MST(155,142)+".") From AGENLIBA
        Endif
    Elsif [ADO]TYP='ADP'
        # "Les codes activités suivants (classés par type) sont..."
        # "associés au paramètre"
        Call PAR_PAR(func AGENADO.MST(111,142)-":") From AGENLIBA
    Else
        # "Les codes activités suivants (classés par type) ont..."
        # "une influence sur le comportement de la fonction"
        Call PAR_PAR(func AGENADO.MST(284,142)-":") From AGENLIBA
    Endif


    For JJ=1 To II

        Read [ACV]CODACT=VALEURS(JJ)

        # Si on change de type de code activité
        If min(TYPINS(1..II))<>max(TYPINS(1..II))
            If JJ=1 or (TYPINS(max(JJ-1,1))<>TYPINS(JJ))
                If TYPINS(JJ)=0
                    Call TIT_PAR([ADO]STY+1,func AGENADO.MST(5,142)) From AGENLIBA: # "Codes activités dépendants"
                    # "Ces codes ne sont jamais saisis en gestion de dossier, car leur valeur est calculée"
                    Call PAR_PAR(func AGENADO.MST(155,142)+"&nbsp;:") From AGENLIBA
                Else
                    Call TIT_PAR([ADO]STY+1,func AGENADO.MST(TYPINS(JJ),93)) From AGENLIBA
                Endif
            Endif
        Endif

        If TYPINS(JJ)=0 : # Les codes dépendants sont affichés sur une ligne sans lien
            If JJ=1 : Gosub BULLET : Endif
            Wrseq VALEURS(JJ)-"("+func AGENADO.RDT([ACV]LIBACT)+")"; Using [DOC]
            If TYPINS(JJ+1)=1 or JJ=II
                Wrseq "." Using [DOC]
                Wrseq '        </p>' Using [DOC]
            Else
                Wrseq ", "; Using [DOC]
            Endif
        Else : # Les codes indépendants sont présentés en liste de bullets
            Gosub BULLET
            Wrseq '          <a href="../OBJ/ACV_'+VALEURS(JJ)+'.htm">'+VALEURS(JJ)
&                 +'</a>&nbsp;:&nbsp;'Using [DOC]
            Wrseq '          '+func AGENADO.RDT([ACV]LIBACT) Using [DOC]
            Wrseq '        </p>' Using [DOC]
        Endif
    Next JJ

  Endif
Return

# Inclusion du paragraphe décrivant les paramètres généraux (ACV/ADP/AFC/AOE)
$INCL_ADP

  # On recherche les valeurs dans la table des liens dans les deux sens
  Gosub LIT_VALEURS
  Gosub LIT_AUSSI_VALINV

# On lit ensuite dans le dictionnaire
  If [ADO]TYP="ACV"
    Gosub ADP_ACV
#  Elsif [ADO]TYP="ADP"
#    Gosub ADP_ADP
  Endif

  # On recompte les valeurs
  KK=II : II=0
  For JJ=1 To KK
    Read [ADP]ADP1=VALEURS(JJ)
    If fstat=0
        II+=1
        VALEURS(II)=VALEURS(JJ)
        FAMINS(II)=[ADP]CHAPITRE
    Endif
  Next JJ

  # A ce stade, le tableau VALEURS, FAMINS est rempli
  # On le trie par type, pour créer un inter-titre si plusieurs types existent
  If II>0

    Sorta II FAMINS,VALEURS

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        If [ADO]TYP='ADP'
            Call ENT_PAR([ADO]PAR,0,func AGENADO.MST(158,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Paramètres liés"
        Else
            Call ENT_PAR([ADO]PAR,0,func AGENADO.MST(9,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Paramètres généraux"
        Endif
    Endif

    # Le petit bout de phrase introductif...
    If [ADO]TYP='ACV'
        # "Les paramètres suivants ne sont utilisables que si le code activité est activé"
        Call PAR_PAR(func AGENADO.MST(159,142)) From AGENLIBA
    Elsif [ADO]TYP='ADP'
        # "Les paramètres suivants sont liés au paramètre..."
        Call PAR_PAR(func AGENADO.MST(166,142)-[ADO]COD-"&nbsp;:") From AGENLIBA
    Elsif [ADO]TYP='AOE'
        Call PAR_PAR(func AGENADO.MST(168,142)) From AGENLIBA : # "Les paramètres suivants doivent être renseignés"
    Else
        # "Les paramètres généraux suivants ont une influence sur le comportement de la fonction"
        Call PAR_PAR(func AGENADO.MST(10,142)-":") From AGENLIBA
    Endif

    For KK=1 To II

        # On change de famille de paramètre
        # BUG n°51149 - JPGA - 19/12/2008 : Affichage du nom de famille même si on a 1 seule famille
        # If min(FAMINS(1..II))<>max(FAMINS(1..II))
            If KK=1 or (FAMINS(max(KK-1,1))<>FAMINS(KK))
                # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                Call TIT_PAR([ADO]STY+1,func AGENLIBA.RECH_DESIGNATION('ADI', '901', FAMINS(KK))) From AGENLIBA
            Endif
        # Endif

        Read [ADP]ADP1=VALEURS(KK)
        Gosub BULLET
        Wrseq '          <a href="../OBJ/ADP_'+FAMINS(KK)+"_"+VALEURS(KK)+'.htm">'; Using [DOC]
        Wrseq VALEURS(KK)+'</a>'-func AGENADO.MST(11,142)-'<i>'+func AGENADO.MST([ADP]NIVDEF,987); Using [DOC]
        Wrseq '</i>)&nbsp;:&nbsp;'+func AGENADO.RDT([ADP]NAM) Using [DOC]
        Wrseq '        </p>' Using [DOC]

    Next KK

  Endif
Return

# Inclusion du paragraphe décrivant les événements Workflow liés
$INCL_AWA

  # On recherche les valeurs dans la table des liens dans les deux sens
  Gosub LIT_VALEURS
  Gosub LIT_AUSSI_VALINV

  If II
    If [ADO]TYP="AFC"
      # "Les événements Workflow suivants peuvent être déclenchés par la fonction"
      Call PAR_PAR(func AGENADO.MST(123,142)+" :") From AGENLIBA
    Elsif [ADO]TYP="AWA"
      # "L'événement Workflow est dépendant des événements Workflow suivants"
      Call PAR_PAR(func AGENADO.MST(128,142)+" :") From AGENLIBA
    Endif
    For KK=1 To II
        Read [AWA]AWA0=VALEURS(KK)
        Gosub BULLET
        Wrseq '          <a href="../OBJ/AWA_'+VALEURS(KK)+'.htm">'; Using [DOC]
        # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
        Wrseq VALEURS(KK)+'</a>'-func AGENLIBA.RECH_DESIGNATION('AWA', [AWA]CODE, '') Using [DOC]
        Wrseq '        </p>' Using [DOC]
    Next KK
 Endif
Return

# Inclusion du paragraphe décrivant les paramètres de l'action
$INCL_PAR

# Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
      Call ENT_PAR("PAR",0,func AGENADO.MST(188,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Paramètres de l'action"
  Endif

# Le petit bout de phrase introductif...
# ... puis le tableau des paramètres (si des paramètres existent)
  If [ACT]NBPAR>0
    Call PAR_PAR(func AGENADO.MST(189,142)-":") From AGENLIBA : # "LES paramètres de l'action sont les suivants"
    Call WRPARAMACT From AGENADOF
  Else
    Call PAR_PAR(func AGENADO.MST(190,142)) From AGENLIBA : # "Cette action n'admet aucun paramètre"
  Endif
  If [ACT]TYPACT=2
    Call PAR_PAR(func AGENADO.MST(201,142)) From AGENLIBA : # "Quand l'action est appelée depuis un champ, le 1er paramètre est..."
  Endif
  If [ACT]PARAM6=2
    Call PAR_PAR(func AGENADO.MST(208,142)) From AGENLIBA : # "Quand l'action est appelée depuis un champ, le 1er paramètre est..."
  Endif
Return


# Inclusion du paragraphe décrivant les compteurs
$INCL_ANM

  # On recherche les valeurs dans le dictionnaire
  Gosub LIT_VALEURS

  If II>0

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("ANM",0,func AGENADO.MST(13,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Compteurs"
    Endif

    # Le petit bout de phrase introductif...
    # "Les" < "compteurs" > "utilisés pour numéroter les documents associés à cette fonction sont"
    Call PAR_PAR(func AGENADO.MST(15,142)-'<a href="../FCT/GESANM.htm">'+func AGENADO.MST(16,142)+'</a>'-func AGENADO.MST(17,142)-":") From AGENLIBA

    For KK=1 To II
        Read [ANM]ANM0=VALEURS(KK)
        Gosub BULLET
        # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
        Wrseq [ANM]CODNUM-":"-func AGENLIBA.RECH_DESIGNATION('ANM', [ANM]CODNUM, '')+'</p>' Using [DOC]
    Next KK

    # Si la case sur les affectations automatique est cochée...
    # Changer la structure pour n'en avoir qu'une
    # A revoir !!!
    # dans un premier temps, vérifier que la fonction existe
    # dans un deuxième temps, tester un lien à créer ...
    Read [AF1]CODINT="GESTCA"
    If fstat=0
        # "La fonction d'" < "affectation des compteurs" > "permet de définir quel code de compteur est utilisé"
        Wrseq "      <p>"+func AGENADO.MST(18,142)-'<a href="../FCT/GESTCA.htm">'+func AGENADO.MST(19,142); Using [DOC]
        Wrseq '</a>'-func AGENADO.MST(20,142)+'</p>' Using [DOC]
        Wrseq Using [DOC]
    Endif
  Else
     # "Il n'y a pas de compteur utilisé par cette fonction"
     Wrseq "      <p>"+func AGENADO.MST(14,142)+".</p>" Using [DOC]
  Endif

Return

# Inclusion du paragraphe décrivant les pièces automatiques
# Ces codes sont présents dans le texte sous la forme d'une liste avec séparateurs virgule
$INCL_GAU

  # On recherche les valeurs dans le dictionnaire
  Gosub LIT_VALEURS

  If II>0

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("GAU",0,func AGENADO.MST(27,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Pièces automatiques"
    Endif

    # Le petit bout de phrase introductif...
    # "Les" < "pièces automatiques" >
    # "suivantes sont utilisées dans les processus de comptabilisation liés à la fonction"
    Call PAR_PAR(func AGENADO.MST(29,142)-'<a href="../FCT/GESGAU.htm">'+func AGENADO.MST(30,142)+'</a>'-func AGENADO.MST(31,142)-":") From AGENLIBA

    For KK=1 To II
        Read [GAU]GAU0=VALEURS(KK)
        Gosub BULLET
# Il faudrait un intitulé traduisible...
        Wrseq '<a href="../OBJ/GAU_'+[GAU]COD+'.htm">'+[GAU]COD-"</a>:"-[GAU]DES+'</p>' Using [DOC]
    Next KK

  Else
    # "Il n'y a pas de pièce comptable utilisée par cette fonction"
    Wrseq "      <p>"+func AGENADO.MST(22,142)+"</p>" Using [DOC]
  Endif

Return

# Inclusion du paragraphe décrivant les sections
# Ces codes sont présents dans le texte sous la forme d'une liste avec séparateurs virgule
$INCL_CDE

  # On recherche les valeurs dans le dictionnaire
  Gosub LIT_VALEURS

  If II>0

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("CDE",0,func AGENADO.MST(23,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA
    Endif

    # Le petit bout de phrase introductif...
    # "L'affectation des" < "sections par défaut" > "se fait via les codes suivants"
    Call PAR_PAR(func AGENADO.MST(24,142)-'<a href="../FCT/GESCDE.htm">'+func AGENADO.MST(25,142)+'</a>'-func AGENADO.MST(26,142)-":") From AGENLIBA

    # En V6 : les sections par défaut sont par société (clé = Code + Société)
    # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs "CDE"
    Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
    If find("CDE", [L]DOC_CLE_MULT)
       Call PAR_PAR(func AGENADO.MST(11,142)-'<i>'+func AGENADO.MST(2,987)+'</i>)') From AGENLIBA
    Endif

    For KK=1 To II
        # Il faudrait un intitulé traduisible...
        Gosub BULLET

        I = instr(1,VALEURS(KK),[L]WTIRET)
        If find("CDE", [L]DOC_CLE_MULT) & I
           Read [CDE]CDE0=left$(VALEURS(KK),I-1);right$(VALEURS(KK),I+1)
           Wrseq '<a href="../OBJ/CDE_'+VALEURS(KK)+'.htm">'; Using [DOC]
           Wrseq [CDE]COD+'</a>'-'(<i>'; Using [DOC]
           If [CDE]CPY=""
              Wrseq func AGENADO.MST(145,139); Using [DOC]
           Else
              Wrseq func AGENADO.MST(2,987)-':'-[CDE]CPY; Using [DOC]
           Endif
           # JPGA 130/09/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
           Wrseq '</i>'-')&nbsp;:&nbsp;'+func AGENLIBA.RECH_DESIGNATION('CDE', [CDE]COD, ''); Using [DOC]
           Wrseq '</p>' Using [DOC]
        Else
           Read [CDE]CDE0=VALEURS(KK)
           # JPGA 130/09/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
           Wrseq '<a href="../OBJ/CDE_'+VALEURS(KK)+'.htm">'+[CDE]COD+"</a>&nbsp:"-func AGENLIBA.RECH_DESIGNATION('CDE', [CDE]COD, '')-"("+")"+'</P>' Using [DOC]
        Endif
    Next KK
  Else
    # "Il n'y a pas de section automatique utilisée par cette fonction"
    Wrseq "      <p>"+func AGENADO.MST(28,142)+".</p>" Using [DOC]
  Endif

Return

# Inclusion du paragraphe décrivant les habilitations
$INCL_HAB

  # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR("HAB",0,func AGENADO.MST(124,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Habilitations"
  Endif

  # Si c'est un objet
  If CODOBJ<>""
    Read [AOB]ABREV=CODOBJ
    If fstat=0
        # "Cette fonction est de type objet. Les opérations de création, modification, et"
        Wrseq '          <p>'+func AGENADO.MST(40,142) Using [DOC]
        # "suppression de fiche peuvent être activées ou désactivées pour un utilisateur donné"
        Wrseq '             '+func AGENADO.MST(41,142)+"." Using [DOC]
        # "Des filtres par" < "rôles" >
        Wrseq '             '+func AGENADO.MST(42,142)-'<a href="GESARL.htm">'+func AGENADO.MST(43,142)+'</a>'  Using [DOC]
        # "peuvent également être mis en place sur cette fonction"
        Wrseq '             '+func AGENADO.MST(44,142)+".</p>" Using [DOC]
    Endif
  Endif

  # Si c'est un objet ou une consultation
  If CODOBJ<>"" or CODCON<>""
    # S'il y a des habilitations par site et/ou société (selon le produit)
    Read [AFC]CODINT=[ADO]COD
    If [AFC]FCYAUZ=2
        # "Les données étant rattachées à un site, un filtrage par site peut être activé"
        # "Les données étant rattachées à un site ou une société,...
        #  ...un filtrage par site ou société peut être activé"
        Wrseq '          <p>'+func AGENADO.MST(45+(PRODUIT=3)*100,142)+".</p>" Using [DOC]
    Endif
  Elsif [AFC]FCYAUZ=2
    # Cas particulier de filtre société site sur des traitements (ex : VALSTA)
    # "Une habilitation peut être réalisée sur cette fonction,
    #   pour limiter les traitements à une société ou à un site
    Wrseq '          <p>'+func AGENADO.MST(167,142)+".</p>" Using [DOC]
  Endif

  # Si c'est un objet
  If CODOBJ<>""

    # S'il y a une gestion par codes d'accès
    If [AOB]ZACC<>""
        # "Un filtrage par code d'accès est effectué grâce au champ nommé..."
        Wrseq '          <p>'+func AGENADO.MST(135,142)-[AOB]ZACC+". " Using [DOC]
        # "Si un" <
        Wrseq '             '+func AGENADO.MST(136,142)-'<a href="GESACS.htm">';Using [DOC]
        # "code d'accès" >
        # "s'y trouve, les droits de visualisation et de modification sont accordés conformément"
        Wrseq func AGENADO.MST(137,142)+'</a>'-func AGENADO.MST(138,142) Using [DOC]
        # "aux droits de lecture et d'écriture associés au code pour l'utilisateur, via son"
        # < "profil fonction" >
        Wrseq '             '+func AGENADO.MST(139,142)-'<a href="GESAFT.htm">'+func AGENADO.MST(140,142)+'</a>.' Using [DOC]
        Wrseq '          </p>' Using [DOC]
    Endif
  Endif

  # S'il y a des options
  If [AFC]NBOPT
    # "Les options suivantes peuvent être activées ou désactivées pour chaque utilisateur"
    Wrseq '          <p>'+func AGENADO.MST(46,142)-":" Using [DOC]
    For II=1 To [AFC]NBOPT
        Gosub BULLET
        Wrseq '          '+func AGENADO.RDT([AFC]OPTION(II-1)) Using [DOC]
        Wrseq '        </p>' Using [DOC]
    Next II
  Endif

Return

# Inclusion du paragraphe décrivant les pré-requis divers
$INCL_PRD

  LL=0

  # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR("PRD",0,func AGENADO.MST(126,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Autres pré-requis
  Endif

  # On recherche les tables diverses dans le dictionnaire
  LNK_TYPE="ADI"
  Gosub LIT_PAR_VAL
  If II>0
    LL=1
    Call ENT_PAR("",[ADO]STY+1,func AGENADO.MST(48,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Tables diverses"
    # "Les tables diverses suivantes sont utilisées par la fonction. Elles doivent donc être renseignées"
    Wrseq '        <p>'+func AGENADO.MST(49,142)-":"+'</p>' Using [DOC]
    For KK=1 To II
        Gosub BULLET
        Read [ADV]CODE=val(VALEURS(KK))
        Wrseq '          '+func AGENADO.MST(50,142); Using [DOC] : # "Table diverse numéro"
        # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
        Wrseq ' '+num$(VALEURS(KK))+' : '+func AGENLIBA.RECH_DESIGNATION('ADV', num$([ADV]NUMTAB), '') Using [DOC]
        Wrseq '        </p>' Using [DOC]
    Next KK
  Endif

  # On recherche les tables de pré-requis dans le dictionnaire
  LNK_TYPE="AT2"
  Gosub LIT_PAR_VAL
  If II>0
    LL=1
    Call ENT_PAR("PR",[ADO]STY+1,func AGENADO.MST(51,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Tables à renseigner"
    # "Les tables suivantes sont utilisées par la fonction...
    # " Leur contenu doit donc être éventuellement mis à jour"
    Wrseq '        <p>'+func AGENADO.MST(52,142)+' :</p>' Using [DOC]
    Call WRTABLE(VALEURS,II) From AGENADOF
  Endif

# S'il y a des menus locaux concernés
  LNK_TYPE="AML"
  Gosub LIT_PAR_VAL
  If II>0
    LL=1
    Call ENT_PAR("",[ADO]STY+1,func AGENADO.MST(54,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Menus locaux"

    # Le petit bout de phrase introductif...
    # "Les menus locaux paramétrables suivants sont utilisés par la fonction....
    # " Ils doivent donc être renseignés"
    Call PAR_PAR(func AGENADO.MST(55,142)-":") From AGENLIBA

    For JJ=1 To II
        Gosub BULLET
        Wrseq '          '+func AGENADO.MST(56,142); Using [DOC]
        Wrseq ' '+'<a href="../MCD/MEN'+func AGENLIBA.FORMAT_AML(val(VALEURS(JJ)))+'.htm">'; Using [DOC]
        Wrseq VALEURS(JJ)+'</a>'; Using [DOC]
        Wrseq '&nbsp;:&nbsp;'+func TML(val(VALEURS(JJ)))+'</p>' Using [DOC]
    Next II

  Endif

# S'il y a un texte complémentaire, on écrit un en-tête en plus si le texte ne commence pas par un titre
  Gosub LEC_ADO From AGENDOCA
  If TEXBASE & pat(toupper(vireblc(TEXTES(1),0)),"<H#>*")=0 & LL=1
    Call ENT_PAR("",[ADO]STY+1,func AGENADO.MST(57,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Pré-requis divers"
  Endif

Return

# Inclusion du paragraphe décrivant les erreurs
$INCL_ERR
  Wrseq '      <div class="links">' Using [DOC]
  Wrseq '      <h3 class="g1"><span></span></h3>' Using [DOC]
  Wrseq '        <ul>' Using [DOC]
  # "Messages génériques"
  Wrseq '          <li><a href="../FCT/ERR_GEN.htm">'+func AGENADO.MST(127,142)+'</a></li>' Using [DOC]
  Wrseq '        </ul>' Using [DOC]
  Wrseq '      </div>' Using [DOC]

  # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR("ERR",0,func AGENADO.MST(97,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Messages d'erreur"
  Else
    Call ENT_PAR("ERR",0,[ADO]TIT,INCLUT_TEXTE,BOT_PAR) From AGENLIBA
  Endif

  Gosub LEC_ADO From AGENDOCA
  If TEXBASE=0
      # "Il n'y a pas de message d'erreur autre que les messages d'erreur génériques"
      Call PAR_PAR(func AGENADO.MST(32,142)+".") From AGENLIBA
  Else
      # "Outre les messages génériques, les messages d'erreur suivants peuvent apparaître lors de la saisie"
      Call PAR_PAR(func AGENADO.MST(98,142)-":") From AGENLIBA
  Endif

  #VPO 13/10/08 44226: on gere mess(xx,xx,xx)
  Gosub RECHERRMESS
  Onerrgo ERR_ADH : # 120220
  If TEXBASE=1
    Call MAJ_ERR([ADH]TEXTE,II,VALEURS) From AGENADOF
  Elsif TEXBASE=2
    Call MAJ_ERR([ADH2]TEXTE,II,VALEURS) From AGENADOF
  Endif
  Onerrgo
  INCLUT_TEXTE=0
  Gosub WR_TEX From AGENDOCA
Return

$ERR_ADH
Gosub ERR_ADH From AGENADOF
Resume

$RECHERRMESS
# Recherche des mess( dans les paragraphes ERR (1 lien=1 ligne dans TEXTES : renvoie II valeurs)
  II=1
  JJ=1
  While TEXTES(JJ)<>""
    CHAINE=ctrans(vireblc(TEXTES(JJ),0),chr$(13)+chr$(10),'')
    JJ+=1
    While CHAINE<>""
        If pat(tolower(CHAINE),"*mess(*")
            CHAINE=right$(CHAINE,5+instr(1,tolower(CHAINE),"mess("))
            KK=instr(1,tolower(CHAINE),")")
            If KK
                VALEURS(II)=vireblc(left$(CHAINE,KK-1),2)
                II+=1
                CHAINE=vireblc(right$(CHAINE,KK+1),0)
            Else
                Break 2*(TEXTES(JJ)="") : # Sortie de boucle
                #VPO 24/10/08 49974
                # JPGA 21-04-2009 BUG-54580 : plantage sur recherche de mess(...) dans TEXTES qui est trop grand par rapport à CHAINE (5 passe a 15)
                If len(CHAINE)>15
                    CHAINE=right$(CHAINE,len(CHAINE)-14)
                Endif
                CHAINE+=ctrans(vireblc(TEXTES(JJ),0),chr$(13)+chr$(10),'')
                JJ+=1
                KK=instr(1,tolower(CHAINE),")")
                If KK
                    VALEURS(II)=vireblc(left$(CHAINE,KK-1),2)
                    II+=1
                    CHAINE=vireblc(right$(CHAINE,KK+1),0)
                Endif
            Endif
        Else
            Break 2*(TEXTES(JJ)="") : # Sortie de boucle
            #VPO 24/10/08 49974
            # JPGA 21-04-2009 BUG-54580 : plantage sur recherche de mess(...) dans TEXTES qui est trop grand par rapport à CHAINE (5 passe a 15)
            If len(CHAINE)>15
                CHAINE=right$(CHAINE,len(CHAINE)-14)
            Endif
            CHAINE+=ctrans(vireblc(TEXTES(JJ),0),chr$(13)+chr$(10),'')
            JJ+=1
        Endif
    Wend
  Wend
Return

# Inclusion du paragraphe décrivant les écritures générées
$INCL_ECG

  # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR("ERR",0,func AGENADO.MST(76,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Ecritures générées"
  Endif

  # "Les écritures suivantes sont générées"
  Call PAR_PAR(func AGENADO.MST(77,142)-":") From AGENLIBA

Return

# Inclusion du paragraphe décrivant les états associés
# Ces codes sont présents dans le texte sous la forme d'une liste avec séparateurs virgule
$INCL_ARP

  # On recherche les états à la fois dans la table des liens et dans le dictionnaire
  Gosub LIT_VALEURS
  Gosub ARP_AFC

  If II>0

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR([ADO]PAR,0,func AGENADO.MST(78,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Etats"
    Endif

    # Le petit bout de phrase introductif...
    # "Par défaut, les états suivants sont associés à la fonction"
    Call PAR_PAR(func AGENADO.MST(79,142)-":") From AGENLIBA

    For KK=1 To II
        Read [ARP]ARP0=VALEURS(KK)
        Gosub BULLET
        Wrseq '          '; Using [DOC]
        Read [AD1]ADO0=[ADO]LAN;"ARP";VALEURS(KK);10;10
        If fstat=0
            Wrseq '<a href="../OBJ/ARP_'+VALEURS(KK)+'.htm">'+VALEURS(KK)+'</a>'; Using [DOC]
        Else
            Wrseq VALEURS(KK); Using [DOC]
        Endif
        Wrseq '&nbsp;:&nbsp;'+func AGENADO.RDT([ARP]RPTDES) Using [DOC]
        Wrseq '        </p>' Using [DOC]
    Next KK

    # Le petit bout de phrase final ...
    # Prévoir un lien vers les fonctions idoines ???
    Call PAR_PAR(func AGENADO.MST(80,142)+".") From AGENLIBA : # "Mais ceci peut être modifié par paramétrage"

  Endif
Return

# Inclusion du paragraphe décrivant les tables mises à jour
# On recherche celle que l'on peut trouver dans le dictionnaire
# On complète par celles qui sont donnés dans les liens
$INCL_ATB

  # On recherche les tables dans la table des liens, puis dans le dictionnaire
  Gosub LIT_VALEURS
  If [ADO]TYP="AFC"
    Gosub ATB_AFC
  Elsif [ADO]TYP="ADM"
    Gosub ATB_ADM
  Elsif [ADO]TYP="AWA"
    Gosub ATB_AWA
  Elsif [ADO]TYP="ARP"
    Gosub ATB_ARP From AGENDOCA
  Elsif [ADO]TYP="AOE"
    Gosub ATB_AOE
  Elsif [ADO]TYP="PS1"
    Gosub ATB_PS1 From AGENDOCA
  Endif

  # On recherche les types de tables (communes/autres)
  JJ=II : II=0
  For KK=1 To JJ
    Read [ATB]CODFIC=VALEURS(KK)
    If fstat=0
        II+=1
        VALEURS(II)=VALEURS(KK)
        TYPINS(II)=([ATB]TYPFIC=3)
    Endif
  Next KK

  # A ce stade, le tableau VALEURS, TYPINS est rempli
  # On le trie par type, pour créer un inter-titre si plusieurs types existent

 # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR([ADO]PAR,0,func AGENADO.MST(101,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Tables mises en oeuvre"
  Endif

  If II>0

    Sorta II TYPINS,VALEURS

    # Le petit bout de phrase introductif selon que c'est une consultation, une variable de dimensionnement,
    # un modèle d'import/export, un événement Workflow ou une autre fonction ...
    If CODCON<>""
        # "Cette fonction étant une fonction de consultation, aucune table n'est mise à jour" .
        # "Mais les informations issues des tables suivantes sont utilisées"
        Call PAR_PAR(func AGENADO.MST(99,142)+"."-func AGENADO.MST(100,142)-":") From AGENLIBA
    Elsif [ADO]TYP='ADM'
        # "Les tables suivantes sont dimensionnées par la variable"
        Call PAR_PAR(func AGENADO.MST(47,142)-[ADO]COD+"&nbsp;:") From AGENLIBA
    Elsif [ADO]TYP='ARP'
        # "Les données extraites des tables suivantes sont utilisées par l'état"
        Call PAR_PAR(func AGENADO.MST(74,142)-[ADO]COD+"&nbsp;:") From AGENLIBA
    Elsif [ADO]TYP='AWA'
        # "Les tables suivantes sont concernées par la règle"
        Call PAR_PAR(func AGENADO.MST(53,142)-[ADO]COD+"&nbsp;:") From AGENLIBA
    Elsif [ADO]TYP='PS1'
        # "Les tables suivantes sont utilisables dans les statistiques liées à l'événement déclenchant"
        Call PAR_PAR(func AGENADO.MST(75,142)-[ADO]COD+"&nbsp;:") From AGENLIBA
    Elsif [ADO]TYP='AOE'
        Read [AOE]AOE0=[ADO]COD
        If [AOE]IMPORT=2
            If [AOE]EXPORT=2
                # "Ce modèle est utilisable à la fois en import et en export"
                # "Les données sont mises à jour dans les tables suivantes"
                Call PAR_PAR(func AGENADO.MST(202,142)+"."-func AGENADO.MST(204,142)+"&nbsp;:") From AGENLIBA
            Else
                # "Ce modèle n'est utilisable qu'en import"
                # "Les données sont mises à jour dans les tables suivantes"
                Call PAR_PAR(func AGENADO.MST(203,142)+"."-func AGENADO.MST(204,142)+"&nbsp;:") From AGENLIBA
            Endif
        Else
            # "Ce modèle n'est utilisable qu'en export"
            # "Les données sont extraites des tables suivantes"
            Call PAR_PAR(func AGENADO.MST(205,142)+"."-func AGENADO.MST(206,142)+"&nbsp;:") From AGENLIBA
        Endif
    Else
        # "Les tables suivantes sont mises en oeuvre par la fonction"
        Call PAR_PAR(func AGENADO.MST(105,142)-":") From AGENLIBA
    Endif

    If min(TYPINS(1..II))<>max(TYPINS(1..II))
        KK=find(1,TYPINS(1..II))-1
        Call WRTABLE(VALEURS,KK) From AGENADOF
        # "Cette fonction met à jour des tables communes à tous les dossiers, situées dans le superviseur"
        # "Ces tables sont les suivantes"
        Call PAR_PAR(func AGENADO.MST(103,142)+"."-func AGENADO.MST(104,142)-":") From AGENLIBA
        For JJ=KK+1 To II
            VALEURS(JJ-KK)=VALEURS(JJ)
        Next JJ
        II-=KK
    Endif
    Call WRTABLE(VALEURS,II) From AGENADOF

# Si aucune table n'est mise en oeuvre, et si aucun texte n'existe dans le clob, on met un message par défaut
  Else
      Gosub LEC_ADO From AGENDOCA
      If TEXBASE=0
          # "Aucune table n'est mise en oeuvre par cette fonction"
          Call PAR_PAR(func AGENADO.MST(102,142)+".") From AGENLIBA
      Endif
  Endif

Return

# Inclusion du paragraphe décrivant les fonctions concernées
# Concerne les paramètres et les codes activités
$INCL_AFC
  # On recherche les fonctions associées aux paramètres et les codes activité
  # en inverse dans la table des liens
  # (les fonctions pointent sur les paramètres et les codes activité
  If [ADO]TYP="ARP"
    Goto INCL_ACC : # Accès à l'état, ex paragraphe ACC renommé en AFC
  Elsif [ADO]TYP="ADP"
    Gosub LIT_VALINV
  Elsif [ADO]TYP="ACV"
    Gosub LIT_VALINV
    Gosub AFC_ACV
  Endif

  If II>0
    Sorta II VALEURS

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("FCT",0,func AGENADO.MST(192,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Fonctions concernées"
    Endif

    # Le petit bout de phrase introductif ...
    If [ADO]TYP='ADP'
        # "Les fonctions suivantes sont concernées par ce paramètre"
        Call PAR_PAR(func AGENADO.MST(58,142)+"&nbsp;:") From AGENLIBA
    Else
        # "Les fonctions suivantes sont impactées par le code activité"
        Call PAR_PAR(func AGENADO.MST(193,142)+"&nbsp;:") From AGENLIBA
    Endif

    Gosub INCL_FONCTIONS
  Endif
Return

# Inclusion d'une liste de fonctions trouvées dans le tableau valeurs(1..II-1)
$INCL_FONCTIONS

    # La liste des fonctions
    For JJ=1 To II

        # Pour éviter les problèmes liés aux fonctions non référencées dans un menu...
        Read [AF1]CODINT=VALEURS(JJ)
        If fstat=0 and [AF1]MENU<>""

            # Une petite bullet..
            Gosub BULLET

            # Recherche de l'arbrescence des menus
            IPIL=1
            While fstat=0 & [AF1]CODINT<>"GENE" & IPIL<6
                PILE_NOMEN(IPIL)=func AGENADO.RDT([AF1]LIBMENU)
                IPIL+=1
                Break [AF1]MENU=""
                Read [AF1]CODINT=[AF1]MENU
            Wend
            For KK=IPIL-1 To 1 Step -1
                Wrseq string$(KK=1,'<a href="../FCT/'+VALEURS(JJ)+'.htm">')+PILE_NOMEN(KK); Using [DOC]
                #JPGA 06/04/2010 BUG-60798 : Non fermeture de balise <a> sur Fonctions concernees AFC et ACC
                Wrseq string$(KK=1,'</a>')+string$(KK<>1,'&nbsp;&gt;&nbsp;'); Using [DOC]
            Next KK
            Wrseq '</p>' Using [DOC]
        Endif
    Next JJ

Return

# Inclusion du paragraphe décrivant les tâches batch associées
$INCL_ABT

  # On recherche les tâches dans le dictionnaire (et aussi dans la table de liens)
  Gosub LIT_VALEURS
  Gosub ABT_AFC From AGENDOCA

  # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR("ABT",0,func AGENADO.MST(89,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Tâche batch"
  Endif

  # La phrase qui va bien (elle inclut le code de la première tâche batch si elle existe)
  # "Cette fonction peut être lancée en batch"
  # "mais il n'existe pas de tâche standard dédiée à son lancement"
  # "La tâche standard"..."est prévue à cet effet"
  Call PAR_PAR(func AGENADO.MST(85,142)+string$(II>0,"."-func AGENADO.MST(87,142)-VALEURS(1)-func AGENADO.MST(88,142)+".")
&             +string$(II=0,","-func AGENADO.MST(86,142)+".")) From AGENLIBA

Return

# Inclusion du paragraphe décrivant la gestion des transactions associées
$INCL_TRS

  # On recherche les fonctions de gestion de transaction dans les liens dictionnaire
  Gosub LIT_VALEURS

  If II>0

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("TRS",0,func AGENADO.MST(33,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Transaction de saisie"
    Endif

# Si une seule fonction de gestion de transaction existe, on la met en lien direct
# Le petit bout de phrase introductif...
    # "Cette fonction est gérée par des" < "transactions de saisie" > "paramétrables"
    Call PAR_PAR(func AGENADO.MST(34,142)-string$(II=1,'<a href="./'+VALEURS(1)+'.htm">')+func AGENADO.MST(35,142)
&               +string$(II=1,'</a>')-func AGENADO.MST(36,142)+string$(II=1,".")+string$(II>1,"&nbsp;:&nbsp;")) From AGENLIBA

    If II>1
        For KK=1 To II
            Read [AFC]CODINT=VALEURS(KK)
            Gosub BULLET
            Wrseq '          <a href=".'+VALEURS(KK)+'.htm">'; Using [DOC]
            Wrseq VALEURS(KK)+'</a>&nbsp;:&nbsp;'+func AGENADO.RDT([AFC]NOM) Using [DOC]
            Wrseq '        </p>' Using [DOC]
        Next KK
    Endif
  Else
     # "Cette fonction n'est pas gérée par des transactions de saisie paramétrables"
     Wrseq "      <p>"+func AGENADO.MST(59,142)+"."+"</p>" Using [DOC]
  Endif
  Read [AFC]CODINT=[ADO]COD
Return

# Inclusion du paragraphe décrivant la gestion des écrans de consultation paramétables
$INCL_GTC

  # On recherche les codes de transactions de saisie correspondantes dans le dictionnaire
  If CODCON<>""

    Read [ACN]ACN0=CODCON
    If fstat=0

        # Recherche dans le dictionnaire
        II=0
        Gosub GTC_ACN

        # Si le titre n'est pas imposé, on l'impose
        If [ADO]TIT=""
            Call ENT_PAR("ECC",0,func AGENADO.MST(1,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Ecrans de consultation"
        Endif

        # Le petit bout de phrase introductif...
        # "Les écrans ...sont paramétrables (code XXX) via la fonction de paramétrage correspondante"
        Call PAR_PAR(func AGENADO.MST(65,142)-"("+func AGENADO.MST(66,142)-[ACN]COD+")"-func AGENADO.MST(67,142)
&                   -'<a href="../FCT/GESGTC.htm">'+func AGENADO.MST(68,142)+'</a>'-func AGENADO.MST(69,142)+".") From AGENLIBA

        If II>0
            # "Les écrans pré-paramétrés livrés en standard sont les suivants"
            Call PAR_PAR(func AGENADO.MST(70,142)-":") From AGENLIBA
            For KK=1 To II
                Read [GTC]GTC0=CODCON;VALEURS(KK)
                Gosub BULLET
                # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                Wrseq '          '+VALEURS(KK)+"&nbsp;:&nbsp;"+func AGENLIBA.RECH_DESIGNATION('GTC', CODCON, VALEURS(KK))
&               Using [DOC]
                Wrseq '        </p>' Using [DOC]
            Next KK
        Endif
    Endif
  Endif
Return

# Inclusion du paragraphe décrivant les actions liées
$INCL_ACT

  If [ADO]TYP="AWA"
    Goto INCL_ACTAWA
  Endif

  # On recherche les tâches dans les liens dictionnaires
  Gosub LIT_VALEURS

  If II>0

    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("CDE",0,func AGENADO.MST(210,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Actions liées"
    Endif

    # Le petit bout de phrase introductif...
    Call PAR_PAR(func AGENADO.MST(61,142)-[ADO]CODACT+"&nbsp;:") From AGENLIBA : # "Les actions suivantes sont liées à l'action"

    For KK=1 To II
        Read [ACT]ACTION=VALEURS(KK)
        Gosub BULLET
        Wrseq '<a href="../OBJ/ACT_'+[ACT]ACTION+'">'; Using [DOC]
        Wrseq [ACT]ACTION+'</a>'-":"-func AGENADO.RDT([ACT]INTITA)+'</p>' Using [DOC]
    Next KK

  Endif

Return

# Inclusion du paragraphe décrivant les actions déclenchées par le Workflow
$INCL_ACTAWA
  # On recherche les actions dans les liens dictionnaires
  II=0
  For [AWC]AWC0 Where CODE=[AWA]CODE
    Read [ACT]ACTION=[AWC]ACTION
    If fstat=0
        II+=1
        VALEURS(II)=[AWC]ACTION
        II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        VALSUP(II)=func AGENADO.MST([AWC]DECACT,2923)
    Endif
  Next

  For JJ=1 To II
    Read [ACT]ACTION=VALEURS(JJ)
    Read [AD1]ADO1=[ADO]LAN;"ACT";VALEURS(JJ);"TIT"
    If fstat=0
        VALEURS(JJ)='<a href="../OBJ/ACT_'+VALEURS(JJ)+'.htm">'+VALEURS(JJ)+'</a>'
    Endif
    VALEURS(JJ)-=":"-func AGENADO.RDT([ACT]INTITA)
  Next JJ


  If II
    # Si le titre n'est pas imposé, on l'impose
    If [ADO]TIT=""
        Call ENT_PAR("CDE",0,func AGENADO.MST(134,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Actions déclenchées par l'événement"
    Endif

    Call PAR_PAR(func AGENADO.MST(129+82*(II=1),142)-":") From AGENLIBA : # "L'événement Workflow déclenche les actions suivantes"
    Call WRTAB2(func AGENADO.RDM("AWA5","ACTION"),func AGENADO.RDM("AWA5","DECACT"),50,50,VALEURS,VALSUP,II) From AGENADOF
  Endif

Return

# Inclusion du paragraphe décrivant les conditions d'accès à un état
# On recherche directement les conditions dans le dictionnaire, le texte ajouté est complémentaire
# Le premier est le numéro du groupe d'états pour l'accès (menu local 97)
# Les suivants sont les fonctions à partir desquelles cet état est accessible
$INCL_ACC
  Gosub LIT_VALINV
  Gosub AFC_ARP From AGENDOCA

  # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR("ACC",0,func AGENADO.MST(169,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Accès à l'état"
  Endif

  # Le petit bout de phrase introductif...
  Read [ARP]ARP0=[ADO]COD
  If [ARP]EXEFLG=2
    If II>0
        # "Cet état n'est pas directement exécutable, mais il est appelé depuis les fonctions suivantes"
        Call PAR_PAR(func AGENADO.MST(170,142)+","-func AGENADO.MST(171,142)+"&nbsp;:") From AGENLIBA
        Gosub INCL_FONCTIONS
    Else
        # "Cet état n'est pas directement exécutable"
        Call PAR_PAR(func AGENADO.MST(170,142)+".") From AGENLIBA
    Endif
  Else
    If [ARP]MODULE<>0
        # "Cet état est accessible à partir du menu d'impression du groupe..."
        #VPO 26/10/07 bug43778 Call PAR_PAR(func AGENADO.MST(172,142)-"<i>"+func AGENADO.MST([ARP]MODULE,97)+"</i>.") From AGENLIBA
        Call PAR_PAR(func AGENADO.MST(172,142)-"<i>"+func AGENADO.MST([ARP]GRP,97)+"</i>.") From AGENLIBA
        If II>0
            # "Il est aussi appelé par défaut depuis les fonctions suivantes"
            Call PAR_PAR(func AGENADO.MST(173,142)+"&nbsp;:") From AGENLIBA
            Gosub INCL_FONCTIONS
        Endif
    Endif
  Endif
Return

# Inclusion du paragraphe décrivant les paramètres d'un état
$INCL_CRI
  Read [ARP]ARP0=[ADO]COD
  If fstat=0
    If [ADO]TIT=""
        Call ENT_PAR("CRI",0,func AGENADO.RDM("PS23","CRI"),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Critères"
    Endif

    Call WRPARETAT(II,JJ) From AGENADOF

    # On regarde s'il y a bien des paramètres
    If JJ=0
        Call PAR_PAR(func AGENADO.MST(62,142)+".") From AGENLIBA : # "Cet état n'a pas de critères de lancement"
    Endif

    # On regarde s'il y a des choses à ajouter
    If II=1 or [ARP]PARSEG<>"" or ([ARP]AUZFCY=2 and [ARP]FNC<>"") or [ARP]PRTNAT>1
        Call ENT_PAR("",0,func AGENADO.MST(177,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Remarques"
        If II=1
            # "Dans un paramètre de type borne début/fin, ne rien saisir dans les deux "
            # "valeurs revient à ne pas borner l'état sur la valeur du paramètre"
            Call PAR_PAR(func AGENADO.MST(178,142)-func AGENADO.MST(179,142)+".") From AGENLIBA
        Endif
        If [ARP]PARSEG<>""
            # "Le paramètre" <...> "peut prendre plusieurs valeurs successives".
            Call PAR_DEB(func AGENADO.MST(180,142)-"<b>"+[ARP]PARSEG+"</b>"-func AGENADO.MST(181,142)+". ") From AGENLIBA
            # "L'état est alors segmenté en parties éditées successivement, bornées par"
            Call PAR_SUI(func AGENADO.MST(182,142)+"&nbsp;") From AGENLIBA
            # "les valeurs de bornes saisies. Ceci permet d'améliorer les"
            Call PAR_SUI(func AGENADO.MST(183,142)+"&nbsp;") From AGENLIBA
            # "performances de Crystal Reports (pagination se ralentissant pour"
            Call PAR_SUI(func AGENADO.MST(184,142)+"&nbsp;") From AGENLIBA
            # "des états particulièrement volumineux, sur plusieurs milliers de pages)"
            Call PAR_SUI(func AGENADO.MST(185,142)+".") From AGENLIBA
            Call PAR_FIN From AGENLIBA
        Endif
        If ([ARP]AUZFCY=2 and [ARP]FNC<>"")
            # "Un filtrage des données par site est réalisé selon les habilitations"
            Call PAR_DEB(func AGENADO.MST(186,142)+"&nbsp;") From AGENLIBA
            # "accordées à l'utilisateur sur la fonction" < ... >
            Read [AFC]CODINT=[ARP]FNC
            Call PAR_SUI(func AGENADO.MST(187,142)+"&nbsp;"+[ARP]FNC+"&nbsp;(<a href="+'"../FCT/'+[ARP]FNC+'.htm">'
&           +func AGENADO.RDT([AFC]NOM)+"</a>).") From AGENLIBA
            Call PAR_FIN From AGENLIBA
        Endif
        If [ARP]PRTNAT>1
            # "Cet état ne peut être imprimé que sur une imprimante de type..."
            Call PAR_PAR(func AGENADO.MST(71,142)-"<i>"+func AGENADO.MST([ARP]PRTNAT,22)+"</i>.") From AGENLIBA
        Endif
    Endif
  Endif
Return

# Inclusion du paragraphe décrivant les paramètres d'un sous-programme
$INCL_ASUCRI
  # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs "ASU"
  Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
  I = instr(1,[ADO]COD,[L]WTIRET)
  If find([ADO]TYP, [L]DOC_CLE_MULT) & I
    Read [ASU]ASU0=left$([ADO]COD,I-1);right$([ADO]COD,I+1)
  Else
    Read [ASU]ASU0=[ADO]COD
  Endif
  If fstat=0
    If [ADO]TIT=""
        Call ENT_PAR("CRI",0,func AGENADO.MST(7,42),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Paramètres"
    Endif

    Call WRPARASU(II,JJ) From AGENADOF

    # On regarde s'il y a bien des paramètres
    If JJ=0
        Call PAR_PAR(func AGENADO.MST(162,142)+".") From AGENLIBA : # "Ce sous-programme n'a pas de critères d'appel"
    Endif

    # On regarde s'il y a des choses à ajouter
    If [ASU]FONCTION=2 or [ASU]WEBS=2
        Call ENT_PAR("",0,func AGENADO.MST(177,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Remarques"
        If [ASU]FONCTION=2
            # "Ce sous-programme est appelé comme une fonction par la syntaxe Func"
            Call PAR_PAR(func AGENADO.MST(121,142)+".") From AGENLIBA
        Endif
        If [ASU]WEBS=2
            # "Ce sous-programme est publiable comme Web service"
            Call PAR_PAR(func AGENADO.MST(122,142)+".") From AGENLIBA
        Endif
    Endif
  Endif
Return

# Inclusion du paragraphe décrivant les valeurs par défaut du dossier de référence
$INCL_REC

# Si un texte existe, on ne fait rien de plus
  Gosub LEC_ADO From AGENDOCA
  If TEXBASE=0
    Return
  Endif

# Sinon, on recherche d'abord s'il existe une valeur pour le dossier courant, puis dans le dossier superviseur
  Read [ADE]ADE0=nomap;[ADO]COD
  If fstat<>0
    Read [ADE]ADE0=DOSSUP;[ADO]COD
    If fstat<>0
        Return
    Endif
  Endif
  Call PAR_PAR(func AGENADO.MST(82,142)-num$([ADE]NBR)+".") From AGENLIBA : # "La valeur proposée par défaut pour ce paramètre est"
Return

# Inclusion du paragraphe décrivant le contexte déclencheur de statistiques
$INCL_PS1CT
  Read [PS1]PS10=[ADO]COD
  If fstat=0
    If [ADO]TIT=""
        Call ENT_PAR("CTX",0,func AGENADO.MST(196,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Tables et variables en ligne"
    Endif

    # La liste des tables
    Read [ATB]CODFIC=[PS1]RLGTBL
    # "La table principale déclenchante est la table..." . "Les tables suivantes sont également en ligne"
    Call PAR_PAR(func AGENADO.MST(194,142)-'<a href="../MCD/'+[PS1]RLGTBL+'.htm">'
&        +[PS1]RLGTBL+'</a>&nbsp;'+'['+[ATB]ABRFIC+'].&nbsp;'
&        +string$([PS1]NBRTBL>0,func AGENADO.MST(195,142)+" :")) From AGENLIBA
    If [PS1]NBRTBL>0
        Call WRTABLE([PS1]TBL,[PS1]NBRTBL) From AGENADOF
    Endif

    # La liste des variables
    If [PS1]NBRVAR>0
        For II=1 To [PS1]NBRVAR
            VALEURS(II)=func RDX("PARSTA1","VARINTIT",num$(II-1),[PS1]VARNAM(II-1))
        Next II
        # "Les variables suivantes sont utilisables dans les statistiques basées sur cet événement"
        Call PAR_PAR(func AGENADO.MST(197,142)+" :") From AGENLIBA
        # VARDES à traduire !!
        Call WRTAB2(func AGENADO.RDM("PS12","VARNAM"),func AGENADO.RDM("PS12","VARDES"),30,70,[PS1]VARNAM,VALEURS,[PS1]NBRVAR) From AGENADOF
    Endif

    II=min(1+([PS1]CPYFLD<>"")+2*([PS1]FCYFLD<>""),3)
    # "Les statistiques basées sur cet événement peuvent être définies au niveau" ...
    # "(ou aux niveaux supérieurs)"
    Call PAR_PAR(func AGENADO.MST(198,142)+'&nbsp;<i>'+func AGENADO.MST(II,987)+'</i>'-string$(II>1,func AGENADO.MST(199,142))+".") From AGENLIBA
  Endif
Return

# Inclusion du paragraphe décrivant le contexte déclencheur de Workflow
$INCL_AWACT
  Read [AWA]AWA0=[ADO]COD
  If fstat=0
    If [ADO]TIT=""
        Call ENT_PAR("CTX",0,func AGENADO.MST(153,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Contexte et mode de fonctionnement"
    Endif

    KK=1 : # Compteur des tables trouvées
    CODINS(KK)="AUTILIS [AUS]"
    KK+=1

    # La caractérisation de l'événement déclencheur
    Case [AWA]TYPEVT
    When 1 : # Divers
        # "Cette règle Workflow se déclenche sur l'événement divers"
        # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
        Call PAR_PAR(func AGENADO.MST(215,142)-'"'+func AGENLIBA.RECH_DESIGNATION('ADI', '908', [AWA]CODEVT)+'".') From AGENLIBA
    When 2 :
        TEXTES=func AGENADO.MST(216,142) : # "Cette règle Workflow se déclenche en gestion d'objet"
        If len([AWA]OPERATION)<>0
            Call PAR_PAR(TEXTES+","-func AGENADO.MST(217,142)-":") From AGENLIBA : # ", uniquement sur les opérations suivantes"
        Else
            Call PAR_PAR(TEXTES+".") From AGENLIBA
        Endif
        Call OWRK(OWRKF,[AWA]CODEVT,II) From AGENDOCA
        For JJ=1 To len([AWA]OPERATION)
            For KK=1 To II
                If left$(OWRKF(KK),1)=mid$([AWA]OPERATION,JJ,1)
                    Gosub BULLET
                    Wrseq right$(OWRKF(KK),2)+"</p>" Using [DOC]
                Endif
            Next KK
        Next JJ
    When 3 : # Entrée fonction
        TEXTES=func AGENADO.MST(218,142) : # "Cette règle Workflow se déclenche sur l'entrée dans"
        If [AWA]CODEVT<>""
            Read [AFC]CODINT=[AWA]CODEVT
            If fstat=0
                # "la fonction"
                Call PAR_PAR(TEXTES-func AGENADO.MST(219,142)-'<a href="../FCT/'+[AWA]CODEVT+'.htm">'
&                        +[AWA]CODEVT+'</a> ('+func AGENADO.RDT([AFC]NOM)+').') From AGENLIBA
            Endif
        Else
            Call PAR_PAR(TEXTES-func AGENADO.MST(220,142)+".") From AGENLIBA : # "toute fonction"
        Endif
    When 4 : # Edition
        TEXTES=func AGENADO.MST(221,142) : # "Cette règle Workflow se déclenche sur l'édition de"
        Read [ARP]ARP0=[AWA]CODEVT
        If fstat=0
            Call PAR_PAR(TEXTES-'<a href="../OBJ/ARP_'+[AWA]CODEVT+'.htm">'+[AWA]CODEVT+'</a> ('
&                        +func AGENADO.RDT([ARP]RPTDES)+')') From AGENLIBA
        Else
            Call PAR_PAR(TEXTES-func AGENADO.MST(222,142)+".") From AGENLIBA : # "tout état"
        Endif
    When 5,6 : # Fin et arrêt de tâche batch
        If [AWA]TYPEVT=6
            TEXTES=func AGENADO.MST(223,142) : # "Cette règle Workflow se déclenche sur la fin de"
        Else
            TEXTES=func AGENADO.MST(224,142) : # "Cette règle Workflow se déclenche sur l'arrêt de"
        Endif
        If [AWA]CODEVT<>''
            Read [ABT]CODTAC=[AWA]CODEVT
            If fstat=0
                # "la tâche batch"
                Call PAR_PAR(TEXTES-func AGENADO.MST(225,142)-[AWA]CODEVT-'('+func AGENADO.RDT([ABT]DES)+').') From AGENLIBA
            Endif
        Else
            Call PAR_PAR(TEXTES-func AGENADO.MST(226,142)+".") From AGENLIBA : # "toute tâche batch"
        Endif
    When 7 : # Gestion des temps, voir avec la paye
    When 8 : # Import/Export
        If pat([AWA]OPERATION,"*I*")
            If pat([AWA]OPERATION,"*E*")
                # "Cette règle Workflow se déclenche en gestion d'import et d'export"
                TEXTES=func AGENADO.MST(227,142)
            Else
                TEXTES=func AGENADO.MST(228,142) : # "Cette règle Workflow se déclenche en gestion d'import"
            Endif
        Else
            TEXTES=func AGENADO.MST(229,142) : # "Cette règle Workflow se déclenche en gestion d'export"
        Endif
        If pat([AWA]OPERATION,"*D*")
            If pat([AWA]OPERATION,"*F*")
                TEXTES+=","-func AGENADO.MST(230,142) : # "à la fois en début et en fin"
            Else
                TEXTES-="("+func AGENADO.MST(231,142)+")" : # "en début d'opération"
            Endif
        Else
            TEXTES-="("+func AGENADO.MST(232,142)+")" : # "en fin d'opération"
        Endif

        If [AWA]CODEVT<>""
            Read [AOE]AOE0=[AWA]CODEVT
            If fstat=0
                # "sur le modèle"
                # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                Call PAR_PAR(TEXTES+ ", "+func AGENADO.MST(233,142)-'<a href="../OBJ/AOE_'+[AWA]CODEVT+'">'
&                           +[AWA]CODEVT+"</a> ("-func AGENLIBA.RECH_DESIGNATION('AOE', [AOE]EXT, '')+").") From AGENLIBA
            Endif
        Else
            Call PAR_PAR(TEXTES+", "+func AGENADO.MST(234,142)+".") From AGENLIBA : # "sur tous les modèles"
        Endif
    When 9 : # Signature
        # "Cette règle workflow est de type signature. Elle est associé à l'événement"
        If [AWA]CODEVT<>""
            # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
            Call PAR_PAR(func AGENADO.MST(235,142)+"."-func AGENADO.MST(247,142)-[AWA]CODEVT
&                       -'('+func AGENLIBA.RECH_DESIGNATION('AWA', [AWA]CODE, '')+').') From AGENLIBA
        Else
            Call PAR_PAR(func AGENADO.MST(235,142)+"."-func AGENADO.MST(248,142)+".") From AGENLIBA
        Endif
        II=0
        If [AWA]CODEVT=""
            For [AWF]
                If find ([AWA]CODEVT,[AWF]OPESIG) & [AWA]CODE<>[AWF]CODE
                    II+=1
                    If II=1
                        # "Les règles Workflow susceptibles de déclencher cet événement en suivi sont"
                        Call PAR_PAR(func AGENADO.MST(236,142)-":") From AGENLIBA
                    Endif
                    Gosub BULLET
                    Read [ADO2]ADO1=[ADO]LAN;"AWA";[AWF]CODE;"TIT"
                    If fstat=0
                        # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                        Wrseq '<a href="../OBJ/AWA_'+[AWF]CODE+'.htm">'+[AWF]CODE+"</a>("
&                             +func AGENLIBA.RECH_DESIGNATION('AWA', [AWF]CODE, '')+")</p>" Using [DOC]
                    Else
                        Wrseq [AWF]CODE-"("+func AGENLIBA.RECH_DESIGNATION('AWA', [AWF]CODE, '')+")</p>" Using [DOC]
                    Endif
                Endif
            Next
        Endif
    When 10 : # Manuel
        # "Cette règle de workflow est de type manuel (le workflow est lancé soit en direct, soit en batch)"
        Call PAR_PAR(func AGENADO.MST(237,142)+".") From AGENLIBA
    Endcase

# On compte les actions de type Début, Fin, ou Ligne
    JJ=0
    For [AWC] Where CODE=[AWA]CODE
        JJ+=find([AWC]DECACT,1,2,4)<>0
    Next

    II=([AWA]ENAMES=2)+([AWA]ENASUI=2)+([AWA]ENAACT=2 & JJ<>0)
    If II=1
        # "Elle déclenche"..."un message"..."un suivi"..."une action"..."des actions"
        Call PAR_PAR(func AGENADO.MST(240,142)-string$([AWA]ENAMES=2,func AGENADO.MST(241,142)+".")
&                   -string$([AWA]ENASUI=2,func AGENADO.MST(242,142)+".")
&                   -string$([AWA]ENAACT=2 & JJ<>0,func AGENADO.MST(243+(JJ>1),142)+".")) From AGENLIBA
    Elsif II>1
        Call PAR_PAR(func AGENADO.MST(240,142)-":") From AGENLIBA : # "Cette règle de workflow déclenche"
        If [AWA]ENAMES=2
            Gosub BULLET : Wrseq func AGENADO.MST(241,142)+"." Using [DOC] : # "un message"
        Endif
        If [AWA]ENASUI=2
            Gosub BULLET : Wrseq func AGENADO.MST(242,142)+"." Using [DOC] : # "un suivi"
        Endif
        If [AWA]ENAACT=2 & JJ<>0
            Gosub BULLET : Wrseq func AGENADO.MST(243+(JJ>1),142)+"." Using [DOC] : # "une/des action(s)"
        Endif
    Endif

    If [AWA]REGLE<>""
#       Read [AWR]AWR1(1)=[AWA]REGLE
#       If fstat=0

        # "La règle d'affectation" ... "est utilisée par la règle de workflow" ...
        # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
        Call PAR_PAR(func AGENADO.MST(238,142)-[AWA]REGLE-"("+func AGENLIBA.RECH_DESIGNATION('AWR', [AWA]REGLE, '')+')'
&                       -func AGENADO.MST(239,142)-[AWA]CODE+".") From AGENLIBA
#       Endif
    Endif

  Endif
Return

# Inclusion du paragraphe décrivant le contexte du point d'entrée
$INCL_ADCCT

# On recherche d'abord les tables et les informations par défaut dans la table des liens (avant le 1er APE)
  Raz II,KK,LL
  For [ADF]ADF0 Where TYP=[ADO]TYP and COD=[ADO]COD
    If [ADF]TYPLNK="APE"
        Break
    Elsif find([ADF]TYPLNK,"ATB","AT2")
        II+=1
        VALEURS(II)=[ADF]CLELNK
        VALNUM(II)=2*([ADF]TYPLNK="ATB")+1*([ADF]TYPLNK="AT2")
        II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Elsif [ADF]TYPLNK="TRS"
        LL=val([ADF]CLELNK) : # Transaction en cours (2=oui, 1=Non)
    Elsif [ADF]TYPLNK="TRA"
        KK=val([ADF]CLELNK) : # Trace ouverte (2=oui, 1=Non)
    Endif
  Next

# On recherche ensuite le paragraphe dans la table des liens, puis on explore la suite
  For [ADF]ADF0 Where TYP=[ADO]TYP and COD=[ADO]COD and TYPLNK="APE" and CLELNK=LAST_APE
    JJ=[ADF]NUM
  Next

# On parcourt les liens en gérant les liens Transaction, Trace et en s'arrêtant à l'APE suivant
  For [ADF]ADF0 Where TYP=[ADO]TYP and COD=[ADO]COD and NUM>JJ
    If find([ADF]TYPLNK,"ATB","AT2")
        II+=1
        VALEURS(II)=[ADF]CLELNK
        II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        VALNUM(find([ADF]CLELNK,VALEURS(1..II)))=2*([ADF]TYPLNK="ATB")+1*([ADF]TYPLNK="AT2")
    Elsif [ADF]TYPLNK="TRS"
        LL=val([ADF]CLELNK) : # Transaction en cours (2=oui, 1=Non)
    Elsif [ADF]TYPLNK="TRA"
        KK=val([ADF]CLELNK) : # Trace ouverte (2=oui, 1=Non)
    Elsif [ADF]TYPLNK="APE"
        Break
    Endif
  Next

  Read [ADC]ADC0=[ADO]COD

  If fstat=0
    If [ADO]TIT=""
        Call ENT_PAR("CTX",[ADO]STY,func AGENADO.MST(153,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA : # "Contexte et mode de fonctionnement"
    Endif
    If LL<>0 or KK<>0
        Call PAR_PAR(func AGENADO.MST(114,142)-":") From AGENLIBA : # "Dans le contexte du point d'entrée"
        Wrseq '            <ul>' Using [DOC]
        If LL<>0
            Wrseq '              <li>'; Using [DOC]
            Wrseq func AGENADO.MST((LL=2)*116+(LL<>2)*115,142) Using [DOC]: # " Il y a (ou pas) une transaction en cours"
            Wrseq '              </li>' Using [DOC]
        Endif
        If KK<>0
            Wrseq '              <li>'; Using [DOC]
            Wrseq func AGENADO.MST((KK=2)*117+(KK<>2)*118,142) Using [DOC] : # " Il y a (ou pas) une trace ouverte"
            Wrseq '              </li>' Using [DOC]
        Endif
        Wrseq '            </ul>' Using [DOC]
    Endif
    If II>=1
        Call PAR_PAR(func AGENADO.MST(120,142)-":") From AGENLIBA : # "Les tables suivantes sont en ligne"
        Call WRTBSIG(VALEURS,VALNUM,II) From AGENADOF
    Endif
  Endif
Return

# Inclusion du paragraphe décrivant le niveau et la variable globale associée
$INCL_LEV

  # Si le titre n'est pas imposé, on l'impose
  If [ADO]TIT=""
    Call ENT_PAR("CDE",0,func AGENADO.MST(160,142),INCLUT_TEXTE,BOT_PAR) From AGENLIBA
  Endif

  # Le niveau du paramètre est...
  Read [ADP]ADP1=[ADO]COD
  Call PAR_DEB(func AGENADO.MST(161,142)-"<i>"+func AGENADO.MST([ADP]NIVDEF,987)+". </i>") From AGENLIBA

  # Il appartient au chapitre ... et au groupe ...
  II=0
  Gosub ADP_ADP
  # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
  Call PAR_SUI(func AGENADO.MST(92,142)-"<i>"+[ADP]CHAPITRE-"("+func AGENLIBA.RECH_DESIGNATION('ADI', '901', [ADP]CHAPITRE)
&             +")</i>"-func AGENADO.MST(93,142)-"<i>"+[ADP]GRPPAR-"("+func AGENLIBA.RECH_DESIGNATION('ADI', '903', [ADP]GRPPAR)
&             +")</i>"+string$(II=0,".")+string$(II<>0,",")) From AGENLIBA
  If II>0
    Call PAR_SUI(func AGENADO.MST(108,142)-":") From AGENLIBA : # "dans lequel on trouve aussi les paramètres suivants :"
    Wrseq '        <ul>' Using [DOC]
    For JJ=1 To II
        Read [ADP2]ADP1=VALEURS(JJ)
        Wrseq '        <li><a href="../OBJ/ADP_'+[ADP]CHAPITRE+"_"+VALEURS(JJ)+'.htm">'; Using [DOC]
        Wrseq VALEURS(JJ)+'</a> ('+func AGENADO.RDT([ADP2]NAM)+")</li>" Using [DOC]
    Next JJ
    Wrseq '        </ul>' Using [DOC]
  Endif
  Call PAR_FIN From AGENLIBA

  # Si la variable est gérée par un objet, on le donne
  If [ADP]OBJET<>""
    Read [AOB]ABREV=[ADP]OBJET
    Read [AFC]CODINT="GES"+[AOB]ABREV
    If fstat=0
        Call PAR_PAR(func AGENADO.MST(95,142)-'<a href="../FCT/GES'+[AOB]ABREV+'.htm">'
&                   +func AGENADO.RDT([AFC]LIBMENU)+'</a>.') From AGENLIBA
    Endif
  Endif

  # On teste pour savoir s'il existe des jeux de valeurs
  II=0
  For [ADG] Where CHAPITRE=[ADP]CHAPITRE and GRPPAR=[ADP]GRPPAR and PARAM=[ADP]PARAM
    II+=1
    If II=1
        Call PAR_PAR(func AGENADO.MST(96,142)-":") From AGENLIBA
        Wrseq '        <ul>' Using [DOC]
    Endif
    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
    Wrseq '        <li>'+[ADG]GRPDEF-'('+func AGENLIBA.RECH_DESIGNATION('ADI', '912', [ADG]GRPDEF)+')</li>' Using [DOC]
  Next
  If II : Wrseq '        </ul>' Using [DOC] : Endif

  # Si la variable globale est trouvée, on la donne
  Read [AGB]AGB2(1)=[F:ADP]PARAM
  If !fstat
   Call PAR_PAR(func AGENADO.MST(163,142)-[AGB]CODVAR-func AGENADO.MST(164,142)+".") From AGENLIBA

  # Sinon, on ne met la phrase négative que si aucun texte n'est présent dans le CLOB
  # (car parfois il existe une variable qui n'est pas décrite dans le dictionnaire)
  # Dans ce cas, le texte est censé donner le nom de la variable
  Else
   Gosub LEC_ADO From AGENDOCA
   If TEXBASE=0
    Call PAR_PAR(func AGENADO.MST(165,142)+".") From AGENLIBA
   Endif
  Endif

Return

# Inclusion du paragraphe décrivant les fonctions rattachées à un menu
$INCL_APM
  If left$([ADO]COD,4)="ADP_"
    Goto INCL_ADPINT
  Endif

# Début de la liste des fonctions
  Wrseq '        <ul>' Using [DOC]

# Les menus particuliers intermédiaires sont codés sous la forme ???_numéro ou ADP_chapitre ou AWA_categ
# Le premier sera codé ???_0
  If pat([ADO]COD,"???_*")
    I_LEV=10 : I_SUBLEV=10
    Case left$([ADO]COD,3)
        When "ABF" : #VPO 04/09/08 48971 ajout ABF et ABM
                   If [L]BIDOC
                     Default File [ABF] : CLE_MEN="[ABF]CODABF"
                     TIT_MEN="[ABF]CODABF-'('+func AGENADO.RDT([ABF]INTIT)+')'"
                     I_SUBLEV=20 :  # pour forcer ecriture dans le menu
                     Gosub INCL_MENINT
                   Endif
        When "ABM" : #VPO 04/09/08 48971 ajout ABF et ABM
                   If [L]BIDOC
                     Default File [ABM] : CLE_MEN="[ABM]COD"
                     TIT_MEN="[ABM]COD-'('+func AGENADO.RDT([ABM]INTIT)+')'"
                     I_SUBLEV=20 :  # pour forcer ecriture dans le menu
                     Gosub INCL_MENINT
                   Endif
        When "ABO" : #VPO 14/01/08 41049,42137 doc ABO
                   If [L]BIDOC
                     Default File [ABO] : CLE_MEN="[ABO]COD"
                     TIT_MEN="[ABO]COD-'('+func AGENADO.RDT([ABO]DES)+')'"
                     I_SUBLEV=20 :  # pour forcer ecriture dans le menu
                     Gosub INCL_MENINT
                   Endif
        When "ACT" : Default File [ACT] : CLE_MEN="[ACT]ACTION"
                     TIT_MEN="[ACT]ACTION-'('+func AGENADO.RDT([ACT]INTITA)+')'"
                     I_SUBLEV=20 : Gosub INCL_MENINT
        When "ACV" : Default File [ACV] : CLE_MEN="[ACV]CODACT"
                     TIT_MEN="[ACV]CODACT-'('+func AGENADO.RDT([ACV]LIBACT)+')'"
                     Gosub INCL_MENINT
        #VPO 30/06/08 48129 : ajout liste des tables diverses
        When "ADI" : Default File [ADV] : Gosub INCL_ADIMENINT
        When "ADM" : Default File [ADM] : CLE_MEN="[ADM]COD"
                     TIT_MEN="[ADM]COD-'('+func AGENADO.RDT([ADM]DES)+')'"
                     Gosub INCL_MENINT
        When "ARP" : Default File [ARP] : CLE_MEN="[ARP]RPTCOD"
                     TIT_MEN="[ARP]RPTCOD-'('+func AGENADO.RDT([ARP]RPTDES)+')'"
                     Gosub INCL_MENINT
        When "AOE" : Default File [AOE] : CLE_MEN="[AOE]EXT"
                     # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                     TIT_MEN="[AOE]EXT-'('+func AGENLIBA.RECH_DESIGNATION('AOE', [AOE]EXT, '')+')'"
                     Gosub INCL_MENINT
        When "PS1" : Default File [PS1] : CLE_MEN="[PS1]COD"
                     # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                     TIT_MEN="[PS1]COD-'('+func AGENLIBA.RECH_DESIGNATION('PS1', [PS1]COD, '')+')'"
                     Gosub INCL_MENINT
        When "AWA" : Default File [AWA] : CLE_MEN="[AWA]CODE"
                     # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                     TIT_MEN="[AWA]CODE-'('+func AGENLIBA.RECH_DESIGNATION('AWA', [AWA]CODE, '')+')'"
                     Gosub INCL_AWAMENINT
        When "CDA" : Default File [CDA] : CLE_MEN="[CDA]COD" : TIT_MEN="[CDA]COD-'('+[CDA]DESSHO+')'"
                     Gosub INCL_CPTMENINT
        When "CDE" : #JPGA 13/04/2010 BUG-63897 : Alimentation de la variable CDEDOC pour savoir si les sections par défaut sont présentes
                   If [L]CDEDOC
                     Default File [CDE] : # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
                     Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
                     If find(left$([ADO]COD,3), [L]DOC_CLE_MULT)
                        CLE_MEN="[CDE]COD+[L]WTIRET+[CDE]CPY"
                        # JPGA 10/09/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                        # JPGA 06/10/2009 Bug-57459 : ATTENTION pour la PAYE V6 : la clé est resté simple pour les CDE : code section
                        TIT_MEN="[CDE]COD-'('+func AGENLIBA.RECH_DESIGNATION('CDE', [CDE]COD, '')"
&                              +"-string$([CDE]CPY='', func AGENADO.MST(145,139))"
&                              +"-string$([CDE]CPY<>'',func AGENADO.RDM('CDE0','CPY')-[CDE]CPY)+')'"
                     Else
                        CLE_MEN="[CDE]COD"
                        TIT_MEN="[CDE]COD-'('+func AGENLIBA.RECH_DESIGNATION('CDE', [CDE]COD, '')+')'"
                     Endif
                     Gosub INCL_MENINT
                   Endif
        When "GAU" : #JPGA 10/08/2010 BUG-66637 : Alimentation de la variable GAUDOC pour savoir si les Pièces automatiques sont présentes
                   If [L]GAUDOC
                     Default File [GAU] : CLE_MEN="[GAU]COD" : TIT_MEN="[GAU]COD-'('+[GAU]DESSHO+')'"
                     Gosub INCL_MENINT
                   Endif
        When "ATB" :     #VPO 19/06/08 39766 ajout ATD: différences de tables
                     #Default File [ATB] : CLE_MEN="[ATB]CODFIC"
                     #TIT_MEN="[ATB]CODFIC-'('+func AGENADO.RDT([ATB]INTITFIC)+')'"
                     #I_SUBLEV=0 : Gosub INCL_MENINT
                     Default File [ATB] : Gosub INCL_ATBMENINT
        When "AML" : Default File [AML] : CLE_MEN="func AGENLIBA.FORMAT_AML([AML]MENLOC)"
                     TIT_MEN="func AGENADO.TML([AML]MENLOC)-'('+num$([AML]MENLOC)+')'"
                     I_SUBLEV=0 : Gosub INCL_MENINT
#       When "ADC" : Default File [ADC] : CLE_MEN="[ADC]CODTRT"
#                    TIT_MEN="[ADC]CODTRT"
#                    I_SUBLEV=0 : Gosub INCL_MENINT
        When "ADC" : Default File [ADC] : CLE_MEN="[ADC]CODTRT"
                     #TIT_MEN="func AGENDOCA.TRTINT([ADC]CODTRT)" : # Intitulé non traduisible
                     TIT_MEN="[AD1]TIT" : # Intitulé non traduisible
                     I_SUBLEV=0 : Gosub INCL_MENINT
        When "ASU" : Default File [ASU] : # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
                     Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
                     If find(left$([ADO]COD,3), [L]DOC_CLE_MULT)
                        CLE_MEN="[ASU]PRG+[L]WTIRET+[ASU]SUBPRG" : # Bug signalé (E Latour 01/09/06)
                     Else
                        CLE_MEN="[ASU]PRG"
                     Endif
                     # TIT_MEN=CLE_MEN+"-'('+[ASU]DES+')'"
                     TIT_MEN="[ASU]SUBPRG-'('+func AGENADO.RDT([ASU]INTIT)+')'"
                     I_SUBLEV=20 : Gosub INCL_MENINT
        When "AGB" : Default File [AGB] : CLE_MEN="[AGB]CODVAR" : TIT_MEN=CLE_MEN+"-'('+func AGENADO.RDT([AGB]INTIT)+')'"
                     I_SUBLEV=20 : Gosub INCL_MENINT
        When "ATY" : Default File [ATY] : CLE_MEN="[ATY]CODTYP" : TIT_MEN=CLE_MEN+"-'('+func AGENADO.RDT([ATY]INTITTYP)+')'"
                      I_SUBLEV=20 : Gosub INCL_MENINT
        When "AHI" : Default File [AHI] : CLE_MEN="[AHI]COD" : TIT_MEN="[AHI]COD-'('+func AGENADO.RDT([AHI]DES)+')'"
                     Gosub INCL_MENINT
    Endcase

# Si c'est un menu intermédiaire normal, parcours de l'arborescence des menus
  Else
    For [AF1]MENU Where MENU=[ADO]COD
        DOC_TROUVE= 0 : Call DOCUMENTATION_TROUVE("ADO1",[ADO]LAN,mid$("AFCAPM",3*[AF1]TYPTRAIT-2,3),[AF1]CODINT,0,0,"TIT", DOC_TROUVE)

        If DOC_TROUVE
          # JPGA 19/03/2010 BUG-54804 : si une doc n'est pas validées : on ne crée pas le menu si la case a été cochée.
          # JPGA 20/03/2010 BUG-63408 : Si le paragraphe TIT est en FAL : Elle n'a pas été générée, on ne crée pas le lien
          If ([AD1]CODACT<>"FAL") & func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
            Wrseq '        <li><a href="../FCT/'+string$(fstat=0,[AF1]CODINT)
&                +'.htm">'+func AGENADO.RDT([AF1]LIBMENU)+'</a></li>' Using [DOC]
          Endif
        Else
            Wrseq '        <li><a href="../FCT/'+string$(fstat<>0,"ERR_DOC")
&                +'.htm">'+func AGENADO.RDT([AF1]LIBMENU)+'</a></li>' Using [DOC]
        Endif
    Next
  Endif

$INCL_LIENS

# S'il y a du texte, celui-ci correspond à des liens supplémentaires
  Gosub LEC_ADO From AGENDOCA

# Recherche des liens
  Gosub RECHLNK

  Filter [AD1]

# Parcours de l'arborescence des menus
  For KK=1 To II-1
    JJ=instr(1,VALEURS(KK),"/")
    LL=instr(1,VALEURS(KK),"#")
    If LL
        CHAINE=right$(VALEURS(KK),LL)
        VALEURS(KK)=left$(VALEURS(KK),LL-1)
    Else
        CHAINE=""
    Endif
    If JJ=0
        For [AD1] Where [AD1]LAN=[ADO]LAN & [AD1]COD=VALEURS(KK) and [AD1]PAR="TIT" and [AD1]TYP="AFC"
            CH1=[AD1]TYP : CH2=[AD1]COD : CH3=""
            If [AD1]TYP="ADP" : Read [ADP]ADP1=[AD1]COD : CH3="ADP_"+[ADP]CHAPITRE : Endif
            Gosub REP_NOM_FIC
            Wrseq '        <li><a href="../'+CH4+'/'+CH5+'.htm'+CHAINE+'">'+[AD1]TIT+'</a></li>' Using [DOC]
            Break
        Next
    Else
        # Errbox "LAN="+[ADO]LAN-"COD="+right$(VALEURS(KK),JJ+1)-"TYP="+left$(VALEURS(KK),JJ-1)
        CH5=right$(VALEURS(KK),JJ+1) : CH6=left$(VALEURS(KK),JJ-1)
#        For [AD1] Where [AD1]LAN=[ADO]LAN & [AD1]COD=right$(VALEURS(KK),JJ+1) and [AD1]TYP=left$(VALEURS(KK),JJ-1)
        For [AD1] Where [AD1]LAN=[ADO]LAN & [AD1]COD=CH5 and [AD1]TYP=CH6
&                   and [AD1]PAR="TIT"
            CH1=[AD1]TYP : CH2=[AD1]COD : CH3=""
            If [AD1]TYP="ADP" : Read [ADP]ADP1=[AD1]COD : CH3="ADP_"+[ADP]CHAPITRE : Endif
            Gosub REP_NOM_FIC
            Wrseq '        <li><a href="../'+CH4+'/'+CH5+'.htm'+CHAINE+'">'+[AD1]TIT+'</a></li>' Using [DOC]
            Break
        Next
    Endif

  Next KK

  Wrseq '        </ul>' Using [DOC]

Return

# Inclusion d'un paragraphe décrivant des liens
$INCL_LNK

# Début de la liste des fonctions
  Wrseq '        <ul>' Using [DOC]

Goto INCL_LIENS

# Recherche des liens (1 lien=1 ligne dans TEXTES : renvoie II valeurs)
$RECHLNK
  II=1
  JJ=1
  While TEXTES(JJ)<>""
    CHAINE=ctrans(vireblc(TEXTES(JJ),0),chr$(13)+chr$(10),'')
    JJ+=1
    While CHAINE<>""
        If pat(tolower(CHAINE),"*<p>*")
            CHAINE=right$(CHAINE,3+instr(1,tolower(CHAINE),"<p>"))
            KK=instr(1,tolower(CHAINE),"</p>")
            If KK
                VALEURS(II)=vireblc(left$(CHAINE,KK-1),2)
                II+=1
                CHAINE=vireblc(right$(CHAINE,KK+4),0)
            Else
                Break 2*(TEXTES(JJ)="") : # Sortie de boucle
                CHAINE+=ctrans(vireblc(TEXTES(JJ),0),chr$(13)+chr$(10),'')
                JJ+=1
                KK=instr(1,tolower(CHAINE),"</p>")
                If KK
                    VALEURS(II)=vireblc(left$(CHAINE,KK-1),2)
                    II+=1
                    CHAINE=vireblc(right$(CHAINE,KK+4),0)
                Endif
            Endif
        Else
            Break 2*(TEXTES(JJ)="") : # Sortie de boucle
            CHAINE+=ctrans(vireblc(TEXTES(JJ),0),chr$(13)+chr$(10),'')
            JJ+=1
        Endif
    Wend
  Wend
Return

# Inclusion des menus intermédiaires compta (un seul niveau)
$INCL_CPTMENINT
  For [F]
      DOC_TROUVE= 0 : Call DOCUMENTATION_TROUVE("ADO0",COD_LAN,left$([ADO]COD,3), evalue(CLE_MEN),10,10,"", DOC_TROUVE)

      If DOC_TROUVE
          # JPGA 19/03/2010 BUG-54804 : si une doc n'est pas validées : on ne crée pas le menu si la case a été cochée.
          If func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
            Wrseq '        <li><a href="../OBJ/'+left$([ADO]COD,3)+"_"+[AD1]COD+'.htm">'+evalue(TIT_MEN)
&                +'</a></li>' Using [DOC]
          Endif
      Endif
  Next
Return

# Inclusion des menus intermédiaires (fonction générique pour les tables à menu intermédiaire par module)
# Le test d'existence d'une doc valide s'est un peu compliqué :
# - le titre est cherché en (10,10)
# - la doc est incluse s'il existe un texte en (10,20) si I_SUBLEV=2 (concerne ASU, AGB, et ADC)
# - si I_SUBLEV=0, on inclut toujours même si pas de texte dès lors que le paragraphe existe (ATB, AML)
$INCL_MENINT
  II=val(right$([ADO]COD,5))

  If left$([ADO]COD,3)="ATB"
    CH1="MCD/"
  Elsif left$([ADO]COD,3)="ATY"
    CH1="MCD/"+string$(II<>0,"ATY_")
  Elsif left$([ADO]COD,3)="AML"
    CH1="MCD/"+string$(II<>0,"MEN")
  Else
    #VPO 04/09/08 48971 ajout ABF et ABM
    #CH1="OBJ/"+string$(II<>0,left$([ADO]COD,3)+"_")
    #CH1="OBJ/"+string$(II<>0 | left$([ADO]COD,3)="ABF",left$([ADO]COD,3)+"_")
    # TCH 05/06/2014 100639 SI029 modules sur tables de fait
    CH1="OBJ/"+string$(II<>0,left$([ADO]COD,3)+"_")
  Endif
# Les menu XXX_numéro sont créés en fonction des docs présentes et remplies
  #VPO 04/09/08 48971 ajout ABF et ABM
  #If II | left$([ADO]COD,3)="ABF"
  # TCH 05/06/2014 100639 SI029 modules sur tables de fait
  If II
    If dim([F]FLGPUB)>0
        CH2="MODULE=II and FLGPUB>1"
    Else
        CH2="MODULE=II"
    Endif
    CH5=""
    If left$([ADO]COD,3)="ADC"
      #JPGA 12/03/2013 BUG-88559: En clientèle, il faut pouvoir générer les APM sur ADC dont le nom du traitement SPE est > 'X' sinon le menu SPE ne peut pas être généré
      If GADONIX=2
        CH2-="and CODTRT<'X'"
      Endif
    Endif
    For [F] Where evalue(CH2)
        JJ=0
        DOC_TROUVE= 0 : Call DOCUMENTATION_TROUVE("ADO0",COD_LAN,left$([ADO]COD,3), evalue(CLE_MEN),10,10,"", DOC_TROUVE)

        If DOC_TROUVE
          # VPO 04/09/08 48881 : on fait menu sur doc validées uniquement
          If func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
            CH3=evalue(TIT_MEN)
            # JPGA 19/08/2009 Bug-52238 : Procedure de recherche pour savoir si on est en présence de clé multiples pour les docs
            Gosub DOC_INIT_CLE_MULTIPLE From AGENLIBA
            If find(left$([ADO]COD,3), [L]DOC_CLE_MULT)
                CH4=vireblc(ctrans(evalue(CLE_MEN),[L]WTIRET," "),3)
            Else
                CH4=""
            Endif

            #JPGA 20/12/2010 BUG-70099:Recherche pour savoir si la langue COD_LAN fait bien partie des langues pour lesquelles ont recherche les menus ENG
            Gosub RECHERCHE_LAN_DANS_ENG

            If I_SUBLEV<>10
                #VPO 16/09/08 49235
                Read [AD1]ADO0=COD_LAN;left$([ADO]COD,3);evalue(CLE_MEN);10;I_SUBLEV
                #JPGA 09/12/2010 BUG-69811: En GER : pas de génération HTML des sous-menus car le contenu des CLOBS est VIDE : doc non validée ni traduite
                #JPGA 09/12/2010 BUG-69811: Comme la génération Auto a créé le squelette, il est nécessaire de le prendre en comtpe pour aller voir le ENG
                If [L]IF_MENU_ENG
                   If fstat
                      Read [AD1]ADO0="ENG";left$([ADO]COD,3);evalue(CLE_MEN);10;I_SUBLEV
                   Else
                      Gosub LEC_AD1 From AGENDOCA
                      If TEXBASE=0
                         Read [AD1]ADO0="ENG";left$([ADO]COD,3);evalue(CLE_MEN);10;I_SUBLEV
                      Endif
                   Endif
                Endif
            Endif
            Gosub LEC_AD1 From AGENDOCA
            If (TEXBASE<>0) or (I_SUBLEV=0) or left$([ADO]COD,3)="ATY"
                If CH4<>"" and CH5<>CH4
                    If CH5<>""
                        Wrseq '           </ul>' Using [DOC]
                    Endif
                    Wrseq '        <li>'+func AGENADO.RDM('ADC1','CODTRT')-CH4-":" Using [DOC]
                    Wrseq '           <ul>' Using [DOC]
                Endif
                #VPO 09/01/08 43109
                If left$([ADO]COD,3)="ADC"
                    Wrseq '           <li>'+CH3+'</li>' Using [DOC]
                    Wrseq '               <table border="0" width="803" style="margin-left:30pt">' Using [DOC]
                    #VPO 16/09/08 49235
                    #For [AD1]ADO0 Where LAN=COD_LAN & TYP=left$([ADO]COD,3) & COD=evalue(CLE_MEN) & PAR="APE"
                    #JPGA 20/03/2010 BUG-56199 : Les menus sur les points d'entrée ne génèrent que le premier point d'entrée. Prendre la clé sur 2 : COD + LEV
                    For [ADO2]ADO2(2) Where (LAN=COD_LAN | evalue([L]DOC_MENU_ENG)) & TYP=left$([ADO]COD,3) & COD=evalue(CLE_MEN) & PAR="APE"
                        DOC_TROUVE= 0 : Call DOCUMENTATION_TROUVE("ADO0",COD_LAN,[ADO2]TYP,[ADO2]COD,[ADO2]LEV,[ADO2]SUBLEV,"", DOC_TROUVE)

                        If DOC_TROUVE
                           If func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
                          Wrseq '                   <tr><td><a href="../'+CH1+[AD1]COD+'.htm#APE_'
&                           +num$([AD1]LEV)+'_'+num$([AD1]SUBLEV)+'">'
&                           +[AD1]TIT+'</a></td></tr>' Using [DOC]
                           Endif
                        Endif
                    Next
                    Wrseq '               </table>' Using [DOC]
                Else
                    Wrseq '           <li><a href="../'+CH1+[AD1]COD+'.htm">'
&                     +evalue(TIT_MEN)+'</a></li>' Using [DOC]
                Endif
                CH5=CH4
            Endif
          Endif
        Endif
    Next
    If CH5<>""
        Wrseq '           </ul>' Using [DOC]
    Endif


# Le menu XXX_0 regroupe tous les menus XXX_numéro
  Else
    #VPO 14/10/08 49749: ajout lien depuis DI/BI_0 : les PAM peuvent avoir +sieurs paragraphes
    ##For [AD1] Where LAN=COD_LAN & TYP="APM" & pat(COD,left$([ADO]COD,3)+"_*") & COD<>left$([ADO]COD,3)+"_0"
    For [AD1] Where LAN=COD_LAN & TYP="APM" & pat(COD,left$([ADO]COD,3)+"_*") & COD<>left$([ADO]COD,3)+"_0" & LEV=10 & SUBLEV=10
        Wrseq '        <li><a href="../'+CH1+[AD1]COD+'.htm">'
&             +[AD1]TIT+'</a></li>' Using [DOC]
    Next
  Endif
Return


# Menu liste des tables diverses
$INCL_ADIMENINT
# JPGA 21/01/2011 NUG-70953 : Plus de mémoire disponible en génération HTML tous types suite à l'extension de la zone COLONNE(Bug-70516)
Filter [ADV]
Local Integer MAX_COLONNE : MAX_COLONNE=rowcount([ADV])+10
# Local Char TITRECOL(30)(1..9), POURCENTCOL(5)(1..9), COLONNE(250)(1..9,1..1500)
Local Char TITRECOL(30)(1..11), POURCENTCOL(5)(1..11), COLONNE(250)(1..11,1..[L]MAX_COLONNE) # Exigence 53267
Local Char COL_ALP(10) : COL_ALP="#003fbf"  # Bleu foncé
Local Char COL_NUM(10) : COL_NUM="#bfbf3f"  # Vert clair
Local Integer NBCOL, II, JJ

  II=val(right$([ADO]COD,5))

  If left$([ADO]COD,3)<>"ADI" : Return : Endif
  CH1="MCD/"

# Les menu XXX_numéro sont créés en fonction des docs présentes et remplies
  If II : Return : Endif

  NBCOL=0
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADI1","NUMTAB") : POURCENTCOL(NBCOL)="15" : #Table
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","LNGDES") : POURCENTCOL(NBCOL)="" : # #intitule
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","MODULE") : POURCENTCOL(NBCOL)=""
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","CODACT") : POURCENTCOL(NBCOL)="10"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","DEPNUM") : POURCENTCOL(NBCOL)="10"
  # JPGA 07/01/2010 BUG-70516 : A partir de la V7 : ALPDES1/ALPDES2/NUMDES1/NUMDES2/CODTYP* ont été remplacées par un tableau de NBCOL éléments
  # Exigence 53267
  If dim([F]COLALPTYP)>0 and dim([F]COLNUMTYP)>0
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","COLALPDES")-func MST(46,9009) : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","COLALPTYP")                   : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","COLALPSUP")                   : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","COLNUMDES")-func MST(46,9009) : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","COLNUMTYP")                   : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","COLNUMSUP")                   : POURCENTCOL(NBCOL)=""
  Else
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","ALPDES1") : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","ALPDES2") : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","NUMDES1") : POURCENTCOL(NBCOL)=""
     NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ADV1","NUMDES2") : POURCENTCOL(NBCOL)=""
  Endif
  # End Exigence 53267

  JJ=1
  For [F:ADV]
    COLONNE(1,JJ)=[F:ADV]NUMCAR
    COLONNE(2,JJ)=func RDX("ATABTAB","LNGDES",[F:ADV]NUMCAR,"")+"&nbsp;"
    COLONNE(3,JJ)=func AGENADO.MST([F]MODULE,14)
    COLONNE(4,JJ)=string$([F]CODACT="","&nbsp;")+[F]CODACT
    COLONNE(5,JJ)=string$([F]DEPNUM=0,"&nbsp;")+string$([F]DEPNUM>0,num$([F]DEPNUM))
    # JPGA 07/01/2010 BUG-70516 : A partir de la V7 : ALPDES1/ALPDES2/NUMDES1/NUMDES2/CODTYP* ont été remplacées par 2 tableaux
    # Exigence 53267
    If dim([F]COLALPTYP)>0 and dim([F]COLNUMTYP)>0
     Local Integer T_COLUMN_FOUND
     T_COLUMN_FOUND = 0
     For KK=1 To dim([F:ADV]COLALPTYP)    # Boucle sur le nombre de colonnes selon la table ADI
      If func RDX("ATABTAB","COLALPDES",[F:ADV]NUMCAR,num$(KK-1))<>""
       If COLONNE(6,JJ)<>""  :  COLONNE(6,JJ)+='<br>'   :  Endif
       If COLONNE(7,JJ)<>""  :  COLONNE(7,JJ)+='<br>'   :  Endif
       If COLONNE(8,JJ)<>""  :  COLONNE(8,JJ)+='<br>'   :  Endif
       COLONNE(6,JJ)+=func RDX("ATABTAB","COLALPDES",[F:ADV]NUMCAR,num$(KK-1))+'&nbsp;'
       COLONNE(7,JJ)+=[F]COLALPTYP(KK-1)+'&nbsp;'
       COLONNE(8,JJ)+=[F]COLALPSUP(KK-1)+'&nbsp;'
       T_COLUMN_FOUND = 1
      Endif
     Next KK
     If T_COLUMN_FOUND = 0
      COLONNE(6,JJ)='&nbsp;'  :  COLONNE(7,JJ)='&nbsp;'  :  COLONNE(8,JJ)='&nbsp;'
     Endif

     T_COLUMN_FOUND = 0
     For KK=1 To dim([F:ADV]COLNUMTYP)    # Boucle sur le nombre de colonnes selon la table ADI
      If func RDX("ATABTAB","COLNUMDES",[F:ADV]NUMCAR,num$(KK-1))<>""
       If COLONNE(9,JJ)<>""   :  COLONNE(9,JJ)+='<br>'    :  Endif
       If COLONNE(10,JJ)<>""  :  COLONNE(10,JJ)+='<br>'   :  Endif
       If COLONNE(11,JJ)<>""  :  COLONNE(11,JJ)+='<br>'   :  Endif
       COLONNE(9,JJ)+=func RDX("ATABTAB","COLNUMDES",[F:ADV]NUMCAR,num$(KK-1))+'&nbsp;'
       COLONNE(10,JJ)+=[F]COLNUMTYP(KK-1)+'&nbsp;'
       COLONNE(11,JJ)+=[F]COLNUMSUP(KK-1)+'&nbsp;'
       T_COLUMN_FOUND = 1
      Endif
     Next KK
     If T_COLUMN_FOUND = 0
      COLONNE(9,JJ)='&nbsp;'  :  COLONNE(10,JJ)='&nbsp;'  :  COLONNE(11,JJ)='&nbsp;'
     Endif

    Else
       COLONNE(6,JJ)=func RDX("ATABTAB","ALPDES1",[F:ADV]NUMCAR,"")+"&nbsp;"
       COLONNE(7,JJ)=func RDX("ATABTAB","ALPDES2",[F:ADV]NUMCAR,"")+"&nbsp;"
       COLONNE(8,JJ)=func RDX("ATABTAB","NUMDES1",[F:ADV]NUMCAR,"")+"&nbsp;"
       COLONNE(9,JJ)=func RDX("ATABTAB","NUMDES2",[F:ADV]NUMCAR,"")+"&nbsp;"
    Endif
    #End Exigence 53267

    JJ+=1
  Next
  If JJ>1
    Gosub WTABDIC From AGENADOF
  Endif
Return


# Inclusion des menus intermédiaires (fonction générique pour les tables à menu intermédiaire par module)
# Le test d'existence d'une doc valide s'est un peu compliqué :
# - le titre est cherché en (10,10)
# - la doc est incluse s'il existe un texte en (10,20) si I_SUBLEV=2 (concerne ASU, AGB, et ADC)
# - si I_SUBLEV=0, on inclut toujours même si pas de texte dès lors que le paragraphe existe (ATB, AML)
$INCL_ATBMENINT
  II=val(right$([ADO]COD,5))

  If left$([ADO]COD,3)<>"ATB" : Return : Endif
  CH1="MCD/"

# Les menu XXX_numéro sont créés en fonction des docs présentes et remplies
  If II
    If dim([F]FLGPUB)>0
        CH2="[F]MODULE=II and [F]FLGPUB>1"
    Else
        CH2="[F]MODULE=II"
    Endif
    CHMODULE="MODULE=II"
    Gosub ATBMENINT

# Le menu XXX_0 regroupe tous les menus XXX_numéro
  Else
    For [AD1] Where LAN=COD_LAN & TYP="APM" & pat(COD,left$([ADO]COD,3)+"_*") & COD<>left$([ADO]COD,3)+"_0"
        Wrseq '        <li><a href="../'+CH1+[AD1]COD+'.htm">'
&             +[AD1]TIT+'</a></li>' Using [DOC]
    Next

    Wrseq '  </ul>' Using [DOC]
    Wrseq '  <P>&nbsp;<P>' Using [DOC]

    If dim([F]FLGPUB)>0
        CH2="[F]FLGPUB>1"
    Else
        CH2="1=1"
    Endif
    CHMODULE="1=1"
    Gosub ATBMENINT
    Wrseq '  <ul>' Using [DOC]
  Endif
Return

#VPO 27/10/08 49955 ajout AT3: différences de tables 130
$ATBMENINT
    #On doit lire l'index pour recup versions
    CURVERSION=""
    OLDVERSION=""
    OLDVERS130=""
    Read [AD1]ADO0=COD_LAN;"AT3";"_INDEX";10;10
    If fstat=0
        OLDVERS130=[AD1]TIT
    Endif

    Read [AD1]ADO0=COD_LAN;"ATD";"_INDEX";10;10
    If fstat=0
        OLDVERSION=[AD1]TIT
    Endif

    Read [AD1]ADO0=COD_LAN;"ATD";"_INDEX";10;20
    If fstat=0
        CURVERSION=[AD1]TIT
    Endif
    ###
    JJ=0
    For [ADO2]ADO2(1) Where evalue(CHMODULE) & LAN=COD_LAN & (TYP='ATB' or TYP='ATD' or TYP='AT3') & LEV=10 & SUBLEV=10
        TAB_TROUVE=1
        If [ADO2]COD="_INDEX" and ( [ADO2]TYP="ATD" | [ADO2]TYP="AT3" )
            #il s'agit de l'INDEX de différences de versions
            TAB_TROUVE=0
        Endif
        If TAB_TROUVE=1
            For [F] Where CODFIC=[ADO2]COD
                TAB_TROUVE=1
                If !evalue(CH2)
                    TAB_TROUVE=0
                Endif
                Break
            Next
        Endif
        If TAB_TROUVE=1
            #on ecrit entete de tableau
            If JJ=0
                If II=0
                    #Liste des tables par ordre alphabétique
                    Wrseq '  <h3 class="g1">'+func AGENADO.MST(280,142)+'</h3>' Using [DOC]
                Endif
                JJ=1
                If OLDVERS130=""
                Wrseq '<TABLE border=0 cellPadding=2 cellSpacing=0 cols=6 width=780>' Using [DOC]
                Else
                Wrseq '<TABLE border=0 cellPadding=2 cellSpacing=0 cols=7 width=780>' Using [DOC]
                Endif
                Wrseq '  <TR>' Using [DOC]
                Wrseq '    <TH ID=hdico width="15%">'+func AGENADO.RDM("ARP3","TBL")-CURVERSION+'</TH>' Using [DOC] : #Table
                If OLDVERS130<>""
                Wrseq '    <TH id=hdico width="10%">'+string$(OLDVERS130="","&nbsp;")+OLDVERS130+'</TH>' Using [DOC]
                Endif
                Wrseq '    <TH id=hdico width="10%">'+string$(OLDVERSION="","&nbsp;")+OLDVERSION+'</TH>' Using [DOC]
                Wrseq '    <TH id=hdico width="10%">'+func AGENADO.RDM("PS12","ABRLNK")+'</TH>' Using [DOC] : #Abrev
                Wrseq '    <TH id=hdico width="40%">'+func AGENADO.RDM("AMK0","ZINTMSK")+'</TH>' Using [DOC] : #intitule
                Wrseq '    <TH id=hdico width="25%">'+func AGENADO.RDM("ATB1","MODULE")+'</TH>' Using [DOC]
                Wrseq '    <TH id=hdicos width="10%">'+func AGENADO.RDM("ATB1","CODACT")+'</TH>' Using [DOC]
                Wrseq '  </TR>' Using [DOC]
            Endif

            # on ecrit chaque ligne du tableau
                Wrseq '  <TR>' Using [DOC]
            Read [AD1]ADO0=COD_LAN;"ATB";[ADO2]COD;10;10
            If fstat=0
                TAB_V5=1
                Wrseq '    <TD id=ldico><A href="../'+CH1+[ADO2]COD+'.htm">'+[ADO2]COD+'</A></TD>' Using [DOC]
            Else
                TAB_V5=0
                Wrseq '    <TD id=ldico>'+[ADO2]COD+'</TD>' Using [DOC]
            Endif

            If OLDVERS130<>""
                Read [AD1]ADO0=COD_LAN;"AT3";[ADO2]COD;10;10
                If fstat<>0
                        # c'est une table inexistante en 130
                    #VPO 07/11/08 47899 modif charte
                    If IF_DOCV5=0
                        Wrseq '    <TD id=ldicodis>&nbsp;</TD>' Using [DOC]
                    Else
                        Wrseq '    <TD id=ldico BGCOLOR="gainsboro">&nbsp;</TD>' Using [DOC]
                    Endif
                Else
                    Read [AD1]ADO0=COD_LAN;"AT3";[ADO2]COD;10;20
                    If fstat<>0
                        # c'est une table non modifiée
                        Wrseq '    <TD id=ldico>&nbsp;</TD>' Using [DOC]
                    Elsif [AD1]PAR="DEL"
                        Wrseq '    <TD id=ldico><IMG SRC="../'+CH1+'atd_del.gif" align=center alt="'+func AGENADO.MST(279,142)+'"></TD>' Using [DOC]
                    Elsif [AD1]PAR="NEW"
                        Wrseq '    <TD id=ldico><IMG SRC="../'+CH1+'atd_new.gif" align=center alt="'+func AGENADO.MST(278,142)+'"></TD>' Using [DOC]
                    Elsif [AD1]PAR="UPD"
                        Wrseq '    <TD id=ldico2><A href="../'+CH1+'AT3_'+[ADO2]COD+'.htm" align=center>'+func AGENADO.MST(256,142)+'</A></TD>' Using [DOC]
                    Endif
                Endif
            Endif


            Read [AD1]ADO0=COD_LAN;"ATD";[ADO2]COD;10;10
            If fstat<>0
                    # c'est une table inexistante en 130
                    #VPO 07/11/08 47899 modif charte
                    If IF_DOCV5=0
                        Wrseq '    <TD id=ldicodis>&nbsp;</TD>' Using [DOC]
                    Else
                        Wrseq '    <TD id=ldico BGCOLOR="gainsboro">&nbsp;</TD>' Using [DOC]
                    Endif
            Else
                Read [AD1]ADO0=COD_LAN;"ATD";[ADO2]COD;10;20
                If fstat<>0
                    # c'est une table non modifiée
                    Wrseq '    <TD id=ldico>&nbsp;</TD>' Using [DOC]
                Elsif [AD1]PAR="DEL"
                    Wrseq '    <TD id=ldico><IMG SRC="../'+CH1+'atd_del.gif" align=center alt="'+func AGENADO.MST(279,142)+'"></TD>' Using [DOC]
                Elsif [AD1]PAR="NEW"
                    Wrseq '    <TD id=ldico><IMG SRC="../'+CH1+'atd_new.gif" align=center alt="'+func AGENADO.MST(278,142)+'"></TD>' Using [DOC]
                Elsif [AD1]PAR="UPD"
                    Wrseq '    <TD id=ldico2><A href="../'+CH1+'ATD_'+[ADO2]COD+'.htm" align=center>'+func AGENADO.MST(256,142)+'</A></TD>' Using [DOC]
                Endif
            Endif

            If TAB_V5=1
                Wrseq '    <TD id=ldico>'+[F]ABRFIC+'</TD>' Using [DOC]
                Wrseq '    <TD id=ldico>'+func AGENADO.RDT([F]INTITFIC)+'</TD>' Using [DOC]
                Wrseq '    <TD id=ldico>'+func AGENADO.MST([F]MODULE,14)+'</TD>' Using [DOC]
                Wrseq '    <TD id=ldicos>'+string$([F]CODACT="","&nbsp;")+[F]CODACT+'</TD>' Using [DOC]
                Wrseq '  </TR>' Using [DOC]
            Else
                Wrseq '    <TD id=ldico>'+[AD1]TIT+'</TD>' Using [DOC]
                Wrseq '    <TD id=ldico>'+[ADO2]TIT+'</TD>' Using [DOC]
                Wrseq '    <TD id=ldico>'+func AGENADO.MST([ADO2]MODULE,14)+'</TD>' Using [DOC]
                Wrseq '    <TD id=ldicos>'+string$([ADO2]CODACT="","&nbsp;")+[ADO2]CODACT+'</TD>' Using [DOC]
                Wrseq '  </TR>' Using [DOC]
            Endif
        Endif
    Next
    If JJ>0
       Wrseq '</TABLE>' Using [DOC]
    Endif
Return

# Menus intermédiaires Workflow
$INCL_AWAMENINT
  CH1=right$([ADO]COD,5)

# Les menus AWA_groupe sont créés en fonction des docs présentes
  If CH1<>"0"
    KK=0
    For [AWA]AWA2(2) Where CATEG=CH1
        If KK=0
            Wrseq '        <ul>' Using [DOC]
            KK=1
        Endif
        For [AWA]AWA2
            JJ=0
            Read [AD1]ADO0=COD_LAN;"AWA";[AWA]CODE;10;10
            #JPGA 03/12/2011 BUG-69649 : Les Sous-menus des APM génère des liens vers des Docs non validées si la case "Docs validées" est cochée
            If !fstat & func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
                # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                Wrseq '        <li><a href="../OBJ/AWA_'+[AD1]COD+'.htm">'
&                     +[AWA]CODE+"</a>"-"("+func AGENLIBA.RECH_DESIGNATION('AWA', [AWA]CODE, '')+')</li>' Using [DOC]
            Endif
        Next
    Next
    If KK
        Wrseq '        </ul>' Using [DOC]
    Endif

# Le menu AWA_0 regroupe tous les menus AWA_catégorie
  Else
    KK=0
    For [AD1] Where LAN=COD_LAN & TYP="APM" & pat(COD,"AWA_*") & COD<>"AWA_0"
        If KK=0 : Wrseq '        <ul>' Using [DOC] : KK=1 : Endif
        Wrseq '        <li><a href="../OBJ/'+[AD1]COD+'.htm">'
&             +[AD1]TIT+'</a></li>' Using [DOC]
    Next
    If KK : Wrseq '        </ul>' Using [DOC] : Endif

  Endif
Return


# Menus intermédiaires paramètres
$INCL_ADPINT
  CH1=right$([ADO]COD,5)

# Les menus ADP_chapitre sont créés en fonction des docs présentes
  If CH1<>"0"
    For [ADP]ADP5(2) Where CHAPITRE=CH1 & MODIF=2
        KK=0
        For [ADP]ADP5
            JJ=0
            #JPGA 16/06/2011 BUG-74237 : Les Sous-menus des APM ne génère des liens vers des Docs ENG pour les ADP si la case "Docs validées" est cochée
            DOC_TROUVE= 0 : Call DOCUMENTATION_TROUVE("ADO0",COD_LAN,left$([ADO]COD,3), [ADP]PARAM,10,10,"", DOC_TROUVE)

            If DOC_TROUVE & func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
                If KK=0
                    # JPGA 01/10/2010 Bug-67364 : Procedure Détectant le type de Désignation dans ATABLE pour recherche du texte traduit
                    Call TIT_PAR(4,func AGENADO.RDM('ADP1','GRPPAR')-[ADP]GRPPAR-"("+
&                                  func AGENLIBA.RECH_DESIGNATION('ADI', '903', [ADP]GRPPAR)+")") From AGENLIBA
                    KK=1
                    Wrseq '        <ul>' Using [DOC]
                Endif
                Wrseq '        <li><a href="../OBJ/ADP_'+CH1+"_"+[AD1]COD+'.htm">'
&                     +[ADP]PARAM+"</a>"-"("+func AGENADO.RDT([ADP]NAM)+')</li>' Using [DOC]
            Endif
        Next
        If KK
            Wrseq '        </ul>' Using [DOC]
        Endif
    Next

# Le menu ADP_0 regroupe tous les menus ADP_chapitre
  Else
    KK=0
    For [AD1] Where LAN=COD_LAN & TYP="APM" & pat(COD,"ADP_*") & COD<>"ADP_0"
        If KK=0 : Wrseq '        <ul>' Using [DOC] : KK=1 : Endif
        Wrseq '        <li><a href="../OBJ/'+[AD1]COD+'.htm">'
&             +[AD1]TIT+'</a></li>' Using [DOC]
    Next
    If KK : Wrseq '        </ul>' Using [DOC] : Endif

  Endif
Return

# Menus intermédiaires points d'entrée : fonction qui tente de trouver un intitulé
# En français, on peut éventuellement prendre l'intitulé trouvé dans le dictionnaire des traitements
# Dans les autres langues : on recherche s'il existe un texte français
# Sinon, on recherche une action, et on choisit de prendre son intitulé

# Inclusion de la structure des tables
$INCL_DIC

# Si un texte préliminaire existe, on l'inclut
  Gosub LEC_WR_ADO From AGENDOCA

# Sinon, on se contente d'écrire la structure de la table
  Read [ATB]CODFIC=[ADO]COD
  If fstat=0
      Call WRDICATB(DOSDOC,[ADO]COD,GEN_FIN) From AGENADOF
  Endif

Return

# Inclusion de la structure des menus locaux
$INCL_AML

# Si un texte préliminaire existe, on l'inclut
  Gosub LEC_WR_ADO From AGENDOCA

# Sinon, on se contente d'écrire la structure de la table
  Read [AML]MENLOC=val([ADO]COD)
  If fstat=0
      Call WRDICAML(DOSDOC,[ADO]COD,GEN_FIN) From AGENADOF
  Endif

Return

# Inclusion de la structure des menus locaux
$INCL_ATY

# Si un texte préliminaire existe, on l'inclut
  Gosub LEC_WR_ADO From AGENDOCA

# Sinon, on se contente d'écrire la structure de la table
  Read [ATY]CODTYP=[ADO]COD
  If fstat=0
      Call WRDICATY(DOSDOC,[ADO]COD,GEN_FIN) From AGENADOF
  Endif

Return


# Inclusion de l'aide en ligne (on purge des textes qui auraient un en-tête HTML)
# On gère le chaînage avant/après sur des aides génériques, mais à un seul niveau !
$INCL_AIDE
  Read [ADZ]ADZ0=COD_LAN;HELP_CHAMP(II)
  #VPO 04/01/08 BUG44500
  If fstat
     Read [ADZ4]ADZ0=COD_LAN;HELP_CHAMP(II)
     [ADZ]=[ADZ4]
  Endif
  If [ADZ]LNKHLP<>""
    If [ADZ]LNKORD=1
        [ADZ3]=[ADZ]
        Read [ADZ]ADZ0=COD_LAN;[ADZ]LNKHLP
        #VPO 04/01/08 BUG44500
        If fstat
           Read [ADZ4]ADZ0=COD_LAN;[ADZ]LNKHLP
           [ADZ]=[ADZ4]
        Endif
        Gosub INCL_HLPCHP
        ##Read [ADZ]ADZ0=COD_LAN;HELP_CHAMP(II)
        [ADZ]=[ADZ3]
    Endif
    Gosub INCL_HLPCHP
    If [ADZ]LNKORD=2
        Read [ADZ]ADZ0=COD_LAN;[ADZ]LNKHLP
        #VPO 04/01/08 BUG44500
        If fstat
           Read [ADZ4]ADZ0=COD_LAN;[ADZ]LNKHLP
           [ADZ]=[ADZ4]
        Endif
        Gosub INCL_HLPCHP
    Endif
  Else
    Gosub INCL_HLPCHP
  Endif
Return

$INCL_HLPCHP
  If fstat=0
    Setlob AIDECHP With [ADZ]TEXTE
    KK=1 : KKBD=0 : KKBE=0
    While AIDECHP(KK)<>""
        If pat(tolower(AIDECHP(KK)),"*<body>*")
            AIDECHP(KK)=right$(AIDECHP(KK),instr(1,tolower(AIDECHP(KK)),"<body>")+6)
            KKBD=KK+(vireblc(AIDECHP(KK),4)="")
        Elsif pat(tolower(AIDECHP(KK)),"*</body>*")
            AIDECHP(KK)=left$(AIDECHP(KK),instr(1,tolower(AIDECHP(KK)),"</body>")-1)
            KKBE=KK-(vireblc(AIDECHP(KK),4)="")
        Endif
        KK+=1
    Wend
    If KKBD<>0 or KKBE<>0
        KK=max(1,KKBD)
        While AIDECHP(KK)<>""
            Wrseq AIDECHP(KK) Using [DOC]
            Break (KK=KKBE)
            KK+=1
        Wend
    Else
        If pat(toupper(vireblc(AIDECHP(1),0)),"<P>*")=0
            Wrseq "                <p>" Using [DOC]
            Wrseq [ADZ]TEXTE Using [DOC]
            Wrseq "                </p>" Using [DOC]
        Else
            Wrseq [ADZ]TEXTE Using [DOC]
        Endif
    Endif
  Endif
Return

# Ecriture d'une bullet
$BULLET
  Wrseq '        <p><img border=0 width=7 height=7 src="bullet_brique.gif">&nbsp;' Using [DOC]
Return


#
# Ensemble de fonctions donnant un accès traduisible aux textes du dictionnaire
# Lecture des textes dans la bonne langue
# Si le texte n'est pas trouvé, on le prend en français mais on le met entre crochets
#

# Textes du dictionnaire (ATEXTE)
Funprog RDT(I)
Value Integer I
 If clalev([ZATX])=0 : Local File ATEXTE [ZATX] : Endif
 Read [ZATX]NUMERO=[V]COD_LAN;I
 If fstat<>0
    If [V]COD_LAN<>"FRA"
        Read [ZATX]NUMERO="FRA";I
        If fstat=0
            [ZATX]TEXTE="["+[ZATX]TEXTE+"]"
        Else
            Raz [ZATX]
        Endif
    Else
        Raz [ZATX]
    Endif
 Endif
End [ZATX]TEXTE

# Textes du dictionnaire par référence au champ d'un écran
# (ou au titre de l'écran si le champ est vide, ou au titre du bloc si on retrouve un champ numérique)
# A utiliser dès qu'on a besoin d'un texte "constant" déjà traduit (le numéro de ATEXTE n'est pas constant)
#
Funprog RDM(MASQ,CHAMP)
Value Char MASQ(),CHAMP()

 If clalev([AMK1])=0 : Local File AMSK [AMK1] : Endif
 If clalev([AMZ1])=0 : Local File AMSKZON [AMZ1] : Endif
 If pat(CHAMP,"#*")
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]TITBLOC(val(CHAMP))<>0
            End func AGENADO.RDT([AMK1]TITBLOC(val(CHAMP)))
        Endif
    Endif
 Elsif CHAMP<>""
    Read [AMZ1]CODE=MASQ;CHAMP
    If fstat=0
        If [AMZ1]INTIT<>0
            End func AGENADO.RDT([AMZ1]INTIT)
        Endif
    Endif
 Else
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]INTMSK<>0
            End func AGENADO.RDT([AMK1]INTMSK)
        Endif
    Endif
  Endif
End ""

#
# Textes du dictionnaire (APLSTD)
# (notamment les menus locaux, table de messages 142 dédiée à la doc...)
#
Funprog MST(ID,CHAPTER)
Value Integer ID, CHAPTER

Local Char MESSAGE(250)

 If clalev([F:ZSTD])=0 : Local File APLSTD [ZSTD] : Endif
 Read [ZSTD]CLE=CHAPTER;ID;[V]COD_LAN
 If fstat=0
    [L]MESSAGE = [ZSTD]LANMES
 Else
    Read [ZSTD]CLE=CHAPTER;ID;GLANGUE
    If fstat=0
        [L]MESSAGE =  "["+[ZSTD]LANMES+"]"
    Else
        [L]MESSAGE =  "["+num$(ID)+","+num$(CHAPTER)+"] "
    Endif
 Endif
GPOINT = "MESSAGE" : Gosub ENTREE From EXEFNC
End [L]MESSAGE



# Textes traduisibles (ATEXTRA)
Funprog RDX(A,B,C,D)
Value Char A(),B(),C(),D()

#VPO 29/10/07 BUG42128 : lire ATEXTRA du dossier voulu
Read [ZAXX]AXX0=A;B;[V]COD_LAN;C;D
If fstat<>0
 Read [AXX]AXX0=A;B;[V]COD_LAN;C;D
 If fstat<>0
    If [V]COD_LAN<>"FRA"
        Read [AXX]AXX0=A;B;"FRA";C;D
        If fstat=0
            End "["+[AXX]TEXTE+"]"
        Else
            End ""
        Endif
    Else
        End ""
    Endif
 Else
    End [AXX]TEXTE
 Endif
Else
End [ZAXX]TEXTE
Endif
End ""

# Titre du menu local
Funprog TML(M)
Value Integer M
##VPO 26/09/07 BUG41384
  If M>0 and M<100
    End func AGENADO.MST(M,0)
  Else
    End func AGENADO.MST(M-200,200)
  Endif
End
#
# Ensemble de sous-programmes accédant au dictionnaire pour retrouver les éléments nécessaires
# à la génération automatique de la doc
#

#
# Sous-programmes de lecture du dictionnaire (accès aux liens)
#
# Lecture directe de la table des liens
#
$LIT_VALEURS
  LNK_TYPE=[ADO]PAR
$LIT_PAR_VAL
  II=0
  For [ADF]ADF0 Where TYP=[ADO]TYP and COD=[ADO]COD and TYPLNK=LNK_TYPE
    II+=1
    VALEURS(II)=[ADF]CLELNK
    II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

#
# Lecture inverse de la table des liens
#
$LIT_VALINV
  II=0
  LNK_TYPE=[ADO]PAR
$LIT_AUSSI_VALINV
  For [ADF]ADF0 Where TYP=[ADO]PAR and CLELNK=[ADO]COD and TYPLNK=[ADO]TYP
    II+=1
    VALEURS(II)=[ADF]COD
    II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return


#
# Caractérisation de la fonction (objet, consultation, tâche batch) et lecture de la fenêtre associée
# (Aide fonctionnelle uniquement)
# Ce sous-programme lit [AFC], [AWI], [AOB], [ACN]
# et renseigne TYPEFONC avec les valeurs suivantes :
#    1=objet, 2=consult, 3=traitement batchable, 4=traitement autre, 5=saisie fenêtre, 6=menu
# Une entrée dédiée (LECWIN) est utilisée par le traitement AGENDOCA
#
$LIREWIN

  Raz INTCPT,BOUTBAS, LIENSGEN
  CODE_DOC=[ADO]COD

$LECWIN : # Entrée utilisée par le traitement AGENDOCA

  Raz CODOBJ,CODCON,TYPEFONC
  Raz [AWI] : #VPO 23/06/08 bug48044
  Raz [AOB]
  Raz [ACT]
  Raz [ACN]

  Read [AFC]CODINT=CODE_DOC
  If fstat<>0
    Raz [AWI]
    Return
  Endif

  If [AFC]TYPTRAIT=2 : # Il s'agit d'un menu
    TYPEFONC=6
    Raz [AWI]
  Elsif [AFC]ACTION="GOBJET" : # Il s'agit d'un objet
    TYPEFONC=1
    Read [AWI]AWI0="O"+right$(CODE_DOC,4)
    If fstat : # La fenêtre de l'objet n'est pas normalisée comme elle devrait (ex : objet SNL)
        For [AWI]AWI1 Where OBJ=right$(CODE_DOC,4)
            Break
        Next
    Endif
    If [AWI]OBJ<>right$(CODE_DOC,4)
        Raz [AWI]
        II=0
        While II<dim([AFC]CODPAR) and [AFC]CODPAR(II)<>""
            If [AFC]CODPAR(II)="OBJET"
                CODOBJ=vireblc(ctrans([AFC]VALPAR(II),'"'+"'","  "),3)
                # VPO 12/06/08 BUG47912
                If [AFC]VARIA(0)="GFLAG"
                    CODTRN=vireblc(ctrans([AFC]VALEUR(0),'"'+"'","  "),3)
                    For [AWI] Where WINTYP=2 and OBJ=CODOBJ & TRN=CODTRN
                        Break 2
                    Next
                Else
                    For [AWI] Where WINTYP=2 and OBJ=CODOBJ
                        Break 2
                    Next
                Endif
            Endif
            II+=1
        Wend
    Endif
    CODOBJ=[AWI]OBJ
    Read [AOB]ABREV=CODOBJ

  Elsif [AFC]ACTION<>"" : # Et non plus "Elsif [AFC]TYP=1", pour gérer les fonctions non objet avec habilitation objet !
    Read [ACT]ACTION=[AFC]ACTION

    If [ACT]TYP=2 : # Il s'agit d'une consultation
        Raz [AWI]
        CODCON=""
        Read [ACN]ACN0=[ACT]PARAM1
        If fstat=0
            TYPEFONC=2
            CODCON=[ACN]COD
            Read [AWI]AWI0=[ACN]WND1
        Endif

    Elsif [ACT]TYP=3
        If [ACT]PARAM2="" : # Traitement standard sans fenêtre, lançable en batch
            TYPEFONC=3
            If [ACT]PARAM4<>""
                Read [AWI]AWI0=[ACT]PARAM4
            Else
                # Modification pour tenir compte de traitements batch qui se font dans l'action suite
                # Exemples : GIMPOBJ, GEXPOBJ...
                Raz [AWI]
                If [ACT]ACTSUI<>""
                    Read [ACT]ACTION=[ACT]ACTSUI
                    If [ACT]TYP=3 and [ACT]PARAM2="" and [ACT]PARAM4<>""
                        TYPEFONC=3
                        Read [AWI]AWI0=[ACT]PARAM4
                    Endif
                Endif
            Endif
        Else
            TYPEFONC=4
            Read [AWI]AWI0=[ACT]PARAM2 : # Traitement standard de type "plan de travail", la fenêtre est lue
        Endif

    Elsif [ACT]TYP=4 : # Traitement de type Saisie fenêtre
        TYPEFONC=5
        Raz [AWI]
        If [ACT]PARAM2<>"" : # Pas de fenêtre
            Read [AWI]AWI0=[ACT]PARAM2
        Endif
    Endif
  Else
    Raz [AWI]
    TYPEFONC=3 : # ??
  Endif

Return

# Recherche des codes activités dans le dictionnaire (renvoie II et VALEURS)
$RECH_ACV

  # On regarde d'abord s'il y a des liens
  Gosub LIT_VALEURS

  # Modification : si on trouve FAL dans les valeurs de lien, on ne fait pas la recherche standard
  If find("FAL",VALEURS(1..II))=0

      # Puis on recherche dans la fonction et la fenêtre
      Gosub ACV_AFC
      Gosub ACV_AWI

    # Les codes activités de l'objet
      If TYPEFONC=1
        Gosub ACV_AOB
      Elsif TYPEFONC=2
        Gosub ACV_ACN
      Endif
    Endif

# On supprime les codes activités internes du superviseur
  Gosub ELIMINE_ACV From AGENDOCA

Return

# Recherche des codes activités de la fonction
$ACV_AFC
  If [AFC]CODINT<>""
    If [AFC]CODACT<>""
        II+=1 : VALEURS(II)=[AFC]CODACT : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Endif
    For JJ=0 To [AFC]NBOPT-1
        II+=1 : VALEURS(II)=[AFC]ACTOPT(JJ): II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next JJ
    For JJ=0 To [AFC]NBVAR-1
        If [AFC]ACTVAR(JJ)<>""
            II+=1 : VALEURS(II)=[AFC]ACTVAR(JJ): II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        Endif
    Next JJ
    Read [ACT]ACTION=[AFC]ACTION
    If fstat=0 & [ACT]CODACT<>""
        II+=1 : VALEURS(II)=[ACT]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Endif
  Endif
Return

# Recherche des codes activités de la fenêtre
$ACV_AWI

# La fenêtre elle-même
  If [AWI]WIN<>""
    If [AWI]CODACT<>""
        II+=1 : VALEURS(II)=[AWI]CODACT : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Endif
    For JJ=0 To [AWI]NBMSK
        CHAINE=string$(JJ=0,[AWI]MSKENT)+string$(JJ<>0,[AWI]NOMMSK(max(0,JJ-1)))
        If JJ & [AWI]ACTMSK(max(0,JJ-1))<>""
            II+=1 : VALEURS(II)=[AWI]ACTMSK(JJ-1): II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        Endif

# Les écrans
        If CHAINE<>""
            Read [AMK]CODMSK=CHAINE
            Gosub ACV_AMK
        Endif
    Next

# Les boutons de la fenêtre
    For [AWT] Where WIN=[AWI]WIN
        If [AWT]CODACTBOUT<>""
            II+=1 : VALEURS(II)=[AWT]CODACTBOUT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        Endif
        Read [ACT]ACTION=[AWT]ACTBOUT
        If fstat=0 & [ACT]CODACT<>""
            II+=1 : VALEURS(II)=[ACT]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        Endif
    Next
    For JJ=0 To 19
        If [AWI]ACTSTD(JJ)<>""
            Read [ACV]CODACT=[AWI]ACTSTD(JJ)
            If fstat=0 & [ACV]CODACT<>""
                II+=1 : VALEURS(II)=[ACV]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
            Endif
        Endif
    Next JJ

  Endif
Return

# Recherche des codes activités d'un écran
$ACV_AMK
  If [AMK]CODMSK<>""
    If [AMK]CODACT<>""
        II+=1 : VALEURS(II)=[AMK]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Endif
    For KK=0 To [AMK]NBBLOC-1
        If [AMK]ACTBLOC(KK)<>""
            II+=1 : VALEURS(II)=[AMK]ACTBLOC(KK): II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        Endif
    Next KK
    For [AMZ] Where CODMSK=[AMK]CODMSK & CODACT<>""
        II+=1 : VALEURS(II)=[AMZ]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next
    Link [AMA] With [ACT]ACTION=[AMA]ACTION As [MZZ] Where [AMA]CODAFF=[AMK]CODMSK & [ACT]CODACT<>""
    For [MZZ]
        II+=1 : VALEURS(II)=[ACT]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next
  Endif
Return

# Recherche des codes activités d'une table
$ACV_ATB
  If [ATB]CODFIC<>""
    II+=1 : VALEURS(II)=[ATB]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    For [ATZ] Where CODFIC=[ATB]CODFIC & CODACT<>""
        II+=1 : VALEURS(II)=[ATZ]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next
    For [ATI] Where CODFIC=[ATB]CODFIC & CODACT<>""
        II+=1 : VALEURS(II)=[ATI]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next
  Endif
Return

# Recherche des codes activités d'un objet  => modification : on n'analyse que les tables du même module
$ACV_AOB
  If [AOB]ABREV<>""
    Read [ATB]CODFIC=[AOB]NOMFIC
    JJ=[ATB]MODULE
    Gosub ACV_ATB
    II+=1 : VALEURS(II)=[AOB]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    For [AOT] Where ABREV=[AOB]ABREV
        II+=1 : VALEURS(II)=[AOT]TABACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
        Read [ATB]CODFIC=[AOT]TABFIC
        If [ATB]MODULE=JJ
            Gosub ACV_ATB
        Endif
    Next
  Endif
Return

# Recherche des codes activités d'une consultation
$ACV_ACN
  If [ACN]COD<>""
    II+=1 : VALEURS(II)=[ACN]CODACT: II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Endif
Return

# Recherche des codes activité associés à un code activité
$ACV_ACV
  For [ACV1] Where DEP<>1
    If    (([ACV1]DEP=2 or [ACV1]DEP=3) and [ACV1]ACTDEP=[ACV]CODACT)
&      or pat(ctrans(" "+[ACV1]ACTFOR+" ","*+-/()",space$(6)),"* "+[ACV]CODACT+" *")
        II+=1 : VALEURS(II)=[ACV1]CODACT : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Endif
  Next
Return

# Recherche des codes activités associés à un paramètre
$ACV_ADP
  If [ADP]CODACT<>""
    II+=1 : VALEURS(II)=[ADP]CODACT : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Endif

# On en ramène trop d'inutiles si on active cette partie de code
# If [ADP]OBJET<>""
#   Read [AOB]ABREV=[ADP]OBJET
#   Gosub ACV_AOB
# Endif

Return

# Recherche des paramètres associés à un code activité
$ADP_ACV
  For [ADP2] Where CODACT=[ACV]CODACT and MODIF=2
    II+=1 : VALEURS(II)=[ADP2]PARAM : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

# Recherche des paramètres associés à un paramètre
# On prend tous ceux du même groupe
$ADP_ADP
  For [ADP2] Where [ADP2]CHAPITRE=[ADP]CHAPITRE and [ADP2]GRPPAR=[ADP]GRPPAR and [ADP2]PARAM<>[ADP]PARAM
&              and MODIF=2
    II+=1 : VALEURS(II)=[ADP2]PARAM : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

# Recherche des états d'une fonction
$ARP_AFC
  If [ADO]TYP='AFC'
    Read [AFC]CODINT=[ADO]COD
    If fstat=0
        For CHAINE=[AFC]RPT1,[AFC]RPT2
            If CHAINE<>""
                JJ=II
                For [ARX]ARX0 Where INTCOD=CHAINE
                    II+=1 : VALEURS(II)=[ARX]EXTCOD : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
                Next
                If JJ=II
                    Read [ARP]ARP0=CHAINE
                    If fstat=0
                        II+=1 : VALEURS(II)=CHAINE : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
                    Endif
                Endif
            Endif
        Next CHAINE
    Endif
  Endif
Return

# Recherche des tables d'une fonction
$ATB_AFC
  If TYPEFONC=1 & CODOBJ<>""
    Read [AOB]ABREV=CODOBJ
    Gosub ATB_AOB
  Elsif TYPEFONC=2 & [ACN]COD<>""
    II+=1 : VALEURS(II)=[ACN]FILNAM : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    For JJ=0 To [ACN]NBRFIL-1
        II+=1 : VALEURS(II)=[ACN]FILOPN(JJ) : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Next JJ
  Endif
Return

# Recherche des tables d'une variable de dimensionnement
$ATB_ADM
  For [AFO]
    If pat(ctrans(" "+[AFO]FORDIM+" ","*+-/()",space$(6)),"* "+[ADM]COD+" *")
        II+=1 : VALEURS(II)=[AFO]CODFIC : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Endif
  Next
Return

# Recherche des tables d'une règle Workflow
$ATB_AWA

# On ramène trop de tables en reprenant tout ce qui se trouve dans l'objet
#
# If [AWA]TYPEVT=2 & [AWA]CODEVT<>"" : # C'est un objet non générique
#   Read [AOB]ABREV=[AWA]CODEVT
#   If fstat=0
#       Gosub ATB_AOB
#   Endif
# Endif
#
# Code désactivé

  If [AWA]MODELE<>""
    Read [AWM]AWM0=[AWA]MODELE
    II+=1 : VALEURS(II)=[AWM]TABREF : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    #JPGA 06/01/2010 BUG-70497 : Test de la variable AWKDOC pour savoir si les Modèles de données sont présents (a partir de la V7)
    If [L]AWKDOC & dim([AWK]TABLNK)>0 : #  CCL ajout table AWRKTAB 31/12/2010
       For [AWK]AWK0 Where MODELE=[AWA]MODELE
          II+=1 : VALEURS(II)=[AWK]TABORI : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
          II+=1 : VALEURS(II)=[AWK]TABLNK : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
       Next
    Else
       For JJ=0 To [AWM]NBRLNK-1
          II+=1 : VALEURS(II)=[AWM]TABORI(JJ) : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
          II+=1 : VALEURS(II)=[AWM]TABLNK(JJ) : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
       Next JJ
    Endif
  Endif
Return

# Recherche des tables d'un objet
$ATB_AOB
  II+=1 : VALEURS(II)=[AOB]NOMFIC : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  For [AOT]ABREV Where ABREV=[AOB]ABREV
    II+=1 : VALEURS(II)=[AOT]TABFIC : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

# Recherche des tables d'un modèle import/export
$ATB_AOE
  If [AOE]OBJ<>""
    Read [AOB]ABREV=[AOE]OBJ
    If fstat=0
        Gosub ATB_AOB
    Endif
  Endif
  For JJ=0 To [AOE]NBRFLG-1
    II+=1 : VALEURS(II)=[AOE]FLGFIL(JJ) : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next JJ
  For [AOD]AOD0 Where EXT=[AOE]EXT
    II+=1 : VALEURS(II)=[AOD]FIL : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

# Recherche des fonctions associées à un code activité
# Recherche limitée au code activité principal (au delà, on peut mettre des liens)
$AFC_ACV
#VPO 12/11/07 BUG44007
If [ACV]CODACT<>""
  For [AFC] Where TYPTRAIT=1
    If find([ACV]CODACT,[AFC]CODACT,[AFC]ACTVAR)
        II+=1 : VALEURS(II)=[AFC]CODINT : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
    Endif
  Next
Endif
Return

# Recherche des écrans de consultation associés à une fonction
# Recherche limitée au code activité principal (au delà, on peut mettre des liens)
$GTC_ACN
  For [GTC]GTC0 Where CNSCOD=CODCON
    II+=1 : VALEURS(II)=[GTC]COD : II-=(find(VALEURS(II),"",VALEURS(1..II-1))<>0)
  Next
Return

$WR_INTRO : Gosub WR_INTRO From AGENDOCA : Return


##################################################################################
Subprog DOCUMENTATION_TROUVE (VV_INDEX, VV_LAN, VV_TYP, VV_COD, VV_LEV, VV_SUBLEV, VV_PAR, DOC_TROUVE)
Value Char       VV_INDEX, VV_LAN() , VV_TYP(), VV_COD(), VV_PAR()
Value Integer    VV_LEV,   VV_SUBLEV
Variable Integer DOC_TROUVE

# La documentation est elle présente ou pas ? (Non trouvée par défaut)
  DOC_TROUVE=0

  #JPGA 20/12/2010 BUG-70099:Recherche pour savoir si la langue COD_LAN fait bien partie des langues pour lesquelles ont recherche les menus ENG
  Gosub RECHERCHE_LAN_DANS_ENG

  # Lecture en fonction de l'index donné en Entrée
  Case VV_INDEX
    When "ADO0"
      Read [AD1]ADO0=VV_LAN;VV_TYP;VV_COD;VV_LEV;VV_SUBLEV
      #VPO 16/09/08 49235
      If [L]IF_MENU_ENG
         If fstat
            # Documentation RUS ou GER : Si non trouvé : Lecture de la doc ENG
            Read [AD1]ADO0="ENG";VV_TYP;VV_COD;VV_LEV;VV_SUBLEV
         Else
            # JPGA 18/01/2010 BUG-70804 - Documentation RUS ou GER : Si trouvé mais non valide : Lecture de la doc ENG
            If ! func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
               Read [AD1]ADO0="ENG";VV_TYP;VV_COD;VV_LEV;VV_SUBLEV
            Endif
         Endif
      Endif
      If !fstat
         DOC_TROUVE=1
      Endif
    When "ADO1"
      Read [AD1]ADO1=VV_LAN;VV_TYP;VV_COD;VV_PAR
      #VPO 16/09/08 49235
      If [L]IF_MENU_ENG
         If fstat
            # Documentation RUS ou GER : Si non trouvé : Lecture de la doc ENG
            Read [AD1]ADO1="ENG";VV_TYP;VV_COD;VV_PAR
         Else
            # JPGA 18/01/2010 BUG-70804 - Documentation RUS ou GER : Si trouvé mais non valide : Lecture de la doc ENG
            If ! func AGENLIBA.DOCUMENTATION_VALIDE([AD1]LAN, [AD1]TYP, [AD1]COD, [AD1]LEV, [AD1]SUBLEV)
               Read [AD1]ADO1="ENG";VV_TYP;VV_COD;VV_PAR
            Endif
         Endif
      Endif
      If !fstat
         DOC_TROUVE=1
      Endif
  Endcase
End

#JPGA 20/12/2010 BUG-70099:Recherche pour savoir si la langue COD_LAN fait bien partie des langues pour lesquelles ont recherche les menus ENG
$RECHERCHE_LAN_DANS_ENG
   # Initialisation des Langues à prendre en compte pour aller chercher les Menus en ENG
   If dim([L]LAN_MENU_ENG)<0
      Local Char    LAN_MENU_ENG(50)(1..50)

      If dim(MM)<0  :  Local Integer MM  :  Endif
      Raz MM
      MM+=1 : [L]LAN_MENU_ENG(MM) = "GER"
      MM+=1 : [L]LAN_MENU_ENG(MM) = "RUS"
      # JPGA 10/10/2011 BUG-76946 - Pour documentation SPA : Si trouvé mais non valide : Lecture de la doc ENG (Pas a faire en V5)
      If ! IF_DOCV5
         MM+=1 : [L]LAN_MENU_ENG(MM) = "SPA"
      Endif
   Endif

   # Initialisation des variables utilisées pour la suite des traitements à partir de LAN_MENU_ENG préalablement initialisée
   # Initialisation n°1 : IF_MENU_ENG : exemple : find(COD_LAN,'GER','RUS')
   If dim([L]IF_MENU_ENG)<0  :  Local Integer IF_MENU_ENG   : Endif
   [L]IF_MENU_ENG = find(COD_LAN,[L]LAN_MENU_ENG)

   # Initialisation n°2 : DOC_MENU_ENG    : exemple : "( COD_LAN,'GER' & find(LAN,'GER','ENG') )" ou "( COD_LAN,'RUS' & find(LAN,'RUS','ENG') )"
   If dim([L]DOC_MENU_ENG)<0     :  Local Char    DOC_MENU_ENG(100) : Endif
   If [L]IF_MENU_ENG
      [L]DOC_MENU_ENG = "(  COD_LAN='"+[L]LAN_MENU_ENG(find(COD_LAN,[L]LAN_MENU_ENG))+"' "
      [L]DOC_MENU_ENG+= "& find(LAN,'"+[L]LAN_MENU_ENG(find(COD_LAN,[L]LAN_MENU_ENG))+"','ENG') )"
   Else
      [L]DOC_MENU_ENG = "1=1"
   Endif
Return

