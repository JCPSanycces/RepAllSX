######################################################################################
## Etiquette ajoutée par le superviseur (écran SCO1) 10/03/2009 11:43:56 (GA)
######################################################################################
Subprog AS_LTI(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M:SCO3]SCOLTI>0  # FQ 52859 GA 10/03/2009
   VALEUR=[M:SCO3]SCOLTI
Endif
End

Subprog AM_LTI(VALEUR)
Variable Decimal VALEUR
Local    Date    WOPESTR
Local    Integer WOFS : WOFS=VALEUR
Raz [M:SCO1]RETDAT                     # FQ 52859 GA 10/03/2009
# Recalcul de la date de réception prévue
Call UPD_ITM_DAT(WOFS,[M:SCO0]POHFCY,[M:SCO1]ORDDAT,[M:SCO1]RETDAT) From SCOLIB
Call AM_RETDAT([M:SCO1]RETDAT) From SUBSCO1
Affzo [M:SCO1]LTI,ORDDAT,RETDAT

# Repositionnemant dates+délai du service
If [M:SCO1]RETDAT<[M:SCO3]OPEEND   [M:SCO3]OPEEND = [M:SCO1]RETDAT Endif
If WOFS<[M:SCO3]SCOLTI             [M:SCO3]SCOLTI = WOFS           Endif
Raz [M:SCO3]OPESTR
Call AM_OPEEND([M:SCO1]RETDAT) From SUBSCO3
Affzo [M:SCO3]OPESTR,OPEEND,SCOLTI

End

######################################################################################
# Issue 91501 GA 07/2013
# --------------------------------------- NBAXE --------------------------------
Subprog C_NBDIE
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle Sections d'entête obligatoires si saisissables -----#
# Issue 118457 - 2016-09-21 by MUARN : GHEADIE inutiles en SST
#If [M:SCO1]NBDIE>0 & GHEADIE=1
If [M:SCO1]NBDIE>0
  Local Integer I,J
  For I=1 To [M:SCO1]NBDIE
    J=find([M:SCO1]DIE(I-1),GDIE(1..GNBDIE))
    Call CTRL_CCEH([M:SCO1]CCE(I-1),J,GFINRSP,[M:SCO1]RETDAT ) From TRTX3CPT
    If mkstat  Break : Endif
  Next I
Endif
End

Subprog D_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCO1]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub D_CCEX
End

Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCO1]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub AS_CCEX
End

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
Local    Integer AXE : AXE=find([M:SCO1]DIE(nolign-1),GDIE(1..GNBDIE)) : Gosub C_CCEX
End

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SCI","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
If VALEUR="" Gosub D_CCEX Endif # Issue 91501 GA 07/2013
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SCO1]RETDAT) From TRTX3CPT
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:SCO1]ITMREF
Endif
Return

######################################################################################

 # Issue X3-95319 - 2018-06-21 by MUARN : avant modification site de réception contrôle qu'il soit différent du site du fournisseur
Subprog C_PRHFCY(VALEUR)
Variable Char    VALEUR()

If [F:BPR]BPRNUM<>[M:SCO0]BPRNUM
  Read [BPR] BPR0=[M:SCO0]BPRNUM
  If fstat Raz [F:BPR] : Endif
Endif
If [F:BPR]BETFCY=2 & [F:BPR]FCY= VALEUR
  GMESSAGE = mess(588,194,1)
  mkstat = 2 : End
Endif

End


