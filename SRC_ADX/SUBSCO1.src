#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# SCO1 => 1er onglet: Article lancé (un seul pour le moment)
######################################################################################

$ACTION
Case ACTION
 When "AB6_NBLIG"     : Return
 When "AB1_BPAADD"    : Gosub AB1_BPAADD # Issue 86493 GA 01/2013
 When "BB1_BPAADD"    : Gosub BB1_BPAADD # Issue 86493 GA 01/2013
 When "SUPLIG"        : Gosub SUPLIG
 When "AAS_QTYPUU"    : Gosub AAS_QTYPUU
 When "BAS_QTYPUU"    : Gosub BAS_QTYPUU
 # When Default       : Infbox "SUBSCO1: action "-ACTION
Endcase
Return

########################################################################
$OUVRE
Global Integer IMODIF
Return

########################################################################
$FERME
Return

########################################################################
$APRES_MODIF
IMODIF=1
Return

########################################################################
## Action technique de définition du filtre de lecture
$DEFLIG
FICLIG = "SCOITM" : ABLIG = "SCI"
Return

########################################################################
$RAZCRE
#----------------------------#
# Initialisation de la ligne #
#----------------------------#
# clé: cf INICRE_LIG à la validation
#
# Issue 83440 GA 11/2012 site de réception ?
# Site de réception = Site de commande par défaut (ssi site de stockage)
#[M:SCO1]PRHFCY = [M:SCO0]POHFCY
If [F:FCY]FCY<>[M:SCO0]POHFCY
   Read [FCY]FCY0=[M:SCO0]POHFCY
   If fstat Raz [F:FCY] Endif
Endif
# Issue 88046 GA 02/2014 ne pas pré-affecter le site de réception
#If [F:FCY]WRHFLG=2 & [M:SCO1]PRHFCY="" [M:SCO1]PRHFCY=[M:SCO0]POHFCY Endif
#
[M:SCO1]PIO    = 1
#
Case [F:PTR]SCOSTA
   When 1  :  [M:SCO1]SCOSTA = 2 : Grizo [M:SCO1]SCOSTA
   When 2  :  [M:SCO1]SCOSTA = 1 : Grizo [M:SCO1]SCOSTA
   #When Default :  Gosub SCO_SCOSTA_DEF From SCOLIB  # FQ 54052 il manquait le When
   When Default :  Gosub SCO_SCOSTA_INI From SCOLIB   # FQ 54211 statut Ferme par défaut
Endcase
Gosub SCI_ITMSTA_DEF From SCOLIB
#
If [M:SCO1]ORDDAT=[0/0/0] [M:SCO1]ORDDAT=date$ Endif # FQ 74682

#----- Chargement comptes et sections analytiques -----#
#Call CHARG_SCI_CPTANALIN(-1) From SCOCPTLIB # Issue 91501 GA 08/2013
#-----
Actzo [M:SCO1]ITMSTA, QTYPUU, PUU
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque : sections [M:SCO1]25
Affzo [M:SCO1]5 : Affzo [M:SCO1]10 : Affzo [M:SCO1]15

# Issue X3-69383 - 2018-05-04 by MUARN : axe affiché
If dim([M:SCO1]FMTDIE)>0
  For I = 0 To dim([M:SCO1]FMTDIE)-1
    If [M:SCO1]FMTDIE(I)<>""
      If instr(1,[M:SCO1]FMTDIE(I),"P") >0
        Diszo [M:SCO1]CCE(I)
      Else
        Actzo [M:SCO1]CCE(I)
      Endif
    Else
      Actzo [M:SCO1]CCE(I)
    Endif
  Next I
Endif

Return

########################################################################
$RAZDUP
# appelé par RAZDUP de SUBSCOA
[M:SCO1]POHNUM=""
[M:SCO1]POPLIN=0
[M:SCO1]POQSEQ=0
[M:SCO1]WIPNUM=""
Gosub SCI_ITMSTA_DEF From SCOLIB
Case [F:PTR]SCOSTA
   When 1  :  [M:SCO1]SCOSTA = 2
   When 2  :  [M:SCO1]SCOSTA = 1
   #When Default :  Gosub SCO_SCOSTA_DEF From SCOLIB  # FQ 54052 il manquait le When
   When Default :  Gosub SCO_SCOSTA_INI From SCOLIB   # FQ 54211 statut Ferme par défaut
Endcase
[M:SCO1]WIPTYP=13 : # Encours EO* (sinon on reste sur POF)
[M:SCO1]WIPSTA=[M:SCO1]SCOSTA
[M:SCO1]ALLSTA=1                       # FQ 51325 avant 0
[M:SCO1]RMNEXTQTY=[M:SCO1]EXTQTY
[M:SCO1]ORDQTY=0                       # FQ 51325
[M:SCO1]CPLQTY=0
[M:SCO1]REJCPLQTY=0
[M:SCO1]QUACPLQTY=0
[M:SCO1]INVQTY=0
[M:SCO1]OVRALLNBR=0
[M:SCO1]DETALLNBR=0
[M:SCO1]SHTMATNBR=0
[M:SCO1]MATCLENBR=0
[M:SCO1]OPECLENBR=0
[M:SCO1]ITMCLENBR=0
If dim([M:SCO1]PECFLG)>0 : [M:SCO1]PECFLG=1 : Endif # Issue 87160 - 2013-01-14 by CCC
Raz [M:SCO1]RETDAT,[M:SCO1]CLODAT      # FQ 54052 + raz de CLODAT
Raz [M:SCO1]UPDDAT,[M:SCO1]UPDUSR      # FQ 51325
Raz [M:SCO1]CREDAT,[M:SCO1]CREUSR      # Maj par WRITE_SCI From SCOLIB
Actzo [SCO1]ORDDAT
If [M:SCO1]ORDDAT<date$   # FQ 52864
   [M:SCO1]ORDDAT=date$ : Affzo [M:SCO1]ORDDAT
Endif
[M:SCO1]OLDCUR=[M:SCO1]CUR
Call CONTDEV([M:SCO1]CUR,[M:SCO1]ORDDAT) From TRTDEV
If mkstat
  Raz GMESSAGE, mkstat
Endif
Actzo [M:SCO1]ITMSTA, QTYPUU, PUU
# Issue 107513/US2 GA 06/2015 : ECC management ?
If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0
   If [M:SCO0]ITMREF<>[F:ITM]ITMREF
     Read [ITM]ITM0=[M:SCO0]ITMREF : If fstat Raz [F:ITM] Endif
   Endif
   If [F:ITM]ECCFLG=2
      Actzo [M:SCO0]ECCVALMAJ,ECCVALMIN
   Endif
Endif
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
Affzo [M:SCO1]1-99

# Issue X3-69383 - 2018-05-04 by MUARN : axe affiché
If dim([M:SCO1]FMTDIE)>0
  For I = 0 To dim([M:SCO1]FMTDIE)-1
    If [M:SCO1]FMTDIE(I)<>""
      If instr(1,[M:SCO1]FMTDIE(I),"P") >0
        Diszo [M:SCO1]CCE(I)
      Else
        Actzo [M:SCO1]CCE(I)
      Endif
    Else
      Actzo [M:SCO1]CCE(I)
    Endif
  Next I
Endif

Return


###########################################################################
$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
# Insertion d'une nouvelle ligne: on renseigne toute la clé
  [F:SCI]SCONUM  = [M:SCO0]SCONUM
  [M:SCO1]SCILIN = 1000            : # un seul article par ordre pour commencer ...
  [F:SCI]SCILIN  = [M:SCO1]SCILIN
  [F:SCI]ITMREF  = [M:SCO0]ITMREF
  [F:SCI]BOMALT  = [M:SCO0]BOMALT
#
  [F:SCI]RMNEXTQTY=[M:SCO1]EXTQTY
#
  If [F:SCI]CPY = ""
     [F:SCI]CPY = GSOCIETE
  Endif
#
Return

###########################################################################
$INIMOD_LIG
#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
Return


###########################################################################
# appel en VERIF_CRE et VERIF_MOD sur l'objet SCO
$VERIF
Raz GMESSAGE

# Issue 86437 GA 12/2012
If [M:SCO1]PRHFCY<>[M:SCO0]POHFCY
  If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
  If clalev([F:FCY2]) = 0 : Local File FACILITY   [FCY2] : Endif
  Read [FCY1]FCY0=[M:SCO0]POHFCY : If fstat : Raz [F:FCY1] : Endif
  Read [FCY2]FCY0=[M:SCO1]PRHFCY : If fstat : Raz [F:FCY2] : Endif
  If [F:FCY1]LEGCPY<>[F:FCY2]LEGCPY
     # Le site n'est pas sur la même société juridique
     GMESSAGE=[F:FCY1]FCY-"/"-[F:FCY2]FCY-mess(2,194,1)-[F:FCY1]LEGCPY-"/"-[F:FCY2]LEGCPY
     If [F:PTR]RCPFCYCOD=1 zonsui="[M:SCO1]PRHFCY" Else zonsui="[M:SCO0]POHFCY"Endif
     GERR=1 : mkstat=1 : Return
  Endif
Endif

# Contrôles communs création/modification
Gosub COMPLETE_LIG
# Issue X3-55891 - 2018-09-20 by MUARN : exploitation table article/site/fournisseur
If GERR=1 : Return : Endif

# Ctrl Nomenc de sous-traitance
Local Integer WBOMALT : WBOMALT=[M:SCO0]BOMALT
Local Date WDAT
If [M:SCO1]ORDDAT=[0/0/0]    WDAT=date$
Else                         WDAT=[M:SCO1]ORDDAT
Endif
Call CONTSCONOM([M:SCO1]PRHFCY,WBOMALT,WDAT,1) From SUBSCO
If GMESSAGE<>"" mkstat=1 : zonsui="[M:SCO0]BOMALT" : GERR=1 : Return : Endif

If [M:SCO1]ORDDAT > [M:SCO1]RETDAT
   GMESSAGE = mess(106,177,1) : # La date de fin d'opération ne peut pas être inférieure à la date de début.
   zonsui="[M:SCO1]RETDAT"
   GERR=1 : mkstat=1 : Return
Endif
# FQ 67864 GA 10/2010 ne pas faire ce contrôle
#If find(GREP,"C","D") & [M:SCO1]ORDDAT < date$
#   GMESSAGE = mess(114,199,1) : # La date ne doit pas être antérieure à la date du jour
#   zonsui="[M:SCO1]ORDDAT "
#   GERR=1 : mkstat=1 : Return
#Endif
If [M:SCO1]RETDAT = [0/0/0]
   # Issue 113031 - 2016-02-16 by MUARN : ajout nom zone
   GMESSAGE = mess(1,762,1) - " : " - mess(547,194,1) - "(RETDAT)" : # Saisie obligatoire (RETDAT)
   zonsui="[M:SCO1]RETDAT"
   GERR=1 : mkstat=1 : Return
Endif
If [M:SCO1]QTYPUU = 0
   # Issue 113031 - 2016-02-16 by MUARN : ajout nom zone
   GMESSAGE = mess(1,762,1) - " : " - mess(548,194,1) - "(QTYPUU)": # Saisie obligatoire (QTYPUU)
   zonsui="[M:SCO1]QTYPUU"
   GERR=1 : mkstat=1 : Return
Endif
If [M:SCO1]INVFCY="" : [M:SCO1]INVFCY=GFINRSP: Endif

# Issue 85534 GA 11/2012 ctrl à (re)faire sur site de rcp
# contrôle article/site
Local Char WITMREF(GLONITM): WITMREF=[M:SCO0]ITMREF
Local Char WFCY   (GLONFCY) : WFCY=[M:SCO1]PRHFCY
Gosub READ_ITM From ITMLIB
Gosub READ_ITF From ITMLIB
If GOK=-1
   GMESSAGE=mess(139,197,1)-WITMREF-WFCY
   If [F:PTR]RCPFCYCOD=1 zonsui="[M:SCO1]PRHFCY" Endif
   GERR=1 : mkstat=1 : Return
Endif

# Issue 113031 - 2016-02-16 by MUARN : suppression mode de saisie
# Issue 84534 GA 11/2012 obligatoire pour générer commande achat
#If [M:SCO1]BPAADD = "" &  [F:PTR]SCOADDCOD<3
If [M:SCO1]BPAADD = ""
   # Issue 113031 - 2016-02-16 by MUARN : ajout nom zone
   GMESSAGE = mess(1,762,1) - " : " - mess(549,194,1) - "(BPAADD)": # Saisie obligatoire (BPAADD)
   If [F:PTR]SCOADDCOD=1 zonsui="[M:SCO1]BPAADD" Endif
   GERR=1 : mkstat=1 : Return
Endif
# Issue 113031 - 2016-02-16 by MUARN : suppression mode de saisie
# Issue 84534 GA 11/2012 obligatoire pour générer commande achat
#If [M:SCO1]PRHADD = "" & [F:PTR]RCPADDCOD<3
If [M:SCO1]PRHADD = ""
   # Issue 113031 - 2016-02-16 by MUARN : ajout nom zone
   GMESSAGE = mess(1,762,1) - " : " - mess(605,197,1) - "(PRHADD)": # Saisie obligatoire (PRHADD)
   If [F:PTR]RCPADDCOD=1 zonsui="[M:SCO1]PRHADD" Endif
   GERR=1 : mkstat=1 : Return
Endif

# Issue 107513/US2 GA 04/2015 : is ECC version mandatory for this BOM/ITM ?
If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0 & [F:ITM]ECCFLG=2
   If [M:SCO0]ECCVALMAJ="" & ([F:ITM]ECCSTO > 1 | [F:ITM]ECCMAJ<>"")
      GMESSAGE = mess(420,184,1)-"(ECCVALMAJ)" #  # Version majeure ou mineure incorrecte !
      GERR=1 : mkstat=1 : Return
   Endif
   If [M:SCO0]ECCVALMIN="" & ([F:ITM]ECCSTO > 2 | [F:ITM]ECCMIN<>"")
      GMESSAGE = mess(420,184,1)-"(ECCVALMIN)" #  # Version majeure ou mineure incorrecte !
      GERR=1 : mkstat=1 : Return
   Endif
   Raz GMESSAGE
   Call BOMCTRECC([M:SCO0]ITMREF,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,"",0,[M:SCO0]BOMALT,3,[M:SCO1]ORDDAT) From TRTBOM
   If GMESSAGE<>"" : GERR=1 : mkstat=1 : Return : Endif
Endif

Return


###########################################################################
$COMPLETE_LIG
# Issue 88046 GA 02/2014 affectation supprimée en RAZCRE
# Site de réception = Site de commande par défaut (ssi site de stockage)
If [F:FCY]FCY<>[M:SCO0]POHFCY
   Read [FCY]FCY0=[M:SCO0]POHFCY
   If fstat Raz [F:FCY] Endif
Endif
If [F:FCY]WRHFLG=2 & [M:SCO1]PRHFCY="" [M:SCO1]PRHFCY=[M:SCO0]POHFCY Endif

# Récup Adresse Client livré et Emplacement de sous-traitance
If [M:SCO1]BPAADD=""
   # FQ 54554 Adresse du client livré (avant FIND_BPAADD)
   Call FIND_BPDADD ([M:SCO0]BPRNUM,[M:SCO1]BPAADD) From  BPRLIB
   If [M:SCO1]BPAADD<>""
      Call AM_BPAADD([M:SCO1]BPAADD) From SUBSCO1
   Endif
   Affzo [M:SCO1]BPAADD
Endif

#--------------------------------------
# Valorisation de l'article sous-traité
#--------------------------------------
  If [M:SCO1]REFPRI=0 | [M:SCO1]NETPRI=0
     Call UPD_ITM_PRI(0) From SCOLIB
  Endif

  If [M:SCO1]EXTQTY=0   # FQ 73561 GA 05/2011 pb en picking des besoins
     Call AM_QTYPUU([M:SCO1]QTYPUU)
  Endif

# FQ 73732 GA 06/2011
  Gosub CTL_PURMINQTY
  # Issue X3-55891 - 2018-09-20 by MUARN : exploitation table article/site/fournisseur
  If GERR=1 : Return : Endif

  If [M:SCO1]LTI>0 & [M:SCO1]RETDAT=[0/0/0]
    If [M:SCO3]OPEEND=[0/0/0] # date du service prioritaire
        Local    Integer WOFS : WOFS=[M:SCO3]SCOLTI
        Call UPD_SRV_DAT(WOFS,[M:SCO3]OPESTR,[M:SCO3]OPEEND,0) From SCOLIB
        Affzo [M:SCO3]SCOLTI : Affzo [M:SCO3]OPESTR : Affzo [M:SCO3]OPEEND
    Else
        Call UPD_ITM_DAT([M:SCO1]LTI,[M:SCO0]POHFCY,[M:SCO1]ORDDAT,[M:SCO1]RETDAT) From SCOLIB
    Endif
    Affzo [M:SCO1]RETDAT
  Endif

#----- Chargement comptes et sections analytiques -----#
#  Call CHARG_SCI_CPTANALIN(-1) From SCOCPTLIB # Issue 91501 GA 08/2013 Ko écrase valeurs saisies
 Gosub INIT_CCE_SCO1 From SCOCPTLIB

# Issue 107513/US2 GA 04/2015 : ECC version
If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0
   [F:SCI]ECCVALMAJ = [M:SCO0]ECCVALMAJ
   [F:SCI]ECCVALMIN = [M:SCO0]ECCVALMIN
Endif
Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Decimal WDIS
Local Integer WRET
Local Integer I : I=0
Local Integer L
Local Integer WSCILIN : WSCILIN =1000
#
  WOK = 2

# ----
# déjà fait dans SUBSCOA/LIENS
# Raz [M:SCO1]
# ----
  # Issue 85502 GA 11/2012 relire après Solde par exemple
  #If [F:SCI]SCONUM<>[M:SCO0]SCONUM
   # GA 21/07/2005 un seul article pour le moment
     Read [SCI]SCI0=[M:SCO0]SCONUM;WSCILIN
     If fstat : Raz [F:SCI] : WOK=0 : Return : Endif
  #Endif
  [M:SCO1] = [F:SCI]

# Pour Chargement [F:SCO]ORDDAT dans SCO1
  # Issue 85502 GA 11/2012 relire après Solde par exemple
  #If [F:SCO]SCONUM<>[M:SCO0]SCONUM
     Read [SCO]SCO0=[M:SCO0]SCONUM
     If fstat : Raz [F:SCO] : WOK=0 : Return : Endif
  #Endif
  [M:SCO0] = [F:SCO]
  [M:SCO1] = [F:SCO]
#
# Load informations into head screen [M:SCO0]
# Pour Chargement [F:SCI]ITMREF et [F:SCI]BOMALT dans SCO0
# [M:SCO0] = [F:SCI]   !!!! ecrase BPRNUM si non renseigné sur [F:SCI]
  If [M:SCO0]ITMREF<>[F:SCI]ITMREF [M:SCO0]ITMREF = [F:SCI]ITMREF Endif
  If [M:SCO0]BOMALT<>[F:SCI]BOMALT [M:SCO0]BOMALT = [F:SCI]BOMALT Endif
  # Issue 107513/US2 GA 04/2015 : ECC show version for this BOM/ITM
  If func AFNC.ACTIV("ECC") & dim([M:SCO0]ECCVALMAJ)>0
     If [F:SCI]ECCVALMAJ<>"" [M:SCO0]ECCVALMAJ = [F:SCI]ECCVALMAJ Endif
     If [F:SCI]ECCVALMIN<>"" [M:SCO0]ECCVALMIN = [F:SCI]ECCVALMIN Endif
  Endif

  If [F:TBO]BOMALT<>[F:SCI]BOMALT
     Read [TBO]TBO0=3;[F:SCI]BOMALT
     If fstat : Raz [F:TBO] : Endif
  Endif
  # FGR 16/09/2009 : X3SUIVI57824
  #If dim([M:SCO0]TBODES)>0 : [M:SCO0]TBODES = [F:TBO]TBODES : Endif
  If dim([M:SCO0]TBODES)>0 Then
    Call LECTEXTRA([M:SCO0]TBODES,"TABBOMALT","TBODESAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
  Endif

  # V6 Règle d'affectation
  [M:SCO1]PTOCOD = func ITMLIB.GET_PTOCOD([M:SCO0]ITMREF,[M:SCO0]POHFCY)

# Ctrl présence d'une ligne POF
  Call FIND_POF

# Pas de saisie possible ITMSTA si statut différent de
#     0=
#     1="En attente"
#     2="En-cours"
  If !find([M:SCO1]ITMSTA,0,1,2)
     Diszo [M:SCO1]ITMSTA
  Else
     Actzo [M:SCO1]ITMSTA
  Endif

# Récup Adresse Client livré et Emplacement de sous-traitance
###  If [M:SCO1]BPAADD=""
###     # FQ 54554 Adresse du client livré (avant FIND_BPAADD)
###     Call FIND_BPDADD ([M:SCO0]BPRNUM,[M:SCO1]BPAADD) From  BPRLIB
###     If [M:SCO1]BPAADD<>""
###        Call AM_BPAADD([M:SCO1]BPAADD) From SUBSCO1
###     Endif
###  Endif
###  Affzo [M:SCO1]BPAADD

# Libellé Adresse Site réception
  If [M:SCO1]PRHADD<>""
     Call AM_PRHADD([M:SCO1]PRHADD) From SUBSCO1
  Endif

  If [M:SCO1]LTI=0
  # -----------------------------------------------
  # Ajustement du délai article sous-traité
  # en tenant compte des délais matières et service
  # -----------------------------------------------
    Local Decimal WLTI,WQUALTI
    Call CALCUL_DELAI([F:SCI]EXTQTY,WLTI,WQUALTI) From SCOLIB
    [M:SCO1]LTI = WLTI+WQUALTI : Affzo [M:SCO1]LTI
  Endif

#-----
#----- Chargement comptes et sections analytiques -----#
  Call CHARG_SCI_CPTANALIN(-1) From SCOCPTLIB
#-----

# Type de Maj autorisée sur l'EO (Menu local 332): modifs autorisées ou non sur Matières et Service
  If dim([M:SCO1]EORTYP)>0 & dim(GDEFEORTYP)>0
     [M:SCO1]EORTYP=GDEFEORTYP
  Endif
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
  Affzo [M:SCO1]1-99

# Issue X3-69383 - 2018-05-04 by MUARN : axe affiché
If dim([M:SCO1]FMTDIE)>0
  For I = 0 To dim([M:SCO1]FMTDIE)-1
    If [M:SCO1]FMTDIE(I)<>""
      If instr(1,[M:SCO1]FMTDIE(I),"P") >0
        Diszo [M:SCO1]CCE(I)
      Else
        Actzo [M:SCO1]CCE(I)
      Endif
    Else
      Actzo [M:SCO1]CCE(I)
    Endif
  Next I
Endif
Return

#########################################################################
## Modification des lignes
#########################################################################
$MODIF
Local Integer I
Local Integer J : J=0
Local Integer WRETOUR,K
#Local Char    WNUMTEX (12)
Local Integer L         : # pour sections analytiques
Local Integer KLIN
Local Integer WEXISTE
Local Char    WTRTLIG(1) : WTRTLIG="M"
#
#Gosub DEFLIG
### GA 21/07/2005 un seul article pour le moment
    Readlock [SCI]SCI0=[M:SCO0]SCONUM;[M:SCO1]SCILIN
    If fstat=1 : GOK=-1 : GLOCK="$SCOITM" : Return : Endif
    WEXISTE = fstat
#
   [F:SCI] = [M:SCO0]
   [F:SCI] = [M:SCO1]
#
   If    WEXISTE=0
       # Maj d'une ligne
        Gosub INIMOD_LIG

      # Texte
        Call UPDATE_SCOTEX("M")
#
      # création/màj de l'encours EOx + maj de la référence dans [F:SCI]
        Call UPDATE_EOX ("M") From SCOLIB
      #
      #----- Ecriture des comptes et sections de la ligne de document -----#
        Call UPDATE_SCI_CPTANALIN ("M") From SCOCPTLIB : If GOK<1  Return : Endif

        Gosub REWRITE_SCI From SCOLIB
        If GOK<1 : Return : Endif
#
   Elsif WEXISTE = 5
       # Insertion d'une nouvelle ligne
        Gosub INICRE_LIG
#
      # Texte
        Call UPDATE_SCOTEX("C")
#
      # création de l'encours EOx + maj de la référence dans [F:SCI]
        Call UPDATE_EOX ("C") From SCOLIB
      #
       #----- Ecriture des comptes et sections de la ligne de document -----#
        Call UPDATE_SCI_CPTANALIN ("C") From SCOCPTLIB : If GOK<1  Return : Endif

        Gosub WRITE_SCI From SCOLIB
        If GOK<1 : Return : Endif
#
   Endif
#
Return

#########################################################################
## Insertion de toutes les lignes
#########################################################################
$CREATION
Local Integer I
Local Integer WRETOUR,K
#Local Char WNUMTEX (12)
Local Integer L         : # pour sections analytiques
Local Char    WTRTLIG(1): WTRTLIG   = "C"
#
  Raz [F:SCI]
### GA 21/07/2005 un seul article pour le moment
  [F:SCI] = [M:SCO0] : [F:SCI] = [M:SCO1]
#
  # on s'assure que la Cle soit entièrement renseignée
  Gosub INICRE_LIG
#
# Texte
  Call UPDATE_SCOTEX("C")
#
# création/màj de l'encours EOx
  Call UPDATE_EOX ("C") From SCOLIB
  If GOK<1 : Return : Endif   # Issue 88058 GA 02/2013

#----- Ecriture des comptes et sections de la ligne de document -----#
  Call UPDATE_SCI_CPTANALIN ("C") From SCOCPTLIB : If GOK<1  Return : Endif

  Gosub WRITE_SCI From SCOLIB
#
Return
$ERR_CREATION
#Raz [M:SCO0]SCONUM
Return

#########################################################################
## Annulation de toutes les lignes
#########################################################################
$ANNULE
Local Integer WRET
### GA 21/07/2005 un seul article pour le moment
For [SCI]SCI0 Where SCONUM=[M:SCO0]SCONUM With Lock
#
# Texte
  Call UPDATE_SCOTEX("A")
#
#----- Suppression des comptes et sections de la ligne de document -----#
# ne pas planter en cas d'erreur
  Call UPDATE_SCI_CPTANALIN ("A") From SCOCPTLIB
#
  Gosub DELETE_SCI From SCOLIB
  If GOK < 1 : Break : Endif
Next
Return

$SUPLIG
#-----------------------------------------------------------#
# Avant Delete ou Rewrite de la ligne                       #
#-----------------------------------------------------------#
# not used ????
Return


Subprog AS_ORDDAT(VALEUR)
#-------------------------------------------#
# avant saisie de la date de commande       #
#-------------------------------------------#
Variable Date    VALEUR
If VALEUR = [0/0/0]
   VALEUR = date$
   # FQ 58266 If [M:SCO1]LTI>0
   If [M:SCO1]LTI>0 & [M:SCO1]RETDAT = [0/0/0]
    # Issue 82748 GA 06/2012 selon 77115
    # Call CALC_DAT_FCY(VALEUR,[M:SCO1]LTI,[M:SCO1]PRHFCY,0,[M:SCO1]RETDAT) From TRTACHDAT
    Local Decimal  WOFS : WOFS=[M:SCO1]LTI
    Local Integer  WCOR : WCOR=8  # Arrondi date
    Local Integer  WCOD : WCOD=1  # 1=délai achat en jours calendaires, 2=délai fab en jours ouvrés (???)
    Local Shortint WUPD : WUPD=0  # flag recalcul enddat
    Local Decimal  WCAP(31)
    Local Date     WCALDATD : Raz WCALDATD
    Local Date     WDATR :    WDATR = date$
    Call CALDAT("+",WCOR,WDATR,WCOD,WOFS,WCAP,WCALDATD,WDATR) From CBNLIB
    [M:SCO1]RETDAT = WDATR
     Affzo [M:SCO1]RETDAT
   Endif
Endif
End

