Subprog AM_PRHFCY(VALEUR)
Variable Char    VALEUR

Raz GMESSAGE
# Issue 86437 GA 12/2012
If VALEUR<>[M:SCO0]POHFCY
  If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
  If clalev([F:FCY2]) = 0 : Local File FACILITY   [FCY2] : Endif
  Read [FCY1]FCY0=[M:SCO0]POHFCY : If fstat : Raz [F:FCY1] : Endif
  Read [FCY2]FCY0=VALEUR         : If fstat : Raz [F:FCY2] : Endif
  If [F:FCY1]LEGCPY<>[F:FCY2]LEGCPY
     # Le site n'est pas sur la même société juridique
     GMESSAGE=[F:FCY1]FCY-"/"-[F:FCY2]FCY-mess(2,194,1)-[F:FCY1]LEGCPY-"/"-[F:FCY2]LEGCPY
     # Issue 86768 GA 12/2012
     #mkstat=2 : End
     Local Integer  WOK : WOK=2
     # Issue X3-95319 - 2018-06-20 by MUARN : message d'erreur non avertissement
     #WOK=2 : Call AVERTIR(GMESSAGE,WOK) From GESECRAN
     #Raz GMESSAGE : If WOK=1 : mkstat=2 : End : Endif
     Call ERREUR(GMESSAGE) From GESECRAN
     Raz GMESSAGE : mkstat=1 : End
  Endif
Endif

# Issue 86439 GA 12/2012 revérifier validité alternative de nomenclature
If [F:TBO]BOMALT<>[M:SCO0]BOMALT
   Read [TBO]TBO0=3;[M:SCO0]BOMALT
   If fstat Raz [F:TBO] Endif
Endif
If [F:TBO]FCY<>"" & [F:TBO]FCY<>VALEUR
  If !find(GREP,"C","D")    # Alternative non valide sur ce site !
    # Modification article ou nomenclature, veuillez supprimer puis recréer votre ordre de sous-traitance.
     GMESSAGE= mess(48,193,1)-"\"-mess(362,194,1)
     mkstat=2 : End
  Else
     GMESSAGE= mess(48,193,1)
     mkstat=2 : End
  Endif
Endif

# Issue 83440 GA 11/2012 Nomenclature existante et valide ?
Read [FCY]FCY0=VALEUR
If fstat Raz [F:FCY] : mkstat=2 : End : Endif
If [F:FCY]WRHFLG=2
    # Ctrl Nomenc de sous-traitance
    Local Integer WBOMALT : WBOMALT=[M:SCO0]BOMALT
    Local Date WDAT
    If [M:SCO1]ORDDAT=[0/0/0]    WDAT=date$
    Else                         WDAT=[M:SCO1]ORDDAT
    Endif
    Call CONTSCONOM(VALEUR,WBOMALT,WDAT,1) From SUBSCO
    If GMESSAGE<>"" mkstat=2 : End : Endif # Issue 86437 GA 12/2012
Endif

If VALEUR<>""
  # Changement de site, on vide les infos
  Raz [M:SCO1]PRHADD : Raz[M:SCO1]PRHADDDES
  Raz [M:SCO1]LOC
Endif
#
# Issue 85534 GA 11/2012 ctrl à (re)faire sur site de rcp
# contrôle article/site
Local Char WITMREF(GLONITM): WITMREF=[M:SCO0]ITMREF
Local Char WFCY   (GLONFCY): WFCY=VALEUR
Gosub READ_ITF From ITMLIB
If GOK=-1 : GOK=1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : mkstat=2 : End : Endif

# Issue 84534 GA 11/2012
Call FIND_PRHFCY ([M:SCO0]POHFCY,[M:SCO0]BPRNUM,[M:SCO1]BPAADD,[M:SCO1]MFGFCY,VALEUR,[M:SCO1]PRHADD,[M:SCO1]LOC) From SCOLIB
Affzo [M:SCO1]BPAADD : Affzo [M:SCO1]MFGFCY : Affzo [M:SCO1]PRHFCY : Affzo [M:SCO1]PRHADD : Affzo [M:SCO1]LOC

# (re)contrôle de l'article-site pour le Service SCOSRV
If clalev([M:SCO3])>0
  [M:SCO3]PRHFCY = VALEUR : Affzo [M:SCO3]PRHFCY
  If dim([M:SCO3]ZPRHFCY)>0 : Affzo [SCO3]ZPRHFCY : Endif : # GH 18/09/2013 bug 91978

  If [M:SCO3]SRVITMREF<>""
    # contrôle article/site
    Local Char WITMREF(GLONITM): WITMREF=[M:SCO3]SRVITMREF
    Local Char WFCY   (GLONFCY): WFCY=VALEUR
    Gosub READ_ITF From ITMLIB
    If GOK=-1 : GOK=1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : mkstat=2 : End : Endif

  # Issue 84534 GA 11/2012 utiliser plutôt FIND_PRHFCY (cf + haut)
###    # Issue 85539 - 2012-11-05 by CCC : Si modif du site => recherche adresse & emplacement
###    If clalev ([F:BPD])=0  Local File BPDLVCUST   [BPD] : Endif
###    Filter [BPD] Where STOFCY=VALEUR
###&                    & BPCNUM=[M:SCO0]BPRNUM
###    Read [BPD] First
###    Filter [BPD]
###    If fstat | [F:BPD]SCOLOC=""
###        mkstat=2
###        End
###    Endif
###    [M:SCO1]BPAADD = [F:BPD]BPAADD
###    [M:SCO1]LOC    = [F:BPD]SCOLOC


    # Issue 83440 GA 11/2012 code déplacé
    #Call AM_PRHFCY(VALEUR) From SUBSCO3
    OMODIF = 1
    # Issue 81641 GA 08/2012 proposer maj site/emplacement des composants
    If !GIMPORT
      Local    Integer  WRET : WRET = 2
      Call OUINON(mess(429,194,1),WRET) From GESECRAN
      If WRET=2
        #--------------------------------------
        # Maj site/emplacement pour les matières
        #--------------------------------------
        Default Mask [SCO2]
        For I=0 To [M:SCO2]NBLIG-1
          nolign=I+1
          # Issue 85539 - 2012-11-05 by CCC
          #Call UPD_MAT_FCY(VALEUR,I) From SCOLIB
          Call UPD_MAT_FCY2(VALEUR,[M:SCO1]LOC,I) From SCOLIB
          If GOK<>1
             Raz [M:SCO2]STOFCY(I) : Raz [M:SCO2]LOC(I)
             If GMESSAGE<>""
                Call MESSAGE(GMESSAGE) From GESECRAN
                Raz GMESSAGE
                Break
             Endif
          Endif
        Next
        # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
        Affzo [SCO2]1-99
      Endif
    Endif
  Endif
Endif
End

######################################################################################

Subprog AS_RETDAT(VALEUR)
#-------------------------------------------#
# proposer une date de réception            #
#-------------------------------------------#
Variable Date     VALEUR
If [M:SCO1]LTI<>0 & VALEUR = [0/0/0] & [M:SCO1]ORDDAT<>[0/0/0]
   Call UPD_ITM_DAT([M:SCO1]LTI,[M:SCO0]POHFCY,[M:SCO1]ORDDAT,VALEUR) From SCOLIB
Endif
End

######################################################################################
Subprog AM_RETDAT(VALEUR)
Variable Date    VALEUR
Local Integer I
# FQ 67864 GA 10/2010 ne pas faire ce contrôle
# antériorité par rapport à la date du jour ?
# Call CHECK_PAST(VALEUR, 2) From MFGLIB

If clalev([M:SCO3])>0 & clalev([M:SCO2])>0

 # cela détermine la date de fin de l'opération de sous-traitance
 # qui permet de calculer [M:SCO3]OPESTR et [M:SCO2]DVLDAT(nolign-1)
 If VALEUR<>[0/0/0] & ([M:SCO3]OPEEND=[0/0/0] | [M:SCO3]OPEEND<>VALEUR )
 #
   # Issue 107513 - 2015-06-22 by GA : ECC for EO - use local variables
   Local Date WOPESTR : WOPESTR=[0/0/0]
   Local Date WOPEEND : WOPEEND=VALEUR
   #Raz [M:SCO3]OPESTR
   #[M:SCO3]OPEEND = VALEUR
   [M:SCO1]RETDAT = VALEUR  # pour éviter message "Date de réception reportée au" dans UPD_SRV_DAT
   Local Integer WOFS : WOFS=[M:SCO3]SCOLTI
   Call UPD_SRV_DAT(WOFS,WOPESTR,WOPEEND,0) From SCOLIB
   [M:SCO3]OPESTR = WOPESTR
   [M:SCO3]OPEEND = WOPEEND
   # Issue 87038 GA 01/2013 performances
   #Affzo [M:SCO3]SCOLTI,OPESTR,OPEEND
 #
 # reCalcul date livraison des matières (si elles sont fournies au sous-traitant)
   For I=0 To [M:SCO2]NBLIG-1
     WOFS = [M:SCO2]BOMOFS(I)
     Call UPD_MAT_DAT(WOPESTR,WOPEEND,[M:SCO2]STOFCY(I),WOFS,[M:SCO2]DLVDAT(I)) From SCOLIB
     # Issue 87038 GA 01/2013 performances
     #Affzo [M:SCO2]DLVDAT(I)
   Next
 Endif
 # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
 # Issue 87038 GA 01/2013 performances
 Affzo [M:SCO2]1-99 : Affzo [M:SCO3]1-99
Endif
End

Subprog C_RETDAT(VALEUR)
Variable Date    VALEUR
#
# Saisie obligatoire: vérifié + tard
# FQ 66569 GA 09/2010 ne pas tenir compte des schémas hebdomadaires sur achats de sous-traitance
#                     ctrl remplacé par l'action CTLJOU2 sur le champ

# Issue 107513 by GA 08/2015 : ECC for EO
Local Date WOPESTR
Local Date WOPEEND
Local Integer WOFS

If VALEUR<>[M:SCO1]RETDAT
    # Issue 115211 - 2016-03-23 by BAKHA/CCC : control if new start date is not in the past
    Call CTLRCPDAT(VALEUR,[M:SCO1]LTI)
    If mkstat=2
        End
    Endif

    WOPESTR=[0/0/0]
    WOPEEND=VALEUR
    WOFS=[M:SCO1]LTI
    Call CALSTRDAT(WOFS, WOPESTR, WOPEEND) From SCOLIB
Else
    WOPESTR=[M:SCO1]ORDDAT
Endif

If dim([M:SCO0]ECCVALMAJ)>0 & [M:SCO0]ECCVALMAJ<>""
    If clalev([F:EVL])=0 : Local File ECCVAL [EVL] : Endif
    Call CTRECC([M:SCO0]ITMREF,"SCO0","ORDDAT",[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,
&               WOPESTR,GERR,GMESSAGE) From ECCLIB

    If find(GERR,1,4)
        GERR = min(1,GERR)
        mkstat=2
        End
    Else
        GOK=1 : Raz GERR
    Endif
Endif

End

# Issue 115211 - if receipt date is changed, calculate start date and
#                reject receipt date if start date in past
#                Control done in screens SCO1 and SCO3
Subprog CTLRCPDAT(PENDDAT,PLTI)
Value Date PENDDAT
Value Integer PLTI

Local Decimal  WOFS
Local Integer  WCOR : WCOR=8  #  correction calender
Local Integer  WCOD : WCOD=1  # 1=purchase period in calender days
Local Shortint WUPD : WUPD=0  # flag recalculate end date
Local Decimal  WCAP(31)
Local Date     WCALDATD : Raz WCALDATD
Local Date     WOPESTR
Local Date     WOPEEND

If PENDDAT<>[0/0/0] and PLTI>0
    #  Calculate start date
    WOFS=PLTI
    WOPEEND=PENDDAT
    Call CALDAT("-",WCOR,WOPEEND,WCOD,WOFS,WCAP,WCALDATD,WOPESTR) From CBNLIB
    #if start date in past, return error
    If WOPESTR<date$
        WOPESTR=date$
        Call CALDAT("+",WCOR,WOPESTR,WCOD,WOFS,WCAP,WCALDATD,WOPEEND) From CBNLIB
        GMESSAGE=mess(550,194,1)+"\"+mess(364,200,1)-format$("D:"+GFMDAT,WOPEEND)
        mkstat=2
        End
    Endif
Endif
End
# End issue 115211

######################################################################################
# Issue 87160 - 2013-01-14 by CCC
$AAS_QTYPUU
If dim([M:SCO1]PECFLG)>0 & [M:SCO1]PECFLG<>2
    If !find(GREP,"C","D")
        [M:SCO1]PECFLG=2
    Endif
Endif
Return

######################################################################################
# Issue 87160 - 2013-01-14 by CCC
$BAS_QTYPUU
If dim([M:SCO1]PECFLG)>0 : [M:SCO1]PECFLG=2 : Endif
Return

Subprog C_QTYPUU(VALEUR)
#----------------------------#
# Contrôle quantité commande #
#----------------------------#
Variable Decimal VALEUR
Local    Decimal  WQTE,WCOEF
# FQ 62179 GA 02/2010
Call UPD_ITM_QTY(2,[M:SCO1]PUU,VALEUR,[M:SCO1]STU,WQTE,WCOEF,0) From SCOLIB
If WQTE<>[M:SCO1]EXTQTY
   [M:SCO1]EXTQTY=WQTE
   Affzo [M:SCO1]EXTQTY
Endif
End

Subprog AM_QTYPUU(VALEUR)
#--------------------------------#
# Après modif de la qté commande #
#--------------------------------#
Variable Decimal  VALEUR
Local    Decimal  WQTE,WCOEF
Local    Integer  WOK : WOK=2
Local    Decimal WFRCQTY
Local    Integer OK

Raz GMESSAGE
[M:SCO1]QTYPUU=VALEUR      : # pour CTL_PURMINQTY
Gosub CTL_PURMINQTY
If GMESSAGE<>"" | mkstat : mkstat=2 : Goto FINQTYPUU : Endif
Call UPD_ITM_QTY(2,[M:SCO1]PUU,VALEUR,[M:SCO1]STU,[M:SCO1]EXTQTY,WCOEF,0) From SCOLIB
Affzo [M:SCO1]EXTQTY

#-----
If !GIMPORT Affzo [SCO1]PUUSTUCOE,QTYPUU,EXTQTY : Endif
#----- Avertissement si qté cdée inférieure à la qté réceptionnée -----#
If [M:SCO1]EXTQTY<[M:SCO1]CPLQTY
  WOK=2 : Call AVERTIR(mess(170,194,1)-format$("N:15F",[M:SCO1]CPLQTY)
&                   -[M:SCO1]STU,WOK) From GESECRAN
  If WOK=1 mkstat=1 : Goto FINQTYPUU : Endif
Endif
If [M:SCO1]EXTQTY > [M:SCO1]CPLQTY
   [M:SCO1]RMNEXTQTY = [M:SCO1]EXTQTY - [M:SCO1]CPLQTY
Else
   [M:SCO1]RMNEXTQTY = 0
Endif

If !find(GREP,"C","D")
    Call GET_FRCQTY([M:SCO1]PRHFCY, [M:SCO0]ITMREF, 36, [M:SCO0]SCONUM, [M:SCO1]SCILIN, 0, 13, WFRCQTY) From MTOLINKLIB
    If ([M:SCO1]EXTQTY - [M:SCO1]CPLQTY) < WFRCQTY
        # lecture règle si nécessaire
        If [F:PTO]PTOCOD <> [M:SCO1]PTOCOD
            Read [F:PTO]PTO0=[M:SCO1]PTOCOD
            If fstat : Raz [PTO] : Endif
        Endif
        If [F:PTO]FRCPRO <> 2
            OK=1
            Call OUINON(mess(228,190,1), OK) From GESECRAN
            If OK <> 2 : VALEUR = [M:SCO1]QTYPUU : mkstat = 2 : End : Endif
        Endif
    Endif
Endif
#
#--------------------------------------
# Prix pour l'article sous-traité
#--------------------------------------
Call UPD_ITM_PRI(0) From SCOLIB

If clalev([M:SCO3])>0 &  clalev([M:SCO2])>0

  #--------------------------------------
  # Qté/Prix pour le service
  #--------------------------------------
  Default Mask [SCO3]
  Local    Decimal  WEXTSTRQTY_SCS : WEXTSTRQTY_SCS = [M:SCO3]EXTSTRQTY
  Call UPD_SRV_QTY([M:SCO1]EXTQTY,[M:SCO3]OPESTU,[M:SCO3]SCOPUU,0) From SCOLIB
  #----- Prix & Montant ligne -----# Issue 87680 GA 07/2013 Poser la question, sauf si ancienne valeur était à 0
  If WEXTSTRQTY_SCS<>[M:SCO3]EXTSTRQTY & [M:SCO3]NETPRI<>0
    Local Integer OK
    OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
    If OK=2
      Call UPD_SRV_PRI(0) From SCOLIB
    Else
      Gosub CALC_LINAMT_SCO3 From SCOLIB
    Endif
  Else
    Call UPD_SRV_PRI(0) From SCOLIB
  Endif

  # Issue 95452 GA 12/2013 réafficher prix/qté calculés
  # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
  #Affzo [SCO3]
  Affzo [M:SCO3]EXTSTRQTY : Affzo [M:SCO3]NETPRI

  #--------------------------------------
  # Qté/Prix pour les matières
  #--------------------------------------
  Default Mask [SCO2]
  For I=0 To [M:SCO2]NBLIG-1
    nolign=I+1
    Call UPD_MAT_QTY([M:SCO1]EXTQTY, I) From SCOLIB
    Call UPD_MAT_PRI(I) From SCOLIB
  Next
  # Issue 95452 GA 12/2013 réafficher prix/qté calculés
  # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
  #Affzo [SCO2]
  # Issue X3-74812-25003 - 2018-02-01 by SR : Affzo avec rang ne valide pas le masque et affiche tout ce qu'il faut
  #Affzo [M:SCO2]RETQTY : Affzo [M:SCO2]NETPRI  : Affzo [M:SCO2]MATSTA
  Affzo [M:SCO2]1-99

Endif


#-------------------------------------
Default Mask [SCO1]
[M:SCO1]QTYPUU=VALEUR
#----- Restauration nolign -----#
$FINQTYPUU
End

######################################################################################
Subprog C_INVFCY(VALEUR)
#-----------------------------------#
#     Contrôle site facturation     #
# --------------------------------- #
# Doit appartenir à la même société #
# Juridique que le site de commande #
#-----------------------------------#
Variable Char     VALEUR
If [F:FCY]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=1 : End : Endif
If VALEUR="" & [M:SCO0]BETFCY=2  : mkstat=1 : End : Endif
End

Subprog AM_INVFCY(VALEUR)
#-----------------------------------#
#     Apres-modif site facturation  #
# --------------------------------- #
Variable Char    VALEUR()
If [M:SCO0]BETFCY=2 & [M:SCO1]SALFCY<>""
  Local Char BETINVFCY(GLONFCY)
  [L]BETINVFCY=VALEUR
  Gosub CTRL_BETINVFCY
  If !mkstat
    [M:SCO1]BPCINV=[F:BPC]BPCNUM
    #------ Chargement des éléments de facturation -----#
    #Local Integer NBPOSTE : NBPOSTE=dim([M:POH3]SHO)
    #Call SAISFOOT (3,"POH3",NBPOSTE,[M:SCO1]CHGTYP,[M:SCO1]CUR,GCUR,"OUI") From TRTACHELT1
    #[M:POH3]NBFAC=NBPOSTE : If !GIMPORT Affzo [POH3]10 : Endif
  Endif
Endif
End


$CTRL_BETINVFCY
#-- En inter-sociétés (si facturation)
#--- Contrôle sur le site de facturation qui doit être client
If !clalev([F:BPR2])  Local File BPARTNER  [BPR2] : Endif
Read [BPR2] BPR2(2)=2;[L]BETINVFCY
If fstat  Raz [F:BPR2] : Endif
[G:BPR2]currind=1 : [G:BPR2]currlen=0 : # Réinitialisation clé par défaut
#----- Vérification que le tiers associé au site facture est client -----#
If [F:BPR2]BPCFLG<>2
  GMESSAGE=[L]BETINVFCY-mess(258,194,1) : GERR=1 : mkstat=1 : Return
Endif
#-- En inter-société contrôle du client facture
Call C_BPCINV([F:BPR2]BPRNUM,[M:SCO1]SALFCY) From TRTVENISOC : # Contrôle du client facture
Return

$CHARG_COEFLG
#-----------------------------------------------------------#
# Chargement de l'indicateur de modification du coefficient #
#-----------------------------------------------------------#
  If [M:SCO1]PUU=[F:ITM]PUU
    If [F:ITM]DACPUUCOE=2 : [M:SCO1]COEFLG=0 Else [M:SCO1]COEFLG=1 : Endif
  Else
    [M:SCO1]COEFLG=1
  Endif
Return

