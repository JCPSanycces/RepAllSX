######################################################################################

Subprog AS_PUU(VALEUR)
Variable Char    VALEUR()
If [F:PTR]UOMSAIFLG1=1
 # Saisie de la qté tjs en US
   If VALEUR <> [M:SCO1]STU
      VALEUR =  [M:SCO1]STU
      [M:SCO1]PUUSTUCOE = 1
      Call AM_PUU(VALEUR) : # recalcul de la qté UA
   Endif
   mkstat=2
Elsif [F:PTR]QTYPUUCOD=2  : # Menu local 514 2="Qté saisie sans unité"
 # UA déterminée automatiquement, non modifiable
   mkstat=2
Endif
End

Subprog C_PUU(VALEUR)
#---------------------------------------#
# Contrôle de l'unité pour l'inter-site #
#---------------------------------------#
Variable Char    VALEUR()
#----- contrôle que l'unité d'achat convienne pour le couple article/fournisseur -----#
  Local Char WUOM(GLONUOM) : WUOM=VALEUR
  Call CTLUOM([M:SCO0]ITMREF,1,[M:SCO0]BPRNUM,WUOM,[M:SCO1]PUUSTUCOE,
&             GBIDC2,GBIDC3,GBIDI1) From STKACT
  If mkstat  End : Endif
  Affzo [M:SCO1]PUUSTUCOE
End

Subprog AM_PUU(VALEUR)
Variable Char    VALEUR()
Local    Integer  WOK : WOK=2
Local    Decimal  WQTEUA, WQTEUS, WCOEF
# Calcul Coef et Qté en UA
  Call UPD_ITM_QTY(1,[M:SCO1]STU,[M:SCO1]EXTQTY,VALEUR,WQTEUA,WCOEF,0) From SCOLIB
  [M:SCO1]QTYPUU=WQTEUA   : Affzo [M:SCO1]QTYPUU
  [M:SCO1]PUUSTUCOE=WCOEF : Affzo [M:SCO1]PUUSTUCOE
  [M:SCO1]PUU=VALEUR      : # pour CTL_PURMINQTY
  Gosub CTL_PURMINQTY
  If GMESSAGE<>"" | mkstat : mkstat=1 : End: Endif
# Tarif
  Call UPD_ITM_PRI(0) From SCOLIB
End

Subprog AS_STU(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_STU(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
Subprog AS_PRHADD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:SCO1]PRHFCY<>""
   Call FIND_FCYADD([M:SCO1]PRHFCY,VALEUR) From BPRLIB
Endif
End

Subprog AM_PRHADD(VALEUR)
Variable Char    VALEUR()
Raz [M:SCO1]PRHADDDES : Affzo [M:SCO1]PRHADDDES
If VALEUR <> ""
  Read [F:BPA]BPA0 = 3;[M:SCO1]PRHFCY;VALEUR
  # Adresse inexistante
  If fstat : Raz [F:BPA] : GMESSAGE=VALEUR-mess(529,199,1)-[M:SCO1]PRHFCY : mkstat=1 : End : Endif
  If dim([M:SCO1]PRHADDDES)>0 [M:SCO1]PRHADDDES = [F:BPA]BPADES : Affzo [M:SCO1]PRHADDDES : Endif
Endif
End

######################################################################################
Subprog AS_BPAADD(VALEUR)
Variable Char    VALEUR()
# nécessaire pour le tunnel ?
GBPCNUM = [M:SCO0]BPRNUM
If VALEUR="" & [M:SCO1]MFGFCY<>""
   Call FIND_FCYADD([M:SCO1]MFGFCY,VALEUR) From BPRLIB
Endif
End

######################################################################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char WLOC    (GLONLOC) : WLOC=[M:SCO1]LOC # Issue 95308 GA 01/2014
Local Char WSTOFCY (GLONFCY)
Local Char WRCPFCY (GLONFCY)
Local Char WBPAADD (GLONBPA)
Local Integer WRET

If VALEUR="" : End : Endif
WBPAADD = [M:SCO1]BPAADD # ancienne valeur

# Issue X3-95319 - 2018-08-01 by MUARN : se baser sur BPD et non BPA et contrôler les adresses inactives
## Issue 83847 GA 08/2012 ctl BPAADD
##----- Lecture de l'adresse si nécessaire -----#
#If !clalev([F:BPA])  Local File BPADDRESS [BPA] : Endif
#If [M:SCO1]MFGFCY=""
#  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:SCO0]BPRNUM | [F:BPA]BPAADD<>VALEUR
#    Read [BPA] BPA0=1;[M:SCO0]BPRNUM;VALEUR
#    If fstat
#       Raz [F:BPA]
#    # Adresse inexistante : Fournisseur
#       GMESSAGE=VALEUR-mess(10,119,1)-":"-mess(17,7,1)-[M:SCO0]BPRNUM
#       mkstat=2 : End
#    Endif
#  Endif
#Else
#  If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[M:SCO1]MFGFCY | [F:BPA]BPAADD<>VALEUR
#    Read [BPA] BPA0=3;[M:SCO1]MFGFCY;VALEUR
#    If fstat
#       Raz [F:BPA]
#    # Adresse inexistante pour ce site
#       GMESSAGE=VALEUR-mess(529,199,1)-[M:SCO1]MFGFCY
#       mkstat=2 : End
#    Endif
#  Endif
#Endif
If !clalev([F:BPD])  : Local File BPDLVCUST  [BPD] : Endif
If [F:BPD]BPCNUM <> [M:SCO0]BPRNUM | [F:BPD]BPAADD <> VALEUR
  Read [BPD] BPD0=[M:SCO0]BPRNUM;VALEUR
  If fstat
    Raz [F:BPD]
    GMESSAGE=mess(16,199,1)
    mkstat=2 : End
  Else
    If [F:BPD]ENAFLG=1
      GMESSAGE=mess(702,199,1)
      mkstat=2 : End
    Endif
  Endif
Endif

# End issue X3-95319

#-------------------------------------------
# Emplacement de sous-traitance ?
# WRCPFCY Site de réception du client livré
#       = Site de production
# WSTOFCY Site d'expédition du client livré (sur lequel se trouve l'emplacement sous-traitance)
#       = Site de stockage des matières
#       = Site de réception du produit sous-traité (par défaut)
#-------------------------------------------
  Call FIND_SCOLOC ( [M:SCO0]BPRNUM, VALEUR, WLOC,WRCPFCY,WSTOFCY ) From BPRLIB
  # Issue 95308 GA 01/2014 l'adresse client livré détermine emplacement
  If WLOC<>"" & WLOC<>[M:SCO1]LOC
     [M:SCO1]LOC=WLOC : Affzo [M:SCO1]LOC
  Endif

  If WRCPFCY <> "" & [M:SCO1]MFGFCY="" & [M:SCO0]BETFCY=1
     [M:SCO1]MFGFCY = WRCPFCY
  Endif
#
  # Issue 88814 GA 05/2013 Pouvoir rendre LOC obligatoire (ctrl bloquant sur les matières avec SCOFLG=2)
  #If [M:SCO1]LOC="" & [M:SCO0]BETFCY=2 : # Message uniquement si intersite
  # Issue 95308 GA 01/2014 parenthèses ajoutées sur la condition
  #If [M:SCO1]LOC="" & [M:SCO0]BETFCY=2 | (dim(GEOMLOC)>0 & GEOMLOC=1)
  If [M:SCO1]LOC="" & ([M:SCO0]BETFCY=2 | (dim(GEOMLOC)>0 & GEOMLOC=1))
  # "Pas d'emplacement de sous-traitance pour ce fournisseur: livraison impossible !"
    Call AVERTIR(mess(525,199,1),WRET ) From GESECRAN
    If WRET = 1
        [M:SCO1]BPAADD=WBPAADD : Affzo [M:SCO1]BPAADD : mkstat = 2 : End
    Endif
  Endif

# Issue 85539 - 2012-11-05 by CCC
#  If WSTOFCY <> "" & [M:SCO1]PRHFCY=""
  If WSTOFCY <> "" &  [M:SCO1]PRHFCY <> WSTOFCY
    Call AM_PRHFCY(WSTOFCY) # Issue 86439 GA 12/2012
    If mkstat : [M:SCO1]BPAADD=WBPAADD : Affzo [M:SCO1]BPAADD : mkstat = 2 : End : Endif
    [M:SCO1]PRHFCY = WSTOFCY :  Affzo [M:SCO1]PRHFCY

    Call FIND_FCYADD(WSTOFCY,[M:SCO1]PRHADD) From BPRLIB
    Affzo [M:SCO1]PRHADD
  Endif
#

# Issue 95308 GA 01/2014 code remis/complété # Issue 86439 GA 12/2012
  If clalev([M:SCO2])>0 & [M:SCO1]LOC<>""
# Issue 85539 - 2012-11-02 by CCC
#    For I=0 To [M:SCO2]NBLIG-1
#      If [M:SCO2]SCOFLG(I) = 2 & [M:SCO2]LOC(I)=""
#      #  ssi composant normal et fourni au sous-traitant
#         [M:SCO2]LOC(I) = [M:SCO1]LOC
#      Endif
#      If WSTOFCY <> "" & [M:SCO2]STOFCY(I)=""
#         [M:SCO2]STOFCY (I) = WSTOFCY
#      Endif
#    Next
#    Affzo [M:SCO2]LOC,STOFCY
    If [M:SCO2]NBLIG>0 & !find([M:SCO1]LOC,[M:SCO2]LOC)
        Call OUINON(mess(429,194,1),WRET) From GESECRAN
        If WRET=2
            For I=0 To [M:SCO2]NBLIG-1
                Call UPD_MAT_FCY2(WSTOFCY, [M:SCO1]LOC, I) From SCOLIB
                Affzo [M:SCO2]LOC(I),STOFCY(I)
            Next
        Endif
    Endif
  Endif
  Affzo [M:SCO1]PRHFCY,MFGFCY
End

$AB1_BPAADD
#------------------------------------------#
# Avant exécution du tunnel Clients livrés #
#------------------------------------------#
# Issue 86493 GA 01/2013
GBPCNUM=[M:SCO0]BPRNUM
Return

$BB1_BPAADD
#------------------------------------------#
# Après exécution du tunnel Clients livrés #
#------------------------------------------#
# Issue 86493 GA 01/2013
Raz GBPCNUM
If [F:BPD]BPCNUM=[M:SCO0]BPRNUM & [F:BPD]BPAADD<>""
  VALEUR=[F:BPD]BPAADD
Endif
Return

######################################################################################
Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()

# Issue 71069 - 2016-09-08 by MUARN : PJT
If [M:SCO1]POHNUM = ""
  Local Integer OK
  OK=2 : Call OUINON(mess(571,194,1),OK) From GESECRAN
  If OK = 2
    [M:SCO1]PJT=VALEUR
    # article lancé
    If dim([M:SCO1]NBDIE)>0
      If [M:SCO1]NBDIE>0
          For I=1 To [M:SCO1]NBDIE Raz [M:SCO1]CCE(I-1) : Next
      Endif
      Call INIT_CCEH("SCO1","NBDIE","SCI") From TRTX3CPT
      If !GIMPORT : Affzo [M:SCO1]25 : Endif
    Endif
    # service
    If dim([M:SCO3]NBDIE)>0
      If [M:SCO3]NBDIE>0
          For I=1 To [M:SCO3]NBDIE Raz [M:SCO3]CCE(I-1) : Next
      Endif
      Call INIT_CCEH("SCO3","NBDIE","SCS") From TRTX3CPT
      If !GIMPORT : Affzo [M:SCO3]30 : Endif
    Endif
    # matières
    If dim([M:SCO2]NBLIG) > 0
      For I=0 To [M:SCO2]NBLIG-1
        For J=1 To GNBDIE
          Case J
            When  1 :
              Raz [M:SCO2]CCE1 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE1(I),J,"SCM","",I) From TRTX3CPT
            When  2 :
              Raz [M:SCO2]CCE2 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE2(I),J,"SCM","",I) From TRTX3CPT
            When  3 :
              Raz [M:SCO2]CCE3 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE3(I),J,"SCM","",I) From TRTX3CPT
            When  4 :
              Raz [M:SCO2]CCE4 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE4(I),J,"SCM","",I) From TRTX3CPT
            When  5
              Raz [M:SCO2]CCE5 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE5(I),J,"SCM","",I) From TRTX3CPT
            When  6 :
              Raz [M:SCO2]CCE6 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE6(I),J,"SCM","",I) From TRTX3CPT
            When  7 :
              Raz [M:SCO2]CCE7 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE7(I),J,"SCM","",I) From TRTX3CPT
            When  8 :
              Raz [M:SCO2]CCE8 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE8(I),J,"SCM","",I) From TRTX3CPT
            When  9 :
              Raz [M:SCO2]CCE9 (I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE9(I),J,"SCM","",I) From TRTX3CPT
            When 10 :
              Raz [M:SCO2]CCE10(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE10(I),J,"SCM","",I) From TRTX3CPT
            When 11 :
              Raz [M:SCO2]CCE11(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE11(I),J,"SCM","",I) From TRTX3CPT
            When 12 :
              Raz [M:SCO2]CCE12(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE12(I),J,"SCM","",I) From TRTX3CPT
            When 13 :
              Raz [M:SCO2]CCE13(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE13(I),J,"SCM","",I) From TRTX3CPT
            When 14 :
              Raz [M:SCO2]CCE14(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE14(I),J,"SCM","",I) From TRTX3CPT
            When 15 :
              Raz [M:SCO2]CCE16(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE15(I),J,"SCM","",I) From TRTX3CPT
            When 16 :
              Raz [M:SCO2]CCE17(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE16(I),J,"SCM","",I) From TRTX3CPT
            When 17 :
              Raz [M:SCO2]CCE17(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE17(I),J,"SCM","",I) From TRTX3CPT
            When 18 :
              Raz [M:SCO2]CCE18(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE18(I),J,"SCM","",I) From TRTX3CPT
            When 19 :
              Raz [M:SCO2]CCE19(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE19(I),J,"SCM","",I) From TRTX3CPT
            When 20 :
              Raz [M:SCO2]CCE20(I)
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE([M:SCO2]CCE20(I),J,"SCM","",I) From TRTX3CPT
          Endcase
        Next J
      Next I
      If !GIMPORT : Affzo [M:SCO2]5 : Endif
    Endif
  # Issue X3-3807 - 2017-12-07 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
  #Else
  Elsif [M:SCO1]NBDIE = 0 | [M:SCO3]NBDIE = 0
    [M:SCO1]PJT=VALEUR
    Local Integer WPJMDIENUM
    Local Char    WCCEZON
    Local Char    WSECTION(GLONCCE)
    WPJMDIENUM=find(GPJMDIE,GDIE(1..GNBDIE))
    If [M:SCO1]NBDIE = 0
      If WPJMDIENUM>0
        WCCEZON = "[M:SCO1]CCE(0)"
        [M:SCO1]DIE(0) = GDIE(WPJMDIENUM)
        Assign WCCEZON With ""
        Call INISEC([L]WSECTION,"SCI",GPJMDIE) From SUBCDE
        Assign WCCEZON With [L]WSECTION
        [M:SCO1]NBDIE = 1
      Endif
    Endif
    If [M:SCO3]NBDIE = 0
      If WPJMDIENUM>0
        WCCEZON = "[M:SCO3]CCE(0)"
        [M:SCO3]DIE(0) = GDIE(WPJMDIENUM)
        Assign WCCEZON With ""
        Call INISEC([L]WSECTION,"SCS",GPJMDIE) From SUBCDE
        Assign WCCEZON With [L]WSECTION
        [M:SCO3]NBDIE = 1
      Endif
    Endif
  Endif
Endif
End

######################################################################################

Subprog D_SCOSTA(VALEUR)
Variable Integer VALEUR
Case [F:PTR]SCOSTA
    When 1: VALEUR = 2
    When 2: VALEUR = 1
   #When Default :  Gosub SCO_SCOSTA_DEF From SCOLIB
   When Default :  Gosub SCO_SCOSTA_INI From SCOLIB   # FQ 54211 statut Ferme par défaut
Endcase
End

Subprog AS_SCOSTA(VALEUR)
Variable Integer VALEUR
 # si EO Clos: le statut ne peut plus revenir de "Ferme" à "Planifié"
If VALEUR=4
 # si article commandé, soldé: le statut ne peut plus revenir de "Ferme" à "Planifié"
   mkstat = 2 : End
Endif
GMENLOC(3)=1
GMENLOC(4)=1
If [M:SCO1]ITMSTA>2
 # si article commandé, soldé: le statut ne peut plus revenir de "Ferme" à "Planifié"
   GMENLOC(2)=1
   mkstat = 2 : End
Endif
Case [F:PTR]SCOSTA
    When 1: If find(GREP,"C","D") : VALEUR = 2 : Endif
            mkstat = 2 :  End
    When 2: If find(GREP,"C","D") : VALEUR = 1 : Endif
            mkstat = 2 :  End
Endcase
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SCO1) 29/12/2008 15:52:52 (LLC)
######################################################################################
Subprog C_SCOSTA(VALEUR)
Variable Integer VALEUR
If find(GREP,"C","D") : End : Endif

Local Integer OK
# si passage de ferme à planifié
If VALEUR = 2 & GMEMSTA = 1
   # V6 Affectations
    Gosub CTL_MAJ_EOFP From SCOMTOLIB
    If OK <> 2 : VALEUR = [M:SCO1]SCOSTA : mkstat = 2 : End : Endif
Endif
End

######################################################################################
## Issue 87818 GA 02/2013 Lancement de l'EO avec mise à niveau GEOMUPD=2
######################################################################################
Subprog AM_SCOSTA(VALEUR)
Variable Integer VALEUR
If find(GREP,"C","D") : End : Endif

Local Integer OK
# si passage de planifié à ferme
If VALEUR = 1 & GMEMSTA=2
   If find(GEOMUPD,2,4)
      Call SUPSRV()
      Call GENSRV()
   Endif
   If find(GEOMUPD,3,4)
      Call SUPMAT()
      Call GENMAT()
   Endif
Endif
End

##############################################################################
## Issue 87818 GA 02/2013 Lancement de l'EO avec mise à niveau GEOMUPD=2
Subprog SUPMAT()
# Tous les cpn sont rattachés à l'article lancé courant
# recherche bornes des lignes matières concernées
#For I=0 To [M:SCO2]NBLIG-1
#    #If ([M:SCO2]SCILIN(I) = [M:SCO1]SCILIN )
#        Dela I,1 [M:SCO2]NBLIG
#    #Endif
#Next I
# Issue 107513/US2 GA 05/2015 delete also Order MSx / allocations / ...
Gosub ANNULE From SUBSCO2

Effzo [M:SCO2]5     # Issue 87818 by CCC
[M:SCO2]NBLIG=0
End
##############################################################################
## Issue 87818 GA 02/2013 Lancement de l'EO avec mise à niveau GEOMUPD=2
Subprog SUPSRV()
# Issue 107513/US2 GA 05/2015 delete also Order SCx / Cptanalin / ...
Gosub ANNULE From SUBSCO3

Raz [M:SCO3] #### [M:SCO3]SRVITMREF
End

##############################################################################
## Issue 87818 GA 02/2013 Lancement de l'EO avec mise à niveau GEOMUPD=2
Subprog GENMAT()

Local Integer OK,I : I=0
Local Date WDAT
# Issue 105251 GA 04/2015 EP to use end date instead of [M:SCO1]ORDDAT to check availability of component
#If [M:SCO1]ORDDAT<>[0/0/0] WDAT=[M:SCO1]ORDDAT Else WDAT=date$ Endif
# Check validity date of the link
Local Integer WBOMDATCTL : WBOMDATCTL=2

# Issue 110935 - 2016-04-20 by BEEBE : Deactivate EP PE_BOMDATCTL for product managed by version
Local Char WITMREF(GLONITM)

WITMREF = [M:SCO0]ITMREF
#----- Read [F:ITM] with WITMREF when not loaded
If clalev([F:ITM])=0 | [F:ITM]ITMREF <> WITMREF
    Gosub READ_ITM From ITMLIB
Endif

If dim([F:ITM]ECCFLG)<=0 | [F:ITM]ECCFLG<>2
    Gosub PE_BOMDATCTL From SCOAUTLIB
Endif
# End issue 110935
Case WBOMDATCTL
  When 1       : WDAT=[M:SCO1]RETDAT
  When Default : WDAT=[M:SCO1]ORDDAT  # standard mode
Endcase
If WDAT=[0/0/0] WDAT=date$ Endif
# Issue 110838 - 2016-03-02 by JUSYN : Reload of versioned material must be correct according to date of BOM.
#                                      Versioned BOM delivered already correct start date beeing calculated
#                                      in GENSRV for service. But for versioned BOM's material only start date
#                                      makes sense.
# Issue 107513 by GA 08/2015: change reference date to reload correctly the BOM
If dim([M:SCO0]ECCVALMAJ)>0 & [M:SCO0]ECCVALMAJ<>""
#    Local Date WWDAT : WWDAT=WDAT
#    Call INIECCDAT([M:SCO0]ITMREF,[M:SCO1]PRHFCY,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,3,WDAT) From SCOECCLIB
#    If WDAT>WWDAT
#        [M:SCO1]ORDDAT=WDAT : [M:SCO3]OPESTR=WDAT : Raz [M:SCO3]OPEEND
#        Call CALENDDAT([M:SCO1]LTI,[M:SCO1]ORDDAT,[M:SCO1]RETDAT) From SCOLIB
#        [M:SCO3]OPEEND = [M:SCO1]RETDAT # réaffecté suite au Raz SUPSRV
#        If !GIMPORT : Affzo [M:SCO1]ORDDAT,RETDAT : Affzo [M:SCO3]OPESTR,OPEEND : Endif
#    Endif
    WDAT=[M:SCO1]ORDDAT

    # Issue 111235 - 2016-03-08 by CCC : Take into account derogation => calculate the date to read the BOM
    Call CORDAT([M:SCO0]ITMREF,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,3,WDAT) From ECCLIB
Endif

Default Mask [SCO2]
For [BOD] Where ITMREF=[M:SCO0]ITMREF and BOMALT=[M:SCO0]BOMALT and BOMALTTYP=3 and CPNTYP<6 &
&              (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDAT)) &
&              (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDAT))

     OK=2
     Raz mkstat
     nolign=I+1
     Gosub RAZCRE From SUBSCO2
     Call CHARGE_SCO2_FROM_BOD ( [M:SCO0]ITMREF,[M:SCO0]BPRNUM,[M:SCO0]BOMALT,[F:BOD]CPNITMREF, I) From SUBSCOA
     #If GOK<>1  : OK=1 : Break : Endif   # FQ 74423 GA 06/2011
     I+=1

$NEXT_BOD
Next
If OK=1 : End : Endif

[M:SCO2]NBLIG=I
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
Affzo [SCO2]1-99
End

##############################################################################
Subprog GENSRV()
Default Mask [SCO3]
Local Integer OK,I : I=0
Local Date WDAT
# Issue 105251 GA 04/2015 EP to use end date instead of [M:SCO1]ORDDAT to check availability of component
#If [M:SCO1]ORDDAT<>[0/0/0] WDAT=[M:SCO1]ORDDAT Else WDAT=date$ Endif
# Check validity date of the link
Local Integer WBOMDATCTL : WBOMDATCTL=2

# Issue 110935 - 2016-04-20 by BEEBE : Deactivate EP PE_BOMDATCTL for product managed by version
Local Char WITMREF(GLONITM)

WITMREF = [M:SCO0]ITMREF
#----- Read [F:ITM] with WITMREF when not loaded
If clalev([F:ITM])=0 | [F:ITM]ITMREF <> WITMREF
    Gosub READ_ITM From ITMLIB
Endif

If dim([F:ITM]ECCFLG)<=0 | [F:ITM]ECCFLG<>2
    Gosub PE_BOMDATCTL From SCOAUTLIB
Endif
# End issue 110935
Case WBOMDATCTL
  When 1       : WDAT=[M:SCO1]RETDAT
  When Default : WDAT=[M:SCO1]ORDDAT  # standard mode
Endcase
If WDAT=[0/0/0] WDAT=date$ Endif
# Issue 110838 - 2016-03-04 by JUSYN : Reload of service must be correct according to date of subcontract BOM
# Issue 107513 by GA 08/2015: change reference date to reload correctly the BOM
If dim([M:SCO0]ECCVALMAJ)>0 & [M:SCO0]ECCVALMAJ<>""
   # versioned BOM/Service delivers only start date / order date
   # Local Date WWDAT : WWDAT=WDAT
   #WDAT = [0/0/0]
   Call INIECCDAT([M:SCO0]ITMREF,[M:SCO1]PRHFCY,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,3,WDAT) From SCOECCLIB
   # If WDAT>WWDAT
   [M:SCO1]ORDDAT=WDAT : [M:SCO3]OPESTR=WDAT : Raz [M:SCO3]OPEEND
   # Call CALENDDAT([M:SCO1]LTI,[M:SCO1]ORDDAT,[M:SCO1]RETDAT) From SCOLIB
   # If !GIMPORT : Affzo [M:SCO1]ORDDAT,RETDAT : Endif
   # Endif

    # Issue 111235 - 2016-03-08 by CCC : Take into account derogation => calculate the date to read the BOM
   Call CORDAT([M:SCO0]ITMREF,[M:SCO0]ECCVALMAJ,[M:SCO0]ECCVALMIN,3,WDAT) From ECCLIB

Endif

For [BOD] Where ITMREF=[M:SCO0]ITMREF and BOMALT=[M:SCO0]BOMALT and BOMALTTYP=3 and CPNTYP=7     &
&              (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDAT)) &
&              (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDAT))
     Gosub RAZCRE From SUBSCO3
     # Issue 111235 - 2016-03-04 by JUSYN : For versioned BOM precalculation start/end date (needed for OPEEND in UPD_SRV_DAT in CHARGE_SCO3_FROM_BOS)
     If dim([M:SCO0]ECCVALMAJ)>0 & [M:SCO0]ECCVALMAJ<>""
         Local Integer WPRELTI
         If [F:BOD]BOMOFS > 0
             WPRELTI = [F:BOD]BOMOFS
         Else
             Call FIND_LTI([F:BOD]CPNITMREF,[M:SCO0]BPRNUM,[M:SCO0]POHFCY,WPRELTI) From SCOLIB
             If WPRELTI <= 0
                 WPRELTI = [M:SCO1]LTI
             Endif
         Endif
         Call CALENDDAT(WPRELTI,[M:SCO1]ORDDAT,[M:SCO1]RETDAT) From SCOLIB
         If !GIMPORT : Affzo [M:SCO1]ORDDAT,RETDAT : Endif
     Endif
     [M:SCO3]OPEEND = [M:SCO1]RETDAT : Affzo [M:SCO3]OPEEND # réaffecté suite au Raz SUPSRV
     Call CHARGE_SCO3_FROM_BOS ( [M:SCO0]ITMREF,[M:SCO0]BPRNUM,[M:SCO0]BOMALT,[F:BOD]CPNITMREF, I) From SUBSCOA
     #If GOK<>1  : OK=1 : Break : Endif   # FQ 74423 GA 06/2011
     Break
Next
If [M:SCO3]SRVITMREF=""
   # Issue 100626 GA 06/2014 return previous error
   # "Aucun service valide au niveau de la nomenclature de sous-traitance !"
   GMESSAGE=mess(378,194,1)-GMESSAGE : OK=1
Endif
If OK=1 : End : Endif
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
Affzo [SCO3]1-99
End

##############################################################################

Subprog UPDATE_SCOTEX(LCOD)
Value Char LCOD
Local Integer WRET
Case LCOD
  When "C","M","U" :
    #---------------------------------------------#
    # nouvelle gestion des textes                 #
    #---------------------------------------------#
     If [F:SCO]SCOTEX <> ""
        If left$([F:SCO]SCOTEX,3)="SCO"
           Call CRE_CLOB([F:SCO]SCOTEX,GOK) From TRTX3TEX
        Elsif left$([F:SCO]SCOTEX,3) <> "SCO"
           Call DUP_CLOB("SCO",[F:SCO]SCOTEX,GOK) From TRTX3TEX
        Endif
     Endif
   When "A"
     If [F:SCO]SCOTEX <> "" & left$([F:SCO]SCOTEX,3) = "SCO"
        Call SUP_CLOB([F:SCO]SCOTEX,WRET) From TRTX3TEX
     Endif
Endcase
End

#######################################################

Subprog FIND_POF ()
#-------------------------------------------#
# On vérifie si une commande est rattachée  #
# en cherchant un encours POF               #
#-------------------------------------------#
If [M:SCO1]POHNUM=""
  Raz [F:ORD]
  If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY<>2
#   Commande inter-site: encours de type 7 TRF
    Filter [ORD] Where WIPTYP=7 & WIPSTA=1      & ITMREF=[M:SCO0]ITMREF
&                    & VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                    & VCRLINORI=[M:SCO1]SCILIN & VCRSEQORI=0
    Read   [ORD] ORD0 First
    If fstat : Raz [F:ORD] : Goto FIN_FIND_POF : Endif
  Else
#   Recherche d'un encours article POF rattaché à cet article lancé
    Filter [ORD] Where WIPTYP=2 & WIPSTA=1      & ITMREF=[M:SCO0]ITMREF
&                    & VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                    & VCRLINORI=[M:SCO1]SCILIN & VCRSEQORI=0
    Read   [ORD] ORD0 First
    If fstat : Raz [F:ORD] : Goto FIN_FIND_POF : Endif
  Endif
#
# Référence ligne commande sur [F:SCI]
  [M:SCO1]POHNUM = [F:ORD]VCRNUM
  [M:SCO1]POPLIN = [F:ORD]VCRLIN
  [M:SCO1]POQSEQ = [F:ORD]VCRSEQ
  Gosub SCI_ITMSTA_PUR From SCOLIB
# Référence de l'encours POF
# NB: il vaut mieux conserver la réf encours EOF s'il n'est pas consommé
  If [F:ORD]EXTQTY >= [M:SCO1]EXTQTY
     [M:SCO1]WIPTYP = [F:ORD]WIPTYP
     [M:SCO1]WIPSTA = [F:ORD]WIPSTA
     [M:SCO1]WIPNUM = [F:ORD]WIPNUM
  Endif
#
Else
# TEMPORAIRE: si ligne POQ supprimée => Raz de la référence
  Read [POQ] POQ0=[M:SCO1]POHNUM;[M:SCO1]POPLIN;[M:SCO1]POQSEQ
  If fstat
     Raz [F:POQ]
     Raz [M:SCO1]POHNUM,POPLIN,POQSEQ,ITMSTA
  Elsif [M:SCO1]ITMSTA<3
    Gosub SCI_ITMSTA_PUR From SCOLIB
  Endif
Endif
$FIN_FIND_POF
Affzo [M:SCO1]ITMSTA
Filter [ORD]
If [M:SCO1]POHNUM=""
   Actzo [M:SCO1]ITMSTA, QTYPUU, PUU
   Raz [M:SCO1]POHNUM,[M:SCO1]POPLIN,[M:SCO1]POQSEQ,[M:SCO1]ORDQTY
 # Référence de l'encours EOx
   Call FIND_EOX()
Else
 # une fois le service commandé, il faut utiliser l'écran de saisie des commandes pour màj la qté
 # => les zones sont bloquées dans la saisie de SCO
   Diszo [M:SCO1]ITMSTA, QTYPUU, PUU
Endif
If [M:SCO1]ITMSTA>2 # Issue 88046 GA 12/2013 pas de modif site/adresse de réception si déjà commandé
   Diszo [M:SCO1]PRHFCY : Diszo [M:SCO1]PRHADD
Endif
End

#######################################################
Subprog FIND_EOX ()
#-------------------------------------------#
# On cherche la présence d'un encours EOx   #
#-------------------------------------------#
If [M:SCO1]WIPNUM<>"" & [M:SCO1]WIPTYP=2 & [M:SCO1]POHNUM<>""
  End
Else
  Raz [F:ORD]
# Recherche d'un encours article EOx rattaché à cet ordre de sous-traitance/article
  Filter [ORD] Where WIPTYP=13 & WIPSTA=[M:SCO1]SCOSTA
&                  & ITMREF=[M:SCO0]ITMREF & VCRTYP=36 & VCRNUM=[M:SCO0]SCONUM
&                  & VCRLIN=[M:SCO1]SCILIN & VCRSEQ=0
  Read   [ORD] ORD0 First
  If fstat : Raz [F:ORD] : Endif
  Filter [ORD]
  [M:SCO1]WIPTYP = [F:ORD]WIPTYP
  [M:SCO1]WIPSTA = [F:ORD]WIPSTA
  [M:SCO1]WIPNUM = [F:ORD]WIPNUM
Endif
End

######################################################################################
#----------------------------------------------------------------#
# Contrôle si quantité supérieure ou égale à la quantité minimun #
#----------------------------------------------------------------#
$CTL_PURMINQTY
Local Integer WOK
Raz GMESSAGE, mkstat
#----- Article référencé chez le fournisseur ? -----#
  # Issue X3-55891 - 2018-09-12 by MUARN : exploitation table article/fournisseur/site
  #WOK = func ITMLIB.IS_ITP_OK ( [M:SCO0]ITMREF, [M:SCO0]BPRNUM)
  If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY=1
    WOK = func ITMLIB.IS_ITP_OK ( [M:SCO0]ITMREF, [M:SCO0]BPRNUM, [M:SCO1]PRHFCY,2)
  Else
    WOK = func ITMLIB.IS_ITP_OK ( [M:SCO0]ITMREF, [M:SCO0]BPRNUM, [M:SCO1]PRHFCY,1)
  Endif
  If WOK<2 : Return : Endif
#-----
  Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:SCO1]PUU,
&                [M:SCO0]ITMREF,[M:SCO0]BPRNUM,1,GBIDD2) From TRTACHQTE1
#----- Qté inférieure à qté minimum d'achat ?  -----#
  #VPO 15/10/10 17730/59532 contrôle selon paramètre
  If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
  #If [M:SCO1]QTYPUU<GBIDD1
  If [M:SCO1]QTYPUU<GBIDD1 & GPOHMINQTY<3
    GMESSAGE =[M:SCO0]ITMREF-mid$(mess(14,194,1),1,instr(1,mess(14,194,1),"\")-1)
    GMESSAGE-=right$(mess(14,194,1),instr(1,mess(14,194,1),"\")+1)
    GMESSAGE-=num$(GBIDD1)-[M:SCO1]PUU
    If GPOHMINQTY=1
          mkstat=2 : Return
    Else : #GPOHMINQTY=2
       WOK=2
       Call AVERTIR (GMESSAGE, WOK)From GESECRAN
       If WOK=1
          Raz GMESSAGE
          mkstat=2 : Return
       Endif
       Raz GMESSAGE
    Endif
  Endif
Return


