##################################################################################################
# SUBFIDB    Gestion des critères de ciblages           Module CRM                12 mars 2002   #
#                                                                                                #
# Sous-programmes utilitaires                                                                    #
##################################################################################################
#                                                                                                #
# LOADCRIT  : Charge une description des critères.                                               #
# SAVECRIT  : Enregistre une description des critères.                                           #
#                                                                                                #
##################################################################################################
##################################################################################################
# Charge une description des critères.
##################################################################################################
Subprog LOADCRIT(SZCRITAB, SZCAT)
Value Char SZCRITAB
Value Char SZCAT

Local Integer INBFIE
Local Integer INBFIEX
Local Char SZTEXTE(GLONDCO)

  INBFIE = 0
  INBFIEX = 0
  Read [FID]FID0=SZCRITAB;SZCAT
  If fstat Then
    #Il s'agit d'une nouvelle description de critères
    #On utilise le dictionnaire champs pour charger une description active par défaut.
    Filter [ATZ] Where [F:ATZ]CODFIC = SZCRITAB
    For [ATZ]CODZONE
      If INBFIE >= dim([M:FID1]SELCRIFIE) Then
        Break
      Endif
      [M:FID1]SELCRIFIE(INBFIE) = [F:ATZ]CODZONE
      Call TEXTE([F:ATZ]NOLONG, [M:FID1]SELCRIAXX(INBFIE)) From OBJDIV
      [M:FID1]SELCRIFLG(INBFIE) = 2
      [M:FID1]SELCRISRT(INBFIE) = INBFIE + 1
      INBFIE += 1
    Next
    Filter [ATZ]
    [M:FID1]NBFIE = INBFIE
    [M:FID2]NBFIEX = 0
  Else
    #On charge une description existante.
    Filter [FDF] Where [F:FDF]CRITAB = SZCRITAB and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = SZCAT Order By [F:FDF]SELCRISRT Asc
    For [FDF] Hint Key FDF0
      If INBFIE >= dim([M:FID1]SELCRIFIE) Then
        Break
      Endif
      [M:FID1]SELCRIFIE(INBFIE) = [F:FDF]SELCRIFIE
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      [M:FID1]SELCRIAXX(INBFIE) = SZTEXTE
      [M:FID1]SELCRIFLG(INBFIE) = [F:FDF]SELCRIFLG
      [M:FID1]SELCRISRT(INBFIE) = [F:FDF]SELCRISRT
      INBFIE += 1
    Next
    Filter [FDF]
    [M:FID1]NBFIE = INBFIE
    Filter [FDF] Where [F:FDF]CRITAB = SZCRITAB and [F:FDF]SELCRIFLG = 1 and [F:FDF]CAT = SZCAT Order By [F:FDF]SELCRISRT Asc
    For [FDF] Hint Key FDF0
      If INBFIEX >= dim([M:FID2]SELCRIFIEX) Then
        Break
      Endif
      [M:FID2]SELCRIFIEX(INBFIEX) = [F:FDF]SELCRIFIE
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      [M:FID2]SELCRIAXX(INBFIEX) = SZTEXTE
      [M:FID2]SELCRIFLGX(INBFIEX) = [F:FDF]SELCRIFLG
      [M:FID2]SELCRISRTX(INBFIEX) = [F:FDF]SELCRISRT
      INBFIEX += 1
    Next
    Filter [FDF]
    [M:FID2]NBFIEX = INBFIEX
  Endif
End

##########################################################################################################
# Enregistre une description des critères.
##################################################################################################
$SAVECRIT
Local Integer IFIEITER
Local Integer IFIDPBL
Local Integer IMAXSRT
Local Integer ISTDFLG

  IFIDPBL = 0
  IMAXSRT = 0
  ISTDFLG = 0
  #Détermine le status standard de la table.
  Case [M:FID0]CRITAB
    When "BAPPOINT"
      ISTDFLG = 1
    When "BPADDRESS"
      ISTDFLG = 1
    When "BPARTNER"
      ISTDFLG = 1
    When "BPCUSTOMER"
      ISTDFLG = 1
    When "CALLATTEMP"
      ISTDFLG = 1
    When "CONTACT"
      ISTDFLG = 1
    When "CONTACTCRM"
      ISTDFLG = 1
    When "CONTSERV"
      ISTDFLG = 1
    When "ESCSRE"
      ISTDFLG = 1
    When "HDKTASK"
      ISTDFLG = 1
    When "HISTOOMM"
      ISTDFLG = 1
    When "INTERVEN"
      ISTDFLG = 1
    When "ITMMASTER"
      ISTDFLG = 1
    When "MACHINES"
      ISTDFLG = 1
    When "MACITN"
      ISTDFLG = 1
    When "OMMRESULT"
      ISTDFLG = 1
    When "OPPOR"
      ISTDFLG = 1
    When "PHONECALL"
      ISTDFLG = 1
    When "REPSEC"
      ISTDFLG = 1
    When "SCPASW"
      ISTDFLG = 1
    When "SDELIVERY"
      ISTDFLG = 1
    When "SDELIVERYD"
      ISTDFLG = 1
    When "SERREQUEST"
      ISTDFLG = 1
    When "SINVOICE"
      ISTDFLG = 1
    When "SINVOICED"
      ISTDFLG = 1
    When "SINVOICEV"
      ISTDFLG = 1
    When "SOLUTION"
      ISTDFLG = 1
    When "SORDER"
      ISTDFLG = 1
    When "SORDERP"
      ISTDFLG = 1
    When "SORDERQ"
      ISTDFLG = 1
    When "SQUOTE"
      ISTDFLG = 1
    When "SQUOTED"
      ISTDFLG = 1
    When "SREMAC"
      ISTDFLG = 1
    When "SREMACCPN"
      ISTDFLG = 1
    When "SRETURN"
      ISTDFLG = 1
    When "TABLINCFG"
      ISTDFLG = 1
    When "TABSOHTYP"
      ISTDFLG = 1
    When "TASK"
      ISTDFLG = 1
    When "LEAD"
      ISTDFLG = 1
  Endcase
  #Recherche le numéro d'ordre max dans le tableau 1
  For IFIEITER = 0 To [M:FID1]NBFIE-1
    If [M:FID1]SELCRIFIE(IFIEITER) <> "" Then
      If [M:FID1]SELCRISRT(IFIEITER) > IMAXSRT Then
        IMAXSRT = [M:FID1]SELCRISRT(IFIEITER)
      Endif
    Endif
  Next
  #On efface tout et on recommence
  Delete [FDF] Where [F:FDF]CRITAB = [M:FID0]CRITAB and [F:FDF]CAT = [M:FID0]CAT
  If fstat Then
    IFIDPBL = 1
    GOK = 0
    Call FSTA("FDF") From GLOCK
    Return
  Endif
  #Enregistre le tableau 1
  For IFIEITER = 0 To [M:FID1]NBFIE-1
    If [M:FID1]SELCRIFIE(IFIEITER) <> "" Then
      [F:FDF]CRITAB = [M:FID0]CRITAB
      [F:FDF]SELCRIFIE = [M:FID1]SELCRIFIE(IFIEITER)
      [F:FDF]SELCRIFLG = [M:FID1]SELCRIFLG(IFIEITER)
      [F:FDF]SELCRISRT = [M:FID1]SELCRISRT(IFIEITER)
      [F:FDF]STD = ISTDFLG
      [F:FDF]CAT = [M:FID0]CAT
      Write [FDF]
      If fstat Then
        IFIDPBL = 1
        GOK = 0
        Call FSTA("FDF") From GLOCK
      Endif
      Call MAJTEXTRA([M:FID1]SELCRIAXX(IFIEITER), "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
    Endif
    If IFIDPBL Then
      Break
    Endif
  Next
  If IFIDPBL Then
    Return
  Endif
  #Enregistre le tableau 2
  For IFIEITER = 0 To [M:FID2]NBFIEX-1
    If [M:FID2]SELCRIFIEX(IFIEITER) <> "" Then
      [F:FDF]CRITAB = [M:FID0]CRITAB
      [F:FDF]SELCRIFIE = [M:FID2]SELCRIFIEX(IFIEITER)
      [F:FDF]SELCRIFLG = [M:FID2]SELCRIFLGX(IFIEITER)
      If [M:FID2]SELCRIFLGX(IFIEITER) = 2 Then
        IMAXSRT += 1
        [F:FDF]SELCRISRT = IMAXSRT
      Else
        [F:FDF]SELCRISRT = [M:FID2]SELCRISRTX(IFIEITER)
      Endif
      [F:FDF]STD = ISTDFLG
      [F:FDF]CAT = [M:FID0]CAT
      Write [FDF]
      If fstat Then
        IFIDPBL = 1
        GOK = 0
        Call FSTA("FDF") From GLOCK
      Endif
      Call MAJTEXTRA([M:FID2]SELCRIAXX(IFIEITER), "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
    Endif
    If IFIDPBL Then
      Break
    Endif
  Next
Return
