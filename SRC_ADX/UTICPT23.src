#<AdxTL>@(#)9.0.0.0 $Revision$
##############################################################################
## Initialisation du nouveau flag LOSGAIFLG à "Non" pour tous les comptes
##############################################################################

Call MAJ_UTICPT23
End

Subprog MAJ_UTICPT23

Local Char DOSSIER(30) : DOSSIER=nomap
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICPT23:"-"Initialization 'LOSGAIFLG' Field (GACCOUNT Table) and 'MTCRNDBAT' Parameter") From LECFIC
Call SAIDOS(DOSSIER,"UTICPT23") From SAIDOS
If DOSSIER<>"" Call EXE_UTICPT23(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


Subprog EXE_UTICPT23(APPLI)
Value Char APPLI

Local Integer OK
If filinfo(filpath("FIL","GACCOUNT","fde",APPLI),0) < 0 : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0) < 0 : End : Endif

If clalev([F:GAC])=0 : Local File =APPLI+".GACCOUNT" [GAC] : Endif
If clalev([F:ADW])=0 : Local File =APPLI+".ADOVAL"   [ADW] : Endif
If clalev([F:ADW2])=0 : Local File =APPLI+".ADOVAL"  [ADW2] : Endif


Call ECR_TRACE("UTICPT23: Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Gosub TR_UTICPT23
Call ECR_TRACE("UTICPT23: Process End on : "+APPLI,0) From GESECRAN
End


#### Corps de la moulinette - début
$TR_UTICPT23
Trbegin [GAC], [ADW]
 For [GAC]GAC0 Where LOSGAIGNR=0
  [F:GAC]LOSGAIGNR = 1
  Rewrite [GAC]
  If fstat
   GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"GACCOUNT"-":"-[F:GAC]COA-[F:GAC]ACC,1) From GESECRAN
   Break
  Endif
 Next
 If !GOK : Goto AB_UTICPT23 : Endif
 For [ADW2]ADW1 Where PARAM="MTCRND"
  Read [ADW]ADW1 = "MTCRNDBAT";[F:ADW2]CMP;[F:ADW2]FCY
  If fstat
   [F:ADW] = [F:ADW2]
   [F:ADW]PARAM = "MTCRNDBAT"
   Write [ADW]
   If fstat
    GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"ADOVAL"-":"-[F:ADW]PARAM-[F:ADW]FCY,1) From GESECRAN
    Break
   Endif
  Endif
 Next
 If !GOK : Goto AB_UTICPT23 : Endif
Commit
Return


$AB_UTICPT23
Rollback
Return 

#### Corps de la moulinette - fin 

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTICPT23(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTICPT23(APPLI)
End
