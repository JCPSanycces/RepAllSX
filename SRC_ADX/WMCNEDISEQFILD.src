####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDISEQFILD
Gosub _ALOADATTRIBUTE_MSGCOD From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGREL From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_MSGFILNOR From WMC1EDISEQFILD : Gosub TESTALLSTAT
