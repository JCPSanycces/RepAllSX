Gosub _ALOADATTRIBUTE_SORT From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_ALIAS From WMC1EDISEQFILD : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDISEQFILD
Gosub LNKPRO_MSGCOD From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub LNKPRO_MSGREL From WMC1EDISEQFILD : Gosub TESTALLSTAT
