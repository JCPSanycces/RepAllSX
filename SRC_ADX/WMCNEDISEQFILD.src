####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDISEQFILD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_MSGCOD From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_MSGREL From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_MSGFILNOR From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_NUMORDER From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_NUMLIN From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_SORT From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_MANDATORY From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_REPCOD From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_FILCOD From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_FLGREC From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_LEVEL From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_ALIAS From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_EXPRESSION From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_PROTOPATH From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_LOC From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_LNG From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_ENDREG From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_DESCRIPTION From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDISEQFILD : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDISEQFILD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

