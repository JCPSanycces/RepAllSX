$ON_ETA
Onevent CONTROL Call C_ETA(zc) From W1TNH2
Onevent AFTER_AREA Call AP_ETA(zc) From W1TNH2
Return

Subprog C_ETA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTHM
 Call CONTHM(VALEUR) From OBJDIV
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
Endif
If !mkstat
 ## Action STD
 Call C_ETA(VALEUR) From SUBTNH
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
Endif
Gosub _AFF
End

Subprog AP_ETA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action INIHM
 Call INIHM(VALEUR) From OBJDIV
 If mkstat : GERR = 1 : GZONE = "ETA" : GZNUM = 13424 : Endif
Endif
Gosub _AFF
End

$ON_GLBDOC
Onevent AFTER_CHANGE Gosub AMM_GLBDOC From W1TNH2
Onevent INIT_AREA Call D_GLBDOC(zc) From W1TNH2
Onevent BEFORE_INPUT Call AS_GLBDOC(zc) From W1TNH2
Return

Subprog D_GLBDOC(VALEUR)
Variable Integer VALEUR
If varinit([M]GLBDOC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_GLBDOC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_GLBDOC
Call AM_GLBDOC(zc)
If !mkstat & GOBJET
 zoncou = "GLBDOC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_GLBDOC(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_GLBDOC(VALEUR) From SUBTNH
If mkstat : GERR = 1 : GZONE = "GLBDOC" : GZNUM = 52720 : Endif
Gosub _AFF
End

$ON_GLBDOCTYP
Onevent BEFORE_INPUT Call AS_GLBDOCTYP(zc) From W1TNH2
Onevent INIT_AREA Call D_GLBDOCTYP(zc) From W1TNH2
Onevent CONTROL Call C_GLBDOCTYP(zc) From W1TNH2
Return

Subprog D_GLBDOCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]GLBDOCTYP,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_GLBDOCTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2047) From COMBOS
## Action STD
Call AS_GLBDOCTYP(VALEUR) From SUBTNH
If mkstat=2
 [M]GLBDOCTYP(INDIC) = VALEUR
 Affzo GLBDOCTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2047,1))))
Endif
If !mkstat
 Discombo 0 From GLBDOCTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From GLBDOCTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_GLBDOCTYP(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_GLBDOCNUM
Onevent CONTROL Call C_GLBDOCNUM(zc) From W1TNH2
Onevent AFTER_CHANGE Gosub AMM_GLBDOCNUM From W1TNH2
Onevent BEFORE_INPUT Call AS_GLBDOCNUM(zc) From W1TNH2
Return

Subprog AS_GLBDOCNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_GLBDOCNUM(zc) From W1TNH2
Gosub _AFF
End

Subprog C_GLBDOCNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "GLBDOCNUM" : GZNUM = 52721 : Endif
Endif
Gosub _AFF
End

$AMM_GLBDOCNUM
Call AM_GLBDOCNUM(zc)
If !mkstat & GOBJET
 zoncou = "GLBDOCNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_GLBDOCNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_GLBDOCNUM(VALEUR) From SUBTNH
If mkstat : GERR = 1 : GZONE = "GLBDOCNUM" : GZNUM = 52721 : Endif
Gosub _AFF
End

Subprog S_GLBDOCNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELGLBDOC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELGLBDOC"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELTAB","SELGLBDOC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_GLBDOCDAT
Onevent BEFORE_AREA Gosub AV_GLBDOCDAT From W1TNH2
Return

$AV_GLBDOCDAT
