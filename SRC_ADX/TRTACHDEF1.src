#<AdxTL>@(#)157.0.0.0 $Revision$
########################################################################
# TRTACHDEF1         Traitements valeurs par défaut       Module ACHAT #
#                         et chargement de zones                       #
# -------------------------------------------------------------------- #
# Sous-programmes :                                                    #
#   - DEFRCPFCY    : Chargement site réception GRCPFCY                 #
#   - DEFBETRCPFCY : Chargement site réception pour inter-sites        #
#   - DEFSITE      : CHARGEMENT SITE FINANCIER ET DEVISE COMPTABLE     #
#   - DEFBUD       : CHARGEMENT DE PARAMèTRES BUDGET                   #
# -------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Affichage divers GACTION)                  #
#   - DIVRECHNAT : Recherche de la nature pour visu budget             #
########################################################################


$ACTION
Case ACTION
 When "TRT_DIV"
  Case TRAIT
   When "DIVRECHNAT" : Gosub DIVRECHNAT
  Endcase
Endcase
Return


############################################################
# Recherche de la nature pour la visualisation des budgets #
# -------------------------------------------------------- #
# En entrée PARAM(1) : Code traitement appelant            #
#                      1 = Gestion demandes d'achat (PSH)  #
#                      2 = Gestion des commandes (POH)     #
#                      3 = Gestion des DL (POD)            #
#           PARAM(2) : Numéro de ligne courante (nolign-1) #
#                                                          #
# En sortie GBIDC3   : Nature                              #
#           GBIDA3   : Date du budget                      #
# Si erreur GMESSAGE : Message d'erreur                    #
#           GERR     : Code erreur = 1                     #
#           mkstat   : Code statut = 1                     #
############################################################
$DIVRECHNAT
Local Integer  I
Local Shortint NOL : NOL=val(PARAM(2))
Case PARAM(1)
  When "1"
    If [M:PSH1]LINACC1(NOL)="" & [M:PSH1]LINACC2(NOL)="" & [M:PSH1]LINACC3(NOL)=""
      Call INIT_COMPTES_LIGNE(NOL)               From SUBPSH
    Endif
    Call RECH_ACC(2,"[M:PSH1]LINACC",NOL,GBIDC3) From TRTX3CPT
    If GBIDC3=""
      GMESSAGE=mess(36,194,1) : GERR=2 : Raz GBIDA3 : mkstat=1
    Else
      If [M:PSH1]LINPURTYP(NOL)=0
        Call D_LINPURTYP([M:PSH1]LINPURTYP(NOL)) From SUBPSH
      Endif
      GBIDA3=[M:PSH1]EXTRCPDAT(NOL)
    Endif
  When "2"
    If [M:POH2]LINACC1(NOL)="" & [M:POH2]LINACC2(NOL)="" & [M:POH2]LINACC3(NOL)=""
      Call INIT_COMPTES_LIGNE(NOL)               From SUBPOHB
    Endif
    Call RECH_ACC(2,"[M:POH2]LINACC",NOL,GBIDC3) From TRTX3CPT
    If GBIDC3=""
      GMESSAGE=mess(36,194,1) : GERR=2 : Raz GBIDA3 : mkstat=1
    Else
      If [M:POH2]LINPURTYP(NOL)=0
        Call D_LINPURTYP([M:POH2]LINPURTYP(NOL)) From SUBPOH
      Endif
      GBIDA3=[M:POH2]DATBUD(NOL)
    Endif
  When "3"
    If [M:POD1]LINACC(0)="" & [M:POD1]LINACC(1)="" & [M:POD1]LINACC(2)=""
      Call INIT_COMPTES_LIGNE(NOL) From SUBPOD
    Endif
    Call RECH_INDACC(2,I)          From TRTX3CPT
    If I=0
      GMESSAGE=mess(36,194,1) : GERR=2 : Raz GBIDC3, GBIDA3 : mkstat=1
    Else
      GBIDC3=[M:POD1]LINACC(I-1)
      If [M:POD1]LINPURTYP=0
        Call INIT_LINPURTYP      From SUBPOD
      Endif
      If GPURCMMDAT=1
        GBIDA3=[M:POD1]ORDDAT Else GBIDA3=[M:POD1]EXTRCPDAT(NOL)
      Endif
    Endif
Endcase
Return


###################################################################################
# Chargement du site de réception par défaut GRCPFCY (sert pour l'initialisation) #
###################################################################################
Subprog DEFRCPFCY(WSITE)
Value Char WSITE
Raz GRCPFCY
If !clalev([F:FCY])  Local File FACILITY [FCY] : Endif
If [F:FCY]FCY<>WSITE
  Read [FCY] FCY0=WSITE  : If fstat  Raz [FCY] : Endif
Endif
If [F:FCY]WRHFLG=2
  GRCPFCY=WSITE         : # Site passé en paramètre si site de stockage
Else
  Local File FACILITY [FCYW]
  Read [FCYW] FCY0=GFCYDEF(7)
  If fstat
    Raz [F:FCYW]
  Elsif [F:FCYW]LEGCPY=GSOCIETE
    GRCPFCY=GFCYDEF(7)  : # Site par défaut du module stock
  Endif
  Close Local File [FCYW]
Endif
End


###################################################################################
# Chargement du site de réception par défaut GRCPFCY (sert pour l'initialisation) #
# Chargement du site d'expédition par défaut GSTOFCY                              #
# Nota : si GRCPFCY est renseigné c'est que le site de réception est déjà connu ! #
###################################################################################
Subprog DEFBETRCPFCY(WBPCNUM)
Value Char WBPCNUM
Raz GSTOFCY
If !clalev([F:BPD])  Local File BPDLVCUST  [BPD] : Endif
If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
Local File FACILITY [FCYW]
#----- Site d'expédition correspondant au site de réception déjà connu -----#
If GRCPFCY<>""
  For [BPD] BPD1 Where BPCNUM=WBPCNUM & RCPFCY=GRCPFCY & ENAFLG=2
    GSTOFCY=[F:BPD]STOFCY : # Site d'expédition de l'adresse client livré
    Break
  Next
Else
  #----- Site de l'adresse par défaut du client livré -----#
  Read [BPC] BPC0=WBPCNUM : If fstat  Raz [F:BPC] : Endif
  If [F:BPC]BPDADD<>""
    Read [BPD] BPD0=WBPCNUM;[F:BPC]BPDADD
    If !fstat & [F:BPD]ENAFLG=2
      Read [FCYW] FCY0=[F:BPD]RCPFCY : If fstat  Raz [F:FCYW] : Endif
      #----- Doit appartenir à la même société que le site de commande d'achat -----#
      If [F:FCYW]LEGCPY=GSOCIETE
        GRCPFCY=[F:BPD]RCPFCY : # Site de réception de l'adresse client livré
        GSTOFCY=[F:BPD]STOFCY : # Site d'expédition de l'adresse client livré
        Close Local File [FCYW]
        End
      Endif
    Endif
  Endif
  #----- Autres sites du client livré -----#
  For [BPD] BPD0 Where BPCNUM=WBPCNUM & RCPFCY<>"" & ENAFLG=2
    Read [FCYW] FCY0=[F:BPD]RCPFCY : If fstat  Raz [F:FCYW] : Endif
    #----- Doit appartenir à la même société que le site de commande d'achat -----#
    If [F:FCYW]LEGCPY=GSOCIETE
      GRCPFCY=[F:BPD]RCPFCY : # Site de réception de l'adresse client livré
      GSTOFCY=[F:BPD]STOFCY : # Site d'expédition de l'adresse client livré
      Break
    Endif
  Next
Endif
Close Local File [FCYW]
End


########################################################################
# CHARGEMENT de GSOCIETE, GLOCALDEV et de GFINRSP      CG janvier 1998 #
#     - GSOCIETE  : Société courante (Sté du site)                     #
#     - GLOCALDEV : Devise de la société                               #
#     - GFINRSP   : Site financier de la société                       #
#     - GCUR      : Devise de la société (idem GLOCALDEV)              #
########################################################################
Subprog DEFSITE(WSITE)
Value Char WSITE
Call GETDEV(WSITE) From DEVSUB
If GFINRSP="" GFINRSP=WSITE : Endif
GCUR=GLOCALDEV
End


########################################################################
#  CHARGEMENT DES PARAMETRES LIéS AU BUDGET                            #
#  COMMUN POUR LES DA ET COMMANDES OUVERTES  ET CDES CLASSIQUES        #
#                                                       CG JANVIER 1998#
########################################################################
Subprog DEFBUD(TYP,WSITE)
Value Char TYP
Value Char WSITE
#----------------------------------------#
# DEFINITION DES PARAMèTRES POUR BUDGETS #
#----------------------------------------#
Local Char PARAM2(10)

#------ PARAMèTRE ACHAT : MISE à JOUR DES ENGAGEMENTS
#------ PARAMèTRE ACHAT : MISE à JOUR DES PRé-ENGAGEMENTS

GPURCMM    = 1
GPURCMMPRP = 1
GPURCMMDAT = 1
GCTLBUD    = 1
GBUDCTLPOH = 1
GBUDCTLPSH = 1
GBUDCTLPOL = 1
GBUDCTLPSL = 1

If GMODU(2)<>2 End : Endif : # Dossier sans module comptabilité

If TYP = "POH"
       If WSITE = ""
              Call PARAM(GFCYDEF(6),"PURCMM",PARAM2)     From ADOVAL
       Else
               Call PARAM(WSITE,"PURCMM",PARAM2)    From ADOVAL
       Endif
       GPURCMM = val(PARAM2)
Else
       If WSITE = ""
              Call PARAM(GFCYDEF(6),"PURCMMPRP",PARAM2)  From ADOVAL
       Else
             Call PARAM(WSITE,"PURCMMPRP",PARAM2) From ADOVAL
       Endif
       GPURCMMPRP = val(PARAM2)
Endif
#-------- PARAMèTRE UNIQUEMENT COMMANDE Date ENGAGEMENT
#-------- 1 Date COMMANDE OU 2 Date RECPETION PRéVUE
If TYP = "POH"
       If WSITE = ""
              Call PARAM(GFCYDEF(6),"PURCMMDAT",PARAM2)     From ADOVAL
       Else
              Call PARAM(WSITE,"PURCMMDAT",PARAM2)    From ADOVAL
       Endif
       GPURCMMDAT = val(PARAM2)
Endif

#------ PARAMèTRE type DE CONTROLE
GCTLBUD = 0
If TYP = "POH"
     Call PARAM(GFINRSP,"BUDCNTCMM",PARAM2) From ADOVAL
Else
     Call PARAM(GFINRSP,"BUDCNTPRP",PARAM2) From ADOVAL
Endif
GCTLBUD = val(PARAM2)

If GCTLBUD = 4
     #-----------------------------------#
     # Le contrôle est selon l'opérateur #
     #-----------------------------------#
     Call PARAMUTIL("CNTBUD",PARAM2,"",GFINRSP) From SUBAUS
     If val(PARAM2)=1 GCTLBUD=0 Else GCTLBUD=val(PARAM2) : Endif
Endif

#----- PARAMèTRE CONTROLE EN CDE OU DA: OUI/NON
If TYP = "POH"
     Call PARAM(GFINRSP,"BUDCTLPOH",PARAM2) From ADOVAL
     GBUDCTLPOH = val(PARAM2)
Else
     Call PARAM(GFINRSP,"BUDCTLPSH",PARAM2) From ADOVAL
     GBUDCTLPSH = val(PARAM2)
Endif

#----- PARAMèTRE CONTROLE EN LIGNE à LIGNE : OUI/NON
If TYP = "POH"
      Call PARAM(GFINRSP,"BUDCTLPOL",PARAM2) From ADOVAL
      GBUDCTLPOL = val(PARAM2)
Else
      Call PARAM(GFINRSP,"BUDCTLPSL",PARAM2) From ADOVAL
      GBUDCTLPSL = val(PARAM2)
Endif
End


# Issue X3-55891 - 2018-08-07 by MUARN : Composant d'initialisation du fournisseur par défaut
########################################################################
# CHARGEMENT DU FOURNISSEUR PAR DEFEAUT              MUARN 07/08/2018  #
#     - WITMREF    : article                                           #
#     - WPOHFCY    : site commande achats                              #
#     - WFCY       : site réception achats                             #
#     - WSALFCY    : site ventes                                       #
#     - WCTMBPSFLG : contexte de contremarque                          #
#     - WBPSNUM    : fournisseur                                       #
#     - WITMBPS    : fournisseur par défaut trouvé                     #
#                    0 non trouvé                                      #
#                    1 dans ITMBPS                                     #
#                    2 dans ITMBPSFCY                                  #
########################################################################
Subprog DEFBPSNUM(WITMREF,WPOHFCY,WFCY,WSALFCY,WCTMBPSFLG,WBPSNUM,WITMBPS)
Value    Char    WITMREF
Value    Char    WPOHFCY
Value    Char    WFCY
Value    Char    WSALFCY
Value    Integer WCTMBPSFLG
Variable Char    WBPSNUM
Variable Integer WITMBPS

If clalev([F:ITP])=0   Local File ITMBPS     [ITP]   : Endif
If clalev([F:ITPF])=0  Local File ITMBPSFCY  [ITPF]  : Endif
If clalev([F:BPR])=0   Local File BPARTNER   [BPR]   : Endif
If clalev([F:BPS])=0   Local File BPSUPPLIER [BPS]   : Endif

Local Integer WTROUVE : WTROUVE =1

WITMBPS = 0
If WCTMBPSFLG=1
  # fournisseur par défaut non contremarque
  Filter [F:ITPF] Where ITMREF = WITMREF & STOFCY = WFCY & DEFBPSFLG = 2
Else
  # fournisseur par défaut en contremarque
  Filter [F:ITPF] Where ITMREF = WITMREF & STOFCY = WFCY & DEFCTMBPSFLG = 2
Endif
Read [ITPF] ITPF0 First
# article/fournisseur/site par défaut trouvé
If !fstat
  # contrôle fournisseur non site achat ni vente
  Read [BPR] BPR0=[F:ITPF]BPSNUM : If fstat  Raz [F:BPR] : Endif
  If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>WPOHFCY & [F:BPR]FCY<>WFCY & [F:BPR]FCY<>WSALFCY)
    # ce n'est ni le site achats ni le site vente
    # contrôle fournisseur actif, non douteux, non prospect
    Read [BPS] BPS0=[F:ITPF]BPSNUM
    If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
      WTROUVE=2
      WBPSNUM = [F:ITPF]BPSNUM
      WITMBPS = 2
      # lecture de ITP pour les autres données achat
      Read [ITP] ITP0=WITMREF;WBPSNUM
    Endif
  Endif
Endif
# on est en contexte contremarque, on recherche le fournisseur non contremarque par défaut
If WTROUVE=1 & WBPSNUM="" & WCTMBPSFLG=2
  Raz [F:ITPF]
  # article/fournisseur/site par défaut mais non contremarque
  Filter [F:ITPF] Where ITMREF = WITMREF & STOFCY = WFCY & DEFBPSFLG = 2
  Read [ITPF] ITPF0 First
  If  !fstat
    # contrôle fournisseur non site achat ni vente
    Read [BPR] BPR0=[F:ITPF]BPSNUM : If fstat  Raz [F:BPR] : Endif
    If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>WPOHFCY & [F:BPR]FCY<>WFCY & [F:BPR]FCY<>WSALFCY)
      # ce n'est ni le site achats ni le site vente
      # contrôle fournisseur actif, non douteux, non prospect
      Read [BPS] BPS0=[F:ITPF]BPSNUM
      If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
        WTROUVE=2
        WBPSNUM = [F:ITPF]BPSNUM
        WITMBPS = 2
        # lecture de ITP pour les autres données achat
        Read [ITP] ITP0=WITMREF;WBPSNUM
      Endif
    Endif
  Endif
Endif
# recherche dans l'ordre des priorités
If WTROUVE=1 & WBPSNUM=""
  Raz [F:ITPF]
  Filter [ITPF]
  For [ITPF] ITPF1 Where ITMREF =WITMREF & STOFCY =WFCY & DOUFLG<3 & DEFBPSFLG=1 & DEFCTMBPSFLG=1
    # contrôle fournisseur non site achat ni vente
    Read [BPR] BPR0=[F:ITPF]BPSNUM : If fstat  Raz [F:BPR] : Endif
    If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>WPOHFCY & [F:BPR]FCY<>WFCY & [F:BPR]FCY<>WSALFCY)
      # ce n'est ni le site achats ni le site vente
      # contrôle fournisseur actif, non douteux, non prospect
      Read [BPS] BPS0=[F:ITPF]BPSNUM
      If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
        WTROUVE=2
        WBPSNUM = [F:ITPF]BPSNUM
        WITMBPS = 2
        # lecture de ITP pour les autres données achat
        Read [ITP] ITP0=WITMREF;WBPSNUM
        Break
      Endif
    Endif
  Next
Endif
# recherche fournisseur autre, bloqué
If WTROUVE=1 & WBPSNUM=""
  Raz [F:ITPF]
  # recherche fournisseur bloqué
  Filter [ITPF] Where ITMREF=WITMREF & STOFCY =WFCY & DOUFLG =3
  Read [ITPF] ITPF0 First
  If !fstat
    WTROUVE=2
    WITMBPS=0
  Endif
  Raz [ITPF]
Endif

# on ne remonte pas au niveai article/fournisseur si GITMBPSFCY est à obligatoire
# aucun fournisseur au niveau article/fournisseur/site, on recherche au niveau article/fournisseur
If WTROUVE=1 & WBPSNUM="" & GITMBPSFCY > 1
  If WCTMBPSFLG=1
    # fournisseur par défaut non contremarque
    Filter [F:ITP] Where ITMREF = WITMREF & DEFBPSFLG = 2
  Else
    # fournisseur par défaut en contremarque
    Filter [F:ITP] Where ITMREF = WITMREF & DEFCTMBPSFLG = 2
  Endif
  Read [ITP] ITP0 First
  If !fstat
    # contrôle fournisseur non site achat ni vente
    Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : Endif
    If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>WPOHFCY & [F:BPR]FCY<>WFCY & [F:BPR]FCY<>WSALFCY)
      # ce n'est ni le site achats ni le site vente
      # contrôle fournisseur actif, non douteux, non prospect
      Read [BPS] BPS0=[F:ITP]BPSNUM
      If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
        WTROUVE = 2
        WBPSNUM = [F:ITP]BPSNUM
        WITMBPS = 1
      Endif
    Endif
  Endif
  # on est en contexte contremarque, on recherche le fournisseur non contremarque par défaut
  If WTROUVE=1 & WBPSNUM="" & WCTMBPSFLG=2
    Raz [ITP]
    Filter [F:ITP] Where ITMREF = WITMREF & DEFBPSFLG = 2
    Read [ITP] ITP0 First
    If !fstat
      # contrôle fournisseur non site achat ni vente
      Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : Endif
      If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>WPOHFCY & [F:BPR]FCY<>WFCY & [F:BPR]FCY<>WSALFCY)
        # ce n'est ni le site achats ni le site vente
        # contrôle fournisseur actif, non douteux, non prospect
        Read [BPS] BPS0=[F:ITP]BPSNUM
        If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
          WTROUVE = 2
          WBPSNUM = [F:ITP]BPSNUM
          WITMBPS = 1
        Endif
      Endif
    Endif
  Endif
  # recherche dans l'ordre des priorités
  If WTROUVE=1 & WBPSNUM=""
    Raz [F:ITP]
    Filter [F:ITP]
    For [ITP] ITP1 Where ITMREF=WITMREF & DEFBPSFLG=1 & DEFCTMBPSFLG=1 & DOUFLG<3
      Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : Endif
      If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>WPOHFCY & [F:BPR]FCY<>WFCY & [F:BPR]FCY<>WSALFCY)
        # ce n'est ni le site achats ni le site vente
        # contrôle fournisseur actif, non douteux, non prospect
        Read [BPS] BPS0=[F:ITP]BPSNUM
        If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
          WTROUVE = 2
          WBPSNUM = [F:ITP]BPSNUM
          WITMBPS = 1
          Break
        Endif
      Endif
    Next
  Endif
Endif
If WTROUVE=1
  Raz [F:ITP]
  Raz [F:ITPF]
Endif
Filter [F:ITPF]
Filter [F:ITP]
End

# Issue X3-55891 - 2018-08-10 by MUARN : Composant de recherche article/fournisseur/site ou article/fournisseur
###########################################################################
# LECTURE ARTICLE/FOURNISSEUR/SITE ARTICLE/FOURNISSEUER MUARN 08/08/2018  #
#     - WITMREF    : article                                              #
#     - WBPSNUM    : fournisseur                                          #
#     - WFCY       : site                                                 #
#     - WITMBPS    : fournisseur par défaut trouvé                        #
#                    0 non trouvé                                         #
#                    1 dans ITMBPS                                        #
#                    2 dans ITMBPSFCY                                     #
###########################################################################
Subprog FIND_ITMBPSFCY_ITMBPS(WITMREF,WBPSNUM,WFCY,WITMBPS)
Value    Char    WITMREF
Value    Char    WBPSNUM
Value    Char    WFCY
Variable Integer WITMBPS

If clalev([F:ITP])=0   Local File ITMBPS     [ITP]   : Endif
If clalev([F:ITPF])=0  Local File ITMBPSFCY  [ITPF]  : Endif

WITMBPS = 0
If [F:ITPF]ITMREF<>WITMREF | [F:ITPF]BPSNUM<>WBPSNUM | [F:ITPF]STOFCY<>WFCY
  Read [ITPF] ITPF0=WITMREF;WBPSNUM;WFCY
  If fstat
    Raz [F:ITPF]
    If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPSNUM
      Read [ITP] ITP0=WITMREF;WBPSNUM
      If fstat
        Raz [F:ITP]
      Else
        WITMBPS = 1
      Endif
    Else
      WITMBPS = 1
    Endif
  Else
    WITMBPS = 2
    If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPSNUM
      Read [ITP] ITP0=WITMREF;WBPSNUM
      If fstat : Raz [F:ITP] : Endif
    Endif
  Endif
Else
  WITMBPS = 2
  If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPSNUM
    Read [ITP] ITP0=WITMREF;WBPSNUM
    If fstat : Raz [F:ITP] : Endif
  Endif
Endif

End

