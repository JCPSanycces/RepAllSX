Local Decimal BASPAG
Local Char    PARMSK(250)(1..20) , SAVACT(20)
GACTION = "SAISTACPY"
Call SAISIE_NUM(BASPAG,PARMSK,"DSTACPY","SAISTACPY","") From GSAISIE
End
#*********************************************************************

$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "BOUTON"      : Gosub BOUTON
    When Default
  Endcase
Return

$OUVRE
  If !clalev([CPY]) : Local File COMPANY    [CPY] : Endif
  If !clalev([CNX]) : Local File CONTEXT    [CNX] : Endif
  If !clalev([FIS]) : Local File FISCYEAR   [FIS] : Endif
  If !clalev([FAS]) : Local File FXDASSETS  [FAS] : Endif
  If !clalev([DEP]) : Local File DEPREC     [DEP] : Endif
Return

$DEBUT
  Raz [M:STA]
  nolign = 1

  Local Integer NBR_CPY : NBR_CPY = rowcount([F:CPY])
  Local Decimal RCPY    : RCPY  = 0
  Local Integer INTERRUPT
  Local Integer WCNXERR # FQ93731
  Local Char WSOCERR(10), WMESS(250) # FQ93731

  If NBR_CPY > 1 Then
    Call OUVRE_BOITE(mess(90,151,1),NBR_CPY) From GESECRAN
  Else
    Call TEMPON("L") From GESECRAN
  Endif

  For [CPY]
    If NBR_CPY > 1 Then
      RCPY += 1
      Call AFF_BOITE([F:CPY]CPY-[F:CPY]CPYNAM,RCPY,INTERRUPT) From GESECRAN
    Endif

    [M:STA]CPY(nolign-1) = [F:CPY]CPY

    For [CNX] Where CPY=[F:CPY]CPY
      [M:STA]CPYC(nolign-1) = [F:CNX]CPY
      [M:STA]CNX(nolign-1)  = [F:CNX]CNX

      Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA

      [M:STA]PERSTRDAT(nolign-1)=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      [M:STA]PERENDDAT(nolign-1)=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)

      Gosub DETERM_STATUT_INACTIF
      Gosub DETERM_STATUT_CALCUL
      Gosub DETERM_STATUT_COMPTABILISE
      Gosub DETERM_STATUT_CONCESSION
      Gosub DETERM_STATUT_FLUX
      Gosub DETERM_STATUT_CLOTURE
      # FQ93731
      [M:STA]CNXERR(nolign-1) = func SUBCNX2.CTRL_CNX ([F:CNX]CPY, [F:CNX]CNX, 0, WSOCERR, WCNXERR, WMESS)

      nolign +=1
    Next
  Next

  [M:STA]NB_CPY = nolign-1

  If NBR_CPY > 1 Then
    Call FERME_BOITE() From GESECRAN
  Else
    Call TEMPOFF From GESECRAN
  Endif

  Gosub AFFICHE_INFOS_LICENCE : # FQ61310

  Affzo [M:STA]

  Gosub COLORISATION
Return

$BOUTON
  Case BOUT
    When "1" : Gosub DEBUT
    When Default
  Endcase
Return

$DETERM_STATUT_INACTIF
  # Y-a-t'il des biens inactifs dans la société ?
  Look [FAS]FAS7=[F:CPY]CPY;G_NON

  If fstat
    [M:STA]FLGDISAFAS(nolign-1)=G_NON
    [M:STA]ICODISAFAS(nolign-1)="128"
    Return
  Endif

  [M:STA]FLGDISAFAS(nolign-1)=G_OUI
  [M:STA]ICODISAFAS(nolign-1)="127"
Return

$DETERM_STATUT_CALCUL
  If  (func GLOBIENS.IS_CNX_CALCULATE([F:CNX]CPY, [F:CNX]CNX, [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_OUI)
& and (G_ACTCCN <> G_OUI or [F:CNX]CCNFLG <> G_OUI or func GLOCCN.IS_RPR_CALCULATE([F:CNX]CPY) = G_OUI) Then
    [M:STA]FLGCALC(nolign-1) = G_OUI
    [M:STA]ICOCALC(nolign-1) = "128"
  Else
    [M:STA]FLGCALC(nolign-1) = G_NON
    [M:STA]ICOCALC(nolign-1) = "127"
  Endif
Return

$DETERM_STATUT_COMPTABILISE
  Local Integer TYP
  Local Char    TLSTEVTTYP(1)
  Local Integer TLSTPLN(1)
  Local Integer TLSTNBE(1)
  Local Integer RET
  Local Integer N_I

  If [F:FIS]DATENDFIY = [F:FIS]DATENDPER([F:FIS]INDCURPER-1) Then
    TYP = 2 : # contrôle sur l'exercice
  Else
    TYP = 1 : # contrôle sur la période courante
  Endif

  If  (func GLOBIENS.IS_ALL_PER_POSTED([F:CNX]CPY, [F:CNX]CNX, [F:FIS]DATENDFIY) = G_NON)
    [M:STA]FLGCPT(nolign-1) = G_NON
    [M:STA]ICOCPT(nolign-1) = "127"
    Return
  Endif

  If (func GLOBIENS.IS_CNX_POSTED([F:CNX]CPY,
&                                 [F:CNX]CNX,
&                                 [F:FIS]DATENDFIY,
&                                 [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON)
    [M:STA]FLGCPT(nolign-1) = G_NON
    [M:STA]ICOCPT(nolign-1) = "127"
    Return
  Endif

  If (func GLOLNK.IS_LNK_POSTED([F:CNX]CPY,
&                               [F:CNX]CNX,
&                               [F:FIS]DATENDFIY,
&                               [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON)
    [M:STA]FLGCPT(nolign-1) = G_NON
    [M:STA]ICOCPT(nolign-1) = "127"
    Return
  Endif

  # FQ84664 : ajout de [F:CPY]LEG
  If ((TYP = 2) and (func GENEVE.CTRL_ALL_EVT_CPT([F:CPY]LEG,
&                                                 [F:CNX]CPY,
&                                                 [F:CNX]CNX,
&                                                 TYP,
&                                                 1,
&                                                 "",
&                                                 TLSTEVTTYP,
&                                                 TLSTPLN,
&                                                 TLSTNBE,
&                                                 RET,
&                                                 [0/0/0], [0/0/0]) = G_NON))
    [M:STA]FLGCPT(nolign-1) = G_NON
    [M:STA]ICOCPT(nolign-1) = "127"
    Return
  Endif

  If ((TYP = 2) and (func GLOBIENS.IS_CNX_POSTED_ISS_FUTURE([F:CNX]CPY,[F:CNX]CNX) = G_NON))
    [M:STA]FLGCPT(nolign-1) = G_NON
    [M:STA]ICOCPT(nolign-1) = "127"
    Return
  Endif

  If ((TYP = 2) and (func GLOLNK.IS_LNK_POSTED_ISS_FUTURE([F:CNX]CPY,[F:CNX]CNX) = G_NON))
    [M:STA]FLGCPT(nolign-1) = G_NON
    [M:STA]ICOCPT(nolign-1) = "127"
    Return
  Endif

  If (G_ACTCCN = G_OUI) : # FQ65817
    If ([F:CNX]CCNFLG = G_OUI and
&                   (func GLOCCN.IS_CPY_RPR_POSTED([F:CNX]CPY, [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON)
&                     or ((TYP = 2) and (func GLOCCN.IS_RPR_POSTED_ISS_FUTURE([F:CNX]CPY) = G_NON))) Then
      [M:STA]FLGCPT(nolign-1) = G_NON
      [M:STA]ICOCPT(nolign-1) = "127"
      Return
    Endif
  Endif

  [M:STA]FLGCPT(nolign-1) = G_OUI
  [M:STA]ICOCPT(nolign-1) = "128"
Return

$DETERM_STATUT_CONCESSION
  Local Shortint IS_BCO_NOT_RNW, IS_RNWOP_NOT_DONE, IS_CCNEND_NOT_DONE

  If G_ACTCCN <> G_OUI : Return : Endif

  Local Integer TYP

  If [F:CNX]CCNFLG <> G_OUI
    [M:STA]FLGCCN(nolign-1) = G_OUI
    [M:STA]ICOCCN(nolign-1) = ""
    Return
  Endif

  If [F:FIS]DATENDFIY = [F:FIS]DATENDPER([F:FIS]INDCURPER-1) Then
    TYP = 2 : # contrôle sur l'exercice
  Else
    TYP = 1 : # contrôle sur la période courante
  Endif

  IS_BCO_NOT_RNW     = func GLOCCN.IS_BCO_NOT_RNW([F:CNX]CPY)
  IS_RNWOP_NOT_DONE  = func GLOCCN.IS_RNWOP_NOT_DONE([F:CNX]CPY)
  IS_CCNEND_NOT_DONE = func GLOCCN.IS_CCNEND_NOT_DONE([F:CNX]CPY)

  If TYP = 2
    # Clôture Exercice
    If IS_BCO_NOT_RNW = G_OUI or IS_RNWOP_NOT_DONE = G_OUI
      [M:STA]FLGCCN(nolign-1) = G_NON
      [M:STA]ICOCCN(nolign-1) = "127"  : # rouge
    Elsif IS_CCNEND_NOT_DONE = G_OUI
      [M:STA]FLGCCN(nolign-1) = G_OUI
      [M:STA]ICOCCN(nolign-1) = "129"  : # jaune
    Else
      [M:STA]FLGCCN(nolign-1) = G_OUI
      [M:STA]ICOCCN(nolign-1) = "128"  : # vert
    Endif
  Else
    # Clôture Période
    If IS_BCO_NOT_RNW = G_OUI or IS_RNWOP_NOT_DONE = G_OUI or IS_CCNEND_NOT_DONE = G_OUI
      [M:STA]FLGCCN(nolign-1) = G_OUI
      [M:STA]ICOCCN(nolign-1) = "129"  : # jaune
    Else
      [M:STA]FLGCCN(nolign-1) = G_OUI
      [M:STA]ICOCCN(nolign-1) = "128"  : # vert
    Endif
  Endif
Return

$DETERM_STATUT_FLUX
  [M:STA]FLGFLX(nolign-1)=0

  # Y-a t'il au moins un plan du contexte qui gère les flux ?
  For N_P = 0 To [F:CNX]NBPLC-1
    If ( [F:CNX]FLUTRATXS(N_P) <> '' ) or ( [F:CNX]FLUTRAACC(N_P) = G_OUI ) Then
      [M:STA]FLGFLX(nolign-1)=G_OUI
      Break
    Endif
  Next

  If [M:STA]FLGFLX(nolign-1)=G_OUI and [M:STA]FLGCALC(nolign-1)=G_NON Then
    [M:STA]FLGFLX(nolign-1)=G_NON
  Endif
Return

$DETERM_STATUT_CLOTURE
  Local Integer STATUT_CIG                 : STATUT_CIG = 0
  Local Integer STATUT_COHERENCE_COMPTA    : STATUT_COHERENCE_COMPTA = 0
  Local Integer STATUT_BIENS_CLASSES_VENTE : STATUT_BIENS_CLASSES_VENTE = 0 : # FQ95754

  Call CONTROLE_CIG([F:CPY]CPY, 2, STATUT_CIG) From GLOBIENS

  If func GLOBIENS.ACCPERCTL([F:CNX]CPY) : # FQ70465
    # FQ105514
    Local Shortint N_PLN
    For N_PLN = 0 To [F:CNX]NBPLC-1
      If func GLOBIENS.PERCPT_STATE([F:CNX]CPY, [F:CNX]LEDTYP(N_PLN), [F:FIS]DATENDPER([F:FIS]INDCURPER-1)+1) <> 2
        STATUT_COHERENCE_COMPTA = 1
        Break
      Endif
    Next
  Endif

  # FQ95754 : Y-a-t il des biens classés pour vente non sortis en fin d'exercice ?
  If [F:FIS]DATENDFIY = [F:FIS]DATENDPER([F:FIS]INDCURPER-1) Then
    If func GLOBIENS.HAS_FAS_SALCLS([F:CNX]CPY, [F:FIS]DATENDFIY) = G_OUI
      STATUT_BIENS_CLASSES_VENTE = 1
    Endif
  Endif

  If  [M:STA]FLGDISAFAS(nolign-1)=G_NON
& and [M:STA]FLGCALC(nolign-1)=G_OUI
& and [M:STA]FLGCPT(nolign-1)=G_OUI
& and ((G_ACTCCN<>G_OUI) or (G_ACTCCN=G_OUI and [M:STA]FLGCCN(nolign-1)=G_OUI))
& and STATUT_CIG=0
& and STATUT_COHERENCE_COMPTA=0
& and STATUT_BIENS_CLASSES_VENTE=0 Then
    [M:STA]FLGCLOT(nolign-1)=G_OUI
  Else
    [M:STA]FLGCLOT(nolign-1)=G_NON
  Endif
Return

$COLORISATION
  Local Integer N_I

  For N_I = 0 To [M:STA]NB_CPY-1
    # FQ93731 ajout de and [M:STA]CNXERR(nolign-1) = 0
    If ([M:STA]FLGFLX(N_I) = G_OUI or [M:STA]FLGFLX(N_I) = 0) and [M:STA]FLGCLOT(N_I) = G_OUI and [M:STA]CNXERR(N_I) = 0 Then
      # Pas de flux ou flux OK et clôture OK
      Chgstl [M:STA]CNX(N_I) With "BACKGREEN"
    Elsif [M:STA]FLGFLX(N_I) = G_OUI or [M:STA]FLGCLOT(N_I) = G_OUI or [M:STA]CNXERR(N_I) Then
     # FQ93731 ajout de or [M:STA]CNXERR(nolign-1)
      # Pas de flux ou flux OK ou clôture OK ou erreur sur le contexte # FQ93731
      Chgstl [M:STA]CNX(N_I) With "BACKYELLOW"
    Else
      Chgstl [M:STA]CNX(N_I) With "" #"BACKRED"
    Endif
    If [M:STA]FLGFLX(N_I) =G_OUI : Chgstl [M:STA]FLGFLX(N_I)  With "BACKGREEN" : Endif
    If [M:STA]FLGCLOT(N_I)=G_OUI : Chgstl [M:STA]FLGCLOT(N_I) With "BACKGREEN" : Endif
  Next N_I
Return

#################################################### FQ61310
# Affiche les informations "biens licence" / "biens gérés"
$AFFICHE_INFOS_LICENCE
  #Local Integer FASMAX                		 : # FQ97426
  #Call NOMBRE(1,[L]FASMAX) From GLOCK 		 : # FQ97426
  #[M:STA]FASMAX = [L]FASMAX           		 : # FQ97426
  [M:STA]FASMAX = func TRTLIC.GET_FASMAX() : # FQ97426
  [M:STA]FASCNT = func TRTLIC.LEC_NOMBCO()

  Filter [FAS] Where ISSTYP<>GVML_TSCIG and ISSTYP<>GVML_TSAPPOR and
&                    ISSTYP<>GVML_TSFUSIO and ISSTYP<>GVML_TSSCISS and
&                    ENAFAS=[V]CST_AYES # Issue 116395

  [M:STA]FASDOS = rowcount([F:FAS])
  Filter [FAS]
Return

