Subprog AV_COL000(VALEUR)
Variable Char    VALEUR()
If nolign > 0
  Case nolign
    When 1,2,8,9,10,11,12 :
      pcolor = GCOUL(1)
    When 4,5,6 :
      pcolor = GCOUL(3)
    When Default :
      pcolor = GCOUL(0)
  Endcase
Endif
End
############################################################
# Routine de calcul de la date de première disponibilité
# LFCY    = Site
# LITM    = Article
# LDAT    = Date de 1ère disponibilité
# LQTY    = Quantité disponible
#
# Le calcul est identique au calcul fait lors de l'affichage du stock disponible
# -    Calcul du disponible sur 20 semaines à partir de la date du jour
# -    Traitement de l'horizon de la demande
# -    Stock de départ : Stock physique - Stock chez les tiers + Transferts en cours
# -    Imputation des allocations à date
# -    Pas de prise en compte de l'alloué global
#
Subprog FIRAVADAT(LFCY,LITM,LDAT,LQTY)
Value     Char    LFCY
Value     Char    LITM
Variable  Date    LDAT
Variable  Decimal LQTY
Local     Integer WCOLSDI      : WCOLSDI = 20 : # Nombre de colonnes (idem masque SDI2)
Local     Integer WNBL      : WNBL = 18 : # Nombre de lignes +1
# Issue 107498/9 _increase size of array
Local     Integer WNBT      : WNBT = 15 : # Nombre de types d'ordres +1
Local     Integer WSEM      : WSEM = 1  : # Premier jour ouvré semaine
#
Local     Char    WPAR(1)
Local     Char    WFCY(GLONFCY)
Local     Integer WPER
Local     Integer WLPER
Local     Integer WSEL
Local     Date    WREF
Local     Char    WITM(GLONITM)
Local     Integer WCHO
Local     Date    WDATD(WCOLSDI)
Local     Date    WDATF(WCOLSDI)
#
Local     Date    WDTE
Local     Date    WDTED
Local     Date    WDTEF
Local     Integer WSEMD
Local     Integer WSEMF
Local     Integer WYEA
Local     Integer WMON
Local     Integer WSEM
#
Local     Integer WCOR
Local     Decimal WDEL
Local     Integer WCOD
Local     Date    WDAT
Local     Decimal WDMYI
Local     Date    WDMYD
Local     Date    WFOH
# Cumuls par type / date / statut / signe (type 0 = alloué)
Local     Integer ITYP
Local     Integer IDAT
Local     Integer ISTA
Local     Integer ISIG
Local     Decimal TCUM(WNBT,WCOLSDI,5,2) : # Cumuls par type d'ordre, date, statut, signe
Local     Decimal TLIG(WNBL,WCOLSDI)     : # Cumuls lignes
Local     Char    TTAB(80)(WNBL)      : # Contenu des lignes
Local     Integer WLNE(WNBL)          : # Titres lignes
Local     Char    WTAB(100)
Local     Char    WZON(5)
Local     Integer WLIN
#
Local     Decimal WQTY
Local     Decimal WTRF
Local     Decimal WBES
Local     Decimal WALL
Local     Integer WALLFLG
Local     Integer WGLOFLG
Local     Integer WSHRFLG
Local     Integer I, J

If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
If clalev([F:STA]) = 0 : Local File STOALL     [STA] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif

# FQ 55414 GA for Sage UK Read MRP parameters to see if Forecast offset
If clalev([F:PCB]) = 0 : Local File PARMRP[PCB] : Endif
If dim(WHORDEM)<0        Local Integer WHORDEM       : Endif
If dim(TALL)<0           Local Decimal TALL(WCOLSDI) : Endif
If dim(ZALL)<0           Local Decimal ZALL          : Endif  # FQ 60307 GA 12/2009 avant dim(WALL)
#
Call PARAM(LFCY,"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
  WSEM = 1
Else
  WSEM = val(WPAR)
Endif
If WSEM = 1
  WCOR = 7
Else
  WCOR = WSEM-1
Endif
# Lecture article site
Read [ITF]ITF1=LFCY;LITM
If fstat
  Raz [F:ITF]
Endif
# FQ 55414 GA Dde Sage UK Read MRP parameters to see if Forecast offset
If LFCY <> ""
 Read [PCB]PCB0 = LFCY
 If fstat WHORDEM = 1
 Else
     Case [F:ITF]REOMGTCOD
     When 2 :       WHORDEM = [F:PCB]MRPHORDEM
     When 3 :       WHORDEM = [F:PCB]MPSHORDEM
     When Default : WHORDEM = 1
     Endcase
 Endif
Endif
#
# Lecture cumuls stocks
Read [ITV]ITV1=LFCY;LITM
If fstat
  Raz [F:ITV]
Endif
#
#Calcul date fin horizon demande arrondi fin semaine
If [F:ITF]FOH = 0
  WFOH = [0/0/0]
Else
  If WSEM = 1
    WCOR = 7
  Else
    WCOR = WSEM-1
  Endif
  WCOD = [F:ITF]FOHUOT
  WDEL = [F:ITF]FOH
  WDAT = date$
  Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,WDMYI,WDMYD,WFOH)
&        From CBNLIB
Endif
# Calcul des buckets en semaine
WDATD(0) = [0/0/0]
WDATF(0) = date$-1
If dayn(date$) = WSEM
  WDATD(1) = date$
  WDATF(1) = date$+6
Else
  WDATD(1) = date$
  WDATF(1) = date$
  While dayn(WDATF(1)) <> WCOR
    WDATF(1) += 1
  Wend
Endif
For I = 2 To WCOLSDI-1
  WDATD(I) = WDATF(I-1)+1
  WDATF(I) = WDATF(I-1)+7
Next I
#
Gosub MEI_CONSTANTES
#
#--- Issue 112817
GPE=0
GPOINT="FILTER_ORD" : Gosub ENTREE From EXEFNC
If GPE=0
   Filter [ORD] Where STOFCY=LFCY & ITMREF=LITM & FMI<2
&               Order By Key ORD1
Endif
#Filter [ORD] Where STOFCY = LFCY      &
#&                  ITMREF = LITM      &
#&                  FMI    < 2
#&            Order By Key ORD1
#---
For [ORD]
  ITYP    = [F:ORD]WIPTYP
  ISTA    = [F:ORD]WIPSTA
  WALLFLG = 1
  WGLOFLG = 1
  WSHRFLG = 2
  Gosub TRT_CUMUL
Next
Filter [ORD]
# Traitement horizon demande : effacement SOS dans horizon / + grande valeur au delà
If WFOH <> [0/0/0]
  For IDAT = 0 To WCOLSDI-1
    If WDATD(IDAT) <= WFOH
      TCUM(1,IDAT,3,0) = 0
    Else
      If TCUM(1,IDAT,3,0) > TCUM(1,IDAT,1,0)
        TCUM(1,IDAT,3,0) = TCUM(1,IDAT,3,0) - TCUM(1,IDAT,1,0)
      Else
        TCUM(1,IDAT,3,0) = 0
      Endif
    Endif
  Next IDAT
Endif
# Préparation du tableau
For WLIN = 0 To WNBL-1
  WTAB = TTAB(WLIN)
  Gosub CUM_COL
Next WLIN

# Stock de départ 140 : Physique + en rangement + en transit - sorties en attente
WQTY = [F:ITV]PHYSTO+[F:ITV]PLFPHYSTO+[F:ITV]TRFSTO-[F:ITV]WAISTO

# Recherche diponible
Raz LDAT, LQTY
For IDAT = 0 To WCOLSDI-1
  WQTY += TLIG(2,IDAT)
  WQTY -= TLIG(0,IDAT)
  WQTY -= TLIG(1,IDAT)
  TLIG(3,IDAT) = WQTY
  If WQTY > 0 & LDAT = [0/0/0] & IDAT > 0
    LDAT = WDATD(IDAT)
    LQTY = WQTY
  Endif
Next IDAT
End
#
############################################################
Subprog AV_INTFLD(VALEUR)
Variable Char    VALEUR()
Call AV_INTFLD(VALEUR) From VISUITF
End


