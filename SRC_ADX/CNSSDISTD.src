#<AdxTL>@(#)6.0.0.0 $Revision$ Consultation SFC
# Issue 107498 - 2016-03-02 by BK : Add project demand to enquiry

$ACTION
Case GACTION
    When "CONSSDI"
        Case ACTION
          When "AUTORIS"    : Gosub AUTORIS
          When "FERME"      : Gosub FERME
          When "OUVRE"      : Gosub OUVRE
          When "SETBOUT"    : Gosub SETBOUT
          When "LECTURE"    : Gosub LECTURE
          When "DEB_CRIT"   : Raz [M:CSDI] : Transmask [M:SDI1] To [M:CSDI]# Issue 25606 [M:CSDI] = [M:SDI1]
          When "FIN_CRIT"   : [M:SDI1] = [M:CSDI]
          When Default
        Endcase
#MAE, bg 49555
    When "ASNBLIGSDI"
         Case ACTION
          When "TRT_DIV"    : Gosub TRT_DIV
         Endcase
    When "FGRAPHSDI"
        Case ACTION
          When "OUVRE"      : Gosub OUVRE_FGRAPHSDI
          When "DEBUT"      : Gosub DEBUT_FGRAPHSDI
          When "TITRE"
                #TIT=mess(287,195,1)-[F:ITM]ITMREF -"  "-[F:ITM]ITMDES1    # hcb graphique
                Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189
                Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
                TIT=mess(287,195,1)-[F:ITM]ITMREF -"  "-WITMDES    # hcb graphique                   # FGR 30/06/2009 : X3SUIVI56189
        Endcase
Endcase
Return

############################################################
$TRT_DIV
Case TRAIT
  When "ASNBLIG" :  Gosub GEN_FILTRE
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
#
Local    Integer WCOLSDI   : WCOLSDI = 26 : # Nombre de colonnes (idem masque SDI2) # FQ 55414 GA for Sage UK avant (20)
Local    Integer WNBL      : WNBL = 18 : # Nombre de lignes +1
# Issue 107498/9 _increase size of array
Local    Integer WNBT      : WNBT = 15 : # Nombre de types d'ordres +1
Local    Integer WSEM      : WSEM = 1  : # Premier jour ouvré semaine
Local    Integer WGCONSULT : WGCONSULT = GCONSULT
Global   Char    GSCOLDES(20)(WCOLSDI)
Global   Decimal TLIG(WNBL,WCOLSDI)    : # Cumuls lignes
Global   Decimal TALL(WCOLSDI)  : # FQ 55414 GA for Sage UK Accumulated Sales Allocations
Global   Decimal ZALL           : # FQ 55414 GA for Sage UK Record Allocated qty
#
Local Char       WPAR(1)
Local Integer    CHOIX
Local Integer    WFSTAT
Local Integer    WBOU(1..GNBBOU)
#
Local Char       WFCY(GLONFCY)
Local Integer    WPER
Local Integer    WLPER
Local Integer    WSEL
Local Date       WREF
Local Char       WITM(GLONITM)
Local Integer    WCHO
Local Date       WDATD(WCOLSDI)
Local Date       WDATF(WCOLSDI)
#
Local Date       WDTE
Local Date       WDTED
Local Date       WDTEF
Local Integer    WSEMD
Local Integer    WSEMF
Local Integer    WYEA
Local Integer    WMON
Local Integer    WSEMNB                # 08.07 42722
Local Integer    WLTI
#
Local Integer    WCOR
Local Decimal    WDEL
Local Integer    WCOD
Local Date       WDAT
Local Decimal    WDMYI
Local Date       WDMYD
# Cumuls par type / date / statut / signe (type 0 = alloué)
Local Integer    ITYP
Local Integer    IDAT
Local Integer    ISTA
Local Integer    ISIG
Local Char       WINT(30)(40)
Local Decimal    TCUM(WNBT,WCOLSDI,5,2) : # Cumuls par type d'ordre, date, statut, signe
Local Char       TTAB(120)(WNBL)         : # Contenu des lignes
Local Integer    WLNE(WNBL)             : # Titres lignes
Local Char       WTAB(120)
Local Char       WZON(5)
Local Integer    WLIN
#
Local Decimal    WQTY
Local Decimal    WTRF
Local Decimal    WBES
Local Decimal    WALL
Local Integer    WALLFLG
Local Integer    WGLOFLG
Local Integer    WSHRFLG
Local Integer    WGLO
Local Integer    I, J, K
#
Local Char       WFILS(250), WFILSPE(250)
Local Char       WFILEXY(250)
#
Local Char       WEVA(80)
Local Char       WFLD(30)
Local Char       WDIRECT(GLONVCR)   # hcb 107209
Local Char       WDOCU  (GLONVCR)   # hcb 107209
# Ouvertures fichiers
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITV1])= 0 : Local File ITMMVT     [ITV1]: Endif
If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif
If clalev([F:STA]) = 0 : Local File STOALL     [STA] : Endif
If clalev([F:QLH]) = 0 : Local File STOQLYH    [QLH] : Endif
If clalev([F:QLD]) = 0 : Local File STOQLYD    [QLD] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY  [SLF] : Endif
If GMODU(5)=2
  If clalev([F:SDD]) = 0 : Local File SDELIVERYD [SDD] : Endif
  If clalev([F:SID]) = 0 : Local File SINVOICED  [SID] : Endif
Endif
NAVIG="CONSSDI"
#
# FQ 55414 GA for Sage UK Read MRP parameters to see if Forecast offset
Local Integer    WHORDEM
If clalev([F:PCB]) = 0 : Local File PARMRP[PCB] : Endif
#
Gosub LOAD_SCREEN
Gosub MEI_CONSTANTES
# Lecture paramètre premier jour ouvré
Call PARAM(GFCYDEF(0),"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
  WSEM = 1
Else
  WSEM = val(WPAR)
Endif
Gosub CAL_COLONNES
#
#MAE, si on vient de la recherche tarif (achat ou vente), la date de ref est celle saisie ds la recherche
If GFONC1="FUNPPSI"
         [M:SDI1]REFPER = [M:PPM0]ORDDAT
Elsif GFONC1 = "FUNVSPSI"
        [M:SDI1]REFPER = [M:SPM0]ORDDAT
    Affzo [M:SDI1]REFPER
Endif
#
SUITE = 1
RETOUR = 1
Return

############################################################
$SETBOUT
If [M:SDI2]NBLIG = 0 : Call VIREBOUT(CHAINE,"g") From GOBJET : Endif
#If GBROWS : Call VIREBOUT(CHAINE,"G") From GOBJET : Endif
Return

############################################################
$LOAD_SCREEN

For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SDI1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SDI1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
# hcb 91186  deb
If dim([M:SDI1]SCOSTOFLG) > 0
   [M:SDI1]SCOSTOFLG = 2
Endif
#
If dim([M:SDI1]SCCSTOFLG) > 0
   [M:SDI1]SCCSTOFLG = 2
Endif
# hcb 91186  fin


If clalev([M:CSDI]) <> 0 & [M:CSDI]MEMO = "STD"
  [M:SDI1] = [M:CSDI]
Else
  [M:SDI1]PERCOD = 2
Endif
# Initialisation selection ajoutée
If [M:SDI1]MRPFLG = 0 : [M:SDI1]MRPFLG = 3 : Endif
#
[M:SDI1]REFPER = date$
Raz [M:SDI1]WTYP
[M:SDI1]WTYP(0) = 2
[M:SDI1]WTYP(1) = 2
[M:SDI1]WTYP(2) = 2
[M:SDI1]WTYP(3) = 2
[M:SDI1]WTYP(4) = 1
[M:SDI1]WTYP(5) = 2
[M:SDI1]WTYP(6) = 2
[M:SDI1]WTYP(7) = 2
[M:SDI1]WTYP(8) = 2
[M:SDI1]WTYP(9) = 2
[M:SDI1]WTYP(10) = 1
[M:SDI1]WTYP(11) = 1
[M:SDI1]WTYP(12) = 1
[M:SDI1]WTYP(13) = 2
# hcb 91186  deb
#If dim([M:SDI1]SCOSTOFLG) > 0
#   [M:SDI1]SCOSTOFLG = 2
#Endif
#
#If dim([M:SDI1]SCCSTOFLG) > 0
#   [M:SDI1]SCCSTOFLG = 2
#Endif
# hcb 91186  fin

Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LECTURE
# MHB 13/03/09 : accès depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:SDI1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:SDI1]ITMREF
        Diszo [M:SDI1]FCY
    Endif
Endif

Raz [M:SDI2]
NBLU   = 2
nolign = 0
If [M:SDI1]ITMREF = "" | [M:SDI1]FCY = ""
  NBLU = 0
  Goto LECTURE_FIN
Endif
nolign = 0
# Chargement types d'ordre et statuts
For I = 1 To dim([M]ABRTYP)-1
  [M]ABRTYP(I) = mess(I,341,1)
Next I
For I = 1 To dim([M]ABRSTA)-1
  [M]ABRSTA(I) = mess(I,342,1)
Next I
# Lecture paramètre premier jour ouvré
Call PARAM([M]FCY,"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
  WSEM = 1
Else
  WSEM = val(WPAR)
Endif
Gosub CAL_COLONNES
# Lecture ITMMASTER
Read [ITM]ITM0=[M:SDI1]ITMREF
If fstat
  Raz [F:ITM]
  Goto LECTURE_FIN
Endif
# Lecture unité stock
Read [TUN]TUN0=[F:ITM]STU
If fstat
  Raz [F:TUN]
Endif

#--- Dem 68319
[M:SDI1] = [F:ITM]

[M:SDI1]STU       = [F:ITM]STU
[M:SDI2]STU       = [F:ITM]STU
# Lecture article - site
If [M:SDI1]FCY <> ""
  Read [ITF]ITF0=[M:SDI1]ITMREF;[M:SDI1]FCY
  If fstat
    Raz [F:ITF]
  Endif
  # FQ 55414 GA for Sage UK Read MRP parameters to see if Forecast offset
  If [M:SDI1]FCY <> ""
     Read [PCB]PCB0 = [M:SDI1]FCY
     If fstat WHORDEM = 1
     Else
         Case [F:ITF]REOMGTCOD
         When 2 :       WHORDEM = [F:PCB]MRPHORDEM
         When 3 :       WHORDEM = [F:PCB]MPSHORDEM
         When Default : WHORDEM = 1
         Endcase
     Endif
  Endif
#Calcul date fin horizon demande arrondi fin semaine
  If [F:ITF]FOH = 0
    [M:SDI2]FOHENDDAT = [0/0/0]
  Else
    If WSEM = 1
      WCOR = 7
    Else
      WCOR = WSEM-1
    Endif
    WCOD = [F:ITF]FOHUOT
    WDEL = [F:ITF]FOH
    WDAT = date$
    Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,WDMYI,WDMYD,[M:SDI2]FOHENDDAT)
&        From CBNLIB
  Endif
#Calcul date fin horizon ferme
  If [F:ITF]PLH = 0
    [M:SDI2]PLHENDDAT = [0/0/0]
  Else
    WCOR = 0
    WCOD = [F:ITF]PLHUOT
    WDEL = [F:ITF]PLH
    WDAT = date$
    Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,WDMYI,WDMYD,[M:SDI2]PLHENDDAT)
&        From CBNLIB
  Endif
Else
  [M:SDI2]FOHENDDAT = [0/0/0]
  [M:SDI2]PLHENDDAT = [0/0/0]
Endif
#
Raz TCUM, TLIG
If dim(TALL)>0 Raz TALL  Endif  # FQ 55414 GA for Sage UK ajout TALL
Raz [F:ITV]
#

Gosub CAL_LIGNES
Filter [ITV1] Where ITMREF = [M:SDI1]ITMREF & STOFCY = [M:SDI1]FCY
&             Order By Key ITV0
#
For [ITV1]
  Call STKDETSTO("[F:ITV1]","[F:ITV]","","",WINT,3,0) From STKACT
Next
Filter [ITV1]
#
Call STKDETSTO("[F:ITV]","","[M:SDI2]","NBLIG0",WINT,0,0) From STKACT
#
[M:SDI2]PHYSTO1    += [F:ITV]PHYSTO    + [F:ITV]CTLSTO    + [F:ITV]REJSTO
[M:SDI2]PLFSTO1    += [F:ITV]PLFPHYSTO + [F:ITV]PLFCTLSTO + [F:ITV]PLFREJSTO
[M:SDI2]BPRSTO1    += [F:ITV]BPRPHYSTO + [F:ITV]BPRCTLSTO + [F:ITV]BPRREJSTO
[M:SDI2]SCOSTO1    += [F:ITV]SCOPHYSTO + [F:ITV]SCOCTLSTO + [F:ITV]SCOREJSTO
[M:SDI2]TOTSTO1    += [F:ITV]PHYSTO    + [F:ITV]CTLSTO    + [F:ITV]REJSTO
[M:SDI2]TOTSTO1    += [F:ITV]PLFPHYSTO + [F:ITV]PLFCTLSTO + [F:ITV]PLFREJSTO
[M:SDI2]TOTSTO1    += [F:ITV]BPRPHYSTO + [F:ITV]BPRCTLSTO + [F:ITV]BPRREJSTO
[M:SDI2]TOTSTO1    += [F:ITV]SCOPHYSTO + [F:ITV]SCOCTLSTO + [F:ITV]SCOREJSTO
[M:SDI2]ALLSTO1    += [F:ITV]PHYALL    + [F:ITV]CTLALL    + [F:ITV]REJALL
[M:SDI2]PHYSTO     += [F:ITV]PHYSTO    + [F:ITV]PLFPHYSTO
[M:SDI2]CTLSTO     += [F:ITV]CTLSTO    + [F:ITV]PLFCTLSTO
[M:SDI2]SCOPHYSTO  += [F:ITV]SCOPHYSTO
[M:SDI2]SCOCTLSTO  += [F:ITV]SCOCTLSTO
[M:SDI2]SCOPHYALL  += [F:ITV]SCOPHYALL
[M:SDI2]SCOCTLALL  += [F:ITV]SCOCTLALL
[M:SDI2]WAISTO     += [F:ITV]WAISTO
[M:SDI2]GLOALL     += [F:ITV]GLOALL
[M:SDI2]SCCLNDSTO  += [F:ITV]SCCLNDSTO
[M:SDI2]TRFSTO     += [F:ITV]TRFSTO

If dim([M:SDI2]DETALL) > 0
   [M:SDI2]DETALL     += [F:ITV]PHYALL
   If [M:SDI1]CTLSTOFLG = 2
      [M:SDI2]DETALL  += [F:ITV]CTLALL
   Endif
   If dim([M:SDI1]SCOSTOFLG) > 0 & [M:SDI1]SCOSTOFLG = 1
      [M:SDI2]DETALL += [M:SDI2]SCOPHYALL
      If [M:SDI1]CTLSTOFLG = 2
         [M:SDI2]DETALL += [M:SDI2]SCOCTLALL
      Endif
   Endif
Endif

If [M:SDI1]ALLSTOFLG = 2 & dim([M:SDI2]DETALL) > 0
  TLIG(1,0) += [M:SDI2]DETALL
# Sinon si présence module vente
Elsif GMODU(5)=2
# Ajout dans allocations 1ère période factures, livraisons directes, retour fournisseur
  Filter [STA] Where ITMREF = [M:SDI1]ITMREF &
&                    STOFCY = [M:SDI1]FCY    &
&                    ALLTYP = 2              &
&                    (VCRTYP = 4 | VCRTYP = 5 | VCRTYP = 8)
&              Order By Key STA0
  For [STA]
    Raz WDIRECT, WDOCU                                       # hcb 107209
    If [F:STA]VCRTYP=4
      Read [SDD]SDD0=[F:STA]VCRNUM;[F:STA]VCRLIN
      If fstat                                              # hcb 107209
         Raz [F:SDD]
      Endif
      WDIRECT=[F:SDD]SOHNUM
      WDOCU  =[F:SDD]SDHNUM                                 # hcb 107209
    Else
      Read [SID]SID0=[F:STA]VCRNUM;[F:STA]VCRLIN
      If fstat                                              # hcb 107209
         Raz [F:SID]
      Endif
      WDIRECT=[F:SID]SOHNUM
      WDOCU  =[F:SID]NUM                                 # hcb 107209
    Endif
    If WDIRECT=""
       Read [ORD]ORD3=[M:SDI1]FCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
       If fstat
          If WDOCU <> ""                                     # hcb 17209
             TLIG(1,0) += [F:STA]QTYSTU
          Endif                                              # hcb 17209
       Endif
    Endif
  Next
  Filter [STA]
Endif

If [M:SDI1]RERSTOFLG = 2
  TLIG(1,0) += [M:SDI2]GLOALL
Endif
# Répartition du  stock contrôle qualité à date
# sr 02.04 revu pour utiliser les tables de la 1.4.0
If [M:SDI1]CTLSTOFLG = 3
  ITYP = 2
  ISTA = 1
  ISIG = 0
#MAE, bg 89717
#  Filter [STO] Where STOFCY       = [M:SDI1]FCY    &
#&                    ITMREF       = [M:SDI1]ITMREF &
#&                    QTYSTU       > 0              &
#&                    left$(STA,1) = "Q"
#&              Order By Key STO3
If [M:SDI1]SCOSTOFLG =2
    #MAE, bg 89717, on ne prend pas le stock client et sous traitant
    Filter [STO] Where STOFCY       = [M:SDI1]FCY    &
&                    ITMREF       = [M:SDI1]ITMREF &
&                    QTYSTU       > 0              &
&                    left$(STA,1) = "Q"            &
&                    LOCCAT <3
&              Order By Key STO3
  Else
    #MAE, bg 89717, on ne prend pas le stock client
    Filter [STO] Where STOFCY       = [M:SDI1]FCY    &
&                    ITMREF       = [M:SDI1]ITMREF &
&                    QTYSTU       > 0              &
&                    left$(STA,1) = "Q"            &
&                    LOCCAT <>3
&              Order By Key STO3
Endif
  For [STO]

      If [F:STO]QLYCTLDEM = ""
            IDAT = 0
            TCUM(ITYP,IDAT,ISTA,ISIG) += [F:STO]QTYSTU
      Else
            Link [QLD] With [QLH]QLH0=28;[F:QLD]VCRNUM As [QLX]
&                      Where ITMREF   =[F:STO]ITMREF
&                          & STOFCY   =[F:STO]STOFCY
&                          & VCRTYP   =28
&                          & VCRNUM   =[F:STO]QLYCTLDEM
&                          & LOT      =[F:STO]LOT
&                          & SLO      =[F:STO]SLO
&                          & PALNUM   =[F:STO]PALNUM
&                          & CTRNUM   =[F:STO]CTRNUM
&                          & STA      =[F:STO]STA
&                          & LOC      =[F:STO]LOC
&                          & PCU      =[F:STO]PCU
&                          & PCUSTUCOE=[F:STO]PCUSTUCOE
&                          & SERNUM   =[F:STO]SERNUM
&                      Order By Key QLD1
            For [QLX]
                If [F:QLH]ENDCTLDAT <= WDATF(WCOLSDI-1)
                   If [F:QLH]ENDCTLDAT < WDATD
                        IDAT = 0
                        #MAE, bug 97315
                        #TCUM(ITYP,IDAT,ISTA,ISIG) += [F:STO]QTYSTU
                        TCUM(ITYP,IDAT,ISTA,ISIG) += [F:QLX]QTYSTU
                   Else
                        For IDAT = 0 To WCOLSDI-1
                              If [F:QLH]ENDCTLDAT >= WDATD(IDAT) & [F:QLH]ENDCTLDAT <= WDATF(IDAT)
                                    #MAE, bug 97315
                                    #TCUM(ITYP,IDAT,ISTA,ISIG) += [F:STO]QTYSTU
                                    TCUM(ITYP,IDAT,ISTA,ISIG) += [F:QLX]QTYSTU
                                    Break
                              Endif
                        Next IDAT
                   Endif
                Endif
             Next
             Filter [QLX]
      Endif
  Next
  Filter [STO]
Endif
#

# Prise en compte delai peremption
If [M:SDI1]EXYFLG > 1
   ITYP = 2
   ISTA = 1
   ISIG = 0
   WFILEXY = "1=1"
   WFILEXY += "&sum([F:SLF]AAACUMQTY,[F:SLF]QQQCUMQTY,[F:SLF]RRRCUMQTY)<>0"
   WFILEXY += "&[F:SLF]STOFCY=[M:SDI1]FCY & [F:STL]ITMREF = [M:SDI1]ITMREF"

# faire un filtre de se qui est en premption à la derniere periode
   If [M:SDI1]EXYFLG = 3
       WFILEXY += "&[F:STL]SHLDAT<=(WDATF(WCOLSDI-1))"
   Else
       WFILEXY += "&[F:STL]SHLDAT<=(WDATF(WCOLSDI-1))"
   Endif
   Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO,[F:ITM]ITM0=[F:STL]ITMREF
&             As [LNK]
&             Where evalue(WFILEXY)
&             Order By Key STL3
   Raz [F:STL],[F:SLF]
   For [LNK]
       Filter [STO] Where ITMREF = [F:STL]ITMREF &
&                         STOFCY = [F:SLF]STOFCY &
&                         LOT    = [F:STL]LOT    &
&                         SLO    = [F:STL]SLO
&                   Order By Key STO3
       For [STO]

           If [F:STL]SHLDAT < (WDATD)
              IDAT = 0
              TCUM(ITYP,IDAT,ISTA,ISIG) -= [F:STO]QTYSTU
           Else
              For IDAT = 0 To WCOLSDI-1
                  If [F:STL]SHLDAT >= (WDATD(IDAT)) & [F:STL]SHLDAT <= (WDATF(IDAT))
                     TCUM(ITYP,IDAT,ISTA,ISIG) -= [F:STO]QTYSTU
                     Break
                  Endif
              Next IDAT
           Endif
       Next
   Next
Endif







WFILSPE="1=1"

If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Filter [ORD] Where STOFCY = [M:SDI1]FCY      &
&                  ITMREF = [M:SDI1]ITMREF   &
&                  evalue (WFILS)            &
&                  evalue (WFILSPE)          &
&                  WIPSTA < 4
&               Order By Key ORD1
For [ORD]
  Gosub TRT_SEL
    If WSEL = 2
      WALLFLG = [M:SDI1]ALLSTOFLG
      WGLOFLG = [M:SDI1]RERSTOFLG
      WSHRFLG = [M:SDI1]SHRFLG
      Gosub TRT_CUMUL
    Endif
Next
Filter [ORD]
# Traitement horizon demande : effacement SOS dans horizon / + grande valeur au delà
If [M:SDI2]FOHENDDAT <> [0/0/0]
  For IDAT = 0 To WCOLSDI-1
    If WDATD(IDAT) <= [M:SDI2]FOHENDDAT
      TCUM(1,IDAT,3,0) = 0
    Else
      If TCUM(1,IDAT,3,0) > TCUM(1,IDAT,1,0)
        TCUM(1,IDAT,3,0) = TCUM(1,IDAT,3,0) - TCUM(1,IDAT,1,0)
      Else
        TCUM(1,IDAT,3,0) = 0
      Endif
    Endif
  Next IDAT
Endif
# Préparation du tableau
For WLIN = 0 To WNBL-1
  WTAB = TTAB(WLIN)
  Gosub CUM_COL
Next WLIN

# Calcul disponible 130
#WQTY = [M:SDI2]PHYSTO-[M:SDI2]BPRSTO1
#If dim([M:SDI1]SCOSTOFLG) > 0 & [M:SDI1]SCOSTOFLG = 2
#  WQTY -= [M:SDI2]SCOSTO1
#Endif

# Calcul disponible 140
WQTY = [M:SDI2]PHYSTO
If [M:SDI1]CTLSTOFLG = 2
  WQTY += [M:SDI2]CTLSTO
Endif
#TS/MAE, bg 78980
#If dim([M:SDI1]SCOSTOFLG) > 0 & [M:SDI1]SCOSTOFLG = 1
#  WQTY += [M:SDI2]SCOPHYSTO
#  If [M:SDI1]CTLSTOFLG = 2
#    WQTY += [M:SDI2]SCOCTLSTO
#  Endif
#Endif
If dim([M:SDI1]SCOSTOFLG) > 0
  If[M:SDI1]SCOSTOFLG = 1
    WQTY += [M:SDI2]SCOPHYSTO
    If [M:SDI1]CTLSTOFLG = 2
      WQTY += [M:SDI2]SCOCTLSTO
    Endif
 # si on déduit uniquement le stock sous traitant et pas les allocations,
 # on rajoute le stock sous traitant alloué car il est déduit du stock disponible lorsque les allocations sont déduites
  Elsif [M:SDI1]ALLSTOFLG<>2
    WQTY += [M:SDI2]SCOPHYALL
    If [M:SDI1]CTLSTOFLG = 2
      WQTY += [M:SDI2]SCOCTLALL
    Endif
  Endif
Endif
#Fin bg 78980

If dim([M:SDI1]SCCSTOFLG) > 0 & [M:SDI1]SCCSTOFLG = 1
  WQTY += [M:SDI2]SCCLNDSTO
Endif
If [M:SDI1]WAISTOFLG = 2    #sorties en attentes
  WQTY -= [M:SDI2]WAISTO
Endif
If [M:SDI1]TRFSTOFLG = 2    #stock transit
  WQTY += [M:SDI2]TRFSTO
Endif

WTRF = 0

[M:SDI2]FIRAVADAT = [0/0/0]

# Issue 121113  - 2017-01-25 by MAE : si allocations en statut R, ne doivent pas etre prise en compte ds le stock dispo
#elles ont été enlevées du stock dispo car elles font partie du total allocation (si ALLSTOFLG =2), on doit dc les rajouter ds le stock dispo
If [M:SDI1]ALLSTOFLG <> 2
  WQTY += [F:ITV]REJALL
Endif

For IDAT = 0 To WCOLSDI-1
  WQTY += TLIG(2,IDAT)
  WQTY -= TLIG(0,IDAT)
  WQTY -= TLIG(1,IDAT)
  TLIG(3,IDAT) = WQTY
  If WQTY > 0 & [M:SDI2]FIRAVADAT = [0/0/0] & IDAT > 0
    [M:SDI2]FIRAVADAT = WDATD(IDAT)
  Endif
Next IDAT
# Calcul disponible à la vente 130
#WQTY = [M:SDI2]PHYSTO-[M:SDI2]BPRSTO1
#If dim([M:SDI1]SCOSTOFLG) > 0 & [M:SDI1]SCOSTOFLG = 2
#  WQTY -= [M:SDI2]SCOSTO1
#Endif

# Calcul disponible à la vente 140
WQTY = [M:SDI2]PHYSTO
If [M:SDI1]CTLSTOFLG = 2
  WQTY += [M:SDI2]CTLSTO
Endif
If [M:SDI1]WAISTOFLG = 2
  WQTY -= [M:SDI2]WAISTO
Endif
If [M:SDI1]TRFSTOFLG = 2
  WQTY += [M:SDI2]TRFSTO
Endif

# Issue 121113  - 2017-01-25 by MAE : si allocations en statut R, ne doivent pas etre prise en compte ds le stock dispo
#elles ont été enlevées du stock dispo car elles font partie du total allocation (si ALLSTOFLG =2), on doit dc les rajouter ds le stock dispo
If [M:SDI1]ALLSTOFLG <> 2
  WQTY += [F:ITV]REJALL
Endif

For IDAT = 0 To WCOLSDI-1
  WQTY += TLIG(2,IDAT)
  WQTY -= TLIG(1,IDAT)
  WQTY -= TLIG(7,IDAT)
  WQTY -= TLIG(8,IDAT)
  TLIG(4,IDAT) = WQTY
Next IDAT
For IDAT = 0 To WCOLSDI-2
  WQTY = TLIG(4,IDAT)
  I = IDAT+1
  While TLIG(2,I) = 0 & I < WCOLSDI-1
    WQTY -= TLIG(7,I)
    WQTY -= TLIG(8,I)
    I += 1
  Wend
  TLIG(4,IDAT) = WQTY
Next IDAT
# Calcul de la couverture
For IDAT = 0 To WCOLSDI-1
  TLIG(5,IDAT) = 0
  WQTY = TLIG(3,IDAT)
  If WQTY > 0
    I = IDAT+1
    While WQTY > 0 & I <= WCOLSDI-1
      WBES = TLIG(0,I) + TLIG (1,I)
      If WQTY > WBES
        TLIG(5,IDAT) += 1
        WQTY -= WBES
      Else
        If WBES <> 0
          TLIG(5,IDAT) += (WQTY/WBES)
          WQTY -= WBES
        Endif
      Endif
      I += 1
    Wend
    TLIG(5,IDAT) = 1 + arr(TLIG(5,IDAT),0.1) : # FQ 55414 for Sage UK add 1 to match MRP definition
  Endif
Next IDAT

# Chargement TLIG dans tableau ecran
For WLIN = 0 To WNBL-1
  [M:SDI2]COL001(WLIN) = TLIG(WLIN,0)
  [M:SDI2]COL002(WLIN) = TLIG(WLIN,1)
  [M:SDI2]COL003(WLIN) = TLIG(WLIN,2)
  [M:SDI2]COL004(WLIN) = TLIG(WLIN,3)
  [M:SDI2]COL005(WLIN) = TLIG(WLIN,4)
  [M:SDI2]COL006(WLIN) = TLIG(WLIN,5)
  [M:SDI2]COL007(WLIN) = TLIG(WLIN,6)
  [M:SDI2]COL008(WLIN) = TLIG(WLIN,7)
  [M:SDI2]COL009(WLIN) = TLIG(WLIN,8)
  [M:SDI2]COL010(WLIN) = TLIG(WLIN,9)
  [M:SDI2]COL011(WLIN) = TLIG(WLIN,10)
  [M:SDI2]COL012(WLIN) = TLIG(WLIN,11)
  [M:SDI2]COL013(WLIN) = TLIG(WLIN,12)
  [M:SDI2]COL014(WLIN) = TLIG(WLIN,13)
  [M:SDI2]COL015(WLIN) = TLIG(WLIN,14)
  [M:SDI2]COL016(WLIN) = TLIG(WLIN,15)
  [M:SDI2]COL017(WLIN) = TLIG(WLIN,16)
  [M:SDI2]COL018(WLIN) = TLIG(WLIN,17)
  [M:SDI2]COL019(WLIN) = TLIG(WLIN,18)
  [M:SDI2]COL020(WLIN) = TLIG(WLIN,19)
  If dim([M:SDI2]COL021)>0 & WCOLSDI>20   # FQ 55414 ajout 6 colonnes Demande D.Fritz
    [M:SDI2]COL021(WLIN) = TLIG(WLIN,20)
    [M:SDI2]COL022(WLIN) = TLIG(WLIN,21)
    [M:SDI2]COL023(WLIN) = TLIG(WLIN,22)
    [M:SDI2]COL024(WLIN) = TLIG(WLIN,23)
    [M:SDI2]COL025(WLIN) = TLIG(WLIN,24)
    [M:SDI2]COL026(WLIN) = TLIG(WLIN,25)
  Endif
Next WLIN
NOL = WNBL-1
#
$LECTURE_FIN
SUITE  = 1
RETOUR = 1
Return
###########################################################
$LEC_RER
# Recherche allocations globales
WGLO = 0

##VPO 05/10/10 Bug67119 amelio perf
##Filter [STA] Where VCRTYP = [F:ORD]VCRTYP &
##&                  VCRNUM = [F:ORD]VCRNUM &
##&                  VCRLIN = [F:ORD]VCRLIN &
##&                  VCRSEQ = [F:ORD]VCRSEQ &
##&                  ALLTYP = 1
##&            Order By Key STA0
##For [STA] Hint Key STA1
##  WGLO = 1
##  Break
##Next
Filter [STA] Where VCRTYP = [F:ORD]VCRTYP &
&                  VCRNUM = [F:ORD]VCRNUM &
&                  VCRLIN = [F:ORD]VCRLIN &
&                  VCRSEQ = [F:ORD]VCRSEQ &
&                  ALLTYP = 1
&            Order By Key STA1
Look [STA]STA1(4) First
If !fstat
  WGLO = 1
Endif
Filter [STA]
If WGLO = 0
  If WALLFLG = 2
    WALL = 0
    WQTY = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY - [F:ORD]MTOQTY    # hcb 83895
  Else
    WALL = [F:ORD]ALLQTY
    WQTY = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY - [F:ORD]MTOQTY    # hcb 83895
  Endif
Else
  If WGLOFLG = 2
    WALL = 0
    WQTY = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY - [F:ORD]MTOQTY    # hcb 83895
  Else
    WALL = [F:ORD]ALLQTY
    WQTY = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY - [F:ORD]MTOQTY    # hcb 83895
  Endif
Endif
# FQ 55414 GA for Sage UK  Accumulate Sales Allocation
If dim(ZALL)>0 & [F:ORD]WIPTYP = 1
    ZALL = [F:ORD]ALLQTY
Endif
Return
###########################################################
$CUM_COL
# FQ 55414 GA for Sage UK
#While left$(WTAB,5) <> ""
#  WZON = left$(WTAB,5)
#  ITYP = val(mid$(WZON,1,2))
#  ISTA = val(mid$(WZON,3,1))
#  ISIG = val(mid$(WZON,4,1))
#  For IDAT = 0 To WCOLSDI-1
#    TLIG(WLIN-1,IDAT) += TCUM(ITYP,IDAT,ISTA,ISIG)
#  Next IDAT
#  WTAB = mid$(WTAB,6,95)
#Wend
Local Char       ZSAFTAB(100)
ZSAFTAB = WTAB                                # Save WTAB
For IDAT = 0 To WCOLSDI-1
  Local Decimal ZSOF : ZSOF = 0
  Local Decimal ZSOS : ZSOS = 0

  WTAB = ZSAFTAB                                # Restore WTAB
   While left$(WTAB,5) <> ""
    WZON = left$(WTAB,5)
    ITYP = val(mid$(WZON,1,2))
    ISTA = val(mid$(WZON,3,1))
    ISIG = val(mid$(WZON,4,1))
      If dim(WHORDEM)>0 & WHORDEM = 2 &  WLIN = 1 & ITYP = 1       # Requirements line, Sales order, Forecast offset
        If ISTA < 3
          ZSOF += TCUM(ITYP,IDAT,ISTA,ISIG)     # Firm or planned
        Else
          ZSOS += TCUM(ITYP,IDAT,ISTA,ISIG)     # Suggested
        Endif
      Else
        TLIG(WLIN-1,IDAT) += TCUM(ITYP,IDAT,ISTA,ISIG)
      Endif
    WTAB = mid$(WTAB,6,95)
   Wend
  If WLIN = 1 & dim(TALL)>0
    TLIG(0,IDAT) += max((ZSOF+TALL(IDAT)),ZSOS) - TALL(IDAT)                # Add max of Firm or suggested - Allocated
  Endif
Next IDAT
# End - FQ 55414 GA for Sage UK
Return
############################################################
$TRT_SEL

WSEL = 1
If [F:ORD]WIPTYP > 0 & [F:ORD]WIPTYP <= dim([M]ABRTYP) &
&  [F:ORD]WIPSTA > 0 & [F:ORD]WIPSTA <= dim([M]ABRSTA)
  WFLD = "[M:SDI1]"+[M]ABRTYP([F:ORD]WIPTYP)+[M]ABRSTA([F:ORD]WIPSTA)+"FLG"
  WEVA = "dim("+WFLD+")>0&"+WFLD+"=2"
  If [F:ORD]WIPTYP <> 1 & [F:ORD]WIPSTA = 3
    Case [M:SDI1]MRPFLG
      When 1 : WEVA += "&[F:ORD]ORI=5"
      When 2 : WEVA += "&[F:ORD]ORI=6"
    Endcase
  Endif
  If evalue(WEVA)
    WSEL = 2
    ITYP = [F:ORD]WIPTYP
    ISTA = [F:ORD]WIPSTA
    Case [F:ORD]WIPTYP
      When 1 :
        Case [M:SDI1]CTMFLGS
          When 1 : If [F:ORD]FMI > 1
                     WSEL = 1
                   Endif
          When 2 : If [F:ORD]FMI > 1
                     ISTA = 4
                   Endif
        Endcase
        If [F:ORD]WIPSTA = 3 & [M:SDI1]SOSCOD = 2 & [F:ORD]ENDDAT < [M:SDI1]REFPER
          WSEL = 1
        Endif
      When 2 :
        Case [M:SDI1]CTMFLGP
          When 1 : If [F:ORD]FMI > 1
                     WSEL = 1
                   Endif
          When 2 : If [F:ORD]FMI > 1
                     ISTA = 4
                   Endif
        Endcase
      When 5 :
        Case [M:SDI1]CTMFLGW
          When 1 : If [F:ORD]FMI > 1
                     WSEL = 1
                   Endif
          When 2 : If [F:ORD]FMI > 1
                     ISTA = 4
                   Endif
        Endcase
      When 13 :
        Case [M:SDI1]CTMFLGSC
          When 1 : If [F:ORD]FMI > 1
                     WSEL = 1
                   Endif
          When 2 : If [F:ORD]FMI > 1
                     ISTA = 4
                   Endif
        Endcase
    Endcase
  Endif
Endif
# Correction éventuelle date fin par delai contrôle qualité
If WSEL = 2 & [M:SDI1]LTIFLG = 2
# FQ 55414 GA for Sage UK
#  If ([F:ORD]WIPTYP = 5 & [F:ORD]WIPSTA = 1 & [F:ITF]QUALTI > 0) |
#&    ([F:ORD]WIPTYP = 5 & [F:ORD]WIPSTA = 2 & [F:ITF]QUALTI > 0)
  If ([F:ORD]WIPTYP = 5 & [F:ITF]QUALTI > 0)
    Gosub COR_QUA
  Else
# FQ 55414 GA for Sage UK
#    If ([F:ORD]WIPTYP = 2 & [F:ORD]WIPSTA = 1 & [F:ITF]QUALTI > 0) |
#&      ([F:ORD]WIPTYP = 2 & [F:ORD]WIPSTA = 2 & [F:ITF]QUALTI > 0)
     If ([F:ORD]WIPTYP = 2 & [F:ITF]QUALTI > 0)
      Read [ITP]ITP0=[F:ORD]ITMREF;[F:ORD]BPRNUM
      If fstat = 0
        If [F:ITP]QUAFLG > 1
          Gosub COR_QUA
        Endif
      Else
        If [F:ITF]QUAFLG > 1              # hcb V6CQ
          Gosub COR_QUA
        Endif
      Endif
    Endif
  Endif
Endif
Return
###########################################################
# Correction Date fin par delai contrôle qualité
$COR_QUA
If [F:ORD]STOFCY <> [F:FCY]FCY
  Read [FCY]FCY0=[F:ORD]STOFCY
  If fstat
    Raz [F:FCY]
  Endif
Endif
If sum([F:FCY]UVYDAY(0..dim([F:FCY]UVYDAY)-1)) > 0
  WLTI = [F:ITF]QUALTI
  While WLTI > 0
    [F:ORD]ENDDAT += 1
    If [F:FCY]UVYDAY(dayn([F:ORD]ENDDAT)-1) = 2
      WLTI -=1
    Endif
  Wend
Endif
Return
###########################################################
# Cumul selon Type date statut signe
$TRT_CUMUL
# Correction quantité restante par % perte
If [F:ORD]WIPTYP = 5 & find([F:ORD]WIPSTA,1,2,3) & WSHRFLG = 2 & [F:ITF]SHR > 0
  [F:ORD]EXTQTY    = arr(([F:ORD]EXTQTY*100)/(100+[F:ITF]SHR),10^-[F:TUN]UOMDEC)
  [F:ORD]RMNEXTQTY = arr(([F:ORD]RMNEXTQTY*100)/(100+[F:ITF]SHR),10^-[F:TUN]UOMDEC)
Endif
#
If [F:ORD]RMNEXTQTY >= 0
  ISIG = 0
Else
  ISIG = 1
Endif
#107498/9 - added project demands
Case [F:ORD]WIPTYP
  When 1,3,6,12,14    :
    Gosub LEC_RER
    If WQTY < 0
      WQTY = 0
    Endif
  When Default :
    WALL = 0
    WQTY = ([F:ORD]RMNEXTQTY - [F:ORD]MTOQTY)  # hcb 83895
    If WQTY < 0                                # hcb 83895
      WQTY = 0
    Endif
Endcase
If [F:ORD]ENDDAT <= WDATF(WCOLSDI-1)
  If [F:ORD]ENDDAT < WDATD
    IDAT = 0
    TCUM(ITYP,IDAT,ISTA,ISIG) += WQTY
# FQ 55414 GA for Sage UK Accumulate Allocations
    If dim(TALL)>0 & dim(ZALL)>0 TALL(IDAT) += ZALL Endif
    If WALL <> 0
       TCUM(0,IDAT,ISTA,ISIG) += WALL
    Endif
  Else
    For IDAT = 0 To WCOLSDI-1
      If [F:ORD]ENDDAT >= WDATD(IDAT) & [F:ORD]ENDDAT <= WDATF(IDAT)
        TCUM(ITYP,IDAT,ISTA,ISIG) += WQTY
      # FQ 55414 GA for Sage UK Accumulate Allocations
        If dim(TALL)>0 & dim(ZALL)>0 TALL(IDAT) += ZALL Endif
        If WALL <> 0
         TCUM(0,IDAT,ISTA,ISIG) += WALL
        Endif
        Break
      Endif
    Next IDAT
  Endif
Endif
Return
###########################################################
# Positionnement valeurs par défaut de départ
$MEI_CONSTANTES
# Types d'ordres par ligne :
# - Chiffres 1 et 2 = Type d'ordre (ML 306 : Cde cli, Cde fou, ..., Ordre SST)
# - Chiffre 3       = Statut ordre (ML 317 : Ferme, Planifié, Suggéré, Clos)
# - Chiffre 4       = Signe (0 : positif, 1 : négatif)

TTAB(0)  = ""
# Issue 107498/9 - added 1410 and 1411 for project demand
# Issue 107498/102 - 2016-04-14 by ALSHE : added 1420 and 1421 for project demand
TTAB(1)  = "0110 0120 0130 0140 0310 0320 0330 0610 0620 0630 0611 0621 0631 0810 0820 0830 1230 1410 1411 1420 1421"
TTAB(2)  = "0010 0020 0030 0040 "
TTAB(3)  = "0210 0220 0230 0240 0510 0520 0530 0540 0710 0720 0730 0740 0910 0920 0930 0940 1310 1320 1330"
TTAB(4)  = "*"
TTAB(5)  = "*"
TTAB(6)  = "*"
TTAB(7)  = ""
TTAB(8)  = "0110 0310 0610 0810 1410" #107498/9 - added 1410 for project demand
TTAB(9)  = "0140 "
TTAB(10) = "0120 0320 0620 0820 1420" # Issue 107498/102 - 2016-04-14 by ALSHE : added 1420 for project demand
TTAB(11) = "0330 0630"
TTAB(12) = "0130 0330 0630 0830"
TTAB(13) = ""
TTAB(14) = "0210 0510 0611 0710 0910 1310 1410" #107498/9 - added 1411 for project demand
TTAB(15) = "0240 0540 1340"
TTAB(16) = "0220 0520 0621 0720 0920 1320 1420" # Issue 107498/102 - 2016-04-14 by ALSHE : added 1420 for project demand
TTAB(17) = "0230 0530 0730 0631 0930 1330"
# Titres lignes
WLNE(0)  = 0
WLNE(1)  = 112      : # Total besoins
WLNE(2)  = 113      : # Total allocations
WLNE(3)  = 114      : # Total ressources
WLNE(4)  = 115      : # Disponible
WLNE(5)  = 116      : # Disponible vente
WLNE(6)  = 117      : # Couverture
WLNE(7)  = 0
WLNE(8)  = 118      : # Besoins fermes
WLNE(9)  = 119      : # Besoins contremarques
WLNE(10) = 120      : # Besoins planifiés
WLNE(11) = 121      : # Besoins indirects
WLNE(12) = 122      : # Besoins prévisionnels
WLNE(13) = 0
WLNE(14) = 123      : # Ressources fermes
WLNE(15) = 124      : # Ressources contremarques
WLNE(16) = 125      : # Ressources planifiées
WLNE(17) = 126      : # Ressources prévisionnelles
Return

#---------------------------------------------------------------------------#
# Action FGRAPHSDI  Représentation graphique du stock disponible            #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_FGRAPHSDI
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
Return

########################################################################
$DEBUT_FGRAPHSDI
Gosub CHARGE_SDIG
Affzo [M:SDIG]
Return



#########################################################################
$CHARGE_SDIG
Local Integer WROW
Local Integer I
If [F:ITM]ITMREF <> [M:SDI1]ITMREF
    Read [ITM]ITM0=[M:SDI1]ITMREF
Endif
WROW = dim([M:SDI2]COL000)
Effzo [M:SDIG]

[M:SDIG]STU     = [F:ITM]STU         # hcb graphique
[M:SDIG]PERCOD  = [M:SDI1]PERCOD     # hcb graphique
[M:SDIG]REFPER  = [M:SDI1]REFPER     # hcb graphique


For I = 0 To WROW-1
  [M:SDIG]WABS(I)       = GSCOLDES(I)
#  [M:SDIG]STU(I)        = [F:ITM]STU    # hcb graphique
  [M:SDIG]WAMT1(I)      = TLIG(0,I)+TLIG(1,I)
  [M:SDIG]WAMT2(I)      = TLIG(2,I)
  [M:SDIG]WAMT3(I)      = TLIG(3,I)
  [M:SDIG]WAMT4(I)      = TLIG(4,I)
Next I
[M:SDIG]NBLIGC = WROW
Return

###########################################################
# Titres colonnes
$CAL_COLONNES
If WSEM = 1
  WCOR = 7
Else
  WCOR = WSEM-1
Endif
# Autres colonnes selon périodicité
Case [M:SDI1]PERCOD
  When 1 :
    GSCOLDES(0) = "--"-format$("D:"+GFMDAT4,[M:SDI1]REFPER)
    WDATD(0) = [0/0/0]
    WDATF(0) = [M:SDI1]REFPER-1
    For I = 1 To WCOLSDI-1 : # FQ 55414 GA for Sage UK avant 19
      WDATD(I) = WDATF(I-1)+1
      WDATF(I) = WDATF(I-1)+1
      GSCOLDES(I) = format$("D:"+GFMDAT4,WDATD(I))
    Next I
  When 2 :
    GSCOLDES(0) = "--"-format$("D:"+GFMDAT4,[M:SDI1]REFPER)
    WDATD(0) = [0/0/0]
    WDATF(0) = [M:SDI1]REFPER-1
    If dayn([M:SDI1]REFPER) = WSEM
      WDATD(1) = [M:SDI1]REFPER
      WDATF(1) = [M:SDI1]REFPER+6
    Else
      WDATD(1) = [M:SDI1]REFPER
      WDATF(1) = [M:SDI1]REFPER
      While dayn(WDATF(1)) <> WCOR
        WDATF(1) += 1
      Wend
    Endif
    GSCOLDES(1) = format$("D:"+GFMDAT4,WDATD(1))+"++"
    For I = 2 To WCOLSDI-1 : # FQ 55414 GA for Sage UK avant 19
      WDATD(I) = WDATF(I-1)+1
      WDATF(I) = WDATF(I-1)+7
      GSCOLDES(I) = format$("D:"+GFMDAT4,WDATD(I))+"++"
    Next I
  When 3 :
    WDTE = [M:SDI1]REFPER
    Call DATMOIS(WDTE,WDTED,WDTEF,WSEMD,WSEMF,WYEA,WMON,WSEMNB) From CBNLIB            # 08.07 42722
    GSCOLDES(0) = "--"-format$("D:"+GFMDAT4,[M:SDI1]REFPER)
    WDATD(0) = [0/0/0]
    WDATF(0) = [M:SDI1]REFPER-1
     WDTE = gdat$(15,month(WDTED+7),year(WDTED+7))
    For I = 1 To WCOLSDI-1 : # FQ 55414 GA for Sage UK avant 19
#      Call DATMOIS(WDTE,WDTED,WDTEF,WSEMD,WSEMF,WYEA,WMON,WSEM) From CBNLIB   # hcb 38330
      If I = 1
        WDATD(I) = [M:SDI1]REFPER
      Else
#       WDATD(I) = WDTED                                                       # hcb 38330
        WDATD(I) = WDATF(I-1)+1                                                # hcb 38330
      Endif
#     WDATF(I) = WDTEF                                                         # hcb 38330
      WDATF(I) = eomonth(WDATD(I))                                             # hcb 38330
#MAE, bg 48684, si la semaine est entre 2 mois, on prend le mois de la date courante
If month$(WDATD(I)+7) <> month$(WDATD(I))
      GSCOLDES(I) = month$(WDATD(I))-num$(year(WDATD(I)))                  # hcb 38330
Else
      GSCOLDES(I) = month$(WDATD(I)+7)-num$(year(WDATD(I)+7))                  # hcb 38330
Endif
#      GSCOLDES(I) = month$(WDTED+7)-num$(year(WDTED+7))                       # hcb 38330
      WDTE = addmonth(WDTE,1)
    Next I
Endcase
Return
############################################################
$CAL_LIGNES
For I = 0 To WNBL-2
  If WLNE(I+1) <> 0
    [M:SDI2]COL000(I) = mess(WLNE(I+1),196,1)
    If I <> 5
      [M:SDI2]UOM(I)  = [F:ITM]STU
    Else
      [M:SDI2]UOM(I)  = "1"
    Endif
    [M:SDI2]LINTYP(I) = TTAB(I+1)
  Else
    [M:SDI2]COL000(I) = ""
    [M:SDI2]LINTYP(I) = ""
  Endif
Next I
Return
############################################################
$GEN_FILTRE
Local Char    WTAB(100)
Local Char    WFIL(60)
Local Char    WEVA(80)
Local Char    WZON(5)
Local Integer ITYP,ISTA,ISIG
Local Integer WTYPSEL
Local Char    WNUMSEL
Raz [M:SDI2]FLT
WTAB = [M:SDI2]LINTYP(nolign-1)
If left$(WTAB,1) <> "*"
  While left$(WTAB,5) <> ""
    WZON = left$(WTAB,5)
    ITYP = val(mid$(WZON,1,2))
    ISTA = val(mid$(WZON,3,1))
    ISIG = val(mid$(WZON,4,1))
    If [M]WTYP(ITYP) = 2
      Gosub LOA_FILTRES
    Endif
    WTAB = mid$(WTAB,6,95)
  Wend
Endif
Return
############################################################
$LOA_FILTRES
WFIL = ""
If ITYP = 0 & ISTA <> 4
  # 107498/9 Added project demand
  WFIL = "(find([F:ORD]WIPTYP,1,3,6,12,14)&[F:ORD]ALLQTY<>0"
  Gosub LOA_WFIL
Else
  If ITYP <> 0
    Case ISTA
      When 1, 2, 3 :
        WEVA = "[M:SDI1]"+[M]ABRTYP(ITYP)+[M]ABRSTA(ISTA)+"FLG=2"
        If evalue(WEVA)
          WFIL = "([F:ORD]WIPTYP="+num$(ITYP)+"&[F:ORD]WIPSTA="+num$(ISTA)
          Gosub LOA_WFIL
        Endif
     When 4 :
        WEVA = "[M:SDI1]"+[M]ABRTYP(ITYP)+[M]ABRSTA(1)+"FLG=2"
        If evalue(WEVA)
          WFIL = "([F:ORD]WIPTYP="+num$(ITYP)+"&[F:ORD]WIPSTA=1"+
&                "&[F:ORD]FMI>1"
          Gosub LOA_WFIL
        Endif
        WEVA = "[M:SDI1]"+[M]ABRTYP(ITYP)+[M]ABRSTA(2)+"FLG=2"
        If evalue(WEVA)
          WFIL = "([F:ORD]WIPTYP="+num$(ITYP)+"&[F:ORD]WIPSTA=2"+
&                "&[F:ORD]FMI>1"
          Gosub LOA_WFIL
        Endif
        WEVA = "[M:SDI1]"+[M]ABRTYP(ITYP)+[M]ABRSTA(3)+"FLG=2"
        If evalue(WEVA)
          WFIL = "([F:ORD]WIPTYP="+num$(ITYP)+"&[F:ORD]WIPSTA=3"+
&                "&[F:ORD]FMI>1"
          Gosub LOA_WFIL
        Endif
    Endcase
  Endif
Endif
Return
############################################################
$LOA_WFIL
  If WFIL <> ""
    If ITYP = 6 & ISIG = 1
      WFIL += "&[F:ORD]RMNEXTQTY<0"
    Endif
  WFIL += ")"
  If len([M]FLT(0))+len(WFIL) < 250
    If [M]FLT(0) <> ""
      [M]FLT(0) += "|"
    Endif
    [M]FLT(0) += WFIL
  Else
    If len([M]FLT(1))+len(WFIL) < 250
      If [M]FLT(1) <> ""
        [M]FLT(1) += "|"
      Endif
      [M]FLT(1) += WFIL
    Else
      If len([M]FLT(2))+len(WFIL) < 250
        If [M]FLT(2) <> ""
          [M]FLT(2) += "|"
        Endif
        [M]FLT(2) += WFIL
      Else
        If len([M]FLT(3))+len(WFIL) < 250
          If [M]FLT(3) <> ""
            [M]FLT(3) += "|"
          Endif
          [M]FLT(3) += WFIL
        Endif
      Endif
    Endif
  Endif
Endif
Return
