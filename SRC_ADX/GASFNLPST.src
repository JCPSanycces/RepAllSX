#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "DEBUT"   : Gosub DEBUT
 When Default
Endcase
Return

$DEBUT
## initialisation du masque
If clalev([F:HAE])  = 0 : Local File GACCENTRY [HAE] : Endif
Call LEC_HAE(PARAM(1),PARAM(2)) From CPTLEC
If fstat : FIN=1 : Endif

Local Integer NBRFNLPST
Raz NBRFNLPST
For I=0 To dim([F:HAE]FNLPSTNUM)-1
 If [F:HAE]FNLPSTNUM(I)<>""
  [L]NBRFNLPST+=1
  Assign "[M]LEDTYP"+num$([L]NBRFNLPST) With mess((I+1),2644,1)
  Assign "[M]FNLPSTNUM"+num$([L]NBRFNLPST) With [F:HAE]FNLPSTNUM(I)
 Endif
Next
For I=[L]NBRFNLPST+1 To 10
 Case I
  When  1 :
   Chgfmt [M:DIA]LEDTYP1     With "-K:"+num$(type([M:DIA]LEDTYP1)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM1  With "-K:"+num$(GLONVCR)+"X"
  When  2 :
   Chgfmt [M:DIA]LEDTYP2     With "-K:"+num$(type([M:DIA]LEDTYP2)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM2  With "-K:"+num$(GLONVCR)+"X"
  When  3 :
   Chgfmt [M:DIA]LEDTYP3     With "-K:"+num$(type([M:DIA]LEDTYP3)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM3  With "-K:"+num$(GLONVCR)+"X"
  When  4 :
   Chgfmt [M:DIA]LEDTYP4     With "-K:"+num$(type([M:DIA]LEDTYP4)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM4  With "-K:"+num$(GLONVCR)+"X"
  When  5 :
   Chgfmt [M:DIA]LEDTYP5     With "-K:"+num$(type([M:DIA]LEDTYP5)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM5  With "-K:"+num$(GLONVCR)+"X"
  When  6 :
   Chgfmt [M:DIA]LEDTYP6     With "-K:"+num$(type([M:DIA]LEDTYP6)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM6  With "-K:"+num$(GLONVCR)+"X"
  When  7 :
   Chgfmt [M:DIA]LEDTYP7     With "-K:"+num$(type([M:DIA]LEDTYP7)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM7  With "-K:"+num$(GLONVCR)+"X"
  When  8 :
   Chgfmt [M:DIA]LEDTYP8     With "-K:"+num$(type([M:DIA]LEDTYP8)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM8  With "-K:"+num$(GLONVCR)+"X"
  When  9 :
   Chgfmt [M:DIA]LEDTYP9     With "-K:"+num$(type([M:DIA]LEDTYP9)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM9  With "-K:"+num$(GLONVCR)+"X"
  When 10 :
   Chgfmt [M:DIA]LEDTYP10    With "-K:"+num$(type([M:DIA]LEDTYP10)-10)+"X"
   Chgfmt [M:DIA]FNLPSTNUM10 With "-K:"+num$(GLONVCR)+"X"
 Endcase
Next
[M]FNLPSTDAT=[F:HAE]FNLPSTDAT
Return

