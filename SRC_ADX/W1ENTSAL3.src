Subprog AS_WSTACAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10364") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WSTACAT(zc) From W1ENTSAL3
Onkey   2 Titled GBOUTS Call S_WSTACAT(zc) From W1ENTSAL3
Onkey 144 Titled GBOUTP Call P_WSTACAT(zc) From W1ENTSAL3
Onkey 146 Titled GBOUTA Call SA_WSTACAT(zc) From W1ENTSAL3
If VALEUR="" : Call INIADI(VALEUR,"10364") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_WSTACAT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WSTACAT" : GZNUM = 47313 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"10364","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "WSTACAT" : GZNUM = 47313 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"10364",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WSTACAT" : GZNUM = 47313 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_WSTACAT
Call AM_WSTACAT(zc)
If !mkstat & GOBJET
 zoncou = "WSTACAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WSTACAT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WSTACAT(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WSTACAT" : GZNUM = 47313 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWSTACAT)")>indice
 [M]WSTACAT(indice) = VALEUR
 Affzo ZWSTACAT(indice)
Endif
Gosub _AFF
End

Subprog S_WSTACAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10364"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WSTACAT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10364") From GOBJET
Gosub _AFF
End

Subprog SA_WSTACAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10364"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WSTACAT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10364"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWSTACAT
Onevent BEFORE_AREA Gosub AV_ZWSTACAT From W1ENTSAL3
Return

$AV_ZWSTACAT
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10364",num$([M]WSTACAT(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_WRSKWRK
Onevent BEFORE_INPUT Call AS_WRSKWRK(zc) From W1ENTSAL3
Onevent AFTER_CHANGE Gosub AMM_WRSKWRK From W1ENTSAL3
Onevent CONTROL Call C_WRSKWRK(zc) From W1ENTSAL3
Return

Subprog AS_WRSKWRK(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45608,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_WRSKWRK(VALEUR) From SUBHRENT
If mkstat=2
 [M]WRSKWRK(INDIC) = VALEUR
 Affzo WRSKWRK(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_WRSKWRK(zc) From W1ENTSAL3
Onkey   2 Titled GBOUTS Call S_WRSKWRK(zc) From W1ENTSAL3
Onkey 144 Titled GBOUTP Call P_WRSKWRK(zc) From W1ENTSAL3
Onkey 146 Titled GBOUTA Call SA_WRSKWRK(zc) From W1ENTSAL3
Gosub _AFF
End

Subprog C_WRSKWRK(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("VAC","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "WRSKWRK" : GZNUM = 46115 : Endif
Gosub _AFF
End

$AMM_WRSKWRK
Call AM_WRSKWRK(zc)
If !mkstat & GOBJET
 zoncou = "WRSKWRK" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WRSKWRK(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WRSKWRK(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WRSKWRK" : GZNUM = 46115 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWRSKWRK)")>indice
 [M]WRSKWRK(indice) = VALEUR
 Affzo ZWRSKWRK(indice)
Endif
Gosub _AFF
End

Subprog S_WRSKWRK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "VAC"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_WRSKWRK(VALEUR)
Variable Char    VALEUR()
Call OBJET("VAC",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_WRSKWRK(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "VAC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WRSKWRK(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("VAC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWRSKWRK
Onevent BEFORE_AREA Gosub AV_ZWRSKWRK From W1ENTSAL3
Return

$AV_ZWRSKWRK
If clalev([F:WAC])=0 : Local File TRVACC [WAC] : Endif
Call LECTURE("VAC",num$([M]WRSKWRK(indice)),"") From CONTOBJ
zc = [F:WAC]DESWAC
Gosub _AFF
Return

