## Action CONTHRCSP
Call CONTHRCSP(VALEUR,GCURLEG,GSOCIETE) From SUBHRCSP
If mkstat : GERR = 1 : GZONE = "WCATCSP" : GZNUM = 44777 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WCATCSP" : GZNUM = 44777 : Endif
Endif
Gosub _AFF
End

$AMM_WCATCSP
Call AM_WCATCSP(zc)
