Subprog D_WADD(VALEUR)
Variable Integer VALEUR
If varinit([M]WADD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WADD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WADD(VALEUR) From SUBHRENT
If mkstat=2
 [M]WADD(INDIC) = VALEUR
 Affzo WADD(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
