$ON_WURS1
Onevent CONTROL Call C_WURS1(zc) From W1ENTSAL3
Onevent AFTER_CHANGE Gosub AMM_WURS1 From W1ENTSAL3
Onevent BEFORE_INPUT Call AS_WURS1(zc) From W1ENTSAL3
Return

Subprog AS_WURS1(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46228,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WURS1(zc) From W1ENTSAL3
Onkey   2 Titled GBOUTS Call S_WURS1(zc) From W1ENTSAL3
Onkey 144 Titled GBOUTP Call P_WURS1(zc) From W1ENTSAL3
Onkey 146 Titled GBOUTA Call SA_WURS1(zc) From W1ENTSAL3
Gosub _AFF
End

Subprog C_WURS1(VALEUR)
Variable Char    VALEUR()
## Action CONTOBJN
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CONTOBJN"
Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WURS1" : GZNUM = 47509 : Endif
If !mkstat
 ## Action CONTORG
 Call CONTORG(VALEUR) From SUBORG
 If mkstat : GERR = 1 : GZONE = "WURS1" : GZNUM = 47509 : Endif
Endif
Gosub _AFF
End

$AMM_WURS1
Call AM_WURS1(zc)
If !mkstat & GOBJET
 zoncou = "WURS1" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WURS1(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WURS1(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "WURS1" : GZNUM = 47509 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWURS1)")>indice
 [M]WURS1(indice) = VALEUR
 Affzo ZWURS1(indice)
Endif
Gosub _AFF
End

Subprog S_WURS1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELORGLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELORGLEG"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELORGLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WURS1(VALEUR)
Variable Char    VALEUR()
Call OBJET("ORG",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_WURS1(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ORG"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WURS1(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("ORG",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWURS1
Onevent BEFORE_AREA Gosub AV_ZWURS1 From W1ENTSAL3
Return

$AV_ZWURS1
Call LECTEXTRA(zc,"ORGANISME","DES",num$(GCURLEG),num$([M]WURS1(indice))) From ATEXTRA
Gosub _AFF
Return

