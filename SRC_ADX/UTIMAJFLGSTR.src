#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise a jour champ strucutre dnas les modeles de données
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise a jour champ structure dnas les modeles de données") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJFLGSTR
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJFLGSTR
End

#-------------------#
$MAJFLGSTR
Local File =DOSSIER+".AWRKLNK"   [AWM]

If dim([AWM]FLGSTR)<0 : End : Endif

# Mise à jour de la table AWRKLNK
Call ECR_TRACE(mess(81,125,1)-"AWRKLNK:"-time$,0) From GESECRAN
Trbegin [AWM]
For [AWM]AWM0 
 If [AWM]FLGSTR=0
  [AWM]FLGSTR=1 
  Rewrite [AWM]
  If fstat
   Call ERREUR("AWRKLNK"-[F:AWM]MODELE,1) From DOSDIC
  Endif
 Endif
Next
Commit

Close Local File [AWM]

Return

