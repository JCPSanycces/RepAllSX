#<AdxTL>@(#)0.0.0.0 $Revision$
Run FUNSADJ
End

##############################################################
#UPD_IFO : régularisation des mouvements valorisés au FIFO ou LIFO
#         Cette régularisation se contente de revaloriser les mouvements
#         de sortie directement liés à l'élément de pile de l'entrée régularisée
##############################################################
$UPD_IFO

Local Char    LFILSMC(250)
Local Date    LCSTDATE
Local Char    LCSTTIM(GLONHS)
Local Integer LCSTCOU
Local Integer LSTOPSMC
Local Decimal LDELTATRF(1+GDIMCST*GACTDECCST)
Local Decimal LRCPQTYTRF

LINDFCY = 0
Raz LCUMAMT

# qté et montant du mouvement d'entrée
# 118579.c - pass in the correct value for CREMVTSEQ (was passing 0 prior to change)
Call CALVALDOC([F:SMA]STOFCY,[F:SMA]ITMREF,[F:SMA]VCRTYP,[F:SMA]VCRNUM,[F:SMA]VCRLIN,[F:STJ2]CREMVTSEQ, LNUMVLT, "O", LNBMVT, LRCPQTY, LRCPQTYACT, LRCPAMT, LDEVLIN) From FUNSADJB

# Issue 82593 - 2012-08-23 by CCC : Si la ligne de doc n'existe plus, on ne peut rien faire
If LRCPQTYACT=0
    Return
Endif

# Si l'écart non absorbé est <>0 => il faut réécrire les mouvements pour annuler l'écart non absorbé
If LDEVLIN(0)
    Raz LRCPDEV
    For I= 0 To dim(LRCPAMT)-1
        LRCPAMT(I)+=LDEVLIN(I)             # Montant réel de l'entrée
        LRCPPRI(I) = LRCPAMT(I)/LRCPQTY    # Prix de l'entrée
        LRCPDEV(I)-=LDEVLIN(I)             # Ecart non absorbé    (<0 pour le passer à UPDSTJLIN)
    Next

    Filter [SJA] Where STOFCY = [F:SMA]STOFCY
&                    & VCRTYP = [F:SMA]VCRTYP
&                    & VCRNUM = [F:SMA]VCRNUM
&                    & VCRLIN = [F:SMA]VCRLIN
&                    & ITMREF = [F:SMA]ITMREF
&                    & CREMVTSEQ = [F:SMA]CREMVTSEQ     # 118579.c - filter on CREMVTSEQ too

    Read [SJA]SJA0 First
    Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
    # On réécrit les mouvements de la ligne de doc pour ne plus avoir d'écart non absorbé
    # => delta valo = ldevlin
    # => delta ecart non abs  = lrcpdev
    LNB += func FUNSADJB.UPDSTJLIN([F:SMA]STOFCY,[F:SMA]VCRTYP,[F:SMA]VCRNUM,[F:SMA]VCRLIN,1,
&                                  LNBMVT, LRCPQTYACT, LRCPAMT,LDEVLIN, LRCPDEV, LVLTCOD, LNUMVLT, LAMTRND,LPRIRND)
    Filter [SJA]    # UPDSTJLIN a besoin du filtre

# Issue 80960 - 2012-03-23 by CCC : C'est le nouveau montant total de l'entrée qui sera passé à ISSADJ
#    # LRCPAMT reçoit le delta pour calcul des delta dans les sorties
#    For I= 0 To dim(LRCPAMT)-1
#        LRCPAMT(I) = LDEVLIN(I)             # Delta montant réel de l'entrée
#    Next

    LSUMVARRCP=-LRCPDEV
    LSUMVARISS=0
    LSUMVARDEV=LRCPDEV
    If GOK & (LSUMVARISS<>0 | LSUMVARRCP<>0 | LSUMVARDEV<>0)
        #MIHAL
        Call PITPRIADJ(LSUMVARRCP,LSUMVARISS,LSUMVARDEV) From STKPITLIB

        Call UPDITH(LNUMVLT,[F:STJ2]ITMREF,[F:STJ2]STOFCY,[F:STJ2]IPTDAT,LSUMVARRCP,LSUMVARISS,LSUMVARDEV) From FUNSADJB
        Raz LSUMVARRCP,LSUMVARISS,LSUMVARDEV
    Endif
Endif

Filter [STJ2] Where ITMREF=[F:SMA]ITMREF
&                 & CREMVTSEQ = [F:SMA]CREMVTSEQ     # 118579.c - filter on CREMVTSEQ too
Read [STJ2]STJ1=[F:SMA]STOFCY;[F:SMA]VCRTYP;[F:SMA]VCRNUM;[F:SMA]VCRLIN
Filter [STJ2]
LCSTDAT = [F:STJ2]CSTDAT
LCSTTIM = [F:STJ2]CSTTIM
LCSTCOU = [F:STJ2]CSTCOU
LIPT    = [F:STJ2]IPTDAT

Raz LSTOPSMC, LVCRNUM, LVCRLIN, LVCRTYP


$BOUCLE_SMC

If adxlog=0
    Trbegin [SMA]
Endif

If LSTOPSMC=1
    LFILSMC = "VCRNUM=LVCRNUM & VCRLIN=LVCRLIN & VCRTYP>LVCRTYP"
    LSTOPSMC += 1
Elsif LSTOPSMC=2
    LFILSMC = "VCRNUM=LVCRNUM & VCRLIN>LVCRLIN"
    LSTOPSMC += 1
Elsif LSTOPSMC=3
    LFILSMC = "VCRNUM>LVCRNUM"
    LSTOPSMC =0
Else
    LFILSMC = "1=1"
Endif

For [SMC]SMC0 Where CSTDAT = LCSTDAT
&                 & CSTTIM = LCSTTIM
&                 & CSTCOU = LCSTCOU
&                 & QTYSTU<>0
&                 & ITMREF = [F:SMA]ITMREF
&                 & evalue(LFILSMC)

    Call ECRTRACE("SMC --> "-mess([F:SMC]VCRTYP,701,1)-[F:SMC]VCRNUM-mess(61,100,1)-num$([F:SMC]VCRLIN), 0) From FUNSADJB

    Raz [F:STJ2]
    Filter [SJA] Where STOFCY = [F:SMC]STOFCY
&                    & VCRTYP = [F:SMC]VCRTYP
&                    & VCRNUM = [F:SMC]VCRNUM
&                    & VCRLIN = [F:SMC]VCRLIN
&                    & ITMREF = [F:SMC]ITMREF
&                    & REGFLG<> 2
    For [SJA]    # On récupère le 1er mouvement valable (break à la fin)
      Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND

      # 118579.n - to be sure to get an issue
      If [F:STJ2]ACTQTY<0

        Call ECRTRACE("STJ2 : "-[F:SJA]STOFCY+";"+[F:SJA]ITMREF+";"+num$([F:SJA]IPTDAT)+";"+num$([F:SJA]MVTSEQ)+";"+num$([F:SJA]MVTIND), 0) From FUNSADJB
        If [F:STJ2]IPTDAT<>LIPT & (LSUMVARISS<>0 | LSUMVARRCP<>0 | LSUMVARDEV<>0)
            Call UPDITH(LNUMVLT,[F:STJ2]ITMREF,[F:STJ2]STOFCY,LIPT,LSUMVARRCP,LSUMVARISS,LSUMVARDEV) From FUNSADJB
            Raz LSUMVARRCP,LSUMVARISS,LSUMVARDEV
            LNB += 1
        Endif

        LIPT = [F:STJ2]IPTDAT

        #---- Vérification que le mouvement est une sortie ----#
        Raz LDELTA, LDEVLIN, LAMTLIN, LQTYLIN, LQTYLINACT
        # Issue 112045 - 2015-10-30 by CCC : Add Counts case
        If find([F:STJ2]TRSTYP,2,4,6,11,24,29)
&        | [F:STJ2]TRSTYP=14 & [F:STJ2]ACTQTY<0 & [F:STJ2]BETCPY<>2
&        | [F:STJ2]TRSTYP=13 & [F:STJ2]ACTQTY<0 & (LNUMVLT=0 & find([F:STJ2]PRINAT,6,9) | LNUMVLT=1 & find([F:STJ2]PRINAT2,6,9))
            # Issue 83408 - 2012-08-28 by CCC
            ## Issue 80960 - 2012-03-23 by CCC : [SMC]QTYSTU est positif => ajout signe -
            #LNB += func FUNSADJB.ISSADJ(-[F:SMC]QTYSTU/LRCPQTYACT,LRCPAMT,LRCPPRI,LAMTRND,LPRIRND,LNUMVLT,LQTYLINACT,LAMTLIN,LDELTA,LDEVLIN)
            If GACTDECCST #X3-87885 MJH 23 April 2018. Only call LOADVAR if SPD is active
              Call LOADVAR(LAMTLIN, "[F:SMC]", 0, "", -1, 0, 0) From STKVALECR
            Endif
            LAMTLIN(0)=-[F:SMC]CST
            # LRCPAMT reçoit le delta pour calcul des delta dans les sorties
            For I= 0 To dim(LRCPAMT)-1
                # Issue 86836 - 2012-12-21 by CCC : LRCPAMT ne doit pas être modifié d'un mouvement à l'autre
                #LRCPAMT(I) = LRCPAMT(I)*(-[F:SMC]QTYSTU)/LRCPQTYACT-LAMTLIN(I)
                LDELTA(I) = LRCPAMT(I)*(-[F:SMC]QTYSTU)/LRCPQTYACT-LAMTLIN(I)
            Next
            Raz LAMTLIN
            # Issue 86836 - 2012-12-21 by CCC
            #LNB += func FUNSADJB.ISSADJ(1,LRCPAMT,LRCPPRI,LAMTRND,LPRIRND,LNUMVLT,LQTYLINACT,LAMTLIN,LDELTA,LDEVLIN)
            LNB += func FUNSADJB.ISSADJ(1,LDELTA,LRCPPRI,LAMTRND,LPRIRND,LNUMVLT,LQTYLINACT,LAMTLIN,LDELTA,LDEVLIN)
            [F:SMC]CST += -LDELTA(0)
            If GACTDECCST
                Call LOADFIC("[F:SMC]", LDELTA, "", "CST", -1, 1) From STKVALECR
            Endif
            Rewrite [SMC]

            # Issue 111385 - 2015-10-15 by CCC : If inter-sites movements => adjust corresponding entry price
            If find([F:STJ2]TRSTYP,4,14) & [F:STJ2]BETCPY<>2
                If [F:STJ2]TRSTYP=4 # Delivery
                    Filter [STJ1] Where ITMREF=[F:STJ2]ITMREF
&                                    & STOFCY<>[F:STJ2]STOFCY
&                                    & VCRTYPORI=[F:STJ2]VCRTYP
&                                    & VCRNUMORI=[F:STJ2]VCRNUM
&                                    & VCRLINORI=[F:STJ2]VCRLIN
&                                    & REGFLG=1
&                                Order By Key XSTJ=STOFCY;VCRTYP;VCRNUM;VCRLIN
                Elsif [F:STJ2]TRSTYP=14 # Direct inter-site
                    Filter [STJ1] Where ITMREF=[F:STJ2]ITMREF
&                                    & STOFCY<>[F:STJ2]STOFCY
&                                    & VCRTYP=[F:STJ2]VCRTYP
&                                    & VCRNUM=[F:STJ2]VCRNUM
&                                    & VCRLIN=[F:STJ2]VCRLIN
&                                    & REGFLG=1
&                                Order By Key XSTJ=STOFCY;VCRTYP;VCRNUM;VCRLIN
                Endif
                For [STJ1]XSTJ(4)
                    Raz LRCPQTYTRF
                    # Get qty received on the other site
                    For [STJ1]XSTJ
                        LRCPQTYTRF += [F:STJ1]ACTQTY
                    Next

                    Raz [M:SDP]

                    [M:SDP]QTY    = 0   # Delta is passed to adjustment process
                    # Calculate difference of amount for the corresponding entry
                    For I=0 To dim(LDELTA)-1
                        LDELTATRF(I) = LDELTA(I) * LRCPQTYTRF/LQTYLINACT
                    Next
                    LDELTATRF(0) = arr(LDELTATRF(0),LAMTRND)
                    [M:SDP]AMTTOT = LDELTATRF(0)
                    # Get detailed rounded amount
                    If GACTDECCST
                        Call REPVAL(LDELTATRF(0),LDELTATRF(1..dim(LDELTATRF)-1),LAMTRND,LDELTATRF(1..dim(LDELTATRF)-1)) From STKVALECR
                        Call LOADFIC("[M:SDP]", LDELTATRF, "", "CST", 1, 0) From STKVALECR
                    Endif
                    GISSADJ = 2     # Allow creation of STKMVTADJ record
                    Call REGPRIX([F:STJ1]STOFCY, [F:STJ1]TRSTYP, [F:STJ1]ITMREF, [F:STJ1]IPTDAT, "",
&                                [F:STJ1]VCRTYP, [F:STJ1]VCRNUM, [F:STJ1]VCRLIN, [F:STJ1]VCRTYP, [F:STJ1]VCRNUM, [F:STJ1]VCRLIN, 1, LRET) From STKVALREG
                    GISSADJ = 1
                Next
                Filter [STJ1]
            Endif

            # Issue 112045 - 2015-10-30 by CCC : Counts don't update ITMMVTHIS
            If [F:STJ2]TRSTYP<>13
                LSUMVARISS += LDELTA(0)
                LSUMVARDEV += LDEVLIN(0)
                For I=0 To dim(LDELTA)-1
                    LCUMAMT(I) += LDELTA(I)
                Next
            Endif
        Endif

        Break
      Endif
    Next
    Filter [SJA]

# Issue 118956.s - 2016-11-29 by CCC : during FIFO adjustment, delivery return linked to the delivery which has just been adjusted
#                                      or stock returns linked to WO for which we just have adjusted a WO issue
#                                      must be adjusted too
    If find([F:STJ2]TRSTYP,4,6)>0   # A delivery or a WO issue has just been adjusted
        Case [F:STJ2]TRSTYP
            When 4:  # => try to find all linked delivery returns
                    Call ECRTRACE(mess([F:STJ2]TRSTYP,704,1)-" => looking for delivery returns", 0) From FUNSADJB
                    Filter [SJA] Where STOFCY = [F:SMC]STOFCY
&                                    & ITMREF = [F:SMC]ITMREF
&                                    & VCRTYP = 13
&                                    & VCRTYPORI = [F:SMC]VCRTYP
&                                    & VCRNUMORI = [F:SMC]VCRNUM
&                                    & VCRLINORI = [F:SMC]VCRLIN
&                                    & REGFLG<> 2
            When 6:  # => try to find all Stock returns for the same WO
                    Call ECRTRACE(mess([F:STJ2]TRSTYP,704,1)-" => looking for stock returns", 0) From FUNSADJB
                    Filter [SJA] Where STOFCY = [F:SMC]STOFCY
&                                    & ITMREF = [F:SMC]ITMREF
&                                    & VCRTYP = 12
&                                    & VCRTYPORI = [F:STJ2]VCRTYPORI
&                                    & VCRNUMORI = [F:STJ2]VCRNUMORI
&                                    & VCRLINORI = [F:STJ2]VCRLINORI
&                                    & REGFLG<> 2
        Endcase
        Raz [F:STJ2]
        Read [SJA]SJA0 First
        While !fstat
            # Get last MVTSEQ known to avoid to read, later, records created by RCPADJ
            If [F:SJA]IPTDAT<>[F:STJ2]IPTDAT
                LMINSEQ = func FUNSADJB.GETLASTSEQ([F:SJA]STOFCY,[F:SJA]ITMREF,[F:SJA]IPTDAT,[F:SJA]CREMVTDAT,[F:SJA]CREMVTTIM)
            Endif
            Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
            If [F:STJ2]VCRTYP=13
&            | [F:STJ2]VCRTYP=12 & [F:STJ2]TRSTYP=19
                Call ECRTRACE("    found : "-[F:SJA]STOFCY-[F:SJA]ITMREF-num$([F:SJA]IPTDAT)-num$([F:SJA]MVTSEQ)-[F:SJA]VCRNUM-num$([F:SJA]VCRLIN), 0) From FUNSADJB
                # The entry adjustment will calculate the new value by using :
                #  - [F:SRW] for a delivery return
                #  - material issue values for a stock return
                Raz LDELTA, LDEVLIN, LAMTLIN, LQTYLIN, LQTYLINACT
                LNB += func FUNSADJB.RCPADJ(0, LAMTLIN, LAMTLIN, LAMTRND, LPRIRND, LNUMVLT, LQTYLIN, LAMTLIN, LDELTA, LDEVLIN)
                If GOK=0
                    Break
                Endif
            Endif
            Read [SJA]SJA0 Next
            # If next record is one of the records just created by adjustment => read next
            While !fstat & [F:SJA]IPTDAT=[F:STJ2]IPTDAT & [F:SJA]MVTSEQ<LMINSEQ
                Read [SJA]SJA0 Next
            Wend
        Wend
        Filter [SJA]
    Endif

    If GOK=0
        Break
    Endif
# Issue 118956.e - 2016-11-29 by CCC

    LVCRNUM=[F:SMC]VCRNUM
    LVCRLIN=[F:SMC]VCRLIN
    LVCRTYP=[F:SMC]VCRTYP

    If LNB>GMAXUPDTRS
        LSTOPSMC = 1
        Break
    Endif
Next

If GOK & !LSTOPSMC & (LSUMVARISS<>0 | LSUMVARRCP<>0 | LSUMVARDEV<>0)
    Call UPDITH(LNUMVLT,[F:STJ2]ITMREF,[F:STJ2]STOFCY,LIPT,LSUMVARRCP,LSUMVARISS,LSUMVARDEV) From FUNSADJB
    Raz LSUMVARRCP,LSUMVARISS,LSUMVARDEV
Endif
If GOK & LSTOPSMC
    Raz LNB
    Commit
    Goto BOUCLE_SMC
Endif

# Issue 111385 - 2015-10-15 by CCC
## Issue 88247 - 2013-04-15 by CCC
#Gosub UPD_TRFFCY From TRTADJIFO

Return

$UPD_TRFFCY
If clalev([F:SRW2])=0 : Local File STKREGWRK [SRW2] : Endif
For [SRW2] Where ITMREF = [F:SMA]ITMREF
&              & !find(VCRTYP,10,36)
    Raz [F:STJ]
    Filter [SJA] Where ITMREF=[F:SRW2]ITMREF
&                    & VCRTYPORI=[F:SRW2]VCRTYP
&                    & VCRNUMORI=[F:SRW2]VCRNUM
&                    & VCRLINORI=[F:SRW2]VCRLIN
    Read [SJA]SJA0 First
    If !fstat
        Gosub READ_STJ2 From TRTADJAVC
        #Infbox "régul réception inter-sites : "-[F:SJA]VCRNUM-num$([F:SJA]VCRLIN)
        LNB += func FUNSADJB.RCPADJ(1,LDELTA,LRCPPRI,LAMTRND,LPRIRND,LNUMVLT,LQTYLINACT,LAMTLIN,LDELTA,LDEVLIN)
        LSTOP=1
    Endif
    Filter [SJA]
Next
Return


########################################################################################
########################################################################################
########################################################################################
########################################################################################
#0- l'entrée à lorifgine de la régularisation doit être la plus ancienne en terme d'IPTDAT
#1- récupération des entrées ayant eu lieu après l'entrée à régulariser
#2- récupération de toutes les sorties qui ont utilisé un élément de pile correspondant à une des entrées récupérées précédemment

