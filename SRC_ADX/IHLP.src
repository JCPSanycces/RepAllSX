#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
######################################################################################
#    INTEGRATION DES MOTS CLE D'AIDE dans LES ECRANS                                 #
#    programme a lancer de X3 pour tous les dossiers                                 #
######################################################################################
Local File ADOSSIER [ADS]

#----------------------------#
#  saisie des dossiers       #
#----------------------------#

GSERVEUR = 0
Local Char     WNOMFIC (250)
Local Char     WAPPLI
Local Char     WNOM
Local Char     WMASQUE, WCHAMP , WAIDE
Local Char     ANC_MASQUE
Local Integer  OK
Local Shortint I

#-- fichier des ecrans avec mot cle d'aide 
WNOM = "AIDE_MOTCLE"
WNOMFIC = filpath("TXT",WNOM,"txt",0)

#-- si n'existe pas alors pas de mise à jour a faire 
If filinfo (WNOMFIC,1) < 0 :CALL MESSAGE("AIDE_MOTCLE.txt don't exist") From GESECRAN
        End 
Endif


Local Mask IHLP [DIA]
Raz [M:DIA]
For [ADS]
     If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>=0
           [M:DIA]DOSSIER([M:DIA]NBDOS) = [F:ADS]DOSSIER
           [M:DIA]NBDOS += 1
     Endif
Next

#----
OK = 2 
Call DIALO(OK,"IHLP process ") From GESECRAN 
If OK <> 2          : Goto FIN : Endif

If [M:DIA]NBDOS = 0 : Goto FIN : Endif

#----
Call TEMPON(" ") From GESECRAN 

SAVADXIFS = adxifs
SAVADXIRS = adxirs

For I = 1  To [M:DIA]NBDOS
    WAPPLI  = [M:DIA]DOSSIER(I-1)
    If WAPPLI <> ""
       Gosub CHARGEMENT
#      If WAPPLI <> "X3"
#          #--- validation dernier ecran 
#          Gosub VALIDATION
#      Endif
    Endif
Next I

#-- il faut que les ecrans soient a jour dans X3 avant de faire la validation
#-- validation des ecrans a la demande
If [M:DIA]WVALID = 2 
    For I = 1  To [M:DIA]NBDOS
        WAPPLI  = [M:DIA]DOSSIER(I-1)
            If WAPPLI <> ""
              If WAPPLI <> "X3"
                  #--- validation dernier ecran 
                  Gosub VALIDATION
              Endif
            Endif
    Next I
Endif


adxifs      = SAVADXIFS
adxirs      = SAVADXIRS
Call TEMPOFF From GESECRAN 


$FIN
Close Mask [DIA]
End

#########################################################################################
$CHARGEMENT 

WMASQUE = "" : WCHAMP = "" : WAIDE = ""

Local File =WAPPLI+".AMSKZON"  [XX1]
Local File =WAPPLI+".AMSK"     [AMS]

adxifs = " "
adxirs = chr$(13)+chr$(10)


$TRT_MSK
Openi WNOMFIC

Trbegin [XX1]

Rdseq WMASQUE,WCHAMP,WAIDE
If fstat = 0
    While fstat = 0 
        Readlock [XX1]CODE = WMASQUE ; WCHAMP
        If fstat = 0 
           If [F:XX1]MOTCLE = "" 
               #---------------------------------#
               # ecriture du mot cle d'aide      # 
               #---------------------------------#
                    [F:XX1]MOTCLE = WAIDE
                    Rewrite [XX1]
                    Update  [AMS] Where CODMSK = WMASQUE 
&                                 With UPDUSR = "ADMIN" , UPDDAT = date$
           Endif
        Endif
        Rdseq WMASQUE,WCHAMP,WAIDE
    Wend
Endif
Commit

Openi

Close File [XX1]
Close File [AMS]


Return


#########################################################################################
$VALIDATION 

Local Char SAVLAN
SAVLAN = GLANGUE

#-- lecture du dossier et recuperation DES langues
Read [ADS]DOSSIER = WAPPLI
If fstat <> 0 : Return : Endif

Local File =WAPPLI+".AMSK"     [AAA]


Filter [AAA] Where UPDUSR = "ADMIN" and UPDDAT = date$ 

For [AAA]
    WMASQUE = [F:AAA]CODMSK
    For I=0 To [F:ADS]NBRLAN-1
         WLAN = [F:ADS]LAN (I)
         If WLAN <> "" and filinfo(filpath("E"+WLAN,"","",WAPPLI),0)>=0
            GLANGUE     = WLAN
            adxrob(0)   = "E"+GLANGUE    
            messname(0) = GLANGUE
            adxtms      = WAPPLI+".APLSTD"
            adxmbm      = adxmbm
            Call MAJMSK(WMASQUE,0,WAPPLI,WAPPLI) From GRVALMSK
          Endif
    Next I
Next

Filter [AAA]

GLANGUE     = SAVLAN
adxrob(0)   = "E"+GLANGUE    
messname(0) = GLANGUE
adxtms      = "APLSTD"
adxmbm      = adxmbm



Close File [AAA]

Return














