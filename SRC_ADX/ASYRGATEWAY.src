#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog _EXPORTED() : End 1

#
# Entry point for RPC calls
#
$ACTION
Case ACTION
 When "GATEWAY" : Gosub GATEWAY
 Endcase
Return

#
# RPC Function GATEWAY
#
$GATEWAY
#ARCV.JSON
Local Char SCRIPT(250)
Local Char FUNCTION(250)
Local Clbfile PARAMETERS
Local Instance  PNODE          Using C_ASYRJSO

Local Integer GSERVEURSAV
GSERVEURSAV = GSERVEUR
GSERVEUR = 1

PNODE=JSON
While PNODE <> null
 Case toupper(PNODE.PRO)
  When "SCRIPT"           : SCRIPT = fmet PNODE.AGETCNT
  When "OPERATION"    : FUNCTION = fmet PNODE.AGETCNT
  When "PARAMETERS": PARAMETERS = fmet PNODE.AGETCNT
 Endcase
 PNODE = PNODE.NEX
Wend

If len(SCRIPT) and len(FUNCTION) and len(PARAMETERS)
 Local Instance IGATEWAY Using C_AGATEWAYETNA

 #remove quotes
 SCRIPT = func EAT_QUOTES(SCRIPT)
 FUNCTION = func EAT_QUOTES(FUNCTION)
 PARAMETERS = func EAT_QUOTES(PARAMETERS)

 # Transform the RPC call in a operation
 Local Integer ASTATUS
 IGATEWAY = NewInstance C_AGATEWAYETNA AllocGroup null
 ASTATUS = fmet IGATEWAY.AFROMRPC(SCRIPT,FUNCTION,PARAMETERS)

 # Prepare the answer
 Local Clbfile PARAMETERS
 Append PARAMETERS ,"C["
 For AI=1 To IGATEWAY.NBPAR
  Append PARAMETERS ,func FORMAT_VALUE('S', IGATEWAY.APARAMETERS(AI).NAME)
  Append PARAMETERS ,';'
  Append PARAMETERS, func FORMAT_VALUE('S', SEG2$( IGATEWAY.BODY , IGATEWAY.APARAMETERS(AI).START+1, IGATEWAY.APARAMETERS(AI).START+IGATEWAY.APARAMETERS(AI).LENGTH))
  Append PARAMETERS ,';'
 Next AI
 Append PARAMETERS ,'];"'
 PARAMETERS = escJson(PARAMETERS)

 Local Instance  NODES(1..)  Using C_ASYRJSO
 Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
 Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null

 Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
 Call JSON_ADDSTRING(NODES,ROOT,"script",SCRIPT)  From ASYRJSO
 Call JSON_ADDSTRING(NODES,ROOT,"operation",FUNCTION)  From ASYRJSO
 Call JSON_ADDCLB(NODES,ROOT,"parameters",PARAMETERS)  From ASYRJSO
 Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO

 FreeInstance IGATEWAY
Endif
GSERVEUR = GSERVEURSAV
Return

#
# Transforms the RPC call in GATEWAY operation
#
$AFROMRPC
Gosub PARSE_PARAMETERS
this.ASTATE = 1
Gosub GATEWAYS From =SCRIPT
Return

#
# Sets a parameter
#
$SETPARAMETER
If this.ASTATE = 1
 Gosub FREE_PARAMETERS
 this.ASTATE = 0
 this.NBPAR = 0
 this.BODY=""
Endif

Local Instance PARAMETER Using C_AGATEWAYPAR
PARAMETER= NewInstance C_AGATEWAYPAR AllocGroup this
this.NBPAR += 1
this.APARAMETERS(this.NBPAR) = PARAMETER

Local Clbfile R1
Local Integer T, D,AP
T = type(PARAMVALUE)
D = dim(PARAMVALUE)
R1 = func STRINGIFY(PARAMVALUE, D, T)

PARAMETER.NAME = PARAMNAME
PARAMETER.START = len(this.BODY)
PARAMETER.LENGTH = len(R1)
Append this.BODY,R1
Return

#
# Gets a parameter
#
$GETPARAMETER
Local Instance PARAMETER Using C_AGATEWAYPAR
Local Integer POS
Local Clbfile STR
Local Char LETTER(1)

POS = find(PARAMNAME, this.APARAMETERS(1..this.NBPAR).NAME)
If POS
 PARAMETER =  this.APARAMETERS(POS)
 STR = SEG2$( this.BODY , PARAMETER.START+1, PARAMETER.START+PARAMETER.LENGTH)
 POS = 1
 Gosub PARSE_VALUE
 If dim(PARAMVALUE) = 1
  PARAMVALUE =PARSED(1)
 Else
  #The trick used to accept array or simple value in ASET method forcess the engine to handle arrays that start at 0
  For AP=1 To maxtab(PARSED)
   PARAMVALUE(AP-1) = PARSED(AP)
  Next AP
 Endif
Else
   [L]ARET_VALUE = fmet this.ASETERROR("",mess(294,143,1),[V]CST_AERROR)
Endif
Return

###############################################################################
#
# Internal functions
#
Subprog FAIL(STR)
 Value Clbfile STR
 Local Integer DUMMY
 Infbox STR
 DUMMY = evalue("1/0")
End

Funprog TYPE_LETTER(T)
Value Integer T
 If T >= 10 and T <= 265 : End "S": Endif
 Case T
 When 1: End "V"
 When 2: End "J"
 When 3 : End "D"
 When 4 : End "I"
 When 6 : End "F"
 When 7 : End "N"
 When 40 : End "S"
 When 522 : End "B"
 When 523 : End "C"
 When 524 : End "O"
 When 525 : End "U"
 When 526 : End "T"
 When Default : Call FAIL("bad type" - num$(T))
 Endcase
End ""

Funprog SKIP_PROP(NAME)
End find(NAME, "AATTRIBUTES", "ACACHE", "ACCESS", "ACTX", "AERROR", "AINF", "_AINFOS","_AINSPTH", "AKEYS", "AORDER", "APARENT", "ASTALIN", "AUUID", "AXX","CREDAT", "CREDATTIM", "CREUSR", "ENAFLG",
& "EXPNUM",
& "MODULE",
& "UPDDAT","UPDDATTIM", "UPDUSR" ) <> 0

Funprog FORMAT_INSTANCE(V)
 Local Clbfile S
 Local Integer N
 Local Char PRO(250)
 Local Integer PTYPE, PDIM,PMAX,I

S = "!" + V.ObjectType + "{"
N = V.ObjectNbs
For J = 1 To N
 PRO = V.ObjectVar(J)
 PTYPE = evalue('type(V.'+PRO+')')
 PDIM = evalue("dim(V." + PRO + ")")

 If PTYPE <> -1 and not func SKIP_PROP(PRO)
  If PTYPE = 524 and PDIM > 1
   If evalue("V."+PRO) <> null
    #(evalue("V." + PRO) doesn't create an array in this case ...
    PMAX = evalue("maxtab(V." + PRO+')')
    Local Instance COL(1..) Using =evalue("V."+PRO+".ObjectType")
    For I=1 To PMAX
     COL(I) =evalue("V." + PRO+"("+num$(I) +")")
    Next I
    S += PRO + ":" + func STRINGIFY(COL, PDIM, PTYPE)
   Endif
  Else
   S += PRO + ":" + func STRINGIFY(evalue("V." + PRO), PDIM, PTYPE)
  Endif
 Endif
Next J
S += "}"
End S


Funprog FORMAT_VALUE(LETTER, V)
Local Integer COUNT
Local Clbfile GOT
 Case LETTER
 When "D" : End format$("D:YYYY[-]MM[-]DD",V)
 When "I", "F", "N", "T","V","J" : End num$(V)
 When "U":
  GOT = num$(V)
  GOT = left$(GOT,8) + mid$(GOT,10,4) + mid$(GOT,15,4) + mid$(GOT,20,4) + mid$(GOT,25,12)
  End GOT :#UUID without -
 When "S", "C" : End num$(len(V)) + '!' + V
 When "B" :
  COUNT = b64Encode(V, GOT)
  End '!' +GOT
 When "O" : End func FORMAT_INSTANCE(V)
 When Default : Call FAIL("bad type letter" - LETTER)
 Endcase
End ""


Funprog STRINGIFY(V, D, T)
 Local Clbfile RESULT
 Local Char LETTER(1)
 LETTER = func TYPE_LETTER(T)
 RESULT += LETTER
 If (D > 1)
  RESULT += "["
  #WARNING : Since D isn't declared as a parameter the engine autodeclare it as an array which starts at 0
  For I = 0 To maxtab(V)
   RESULT += func FORMAT_VALUE(LETTER, V(I)) + ";"
  Next I
  RESULT += "];"
 Else
  RESULT += func FORMAT_VALUE(LETTER, V) + ";"
 Endif
End RESULT



Subprog EAT(STR, POS, C)
 Value Clbfile STR
 Variable Integer POS
 Value Char C()
 If mid$(STR, POS, 1) <> C
  Call FAIL("expected " + C + " got" - mid$(STR, POS, 1))
 Endif
 POS += 1
End

Subprog PARS_PROPS(STR, POS, INS)
 Value Clbfile STR
 Variable Integer POS

Local Char C(1)

Local Integer I,J,LINE
Local Char CLNAME, PROPNAME
While (POS < len(STR) and mid$(STR, POS, 1) <> '}')
 I = instr(POS, STR, ":")
 If I <= POS
  Call FAIL("missing : after property name")
 Endif
 PROPNAME = mid$(STR, POS, I - POS)
 POS = I + 1
 Gosub PARSE_VALUE
 If evalue('type(INS.'+PROPNAME +')') = 524
  #It's a collection
  For J=1 To maxtab(PARSED)
   Assign "INS." + PROPNAME + '(' + num$(J) + ')' With PARSED(J)
  Next J
 Else
  Assign "INS." + PROPNAME With PARSED(1)
Endif
Wend
Call EAT(STR, POS, "}")
End


$PARSE_VALUE
Local Char LETTER(1)
Local Integer IS_ARRAY,IDX,COUNT,D,I,LENG
Local Clbfile CLB
Local Char CLNAME

LETTER = mid$(STR, POS, 1)
Case LETTER
 When "V": Local Tinyint PARSED(1..)
 When "J": Local Shortint PARSED(1..)
 When "D": Local Date PARSED(1..)
 When "I": Local Integer PARSED(1..)
 When "F": Local Float PARSED(1..)
 When "N": Local Decimal PARSED(1..)
 When "S": Local Char PARSED(250)(1..)
 When "B": Local Blbfile PARSED(1)(1..)
 When "C": Local Clbfile PARSED(1)(1..)
 When "U": Local Uuident  PARSED(1..)
 When "T": Local Datetime PARSED(1..)
Endcase

POS += 1
If mid$(STR, POS, 1) = "["
 IS_ARRAY = 1
 POS += 1
Else
 IS_ARRAY = 0
Endif
IDX=1

While 1
 Case LETTER
 When "I","F","N","V","J"
  I = instr(POS, STR, ";")
  PARSED(IDX) = val(mid$(STR, POS, I - POS))
  POS = I
 When "U"
  I = instr(POS, STR, ";")
  CLB = mid$(STR, POS, I - POS)
  GOT = left$(CLB,8) +'-'+ mid$(CLB,9,4) +'-'+ mid$(CLB,13,4) +'-'+ mid$(CLB,17,4) +'-'+ mid$(CLB,21,12)
  PARSED(IDX) = toUuid(GOT)
  POS = I
 When 'S'
  I = instr(POS, STR, "!")
  LENG = val(mid$(STR, POS, I))
  PARSED(IDX) =  mid$(STR, I + 1, LENG)
  POS = I + 1 + LENG
 When 'C'
  I = instr(POS, STR, "!")
  LENG = val(mid$(STR, POS, I))
  PARSED(IDX) =  mid$(STR, I + 1, LENG)
  POS = I + 1 + LENG
 When 'B'
  POS = instr(POS, STR, "!")
  I = instr(POS, STR, ";")
  LENG = I - POS-1
  CLB = mid$(STR, POS + 1, LENG)
  COUNT = b64Decode(CLB,  PARSED(IDX) )
  POS += 1 + LENG
 When 'D'
  PARSED(IDX) = gdat$(val(mid$(STR, POS + 8, 2)), val(mid$(STR, POS + 5, 2)), val(mid$(STR, POS, 4)))
  POS += 10
 When 'T'
  I = instr(POS, STR, ";")
  PARSED(IDX) = gdatetime$(mid$(STR, POS, I - POS))
  POS = I
 When 'O'
  Call EAT(STR, POS, "!")
  I = instr(POS + 1, STR, "{")
  CLNAME = mid$(STR, POS, I - POS)
  POS = I + 1
  If IDX = 1
   Local Instance PARSED(1..) Using =CLNAME
  Endif
  PARSED(IDX) = NewInstance [GATEWAY] With =CLNAME
  Call PARS_PROPS(STR, POS, PARSED(IDX))
 When Default
  Call FAIL("invalid character" - LETTER)
 Endcase

 Call EAT(STR, POS, ";")
 If IS_ARRAY
  If mid$(STR, POS, 1) = ']'
   POS += 1
   Call EAT(STR, POS, ";")
   Break
  Endif
  IDX += 1
 Else
  Return
 Endif
Wend

Return

$ARPC1
Local Integer AI
Local Clbfile ARGUMENTS
Local Clbfile RESHEAD
Local Clbfile STR

ARET_VALUE = [V]CST_AOK
Append ARGUMENTS, '"'+SCRIPT + '","' + AGATEWAY +'","'

Append ARGUMENTS ,"C["
For AI=1 To this.NBPAR
 Append ARGUMENTS ,func FORMAT_VALUE('S', this.APARAMETERS(AI).NAME)
 Append ARGUMENTS ,';'
 Append ARGUMENTS, func FORMAT_VALUE('S', SEG2$( this.BODY , this.APARAMETERS(AI).START+1, this.APARAMETERS(AI).START+this.APARAMETERS(AI).LENGTH))
 Append ARGUMENTS ,';'
Next AI
Append ARGUMENTS ,'];"'

ASTATUS = func ASYRWEBSER.EXEC_JS(ASYRMODULE, 'gateway', 'wait', ARGUMENTS, '', 0, '', '0', RESHEAD, STR)
If ASTATUS = 200
 Gosub PARSE_PARAMETERS
Else
 ARET_VALUE = [V]CST_AERROR
Endif
Return

$ARPC2
this.ASTATE = 1 :# 1 = read
Onerrgo ARPC_ERROR
Gosub GATEWAYS From =SCRIPT
Onerrgo
Return

$ARPC_ERROR
Local Integer EXISTS
Call EXISTE_ADX("","",SCRIPT,EXISTS) From ASYRSYS
If EXISTS = 0
 ARET_VALUE = fmet this.ASETERROR("",func ASYRFNC.MES1(mess(12,149,1),SCRIPT),[V]CST_AERROR)
Endif
ARET_VALUE = CST_AERROR
Resume

$PARSE_PARAMETERS
Local Integer AI
Local Integer POS
Local Instance PARAMETER Using C_AGATEWAYPAR

Gosub FREE_PARAMETERS

this.ASTATE = 0
this.NBPAR = 0
this.ASTATE = 0
this.BODY =  ""

POS = 1
Gosub PARSE_VALUE From ASYRGATEWAY
AI = 1
While AI <=  maxtab(PARSED)
 PARAMETER= NewInstance C_AGATEWAYPAR AllocGroup this

 this.NBPAR += 1
 PARAMETER.NAME = PARSED(AI)
 AI += 1
 PARAMETER.START = len(this.BODY)
 PARAMETER.LENGTH = len(PARSED(AI))
 this.BODY += PARSED(AI)
 AI += 1
 this.APARAMETERS(this.NBPAR) = PARAMETER
Wend

Return

$FREE_PARAMETERS
For AI=1 To maxtab(this.APARAMETERS)
 FreeInstance this.APARAMETERS(AI)
 this.APARAMETERS(AI) = null
Next AI
Return

Funprog EAT_QUOTES(STR)
End mid$(STR,2,len(STR)-2)

