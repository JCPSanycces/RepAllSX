#<AdxTL>@(#)2.0.0.0 $Revision$  Gestion du fichier DICODAD
Call OBJET("DDA",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LIENS"    : Gosub LIENS
 When "SEL_TABLE"
  Case TABLE
   When "SELDDA"   : Gosub SELDDA
  Endcase
 When "FIN_TABLE"
  Case TABLE
   When "SELDDA"   : Gosub FINDDA
  Endcase
Endcase
Return

$OUVRE
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
Return

$LIENS
Call TEXTE([F:DDA]DES,[M]ZDES) From OBJDIV
Read [ATZ]CODZONE = [F:DDA]TBL;[F:DDA]FLD
[M]TYP = [F:ATZ]CODTYP
Read [ATY]CODTYP = [F:ATZ]CODTYP
Call TEXTE([F:ATY]INTITTYP,[M]DESTYP) From OBJDIV
Return

$SELDDA
If clalev([F:DAD])=0 : Local File DICODAD  [DDA] : Endif
Local Integer I
SAV_VALEUR=VALEUR
I = instr(1,VALEUR, "]")
If I
 VALEUR = mid$ (VALEUR,I+1,len(VALEUR)-I)
 ORDRE  = "FLD"
Else
 VALEUR = ""
 ORDRE  = "ROW;FLD"
Endif
OBJET = "DDA"
START = "FLD"

CRITERE = 'ENASEL=2 & (CODACT="" |CODACT<>"'+[F:DDA]CODACT+'")'
Return

$FINDDA
If status=7
 VALEUR = SAV_VALEUR
Else
 If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
 If VALEUR<>""
  Read [ATB]CODFIC = [F:DDA]TBL
  If !fstat
   VALEUR = toupper("[F:"+[F:ATB]ABRFIC+"]"+VALEUR)
  Else
   VALEUR = SAV_VALEUR
  Endif
 Endif
Endif
Return

