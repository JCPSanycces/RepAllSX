#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################
## control reference / collection
###########################################################################

Funprog ALISTCTRLREF(AINSTANCE,APRONAME,AVALUE,BPATYP,BPANUM,BPAADD,BPA)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Tinyint BPATYP
Value Char BPANUM
Value Char BPAADD
Variable Instance BPA (1..) Using BPADDRESS

Local Integer ASTATUS
Local Integer INDEX
Local Integer IRESULT
Local Integer BEXIST
BEXIST= 0


For INDEX=1 To MAXTABL(BPA.BPAADD)
  IRESULT= find (AVALUE, BPA(INDEX..maxtab(BPA)).BPAADD)
  If IRESULT<>0
    If BPA(IRESULT).BPAADD = AVALUE or BPA(IRESULT).BPANUM = BPANUM or BPA(IRESULT).BPATYP = BPATYP
      BEXIST=1
    Endif
  Endif
  If BEXIST=1
    Break
  Else
   INDEX=IRESULT+1
  Endif
Next
If BEXIST=0
  [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]BPATYP)+"~"+num$([L]BPANUM)+"~"+num$([L]BPAADD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif
If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File BPADDRESS [BPA]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".BPADDRESS" [BPA]
Endif

Default File [F:BPA]
Read [F:BPA]BPA0 = [L]BPATYP;[L]BPANUM;[L]BPAADD
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]BPATYP)+"~"+num$([L]BPANUM)+"~"+num$([L]BPAADD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
 End [L]ASTATUS
Endif

End [V]CST_AOK

