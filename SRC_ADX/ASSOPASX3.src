#<AdxTL>@(#)10.0.0.0 $Revision$
Call PARCLI("UserName",GBIDC1) From GLOBVAR
GBIDC2 = password
Call PASSE(GBIDC1,GBIDC2)
Infbox GBIDC2
End

#-----------------------------------#
Subprog PASSE(USER,PASSE)
Value    Char USER
Variable Char PASSE
Local Integer OK
Local Char TIT(30)
If !GSERVEUR
 Local Mask ASSOPASX3 [PAS]
 [M:PAS]USER  = [L]USER
 [M:PAS]PASSE = [L]PASSE
 Call TITAWI("ASSOPASX3",TIT) From OBJDIV
 Call DIALWIN(OK,TIT,"ASSOPASX3") From GESECRAN
 If OK<>2 : mkstat = 1 : End : Endif
 [L]PASSE = [M:PAS]PASSE
 Close Local Mask [PAS]
Endif
End
