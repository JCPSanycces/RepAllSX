#<AdxTL>@(#)10.0.0.0 $Revision$
Close Local File
Raz GNBMASKOUV
Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"AFRQTSUB","ARQTSUB","") From GSAISIE
End

#------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "VERF_LISTE"   : Gosub VERF_LISTE
Endcase
Return

#---------------#
$OUVRE
Gosub OUVRE_TABLE
Gosub FERME_ATEXTE
Gosub OUVRE_ATEXTE
Return

#---------------#
$OUVRE_TABLE
If clalev([F:ABP])=0 : Local File ABATPAR  [ABP] : Endif
If clalev([F:ABR])=0 : Local File ABATRQT  [ABR] : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif
If clalev([F:ABT])=0 : Local File ABATTAC  [ABT] : Endif
If clalev([F:ABG])=0 : Local File ABATGRP  [ABG] : Endif
If clalev([F:ABH])=0 : Local File ABATHOR  [ABH] : Endif
If clalev([F:ABC])=0 : Local File ABATCAL  [ABC] : Endif
Return

#-------------------------------------------------------------------------------------------------------#
# Les tables ABATGRP et ABATTAC étant de type X3 communes à plusieurs dossiers et l'intitulé
# des tâches et groupes étant du type ATX, il est nécessaire d'ouvrir la table ATEXTE dans le dossier X3
#-------------------------------------------------------------------------------------------------------#

$OUVRE_ATEXTE
If clalev([F:ATX])=0
 Local Char DOSX3(GLONADS)
 If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
 Read [ADW]ADW0 = "";"";"SUPDOS"
 DOSX3 = [F:ADW]VALEUR
 If DOSX3="" : DOSX3 = "X3" : Endif
 Local File =DOSX3+".ATEXTE" [ATX]
Endif
Return

#---------------#
$FERME_ATEXTE
If clalev([F:ATX])>0 : Close Local File   [ATX] : Endif
Return

#---------------#
$DEBUT
Local Char    TACHE(GLONABT) , DOSSIER(GLONADS) , USER(GLONAUS) , FICHIER(GDIMFIC)
Local Char    JOB(1)
Raz [M:ABQ1]
Call PARAMUTIL("EXTBATCH",JOB,"","") From SUBAUS
Read [ABP]SPOOL First
Call SETFIC("test","mod",FICHIER) From SERVJOB
If [F:ABP]JOB<>2 | JOB<>"2" | FICHIER="" | clalev([M:ABR1])>0
 [M:ABQ1]JOBMOD = 1
 Affzo [M:ABQ1]JOBMOD
 Grizo [M:ABQ1]JOBMOD
Endif
Return

#---------------#
$AVANT_BOUTON
Case BOUT
 When "V"
  DOSSIER = [M:ABQ1]DOSSIER
  USER    = [M:ABQ1]USER
  Gosub SETUSR
  If [M:ABQ1]GRP=""
   TACHE = [M:ABQ1]TACHE
   Gosub VERFTAC
   If GERR
    Gosub RESTUSR
   Endif
  Endif
  Gosub FERME_ATEXTE
Endcase
Return

#---------------#
$BOUTON
Case BOUT
 When "V"
  Gosub RESTUSR
  If [M:ABQ1]GRP<>""
   Call GROUPE
  Endif
  Gosub OUVRE_ATEXTE
  FIN = 1
Endcase
Return

#---------------#
$SETUSR
If clalev([F:AUS])>0 : Close Local File [AUS] : Endif
If clalev([F:AFC])>0 : Close Local File [AFC] : Endif
If clalev([F:ACT])>0 : Close Local File [ACT] : Endif
If clalev([F:ADW])>0 : Close Local File [ADW] : Endif
If clalev([F:ADU])>0 : Close Local File [ADU] : Endif
If clalev([F:ADP])>0 : Close Local File [ADP] : Endif
If clalev([F:AFT])>0 : Close Local File [AFT] : Endif
If clalev([F:AME])>0 : Close Local File [AME] : Endif
If DOSSIER=nomap
 Local File AUTILIS   [AUS]
 Local File AFONCTION [AFC]
 Local File ACTION    [ACT]
 Local File ADOVAL    [ADW]
 Local File ADOVALAUS [ADU]
 Local File ADOPAR    [ADP]
 Local File AFCTFCT   [AFT]
 Local File AMETUTI   [AME]
Else
 Local File =DOSSIER+".AUTILIS"   [AUS]
 Local File =DOSSIER+".AFONCTION" [AFC]
 Local File =DOSSIER+".ACTION"    [ACT]
 Local File =DOSSIER+".ADOVAL"    [ADW]
 Local File =DOSSIER+".ADOVALAUS" [ADU]
 Local File =DOSSIER+".ADOPAR"    [ADP]
 Local File =DOSSIER+".AFCTFCT"   [AFT]
 Local File =DOSSIER+".AMETUTI"   [AME]
Endif
Local Char SAVFNC(GLONAFC) , SAVPRF(GLONAFT) , SAVUSR(GLONAUS)
SAVFNC    = GFONCTION
SAVUSR    = GUSER
SAVPRF    = GPROFIL
GUSER     = USER
Call LECTURE("AUS",GUSER,"") From CONTOBJ
If [F:AUS]PRFFCT=""
 Call LECTURE("AME",[F:AUS]CODMET,"") From CONTOBJ
 GPROFIL   = [F:AME]PRFFCT
Else
 GPROFIL   = [F:AUS]PRFFCT
Endif
Return

#---------------#
$RESTUSR
If clalev([F:AUS])>0 : Close Local File [AUS] : Endif
If clalev([F:AFC])>0 : Close Local File [AFC] : Endif
If clalev([F:ACT])>0 : Close Local File [ACT] : Endif
If clalev([F:ADU])>0 : Close Local File [ADU] : Endif
If clalev([F:ADW])>0 : Close Local File [ADW] : Endif
If clalev([F:ADP])>0 : Close Local File [ADP] : Endif
If clalev([F:AFT])>0 : Close Local File [AFT] : Endif
Local File AUTILIS   [AUS]
Local File AFONCTION [AFC]
Local File ACTION    [ACT]
GUSER     = SAVUSR
GFONCTION = SAVFNC
GPROFIL   = SAVPRF
Call AUTORIS From EXEFNC
Close Local File [AUS], [AFC], [ACT]
If clalev([F:ABR])=0 : Local File ABATRQT  [ABR] : Endif
Default File [ABR]
Return

#---------------#
$VERFTAC
# Existence de la tâche
Read [ABT]CODTAC = TACHE
If fstat
 GMESSAGE = mess(12,100,1)-"ABATTAC"-TACHE : GERR = 1 : # Erreur d'accès sur le fichier
 Return
Endif
# Niveau d'accès aux batchs
If [F:ABT]NIVEAU<>0 & GPROFIL<>GSUPER
 Local Char LNIVBATCH(10)
 Call PARAMUTIL("NIVBATCH",LNIVBATCH,"","") From SUBAUS
 If val(LNIVBATCH)<[F:ABT]NIVEAU
  GMESSAGE = TACHE-":"-mess(38,134,1) : GERR = 1 : # Niveau d'accès insuffisant
  Return
 Endif
Endif
# Vérif multi-dossier
If [F:ABT]MULTIDOS<>2 & DOSSIER<>nomap
 GMESSAGE = TACHE-":"-mess(39,134,1)-DOSSIER : GERR = 1
# Cette tâche doit être activée depuis le dossier
Endif
# Droits sur la fonction
If [F:ABT]FONCTION<>""
 GFONCTION = [F:ABT]FONCTION
 Call LECTURE("AFC",GFONCTION,"") From CONTOBJ
 Call AUTORIS From EXEFNC
 If GNBAUZ=0
  GMESSAGE = [F:ABT]FONCTION-":"-mess(74,100,1) : GERR = 1 : # Fonction non autorisée
  Return
 Endif
 For I=0 To [F:AFC]NBVAR-1
  If [F:AFC]VALEUR(I)<>"#"
   Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
  Else
   Assign [F:AFC]VARIA(I) With [F:ABT]PARAM
  Endif
 Next I
Endif
Return

#---------------#
$VERFGRP
# Existence de la tâche
Read [ABG]ABG0 = GROUPE
If fstat
 GMESSAGE = mess(12,100,1)-"ABATGRP"-GROUPE : GERR = 1 : # Erreur d'accès sur le fichier
 Return
Endif
# Niveau d'accès aux batchs
If [F:ABG]NIVEAU<>0 & GPROFIL<>GSUPER
 Local Char LNIVBATCH(10)
 Call PARAMUTIL("NIVBATCH",LNIVBATCH,"","") From SUBAUS
 If val(LNIVBATCH)<[F:ABG]NIVEAU
  GMESSAGE = GROUPE-":"-mess(38,134,1) : GERR = 1 : # Niveau d'accès insuffisant
  Return
 Endif
Endif
Return

#------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELUSR"
  OBJET = "AUS"
  Local File =PARAM(1)+".AUTILIS" [AUS]
Endcase
Return

#---------------#
$SEL_LISTE
Case LISTE
 When "SELDATBAT" : Gosub SEL_DATBAT
 When "SELHORBAT" : Gosub SEL_HORBAT
Endcase
Return

#---------------#
$VERF_LISTE
Case LISTE
 When "SELHORBAT" : Gosub VERF_HORBAT
Endcase
Return

#---------------#
$SEL_DATBAT
Local Char GRP(GLONABG), TACHE(GLONABT), HOR(GLONABH)
Local Date DAT
GRP   = PARAM(1)
TACHE = PARAM(2)
HOR   = PARAM(3)
If VALEUR=[0/0/0]
 Call INIDAT(HOR,GRP,TACHE,DAT)
Else
 DAT = VALEUR
Endif
NBTEX = 0
While NBTEX<dim(TEXTE)-1
 Call CTLDAT(HOR,GRP,TACHE,DAT,OK)
 If OK
  NBTEX += 1
  TEX(NBTEX)   = DAT
  TEXTE(NBTEX) = format$("D:"+GFMDAT,DAT)-day$(DAT)
 Endif
 DAT += 1
Wend
Return

#---------------#
$SEL_HORBAT
Local Integer I, JOUR, OK, FERIE
Local Char    GRP(GLONABG), TACHE(GLONABT), HOR(GLONABH), TIM(10)
Local Date    DAT
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

GRP   = PARAM(1)
TACHE = PARAM(2)
DAT   = PARAM(3)
HOR   = PARAM(4)

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR

If VALEUR=""
 Call INIHOR(HOR,GRP,TACHE,DAT,TIM,OK)
Else
 TIM = VALEUR
Endif
NBTEX = 0
If GRP<>""
 Read [ABG]ABG0=GRP
 HOR = [F:ABG]HOR
Elsif TACHE<>""
 Read [ABT]CODTAC=TACHE
 HOR = [F:ABT]HOR
Endif
If HOR<>""
 Read [F:ABH]ABH0=HOR
 JOUR = dayn(DAT)
 FERIE = 0
 If [F:ABH]CAL<>""
  Read [F:ABC]ABC0=[F:ABH]CAL
  If [F:ABC]NBRDAT>0
   For I=0 To [F:ABC]NBRDAT-1
    If DAT>=[F:ABC]STRDAT(I) & DAT<=[F:ABC]ENDDAT(I)
     FERIE = 1 : Break
    Endif
   Next I
  Endif
 Endif
 If FERIE | [F:ABH]DAYOPE(JOUR-1)=1
  If [F:ABH]NBRCLO>0
   For I=0 To [F:ABH]NBRCLO-1
    NBTEX += 1
    TEX(NBTEX)   = num$(NBTEX)
    TEXTE(NBTEX) = format$("K:##[:]##",[F:ABH]STRCLO(I))-format$("K:##[:]##",[F:ABH]ENDCLO(I))
   Next I
  Endif
 Else
  If [F:ABH]NBROPE>0
   For I=0 To [F:ABH]NBROPE-1
    NBTEX += 1
    TEX(NBTEX)   = num$(NBTEX)
    TEXTE(NBTEX) = format$("K:##[:]##",[F:ABH]STROPE(I))-format$("K:##[:]##",[F:ABH]ENDOPE(I))
   Next I
  Endif
 Endif
Endif
If NBTEX=0
 Call MESSAGE(mess(108,134,1)) From GESECRAN : # Pas de contraintes horaires
Endif
Return

#---------------#
$VERF_HORBAT
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

I = val(VALEUR)-1
If I>=0 & I<dim([F:ABH]STRCLO)
 # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
 Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
 If FERIE | [F:ABH]DAYOPE(JOUR-1)=1
  If DAT=[L]DD & [L]HH>=[F:ABH]STRCLO(I) & [L]HH<=[F:ABH]ENDCLO(I)
   VALEUR = [L]HH
  Else
   VALEUR = [F:ABH]STRCLO(I)
  Endif
 Else
  If DAT=[L]DD & [L]HH>=[F:ABH]STROPE(I) & [L]HH<=[F:ABH]ENDOPE(I)
   VALEUR = [L]HH
  Else
   VALEUR = [F:ABH]STROPE(I)
  Endif
 Endif
Endif
Return

#------------------------------------------------#
# S/P de contrôles
#------------------------------------------------#
Subprog CTLDAT(HOR,GRP,TACHE,DAT,OK)
Value    Char    HOR
Value    Char    GRP
Value    Char    TACHE
Value    Date    DAT
Variable Integer OK
Local Integer FERIE , I , JOUR
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

OK = 1
JOUR = dayn(DAT)

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
If DAT<[L]DD
 OK = 0 : GMESSAGE = mess(167,133,1) : # Impossible de programmer une tâche pour une période passée
 End
Endif
If GRP<>""
 Read [ABG]ABG0=GRP
 HOR = [F:ABG]HOR
Elsif TACHE<>""
 Read [ABT]CODTAC=TACHE
 HOR = [F:ABT]HOR
Endif
If HOR<>""
 FERIE = 0
 Read [ABH]ABH0=HOR
 If [F:ABH]CAL<>""
  Read [ABC]ABC0=[F:ABH]CAL
  If [F:ABC]NBRDAT>0
   For I=0 To [F:ABC]NBRDAT-1
    If DAT>=[F:ABC]STRDAT(I) & DAT<=[F:ABC]ENDDAT(I)
     FERIE = 1 : Break
    Endif
   Next I
  Endif
 Elsif [F:ABH]DAYOPE(JOUR-1)=1
  FERIE = 1
 Endif
 If !FERIE & [F:ABH]NBROPE=0
  OK = 0
 Elsif FERIE & [F:ABH]NBRCLO=0
  OK = 0
 Endif
Endif
If !OK
 GMESSAGE = mess(31,135,1)+"\"+HOR-[F:ABH]DES : # Jour interdit par la contrainte
Endif
End

#------------------------------------------------#
Subprog INIDAT(HOR,GRP,TACHE,DAT)
Value    Char HOR
Value    Char GRP
Value    Char TACHE
Variable Date DAT
Local Integer I, OK, JOUR, FERIE
OK = 1
If GRP<>""
 Read [ABG]ABG0=GRP
 HOR = [F:ABG]HOR
Elsif TACHE<>""
 Read [ABT]CODTAC=TACHE
 HOR = [F:ABT]HOR
Endif
If HOR<>""
 Read [ABH]ABH0=HOR
 OK = 0
 OK =  ([F:ABH]NBRCLO=0 & [F:ABH]NBROPE=0)
 OK += ([F:ABH]NBROPE=0 & sum([F:ABH]DAYOPE)=14)
 OK += ([F:ABH]NBRCLO=0 & sum([F:ABH]DAYOPE)=7)
 If OK : End : Endif
 While !OK
  FERIE = 0
  If [F:ABH]CAL<>""
   Read [ABC]ABC0=[F:ABH]CAL
   If [F:ABC]NBRDAT>0
    For I=0 To [F:ABC]NBRDAT-1
     If DAT>=[F:ABC]STRDAT(I) & DAT<=[F:ABC]ENDDAT(I)
      FERIE = 1 : Break
     Endif
    Next I
   Endif
  Endif
  JOUR = dayn(DAT)
  OK = 1
  If (FERIE | [F:ABH]DAYOPE(JOUR-1)=1) & [F:ABH]NBRCLO=0
   OK = 0
  Elsif [F:ABH]DAYOPE(JOUR-1)=2 & [F:ABH]NBROPE=0
   OK = 0
  Endif
  If !OK : DAT += 1 : Endif
 Wend
Endif
End

#------------------------------------------------#
Subprog INIHOR(HOR,GRP,TACHE,DAT,TIM,OK)
Value    Char HOR
Value    Char GRP
Value    Char TACHE
Value    Date DAT
Variable Char TIM
Variable Integer OK
Local Integer I , JOUR , FERIE
JOUR = dayn(DAT)
OK = 1
If GRP<>""
 Read [ABG]ABG0=GRP
 HOR = [F:ABG]HOR
Elsif TACHE<>""
 Read [ABT]CODTAC=TACHE
 HOR = [F:ABT]HOR
Endif
If HOR<>""
 Read [ABH]ABH0=HOR
 FERIE = 0
 If [F:ABH]CAL<>""
  Read [ABC]ABC0=[F:ABH]CAL
  If [F:ABC]NBRDAT>0
   For I=0 To [F:ABC]NBRDAT-1
    If DAT>=[F:ABC]STRDAT(I) & DAT<=[F:ABC]ENDDAT(I)
     FERIE = 1 : Break
    Endif
   Next I
  Endif
 Endif
 If FERIE | [F:ABH]DAYOPE(JOUR-1)=1
  OK = 0
  If [F:ABH]NBRCLO>0
   For I=0 To [F:ABH]NBRCLO-1
    If TIM>=[F:ABH]STRCLO(I) & TIM<=[F:ABH]ENDCLO(I)
     OK = 1 : Break
    Endif
   Next I
   If !OK
    For I=0 To [F:ABH]NBRCLO-1
     If I=0
      If TIM<=[F:ABH]STRCLO(0)
       TIM = [F:ABH]STRCLO(0) : OK = 1 : Break
      Endif
     Elsif TIM>=[F:ABH]STRCLO(I-1) & TIM<=[F:ABH]STRCLO(I)
      TIM = [F:ABH]STRCLO(I) : OK = 1 : Break
     Endif
    Next I
   Endif
  Endif
 Else : # Jour ouvré
  OK = 0
  If [F:ABH]NBROPE>0
   For I=0 To [F:ABH]NBROPE-1
    If TIM>=[F:ABH]STROPE(I) & TIM<=[F:ABH]ENDOPE(I)
     OK = 1 : Break
    Endif
   Next I
   If !OK
    For I=0 To [F:ABH]NBROPE-1
     If I=0
      If TIM<=[F:ABH]STROPE(0)
       TIM = [F:ABH]STROPE(0) : OK = 1 : Break
      Endif
     Elsif TIM>=[F:ABH]STROPE(I-1) & TIM<=[F:ABH]STROPE(I)
      TIM = [F:ABH]STROPE(I) : OK = 1 : Break
     Endif
    Next I
   Endif
  Endif
 Endif
Endif
End

#------------------------------------------------#
Subprog CTLHOR(HOR,GRP,TACHE,DAT,TIM,OK)
Value    Char    HOR
Value    Char    GRP
Value    Char    TACHE
Value    Date    DAT
Value    Char    TIM
Variable Integer OK
Local Integer I , JOUR , FERIE
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

JOUR = dayn(DAT)
OK = 1
If GRP<>""
 Read [ABG]ABG0=GRP
 HOR = [F:ABG]HOR
Elsif TACHE<>""
 Read [ABT]CODTAC=TACHE
 HOR = [F:ABT]HOR
Endif
If HOR<>""
 # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
 Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
 If DAT=[L]DD & TIM<[L]HH
  OK = 0 : GMESSAGE = mess(167,133,1) : # Impossible de programmer une tâche pour une période passée
  End
 Endif
 Read [ABH]ABH0=HOR
 FERIE = 0
 If [F:ABH]CAL<>""
  Read [ABC]ABC0=[F:ABH]CAL
  If [F:ABC]NBRDAT>0
   For I=0 To [F:ABC]NBRDAT-1
    If DAT>=[F:ABC]STRDAT(I) & DAT<=[F:ABC]ENDDAT(I)
     FERIE = 1 : Break
    Endif
   Next I
  Endif
 Endif
 If FERIE | [F:ABH]DAYOPE(JOUR-1)=1
  OK = 0
  If [F:ABH]NBRCLO>0
   For I=0 To [F:ABH]NBRCLO-1
    If TIM>=[F:ABH]STRCLO(I) & TIM<=[F:ABH]ENDCLO(I)
     OK = 1 : Break
    Endif
   Next I
  Endif
 Else
  OK = 0
  If [F:ABH]NBROPE>0
   For I=0 To [F:ABH]NBROPE-1
    If TIM>=[F:ABH]STROPE(I) & TIM<=[F:ABH]ENDOPE(I)
     OK = 1 : Break
    Endif
   Next I
  Endif
 Endif
Endif
If !OK
 GMESSAGE = mess(32,135,1)+"\"+HOR-[F:ABH]DES : # Heure interdite par la contrainte
Endif
End

#------------------------------------------------#
# Saisie des paramètres pour un groupe
#------------------------------------------------#

Subprog GROUPE

Local Integer I , J , K , OK , CHGUSR , OUVDIA , NOTAC
Local Integer REQUETE , TYPPRG , OKTRT, USR_BRK_FLG
Local Char    BPROG(GLONADC) , SPROG(GLONADC) , BCRIT(GLONFEN) , BOITE(GLONFEN)
Local Char    PARAM(250)(1..20) , VALEUR(10)
Local Char    ACTION(20)
Local Char    FICHIER(GDIMFIC)
Local Char    TRTCRIT(GLONADC) , TITCRIT(200) , MSKCRIT(GLONAMK)(0..15) , ABRECR(GLONABR)(0..15)
Local Char    TACHE(GLONABT) , DOSSIER(GLONADS) , USER(GLONAUS) , GROUPE(GLONABG)
Local Char    MESSA(250)

If [V]GPRODUIT=1
 Local Char BATFCY([V]GLONFCY), BATDEP([V]GLONDEP)
 [L]BATFCY=[V]GFCY
 [L]BATDEP=[V]GDEP
Endif

DOSSIER = [M:ABQ1]DOSSIER
USER    = [M:ABQ1]USER
Gosub SETUSR
GROUPE = [M:ABQ1]GRP
Gosub VERFGRP
Gosub RESTUSR
If GERR : End : Endif

GBATCH = 1
Read [ABG]ABG0 = [M:ABQ1]GRP
If fstat : End : Endif
# Issue X3-59123 - 2018-05-30 by CCC : Check that sequence number of tasks are all initialized
If [F:ABG]NBTAC>0 & find(0,[F:ABG]SEQ(0..[F:ABG]NBTAC-1))>0
    # If at least 1 task has 0 as sequence number => run the initialization function
    Call INISEQ([F:ABG]SEQ, [F:ABG]NBTAC) From SUBABG
    Rewrite [ABG]
    If fstat
        GOK=0
        GMESSAGE = func GLOCK.GET_FSTAT_MSG(fstat)-"ABATGRP"-[F:ABG]CODGRP
        End
    Endif
Endif

For NOTAC=1 To [F:ABG]NBTAC
 Raz BCRIT , BPROG , SPROG , CHGUSR
 Read [ABT]CODTAC = [F:ABG]CODTAC(NOTAC-1)
 If !fstat
  If [F:ABT]FONCTION<>"" : # Nouvelle mode
   DOSSIER = [M:ABQ1]DOSSIER
   USER    = [M:ABQ1]USER
   CHGUSR  = 1
   Gosub SETUSR
   TACHE = [F:ABG]CODTAC(NOTAC-1)
   Gosub VERFTAC
   If !GERR
    Read [AFC]CODINT = [F:ABT]FONCTION
    If !fstat
     For I=0 To [F:AFC]NBVAR-1
      If [F:AFC]VALEUR(I)<>"#"
       Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
      Endif
     Next I
     Raz PARAM
     For I=1 To dim([F:AFC]VALPAR)
      If [F:AFC]VALPAR(I-1)<>""
       PARAM(I) = num$(evalue([F:AFC]VALPAR(I-1)))
      Endif
     Next I
     If [F:AFC]ACTION<>""
      Read [ACT]ACTION = [F:AFC]ACTION
      BCRIT  = [F:ACT]PARAM4
      BPROG  = [F:ACT]CODTRT
      SPROG  = [F:ACT]SPETRT
      TYPPRG = [F:ACT]PARAM3
      BOITE  = [F:ACT]PARAM2
     Endif
    Endif
   Endif
  Endif
  If !GERR
   If BCRIT<>"" & (BPROG<>"" or SPROG<>"")
    ACTION = "OUVRE_BATCH" : Gosub ACTIONB
    GBOITE = BCRIT
    Call SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRECR,TITCRIT) From GTRAITE
    OUVDIA = 0
    For I=0 To dim(ABRECR)-1
     If ABRECR(I)<>"" & evalue("clalev([M:"+ABRECR(I)+"])")=0
      Local Mask =MSKCRIT(I)
      OUVDIA = 1
     Endif
    Next I
    If OUVDIA
     ACTION = "INIT_DIA" : Gosub ACTIONB
    Endif
    OK = 0
    While !OK
     Case TYPPRG
      When 3
       OK = 2 : Call DIALWIN(OK,TITCRIT,BCRIT) From GESECRAN
      When 4
       Call SAISIE_CHAR(VALEUR,PARAM,BCRIT,BPROG,SPROG) From GSAISIE
       If GSTATUT<>GSTAESC : GSTATUS = GSTAOK : OK = 2 : Else : OK = 1 : Endif
     Endcase
     If OK<>2
      # Do you want to interrupt the group entry?
      Call AVERTIR(mess(106,134,1),OK) From GESECRAN
      If OK=2 Then OK=1: USR_BRK_FLG=1: Else OK=0 : Endif
     Endif
    Wend
    ACTION = "CONT_BATCH" : Gosub ACTIONB
    If OK<>2
     For I=0 To dim(ABRECR)-1
      If ABRECR(I)<>"" & evalue("clalev([M:"+ABRECR(I)+"])")>0
       Gosub FERME_MASK From =TRTCRIT
       Break
      Endif
     Next I
    Endif
   Else
    OK = 2
    ACTION = "CONT_BATCH" : Gosub ACTIONB
   Endif
   GOK = 1
   If OK=2
    If [M:ABQ1]JOBMOD=2
     #109897
     Call SETJOB([F:ABT]CODTAC+"_"+num$(NOTAC),[M:ABQ1]DOSSIER,[M:ABQ1]USER,[M:ABQ1]GRP
&   ,[F:ABT]CODTAC,[M:ABQ1]DAT,[M:ABQ1]HEURE,ABRECR,FICHIER,[M:ABQ1]LAN) From SERVJOB
     If FICHIER=""
      Call ERREUR(mess(9,135,1)) From GESECRAN : # Paramètres incorrects
     Else
      Call MESSAGE(mess(12,125,1)-"|"+FICHIER) From GESECRAN : # Création du fichier
     Endif
    Else
     Call DEBTRANS From GLOCK
     Gosub TR1
     If GOK<1 : Break : Endif
    Endif
   Endif
   If BCRIT<>"" & (BPROG<>"" or SPROG<>"")
    For I=0 To dim(ABRECR)-1
     If ABRECR(I)<>"" & evalue("clalev([M:"+ABRECR(I)+"])")>0
      Gosub FERME_MASK From =TRTCRIT
     Endif
    Next I
   Endif
  Endif
  If CHGUSR
   Close Local File
   Gosub OUVRE_TABLE
   Read [ABG]ABG0 = [M:ABQ1]GRP
   Gosub RESTUSR
  Endif
 Endif
 If USR_BRK_FLG Then Break: Endif
Next NOTAC
If GOK=1 & REQUETE<>0 & [M:ABQ1]JOBMOD<>2
 OK = 0
 For [ABR] Where [F:ABR]NUMGRP=[L]REQUETE
  If [F:ABR]FLAG<>4 : # Il y en a au moins une qui n'est pas "bloquée"
   OK = 1 : Break
  Endif
 Next ABR
 If OK
  GERR = 2 : GMESSAGE = mess(29,134,1)+" ("+num$(REQUETE)+")" : # Requête transmise au serveur
 Else
  Call DEBTRANS From GLOCK
  Gosub TR2 : # Requêtes avortées
  If GOK=1
   GERR = 2 : GMESSAGE = mess(107,134,1)+" ("+num$(REQUETE)+")" : # Soumission du groupe de requêtes abandonnée
  Endif
 Endif
Endif
If [V]GPRODUIT=1
 [V]GFCY=[L]BATFCY
 [V]GDEP=[L]BATDEP
Endif
GBATCH = 0
End

$ACTIONB
GPE = 0
If dim(SPROG)>0 & SPROG<>""
 Call EXISTE_ADX("","",SPROG,OKTRT) From ORDSYS
 If OKTRT : Gosub ACTION From =SPROG : Endif
Endif
If !GPE & dim(BPROG)>0 & BPROG<>""
 Gosub ACTION From =BPROG
Endif
Return

$TR1
GOK = 1
Trbegin [ABP] , [ABR]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK=-1 : GLOCK="$ABATPAR" : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("ABP","") From GLOCK : Goto AB_TR1
 Endif
 Read [ABT]CODTAC = [F:ABG]CODTAC(NOTAC-1)
 If fstat
  GOK=0 : Call RSTA("ABT",TACHE) From GLOCK : Goto AB_TR1
 Endif
 Raz [F:ABR]
 [F:ABR] = [M:ABQ1]
 [F:ABR] = [F:ABT]
 [F:ABR]CNTERR = [F:ABG]CNTERR
 [F:ABR]TACHE  = [F:ABT]CODTAC
 [F:ABR]ETAT   = [F:ABT]TRAIT
 [F:ABR]NUMREQ = [F:ABP]NUMREQ
 [F:ABR]SEQGRP = [F:ABG]SEQ(NOTAC-1)           # Issue X3-59123 - 2018-05-29 by CCC : add sequence in group of tasks
 [F:ABR]FLAG = 4 : # Bloquée tant qu'on a pas saisi tous les paramètres de toutes les tâches bug 56378
 If NOTAC=1
  REQUETE = [F:ABR]NUMREQ
 Endif
 [F:ABR]NUMGRP = REQUETE : # [F:ABP]NUMREQ
 If [V]GPRODUIT=1
  #CHECK UNUSED_BEGIN
  [F:ABR]FCY=[V]GFCY
  [F:ABR]DEP=[V]GDEP
  #CHECK UNUSED_END
 Endif
 Gosub ECRIT_PARAM From REQUETES
 If GOK=0 : Goto AB_TR1 : Endif
 [F:ABP]NUMREQ += 1
 Rewrite [ABP]
 If fstat
  GOK=0 : Call FSTA("ABP") From GLOCK : Goto AB_TR1
 Endif
 If NOTAC=[F:ABG]NBTAC
# Issue X3-59123 - 2018-05-29 by CCC : add sequence in group of tasks => call function to run all tasks that must be unhold
#  Read [F:ABR]NUMREQ = REQUETE
#  If !fstat
#   [F:ABR]FLAG = 1 : # En cours
#  Endif
#  Rewrite [ABR]
#  If fstat
#   GOK=0
#   Call FSTA("ABR") From GLOCK : Goto AB_TR1
#  Endif
    If func REQUETES.RUN_NEXT_GRP_SEQ(REQUETE,MESSA)<>[V]CST_AOK
        GOK=0
        Call ERREUR(MESSA) From GESECRAN
        Goto AB_TR1
    Endif
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK = 1
Trbegin [ABR]
 For [ABR] Where [F:ABR]NUMGRP=[L]REQUETE
  [F:ABR]FLAG = 6 : # Avortée
  Rewrite [ABR]
  If fstat
   GOK=0 : Call FSTA("ABR") From GLOCK : Goto AB_TR2
  Endif
 Next ABR
Commit
Return

$AB_TR2
Rollback
Return

#------------------------------------------------#
# Ecran ABQ1
#------------------------------------------------#

Subprog AS_DOSSIER(VALEUR)
Variable Char     VALEUR
If !instr(1,GUSRAUZ(1),"U")
 VALEUR = nomap : mkstat = 2 : End
Elsif VALEUR= ""
 VALEUR = nomap
Endif
End

Subprog AS_USER(VALEUR)
Variable Char     VALEUR
If !instr(1,GUSRAUZ(1),"U")
 VALEUR = GUSER : mkstat = 2 : End
Elsif VALEUR=""
 VALEUR = GUSER
Endif
End

Subprog C_USER(VALEUR)
Variable Char VALEUR
Local File =[M]DOSSIER+".AUTILIS" [AUS]
Call CONTROLE("AUS","",VALEUR,"",mkstat) From CONTOBJ
End

Subprog AS_PASSE(VALEUR)
Variable Char    VALEUR()
If !instr(1,GUSRAUZ(1),"U") : mkstat = 1 : End : Endif
If [M]DOSSIER=nomap & [M]USER=GUSER : mkstat = 1 : End : Endif
End

Subprog C_PASSE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If [M]USER<>GUSER or [M]DOSSIER<>nomap
 Local File =[M]DOSSIER+".AUTILIS" [AUS]
 Local Char    MOTPASSE(30)
 Read [AUS]CODUSR = [M]USER
 MOTPASSE = VALEUR
 Call CTLPAS(MOTPASSE,OK) From GESUSER
 If !OK
  GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
  mkstat  = 2 : End
 Endif
Endif
End

Subprog C_GRP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [ABG]ABG0 = VALEUR
 Gosub SET_TABTEX
 Call TEXTE([F:ABG]DES,[M]ZGRP) From OBJDIV
 Raz [M]TACHE , ZTACHE
 Affzo TACHE, ZTACHE : Grizo TACHE
Else
 Raz [M]ZGRP
 Affzo ZGRP
 Actzo TACHE
Endif
End

$SET_TABTEX
Local Char DOSX3(GLONADS)
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
DOSX3 = [F:ADW]VALEUR
If DOSX3="" : DOSX3 = "X3" : Endif
Local File =DOSX3+".ATEXTE" [ATX]
Return

Subprog C_TACHE(VALEUR)
Variable Char    VALEUR()
Gosub SET_TABTEX
Call TEXTE([F:ABT]DES,[M]ZTACHE) From OBJDIV
End

Subprog AS_DAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
Local Char    HOR(GLONABH)
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

If VALEUR=[0/0/0]
 # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
 Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
 VALEUR = [L]DD
 Call CTLDAT(HOR,[M]GRP,[M]TACHE,VALEUR,OK)
 If !OK
  Call INIDAT(HOR,[M]GRP,[M]TACHE,VALEUR)
  [M]HEURE = "0000"
  Call INIHOR(HOR,[M]GRP,[M]TACHE,VALEUR,[M]HEURE,OK)
 Endif
Endif
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
Local Char    HOR(GLONABH)
Call CTLDAT(HOR,[M]GRP,[M]TACHE,VALEUR,OK)
If !OK : mkstat = 2 : Endif
End

Subprog AS_HEURE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char    HOR(GLONABH)
Local Char    HH(10), HS(10)
Local Integer SS
Local Date    DD

If VALEUR=""
 # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
 Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
 VALEUR = [L]HH
 Call CTLHOR(HOR,[M]GRP,[M]TACHE,[M]DAT,VALEUR,OK)
 If !OK
  Call INIHOR(HOR,[M]GRP,[M]TACHE,[M]DAT,VALEUR,OK)
 Endif
Endif
End

Subprog C_HEURE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char    HOR(GLONABH)
Call CTLHOR(HOR,[M]GRP,[M]TACHE,[M]DAT,VALEUR,OK)
If !OK : mkstat = 2 : Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran ABQ1) 16/11/2015 15:53:00 (VPO)
######################################################################################
Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
End :#113860 language not mandatory
If VALEUR=""
 Local File ADOSSIER [ADS]
 If func DOSSUB.FILL_ADS([M:ABQ1]DOSSIER)
  VALEUR=[F:ADS]LANDEF
 Endif
Endif
End

Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local File ADOSSIER [ADS]
If func DOSSUB.FILL_ADS([M:ABQ1]DOSSIER)
 If find(VALEUR,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))=0
   GMESSAGE=VALEUR-":"-mess(138,124,1)
   GERR=1
   mkstat=2
 Endif
Endif
End

Subprog S_LAN(VALEUR)
Variable Char    VALEUR()
Local Integer NBCHOI, CHOI,J
Local Char    TEX(GLONDES)(1..500,1..2) , TIT(GLONDES)(0..2)
Local File ADOSSIER [ADS]
If [M:ABQ1]DOSSIER=nomap
 Local File ATEXTRA [AXX]
Else
 Local File =DOSSIER+".ATEXTRA"   [AXX]
Endif
J=func DOSSUB.FILL_ADS([M:ABQ1]DOSSIER)
For J=0 To [F:ADS]NBRLAN-1
 If [F:ADS]LAN(J)<>""
  NBCHOI += 1
  TEX(NBCHOI,1) = [F:ADS]LAN(J)
  Call LECTEXTRA(TEX(NBCHOI,2),"TABLAN","INTDES",[F:ADS]LAN(J),"") From ATEXTRA
 Endif
Next
CHOI = 0
TIT(0) = mess(8,31,1) : #SÉLECTION
TIT(1) = mess(259,123,1) : #Langue
TIT(2) = mess(30,109,1) : #Intitulé
Call SAITEX_COL_MAX(NBCHOI,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
Endif
End


