#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
#  Traitement de gestion de la saisie du ciblage marketing             Module CRM           4 mars 2002  #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
#---------------------------------------------------#
# Description des paramètres
#   PARAM(1) = Code ciblage
#   PARAM(2) = Cible à obtenir
#   PARAM(3) = Support de présentation
#   PARAM(4) = Flag de duplication
#---------------------------------------------------#
Global Integer GIMGGSTEP
Global Integer GIMGGDIRTY
Global Integer GPREMGG1NOL
Global Integer GCRIDIRTY
Global Integer GPPLDIRTY
Global Integer GPRECRINOL 
Global Integer GIMGGDELALL
Global Char GSZPREGRU(110)

  GIMGGSTEP = 0
  GCRIDIRTY = 0
  GPPLDIRTY = 0
  GPRECRINOL = 0
  GSZPREGRU = ""
  GPREMGG1NOL = 0
  GIMGGDIRTY = 0
  GIMGGDELALL = 1
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
  If !clalev([F:SSC]) : Local File SELSSPCPN [SSC] : Endif
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:MQP]) : Local File MKGQURPPL [MQP] : Endif
  If !clalev([F:QCR]) : Local File QURCRI [QCR] : Endif
  If !clalev([F:QCV]) : Local File QURCRIVAL [QCV] : Endif
  If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:TGL]) : Local File TGRLIS [TGL] : Endif
  If !clalev([F:TGP]) : Local File TGRSSP [TGP] : Endif
  If !clalev([F:FID]) : Local File FIEDIC [FID] : Endif
  #Table complémentaire pour exécution dans l'assistant Marketing
  If type(GSZWIZMGG) > 0 Then
    If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
    If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
    If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
    If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
    If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
    If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
    If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
    If !clalev([F:MOG]) : Local File MKGOPG [MOG] : Endif
    If !clalev([F:MKL]) : Local File MKGLEVEL [MKL] : Endif
    If !clalev([F:SCLW]) : Local File SELCMGLIS [SCLW] : Endif
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If GIMGGDIRTY Then
    ETABOU(GVALI) = 1
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
  Else
    ETABOU(GVALI) = 0
    If [M:MGG0]TGPNUM = "" Then
      ETABOU(GSPE1) = 0
      ETABOU(GSPE2) = 0
    Else
      If [M:MGG1]NBPPL = 0 Then
        ETABOU(GSPE1) = 0
        ETABOU(GSPE2) = 0
      Else
        ETABOU(GSPE1) = 1
        If type(GSZWIZMGG) > 0 Then
          If GIMGGSTEP = 2 Then
            ETABOU(GSPE2) = 1
          Else
            ETABOU(GSPE2) = 0
          Endif
        Else
          ETABOU(GSPE2) = 1
        Endif
      Endif
    Endif
  Endif
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
      ETABOU(GVALI) = 0
      ETABOU(GSPE1) = 0
      ETABOU(GSPE2) = 0
    Elsif GNAVIG(GPILNAV-1) = "GESSET" Then
      ETABOU(GVALI) = 0
      ETABOU(GSPE1) = 0
      ETABOU(GSPE2) = 0
    Endif
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Char SZDVAPARAM
Local Char SZOLDQURNUM(GLONVCR)

  Raz [M:MGG0]
  Raz [M:MGG1]
  Raz [M:MGG2]
  SZDVAPARAM = ""
  SZOLDQURNUM = ""
  [M:MGG0]QURNUM = PARAM(1)
  [M:MGG0]TGR = PARAM(2)
  [M:MGG0]TGPNUM = PARAM(3)
  If [M:MGG0]QURNUM = "" Then
    Raz [M:MGG0]QURCAT
    Raz [M:MGG0]QURNAM
    Raz [M:MGG1]
    Raz [M:MGG1]NBPPL
    Raz [M:MGG1]NBSUM
    Raz [M:MGG2]
    Raz [M:MGG2]NBCRI
    Raz [M:MGG2]NBOCC
    #On créé un ciblage afin de disposer d'un référentiel fiable pour tous les enregistrements intermédiaires.
    Call CPTQURNUM([M:MGG0]QURNUM)
    If [M:MGG0]QURNUM = "" Then
      #Impossible de générer un identifiant pour le nouveau ciblage. Accès refusé.
      GMESSAGE = mess(584,196,1)
      GERR = 1
      FIN = 1
      Return
    Else
      Raz [F:MQR]
      Call DEBTRANS From GLOCK
      Trbegin [MQR]
      [F:MQR]QURNUM = [M:MGG0]QURNUM
      [F:MQR]TGR = [M:MGG0]TGR
      [F:MQR]TGPNUM = [M:MGG0]TGPNUM
      [F:MQR]PPLGRUDIO = ""
      [F:MQR]FGVCAH = 0
      [F:MQR]WIZCRE = 0
      [F:MQR]CREDAT = date$
      [F:MQR]CREUSR = GUSER
      Write [MQR]
      If fstat Then
        Rollback
        #Impossible de générer un identifiant pour le nouveau ciblage. Accès refusé.
        GMESSAGE = mess(584,196,1)
        GERR = 1
        Return
      Else
        Commit
      Endif
    Endif
  Else
    GIMGGDELALL = 0
    Call LOADMGG([M:MGG0]QURNUM)
  Endif
  If [M:MGG0]TGR = "" Then
    Raz [M:MGG0]TGPNUM
    Grizo [M:MGG0]TGPNUM
    Grizo [M:MGG1]
    Grizo [M:MGG2]
    Actzo [M:MGG0]TGR
  Else
    Actzo [M:MGG1]
    Actzo [M:MGG2]
    Grizo [M:MGG0]TGR
    If [M:MGG0]TGPNUM = "" Then
      #On recherche le support de présentation le plus adapté
      Actzo [M:MGG0]TGPNUM
      SZDVAPARAM = GUSER + [M:MGG0]TGR
      #D'abord un support pour l'utilisateur
      Read [DVA]DVA0="TGP";SZDVAPARAM
      If fstat Then
        #Sinon le support par défaut de la cible
        Read [TGL]TGL0=[M:MGG0]TGR
        If fstat Then
          [M:MGG0]TGPNUM = ""
        Else
          [M:MGG0]TGPNUM = [F:TGL]TGRSSPDEF
        Endif
      Else
        [M:MGG0]TGPNUM = [F:DVA]ALHX(0)
        If [M:MGG0]TGPNUM = "" Then
          #Sinon le support par défaut de la cible
          Read [TGL]TGL0=[M:MGG0]TGR
          If fstat Then
            [M:MGG0]TGPNUM = ""
          Else
            [M:MGG0]TGPNUM = [F:TGL]TGRSSPDEF
          Endif
        Else
          #Vérifie si le support de présentation existe
          Read [TGP]TGP0=[M:MGG0]TGPNUM
          If fstat Then
            #Il vaut mieux reprendre le support par défaut de la cible
            Read [TGL]TGL0=[M:MGG0]TGR
            If fstat Then
              [M:MGG0]TGPNUM = ""
            Else
              [M:MGG0]TGPNUM = [F:TGL]TGRSSPDEF
            Endif
            #Supprime le support personnel de l'utilisateur
            Call DEBTRANS From GLOCK
            Trbegin [DVA]
            Delete [DVA] Where [F:DVA]OBC = "TGP" and [F:DVA]PARAM = SZDVAPARAM
            If fstat Then
              Rollback
            Else
              Commit
            Endif                    
          Endif
        Endif
      Endif
    Else
      Grizo [M:MGG0]TGPNUM
    Endif
  Endif
  If [M:MGG0]TGR = "" Then
    Grizo [M:MGG0]QURCAT
    Grizo [M:MGG0]QURNAM
  Else
    If [M:MGG0]TGPNUM = "" Then
      Grizo [M:MGG0]QURCAT
      Grizo [M:MGG0]QURNAM
    Else
      Actzo [M:MGG0]QURCAT
      Actzo [M:MGG0]QURNAM
    Endif
  Endif
  #Gestion de la récupération de critères
  If type(GSZWIZMGG) > 0 Then
    If PARAM(4) <> "" Then
      #On créé un nouveau code de ciblage.
      SZOLDQURNUM = [M:MGG0]QURNUM
      Call CPTQURNUM([M:MGG0]QURNUM)
      If [M:MGG0]QURNUM = "" Then
        #Impossible de générer un identifiant pour le nouveau ciblage. Accès refusé.
        GMESSAGE = mess(584,196,1)
        GERR = 1
        FIN = 1
        Return
      Else
        Raz [F:MQR]
        Call DEBTRANS From GLOCK
        Trbegin [MQR]
        [F:MQR]QURNUM = [M:MGG0]QURNUM
        [F:MQR]TGR = [M:MGG0]TGR
        [F:MQR]QURCAT = [M:MGG0]QURCAT
        [F:MQR]QURNAM = [M:MGG0]QURNAM
        [F:MQR]TGPNUM = [M:MGG0]TGPNUM
        [F:MQR]PPLGRUDIO = [M:MGG1]PPLGRUDIO
        [F:MQR]FGVCAH = 0
        [F:MQR]WIZCRE = 2
        [F:MQR]CREDAT = date$
        [F:MQR]CREUSR = GUSER
        Write [MQR]
        If fstat Then
          Rollback
          #Impossible de générer un identifiant pour le nouveau ciblage. Accès refusé.
          GMESSAGE = mess(584,196,1)
          GERR = 1
          Return
        Else
          Commit
          #On complète l'enregistrement avec les critères et les valeurs de critères intermédiaires.
          Gosub ONSAVEMORE
          Call LOADMGG([M:MGG0]QURNUM)
        Endif
      Endif
    Endif
  Endif
  Affzo [M:MGG0]1-99
  Affzo [M:MGG1]1-99
  Affzo [M:MGG2]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
  Case BOUT
    When "B"
      GIMGGSTEP = 2
    When Default
  Endcase
Return

##########################################################################################################
$FINSAI
  If type(GSZWIZMGG) > 0 Then
    NBAFF = 1
  Endif
  If GIMGGDELALL Then
    Gosub DELALLMGG
  Endif
  Gosub KILLGLOB
  #Nettoie les écrans avant de partir.
  Raz [M:MGG0]
  Raz [M:MGG1]
  Raz [M:MGG1]NBPPL
  Raz [M:MGG1]NBSUM
  Raz [M:MGG2]
  Raz [M:MGG2]NBCRI
  Raz [M:MGG2]NBOCC
Return

##########################################################################################################
$KILLGLOB
  Kill GIMGGSTEP
  Kill GIMGGDIRTY
  Kill GPREMGG1NOL
  Kill GCRIDIRTY
  Kill GPPLDIRTY
  Kill GPRECRINOL 
  Kill GSZPREGRU
  Kill GIMGGDELALL
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  GIMGGDIRTY = 1
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "C"
      Gosub ONCONFCONS
    When Default
  Endcase
Return

##########################################################################################################
$ONOK
  Gosub ONSAVEMGG
  FIN = 0
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
#
#  ONCONFCONS   : Gestion du bouton "Conserver" ou "Confirmer".
#  ONSAVEMGG    : Gestion du bouton "Enregistrer".
#  DISPSUMUP    : Affiche le résumé du ciblage
#  CPTQURNUM    : Calcul une nouvelle clé pour le ciblage.
#  LOADMGG      : Charge un ciblage complet avec toutes ses informations
#  LOADPPL      : Charge le tableau des populations d'un ciblage
#  LOADCRI      : Charge le tableau des critères de ciblage d'une population
#  LOADCRIVAL   : Charge le tableau des valeurs d'un critère
#  REMOVECRLF   : Retire les retours chariots et line feed de la description de la population
#  RUNSELBPR    : Transfère le résultat de la sélection Tiers dans SELCMGLIS
#  RUNSELCCN    : Transfère le résultat de la sélection Interlocuteur dans SELCMGLIS
#  SETMKGOPGLNK : Associe un ciblage à une opération
#  ONSAVEMORE   : Complément d'enregistrement en cas de récupération de critère depuis l'assistant marketing.
#
##########################################################################################################

##########################################################################################################
#  Gestion du bouton "Enregistrer".
#########################################################
$ONCONFCONS
Local Integer IOUTREP
Local Integer ISEAHBDONE
Local Char SZMGG0QURNUM(GLONVCR)
Local Char SZMGG0TGR(GLONTGL)

  SZMGG0QURNUM = [M:MGG0]QURNUM
  SZMGG0TGR = [M:MGG0]TGR
  ISEAHBDONE = 0
  IOUTREP = 0
  #On enregistre le nombre d'enregistrements du ciblage 
  Call DEBTRANS From GLOCK
  Trbegin [MQR]
  Read [MQR]MQR0=[M:MGG0]QURNUM
  If !fstat Then
    [F:MQR]QURTOTREC = 0
    Filter [QTP] Where [F:QTP]QURNUM = [M:MGG0]QURNUM
    For [QTP]
      [F:MQR]QURTOTREC += 1
    Next
    Filter [QTP]
    Rewrite [MQR]
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Endif
  #Supprime le ciblage et tous les éléments associés si on n'est pas dans l'assistant
  If type(GSZWIZMGG) > 0 Then
    #Détermine si une recherche a été effectuée.
    Read [MQR]MQR0=[M:MGG0]QURNUM
    If fstat Then
      ISEAHBDONE = 0
    Else
      If [F:MQR]FINPPL > 0 Then
        Filter [QTP] Where [F:QTP]QURNUM = [F:MQR]QURNUM and [F:QTP]PPLORD = [F:MQR]FINPPL
        For [QTP]
          ISEAHBDONE += 1
          Break
        Next
        Filter [QTP]
      Else
        ISEAHBDONE = 0
      Endif
    Endif
    If ISEAHBDONE Then
      If GICSTEP = GISTEPBPR Then
        Gosub RUNSELBPR
        Gosub SETMKGOPGLNK
        Gosub REFRESH From TRTMGD1
        GISTECPL(GICSTEP - 1) = 1
      Endif
      GIMGGDELALL = 0
      FIN = 1
    Else
      #Aucune recherche d'échantillon n'a été effectuée. Confirmez-vous l'abandon du ciblage ?
      IOUTREP = 0
      Call OUINON(mess(787,196,1), IOUTREP) From GESECRAN
      If IOUTREP = 2 Then
        GIMGGDELALL = 1
        FIN = 1
      Endif
    Endif
  Else
    GIMGGDELALL = 0
    FIN = 1
  Endif
Return

##########################################################################################################
#  Gestion du bouton "Enregistrer".
#########################################################
$ONSAVEMGG
Local Integer ICANSAVE
Local Char SZMGG0QURNUM(GLONVCR)
Local Char SZMGG0TGR(GLONTGL)

  SZMGG0QURNUM = [M:MGG0]QURNUM
  SZMGG0TGR = [M:MGG0]TGR
  ICANSAVE = 1
  #Contrôle du champ Regroupement des populations
  Call CTLPPLGRU([M:MGG1]NBPPL, "PPL", [M:MGG1]PPLGRUDIO, ICANSAVE) From SUBMGGB
  If !ICANSAVE Then
    GMESSAGE = GMESSAGE - '->' - mess(575,196,1)
    Return
  Endif
  #Contrôle du champ Regroupement des critères
  Call CTLPPLGRU([M:MGG2]NBCRI, "CRI", [M:MGG2]CRIGRUDIO, ICANSAVE) From SUBMGGB
  If ICANSAVE Then
    [M:MGG1]CRIGRUDIOX(GPREMGG1NOL) = [M:MGG2]CRIGRUDIO
  Else
    GMESSAGE = GMESSAGE - '->' - mess(576,196,1)
    Return
  Endif
  #Contrôle si un support de présentation est précisé
  If [M:MGG0]TGPNUM = "" Then
    #Un support de présentation doit être précisé.
    GMESSAGE = mess(766,196,1)
    GERR = 1
    Return
  Endif
  #On peut enregistrer
  Call DEBTRANS From GLOCK
  Trbegin [MQR]
  Read [MQR]MQR0=[M:MGG0]QURNUM
  If fstat Then
    Rollback
    #Erreur lors de l'enregistrement du ciblage marketing.
    GMESSAGE = mess(580,196,1)
    GERR = 1
    Return
  Else
    [F:MQR]QURNUM = [M:MGG0]QURNUM
    [F:MQR]TGR = [M:MGG0]TGR
    [F:MQR]QURCAT = [M:MGG0]QURCAT
    [F:MQR]QURNAM = [M:MGG0]QURNAM
    [F:MQR]QURTOTREC = 0
    [F:MQR]TGPNUM = [M:MGG0]TGPNUM
    [F:MQR]PPLGRUDIO = [M:MGG1]PPLGRUDIO
    [F:MQR]FGVCAH = 0
    If type(GSZWIZMGG) > 0 Then
      [F:MQR]WIZCRE = 2
    Else
      [F:MQR]WIZCRE = 0
    Endif
    [F:MQR]CREDAT = date$
    [F:MQR]CREUSR = GUSER
    Rewrite [MQR]
    If fstat Then
      Rollback
      #Erreur lors de l'enregistrement du ciblage marketing.
      GMESSAGE = mess(580,196,1)
      GERR = 1
      Return
    Else
      Commit
    Endif
    #On enregistre une relation Ciblage / Opération dans MKGOPG
    If type(GSZWIZMGG) > 0 Then
      Gosub SETMKGOPGLNK
    Endif
  Endif
  Call SAVEPPL([M:MGG0]QURNUM)
  #Contrôle de la présence de condition Compris entre avec une seule valeur de critère
  Call CTLCND10([M:MGG0]QURNUM, ICANSAVE) From SUBMGGB
  If !ICANSAVE Then
    #Certains critères avec une condition de type "Compris entre" comportent un nombre de valeurs incorrect.
    GMESSAGE = mess(758,196,1)
    GERR = 1
    Return
  Endif
  #Crée la tâche batch si elle n'existe pas.
  Call CREABTMGG From TRTMGC1
  #Affiche le résumé du ciblage
  Gosub DISPSUMUP
  #
  GIMGGDIRTY = 0
  GIMGGSTEP = 1
  Affzo [M:MGG1]1-99
Return

##########################################################################################################
#Affiche le résumé du ciblage
####################################################################
$DISPSUMUP
Local Integer ISUMUPITER
Local Integer INBSUM
Local Char SZOPER
Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)
Local Char SZTEXTE(GLONDCO)

  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  INBSUM = 0
  SZOPER = ""
  For ISUMUPITER = 0 To [M:MGG1]NBPPL-1
    If [M:MGG1]PPLSELSPT(ISUMUPITER) = "" Then
      Break
    Endif
    If [M:MGG1]PPLOPD(ISUMUPITER) > 1 Then
      SZOPER = mess([M:MGG1]PPLOPD(ISUMUPITER),2959,1)
      If [M:MGG1]PPLDES(ISUMUPITER) = "" Then
        Read [SSP]SSP0=[M:MGG1]PPLSELSPT(ISUMUPITER)
        If fstat Then
          [M:MGG1]PPLSUM(ISUMUPITER) = SZOPER
        Else
          Call LECTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
          [M:MGG1]PPLSUM(ISUMUPITER) = SZOPER - SZTEXTE
        Endif
      Else
        [M:MGG1]PPLSUM(ISUMUPITER) = SZOPER - left$([M:MGG1]PPLDES(ISUMUPITER), 108 - len(SZOPER))
      Endif
    Else
      If [M:MGG1]PPLDES(ISUMUPITER) = "" Then
        Read [SSP]SSP0=[M:MGG1]PPLSELSPT(ISUMUPITER)
        If fstat Then
          [M:MGG1]PPLSUM(ISUMUPITER) = ""
        Else
          Call LECTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
          [M:MGG1]PPLSUM(ISUMUPITER) = SZTEXTE
        Endif
      Else
        [M:MGG1]PPLSUM(ISUMUPITER) = left$([M:MGG1]PPLDES(ISUMUPITER), 110)
      Endif
    Endif
    #On enlève les retours chariots et les line feed de la ligne
    While instr(1, [M:MGG1]PPLSUM(ISUMUPITER), chr$(10))
      ISTR = instr(1, [M:MGG1]PPLSUM(ISUMUPITER), chr$(10))
      SZ1 = left$([M:MGG1]PPLSUM(ISUMUPITER), ISTR - len(chr$(10)))
      SZ2 = right$([M:MGG1]PPLSUM(ISUMUPITER), ISTR + 1)
      SZ3 = SZ1 + SZ2
      [M:MGG1]PPLSUM(ISUMUPITER) = SZ3
      ILOOPSECURE += 1
      If ILOOPSECURE > 10000 Then
        Break
      Endif
    Wend
    ISTR = 0
    SZ1 = ""
    SZ2 = ""
    SZ3 = ""
    While instr(1, [M:MGG1]PPLSUM(ISUMUPITER), chr$(13))
      ISTR = instr(1, [M:MGG1]PPLSUM(ISUMUPITER), chr$(13))
      SZ1 = left$([M:MGG1]PPLSUM(ISUMUPITER), ISTR - len(chr$(13)))
      SZ2 = right$([M:MGG1]PPLSUM(ISUMUPITER), ISTR + 1)
      SZ3 = SZ1 - SZ2
      [M:MGG1]PPLSUM(ISUMUPITER) = SZ3
      ILOOPSECURE += 1
      If ILOOPSECURE > 20000 Then
        Break
      Endif
    Wend
    INBSUM += 1
  Next
  [M:MGG1]NBSUM = INBSUM
Return

##########################################################################################################
# Calcul une nouvelle clé pour le ciblage.
#########################################################
Subprog CPTQURNUM(SZQURNUM)
Variable Char SZQURNUM

Local Integer IQURKEY

  IQURKEY = nbrecord([F:MQR]) + 1
  While 1
    Read [F:MQR]MQR0=num$(IQURKEY)
    If fstat Then
      Break
    Endif
    IQURKEY += 1
  Wend
  SZQURNUM = num$(IQURKEY)
End

##########################################################################################################
#  Charge un ciblage complet avec toutes ses informations
#############################################################################
Subprog LOADMGG(SZQURNUM)
Value Char SZQURNUM

  If SZQURNUM = "" Then
    Raz [M:MGG1]
    Raz [M:MGG2]
    End
  Endif
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Erreur lors du chargement du ciblage marketing.
    GMESSAGE = mess(579,196,1)
    GERR = 1
    End
  Else
    [M:MGG0]TGR = [F:MQR]TGR
    [M:MGG0]QURCAT = [F:MQR]QURCAT
    [M:MGG0]QURNAM = [F:MQR]QURNAM
    [M:MGG0]TGPNUM = [F:MQR]TGPNUM
    [M:MGG1]PPLGRUDIO = [F:MQR]PPLGRUDIO
    Call LOADPPL(SZQURNUM)
  Endif
  #Affiche le résumé du ciblage
  Gosub DISPSUMUP
  Affzo [M:MGG0]1-99
  Affzo [M:MGG1]15
  Affzo [M:MGG1]20
End

##########################################################################################################
#  Charge le tableau des populations d'un ciblage
#############################################################################
Subprog LOADPPL(SZQURNUM)
Value Char SZQURNUM

Local Integer INBPPL
Local Char SZTEXTE(GLONDCO)

  INBPPL = 0
  Raz [M:MGG1]NBPPL
  Raz [M:MGG1]NBPPLSEL
  Raz [M:MGG1]PPLOPD
  Raz [M:MGG1]PPLSELSPT
  Raz [M:MGG1]PPLDES
  Raz [M:MGG1]PPLORD
  Raz [M:MGG1]CRIGRUDIOX
  Raz [M:MGG1]PPLDESX
  Filter [MQP] Where [F:MQP]QURNUM = SZQURNUM
  For [MQP] MQP1
    If INBPPL >= dim([M:MGG1]PPLOPD) Then
      Break
    Endif
    [M:MGG1]PPLOPD(INBPPL) = [F:MQP]PPLOPD
    [M:MGG1]PPLSELSPT(INBPPL) = [F:MQP]PPLSELSPT
    [M:MGG1]PPLDES(INBPPL) = [F:MQP]PPLDES
    [M:MGG1]PPLORD(INBPPL) = [F:MQP]PPLORD
    [M:MGG1]CRIGRUDIOX(INBPPL) = [F:MQP]CRIGRUDIO
    If INBPPL = 0 Then
      [M:MGG1]NBPPLSEL(INBPPL) = "->"
      [M:MGG1]PPLDESX = [M:MGG1]PPLDES(INBPPL)
      If [M:MGG1]PPLSELSPT(INBPPL) = "" Then
        [M:MGG2]CURSPT = ""
      Else
        Read [SSP]SSP0=[M:MGG1]PPLSELSPT(INBPPL)
        If fstat Then
          [M:MGG2]CURSPT = ""
        Else
          [M:MGG2]CURSPT = [F:SSP]SPTNUM
        Endif
      Endif
      [M:MGG2]CRIGRUDIO = [F:MQP]CRIGRUDIO
      [M:MGG2]PPLORDX = [F:MQP]PPLORD
      Call LOADCRI(SZQURNUM, [F:MQP]PPLORD)
    Else
      [M:MGG1]NBPPLSEL(INBPPL) = ""
    Endif
    INBPPL += 1
  Next
  Filter [MQP]
  [M:MGG1]NBPPL = INBPPL
  Affzo [M:MGG1]5
  Affzo [M:MGG1]10
  Affzo [M:MGG1]20
  Affzo [M:MGG2]5
  Affzo [M:MGG2]20
End

##########################################################################################################
#  Charge le tableau des critères de ciblage d'une population
#############################################################################
Subprog LOADCRI(SZQURNUM, IPPLORD)
Value Char SZQURNUM
Value Integer IPPLORD

Local Integer INBCRI
Local Integer IFIETYP

  IFIETYP = 0
  INBCRI = 0
  Raz [M:MGG2]NBCRI
  Raz [M:MGG2]NBCRISEL
  Raz [M:MGG2]CRIOPD
  Raz [M:MGG2]CRITAB
  Raz [M:MGG2]CRIFIE
  Raz [M:MGG2]CRICND
  Raz [M:MGG2]CRINUM
  Raz [M:MGG2]CRIFIETYP
  Raz [M:MGG2]NBOCC
  Raz [M:MGG2]CRIVAL
  Raz [M:MGG2]CRIVALNUM
  Raz [M:MGG2]CRIVALDAT
  Filter [QCR] Where [F:QCR]QURNUM = SZQURNUM and [F:QCR]PPLORD = IPPLORD
  For [QCR] QCR1
    If INBCRI >= dim([M:MGG2]CRIOPD) Then
      Break
    Endif
    [M:MGG2]CRIOPD(INBCRI) = [F:QCR]CRIOPD
    [M:MGG2]CRITAB(INBCRI) = [F:QCR]CRITAB
    [M:MGG2]CRIFIE(INBCRI) = [F:QCR]CRIFIE
    [M:MGG2]CRICND(INBCRI) = [F:QCR]CRICND
    [M:MGG2]CRINUM(INBCRI) = [F:QCR]CRINUM
    #Obtient le type d'un champ
    Local File =[M:MGG2]CRITAB(INBCRI) [TYPX]
    IFIETYP = evalue("Type([F:TYPX]" + [M:MGG2]CRIFIE(INBCRI) + ")")
    Close Local File [TYPX]
    #On calcul un type pour le champs indiqué
    If IFIETYP < 0 Then
      [M:MGG2]CRIFIETYP(INBCRI) = ""
    Elsif IFIETYP = 1 or IFIETYP = 2 Then
      [M:MGG2]CRIFIETYP(INBCRI) = "N"
    Elsif IFIETYP = 3 Then
      [M:MGG2]CRIFIETYP(INBCRI) = "D"
    Elsif IFIETYP >= 4 and IFIETYP <= 9 Then
      [M:MGG2]CRIFIETYP(INBCRI) = "N"
    Elsif IFIETYP >= 10 Then
      [M:MGG2]CRIFIETYP(INBCRI) = "A"
    Endif
    If INBCRI = 0 Then
      [M:MGG2]NBCRISEL(INBCRI) = "->"
      Call LOADCRIVAL(SZQURNUM, IPPLORD, [F:QCR]CRINUM)
    Else
      [M:MGG2]NBCRISEL(INBCRI) = ""
    Endif
    INBCRI += 1
  Next
  Filter [QCR]
  [M:MGG2]NBCRI = INBCRI
  Affzo [M:MGG2]10
End

##########################################################################################################
#  Charge le tableau des valeurs d'un critère
#############################################################################
Subprog LOADCRIVAL(SZQURNUM, IPPLORD, ICRINUM)
Value Char SZQURNUM
Value Integer IPPLORD
Value Integer ICRINUM

Local Integer INBOCC

  INBOCC = 0
  Raz [M:MGG2]NBOCC
  Raz [M:MGG2]CRIVAL
  Raz [M:MGG2]CRIVALNUM
  Raz [M:MGG2]CRIVALDAT
  Filter [QCV] Where [F:QCV]QURNUM = SZQURNUM and [F:QCV]PPLORD = IPPLORD and [F:QCV]CRINUM = ICRINUM
  For [QCV] QCV1
    If INBOCC >= dim([M:MGG2]CRIVAL) Then
      Break
    Endif
    [M:MGG2]CRIVAL(INBOCC) = [F:QCV]CRIVAL
    [M:MGG2]CRIVALNUM(INBOCC) = [F:QCV]CRIVALNUM
    [M:MGG2]CRIVALDAT(INBOCC) = [F:QCV]CRIVALDAT
    INBOCC += 1
  Next
  Filter [QCV]
  [M:MGG2]NBOCC = INBOCC
  Affzo [M:MGG2]15
End

##########################################################################################################
#  Enregistre le tableau des valeurs d'un critère
#############################################################################
Subprog SAVECRIVAL(SZQURNUM, IPPLORD, ICRINUM)
Value Char SZQURNUM
Value Integer IPPLORD
Value Integer ICRINUM

Local Integer ZU
Local Integer IPBL

  IPBL = 0
  #Supprime l'ancienne grille de valeurs
  Call DEBTRANS From GLOCK
  Trbegin [QCV]
  Delete [QCV] Where [F:QCV]QURNUM = SZQURNUM and [F:QCV]PPLORD = IPPLORD and [F:QCV]CRINUM = ICRINUM
  If fstat Then
    IPBL = 1
  Endif
  If IPBL Then
    Rollback
    End
  Else
    Commit
  Endif
  #Affecte un numéro à chaque ligne du tableau
  For ZU = 0 To [M:MGG2]NBOCC-1
    [M:MGG2]CRIVALNUM(ZU) = ZU + 1
  Next
  #Enregistre la nouvelle grille de valeurs
  Call DEBTRANS From GLOCK
  Trbegin [QCV]
  For ZU = 0 To [M:MGG2]NBOCC-1
    If [M:MGG2]CRIVAL(ZU) <> "" Then
      [F:QCV]QURNUM = SZQURNUM
      [F:QCV]PPLORD = IPPLORD
      [F:QCV]CRINUM = ICRINUM
      [F:QCV]CRIVALNUM = [M:MGG2]CRIVALNUM(ZU)
      [F:QCV]CRIVAL = [M:MGG2]CRIVAL(ZU)
      [F:QCV]CRIVALDAT = [M:MGG2]CRIVALDAT(ZU)
      [F:QCV]FGVCAH = 0
      Write [QCV]
      If fstat Then
        IPBL = 1
        Break
      Endif
    Endif
  Next
  If IPBL Then
    #Erreur lors de l'enregistrement du ciblage marketing.
    GMESSAGE = mess(580,196,1) - '(' + mess(583,196,1) + ')'
    GERR = 1
    Rollback
  Else
    Commit
  Endif
  GCRIDIRTY = 0
End

##########################################################################################################
#  Enregistre le tableau des critères
#############################################################################
Subprog SAVECRI(SZQURNUM, IPPLORD)
Value Char SZQURNUM
Value Integer IPPLORD

Local Integer ZU
Local Integer IPBL

  IPBL = 0
  #Supprime l'ancienne grille de critères
  Call DEBTRANS From GLOCK
  Trbegin [QCR]
  Delete [QCR] Where [F:QCR]QURNUM = SZQURNUM and [F:QCR]PPLORD = IPPLORD
  If fstat Then
    IPBL = 1
  Endif
  If IPBL Then
    Rollback
    End
  Else
    Commit
  Endif
  #Enregistre la nouvelle grille des critères
  Call DEBTRANS From GLOCK
  Trbegin [QCR]
  For ZU = 0 To [M:MGG2]NBCRI-1
    If [M:MGG2]CRITAB(ZU) <> "" Then
      [F:QCR]QURNUM = SZQURNUM
      [F:QCR]PPLORD = IPPLORD
      [F:QCR]CRINUM = [M:MGG2]CRINUM(ZU)
      [F:QCR]CRIOPD = [M:MGG2]CRIOPD(ZU)
      [F:QCR]CRITAB = [M:MGG2]CRITAB(ZU)
      [F:QCR]CRIFIE = [M:MGG2]CRIFIE(ZU)
      [F:QCR]CRICND = [M:MGG2]CRICND(ZU)
      [F:QCR]FGVCAH = 0
      Write [QCR]
      If fstat Then
        IPBL = 1
        Break
      Endif
    Endif
  Next
  If IPBL Then
    #Erreur lors de l'enregistrement du ciblage marketing.
    GMESSAGE = mess(580,196,1) - '(' + mess(582,196,1) + ')'
    GERR = 1
    Rollback
  Else
    Commit
  Endif
  #Enregistrement des valeurs de critères
  If !IPBL Then
    If GCRIDIRTY Then
      Call SAVECRIVAL(SZQURNUM, IPPLORD, [M:MGG2]CRINUM(GPRECRINOL))
      GCRIDIRTY = 0
    Endif
  Endif
  GPPLDIRTY = 0
End

##########################################################################################################
#  Enregistre le tableau des populations
#############################################################################
Subprog SAVEPPL(SZQURNUM)
Value Char SZQURNUM

Local Integer ZU
Local Integer IPBL
Local Char SZBUFPPL(250)

  IPBL = 0
  SZBUFPPL = ""
  #Supprime l'ancienne grille de populations
  Call DEBTRANS From GLOCK
  Trbegin [MQP]
  Delete [MQP] Where [F:MQP]QURNUM = SZQURNUM
  If fstat Then
    IPBL = 1
  Endif
  If IPBL Then
    Rollback
    End
  Else
    Commit
  Endif
  #Enregistre la nouvelle grille des populations
  Call DEBTRANS From GLOCK
  Trbegin [MQP]
  For ZU = 0 To [M:MGG1]NBPPL-1
    If [M:MGG1]PPLSELSPT(ZU) <> "" Then
      [F:MQP]QURNUM = SZQURNUM
      [F:MQP]PPLORD = [M:MGG1]PPLORD(ZU)
      [F:MQP]PPLOPD = [M:MGG1]PPLOPD(ZU)
      [F:MQP]PPLSELSPT = [M:MGG1]PPLSELSPT(ZU)
      [F:MQP]PPLDES = [M:MGG1]PPLDES(ZU)
      SZBUFPPL = [M:MGG1]PPLDES(ZU)
      Call REMOVECRLF(SZBUFPPL)
      [F:MQP]PPLDESCRLF = SZBUFPPL
      [F:MQP]CRIGRUDIO = [M:MGG1]CRIGRUDIOX(ZU)
      [F:MQP]FGVCAH = 0
      Write [MQP]
      If fstat Then
        IPBL = 1
        Break
      Endif
    Endif
  Next
  If IPBL Then
    #Erreur lors de l'enregistrement du ciblage marketing.
    GMESSAGE = mess(580,196,1) - '(' + mess(581,196,1) + ')'
    GERR = 1
    Rollback
  Else
    Commit
  Endif
  #Enregistrement des valeurs de critères
  If !IPBL Then
    If GPPLDIRTY Then
      Call SAVECRI(SZQURNUM, [M:MGG1]PPLORD(GPREMGG1NOL))
      GPPLDIRTY = 0
    Endif
  Endif
  GPPLDIRTY = 0
End

##########################################################################################################
# Supprime le ciblage et tous les éléments associés
#############################################################################
$DELALLMGG
  If [M:MGG0]QURNUM = "" Then
    Return
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [MQR], [MQP], [QCR], [QCV], [QTP]
  Delete [MQR] Where [F:MQR]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Delete [MQP] Where [F:MQP]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Delete [QCR] Where [F:QCR]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Delete [QCV] Where [F:QCV]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Delete [QTP] Where [F:QTP]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Rollback
    Return
  Endif
  Commit
Return

##########################################################################################################
# Retire les retours chariots et line feed de la description de la population
######################################################################################
Subprog REMOVECRLF(SZPPLDES)
Variable Char SZPPLDES

Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)

  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  #On enlève les retours chariots et les line feed de la ligne
  While instr(1, SZPPLDES, chr$(10))
    ISTR = instr(1, SZPPLDES, chr$(10))
    SZ1 = left$(SZPPLDES, ISTR - len(chr$(10)))
    SZ2 = right$(SZPPLDES, ISTR + 1)
    SZ3 = SZ1 + SZ2
    SZPPLDES = SZ3
    ILOOPSECURE += 1
    If ILOOPSECURE > 10000 Then
      Break
    Endif
  Wend
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  While instr(1, SZPPLDES, chr$(13))
    ISTR = instr(1, SZPPLDES, chr$(13))
    SZ1 = left$(SZPPLDES, ISTR - len(chr$(13)))
    SZ2 = right$(SZPPLDES, ISTR + 1)
    SZ3 = SZ1 + ' ' + SZ2
    SZPPLDES = SZ3
    ILOOPSECURE += 1
    If ILOOPSECURE > 20000 Then
      Break
    Endif
  Wend
End

##########################################################################################################
# Transfère le résultat de la sélection Tiers dans SELCMGLIS
#############################################################
$RUNSELBPR
Local Integer IPERF
Local Integer IPBL
Local Integer INTR
Local Integer ICLSNUM
Local Char SZOPGTYP (GLONAOB)
Local Integer INBRECSEL
Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  SZOPGTYP = ""
  INBRECSEL = 0
  IPERF = 0
  IPBL = 0
  INTR = 0
  ICLSNUM = 0
  Call TEMPON(mess(785,196,1)) From GESECRAN   #Génération de l'échantillon.
  Case GSZWIZCOD
    When "MAILING"
      SZOPGTYP = "OMM"
    When "PHONING"
      SZOPGTYP = "OMP"
    When Default
  Endcase
  Call DEBTRANS From GLOCK
  Trbegin [SCL]
  Delete [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN"
  If fstat Then
    Rollback
  Else
    Commit
  Endif
  Read [MQR]MQR0=SZMGG0QURNUM
  If fstat Then
    Call TEMPOFF From GESECRAN
    GMESSAGE = mess(786,196,1) #Impossible de générer l'échantillon souhaité. Génération abandonnée.
    GERR = 1
    Return
  Endif
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [QTP] Where [F:QTP]QURNUM = [F:MQR]QURNUM and [F:QTP]PPLORD = [F:MQR]FINPPL and [F:QTP]KEYTGR > SZLOOPCLE
    For [QTP]QTP1
      SZLOOPCLE = [F:QTP]KEYTGR
      If IPERF = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SCL]
        INTR = 1
      Endif
      [F:SCL]OPGNUM = GSZOPGNUM
      [F:SCL]RECTYP = "BPR"
      [F:SCL]RECNUM = [F:QTP]KEYTGR
      [F:SCL]CLSNUM = ICLSNUM
      ICLSNUM += 1
      Write [SCL]
      If fstat Then
        IPBL = 1
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Rollback
        INTR = 0
        Break
      Else
        If IPERF >= 500 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      INBRECSEL += 1
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
    Filter [QTP]
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  #On enregistre la sélection
  Call DEBTRANS From GLOCK
  Trbegin [SEC]
  Readlock [SEC]SEC0=GSZOPGNUM;"BPR"
  If fstat Then
    #Il faut créer une nouvelle sélection
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP 
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = "BPR"
    [F:SEC]SELCRI = ""
    [F:SEC]SELREC = INBRECSEL
    Write [SEC]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Unlock [SEC]
      Rollback
      Call TEMPOFF From GESECRAN
      Return
    Else
      Commit
      Unlock [SEC]
    Endif
  Else
    # Il s'agit d'une modification
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP 
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = "BPR"
    [F:SEC]SELCRI = ""
    [F:SEC]SELREC = INBRECSEL
    Rewrite [SEC]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [SEC]
      Rollback
      Call TEMPOFF From GESECRAN
      Return
    Else
      Commit
      Unlock [SEC]
    Endif
  Endif
  Call TEMPOFF From GESECRAN
Return

##########################################################################################################
#Creé ou modifie le selection marketing
#Transfère le résultat de la sélection Interlocuteur dans SELCMGLIS
#############################################################
$RUNSELCCN
  Gosub VARCCNSEL
  Gosub RUNCCNSEL
Return

##########################################################################################################
$VARCCNSEL
Local Char SZOPGTYP (GLONAOB)
Local Integer INBRECSEL
Local Integer INOTHING
Local Integer IPERF
Local Integer IPBL
Local Integer INTR
Local Integer ICLSNUM
Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  IPBL = 0
  INTR = 0
  SZOPGTYP = ""
  INBRECSEL = 0
  INOTHING = 0
  ICLSNUM = 0
  Case GSZWIZCOD
    When "MAILING"
      SZOPGTYP = "OMM"
    When "PHONING"
      SZOPGTYP = "OMP"
    When Default
  Endcase
Return

##########################################################################################################
$CRECCNSEL
  #On enregistre la sélection
  Call DEBTRANS From GLOCK
  Trbegin [SEC]
  Readlock [SEC]SEC0=GSZOPGNUM;"CCN"
  If fstat Then
    #Il faut créer une nouvelle sélection
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP 
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = "CCN"
    [F:SEC]SELCRI = ""
    [F:SEC]SELREC = INBRECSEL
    [F:SEC]DEFADD = [M:MAI3]DEFADD
    [F:SEC]HIEBPR = [M:MAI3]HIEBPR
    If INOTHING Then
      [F:SEC]CNTTTR = [M:MAI3]CNTTTR
    Else
      [F:SEC]CNTTTR = ""
    Endif
    Write [SEC]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Unlock [SEC]
      Rollback
      Return
    Else
      Commit
      Unlock [SEC]
    Endif
  Else
    # Il s'agit d'une modification
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP 
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = "CCN"
    [F:SEC]SELCRI = ""
    [F:SEC]SELREC = INBRECSEL
    [F:SEC]DEFADD = [M:MAI3]DEFADD
    [F:SEC]HIEBPR = [M:MAI3]HIEBPR
    If INOTHING Then
      [F:SEC]CNTTTR = [M:MAI3]CNTTTR
    Else
      [F:SEC]CNTTTR = ""
    Endif
    Rewrite [SEC]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [SEC]
      Rollback 
      Return
    Else
      Commit
      Unlock [SEC]
    Endif
  Endif
Return

##########################################################################################################
#On enregistre la sélection (Création ou modification)
#On cree les enregistrements dans SELCMGLIS
######################################################################
$RUNCCNSEL
Local Integer ICIBLAGE
Local Integer IGESLEVEL
Local Integer ICURLEVEL
Local Integer INBCOL
Local Integer IBPASOK
Local Integer IBPASOK
Local Char    SZCURBPA(GLONBPN)

  ICIBLAGE = 0
  IGESLEVEL = 0
  ICURLEVEL = 0
  INBCOL = 0
  IBPASOK = 0
  SZCURBPA =""
  If [MAI3]NBMQR > 0 Then
    ICIBLAGE = 0
    INBCOL = 0
    #Il faut créer une nouvelle population de ciblage
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
    [F:DVA]OBC = "MKL"
    [F:DVA]PARAM = GSZOPGNUM
    While ICIBLAGE < [MAI3]NBMQR
      If [M:MAI3]QURNUM (ICIBLAGE ) <> "" Then
        [F:DVA]ALHX(INBCOL) = [M:MAI3]QURNUM (ICIBLAGE)
        INBCOL += 1
      Endif
      ICIBLAGE += 1
    Wend
    If INBCOL > 0 Then
      Write [DVA]
      If fstat Then
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Rollback 
        Return
      Else
        Commit
      Endif
    Else
      Rollback 
    Endif
  Endif
  #On traite la sélection
  Call DEBTRANS From GLOCK
  Trbegin [SEC]
  Readlock [SEC]SEC0=GSZOPGNUM;"CCN"
  If fstat Then
    #Il faut créer une nouvelle sélection
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP 
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = "CCN"
    [F:SEC]SELCRI = ""
    [F:SEC]SELREC = INBRECSEL
    [F:SEC]DEFADD = [M:MAI3]DEFADD
    [F:SEC]HIEBPR = [M:MAI3]HIEBPR
    [F:SEC]CNTTTR = [M:MAI3]CNTTTR
    If [MAI3]NBMQR > 0 Then
      If INBCOL > 0 Then
        [F:SEC]USEQUR = 2
      Else
        [F:SEC]USEQUR = 1
      Endif
    Else
      [F:SEC]USEQUR = 1
    Endif
    Write [SEC]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Unlock [SEC]
      Rollback
      Return
    Else
      Commit
      Unlock [SEC]
    Endif
  Else
    # Il s'agit d'une modification
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP 
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = "CCN"
    [F:SEC]SELCRI = ""
    [F:SEC]SELREC = INBRECSEL
    [F:SEC]DEFADD = [M:MAI3]DEFADD
    [F:SEC]HIEBPR = [M:MAI3]HIEBPR
    [F:SEC]CNTTTR = [M:MAI3]CNTTTR
    If [MAI3]NBMQR > 0 Then
      If INBCOL > 0 Then
        [F:SEC]USEQUR = 2
       Else
        [F:SEC]USEQUR = 1
       Endif
    Else
      [F:SEC]USEQUR = 1
    Endif
    Rewrite [SEC]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [SEC]
      Rollback 
      Return
    Else
      Commit
      Unlock [SEC]
    Endif
  Endif
  Call TEMPON(mess(785,196,1)) From GESECRAN   #Génération de l'échantillon.
  Call DEBTRANS From GLOCK
  Trbegin [SCL]
  Delete [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP = "CCN"
  If fstat Then
    Rollback
  Else
    Commit
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [MKL]
  Delete [MKL] Where [F:MKL]OPGNUM = GSZOPGNUM and [F:MKL]KEYTYPE = "CCN"
  If fstat Then
    Rollback
  Else
    Commit
  Endif
  #On test si il faut gere le ciblage par niveaux
  If [M:MAI3]MASTERSEL=2 Then
    If [M:MAI3]CNTTTR <> "" Then
      If [M:MAI3]NBMQR > 0 Then
        IGESLEVEL = 1
      Else
        IGESLEVEL = 0
      Endif
    Else
      If [M:MAI3]NBMQR > 1 Then
        IGESLEVEL = 1
      Else
        IGESLEVEL = 0
      Endif
    Endif
  Else
    IGESLEVEL = 0
  Endif
  If [M:MAI3]NBMQR > 0 Then
    ICIBLAGE = 0
    #On a des selection marketing    
    While ICIBLAGE < [M:MAI3]NBMQR
      SZMGG0QURNUM = [M:MAI3]QURNUM (ICIBLAGE)
      If SZMGG0QURNUM <> "" Then
        Read [MQR]MQR0=SZMGG0QURNUM
        If fstat Then
          Call TEMPOFF From GESECRAN
          GMESSAGE = mess(786,196,1) #Impossible de générer l'échantillon souhaité. Génération abandonnée.
          GERR = 1
          Break
        Endif
        SZLOOPCLE = ""
        ILOOPCUT = 2750
        ILOOPCLECOUNT = ILOOPCUT
        While ILOOPCLECOUNT >= ILOOPCUT
          ILOOPCLECOUNT = 0
          Filter [QTP] Where [F:QTP]QURNUM = [F:MQR]QURNUM and [F:QTP]PPLORD = [F:MQR]FINPPL and [F:QTP]KEYTGR > SZLOOPCLE
          For [QTP] QTP1
            SZLOOPCLE = [F:QTP]KEYTGR
            If [M:MAI3]MASTERSEL = 2 Then
              #Il y a une sélection maitre définie
              Filter [CNT] Where [F:CNT]CCNCRM = [F:QTP]KEYTGR
              For [CNT] CNT2
                If [F:CNT]BPATYP = 1 Then
                  Read [SCL]SCL1=GSZOPGNUM;"BPR";[F:CNT]BPANUM
                  If !fstat Then
                    If IPERF = 0 Then
                      Call DEBTRANS From GLOCK
                      Trbegin [SCL]
                      INTR = 1
                    Endif
                    If IGESLEVEL = 1 Then
                      Read [MKL]MKL0=GSZOPGNUM;"CCN";[F:CNT]BPANUM
                      If fstat = 0 Then
                        #La clé existe déjà
                        If [F:MKL]LEVEL = ICIBLAGE Then
                          #on traite le meme niveau, il faut insérer
                          IBPASOK = 1
                        Else
                          IBPASOK = 0
                        Endif
                      Else
                        #La clé  n'existe pas on insère
                        [F:MKL]OPGNUM = GSZOPGNUM
                        [F:MKL]KEYTYPE= "CCN"
                        [F:MKL]DATAKEY = [F:CNT]BPANUM
                        [F:MKL]LEVEL = ICIBLAGE 
                        Write [MKL]
                        If fstat Then
                          IPBL = 1
                          Call TEMPOFF From GESECRAN
                          GMESSAGE = mess(100,141,1) #Erreur création
                          GERR = 1
                          INTR = 0
                          Rollback
                          Break 
                        Else
                          If IPERF >= 500 Then
                            Commit
                            IPERF = 0
                            INTR = 0
                          Else
                            IPERF += 1
                          Endif
                        Endif
                        IBPASOK = 1
                      Endif
                    Else
                      IBPASOK = 1
                    Endif
                    If IBPASOK = 1 Then
                      [F:SCL]OPGNUM = GSZOPGNUM
                      [F:SCL]RECTYP = "CCN"
                      [F:SCL]RECNUM = [F:QTP]KEYTGR
                      [F:SCL]BPRNUM = [F:CNT]BPANUM
                      If [M:MAI3]DEFADD = 2 Then
                        [F:SCL]BPAADD = ""
                      Else
                        Read [BPR]BPR0=[F:CNT]BPANUM
                        If fstat Then
                          [F:SCL]BPAADD = ""
                        Else
                          [F:SCL]BPAADD = [F:BPR]BPAADD
                        Endif
                      Endif
                      [F:SCL]CLSNUM = ICLSNUM
                      ICLSNUM += 1
                      Write [SCL]
                      If fstat Then
                        IPBL = 1
                        Call TEMPOFF From GESECRAN
                        GMESSAGE = mess(100,141,1) #Erreur création
                        GERR = 1
                        INTR = 0
                        Rollback
                        Break 
                      Else
                        If IPERF >= 500 Then
                          Commit
                          IPERF = 0
                          INTR = 0
                        Else
                          IPERF += 1
                        Endif
                      Endif
                      INBRECSEL += 1
                    Endif
                  Endif
                Endif
              Next
              Filter [CNT]
              If GERR Then
                Break
              Endif
            Else
              # Il n'y a pas de sélection maitre. On applique uniquement le filtre contact.
              If IPERF = 0 Then
                Call DEBTRANS From GLOCK
                Trbegin [SCL]
                INTR = 1
              Endif
              [F:SCL]OPGNUM = GSZOPGNUM
              [F:SCL]RECTYP = "CCN"
              [F:SCL]RECNUM = [F:QTP]KEYTGR
              [F:SCL]BPRNUM = ""
              [F:SCL]BPAADD = ""
              [F:SCL]CLSNUM = ICLSNUM
              ICLSNUM += 1
              Write [SCL]
              If fstat Then
                IPBL = 1
                Call TEMPOFF From GESECRAN
                GMESSAGE = mess(100,141,1) #Erreur création
                GERR = 1
                INTR = 1
                Rollback
                Break
              Else
                If IPERF >= 500 Then
                  Commit
                  IPERF = 0
                  INTR = 0
                Else
                  IPERF += 1
                Endif
              Endif
              INBRECSEL += 1
            Endif
            ILOOPCLECOUNT += 1
            If ILOOPCLECOUNT >= ILOOPCUT Then
              Break
            Endif
          Next
          Filter [QTP]
          If GERR Then
            Break
          Endif
        Wend
      Endif
      ICIBLAGE += 1
      If GERR Then
        Break
      Endif
    Wend
  Endif
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  If IGESLEVEL = 1 Then
    If [M:MAI3]CNTTTR <> "" Then
      #On utilise le ciblage par niveau pour completer les contacts génériques
      IPERF = 0
      INTR = 0
      SZLOOPCLE = ""
      ILOOPCUT = 2750
      ILOOPCLECOUNT = ILOOPCUT
      While ILOOPCLECOUNT >= ILOOPCUT
        ILOOPCLECOUNT = 0
        Filter [SCL] Where [F:SCL]OPGNUM=GSZOPGNUM and [F:SCL]RECTYP="BPR" and [F:SCL]RECNUM > SZLOOPCLE
        For [SCL]SCL1
          SZLOOPCLE = [F:SCL]RECNUM
          Read [MKL]MKL0=GSZOPGNUM;"CCN";[F:SCL]RECNUM
          If fstat <> 0 Then
            #La clé n'existe déjà, il faut creer un contact generique
            If IPERF = 0 Then
              Call DEBTRANS From GLOCK
              Trbegin [SCLW]
              INTR = 1
            Endif
            [F:SCLW]OPGNUM = GSZOPGNUM
            [F:SCLW]RECTYP = "CCN"
            [F:SCLW]RECNUM = ""
            [F:SCLW]BPRNUM = [F:SCL]RECNUM
            Read [BPR]BPR0=[F:SCL]RECNUM
            If fstat Then
              [F:SCLW]BPAADD = ""
            Else
              [F:SCLW]BPAADD = [F:BPR]BPAADD
            Endif
            [F:SCLW]CLSNUM = ICLSNUM
            ICLSNUM += 1
            Write [SCLW]
            If fstat Then
              IPBL = 1
              Call TEMPOFF From GESECRAN
              GMESSAGE = mess(100,141,1) #Erreur création
              GERR = 1
              INTR = 1
              Rollback
              Break
            Else
              If IPERF >= 500 Then
                Commit
                IPERF = 0
                INTR = 0
              Else
                IPERF += 1
              Endif
            Endif
            INBRECSEL += 1
          Endif
          ILOOPCLECOUNT += 1
          If ILOOPCLECOUNT >= ILOOPCUT Then
            Break
          Endif
        Next
        Filter [SCL]
      Wend
      If INTR Then
        If !IPBL Then
          Commit
        Endif
      Endif
    Endif
  Endif
  Call TEMPOFF From GESECRAN
Return

##########################################################################################################
#Associe un ciblage à une opération
##################################################################
$SETMKGOPGLNK
  #On supprime d'abord toutes les anciennes relations établies avec l'opération courante
  Call DEBTRANS From GLOCK
  Trbegin [MOG]
  Delete [MOG] Where [F:MOG]OPGNUM = GSZOPGNUM and [F:MOG]TGR = SZMGG0TGR
  If fstat Then
    Rollback
    #Erreur lors de l'enregistrement du ciblage marketing.
    GMESSAGE = mess(580,196,1)
    GERR = 1
    Return
  Else
    Commit        
  Endif
  #Ensuite on enregistre la nouvelle relation
  Read [MOG]MOG0=SZMGG0QURNUM;GSZOPGNUM;SZMGG0TGR
  If fstat Then
    Call DEBTRANS From GLOCK
    Trbegin [MOG]
    [F:MOG]MKGQUR = SZMGG0QURNUM
    [F:MOG]OPGNUM = GSZOPGNUM
    [F:MOG]TGR = SZMGG0TGR
    Write [MOG]
    If fstat Then
      Rollback
      #Erreur lors de l'enregistrement du ciblage marketing.
      GMESSAGE = mess(580,196,1)
      GERR = 1
      Return
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
#Associe un ciblage de plus à une opération 
##################################################################
$SETMOREMKGOPGLNK
  #On enregistre la nouvelle relation
  Read [MOG]MOG0=SZMGG0QURNUM;GSZOPGNUM;SZMGG0TGR
  If fstat Then
    Call DEBTRANS From GLOCK
    Trbegin [MOG]
    [F:MOG]MKGQUR = SZMGG0QURNUM
    [F:MOG]OPGNUM = GSZOPGNUM
    [F:MOG]TGR = SZMGG0TGR
    Write [MOG]
    If fstat Then
      Rollback
      #Erreur lors de l'enregistrement du ciblage marketing.
      GMESSAGE = mess(580,196,1)
      GERR = 1
      Return
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
# Complément d'enregistrement en cas de récupération de critère depuis l'assistant marketing.
##########################################################################################################
$ONSAVEMORE
  Local File MKGQURPPL [MQPX]
  Local File QURCRI [QCRX]
  Local File QURCRIVAL [QCVX]
  #Duplique les populations de ciblage
  Call DEBTRANS From GLOCK
  Trbegin [MQPX]
  Delete [MQPX] Where [F:MQPX]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    Rollback
    #Erreur lors de la duplication du ciblage.
    GMESSAGE = mess(789,196,1)
    GERR = 1
    Close Local File [MQPX]
    Close Local File [QCRX]
    Close Local File [QCVX]
    Return
  Else
    Commit
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [MQPX]
  Filter [MQP] Where [F:MQP]QURNUM = SZOLDQURNUM
  For [MQP]
    [F:MQPX] = [F:MQP]
    [F:MQPX]QURNUM = [M:MGG0]QURNUM
    Write [MQPX]
    If fstat Then
      Rollback
      #Erreur lors de la duplication du ciblage.
      GMESSAGE = mess(789,196,1)
      GERR = 1
      Close Local File [MQPX]
      Close Local File [QCRX]
      Close Local File [QCVX]
      Break
    Endif
  Next
  Filter [MQP]
  If GERR Then
    Return
  Else
    Commit
  Endif
  #Duplique les critères de ciblage
  Call DEBTRANS From GLOCK
  Trbegin [QCRX]
  Delete [QCRX] Where [F:QCRX]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    Rollback
    #Erreur lors de la duplication du ciblage.
    GMESSAGE = mess(789,196,1)
    GERR = 1
    Close Local File [MQPX]
    Close Local File [QCRX]
    Close Local File [QCVX]
    Return
  Else
    Commit
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [QCRX]
  Filter [QCR] Where [F:QCR]QURNUM = SZOLDQURNUM
  For [QCR]
    [F:QCRX] = [F:QCR]
    [F:QCRX]QURNUM = [M:MGG0]QURNUM
    Write [QCRX]
    If fstat Then
      Rollback
      #Erreur lors de la duplication du ciblage.
      GMESSAGE = mess(789,196,1)
      GERR = 1
      Close Local File [MQPX]
      Close Local File [QCRX]
      Close Local File [QCVX]
      Break
    Endif
  Next
  Filter [QCR]
  If GERR Then
    Return
  Else
    Commit
  Endif
  #Duplique les valeurs de critères de ciblage
  Call DEBTRANS From GLOCK
  Trbegin [QCVX]
  Delete [QCVX] Where [F:QCVX]QURNUM = [M:MGG0]QURNUM
  If fstat Then
    Rollback
    #Erreur lors de la duplication du ciblage.
    GMESSAGE = mess(789,196,1)
    GERR = 1
    Close Local File [MQPX]
    Close Local File [QCRX]
    Close Local File [QCVX]
    Return
  Else
    Commit
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [QCVX]
  Filter [QCV] Where [F:QCV]QURNUM = SZOLDQURNUM
  For [QCV]
    [F:QCVX] = [F:QCV]
    [F:QCVX]QURNUM = [M:MGG0]QURNUM
    Write [QCVX]
    If fstat Then
      Rollback
      #Erreur lors de la duplication du ciblage.
      GMESSAGE = mess(789,196,1)
      GERR = 1
      Close Local File [MQPX]
      Close Local File [QCRX]
      Close Local File [QCVX]
      Break
    Endif
  Next
  Filter [QCV]
  If GERR Then
    Return
  Else
    Commit
  Endif
  Close Local File [MQPX]
  Close Local File [QCRX]
  Close Local File [QCVX]
Return
