#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ACV",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBACVB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "SETBOUT"   : Gosub SETBOUT
 When "APRES_CRE" : Gosub APRES_CRE
 When "APRES_MOD" : Gosub APRES_MOD
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "RAZCRE"    : Gosub RAZCRE
 When "ANNULE"    : Gosub ANNULE
Endcase
If PSUBB
 Gosub ACTION From SUBACVB
Endif
Return

$OUVRE
Global Char GDOSX3(GLONADS)
Call PARAM("","SUPDOS",GDOSX3) From ADOVAL
If GDOSX3="" : GDOSX3 = "GX3APP" : Endif
Local File =GDOSX3+".ACTIV" [ACV3]
If clalev([F:ATX])=0  : Local File ATEXTE  [ATX]  : Endif
If clalev([F:ACV2])=0 : Local File ACTIV   [ACV2] : Endif
If clalev([F:ACV4])=0 : Local File ACTIV   [ACV4] : Endif
If clalev([F:ADA])=0  : Local File ADOSACT [ADA]  : Endif
Return

$RAZCRE
Actzo
Return

$LIENS
If [F:ACV]LIBACT=0
 [M]ZLIBACT = [F:ACV]INTIT
Else
 Call TEXTE([F:ACV]LIBACT,[M]ZLIBACT) From OBJDIV
Endif
Call GRISE_DEP
Call GRISE_SUP
Call GRISE_TYP
Call GRISE_RANG
Return

Subprog GRISE_DEP
Actzo DEP
Case [M]DEP
 When 2,3
  Actzo ACTDEP
  Effzo ACTFOR
  Grizo ACTFOR
 When 4
  Actzo ACTFOR
  Effzo ACTDEP
  Grizo ACTDEP
 When Default
  Effzo ACTDEP, ACTFOR
  Grizo ACTDEP, ACTFOR
Endcase
End

Subprog GRISE_SUP
If dim([M]FLGSUP)>0
 If [M]FLGSUP=2
  Effzo ACTSUP
  Grizo ACTSUP
 Else
  Actzo ACTSUP
 Endif
Endif
End

Subprog GRISE_TYP
Case [M]TYP
 When 2
  Actzo DIMFIL, DIMMAX
  If [M]DEP=4
   Diszo DIME
  Else
   If [M]DEP=3 & [M]ACTDEP<>""
    Read [ACV]CODACT=[M]ACTDEP
    If [F:ACV]TYP=2
     Diszo DIME
    Else
     Actzo DIME
    Endif
   Else
    Actzo DIME
   Endif
  Endif
 When Default
  [M]DIME = 0 : [M]DIMFIL = 0 : [M]DIMMAX = 0
  Affzo DIME , DIMFIL , DIMMAX
  Grizo DIME , DIMFIL , DIMMAX
Endcase
If nomap<>GDOSX3
 Read [ACV3]CODACT = [M]CODACT
 If !fstat & [F:ACV3]DEP<2
  Diszo DIMFIL
 Endif
Endif
End

Subprog GRISE_RANG
Actzo RANG
End

$VERIF_CRE
Gosub VERIF
Return

$VERIF_MOD
Gosub VERIF
If OK
 # La modification d'un code activité doit être suivie d'une validation du dictionnaire
 # Il est préférable de faire cette modification dans la fiche dossier et de revalider ce dossier
 # Voulez-vous poursuivre la modification
 OK = 1
 Call OUINON(mess(187,125,1)+".\"+mess(188,125,1)+".\"+mess(248,126,1)+"?",OK) From GESECRAN
 If OK<>2 : OK = 0 : Gosub ABANDON From GOBJSUB : Return : Endif
Endif
Return

$VERIF
If [M]TYP=2 & [M]DIME=0
 [M]FLACT = 1 : Affzo FLACT
 # Dimension écran non définie\Fiche désactivée
 Call MESSAGE(mess(155,125,1)+"\"+mess(62,139,1)) From GESECRAN
Endif
Return

$SETBOUT
If CLECUR=0 | REP="M"
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
If find([M]CODACT,"TRU","FAL")
 Call VIREBOUT(CHAINE,"M") From GOBJET
Endif
If GADONIX<>2
 If [M]CODACT<>"" & [M]CODACT<"X"
  Call VIREBOUT(CHAINE,"A2") From GOBJET
 Endif
Endif
Return

$INICRE
$INIMOD
Case [F:ACV]MODULE
 When 1       : [F:ACV]ORDRE = 0
 When 9       : [F:ACV]ORDRE = 1000
 When 2       : [F:ACV]ORDRE = 2000
 When 3       : [F:ACV]ORDRE = 3000
 When 4       : [F:ACV]ORDRE = 4000
 When 7       : [F:ACV]ORDRE = 5000
 When 5       : [F:ACV]ORDRE = 6000
 When 6       : [F:ACV]ORDRE = 7000
 When 8       : [F:ACV]ORDRE = 8000
 When 10      : [F:ACV]ORDRE = 9000
 When Default : [F:ACV]ORDRE = 10000
Endcase
[F:ACV]ORDRE += [F:ACV]RANG
Return

$APRES_CRE
$APRES_MOD
## Mise à jour des dépendances
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ACV2] , [ADA]
 Readlock [ADA]ADA0 = nomap;[M]CODACT
 If fstat=1
  GOK = -1 : GLOCK = "$ADOSACT"-nomap-[M]CODACT : Goto ROLL_TR1
 Elsif fstat=0
  [F:ADA]FLACT = [M]FLACT
  [F:ADA]DIME  = [M]DIME
  Rewrite [ADA]
 Else
  [F:ADA]DOSSIER = nomap
  [F:ADA]CODACT  = [M]CODACT
  [F:ADA]FLACT   = [M]FLACT
  [F:ADA]DIME    = [M]DIME
  [F:ADA]MODULE  = [M]MODULE
  [F:ADA]INTIT   = [M]ZLIBACT
  Write [ADA]
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADA") From GLOCK : Goto AB_TR1
 Endif
 For [ACV2]CODACT Where DEP>=2 and DEP<4 & ACTDEP=[M]CODACT
  Case [F:ACV2]DEP
   When 2
    If [M]FLACT=2 : [F:ACV2]FLACT = 1 : Else : [F:ACV2]FLACT = 2 : Endif
   When 3
    If [F:ACV2]TYP<>2
     Local Char CC(1)
     CC = right$([F:ACV2]CODACT,len([F:ACV2]CODACT))
     If CC>="1" & CC<="9"
      K = val(CC)
     Elsif CC>="A" & CC<="Z"
      K = ascii(CC)-55
     Else
      K = 0
     Endif
     If K<=[M]DIME : [F:ACV2]FLACT = 2 : Else : [F:ACV2]FLACT = 1 : Endif
    Else
     [F:ACV2]FLACT = [M]FLACT
     [F:ACV2]DIME  = min(max([F:ACV2]DIMFIL,[M]DIME),[F:ACV2]DIMMAX)
    Endif
  Endcase
  Rewrite [ACV2]
  If fstat
   GOK = 0 : Call FSTA("ACV2") From GLOCK : Break
  Endif
  Readlock [ADA]ADA0 = nomap;[F:ACV2]CODACT
  If fstat=1
   GOK = -1 : GLOCK = "$ADOSACT"-nomap-[F:ACV2]CODACT : Break
  Elsif fstat=0
   [F:ADA]FLACT = [F:ACV2]FLACT
   [F:ADA]DIME  = [F:ACV2]DIME
   Rewrite [ADA]
   If fstat
    GOK = 0 : Call FSTA("ADA") From GLOCK : Break
   Endif
  Endif
 Next ACV2
 If    GOK<0 : Goto ROLL_TR1
 Elsif !GOK  : Goto AB_TR1
 Endif
 For [ACV2]CODACT Where DEP=4 & ACTFOR<>""
  If instr(1,[F:ACV2]ACTFOR,[M]CODACT)
   Call FORMULE([F:ACV2]ACTFOR,I,K)
   If K
    If I>0
     [F:ACV2]FLACT = 2
     If [F:ACV2]TYP=2
      [F:ACV2]DIME = min(max([F:ACV2]DIMFIL,I),[F:ACV2]DIMMAX)
     Else
      [F:ACV2]DIME = 0
     Endif
    Else
     [F:ACV2]FLACT = 1
    Endif
    Rewrite [ACV2]
    If fstat
     GOK = 0 : Call FSTA("ACV2") From GLOCK : Break
    Endif
    Readlock [ADA]ADA0 = nomap;[F:ACV2]CODACT
    If fstat=1
     GOK = -1 : GLOCK = "$ADOSACT"-nomap-[F:ACV2]CODACT : Break
    Elsif fstat=0
     [F:ADA]FLACT = [F:ACV2]FLACT
     [F:ADA]DIME  = [F:ACV2]DIME
     Rewrite [ADA]
     If fstat
      GOK = 0 : Call FSTA("ADA") From GLOCK : Break
     Endif
    Endif
   Endif
  Endif
 Next ACV2
 If    GOK<0 : Goto ROLL_TR1
 Elsif !GOK  : Goto AB_TR1
 Endif
 If [M]DEP=4 & [M]ACTFOR<>""
  Call FORMULE([M]ACTFOR,I,K)
  If K
   If I>0
    [M]FLACT = 2
    If [M]TYP=2
     [M]DIME = min(max([M]DIMFIL,I),[M]DIMMAX)
    Else
     [M]DIME = 0
    Endif
   Else
    [M]FLACT = 1
   Endif
   Read [ACV2]CODACT=[M]CODACT
   [F:ACV2] = [M]
   Rewrite [ACV2]
   If fstat
    GOK = 0 : Call FSTA("ACV2") From GLOCK : Goto AB_TR1
   Endif
   Readlock [ADA]ADA0 = nomap;[M]CODACT
   If fstat=1
    GOK = -1 : GLOCK = "$ADOSACT"-nomap-[M]CODACT : Goto ROLL_TR1
   Elsif fstat=0
    [F:ADA]FLACT = [F:ACV2]FLACT
    [F:ADA]DIME  = [F:ACV2]DIME
    Rewrite [ADA]
    If fstat
     GOK = 0 : Call FSTA("ADA") From GLOCK : Goto AB_TR1
    Endif
   Endif
  Endif
  Affzo DIME , FLACT
 Endif
 If [M]DEP>=2 and [M]DEP<4 & [M]ACTDEP<>""
  Read [ACV2]CODACT=[M]ACTDEP
  Case [M]DEP
   When 2
    If [F:ACV2]FLACT=2 : [M]FLACT = 1 : Else : [M]FLACT = 2 : Endif
   When 3
    If [M]TYP<>2
     Local Char CC(1)
     CC = right$([M]CODACT,len([M]CODACT))
     If CC>="1" & CC<="9"
      K = val(CC)
     Elsif CC>="A" & CC<="Z"
      K = ascii(CC)-55
     Else
      K = 0
     Endif
     If K<=[F:ACV2]DIME : [M]FLACT = 2 : Else : [M]FLACT = 1 : Endif
    Else
     [M]FLACT = [F:ACV2]FLACT
     [M]DIME  = min(max([M]DIMFIL,[F:ACV2]DIME),[M]DIMMAX)
    Endif
  Endcase
  Read [ACV2]CODACT=[M]CODACT
  [F:ACV2] = [M]
  Rewrite [ACV2]
  If fstat
   GOK = 0 : Call FSTA("ACV2") From GLOCK : Goto AB_TR1
  Endif
  Readlock [ADA]ADA0 = nomap;[F:ACV2]CODACT
  If fstat=1
   GOK = -1 : GLOCK = "$ADOSACT"-nomap-[F:ACV2]CODACT : Goto ROLL_TR1
  Elsif fstat=0
   [F:ADA]FLACT = [F:ACV2]FLACT
   [F:ADA]DIME  = [F:ACV2]DIME
   Rewrite [ADA]
   If fstat
    GOK = 0 : Call FSTA("ADA") From GLOCK : Goto AB_TR1
   Endif
  Endif
 Endif
 Affzo DIME , FLACT
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

###########################################################
Subprog FORMULE(EXPR,RESULT,OK)
Value    Char    EXPR
Variable Integer RESULT, OK
Local Integer I_ , DEB_ , FIN_ , RES_
Local Char    ACT_(30) , CAR_(1) , EXP_(250) , MES_(250)
EXP_ = format$("KTv2:250X",EXPR)
DEB_ = 0
I_ = 1
While 1=1
 CAR_ = mid$(EXP_,I_,1)
 If (CAR_>="A" & CAR_<="Z") | (CAR_>="0" & CAR_<="9" & DEB_>0)
  If DEB_=0 : DEB_ = I_ : Endif
  FIN_ = I_
 Elsif DEB_
  Gosub REMP
 Endif
 I_ += 1
 If I_>len(EXP_) : Break : Endif
Wend
If DEB_
 Gosub REMP
Endif
OK = 1
Onerrgo ERRACT
RESULT = evalue(EXP_)
Onerrgo
End

$ERRACT
MES_ = mess(65,106,1)-"("+EXP_+") : "+errmes$(errn)-errm : # Erreur en évaluation de la formule
Call ECR_TRACE(MES_,1) From GESECRAN
OK = 0
Resume

$REMP
ACT_ = seg$(EXP_,DEB_,FIN_)
If evalue("dim("+ACT_+")")<=0 & len(ACT_)<=GLONACV
 Read [ADA]ADA0 = nomap;ACT_
 If fstat | [F:ADA]FLACT<2
  RES_ = 0
 Elsif [F:ADA]DIME>0
  RES_ = [F:ADA]DIME
 Else
  RES_ = 1
 Endif
 EXP_ = left$(EXP_,DEB_-1)+num$(RES_)+right$(EXP_,FIN_+1)
 I_ = DEB_-1+len(num$(RES_))
Endif
DEB_ = 0
Return

################################################################################
$ANNULE
If clalev([F:ADA])=0  : Local File ADOSACT [ADA]  : Endif
Read [ACV]CODACT=[L]CODE
If [F:ACV]DEP>1
 Delete [ADA] Where DOSSIER=nomap & CODACT=[L]CODE
 If fstat=1
  GOK=-1 : GLOCK = "$ADOSACT"
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADA","") From GLOCK
 Endif
Endif
Return

###########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ACTIV   [ACV1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".ACTIV"   [ACV1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ACTIV   [ACV2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".ACTIV"   [ACV2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
Local Char APPLI1(GDIMFIC), MERE1(GDIMFIC), MACHINE1(GDIMFIC)
Local Char APPLI2(GDIMFIC), MERE2(GDIMFIC), MACHINE2(GDIMFIC)
Call MOTHER([M]DOSORG,APPLI1,MERE1,MACHINE1) From ATEXTRA
If MERE1<>""
 If MACHINE1=""
  If MERE1=nomap
   Local File ADOSACT [ADA1]
  Else
   Local File =MERE1+".ADOSACT" [ADA1]
  Endif
 Else
  Local File =MACHINE1+"@"+MERE1+".ADOSACT" [ADA1]
 Endif
Endif
Call MOTHER([M]DOSDES,APPLI2,MERE2,MACHINE2) From ATEXTRA
If MERE2<>""
 If MACHINE2=""
  If MERE2=nomap
   Local File ADOSACT [ADA2]
  Else
   Local File =MERE2+".ADOSACT" [ADA2]
  Endif
 Else
  Local File =MACHINE2+"@"+MERE2+".ADOSACT" [ADA2]
 Endif
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ACV1], [ATX1], [ACV2], [ATX2]
If clalev([F:ADA1])>0 : Close Local File [ADA1] : Endif
If clalev([F:ADA2])>0 : Close Local File [ADA2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [ACV2] , [ATX2]
 Delete [ACV2] Where CODACT=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACTIV" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACV2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ACV1]CODACT Where CODACT=TABLE
  [F:ACV2] = [F:ACV1]
  Call COPTEXTE([F:ACV1]LIBACT,[F:ACV2]LIBACT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:ACV2]UPDUSR)>0 : [F:ACV2]UPDUSR = GUSER : Endif
  If dim([F:ACV2]UPDDAT)>0 : [F:ACV2]UPDDAT = date$ : Endif
  If dim([F:ACV2]UPDTIM)>0 : [F:ACV2]UPDTIM = time : Endif
  Write [ACV2]
  If fstat
   GOK=0 : Call FSTA("ACV2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 If clalev([F:ADA1])>0 & clalev([F:ADA2])>0
  Read [ADA1]ADA0 = APPLI1;TABLE
  If !fstat
   Readlock [ADA2]ADA0 = APPLI2;TABLE
   If fstat=1
    GOK = -1 : GLOCK = "$ADOSACT"-APPLI1-TABLE : Goto ROLL_TR_COP
   Elsif fstat=0
    [F:ADA2]FLACT = [F:ADA1]FLACT
    [F:ADA2]DIME  = [F:ADA1]DIME
    Rewrite [ADA2]
    If fstat
     GOK = 0 : Call FSTA("ADA2") From GLOCK : Goto AB_TR_COP
    Endif
   Else
    [F:ADA2]DOSSIER = APPLI2
    [F:ADA2]CODACT  = [F:ADA1]CODACT
    [F:ADA2]FLACT   = [F:ADA1]FLACT
    [F:ADA2]DIME    = [F:ADA1]DIME
    [F:ADA2]MODULE  = [F:ADA1]MODULE
    [F:ADA2]INTIT   = [F:ADA1]INTIT
    Write [ADA2]
    If fstat
     GOK = 0 : Call FSTA("ADA2") From GLOCK : Goto AB_TR_COP
    Endif
   Endif
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################################
# Etiquettes du masque ACV2
##########################################################################

Subprog AP_CODACT(VALEUR)
Variable Char     VALEUR
[M]CODACT = VALEUR
Call GRISE_RANG
Call GRISE_TYP
Call GRISE_DEP
End

Subprog AS_ZLIBACT(VALEUR)
Variable Char     VALEUR
# Le code activité peut avoir été créé dans la gestion des dossiers
If [M]LIBACT=0
 Read [ACV]CODACT=[M]CODACT
 If !fstat & [F:ACV]INTIT<>""
  VALEUR = [F:ACV]INTIT
  Call TXTCONT(VALEUR,[M]ZLIBACT,[M]LIBACT,30,8,[M]CODACT,"#1") From OBJDIV
 Endif
Endif
End

Subprog C_FLGSUP(VALEUR)
Variable Integer VALEUR
[M]FLGSUP = VALEUR
Call GRISE_SUP
End

Subprog C_ACTSUP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local File ACTIV [ACV2]
Read [ACV2]CODACT = VALEUR
If fstat | [F:ACV2]FLGSUP<>2
 Call ERREUR("Code activité non superviseur") From GESECRAN
 mkstat = 2 : End
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
[M]TYP = VALEUR
Call GRISE_TYP
End

Subprog C_DIMFIL(VALEUR)
Variable Decimal VALEUR
If VALEUR>32767 : mkstat = 1 : End : Endif
End

Subprog C_DIMMAX(VALEUR)
Variable Decimal VALEUR
If VALEUR>32767 : mkstat = 1 : End : Endif
If VALEUR<>0 & VALEUR<[M]DIMFIL : mkstat = 1 : End : Endif
End

Subprog AM_DIMMAX(VALEUR)
Variable Decimal VALEUR
If GADONIX<>2 and [M]CODACT<"X"
 # Modification impossible
 # Cette valeur standard est réactualisée par l'installation d'une nouvelle version du produit
 GMESSAGE = mess(9,123,1)+"\"+mess(156,139,1)
 mkstat = 2
Endif
End

Subprog C_DIME(VALEUR)
Variable Decimal VALEUR
If VALEUR>32767 : mkstat = 1 : End : Endif
If [M]DIMMAX=0 : End : Endif
If VALEUR<>0 & VALEUR>[M]DIMMAX : mkstat = 1 : End : Endif
If [M]CODACT="STT" & VALEUR<[M]DIMFIL : mkstat = 1 : End : Endif
End

Subprog C_DEP(VALEUR)
Variable Integer VALEUR
[M]DEP = VALEUR
Call GRISE_DEP
Call GRISE_TYP
End

Subprog AS_ACTDEP(VALEUR)
Variable Char    VALEUR()
If [M]DEP<1 : mkstat = 1 : Endif
End

Subprog C_ACTDEP(VALEUR)
Variable Char    VALEUR()
Read [ACV2]CODACT = VALEUR
If [F:ACV2]DEP<>1
 GMESSAGE = mess(55,126,1)-[F:ACV2]ACTDEP : # Code activité dépendant de
 mkstat = 2 : End
Endif
End

######################################################
## Test présence d'un code activité
######################################################
Subprog ACTIV(CODACT,OK)
Value    Char    CODACT
Variable Integer OK
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
Read [ACV]CODACT = CODACT
If fstat or [F:ACV]FLACT<>2
 OK = 0
Else
 OK = 1
Endif
End

################################################################################
#
# Désactivation de lignes d'un menu local suivant un code activité
# Pour désactiver les lignes 1, 2, 3, 11 : [L]LISTE='01020311'
#
Subprog ACVLIB(CODACT2,LISTE2)
Value Char CODACT2(), LISTE2()

Local Libelle I1, J1, I2, J2, I
Local Char    CODACT(len([L]CODACT2)), LISTE(len([L]LISTE2))
If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif

Repeat
 I1=I2+1
 I2=instr(I1,[L]CODACT2," ")
 If !I2 : I2=1+len([L]CODACT2) : Endif
 [L]CODACT=seg$([L]CODACT2,I1,I2-1)

 J1=J2+1
 J2=instr(J1,[L]LISTE2," ")
 If !J2 : J2=1+len([L]LISTE2) : Endif
 [L]LISTE=seg$([L]LISTE2,J1,J2-1)

 If [F:ACV]CODACT<>[L]CODACT : Read [ACV]CODACT=[L]CODACT
 Else                          fstat=0
 Endif
 If fstat | [F:ACV]FLACT<2
  For I=1 To len([L]LISTE) Step 2 : [V]GMENLOC(val(mid$([L]LISTE,I,2)))=1 : Next
 Endif
Until I2>len([L]CODACT2) | J2>len([L]LISTE2)

End

################################################################################
#
# Désactivation de lignes d'un menu local sous forme de bouton radio suivant
# un code activité
# Pour désactiver les lignes 1, 2, 3, 11 : [L]LISTE='01020311'
#
Subprog ACVLIBBUT(VALEUR,CODACT2,LISTE2)
Value Integer VALEUR
Value Char    CODACT2(), LISTE2()

Local Libelle I1, J1, I2, J2, I
Local Char    CODACT(len([L]CODACT2)), LISTE(len([L]LISTE2))
If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif

Repeat
 I1=I2+1
 I2=instr(I1,[L]CODACT2," ")
 If !I2 : I2=1+len([L]CODACT2) : Endif
 [L]CODACT=seg$([L]CODACT2,I1,I2-1)

 J1=J2+1
 J2=instr(J1,[L]LISTE2," ")
 If !J2 : J2=1+len([L]LISTE2) : Endif
 [L]LISTE=seg$([L]LISTE2,J1,J2-1)

 If [F:ACV]CODACT<>[L]CODACT : Read [ACV]CODACT=[L]CODACT
 Else                          fstat=0
 Endif
 If fstat | [F:ACV]FLACT<2
  For I=1 To len([L]LISTE) Step 2
   If [L]VALEUR=val(mid$([L]LISTE,I,2))
    [V]GMESSAGE=mess(83,123,1) : # Valeur incorrecte
    mkstat     =2
    Break 2
   Endif
  Next
 Endif
Until I2>len([L]CODACT2) | J2>len([L]LISTE2)

End

################################################################################
#
# mkstat=2 si code activité désactivé
#
Subprog ACVMK2(CODACT)
Value Char CODACT()

If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif

If [F:ACV]CODACT<>[L]CODACT : Read [ACV]CODACT=[L]CODACT
Else                          fstat=0
Endif
If !fstat & [F:ACV]FLACT=2 : End : Endif

mkstat=2

End

################################################################################
#
# Désactivation de boutons suivant un code activité
# Pour désactiver les boutons 1, 2, 3, 11 : [L]LISTE='01020311'
#
Subprog ACVBUT(CODACT,LISTE)
Value Char CODACT(), LISTE()

If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif

If [F:ACV]CODACT<>[L]CODACT : Read [ACV]CODACT=[L]CODACT
Else                          fstat=0
Endif
If !fstat & [F:ACV]FLACT=2 : End : Endif

Local Libelle I

For I=1 To len([L]LISTE) Step 2
 Assign "[V]GBOUT"+num$((val(mid$([L]LISTE,I,2)))) With ""
Next

End
