$GEOIND150_APLSTD
#----------------------------------------
# lecture aplstd XVX de geode et verification si c'est le même
#------------------------

Read [XVX]CLE = WCHAPITRE;WNUMERO;GLANORI
If fstat = 0
   If [F:XVX]LANMES = WTEXTE_FRA
      # on peut donc mettre a jour
      Read [XVX]CLE = WCHAPITRE;WNUMERO;WLANTRAD
      Case fstat 
           When 0 :
                [F:XVX]LANMES = WLANMESSAGE
                Call FLDUPD("XVX") From OBJDIV
                Rewrite [XVX]
                If fstat:   Call FSTA("XVX") From GLOCK : Endif
               # si le bri est vide on le met aussi a jour
               If GUSER = "XENG" and [M]LAN = "ENG"
                   Read [XVX]CLE = WCHAPITRE;WNUMERO;"BRI"
                   If fstat = 0
                      If [F:XVX]LANMES = ""
                           [F:XVX]LANMES   = WLANMESSAGE
                           Call FLDUPD("XVX") From OBJDIV
                           Rewrite [XVX]
                           If fstat : Call FSTA("XVX") From GLOCK  : Endif
                      Endif
                   Endif
                Endif

           When 4, 5 :
                WLANTRAD = GLANORI
                Read [XVX]CLE = WCHAPITRE;WNUMERO;WLANTRAD
                Case fstat
                     When 0 :
                         [F:XVX]LANCHP   = WCHAPITRE
                         [F:XVX]LANNUM   = WNUMERO
                         [F:XVX]LAN      = [M:ALT]LAN
                         [F:XVX]LANMES   = WLANMESSAGE
