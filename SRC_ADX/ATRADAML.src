                              Rewrite [XXZ]
                              If fstat : Call FSTA("XXZ") From GLOCK  : Endif
                          Endif
                       Endif
                  Endif
               When 4, 5 :
                  WLANTRAD = GLANORI
                  Read [XXZ]CLE = WCHAPITRE;WNUMERO;WLANTRAD
                  Case fstat
                       When 0 :
                           [F:XXZ]LANCHP   = WCHAPITRE
                           [F:XXZ]LANNUM   = WNUMERO
                           [F:XXZ]LAN      = [M:ALT]LAN
                           [F:XXZ]LANMES   = WLANMESSAGE
                           Call FLDCRE("XXZ") From OBJDIV
                           Write [XXZ]
                           If fstat : Call FSTA("XXZ") From GLOCK  : Endif
                           # dans le cas du BRI on met a jour egalement langue USA uniquement en creation
                           # suite a demande (2007) sophie rebeyrotte : inversion
                           # c'est maintenant le ENG qui est maitre et qui met a jour le bri
                           If GUSER = "XENG" and [M]LAN = "ENG"
                              Read [XXZ]CLE = WCHAPITRE;WNUMERO;"BRI"
                              Case fstat
                                When 4, 5 :
                                    Read [XXZ]CLE = WCHAPITRE;WNUMERO;WLANTRAD
                                    [F:XXZ]LANCHP   = WCHAPITRE
                                    [F:XXZ]LANNUM   = WNUMERO
                                    [F:XXZ]LAN      = "BRI"
