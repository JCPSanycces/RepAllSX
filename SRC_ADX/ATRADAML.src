#<AdxTL>@(#)4.0.0.0 $Revision$
#############################################################
#   TRT pour mise a jour APLSTD tout produit toute version
#############################################################

$SUPERV150_APLSTD
Read [XVS]CLE = WCHAPITRE;WNUMERO;GLANORI
If fstat = 0
    If [F:XVS]LANMES = WTEXTE_FRA
        # on peut donc mettre a jour
        Read [XVS]CLE = WCHAPITRE;WNUMERO;WLANTRAD
        Case fstat 
            When 0 :
               [F:XVS]LANMES = WLANMESSAGE
               Call FLDUPD("XVS") From OBJDIV
               Rewrite [XVS]
               If fstat:   Call FSTA("XVS") From GLOCK : Endif
               # si le bri est vide on le met aussi a jour
               If GUSER = "XENG" and [M]LAN = "ENG"
                   Read [XVS]CLE = WCHAPITRE;WNUMERO;"BRI"
                   If fstat = 0
                      If [F:XVS]LANMES = ""
                           [F:XVS]LANMES   = WLANMESSAGE
                           Call FLDUPD("XVS") From OBJDIV
                           Rewrite [XVS]
                           If fstat : Call FSTA("XVS") From GLOCK  : Endif
                      Endif
                   Endif
                Endif
            When 4, 5 :
               WLANTRAD = GLANORI
               Read [XVS]CLE = WCHAPITRE;WNUMERO;WLANTRAD
               Case fstat
               When 0 :
                   [F:XVS]LANCHP   = WCHAPITRE
                   [F:XVS]LANNUM   = WNUMERO
                   [F:XVS]LAN      = [M:ALT]LAN
                   [F:XVS]LANMES   = WLANMESSAGE
                   Call FLDCRE("XVS") From OBJDIV
                   Write [XVS]
                   If fstat : Call FSTA("XVS") From GLOCK  : Endif

                   # dans le cas du BRI on met a jour egalement langue USA uniquement en creation
                   # suite a demande (2007) sophie rebeyrotte : inversion
                   # c'est maintenant le ENG qui est maitre et qui met a jour le bri
                   If GUSER = "XENG" and [M]LAN = "ENG"
                      Read [XVS]CLE = WCHAPITRE;WNUMERO;"BRI"
                      Case fstat
                      When 4, 5 :
                                Read [XVS]CLE = WCHAPITRE;WNUMERO;WLANTRAD
                                [F:XVS]LANCHP   = WCHAPITRE
                                [F:XVS]LANNUM   = WNUMERO
                                [F:XVS]LAN      = "BRI"
                                [F:XVS]LANMES   = WLANMESSAGE
                                Call FLDCRE("XVS") From OBJDIV
                                Write [XVS]
                                If fstat : Call FSTA("XVS") From GLOCK  : Endif
                       When 0:
                            If [F:XVS]LANMES = ""
                                [F:XVS]LANMES   = WLANMESSAGE
                                Call FLDUPD("XVS") From OBJDIV
                                Rewrite [XVS]
                                If fstat : Call FSTA("XVS") From GLOCK  : Endif
                            Endif
                     Endcase
                   Endif
               Endcase
               WLANTRAD = [M]LAN
            When Default :
                GOK = 0 
                Call FSTA("XVS") From GLOCK 
        Endcase        
    Else
        # on n'est pas identique : on sort
        Return
    Endif
Else
        # on n'est pas identique : on sort
        Return

Endif

Return

