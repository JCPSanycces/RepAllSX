#############################################################################
# ouverture des differents fichiers pour trts comme aloctrad
#############################################################################
$OUVRE_FIC
If filinfo(filpath("",GMAGIC,""),0)>=0
   WIND_TRAD = 0
   For ILAN=1 To GNBLANSTD
       If GUSER=GUSRLAN(ILAN) and nomap=GREFER(ILAN)
            # on est sur à dossier indus pour trad
            # ici on ne peut pas tester code langue car classe M  pas ouverte
            WIND_TRAD = 1
      Endif
   Next ILAN
   ###
   Local Char WDOSMOTH(GLONADS+2)
   WDOSMOTH = "*"+adxmother(0)+"*"
   If pat (GINDUS , WDOSMOTH)
        # ce fichier ne sert plus a rien
        #Local File AMENLOC [XAM]
        If GINDUS = ""
             Local File APLSTD [XAS]
        Else
            If WIND_TRAD = 0
                Local File APLSTD [XAS]
            Else
                Local File =adxmother(0)+"."+"APLSTD" [XAS]
                #----------------------------------#
                #  mise a jour aplstd uniquement de la version en cours 
                # mise a jour egalement  en v5 sur les autres produits pour les aplstd superv
                #  pas de remonter sur les autres versions v140 et v130
                #  attention en V6 : abelx3 n'existe plus on est directement dans x3
                # attention au V5 : paye est uniquement en fra
                #----------------------------------#
                If GFOLDER_V190 (0) <> "" 
                  # APLSTD de l'appli SUPERV190
                  Local File =GFOLDER_V190(0)+".APLSTD" [XYSV9]
                  Local File =GFOLDER_V190(0)+".AMENLOC" [XYAV9]
                  # gproduit = 0 : c'est x3
                  # gproduit = 1 : c'est geode
                  # gproduit = 3 : c'est abelx3
                  # gproduit = 2 : c'est paye
                  If GPRODUIT = 0
                        # amenloc v9 du dossier mere + aplstd
                        Local File =GFOLDER_V190(1)+".AMENLOC" [XYMV9]
                        Local File =GFOLDER_V190(1)+".APLSTD" [XYZV9]
                        If GFOLDER_V190(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus 
                        Endif
                        If GFOLDER_V190(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V190(2)+".APLSTD" [XYXV9]
                        Endif
                        If GFOLDER_V190(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V190(3)+".APLSTD" [XYPV9]
                        Endif
                  Elsif GPRODUIT = 1
                        # amenloc v9 du dossier mere + aplstd
                        Local File =GFOLDER_V190(2)+".AMENLOC" [XYMV9]
                        Local File =GFOLDER_V190(2)+".APLSTD" [XYXV9]
                        If GFOLDER_V190(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V190(1)+".APLSTD" [XYZV9]
                        Endif
                        If GFOLDER_V190(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V190(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V190(3)+".APLSTD" [XYPV9]
                        Endif
                  Elsif GPRODUIT = 2
                        # amenloc v9 du dossier mere + aplstd
                        Local File =GFOLDER_V190(3)+".AMENLOC" [XYMV9]
                        Local File =GFOLDER_V190(3)+".APLSTD" [XYPV9]
                        If GFOLDER_V190(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V190(1)+".APLSTD" [XYZV9]
                        Endif
                        If GFOLDER_V190(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V190(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V190(2)+".APLSTD" [XYXV9]
                        Endif

                  Elsif GPRODUIT = 3
                        # on ne fait plus rien car abel dans x3 a partir de la v6
                  Endif
                Endif  
                #----------------------------------#
                #  mise a jour aplstd uniquement de la version en cours 
                # mise a jour egalement  en v5 sur les autres produits pour les aplstd superv
                #  pas de remonter sur les autres versions v140 et v130
                #  attention en V6 : abelx3 n'existe plus on est directement dans x3
                # attention au V5 : paye est uniquement en fra
                #----------------------------------#
                If GFOLDER_V180 (0) <> "" 
                  # APLSTD de l'appli SUPERV180
                  Local File =GFOLDER_V180(0)+".APLSTD" [XYSV8]
                  Local File =GFOLDER_V180(0)+".AMENLOC" [XYAV8]
                  # gproduit = 0 : c'est x3
                  # gproduit = 1 : c'est geode
                  # gproduit = 3 : c'est abelx3
                  # gproduit = 2 : c'est paye
                  If GPRODUIT = 0
                        # amenloc v8 du dossier mere + aplstd
                        Local File =GFOLDER_V180(1)+".AMENLOC" [XYMV8]
                        Local File =GFOLDER_V180(1)+".APLSTD" [XYZV8]
                        If GFOLDER_V180(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus 
                        Endif
                        If GFOLDER_V180(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V180(2)+".APLSTD" [XYXV8]
                        Endif
                        If GFOLDER_V180(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V180(3)+".APLSTD" [XYPV8]
                        Endif
                  Elsif GPRODUIT = 1
                        # amenloc v8 du dossier mere + aplstd
                        Local File =GFOLDER_V180(2)+".AMENLOC" [XYMV8]
                        Local File =GFOLDER_V180(2)+".APLSTD" [XYXV8]
                        If GFOLDER_V180(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V180(1)+".APLSTD" [XYZV8]
                        Endif
                        If GFOLDER_V180(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V180(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V180(3)+".APLSTD" [XYPV8]
                        Endif
                  Elsif GPRODUIT = 2
                        # amenloc v8 du dossier mere + aplstd
                        # pas de hrm en v8
                        If GFOLDER_V180(3) <> ""
                               Local File =GFOLDER_V180(3)+".AMENLOC" [XYMV8]
                               Local File =GFOLDER_V180(3)+".APLSTD" [XYPV8]
                        Endif
                        If GFOLDER_V180(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V180(1)+".APLSTD" [XYZV8]
                        Endif
                        If GFOLDER_V180(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V180(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V180(2)+".APLSTD" [XYXV8]
                        Endif

                  Elsif GPRODUIT = 3
                        # on ne fait plus rien car abel dans x3 a partir de la v6
                  Endif
                Endif  
                #-----------------------------#
                #  mise a jour aplstd uniquement de la version en cours 
                # mise a jour egalement  en v5 sur les autres produits pour les aplstd superv
                #  pas de remonter sur les autres versions v140 et v130
                #  attention en V6 : abelx3 n'existe plus on est directement dans x3
                # attention au V5 : paye est uniquement en fra
                #----------------------------------#
                If GFOLDER_V170 (0) <> "" 
                  # APLSTD de l'appli SUPERV170
                  Local File =GFOLDER_V170(0)+".APLSTD" [XYS]
                  Local File =GFOLDER_V170(0)+".AMENLOC" [XYA]
                  # gproduit = 0 : c'est x3
                  # gproduit = 1 : c'est geode
                  # gproduit = 3 : c'est abelx3
                  # gproduit = 2 : c'est paye
                  If GPRODUIT = 0
                        # amenloc v7 du dossier mere + aplstd
                        Local File =GFOLDER_V170(1)+".AMENLOC" [XYM]
                        Local File =GFOLDER_V170(1)+".APLSTD" [XYZ]
                        If GFOLDER_V170(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus 
                        Endif
                        If GFOLDER_V170(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V170(2)+".APLSTD" [XYX]
                        Endif
                        If GFOLDER_V170(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V170(3)+".APLSTD" [XYP]
                        Endif
                  Elsif GPRODUIT = 1
                        # amenloc v7 du dossier mere + aplstd
                        Local File =GFOLDER_V170(2)+".AMENLOC" [XYM]
                        Local File =GFOLDER_V170(2)+".APLSTD" [XYX]
                        If GFOLDER_V170(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V170(1)+".APLSTD" [XYZ]
                        Endif
                        If GFOLDER_V170(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V170(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V170(3)+".APLSTD" [XYP]
                        Endif
                  Elsif GPRODUIT = 2
                        # amenloc v7 du dossier mere + aplstd
                        Local File =GFOLDER_V170(3)+".AMENLOC" [XYM]
                        Local File =GFOLDER_V170(3)+".APLSTD" [XYP]
                        If GFOLDER_V170(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V170(1)+".APLSTD" [XYZ]
                        Endif
                        If GFOLDER_V170(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V170(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V170(2)+".APLSTD" [XYX]
                        Endif

                  Elsif GPRODUIT = 3
                        # on ne fait plus rien car abel dans x3 a partir de la v6
                  Endif
                Endif    
                #-----------------------------#
                #  mise a jour aplstd uniquement de la version en cours 
                # mise a jour egalement  en v5 sur les autres produits pour les aplstd superv
                #  pas de remonter sur les autres versions v140 et v130
                #  attention en V6 : abelx3 n'existe plus on est directement dans x3
                # attention au V5 : paye est uniquement en fra
                #----------------------------------#
                If GFOLDER_V160 (0) <> "" 
                  # APLSTD de l'appli SUPERV160
                  Local File =GFOLDER_V160(0)+".APLSTD" [XXS]
                  Local File =GFOLDER_V160(0)+".AMENLOC" [XXA]
                  # gproduit = 0 : c'est x3
                  # gproduit = 1 : c'est geode
                  # gproduit = 3 : c'est abelx3
                  # gproduit = 2 : c'est paye
                  If GPRODUIT = 0
                        If GFOLDER_V160(1) <> "" 
                            # amenloc v6 du dossier mere + aplstd
                            Local File =GFOLDER_V160(1)+".AMENLOC" [XXM]
                            Local File =GFOLDER_V160(1)+".APLSTD" [XXZ]
                        Endif
                        If GFOLDER_V160(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus 
                        Endif
                        If GFOLDER_V160(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V160(2)+".APLSTD" [XXX]
                        Endif
                        If GFOLDER_V160(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V160(3)+".APLSTD" [XXP]
                        Endif
                  Elsif GPRODUIT = 1
                        If GFOLDER_V160(2) <> "" 
                            # amenloc v6 du dossier mere
                            Local File =GFOLDER_V160(2)+".AMENLOC" [XXM]
                            Local File =GFOLDER_V160(2)+".APLSTD" [XXX]
                        Endif
                        If GFOLDER_V160(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V160(1)+".APLSTD" [XXZ]
                        Endif
                        If GFOLDER_V160(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V160(3) <> ""
                            # aplstd de l appli paye
                            Local File =GFOLDER_V160(3)+".APLSTD" [XXP]
                        Endif
                  Elsif GPRODUIT = 2
                        If GFOLDER_V160(3) <> "" 
                            # amenloc v6 du dossier mere attention sur la paye 
                            Local File =GFOLDER_V160(3)+".AMENLOC" [XXM]
                            Local File =GFOLDER_V160(3)+".APLSTD" [XXP]
                        Endif
                        If GFOLDER_V160(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V160(1)+".APLSTD" [XXZ]
                        Endif
                        If GFOLDER_V160(4) <> "" 
                            # aplstd de l appli abelx3
                            # on ne fait plus
                        Endif
                        If GFOLDER_V160(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V160(2)+".APLSTD" [XXX]
                        Endif
                  Elsif GPRODUIT = 3
                        # on ne fait plus rien car abel dans x3 a partir de la v6
                  Endif
                Endif    
                #---------------------
                # pour les versions v5
                # pas de mise a jour de paye en v5
                #---------------------
                If GFOLDER_V150 (0) <> "" 
                    # APLSTD de l'appli SUPERV150 et amenloc
                    Local File =GFOLDER_V150(0)+".APLSTD" [XVS]
                    Local File =GFOLDER_V150(0)+".AMENLOC" [XVA]
                    # gproduit = 0 : c'est x3
                    # gproduit = 1 : c'est geode
                    # gproduit = 3 : c'est abelx3
                    # gproduit = 2 : c'est paye
                    If GPRODUIT = 0
                        If GFOLDER_V150(1) <> "" 
                            # amenloc v5 du dossier mere + aplstd
                            Local File =GFOLDER_V150(1)+".AMENLOC" [XVM]
                            Local File =GFOLDER_V150(1)+".APLSTD" [XVZ]
                        Endif
                        If GFOLDER_V150(4) <> "" 
                            # aplstd de l appli abelx3
                            Local File =GFOLDER_V150(4)+".APLSTD" [XVY]
                        Endif
                        If GFOLDER_V150(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V150(2)+".APLSTD" [XVX]
                        Endif
                        If GFOLDER_V150(3) <> ""
                            # on ne fait rien en v5 sur paye 
                        Endif
                    Elsif GPRODUIT = 1
                        If GFOLDER_V150(2) <> "" 
                            # amenloc v5 du dossier mere
                            Local File =GFOLDER_V150(2)+".AMENLOC" [XVM]
                            Local File =GFOLDER_V150(2)+".APLSTD" [XVX]
                        Endif
                        If GFOLDER_V150(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V150(1)+".APLSTD" [XVZ]
                        Endif
                        If GFOLDER_V150(4) <> "" 
                            # aplstd de l appli abelx3
                            Local File =GFOLDER_V150(4)+".APLSTD" [XVY]
                        Endif
                        If GFOLDER_V150(3) <> ""
                            # on ne fait rien en v5 sur paye 
                        Endif
                    Elsif GPRODUIT = 2
                        If GFOLDER_V150(3) <> "" 
                            # amenloc v5 du dossier mere attention sur la paye 
                            Local File =GFOLDER_V150(3)+".AMENLOC" [XVM]
                            # on ne fait rien en v5 sur paye 
                        Endif
                        If GFOLDER_V150(1) <> "" 
                            # aplstd de l appli x3
                            Local File =GFOLDER_V150(1)+".APLSTD" [XVZ]
                        Endif
                        If GFOLDER_V150(4) <> "" 
                            # aplstd de l appli abelx3
                            Local File =GFOLDER_V150(4)+".APLSTD" [XVY]
                        Endif
                        If GFOLDER_V150(2) <> ""
                            # aplstd de l appli geode
                            Local File =GFOLDER_V150(2)+".APLSTD" [XVX]
                        Endif
                    Elsif GPRODUIT = 3
                        # on ne fait plus rien car abel dans x3 a partir de la v6
                    Endif
                Endif    
            Endif
        Endif
   Endif
Endif

Return




