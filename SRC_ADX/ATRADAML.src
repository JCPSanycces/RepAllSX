                              Read [XVX]CLE = WCHAPITRE;WNUMERO;"BRI"
                              Case fstat
                                  When 4, 5 :
                                    Read [XVX]CLE = WCHAPITRE;WNUMERO;WLANTRAD
                                    [F:XVX]LANCHP   = WCHAPITRE
                                    [F:XVX]LANNUM   = WNUMERO
                                    [F:XVX]LAN      = "BRI"
                                    [F:XVX]LANMES   = WLANMESSAGE
                                    Call FLDCRE("XVX") From OBJDIV
                                    Write [XVX]
                                    If fstat : Call FSTA("XVX") From GLOCK  : Endif
                               When 0:
                                    If [F:XVX]LANMES = ""
                                        [F:XVX]LANMES   = WLANMESSAGE
                                        Call FLDUPD("XVX") From OBJDIV
                                        If fstat : Call FSTA("XVX") From GLOCK  : Endif
                                    Endif
                             Endcase
                         Endif
                Endcase
                WLANTRAD = [M]LAN
           When Default :
                GOK = 0 
                Call FSTA("XVX") From GLOCK 
      Endcase        
   Else
      # on n'est pas identique : on sort
      Return
   Endif
Else
     # on n'est pas identique : on sort
     Return
Endif

Return

