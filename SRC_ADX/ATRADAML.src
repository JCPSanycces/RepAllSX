If fstat = 0
   If [F:XXZ]LANMES = WTEXTE_FRA
          # on peut donc mettre a jour
          Read [XXZ]CLE = WCHAPITRE;WNUMERO;WLANTRAD
          Case fstat 
               When 0 :
                  [F:XXZ]LANMES = WLANMESSAGE
                  Call FLDUPD("XXZ") From OBJDIV
                  Rewrite [XXZ]
                  If fstat:   Call FSTA("XXZ") From GLOCK : Endif
                  # si le bri est vide on le met aussi a jour
                  If GUSER = "XENG" and [M]LAN = "ENG"
                       Read [XXZ]CLE = WCHAPITRE;WNUMERO;"BRI"
                       If fstat = 0
                          If [F:XXZ]LANMES = ""
                              [F:XXZ]LANMES   = WLANMESSAGE
