                                    Call FLDCRE("XXZ") From OBJDIV
                                    Write [XXZ]
                                    If fstat : Call FSTA("XXZ") From GLOCK  : Endif
                               When 0:
                                    If [F:XXZ]LANMES = ""
                                        [F:XXZ]LANMES   = WLANMESSAGE
                                        Call FLDUPD("XXZ") From OBJDIV
                                        Rewrite [XXZ]
                                        If fstat : Call FSTA("XXZ") From GLOCK  : Endif
                                    Endif

                             Endcase
                           Endif
                  Endcase
                  WLANTRAD = [M]LAN
               When Default :
                  GOK = 0 
                  Call FSTA("XXZ") From GLOCK 
          Endcase        
   Else
          # on n'est pas identique : on sort
          Return
   Endif
Else
   # on n'est pas identique : on sort
   Return
Endif
Return


