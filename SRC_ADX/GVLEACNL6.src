#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : MWA
# LE          : 08 Mars      2018 07:31:23

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".ELEACNL" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".ELEACNL" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub LEACNL6
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$LEACNL6
 #--> Désignation
 [F:EVT0]DES        = [F:LEA]LEADES
 #--> Menus locaux
 #--> Zones numériques
 [F:EVT0]ICRBRWRAT  = [F:LEA]ICRBRWRAT
 [F:EVT0]IMPLEARAT  = [F:LEA]IMPLEARAT
 [F:EVT0]INIDIRCST  = [F:LEA]INIDIRCST
 [F:EVT0]INIPREVAL  = [F:LEA]INIPREVAL
 [F:EVT0]INIPREVALC = [F:LEA]INIPREVALC
 [F:EVT0]INIPREVALI = [F:LEA]INIPREVALI
 [F:EVT0]RESCOS     = [F:LEA]RESCOS
 [F:EVT0]USRFLDM1   = [F:LEA]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:LEA]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:LEA]USRFLDM3
 [F:EVT0]USRFLDM4   = [F:LEA]USRFLDM4
 [F:EVT0]USRFLDM5   = [F:LEA]USRFLDM5
 [F:EVT0]USRFLDM6   = [F:LEA]USRFLDM6
 [F:EVT0]USRFLDC1   = [F:LEA]USRFLDC1
 [F:EVT0]USRFLDC2   = [F:LEA]USRFLDC2
 #--> Zones alphanumériques
 [F:EVT0]ACCCOD     = [F:LEA]ACCCOD
 [F:EVT0]CUR        = [F:LEA]IASCUR
 [F:EVT0]USRFLDA1   = [F:LEA]USRFLDA1
 [F:EVT0]USRFLDA2   = [F:LEA]USRFLDA2
 [F:EVT0]USRFLDA3   = [F:LEA]USRFLDA3
 [F:EVT0]USRFLDA4   = [F:LEA]USRFLDA4
 [F:EVT0]USRFLDA5   = [F:LEA]USRFLDA5
 [F:EVT0]USRFLDA6   = [F:LEA]USRFLDA6
 [F:EVT0]USRFLDA7   = [F:LEA]USRFLDA7
 [F:EVT0]USRFLDA8   = [F:LEA]USRFLDA8
 [F:EVT0]USRFLDA9   = [F:LEA]USRFLDA9
 [F:EVT0]USRFLDA10  = [F:LEA]USRFLDA10
 #--> Dates
 [F:EVT0]USRFLDD1   = [F:LEA]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:LEA]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:LEA]USRFLDD3
 [F:EVT0]USRFLDD4   = [F:LEA]USRFLDD4
Return

$ECLATE_NBFLD
 LNBFLD=-6
Return

$ECLATE_STATUS
Return

$INFO_EVTINT
 EVT = "LEACNL"
 LPLN= 6
Return

