#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe PJMSOLITMH
#######################################################################################
# PJMSOLITMDH OPERATIONS                                                              #
#######################################################################################
$DOC_DELINK
# Issue 7539/119856 - 2016-11-18 by TEJAC : Sales Document Delinking
#Value Char PSONUM ()
#Value Shortint DOCTYP
#Value Char SALDOCNUM ()
#Local Integer ARET_VALUE

Local Char SPSONUM(GLONPSO)

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  SPSONUM = fmet this.GET_PSONUM_FROM_SALE_DOC(DOCTYP, SALDOCNUM)
  If SPSONUM <> AVOID.ACHAR Then
    [L]ARET_VALUE = fmet this.AREAD(SPSONUM)
    # ------------------------------------
    If [L]ARET_VALUE < [V]CST_AERROR Then
      this.HDOCNUM = AVOID.ACHAR
      For NI = 1 To maxtab(this.SPLD)      # Remove the DOCNUM update lines
        If this.SPLD(NI) <> null and find(this.SPLD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.SPLD(NI).DOCNUM <> AVOID.ACHAR Then
            this.SPLD(NI).DOCNUM = AVOID.ACHAR
          Endif
        Endif
      Next NI
      # ------------------------------------
      [L]ARET_VALUE = fmet this.AUPDATE()
      # ------------------------------------
    Endif
  Endif
Return

