#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("EIN",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
GPE = 0
GPV = 0
If MPSPE 
 Gosub ACTION From =MPROGSPE
Endif
If !GPV & MPSPV & MPROGSPV<>""
 Gosub ACTION From =MPROGSPV
Endif
If !GPE & MPROGSUB<>""
 Gosub ACTION From =MPROGSUB
Endif
Return

##############################################################################

$DEFVAR
Local Char    MACTION(20), MPROGSUB(GLONADC), MPROGSPE(GLONADC), MPROGSPV(GLONADC)
Local Integer MPSPE , MPSPV
If dim([L]SYMBOLE)<0 : Local Char SYMBOLE(50) : Endif
If dim([L]ACTION)<0  : Local Char ACTION(20)  : Endif
If dim([L]OK)<0      : Local Integer OK       : Endif
If dim([L]VERROU)<0  : Local Integer VERROU   : Endif
If dim([L]MLOCK)<0   : Local Integer MLOCK    : MLOCK=1 : Endif
If dim([L]AIMGLCK)<0 : Local Integer AIMGLCK  : Endif

If find(GPROGRAMME,"GOBJET","GOBJSUB") or GIMPORT
 If dim([L]PROGSUB)>0 : MPROGSUB=PROGSUB : Endif
 If dim([L]PROGSPE)>0 : MPSPE=PSPE : MPROGSPE=PROGSPE : Endif
 If dim([L]PROGSPV)>0 : MPSPV=PSPV : MPROGSPV=PROGSPV : Endif
Endif
Return

$SETPROG
If MACTION<>""
 Call PROGSYM(MACTION,MPROGSUB,MPROGSPE,MPROGSPV)
Endif
MPSPE = 0
If MPROGSPE<>""
 Call EXISTE_ADX("","",MPROGSPE,MPSPE) From ORDSYS
Endif
MPSPV = 0
If MPROGSPV<>""
 Call EXISTE_ADX("","",MPROGSPV,MPSPV) From ORDSYS
Endif
Return

##############################################################################

$VERROU
OK=1
If VERROU : Return : Endif

GLOCK=""
If left$(SYMBOLE,1)="\"
 MACTION=ACTION : ACTION="VERROU" : Gosub ACTION : ACTION=MACTION
Else
 Lock =SYMBOLE With lockwait=0
 If fstat
  OK=0 : GLOCK="%"+SYMBOLE
 Else
  MACTION=ACTION : ACTION="VERROU" : Gosub ACTION : ACTION=MACTION
  If !OK : Unlock =SYMBOLE : Endif
 Endif
Endif

If !OK
 If GIMPORT
  GMESSAGE="" 
 ELSE
  If GMESSAGE="" 
   GMESSAGE=mess(10,100,1) : #  Modification en cours sur un autre poste
  Endif
  If left$(GLOCK,1)="%" & GLOCK<>"%"+SYMBOLE
   GMESSAGE+="\("+mess(20,100,1)-mess(56,100,1)+" |"+right$(GLOCK,2)+"|)"
  Endif
 Endif
Else
 VERROU=1
Endif
Return

##############################################################################

$DEVERROU
If !(dim([L]MLOCK)>0 & [L]MLOCK) | !VERROU : Return : Endif
Goto S_DEVERROU

$DEVERROU2
If !VERROU : Return : Endif
Goto S_DEVERROU

$S_DEVERROU
If left$(SYMBOLE,1)<>"\"
 Unlock =SYMBOLE
Endif
MACTION=ACTION : ACTION="DEVERROU" : Gosub ACTION : ACTION=MACTION
VERROU=0
If find(GPROGRAMME,"GOBJET","GOBJSUB")
 Call SET_IMAGE(11) From GESECRAN
Endif
Return

##############################################################################

$SYMBOLE
Call DEBTRANS From GLOCK
Repeat
 OK=1 : GLOCK=""
 If left$(SYMBOLE,1)="\"
  MACTION=ACTION : ACTION="VERROU" : Gosub ACTION : ACTION=MACTION
 Else
  Lock =SYMBOLE
  If fstat
   OK=0 : GLOCK="%"+SYMBOLE
  Else
   OK=1
   MACTION=ACTION : ACTION="VERROU" : Gosub ACTION : ACTION=MACTION
   If !OK : Unlock =SYMBOLE : Endif
  Endif
 Endif
 If !OK : GOK=-1 : Call ROLL From GLOCK
 Else VERROU=1 : GOK=1 : # pour faire le DEVERROU après
 Endif
Until OK | GROLL 
Return

##############################################################################

Subprog PROGSYM(ACTION,PROGSUB,PROGSPE,PROGSPV)
Value    Char ACTION()
Variable Char PROGSUB(), PROGSPE(), PROGSPV()

If !clalev([F:ACT]) : Local File ACTION [ACT] : Endif
Read [ACT]ACTION = [L]ACTION
If fstat : End : Endif
[L]PROGSUB=[F:ACT]CODTRT
If left$([L]PROGSUB,3)="SUB"
 [L]PROGSPE="SPE"+right$([L]PROGSUB,4)
Else
 Call NOMSPEWIN([F:ACT]PARAM2,[L]PROGSPE)  From MSKDIV
Endif
PROGSPV = ""
End
