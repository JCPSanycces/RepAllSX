#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# TRTPJT_SYR
# Issue X3-3287/121366 - 2017-02-06 by FGR : comment
##########################################################################################################
Funprog CONTROL(AINSTANCE, APRONAME, AVALUE, STECPJT)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     STECPJT

Local Integer IARENDRE
Local Integer FROMSQHSOH
Local Integer FROMSIH
Local Char SPJT(GLONPJT)
Local Integer ICONTROLE   # =[V]CST_ANO : SPJT inexistant => considéré comme zone texte, on ne s'en occupe pas.
                          # =[V]CST_AYES : SPJT inexistant => erreur bloquante.
                          # Par contre tous les deux cas, s'il existe, il doit respecter les règles
Local Integer ICTLOPPCOD
Local Integer IRET
Local Instance TECPJT Using C_TECPJT
Local Char SCPY(GLONCPY)  # Issue X3-49144 - 2017-07-18 by FGR
Local Char SMETHOD(250)   # Issue X3-49098 - 2017-07-26 by FGR

  IARENDRE = [V]CST_AOK
  # -----------------------------------
  # Check if parameters are true ? This is to trap bug in parameters, not functionnal level
  If STECPJT = AVOID.ACHAR Then
    If evalue("dim([L]AINSTANCE.TECPJT)") < 0 Then
      IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, mess(1196,196,1) - "(a1)", [V]CST_AFATAL)
      End IARENDRE
    Endif
    TECPJT = evalue("[L]AINSTANCE.TECPJT")
  Else
    # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
    #If evalue("dim([L]AINSTANCE." + STECPJT + ")") < 0 Then
    #  IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, mess(1196,196,1) - "(a2)", [V]CST_AFATAL)
    #  End IARENDRE
    #Endif
    #TECPJT = evalue("[L]AINSTANCE." + STECPJT)
    Raz SMETHOD
    If left$(STECPJT,1) = "#" Then
      SMETHOD = seg$(STECPJT, 2, len(STECPJT))
      TECPJT = NewInstance C_TECPJT AllocGroup null
      IRET = evalue("fmet [L]AINSTANCE." + SMETHOD + "(TECPJT)")
      If IRET >= [V]CST_AERROR Then
        IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, mess(1196,196,1) - "(a3)", [V]CST_AFATAL)
        FreeGroup TECPJT
        End IARENDRE
      Endif
    Else
      If evalue("dim([L]AINSTANCE." + STECPJT + ")") < 0 Then
        IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, mess(1196,196,1) - "(a2)", [V]CST_AFATAL)
        End IARENDRE
      Endif
      TECPJT = evalue("[L]AINSTANCE." + STECPJT)
    Endif
    # Issue X3-49098 - 2017-07-26 by FGR : END
  Endif
  If TECPJT = null Then
    IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, mess(1196,196,1) - "(b)", [V]CST_AFATAL)
    End IARENDRE
  Endif
  If [L]TECPJT.SCOLLECTION <> AVOID.ACHAR Then
    If evalue("dim([L]AINSTANCE." + [L]TECPJT.SCOLLECTION + ")") < 0 Then
      IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, func AFNC.MES1(mess(1193,196,1), [L]TECPJT.SCOLLECTION), [V]CST_AFATAL)
      # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
      If SMETHOD <> AVOID.ACHAR Then
        FreeGroup TECPJT
      Endif
      # Issue X3-49098 - 2017-07-26 by FGR : END
      End IARENDRE
    Endif
    If evalue("dim([L]AINSTANCE." + [L]TECPJT.SCOLLECTION + "." + [L]TECPJT.SPJTFLDD + ")") < 0 Then
      IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, func AFNC.MES2(mess(1194,196,1), [L]TECPJT.SPJTFLDD, [L]TECPJT.SCOLLECTION), [V]CST_AFATAL)
      # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
      If SMETHOD <> AVOID.ACHAR Then
        FreeGroup TECPJT
      Endif
      # Issue X3-49098 - 2017-07-26 by FGR : END
      End IARENDRE
    Endif
  Elsif [L]TECPJT.SPJTFLDH <> AVOID.ACHAR Then
    If evalue("dim([L]AINSTANCE.APARENT." + [L]TECPJT.SPJTFLDH + ")") < 0 Then
      IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, func AFNC.MES1(mess(1195,196,1), [L]TECPJT.SPJTFLDH), [V]CST_AFATAL)
      # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
      If SMETHOD <> AVOID.ACHAR Then
        FreeGroup TECPJT
      Endif
      # Issue X3-49098 - 2017-07-26 by FGR : END
      End IARENDRE
    Endif
  Endif
  # -----------------------------------
  Gosub OPEN_TABLE
  Gosub TRT_PJM_INACTIVE
  # -----------------------------------
  SCPY = [L]TECPJT.SSOCIETE  # Issue X3-49144 - 2017-07-18 by FGR : we are in CONTROL. Can't update a property of the class
  If SCPY = AVOID.ACHAR and [L]TECPJT.SSITE = AVOID.ACHAR Then
    IRET = fmet AINSTANCE.ASETERROR(APRONAME, mess(1192,196,1), [V]CST_AERROR)
    IARENDRE = max(IARENDRE, IRET)
  Elsif SCPY = AVOID.ACHAR and [L]TECPJT.SSITE <> AVOID.ACHAR Then
    SCPY = func GET_CPY_FROM_FCY(AINSTANCE.ACTX, [L]TECPJT.SSITE)
  Elsif SCPY <> AVOID.ACHAR and [L]TECPJT.SSITE <> AVOID.ACHAR Then
    # Contrôle que le site est sur la bonne société
    If SCPY <> func GET_CPY_FROM_FCY(AINSTANCE.ACTX, [L]TECPJT.SSITE) Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, func AFNC.MES2(mess(1191,196,1), [L]TECPJT.SSITE, SCPY), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Endif
  Endif
  # -----------------------------------
  If IARENDRE <= [V]CST_AWARNING Then
    If [L]AVALUE = AVOID.ACHAR Then
      # Si on est en détail et que PJTSNGDOC=[V]CST_AYES, ZONDET doit être égal à ZONHEAD
      If [L]TECPJT.SCOLLECTION = AVOID.ACHAR and [L]TECPJT.SPJTFLDH <> AVOID.ACHAR Then
        If func GET_PARAM_SOC_PJTSNGDOC(AINSTANCE.ACTX, SCPY) = [V]CST_AYES Then
          If evalue("dim([L]AINSTANCE.APARENT." + [L]TECPJT.SPJTFLDH + ")") >= 0 and evalue("[L]AINSTANCE.APARENT." + [L]TECPJT.SPJTFLDH) <> AVOID.ACHAR Then
            IRET = fmet AINSTANCE.ASETERROR(APRONAME, mess(1047,196,1), [V]CST_AERROR)
            IARENDRE = max(IARENDRE, IRET)
          Endif
        Endif
      Endif
      # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
      If SMETHOD <> AVOID.ACHAR Then
        FreeGroup TECPJT
      Endif
      # Issue X3-49098 - 2017-07-26 by FGR : END
      End IARENDRE           # Dans tous les cas pas la peine de faire la suite puisque AVALUE est vide
    Endif
  Endif
  # -----------------------------------
  SPJT = [L]AVALUE
  # -----------------------------------
  # Si on est en détail et que PJTSNGDOC=[V]CST_AYES, ZONDET doit être égal à ZONHEAD (dans tous les cas)
  If [L]TECPJT.SCOLLECTION = AVOID.ACHAR and [L]TECPJT.SPJTFLDH <> AVOID.ACHAR Then
    If func GET_PARAM_SOC_PJTSNGDOC(AINSTANCE.ACTX, SCPY) = [V]CST_AYES Then
      If evalue("dim([L]AINSTANCE.APARENT." + [L]TECPJT.SPJTFLDH + ")") >= 0 >= 0 Then
        If evalue("[L]AINSTANCE.APARENT." + [L]TECPJT.SPJTFLDH) <> SPJT Then
          IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, mess(1047,196,1) - ": '" + SPJT + "' <> '" + evalue(evalue("[L]AINSTANCE.APARENT." + [L]TECPJT.SPJTFLDH)) + "'", [V]CST_AERROR)
          # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
          If SMETHOD <> AVOID.ACHAR Then
            FreeGroup TECPJT
          Endif
          # Issue X3-49098 - 2017-07-26 by FGR : END
          End IARENDRE
        Endif
      Endif
    Endif
  Endif
  # -----------------------------------
  ICONTROLE = [V]CST_ANO
  ICTLOPPCOD = fmet [L]AINSTANCE.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, AINSTANCE.ACTX.AFOLDER, "CTLOPPCOD")
  If [L]TECPJT.IMODULE = 12 or [L]TECPJT.IMODULE = 13 Then
    # Support client ou Action commerciale
    ICONTROLE = [V]CST_AYES  # Toujours bloquant
  Elsif [L]TECPJT.IMODULE = 5 Then
    # Ventes
    If ICTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif [L]TECPJT.IMODULE = 6 Then
    # Achats
    If ICTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif [L]TECPJT.IMODULE = 7 Then
    # Stock
    If ICTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif [L]TECPJT.IMODULE = 8 Then
    # GPAO
    If ICTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif [L]TECPJT.IMODULE = 9 Then
    # Tronc commun
    If ICTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif [L]TECPJT.IMODULE = 2 Then
    # Comptabilité
    If ICTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Elsif [L]TECPJT.IMODULE = 3 Then
    # Compta tiers
    If ICTLOPPCOD = [V]CST_AYES Then
      ICONTROLE = [V]CST_AYES  # controle bloquant
    Endif
  Else
    # Ailleurs pour le moment on ne controle pas
    ICONTROLE = [V]CST_ANO
  Endif
  # -----------------------------------
  If func ASYRFNC.ACTIV("PJM") Then
    # Issue X3-54290 - 2017-10-04 by FGR : BEGIN
    #    Link [PIM] With [F:PIMI]PIMI0~=[F:PIM]PIMNUM
    #&                As [PIMX]
    #&              Order By Key KEY1=[F:PIM]PIMNUM
    Link [PIM] With [F:PIMI]PIMI0=[F:PIM]PIMNUM
&                As [PIMX]
&              Order By Key KEY1=[F:PIM]PIMNUM
    Read [PIMX]KEY1=SPJT
    If [F:PIMI]PIMNUM = AVOID.ACHAR Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
      End IARENDRE
    Endif
    # Issue X3-54290 - 2017-10-04 by FGR : END
  Else
    Read [PIM]PIM0=SPJT
  Endif
  # -----------------------------------
  If fstat Then
    If ICONTROLE = [V]CST_AYES Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1189,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Endif
  Else
    # -----------------------------------
    # Par contre à partir du moment où il existe, il doit respecter les règles.
    # -----------------------------------
    # 1°) Test si le type de [F:PIM] fait parti de ce qui est demandé
    If [L]TECPJT.IBOOCRM = [V]CST_ANO and [F:PIM]PIMTYP = 1 Then
      IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Elsif [L]TECPJT.IBOOPJM = [V]CST_ANO and [F:PIM]PIMTYP = 2 Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Elsif [L]TECPJT.IBOOCRM = [V]CST_ANO and [L]TECPJT.IBOOPJM = [V]CST_ANO and [F:PIM]PIMTYP = 3 Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Elsif [L]TECPJT.IBOOPJMBUD = [V]CST_ANO and [F:PIM]PIMTYP = 4 Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Elsif [L]TECPJT.IBOOPJMTAC5 = [V]CST_ANO and [F:PIM]PIMTYP = 5 Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Elsif [L]TECPJT.IBOOPJMTAC6 = [V]CST_ANO and [F:PIM]PIMTYP = 6 Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Elsif [L]TECPJT.IBOOPJMTAC7 = [V]CST_ANO and [F:PIM]PIMTYP = 7 Then
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Elsif [F:PIM]PIMTYP = 8 Then
      # Issue X3-54290 - 2017-08-31 by FGR
      IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1023,196,1), [V]CST_AERROR)
      IARENDRE = max(IARENDRE, IRET)
    Endif
    # -----------------------------------
    # 2°) Test si ce qui est inactif est autorisé
    If [F:PIM]PIMSTA = [V]CST_ANO Then
      If ([F:PIM]PIMTYP = 2 or [F:PIM]PIMTYP = 3) and
&       (([L]TECPJT.IUSEDISPJM = [V]CST_ANO) or
&        ([L]TECPJT.IUSEDISPJM = [V]CST_AYES and
&          (FROMSQHSOH = [V]CST_AYES and ([F:PIM]OPPSTATE = 4 or [F:PIM]OPPSTATE = 9)) or
&          (FROMSIH = [V]CST_AYES and ([F:PIM]OPPSTATE <> 4))
&       ))
&     Then
        IARENDRE = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1026,196,1), [V]CST_AERROR)
      Elsif [F:PIM]PIMTYP = 4 and
&       (([L]TECPJT.IUSEDISPJM = [V]CST_ANO) or
&        ([L]TECPJT.IUSEDISPJM = [V]CST_AYES and
&          (FROMSQHSOH = [V]CST_AYES and ([F:PIM]PBUSTATE = 4 or [F:PIM]PBUSTATE = 9 or [F:PIM]OPPSTATE = 4)) or
&          (FROMSIH = [V]CST_AYES and ([F:PIM]PBUSTATE <> 4 or [F:PIM]OPPSTATE = 4))
&       ))
&     Then
        IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1027,196,1), [V]CST_AERROR)
        IARENDRE = max(IARENDRE, IRET)
      Elsif ([F:PIM]PIMTYP = 5 or [F:PIM]PIMTYP = 6 or [F:PIM]PIMTYP = 7) and
&       (([L]TECPJT.IUSEDISTAC = [V]CST_ANO) or
&        ([L]TECPJT.IUSEDISTAC = [V]CST_AYES and
&          (FROMSQHSOH = [V]CST_AYES and ([F:PIM]TASSTATE = 4 or [F:PIM]TASSTATE = 9 or [F:PIM]OPPSTATE = 4)) or
&          (FROMSIH = [V]CST_AYES and ([F:PIM]TASSTATE <> 4 or [F:PIM]OPPSTATE = 4))
&       ))
&     Then
        IRET = fmet AINSTANCE.ASETERROR(APRONAME, SPJT - ":" - mess(1028,196,1), [V]CST_AERROR)
        IARENDRE = max(IARENDRE, IRET)
      Endif
    Endif
    # -----------------------------------
    # 4°) Test si la société est compatible avec celle passée
    If SCPY <> AVOID.ACHAR Then
      If [F:PIM]CPY <> SCPY Then
        Case [F:PIM]PIMTYP
          When 1,2,3
            IRET = fmet AINSTANCE.ASETERROR(APRONAME, SCPY - ":" - mess(1078,196,1), [V]CST_AERROR)
            IARENDRE = max(IARENDRE, IRET)
          When 4
            IRET = fmet AINSTANCE.ASETERROR(APRONAME, SCPY - ":" - mess(1079,196,1), [V]CST_AERROR)
            IARENDRE = max(IARENDRE, IRET)
          When Default
            IRET = fmet AINSTANCE.ASETERROR(APRONAME, SCPY - ":" - mess(1080,196,1), [V]CST_AERROR)
            IARENDRE = max(IARENDRE, IRET)
        Endcase
      Endif
    Endif
    # -----------------------------------
    # 5°) Test de la compatibilité avec le tiers
    If [L]TECPJT.SBPR <> "" Then
      Read [BPR]BPR0=[L]TECPJT.SBPR
      If [F:BPR]BETFCY <> [V]CST_AYES Then
        # Control a ne pas faire si c'est un client intersite (mail CH 12/04/2016)
        Read [OPP]OPP0=[F:PIM]OPPNUM
        If !fstat Then
          Read [F:BPC]BPC0=[L]TECPJT.SBPR                                                                              # Issue X3-53308 - 2017-08-24 by FGR
          #If [F:OPP]OPPCMP <> AVOID.ACHAR and [F:OPP]OPPCMP <> [L]TECPJT.SBPR Then                                    # Issue X3-53308 - 2017-08-24 by FGR
          If [F:OPP]OPPCMP <> AVOID.ACHAR and [F:OPP]OPPCMP <> [L]TECPJT.SBPR and [F:OPP]OPPCMP <> [F:BPC]BPCGRU Then  # Issue X3-53308 - 2017-08-24 by FGR
            Case [F:PIM]PIMTYP
              When 1,2,3
                IRET = fmet AINSTANCE.ASETERROR(APRONAME, [L]TECPJT.SBPR - ":" - mess(1038,196,1), [V]CST_AERROR)
                IARENDRE = max(IARENDRE, IRET)
              When 4
                IRET = fmet AINSTANCE.ASETERROR(APRONAME, [L]TECPJT.SBPR - ":" - mess(1039,196,1), [V]CST_AERROR)
                IARENDRE = max(IARENDRE, IRET)
              When Default
                IRET = fmet AINSTANCE.ASETERROR(APRONAME, [L]TECPJT.SBPR - ":" - mess(1040,196,1), [V]CST_AERROR)
                IARENDRE = max(IARENDRE, IRET)
            Endcase
          Endif
        Endif
      Endif
    Endif
    # -----------------------------------
    # 6°)
    If [L]TECPJT.IMODULE = 6 or [L]TECPJT.IMODULE = 7 Then
      # Modules "Achats" ou "Stocks"
      If [F:PIM]PIMTYP = 1 Then
        # Si l'affaire n'est pas gagnée on n'a pas le droit de la prendre
        Read [OPP]OPP0=[F:PIM]OPPNUM
        Read [OPPCRM]OPPCRM0=[F:PIM]OPPNUM
        If [F:OPPCRM]OPPSTEADI = 421 Then
          # Si la table des "étapes en cours" est la 421, c'est qu'on est déjà en après-vente.
          # Donc tout va bien on peut prendre l'affaire
        Elsif [F:OPPCRM]OPPSTEADI = 400 Then
          # Si la table des "étapes en cours" est la 420, c'est pas sur qu'on est en après-vente.
          If [F:OPPCRM]OPPSTE <> AVOID.ACHAR Then
            # Si l'étape en cours à le statut N2:"5-Affaire gagnée" on peut prendre l'affaire
            Read [ADI]CODE=[F:OPPCRM]OPPSTEADI;[F:OPPCRM]OPPSTE
            If !fstat Then
              If [F:ADI]N2 <> 5 and [F:ADI]N2 <> 0 Then
                If MODULE = 6 Then
                  IRET = fmet AINSTANCE.ASETERROR(APRONAME, mess(1075,196,1) - "'" + mess([F:ADI]N2,2973,1) + "'" - mess(1076,196,1), [V]CST_AERROR)
                  IARENDRE = max(IARENDRE, IRET)
                Else
                  IRET = fmet AINSTANCE.ASETERROR(APRONAME, mess(1075,196,1) - "'" + mess([F:ADI]N2,2973,1) + "'" - mess(1077,196,1), [V]CST_AERROR)
                  IARENDRE = max(IARENDRE, IRET)
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  # -----------------------------------
  # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
  If SMETHOD <> AVOID.ACHAR Then
    FreeGroup TECPJT
  Endif
  # Issue X3-49098 - 2017-07-26 by FGR : END
  # -----------------------------------
End IARENDRE
#
####################################################################################################
Funprog PROPAGATE(AINSTANCE, APRONAME, AVALUE, STECPJT)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Value    Char     STECPJT

Local Integer IARENDRE
Local Char SANSWER(250)
Local Integer IANSWER
Local Instance TECPJT Using C_TECPJT
Local Char SMETHOD(250)   # Issue X3-49098 - 2017-07-26 by FGR

  # -----------------------------------
  # TCHSNGDOCANS values : 1 : No
  #                       2 : Yes
  #                       3 : Yes if same value
  # -----------------------------------
  IARENDRE = [V]CST_AOK
  # -----------------------------------
  If STECPJT = AVOID.ACHAR Then
    TECPJT = evalue("[L]AINSTANCE.TECPJT")
  Else
    # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
    #TECPJT = evalue("[L]AINSTANCE." + STECPJT)
    Raz SMETHOD
    If left$(STECPJT,1) = "#" Then
      SMETHOD = seg$(STECPJT, 2, len(STECPJT))
      TECPJT = NewInstance C_TECPJT AllocGroup null
      IRET = evalue("fmet [L]AINSTANCE." + SMETHOD + "(TECPJT)")
    Else
      TECPJT = evalue("[L]AINSTANCE." + STECPJT)
    Endif
    # Issue X3-49098 - 2017-07-26 by FGR : END
  Endif
  # -----------------------------------
  If [L]TECPJT.SSOCIETE = AVOID.ACHAR Then
    [L]TECPJT.SSOCIETE = func GET_CPY_FROM_FCY(AINSTANCE.ACTX, [L]TECPJT.SSITE)          # Issue X3-50134 - 2017-07-25 by FGR : not "SITE"
  Endif
  # -----------------------------------
  If [L]TECPJT.SCOLLECTION <> AVOID.ACHAR Then
    If func GET_PARAM_SOC_PJTSNGDOC(AINSTANCE.ACTX, [L]TECPJT.SSOCIETE) = [V]CST_AYES Then
      IANSWER = 2
    Else
      If TECPJT.TCHSNGDOCANS <> 1 and TECPJT.TCHSNGDOCANS <> 2 and TECPJT.TCHSNGDOCANS <> 3 Then
        TECPJT.TCHSNGDOCANS = 2
      Endif
      IANSWER = TECPJT.TCHSNGDOCANS
    Endif
    If IANSWER = 2 Then
      IARENDRE = func EXEC_PJTREPEAT_YES(AINSTANCE, APRONAME, AVALUE, TECPJT)
    Elsif IANSWER = 3 Then
      IARENDRE = func EXEC_PJTREPEAT_YES_IF(AINSTANCE, APRONAME, AVALUE, TECPJT)
    Endif
  Endif
  # -----------------------------------
  # Issue X3-49098 - 2017-07-26 by FGR : BEGIN
  If SMETHOD <> AVOID.ACHAR Then
    FreeGroup TECPJT
  Endif
  # Issue X3-49098 - 2017-07-26 by FGR : END
  # -----------------------------------
End IARENDRE

####################################################################################################
####################################################################################################
Funprog EXEC_PJTREPEAT_YES(AINSTANCE, APRONAME, AVALUE, TECPJT)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Instance TECPJT Using C_TECPJT

Local Integer NI
Local Char SCOLLEC(250)
Local Char SCOLLECPRO(250)
Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  # -----------------------------------
  If [L]TECPJT.SCOLLECTION <> AVOID.ACHAR Then
    For NI = 1 To evalue("maxtab([L]AINSTANCE." + [L]TECPJT.SCOLLECTION + ")")
      SCOLLEC = "[L]AINSTANCE." + [L]TECPJT.SCOLLECTION + "(" + num$(NI) + ")"
      SCOLLECPRO = SCOLLEC + "." + [L]TECPJT.SPJTFLDD
      If evalue(SCOLLEC) <> null and find(evalue(SCOLLEC + ".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        Assign (SCOLLECPRO) With [L]AVALUE
      Endif
    Next NI
  Endif
  # -----------------------------------
End IARENDRE

####################################################################################################
Funprog EXEC_PJTREPEAT_YES_IF(AINSTANCE, APRONAME, AVALUE, TECPJT)
Variable Instance AINSTANCE Using OBJECT
Value    Char     APRONAME
Variable Char     AVALUE
Variable Instance TECPJT Using C_TECPJT

Local Integer NI
Local Char SCOLLEC(250)
Local Char SCOLLECPRO(250)
Local Char SFORMERAVALUE(250)
Local Integer IARENDRE

  IARENDRE = [V]CST_AOK
  # -----------------------------------
  SFORMERAVALUE = evalue("[L]AINSTANCE.snapshot." + APRONAME)
  If [L]TECPJT.SCOLLECTION <> AVOID.ACHAR Then
    For NI = 1 To evalue("maxtab([L]AINSTANCE." + [L]TECPJT.SCOLLECTION + ")")
      SCOLLEC = "[L]AINSTANCE." + [L]TECPJT.SCOLLECTION + "(" + num$(NI) + ")"
      SCOLLECPRO = SCOLLEC + "." + [L]TECPJT.SPJTFLDD
      If evalue(SCOLLEC) <> null and find(evalue(SCOLLEC + ".ASTALIN"),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If evalue(SCOLLECPRO) = SFORMERAVALUE Then
          Assign (SCOLLECPRO) With [L]AVALUE
        Endif
      Endif
    Next NI
  Endif
  # -----------------------------------
End IARENDRE

####################################################################################################
####################################################################################################
# COMMON TOOLS
####################################################################################################
$OPEN_TABLE
  Local File ATABDIV [ADI]
  Local File OPPOR [OPP]
  Local File OPPORCRM [OPPCRM]
  Local File PIMPL [PIM]
  Local File ATEXTRA [AXX]
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]          # Issue X3-53308 - 2017-08-24 by FGR
  #
  If func ASYRFNC.ACTIV("PJM") Then
    Local File PIMPLIMP [PIMI]
  Endif
Return

####################################################################################################
$TRT_PJM_INACTIVE
Local Integer IPJMAVAILABLE

  # Voir pour remplacer la lecture par l'accès à une classe an cache (Demande de modif SAM113867)
  IPJMAVAILABLE = func ASYRFNC.ACTIV("PJM")
  # -------------------
  If IPJMAVAILABLE = [V]CST_AFALSE Then
    # Si le code activité PJM n'est pas actif, faire comme si tous les paramètres relatifs à PJM étaient à NON ([V]CST_ANO)
    TECPJT.IBOOPJM     = [V]CST_ANO
    TECPJT.IBOOPJMBUD  = [V]CST_ANO
    TECPJT.IBOOPJMTAC5 = [V]CST_ANO
    TECPJT.IBOOPJMTAC6 = [V]CST_ANO
    TECPJT.IBOOPJMTAC7 = [V]CST_ANO
    TECPJT.IUSEDISPJM  = [V]CST_ANO
    TECPJT.IUSEDISBUD  = [V]CST_ANO
    TECPJT.IUSEDISTAC  = [V]CST_ANO
  Else
    FROMSQHSOH = [V]CST_ANO
    If (instr(0, TECPJT.SFROM, "SQH") > 0 or instr(0, TECPJT.SFROM, "SOH") > 0) Then
      FROMSQHSOH = [V]CST_AYES
      If TECPJT.IUSEDISPJM = [V]CST_ANO Then
        # Un devis où une commande peut être fait sur une affaire non active
        TECPJT.IUSEDISPJM = [V]CST_AYES
      Endif
      If TECPJT.IUSEDISBUD = [V]CST_ANO Then
        # Un devis où une commande peut être fait sur un budget non actif
        TECPJT.IUSEDISBUD = [V]CST_AYES
      Endif
      If TECPJT.IUSEDISTAC = [V]CST_ANO Then
        # Un devis où une commande peut être fait sur une tâche non active
        TECPJT.IUSEDISTAC = [V]CST_AYES
      Endif
    Endif
    FROMSIH = [V]CST_ANO
    If (instr(0, TECPJT.SFROM, "SIH") > 0) Then
      FROMSIH = [V]CST_AYES
      If TECPJT.IUSEDISPJM = [V]CST_AYES Then
        # ATTENTION : Une facture peut jamais être faite sur une affaire clôturée. Là c'est la fin
        TECPJT.IUSEDISPJM = [V]CST_ANO
      Endif
      If TECPJT.IUSEDISBUD = [V]CST_ANO Then
        TECPJT.IUSEDISBUD = [V]CST_AYES
      Endif
      If TECPJT.IUSEDISTAC = [V]CST_ANO Then
        TECPJT.IUSEDISTAC = [V]CST_AYES
      Endif
    Endif
  Endif
  If AINSTANCE.ACTX.AFOLD.AMODULE(13) = [V]CST_ANO Then
    # S'il n'y a pas le module "Action commerciale", il ne peut pas y avoir d'affaire CRM.
    # Je désactive les paramètres CRM.
    TECPJT.IBOOCRM = [V]CST_ANO
  Endif
  # -------------------
Return

####################################################################################################
Funprog GET_CPY_FROM_FCY(CTX, SITE)
Value Instance CTX Using C_WMACONTEXT
Value Char SITE

Local Char SARENDRE(GLONCPY)

  SARENDRE = fmet CTX.ACACHE.AFCY.AGETVALCHAR(SITE, "LEGCPY")
End SARENDRE

####################################################################################################
Funprog GET_PARAM_SOC_PJTSNGDOC(CTX, SCPY)
Value Instance CTX Using C_WMACONTEXT
Value Char SCPY

Local Integer IPJTSNGDOC
Local Char STRTMODULE(GLONADC)
Local Integer ITRTMODULE
Local Char PJTACTION(GLONDCO)

  IPJTSNGDOC = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, SCPY, "PJTSNGDOC")
  # ------------------------------------------------------------
  #If dim(GUPDPJTSNGDOC) >= 0 Then
  #  Call TRAITEMENT_MODULE(GUPDPJTSNGDOC, STRTMODULE, ITRTMODULE)
  #  If ITRTMODULE = [V]CST_AYES Then
  #    PJTACTION = "PJTSNGDOC"
  #    Gosub ACTION From =STRTMODULE
  #  Endif
  #Endif
  # ------------------------------------------------------------
  If IPJTSNGDOC <> [V]CST_AYES and IPJTSNGDOC <> [V]CST_ANO Then
    IPJTSNGDOC = [V]CST_AYES  # Par défaut, document mono-affaire.
  Endif
End IPJTSNGDOC

