#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 11 Mai       2015 13:53:02

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".ECCNREV" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".ECCNREV" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT=""
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub CCNREV
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$CCNREV
 #--> Désignation
 [F:EVT0]DES        = [F:CCN]CCNDES1
 #--> Menus locaux
 #--> Zones numériques
 [F:EVT0]USRFLDC1   = [F:CCN]USRFLDC1
 [F:EVT0]USRFLDC2   = [F:CCN]USRFLDC2
 [F:EVT0]USRFLDM1   = [F:CCN]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:CCN]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:CCN]USRFLDM3
 [F:EVT0]USRFLDM4   = [F:CCN]USRFLDM4
 [F:EVT0]USRFLDM5   = [F:CCN]USRFLDM5
 [F:EVT0]USRFLDM6   = [F:CCN]USRFLDM6
 #--> Zones alphanumériques
 [F:EVT0]ACCCOD     = [F:CCN]ACCCOD
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,G301CPT)
 [F:EVT0]REVREN     = G_REVREN
 [F:EVT0]USRFLDA1   = [F:CCN]USRFLDA1
 [F:EVT0]USRFLDA10  = [F:CCN]USRFLDA10
 [F:EVT0]USRFLDA2   = [F:CCN]USRFLDA2
 [F:EVT0]USRFLDA3   = [F:CCN]USRFLDA3
 [F:EVT0]USRFLDA4   = [F:CCN]USRFLDA4
 [F:EVT0]USRFLDA5   = [F:CCN]USRFLDA5
 [F:EVT0]USRFLDA6   = [F:CCN]USRFLDA6
 [F:EVT0]USRFLDA7   = [F:CCN]USRFLDA7
 [F:EVT0]USRFLDA8   = [F:CCN]USRFLDA8
 [F:EVT0]USRFLDA9   = [F:CCN]USRFLDA9
 #--> Dates
 [F:EVT0]ENDCCNDATN = G_ENDCCNDATN
 [F:EVT0]ENDCCNDATO = G_ENDCCNDATO
 [F:EVT0]USRFLDD1   = [F:CCN]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:CCN]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:CCN]USRFLDD3
 [F:EVT0]USRFLDD4   = [F:CCN]USRFLDD4
Return

$ECLATE_NBFLD
 LNBFLD=0
Return

$ECLATE_STATUS
Return

$INFO_EVTINT
 EVT = "CCNREV"
 LPLN= 16
Return

