#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################################
#                                                                                           #
# SUBS1H1 : TRAITEMENTS STANDARDS UTILISES DANS LES FACTURES DE VENTE                       #
#           STANDARD SCRIPTS USED IN SALES INVOICES                                         #
#                                                                                           #
#############################################################################################
#############################################################################################
#
# Etiquettes/sous-pro appelées par SUBSIH
# Labels/subprog called by SUBSIH
#
#
#  $AAPRES_NBLIG
#############################################################################################
# Issue X3-58977 - 20171220 by LD : PCU on stock transaction from credit memo incorrect

#############################################################################################
$AAPRES_NBLIG

Local Integer  WRETS, NOL
Local Shortint WRET
NOL = nolign-1
Raz WRET, WRETS

Raz GOUVSOR
# If GIMPORT Return Endif  : # bug 31504
# Si suppression ligne
If find(status,65,68,83)       Return Endif
# Si sortie tableau non validante
If adxgtb=1 | find(status,6,7) Return Endif

# Si facture directe avec maj stock
# ou facture de commande
# ou facture de livraison mais ligne sans no liv
# et article géré en stock
If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&  (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&   ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
   # Si ligne saisie mais non créée ou
   # ligne déjà créée et pièce avec validation non validée
   If [M]CREFLG(NOL)=0 | ([M]CREFLG(NOL)<>0 & [M]INVSTA<>3)
      # Alimentation de [M:ALP]
      Gosub ALI_ALP From SUBSIH
      # Détermination du stock à sortir (automatisme, saisie)
      Call OUVSOR("SIH4",NOL,[M:SIH4]NBLIG,[M:SIH4]WSTOSEQ(NOL),GSLTSTKFLG,WRETS)
&                 From STKSOR
      # Bug 53970 : Recalcul du prix de revient et de la marge (Ds le cas où valorisation au PMP du lot)
      Call CALCPFM("[M:SIH4]",[M:SIH4]DSTOFCY(NOL),[M:SIH1]PRITYP,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,[M:SIH2]CUR,NOL,2) From TRTVENPRI
      Affzo [M:SIH4]CPRPRI(NOL), PFM(NOL)
   Endif
Endif

# ----- #
# Avoir #
# ----- #
If   [M:SIH0]INVTYP=2
    If [M:SIH4]STOMGTCOD(NOL)=1 | [M:SIH4]RTNSTOUPD(NOL)=1 | [M:SIH1]STOMVTFLG=1 | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)<>"")
        Raz GOUVENT : Return
    Endif
    # Si avoir direct ou sur facture ou ligne directe d'un avoir sur retour
    # avec mouvement de stock et article géré en stock
    #---------------------------------------------------#
    # Appel sous-pro OUVENT pour déterminer l'ouverture #
    #       de la fenêtre détail SAISTOENT              #
    #---------------------------------------------------#
    Local Char     LSUP(1)
    If [F:ITM]ITMREF<>[M:SIH4]ITMREF(NOL) Read [ITM]ITM0=[M:SIH4]ITMREF(NOL)
                                          If fstat Raz [F:ITM] : Endif
                                          Endif
    If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=5;GFLAG
                            If fstat Raz [F:SLT] : Endif
                            Endif
    # Controle ouverture fenetre saisie des entrées
    # Pour cela aliment les variables GOUVENT et GOUVLOT
    # Grise les champs ne pouvant plus être modifiés (sous-pro STKDISLIG)
    # LSUP = Option : "O"=Même si WSTOFLG=0, garder ce qui se trouve déjà dans STOENTW (lignes liées à la liv)
#    If [M:SIH4]XSIHORINUM(NOL)<>"" LSUP="O" Endif

    # Issue X3-58977
    If [F:ITM]STOMGTCOD>1 & !find([M:SIH4]SAU(NOL),[F:ITM]STU,[F:ITM]PCU)
      [M:ENTW]WZONPCU = "STU"
      [M:ENTW]WZONQUC = "QTYSTU"
    Else
      [M:ENTW]WZONPCU = "SAU"
      [M:ENTW]WZONQUC = "QTY"
    Endif
    # End issue X3-58977

    Call OUVENT([M:SIH4]DSTOFCY(NOL),"SIH4",12,[M]TRSCOD,[M]BPCORD,18,
&               [M:SIH0]INVDAT,NOL,[M:SIH4]NBLIG,"SLT",LSUP,WRET) From STKENT


Endif

Return

