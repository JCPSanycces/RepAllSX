#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case GACTION
 When "ANUPLAN"
  Case ACTION
   When "CONTROLE" : Gosub CONTROLE
   When "EXEC"     : Gosub EXEC
   When "SORTIE"   : Gosub SORTIE
  Endcase
Endcase
Return

$CONTROLE
TMP = 1
Return

$EXEC
TRA = 1
Local Integer STAT
Call ANNULE(val(PARAM(1)),PARAM(2),STAT)
Return

$SORTIE
If STAT
 Local Char MESSA(80)
 Case val(PARAM(1))
  When 1 : MESSA = mess(32,10703,1) : # Suppression de la rubrique
  When 2 : MESSA = mess(33,10703,1) : # Suppression de la variable
  When 3 : MESSA = mess(34,10703,1) : # Suppression du cumul
 Endcase
 STAT = 1 : Call OUINON(MESSA-":"-PARAM(2),STAT) From GESECRAN
 If STAT=2 : STAT = 1 : Else : STAT = 0 : Endif
Else
 STAT = 1
Endif
PARAM(3) = num$(STAT)
Return

Subprog ANNULE(TYP,CODE,STAT)
Value    Integer TYP
Value    Char    CODE
Variable Integer STAT

Local File RUBRIQUE [RUB]
Local File CUMUL    [CUM]
Local Integer FLG
Local Char MESSA(80)
Case TYP
 When 1 : MESSA = mess(32,10703,1) : # Suppression de la rubrique
 When 2 : MESSA = mess(33,10703,1) : # Suppression de la variable
 When 3 : MESSA = mess(34,10703,1) : # Suppression du cumul
Endcase
Call OUVRE_TRACE(MESSA-":"-CODE) From LECFIC
For [RUB]RUB0 Where LEG=GCURLEG
 FLG = 0
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]CNDCAL,CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]BAS,CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]RAT1,CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]RAT2,CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]TBLFRM(0),CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]TBLFRM(1),CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]TBLFRM(2),CODE,FLG) : STAT += FLG : Endif
 For I=0 To [F:RUB]ITVNBR-1
  If !FLG : Call ANUCOD(TYP,1,[F:RUB]ITVAMT(I),CODE,FLG) : STAT += FLG : Endif
 Next I
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]AMTMAX(0),CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]AMTMAX(1),CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]AMTMAX(2),CODE,FLG) : STAT += FLG : Endif
 #52553
 If !FLG : Call ANUCOD(TYP,1,[F:RUB]DESPRN,CODE,FLG) : STAT += FLG : Endif
Next
For [CUM]CUM0 Where LEG=GCURLEG
 FLG = 0
 If !FLG : Call ANUCOD(TYP,2,[F:CUM]CUMINI,CODE,FLG) : STAT += FLG : Endif
 If !FLG : Call ANUCOD(TYP,2,[F:CUM]CUMREP,CODE,FLG) : STAT += FLG : Endif
Next
Call FERME_TRACE From LECFIC
End

Subprog ANUCOD(TYP1,TYP2,EXPR,CODE,FLG)
Value Integer    TYP1
Value Integer    TYP2
Value Char       EXPR
Value Char       CODE
Variable Integer FLG
Local Char    PFIX(5)
Local Integer K
Case TYP1
 When 1 : # Rubrique
  For PFIX="R","TA","TB","TC","EA","EB","EC"
   Gosub ANU_COD
   If FLG : Break : Endif
  Next PFIX
 When 2 : # Variable
  PFIX = "V"
  Gosub ANU_COD
 When 3 : # Cumul
  PFIX = "C"
  Gosub ANU_COD
Endcase
End

$ANU_COD
Local Char VTITLE(GLONAX3)
K = 0
Repeat
 K = instr(K+1,EXPR,PFIX+"_"+CODE)
 If K
  If K+len(PFIX)+len(CODE)+1>len(EXPR) or
&    !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789",mid$(EXPR,K+len(PFIX)+len(CODE)+1,1))
   FLG = 1
   Case TYP2
    When 1
      Call LECTEXTRA([L]VTITLE,"RUBRIQUE","DES",GCURLEG,[F:RUB]COD) From ATEXTRA
      Call ECR_TRACE(CODE-mess(35,10703,1)-[F:RUB]COD-[L]VTITLE,0) From GESECRAN : # utilisé par la rubrique
    When 2
      Call LECTEXTRA([L]VTITLE,"CUMUL","CUMDES",GCURLEG,[F:CUM]CUMCOD) From ATEXTRA
      Call ECR_TRACE(CODE-mess(36,10703,1)-[F:CUM]CUMCOD-[L]VTITLE,0) From GESECRAN : # utilisé par le cumul
   Endcase
  Endif
 Endif
Until K=0
Return

Subprog CHANGE(TYP,OCODE,NCODE)
Value Integer TYP
Value Char    OCODE
Value Char    NCODE

Local File RUBRIQUE [RUB]
Local File CUMUL    [CUM]
Local File SCREMPD  [HRSMD]

Local Integer I , FLGMOD
Call DEBTRANS From GLOCK
Gosub TR_CHANGE
End

$TR_CHANGE
GOK = 1
Trbegin [RUB] , [CUM] , [HRSMD]
 For [RUB]RUB0 Where LEG=GCURLEG
  FLGMOD = 0
  Readlock [RUB]RUB0 Curr
  If fstat=1
   GOK = -1 : GLOCK = "$RUBRIQUE"-[F:RUB]COD-[F:RUB]LEG : Break
  Elsif fstat
   GOK = 0 : Call RSTA("RUB",[F:RUB]COD) From GLOCK : Break
  Endif
  Call CHGCOD(TYP,[F:RUB]CNDCAL,OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]BAS,OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]RAT1,OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]RAT2,OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]TBLFRM(0),OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]TBLFRM(1),OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]TBLFRM(2),OCODE,NCODE,FLGMOD)
  For I=0 To [F:RUB]ITVNBR-1
   Call CHGCOD(TYP,[F:RUB]ITVAMT(I),OCODE,NCODE,FLGMOD)
  Next I
  Call CHGCOD(TYP,[F:RUB]AMTMAX(0),OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]AMTMAX(1),OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:RUB]AMTMAX(2),OCODE,NCODE,FLGMOD)
  #52553
  Call CHGCOD(TYP,[F:RUB]DESPRN,OCODE,NCODE,FLGMOD)
  If FLGMOD
   Rewrite [RUB]
   If fstat
    GOK = 0 : Call FSTA("RUB") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_CHANGE
 Elsif !GOK : Goto AB_CHANGE
 Endif
 For [CUM]CUM0 Where LEG=GCURLEG
  FLGMOD = 0
  Readlock [CUM]CUM0 Curr
  If fstat=1
   GOK = -1 : GLOCK = "$CUMUL"-[F:CUM]CUMCOD : Break
  Elsif fstat
   GOK = 0 : Call RSTA("CUM",[F:CUM]CUMCOD) From GLOCK : Break
  Endif
  Call CHGCOD(TYP,[F:CUM]CUMINI,OCODE,NCODE,FLGMOD)
  Call CHGCOD(TYP,[F:CUM]CUMREP,OCODE,NCODE,FLGMOD)
  If FLGMOD
   Rewrite [CUM]
   If fstat
    GOK = 0 : Call FSTA("CUM") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_CHANGE
 Elsif !GOK : Goto AB_CHANGE
 Endif
 For [HRSMD]SMD0 Where TYPFRM=2
  FLGMOD = 0
  Readlock [HRSMD]SMD0 Curr
  If fstat=1
   GOK = -1 : GLOCK = "$SCREMPD"-[F:HRSMD]COD : Break
  Elsif fstat
   GOK = 0 : Call RSTA("SMD",[F:HRSMD]COD) From GLOCK : Break
  Endif
  Call CHGCOD(TYP,[F:HRSMD]FRM,OCODE,NCODE,FLGMOD)
  If FLGMOD
   Rewrite [HRSMD]
   If fstat
    GOK = 0 : Call FSTA("HRSMD") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_CHANGE
 Elsif !GOK : Goto AB_CHANGE
 Endif
Commit
Return

Subprog CHGCOD(TYP,EXPR,OCODE,NCODE,FLGMOD)
Value    Integer TYP
Variable Char    EXPR()
Value    Char    OCODE
Value    Char    NCODE
Variable Integer FLGMOD
Local Integer K
Local Char    PFIX(5)
Case TYP
 When 1 : # Rubrique
  For PFIX="R","TA","TB","TC","EA","EB","EC"
   Gosub CHANGE_COD
  Next PFIX
 When 2 : # Variable
  PFIX = "V"
  Gosub CHANGE_COD
 When 3 : # Cumul
  PFIX = "C"
  Gosub CHANGE_COD
Endcase
End

$CHANGE_COD
K = 0
Repeat
 K = instr(K+1,EXPR,PFIX+"_"+OCODE)
 If K
  # 48718
  #If K+len(PFIX)+len(OCODE)+1>len(EXPR) or !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ_",mid$(EXPR,K+len(PFIX)+len(OCODE)+1,1))
  If K+len(PFIX)+len(OCODE)+1>len(EXPR) or !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789",mid$(EXPR,K+len(PFIX)+len(OCODE)+1,1))
   FLGMOD = 1
   EXPR   = left$(EXPR,K+len(PFIX))+NCODE+right$(EXPR,K+len(PFIX)+len(OCODE)+1)
  Endif
 Endif
Until K=0
Return

$AB_CHANGE
Rollback
Return

$ROLL_CHANGE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CHANGE : Endif
Return

