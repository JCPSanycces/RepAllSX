$GRISE
If [F:HRCTR]REFNUM<>[F:ID]REFNUM
 Read [ID]ID0=[F:HRCTR]REFNUM
 If fstat : Return : Endif
Endif

Call GRISE_CALPAY([F:ID]FLGINT) From SUBCTR2
Call GRISE_FLGPAY([F:ID]FLGPAY) From SUBCTR2
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("FPAY")
If func AFNC.ACTIV("FPAY") & func DIVPAYE.IS_KFR_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - ENDT
 Call GRISE_OPTION([M:CTR2]DED) From SUBCTR2
Endif
Call GRISE_ESSAI2([M]NEWTRY) From SUBCTR2
Call GRISE_TAUX_TP([M]TYPJOB,[M]DNACODMOD)
Call GRISE_AGENCE([M]TYPJOB) From SUBCTR2
Call GRISE_SORTIE([M]XITDAT) From SUBCTR2
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If GDOSLEG="FRA" Then
If func DIVPAYE.IS_KFR_LEG(GCURLEG) Then
#JOJAC - 2016-06-08 - REQ114309 US215 - END
  Call GRISE_CCPB([M]DNACCP)From SUBCTR2
Endif
Call GRISE_GRDCDD([M]NATCON) From SUBCTR
If GPAYE=1
 Call GRISE_ACOMPTE([M]INSAMT) From SUBCTR
 Call GRISE_EXO([M]EXOCOD1,[M]EXOCOD2,[M]EXOCOD3,[M]EXOCOD4) From SUBCTR
 Call GRISE_INFOS_ENVERS([M]TWDPAY) From SUBCTR2
Endif
Call GRISE_PRV([M]FLGPRV,1) From SUBCTR2
Call GRISE_PRV([M]FLGPRV2,2) From SUBCTR2
Call GRISE_PRV([M]FLGPRV3,3) From SUBCTR2
#V01X09
Call GRISE_PRV([M]FLGXITPRV,4) From SUBCTR2
If GPAYE
 Call GRISE_RAZCUM([M]XITGRD) From SUBCTR
Endif
Call GRISE_WRKADD([M]WRKFLGADD) From SUBCTR
If GPAYE : Gosub AFF_COL From SUBCTR2 : Endif
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If GDOSLEG="FRA" Then
If func DIVPAYE.IS_KFR_LEG(GCURLEG) Then
#JOJAC - 2016-06-08 - REQ114309 US215 - END
  Call GRISE_LNK ([M]LNK) From SUBCTR
Endif
Call GRISE_SEVCTR([M]SEVCTR) From SUBCTR
Call GRISE_FORFAIT([M]NBRDAYCTR,"NBRDAYCTR") From SUBCTR2
Call GRISE_FORFAIT([M]NBRHOUCTR,"NBRHOUCTR") From SUBCTR2

Call GRISE_COTMIDWRK([M]RATMIDWRK) From SUBCTR2 :#109334

# Manage the box 'Break payslip' (3 = Display only)
If GPAYE : Call UPD_FLGCREBUL([M]FLGCREBUL, 3) From SUBCTR2 : Endif

#JASMI - 2017-06-01 - START
If GPAYE
  Gosub AFF_COL
  Gosub DISP_TOTALS
Endif
#JASMI - 2017-06-01 - END

Return

########################################################
Subprog GRISE_PRV(VALEUR,NUM)
Value Integer VALEUR
Value Integer NUM
Local Char ZONE(10)
Case NUM
 When 1 : ZONE = "FLGPRV"
          Gosub SET_ZONE From SUBCTR
          If MA
           If VALEUR=2
            Actzo STRTIMNTC, ENDTIMNTC
           Else
            Effzo STRTIMNTC, ENDTIMNTC
            Grizo STRTIMNTC, ENDTIMNTC
           Endif
          Endif
 When 2 : ZONE = "FLGPRV2"
          Gosub SET_ZONE From SUBCTR
          If MA
           If VALEUR=2
            Actzo STRNTC2, ENDNTC2
           Else
            Effzo STRNTC2, ENDNTC2
            Grizo STRNTC2, ENDNTC2
           Endif
          Endif
 When 3 : ZONE = "FLGPRV3"
          Gosub SET_ZONE From SUBCTR
          If MA
           If VALEUR=2
            Actzo STRNTC3, ENDNTC3
           Else
            Effzo STRNTC3, ENDNTC3
            Grizo STRNTC3, ENDNTC3
           Endif
          Endif
 #V01X09
 When 4 : ZONE = "FLGXITPRV"
          Gosub SET_ZONE From SUBCTR
          If MA
           If VALEUR=2
            Actzo STRXITPRV, ENDXITPRV
           Else
            Effzo STRXITPRV, ENDXITPRV
            Grizo STRXITPRV, ENDXITPRV
           Endif
          Endif
Endcase
End

