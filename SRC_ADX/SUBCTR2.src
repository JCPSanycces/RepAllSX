If clalev([F:ID5])=0 : Local File EMPLOID [ID5] : Endif
VALEUR=""
ZONE = "MATREMP"
Gosub SET_ZONE From SUBCTR
If MA & [M]MATREMP<>""
 Read [ID5]ID0=[M]MATREMP
 If !fstat
  VALEUR = [F:ID5]NAM-[F:ID5]SRN
 Endif
Endif
End

