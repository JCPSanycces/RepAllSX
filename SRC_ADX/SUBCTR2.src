Subprog GRISE_TAUX_TP (VALEUR, VALEUR2)
Value Integer VALEUR    :#TYPJOB
Value Integer VALEUR2   :#DNACODMOD
Local Char ZONE(10) : ZONE = "RATMIDWRK"
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If GDOSLEG<>"FRA" Then End : Endif
If !func DIVPAYE.IS_KFR_LEG(GCURLEG) Then End : Endif
#JOJAC - 2016-06-08 - REQ114309 US215 - END
Gosub SET_ZONE From SUBCTR
If MA
  If VALEUR<>1 & VALEUR2<>1          :#Activation taux TP que si pas temps complet
  Actzo RATMIDWRK
 Else
  Effzo RATMIDWRK
  Grizo RATMIDWRK
 Endif
Endif
End

########################################################
Subprog GRISE_AGENCE (VALEUR)
Value Integer VALEUR
Local Char ZONE(10) : ZONE = "AGNMIDWRK"
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If GDOSLEG<>"FRA" Then End : Endif
Gosub SET_ZONE From SUBCTR
Actzo AGNMIDWRK
If !func DIVPAYE.IS_KFR_LEG(GCURLEG) Then End : Endif
#JOJAC - 2016-06-08 - REQ114309 US215 - END
#Gosub SET_ZONE From SUBCTR
If MA
 If VALEUR=3 :#interimaire
  Actzo AGNMIDWRK
 Else
  Effzo AGNMIDWRK,ZAGNMIDWRK
  Grizo AGNMIDWRK
 Endif
Endif
End

########################################################
Subprog GRISE_INFOS_ENVERS(VALEUR)
Value Integer VALEUR
Local Char ZONE(10) : ZONE = "OBJRUB"
Gosub SET_ZONE From SUBCTR
If MA
 If VALEUR=1
  Effzo OBJRUB,OBJVAR,INCVAR
  Grizo OBJRUB,OBJVAR,INCVAR
 Else
  Actzo OBJRUB,OBJVAR,INCVAR
 Endif
Endif
End

