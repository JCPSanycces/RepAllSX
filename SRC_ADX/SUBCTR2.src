Subprog VERIF_AML_EML(PFCY,PNUMCIV,DISPMSG,LPARAM,PNOLIB,PLEGI,PLEGC,OKPAR)
Value    Char    PFCY,LPARAM
Value    Integer PNUMCIV
Variable Integer PNOLIB,OKPAR
Variable Char    PLEGI,PLEGC
Value    Integer DISPMSG
Local    Char    NUMLIB(10)

  OKPAR=0
  Call PARAM(PFCY,LPARAM,NUMLIB) From ADOVAL
  If NUMLIB<>"0" Then
    PNOLIB=val(NUMLIB)

#   PNUMCIV= 0 modified PFCY
    If PNUMCIV <> 0 & mess(PNUMCIV,val(NUMLIB),1)="" Then
      If DISPMSG
        Call MESSAGE(func AFNC.MES1(mess(132,10701,1), LPARAM)) From GESECRAN : # Le menu local du paramŠtre <LPARAM> n'est pas correctement renseign‚
      Endif
    Else
      If mess(1,val(NUMLIB),1)="" Then
        If DISPMSG
           Call MESSAGE(func AFNC.MES1(mess(132,10701,1), LPARAM)) From GESECRAN : # Le menu local du paramŠtre <LPARAM> n'est pas correctement renseign‚
        Endif
      Else
       Call LECTURE("FCY",[F:ID]FCYORI,"") From CONTOBJ  : PLEGI = [F:FCY]LEG
       Call LECTURE("FCY",PFCY,"") From CONTOBJ          : PLEGC = [F:FCY]LEG
        OKPAR=1
      Endif
    Endif
  Else
    If DISPMSG
      Call MESSAGE(func AFNC.MES1(mess(130,10701,1), LPARAM)) From GESECRAN : # Le paramŠtre <LPARAM> n'est pas correctement renseign‚
    Endif
  Endif
End

#JOJAC - 2016-07-13 - REQ114309 - START
Subprog AM_JNTREFNUM(VALEUR)
Variable Char    VALEUR()
#JOJAC - 2016-07-12 - REQ114309 - START
If clalev([ECNT])=0 : Local File EMPLOCTR [ECNT] :Endif

  If VALEUR <>""
   Read[F:ECNT]ID0 = VALEUR
   If fstat=0
    [M]JNTNAM = [F:ECNT]NAM
    [M]JNTSRN = [F:ECNT]SRN
    [M]JNTDATBRN = [F:ECNT]DATBRN
    [M]JNTTEL = [F:ECNT]TEL

    If dim([M]NBRJNT)>0
      [M]SJNTREFNUM(0)=VALEUR
      [M]SJNTNAM(0) = [F:ECNT]NAM
      [M]SJNTSRN(0) = [F:ECNT]SRN
      [M]SJNTDATBRN(0) = [F:ECNT]DATBRN
      [M]SJNTTEL(0) = [F:ECNT]TEL
      If [M]NBRJNT = 0 : [M]NBRJNT =1 : Endif
    Endif

    Affzo [M]JNTNAM, JNTSRN, JNTDATBRN, JNTTEL

   Endif
  Endif

End
#JOJAC - 2016-07-12 - REQ114309 - END

Subprog GRISE_CONJOINT(VALEUR)
Value Integer VALEUR
Local Char ZONE(10) : ZONE = "JNTNAM"
Local Char DISPLAYIND(2)

Gosub SET_ZONE From SUBCTR
If MA
 # FQ81085 - 25/11/13 - On ne grise le conjoint que si on est leg FRA
   If VALEUR=1
    Effzo JNTNAM,JNTREFNUM,JNTTEL,JNTSRN,JNTDATBRN,JNTCRY,JNTCRYNAM
    Grizo JNTNAM,JNTREFNUM,JNTTEL,JNTSRN,JNTDATBRN,JNTCRY,JNTCRYNAM
    Call MRGDAT(VALEUR) From SUBCTR
    Call SPOMDNNAM(VALEUR) From SUBCTR
   Else
    Actzo JNTNAM,JNTREFNUM,JNTTEL,JNTSRN,JNTDATBRN,JNTCRY,JNTCRYNAM
    Call MRGDAT(VALEUR) From SUBCTR
    Call SPOMDNNAM(VALEUR) From SUBCTR
   Endif
#MASHI - 2017-05-22 - JIRA X3-39377 - START
   If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBCTRUKI") Then
     Call C_SITFAMA(VALEUR) From SUBCTRUKI
   Endif
#MASHI - 2017-05-22 - JIRA X3-39377 - END

Endif
End

Subprog C_JNTREFNUM(VALEUR)
Variable Char    VALEUR()
#JOJAC - 2016-07-07 - REQ114309 - START
Local File EMPLOID [JNT]
If VALEUR <>"" & VALEUR<>[M]JNTREFNUM
 Read[F:JNT]ID0 = VALEUR
 If fstat=0
  #[M]JNTNAM = [F:JNT]NAM-[F:JNT]SRN
  [M]JNTNAM = [F:JNT]NAM
  [M]JNTSRN = [F:JNT]SRN
  [M]JNTTEL = [F:JNT]TEL
  Affzo [M]JNTNAM, JNTTEL,JNTSRN
 Endif
Endif
#JOJAC - 2016-07-07 - REQ114309 - END
End

Subprog SPOMDNNAM(VALEUR)
Value Integer VALEUR
If func DIVPAYE.IS_KAO_LEG(GCURLEG)
    If VALEUR = 1
       Effzo [M:CTR4]SPOMDNNAM
       Grizo [M:CTR4]SPOMDNNAM
    Else
       Actzo [M:CTR4]SPOMDNNAM
    Endif
Endif

End

