#JASMI - 2016-06-02 - REQ 114309 - END
Local Char ZONE(10) : ZONE = "OPEDED"
Gosub SET_ZONE From SUBCTR
If MA
 If VALEUR<=0
  Effzo OPEDED
  Grizo OPEDED
  If dim([M]CATDED) > 0
   Effzo CATDED : Grizo CATDED
