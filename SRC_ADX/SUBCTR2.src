Filter [F:VEP] Where EMP = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CURCOD = [M:CTR1]CUR
If rowcount([F:VEP])>0
  Grizo [M:CTR1]CUR
Else
  Actzo [M:CTR1]CUR
Endif
Filter [F:VEP]


#PEVAN 2017-10-23 - X3-60602 - START
If !func AFNC.ACTIV("GLM")
  If dim([M:CTR12]CODLST)>0 : Chgfmt [M:CTR12]CODLST With '-LA:1' : Endif
  If dim([M:CTR12]STRDATLVE)>0 : Chgfmt [M:CTR12]STRDATLVE With '-LA:1' : Endif
  If dim([M:CTR12]ENDDATLVE)>0 : Chgfmt [M:CTR12]ENDDATLVE With '-LA:1' : Endif
