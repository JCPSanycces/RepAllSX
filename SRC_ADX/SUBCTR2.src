If evalue("dim([M:CTR6]NBRPOP)")>0
  L_NB_POPUL=[M:CTR6]NBRPOP
#Done once is enough
#Call CHARGE_POPUL([F:HRCTR]REFNUM,L_POPUL,L_NB_POPUL) From SUBCTR2
Call CHARGE_POPUL([F:HRCTR]REFNUM,[M:CTR6]POP,L_NB_POPUL,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:CTR6]MAJTYP) From SUBCTR
[M:CTR6]NBRPOP=L_NB_POPUL
Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
If GPAYE
 Gosub LOAD_RETROCTR From SUBCTRRET
Endif

If [M:CTR0]FLGVAR=2
 Diszo [M:CTR1]SUICAR
Else
 Actzo [M:CTR1]SUICAR
Endif
GRETTIP=0
GLASTCTR = 1

Filter [CTR1] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
Read [CTR1]CTR0 Last
Filter [CTR1]
If fstat<=2 & [F:CTR1]CTRDAT<>[F:HRCTR]CTRDAT
 GLASTCTR = 0
Endif

