$MAJ_TIMEMP
If [M:CTR0]FLGVAR=2 : Return : Endif

For [TIP]TIP2 Where REFNUM=[F:CTR1]REFNUM & CTRNUM=[F:CTR1]CTRNUM & STRDAT>=[F:CTR1]CTRDAT
 [F:TIP]FCY=[F:CTR1]ETRFCY
 [F:TIP]SRV=[F:CTR1]ETRSRV
 [F:TIP]CPY=func DIVPAYE.GETSOC([F:CTR1]ETRFCY)
 Rewrite [F:TIP]
 If fstat
  GOK=0 : Call FSTA("TIP") From GLOCK : Break
 Endif
Next
GRETTIP=0
Return

# Si on change de société dans le contrat, on doit vérifier que les axes des temps existants sont toujours suivis par
# la nouvelle société :
#   - Récupération du modèle de la nouvelle société
#   - Si les modèles sont différents, il faut descendre au niveau des plans et axes
#   - On regarde si les axes de l'ancienne société font partie des axes de la nouvelle
#   - Si les axes sont différents, on recalcule les répartitions, les axes, et les sections
$MAJ_ANA
Local Integer NBPLAN_OLD,NBAXE_OLD,NBPLAN_NEW,NBAXE_NEW,MAXAXE
MAXAXE=max(GOPTCANA,1)
Local Integer REFTYP_OLD(1..MAXAXE), REFTYP_NEW(1..MAXAXE)
Local Integer OBLIG_OLD(1..MAXAXE), OBLIG_NEW(1..MAXAXE)
Local Char    LSTPLAN_OLD(GLONCOA)(1..MAXAXE), LSTPLAN_NEW(GLONCOA)(1..MAXAXE)
Local Char    LSTAXE_OLD(GLONDIE)(1..MAXAXE), LSTAXE_NEW(GLONDIE)(1..MAXAXE)
Local Integer AXE, DIFF
Local Integer TYPJOU
Local Decimal JR(1..2),HR(1..2),TPSBRK
Local Integer JNUIT
Local Char    HREDEB(GLONHM),HREFIN(GLONHM),NATACT(GLONNAT)
Local Char    CCE(GLONCCE)(1..MAXAXE)
Local Char    DIE(GLONDIE)(1..MAXAXE)
Local Integer INI
Local Char    MATRI(GLONMAT),CPY_TIP(GLONCPY),CTR(GLONCTR)

  MATRI=W_TIP_REFNUM : CTR=W_TIP_CTRNUM : CPY_TIP=W_TIP_CPY
  IDIFF=0
  # Plans de comptes et axes du modèle comptable de l'ancienne société
  Call SETPLAN2(ACMCUR_OLD,NBPLAN_OLD,LSTPLAN_OLD,REFTYP_OLD,NBAXE_OLD,LSTAXE_OLD,OBLIG_OLD) From CPTDIV
  # Plans de comptes et axes du modèle comptable de la nouvelle société
  Call SETPLAN2(ACMCUR_NEW,NBPLAN_NEW,LSTPLAN_NEW,REFTYP_NEW,NBAXE_NEW,LSTAXE_NEW,OBLIG_NEW) From CPTDIV
  DIFF=0
  For AXE=1 To NBAXE_OLD
    If !find(LSTAXE_OLD(AXE),LSTAXE_NEW) Then
      DIFF=1
      Break
    Endif
  Next
  If DIFF Then
    Raz [F:TIP]DIE : Raz [F:TIP]CCE
    If clalev([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
    Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
    If GNBHOR & [F:TIM]PLGHOR=2
      Call JOUR_AXE(MATRI,[F:TIP]STRDAT,TYPJOU,JR,HR,JNUIT,[F:TIP]FCY,CTR,1,HREDEB,HREFIN,TPSBRK,NATACT,CCE,INI,DIE) From SUBPLN  #CHECK IGNORE_LINE
    Endif
    If [F:TIP]NBRHOU>0
      If INI=1
        Gosub LISTDIE From TPSSUB
        Local Integer JS : JS=0
        For AXE=1 To GOPTCANA
          If find(DIE(AXE),WLSTDIE(1..WNBRDIE)) Then
            [F:TIP]CCE(JS) = CCE(AXE)
            [F:TIP]DIE(JS) = DIE(AXE)
            JS += 1
          Endif
        Next
      Else
        If [F:ID]REFNUM<>MATRI : Read [ID]ID0=MATRI : Endif
        Gosub INISEC From TPSSUB
        Gosub VERFSEC From TRTREM
      Endif
    Endif
  Endif
 Return

#########################################################
Subprog UPD_FLGCREBUL(VALEUR, FLGACT)
Variable Integer VALEUR
Value Integer FLGACT  :# 1=Assign&Display ; 2=Assign ; 3=Display

Local Integer FLGVAL

If FLGACT<>2
 Local Char ZONE(10) : ZONE = "FLGCREBUL"
 Gosub SET_ZONE From SUBCTR
 If !MA : End : Endif
 Actzo [M]FLGCREBUL
Endif

#Casual workers = Never check the box 'Break payslip'
#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If (GINTMT & [F:ID]FLGINT=2)
If (GINTMT & [F:ID]FLGINT=2) & GCURLEG = 'FRA'
#JOJAC - 2016-06-08 - REQ114309 US215 - END
 Case FLGACT
  When 1 : FLGVAL = 1 : Grizo [M]FLGCREBUL
  When 2 : FLGVAL = 1
  When 3 : Grizo [M]FLGCREBUL
 Endcase
#Payback or VAR = Always check the box 'Break payslip'
Elsif  [M:CTR0]FLGRET=2 | [M:CTR0]FLGVAR=2
 Case FLGACT
  When 1 : FLGVAL = 2 : Grizo [M]FLGCREBUL
  When 2 : FLGVAL = 2
  When 3 : Grizo [M]FLGCREBUL
 Endcase
Else
 #First contract = Always check the box 'Break payslip'
 If clalev([F:CTR2])=0 : Local File EMPLOCTR         [CTR2] : Endif
 Filter [CTR2] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT<[M:CTR0]CTRDAT
 Read [CTR2]CTR0 Last
 Filter [CTR2]
 # Not existing contrat so we are creating the first one and the first one must be check
 If fstat>2
  Case FLGACT
   When 1 : FLGVAL = 2 : Grizo [M]FLGCREBUL
   When 2 : FLGVAL = 2
   When 3 : Grizo [M]FLGCREBUL
   #JOJAC - 2016-07-28 - REQ114309 - START
   When 4 : FLGVAL = 2 : Grizo [M]FLGCREBUL
   #JOJAC - 2016-07-28 - REQ114309 - END
  Endcase
 Elsif !fstat & [F:CTR2]XITFNL=2
  Case FLGACT
   When 1 : FLGVAL = 2 : Actzo [M]FLGCREBUL
   When 2 : FLGVAL = 2
   When 3 : Actzo [M]FLGCREBUL
  Endcase
 Endif
 Close Local File [CTR2]
Endif

If FLGACT<>3
 #Assign a default value
 If !FLGVAL : Call GET_FLGCREBUL (FLGVAL,[M:CTR0]CTRGRD) From SUBMOE : Endif
 VALEUR=FLGVAL
Endif

If FLGACT<>2
 Call BOLD_CTR0(VALEUR)
 If FLGACT<>3 :  : Affzo [M]FLGCREBUL : Affzo [M:CTR0] : Endif
Endif
End

#########################################################
Subprog BOLD_CTR0(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Chgstl [M:CTR0] With "CONTRAT"
Else
 Chgstl [M:CTR0] With ""
Endif
End

