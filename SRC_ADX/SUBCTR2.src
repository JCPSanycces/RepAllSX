########################################################
# CONTROL TIP For ANNULE contract
# Test s'il existe temps sur une autre période d'activité
#**
#*
#*
#* @param REFNUM
#* @param CTRNUM
#* @param CTRDAT
#* @param POK
#*!
Subprog CONTROLE_TIP4(REFNUM,CTRNUM,CTRDAT,POK)
Value   Char  REFNUM,CTRNUM
Value   Date  CTRDAT
Variable Integer POK
Local Integer NBCTR
Local Date MCTRDA

If clalev([F:TIP])=0  : Local File TIMEMP     [TIP] : Endif

POK=2
For [F:TIP]
# Test s'il existe temps sur une autre période d'activité
 MCTRDA=func TPSSTD.CALC_CTRDATDEF2([L]REFNUM,[L]CTRNUM,[L]CTRDAT,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,NBCTR)
 If  MCTRDA= [0/0/0] or !NBCTR Then
   POK=0
   Break
 Endif
Next
End


########################################################
# Payslips is present in period
#* Control FLGCREBUL
#*
#* @param VALEUR
#* @param MAT
#* @param CTR
#* @param DATCTR
#*!
Subprog CONTROLE_REBUL(VALEUR,MAT,CTR,DATCTR)
Variable Integer VALEUR
Value Char MAT()
Value Char CTR()
Value Date DATCTR
Local Char    CRITERED_VEP(250)
Local Date WSTRCTRDAT,WDAT,FINPAY
FINPAY=gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
If DATCTR > FINPAY : End : Endif
# recherche bulletins sur période en cours + période précédente
# donc recherche / DATCTR-1
Call CTRDAT_STR_END(MAT,CTR,DATCTR-1,WSTRCTRDAT,WDAT) From DIVPAYE
CRITERED_VEP="[F:VEP]CTRNUM='"+[L]CTR+"'"
CRITERED_VEP-= "& [F:VEP]PYRMON=GMOIPAY & [F:VEP]PST<2 "
CRITERED_VEP-= "& [F:VEP]STRCTRDAT>=["+num$([L]WSTRCTRDAT)+"]"
If VALEUR <>2
  CRITERED_VEP-= "& ([F:VEP]CTRDAT=[F:VEP]STRCTRDAT | ([F:VEP]CTRDAT<>[F:VEP]STRCTRDAT & [F:VEP]STRCTRDAT=["+num$([L]DATCTR)+"]))"
Else
  CRITERED_VEP-= "& [F:VEP]CTRDAT<>[F:VEP]STRCTRDAT & [F:VEP]STRCTRDAT<>["+num$([L]DATCTR)+"]"
Endif
Call CONTROLE_PAYE([L]MAT, CRITERED_VEP) From SUBCTR
If mkstat
   # Modification impossible : Paies présentes sur la période
#JASMI - 2016-05-31 - REQ 114309 - START
#   GMESSAGE = mess(12,701,1)
   GMESSAGE = mess(12,10701,1)
#JASMI - 2016-05-31 - REQ 114309 - END
   mkstat = 2 : End
Endif
End

#Il ne faut pas nommer une variable 'PARAM' car déjà utilisée par le superviseur lors de l'import/export
########################################################
$AFF_COL
Local Char VPARAM   (GLONADP)
Local Char SALAIRE (10)
Local Char ZONE(10) : ZONE = "FRMSAL"
Gosub SET_ZONE From SUBCTR
#JOJAC - START
If MA
#JOJAC - END
 For J=0 To 5
  Case J
   When 0 : Chgfmt [M]SALVAL  With "-N:9.2#"
   When 1 : Chgfmt [M]SALVAL1 With "-N:9.2#"
   When 2 : Chgfmt [M]SALVAL2 With "-N:9.2#"
   When 3 : Chgfmt [M]SALRUB  With "-N:9.2#"
   When 4 : Chgfmt [M]SALRUB1 With "-N:9.2#"
   When 5 : Chgfmt [M]SALRUB2 With "-N:9.2#"
  Endcase
  [M]FRMSAL(J)="-N:9.2#"
  [M]LIBSAL(J)=""
  Gosub FIND_COL
 Next
Endif
Return

########################################################
$FIND_COL
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#Case J
# When 0 : VPARAM="VARSAL"
# When 1 : VPARAM="VARSAL2"
# When 2 : VPARAM="VARSAL3"
# When 3 : VPARAM="RUBSAL"
# When 4 : VPARAM="RUBSAL2"
# When 5 : VPARAM="RUBSAL3"
#Endcase
#Raz SALAIRE
#Call PARAM("",VPARAM ,SALAIRE) From ADOVAL
#If SALAIRE<>""
# Case J
#  When 0 : Chgfmt [M]SALVAL  With "N:9.3#"
#  When 1 : Chgfmt [M]SALVAL1 With "N:9.3#"
#  When 2 : Chgfmt [M]SALVAL2 With "N:9.3#"
#  When 3 : Chgfmt [M]SALRUB  With "N:9.3#"
#  When 4 : Chgfmt [M]SALRUB1 With "N:9.3#"
#  When 5 : Chgfmt [M]SALRUB2 With "N:9.3#"
# Endcase
#   [M]FRMSAL(J)="N:9.3#"
#   If J<3
#    Read [VRA]VRA0=SALAIRE
#    If !fstat : [M]LIBSAL(J)=[F:VRA]DESSHO : Endif
#   Else
#    Read [RUB]RUB0=SALAIRE
#    If !fstat : [M]LIBSAL(J)=[F:RUB]DESSHO : Endif
#   Endif
# Endif
##Endif
Case J
 When 0 : VPARAM="VARSAL"  : VPARAM2=GCURLEG
 When 1 : VPARAM="VARSAL2" : VPARAM2=GCURLEG
 When 2 : VPARAM="VARSAL3" : VPARAM2=GCURLEG
 When 3 : VPARAM="RUBSAL"  : VPARAM2=GCURLEG
 When 4 : VPARAM="RUBSAL2" : VPARAM2=GCURLEG
 When 5 : VPARAM="RUBSAL3" : VPARAM2=GCURLEG
Endcase
Raz SALAIRE

Call PARAM(VPARAM2,VPARAM ,SALAIRE) From ADOVAL
If SALAIRE<>""
 Case J
  When 0 : Chgfmt [M]SALVAL  With "N:9.2#"
  When 1 : Chgfmt [M]SALVAL1 With "N:9.2#"
  When 2 : Chgfmt [M]SALVAL2 With "N:9.2#"
  When 3 : Chgfmt [M]SALRUB  With "N:9.2#"
  When 4 : Chgfmt [M]SALRUB1 With "N:9.2#"
  When 5 : Chgfmt [M]SALRUB2 With "N:9.2#"
 Endcase
 [M]FRMSAL(J)="N:9.2#"
 If J<3
  #Read [VRA]VRA0=SALAIRE;GCURLEG
  #If !fstat : [M]LIBSAL(J)=[F:VRA]DESSHO : Endif
  Call LECTEXTRA( [M]LIBSAL(J),"VARIA","DESSHO",GCURLEG,SALAIRE) From ATEXTRA
 Else
  Call LECTEXTRA( [M]LIBSAL(J),"RUBRIQUE","DESSHO",GCURLEG,SALAIRE) From ATEXTRA
 Endif
Endif
#JOJAC - 2016-06-02 - REQ114309 US215 - END
Return

