#FRLAA - X3 2017-01-31 - START
Subprog CHARGE_POPUL(P_REFNUM,P_TBPOPUL,P_NB_POPUL,P_CTRNUM,P_CTRDAT,P_TBMAJTYP)
Value    Char     P_REFNUM()
Variable Char     P_TBPOPUL()()
Variable Integer  P_NB_POPUL, P_TBMAJTYP

Value Char P_CTRNUM()
Value Date P_CTRDAT
Raz P_TBPOPUL, P_NB_POPUL

If clalev([F:HRPOA])=0  : Local File POPULA           [HRPOA]  : Endif

# Tableau des populations auxquelles le salarié appartient déjà
For [F:HRPOA]POA1 Where [F:HRPOA]REFNUM=P_REFNUM  & [F:HRPOA]CTRNUM=P_CTRNUM & [F:HRPOA]CTRDAT=P_CTRDAT
   If [F:HRPOA]TYP=0 & [F:HRPOA]COD<>""
     P_TBPOPUL(P_NB_POPUL) = [F:HRPOA]COD
     P_TBMAJTYP(P_NB_POPUL) = [F:HRPOA]MAJTYP
     P_NB_POPUL += 1
    Endif
Next
End
#FRLAA - X3 2017-01-31 - END

$CHARGE_EPC_SAL
If GPAYE
 Filter [SAL] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM Order By Key CLE=REFNUM;CTRNUM;SALDAT Desc
 nolign = 0
 For [SAL]CLE
  If nolign>=dim([M:CTR5]SALDAT)
   GMESSAGE=mess(26,100,1)-':'-mess(31,10713,1)  #: Tableau plein : Récupération des évolutions de salaire
   Break
  Endif
  nolign +=1
  [M:CTR5] = [F:SAL]
 Next
 [M:CTR5]NBRSAL = nolign
 Filter [SAL]
 Read[EPC]EPC0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM
 If !fstat
  [M] = [F:EPC]
 Endif
Endif
Return

$CHARGE_EVT
For nolign=1 To dim([F:HRCTR]EVECTRCOD)
 If [F:HRCTR]EVECTRCOD(nolign-1)="" : Break : Endif
 [M:CTR4]EVECTRCOD(nolign-1)=[F:HRCTR]EVECTRCOD(nolign-1)
 [M:CTR4]EVECTRDAT(nolign-1)=[F:HRCTR]EVECTRDAT(nolign-1)
Next
[M:CTR4]NBRDP1 = nolign-1
Return

#JASMI - 2016-05-28 - REQ 114309 - START
###############################################################
##** V7 : Waiting Update Accounting **#

$CHARGE_CPR
  If dim([M:CTR9]FLGCTRCPT) > 0
    Raz [M:CTR9]
    Read [F:CPR]CPR0 = [M:CTR0]REFNUM ; [M:CTR0]CTRNUM ; [M:CTR0]CTRDAT
    If fstat = 0
      [M:CTR9]BPR = [F:CPR]BPR
      [M:CTR9]ACCCOD = [F:CPR]ACCCOD
      [M:CTR9]DSP = [F:CPR]DSP
      Call LECTEXTRA([M:CTR9]DSPDES, "CADSP","DESTRA",[F:CPR]DSP,"") From ATEXTRA
      Call VALDEF_CTR9_ANA(1,[F:FCY]LEGCPY) From SUBCTR
      [M:CTR9]FLGCTRCPT = 2
      Actzo [M:CTR9]
    Else
      Effzo [M:CTR9]
      [M:CTR9]FLGCTRCPT = 1
      Call SETMSK_CTR9([M:CTR0]ETRFCY) From SUBCTR
    Endif
    Affzo [M:CTR9]
  Endif
Return
#JASMI - 2016-05-28 - REQ 114309 - END

$REFRESH_CPR
If dim([M:CTR9]FLGCTRCPT) > 0
   # Valeur Param CTRCPT
   Call SETMSK_CTR9([L]VALEUR) From SUBCTR

   If [M:CTR9]FLGCTRCPT = 2 : #  « Infos comptables au contrat » cochée
     Call LECTURE("FCY",[M:CTR0]ETRFCY,"") From CONTOBJ
     [L]SOC=[F:FCY]LEGCPY
     Call LECTURE("FCY",VALEUR,"") From CONTOBJ

     If find([V]GREP,"C") :# Création
        # Activation de l'écran
        # reinit bloc compta
        Call VALDEF_CTR9_CPT([M:CTR0]REFNUM) From SUBCTR
        # reinit bloc Ana
        Call VALDEF_CTR9_ANA(0,[F:FCY]LEGCPY) From SUBCTR
        Actzo [M:CTR9]
     Else   # modif de CTR ou ou duplication
        #    Pas de reinit du bloc compta
       If [F:FCY]LEGCPY<>[L]SOC
        # If different  Companies
        #    on ne réinit le bloc Ana que si les modèles comptables sont différents
         Local Integer DIFF : DIFF = 0
         Local Char ACMCUR1(GLONGCM), ACMCUR2(GLONGCM)
         Call SETGCM([L]SOC,[L]ACMCUR1) From CPTDIV :# previous input
         Call SETGCM([F:FCY]LEGCPY,[L]ACMCUR2) From CPTDIV :# current input
         Call VERFMDL([L]ACMCUR1,[L]ACMCUR2,[L]DIFF) From SUBCPYB
         If [L]DIFF :# If  Different Account Core Model
           Effzo [M:CTR9]20
           Call VALDEF_CTR9_ANA(0,[F:FCY]LEGCPY) From SUBCTR
         Endif
        Endif
     Endif
   Else  :# « Infos comptables au contrat » non cochée
      Effzo [M:CTR9]10,20
   Endif

   Affzo [M:CTR9]
Endif
Return

$CHARGE_BULDEM
If dim([M:CTR5]BULDEMAFF) > 0
 If(func SUBEML.DISP_BULDEM([M:CTR0]REFNUM,[M:CTR0]CTRNUM,[M:CTR0]CTRDAT)<>0 and  func SUBEML.GETVAL_BULDEM([M:CTR0]REFNUM)=2)
  [M:CTR5]BULDEMAFF=2
 Else
  [M:CTR5]BULDEMAFF=1
 Endif
Endif
Return

$REFRESH_BULDEM
If dim([M:CTR5]BULDEMAFF) > 0
 Local Char WRES(3)
 Call PARAM(VALEUR,"BULDEM",[L]WRES) From ADOVAL
 If([L]WRES="2" and  func SUBEML.GETVAL_BULDEM([M:CTR0]REFNUM)=2)
  [M:CTR5]BULDEMAFF=2
 Else
  [M:CTR5]BULDEMAFF=1
 Endif
 Affzo [M:CTR5]BULDEMAFF
Endif
Return

$SUPPR_CNE
Filter [F:CNG] Where CPY=[M:CTR0]CPY & ((STRPER>=[F:CTR1]CTRDAT & STRPER<=[F:CTR1]XITDAT) | (ENDPER>=[F:CTR1]CTRDAT & ENDPER<=[F:CTR1]XITDAT))

#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  Filter [F:CNE] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
&                   & ((EMPLEASTR>=[F:CTR1]CTRDAT & EMPLEASTR<=[F:CTR1]XITDAT) | (EMPLEAEND>=[F:CTR1]CTRDAT & EMPLEAEND<=[F:CTR1]XITDAT))
 Read [F:CNE]CNE0 Last
 Filter [F:CNE]
 If !fstat
   Filter [F:CNG] Where CPY=[M:CTR0]CPY & YEA=[F:CNE]YEA
 Endif
Endif

For [F:CNG]CNG0
 Filter [F:CNE] Where  YEA=[F:CNG]YEA & REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
 For [F:CNE]CNE0
  [F:CNE]NBRDAY=0
  [F:CNE]NBRPRI=0
  Rewrite [F:CNE]
  If fstat
   GOK=0 : Call FSTA("CNE") From GLOCK : Break 2
  Endif
 Next
 Filter [F:CNE]
Next
Filter [F:CNG]
Return

########################################################
Subprog LECTXC(CRITERE)
Value Char CRITERE
Local Char TABCLE (20)(0..3)
Local Char CTR
If clalev([F:TXC])=0 : Local File TXTCTR [TXC] : Endif
Filter [TXC] Where evalue(CRITERE)
Read[TXC]TXC0 First
Filter [TXC]
If ! fstat
 CTR       = [TXC]CTRNUM
 TABCLE(0) = [TXC]REFNUM
 TABCLE(1) = num$([TXC]CTRDAT)
 TABCLE(2) = num$([TXC]DOCCLA)
 TABCLE(3) = [TXC]CODCLA
 Call OBJET ("TXC",CTR,TABCLE) From GOBJET
Else
 Raz [F:TXC]
#JASMI - 2016-05-31 - REQ 114309 - START
# GMESSAGE = mess(7,715,1)
 GMESSAGE = mess(7,10715,1)
#JASMI - 2016-05-31 - REQ 114309 - END
 mkstat = 2 : End
Endif
End

