Subprog C_CTRTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
  Diszo [M:CTR1]CDDGRD, NBRPER, PERCON, ENDCON, MATREMP
Else
  Actzo [M:CTR1]CDDGRD, NBRPER, PERCON, ENDCON, MATREMP
Endif
End
#ADNGO - 2017-12-07 - X3-60300 - END

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer  OK

  #JOJAC - 2016-07-21 - REQ114309 - START
  Call MULCTR(VALEUR,[M:CTR0]CTRNUM,OK) From SUBCTR
  If OK = 1 : mkstat=2 : End : Endif
  #JOJAC - 2016-07-21 - REQ114309 - END

  #JOJAC - 2016-07-20 - REQ114309 - START
  Read [F:ID]ID0=VALEUR
  If !fstat & [F:ID]FCYORI<>"" Then
    Call LECTURE("FCY",[F:ID]FCYORI,"")  From CONTOBJ : LEGI = [F:FCY]LEG : # LEGI=leg of the employee
    If GCURLEG = ""
     GCURLEG=LEGI
    Endif
  Endif
  #JOJAC - 2016-07-20 - REQ114309 - END

  If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
  Read[ID]ID0=VALEUR
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
  #If !fstat
  If !fstat Then
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
   #[M]SRN = [F:ID]NAM-[F:ID]SRN
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  #JOJAC - 2016-06-08 - REQ11439 US215 - START
   #If GINTMT
   If GINTMT & func DIVPAYE.IS_KFR_LEG(GCURLEG)
   #JOJAC - 2016-06-08 - REQ11439 US215 - END
    If [F:ID]FLGINT<>2 : # Le salarié n'est pas un intermittent
     Effzo [CTR3]
     If dim([M:CTR3]STACTR)>0 : [M:CTR3]STACTR = 2 : Endif
     Grizo [CTR3]
    Else
     Actzo [CTR3]
    Endif
    Affzo [CTR3]
   Endif
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
   # FQ81085 - 17/09/13 - Affichage du Nom-Prénom sur sélection d'un salarié
   [M]SRN = [F:ID]NAM-[F:ID]SRN
   Affzo [M]SRN
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  Endif
  Call GRISE_CALPAY([F:ID]FLGINT) #From SUBCTR2
  Call GRISE_FLGPAY([F:ID]FLGPAY) #From SUBCTR2
#MIPEA - 2017-02-16- X3-11258- START
  Local Char WCTRNUMERO(GLONHRCTR)
#  Local Char WCTRNUMERO(GLONCTR)
#MIPEA - 2017-02-16- X3-11258- END
  WCTRNUMERO=""
  If GREP<> "C"
  #JOJAC - 2016-06-02 - REQ114309 US215 - START
    #Call SELCTR2(VALEUR,[0/0/0],[0/0/0],WCTRNUMERO) From DIVPAYE
    #Call SELCTRMLEG(VALEUR,[0/0/0],[0/0/0],GLEGFIL,WCTRNUMERO) From TOOLSHRLEG
     Call SELCTRMLEG(VALEUR,[0/0/0],[0/0/0],"",WCTRNUMERO) From TOOLSHRLEG
  #JOJAC - 2016-06-02 - REQ114309 US215 - END
  #JASMI - 2017-01-06 - START
    If [M:CTR0]LEG<>""
      GCURLEG=[M:CTR0]LEG
    Endif
  #JASMI - 2017-01-06 - END
  Endif
  If WCTRNUMERO <> ""
   [M:CTR0]=[F:HRCTR]
  Endif
End
#MIPEA - 2018-05-10 - X3-86564 - START
$LINK_ACCRUALS
#MIPEA - 2018-05-10 - X3-86564 - START
#PEVAN - 2018-05-17 - X3-88290 - START
  If [M:CTR0]FLGVAR < 2 & [M:CTR0]FLGRET < 2 & [M:CTR0]XITFNL < 2
#PEVAN - 2018-05-17 - X3-88290 - END
#PEVAN - 2018-05-15 - X3-90838 - START
    OK = 2
    If GREP="D" | GREP="C"
      If !clalev([F:ACCRUCTR]) : Local File HRLVEACCRU [F:ACCRUCTR] : Endif
      Filter [F:ACCRUCTR] Where [F:ACCRUCTR]CTR = [F:HRCTR]CTRNUM and [F:ACCRUCTR]LVEACCTYP="Linking"
      If rowcount([F:ACCRUCTR]) > 0
      #PEVAN - 2018-09-05 - X3-106820 - START
        If !clalev([F:HRCTRHR]) : Local File EMPLOCTR [F:HRCTRHR] : Endif
        Filter [F:HRCTRHR] Where [F:HRCTRHR]CTRNUM = [M:CTR0]CTRNUM
        If rowcount([F:HRCTRHR]) > 1
      #PEVAN - 2018-09-05 - X3-106820 - END
          Call OUINON(mess(37,11691,1),OK) From GESECRAN
        Endif
        Close File [F:HRCTRHR]
      Endif
      Filter [F:ACCRUCTR]
      Close File [F:ACCRUCTR]
    Endif
#PEVAN - 2018-05-15 - X3-90838 - END
    # Do you want to link current subtypes linked for same contract chrono ?
    If OK=2
      Call LINKING_ACCRUALS_PROG("","","",[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,4,1) From SUBACCRUAL
    Else
      GERR=2
      GMESSAGE = mess(38,11691,1)
    Endif
  Else
    If [M:CTR8]XITDAT <> [0/0/0]
      If !clalev([F:ACCRUCTR]) : Local File HRLVEACCRU [F:ACCRUCTR] : Endif
      Update [F:ACCRUCTR] Where [F:ACCRUCTR]CTR=[F:HRCTR]CTRNUM and [F:ACCRUCTR]LVEACCTYP="Linking" and [F:ACCRUCTR]CTRDAT=[F:HRCTR]CTRDAT With [F:ACCRUCTR]XITDAT=[F:HRCTR]XITDAT
      Close File [F:ACCRUCTR]
    Endif
  Endif
#MIPEA - 2018-05-10 - X3-86564 - END
Return
#MIPEA - 2018-05-10 - X3-86564 - END

#PEVAN - 2018-05-22 - X#-90346 - START
$DELETE_ACCRUALS
  If [M:CTR8]XITDAT <> [0/0/0]
    If !clalev([F:ACCRUCTR]) : Local File HRLVEACCRU [F:ACCRUCTR] : Endif
    Delete [F:ACCRUCTR] Where [F:ACCRUCTR]LVEACCDAT > [M:CTR8]XITDAT & ([F:ACCRUCTR]LVEACCTYP = "Accrual" | [F:ACCRUCTR]LVEACCTYP = "Carry Over" | [F:ACCRUCTR]LVEACCTYP = "Carry Over Excess")
    Close File [F:ACCRUCTR]
  Endif
Return
#PEVAN - 2018-05-22 - X#-90346 - END


#MAPAD 2018-05-24 X3-91756 -START
$GETPAYPERIOD
Local Date STR2, END2
Local Date MINDATE,MAXDATE,MIDMON
Local Integer TAXMON

[L]STR2 = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[L]END2 = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))


If !clalev([F:HRPEOD2]) : Local File HRPEODET [HRPEOD2] : Endif
If !clalev([F:HRPEOH2]) : Local File HRPEOHEA [HRPEOH2] : Endif


Filter [F:HRPEOH2] Where PERCOD =[M:CTR1]PERCOD and [F:HRPEOH2]FLGENA=2
Read [F:HRPEOH2] Last

If [F:HRPEOH2]PAYFRQ = 1 Then



  MIDMON=gdat$(16,month(STR2),year(STR2))
  If !clalev([F:HRPEOD3]) : Local File HRPEODET [HRPEOD3] : Endif

  Filter [F:HRPEOD3]
  Filter [F:HRPEOD3] Where PERCOD =[M:CTR1]PERCOD and PERYEA =[F:HRPEOH2]PERYEA and  PERSTR(1) <= MIDMON and PEREND(1) >= MIDMON
  Read [F:HRPEOD3] Last

  TAXMON=[F:HRPEOD3]TAXMON

  Filter [F:HRPEOH2]
  MINDATE =date$


Link [F:HRPEOD2]
&  With [F:HRPEOH2]HRPEOH0 = [F:HRPEOD2]PERYEA;[F:HRPEOD2]PERCOD
&  As [LNK]
&  Where [F:HRPEOD2]PERCOD=[M:CTR1]PERCOD  & [F:HRPEOH2]FLGENA=2
&        & (month([F:HRPEOD2]PERSTR(1))=month([L]STR2) or month([F:HRPEOD2]PEREND(1))=month([L]END2))
&        & (year([F:HRPEOD2]PERSTR(1))=year([L]STR2) or year([F:HRPEOD2]PEREND(1))=year([L]END2))



  For [LNK]

    If TAXMON = [F:HRPEOD2]TAXMON Then
      MINDATE =min(MINDATE,[F:HRPEOD2]PERSTR(1))
      MAXDATE = max(MAXDATE,[F:HRPEOD2]PEREND(1))
    Endif

  Next
Else

  MINDATE =[L]STR2
  MAXDATE= [L]END2

Endif

Filter [F:HRPEOH2]

Return
#MAPAD 2018-05-24 X3-91756 -END

#ADNGO - 2018-09-21 - X3-75324 - START
Subprog C_AFRPRV(VALEUR)
Variable Char    VALEUR()

If !clalev([F:ATU]) : Local File TABSUBDIV : Endif

If func DIVPAYE.IS_KNG_LEG(GCURLEG) Then
  If VALEUR = "" Then
    GMESSAGE = mess(00010,00123,1) : mkstat=2 : End
  Endif
Endif

Filter [F:ATU] Where COD=VALEUR
Read [F:ATU] First
Filter[F:ATU]
If fstat Then
  GMESSAGE = VALEUR-":"-mess(23,100,1)
  mkstat = 2 : End
Endif

End

$CHECK_AFRPRV
If func DIVPAYE.IS_KNG_LEG(GCURLEG) Then
  For nolign = 1 To [M:CTR4]NBRAFR
    If [M:CTR4]AFRTYP(nolign-1) = 1 Then
      If [M:CTR4]AFRPRV(nolign-1) = "" Then
        GMESSAGE = mess(00010,00123,1)
        zonsui = "[M:CTR4]AFRPRV(nolign-1)"
        Return
      Endif
    Endif
  Next
Endif
Return
#ADNGO - 2018-09-21 - X3-75324 - END

