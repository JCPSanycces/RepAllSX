#LIPET - 2017-06-27 - X3-32840 - START
Subprog C_STRDATLVE(VALEUR)
Variable Date    VALEUR
If func AFNC.ACTIV("GLM")>0 Then

  Call C_HRLST([M]CODLST(nolign-1),VALEUR)
  Local Integer X

    For X=0 To HRLSTNR-1
      If CODLST(X) = CODLST(nolign-1) and VALEUR >= [M]STRDATLVE(X) and VALEUR <= [M]ENDDATLVE(X) Then
        Gosub ERRDAT
      Endif
    Next
  #MIPEA - 2017-08-14- US X3-X3-52577- START
  If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif

  Filter [HRPEOD] Where PERCOD = [M]PERCOD and PERSTR(1) = VALEUR
  Read [HRPEOD] Last
  Filter [HRPEOD]

  If fstat
    GMESSAGE= mess(164,107,1)+" "+mess(27,114,1)+" - "+mess(00023,00100,1)
    mkstat=1
  Endif
#MIPEA - 2017-08-14- US X3-X3-52577- END

Endif
End

Subprog C_ENDDATLVE(VALEUR)
Variable Date    VALEUR
If func AFNC.ACTIV("GLM")>0 Then

Call C_HRLST([M]CODLST(nolign-1),VALEUR)
Local Integer X

If [M:CTR12]CODLST(HRLSTNR)<>""
  For X=0 To HRLSTNR-1
    If CODLST(X) = CODLST(nolign-1) and ((VALEUR >= [M]STRDATLVE(X) and VALEUR <= [M]ENDDATLVE(X)) | (STRDATLVE(nolign-1) < [M]STRDATLVE(X) and VALEUR > [M]ENDDATLVE(X))) Then
      Gosub ERRDAT
    Endif
  Next
Else
  For X=0 To HRLSTNR-2
    If CODLST(X) = CODLST(nolign-1) and ((VALEUR >= [M]STRDATLVE(X) and VALEUR <= [M]ENDDATLVE(X)) | (STRDATLVE(nolign-1) < [M]STRDATLVE(X) and VALEUR > [M]ENDDATLVE(X))) Then
      Gosub ERRDAT
    Endif
  Next
Endif
#MIPEA - 2017-08-14- US X3-X3-52577- START
If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif

Filter [HRPEOD] Where PERCOD = [M]PERCOD and PEREND(1) = VALEUR
Read [HRPEOD] Last
Filter [HRPEOD]

If fstat
  GMESSAGE= mess(164,107,1)+" "+mess(18,2,1)+" - "+mess(00023,00100,1)
  mkstat=1
Endif
#MIPEA - 2017-08-14- US X3-X3-52577- END
Endif
End

Subprog C_HRLST(VALEUR,DAT)
Variable Char  VALEUR
Variable Date DAT
If VALEUR <> "" and  DAT = [00/00/00]
  GERR = 1 : GMESSAGE = mess(10,123,1) : #Madatory field
  mkstat = 1
Endif
End

$ERRDAT
GMESSAGE =mess(9,11691,1)
mkstat   = 1
Return

$CRE_HRLST
If func AFNC.ACTIV("GLM")>0 Then
For nolign=1 To [M]HRLSTNR
 [F:HRCTR]CODLST(nolign-1)    = [M:CTR12]CODLST(nolign-1)
 [F:HRCTR]STRDATLVE(nolign-1)   = [M:CTR12]STRDATLVE(nolign-1)
 [F:HRCTR]ENDDATLVE(nolign-1)   = [M:CTR12]ENDDATLVE(nolign-1)
Next
Endif
Return

$RD_HRLST
If func AFNC.ACTIV("GLM")>0 Then
#nolign=0
For nolign=1 To dim([F:HRCTR]CODLST)
If [F:HRCTR]CODLST(nolign-1) ="" : Break : Endif
 [M:CTR12]CODLST(nolign-1)     = [F:HRCTR]CODLST(nolign-1)
 [M:CTR12]STRDATLVE(nolign-1)     = [F:HRCTR]STRDATLVE(nolign-1)
 [M:CTR12]ENDDATLVE(nolign-1)  = [F:HRCTR]ENDDATLVE(nolign-1)
# Call LECTEXTRA([M]DES(nolign-1),"HRLVESUBHEA","DES",GCURLEG,[M:CTR12]CODLST(nolign-1)) From ATEXTRA
# Call LECTEXTRA([M]SHO(nolign-1),"HRLVESUBHEA","SHO",GCURLEG,[M:CTR12]CODLST(nolign-1)) From ATEXTRA

Next
[M:CTR12]HRLSTNR = nolign-1
Affzo [M:CTR12]
Endif
Return

