If MA
 If varmode([M]CALPAY)>0
  [M]CALPAY = 1
 Else
 #end 92316
   If VALEUR<>2 : # Salarié non intermittent
    [M]CALPAY = 1
    Grizo CALPAY
    Affzo CALPAY
   Else         : # Salarié intermittent
    Actzo CALPAY
    Affzo CALPAY
   Endif
 Endif
