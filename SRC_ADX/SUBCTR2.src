#Compare the country of the main site of the employee, and the country of the site
# of the contract, to determine if the fields can be seizable or not
###############################################################
Subprog SEIZE_NUMSSC(SITE)
Value Char SITE
Local Char CRYFCY
CRYFCY=func TRTDIV.LECPAYSIT(SITE)
If func TRTDIV.LECPAYSIT([F:ID]FCYORI)=CRYFCY | CRYFCY="" Then
  If CRYFCY="" Then
    [M:CTR4]NUMSSCCTR  = ""
    [M:CTR4]NUMSSCCTR2 = ""
  Else
    [M:CTR4]NUMSSCCTR  = [F:ID]NUMSSC
    [M:CTR4]NUMSSCCTR2 = [F:ID]NUMSSC2
  Endif
  # This "Affzo" calls W1CTR4.AV_NUMSSCCTR & W1CTR4.AV_NUMSSCCTR2, and allows to hide or mask the fields with the Chgfmt
  Affzo [M:CTR4]NUMSSCCTR, NUMSSCCTR2
  Grizo [M:CTR4]NUMSSCCTR, NUMSSCCTR2
Else
  # This "Affzo" calls W1CTR4.AV_NUMSSCCTR & W1CTR4.AV_NUMSSCCTR2, and allows to hide or mask the fields with the Chgfmt
  Affzo [M:CTR4]NUMSSCCTR, NUMSSCCTR2
  Actzo [M:CTR4]NUMSSCCTR, NUMSSCCTR2
Endif
End

###############################################################
$DISP_TOTALS
Local Integer NUMRECADI
Local Char LIBZON
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#Gosub SET_ZONE
Gosub SET_ZONE From SUBCTR
#JOJAC - 2016-06-02 - REQ114309 US215 - END
If MA
  For J=0 To 8
    Case J
      When 0 : Chgtzn [M]CUM1 With ""
      When 1 : Chgtzn [M]CUM2 With ""
      When 2 : Chgtzn [M]CUM3 With ""
      When 3 : Chgtzn [M]CUM4 With ""
      When 4 : Chgtzn [M]CUM5 With ""
      When 5 : Chgtzn [M]CUM6 With ""
      When 6 : Chgtzn [M]CUM7 With ""
      When 7 : Chgtzn [M]CUM8 With ""
      When 8 : Chgtzn [M]CUM9 With ""
#      When 0 : Chgfmt [M]CUM1 With "-Nz3:9.2#"
#      When 1 : Chgfmt [M]CUM2 With "-Nz3:9.2#"
#      When 2 : Chgfmt [M]CUM3 With "-Nz3:9.2#"
#      When 3 : Chgfmt [M]CUM4 With "-Nz3:9.2#"
#      When 4 : Chgfmt [M]CUM5 With "-Nz3:9.2#"
#      When 5 : Chgfmt [M]CUM6 With "-Nz3:9.2#"
#      When 6 : Chgfmt [M]CUM7 With "-Nz3:9.2#"
#      When 7 : Chgfmt [M]CUM8 With "-Nz3:9.2#"
#      When 8 : Chgfmt [M]CUM9 With "-Nz3:9.2#"
    Endcase
  Next J

  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  NUMRECADI=0

  For [ADI]CODE Where NUMTAB=10349 & LEG=GCURLEG
    Call LECTEXTRA(LIBZON,"ATABDIV","LNGDES","10349",[F:ADI]CODE) From ATEXTRA
    Case NUMRECADI
      When 0 : Chgtzn [M]CUM1 With LIBZON
      When 1 : Chgtzn [M]CUM2 With LIBZON
      When 2 : Chgtzn [M]CUM3 With LIBZON
      When 3 : Chgtzn [M]CUM4 With LIBZON
      When 4 : Chgtzn [M]CUM5 With LIBZON
      When 5 : Chgtzn [M]CUM6 With LIBZON
      When 6 : Chgtzn [M]CUM7 With LIBZON
      When 7 : Chgtzn [M]CUM8 With LIBZON
      When 8 : Chgtzn [M]CUM9 With LIBZON
#      When 0 : Chgfmt [M]CUM1 With "Nz3:9.2#" :
#      When 1 : Chgfmt [M]CUM2 With "Nz3:9.2#"
#      When 2 : Chgfmt [M]CUM3 With "Nz3:9.2#"
#      When 3 : Chgfmt [M]CUM4 With "Nz3:9.2#"
#      When 4 : Chgfmt [M]CUM5 With "Nz3:9.2#"
#      When 5 : Chgfmt [M]CUM6 With "Nz3:9.2#"
#      When 6 : Chgfmt [M]CUM7 With "Nz3:9.2#"
#      When 7 : Chgfmt [M]CUM8 With "Nz3:9.2#"
#      When 8 : Chgfmt [M]CUM9 With "Nz3:9.2#"
    Endcase
    NUMRECADI+=1
    If NUMRECADI>8 : Break : Endif
  Next
Endif
Return

############################################
$MAJ_CTRDOC
If  !(dim([V]WGOLDCTRNUM)>0 & dim([V]WGOLDCTRDAT)> 0 & dim([V]WGDIFLEG)> 0) : Return : Endif
If GREP="D"
  [M:CTR1]FLGCRE1=1
  If  [V]WGOLDCTRNUM <> "" &  ![V]WGDIFLEG
    For [HRDOC1] Where REFNUM=[M]REFNUM & CTRNUM=[V]WGOLDCTRNUM & CTRDAT=[V]WGOLDCTRDAT
      [F:HRDOC]=[F:HRDOC1]
      [F:HRDOC]REFNUM=[M:CTR0]REFNUM
      [F:HRDOC]CTRNUM=[M:CTR0]CTRNUM
      [F:HRDOC]CTRDAT=[M:CTR0]CTRDAT
      If dim([F:HRDOC]CREDAT)>0 : [F:HRDOC]CREDAT = date$     : Endif
      If dim([F:HRDOC]CRETIM)>0 : [F:HRDOC]CRETIM = time      : Endif
      If dim([F:HRDOC]CREUSR)>0 : [F:HRDOC]CREUSR = GUSER     : Endif
      Write [F:HRDOC]
      If fstat
          GOK = 0 : Call FSTA("HRDOC") From GLOCK : Break
      Endif
      [M:CTR1]FLGCRE1=2
    Next
  Else
    [M:CTR1]FLGCRE1=1
  Endif
Endif
If GREP="M" &  [V]WGDIFLEG
  Delete [HRDOC] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT=[M]CTRDAT
  If fstat=1
     GOK = -1 : GLOCK = "$HRDOC"-num$([F:HRDOC]COD)-[F:HRDOC]REFNUM-[F:HRDOC]CTRNUM-[F:HRDOC]CTRDAT
  Endif
  If GOK<1 : Return : Endif
  Delete [HRTXC]TXC2(3)=[M]REFNUM;[M]CTRNUM;[M]CTRDAT
  If fstat=1
    GOK = -1 : GLOCK = "$TXTCTR"-[M:CDOC]REFNUM-[M:CDOC]CTRNUM-[M:CDOC]CTRDAT-num$([M:CDOC]DOCGEN(K))
  Endif
  If GOK<1 : Return : Endif
  [M:CTR1]FLGCRE1=1
Endif
Return

###########################################
$FILDEM
CRITCTR="1=1"
If GLEGFIL<>""
If CRITCTR<>"" Then CRITCTR-="&" : Endif
CRITCTR -= "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
CRITCTR -= "& [F:ID]FLGNEWSAL<>2"

Call FILTREROLE("EML",CRITCTR) From SUBEML
Call FILTREROLE("CTR",CRITCTR) From SUBEML

If GUSRACS<>2
  CRITCTR -= "& find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))"
  CRITCTR -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
Endif
If GPILNAV>1
  If find(GNAVIG(GPILNAV-1),"GESEML") & GREP<>"C" & GREP<>"D" & dim(TUNCLE)>0
    CRITCTR -= "& CTRNUM='"+TUNCLE+"'"
    Endif
  Endif
Endif
Filter [HRCTR_] Where evalue(CRITCTR)
Return

###########################################
$APRES_CHOI
  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILDEM
      If REPONSE=GSTASUI Then Read [HRCTR_]CTR0 > [M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT  : Endif
      If REPONSE=GSTAPRE Then Read [HRCTR_]CTR0 < [M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT  : Endif
      If REPONSE=GSTAFIR Then Read [HRCTR_]CTR0 First                                           : Endif
      If REPONSE=GSTALAS Then Read [HRCTR_]CTR0 Last                                            : Endif
      Filter [HRCTR_]
      Gosub SUIVPREC From TOOLSHRLEG
#JASMI - 2016-07-26 - START
    When [V]GSTANEW
      GCURLEG=""
      Gosub STYLE From SUBCTR
      Affzo [M:CTR4]
#JASMI - 2016-07-26 - END
  Endcase
Return

###########################################
$ABANDON
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

###########################################
$POPUL
  If ACTION="AP_ANNULE" : Return : Endif
   WREFNUM = [M:CTR0]REFNUM
   Raz TBLPOP
   #JOJAC - 2016-06-15 - REQ114309 US215 - START
   Raz NBPOP
   #JOJAC - 2016-06-15 - REQ114309 US215 - END
   If evalue("dim([M:CTR6]NBRPOP)")>0
      If (ACTION="CREATION")
## PEVAN - 2018-07-28 - X3-101061 - START
        If REP = 'D'
          For nolign=1 To [M:CTR6]NBRPOP
            If [M:CTR6]MAJTYP(nolign-1) = 1
              [M:CTR6]POP(nolign-1) = ""
              [M:CTR6]MAJTYP(nolign-1) = 0
              [M:CTR6]NBRPOP -= 1
            Endif
          Next
        Endif
## PEVAN - 2018-07-28 - X3-101061 - END
         Filter [HRPOP] Where CRI<>""
         For [HRPOP]
            If evalue([F:HRPOP]CRI)=1 & !find([F:HRPOP]COD,[M:CTR6]POP(0..[M:CTR6]NBRPOP-1))
&              & ([F:HRPOP]LEG="" |[F:HRPOP]LEG= [M:CTR0]LEG)
#              # Ajout dans le tableau de l'écran
               [M:CTR6]POP([M:CTR6]NBRPOP) = [F:HRPOP]COD
               [M:CTR6]MAJTYP([M:CTR6]NBRPOP) = 1 : # automatique
               [M:CTR6]NBRPOP +=1
               [M:CTR6]POPMOD = 1
               Affzo [M:CTR6]NBRPOP, POP, MAJTYP
            Endif
         Next
         Filter[HRPOP]
         Affzo [M:CTR6]POP, ZPOP, NBRPOP,MAJTYP
      Endif
      # On regarde aussi si on doit supprimer le salarié d'une population à laquelle il n'appartient plus
      For J=[M:CTR6]NBRPOP-1 To 0 Step -1
         Read [F:HRPOP]POP0=[M:CTR6]POP(J)
         If !fstat & [F:HRPOP]CRI<>"" & !evalue([F:HRPOP]CRI) Then
             Read [F:HRPOA]POA0=[M:CTR6]POP(J);[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
             If !fstat & [F:HRPOA]MAJTYP=1 Then
                 # suppression de l'enregistrement dans fichier
                 Delete [F:HRPOA] Curr
                 If fstat=1
                   GOK = -1 : GLOCK = "$POPULA"-[F:HRPOA]COD-[F:HRPOA]REFNUM-[F:HRPOA]CTRNUM-[F:HRPOA]CTRDAT : Break 2
                 Endif
                 # ajout dans tableau des supprimés
                 NBPOP += 1
                 TBLPOP(NBPOP) = [F:HRPOA]COD
                 # suppression de la ligne dans tableau de l'écran
                 Dela J,1 [M:CTR6]NBRPOP
                 [M:CTR6]NBRPOP -= 1
                 [M:CTR6]POPMOD = 1
             Endif
         Endif
      Next
      Sorta [M:CTR6]NBRPOP [M:CTR6]NBRPOP Order By [M:CTR6]POP([S]indice), [M]MAJTYP([S]indice)
      Affzo [M:CTR6]NBRPOP, ZPOP, POP, MAJTYP
        If [M:CTR6]POPMOD
         NBPOP = 0
         For [HRPOA]POA1 Where REFNUM=[F:HRCTR]REFNUM
&                      & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
&                      & TYP=0 & COD<>""
            If !find([F:HRPOA]COD,[M:CTR6]POP(0..[M:CTR6]NBRPOP-1))
               NBPOP += 1
               TBLPOP(NBPOP) = [F:HRPOA]COD
               Delete [HRPOA] Curr
               If fstat=1
                 GOK = -1 : GLOCK = "$POPULA"-[F:HRPOA]COD-[F:HRPOA]REFNUM-[F:HRPOA]CTRNUM-[F:HRPOA]CTRDAT  : Break 2
               Endif
            Endif
         Next
         ## On efface de POPULA toutes les fiches du salarié associées à des sous-populations de la population
         ## stockée dans CODPOP
         Local Char CRITERE_REF
         CRITERE_REF="REFNUM='"+[F:HRPOA]REFNUM+"'"
         For J=1 To NBPOP
            CODPOP = TBLPOP(J)
            Gosub GENPOP From SUBPOP
         Next J
     Endif
     # La maj des populations doit se faire aussi en modification, en tenant compte des éventuelles
     # lignes supprimées manuellement, de façon à ne pas les recréer
     If (ACTION="MODIF")
       Filter [HRPOP] Where CRI<>""
       For [HRPOP]
         If evalue([F:HRPOP]CRI)=1 & !find([F:HRPOP]COD,[M:CTR6]POP(0..[M:CTR6]NBRPOP-1)) & !find([F:HRPOP]COD,TBLPOP)
&         & ([F:HRPOP]LEG="" |[F:HRPOP]LEG= [M:CTR0]LEG)
  #        # Ajout dans le tableau de l'écran
           [M:CTR6]POP([M:CTR6]NBRPOP) = [F:HRPOP]COD
           [M:CTR6]MAJTYP([M:CTR6]NBRPOP) = 1 : # automatique
           [M:CTR6]NBRPOP +=1
           [M:CTR6]POPMOD = 1
           Affzo [M:CTR6]NBRPOP, POP, MAJTYP
         Endif
       Next
       Filter[HRPOP]
       Affzo [M:CTR6]POP, ZPOP, NBRPOP,MAJTYP
     Endif
     If [M:CTR6]POPMOD
         For nolign=1 To [M:CTR6]NBRPOP
            Read [F:HRPOA]POA1 = [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;[M:CTR6]POP(nolign-1)
            If fstat
               [F:HRPOA]COD    = [M:CTR6]POP(nolign-1)
               [F:HRPOA]TYP    = 0
               [F:HRPOA]REFNUM = [F:HRCTR]REFNUM
               [F:HRPOA]CTRNUM = [F:HRCTR]CTRNUM
               [F:HRPOA]CTRDAT = [F:HRCTR]CTRDAT
               If [M:CTR6]MAJTYP(nolign-1)=0
                 [M:CTR6]MAJTYP(nolign-1)=2: # Manuelle
               Endif
               [F:HRPOA]MAJTYP = [M:CTR6]MAJTYP(nolign-1)
               If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
               If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
               If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
               Write [F:HRPOA]
               If fstat
                  GOK = 0 : Call FSTA("HRPOA") From GLOCK : Break 2
               Endif
               CODPOP = [M:CTR6]POP(nolign-1)
               L_MAJTYP =  [M:CTR6]MAJTYP(nolign-1)
               Gosub AJOUTLIS From SUBEML
            Endif
         Next nolign
      Endif
      Sorta [M:CTR6]NBRPOP [M:CTR6]NBRPOP Order By [M:CTR6]POP([S]indice), [M]MAJTYP([S]indice)
      Affzo [M:CTR6]NBRPOP, ZPOP, POP, MAJTYP
    Endif

   If GOK<1 : Return : Endif
   # Population vide
   Read [F:HRPOA]POA0 = "";[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
   If fstat
       Raz [F:HRPOA]
       [F:HRPOA]REFNUM = [F:HRCTR]REFNUM
       [F:HRPOA]CTRNUM = [F:HRCTR]CTRNUM
       [F:HRPOA]CTRDAT = [F:HRCTR]CTRDAT
       [F:HRPOA]MAJTYP = 2 : # Manuelle
       If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
       If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
       If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
       Write [F:HRPOA]
       If fstat
          GOK = 0 : Call FSTA("HRPOA") From GLOCK : Return
       Endif
   Endif
Return
#JOJAC - 2016-06-02 - REQ114309 US215 - END


#JOJAC - 2016-06-02 - REQ114309 US215 - START
$SAUVE_EVT
If dim([F:HRCTR]CCP)>0 & [F:HRCTR]CCP=0 : [F:HRCTR]CCP = 1 : Endif
Raz [F:HRCTR]EVECTRCOD
Raz [F:HRCTR]EVECTRCOD
For nolign=1 To [M:CTR4]NBRDP1
 [F:HRCTR]EVECTRCOD(nolign-1)=[M:CTR4]EVECTRCOD(nolign-1)
 [F:HRCTR]EVECTRDAT(nolign-1)=[M:CTR4]EVECTRDAT(nolign-1)
Next
Return

$INIMOD
If [F:ID]FLGINT<>2 & [M:CTR0]FLGVAR<>2
 Local Integer WOK
 WOK=1
 Call CONTROLE_ENT_CTRGRD([M:CTR0]CTRGRD,1,WOK) #bug 91300 Suite 85360
 If !WOK : GERR=1 : GOK=0 : Endif
Endif

If [M:CTR0]FLGRET<>2
#JOJAC - 2016-06-08 - REQ114309 US215 - START
 #If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2
 If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2 & func DIVPAYE.IS_KFR_LEG(GCURLEG)
#JOJAC - 2016-06-08 - REQ114309 US215 - END
  If max([M:CTR3]PSNENDDAT)<[F:HRCTR]CTRDAT
   # La date du contrat est postérieure aux dates des prestations
#JASMI - 2016-05-31 - REQ 114309 - START
#   GOK=0 : GMESSAGE = mess(56,701,1)
   GOK=0 : GMESSAGE = mess(56,10701,1)
#JASMI - 2016-05-31 - REQ 114309 - END
  Else
   [F:HRCTR]XITDAT = max([M:CTR3]PSNENDDAT)
   [F:HRCTR]XITGRD = "FDC"
  Endif
 Endif
Endif
If [F:HRCTR]FLGVAR=0 : [F:HRCTR]FLGVAR=1 : Endif
Gosub SAUVE_EVT From SUBCTR2

# V01X08 - Délégation maladie disparaît (public seulement), on force la valeur trois si vide
#          pour éviter un effet de bord malencontreux.
If dim([M]DEGMAL) > 0 & [M]DEGMAL = 0
    [M]DEGMAL = 3
Endif

If GPAYE
 Gosub SAVE_RETROCTR From SUBCTRRET
Endif
Return

## Controle date de sortie / dates d'entrée pour les non artistes
########################################################
Subprog CONTROLE_ENT_CTRGRD(PCTRGRD,PMAJ,POK)
Value Char PCTRGRD()
Value Integer PMAJ
Variable Integer POK
Local Integer SORTIE_VIDE, OK, I
Local Char    CRITERE(250)
Local Date    OLDDAT
Local Char    OLDCTR(GLONCTR)
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
If clalev([F:MOE])=0  : Local File MOTENT   [MOE]  : Endif

If [M:CTR8]XITDAT=[00/00/00]
 SORTIE_VIDE = 1
 I = 1
Endif
Raz OLDCTR
#JOJAC - 2016-06-02 - REQ114309 US215 - START
#If [M:CTR0]REFNUM<>[F:ID]REFNUM
# Read [ID]ID0=[M:CTR0]REFNUM
# If fstat : POK=0 : End : Endif
#Endif
Read [ID]ID0=[M:CTR0]REFNUM
#JOJAC - 2016-06-02 - REQ114309 US215 - END

If [F:ID]FLGMULCTR=2
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & FLGVAR<>2
Else
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & FLGVAR<>2
Endif

#Verif chronologie
For [CTR1]CTR1
 If [F:CTR1]CTRNUM<>[M:CTR0]CTRNUM | [F:CTR1]CTRDAT<>[M:CTR0]CTRDAT
  If [F:CTR1]XITDAT="00/00/00"
   SORTIE_VIDE +=1
   OLDCTR=[F:CTR1]CTRNUM
   If [F:CTR1]CTRNUM=[M:CTR0]CTRNUM & [F:CTR1]CTRDAT<>[M:CTR0]CTRDAT
    I +=1
    OLDDAT = [F:CTR1]CTRDAT
   Endif
  Endif
  If ([F:CTR1]XITDAT>=[M:CTR0]CTRDAT & [F:CTR1]CTRDAT<=[M:CTR8]XITDAT & [M:CTR8]XITDAT<>[0/0/0] & [F:CTR1]XITDAT<>[0/0/0])
&|   ([F:CTR1]CTRDAT>=[M:CTR0]CTRDAT & [F:CTR1]XITDAT=[0/0/0] & ([M:CTR8]XITDAT=[0/0/0] | [M:CTR8]XITDAT>=[F:CTR1]CTRDAT))
&|   ([F:CTR1]XITDAT>=[M:CTR0]CTRDAT & ([F:CTR1]CTRDAT<=[M:CTR0]CTRDAT | ([F:CTR1]CTRDAT>[M:CTR0]CTRDAT & [M:CTR8]XITDAT=[0/0/0])
&&    [F:CTR1]XITDAT<>[0/0/0]))

   # La période du contrat chevauche celle d'un contrat déja existant :
#JASMI - 2016-05-31 - REQ 114309 - START
#   GMESSAGE = mess(35,701,1)-num$([F:CTR1]CTRDAT)-num$([F:CTR1]XITDAT)
   GMESSAGE = mess(35,10701,1)-num$([F:CTR1]CTRDAT)-num$([F:CTR1]XITDAT)
#JASMI - 2016-05-31 - REQ 114309 - END
   POK = 0 : Break
  Endif
 Endif
Next
Filter [CTR1]

If !POK : End : Endif

If SORTIE_VIDE>1
 If [M:CTR8]XITDAT=[00/00/00] & I=2
  Gosub TR_ENT_CTRGRD
 Else
  # Un contrat encore actif existe pour ce matricule
#JASMI - 2016-05-31 - REQ 114309 - START
#  GMESSAGE = mess(137,701,1)-[M:CTR0]REFNUM-"/"-OLDCTR
  GMESSAGE = mess(137,10701,1)-[M:CTR0]REFNUM-"/"-OLDCTR
#JASMI - 2016-05-31 - REQ 114309 - END
  POK = 0
 Endif
Elsif SORTIE_VIDE=1 & [M:CTR8]XITDAT<>[0/0/0] & OLDDAT<[M:CTR0]CTRDAT & OLDDAT<>[0/0/0] #bug 91300 Suite 85360
 Gosub TR_ENT_CTRGRD
Endif
If !POK : End : Endif
End

$TR_ENT_CTRGRD
Read[F:HRCGD]HRCGD0=PCTRGRD;GCURLEG
If fstat
 Read[F:HRCGD]HRCGD0=PCTRGRD;""
Endif
If !fstat & [F:HRCGD]CTRXITAUT=2 & [F:HRCGD]CTRXITGRD<>""
  If PMAJ
   Readlock [CTR1]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;OLDDAT
   If fstat=1
    GOK=-1 : GLOCK="$EMPLOCTR"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-num$(OLDDAT) : Return
   Elsif fstat
    GOK=0 : Call FSTA("CTR1") From GLOCK : Return
   Endif
   [F:CTR1]XITDAT = [M:CTR0]CTRDAT-1
   [F:CTR1]XITGRD = [F:HRCGD]CTRXITGRD
   Rewrite [CTR1]
   If fstat
    GOK=0 : Call FSTA("CTR1") From GLOCK : Return
   Endif
  Endif
Else
 # Un contrat encore actif existe pour ce matricule
 GMESSAGE = mess(137,10701,1)-[M:CTR0]REFNUM-"/"-OLDCTR
 POK = 0
Endif
Return

#JASMI - 2016-06-06 - REQ 114309 - START
#$RAZDUP
##JOJAC - 2016-06-02 - REQ114309 US215 - START
#If GINTMT=1
#  If [F:ID]FLGINT<>2
#    Grizo [CTR3]
#  Else
#    Effzo [M:CTR3]AEMNUM
#    Effzo [M:CTR3]30
#  Endif
#Endif
#
#If dim([M:CTR1]FLGDUE)>0 Then
#  Effzo [M:CTR1]FLGDUE
#Endif
#[M:CTR0]FLGVAR=1
#Gosub RAZRETRO
#Call INI_GRDEXUDSN([F:ID]FLGPAY) From SUBCTR2
##JOJAC - 2016-06-02 - REQ114309 US215 - END
#Return
#JASMI - 2016-06-06 - REQ 114309 - END

$RAZRETRO
If GPAYE
 Raz [M:CTR0]RETDATEFF
 [M:CTR0]FLGRET=1
 Affzo [M:CTR0]
 Effzo [M:CTRA] : Grizo [M:CTRA]
Endif
Return

$CRE_PSN
[F:PSN]CTRNUM    = [M:CTR0]CTRNUM
[F:PSN]REFNUM    = [M:CTR0]REFNUM
[F:PSN]CTRDAT    = [M:CTR0]CTRDAT
For nolign=1 To [M]NBRPSN
 [F:PSN]       = [M:CTR3]
 [F:PSN]PSNNUM = nolign
 Write [PSN]
 If fstat
  GOK=0 : Call FSTA("PSN") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
Return

$MAJ_EMPLOID
If [M:CTR0]FLGVAR=2 : Return : Endif
Readlock [ID]ID0=[M:CTR0]REFNUM
If fstat=1
 GOK=-1 : GLOCK="$EMPLOID"-[M:CTR0]REFNUM
 Return
Elsif fstat
 GOK=0 : Call FSTA("ID") From GLOCK
 Return
Endif
Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM
[F:ID]NBRCTR = rowcount([CTR1])
Read [CTR1]CTR1 Last
Filter [CTR1]

If func DIVPAYE.EXISTE_KXX("SUBCTRKPO") Then
  Gosub MAJ_EMPLOID From SUBCTRKPO
Endif

[F:ID]FCY      = [F:CTR1]ETRFCY
[F:ID]SRV      = [F:CTR1]ETRSRV
[F:ID]PRF      = [F:CTR1]PROPRF
Read [FCY]FCY0=[F:CTR1]ETRFCY
[F:ID]CPY      = [F:FCY]LEGCPY
Rewrite [F:ID]
If fstat
 GOK=0 : Call FSTA("ID") From GLOCK : Return
Endif
#JASMI - 2016-05-23 - START
#Gosub MAJ_EMPLOID From SUBCTR2
#JASMI - 2016-05-23 - END
Return

$MAJ_TIMEMP2
Local Date MCTRDA
Local Integer WINIT, WINIT_ANA
WINIT=0 : WINIT_ANA=0
CRITCTRL="1=1"
If WACTION="AP_ANNULE" or WACTION="APRES_CRE" or WACTION="APRES_MOD"
  CRITCTRL="REFNUM='"+W_TIP_REFNUM+"'"
  CRITCTRL += "& CTRNUM='"+W_TIP_CTRNUM+"'"
  If W_TIP_CTRDAT<>[0/0/0]
   CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$(W_TIP_CTRDAT)+"])"
   CRITCTRL-="& DATPYR>=["+num$(W_TIP_CTRDAT)+"]"
  Endif
  If W_TIP_XITDAT<>[0/0/0]
   CRITCTRL-="& ENDDAT<=["+num$(W_TIP_XITDAT)+"]"
  Endif
Endif

Local Char    W_TIP_CPY(GLONCPY)
GMESSAGE=""
If WACTION<>"APRES_MOD" Then
  W_TIP_ETRFCY=[F:CTR1]ETRFCY
  W_TIP_ETRSRV=[F:CTR1]ETRSRV
Endif
If WACTION="APRES_MOD"
  If clalev([F:DSP])=0 : Local File CADSP [DSP] : Endif
  For [TIP]TIP2 Where evalue(CRITCTRL)
    Gosub MAJ_TPS
   If fstat
    GOK=0 : Call FSTA("TIP") From GLOCK : Break
   Endif
  Next
Else
  For [TIP]TIP2 Where REFNUM=[F:CTR1]REFNUM & CTRNUM=[F:CTR1]CTRNUM &
& (STRDAT>=[F:CTR1]CTRDAT or (WACTION="AP_ANNULE" or WACTION="APRES_CRE" & evalue(CRITCTRL)))
    Gosub MAJ_TPS
   If fstat
    GOK=0 : Call FSTA("TIP") From GLOCK : Break
   Endif
  Next
Endif
Return

$MAJ_TPS
Local Char    ACMCUR_OLD(GLONGCM), ACMCUR_NEW(GLONGCM)

  Call SETGCM([F:TIP]FCY,ACMCUR_OLD) From CPTDIV : # Récupération du modèle de l'ancienne société
  [F:TIP]FCY=W_TIP_ETRFCY
  [F:TIP]SRV=W_TIP_ETRSRV
  W_TIP_CPY=func DIVPAYE.GETSOC([F:TIP]FCY)
  If [F:TIP]CPY<>W_TIP_CPY Then
    [F:TIP]CPY=W_TIP_CPY
    If GOPTCANA Then
      Call SETGCM([F:TIP]FCY,ACMCUR_NEW) From CPTDIV
      If ACMCUR_NEW<>ACMCUR_OLD Then
        Gosub MAJ_ANA From SUBCTR2
        If !WINIT_ANA & !GSERVEUR & !GIMPORT
          GERR=2
#JASMI - 2016-05-31 - REQ 114309 - START
#          GMESSAGE=mess(165,701,1) : # Les données analytiques des événements temps ont été recalculées.
          GMESSAGE=mess(165,10701,1) : # Les données analytiques des événements temps ont été recalculées.
#JASMI - 2016-05-31 - REQ 114309 - END
          WINIT_ANA=1
        Endif
      Endif
    Endif
  Endif

  MCTRDA=func TPSSTD.CALC_CTRDATDEF(W_TIP_REFNUM,W_TIP_CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  If  MCTRDA <> [F:TIP]CTRDAT Then
    [F:TIP]CTRDAT=MCTRDA
    #Les périodes d'activités du contrat ont été affectées aux évènements temps.
    If !WINIT & !GSERVEUR & !GIMPORT
      GERR=2
      If GMESSAGE<>"" Then
        GMESSAGE += chr$(10)+chr$(13)
      Endif
#JASMI - 2016-05-31 - REQ 114309 - START
#      GMESSAGE+=mess(141,701,1)
      GMESSAGE+=mess(141,10701,1)
#JASMI - 2016-05-31 - REQ 114309 - END
      WINIT=1
    Endif
  Endif
  Rewrite [F:TIP]
Return

$CHARGE_CTR3
# Appelé aussi par SUBENT

#JOJAC - 2016-06-08 - REQ114309 US215 - START
#If GINTMT=1
If GINTMT=1 & func DIVPAYE.IS_KFR_LEG(GCURLEG)
#JOJAC - 2016-06-08 - REQ114309 US215 - END
 If [F:ID]FLGINT<>2
  Effzo [CTR3]
  [M:CTR3]STACTR = [F:HRCTR]STACTR
  Grizo [CTR3]
 Else
  Actzo [CTR3]
  nolign = 1
  ## Add filter on CTRDAT
  For [PSN]PSN0 Where CTRNUM=[F:HRCTR]CTRNUM & CTRDAT=[F:HRCTR]CTRDAT
   [M:CTR3] = [F:PSN]
   If [F:PSN]BUL<>""
    Read [VEP]VEP5=[F:PSN]BUL
    If !fstat
     [M:CTR3]PYRDAT(nolign-1) = [F:VEP]PYRDAT
    Endif
   Endif
   nolign +=1
  Next
  [M:CTR3]NBRPSN = nolign-1
  Sorta [M]NBRPSN [M]NBRPSN Order By PSNSTRDAT([S]indice)
 Endif
 Affzo [CTR3]
Endif
Return

Subprog LIB_PLANNING(VALEUR)
Value Char VALEUR
Local Integer ANNEE
If VALEUR<>""
 ANNEE=year(GMOIPAY)
 # Contrat actif sur le mois de paye
 If [F:HRCTR]FLGRET<>2 & year([F:HRCTR]CTRDAT)>year(GMOIPAY)
  ANNEE=year([F:HRCTR]CTRDAT)
 Elsif [F:HRCTR]FLGRET=2 & year([F:HRCTR]RETDATEFF)>year(GMOIPAY)
  ANNEE=year([F:HRCTR]RETDATEFF)
 Elsif [F:HRCTR]XITDAT<>[0/0/0] & year([F:HRCTR]XITDAT)<year(GMOIPAY)
  ANNEE=year([F:HRCTR]XITDAT)
 Endif
 Filter [PLN] Where COD=VALEUR & YEA=ANNEE
 Read [PLN]PLN1 Last
 Filter [PLN]
 If !fstat
  [M]PLNDES = [F:PLN]DES
 Else
#JASMI - 2016-05-31 - REQ 114309 - START
#  GMESSAGE=VALEUR-":"-mess(84,701,1)-num$(ANNEE)
  GMESSAGE=VALEUR-":"-mess(84,10701,1)-num$(ANNEE)
#JASMI - 2016-05-31 - REQ 114309 - END
  mkstat=2 : End
 Endif
Else
  [M]PLNDES=""
Endif
End

Subprog AS_WAGPAYPER(VALEUR)
Variable Integer  VALEUR
# Par défaut "mensuel" ...
#JOJAC - 2016-06-02 - REQ114309 US215 - START
