######################################################################################
Subprog S_STRDATLVE(VALEUR)
Variable Date    VALEUR

Local Integer NBHRPEO
Local Integer PEOPERIOD
Local Char LIBHRPEO(130)(0..)
Local Char    TITLE(250) : TITLE = mess(164,107,1)+" "+mess(27,114,1)
Local Date STRARR(1..)

If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif

If dim([M]PERCOD)>0
  Filter [HRPEOD] Where PERCOD=[M]PERCOD Order By PYRDAT Desc
Else
  Filter [HRPEOD] Where PERCOD=PARAM(1) Order By PYRDAT Desc
Endif
Read [HRPEOD] Last

If rowcount([HRPEOD]) = 0
  GERR = 2 : GMESSAGE = mess(92,10703,1) #### MIPEA make better message here
Endif

For [F:HRPEOD]
  NBHRPEO+=1
  STRARR(NBHRPEO) = [F:HRPEOD]PERSTR(1)
  LIBHRPEO(NBHRPEO) = [F:HRPEOD]PERCOD-" - "-num$([F:HRPEOD]PERYEA)-" - "-num$([F:HRPEOD]PERSTR(1))
Next

Call SAITEX(NBHRPEO,LIBHRPEO,PEOPERIOD,TITLE) From GESECRAN # Choose extraction periods

If PEOPERIOD>0
  VALEUR = STRARR(PEOPERIOD)
Else
  VALEUR=""
Endif
Filter [HRPEOD]

End

Subprog S_ENDDATLVE(VALEUR)
Variable Date    VALEUR

Local Integer NBHRPEO
Local Integer PEOPERIOD
Local Char LIBHRPEO(130)(0..)
Local Char    TITLE(250) : TITLE = mess(164,107,1)+" "+mess(18,2,1)
Local Date ENDARR(1..)

If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif

Filter [HRPEOD] Where PERCOD=[M]PERCOD Order By PYRDAT Desc

Read [HRPEOD] Last

If rowcount([HRPEOD]) = 0
  GERR = 2 : GMESSAGE = mess(92,10703,1)
Endif

For [F:HRPEOD]
  NBHRPEO+=1
  ENDARR(NBHRPEO) = [F:HRPEOD]PEREND(1)
  LIBHRPEO(NBHRPEO) = [F:HRPEOD]PERCOD-" - "-num$([F:HRPEOD]PERYEA)-" - "-num$([F:HRPEOD]PEREND(1))
Next

Call SAITEX(NBHRPEO,LIBHRPEO,PEOPERIOD,TITLE) From GESECRAN # Choose extraction periods
If PEOPERIOD>0
  VALEUR = ENDARR(PEOPERIOD)
Else
  VALEUR=""
Endif
Filter [HRPEOD]

End
#MIPEA - 2017-08-12- US X3-39538- END
#LIMAS - 2017-09-20- US X3-55115- START
Subprog CHK_CTR(EML,CTR,MKSTR)
Variable Char EML ()
Variable Char CTR
Variable Integer MKSTR
MKSTR=0
If !clalev([TIP8]) : Local File TIMEMP [TIP8] : Endif
If !clalev([TIG8]) : Local File TIMREGUL [TIG8] : Endif
If !clalev([DCG8]) : Local File DEMCONGE [DCG8] : Endif

Filter [DCG8] Where [DCG8]REFNUM = EML and [DCG8]CTRNUM = CTR
  Read [DCG8]DCG0 Last
  Filter [DCG8]
  If !fstat : MKSTR=1 : Endif

Filter [TIP8] Where [TIP8]REFNUM = EML and [TIP8]CTRNUM = CTR
  Read [TIP8]TIP0 Last
  Filter [TIP8]
  If !fstat : MKSTR=1 : Endif

Filter [TIG8] Where [TIG8]REFNUM = EML and [TIG8]CTRNUM = CTR
  Read [TIG8]TIG0 Last
  Filter [TIG8]
  If !fstat : MKSTR=1 : Endif

End
#LIMAS - 2017-09-20- US X3-55115- END
