$LIENS
# Multi_leg & multi_société
Call LECTURE("FCY",[M:CTR0]ETRFCY,"") From CONTOBJ
#JOJAC - 2016-06-02 - REQ114309 US215 - START
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#GSOCIETE=[F:FCY]LEGCPY : [M:CTR0]CPY=GSOCIETE
GSOCIETE=[F:CPY]CPY : [M:CTR0]CPY=GSOCIETE
If dim([F:CPY]LEG)>0
  GCURLEG=[F:CPY]LEG : [M:CTR0]LEG=GCURLEG
  Local Char    LEGI,LEGC
  Local Integer PNOLIB,OKPAR

  Call VERIF_AML_EML([M:CTR0]ETRFCY,[M:CTR4]CIVCTR,1,"CIVIL",PNOLIB,LEGI,LEGC,OKPAR) From SUBCTR2
  [M:CTR4]NOLIB=PNOLIB
  Actzo [M:CTR4]CIVCTRA
  If OKPAR Then
    If [M:CTR4]CIVCTR>0 Then [M:CTR4]CIVCTRA=mess([M:CTR4]CIVCTR,[M:CTR4]NOLIB,1) : Endif
    #JOJAC - 2016-07-28 - REQ114309 - START
#    If LEGI=LEGC Then
#      Grizo [M:CTR4]CIVCTRA
#    Endif
    #JOJAC - 2016-07-28 - REQ114309 - END
  Endif

#JOJAC-START
  Call VERIF_AML_EML([M:CTR0]ETRFCY,[M:CTR4]SITFAM,1,"SITFAM",PNOLIB,LEGI,LEGC,OKPAR) From SUBCTR2
  [M:CTR4]NOLIBM=PNOLIB
  If([M:CTR4]SITFAM<>0)
    [M:CTR4]SITFAMA = mess([M:CTR4]SITFAM,[M:CTR4]NOLIBM,1)
  Else
    [M:CTR4]SITFAMA=""
  Endif
  Affzo [M:CTR4]SITFAMA
#JOJAC - END
 Endif

# Compare the country of the main site of the employee, and the country of the
# site of the contract, to determine if the fields can be seizable or not
Call SEIZE_NUMSSC([M:CTR0]ETRFCY)
#JOJAC - 2016-06-02 - REQ114309 US215 - END

If [M]RPL(dim([M]RPL)-1)<>""
 [M]NBRRPL = dim([M]RPL)
Else
 [M]NBRRPL = find("",[M]RPL) - 1
Endif

Look [ELC]ELC0=[F:HRCTR]REFNUM;[F:HRCTR]ETRFCY
[M]MAIFCY=1+!fstat

If [F:HRCTR]REFNUM<>[F:ID]REFNUM
 Read [ID]ID0=[F:HRCTR]REFNUM
 If fstat : Return : Endif
Endif
[M]SRN = [F:ID]NAM-[F:ID]SRN


Gosub GRISE From SUBCTR2
Gosub CHARGE_CTR3 From SUBCTR2
Gosub CHARGE_EPC_SAL From SUBCTR2
Gosub CHARGE_EVT From SUBCTR2
Gosub CHARGE_CPR From SUBCTR2
Gosub CHARGE_BULDEM From SUBCTR2
