End

Subprog MRGDAT(VALEUR)
Value Integer VALEUR
If (func DIVPAYE.IS_KAO_LEG(GCURLEG) or func DIVPAYE.IS_KSZ_LEG(GCURLEG) or func DIVPAYE.IS_KLS_LEG(GCURLEG))
  If VALEUR = 1
    If dim([M:CTR4]MRGDAT)>0 : Effzo [M:CTR4]MRGDAT : Endif
    If dim([M:CTR4]MRGDAT)>0 : Grizo [M:CTR4]MRGDAT : Endif
  Else
    If dim([M:CTR4]MRGDAT)>0 : Actzo [M:CTR4]MRGDAT : Endif
  Endif
Else
  If dim([M:CTR4]MRGDAT)>0 : Actzo [M:CTR4]MRGDAT : Endif
  If dim([M:CTR4]MRGDAT)>0 : Affzo [M:CTR4]MRGDAT : Endif
  If dim([M:CTR4]MRGDAT)>0 : Chgfmt [M:CTR4]MRGDAT  With "-D:"+GFMDAT4 : Endif
Endif
End
### AWAITING MULTI CURRENCY
#TIVAN - 2017-03-24 - JIRA:  - START
Subprog C_CUR(VALEUR)
Variable Char    VALEUR()

  If VALEUR = ""
    If !clalev([F:ZCPY]) Local File COMPANY [F:ZCPY] Endif
    Read [F:ZCPY]CPY0 = [M:CTR0]CPY
    If !fstat
      VALEUR = [F:ZCPY]ACCCUR
      Affzo [M:CTR1]CUR
    Endif
  Endif

#MIPEA - 2017-10-23- US X3-58562- START
Filter [F:VEP] Where EMP = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CURCOD = [M:CTR1]CUR
If rowcount([F:VEP])>0
  Grizo [M:CTR1]CUR
Else
  Actzo [M:CTR1]CUR
Endif
Filter [F:VEP]
#MIPEA - 2017-10-23- US X3-58562- END
End
#TIVAN - 2017-03-24 - JIRA:  - END
Subprog AM_STACTR(VALEUR)
Variable Integer VALEUR

If VALEUR=2 & [M:CTR0]XITDAT=[0/0/0] & [M:CTR3]NBRPSN>0
  [M:CTR0]XITDAT=max([M:CTR3]PSNENDDAT) : Affzo [M:CTR0]XITDAT
  If [M:CTR8]XITDAT=[0/0/0]
    [M:CTR8]XITDAT=[M:CTR0]XITDAT : [M:CTR8]XITGRD="FDC" : Affzo [M:CTR8]5
  Endif
Endif
End

Subprog MULCTR(VREFNUM,VCTRNUM,ISOK)
Variable Char VREFNUM,VCTRNUM
Variable Integer ISOK : ISOK=2
##JOJAC - 2016-07-21 - REQ114309 - START
 If GREP='C' | VCTRNUM=""
   Filter [F:ID] Where REFNUM = VREFNUM
   If [F:ID]FLGMULCTR=1
     Filter [F:HRCTR] Where REFNUM = VREFNUM and XITDAT = [0/0/0]
       Read [F:HRCTR]CTR0 First
       If !fstat
         GERR = 2  : GMESSAGE = mess(190,10701,1)
         ISOK = 1
       Endif
   Endif
    Filter [F:ID]
    Filter [F:HRCTR]
 Endif
##JOJAC - 2016-07-21 - REQ114309 - END
End

