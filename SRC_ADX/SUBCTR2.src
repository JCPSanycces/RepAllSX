Subprog C_PLNTYP(VALEUR)
Variable Char    VALEUR()
Local Integer PLNFIRDAY, HRPEOFIRDAY

PLNFIRDAY = [F:PLN]FIRDAY

If clalev([HRPEOH8])=0 : Local File HRPEOHEA [HRPEOH8] : Endif
If clalev([F:HRPEOD8])=0 : Local File HRPEODET [HRPEOD8] : Endif

#JASMI - 2017-12-06 - X3-67453 - START
#Link [HRPEOH8] With [F:HRPEOD8]HRPEOD0(1) = [HRPEOH8]PERCOD As [LNK] Where [HRPEOH8]FLGENA=2
Link [HRPEOH8]
& With [F:HRPEOD8]HRPEOD0(1) = [HRPEOH8]PERCOD
& As [LNK]
& Where [HRPEOH8]FLGENA=2 & [HRPEOH8]PERCOD=[M:CTR1]PERCOD
#JASMI - 2017-12-06 - X3-67453 - END

Read [LNK] First

HRPEOFIRDAY = dayn([F:HRPEOD8]PERSTR(0))

If PLNFIRDAY <> HRPEOFIRDAY & VALEUR <> ""
  GMESSAGE = mess(257,10702,1)
  mkstat   = 2
Endif

#LIPET - 2018-02-26 - X3-68707 - START
If clalev([F:ID1])=0 : Local File EMPLOID [ID1] : Endif
Read [F:ID1]ID0=[M]REFNUM
If !fstat & VALEUR="" & [F:ID1]FLGTPS=2 Then
  GMESSAGE=mess(10,123,1):mkstat=2:End : #Mandatory Field when time management is active
Endif
Filter [F:ID1]
#LIPET - 2018-02-26 - X3-68707 - END

End
#MIPEA - 2017-11-29- US X3-63170- END
