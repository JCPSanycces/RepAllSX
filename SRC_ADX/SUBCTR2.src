#PEVAN - 2018-06-13 - X3-92482 - START
Case ACTION
 When "CREATION"   : Gosub CREATION
 When Default
Endcase
#PEVAN - 2018-06-13 - X3-92482 - END

##FRLAA and JASMI - 2015-02-16 - Requirement 104592 US 3261 - END
If ACTION = "OUVRE"
  If func AFNC.ACTIV("KZA")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Gosub ACTION From SUBCTRKSA
  Endif
  If func AFNC.ACTIV("KMIEA")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRMID") Then
    Gosub ACTION From SUBCTRMID
  Endif
  If func AFNC.ACTIV("KAQ")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRKAQ") Then
    Gosub ACTION From SUBCTRKAQ
  Endif
#JASMI - 2016-10-17 - UK and US - START
  If func AFNC.ACTIV("KUK")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRUKI") Then
    Gosub ACTION From SUBCTRUKI
  Endif
  If func AFNC.ACTIV("KUS")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRNA") Then
    Gosub ACTION From SUBCTRNA
  Endif
#JASMI - 2016-10-17 - UK and US - END
Else
  If func DIVPAYE.IS_KZA(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Gosub ACTION From SUBCTRKSA
  Endif
  If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBCTRMID") Then
    Gosub ACTION From SUBCTRMID
  Endif
  If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBCTRKAQ") Then
    Gosub ACTION From SUBCTRKAQ
  Endif
#JASMI - 2016-10-17 - UK and US - START
  If GCURLEG="BRI" & func DIVPAYE.EXISTE_KXX("SUBCTRUKI") Then
    Gosub ACTION From SUBCTRUKI
  Endif
  If GCURLEG="USA" & func DIVPAYE.EXISTE_KXX("SUBCTRNA") Then
    Gosub ACTION From SUBCTRNA
  Endif
#JASMI - 2016-10-17 - UK and US - END
Endif
#JASMI - 2016-06-01 - REQ 114309 - END

Return
