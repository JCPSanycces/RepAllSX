    Filter [F:DCGCTR] Where [F:DCGCTR]CTRNUM=[M:CTR0]CTRNUM
&     and [F:DCGCTR]ENDDAT > [M:CTR0]CTRDAT
&     and ([F:DCGCTR]STA = 1 | [F:DCGCTR]STA = 2 | [F:DCGCTR]STA = 3 | [F:DCGCTR]STA = 5 | [F:DCGCTR]STA = 7)

    If rowcount([F:DCGCTR]) > 0
      GOK = 0
      GERR = 1
      GMESSAGE = mess(42,11691,1)
    Endif

    Close File [F:DCGCTR]
  Endif
Return
