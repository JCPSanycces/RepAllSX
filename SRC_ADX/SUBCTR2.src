Subprog GRISE_GRDCDD (VALEUR)
Value Char VALEUR ()
Local Integer WISTRAINEE #US3750 108474 Stagiaire
Local Char ZONE(10) : ZONE = "CDDGRD"
Gosub SET_ZONE From SUBCTR
If MA
 WISTRAINEE=func DIVPAYE.ISTRAINEE(VALEUR)  : #US3750 108474 Stagiaire
 Gosub CHGTZON_MATREMP From SUBCTR2 : #US3750 108474 Stagiaire
 #If VALEUR<>"02" & VALEUR<>"03" & VALEUR<>"25" & VALEUR<>"26" & VALEUR<>"27" & VALEUR<>"28" & VALEUR<>"04" & VALEUR<>"05"
If !func DIVPAYE.ISCDD(VALEUR)
& & !WISTRAINEE  #US3750 108474 Stagiaire
#JOJAC - 2016-06-17 - REQ114309 US215 - START
  #If !func DIVPAYE.ISKMIEAFLD(VALEUR) #FRLAA 2015-05-27 - Requirement 105483 US 3571
   If !func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
#JOJAC - 2016-06-17 - REQ114309 US215 - END
    Effzo CDDGRD, PERCON, NBRPER, ENDCON, MATREMP, ZCDDGRD
    Grizo CDDGRD, PERCON, NBRPER, ENDCON, MATREMP
    If dim([M]SRNRPL) > 0 : Raz [M]SRNRPL : Affzo SRNRPL : Endif #US3750 108474 Stagiaire
  Endif
 Else
  #105476 - US 3421
  If VALEUR="COD"
   Grizo CDDGRD
  Else
   Actzo CDDGRD
  Endif
  Actzo PERCON, NBRPER, ENDCON
  If [M]CDDGRD="REM" | [M]CDDGRD="RPL"
&    | WISTRAINEE #US3750 108474 114634 Stagiaire
   Actzo MATREMP
  Else
   Effzo MATREMP
   Grizo MATREMP
   If dim([M]SRNRPL) > 0 : Raz [M]SRNRPL : Affzo SRNRPL : Endif #US3750 108474 Stagiaire
  Endif
 Endif
Endif
End

