Subprog MAJ_CHGTZON_MATREMP(PPROG,PISSTA,PMSK,ZONE,PINTIT,POK)
Value Char PPROG()
Value Integer PISSTA
Value Char PMSK()
Value Char ZONE()
Variable Char PINTIT()
#JOJAC - 2016-06-02 - REQ114309 US215 - START (GX3APP)
Variable Integer POK
#SBA :
#Value Integer POK
#JOJAC - 2016-06-02 - REQ114309 US215 - END
[L]POK=0
If [L]PISSTA : # Stagiaire.
   [L]POK=1
#JASMI - 2016-05-31 - REQ 114309 - START
#   [L]PINTIT=mess(182,701,1) :#Tuteur
   [L]PINTIT=mess(182,10701,1) :#Tuteur
#JASMI - 2016-05-31 - REQ 114309 - END
Else
  Gosub SET_ZONE From =PPROG
  If MA
    Local Char WAMK(GLONAMK)
    If !clalev([F:AMZ])   : Local File AMSKZON  [AMZ]   : Endif
    If !clalev([F:ATX])   : Local File ATEXTE   [ATX]   : Endif
    [L]WAMK = [L]PMSK +num$(MA-1)
    Read [AMZ]CODE =WAMK;[L]ZONE
    If(!fstat)
      Read [F:ATX]NUMERO=GLANGUE;[AMZ]INTIT
      If ! fstat
        [L]POK=1
        [L]PINTIT=[F:ATX]TEXTE
      Endif
    Endif
  Endif
Endif
End

#US3750 108474 Stagiaire
Subprog DISPLAY_SRNRPL(VALEUR)
Variable Char    VALEUR()
