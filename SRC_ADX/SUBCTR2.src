End

########################################################
Subprog GRISE_FORFAIT (VALEUR,CHAMP)
Value Decimal VALEUR
Value Char    CHAMP
Local Char ZONE(10) : ZONE = "DNACODTIM"
Gosub SET_ZONE From SUBCTR
If MA
 If !VALEUR
#   Actzo DNACODTIM
   If CHAMP="NBRDAYCTR" Then
    Actzo [M]DNACODTIM
   Endif
   If CHAMP="NBRHOUCTR" Then
    If [M]DNACODTIM=5 & [M]NBRDAYCTR<>0 Then
      Grizo [M]DNACODTIM
    Else
      Actzo [M]DNACODTIM
    Endif
   Endif
   If CHAMP="NBRDAYCTR" Then
    Actzo [M]NBRHOUCTR
   Else
    Actzo [M]NBRDAYCTR
   Endif
 Else
  If CHAMP="NBRDAYCTR" Then
    [M]DNACODTIM = 5 :#Forfait jours
    [M]NBRHOUCTR=0 : Grizo [M]NBRHOUCTR
    Grizo DNACODTIM
  Else
    [M]DNACODTIM = 6 :#Forfait heures
    [M]NBRDAYCTR=0 : Grizo [M]NBRDAYCTR
    Actzo DNACODTIM
  Endif
 Endif
 Affzo DNACODTIM
Endif
End

########################################################
Subprog GRISE_FLGPAY(VALEUR)
Value Integer VALEUR
Local Char ZONE(10)
For ZONE = "ENDTRY","NEWTRY","ENDTRY2","COE","GRA","IND","CLLCVT","RSKWRK","STAEMP","NUMASS",
& "RPTBUL","INSAMT","INSDAY","EXOCOD1","EXOCOD2", "EXOCOD3","EXOCOD4","AFFMUT","NUMBNF","CATCSP","CTRCODSEE","STACAT","STACAT2",
& "CATJOB","AVNNAT","EXSPFL","WRKSTG","CODCNB","DED","OPEDED","CATDED","TIP","NTIC","SYSMAL","SYSAT","SYSVIP","SYSFLG",
& "SEVEMP","STRDATSEV","ENDDATSEV","SEVCTR","DNASITADM","DNACPYSTG","DNAACTASS","DNACCP","CCP","NUMCCP","RSKASS","PRUCOL","PRUACV",
& "PRUVOT","PRUCTR"
 Gosub SET_ZONE From SUBCTR
 #JOJAC - 2016-06-08 - REQ114309 US215 - START
 #If GDOSLEG<>"FRA" & find(ZONE,"NUMASS","SYSAT","SYSVIP","SYSFLG")>0  Then MA=0 : Endif
 #If GDOSLEG="POR"  & find(ZONE,"INSAMT","INSDAY")>0                   Then MA=0 : Endif
 If !func DIVPAYE.IS_KFR_LEG(GCURLEG) & find(ZONE,"NUMASS","SYSAT","SYSVIP","SYSFLG")>0  Then MA=0 : Endif
 If func DIVPAYE.IS_KPO_LEG(GCURLEG)  & find(ZONE,"INSAMT","INSDAY")>0                   Then MA=0 : Endif
 #JOJAC - 2016-06-08 - REQ114309 US215 - END
 # Issue 105418 US7- 2016-04-21 by BRBAN : If it is a migrated customer, this field must appear.
 If func AFNC.ACTIV("PORMI")>0
  If find(ZONE,"NUMASS") : MA = 1 : Endif
 Endif
 # -

 If MA
  If VALEUR=2
   Actzo =ZONE
  Else
   Effzo =ZONE
   Grizo =ZONE
  Endif
 Endif
Next
End

########################################################
Subprog GRISE_SORTIE(VALEUR)
Value Date VALEUR
Local Char ZONE(10) : ZONE = "NTFDAT"
Gosub SET_ZONE From SUBCTR
If MA
 If VALEUR=[0/0/0]
  Effzo XITFNL,XITGRD,NTFDAT,LSTDAY,XITLEA,DATLIC,DNACLC,FLGINDSUP,FLGALCCHO,CLEEVETIM
  Grizo XITFNL,XITGRD,NTFDAT,LSTDAY,XITLEA,DATLIC,DNACLC,FLGINDSUP,FLGALCCHO,CLEEVETIM
  If GPAYE : Effzo RAZCUM : Grizo RAZCUM : Endif
 Elsif [F:ID]FLGPAY<>2  & GPAYE
  Effzo NTFDAT,LSTDAY,XITLEA,DATLIC,DNACLC,FLGINDSUP
  Grizo NTFDAT,LSTDAY,XITLEA,DATLIC,DNACLC,FLGINDSUP
  Actzo XITFNL,XITGRD,FLGALCCHO,CLEEVETIM
  If GPAYE : Effzo RAZCUM : Grizo RAZCUM : Endif
 Else
  Actzo XITFNL,XITGRD,NTFDAT,LSTDAY,XITLEA,DATLIC,DNACLC,FLGINDSUP,FLGALCCHO,CLEEVETIM
  If [M]XITFNL<>2
   Grizo FLGALCCHO
  Else
   Read[F:ADI]CODE=359;[M]XITGRD
   #faute lourde
   #JOJAC - 2016-06-08 - REQ114309 US215 - START
   #If fstat | (GDOSLEG="FRA" & ([F:ADI]A1="012|88" |[F:ADI]A1="902|96"))
   If fstat | (func DIVPAYE.IS_KFR_LEG(GCURLEG) & ([F:ADI]A1="012|88" |[F:ADI]A1="902|96"))
   #JOJAC - 2016-06-08 - REQ114309 US215 - END
    Grizo FLGALCCHO
   Endif
  Endif
 Endif
 If [M:CTR0]FLGVAR=2  :  Diszo CLEEVETIM, XITFNL : Endif
Endif
Local Char ZONE(10) : ZONE = "FLGPRV"
Gosub SET_ZONE From SUBCTR
If MA
    If VALEUR=[0/0/0]
        Effzo FLGPRV,STRTIMNTC,ENDTIMNTC,FLGPRV2,STRNTC2,ENDNTC2,FLGPRV3,STRNTC3,ENDNTC3
        Grizo FLGPRV,STRTIMNTC,ENDTIMNTC,FLGPRV2,STRNTC2,ENDNTC2,FLGPRV3,STRNTC3,ENDNTC3
        If dim([M]FLGXITPRV) > 0
            Effzo FLGXITPRV, STRXITPRV, ENDXITPRV
            Grizo FLGXITPRV, STRXITPRV, ENDXITPRV
        Endif
    Elsif [F:ID]FLGPAY<>2 & GPAYE
        Effzo FLGPRV,STRTIMNTC,ENDTIMNTC,FLGPRV2,STRNTC2,ENDNTC2,FLGPRV3,STRNTC3,ENDNTC3
        Grizo FLGPRV,STRTIMNTC,ENDTIMNTC,FLGPRV2,STRNTC2,ENDNTC2,FLGPRV3,STRNTC3,ENDNTC3
        If dim([M]FLGXITPRV) > 0
            Effzo FLGXITPRV, STRXITPRV, ENDXITPRV
            Grizo FLGXITPRV, STRXITPRV, ENDXITPRV
        Endif
    Else
        Actzo FLGPRV,STRTIMNTC,ENDTIMNTC,FLGPRV2,STRNTC2,ENDNTC2,FLGPRV3,STRNTC3,ENDNTC3
        If dim([M]FLGXITPRV) > 0
            Actzo FLGXITPRV, STRXITPRV, ENDXITPRV
        Endif
    Endif
Endif

#ANCOA - X3-32717 - 2017-04-12 - START
If GCURLEG="BRI" & func DIVPAYE.EXISTE_KXX("SUBCTRUKI") Then
  Call SETUPDEATHINSERVICE(VALEUR,XITGRD) From SUBCTRUKI
Elsif dim([M:CTR8]DATDTH)>0 Then
  Chgfmt [M:CTR8]DATDTH  With "-D:"+GFMDAT4
  Raz [M:CTR8]DATDTH
Endif
#ANCOA - X3-32717 - 2017-04-12 - END
End

