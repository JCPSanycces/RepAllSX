#<AdxTL>@(#)0.0.0.0 $Revision$ 


$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "DEBUT"    : Gosub DEBUT
Endcase

Return


$OUVRE
If clalev([F:ESUT2])    = 0 : Local File ESSUSRTRK     [ESUT2]     : Endif

Read [F:ESUT2]ESUT0 = GUSER
If !fstat
  If [F:ESUT2]ATTFLG <> 2
    FIN = 1
  Endif
Else
  FIN = 1
Endif
Return

$DEBUT

[M]REFNUM     = [F:ESUT2]REFNUM
[M]UID        = [F:ESUT2]UID
[M]CTRNUM     = [F:ESUT2]CTRNUM

If func AFNC.ACTIV("GLM")>0
  Gosub REFRESHLVESUBNNR From ESSDCGV
Endif

Affzo [M:ESUDC]1-99

Return




