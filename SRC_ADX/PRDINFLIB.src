####################################################################################
# Program Name: PRDINFLIB
# Description : Product Info Library
# Author      : GRNA
####################################################################################

####################################################################################
$AFFMASK

# If PLM is not active, change length to same as PLMATTURL on purpose
If !func AFNC.ACTIV("PLM")
  Chgfmt [M:ITM1]PLMITMREF With "K:" + num$(type([M:ITM1]PLMATTURL)-10) + "X"
Endif

Return


######################################################################################
Subprog C_PLMITMREF(VALEUR)
Value Char    VALEUR()

If VALEUR="" Raz [M:ITM1]PLMATTURL : End Endif

Local Char V2(250)
Call URL(VALEUR,V2)

[M:ITM1]PLMATTURL = V2

End


######################################################################################
Subprog URL(IN,OUT)
Variable Char    IN
Variable Char    OUT

Local Char    SEP : SEP="\"
Local Integer DS,EXISTE

If vireblc(IN,4)=""
  mkstat=2 : End
Endif

IN = vireblc(IN,0)

If left$(IN,1)="%"
  IN  = right$(IN,2)  # strip off "%"
  OUT = func AFNC.PARAM("PRDINF","")
  If OUT=""
    GMESSAGE = mess(136,199,1)+": PRDINF"
    mkstat = 2 : End
  Endif
  # if neither side has a "\", add one
  If right$(OUT,len(OUT))<>SEP & left$(IN,1)<>SEP
    OUT += SEP
  Endif
  OUT += IN
Else
  OUT = IN
Endif

If left$(OUT,2)="\\" | left$(OUT,1)="/"
  # if double "\\" or "//" after first 2 chars, remove
  While instr(3,OUT,SEP+SEP)
    DS = instr(3,OUT,SEP+SEP)
    OUT = left$(OUT,DS) + right$(OUT,DS+2)
  Wend
  # URL existent check here
Elsif left$(OUT,4)<>"http"
  OUT = "http://"+OUT
Endif

End


# Called from IBPRDINF action on ITM and ITV data types
####################################################################################
Subprog IBPRDINF(ITMREF)
Value Char    ITMREF
# Data types ITM and ITV are using Button 13 for Product information
Call IB_PRDINF(ITMREF,13)
End


####################################################################################
Subprog IB_PRDINF(ITMREF,NUMBOUT)
Value Char    ITMREF
Value Integer NUMBOUT

If [L]ITMREF="" | func AFNC.ACTIV("PLM")
  Assign ("[V]GBOUT" + num$([L]NUMBOUT)) With "" : End
Endif

If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF<>[L]ITMREF
  Read [ITM]ITM0=[L]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]PLMATTURL=""
  Assign ("[V]GBOUT" + num$([L]NUMBOUT)) With "" : End
Endif

End


####################################################################################
Subprog PRDINF(ITMREF)
Value Char ITMREF

If [L]ITMREF="" | func AFNC.ACTIV("PLM") : End : Endif

If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif

If [F:ITM]ITMREF<>[L]ITMREF
  Read [ITM]ITM0=[L]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]PLMATTURL<>""
  Call BUTPRDINF([F:ITM]PLMATTURL)
Endif

End


####################################################################################
Subprog BUTPRDINF(VALEUR)
Variable Char VALEUR

If VALEUR="" : End : Endif

## Action SINTERNET
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "SINTERNET"
PARMSK(1) = VALEUR
Call SAISIE_CHAR(VALEUR,PARMSK,"SINTERNET","TRTINT","") From GSAISIE
GACTION = SAVACT

End
