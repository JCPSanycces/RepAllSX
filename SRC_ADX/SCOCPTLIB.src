#<AdxTL>@(#)9.0.0.0 $Revision$
##############################################################################
# Librairie de sous-programmes d'accès comptes et sections     - GA 08/2006  #
##############################################################################
#                                                                            #
# UPDATE_SCI_CPTANALIN: ins/upd/del de la ligne [F:CAL] pour SCOITM          #
# UPDATE_SCM_CPTANALIN: ins/upd/del de la ligne [F:CAL] pour SCOMAT          #
# UPDATE_SCS_CPTANALIN: ins/upd/del de la ligne [F:CAL] pour SCOSRV          #
# --> si l'écran [M:SCOx] est actif, on prend les données dans l'écran       #
#     sinon (maj automatique) initialisation par défaut ????                 #
#                                                                            #
# CHARG_SCI_CPTANALIN : relecture [F:CAL] pour SCOITM                        #
# CHARG_SCM_CPTANALIN : relecture [F:CAL] pour SCOMAT  (liste composants)    #
# CHARG_SCS_CPTANALIN : relecture [F:CAL] pour SCOSRV                        #
#                                                                            #
# CHARG_SCO2_FROM_SCMA: recopie des sections de SCO2(tableau) à SCMA(fiche)  #
# CHARG_SCMA_FROM_SCO2: recopie des sections de SCMA(fiche) à SCO2(tableau)  #
#                                                                            #
# CHARG_ACCCOD    : Chargement mode de saisie d'un compte   COATRS           #
# CHARG_TABACC    : Chargement [F:CAL]ACC dans un tableau [M]ACC             #
# SAIS_TABACC     : Avant saisie des comptes  en tableau                     #
# INIT_TABACC     : Initialisation des comptes  en tableau ACC(10)           #
# CTRL_TABACC     : Contrôle des comptes  en tableau                         #
#                                                                            #
# Pour mémo:                                                                 #
# Le mode de saisie sections est dans [F:DTR] DIETRS                         #
# Mode de saisie des sections:                                               #
#                                                                            #
# - au niveau de l'article lancé  [M:SCO1] Format dynamique sur les champs   #
#   selon GFMTDIE(nolign) sections CCE                                       #
#   renseignés par GETCPY via CHARG_PARAM selon Site+Transaction courante    #
#                                                                            #
# - au niveau des matières        [M:SCO2]                                   #
#   pris en compte dans SUBPTE mode de saisie des champs CCEi                #
#   à la validation de la transaction                                        #
#                                                                            #
# - au niveau du service          [M:SCO3] Format dynamique sur les champs   #
#   selon [M:SCO3]FMTDIE(i) sections CCE                                     #
#   renseignés par GETCPY via CHARG_PARAM selon Site+Transaction courante    #
#   (sous-programmes ACTUALIS_FMTDIE23)                                      #
#                                                                            #
##############################################################################
# GA 09/2006 décision GLE+CH de ne pas gérer les comptes
# GA 06/2008 utiliser les fonctions de mise à jour MBT
# voir s'il faut rajouter [M:SCOx]DSP ????
##############################################################################


Subprog UPDATE_SCI_CPTANALIN(LCOD)
Value Char LCOD
Local Integer WRET
Local Integer I, J
Local Char TRTLIG(1) : TRTLIG=LCOD

If GMODU(2)<>2  : Return : Endif : # Pas de module Compta
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif

Case LCOD
   When "C","M":
      #-----------------------------------------------------------#
      # Ecriture des comptes et sections de la ligne SCOITM       #
      #-----------------------------------------------------------#
      Read [CAL] CAL0="SCI";36;[F:SCI]SCONUM;[F:SCI]SCILIN;0;"";1
      If fstat       # si aucune ligne trouvée, on la crée
         TRTLIG="C"
      Endif
     #-----
   When "A" :
      Delete [CAL] CAL0="SCI";36;[F:SCI]SCONUM;[F:SCI]SCILIN;0;"";1
      End
Endcase

#-------------------------------------------------------------------
# GA 09/2006 décision GLE+CH de ne pas gérer les comptes
# GA 06/2008 utiliser les fonctions de mise à jour selon MBT
#-------------------------------------------------------------------
If dim([M:SCO1]ACC) > 0  & TRTLIG<>"A" : # Stockage des comptes uniquement
     Call ENREG_ACCCCE(0,"[M:SCO1]ACC(","","","SCI",
&                 36,[F:SCI]SCONUM,[F:SCI]SCILIN,0,"",TRTLIG) From TRTX3CPT
     TRTLIG="M"
Endif
Gosub INIT_CCE_SCO1          # Issue 91857 GA 08/2013
Call ENREG_TABCCE("SCO1","","DIE","CCE","NBDIE",
&                 "SCI",36,[F:SCI]SCONUM,[F:SCI]SCILIN,0,"",TRTLIG) From TRTX3CPT
End

######################################################################################

Subprog UPDATE_SCM_CPTANALIN(LCOD,NOL)
Value Char    LCOD
Value Integer NOL

Local Integer WRET
Local Integer I
Local Char TRTLIG(1) : TRTLIG="M"

If GMODU(2)<>2  : Return : Endif : # Pas de module Compta
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif

Case LCOD
   When "C","M":
      #-----------------------------------------------------------#
      # Ecriture des comptes et sections de la ligne SCOMAT       #
      #-----------------------------------------------------------#
      Read [CAL] CAL0="SCM";36;[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCMLIN;"";1
      If fstat       # si aucune ligne trouvée, on la crée
         TRTLIG="C"
         Raz [F:CAL]
      Endif
   When "A" :
      Delete [CAL] CAL0="SCM";36;[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCMLIN;"";1
      End
Endcase
#-------------------------------------------------------------------
# GA 09/2006 décision GLE+CH de ne pas gérer les comptes
# GA 06/2008 utiliser les fonctions de mise à jour MBT
#-------------------------------------------------------------------
If dim([M:SCO2]ACC10) > 0
     Call ENREG_ACCCCE(nolign-1,"[M:SCO2]ACC","","[M:SCO2]CCE","SCM",
&                 36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,"",TRTLIG) From TRTX3CPT
Else
     Call ENREG_ACCCCE(nolign-1,"","","[M:SCO2]CCE","SCM",
&                 36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,"",TRTLIG) From TRTX3CPT
Endif
End
##############################################################################

Subprog UPDATE_SCS_CPTANALIN(LCOD)
Value Char LCOD
Local Integer WRET
Local Integer I,J
Local Char TRTLIG(1) : TRTLIG=LCOD
Local Char WVAL(GLONCCE)

If GMODU(2)<>2  : Return : Endif : # Pas de module Compta
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif

Case LCOD
   When "C","M":
      #-----------------------------------------------------------#
      # Ecriture des comptes et sections de la ligne SCOSRV       #
      #-----------------------------------------------------------#
      Read [CAL] CAL0="SCS";36;[F:SCS]SCONUM;[F:SCS]SCILIN;[F:SCS]SCSLIN;"";1
      If fstat       # si aucune ligne trouvée, on la crée
         TRTLIG="C"
         Raz [F:CAL]
      Endif
   When "A" :
      Delete [CAL] CAL0="SCS";36;[F:SCS]SCONUM;[F:SCS]SCILIN;[F:SCS]SCSLIN;"";1
      End
Endcase

#-------------------------------------------------------------------
# GA 09/2006 décision GLE+CH de ne pas gérer les comptes
# GA 06/2008 utiliser les fonctions de mise à jour MBT
#-------------------------------------------------------------------
If dim([M:SCO3]ACC) > 0 & TRTLIG<>"A" : # Stockage des comptes uniquement
     Call ENREG_ACCCCE(0,"[M:SCO3]ACC(","","","SCS",
&                 36,[F:SCS]SCONUM,[F:SCS]SCILIN,[F:SCS]SCSLIN,"",TRTLIG) From TRTX3CPT
     TRTLIG="M"
Endif
Gosub INIT_CCE_SCO3          # Issue 91857 GA 08/2013
Call ENREG_TABCCE("SCO3","","DIE","CCE","NBDIE",
&                 "SCS",36,[F:SCS]SCONUM,[F:SCS]SCILIN,[F:SCS]SCSLIN,"",TRTLIG) From TRTX3CPT
End

##############################################################################

Subprog CHARG_SCI_CPTANALIN(IITM)
Value Integer IITM

If GMODU(2)<>2  : Return : Endif : # Pas de module Compta
If clalev ([M:SCO1])=0 : End : Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif

#-----------------------------------------------------------#
# Relecture des comptes et sections de la ligne SCOITM      #
#-----------------------------------------------------------#
  # Code <Sections par defaut> "SCI"
  Call INIT_TABCCE ("SCO1","DIE","CCE","NBDIE","SCI","PTR",1) From TRTX3CPT
  Call CHARG_TABCCE("SCO1","DIE","CCE","NBDIE",
&                   "SCI",36,[M:SCO0]SCONUM,[M:SCO1]SCILIN,0,"") From TRTX3CPT
  Affzo [M:SCO1]DIE,CCE
#-------------------------------------------------------------------
#----- GA 09/2006 décision GLE+CH de ne pas gérer les comptes
#-------------------------------------------------------------------
  If dim([M:SCO1]ACC) > 0
    Call INIT_TABACC("SCO1","NBCOA","SCI","PTR",1) From SCOCPTLIB
    Call CHARG_TABACC("SCO1","ACC","NBCOA","",
&                     "SCI",36,[M:SCO0]SCONUM,[M:SCO1]SCILIN,0,"") From SCOCPTLIB
    Affzo [M:SCO1]ACC
  Endif
#----
End

##############################################################################

Subprog CHARG_SCM_CPTANALIN(IMAT)
Value Integer IMAT

If GMODU(2)<>2  : Return : Endif : # Pas de module Compta
If clalev ([M:SCO2])=0 : End : Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif

#----
#-------------------------------------------------------------------
#----- GA 09/2006 décision GLE+CH de ne pas gérer les comptes
#-------------------------------------------------------------------
  If dim([M:SCO2]ACC10) > 0
    Gosub AFFICH_ACC_SCO2
    Call  CHARG_ACCCCE(IMAT,"[M:SCO2]ACC","","[M:SCO2]CCE","SCM",
&                      36,[M:SCO0]SCONUM,[M:SCO1]SCILIN,[M:SCO2]SCMLIN(IMAT),"") From TRTX3CPT
  Else
    Call  CHARG_ACCCCE(IMAT,"","","[M:SCO2]CCE","SCM",
&                      36,[M:SCO0]SCONUM,[M:SCO1]SCILIN,[M:SCO2]SCMLIN(IMAT),"") From TRTX3CPT
  Endif
#----
  Gosub AFFICH_CCE_SCO2

End


#------------------------------------------------#
# Init par défaut des sections analytiques  SCI  #
#------------------------------------------------#
$INIT_CCE_SCO1          # Issue 91857 GA 08/2013
If dim([M:SCO1]DIE)<0 Return Endif
Local Char WVAL(GLONCCE)
Local Integer I,AXE
For ICCE=1 To GNBDIE
    If [M:SCO1]CCE(ICCE-1)="" & [M:SCO1]DIE(ICCE-1)<>""  # Issue 91857 & 91501 GA 08/2013
       AXE=find([M:SCO1]DIE(ICCE-1),GDIE(1..GNBDIE))
       If AXE<1 | AXE>GNBDIE Break : Endif
       Call INIT_CCE([M:SCO1]CCE(ICCE-1),AXE,"SCI","",0) From TRTX3CPT
    Endif
Next
Affzo [M:SCO1]CCE
Return
#------------------------------------------------#
# Init par défaut des sections analytiques  SCS  #
#------------------------------------------------#
$INIT_CCE_SCO3          # Issue 91857 GA 08/2013
If dim([M:SCO3]DIE)<0 Return Endif
Local Char WVAL(GLONCCE)
Local Integer I,AXE
If dim(ICCE)<1  Local Integer ICCE : Endif
For ICCE=1 To GNBDIE
    If [M:SCO3]CCE(ICCE-1)="" & [M:SCO3]DIE(ICCE-1)<>""  # Issue 91857 & 91501 GA 08/2013
       AXE=find([M:SCO3]DIE(ICCE-1),GDIE(1..GNBDIE))
       If AXE<1 | AXE>GNBDIE Break : Endif
       Call INIT_CCE([M:SCO3]CCE(ICCE-1),AXE,"SCS","",0) From TRTX3CPT
    Endif
Next
Affzo [M:SCO3]CCE
Return

#------------------------------------------------#
# Affichage des sections analytiques de la ligne #
#------------------------------------------------#
$AFFICH_CCE_SCO2
Local Char WVAL(GLONCCE)
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBDIE
  # Issue X3_39028 - 2017-06-08 by MUARN : ne faire que si non initialisé
  #If evalue("[M:SCO2]CCE"+num$(I)+"(IMAT)")=""   # Issue 91857 GA 08/2013
  If evalue("varinit([M:SCO2]CCE"+num$(I)+",IMAT)") = 0
     Raz WVAL
     Call INIT_CCE(WVAL,I,"SCM","",0) From TRTX3CPT
     Assign "[M:SCO2]CCE"+num$(I)+"(IMAT)" With WVAL
  Endif
  Case I
    When  1 : Affzo [M:SCO2]CCE1 (IMAT)
    When  2 : Affzo [M:SCO2]CCE2 (IMAT)
    When  3 : Affzo [M:SCO2]CCE3 (IMAT)
    When  4 : Affzo [M:SCO2]CCE4 (IMAT)
    When  5 : Affzo [M:SCO2]CCE5 (IMAT)
    When  6 : Affzo [M:SCO2]CCE6 (IMAT)
    When  7 : Affzo [M:SCO2]CCE7 (IMAT)
    When  8 : Affzo [M:SCO2]CCE8 (IMAT)
    When  9 : Affzo [M:SCO2]CCE9 (IMAT)
    When 10 : Affzo [M:SCO2]CCE10(IMAT)
    When 11 : Affzo [M:SCO2]CCE11(IMAT)
    When 12 : Affzo [M:SCO2]CCE12(IMAT)
    When 13 : Affzo [M:SCO2]CCE13(IMAT)
    When 14 : Affzo [M:SCO2]CCE14(IMAT)
    When 15 : Affzo [M:SCO2]CCE16(IMAT)
    When 16 : Affzo [M:SCO2]CCE17(IMAT)
    When 17 : Affzo [M:SCO2]CCE17(IMAT)
    When 18 : Affzo [M:SCO2]CCE18(IMAT)
    When 19 : Affzo [M:SCO2]CCE19(IMAT)
    When 20 : Affzo [M:SCO2]CCE20(IMAT)
  Endcase
Next I
Return

$AFFICH_ACC_SCO2
#CHECK IGNORE_BEGIN
#-----------------------------------#
# Affichage des comptes de la ligne #
#-----------------------------------#
If dim(I)<1     Local Integer I    : Endif
For I=1 To GNBCOA
  Case I
    When  1 : Affzo [M:SCO2]ACC1 (IMAT)
    When  2 : Affzo [M:SCO2]ACC2 (IMAT)
    When  3 : Affzo [M:SCO2]ACC3 (IMAT)
    When  4 : Affzo [M:SCO2]ACC4 (IMAT)
    When  5 : Affzo [M:SCO2]ACC5 (IMAT)
    When  6 : Affzo [M:SCO2]ACC6 (IMAT)
    When  7 : Affzo [M:SCO2]ACC7 (IMAT)
    When  8 : Affzo [M:SCO2]ACC8 (IMAT)
    When  9 : Affzo [M:SCO2]ACC9 (IMAT)
    When 10 : Affzo [M:SCO2]ACC10(IMAT)
  Endcase
Next I
#CHECK IGNORE_END
Return

##############################################################################

Subprog CHARG_SCS_CPTANALIN(ISRV)
Value Integer ISRV

If GMODU(2)<>2  : Return : Endif : # Pas de module Compta
If clalev ([M:SCO3])=0 End Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif

#-----------------------------------------------------------#
# Relecture des comptes et sections de la ligne SCOSRV      #
#-----------------------------------------------------------#
  Call INIT_TABCCE ("SCO3","DIE","CCE","NBDIE","SCS","PTR",3) From TRTX3CPT
  Call CHARG_TABCCE("SCO3","DIE","CCE","NBDIE",
&                   "SCS",36,[M:SCO0]SCONUM,[M:SCO1]SCILIN,[M:SCO3]SCSLIN,"") From TRTX3CPT
  Affzo [M:SCO3]DIE,CCE

#-------------------------------------------------------------------
#----- GA 09/2006 décision GLE+CH de ne pas gérer les comptes
#-------------------------------------------------------------------
  If dim([M:SCO3]ACC) > 0
    Call INIT_TABACC("SCO3","NBCOA","SCS","PTR",3) From SCOCPTLIB
    Call CHARG_TABACC("SCO3","ACC","NBCOA","",
&                     "SCS",36,[M:SCO0]SCONUM,[M:SCO1]SCILIN,[M:SCO3]SCSLIN,"") From SCOCPTLIB
    Affzo [M:SCO3]ACC
  Endif

#----
End

##############################################################################

Subprog CHARG_SCMA_FROM_SCO2(IMAT)
Value Integer IMAT
#-----------------------------------------------------#
#----- Affichage comptes et sections analytiques -----#
#-----------------------------------------------------#
Local Integer I,J
  If clalev ([M:SCO2])=0 : End : Endif
#-------------------------------------------------------------------
#----- GA 09/2006 décision GLE+CH de ne pas gérer les comptes
#-------------------------------------------------------------------
  If dim([M:SCMA]ACC) > 0 & dim([M:SCO2]ACC10) > 0
    Call INIT_TABACC("SCMA","NBCOA","SCM","PTR",2) From SCOCPTLIB
    #CHECK IGNORE_BEGIN
    For I=0 To [M:SCMA]NBCOA
      J=find([M:SCMA]COA(I),GCOA(1..GNBCOA))
      If J
        [M:SCMA]ACC(I)=evalue("[M:SCO2]ACC"+num$(J)+"(IMAT)")
      Endif
    Next I
    #CHECK IGNORE_END
  Endif
#---
  Call INIT_TABCCE("SCMA","DIE","CCE","NBDIE","SCM","PTR",2) From TRTX3CPT
  For I=0 To [M:SCMA]NBDIE
    J=find([M:SCMA]DIE(I),GDIE(1..GNBDIE))
    If J
      [M:SCMA]CCE(I)=evalue("[M:SCO2]CCE"+num$(J)+"(IMAT)")
    Endif
  Next I
#---
End


##############################################################################

Subprog CHARG_SCO2_FROM_SCMA(IMAT)
Value Integer IMAT

  If clalev ([M:SCO2])=0 : End : Endif
#-------------------------------------------------------------------
#----- GA 09/2006 décision GLE+CH de ne pas gérer les comptes
#-------------------------------------------------------------------
  If dim([M:SCMA]ACC) > 0 & dim([M:SCO2]ACC10) > 0
    # Affectation des comptes
     Local Integer I,J
     #CHECK IGNORE_BEGIN
     For I=0 To [M:SCMA]NBCOA
       J=find([M:SCMA]COA(I),GCOA(1..GNBCOA))
       If J
         Assign "[M:SCO2]ACC"+num$(J)+"(IMAT)" With [M:SCMA]ACC(I)
       Endif
     Next I
     #CHECK IGNORE_END
  Endif

  # Affectation des axes analytiques
  For I=0 To [M:SCMA]NBDIE
    J=find([M:SCMA]DIE(I),GDIE(1..GNBDIE))
    If J
      Assign "[M:SCO2]CCE"+num$(J)+"(IMAT)" With [M:SCMA]CCE(I)
    Endif
  Next I
#----
End



#--------------------------------------------------------------#
# Avant saisie des comptes en mode tableau (entete)            #
# Remplace les formats évalués qui ne fonctionnement pas       #
# si saisie de ACC ou CCE en mode tableau   -  GA 08/2006      #
# ------------------------------------------------------------ #
# Paramètres à passer au sous-programme :                      #
#   - WACC     : Valeur du compte à contrôler                  #
#   - WCOA     : Code du plan de compte                        #
#   - WLEDTYP  : Type de référentiel                           #
#   - WABRFIC  : Code table des transactions de saisie         #
#   - WIND     : Indice du code (1, 2, ou 3)                   #
#--------------------------------------------------------------#
# NB: La transaction courante doit déjà avoir été lue          #
#--------------------------------------------------------------#
Subprog SAIS_TABACC(WACC,WCOA,WLEDTYP,WABRFIC,WIND)
Variable Char    WACC
Value    Char    WCOA
Value    Integer WLEDTYP
Value    Char    WABRFIC
Value    Integer WIND

Local    Integer WACCCOD

  Call CHARG_ACCCOD(WACCCOD,WCOA,WLEDTYP,WABRFIC,WIND)
 #---- plan Non saisissable
  If WACCCOD =2 : mkstat=2 : Endif
#-----
End


#--------------------------------------------------------------#
# Recherche mode saisie des plans de comptes COATRS            #
# ------------------------------------------------------------ #
# Paramètres du sous-programme :                               #
#   - WACCCOD  : Mode de saisie associé à ce plan COATRS       #
#   - WCOA     : Code du plan de compte                        #
#   - WLEDTYP  : Type de référentiel                           #
#   - WABRFIC  : Code table des transactions de saisie         #
#   - WIND     : Indice du code (1, 2, ou 3)                   #
#--------------------------------------------------------------#
# NB: La transaction courante doit déjà avoir été lue          #
#--------------------------------------------------------------#
Subprog CHARG_ACCCOD(WACCCOD,WCOA,WLEDTYP,WABRFIC,WIND)
Variable Integer WACCCOD
Value    Char    WCOA
Value    Integer WLEDTYP
Value    Char    WABRFIC
Value    Integer WIND

Local    Integer J

  #CHECK IGNORE_BEGIN
  If !clalev([F:CAT])  Local File COATRS [CAT] : Endif
  Raz [F:CAT]

 #---- Mode de saisie de cet axe analytique pour cette transaction  -----#
 #---- lecture COATRS (saisie/affiché/invisible)                    -----#
  Case WABRFIC
    When "PTR"
      If [F:PTR]PTRNUM<>""
        If WLEDTYP>0    : # Paramétrage par type de référentiel
          Read [CAT] CAT1="PTR";[F:PTR]PTRTYP;[F:PTR]PTRNUM;WLEDTYP : If fstat  Raz [F:CAT] : Endif
        Elsif WCOA<>""  : # Paramétrage par code plan de compte
          Read [CAT] CAT0="PTR";[F:PTR]PTRTYP;[F:PTR]PTRNUM;WCOA : If fstat  Raz [F:CAT] : Endif
        Endif
      Endif
    When "SLT" : # pas de tableau des comptes ACC(10)
    When "CTR" : # pas de tableau des comptes ACC(10)
    When "SRT" : # pas de tableau des comptes ACC(10)
    When "MTS" : # pas de tableau des comptes ACC(10)
    When "BTS" : # pas de tableau des comptes ACC(10)
  Endcase
  Case WIND
    When 1 :
    #---- Mode de saisie (Entête)
     WACCCOD=[F:CAT]ACCCOD1
    When 2 :
    #---- Mode de saisie (Détail 1)
     WACCCOD=[F:CAT]ACCCOD2
    When 3 :
    #---- Mode de saisie (Détail 2)
     WACCCOD=[F:CAT]ACCCOD3
  Endcase
  #CHECK IGNORE_END
#-----
End



#--------------------------------------------------------------#
# Initialisation des comptes entête                            #
# ------------------------------------------------------------ #
# Paramètres à passer au sous-programme :                      #
#   - WABRMSK  : Abréviation du masque écran                   #
#   - WBASTAB  : Nom de la variable de bas de tableau          #
#   - WACCDEF  : Paramétrage compte par défaut ?????           #
#                (exemple "POH")                               #
#   - WABRFIC  : Code table des transactions de saisie         #
#   - WIND     : Indice du code (1, 2, ou 3)                   #
#--------------------------------------------------------------#
Subprog INIT_TABACC(WABRMSK,WBASTAB,WACCDEF,WABRFIC,WIND)
Value    Char    WABRMSK
Value    Char    WBASTAB
Value    Char    WACCDEF
Value    Char    WABRFIC
Value    Integer WIND
#-----
Local    Char    ECRAN(10)
Local    Char    BATAB(20)
Local    Char    COMPTE(GLONCCE)
Local    Char    MSK_COURANT(20)
Local    Integer WACCCOD
Local    Integer I,J
#----- Chargement abréviation du masque courant -----#
If instr(1,dbgstr(1),",")
  [L]MSK_COURANT=vireblc(left$(dbgstr(1),instr(1,dbgstr(1),",")-1),4)
Else
  [L]MSK_COURANT=vireblc(dbgstr(1),4)
Endif
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]" : Default Mask "["+WABRMSK+"]"
Endif
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBCOA"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
#-----
[L]J=0
For [L]I=1 To GNBCOA
  Call CHARG_ACCCOD(WACCCOD,GCOA([L]I),GTYPLED(I),WABRFIC,WIND)
 #---- Plan Invisible => non chargé dans le tableau
  If WACCCOD<>3
    If evalue("dim("+[L]ECRAN+"COA([L]J))")>0
       Assign [L]ECRAN+"COA([L]J)" With GCOA([L]I)
    Endif
    If evalue("dim("+[L]ECRAN+"LED([L]J))")>0
       Assign [L]ECRAN+"LED([L]J)" With GLED([L]I)
    Endif
    If evalue("dim("+[L]ECRAN+"LEDTYP([L]J))")>0
       Assign [L]ECRAN+"LEDTYP([L]J)" With GTYPLED([L]I)
    Endif
    #y-a-t-il un moyen d'avoir une valeur par défaut pour [L]COMPTE: selon WACCDEF ????
    #Raz [L]COMPTE
    #Assign [L]ECRAN+"ACC([L]J)" With [L]COMPTE
    [L]J+=1
  Endif
Next [L]I
Assign [L]BATAB With [L]J : # avant GNBCOA
#----- Affichage et rétablissement masque par défaut si nécessaire -----#
If !GIMPORT  Affzo [M]COA, ACC : Endif
If WABRMSK<>""
  Default Mask [L]MSK_COURANT
Endif
#-----
End


#--------------------------------------------------------------#
# Contrôle des comptes d'une ligne de document                 #
# ------------------------------------------------------------ #
# Paramètres à passer au sous-programme :                      #
#   - WCOMPTE  : Valeur du compte à contrôler                  #
#   - WCOA     : Code du plan de compte                        #
#   - WFCY     : Site financier de la société (GFINRSP)        #
#   - WDATE    : Date                                          #
#   - WDEVISE  : Devise                                        #
#--------------------------------------------------------------#
Subprog CTRL_TABACC(WCOMPTE,WCOA,WFCY,WDATE,WDEVISE)
Variable Char    WCOMPTE
Value    Char    WCOA
Value    Char    WFCY
Value    Date    WDATE
Value    Char    WDEVISE

Local    Integer J

J=find(WCOA,GCOA(1..GNBCOA))
If J=0 : End : Endif

# en attendant de faire mieux
#### Call CTRL_ACC(WCOMPTE,J,"[M]ACC",WFCY,WDATE,WDEVISE) From TRTX3CPT

#----- Erreur non bloquante si saisie en mode fiche uniquement -----#
$ERR_ACCH
If mkstat & GSCRCOA=2
  Raz mkstat : GERR=2
Endif
#-----
End

##############################################################################

#--------------------------------------------------------------#
# Chargement des comptes depuis CPTANALIN                      #
# Appelé par l'action LIENS pour maj d'un tableau contenant    #
# les comptes ACC(10)                           - GA 08/2006   #
# ------------------------------------------------------------ #
# Paramètres à passer au sous-programme :                      #
#   - WABRMSK    : Abréviation du masque écran                 #
#   - WNOMACC    : Nom du tableau contenant les comptes        #
#   - WBASTABACC : Var. bas de tableau contenant les comptes   #
#   - WNOMDSP    : Nom du champ du code répartition            #
#                  "" = il n'y a pas de code répartition       #
#   - WABRFIC    : Abréviation table des lignes du document    #
#   - WVCRTYP    : Type de la pièce                            #
#   - WVCRNUM    : Numéro de la pièce                          #
#   - WVCRLIN    : Numéro de ligne de la pièce                 #
#   - WVCRSEQ    : Numéro de séquence de la pièce              #
#   - WCPLCLE    : Complément clé                              #
#--------------------------------------------------------------#
Subprog CHARG_TABACC(WABRMSK,WNOMACC,WBASTABACC,WNOMDSP,WABRFIC,WVCRTYP,WVCRNUM,WVCRLIN,WVCRSEQ,WCPLCLE)
Value    Char    WABRMSK
Value    Char    WNOMACC
Value    Char    WBASTABACC
Value    Char    WNOMDSP
Value    Char    WABRFIC
Value    Integer WVCRTYP
Value    Char    WVCRNUM
Value    Integer WVCRLIN
Value    Integer WVCRSEQ
Value    Char    WCPLCLE
#-----
Local    Integer I, J, WNBCOA
Local    Char    WMSK (GLONAMK)
#-----
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
#-----
Read [CAL] CAL0=WABRFIC;WVCRTYP;WVCRNUM;WVCRLIN;WVCRSEQ;WCPLCLE;1
If !fstat
  If WABRMSK<>""
     WMSK="[M:"+WABRMSK+"]"
  Else
     WMSK=""
  Endif
  If WNOMACC<>""
  # --------------------------------------------
  # Tableau [M]ACC ou [M]LINACC pour les comptes
  # --------------------------------------------
    For I=1 To 10
      If  evalue("dim("+WMSK+WNOMACC+")")<=0 : Break : Endif
      Assign WMSK+WNOMACC+"(I-1)" With ""
    Next I
    If evalue("dim("+WMSK+WBASTABACC+")")>0
      WNBCOA = evalue(WMSK+WBASTABACC)
      For I=0 To WNBCOA-1
        # Certains plans de GCOA peuvent ne pas etre affichées (selon COATRS)
        # On cherche la position du plan de comtpe dans [F:CAL]COA plutôt que GCOA
        J=find(evalue(WMSK+"COA(I)"),[F:CAL]COA(0..GNBCOA-1))
        If J & J<evalue("dim("+WMSK+WNOMACC+")") & evalue("dim("+WMSK+WNOMACC+")")>0
          Assign WMSK+WNOMACC+"(I)" With [F:CAL]ACC(J-1)
        Endif
      Next I
    Endif
  Endif
  If WNOMDSP<>""
  # -------------------------------
  # Code répartition
  # -------------------------------
    Assign WMSK+WNOMDSP With [F:CAL]DSP
  Endif
Endif
#-----
End

