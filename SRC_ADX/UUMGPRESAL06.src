#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPRESAL06   Pre-migration livraisons                    Module Ventes #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête livraison : SDELIVERY                                             #
# ------------------------                                                 #
# Gestion des adresses                                                     #
#                                                                          #
# Migration en V11 :            : # Issue X3-90233                         #
# ---------------                                                          #
# Détail livraison : SDELIVERYD                                            #
# -------------------------                                                #
# Alim. PJT à partir du champ PJT de l'entête                              #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail livraisons : SDELIVERYD                                           #
# ----------------------------                                             #
# Alim. STOFCY à partir de l'entête si différence                          #
############################################################################
# Issue X3-90233 - 20180807 by LD : Error in processes UUMGPRESALxx

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRESAL06") From LECFIC
  Endif

  Call MAJ_UUMGPRESAL06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGPRESAL06(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

#----- Récupération du n° de version
# Issue X3-90233
#Local Char VERSION
#Call VERSION (DOSSIER,VERSION) From DOSSUB
#If val(VERSION)=0
#  # N° de version incorrecte
#  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL06",7,ERR) From TRTMIG : #7=Erreur
#  End
#Endif
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
# End issue X3-90233

Call ECR_TIME("UUMGPRESAL06 Sales Delivery Process : Update SDELIVERY") From DOSSUB
Call ECR_TRACE("UUMGPRESAL06 : Process Start on : "+DOSSIER,0) From GESECRAN

Gosub MIG_OUVRE From TRTMIG

Local Integer EXE_SQL
EXE_SQL = 0

If EXE_SQL
  # Mise à jour des champs directement par requête SQL

  # Passage en V6
  If VERSION<GMIGX3VER60

    #1- ajouter la colonne dans la table SDH
    #--------------- Field ADDITION  ----------#
    Call MIGINDCRE (DOSSIER,"SDELIVERY","","BPAINV","A",5,ERR) From TRTMIG
    If ERR : Goto FIN : Endif

    Gosub TRT_SQL1_60
  Endif

Else
  # Mise à jour des champs par boucle de lecture de la table et maj

  # Passage en V6
  If VERSION<GMIGX3VER60
    #1- ajouter la colonne dans la table SDH
    #2- ajouter un index unique
    #--------------- Field ADDITION  ----------#
    Call MIGINDCRE (DOSSIER,"SDELIVERY","BPAINV+BPCINV+SDHNUM","BPAINV","A",5,ERR) From TRTMIG
    If ERR : Goto FIN : Endif

    Gosub TRT_X3_60

    #--------------- Suppression index ----------#
    Call MIGINDDEL (DOSSIER,"SDELIVERY",ERR) From TRTMIG
    If ERR : Goto FIN : Endif
  Endif

Endif

# Issue X3-90233
# Passage en V11
If VERSION<GMIGX3VER110
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table SDD
  # ----------------------------------------
  Gosub ADDCOL110
  If ERR : Goto FIN : Endif
Endif
# End issue X3-90233

# Mise à jour des champs directement par une requête SQL
Gosub TRT_SQL2

$FIN
Call ECR_TIME("UUMGPRESAL06 : Sales Delivery Process END.")  From DOSSUB
End

########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V11         : # Issue X3-90233
# ----------------------------------------
# 1- ajouter les colonnes dans la table SDD
# ----------------------------------------
$ADDCOL110                                      : # Issue X3-90233

# 1- ajouter les colonnes dans la table SDD
# ----------------------------------------
# Ajout du champ PJT : Code affaire
Call MIGADDCOL (DOSSIER,"SDELIVERYD","PJT","A",40,1,ERR) From TRTMIG

Return

############################################################
$TRT_SQL1_60
#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SDH]) : Close File [SDH] : Endif
If clalev([F:SDH])  = 0 : Local File =DOSSIER+".SDELIVERY"    [SDH]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SDH]
GOK = 1

Gosub TRT_SQL1_60_1

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SDH]
Return
###################################################################################################
$TRT_SQL1_60_1

Return
############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête livraisons : SDELIVERY                                            #
# -----------------------------                                            #
# Gestion des adresses                                                     #
############################################################################
$TRT_X3_60
Local Integer COMPTEUR


#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SDH]) : Close File [SDH] : Endif
If clalev([F:SDH])  = 0 : Local File =DOSSIER+".SDELIVERY"   [SDH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST
Filter [SDH] Order By Key CLE=[F:SDH]BPAINV;[F:SDH]BPCINV;[F:SDH]SDHNUM

$LOOP_SAL00
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:SDH]BPAINV='' & [F:SDH]BPCINV=ACLE1 & [F:SDH]SDHNUM>ACLE2"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:SDH]BPAINV='' & [F:SDH]BPCINV>ACLE1"
Else
 CRITERE = "[F:SDH]BPAINV='' & 1=1"
Endif

Trbegin [SDH]
GOK = 1

For [SDH]CLE Where evalue(CRITERE)

  # --- alimentation des champs et écriture enreg
  Gosub RECUP_BPR

  Rewrite [F:SDH]
  If fstat
    Call ECR_TRACE("File SDELIVERY(SDHNUM)"-[F:SDH]SDHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:SDH]BPCINV
    ACLE2 = [F:SDH]SDHNUM
    STOP=1
    Break
  Endif
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_SAL00
  Endif
Endif

$FIN_1
Gosub UNSET_FIRST From TRTFIRST
Close Local File [SDH]

Call ECR_TIME("UUMGPRESAL06 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB

Return
########################################################################
$RECUP_BPR

    If [F:SDH]BPAINV=""
      # ACA Gestion des adresses +BPAINV
      If [F:BPC]BPCNUM<>[F:SDH]BPCINV
        Read [BPC]BPC0=[F:SDH]BPCINV
        If fstat Raz [F:BPC] Endif
      Endif
#     [F:SDH]BPAINV=[F:BPC]BPAINV
      If [F:SDH]BPCINV=[F:BPC]BPCINV
          [F:SDH]BPAINV=[F:BPC]BPAINV
      Else
          If [BPR]BPRNUM<>[F:SDH]BPCINV
            Read [BPR]BPR0=[F:SDH]BPCINV
            If fstat Raz [F:BPR] Endif
          Endif
          [F:SDH]BPAINV=[F:BPR]BPAADD
      Endif
    Endif

Return

########################################################################
$TRT_SQL2

#----- Ouverture des fichiers -----#
If clalev([F:SDH]) : Close File [SDH] : Endif
If clalev([F:SDD]) : Close File [SDD] : Endif
If clalev([F:SDH])  = 0 : Local File =DOSSIER+".SDELIVERY"      [SDH]  : Endif
If clalev([F:SDD])  = 0 : Local File =DOSSIER+".SDELIVERYD"     [SDD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SDD]
GOK = 1

# Suppression des incohérences entre tables avant migration
# A faire pour toutes les versions
## Passage en V6
#If val(VERSION)<30
  # Champs à alimenter à partir de la V6
  Gosub TRT_SQL2_30
#Endif

# Issue X3-90233
# Passage en V11
If VERSION<GMIGX3VER110
  # Champs à alimenter à partir de la V11
  Gosub TRT_SQL2_110
Endif
# End issue X3-90233

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SDH],[SDD]
Return
############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Détail livraison  : SDELIVERYD                                           #
# --------------------------                                               #
# Alim. STOFCY à partir de l'entête si différence                          #
############################################################################
$TRT_SQL2_30
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SDELIVERYD SET STOFCY_0="
REQSQL(1)="(SELECT SDH.STOFCY_0 FROM"-DOSSIER+".SDELIVERY SDH WHERE SDH.SDHNUM_0=SDELIVERYD.SDHNUM_0)"
REQSQL(2)=" WHERE SDELIVERYD.STOFCY_0<>(SELECT SDH.STOFCY_0 FROM"-DOSSIER+".SDELIVERY SDH WHERE SDH.SDHNUM_0=SDELIVERYD.SDHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

############################################################################
# Migration en V11 :                     : # Issue X3-90233                #
# ---------------                                                          #
# Détail livraison : SDELIVERYD                                            #
# -------------------------                                                #
# Alim. PJT à partir de l'entête                                           #
############################################################################
$TRT_SQL2_110                            : # Issue X3-90233

Gosub TRT_SQL2_110_1 : # Mise à jour PJT SDELIVERYD à partir de PJT SDELIVERY : # Issue X3-90233

Return



############################################################################
# Migration en V11 :                     : # Issue X3-90233                #
# ---------------                                                          #
# Détail livraison : SDELIVERYD                                            #
# -------------------------                                                #
# Alim. PJT à partir de l'entête                                           #
############################################################################
$TRT_SQL2_110_1                          : # Issue X3-90233

Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SDELIVERYD SET PJT_0="
REQSQL(1)="(SELECT SDH.PJT_0 FROM"-DOSSIER+".SDELIVERY SDH WHERE SDH.SDHNUM_0=SDELIVERYD.SDHNUM_0)"
REQSQL(2)=" WHERE SDELIVERYD.PJT_0=' '"

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

