zoncou = "INCITM"
indice = 0
IMPENT = [M]INCITM
WNUM = IMPENT
If varinit([M]INCITM,indice)=0
 IMPENT = 1
Endif
If varmode([M]INCITM,indice)=0
 [M]INCITM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INCITM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INCITM(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_INCITM(IMPENT) From PJMAUTSPLD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "INCITM" : GZNUM = 54941 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]INCITM = IMPENT

## Zone INCOPE
mkstat = 0
zoncou = "INCOPE"
indice = 0
IMPENT = [M]INCOPE
WNUM = IMPENT
If varinit([M]INCOPE,indice)=0
 IMPENT = 1
Endif
If varmode([M]INCOPE,indice)=0
 [M]INCOPE(indice) = IMPENT
