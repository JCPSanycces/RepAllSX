 Endif
Endif
[M]INCDAL = IMPENT

## Zone INCLOG
mkstat = 0
zoncou = "INCLOG"
indice = 0
IMPENT = [M]INCLOG
If varinit([M]INCLOG,indice)=0
 IMPENT = 1
Endif
If varmode([M]INCLOG,indice)=0
 [M]INCLOG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INCLOG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INCLOG(indice)
 Endif
Endif
[M]INCLOG = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone INCBUD
mkstat = 0
zoncou = "INCBUD"
indice = 0
IMPENT = [M]INCBUD
WNUM = IMPENT
If varinit([M]INCBUD,indice)=0
 IMPENT = 1
Endif
If varmode([M]INCBUD,indice)=0
 [M]INCBUD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INCBUD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INCBUD(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_INCBUD(IMPENT) From PJMAUTSPLD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "INCBUD" : GZNUM = 1001834 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]INCBUD = IMPENT

## Zone INCTAS
mkstat = 0
zoncou = "INCTAS"
indice = 0
IMPENT = [M]INCTAS
WNUM = IMPENT
If varinit([M]INCTAS,indice)=0
 IMPENT = 1
Endif
If varmode([M]INCTAS,indice)=0
 [M]INCTAS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INCTAS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INCTAS(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
