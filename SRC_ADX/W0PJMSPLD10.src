#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSPLD10 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PJTALL
mkstat = 0
zoncou = "PJTALL"
indice = 0
IMPENT = [M]PJTALL
If varinit([M]PJTALL,indice)=0
 IMPENT = 1
Endif
If varmode([M]PJTALL,indice)=0
 [M]PJTALL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJTALL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PJTALL(indice)
 Endif
Endif
[M]PJTALL = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone PRODGRPLVL
mkstat = 0
zoncou = "PRODGRPLVL"
indice = 0
IMPENT = [M]PRODGRPLVL
If varinit([M]PRODGRPLVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]PRODGRPLVL,indice)=0
 [M]PRODGRPLVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRODGRPLVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PRODGRPLVL(indice)
 Endif
Endif
[M]PRODGRPLVL = IMPENT

## Zone INCALL
