mkstat = 0
zoncou = "INCOWRT"
indice = 0
IMPENT = [M]INCOWRT
If varinit([M]INCOWRT,indice)=0
 IMPENT = 1
Endif
If varmode([M]INCOWRT,indice)=0
 [M]INCOWRT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "INCOWRT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]INCOWRT(indice)
 Endif
Endif
[M]INCOWRT = IMPENT

## Zone INCDAL
mkstat = 0
zoncou = "INCDAL"
indice = 0
IMPENT = [M]INCDAL
If varinit([M]INCDAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]INCDAL,indice)=0
 [M]INCDAL(indice) = IMPENT
