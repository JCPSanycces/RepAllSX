#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:06"
A_USER  = "DOC"
A_STAMP = "20181109230406"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRSTG"
  If [M]NBRSTG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ECP5 [ECP5]
Gosub HORODAT
Local Inpbox "ECP5" From GFONCTION At A_STAMP With A_WINDPREV Mask [ECP5] As [SIM_]
Grizo [ECP5]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ECP5]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=22
Return

$ON_NBRSTG
Onevent BEFORE_INPUT Call AS_NBRSTG From W1ECP5
Return

Subprog AS_NBRSTG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45543,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRSTG From W1ECP5
Gosub _AFF
End

Subprog B1_NBRSTG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = [M:ECP0]REFNUM
 Call OBJET_CHAR(OBJCLE,"INS",[M:ECP5]SES(nolign-1)) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_STG
Return

$ON_ZSTG
Onevent BEFORE_AREA Gosub AV_ZSTG From W1ECP5
Return

$AV_ZSTG
If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
Call LECTURE("STG",num$([M]STG(indice)),"") From CONTOBJ
zc = [F:STG]DES
Gosub _AFF
Return

$ON_DEBSES
Onevent BEFORE_AREA Gosub AV_DEBSES From W1ECP5
Return

$AV_DEBSES
Chgfmt [M]DEBSES(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_FINSES
Onevent BEFORE_AREA Gosub AV_FINSES From W1ECP5
Return

$AV_FINSES
Chgfmt [M]FINSES(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_SES
Return

$ON_ZSES
Onevent BEFORE_AREA Gosub AV_ZSES From W1ECP5
Return

$AV_ZSES
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
Call LECTURE("HRSES",num$([M]SES(indice)),"") From CONTOBJ
zc = [F:HRSES]DES
Gosub _AFF
Return

$CHG_STY
Return


