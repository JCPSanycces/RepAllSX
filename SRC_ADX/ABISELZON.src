#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ABF",GBIDC1,GBIDC2) From GOBJET
End

Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(2) = "GACCENTRYD"
Call TRAITE_CHAR(VALEUR,PARAM,"","ABISELZON","ABISELZON",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Integer NOLI
NOLI = nolign-1
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
Local File ABIDIM [ABI2]
Local Mask ABISELZON [DIA]
Raz [M:DIA]
[M:DIA]TYPTAB  = val(PARAM(1))
If PARAM(2)<>""
 Read [ATB]CODFIC = PARAM(2)
 If !fstat
  [M:DIA]FICHIER = PARAM(2)
  Call AM_FICHIER([M:DIA]FICHIER)
 Endif
Endif
Return

$EXEC
Local Integer OKFLD , NUMTEX
Local Char    TEXTE(80) , CHAMP(GLONAVA)
Read [ATB]CODFIC = [M:DIA]FICHIER
Case [M:DIA]TYPTAB
 When 1 : Gosub FAITS
 When 2 : Gosub DIMENSION
Endcase
Return

$FAITS
For I=0 To [M:DIA]NBLIG-1
 CHAMP = [M:DIA]CODZONE(I)
 If [M:DIA]SELECT(I)=2
  OKFLD  = !find(CHAMP,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
  OKFLD *= [M:ABF2]NBRFLD<dim([M:ABF2]CODFLD)
  If OKFLD
   OKFLD = 0
   Read [ATZ]CODZONE = [M:DIA]FICHIER;CHAMP
   For NUMTEX=[F:ATZ]NOCOURT,[F:ATZ]NOLONG,[F:ATZ]NOABREG
    Call TEXTE(NUMTEX,TEXTE) From OBJDIV
    If !find(TEXTE,[M:ABF2]ZINTFLD(0..[M:ABF2]NBRFLD-1))
     OKFLD = 1 : Break
    Endif
   Next NUMTEX
   If OKFLD
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    Insa  NOLI,1,[M:ABF2]NBRFLD [M:ABF2]NBRFLD
    J = NOLI
    NOLI += 1
    [M:ABF2]NBRFLD += 1
    [M:ABF2]CODFLD(J)  = [M:DIA]CODZONE(I)
    [M:ABF2]INTFLD(J)  = NUMTEX
    [M:ABF2]ZINTFLD(J) = TEXTE
    [M:ABF2]CODTYP(J)  = [F:ATZ]CODTYP
    [M:ABF2]LNGFLD(J)  = [F:ATZ]LONG
    If [F:ATY]TYPTYP=1
     [M:ABF2]MENLOC(J)  = [F:ATZ]NOLIB
    Elsif [F:ATY]TYPTYP=8
     [M:ABF2]TYPDAT(J) = "YMQ"
    Elsif [F:ATY]CODTYP="ADI"
     [M:ABF2]TABDIV(J) = max(1,val([F:ATZ]EXPLIEN))
    Endif
    [M:ABF2]TYPOPE(J)  = 1
    [M:ABF2]ACTFLD(J)  = [F:ATZ]CODACT
    If [F:ATY]OBJLIEN<>"" or [F:ATY]TYPTYP=8 or [F:ATY]CODTYP="ADI" or [F:ATY]CODTYP="ADS"
     [M:ABF2]TYPFLD(J) = 3
    Elsif [F:ATY]CODTYP="ACS"
     [M:ABF2]TYPFLD(J) = 4
    Elsif find([F:ATY]TYPTYP,4,5,6)
     [M:ABF2]TYPFLD(J) = 1
    Else
     [M:ABF2]TYPFLD(J) = 2
    Endif
   Endif
  Endif
 Endif
Next I
Affzo [ABF2]
Return

$DIMENSION
For I=0 To [M:DIA]NBLIG-1
 CHAMP = [M:DIA]CODZONE(I)
 If [M:DIA]SELECT(I)=2
  OKFLD  = !find(CHAMP,[M:ABI2]FLDDIM(0..[M:ABI2]NBRFLD-1))
  OKFLD *= [M:ABI2]NBRFLD<dim([M:ABI2]FLDDIM)
  If OKFLD
   OKFLD = 0
   Read [ATZ]CODZONE = [M:DIA]FICHIER;CHAMP
   For NUMTEX=[F:ATZ]NOCOURT,[F:ATZ]NOLONG,[F:ATZ]NOABREG
    Call TEXTE(NUMTEX,TEXTE) From OBJDIV
    If !find(TEXTE,[M:ABI2]ZINTDIM(0..[M:ABI2]NBRFLD-1))
     OKFLD = 1 : Break
    Endif
   Next NUMTEX
   If OKFLD
    Insa  NOLI,1,[M:ABI2]NBRFLD [M:ABI2]NBRFLD
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    J = NOLI
    NOLI += 1
    [M:ABI2]NBRFLD += 1
    [M:ABI2]FLDDIM(J)  = [M:DIA]CODZONE(I)
    [M:ABI2]INTDIM(J)  = NUMTEX
    [M:ABI2]ZINTDIM(J) = TEXTE
    [M:ABI2]CODTYP(J)  = [F:ATZ]CODTYP
    [M:ABI2]LNG(J)     = [F:ATZ]LONG
    If [F:ATY]TYPTYP=1
     [M:ABI2]MENLOC(J)  = [F:ATZ]NOLIB
    Elsif [F:ATY]TYPTYP=8
     [M:ABI2]TYPDAT(J) = "YMQ"
    Elsif [F:ATY]CODTYP="ADI"
     [M:ABI2]TABDIV(J) = max(1,val([F:ATZ]EXPLIEN))
    Endif
    [M:ABI2]ACTDIM(J)  = [F:ATZ]CODACT
    [M:ABI2]TYPFLD(J)  = 0
    If [F:ATY]OBJLIEN<>""
     Filter [ABI2] Where TABORG=[F:ATY]FICLIEN
     For [ABI2]ABI0
      If !find([F:ABI2]CODDIM,[M:ABI2]DIMFAT(0..[M:ABI2]NBRFLD-1))
       [M:ABI2]TYPFLD(J) = 3
       [M:ABI2]DIMFAT(J) = [F:ABI2]CODDIM
       K = instr(1,[F:ABI2]CLE,"+")
       If K
        [M:ABI2]DIMFLD(J) = left$([F:ABI2]CLE,K-1)
       Else
        [M:ABI2]DIMFLD(J) = [F:ABI2]CLE
       Endif
       Break
      Endif
     Next
     Filter [ABI2]
    Endif
    If [M:ABI2]TYPFLD(J)=0
     If [F:ATY]TYPTYP=8 or [F:ATY]CODTYP="ADI" or [F:ATY]CODTYP="ADS"
      [M:ABI2]TYPFLD(J) = 1
     Elsif [F:ATY]CODTYP="ACS"
      [M:ABI2]TYPFLD(J) = 4
     Else
      [M:ABI2]TYPFLD(J) = 2
      For K=J-1 To 0 Step -1
       If [M:ABI2]TYPFLD(K)=1
        [M:ABI2]FLDLIE(J) = [M:ABI2]FLDDIM(K)
        Break
       Endif
      Next K
     Endif
    Endif
    [M:ABI2]FLDORG(J)  = "[F:"+[F:ATB]ABRFIC+"]"+CHAMP
   Endif
  Endif
 Endif
Next I
Affzo [ABI2]
Return

######################################################################################
# Gestion du masque ABISELZON
######################################################################################

Subprog IB_FICHIER
End

Subprog AM_FICHIER(VALEUR)
Variable Char VALEUR()
Local Integer OK
Effzo 10
nolign = 0
For [ATZ]NUMLIG Where CODFIC=VALEUR
 nolign += 1
 [M] = [F:ATZ]
 Call TEXTE([F:ATZ]NOCOURT,[M]INTITCOURT(nolign-1)) From OBJDIV
 Case [M]TYPTAB
  When 1
   OK = find([F:ATZ]CODZONE,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
  When 2
   OK = find([F:ATZ]CODZONE,[M:ABI2]FLDDIM(0..[M:ABI2]NBRFLD-1))
  When Default
   OK = 0
 Endcase
 OK += find([F:ATZ]CODZONE,"CREDAT","CREUSR","CRETIM","UPDDAT","UPDUSR","UPDTIM","EXPNUM")
 If OK
  [M]SELECT(nolign-1) = 1
 Else
  [M]SELECT(nolign-1) = 2
 Endif
Next
[M]NBLIG = nolign
Affzo 10
End

Subprog IB_NBLIG
GBOUT2 = mess(202,124,1) : # Oui à tout le reste
GBOUT3 = mess(203,124,1) : # Non à tout le reste
End

Subprog B2_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]SELECT(I-1) = 2
Next I
Affzo 10
End

Subprog B3_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]SELECT(I-1) = 1
Next I
Affzo 10
End



