#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# SUBPODA : Gestion des demandes de livraison d'achat       CG 10/02/98 #
#           Modifié                                         HN Sep 2003 #
# --------------------------------------------------------------------- #
# Traitement des actions "GOSUB" de l'objet "POD"                       #
# Les traitements sur champ "Call" se trouvent dans le SUBPOD           #
#                                                                       #
# GCUR    = devise societe          GSYSCUR = devise dossier            #
# GFINRSP = site financier                                              #
#########################################################################


$FILTRE
#-------------------------------------------------------------#
# Besoin pour activer filtre sur les habilitations opérateurs #
# sinon filtre ne marche pas                                  #
#-------------------------------------------------------------#
Default File [POC]
Return


#------------------#
# Avant impression #
#------------------#
$AV_IMPRIME
Return


$OUVRE
# Issue 71276 - 2015-03-20 by SR : Versions
Global Char GFMT_MAJ(20)
Global Char GFMT_MIN(20)
GFMT_MAJ = "K:10X"
GFMT_MIN = "K:10X"
Raz GSOC_ACTIVE
#---------------------------------------------------#
# Ouvertures complémentaires en début de traitement #
#---------------------------------------------------#
If GMODU(2)=2  :# Compta
  Local File BALANA , BUD , BUDPAR
Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
GCONSDIA=0 : # Rend saisissable les écrans avec abréviation [DIA]
#-----
Raz GPURPICKING, GPURTRACE, GQSEQ, GPOQSEQ, GPUU
#----- Montant du contrat HT et TTC init sur étiquette LIENS -----#
Raz GTOTORD, GTTVORD
#----- Variables locales -----#
Local Libelle  OLD_WIPSTA, OLD_LINSTA
Local Integer  I, K, STAT, WPOPSEQ1, WPOPSEQ2, WPOPSEQ
Local Shortint OUVFICFLG, SAVNOLIGN, TARFLG
Local Char     VAT(GLONVAT)(3), WSECTION(GLONCCE)
Local Decimal  WCLCAMT(1..7)
Local Decimal  WCOEUOM ,ANC_QTYSTU
Local Char     SYMBOLE2(20)         : # Pour verrou du contrat
#-----
If clalev ([F:PSO])<=0 Local File PREQUISO  [PSO] : Endif
#----- Pour calcul montant ligne DL ferme -----#
If !clalev([F:PO1])  Local File PORDERP    [PO1] : Endif
If !clalev([F:PO2])  Local File PORDERP    [PO2] : Endif
#-----
If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] : Endif
If !clalev([F:GCM])  Local File GACM       [GCM] : Endif
#----------------------------
# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

#----- Effacement fichier de travail -----#
Gosub EFFAC_PWRKORDERS From SUBPODA : If OK=0 Return : Endif
#---------------------------------------------------------#
# Pas de transaction pour les demandes de livraisons      #
#---------------------------------------------------------#
Gosub DECLARE From TABLEAUX
Local Mask PPICORD1 [PPI1] : # Masque prise en compte des besoins
Local Mask ORDK     [ORDK] : # Masque paramètres encours
#-----
If GMODU(5)=2 : # Si module Ventes présent
  Local Mask SORW   [SORW] : # Pour màj contrat ventes
  If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:ITS])  Local File ITMSALES   [ITS] : Endif
  If !clalev([F:MVC])  Local File BPCUSTMVT  [MVC] : Endif
  If !clalev([F:SOH])  Local File SORDER     [SOH] : Endif
  If !clalev([F:BPD])  Local File BPDLVCUST  [BPD] : Endif
Endif
If !clalev([F:STCF])   Local File COSTSTCF   [STCF] : Endif # Issue 90991 - 2013-10-29 by MUARN : sdc sites
Return


$SETBOUT
#-----------------------------------------------#
# Suppression du bouton # Code                  #
# On ne doit pas pouvoir modifier la clé        #
# Suppression des boutons création, suppression #
#-----------------------------------------------#
Call VIREBOUT (CHAINE,"ACDH")  From GOBJET
#----- Boutons tunnel contrat et visu réceptions -----#
If !CLECUR | GREP="M"
  Call VIREBOUT (CHAINE,"12") From GOBJET
Endif
If find("GESPOC",GNAVIG(1..GPILNAV)) Then Call VIREBOUT (CHAINE,"1") From GOBJET Endif
#----- Menu "Visualisation des demandes de livraison" dans la ToolBar -----#
If GREP="" & CLECUR  CHMEN+="F" : Endif
#----- Menu "Traçabilité pièces" -----#
If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "N" Endif # SYMEU 10/12/2008 : branchement traçabilité pièces
Gosub SET_BOUT_SPE From GSAISIE
Return


$AVANTBOUT
#-----------------------------#
# Avant exécution des boutons #
# --------------------------- #
# 1 = Contrat                 #
# 2 = Réceptions              #
#-----------------------------#
Local  Char     SAV_ZONCOU(GLONAVA)
If GREP<>"" SAV_ZONCOU=COUZON Else SAV_ZONCOU="" : Endif
Case BOUT
Endcase
Return


$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
# 1 = Contrat                        #
# 2 = Réception                      #
#------------------------------------#
Case BOUT
  When "1" : Default File [POC] : Gosub RELIT From GOBJSUB
Endcase
Return


$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
#-------------------------------------------#
Case BOUT
Endcase
#VPO 14/03/11 72298 ajout test dim(SAV_ZONCOU)
If dim(SAV_ZONCOU)>0 & SAV_ZONCOU<>"" & !GIMPORT  SUIZON=SAV_ZONCOU : Endif
Return


$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
# -------------------------------- #
# Critère lecture     (CRIT)       #
# Nom du fichier      (FICLIG)     #
# Abréviation fichier (ABLIG)      #
# Zone numéro ligne   (ZONLIG)     #
#----------------------------------#
Default File [POQ]
Default Mask [POD1]
#----- On remet un filter à cause du filtre sur lignes soldées -----#
Filter [POQ]
#----- Les lignes soldées ne sont pas toutes affichées -----#
CRIT = 'POHNUM="'+[M:POD1]POHNUM+'" & POPLIN='+num$([M:POD1]POPLIN)+' & POQSEQ>=GPOQSEQ'
# Issue 114874 - 2016-03-10 by SR : ajouter des filtres supplémentaires
GPOINT = "CUSADDCRIT" : Gosub ENTREE From EXEFNC

FICLIG = "PORDERQ"
ABLIG  = "POQ"
ZONLIG = "POQSEQ"
Return

$LIENS_LIG

#-----------------------------------------------------------#
# Ici on se trouve dans la boucle de chargement des détails #
# Il faut charger certains champs de l'écran                #
#-----------------------------------------------------------#
[M:POD1]ORIQTYPUU(nolign-1)  = [F:POQ]QTYPUU
[M:POD1]XPRHFCY  (nolign-1)  = [F:POQ]PRHFCY
[M:POD1]XFCYADD  (nolign-1)  = [F:POQ]FCYADD
If [M:POD1]EXTRCPDAT (nolign-1) < date$
  If [M:POD1]LINSTA (nolign-1) <> 3
    [M:POD1]LINSTA (nolign-1) = 2
  Endif
Endif
#----- Calcul avance retard si ligne ferme et retard -----#
If [M:POD1]WIPSTA (nolign-1) = 1 & [M:POD1]LINSTA (nolign-1) = 2
  [M:POD1]XEARQTY += [M:POD1]QTYPUU (nolign-1)
Endif
#----- Chargement zone WRCPDAT -----#
Local Shortint WJOUR ,WMOIS ,WANNEE
Local Char     WDATE(10)
WANNEE = val(left$([M]EXTRCPDAT (nolign-1),4))
WMOIS  = val(mid$([M]EXTRCPDAT (nolign-1),5,2))
WJOUR  = val(right$([M]EXTRCPDAT (nolign-1),7))
If [M]CAD (nolign-1) = 1    : #----- Cadencement jour
  Gosub DAT8 From SUBPODA
  [M]WRCPDAT  (nolign-1) = WDATE
  [M]STRRCPDAT(nolign-1) = [M]EXTRCPDAT (nolign-1)
Elsif [M]CAD (nolign-1) = 3 : #----- Cadencement mois
  [M]STRRCPDAT (nolign-1) = aweek([M]WEE(nolign-1),[M]YEA(nolign-1))
  Local Char WWMOIS
  If len(num$(WMOIS))= 1
    WWMOIS = "0"+num$(WMOIS)
  Else
    WWMOIS = num$(WMOIS)
  Endif
  WDATE= format$("K:2#[-]4#",WWMOIS+num$(WANNEE))
  [M]WRCPDAT (nolign-1) = WDATE
Else                        : #----- Cadencement semaine
  [M]STRRCPDAT(nolign-1) = aweek([M]WEE(nolign-1),[M]YEA(nolign-1))
  Local Char WSEM
  If len(num$([M]WEE(nolign-1)))= 1
    WSEM = "00"+num$([M]WEE(nolign-1))
  Elsif len(num$([M]WEE(nolign-1)))= 2
    WSEM = "0"+num$([M]WEE(nolign-1))
  Else
    WSEM = num$([M]WEE(nolign-1))
  Endif
  WDATE= format$("K:3#[-]4#",WSEM+num$([M]YEA (nolign-1)))
  [M]WRCPDAT (nolign-1) = WDATE
Endif
#VPO 09/12/10 17667
[M:POD1]UPDPSDFLG(nolign-1)=1
Return


$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
Call RELEC From SUBPODA : # Relecture article et article-fournisseur
#----- Zones du detail -----#
If [F:POQ]LINSTA=3  [F:POQ]LINCLEFLG=2 Else  [F:POQ]LINCLEFLG=1 : Endif
[F:POQ]CPY       = GSOCIETE
[F:POQ]POHNUM    = [M:POD1]POHNUM
[F:POQ]POPLIN    = [M:POD1]POPLIN
[F:POQ]POQLNK    = mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&                 +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
[F:POQ]ITMREFBPS = [F:ITP]ITMREFBPS
[F:POQ]POHTYP    = 2
[F:POQ]ORI       = 1
[F:POQ]LINSTOFCY = [M:POD1]STOFCY
[F:POQ]PRHFCY    = [M:POD1]XPRHFCY(nolign-1)
[F:POQ]FCYADD    = [M:POD1]XFCYADD(nolign-1)
[F:POQ]DEMRCPDAT = [M:POD1]STRRCPDAT(nolign-1)
[F:POQ]DEMENDDAT = [M:POD1]EXTRCPDAT(nolign-1)
[F:POQ]DEMENDHOU = [F:POQ]DEMRCPHOU
[F:POQ]RCPCLEFLG = 1
[F:POQ]PUU       = [F:POC]PUU
[F:POQ]STU       = [F:POC]STU
[F:POQ]BPSINV    = [F:POH]BPSINV
[F:POQ]LININVFLG = 1
[F:POQ]LINPRNFLG = 1
[F:POQ]LINTYP    = 1 : # Ligne classique (indépendante)
[F:POQ]CMMTAX           =max(GPURCMMTAX,1) : # Indicateur Type d'engagement
[M:POD1]CMMTAX(nolign-1)=max(GPURCMMTAX,1) : # Indicateur Type d'engagement
#----- Contrat inter-sites/intra-sociétés, type d'ordre = "TR" autrement = "PO" -----#
If [M:POD1]BETFCY=2 & [M:POD1]BETCPY<>2 [F:POQ]WIPTYP=7 Else [F:POQ]WIPTYP=2 : Endif
#----- Calcul qté commande en US -----#
Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,
&             [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
#----- Calcul qté besoins pris en US -----#
Call PCAL_QTY([F:POQ]RETQTYPUU,[F:POQ]PUU,[F:POQ]RETQTYSTU,[F:POQ]STU,
&             [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
#----- Qté en unité cde = qté en unité achat -----#
[F:POQ]QTYUOM    = [F:POQ]QTYPUU
[F:POQ]UOMPUUCOE = 1
[F:POQ]UOMFLG    = 1
[F:POQ]UOM       = [F:POQ]PUU
#-------------------------------------------#
# Calcul des montants sur les lignes fermes #
# Création si besoin d'un POP               #
# Rien si contrat inter-site !!             #
#-------------------------------------------#
If [M:POD1]WIPSTA(nolign-1)=1
  Gosub CALPOD From SUBPODA
  If GOK<1  Return : Endif
Endif
#----- Il faut récupérer le chrono pour les encours -----#
If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[F:POQ]PRHFCY
  Read [ITF] ITF0=[F:POQ]ITMREF;[F:POQ]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD>1
  Call NUMERO(GWIP,[F:POQ]PRHFCY,date$,"",[F:POQ]WIPNUM,STAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | STAT<>0
    GOK=0 : GERR=1 : GMESSAGE=GWIP-mess(60,199,1)
    Return
  Endif
Endif
#---------------------------------------------------------------------#
# Appel du S/P ventes pour création de la ligne quantité (SORDERQ) et #
# récupération du numéro de séquence ventes pour maj dans le PORDERQ  #
#---------------------------------------------------------------------#
If [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD    = "C"
  [M:SORW]SOHNUM    = [M:POD1]OCNNUM
  [M:SORW]SALFCY    = [M:POD1]SALFCY
  [M:SORW]BPCORD    = [M:POD1]BPCORD
  [M:SORW]STOFCY    = [M:POD1]STOFCY
  [M:SORW]PRHFCY    = [M:POD1]PRHFCY
  [M:SORW]VLYDATCON = [F:POH]ENDDAT
  [M:SORW]POHNUM    = [M:POD1]POHNUM
  [M:SORW]SOPLIN    = [F:POC]POPLIN
  [M:SORW]ITMREF    = [F:POC]ITMREF
  [M:SORW]VLYDATITM = [F:POC]ENDDAT
  [M:SORW]EXTQTY    = [F:POC]EXTQTYPUU
  [M:SORW]SAU       = [F:POC]PUU
  [M:SORW]POPLIN    = [F:POC]POPLIN
  [M:SORW]DEMDLVDAT = [F:POQ]DEMRCPDAT
  [M:SORW]QTY       = [F:POQ]QTYPUU
  [M:SORW]DEMSTA    = [F:POQ]WIPSTA
  [M:SORW]USEPLC    = [F:POQ]USEPLC
  [M:SORW]CAD       = [F:POQ]CAD
  # 105605 : CCM - Revision index (LD:03/06/15)
  If dim([M:SORW]ECCVALMAJ) > 0       : # Issue 116162
      [M:SORW]ECCVALMAJ = [F:POQ]ECCVALMAJ
      [M:SORW]ECCVALMIN = [F:POQ]ECCVALMIN
  Endif                               : # Issue 116162
  # 105605 : CCM - Revision index (LD:03/06/15)
  If [F:POQ]CAD=1
    [M:SORW]DLVDAY  = val(left$(num$([F:POQ]DEMRCPDAT),2))
    [M:SORW]MON     = [F:POQ]MON
    [M:SORW]YEA     = [F:POQ]YEA
  Elsif [F:POQ]CAD=2
    [M:SORW]WEE     = [F:POQ]WEE
    [M:SORW]YEA     = [F:POQ]YEA
  Else
    [M:SORW]MON     = [F:POQ]MON
    [M:SORW]YEA     = [F:POQ]YEA
  Endif
  [M:SORW]POQSEQ    = [F:POQ]POQSEQ
  [M:SORW]SOQSTA    = [F:POQ]LINSTA
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  # Le PJT transite uniquement en intersite
  If [M:POD1]BETCPY=1
      [M:SORW]PJT=[F:POC]PJT
  Endif
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  Call MAJ_SOQ From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
  [F:POQ]LINOCNNUM=[M:POD1]OCNNUM
  [F:POQ]OCNLIN=[M:SORW]SOPLIN
  [F:POQ]OCNSEQ=[M:SORW]SOQSEQ
Endif
#----- Récupération des liens texte article ou article-fournisseur -----#
If [M:POD1]LINTEX(nolign-1)=""
  If [F:ITP]TEX<>""
    [M:POD1]LINTEX(nolign-1)=[F:ITP]TEX
  Else
    [M:POD1]LINTEX(nolign-1)=[F:ITM]PURTEX
  Endif
Endif
#----------------------------------------#
# Création ou duplication du texte ligne #
#----------------------------------------#
Gosub CHARG_TEXT_LIGNE

# Issue 84130 - 2013-02-19 by MUARN : landed cost
# Issue 90991 - 2013-10-29 by MUARN : ajout SDC au niveau site
#If [F:POQ]PRHFCY=[F:POC]PRHFCY
#  [F:POQ]CPRCOE=[F:POC]CPRCOE
#  [F:POQ]CPRAMT=[F:POC]CPRAMT
#  [F:POQ]STCNUM=[F:POC]STCNUM
#  [F:POQ]CPRCUR=[F:POC]CPRCUR
  [F:POQ]NETCUR=[F:POH]CUR
#Endif

Return


$INIMOD_LIG
#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
Call RELEC From SUBPODA : # Relecture article et article-fournisseur
#----- Zones du detail -----#
If [F:POQ]LINSTA=3  [F:POQ]LINCLEFLG=2 Else  [F:POQ]LINCLEFLG=1 : Endif
[F:POQ]FBUFLG    = 1
[F:POQ]LININVFLG = 1
[F:POQ]LINPRNFLG = 1
[F:POQ]ORDDAT    = [F:POH]ORDDAT
[F:POQ]PRHFCY    = [M:POD1]XPRHFCY  (nolign-1)
[F:POQ]FCYADD    = [M:POD1]XFCYADD  (nolign-1)
[F:POQ]DEMRCPDAT = [M:POD1]STRRCPDAT(nolign-1)
[F:POQ]DEMENDDAT = [M:POD1]EXTRCPDAT(nolign-1)
#----- Contrat inter-sites/intra-sociétés, type d'ordre = "TR" autrement = "PO" -----#
If [M:POD1]BETFCY=2 & [M:POD1]BETCPY<>2 [F:POQ]WIPTYP=7 Else [F:POQ]WIPTYP=2 : Endif
#----- Calcul qté commande en US -----#
Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,
&             [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
#----- Calcul qté besoins pris en US -----#
Call PCAL_QTY([F:POQ]RETQTYPUU,[F:POQ]PUU,[F:POQ]RETQTYSTU,[F:POQ]STU,
&             [F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
#----- Calcul des qtés en UC -----#
[F:POQ]QTYUOM = [F:POQ]QTYPUU
#-------------------------------------------#
# Calcul des montants sur les lignes fermes #
# Création si besoin d'une ligne POP        #
# Rien site inter-site et intra-soc
#-------------------------------------------#
If [M:POD1]WIPSTA(nolign-1)=1
  Gosub CALPOD From SUBPODA
  If GOK<1  Return : Endif
Else
  [F:POQ]LINAMT    = 0
  [F:POQ]LINATI    = 0
  [F:POQ]LINATIAMT = 0
Endif
#----------------------------------------#
# Création ou duplication du texte ligne #
#----------------------------------------#
Gosub CHARG_TEXT_LIGNE
Return


$VALLIG
#----------------------------------------------------------------------#
# Traitements complémentaires ligne DL                                 #
# SIGN vaut +1 en création ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
#----------------------------------------------------------------------#
Call RELEC From SUBPODA : # Lecture fichiers article et article-fournisseur si besoin
#----- Lecture ligne prix pour récupération de l'affaire -----#
If [F:POP]POHNUM<>[F:POQ]POHNUM | [F:POP]POPLIN<>[F:POQ]POPLIN | [F:POP]POPDAT<[F:POQ]DEMRCPDAT
  Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
  Read [POP] POP1 First : If fstat  Raz [F:POP] : Endif
  Filter [POP]
Endif
#----------------------------------------------------------#
# mise à jour en ligne à ligne  apres le write ligne       #
# mise à jour en ligne à ligne  avant le delete  lig       #
# -------------------------------------------------------- #
# la gestion des signatures se fait sur le contrat complet #
# la mise à jour des budgets se fait a la creation des DL  #
#----------------------------------------------------------#
If TRTLIG="M" & SIGN=-1
   #----- Cas particulier où l'on modifie le texte en le supprimant -----#
   If [M:POD1]LINTEX(nolign-1)="" & left$([F:POQ]LINTEX,3)="POQ"
     Call SUP_CLOB([F:POQ]LINTEX,GBIDI1) From TRTX3TEX
   Endif
   #-----
   OLD_LINSTA=[F:POQ]LINSTA
   OLD_WIPSTA=[F:POQ]WIPSTA
   Goto MAJ_ITV
Elsif TRTLIG="A"
   #----- Suppression du texte ligne si nécessaire -----#
   If left$([F:POQ]LINTEX,3)="POQ"
     Call SUP_CLOB([F:POQ]LINTEX,GBIDI1) From TRTX3TEX
   Endif
Endif
#-----------------------------------------------#
# si ligne soldée et que l on vient de la creer #
#-----------------------------------------------#
If TRTLIG = "C" & [F:POQ]LINSTA = 3  Goto MAJ_ITV : Endif
#---------------------------------------------#
# Màj si solde ou désolde d'une DL inter-site #
#---------------------------------------------#
If TRTLIG="M" & SIGN=1 & [M:POD1]BETFCY=2 & [M:POD1]SALFCY<>"" &
&  OLD_LINSTA<>[F:POQ]LINSTA & (OLD_LINSTA=3 |  [F:POQ]LINSTA=3)
  #----- Màj indicateur livraison réceptionnée -----#
  If [F:POQ]SDHNUM<>""
    If clalev([F:SDD])=0 Local File SDELIVERYD [SDD] : Default File [POQ] : Endif
    If [F:POQ]LINSTA=3
      Update [SDD] Where SDHNUM=[F:POQ]LINOCNNUM & SDDLIN=[F:POQ]OCNLIN
&                  With RCPFLG=2
    Else
      Update [SDD] Where SDHNUM=[F:POQ]LINOCNNUM & SDDLIN=[F:POQ]OCNLIN
&                  With RCPFLG=1
    Endif
    If fstat GOK=0 : Call FSTA("SDD") From GLOCK : Return : Endif
  Endif
  #----- Màj indicateur solde DL vente si besoin -----#
  If clalev([F:SOQ])=0 Local File SORDERQ [SOQ] : Default File [POQ] : Endif
  If [F:SOQ]SOHNUM<>[F:POQ]LINOCNNUM |
&    [F:SOQ]SOPLIN<>[F:POQ]OCNLIN |
&    [F:SOQ]SOQSEQ<>[F:POQ]OCNSEQ
     Read [SOQ] SOQ0=[F:POQ]LINOCNNUM;[F:POQ]OCNLIN;[F:POQ]OCNSEQ
    If fstat Raz [F:SOQ] : Endif
  Endif
  #----- On ne touche à l'indicateur de solde que si la DL vente est "vierge" -----#
  If [F:SOQ]ALLQTY=0 & [F:SOQ]ODLQTY=0 & [F:SOQ]DLVQTY=0
    If [F:POQ]LINSTA=3 & [F:SOQ]SOQSTA<>3
      #----- Solde de la ligne DL vente ------#
      Raz [M:SORW]
      [M:SORW]MAJCOD = "S"
      [M:SORW]SOHNUM = [F:POQ]LINOCNNUM
      [M:SORW]SOPLIN = [F:POQ]OCNLIN
      [M:SORW]SOQSEQ = [F:POQ]OCNSEQ
      Call MAJ_SOQ From TRTVENMSIT
      If GMESSAGE<>"" GERR=1 : Endif
      If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
    Elsif [F:POQ]LINSTA<>3 & [F:SOQ]SOQSTA=3
      #----- Désolde de la ligne DL vente -----#
      Raz [M:SORW]
      [M:SORW]MAJCOD = "S"
      [M:SORW]SOHNUM = [F:POQ]LINOCNNUM
      [M:SORW]SOPLIN = [F:POQ]OCNLIN
      [M:SORW]SOQSEQ = [F:POQ]OCNSEQ
      Call MAJ_SOQ From TRTVENMSIT
      If GMESSAGE<>"" GERR=1 : Endif
      If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
    Endif
  Endif
Endif
#-------------------------------------------------------------#
# orders cle principale ordtyp et ordnum                      #
# le passage de ??P en ??F ne pose pas de problème sur ORACLE #
# le rewrite est bien fait                                    #
#-------------------------------------------------------------#
If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[F:POQ]PRHFCY
  Read [ITF] ITF0=[F:POQ]ITMREF;[F:POQ]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD>1
  Raz [M:ORDK]
  #-----------------------------------------#
  # Si ligne soldée --> encours a supprimer #
  #-----------------------------------------#
  If [F:POQ]LINSTA = 3
    [M:ORDK]MAJCOD    = "A"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP : # PO ou TR
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
  Else
    If TRTLIG="M"
      Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
      If fstat  Raz [F:ORD] : Endif
      [M:ORDK]=[F:ORD]
    Endif
    [M:ORDK]MAJCOD    = TRTLIG
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP : # PO ou TR
    [M:ORDK]WIPSTA    = [F:POQ]WIPSTA : #  P ou F
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
    [M:ORDK]STOFCY    = [F:POQ]PRHFCY
    # Issue 71069 - 2016-03-25 by MUARN : PJT dans PORDERC et non PORDERP
    [M:ORDK]PJT       = [F:POC]PJT
    [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
    [M:ORDK]STRDAT    = [F:POQ]DEMRCPDAT
    [M:ORDK]ENDDAT    = [F:POQ]DEMENDDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:POQ]POHNUM
    [M:ORDK]VCRLIN    = [F:POQ]POPLIN
    [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
    [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
    [M:ORDK]CPLQTY    = 0
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = 1
    [M:ORDK]MRPMES    = 1
    # Issue 71276 - 2015-02-27 by SR : Versions
    If dim([M:ORDK]ECCVALMAJ)> 0
     [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
     [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
    Endif
    # End issue 71276
    #----- Chargement pièce origine si création autrement conservation valeurs -----#
    If [M:ORDK]MAJCOD="C" | [F:ORD]WIPNUM=""
      [M:ORDK]VCRTYPORI = 0
      [M:ORDK]VCRNUMORI = ""
      [M:ORDK]VCRLINORI = 0
      [M:ORDK]VCRSEQORI = 0
      #----- Contrats inter-sites intra-société -----#
      If [F:POQ]WIPTYP=7
        [M:ORDK]ORIFCY=[F:POQ]LINSTOFCY
        #----- Si pendant vente uniquement
        If [M:POD1]SALFCY<>""
          [M:ORDK]VCRTYPORI = 2
          [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
          [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
          [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
        Endif
      #----- Autres contrats -----#
      Else
        [M:ORDK]ORIFCY    = [F:POQ]POHFCY
        #----- Chargement pièce d'origine si un seul besoin pris -----#
        If [F:POQ]RETQTYSTU<>0
          Raz GBIDI1
          For [PWO] PWO0 Where PRONUM=adxuid(1)
&                            & CODFNC="POD"
&                            & LINNUM=[M:POD1]POHLIN(nolign-1)
            GBIDI1+=1
          Next
          If GBIDI1=1 & [F:PWO]PSDLIN=0
            Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
            If !fstat
              If [F:ORD]VCRTYPORI>0 & [F:ORD]VCRNUMORI<>""
                [M:ORDK]ITMREFORI=[F:ORD]ITMREFORI
                [M:ORDK]VCRTYPORI=[F:ORD]VCRTYPORI
                [M:ORDK]VCRNUMORI=[F:ORD]VCRNUMORI
                [M:ORDK]VCRLINORI=[F:ORD]VCRLINORI
                [M:ORDK]VCRSEQORI=[F:ORD]VCRSEQORI
              Else
                [M:ORDK]VCRTYPORI=[F:ORD]VCRTYP
                [M:ORDK]VCRNUMORI=[F:ORD]VCRNUM
                [M:ORDK]VCRLINORI=[F:ORD]VCRLIN
                [M:ORDK]VCRSEQORI=[F:ORD]VCRSEQ
              Endif
            Else
              Raz [F:ORD]
            Endif
          # Issue 74341 - 2011-07-26 by VPO : il faut remettre à jour la POF regénérée
          # avec les infos de la DA (on est em modif, donc on n'a plus de WIPNUM de la POP mais la DA dans WIPNUM)
          Elsif GBIDI1=1 & [F:PWO]PSDLIN>0
                [M:ORDK]VCRTYPORI=14
                [M:ORDK]VCRNUMORI=[F:PWO]WIPNUM
                [M:ORDK]VCRLINORI=[F:PWO]PSDLIN
                [M:ORDK]VCRSEQORI=0
          ##fin Issue 74341
          Endif
        Endif
      Endif
    Endif
    #-----
    [M:ORDK]BOMALT = 0
    [M:ORDK]ORI    = 1
    [M:ORDK]ABBFIL = "POC"
  Endif
  Call WIP From TRTWIP : If GOK<1 Return : Endif
Endif

$MAJ_ITV
#---------------------------------------------------#
# mise à jour qté en commande dans mvt article site #
# si article gére en stock  et uniquement sur ferme #
#---------------------------------------------------#
If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[F:POQ]PRHFCY
  Read [ITF] ITF0=[F:POQ]ITMREF;[F:POQ]PRHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD = 1  : Goto MAJ_BUD : Endif
If clalev ([F:ITV]) = 0  : Goto MAJ_BUD : Endif
Call LECITV ([F:POQ]PRHFCY,[F:POQ]ITMREF,"",STAT) From  STKLIB
#-- stat = 0  on a trouve enreg / 1 = creation faite --#
#-- si stat > 3 : probleme mais on continue qd meme : message en dur pour phase de test
If STAT>2
  #Infbox("Erreur : Le site ou l'article ne sont pas alimenté")
  Goto MAJ_BUD
Endif
#-----
If STAT=2
  GMESSAGE="ITMMVT :"-[F:POQ]PRHFCY-[F:POQ]ITMREF-mess(60,100,1)
  If GOK=1  GOK=-1 : Endif
Endif
#-----
If GOK<>1  Return : Endif
#----------------------------------------#
# ligne soldée                           #
#       si creation rien a faire         #
#       si POP      rien a faire         #
#       si POF et sign + 1 rien a faire  #
# sign -1 : si ligne soldée rien a faire #
#----------------------------------------#
If [F:POQ]LINSTA = 3
  If TRTLIG = "C"                  : Goto MAJ_BUD : Endif
  If [F:POQ]WIPSTA = 2             : Goto MAJ_BUD : Endif
  If [F:POQ]WIPSTA = 1 & SIGN =  1 : Goto MAJ_BUD : Endif
Endif

If SIGN = -1 & [F:POQ]LINSTA = 3
             Goto MAJ_BUD
Elsif SIGN = -1 & [F:POQ]WIPSTA = 2
             Goto MAJ_BUD
Elsif SIGN = 1 & [F:POQ]WIPSTA = 2
             Goto MAJ_BUD
Elsif SIGN = 1 & [F:POQ]LINSTA = 3
             Goto MAJ_BUD
Endif


If TRTLIG = "M" & SIGN = - 1 & STAT = 1      :   Goto MAJ_BUD : Endif
If TRTLIG = "A" & STAT = 1                     : Goto MAJ_BUD : Endif

[F:ITV]ORDSTO += [F:POQ]QTYSTU*SIGN
Rewrite [ITV]
#------ pas de test status volontairement ---#

$MAJ_BUD
#-----------------------------------------------------#
# Pas de màj budget pour contrat inter-site intra-soc #
#-----------------------------------------------------#
If [M:POD1]BETFCY=2 & [M:POD1]BETCPY=1 Goto MAJ_MONTANT : Endif
#--------------------------------------------#
# Mise à jour budget uniquement sur le ferme #
# SIGN = -1 : sur PP rien a faire            #
# SIGN = -1 : si ligne soldée rien a faire   #
# SIGN =  1 : sur PP rien a  faire           #
# SIGN =  1 : sur ligne soldée rien a faire  #
#--------------------------------------------#
If SIGN=-1 & [F:POQ]WIPSTA=2
  Goto MAJ_MONTANT
Elsif SIGN=-1 & [F:POQ]LINSTA=3
  Goto MAJ_MONTANT
Elsif SIGN=1 & [F:POQ]WIPSTA=2
  Goto MAJ_MONTANT
Elsif SIGN=1 & [F:POQ]LINSTA=3
  Goto MAJ_MONTANT
Endif

$MAJ_BUD1
#----- Test presence du module compta -----#
If GMODU(2)=2
  If TRTLIG="M"
    If OLD_LINSTA<>[M:POD1]LINSTA(nolign-1) & (OLD_LINSTA=3 | [M:POD1]LINSTA(nolign-1)=3)
      GBIDC2="POQ2" : # Solde ou désolde ligne commande
    Else
      GBIDC2="POQ1" : # Modification ligne commande
    Endif
  Else
    GBIDC2="POQ"    : # Création ou suppression ligne commande
  Endif
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,SIGN,2,GBIDC2,2,GBIDI1) From TRTACHDIV1
  If GOK<1  Return : Endif
  If SIGN=1
    #-------------------------------------------------------#
    # Mise à jour du numéro d'engagement sur ligne commande #
    #-------------------------------------------------------#
    [M:POD1]CMMNUM(nolign-1)=[F:POQ]CMMNUM
    Local Char    WPOHNUM(GLONPOH), WCMMNUM(GLONVCR)
    Local Integer WPOPLIN,  WPOQSEQ
    Local Libelle WCMMFLG
    WPOHNUM=[F:POQ]POHNUM : WPOPLIN=[F:POQ]POPLIN
    WPOQSEQ=[F:POQ]POQSEQ : WCMMNUM=[F:POQ]CMMNUM
    WCMMFLG=[F:POQ]CMMFLG
    Update [POQ] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POQSEQ=WPOQSEQ
&                 With CMMNUM=WCMMNUM, CMMFLG=WCMMFLG
    If fstat GOK=0 : Call FSTA("POQ") From GLOCK : Endif
  Endif
Endif

$MAJ_MONTANT
#---------------------------------------#
# pour mettre à jour PORDER en MODIF    #
# dans le cas passage PF en PP c est ok #
# puisque sign-1 test ancienne valeur   #
#---------------------------------------#
If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
  If [F:POQ]QTYPUU<>0 & ([F:POQ]RCPQTYPUU<>0 | [F:POQ]INVQTYPUU<>0)
    If [F:POQ]INVQTYPUU>[F:POQ]RCPQTYPUU
      #----- Si article facturé avant réception ou jamais réceptionné -----#
      GTOTORD+=([F:POQ]LINAMT   *max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
      GTTVORD+=([F:POQ]LINATIAMT*max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
    Else
      #----- La réception partielle est permise pour l'inter-sites avec flux auto -----#
      GTOTORD+=([F:POQ]LINAMT   *max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
      GTTVORD+=([F:POQ]LINATIAMT*max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU)*SIGN
    Endif
  Else
    GTOTORD+=[F:POQ]LINAMT*SIGN
    GTTVORD+=[F:POQ]LINATIAMT*SIGN
  Endif
Endif

$FINVALLIG
#-------------------------------------------#
# Mise à jour DA après suppression d'une DL #
#-------------------------------------------#
If TRTLIG="A"
  Gosub MAJ_PREQUIS  From SUBPOHB : If GOK<1 Return : Endif
#VPO 09/12/10 17667 maj qte sur une DA
Elsif TRTLIG="M" & SIGN=-1 & [M:POD1]UPDPSDFLG(nolign-1)=2
  Gosub MAJ_PREQUIS  From SUBPOHB : If GOK<1 Return : Endif
#---------------------------------------------------------------#
# Mise à jour des besoins pris "POS" "POP" "TRS" "TPS" et "SCF" #
#---------------------------------------------------------------#
Elsif SIGN=1 & [F:POQ]RETQTYSTU<>0 & [F:POQ]SOHNUM=""
  Gosub EXPLOITE_PWO From SUBPOHB : If GOK<1 Return : Endif
  #VPO 09/12/10 17667 maj qte sur une DA
  If [M:POD1]UPDPSDFLG(nolign-1)=2 & TRTLIG="M"
    Gosub MAJ_PREQUISQTE From SUBPOHB : If GOK<1 Return : Endif
  Endif
Endif
#-----------------------------------------------------------------#
# En suppression de DL ferme ou modification de ferme à planifiée #
#       mettre à jour l'indicateur POPCREFLG si nécessaire        #
#-----------------------------------------------------------------#
If (TRTLIG="A" & [F:POQ]WIPSTA=1) | (TRTLIG="M" & OLD_WIPSTA=1 & [F:POQ]WIPSTA>1)
  Local Shortint I
  Local Integer  WPOPSEQ
  Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                    POPDAT>=[F:POQ]DEMRCPDAT
  Read [POP] POP1 First : If fstat Raz [F:POP] : Endif
  Filter [POP]
  If [F:POP]POHNUM<>""
    WPOPSEQ=[F:POP]POPSEQ
    For I=0 To [M:POD1]NBLIG-1
      If [M:POD1]WIPSTA(I)=1
        Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                    POPDAT>=[M:POD1]STRRCPDAT(I)
        Read [POP] POP1 First : If fstat Raz [F:POP] : Endif
        Filter [POP]
        If [F:POP]POPSEQ=WPOPSEQ Raz WPOPSEQ : Break : Endif
      Endif
    Next I
    If WPOPSEQ<>0
      Update [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPSEQ=WPOPSEQ
&                  With POPCREFLG=1
      If fstat GOK=0 : Call FSTA("POP") From GLOCK : Return : Endif
      [F:POP]POPCREFLG=1 : # La classe [F] n'est pas màj par l'Update
    Endif
  Endif
Endif
#------------------------------------------------------#
# Ce n'est pas un contrat inter-site, alors c'est fini #
#------------------------------------------------------#
If [M:POD1]BETFCY<>2 | [M:POD1]SALFCY="" Return : Endif
#----------------------------------------------------------------------#
# Nota : L'appel du S/P ventes pour création de la ligne qté (SORDERQ) #
#        est fait dans le INICRE_LIG                                   #
#----------------------------------------------------------------------#
# Appel du S/P ventes pour modification de la ligne quantité (SORDERQ) #
#----------------------------------------------------------------------#
If TRTLIG="M" & SIGN=1
  Raz [M:SORW]
  [M:SORW]MAJCOD = "M"
  [M:SORW]SOHNUM = [F:POQ]LINOCNNUM
  [M:SORW]SOPLIN = [F:POQ]OCNLIN
  [M:SORW]SOQSEQ = [F:POQ]OCNSEQ
  [M:SORW]QTY    = [F:POQ]QTYPUU-[M:POD1]ORIQTYPUU(nolign-1)
  [M:SORW]DEMSTA = [F:POQ]WIPSTA
  [M:SORW]USEPLC = [F:POQ]USEPLC
  [M:SORW]SOQSTA = [F:POQ]LINSTA
  # 105605 : CCM - Revision index (LD:03/06/15)
  If dim([M:SORW]ECCVALMAJ) > 0       : # Issue 116162
      [M:SORW]ECCVALMAJ = [F:POQ]ECCVALMAJ
      [M:SORW]ECCVALMIN = [F:POQ]ECCVALMIN
  Endif                               : # Issue 116162
  # 105605 : CCM - Revision index (LD:03/06/15)
  Call MAJ_SOQ From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
#---------------------------------------------------------------------#
# Appel du S/P ventes pour suppression de la ligne quantité (SORDERQ) #
#---------------------------------------------------------------------#
Elsif TRTLIG="A"
  Raz [M:SORW]
  [M:SORW]MAJCOD = "A"
  [M:SORW]SOHNUM = [F:POQ]LINOCNNUM
  [M:SORW]SOPLIN = [F:POQ]OCNLIN
  [M:SORW]SOQSEQ = [F:POQ]OCNSEQ
  Call MAJ_SOQ From TRTVENMSIT
  If GMESSAGE<>"" GERR=1 : Endif
  If GOK<1 : Return : Endif : # ça c'est mal passé, abandon de la transaction
Endif
Return


$LIENS

#-----------------------------------------------------#
# Liens exécuté après chaque lecture d'enregistrement #
#-----------------------------------------------------#
Raz GPURPICKING
#----- Lecture du PORDER si nécessaire -----#
If [F:POH]POHNUM<>[F:POC]POHNUM
  Read [POH] POH0=[F:POC]POHNUM : If fstat Raz [F:POH] : Endif
Endif
If [F:POH]POHNUM=""
  GMESSAGE=[F:POC]POHNUM-mess(178,199,1) : GERR=1 : OK=0 : Return
Endif
GTOTORD         = [F:POH]TOTORD
GTTVORD         = [F:POH]TTVORD
[M:POD1]ENDDAT  = [F:POC]ENDDAT
[M:POD1]STRDAT  = [F:POC]STRDAT
[M:POD1]ORDREF  = [F:POH]ORDREF
[M:POD1]ORDDAT  = [F:POH]ORDDAT
[M:POD1]BETCPY  = [F:POH]BETCPY
[M:POD1]BETFCY  = [F:POH]BETFCY
[M:POD1]SALFCY  = [F:POH]SALFCY
[M:POD1]BPCORD  = [F:POH]BPCORD
If [M:POD1]SALFCY<>""
  [M:POD1]OCNNUM= [F:POH]OCNNUM
  Read [FCY] FCY0=[F:BPR]FCY : If fstat  Raz [F:FCY] : Endif
  GCPY=[F:FCY]LEGCPY
Endif
[M:POD1]STOFCY     = [F:POC]STOFCY
[M:POD1]PRHFCY     = [F:POC]PRHFCY
[M:POD1]XEARQTY    = 0
[M:POD1]XEARDAT    = date$
# Issue 71276 - 2015-03-20 by SR : Versions
If [F:ITM]ITMREF <> [F:POC]ITMREF
  Read [F:ITM]ITM0 = [F:POC]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
GFMT_MAJ = "K:10X"
GFMT_MIN = "K:10X"

#                                                          # hcb 71276 deb
If dim([M:POD1]ECCVALMAJORI)>0
   [M:POD1]ECCVALMAJORI  = [F:POC]ECCVALMAJ   # version majeure origine
   [M:POD1]ECCVALMINORI  = [F:POC]ECCVALMIN   # version mineure origine
   If [M:POD1]WRCPDAT(0) = ""
      Raz  [M:POD1]ECCVALMAJ(0)
      Raz  [M:POD1]ECCVALMIN(0)
   Endif
Endif
#                                                          # hcb 71276 fin
If [F:ITM]ECCFLG <> 2
  GFMT_MAJ = "-K:10X"
  GFMT_MIN = "-K:10X"
Else
  Case [F:ITM]ECCSTO
    When 1 :
      GFMT_MAJ = "-K:10X"
      GFMT_MIN = "-K:10X"
    When  2 :
      GFMT_MAJ = "K:10X"
      GFMT_MIN = "-K:10X"
    When 3 :
      GFMT_MAJ = "K:10X"
      GFMT_MIN = "K:10X"
  Endcase
Endif
If [M:POD1]NBLIG = 0
  [M:POD1]NBLIG = 1
  Affzo [M:POD1]1-99
Endif
# End issue 71276

#-------------------------------------------------#
# il faut charger la societe juridique de enreg   #
# ainsi que le site financier et les parametres   #
# Rem si le site est financier -> FINRSPFCY = ""  #
#-------------------------------------------------#
Call DEFSITE([F:POH]POHFCY) From TRTACHDEF1
Call GLOBVAR([F:POH]POHFCY) From WWGLOBACH
Call GLOBVAR(GFINRSP)       From WWGLOBBUD
GFCY=[F:POH]POHFCY
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#----- Chargement et contrôle du compteur des encours -----#
Call LECTCA(7,OK) From SUBTCA
If fstat | !OK   GMESSAGE=mess(64,199,1)  : GERR=1 : OK=0 : Return : Endif
GWIP=[F:TCA]CODNUM(8)
#Call CTRCPT(GWIP,25,STAT) From STKLIB
#If STAT<>0 GMESSAGE=mess(222,199,1) : GERR=1 : OK=0 : Return : Endif
#------ Relecture des fichiers liés -----#
Call RELEC From SUBPODA
#----- Initialisation qté minimum -----#
[M]PURMINQTY=[F:ITP]PURMINQTY
If [M]PUU<>[F:ITP]PUU
   Call PCAL_QTY([F:ITP]PURMINQTY,[F:ITP]PUU,[M]PURMINQTY,[M]PUU,[F:POC]ITMREF,
&                [F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
Endif
#----- Chargement des sections analytiques entête -----#
If dim([M:POD1]NBAXE)>0
  Call CHARG_CCEH("POD1","NBAXE","POH") From TRTX3CPT
Endif
#----- Chargement des comptes -----#
Call CHARG_ACCX("POD1","NBCOA","LINACC","POC") From TRTX3CPT
#-------------------------------------------#
# Position du GPOQSEQ                       #
# recherche de la première ligne à afficher #
#-------------------------------------------#
Filter [POQ] Where POHNUM=[M:POD1]POHNUM & POPLIN=[M:POD1]POPLIN & LINSTA=3
Read [POQ] POQ0 Last  : If fstat  Raz [F:POQ] : Endif
GPOQSEQ=[F:POQ]POQSEQ
Filter [POQ] Where POHNUM=[M:POD1]POHNUM & POPLIN=[M:POD1]POPLIN & LINSTA<>3
Read [POQ] POQ0 First : If fstat  Raz [F:POQ] : Endif
#------------------------------------------------------#
# Entre la dernière ligne soldée et la 1ère non soldée #
#          on prend la plus petite des deux            #
#------------------------------------------------------#
If [F:POQ]POQSEQ<>0 & ([F:POQ]POQSEQ<GPOQSEQ | GPOQSEQ=0)
  GPOQSEQ=[F:POQ]POQSEQ
Endif
#-----
If GPOQSEQ=0
  GQSEQ=GPOQSEQ
Else
  Filter [POQ] Where POHNUM=[M:POD1]POHNUM & POPLIN=[M:POD1]POPLIN & POQSEQ<GPOQSEQ
  Read [POQ] Last
  If fstat
    GQSEQ=0
  Else
    GQSEQ=[F:POQ]POQSEQ
  Endif
Endif
Filter [POQ]
#-----
Raz [M:POD1]POHCOU, [M:POD1]POHLIN

Gosub LIENS From TABLEAUX
[M:POD1]PRHFCY = [F:POC]PRHFCY
#---------------------------------------------------------------------#
# il faut recupérer les paramètres pour les budgets                   #
# car on ne peut plus a ce niveau modifier le USER et le site cde     #
#---------------------------------------------------------------------#
Call DEFBUD("POH",[F:POH]POHFCY) From TRTACHDEF1

#---------------------------------------------------------------------#
# lecture du tiers pour recuperer le code pays si besoin creer PORDERP#
#---------------------------------------------------------------------#
Read [BPR]BPR0 = [F:POH]BPSNUM
If fstat  : Raz  [F:BPR] : Endif

#-------------------------------------------------------------#
# lecture du fournisseur pour recuperer la structure du tarif #
#-------------------------------------------------------------#
Read [BPS]BPS0 = [F:POH]BPSNUM
If fstat  : Raz  [F:BPS] : Endif

If [F:POH]BPRNAM (0) = ""
      [M:POD1]XBPRNAM = [F:BPS]BPSNAM (0)
Else  [M:POD1]XBPRNAM = [F:POH]BPRNAM (0)
Endif
#-------------------------------------------------------#
# chargement des numeros semaines                       #
# date fin validite- date jour                          #
# attention ici car remise à zero du masque dans gobjet #
#-------------------------------------------------------#
[M]WEESYST  = week(date$)
[M]YEASYST  = year(date$)

If [M]WEESYST = 53
    #--------------------------------------------------------------#
    # on regarde si le 4 jour de la semaine est sur annee suivante #
    #--------------------------------------------------------------#
      If  year(aweek ([M]WEESYST,year(date$)+ 3)) <> year(date$)
              [M]WEESYST = 1
              If month(date$) <> 1
                     [M]YEASYST +=1
              Endif
      Endif
Elsif [M]WEESYST = 0
      [M]WEESYST = 1
      If month(date$) <> 1
          [M]YEASYST +=1
      Endif
Endif

[M]WEEENDDAT = week([M]ENDDAT)
[M]YEAENDDAT = year([M]ENDDAT)
If [M]WEEENDDAT = 53
    #--------------------------------------------------------------#
    # on regarde si le 4 jour de la semaine est sur annee suivante #
    #--------------------------------------------------------------#
      If  year(aweek ([M]WEEENDDAT,year([F:POC]ENDDAT)+ 3)) <> year([F:POC]ENDDAT)
              [M]WEEENDDAT = 1
              If month([M]ENDDAT) <> 1
                     [M]YEAENDDAT +=1
              Endif
      Endif
Elsif [M]WEEENDDAT = 0
      [M]WEEENDDAT = 1
      If month([M]ENDDAT) <> 1
              [M]YEAENDDAT +=1
      Endif
Endif
#-----
If [M:POD1]REVNUM<>0 [M:POD1]FILLER1="/" : Endif
If GFONC1="GESPOD"  Call RAZ_CLOB From ACLOB : Endif
#---- Désactivation du site réception entête (mis en saisie pour le lien court) -----#
Diszo [POD1]PRHFCY
Diszo [POD1]STOFCY

# Issue 90991 - 2013-11-04 by MUARN : ajout SDC au niveau site
For I=0 To [M:POD1]NBLIG-1
  If [M:POD1]STCNUM(I)<> ""
    Diszo [M:POD1]CPRAMT(I)
    Diszo [M:POD1]CPRCOE(I)
  Else
    Actzo [M:POD1]CPRAMT(I)
    Actzo [M:POD1]CPRCOE(I)
  Endif
Next
Return


$VERIF_MOD
#------------------------------#
# Vérification en modification #
#------------------------------#
Gosub OUVERTURE_TRACE : # Ouverture fichier trace pour alertes budget si nécessaire
Return

$AVANT_MODFIC

# V6 Affectations
Gosub AVANT_MODFIC_POD From PURMTOLIB

Return

$AVANT_MOD
#--------------------------------------------------------#
# Il faut vérifier si on a droit de modifier le contrat  #
#--------------------------------------------------------#
# modification impossible                                #
# contrat soldé - contrat non signe si gestion signature #
#--------------------------------------------------------#
Default File [POQ]
Raz GMESSAGE
If [F:POH]CLEFLG=2
  GMESSAGE=mess(47,194,1) : # Commande soldée. Modification interdite.
Endif
If [F:POH]APPFLG<3
  GMESSAGE=mess(84,194,1) : # Contrat partiellement signé. Modif ou suppr interdite
Endif
If GMESSAGE <> ""
  GERR=1 : OK=0 : Return
Endif
#---------------------------------------#
# Il faut verrouiller symbole POH       #
# personne ne doit modifier le contrat  #
#---------------------------------------#
SYMBOLE2 = "POH"+num$([M:POD1]POHNUM)
Lock = SYMBOLE2 With lockwait = 0
OK=1
If fstat
  GMESSAGE=mess(10,100,1) : GERR=1 : OK=0
Endif
Return


$INIMOD
#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
#----- Calcul qté commandée en US -----#
Call PCAL_QTY([F:POC]ORDQTYPUU,[F:POC]PUU,[F:POC]ORDQTYSTU,[F:POC]STU,[F:POC]ITMREF,[F:POC]BPSNUM,1,WCOEUOM) From TRTACHQTE1
#----- Mise à jour de avance retard -----#
[F:POC]EARQTY = [M:POD1]XEARQTY
[F:POC]EARDAT = date$
[F:POC]DLVREQNUM += 1
Return


$MODIF
#------------------------------------------------#
# Modification ou ajout de demandes de livraison #
#------------------------------------------------#
GMODIF = 0
If clalev ([F:PSO])<=0 Local File PREQUISO  [PSO] : OUVFICFLG=1  : Endif
Gosub MODIF From TABLEAUX
If OUVFICFLG=1 Close Local File [PSO] : Raz OUVFICFLG : Endif
If GOK<1 : Return : Endif
#----- Il faut réécrire les totaux PORDER -----#
Readlock [POH]POH0 = [F:POH]POHNUM
If fstat=1
  GOK=-1 : GLOCK = "$PORDER"-[F:POH]POHNUM
  Call ROLL From GLOCK
  Return
Elsif fstat
  GOK= 0 : Call RSTA ("POH",[F:POH]POHNUM) From GLOCK
  Return
Endif
#-------------------------------------------------------#
# Les montants de la commande ne sont que pour le ferme #
# GBIDD1 et GBIDD2 pour mise à jour mvts supplier       #
# attention pas comme dans commande classique           #
# car une fois ligne soldée on ne peut plus la modifier #
#-------------------------------------------------------#
GBIDD1        = GTOTORD - [F:POH]TOTORD
GBIDD2        = GTTVORD - [F:POH]TTVORD
[F:POH]TOTORD = GTOTORD
[F:POH]TTVORD = GTTVORD
Rewrite [POH]
If fstat  GOK=0 : Call FSTA ("POH") From GLOCK : Return : Endif
#----- Mettre à jour le mouvement fournisseur -----#
GLOCALDEV = GCUR
Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POH]POHNUM,GBIDD1,GBIDD2,[F:POH]TTVORD) From TRTBPMVT
Return


$APRES_MOD
# V6 Affectations
Gosub MAJ_MTO_AP_ALL_POD From PURMTOLIB

#--------------------------------------------------------#
# Après modification : Effacement besoins pris en compte #
#--------------------------------------------------------#
Gosub EFFAC_PWRKORDERS From SUBPODA : # Effacement fichier de travail
Raz [M:POD1]POHCOU, [M:POD1]POHLIN
Gosub LIENS From SUBPODA
Affzo [POD1]25
Gosub LECTURE_TRACE    From SUBPODA : # Lecture fichier trace si nécessaire
Return


$AB_MODIF
#-----------------------------------------------#
# Abandon de la modification suite à une erreur #
#-----------------------------------------------#
Return


$ABANDON
#----------------------------------------------------#
# Abandon création ou modification par l'utilisateur #
#----------------------------------------------------#
Local Shortint SAVGOK : SAVGOK=GOK  : # Sauvegarde de GOK
Local Integer  I
#----- Il faut déverrouiller le contrat -----#
SYMBOLE2="POH"+num$([M:POD1]POHNUM)
Unlock = SYMBOLE2
Gosub EFFAC_PWRKORDERS From SUBPODA : # Effacement fichier de travail
#----- Suppression des textes ligne -----#
For I=0 To [M:POD1]NBLIG-1
  If left$([M:POD1]LINTEX(I),3)="POQ" & [M:POD1]CREFLG(I)=0
    Call SUP_CLOB([M:POD1]LINTEX(I),GBIDI1) From TRTX3TEX
  Endif
Next I
Call RAZ_CLOB From ACLOB
#-----
GOK=SAVGOK                          : # Restitution de GOK
Return


$FERME
#------------------------#
# Femeture du traitement #
#------------------------#
Call IMPSCR From ATRTX3
#------------------------------------------------#
# Restitution des variables globales             #
# attention cas particulier des GQSEQ et GPOQSEQ #
#------------------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1="GESPOD"
  Raz GCONSDIA
Endif
GQSEQ   = 0 : GPOQSEQ = 0
GPUU    = ""
GTOTORD = 0 : GTTVORD = 0
Gosub EFFAC_PWRKORDERS From SUBPODA : # Effacement fichier de travail
Gosub FERMETURE_TRACE  From SUBPODA : # Fermeture fichier trace si nécessaire
Return


#######################################################################
#######################################################################
#######################################################################
Subprog RELEC
#------------------------#
# relecture de l'article #
#------------------------#
If [F:ITM]ITMREF<>[F:POC]ITMREF
  Read [ITM] ITM0=[F:POC]ITMREF
  If fstat Raz [F:ITM] : Endif
Endif
#----- Relecture aticle - site de réception (pour QUAFLG) -----#
If [F:ITF]ITMREF<>[F:POC]ITMREF | [F:ITF]STOFCY<>[F:POC]PRHFCY
  Read [ITF] ITF0=[F:POC]ITMREF;[F:POC]PRHFCY : If fstat  Raz [F:ITF] : Endif
Endif
#-----------------------------------------------------------------#
# relecture de l'article - fournisseur                            #
# obligatoire sinon dans les signatures on prend le mauvais enreg #
# et on a besoin de la qte mininum d'achat                        #
#-----------------------------------------------------------------#
If [F:ITP]ITMREF<>[F:POC]ITMREF | [F:ITP]BPSNUM<>[F:POH]BPSNUM
  Read [ITP] ITP0=[F:POC]ITMREF;[F:POH]BPSNUM
  If fstat Raz [F:ITP] : Endif
Endif
End

########################################################################
$LENDAT4
#----------------------------------------------------#
# Longueur chaine = 4 c'est donc demande mensuelle   #
# vérification du mois >= 01 et <= 12                #
# attention format saisie aamm ou mmaa               #
# mis sous format mm-aaaa   (format fixe qqsoit user)#
#----------------------------------------------------#
If val(left$(WDATE,2)) > 0 & val(left$(WDATE,2)) < 13
    [M]CAD(nolign-1) = 3
    If val(right$(WDATE,3)) > 90
         WDATE = left$(WDATE,2)+"-19"+right$(WDATE,3)
    Else
         WDATE = left$(WDATE,2)+"-20"+right$(WDATE,3)
    Endif
Else
    If val(right$(WDATE,3)) > 0 & val(right$(WDATE,3)) < 13
        [M]CAD(nolign-1) = 3
        If val(left$(WDATE,2)) > 90
           WDATE = right$(WDATE,3)+"-19"+left$(WDATE,2)
        Else
           WDATE = right$(WDATE,3)+"-20"+left$(WDATE,2)
        Endif
    Else
        mkstat = 2
    Endif
Endif
Return


$LENDAT5
#----------------------------------------------------#
# Longueur chaine = 5 c'est donc demande hebdomadaire#
# vérification periode >= 01 et <= 53                #
# attention format aappp ou pppaa suivant dossier    #
# semaine sous format ppp-aaaa  (fixe qqsoit user)   #
#----------------------------------------------------#
If val(left$(WDATE,3)) > 0 & val(left$(WDATE,3)) < 54
      [M]CAD (nolign -1) = 2
      If val(right$(WDATE,4)) > 90
         WDATE = left$(WDATE,3)+"-19"+right$(WDATE,4)
      Else
         WDATE = left$(WDATE,3)+"-20"+right$(WDATE,4)
      Endif
Else
      If val(right$(WDATE,3)) > 0 & val(right$(WDATE,3)) < 54
            [M]CAD (nolign -1) = 2
            If val(left$(WDATE,2)) > 90
                WDATE = right$(WDATE,3)+"-19"+left$(WDATE,2)
            Else
                WDATE = right$(WDATE,3)+"-20"+left$(WDATE,2)
            Endif
      Else
            mkstat = 2
      Endif

Endif
If [M]CAD (nolign -1 ) = 2
      #----------------------------------#
      # est ce une année à 53 semaines ? #
      #----------------------------------#
      If left$(WDATE,3) = "053"
                 Gosub S53
      Endif
Endif
Return


$LENDAT6
#----------------------------------------------------#
# Longueur chaine = 6 c'est donc demande journaliere #
# vérification du mois >= 01 et <= 12                #
# vérification du jour >= 01 et <= 31                #
# attention format saisie aammjj jjmmaa ou mmjjaa    #
# mis sous format GFMDAT4                            #
# c'est aussi un mois mmaaaa ou aaaamm   ????        #
#----------------------------------------------------#
Local Shortint WLEN ,WMOIS ,WJOUR ,WANNEE
Local Shortint WRETOUR
WLEN    = 6
WRETOUR = 0

If left$(GFMDAT,2) = "DD" : # GFMDAT = DD/MM/YY
    WJOUR = val(left$(WDATE,2))
    WMOIS = val(mid$(WDATE,3,2))
    WANNEE = val(right$(WDATE,5))
Else
    If left$(GFMDAT,2) = "YY" : #GFMDAT = YY/MM/DD
         WJOUR = val(right$(WDATE,5))
         WMOIS = val(mid$(WDATE,3,2))
         WANNEE = val(left$(WDATE,2))
    Else
       If left$(GFMDAT,2) = "MM" & right$(GFMDAT,len(GFMDAT)-1) = "YY" : # GFMDAT = MM/DD/YY
            WJOUR = val(mid$(WDATE,3,2))
            WMOIS = val(left$(WDATE,2))
            WANNEE = val(right$(WDATE,5))
       Else
            mkstat = 2
            Return
       Endif
    Endif
Endif
If WANNEE > 90
             WANNEE +=1900
Else         WANNEE +=2000
Endif
Case WMOIS
         When 1,3,5,7,8,10,12 : Gosub M31
         When 4,6,9,11        : Gosub M30
         When 2               : Gosub M28
#        When Default         : Gosub ERRD
         When Default         : WRETOUR = 1 : # on regarde si c est mois
Endcase
If WRETOUR = 0
     [M]CAD(nolign-1) = 1
     Return
Endif
#----------------------------------------#
# ici erreur sur zone voir si mois saisi #
#----------------------------------------#
If left$(GFMDAT,2) = "DD" : # GFMDAT = DD/MM/YY mois mmaaaa
    WMOIS = val(left$(WDATE,2))
    WANNEE = val(right$(WDATE,3))
Else
    If left$(GFMDAT,2) = "YY" : #GFMDAT = YY/MM/DD mois aaaamm
         WMOIS = val(right$(WDATE,5))
         WANNEE = val(left$(WDATE,4))
    Else
       If left$(GFMDAT,2) = "MM" & right$(GFMDAT,len(GFMDAT)-1) = "YY" : # GFMDAT = MM/DD/YY mois mmaaaa
            WMOIS = val(left$(WDATE,2))
            WANNEE = val(right$(WDATE,3))
       Else
            mkstat = 2
            Return
       Endif
    Endif
Endif
If WANNEE < 1900
        Gosub ERRD
        Return
Endif
If WMOIS = 0 | WMOIS > 12
              Gosub ERRD
Endif
Local Char WWMOIS(2)
If len(num$(WMOIS)) = 1
       WWMOIS = "0"+num$(WMOIS)
Else   WWMOIS = num$(WMOIS)
Endif
WDATE = WWMOIS+"-"+num$(WANNEE)
[M]CAD(nolign-1) = 3
Return


$LENDAT7
#----------------------------------------------------#
# Longueur chaine = 7 c'est donc demande hebdomadaire#
# vérification periode >= 01 et <= 53                #
# attention format aaaappp ou pppaaaa suivant dossier#
# mois sous format ppp-aaaa                          #
#----------------------------------------------------#
If val(left$(WDATE,3)) > 0 & val(left$(WDATE,3)) < 54
      [M]CAD (nolign -1) = 2
      If val(right$(WDATE,6)) > 90
            WDATE = left$(WDATE,3)+"-19"+right$(WDATE,6)
      Else
            WDATE = left$(WDATE,3)+"-20"+right$(WDATE,6)
      Endif
Else
      If val(right$(WDATE,5)) > 0 & val(right$(WDATE,5)) < 54
            [M]CAD (nolign -1) = 2
            If val(mid$(WDATE,3,2)) > 90
                WDATE = right$(WDATE,5)+"-19"+mid$(WDATE,3,2)
            Else
                WDATE = right$(WDATE,5)+"-20"+mid$(WDATE,3,2)
            Endif
      Else
            mkstat = 2
      Endif

Endif
If [M]CAD (nolign -1 ) = 2
      #----------------------------------#
      # est ce une année à 53 semaines ? #
      #----------------------------------#
      If left$(WDATE,3) = "053"
                 Gosub S53
      Endif
Endif
Return


$LENDAT8
#----------------------------------------------------#
# Longueur chaine = 8 c'est donc demande journaliere #
# vérification du mois >= 01 et <= 12                #
# vérification du jour >= 01 et <= 31                #
# attention format saisie aaaammjj ou jjmmaaaa       #
# mis sous format GFMDAT4                            #
#----------------------------------------------------#
Local Shortint WLEN ,WJOUR ,WMOIS ,WANNEE
WLEN =  8

If left$(GFMDAT,2) = "DD" : # GFMDAT = DD/MM/YY
    WJOUR = val(left$(WDATE,2))
    WMOIS = val(mid$(WDATE,3,2))
    WANNEE = val(right$(WDATE,5))
Elsif left$(GFMDAT,2) = "YY" : # GFMDAT = YY/MM/DD
       WJOUR = val(right$(WDATE,7))
       WMOIS = val(mid$(WDATE,5,2))
       WANNEE = val(left$(WDATE,4))
Elsif left$(GFMDAT,2) = "MM" & right$(GFMDAT,len(GFMDAT)-1) = "YY" : # GFMDAT = MM/DD/YY
            WJOUR = val(mid$(WDATE,3,2))
            WMOIS = val(left$(WDATE,2))
            WANNEE = val(right$(WDATE,5))
Endif
If WANNEE < 1990
         mkstat = 2
         Return
Endif

Case WMOIS
         When 1,3,5,7,8,10,12 : Gosub M31
         When 4,6,9,11        : Gosub M30
         When 2               : Gosub M28
         When Default         : Gosub ERRD
Endcase
[M]CAD(nolign-1) = 1
Return
#######################################################################

$M31
If WJOUR = 0 | WJOUR > 31
   Gosub ERRD
Else
   Gosub DAT8
Endif
Return

$M30
If WJOUR = 0 | WJOUR > 30
   Gosub ERRD
Else
   Gosub DAT8
Endif
Return

$M28
Local Shortint AN4
If WJOUR = 0 | WJOUR > 29
   Gosub ERRD
Else
   If WJOUR = 29
      #----------------------------#
      # voir avec année bissextile #
      #----------------------------#
      If mod(WANNEE,4) <> 0
            Gosub ERRD
      Elsif WANNEE = 2000
            Gosub DAT8
      Else
            Gosub DAT8
        Endif
      Else   Gosub DAT8
      Endif
Endif
Return


$DAT8
Local Char WWJOUR(2) ,WWMOIS(2) ,WWANNEE(4)
If len(num$(WJOUR)) = 1
             WWJOUR= "0"+num$(WJOUR)
Else         WWJOUR = num$(WJOUR)
Endif
If len(num$(WMOIS)) = 1
       WWMOIS = "0"+num$(WMOIS)
Else   WWMOIS = num$(WMOIS)
Endif
WWANNEE = num$(WANNEE)
WDATE=format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWANNEE)))
Return


$S53
Local Shortint I
#---------------------------------------------------#
# L'année comporte t-elle 53 semaines ?             #
# Il y a 53 semaines si le dernier jour de l'année  #
# est un jeudi ou un vendredi                       #
# No jour du 31/12 de l'année concernée             #
#---------------------------------------------------#
I = dayn(gdat$(31,12,val(right$(WDATE,5))))
If I < 4 | I > 5         Gosub ERRD : Endif
If I = 5 & dayn(gdat$(01,01,val(right$(WDATE,5)))) <> 4 Gosub ERRD : Endif
Return

$ERRD
GMESSAGE = mess(68,194,1)
mkstat = 2
Return


#------------------------------------------------#
# Recherche tarif et calcul des montants lignes  #
# uniquement sur lignes fermes                   #
# ---------------------------------------------- #
# TARFLG : Indicateur traitement ligne tarif POP #
#          0 = Rien                              #
#          1 = Modif date fin ligne précédente   #
#          2 = Modif date début ligne suivante   #
#          3 = Modif flag POPCREFLG uniquement   #
#          4 = Création d'une nouvelle ligne     #
# WPOPSEQ  : Séquence ligne POP pour màj         #
# WPOPSEQ1 : Séquence ligne POP précédente       #
# WPOPSEQ2 : Séquence ligne POP suivante         #
#------------------------------------------------#
$CALPOD
If [F:POH]POHNUM<>[F:POQ]POHNUM
  Read [POH]POH0=[F:POQ]POHNUM
  If fstat : Raz [F:POH] : Endif
Endif
If [F:POH]BETFCY=2 & [F:POH]BETCPY=1
 [F:POQ]LINAMT    = 0
 [F:POQ]LINATI    = 0
 [F:POQ]LINATIAMT = 0
 Return
Endif
SAVNOLIGN=nolign
If !clalev([M:POD1]) nolign=1 : Endif
GPUU=[F:POC]PUU
TARFLG=0 : # Ne rien faire
#----- Lecture ligne POP précédente -----#
Filter [PO1] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT<[F:POQ]DEMRCPDAT
Read [PO1] POP1 Last
If !fstat WPOPSEQ1=[F:PO1]POPSEQ Else Raz [F:PO1], WPOPSEQ1 : Endif
#----- Lecture ligne POP suivante -----#
WPOPSEQ2=0
Filter [PO2] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
Read [PO2] POP1 First
If fstat
  #----- Pas de ligne POP suivante -----#
  Raz [F:PO2]
  If [F:POC]PLI<>""
    #----- Un code tarif existe -----#
    If WPOPSEQ1=0
      Gosub INIT_POP  : # Initialisation buffer POP
    Else
      [F:POP]=[F:PO1] : # Récupération buffer ligne POP précédente
      [F:POP]=[F:POQ]
      [F:POP]=[F:POC]
    Endif
    TARFLG=4 : # Création nouvelle ligne POP
    [F:POP]POPSEQ=WPOPSEQ1+1000
    [F:POP]STRDAT=[F:POQ]DEMRCPDAT
    [F:POP]POPDAT=[F:POQ]DEMENDDAT
    Call RECH_TARIF ("POD",nolign-1) From TRTACHTAR1
    If WPOPSEQ1<>0
      If [F:POP]GROPRI=[F:PO1]GROPRI & [F:POP]NETPRI=[F:PO1]NETPRI
        TARFLG=1 : # Si prix identique modif date fin ligne POP précédente
        For K=1 To 9
          If evalue("dim([F:POP]DISCRGVAL"+num$(K)+")")>0
            If evalue("[F:POP]DISCRGVAL"+num$(K))<>evalue("[F:PO1]DISCRGVAL"+num$(K))
              TARFLG=4 : Break : # Création nouvelle ligne POP
            Endif
          Endif
        Next K
        If TARFLG=1 [F:POP]=[F:PO1] : WPOPSEQ=WPOPSEQ1 : Endif
      Endif
    Endif
  Else
    #----- Pas de code tarif -----#
    Raz [F:POP]
  Endif
Else
  #----- Une ligne POP suivante existe -----#
  WPOPSEQ2=[F:PO2]POPSEQ
  If [F:POC]PLI<>""
    #----- Un code traif existe -----#
    If [F:PO2]STRDAT>[F:POQ]DEMRCPDAT
      #----- Ligne POP suivante hors bornes -----#
      [F:POP]=[F:PO2]
      [F:POP]=[F:POQ]
      [F:POP]=[F:POC]
      TARFLG=4 : # Création nouvelle ligne POP
      [F:POP]POPSEQ=WPOPSEQ1+int((WPOPSEQ2-WPOPSEQ1)/2)
      [F:POP]STRDAT=[F:POQ]DEMRCPDAT
      [F:POP]POPDAT=[F:POQ]DEMENDDAT
      Call RECH_TARIF ("POD", nolign-1) From TRTACHTAR1
      If WPOPSEQ1<>0
        If [F:POP]GROPRI=[F:PO1]GROPRI & [F:POP]NETPRI=[F:PO1]NETPRI
          TARFLG=1 : # Si prix identique modif date fin ligne POP précédente
          For K=1 To 9
            If evalue("dim([F:POP]DISCRGVAL"+num$(K)+")")>0
              If evalue("[F:POP]DISCRGVAL"+num$(K))<>evalue("[F:PO1]DISCRGVAL"+num$(K))
                TARFLG=4 : Break : # Création nouvelle ligne POP
              Endif
            Endif
          Next K
          If TARFLG=1 [F:POP]=[F:PO1] : WPOPSEQ=WPOPSEQ1 : Endif
        Endif
      Endif
      If TARFLG=4
        If [F:POP]GROPRI=[F:PO2]GROPRI & [F:POP]NETPRI=[F:PO2]NETPRI
          TARFLG=2 : # Si prix identique modif date début ligne POP suivante
          For K=1 To 9
            If evalue("dim([F:POP]DISCRGVAL"+num$(K)+")")>0
              If evalue("[F:POP]DISCRGVAL"+num$(K))<>evalue("[F:PO2]DISCRGVAL"+num$(K))
                TARFLG=4 : Break : # Création nouvelle ligne POP
              Endif
            Endif
          Next K
          If TARFLG=2 [F:POP]=[F:PO2] : WPOPSEQ=WPOPSEQ2 : Endif
        Endif
      Endif
    Else
      #----- Ligne POP suivante valable -----#
      If [F:PO2]POPCREFLG=2
        #----- Ligne prix créée automatiquement par le tarif -----#
        If [F:PO2]POPDAT=[F:POC]ENDDAT & [F:PO2]STRDAT<>[F:POQ]DEMRCPDAT
          #----- Date fin = date fin de contrat ligne et date début différente -----#
          [F:POP]=[F:PO2]
          [F:POP]=[F:POQ]
          [F:POP]=[F:POC]
          TARFLG=4 : # Création nouvelle ligne POP
          [F:POP]POPSEQ=WPOPSEQ2+1000
          [F:POP]STRDAT=[F:POQ]DEMRCPDAT
          [F:POP]POPDAT=[F:POQ]DEMENDDAT
          Raz [F:POP]GROPRI, [F:POP]NETPRI,[F:POP]PRIREN
          Call RECH_TARIF ("POD", nolign-1) From TRTACHTAR1
          If [F:POP]GROPRI=0 & [F:POP]NETPRI=0 & [F:POP]PRIREN=0 : # Recherche nulle
            TARFLG=0 : [F:POP]=[F:PO2] : WPOPSEQ=WPOPSEQ2 : # Ne rien faire
          Elsif [F:POP]GROPRI=[F:PO2]GROPRI & [F:POP]NETPRI=[F:PO2]NETPRI
            TARFLG=3 : # Si prix identique màj flag POPCREFLG
            For K=1 To 9
              If evalue("dim([F:POP]DISCRGVAL"+num$(K)+")")>0
                If evalue("[F:POP]DISCRGVAL"+num$(K))<>evalue("[F:PO2]DISCRGVAL"+num$(K))
                  TARFLG=4 : Break : # Création nouvelle ligne POP
                Endif
              Endif
            Next K
            If TARFLG=3 [F:POP]=[F:PO2] : WPOPSEQ=WPOPSEQ2 : Endif
          Endif
        Elsif [F:PO2]STRDAT<>[F:POQ]DEMRCPDAT
          #----- Date début différente -----#
          [F:POP]=[F:PO2]
          Read [PO2] POP1 Next
          If !fstat WPOPSEQ=[F:PO2]POPSEQ Else WPOPSEQ=WPOPSEQ2+2000 : Endif
          [F:PO2]=[F:POP]
          [F:POP]=[F:POQ]
          [F:POP]=[F:POC]
          TARFLG=4 : # Création nouvelle ligne POP
          [F:POP]POPSEQ=WPOPSEQ2+int((WPOPSEQ-WPOPSEQ2)/2)
          [F:POP]STRDAT=[F:POQ]DEMRCPDAT
          [F:POP]POPDAT=[F:POQ]DEMENDDAT
          Raz [F:POP]GROPRI, [F:POP]NETPRI,[F:POP]PRIREN
          Call RECH_TARIF ("POD", nolign-1) From TRTACHTAR1
          If [F:POP]GROPRI=0 & [F:POP]NETPRI=0 & [F:POP]PRIREN=0 : # Recherche nulle
            TARFLG=0 : [F:POP]=[F:PO2] : WPOPSEQ=WPOPSEQ2 : # Ne rien faire
          Elsif [F:POP]GROPRI=[F:PO2]GROPRI & [F:POP]NETPRI=[F:PO2]NETPRI
            TARFLG=3 : # Si prix identique màj flag POPCREFLG
            For K=1 To 9
              If evalue("dim([F:POP]DISCRGVAL"+num$(K)+")")>0
                If evalue("[F:POP]DISCRGVAL"+num$(K))<>evalue("[F:PO2]DISCRGVAL"+num$(K))
                  TARFLG=4 : Break : # Création nouvelle ligne POP
                Endif
              Endif
            Next K
            If TARFLG=3 [F:POP]=[F:PO2] : WPOPSEQ=WPOPSEQ2 : Endif
          Endif
        Else
          #---- Même date début, on conserve la ligne tarif déjà créée ----#
          [F:POP]=[F:PO2]
          WPOPSEQ=WPOPSEQ2
          TARFLG=3 : # Màj flag POPCREFLG
        Endif
      Else
        #----- Ligne tarif créée manuellement -----#
        [F:POP]=[F:PO2]
        WPOPSEQ=WPOPSEQ2
        TARFLG=0 : # Ne rien faire
      Endif
    Endif
  Else
    #----- Pas de code tarif -----#
    If [F:PO2]STRDAT>[F:POQ]DEMRCPDAT
      #----- Ligne POP suivante hors bornes -----#
      Raz [F:POP]
    Else
      #----- Ligne POP suivante valide -----#
      TARFLG=0 : # Ne rien faire
      [F:POP]=[F:PO2] : WPOPSEQ=WPOPSEQ2
    Endif
  Endif
Endif
Filter [PO1]
Filter [PO2]
nolign = SAVNOLIGN
#----- Modif date de fin et flag de la ligne POP précédente -----#
If TARFLG=1
  Readlock [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;WPOPSEQ
  If fstat=1
    GLOCK="$PORDERP"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$(WPOPSEQ)
    GOK=-1 : Return
  Elsif fstat
    Call RSTA ("POQ",[F:POQ]POHNUM+num$([F:POQ]POPLIN)+num$(WPOPSEQ)) From GLOCK
    GOK=0  : Return
  Endif
  [F:POP]POPDAT=[F:POQ]DEMENDDAT : [F:POP]POPCREFLG=2
  Rewrite [POP]
  If fstat GOK=0 : Call FSTA ("POP") From GLOCK : Return : Endif
#----- Modif date début et flag de la ligne POP suivante -----#
Elsif TARFLG=2
  Update [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPSEQ=WPOPSEQ
&        With STRDAT=[F:POQ]DEMRCPDAT, POPCREFLG=2
  If fstat GOK=0 : Call FSTA("POP") From GLOCK : Return : Endif
  [F:POP]STRDAT=[F:POQ]DEMRCPDAT : # La classe [F] n'est pas màj par l'Update
  [F:POP]POPCREFLG=2
#----- Modif flag de la ligne POP suivante -----#
Elsif TARFLG=3
  Update [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPSEQ=WPOPSEQ
&        With POPCREFLG=2
  If fstat GOK=0 : Call FSTA("POP") From GLOCK : Return : Endif
  [F:POP]POPCREFLG=2 : # La classe [F] n'est pas màj par l'Update
#----- Création d'une nouvelle ligne POP -----#
Elsif TARFLG=4
  #----- Vérif si date début et fin de la ligne POP suivante doivent être modifiée -----#
  If WPOPSEQ2<>0
    #----- Ajustement de la date fin de la ligne POP suivante si nécessaire -----#
    If [F:PO2]STRDAT<[F:POQ]DEMRCPDAT & [F:PO2]POPDAT>=[F:POQ]DEMRCPDAT
      Readlock [PO2] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;WPOPSEQ2
      If fstat=1
        GLOCK="$PORDERP"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$(WPOPSEQ2)
        GOK=-1 : Return
      Elsif fstat
        Call RSTA ("POQ",[F:POQ]POHNUM+num$([F:POQ]POPLIN)+num$(WPOPSEQ2)) From GLOCK
        GOK=0  : Return
      Endif
      [F:PO2]POPDAT=[F:POQ]DEMRCPDAT-1
      Rewrite [PO2]
      If fstat GOK=0 : Call FSTA ("POP") From GLOCK : Return : Endif
    Endif
    #----- Ajustement de la date début de la ligne POP suivante si nécessaire -----#
    If [F:PO2]STRDAT<=[F:POQ]DEMENDDAT & [F:PO2]POPDAT>[F:POQ]DEMENDDAT
      Update [PO2] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPSEQ=WPOPSEQ2
&             With STRDAT=[F:POQ]DEMENDDAT+1
      If fstat GOK=0 : Call FSTA("POP") From GLOCK : Return : Endif
      [F:PO2]STRDAT=[F:POQ]DEMENDDAT+1 : # La classe [F] n'est pas màj par l'Update
    Endif
  Endif
  #----- Création nouvelle ligne POP -----#
  [F:POP]POPCREFLG=2
  Write [POP]
  If fstat GOK=0 : Call FSTA ("POP") From GLOCK : Return : Endif
  #----- Ecriture des comptes et sections de la ligne de commande -----#
  If clalev([M:POD1])
    #----- Depuis la gestion des DL -----#
    Call ENREG_ACCCCE(nolign-1,"[M:POD1]LINACC(","","POC","POP",
&                     0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"","C") From TRTX3CPT
  Else
    #----- Depuis la gestion des plans d'approvisionnement -----#
    Call ENREG_ACCCCE(nolign-1,"[F:POC]LINACC(" ,"","POD","POP",
&                     0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"","C") From TRTX3CPT
  Endif
  If GOK<1  Return : Endif
Endif
#----------------------------------#
# Récuperation des infos de POP et #
# calcul des montants sur la ligne #
#----------------------------------#

# Issue 96912 - 2014-02-17 by MUARN : Gestion des tarifs en DL
#[F:POQ]LINAMT=[F:POP]NETPRI*[F:POQ]QTYPUU
# Issue 113603 - 2016-02-05 by SR : On vient ici de différentes manières et
# I peut déjà être utilsé : définir une variable propre à ce code = WICALPOD
Local  Decimal  DISCRGVAL(0..8), NETPRI, WICALPOD
For WICALPOD=1 To 9
    If evalue("DIM([F:POP]DISCRGVAL"+num$(WICALPOD)+")")>0
       DISCRGVAL(WICALPOD-1)=evalue("[F:POP]DISCRGVAL"+num$(WICALPOD))
    Endif
Next WICALPOD
Call CALNET(2,[F:BPS]PLISTC,[F:POP]GROPRI,DISCRGVAL,[F:POQ]QTYUOM,NETPRI,[F:POH]CUR) From TRTPRICE
[F:POQ]LINAMT=NETPRI*[F:POQ]QTYPUU

Call ARRDEV ([F:POQ]LINAMT,[F:POH]CUR) From TRTDIV
VAT(0) = [F:POP]VAT(0) : WCLCAMT(1)=[F:POQ]CLCAMT1
VAT(1) = [F:POP]VAT(1) : WCLCAMT(2)=[F:POQ]CLCAMT2
VAT(2) = [F:POP]VAT(2) : WCLCAMT(3)=[F:POQ]CLCAMT3
Call CLCTAXEMNT2([F:POQ]LINAMT,VAT,1,GSOCIETE,[F:POQ]ORDDAT,WCLCAMT,[F:POQ]LINATIAMT) From TRTX3
Call ARRDEV ([F:POQ]LINATIAMT,[F:POH]CUR) From TRTDIV
[F:POQ]LINATI=[F:POQ]LINATIAMT
Return


#------------------------------#
# Initialisation du buffer POP #
#------------------------------#
$INIT_POP
[F:POP]       = [F:POQ]
[F:POP]       = [F:POC]
# Issue 71069 - 2016-03-25 by MUARN : PJT
#[F:POP]PJT    = ""
[F:POP]ORICRY = [F:BPR]CRY
[F:POP]LINBUY = [F:POH]BUY
[F:POP]CREDAT = date$
[F:POP]CREUSR = GUSER
#----- Initialisation codes taxe -----#
Call ALIVATCOD(2,[F:BPS]BPSNUM,[F:ITM]ITMREF,"POP",0) From TRTX3
# Issue 84130 - 2013-02-26 by MUARN : landed-cost ne pas faire on pert les données de ALIVATCOD,et VAT(X) non alimentées
#[F:POP]VAT(0) = VAT(0)
#[F:POP]VAT(1) = VAT(1)
#[F:POP]VAT(2) = VAT(2)

#-----
If [F:ITP]ITMREF=""
  If GACTDEB=2  [F:POP]EECINCRAT = [F:BPS]EECINCRAT : Endif
  [F:POP]QUAFLG = [F:ITF]QUAFLG
Else
  If GACTDEB=2  [F:POP]EECINCRAT = [F:ITP]EECINCRAT : Endif
  [F:POP]QUAFLG = [F:ITF]QUAFLG
Endif
If [F:POP]QUAFLG>1 [F:POP]QUAFLG=2 : Endif
#----- Initialisation codes statistiques article -----#
For K=0 To dim([F:POP]TSICOD)-1
  [F:POP]TSICOD(K) = [F:ITM]TSICOD(K)
Next K
#----- Relecture si nécessaire de l'ITMMASTER et ITMBPS -----#
If [F:ITM]ITMREF<>[F:POC]ITMREF
  Read [ITM] ITM0=[F:POC]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF<>[F:POC]ITMREF | [F:ITP]BPSNUM<>[F:POH]BPSNUM
  Read [ITP] ITP0=[F:POC]ITMREF;[F:POH]BPSNUM
  If fstat Raz [F:ITP] : [F:ITP]PUU=[F:ITM]PUU : Endif
Endif
#----- Relecture si nécessaire de l'ITMFACILITY si plan d'approvisionnement -----#
If !clalev([M:POD1])
  If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[F:POQ]PRHFCY
    Read [ITF] ITF0=[F:POQ]ITMREF;[F:POQ]PRHFCY
    If fstat Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS : Endif
  Endif
Endif
#----- Relecture si nécessaire du BPARTNER et du BPSUPPLIER -----#
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  Read [BPR] BPR0=[F:POH]BPSNUM
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM
  If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
Return


$EFFAC_PWRKORDERS
#--------------------------------------------------------#
# Effacement fichier de travail "Besoins pris en compte" #
#--------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=adxuid(1) & CODFNC="POD"
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKORDERS"-num$(adxuid(1)-"POD")
              Goto ROLL_PWO
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWO",num$(adxuid(1))-"POD") From GLOCK
              Goto AB_PWO
  Endif
Commit
Return
$AB_PWO
Rollback : Return
$ROLL_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_PWO : Endif : Return


$EFFAC_LIG_PWRKORDERS
#--------------------------------------------------------------------#
# Effacement fichier de travail "Besoins pris en compte" d'une ligne #
#--------------------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_LIG_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=adxuid(1)
&                  & CODFNC="POD"
&                  & LINNUM=[M:POD1]POHLIN(nolign-1)
  If fstat=1
    GLOCK="$PWRKORDERS"-num$(adxuid(1))-"POD"-num$([M:POD1]POHLIN(nolign-1))
    GOK=-1 : Goto ROLL_LIG_PWO
  Elsif fstat
    Call RSTA("PWO",num$(adxuid(1))-"POD"-num$([M:POD1]POHLIN(nolign-1))) From GLOCK
    GOK=0  : Goto AB_LIG_PWO
  Endif
Commit
Return
$AB_LIG_PWO
Rollback : Return
$ROLL_LIG_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_LIG_PWO : Endif : Return


$OUVERTURE_TRACE
#---------------------------------------#
# Ouverture fichier trace si nécessaire #
#---------------------------------------#
If GPURTRACE=0 & GPURCMM=2 & GMODU(2)=2 & !GIMPORT
  Call OUVRE_TRACE(mess(173,197,1)) From LECFIC : GPURTRACE=1
Endif
Return

$LECTURE_TRACE
#-----------------------------------------------------------#
# Lecture du fichier trace des alertes budget si nécessaire #
#-----------------------------------------------------------#
If GPURTRACE=2 & !GIMPORT
  Call FERME_TRACE  From LECFIC
  Call LEC_TRACE    From LECFIC
  GPURTRACE=0
Endif
Return

$FERMETURE_TRACE
#---------------------------------------#
# Fermeture fichier trace si nécessaire #
#---------------------------------------#
If GPURTRACE<>0 & !GIMPORT & GWEBSERV<>1
  Call FERME_TRACE From LECFIC : GPURTRACE=0
Endif
Return

#---------------------------------#
# Chargement du texte de la ligne #
#---------------------------------#
$CHARG_TEXT_LIGNE
If [M:POD1]LINTEX(nolign-1)<>""
  If left$([M:POD1]LINTEX(nolign-1),3)="POQ"
    Call CRE_CLOB([M:POD1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif !find(left$([M:POD1]LINTEX(nolign-1),3),"ITM","ITP")
    Call DUP_CLOB("POQ",[M:POD1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:POQ]LINTEX=[M:POD1]LINTEX(nolign-1)
Endif
Return

