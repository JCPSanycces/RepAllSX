#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR7 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone BUICODASS
mkstat = 0
zoncou = "BUICODASS"
indice = 0
IMPENT = [M]BUICODASS
If varinit([M]BUICODASS,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUICODASS,indice)=0
 [M]BUICODASS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUICODASS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUICODASS(indice)
 Endif
Endif
[M]BUICODASS = IMPENT

## Zone BUISTAPAY
mkstat = 0
zoncou = "BUISTAPAY"
indice = 0
IMPENT = [M]BUISTAPAY
If varinit([M]BUISTAPAY,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUISTAPAY,indice)=0
 [M]BUISTAPAY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUISTAPAY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUISTAPAY(indice)
 Endif
Endif
[M]BUISTAPAY = IMPENT

## Zone BUIRATEXS
mkstat = 0
zoncou = "BUIRATEXS"
indice = 0
If varmode([M]BUIRATEXS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUIRATEXS" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BUIRETPRV
mkstat = 0
zoncou = "BUIRETPRV"
indice = 0
IMPENT = [M]BUIRETPRV
If varinit([M]BUIRETPRV,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUIRETPRV,indice)=0
 [M]BUIRETPRV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUIRETPRV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUIRETPRV(indice)
 Endif
Endif
[M]BUIRETPRV = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone BUICODTIM
mkstat = 0
zoncou = "BUICODTIM"
indice = 0
IMPENT = [M]BUICODTIM
If varinit([M]BUICODTIM,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUICODTIM,indice)=0
 [M]BUICODTIM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUICODTIM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUICODTIM(indice)
 Endif
Endif
[M]BUICODTIM = IMPENT

## Zone BUIDAYTYP
mkstat = 0
zoncou = "BUIDAYTYP"
indice = 0
IMPENT = [M]BUIDAYTYP
If varinit([M]BUIDAYTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUIDAYTYP,indice)=0
 Call INICOMBO(10404) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_BUIDAYTYP(IMPENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10404,1))))
 Endif
 [M]BUIDAYTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUIDAYTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUIDAYTYP(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "BUIDAYTYP" : GZNUM = 46020 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]BUIDAYTYP = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone BUICODSAL
mkstat = 0
zoncou = "BUICODSAL"
indice = 0
IMPENT = [M]BUICODSAL
If varinit([M]BUICODSAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUICODSAL,indice)=0
 [M]BUICODSAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUICODSAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUICODSAL(indice)
 Endif
Endif
[M]BUICODSAL = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone BUICODHRS
mkstat = 0
zoncou = "BUICODHRS"
indice = 0
IMPENT = [M]BUICODHRS
If varinit([M]BUICODHRS,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUICODHRS,indice)=0
 [M]BUICODHRS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUICODHRS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUICODHRS(indice)
 Endif
Endif
[M]BUICODHRS = IMPENT

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone BUICODJOB
mkstat = 0
zoncou = "BUICODJOB"
indice = 0
If varinit([M]BUICODJOB,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]BUICODJOB,"10403","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]BUICODJOB,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "BUICODJOB" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]BUICODJOB,"10403","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BUICODJOB" : GZNUM = 46541 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]BUICODJOB,"10403",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "BUICODJOB" : GZNUM = 46541 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone BUICODQLY
mkstat = 0
zoncou = "BUICODQLY"
indice = 0
If varinit([M]BUICODQLY,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]BUICODQLY,"10404","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]BUICODQLY,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "BUICODQLY" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]BUICODQLY,"10404","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BUICODQLY" : GZNUM = 14448 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]BUICODQLY,"10404",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "BUICODQLY" : GZNUM = 14448 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone BUICAT
mkstat = 0
zoncou = "BUICAT"
indice = 0
IMPENT = [M]BUICAT
If varinit([M]BUICAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUICAT,indice)=0
 Call INICOMBO(10380) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_BUICAT(IMPENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10380,1))))
 Endif
 [M]BUICAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUICAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUICAT(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "BUICAT" : GZNUM = 707 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]BUICAT = IMPENT

## Zone BUILEV
mkstat = 0
zoncou = "BUILEV"
indice = 0
IMPENT = [M]BUILEV
If varinit([M]BUILEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]BUILEV,indice)=0
 Call INICOMBO(10380) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_BUILEV(IMPENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10380,1))))
 Endif
 [M]BUILEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUILEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BUILEV(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "BUILEV" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]BUILEV = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR7"
Return

