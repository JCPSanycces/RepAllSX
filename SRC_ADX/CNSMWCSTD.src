#<AdxTL>@(#)7.0.0.0 $Revision$ Consultation MWC
############################################################################
#                        Consultation                                       #
#                        Situation de pesée composants                                 #
#                                                                GPAO       #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site        /SITE                                                    #
# 2  = article     /ART                                                     #
# 3  = phase       /PHASE                                                  #
# 4  = pièce       /VCRNUM                                                  #
# 5  = pesee       /PESEE
# 6  = tri         /TRI                                                     #
#                      1 - date                                             #
#                      2 - OF                                               #
#                      3 - article                                          #
#############################################################################
Local Char PARAM(20)(1..10)
PARAM(1) = "GAL"
PARAM(2) = ""
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = "1"
PARAM(7) = "" # CATUA X3-68727.n
Call GCONSULT("SHO","",PARAM) From GCONSULT
End



$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When Default
Endcase
Return
############################################################
$AUTORIS
Return

############################################################
$OUVRE
Local Integer WSRT,WRET
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    FORMULE1(250)


If clalev ([F:ITM])  <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:FCY])  <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:MFM])  <= 0 : Local File MFGMAT     [MFM] : Endif
If clalev ([F:TFO])  <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:TUN])  <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:MFO])  <= 0 : Local File MFGOPE     [MFO]  : Endif

Gosub DEFCRIT
If !find([M:CMWC]TRI,1,2,3,4) : [M:CMWC]TRI = 1 : Endif

# Mail TS du 18/03/08
NAVIG="CONSMWC"
Return

#############################################################################
$FERME
Return

############################################################################
$FIN_CRIT
Return

#############################################################################
# analyse paramètres
$DEFCRIT

Local Char    WCTN(8)

For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     If !fstat & [F:FCY]MFGFLG = 2 : [M:MWC1]MFGFCY = PARAM(I) : Endif
                 Endif
        When 2 : # article
                 If PARAM(I) <> ""
                     Read [ITM]ITM0 = PARAM(I)
                     If !fstat
                         [M:MWC1]ITMREFSTR = PARAM(I)
                         [M:MWC1]ITMREFEND = PARAM(I)
                     Endif
                 Endif
        When 3 : # Phase
                 If PARAM(I) <> ""
                     WOPE = val(PARAM(I))

                     [M:MWC1]BOMOPESTR = WOPE
                     [M:MWC1]BOMOPEEND = WOPE
                 Endif

        When 4 : # Piece
                 If PARAM(I) <> ""
                     [M:MWC1]MFGNUMSTR = PARAM(I)
                 Endif

        When 5 : # Situation de pesee
                 If PARAM(I) <> ""
                     WSTA = val(PARAM(I))

                     [M:CMWC]WGGSTASTR = WSTA
                     [M:CMWC]WGGSTAEND = WSTA
                 Endif

        When 6 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 4  : WSRT = 1 : Endif
                     [M:CMWC]TRI = WSRT
                 Endif

        # CATUA X3-68727.sn Add the ability to filter by container
        When 7 : # Container
                 If PARAM(I) <> "" & dim([M:MWC1]CTNSTR)>0
                     WCTN = PARAM(I)
                     [M:MWC1]CTNSTR = WCTN
                     [M:MWC1]CTNEND = WCTN
                 Endif
        # CATUA X3-68727.en
        When Default: Break
    Endcase
Next I
# copie de l'écran critères (CMWC) vers le masque 0 (MWC1)
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE
# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:MWC1]MFGFCY = ""  : NBLU = 0 : Return : Endif
If PARAM(6) = "" : PARAM(6) = "1" : Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
# sr 10.04 demande 26046
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

# application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CMWC]TRI
      When 1 : # tri par OF
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key MFM0
      When 2 : # tri par phase
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE = [F:MFM]BOMOPE
      When 3 : # tri par composant
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFM]ITMREF
      When 4 : # tri par situation de pesee
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFM]WGGSTA

    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CMWC]TRI
      When 1 : # tri par OF
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key MFM0 Desc
      When 2 : # tri par phase
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE = [F:MFM]BOMOPE Desc
      When 3 : # tri par composant
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFM]ITMREF Desc
      When 4 : # tri par situation de pesee
             Filter [MFM] Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                         evalue(FORMULE1)
&                         Order By Key CLE=[F:MFM]WGGSTA Desc

    Endcase
Endif

# raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 : Raz [M:MWC2] : Endif

# lecture
$BOUCLE

For [MFM]
      If NBLU = 1
         If CHGPAG = 2 | CHGPAG = -2 : Raz [M:MWC2] : Endif
      NBLU = 2
      Endif

      If CHGPAG > 0
         If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
      NOL    += 1
      If NOL=0
         DEBNUM = [F:MFM]MFGNUM
         DEBPHA = [F:MFM]BOMOPE
         DEBITM = [F:MFM]ITMREF
         DEBSTA = [F:MFM]WGGSTA
      Endif
      FINNUM = [F:MFM]MFGNUM
      FINPHA = [F:MFM]BOMOPE
      FINITM = [F:MFM]ITMREF
      FINSTA = [F:MFM]WGGSTA

   Else
      If NOL <= 0 : RETOUR = 2 : Break : Endif
      NOL    -= 1
      If NOL = MAXLIG-1
         FINNUM = [F:MFM]MFGNUM
         FINPHA = [F:MFM]BOMOPE
         FINITM = [F:MFM]ITMREF
         FINSTA = [F:MFM]WGGSTA
     Endif
     DEBNUM = [F:MFM]MFGNUM
     DEBPHA = [F:MFM]BOMOPE
     DEBITM = [F:MFM]ITMREF
     DEBSTA = [F:MFM]WGGSTA

  Endif
  nolign = NOL+1

  Gosub FILLTAB
$SUIV
Next
Filter [F:MFM]

# Issue 85521 - 2012-11-15 by MM
[M:MWC2]NBLIG = nolign
Gosub HIGHLIGHT

Return

#############################################################################
# Chargements spéciaux
$FILLTAB
[M:MWC2] = [F:MFM]

# CATUA X3-68727.sn
# Populate both CTN (activity coded) and CTN2 (not activity coded) with the same value
# Use CTN2 (not activity coded) for screen parameter requirements, cannot use CTN (activity coded) when activity code MWC is turned off
Local Char   WCTN2(8)

Raz WCTN2

If dim([F:MFM]CTN)>0
  WCTN2 = [F:MFM]CTN
Endif

[M:MWC2]CTN2(nolign-1) = WCTN2
# CATUA X3-68727.sn

# Lecture ITMMASTER
Read [ITM]ITM0 = [F:MFM]ITMREF
If fstat : Raz [F:ITM] : Endif
# Lecture ITMFACILIT
Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
If fstat Raz[F:ITF] : Endif
[M:MWC2]NEGSTO   (nolign-1) = [F:ITM]NEGSTO
[M:MWC2]MFGSHTCOD(nolign-1) = [F:ITF]MFGSHTCOD
[M:MWC2]ISM      (nolign-1) = [F:ITF]ISM

# Lecture ITMMASTER
# 03.09 mm - libellé traduisible
#Call LECTEXTRA ([M:MWC2]ITMDES1(nolign-1),"ITMMASTER","DES1AXX",[M:MWC2]ITMREF(nolign-1),"") From ATEXTRA
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MWC2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
Return



#############################################################################
# Issue 85521 - 2012-11-15 by MM : coloriser les OFs à réactiver
$HIGHLIGHT
Local Integer I
Affzo [M:MWC2]

 # réinitialisation style
Chgstl [M:MWC2] With ""

For I =0 To [M:MWC2]NBLIG-1
  # application style
  # matière en cours de pesée box ou
  # situation de pesée = matière en cours et statut matière = en attente
  If [M:MWC2]WGGBOX(I) = 2 | ([M:MWC2]WGGSTA(I) = 2 & [M:MWC2]MATSTA(I) = 1)
      Chgstl [M:MWC2]NBLIG(I) With "MTOLINKC"
  Endif
Next I

Return

#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

CRITERE1 = "[F:MFM]PKC>1 & [F:MFM]MATSTA < 4"         # filtre code à servir

# site
If [M:MWC1]MFGFCY <> ""
   CRITERE = "[F:MFM]MFGFCY=[M:MWC1]MFGFCY"
   Gosub LOAD_CRITERE2
Endif
# composant
If [M:CMWC]ITMREFSTR <> ""
   CRITERE = "[F:MFM]ITMREF>=[M:CMWC]ITMREFSTR"       # borne debut composant
   Gosub LOAD_CRITERE2
Endif
If [M:CMWC]ITMREFEND <> ""
   CRITERE = "[F:MFM]ITMREF<=[M:CMWC]ITMREFEND"       # borne fin composant
   Gosub LOAD_CRITERE2
Endif
# phase
If [M:CMWC]BOMOPESTR <> 0
   CRITERE = "[F:MFM]BOMOPE>=[M:CMWC]BOMOPESTR"       # borne debut phase
   Gosub LOAD_CRITERE2
Endif
If [M:CMWC]BOMOPEEND <> 0
   CRITERE = "[F:MFM]BOMOPE<=[M:CMWC]BOMOPEEND"       # borne fin phase
   Gosub LOAD_CRITERE2
Endif

# CATUA X3-68727.sn Add the ability to filter by container
# container
If dim([M:CMWC]CTNSTR)>0
  If [M:CMWC]CTNSTR <> ""
    CRITERE = "[F:MFM]CTN>=[M:CMWC]CTNSTR"             # container start
    Gosub LOAD_CRITERE2
  Endif
  If [M:CMWC]CTNEND <> ""
    CRITERE = "[F:MFM]CTN<=[M:CMWC]CTNEND"             # container end
    Gosub LOAD_CRITERE2
  Endif
Endif
# CATUA X3-68727.en
# ordre

If [M:CMWC]MFGNUMSTR <> ""
   CRITERE = "[F:MFM]MFGNUM=[M:CMWC]MFGNUMSTR"       # borne début ordre
   Gosub LOAD_CRITERE2
Endif
# situation de pesée
If [M:CMWC]WGGSTASTR <> 0
   CRITERE = "[F:MFM]WGGSTA>=[M:CMWC]WGGSTASTR"       # borne debut situation pesee
   Gosub LOAD_CRITERE2
Endif
If [M:CMWC]WGGSTAEND <> 0
   CRITERE = "[F:MFM]WGGSTA<=[M:CMWC]WGGSTAEND"       # borne fin situation pesee
   Gosub LOAD_CRITERE2
Endif


Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CMWC]TRI
       When 1 : # tri par of
           CRITERE = "[F:MFM]MFGNUM>=DEBNUM"
           Gosub LOAD_CRITERE3
       When 2 : # tri par phase
           CRITERE = "[F:MFM]BOMOPE>=DEBPHA"
           Gosub LOAD_CRITERE3
       When 3 : # tri par composant
           CRITERE = "[F:MFM]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
       When 4 : # tri par situation pesee
           CRITERE = "[F:MFM]WGGSTA>=DEBSTA"
           Gosub LOAD_CRITERE3

     Endcase
   When 2 : # suite
     Case [M:CMWC]TRI
       When 1 : # tri par of
           CRITERE = "[F:MFM]MFGNUM>=FINNUM"
           Gosub LOAD_CRITERE3
       When 2 : # tri par phase
           CRITERE = "[F:MFM]BOMOPE>=FINPHA"
           Gosub LOAD_CRITERE3
       When 3 : # tri par composant
           CRITERE = "[F:MFM]ITMREF>=FINITM"
           Gosub LOAD_CRITERE3
       When 4 : # tri par situation pesee
           CRITERE = "[F:MFM]WGGSTA>=FINSTA"
           Gosub LOAD_CRITERE3


     Endcase
   When -2 : # retour
     Case [M:CMWC]TRI
       When 1 : # tri par of
           CRITERE = "[F:MFM]MFGNUM>=DEBNUM"
           Gosub LOAD_CRITERE3
       When 2 : # tri par phase
           CRITERE = "[F:MFM]BOMOPE>=DEBPHA"
           Gosub LOAD_CRITERE3
       When 3 : # tri par composant
           CRITERE = "[F:MFM]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
       When 4 : # tri par situation pesee
           CRITERE = "[F:MFM]WGGSTA>=DEBSTA"
           Gosub LOAD_CRITERE3

     Endcase
Endcase
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif
If CRITERE3 = "" : CRITERE3 = "1=1" : Endif

# analyse présence formule de sélection
If [M:CMWC]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=12;[M:CMWC]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif

Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
$SETBOUT
Return

#############################################################################
$EXEBOUT
Return



############################################################
# Etiquettes
############################################################

########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M:MWC1]ITMREFEND = ""     : [M:MWC1]ITMREFEND = VALEUR : Affzo [M:MWC1]ITMREFEND : Endif
If [M:MWC1]ITMREFEND < VALEUR : [M:MWC1]ITMREFEND = VALEUR : Affzo [M:MWC1]ITMREFEND : Endif

End

########################################
Subprog AS_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
# Article site

GBOUT1 = mess(4,198,1)
End

########################################
Subprog C_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog S_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY : WFCY = [M:MWC1]MFGFCY
Local    Char    WART : WART = VALEUR
Local    Char    WUSR : WUSR = ""

If VALEUR = "" : End : Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
Endif

If WFCY <> ""
    Call CTLPLNFLT(WFCY, WART, WUSR) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
    Endif
Endif
End

########################################
Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
# Article site

GBOUT1 = mess(4,198,1)

End

########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()

End

########################################
Subprog S_ITMREFEND(VALEUR)
Variable Char    VALEUR()
End

# CATUA X3-68727.sn Add the ability to filter by container
########################################
Subprog AM_CTNSTR(VALEUR)
Variable Char    VALEUR()

  If [M]CTNEND = ""     : [M]CTNEND = VALEUR : Affzo [M]CTNEND : Endif
  If [M]CTNEND < VALEUR : [M]CTNEND = VALEUR : Affzo [M]CTNEND : Endif
End
# CATUA X3-68727.en


########################################
Subprog AM_MFGNUMSTR(VALEUR)
Variable Char    VALEUR()

End

# FQ 57754 Module GPAO GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"MWC") From SUBGTC

End

