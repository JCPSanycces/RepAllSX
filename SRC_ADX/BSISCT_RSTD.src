######################################################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When "BSISCT"
            Case [L]AEVENT
                When "AREAD_AFTER" : Gosub AREAD_AFTER
            Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
        When "BSISCT.FILTYP"
            Case [L]ARULE
              When "PROPAGATE" : Gosub PROPAGATE_FILTYP
            Endcase
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


############################################################################################
# Implementation
############################################################################################

#set field depending on filetype
$PROPAGATE_FILTYP
  Gosub HIDE_DISPLAY_ELTMAP
Return


$HIDE_DISPLAY_ELTMAP
  If this.FILTYP = 3
    ASTATUS = fmet this.ASETATTRIBUTE ("CODELT","$isHidden","false")  # for file type CAMT: element mapping link is visible
    ASTATUS = fmet this.ASETATTRIBUTE ("LEV","$isHidden","false")     # for file type CAMT: level is visible
  Else
    ASTATUS = fmet this.ASETATTRIBUTE ("CODELT","$isHidden","true")   # for all other file types hidden
    ASTATUS = fmet this.ASETATTRIBUTE ("LEV","$isHidden","true")      # for all other file types hidden
  Endif
Return


$AREAD_AFTER
  Gosub HIDE_DISPLAY_ELTMAP
Return

