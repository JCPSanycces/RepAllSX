#<AdxTL>@(#)249.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
GBIDC1 = "TESTEUR2"
GBIDI1 = 1
Call CNVFAS(GBIDC1,GBIDI1,datesyst,"FRF","EUR",1)
End

Subprog CNVFAS(COD,NUM,DATPAS,DEVCUR,DEVDES,TYPCOURS)
Value Char    COD
Value Integer NUM
Value Date    DATPAS
Value Char    DEVCUR
Value Char    DEVDES
Value Integer TYPCOURS         : # Type de cours


Local Integer  I, J, SPSTAT, ERR
Local Shortint NBMAX : NBMAX = 300
Local Date     DATDEB, DATFIN
Local Decimal  WAMTWRO(NBMAX), WAMTEXC(NBMAX), WAMTWROACC(NBMAX), WAMTEXCACC(NBMAX)
&           ,  WAMTSTR(NBMAX), WAMTREV(NBMAX)
Local Decimal  TOT_AMTNOT, TOT_AMTATI


Raz ERR
Onerrgo ERR
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE  [TCH]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:FAS])=0  : Local File FIXASSET   [FAS]  : Endif
If clalev([F:FIL])=0  : Local File FIXINVLIG  [FIL]  : Endif
If clalev([F:FDP])=0  : Local File FIXDEP     [FDP]  : Endif
If clalev([F:FWR])=0  : Local File FIXWRO     [FWR]  : Endif
If clalev([F:FWR2])=0 : Local File FIXWRO     [FWR2] : Endif
Onerrgo
If ERR : End : Endif

Call DEBTRANS From GLOCK
Gosub TR5 : # Conversion montant de la fiche immo et tableaux d'amortissements
If GOK<1 : End : Endif
Read [FAS]FAS0 = COD ; NUM
If fstat
 End
Else
 Call ECR_TRACE(COD-num$(NUM),0) From GESECRAN
Endif
End

$TR5
GOK = 1
Trbegin [FAS], [FDP], [FIL], [FWR]
 Readlock [FAS]FAS0 = COD ; NUM
 If fstat=1
  GOK=-1 : GLOCK="$FIXASSET"-COD-num$(NUM) : Goto ROLL_TR5
 Elsif fstat
  GOK=0 : Call RSTA("FAS",COD-num$(NUM)) From GLOCK : Goto AB_TR5
 Endif
 
 Raz TOT_AMTNOT, TOT_AMTATI
 For [FIL]FIL0 Where FASCOD=COD & FASNUM=NUM
  Call CONVERT(DEVCUR,DEVDES,DEVDES,[F:FIL]CURTYP,DATPAS,[F:FIL]AMTNOTCPY,[F:FIL]AMTNOTCPY,SPSTAT) From TRTDEV
  Call CONVERT(DEVCUR,DEVDES,DEVDES,[F:FIL]CURTYP,DATPAS,[F:FIL]AMTATICPY,[F:FIL]AMTATICPY,SPSTAT) From TRTDEV
  Call CONVERT(DEVCUR,DEVDES,DEVDES,[F:FIL]CURTYP,DATPAS,[F:FIL]VALLIN,[F:FIL]VALLIN,SPSTAT) From TRTDEV
  TOT_AMTNOT += [F:FIL]AMTNOTCPY
  TOT_AMTATI += [F:FIL]AMTATICPY
  Rewrite [FIL]
  If fstat=1
   GOK=-1 : GLOCK = "$FIXINVLIG" : Break
  Elsif fstat
   GOK=0 : Call FSTA("FIL") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR5
 Elsif !GOK : Goto AB_TR5
 Endif
 
 [F:FAS]TOTAMTNOT = TOT_AMTNOT
 [F:FAS]TOTAMTATI = TOT_AMTATI
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]SALPRI,   [F:FAS]SALPRI,   SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTVATRMN,[F:FAS]AMTVATRMN,SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTORI,   [F:FAS]AMTORI,   SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTDEP,   [F:FAS]AMTDEP,   SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]BASTAX,   [F:FAS]BASTAX,   SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTRVA(0),[F:FAS]AMTRVA(0),SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTRVA(1),[F:FAS]AMTRVA(1),SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTRVA(2),[F:FAS]AMTRVA(2),SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTRVA(3),[F:FAS]AMTRVA(3),SPSTAT) From TRTDEV
 Call CONVERT(DEVCUR,DEVDES,DEVDES,TYPCOURS,DATPAS,[F:FAS]AMTRVA(4),[F:FAS]AMTRVA(4),SPSTAT) From TRTDEV
 Rewrite [FAS]
 If fstat
  GOK=0 : Call FSTA("FAS") From GLOCK : Goto AB_TR5
 Endif

 Call FIXUPD(COD,NUM,2,DATPAS,DEVCUR,DEVDES,TYPCOURS) From FIXUPD
 If   GOK<0 : Goto ROLL_TR5
 Elsif !GOK : Goto AB_TR5
 Endif
Commit
Return

$AB_TR5
Rollback
Return

$ROLL_TR5
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR5 : Endif

$ERR
ERR = errn
Resume
