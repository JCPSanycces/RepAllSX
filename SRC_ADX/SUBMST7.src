##########################################################################################################
Subprog C_SCTNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR = ""
    GMESSAGE = mess(83, 123, 1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
    End
Endif

End

##########################################################################################################
Subprog AM_SCTNUM(VALEUR)
Variable Char    VALEUR()

[M:MST7]SCTNUM = VALEUR
#GSZMST7SCT = VALEUR
#Raz [M:MST7]
Gosub DISPMST7 From TRTMST7

End





