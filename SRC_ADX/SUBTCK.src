#<AdxTL>@(#)153.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("COA",GBIDC1,GBIDC2) From GOBJET 
End 
 
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "LIENS"       : Gosub LIENS 
 When "SETBOUT"     : Gosub SETBOUT
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When Default
Endcase
Return

$OUVRE
If clalev([GAC])=0 : Local File GACCOUNT [GAC] : Endif
Return

$OUVRE_BOITE
Actzo SAC
If GTABCPT<>""
 If clalev([F:BPR])=0 : Local File =GTABCPT+"BPARTNER" [BPR] : Endif
Elsif filinfo(filpath("FIL","BPARTNER","fde",0),0)>=0
 If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
Else
 Grizo SAC
Endif
Return

$LIENS 
[M]COMBI(nolign-1) = [M]FCY1(nolign-1)+[M]FCY2(nolign-1)
If [M]SAC<>""
 Read [GAC]GAC1 = [M:COA0]COA;[M]SAC
 If !fstat
  Call LECTEXTRA([M]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Endif
Endif
Return

$SETBOUT 
Call VIREBOUT(CHAINE,"AH") From GOBJET 
Return 

$VERIF
For nolign=1 To [M]NBLIG
 If [M]SAC<>""
  Read [GAC]GAC1 = [M:COA0]COA;[M]SAC
  If [M]BPR(nolign-1)=""
   # Tiers incorrect
   GMESSAGE = mess(50,102,1)
   OK = 0 : Break
  Else
   Call LECTURE("BPR",[M]BPR(nolign-1),"") From CONTOBJ
   If fstat | [F:BPR]BPRACC<>2
    # Tiers incorrect
    GMESSAGE = mess(50,102,1)
    OK = 0 : Break
   Endif
  Endif
  [M]ACC(nolign-1) = [F:GAC]ACC
 Elsif [M]ACC(nolign-1)=""
  # Compte inexistant  
  GMESSAGE = mess(44,102,1)
  OK = 0 : Break
 Else
  Call C_ACC([M]ACC(nolign-1))
  If mkstat : OK = 0 : Break : Endif
  [M]BPR(nolign-1) = ""
 Endif
Next nolign
If !OK
 Call ERREUR(GMESSAGE) From GESECRAN
Endif
Return

########################################################################
# Etiquette du mask TCK1 (devenu onglet ds Plan de compte)
########################################################################

Subprog C_FCY1(VALEUR)
Variable Char     VALEUR
End

Subprog C_FCY2(VALEUR)
Variable Char     VALEUR
If VALEUR=[M]FCY1(nolign-1)
 # Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
[M]COMBI(nolign-1) = [M]FCY1(nolign-1)+VALEUR
Call UNICITE([M]COMBI(nolign-1),[M]COMBI) From OBJDIV
If mkstat : End : Endif
Call UNICITE(VALEUR+[M]FCY1(nolign-1),[M]COMBI) From OBJDIV
End

Subprog AS_SAC(VALEUR)
Variable Char    VALEUR()
mkstat = 1
End

Subprog AS_ACC(VALEUR)
Variable Char     VALEUR
If [M]SAC<>""
 VALEUR = [F:GAC]ACC
 mkstat = 2
Endif
End

Subprog AS_BPR(VALEUR)
Variable Char     VALEUR
If [M]SAC="" : mkstat = 1 : Endif
End

Subprog AV_DES(VALEUR)
Variable Char     VALEUR
If [M]SAC=""
 VALEUR = ""
Else
 Call LECTEXTRA(VALEUR,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Endif
End

Subprog C_ACC(VALEUR)
Variable Char     VALEUR
Call LECTURE("GAC",VALEUR,[M:COA0]COA) From CONTOBJ
Call VERIF([F:GAC]FCY,[M]FCY1(nolign-1),VALEUR) From CFYSUB
If mkstat : End : Endif
Call VERIF([F:GAC]FCY,[M]FCY2(nolign-1),VALEUR) From CFYSUB
If mkstat : End : Endif
# Afficher le code d'appel dans la colonne Collectif si le compte est de type collectif
Read [GAC]GAC0 = [M:COA0]COA;VALEUR
If !fstat
 If [F:GAC]SAC = 2
  [M:TCK1]SAC(nolign-1) = [F:GAC]ACCSHO 
 Endif
Affzo [M:TCK1]SAC
Endif
End

#########################################################################
#  devenu obsolète car le collectif dépend du compte choisi
#########################################################################
Subprog C_SAC(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & [F:GAC]AUZBPR(5)<>2
 # Collectif incorrect
 GMESSAGE = mess(51,102,1) 
 mkstat = 2 : End
Endif
End

Subprog AM_SAC(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG
 If VALEUR<>""
  If [F:GAC]ACCSHO<>VALEUR : Read [GAC]GAC1 = [M:COA0]COA;VALEUR : Else fstat=0 : Endif
  For nolign=1 To [M]NBLIG
   [M]ACC(nolign-1) = [F:GAC]ACC 
  Next nolign
  Affzo ACC
 Else
  For nolign=1 To [M]NBLIG
   Raz [M]ACC(nolign-1), [M]BPR(nolign-1)
  Next nolign
  Affzo ACC, BPR
 Endif
Endif
End
