  Endif
 Next I_FLD
Return

$FILTPE9_LCTRM
 Local Integer I_FLD
 For I_FLD=1 To [M:TPE9]NBLIG
  If [M:TPE9]TMPFLD(I_FLD-1)="ACCCOD" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="ELEATRM"
   [M:TPE9]ORIFLD(I_FLD-1)="ACCCOD"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="ELEATRM"
   [M:TPE9]ORIFLD(I_FLD-1)="RMNTPA"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="CUR" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="ELEATRM"
   [M:TPE9]ORIFLD(I_FLD-1)="LEACUR"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="DAT" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="ELEATRM"
   [M:TPE9]ORIFLD(I_FLD-1)="EVTDAT"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="LEATYP" & [M:TPE9]TMPIND(I_FLD-1)=0
   [M:TPE9]ORITAB(I_FLD-1)="ELEATRM"
   [M:TPE9]ORIFLD(I_FLD-1)="LEATYP"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="SNS" & [M:TPE9]TMPIND(I_FLD-1)=0
   [M:TPE9]ORIEXP(I_FLD-1)="2*([F:CPT]SNSEVE<2)-1"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
 Next I_FLD
Return

