   [M:TPE9]ORIEXP(I_FLD-1)="[F:CPT]DPRCUMD+[F:CPT]PERCLOCUMD"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=5
   [M:TPE9]ORITAB(I_FLD-1)="EFASREEVAL"
   [M:TPE9]ORIFLD(I_FLD-1)="NBVO"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=6
   [M:TPE9]ORITAB(I_FLD-1)="EFASREEVAL"
   [M:TPE9]ORIFLD(I_FLD-1)="NBVD"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="CUR" & [M:TPE9]TMPIND(I_FLD-1)=1
