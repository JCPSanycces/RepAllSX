$FILTPE9_CCREV
 Local Integer I_FLD
 For I_FLD=1 To [M:TPE9]NBLIG
  If [M:TPE9]TMPFLD(I_FLD-1)="ACCCOD" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASREEVAL"
   [M:TPE9]ORIFLD(I_FLD-1)="ACCCOD"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASREEVAL"
   [M:TPE9]ORIFLD(I_FLD-1)="DPRBASO"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=2
   [M:TPE9]ORITAB(I_FLD-1)="EFASREEVAL"
   [M:TPE9]ORIFLD(I_FLD-1)="DPRBASD"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=3
   [M:TPE9]ORIEXP(I_FLD-1)="[F:CPT]DPRCUMO+[F:CPT]PERCLOCUMO"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
