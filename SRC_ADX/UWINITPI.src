$AIGUILLAGE
 Case LABUWINITPI
  When "CCAMT" : Gosub FILTPE9_CCAMT
  When "CCBVA" : Gosub FILTPE9_CCBVA
  When "CCDCP" : Gosub FILTPE9_CCDCP
  When "CCDPR" : Gosub FILTPE9_CCDPR
  When "CCDVA" : Gosub FILTPE9_CCDVA
  When "CCREV" : Gosub FILTPE9_CCREV
  When "CCSOR" : Gosub FILTPE9_CCSOR
  When "CCVIR" : Gosub FILTPE9_CCVIR
  When "CSAMT" : Gosub FILTPE9_CSAMT
  When "CSBVA" : Gosub FILTPE9_CSBVA
  When "CSDCP" : Gosub FILTPE9_CSDCP
  When "CSDPR" : Gosub FILTPE9_CSDPR
  When "CSDVA" : Gosub FILTPE9_CSDVA
  When "CSREV" : Gosub FILTPE9_CSREV
  When "CSSOR" : Gosub FILTPE9_CSSOR
  When "CSVIR" : Gosub FILTPE9_CSVIR
  When "GCCRB" : Gosub FILTPE9_GCCRB
  When "GCCRT" : Gosub FILTPE9_GCCRT
  When "GCCSH" : Gosub FILTPE9_GCCSH
  When "GSCRB" : Gosub FILTPE9_GSCRB
  When "GSCRT" : Gosub FILTPE9_GSCRT
  When "GSCSH" : Gosub FILTPE9_GSCSH
  When "LCACT" : Gosub FILTPE9_LCACT
  When "LCCRT" : Gosub FILTPE9_LCCRT
  When "LCPAY" : Gosub FILTPE9_LCPAY
  When "LCRPU" : Gosub FILTPE9_LCRPU
  When "LCTRM" : Gosub FILTPE9_LCTRM
  When "LSPAY" : Gosub FILTPE9_LSPAY
 Endcase
Return

$FILTPE9_CCAMT
 Local Integer I_FLD
 For I_FLD=1 To [M:TPE9]NBLIG
  If [M:TPE9]TMPFLD(I_FLD-1)="ACCCOD" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="FXDASSETS"
   [M:TPE9]ORIFLD(I_FLD-1)="ACCCOD"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="DEPREC"
   [M:TPE9]ORIFLD(I_FLD-1)="DPEDEV"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=2
   [M:TPE9]ORITAB(I_FLD-1)="DEPREC"
   [M:TPE9]ORIFLD(I_FLD-1)="EXCDEV"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=6
   [M:TPE9]ORITAB(I_FLD-1)="DEPREC"
   [M:TPE9]ORIFLD(I_FLD-1)="RVACRBDEV"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="CUR" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORIEXP(I_FLD-1)="func GLOFCYCPY.GET_DEVISE_PLN([F:OBJ]CPY,[F:CPT]DPRPLN)"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="OWNTYP" & [M:TPE9]TMPIND(I_FLD-1)=0
   [M:TPE9]ORITAB(I_FLD-1)="FXDASSETS"
   [M:TPE9]ORIFLD(I_FLD-1)="OWNTYP"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="SNS" & [M:TPE9]TMPIND(I_FLD-1)=0
   [M:TPE9]ORIEXP(I_FLD-1)="+1"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
 Next I_FLD
Return

$FILTPE9_CCBVA
 Local Integer I_FLD
 For I_FLD=1 To [M:TPE9]NBLIG
  If [M:TPE9]TMPFLD(I_FLD-1)="ACCCOD" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASVATREG"
   [M:TPE9]ORIFLD(I_FLD-1)="ACCCOD"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASVATREG"
   [M:TPE9]ORIFLD(I_FLD-1)="CRBVAT"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="AMT" & [M:TPE9]TMPIND(I_FLD-1)=2
   [M:TPE9]ORITAB(I_FLD-1)="EFASVATREG"
   [M:TPE9]ORIFLD(I_FLD-1)="DEDVAT"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="CUR" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASVATREG"
   [M:TPE9]ORIFLD(I_FLD-1)="CUR"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="GAC" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASVATREG"
   [M:TPE9]ORIFLD(I_FLD-1)="GAC"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="IASCGU" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASVATREG"
   [M:TPE9]ORIFLD(I_FLD-1)="IASCGU"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="OWNTYP" & [M:TPE9]TMPIND(I_FLD-1)=0
   [M:TPE9]ORITAB(I_FLD-1)="EFASVATREG"
   [M:TPE9]ORIFLD(I_FLD-1)="OWNTYP"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="SNS" & [M:TPE9]TMPIND(I_FLD-1)=0
   [M:TPE9]ORIEXP(I_FLD-1)="2*([F:CPT]SNSEVE<2)-1"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
 Next I_FLD
Return

$FILTPE9_CCDCP
 Local Integer I_FLD
 For I_FLD=1 To [M:TPE9]NBLIG
