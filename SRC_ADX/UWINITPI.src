   [M:TPE9]ORIFLD(I_FLD-1)="CUR"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="IASACC" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASREEVAL"
   [M:TPE9]ORIFLD(I_FLD-1)="IASACC"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="IASCGU" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASREEVAL"
   [M:TPE9]ORIFLD(I_FLD-1)="IASCGU"
   [M:TPE9]ENALIG(I_FLD-1)=G_OUI
  Endif
  If [M:TPE9]TMPFLD(I_FLD-1)="OWNTYP" & [M:TPE9]TMPIND(I_FLD-1)=0
