$FILTPE9_CCVIR
 Local Integer I_FLD
 For I_FLD=1 To [M:TPE9]NBLIG
  If [M:TPE9]TMPFLD(I_FLD-1)="ACCCOD" & [M:TPE9]TMPIND(I_FLD-1)=1
   [M:TPE9]ORITAB(I_FLD-1)="EFASCHGIMP"
