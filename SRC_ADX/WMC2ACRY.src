# 32 : ETATNAM Subdivision title ( Field AX3)
####################################################################

$GET_ETATNAM
Gosub DECLARE_VAR From WMC0ACRY
[L]CURPRO = "ETATNAM"
this.ETATNAM = fmet this.AGETTEXTRA(CURPRO)
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return


