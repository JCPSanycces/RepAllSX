#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When 1
      [M:LKP9]TYPCLA = "AUS"
    When 2
      [M:LKP9]TYPCLA = "BPR"
    When 3
      [M:LKP9]TYPCLA = "AIN"
    When 4
      [M:LKP9]TYPCLA = ""
  Endcase
  If VALEUR = 4 Then
    [M:LKP9]CRI = ""
    Grizo [M:LKP9]CRI
  Else
    Actzo [M:LKP9]CRI
  Endif
  [M:LKP9]TYP = VALEUR
  Gosub LOADLKP9 From TRTLKP9
End

##########################################################################
Subprog AM_CRI(VALEUR)
Variable Char    VALEUR()

  [M:LKP9]CRI = VALEUR
  Gosub LOADLKP9 From TRTLKP9
End

##########################################################################
Subprog AS_NBLIG

  If nolign > 0 Then
    Raz [M:LKP9]NBLIGSEL
    [M:LKP9]NBLIGSEL(nolign-1) = "->"
    If [M:LKP9]NBWEBADD = 0 Then
      [M:LKP9]NBWEBADD += 1
      [M:LKP9]WEBADD([M:LKP9]NBWEBADD-1) = [M:LKP9]ADEWEB(nolign-1)
    Else
      If !find([M:LKP9]ADEWEB(nolign-1),[M:LKP9]WEBADD(0..[M:LKP9]NBWEBADD-1)) Then
        [M:LKP9]NBWEBADD += 1
        [M:LKP9]WEBADD([M:LKP9]NBWEBADD-1) = [M:LKP9]ADEWEB(nolign-1)
      Endif
    Endif
    Affzo [M:LKP9]
  Endif
End

##########################################################################
Subprog IB_NBLIG

  Raz GBOUT1
  If [M:LKP9]TYPCLA <> "" Then
    Call TEXTE(5562, GBOUT1) From OBJDIV      #Détail
  Endif
End

##########################################################################
Subprog AM_DSYTYP(VALEUR)
Variable Integer VALEUR

Local Integer IARENDRE
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Char S_ATTACHMENTS(250)(1..)

  Case [M:LKP9]AOB
    When "SRE"
      # Demandes de services
      # --------------------
      IARENDRE = func SUBSREHTML.CREATE_PJ(GACTX, [M:LKP9]VCRNUM, VALEUR, S_ATTACHMENTS, SMESSAGE)
      If IARENDRE = [V]CST_ANO Then
        GMESSAGE = SMESSAGE
        mkstat = 2
      Else
        Gosub PRECHARGE_ATTACHMENT From TRTLKP9
      Endif
    When "ITN"
      # Interventions
      # --------------------
      IARENDRE = func SUBITNHTML.CREATE_PJ(GACTX, [M:LKP9]VCRNUM, VALEUR, [V]CST_AYES, S_ATTACHMENTS, SMESSAGE)
      If IARENDRE = [V]CST_ANO Then
        GMESSAGE = SMESSAGE
        mkstat = 2
      Else
        Gosub PRECHARGE_ATTACHMENT From TRTLKP9
      Endif
  Endcase
End

