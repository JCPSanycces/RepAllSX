#<AdxTL>@(#)12.0.0.0 $Revision$ 
################################################################################################
#                                                                                              #
#      TRAITEMENTS EPURATION dans les ACHATS                                                   #
#                                                                                              #
################################################################################################
################################################################################################
# HISTO = 1 => Historisation                                                                   #
#                                                                                              #
#              Les données passent d'APPLI vers HISAPL                                         #
#              Les données historisées sont supprimées d'APPLI                                 #
#              Uniquement des contrôles liés au dossier APPLI                                  #
#                                                                                              #
#                                                                                              #
# OKEPU  = 1 => Epuration                                                                      #
#                                                                                              #
#    Soit Epuration seule (OKEPU=1 et HISTO=0)                                                 #
#              Les données sont supprimées d'APPLI                                             #
#              Uniquement des contrôles liés au dossier APPLI.                                 #
#                                                                                              #
#    Soit Epuration suite à l'historisation (OKEPU=1 et HISTO=1)                               #
#              L'historisation a fait les vérifications nécessaires (cf HISTO=1)               #
#              L'épuration concerne donc le dossier HISAPL mais aucun contrôle sur ce dossier. #
#                                                                                              #
################################################################################################
# Règles d'épuration :                                       MBT 24/12/08 #
#   - PQH : Epuration des appels d'offre                                  #
#   - PSH : Epuration des demandes d'achats                               #
#   - POH : Epuration des commandes classiques                            #
#   - POC : Epuration des contrats commandes ouvertes                     #
#   - PTH : Epuration des réceptions                                      #
#   - PNH : Epuration des retours                                         #
#   - PIH : Epuration des factures achats fournisseurs                    #
###########################################################################

$ACTION
Case ACTION
  When "OUVRE"
    #-----------------------------------------#
    # Ouvertures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "PQH"   : Gosub OUVRE_PQH
      When "PSH"   : Gosub OUVRE_PSH
      When "POH"   : Gosub OUVRE_POH
      When "POC"   : Gosub OUVRE_POC
      When "PTH"   : Gosub OUVRE_PTH
      When "PNH"   : Gosub OUVRE_PNH
      When "PIH"   : Gosub OUVRE_PIH
    Endcase
  When "HISTO"
    #--------------------------------------------------------------------------#
    # Historisation enregistrements tables complémentaires non liées à l'objet #
    #--------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "PQH"   : Gosub HISTO_EPURE_PQH
      When "PSH"   : Gosub HISTO_EPURE_PSH
      When "POH"   : Gosub HISTO_EPURE_POH
      When "POC"   : Gosub HISTO_EPURE_POC
      When "PTH"   : Gosub HISTO_EPURE_PTH
      When "PNH"   : Gosub HISTO_EPURE_PNH
      When "PIH"   : Gosub HISTO_EPURE_PIH
    Endcase
  When "EPURE"
    #-------------------------------------------------------------------------#
    # Suppressions enregistrements tables complémentaires non liées à l'objet #
    #-------------------------------------------------------------------------#
    Case [F:AHI]COD
      When "PQH"   : Gosub HISTO_EPURE_PQH
      When "PSH"   : Gosub HISTO_EPURE_PSH
      When "POH"   : Gosub HISTO_EPURE_POH
      When "POC"   : Gosub HISTO_EPURE_POC
      When "PTH"   : Gosub HISTO_EPURE_PTH
      When "PNH"   : Gosub HISTO_EPURE_PNH
      When "PIH"   : Gosub HISTO_EPURE_PIH
    Endcase
  When "FERME"
    #-----------------------------------------#
    # Fermetures des fichiers complémentaires #
    #-----------------------------------------#
    Case [F:AHI]COD
      When "PQH"   : Gosub FERME_PQH
      When "PSH"   : Gosub FERME_PSH
      When "POH"   : Gosub FERME_POH
      When "POC"   : Gosub FERME_POC
      When "PTH"   : Gosub FERME_PTH
      When "PNH"   : Gosub FERME_PNH
      When "PIH"   : Gosub FERME_PIH
    Endcase
Endcase
Return


######################################
# Epuration des appels d'offre       #
# ---------------------------------- #
# Formule d'épuration PQH :          #
#    RSPDEA<>[0/0/0] & RSPDEA<date$  #
######################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
# ou autre ici PQD pour retrouver le texte détail #
#-------------------------------------------------#
$OUVRE_PQH
Gosub DEFVAR
#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:PQD])  Local File =[L]HISAPL+".PQUOTATD"  [PQD]  : Endif
    If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN" [CAL]  : Endif
  #----- Historisation -----#
  Else
    If !clalev([F:PQD])  Local File =[L]APPLI +".PQUOTATD"  [PQD]  : Endif
    If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
    #-----
    TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
    If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  If !clalev([F:PQD])    Local File =[L]APPLI +".PQUOTATD"  [PQD]  : Endif
  If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
Endif
Return

#------------------------------------------------------------#
# Suppressions ou historisation                              #
# Enregistrements tables complémentaires non liées à l'objet #
# ---------------------------------------------------------- #
# - Textes entête et pied de la table PQUOTAT                #
# - Textes détail article de la table PQUOTATD               #
# - Comptes et sections ligne d'appel d'offre                #
# Nota : Il n'est plus nécessaire en V140 d'effectuer la     #
#        suppression manuellement s'il existe un lien simple #                                             #
#------------------------------------------------------------#
$HISTO_EPURE_PQH
WCLE=[F:F1]PQHNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
#----- Historisation-épuration textes entête et pied -----#
If [F:F1]TEX1<>""
  WNUMTEX=[F:F1]TEX1 : WTYP="PQH1" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
If [F:F1]TEX2<>""
  WNUMTEX=[F:F1]TEX2 : WTYP="PQH2" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Historisation-épuration comptes, sections et textes lignes article -----#
Columns [PQD] (PQHNUM, PQDLIN, LINTEX)
For [PQD] PQD0 Where PQHNUM=[F:F1]PQHNUM
  WABRFIC="PQD" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
  If [F:PQD]LINTEX<>""
    WCLE=[F:F1]PQHNUM-num$([F:PQD]PQDLIN)
    WNUMTEX=[F:PQD]LINTEX : WTYP="PQD1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
Next
Columns [PQD]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_PQH
If clalev([F:PQD])   Close Local File [PQD]  : Endif
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
Return


##################################
# Epuration des demandes d'achat #
# ------------------------------ #
# Formule d'épuration PSH :      #
#    CLEFLG=2                    #
##################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
# ou autre ici PSD pour retrouver le texte détail #
#-------------------------------------------------#
$OUVRE_PSH
Gosub DEFVAR
#----- Historisationns -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:PSD])  Local File =[L]HISAPL+".PREQUISD"  [PSD]  : Endif
    If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN" [CAL]  : Endif
  #----- Historisation -----#
  Else
    If !clalev([F:PSD])  Local File =[L]APPLI +".PREQUISD"  [PSD]  : Endif
    If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
    #-----
    TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
    If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN" [CAL1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  If !clalev([F:PSD])    Local File =[L]APPLI +".PREQUISD"  [PSD]  : Endif
  If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN" [CAL]  : Endif
Endif
Return

#---------------------------------------------------------------------#
# Historisation et Suppression enregistrements tables complémentaires #
# ------------------------------------------------------------------- #
# - Textes entête et pied de la table PREQUIS                         #
# - Textes détail article de la table PREQUISD                        #
# - Comptes et sections ligne demande d'achat                         #
# Nota : Les enregistrements tables PREQUISD-PREQUISO-PREQUISA sont   #
#        supprimés automatiquement grâce au lien sur la table PREQUIS #
#---------------------------------------------------------------------#
$HISTO_EPURE_PSH
WCLE=[F:F1]PSHNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
#----- Historisation-épuration textes entête et pied -----#
If [F:F1]TEX1<>""
  WNUMTEX=[F:F1]TEX1 : WTYP="PSH1" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
If [F:F1]TEX2<>""
  WNUMTEX=[F:F1]TEX2 : WTYP="PSH2" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Historisation-épuration comptes, sections et textes lignes article -----#
Columns [PSD] (PSHNUM, PSDLIN, LINTEX)
For [PSD] PSD0 Where PSHNUM=[F:F1]PSHNUM
  WABRFIC="PSD" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
  If [F:PSD]LINTEX<>""
    WCLE=[F:F1]PSHNUM-num$([F:PSD]PSDLIN)
    WNUMTEX=[F:PSD]LINTEX : WTYP="PSD1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
Next
Columns [PSD]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_PSH
If clalev([F:PSD])   Close Local File [PSD]  : Endif
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
Return


################################################################################
# Epuration des commandes classiques                                           #
# ---------------------------------------------------------------------------- #
# Formule d'épuration POH :                                                    #
#    POHTYP<>2 & CLEFLG=2 & (INVFLG>2 or RCPFLG<2 or (BETFCY=2 and BETCPY<>2)) #
################################################################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
# ou autre ici POQ pour retrouver le texte détail #
# POP pour retrouver les comptes et sections      #
# et PIH, PID, PTD pour vérifications             #
# et STCR pour contrôle rapprochement en attente  #
# et STCD/STCR pour histo-épuration des charges   #
#-------------------------------------------------#
$OUVRE_POH
Gosub DEFVAR
#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:DUD])  Local File =[L]HISAPL+".GACCDUDATE" [DUD]  : Endif
    If !clalev([F:PVF])  Local File =[L]HISAPL+".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]HISAPL+".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:POQ])  Local File =[L]HISAPL+".PORDERQ"    [POQ]  : Endif
    If !clalev([F:POP])  Local File =[L]HISAPL+".PORDERP"    [POP]  : Endif
    If !clalev([F:UOP])  Local File =[L]HISAPL+".UPORDERP"   [UOP]  : Endif
    If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN"  [CAL]  : Endif
    # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
    If !clalev([F:STCD]) Local File =[L]HISAPL+".COSTSTCD"   [STCD] : Endif
    # Issue X3-25003 - 2018-03-23 by SR : ajout tables nécessaires
    If !clalev([F:PIH])  Local File =[L]HISAPL+".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]HISAPL+".PINVOICED"  [PID]  : Endif
    If !clalev([F:PTD])  Local File =[L]HISAPL+".PRECEIPTD"  [PTD]  : Endif
    If !clalev([F:STCR]) Local File =[L]HISAPL+".COSTSTCR"   [STCR] : Endif
  #----- Historisation -----#
  Else
    #----- Fichiers pour vérifications -----#
    If !clalev([F:PIH])  Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
    If !clalev([F:PTD])  Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
    #-----
    If !clalev([F:DUD])  Local File =[L]APPLI +".GACCDUDATE" [DUD]  : Endif
    If !clalev([F:PVF])  Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:POQ])  Local File =[L]APPLI +".PORDERQ"    [POQ]  : Endif
    If !clalev([F:POP])  Local File =[L]APPLI +".PORDERP"    [POP]  : Endif
    If !clalev([F:UOP])  Local File =[L]APPLI +".UPORDERP"   [UOP]  : Endif
    If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
    # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
    If !clalev([F:STCR]) Local File =[L]APPLI+".COSTSTCR"   [STCR] : Endif
    #-----
    TABLE="GACCDUDATE" : Gosub CRETAB_HISTO
    If !clalev([F:DUD1]) Local File =[L]HISAPL+".GACCDUDATE" [DUD1] : Endif
    TABLE="PVCRFOOT"   : Gosub CRETAB_HISTO
    If !clalev([F:PVF1]) Local File =[L]HISAPL+".PVCRFOOT"   [PVF1] : Endif
    TABLE="PVCRVAT"    : Gosub CRETAB_HISTO
    If !clalev([F:PVV1]) Local File =[L]HISAPL+".PVCRVAT"    [PVV1] : Endif
    TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
    If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
    # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
    TABLE="COSTSTCD"  : Gosub CRETAB_HISTO
    If !clalev([F:STC1]) Local File =[L]HISAPL+".COSTSTCD"   [STC1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  #----- Fichiers pour vérifications -----#
  If !clalev([F:PIH])    Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
  If !clalev([F:PID])    Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
  If !clalev([F:PTD])    Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
  #-----
  If !clalev([F:DUD])    Local File =[L]APPLI +".GACCDUDATE" [DUD]  : Endif
  If !clalev([F:PVF])    Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
  If !clalev([F:PVV])    Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
  If !clalev([F:POQ])    Local File =[L]APPLI +".PORDERQ"    [POQ]  : Endif
  If !clalev([F:POP])    Local File =[L]APPLI +".PORDERP"    [POP]  : Endif
  If !clalev([F:UOP])    Local File =[L]APPLI +".UPORDERP"   [UOP]  : Endif
  If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
  # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
  If !clalev([F:STCR])   Local File =[L]APPLI+".COSTSTCR"    [STCR] : Endif
  If !clalev([F:STCD])   Local File =[L]APPLI+".COSTSTCD"    [STCD] : Endif
Endif
Gosub OUVRE_VEN
Return

#--------------------------------------------------------------------#
# Historisation et suppressions enregistrements tables non liées     #
# ------------------------------------------------------------------ #
# - Echéances GACCDUDATE [DUD]                                       #
# - Eléments de facturation pied de commande                         #
# - Taxes pied de commande                                           #
# - Textes entête et pied de la table PORDER                         #
# - Textes détail article de la table PORDERQ                        #
# - Comptes et sections ligne de commande                            #
# - Comptes et sections ligne avenant de commande                    #
# ------------------------------------------------------------------ #
# Si contrat inter-site, suppression du contrat vente                #
# SORDER    [SOH] Commandes de vente entête                          #
# SORDERC   [SOC] Commandes de vente article contrat (avance/retard) #
# SORDERQ   [SOQ] Commandes de vente détail quantités                #
# SORDERP   [SOP] Commandes de vente détail prix                     #
# VSORDER   [VOH] Historique commandes de vente entête               #
# VSORDERC  [VOC] Historique commandes de vente article contrat      #
# VSORDERQ  [VOQ] Historique commandes de vente détail quantités     #
# VSORDERP  [VOP] Historique commandes de vente détail prix          #
#--------------------------------------------------------------------#
$HISTO_EPURE_POH
WCLE=[F:F1]POHNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
Gosub VERIF_POH
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#-----
If [F:F1]BETFCY=2 & [F:F1]SALFCY<>""
  Gosub VERIF_VEN
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
  Gosub HISTO_EPURE_VEN
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
  WCLE=[F:F1]POHNUM
Endif
#----- Historisation-épuration des échéances -----#
Gosub HISTO_EPURE_DUDPOH
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration des éléments de facturation -----#
[L]WVCRTYP2=3 : Gosub HISTO_EPURE_PVF
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation_épuration des taxes -----#
[L]WVCRTYP=3 : Gosub HISTO_EPURE_PVV
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration textes entête et pied -----#
If [F:F1]TEX1<>""
  WNUMTEX=[F:F1]TEX1 : WTYP="POH1" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
If [F:F1]TEX2<>""
  WNUMTEX=[F:F1]TEX2 : WTYP="POH2" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Historisation-épuration textes lignes article -----#
#-----Historisation-épuration des charges lignes ---------#
Columns [POQ] (POHNUM, POPLIN, POQSEQ, LINTEX)
For [POQ] POQ0 Where POHNUM=[F:F1]POHNUM
  If [F:POQ]LINTEX<>""
    WCLE=[F:F1]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
    WNUMTEX=[F:POQ]LINTEX : WTYP="POD1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
  # Issue 96113 - 2014-06-23 by SR : Landed costs
  If [F:POQ]STCNUM <> ""
     WABRFIC="POQ" : Gosub HISTO_EPURE_STCD
     If !WOK  Break : Endif
  Endif
  # Issue 96113 - 2014-06-23 by SR
Next
Columns [POQ]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration comptes, sections lignes commande -----#
Columns [POP] (POHNUM, POPLIN, POPSEQ)
For [POP] POP0 Where POHNUM=[F:F1]POHNUM
  WABRFIC="POP" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
Next
Columns [POP]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration comptes, sections lignes avenants commande -----#
Columns [UOP] (POHNUM, POPLIN, POPSEQ)
For [UOP] POP0 Where POHNUM=[F:F1]POHNUM
  WABRFIC="UOP" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
Next
Columns [UOP]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#-----
Return

#-----------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (WOK=0 pour refuser) #
# --------------------------------------------------------------------------- #
# La commande ne peut être purgée que si :                                    #
#    - Toutes les factures s'y rapportant sont validées                       #
#    - Toutes les factures des réceptions s'y rapportant sont validées        #
#    - Des enregistrements s'y rapportant existent dans COSTSTCR              #
#-----------------------------------------------------------------------------#
$VERIF_POH
WOK=1
#----- Si épuration suite à histo, le contrôle a été fait lors de l'histo -----#
If HISTO & OKEPU  Return : Endif
#----- Verification des factures se rapportant à la commande -----#
If ([F:F1]BETFCY<>2 | [F:F1]BETCPY=2)
  Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI)
  For [PID] PID1 Where TYPORI=1 & NUMORI=[F:F1]POHNUM
    Read [PIH] PIH0=[F:PID]NUM
    If !fstat
      If [F:PIH]STA<>3
        WMESSAGE=[F:PIH]PIVTYP-[F:PIH]NUM : WOK=0 : Break
      Endif
    Endif
  Next
  Columns [PID]
Endif
#----- Vérification des factures des réceptions se rapportant à la commande -----#
If WOK & ([F:F1]BETFCY<>2 | [F:F1]BETCPY=2)
  Columns [PTD] (PTHNUM, PTDLIN, POHNUM)
  Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI, LINORI)
  For [PTD] PTD2 Where POHNUM=[F:F1]POHNUM
    For [PID] PID1 Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN
      Read [PIH] PIH0=[F:PID]NUM
      If !fstat
        If [F:PIH]STA<>3
          WMESSAGE=[F:PIH]PIVTYP-[F:PIH]NUM : WOK=0 : Break 2
        Endif
      Endif
    Next
  Next
  Columns [PTD]
  Columns [PID]
Endif
#-----
If !WOK
  WMESSAGE=[F:F1]POHNUM-WMESSAGE-mess(431,197,1)
# Issue 96113 - 2014-06-24 by SR : Landed Costs
#  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
# Issue 96113 - 2014-06-24 by SR : Landed Costs
#------- Pas de Rapprochement en attente
If WOK
  Filter [F:STCR] Where TYPORI = 1 & NUMORI = [F:F1]POHNUM & STCRFLG <> 2
  Look [F:STCR]STCR1 First
  If !fstat
      # Il reste des rapprochements de charge non validés
      WMESSAGE=[F:F1]POHNUM-mess(831,197,1) : WOK=0
  Endif
  Filter [F:STCR]
Endif
If !WOK
  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
# End issue 96113
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_POH
If clalev([F:PIH])   Close Local File [PIH]  : Endif
If clalev([F:PID])   Close Local File [PID]  : Endif
If clalev([F:PTD])   Close Local File [PTD]  : Endif
If clalev([F:DUD])   Close Local File [DUD]  : Endif
If clalev([F:PVF])   Close Local File [PVF]  : Endif
If clalev([F:PVV])   Close Local File [PVV]  : Endif
If clalev([F:POQ])   Close Local File [POQ]  : Endif
If clalev([F:POP])   Close Local File [POP]  : Endif
If clalev([F:UOP])   Close Local File [UOP]  : Endif
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:DUD1])  Close Local File [DUD1] : Endif
If clalev([F:PVF1])  Close Local File [PVF1] : Endif
If clalev([F:PVV1])  Close Local File [PVV1] : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
# Issue 96113 - 2014-06-24 by SR : Landed Costs
If clalev([F:STCR])  Close Local File [STCR] : Endif
If clalev([F:STCD])  Close Local File [STCD] : Endif
If clalev([F:STC1])  Close Local File [STC1] : Endif
Gosub FERME_VEN
Return


#############################################
# Epuration des contrats commandes ouvertes #
# ----------------------------------------- #
# Formule d'épuration POC :                 #
#    POHTYP=2 & ENDDAT<date$                #
#############################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
# ou autre ici POC, POQ pour retrouver les textes #
# POP pour retrouver les comptes et sections      #
# et PIH, PID, PTD pour vérifications             #
#-------------------------------------------------#
$OUVRE_POC
Gosub DEFVAR
#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:PVF])  Local File =[L]HISAPL+".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]HISAPL+".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:POC])  Local File =[L]HISAPL+".PORDERC"    [POC]  : Endif
    If !clalev([F:POQ])  Local File =[L]HISAPL+".PORDERQ"    [POQ]  : Endif
    If !clalev([F:POP])  Local File =[L]HISAPL+".PORDERP"    [POP]  : Endif
    If !clalev([F:UOP])  Local File =[L]HISAPL+".UPORDERP"   [UOP]  : Endif
    If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN"  [CAL]  : Endif
    # Issue X3-25003 - 2018-03-23 by SR : Ouverture des tables nécessaire
    If !clalev([F:PIH])  Local File =[L]HISAPL+".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]HISAPL+".PINVOICED"  [PID]  : Endif
    If !clalev([F:PTD])  Local File =[L]HISAPL+".PRECEIPTD"  [PTD]  : Endif
  #----- Historisation -----#
  Else
    #----- Fichiers pour vérifications -----#
    If !clalev([F:PIH])  Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
    If !clalev([F:PTD])  Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
    #-----
    If !clalev([F:PVF])  Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:POC])  Local File =[L]APPLI +".PORDERC"    [POC]  : Endif
    If !clalev([F:POQ])  Local File =[L]APPLI +".PORDERQ"    [POQ]  : Endif
    If !clalev([F:POP])  Local File =[L]APPLI +".PORDERP"    [POP]  : Endif
    If !clalev([F:UOP])  Local File =[L]APPLI +".UPORDERP"   [UOP]  : Endif
    If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
    #-----
    TABLE="PVCRFOOT"   : Gosub CRETAB_HISTO
    If !clalev([F:PVF1]) Local File =[L]HISAPL+".PVCRFOOT"   [PVF1] : Endif
    TABLE="PVCRVAT"    : Gosub CRETAB_HISTO
    If !clalev([F:PVV1]) Local File =[L]HISAPL+".PVCRVAT"    [PVV1] : Endif
    TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
    If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  #----- Fichiers pour vérifications -----#
  If !clalev([F:PIH])    Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
  If !clalev([F:PID])    Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
  If !clalev([F:PTD])    Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
  #-----
  If !clalev([F:PVF])    Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
  If !clalev([F:PVV])    Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
  If !clalev([F:POC])    Local File =[L]APPLI +".PORDERC"    [POC]  : Endif
  If !clalev([F:POQ])    Local File =[L]APPLI +".PORDERQ"    [POQ]  : Endif
  If !clalev([F:POP])    Local File =[L]APPLI +".PORDERP"    [POP]  : Endif
  If !clalev([F:UOP])    Local File =[L]APPLI +".UPORDERP"   [UOP]  : Endif
  If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
Endif
Gosub OUVRE_VEN
Return

#--------------------------------------------------------------------#
# Historisation et suppressions enregistrements tables non liées     #
# ------------------------------------------------------------------ #
# - Eléments de facturation pied de commande                         #
# - Taxes pied de commande                                           #
# - Textes entête et pied de la table PORDER                         #
# - Textes détail article de la table PORDERC                        #
# - Textes détail article de la table PORDERQ                        #
# - Comptes et sections ligne de commande                            #
# - Comptes et sections ligne avenant de commande                    #
# ------------------------------------------------------------------ #
# Si contrat inter-site, suppression du contrat vente                #
# SORDER    [SOH] Commandes de vente entête                          #
# SORDERC   [SOC] Commandes de vente article contrat (avance/retard) #
# SORDERQ   [SOQ] Commandes de vente détail quantités                #
# SORDERP   [SOP] Commandes de vente détail prix                     #
# VSORDER   [VOH] Historique commandes de vente entête               #
# VSORDERC  [VOC] Historique commandes de vente article contrat      #
# VSORDERQ  [VOQ] Historique commandes de vente détail quantités     #
# VSORDERP  [VOP] Historique commandes de vente détail prix          #
#--------------------------------------------------------------------#
$HISTO_EPURE_POC
WCLE=[F:F1]POHNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
Gosub VERIF_POC
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#-----
If [F:F1]BETFCY=2 & [F:F1]SALFCY<>""
  Gosub VERIF_VEN
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
  Gosub HISTO_EPURE_VEN
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
  WCLE=[F:F1]POHNUM
Endif
#----- Historisation-épuration des éléments de facturation -----#
[L]WVCRTYP2=5 : Gosub HISTO_EPURE_PVF
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration des taxes -----#
[L]WVCRTYP=5 : Gosub HISTO_EPURE_PVV
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration textes entête et pied -----#
If [F:F1]TEX1<>""
  WNUMTEX=[F:F1]TEX1 : WTYP="POH1" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
If [F:F1]TEX2<>""
  WNUMTEX=[F:F1]TEX2 : WTYP="POH2" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Historisation-épuration textes lignes article contrat -----#
Columns [POC] (POHNUM, POPLIN, TEX)
For [POC] POC0 Where POHNUM=[F:F1]POHNUM
  If [F:POC]TEX<>""
    WCLE=[F:F1]POHNUM-num$([F:POC]POPLIN)
    WNUMTEX=[F:POC]TEX : WTYP="POC1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
Next
Columns [POC]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration textes lignes article -----#
Columns [POQ] (POHNUM, POPLIN, POQSEQ, LINTEX)
For [POQ] POQ0 Where POHNUM=[F:F1]POHNUM
  If [F:POQ]LINTEX<>""
    WCLE=[F:F1]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
    WNUMTEX=[F:POQ]LINTEX : WTYP="POQ1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
Next
Columns [POQ]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration comptes, sections lignes commande -----#
Columns [POP] (POHNUM, POPLIN, POPSEQ)
For [POP] POP0 Where POHNUM=[F:F1]POHNUM
  WABRFIC="POP" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
Next
Columns [POP]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration comptes, sections lignes avenants commande -----#
Columns [UOP] (POHNUM, POPLIN, POPSEQ)
For [UOP] POP0 Where POHNUM=[F:F1]POHNUM
  WABRFIC="UOP" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
Next
Columns [UOP]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#-----
Return

#-----------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (WOK=0 pour refuser) #
# --------------------------------------------------------------------------- #
# Le contrat ne peut être purgé que si :                                      #
#    - Toutes les demandes de livraison sont soldées                          #
#    - Toutes les factures s'y rapportant sont validées                       #
#    - Toutes les factures des réceptions s'y rapportant sont validées        #
#    - Toutes les réceptions non inter-sites s'y rapportant sont facturées    #
#-----------------------------------------------------------------------------#
$VERIF_POC
WOK=1
#----- Si épuration suite à histo, le contrôle a été fait lors de l'histo -----#
If HISTO & OKEPU  Return : Endif
#----- Vérification que toutes les DL achats sont soldées -----#
Columns [POQ] (POHNUM, POPLIN, POQSEQ, LINSTA)
For [POQ] POQ0 Where POHNUM=[F:F1]POHNUM
  If [F:POQ]LINSTA<>3
    WMESSAGE =[F:F1]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)-mess(432,197,1)
    WOK=0 : Break
  Endif
Next
Columns [POQ]
#----- Verification des factures se rapportant au contrat -----#
If WOK & ([F:F1]BETFCY<>2 | [F:F1]BETCPY=2)
  Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI)
  For [PID] PID1 Where TYPORI=1 & NUMORI=[F:F1]POHNUM
    Read [PIH] PIH0=[F:PID]NUM
    If !fstat
      If [F:PIH]STA<>3
        WMESSAGE=[F:F1]POHNUM-[F:PIH]PIVTYP-[F:PIH]NUM-mess(431,197,1)
        WOK=0 : Break
      Endif
    Endif
  Next
  Columns [PID]
Endif
#----- Vérification des factures des réceptions se rapportant au contrat -----#
If WOK & ([F:F1]BETFCY<>2 | [F:F1]BETCPY=2)
  Columns [PTD] (PTHNUM, PTDLIN, POHNUM, LININVFLG)
  Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI, LINORI)
  For [PTD] PTD2 Where POHNUM=[F:F1]POHNUM
    #----- Vérification si réceptions facturées -----#
    If [F:PTD]LININVFLG<>2
      WMESSAGE=[F:F1]POHNUM-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-mess(434,197,1)
      WOK=0 : Break
    Endif
    #----- Vérification si les factures existantes sont validées ------#
    For [PID] PID1 Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN
      Read [PIH] PIH0=[F:PID]NUM
      If !fstat
        If [F:PIH]STA<>3
          WMESSAGE=[F:F1]POHNUM-[F:PIH]PIVTYP-[F:PIH]NUM-mess(431,197,1)
          WOK=0 : Break 2
        Endif
      Endif
    Next
  Next
  Columns [PTD]
  Columns [PID]
Endif
#-----
If !WOK
  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_POC
If clalev([F:PIH])   Close Local File [PIH]  : Endif
If clalev([F:PID])   Close Local File [PID]  : Endif
If clalev([F:PTD])   Close Local File [PTD]  : Endif
If clalev([F:PVF])   Close Local File [PVF]  : Endif
If clalev([F:PVV])   Close Local File [PVV]  : Endif
If clalev([F:POC])   Close Local File [POC]  : Endif
If clalev([F:POQ])   Close Local File [POQ]  : Endif
If clalev([F:POP])   Close Local File [POP]  : Endif
If clalev([F:UOP])   Close Local File [UOP]  : Endif
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:PVF1])  Close Local File [PVF1] : Endif
If clalev([F:PVV1])  Close Local File [PVV1] : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
Gosub FERME_VEN
Return


###########################################
# Epuration des réceptions d'achat        #
# --------------------------------------- #
# Formule d'épuration PTH :               #
#    (BETFCY=2 and BETCPY<>2) or INVFLG>2 #
###########################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
# ou autre ici PTD pour retrouver le texte détail #
# et  comptes et sections                         #
# et PIH, PID pour vérifications                  #
# et STCR pour contrôle rapprochement en attente  #
# et STCD/STCR pour histo-épuration des charges   #
#-------------------------------------------------#
$OUVRE_PTH
Gosub DEFVAR
#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:PVF])  Local File =[L]HISAPL+".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]HISAPL+".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:PTD])  Local File =[L]HISAPL+".PRECEIPTD"  [PTD]  : Endif
    If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN"  [CAL]  : Endif
    # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
    If !clalev([F:STCD]) Local File =[L]HISAPL+".COSTSTCD"   [STCD] : Endif
    # Issue X3-25003 - 2018-03-23 by SR : Ouverture tables nécessaires
    If !clalev([F:PIH])  Local File =[L]HISAPL+".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]HISAPL+".PINVOICED"  [PID]  : Endif
    If !clalev([F:STCR]) Local File =[L]HISAPL+".COSTSTCR"   [STCR] : Endif
    #-----
  #----- Historisation -----#
  Else
    #----- Fichiers pour vérifications -----#
    If !clalev([F:PIH])  Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
    #-----
    If !clalev([F:PVF])  Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:PTD])  Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
    If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
    # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
    If !clalev([F:STCR]) Local File =[L]APPLI+".COSTSTCR"   [STCR] : Endif
    #-----
    TABLE="PVCRFOOT"   : Gosub CRETAB_HISTO
    If !clalev([F:PVF1]) Local File =[L]HISAPL+".PVCRFOOT"   [PVF1] : Endif
    TABLE="PVCRVAT"    : Gosub CRETAB_HISTO
    If !clalev([F:PVV1]) Local File =[L]HISAPL+".PVCRVAT"    [PVV1] : Endif
    TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
    If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
    # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
    TABLE="COSTSTCD"  : Gosub CRETAB_HISTO
    If !clalev([F:SCT1]) Local File =[L]HISAPL+".COSTSTCD"   [STC1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  #----- Fichiers pour vérifications -----#
  If !clalev([F:PIH])    Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
  If !clalev([F:PID])    Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
  #-----
  If !clalev([F:PVF])    Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
  If !clalev([F:PVV])    Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
  If !clalev([F:PTD])    Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
  If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
  # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
  If !clalev([F:STCR])   Local File =[L]APPLI+".COSTSTCR"    [STCR] : Endif
  If !clalev([F:STCD])   Local File =[L]APPLI+".COSTSTCD"    [STCD] : Endif
Endif
Return

#--------------------------------------------------------------------#
# Historisation et suppressions enregistrements tables non liées     #
# ------------------------------------------------------------------ #
# - Eléments de facturation pied de réception                        #
# - Taxes pied de réception                                          #
# - Textes entête et pied de la table PRECEIPT                       #
# - Textes détail article de la table PRECEIPTD                      #
# - Comptes et sections ligne de commande                            #
#--------------------------------------------------------------------#
$HISTO_EPURE_PTH
WCLE=[F:F1]PTHNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
Gosub VERIF_PTH
If !WOK : OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration des éléments de facturation -----#
[L]WVCRTYP2=6 : Gosub HISTO_EPURE_PVF
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration des taxes -----#
[L]WVCRTYP=6 : Gosub HISTO_EPURE_PVV
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration textes entête et pied si nécessaire -----#
If [F:F1]TEX1<>""
  WNUMTEX=[F:F1]TEX1 : WTYP="PTH1" : Gosub HISTO_EPURE_TEX
  If !WOK=0  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
If [F:F1]TEX2<>""
  WNUMTEX=[F:F1]TEX2 : WTYP="PTH2" : Gosub HISTO_EPURE_TEX
  If !WOK=0  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Historisation-épuration comptes, sections et textes lignes article -----#
#----- Historisation-épuration des charges lignes article ---------------------#
Columns [PTD] (PTHNUM, PTDLIN, LINTEX)
For [PTD] PTD0 Where PTHNUM=[F:F1]PTHNUM
  WABRFIC="PTD" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
  If [F:PTD]LINTEX<>""
    WCLE=[F:F1]PTHNUM-num$([F:PTD]PTDLIN)
    WNUMTEX=[F:PTD]LINTEX : WTYP="PTD1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
  # Issue 96113 - 2014-06-23 by SR : Landed costs
  If [F:PTD]STCNUM <> ""
     WABRFIC="PTD" : Gosub HISTO_EPURE_STCD
     If !WOK  Break : Endif
  Endif
  # Issue 96113 - 2014-06-23 by SR
Next
Columns [PTD]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#----------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (WOK=0 pour refuser)      #
# -------------------------------------------------------------------------------- #
# La réception ne peut être purgée que si :                                        #
#  - Toutes les factures s'y rapportant ne sont pas validées                       #
#  - Des enregistrements s'y rapportant existent dans COSTSTCR                     #
#  - Des enregistrements se rapportant à une commanade liée existent dans COSTSTCR #
#----------------------------------------------------------------------------------#
$VERIF_PTH
WOK=1
# Issue X3-25003 - 2018-04-05 by SR
#----- Si épuration suite à histo, le contrôle a été fait lors de l'histo -----#
If HISTO & OKEPU  Return : Endif
# End issue X3-25003
#----- Verification des factures se rapportant à la réception -----#
If [F:F1]BETFCY<>2 | [F:F1]BETCPY=2
  Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI)
  For [PID] PID1 Where TYPORI=2 & NUMORI=[F:F1]PTHNUM
    Read [PIH] PIH0=[F:PID]NUM
    If !fstat
      If [F:PIH]STA<>3
        WMESSAGE=[F:PIH]PIVTYP-[F:PIH]NUM : WOK=0 : Break
      Endif
    Endif
  Next
  Columns [PID]
Endif
#-----
If !WOK
  WMESSAGE=[F:F1]PTHNUM-WMESSAGE-mess(431,197,1)
  # Issue 96113 - 2014-06-24 by SR : Landed Costs
#  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
# Issue 96113 - 2014-06-24 by SR : Landed Costs
#------- Pas de Rapprochement en attente sur la réception
If WOK
  Filter [F:STCR] Where TYPORI = 2 & NUMORI = [F:F1]PTHNUM & STCRFLG <> 2
  Look [F:STCR]STCR1 First
  If !fstat
      # Il reste des rapprochements de charge non validés
      WMESSAGE=[F:F1]PTHNUM-mess(831,197,1) : WOK=0
  Endif
  Filter [F:STCR]
Endif
#------- Pas de Rapprochement en attente sur les lignes de commandes liées
If WOK
  Columns [PTD] (PTHNUM, PTDLIN, POHNUM, STCNUM)
  For [F:PTD]PTD0 Where PTHNUM = [F:F1]PTHNUM & POHNUM <> "" & STCNUM <> ""
      Filter [F:STCR] Where TYPORI = 1 & NUMORI = [F:PTD]POHNUM  & LINORI = [F:PTD]POPLIN & STCRFLG <> 2
      Look [F:STCR]STCR1 First
      If !fstat
          # Il reste des rapprochements de charge non validés
          WMESSAGE=[F:F1]PTHNUM + ":"+ [F:PTD]POHNUM+"/"+num$([F:PTD]POPLIN)-mess(831,197,1) : WOK=0
      Endif
      Filter [F:STCR]
      If WOK = 0 : Break : Endif
  Next
  Columns [PTD]
Endif
If !WOK
  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
# End issue 96113
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_PTH
If clalev([F:PIH])   Close Local File [PIH]  : Endif
If clalev([F:PID])   Close Local File [PID]  : Endif
If clalev([F:PVF])   Close Local File [PVF]  : Endif
If clalev([F:PVV])   Close Local File [PVV]  : Endif
If clalev([F:PTD])   Close Local File [PTD]  : Endif
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:PVF1])  Close Local File [PVF1] : Endif
If clalev([F:PVV1])  Close Local File [PVV1] : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
# Issue 96113 - 2014-06-24 by SR : Landed Costs
If clalev([F:STCR])  Close Local File [STCR] : Endif
If clalev([F:STCD])  Close Local File [STCD] : Endif
If clalev([F:STC1])  Close Local File [STC1] : Endif
Return


#################################
# Epuration des retours d'achat #
# ----------------------------- #
# Formule d'épuration PNH :     #
#    CFMFLG=2 & INVFLG>2        #
#################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
# ou autre ici PND pour retrouver le texte détail #
# et comptes et sections analytiques              #
# et PIH, PID pour vérifications                  #
#-------------------------------------------------#
$OUVRE_PNH
Gosub DEFVAR
#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:PND])  Local File =[L]HISAPL+".PRETURND"   [PND]  : Endif
    If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN"  [CAL]  : Endif
    # Issue X3-25003 - 2018-03-23 by SR : Ouverture tables nécessaires
    If !clalev([F:PIH])  Local File =[L]HISAPL+".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]HISAPL+".PINVOICED"  [PID]  : Endif
  Else
    #----- Fichiers pour vérifications -----#
    If !clalev([F:PIH])  Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
    If !clalev([F:PID])  Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
    #-----
    If !clalev([F:PND])  Local File =[L]APPLI +".PRETURND"   [PND]  : Endif
    If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
    #----
    TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
    If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  #----- Fichiers pour vérifications -----#
  If !clalev([F:PIH])    Local File =[L]APPLI +".PINVOICE"   [PIH]  : Endif
  If !clalev([F:PID])    Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
  #-----
  If !clalev([F:PND])    Local File =[L]APPLI +".PRETURND"   [PND]  : Endif
  If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
Endif
Return

#--------------------------------------------------------------------#
# Historisation et suppressions enregistrements tables non liées     #
# ------------------------------------------------------------------ #
# - Textes entête et pied de la table PRETURN                        #
# - Textes détail article de la table PRETURND                       #
# - Comptes et sections ligne de retour                              #
#--------------------------------------------------------------------#
$HISTO_EPURE_PNH
WCLE=[F:F1]PNHNUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
Gosub VERIF_PNH
If !WOK=0  OKHIS=0 : OKEPU=0 : Return : Endif
If [F:F1]TEX1<>""
  WNUMTEX=[F:F1]TEX1 : WTYP="PNH1" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Hstorisation-épuration textes entête et pied -----#
If [F:F1]TEX2<>""
  WNUMTEX=[F:F1]TEX2 : WTYP="PNH2" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Historisation-épuration comptes, sections, textes lignes article -----#
Columns [PND] (PNHNUM, PNDLIN, LINTEX)
For [PND] PND0 Where PNHNUM=[F:F1]PNHNUM
  WABRFIC="PND" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
  If [F:PND]LINTEX<>""
    WCLE=[F:F1]PNHNUM-num$([F:PND]PNDLIN)
    WNUMTEX=[F:PND]LINTEX : WTYP="PND1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
Next
Columns [PND]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#-----------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (WOK=0 pour refuser) #
# --------------------------------------------------------------------------- #
# Le retour ne peut être purgé que si :                                       #
#    - Toutes les factures s'y rapportant sont validées                       #
#-----------------------------------------------------------------------------#
$VERIF_PNH
WOK=1
# Issue X3-25003 - 2018-04-05 by SR
#----- Si épuration suite à histo, le contrôle a été fait lors de l'histo -----#
If HISTO & OKEPU  Return : Endif
# End issue X3-25003
#----- Verification des factures se rapportant au retour -----#
Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI)
For [PID] PID1 Where TYPORI=3 & NUMORI=[F:F1]PNHNUM
    Read [PIH] PIH0=[F:PID]NUM
    If !fstat
      If [F:PIH]STA<>3
        WMESSAGE=[F:PIH]PIVTYP-[F:PIH]NUM : WOK=0 : Break
      Endif
    Endif
Next
Columns [PID]
#-----
If !WOK
  WMESSAGE=[F:F1]PNHNUM-WMESSAGE-mess(431,197,1)
  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_PNH
If clalev([F:PIH])   Close Local File [PIH]  : Endif
If clalev([F:PID])   Close Local File [PID]  : Endif
If clalev([F:PND])   Close Local File [PND]  : Endif
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
Return


##############################################
# Epuration des factures achats fournisseurs #
# ------------------------------------------ #
# Formule d'épuration PIH :                  #
#    ORIMOD=6 & STA=3                        #
##############################################

#-------------------------------------------------#
# Ouvertures des fichiers non liés (lien simple)  #
# ou autre ici PID pour retrouver le texte détail #
# et les comptes et sections                      #
# et PIH2 pour vérifications                      #
# et STCR pour contrôle rapprochement en attente  #
# Il n'y a pas de charges à historiser-épurer     #
#-------------------------------------------------#
$OUVRE_PIH
Gosub DEFVAR
#----- Historisation -----#
If HISTO
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:DUD])  Local File =[L]HISAPL+".GACCDUDATE" [DUD]  : Endif
    If !clalev([F:PVF])  Local File =[L]HISAPL+".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]HISAPL+".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:PIV])  Local File =[L]HISAPL+".PINVOICEV"  [PIV]  : Endif
    If !clalev([F:PID])  Local File =[L]HISAPL+".PINVOICED"  [PID]  : Endif
    If !clalev([F:CAL])  Local File =[L]HISAPL+".CPTANALIN"  [CAL]  : Endif
    # Issue X3-25003 - 2018-03-06 by SR : Valorisation des stocks
    If !clalev([F:PIH2]) Local File =[L]HISAPL+".PINVOICE"   [PIH2] : Endif
    If !clalev([F:POQ])  Local File =[L]HISAPL+".PORDERQ"    [POQ]  : Endif
    If !clalev([F:PTD])  Local File =[L]HISAPL+".PRECEIPTD"  [PTD]  : Endif
    If !clalev([F:STCR]) Local File =[L]HISAPL+".COSTSTCR"   [STCR] : Endif
    If !clalev([F:SHD])  Local File =[L]HISAPL+".SHIPMENTD"  [SHD]  : Endif
    If !clalev([F:PID2]) Local File =[L]HISAPL+".PINVOICED"  [PID2] : Endif
    If !clalev([F:PID3]) Local File =[L]HISAPL+".PINVOICED"  [PID3] : Endif
    If !clalev([F:PSV])  Local File =[L]HISAPL+".PTDSTKVAL"  [PSV]  : Endif
  #----- Historisation -----#
  Else
    #----- Fichier pour vérifications -----#
    If !clalev([F:PIH2]) Local File =[L]APPLI +".PINVOICE"   [PIH2] : Endif
    #-----
    If !clalev([F:DUD])  Local File =[L]APPLI +".GACCDUDATE" [DUD]  : Endif
    If !clalev([F:PVF])  Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
    If !clalev([F:PVV])  Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
    If !clalev([F:PIV])  Local File =[L]APPLI +".PINVOICEV"  [PIV]  : Endif
    If !clalev([F:PID])  Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
    If !clalev([F:CAL])  Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
    # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
    If !clalev([F:POQ])  Local File =[L]APPLI +".PORDERQ"    [POQ]  : Endif
    If !clalev([F:PTD])  Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
    If !clalev([F:PID2]) Local File =[L]APPLI +".PINVOICED"  [PID2] : Endif
    If !clalev([F:STCR]) Local File =[L]APPLI +".COSTSTCR"   [STCR] : Endif
    # Issue X3-25003 - 2018-03-06 by SR : Valorisation des stocks
    If !clalev([F:SHD])  Local File =[L]APPLI +".SHIPMENTD"  [SHD]  : Endif
    If !clalev([F:PID3]) Local File =[L]APPLI +".PINVOICED"  [PID3] : Endif
    If !clalev([F:PSV])  Local File =[L]APPLI +".PTDSTKVAL"  [PSV]  : Endif
    TABLE="GACCDUDATE" : Gosub CRETAB_HISTO
    If !clalev([F:DUD1]) Local File =[L]HISAPL+".GACCDUDATE" [DUD1] : Endif
    TABLE="PVCRFOOT"   : Gosub CRETAB_HISTO
    If !clalev([F:PVF1]) Local File =[L]HISAPL+".PVCRFOOT"   [PVF1] : Endif
    TABLE="PVCRVAT"    : Gosub CRETAB_HISTO
    If !clalev([F:PVV1]) Local File =[L]HISAPL+".PVCRVAT"    [PVV1] : Endif
    TABLE="CPTANALIN"  : Gosub CRETAB_HISTO
    If !clalev([F:CAL1]) Local File =[L]HISAPL+".CPTANALIN"  [CAL1] : Endif
    # Issue X3-25003 - 2018-03-06 by SR : Valorisation des stocks
    TABLE="PTDSTKVAL"  : Gosub CRETAB_HISTO
    If !clalev([F:PSV1]) Local File =[L]HISAPL+".PTDSTKVAL"  [PSV1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  #----- Fichiers pour vérifications -----#
  If !clalev([F:PIH2])   Local File =[L]APPLI +".PINVOICE"   [PIH2] : Endif
  #-----
  If !clalev([F:DUD])    Local File =[L]APPLI +".GACCDUDATE" [DUD]  : Endif
  If !clalev([F:PVF])    Local File =[L]APPLI +".PVCRFOOT"   [PVF]  : Endif
  If !clalev([F:PVV])    Local File =[L]APPLI +".PVCRVAT"    [PVV]  : Endif
  If !clalev([F:PIV])    Local File =[L]APPLI +".PINVOICEV"  [PIV]  : Endif
  If !clalev([F:PID])    Local File =[L]APPLI +".PINVOICED"  [PID]  : Endif
  If !clalev([F:CAL])    Local File =[L]APPLI +".CPTANALIN"  [CAL]  : Endif
  # Issue 96113 - 2014-06-23 by SR : ajout Landed coast
  If !clalev([F:POQ])    Local File =[L]APPLI +".PORDERQ"    [POQ]  : Endif
  If !clalev([F:PTD])    Local File =[L]APPLI +".PRECEIPTD"  [PTD]  : Endif
  If !clalev([F:PID2])   Local File =[L]APPLI +".PINVOICED"  [PID2] : Endif
  If !clalev([F:STCR])   Local File =[L]APPLI +".COSTSTCR"   [STCR] : Endif
  # Issue X3-25003 - 2018-03-06 by SR : Valorisation des stocks
  If !clalev([F:SHD])    Local File =[L]APPLI +".SHIPMENTD"  [SHD]  : Endif
  If !clalev([F:PID3])   Local File =[L]APPLI +".PINVOICED"  [PID3] : Endif
  If !clalev([F:PSV])    Local File =[L]APPLI +".PTDSTKVAL " [PSV]  : Endif
Endif
Return

#-------------------------------------------------------------------------#
# Suppressions enregistrements tables complémentaires non liées à l'objet #
# ----------------------------------------------------------------------- #
# Suppression textes entête et pied de la table PINVOICE                  #
# Suppression textes détail article de la table PINVOICED                 #
# Historisation et suppression des échéances si pas de module compta      #
#-------------------------------------------------------------------------#
$HISTO_EPURE_PIH
WCLE=[F:F1]NUM : WOK=1
If [L]TRACEDET
  Call ECR_TRACE("*"-mess(1,13,1)-WCLE,0) From GESECRAN
Endif
Gosub VERIF_PIH
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#-----
Read [PIV] PIV0=[F:F1]NUM
If fstat
  Raz [F:PIV]
  Call ECR_TRACE(mess(12,100,1)-"PINVOICEV"-WCLE,1) From GESECRAN
Endif
#----- Historisation-épuration des échéances -----#
Gosub HISTO_EPURE_DUDPIH
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation et épuration des éléments de facturation -----#
[L]WVCRTYP2=8 : Gosub HISTO_EPURE_PVF
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation_épuration des taxes -----#
[L]WVCRTYP=8 : Gosub HISTO_EPURE_PVV
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
#----- Historisation-épuration textes entête et pied -----#
If [F:PIV]TEX1<>""
  WNUMTEX=[F:PIV]TEX1 : WTYP="PIV1" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
If [F:PIV]TEX2<>""
  WNUMTEX=[F:PIV]TEX2 : WTYP="PIV2" : Gosub HISTO_EPURE_TEX
  If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Endif
#----- Historisation-épuration comptes, sections, textes lignes article -----#
Columns [PID] (NUM, PIDLIN, LINTEX)
For [PID] PID0 Where NUM=[F:F1]NUM
  WABRFIC="PID" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
  If [F:PID]LINTEX<>""
    WCLE=[F:F1]NUM-num$([F:PID]PIDLIN)
    WNUMTEX=[F:PID]LINTEX : WTYP="PID1" : Gosub HISTO_EPURE_TEX
    If !WOK  Break : Endif
  Endif
  # Issue X3-25003 - 2018-03-06 by SR : Historisation-Epuration PTDSTKVAL, si besoin
  Filter [F:PSV] Where NUM = [F:PID]NUM & PIDLIN = [F:PID]PIDLIN
  Look [F:PSV]PSV0 First
  Filter [F:PSV]
  If !fstat : Gosub HISTO_EPURE_PSV : Endif
  If !WOK  Break : Endif
Next
Columns [PID]
If !WOK  OKHIS=0 : OKEPU=0 : Return : Endif
Return

#----------------------------------------------------------------------------------#
# Vérifications complémentaires si critères insuffisants (OK=0 pour refuser)       #
# -------------------------------------------------------------------------------- #
# La facture ne peut être purgée que si :                                          #
#  - Tous les montants d'échéance ont été réglés (si module compta présent)        #
#  - Toutes les factures s'y rapportant sont validées (fac compl et avoir)         #
# Si facture "Normale/Avoir sur retour/Avoir sur facture normale"                  #
#  - Des enregistrements se rapportant à une commande liée existent dans COSTSTCR  #
#  - Des enregistrements se rapportant à une réception liée existent dans COSTSTCR #
# Si Facture complémentaire/Avoir sur FCC :                                        #
#  - Des enregistrements s'y rapportant existent dans COSTSTCR                     #
#----------------------------------------------------------------------------------#
$VERIF_PIH
WOK=1
# Issue X3-25003 - 2018-04-05 by SR
#----- Si épuration suite à histo, le contrôle a été fait lors de l'histo -----#
If HISTO & OKEPU  Return : Endif
# End issue X3-25003
#----- Vérification des montants d'échéance si module compta présent -----#
If GMODU(2)=2
  Columns [DUD] (ACCNUM, DUDLIG, FLGCLE)
  For [DUD] DUD6 Where FLGCLE=1 & ACCNUM=[F:F1]ACCNUM
    WMESSAGE=[F:F1]NUM-[F:F1]BPR-num$([F:F1]ACCNUM)-mess(430,197,1)
    WOK=0 : Break
  Next
  Columns [DUD]
Endif
#----- Verification des factures se rapportant à la facture ou avoir -----#
If WOK
  Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI)
  For [PID] PID1 Where TYPORI=4 & NUMORI=[F:F1]NUM
    Read [PIH2] PIH0=[F:PID]NUM
    If !fstat
      If [F:PIH2]STA<>3
        WMESSAGE=[F:F1]NUM-[F:PIH2]PIVTYP-[F:PIH2]NUM-mess(431,197,1)
        WOK=0 : Break
      Endif
    Endif
  Next
  Columns [PID]
Endif
# Issue 96113 - 2014-06-24 by SR : Landed Costs
#------- Pas de Rapprochement en attente sur la réception
If WOK
   # Si FCC ou Avoir : Pas de rapprochement en attente
   If find([F:F1]PIHTYP,2,3)
     Filter [F:STCR] Where NUM = [F:F1]NUM & STCRFLG <> 2
     Look [F:STCR]STCR0 First
     If !fstat
        # Il reste des rapprochements de charge non validés
        WMESSAGE=[F:F1]NUM-mess(831,197,1) : WOK=0
     Endif
     Filter [F:STCR]
   Endif
Endif
#------- Pas de Rapprochement en attente sur les Commandes/Réceptions liées
#------- pour Facture normale ou Avoir sur retour ou Avoir sur facture normale
#--------
If WOK
  If find([F:F1]PIHTYP,1,3,4)
    Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI)
    # Pour toutes les lignes
    For [F:PID]PID0 Where NUM = [F:F1]NUM & NUMORI <> "" & find(TYPORI,1,2,3) & STCNUM <> ""
        Case [F:PID]TYPORI
          When 1
            # Facture sur commande
            Filter [F:STCR] Where TYPORI = 1 & NUMORI = [F:PID]NUMORI & STCRFLG <> 2
            Look [F:STCR]STCR1 First
            If !fstat
                # Il reste des rapprochements de charge non validés
                WMESSAGE=[F:F1]NUM + ":"+ [F:PID]NUMORI-mess(831,197,1) : WOK=0
            Endif
            Filter [F:STCR]
            If WOK = 0 : Break : Endif
            # si commande réceptionnée  , vérifier pour la/les réceptions
            Read [F:POQ]POQ0 = [F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
            If fstat : Raz [F:POQ] : Endif
            If [F:POQ]RCPQTYSTU <> 0
              Filter [F:PTD] Where POHNUM = [F:POQ]POHNUM
              For [F:PTD]PTD0
                  Filter [F:STCR] Where TYPORI = 2 & NUMORI = [F:PTD]PTHNUM & STCRFLG <> 2
                  Look [F:STCR]STCR1 First
                  If !fstat
                      # Il reste des rapprochements de charge non validés
                      WMESSAGE=[F:F1]NUM + ":"+ [F:PTD]PTHNUM-mess(831,197,1) : WOK=0
                  Endif
                  Filter [F:STCR]
                  If WOK = 0 : Break 2 : Endif
              Next
              Filter [F:PTD]
            Endif
          When 2
            # Facture sur réception
            Filter [F:STCR] Where TYPORI = 2 & NUMORI = [F:PID]NUMORI & STCRFLG <> 2
            Look [F:STCR]STCR1 First
            If !fstat
                # Il reste des rapprochements de charge non validés
                WMESSAGE=[F:F1]NUM + ":"+ [F:PID]NUMORI-mess(831,197,1) : WOK=0
            Endif
            Filter [F:STCR]
            If WOK = 0 : Break : Endif
            # si réception sur commande , vérifier pour la commande
            Read [F:PTD]PTD0 = [F:PID]NUMORI;[F:PID]LINORI
            If fstat : Raz [F:PTD] : Endif
            If [F:PTD]POHNUM <> ""
              Filter [F:STCR] Where TYPORI = 1 & NUMORI = [F:PTD]POHNUM & STCRFLG <> 2
              Look [F:STCR]STCR1 First
              If !fstat
                  # Il reste des rapprochements de charge non validés
                  WMESSAGE=[F:F1]NUM + ":"+ [F:PTD]POHNUM-mess(831,197,1) : WOK=0
              Endif
              Filter [F:STCR]
              If WOK = 0 : Break : Endif
            Endif
           When 3
            # Avoir sur facture
              Read [F:PID2]PID0 = [F:PID]NUMORI;[F:PID]LINORI
              If fstat : Raz [F:PID2] : Endif
              # Si Avoir sur facture normale (les avoir sur FCC ont été traités plus haut)
              If [F:PID2]PIHTYP = 1
                Case [F:PID2]TYPORI
                    When 1
                      # Facture sur commande
                      Filter [F:STCR] Where TYPORI = 1 & NUMORI = [F:PID2]NUMORI & STCRFLG <> 2
                      Look [F:STCR]STCR1 First
                      If !fstat
                          # Il reste des rapprochements de charge non validés
                          WMESSAGE=[F:F1]NUM + ":"+ [F:PID2]NUMORI-mess(831,197,1) : WOK=0
                      Endif
                      Filter [F:STCR]
                      If WOK = 0 : Break : Endif
                      # si commande réceptionnée  , vérifier pour la/les réceptions
                      Read [F:POQ]POQ0 = [F:PID2]NUMORI;[F:PID2]LINORI;[F:PID2]SEQORI
                      If fstat : Raz [F:POQ] : Endif
                      If [F:POQ]RCPQTYSTU <> 0
                        Filter [F:PTD] Where POHNUM = [F:POQ]POHNUM
                        For [F:PTD]PTD0
                            Filter [F:STCR] Where TYPORI = 2 & NUMORI = [F:PTD]PTHNUM & STCRFLG <> 2
                            Look [F:STCR]STCR1 First
                            If !fstat
                                # Il reste des rapprochements de charge non validés
                                WMESSAGE=[F:F1]NUM + ":"+ [F:PTD]PTHNUM-mess(831,197,1) : WOK=0
                            Endif
                            Filter [F:STCR]
                            If WOK = 0 : Break 2 : Endif
                        Next
                        Filter [F:PTD]
                      Endif
                    When 2
                      # Facture sur réception
                      Filter [F:STCR] Where TYPORI = 2 & NUMORI = [F:PID2]NUMORI & STCRFLG <> 2
                      Look [F:STCR]STCR1 First
                      If !fstat
                          # Il reste des rapprochements de charge non validés
                          WMESSAGE=[F:F1]NUM + ":"+ [F:PID2]NUMORI-mess(831,197,1) : WOK=0
                      Endif
                      Filter [F:STCR]
                      If WOK = 0 : Break : Endif
                      # si réception sur commande , vérifier pour la commande
                      Read [F:PTD]PTD0 = [F:PID2]NUMORI;[F:PID2]LINORI
                      If fstat : Raz [F:PTD] : Endif
                      If [F:PTD]POHNUM <> ""
                        Filter [F:STCR] Where TYPORI = 1 & NUMORI = [F:PTD]POHNUM & STCRFLG <> 2
                        Look [F:STCR]STCR1 First
                        If !fstat
                            # Il reste des rapprochements de charge non validés
                            WMESSAGE=[F:F1]NUM + ":"+ [F:PTD]POHNUM-mess(831,197,1) : WOK=0
                        Endif
                        Filter [F:STCR]
                        If WOK = 0 : Break : Endif
                      Endif
                    Endcase
              Endif
        Endcase
    Next
  Endif
Endif
# End issue 96113
#----------
# Issue X3-25003 - 2018-03-12 by SR : Si ligne commande à l'origine, alors ligne Commande soldée
If WOK
  Raz [F:POQ]POHNUM
  Columns [PID] (NUM, PIDLIN, TYPORI, NUMORI,LINORI,SEQORI)
  Case [F:F1]PIHTYP :
    When 1 :
      # facture Normale
      # Pour toutes les lignes
      For [F:PID]PID0 Where NUM = [F:F1]NUM & NUMORI <> "" & find(TYPORI,1,2)
       Case [F:PID]TYPORI
        When 1:
          # Facture de commande
          Read [F:POQ]POQ0 =[F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
            If !fstat & [F:POQ]LINCLEFLG <> 2
              WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
            Endif
        When 2 :
          # facture de réception
          Read [F:PTD]PTD0 = [F:PID]NUMORI;[F:PID]LINORI
          If !fstat & [F:PTD]POHNUM <> ""
            Read [F:POQ]POQ0 =[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
            If !fstat & [F:POQ]LINCLEFLG <> 2
              WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
            Endif
          Endif
        Endcase
       Next
    When 2 :
       # FCC
       # aucun enregistrement non rapproché dans PTDSTKVAL
       Filter [F:PSV] Where NUM = [F:F1]NUM & TIAFLG <> 2
       Look [F:PSV]PSV0 First
       If !fstat
          WMESSAGE =[F:F1]NUM + ":"- mess(895,197,1) : WOK = 0
       Else
         # Pour toutes les lignes
         For [F:PID]PID0 Where NUM = [F:F1]NUM & find(TYPORI,1,2,4,6)
           Case [F:PID]TYPORI
             When 1 :
                # FCC sur commande
                Read [F:POQ]POQ0 =[F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
                If !fstat & [F:POQ]LINCLEFLG <> 2
                   WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                Endif
              When 2 :
                # FCC sur réception
                Read [F:PTD]PTD0 = [F:PID]NUMORI;[F:PID]LINORI
                If !fstat & [F:PTD]POHNUM <> ""
                  Read [F:POQ]POQ0 =[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
                  If !fstat & [F:POQ]LINCLEFLG <> 2
                    WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                  Endif
                Endif
               When 4 :
                # FCC Sur facture
                Read [F:PID2]PID0 = [F:PID]NUMORI;[F:PID]LINORI
                If !fstat
                  Case [F:PID2]TYPORI
                    When 1 :
                      # Facture de commande
                      Read [F:POQ]POQ0 =[F:PID2]NUMORI;[F:PID2]LINORI;[F:PID2]SEQORI
                        If !fstat & [F:POQ]LINCLEFLG <> 2
                          WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                        Endif
                    When 2 :
                      # Facture de réception
                      Read [F:PTD]PTD0 = [F:PID2]NUMORI;[F:PID2]LINORI
                      If !fstat & [F:PTD]POHNUM <> ""
                        Read [F:POQ]POQ0 =[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
                        If !fstat  & [F:POQ]LINCLEFLG <> 2
                          WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                        Endif
                      Endif
                   Endcase
                 Endif
               When 6 :
                  # FCC sur Expédition
                  Read [F:SHD]SHD0 = [F:PID]NUMORI;[F:PID]LINORI
                  If !fstat
                    Read [F:POQ]POQ0 = [F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ
                    If !fstat & [F:POQ]LINCLEFLG <> 2
                      WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                    Endif
                  Endif
               Endcase
             Next
       Endif
    When 3 :
       # Avoirs
       # Pour toutes les lignes
       For [F:PID]PID0 Where NUM = [F:F1]NUM
        Read [F:PID2]PID0 = [F:PID]NUMORI;[F:PID]LINORI
        If !fstat
          # Avoir sur FCC  : aucun enregistrement non rapproché dans PRDSTKVAL
          If [F:PID2]PIHTYP = 2
            Filter [F:PSV] Where NUM = [F:F1]NUM & TIAFLG <> 2
            Look [F:PSV]PSV0 First
            If !fstat
              WMESSAGE =[F:F1]NUM + ":"- mess(895,197,1) : WOK = 0 : Break
            Endif
          Endif
          If WOK
            Case [F:PID2]TYPORI :
              When 1 :
                # Avoir sur Facture/FCC sur commande
                Read [F:POQ]POQ0 =[F:PID2]NUMORI;[F:PID2]LINORI;[F:PID2]SEQORI
                If !fstat &  [F:POQ]LINCLEFLG <> 2
                  WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                Endif
              When 2 :
                # Avoir sur facture/FCC sur réception
                Read [F:PTD]PTD0 = [F:PID2]NUMORI;[F:PID2]LINORI
                If !fstat & [F:PTD]POHNUM <> ""
                  Read [F:POQ]POQ0 =[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
                  If !fstat & [F:POQ]LINCLEFLG <> 2
                    WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                  Endif
                Endif
               When 4 :
                  # avoir sur FCC sur facture
                  Read [F:PID3]PID0 = [F:PID2]NUMORI;[F:PID2]LINORI
                  If !fstat
                    Case [F:PID3]TYPORI
                        When 1:
                          # facture de commade
                          Read [F:POQ]POQ0 =[F:PID3]NUMORI;[F:PID3]LINORI;[F:PID3]SEQORI
                            If !fstat & [F:POQ]LINCLEFLG <> 2
                              WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                            Endif
                        When 2 :
                          # facture de réception
                          Read [F:PTD]PTD0 = [F:PID3]NUMORI;[F:PID3]LINORI
                          If !fstat  & [F:PTD]POHNUM <> ""
                            Read [F:POQ]POQ0 =[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
                            If !fstat & [F:POQ]LINCLEFLG <> 2
                              WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0 : Break
                            Endif
                          Endif
                   Endcase
                 Endif
               When 6 :
                # Avoir sur FCC sur Expédition
                Read [F:SHD]SHD0 = [F:PID2]NUMORI;[F:PID2]LINORI
                If !fstat
                  Read [F:POQ]POQ0 =[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ
                  If !fstat & [F:POQ]LINCLEFLG <> 2
                    WMESSAGE =[F:F1]NUM + ":"+[F:POQ]POHNUM-num$([F:POQ]POPLIN) - num$([F:POQ]POQSEQ) - mess(894,197,1) : WOK = 0
                  Endif
                Endif
              Endcase
          Endif
        Endif
       Next
  Endcase
Endif
# End issue X3-25003
#-----
If !WOK
  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
Return

#-----------------------------------------#
# Fermetures des fichiers complémentaires #
#-----------------------------------------#
$FERME_PIH
If clalev([F:PIH2])  Close Local File [PIH2] : Endif
If clalev([F:DUD])   Close Local File [DUD]  : Endif
If clalev([F:PVF])   Close Local File [PVF]  : Endif
If clalev([F:PVV])   Close Local File [PVV]  : Endif
If clalev([F:PIV])   Close Local File [PIV]  : Endif
If clalev([F:PID])   Close Local File [PID]  : Endif
If clalev([F:CAL])   Close Local File [CAL]  : Endif
If clalev([F:DUD1])  Close Local File [DUD1] : Endif
If clalev([F:PVF1])  Close Local File [PVF1] : Endif
If clalev([F:PVV1])  Close Local File [PVV1] : Endif
If clalev([F:CAL1])  Close Local File [CAL1] : Endif
# Issue 96113 - 2014-06-24 by SR : Landed Costs
If clalev([F:STCR])  Close Local File [STCR] : Endif
# Issue X3-25003 - 2018-03-12 by SR : Valorisation réceptions
If clalev([F:SHD])   Close Local File [SHD]  : Endif
If clalev([F:POQ])   Close Local File [POQ]  : Endif
If clalev([F:PTD])   Close Local File [PTD]  : Endif
If clalev([F:PID2])  Close Local File [PID2] : Endif
If clalev([F:PID3])  Close Local File [PID3] : Endif
If clalev([F:PSV])   Close Local File [PSV]  : Endif
If clalev([F:PSV1])  Close Local File [PSV1] : Endif
Return


#---------------------------#
# Déclaration des variables #
#---------------------------#
$DEFVAR
#----- Variables locales -----#
Local Integer WOK
Local Char    WNUMTEX (12), WTYP(4), WMESSAGE(100), WCLE(GLONVCR)
Local Char    NEWTEX(250), OLDTEX(250)
Local Char    WCRITERE(100)
Local Char    WABRFIC(4)
Local Integer WVCRTYP,          WVCRTYP2
Local Char    WVCRNUM(GLONVCR), WVCRNUM2(GLONVCR)
Local Integer WVCRLIN
Local Integer WVCRSEQ
Local Char    WCPLCLE(30)
Local Char    WCLEFIC(50),      WCLEFIC2(50)
# Issue 96113 - 2014-06-23 by SR : Historisation des charges
Local Integer WNUMSEQ
# Issue X3-25003 - 2018-03-19 by SR : Valo des stocke
Local Integer WNB_PSV
Local Integer WEPUR_AFTER_HISTO
Return

#--------------------------------------------------------------------#
# Historisation / Epuration des textes associés aux documents achats #
#--------------------------------------------------------------------#
$HISTO_EPURE_TEX
Return

#--------------------------------------------------------------------#
# Historisation / Epuration des textes associés aux documents ventes #
#--------------------------------------------------------------------#
$HISTO_EPURE_VENTEX
Return

#------------------------------------------------------------------------#
# Historisation / Epuration des éléments de facturation pied de document #
#------------------------------------------------------------------------#
$HISTO_EPURE_PVF
Case [L]WVCRTYP2
  When 3 : [L]WVCRNUM2=[F:F1]POHNUM
  When 5 : [L]WVCRNUM2=[F:F1]POHNUM
  When 6 : [L]WVCRNUM2=[F:F1]PTHNUM
  When 8 : [L]WVCRNUM2=[F:F1]NUM
Endcase
[L]WCLEFIC2=num$([L]WVCRTYP2)-[L]WVCRNUM2
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [PVF] PVF1 Where VCRTYP=[L]WVCRTYP2
&                    & VCRNUM=[L]WVCRNUM2
    #----- Historisation-épuration comptes, sections éléments facturation -----#
    WABRFIC="PVF" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
    #-----
    If ![L]SIMUL
      [F:PVF1] = [F:PVF]
      If dim([F:PVF1]CREHISDAT)>0  [F:PVF1]CREHISDAT=date$    : Endif
      If dim([F:PVF1]CREHISUSR)>0  [F:PVF1]CREHISUSR=[V]GUSER : Endif
      Write [PVF1]
      If fstat
        Call ECR_TRACE("$PVCRFOOT"-[L]WCLEFIC2-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If !WOK  Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [PVF] Where VCRTYP=[L]WVCRTYP2
&                  & VCRNUM=[L]WVCRNUM2
  If fstat
    Call ECR_TRACE("$PVCRFOOT"-[L]WCLEFIC2-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- PVCRFOOT"-[L]WCLEFIC2,0) From GESECRAN
Endif
#-----
Return

#------------------------------------------------------#
# Historisation / Epuration des taxes pied de document #
#------------------------------------------------------#
$HISTO_EPURE_PVV
Case [L]WVCRTYP
  When 3 : [L]WVCRNUM=[F:F1]POHNUM
  When 5 : [L]WVCRNUM=[F:F1]POHNUM
  When 6 : [L]WVCRNUM=[F:F1]PTHNUM
  When 8 : [L]WVCRNUM=[F:F1]NUM
Endcase
[L]WCLEFIC=num$([L]WVCRTYP)-[L]WVCRNUM
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [PVV] PVV1 Where VCRTYP=[L]WVCRTYP
&                    & VCRNUM=[L]WVCRNUM
    If ![L]SIMUL
      [F:PVV1] = [F:PVV]
      If dim([F:PVV1]CREHISDAT)>0  [F:PVV1]CREHISDAT=date$    : Endif
      If dim([F:PVV1]CREHISUSR)>0  [F:PVV1]CREHISUSR=[V]GUSER : Endif
      Write [PVV1]
      If fstat
        Call ECR_TRACE("$PVCRVAT"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If !WOK  Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [PVV] Where VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
  If fstat
    Call ECR_TRACE("$PVCRVAT"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- PVCRVAT"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return

#--------------------------------------------------------------------------------#
# Historisation / Epuration des comptes et sections associés aux lignes document #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_CAL
#-----
Raz [L]WVCRTYP, [L]WVCRNUM, [L]WVCRLIN, [L]WVCRSEQ, [L]WCPLCLE
#-----
Case WABRFIC
  When "PQD" : [L]WVCRNUM=[F:PQD]PQHNUM : [L]WVCRLIN=[F:PQD]PQDLIN
  When "PSD" : [L]WVCRNUM=[F:PSD]PSHNUM : [L]WVCRLIN=[F:PSD]PSDLIN
  When "POP" : [L]WVCRNUM=[F:POP]POHNUM : [L]WVCRLIN=[F:POP]POPLIN
               [L]WVCRSEQ=[F:POP]POPSEQ
  When "UOP" : [L]WVCRNUM=[F:UOP]POHNUM : [L]WVCRLIN=[F:UOP]POPLIN
               [L]WVCRSEQ=[F:UOP]POPSEQ : [L]WCPLCLE=num$([F:UOP]LINREVNUM)
  When "PTD" : [L]WVCRNUM=[F:PTD]PTHNUM : [L]WVCRLIN=[F:PTD]PTDLIN
  When "PND" : [L]WVCRNUM=[F:PND]PNHNUM : [L]WVCRLIN=[F:PND]PNDLIN
  When "PID" : [L]WVCRNUM=[F:PID]NUM    : [L]WVCRLIN=[F:PID]PIDLIN
  When "PVF" : [L]WVCRTYP=[F:PVF]VCRTYP : [L]WVCRNUM=[F:PVF]VCRNUM
               [L]WVCRSEQ=[F:PVF]IND
  When "SOP" : [L]WVCRNUM=[F:SOP]SOHNUM : [L]WVCRLIN=[F:SOP]SOPLIN
               [L]WVCRSEQ=[F:SOP]SOPSEQ
  When "VOP" : [L]WVCRNUM=[F:VOP]SOHNUM : [L]WVCRLIN=[F:VOP]SOPLIN
               [L]WVCRSEQ=[F:VOP]SOPSEQ : [L]WCPLCLE=num$([F:VOP]LINREVNUM)
  When "SVF" : [L]WVCRTYP=[F:SVF]VCRTYP : [L]WVCRNUM=[F:SVF]VCRNUM
               [L]WVCRSEQ=[F:SVF]DTA
Endcase
[L]WCLEFIC=[L]WABRFIC-num$([L]WVCRTYP)-[L]WVCRNUM-num$([L]WVCRLIN)-num$([L]WVCRSEQ)-[L]WCPLCLE
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  Read [CAL] CAL0=[L]WABRFIC;[L]WVCRTYP;[L]WVCRNUM;[L]WVCRLIN;[L]WVCRSEQ;[L]WCPLCLE;1
  If !fstat & ![L]SIMUL
    [F:CAL1]=[F:CAL]
    If dim([F:CAL1]CREHISDAT)>0  [F:CAL1]CREHISDAT=date$    : Endif
    If dim([F:CAL1]CREHISUSR)>0  [F:CAL1]CREHISUSR=[V]GUSER : Endif
    Write [CAL1]
    If fstat
      Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
      WOK=0 : Return
    Endif
  Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [CAL] Where ABRFIC=[L]WABRFIC
&                  & VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
&                  & VCRLIN=[L]WVCRLIN
&                  & VCRSEQ=[L]WVCRSEQ
&                  & CPLCLE=[L]WCPLCLE
&                  & ANALIG=1
  If fstat
    Call ECR_TRACE("$CPTANALIN"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- CPTANALIN"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return

#-------------------------------------------------#
# Historisation-épuration des échéances commandes #
#-------------------------------------------------#
$HISTO_EPURE_DUDPOH
If GMODU(2)=2
  [L]WCRITERE='TYP="*PO" & NUM=WCLE & FLGCLE=2'
Else
  [L]WCRITERE='TYP="*PO" & NUM=WCLE'
Endif
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [DUD] Where evalue(WCRITERE)
    [F:DUD1] = [F:DUD]
    If dim([F:DUD1]CREHISDAT)>0  [F:DUD1]CREHISDAT=date$    : Endif
    If dim([F:DUD1]CREHISUSR)>0  [F:DUD1]CREHISUSR=[V]GUSER : Endif
    If ![L]SIMUL
      Write [DUD1]
      If fstat
        Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If !WOK  Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [DUD] Where evalue(WCRITERE)
  If fstat=1
    Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- GACCDUDATE"-WCLE,0) From GESECRAN
Endif
#-----
Return

#------------------------------------------------#
# Historisation-épuration des échéances factures #
#------------------------------------------------#
$HISTO_EPURE_DUDPIH
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [DUD] DUD1 Where ACCNUM=[F:F1]ACCNUM
    [F:DUD1] = [F:DUD]
    If dim([F:DUD1]CREHISDAT)>0  [F:DUD1]CREHISDAT=date$    : Endif
    If dim([F:DUD1]CREHISUSR)>0  [F:DUD1]CREHISUSR=[V]GUSER : Endif
    If ![L]SIMUL
      Write [DUD1]
      If fstat
        Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(13,100,1),1) From GESECRAN
        WOK=0 :  Break
      Endif
    Endif
  Next
  If !WOK  Return : Endif
Endif
#----- Suppression des échéances -----#
If ![L]SIMUL
  Delete [DUD] Where ACCNUM=[F:F1]ACCNUM
  If fstat=1
    Call ECR_TRACE("$GACCDUDATE"-WCLE-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- GACCDUDATE"-WCLE,0) From GESECRAN
Endif
#-----
Return

# Issue 96113 - 2014-06-23 by SR : Landed costs
#--------------------------------------------------------------------------------#
# Historisation / Epuration charges associés aux lignes document                 #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_STCD
#-----
[L]WCLEFIC=[L]WABRFIC-num$([L]WVCRTYP)-[L]WVCRNUM-num$([L]WVCRLIN)-num$([L]WVCRSEQ)
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [STCD] STCD0 Where VCRTYP=[L]WVCRTYP & VCRNUM=[L]WVCRNUM & VCRLIN=[L]WVCRLIN & VCRSEQ=[L]WVCRSEQ
    If !fstat & ![L]SIMUL
     [L]WCLEFIC+=num$([L]WNUMSEQ)
      [F:STC1]=[F:STCD]
      If dim([F:STC1]CREHISDAT)>0  [F:STC1]CREHISDAT=date$    : Endif
      If dim([F:STC1]CREHISUSR)>0  [F:STC1]CREHISUSR=[V]GUSER : Endif
      Write [STC1]
      If fstat
        Call ECR_TRACE("$COSTSTCD"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If WOK = 0 : Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [STCD] Where VCRTYP=[L]WVCRTYP
&                   & VCRNUM=[L]WVCRNUM
&                   & VCRLIN=[L]WVCRLIN
&                   & VCRSEQ=[L]WVCRSEQ
  If fstat
    Call ECR_TRACE("$COSTSTCD"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- COSTSTCD"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return
# End issue 96113

# Issue X3-25003 - 2018-03-06 by SR : PTDSTKVAL
#--------------------------------------------------------------------------------#
# Historisation / Epuration enregistrements de régularisation de la valo stock   #
#--------------------------------------------------------------------------------#
$HISTO_EPURE_PSV
Raz [L]WVCRNUM, [L]WVCRLIN, WNB_PSV
#-----
[L]WVCRNUM=[F:PID]NUM : [L]WVCRLIN=[F:PID]PIDLIN
[L]WCLEFIC=[L]WVCRNUM-num$([L]WVCRLIN)
# En simutation, on indique juste qu'on aura au moins un enregistrement à Historiser/Epurer
If [L]SIMUL
   Filter [F:PSV] Where NUM = WVCRNUM & PIDLIN = WVCRLIN
   Look [F:PSV]PSV0 First
   If !fstat : WNB_PSV = 1 : Endif
   Filter [F:PSV]
Endif
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [PSV] PSV0 Where NUM=[L]WVCRNUM & PIDLIN=[L]WVCRLIN
    WNB_PSV += 1
    If !fstat & ![L]SIMUL
      [L]WCLEFIC+=[F:PSV]PTHNUM- num$([F:PSV]PTDLIN)
      [F:PSV1]=[F:PSV]
      If dim([F:PSV1]CREHISDAT)>0  [F:PSV1]CREHISDAT=date$    : Endif
      If dim([F:PSV1]CREHISUSR)>0  [F:PSV1]CREHISUSR=[V]GUSER : Endif
      Write [PSV1]
      If fstat
        Call ECR_TRACE("$PTDSTKVAL"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If WOK = 0 : Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [PSV] Where NUM=[L]WVCRNUM
&                  & PIDLIN=[L]WVCRLIN
  If fstat
    Call ECR_TRACE("$PTDSTKVAL"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET & WNB_PSV <> 0
  Call ECR_TRACE("-- PTDSTKVAL"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return

#---------------------------------------------------------#
# Création des tables historiques non liées si nécessaire #
#---------------------------------------------------------#
$CRETAB_HISTO
WOK=0
# Issue 102572 - 2014-09-15 by SR : fde instead of FDE
If filinfo(filpath("FIL",TABLE,"fde",HISAPL),0)<0
  WOK=1
Else
  # Issue 102572 - 2014-09-15 by SR : WOK instead of OK
  Call VUE_OK(TABLE,HISAPL,"FIL",WOK) From DOSVUE
Endif
If WOK
  Call CRETABLE(APPLI,HISAPL,TYPDBA,TABLE,COEFF,0) From CREHISTO
Endif
WOK=1
Return


#-------------------------------#
# Ouverture des fichiers ventes #
#-------------------------------#
$OUVRE_VEN
If GMODU(5)<>2  Return : Endif : # Module ventes actif
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR
If OKHIS
  #----- Epuration après historisation -----#
  If OKEPU
    If !clalev([F:SOH])  Local File =[L]HISAPL+".SORDER"     [SOH]  : Endif
    If !clalev([F:SVF])  Local File =[L]HISAPL+".SVCRFOOT"   [SVF]  : Endif
    If !clalev([F:SVV])  Local File =[L]HISAPL+".SVCRVAT"    [SVV]  : Endif
    If !clalev([F:SOC])  Local File =[L]HISAPL+".SORDERC"    [SOC]  : Endif
    If !clalev([F:SOQ])  Local File =[L]HISAPL+".SORDERQ"    [SOQ]  : Endif
    If !clalev([F:SOP])  Local File =[L]HISAPL+".SORDERP"    [SOP]  : Endif
    If !clalev([F:VOH])  Local File =[L]HISAPL+".VSORDER"    [VOH]  : Endif
    If !clalev([F:VOC])  Local File =[L]HISAPL+".VSORDERC"   [VOC]  : Endif
    If !clalev([F:VOQ])  Local File =[L]HISAPL+".VSORDERQ"   [VOQ]  : Endif
    If !clalev([F:VOP])  Local File =[L]HISAPL+".VSORDERP"   [VOP]  : Endif
    # Issue X3-25003 - 2018-03-23 by SR : Ouverture tables nécessaire
    If !clalev([F:SDD])  Local File =[L]HISAPL+".SDELIVERYD" [SDD]  : Endif
  #----- Historisation -----#
  Else
    #----- Fichiers pour vérifications -----#
    If !clalev([F:SDD])  Local File =[L]APPLI +".SDELIVERYD" [SDD]  : Endif
    #----- Fichiers pour suppression et historisation (commandes de vente) -----#
    If !clalev([F:SOH])  Local File =[L]APPLI +".SORDER"     [SOH]  : Endif
    If !clalev([F:SVF])  Local File =[L]APPLI +".SVCRFOOT"   [SVF]  : Endif
    If !clalev([F:SVV])  Local File =[L]APPLI +".SVCRVAT"    [SVV]  : Endif
    If !clalev([F:SOC])  Local File =[L]APPLI +".SORDERC"    [SOC]  : Endif
    If !clalev([F:SOQ])  Local File =[L]APPLI +".SORDERQ"    [SOQ]  : Endif
    If !clalev([F:SOP])  Local File =[L]APPLI +".SORDERP"    [SOP]  : Endif
    If !clalev([F:VOH])  Local File =[L]APPLI +".VSORDER"    [VOH]  : Endif
    If !clalev([F:VOC])  Local File =[L]APPLI +".VSORDERC"   [VOC]  : Endif
    If !clalev([F:VOQ])  Local File =[L]APPLI +".VSORDERQ"   [VOQ]  : Endif
    If !clalev([F:VOP])  Local File =[L]APPLI +".VSORDERP"   [VOP]  : Endif
    #-----
    TABLE="SORDER"     : Gosub CRETAB_HISTO
    If !clalev([F:SOH1]) Local File =[L]HISAPL+".SORDER"     [SOH1] : Endif
    TABLE="SVCRFOOT"   : Gosub CRETAB_HISTO
    If !clalev([F:SVF1]) Local File =[L]HISAPL+".SVCRFOOT"   [SVF1] : Endif
    TABLE="SVCRVAT"    : Gosub CRETAB_HISTO
    If !clalev([F:SVV1]) Local File =[L]HISAPL+".SVCRVAT"    [SVV1] : Endif
    TABLE="SORDERC"    : Gosub CRETAB_HISTO
    If !clalev([F:SOC1]) Local File =[L]HISAPL+".SORDERC"    [SOC1] : Endif
    TABLE="SORDERQ"    : Gosub CRETAB_HISTO
    If !clalev([F:SOQ1]) Local File =[L]HISAPL+".SORDERQ"    [SOQ1] : Endif
    TABLE="SORDERP"    : Gosub CRETAB_HISTO
    If !clalev([F:SOP1]) Local File =[L]HISAPL+".SORDERP"    [SOP1] : Endif
    TABLE="VSORDER"    : Gosub CRETAB_HISTO
    If !clalev([F:VOH1]) Local File =[L]HISAPL+".VSORDER"    [VOH1] : Endif
    TABLE="VSORDERC"   : Gosub CRETAB_HISTO
    If !clalev([F:VOC1]) Local File =[L]HISAPL+".VSORDERC"   [VOC1] : Endif
    TABLE="VSORDERQ"   : Gosub CRETAB_HISTO
    If !clalev([F:VOQ1]) Local File =[L]HISAPL+".VSORDERQ"   [VOQ1] : Endif
    TABLE="VSORDERP"   : Gosub CRETAB_HISTO
    If !clalev([F:VOP1]) Local File =[L]HISAPL+".VSORDERP"   [VOP1] : Endif
  Endif
#----- Epuration sans historisation -----#
Else
  #----- Fichiers pour vérifications -----#
  If !clalev([F:SDD])    Local File =[L]APPLI +".SDELIVERYD" [SDD]  : Endif
  #-----
  If !clalev([F:SOH])    Local File =[L]APPLI +".SORDER"     [SOH]  : Endif
  If !clalev([F:SVF])    Local File =[L]APPLI +".SVCRFOOT"   [SVF]  : Endif
  If !clalev([F:SVV])    Local File =[L]APPLI +".SVCRVAT"    [SVV]  : Endif
  If !clalev([F:SOC])    Local File =[L]APPLI +".SORDERC"    [SOC]  : Endif
  If !clalev([F:SOQ])    Local File =[L]APPLI +".SORDERQ"    [SOQ]  : Endif
  If !clalev([F:SOP])    Local File =[L]APPLI +".SORDERP"    [SOP]  : Endif
  If !clalev([F:VOH])    Local File =[L]APPLI +".VSORDER"    [VOH]  : Endif
  If !clalev([F:VOC])    Local File =[L]APPLI +".VSORDERC"   [VOC]  : Endif
  If !clalev([F:VOQ])    Local File =[L]APPLI +".VSORDERQ"   [VOQ]  : Endif
  If !clalev([F:VOP])    Local File =[L]APPLI +".VSORDERP"   [VOP]  : Endif
Endif
Return

#-------------------------------------------------------------#
# Si inter-sites, vérification DL ou commandes ventes soldées #
#-------------------------------------------------------------#
$VERIF_VEN
WOK=1
#----- Si inter-sites, vérification que toutes les DL ventes sont soldées -----#
Columns [SOQ] (SOHNUM, SOPLIN, SOQSEQ, SOQSTA)
For [SOQ] SOQ0 Where SOHNUM=[F:F1]OCNNUM
  If [F:SOQ]SOQSTA<>3
    WMESSAGE =[F:F1]POHNUM-[F:F1]OCNNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
    WMESSAGE-=-mess(432,197,1)
    WOK=0 : Break
  Endif
Next
Columns [SOQ]
#----- Si inter-sites, vérification livraisons ventes réceptionnées -----#
If WOK
  Columns [SDD] (SDHNUM, SDDLIN, RCPFLG)
    For [SDD] SDD1 Where SOHNUM=[F:F1]OCNNUM
      If [F:SDD]RCPFLG<>2
        WMESSAGE =[F:F1]OCNNUM-[F:SDD]SDHNUM-num$([F:SDD]SDDLIN)
        WMESSAGE-=mess(436,197,1)
        WOK=0 : Break
      Endif
    Next
  Columns [SDD]
Endif
#-----
If !WOK
  Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
Return

$HISTO_EPURE_VEN
#-----------------------------------------#
# Historisation-épuration commande ventes #
# Pour l'inter-sites et l'inter-sociétés  #
#-----------------------------------------#
WOK=1
Read [SOH] SOH0=[F:F1]OCNNUM
If !WOK  Return : Endif
#----- Historisation-épuration des échéances -----#
If [F:AHI]COD="POH"
  Gosub HISTO_EPURE_DUDSOH : If !WOK  Return : Endif
Endif
#----- Historisation et épuration des éléments de facturation -----#
Gosub HISTO_EPURE_SVF
If !WOK  Return : Endif
#----- Historisation_épuration des taxes -----#
Gosub HISTO_EPURE_SVV
If !WOK  Return : Endif
#----- Historisation-épuration textes entête et pied commande vente -----#
WCLE=[F:F1]OCNNUM
If [F:SOH]SOHTEX1<>""
  WNUMTEX=[F:SOH]SOHTEX1 : WTYP="SOH1" : Gosub HISTO_EPURE_VENTEX
  If !WOK  Return : Endif
Endif
If [F:SOH]SOHTEX2<>""
  WNUMTEX=[F:SOH]SOHTEX2 : WTYP="SOH2" : Gosub HISTO_EPURE_VENTEX
  If !WOK  Return : Endif
Endif
#----- Historisation-épuratin textes lignes article contrat vente -----#
If [F:AHI]COD="POC"
  Columns [SOC] (SOHNUM, SOPLIN, SOCTEX)
  For [SOC] SOC0 Where SOHNUM=[F:F1]OCNNUM
    If [F:SOC]SOCTEX<>""
      WCLE=[F:F1]OCNNUM-num$([F:SOC]SOPLIN)
      WNUMTEX=[F:SOC]SOCTEX : WTYP="SOC1" : Gosub HISTO_EPURE_VENTEX
      If !WOK  Break : Endif
    Endif
  Next
  Columns [SOC]
  If !WOK  Return : Endif
Endif
#----- Historisation-épuration textes lignes article vente -----#
Columns [SOQ] (SOHNUM, SOPLIN, SOQSEQ, SOQTEX)
For [SOQ] SOQ0 Where SOHNUM=[F:F1]OCNNUM
  If [F:SOQ]SOQTEX<>""
    WCLE=[F:F1]OCNNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)
    WNUMTEX=[F:SOQ]SOQTEX : WTYP="SOQ1" : Gosub HISTO_EPURE_VENTEX
    If !WOK  Break : Endif
  Endif
Next
Columns [SOQ]
If !WOK  Return : Endif
#----- Historisation-épuration comptes et sections lignes commande -----#
Columns [SOP] (SOHNUM, SOPLIN, SOPSEQ)
For [SOP] SOP0 Where SOHNUM=[F:F1]OCNNUM
  WABRFIC="SOP" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
Next
Columns [SOP]
If !WOK  Return : Endif
#----- Historisation-épuration comptes et sections lignes avenants commande -----#
Columns [VOP] (SOHNUM, SOPLIN, SOPSEQ)
For [VOP] VOP0 Where SOHNUM=[F:F1]OCNNUM
  WABRFIC="VOP" : Gosub HISTO_EPURE_CAL
  If !WOK  Break : Endif
Next
Columns [VOP]
If !WOK  Return : Endif
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR
#If OKHIS & ![L]SIMUL
If OKHIS & OKEPU=0 & ![L]SIMUL
  #-----
  [F:SOH1] = [F:SOH]
  If dim([F:SOH1]CREHISDAT)>0  [F:SOH1]CREHISDAT=date$    : Endif
  If dim([F:SOH1]CREHISUSR)>0  [F:SOH1]CREHISUSR=[V]GUSER : Endif
  Write [SOH1]
  If fstat
    Call ECR_TRACE("$SORDER"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
  #-----
  If [F:AHI]COD="POC"
    For [SOC] SOC0 Where SOHNUM=[F:F1]OCNNUM
      [F:SOC1] = [F:SOC]
      If dim([F:SOC1]CREHISDAT)>0  [F:SOC1]CREHISDAT=date$    : Endif
      If dim([F:SOC1]CREHISUSR)>0  [F:SOC1]CREHISUSR=[V]GUSER : Endif
      Write [SOC1]
      If fstat
        Call ECR_TRACE("$SORDERC"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Next
    If !WOK  Return : Endif
  Endif
  #-----
  For [SOQ] SOQ0 Where SOHNUM=[F:F1]OCNNUM
    [F:SOQ1] = [F:SOQ]
    If dim([F:SOQ1]CREHISDAT)>0  [F:SOQ1]CREHISDAT=date$    : Endif
    If dim([F:SOQ1]CREHISUSR)>0  [F:SOQ1]CREHISUSR=[V]GUSER : Endif
    Write [SOQ1]
    If fstat
      Call ECR_TRACE("$SORDERQ"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
      WOK=0 : Break
    Endif
  Next
  If !WOK  Return : Endif
  #-----
  For [SOP] SOP0 Where SOHNUM=[F:F1]OCNNUM
    [F:SOP1] = [F:SOP]
    If dim([F:SOP1]CREHISDAT)>0  [F:SOP1]CREHISDAT=date$    : Endif
    If dim([F:SOP1]CREHISUSR)>0  [F:SOP1]CREHISUSR=[V]GUSER : Endif
    Write [SOP1]
    If fstat
      Call ECR_TRACE("$SORDERP"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
      WOK=0 : Break
    Endif
  Next
  If !WOK  Return : Endif
  #-----
  For [VOH] VOH0 Where SOHNUM=[F:F1]OCNNUM
    [F:VOH1] = [F:VOH]
    If dim([F:VOH1]CREHISDAT)>0  [F:VOH1]CREHISDAT=date$    : Endif
    If dim([F:VOH1]CREHISUSR)>0  [F:VOH1]CREHISUSR=[V]GUSER : Endif
    Write [VOH1]
    If fstat
      Call ECR_TRACE("$VSORDER"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
      WOK=0 : Break
    Endif
  Next
  If !WOK  Return : Endif
  #-----
  If [F:AHI]COD="POC"
    For [VOC] VOC0 Where SOHNUM=[F:F1]OCNNUM
      [F:VOC1] = [F:VOC]
      If dim([F:VOC1]CREHISDAT)>0  [F:VOC1]CREHISDAT=date$    : Endif
      If dim([F:VOC1]CREHISUSR)>0  [F:VOC1]CREHISUSR=[V]GUSER : Endif
      Write [VOC1]
      If fstat
        Call ECR_TRACE("$VSORDERC"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Next
    If !WOK  Return : Endif
  Endif
  #-----
  For [VOQ] VOQ0 Where SOHNUM=[F:F1]OCNNUM
    [F:VOQ1] = [F:VOQ]
    If dim([F:VOQ1]CREHISDAT)>0  [F:VOQ1]CREHISDAT=date$    : Endif
    If dim([F:VOQ1]CREHISUSR)>0  [F:VOQ1]CREHISUSR=[V]GUSER : Endif
    Write [VOQ1]
    If fstat
      Call ECR_TRACE("$VSORDERQ"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
      WOK=0 : Break
    Endif
  Next
  If !WOK  Return : Endif
  #-----
  For [VOP] VOP0 Where SOHNUM=[F:F1]OCNNUM
    [F:VOP1] = [F:VOP]
    If dim([F:VOP1]CREHISDAT)>0  [F:VOP1]CREHISDAT=date$    : Endif
    If dim([F:VOP1]CREHISUSR)>0  [F:VOP1]CREHISUSR=[V]GUSER : Endif
    Write [SOP1]
    If fstat
      Call ECR_TRACE("$VSORDERP"-[F:F1]OCNNUM-mess(13,100,1),1) From GESECRAN
      WOK=0 : Break
    Endif
  Next
  If !WOK  Return : Endif
  #-----
Endif
#----- Suppression entête commande de vente -----#
If ![L]SIMUL
  Delete [SOH] Where SOHNUM=[F:F1]OCNNUM
  If fstat
    Call ECR_TRACE("$SORDER"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
If [L]TRACEDET
  WMESSAGE="[SOH]"-[F:F1]OCNNUM-mess(411,197,1)
  Call ECR_TRACE (WMESSAGE,0) From GESECRAN
Endif
#----- Suppression lignes article contrat de vente -----#
If [F:AHI]COD="POC"
  If ![L]SIMUL
    Delete [SOC] Where SOHNUM=[F:F1]OCNNUM
    If fstat
      Call ECR_TRACE("$SORDERC"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
      WOK=0 : Return
    Endif
  Endif
  If [L]TRACEDET
    WMESSAGE="[SOC]"-[F:F1]OCNNUM-mess(429,197,1)
    Call ECR_TRACE (WMESSAGE,0) From GESECRAN
  Endif
Endif
#----- Suppression lignes détail quantité commande de vente -----#
If ![L]SIMUL
  Delete [SOQ] Where SOHNUM=[F:F1]OCNNUM
  If fstat
    Call ECR_TRACE("$SORDERQ"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
If [L]TRACEDET
  WMESSAGE="[SOQ]"-[F:F1]OCNNUM-mess(429,197,1)
  Call ECR_TRACE (WMESSAGE,0) From GESECRAN
Endif
#----- Suppression lignes détail prix commande de vente -----#
If ![L]SIMUL
  Delete [SOP] Where SOHNUM=[F:F1]OCNNUM
  If fstat=1
    Call ECR_TRACE("$SORDERP"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
If [L]TRACEDET
  WMESSAGE="[SOP]"-[F:F1]OCNNUM-mess(429,197,1)
  Call ECR_TRACE (WMESSAGE,0) From GESECRAN
Endif
#----- Suppression historique entête commande de vente -----#
If ![L]SIMUL
  Delete [VOH] Where SOHNUM=[F:F1]OCNNUM
  If fstat
    Call ECR_TRACE("$VSORDER"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
If [L]TRACEDET
  WMESSAGE="[VOH]"-[F:F1]OCNNUM-mess(411,197,1)
  Call ECR_TRACE (WMESSAGE,0) From GESECRAN
Endif
#----- Suppression historique lignes article contrat de vente -----#
If [F:AHI]COD="POC"
  If ![L]SIMUL
    Delete [VOC] Where SOHNUM=[F:F1]OCNNUM
    If fstat
      Call ECR_TRACE("$VSORDERC"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
      WOK=0 : Return
    Endif
  Endif
  If [L]TRACEDET
    WMESSAGE="[VOC]"-[F:F1]OCNNUM-mess(429,197,1)
    Call ECR_TRACE (WMESSAGE,0) From GESECRAN
  Endif
Endif
#----- Suppression historique lignes détail quantité commande de vente -----#
If ![L]SIMUL
  Delete [VOQ] Where SOHNUM=[F:F1]OCNNUM
  If fstat
    Call ECR_TRACE("$VSORDERQ"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
If [L]TRACEDET
  WMESSAGE="[VOQ]"-[F:F1]OCNNUM-mess(429,197,1)
  Call ECR_TRACE (WMESSAGE,0) From GESECRAN
Endif
#----- Suppression historique lignes détail prix commande de vente -----#
If ![L]SIMUL
  Delete [VOP] Where SOHNUM=[F:F1]OCNNUM
  If fstat=1
    Call ECR_TRACE("$VSORDERP"-[F:F1]OCNNUM-mess(10,100,1),1) From GESECRAN
  Endif
Endif
If [L]TRACEDET
  WMESSAGE="[VOP]"-[F:F1]OCNNUM-mess(429,197,1)
  Call ECR_TRACE (WMESSAGE,0) From GESECRAN
Endif
Return

$FERME_VEN
#-------------------------------#
# Fermeture des fichiers ventes #
#-------------------------------#
If clalev([F:SDD])   Close Local File [SDD]  : Endif
If clalev([F:SOH])   Close Local File [SOH]  : Endif
If clalev([F:SVF])   Close Local File [SVF]  : Endif
If clalev([F:SVV])   Close Local File [SVV]  : Endif
If clalev([F:SOC])   Close Local File [SOC]  : Endif
If clalev([F:SOQ])   Close Local File [SOQ]  : Endif
If clalev([F:SOP])   Close Local File [SOP]  : Endif
If clalev([F:VOH])   Close Local File [VOH]  : Endif
If clalev([F:VOC])   Close Local File [VOC]  : Endif
If clalev([F:VOQ])   Close Local File [VOQ]  : Endif
If clalev([F:VOP])   Close Local File [VOP]  : Endif
If clalev([F:SOH1])  Close Local File [SOH1] : Endif
If clalev([F:SVF1])  Close Local File [SVF1] : Endif
If clalev([F:SVV1])  Close Local File [SVV1] : Endif
If clalev([F:SOC1])  Close Local File [SOC1] : Endif
If clalev([F:SOQ1])  Close Local File [SOQ1] : Endif
If clalev([F:SOP1])  Close Local File [SOP1] : Endif
If clalev([F:VOH1])  Close Local File [VOH1] : Endif
If clalev([F:VOC1])  Close Local File [VOC1] : Endif
If clalev([F:VOQ1])  Close Local File [VOQ1] : Endif
If clalev([F:VOP1])  Close Local File [VOP1] : Endif
#-----
Return

#-----------------------------------------------------------------------#
# Historisation / Epuration des éléments de facturation commande ventes #
#-----------------------------------------------------------------------#
$HISTO_EPURE_SVF
[L]WVCRTYP2=[F:SOH]SOHCAT+9
[L]WVCRNUM2=[F:SOH]SOHNUM
[L]WCLEFIC2=num$([L]WVCRTYP2)-[L]WVCRNUM2
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [SVF] SVF1 Where VCRTYP=[L]WVCRTYP2
&                    & VCRNUM=[L]WVCRNUM2
    #----- Historisation-épuration comptes, sections éléments facturation -----#
    WABRFIC="SVF" : Gosub HISTO_EPURE_CAL
    If !WOK  Break : Endif
    #-----
    If ![L]SIMUL
      [F:SVF1] = [F:SVF]
      If dim([F:SVF1]CREHISDAT)>0  [F:SVF1]CREHISDAT=date$    : Endif
      If dim([F:SVF1]CREHISUSR)>0  [F:SVF1]CREHISUSR=[V]GUSER : Endif
      Write [SVF1]
      If fstat
        Call ECR_TRACE("$SVCRFOOT"-[L]WCLEFIC2-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If !WOK  Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [SVF] Where VCRTYP=[L]WVCRTYP2
&                  & VCRNUM=[L]WVCRNUM2
  If fstat
    Call ECR_TRACE("$SVCRFOOT"-[L]WCLEFIC2-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- SVCRFOOT"-[L]WCLEFIC2,0) From GESECRAN
Endif
#-----
Return

#-------------------------------------------------------------#
# Historisation / Epuration des taxes pied de commande ventes #
#-------------------------------------------------------------#
$HISTO_EPURE_SVV
[L]WVCRTYP=[F:SOH]SOHCAT+9
[L]WVCRNUM=[F:SOH]SOHNUM
[L]WCLEFIC=num$([L]WVCRTYP)-[L]WVCRNUM
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [SVV] SVV1 Where VCRTYP=[L]WVCRTYP
&                    & VCRNUM=[L]WVCRNUM
    If ![L]SIMUL
      [F:SVV1] = [F:SVV]
      If dim([F:SVV1]CREHISDAT)>0  [F:SVV1]CREHISDAT=date$    : Endif
      If dim([F:SVV1]CREHISUSR)>0  [F:SVV1]CREHISUSR=[V]GUSER : Endif
      Write [SVV1]
      If fstat
        Call ECR_TRACE("$SVCRVAT"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If !WOK  Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [SVV] Where VCRTYP=[L]WVCRTYP
&                  & VCRNUM=[L]WVCRNUM
  If fstat
    Call ECR_TRACE("$SVCRVAT"-[L]WCLEFIC-mess(13,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- SVCRVAT"-[L]WCLEFIC,0) From GESECRAN
Endif
#-----
Return

#--------------------------------------------------------#
# Historisation-épuration des échéances commandes ventes #
#--------------------------------------------------------#
$HISTO_EPURE_DUDSOH
If GMODU(2)=2
  [L]WCRITERE='TYP="*SO" & NUM=[F:SOH]SOHNUM & FLGCLE=2'
Else
  [L]WCRITERE='TYP="*SO" & NUM=[F:SOH]SOHNUM'
Endif
#----- Historisation -----#
# Issue X3-25003 - 2018-04-05 by SR : Phase d'historisation
If OKHIS & OKEPU=0
  For [DUD] Where evalue(WCRITERE)
    [F:DUD1] = [F:DUD]
    If dim([F:DUD1]CREHISDAT)>0  [F:DUD1]CREHISDAT=date$    : Endif
    If dim([F:DUD1]CREHISUSR)>0  [F:DUD1]CREHISUSR=[V]GUSER : Endif
    If ![L]SIMUL
      Write [DUD1]
      If fstat
        Call ECR_TRACE("$GACCDUDATE"-[F:SOH]SOHNUM-mess(13,100,1),1) From GESECRAN
        WOK=0 : Break
      Endif
    Endif
  Next
  If !WOK  Return : Endif
Endif
#----- Epuration -----#
If ![L]SIMUL
  Delete [DUD] Where evalue(WCRITERE)
  If fstat=1
    Call ECR_TRACE("$GACCDUDATE"-[F:SOH]SOHNUM-mess(10,100,1),1) From GESECRAN
    WOK=0 : Return
  Endif
Endif
#-----
If [L]TRACEDET
  Call ECR_TRACE("-- GACCDUDATE"-[F:SOH]SOHNUM,0) From GESECRAN
Endif
#-----
Return

