#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_INICRE"    : Gosub IMP_INICRE
 When "IMP_INIMOD"    : Gosub IMP_INIMOD
 When "IMP_FERME"     : Gosub FERME
 When "EXPORT"        : Gosub EXPORT
Endcase
Return


$OUVRE
Global Char SAVE_ZLAN(3)
Return

# l'action EXPORT est la SEULE appellée à chaque record en export
# il n'y en a pas d'autre
$EXPORT
Local Char TRT  : TRT="1"
Local Char ACT  : ACT="1"
Local Char LANG : LANG=LAN
#If [M:EXP2]NOMEXP <> ""
#    Call MAJTRADX(LANG,TRT,ACT,[M:EXP2]NOMEXP) From MAJTRAD
#    [M:EXP2]NOMEXP=""
#Endif
Return

$IMP_INICRE
[F:AST]LAN=[M:TRA2]ZLAN
[F:AST]LANCHP=[M:TRA2]LANCHP
[F:AST]LANNUM=[M:TRA2]LANNUM
[F:AST]LANMES=[M:TRA2]ZTEXTE
[F:AST]CREDAT  = date$  
[F:AST]UPDDAT  = date$ 
If dim([F:AST]CRETIM)>0 : [F:AST]CRETIM  = time : Endif
If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM  = time : Endif
[F:AST]CREUSR  = GUSER 
[F:AST]UPDUSR  = GUSER
Return

$IMP_INIMOD
[F:AST]LAN=[M:TRA2]ZLAN
[F:AST]LANMES=[M:TRA2]ZTEXTE
If [F:AST]LAN <>"FRA"
  [F:AST]UPDDAT = date$ 
  If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM = time : Endif
  [F:AST]UPDUSR = GUSER
Endif
Return


# Mise à jour suivi des traductions
# TRT=0 traitement de ATEXTE
# TRT=1 traitement de APLSTD
# ACT=0 import
# ACT=1 export
$FERME
Local Char TRT  : TRT="1"
Local Char ACT  : ACT="0"
Local Char LANG : LANG=LAN
#Call MAJTRADX(LANG,TRT,ACT,[M:IMP2]NOMIMP) From MAJTRAD
Return

$IMP_ZONE
Case IMPZON
When "ZLAN"
     [M:TRA2]ZLAN=[F:AST]LAN
     GLANTRAD=[F:AST]LAN
     IMPMOD=1
     OK=0
When "ZTEXTE"
     [M:TRA2]ZTEXTE=[F:AST]LANMES
     If  [M:TRA2]ZTEXTE = "" 
         [M:TRA2]ZTEXTE=" "
     Endif
     IMPMOD=1
     OK=0
When "LANNUM"
     [M:TRA2]LANNUM=[F:AST]LANNUM
     IMPMOD=1
     OK=0
Endcase
Return


