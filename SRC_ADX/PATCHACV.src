#<AdxTL>@(#)4.0.0.0 $Revision$
###################################################
## Intégration d'un code activité
###################################################
$ACTIV
FICHIER = "ACTIV" : ABR = "ACV"
Read [ACV]CODACT = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
 Elsif APPLI=GDOSX3
  NEWOBJ = 0
 Else
  Gosub FIN_OBJ From PATCH
  Return
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_ACV
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ACV
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Return

$DEL_ACV
If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif
Trbegin [ACV]
 Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:ACV]CODACT
 If !fstat
  Delete [ADA] Curr
 Endif
 Delete [ACV] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ACTIV"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACV",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$TR_ACV
Trbegin [ACV]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ACV"   : Gosub ACV1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER : Break : Endif
 Until 1=0
 If ER : Goto ABORT : Endif
Commit
If clalev([F:ADA])=0 : Local File ADOSACT [ADA] : Endif
Trbegin [ADA]
 Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:ACV]CODACT
 If fstat
  [F:ADA] = [F:ACV]
  If TYPPTC=4
   [F:ADA]COP = 2
  Else
   [F:ADA]COP = 1
  Endif
  [F:ADA]DOSSIER = [F:ADS]DOSSIER
  Write [ADA]
 Else
  [F:ADA] = [F:ACV]
  Rewrite [ADA]
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACV",[ACV]CODACT,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return

$ACV1
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   If VARIA="FLACT"
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If APPLI=GDOSX3 & [F:ACV]CODACT="ABI"
 [F:ACV]FLACT = 2 : # mb 9.10.7 demande 43480
Endif
If [F:ACV]CODACT="AUD"
 Local File =[F:ADS]DOSSIER+".ACTIV" [ACVX]
 Read [ACVX]CODACT="AUDIT"
 If !fstat
  [F:ACV]FLACT = [F:ACVX]FLACT : # mb 10.8.10 demande 64860
 Endif
 Close Local File [ACVX]
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACV]CREDAT = date$
  [F:ACV]CREUSR = GUSER
  If dim([F:ACV]CRETIM)>0 : [F:ACV]CRETIM = time  : Endif
  [F:ACV]UPDDAT = [0/0/0]
  [F:ACV]UPDUSR = ""
  If dim([F:ACV]UPDTIM)>0 : [F:ACV]UPDTIM = 0     : Endif
 Elsif APPLI=GDOSX3 : # Issue 88973 pousse rend actif les nouveaux codes activité
  [F:ACV]FLACT = 2 : # mb 9.10.7 demande 43480
 Endif
 Write [ACV]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACV]UPDDAT = date$
  [F:ACV]UPDUSR = GUSER
  If dim([F:ACV]UPDTIM)>0 : [F:ACV]UPDTIM = time  : Endif
 Endif
 Rewrite [ACV]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACTIV"-NOMOBJ : Return
Endif
Return

$ABORT
Rollback
Return

