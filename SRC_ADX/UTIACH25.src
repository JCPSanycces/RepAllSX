#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTIACH25      Utilitaire de rûˋajustement des              Module ACHAT #
#               comptes et sections des demandes de livraison            #
#               et des rûˋceptions suite au bug 67796          20/10/2010 #
# ---------------------------------------------------------------------- #
# Fichier PORDERC                                                        #
#   [F:POC]COA   (0..9) : Codes plan comptable                           #
#   [F:POC]LINACC(0..9) : Comptes                                        #
#                                                                        #
# Fichier CPTANALIN pour PORDERP                                         #
#   [F:CAL]COA   (0..9) : Codes plan comptable                           #
#   [F:CAL]LINACC(0..9) : Comptes                                        #
#                                                                        #
# Fichier CPTANALIN pour PRECEIPTD                                       #
#   [F:CAL]COA   (0.. 9) : Codes plan comptable                          #
#   [F:CAL]LINACC(0.. 9) : Comptes                                       #
#   [F:CAL]DIE   (0..19) : Codes axe                                     #
#   [F:CAL]CCE   (0..19) : Sections analytiqyes                          #
##########################################################################


Call MAJ_UTIACH25
End


Subprog MAJ_UTIACH25
Local Char WDOSSIER(30)
Local Libelle WTRACE  : WTRACE=2     : # WTRACE=2 --> Trace dûˋtaillûˋe
Local Libelle WSIMUL  : WSIMUL=1     : # 0=normale, 1=simulation (pas de mû j)
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTIACH25 - Rûˋajustement tables achats en v6") From SAIDOS
If WDOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  If WTRACE
    Call OUVRE_TRACE("UTIACH25 : Rûˋcupûˋration comptes et sections en v6") From LECFIC
    Call ECR_TIME("UTIACH25 : Starting process on folder "+WDOSSIER) From DOSSUB
  Endif
  Call EXE_UTIACH25(WDOSSIER,WTRACE,WSIMUL)
  Call TEMPOFF From GESECRAN
  If WTRACE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
End


Subprog EXE_UTIACH25(WDOSSIER,WTRACE,WSIMUL)
Value Char     WDOSSIER
Value Libelle  WTRACE
Value Libelle  WSIMUL
#----- Variables locales -----#
Local Char     WMSG(90), WMSG2(90), WID0(40)
Local Integer  NBENR, NBCOR, WNBR
Local Char     CLE1(GLONVCR)
Local Integer  CLE2
Local Integer  CLE3
Local Char     CRITERE(150)
Local Integer COMPTEUR, STOP
Local Libelle  WFLAG, WCREFLG
Local Char     WCOA   (GLONCOA)(2)
Local Char     WLINACC(GLONGAC)(2)
Local Integer  I
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=WDOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If dim(GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#-----
Gosub TRT_POC
Gosub TRT_POP
Gosub TRT_PTD
#-----
$FIN_UTIACH25
If dim([V]GSOC_ACTIVE2)>0  Raz [V]GSOC_ACTIVE2 : Endif
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
Endif
#-----
End


#----------------------------------------------#
# Alimentation des comptes du PORDERC          #
# -------------------------------------------- #
# Fichier PORDERC                              #
#   [F:POC]COA   (0..9) : Codes plan comptable #
#   [F:POC]LINACC(0..9) : Comptes              #
#----------------------------------------------#
$TRT_POC
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".PORDERC"    [POC]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [POQ]
Local File =[F:ADS]DOSSIER+".PORDERP"    [POP]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD]
Local File =[F:ADS]DOSSIER+".PORDER"     [TB0]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [TB1]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [TB2]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  Call ECR_TIME("UTIACH25 : Purchase Order Process 1 : Update PORDERC") From DOSSUB
Endif
Raz CLE1, CLE2, STOP, NBENR, NBCOR, WNBR
#-----
$BOUCLE_POC
If STOP=1
  CRITERE='POHNUM="'+CLE1+'" & POPLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='POHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [POC]
  For [POC] POC0 Where evalue(CRITERE)
    Raz WFLAG
    NBENR+=1
    If [F:POC]COA(0)="" | [F:POC]LINACC(0)=""
      WID0=[F:POC]POHNUM-num$([F:POC]POPLIN)-"-"
      WNBR+=1
      WCOA   (0)=[F:POC]COA   (0)
      WLINACC(0)=[F:POC]LINACC(0)
      WCOA   (1)=[F:POC]COA   (1)
      WLINACC(1)=[F:POC]LINACC(1)
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:POC]POHFCY) From TRTX3CPT
      Call INIT_COMPTES_POC
      If WCOA(0)<>[F:POC]COA(0)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"COA(0)    :"-WCOA(0)-"-->"-[F:POC]COA(0)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
      Endif
      If WLINACC(0)<>[F:POC]LINACC(0)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"LINACC(0) :"-WLINACC(0)-"-->"-[F:POC]LINACC(0)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
      Endif
      If WCOA(1)<>[F:POC]COA(1)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"COA(1)    :"-WCOA(1)-"-->"-[F:POC]COA(1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
      Endif
      If WLINACC(1)<>[F:POC]LINACC(1)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"LINACC(1) :"-WLINACC(1)-"-->"-[F:POC]LINACC(1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
      Endif
    Endif
    #-----
    If WFLAG
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [POC]
      If fstat & WTRACE
        Call ECR_TRACE("File PORDERC, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:POC]POHNUM : CLE2=[F:POC]POPLIN : STOP=1 : Break
    Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP  Goto BOUCLE_POC : Endif
#-----
Close Local File [POH], [POC], [POQ], [POP], [BPR], [BPS], [BPA], [ITM],
&                [GAD], [TB0], [TB1], [TB2]
#-----
If WTRACE
  WMSG ="UTIACH25 : Number of processed records :"-num$(WNBR)+"/"+num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#-------------------------------------------------------#
# Alimentation des comptes du CPTANALIN pour le PORDERP #
# ----------------------------------------------------- #
# Fichier CPTANALIN                                     #
#   [F:CAL]COA   (0..9) : Codes plan comptable          #
#   [F:CAL]LINACC(0..9) : Comptes                       #
#-------------------------------------------------------#
$TRT_POP
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".PORDERC"    [POC]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [POQ]
Local File =[F:ADS]DOSSIER+".PORDERP"    [POP]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD]
Local File =[F:ADS]DOSSIER+".PORDER"     [TB0]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [TB1]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [TB2]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  Call ECR_TIME("UTIACH25 : Purchase Order Process 2 : Update CPTANALIN") From DOSSUB
Endif
Raz CLE1, CLE2, CLE3, STOP, NBENR, NBCOR, WNBR
#-----
$BOUCLE_POP
If STOP=1
  CRITERE='POHNUM="'+CLE1+'" & POPLIN='+num$(CLE2)+' & POPSEQ>'+num$(CLE3)
  STOP=2
Elsif STOP=2
  CRITERE='POHNUM="'+CLE1+'" & POPLIN>'+num$(CLE2)
  STOP=3
Elsif STOP=3
  CRITERE='PTHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [CAL]
  For [POP] POP0 Where evalue(CRITERE) & POHTYP=2
    Raz WFLAG
    NBENR+=1
    If [F:POH]POHNUM<>[F:POP]POHNUM
      Read [POH] POH0=[F:POP]POHNUM
      If fstat
        Raz [F:POH]
        If WTRACE
          Call ECR_TRACE("File PORDER"-[F:POP]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
        Goto SUIT_POP
      Endif
    Endif
    Read [CAL] CAL0="POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
    If fstat
      If WTRACE
        WMSG="POP 0"-[F:POP]POHNUM-num$([F:POP]POPLIN)-num$([F:POP]POPSEQ)-"1" 
        Call ECR_TRACE("File CPTANALIN :"-WMSG-"Key not found !",1) From GESECRAN
      Endif
    Else
      If [F:CAL]COA(0)="" | [F:CAL]ACC(0)=""
        WID0="POP 0"-[F:POP]POHNUM-num$([F:POP]POPLIN)-num$([F:POP]POPSEQ)-"-"
        WNBR+=1
        WCOA   (0)=[F:CAL]COA(0)
        WLINACC(0)=[F:CAL]ACC(0)
        WCOA   (1)=[F:CAL]COA(1)
        WLINACC(1)=[F:CAL]ACC(1)
        Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:POH]POHFCY) From TRTX3CPT
        Call INIT_COMPTES_POP
        If WCOA(0)<>[F:CAL]COA(0)
          WFLAG=1
          If WTRACE=2
            WMSG=WID0-"COA(0)    :"-WCOA(0)-"-->"-[F:CAL]COA(0)
            Call ECR_TRACE(WMSG,0) From GESECRAN
            WID0=space$(len(WID0)-2)+" -"
          Endif
        Endif
        If WLINACC(0)<>[F:CAL]ACC(0)
          WFLAG=1
          If WTRACE=2
            WMSG=WID0-"ACC(0)    :"-WLINACC(0)-"-->"-[F:CAL]ACC(0)
            Call ECR_TRACE(WMSG,0) From GESECRAN
            WID0=space$(len(WID0)-2)+" -"
          Endif
        Endif
        If WCOA(1)<>[F:CAL]COA(1)
          WFLAG=1
          If WTRACE=2
            WMSG=WID0-"COA(1)    :"-WCOA(1)-"-->"-[F:CAL]COA(1)
            Call ECR_TRACE(WMSG,0) From GESECRAN
            WID0=space$(len(WID0)-2)+" -"
          Endif
        Endif
        If WLINACC(1)<>[F:CAL]ACC(1)
          WFLAG=1
          If WTRACE=2
            WMSG=WID0-"ACC(1)    :"-WLINACC(1)-"-->"-[F:CAL]ACC(1)
            Call ECR_TRACE(WMSG,0) From GESECRAN
            WID0=space$(len(WID0)-2)+" -"
          Endif
        Endif
      Endif
      #-----
      If WFLAG
        COMPTEUR+=1 : NBCOR+=1
        Rewrite [CAL]
        If fstat & WTRACE
          Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:POP]POHNUM : CLE2=[F:POP]POPLIN : CLE3=[F:POP]POPSEQ : STOP=1 : Break
    Endif
$SUIT_POP
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP  Goto BOUCLE_POP : Endif
#-----
Close Local File [CAL], [POH], [POC], [POQ], [POP], [BPR], [BPS], [BPA], [ITM],
&                [GAD], [TB0], [TB1], [TB2]
#-----
If WTRACE
  WMSG ="UTIACH25 : Number of processed records :"-num$(WNBR)+"/"+num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return

#---------------------------------------------------------#
# Alimentation des comptes du CPTANALIN pour le PRECEIPTD #
# ------------------------------------------------------- #
# Fichier CPTANALIN                                       #
#   [F:CAL]COA   (0.. 9) : Codes plan comptable           #
#   [F:CAL]LINACC(0.. 9) : Comptes                        #
#   [F:CAL]DIE   (0..19) : Codes axe                      #
#   [F:CAL]CCE   (0..19) : Sections analytiqyes           #
#---------------------------------------------------------#
$TRT_PTD
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL2]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"  [PTD]
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [POQ]
Local File =[F:ADS]DOSSIER+".PORDERP"    [POP]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  Call ECR_TIME("UTIACH25 : Purchase Receipt Process 1 : Update CPTANALIN") From DOSSUB
Endif
Raz CLE1, CLE2, STOP, NBENR, NBCOR, WNBR, WMSG2
#-----
$BOUCLE_PTD
If STOP=1
  CRITERE='PTHNUM="'+CLE1+'" & PTDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PTHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [CAL]
  For [PTD] PTD2 Where evalue(CRITERE) & POHTYP=2 & POHNUM<>""
    Raz WFLAG, WCREFLG
    NBENR+=1
    Read [CAL] CAL0="PTD";0;[F:PTD]PTHNUM;[F:PTD]PTDLIN;0;"";1
    If fstat
      If WTRACE
        WMSG="PTD 0"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"0 1" 
        Call ECR_TRACE("File CPTANALIN :"-WMSG-"Key not found !",1) From GESECRAN
      Endif
      Raz [F:CAL]
      [F:CAL]ABRFIC="PTD"
      [F:CAL]VCRTYP=0
      [F:CAL]VCRNUM=[F:PTD]PTHNUM
      [F:CAL]VCRLIN=[F:PTD]PTDLIN
      [F:CAL]VCRSEQ=0
      [F:CAL]CPLCLE=""
      [F:CAL]ANALIG=1
      WCREFLG=1
    Endif
    If [F:POH]POHNUM<>[F:PTD]POHNUM
      Read [POH] POH0=[F:PTD]POHNUM
      If fstat
        Raz [F:POH]
        If WTRACE
          WMSG=[F:PTD]POHNUM
          If WMSG<>WMSG2
            Call ECR_TRACE("File PORDER :"-WMSG-"Key not found !",1) From GESECRAN
          Endif
          WMSG2=WMSG
        Endif
        Goto SUIT_PTD
      Endif
    Endif
    #----- Les commandes inter-sites ne sont pas facturûˋes -----#
    If [F:POH]BETFCY=2 & [F:POH]BETCPY=1
      Goto SUIT_PTD
    Endif
    #-----
    If [F:CAL]COA(0)="" | [F:CAL]ACC(0)="" | [F:CAL]DIE(0)="" | [F:CAL]CCE(0)=""
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:PTD]PRHFCY) From TRTX3CPT
      WID0="PTD 0"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"-"
      WNBR+=1
      If [F:POQ]POHNUM<>[F:PTD]POHNUM |
&        [F:POQ]POPLIN<>[F:PTD]POPLIN |
&        [F:POQ]POQSEQ<>[F:PTD]POQSEQ
        Read [POQ] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
        If fstat
          Raz [F:POQ]
          If WTRACE
            WMSG=[F:PTD]POHNUM-num$([F:PTD]POPLIN)-num$([F:PTD]POQSEQ)
            If WMSG<>WMSG2
              Call ECR_TRACE("File PORDERQ :"-WMSG-"Key not found !",1) From GESECRAN
            Endif
            WMSG2=WMSG
          Endif
          Goto SUIT_PTD
        Endif
      Endif
      Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT 
      Read [POP] POP1 First
      Filter [POP]
      If fstat
        Raz [F:POP]
        If WTRACE
          WMSG=[F:PTD]POHNUM-num$([F:PTD]POPLIN)-"####"
          If WMSG<>WMSG2
            Call ECR_TRACE("File PORDERP :"-WMSG-"Key not found !",1) From GESECRAN
          Endif
          WMSG2=WMSG
          Endif
        Goto SUIT_PTD
      Endif
      Read [CAL2] CAL0="POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
      If fstat
        If WTRACE
          WMSG="POP 0"-[F:POP]POHNUM-num$([F:POP]POPLIN)-num$([F:POP]POPSEQ)-"1" 
          Call ECR_TRACE("File CPTANALIN2 :"-WMSG-"Key not found !",1) From GESECRAN
        Endif
        Raz [F:CAL2]
        Goto SUIT_PTD
      Endif
      If [F:CAL]COA(0)="" & [CAL]COA(0)<>[F:CAL2]COA(0)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"COA(0)    :"-[F:CAL]COA(0)-"-->"-[F:CAL2]COA(0)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]COA(0)=GCOA(1)
        [F:CAL]COA(0)=[F:CAL2]COA(0)
      Endif
      If [F:CAL]ACC(0)="" & [F:CAL]ACC(0)<>[F:CAL2]ACC(0)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"ACC(0)    :"-[F:CAL]ACC(0)-"-->"-[F:CAL2]ACC(0)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]ACC(0)=[F:CAL2]ACC(0)
      Endif
      If [F:CAL]COA(1)="" & [F:CAL]COA(1)<>[F:CAL2]COA(1)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"COA(1)    :"-[F:CAL]COA(1)-"-->"-[F:CAL2]COA(1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]COA(1)=GCOA(2)
        [F:CAL]COA(1)=[F:CAL2]COA(1)
      Endif
      If [F:CAL]ACC(1)="" & [F:CAL]ACC(1)<>[F:CAL2]ACC(1)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"ACC(1)    :"-[F:CAL]ACC(1)-"-->"-[F:CAL2]ACC(1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]ACC(1)=[F:CAL2]ACC(1)
      Endif
      If [F:CAL]COA(2)="" & [F:CAL]COA(2)<>[F:CAL2]COA(2)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"COA(2)    :"-[F:CAL]COA(2)-"-->"-[F:CAL2]COA(2)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]COA(2)=GCOA(3)
        [F:CAL]COA(2)=[F:CAL2]COA(2)
      Endif
      If [F:CAL]ACC(2)="" & [F:CAL]ACC(2)<>[F:CAL2]ACC(2)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"ACC(2)    :"-[F:CAL]ACC(2)-"-->"-[F:CAL2]ACC(2)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]ACC(2)=[F:CAL2]ACC(2)
      Endif
      #-----
      If [F:CAL]DIE(0)="" & [CAL]DIE(0)<>[F:CAL2]DIE(0)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(0)    :"-[F:CAL]DIE(0)-"-->"-[F:CAL2]DIE(0)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(0)=GDIE(1)
        [F:CAL]DIE(0)=[F:CAL2]DIE(0)
      Endif
:     If [F:CAL]CCE(0)="" & [F:CAL]CCE(0)<>[F:CAL2]CCE(0)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(0)    :"-[F:CAL]CCE(0)-"-->"-[F:CAL2]CCE(0)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(0)=[F:CAL2]CCE(0)
      Endif
      If [F:CAL]DIE(1)="" & [F:CAL]DIE(1)<>[F:CAL2]DIE(1)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(1)    :"-[F:CAL]DIE(1)-"-->"-[F:CAL2]DIE(1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(1)=GDIE(2)
        [F:CAL]DIE(1)=[F:CAL2]DIE(1)
      Endif
      If [F:CAL]CCE(1)="" & [F:CAL]CCE(1)<>[F:CAL2]CCE(1)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(1)    :"-[F:CAL]CCE(1)-"-->"-[F:CAL2]CCE(1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(1)=[F:CAL2]CCE(1)
      Endif
      If [F:CAL]DIE(2)="" & [F:CAL]DIE(2)<>[F:CAL2]DIE(2)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(2)    :"-[F:CAL]DIE(2)-"-->"-[F:CAL2]DIE(2)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(2)=GDIE(3)
        [F:CAL]DIE(2)=[F:CAL2]DIE(2)
      Endif
      If [F:CAL]CCE(2)="" & [F:CAL]CCE(2)<>[F:CAL2]CCE(2)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(2)    :"-[F:CAL]CCE(2)-"-->"-[F:CAL2]CCE(2)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(2)=[F:CAL2]CCE(2)
      Endif
      If [F:CAL]DIE(3)="" & [F:CAL]DIE(3)<>[F:CAL2]DIE(3)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(3)    :"-[F:CAL]DIE(3)-"-->"-[F:CAL2]DIE(3)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(3)=GDIE(4)
        [F:CAL]DIE(3)=[F:CAL2]DIE(3)
      Endif
      If [F:CAL]CCE(3)="" & [F:CAL]CCE(3)<>[F:CAL2]CCE(3)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(3)    :"-[F:CAL]CCE(3)-"-->"-[F:CAL2]CCE(3)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(3)=[F:CAL2]CCE(3)
      Endif
      If [F:CAL]DIE(4)="" & [F:CAL]DIE(4)<>[F:CAL2]DIE(4)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(4)    :"-[F:CAL]DIE(4)-"-->"-[F:CAL2]DIE(4)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(4)=GDIE(5)
        [F:CAL]DIE(4)=[F:CAL2]DIE(4)
      Endif
      If [F:CAL]CCE(4)="" & [F:CAL]CCE(4)<>[F:CAL2]CCE(4)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(4)    :"-[F:CAL]CCE(4)-"-->"-[F:CAL2]CCE(4)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(4)=[F:CAL2]CCE(4)
      Endif
      If [F:CAL]DIE(5)="" & [F:CAL]DIE(5)<>[F:CAL2]DIE(5)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(5)    :"-[F:CAL]DIE(5)-"-->"-[F:CAL2]DIE(5)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(5)=GDIE(6)
        [F:CAL]DIE(5)=[F:CAL2]DIE(5)
      Endif
      If [F:CAL]CCE(5)="" & [F:CAL]CCE(5)<>[F:CAL2]CCE(5)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(5)    :"-[F:CAL]CCE(5)-"-->"-[F:CAL2]CCE(5)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(5)=[F:CAL2]CCE(5)
      Endif
      If [F:CAL]DIE(6)="" & [F:CAL]DIE(6)<>[F:CAL2]DIE(6)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(6)    :"-[F:CAL]DIE(6)-"-->"-[F:CAL2]DIE(6)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(6)=GDIE(7)
        [F:CAL]DIE(6)=[F:CAL2]DIE(6)
      Endif
      If [F:CAL]CCE(6)="" & [F:CAL]CCE(6)<>[F:CAL2]CCE(6)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(6)    :"-[F:CAL]CCE(6)-"-->"-[F:CAL2]CCE(6)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(6)=[F:CAL2]CCE(6)
      Endif
      If [F:CAL]DIE(7)="" & [F:CAL]DIE(7)<>[F:CAL2]DIE(7)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(7)    :"-[F:CAL]DIE(7)-"-->"-[F:CAL2]DIE(7)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(7)=GDIE(8)
        [F:CAL]DIE(7)=[F:CAL2]DIE(7)
      Endif
      If [F:CAL]CCE(7)="" & [F:CAL]CCE(7)<>[F:CAL2]CCE(7)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(7)    :"-[F:CAL]CCE(7)-"-->"-[F:CAL2]CCE(7)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(7)=[F:CAL2]CCE(7)
      Endif
      If [F:CAL]DIE(8)="" & [F:CAL]DIE(8)<>[F:CAL2]DIE(8)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"DIE(8)    :"-[F:CAL]DIE(8)-"-->"-[F:CAL2]DIE(8)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
       #[F:CAL]DIE(8)=GDIE(9)
        [F:CAL]DIE(8)=[F:CAL2]DIE(8)
      Endif
      If [F:CAL]CCE(8)="" & [F:CAL]CCE(8)<>[F:CAL2]CCE(8)
        WFLAG=1
        If WTRACE=2
          WMSG=WID0-"CCE(8)    :"-[F:CAL]CCE(8)-"-->"-[F:CAL2]CCE(8)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WID0=space$(len(WID0)-2)+" -"
        Endif
        [F:CAL]CCE(8)=[F:CAL2]CCE(8)
      Endif
    Endif
    #-----
    If WFLAG
      COMPTEUR+=1 : NBCOR+=1
      If WCREFLG  Write [CAL]  Else  Rewrite [CAL] : Endif
      If fstat & WTRACE
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:PTD]PTHNUM : CLE2=[F:PTD]PTDLIN : STOP=1 : Break
    Endif
$SUIT_PTD
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP  Goto BOUCLE_PTD : Endif
#-----
Close Local File [CAL], [CAL2], [PTD], [POH], [POQ], [POP]
#-----
If WTRACE
  WMSG ="UTIACH25 : Number of processed records :"-num$(WNBR)+"/"+num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


###############################################################
# Initialisation des comptes d'une ligne article d'un contrat #
###############################################################
Subprog INIT_COMPTES_POC
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..3)
Local    Shortint I, J
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
For I=1 To GNBCOA
  [F:POC]COA(I-1)=GCOA(I)
Next I
#-----
If [F:POH]POHNUM<>[F:POC]POHNUM
  Read [POH] POH0=[F:POC]POHNUM : If fstat  Raz [F:POH] : Endif
Endif
#-----
[F:TB0]=[F:POH]
[F:TB1]=[F:POH] : [F:TB1]=[F:POC]
If [F:TB1]LINPURTYP=0  [F:TB1]LINPURTYP=1 : Endif
#----- Chargement table liûˋe PORDERP pour la piû´ce auto PORD -----#
[F:POP]=[F:POH] : [F:POP]=[F:POC]
If [F:ITM]ITMREF<>[F:POC]ITMREF
  Read [ITM] ITM0=[F:POC]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif
For I=0 To dim([F:POP]TSICOD)-1
  [F:POP]TSICOD(I)=[F:ITM]TSICOD(I)
Next I
#----- Initialisation des codes taxe -----#
Call ALIVATCOD(2,[F:POC]BPSNUM,[F:POC]ITMREF,"POP",0) From TRTX3
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="POP"
[F:TB2]VCRNUM=[F:POC]POHNUM
[F:TB2]VCRLIN=[F:POC]POPLIN
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=[F:POC]LINACC(I-1)
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
Next I
#-----
Raz ID1,ID2
#-----
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        [F:POC]LINACC(J-1)=TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
End


############################################################
# Initialisation des comptes d'une ligne prix d'un contrat #
############################################################
Subprog INIT_COMPTES_POP
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..3)
Local    Shortint I, J
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If [F:POC]POHNUM<>[F:POP]POHNUM | [F:POC]POPLIN<>[F:POP]POPLIN
  Read [POC] POC0=[F:POP]POHNUM;[F:POP]POPLIN : If fstat  Raz [F:POC] : Endif
Endif
#-----
[F:TB0]=[F:POH]
[F:TB1]=[F:POH] : [F:TB1]=[F:POC]
If [F:TB1]LINPURTYP=0  [F:TB1]LINPURTYP=1 : Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
[F:TB2]=[F:CAL]
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)         : [F:CAL]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)            : [F:CAL]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=[F:POC]LINACC(I-1)
  Endif
Next I
#-----
Raz ID1,ID2
#-----
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        [F:CAL]ACC(J-1)=TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
End


###################################################
# Pour exûˋcution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH25 - Rûˋcupûˋration comptes et sections en v6",0) From GESECRAN
  Call EXE_UTIACH25(DOSSIER,1,0)
Endif
#-----       
End


#########################################################
# Pour exûˋcution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH25 - Rûˋcupûˋration comptes et sections en v6",0) From GESECRAN
  Call EXE_UTIACH25(DOSSIER,1,0)
Endif
#-----
End
