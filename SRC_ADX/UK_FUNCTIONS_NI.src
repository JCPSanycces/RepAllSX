#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Function to determine the amount of pay that should be allocated to a particular national insurance band.
#*
#* @param BAND_NO Band number to find the amount for (valid values 1-4)
#* @param CAT_TOTAL_PAY The total amount paid against the NI current category
#* @param PRE_ALLOCATED The total amount that has already been allocated against other NI categories
#* @return The amount of CAT_TOTAL_PAY that lies within the band requested.
#*!
Funprog GET_AMOUNT_IN_BAND (BAND_NO,CAT_TOTAL_PAY,PRE_ALLOCATED, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3)
  Value Integer BAND_NO
  Value Decimal CAT_TOTAL_PAY, PRE_ALLOCATED, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3
  Local Decimal AMOUNT, PRE_ALLOCATED_TO_BAND, TOTAL_PAY

  [L]TOTAL_PAY = CAT_TOTAL_PAY + PRE_ALLOCATED
  If PRE_ALLOCATED > 0
    [L]PRE_ALLOCATED_TO_BAND = func GET_AMOUNT_IN_BAND(BAND_NO,PRE_ALLOCATED,0,THRESHOLD_1,THRESHOLD_2,THRESHOLD_3)
  Endif

  If BAND_NO = 1
    If [L]TOTAL_PAY > THRESHOLD_1
      [L]AMOUNT = THRESHOLD_1
    Else
      [L]AMOUNT = [L]TOTAL_PAY
    Endif
  Elsif BAND_NO = 2 and [L]TOTAL_PAY > THRESHOLD_1
    [L]TOTAL_PAY = [L]TOTAL_PAY - THRESHOLD_1
    If [L]TOTAL_PAY > THRESHOLD_2 - THRESHOLD_1
      [L]AMOUNT = THRESHOLD_2 - THRESHOLD_1
    Else
      [L]AMOUNT = [L]TOTAL_PAY
    Endif
  Elsif BAND_NO = 3 and [L]TOTAL_PAY > THRESHOLD_2
    TOTAL_PAY = TOTAL_PAY - THRESHOLD_2
    If TOTAL_PAY > THRESHOLD_3 - THRESHOLD_2
      [L]AMOUNT = THRESHOLD_3 - THRESHOLD_2
    Else
      [L]AMOUNT = [L]TOTAL_PAY
    Endif
  Elsif BAND_NO = 4 and [L]TOTAL_PAY > THRESHOLD_3
    [L]TOTAL_PAY = [L]TOTAL_PAY - THRESHOLD_3
    [L]AMOUNT = [L]TOTAL_PAY
  Endif

  [L]AMOUNT = [L]AMOUNT - [L]PRE_ALLOCATED_TO_BAND
End [L]AMOUNT

#**
#* Function called by the payplan to calculate the National Insurance category/band breakdown.
#*
#* @param CATEGORY National insurance Category to find allocated amount for e.g. "A", "B"
#* @param BAND_NAME National insurance Band to find allocated amount for valid value: "TO_LEL", "LEL_PT", "PT_UEL", "OV_UEL"
#* @param NUM_WEEKS Number of weeks the director has been a director (used to pro-rata thresholds)
#* @param THRESHOLD_1 Annual limit of the first threshold (LEL)
#* @param THRESHOLD_2 Annual limit of the second threshold (PT)
#* @param THRESHOLD_3 Annual limit of the thirds threshold (UEL)
#* @param CAT_A Total pay allocated to Category A (year to date)
#* @param CAT_B Total pay allocated to Category B (year to date)
#* @param CAT_C Total pay allocated to Category C (year to date)
#* @param CAT_H Total pay allocated to Category H (year to date)
#* @param CAT_J Total pay allocated to Category J (year to date)
#* @param CAT_M Total pay allocated to Category M (year to date)
#* @param CAT_X Total pay allocated to Category X (year to date)
#* @param CAT_Z Total pay allocated to Category Z (year to date)
#* @return Returns the amount calculated to fall within the requested NI category/band
#*!
Funprog GET_BAND_BREAKDOWN(CATEGORY, BAND_NAME, NUM_WEEKS, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3, CAT_A, CAT_B, CAT_C, CAT_H, CAT_J, CAT_M, CAT_X, CAT_Z)
  Value Char CATEGORY, BAND_NAME
  Value Integer NUM_WEEKS
  Value Decimal CAT_A, CAT_B, CAT_C, CAT_H, CAT_J, CAT_M, CAT_X, CAT_Z, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3
  Local Decimal AMOUNT, ALLOCATED
  Local Char CALC_ORDER, CURR_CAT
  Local Integer I

  #Get an ordered list of categories, (minus the categories with no year to dates)
  CALC_ORDER = func GET_ORDERED_CATEGORIES_LIST(CAT_A, CAT_B, CAT_C, CAT_H, CAT_J, CAT_M, CAT_X, CAT_Z)

  #Pro-rata the thresholds if needs be
  THRESHOLD_1 = func PRORATA_THRESHOLD(NUM_WEEKS,THRESHOLD_1)
  THRESHOLD_2 = func PRORATA_THRESHOLD(NUM_WEEKS,THRESHOLD_2)
  THRESHOLD_3 = func PRORATA_THRESHOLD(NUM_WEEKS,THRESHOLD_3)

  For I = 1 To len(CALC_ORDER)
    CURR_CAT = mid$(CALC_ORDER,I,1)

    #If already allocated + current category is below PT then shuffle the earnings down to the next category
      # assuming we're not already on the last category
    If evalue("ALLOCATED + CAT_" + CURR_CAT) < THRESHOLD_2 and I < len(CALC_ORDER)
      Assign ("CAT_" + mid$(CALC_ORDER,I+1,1)) With evalue("CAT_" + mid$(CALC_ORDER,I+1,1) + " + CAT_" + CURR_CAT)
      Assign ("CAT_" + CURR_CAT) With 0
    Else
      #If the current category being processed is the one requested then determine the amount requested and leave
      If CURR_CAT = CATEGORY
        # Set the amount to the requested Category/Band and break out
        Case BAND_NAME
          When "TO_LEL"
            [L]AMOUNT = evalue("func UK_FUNCTIONS_NI.GET_AMOUNT_IN_BAND(1,CAT_" + CURR_CAT + ",ALLOCATED, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3)")
          When "LEL_PT"
            [L]AMOUNT = evalue("func UK_FUNCTIONS_NI.GET_AMOUNT_IN_BAND(2,CAT_" + CURR_CAT + ",ALLOCATED, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3)")
          When "PT_UEL"
            [L]AMOUNT = evalue("func UK_FUNCTIONS_NI.GET_AMOUNT_IN_BAND(3,CAT_" + CURR_CAT + ",ALLOCATED, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3)")
          When "OV_UEL"
            [L]AMOUNT = evalue("func UK_FUNCTIONS_NI.GET_AMOUNT_IN_BAND(4,CAT_" + CURR_CAT + ",ALLOCATED, THRESHOLD_1, THRESHOLD_2, THRESHOLD_3)")
        Endcase
        Break
      Endif

      # Accumulate the running total of amounts already allocated
      Assign ("ALLOCATED") With evalue("ALLOCATED + CAT_" + CURR_CAT)
    Endif
  Next
End [L]AMOUNT

#**
#* Works out the prorata'd amount based on a 52 week annual threshold
#*
#* @param NUM_WEEKS Number of weeks the threshold applies for 1-52
#* @param ANNUAL_THRESHOLD Annual amount for the threshold
#* @return Prorata'd threshold amount. NUM_WEEKS/52 * ANNUAL_THRESHOLD; then rounded up to whole pounds
#*!
Funprog PRORATA_THRESHOLD (NUM_WEEKS, ANNUAL_THRESHOLD)
  Value Integer NUM_WEEKS
  Value Decimal ANNUAL_THRESHOLD
  Local Decimal RETVAL
  [L]RETVAL = (ANNUAL_THRESHOLD / 52) * NUM_WEEKS
  [L]RETVAL = func UK_FUNCTIONS.ROUNDUP([L]RETVAL)
End [L]RETVAL

#**
#* Returns list of National insurance categories in the order they should be calculated, stripping out any categories without year to date values
#*
#* @param CATEGORY_LIST Full list of all the NI categories
#* @param CAT_A Total pay allocated to Category A (year to date)
#* @param CAT_B Total pay allocated to Category B (year to date)
#* @param CAT_C Total pay allocated to Category C (year to date)
#* @param CAT_H Total pay allocated to Category H (year to date)
#* @param CAT_J Total pay allocated to Category J (year to date)
#* @param CAT_M Total pay allocated to Category M (year to date)
#* @param CAT_X Total pay allocated to Category X (year to date)
#* @param CAT_Z Total pay allocated to Category Z (year to date)
#* @return Returns the list "BHMACZJX" and removes categories where no year to date pay
#*!
Funprog GET_ORDERED_CATEGORIES_LIST (CAT_A, CAT_B, CAT_C, CAT_H, CAT_J, CAT_M, CAT_X, CAT_Z)
  Value Decimal CAT_A, CAT_B, CAT_C, CAT_H, CAT_J, CAT_M, CAT_X, CAT_Z
  Local Char RETVAL, CATEGORY_LIST : CATEGORY_LIST = "BHMACZJX"
  Local Integer I

  For I = 1 To len(CATEGORY_LIST)
    If evalue("CAT_" + mid$(CATEGORY_LIST,I,1)) > 0
      [L]RETVAL = [L]RETVAL + mid$(CATEGORY_LIST,I,1)
    Endif
  Next

End [L]RETVAL

