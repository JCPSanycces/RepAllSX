#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXELP
####################################################################################
$ACTION

Case ACTION
  When "DEBUT"         : Gosub DEBUT
  When "OUVRE"         : Gosub OUVRE
  When "OK"            : Gosub OK
Endcase

Return
####################################################################################
$OUVRE

  Global Char     GMTSNUM(GLONTRS) : GMTSNUM = GFLAG

  If !clalev([SFTX])  : Local File SFTTXN     [SFTX]  : Endif
  If !clalev([SFTH])  : Local File SFTTXNH    [SFTH]  : Endif
  If !clalev([F:MFG]) : Local File MFGHEAD    [MFG]   : Endif
  If !clalev([F:MFO]) : Local File MFGOPE     [MFO]   : Endif
  If !clalev([F:TMA]) : Local File TABMAT     [TMA]   : Endif
  If !clalev([SCH])   : Local File SCHEDULING [SCH]   : Endif
  If !clalev([MWS])   : Local File WORKSTATIO [MWS]   : Endif

Return
####################################################################################
$DEBUT

  Raz [M:VXELP]
  Affzo [M:VXELP]

  # Default to disable reject qty and reject reason fields
  Grizo [M:VXELP]REJCPLQTY
  Grizo [M:VXELP]SCANUM

Return
####################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Local Integer EMPTYP

  # Verify if employee exists.
  Read [TMA]TMA0 = VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

  # Check if employee is active
  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 2
    End
  Endif

  # X3-1801 sn
  EMPTYP =  [F:TMA]EMPTYP

  # Check if employee is on a break?
  If EMPTYP <> 2
    #Check if an employee or a summary team is on a break or on an exclusive indirect
    If func SFTLIB.EMPLOYEE_ON_BREAK(VALEUR) = [V]CST_AYES
      Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
      If EMPTYP = 3
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(121,2422,1)
      Else
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(18,2422,1)
      Endif
      mkstat = 2
      End
    Endif
  Endif
  # X3-1801 en

End
######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR
  Raz [M:VXELP]VCRNUM
  Call CLEAR_FIELDS

  # Get the employee description and default site (if it exists)
  Read [TMA]TMA0 = VALEUR
  If !fstat
    # Make sure employee has elapsed labor access
    If [F:TMA]ELPFLG <> [V]CST_AYES
      Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
      #GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(89,2422,1)
      Call ERREUR(func AFNC.MES1(mess(89,2422,1), num$(VALEUR))) From GESECRAN #CT-1797
      mkstat = 2
      End
    Endif

    # Default employee description,site and employee type, if exists
    [M:VXELP]EMPDES = [F:TMA]EMPDES
    [M:VXELP]FCY    = [F:TMA]DEFFCY
    Affzo [M:VXELP]FCY, EMPDES
  Else    # Employee not found
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer  EMP_LIST(1..)

  # Make sure the global variables and parameters are updated
  GFCY=VALEUR : Gosub CHARG_PARAM From SUBMTKA

  Local Char PARAMRET(4)
  Raz PARAMRET

  # For detailed team, make sure the site is required clock in and
  # at least one of the team member is clocked in and not on any individual activity
  If func SFTLIB.EMPTYP([M:VXELP]EMPNUM) = 2    # Detailed team
    # check if clock in is needed for this site
    Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
    If val([L]PARAMRET) <> [V]CST_AYES
      Call ERREUR(func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")) From GESECRAN
      mkstat = 2
      End
    Endif
    # Check if team members are clocked in
    Call TEAM_LIST ([M:VXELP]EMPNUM, 'E', EMP_LIST) From SFTLIB
    If maxtab(EMP_LIST) = 0   # No team member found
      Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:VXELP]EMPNUM))) From GESECRAN
      mkstat = 2
      End
    Endif
  Else  # Not a detailed team. Employee or summary team
    If func SFTLIB.EMPL_CLK_IN_OUT([M:VXELP]EMPNUM, VALEUR) = [V]CST_ANO
      mkstat = 2
      End
    Endif
  Endif

End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Raz [M:VXELP]VCRNUM
  Call CLEAR_FIELDS

End
######################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

  Call CLEAR_FIELDS

  # Verify the WO
  Read [F:MFG]MFG0 = VALEUR
  If !fstat
      #Work order does not exist at the site
      If [F:MFG]MFGFCY<>[M:VXELP]FCY : Call ERREUR(mess(51,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #This WO Status is not Firm: cannot be tracked.
      If [F:MFG]MFGSTA<>1 : Call ERREUR(mess(19,190,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #This WO is suspended: tracking is not possible
      If [F:MFG]SUSFLG=2  : Call ERREUR(mess(180,190,1)) From GESECRAN :  mkstat = 2 : End : Endif

      #Allocation incomplete. Tracking not possible
      If GMTKALLMGT = [V]CST_AYES & !find([F:MFG]ALLSTA,3,5)
          Call ERREUR(mess(18,190,1)) From GESECRAN
          mkstat = 2
          End
      Endif

      #The WO is not printed: tracking not possible
      If [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : Call ERREUR(mess(20,190,1)) From GESECRAN : mkstat = 2 : End : Endif
  Else
      #Record does not exist
      Call ERREUR(mess(23,100,1)) From GESECRAN
      mkstat = 2
      End
  Endif

End
######################################################################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR

  Local Integer OPERPREC, ALLOW_IT

  # Verify if someone has this record open using actuals
  Filter [F:SFTX] Where [F:SFTX]VCRNUM = [M:VXELP]VCRNUM &
&                       [F:SFTX]OPENUM = VALEUR &
&                       [F:SFTX]UTCENDDATTIM = AVOID.ADATTIM
  Read [F:SFTX] First
  Filter [F:SFTX]
  If fstat = 0     # Record found
    GERR=1
    If [F:SFTX]SFTTYP = 4 # Setup
      GMESSAGE = mess(88,2422,1)      # Setup in process for the selected operation.
    Else                  # Run
      GMESSAGE = mess(85,2422,1)      # Run in process for the selected operation.
    Endif
    mkstat = 2
    End
  Endif

  # Operation is valid?
  If [M:VXELP]VCRNUM <> AVOID.ACHAR
    Filter [MFO] Where MFGNUM = [M:VXELP]VCRNUM & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat
      #Operation status cannot be closed, excluded, or ordered
      If [F:MFO]OPESTA >= 5 : Call ERREUR(mess(50,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #Work center type cannot be subcontract
      If [F:MFO]EXTWST <> AVOID.ACHAR
        Read [MWS]WST0 = [F:MFO]EXTWST;[M:VXELP]FCY
        If !fstat
          If [F:MWS]WSTTYP = 3
            Call ERREUR(mess(52,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      #Labor center type cannot be subcontract
      If [F:MFO]EXTLAB <> AVOID.ACHAR
        Read [MWS]WST0=[F:MFO]EXTLAB;[M:VXELP]FCY
        If !fstat
          If [F:MWS]WSTTYP=3
            Call ERREUR(mess(55,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      #Invalid if GCTLOPEPRE = 3 and prior operation has not been run.
      If GCTLOPEPRE > 1
        OPERPREC = 0
        # Find the prior operation number
        Filter [SCH] Where MFGNUM = [M:VXELP]VCRNUM & NEXOPENUM = VALEUR
        Read [SCH]SCH0 First
        Filter [SCH]
        If !fstat : OPERPREC = [F:SCH]OPENUM : Endif
        If OPERPREC<>0
          # Check if prior marked complete in MFG Operations table
           Filter [MFO] Where MFGNUM = [M:VXELP]VCRNUM & OPENUM = OPERPREC
           Read [MFO]MFO0 First
           Filter [MFO]
           If !fstat & [F:MFO]OPESTA < 5
             # This operation is not closed in the MFG tables - see if closed in SFTTXN tables
             Filter [F:SFTX] Where [F:SFTX]VCRNUM = [M:VXELP]VCRNUM &
&                                  [F:SFTX]OPENUM = OPERPREC &
&                                  [F:SFTX]CLEFLG = [V]CST_AYES
             Read [F:SFTX]SFT0 First
             Filter [F:SFTX]
             If fstat <> 0
               ALLOW_IT = [V]CST_ANO
               If GCTLOPEPRE=2
                 Call AVERTIR(mess(22,190,1)-num$([L]OPERPREC),ALLOW_IT) From GESECRAN
               Else
                 Call ERREUR(mess(22,190,1)-num$([L]OPERPREC)) From GESECRAN
               Endif
               If ALLOW_IT=[V]CST_ANO : mkstat = 2 : End : Endif
             Endif
           Endif
         Endif
      Endif
    Else
       #Invalid Operation
      Call ERREUR(mess(58,123,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif

End
######################################################################################
Subprog AM_OPENUM(VALEUR)
Variable Decimal VALEUR

  #Default work center and labor center from the work order
  If [M:VXELP]VCRNUM <> AVOID.ACHAR & VALEUR <> 0
    Filter [MFO] Where MFGNUM = [M:VXELP]VCRNUM & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat
      [M:VXELP]WCENTER   = [F:MFO]EXTWST
      If [F:MFO]EXTLAB <> AVOID.ACHAR
        Actzo [M:VXELP]LCENTER
        [M:VXELP]LCENTER   = [F:MFO]EXTLAB
      Else
        Raz [M:VXELP]LCENTER
        Grizo [M:VXELP]LCENTER
      Endif
#      [M:VXELP]NUMMAC       = [F:MFO]EXTWSTNBR  # Expected machines    # TODAN-119090.o
      [M:VXELP]SETTIMUOMCOD = [F:MFO]TIMUOMCOD  # Time unit
      [M:VXELP]RUNTIMUOMCOD = [F:MFO]TIMUOMCOD  # Time unit
      [M:VXELP]CPLOPEUOM    = [F:MFO]OPEUOM     # Operation unit
      [M:VXELP]REJOPEUOM    = [F:MFO]OPEUOM     # Operation unit
    Endif
  Endif

  # Read Work centers table
  Read [MWS]WST0 = [F:MFO]EXTWST;[M:VXELP]FCY
  If !fstat #TTD-1632
    # Get modified work center and labor center from the SFTTXN, if exists.
    #add [F:MWS]WSTTYP
    Call GET_SFT_WC_LC([M:VXELP]VCRNUM, VALEUR, [F:MWS]WSTTYP, [F:MFO]EXTWST,
&                       [F:MFO]EXTLAB, [M:VXELP]WCENTER, [M:VXELP]LCENTER) From SFTLIB

    # Get Work center type for the primary work center
    # and enable/disable the Machines field accordingly.
    If [F:MFO]EXTWST <> AVOID.ACHAR
      #Read [MWS]WST0 = [F:MFO]EXTWST;[M:VXELP]FCY #Moved to before GET_SFT_WC_LC
  #    If !fstat #TTD-1632
        [M:VXELP]WSTTYP = [F:MWS]WSTTYP
        If [M:VXELP]WSTTYP = 2      # Labor type
#          Raz [M:VXELP]NUMMAC            # TODAN-119090
          [M:VXELP]NUMMAC = [V]CST_ANO    # TODAN-119090
          Grizo [M:VXELP]NUMMAC
        Else                        # Machine type
          [M:VXELP]NUMMAC = [V]CST_AYES   # TODAN-119090
          Actzo [M:VXELP]NUMMAC
        Endif
  #    Endif  #TTD-1632
    Endif
  Endif
  Affzo [M:VXELP]WCENTER, LCENTER, NUMMAC, SETTIMUOMCOD, RUNTIMUOMCOD, CPLOPEUOM, REJOPEUOM, WSTTYP
End
######################################################################################
# TODAN-119090.n
Subprog C_NUMMAC(VALEUR)
Variable Integer VALEUR

  # Do not allow machine uncheck when the primary wc type is a machine and labor center is blank
  If VALEUR = [V]CST_ANO & [M:VXELP]WSTTYP = 1 & [M:VXELP]LCENTER = AVOID.ACHAR
    Call ERREUR(mess(30,2422,1)) From GESECRAN
    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog C_WCENTER(VALEUR)
Variable Char    VALEUR()

  # Verify if the WC exist
  Read [MWS]WST0 = VALEUR; [M:VXELP]FCY
  If fstat  # Not found
    GERR=1 : GMESSAGE = VALEUR - tolower(mess(196,193,1))
    mkstat = 2
    End
  Else      # Found
    # WC has to be the same type as the default WC
    If [F:MWS]WSTTYP <> [M:VXELP]WSTTYP
       #CT-1797.sn
       #GERR=1 : GMESSAGE = VALEUR - mess(47,2422,1) : mkstat=2 : End
       Call ERREUR(func AFNC.MES1(mess(47,2422,1), VALEUR)) From GESECRAN
       mkstat = 2
       End
       #CT-1797.en
    Endif
  Endif

End
######################################################################################
Subprog C_LCENTER(VALEUR)
Variable Char    VALEUR()

  # Labor wc is required if one existed
  If VALEUR = AVOID.ACHAR & [M:VXELP]LCENTER <> AVOID.ACHAR
    GERR=1 : GMESSAGE = mess(48,2422,1) : mkstat = 2 : End
  Endif

  # Labor wc cannot be the same as the work center
  If VALEUR = [M:VXELP]WCENTER
    GERR=1 : GMESSAGE=mess(26,193,1) : mkstat=2 : End
  Endif

  # Labor wc valid for the site?
  Read [MWS]WST0 = VALEUR; [M:VXELP]FCY
  If fstat  # Not found
    GERR=1 : GMESSAGE = VALEUR - tolower(mess(44,2422,1)) : mkstat=2 : End
  Else      # Found
    # Not allow a wc that is not a labor type
    If [F:MWS]WSTTYP <> 2
       GERR=1 : GMESSAGE = VALEUR - mess(4,193,1) : mkstat = 2 : End
    Endif
  Endif
End
######################################################################################
Subprog AM_CPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer OK, CPLQTY_HIGHER,  OPERCLOSE

  OPERCLOSE = [V]CST_ANO

  # Check if the completed qty and more than the estimated/planned qty
  Call VAL_COMPLETEQTY([M:VXELP]VCRNUM,[M:VXELP]OPENUM,VALEUR, CPLQTY_HIGHER, OPERCLOSE) From SFTLIB
  If CPLQTY_HIGHER = [V]CST_AYES
    Call AVERTIR(mess(54,190,1),OK) From GESECRAN   # Actual quantity larger than estimated quantity. Continue?
    If OK = 1     # Cancel
      mkstat = 2
      End
    Endif
  Endif

  # Assign and refresh Close value
  [M:VXELP]CLEFLG = OPERCLOSE
  Affzo [M:VXELP]CLEFLG
  # Enable/disable rejected field
  Call REJECTQTY(VALEUR)
  # Enable/disable the rejected code field
  Call REJECTCODE([M:VXELP]REJCPLQTY)

End
######################################################################################
Subprog C_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

  # Display message when rejected qty is > completed qty
  If VALEUR > [M:VXELP]CPLQTY
    GERR=1 : GMESSAGE = mess (25,2422,1)
    mkstat = 2
  Endif

End
######################################################################################
Subprog AM_REJCPLQTY(VALEUR)
Variable Decimal VALEUR
    # Enable/disable rejected code field
    Call REJECTCODE(VALEUR)
End
######################################################################################
Subprog C_SCANUM(VALEUR)
Variable Decimal VALEUR

  Local Char WSCANUM(12) : WSCANUM = num$(VALEUR)
  # Reason code valid?
  If VALEUR <> 0
    Call CONTROLE("TSR","",WSCANUM,"",mkstat) From CONTOBJ
  Endif

End
######################################################################################
Subprog CLEAR_FIELDS

  Raz [M:VXELP]OPENUM, NUMMAC, WCENTER, LCENTER, SETDURATION, SETTIMUOMCOD, RUNDURATION,
&             RUNTIMUOMCOD, CPLQTY, CPLOPEUOM, REJCPLQTY, REJOPEUOM, SCANUM, CLEFLG
  Affzo [M:VXELP]OPENUM, NUMMAC, WCENTER, LCENTER, SETDURATION, SETTIMUOMCOD, RUNDURATION,
&               RUNTIMUOMCOD, CPLQTY, CPLOPEUOM, REJCPLQTY, REJOPEUOM, SCANUM, CLEFLG

End
######################################################################################
Subprog REJECTCODE(I)
Value Decimal I

  If I > 0
    Actzo [M:VXELP]SCANUM
  Else
    Raz [M:VXELP]SCANUM
    Grizo [M:VXELP]SCANUM
  Endif
  Affzo [M:VXELP]SCANUM

End
######################################################################################
Subprog REJECTQTY(I)
Value Decimal I

  If I > 0
    Actzo [M:VXELP]REJCPLQTY
  Else
    Raz [M:VXELP]REJCPLQTY
    Grizo [M:VXELP]REJCPLQTY
  Endif
  Affzo [M:VXELP]REJCPLQTY

End
####################################################################################
$OK

  Local Char    START_WONUM(20)(1..1), START_WCENTER(8)(1..1)
  Local Char    START_LCENTER(8)(1..1), START_UOM(3)(1..1)
  Local Integer I, START_COUNT, START_OPENUM(1..1), START_NUMMAC(1..1)
  Local Integer START_NUMJOBS(1..1), START_REJECTEDCODE(1..1), START_CLOSE(1..1)
  Local Decimal START_SETUPDURATION(1..1), START_RUNDURATION(1..1)
  Local Decimal START_COMPLETEQTY(1..1), START_REJECTEDQTY(1..1)
  Local Integer MY_STATUS

  If [M:VXELP]SETDURATION = 0 & [M:VXELP]RUNDURATION = 0 & [M:VXELP]CPLQTY = 0
    Call ERREUR(func AFNC.MES1(mess(91,2422,1), [M:VXELP]VCRNUM+" "+num$([M:VXELP]OPENUM))) From GESECRAN
    FIN = 0
    Return
  Endif

  # Add the record to a collection
  START_COUNT = 1
  START_WONUM(START_COUNT)            = [M:VXELP]VCRNUM
  START_OPENUM(START_COUNT)           = [M:VXELP]OPENUM
  START_NUMMAC(START_COUNT)           = [M:VXELP]NUMMAC
  START_NUMJOBS(START_COUNT)          = 1                # Default to 1. No # of job here...
  START_WCENTER(START_COUNT)          = [M:VXELP]WCENTER
  START_LCENTER(START_COUNT)          = [M:VXELP]LCENTER
  # Check Time unit, convert setup duration to minutes if needed.
  If [M:VXELP]SETTIMUOMCOD = 1
    START_SETUPDURATION(START_COUNT)  = [M:VXELP]SETDURATION * 60
  Else
    START_SETUPDURATION(START_COUNT)  = [M:VXELP]SETDURATION
  Endif
  # Check Time unit, convert run duration to minutes if needed.
  If [M:VXELP]RUNTIMUOMCOD = 1
    START_RUNDURATION(START_COUNT)    = [M:VXELP]RUNDURATION * 60
  Else
    START_RUNDURATION(START_COUNT)    = [M:VXELP]RUNDURATION
  Endif
  START_COMPLETEQTY(START_COUNT)      = [M:VXELP]CPLQTY
  START_UOM(START_COUNT)              = [M:VXELP]CPLOPEUOM
  START_REJECTEDQTY(START_COUNT)      = [M:VXELP]REJCPLQTY
  START_REJECTEDCODE(START_COUNT)     = [M:VXELP]SCANUM
  START_CLOSE(START_COUNT)            = [M:VXELP]CLEFLG

  # Start the operations...
    #--- Shop floor tracking transaction class ---
    Local Instance SFTTXN Using C_SFTTXN
    SFTTXN = NewInstance C_SFTTXN AllocGroup null

    # Start the elapsed labor operation(s)
    MY_STATUS = fmet SFTTXN.TIME_TRACKING([M:VXELP]EMPNUM, [M:VXELP]FCY, START_WONUM, START_OPENUM,
&                                         START_NUMMAC, START_NUMJOBS, START_WCENTER, START_LCENTER,
&                                         START_SETUPDURATION, START_RUNDURATION, START_COMPLETEQTY,
&                                         START_UOM, START_REJECTEDQTY, START_REJECTEDCODE, START_CLOSE,
&                                         START_COUNT)

    # Check if the operation start successfully
    If MY_STATUS >= [V]CST_AERROR
      Call ERREUR(SFTTXN.AERROR.MES) From GESECRAN
    Endif

    Call MESSAGE(func AFNC.MES1(mess(93,2422,1), [M:VXELP]VCRNUM+" "+num$([M:VXELP]OPENUM))) From GESECRAN

    FreeGroup SFTTXN
    Kill SFTTXN
Return
######################################################################################

