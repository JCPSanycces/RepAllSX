#---------------------------------------#
Funprog ACTIV(COD)
Value Char COD
Local Integer DIME
Gosub ACTIV_DIME
End [L]DIME

#---------------------------------------#
Funprog ACTIVDOS(DOS,COD)
Value Char DOS
Value Char COD
Local Integer DIME
Gosub ACTIV_DIME
End [L]DIME

#-----------#
$ACTIV_DIME
If [L]COD=""
 [L]DIME = 1
Else
 If dim([L]DOS)<=0 or (dim([L]DOS) >= 0 & [L]DOS="")
  Local File ACTIV [ACV]
 Else
  Local File =[L]DOS+".ACTIV" [ACV]
 Endif
 Read [ACV]CODACT = COD
 If fstat or [F:ACV]FLACT<>2
  [L]DIME = 0
 Elsif [F:ACV]TYP=2
  [L]DIME = [F:ACV]DIME
 Else
  [L]DIME = 1
 Endif
Endif
Return


######################################################################
## Pour remplacer la balise # dans les mess(x,y,z)
######################################################################
Funprog MES(MESSAGE,VALEUR)
Value Char MESSAGE , VALEUR
Local Integer K
K = instr(1,MESSAGE,"#")
If K
 End left$(MESSAGE,K-1)+VALEUR+right$(MESSAGE,K+1)
Else
 End MESSAGE-VALEUR
Endif
End

######################################################################
## Pour remplacer la balise $1$ dans les mess(x,y,z)
######################################################################
Funprog MES1(MESSAGE,VAL1)
Value Char MESSAGE , VAL1
Goto MES0

######################################################################
## Pour remplacer les balises $1$ $2$ dans les mess(x,y,z)
######################################################################
Funprog MES2(MESSAGE,VAL1,VAL2)
Value Char MESSAGE , VAL1 , VAL2
Goto MES0

######################################################################
## Pour remplacer les balises $1$ $2$ $3$ dans les mess(x,y,z)
######################################################################
Funprog MES3(MESSAGE,VAL1,VAL2,VAL3)
Value Char MESSAGE , VAL1 , VAL2 , VAL3
Goto MES0

######################################################################
## Pour remplacer les balises $1$ $2$ $3$ dans les mess(x,y,1)
######################################################################
Funprog M(MES,CHAP,VAL1,VAL2,VAL3)
Value Integer MES, CHAP
Value Char VAL1 , VAL2 , VAL3
Local Char MESSAGE(255)
MESSAGE = mess(MES,CHAP,1)
Goto MES0

######################################################################
## Pour remplacer les balises $1$ $2$ $3$ $4$ dans les mess(x,y,z)
######################################################################
Funprog MES4(MESSAGE,VAL1,VAL2,VAL3,VAL4)
Value Char MESSAGE , VAL1 , VAL2 , VAL3 , VAL4
Goto MES0

######################################################################
## Pour remplacer les balises $1$ $2$ $3$ $4$ $5$ dans les mess(x,y,z)
######################################################################
Funprog MES5(MESSAGE,VAL1,VAL2,VAL3,VAL4,VAL5)
Value Char MESSAGE , VAL1 , VAL2 , VAL3 , VAL4 , VAL5
Goto MES0

$MES0
Local Integer I , K
For I=1 To 5
 If evalue("dim(VAL"+num$(I)+")")>0
  K = instr(1,MESSAGE,evalue('"$"+num$(I)+"$"'))
  If K
   MESSAGE = left$(MESSAGE,K-1)+evalue("VAL"+num$(I))+right$(MESSAGE,K+3)
  Endif
 Endif
Next I
End MESSAGE

######################################################################
## Pour remplacer les balises $1$ à $n$ dans les mess(x,y,z)
######################################################################
Funprog MESN(MESSAGE,VALN)
Value Char MESSAGE , VALN
Goto MES_N

Funprog MESNC(MESSAGE,VALN)
Value Clbfile MESSAGE
Value Char VALN
Goto MES_N

$MES_N
Local Integer I , K
I = 0
While VALN<>""
 I += 1
 K = instr(1,VALN,"~")
 If K
  TEXTE = left$(VALN,K-1)
  VALN  = right$(VALN,K+1)
 Else
  TEXTE = VALN
  VALN = ""
 Endif
 K = instr(1,MESSAGE,evalue('"$"+num$(I)+"$"'))
 If K
  MESSAGE = left$(MESSAGE,K-1)+TEXTE+right$(MESSAGE,K+3)
 Endif
Wend
End MESSAGE


######################################################################
######################################################################
Subprog NUMEROFRA(VALEUR,NUM)
Value    Char    VALEUR
Variable Integer NUM

If dim(GLANGUE)>0 :
 Call NUMEROFRA(VALEUR,NUM) From OBJDIV
Else
 If dim(GACTX.LAN)<0  : NUM = 0 : End : Endif
 If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
 Read [ATX]CLEREC = GACTX.LAN;left$(vireblc(toupper(ctrans(VALEUR)),4),20)
 If !fstat
  NUM = [F:ATX]NUMERO
 Endif
Endif
End

#**
#* TEXTE(NUMERO): syracuse implementation of AFNC.TEXTE()
#*
#* @param NUMERO
#*!
Funprog TEXTE(NUMERO)
Value Integer NUMERO
If dim(GACTX.LAN)<0  : End "" : Endif
If dim(GACTX.AFOLD.ALANGDEF)<0  : End "" : Endif

If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Read [ATX]NUMERO = GACTX.LAN;NUMERO
If !fstat
 End [F:ATX]TEXTE
Else
 Read [ATX]NUMERO = GACTX.AFOLD.ALANGDEF;NUMERO
 If !fstat
  End [F:ATX]TEXTE
 Else
  End ""
 Endif
Endif
End

####################################################
## Texte traduisible
####################################################
Funprog TEXTRA(TABLE,CHAMP,CLE1,CLE2)
Value Char TABLE
Value Char CHAMP
Value Char CLE1
Value Char CLE2
Local Char TEXTRA(80)
Call LECTEXTRA(GACTX,"",TEXTRA,TABLE,CHAMP,CLE1,CLE2)
End TEXTRA


#--------------------------------------------#
$ACTIONB_TEXTRA
Local Integer PSUB
Call EXISTE_ADX("","","ATEXTRAB",PSUB) From ASYRSYS
If PSUB
 Gosub ACTION From ATEXTRAB
Endif
Return

Subprog LECTEXTRA(AINSTANCE,APRONAME, AVALUE,TABLE,CHAMP,CLE1,CLE2)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value    Char    TABLE, CHAMP, CLE1, CLE2

Local    Char    ACTION(20)
Local Integer    OK
# If GPRODUIT=1 : Gosub MODIF_CLE : Endif : # Géode
OK = 1
#110009
#ACTION = "LECTEXTRA" : Gosub ACTIONB_TEXTRA
ACTION = "LECTEXTRASYR" : Gosub ACTIONB_TEXTRA
If !OK : End : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If dim(AINSTANCE.ACTX.LAN) >0
Read [AXX]AXX0 = TABLE;CHAMP;AINSTANCE.ACTX.LAN;CLE1;CLE2
Else
Read [AXX]AXX0 = TABLE;CHAMP;GACTX.LAN;CLE1;CLE2
Endif
If fstat=0
 AVALUE = [F:AXX]TEXTE
Else
 If dim(AINSTANCE.ACTX.AFOLD.ALANGDEF)>0
 Read [AXX]AXX0 = TABLE;CHAMP;AINSTANCE.ACTX.AFOLD.ALANGDEF;CLE1;CLE2
 Else
 Read [AXX]AXX0 = TABLE;CHAMP;GACTX.AFOLD.ALANGDEF;CLE1;CLE2
 Endif
 If fstat=0
  AVALUE = [F:AXX]TEXTE
 Else
  AVALUE = ""
 Endif
Endif
End

######################################################################

#**
#* PARSE_WHERE(CHAINE,PARAM,PARTYPE,VALBEG,STRICTBEG,VALEND,STRICTEND,ERR,MSG)
#*   Analyses a Sdata Where clause with the following restrictions :
#*   - it can only be a list of expressions in the following list
#*      parameter operator value               (operator can be lt, le, gt, ge, eq)
#*      parameter between value1 and value2
#*   - and they can only be separated by "and" and not "or"
#*
#*   The main purpose of this routine is to get a list of parameters (PARAM),
#*   with the associated data type (PARTYPE, corresponds to local menu #30, with 13 corresponding to boolean),
#*   two values (VALBEG and and VALEND),
#*   and 2 indicators (STRICTBEG, STRICTEND) (0=no value in VALBEG/END, 1=strict comparizon, 2=can be equal)
#*   ERR is equel to 0 if OK, otherwise a number is given, related to the message error stored in
#*   chapter 146 of messages; MSG contains a complement if necessary
#*
#*   Values can be predefined in PARAM before calling the program, with the right PARTYPE filled
#*   This allows a more strict parameter control
#*
#*   The data type uses local menu 30 definition, with a special value (13) for boolean
#*   All parameter types are allowed except the blobs (9) :
#*    (1=local menu, 2=shortint, 3=long, 4=decimal, 5=floating point, 6=double, 7=char,
#*     8=date, 10=clob, 11=uuid, 12=datetime)
#*   The datetime must be in GMT format only (YYYY-MM-DDTHH:MM:SSZ)
#*!

Subprog PARSE_WHERE(CHAINE,PARAM,PARTYPE,VALBEG,STRICTBEG,VALEND,STRICTEND,ERR,MSG)
Value Clbfile CHAINE
Variable Char PARAM()(1..)
Variable Libelle PARTYPE(1..) : # Local menu 30 with a value equal to 13 for booleans
Variable Libelle STRICTBEG(1..),STRICTEND(1..)
Variable Char VALBEG()(1..),VALEND()(1..)
Variable Integer ERR
Variable Char MSG()

Local Integer I,NUMPAR,FOUND,PARENTHESIS,OK
Local Char C(1),OPERATOR(20),VALE(250), PAR(30)
Local Libelle IFDEB(1..dim(VALBEG)),IFEND(1..dim(VALEND)) : # set to 1 if a value was given

# For character recognition
Local Char CARVARNAME(100)
  CARVARNAME="$abcdefghijklmnopqrstuvwxyz_ABCEDFGHIJKLMNOPQRSTUVWXYZ"
Local Char CARDIGITS(20)
  CARDIGITS="+-.0123456789"

  Raz ERR, MSG, PARENTHESIS

# Skip trailing spaces
  Repeat I+=1 Until mid$(CHAINE,I,1)<>" "

  C=mid$(CHAINE,I,1)
  While C<>""
    While C="("
      PARENTHESIS+=1 : Repeat I+=1 : C=mid$(CHAINE,I,1) Until C<>" "
    Wend
    NUMPAR=0
    Repeat NUMPAR+=1 Until NUMPAR>dim(PARAM) or PARAM(NUMPAR)='' or toupper(mid$(CHAINE,I,len(PARAM(NUMPAR))))=toupper(PARAM(NUMPAR))
    If NUMPAR>dim(PARAM)
       ERR=6 : MSG=CHAINE : Break
    Else
      If PARAM(NUMPAR)=''
        PAR=''
        While C<>"" and instr(1,CARVARNAME+string$(PAR<>"","012356789"),C)
          PAR+=C
          I+=1
          C=mid$(CHAINE,I,1)
        Wend
        PARAM(NUMPAR)=PAR
        PARTYPE(NUMPAR)=0
      Else
        I+=len(PARAM(NUMPAR))
      Endif
    Endif
    While mid$(CHAINE,I,1)=" " : I+=1 : Wend
    FOUND=0
    For OPERATOR="eq","ge","gt","le","lt", "between"
      If toupper(mid$(CHAINE,I,len(OPERATOR)))=toupper(OPERATOR)
        FOUND=1 : Break
      Endif
    Next
    If FOUND
      I+=len(OPERATOR)
      Gosub FETCH_CONST
      Break (ERR<>0)
      If find(toupper(OPERATOR),"GE","EQ","BETWEEN","GT")
        If STRICTBEG(NUMPAR)=0 : VALBEG(NUMPAR)=VALE : STRICTBEG(NUMPAR)=1+(find(toupper(OPERATOR),"GT")<>0)
        Elsif find(PARTYPE(NUMPAR),1,2,3,4,5,6)
          If val(VALBEG(NUMPAR))<val(VALE) or (val(VALBEG(NUMPAR))=val(VALE) and STRICTBEG(NUMPAR)=2)
            VALBEG(NUMPAR)=VALE : STRICTBEG(NUMPAR)=1+(find(toupper(OPERATOR),"GT")<>0)
          Endif
        Elsif VALBEG(NUMPAR)<VALE or (VALBEG(NUMPAR)=VALE and STRICTBEG(NUMPAR)=2)
          VALBEG(NUMPAR)=VALE : STRICTBEG(NUMPAR)=1+(find(toupper(OPERATOR),"GT")<>0)
        Endif
      Endif
      If toupper(OPERATOR)="BETWEEN"
        While mid$(CHAINE,I,1)=" " : I+=1 : Wend
        If toupper(mid$(CHAINE,I,3))="AND"
          I+=3
          Gosub FETCH_CONST
          If ERR : Break : Endif
        Else
          ERR=7 : Break
        Endif
      Endif
      If find(toupper(OPERATOR),"LT","BETWEEN","EQ","LE")
        If STRICTEND(NUMPAR)=0 : VALEND(NUMPAR)=VALE : STRICTEND(NUMPAR)=1+(find(toupper(OPERATOR),"LT")<>0)
        Elsif find(PARTYPE(NUMPAR),1,2,3,4,5,6)
          If val(VALEND(NUMPAR))>val(VALE) or (val(VALEND(NUMPAR))=val(VALE) and STRICTEND(NUMPAR)=2)
            VALEND(NUMPAR)=VALE : STRICTEND(NUMPAR)=1+(find(toupper(OPERATOR),"LT")<>0)
          Endif
        Elsif VALEND(NUMPAR)>VALE or (VALEND(NUMPAR)=VALE and STRICTEND(NUMPAR)=2)
          VALEND(NUMPAR)=VALE : STRICTEND(NUMPAR)=1+(find(toupper(OPERATOR),"LT")<>0)
        Endif
      Endif
    Else
      ERR=8 : Break
    Endif

    While mid$(CHAINE,I,1)=" " : I+=1 : Wend

    C=mid$(CHAINE,I,1)
    While C=")"
      PARENTHESIS-=1 : Repeat I+=1 : C=mid$(CHAINE,I,1) Until C<>" "
    Wend

    If C<>""
      If toupper(mid$(CHAINE,I,3))<>"AND"
         ERR=9 : Break
      Else
        I+=3
      Endif
      C=mid$(CHAINE,I,1) : While C=" " : I+=1 : C=mid$(CHAINE,I,1) : Wend
    Endif
  Wend
  If ERR : End : Endif
  If PARENTHESIS<0
    ERR=10 : MSG=num$(abs(PARENTHESIS))
  Elsif PARENTHESIS>0
    ERR=11 : MSG=num$(abs(PARENTHESIS))
  Endif
End

# NUMPAR can be known or not
$FETCH_CONST
  VALE=""
  While mid$(CHAINE,I,1)=" " : I+=1 : Wend
  Case PARTYPE(NUMPAR)
    When 1,2,3,4,5,6
      C=mid$(CHAINE,I,1)
      While C<>"" and instr(1,CARDIGITS,C)
        If find(C,"+","-")
          If VALE<>"" : ERR=12 : Break : Endif
            VALE=C
            While mid$(CHAINE,I+1,1)=" " : I+=1 : Wend
        Elsif C="."
          If find(PARTYPE(NUMPAR),1,2,3)
            ERR=13 : Break
          Elsif VALE="" : VALE="0."
          Elsif instr(1,VALE,".")
            ERR=12 : Break
          Else VALE+="."
          Endif
        Else VALE+=C
        Endif
        I+=1
        C=mid$(CHAINE,I,1)
        If PARTYPE(NUMPAR)=1 and (val(VALE)<0 or val(VALE)>255)
&       or PARTYPE(NUMPAR)=2 and (val(VALE)<-32767 or val(VALE)>32768)
&       or PARTYPE(NUMPAR)=2 and (val(VALE)<-2^31-1 or val(VALE)>2^31)
          ERR=14
        Endif
      Wend
      If len(VALE)=0 or (VALE<>"0" and sigma(1,9,instr(1,VALE,num$(indcum)))=0) : # case VALE equal 0
        ERR=12
      Endif
    When 7,10,11
      C=mid$(CHAINE,I,1)
      If C<>"'" : ERR=15
      Else
        I+=1
        C=mid$(CHAINE,I,1)
        While C<>"'" and C<>""
          If C="" : ERR=15 : Break : Endif
          If C="\" : I+=1 : C=mid$(CHAINE,I,1) : Endif
          VALE+=C : I+=1 : C=mid$(CHAINE,I,1)
        Wend
        If C="" : ERR=15
        Else I+=1
        Endif
      Endif
      If PARTYPE(NUMPAR)=11
        Gosub CHECKUUID
        If OK=0 : ERR=16 : Return : Endif
      Endif
    When 8
      C=mid$(CHAINE,I,1)
      If C<>"@" : ERR=17 : Return
      Else
        Repeat I+=1 : C=mid$(CHAINE,I,1) Until C<>" "
        If pat(mid$(CHAINE,I,10),"####-##-##")=0
          ERR=17 : Return
        Else
          VALE=mid$(CHAINE,I,10)
          I+=10
        Endif
        C=mid$(CHAINE,I,1)
        If C<>'@'
          ERR=17 : Return
        Else
          I+=1
        Endif
      Endif
    When 12
      C=mid$(CHAINE,I,1)
      If C<>"@" : ERR=17 : Return
      Else
        Repeat I+=1 : C=mid$(CHAINE,I,1) Until C<>" "
        If pat(mid$(CHAINE,I,20),"####-##-##T##:##:##Z")=0
          ERR=18 : Return
        Else
          VALE=mid$(CHAINE,I,20)
          I+=20
        Endif
        C=mid$(CHAINE,I,1)
        If C<>'@'
          ERR=17 : Return
        Else
          I+=1
        Endif
      Endif
      When 13 : # True/false
        If toupper(mid$(CHAINE,I,4))="TRUE"
            I+=4 : VALE="2"
        Elsif toupper(mid$(CHAINE,I,5))="FALSE"
            I+=5 : VALE="1"
        Else
            ERR=19
        Endif
      When 9 : # Blob
        ERR=20
      When 0 : # Unknown
        C=mid$(CHAINE,I,1)
        If C="'"
          VALE=mid$(CHAINE,I,36)
          If len(VALE)=36 and mid$(CHAINE,I,37)="'"
            Gosub CHECKUUID
            If OK
              I+=38
              PARTYPE(NUMPAR)=8
              Return
            Endif
          Endif
          PARTYPE(NUMPAR)=7
          Gosub FETCH_CONST
        Elsif C='@'
          PARTYPE(NUMPAR)=8
          Gosub FETCH_CONST
        Elsif instr(1,CARDIGITS,C)
          PARTYPE(NUMPAR)=4
          Gosub FETCH_CONST
        Elsif toupper(mid$(CHAINE,I,5))="FALSE" or toupper(mid$(CHAINE,I,4))="TRUE"
          PARTYPE(NUMPAR)=13
          Gosub FETCH_CONST
        Endif
      When Default
        ERR=21
  Endcase
Return

$CHECKUUID
  VALE=tolower(vireblc(format$("K:8HX4HX4HX4HX12H",VALE),4))
  OK=(len(VALE)=36 & mid$(VALE,9,1)="-" & mid$(VALE,14,1)="-" & mid$(VALE,19,1)='-' & mid$(VALE,24,1)='-')
Return

#
# Written by DOM
# Routine that transforms an URL extension in a JSON
# A test case will be developed later
#
Subprog URLJS(URL,JSON,ERRCODE)
Variable Clbfile URL
Variable Clbfile JSON
Variable Char ERRCODE

Local Integer I,J0,J,K,L,M
Local Char PILE(250)
Local Integer LENURL

  Gosub TRS_TBL1

  ERRCODE=""
  If left$(URL,1)<>"~" : ERRCODE="~ missing" : End : Endif
  LENURL=len(URL)
  I=2
  While I<=LENURL and ERRCODE=""
    Gosub OBJET
  Wend
End

$OBJET
  C=mid$(URL,I,1)
  If C="("
    I+=1 : C=mid$(URL,I,1)
    If C="~"
        I+=1 : C=mid$(URL,I,1) : Append JSON,"["
        Gosub LISTE
        Append JSON,"]" : I+=1 : C=mid$(URL,I,1)
    Else
        Append JSON,"{"
        Gosub OBJET
        Append JSON,"}" : C=mid$(URL,I,1)
    Endif
  Else
    While C<>")"
        I+=(C="'") : Append JSON,'"'
        Gosub VALEUR
        Append JSON,'":' : I+=1 : C=mid$(URL,I,1)
        Gosub VALCHAINE
        C=mid$(URL,I,1)
        If C="~" : Append JSON,"," : I+=1 : Endif
    Wend
    I+=1 : C=mid$(URL,I,1)
  Endif
Return

$VALCHAINE
  If C="'"
    Append JSON,'"'
    I+=1
    C=mid$(URL,I,1)
    Gosub VALEUR
    Append JSON,'"'
  Else
    Gosub VALEUR
  Endif
Return

$VALEUR
  If C="(" : Goto OBJET : Endif
  J=instr(I,URL,"~") : K=instr(I,URL,")") : L=instr(I,URL,"*")
  If J=0
    J=LENURL
    If K=0 : ERRCODE="Unbalanced string constant" : Return : Endif
  Elsif K=0
    K=LENURL
  Endif
  J=min(J,K)
  While L & L<J
    If mid$(URL,L,2)="**"
        Append JSON,ctrans(mid$(URL,I,L-I),"!","$")
        Append JSON,chr$(4096*ASCI(ascii(toupper(mid$(URL,L+2,1)))-48)+256*ASCI(ascii(toupper(mid$(URL,L+3,1)))-48)
&                       +16*ASCI(ascii(toupper(mid$(URL,L+4,1)))-48)+ASCI(ascii(toupper(mid$(URL,L+5,1)))-48))
        I=L+6
    Else
        Append JSON,ctrans(mid$(URL,I,L-I),"!","$")
        Append JSON,chr$(16*ASCI(ascii(toupper(mid$(URL,L+1,1)))-48)+ASCI(ascii(toupper(mid$(URL,L+2,1)))-48))
        I=L+3
    Endif
    L=instr(I,URL,"*")
  Wend
  Append JSON,ctrans(mid$(URL,I,J-I),"!","$")
  I=J
Return

$LISTE
  If C<>")"
    Gosub VALCHAINE
    C=mid$(URL,I,1)
    While C="~"
        Append JSON,","
        I+=1
        C=mid$(URL,I,1)
        Gosub VALCHAINE
        C=mid$(URL,I,1)
    Wend
  Endif
Return

$TRS_TBL1
Local Libelle ASCI(23)
  ASCI(0)=0 : ASCI(1)=1 : ASCI(2)=2 : ASCI(3)=3 : ASCI(4)=4 : ASCI(5)=5 : ASCI(6)=6 : ASCI(7)=7 : ASCI(8)=8 : ASCI(9)=9
  ASCI(17)=10 : ASCI(18)=11 : ASCI(19)=12 : ASCI(20)=13 : ASCI(21)=14 : ASCI(22)=15
Return

######################################################################
# Add criteria
#########################################################################
Funprog ADDCRIT(AINSTANCE,CRIT,ICRIT,VARIA,COND,OPE,AFLGERR)
Variable Instance AINSTANCE Using OBJECT
Variable Char    CRIT()() : # Critère principal
Variable Integer ICRIT    : # Indice critère
Value    Char    VARIA    : # Commentaire en cas d'erreur
Value    Char    COND     : # Critère à rajouter
Value    Char    OPE      : # Opérateur de concaténation (&,|)
Value Integer   AFLGERR  : # creation message erreur oui non
Local    Integer TYP , OK , ASTATUS
Local    Char    SEP(255)
If ICRIT<0 | COND="" : End : Endif
TYP = mod(type(CRIT)-10,256)
If CRIT<>""
 SEP = OPE
Endif
OK = 1
While len(CRIT(ICRIT))+len(SEP)+len(COND)>TYP
 If ICRIT<dim(CRIT)-1
  ICRIT += 1
 Else
  OK = 0 : Break
 Endif
Wend
If OK
 If find(tolower(OPE),"&","|","and","or") & left$(vireblc(COND,0),len(OPE))=OPE
  CRIT(ICRIT) += COND : # Pour ne pas rajouter 2 fois l'opérateur de concaténation
 Else
  CRIT(ICRIT) += SEP+COND
 Endif
Else
 # Critères trop nombreux
 If AFLGERR>0
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,VARIA+"("+num$(ICRIT)+") :"-mess(199,133,1))
 Endif
 Raz CRIT : ICRIT=-1
 End [V]CST_AERROR
Endif
End [V]CST_AOK

# OBject tagging
Subprog SET_TYPOBJ(AFOLDER,NBTYP,TYPOBJ)
Value Char AFOLDER
Variable Integer NBTYP
Variable Char TYPOBJ()(1..)
Local File =AFOLDER+".ATABDIV" [AD97]
NBTYP = 0
For [AD97] Where NUMTAB=97 & ENAFLG=2
 NBTYP += 1
 TYPOBJ(NBTYP) = [AD97]CODE
Next
Close Local File [AD97]
End

# Dev group
Subprog SET_CTLOBJ(AFOLDER,NBCTL,CTLOBJ)
Value Char AFOLDER
Variable Integer NBCTL
Variable Char CTLOBJ()(1..)
Local File =AFOLDER+".ATABDIV" [AD97]
NBCTL = 0
For [AD97] Where NUMTAB=97 & ENAFLG=2 & N1=2
 NBCTL += 1
 CTLOBJ(NBCTL) = [AD97]CODE
Next
Close Local File [AD97]
End



#**
#* Update the ETag used when updating user's rights
#*
#* @param DOS
#*!
Subprog UPDATE_RIGHTSETAG(DOS)
Value Char DOS

Onerrgo ERRUPD

 If dim([L]DOS)<=0 or [L]DOS=""
  Local File ADOVAL [ADW_]
 Else
  Local File =[L]DOS+".ADOVAL" [ADW_]
 Endif

 If !adxlog
  Gosub AUPDATE_TR_ETAG
 Else
  Gosub AUPDATE_ETAG
 Endif
 Close Local File [ADW_]
Onerrgo
End

$ERRUPD
Resume

$AUPDATE_TR_ETAG
Trbegin [ADW_]
Gosub AUPDATE_ETAG
Commit
Return

$AUPDATE_ETAG
Read [ADW_]ADW0= "";"";"RIGHTSETAG"
[ADW_]VALEUR = num$(datetime$)
If fstat
 [ADW_]PARAM = "RIGHTSETAG"
 Write [ADW_]
Else
 Rewrite [ADW_]
Endif
Return

#**
#* Get the ETag used when updating user's rights
#*
#*!
Funprog READ_RIGHTSETAG(DOS)
Value Char DOS

Local Char ETAG(20) : ETAG=""

If dim([L]DOS)<=0 or [L]DOS=""
 Local File ADOVAL [ADW_]
Else
 Local File =[L]DOS+".ADOVAL" [ADW_]
Endif

Read [ADW_]ADW0= "";"";"RIGHTSETAG"
If !fstat
 ETAG = [ADW_]VALEUR
Endif
Close Local File [ADW_]
End ETAG

#**
#* Get the URL based on the parameters on classic function
#* Example :
#* Local Char FUNCTION(GLONAFC),TABKEY(50)(1..10),TABVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
#* Local Clbfile WURL
#* Local Integer ASTATUS
#* FUNCTION = "GESAFC"
#* TABKEY(1) = "CODINT"
#* TABVAL(1) = "GESACLA"
#* ASTATUS = func AGET_CLASSICURL(GACTX,[V]CST_ATRUE,FUNCTION,[V]CST_AMODIFFCT,TABKEY,TABVAL,TABPAR,TABPARVAL,WURL)
#*!
Funprog AGET_CLASSICURL(CTX,FULLURL,FUNCTION,MODE,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT : # Context where the errors messages are stored
Value Integer FULLURL          :  # ful url true or false
Value Char FUNCTION   : # function
Value Integer MODE     : # use CREATION?[V]CST_ACREATIONFCT , EDIT?[V]CST_AMODIFFCT
Value Char TABKEY()(1..)  : # array of Keys of the principal table
Value Char TABKEYVAL()(1..)  : # array of value of keys of the principal table
Value Char TABPAR()(1..)  : # array of parameters
Value Char TABPARVAL()(1..)  : # arrzy of value of parameters
Variable Clbfile WURL  : # clob to return the URL

Local Integer ASTATUS,NBKEY,NBPAR,AP,I,JI
Local Char P1(250)
Local Char    JSEP(1)
Local Char BBASEURL(250)

[L]ASTATUS = [V]CST_AOK

If baseUrl<>""
 BBASEURL = vireblc(baseUrl,4)
Else
 BBASEURL = vireblc(fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"AWRKSYRA"),4)
Endif

BBASEURL = func ASHWJSO.GET_TRANSITION_URL(BBASEURL)

AP = instr(8+1,BBASEURL,"/")
If AP<=0
 [L]ASTATUS = fmet CTX.ASETERROR("",mess(162,115,1),[V]CST_AERROR) : # lien incorrect
 End  [L]ASTATUS
Endif

If [L]FULLURL=[V]CST_ATRUE
 [L]WURL  = left$(BBASEURL,AP-1)
 [L]WURL += '/syracuse-main/html/main.html?url='
Endif
If left$(right$(BBASEURL,AP),1)<>"/"
 [L]WURL += "/"
Endif
[L]WURL += right$(BBASEURL,AP)
If right$([L]WURL,len([L]WURL))<>"/"
 [L]WURL += '/'
Endif
[L]WURL += "$sessions?f="+[L]FUNCTION
If MODE = 1 :#create
 [L]WURL += '/2//C/'
Else
 [L]WURL += '/2//M/'
 JSEP    = ''
 Gosub GET_DESCRIPT
 If [L]ASTATUS= [V]CST_AERROR : End [L]ASTATUS : Endif
 If NBCLE=2 & func SUBASW.IS_AFC_OBJ_GES3(nomap,[L]FUNCTION)=1
  For JI=1 To 2
    [L]WURL += JSEP+ TABKEYVAL(JI)
    JSEP        = '~'
  Next JI
 Else
  If NBCLE>1
   JI=2
   [L]WURL += JSEP+ TABKEYVAL(JI)
   JSEP     = '~'
  Endif
  For JI=1 To NBCLE
   If JI<>2
     [L]WURL += JSEP+ TABKEYVAL(JI)
     JSEP        = '~'
   Endif
  Next JI
 Endif
 For I=1 To dim(TABPAR)
  If TABPAR(I)="" : Break : Endif
  NBPAR +=1
 Next
 JSEP    = '~'
 For JI=1 To NBPAR
  [L]WURL += string$(JI=1,'/params')
  [L]WURL += JSEP+TABPAR(JI)+'~'
  If TABPARVAL(JI)<>'""'
   [L]WURL += TABPARVAL(JI)
  Endif
 Next JI
Endif
End [L]ASTATUS

$GET_DESCRIPT
Local Integer NBCLE,JJ,J
Local Char    CLE(GLONAVB)(1..),WTABKEYVAL(250)(1..)
Local File AFONCTION [AFC],AOBJET [AOB],ATABIND [ATI]
Read [AFC]CODINT = [L]FUNCTION
If !fstat &  [F:AFC]ACTION="GOBJET"
 For I=0 To 19
  If left$([F:AFC]CODPAR(I),5)="OBJET" & [F:AFC]VALPAR(I)<>""
    Onerrgo ERR_EVAL
    [L]P1=evalue([F:AFC]VALPAR(I))
    Onerrgo
    Break
  Endif
 Next I
 If [L]P1="" : End : Endif : #pas d'objet
 Filter [AOB]
 Read [AOB]ABREV=[L]P1
 If !fstat & [F:AOB]NOMFIC<>""
  Read [ATI]NUMLIG=[F:AOB]NOMFIC;1
  If !fstat
   Call SETCLE([L]NBCLE,[L]CLE,[F:ATI]DESCRIPT) From LNKSUB
   For I=1 To NBCLE
    J = find(CLE(I),TABKEY)
    If J>0
     JJ +=1
     WTABKEYVAL(JJ) = TABKEYVAL(J)
    Endif
   Next
  Endif
 Endif
Elsif fstat>0
 [L]ASTATUS = fmet CTX.ASETERROR("",mess(162,123,1) ,[V]CST_AERROR) : # : FONCTION INEXISTANTE
Endif
LogicClose File [AFC],[AOB],[ATI]
Return

$ERR_EVAL
Resume


#**
#* Get the URL based on the parameters on syracuse url
#* Example :
#* Local Char TABKEY(50)(1..10),TABKEYVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
#* Local Char REPRESENTATION(30)
#* Local Integer ASTATUS
#* Local Clbfile WURL
#* REPRESENTATION = "ABANK"
#* TABKEY(1)="CRY" : TABKEYVAL(1)="DE"
#* TABKEY(2)="BAN" : TABKEYVAL(2)="69490000"
#* ASTATUS = func AGET_SYRAURL(GACTX,[V]CST_ATRUE,REPRESENTATION,1,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
#*!
Funprog AGET_SYRAURL(CTX,FULLURL,REPRESENTATION,FACET,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT : # Context where the errors messages are stored
Value Integer FULLURL          :  # ful url true or false
Value Char REPRESENTATION  : # Représentation
Value Integer FACET  : # [V]CST_AFAC_DETAILS, [V]CST_AFAC_EDIT,[V]CST_AFAC_QUERY,[V]CST_AFAC_LOOKUP,[V]CST_AFAC_SUMMARY
Value Char TABKEY()(1..)  : # array of Keys of the principal table
Value Char TABKEYVAL()(1..)  : # array of value of keys of the principal table
Value Char TABPAR()(1..)  : # array of parameters
Value Char TABPARVAL()(1..)  : # array of value of parameters
Variable Clbfile WURL  : # clob to return the URL


Local Integer ASTATUS,NBKEY,NBPAR,CMPLNK,I,AP
Local Char P1(250)
Local Char    JSEP(1)
Local Char BBASEURL(250),PARAM(250)
Local Clbfile LURL

[L]ASTATUS = [V]CST_AOK

If baseUrl<>""
 BBASEURL = baseUrl
Else
 BBASEURL = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"AWRKSYRA")
Endif

# For syracuse switch to sdata
BBASEURL = func ASHWJSO.GET_SYRA_URL(BBASEURL)        # X3PLAT-1475 Workflow link on representation

Gosub GET_REPKEYS
If [L]ASTATUS= [V]CST_AERROR : End [L]ASTATUS : Endif

# Issue X3-68692 - 2017-12-18 by CCC : move it before NewInstance done in LOAD_ACTIONS
AP = instr(8+1,BBASEURL,"/")
If AP<=0
 [L]ASTATUS = fmet CTX.ASETERROR("",mess(162,115,1),[V]CST_AERROR) : # lien incorrect
 End  [L]ASTATUS
Endif

Local Instance ASWACTIONS(1..) Using C_ASWACTION
Call LOAD_ACTIONS(ASWACTIONS) From SUBASW_TOOL

Case [L]FACET
 When [V]CST_AFAC_EDIT : [L]CMPLNK=3
 When [V]CST_AFAC_QUERY : [L]CMPLNK= 5
 When [V]CST_AFAC_LOOKUP : [L]CMPLNK=9
 When [V]CST_AFAC_SUMMARY : [L]CMPLNK=10
 When Default : [L]CMPLNK=2
Endcase

If [L]FULLURL=[V]CST_ATRUE
 [L]WURL  = left$(BBASEURL,AP-1)
 [L]WURL += '/syracuse-main/html/main.html?url='
Endif

[L]LURL = right$(BBASEURL,AP)

If right$([L]LURL,len([L]LURL))<>"/"
 [L]LURL += '/'
Endif

[L]LURL += CLASSE
If NBCLE>0 & !find([L]CMPLNK,9,5)
 [L]LURL  += "('"+WTABKEYVAL+"')"
Endif

If ASWACTIONS([L]CMPLNK).MET="POST"
 If ASWACTIONS([L]CMPLNK).PROLNK = "$create"
  [L]LURL += "/$template"
 Endif
 [L]LURL += "/$workingCopies?representation="
Else
 [L]LURL += "?representation="
Endif
[L]LURL += REPRESENTATION+'.'+ASWACTIONS([L]CMPLNK).LNKTAR

#If (ASWACTIONS([L]CMPLNK).PROLNK= "$create"or ASWACTIONS([L]CMPLNK).PROLNK= "$edit"or ASWACTIONS([L]CMPLNK).PROLNK= "$query")
 For I=1 To dim(TABPAR)
  If TABPAR(I)="" : Break : Endif
  NBPAR +=1
 Next
 For I=1 To NBPAR
  PARAM = '&'
  PARAM += TABPAR(I)
  PARAM += '='
  If len(ctrans(TABPARVAL(I),'"',''))
   PARAM += ctrans(TABPARVAL(I),'"','')
  Else
   Raz PARAM
  Endif
  If len(PARAM) :  [L]LURL += PARAM : Endif
 Next
#Endif

If [L]FULLURL=[V]CST_ATRUE
  [L]WURL += func ASYRJSO.ENCODE_URL([L]LURL)
Else
  [L]WURL += [L]LURL
Endif

# Issue X3-68692 - 2017-12-15 by CCC : Free memory
If ASWACTIONS<>null
 FreeGroup ASWACTIONS
Endif

End [L]ASTATUS

#SAM 121201
#**
#* Get the URL based on the parameters on syracuse url
#* Example :
#* Local Char TABKEY(50)(1..10),TABKEYVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
#* Local Char REPRESENTATION(30)
#* Local Integer ASTATUS
#* Local Clbfile WURL
#* REPRESENTATION = "ABANK"
#* TABKEY(1)="CRY" : TABKEYVAL(1)="DE"
#* TABKEY(2)="BAN" : TABKEYVAL(2)="69490000"
#* ASTATUS = func AGET_SYRAURL(GACTX,[V]CST_ATRUE,REPRESENTATION,1,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
#*!
Funprog AGET_SYRAURLMOB(CTX,FULLURL,REPRESENTATION,FACET,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
Variable Instance CTX Using =[V]CST_C_NAME_CLASS_CONTEXT : # Context where the errors messages are stored
Value Integer FULLURL          :  # ful url true or false
Value Char REPRESENTATION  : # Représentation
Value Integer FACET  : # [V]CST_AFAC_DETAILS, [V]CST_AFAC_EDIT,[V]CST_AFAC_QUERY,[V]CST_AFAC_LOOKUP,[V]CST_AFAC_SUMMARY
Value Char TABKEY()(1..)  : # array of Keys of the principal table
Value Char TABKEYVAL()(1..)  : # array of value of keys of the principal table
Value Char TABPAR()(1..)  : # array of parameters
Value Char TABPARVAL()(1..)  : # array of value of parameters
Variable Clbfile WURL  : # clob to return the URL


Local Integer ASTATUS,NBKEY,NBPAR,CMPLNK,I,AP
Local Char P1(250)
Local Char    JSEP(1)
Local Char BBASEURL(250),PARAM(250)

[L]ASTATUS = [V]CST_AOK

If baseUrl<>""
 BBASEURL = baseUrl
Else
 BBASEURL = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"AWRKSYRA")
Endif

# For syracuse switch to sdata
BBASEURL = func ASHWJSO.GET_SYRA_URL(BBASEURL)        # X3PLAT-1475 Workflow link on representation

Gosub GET_REPKEYS
If [L]ASTATUS= [V]CST_AERROR : End [L]ASTATUS : Endif

# Issue X3-68692 - 2017-12-18 by CCC : move it before NewInstance done in LOAD_ACTIONS
AP = instr(8+1,BBASEURL,"/")
If AP<=0
 [L]ASTATUS = fmet CTX.ASETERROR("",mess(162,115,1),[V]CST_AERROR) : # lien incorrect
 End  [L]ASTATUS
Endif

Local Instance ASWACTIONS(1..) Using C_ASWACTION
Call LOAD_ACTIONS(ASWACTIONS) From SUBASW_TOOL

Case [L]FACET
 When [V]CST_AFAC_EDIT : [L]CMPLNK=3
 When [V]CST_AFAC_QUERY : [L]CMPLNK= 5
 When [V]CST_AFAC_LOOKUP : [L]CMPLNK=9
 When [V]CST_AFAC_SUMMARY : [L]CMPLNK=10
 When Default : [L]CMPLNK=2
Endcase

If [L]FULLURL=[V]CST_ATRUE
 [L]WURL  = left$(BBASEURL,AP-1)
 [L]WURL += '/syracuse-tablet/dist/index.html?url='
Endif

[L]WURL += right$(BBASEURL,AP)

If right$([L]WURL,len([L]WURL))<>"/"
 [L]WURL += '/'
Endif

[L]WURL += CLASSE
If NBCLE>0 & !find([L]CMPLNK,9,5)
 [L]WURL  += "('"+WTABKEYVAL+"')"
Endif

If ASWACTIONS([L]CMPLNK).MET="POST"
 If ASWACTIONS([L]CMPLNK).PROLNK = "$create"
  [L]WURL += "/$template"
 Endif
 [L]WURL += "/$workingCopies?representation="
Else
 [L]WURL += "?representation="
Endif
[L]WURL += REPRESENTATION+'.'+ASWACTIONS([L]CMPLNK).LNKTAR

#If (ASWACTIONS([L]CMPLNK).PROLNK= "$create"or ASWACTIONS([L]CMPLNK).PROLNK= "$edit"or ASWACTIONS([L]CMPLNK).PROLNK= "$query")
 For I=1 To dim(TABPAR)
  If TABPAR(I)="" : Break : Endif
  NBPAR +=1
 Next
 For I=1 To NBPAR
  PARAM = '&'
  PARAM += TABPAR(I)
  PARAM += '='
  If len(ctrans(TABPARVAL(I),'"',''))
   PARAM += ctrans(TABPARVAL(I),'"','')
  Else
   Raz PARAM
  Endif
  If len(PARAM) :  [L]WURL += PARAM : Endif
 Next
#Endif

# Issue X3-68692 - 2017-12-15 by CCC : Free memory
If ASWACTIONS<>null
    FreeGroup ASWACTIONS
Endif

End [L]ASTATUS


$GET_REPKEYS
Local Integer NBCLE,JJ,J
Local Char    CLE(GLONAVB)(1..),WTABKEYVAL(250),CLASSE(GLONACLA)

Local File ASHW [ASW],ACLASSE[ACLA],ATABLE [ATB],ATABIND [ATI]

Read [ASW]ASW0 = [L]REPRESENTATION
If !fstat
 Read [F:ACLA]ACLA0 = [F:ASW]CODCLA
 If !fstat
  CLASSE = [F:ACLA]CODCLA
  If [F:ACLA]TYPCLA=2
   Read [F:ATB]CODFIC = [F:ACLA]TABREF
   If !fstat
    Read [ATI]CODIND =[F:ACLA]TABREF;[F:ACLA]INDREF
    If !fstat
     Call SETCLE([L]NBCLE,[L]CLE,[F:ATI]DESCRIPT) From LNKSUB
     For I=1 To NBCLE
      J = find(CLE(I),TABKEY)
      If J>0
       JJ +=1
       If JJ>1 : WTABKEYVAL += '~' : Endif
       WTABKEYVAL += TABKEYVAL(J)
      Endif
     Next
    Else
     [L]ASTATUS = fmet CTX.ASETERROR("",mess(207,115,1)  ,[V]CST_AERROR) : # : INDEX INEXISTANTE
    Endif
   Else
     [L]ASTATUS = fmet CTX.ASETERROR("",mess(124,124,1)  ,[V]CST_AERROR) : # : TABLE INEXISTANTE
   Endif
  Elsif [F:ACLA]TYPCLA=5
   Call SETCLE([L]NBCLE,[L]CLE,[F:ACLA]KEYINT) From LNKSUB
   For I=1 To NBCLE
    J = find(CLE(I),TABKEY)
    If J>0
     JJ +=1
     If JJ>1 : WTABKEYVAL += '~' : Endif
     WTABKEYVAL += TABKEYVAL(J)
    Endif
   Next

  Endif
 Else
  [L]ASTATUS = fmet CTX.ASETERROR("",mess(4,140,1)  ,[V]CST_AERROR) : # : CLASSE INEXISTANTE
 Endif
Else
 [L]ASTATUS = fmet CTX.ASETERROR("",mess(15,140,1)  ,[V]CST_AERROR) : # : REPRÉSENTATION INEXISTANTE
Endif
LogicClose File [ASW],[ACLA],[ATB],[ATI]

Return


Funprog _ACONTROL_DATASTABLE(_AINSTANCE,_TABLE)
Variable Instance _AINSTANCE Using OBJECT
Value Char _TABLE

If GADONIX=[V]CST_AFALSE : End [V]CST_AOK : Endif

Local Integer ASTATUS
Local Char WDOSX3(GLONADS)

WDOSX3=fmet _AINSTANCE.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","SUPDOS")

[L]ASTATUS= [V]CST_AOK

If dim(_AINSTANCE.CREUSR)>0
 If find(_AINSTANCE.ACTX.AFOLDER,WDOSX3)>0
  Gosub SET_USER From ATRIFIL
  If find(_AINSTANCE.CREUSR,TB_AUZ(1..NB_AUZ)) & _AINSTANCE.CREUSR<>_AINSTANCE.ACTX.USER
   Gosub SET_TABLE From ATRIFIL
   Gosub GET_NAMTAB From ATRIFIL
   If !find(_TABLE,TB_VIR(1..NB_VIR))
    Local Char MES(80)
    [L]MES = "You ("+_AINSTANCE.ACTX.USER+") are not allowed to modify"-_TABLE-"created by"-_AINSTANCE.CREUSR
    [L]ASTATUS = fmet _AINSTANCE.ASETERROR("",[L]MES ,[V]CST_AERROR)
   Endif
  Endif
 Endif
Endif

End ASTATUS


#**
#* ACHECKCONNECT Verify the password or signature code of the current user
#*
#* @param ACTX (in)
#* @param APSSWD (in) the password or signature code of the current user
#* @param MESSAGE (out) the reason of the failure
#*
#* @return status code (CST_AOK, CST_AINFO, CST_AWARNING, CST_AFATAL, CST_AERROR)
#*!
Funprog ACHECKCONNECT(_ACTX,APSSWD,MESSAGE)
Variable Instance _ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char APSSWD
Variable Char MESSAGE
Local Char ALOGINX3(GLONAUS) :#X3-99985
End func ACHECKLOGIN(_ACTX,"",APSSWD,ALOGINX3,MESSAGE)

#**
#* ACHECKSYRCONNECT Verify the password or signature code of received user
#*
#* @param ACTX (in)
#* @param ASYRLOGIN (in) the syracuse login
#* @param ASYRPSSWD (in) the password or signature code to check
#* @param ALOGINX3 (out) the X3 login
#* @param MESSAGE (out) the reason of the failure
#*!
#X3-99985: new function
Funprog ACHECKSYRCONNECT(_ACTX,ASYRLOGIN,ASYRPSSWD,ALOGINX3,MESSAGE)
Variable Instance _ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char ASYRLOGIN,ASYRPSSWD
Variable Char MESSAGE
Variable Char ALOGINX3
End func ACHECKLOGIN(_ACTX,ASYRLOGIN,ASYRPSSWD,ALOGINX3,MESSAGE)

#**
#* ACHECKLOGIN Verify the password or signature code of the given syracuse login
#*
#* @param ACTX (in)
#* @param ASYRLOGIN (in) the syracuse login
#* @param ASYRPSSWD (in) the password or signature code to check
#* @param ALOGINX3 (out) the X3 login
#* @param MESSAGE (out) the reason of the failure
#*
#* @return status code (CST_AOK, CST_AINFO, CST_AWARNING, CST_AFATAL, CST_AERROR)
#*!
#X3-99985: add ALOGINX3 parameter
Funprog ACHECKLOGIN(_ACTX,ASYRLOGIN,ASYRPSSWD,ALOGINX3,MESSAGE)
Variable Instance _ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char ASYRLOGIN,ASYRPSSWD
Variable Char MESSAGE
Variable Char ALOGINX3

Local Clbfile RESHEAD(4)
Local Clbfile RESBODY(6)
Local Char MODULE(100)
Local Char FONCTION(30)
Local Char MODE(10)
Local Clbfile ARGUMENTS(2)
Local Char ENCODINGS(40)
Local Integer CALLBACKINDEX
Local Char RETURNS(50)
Local Char RETURNS_ENC(3)
Local Integer STATUSCODE

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE        Using C_ASYRJSO
Local Integer ASTATUS : ASTATUS=[V]CST_AOK

MODULE = 'syracuse-auth/lib/signatureAuth'
FONCTION = "sign"
MODE = "wait"
ARGUMENTS = '"'+ASYRPSSWD+'","'+ASYRLOGIN+'"'
ENCODINGS = ''
CALLBACKINDEX = 0
RETURNS = ''
RETURNS_ENC = '0'
Raz ALOGINX3

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, CALLBACKINDEX,    RETURNS, RETURNS_ENC, RESHEAD, RESBODY)
#RESBODY = '{"statusCode":"200","message":"OK","content-type":"application/json","content-length":"17"}'
#RESBODY = '{"$diagnoses":[]}}'
If STATUSCODE = [V]CST_AHTTP_OK & len2(RESBODY)>10
 Onerrgo ACHECKCONNECT_EXIT :#SAM 117327
 ASTATUS = func ASYRJSONPARSE.PARSEJSON(_ACTX,RESBODY,NODES,NODE)
 ASTATUS = [V]CST_AOK
 For I=1 To maxtab(NODES)
  If NODES(I)<>null
   If toupper(NODES(I).PRO)="$SEVERITY"
    Case tolower(fmet NODES(I).AGETCNT)
     When "success" :  ASTATUS =  [V]CST_AOK
     When "info"   :   ASTATUS = [V]CST_AINFO
     When "warning" :  ASTATUS = [V]CST_AWARNING
     When "fatal" :    ASTATUS = [V]CST_AFATAL
     When Default :    ASTATUS = [V]CST_AERROR
    Endcase
   Endif
   If toupper(NODES(I).PRO)="$MESSAGE"
    If instr(1,fmet NODES(I).AGETCNT,'"')>0
     MESSAGE = evalue(fmet NODES(I).AGETCNT)
    Else
     MESSAGE = fmet NODES(I).AGETCNT
    Endif
   Endif
   #X3-99985
   If toupper(NODES(I).PRO)="X3LOGIN"
      ALOGINX3=fmet NODES(I).AGETCNT
   Endif
   #end X3-99985
  Endif
 Next
 If MESSAGE="" and ASTATUS=[V]CST_AERROR
  MESSAGE = mess(233,100,1)
 Endif
 # {"$diagnoses":[{"$severity":"error","$message":"No authentication"}]}
 # {"$diagnoses":[{"$severity":"error","$message":"User 'CCLs' does not exist"}]}
 # {"$diagnoses":[]}
Else
 ASTATUS = [V]CST_AERROR
 MESSAGE = func ASYRWEBSER.GETMESS(RESHEAD)
Endif
$ACHECKCONNECT_EXIT:#SAM 117327
End ASTATUS

#--------------------------------------------#
# Renvoi la date d'un datetime
#--------------------------------------------#

Funprog DATE_FROM_DT(DT)
Value Datetime DT
Local Date DAT
If num$(DT)=num$(gdatetime$(""))
 DAT = [00/00/00]
Else
 DAT = gdat$(val(seg$(num$(DT),9,10)),val(seg$(num$(DT),6,7)),val(left$(num$(DT),4)))
Endif
End DAT

#--------------------------------------------#
# Renvoi l'heure d'un datetime
#--------------------------------------------#

Funprog TIME_FROM_DT(DT)
Value Datetime DT
Local Char TIM(10)
If num$(DT)=num$(gdatetime$(""))
 TIM = "00:00:00"
Else
 TIM = seg$(num$(DT),12,19)
Endif
End TIM


