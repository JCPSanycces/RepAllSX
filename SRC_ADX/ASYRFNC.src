#**
#* Update the ETag used when updating a folder's property
#*
#* @param DOS
#*!
Subprog UPDATE_FOLDERETAG(DOS)
Value Char DOS

Onerrgo ERRUPD

 If dim([L]DOS)<=0 or [L]DOS=""
  Local File ADOVAL [ADW_]
 Else
  Local File =[L]DOS+".ADOVAL" [ADW_]
 Endif

 If !adxlog
  Gosub AUPDATE_TR_FLDETAG
 Else
  Gosub AUPDATE_FLDETAG
 Endif
 Close Local File [ADW_]
Onerrgo
End

$ERRDLFUPD
Resume

$AUPDATE_TR_FLDETAG
Trbegin [ADW_]
Gosub AUPDATE_FLDETAG
Commit
Return

$AUPDATE_FLDETAG
Read [ADW_]ADW0= "";"";"FOLDERETAG"
[ADW_]VALEUR = num$(datetime$)
If fstat
 [ADW_]PARAM = "FOLDERETAG"
 Write [ADW_]
Else
 Rewrite [ADW_]
Endif
Return

#**
#* Get properties of the endpoint which opend the session :
#* USEETNA = 1 if the endpoint's useEtna property is set to true:
#* USESCM = 1 if the syracuse detects a SCM configuration
#* @param DOS
#*!
Funprog AGET_ENDPOINT_PROPERTIES(USEETNA,USESCM)
Variable Integer USEETNA,USESCM
Raz USEETNA,USESCM

Local Clbfile ARGUMENTS(0)
Local Clbfile RESHEAD,RESBODY
Local Integer ASTATUS:ASTATUS =[V]CST_AERROR
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE        Using C_ASYRJSO
Local Char CNT(250)

ASTATUS = func ASYRWEBSER.EXEC_JS("syracuse-4gl-api/lib/endpoint", "getProperties", 'wait', ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)
If ASTATUS = 200
 ASTATUS = func ASYRJSONPARSE.PARSEJSON(GACTX,RESBODY,NODES,NODE)
 If ASTATUS=[V]CST_AOK
  For I=1 To maxtab(NODES)
   CNT =fmet NODES(I).AGETCNT
   Case NODES(I).PRO
    When "useEtna" :  If CNT="true" : USEETNA=1 : Endif
    When "useScm" :  If CNT="true" : USESCM=1 : Endif
   Endcase
  Next I
 Endif
Else
 ASTATUS =  [V]CST_AERROR
Endif
End ASTATUS

