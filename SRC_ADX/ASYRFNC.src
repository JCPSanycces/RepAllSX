# X3-62662 - Get URL prefix (protocol)
Funprog GET_URLPREFIX

Local Char WURL_PREFIX(5)

If (left$(toupper(baseUrl),5) = "HTTPS")
  WURL_PREFIX = "HTTPS"
Else
  WURL_PREFIX = "HTTP"
Endif

End WURL_PREFIX

