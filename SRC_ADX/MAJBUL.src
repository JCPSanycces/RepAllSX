#<AdxTL>@(#)7.0.0.0 $Revision$
#** V7 : Waiting several modules **#
#*********************************#
# SEGAY  US 2326-88174 BULDEM
$OUVRE2
If !func AFNC.ACTIV("DEMAT")
  Local Integer WJ
  # Suppression de la ligne des paramètres, ATTENTION il ne faut pas que le paramètres soit de type multiple
  # Car le tableau invisible des plages de valeurs NBPLAG est alimentée dans écran AIMP1
  GBIDI2=find("impdemat",[M:RPT]PARCOD(0..[M:RPT]NBRPAR))
  If GBIDI2
    [L]WJ= find([M:RPT]PARCOD(GBIDI2-1),[M:RPT]PARPLAG(0..[M:RPT]NBPLAG))
    While [L]WJ
       Dela [L]WJ-1 , 1 [M:RPT]PARPLAG, [M:RPT]VALPLAG1 , [M:RPT]VALPLAG2 , [M:RPT]BORPLAG
       If [M:RPT]NBPLAG> 0 : [M:RPT]NBPLAG-= 1 : Endif
       [L]WJ= find([M:RPT]PARCOD(GBIDI2-1),[M:RPT]PARPLAG(0.. [M:RPT]NBPLAG))
    Wend
    Dela GBIDI2-1,1 [M:RPT]NBRPAR
    If [M:RPT]NBRPAR> 0 : [M:RPT]NBRPAR -= 1 : Endif
  Endif
Endif
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char CRITCPY(255),CRITFCY(255),CRITERE(255),CRITERE2(255), PARAM(30), CRITVEP(255)
Local Integer I, J, FLGIMP, NBLIG, NUMREQ, OK, FLGARCHI, FLGDEMAT :# SEGAY  US 2326-88174 BULDEM
Local Date  DATDEB, DATFIN
Local Char  SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , SERVICE(GLONSRV), PROFIL (GLONPRF)
Local Char  MATDEB (GLONEML) , MATFIN (GLONEML)
Local Char  ETAT(GLONARP), POPULATION(GLONPOP), BULDEB(GLONVCR), BULFIN(GLONVCR)
Local Char  REPORT1([V]GLONARP)
Local Date REFANC, REFCTR

## 39496
Local Char  BTP(1)
##
Local Char  ORG(GLONORG)

If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:FGR])=0    : Local File FACGROUP   [FGR]   : Endif
If clalev([F:VEP])=0    : Local File VALEMP     [VEP]   : Endif
If clalev([F:ARM])=0    : Local File AREPORTM   [ARM]   : Endif
If clalev([F:HRPOA])=0    : Local File POPULA     [HRPOA]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
#39496
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
#

#54667
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
If clalev([F:HSP])=0 : Local File HISTOPAYE  [HSP] : Endif
#

If clalev([F:HRXGD])=0  : Local File HRXITGRD [HRXGD]  : Endif

##**82073
#ADNGO - 2017-09-28 - X3-57772 - START
If clalev([F:HRPEOD])=0 : Local File HRPEODET     [HRPEOD] : Endif
#ADNGO - 2017-09-28 - X3-57772 - END
#

[L]ETAT=[M]RPTCOD
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB) From ETAT
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN) From ETAT
Call GETPARAM("buldeb",NBPAR,PARAMETRE,BULDEB) From ETAT
Call GETPARAM("bulfin",NBPAR,PARAMETRE,BULFIN) From ETAT
Call GETPARAM("cpy",NBPAR,PARAMETRE,SOCIETE) From ETAT
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,SITEDEB) From ETAT
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,SITEFIN) From ETAT
Call GETPARAM("srv",NBPAR,PARAMETRE,SERVICE) From ETAT
Call GETPARAM("prf",NBPAR,PARAMETRE,PROFIL) From ETAT
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) From ETAT : DATDEB = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) From ETAT : DATFIN = PARAM
Call GETPARAM("flgprn",NBPAR,PARAMETRE,PARAM) From ETAT : FLGIMP = val(PARAM)
Call GETPARAM("archivage",NBPAR,PARAMETRE,PARAM) From ETAT : FLGARCHI = val(PARAM)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT : [L]NUMREQ = val(PARAM)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION) From ETAT
Call GETPARAM("impdemat",NBPAR,PARAMETRE,PARAM) From ETAT : FLGDEMAT = val(PARAM) :# SEGAY  US 2326-88174 BULDEM

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT


CRITVEP="1=1" : CRITVEP2="1=1" : CRITCPY="1=1" : CRITFCY="1=1"

If SOCIETE<>""
 CRITCPY -= '& [F:FGR]CPY="'+SOCIETE+'"'
Else
 Call ERREUR (mess(68,10702,1)) From GESECRAN
 GOK=0 : End
Endif

If SITEDEB<>"" : CRITFCY  -= '& [F:FGR]FCY>="'+SITEDEB+'"' : Endif
If SITEFIN<>"" : CRITFCY  -= '& [F:FGR]FCY<="'+SITEFIN+'"' : Endif

If MATDEB<>""  : CRITVEP  -= '& [F:VEP]EMP>="'+MATDEB+'"' :  Endif
If MATFIN<>""  : CRITVEP  -= '& [F:VEP]EMP<="'+MATFIN+'"' :  Endif

If BULDEB<>""  : CRITVEP  -= '& [F:VEP]BUL>="'+BULDEB+'"' :  Endif
If BULFIN<>""  : CRITVEP  -= '& [F:VEP]BUL<="'+BULFIN+'"' :  Endif

If DATDEB<>[0/0/0]
 CRITVEP -= '& [F:VEP]PYRDAT>=['+format$(GFMD,DATDEB)+']'
Endif
If DATFIN<>[0/0/0]
 CRITVEP -= '& [F:VEP]PYRDAT<=['+format$(GFMD,DATFIN)+']'
Endif
If [L]FLGARCHI
 CRITVEP2 -= '& [F:VEP]STA=3'
Elsif FLGIMP<>0
 CRITVEP2 -= '& [F:VEP]STA=2'
Else
 CRITVEP2 -= '& [F:VEP]STA>1' #pour prendre aussi STA=3
Endif
If SERVICE<>"" : CRITVEP2 -= '& [F:VEP]SRV="'+SERVICE+'"'   : Endif
If PROFIL<>""  : CRITVEP2 -= '& [F:VEP]PRF="'+PROFIL+'"'    : Endif

# SEGAY  US 2326-88174 BULDEM ML 2415
Case [L]FLGDEMAT
   When 1 : CRITVEP2 -= '& [F:VEP]BULDEMAFF=1'             : # Non adhérent
   When 2 : CRITVEP2 -= '& [F:VEP]BULDEMAFF=2'             : # Adhérent
Endcase

## 39496
Read [ACV]CODACT="BTP"
If !fstat & [F:ACV]FLACT=2
 [L]BTP = "1"
Endif
## fin 39496

Gosub RAZ_ARM

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
GCURLEG=[F:CPY]LEG

For [F:FGR]FGR0 Where evalue (CRITCPY) & evalue(CRITFCY)
 Call DEBTRANS From GLOCK
 Gosub TR1
Next

If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

End



##########################
$TR1
GOK = 1
Trbegin [VEP],[ARM]

For [VEP] Where evalue(CRITVEP) & evalue(CRITVEP2) & find(RPTBUL,"",[L]ETAT)<>0 & FCY=[F:FGR]FCY
 OK=1
 If POPULATION<>""
  Look[HRPOA]POA0=POPULATION;[F:VEP]EMP
  If fstat : OK=0 : Endif
 Endif
 #54667
 If OK :  Gosub NBRUBPRN : Endif
 #
 If OK
  If [F:VEP]RPTBUL=""
   Gosub GETRPTBUL From SUBVEP
  Else
   [L]REPORT1=[L]ETAT
  Endif
  If [L]REPORT1=[L]ETAT

   ##**82073
   #Gosub ANCIENNETE

   #Ajout des dates calendrier
   #Read [F:PEO]PEO0=[F:VEP]FCY;[F:VEP]PYRDAT
   #If fstat Then
   # Read [F:PEO]PEO0="";[F:VEP]PYRDAT
   # If fstat Then Raz [F:PEO] : Endif
   #Endif
#ADNGO - 2017-09-28 - X3-57772 - START
#   Filter [F:HRPEO] Where FCY=[F:VEP]FCY & PYRDAT<=eomonth([F:VEP]PYRDAT)
#   Read [F:HRPEO]PEO0 Last
#   Filter [F:HRPEO]
#   If fstat Then
#    Filter [F:HRPEO] Where FCY="" & PYRDAT<=eomonth([F:VEP]PYRDAT)
#    Read [F:HRPEO]PEO0 Last
#    Filter [F:HRPEO]
#    If fstat Then Raz [F:HRPEO] : Endif
#   Endif

#   REFANC=[F:VEP]ENDDAT
#   REFCTR=[F:VEP]CTRDAT

   Filter [F:HRPEOD] Where PERCOD=[F:VEP]PERCOD & PYRDAT<=eomonth([F:VEP]PYRDAT)
   #Read [F:HRPEOD]HRPEO0 Last
   Read [F:HRPEOD] Last
   Filter [F:HRPEOD]
   If fstat Then
      Raz [F:HRPEOD]
   Endif

   REFANC=[F:VEP]ENDDAT
   REFCTR=[F:VEP]CTRDAT
#ADNGO - 2017-09-28 - X3-57772 - END
   Readlock [F:VEP]Curr
   If !fstat
    [F:VEP]STA=3 : #Imprimer
    Rewrite [F:VEP]
    If fstat
     GOK = 0 : Call FSTA("VEP") From GLOCK
    Endif
    Gosub AFFECT_ARM
   Endif
  Endif
 Endif
Next
If GOK<1
 Gosub AB_TR
 Return
Endif
Commit
Return

###54667 : il faut au moins q'une rubrique soit imprimable pour lancer le bulletin
##########################
$NBRUBPRN

OK=0
For [HSP]HSP2 Where BUL=[F:VEP]BUL & TYP<6
 Read[F:RUB]RUB1=GCURLEG;[F:HSP]ROW
 If !fstat & [F:RUB]AMTPRN>1
  OK=1 : Break
 Endif
Next
If !OK
 #0 Rubrique imprimable sur les bulletins
 Call ERREUR([F:VEP]EMP-format$("D:"+GFMDAT,[F:VEP]PYRDAT)-": 0"-mess(130,10702,1)) From GESECRAN
Endif
Return

##########################
$RAZ_ARM
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$-1
Commit
Return

##########################
$AB_TR
 Rollback
Return

##########################
$AFFECT_ARM
NBLIG +=1
Raz [F:ARM]
[F:ARM]USR     = GUSER
[F:ARM]RPTCOD  = [L]ETAT
[F:ARM]NUMREQ  = [L]NUMREQ
[F:ARM]NUMLIG  = [L]NBLIG
[F:ARM]CLEA1   = [F:VEP]EMP
[F:ARM]CLED1   = REFCTR : # [F:VEP]PYRDAT
[F:ARM]CLED2   = REFANC
[F:ARM]CREDAT  = date$
## 39496
[F:ARM]CLEA2   = [L]BTP
## fin 39496
#MIPEA - 2016-09-29 - X3PEOP-777 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDURS
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
Call ORGANISME ([F:VEP]EMP ,[F:VEP]FCY,[F:VEP]CTRNUM,[L]ORG,[L]ORGLINE) From SUBORG
#Call ORGANISME ([F:VEP]EMP ,[F:VEP]FCY,[F:VEP]CTRNUM,[L]ORG,GINDURS-1) From SUBORG
#MIPEA - 2016-09-29 - X3PEOP-777 - END
If [L]ORG<>""
 Call ORGAFFIL  ([L]ORG,[F:VEP]FCY,[F:VEP]EMP,[F:VEP]CTRNUM,[F:ARM]CLEA5,[F:ARM]CLEA4) From SUBORA
Endif
[F:ARM]CLEA3   = [F:VEP]BUL : # BY, ça devrait servir...

##**82073
#ADNGO - 2017-09-28 - X3-57772 - START
#[F:ARM]CLEN1   = [F:HRPEO]YEA
#[F:ARM]CLEN2   = [F:HRPEO]LIG
[F:ARM]CLEN1   = [F:HRPEOD]PERYEA
[F:ARM]CLEN2   = [F:HRPEOD]PERNUM
#ADNGO - 2017-09-28 - X3-57772 - END
#If [F:HRPEO]FCY="" Then
#  [F:ARM]CLEA4   = " "
#Endif
#ADNGO - 2017-09-28 - X3-57772 - START
#[F:ARM]CLEA4   = [F:HRPEO]FCY
[F:ARM]CLEA4   = [F:HRPEOD]PERCOD
#ADNGO - 2017-09-28 - X3-57772 - END

[F:ARM]CLEA6   = [F:VEP]CTRNUM

# Issue X3-71919 - 2018-07-16 by BRBAN : Description for SERVICE and DEPARTMENT
If [F:VEP]LEG='MAR' & func AFNC.ACTIV('KMA')>0
  Local Char TEXTRA : [L]TEXTRA = ''
  Call LECTEXTRA([L]TEXTRA,"SERVICE","DES",[F:VEP]SRV,"") From ATEXTRA
  [F:ARM]CLEA7= [L]TEXTRA

  Raz [L]TEXTRA
  Read [F:HRCTR]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
  If !fstat
    Call LECTEXTRA([L]TEXTRA,"HRCATCSP","DESAXX",[F:HRCTR]CATCSP,[F:VEP]LEG) From ATEXTRA
    [F:ARM]CLEA8= [L]TEXTRA
  Endif

Endif
#-

Write [F:ARM]
If fstat
 GOK = 0 : Call FSTA("ARM") From GLOCK
Endif
Return

##########################
$ANCIENNETE
#Cause code DNA
Local Integer JADI
Local Char CODA1 (10)

REFANC=[F:VEP]ENDDAT
Raz REFCTR
Filter [F:HRCTR] Where REFNUM=[F:VEP]EMP & CTRDAT<=[F:VEP]STRDAT & CTRNUM=[F:VEP]CTRNUM Order By Key CLE=CTRDAT Desc
For [F:HRCTR]CLE
 If REFCTR=[0/0/0] : REFCTR = [F:HRCTR]CTRDAT : Endif
 If [F:HRCTR]XITDAT<>[0/0/0]
  Call SIMPLEREAD([F:HRCTR]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
  If !GERRHRM
   #Cause code DNA
   JADI=instr (1,[F:HRXGD]CODN4H,"|")
   If JADI
    CODA1=seg$([F:HRXGD]CODN4H,1,JADI-1)
   Else
    CODA1=[F:HRXGD]CODN4H
   Endif
   If CODA1<>"096" & [F:HRCTR]XITFNL=2 :# Pas un Versement Après Rupture  & Sortie Definitive=oui
    REFANC=[F:HRCTR]XITDAT
    Break
   Endif
  Endif
 Else
  Break
 Endif
Next
Filter [HRCTR]
Return

##########################
$ACTION
Case ACTION
 When "MESSAGERIE"
#JASMI - 2017-09-26 - START
  # Issue 105399 - 2015-10-09 by BRBAN : Change the name of the report when sent by email
  # Issue 112975US2 - 2016-05-03 by BRBAN : Improvements on email payslip
  If func AFNC.ACTIV("EPAY")>0
    If find(GFONCTION,"FUNEMLPAY","GESVEP")
      # Issue 114304 - 2016-02-09 by BRBAN : Create a unique name for the file.
      #[L]JOBID = mess(104,703,1)+"_"+month$([F:VEP2]PYRDAT)+"_"+num$(year([F:VEP2]PYRDAT))
      #[L]JOBID = "EPS"+[F:VEP2]BUL+"_"+mess(104,703,1)+"_"+month$([F:VEP2]PYRDAT)+"_"+num$(year([F:VEP2]PYRDAT))+[F:VEP2]PRFSUP
      [L]JOBID = "EPS"+[F:VEP2]BUL+"_"+mess(104,10703,1)+"_"+format$("D:YYYY[-]MM",[F:VEP2]PYRDAT)+[F:VEP2]PRFSUP
    Endif
  Endif
#JASMI - 2017-09-26 - END
 When "SAISIE"
  If GIMPRIME : OK = 0 : Endif
 When "FICHIER"
  If clalev([M:VEF])
   I=find("fcydeb",[L]TBPAR(1..dim([L]TBPAR)))
   If I : [L]FICHIER=[L]TBVAL(I) : Endif
   I=find("datdeb",[L]TBPAR(1..dim([L]TBPAR)))
   If I : [L]FICHIER+="_"+format$("D:YYYY[-]MM[-]DD",evalue("["+[L]TBVAL(I)+"]")) : Endif
   [L]FICHIER=[M:VEF]FDR+"\"+[L]FICHIER+"_"+[L]ETAT+".pdf"
   #[L]FICHIER=[M:VEF]FDR+"\"+[L]FICHIER+".pdf" : # bogue 41909
   #[L]FICHIER=filpath([M:VEF]FDR,[L]FICHIER,"pdf")
    #ADNGO - 2017-09-28 - X3-57772 - START
    If (dim([M:VEF]FDR)<>-1)
      [L]FICHIER=[M:VEF]FDR+"\"+[L]FICHIER
    Else
      [L]FICHIER=[M:VEF]FIL+"\"+[L]FICHIER
    Endif
    #ADNGO - 2017-09-28 - X3-57772 - END
  Endif
  If clalev([M:VEI])
   I=find("buldeb",[L]TBPAR(1..dim([L]TBPAR)))
   If I : [L]FICHIER=[L]TBVAL(I) : Endif
   [L]FICHIER=[M:VEI]FDR+"\"+[L]FICHIER+".pdf"
  Endif

  # (C) PROSPER 17/01/2011 - Edition depuis la fonction de rétroactivité
  If dim([V]GRETROACTIVITE) > 0 & [V]GRETROACTIVITE = 1 & dim([M:DIA]FDR) > 0 & [M:DIA]FDR <> ""
        I=find("buldeb",[L]TBPAR(1..dim([L]TBPAR)))
        If I
            [L]FICHIER=[L]TBVAL(I)
            [L]FICHIER=[M:DIA]FDR+"\"+[L]FICHIER+".pdf"
        Endif
  Endif
  When "OUVRE"   : Gosub OUVRE2 : # SEGAY  US 2326-88174 BULDEM
Endcase
Return

