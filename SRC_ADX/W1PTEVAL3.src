#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PTEVAL3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:11"
A_USER  = "DOC"
A_STAMP = "20181109230611"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDIE"
  If [M]NBRDIE=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PTEVAL3 [PJT3]
Gosub HORODAT
Local Inpbox "PTEVAL3" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJT3] As [SIM_]
Grizo [PJT3]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJT3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=77 : Y1(0)=1 : Y2(0)=21
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_DIE
Return

$ON_ZDIE
Onevent BEFORE_AREA Gosub AV_ZDIE From W1PTEVAL3
Return

$AV_ZDIE
Call LECTEXTRA(zc,"GDIE","DESTRA",num$([M]DIE(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_CCE
Onevent BEFORE_AREA Gosub AV_CCE From W1PTEVAL3
Return

$AV_CCE
## Action INICCEFMT
Call INICCEFMT(num$([M:PJT3]DIE(nolign-1))) From SETGLBDIE
If GCCEFMT<>""
 Chgfmt [M]CCE(indice) With "KP:"+GCCEFMT
Else
 Chgfmt [M]CCE(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_ZCCE
Onevent BEFORE_AREA Gosub AV_ZCCE From W1PTEVAL3
Return

$AV_ZCCE
Call LECTEXTRA(zc,"CACCE","SHOTRA",num$([M:PJT3]DIE(nolign-1)),num$([M]CCE(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_SEARCH
Onevent INIT_AREA Call D_SEARCH(zc) From W1PTEVAL3
Return

Subprog D_SEARCH(VALEUR)
Variable Integer VALEUR
If varinit([M]SEARCH,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


