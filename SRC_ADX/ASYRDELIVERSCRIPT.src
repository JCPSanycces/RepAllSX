#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO


Local Char SCRIPT(250),NAME(250)
Local Integer   ERROR : ERROR = [V]CST_AOK
Local Char SRCPATH(250),ADXPATH(250)
Local Char SCRIPTTYPE(10)
Local Clbfile SOURCE
Local Blbfile ADX
Local Integer ASTATUS : ASTATUS=[V]CST_AOK
Local Integer SIZE
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODES2(1..)  Using C_ASYRJSO
Local Instance  NODE        Using C_ASYRJSO
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null

If dim(GOS) < 0
 Global Char     GOS(10)(0..3)       : # computer type (dos/unix)
 Global Char     GOS2(10)(0..3)      : # Sous-type (AIX/ULTRIX)
 Global Char     GREPTMP(250)(0..3)  : # temporary folders
 Global Char     GIRS(2)(0..3)

 For I=1 To maxtab(ACTX.ASOL.OS)
  GOS(I-1) = ACTX.ASOL.OS(I)
  GOS2(I-1) = ACTX.ASOL.OS2(I)
  GREPTMP(I-1) = ACTX.ASOL.TMPDIR(I)
  GIRS(I-1) = ACTX.ASOL.IRS(I)
 Next
Endif


#TRT or ADX ?
SCRIPTTYPE="TRT"
NAME = func ASYRMAIN.PARVAL(ARCV,"name")

If len(NAME)
 Local File ADICTRT   [ADC]
 Read [ADC]ADC0=NAME
 If !fstat
 If (GPRODUIT=-1 and [ADC]MODULE=2) or (GPRODUIT<>1 and [ADC]MODULE=11)
  End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,mess(132,124,1))
 Endif
  If [ADC]SRC <> 2
   SCRIPTTYPE="ADX"
  Endif
 Endif
 Close Local File [ADC]
Else
 SCRIPT ="VALTRT"
Endif

If SCRIPTTYPE="ADX"
 # Issue X3-48644 - 2017-07-13 by CCC : Name's length is limited => adding ZPATCH to real name generates an error in valtrt
 #SCRIPT = "ZPATCH_"+NAME
 SCRIPT = "ZPATCH_"+timestamp$
 ADXPATH = filpath("TRT",SCRIPT,"adx",nomap)
 STA = Delfile (ADXPATH)
 SRCPATH = filpath("TRT",SCRIPT,"src",nomap)
 STA = Delfile (SRCPATH)

 Openo SRCPATH,0 Using [SRC]
 If JSON.PRO  = "source"
  SOURCE = fmet JSON.AGETCNT
  SOURCE = seg$(SOURCE,2,len(SOURCE)-1)
 Endif
 Wrseq SOURCE Using [SRC]
 Openo Using [SRC]

 ##compile it
 Call SYSTEME(adxmac(0),"valtrt"-"-l"-"ENG"-nomap-SCRIPT,"",ERROR) From ORDSYS

 SIZE = filinfo(ADXPATH,7)
 If  SIZE > 0
  Openi ADXPATH Using [ADX]
  Getseq 1,ADX Sized SIZE Using [ADX]
  Openi Using [ADX]
  SIZE = b64Encode(ADX, SOURCE)
 Else
  Raz SOURCE    # An error occured during compilation => don't send the content of the source
 Endif
 STA = Delfile (ADXPATH)
 STA = Delfile (SRCPATH)
Endif


Call JSON_ADDOBJECT(NODES2,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDSTRING(NODES2,ROOT,"type",SCRIPTTYPE)  From ASYRJSO
Call JSON_ADDSTRING(NODES2,ROOT,"script",NAME)  From ASYRJSO
Call JSON_ADDCLB(NODES2,ROOT,"source",SOURCE)  From ASYRJSO

Call GENERATE_JSON(NODES2,ASND.DATA) From ASYRJSO
End ERROR

