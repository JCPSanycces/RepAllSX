#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "TITRE"       : Gosub TIT
Endcase
Return

$TIT
TIT = mess(199,123,1) : # Propriétés
Return

$DEBUT
Raz [M]
For I=1 To VISNBR
 [M]DES(I-1)    = VISDES(I)
 [M]VALEUR(I-1) = VISVAL(I)
Next I
[M]NBLIG = VISNBR
Affzo
Return

$OUVRE
Local Char    CHAINE(250)
Local Char    PROGOBJ(GDIMFIC) , PROGSUB(GDIMFIC) , PROGSPE(GDIMFIC)
Local Integer PSUB , PSPE , PSTD
Local Char    OBJET(GLONAOB), SUPP(GLONID2)(0..16), DEFFIL(10)
Local Char    VISDES(20)(1..20), VISVAL(30)(1..20)
Local Integer VISNBR
Local Integer I , J , K , ER
Local Integer TEMPS , HH , MM , SS
Local Char    CLE(GLONAVA)(1..16)
Local Integer NBCLE
Local Char    ZONE(80), ABREV(4) , ABCPY(4)
Local Char    INTITULE(10), NOMFICHIER(15)
Local Integer NUMERO
Local Char    SOCIETE(GLONCPY)

OBJET = PARAM(1)
Onerrgo ERREUR From CONTROLE
GERREUR = 0
If find(OBJET,GABRCPT(1..GNBTABCPT)) & GDOSCPT<>""
 If clalev([F:AOP]) : Close Local File [AOP] : Endif 
 If clalev([F:ATX]) : Close Local File [ATX] : Endif 
 If clalev([F:AXX]) : Close Local File [AXX] : Endif 
 Local File =GTABCPT+"AOBJPROP" [AOP]
 Local File =GTABCPT+"ATEXTE"   [ATX]
 Local File =GTABCPT+"ATEXTRA"  [AXX] 
Endif
If clalev([F:AOP])=0 : Local File AOBJPROP [AOP] : Endif
If clalev([F:AOB])=0 : Local File AOBJET   [AOB] : Endif
If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
Onerrgo
If GERREUR : GERREUR = 0 : FIN = 1 : Return : Endif

# Evaluation des expressions

Raz VISNBR
Gosub NOMFIC From ="WO"+OBJET
Gosub DEFAUT From ="WO"+OBJET
Gosub SETNUM From WWCPY
Gosub DEFAUT From WWCPY
ABFIC 
ABCPY   = "W"+format$("N0:2#",TT)
SOCIETE = evalue("[F:"+ABCPY+"]WCPY")
Default [F] , [M] , [S] , [V] , [L]
For [AOP]AOP0 Where OBJ=[L]OBJET
 Onerrgo ERREUR
 [L]CHAINE = num$(evalue([F:AOP]FRM))
 Onerrgo
 VISNBR += 1
 Call LECTEXTRA(VISDES(VISNBR),"AOBJPROP","INTIT",[F:AOP]OBJ,num$([F:AOP]NUM)) From ATEXTRA
 VISVAL(VISNBR) = [L]CHAINE
Next
Default [L] , [V] , [S] , [F] , [M]

# Ajout intitulé et dates/users

If VISNBR=0
 Call LECTURE("AOB",OBJET,"") From CONTOBJ
 NOMFICHIER = [F:AOB]NOMFIC
 Call LECTURE("ATB",NOMFICHIER,"") From CONTOBJ
 If [F:ATB]INTIT<>""
  INTITULE = [F:ATB]INTIT
 Elsif [F:ATB]INTITC<>""
  INTITULE = [F:ATB]INTITC
 Endif
 CHAINE = ""
 If INTITULE<>""
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  Read [ATZ]CODZONE = NOMFICHIER;INTITULE
  If !fstat
   Case [F:ATZ]CODTYP
    When "ATX"
     If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
     Onerrgo ERREUR
     NUMERO = evalue("[F:"+ABFIC+"]"+INTITULE)
     Onerrgo
     Call TEXTE(NUMERO,CHAINE) From OBJDIV
    When "AXX","AX1","AX2","AX3"
     If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
     CLE1 = num$(evalue("[F:"+ABFIC+"]"+CLEPRIM))
     If CLESEC<>""
      CLE2 = num$(evalue("[F:"+ABFIC+"]"+CLESEC))
     Else
      CLE2 = ""
     Endif
     Call LECTEXTRA(CHAINE,NOMFICHIER,INTITULE,CLE1,CLE2) From ATEXTRA
    When Default
     Onerrgo ERREUR
     CHAINE = evalue("[F:"+ABFIC+"]"+INTITULE)
     Onerrgo
   Endcase
  Endif
 Endif
 If CHAINE<>""
  VISNBR = 1
  VISDES(1) = mess(82,123,1) : # Intitulé
  VISVAL(1) = CHAINE
 Endif

 If evalue("dim([F:"+ABCPY+"]CREDAT)")>0
  If evalue("[F:"+ABCPY+"]CREDAT")<>[0/0/0]
   VISNBR += 1
   VISDES(VISNBR) = mess(160,124,1)-"("+SOCIETE+")" : # Créé le
   VISVAL(VISNBR) = format$("D:"+GFMDAT,evalue("[F:"+ABCPY+"]CREDAT"))
   If evalue("dim([F:"+ABCPY+"]CRETIM)")>0
    TEMPS = evalue("[F:"+ABCPY+"]CRETIM")
    If TEMPS<>0
     HH = int(TEMPS/3600)
     MM = int(mod(TEMPS,3600)/60)
     SS = mod(TEMPS,60)
     VISVAL(VISNBR) -= num$(HH)+":"+num$(MM)+":"+num$(SS)
    Endif
   Endif
   If evalue("dim([F:"+ABCPY+"]CREUSR)")>0
    VISVAL(VISNBR) -= mess(161,124,1)-evalue("[F:"+ABCPY+"]CREUSR") : # par
   Endif
  Endif
 Endif

 If evalue("dim([F:"+ABCPY+"]UPDDAT)")>0
  If evalue("[F:"+ABCPY+"]UPDDAT")<>[0/0/0]
   VISNBR += 1
   VISDES(VISNBR) = mess(162,124,1)-"("+SOCIETE+")" : # Modifié le
   VISVAL(VISNBR) = format$("D:"+GFMDAT,evalue("[F:"+ABCPY+"]UPDDAT"))
   If evalue("dim([F:"+ABCPY+"]UPDTIM)")>0
    TEMPS = evalue("[F:"+ABCPY+"]UPDTIM")
    If TEMPS<>0
     HH = int(TEMPS/3600)
     MM = int(mod(TEMPS,3600)/60)
     SS = mod(TEMPS,60)
     VISVAL(VISNBR) -= num$(HH)+":"+num$(MM)+":"+num$(SS)
    Endif
   Endif
   If evalue("dim([F:"+ABCPY+"]UPDUSR)")>0
    VISVAL(VISNBR) -= mess(161,124,1)-evalue("[F:"+ABCPY+"]UPDUSR")
   Endif
  Endif
 Endif

Endif

# Affichage s'il y a quelque chose

If !VISNBR
 Call MESSAGE(mess(1,126,1)) From GESECRAN : # Pas de propriété
 FIN = 1
 Return
Endif

Return

$ERREUR
ER = errn
CHAINE = errmes$(ER)-errm
Resume

$RIEN
Resume



