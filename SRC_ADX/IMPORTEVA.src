#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTATION("EVALUATION") From GIMPOBJ
End

###################################################################################
#   MABOS  -  FQ 89268 - US 1911 -
#   SEGAY - 13/02/14 - FQ 96649 - US2420 - Mission
###################################################################################
$ACTION

  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "RAZCRE"    : Gosub RAZCRE
    When "SAIMSK"    : Gosub SAIMSK
    When "VALID"     : Gosub VALID
    When "FERME"     : Gosub FERME

  Endcase
Return


###################################################################################
$OUVRE
  Local Integer INTFRT, EVATYPCPC, TYPOBJ
  Local Mask EVA0 [EVA0], EVA1 [EVA1], EVA2 [EVA2], EVA3 [EVA3], EVA4 [EVA4], EVA5 [EVA5], EVA6 [EVA6], EVA7 [EVA7] # 13/02/14 - EXI 96649 US2420 Mission

  If clalev([F:EVE])=0 : Local File EVAEMP     [EVE] : Endif
  If clalev([F:EVC])=0 : Local File EVAEMPCPC  [EVC] : Endif
  If clalev([F:EVD])=0 : Local File EVAEMPDET  [EVD] : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
  If clalev([F:CPC])=0 : Local File COMPETENCE [CPC] : Endif
  If clalev([F:EV1])=0 : Local File EVAEMP     [EV1] : Endif
  If clalev([F:EVM])=0 : Local File EVAEMPMIS  [EVM] : Endif : # 13/02/14 - EXI 96649 US2420 Mission
  If clalev([F:EPO])=0 : Local File EMPLOPOT   [EPO] : Endif : # 13/02/14 - EXI 96649 US2420 Mission
  If clalev([F:JOT])=0 : Local File JOBTYP     [JOT] : Endif : # 13/02/14 - EXI 96649 US2420 Mission
  If clalev([F:POT])=0 : Local File POSTE      [POT] : Endif : # 13/02/14 - EXI 96649 US2420 Mission
  If clalev([F:MIS])=0 : Local File MISSION    [MIS] : Endif : # 13/02/14 - FQ 96649 - US2420 - Mission

  Read [ACV]CODACT="FRT"
  If !fstat & [F:ACV]FLACT=2
    [L]INTFRT=1
  Endif

  nolign=0
Return

$FERME
  If dim([V]WERR)>0 : Kill [V]WERR : Endif
Return

###################################################################################
$RAZCRE
  Global Integer WERR
  #Initialisation des masks et des variables
  Raz [EVA0], [EVA1], [EVA2], [EVA3], [EVA4], [EVA5], [EVA6], [EVA7] : # 13/02/14 - EXI 96649 US2420 Mission
  nolign=0
Return

Subprog CREATE_ADI(NUMTAB, CODE)
Value Integer NUMTAB
Value Char    CODE

  Readlock [F:ADI]CODE=NUMTAB;CODE
  If fstat>1 Then
    [F:ADI]NUMTAB = NUMTAB
    [F:ADI]CODE   = CODE
    Write [F:ADI]
    If !fstat
       ##------------------------------------------------------------------------------------------------##
       ## Maj des champs LNGDES et SHODES dans la table ATEXTRA                                          ##
       ##------------------------------------------------------------------------------------------------##
       Call MAJTEXTRA(CODE,"ATABDIV","LNGDES",num$(NUMTAB), CODE) From ATEXTRA
       Call MAJTEXTRA(left$(CODE,GLONSHO),"ATABDIV","SHODES",num$(NUMTAB), CODE ) From ATEXTRA
   Endif
  Endif
  If fstat
    GOK=0 : Call FSTA("ADI") From GLOCK : End
  Endif
End

###################################################################################
$SAIMSK
Local Integer WI

If GOK=0 : Return : Endif
  #Affectation des masks
  Case IMPFIC
    When "EVE"
      [V]WERR=0
      nolign = 1
      [M:EVA0] = [F:EVE]
#      If [M:EVA0]EVAVAL>3 :  [M:EVA0]EVAVAL = 1 : Endif : # si validé, Import status "En cours"
      [M:EVA0]EVAVAL = 1 : #Import status "En cours"
      [M:EVA0]VISCOL = 0 : # 0 car status "En cours"
      [M:EVA1]EVASCA = [F:EVE]EVASCA
      [M:EVA3] = [F:EVE]
      [M:EVA5] = [F:EVE]
      [M:EVA6] = [F:EVE]
      [M:EVA7]EVAMIS = [F:EVE]EVAMIS : # 13/02/14 - EXI 96649 US2420 Mission

      [F:EVE]EVAJOBGRP = vireblc([F:EVE]EVAJOBGRP,4)
      [F:EVE]EVATYP = vireblc([F:EVE]EVATYP,4)
      [F:EVE]ARE = vireblc([F:EVE]ARE,4)

      Read [F:ID]ID0=[F:EVE]REFNUM
      If fstat
        Call TRACE(2,mess(83,10702,1)-[F:EVE]REFNUM) From SUBIMPOBJ : # Matricule inexistant
        GOK=0 : [V]WERR=1 : Gosub TRACE_EXIT: Return
      Endif
      # Vérif Contrat
      Local Char WMESS(250)
      Call SEARCH_CTR([M:EVA0]REFNUM, [M:EVA0]CTRNUM, [M:EVA0]CTRDAT, [M:EVA0]EVADATEND, [M:EVA0]EVADATEND, [L]WMESS) From DIVPAYE
#      Call CHERCHE_CTR_PER([M:EVA0]REFNUM,[M:EVA0]EVADATEND,[M:EVA0]EVADATEND,[M:EVA0]CEV,[M:EVA0]CTRNUM) From SUBEVA
#      If [M:EVA0]CTRNUM=""

      If [L]WMESS<>""
         Call TRACE(2,mess(180,10702,1)-mess(188,10702,1)-[M:EVA0]REFNUM+"/"+[M:EVA0]CTRNUM+"/"+format$("D:"+GFMDAT,[M:EVA0]CTRDAT)) From SUBIMPOBJ : # Contrat inexistant
         GOK=0 : [V]WERR=1 : Gosub TRACE_EXIT : Return
      Else
         If [M:EVA0]CTRDAT =[0/0/0] Then [M:EVA0]CTRDAT=[F:HRCTR]CTRDAT :Endif
         GCURLEG = func TOOLSHRLEG.LEGHRCTRDAT([M:EVA0]REFNUM, [M:EVA0]CTRNUM, [M:EVA0]CTRDAT)
      Endif


      If dim([M:EVA3]EVASTG)>0
         For nolign=1 To dim([F:EVE]EVASTG)
            If vireblc([F:EVE]EVASTG(nolign-1),4)="" & vireblc([F:EVE]DOM(nolign-1),4)="" & vireblc([F:EVE]THM(nolign-1),4)="": Break : Endif
            [M:EVA3] = [F:EVE]
            [F:EVE]EVASTG(nolign-1) = vireblc([F:EVE]EVASTG(nolign-1),4)
            [F:EVE]DOM(nolign-1) = vireblc([F:EVE]DOM(nolign-1),4)
            [F:EVE]THM(nolign-1) = vireblc([F:EVE]THM(nolign-1),4)
            [M:EVA3]NBRSTG = nolign
         Next nolign
      Endif
      # Création du métier s'il n'existe pas
      If [F:EVE]EVAJOBGRP<>""      Then Call CREATE_ADI(10460, [F:EVE]EVAJOBGRP) : Endif
      For [L]WI=0 To dim([F:EVE]DOM)-1
        # Création du domaine s'il n'existe pas
        If [L]INTFRT=1 & [F:EVE]DOM([L]WI)<>"" Then Call CREATE_ADI(10381, [F:EVE]DOM([L]WI))       : Endif
        # Création du thème s'il n'existe pas
        If [L]INTFRT=1 & [F:EVE]THM([L]WI)<>"" Then Call CREATE_ADI(10457, [F:EVE]THM([L]WI))       : Endif
      Next
      # Création du type d'évaluation s'il n'existe pas
      If [F:EVE]EVATYP<>""         Then Call CREATE_ADI(10464, [F:EVE]EVATYP)    : Endif
      # Création de la région si elle n'existe pas
      If [F:EVE]ARE<>""         Then Call CREATE_ADI(10465, [F:EVE]ARE)       : Endif


    When "EVC"
      If [F:EVC]EVATYPCPC=2
       If [M:EVA2]NBRVAL+1 > dim([M:EVA2]CPCVAL)
          # Tableau des compétences plein
          Call TRACE(2,mess(5,10720,1)+" > "+num$(dim([M:EVA2]CPCVAL)) -[M:EVA0]REFNUM+"/"+[M:EVA0]CTRNUM+"/"+format$("D:"+GFMDAT,[M:EVA0]CTRDAT)) From SUBIMPOBJ
          GOK=0 : [V]WERR=1 :Return
        Else
          nolign=[F:EVC]NUMLIG
          # Watchout here, don't make a 'transclass' !
          [M:EVA2]CPCVAL(nolign-1)       = [F:EVC]EVACPC
          [M:EVA2]LEVCPCVAL(nolign-1)    = [F:EVC]EVALEV
          [M:EVA2]LEVCPCEVA(nolign-1)    = [F:EVC]LEVCPCEVA
          If [F:EVC]LEVREFVAL<>0
            [M:EVA2]LEVREFVAL(nolign-1)  = [F:EVC]LEVREFVAL
          Else
            [M:EVA2]LEVREFVAL(nolign-1)  = func SUBECP.CPC_LEVREF([F:EVC]EVACPC,[F:EVC]EVALEV)
          Endif
          If [F:EVC]LEVREFEVA<>0
            [M:EVA2]LEVREFEVA(nolign-1)  = [F:EVC]LEVREFEVA
          Else
            [M:EVA2]LEVREFEVA(nolign-1)  = func SUBECP.CPC_LEVREF([F:EVC]EVACPC,[F:EVC]LEVCPCEVA)
          Endif
          [M:EVA2]EVACPCDATVAL(nolign-1) = [F:EVC]EVACPCDAT
          [M:EVA2]ORICPCVAL(nolign-1)    = [F:EVC]ORICPC
          [M:EVA2]ACTDEV(nolign-1)       = [F:EVC]ACTDEV
          [M:EVA2]FLGMODVAL(nolign-1)    = 1
          [M:EVA2]FLGOLDVAL(nolign-1)    = 2

          Call LECTURE("CPC",[F:EVC]EVACPC,"") From CONTOBJ
          [M:EVA2]CODSCAVAL(nolign-1) = [F:CPC]CODSCA

          # Création de l'Action développement si elle n'existe pas
          If [F:EVC]ACTDEV<>""         Then Call CREATE_ADI(10467, [F:EVC]ACTDEV)       : Endif

          [M:EVA2]NBRVAL +=1
        Endif
      Endif

    When "EVD"
      nolign   = [F:EVD]NUMLIG
      [L]TYPOBJ   = [F:EVD]TYPOBJ
      If [F:EVD]TYPOBJ = 1 Then
        If [M:EVA1]NBRCMT+1 > dim([M:EVA1]EVACRIT)
          # Tableau des performances plein
          Call TRACE(2,mess(148,10720,1)-" > "+num$(dim([M:EVA1]EVACRIT)) -[M:EVA0]REFNUM+"/"+[M:EVA0]CTRNUM+"/"+format$("D:"+GFMDAT,[M:EVA0]CTRDAT)) From SUBIMPOBJ
          GOK=0 : [V]WERR=1 :Return
        Else
          [M:EVA1]NBRCMT += 1
          [M:EVA1] = [F:EVD]
        Endif
      Else
        If [M:EVA4]NBROBJ+1 > dim([M:EVA4]EVACRIT)
        # Tableau des objectifs plein
         Call TRACE(2,mess(147,10720,1)-" > "+num$(dim([M:EVA4]EVACRIT)) -[M:EVA0]REFNUM+"/"+[M:EVA0]CTRNUM+"/"+format$("D:"+GFMDAT,[M:EVA0]CTRDAT)) From SUBIMPOBJ
         GOK=0 : [V]WERR=1 :Return
        Else
           [M:EVA4]NBROBJ += 1
           [M:EVA4] = [F:EVD]
        Endif
      Endif

    When "EVM"
      # 13/02/14 - EXI 96649 US2420 Mission
      nolign   = [F:EVM]NUMLIG
      If [M:EVA7]NBRMIS+1 > dim([M:EVA7]CODMIS)
        # Tableau des missions plein
         Call TRACE(2,mess(150,10720,1)-" > "+num$(dim([M:EVA7]CODMIS)) -[M:EVA0]REFNUM+"/"+[M:EVA0]CTRNUM+"/"+format$("D:"+GFMDAT,[M:EVA0]CTRDAT)) From SUBIMPOBJ
         GOK=0 : [V]WERR=1 :Return
      Else
         [M:EVA7]NBRMIS += 1
         [M:EVA7] = [F:EVM]
      Endif

  Endcase
Return

###################################################################################
$VALID
  If nolign=0 : Return : Endif
  If GOK=0 : GERREUR=1 : Return : Endif

    Read [F:EV1]EVE0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP
    If !fstat
      If [F:EV1]EVAVAL>3 Then
         # statut de validation (validé N+1) - modif impossible
         Call TRACE(2,","-mess(9,123,1)+":"-mess(63,10720,1)-mess([F:EV1]EVAVAL,10947,1)-[M:EVA0]REFNUM-[M:EVA0]CTRNUM-format$("D:"+GFMDAT,[M:EVA0]EVADATSTR)-format$("D:"+GFMDAT,[M:EVA0]EVADATEND)-[M:
& EVA0]EVATYP) From SUBIMPOBJ
        [V]WERR=1 :Return
      Endif
      If [M:AOE1]OPTUPD<>2 :# MODIFICATION NON AUTORISÉE
        Call TRACE(2,","-mess(1215,9900,1)+":"-mess(63,10720,1)-[M:EVA0]REFNUM-[M:EVA0]CTRNUM-format$("D:"+GFMDAT,[M:EVA0]EVADATSTR)-format$("D:"+GFMDAT,[M:EVA0]EVADATEND)-[M:EVA0]EVATYP) From
& SUBIMPOBJ
        [V]WERR=1 :Return
      Endif
    Endif

  Call SAIMSK("EVE","IMP_ZONE","SUBIMPOBJ") From CONTEVA
  If  mkstat : Gosub TRACE_EXIT: Return  :Endif

  Call SAIMSK("EVC","IMP_ZONE","SUBIMPOBJ") From CONTEVA
  If  mkstat : Gosub TRACE_EXIT: Return  :Endif

  Call SAIMSK("EVDP","IMP_ZONE","SUBIMPOBJ") From CONTEVA
  If  mkstat : Gosub TRACE_EXIT : Return  :Endif

  Call SAIMSK("EVDO","IMP_ZONE","SUBIMPOBJ") From CONTEVA
  If  mkstat : Gosub TRACE_EXIT : Return  :Endif

  Call SAIMSK("EVM","IMP_ZONE","SUBIMPOBJ") From CONTEVA : # 13/02/14 - EXI 96649 US2420 Mission
  If  mkstat : Gosub TRACE_EXIT : Return  :Endif

  If [V]WERR=1 :Return :Endif

  GOK=1

  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK<0 : GERREUR=1 : Goto AB_TR1 : Endif
Return

#######################################################################################
#                ENREGISTREMENT DES DONNEES DANS LES TABLES
#######################################################################################
$TR1
  If [V]WERR=1 Then GOK=0 : Return : Endif

  Trbegin [EVE]
  Readlock [F:EVE]EVE0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP
  Local Integer WEVA
  [L]WEVA=-1
  If fstat>1
    [L]WEVA=0
  Elsif !fstat & [M:AOE1]OPTUPD=2
    [L]WEVA=1
  Endif

  Default File [EVE]
  If [L]WEVA>=0 : Gosub AFFECT_EVA : Endif

  Case [L]WEVA
    When 0 :   #--- Création -----
    Call INICRE From SUBIMPOBJ0
    If dim([F:EVE]EXPNUM)>0 : [F:EVE]EXPNUM = [C]EXPORT : Endif
    Write [F:EVE]

   When 1  :     # --- Modification ---------
    Call INIMOD From SUBIMPOBJ0
    Rewrite [F:EVE]

   When Default :  # --- Pas de modif possible ---------
    GOK =0

  Endcase

  If [L]WEVA>=0
    Call TRACE([L]WEVA,mess(63,10720,1)-[M:EVA0]REFNUM-[M:EVA0]CTRNUM-format$("D:"+GFMDAT,[M:EVA0]EVADATSTR)-format$("D:"+GFMDAT,[M:EVA0]EVADATEND)-[M:EVA0]EVATYP) From SUBIMPOBJ
  Endif
  If fstat
    GOK=0 : Call FSTA("EVE") From GLOCK : Return
  Endif


  If GOK=0 Then Return : Endif


#----------------------------------------------
# Préparation Enregistrement des Lignes EVD
#----------------------------------------------
  Default File [EVD]
  If [L]WEVA=1
    # Modif EVA : Suppression des lignes de détails existantes
    Delete [EVD] Where [F:EVD]REFNUM=[M]REFNUM & [F:EVD]CTRNUM=[M]CTRNUM
&    & [F:EVD]EVADATSTR=[M]EVADATSTR & [F:EVD]EVADATEND=[M]EVADATEND & [F:EVD]EVATYP=[M]EVATYP
    If fstat=1
     GOK = -1 : GLOCK = "$EVAEMPDET"-[M]REFNUM-[M]CTRNUM-[M]EVADAT-num$([F:EVD]NUMLIG)
     Return
    Endif
  Endif

#-----------------------------------
# Enregistrement EVD Performances
#-----------------------------------
  # Création lignes de détail Performances
  For [L]I=1 To [M:EVA1]NBRCMT
    [L]TYPOBJ=1
    Gosub WRITE_EVD
    If GOK=0 : Break : Endif
  Next [L]I
  If GOK=0 Then Return : Endif

#------------------------------
# Enregistrement EVD Objectifs
#------------------------------
  For [L]I=1 To [M:EVA4]NBROBJ
    [L]TYPOBJ=2
    Gosub WRITE_EVD
    If GOK=0 : Break : Endif
  Next [L]I
  If GOK=0 Then Return : Endif

#----------------------------------------------------
# Préparation Enregistrement des Lignes EVC Validées
#----------------------------------------------------
  Default File [EVC]
  If [L]WEVA=1
    # Modif EVA : Suppression des lignes de détails existantes
    Delete [EVC] Where [F:EVC]REFNUM=[M]REFNUM & [F:EVC]CTRNUM=[M]CTRNUM
&      & [F:EVC]EVADATSTR=[M]EVADATSTR & [F:EVC]EVADATEND=[M]EVADATEND
&      & [F:EVC]EVATYP=[M]EVATYP
&      & [F:EVC]EVATYPCPC = 2
  Endif
#----------------------------
# Enregistrement EVC
#----------------------------
  For [L]I=1 To [M:EVA2]NBRVAL
    Readlock [F:EVC]EVC0(7)=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP;2;[M:EVA2]CPCVAL(I-1)
    If fstat<>1 : Gosub AFFECT_EVC : Endif
    If fstat>1    :       # --- Création -----
      Call INICRE From SUBIMPOBJ0
      If dim([F:EVC]EXPNUM)>0 : [F:EVC]EXPNUM = [C]EXPORT : Endif
      Write [F:EVC]
    Elsif !fstat  :       # --- Modification ---------
      Call INIMOD From SUBIMPOBJ0
      If dim([F:EVC]EXPNUM)>0 : [F:EVC]EXPNUM = [C]EXPORT : Endif
      Rewrite [F:EVC]
    Endif
    If fstat
      GOK=0 : Call FSTA("EVC") From GLOCK : Break
    Endif
   Next [L]I
  If GOK=0 Then Return : Endif

# 13/02/14 - EXI 96649 US2420 Mission
#----------------------------------------------
# Préparation Enregistrement des Lignes EVM
#----------------------------------------------
  Default File [EVM]
  If [L]WEVA=1
    # Modif EVA : Suppression des lignes de détails existantes
    Delete [EVM] Where [F:EVM]REFNUM=[M]REFNUM & [F:EVM]CTRNUM=[M]CTRNUM
&    & [F:EVM]EVADATSTR=[M]EVADATSTR & [F:EVM]EVADATEND=[M]EVADATEND & [F:EVM]EVATYP=[M]EVATYP
    If fstat=1
     GOK = -1 : GLOCK = "$EVAEMPMIS"-[M]REFNUM-[M]CTRNUM-[M]EVADAT-num$([F:EVM]NUMLIG)
     Return
    Endif
  Endif
# 13/02/14 - EXI 96649 US2420 Mission
#-----------------------------------
# Enregistrement EVM Missions
#-----------------------------------
  # Création lignes de détail Missions
  If [L]WEVA=0 & ![M:EVA7]NBRMIS
    # FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
    # exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
    Gosub INI_POT_JOBPOT From SUBEVA
    Gosub INIT_MIS From SUBEVA
  Endif
  For [L]I=1 To [M:EVA7]NBRMIS
      Gosub WRITE_EVM
      If GOK=0 : Break : Endif
  Next [L]I
  If GOK=0 Then Return : Endif


#---------------------------
# Validation Transaction
#---------------------------
  Commit

Return

#########################
$AFFECT_EVA
Local Integer I
  Raz [F:EVE]
  [F:EVE]=[M:EVA0]
  [F:EVE]EVASCA=[M:EVA1]EVASCA
  [F:EVE]=[M:EVA3]
  [F:EVE]=[M:EVA5]
  [F:EVE]=[M:EVA6]
  [F:EVE]EVAMIS=[M:EVA7]EVAMIS  # 13/02/14 - EXI 96649 US2420 Mission
Return

#########################
$AFFECT_EVC

  Raz [F:EVC]
  nolign=I

  [F:EVC]REFNUM    = [F:EVE]REFNUM
  [F:EVC]CTRNUM    = [F:EVE]CTRNUM
  [F:EVC]CTRDAT    = [F:EVE]CTRDAT
  [F:EVC]EVADATSTR = [F:EVE]EVADATSTR
  [F:EVC]EVADATEND = [F:EVE]EVADATEND
  [F:EVC]EVATYP    = [F:EVE]EVATYP
  [F:EVC]EVADAT    = [F:EVE]EVADAT
  [F:EVC]NUMLIG    = nolign
  [F:EVC]EVACPCDAT = [M:EVA2]EVACPCDATVAL(nolign-1)
  [F:EVC]EVACPC    = [M:EVA2]CPCVAL(nolign-1)
  [F:EVC]EVALEV    = [M:EVA2]LEVCPCVAL(nolign-1)
  [F:EVC]LEVCPCEVA = [M:EVA2]LEVCPCEVA(nolign-1)
  [F:EVC]ORICPC    = [M:EVA2]ORICPCVAL(nolign-1)
  [F:EVC]ACTDEV    = [M:EVA2]ACTDEV(nolign-1)
  [F:EVC]LEVREFVAL = [M:EVA2]LEVREFVAL(nolign-1)
  [F:EVC]LEVREFEVA = [M:EVA2]LEVREFEVA(nolign-1)
  [F:EVC]EVATYPCPC = 2

Return

#########################
$WRITE_EVD
  Readlock [F:EVD]EVD0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP;[L]TYPOBJ;[L]I
  If fstat<>1
     Gosub AFFECT_EVD
  Endif
  If fstat>1   :       # --- Création -----
    Call INICRE From SUBIMPOBJ0
    Write [F:EVD]
  Elsif !fstat :       # --- Modification ---------
    Call INIMOD From SUBIMPOBJ0
    Rewrite [F:EVD]
  Endif
  If fstat
    GOK=0 : Call FSTA("EVD") From GLOCK : Return
  Endif
Return

$AFFECT_EVD

  Raz [F:EVD]
  nolign=[L]I
  [F:EVD]=[M:EVA0]
  If [L]TYPOBJ=1 Then
    [F:EVD]=[M:EVA1]
  Else
    [F:EVD]=[M:EVA4]
  Endif
  If [F:EVD]ORIDET = 0 Then [F:EVD]ORIDET=1 : Endif
  [F:EVD]NUMLIG = [L]I
  [F:EVD]TYPOBJ = [L]TYPOBJ
Return

#########################
# 13/02/14 - EXI 96649 US2420 Mission
$WRITE_EVM
  Readlock [F:EVM]EVM0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]EVADATSTR;[M:EVA0]EVADATEND;[M:EVA0]EVATYP;[L]I
  If fstat<>1
     Gosub AFFECT_EVM
  Endif
  If fstat>1
    Call INICRE From SUBIMPOBJ0
    Write [F:EVM]
  Elsif !fstat :       # --- Modification ---------
    Call INIMOD From SUBIMPOBJ0
    Rewrite [F:EVM]
  Endif
  If fstat
    GOK=0 : Call FSTA("EVM") From GLOCK : Return
  Endif
Return
# 13/02/14 - EXI 96649 US2420 Mission
$AFFECT_EVM
  Raz [F:EVM]
  nolign=[L]I
  [F:EVM]=[M:EVA0]
  [F:EVM]=[M:EVA7]
  [F:EVM]NUMLIG = I
Return

