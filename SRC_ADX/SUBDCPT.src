#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque DATCPT
GBIDI1=3
Call PAYCPT(GBIDI1,"PAR",GBIDA2,GBIDA1) From PAYDIV
End


########################################
# DAT1 : Date comptable
########################################
Subprog D_DAT1(VALEUR)
Variable Date    VALEUR
If [M]DACDAT1=3 : Grizo [DIA]DAT1 : mkstat=1 : Endif
End

Subprog C_DAT1(VALEUR)
Variable Date    VALEUR
If [M]DACDAT1=1 & VALEUR=[0/0/0]
 GMESSAGE=mess(10,123,1) : mkstat=2 : # Zone obligatoire
Endif
End

########################################
# DAT2 : Date de valeur
########################################
Subprog D_DAT2(VALEUR)
Variable Date    VALEUR
If [M]DACDAT2=3 : Grizo [DIA]DAT2 : mkstat=1 : Endif
End

Subprog C_DAT2(VALEUR)
Variable Date    VALEUR
If [M]DACDAT2=1 & VALEUR=[0/0/0]
 GMESSAGE=mess(10,123,1) : mkstat=2 : # Zone obligatoire
Endif
End
