Subprog C_BNKACCTYP(VALEUR)
Variable Integer VALEUR
  If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBPCAUKI") Then
    Call C_BNKACCTYP(VALEUR) From SUBPCAUKI
  Endif
End

Subprog C_BNKACCNUM(VALEUR)
Variable Decimal VALEUR
  If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBPCAUKI") Then
    Call C_BNKACCNUM(VALEUR) From SUBPCAUKI
  Endif
End

Subprog AS_BNKSRTCOD(VALEUR)
Variable Char    VALEUR()
  If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBPCAUKI") Then
    Call AS_BNKSRTCOD(VALEUR) From SUBPCAUKI
  Endif
End

Subprog C_BNKSRTCOD(VALEUR)
Variable Char    VALEUR()
  If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBPCAUKI") Then
    Call C_BNKSRTCOD(VALEUR) From SUBPCAUKI
  Endif
End

Subprog AM_BNKSRTCOD(VALEUR)
Variable Char    VALEUR()
  If GCURLEG = 'BRI' and func DIVPAYE.EXISTE_KXX("SUBPCAUKI") Then
    Call AM_BNKSRTCOD(VALEUR) From SUBPCAUKI
  Endif
End
#ANCOA - 2017-09-18 - X3-22017 - END

