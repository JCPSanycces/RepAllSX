#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du fichier GCAISSE
Raz GPILOBJ
Call OBJET("PCA",GBIDC1,GBIDC2) From GOBJET
End

###########################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "SETBOUT"     : Gosub SETBOUT
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "VERF_ANU"    : Gosub VERF_ANU
 When "EFFMASK"     : Gosub EFFMASK
 When "INICRE"      : Gosub SAUVE
 When "INIMOD"      : Gosub SAUVE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FERME"       : Gosub FERME
 When "APRES_CRE"   : Gosub APRES
 When "APRES_MOD"   : Gosub APRES
 When "AVANT_CHOI"  : Gosub APRES
Endcase
Return

###########################################
$OUVRE
If clalev ([F:ORG])=0 : Local File ORGANISME [ORG] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

###########################################
$LIENS
Call GRISE_LEV([F:PCA]LEV)

If [F:PCA]LEV=5 : Gosub LIEN_EMP : Endif        :#GCURLEG is load in LIEN_EMP
If [F:PCA]LEV=6 : Gosub LIEN_CTR : Endif        :#GCURLEG is load in LIEN_CTR

Case [F:PCA]LEV
 When 1,2 : GCURLEG = [F:PCA]LEG
 When 3 : Call LECTURE("CPY",[F:PCA]CPY,"") From CONTOBJ : GCURLEG = [F:CPY]LEG
 When 4 : Call LECTURE("FCY",[F:PCA]FCY,"") From CONTOBJ : Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ : GCURLEG = [F:CPY]LEG
Endcase

If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Gosub CHARGE

Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

###########################################
$CHARGE
Local Char LSTORG
Local Integer NBRORG
#JOJAC - 2016-09-13 - X3PEOP-1133 - START
 Local Integer NUMTAB(10) : [L]NUMTAB = 10469 : # table diverse
 Local Char NOMLEG(10) : [L]NOMLEG = GCURLEG
#JOJAC - 2016-09-13 - X3PEOP-1133 - END

Call PARAM (GCURLEG,"NBCAISTD",LSTORG) From ADOVAL
NBRORG=val(LSTORG)
Raz LSTORG
Call PARAM (GCURLEG,"LSTORG",LSTORG) From ADOVAL

Call CLEAR_GRID

#Caisses std
#JOJAC - 2016-09-13 - X3PEOP-1133 - START
#nolign=1
#For I=1 To NBRORG
#  [M:PCA1]CAI(nolign-1) = I
#  [M:PCA1]CAIVAL(nolign-1) = mess(I,val(LSTORG),1)
#  [M:PCA1]ORG(nolign-1)=[F:PCA]ORG(I-1)
#  nolign+=1
#Next
#[M:PCA1]TBL = nolign-1

If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif

nolign=1
I=1
For [ADI] Where NUMTAB = [L]NUMTAB and LEG = [L]NOMLEG and N1=1 and ENAFLG = 2
  [M:PCA1]CAI(nolign-1) = [ADI]CODE
  Call LECTEXTRA([M:PCA1]CAIVAL(nolign-1),"ATABDIV","LNGDES","10469",[F:ADI]CODE) From ATEXTRA
  [M:PCA1]ORG(nolign-1)=[F:PCA]ORG(I-1)


  #ANCOA X3-22017 load the extra Autoenrolment details - START
  If func AFNC.ACTIV("FUKPH")>0 and func DIVPAYE.EXISTE_KXX("SUBPCAUKI")
    Call LOAD_AE_DETAILS (nolign-1) From SUBPCAUKI
  Endif
  #ANCOA X3-22017 - END
  nolign+=1
  I+=1
Next
[M:PCA1]TBL = nolign-1
#JOJAC - 2016-09-13 - X3PEOP-1133 - END

nolign=1
I=1
For [ADI] Where NUMTAB = [L]NUMTAB and LEG = [L]NOMLEG and N1=2 and ENAFLG = 2
  [M:PCA2]CAI2(nolign-1) = [ADI]CODE
  Call LECTEXTRA([M:PCA2]CAIVAL2(nolign-1),"ATABDIV","LNGDES","10469",[F:ADI]CODE) From ATEXTRA
  [M:PCA2]ORG2(nolign-1)=[F:PCA]ORG(I-1)
  nolign+=1
  I+=1
Next
[M:PCA2]TBL2 = nolign-1
#JOJAC - 2016-09-13 - X3PEOP-1133 - END

Call REFRESH_GRID
Return

###########################################
$SAUVE

If dim([M:PCA2]TBL2)>0
 For I=0 To [M:PCA2]TBL2-1
  [F:PCA]ORG(NBRORG+I)=[M:PCA2]ORG2(I)
 Next
Endif

#ANCOA X3-22017 save the extra Autoenrolment details - START
If func AFNC.ACTIV("FUKPH")>0 and dim([M:PCA1]TBL)>0 and dim(NBRORG)>0
  Call SAVE_AE_DETAILS (nolign-1) From SUBPCAUKI
Endif
#ANCOA X3-22017 - END


Return

###########################################
$LIEN_EMP
Read [ID]ID0 = [F:PCA]EMP
[M:PCA0]NAM = [F:ID]NAM-[F:ID]SRN
Call LECTURE("FCY",[F:ID]FCYORI,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GCURLEG = [F:CPY]LEG
Return

###########################################
$LIEN_CTR
Filter [HRCTR] Where CTRNUM=[F:PCA]CTR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 Read [ID]ID0=[F:HRCTR]REFNUM
 [M:PCA0]NAM = [F:ID]NAM-[F:ID]SRN

 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 GCURLEG = [F:CPY]LEG

Endif
Return

###########################################
$RAZCRE
Raz GCURLEG
Call CLEAR_GRID
Call GRISE_LEV(1)
Return

$RAZDUP
Raz [F:PCA]
Gosub CHARGE
Return

###########################################
$EFFMASK

Case MA
 When 1 :
  #Caisses std
#JOJAC - 2016-09-13 - X3PEOP-1133 - START
#  nolign=1
#  For I=1 To NBRORG
#    [M:PCA1]CAI(nolign-1) = I
#    [M:PCA1]CAIVAL(nolign-1) = mess(I,val(LSTORG),1)
#    [M:PCA1]ORG(nolign-1)=""
#    nolign+=1
#  Next
#  [M:PCA1]TBL = nolign-1
#    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
#    nolign=1
#    I=1
#    For [ADI] Where NUMTAB = [L]NUMTAB and LEG = [L]NOMLEG and N1=1 and ENAFLG = 1
#     Infbox rowcount(ADI)
#     [M:PCA1]CAI(nolign-1) = I
#     [M:PCA1]CAIVAL(nolign-1)= [ADI]LNGDES
#     [M:PCA1]ORG(nolign-1)=[F:PCA]ORG(I-1)
#     I+=1
#     nolign+=1
#    Next
#    [M:PCA1]TBL = nolign-1
#JOJAC - 2016-09-13 - X3PEOP-1133 - END


  Affzo
 When 2 :
  #Caisses distributeur
  J=0
  If dim(NBRORG) > 0# ANCOA X3-50452 2017-03-10 - Check NBRORG exists before trying to use it for a loop
    For I=NBRORG+1 To len(mess(I,val(LSTORG),1))
      [M:PCA2]CAI2(J)=num$(I)  #ANCOA X3-50452 2017-29-09 - fix type incompatibilty error
      [M:PCA2]CAIVAL2(J)=mess(I,val(LSTORG),1)
      [M:PCA2]ORG2(J)=""
      J+=1
    Next
  Endif
  [M:PCA2]TBL2=J
  Affzo
Endcase
Return

###########################################
$SETBOUT
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR  CHAINE+="A"  Endif

# (C) PROSPER 13/07/10 - Ajout du point de menu Génération caisse par contrat (TRTPCACTR)
# P06 / 66101
If [L]CLECUR & [M:PCA0]LEV = 2
    # Le point de menu n'est activable que si on a un enregistrement chargé de niveau "2" = population
    [L]CHMEN += "1"
Endif

Return

###########################################
$FIN_ACTION
Case [L]BOUT
    When "1"
        # (C) PROSPER 13/07/10
        # P06 / 66101
        # Déclencher le rafraichissement de la liste gauche principale en retour
        # de l'action TRTPCACTR
        Gosub REMPLIT From GOBJSUB
Endcase
Return

###########################################
$VERF_ANU
Trbegin [PCA]
 Delete [PCA] Where LEV=[M:PCA0]LEV & POP=[M:PCA0]POP & CPY=[M:PCA0]CPY
&                 & FCY=[M:PCA0]FCY & EMP=[M:PCA0]EMP & CTR=[M:PCA0]CTR & LEG=GCURLEG
 If fstat = 1  : # enreg locké
  GLOCK = "$CAISSE" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

###########################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###########################################
$AB_ANN
Rollback
Return

###########################################
$APRES_MODIF
#42589
If COUZON="LEV" : [M:PCA0]LEV = val(CZ) : Endif
Return

$APRES
Call GRISE_LEV([M]LEV)
Return

########################################
Subprog AS_TBL
#[M:PCA1]TBL = GNBCAISTD
End

###########################################
Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
# WGA suite ajout de la valeur service dans le menu local
Raz GMENLOC
GMENLOC(7)=1
End

Subprog AM_LEV(VALEUR)
Variable Integer VALEUR
Call GRISE_LEV(VALEUR)
End

###########################################
Subprog GRISE_LEV(VALEUR)
Value Integer VALEUR
#JOJAC - 2016-09-13 - X3PEOP-1133 - START
Case VALEUR
 When 1
  Effzo [PCA0]CPY,POP,FCY,EMP,ZPOP,ZCPY,ZFCY,NAM,CTR
  Grizo [PCA0]CPY,POP,FCY,EMP,CTR
  If dim([M:PCA0]LEG) : Actzo [PCA0]LEG : Endif
 When 2
  Effzo [PCA0]CPY,FCY,EMP,ZCPY,ZFCY,NAM,CTR
  Grizo [PCA0]CPY,FCY,EMP,CTR,LEG
  #Actzo [PCA0]POP
  #If dim([M:PCA0]LEG)>=0 : Actzo [PCA0]LEG : Endif
  If dim([M:PCA0]POP) : Actzo [PCA0]POP : Endif
 When 3
  Effzo [PCA0]POP,FCY,EMP,ZPOP,ZFCY,NAM,CTR
  #Grizo [PCA0]POP,FCY,EMP,CTR,LEG
  Grizo [PCA0]POP,FCY,EMP,CTR,LEG
  #If dim([M:PCA0]LEG)>=0 : Diszo [PCA0]LEG : Endif
  #Actzo [PCA0]CPY
  If dim([M:PCA0]CPY) : Actzo [PCA0]CPY : Endif
 When 4
  Effzo [PCA0]POP,CPY,EMP,ZPOP,ZCPY,NAM,CTR
  #Grizo [PCA0]POP,CPY,EMP,CTR
  Grizo [PCA0]POP,CPY,EMP,CTR,LEG
  #If dim([M:PCA0]LEG)>=0 : Diszo [PCA0]LEG : Endif
  #Actzo [PCA0]FCY
  If dim([M:PCA0]FCY) : Actzo [PCA0]FCY : Endif
 When 5
  #Effzo [PCA0]POP,CPY,FCY,ZPOP,ZCPY,ZFCY,CTR
  #Grizo [PCA0]POP,CPY,FCY,CTR
  Grizo [PCA0]POP,CPY,FCY,CTR,LEG
  #If dim([M:PCA0]LEG)>=0 : Diszo [PCA0]LEG : Endif
  If dim([PCA0]EMP) :  Actzo [PCA0]EMP : Endif
 When 6
  Effzo [PCA0]POP,CPY,FCY,EMP,ZPOP,ZCPY,ZFCY,NAM
  #Grizo [PCA0]POP,CPY,FCY,EMP
  Grizo [PCA0]POP,CPY,FCY,EMP,LEG
  #If dim([M:PCA0]LEG) : Diszo [PCA0]LEG : Endif
  If dim([PCA0]CTR) : Actzo [PCA0]CTR : Endif
Endcase
#JOJAC - 2016-09-13 - X3PEOP-1133 - END
End

###########################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M:PCA0]LEV<>3 : mkstat = 1 : End : Endif
End

###########################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:PCA0]LEV<>4 : mkstat = 1 : End : Endif
End

###########################################
Subprog AS_EMP(VALEUR)
Variable Char    VALEUR()
If [M:PCA0]LEV<>5 : mkstat = 1 : End : Endif
End

###########################################
Subprog AM_EMP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("EML",VALEUR,"") From CONTOBJ
[M:PCA0]NAM = [F:ID]NAM-[F:ID]SRN
Call LECTURE("FCY",[F:ID]FCYORI,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GCURLEG = [F:CPY]LEG
If dim([M]LEG)>=0 : [M]LEG=GCURLEG : Affzo [M]LEG : Endif
Gosub CHARGE
End

###########################################
Subprog AS_TBL2

Local Char LSTORG
Local Integer NBRORG

Call PARAM (GCURLEG,"NBCAISTD",LSTORG) From ADOVAL
NBRORG=val(LSTORG)
Raz LSTORG
Call PARAM (GCURLEG,"LSTORG",LSTORG) From ADOVAL

If len(mess(0,val(LSTORG),1)) > NBRORG
  [M:PCA2]TBL2 = len(mess(0,val(LSTORG),1))-NBRORG
Else
  [M:PCA2]TBL2 = 0
Endif

End

############################################
Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()
If [M:PCA0]LEV<>6 : mkstat = 1 : End : Endif
End

Subprog AM_CTR(VALEUR)
Variable Char    VALEUR()
#72068
#Read[HRCTR]CTR0=VALEUR
Filter [HRCTR] Where CTRNUM=VALEUR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#
If !fstat
 Read [ID]ID0=[F:HRCTR]REFNUM
 [M:PCA0]NAM = [F:ID]NAM-[F:ID]SRN
 Affzo [PCA0]NAM

 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 GCURLEG = [F:CPY]LEG
 If dim([M]LEG)>=0 : [M]LEG=GCURLEG : Affzo [M]LEG : Endif
 Gosub CHARGE
Endif
End

######################################################################################
## Section automatically added (screen PCA0) 18/06/2012 18:13:06 (OLY)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
Gosub CHARGE
End


######################################################################################
######################################################################################
## Section automatically added (screen PCA0) 28/06/2012 18:09:20 (OLY)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPY",VALEUR,"") From CONTOBJ
GCURLEG = [F:CPY]LEG
If dim([M]LEG)>=0 : [M]LEG=GCURLEG : Affzo [M]LEG : Endif
Gosub CHARGE
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GCURLEG = [F:CPY]LEG
If dim([M]LEG)>=0 : [M]LEG=GCURLEG : Affzo [M]LEG : Endif
Gosub CHARGE
End

Subprog CLEAR_GRID
  Raz [M:PCA1]
  Raz [M:PCA2]
  [M:PCA1]TBL = 0
  [M:PCA2]TBL2 = 0
  Call REFRESH_GRID
End

Subprog REFRESH_GRID
  Affzo [M:PCA1]TBL,CAI,CAIVAL,ORG
  Affzo [M:PCA2]TBL2,CAI2,CAIVAL2,ORG2
End
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran PCA0) 09/08/2012 14:55:50 (DBA)
######################################################################################
Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("POP",VALEUR,"") From CONTOBJ
If [F:HRPOP]LEG<>""
 GCURLEG = [F:HRPOP]LEG
 If dim([M]LEG)>=0 : [M]LEG=GCURLEG : Affzo [M]LEG : Endif
Endif
Gosub CHARGE
End


