#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
# Gestion des objets ICD, ICA, ICB et ICS : Coût standard
######################################################################################
$ACTION
Case ACTION
    When "OUVRE"     : Gosub OUVRE      From SUBITCA
    When "AFFMASK"   : Gosub AFFMASK    From SUBITCA
    When "FILTRE"    : Gosub FILTRE     From SUBITCA
    When "LIENS"     : Gosub LIENS      From SUBITCA
    When "FILGAUCHE" : Gosub FILGAUCHE  From SUBITCA  # FQ 62854 GA 03/2010
    When "RAZCRE"    : Gosub RAZCRE     From SUBITCA
    When "INICRE"    : Gosub INICRE     From SUBITCA
    When "INIMOD"    : Gosub INIMOD     From SUBITCA
    When "MODIF"     : Gosub MODIF      From SUBITCA
    When "AVANTBOUT" : Gosub AVANTBOUT  From SUBITCA
    When "EXEBOUT"   : Gosub EXEBOUT    From SUBITCA
    When "SETBOUT"   : Gosub SETBOUT    From SUBITCA
    When "ANNULE"    : Gosub ANNULE     From SUBITCA
    When "FERME"     : Gosub FERME      From SUBITCA
    When "DROIT"     : Gosub DROIT      From SUBITCA

    When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return


######################################################################################
$APRES_MODIF
Local Integer LUPDNIV, I, LRET
Local Decimal LPRI
Local Char LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Raz LUPDNIV

# Cas de "Nouveau" puis "Abandon" puis saisie des champs pour charger
If [M]CSTTYP <= 1
    [M]CSTTYP = GCSTTYP
Endif

Raz LECCMAJ, LECCMIN
If dim([M]ECCVALMAJ)>0
    LECCMAJ=[M]ECCVALMAJ
    LECCMIN=[M]ECCVALMIN
Endif

Case COUZON
    When "STOFCY"
        Case GCSTTYP
            When 1,3 :
                If !func SUBITCB.LOADITC(CZ,[M]ITMREF,GCSTTYP,[M]FIYNUM,LECCMAJ,LECCMIN)
                    [M]ITCSEQ = 0
                Endif
                Affzo [M]ITCSEQ
        Endcase
    When "ITMREF"
        Case GCSTTYP
            When 1,3 :
                If !func SUBITCB.LOADITC([M]STOFCY,CZ,GCSTTYP,[M]FIYNUM,LECCMAJ,LECCMIN)
                    [M]ITCSEQ = 0
                    If dim([M]ECCVALMAJ)>0 : Effzo [M]ECCVALMAJ, ECCVALMIN : Endif
                Endif
                Affzo [M]ITCSEQ
        Endcase

        Gosub ACTIVE_ZONES From SUBITCA

    When "FIYNUM"
        [M]FIYNUM=val(CZ)
        If !func SUBITCB.LOADITC([M]STOFCY,[M]ITMREF,GCSTTYP,[M]FIYNUM,LECCMAJ,LECCMIN)
            [M]ITCSEQ = 0
        Endif
        COUZON = "ITCSEQ"
        CZ = num$([M]ITCSEQ)
        Affzo [M]FIYNUM
        Affzo [M]ITCSEQ

    When "DATREF"
        LDATREF=CZ
        Raz [F:ITC]ITCSEQ
        If dim([M]ECCVALMAJ)>0
            Call GETPRISTD([M]ITMREF,[M]ECCVALMAJ,[M]ECCVALMIN,[M]STOFCY,LDATREF,0,GCSTTYP,LPRI,LRET) From STKVAL
        Else
            Call GETPRISTD([M]ITMREF,"","",[M]STOFCY,LDATREF,0,GCSTTYP,LPRI,LRET) From STKVAL
        Endif
        [M]ITCSEQ = [F:ITC]ITCSEQ
        COUZON = "ITCSEQ"
        CZ = num$([M]ITCSEQ)

        If [M]ITCSEQ=0
            If ([M]DATREF<[M]ITCSTRDAT | [M]DATREF>[M]ITCENDDAT)
                [M]ITCSTRDAT = LDATREF
                Affzo [M]ITCSTRDAT
                Effzo [M]ITCENDDAT
            Endif
        Endif

    When "ITCSTRDAT"
        If !find(GREP,"C","M")
            Call OUINON(mess(12,126,1),LRET) From GESECRAN
            If LRET=2    # Passage en duplication
                [M]ITCSEQ = 0
                COUZON = "ITCSEQ"
                CZ = num$([M]ITCSEQ)
            Endif
        Endif
    When "MATTOTLEV"
        Effzo [M:ICD2]MATLEVCST,FXDMATLEV
        [M:ICD2]MATLEVCST([M]BRDCOD-1) = val(CZ)
        For I=0 To GACTMAT-1
            [M:ICLD]MATCST(I) = 0
        Next
        [M:ICLD]MATCST([M]BRDCOD-1) = val(CZ)
        [M:ICLD]MATTOT = val(CZ)
        LUPDNIV = 1

    When "MACTOTLEV"
        Effzo [M:ICD2]MACLEVCST,FXDMACLEV
        [M:ICD2]MACLEVCST(0) = zc
        For I=0 To GACTMAC-1
            [M:ICLD]MACCST(I) = 0
        Next
        [M:ICLD]MACCST(0) = val(CZ)
        [M:ICLD]MACTOT = val(CZ)
        LUPDNIV = 1

    When "LABTOTLEV"
        Effzo [M:ICD2]LABLEVCST,FXDLABLEV
        [M:ICD2]LABLEVCST(0) = zc
        For I=0 To GACTLAB-1
            [M:ICLD]LABCST(I) = 0
        Next
        [M:ICLD]LABCST(0) = val(CZ)
        [M:ICLD]LABTOT = val(CZ)
        LUPDNIV = 1

    When "SCOTOTLEV"
        Effzo [M:ICD2]SCOLEVCST,FXDSCOLEV
        [M:ICD2]SCOLEVCST = zc
        [M:ICLD]SCOCST = val(CZ)
        [M:ICLD]SCOTOT = val(CZ)
        LUPDNIV = 1

    When "OVETOTLEV"
        Effzo [M:ICD2]OVELEVCST,FXDOVELEV
        Effzo [M:ICD2]OVEMATLEV,FXDOVEMATL
        Effzo [M:ICD2]OVEMACLEV,FXDOVEMACL
        Effzo [M:ICD2]OVELABLEV,FXDOVELABL
        Effzo [M:ICD2]OVESCOLEV,FXDOVESCOL
        [M:ICD2]OVELEVCST = zc
        [M:ICD2]OVEMATLEV = zc
        [M:ICLD]OVEMATCST = val(CZ)
        [M:ICLD]OVEMACCST = 0
        [M:ICLD]OVELABCST = 0
        [M:ICLD]OVESCOCST = 0
        Raz [M:ICLD]NBONA,[M:ICLD]OVENAT,[M:ICLD]ONATYP,[M:ICLD]ONAAMT
        If [M:ICLD]OVEMATCST<>0
            [M:ICLD]OVENAT(0)="ZZZ"
            [M:ICLD]ONATYP(0)=2
            [M:ICLD]ONAAMT(0)=[M:ICLD]OVEMATCST
            [M:ICLD]NBONA=1
        Endif
        LUPDNIV = 1

    When "CLCQTY"
        [M:ICD1]CLCQTY = val(CZ)
        Affzo [M:ICD1]CLCQTY

    When "CLCSTD"
        Gosub RELIT From GOBJSUB
        OK=0
Endcase

Gosub APRES_MODIF From SUBICDECC

If LUPDNIV
    Assign "[M:ICD2]"+COUZON With zc
    Effzo [M:ICD1]10-15
    Effzo [M:ICD1]MATTOT,MACTOT,LABTOT,SCOTOT,OVETOT,VLTTOT
    For I=0 To GACTMAT-1
        [M:ICD1]MATCST(I) = [M:ICD2]MATLEVCST(I)
    Next
    For I=0 To GACTMAC-1
        [M:ICD1]MACCST(I) = [M:ICD2]MACLEVCST(I)
    Next
    For I=0 To GACTLAB-1
        [M:ICD1]LABCST(I) = [M:ICD2]LABLEVCST(I)
    Next
    [M:ICD1]SCOCST = [M:ICD2]SCOLEVCST
    [M:ICD1]OVEMATCST = [M:ICD2]OVELEVCST
    [M:ICD1]MATTOT = sum([M:ICD2]MATLEVCST)
    [M:ICD1]MACTOT = sum([M:ICD2]MACLEVCST)
    [M:ICD1]LABTOT = sum([M:ICD2]LABLEVCST)
    [M:ICD1]SCOTOT = sum([M:ICD2]SCOLEVCST)
    [M:ICD1]OVETOT = sum([M:ICD2]OVELEVCST)
    [M:ITCD] = [M:ICD1]
    Raz [M:ITCD]NBONA,[M:ITCD]OVENAT,[M:ITCD]ONATYP,[M:ITCD]ONAAMT
    If [M:ITCD]OVEMATCST<>0
        [M:ITCD]OVENAT(0)="ZZZ"
        [M:ITCD]ONATYP(0)=2
        [M:ITCD]ONAAMT(0)=[M:ITCD]OVEMATCST
        [M:ITCD]NBONA=1
    Endif
    Gosub CAL_TOT
    Affzo [ICD1]5
    Affzo [ICD2]VLTTOT

    Gosub CHARGE_GRAPH From SUBICDG
Endif


Return

$CAL_TOT
    [M:ICD2]VLTTOT = sum([M:ICD2]MATLEVCST,[M:ICD2]MACLEVCST,[M:ICD2]LABLEVCST,[M:ICD2]SCOLEVCST)
&                   +sum([M:ICD2]OVEMATLEV,[M:ICD2]OVEMACLEV,[M:ICD2]OVELABLEV,[M:ICD2]OVESCOLEV)
    # CCC (2009-08-04) Bug 56348 : CSTTOT n'était pas calculé
    [M:ICD1]CSTTOT = [M:ICD1]MATTOT+[M:ICD1]MACTOT+[M:ICD1]LABTOT+[M:ICD1]SCOTOT
    [M:ICD1]VLTTOT = [M:ICD2]VLTTOT
Return


######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

Call GETDEV(VALEUR) From DEVSUB
GFCY=VALEUR
Call GETCPY(GFCY,"",0,"") From TRTX3CPT

If [M]ITMREF <> ""
    Read [ITF]ITF0=[M]ITMREF;VALEUR
    # Issue 80346 - 2012-02-23 by CCC
#    # alimenter les zones reprises de ITF : Saisi ou calculé
#    If clalev([M:ICD0])
#        [M:ICD0] = [F:ITF]
#    Elsif clalev([M:ICA0])
#        [M:ICA0] = [F:ITF]
#    Endif
#    [M] = [F:ITF]
    Gosub LOAD_ITF From SUBITCA
    [M]NBTYP = find("",[M]OVECOD)-1
    If [M]NBTYP=-1
        [M]NBTYP=dim([M]OVECOD)
    Endif
Endif
# Issue 66517 - 2010-08-20 by CCC
If [F:ITM]ITMREF<>[M]ITMREF
    Read [ITM]ITM0=[M]ITMREF
Endif
If clalev([M:ICD0])
    [M:ICD0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
    Affzo [M:ICD0]10,15
Elsif clalev([M:ICA0])
    [M:ICA0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
    Affzo [M:ICA0]10,15
Else
    [M] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
Endif

Call INITCCE From SUBITCA

#111369.sn MJH 21/12/2016
If clalev([M:ICD1])
  [M:ICD1]CUR = GLOCALDEV
  [M:ICD1]STU = [F:ITM]STU
  Affzo [M:ICD1]CUR, STU
Endif
If clalev([M:ICD2])
  [M:ICD2]CUR = GLOCALDEV
  [M:ICD2]STU = [F:ITM]STU
  Affzo [M:ICD2]CUR, STU
Endif
#111369.en MJH 21/12/2016

End

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ITMREF <> VALEUR
     Read [ITM]ITM0=VALEUR
Endif

If [M]STOFCY <> ""
    Read [ITF]ITF0=VALEUR;[M]STOFCY
    # alimenter les zones reprises de ITF : Saisi ou calculé
    # Issue 80346 - 2012-02-23 by CCC
#    If clalev([M:ICD0])
#        [M:ICD0] = [F:ITF]
#    Elsif clalev([M:ICA0])
#        [M:ICA0] = [F:ITF]
#    Else
#        [M]=[F:ITF]
#    Endif
    Gosub LOAD_ITF From SUBITCA

    [M]NBTYP = find("",[M]OVECOD)-1
    If [M]NBTYP=-1
        [M]NBTYP=dim([M]OVECOD)
    Endif
Endif
If clalev([M:ICD0])
    [M:ICD0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
    Affzo [M:ICD0]
Elsif clalev([M:ICA0])
    [M:ICA0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
    Affzo [M:ICA0]
Else
    Affzo [M]
Endif

Call INITCCE From SUBITCA

Call AM_ITMREF(VALEUR) From SUBICDECC
End

######################################################################################
Subprog C_FIYNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
   Raz [F:FIY]
   mkstat=2
   End
Endif
Call GETSOC([M]STOFCY) From DEVSUB
Read [FIY]FIY0=GSOCIETE;1;VALEUR
If fstat
    GMESSAGE = mess(6,199,1)
    mkstat = 2
    End
Endif
Call C_FIYNUM(VALEUR) From SUBICDECC
End

######################################################################################
Subprog AM_FIYNUM(VALEUR)
Variable Decimal VALEUR
[M]ITCSTRDAT = [F:FIY]FIYSTR
[M]ITCENDDAT = [F:FIY]FIYEND
Affzo [M]ITCSTRDAT,ITCENDDAT

Call AM_FIYNUM(VALEUR) From SUBICDECC
End

######################################################################################
Subprog C_ITCSTRDAT(VALEUR)
Variable Date    VALEUR

Call C_ITCSTRDAT(VALEUR) From SUBICDECC

End
######################################################################################
Subprog AM_ITCSTRDAT(VALEUR)
Variable Date    VALEUR
    If VALEUR>[M]ITCENDDAT
        [M]ITCENDDAT=VALEUR
    Endif
Call C_ITCSTRDAT(VALEUR) From SUBICDECC
End

######################################################################################
Subprog C_ITCENDDAT(VALEUR)
Variable Date    VALEUR
    If VALEUR<[M]ITCSTRDAT
        mkstat=2
    Endif
End


######################################################################################

######################################################################################
Subprog AS_OTRSTYP(VALEUR)
Variable Integer VALEUR
Local Integer I,J,LTYP
If [F:ITG]TCLCOD<>[M]TCLCOD | [F:ITG]STOFCY<>[M]STOFCY
    Read [ITG]ITG0=[M]STOFCY;[M]TCLCOD
    If fstat
        Read [ITG]ITG0="";[M]TCLCOD
    Endif
Endif
For I=1 To len(mess(0,704,1))
    LTYP = ([F:ITG]MFGFLG=2)
&         +([F:ITG]PURFLG=2)*2
&         +([F:ITG]SCPFLG=2)*4
&         +([F:ITG]SCSFLG=2)*8    # Types de flux autorisés sur la catégorie
    If !func STKVALPAR.WITHOVE(I,LTYP)
        GMENLOC(I) = 1
    Else    # on affiche que ce qui n'a pas encore été sélectionné.
        J = find(I,[M]OTRSTYP)
        If J>0 & J<>nolign
            GMENLOC(I) = 1
        Endif
    Endif
Next
End

#######################################################
Subprog C_OVECOD(VALEUR)
Variable Char     VALEUR

Local Integer LTYP

If VALEUR <> ""
    If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif
    Read [OVE]OVE0=VALEUR
    # "La devise des frais généraux est différente de celle du site"
    If [F:OVE]CUR <> GLOCALDEV & [F:OVE]CUR <> ""
        mkstat = 2
        GMESSAGE = mess(204,199,1)
    Endif
    If [F:OVE]OVECOD<>VALEUR
        Read [OVE]OVE0=VALEUR
    Endif
    LTYP = abs(func STKLIB.SENSTRS([M]OTRSTYP(nolign-1)))
    If [F:OVE]CLCLEV <> LTYP
        Case CLCLEV
            When 1 :
                GMESSAGE = mess(265,184,1)
            When 2 :
                GMESSAGE = mess(246,184,1)
        Endcase
        mkstat = 2
    Endif
    If !func STKVALPAR.WITHOVEORI([M]OTRSTYP(nolign-1)) & !find(1,[F:OVE]VCRTRG)
        GMESSAGE = mess(258,184,1)
        mkstat = 2
    Endif
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran ICD0) 13/06/2008 12:24:32 (CCC)
######################################################################################
Subprog C_NBTYP
If nolign>[M]NBTYP
    Local Integer I,J,LTYP, LEXI
    LEXI=0
    For I=1 To len(mess(0,704,1))
        LTYP = ([F:ITG]MFGFLG=2)
&             +([F:ITG]PURFLG=2)*2
&             +([F:ITG]SCPFLG=2)*4
&             +([F:ITG]SCSFLG=2)*8    # Types de flux autorisés sur la catégorie
        If !func STKVALPAR.WITHOVE(I,LTYP)
        Else    # on affiche que ce qui n'a pas encore été sélectionné.
            J = find(I,[M]OTRSTYP)
            If J>0 & J<>nolign
            Else
                LEXI=1
            Endif
        Endif
    Next
    If LEXI=0 : mkstat=2 : Endif
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran ICA0) 13/06/2008 16:22:07 (CCC)
######################################################################################
Subprog AS_ITMREF(VALEUR)
Variable Char     VALEUR
If GFLTITM <> ""
    If VALEUR<>GFLTITM
       VALEUR = GFLTITM
    Endif
    mkstat = 2
    Call LECTURE("ITM",GFLTITM,"") From CONTOBJ
Endif
End

Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
End

Subprog D_STOFCY(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If GFLTFCY <> ""
    If VALEUR<>GFLTFCY
       VALEUR = GFLTFCY
    Endif
    Call LECTURE("ITF",GFLTFCY,GFLTITM) From CONTOBJ
    # Issue 80346 - 2012-02-23 by CCC
    #[M] = [F:ITF]
    Gosub LOAD_ITF From SUBITCA
    [M]NBTYP = find("",[M]OVECOD)-1
    If [M]NBTYP=-1
        [M]NBTYP=dim([M]OVECOD)
    Endif

    # Bug 80299 GH 23/02/2012
    If [F:ITM]ITMREF<>[M]ITMREF
        Read [ITM]ITM0=[M]ITMREF
    Endif
    If clalev([M:ICD0])
        [M:ICD0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
    Elsif clalev([M:ICA0])
        [M:ICA0] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
    Else
        [M] = [F:ITM] # pour TCLCOD,BRDCOD, STU et PRIDIV
    Endif

    Call INITCCE From SUBITCA

    Affzo [M]10-15
    mkstat = 2
Endif
End

Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Look [ITF]ITF0=[M]ITMREF;VALEUR
If fstat
    GMESSAGE = mess(139,197,1)
    mkstat=2
Endif
End

Subprog AP_STOFCY(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_BRDCOD(VALEUR)
Variable Integer VALEUR

  #X3-103640 MJH. Only allow to display up to the maximum defined by GACTMAT
  Raz GMENLOC
  For I = 20 To GACTMAT+1 Step -1
    GMENLOC(I) = 1
  Next

End

Subprog C_BRDCOD(VALEUR)
Variable Integer VALEUR
End


