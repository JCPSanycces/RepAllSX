#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone REFNUM
mkstat = 0
zoncou = "REFNUM"
indice = 0
WCHAR = [M]REFNUM
If varmode([M]REFNUM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_REFNUM([M]REFNUM) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]REFNUM : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "REFNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]REFNUM,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "DROITEMP"
   Call DROIT([M]REFNUM,"","1","") From DIVPAYE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("EML","",[M]REFNUM,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]REFNUM or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_REFNUM([M]REFNUM) From SUBCTR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CTRNUM
mkstat = 0
zoncou = "CTRNUM"
indice = 0
WCHAR = [M]CTRNUM
If varmode([M]CTRNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRNUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTVCR"
 Call CONTVCR([M]CTRNUM) From TRTDIV
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CTR","!$",[M]CTRNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CTRNUM([M]CTRNUM) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CTRNUM or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_CTRNUM([M]CTRNUM) From SUBCTR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 20690 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone FLGVAR
mkstat = 0
zoncou = "FLGVAR"
indice = 0
IMPENT = [M]FLGVAR
If varinit([M]FLGVAR,indice)=0
 IMPENT = 1
Endif
[M]FLGVAR = IMPENT

## Zone CTRDAT
mkstat = 0
zoncou = "CTRDAT"
indice = 0
WDATE = [M]CTRDAT
If varmode([M]CTRDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CTRDAT([M]CTRDAT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CTRDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]CTRDAT=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CTRDAT" : GZNUM = 212 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WDATE<>[M]CTRDAT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_CTRDAT([M]CTRDAT) From SUBCTR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CTRDAT" : GZNUM = 212 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ETRTIM
mkstat = 0
zoncou = "ETRTIM"
indice = 0
If varinit([M]ETRTIM,indice)=0
 [M]ETRTIM = "0800"
Endif
If varmode([M]ETRTIM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRTIM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRFCY
mkstat = 0
zoncou = "ETRFCY"
indice = 0
WCHAR = [M]ETRFCY
If varmode([M]ETRFCY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ETRFCY([M]ETRFCY) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]ETRFCY : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRFCY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]ETRFCY,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTFCY"
   Call CONTSITE([M]ETRFCY) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("FCY","",[M]ETRFCY,"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_ETRFCY([M]ETRFCY) From SUBCTR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]ETRFCY or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_ETRFCY([M]ETRFCY) From SUBCTR
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varinit([M]CPY,indice)=0
 [M]CPY = [F:FCY]LEGCPY
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone FLGRET
mkstat = 0
zoncou = "FLGRET"
indice = 0
IMPENT = [M]FLGRET
If varinit([M]FLGRET,indice)=0
 IMPENT = 1
Endif
[M]FLGRET = IMPENT

## Zone CTRGRD
mkstat = 0
zoncou = "CTRGRD"
indice = 0
WCHAR = [M]CTRGRD
If varmode([M]CTRGRD,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRCGD"
 Call DEFHRCGD([M]CTRGRD,GCURLEG,GSOCIETE) From SUBHRCGD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CTRGRD : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRGRD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CTRGRD,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRCGD"
   Call CONTHRCGD([M]CTRGRD,GCURLEG,GSOCIETE) From SUBHRCGD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]CTRGRD
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]CTRGRD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_CTRGRD([M]CTRGRD) From SUBCTR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]CTRGRD or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_CTRGRD([M]CTRGRD) From SUBCTR
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone XITFNL
mkstat = 0
zoncou = "XITFNL"
indice = 0
IMPENT = [M]XITFNL
If varinit([M]XITFNL,indice)=0
 IMPENT = 1
Endif
[M]XITFNL = IMPENT

## Zone NATCON
mkstat = 0
zoncou = "NATCON"
indice = 0
WCHAR = [M]NATCON
If varmode([M]NATCON,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRNCT"
 Call DEFHRNCT([M]NATCON,GCURLEG,GSOCIETE) From SUBHRNCT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NATCON : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NATCON" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]NATCON,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRNCT"
   Call CONTHRNCT([M]NATCON,GCURLEG,GSOCIETE) From SUBHRNCT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]NATCON
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]NATCON = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]NATCON or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_NATCON([M]NATCON) From SUBCTR
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "NATCON" : GZNUM = 29665 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR0"
Return

