#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# X3PMAJ90_ACTION UTI process                                   PAY Module
#                 Migration To U12 - Vnext version
#
# ==>  Update Field Actions and Parameters on custom fields
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update BRI headings with key change in all tables where field is data type RUB") From LECFIC

  Call PATCH(WDOSSIER)
#  Call MAJ_UTIHRM008(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

Close Local File
End

Subprog MAJ_UTIHRM008(LDOSSIER)
Value Char LDOSSIER
Local Char DOSLEGMIG(5)
Local Char RUBARRAY(250)(0..,0..2)
Local Integer F,X

Call OPEN_RUBARRAY(RUBARRAY)

Call ECR_TRACE("UTIHRM008: Start of process on : "+LDOSSIER,0) From GESECRAN

#####Run through all fields in ATABZON where data type = "RUB" and rewrite the old RUB code with the new code
#MIPEA - 2018-03-30-X3-85110- START
If clalev([HRATZ]) : Close Local File [HRATZ]  : Endif
Local File =LDOSSIER+".ATABZON"   [HRATZ]
#  If clalev([F:HRATZ]) = 0 : Local File =LDOSSIER+".ATABZON"   [HRATZ]  : Endif
#MIPEA - 2018-03-30-X3-85110- END


#####Tables that need update where data type is not RUB::
#MIPEA - 2018-03-30-X3-85110- START
If filinfo(filpath("FIL","ATEXTRA","fde",LDOSSIER),0)<=0
Else
  If clalev([AXXX]) : Close Local File [AXXX]  : Endif
  Local File =LDOSSIER+".ATEXTRA"   [AXXX]
Endif
If filinfo(filpath("FIL","HISTOPAYE","fde",LDOSSIER),0)<=0
Else
  If clalev([HRHSP]) : Close Local File [HRHSP]  : Endif   #Type 1
  Local File =LDOSSIER+".HISTOPAYE" [HRHSP]
Endif
If filinfo(filpath("FIL","ODPAYA","fde",LDOSSIER),0)<=0
Else
  If clalev([HRODA]) : Close Local File [HRODA]  : Endif   #TYPE N/A
  Local File =LDOSSIER+".ODPAYA"    [HRODA]
Endif
If filinfo(filpath("FIL","TMPHISTO","fde",LDOSSIER),0)<=0
Else
  If clalev([HRTMP]) : Close Local File [HRTMP]  : Endif   #TYPE N/A
  Local File =LDOSSIER+".TMPHISTO"  [HRTMP]
Endif
If filinfo(filpath("FIL","TMPODPAYA","fde",LDOSSIER),0)<=0
Else
  If clalev([HRTOA]) : Close Local File [HRTOA]  : Endif   #TYPE N/A
  Local File =LDOSSIER+".TMPODPAYA" [HRTOA]
Endif
#If filinfo(filpath("FIL","ATEXTRA","fde",LDOSSIER),0)<=0
#Else
#  If clalev([F:AXXX])  = 0 : Local File =LDOSSIER+".ATEXTRA"   [AXXX]   : Endif
#Endif
#If filinfo(filpath("FIL","HISTOPAYE","fde",LDOSSIER),0)<=0
#Else
#  If clalev([F:HRHSP]) = 0 : Local File =LDOSSIER+".HISTOPAYE" [HRHSP]  : Endif #Type 1
#Endif
#If filinfo(filpath("FIL","ODPAYA","fde",LDOSSIER),0)<=0
#Else
#  If clalev([F:HRODA]) = 0 : Local File =LDOSSIER+".ODPAYA"    [HRODA]  : Endif #TYPE N/A
#Endif
#If filinfo(filpath("FIL","TMPHISTO","fde",LDOSSIER),0)<=0
#Else
#  If clalev([F:HRTMP]) = 0 : Local File =LDOSSIER+".TMPHISTO"  [HRTMP]  : Endif #TYPE N/A
#Endif
#If filinfo(filpath("FIL","TMPODPAYA","fde",LDOSSIER),0)<=0
#Else
#  If clalev([F:HRTOA]) = 0 : Local File =LDOSSIER+".TMPODPAYA" [HRTOA]  : Endif #TYPE N/A
#Endif
#MIPEA - 2018-03-30-X3-85110- END

  Filter [F:HRATZ] Where [F:HRATZ]CODTYP="RUB"
  Call ECR_TRACE("RUB type field rowcount in table ATABZON:" - num$(rowcount([F:HRATZ])),0) From GESECRAN

#MIPEA - 2018-03-30-X3-85110- START
  Local Char RUBDTYPFLD(250)
  Local Char RUBFIELD(250)
  Local Char TABLE(250)
#MIPEA - 2018-03-30-X3-85110- END

  For [F:HRATZ]
#MIPEA - 2018-03-30-X3-85110- START
      RUBDTYPFLD   = [F:HRATZ]CODZONE
      RUBFIELD     = [F:HRATZ]CODZONE
      TABLE        = [F:HRATZ]CODFIC
#MIPEA - 2018-03-30-X3-85110- END

      If filinfo(filpath("FIL",TABLE,"fde",LDOSSIER),0)<=0
        #Table does not exist
      Else
        If clalev([WWWW]) : Close Local File [WWWW]  : Endif
        Local File =LDOSSIER+"."+TABLE [WWWW]

  #      For [F:WWWW] Where find(evalue('[F:WWWW]'+RUBFIELD),RUBARRAY(0..62,1))
        For [F:WWWW] Where find(evalue('[F:WWWW]'+RUBFIELD),RUBARRAY(0..maxtab(RUBARRAY),1))
              For F=0 To maxtab(RUBARRAY)
                If evalue('[F:WWWW]'+RUBFIELD) = RUBARRAY(F,1)
                  Assign "[F:WWWW]"+RUBFIELD With RUBARRAY(F,2)
                  Rewrite [F:WWWW]
                  If !fstat
                    Call ECR_TRACE("Updated field:" - evalue('[F:WWWW]'+RUBFIELD) - "on table:" - TABLE - ", from:" - RUBARRAY(F,1) - "to:" - RUBARRAY(F,2),0) From GESECRAN

                    If filinfo(filpath("FIL","HISTOPAYE","fde",LDOSSIER),0)<=0
                    Else
                      Update [HRHSP] Where [F:HRHSP]RUB = RUBARRAY(F,1) & [F:HRHSP]TYP=1 With [F:HRHSP]RUB = RUBARRAY(F,2)
                      Call ECR_TRACE("Updated RUB field in HISTOPAYE: from:" - RUBARRAY(F,1) - "to:" - RUBARRAY(F,2),0)     From GESECRAN
                    Endif

                    If filinfo(filpath("FIL","ODPAYA","fde",LDOSSIER),0)<=0
                    Else
                      Update [HRODA] Where [F:HRODA]RUB = RUBARRAY(F,1) With [F:HRODA]RUB = RUBARRAY(F,2)
                      Call ECR_TRACE("Updated RUB field in ODPAYA: from:" - RUBARRAY(F,1) - "to:" - RUBARRAY(F,2),0)        From GESECRAN
                    Endif

                    If filinfo(filpath("FIL","TMPHISTO","fde",LDOSSIER),0)<=0
                    Else
                      Update [HRTMP] Where [F:HRTMP]RUB = RUBARRAY(F,1) With [F:HRTMP]RUB = RUBARRAY(F,2)
                      Call ECR_TRACE("Updated RUB field in TMPHISTO: from:" - RUBARRAY(F,1) - "to:" - RUBARRAY(F,2),0)      From GESECRAN
                    Endif

                    If filinfo(filpath("FIL","TMPODPAYA","fde",LDOSSIER),0)<=0
                    Else
                      Update [HRTOA] Where [F:HRTOA]RUB = RUBARRAY(F,1) With [F:HRTOA]RUB = RUBARRAY(F,2)
                      Call ECR_TRACE("Updated RUB field in TMPODPAYA: from:" - RUBARRAY(F,1) - "to:" - RUBARRAY(F,2),0)     From GESECRAN
                    Endif

                    Break
                  Else
                    Call ECR_TRACE("Update failed on field:" - evalue('[F:WWWW]'+RUBFIELD) - "on table:" - TABLE - ", from:" - RUBARRAY(F,1) - "to:" - RUBARRAY(F,2),0) From GESECRAN
                    Break
                  Endif
                Endif
              Next
        Next
        Close File [F:WWWW]
      Endif
  Next

  If filinfo(filpath("FIL","ATEXTRA","fde",LDOSSIER),0)<=0
    #ATEXTRA DOES NOT EXIST
  Else
    For X=0 To maxtab(RUBARRAY)
      Update [AXXX] Where [F:AXXX]IDENT1 = RUBARRAY(X,1) With [F:AXXX]IDENT1 = RUBARRAY(X,2)
      Call ECR_TRACE("Updated text key 1 in ATEXTRA: from:" - RUBARRAY(X,1) - "to:" - RUBARRAY(X,2),0) From GESECRAN
      Update [AXXX] Where [F:AXXX]IDENT2 = RUBARRAY(X,1) With [F:AXXX]IDENT2 = RUBARRAY(X,2)
      Call ECR_TRACE("Updated text key 2 in ATEXTRA: from:" - RUBARRAY(X,1) - "to:" - RUBARRAY(X,2),0) From GESECRAN
    Next
  Endif
  Filter [F:HRATZ]

End

Subprog OPEN_RUBARRAY(RUBARRAY)
Variable Char RUBARRAY()(0..,0..2)
Local Integer Z
Local Char OLDVAL(250),NEWVAL(250)

For OLDVAL = "S_BASIC_RT","W_S_BAS_RT","SBASIC_PER","W_SBAS_PER","SBASIC_CUM","W_SBAS_CUM","SBASIC_LIM",
&            "W_SBAS_LIM","SBASIC_TX1","W_SBAS_TX1","SBASIC_TX2","W_SBAS_TX2","SBASIC_TX3","W_SBAS_TX3",
&            "S_BASIC_W1","W_S_BAS_W1","SBASIC_T_1","W_SBAS_T_1","SBASIC_T_2","W_SBAS_T_2","SBASIC_T_3",
&            "W_SBAS_T_3","SHIGH_RATE","W_SHIGH_RT","SHIGH_R_W1","W_SHI_R_W1","S_HIGH_PER","W_S_HI_PER",
&            "S_HIGH_LIM","W_S_HI_LIM","SHIGH_TX_1","W_SHI_TX_1","SHIGH_TX_2","W_SHI_TX_2","SHIGH_P_W1",
&            "W_SHI_P_W1","S_HIGH_T_1","W_S_HI_T_1","S_HIGH_T_2","W_S_HI_T_2","SMP_HI_RT","SMP _TOTAL",
&            "SMP_RECLM","SPP_ST_RT","SPP_TOTAL","SPP_RECLM","S_D1_TAX","REG_LIMIT","REG_LIMIT1","BR_TAX_1",
&            "S_BR_TAX_1","BR_TAX_2","S_BR_TAX_2","D0_TAX_1","S_D0_TAX_1","D0_TAX_2","S_D1_TAX_2","NT_TAX",
&            "S_NT_TAX","REG_TX_DED","TAX_DEDUCT","W_TAX_DED","TAX_W1M1"


RUBARRAY(Z,1) = OLDVAL
Z+=1
Next

Z=0
For NEWVAL = "S_START_RT","W_S_STA_RT","SSTART_PER","W_SSTA_PER","SSTART_CUM","W_SSTA_CUM","SSTART_LIM",
&            "W_SSTA_LIM","SSTART_TX1","W_SSTA_TX1","SSTART_TX2","W_SSTA_TX2","SSTART_TX3","W_SSTA_TX3",
&            "S_START_W1","W_S_STA_W1","SSTART_T_1","W_SSTA_T_1","SSTART_T_2","W_SSTA_T_2","SSTART_T_3",
&            "W_SSTA_T_3","SBAS_RATE","W_SBAS_RT","SBAS_R_W1","W_SBA_R_W1","S_BAS_PER","W_S_BA_PER","S_BAS_LIM",
&            "W_S_BA_LIM","SBAS_TX_1","W_SBA_TX_1","SBAS_TX_2","W_SBA_TX_2","SBAS_P_W1","W_SBA_P_W1","S_BAS_T_1",
&            "W_S_BA_T_1","S_BAS_T_2","W_S_BA_T_2","SMP_WK_C0","SMP_HI_RT","SMP_HI_RT3","SMP_DAY_PD","SMP_TOTAL",
&            "SMP_W_HIS","W_SINT_RT","W_SIN_R_W1","W_S_IN_PER","W_S_IN_LIM","W_SIN_LIM2","W_SIN_TX_1","W_SIN_TX_2",
&            "W_SIN_P_W1","W_S_IN_T_1","W_S_IN_T_2","SHIGH_RATE","SHIGH_R_W1","S_HIGH_PER","S_HIGH_LIM","S_HI_LIM2",
&            "W_SHI_LIM2","SHI_TX_1"

RUBARRAY(Z,2) = NEWVAL
Z+=1

Next

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#MIPEA - 2018-03-30-X3-85110- START
Call ECR_TRACE("Update BRI headings with key change in all tables where field is data type RUB "+APPLI,0) From GESECRAN
#Call OUVRE_TRACE("Update BRI headings with key change in all tables where field is data type RUB") From LECFIC
#MIPEA - 2018-03-30-X3-85110- END

#MIPEA - 2018-03-30-X3-85110- START
If filinfo(filpath("FIL","ATABZON","fde",APPLI),0)<=0 : End : Endif
#MIPEA - 2018-03-30-X3-85110- END

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

If clalev([F:ACVHR])=0 : Local File =APPLI+".ACTIV" [ACVHR] : Endif
Read [ACVHR]CODACT = "KUK"

If fstat
  Call ECR_TRACE("UTIHRM008: Process aborted as activity code KUK does not exist on : "+APPLI,0) From GESECRAN
  End
Else
  If [F:ACVHR]FLACT <> 2
    Call ECR_TRACE("UTIHRM008: Process aborted as activity code KUK is inactive on : "+APPLI,0) From GESECRAN
    End
  Endif
Endif

Call MAJ_UTIHRM008(APPLI)

  Call ECR_TRACE("UTIHRM008 : End of process on : "+APPLI,0) From GESECRAN
  Call ECR_TRACE("##################################",0) From GESECRAN
  Call ECR_TRACE("##################################",0) From GESECRAN

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif

If clalev([F:ACVHR])=0 : Local File =APPLI+".ACTIV" [ACVHR] : Endif
Read [ACVHR]CODACT = "KUK"
If fstat
  End
Else
  If [F:ACVHR]FLACT <> 2
    End
  Endif
Endif

Call MAJ_UTIHRM008(APPLI)

End

