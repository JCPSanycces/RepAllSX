#<AdxTL>@(#)11.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Consultation : GDD - consultation de la situation budgétaire
#   Action       : CONSGDD
#   Fenêtres     : FCNSGDD / DCNSGDD
#   Ecrans concernés : CONSGDD1, CONSGDD2 / CRITGDD
#   Description : Consultations de situation budgétaire
#
# Check if INDENT>0 & INDENV>0 inthis case : inquiry of GDD company with level 4/5
# then change the company with a non GDD company and go on a line IB_NBLIG.
#--------------------------------------------------------------------------

Local Char PARAM(20)(1..9)
Call GCONSULT("GDD","",PARAM) From GCONSULT
End

# Dmd 62872
Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(2)<>2 End Endif
Local File =APPLI+".ACTIV"    [ACV]
Read [ACV]CODACT="GDD"
If !fstat & [F:ACV]FLACT<>2 End Endif
Call VALGTC(APPLI,"GDD") From SUBGTC
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LECTURE"     : Gosub LECTURE
Endcase
Return


$OUVRE
If !clalev([F:PRJ]) : Local File PROJET    [PRJ] : Endif
If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([F:BUD]) : Local File BUD       [BUD] : Endif
If !clalev([F:BUP]) : Local File BUDPAR    [BUP] : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif
Local Char INFO(80)
Local Char CRITENV(250)
Local Char SOCIETE(GLONCPY),SITE(GLONFCY)
Local Integer ISVIDE
Local Decimal SOM_AMT,SOM_AMTAPP, SOM_AMTRES, SOM_AMTBUD, SOM_AMTLIG, SOM_AMTATT, SOM_AMTCMM, SOM_AMTCMMPRP, SOM_REALISE, SOM_AMTCAP, SOM_AMTCCA, SOM_AMTFAS
Local Decimal SOM_AMT2,SOM_AMTAPP2, SOM_AMTRES2, SOM_AMTBUD2, SOM_AMTLIG2, SOM_AMTATT2, SOM_AMTCMM2, SOM_AMTCMMPRP2, SOM_REALISE2, SOM_AMTCAP2, SOM_AMTCCA2, SOM_AMTFAS2

Local Char INTENV(30)
Local Integer OKACS, CTLACS

[M:GDD1]NIVEAU=1
Affzo [M]
Gosub DEFCRIT
Return

$DEFCRIT
# Valeurs par défaut
Default Mask [GDD1]
# Paramètres
For I=1 To dim(PARAM)
 Case I
  When 1 : #Niveau de détail
   If PARAM(I)<>""
    Case val(PARAM(I))
     When 1
      [M:GDD1]NIVEAU = 2
      [M:GDD1]NIV    = 1
     When 2 :#Enveloppe
      [M:GDD1]NIVEAU = 3
      [M:GDD1]NIV    = 2
     When 3
      [M:GDD1]NIVEAU = 4
      [M:GDD1]NIV    = 3
     When 4
      [M:GDD1]NIVEAU = 5
      [M:GDD1]NIV    = 4
      [M:GDD1]ZOOM   = 1
    Endcase
   Endif
  When 2 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:GDD1]CPY = PARAM(I)
     If [M:GDD1]FCY<>""
      Call LECTURE("FCY",[M:GDD1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:GDD1]CPY : [M:GDD1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 3 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:GDD1]FCY = PARAM(I)
     [M:GDD1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
    ##
    If PARAM(7)<>"" :#Enveloppe
     Call LECTURE("ENV",PARAM(7),"") From CONTOBJ
     Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
     If [F:BUP]LEV=1
      [M:GDD1]FCY = ""
     Endif
    Endif
    ##
   Endif
  When 4 : # Date début
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:GDD1]DATDEB = evalue("["+PARAM(I)+"]")
    Elsif PARAM(I)<>""
     [M:GDD1]DATDEB = PARAM(I)
    Endif
    Call AS_DATDEB([M:GDD1]DATDEB)
    Call C_DATDEB([M:GDD1]DATDEB)
   Endif
  When 5 : # Date fin
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:GDD1]DATFIN = evalue("["+PARAM(I)+"]")
    Elsif PARAM(I)<>""
     [M:GDD1]DATFIN = PARAM(I)
    Endif
    Call C_DATFIN([M:GDD1]DATFIN)
    [M:GDD1]CLEBUD=[M:GDD1]FFIY
   Endif
  When 6 : # Projet
   If PARAM(I)<>""
    Call LECTURE("PRJ",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:GDD1]CRIPRJ = PARAM(I)
     [M:GDD1]CLEPRJ = PARAM(I)
    Endif
   Endif
  When 7 : # Enveloppe
   If PARAM(I)<>""
    Call LECTURE("ENV",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:GDD1]ENVSTR = PARAM(I)
     [M:GDD1]ENVEND = PARAM(I)
     [M:GDD1]CLEENV = PARAM(I)
     Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
     [M:GDD1]COA=[F:BUP]COA
    Endif
   Endif
  When 8 : # ACCNUM Numéro de ligne
   If PARAM(I)<>"0"
    Read [BUD]BUD1 = val(PARAM(I))
    If !fstat
     [M:GDD1]CLELIG=val(PARAM(I))
    Endif
   Endif
  When 9 : # Compte
   If PARAM(I)<>""
    If [M:GDD1]COA<>""
     Read [GAC]GAC0 = [M:GDD1]COA;PARAM(I)
     If !fstat : [M:GDD1]ACC=PARAM(I) : Endif
    Else
     J=0
     Filter [GAC] Where ACC=PARAM(I)
      For [GAC]GAC0
       J+=1 : Break
      Next
     Filter [GAC]
     If J : [M:GDD1]ACC=PARAM(I) : Endif
    Endif
   Endif
 Endcase
Next I
Gosub SET_LIBEL
Return


$FERME
Inftxt "" At 2
Return


$SETBOUT
If [M:GDD1]CPY="" & [M:GDD1]FCY=""
 Call VIREBOUT(CHAINE,"IJRC+-D") From GCONSULT
Endif

If ([M:GDD1]NIVEAU<2 & ![M:GDD1]ZOOM)
 Call VIREBOUT(CHAINE,"I") From GCONSULT
Endif
If [M:GDD1]ZOOM
 Call VIREBOUT(CHAINE,"J") From GCONSULT
Endif

Case [M:GDD1]NIVEAU
 When 1 : INFO="+"-mess(1,2697,1)
 When 2 : INFO="-"-mess(1,2697,1)-"/"-"+"-mess(2,2697,1)
 When 3 : INFO="-"-mess(1,2697,1)-"/"-"+"-mess(3,2697,1)
 When 4 : INFO="-"-mess(2,2697,1)-"/"-"+"-mess(4,2697,1)
 When 5 : INFO="-"-mess(3,2697,1)
Endcase
Inftxt INFO At 2
Return

$EXEBOUT
Case BOUT
 When "J" : Gosub NIV_PLUS
 When "I" : Gosub NIV_MOINS
Endcase
Return

$NIV_PLUS
If nolign<1 or nolign>[M:GDD2]NBLIG : Return : Endif
NOL = nolign-1
# Passage niveau +1
If NOL<0 : Return : Endif
[M:GDD1]NIVEAU += 1
Case [M:GDD1]NIVEAU
 When 2 :# Un projet est choisi, on a une liste d'enveloppe
  If [M]REF(NOL)=""
   If [M:GDD1]DETALLENV<>2
    [M:GDD1]LIBEL  = mess(137,108,1)
   Endif
  Else
   [M:GDD1]LIBEL  = mess(1,2697,1)-[M]REF(NOL)
   [M:GDD1]CLEPRJ = [M]REF(NOL)
  Endif
 When 3 :# Une enveloppe est choisie, on a une liste de budget
  If [M]PRJ(NOL)<>"" :#& [M:GDD1]DETALLENV=2
   [M:GDD1]CLEPRJ = [M]PRJ(NOL)
   [M:GDD1]LIBEL  = mess(1,2697,1)-[M]PRJ(NOL)
  Else
   [M:GDD1]LIBEL  = mess(137,108,1)
  Endif
  [M:GDD1]LIBEL  -= "/"-mess(2,2697,1)-[M]REF(NOL)
  [M:GDD1]CLEENV = [M]REF(NOL)
  [M:GDD1]NIV+=1
 When 4 :# Un budget exercice est choisi, on a une liste de ligne
  [M:GDD1]LIBEL  -= "/"-mess(2,2694,1)-[M]REF(NOL)
  [M:GDD1]CLEBUD = val([M]REF(NOL))
  [M:GDD1]NIV    += 1
 When 5 :# Zoom sur une ligne précise
  [M:GDD1]LIBEL  -= "/"-[M]INTIT(NOL)
  [M:GDD1]CLELIG = val([M]REF(NOL))
  [M:GDD1]ZOOM   = 1
  [M:GDD1]NIV    += 1
Endcase
Gosub PAG_PREM From GCONSULT
Gosub SETBOUT From GCONSULT
Affzo [M:GDD1]
Return

$NIV_MOINS
NOL = nolign-1
If [M:GDD1]ZOOM : # Retour de zoom
 [M:GDD1]ZOOM = 0
 [M:GDD1]NIVEAU -= 1
 [M:GDD1]NIV -= 1
 Raz [M:GDD1]CLELIG
Else : # Passage au niveau -1
 [M:GDD1]NIVEAU -= 1
 If [M:GDD1]NIVEAU>=2
  [M:GDD1]NIV -=1
 Endif
Endif
Gosub SET_LIBEL
Gosub PAG_CUR From GCONSULT
Gosub SETBOUT From GCONSULT
Affzo [M:GDD1]
Return

$SET_LIBEL
Case [M:GDD1]NIVEAU
 When 1
  Raz [M:GDD1]CLEPRJ
  Raz [M:GDD1]LIBEL
 When 2
  Raz [M:GDD1]CLEENV
  If [M:GDD1]CLEPRJ=""
   If [M:GDD1]DETALLENV<>2
   [M:GDD1]LIBEL = mess(137,108,1)
   Else
    [M:GDD1]LIBEL = ""
   Endif
  Else
   If [M:GDD1]DETALLENV<>2
    [M:GDD1]LIBEL = mess(1,2697,1)-[M:GDD1]CLEPRJ
   Else
    Raz [M:GDD1]CLEPRJ
    [M:GDD1]LIBEL = ""
   Endif
  Endif
 When 3
  Raz [M:GDD1]CLEBUD
  If [M:GDD1]CLEPRJ=""
   [M:GDD1]LIBEL = mess(137,108,1)
  Else
   [M:GDD1]LIBEL = mess(1,2697,1)-[M:GDD1]CLEPRJ
  Endif
  [M:GDD1]LIBEL -= "/"-mess(2,2697,1)-[M:GDD1]CLEENV
 When 4
  If [M:GDD1]CLEPRJ=""
   [M:GDD1]LIBEL = mess(137,108,1)
  Else
   [M:GDD1]LIBEL = mess(1,2697,1)-[M:GDD1]CLEPRJ
  Endif
  [M:GDD1]LIBEL -= "/"-mess(2,2697,1)-[M:GDD1]CLEENV-"/"-mess(2,2694,1)-num$([M:GDD1]CLEBUD)
Endcase
Return

$LECTURE
CTLACS = 1
If [M:GDD1]ZOOM
 [M:GDD1]NIVAFF = len(mess(0,2697,1))+1
Else
 [M:GDD1]NIVAFF = [M:GDD1]NIVEAU
Endif
[M:GDD1]NIVMAX = len(mess(0,2697,1))+1
[M:GDD1]LIBNIV = mess([M:GDD1]NIV,2697,1)

Gosub LOAD_FILTRE

Local Integer INDENV, INDENT, INDCCE3
Call GETGDDINDDIE(SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

#-----------------------
Case [M:GDD1]NIVEAU
 When 1,2,3 :
#  [M:GDD1]ENTDENFMT="-K:15X"
  Chgfmt [M:GDD2]ENTDEN With "-KP:15X"
 When 4,5:
#  [M:GDD1]ENTDENFMT="K:15X"
  Chgfmt [M:GDD2]ENTDEN With "KP:15X"
Endcase
#Chgfmt [M:GDD2]ENTDEN With [M:GDD1]ENTDENFMT
Affzo [M:GDD2]
#--------------------
Case [M:GDD1]NIVEAU
 When 1 : # Premier niveau on affiche tous les projets (dont vide)
  If [M]CRIPRJ=""
   Local Char CRITENVSUP(20) : CRITENVSUP = '1=1'
   If [M]DETALLENV<>2
    # Si on demande le détail sur toutes enveloppes alors on affiche qu'une seul ligne toutes enveloppes confondues
    # sur une seule ligne, sinon on affiche en première ligne que les eneveloppe sans projet puis celle par projet
    CRITENVSUP -= '& PRJ=""'
   Endif
   #D'abord afficher les montants des enveloppes sans projet
   ISVIDE=0
   Raz SOM_AMT,SOM_AMTAPP,SOM_AMTRES,SOM_AMTBUD,SOM_AMTLIG,SOM_AMTATT,SOM_AMTCMM,SOM_AMTCMMPRP,SOM_REALISE,SOM_AMTCAP,SOM_AMTCCA,SOM_AMTFAS
   For [ENV]ENV0 Where evalue(CRITENV) & evalue(CRITENVSUP)
    OKACS = 1
    If [F:ENV]ACS<>""
     Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
     If !OKACS : CTLACS=0 : Endif
    Endif
    If OKACS
     ISVIDE=1
     SOM_AMT       += [F:ENV]AMTENV
     SOM_AMTAPP    += [F:ENV]AMTAPP
     SOM_AMTRES    += [F:ENV]AMTRES
     For [ENF]ENF0 Where ENV=[F:ENV]ENV & FIYNUM>=[M]DFIY & FIYNUM<=[M]FFIY
      SOM_AMTBUD    += [F:ENF]AMTBUDFIY
      If INDENV>0
       For [BUD]BUD0 Where evalue("CCE"+num$(INDENV))=[F:ENF]ENV & FIY=[F:ENF]FIYNUM & evalue(CRITLIG)
        SOM_AMTLIG    += [F:BUD]AMT(0)
        SOM_AMTATT    += [F:BUD]AMTATT
        SOM_AMTCMM    += [F:BUD]AMTCMM
        SOM_AMTCMMPRP += [F:BUD]AMTCMMPRP
        SOM_REALISE   += [F:BUD]AMTREA
        SOM_AMTCAP    += [F:BUD]AMTCAP
        SOM_AMTCCA    += [F:BUD]AMTCCA
        SOM_AMTFAS    += [F:BUD]AMTFAS
       Next
      Endif
     Next
    Endif
   Next
   If ISVIDE
    [M:GDD2]REF(0)       = ""
    [M:GDD2]AMTAPP(0)    = SOM_AMTAPP
    [M:GDD2]AMTATT(0)    = SOM_AMTATT
    [M:GDD2]AMTBUD(0)    = SOM_AMT
    [M:GDD2]AMTRES(0)    = SOM_AMTRES
    [M:GDD2]DISPO(0)     = SOM_AMT-SOM_AMTRES
    [M:GDD2]IMPBUD(0)    = SOM_AMTBUD
    [M:GDD2]RAV(0)       = SOM_AMT-SOM_AMTRES-SOM_AMTBUD
    [M:GDD2]AMTCMMPRP(0) = SOM_AMTCMMPRP
    [M:GDD2]AMTCMM(0)    = SOM_AMTCMM
    [M:GDD2]REALISE(0)   = SOM_REALISE
    [M:GDD2]CONSOM(0)    = SOM_AMTCMM+SOM_AMTCMMPRP+SOM_REALISE
    [M:GDD2]SOLDE(0)     = SOM_AMT-[M:GDD2]CONSOM(0)
    [M:GDD2]AMTCAP(0)    = SOM_AMTCAP
    [M:GDD2]AMTCCA(0)    = SOM_AMTCCA
    [M:GDD2]AMTFAS(0)    = SOM_AMTFAS
    [M:GDD2]NBLIG +=1
    Affzo [M:GDD2]
   Endif
  Endif
  I=[M]NBLIG
  If [M]DETALLENV<>2
   # On affiche les lignes par projet que si le détail toutes enveloppes n'est pas demandé.
   For [PRJ]PRJ0
    ISPRJ=0
    Raz SOM_AMT2,SOM_AMTAPP2, SOM_AMTRES2, SOM_AMTBUD2, SOM_AMTLIG2, SOM_AMTATT2, SOM_AMTCMM2, SOM_AMTCMMPRP2, SOM_REALISE2, SOM_AMTCAP2, SOM_AMTCCA2, SOM_AMTFAS2
    For [ENV]ENV0 Where PRJ=[F:PRJ]PRJ & evalue(CRITENV)
     OKACS = 1
     If [F:ENV]ACS<>""
      Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
      If !OKACS : CTLACS=0 : Endif
     Endif
      If OKACS
      If !ISPRJ : ISPRJ=1 : Endif
      SOM_AMT2       += [F:ENV]AMTENV
      SOM_AMTAPP2    += [F:ENV]AMTAPP
      SOM_AMTRES2    += [F:ENV]AMTRES
      For [ENF]ENF0 Where ENV=[F:ENV]ENV & FIYNUM>=[M:GDD1]DFIY & FIYNUM<=[M:GDD1]FFIY
       SOM_AMTBUD2    += [F:ENF]AMTBUDFIY
       If INDENV>0
        For [BUD]BUD0 Where evalue("CCE"+num$(INDENV))=[F:ENF]ENV & FIY=[F:ENF]FIYNUM & evalue(CRITLIG)
         SOM_AMTLIG2    += [F:BUD]AMT(0)
         SOM_AMTATT2    += [F:BUD]AMTATT
         SOM_AMTCMM2    += [F:BUD]AMTCMM
         SOM_AMTCMMPRP2 += [F:BUD]AMTCMMPRP
         SOM_REALISE2   += [F:BUD]AMTREA
         SOM_AMTCAP2    += [F:BUD]AMTCAP
         SOM_AMTCCA2    += [F:BUD]AMTCCA
         SOM_AMTFAS2    += [F:BUD]AMTFAS
        Next
       Endif
      Next
     Endif
     Next
    If ISPRJ
     [M:GDD2]REF(I)       = [F:PRJ]PRJ
     [M:GDD2]INTIT(I)     = mess(1,2697,1)-[F:PRJ]PRJ
     [M:GDD2]CUR(I)       = [F:PRJ]CUR
     [M:GDD2]AMTAPP(I)    = SOM_AMTAPP2
     [M:GDD2]AMTATT(I)    = SOM_AMTATT2
     [M:GDD2]AMTBUD(I)    = SOM_AMT2
     [M:GDD2]AMTRES(I)    = SOM_AMTRES2
     [M:GDD2]DISPO(0)     = SOM_AMT2-SOM_AMTRES2
     [M:GDD2]IMPBUD(0)    = SOM_AMTBUD2
     [M:GDD2]RAV(0)       = SOM_AMT2-SOM_AMTRES2-SOM_AMTBUD2
     [M:GDD2]AMTCMMPRP(I) = SOM_AMTCMMPRP2
     [M:GDD2]AMTCMM(I)    = SOM_AMTCMM2
     [M:GDD2]REALISE(I)   = SOM_REALISE2
     [M:GDD2]CONSOM(I)    = SOM_AMTCMM2+SOM_AMTCMMPRP2+SOM_REALISE2
     [M:GDD2]SOLDE(I)     = SOM_AMT2-[M:GDD2]CONSOM(I)
     [M:GDD2]AMTCAP(I)    = SOM_AMTCAP2
     [M:GDD2]AMTCCA(I)    = SOM_AMTCCA2
     [M:GDD2]AMTFAS(I)    = SOM_AMTFAS2
     I+=1
     #----TB protection----
     If I>dim([M:GDD2]REF)-1
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : Break
     Endif
     #--------------------
     Affzo [M:GDD2]
    Endif
   Next
   [M]NBLIG=I
  Endif
 When 2 : # Liste des enveloppes d'un projet
   I=0
   Case [M:GDD1]TRIPRJ
    When 1 : # tri par enveloppe
     Filter [ENV] Where evalue(CRITENV) Order By Key CLE= [F:ENV]ENV
    When 2 : #Tri par projet
    Filter [ENV] Where evalue(CRITENV) Order By Key CLE=[F:ENV]PRJ;[F:ENV]ENV
   Endcase
   For [ENV]CLE
    OKACS = 1
    If [F:ENV]ACS<>""
     Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
     If !OKACS : CTLACS=0 : Endif
    Endif
    If OKACS
     Raz SOM_AMTBUD, SOM_AMTLIG, SOM_AMTATT, SOM_AMTCMM, SOM_AMTCMMPRP, SOM_REALISE, SOM_AMTCAP, SOM_AMTCCA, SOM_AMTFAS
     For [ENF]ENF0 Where ENV=[F:ENV]ENV & FIYNUM>=[M:GDD1]DFIY & FIYNUM<=[M:GDD1]FFIY
      SOM_AMTBUD    += [F:ENF]AMTBUDFIY
      If INDENV>0
       For [BUD]BUD0 Where evalue("CCE"+num$(INDENV))=[F:ENF]ENV & FIY=[F:ENF]FIYNUM & evalue(CRITLIG)
        SOM_AMTLIG    += [F:BUD]AMT(0)
        SOM_AMTATT    += [F:BUD]AMTATT
        SOM_AMTCMM    += [F:BUD]AMTCMM
        SOM_AMTCMMPRP += [F:BUD]AMTCMMPRP
        SOM_REALISE   += [F:BUD]AMTREA
        SOM_AMTCAP    += [F:BUD]AMTCAP
        SOM_AMTCCA    += [F:BUD]AMTCCA
        SOM_AMTFAS    += [F:BUD]AMTFAS
       Next
      Endif
     Next
     [M:GDD2]REF(I)       = [F:ENV]ENV
     Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
     [M:GDD2]INTIT(I)     = mess(2,2697,1)-[F:ENV]ENV-INTENV
     [M:GDD2]PRJ(I)       = [F:ENV]PRJ
     [M:GDD2]CUR(I)       = [F:ENV]CURENV
     [M:GDD2]AMTAPP(I)    = [F:ENV]AMTAPP
     [M:GDD2]AMTATT(I)    = SOM_AMTATT
     [M:GDD2]AMTBUD(I)    = [F:ENV]AMTENV
     [M:GDD2]AMTRES(I)    = [F:ENV]AMTRES
     [M:GDD2]DISPO(I)     = [F:ENV]AMTENV-[F:ENV]AMTRES
     [M:GDD2]IMPBUD(I)    = SOM_AMTBUD
     [M:GDD2]RAV(I)       = [F:ENV]AMTENV-[F:ENV]AMTRES-SOM_AMTBUD
     [M:GDD2]AMTCMMPRP(I) = SOM_AMTCMMPRP
     [M:GDD2]AMTCMM(I)    = SOM_AMTCMM
     [M:GDD2]REALISE(I)   = SOM_REALISE
     [M:GDD2]CONSOM(I)    = SOM_AMTCMM+SOM_AMTCMMPRP+SOM_REALISE
     [M:GDD2]SOLDE(I)     = [F:ENV]AMTENV-[M:GDD2]CONSOM(I)
     [M:GDD2]AMTCAP(I)    = SOM_AMTCAP
     [M:GDD2]AMTCCA(I)    = SOM_AMTCCA
     [M:GDD2]AMTFAS(I)    = SOM_AMTFAS
     I+=1
     #----TB protection----
     If I>dim([M:GDD2]REF)-1
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : Break
     Endif
     #--------------------
    Endif
   Next
   Filter [ENV]
   [M:GDD2]NBLIG=I
   If I=0
    #Aucun enregistrement pour ces sélections
    Call MESSAGE(mess(104,199,1)) From GESECRAN
   Else
    Affzo [M:GDD2]
     If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
    If [M]DETALLENV=2
     Gosub COLORIZE
    Endif
   Endif
 When 3 : # Liste de budget exercice pour une enveloppe
   CRITENV -= '& PRJ="'+[M:GDD1]CLEPRJ+'" & ENV="'+[M:GDD1]CLEENV+'"'
   I=0
   For [ENV]ENV0 Where evalue(CRITENV)
    For [ENF]ENF0 Where ENV=[F:ENV]ENV & FIYNUM>=[M:GDD1]DFIY & FIYNUM<=[M:GDD1]FFIY
     Raz SOM_AMTLIG, SOM_AMTATT, SOM_AMTCMM, SOM_AMTCMMPRP, SOM_REALISE, SOM_AMTCAP, SOM_AMTCCA, SOM_AMTFAS
     If INDENV>0
      For [BUD]BUD0 Where evalue("CCE"+num$(INDENV))=[F:ENF]ENV & FIY=[F:ENF]FIYNUM & evalue(CRITLIG)
       SOM_AMTLIG    += [F:BUD]AMT(0)
       SOM_AMTATT    += [F:BUD]AMTATT
       SOM_AMTCMM    += [F:BUD]AMTCMM
       SOM_AMTCMMPRP += [F:BUD]AMTCMMPRP
       SOM_REALISE   += [F:BUD]AMTREA
       SOM_AMTCAP    += [F:BUD]AMTCAP
       SOM_AMTCCA    += [F:BUD]AMTCCA
       SOM_AMTFAS    += [F:BUD]AMTFAS
      Next
     Endif
     [M:GDD2]REF(I)       = num$([F:ENF]FIYNUM)
     [M:GDD2]INTIT(I)     = mess(2,2694,1)-num$([F:ENF]FIYNUM):#[F:ENF]ENV-"/"-num$([F:ENF]FIYNUM)
     [M:GDD2]PRJ(I)       = [F:ENV]PRJ
     [M:GDD2]FIY(I)       = [F:ENF]FIYNUM
     [M:GDD2]CUR(I)       = [F:ENV]CURENV
     [M:GDD2]AMTAPP(I)    = [F:ENF]AMTAPPFIY
     [M:GDD2]AMTATT(I)    = SOM_AMTATT
     [M:GDD2]AMTBUD(I)    = [F:ENF]AMTBUDFIY
     [M:GDD2]AMTRES(I)    = [F:ENF]AMTRESFIY
     [M:GDD2]DISPO(I)     = [F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY
     [M:GDD2]IMPBUD(I)    = SOM_AMTLIG
     [M:GDD2]RAV(I)       = [F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY-SOM_AMTLIG
     [M:GDD2]AMTCMMPRP(I) = SOM_AMTCMMPRP
     [M:GDD2]AMTCMM(I)    = SOM_AMTCMM
     [M:GDD2]REALISE(I)   = SOM_REALISE
     [M:GDD2]CONSOM(I)    = SOM_AMTCMM+SOM_AMTCMMPRP+SOM_REALISE
     [M:GDD2]SOLDE(I)     = [F:ENF]AMTBUDFIY-[M:GDD2]CONSOM(I)
     [M:GDD2]AMTCAP(I)    = SOM_AMTCAP
     [M:GDD2]AMTCCA(I)    = SOM_AMTCCA
     [M:GDD2]AMTFAS(I)    = SOM_AMTFAS
     I +=1
     #----TB protection----
     If I>dim([M:GDD2]REF)-1
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : Break 2
     Endif
     #--------------------
    Next
  Next
  [M:GDD2]NBLIG=I
  If I=0
   #Aucun enregistrement pour ces sélections
   Call MESSAGE(mess(104,199,1)) From GESECRAN
  Endif
 When 4 : # Liste de lignes pour un budget exercice
   CRITENV -= '& PRJ="'+[M:GDD1]CLEPRJ+'" & ENV="'+[M:GDD1]CLEENV+'"'
   I=0
   For [ENV]ENV0 Where evalue(CRITENV)
    For [ENF]ENF0 Where ENV=[F:ENV]ENV & FIYNUM=[M:GDD1]CLEBUD
     If INDENV>0
      For [BUD]BUD0 Where evalue("CCE"+num$(INDENV))=[F:ENF]ENV & FIY=[F:ENF]FIYNUM & evalue(CRITLIG)
       [M:GDD2]REF(I)       = num$([F:BUD]ACCNUM)
       [M:GDD2]INTIT(I)     = mess(8,104,1)-[F:BUD]ACC
       [M:GDD2]PRJ(I)       = [F:ENV]PRJ
       [M:GDD2]FIY(I)       = [F:BUD]FIY
       If INDENT>0
        [M:GDD2]ENTDEN(I)    = evalue("[F:BUD]CCE"+num$(INDENT))
       Endif
       [M:GDD2]CUR(I)       = [F:BUD]CUR
       [M:GDD2]AMTAPP(I)    = [F:BUD]AMTAPP
       [M:GDD2]AMTATT(I)    = [F:BUD]AMTATT
       [M:GDD2]AMTBUD(I)    = [F:BUD]AMT(0)
       [M:GDD2]DISPO(I)     = [F:BUD]AMT(0)
       [M:GDD2]RAV(I)       = [F:BUD]AMT(0)-[F:BUD]AMTREA
       [M:GDD2]AMTCMMPRP(I) = [F:BUD]AMTCMMPRP
       [M:GDD2]AMTCMM(I)    = [F:BUD]AMTCMM
       [M:GDD2]REALISE(I)   = [F:BUD]AMTREA
       [M:GDD2]CONSOM(I)    = [F:BUD]AMTCMM+[F:BUD]AMTCMMPRP+[F:BUD]AMTREA
       [M:GDD2]SOLDE(I)     = [F:BUD]AMT(0)-[M:GDD2]CONSOM(I)
       [M:GDD2]AMTCAP(I)    = [F:BUD]AMTCAP
       [M:GDD2]AMTCCA(I)    = [F:BUD]AMTCCA
       [M:GDD2]AMTFAS(I)    = [F:BUD]AMTFAS
       I +=1
       #----TB protection----
       If I>dim([M:GDD2]REF)-1
        #Tableau Plein
        Call MESSAGE(mess(26,100,1)) From GESECRAN : Break 3
       Endif
       #--------------------
      Next
     Endif
    Next
   Next
   [M:GDD2]NBLIG=I
   If I=0
    #Aucun enregistrement pour ces sélections
    Call MESSAGE(mess(104,199,1)) From GESECRAN
   Endif
 When 5 : # Zoom sur une ligne
   Read [BUD]BUD1 = [M:GDD1]CLELIG
   If !fstat
    [M:GDD2]REF(0)       = num$([F:BUD]ACCNUM)
    [M:GDD2]INTIT(0)     = mess(8,104,1)-[F:BUD]ACC
    [M:GDD2]FIY(0)       = [F:BUD]FIY
    [M:GDD2]CUR(0)       = [F:BUD]CUR
    If INDENT>0
     [M:GDD2]ENTDEN(0)    = evalue("[F:BUD]CCE"+num$(INDENT))
    Endif
    [M:GDD2]AMTAPP(0)    = [F:BUD]AMTAPP
    [M:GDD2]AMTATT(0)    = [F:BUD]AMTATT
    [M:GDD2]AMTBUD(0)    = [F:BUD]AMT(0)
    [M:GDD2]DISPO(I)     = [F:BUD]AMT(0)
    [M:GDD2]RAV(I)       = [F:BUD]AMT(0)-[F:BUD]AMTREA
    [M:GDD2]AMTCMMPRP(0) = [F:BUD]AMTCMMPRP
    [M:GDD2]AMTCMM(0)    = [F:BUD]AMTCMM
    [M:GDD2]REALISE(0)   = [F:BUD]AMTREA
    [M:GDD2]CONSOM(0)    = [F:BUD]AMTCMM+[F:BUD]AMTCMMPRP+[F:BUD]AMTREA
    [M:GDD2]SOLDE(0)     = [F:BUD]AMT(0)-[M:GDD2]CONSOM(0)
    [M:GDD2]AMTCAP(0)    = [F:BUD]AMTCAP
    [M:GDD2]AMTCCA(0)    = [F:BUD]AMTCCA
    [M:GDD2]AMTFAS(0)    = [F:BUD]AMTFAS
    [M:GDD2]NBLIG =1
   Endif
Endcase
Affzo [M:GDD1]
Affzo [M:GDD2]
If [M:GDD2]NBLIG>0 & NBLU=1 : SUITE = 1 : Endif
Return

$LOAD_FILTRE
#--------------------------------------------------------------
# Les critères et filtres sur objets
#--------------------------------------------------------------
CRITENV="1=1"
CRITLIG="1=1"

If [M:GDD1]DATDEB<>[0/0/0] & [M:GDD1]DATFIN<>[0/0/0]
 CRITENV -='& REASTR<=['+format$(GFMD,[M:GDD1]DATFIN)+'] & REAEND>=['+format$(GFMD,[M:GDD1]DATDEB)+']'
Endif

If [M:GDD1]CPY<>""
 SOCIETE=[M:GDD1]CPY
 Local Integer SOC,J
 Local Char LISTFCY(GLONFCY)(1..GNBSITE)
 SOC=find(SOCIETE,GSOC(1..GNBSOC))
 J=1
 If SOC
  For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
   LISTFCY(J)=[F:FCY]FCY
   J+=1
  Next
 Endif
Endif

If [M:GDD1]FCY<>""
 SITE=[M:GDD1]FCY
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE=[F:FCY]LEGCPY
Endif

If [M:GDD1]FCY<>"" | [M:GDD1]CPY<>""
 If [M:GDD1]FCY<>""
  CRITENV -= '& FCY="'+SITE+'"'
 Else
  CRITENV -= '& (FCY="'+SOCIETE+'" | find(FCY,LISTFCY(1..'+num$(J)+')))'
 Endif
Else
 CRITENV = "1=2"
Endif

#If [M:GDD1]CRIPRJ<>""
# CRITENV -='& PRJ="'+[M:GDD1]CRIPRJ+'"'
#Elsif [M:GDD1]CLEPRJ<>""
# CRITENV -= '& PRJ="'+[M:GDD1]CLEPRJ+'"'
#Endif

If [M:GDD1]CLEPRJ<>""
 CRITENV -= '& PRJ="'+[M:GDD1]CLEPRJ+'"'
Else
 If [M:GDD1]NIVEAU>1 & [M:GDD1]CRIPRJ<>""
  CRITENV -='& PRJ="'+[M:GDD1]CRIPRJ+'"'
 Endif
Endif



#If [M:GDD1]ENV<>""
# CRITENV -='& ENV="'+[M:GDD1]ENV+'"'
#Elsif [M:GDD1]CLEENV<>""
# CRITENV -= '& ENV="'+[M:GDD1]CLEENV+'"'
#Endif
#
#If [M:GDD1]ENTMNA<>""
# CRITENV -='& ENTMNA="'+[M:GDD1]ENTMNA+'"'
#Endif
#
#If [M]ENTAPP<>""
# CRITENV -='& ENTAPP="'+[M:GDD1]ENTAPP+'"'
#Endif

If [M:GDD1]ENTMSTR<>""
 CRITENV -= '& ENTMNA>="'+[M:GDD1]ENTMSTR+'" & ENTMNA<="'+[M:GDD1]ENTMEND+'"'
Endif
If [M:GDD1]ENTASTR<>""
 CRITENV -= '& ENTAPP>="'+[M:GDD1]ENTASTR+'" & ENTAPP<="'+[M:GDD1]ENTAEND+'"'
Endif

If [M:GDD1]ENVSTR<>""
 CRITENV -= '& ENV>="'+[M:GDD1]ENVSTR+'" & ENV<="'+[M:GDD1]ENVEND+'"'
Elsif [M:GDD1]CLEENV<>""
 CRITENV -= '& ENV="'+[M:GDD1]CLEENV+'"'
Endif

If [M:GDD1]ACC<>""
 CRITLIG -='& ACC="'+[M:GDD1]ACC+'"'
Endif

Raz [M:GDD2]
Affzo [M:GDD2]
Return

$COLORIZE
Local Integer K : K=1
Local Char PRJCUR(GLONPRJ)
PRJCUR=[M:GDD2]PRJ(0)
For I=0 To [M:GDD2]NBLIG-1
 If [M:GDD2]PRJ(I)<>""
  If [M:GDD2]PRJ(I)<>PRJCUR
   If K<>3
    K+=1
   Else
    K=1
   Endif
   Chgstl [M:GDD2]NBLIG(I)  With "GDD"+num$(K)
  Else
   Chgstl [M:GDD2]NBLIG(I)  With "GDD"+num$(K)
  Endif
  PRJCUR=[M]PRJ(I)
 Endif
Next
Affzo [M:GDD2]
Return


##---------------------------------------##
## Etiquettes écrans CONSGDD1 & CRITGDD  ##
##---------------------------------------##

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char SOCIETE(GLONCPY)
Call C_CPY(VALEUR) From CONSSUB
If mkstat=0 : Raz GMESSAGE : Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
If [M]CPY<>""
 Local Libelle LEDTYPGEN,LEDTYPANA
 Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 [M]LEDTYP=LEDTYPANA
 Call LECPLAN([M]CPY,LEDTYPANA,[M]COA) From CPTDIV
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
Local Decimal EXERCICE
Call GETEXE([M]CPY,[M]LEDTYP,VALEUR,EXERCICE) From CPTSUB
[M]DFIY=EXERCICE
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
Local Decimal EXERCICE
Call GETEXE([M]CPY,[M]LEDTYP,VALEUR,EXERCICE) From CPTSUB
[M]FFIY=EXERCICE
End

Subprog AM_CRIPRJ(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M:GDD2]
 Affzo [M:GDD2]
 [M:GDD1]NIVEAU=2
 [M:GDD1]NIVAFF=2
 [M:GDD1]LIBEL = mess(1,2697,1)-":"-VALEUR
 [M:GDD1]CLEPRJ=VALEUR
 Grizo [M:GDD1]DETALLENV
Else
 Actzo [M:GDD1]DETALLENV
Endif
Affzo [M:GDD1]DETALLENV
End

Subprog C_CRIPRJ(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRJ]) = 0 : Local File PROJET [PRJ] : Endif
Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
If !fstat & [F:PRJ]ACS<>""
 Local Integer OKACC
 Call CONSACC([F:PRJ]ACS,OKACC) From CPTSUB
 If !OKACC
  Call MESSAGE(mess(4,104,1)) From GESECRAN
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_DETALLENV(VALEUR)
Variable Integer VALEUR
If [M]CRIPRJ<>""
 VALEUR=1
 mkstat=1
Endif
End

Subprog AM_DETALLENV(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 If [M:GDD1]NIVEAU<=2
  Raz [M:GDD1]LIBEL
  Raz [M:GDD1]CLEPRJ
 Endif
 Grizo [M]CRIPRJ
Else
 Actzo [M]CRIPRJ
Endif
Affzo [M]
End

Subprog AS_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTMSTR<>""
 VALEUR=[M]ENTMSTR
 Affzo [M]ENTMEND
Endif
End

Subprog C_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTMSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2 : End
Endif
End

Subprog AS_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTASTR<>""
 VALEUR=[M]ENTASTR
 Affzo [M]ENTAEND
Endif
End

Subprog C_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTASTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2 : End
Endif
End


Subprog C_ENVSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACS
  If [F:ENV]ACS<>""
   Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
   If !OKACS
    Call MESSAGE(mess(4,104,1)) From GESECRAN
    mkstat = 2 : End
   Endif
  Endif
  If ([M:GDD1]FCY<>"" & [F:ENV]FCY<>[M:GDD1]FCY) | ([M:GDD1]FCY="" & [F:ENV]FCY<>[M:GDD1]CPY)
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M:GDD1]CPY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
Endif
End


Subprog AS_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENVSTR<>""
 VALEUR=[M]ENVSTR
 Affzo [M]ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACS
  If [F:ENV]ACS<>""
   Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
   If !OKACS
    Call MESSAGE(mess(4,104,1)) From GESECRAN
    mkstat = 2 : End
   Endif
  Endif
  If ([M:GDD1]FCY<>"" & [F:ENV]FCY<>[M:GDD1]FCY) | ([M:GDD1]FCY="" & [F:ENV]FCY<>[M:GDD1]CPY)
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M:GDD1]CPY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    #L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
 Endif
 If VALEUR<[M]ENVSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE=mess(44,199,1)
  mkstat=2 :End
 Endif
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSGDD2) 13/02/2012 14:07:38 (JHA)
######################################################################################
Subprog IB_NBLIG
Case [M:GDD1]NIVEAU
 When 1 : Raz GBOUT1, GBOUT2, GBOUT3
 When 2 : Raz GBOUT2, GBOUT3
 When 3 : Raz GBOUT1, GBOUT3
 When 4, 5 : Raz GBOUT1, GBOUT2
Endcase

If [M:GDD1]NIVEAU>2
 If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
 If !clalev([F:BUP]) : Local File BUDPAR    [BUP] : Endif
 If !clalev([F:BUD]) : Local File BUD       [BUD] : Endif
 If !clalev([F:BUA]) : Local File BUDPURAUD [BUA] : Endif
 #Détail des achats/Purchase detail
 Local Char CRITBUA(250),CRITBUAB(250)
 Local Integer INDENV, INDENT, INDCCE3

 Call LECTURE("ENV",[M]CLEENV,"") From CONTOBJ
 CRITBUA ='BUD="'+[F:ENV]BUD+'"'
 Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
 CRITBUA -='& CPY="'+[M:GDD1]CPY+'"'
 If [M]FCY<>""
  CRITBUA -='& FCY="'+[M]FCY+'"'
 Endif
 CRITBUA -='& find("'+[F:BUP]DIE(0)+'",[F:BUA]DIE(0..8))>0'
 CRITBUA -='& find("'+[F:BUP]DIE(1)+'",[F:BUA]DIE(0..8))>0'
 If [M:GDD1]NIVEAU=3
  CRITBUA -= '& FIY='+num$(val([M]REF(nolign-1)))
 Else
  CRITBUA -= '& FIY='+num$([M:GDD1]CLEBUD)
 Endif
  CRITBUA -='& find("'+[M]CLEENV+'",[F:BUA]CCE(0..8))>0'
 CRITBUAB = '1=1'
 If [M:GDD1]NIVEAU>=4
  Read [BUD]BUD1 = val([M:GDD2]REF(nolign-1))
  Call GETGDDINDDIE([M:GDD1]CPY,[F:BUP]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD
  If !fstat
   CRITBUAB -='& find("'+[F:BUD]ACC+'",[F:BUA]ACC(0..9))>0'
   If INDENT>0
    CRITBUAB -='& find("'+evalue('[F:BUD]CCE'+num$(INDENT))+'",[F:BUA]CCE(0..8))>0' ## YYFIN_104036_US15
   Endif
   If INDENV>0
    CRITBUAB -='& find("'+evalue('[F:BUD]CCE'+num$(INDENV))+'",[F:BUA]CCE(0..8))>0'  ## YYFIN_104036_US15
   Endif
   If [F:BUP]DIE(2)<>""
    CRITBUAB -='& find("'+[F:BUP]DIE(2)+'",[F:BUA]DIE(0..8))>0'
    If INDCCE3>0
     CRITBUAB -='& find("'+evalue('[F:BUD]CCE'+num$(INDCCE3))+'",[F:BUA]CCE(0..8))>0'   ## YYFIN_104036_US15
    Endif
   Endif
  Endif
 Endif

 Filter [BUA] Where evalue(CRITBUA) & evalue(CRITBUAB)
 Look [BUA]BUA0 First
 If fstat
  Raz GBOUT4
 Endif
 Filter [BUA]
Else
 Raz GBOUT4
Endif
End

