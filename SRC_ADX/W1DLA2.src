Call IB_FCYCTY(VALEUR)
## Action VILINI
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILINI"
Call S_AFF_CHAR(VALEUR,PARMSK,"INIVIL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat=2
 [M]FCYCTY(INDIC) = VALEUR
 Affzo FCYCTY(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_FCYCTY(zc) From W1DLA2
Onkey   2 Titled GBOUTS Call S_FCYCTY(zc) From W1DLA2
Gosub _AFF
End

