Subprog AS_CPYPOSCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(750,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CPYPOSCOD(zc) From W1DLA2
Onkey   2 Titled GBOUTS Call S_CPYPOSCOD(zc) From W1DLA2
Gosub _AFF
End

Subprog C_CPYPOSCOD(VALEUR)
Variable Char    VALEUR()
## Action POSCNTOBL
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "POSCNTOBL"
PARMSK(1) = [M]CPYCRY
PARMSK(2) = "0"
Call S_AFF_CHAR(VALEUR,PARMSK,"POSCNTOBL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CPYPOSCOD" : GZNUM = 16059 : Endif
Gosub _AFF
End

$AMM_CPYPOSCOD
Call AM_CPYPOSCOD(zc)
If !mkstat & GOBJET
 zoncou = "CPYPOSCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPYPOSCOD(VALEUR)
Variable Char    VALEUR()
## Action CPCONT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CPCONT"
PARMSK(1) = [M]CPYCRY
PARMSK(2) = [M]CPYCTY
PARMSK(3) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CPCONT","SUBPOS","") From GACTION
[M]CPYCTY = PARMSK(2)
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CPYPOSCOD" : GZNUM = 16059 : Endif
If !mkstat
 ## Action SELCTY2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTY2"
 PARMSK(1) = [M]CPYCRY
 PARMSK(2) = [M]CPYCTY
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTY2","SUBPOS","") From GACTION
 [M]CPYCTY = PARMSK(2)
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPYPOSCOD" : GZNUM = 16059 : Endif
Endif
Gosub _AFF
End

Subprog S_CPYPOSCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOS"
 PARMSK(1) = [M]CPYCRY
 PARMSK(2) = [M]CPYCTY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS","SUBPOS","") From GACTION
 [M]CPYCTY = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CPYPOSCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATUNPOS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATUNPOS"
 PARMSK(1) = [M]CPYCRY
 PARMSK(2) = [M]CPYCTY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"ATUNPOS","SUBPOS","") From GACTION
 [M]CPYCTY = PARMSK(2)
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

