#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:58"
A_USER  = "DOC"
A_STAMP = "20181109230358"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DLA2 [DLA2]
Gosub HORODAT
Local Inpbox "DLA2" From GFONCTION At A_STAMP With A_WINDPREV Mask [DLA2] As [SIM_]
Grizo [DLA2]5
Grizo [DLA2]10
Grizo [DLA2]15
Grizo [DLA2]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DLA2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=6
X1(1)=1 : X2(1)=74 : Y1(1)=7 : Y2(1)=13
X1(2)=1 : X2(2)=74 : Y1(2)=14 : Y2(2)=17
X1(3)=1 : X2(3)=74 : Y1(3)=18 : Y2(3)=23
Return

$ON_CPY
Onevent CONTROL Call C_CPY(zc) From W1DLA2
Onevent AFTER_CHANGE Gosub AMM_CPY From W1DLA2
Onevent BEFORE_INPUT Call AS_CPY(zc) From W1DLA2
Return

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3529,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CPY(zc) From W1DLA2
Onkey   2 Titled GBOUTS Call S_CPY(zc) From W1DLA2
Onkey 144 Titled GBOUTP Call P_CPY(zc) From W1DLA2
Onkey 146 Titled GBOUTA Call SA_CPY(zc) From W1DLA2
Gosub _AFF
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
## Action ACONTCPY
Call CONTSOC(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CPY","!A",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 If !mkstat
  ## Action CONTCPYLEG
  Call CONTCPYLEG(VALEUR,GCURLEG) From TRTX3
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CPY
Call AM_CPY(zc)
If !mkstat & GOBJET
 zoncou = "CPY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CPY(VALEUR) From SUBDLA
If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCPY)")>indice
 [M]CPY(indice) = VALEUR
 Affzo ZCPY(indice)
Endif
Gosub _AFF
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCPYLEGH
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCPYLEGH"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCPYLEGH","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CPY(VALEUR)
Variable Char    VALEUR()
Call OBJET("CPY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1DLA2
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_CPYTEL
Onevent BEFORE_AREA Gosub AV_CPYTEL From W1DLA2
Onevent CONTROL Call C_CPYTEL(zc) From W1DLA2
Onevent AFTER_CHANGE Gosub AMM_CPYTEL From W1DLA2
Return

$AV_CPYTEL
## Action FMTTELPAY
Call FMTTELPAY([M]CPYCRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]CPYTEL(indice) With "K:"+GFMT
Else
 Chgfmt [M]CPYTEL(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_CPYTEL(VALEUR)
Variable Char    VALEUR()
## Action ACNTTEL
Call CONTTEL(VALEUR,[M]CPYCRY) From CONTNUM
If mkstat : GERR = 1 : GZONE = "CPYTEL" : GZNUM = 289 : Endif
Gosub _AFF
End

$AMM_CPYTEL
Call AM_CPYTEL(zc)
If !mkstat & GOBJET
 zoncou = "CPYTEL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPYTEL(VALEUR)
Variable Char    VALEUR()
## Action ACNTTELMOD
Call CONTTELMOD(VALEUR,[M]CPYCRY) From CONTNUM
If mkstat : GERR = 1 : GZONE = "CPYTEL" : GZNUM = 289 : Endif
Gosub _AFF
End

