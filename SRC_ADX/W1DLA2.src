Onevent AFTER_CHANGE Gosub AMM_CPYCTY From W1DLA2
Return

Subprog IB_CPYCTY(VALEUR)
Variable Char    VALEUR()
## Action ABOUTPLAN
Call BOUTPLAN From AVISUPLAN
Gosub _AFF
End

$AV_CPYCTY
## Action FMTCTYPAY
Call FMTCTYPAY([M]CPYCRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]CPYCTY(indice) With "K:"+GFMT
Else
 Chgfmt [M]CPYCTY(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_CPYCTY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(36871,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_CPYCTY(VALEUR)
## Action VILINI
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILINI"
Call S_AFF_CHAR(VALEUR,PARMSK,"INIVIL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat=2
 [M]CPYCTY(INDIC) = VALEUR
 Affzo CPYCTY(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CPYCTY(zc) From W1DLA2
Onkey   2 Titled GBOUTS Call S_CPYCTY(zc) From W1DLA2
Gosub _AFF
End

Subprog C_CPYCTY(VALEUR)
Variable Char    VALEUR()
## Action VILCNTOBL
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILCNTOBL"
PARMSK(1) = [M]CPYCRY
PARMSK(2) = "0"
Call S_AFF_CHAR(VALEUR,PARMSK,"VILCNTOBL","SUBPOS","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CPYCTY" : GZNUM = 0 : Endif
Gosub _AFF
End

$AMM_CPYCTY
Call AM_CPYCTY(zc)
If !mkstat & GOBJET
 zoncou = "CPYCTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPYCTY(VALEUR)
Variable Char    VALEUR()
## Action VILCONT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "VILCONT"
PARMSK(1) = [M]CPYCRY
PARMSK(2) = [M]CPYPOSCOD
PARMSK(3) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"VILCONT","SUBPOS","") From GACTION
[M]CPYPOSCOD = PARMSK(2)
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CPYCTY" : GZNUM = 0 : Endif
If !mkstat
 ## Action SELPOS2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOS2"
 PARMSK(1) = [M]CPYCRY
 PARMSK(2) = [M]CPYPOSCOD
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS2","SUBPOS","") From GACTION
 [M]CPYPOSCOD = PARMSK(2)
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPYCTY" : GZNUM = 0 : Endif
 If !mkstat
  ## Action AFFPOSCOD
  If !mkstat & !GIMPORT : Affzo [M]CPYPOSCOD : Endif
  If mkstat : GERR = 1 : GZONE = "CPYCTY" : GZNUM = 0 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CPYCTY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTY
