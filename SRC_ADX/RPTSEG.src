#<AdxTL>@(#)6.0.0.0 $Revision$

$ACTION
Case ACTION
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
Endcase
Return

$INIT_DIA
[M:DIA]CODTYP = [M:RPT]PARTYP(nolign-1)
[M:DIA]LONG   = [M:RPT]LONG(nolign-1)
[M:DIA]NOLIB  = [M:RPT]NOLIB(nolign-1)
[M:DIA]NBLIG = [M:RPT]NBSEG
For I=0 To [M:RPT]NBSEG-1
 [M:DIA]VALEUR(I) = [M:RPT]VALSEG(I)
 [M:DIA]VALINT(I) = [M:RPT]VALSEG(I)
Next I
Return

$CONTROLE
For I=1 To [M:DIA]NBLIG-1
 If [M:DIA]VALEUR(I)<=[M:DIA]VALEUR(I-1)
  GERR = 1 : GMESSAGE = mess(9,135,1) : SAI = 1 : Break
 Endif
Next I
Return

$EXEC
[M:RPT]NBSEG = [M:DIA]NBLIG
For I=0 To [M:RPT]NBSEG-1
 [M:RPT]VALSEG(I) = [M:DIA]VALINT(I)
Next I
Return

