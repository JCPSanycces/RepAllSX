GOK = 1

For [ADI] Where NUMTAB=15
  NBLUS+=1
  Gosub RAZ_TSC

   # --- alimentation des champs et écriture enreg
  Gosub MAJ30_TSC

  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR
      WriteB [F:TSC]
  #Else
  #    Write [F:TSC]
  #Endif
  If fstat
    # Issue 108760 - 2015-08-07 by MAE :
    #If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File TABEECSCH, Error ="-num$(fstat),1) From GESECRAN
    #Else
    #  Call ECR_TRACE("File TABEECSCH(EECSCH/LEG)"-[F:TSC]EECSCH-[F:TSC]LEG+", Error ="-num$(fstat),1) From GESECRAN
    #Endif
    GOK=0 : Break
  Endif

  NB+=1
Next

$FIN_BOUCLE_TSC
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TSC]
    If fstat
        Call ECR_TRACE("File TABEECSCH, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TSC : #on part sur rollback
    Endif
  #Endif

  If ERR
