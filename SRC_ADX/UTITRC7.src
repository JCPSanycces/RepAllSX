################################################
Subprog MAJ_TABEECNAT(DOSSIER)
Value Char DOSSIER

#MAE, bg 92194, si le code activité DEB n'est pas actif, pas de mise à jour de TABEECNAT
Local Integer ACTDEB
If clalev([F:ACV2])=0 Local File =DOSSIER+".ACTIV"   [ACV2]  Endif
Read [ACV2] CODACT="DEB"
If !fstat
  ACTDEB=[F:ACV2]FLACT
Else
  ACTDEB=1
Endif
If ACTDEB = 1  End : Endif    # hcb 92251

Gosub DEBVAR : # 86071

adxftl=10
adxwrb=10
NEWMOTEUR=1
Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TIME("TABEECNAT tables TEC Process : Update TEC") From DOSSUB
Call ECR_TRACE("TABEECNAT : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
Local File =DOSSIER+".ATABDIV"     [ADI]
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABEECNAT"   [TEC]


#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
Local Char TEXTE (80)

Call DEBTRANS From GLOCK

Raz NB
Trbegin [TEC]

Call RAZ_TABEECNAT(DOSSIER)

GOK = 1

For [ADI] Where NUMTAB=6
  NBLUS+=1
  Gosub RAZ_TEC

   # --- alimentation des champs et écriture enreg
  Gosub MAJ30_TEC

  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR
    WriteB [F:TEC]
  #Else
  #  Write [F:TEC]
  #Endif
  If fstat
    # Issue 108760 - 2015-08-07 by MAE :
    #If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File TABEECNAT, Error ="-num$(fstat),1) From GESECRAN
    #Else
    #  Call ECR_TRACE("File TABEECNAT(EECNAT/LEG)"-[F:TEC]EECNAT-[F:TEC]LEG+", Error ="-num$(fstat),1) From GESECRAN
    #Endif
    GOK=0 : Break
  Endif

  NB+=1
Next

$FIN_BOUCLE_TEC
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
    Flush [F:TEC]
    If fstat
        Call ECR_TRACE("File TABEECNAT, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TEC : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TEC
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif
Close Local File  [ADI]
Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TEC]  #Nature de transaction DEB
Close Local File  [ACV2]  #Table activ

Call ECR_TIME("TABEECNAT : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$RAZ_TEC
Raz[F:TEC]EECNAT
Raz[F:TEC]LEG
Raz[F:TEC]VALSTO
Raz[F:TEC]SOC
Raz[F:TEC]UPDUSR
Raz[F:TEC]UPDDAT
Raz[F:TEC]CREUSR
Raz[F:TEC]CREDAT
Return

################################################
$MAJ30_TEC

[F:TEC]EECNAT =[F:ADI]CODE
[F:TEC]LEG    =[F:ADI]LEG
If [F:ADI]N1=0
  [F:TEC]VALSTO =1
Else
  [F:TEC]VALSTO =[F:ADI]N1
Endif

[F:TEC]ENAFLG =2

Gosub MAJ_ATEXTRA_TEC

[F:TEC]UPDUSR = ""
[F:TEC]UPDDAT = [0/0/0]
[F:TEC]CREUSR=GUSER
[F:TEC]CREDAT=date$
Return

################################################
$MAJ_ATEXTRA_TEC
If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif

Local Char SAVELANGUE
Local Char WZONE
SAVELANGUE=GLANGUE

#-- Changement de format du Atextra

#---- Lecture du texte pour ATEXTRA avec niveau taxe et  leg='' --#
For [AX2] Where [F:AX2]CODFIC = 'ATABDIV' & [F:AX2]IDENT1='6' & [F:AX2]IDENT2 = [F:TEC]EECNAT & [F:AX2]TEXTE <> ""

  If WTRA = 2
   Call ECR_TRACE( ""  ,0) From GESECRAN
   Call ECR_TRACE( "lecture atextra pour ATABDIV" - [F:AX2]ZONE - [F:AX2]LANGUE - '1' - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
  Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour régime taxe et  leg que si le texte n'est pas deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABEECNAT";[F:AX2]ZONE;GLANGUE;[F:TEC]EECNAT;[F:TEC]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
    If WTRA = 2
     Call ECR_TRACE( "TABEECNAT" - [F:AXX]ZONE - GLANGUE - [F:TVI]EECNAT - [F:TEC]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
    Endif
  Else
   WZONE=''
   If [F:AX2]ZONE='LNGDES' : WZONE='DESAXX' : Endif
   If [F:AX2]ZONE='SHODES' : WZONE='SHOAXX' : Endif
   If WTRA = 2
    Call ECR_TRACE( "TABEECNAT" - WZONE - GLANGUE - [F:TEC]EECNAT - [F:TEC]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABEECNAT",WZONE,[F:TEC]EECNAT,[F:TEC]LEG) From ATEXTRA
   Call SUPTEXLAN("ATABDIV",[F:AX2]ZONE,GLANGUE,"6",[F:TEC]EECNAT) From ATEXTRA #gbn-98885
  Endif

Next

GLANGUE=SAVELANGUE
Return


################################################
################################################
