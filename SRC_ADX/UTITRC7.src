End

################################################
$RAZ_TSC
Raz[F:TSC]EECSCH
Raz[F:TSC]EECSCH
Raz[F:TSC]VALSTO
Raz[F:TSC]FLUX
Raz[F:TSC]UPDUSR
Raz[F:TSC]UPDDAT
Raz[F:TSC]LEG
Raz[F:TSC]CREUSR
Raz[F:TSC]CREDAT
Return

################################################
$MAJ30_TSC
[F:TSC]EECSCH =[F:ADI]CODE
[F:TSC]LEG    =[F:ADI]LEG
[F:TSC]FLUX   =[F:ADI]N1
If [F:ADI]N2=0
  [F:TSC]VALSTO =1
Else
  [F:TSC]VALSTO =[F:ADI]N2
Endif
[F:TSC]ENAFLG =2

Gosub MAJ_ATEXTRA_TSC

[F:TSC]UPDUSR = ""
[F:TSC]UPDDAT = [0/0/0]
[F:TSC]CREUSR=GUSER
[F:TSC]CREDAT=date$
Return


################################################
$MAJ_ATEXTRA_TSC
If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif

Local Char SAVELANGUE
Local Char WZONE
SAVELANGUE=GLANGUE

#---- Lecture du texte pour ATEXTRA avec niveau taxe et  leg='' --#
For [AX2] Where [F:AX2]CODFIC = 'ATABDIV' & [F:AX2]IDENT1='15' & [F:AX2]IDENT2 = [F:TSC]EECSCH & [F:AX2]TEXTE <> ""

  If WTRA = 2
   Call ECR_TRACE( ""  ,0) From GESECRAN
   Call ECR_TRACE( "lecture atextra pour ATABDIV" - [F:AX2]ZONE - [F:AX2]LANGUE - '1' - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
  Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour régime taxe et  leg que si le texte n'est pas deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABEECSCH";[F:AX2]ZONE;GLANGUE;[F:TSC]EECSCH;[F:TSC]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
    If WTRA = 2
     Call ECR_TRACE( "TABEECSCH" - [F:AXX]ZONE - GLANGUE - [F:TVI]EECSCH - [F:TSC]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
    Endif
  Else
   WZONE=''
   If [F:AX2]ZONE='LNGDES' : WZONE='DESAXX' : Endif
   If [F:AX2]ZONE='SHODES' : WZONE='SHOAXX' : Endif
   If WTRA = 2
    Call ECR_TRACE( "TABEECSCH" - WZONE - GLANGUE - [F:TSC]EECSCH - [F:TSC]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABEECSCH",WZONE,[F:TSC]EECSCH,[F:TSC]LEG) From ATEXTRA
   Call SUPTEXLAN("ATABDIV",[F:AX2]ZONE,GLANGUE,"15",[F:TSC]EECSCH) From ATEXTRA #gbn-98885
  Endif

Next

GLANGUE=SAVELANGUE
Return

