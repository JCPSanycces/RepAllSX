#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
#   Migration de la table TABDIV       Module TC         #
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif

If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTITRC7") From LECFIC
  Endif

  Gosub TRT_MAJ

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

################################################
$MAJ_COMMIT
 Commit
 #Rollback
Return


################################################
$TRT_MAJ

  #-----------------------------------------------------------------------------------------------------#
  #-- Ce traitement effectue les migrations des tables gérées ci-dessous   -----------------------------#
  #-- Ce traitement s'execute automatiquement chaque jour sur les dossiers applicatifs V7 --------------#
  #-- En consequence , ces appels doivent restés en commentaires sauf si l'on veut expressement  -------#
  #-- effectuer la migration d'une table . Auquel cas , on decommente la ligne puis on fait le        --#
  #-- pouss-pouss puis le lendemain, si migration OK, on recommente et on annule la modification dans --#
  #-- le pouss-pouss.                                                                                 --#
  #-----------------------------------------------------------------------------------------------------#

  #-- Table TABVACBPR
  #Call RAZ_TABVACBPR(DOSSIER)
  #Call MAJ_TABVACBPR(DOSSIER)          : #--- Tabdiv 1 --> Table Régime Taxe      : Maj TABVACBPR + ATEXTRA

  #-- Table TABVACITM
  #Call RAZ_TABVACITM(DOSSIER)
  #Call MAJ_TABVACITM(DOSSIER)          : #--- Tabdiv 2 --> Table Niveau Taxe      : Maj TABVACITM + ATEXTRA

  #-- Table TABVAT
  #Call MAJ_TABVAT(DOSSIER)             : #--- Table des taxes                     : Maj uniquement de ATEXTRA

  #-- Table TABVAC
  #Call MAJ_TABVAC(DOSSIER)             : #--- Table Détermination Taxe            : Maj uniquement de ATEXTRA

  #-- Table TABSIVTYP
  #Call MAJ_TABSIVTYP(DOSSIER)          : #--- Table Type Facture Ventes           : Maj uniquement de ATEXTRA

  #-- Table TABPAYTERM
  #Call MAJ_TABPAYTERM(DOSSIER)         : #--- Table Condition paiement            : Maj uniquement de ATEXTRA

  #-- Table TABPAM
  #Call RAZ_TABPAM(DOSSIER)
  #Call MAJ_TABPAM(DOSSIER)             : #--- Tabdiv 3 --> Tab Mode de réglement  : Maj TABPAM + ATEXTRA

  #-- Table TABEECNAT
  #Call MAJ_TABEECNAT(DOSSIER)          : #--- Tabdiv 6 --> Tab Nature transac DEB : Maj TABEECNAT + ATEXTRA

  #-- Table TABEECSCH
  #Call MAJ_TABEECSCH(DOSSIER)          : #--- Tabdiv 15 -> Tab Régime statist DEB : Maj TABEECSCH + ATEXTRA

  #-- Table TABCODEDT
  #Call RAZ_TABCODEDT(DOSSIER)
  #Call MAJ_TABCODEDT(DOSSIER)

  #-- Table TABPIVTYP
  #Call MAJ_TABPIVTYP(DOSSIER)          : #--- Table Table types facture fourniss. : Maj uniquement de ATEXTRA
  #
Return


################################################
$DEBVAR
 Local Integer WTRA
 WTRA=1                : #-- 2 --> Affiche trace
Return

################################################
Subprog MAJ_TABVACBPR(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR : # 86071

adxftl=10
adxwrb=10
NEWMOTEUR=1

Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABVACBPR tables TVB Process : Update TVB") From DOSSUB
Call ECR_TRACE("TABVACBPR : Process Start on : "+DOSSIER,0) From GESECRAN


#----- Ouverture des fichiers -----#
#If clalev([F:ADI]) = 0 : Local File =DOSSIER+".ATABDIV"     [ADI] : Endif   #
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif
#If clalev([F:TVB]) = 0 : Local File =DOSSIER+".TABVACBPR"   [TVB] : Endif   # Régime de taxes
Local File =DOSSIER+".ATABDIV"     [ADI]
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABVACBPR"   [TVB] :# Régime de taxes

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
Local Char TEXTE (80)


Call DEBTRANS From GLOCK

Raz NB
Trbegin [TVB]
GOK = 1

For [ADI] Where NUMTAB=1
  NBLUS+=1
  Gosub RAZ_TVB

   # --- alimentation des champs et écriture enreg
  Gosub MAJ30_TVB

  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR
      WriteB [F:TVB]
  #Else
  #    Write [F:TVB]
  #Endif
  If fstat
    # Issue 108760 - 2015-08-07 by MAE :
    #If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File TABVACBPR, Error ="-num$(fstat),1) From GESECRAN
    #Else
    #  Call ECR_TRACE("File TABVACBPR(VACBPR/LEG)"-[F:TVB]VACBPR-[F:TVB]LEG+", Error ="-num$(fstat),1) From GESECRAN
    #Endif
    GOK=0 : Break
  Endif

  NB+=1
Next

$FIN_BOUCLE
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TVB]
    If fstat
        Call ECR_TRACE("File TABVACBPR, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif


Close Local File  [ADI]
Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TVB]  # Régime de taxes


Call ECR_TIME("TABVACBPR : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$RAZ_TVB
Raz[F:TVB]VAT
Raz[F:TVB]VACBPR
Raz[F:TVB]UPDUSR
Raz[F:TVB]UPDDAT
Raz[F:TVB]TYP
Raz[F:TVB]SALCLA
Raz[F:TVB]REGVAC
Raz[F:TVB]LEG
Raz[F:TVB]LANDESSHO
Raz[F:TVB]SOC
Raz [F:TVB]ENAFLG
Raz[F:TVB]CREUSR
Raz[F:TVB]CREDAT
Return
################################################
$MAJ30_TVB
[F:TVB]VAT=[F:ADI]A1
[F:TVB]VACBPR=[F:ADI]CODE
[F:TVB]TYP=[F:ADI]N2    #type
[F:TVB]LEG=[F:ADI]LEG   #législation
[F:TVB]SOC=[F:ADI]SOC   #gpe de soc
[F:TVB]SALCLA=[F:ADI]A2
[F:TVB]REGVAC=[F:ADI]N1 #type de régime
If [F:TVB]REGVAC=0 [F:TVB]REGVAC=1 Endif

Gosub MAJ_ATEXTRA_TVB

#Flag actif
[F:TVB]ENAFLG = 2

[F:TVB]UPDUSR = ""
[F:TVB]UPDDAT = [0/0/0]
[F:TVB]CREUSR=GUSER
[F:TVB]CREDAT=date$

Return
################################################
$MAJ_ATEXTRA_TVB
If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif

Local Char SAVELANGUE
Local Char WZONE
SAVELANGUE=GLANGUE

#-- Changement de format du Atextra
If WTRA = 2
 Call ECR_TRACE( "deb VACBPR" - [F:TVB]VACBPR - [F:TVB]LEG  ,0) From GESECRAN
Endif

#---- Lecture du texte pour ATEXTRA avec niveau taxe et  leg='' --#
For [AX2] Where [F:AX2]CODFIC = 'ATABDIV' & [F:AX2]IDENT1='1' & [F:AX2]IDENT2 = [F:TVB]VACBPR & [F:AX2]TEXTE <> ""

  If WTRA = 2
   Call ECR_TRACE( ""  ,0) From GESECRAN
   Call ECR_TRACE( "lecture atextra pour ATABDIV" - [F:AX2]ZONE - [F:AX2]LANGUE - '1' - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
  Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour régime taxe et  leg que si le texte n'est pas deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABVACBPR";[F:AX2]ZONE;GLANGUE;[F:TVB]VACBPR;[F:TVB]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
    If WTRA = 2
     Call ECR_TRACE( "TABVACBPR" - [F:AXX]ZONE - GLANGUE - [F:TVI]VACBPR - [F:TVB]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
    Endif
  Else
   WZONE=''
   If [F:AX2]ZONE='LNGDES' : WZONE='DESAXX' : Endif
   If [F:AX2]ZONE='SHODES' : WZONE='SHOAXX' : Endif
   If WTRA = 2
    Call ECR_TRACE( "TABVACBPR" - WZONE - GLANGUE - [F:TVB]VACBPR - [F:TVB]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABVACBPR",WZONE,[F:TVB]VACBPR,[F:TVB]LEG) From ATEXTRA
   Call SUPTEXLAN("ATABDIV",[F:AX2]ZONE,GLANGUE,'1',[F:TVB]VACBPR) From ATEXTRA #gbn-98885
  Endif

Next

GLANGUE=SAVELANGUE
Return

################################################
Subprog MAJ_TABVACITM(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR

adxftl=10
adxwrb=10
NEWMOTEUR=1
Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABVACITM tables TVI Process : Update TVI") From DOSSUB
Call ECR_TRACE("TABVACITM : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#If clalev([F:ADI]) = 0 : Local File =DOSSIER+".ATABDIV"     [ADI] : Endif   #
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:TVI]) = 0 : Local File =DOSSIER+".TABVACITM"   [TVI] : Endif   # Niveau de taxe
Local File =DOSSIER+".ATABDIV"     [ADI]
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABVACITM"   [TVI] :# Niveau de taxe

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
Local Char TEXTE (80)
Call DEBTRANS From GLOCK
Raz NB
Trbegin [TVI]
GOK = 1

For [ADI] Where NUMTAB=2
  NBLUS+=1
  Gosub RAZ_TVI

   #--- Alimentation des champs et écriture enreg
  Gosub MAJ30_TVI

  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR
      WriteB [F:TVI]
  #Else
  #    Write [F:TVI]
  #Endif
  Call ECR_TRACE("Maj File TABVACITM(VACITM/LEG)"-[F:TVI]VACITM-[F:TVI]LEG,0) From GESECRAN

  If fstat
    # Issue 108760 - 2015-08-07 by MAE :
    #If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File TABVACITM, Error ="-num$(fstat),1) From GESECRAN
    #Else
    #  Call ECR_TRACE("File TABVACITM(VACITM/LEG)"-[F:TVI]VACITM-[F:TVI]LEG+", Error ="-num$(fstat),1) From GESECRAN
    #Endif
    GOK=0 : Break
  Endif

  NB+=1
Next

$FIN_BOUCLE_TVI
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TVI]
    If fstat
        Call ECR_TRACE("File TABVACITM, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TVI : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TVI
  Endif

  Gosub MAJ_COMMIT

  NBCOMMIT+=NB
Endif
Close Local File  [ADI]
Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TVI]  # Niveau de taxe

Call ECR_TIME("TABVACITM : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$RAZ_TVI
Raz[F:TVI]VACITM
Raz[F:TVI]UPDUSR
Raz[F:TVI]UPDDAT
Raz[F:TVI]LEG
Raz[F:TVI]LANDESSHO
Raz[F:TVI]A1
Raz[F:TVI]A2
Raz[F:TVI]N1
Raz[F:TVI]N2
Raz[F:TVI]ENAFLG
Raz[F:TVI]SOC
Raz[F:TVI]CREUSR
Raz[F:TVI]CREDAT
Return


################################################
$MAJ30_TVI
[F:TVI]VACITM=[F:ADI]CODE
[F:TVI]LEG=[F:ADI]LEG
[F:TVI]A1=[F:ADI]A1
[F:TVI]A2=[F:ADI]A2
[F:TVI]N1=[F:ADI]N1
[F:TVI]N2=[F:ADI]N2
[F:TVI]ENAFLG=2
[F:TVI]SOC=[F:ADI]SOC

Gosub MAJ_ATEXTRA_TVI

[F:TVI]UPDUSR = ""
[F:TVI]UPDDAT = [0/0/0]
[F:TVI]CREUSR=GUSER
[F:TVI]CREDAT=date$

Return
################################################
$MAJ_ATEXTRA_TVI
If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif

Local Char SAVELANGUE
Local Char WZONE
SAVELANGUE=GLANGUE

#-- Changement de format du Atextra
If WTRA = 2
 Call ECR_TRACE( "deb VACITM" - [F:TVI]VACITM - [F:TVI]LEG  ,0) From GESECRAN
Endif

#---- Lecture du texte pour ATEXTRA avec niveau taxe et  leg='' --#
For [AX2] Where [F:AX2]CODFIC = 'ATABDIV' & [F:AX2]IDENT1='2' & [F:AX2]IDENT2 = [F:TVI]VACITM & [F:AX2]TEXTE <> ""

  If WTRA = 2
   Call ECR_TRACE( ""  ,0) From GESECRAN
   Call ECR_TRACE( "lecture atextra pour ATABDIV" - [F:AX2]ZONE - [F:AX2]LANGUE - '2' - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
  Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour niveau taxe et  leg que si le texte n'est pas deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABVACITM";[F:AX2]ZONE;GLANGUE;[F:TVI]VACITM;[F:TVI]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
    If WTRA = 2
     Call ECR_TRACE( "TABVACITM" - [F:AXX]ZONE - GLANGUE - [F:TVI]VACITM - [F:TVI]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
    Endif
  Else
   WZONE=''
   If [F:AX2]ZONE='LNGDES' : WZONE='DESAXX' : Endif
   If [F:AX2]ZONE='SHODES' : WZONE='SHOAXX' : Endif
   If WTRA = 2
    Call ECR_TRACE( "TABVACITM" - WZONE - GLANGUE - [F:TVI]VACITM - [F:TVI]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABVACITM",WZONE,[F:TVI]VACITM,[F:TVI]LEG) From ATEXTRA
   Call SUPTEXLAN("ATABDIV",[F:AX2]ZONE,GLANGUE,'2',[F:TVI]VACITM) From ATEXTRA #gbn-98885
  Endif

Next

GLANGUE=SAVELANGUE
Return

#######################################################################
# S'il y a une législation dans TABVAC                                #
#  Création des intitulés de TABVAC dans ATEXTRA avec la législation  #
#  --> Pas de migration de TABVAC car LEG était déjà dans la table    #
#######################################################################
Subprog MAJ_TABVAC(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR

adxftl=10
adxwrb=10
NEWMOTEUR=1

Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABVAC tables TVC Process : Update ATEXTRA for TVC") From DOSSUB
Call ECR_TRACE("TABVAC : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif
#If clalev([F:TVC]) = 0 : Local File =DOSSIER+".TABVAC"      [TVC] : Endif   # Régime de taxes
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABVAC"    [TVC] :# Détermination des taxes

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
Local Char TEXTE (80)

Call DEBTRANS From GLOCK

Raz NB
Trbegin [AXX]
GOK = 1

Local Char SAVELANGUE
SAVELANGUE=GLANGUE
For [TVC] Where [F:TVC]LEG <> ''

 #---- Lecture du texte pour ATEXTRA avec code taxe et  leg='' --#
 For [AX2] Where [F:AX2]CODFIC = 'TABVAC' & [F:AX2]IDENT1=[F:TVC]COD & [F:AX2]IDENT2 = "" & [F:AX2]TEXTE <> ""

   If WTRA = 2
    Call ECR_TRACE( ""  ,0) From GESECRAN
    Call ECR_TRACE( "lecture atextra pour TABVAC" - [F:AX2]ZONE - [F:AX2]LANGUE - [F:AX2]IDENT1 - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour code taxe et  leg que si le texte n'est aps deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABVAC";[F:AX2]ZONE;GLANGUE;[F:TVC]COD;[F:TVC]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
   If WTRA = 2
    Call ECR_TRACE( "TABVAC" - [F:AXX]ZONE - GLANGUE - [F:TVC]COD - [F:TVC]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
  Else
   If WTRA = 2
    Call ECR_TRACE( "TABVAC" - [F:AX2]ZONE - GLANGUE - [F:TVC]COD - [F:TVC]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABVAC",[F:AX2]ZONE,[F:TVC]COD,[F:TVC]LEG) From ATEXTRA
   Call SUPTEXLAN("TABVAC",[F:AX2]ZONE,GLANGUE,[F:TVC]COD,"") From ATEXTRA #gbn-98885
  Endif

  NB+=1
 Next
Next

GLANGUE=SAVELANGUE

$FIN_BOUCLE_TVC
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TVC]
    If fstat
        Call ECR_TRACE("File TABVAC, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TVC : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TVC
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif

Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TVC]

Call ECR_TIME("TABVAC : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

#######################################################################
# S'il y a une législation dans TABVAT                                #
#  Création des intitulés de TABVAT dans ATEXTRA avec la législation  #
#  --> Pas de migration de TABVAT car LEG était déjà dans la table    #
#######################################################################
Subprog MAJ_TABVAT(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR

adxftl=10
adxwrb=10
NEWMOTEUR=1

Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABVAT tables TVT Process : Update ATEXTRA for TVT") From DOSSUB
Call ECR_TRACE("TABVAT : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif
#If clalev([F:TVT]) = 0 :# Local File =DOSSIER+".TABVAT"      [TVT] : Endif   # Table des taxes
#If clalev([F:TRA]) = 0 : Local File =DOSSIER+".TABRATVAT"   [TRA] : Endif   # Table des taux de taxes
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABVAT"    [TVT] :# Table des taxes
Local File =DOSSIER+".TABRATVAT"   [TRA] :# Table des taux de taxes

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS

Call DEBTRANS From GLOCK

Raz NB
Trbegin [AXX]
GOK = 1

Local Char SAVELANGUE
SAVELANGUE=GLANGUE
For [TVT] Where [F:TVT]LEG <> ''

 NBLUS += 1
 #---- Alimentation du champ LEG des enreg TABRATVAT correspondant au code taxe courant --#

 Update [F:TRA] Where [F:TRA]VAT=[F:TVT]VAT With LEG=[F:TVT]LEG
 If fstat=0
   If WTRA = 2
    Call ECR_TRACE( "TABRATVAT" - [F:TVT]VAT - [F:TVT]LEG -  '--> LEG Field update with the TABVAT LEG field value '  ,0) From GESECRAN
   Endif
 Else
  Call ECR_TRACE( "TABRATVAT" - [F:TVT]VAT - [F:TVT]LEG -  '--> Update error'-num$(fstat)  ,1) From GESECRAN
  GOK=0
 Endif

 #---- Lecture du texte pour ATEXTRA avec code taxe et  leg='' --#
 For [AX2] Where [F:AX2]CODFIC = 'TABVAT' & [F:AX2]IDENT1=[F:TVT]VAT & [F:AX2]IDENT2 = "" & [F:AX2]TEXTE <> ""

   If WTRA = 2
    Call ECR_TRACE( ""  ,0) From GESECRAN
    Call ECR_TRACE( "Read ATEXTRA table for TABVAT" - [F:AX2]ZONE - [F:AX2]LANGUE - [F:AX2]IDENT1 - [F:AX2]IDENT2  - '--> text : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour code taxe et  leg que si le texte n'est pas deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  Read [AXX]AXX0 = "TABVAT";[F:AX2]ZONE;GLANGUE;[F:TVT]VAT;[F:TVT]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
   If WTRA = 2
    Call ECR_TRACE( "TABVAT" - [F:AXX]ZONE - GLANGUE - [F:TVT]VAT - [F:TVT]LEG -  '--> The following text already exists :' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
  Else
   If WTRA = 2
    Call ECR_TRACE( "TABVAT" - [F:AX2]ZONE - GLANGUE - [F:TVT]VAT - [F:TVT]LEG  - '--> New text update : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABVAT",[F:AX2]ZONE,[F:TVT]VAT,[F:TVT]LEG) From ATEXTRA
   Call SUPTEXLAN("TABVAT",[F:AX2]ZONE,GLANGUE,[F:TVT]VAT,"") From ATEXTRA #gbn-98885
  Endif

  NB+=1
 Next
Next

GLANGUE=SAVELANGUE

$FIN_BOUCLE_TVT
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TVT]
    If fstat
        Call ECR_TRACE("File TABVAT, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TVT : #on part sur rollback
    Endif
  #Endif
  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TVT
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif

Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TVT]
Close Local File  [TRA]


Call ECR_TIME("TABVAT : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
Subprog MAJ_TABPAM(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR : # 86071

adxftl=10
adxwrb=10
NEWMOTEUR=1

Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABPAM tables TAM Process : Update TAM") From DOSSUB
Call ECR_TRACE("TABPAM : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#If clalev([F:ADI]) = 0 : Local File =DOSSIER+".ATABDIV"     [ADI] : Endif   #
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:TAM]) = 0 : Local File =DOSSIER+".TABPAM"      [TAM] : Endif   # Niveau de taxe
Local File =DOSSIER+".ATABDIV"     [ADI]
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABPAM"      [TAM]

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
Local Char TEXTE (80)
Call DEBTRANS From GLOCK
Raz NB
Trbegin [TAM]
GOK = 1

For [ADI] Where NUMTAB=3
  NBLUS+=1
  Gosub RAZ_TAM

   # --- alimentation des champs et écriture enreg
  Gosub MAJ30_TAM

  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR
      WriteB [F:TAM]
  #Else
  #    Write [F:TAM]
  #Endif
  If fstat
    # Issue 108760 - 2015-08-07 by MAE :
    #If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File TABPAM, Error ="-num$(fstat),1) From GESECRAN
    #Else
    #  Call ECR_TRACE("File TABPAM(PAM/LEG)"-[F:TAM]PAM-[F:TAM]LEG+", Error ="-num$(fstat),1) From GESECRAN
    #Endif
    GOK=0 : Break
  Endif

  NB+=1
Next

$FIN_BOUCLE_TAM
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TAM]
    If fstat
        Call ECR_TRACE("File TABPAM, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TAM : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TAM
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif
Close Local File  [ADI]
Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TAM]  # Mode de réglement

Call ECR_TIME("TABPAM : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$RAZ_TAM
Raz[F:TAM]PAM
Raz[F:TAM]SOI
Raz[F:TAM]ACCEPT
Raz[F:TAM]PAPTRT
Raz[F:TAM]TYP
Raz[F:TAM]UPDUSR
Raz[F:TAM]UPDDAT
Raz[F:TAM]LEG
Raz[F:TAM]CREUSR
Raz[F:TAM]CREDAT
Return
################################################
$MAJ30_TAM
[F:TAM]PAM=[F:ADI]CODE
[F:TAM]LEG=[F:ADI]LEG
[F:TAM]SOI=[F:ADI]A1
[F:TAM]ACCEPT=[F:ADI]A2
If [F:ADI]N1=2
 [F:TAM]PAPTRT=2
Else
 [F:TAM]PAPTRT=1
Endif
[F:TAM]TYP=[F:ADI]N2
#champ DESAXX
Call LECTEXTRA (TEXTE,"ATABDIV","LNGDES","3",[F:ADI]CODE) From ATEXTRA
Call MAJTEXTRA (TEXTE,"TABPAM","DESAXX",[F:TAM]PAM,[F:TAM]LEG) From ATEXTRA
Call SUPTEXTRA("ATABDIV","LNGDES","3",[F:TAM]PAM) From ATEXTRA #gbn-98885
#champ SHOAXX
Raz TEXTE
Call LECTEXTRA (TEXTE,"ATABDIV","SHODES","3",[F:ADI]CODE) From ATEXTRA
Call MAJTEXTRA (TEXTE,"TABPAM","SHOAXX",[F:TAM]PAM,[F:TAM]LEG) From ATEXTRA
Call SUPTEXTRA("ATABDIV","SHODES","3",[F:TAM]PAM) From ATEXTRA #gbn-98885
[F:TAM]UPDUSR = ""
[F:TAM]UPDDAT = [0/0/0]
[F:TAM]CREUSR=GUSER
[F:TAM]CREDAT=date$
Return

