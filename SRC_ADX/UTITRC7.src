Raz[F:TED]CODEDT
Raz[F:TED]TRT
Raz[F:TED]UPDUSR
Raz[F:TED]UPDDAT
Raz[F:TED]LEG
Raz[F:TED]CREUSR
Raz[F:TED]CREDAT
Return
################################################
$MAJ30_TED
[F:TED]CODEDT=[F:ADI]CODE
[F:TED]LEG=[F:ADI]LEG
[F:TED]TRT=[F:ADI]A1
#champ DESAXX
Call LECTEXTRA (TEXTE,"ATABDIV","LNGDES","304",[F:ADI]CODE) From ATEXTRA
Call MAJTEXTRA (TEXTE,"TABCODEDT","DESAXX",[F:TED]CODEDT,[F:TED]LEG) From ATEXTRA
Call SUPTEXTRA("ATABDIV","LNGDES","304",[F:TED]CODEDT) From ATEXTRA #gbn-98885
#champ SHOAXX
Raz TEXTE
Call LECTEXTRA (TEXTE,"ATABDIV","SHODES","304",[F:ADI]CODE) From ATEXTRA
Call MAJTEXTRA (TEXTE,"TABCODEDT","SHOAXX",[F:TED]CODEDT,[F:TED]LEG) From ATEXTRA
Call SUPTEXTRA("ATABDIV","SHODES","304",[F:TED]CODEDT) From ATEXTRA #gbn-98885
[F:TED]UPDUSR = ""
[F:TED]UPDDAT = [0/0/0]
[F:TED]CREUSR=GUSER
[F:TED]CREDAT=date$
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-08-07 by MAE :
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Local Char DOSSIER(30)
DOSSIER=APPLI
# Issue 108760 - 2015-08-07 by MAE :
If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TABVACBPR","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TABVACITM","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TABPAM","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TABEECNAT","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TABEECSCH","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","TABCODEDT","fde",APPLI),0)<=0 : End : Endif
If func DOSVUE.ISVIEW(APPLI,"ATABDIV") : End : Endif
If func DOSVUE.ISVIEW(APPLI,"ATEXTRA") : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABVACBPR") : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABVACITM") : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABPAM") : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABEECNAT") : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABEECSCH") : End : Endif
If func DOSVUE.ISVIEW(APPLI,"TABCODEDT") : End : Endif
Gosub TRT_MAJ

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif

Local Char DOSSIER(30)
DOSSIER=APPLI
#Gosub TRT_MAJ

End

#######################################################################
# Pour relancer la moulinette
########################################################################
Subprog RAZ_TABVACBPR (APPLI)

Value Char    APPLI
#If APPLI=GDOSX3 End : Endif
#If clalev([F:AXX]) = 0 :Local File =[F:ADS]DOSSIER+".ATEXTRA"     [AXX]  : Endif
#If clalev([F:TVB]) = 0 : Local File =APPLI+".TABVACBPR"   [TVB] : Endif   # Régime de taxes

Local File =APPLI+".TABVACBPR"   [TVB]

For [TVB] Where VACBPR<> ""
    Call SUPTEXTRA ("TABVACBPR","SHOAXX",[F:TVB]VACBPR,[F:TVB]LEG) From ATEXTRA
    Call SUPTEXTRA ("TABVACBPR","DESAXX",[F:TVB]VACBPR,[F:TVB]LEG) From ATEXTRA
Next

Trbegin [TVB]

Delete [TVB] Where VACBPR<>""
    If fstat
        Call ECR_TRACE("File TABVACBPR, Error ="-num$(fstat),1) From GESECRAN
        Rollback
    Else
        Gosub MAJ_COMMIT
    Endif

Close Local File  [TVB]  # Régime de taxes

End

