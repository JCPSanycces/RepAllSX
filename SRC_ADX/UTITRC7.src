Call DEBTRANS From GLOCK

Raz NB
Trbegin [AXX]
GOK = 1

Local Char SAVELANGUE
SAVELANGUE=GLANGUE
For [TPV] Where [F:TPV]LEG <> ''

 #---- Lecture du texte pour ATEXTRA avec code taxe et  leg='' --#
 For [AX2] Where [F:AX2]CODFIC = 'TABPIVTYP' & [F:AX2]IDENT1=[F:TPV]PIVTYP & [F:AX2]IDENT2 = "" & [F:AX2]TEXTE <> ""

   If WTRA = 2
    Call ECR_TRACE( ""  ,0) From GESECRAN
    Call ECR_TRACE( "lecture atextra pour TABPIVTYP" - [F:AX2]ZONE - [F:AX2]LANGUE - [F:AX2]IDENT1 - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour code taxe et  leg que si le texte n'est aps deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABPIVTYP";[F:AX2]ZONE;GLANGUE;[F:TPV]PIVTYP;[F:TPV]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
   If WTRA = 2
    Call ECR_TRACE( "TABPIVTYP" - [F:AXX]ZONE - GLANGUE - [F:TPV]PIVTYP - [F:TPV]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
  Else
   If WTRA = 2
    Call ECR_TRACE( "TABPIVTYP" - [F:AX2]ZONE - GLANGUE - [F:TPV]PIVTYP - [F:TPV]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABPIVTYP",[F:AX2]ZONE,[F:TPV]PIVTYP,[F:TPV]LEG) From ATEXTRA
   Call SUPTEXLAN("TABPIVTYP",[F:AX2]ZONE,GLANGUE,[F:TPV]PIVTYP,"") From ATEXTRA #gbn-98885
  Endif

  NB+=1
 Next
Next

GLANGUE=SAVELANGUE

$FIN_BOUCLE_TPV
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TPV]
    If fstat
        Call ECR_TRACE("File TABPIVTYP, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TPV : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TPV
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif

Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TPV]


Call ECR_TIME("TABPIVTYP : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

