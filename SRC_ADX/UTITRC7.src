##########################################################################
# S'il y a une législation dans TABSIVTYP                                #
#  Création des intitulés de TABSIVTYP dans ATEXTRA avec la législation  #
#  --> Pas de migration de TABSIVTYP car LEG était déjà dans la table    #
##########################################################################
Subprog MAJ_TABSIVTYP(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR

adxftl=10
adxwrb=10
NEWMOTEUR=1

Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABSIVTYP tables TSV Process : Update ATEXTRA for TSV") From DOSSUB
Call ECR_TRACE("TABSIVTYP : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif
#If clalev([F:TSV]) = 0 : Local File =DOSSIER+".TABSIVTYP"   [TSV] : Endif   # Régime de taxes
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABSIVTYP"   [TSV] :# Types factures ventes

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
Local Char TEXTE (80)

Call DEBTRANS From GLOCK

Raz NB
Trbegin [AXX]
GOK = 1

Local Char SAVELANGUE
SAVELANGUE=GLANGUE
For [TSV] Where [F:TSV]LEG <> ''

 #---- Lecture du texte pour ATEXTRA avec code taxe et  leg='' --#
 For [AX2] Where [F:AX2]CODFIC = 'TABSIVTYP' & [F:AX2]IDENT1=[F:TSV]SIVTYP & [F:AX2]IDENT2 = "" & [F:AX2]TEXTE <> ""

   If WTRA = 2
    Call ECR_TRACE( ""  ,0) From GESECRAN
    Call ECR_TRACE( "lecture atextra pour TABSIVTYP" - [F:AX2]ZONE - [F:AX2]LANGUE - [F:AX2]IDENT1 - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour code taxe et  leg que si le texte n'est aps deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABSIVTYP";[F:AX2]ZONE;GLANGUE;[F:TSV]SIVTYP;[F:TSV]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
   If WTRA = 2
    Call ECR_TRACE( "TABSIVTYP" - [F:AXX]ZONE - GLANGUE - [F:TSV]SIVTYP - [F:TSV]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
  Else
   If WTRA = 2
    Call ECR_TRACE( "TABSIVTYP" - [F:AX2]ZONE - GLANGUE - [F:TSV]SIVTYP - [F:TSV]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABSIVTYP",[F:AX2]ZONE,[F:TSV]SIVTYP,[F:TSV]LEG) From ATEXTRA
   Call SUPTEXLAN("TABSIVTYP",[F:AX2]ZONE,GLANGUE,[F:TSV]SIVTYP,"") From ATEXTRA #gbn-98885
  Endif

  NB+=1
 Next
Next

GLANGUE=SAVELANGUE

$FIN_BOUCLE_TSV
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TSV]
    If fstat
        Call ECR_TRACE("File TABSIVTYP, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TSV : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TSV
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif

Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TSV]


Call ECR_TIME("TABSIVTYP : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

##########################################################################
# S'il y a une législation dans TABPAYTERM                                #
#  Création des intitulés de TABPAYTERM dans ATEXTRA avec la législation  #
#  --> Pas de migration de TABPAYTERM car LEG était déjà dans la table    #
##########################################################################
Subprog MAJ_TABPAYTERM(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR

adxftl=10
adxwrb=10
NEWMOTEUR=1

Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABPAYTERM tables TPT Process : Update ATEXTRA for TPT") From DOSSUB
Call ECR_TRACE("TABPAYTERM : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif
#If clalev([F:TPT]) = 0 : Local File =DOSSIER+".TABPAYTERM"  [TPT] : Endif   # Régime de taxes
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABPAYTERM"  [TPT] :# Types factures ventes

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
Local Char TEXTE (80)

Call DEBTRANS From GLOCK

Raz NB
Trbegin [AXX]
GOK = 1

Local Char SAVELANGUE
SAVELANGUE=GLANGUE
For [TPT] Where [F:TPT]LEG <> ''

 #---- Lecture du texte pour ATEXTRA avec code taxe et  leg='' --#
 For [AX2] Where [F:AX2]CODFIC = 'TABPAYTERM' & [F:AX2]IDENT1=[F:TPT]PTE & [F:AX2]IDENT2 = "" & [F:AX2]TEXTE <> ""

   If WTRA = 2
    Call ECR_TRACE( ""  ,0) From GESECRAN
    Call ECR_TRACE( "lecture atextra pour TABPAYTERM" - [F:AX2]ZONE - [F:AX2]LANGUE - [F:AX2]IDENT1 - [F:AX2]IDENT2  - '--> texte : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif

  #---- On va mettre a jour le texte trouvé ([F:AX2]TEXTE) pour code taxe et  leg que si le texte n'est aps deja saisi --#
  GLANGUE = [F:AX2]LANGUE
  TEXTE=''
  Read [AXX]AXX0 = "TABPAYTERM";[F:AX2]ZONE;GLANGUE;[F:TPT]PTE;[F:TPT]LEG
  #---- Si le texte existe deja pour la leg --> pas de maj
  If fstat=0
   If WTRA = 2
    Call ECR_TRACE( "TABPAYTERM" - [F:AXX]ZONE - GLANGUE - [F:TPT]PTE - [F:TPT]LEG -  '--> Le texte suivant existe déjà :' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
  Else
   If WTRA = 2
    Call ECR_TRACE( "TABPAYTERM" - [F:AX2]ZONE - GLANGUE - [F:TPT]PTE - [F:TPT]LEG  - '--> nouveau texte mis a jour : ' - [F:AX2]TEXTE  ,0) From GESECRAN
   Endif
   Call MAJTEXTRA ([F:AX2]TEXTE,"TABPAYTERM",[F:AX2]ZONE,[F:TPT]PTE,[F:TPT]LEG) From ATEXTRA
   Call SUPTEXLAN("TABPAYTERM",[F:AX2]ZONE,GLANGUE,[F:TPT]PTE,"") From ATEXTRA #gbn-98885
  Endif

  NB+=1
 Next
Next

GLANGUE=SAVELANGUE

$FIN_BOUCLE_TPT
If GOK<1
  Rollback
Else
  # Issue 108760 - 2015-08-07 by MAE :
  #If NEWMOTEUR & adxwrb>1
  Flush [F:TPT]
    If fstat
        Call ECR_TRACE("File TABPAYTERM, Error ="-num$(fstat),1) From GESECRAN
        GOK=0 : Goto FIN_BOUCLE_TPT : #on part sur rollback
    Endif
  #Endif

  If ERR
   GOK=-1 : Goto FIN_BOUCLE_TPT
  Endif
  Gosub MAJ_COMMIT
  NBCOMMIT+=NB
Endif

Close Local File  [AXX]
Close Local File  [AX2]
Close Local File  [TPT]


Call ECR_TIME("TABPAYTERM : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

##########################################################################
# S'il y a une législation dans TABPIVTYP                                #
#  Création des intitulés de TABPIVTYP dans ATEXTRA avec la législation  #
#  --> Pas de migration de TABPIVTYP car LEG était déjà dans la table    #
##########################################################################
Subprog MAJ_TABPIVTYP(DOSSIER)
Value Char DOSSIER

Gosub DEBVAR

adxftl=10
adxwrb=10
NEWMOTEUR=1

Local Integer ERR, NBCOMMIT,NBLUS

Call ECR_TIME("TABPIVTYP tables TPV Process : Update ATEXTRA for TPV") From DOSSUB
Call ECR_TRACE("TABPIVTYP : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
#If clalev([F:AXX]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AXX] : Endif
#If clalev([F:AX2]) = 0 : Local File =DOSSIER+".ATEXTRA"     [AX2] : Endif
#If clalev([F:TPV]) = 0 : Local File =DOSSIER+".TABPIVTYP"      [TPV] : Endif   # Régime de taxes
Local File =DOSSIER+".ATEXTRA"     [AXX]
Local File =DOSSIER+".ATEXTRA"     [AX2]
Local File =DOSSIER+".TABPIVTYP"   [TPV] :# Détermination des taxes

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NB
Local Char CRITERE(250)
Raz CRITERE, NBCOMMIT,NBLUS
