#<AdxTL>@(#)7.0.0.0 $Revision$
GBIDC1="" : GBIDC2=""
Raz GPILOBJ, GPILCOD
Call OBJET("AEX",GBIDC2,GBIDC3) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"   : Gosub SETBOUT 
 When "EXEBOUT"   : Gosub EXEBOUT  
 When default
Endcase
Return

#--------------------------------#  
# Désactivation bouton "Test"    #  
#--------------------------------#  
$SETBOUT  
Return  

#-------------------------------#  
# Après appui sur bouton "Test" #  
#-------------------------------#  
$EXEBOUT  
Return  

#############################################################################################
#    etiquettes 
#############################################################################################
Subprog AP_ZTXTREF(VALEUR)
Variable Char    VALEUR()
If [M]TXTREF <> 0
    Affzo [M]TXTREF
Endif
End

##########################################################################

Subprog AS_ZTXTREF(VALEUR)
Variable Char    VALEUR()
If [M]TXTREF <> 0
    mkstat =2
Endif
End




