#<AdxTL>@(#)4.0.0.0 $Revision$
###############################################################################
# UTITC44  Migration of customer and suppplier notes to new NOTE table on V7  #
# SYMEU :  August 2012                                                        #
# FGR   :  Repris 04/2014                                                     #
###############################################################################
Local Char DOSSIER(30) : DOSSIER = nomap

  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat THEN
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE(mess(45,9901,1)-mess(47,195,1)) From LECFIC  # Updating notes

    If [F:ADS]MODULE(8) = 2 Then
      Call MAJ_UTITC44(DOSSIER)
    Endif
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#############################
Subprog MAJ_UTITC44(DOSSIER)
Value Char DOSSIER

Local Integer NI
Local Integer NE
Local Integer COMPTEUR
Local Integer WNOT
Local Char WNOTA(250)
Local Integer INTGIDX
Local Char SKEY2(250)  # FGR 02/06/2014 : X3SUIVI100382 / X3SUIVI97632
Local Char SNTSCOD(250), SSTOFCY(250), SNTGCOD(250), SKEY(250) #119019

  Call ECR_TRACE("UTITC44 : Process Start on : "+DOSSIER,0) From GESECRAN
  # --------------------------------------------------------------------
  #----- Fichiers existent ? -----#
  If filinfo(filpath("FIL", "NOTE", "fde", DOSSIER), 0) <= 0 Then
    # Si la table n'est pas là, on ne fait rien
    End
  Endif
  If filinfo(filpath("FIL", "NOTCATEG", "fde", DOSSIER), 0) <= 0 Then
    # Si la table n'est pas là, on ne fait rien
    End
  Endif
  # --------------------------------------------------------------------
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER+".NOTE"       [NTS]
  Local File =DOSSIER+".NOTCATEG"   [NTG]
  Local File =DOSSIER+".TEXCLOB"    [TXC]
  Local File =DOSSIER+".BPCUSTOMER" [BPC]
  Local File =DOSSIER+".BPSUPPLIER" [BPS]
  Local File =DOSSIER+".APLSTD"     [AST]
  Local File =DOSSIER+".ATEXTRA"    [AXX]
  Local File =DOSSIER+".ATABIND"    [ATI]
  # --------------------------------------------------------------------
Local Char SNTGCOD_BPC(type([F:NTG]NTGCOD)-10)   # Client
Local Char SNTGCOD_BPP(type([F:NTG]NTGCOD)-10)   # Prospect
Local Char SNTGCOD_BPS(type([F:NTG]NTGCOD)-10)   # Fournisseur
  # --------------------------------------------------------------------
  INTGIDX = 0
  Read [ATI]CODIND="NOTCATEG";"NTG0"
  If fstat Then
    Raz [F:ATI]
  Endif
  If [F:ATI]DESCRIPT = "NTGCOD+NTGTYP" Then
    INTGIDX = 1  # Nouvel index
  Elsif [F:ATI]DESCRIPT = "NTGTYP+NTGCOD" Then
    INTGIDX = 2  # Ancien index
  Endif
  If INTGIDX = 0 Then
    # Cas où ça ne serait aucun index : on ne saurait pas lire ! Donc on sort
    End
  Endif
  # --------------------------------------------------------------------
  Raz COMPTEUR
  Call DEBTRANS From GLOCK
  GOK = 1
  TMP_ADXLOG = adxlog
  If !TMP_ADXLOG Then
    Trbegin [NTG]
  Endif
  # ---------------------------------------
  SNTGCOD_BPC = left$(toupper(ctrans(mess(78,117,1))),  type([F:NTG]NTGCOD)-10)    # Client
  SNTGCOD_BPP = left$(toupper(ctrans(mess(240,196,1))), type([F:NTG]NTGCOD)-10)    # Prospect
  SNTGCOD_BPS = left$(toupper(ctrans(mess(17,7,1))),    type([F:NTG]NTGCOD)-10)    # Fournisseur
  # ---------------------------------------
  # Customer note category
  #Read [F:NTG]NTG0=2;SNTGCOD_BPC
  If INTGIDX = 1 Then
    Read [F:NTG]NTG0=SNTGCOD_BPC;2
  Else
    Read [F:NTG]NTG0=2;SNTGCOD_BPC
  Endif
  If fstat Then
    Raz [F:NTG]
    [F:NTG]NTGTYP = 2
    [F:NTG]NTGCOD = SNTGCOD_BPC
    NE = 0
    For NI = 1,2,3,4,5,6,18,19,20,21,22,23,24,25,26   # Liste reprise de SUBNTG
      [F:NTG]FIE(NE) = 2
      [F:NTG]VCRTYP(NE) = NI
      NE += 1
    Next
    Write [F:NTG]
    If fstat Then
      GOK = 0
      Call ECR_TRACE(mess(13,100,1)-"NOTECATEG :" - num$([F:NTG]NTGTYP) - SNTGCOD_BPC - mess(78,117,1),1) From GESECRAN
      Call FSTA("NTG") From GLOCK
    Else
      #Call TRANSLATED_FIELD(78, 117, "NOTCATEG", "NTGDESAXX", GLONAX1, [F:NTG]NTGCOD, num$([F:NTG]NTGTYP))  # FGR 21/07/2015 : X3SUIVI106944
      #Call TRANSLATED_FIELD(78, 117, "NOTCATEG", "NTGSHOAXX", GLONAX3, [F:NTG]NTGCOD, num$([F:NTG]NTGTYP))  # FGR 21/07/2015 : X3SUIVI106944
      Call TRANSLATED_FIELD(78, 117, "NOTCATEG", "NTGDESAXX", GLONAX1, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)   # FGR 21/07/2015 : X3SUIVI106944
      Call TRANSLATED_FIELD(78, 117, "NOTCATEG", "NTGSHOAXX", GLONAX3, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)   # FGR 21/07/2015 : X3SUIVI106944

    Endif
  Endif
  # ---------------------------------------
  # Prospect note category
  If GOK Then
    #Read [F:NTG]NTG0=2;SNTGCOD_BPP
    If INTGIDX = 1 Then
      Read [F:NTG]NTG0=SNTGCOD_BPP;2
    Else
      Read [F:NTG]NTG0=2;SNTGCOD_BPP
    Endif
    If fstat
      Raz [F:NTG]
      [F:NTG]NTGTYP = 2
      [F:NTG]NTGCOD = SNTGCOD_BPP
      NE = 0
      For NI = 1,2,3,4,5,6,18,19,20,21,22,23,24,25,26   # Liste reprise de SUBNTG
        If NI = 1 or NI = 18 or NI = 19 or NI = 20 Then
          [F:NTG]FIE(NE) = 2 # Devis/tâches/appels/Rdv uniquement pour les prospects
        Else
          [F:NTG]FIE(NE) = 1 # Non pour les autres
        Endif
        [F:NTG]VCRTYP(NE) = NI
        NE += 1
      Next
      Write [F:NTG]
      If fstat Then
        GOK = 0
        Call ECR_TRACE(mess(13,100,1) - "NOTECATEG :" - num$([F:NTG]NTGTYP) - SNTGCOD_BPP - mess(240,196,1),1) From GESECRAN
        Call FSTA("NTG") From GLOCK
      Else
        #Call TRANSLATED_FIELD(240, 196, "NOTCATEG", "NTGDESAXX", GLONAX1, [F:NTG]NTGCOD, num$([F:NTG]NTGTYP))  # FGR 21/07/2015 : X3SUIVI106944
        #Call TRANSLATED_FIELD(240, 196, "NOTCATEG", "NTGSHOAXX", GLONAX3, [F:NTG]NTGCOD, num$([F:NTG]NTGTYP))  # FGR 21/07/2015 : X3SUIVI106944
        Call TRANSLATED_FIELD(240, 196, "NOTCATEG", "NTGDESAXX", GLONAX1, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)   # FGR 21/07/2015 : X3SUIVI106944
        Call TRANSLATED_FIELD(240, 196, "NOTCATEG", "NTGSHOAXX", GLONAX3, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)   # FGR 21/07/2015 : X3SUIVI106944

      Endif
    Endif
  Endif
  # ---------------------------------------
  # Supplier note category
  If GOK Then
    #Read [F:NTG]NTG0=3;SNTGCOD_BPS
    If INTGIDX = 1 Then
      Read [F:NTG]NTG0=SNTGCOD_BPS;3
    Else
      Read [F:NTG]NTG0=3;SNTGCOD_BPS
    Endif
    If fstat
      Raz [F:NTG]
      [F:NTG]NTGTYP = 3
      [F:NTG]NTGCOD = SNTGCOD_BPS
      NE = 0
      For NI = 7,8,9,10,11,12,13   # Liste reprise de SUBNTG
        [F:NTG]FIE(NE) = 2
        [F:NTG]VCRTYP(NE) = NI
        NE += 1
      Next
      Write [F:NTG]
      If fstat Then
        GOK = 0
        Call ECR_TRACE(mess(13,100,1) - "NOTECATEG :" - num$([F:NTG]NTGTYP) - SNTGCOD_BPS - mess(17,7,1),1) From GESECRAN
        Call FSTA("NTG") From GLOCK
      Else
        #Call TRANSLATED_FIELD(17, 7, "NOTCATEG", "NTGDESAXX", GLONAX1, [F:NTG]NTGCOD, num$([F:NTG]NTGTYP))  # FGR 21/07/2015 : X3SUIVI106944
        #Call TRANSLATED_FIELD(17, 7, "NOTCATEG", "NTGSHOAXX", GLONAX3, [F:NTG]NTGCOD, num$([F:NTG]NTGTYP))  # FGR 21/07/2015 : X3SUIVI106944
        Call TRANSLATED_FIELD(17, 7, "NOTCATEG", "NTGDESAXX", GLONAX1, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)   # FGR 21/07/2015 : X3SUIVI106944
        Call TRANSLATED_FIELD(17, 7, "NOTCATEG", "NTGSHOAXX", GLONAX3, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)   # FGR 21/07/2015 : X3SUIVI106944

      Endif
    Endif
  Endif

  #119019.sn
  #Note Category copy - product note type
  If GOK Then
    For [F:NTG] Where NTGTYP = 1 #Filter to only update 'Product' note type
      Call TRANSLATED_FIELD(18, 7, "NOTCATEG", "NTGDESAXX", GLONAX1, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)
      Call TRANSLATED_FIELD(18, 7, "NOTCATEG", "NTGSHOAXX", GLONAX3, num$([F:NTG]NTGTYP), [F:NTG]NTGCOD)
    Next
  Endif
  #119019.en

  # ---------------------------------------
  If !GOK Then
    Rollback
  Else
    Commit
  Endif

  # ---------------------------------------
  # Customer & Prospect Notes copy
  If GOK Then
    Raz COMPTEUR
    Call DEBTRANS From GLOCK
    Trbegin [NTS],[BPC],[BPS]
    For [F:BPC] Where BPCREM <> ""
      WNOTA = left$([F:BPC]BPCNUM,type([F:NTS]NTSCOD)-10)
      # ----------------------
      If [F:BPC]BPCTYP < 4 Then
        # FGR 02/06/2014 : X3SUIVI100382 / X3SUIVI97632
        #Read [F:NTS]NTS0=[F:BPC]BPCNUM;WNOTA;2;"";SNTGCOD_BPC
        SKEY2 = WNOTA + "~" + "2" + "~" + "" + "~" + SNTGCOD_BPC
        Read [F:NTS]NTS0=[F:BPC]BPCNUM;SKEY2
      Else
        # FGR 02/06/2014 : X3SUIVI100382 / X3SUIVI97632
        #Read [F:NTS]NTS0=[F:BPC]BPCNUM;WNOTA;2;"";SNTGCOD_BPP
        SKEY2 = WNOTA + "~" + "2" + "~" + "" + "~" + SNTGCOD_BPP
        Read [F:NTS]NTS0=[F:BPC]BPCNUM;SKEY2
      Endif
      If fstat Then
        Raz [F:NTS]
        #--------------------------
        [F:NTS]CODE = [F:BPC]BPCNUM
        [F:NTS]NTSCOD = WNOTA
        [F:NTS]NTGTYP = 2
        If [F:BPC]BPCTYP < 4 Then
          [F:NTS]NTGCOD = SNTGCOD_BPC                                        # Customer
        Else
          [F:NTS]NTGCOD = SNTGCOD_BPP                                        # Prospect
        Endif
        [F:NTS]AUTODISP = 2                                                  # Auto display
        [F:NTS]BPCNUM = [F:BPC]BPCNUM
        If [F:BPC]BPCTYP < 4 Then
          [F:NTS]EFFDAT = [F:BPC]BPCSNCDAT
        Else
          [F:NTS]EFFDAT = [F:BPC]CREDAT
        Endif
        [F:NTS]ENDDAT = gdat$(day(date$),month(date$),year(date$)+10)        # Valable 10 ans par défaut (?)
        [F:NTS]PRIORITY = 1
        [F:NTS]NOTE = [F:BPC]BPCREM
        #
        If dim([F:NTS]NTSCOD2) >= 0 Then
          [F:NTS]NTSCOD2 = [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD
        Endif
        Write [F:NTS]
        If fstat Then
          GOK = 0
          Call ECR_TRACE(mess(13,100,1) - "NOTE :" - [BPC]BPCNUM - WNOTA, 1) From GESECRAN
          Call FSTA("NTS") From GLOCK
          Break
        Else
          COMPTEUR += 1
          [F:BPC]BPCREM = ""
          Rewrite [BPC]
          # ----------------
          If [F:BPC]BPCTYP < 4 Then
            Call TRANSLATED_FIELD(78, 117, "NOTE", "NTSDESAXX", GLONAX1, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD)
            Call TRANSLATED_FIELD(78, 117, "NOTE", "NTSSHOAXX", GLONAX3, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD)
          Else
            Call TRANSLATED_FIELD(240, 196, "NOTE", "NTSDESAXX", GLONAX1, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD)
            Call TRANSLATED_FIELD(240, 196, "NOTE", "NTSSHOAXX", GLONAX3, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD)
          Endif
        Endif
      Endif
    Next
  Endif
  # ----------------------------------------
  If GOK Then # Supplier Notes copy
    For [F:BPS] Where BPSREM <> "" With Lock
      WNOTA = left$([F:BPS]BPSNUM,type([F:NTS]NTSCOD)-10)
      # ----------------------
      # FGR 02/06/2014 : X3SUIVI100382 / X3SUIVI97632
      #Read [F:NTS]NTS0=[F:BPS]BPSNUM;WNOTA;3;"";SNTGCOD_BPS
      SKEY2 = WNOTA + "~" + "3" + "~" + "" + "~" + SNTGCOD_BPS
      Read [F:NTS]NTS0=[F:BPS]BPSNUM;SKEY2
      If fstat Then
        Raz [F:NTS]
        #
        [F:NTS]CODE = [F:BPS]BPSNUM
        [F:NTS]NTSCOD = WNOTA
        [F:NTS]NTGTYP = 3
        [F:NTS]NTGCOD = SNTGCOD_BPS                                          # Fournisseur
        [F:NTS]AUTODISP = 2                                                  # Auto display
        [F:NTS]BPCNUM = [F:BPS]BPSNUM
        [F:NTS]EFFDAT = [F:BPS]CREDAT
        [F:NTS]ENDDAT = gdat$(day(date$),month(date$),year(date$)+10)        # Valable 10 ans par défaut (?)
        [F:NTS]PRIORITY = 1
        [F:NTS]NOTE = [F:BPS]BPSREM
        #
        If dim([F:NTS]NTSCOD2) >= 0 Then
          [F:NTS]NTSCOD2 = [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD
        Endif
        Write [F:NTS]
        If fstat Then
          GOK = 0
          Call ECR_TRACE(mess(13,100,1) - "NOTE :" - [BPS]BPSNUM - WNOTA, 1) From GESECRAN
          Call FSTA("NTS") From GLOCK
          Break
        Else
          COMPTEUR += 1
          [F:BPS]BPSREM = ""
          Rewrite [BPS]
          # ----------------
          Call TRANSLATED_FIELD(17, 7, "NOTE", "NTSDESAXX", GLONAX1, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD)
          Call TRANSLATED_FIELD(17, 7, "NOTE", "NTSSHOAXX", GLONAX3, [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD)
        Endif
      Endif
    Next
  Endif

  #119019.sn
  #Notes copy - product note type
  #Populate NTSCOD2 = [NTS]NTSCOD +"~"+ [NTS]NTGTYP +"~"+ [NTS]STOFCY +"~"+ [NTS]NTGCOD
  If GOK Then
    For [F:NTS] Where NTGTYP = 1 #Filter to only update 'Product' note type
      SNTSCOD = left$([F:NTS]NTSCOD,type([F:NTS]NTSCOD)-10)
      SSTOFCY = left$([F:NTS]STOFCY,type([F:NTS]STOFCY)-10)
      SNTGCOD = left$([F:NTS]NTGCOD,type([F:NTS]NTGCOD)-10)

      SKEY = SNTSCOD + "~" + "1" + "~" + SSTOFCY + "~" + SNTGCOD
      [F:NTS]NTSCOD2 = SKEY
      Rewrite [F:NTS]

      If fstat Then
        GOK = 0
        Call ECR_TRACE(mess(13,100,1) - "NOTE :" - [F:NTS]CODE - SNTSCOD, 1) From GESECRAN
        Call FSTA("NTS") From GLOCK
        Break
      Else
        COMPTEUR += 1

        #Call MAJTEXTRA([F:NTS]CODE, "NOTE", "NTSDESAXX", [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From ATEXTRA #120120.o
        #Call MAJTEXTRA(left$([F:NTS]CODE,GLONAX1), "NOTE", "NTSSHOAXX", [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From ATEXTRA #120120.o

        #120120.sn
        #Populate description and short description field with NOTE field but if blank populate with NTSCOD field
        If [F:NTS]NOTE = ""
          Call MAJTEXTRA([F:NTS]NTSCOD, "NOTE", "NTSDESAXX", [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From ATEXTRA
          Call MAJTEXTRA([F:NTS]NTSCOD, "NOTE", "NTSSHOAXX", [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From ATEXTRA
        Else
          Call MAJTEXTRA(left$([F:NTS]NOTE,GLONAX1), "NOTE", "NTSDESAXX", [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From ATEXTRA
          Call MAJTEXTRA(left$([F:NTS]NOTE,GLONAX1), "NOTE", "NTSSHOAXX", [F:NTS]CODE, [F:NTS]NTSCOD+"~"+num$([F:NTS]NTGTYP)+"~"+[F:NTS]STOFCY+"~"+[F:NTS]NTGCOD) From ATEXTRA
        Endif
        #120120.en

      Endif
    Next
  Endif
  #119019.en

  If !GOK Then
    Rollback
  Else
    Commit
  Endif
  #---------------------------------------
  Call ECR_TRACE("UTITC44 :" - num$(COMPTEUR) - mess(176,116,1), 0) From GESECRAN
End

########################################################################
Subprog TRANSLATED_FIELD(IMESS, IML, STABLE1, SZONE, ILENGTH, SKEY1, SKEY2)
Value Integer IMESS
Value Integer IML
Value Char STABLE1
Value Char SZONE
Value Integer ILENGTH
Value Char SKEY1
Value Char SKEY2

Local Char SVGLANGUE(type(GLANGUE)-10)
Local Char STEXTE(250)

  SVGLANGUE = GLANGUE
  For [AST] Where [F:AST]LANCHP = IML and [F:AST]LANNUM = IMESS
    GLANGUE = [F:AST]LAN
    STEXTE = left$([F:AST]LANMES, ILENGTH)
    #Call MAJTEXTRA(STEXTE, STABLE1, SZONE, SKEY1, SKEY1) From ATEXTRA  # FGR 21/07/2015 : X3SUIVI106944
    Call MAJTEXTRA(STEXTE, STABLE1, SZONE, SKEY1, SKEY2) From ATEXTRA   # FGR 21/07/2015 : X3SUIVI106944
  Next
  GLANGUE = SVGLANGUE
End

########################################################################
#  For automatic execution during patch integration                    #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  # On  regarde si le module Formation est à "Oui"
  If [F:ADS]MODULE(8) <> 2 : End : Endif
  If filinfo(filpath("FIL","NOTE","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","TEXCLOB","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","NOTCATEG","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","BPCUSTOMER","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","BPSUPPLIER","fde",APPLI),0)<=0 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"NOTE") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"TEXCLOB") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"NOTCATEG") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"BPCUSTOMER") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"BPSUPPLIER") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC44(APPLI)
End

#######################################################################
# For execution during folder validation
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End : Endif
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  # On  regarde si le module Formation est à "Oui"
  If [F:ADS]MODULE(8) <> 2 : End : Endif  # 8 from Common Data on Folders
  If filinfo(filpath("FIL","NOTE","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","TEXCLOB","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","NOTCATEG","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","BPCUSTOMER","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","BPSUPPLIER","fde",APPLI),0)<=0 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"NOTE") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"TEXCLOB") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"NOTCATEG") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"BPCUSTOMER") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"BPSUPPLIER") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC44(APPLI)
End

