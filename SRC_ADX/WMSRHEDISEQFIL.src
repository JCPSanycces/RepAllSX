#<AdxTL>@(#)0.0.0.0 $Revision$Class ## ?IDENTQRY? SEARCH ##
# Supervisor
#WMSRHEDISEQFIL EDISEQFIL
# 2018-11-06 07:05:06 824

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","EDISEQFIL","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EDISEQFIL [ESF]
If filinfo(filpath("FIL","EDISEQFILD","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EDISEQFILD [ESFD]
If filinfo(filpath("FIL","EDISEQFILF","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EDISEQFILF [ESFF]
Local File EDISEQFIL [ESF_]
Local Char KEY_ESF(120)(1..3)
Local Char KEY_ESFD(120)(1..3)
Local Char KEY_ESFF(120)(1..3)
#Empty keys :
KEY_ESF(3) = "++"
KEY_ESFD(3) = "+++0"
KEY_ESFF(3) = "+++0"
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [ESF]
LogicClose File [ESFD]
LogicClose File [ESFF]
LogicClose File [ESF_]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [ESF] With
& [ESFD]ESFD0=[F:ESF]MSGCOD;[F:ESF]MSGREL;[F:ESF]MSGFILNOR,
& [ESFF]ESFF0=[F:ESF]MSGCOD;[F:ESF]MSGREL;[F:ESF]MSGFILNOR
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [ESF] With
& [ESFD]ESFD0=[F:ESF]MSGCOD;[F:ESF]MSGREL;[F:ESF]MSGFILNOR,
& [ESFF]ESFF0=[F:ESF]MSGCOD;[F:ESF]MSGREL;[F:ESF]MSGFILNOR
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE
KEY_ESF(2) = [F:ESF]MSGCOD+"+"+[F:ESF]MSGREL+"+"+[F:ESF]MSGFILNOR
KEY_ESFD(2) = [F:ESFD]MSGCOD+"+"+[F:ESFD]MSGREL+"+"+[F:ESFD]MSGFILNOR+"+"+num$([F:ESFD]NUMLIN)
KEY_ESFF(2) = [F:ESFF]MSGCOD+"+"+[F:ESFF]MSGREL+"+"+[F:ESFF]MSGFILNOR+"+"+num$([F:ESFF]NUMLIN)

If (KEY_ESF(2) <> KEY_ESF(3)) & (KEY_ESF(1) <> KEY_ESF(2))
 If INS <> null
  [L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
  #serialize INS
  Gosub ASEARCH_TO_JSON
 Endif
#Create a new instance
INS = NewInstance C_EDISEQFIL(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
SetInstance INS With [F:ESF]
FINS = 1
 KEY_ESF(1) = KEY_ESF(2)
Endif : # KEY_ESF(1) <> KEY_ESF(2)

Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"MSGCOD":'          +'"'+escJson(INS.MSGCOD)+'"'
Append ASND.DATA ,',"MSGREL":'         +'"'+escJson(INS.MSGREL)+'"'
Append ASND.DATA ,',"MSGFILNOR":'      +'"'+escJson(INS.MSGFILNOR)+'"'
Append ASND.DATA ,',"CREUSR":'         +'"'+escJson(INS.CREUSR)+'"'
Append ASND.DATA ,',"UPDUSR":'         +'"'+escJson(INS.UPDUSR)+'"'
Append ASND.DATA ,'}'
Onerrgo
Freegroup INS
INS = null
Raz KEY_ESF(1),KEY_ESFD(1),KEY_ESFF(1)
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:ESF]MSGCOD"
ASTDKEY += ";[F:ESF]MSGREL"
ASTDKEY += ";[F:ESF]MSGFILNOR"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
Gosub METHODS From EDISEQFIL_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="EDISEQFIL" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"EDISEQFIL")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"EDISEQFIL")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,50162)+'"'
Append WCLOB,',"$url":"{$baseUrl}/EDISEQFIL'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,50162)+' {$key}"'
Append WCLOB,',"$key":"{MSGCOD}~{MSGREL}~{MSGFILNOR}"'
Append WCLOB,',"$url":"{$baseUrl}/EDISEQFIL('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'EDISEQFIL.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"MSGCOD":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,50161)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"MSGREL":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,1281)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,',"MSGFILNOR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,50177)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"CREUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,250)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,',"UPDUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,250)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,',"$links":{'
Append WCLOB,'"$search$details":{'
Append WCLOB,'"$title":"Detail"'
Append WCLOB,',"$default":true'
Append WCLOB,',"$url":"{$baseUrl}/EDISEQFIL('+"'"+'{$key}'+"'"+')?representation=EDISEQFIL.$details"'
Append WCLOB,',"$devices":"desktop"'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
End ERROR
#---------------------------------------------------------------------------------------------------#
# GET_RES_STRING
#---------------------------------------------------------------------------------------------------#
Funprog GET_RES_STRING(_LAN,_ID)
Value Char _LAN
Value Integer _ID
Gosub  _GET_RES_STRING From WMSRHEDISEQFILB
End RES

