#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
# SUBITGA : Gestion des catégorie articles                  TB     2003 #
# --------------------------------------------------------------------- #
# Traitement des actions "GOSUB" de l'objet "ITG"                       #
# Les traitements sur champ "Call" se trouvent dans le SUBITG           #
#########################################################################
$OUVRE

Local Integer I, J, NBITGS, LSENS
Local Integer IQUEST     # indicateur pour poser la question
Local Integer RITG_SITE  # réponse à la question pour répercuter les modifs
Local Integer REP_LOC    # indicateur pour répercuter le tableau Emplacements dans ITF

# rubriques propre à la categorie + site à ne pas ecraser
Local    Integer  STOCOD    # mode retrait stock
Local    Integer  CUNCOD    # mode inventaire
Local    Integer  ABCCLS    # classe abc
Local    Char     VLTCOD    # methode de valorisation
Local    Char     OVECOD    # frais generaux
Local    Integer  STDCSTUPD # maj cout standard
Local    Integer  CUTCSTUPD # maj cout standard actuel
Local    Integer  BUDCSTUPD # maj cout standard budget
Local    Integer  SIMCSTUPD # maj cout standard simulation
Local    Char     PTOCOD

Local    Integer  WSALFLG        : # dde v142

# rubriques commmune la categorie et categorie + site
Local    Char     BUY(GLONAUS)
Local    Char     PLANNER(GLONAUS)

# Issue 70985 - 2012-03-09 by MUARN : landed cost cout achat forfaitaire
Local Decimal WMNTORG
Local Decimal WMNTDES
Local Integer SPSTAT
#
#MAE, bg 72517
If GMODU(7)=2
  Local    Mask ITGSTA [ISTA] # pour statuts en tableau
Endif
# pour charger une catégorie site à partir d'une catégorie générale
If clalev([F:ITGG])=0 Local File ITMCATEG   [ITGG] Endif
If clalev([F:ITGS])=0 Local File ITMCATEG   [ITGS] Endif
If clalev([F:TCM])=0  Local File TABCOSTMET [TCM]  Endif
If clalev([F:TRP])=0  Local File TABREOPOL  [TRP]  Endif
If clalev([F:TRU])=0  Local File TABALLRUL  [TRU]  Endif
If clalev([F:SRU])=0  Local File TABSTORUL  [SRU]  Endif
If clalev([F:TST])=0  Local File TABSTASTO  [TST]  Endif
If clalev([F:TUN])=0  Local File TABUNIT    [TUN]  Endif
If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITF1])=0 Local File ITMFACILIT [ITF1] Endif
If clalev([F:ACV])=0  Local File ACTIV      [ACV]  Endif
If clalev([F:OVE])=0  Local File OVERHEAD   [OVE]  Endif
If clalev([F:CAC])=0  Local File GACCCODE   [CAC]  Endif
If clalev([F:STCH])=0 Local File COSTSTCH   [STCH] Endif # Issue 84130 - 2012-09-18 by MUARN : landed cost SDC
If clalev([F:STC])=0  Local File STOLOC     [STC]  Endif # Jira X3-50162

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

# Issue 70985 - 2012-03-09 by MUARN : landed cost ajout devise pour cout achat forfaitaire
#---- Chargement de GCUR
Call CHARGE_GCUR() From TRTX3

#MAE, bg 69503, suppression de la globale GTYP
#Global Integer  GTYP         : # Pour selection du statut par défaut : # dde 21199
#lecture code activite Nb emplacements par défaut
If dim(GCOD_NDL)<1
   Global Integer GCOD_NDL
Endif
Read [ACV]CODACT="NDL"
If !fstat
   GCOD_NDL =[F:ACV]DIME
Endif
If dim(GSLOACTIV)<1
    Global Integer GSLOACTIV
Endif
#-- Activité sous-lot
Read [ACV] CODACT = "SLO"
If !fstat & [F:ACV]FLACT=2
   GSLOACTIV=2
Else
   GSLOACTIV=1
Endif
#-- Activité titre
If dim(GTITACTIV)<1
    Global Integer GTITACTIV
Endif
Read [ACV] CODACT = "TIT"
If !fstat & [F:ACV]FLACT=2
   GTITACTIV=2
Else
   GTITACTIV=1
Endif
# Issue 10401 - 2013-04-25 by MUARN : origne prix de base vente possibilité % achat
If [M:ITG6]BASPRIORI = 1
  Diszo [M:ITG6]PURPRIPRC
Else
  Actzo [M:ITG6]PURPRIPRC
Endif

# WMAJRUB sert à determiner si les rubriques à repercuter ont étés modifiées
Local Integer WMAJRUB(15)     # hcb 130505 30218

Return

$FERME

#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

#MAE, bg 69177, on utilise plus la globale GTYP mais une rubrique de l'écran ITG8
#If dim(GTYP)>0
#    Kill GTYP
#Endif
If GFONCTION1="GESITG"
    If dim(GCOD_NDL) > 0
        Kill GCOD_NDL
    Endif
    If dim(GSLOACTIV) > 0
        Kill GSLOACTIV
    Endif
    If dim(GTITACTIV) > 0
        Kill GTITACTIV
    Endif
Endif
Return

#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
$RAZCRE

Actzo [M:ITG0]
Actzo [M:ITG1]      : # Description
Actzo [M:ITG2]      : # Gestion
Actzo [M:ITG3]      : # Unités
Actzo [M:ITG4]      : # Règles sorties
Actzo [M:ITG5]      : # Compta et coût
Actzo [M:ITG6]      : # Achat/vente
Actzo [M:ITG7]      : # Production
Actzo [M:ITG8]      : # Règles entrées
Raz   [M:ITG0]
Raz   [M:ITG1]      : # Description
Raz   [M:ITG2]      : # Gestion
Raz   [M:ITG3]      : # Unités
Raz   [M:ITG4]      : # Règles sorties
Raz   [M:ITG5]      : # Compta et coût
Raz   [M:ITG6]      : # Achat/vente
Raz   [M:ITG7]      : # Production
Raz   [M:ITG8]      : # Règles entrées
If dim([M:ITG9]ORDWRH)>0
   #MAE, bug 110809
   #Grizo [M:ITG9]
   #Raz   [M:ITG9]      : # Dépôts
   Grizo [M:ITG9]10
   Grizo [M:ITG9]20
   Effzo [M:ITG9]10      : # Dépôts
   Effzo [M:ITG9]20      : # Dépôts
Endif

#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#

If dim([M:ITG5]BASTAB)>0
  If dim([M:ITG0]SOC)>0 & [M:ITG0]SOC<>""
    Call INIT_DIE(1,[M:ITG0]SOC,"ITG5","BASTAB") From TRTX3CPT
  Else
    Call INIT_DIE(1,"","ITG5","BASTAB") From TRTX3CPT
  Endif
Endif

[M:ITG1]ITMCREMOD  = 1 : # Mode de création
[M:ITG1]PURFLG     = 2 : # Achete
[M:ITG1]MFGFLG     = 1 : # Fabriqué
[M:ITG1]SCPFLG     = 1 : # Sous-traité
[M:ITG1]SCSFLG     = 1 : # Sous-traitance
[M:ITG1]PHAFLG     = 1 : # Fantôme
[M:ITG1]GENFLG     = 1 : # Générique
[M:ITG1]TOOFLG     = 1 : # Outillage
[M:ITG1]DLVFLG     = 1 : # Livrable
[M:ITG1]INTFLG     = 1 : # Intermédiaire
[M:ITG1]SALFLG     = 1 : # Flag vente
[M:ITG1]ABCCLS     = 1 : # Classe ABC
Gosub TRT_TYP_LIEN From SUBITG   # hcb 28874
# Pas de gestion de lot
If dim([M:ITG2]LOTMGTCOD)>0
  [M:ITG2]LOTMGTCOD=1
  Grizo [ITG2]LOTCOU
  Grizo [ITG8]DACLOT,LOTSUPINH
Endif
# Pas de gestion de serie
If dim([M:ITG2]SERMGTCOD)>0
  [M:ITG2]SERMGTCOD=1
  Grizo [ITG2]SERCOU
Endif
# Gestion péremption
If dim([M:ITG2]EXYMGTCOD)>0
  [M:ITG2]EXYMGTCOD=1
  Grizo [ITG2]EXYMGTCOD, EXYSTA
Endif


# Tracabilité
If dim([M:ITG2]TRKCOD)>0    [M:ITG2]TRKCOD=1    Endif
#--- Bug 55665
If dim([M:ITG2]TRKLEV)>0    [M:ITG2]TRKLEV=1    Endif
#---
[M:ITG2]STOMGTCOD = 2 : # Gestion de stock
[M:ITG2]STDFLG    = 3
[M:ITG2]PCKSTKFLG = 1 : # Colisage détail stock
[M:ITG2]PCKFLG    = 1 : # Colisage
[M:ITG2]CUNCOD    = 1
[M:ITG2]QUAFLG    = 1 : # Soumis contrôle
[M:ITG2]STOCOD    = 1 : # Mode retrait de stock

If dim([M:ITG2]LPNMGTCOD)>0   [M:ITG2]LPNMGTCOD = 1 : Endif : # gestion contenant                                         # hcb X3-58069

#--- Jira X3-50162
If dim([M:ITG2]LOCMGTCOD) > 0                        # hcb X3-71908
  #[M:ITG9]LOCMGTCOD = 1
  Actzo [M:ITG2]LOCMGTCOD                            # hcb X3-71908
  Actzo [M:ITG2]NBINT,LOCDES                         # hcb X3-71908
  Diszo [M:ITG2]DEFLOCTYP, DEFLOC                    # hcb X3-71908
Endif
#---
#                                               # hcb 71276 deb
If dim([M:ITG2]ECCFLG)>0
   If [M:ITG2]LOTMGTCOD < 2 & [M:ITG2]STOMGTCOD = 1
      Grizo [M:ITG2]ECCFLG
      Grizo [M:ITG2]ECCSTO
      Grizo [M:ITG2]ECCMIN
      Grizo [M:ITG2]ECCMAJ
      Grizo [M:ITG6]LOAECCFLG
   Else
      If [M:ITG2]ECCFLG < 2
         Grizo [M:ITG2]ECCSTO
         Grizo [M:ITG2]ECCMIN
         Grizo [M:ITG2]ECCMAJ
         Grizo [M:ITG6]LOAECCFLG
      Else
         If [M:ITG2]ECCSTO = 2
            Grizo [M:ITG2]ECCMIN
         Endif
     Endif
   Endif
Endif
#                                               # hcb 71276 fin

If [M:ITG2]PCKFLG = 1
   Grizo [M:ITG2]PCK
   Grizo [M:ITG2]PCKCAP
   #MAE, bug 110809
   #Actzo [M:ITG2]PCKSTKFLG
   Grizo [M:ITG2]PCKSTKFLG
Else
   Actzo [M:ITG2]PCK
   Actzo [M:ITG2]PCKCAP
   If [M:ITG2]STOMGTCOD < 2
      Grizo [M:ITG2]PCKSTKFLG
   Else
      Actzo [M:ITG2]PCKSTKFLG
   Endif
Endif

# Issue 70985 - 2012-03-07 by MUARN : landed cost
If [M:ITG6]CPRCOE = 0
   [M:ITG6]CPRCOE = 1
Endif
# Issue 70985 - 2012-03-09 by MUARN : landed cost ajout devise pour cout achat forfaitaire
[M:ITG6]CUR = GCUR


[M:ITG3]DACPUUCOE = 1 : # Coef UA-US non modifiable !

[M:ITG4]GLOAAAFLG = 2 : # Statut A
[M:ITG4]GLOQQQFLG = 1 : # Statut Q
[M:ITG4]GLORRRFLG = 1 : # Statut R

WSALFLG = [M:ITG1]SALFLG

# Charge l'écran ITG4 (nécessite CLSTYP et SALFLG) >> + actzo ?
Gosub CHARG_SRU From SUBITGB

[M:ITG5]STDCSTUPD = 2
[M:ITG5]CUTCSTUPD = 2
[M:ITG5]BUDCSTUPD = 2
[M:ITG5]SIMCSTUPD = 2

[M:ITG6]FIMHORUOM = 1
[M:ITG6]FRTHORUOM = 1
[M:ITG6]RCPFLG    = 2
[M:ITG6]PRQFLG    = 1

If GMODU(8)<2 Grizo [M:ITG7]10 Endif

Affzo [M:ITG1]1-99  : # Description
Affzo [M:ITG2]1-99  : # Gestion
Affzo [M:ITG8]1-99  : # Règles entrées
Affzo [M:ITG4]1-99  : # Règles sorties
Affzo [M:ITG5]1-99  : # Compta et coût
Affzo [M:ITG6]1-99  : # Achat/vente
Affzo [M:ITG7]1-99  : # Production
Return

$RAZDUP

# controler les différentes possibilités Cat --> Cat  Cat/Site --> Cat/site ...
# si l'on était sur une catég générale...
# si on s'apprête à créer une catégorie site il faut limiter les accès
# (si on est en train de modifier TCLCOD)
If [M:ITG0]STOFCY <> "" & COUZON="TCLCOD"
  Read [ITGG]ITG1=CZ;""   # !! [M] n'est pas encore chargé en modif de clé !
  If !fstat
    [L] = [M:ITG1]
    [L] = [M:ITG2]
    Call LECTEXTRA([M:ITG0]TCLAXX,"ITMCATEG","TCLAXX",[F:ITGG]TCLCOD,"") From ATEXTRA
    [M:ITG1] = [F:ITGG]  # ! sauf BUY, PLANNER :
    [M:ITG1] = [L]
    Call LECTEXTRA([M:ITG1]TCLSHOAXX,"ITMCATEG","TCLSHOAXX",[F:ITGG]TCLCOD,"") From ATEXTRA
    [M:ITG2] = [F:ITGG]  # ! sauf CUNCOD, STOCOD :
    [M:ITG2] = [L]
    [M:ITG3] = [F:ITGG]
    [M:ITG6] = [F:ITGG]
    [M:ITG5]ACCCOD = [F:ITGG]ACCCOD
    For I=0 To 2
      [M:ITG5]VACITM(I) = [F:ITGG]VACITM(I)
    Next
    For I=0 To GOPTCANA-1
      [M:ITG5]CCE(I)    = [F:ITGG]CCE(I)
    Next
    [M:ITG5]BRDCOD = [F:ITGG]BRDCOD
    Affzo [M:ITG0]TCLAXX
    Affzo [M:ITG1]1-99
    Affzo [M:ITG2]1-99
    Affzo [M:ITG3]1-99
    Affzo [M:ITG5]1-99
    Affzo [M:ITG6]1-99
    # Issue 70985 - 2012-03-07 by MUARN : landed cost
    If [M:ITG6]CPRCOE = 0
       [M:ITG6]CPRCOE = 1
    Endif
    # avertir de l'incohérence si Gestion stock='Non gérée' dans la catég générale
    If [F:ITGG]STOMGTCOD < 2
      GERR = 2 : GMESSAGE = mess(351,199,1)
      Effzo [M:ITG8]
      Grizo [M:ITG8]
      Effzo [M:ITG4]
      Grizo [M:ITG4]
      Grizo [M:ITG7]
#     If find([M:ITG1]CLSTYP,6,8)
      If [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2
        Actzo [M:ITG7]REOMINQTY,MFGLOTQTY # pour calc coût art Sous-traitance...
      Endif
    Endif
  Endif

 ## Actzo [M:ITG7]  # inutile normalement !! ?
  Grizo [M:ITG0]TCLAXX
  Grizo [M:ITG1] : Actzo [M:ITG1]BUY,PLANNER
  Grizo [M:ITG2] : Actzo [M:ITG2]CUNCOD,STOCOD
  If [M:ITG2]PCKFLG = 1
     Grizo [M:ITG2]PCK
     Grizo [M:ITG2]PCKCAP
     Grizo [M:ITG2]PCKSTKFLG
  Else
     Actzo [M:ITG2]PCK
     Actzo [M:ITG2]PCKCAP
     Actzo [M:ITG2]PCKSTKFLG
     If [M:ITG2]STOMGTCOD < 2
        Grizo [M:ITG2]PCKSTKFLG
     Endif
  Endif

  Grizo [M:ITG3]
  Grizo [M:ITG5]5,10    # accès aux données de valorisation
  Grizo [M:ITG5]BRDCOD  # Famille de coût qualifie l'ARTICLE
  Grizo [M:ITG6]
Endif

#--- Bug 61719
If [M:ITG0]STOFCY=""
  # Issue 106584 - 2018-08-31 by MAE : Responsive UI
  #Actzo [M:ITG1]25
  #Actzo [M:ITG1]30
  Actzo [M:ITG1]20
  Actzo [M:ITG1]15
Else
  # Issue 106584 - 2018-08-31 by MAE : Responsive UI
  #Diszo [M:ITG1]25
  #Diszo [M:ITG1]30
  Diszo [M:ITG1]20
  Diszo [M:ITG1]15
Endif
#Actzo [M:ITG1]25
#Actzo [M:ITG1]30
#---
If dim([M:ITG9]ORDWRH)>0
  If [M:ITG0]STOFCY=""
    #MAE, bug110809
    #Raz   [M:ITG9]
    #Grizo [M:ITG9]
    Effzo [M:ITG9]10
    Effzo [M:ITG9]20
    Grizo [M:ITG9]10
    Grizo [M:ITG9]20
  Else
    If [F:FCY]FCY<>[M:ITG0]STOFCY
      Read [FCY]FCY0=[M:ITG0]STOFCY
      If fstat Raz [F:FCY] Endif
    Endif
    # Site avec gestion de dépôt, et gestion emplacement
    If [F:FCY]WRHGES=2 & dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=2             # hcb X3-71908
      #MAE, bug110809
      #Actzo [M:ITG9]
      Actzo [M:ITG9]10
      Actzo [M:ITG9]20
    Else
      #MAE, bug110809
      #Raz   [M:ITG9]
      #Grizo [M:ITG9]
      Effzo [M:ITG9]10
      Effzo [M:ITG9]20
      Grizo [M:ITG9]10
      Grizo [M:ITG9]20
    Endif
  Endif
Endif

Return


$LIENS
#-----------------------#
# Après lecture [F:ITG] #
#-----------------------#
# tableau des unités de conditionnement
If find("",[M:ITG3]PCU(0.. dim([M:ITG3]PCU)-1)) > 0
   [M:ITG3]BASTAB = find("",[M:ITG3]PCU(0.. dim([M:ITG3]PCU)-1)) -1
Else
   [M:ITG3]BASTAB = dim([M:ITG3]PCU)
Endif


If dim([M:ITG2]LOCMGTCOD) > 0                    # hcb X3-71908
  #--- Jira X3-50162
  If [M:ITG2]STOMGTCOD=1                         # hcb X3-71908
    [M:ITG2]LOCMGTCOD=1                          # hcb X3-71908
    Raz [M:ITG2]NBINT,LOCDES                     # hcb X3-71908
    Raz [M:ITG2]DEFLOCTYP,DEFLOC                 # hcb X3-71908
    Diszo [M:ITG2]LOCMGTCOD                      # hcb X3-71908
    Diszo [M:ITG2]65                             # hcb X3-71908
    Diszo [M:ITG2]75                             # hcb X3-71908
  Elsif [M:ITG2]LOCMGTCOD=1                      # hcb X3-71908
    Raz [M:ITG2]NBINT,LOCDES                     # hcb X3-71908
    Raz [M:ITG2]DEFLOCTYP,DEFLOC                 # hcb X3-71908
    Actzo [M:ITG2]LOCMGTCOD                      # hcb X3-71908
    If dim([M:ITG2]LPNMGTCOD) >0  Diszo [M:ITG2]LPNMGTCOD : Endif
    Diszo [M:ITG2]75                             # hcb X3-71908
  Else
    Actzo [M:ITG2]LOCMGTCOD                      # hcb X3-71908
    If [M:ITG0]STOFCY=""
      Actzo [M:ITG2]NBINT, LOCDES                # hcb X3-71908
    Else
      Actzo [M:ITG2]75                           # hcb X3-71908
      Actzo [M:ITG2]65                           # hcb X3-71908
    Endif
  Endif
  #---
    If [M:ITG2]LOCMGTCOD=2                                                      # hcb X3-71908
      If find(0,[M:ITG2]LOCDES(0.. dim([M:ITG2]LOCDES)-1)) > 0                  # hcb X3-71908
        [M:ITG2]NBINT = find(0,[M:ITG2]LOCDES(0..dim([M:ITG2]LOCDES)-1))-1      # hcb X3-71908
      Else
        [M:ITG2]NBINT = dim([M:ITG2]LOCDES)                                     # hcb X3-71908
      Endif
    Else
      Raz [M:ITG2]LOCDES,NBINT                                                  # hcb X3-71908
    Endif
Endif
If dim([M:ITG2]LPNMGTCOD)>0                                                                 # hcb X3-58069
  If [M:ITG2]LPNMGTCOD = 0                                                                    # hcb X3-58069
    [M:ITG2]LPNMGTCOD = 1 : # gestion contenant                                              # hcb X3-58069
  Endif                                                                                       # hcb X3-58069
Endif                                                                                       # hcb X3-58069

#101090 - need Societe and Leg set for FRTCLS
If [M:ITG0]STOFCY<>""
  Call GETSOC([M:ITG0]STOFCY) From DEVSUB
Else
  GSOCIETE=""
  GCURLEG=""
  GCURFCY=""
Endif

#101090 - Hide NMFC based on USABOL parameter
If func AFNC.ACTIV("KUS")

  If [M:ITG0]STOFCY="" | func AFNC.PARAM("USABOL",[M:ITG0]STOFCY)="2"
    Chgfmt [M:ITG2]NMFC With "K:"  + num$(type([M:ITG2]NMFC)-10) + "X"    # Show enterable
  Else
    Chgfmt [M:ITG2]NMFC With "-K:" + num$(type([M:ITG2]NMFC)-10) + "X"    # Hide enterable
  Endif
Endif


# CCC (04/12/06) Bug 38759
If !GIMPORT | !find("TABSTORUL",[F:AOE]FLGFIL)
  # Chargement des règles de gestion (flux d'entrée)
  nolign = 0
  For [SRU]SRU0 Where TCLCOD=[M:ITG0]TCLCOD & STOFCY=[M:ITG0]STOFCY &
&                     find(TRSTYP,1,3,5,8,12,16,18,19,26,28,33,34)
    nolign += 1
    [M:ITG8] = [F:SRU]
    [M:ITG8]TRSTYPE(nolign-1) = [F:SRU]TRSTYP
    [M:ITG8]TRSCODE(nolign-1) = [F:SRU]TRSCOD
    If dim([M:ITG2]LOCMGTCOD)>0                         # hcb X3-71908
       [M:ITG8]LOCNUME(nolign-1) = [F:SRU]LOCNUM
    Endif
    [M:ITG8]AUZSTAE(nolign-1) = [F:SRU]AUZSTA
    [M:ITG8]AUZSSTE(nolign-1) = [F:SRU]AUZSST
    [M:ITG8]FORSTAE(nolign-1) = [F:SRU]FORSTA
    [M:ITG8]CONCATKEYE(nolign-1) = num$([M:ITG8]TRSTYPE(nolign-1))+[M:ITG8]TRSCODE(nolign-1)
    #--- Issue X3-53322
    If dim([M:ITG8]DACCTR)>0
      If [M:ITG8]DACCTR(nolign-1)=0 [M:ITG8]DACCTR(nolign-1)=1 Endif
    Endif
    #---
  Next
  [M:ITG8]NBENT = nolign
  If dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=1                  # hcb X3-71908
    For I=0 To [M:ITG8]NBENT-1
      [M:ITG8]LOCNUME(I)=0
    Next I
  Endif

  # Chargement des règles de gestion (flux de sortie)
  nolign = 0
  For [SRU]SRU0 Where TCLCOD=[M:ITG0]TCLCOD & STOFCY=[M:ITG0]STOFCY &
&               find(TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
    nolign += 1
    [M:ITG4] = [F:SRU]
    [M:ITG4]TRSTYPS(nolign-1) = [F:SRU]TRSTYP
    [M:ITG4]TRSCODS(nolign-1) = [F:SRU]TRSCOD
    [M:ITG4]AUZSTAS(nolign-1) = [F:SRU]AUZSTA
    [M:ITG4]AUZSSTS(nolign-1) = [F:SRU]AUZSST
    [M:ITG4]FORSTAS(nolign-1) = [F:SRU]FORSTA
    [M:ITG4]CONCATKEYS(nolign-1) = num$([M:ITG4]TRSTYPS(nolign-1))+[M:ITG4]TRSCODS(nolign-1)
  Next
  [M:ITG4]NBLOC = nolign
  If dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=1                               # hcb X3-71908
    For I=0 To [M:ITG4]NBLOC-1
       Raz [M:ITG4]LOCNUM(I), [M:ITG4]LOCNUM2(I), [M:ITG4]LOCNUM3(I)
    Next I
  Endif
Endif

#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#

If dim([M:ITG5]BASTAB)>0
  If dim([M:ITG0]SOC)>0 & [M:ITG0]SOC<>""
    Call CHARG_DIE(101,[M:ITG0]SOC,"ITG5","BASTAB") From TRTX3CPT
  Else
    Call CHARG_DIE(101,"","ITG5","BASTAB") From TRTX3CPT
  Endif
Endif

# si le site est vide, griser les zones servant à Article-site,
# on laisse la possibilité de définir les valorisations au niveau général.
# si le site est renseigné, griser les zones qui ne sont pas définies par site
If [M:ITG0]STOFCY = ""
   Actzo [M:ITG0]TCLAXX
   Actzo [M:ITG1]        # Description
   Actzo [M:ITG3]        # Unités
   Actzo [M:ITG5]        # Compta et coût

   #Grizo [M:ITG7]1-99
  # Onglet  ITG6        # Achat / Vente
#  If find([M:ITG1]CLSTYP,2,7) | GMODU(6) <> 2
   If ([M:ITG1]PURFLG = 1 & [M:ITG1]SCPFLG = 1) | [M:ITG1]PHAFLG = 2 | GMODU(6) <> 2
      Grizo [M:ITG6]5     # bloc achat
   Else
      Actzo [M:ITG6]5
      # Issue 10401 - 2013-04-25 By MUARN : ORIGNE PRIX DE BASE VENTE POSSIBILITÉ % ACHAT
      If [M:ITG6]BASPRIORI = 1
        Diszo [M:ITG6]PURPRIPRC
      Else
        Actzo [M:ITG6]PURPRIPRC
      Endif
   Endif
  # (dés)activer le bloc vente

   # Issue 70985 - 2012-03-07 by MUARN : landed cost frais d'approche
   If [M:ITG1]PURFLG = 1
      Grizo [M:ITG6]CPRCOE, CPRAMT, CUR, STCNUM
   Else
      [M:ITG6]CUR = GCUR
      WMNTORG = [F:ITG]CPRAMT
      Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG,WMNTDES,SPSTAT) From TRTDEV
      If !SPSTAT  [M:ITG6]CPRAMT = arr(WMNTDES,10^-GDECPRI) : Endif
      Actzo  [M:ITG6]CPRCOE, CPRAMT, STCNUM
   Endif
   If [M:ITG6]CPRCOE = 0
     [M:ITG6]CPRCOE = 1
   Endif
   # fin Issue 70985 - 2012-03-07 by MUARN : landed cost

   If [M:ITG1]SALFLG < 2 | GMODU(5) < 2
      Grizo [M:ITG6]10
   Else
      Actzo [M:ITG6]10
      # Issue 10401 - 2013-04-25 By MUARN : ORIGNE PRIX DE BASE VENTE POSSIBILITÉ % ACHAT
      If [M:ITG6]BASPRIORI = 1
        Diszo [M:ITG6]PURPRIPRC
      Else
        Actzo [M:ITG6]PURPRIPRC
      Endif
      # 107888 : Scheduled invoices (LD:03/12/15)
      # Invoice term accessible only for Service/Generic category and type of flow sales and not deliverable
      If GMODU(5)=2
          If ([M:ITG1]SCSFLG=2 | [M:ITG1]GENFLG=2) & [M:ITG1]DLVFLG=1
            Actzo [M:ITG6]INVCND
          Else
            Diszo [M:ITG6]INVCND
          Endif
      Endif
      # 107888 : Scheduled invoices (LD:03/12/15)
   Endif
   If [M:ITG2]STOMGTCOD > 1
      Actzo [M:ITG8]
      Actzo [M:ITG4]
      Actzo [M:ITG2]      # Gestion
      #--- Bug 52190
      Actzo [M:ITG7]1-99
      If [M:ITG7]REOMGTCOD < 5
         Grizo [M:ITG7]REOPER
      Else
         Actzo [M:ITG7]REOPER
      Endif
      If find([M:ITG7]REOMGTCOD,2,3)
         Actzo [M:ITG7]REOPOL,DAYCOV
      Else
         Grizo [M:ITG7]REOPOL,DAYCOV
      Endif
      If find([M:ITG7]REOCOD,1,2,3,5)
         Grizo [ITG7]REOFCY
      Else
         Actzo [ITG7]REOFCY
      Endif
      #---
   Else
      Grizo [M:ITG8]
      Grizo [M:ITG4]
      Grizo [M:ITG2]        # tout sauf le code Gestion stock
      Actzo [M:ITG2]STOMGTCOD
      Actzo [M:ITG2]QUAACS   # hcb V6CQ
      #MAE, bg75448
      #Grizo [M:ITG5]VLTCOD
      #--- Bug 52190
      Grizo [M:ITG7]
      If [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2
         Actzo [M:ITG7]REOMINQTY,MFGLOTQTY # pour calc coût art Sous-traitance...
      Endif
      #---
   Endif

# hcb 110196 deb
#   If dim([M:ITG9]ORDWRH)>0
#      Grizo [M:ITG9]1-99
#   Endif
  If dim([M:ITG9]ORDWRH)>0
    Effzo [M:ITG9]10
    Effzo [M:ITG9]20
    Grizo [M:ITG9]10
    Grizo [M:ITG9]20
  Endif
  #--- Jira X3-50162
  #If dim([M:ITG9]LOCMGTCOD) > 0
  #  If [M:ITG2]STOMGTCOD>1
  #    Actzo [M:ITG9]LOCMGTCOD
  #  Else
  #    Diszo [M:ITG9]LOCMGTCOD
  #  Endif
  #Endif
  #---
# hcb 110196 fin

#                                               # hcb 71276 deb
   If dim([M:ITG2]ECCFLG)>0
      If [M:ITG2]LOTMGTCOD < 3
         Grizo [M:ITG2]ECCSTO
      Endif


      If [M:ITG2]LOTMGTCOD < 2 & [M:ITG2]STOMGTCOD = 1
         Grizo [M:ITG2]ECCFLG
         Grizo [M:ITG2]ECCSTO
         Grizo [M:ITG2]ECCMIN
         Grizo [M:ITG2]ECCMAJ
         Grizo [M:ITG6]LOAECCFLG
      Else
         If [M:ITG2]ECCFLG < 2
            Grizo [M:ITG2]ECCSTO
            Grizo [M:ITG2]ECCMIN
            Grizo [M:ITG2]ECCMAJ
            Grizo [M:ITG6]LOAECCFLG
         Else
            If [M:ITG2]ECCSTO = 2
               Grizo [M:ITG2]ECCMIN
            Endif
         Endif
      Endif
   Endif
#                                               # hcb 71276 fin


   Gosub TRT_TYP_LIEN From SUBITG   # hcb 28874

Else
   If [F:FCY]FCY<>[M:ITG0]STOFCY
      Read [FCY]FCY0=[M:ITG0]STOFCY
      If fstat Raz [F:FCY] Endif
   Endif

   Grizo [M:ITG0]TCLAXX
   Grizo [M:ITG1] : Actzo [M:ITG1]BUY,PLANNER,ABCCLS
   Grizo [M:ITG2]
   Actzo [M:ITG2]QUAFLG,QLYCRD,QUAACS,FRTCLS            # hcb V6CQ - 101090, added FRTCLS
   #                                                                 # hcb X3-71908 deb
   If dim([M:ITG2]LOCMGTCOD) > 0
       If [M:ITG2]LOCMGTCOD>1
          Actzo [M:ITG2]DEFLOCTYP, DEFLOC
       Endif
   Endif
#                                                                    # hcb X3-71908 fin

   If dim([M:ITG2]NMFC)>0
    Actzo [M:ITG2]NMFC
   Endif  # 101090.n
   Grizo [M:ITG3]
   Grizo [M:ITG5]5,10    # accès aux données de valorisation
   Grizo [M:ITG5]BRDCOD  # Famille de coût qualifie l'ARTICLE
   Grizo [M:ITG6]
   If [M:ITG2]STOMGTCOD > 1
      Actzo [M:ITG2]CUNCOD,STOCOD
      Actzo [M:ITG8]
      Actzo [M:ITG4]
      #MAE, bg75448
      #Actzo [M:ITG5]VLTCOD
      Actzo [M:ITG7]1-99
    # et grizage contextuel
      If [M:ITG7]REOMGTCOD < 5
         Grizo [M:ITG7]REOPER
      Else
         Actzo [M:ITG7]REOPER
      Endif
      If find([M:ITG7]REOMGTCOD,2,3)
         Actzo [M:ITG7]REOPOL,DAYCOV
      Else
         Grizo [M:ITG7]REOPOL,DAYCOV
      Endif
      If find([M:ITG7]REOCOD,1,2,3,5)
         Grizo [ITG7]REOFCY
      Else
         Actzo [ITG7]REOFCY
      Endif

      #--- Bug 74104
      #If [F:FCY]WRHGES=2 & [M:ITG2]STOMGTCOD>1
      #  Diszo [M:ITG2]LOCMGTCOD
      #Elsif [M:ITG2]STOMGTCOD>1
      #   Actzo [M:ITG2]LOCMGTCOD
      #Elsif dim([M:ITG2]LOCMGTCOD)>0
      #   Grizo [M:ITG2]LOCMGTCOD
      #Endif
      #--- Jira X3-50162
      #If dim([M:ITG9]LOCMGTCOD) > 0
      #  If [M:ITG2]STOMGTCOD>1
      #    Actzo [M:ITG9]LOCMGTCOD
      #  Else
      #    Diszo [M:ITG9]LOCMGTCOD
      #  Endif
      #Endif
      #---
      #---

      If dim([M:ITG9]ORDWRH)>0
         # Site avec gestion de dépôt, et gestion emplacement
         If [F:FCY]WRHGES=2 & dim([M:ITG2]LOCMGTCOD)>0 & [M:ITG2]LOCMGTCOD=2                 # hcb X3-71908
            #MAE, bug 110809
            #Actzo [M:ITG9]1-99
            Actzo [M:ITG9]10
            Actzo [M:ITG9]20
         Else
            #MAE, bug 110809
            #Grizo [M:ITG9]1-99
            Grizo [M:ITG9]10
            Grizo [M:ITG9]20
         Endif
      Endif
   Else
      Grizo [M:ITG8]
      Grizo [M:ITG4]
      #MAE, bg75448
      #Grizo [M:ITG5]VLTCOD  # pas de valorisation de mouvement !
      Grizo [M:ITG7]
#     If find([M:ITG1]CLSTYP,6,8)
      If [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2
         Actzo [M:ITG7]REOMINQTY,MFGLOTQTY # pour calc coût art Sous-traitance...
      Endif
      Grizo[M:ITG2]QUAFLG             # hcb V6CQ
      Grizo[M:ITG2]QLYCRD             # hcb V6CQ
      If dim([M:ITG9]ORDWRH)>0
         #MAE,  bug 110809
         #Grizo [M:ITG9]1-99
         Grizo [M:ITG9]10
         Grizo [M:ITG9]20
      Endif
   Endif
   Grizo [M:ITG5]BRDCOD
   Grizo [M:ITG2]40
Endif

#--- Issue 96846
# grisage éventuel
#For I=0 To [M:ITG4]NBLOC-1
#  Call ETAT_ZONE_SRU([M:ITG4]TRSTYPS(I),I)
#Next I
#For I=0 To [M:ITG8]NBENT-1
#  Call ETAT_ZONE_SRU([M:ITG8]TRSTYPE(I),I)
#  # Griser Demande analyse si pas statut Q
#  If !find([M:ITG8]AUZSTAE(I),2,3,6,7)
#    Grizo [M:ITG8]QLYCTLFLG(I)
#  Else
#    Actzo [M:ITG8]QLYCTLFLG(I)
#  Endif
#  Affzo [M:ITG8]QLYCTLFLG(I)
#Next I
#---

If [M:ITG1]SCSFLG=2
    # Issue 106584 - 2018-08-31 by MAE : responsive UI
    #Effzo [M:ITG5]25                                  # hcb 61779
    #Grizo [M:ITG5]25                                  # hcb 61779
    Effzo [M:ITG5]20
    Grizo [M:ITG5]20
#MAE, bg 77458
#Else
Endif
#--- Tableau FG ----#
For GBIDI1=0 To dim([F]OTRSTYP(GBIDI1))-1
  If [F]OTRSTYP(GBIDI1)=0 : Break : Endif
  [M:ITG5]OTRSTYP(GBIDI1) = [F]OTRSTYP(GBIDI1)
  [M:ITG5]OVECOD(GBIDI1)  = [F]OVECOD(GBIDI1)
  [M:ITG5]OVECPNFLG(GBIDI1)= [F]OVECPNFLG(GBIDI1)
  Next
  [M:ITG5]NBTYP=GBIDI1
#Endif

If GMODU(8)<2 Grizo [M:ITG7]10 Endif  # Donnée production
#if find([M:ITG1]CLSTYP,6,8)           # Sous traitance, générique
If [M:ITG1]SCSFLG = 2 | [M:ITG1]GENFLG = 2
  Grizo [ITG2]
Endif
If dim([M:ITG2]LOTMGTCOD)>0
   If [M:ITG2]LOTMGTCOD < 2
      Grizo [M:ITG2]LOTCOU
      # Si gestion péremption
      If dim([M:ITG2]EXYMGTCOD)>0
        Grizo [ITG2]EXYMGTCOD, EXYSTA
      Endif
   Elsif [M:ITG0]STOFCY=""
      Actzo [M:ITG2]LOTCOU
   Endif
Endif

If dim([M:ITG2]SERMGTCOD) > 0
   If [M:ITG2]SERMGTCOD < 2
      Raz [M:ITG2]SERCOU
      Grizo [M:ITG2]SERCOU
   Elsif [M:ITG0]STOFCY=""
      Actzo [M:ITG2]SERCOU
   Endif
Endif

If dim([M:ITG2]LOCMGTCOD) > 0                      # hcb X3-71908
   If [M:ITG2]LOCMGTCOD < 2                        # hcb X3-71908
      Grizo [M:ITG4]LOCNUM
      Grizo [M:ITG4]LOCNUM2
      Grizo [M:ITG4]LOCNUM3
      Grizo [M:ITG8]LOCNUME
      If [M:ITG2]STOMGTCOD >1                                      # hcb X3-58069
        # Issue X3FEAT-345 - 2017-11-20 by MAE
        # Actzo [M:ITG2]65                                          # hcb X3-58069
        Actzo [M:ITG2]LOCMGTCOD                                          # hcb X3-58069
      Endif                                                         # hcb X3-58069
      Grizo [M:ITG2]75      # tableau des intitulés (activé + haut)        # hcb X3-58069
      # Issue X3FEAT-345 - 2017-11-20 by MAE
      If dim([M:ITG2]LPNMGTCOD)>0 Diszo [M:ITG2]LPNMGTCOD : Endif
   #--- Bug 64577
   Else
      Actzo [M:ITG4]LOCNUM
      Actzo [M:ITG4]LOCNUM2
      Actzo [M:ITG4]LOCNUM3
      Actzo [M:ITG8]LOCNUME
      Actzo [M:ITG2]75      # tableau des intitulés (activé + haut)         # hcb X3-58069
      Actzo [M:ITG2]65                                                      # hcb X3-58069
   #---
   Endif
Endif

#--- Issue 96846
# grisage éventuel
For I=0 To [M:ITG4]NBLOC-1
  Call ETAT_ZONE_SRU([M:ITG4]TRSTYPS(I),I)
Next I
For I=0 To [M:ITG8]NBENT-1
  Call ETAT_ZONE_SRU([M:ITG8]TRSTYPE(I),I)
  # Griser Demande analyse si pas statut Q
  If !find([M:ITG8]AUZSTAE(I),2,3,6,7)
    Grizo [M:ITG8]QLYCTLFLG(I)
  Else
    Actzo [M:ITG8]QLYCTLFLG(I)
  Endif
  Affzo [M:ITG8]QLYCTLFLG(I)
Next I
#---

If [M:ITG2]PCKFLG = 2
   Actzo [M:ITG2]PCK
   Actzo [M:ITG2]PCKCAP
   Actzo [M:ITG2]PCKFLG
   If [M:ITG2]STOMGTCOD < 2
      Grizo [M:ITG2]PCKSTKFLG
   Else
      Actzo [M:ITG2]PCKSTKFLG
   Endif
Else
   # Issue 118495 - 2016-09-15 by MAE : la case à cocher colisage n'est pas accessible en modif
   Actzo [M:ITG2]PCKFLG
   Grizo [M:ITG2]PCK
   Grizo [M:ITG2]PCKCAP
   Grizo [M:ITG2]PCKSTKFLG
Endif

#MAE, bg 72133
If dim([M:ITG2]TRKCOD)>0
   #--- Bug 55665
   #If (dim([M:ITG2]LOTMGTCOD)>0 & [M:ITG2]LOTMGTCOD<2) & (dim([M:ITG2]SERMGTCOD)>0 & [M:ITG2]SERMGTCOD<>3)
   #    Diszo [M:ITG2]TRKCOD

   #--- Issue 110327 : remplacement de [M:ITG2]SERMGTCOD<>3 par [M:ITG2]SERMGTCOD<3
   If (dim([M:ITG2]LOTMGTCOD)<0 | (dim([M:ITG2]LOTMGTCOD)>0 & [M:ITG2]LOTMGTCOD<2))
&   & (dim([M:ITG2]SERMGTCOD)<0 | (dim([M:ITG2]SERMGTCOD)>0 & [M:ITG2]SERMGTCOD<3))
      [M:ITG2]TRKCOD=1
      Diszo [M:ITG2]TRKCOD
      If dim([M:ITG2]TRKLEV)>0
         [M:ITG2]TRKLEV=1
         Diszo [M:ITG2]TRKLEV
      Endif
   #---
   Else
      Actzo [M:ITG2]TRKCOD
      #--- Bug 55665
      If dim([M:ITG2]TRKLEV)>0
         If [M:ITG2]TRKLEV=0 : [M:ITG2]TRKLEV=1 : Endif
         If [M:ITG2]TRKCOD<2
            Diszo  [M:ITG2]TRKLEV
         Else
            Actzo [M:ITG2]TRKLEV
         Endif
      Endif
      #---
   Endif
Endif

# Issue 70985 - 2012-05-30 by MUARN : landed cost ajout UA sur onglet achat/vente
[M:ITG6]ITMPUU = [M:ITG3]PUU

If [M:ITG1]SALFLG <> 2 & [M:ITG1]DLVFLG <> 2
   Grizo [M:ITG2]PCK
   Grizo [M:ITG2]PCKCAP
   Grizo [M:ITG2]PCKFLG
   Grizo [M:ITG2]PCKSTKFLG
Endif

# Issue 59757 - 2017-10-23 by MAE : service vendu=> unités de vente accessibles
#If [M:ITG1]SCSFLG = 2                                  # hcb 103984
#   Grizo [M:ITG3]SAU, SAUSTUCOE, DACSAUCOE             # hcb 103984
#Endif                                                  # hcb 103984

Raz REP_LOC, RITG_SITE, IQUEST  # réinitialise les flags de répercution
Raz NBITGS
Raz WMAJRUB  # hcb 130505 30218
Return

$APRES_MODIF

# traiter modif de clé et prévoir d'avance la duplication...

# hcb 130505 30218 : rubriques suivantes enlevées de l instruction suivante "When ..."
#     "TRSTYP","TRSCOD","LOCNUM","NBLOC",
#     "AUZSTA","AUZSST","DEFSTA","DACLOT","LOTSUPINH","SHLLOT",
# hcb 130505 30218
Case COUZON
 When "BUY","PLANNER","GLOAAAFLG","GLOQQQFLG","GLORRRFLG",
&     "ALLRULORD","ALLRULMAT","ALLRULSHI","ALLRULMFG","ALLRULTRF",
&     "ALLRULSCO","ALLRULSCC","VLTCOD",
&     "NBTYP","OTRSTYP","OVECOD","OVECPNFLG"
   # Si on modifie une catég générale et que la question n'a pas encore été posée
   # Positionnement d'un indicateur pour pouvoir poser la question au moment d'enregistrer
   # Faut-il répercuter sur les catégories sites.
   If [M:ITG0]STOFCY="" & IQUEST = 0
     For [ITGS]ITG1 Where TCLCOD=[M:ITG0]TCLCOD & STOFCY<>""
       NBITGS = 1 : Break
     Next
     If NBITGS = 1
       IQUEST = 1 # pour pouvoir poser la question au moment d'enregistrer
     Endif
   Endif
# hcb 130505 30218 deb
   If    COUZON = "ALLRULSHI"
     WMAJRUB(0)  = 1
   Elsif COUZON = "ALLRULMFG"
     WMAJRUB(1)  = 1
   Elsif COUZON = "ALLRULTRF"
     WMAJRUB(2)  = 1
   Elsif COUZON = "ALLRULSCO"
     WMAJRUB(3)  = 1
   Elsif COUZON = "ALLRULSCC"
     WMAJRUB(4)  = 1
   Elsif COUZON = "ALLRULORD"
     WMAJRUB(5)  = 1
   Elsif COUZON = "ALLRULMAT"
     WMAJRUB(6)  = 1
   Elsif COUZON = "GLOAAAFLG"
     WMAJRUB(7)  = 1
   Elsif COUZON = "GLOQQQFLG"
     WMAJRUB(8)  = 1
   Elsif COUZON = "GLORRRFLG"
     WMAJRUB(9)  = 1
   Elsif COUZON = "VLTCOD"
     WMAJRUB(10)  = 1
   Elsif COUZON = "BUY"
     WMAJRUB(11) = 1
   Elsif COUZON = "PLANNER"
     WMAJRUB(12) = 1
   Endif

 When "NBINT","LOCDES"

   # si on veut répercuter des modifs d'emplacement de catégorie générale à categ/site
   # ou si l'on est en train de modifier les empl. d'une catégorie-site
   #... ou s'il n'y a pas de catégorie/sites : positionner l'indicateur

   If [M:ITG0]STOFCY="" & IQUEST = 0
      For [ITGS]ITG1 Where TCLCOD=[M:ITG0]TCLCOD & STOFCY<>""
          NBITGS = 1 : Break
      Next
   Endif

   #--- Jira X3-50162
   #If [M:ITG0]STOFCY<>"" | ([M:ITG0]STOFCY="" & NBITGS=0)
   #   REP_LOC = 2  # (même en création !)
   #Endif
   REP_LOC = 2

   #---

# hcb 130505 30218 fin


 When Default
Endcase

Return
$INICRE
# Initialisation de zones désactivées
If dim([M:ITG2]LOTMGTCOD) < 0
    [F:ITG]LOTMGTCOD = 1
Endif
If dim([M:ITG2]SERMGTCOD) < 0
    [F:ITG]SERMGTCOD = 1
Endif
If dim([M:ITG2]EXYMGTCOD) < 0
    [F:ITG]EXYMGTCOD = 1
Endif
Call MAJTEXTRA([M:ITG0]TCLAXX,"ITMCATEG","TCLAXX",[M:ITG0]TCLCOD,"") From ATEXTRA
Call MAJTEXTRA([M:ITG1]TCLSHOAXX,"ITMCATEG","TCLSHOAXX",[M:ITG0]TCLCOD,"") From ATEXTRA

# Issue 70985 - 2012-03-12 by MUARN : landed cost cout achat forfaitaire
If [M:ITG1]PURFLG = 2
  WMNTORG = [M:ITG6]CPRAMT
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG,WMNTDES,SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITG]CPRAMT = WMNTDES : Endif
Endif
# fin Issue 70985 - 2012-03-12 by MUARN : landed cost cout achat forfaitaire

Return

$CREATION

If [F:ITG]LOCMGTCOD = 0         # hcb 45086
   [F:ITG]LOCMGTCOD = 1         # hcb 45086
Endif                           # hcb 45086

# création de la table TABSTORUL à partir des tableau
For nolign = 1 To [M:ITG4]NBLOC
  Raz [F:SRU]
  [F:SRU] = [F:ITG]
  [F:SRU] = [M:ITG4]
  [F:SRU]TRSTYP = [M:ITG4]TRSTYPS(nolign-1)
  [F:SRU]TRSCOD = [M:ITG4]TRSCODS(nolign-1)
  [F:SRU]AUZSTA = [M:ITG4]AUZSTAS(nolign-1)
  [F:SRU]AUZSST = [M:ITG4]AUZSSTS(nolign-1)
  [F:SRU]FORSTA = [M:ITG4]FORSTAS(nolign-1)
  [F:SRU]QLYCTLFLG = 1
  [F:SRU]DACLOT    = 2
  [F:SRU]LOTSUPINH = 1
  Write [SRU]
  If fstat
    GOK = 0
    GMESSAGE=mess(13,100,1)-"TABSTORUL"
    Break
  Endif
Next
If GOK < 1 Goto FINCRE Endif

For nolign = 1 To [M:ITG8]NBENT
  Raz [F:SRU]
  [F:SRU] = [F:ITG]
  [F:SRU] = [M:ITG8]
  [F:SRU]TRSTYP = [M:ITG8]TRSTYPE(nolign-1)
  [F:SRU]TRSCOD = [M:ITG8]TRSCODE(nolign-1)
  [F:SRU]AUZSTA = [M:ITG8]AUZSTAE(nolign-1)
  [F:SRU]AUZSST = [M:ITG8]AUZSSTE(nolign-1)
  [F:SRU]FORSTA = [M:ITG8]FORSTAE(nolign-1)
  If dim([M:ITG8]LOCNUME)>0                          # hcb 55792
     [F:SRU]LOCNUM = [M:ITG8]LOCNUME(nolign-1)
  Endif
  [F:SRU]SHLLOT = 1
  Write [SRU]
  If fstat
    GOK = 0
    GMESSAGE=mess(13,100,1)-"TABSTORUL"
    Break
  Endif
Next
If GOK < 1 Goto FINCRE Endif

# des articles/site existent dans le cadre de la reprise 130 où on peut créer ITG
# en "repiquant" des valeurs de TABITMCLS !
# (!! s'il n'y a pas de catégorie-site la question n'a pas été posée)
# ATTENTION si ITG livré avant ITF : tester dim([ITF]LOCNUM) pour courtcircuiter
# les MAJ_ITF
If REP_LOC = 2 & dim([F:ITF]LOCNUM)>0
    If [M:ITG0]STOFCY = ""
        #  répercuter le tableau des intitulés d'emplacement dans ITF
        Link [ITF] With [ITM]ITM0=[ITF]ITMREF As [IMF] Where [ITM]TCLCOD=[M:ITG0]TCLCOD
    Else
    # reporter les modifications du tableau d'emplacements dans ITF (Systématiquement)
        Link [ITF] With [ITM]ITM0=[ITF]ITMREF As [IMF]
&                  Where [ITM]TCLCOD=[M:ITG0]TCLCOD & [ITF]STOFCY=[M:ITG0]STOFCY
    Endif
    Gosub MAJ_ITF
Endif

#--- Tableau FG ----#
For GBIDI1=0 To [M:ITG5]NBTYP-1
    [F]OTRSTYP(GBIDI1) = [M:ITG5]OTRSTYP(GBIDI1)
    [F]OVECOD(GBIDI1) = [M:ITG5]OVECOD(GBIDI1)
    [F]OVECPNFLG(GBIDI1) = [M:ITG5]OVECPNFLG(GBIDI1)
Next

$FINCRE
Return

$VERIF

Local Integer I, J, K
Local Integer WRET
For J=0 To [M:ITG8]NBENT-1
  #-- La ligne est-elle déjà dans l'écran ???
  If [M:ITG8]TRSTYPE(J)<>0
    I=sigma(0,[M:ITG8]NBENT-1,(indcum+1)*([M:ITG8]TRSTYPE(indcum)=[M:ITG8]TRSTYPE(J) &
&          [M:ITG8]TRSCODE(indcum)=[M:ITG8]TRSCODE(J) & (indcum<>J) & K=0 & sigma(K=1,1,1)))
    If I<>0
      GMESSAGE =mess(3,40,1)-num$(I)-mess(24,123,1)-num$(J+1) : # Code déjà existant en ligne
      Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE
      OK=0 : Return
    Endif
  Endif
Next J

For J=0 To [M:ITG4]NBLOC-1
  #-- La ligne est-elle déjà dans l'écran ???
  If [M:ITG4]TRSTYPS(J)<>0
    I=sigma(0,[M:ITG4]NBLOC-1,(indcum+1)*([M:ITG4]TRSTYPS(indcum)=[M:ITG4]TRSTYPS(J) &
&          [M:ITG4]TRSCODS(indcum)=[M:ITG4]TRSCODS(J) & (indcum<>J) & K=0 & sigma(K=1,1,1)))
    If I<>0
      GMESSAGE =mess(3,40,1)-num$(I)-mess(24,123,1)-num$(J+1) : # Code déjà existant en ligne
      Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE
      OK=0 : Return
    Endif
  Endif
Next J
If [M:ITG2]STOMGTCOD>1 & [M:ITG4]GLOAAAFLG<2 & [M:ITG4]GLOQQQFLG<2 & [M:ITG4]GLORRRFLG<2
  GMESSAGE=mess(359,199,1)-mess(427,198,1) # Une case au moins doit être cochée dans ce bloc
  OK=0 : Return
Endif

If [M:ITG1]PURFLG = 1 &
&  [M:ITG1]MFGFLG = 1 &
&  [M:ITG1]SCPFLG = 1 &
&  [M:ITG1]SCSFLG = 1 &
&  [M:ITG1]PHAFLG = 1 &
&  [M:ITG1]GENFLG = 1 &
&  [M:ITG1]INTFLG = 1 &
&  [M:ITG1]TOOFLG = 1
   GMESSAGE=mess(257,184,1) # Le bloc types de l onglet description est incorrecte   !
   OK = 0
Endif
# si livrable et unite de vente = "" alors unite de vente = unite de stock
If [M:ITG3]SAU = "" & [M:ITG1]DLVFLG = 2
   [M:ITG3]SAU =      [M:ITG3]STU
   [M:ITG3]SAUSTUCOE = 1                    # hcb 103984
   # Issue 59757 - 2017-10-24 by MAE
   Affzo [M:ITG3]SAU
   Affzo [M:ITG3]SAUSTUCOE
   # End issue 59757
Endif
#MAE, le 10/09/10, bg 55319, si article géré en titre, gestion de lot obligatoire
If [M:ITG2]STOMGTCOD=3 & [M:ITG2]LOTMGTCOD=1
   Call OUINON(mess(489,199,1)+"\"+mess(205,100,1),WRET) From GESECRAN
   If WRET=1 : OK = 0 : Endif
Endif

# Issue 112878 - 2015-12-10 by MAE : si catégorie sous traité ou service, l'article doit être réceptionnné
If ([M:ITG1]SCSFLG = 2 | [M:ITG1]SCPFLG = 2 | [M:ITG2]STOMGTCOD>1)  & [M:ITG6]RCPFLG <> 2
  Call OUINON(mess(648,199,1),WRET) From GESECRAN
  If WRET=1 : OK = 0 : Endif
Endif

#104427 RICAR 2015/01/14 - Inventory - BEGIN
# BRBAN 108908
If func AFNC.ACTIV("KPO")>0 & func AFNC.ACTIV("SAFT")>0
  If [M:ITG1]ITMSFTTYP<>2 & [M:ITG2]INVPRODTYP<>6
    Call ECR_TRACE(mess(172,7711,1)-mess(6,2051,1),1) From GESECRAN
    [M:ITG2]INVPRODTYP=6
    Affzo [M:ITG2]INVPRODTYP
  Endif
Endif
#104427 RICAR 2015/01/14 - Inventory - END

Return

# Issue 84130 - 2013-05-21 by MUARN : landed cost - contrôle sur structure de coût
$APRES_CRE
Local    Integer LRET
# Contrôle cohérence structure de coût
If [M:ITG6]STCNUM <> ""
  Call CONTROL_CSTSTC([M:ITG6]STCNUM,"ITG",LRET) From STCCTL
Endif
Return

# Issue 84130 - 2013-05-21 by MUARN : landed cost - contrôle sur structure de coût
$APRES_MOD
Local    Integer LRET
# Contrôle cohérence structure de coût
If [M:ITG6]STCNUM<>""
  Call CONTROL_CSTSTC([M:ITG6]STCNUM,"ITG",LRET) From STCCTL
Endif
Return

$VERIF_MOD
Gosub VERIF
If OK=0 Return : Endif
# question interactive pour les éléments déclinables dans les catégories sites
If IQUEST
  If !GIMPORT
        # "Répercuter les modifications sur les catégorie/sites ?"
        Call OUINON(mess(347,199,1),RITG_SITE) From GESECRAN
  Else
    RITG_SITE = 2 # forcer la copie en import
  Endif
Endif
Return

$AVANT_MODFIC

# Modifier tous les articles de cette catégorie si le type est modifié
#if [M:ITG1]CLSTYP = [F:ITG]CLSTYP
If [M:ITG1]PURFLG =  [F:ITG]PURFLG  &
&  [M:ITG1]MFGFLG =  [F:ITG]MFGFLG  &
&  [M:ITG1]SCPFLG =  [F:ITG]SCPFLG  &
&  [M:ITG1]SCSFLG =  [F:ITG]SCSFLG  &
&  [M:ITG1]PHAFLG =  [F:ITG]PHAFLG  &
&  [M:ITG1]GENFLG =  [F:ITG]GENFLG  &
&  [M:ITG1]TOOFLG =  [F:ITG]TOOFLG  &
&  [M:ITG1]DLVFLG =  [F:ITG]DLVFLG  &
&  [M:ITG1]INTFLG =  [F:ITG]INTFLG  &
&  [M:ITG1]SALFLG =  [F:ITG]SALFLG
   Return
Endif


For [ITM] Where TCLCOD = [M:ITG0]TCLCOD
#  [F:ITM]CLSTYP = [M:ITG1]CLSTYP
   [F:ITM]PURFLG =  [M:ITG1]PURFLG
   [F:ITM]MFGFLG =  [M:ITG1]MFGFLG
   [F:ITM]SCPFLG =  [M:ITG1]SCPFLG
   [F:ITM]SCSFLG =  [M:ITG1]SCSFLG
   [F:ITM]PHAFLG =  [M:ITG1]PHAFLG
   [F:ITM]GENFLG =  [M:ITG1]GENFLG
   [F:ITM]TOOFLG =  [M:ITG1]TOOFLG
   [F:ITM]DLVFLG =  [M:ITG1]DLVFLG
   [F:ITM]SALFLG =  [M:ITG1]SALFLG
   [F:ITM]INTFLG =  [M:ITG1]INTFLG
# si livrable et unite de vente = "" alors unite de vente = unite de stock
   If [F:ITM]SAU        = "" & [F:ITM]DLVFLG = 2
      [F:ITM]SAU        =      [F:ITM]STU
      [F:ITM]SAUSTUCOE  =  1
   Endif
# si non livrable alors unite de vente = ""
   If [F:ITM]DLVFLG     <> 2
      [F:ITM]SAU        =  ""
      [F:ITM]SAUSTUCOE  =  0
   Endif

   Rewrite [ITM]
   If fstat = 1
      GOK = -1 : GLOCK = "$ITMMASTER"+[F:ITM]ITMREF : Break
   Endif
Next
Default File [ITG] : # rétablit le fichier par défaut avant [F]=[M]
Return

$MODIF
# modification des enregistrements Catégorie/site
#    systématique pour les éléments généraux
#    conditionnée par la réponse interactive pour les éléments déclinables
If [M:ITG0]STOFCY = ""

#MAE, dde 53999 message avertissant que la catégorie site va être affectée par la mise à jour de la catégorie générale
If IQUEST = 0
  #MAE, bg 78447
  For [ITGS]ITG1 Where TCLCOD=[M:ITG0]TCLCOD & STOFCY<>""
          NBITGS = 1 : Break
  Next
  If NBITGS = 1
    Call OUINON(mess(347,199,1),WRET) From GESECRAN
  Endif
Endif
#MAE, bg 74132, si réponse Oui, on met à jour les catégories site associées, sinon on enregistre
#seulement la catégorie mére.
If WRET = 2 | RITG_SITE=2   #MAE, bg 78447
  For [ITGS] Where TCLCOD=[M:ITG0]TCLCOD & STOFCY<>""
     Readlock [ITGS]Curr
     If !fstat
       Call MAJTEXTRA([M:ITG0]TCLAXX,"ITMCATEG","TCLAXX",[F:ITGS]TCLCOD,"") From ATEXTRA
       [L] = [F:ITGS] # on met en classe locale les zones à ne pas ecraser (déclarées dans OUVRE)
       [F:ITGS] = [M:ITG1]
       [F:ITGS] = [M:ITG2]
       [F:ITGS] = [M:ITG3]
       [F:ITGS] = [M:ITG5]
       [F:ITGS] = [L]

       If [F:ITGS]STOMGTCOD>1 & [F:ITGS]VLTCOD = ""
          [F:ITGS]VLTCOD      = [M:ITG5]VLTCOD
       Endif
       #MAE, bg75448
       #If [F:ITGS]STOMGTCOD < 2
       #   [F:ITGS]VLTCOD      = ""
       #Endif


       [F:ITGS]ACCCOD = [M:ITG5]ACCCOD
       For I=0 To 2
         [F:ITGS]VACITM(I) = [M:ITG5]VACITM(I)
       Next
       For I=0 To GOPTCANA-1
         [F:ITGS]CCE(I)    = [M:ITG5]CCE(I)
       Next
       [F:ITGS]BRDCOD = [M:ITG5]BRDCOD
       [F:ITGS] = [M:ITG6]

       If RITG_SITE=2

          #hcb 130505 30218 deb
          #[F:ITGS]        = [M:ITG4]
          #[F:ITGS]BUY     = [M:ITG1]BUY
          #[F:ITGS]PLANNER = [M:ITG1]PLANNER
          #[F:ITGS]VLTCOD  = [M:ITG5]VLTCOD

          If WMAJRUB(0) = 1 : [F:ITGS]ALLRULSHI = [M:ITG4]ALLRULSHI : Endif
          If WMAJRUB(1) = 1 : [F:ITGS]ALLRULMFG = [M:ITG4]ALLRULMFG : Endif
          If WMAJRUB(2) = 1 : [F:ITGS]ALLRULTRF = [M:ITG4]ALLRULTRF : Endif
          If WMAJRUB(3) = 1 : [F:ITGS]ALLRULSCO = [M:ITG4]ALLRULSCO : Endif
          If WMAJRUB(4) = 1 : [F:ITGS]ALLRULSCC = [M:ITG4]ALLRULSCC : Endif
          If WMAJRUB(5) = 1 : [F:ITGS]ALLRULORD = [M:ITG4]ALLRULORD : Endif
          If WMAJRUB(6) = 1 : [F:ITGS]ALLRULMAT = [M:ITG4]ALLRULMAT : Endif
          If WMAJRUB(7) = 1 : [F:ITGS]GLOAAAFLG = [M:ITG4]GLOAAAFLG : Endif
          If WMAJRUB(8) = 1 : [F:ITGS]GLOQQQFLG = [M:ITG4]GLOQQQFLG : Endif
          If WMAJRUB(9) = 1 : [F:ITGS]GLORRRFLG = [M:ITG4]GLORRRFLG : Endif
          If WMAJRUB(10)= 1 : [F:ITGS]VLTCOD    = [M:ITG5]VLTCOD    : Endif
          If WMAJRUB(11)= 1 : [F:ITGS]BUY       = [M:ITG1]BUY       : Endif
          If WMAJRUB(12)= 1 : [F:ITGS]PLANNER   = [M:ITG1]PLANNER   : Endif

         ## reporter aussi les modifs sur les SRU !
           # faut-il deleter ceux qui existaient ?? si TRSCOD a été modifié !
         ## pour chaque ligne du tableau chercher les SRU associés aux ITGS
         ## si SRU existe ; rewrite, sinon : le créer
#         For nolign = 1 To [M:ITG4]NBLOC
#             Readlock [SRU]SRU0=[M:ITG0]TCLCOD;[F:ITGS]STOFCY;[M:ITG4]TRSTYPS(nolign-1);[M:ITG4]TRSCODS(nolign-1)
#             If !fstat
#                [F:SRU] = [M:ITG4]
#                Rewrite [SRU]
#                If fstat
#                   GOK = 0
#                   GMESSAGE=mess(13,100,1)-"TABSTORUL"
#                   Break 2
#                Endif
#             Elsif fstat=5
#             [F:SRU] = [F:ITGS]
#             [F:SRU] = [M:ITG4]
#             Write [SRU]
#             If fstat
#                GOK = 0
#                GMESSAGE=mess(13,100,1)-"TABSTORUL"
#                Break 2
#             Endif
#           Endif
#         Next
#hcb 130505 30218 fin
        #--- Tableau FG ----#
        For GBIDI1=0 To dim([F:ITGS]OTRSTYP)-1
            [F:ITGS]OTRSTYP(GBIDI1) = [M:ITG5]OTRSTYP(GBIDI1)
            [F:ITGS]OVECOD(GBIDI1)  = [M:ITG5]OVECOD(GBIDI1)
            [F:ITGS]OVECPNFLG(GBIDI1)  = [M:ITG5]OVECPNFLG(GBIDI1)
        Next

       Endif
       Rewrite [ITGS]
       If fstat
          GOK = 0 : Break
       Endif
     Else
         GOK = -1 : # FSTA ...
     Endif
  Next
  If GOK < 1 Goto FINMOD Endif
 Endif

  If (REP_LOC=2 | RITG_SITE=2) & dim([F:ITF]LOCNUM)>0
    # > répercuter le tableau des intitulés d'emplacement dans ITF
    Link [ITF] With [ITM]ITM0=[ITF]ITMREF As [IMF] Where [ITM]TCLCOD=[M:ITG0]TCLCOD
    # Attention si ITM+ITF > 255 champs, ou pour accélerer faire un
    Columns [IMF] ([ITF]LOCNUM,[ITF]DEFLOCTYP,[ITF]DEFLOC,[ITF]LOCMGTCOD,[ITF]ITMREF,[ITF]STOFCY,[ITM]TCLCOD)#> + zones clé
    Gosub MAJ_ITF
  Endif
Else
  # reporter les modifications du tableau d'emplacements dans ITF (Systématiquement)
  If REP_LOC = 2 & dim([F:ITF]LOCNUM)>0
    Link [ITF] With [ITM]ITM0=[ITF]ITMREF As [IMF]
&        Where [ITM]TCLCOD=[M:ITG0]TCLCOD & [ITF]STOFCY=[M:ITG0]STOFCY
    Columns [IMF] ([ITF]LOCNUM,[ITF]DEFLOCTYP,[ITF]DEFLOC,[ITF]LOCMGTCOD,[ITF]ITMREF,[ITF]STOFCY)#> + zones clé
    Gosub MAJ_ITF
  Endif
Endif
If GOK < 1 Goto FINMOD Endif

# Mise à jour table TABSTORUL
Local Char CLE_TO_DEL
CLE_TO_DEL = [M:ITG0]TCLCOD
For [SRU]SRU0 Where TCLCOD = [M:ITG0]TCLCOD & STOFCY = [M:ITG0]STOFCY
   Delete [SRU]
#  Vérifier si un enregistrement est locké : si oui : Fin
   If fstat = 1
      GOK = -1
      Call RSTA("SRU",CLE_TO_DEL) From GLOCK
      Break
   Endif
Next
If GOK < 0 Goto FINMOD Endif

# recréation des enregistrements TABSTORUL
For nolign = 1 To [M:ITG4]NBLOC
  Raz [F:SRU]
  [F:SRU] = [F:ITG]
  [F:SRU] = [M:ITG4]
  [F:SRU]STOFCY = [M:ITG0]STOFCY                             # hcb X3-83829
  [F:SRU]TRSTYP = [M:ITG4]TRSTYPS(nolign-1)
  [F:SRU]TRSCOD = [M:ITG4]TRSCODS(nolign-1)
  [F:SRU]AUZSTA = [M:ITG4]AUZSTAS(nolign-1)
  [F:SRU]AUZSST = [M:ITG4]AUZSSTS(nolign-1)
  [F:SRU]FORSTA = [M:ITG4]FORSTAS(nolign-1)
  [F:SRU]QLYCTLFLG = 1
  [F:SRU]DACLOT    = 2
  [F:SRU]LOTSUPINH = 1
  Write [SRU]
  If fstat
    GOK = 0
    GMESSAGE=mess(13,100,1)-"TABSTORUL"
    Break
  Endif
Next
If GOK < 0 Goto FINMOD Endif

For nolign = 1 To [M:ITG8]NBENT
  Raz [F:SRU]
  [F:SRU] = [F:ITG]
  [F:SRU] = [M:ITG8]
  [F:SRU]STOFCY = [M:ITG0]STOFCY                             # hcb X3-83829
  [F:SRU]TRSTYP = [M:ITG8]TRSTYPE(nolign-1)
  [F:SRU]TRSCOD = [M:ITG8]TRSCODE(nolign-1)
  [F:SRU]AUZSTA = [M:ITG8]AUZSTAE(nolign-1)
  [F:SRU]AUZSST = [M:ITG8]AUZSSTE(nolign-1)
  [F:SRU]FORSTA = [M:ITG8]FORSTAE(nolign-1)
  If dim([M:ITG8]LOCNUME)>0                       # hcb 55792
     [F:SRU]LOCNUM = [M:ITG8]LOCNUME(nolign-1)
  Endif
  [F:SRU]SHLLOT = 1

  Write [SRU]
  If fstat
    GOK = 0
    GMESSAGE=mess(13,100,1)-"TABSTORUL"
    Break
  Endif
Next
If GOK < 0 Goto FINMOD Endif

Raz IQUEST   # hcb 130505 30218
Raz WMAJRUB  # hcb 130505 30218

#--- Tableau FG ----#
For GBIDI1=0 To dim([F]OTRSTYP)-1
    [F]OTRSTYP(GBIDI1) = [M:ITG5]OTRSTYP(GBIDI1)
    [F]OVECOD(GBIDI1)  = [M:ITG5]OVECOD(GBIDI1)
    [F]OVECPNFLG(GBIDI1)  = [M:ITG5]OVECPNFLG(GBIDI1)
Next

$FINMOD
Return

$INIMOD
Call MAJTEXTRA([M:ITG0]TCLAXX,"ITMCATEG","TCLAXX",[M:ITG0]TCLCOD,"") From ATEXTRA
Call MAJTEXTRA([M:ITG1]TCLSHOAXX,"ITMCATEG","TCLSHOAXX",[M:ITG0]TCLCOD,"") From ATEXTRA

# Issue 70985 - 2012-03-12 by MUARN : landed cost cout achat forfaitaire
If [M:ITG1]PURFLG = 2
  WMNTORG = [M:ITG6]CPRAMT
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG,WMNTDES,SPSTAT) From TRTDEV
  If !SPSTAT  [F:ITG]CPRAMT = WMNTDES : Endif
Endif
# fin Issue 70985 - 2012-03-12 by MUARN : landed cost cout achat forfaitaire

Return

$MAJ_ITF
If dim([M:ITG2]LOCDES) > 0                                                 # hcb X3-71908
    For [IMF]
        #--- Jira X3-50162
        # S'il existe une catégorie site, pas de répercussion de la catégorie sur l'article site
        If [M:ITG0]STOFCY=""
          Read [ITG]ITG0=[F:ITF]STOFCY;[F:ITM]TCLCOD
          If !fstat Goto NEXT_IMF Endif
        Endif
        #---
        Readlock [ITF]Curr
        If !fstat & [F:ITF]LOCMGTCOD>1
        #--- Màj emplacements ----#
            Read [ITF1]ITF0=[F:ITF]ITMREF;[F:ITF]STOFCY
            If !fstat
                Raz [F:ITF]LOCNUM, [F:ITF]DEFLOCTYP, [F:ITF]DEFLOC
                  For I=0 To [M:ITG2]NBINT-1                                                  # hcb X3-71908
                    [F:ITF]LOCNUM(I) = [M:ITG2]LOCDES(I)                                      # hcb X3-71908
                    J=find([F:ITF]LOCNUM(I),[F:ITF1]LOCNUM(0..dim([F:ITF1]LOCNUM)-1))
                    If J>0
                        [F:ITF]DEFLOCTYP(I)=[F:ITF1]DEFLOCTYP(J-1)
                        [F:ITF]DEFLOC(I)   =[F:ITF1]DEFLOC(J-1)
                    Endif
                  Next
                Rewrite [ITF]
                If fstat
                    GOK = 0
                    Call RSTA("ITF",[F:ITF]ITMREF-[F:ITF]STOFCY) From GLOCK
                    Break
                Endif
            Endif
        Endif
    #--- Jira X3-50162
    $NEXT_IMF
    Next
Endif
Return

$VERF_ANU
# si on veut annuler une catégorie : voir s'il existe des catégorie/sites
If [M:ITG0]STOFCY = ""
  For [ITGS] Where TCLCOD=[M:ITG0]TCLCOD & STOFCY<>""
    GMESSAGE = mess(354,199,1)  # "Des enreg catég-site existent..."
    GERR = 1
    OK = 0
    Break
  Next
Endif
Return

$ANNULE
    Delete [AXX] Where CODFIC="ITMCATEG" & ZONE="TCLAXX" & IDENT1=[M:ITG0]TCLCOD & IDENT2=[M:ITG0]STOFCY
    Delete [AXX] Where CODFIC="ITMCATEG" & ZONE="TCLSHOAXX" & IDENT1=[M:ITG0]TCLCOD & IDENT2=[M:ITG0]STOFCY
Return


$SETBOUT
CHMEN += "B"
Return

#############################################################
# Activation et désactivation
# des champs de gestion des règles de gestion
#############################################################
Subprog ETAT_ZONE_SRU(LTRSTYP,LNOL)
Value Integer LTRSTYP
Value Integer LNOL

# Ctrl qualité, Retour prêt et s-traitance, Chgt stock, Entrée trf
If find(LTRSTYP,8,18,26,28,33)
  If dim([M:ITG8]DACLOT)>0
    Grizo [M:ITG8]DACLOT(LNOL)
    Grizo [M:ITG8]LOTSUPINH(LNOL)
    [M:ITG8]DACLOT(LNOL)    = 2
    [M:ITG8]LOTSUPINH(LNOL) = 1
  Endif
  # Ctrl qualité
  If LTRSTYP=8
    Grizo [M:ITG8]QLYCTLFLG(LNOL)
    [M:ITG8]QLYCTLFLG(LNOL) = 1
  Else
    Actzo [M:ITG8]QLYCTLFLG(LNOL)
  Endif
  # Chgt stock
  If LTRSTYP=26
    Grizo [M:ITG8]DEFSTA(LNOL)
    Raz [M:ITG8]DEFSTA(LNOL)
  Else
    Actzo [M:ITG8]DEFSTA(LNOL)
  Endif
Elsif dim([M:ITG8]DACLOT)>0
  Actzo [M:ITG8]DACLOT(LNOL)
  Actzo [M:ITG8]LOTSUPINH(LNOL)
Endif

#--- Issue X3-53322
# Ctrl qualité, Chgt stock, Entrée trf, Entrée OF et Réintégration stock (à supprimer quand GP)
If find(LTRSTYP,8,26,28,5,19)
  If dim([M:ITG8]DACCTR)>0
    Grizo [M:ITG8]DACCTR(LNOL)
    [M:ITG8]DACCTR(LNOL) = 1
  Endif
Elsif dim([M:ITG8]DACCTR)>0
  Actzo [M:ITG8]DACCTR(LNOL)
Endif
#---

#If LTRSTYP=34     # Demande analyse
#   Grizo [M:ITG8]DACLOT   (LNOL)
#   Grizo [M:ITG8]LOTSUPINH(LNOL)
#   Grizo [M:ITG8]AUZSTAE  (LNOL)
#   Grizo [M:ITG8]QLYCTLFLG(LNOL)
#   [M:ITG8]DACLOT         (LNOL) = 1
#   [M:ITG8]LOTSUPINH      (LNOL) = 1
#   [M:ITG8]AUZSTAE        (LNOL) = 2
#   [M:ITG8]QLYCTLFLG      (LNOL) = 2
#Endif

If dim([M:ITG4]LOCNUM)>0
  # Sortie transfert
  If LTRSTYP=27
    Grizo [M:ITG4]LOCNUM(LNOL)
    Grizo [M:ITG4]LOCNUM2(LNOL)
    Grizo [M:ITG4]LOCNUM3(LNOL)
    [M:ITG4]LOCNUM(LNOL) =0
    [M:ITG4]LOCNUM2(LNOL)=0
    [M:ITG4]LOCNUM3(LNOL)=0
  Else
    Actzo [M:ITG4]LOCNUM(LNOL)
    Actzo [M:ITG4]LOCNUM2(LNOL)
    Actzo [M:ITG4]LOCNUM3(LNOL)
  Endif
Endif
#--- TS 106217
If dim([M:ITG4]ORDVER)>0    # hc
   If LTRSTYP=27
      Grizo [M:ITG4]ORDVER(LNOL)
      [M:ITG4]ORDVER(LNOL)=1
   Elsif find(LTRSTYP,11,32)
      Grizo [M:ITG4]AUZPRO(LNOL)
      [M:ITG4]AUZPRO(LNOL)=3
      Grizo [M:ITG4]AUZACT(LNOL)
      [M:ITG4]AUZACT(LNOL)=3
      Grizo [M:ITG4]AUZSTP(LNOL)
      [M:ITG4]AUZSTP(LNOL)=3
      Grizo [M:ITG4]ORDVER(LNOL)
      [M:ITG4]ORDVER(LNOL)=1
   Else
      Actzo [M:ITG4]AUZPRO(LNOL)
      Actzo [M:ITG4]AUZACT(LNOL)
      Actzo [M:ITG4]AUZSTP(LNOL)
      Actzo [M:ITG4]ORDVER(LNOL)
   Endif
Endif                      # hc
#---
End

