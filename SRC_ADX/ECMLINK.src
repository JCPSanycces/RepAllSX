#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
# Create or view a Symphony web store -- ECMLINK
#
# This logic uses a JavaScript bundle and makes calls to XM Symphony web services.
#
# If a Symphony store does not exist for the arguments passed by the call then the returned
# callbackurl will be for creating a new store.
#     For example, "https://signup.us.xmsymphony.com/?uuid=f80261bf-cd3cdf97-92149cf8".
#
# If the store already exists then the returned callbackurl will be the URL for the store.
#     For example, "abc.us.xmsymphony.com".
#
####################################################################################################
Local Char    FUNCTION(30)
Local Clbfile ARGUMENTS(0)
Local Char    RETURNS(50)
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Integer ERR
Local Char    ERRMSG(GLONAMSG)
Local Clbfile ERRMSG2(0)
Local Char    RESP(255)
Local Char    PROTO(30)
Local Char    FIL(255)
Local Char    WEBAPIURL(255)
Local Char    CLIENTELBURL(255)
Local Char    REGION(20)
Local Char    SITENAME(50)
Local Char    LOGFILE(255)
Local Char    FOLDERNAME(GLONADS)
Local Char    USERLANG(GLONLAN)
Local Char    USERLOCALE(10)

# Create log
Gosub CREATE_LOG

# Get folder name
FOLDERNAME = GACTX.AFOLDER

# Get User's current language setting
USERLANG = GACTX.LAN

# Get current site name
SITENAME = mid$(adxmac(-1), 5, len(adxmac(-1))-8)

# Get current Web API's URL
FUNCTION = 'getWebApiUrl'
Call SEND_BUNDLE_REQUEST(LOGFILE,FUNCTION,ARGUMENTS,RESHEAD,WEBAPIURL,ERR,ERRMSG)
If ERR
  End
Endif

# Get current Symphony Client farm ELB's URL
FUNCTION = 'getFarmElbUrl'
Call SEND_BUNDLE_REQUEST(LOGFILE,FUNCTION,ARGUMENTS,RESHEAD,CLIENTELBURL,ERR,ERRMSG)
If ERR
  End
Endif

# Get current Amazon Web Services region
FUNCTION = 'getAwsRegion'
Call SEND_BUNDLE_REQUEST(LOGFILE,FUNCTION,ARGUMENTS,RESHEAD,REGION,ERR,ERRMSG)
If ERR
  End
Endif

# Get current locale
FUNCTION = 'getUserProfile'
RETURNS = 'selectedLocale.code'
Call SEND_COLLABORATION_REQUEST(LOGFILE,FUNCTION,ARGUMENTS,RETURNS,RESHEAD,USERLOCALE,ERR,ERRMSG)
If ERR
  End
Endif

# Send create call to Symphony
FUNCTION = "createSymphony"
ARGUMENTS  =      '{"site":"' + SITENAME
Append ARGUMENTS, '","endpoint":"' + FOLDERNAME
Append ARGUMENTS, '","language":"' + USERLANG
Append ARGUMENTS, '","region":"' + REGION
Append ARGUMENTS, '","api":"' + WEBAPIURL
Append ARGUMENTS, '","elb":"' + CLIENTELBURL
Append ARGUMENTS, '"}'

Call SEND_BUNDLE_REQUEST(LOGFILE,FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
If ERR
  End
Endif

# Extract creation URL from response body
# The expected response form is {"callbackurl":"https://signup.us.xmsymphony.com/?uuid=1a2b-3c4d-5e6f"}
RESP = vireblc(func FINDVAL(RESBODY, "callbackurl"),4)
If RESP<>""
  # Launch creation URL in browser
  Call SPLIT_URL(RESP, PROTO, FIL)

  Callui RETOUR="" With "UIAction=" + chr$(1) + "OpenFile"
&                    ,"UILocalDir=" + chr$(1) + PROTO
&                   ,"UILocalFile=" + chr$(1) + FIL
Else
  Call ERREURT(mess(1745,10032,1)-"\"-RESBODY,1) From GESECRAN
  End
Endif

# Set change tracking on tables.
Gosub SET_CHANGE_TRACKING

# Create SOAP connection pool named E-COMMERCE_<folderName>
FUNCTION = 'createConnectionPool'
ARGUMENTS =       '"' + SITENAME + '",'
Append ARGUMENTS, '{'
Append ARGUMENTS, '"alias": "E-COMMERCE_' + FOLDERNAME + '",'
Append ARGUMENTS, '"initSize": 3,'
Append ARGUMENTS, '"maxSize": 5,'
Append ARGUMENTS, '"folder": "' + FOLDERNAME + '",'
Append ARGUMENTS, '"localePref": "' + USERLOCALE + '",'
Append ARGUMENTS, '"login": "ADMCA"'
Append ARGUMENTS, '}'

Call SEND_BUNDLE_REQUEST(LOGFILE,FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
If ERR
  End
Endif
If !instr(1, RESBODY, '"success"')
  Call ERREURT("\" + mess(30,7730,1) + "\" + RESBODY, 1) From GESECRAN  # Unable to create connection pool for E-commerce
  End
Endif

End

####################################################################################################

Subprog SEND_BUNDLE_REQUEST(LOGFILE,FUNCTION,ARGUMENTS,RESHEAD,RESBODY,ERR,ERRMSG)
  Value    Char    LOGFILE
  Value    Char    FUNCTION
  Value    Clbfile ARGUMENTS
  Variable Clbfile RESHEAD
  Variable Clbfile RESBODY
  Variable Integer ERR
  Variable Char    ERRMSG

  Local Tinyint DEBUG
  Local Integer STATUSCODE
  Local Char    MODULE(100)   : MODULE = 'bundles/xm-symphony'
  Local Char    MODE(10)      : MODE   = 'wait'
  Local Char    ENCODINGS(40)
  Local Integer CALLBACKINDEX
  Local Char    RETURNS(50)
  Local Char    RETURNS_ENC(3)

  If LOGFILE > ""
    Local Instance MYLOG Using C_ALOG
    MYLOG = NewInstance C_ALOG AllocGroup null
    OK = fmet MYLOG.APPENDLOG(LOGFILE)
    DEBUG = 1
  Endif

  If DEBUG
    OK = fmet MYLOG.APUTLINE("Function = " + FUNCTION,OK)
    OK = fmet MYLOG.APUTLINE("request JSON = " + ARGUMENTS,OK)
    OK = fmet MYLOG.AFLUSHLOG
  Endif

  STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE,FUNCTION,MODE,ARGUMENTS,ENCODINGS,CALLBACKINDEX,RETURNS,RETURNS_ENC,RESHEAD,RESBODY)
  If instr(1, RESBODY, "\")
    RESBODY = unescJson(RESBODY)
  Endif

  If DEBUG
    OK = fmet MYLOG.APUTLINE("Response Header = " + RESHEAD,OK)
    OK = fmet MYLOG.APUTLINE("Response Body = " + RESBODY,OK)
    OK = fmet MYLOG.APUTLINE("",OK)
    OK = fmet MYLOG.AFLUSHLOG
   Endif

  If STATUSCODE<>200
    ERR = 1
    If STATUSCODE=500
      Call ERREURT(FUNCTION - ":" - mess(194,133,1),30) From GESECRAN
    Else
      ERRMSG = FUNCTION - ":" - num$(STATUSCODE)
      ERRMSG2 = func FINDVAL(RESHEAD, "message")
      Call ERREURT(ERRMSG+"\"+ERRMSG2, 1) From GESECRAN
    Endif
  Endif
End

####################################################################################################

Funprog FINDVAL(RESP,K)
  Value Clbfile RESP
  Value Char    K
  Local Integer X

  X = instr(1,RESP,K+'":"')
  If !X : End "" : Endif
  X += len(K)+3
End seg$(RESP,X,instr(X,RESP,'"')-1)

####################################################################################################

Subprog SPLIT_URL(RESBODY, PROTO, FIL)
  Value    Clbfile RESBODY
  Variable Char    PROTO
  Variable Char    FIL

  PROTO = toupper(left$(RESBODY, instr(1,RESBODY,'://')-1))
  FIL = right$(RESBODY, instr(1,RESBODY,'://')+3)

End

####################################################################################################

$CREATE_LOG

  # Set up logging
  Local Instance MYLOG Using C_ALOG
  MYLOG = NewInstance C_ALOG AllocGroup null
  OK = fmet MYLOG.ABEGINLOG(mess(29,7730,1))   # "E-commerce site creation"
  LOGFILE = fmet MYLOG.AGETNAME
  OK = fmet MYLOG.AENDLOG
  FreeGroup MYLOG

Return

####################################################################################################

Funprog GET_DB_TYPE()

  Local Integer DBTYPE
  Local Char DATABASE_TYPE(10)

  DBTYPE = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,"","TYPDBA")
  DATABASE_TYPE = string$(DBTYPE=1,"O")+string$(DBTYPE=2,"S")

End DATABASE_TYPE

####################################################################################################

$SET_CHANGE_TRACKING

# Each table should have two lines: one for enabling change tracking and another for granting access
# to the Symphony user.

DATABASE_TYPE = func GET_DB_TYPE()

Onerrgo CHANGE_TRACKING_ERROR
