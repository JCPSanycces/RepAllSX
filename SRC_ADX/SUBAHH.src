#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet AHH
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AHH",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE_BOITE"     : Gosub OUVRE_BOITE
 When "OUVRE"           : Gosub OUVRE
 When "TIROIR"          : Gosub TIROIR 
 When "DEB_PICK"        : Gosub DEB_PICK
 When "PICKE"           : Gosub PICKE
 When "FIN_PICK"        : Gosub FIN_PICK
 When "DEPICK"          : Gosub DEPICK
 When "LIENS"           : Gosub LIENS 
 When "VERIF_CRE"       : Gosub VERIF_INTIT
 When "VERIF_MOD"       : Gosub VERIF_INTIT
 When "INIMOD"          : Gosub INIMOD
 When "INICRE"          : Gosub INICRE
 When "APRES_MODIF"     : Gosub APRES_MODIF
 When "FIN_ACTION"      : Gosub FIN_ACTION
 When "APRES_CHOI"      : Gosub APRES_CHOI
 When "ABANDON"         : Gosub ABANDON
 When "DEBUT"           : Gosub DEBUT
 When "SETBOUT"         : Gosub SETBOUT
Endcase
Return

$SETBOUT
Local Integer STA
STA = 1
Call VERIF_INTITULE_VARIABLE([M]ABM,nomap,STA) From ABICREUNV
If !STA 
 Call VIREBOUT(CHAINE,"M1") From GOBJET
Endif
Return

$DEBUT
#Global Char BOXVAL(10) , BOXPAR(10)
#BOXVAL = "GAU_CHE"+num$(find("AD5",OBJLIS(1..dim(OBJLIS)-1)))
Return

$OUVRE
Local Integer   NBOBJET : NBOBJET = 2500
Local Char      LIEN1(250),LIEN2(250)
Local Char      TCLASSE2(50)(1..NBOBJET),TSCLASSE2(50)(1..NBOBJET),TOBJ2(80)(1..NBOBJET)
Local Char      TORD_OBJ(80)(1..NBOBJET)
Local Integer   NBOBJ2,TORD2(1..NBOBJET),OKPICK,NOL,OKK
Local Char     TABDEF(50)(1..NBOBJET),CHPDEF(50)(1..NBOBJET),TABDEF2(250)(1..NBOBJET)
Local Char     TYPDEF(50)(1..NBOBJET),TABM(GLONABM)(1..NBOBJET)

Local File   (Char CLASSE(50) ,  Char SCLASSE(50) , Char ORD_OBJET(80)
&            ,Char WTABDEF(50),Char WCHPDEF(50),  Char WTABDEF2(250), Char WTYPDEF(50) , Char WABM(GLONABM)) 
&             From Variable TCLASSE2, TSCLASSE2 ,TORD_OBJ,TABDEF,CHPDEF,TABDEF2,TYPDEF,TABM As [AH2] 
&             Order By CLASSE; SCLASSE ;  ORD_OBJET

If !clalev([F:AHH2]) : Local File ABIHIERA [AHH2]  : Endif
Gosub CHARGE
Return

$LIENS
Local Integer STA
STA = 1
Call VERIF_INTITULE_VARIABLE([M]ABM,nomap,STA) From ABICREUNV
If !STA 
 Call ERREUR(func AFNC.MES1(mess(101,148,1),[M]ABM)) From GESECRAN
Endif
Gosub CHARGE
Call TEXTE([M:AHH1]DES,[M:AHH1]ZDES) From OBJDIV
[M]NBAHH = 0
J = [F:AHH]NBAHH-1
[F:AHH]NBAHH = 0
For I=0 To J
 LIEN1 = [F:AHH]CODABF(I)-[F:AHH]CODFLD(I)-[F:AHH]TYPOPT(I)
 If [F:AHH]CODDIM1(I) <> ""
  LIEN1 -= [F:AHH]CODDIM1(I)+";"+[F:AHH]FLDDIM1(I)
  If [F:AHH]CODDIM2(I) <> ""
   LIEN1 += ";"+[F:AHH]CODDIM2(I)+";"+[F:AHH]FLDDIM2(I)
   If [F:AHH]CODDIM3(I) <> ""
    LIEN1 += ";"+[F:AHH]CODDIM3(I)+";"+[F:AHH]FLDDIM3(I)
    If [F:AHH]CODDIM4(I) <> ""
     LIEN1 += ";"+[F:AHH]CODDIM4(I)+";"+[F:AHH]FLDDIM4(I)
     If [F:AHH]CODDIM5(I) <> ""
      LIEN1 += ";"+[F:AHH]CODDIM5(I)+";"+[F:AHH]FLDDIM5(I)
      If [F:AHH]CODDIM6(I) <> ""
       LIEN1 += ";"+[F:AHH]CODDIM6(I)+";"+[F:AHH]FLDDIM6(I)
       If [F:AHH]CODDIM7(I) <> ""
        LIEN1 += ";"+[F:AHH]CODDIM7(I)+";"+[F:AHH]FLDDIM7(I)
        If [F:AHH]CODDIM8(I) <> ""
         LIEN1 += ";"+[F:AHH]CODDIM8(I)+";"+[F:AHH]FLDDIM8(I)
         If [F:AHH]CODDIM9(I) <> ""
          LIEN1 += ";"+[F:AHH]CODDIM9(I)+";"+[F:AHH]FLDDIM9(I)
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
 For [AH2] Where CLASSE <> "" 
  If vireblc(LIEN1,1) =vireblc([F:AH2]WTABDEF-[F:AH2]WCHPDEF-[AH2]WTYPDEF-[F:AH2]WTABDEF2,1)
   [M:AHH1]CLASSE([M:AHH1]NBAHH)  = [F:AH2]CLASSE
   [M:AHH1]SCLASSE([M:AHH1]NBAHH) = [F:AH2]SCLASSE
   [M:AHH1]OBJET([M:AHH1]NBAHH)   = right$([F:AH2]ORD_OBJET,instr(0,[F:AH2]ORD_OBJET,"#")+1)
   [M:AHH1]COMBI([M:AHH1]NBAHH)   = [F:AH2]CLASSE+[F:AH2]SCLASSE+right$([F:AH2]ORD_OBJET,instr(0,[F:AH2]ORD_OBJET,"#")+1)
   [M:AHH1]NBAHH += 1
   Break
  Endif
 Next AH2
Next I
Return

$STYLE
Local Char STYLE(GLONASY)
STYLE = "SELECTION"
Return

$ABANDON
Raz [F:AH2]
Gosub CHARGE
Gosub REMPLIT
Return

$GRISE_ABM
Case currbox
 When BOXPIC  : Grizo [M]ABM
 When Default : Actzo [M]ABM
Endcase
Return

$OUVRE_BOITE
Local Char BOXPIC(10),BOXLST
BOXPIC = "GAU_CHE"+num$(find("AH2",OBJLIS(1..dim(OBJLIS)-1)))
BOXLST = "GAU_CHE"
If num$(find("AHH",OBJLIS(1..dim(OBJLIS)-1))) <> "0"
 BOXLST+=num$(find("AHH",OBJLIS(1..dim(OBJLIS)-1)))
Endif
Return

$VERIF_INTIT
If [M]NBAHH = 0 
 OK =0
 Call ERREUR([M:AHH1]COD-'('+[M:AHH1]ZDES+') :'-mess(61,148,1)) From GESECRAN 
 # Il faut au moins un niveau de hiérarchie
 Return
Endif
Local Char INTITULE(80)
OK=1
If [M:AHH1]INTEVAL = ""
 INTITULE = [M:AHH1]ZDES
Else
 INTITULE = evalue([M:AHH1]INTEVAL)
Endif
For [AHH2]AHH0 Where ABM = [M:AHH1]ABM & COD <> [M:AHH1]COD
 If [F:AHH2]INTEVAL = ""
  If func AFNC.TEXTE([F:AHH2]DES) = INTITULE 
   OK =0
   Break
  Endif
 Else
  If evalue([F:AHH2]INTEVAL)= INTITULE
   OK =0
   Break
  Endif
 Endif
Next
If !OK
 Call ERREUR(INTITULE-":"-mess(60,148,1)) From GESECRAN 
 Return
 # Il existe déja une hiérarchie ayant le même nom pour ce datamart
Endif
Return

$INICRE
Gosub TRANSFERT
Return

$INIMOD
Gosub TRANSFERT
Return

$TRANSFERT
Local Char    CHAINE(50)(0..18), WCHAINE(250)
Local Integer II
Raz [F:AHH]CODABF,[F:AHH]CODFLD,[F:AHH]TYPOPT
[F:AHH] = [M:AHH1]
For I=0 To [M]NBAHH-1
 For [AH2] Where CLASSE <> "" 
  Raz WCHAINE,CHAINE,II,J
  If [M:AHH1]CLASSE(I)-[M:AHH1]SCLASSE(I)-[M:AHH1]OBJET(I)=[F:AH2]CLASSE-[F:AH2]SCLASSE-right$([F:AH2]ORD_OBJET,instr(0,[F:AH2]ORD_OBJET,"#")+1)
   [F:AHH]CODABF(I)= [F:AH2]WTABDEF
   [F:AHH]CODFLD(I)= [F:AH2]WCHPDEF
   [F:AHH]TYPOPT(I)= [F:AH2]WTYPDEF
   WCHAINE = [AH2]WTABDEF2
   J= instr(0,WCHAINE,";")
   While J>0
    CHAINE(II) = left$(WCHAINE,J-1)
    WCHAINE   = right$(WCHAINE,J+1)
    J= instr(0,WCHAINE,";")
    II+=1
   Wend
   If II > 0
    CHAINE(II) = WCHAINE
   Endif
   [F:AHH]CODDIM1(I) = CHAINE(0)
   [F:AHH]FLDDIM1(I) = CHAINE(1)
   [F:AHH]CODDIM2(I) = CHAINE(2)
   [F:AHH]FLDDIM2(I) = CHAINE(3)
   [F:AHH]CODDIM3(I) = CHAINE(4)
   [F:AHH]FLDDIM3(I) = CHAINE(5)
   [F:AHH]CODDIM4(I) = CHAINE(6)
   [F:AHH]FLDDIM4(I) = CHAINE(7)
   [F:AHH]CODDIM5(I) = CHAINE(8)
   [F:AHH]FLDDIM5(I) = CHAINE(9)
   [F:AHH]CODDIM6(I) = CHAINE(10)
   [F:AHH]FLDDIM6(I) = CHAINE(11)
   [F:AHH]CODDIM7(I) = CHAINE(12)
   [F:AHH]FLDDIM7(I) = CHAINE(13)
   [F:AHH]CODDIM8(I) = CHAINE(14)
   [F:AHH]FLDDIM8(I) = CHAINE(15)
   [F:AHH]CODDIM9(I) = CHAINE(16)
   [F:AHH]FLDDIM9(I) = CHAINE(17)
   Break
  Endif
 Next AH2
Next I
Return

$APRES_MODIF
Case currbox
 When BOXPIC
  Case zoncou
   When "NBAHH"
    Case status
     When 65 : # Suppression ligne
      If currbox = BOXPIC
       Gosub DEPICK_OBJET
      Endif
    Endcase
   When "ABM"
    If instr(1,GCHAINE,"M")
     Gosub CHARGE
     Gosub REMPLIT
    Endif
  Endcase
 When BOXLST
  Case zoncou
   When "ABM"
    If instr(1,GCHAINE,"M")
     Gosub CHARGE
     Gosub REMPLIT
    Endif
  Endcase
Endcase
Return

$DEPICK_OBJET
OKK = 0
For [AH2] Where CLASSE=[M:AHH1]CLASSE(nolign-1) & SCLASSE=[M:AHH1]SCLASSE(nolign-1) 
&      &   right$(ORD_OBJET,7) = [M:AHH1]OBJET(nolign-1)
 OKK = 1
Next
If OKK :  Gosub DEPICK From WGOAHH  : Endif
Return

$PICK_OBJET
For I=0 To [M]NBAHH
 OKK =0
 For [AH2] Where CLASSE=[M:AHH1]CLASSE(I) & SCLASSE=[M:AHH1]SCLASSE(I) & right$(ORD_OBJET,7) = [M:AHH1]OBJET(I)
  OKK = 1
  Break
 Next
 If OKK : #  Setlbox [AHH1] GAU_CHE2 : Endif   : # GAU_CHE2
  Case currbox
   When BOXPIC
    Case BOXPIC
     When "GAU_CHE1" : Setlbox [AHH1] GAU_CHE1
     When "GAU_CHE2" : Setlbox [AHH1] GAU_CHE2
     When "GAU_CHE3" : Setlbox [AHH1] GAU_CHE3
     When "GAU_CHE4" : Setlbox [AHH1] GAU_CHE4
    Endcase
  Endcase
 Endif
Next I
Return

$FIN_ACTION
Case currbox
 When BOXPIC
  Case REPONSE     
   When GSTAFIN  : Gosub PICK_OBJET 
  Endcase
Endcase
Return

#----------------------------------------------------------#
$SUIVANT
Gosub ABORT From GOBJSUB
If !OK : Return : Endif 
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Read [AHH]AHH0 Next
Goto SUIVPREC

$PRECEDENT
Gosub ABORT From GOBJSUB
If !OK : Return : Endif 
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Read [AHH]AHH0 Prev
Goto SUIVPREC

$DERNIER
Gosub ABORT From GOBJSUB
If !OK : Return : Endif 
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Read [AHH]AHH0 Last
Goto SUIVPREC

$PREMIER
Gosub ABORT From GOBJSUB
If !OK : Return : Endif 
If VERROU : Gosub DEVERROU From GOBJET : Endif
Gosub SET_FILTRE From GOBJSUB
Read [AHH]AHH0 First
Goto SUIVPREC

#----------------------#
$SUIVPREC
Filter [F]
If fstat>2
 Call MESSAGE(mess(11,100,1)) From GESECRAN
 Gosub RELIT From GOBJSUB
Else
 Gosub LECTURE From GOBJSUB
Endif
Gosub REMPLIT  
Gosub PICK_OBJET 
REP = "" : GREP = ""
Return

$APRES_CHOI
Case currbox
 When BOXPIC
  Case REPONSE
   When GSTASUI  : Gosub SUIVANT   : REPONSE = 0
   When GSTAPRE  : Gosub PRECEDENT : REPONSE = 0
   When GSTAFIR  : Gosub PREMIER   : REPONSE = 0
   When GSTALAS  : Gosub DERNIER   : REPONSE = 0
   When GSTARAF 
    Gosub REMPLIT  
    Gosub PICK_OBJET 
    REPONSE = 0
   When GSTAFIN  
    Read [AHH]AHH0 = [M]COD
    If !fstat
     [M]ABM = [F:AHH]ABM
     Gosub REMPLIT
    Endif
  Endcase
Endcase
Return

$TIROIR
If [M]ABM = "" : Return : Endif
Gosub REMPLIT
Gosub PICK_OBJET
Return

$DEB_PICK
OKPICK = 0
Return

$PICKE
OK = 1
NOL = find([F:AH2]CLASSE+[F:AH2]SCLASSE+right$([F:AH2]ORD_OBJET,7),[M:AHH1]COMBI(0..[M:AHH1]NBAHH-1))
If NOL : OK = 0 : Return : Endif
nolign = [M:AHH1]NBAHH + 1
If nolign>dim([M:AHH1]CLASSE)-1
 #Call ERREUR("Tableau plein") From GESECRAN
 OK = 0
 Return
Endif
[M:AHH1]CLASSE(nolign-1)   = [F:AH2]CLASSE
[M:AHH1]SCLASSE(nolign-1)  = [F:AH2]SCLASSE
[M:AHH1]OBJET(nolign-1)    = right$([F:AH2]ORD_OBJET,7)
[M:AHH1]COMBI(nolign-1)    = [F:AH2]CLASSE+[F:AH2]SCLASSE+right$([F:AH2]ORD_OBJET,7)
[M:AHH1]NBAHH = nolign
OKPICK = 1
Return

$FIN_PICK
If OKPICK
 Affzo 20
 Gosub STYLE
 Chgstl [M]NBAHH With ""
 Chgstl [M]NBAHH(nolign-1) With STYLE
Endif
Return

$DEPICK 
NOL = find([F:AH2]CLASSE+[F:AH2]SCLASSE+right$([F:AH2]ORD_OBJET,7),[M:AHH1]COMBI(0..[M:AHH1]NBAHH-1))
If NOL>0
 Dela NOL-1,1,[M]NBAHH [M]NBAHH
 [M]NBAHH -= 1
 OKPICK = 0
 Affzo 20
Else
 OK = 0
Endif
Return

$REMPLIT
Case currbox
 When BOXPIC
  Read [AH2] First
  If [AH2]WABM <> [M:AHH1]ABM : Gosub CHARGE : Endif
  adxmxl = NBOBJ2
  Filter [AH2] Order By CLASSE ; SCLASSE ; ORD_OBJET
  Case currbox
   When BOXPIC 
   When "GAU_CHE2" :  Fillbox [AHH1] GAU_CHE2 
  Endcase
  Case currbox
   When BOXPIC
    Case BOXPIC
     When "GAU_CHE1" : Fillbox [AHH1] GAU_CHE1
     When "GAU_CHE2" : Fillbox [AHH1] GAU_CHE2
     When "GAU_CHE3" : Fillbox [AHH1] GAU_CHE3
     When "GAU_CHE4" : Fillbox [AHH1] GAU_CHE4
    Endcase
  Endcase
  Filter [AH2]
 Endcase
Return

$CHARGE
Read [AH2] First
If [AH2]WABM = [M:AHH1]ABM : Return : Endif

Local Integer STA
STA = 1
Call VERIF_INTITULE_VARIABLE([M]ABM,nomap,STA) From ABICREUNV
If !STA : Return : Endif

Raz  TCLASSE2,TSCLASSE2,TOBJ2,TORD_OBJ,NBOBJ2,TABDEF,CHPDEF,TABDEF2,TYPDEF,STA
Call CRE_CLASS_OBJ(nomap,[M]ABM,TCLASSE2,TSCLASSE2,TOBJ2,TORD2,TABDEF,CHPDEF,
&                  TABDEF2,TYPDEF,NBOBJ2,GLANGUE,STA) From ABICREDES
If STA : Return : Endif

Read [F:ABM]ABM0=[M]ABM
For I=1 To NBOBJET
 If   TOBJ2(I) <> ""
  TORD_OBJ(I)  = space$(5-len(num$(TORD2(I))))+num$(TORD2(I))+"#"+ TOBJ2(I)
  TCLASSE2(I) = [F:ABM]ABR
 Else
  TCLASSE2(I)  = chr$(255)
 Endif
 TABM(I) = [M]ABM
Next I

Return

#####################################################################################
## Ecran AHH1
######################################################################################

Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
If clalev([F:AWM])=0 : Local File ABIDATMRT [ABM] : Endif
Read [ABM]ABM0 = [M:AHH1]ABM
If !fstat
 VALEUR = [ABM]MODULE
Endif
End

Subprog CL_HAUT(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Local Char CLA(50),SCL(50),OBJ(80),COMB(250)
If [M]CLASSE(nolign-1) = ""  | nolign = 1
 End
Else 
 Gosub STYLE
 NOL = nolign-1
 CLA  = [M:AHH1]CLASSE(NOL)
 SCLA = [M:AHH1]SCLASSE(NOL)
 OBJ  = [M:AHH1]OBJET(NOL)
 COMB = [M:AHH1]COMBI(NOL)
 [M:AHH1]CLASSE(NOL)     = [M:AHH1]CLASSE(NOL-1)
 [M:AHH1]SCLASSE(NOL)    = [M:AHH1]SCLASSE(NOL-1)
 [M:AHH1]OBJET(NOL)      = [M:AHH1]OBJET(NOL-1)
 [M:AHH1]COMBI(NOL)      = [M:AHH1]COMBI(NOL-1)
 [M:AHH1]CLASSE(NOL-1)   = CLA
 [M:AHH1]SCLASSE(NOL-1)  = SCLA
 [M:AHH1]OBJET(NOL-1)    = OBJ
 [M:AHH1]COMBI(NOL-1)    = COMB
 Affzo 20
 Chgstl [M]NBAHH(NOL) With ""
 Chgstl [M]NBAHH(NOL-1) With STYLE
 nolign = NOL
 mkstat = 4
Endif
End

Subprog CL_BAS(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Local Char CLA(50),SCL(50),OBJ(80),COMB(250)
If [M]CLASSE(nolign-1) = ""  | nolign = [M]NBAHH
 End
Else 
 Gosub STYLE
 NOL = nolign-1
 CLA  = [M:AHH1]CLASSE(NOL)
 SCLA = [M:AHH1]SCLASSE(NOL)
 OBJ  = [M:AHH1]OBJET(NOL)
 COMB = [M:AHH1]COMBI(NOL)
 [M:AHH1]CLASSE(NOL)     = [M:AHH1]CLASSE(NOL+1)
 [M:AHH1]SCLASSE(NOL)    = [M:AHH1]SCLASSE(NOL+1)
 [M:AHH1]OBJET(NOL)      = [M:AHH1]OBJET(NOL+1)
 [M:AHH1]COMBI(NOL)      = [M:AHH1]COMBI(NOL+1)
 [M:AHH1]CLASSE(NOL+1)   = CLA
 [M:AHH1]SCLASSE(NOL+1)  = SCLA
 [M:AHH1]OBJET(NOL+1)    = OBJ
 [M:AHH1]COMBI(NOL+1)    = COMB
 Affzo 20
 Chgstl [M]NBAHH With ""
 Chgstl [M]NBAHH(NOL+1) With STYLE
 nolign = NOL +2
 mkstat = 4
Endif
End

Subprog AS_NBAHH
If nolign>0 & nolign<=[M]NBAHH
 Gosub STYLE
 Chgstl [M]NBAHH With ""
 Chgstl [M]NBAHH(nolign-1) With STYLE
Endif
End

Subprog AM_ABM(VALEUR)
Variable Char    VALEUR()
Local Integer STA
STA = 1
Call VERIF_INTITULE_VARIABLE(VALEUR,nomap,STA) From ABICREUNV
If !STA
 GMESSAGE = func AFNC.MES1(mess(101,148,1),VALEUR) 
 mkstat = 2 : End
Endif
[M]ABM = VALEUR
Effzo [M:AHH1]20
End

Subprog C_INTEVAL(VALEUR)
Variable Char    VALEUR()
Local Integer    ERN
Local Char       INTITULE(80)
If VALEUR = "" & [M:AHH1]ZDES = ""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
If VALEUR = "" : End : Endif
Onerrgo ERCALC
INTITULE = evalue(VALEUR)
If ERN : Errbox mess(65,106,1)-":"-errmes$(ERN) : mkstat = 2 : End : Endif
End

$ERCALC
ERN = errn
Resume

#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap 
 Local File ABIHIERA    [AHH1]
 Local File ATEXTE      [ATX1] 
Else 
 Local File =[M]DOSORG+".ABIHIERA"    [AHH1]
 Local File =[M]DOSORG+".ATEXTE"      [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File ABIHIERA    [AHH2]
 Local File ATEXTE      [ATX2] 
Else 
 Local File =[M]DOSDES+".ABIHIERA"    [AHH2]
 Local File =[M]DOSDES+".ATEXTE"      [ATX2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AHH1] , [ATX1] , [AHH2] ,  [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AHH2], [ATX2] 
 Delete [AHH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABIHIERA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AHH2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AHH1] Where COD=TABLE
  [F:AHH2] = [F:AHH1]
  Call COPTEXTE([F:AHH1]DES,[F:AHH2]DES) From OBJDIV
  If GOK<1 : Break : Endif  
  Write [AHH2]
  If fstat
   GOK = 0 : Call FSTA("AHH2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
