#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = "BALANA"
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End


$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "INIPAR"    : Gosub INIPAR
 When "CONT1"     : Gosub CONT1
 When "CONT2"     : Gosub CONT2
Endcase
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Integer    MAXSEC : MAXSEC = 5    : #  5 niveaux de totaux
Local Integer    MAXCOL : MAXCOL = 6    : #  6 colonnes paramétrables
Local Integer    MAXSOC : MAXSOC = 50   : # 50 sociétés par regroupement
Local Integer    MAXPER : MAXPER = 3    : #  3 périodes

Local Char       PARAM(30), ETAT(GLONARP), TYP_ETAT(GLONARP)
Local Char       SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY)
Local Integer    REFERENTIEL
Local Char       BUDGET(GLONBUP) , VERSION(20)
Local Date       DATDEB(1..MAXPER) , DATFIN(1..MAXPER)
Local Integer    TYPEAXE(1..MAXSEC)
Local Char       AXE(GLONDIE)(1..MAXSEC)
Local Char       CPTDEB(GLONGAC) , CPTFIN(GLONGAC) , SECDEB(GLONCCE)(1..MAXSEC) , SECFIN(GLONCCE)(1..MAXSEC)
Local Char       PYRCPT(GLONGYM) , PYRSEC(GLONCYM)(1..MAXSEC)
Local Integer    NIVCPT , NIVSEC(1..MAXSEC)
Local Integer    RNGCPTDEB , RNGCPTFIN , RNGSECDEB(1..MAXSEC) , RNGSECFIN(1..MAXSEC)
Local Char       DEVORG(GLONCUR) , DEVIMP(GLONCUR)
Local Decimal    COURANA , COURBUD
Local Integer    TYPCOL(1..MAXCOL) , PERCOL(1..MAXCOL)
Local Integer    NBAXE , SENS , TRI , DETAIL_SITE , DETAIL_NATURE , ANOUVEAU
Local Char       PROFIL(GLONAPM) , FONCTION(GLONAFC) , USER(GLONAUS)
Local Integer    IPER , NPER
Local Integer    I , J , K , NUMREQ

Gosub OUVFIC

# Récup des paramètres

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K : ETAT = left$(ETAT,K-1) : Endif
Call GETPARAM("typetat",NBPAR,PARAMETRE,TYP_ETAT) From ETAT
If TYP_ETAT="?????" : TYP_ETAT = ETAT : Endif

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
Call GETPARAM("referentiel",NBPAR,PARAMETRE,PARAM) From ETAT    : REFERENTIEL = val(PARAM)
Call GETPARAM("budget",NBPAR,PARAMETRE,BUDGET) From ETAT
Call GETPARAM("version",NBPAR,PARAMETRE,VERSION) From ETAT
Call GETPARCHAR("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARCHAR("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("nbper",NBPAR,PARAMETRE,PARAM) From ETAT    : NPER = val(PARAM)
For IPER=1 To NPER
 Call GETPARAM("dat"+num$(IPER)+"deb",NBPAR,PARAMETRE,PARAM) From ETAT : DATDEB(IPER) = PARAM
 Call GETPARAM("dat"+num$(IPER)+"fin",NBPAR,PARAMETRE,PARAM) From ETAT : DATFIN(IPER) = PARAM
Next IPER
#Call GETPARCHAR("cptdeb",NBPAR,PARAMETRE,CPTDEB)
#Call GETPARCHAR("cptfin",NBPAR,PARAMETRE,CPTFIN)
#Call GETPARAM("pyrcpt",NBPAR,PARAMETRE,PYRCPT) From ETAT
#Call GETPARAM("nivcpt",NBPAR,PARAMETRE,PARAM) From ETAT         : NIVCPT    = val(PARAM)
#Call GETPARINT("rngcptdeb",NBPAR,PARAMETRE,PARAM)               : RNGCPTDEB = val(PARAM)
#Call GETPARINT("rngcptfin",NBPAR,PARAMETRE,PARAM)               : RNGCPTFIN = val(PARAM)
Call GETPARAM("nbaxe",NBPAR,PARAMETRE,PARAM) From ETAT          : NBAXE     = val(PARAM)
For I=1 To NBAXE
 Call GETPARAM("typ"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT   : TYPAXE(I) = val(PARAM)
 Call GETPARAM("axe"+num$(I),NBPAR,PARAMETRE,AXE(I)) From ETAT
 Call GETPARCHAR("sec"+num$(I)+"deb",NBPAR,PARAMETRE,SECDEB(I))
 Call GETPARCHAR("sec"+num$(I)+"fin",NBPAR,PARAMETRE,SECFIN(I))
 Call GETPARAM("pyrsec"+num$(I),NBPAR,PARAMETRE,PYRSEC(I)) From ETAT
 Call GETPARAM("nivsec"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT         : NIVSEC(I)    = val(PARAM)
 Call GETPARINT("rngsec"+num$(I)+"deb",NBPAR,PARAMETRE,PARAM)            : RNGSECDEB(I) = val(PARAM)
 Call GETPARINT("rngsec"+num$(I)+"fin",NBPAR,PARAMETRE,PARAM)            : RNGSECFIN(I) = val(PARAM)
Next I
Call GETPARAM("devorg",NBPAR,PARAMETRE,DEVORG) From ETAT
Call GETPARAM("devimp",NBPAR,PARAMETRE,DEVIMP) From ETAT
Call GETPARAM("courana",NBPAR,PARAMETRE,PARAM) From ETAT        : COURANA = val(PARAM)
Call GETPARAM("courbud",NBPAR,PARAMETRE,PARAM) From ETAT        : COURBUD = val(PARAM)
For I=1 To MAXCOL
 Call GETPARAM("typcol"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT : TYPCOL(I) = val(PARAM)
Next I
Call GETPARAM("sens",NBPAR,PARAMETRE,PARAM) From ETAT           : SENS = val(PARAM)
Call GETPARAM("tri",NBPAR,PARAMETRE,PARAM) From ETAT            : TRI  = val(PARAM)
Call GETPARAM("detail_site",NBPAR,PARAMETRE,PARAM) From ETAT    : DETAIL_SITE = val(PARAM)
Call GETPARAM("detail_nature",NBPAR,PARAMETRE,PARAM) From ETAT  : DETAIL_NATURE = val(PARAM)
Call GETPARAM("anouveau",NBPAR,PARAMETRE,PARAM) From ETAT       : ANOUVEAU = val(PARAM)
Call GETPARAM("X3PRF",NBPAR,PARAMETRE,PROFIL) From ETAT
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,FONCTION) From ETAT
Call GETPARAM("X3USR",NBPAR,PARAMETRE,USER) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT      : NUMREQ = val(PARAM)
If NPER>1
 For I=1 To MAXCOL
  Call GETPARAM("percol"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT : PERCOL(I) = val(PARAM)
 Next I
Endif

Call BALANA(ETAT,TYP_ETAT,SOCIETE,REFERENTIEL,BUDGET,VERSION,SITEDEB,SITEFIN,NPER,DATDEB,DATFIN
&          ,NBAXE,TYPAXE,AXE,SECDEB,SECFIN,PYRSEC,NIVSEC,RNGSECDEB,RNGSECFIN
&          ,DEVORG,DEVIMP,COURANA,COURBUD,TYPCOL,PERCOL,SENS,TRI
&          ,DETAIL_SITE,DETAIL_NATURE,ANOUVEAU,PROFIL,FONCTION,USER,NUMREQ)

For IPER=1 To NPER
 PARAM = format$("D:YYYYMMDD",DATDEB(IPER))
 Call SETPARAM("dat"+num$(IPER)+"deb",NBPAR,PARAMETRE,PARAM) From ETAT
 PARAM = format$("D:YYYYMMDD",DATFIN(IPER))
 Call SETPARAM("dat"+num$(IPER)+"fin",NBPAR,PARAMETRE,PARAM) From ETAT
Next IPER

PARAM = num$(NUMREQ)
Call SETPARAM("numreq",NBPAR,PARAMETRE,PARAM) From ETAT
Read [CPY]CPY0 = SOCIETE
Call SETPARAM("libcpy",NBPAR,PARAMETRE,[F:CPY]CPYNAM) From ETAT
End

###########################################################################################################
###########################################################################################################
Subprog BALANA(ETAT,TYP_ETAT,SOCIETE,REFERENTIEL,BUDGET,VERSION,SITEDEB,SITEFIN,NPER,DATDEB,DATFIN
&             ,NBAXE,TYPAXE,AXE,SECDEB,SECFIN,PYRSEC,NIVSEC,RNGSECDEB,RNGSECFIN
&             ,DEVORG,DEVIMP,COURANA,COURBUD,TYPCOL,PERCOL,SENS,TRI
&             ,DETAIL_SITE,DETAIL_NATURE,ANOUVEAU,PROFIL,FONCTION,USER,NUMREQ)
Value    Char    ETAT
Value    Char    TYP_ETAT
Value    Char    SOCIETE
Value    Integer REFERENTIEL
Value    Char    BUDGET
Value    Char    VERSION
Value    Char    SITEDEB
Value    Char    SITEFIN
Value    Integer NPER
Variable Date    DATDEB(1..)
Variable Date    DATFIN(1..)
Value    Integer NBAXE
Value    Integer TYPAXE(1..)
Value    Char    AXE()(1..)
Value    Char    SECDEB()(1..)
Value    Char    SECFIN()(1..)
Value    Char    PYRSEC()(1..)
Value    Integer NIVSEC(1..)
Value    Integer RNGSECDEB(1..)
Value    Integer RNGSECFIN(1..)
Value    Char    DEVORG
Value    Char    DEVIMP
Value    Decimal COURANA
Value    Decimal COURBUD
Value    Integer TYPCOL(1..)
Value    Integer PERCOL(1..)
Value    Integer SENS
Value    Integer TRI
Value    Integer DETAIL_SITE
Value    Integer DETAIL_NATURE
Value    Integer ANOUVEAU
Value    Char    PROFIL
Value    Char    FONCTION
Value    Char    USER
Value    Integer NUMREQ

# Déclarations

Local Integer    MAXSEC : MAXSEC = dim(AXE)
Local Integer    MAXCOL : MAXCOL = dim(TYPCOL)
Local Integer    MAXSOC : MAXSOC = 50   : # 50 sociétés par regroupement
Local Integer    MAXPER : MAXPER = dim(DATDEB)

Local Char       REFER(GLONLED) , DEVREF(GLONCUR)
Local Integer    NUMAXE(1..MAXSEC)
Local Integer    IPER
Local Integer    GROUPE , ANA , QTE , BUD , ENG
Local Integer    I , J , K , LIGNE , PASSE , EFFACE
Local Integer    ICRIT
Local Char       CRITERE(250)(1..10) , CRITBUD(250)(1..10) , CRITSOC(250) , CLE(250)
Local Char       PROG(GLONADC) , FICSRC(250) , FICADX(250)
Local Integer    STAT , OK
Local Integer    BUDSIT , NUMBUD(1..MAXSEC)
Local Char       SECTION(20)
Local Integer    ISOC , NBSOC
Local Decimal    EDEB(1..MAXPER,1..MAXSOC) , EFIN(1..MAXPER,1..MAXSOC)
Local Decimal    PDEB(1..MAXPER,1..MAXSOC) , PFIN(1..MAXPER,1..MAXSOC)
Local Char       SOC(GLONCPY)(1..MAXSOC)
Local Date       TBPER(1..100) , FINPER
Local Integer    NIVPYR , OKBUD
Local Char       GROUPYR(max(GLONGYM,GLONCYM))
Local Char       DESIG(GLONAX3)

EFFACE = 1

# Ouverture des tables

Gosub OUVFIC
For I=1 To NBAXE
 Case TYPAXE(I)
  When 1
   Case I
    When 1
     If clalev([F:GAC1])=0 : Local File GACCOUNT   [GAC1] : Endif
     If clalev([F:GYK1])=0 : Local File GACCPYMLIK [GYK1] : Endif
     If clalev([F:GRY1])=0 : Local File GACCGRUPYM [GRY1] : Endif
    When 2
     If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif
     If clalev([F:GYK2])=0 : Local File GACCPYMLIK [GYK2] : Endif
     If clalev([F:GRY2])=0 : Local File GACCGRUPYM [GRY2] : Endif
    When 3
     If clalev([F:GAC3])=0 : Local File GACCOUNT   [GAC3] : Endif
     If clalev([F:GYK3])=0 : Local File GACCPYMLIK [GYK3] : Endif
     If clalev([F:GRY3])=0 : Local File GACCGRUPYM [GRY3] : Endif
    When 4
     If clalev([F:GAC4])=0 : Local File GACCOUNT   [GAC4] : Endif
     If clalev([F:GYK4])=0 : Local File GACCPYMLIK [GYK4] : Endif
     If clalev([F:GRY4])=0 : Local File GACCGRUPYM [GRY4] : Endif
    When 5
     If clalev([F:GAC5])=0 : Local File GACCOUNT   [GAC5] : Endif
     If clalev([F:GYK5])=0 : Local File GACCPYMLIK [GYK5] : Endif
     If clalev([F:GRY5])=0 : Local File GACCGRUPYM [GRY5] : Endif
   Endcase
  When 2
   Case I
    When 1
     If clalev([F:CCE1])=0 : Local File CACCE      [CCE1] : Endif
     If clalev([F:CYK1])=0 : Local File GCCEPYMLIK [CYK1] : Endif
     If clalev([F:CRY1])=0 : Local File GCCEGRUPYM [CRY1] : Endif
    When 2
     If clalev([F:CCE2])=0 : Local File CACCE      [CCE2] : Endif
     If clalev([F:CYK2])=0 : Local File GCCEPYMLIK [CYK2] : Endif
     If clalev([F:CRY2])=0 : Local File GCCEGRUPYM [CRY2] : Endif
    When 3
     If clalev([F:CCE3])=0 : Local File CACCE      [CCE3] : Endif
     If clalev([F:CYK3])=0 : Local File GCCEPYMLIK [CYK3] : Endif
     If clalev([F:CRY3])=0 : Local File GCCEGRUPYM [CRY3] : Endif
    When 4
     If clalev([F:CCE4])=0 : Local File CACCE      [CCE4] : Endif
     If clalev([F:CYK4])=0 : Local File GCCEPYMLIK [CYK4] : Endif
     If clalev([F:CRY4])=0 : Local File GCCEGRUPYM [CRY4] : Endif
    When 5
     If clalev([F:CCE5])=0 : Local File CACCE      [CCE5] : Endif
     If clalev([F:CYK5])=0 : Local File GCCEPYMLIK [CYK5] : Endif
     If clalev([F:CRY5])=0 : Local File GCCEGRUPYM [CRY5] : Endif
   Endcase
 Endcase
Next I
If clalev([F:GRYA])=0 : Local File GACCGRUPYM [GRYA] : Endif
If clalev([F:CRYA])=0 : Local File GCCEGRUPYM [CRYA] : Endif

# Vérification des paramètres

GOK = 1
Read [CPY]CPY0    = SOCIETE
If [F:CPY]CPYLEGFLG=2
 GROUPE = 0
 NBSOC  = 1
 SOC(1) = SOCIETE
Else
 GROUPE = 1
 NBSOC  = 0
 For [FGR]FGR0 Where CPY=SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  If !find([F:FCY]LEGCPY,SOC(1..NBSOC))
   If NBSOC>=MAXSOC
    GMESSAGE = mess(107,104,1)-"("+num$(MAXSOC)+")" : # Trop de sociétés
    GOK = 0 : Break
   Else
    NBSOC += 1
    SOC(NBSOC) = [F:FCY]LEGCPY
   Endif
  Endif
 Next
 If !GOK : Goto ERREUR : Endif
Endif

For ISOC=1 To NBSOC
 SOCREF = SOC(ISOC)
 Read [CPY]CPY0 = SOCREF
 Read [GCM]GCM0 = [F:CPY]ACM
 If [F:GCM]LED(REFERENTIEL-1)=""
  GMESSAGE = mess(REFERENTIEL,2644,1)-":"-mess(105,104,1)-SOCREF : # Référentiel non défini pour la société
  GOK = 0 : Break
 Endif
 If ISOC=1
  REFER  = [F:GCM]LED(REFERENTIEL-1)
  DEVREF = [F:GCM]CUR(REFERENTIEL-1)
  Read [LED]LED0 = REFER
  For I=1 To NBAXE
   If TYPAXE(I)=2
    K = find(AXE(I),[F:LED]DIE(0..[F:LED]DIENBR-1))
    If K
     NUMAXE(I) = K
    Else
     GMESSAGE = AXE(I)-":"-mess(81,103,1)-REFER : # Axe inexistant dans le référentiel
     GOK = 0 : Break 2
    Endif
   Endif
  Next I
 Else
  If [F:GCM]LED(REFERENTIEL-1)<>REFER
   GMESSAGE = SOCREF-":"-mess(82,103,1)-"("+[F:GCM]LED(REFERENTIEL-1)+")" : # Référentiel incompatible
   GOK = 0 : Break
  Endif
  If [F:GCM]CUR(REFERENTIEL-1)<>DEVREF & (DEVORG="" or DEVORG<>DEVIMP)
   GMESSAGE = SOCREF-":"-mess(90,103,1)-"("+[F:GCM]CUR(REFERENTIEL-1)+")" : # Devise incompatible
   GOK = 0 : Break
  Endif
 Endif
 For IPER=1 To NPER
  Call GETPERSOC(SOCREF,REFERENTIEL,DATDEB(IPER),EDEB(IPER,ISOC),PDEB(IPER,ISOC)) From CPTSUB
  If EDEB(IPER,ISOC)=0 or PDEB(IPER,ISOC)=0
   GMESSAGE = SOCREF-format$("D:"+GFMDAT4,DATDEB(IPER))-":"-mess(10,116,1) : # Période incorrecte
   GOK = 0 : Break 2
  Endif
  DATDEB(IPER) = [F:PER]PERSTR
  Call GETPERSOC(SOCREF,REFERENTIEL,DATFIN(IPER),EFIN(IPER,ISOC),PFIN(IPER,ISOC)) From CPTSUB
  If EFIN(IPER,ISOC)=0 or PFIN(IPER,ISOC)=0 
   GMESSAGE = SOCREF-format$("D:"+GFMDAT4,DATFIN(IPER))-":"-mess(10,116,1) : # Période incorrecte
   GOK = 0 : Break 2
  Endif
  DATFIN(IPER) = [F:PER]PEREND
  If ISOC=1
   NBPER = 0
   For [PER]PER0 Where CPY=SOCREF & LEDTYP=REFERENTIEL & FIYNUM>=EDEB(IPER,ISOC) & FIYNUM<=EFIN(IPER,ISOC)
    NBPER += 1
    TBPER(NBPER) = [F:PER]PERSTR
   Next
  Else
   K = 0
   For [PER]PER0 Where CPY=SOCREF & LEDTYP=REFERENTIEL & PERSTR>=TBPER(1) & PERSTR<=TBPER(NBPER)
    K += 1
    If [F:PER]PERSTR<>TBPER(K) : GOK = 0 : Break : Endif
   Next
   If K<>NBPER : GOK = 0 : Endif
  Endif
  If !GOK
   GMESSAGE = mess(11,101,1)-SOCREF : # Périodes incompatibles pour la société
   Break 2
  Endif
 Next ISOC
Next IPER
If !GOK : Goto ERREUR : Endif

If DEVIMP=""
 DEVIMP = DEVREF
Endif

ANA = 0
BUD = 0
QTE = 0
ENG = 0
For I=1 To MAXCOL
 If find(TYPCOL(I),2,3,4,5,8,9,17,18,19,23,24,25,29,30,31,35,36,37)
  ANA = 1
 Elsif TYPCOL(I)=10 or TYPCOL(I)>=16
  BUD = 1
 Elsif find(TYPCOL(I),11,12,13,14,18,20,21,22,26,27,28,32,33,34,38,39,40)
  QTE = 1
 Elsif find(TYPCOL(I),6,7,8,9,18,19,24,25,30,31,36,37)
  ENG = 1
 Endif
Next I

If BUD
 If BUDGET=""
  GMESSAGE = mess(25,108,1) : # Pas de budget défini
  Goto ERREUR
 Endif
 Read [BUP]BUP0 = BUDGET
 BUDSIT = ([F:BUP]LEV=2)
 If [F:BUP]COA<>[F:LED]COA
  GMESSAGE = BUDGET-":"-mess(83,103,1)-[F:BUP]COA-"("+[F:LED]COA+")" : # Budget sur le plan comptable
  Goto ERREUR
 Endif
 For I=1 To NBAXE
  If TYPAXE(I)=2
   K = find(AXE(I),[F:BUP]DIE(0..2))
   If K
    NUMBUD(I) = K
   Else
    GMESSAGE = AXE(I)-":"-mess(84,103,1)-BUDGET : # Axe non défini pour le budget
    GOK = 0 : Break
   Endif
  Endif
 Next I
 If !GOK : Goto ERREUR : Endif
 For I=1 To NBAXE
  If TYPAXE(I)=1
   If PYRSEC(I)<>"" & [F:BUP]PYMACC<>""
    If [F:BUP]PYMACC<>PYRSEC(I)
     GMESSAGE = BUDGET-":"-mess(85,103,1)-[F:BUP]PYMACC : # Budget défini sur la pyramide de comptes
     Goto ERREUR
    Elsif [F:BUP]PYMACCLEV<NIVSEC(I)
     GMESSAGE = BUDGET-":"-mess(89,103,1)-num$([F:BUP]PYMACCLEV)-"("+[F:BUP]PYMACC+")" : # Budget défini au niveau
     Goto ERREUR
    Endif
   Endif
  Else
   If PYRSEC(I)<>"" & [F:BUP]PYMCCE(NUMBUD(I)-1)<>""
    If [F:BUP]PYMCCE(NUMBUD(I)-1)<>PYRSEC(I)
     GMESSAGE = BUDGET-"("+AXE(I)+")"-":"-mess(86,103,1)-[F:BUP]PYMCCE(NUMBUD(I)-1) : # Budget défini sur la pyramide de sections
     GOK = 0 : Break
    Elsif [F:BUP]PYMCCELEV(NUMBUD(I)-1)<NIVSEC(I)
     GMESSAGE = BUDGET-"("+AXE(I)+")"-":"-mess(89,103,1)-num$([F:BUP]PYMCCELEV(NUMBUD(I)-1))-"("+[F:BUP]PYMCCE(NUMBUD(I)-1)+")"
     # Budget défini au niveau
     GOK = 0 : Break
    Endif
   Endif
  Endif
 Next I
 If !GOK : Goto ERREUR : Endif
 If GROUPE & !BUDSIT
  GMESSAGE = BUDGET-":"-mess(33,108,1) : # Budget défini au niveau société
  Goto ERREUR
 Endif
Endif

# Génération du link qui va bien...

PROG   = "WW"+num$(adxuid(1))
FICSRC = filpath("TRT",PROG,"src",0)
FICADX = filpath("TRT",PROG,"adx",0)

Openo FICSRC,0
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq

Raz CRITERE
ICRIT = 1
Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]LEDTYP='+num$(REFERENTIEL))
If SITEDEB<>"" & SITEDEB=SITEFIN
 Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]FCY="'+SITEDEB+'"')
Else
 If SITEDEB<>""
  Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]FCY>="'+SITEDEB+'"')
 Endif
 If SITEFIN<>""
  Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]FCY<="'+SITEFIN+'"')
 Endif
Endif
If DEVORG<>""
 Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CUR="'+DEVORG+'"')
Endif
Call ADDCRIT(ICRIT,CRITERE,'[F:ACC]CONSUL=2')

Wrseq "$LIENS"
Wrseq 'Link [BLA] With'
Wrseq '&    [GAC]GAC0   ~= [F:BLA]COA;[F:BLA]ACC'
Wrseq '&  , [ACC]CODACC ~= "'+USER+'";[F:GAC]ACS'
Wrseq '&  , [AFF]AFF0   ~= [F:BLA]FCY;"'+PROFIL+'";"'+FONCTION+'"'

Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]BPR=""')

For I=1 To NBAXE
 Case TYPAXE(I)
  When 1
   If PYRSEC(I)<>""
    Wrseq '&  , [GYK'+num$(I)+']GYK0 ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BLA]ACC'
    If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:GYK'+num$(I)+']PRNROW='+num$(RNGSECDEB(I)))
    Else
     If RNGSECDEB(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:GYK'+num$(I)+']PRNROW>='+num$(RNGSECDEB(I)))
     Endif
     If RNGSECFIN(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:GYK'+num$(I)+']PRNROW<='+num$(RNGSECFIN(I)))
     Endif
    Endif
   Else
    If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]ACC="'+SECDEB(I)+'"')
    Else
     If SECDEB(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]ACC>="'+SECDEB(I)+'"')
     Endif
     If SECFIN(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]ACC<="'+SECFIN(I)+'"')
     Endif
    Endif
   Endif
  When 2
   If PYRSEC(I)<>""
    Wrseq '&  , [CYK'+num$(I)+']CYK0 ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BLA]CCE'+num$(NUMAXE(I))
    If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:CYK'+num$(I)+']PRNROW='+num$(RNGSECDEB(I)))
    Else
     If RNGSECDEB(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:CYK'+num$(I)+']PRNROW>='+num$(RNGSECDEB(I)))
     Endif
     If RNGSECFIN(I)<>0
      Call ADDCRIT(ICRIT,CRITERE,'[F:CYK'+num$(I)+']PRNROW<='+num$(RNGSECFIN(I)))
     Endif
    Endif
   Else
    If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
     Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CCE'+num$(NUMAXE(I))+'="'+SECDEB(I)+'"')
    Else
     If SECDEB(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CCE'+num$(NUMAXE(I))+'>="'+SECDEB(I)+'"')
     Endif
     If SECFIN(I)<>""
      Call ADDCRIT(ICRIT,CRITERE,'[F:BLA]CCE'+num$(NUMAXE(I))+'<="'+SECFIN(I)+'"')
     Endif
    Endif
   Endif
 Endcase
Next I

Wrseq "& As [LBLA]"

CLE = ""
Case TRI
 When 1 : # Sections-natures
  Gosub TRISEC
  Gosub TRINAT
 When 2 : # Natures-sections
  Gosub TRINAT
  Gosub TRISEC
Endcase
CLE += ";[F:BLA]FCY;[F:BLA]CUR"

Wrseq "& Where evalue(CRITERE(1.."+num$(ICRIT)+"))"
Wrseq "& Order By Key CLE = ";CLE
Wrseq "Return"
Wrseq

For I=1 To ICRIT
 Wrseq "#"-CRITERE(I)
Next I
Wrseq

If BUD
 Raz CRITBUD
 ICRIT = 1
 Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]BUD="'+BUDGET+'"')
 Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]VER="'+VERSION+'"')
 Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]LEDTYP='+num$(REFERENTIEL))
 If BUDSIT
  If SITEDEB<>"" & SITEDEB=SITEFIN
   Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]FCY="'+SITEDEB+'"')
  Else
   If SITEDEB<>""
    Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]FCY>="'+SITEDEB+'"')
   Endif
   If SITEFIN<>""
    Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]FCY<="'+SITEFIN+'"')
   Endif
  Endif
 Endif
 Call ADDCRIT(ICRIT,CRITBUD,'[F:ACC]CONSUL=2')
 Wrseq "$LIENBUD"
 Wrseq 'Link [BUD] With'
 Wrseq '&    [GAC]GAC0   ~= [F:BUD]COA;[F:BUD]ACC'
 Wrseq '&  , [ACC]CODACC ~= "'+USER+'";[F:GAC]ACS'
 If BUDSIT
  Wrseq '&  , [AFF]AFF0 ~= [F:BUD]FCY;"'+PROFIL+'";"'+FONCTION+'"'
 Endif
 For I=1 To NBAXE
  Case TYPAXE(I)
   When 1
    If PYRSEC(I)<>""
     If [F:BUP]PYMACC=""
      Wrseq '&  , [GYK'+num$(I)+']GYK0 ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BUD]ACC'
      If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
       Call ADDCRIT(ICRIT,CRITBUD,'[F:GYK'+num$(I)+']PRNROW='+num$(RNGSECDEB(I)))
      Else
       If RNGSECDEB(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:GYK'+num$(I)+']PRNROW>='+num$(RNGSECDEB(I)))
       Endif
       If RNGSECFIN(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:GYK'+num$(I)+']PRNROW<='+num$(RNGSECFIN(I)))
       Endif
      Endif
     Else
      Wrseq '&  , [GRY'+num$(I)+']GRY0 ~= "'+PYRSEC(I)+'";[F:BUD]ACC;1'
      If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
       Call ADDCRIT(ICRIT,CRITBUD,'[F:GRY'+num$(I)+']PRNROW='+num$(RNGSECDEB(I)))
      Else
       If RNGSECDEB(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:GRY'+num$(I)+']PRNROW>='+num$(RNGSECDEB(I)))
       Endif
       If RNGSECFIN(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:GRY'+num$(I)+']PRNROW<='+num$(RNGSECFIN(I)))
       Endif
      Endif
     Endif
    Else
     If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
      Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]ACC="'+SECDEB(I)+'"')
     Else
      If SECDEB(I)<>""
       Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]ACC>="'+SECDEB(I)+'"')
      Endif
      If SECFIN(I)<>""
       Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]ACC<="'+SECFIN(I)+'"')
      Endif
     Endif
    Endif
   When 2
    If PYRSEC(1)<>""
     If [F:BUP]PYMCCE(NUMBUD(I)-1)=""
      Wrseq '&  , [CYK'+num$(I)+']CYK0 ~= "'+PYRSEC(I)+'";'+num$(NIVSEC(I))+';[F:BUD]CCE'+num$(NUMBUD(I))
      If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
       Call ADDCRIT(ICRIT,CRITBUD,'[F:CYK'+num$(I)+']PRNROW='+num$(RNGSECDEB(I)))
      Else
       If RNGSECDEB(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:CYK'+num$(I)+']PRNROW>='+num$(RNGSECDEB(I)))
       Endif
       If RNGSECFIN(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:CYK'+num$(I)+']PRNROW<='+num$(RNGSECFIN(I)))
       Endif
      Endif
     Else
      Wrseq '&  , [CRY'+num$(I)+']CRY0 ~= "'+PYRSEC(I)+'";[F:BUD]CCE'+num$(NUMBUD(I))+';1'
      If RNGSECDEB(I)<>0 & RNGSECDEB(I)=RNGSECFIN(I)
       Call ADDCRIT(ICRIT,CRITBUD,'[F:CRY'+num$(I)+']PRNROW='+num$(RNGSECDEB(I)))
      Else
       If RNGSECDEB(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:CRY'+num$(I)+']PRNROW>='+num$(RNGSECDEB(I)))
       Endif
       If RNGSECFIN(I)<>0
        Call ADDCRIT(ICRIT,CRITBUD,'[F:CRY'+num$(I)+']PRNROW<='+num$(RNGSECFIN(I)))
       Endif
      Endif
     Endif
    Else
     If SECDEB(I)<>"" & SECDEB(I)=SECFIN(I)
      Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]CCE'+num$(NUMBUD(I))+'="'+SECDEB(I)+'"')
     Else
      If SECDEB(I)<>""
       Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]CCE'+num$(NUMBUD(I))+'>="'+SECDEB(I)+'"')
      Endif
      If SECFIN(I)<>""
       Call ADDCRIT(ICRIT,CRITBUD,'[F:BUD]CCE'+num$(NUMBUD(I))+'<="'+SECFIN(I)+'"')
      Endif
     Endif
    Endif
  Endcase
 Next I
 Wrseq "& As [LBUD]"
 CLE = ""
 Case TRI
  When 1 : # Sections-natures
   Gosub TRIBUDSEC
   Gosub TRIBUDNAT
  When 2 : # Natures-sections
   Gosub TRIBUDNAT
   Gosub TRIBUDSEC
 Endcase
 CLE += ";[F:BUD]FCY"
 Wrseq "& Where evalue(CRITBUD(1.."+num$(ICRIT)+"))"
 Wrseq "& Order By Key CLE = ";CLE
 Wrseq "Return"
 Wrseq
 For I=1 To ICRIT
  Wrseq "#"-CRITBUD(I)
 Next I
 Wrseq
Endif

Openo

# Validation du traitement

Call VALID("TRT",PROG,nomap,STAT) From VALMSKSUB

# Exécution

If EFFACE
 Gosub TR3
Endif

LIGNE = 0

If ANA
 PASSE = 1
 Local File BALANA [BLA]
 Gosub LIENS From =PROG
 Call DEBTRANS From GLOCK
 Gosub TR1
 Close Local File [BLA]
Endif

If QTE
 PASSE = 2
 Local File BLAQTY [BLA]
 Gosub LIENS From =PROG
 Call DEBTRANS From GLOCK
 Gosub TR1
 Close Local File [BLA]
Endif

If ENG
 PASSE = 3
 Local File BLACMM [BLA]
 Gosub LIENS From =PROG
 Call DEBTRANS From GLOCK
 Gosub TR1
 Close Local File [BLA]
Endif

If BUD
 PASSE = 4
 Local File BUD [BUD]
 Gosub LIENBUD From =PROG
 Call DEBTRANS From GLOCK
 Gosub TR2
 Close Local File [BUD]
Endif

# Impression

Call EFFACE(FICSRC,STAT) From ORDSYS
Call EFFACE(FICADX,STAT) From ORDSYS
End

$TR1
GOK = 1
Trbegin [ARM]
 For ISOC=1 To NBSOC
  CRITSOC = '[F:BLA]CPY="'+SOC(ISOC)+'" & [F:BLA]FCY<>""'
  EXEDEB = EDEB(1,ISOC)
  EXEFIN = EFIN(1,ISOC)
  For IPER=2 To NPER
   EXEDEB = min(EXEDEB,EDEB(IPER,ISOC))
   EXEFIN = max(EXEFIN,EFIN(IPER,ISOC))
  Next IPER
  If EXEDEB=EXEFIN
   CRITSOC -= '& [F:BLA]FIY='+num$(EXEDEB)
  Else
   CRITSOC -= '& [F:BLA]FIY>='+num$(EXEDEB)
   CRITSOC -= '& [F:BLA]FIY<='+num$(EXEFIN)
  Endif
#CHECK FILE_DECLARE TMPBLA [ARM]
  For [LBLA]CLE Where evalue(CRITSOC)
   LIGNE += 1
   Raz [F:ARM]
   [F:ARM]RPTCOD = ETAT
   [F:ARM]USR    = GUSER
   [F:ARM]NUMREQ = NUMREQ
   [F:ARM]NUMLIG = LIGNE
   [F:ARM]FCY    = [F:BLA]FCY
   For I=1 To NBAXE
    Case TYPAXE(I)
     When 1
      If PYRSEC(I)=""
       Case I
        When 1
         [F:ARM]CCE1    = [F:BLA]ACC
         [F:ARM]TRICCE1 = [F:BLA]ACC
         Call LECTEXTRA([F:ARM]LIBCCE1,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 2
         [F:ARM]CCE2    = [F:BLA]ACC
         [F:ARM]TRICCE2 = [F:BLA]ACC
         Call LECTEXTRA([F:ARM]LIBCCE2,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 3
         [F:ARM]CCE3    = [F:BLA]ACC
         [F:ARM]TRICCE3 = [F:BLA]ACC
         Call LECTEXTRA([F:ARM]LIBCCE3,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 4
         [F:ARM]CCE4    = [F:BLA]ACC
         [F:ARM]TRICCE4 = [F:BLA]ACC
         Call LECTEXTRA([F:ARM]LIBCCE4,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 5
         [F:ARM]CCE5    = [F:BLA]ACC
         [F:ARM]TRICCE5 = [F:BLA]ACC
         Call LECTEXTRA([F:ARM]LIBCCE5,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
       Endcase
      Else
       Case I
        When 1
         [F:ARM]CCE1    = [F:GYK1]GRU
         [F:ARM]TRICCE1 = format$("N0:4#",[F:GYK1]PRNROW)+[F:GYK1]GRU
         If [F:GRY1]GRU<>[F:GYK1]GRU
          Read [GRY1]GRY0 = [F:GYK1]PYM;[F:GYK1]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE1,"GACCGRUPYM","DESTRA",[F:GRY1]PYM,[F:GRY1]GRU) From ATEXTRA
        When 2
         [F:ARM]CCE2    = [F:GYK1]GRU
         [F:ARM]TRICCE2 = format$("N0:4#",[F:GYK2]PRNROW)+[F:GYK2]GRU
         If [F:GRY2]GRU<>[F:GYK2]GRU
          Read [GRY2]GRY0 = [F:GYK2]PYM;[F:GYK2]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE2,"GACCGRUPYM","DESTRA",[F:GRY2]PYM,[F:GRY2]GRU) From ATEXTRA
        When 3
         [F:ARM]CCE3    = [F:GYK3]GRU
         [F:ARM]TRICCE3 = format$("N0:4#",[F:GYK3]PRNROW)+[F:GYK3]GRU
         If [F:GRY3]GRU<>[F:GYK3]GRU
          Read [GRY3]GRY0 = [F:GYK3]PYM;[F:GYK3]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE3,"GACCGRUPYM","DESTRA",[F:GRY3]PYM,[F:GRY3]GRU) From ATEXTRA
        When 4
         [F:ARM]CCE4    = [F:GYK4]GRU
         [F:ARM]TRICCE4 = format$("N0:4#",[F:GYK4]PRNROW)+[F:GYK4]GRU
         If [F:GRY4]GRU<>[F:GYK4]GRU
          Read [GRY4]GRY0 = [F:GYK4]PYM;[F:GYK4]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE4,"GACCGRUPYM","DESTRA",[F:GRY4]PYM,[F:GRY4]GRU) From ATEXTRA
        When 5
         [F:ARM]CCE5    = [F:GYK5]GRU
         [F:ARM]TRICCE5 = format$("N0:4#",[F:GYK5]PRNROW)+[F:GYK5]GRU
         If [F:GRY5]GRU<>[F:GYK5]GRU
          Read [GRY5]GRY0 = [F:GYK5]PYM;[F:GYK5]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE5,"GACCGRUPYM","DESTRA",[F:GRY5]PYM,[F:GRY5]GRU) From ATEXTRA
       Endcase
      Endif
     When 2
      If PYRSEC(I)=""
       SECTION = evalue("[F:BLA]CCE"+num$(NUMAXE(I)))
       Case I
        When 1
         [F:ARM]CCE1    = SECTION
         [F:ARM]TRICCE1 = SECTION
         If SECTION<>[F:CCE1]CCE
          Read [CCE1]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE1,"CACCE","DESTRA",[F:CCE1]DIE,[F:CCE1]CCE) From ATEXTRA
        When 2
         [F:ARM]CCE2    = SECTION
         [F:ARM]TRICCE2 = SECTION
         If SECTION<>[F:CCE2]CCE
          Read [CCE2]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE2,"CACCE","DESTRA",[F:CCE2]DIE,[F:CCE2]CCE) From ATEXTRA
        When 3
         [F:ARM]CCE3    = SECTION
         [F:ARM]TRICCE3 = SECTION
         If SECTION<>[F:CCE3]CCE
          Read [CCE3]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE3,"CACCE","DESTRA",[F:CCE3]DIE,[F:CCE3]CCE) From ATEXTRA
        When 4
         [F:ARM]CCE4    = SECTION
         [F:ARM]TRICCE4 = SECTION
         If SECTION<>[F:CCE4]CCE
          Read [CCE4]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE4,"CACCE","DESTRA",[F:CCE4]DIE,[F:CCE4]CCE) From ATEXTRA
        When 5
         [F:ARM]CCE5    = SECTION
         [F:ARM]TRICCE5 = SECTION
         If SECTION<>[F:CCE5]CCE
          Read [CCE5]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE5,"CACCE","DESTRA",[F:CCE5]DIE,[F:CCE5]CCE) From ATEXTRA
       Endcase
      Else
       SECTION = evalue("[F:CYK"+num$(I)+"]GRU")
       Case I
        When 1
         [F:ARM]CCE1    = SECTION
         [F:ARM]TRICCE1 = format$("N0:4#",[F:CYK1]PRNROW)+SECTION
         If SECTION<>[F:CRY1]GRU
          Read [CRY1]CRY0 = [F:CYK1]PYM;[F:CYK1]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE1,"GCCEGRUPYM","DESTRA",[F:CRY1]PYM,[F:CRY1]GRU) From ATEXTRA
        When 2
         [F:ARM]CCE2    = SECTION
         [F:ARM]TRICCE2 = format$("N0:4#",[F:CYK2]PRNROW)+SECTION
         If SECTION<>[F:CRY2]GRU
          Read [CRY2]CRY0 = [F:CYK2]PYM;[F:CYK2]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE2,"GCCEGRUPYM","DESTRA",[F:CRY2]PYM,[F:CRY2]GRU) From ATEXTRA
        When 3
         [F:ARM]CCE3    = SECTION
         [F:ARM]TRICCE3 = format$("N0:4#",[F:CYK3]PRNROW)+SECTION
         If SECTION<>[F:CRY3]GRU
          Read [CRY3]CRY0 = [F:CYK3]PYM;[F:CYK3]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE3,"GCCEGRUPYM","DESTRA",[F:CRY3]PYM,[F:CRY3]GRU) From ATEXTRA
        When 4
         [F:ARM]CCE4    = SECTION
         [F:ARM]TRICCE4 = format$("N0:4#",[F:CYK4]PRNROW)+SECTION
         If SECTION<>[F:CRY4]GRU
          Read [CRY4]CRY0 = [F:CYK4]PYM;[F:CYK4]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE4,"GCCEGRUPYM","DESTRA",[F:CRY4]PYM,[F:CRY4]GRU) From ATEXTRA
        When 5
         [F:ARM]CCE5    = SECTION
         [F:ARM]TRICCE5 = format$("N0:4#",[F:CYK5]PRNROW)+SECTION
         If SECTION<>[F:CRY5]GRU
          Read [CRY5]CRY0 = [F:CYK5]PYM;[F:CYK5]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE5,"GCCEGRUPYM","DESTRA",[F:CRY5]PYM,[F:CRY5]GRU) From ATEXTRA
       Endcase
      Endif
    Endcase
   Next I
   Case PASSE
    When 1 : [F:ARM]CLEN1  = [F:BLA]ACCNUM
    When 2 : [F:ARM]CLEN2  = [F:BLA]ACCNUM
    When 3 : [F:ARM]CLEN3  = [F:BLA]ACCNUM
   Endcase
   [F:ARM]CLEN4 = -1
   If dim([F:BLA]UOM)>0 : [F:ARM]UOM = [F:BLA]UOM : Endif
   For IPER=1 To NPER
    If [F:BLA]FIY>=EDEB(IPER,ISOC) & [F:BLA]FIY<=EFIN(IPER,ISOC)
     If [F:BLA]FIY=EDEB(IPER,ISOC)
      If PDEB(IPER,ISOC)=1 & ANOUVEAU
       [F:ARM]PERSTR(IPER-1) = 1
      Else
       [F:ARM]PERSTR(IPER-1) = PDEB(IPER,ISOC)+1
      Endif   
     Else
      [F:ARM]PERSTR(IPER-1) = 1
     Endif
     If [F:BLA]FIY=EFIN(IPER,ISOC)
      [F:ARM]PEREND(IPER-1) = PFIN(IPER,ISOC)+1
     Else
      [F:ARM]PEREND(IPER-1) = dim([F:BLA]CDT)
     Endif
    Endif
   Next IPER
   [F:ARM]CUR = DEVIMP
   Write [ARM]
   If fstat
    GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
   Endif
  Next
 Next ISOC
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$TR2
GOK = 1
Trbegin [ARM]
 For ISOC=1 To NBSOC
  EXEDEB = EDEB(1,ISOC)
  EXEFIN = EFIN(1,ISOC)
  For IPER=2 To NPER
   EXEDEB = min(EXEDEB,EDEB(IPER,ISOC))
   EXEFIN = max(EXEFIN,EFIN(IPER,ISOC))
  Next IPER
  CRITSOC = '[F:BUD]CPY="'+SOC(ISOC)+'" & [F:BUD]FCY<>""'
  If EXEDEB=EXEFIN
   CRITSOC -= '& [F:BUD]FIY='+num$(EXEDEB)
  Else
   CRITSOC -= '& [F:BUD]FIY>='+num$(EXEDEB)
   CRITSOC -= '& [F:BUD]FIY<='+num$(EXEFIN)
  Endif
  For [LBUD]CLE Where evalue(CRITSOC)
   OKBUD = 1
   LIGNE += 1
#CHECK FILE_DECLARE TMPBLA [ARM]
   Raz [F:ARM]
   [F:ARM]RPTCOD = ETAT
   [F:ARM]USR    = GUSER
   [F:ARM]NUMREQ = NUMREQ
   [F:ARM]NUMLIG = LIGNE
   [F:ARM]FCY    = [F:BUD]FCY
   For I=1 To NBAXE
    Case TYPAXE(I)
     When 1
      If PYRSEC(I)=""
       Case I
        When 1
         [F:ARM]CCE1    = [F:BUD]ACC
         [F:ARM]TRICCE1 = [F:BUD]ACC
         Call LECTEXTRA([F:ARM]LIBCCE1,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 2
         [F:ARM]CCE2    = [F:BUD]ACC
         [F:ARM]TRICCE2 = [F:BUD]ACC
         Call LECTEXTRA([F:ARM]LIBCCE2,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 3
         [F:ARM]CCE3    = [F:BUD]ACC
         [F:ARM]TRICCE3 = [F:BUD]ACC
         Call LECTEXTRA([F:ARM]LIBCCE3,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 4
         [F:ARM]CCE4    = [F:BUD]ACC
         [F:ARM]TRICCE4 = [F:BUD]ACC
         Call LECTEXTRA([F:ARM]LIBCCE4,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
        When 5
         [F:ARM]CCE5    = [F:BUD]ACC
         [F:ARM]TRICCE5 = [F:BUD]ACC
         Call LECTEXTRA([F:ARM]LIBCCE5,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
       Endcase
      Elsif [F:BUP]PYMACC=""
       Case I
        When 1
         [F:ARM]CCE1    = [F:GYK1]GRU
         [F:ARM]TRICCE1 = format$("N0:4#",[F:GYK1]PRNROW)+[F:GYK1]GRU
         If [F:GRY1]GRU<>[F:GYK1]GRU
          Read [GRY1]GRY0 = [F:GYK1]PYM;[F:GYK1]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE1,"GACCGRUPYM","DESTRA",[F:GRY1]PYM,[F:GRY1]GRU) From ATEXTRA
        When 2
         [F:ARM]CCE2    = [F:GYK1]GRU
         [F:ARM]TRICCE2 = format$("N0:4#",[F:GYK2]PRNROW)+[F:GYK2]GRU
         If [F:GRY2]GRU<>[F:GYK2]GRU
          Read [GRY2]GRY0 = [F:GYK2]PYM;[F:GYK2]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE2,"GACCGRUPYM","DESTRA",[F:GRY2]PYM,[F:GRY2]GRU) From ATEXTRA
        When 3
         [F:ARM]CCE3    = [F:GYK3]GRU
         [F:ARM]TRICCE3 = format$("N0:4#",[F:GYK3]PRNROW)+[F:GYK3]GRU
         If [F:GRY3]GRU<>[F:GYK3]GRU
          Read [GRY3]GRY0 = [F:GYK3]PYM;[F:GYK3]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE3,"GACCGRUPYM","DESTRA",[F:GRY3]PYM,[F:GRY3]GRU) From ATEXTRA
        When 4
         [F:ARM]CCE4    = [F:GYK4]GRU
         [F:ARM]TRICCE4 = format$("N0:4#",[F:GYK4]PRNROW)+[F:GYK4]GRU
         If [F:GRY4]GRU<>[F:GYK4]GRU
          Read [GRY4]GRY0 = [F:GYK4]PYM;[F:GYK4]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE4,"GACCGRUPYM","DESTRA",[F:GRY4]PYM,[F:GRY4]GRU) From ATEXTRA
        When 5
         [F:ARM]CCE5    = [F:GYK5]GRU
         [F:ARM]TRICCE5 = format$("N0:4#",[F:GYK5]PRNROW)+[F:GYK5]GRU
         If [F:GRY5]GRU<>[F:GYK5]GRU
          Read [GRY5]GRY0 = [F:GYK5]PYM;[F:GYK5]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE5,"GACCGRUPYM","DESTRA",[F:GRY5]PYM,[F:GRY5]GRU) From ATEXTRA
       Endcase
      Else
       GROUPYR = evalue("[F:GRY"+num$(I)+"]GRU")
       NIVPYR  = evalue("[F:GRY"+num$(I)+"]LEV")
#   Cas du budget défini à un niveau supérieur    
       While NIVPYR>NIVSEC(I)
        Filter [GRYA] Where PYM=PYRSEC(I) & SBBGRU=GROUPYR
        Read [GRYA]GRY2 First
        Filter [GRYA]
        If fstat<=2
         GROUPYR = [F:GRYA]GRU
         NIVPYR  = [F:GRYA]LEV
        Else
         OKBUD = 0 : Break
        Endif
       Wend
       If NIVPYR=NIVSEC(I)
        Assign "[F:ARM]CCE"+num$(I) With GROUPYR
        If [F:GRYA]GRU<>GROUPYR
         Read [GRYA]GRY0 = PYRSEC(I);GROUPYR;1
        Endif
        Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[F:GRYA]PYM,[F:GRYA]GRU) From ATEXTRA
        Assign "[F:ARM]TRICCE"+num$(I) With format$("N0:4#",[F:GRYA]PRNROW)+GROUPYR
        Assign "[F:ARM]LIBCCE"+num$(I) With DESIG
       Else
        OKBUD = 0
       Endif
      Endif
     When 2
      If PYRSEC(I)=""
       SECTION = evalue("[F:BUD]CCE"+num$(NUMBUD(I)))
       Case I
        When 1
         [F:ARM]CCE1    = SECTION
         [F:ARM]TRICCE1 = SECTION
         If SECTION<>[F:CCE1]CCE
          Read [CCE1]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE1,"CACCE","DESTRA",[F:CCE1]DIE,[F:CCE1]CCE) From ATEXTRA
        When 2
         [F:ARM]CCE2    = SECTION
         [F:ARM]TRICCE2 = SECTION
         If SECTION<>[F:CCE2]CCE
          Read [CCE2]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE2,"CACCE","DESTRA",[F:CCE2]DIE,[F:CCE2]CCE) From ATEXTRA
        When 3
         [F:ARM]CCE3    = SECTION
         [F:ARM]TRICCE3 = SECTION
         If SECTION<>[F:CCE3]CCE
          Read [CCE3]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE3,"CACCE","DESTRA",[F:CCE3]DIE,[F:CCE3]CCE) From ATEXTRA
        When 4
         [F:ARM]CCE4    = SECTION
         [F:ARM]TRICCE4 = SECTION
         If SECTION<>[F:CCE4]CCE
          Read [CCE4]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE4,"CACCE","DESTRA",[F:CCE4]DIE,[F:CCE4]CCE) From ATEXTRA
        When 5
         [F:ARM]CCE5    = SECTION
         [F:ARM]TRICCE5 = SECTION
         If SECTION<>[F:CCE5]CCE
          Read [CCE5]CCE0 = AXE(I);SECTION
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE5,"CACCE","DESTRA",[F:CCE5]DIE,[F:CCE5]CCE) From ATEXTRA
       Endcase
      Elsif [F:BUP]PYMCCE(NUMBUD(I)-1)=""
       SECTION = evalue("[F:CYK"+num$(I)+"]GRU")
       Case I
        When 1
         [F:ARM]CCE1    = SECTION
         [F:ARM]TRICCE1 = format$("N0:4#",[F:CYK1]PRNROW)+SECTION
         If SECTION<>[F:CRY1]GRU
          Read [CRY1]CRY0 = [F:CYK1]PYM;[F:CYK1]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE1,"GCCEGRUPYM","DESTRA",[F:CRY1]PYM,[F:CRY1]GRU) From ATEXTRA
        When 2
         [F:ARM]CCE2    = SECTION
         [F:ARM]TRICCE2 = format$("N0:4#",[F:CYK2]PRNROW)+SECTION
         If SECTION<>[F:CRY2]GRU
          Read [CRY2]CRY0 = [F:CYK2]PYM;[F:CYK2]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE2,"GCCEGRUPYM","DESTRA",[F:CRY2]PYM,[F:CRY2]GRU) From ATEXTRA
        When 3
         [F:ARM]CCE3    = SECTION
         [F:ARM]TRICCE3 = format$("N0:4#",[F:CYK3]PRNROW)+SECTION
         If SECTION<>[F:CRY3]GRU
          Read [CRY3]CRY0 = [F:CYK3]PYM;[F:CYK3]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE3,"GCCEGRUPYM","DESTRA",[F:CRY3]PYM,[F:CRY3]GRU) From ATEXTRA
        When 4
         [F:ARM]CCE4    = SECTION
         [F:ARM]TRICCE4 = format$("N0:4#",[F:CYK4]PRNROW)+SECTION
         If SECTION<>[F:CRY4]GRU
          Read [CRY4]CRY0 = [F:CYK4]PYM;[F:CYK4]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE4,"GCCEGRUPYM","DESTRA",[F:CRY4]PYM,[F:CRY4]GRU) From ATEXTRA
        When 5
         [F:ARM]CCE5    = SECTION
         [F:ARM]TRICCE5 = format$("N0:4#",[F:CYK5]PRNROW)+SECTION
         If SECTION<>[F:CRY5]GRU
          Read [CRY5]CRY0 = [F:CYK5]PYM;[F:CYK5]GRU;1
         Endif
         Call LECTEXTRA([F:ARM]LIBCCE5,"GCCEGRUPYM","DESTRA",[F:CRY5]PYM,[F:CRY5]GRU) From ATEXTRA
       Endcase
      Else
       GROUPYR = evalue("[F:CRY"+num$(I)+"]GRU")
       NIVPYR  = evalue("[F:CRY"+num$(I)+"]LEV")
#   Cas du budget défini à un niveau supérieur    
       While NIVPYR>NIVSEC(I)
        Filter [CRYA] Where PYM=PYRSEC(I) & SBBGRU=GROUPYR
        Read [CRYA]CRY2 First
        Filter [CRYA]
        If fstat<=2
         GROUPYR = [F:CRYA]GRU
         NIVPYR  = [F:CRYA]LEV
        Else
         OKBUD = 0 : Break
        Endif
       Wend
       If NIVPYR=NIVSEC(I)
        Assign "[F:ARM]CCE"+num$(I) With GROUPYR
        If [F:CRYA]GRU<>GROUPYR
         Read [CRYA]CRY0 = PYRSEC(I);GROUPYR;1
        Endif
        Call LECTEXTRA(DESIG,"GCCEGRUPYM","DESTRA",[F:CRYA]PYM,[F:CRYA]GRU) From ATEXTRA
        Assign "[F:ARM]LIBCCE"+num$(I) With DESIG
        Assign "[F:ARM]TRICCE"+num$(I) With format$("N0:4#",[F:CRYA]PRNROW)+GROUPYR
       Else
        OKBUD = 0
       Endif
      Endif
    Endcase
   Next I
   [F:ARM]CLEN4 = [F:BUD]ACCNUM
   [F:ARM]UOM = [F:BUD]UOM
   For IPER=1 To NPER
    If [F:BUD]FIY>=EDEB(IPER,ISOC) & [F:BUD]FIY<=EFIN(IPER,ISOC)
     If [F:BUD]FIY=EDEB(IPER,ISOC)
      [F:ARM]PERSTR(IPER-1) = PDEB(IPER,ISOC)
     Else
      [F:ARM]PERSTR(IPER-1) = 1
     Endif
     If [F:BUD]FIY=EFIN(IPER,ISOC)
      [F:ARM]PEREND(IPER-1) = PFIN(IPER,ISOC)
     Else
      [F:ARM]PEREND(IPER-1) = dim([F:BUD]AMT)
     Endif
    Endif
   Next IPER
   [F:ARM]CUR = DEVIMP
   If OKBUD
    Write [ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
   Endif
  Next
 Next ISOC
 If GOK<1 : Goto AB_TR2 : Endif
Commit
Return

$AB_TR2
Rollback
Return

$TR3
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=ETAT & USR=GUSER
Commit
Return
  
$TRINAT
Return

$TRISEC
For I=1 To NBAXE
 If CLE<>"" : CLE += ";" : Endif
 Case TYPAXE(I)
  When 1
   If PYRSEC(I)<>""
    CLE += "[F:GYK"+num$(I)+"]PRNROW;[F:GYK"+num$(I)+"]GRU"
   Else
    CLE += "[F:BLA]COA;[F:BLA]ACC"
   Endif
  When 2
   If PYRSEC(I)<>""
    CLE += "[F:CYK"+num$(I)+"]PRNROW;[F:CYK"+num$(I)+"]GRU"
   Else
    CLE += "[F:BLA]DIE("+num$(NUMAXE(I)-1)+");[F:BLA]CCE"+num$(NUMAXE(I))
   Endif
 Endcase
Next I
Return

$TRIBUDNAT
Return

$TRIBUDSEC
For I=1 To NBAXE
 If CLE<>"" : CLE += ";" : Endif
 Case TYPAXE(I)
  When 1
   If PYRSEC(I)<>""
    If [F:BUP]PYMACC=""
     CLE += "[F:GYK"+num$(I)+"]PRNROW;[F:GYK"+num$(I)+"]GRU"
    Else
     CLE += "[F:GRY"+num$(I)+"]PRNROW;[F:GRY"+num$(I)+"]GRU"
    Endif
   Else
    CLE += "[F:BUD]COA;[F:BUD]ACC"
   Endif
  When 2
   If PYRSEC(I)<>""
    If [F:BUP]PYMCCE(NUMBUD(I)-1)<>""
     CLE += "[F:CYK"+num$(I)+"]PRNROW;[F:CYK"+num$(I)+"]GRU"
    Else
     CLE += "[F:CRY"+num$(I)+"]PRNROW;[F:CRY"+num$(I)+"]GRU"
    Endif
   Else
    CLE += "[F:BUD]DIE"+num$(NUMBUD(I))+";[F:BUD]CCE"+num$(NUMBUD(I))
   Endif
 Endcase
Next I
Return

$OUVFIC
If clalev([F:ARM])=0 : Local File TMPBLA     [ARM] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY    [AFF] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GYK])=0 : Local File GACCPYMLIK [GYK] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:CYM])=0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR     [BUP] : Endif
Return

$ERREUR
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK = 0
End

Subprog ADDCRIT(ICRIT,CRITERE,SUBCRIT)
Variable Integer ICRIT
Variable Char    CRITERE()(1..)
Value    Char    SUBCRIT
If len(CRITERE(ICRIT))+len(SUBCRIT)>240
 ICRIT += 1
Endif
If CRITERE(1)<>""
 CRITERE(ICRIT) -= "&"
Endif
CRITERE(ICRIT) -= SUBCRIT
End

Subprog GETPARCHAR(PARAM,NBPAR,PARAMETRES,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Variable Char    VALEUR()
Call GETPARAM(PARAM,NBPAR,PARAMETRES,VALEUR) From ETAT
If VALEUR=" " or VALEUR=string$(len(VALEUR),"z")
 VALEUR = ""
Endif
End

Subprog GETPARINT(PARAM,NBPAR,PARAMETRES,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)
Variable Char    VALEUR()
Call GETPARAM(PARAM,NBPAR,PARAMETRES,VALEUR) From ETAT
If VALEUR="32767"
 VALEUR = "0"
Endif
End

######################################################################################################
## Controles de saisie
######################################################################################################
$OUVRE
Gosub OUVFIC
Return

$INIPAR
Local Integer J , K , IAXE
Local Char    NOMPAR(15)
NOMPAR = [M]PARCOD(nolign-1)
Case NOMPAR
 When "dat2deb"
  K = find("nbper",[M]PARCOD)-1
  If K>=0 & val([M]VALINT1(K))<2
   mkstat = 1
  Endif 
 When "dat3deb"
  K = find("nbper",[M]PARCOD)-1
  If K>=0 & val([M]VALINT1(K))<3
   mkstat = 1
  Endif 
 When "cptdeb"
  K = find("pyrcpt",[M]PARCOD)-1
  If K>=0 & [M]VALINT1(K)<>""
   mkstat = 1
  Endif
  Gosub SETLED
 When "nivcpt","rngcptdeb"
  K = find("pyrcpt",[M]PARCOD)-1
  If K>=0 & [M]VALINT1(K)=""
   mkstat = 1
  Endif
 When "axe1","axe2","axe3","axe4"
  IAXE = val(mid$(NOMPAR,4,1))
  Gosub SETAXE
  If NBAXE<IAXE : mkstat = 1 : Endif
 When "pyrsec1","pyrsec2","pyrsec3","pyrsec4"
  IAXE = val(mid$(NOMPAR,7,1))
  Gosub SETAXE
  If NBAXE<IAXE : mkstat = 1 : Endif
 When "nivsec1","nivsec2","nivsec3","nivsec4","rngsec1deb","rngsec2deb","rngsec3deb","rngsec4deb"
  IAXE = val(mid$(NOMPAR,7,1))
  K = find("pyrsec"+num$(IAXE),[M]PARCOD)-1
  If K>=0 & [M]VALINT1(K)="" : mkstat = 1 : Endif
 When "sec1deb","sec2deb","sec3deb","sec4deb"
  IAXE = val(mid$(NOMPAR,4,1))
  Gosub SETAXE
  K = find("pyrsec"+num$(IAXE),[M]PARCOD)-1
  If NBAXE<IAXE or (K>=0 & [M]VALINT1(K)<>"")
   mkstat = 1
  Else
   K = find("axe"+num$(IAXE),[M]PARCOD)-1
   Read [DIE]DIE0 = [M]VALINT1(K)
  Endif
 When "percol1","percol2","percol3","percol4","percol5","percol6"
  K = find("nbper",[M]PARCOD)-1
  If K>=0 & val([M]VALINT1(K))<2
   zc = 1 : mkstat = 2
  Endif 
Endcase
Return

$SETAXE
Local Integer NBAXE
K = find("nbaxe",[M]PARCOD)-1
If K>=0
 NBAXE = val([M]VALINT1(K))
Endif
Return

$SETLED
K = find("societe",[M]PARCOD)-1
J = find("referentiel",[M]PARCOD)-1
If J>=0 & K>=0
 Read [CPY]CPY0 = [M]VALINT1(K)
 If [F:CPY]CPYLEGFLG<>2
  Read [FGR]FGR0(1) = [F:CPY]CPY
  Read [FCY]FCY0    = [F:FGR]FCY
  Read [CPY]CPY0    = [F:FCY]LEGCPY
 Endif
 Read [GCM]GCM0 = [F:CPY]ACM
 Read [LED]LED0 = [F:GCM]LED(val([M]VALINT1(J))-1)
Endif
Return

$CONT1
Local Integer J , K , IAXE
Local Char    NOMPAR(15)
NOMPAR = [M]PARCOD(nolign-1)
Case NOMPAR
 When "axe1","axe2","axe3","axe4"
  If zc=""
   GMESSAGE = mess(10,123,1) : # Zone obligatoire
   mkstat = 2 : Return
  Endif
  Gosub SETLED
  If !find(zc,[F:LED]DIE(0..[F:LED]DIENBR-1))
   GMESSAGE = mess(81,103,1) : # Axe non défini sur le référentiel
   mkstat = 2 : Return
  Endif
 When "pyrcpt"
  If zc<>""
   Gosub SETLED
   Read [GYM]GYM0 = zc
   If fstat
    GMESSAGE = [F:CYM]DIE-":"-mess(96,102,1) : # Pyramide inexistante
    mkstat = 2 : Return
   Elsif [F:GYM]COA<>[F:LED]COA
    GMESSAGE = [F:GYM]COA-":"-mess(87,103,1) : # Plan de compte incompatible
    mkstat = 2 : Return
   Endif
  Endif
 When "pyrsec1","pyrsec2","pyrsec3","pyrsec4"
  If zc<>""
   IAXE = val(mid$(NOMPAR,7,1))
   K = find("axe"+num$(IAXE),[M]PARCOD)-1
   Read [CYM]CYM0 = zc
   If fstat
    GMESSAGE = [F:CYM]DIE-":"-mess(96,102,1) : # Pyramide inexistante
    mkstat = 2 : Return
   Elsif [F:CYM]DIE<>[M]VALINT1(K)
    GMESSAGE = [F:CYM]DIE-":"-mess(88,103,1) : # Axe incompatible
    mkstat = 2 : Return
   Endif
  Endif
Endcase
Return

$CONT2
Return
