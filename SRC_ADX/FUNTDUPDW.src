#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
#                                                                       #
#    MODELISATION E-COMMERCE                                            #
#                                                                       #
# ACTIONS  :                                                            #
#    SAITDUPDW  : action de saisie fenêtre                              #
#    TRTTDUPDW  : Action traitement modification des postes             #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#---Actions liées à la saisie fenêtre
Case ACTION
   When "OUVRE"      : Case GACTION
                           When "SAITDUPDW" : Gosub OUVRE
                       Endcase
   When "SETBOUT"    : Case GACTION
                           When "TRTTDUPDW" : Gosub SETBOUT
                       Endcase
   When "DEBUT"      : Case GACTION
                           When "SAITDUPDW" : Gosub S_DEBUT
                           When "TRTTDUPDW" : Gosub T_DEBUT
                       Endcase
   When "APRES_MODIF": Gosub APRES_MODIF
   When "ENR"        : Gosub ENREGISTRE
   When "ABA"        : Gosub ABORT
   When "FIN"        : Gosub FIN
   When Default
Endcase



#--- Actions liées au traitement standard
Case ACTION
   When "TERMINE"    : Case GACTION
                           When "TRTTDUPDW" Gosub TERMINE
                       Endcase
   When Default
Endcase

Return
#######################################################################
$OUVRE

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:MWS]) = 0 : Local File WORKSTATIO  [MWS] : Endif
If clalev([F:ROO]) = 0 : Local File ROUOPE      [ROO] : Endif
If clalev([F:ROT]) = 0 : Local File ROUOPESTD   [ROT] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR      [TFO] : Endif
If clalev([F:MWC]) = 0 : Local File WORKCOST    [MWC] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY    [FCY] : Endif
If clalev([F:TWD]) = 0 : Local File TABWEEDIA   [TWD] : Endif
If clalev([F:SCH]) = 0 : Local File SCHEDULING  [SCH] : Endif
If clalev([F:MFG1])= 0 : Local File MFGHEAD     [MFG1]: Endif
If clalev([F:MFO1])= 0 : Local File MFGOPE      [MFO1]: Endif
If clalev([F:MFM]) = 0 : Local File MFGMAT      [MFM] : Endif
If clalev([F:OPS]) = 0 : Local File OPERATIONS  [OPS] : Endif
If clalev([F:WKL]) = 0 : Local File WORKLOAD    [WKL] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT  [ITF] : Endif
If clalev([F:TUV]) = 0 : Local File TABUNAVAIL  [TUV] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR      [CPV] : Endif
If clalev([F:TUC]) = 0 : Local File TDUPDCLC    [TUC] : Endif
If clalev([F:OPS1]) = 0: Local File OPERATIONS  [OPS1]  : Endif
If clalev([F:SCH1]) = 0: Local File SCHEDULING  [SCH1]  : Endif
# llc 12.02 16779
If clalev([F:PJA])  = 0 : Local File PARJAL     [PJA]  : Endif
# Issue X3-23527 - 2017-02-02 by ALSHE : No reschedule of WO when it is being optimized
If clalev([F:ORD])  = 0 : Local File ORDERS     [ORD]  : Endif


Local Mask    JALK [JALK]
Local Char    CRITERE(250), CRITERE1(250)
Local Char    FORMULE1(250)
Local Integer OK, NBMWS, NBROT, NBOPE, NBOF,I
Local Char    WMESS(80), WMESS1(80), WMESS2(80), WMESS3(80)
Local Char    TIT(50) : TIT = mess(222,195,1)
Local Integer WRET

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM     # mm 12.02


Return
#######################################################################
$S_DEBUT
Raz [M:TUW1]
Raz [M:TUW2]
Raz [M:TUW3]


[M:TUW1]WCRFCY    = GFCY
[M:TUW2]WSTTYPDEB =1
[M:TUW2]WSTTYPFIN =3
If dim([M:TUW3]JOURS1)>0
    [M:TUW3]JOURS1    = mess(1,635,1)
Endif

Affzo [M:TUW1]1-99
Affzo [M:TUW2]1-99
Affzo [M:TUW3]1-99


Return

##########################################################################
# Selection sur les postes de charge                                     #
$SEL_MWS
#--> critères de saisie
CRITERE = "1=1"

# site
If [M:TUW1]WCRFCY <> ""
   CRITERE -= '& WCRFCY = "'+[M:TUW1]WCRFCY+'"'
Endif

# centre
If [M:TUW2]WCRDEB <> ""
   CRITERE -= '& WCR >="'+[M:TUW2]WCRDEB+'"'
Endif
If [M:TUW2]WCRFIN <> ""
   CRITERE -= '& WCR <="'+[M:TUW2]WCRFIN+'"'
Endif

CRITERE1 = "1=1"

# type poste
If [M:TUW2]WSTTYPDEB <> 0
   CRITERE1 -= "& WSTTYP >="+num$([M:TUW2]WSTTYPDEB)
Endif
If [M:TUW2]WSTTYPFIN <> 0
   CRITERE1 -= "& WSTTYP <="+num$([M:TUW2]WSTTYPFIN)
Endif

# poste
If [M:TUW2]WSTDEB <> ""
   CRITERE1 -= '& WST >="'+[M:TUW2]WSTDEB+'"'
Endif
If [M:TUW2]WSTFIN <> ""
   CRITERE1 -= '& WST <="'+[M:TUW2]WSTFIN+'"'
Endif

# analyse présence formule de sélection
If [M:TUW2]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=9;[M:TUW2]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif

Return

#######################################################################
$T_DEBUT
Local Char    TIT(50) : TIT = mess(222,195,1)
Default File [MWS]
Default Mask [TUW4]
Local Integer WMAX : WMAX = dim([M]WST)     # llc 04.03 17909

Gosub SEL_MWS

Gosub LIRE
If [M:TUW4]NBLIG=0
    GERR=2 : GMESSAGE=mess(358,197,1)
    FIN=1
Endif

Return

##########################################################################
# Lecture des postes                                #
$LIRE
REP=""
Raz [M]
nolign=0

If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif

[M]WCRFCY = [M:TUW1]WCRFCY
Call LECTURE("FCY",[M]WCRFCY,"") From CONTOBJ
[M]FCYDES = [F:FCY]FCYNAM


# --- Positionnement du filtre
Filter [MWS] Where evalue (CRITERE) &  evalue (CRITERE1)  &
&    evalue(FORMULE1) Order By Key WST0


For [MWS]
    nolign+=1
    If nolign = WMAX : Break : Endif    # llc 04.03 17909
    [M] = [F]

    #LECTURE du libellé traduisible
    Call LECTEXTRA([M]WSTDES(nolign-1),"WORKSTATIO","WSTDESAXX",[F]WST,[F]WCRFCY) From ATEXTRA

    If [M:TUW2]FVLTCCE = 2
        [M]VLTCCE(nolign-1) = [M:TUW2]VLTCCE
    Endif
    If [M:TUW2]FTWD = 2
        [M]TWD(nolign-1) = [M:TUW2]TWD
    Endif

    If [M:TUW2]FWSTNBR = 2
        If [M:TUW2]WSTNBRF <> ""
            Read [F:TFO]TFO0 = 9;[M:TUW2]WSTNBRF
            If !fstat
                [M]WSTNBR(nolign-1) = int(evalue([F:TFO]FORFOR))
                If [M]WSTNBR(nolign-1) <= 0 : [M]WSTNBR(nolign-1) = [F]WSTNBR : Endif
            Endif
        Else
            [M]WSTNBR(nolign-1) = [M:TUW2]WSTNBRV
        Endif
        If [M]WSTNBR(nolign-1) = 0 : [M]WSTNBR(nolign-1) = [F:MWS]WSTNBR : Endif    # llc 08.01 10159
    Endif

    If [M:TUW2]FPCTAUT = 2
        If [M:TUW2]CLEPCTAUTF <> ""
            # FGR 14/01/2010 : X3SUIVI60986
            #Read [F:TFO]TFO0 = 9;[M:TUW2]CLEPCTAUT
            Read [F:TFO]TFO0 = 9;[M:TUW2]CLEPCTAUTF
            If !fstat
                [M]CLEPCTAUT(nolign-1) = evalue([F:TFO]FORFOR)
                If [M]CLEPCTAUT(nolign-1) <= 0 : [M]CLEPCTAUT(nolign-1) = [F]CLEPCTAUT : Endif
            Endif
        Else
            [M]CLEPCTAUT(nolign-1) = [M:TUW2]CLEPCTAUTV
        Endif
    Endif

    If [M:TUW2]FSTOLOC = 2
        [M]STOLOC(nolign-1) = [M:TUW2]STOLOC
    Endif

    If [M:TUW2]FQLFLEV = 2
        [M]QLFLEV(nolign-1) = [M:TUW2]QLFLEV
    Endif

    If [M:TUW2]FEFF = 2
        If [M:TUW2]EFFF <> ""
            Read [F:TFO]TFO0 = 9;[M:TUW2]EFFF
            If !fstat
                [M]EFF(nolign-1) = evalue([F:TFO]FORFOR)
                If [M]EFF(nolign-1) <= 0 : [M]EFF(nolign-1) = [F]EFF : Endif
            Endif
        Else
            [M]EFF(nolign-1) = [M:TUW2]EFFV
        Endif
    Endif

#    If [M:TUW2]FUSE = 2
#        Read [F:TFO]TFO0 = 9;[M:TUW2]USE
#        If !fstat
#            [M]USE(nolign-1) = int(evalue([F:TFO]FORFOR))
#        Endif
#    Endif

    If [M:TUW2]FSHR = 2
        If [M:TUW2]SHRF <> ""
            Read [F:TFO]TFO0 = 9;[M:TUW2]SHRF
            If !fstat
                [M]SHR(nolign-1) = evalue([F:TFO]FORFOR)
                If [M]SHR(nolign-1) < -99 : [M]SHR(nolign-1) = [F]SHR : Endif
            Endif
        Else
            [M]SHR(nolign-1) = [M:TUW2]SHRV
        Endif
    Endif

# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
     If dim([M:TUW2]FDSPLEV)>0 & [M:TUW2]FDSPLEV = 2
        [M]DSPLEV(nolign-1) = [M:TUW2]DSPLEV
     Endif

    If [M:TUW3]FCONSTRAIN=2
        [M]CONSTRAINT(nolign-1) = [M:TUW3]CONSTRAINT
    Endif

    If [M:TUW3]FRCCP=2
        [M]RCCP(nolign-1)=[M:TUW3]RCCP
    Endif

# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
    If dim([M:TUW3]FGRPFLG)>0 & [M:TUW3]FGRPFLG = 2
        [M]GRPFLG(nolign-1)= [M:TUW3]GRPFLG
    Endif

# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
    If dim([M:TUW3]FGRPHOR)>0 & [M:TUW3]FGRPHOR =2
        [M]GRPHOR(nolign-1)= [M:TUW3]GRPHOR
    Endif
Next

Filter [MWS]

[M:TUW4]NBLIG = nolign

If [M:TUW4]NBLIG > 0
    Affzo [M:TUW4]
Endif

If nolign = WMAX : Call MESSAGE(mess(168,190,1)) From GESECRAN: Endif   # llc 04.03 17909

Return
#########################################################################
$SETBOUT

Raz ETABOU
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
ETABOU(GBFIN) = 1
Return

##########################################################################
# Traitement des actions evenementielles            #
$APRES_MODIF
REP="M"
Gosub SETBOUT
Return

#######################################################################
$ENREGISTRE
Gosub MODIF
FIN=1
GERR=2
GMESSAGE=mess(363,197,1)
Return

#######################################################################
$ABORT
Raz [M]
Affzo [M]
Gosub LIRE
Return

#######################################################################
$FIN
#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3
Return

#######################################################################
$TERMINE

TRA=1
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

##########################################################################
# Enregistrement des modifications
$MODIF
Call TEMPON("V") From GESECRAN

If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
Gosub MODMWS
If !NBMWS
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Return : Endif

If [M]EFFUPD  = 2 : Gosub MODOPE : Endif
If [M]LOADUPD = 2 : Gosub RELOAD : Endif
Call TEMPOFF From GESECRAN
Return


##########################################################################
# Mise à jour postes
$MODMWS
Gosub MAJMWS
If NBMWS
    WMESS1=num$(NBMWS)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif
Return

##########################################################################
$MAJMWS
NBMWS = 0
Call DEBTRANS From GLOCK
GOK=1
Trbegin [MWS]
    For nolign=1 To [M]NBLIG
        Read [MWS]WST0=[M]WST(nolign-1);[M]WCRFCY
        If fstat : Goto NXTMWS2 : Endif    # MM 08/01
        # Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields (dim DSPLEV, GPRHOR, GRPFLG)
        # pas la peine de modifier si rien n'a changé
        If [F:MWS]VLTCCE       = [M]VLTCCE(nolign-1)     &
&          [F:MWS]TWD          = [M]TWD(nolign-1)        &
&          [F:MWS]WSTNBR       = [M]WSTNBR(nolign-1)     &
&          [F:MWS]CLEPCTAUT    = [M]CLEPCTAUT(nolign-1)  &
&          [F:MWS]STOLOC       = [M]STOLOC(nolign-1)     &
&          [F:MWS]QLFLEV       = [M]QLFLEV(nolign-1)     &
&          [F:MWS]EFF          = [M]EFF(nolign-1)        &
&          [F:MWS]USE          = [M]USE(nolign-1)        &
&          [F:MWS]SHR          = [M]SHR(nolign-1)        &
&          (dim([M]DSPLEV(nolign-1))<0 | [F:MWS]DSPLEV = [M]DSPLEV(nolign-1))     &
&          [F:MWS]CONSTRAINT   = [M]CONSTRAINT(nolign-1) &
&          [F:MWS]RCCP         = [M]RCCP(nolign-1)       &
&          (dim([M]GRPFLG(nolign-1))<0 | [F:MWS]GRPFLG = [M]GRPFLG(nolign-1))     &
&          (dim([M]GRPHOR(nolign-1))<0 | [F:MWS]GRPHOR = [M]GRPHOR(nolign-1))
            Goto NXTMWS2
        Endif
        If [F:MWS]TWD <> [M]TWD(nolign-1) | [F:MWS]WSTNBR <> [M]WSTNBR(nolign-1)
            [M]UPDSCDFLG(nolign-1) = 2
        Endif
$NXTMWS1
        WMESS1=mess(52,197,1)-[M]WCRFCY+"/"+[M]WST(nolign-1)
        Call ECR_TRACE(WMESS1,0) From GESECRAN
        Readlock [MWS]WST0=[M]WST(nolign-1);[M]WCRFCY
        If fstat = 1
            GOK = -1:GLOCK="$WORKSTATIO"+[M]WST(nolign-1)
            Goto ROLL_MODMWS
        Endif
        If fstat
            GOK = 0 :Call RSTA("MWS", [M]WST(nolign-1)) From GLOCK
            Goto AB_MOD
        Endif

        [F:MWS] = [M]

# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
        If dim([M:TUW3]FGRPFLG)>0 & [M:TUW3]FGRPFLG = 2
            # Si type du poste<>MA ou  si nombre d'exemplaire >1,
            # on force regroupement à "NON"
            If ([F:MWS]WSTTYP <> 1 | [F:MWS]WSTNBR > 1 ): [F:MWS]GRPFLG= 1
            Else
                Read [CPV]CPV0=[M]WST(nolign-1);[M]WCRFCY
                If fstat = 0
                    For I=0 To 24
                        If [F:CPV]STRDAT(I) = [0/0/0] : Break : Endif
                        If [F:CPV]WSTNBR(I)>1 :  [F:MWS]GRPFLG= 1 : Break : Endif
                    Next I
                Endif
            Endif

            # si valeur regroupement= NON , horizon regroupement =0
            If [F:MWS]GRPFLG=1 : [F:MWS]GRPHOR = 0 : Endif
        Endif

        Rewrite [MWS]
        If fstat
            GOK = 0: Call FSTA("MWS") From GLOCK
            Goto AB_MOD
        Endif

        [M]UPDFLG(nolign-1) = 2
        NBMWS +=  1
$NXTMWS2
    Next nolign
If  GOK = 1 : Commit : Endif

$FIN_MAJMWS
Return

##########################################################################
# Mise à jour opérations
$MODOPE

Gosub MAJROT
WMESS1=num$(NBROT)-mess(364,197,1)
Call ECR_TRACE(WMESS1,0) From GESECRAN
Gosub MAJOPE
WMESS1=num$(NBOPE)-mess(364,197,1)
Call ECR_TRACE(WMESS1,0) From GESECRAN
Return


##########################################################################
$MAJROT
Local Integer X
NBROT = 0
GOK=1

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(366,197,1),0) From GESECRAN
# filtre des opérations standard du site
Filter [ROT] Where FCY=[M]WCRFCY

# llc 11.02 Performances 2
For [ROT]ROT1
    X = find([F:ROT]WST,[M]WST(0..[M]NBLIG - 1))
    If X = 0 : Goto NXTROT : Endif

    # décrémentation du no pour être en phase avec indice tableau
    X -= 1

    # si poste non modifié
    If [M]UPDFLG(X) = 1 : Goto NXTROT : Endif

    If ([M]EFF(X) = [F:ROT]EFF) & ([M]SHR(X) = [F:ROT]SHR) : Goto NXTROT : Endif

    WMESS1=mess(365,197,1)-[M]WCRFCY+"/"+num$([F:ROT]STDOPENUM)-"("+[M]WST(X)+")"
    Call ECR_TRACE(WMESS1,0) From GESECRAN

    Call DEBTRANS From GLOCK
    Trbegin [ROT]
        Readlock [ROT]Curr
        If fstat = 1
            GOK = -1:GLOCK="$ROUOPESTD"+num$([F:ROT]STDOPENUM)
            Goto ROLL_MODROT
        Endif
        If fstat
            GOK = 0 :Call RSTA("ROT", num$([F:ROT]STDOPENUM)) From GLOCK
            Goto AB_MOD
        Endif

        If GWSTEFFINH = 2 : [F:ROT]EFF = [M]EFF(X) : Endif
        [F:ROT]SHR = [M]SHR(X)

        Rewrite [ROT]
        If fstat
            GOK = 0: Call FSTA("ROT") From GLOCK
            Goto AB_MOD
        Endif
        NBROT +=  1
    If  GOK = 1 : Commit : Endif
$NXTROT
Next

$FIN_MAJROT
Filter [ROT]
Return

##########################################################################
$MAJOPE
Local Integer X
Local Date    TODAY : TODAY = date$
NBOPE = 0
GOK=1

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(368,197,1),0) From GESECRAN

# filtre des opérations standard du site
Filter [ROO] Where FCY=[M]WCRFCY & (VALENDDAT = [0/0/0] | VALENDDAT >= TODAY)

# llc 11.02 Performances 2
For [ROO]ROO1
    X = find([F:ROO]WST,[M]WST(0..[M]NBLIG - 1))
    If X = 0 : Goto NXTOPE : Endif
    # décrémentation du no pour être en phase avec indice tableau
    X -= 1

    # si poste non modifié
    If [M]UPDFLG(X) = 1 : Goto NXTOPE : Endif

    If (([M]EFF(X) <> [F:ROO]EFF) & GWSTEFFINH = 2) | ([M]SHR(X) <> [F:ROO]SHR)

        WMESS1=mess(370,197,1)-[F:ROO]ITMREF+"/"+num$([F:ROO]ROUALT)+"/"+num$([F:ROO]OPENUM)-"("+[M]WST(X)+")"
        Call ECR_TRACE(WMESS1,0) From GESECRAN

        Call DEBTRANS From GLOCK
        Trbegin [ROO]
            Readlock [ROO]Curr
            If fstat = 1
                GOK = -1:GLOCK="$ROUOPE"+[F:ROO]ITMREF+num$([F:ROO]ROUALT)+num$([F:ROO]OPENUM)
                Goto ROLL_MODOPE
            Endif
            If fstat
                GOK = 0 :Call RSTA("ROO", [F:ROO]ITMREF+num$([F:ROO]ROUALT)+num$([F:ROO]OPENUM)) From GLOCK
                Goto AB_MOD
            Endif

            If GWSTEFFINH = 2 : [F:ROO]EFF = [M]EFF(X) : Endif
            [F:ROO]SHR = [M]SHR(X)

            Rewrite [ROO]
            If fstat
                GOK = 0: Call FSTA("ROO") From GLOCK
                Goto AB_MOD
            Endif
            NBOPE +=  1
            If  GOK = 1 : Commit : Endif
     Endif
$NXTOPE
Next

$FIN_MAJOPE
Return

##########################################################################
# Mise à jour charge
$RELOAD
Gosub MAJLOAD
WMESS1=num$(NBOF)-mess(374,197,1)
Call ECR_TRACE(WMESS1,0) From GESECRAN
Return

##########################################################################
$MAJLOAD
NBOF = 0

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(372,197,1),0) From GESECRAN

For nolign = 1 To [M]NBLIG
    # si poste non modifié
    If [M]UPDFLG(nolign-1) = 1    : Goto NXTSTATION : Endif

    # si pas à rejalonner
    If [M]UPDSCDFLG(nolign-1) = 1 : Goto NXTSTATION : Endif

    #   Jalonnement des OF fermes et planifiés concernés
    Link   [MFO1] With [MFG1]MFG0=[F:MFO1]MFGNUM    As [MFX]
&                 Where [F:MFG1]MFGFCY=[M]WCRFCY
&                     & [F:MFG1]MFGSTA < 3
&                     & [F:MFG1]SCDFLG > 1
&                     & [F:MFO1]EXTWST = [M]WST(nolign-1)
&                 Order By Key MFO0(1)

    For [MFX]

        # OF déjà jalonné ?
        Look [TUC]TUC0 = [F:MFG1]MFGNUM
        If !fstat : Goto NJAL2 : Endif

        # Issue X3-23527 - 2017-02-02 by ALSHE : No reschedule of WO when it is being optimized
        If func AFNC.ACTIV("POPS") & ([F:MFG1]OPTFLG=2 | [F:MFG1]SCDFLG=4 )
            WMESS   = mess(156,197,1)-tolower(mess([F:MFG1]MFGSTA,317,1))-[F:MFG1]MFGNUM-":"-tolower(mess(122,193,1))
            Call ECR_TRACE(WMESS,-1) From GESECRAN
            Goto NJAL2
        Endif
        # End issue X3-23527
        # trace
        WMESS   = mess(373,197,1)-[F:MFG1]MFGNUM-tolower(mess([F:MFG1]MFGSTA,317,1))-"("+[M]WST(nolign-1)+")"
        Call ECR_TRACE(WMESS,0) From GESECRAN

        Trbegin ADOVAL
        #     déjalonnement
        Raz [M:JALK]
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = [M]WCRFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:MFG1]MFGNUM
        [M:JALK]MFGSTA = [F:MFG1]MFGSTA
        [M:JALK]CODMAJ = 3
        Call DEJALONNE From JALLIBA
        If [M:JALK]CODRET <> 0
            WMESS   = [F:MFG1]MFGNUM-"-"
            Gosub AB_MOD
            Goto NJAL2
        Endif

        #     jalonne chaque OF
        Raz [M:JALK]
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = [M]WCRFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:MFG1]MFGNUM
        [M:JALK]MFGSTA = [F:MFG1]MFGSTA
        [M:JALK]CODMAJ = 3
        # llc 12.02 16779
        If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
            Read [PJA]PJA0=[M:JALK]MFGFCY
            If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
        Endif
        Call JALONNE From JALLIB
        # Issue 111414 - 2016-01-22 by CCC : On routing version error, continue !
        #If [M:JALK]CODRET <> 0
        If !find([M:JALK]CODRET,0,2)
            WMESS   = [F:MFG1]MFGNUM-"-"
            Gosub AB_MOD
            Goto NJAL2
        Endif

        # on mémorise les OF jalonnés pour ne pas le faire n fois ...
        [F:TUC]MFGNUM = [F:MFG1]MFGNUM
        [F:TUC]SCDFLG = 2
        Write [TUC]

        NBOF += 1
        Commit
    $NJAL2
    Next

    #   Jalonnement des OF suggérés concernés

    # Issue X3-23527 - 2017-02-02 by ALSHE : No reschedule of WOS when it is being optimized
    For [ORD] Where WIPTYP = 5 & WIPNUM = [M:JALK]MFGNUM
        Break
    Next
    If func AFNC.ACTIV("POPS") & [ORD]OPTFLG = 2
        WMESS   = mess(156,197,1)-tolower(mess([ORD]WIPSTA,317,1))-[ORD]MFGNUM-":"-tolower(mess(122,193,1))
        Call ECR_TRACE(WMESS,-1) From GESECRAN
        Goto NJAL3
    Endif
    # End issue X3-23527

    Link [OPS1]  With [SCH1]SCH0=[F:OPS1]MFGNUM;[F:OPS1]OPENUM;[F:OPS1]OPESPLNUM As [OPX]
&                Where [F:OPS1]MFGFCY=[M]WCRFCY
&                    & [F:OPS1]OPSSTA = 3
&                    & [F:SCH1]OPESTRDAT <> [0/0/0]
&                    & [F:OPS1]EXTWST = [M]WST(nolign-1)
&                 Order By Key OPS1(1)
    For [OPX]

        # OF déjà jalonné ?
        Look [TUC]TUC0 = [F:OPS1]MFGNUM
        If !fstat : Goto NJAL3 : Endif

        # trace
        WMESS   = mess(373,197,1)-[F:OPS1]MFGNUM-tolower(mess([F:OPS1]OPSSTA,317,1))-"("+[M]WST(nolign-1)+")"
        Call ECR_TRACE(WMESS,0) From GESECRAN

        Trbegin ADOVAL
        #     déjalonne chaque suggestion
        Raz [M:JALK]
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = [M]WCRFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:OPS1]MFGNUM
        [M:JALK]MFGSTA = [F:OPS1]OPSSTA
        [M:JALK]CODMAJ = 3
        Call DEJALONNE From JALLIBA
        If [M:JALK]CODRET <> 0
            WMESS   = [F:OPS1]MFGNUM-"-"
            Gosub AB_MOD
            Goto NJAL3
        Endif

        #     jalonne chaque OF
        Raz [M:JALK]
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = [M]WCRFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:OPS1]MFGNUM
        [M:JALK]MFGSTA = 3
        [M:JALK]CODMAJ = 3
        # llc 12.02 16779
        If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
            Read [PJA]PJA0=[M:JALK]MFGFCY
            If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
        Endif
        Call JALONNE From JALLIB
        # Issue 111414 - 2016-01-22 by CCC : On routing version error, continue !
        #If [M:JALK]CODRET <> 0
        If !find([M:JALK]CODRET,0,2)
            WMESS   = [F:OPS1]MFGNUM-"-"
            Gosub AB_MOD
            Goto NJAL3
        Endif

        # on mémorise les OF jalonnés pour ne pas le faire n fois ...
        [F:TUC]MFGNUM = [F:MFG1]MFGNUM
        [F:TUC]SCDFLG = 2
        Write [TUC]

        NBOF += 1
        Commit
    $NJAL3
    Next

$NXTSTATION
Next nolign

# raz table mémo OF jalonnés
For [TUC] With Lock
    Delete [TUC]
Next

Return


##########################################################################
$ROLL_MODMWS
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJMWS :Endif

Return
##########################################################################
$ROLL_MODROT
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJROT :Endif

Return
##########################################################################
$ROLL_MODOPE
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJOPE :Endif

Return
##########################################################################
$AB_MOD
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

