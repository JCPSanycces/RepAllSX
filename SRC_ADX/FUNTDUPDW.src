########################################
Subprog AS_WCRFCY(VALEUR)
Variable Char    VALEUR()
If [M:TUW2]FVLTCCE    = 1 : Grizo [M:TUW2]VLTCCE                                 : Endif
If [M:TUW2]FTWD       = 1 : Grizo [M:TUW2]TWD                                    : Endif
If [M:TUW2]FWSTNBR    = 1 : Grizo [M:TUW2]WSTNBRF    : Grizo [M:TUW2]WSTNBRV     : Endif
If [M:TUW2]FPCTAUT    = 1 : Grizo [M:TUW2]CLEPCTAUTF : Grizo [M:TUW2]CLEPCTAUTV  : Endif
If [M:TUW2]FSTOLOC    = 1 : Grizo [M:TUW2]STOLOC                                 : Endif
If [M:TUW2]FQLFLEV    = 1 : Grizo [M:TUW2]QLFLEV                                 : Endif
If [M:TUW2]FEFF       = 1 : Grizo [M:TUW2]EFFF       : Grizo [M:TUW2]EFFV        : Endif
If [M:TUW2]FUSE       = 1 : Grizo [M:TUW2]USE                                    : Endif
If [M:TUW2]FSHR       = 1 : Grizo [M:TUW2]SHRF       : Grizo [M:TUW2]SHRV        : Endif
# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
If dim([M:TUW2]FDSPLEV)>0 & dim([M:TUW2]DSPLEV)>0
    If [M:TUW2]FDSPLEV    = 1 : Grizo [M:TUW2]DSPLEV                             : Endif
Endif
If [M:TUW3]FCONSTRAIN = 1 : Grizo [M:TUW3]CONSTRAINT                             : Endif
If [M:TUW3]FRCCP      = 1 : Grizo [M:TUW3]RCCP                                   : Endif
# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
If dim([M:TUW3]FGRPFLG)>0 & dim([M:TUW3]FGRPHOR)>0
    If [M:TUW3]FGRPFLG    = 1 : Grizo [M:TUW3]GRPFLG                             : Endif
    If [M:TUW3]FGRPHOR    = 1 : Grizo [M:TUW3]GRPHOR                             : Endif
Endif
End

########################################
Subprog B1_VLTCCE(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY
WFCY = [M:TUW1]WCRFCY
Call OBJET("MWC",WFCY,VALEUR) From GOBJET
If [F:MWC]VLTCCE <> "" & [F:MWC]VLTFCY = [M:TUW1]WCRFCY
    VALEUR = [F:MWC]VLTCCE
Endif
End


########################################
Subprog IB_VLTCCE
Raz GBOUT1
GBOUT1 = mess(410,198,1)
End

########################################
Subprog C_VLTCCE(VALEUR)
Variable Char    VALEUR()

# contrôle existence
If VALEUR <> ""
   Read [MWC]WCT0=VALEUR;[M:TUW1]WCRFCY
   If  fstat : GMESSAGE=mess(137,193,1)
      mkstat=2
   Endif
Endif

End

########################################
Subprog B1_STOLOC(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog IB_STOLOC
GBOUT1=mess(9,198,1)
End

########################################
Subprog C_STOLOC(VALEUR)
Variable Char    VALEUR()

VALEUR = toupper(VALEUR)
If clalev([F:STC])=0 : Local File STOLOC [STC] : Endif
If VALEUR <> ""
    Read [STC]STC0=[M:TUW1]WCRFCY;VALEUR
    Case fstat
        When 1,4,5 : GMESSAGE = mess(23,100,1)
                     mkstat = 2
                     End
    Endcase
    If !find([F:STC]LOCCAT,1,4)
        GMESSAGE=mess(16,196,1)
        mkstat=2
    Endif
Endif


End


########################################
Subprog AM_STOLOC(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

