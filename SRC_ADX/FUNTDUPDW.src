########################################
Subprog AM_WCRDEB(VALEUR)
Variable Char    VALEUR()
If [M]WCRDEB = ""     : [M]WCRFIN = VALEUR : Endif
If [M]WCRFIN < VALEUR : [M]WCRFIN = VALEUR : Endif
End

########################################
Subprog AM_WSTTYPDEB(VALEUR)
Variable Integer VALEUR
If VALEUR <> 0 : [M]WSTTYPFIN = VALEUR : Endif
End

########################################
Subprog C_WSTTYPFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]WSTTYPDEB : GMESSAGE = mess(44,199,1) : mkstat = 2 : End : Endif
End


########################################
Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()

If [M]WSTDEB = ""     : [M]WSTFIN = VALEUR : Endif
If [M:TUW2]WSTFIN < VALEUR : [M:TUW2]WSTFIN = VALEUR : Endif


End

