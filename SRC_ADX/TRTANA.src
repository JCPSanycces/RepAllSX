#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA - 2017-01-25- X3-11609- START
######################################################################################
# Modification :
#     SEGAY - 11/08/11 - 75605
# TRT TRTANA,TRTREM,TRTSYN,TRTTPS passage de MAXSEM de 8 à 12
#     FQ81491 - 12/11/13 - prise en compte date d'effet + fiches de rétroactivité
#     MABON - 24/09/13 - FQ92826 - TRT TRTANA,TRTREM,TRTSYN,TRTTPS passage de MAXSEM de 12 à 15
#     FQ92826 - 14/03/14 - TRT TRTANA,TRTREM,TRTSYN,TRTTPS passage de MAXSEM de 15 à 20
#     FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
#     SEGAY - 26/06/14 - US2768 - 92876 Accounting
######################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTTPS","TRTTPS",4,"") From GTRAITE
End

#####################################################################################
## Répartition ana de la paye en fonction des temps
#####################################################################################

Subprog MAJ(MATRI,DATPAY,CTR,BUL,DETAIL)
Value Char    MATRI
Value Date    DATPAY
Value Char    CTR
Value Char    BUL
Value Integer DETAIL

Local Integer MAXSEC
MAXSEC = 100
Local Integer MAXSEM
#61155
#MAXSEM   = 6
#MAXSEM   = 7
#FQ66409 - MABON 22/11/10
#MAXSEM   = 12
#MAXSEM   = 15
MAXSEM   = 20
Local Date    DATDEB , DATFIN, DATFIN_P, FINMOIS
Local Integer I , J , K , AXE , S , OK , OPT , PSPE
Local Integer NBSEC , NBSEM
#Local Char    TBCLE(250)(1..MAXSEC) , CLEGRP(250) #FQ92876-US2768-
Local Char    TBSEC(GLONCCE)(1..MAXSEC,1..GOPTCANA) , SECTION(GLONCCE)(1..GOPTCANA)
Local Integer ORD(1..MAXSEC)
Local Decimal TBPOI(1..MAXSEC)
Local Decimal POIDS , TOTAL , POITOT , SOMPOI , SOMCOE , RESTE , AJOUT, SUMP, SUMM
Local Decimal SUMANA , TOTANA , ANAPOI, WEKPAR, MONPAR
Local Decimal JOUR(1..7*MAXSEM) , HEURE(1..7*MAXSEM)
Local Integer EVT(1..7*MAXSEM)
Local Integer PRE(1..7*MAXSEM)
Local Char    ANALIS(GLONCCE)(1..GOPTCANA)
Local Integer LISSE
Local Char    ANAMOD(GLONCCE)(1..GOPTCANA)
Local Integer MODUL
Local Char    REPART(GLONDSP) , SECPREC(GLONCCE)(1..GOPTCANA)
Local Integer LIMITSEC, EXITSAL
Local Char    PARAM(10) , ACTION(20)

#Local Char    TIMMAJAUT(GLONTPS)(0..99) : # SEGAY 30/10/13 BUG 93017 US2026

# (C) PROSPER 19/11/10 - Infos comptables sur contrat ; quelques variables
# P05 / 66103 - Bug dans le cas particulier de la maj analytique depuis l'enchainement de saisie
#               Modification spécifiques infos contrats non reprises.
Local Char WDSP([V]GLONDSP)
#Local Integer WINICCE(1..9) #FQ92876-US2768-
Local Char WORICCE(10)     : # Origine des sections
Local Date    DATDEBCTR

Call EXISTE_ADX("","","SPECALTPS",PSPE) From ORDSYS

# FQ97072 - 27/03/14 - Séparation de chaque action
If DETAIL & GTRACE<>""
#MIPEA - 2017-01-26- X3-11609- START
 Call ECR_TRACE("-->"-mess(205,10709,1)-MATRI-CTR,0) From GESECRAN : # Maj analytique
# Call ECR_TRACE("-->"-mess(205,709,1)-MATRI-CTR,0) From GESECRAN : # Maj analytique
#MIPEA - 2017-01-26- X3-11609- END
Endif

Gosub OUVFIC From TRTTPS

#FQ92876-US2768-US2879- Le lissage et la modulation ne sont pas gérés en V7, donc LISSE et MODUL restent à 0 grâce à W_V7=1.
# Le jour où on les gèrera, on n'aura plus que W_V7 à mettre à 0, ou à enlever le test
Local Integer W_V7
W_V7=1
Local Char    WTABDIE(GLONDIE)(1..[V]GOPTCANA)
Local Char    WTABCCE(GLONCCE)(1..[V]GOPTCANA)
Local Char    WTABDIEPREC(GLONDIE)(1..[V]GOPTCANA)
Local Integer WJ,WINICCE(1..20),WOK,NBGRP
Local Char    WSAVGSOC(GLONCPY)
Local Integer WAXE
If clalev ([F:DIE])=0 : Local File =GTABCPT+"GDIE" [DIE] : Endif
#END FQ92876-US2768-US2879

# SEGAY 30/10/13 BUG 93017 US2026
Local Integer MAXCOD,NBCOD
[L]MAXCOD   = nbrecord([F:TIM])
Local Char    TIMMAJAUT(GLONTPS)(0..[L]MAXCOD-1)
# END 93017

# Mise à jour de la variable TIMMAJAUT qui contient les évènements temps dont l'analytique
# saisi dans les temps doit être repris par Maj auto dans la feuille de paye.
TIMMAJAUT(0) = GTPSW
# SEGAY 30/10/13 BUG 93017 US2026
[L]NBCOD=-1
If TIMMAJAUT(0) <> "" : [L]NBCOD=0 : Endif

Filter [TIM] Where CATTIM=1 & [F:TIM]COD<>GTPSW
For [TIM]TIM0
 [L]NBCOD += 1
 [L]TIMMAJAUT(NBCOD) = [F:TIM]COD
Next
Filter [TIM]
# END 93017

ACTION = "INIANA" : Gosub ACTION

#FQ92876-US2675- Est-ce la bonne société car plus bas on fait CTRETRFCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"ETRFCY","CTR")
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
#MIPEA - 2017-01-26- X3-11609- START
Raz [F:HRCTR]
#Raz [F:CTR]
#MIPEA - 2017-01-26- X3-11609- END
Read [VEP]VEP5 = [L]BUL
If !fstat
  If [F:CPY]CPY<>func DIVPAYE.GETSOC([F:VEP]FCY)
   Read [CPY]CPY0=func DIVPAYE.GETSOC([F:VEP]FCY)
  Endif
  Call VALDEF_FLD_ANA([F:CPY]CPY) From SUBVEP
  #92876 US2768
  # Repositionnement sur le contrat initial car le Lecemp et TRTCONT a pu changer ! comme dans SUBVEP car o utilise CTR dans TRTANA
#MIPEA - 2017-01-26- X3-11609- START
  Read[F:HRCTR]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
#  Read[F:CTR]CTR0=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
#MIPEA - 2017-01-26- X3-11609- END
Endif
#END FQ92876-US2675-
Raz [L]WDSP, [L]WINICCE

[L]WDSP = [F:CPT]DSP
Raz [L]WINICCE
For [L]J = 1 To [V]GOPTCANA
    #[L]WINICCE([L]J) = evalue("[F:CPT]INICCE"+num$([L]J))
    #FQ92876-US2675- Pour ne récuperer que les sections des axes lié à la société
    If [L]J <= GNBDIE
       [L]WJ=find(GDIE(J),[F:CPT]DIE(0..[V]GOPTCANA-1))
       If [L]WJ > 0
         [L]WINICCE([L]J) = evalue("[F:CPT]INICCE("+num$([L]WJ-1)+")")
       Endif
    Endif
    #END FQ92876-US2675-
Next
[L]WORICCE = "[F:CPT]"

#MIPEA - 2017-02-09- X3-11609- START
Read [F:CPR]CPR0 = [F:HRCTR]REFNUM ; [F:HRCTR]CTRNUM ; [F:HRCTR]CTRDAT
#Read [F:CPR]CPR0 = [F:CTR]REFNUM ; [F:CTR]CTRNUM ; [F:CTR]CTRDAT
#MIPEA - 2017-02-09- X3-11609- END
If fstat = 0
    Raz [L]WDSP, [L]WINICCE
    [L]WDSP = [F:CPR]DSP
    Raz [L]WINICCE
    For [L]J = 1 To [V]GOPTCANA
      If [L]J <= GNBDIE
         [L]WJ=find(GDIE(J),[F:CPR]DIE(0..[V]GOPTCANA-1))
         If [L]WJ > 0
           [L]WINICCE([L]J) = evalue("[F:CPR]INICCE("+num$([L]WJ-1)+")")
         Endif
      Endif
    Next
    [L]WORICCE = "[F:CPR]"
Endif

OK = 0
For AXE=1 To GOPTCANA
    [L]OK += ([L]WINICCE([L]AXE)=4)
Next AXE

If !OK
 If GPAYE
  #57223 : Add GNUMBUL
  Global Char GNUMBUL (GLONVCR)
  GNUMBUL=[L]BUL
  Call MAJFLGTPS (MATRI,DATPAY,CTR,4,2,[0/0/0]) From SUBVEP
  Kill GNUMBUL
 Endif
 End
Endif

Read [ID]ID0 = MATRI
#JOJAC - 2017-03-23 - START
#DATDEB = [F:PEO]PERSTR(0) :#Début temps(0) Début mois(1) Début régul(2) Début calendrier(3)
DATDEB = [F:HRPEOD]PERSTR(0) :#Début temps(0) Début mois(1) Début régul(2) Début calendrier(3)
#JOJAC - 2017-03-23 - END

#MIPEA - 2017-01-26- X3-11609- START
Read [TIM]TIM0=GCURLEG;TIMMAJAUT(0)
#Read [TIM]TIM0=TIMMAJAUT(0)
#MIPEA - 2017-01-26- X3-11609- END
If !fstat & [F:TIM]MONDAC=2 :# Mois calendaire
#MIPEA - 2017-01-26- X3-11609- START
 DATFIN  = [F:HRPEOD]PEREND(1) :#Fin de mois
Else
 DATFIN = [F:HRPEOD]PEREND(0)  :#Max Date
# DATFIN  = [F:PEO]PEREND(1) :#Fin de mois
#Else
# DATFIN = [F:PEO]PEREND(0)  :#Max Date
#MIPEA - 2017-01-26- X3-11609- END
Endif

#FQ66409 - MABON 22/11/10
DATFIN_P=DATFIN
# FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
#MIPEA - 2017-01-26- X3-11609- START
Call CALC_DATEND("", DATPAY, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL, [F:HRCTR]PERCOD) From TRTTPS
#Call CALC_DATEND("", DATPAY, [F:CTR]XITDAT, [F:CTR]XITFNL, [F:CTR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL) From TRTTPS
#MIPEA - 2017-01-26- X3-11609- END
DATFIN_P=max(DATFIN,DATFIN_P)

ACTION = "DATANA" : Gosub ACTION

NBSEM  = (DATFIN-DATDEB+1)/7

Raz PRE
Local Char CRITERE(50)
# FQ92876 - 08/07/14 - Pour calculer la présence du salarié, on doit se baser sur la date du contrat. Sinon, si plusieurs périodes d'activité,
# on va compter des présences d'une autre période d'activité que celle du bulltin en cours
CRITERE="1=1"
If [F:VEP]CTRDAT<>[0/0/0] Then
  # FQ91472 - 18/07/14 - Le critère n'est plus sur la date exacte, mais sur une fourchette de dates (STRCTRDAT et CTRDAT) pour gérer
  # la consolidation des bulletins
#  CRITERE="CTRDAT=[F:VEP]CTRDAT"
  CRITERE="CTRDAT>=[F:VEP]STRCTRDAT & CTRDAT<=[F:VEP]CTRDAT"
Endif
#For [CTR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR
#MIPEA - 2017-01-26- X3-11609- START
For [HRCTR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERE)
 # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 DATDEBCTR=[F:HRCTR]CTRDAT
 If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
  DATDEBCTR=[F:HRCTR]RETDATEFF
 Endif
#For [CTR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR & evalue(CRITERE)
# # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
# DATDEBCTR=[F:CTR]CTRDAT
# If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#  DATDEBCTR=[F:CTR]RETDATEFF
# Endif
#MIPEA - 2017-01-26- X3-11609- END
# If [F:CTR]XITDAT=[0/0/0] & [F:CTR]CTRDAT<=DATFIN
#  For I=max(DATDEB,[F:CTR]CTRDAT)-DATDEB+1 To DATFIN-DATDEB+1
#   PRE(I) = 1
#  Next I
# Elsif [F:CTR]XITDAT>=DATDEB & [F:CTR]CTRDAT<=DATFIN
#  For I=max(DATDEB,[F:CTR]CTRDAT)-DATDEB+1 To min(DATFIN,[F:CTR]XITDAT)-DATDEB+1
#   PRE(I) = 1
#  Next I
# Endif

#MIPEA - 2017-01-26- X3-11609- START
 If [F:HRCTR]XITDAT=[0/0/0] & DATDEBCTR<=DATFIN
  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To DATFIN-DATDEB+1
   PRE(I) = 1
  Next I
 Elsif [F:HRCTR]XITDAT>=DATDEB & DATDEBCTR<=DATFIN
  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To min(DATFIN,[F:HRCTR]XITDAT)-DATDEB+1
   PRE(I) = 1
  Next I
 Endif
# If [F:CTR]XITDAT=[0/0/0] & DATDEBCTR<=DATFIN
#  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To DATFIN-DATDEB+1
#   PRE(I) = 1
#  Next I
# Elsif [F:CTR]XITDAT>=DATDEB & DATDEBCTR<=DATFIN
#  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To min(DATFIN,[F:CTR]XITDAT)-DATDEB+1
#   PRE(I) = 1
#  Next I
# Endif
#MIPEA - 2017-01-26- X3-11609- END
 # Fin MABON
Next

Read [VEP]VEP5 = [L]BUL
If fstat
 If GTRACE<>"" & sum(PRE(1..7*MAXSEM))<>0
#MIPEA - 2017-01-26- X3-11609- START
  Call ECR_TRACE(MATRI-":"-mess(29,10709,1),1) From GESECRAN : # Paye non générée
#  Call ECR_TRACE(MATRI-":"-mess(29,709,1),1) From GESECRAN : # Paye non générée
#MIPEA - 2017-01-26- X3-11609- END
 Endif
 End
Elsif [F:VEP]PST>1
 If GTRACE<>""
#MIPEA - 2017-01-26- X3-11609- START
  Call ECR_TRACE(MATRI-":"-mess(30,10709,1),1) From GESECRAN : # Paye déjà comptabilisée
#  Call ECR_TRACE(MATRI-":"-mess(30,709,1),1) From GESECRAN : # Paye déjà comptabilisée
#MIPEA - 2017-01-26- X3-11609- END
 Endif
 End
Elsif [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
 If GTRACE<>""
  # MESSAGE : Opération impossible : ce bulletin est verouillé.
#  Call ECR_TRACE(MATRI-":"-[L]BUL-mess(224,703,1), 1) From GESECRAN
#MIPEA - 2017-01-26- X3-11609- START
  Call ECR_TRACE(MATRI-"("+mess(6,10506,1)-[F:VEP]CTRNUM-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,10703,1),0) From GESECRAN
#  Call ECR_TRACE(MATRI-"("+mess(6,506,1)-[F:VEP]CTRNUM-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,703,1),0) From GESECRAN
#MIPEA - 2017-01-26- X3-11609- END
 Endif
 End
Endif

# FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ ETRFCY
Local Char CTRETRFCY(GLONFCY)
#MIPEA - 2017-01-26- X3-11609- START
CTRETRFCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"ETRFCY","HRCTR")
#CTRETRFCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"ETRFCY","CTR")
#MIPEA - 2017-01-26- X3-11609- END
#92876 US2768-US2879 PAS DE LISSAGE POUR V7
LISSE = 0
If !W_V7
  For AXE=1 To GOPTCANA
  # Call PARAM([F:CTR]ETRFCY,"ANALIS"+num$(AXE),ANALIS(AXE)) From ADOVAL
   Call PARAM(CTRETRFCY,"ANALIS"+num$(AXE),ANALIS(AXE)) From ADOVAL
   # Fin FQ85820
  Next AXE
  If sum(ANALIS(1..GOPTCANA))<>""
   LISSE = 1
  Else
   LISSE = 0
  Endif
Endif


MODUL = 0
# FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ MODTPS
#If dim([F:CTR]MODTPS)>0 & [F:CTR]MODTPS=2
#92876 US2768-US2879 Pas de modulation analytique pour V7
LIMITSEC=0
If !W_V7
#MIPEA - 2017-01-26- X3-11609- START
  If dim([F:HRCTR]MODTPS)>0 & val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"MODTPS","HRCTR"))=2
#  If dim([F:CTR]MODTPS)>0 & val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"MODTPS","CTR"))=2
#MIPEA - 2017-01-26- X3-11609- END
   For AXE=1 To GOPTCANA
  #  Call PARAM([F:CTR]ETRFCY,"ANAMOD"+num$(AXE),ANAMOD(AXE)) From ADOVAL
    Call PARAM(CTRETRFCY,"ANAMOD"+num$(AXE),ANAMOD(AXE)) From ADOVAL
   Next AXE
   If sum(ANAMOD(1..GOPTCANA))<>""
    MODUL = 1
   Endif
  Endif
  #Call PARAM([F:CTR]ETRFCY,"MAXANA",PARAM) From ADOVAL
  #92876 US2768 Pas de MAXANA analytique pour V7
  Call PARAM(CTRETRFCY,"MAXANA",PARAM) From ADOVAL
  LIMITSEC = val(PARAM)
Endif

## Temps théoriques y compris jours fériés

#Call VALORDET(DATDEB,DATFIN_P,MATRI,"",JOUR,HEURE,[F:CTR]ETRFCY,[F:CTR]CTRNUM) From SUBPLN
#MIPEA - 2017-01-26- X3-11609- START
Call VALORDET(DATDEB,DATFIN_P,MATRI,"",JOUR,HEURE,CTRETRFCY,[F:HRCTR]CTRNUM) From SUBPLN
#Call VALORDET(DATDEB,DATFIN_P,MATRI,"",JOUR,HEURE,CTRETRFCY,[F:CTR]CTRNUM) From SUBPLN
#MIPEA - 2017-01-26- X3-11609- END
## Parcours des temps
# FQ82073 - MABON 21/12/12 - Ajout CTRDAT dans TIMEMP
#For [TIP]TIP1 Where ENDDAT>=DATDEB & STRDAT<=DATFIN & REFNUM=MATRI & CTRNUM=CTR
#For [TIP]TIP1 Where ENDDAT>=DATDEB & STRDAT<=DATFIN & REFNUM=MATRI & CTRNUM=CTR & CTRDAT=[F:VEP]CTRDAT
# FQ91472 - 18/07/14 - Le critère n'est plus sur la date exacte, mais sur une fourchette de dates (STRCTRDAT et CTRDAT) pour gérer
# la consolidation des bulletins
For [TIP]TIP1 Where ENDDAT>=DATDEB & STRDAT<=DATFIN & REFNUM=MATRI & CTRNUM=CTR & CTRDAT>=[F:VEP]STRCTRDAT & CTRDAT<=[F:VEP]CTRDAT
# Fin MABON
 If [F:TIP]STRDAT=[F:TIP]ENDDAT
  POIDS = [F:TIP]NBRHOU
  K = [F:TIP]STRDAT-DATDEB+1
  EVT(K) = 1
 Else
  POIDS = 0
  For K=max(DATDEB,[F:TIP]STRDAT)-DATDEB+1 To min(DATFIN,[F:TIP]ENDDAT)-DATDEB+1
   POIDS += HEURE(K)
   EVT(K) = 1
  Next K
 Endif
#34772
# If [F:TIP]TIM=GTPSW : # Travail
 If find([F:TIP]TIM,TIMMAJAUT(0..dim(TIMMAJAUT)-1))
  If [F:TIP]ANAFLG=0
   #FQ92876-US2768-
   For AXE=1 To GOPTCANA
     WTABDIE(AXE) = [F:TIP]DIE(AXE-1)
     WTABCCE(AXE) = [F:TIP]CCE(AXE-1)
   Next AXE
   Gosub ANA_TIP
   Gosub SET_SEC
  Else
   SUMANA = 0
   TOTANA = POIDS
   ANAPOI = 0
   For [TIA]TIA0 Where LIG=[F:TIP]LIG
    ANAPOI += [F:TIA]NBRHOU
   Next
   If ANAPOI<>0
    For [TIA]TIA0 Where LIG=[F:TIP]LIG
     POIDS   = ar2((SUMANA+[F:TIA]NBRHOU)*TOTANA/ANAPOI) - ar2(SUMANA*TOTANA/ANAPOI)
     SUMANA += [F:TIA]NBRHOU
     #FQ92876-US2768-
     For AXE=1 To GOPTCANA
       WTABDIE(AXE) = [F:TIA]DIE(AXE-1)
       WTABCCE(AXE) = [F:TIA]CCE(AXE-1)
     Next AXE
     Gosub ANA_TIA
     Gosub SET_SEC
    Next
   Endif
  Endif
 Else                : # Autres temps, on prend la section de l'employé ??
  #FQ92876-US2768-
  For AXE=1 To GOPTCANA
      WTABDIE(AXE) = [F:TIP]DIE(AXE-1)
      WTABCCE(AXE) = evalue([L]WORICCE+"CCE("+num$([L]AXE-1)+")")
  Next AXE
  Gosub ANA_EMP
  Gosub SET_SEC
 Endif

Next

## Parcours des réguls

# FQ82073 - MABON 21/12/12 - Ajout CTRDAT dans TIMREGUL
#For [TIG]TIG1 Where ENDDAT>=DATDEB & STRDAT<=DATFIN & REFNUM=MATRI & CTRNUM=CTR
# FQ91472 - 18/07/14 - Le critère n'est plus sur la date exacte, mais sur une fourchette de dates (STRCTRDAT et CTRDAT) pour gérer
# la consolidation des bulletins
#For [TIG]TIG1 Where ENDDAT>=DATDEB & STRDAT<=DATFIN & REFNUM=MATRI & CTRNUM=CTR & CTRDAT=[F:VEP]CTRDAT
For [TIG]TIG1 Where ENDDAT>=DATDEB & STRDAT<=DATFIN & REFNUM=MATRI & CTRNUM=CTR & CTRDAT>=[F:VEP]STRCTRDAT & CTRDAT<=[F:VEP]CTRDAT
# Fin MABON
 POIDS = [F:TIG]NBRHOU
 #34772
 #If [F:TIG]TIM=GTPSW : # Travail
 If find([F:TIG]TIM,TIMMAJAUT(0..dim(TIMMAJAUT)-1))
  If [F:TIG]ANAFLG=0
    #FQ92876-US2768-
   For AXE=1 To GOPTCANA
       WTABDIE(AXE) = [F:TIG]DIE(AXE-1)
       WTABCCE(AXE) = [F:TIG]CCE(AXE-1)
   Next AXE
   Gosub ANA_TIG
   Gosub SET_SEC
  Else
   SUMANA = 0
   TOTANA = POIDS
   ANAPOI = 0
   For [TIA]TIA0 Where LIG=[F:TIG]LIG
    ANAPOI += [F:TIA]NBRHOU
   Next
   If ANAPOI<>0
    For [TIA]TIA0 Where LIG=[F:TIG]LIG
     POIDS   = ar2((SUMANA+[F:TIA]NBRHOU)*TOTANA/ANAPOI) - ar2(SUMANA*TOTANA/ANAPOI)
     SUMANA += [F:TIA]NBRHOU
     #FQ92876-US2768-
     For AXE=1 To GOPTCANA
       WTABDIE(AXE) = [F:TIA]DIE(AXE-1)
       WTABCCE(AXE) = [F:TIA]CCE(AXE-1)
     Next AXE
     Gosub ANA_TIA
     Gosub SET_SEC
    Next
   Endif
  Endif
 Else                : # Autres temps, on prend la section de l'employé ??
  #FQ92876-US2768-
  For AXE=1 To GOPTCANA
      WTABDIE(AXE) = evalue([L]WORICCE+"DIE("+num$([L]AXE-1)+")")
      WTABCCE(AXE) = evalue([L]WORICCE+"CCE("+num$([L]AXE-1)+")")
  Next AXE
  Gosub ANA_EMP
  Gosub SET_SEC
 Endif
Next

## Il reste les jours sans événement et fériés

#FQ66409 - MABON 22/11/10
#For K=1 To 35
For K=1 To 7*MAXSEM
 # FQ92876 - 08/07/14 - Ajout du test sur PRE(K) pour ne comptabiliser que les jours sur lesquels le salarié est présent
# If !EVT(K) & HEURE(K)
 If !EVT(K) & HEURE(K) & PRE(K)
  POIDS = HEURE(K)
  #FQ92876-US2768-
  For AXE=1 To GOPTCANA
      WTABDIE(AXE) = evalue([L]WORICCE+"DIE("+num$([L]AXE-1)+")")
      WTABCCE(AXE) = evalue([L]WORICCE+"CCE("+num$([L]AXE-1)+")")
  Next AXE
  Gosub ANA_EMP
  Gosub SET_SEC
 Endif
Next K

## Section de lissage

#34901
#92876 US2768 PAS DE LISSAGE POUR V7
If LISSE & MODUL=0
 Gosub ANA_LIS
# WEKPAR= val(func AFNC.PARAM("HOUWEKLEG",[F:CTR]ETRFCY))
# MONPAR= val(func AFNC.PARAM("HOUMONLEG",[F:CTR]ETRFCY))
 WEKPAR= val(func AFNC.PARAM("HOUWEKLEG",CTRETRFCY))
 MONPAR= val(func AFNC.PARAM("HOUMONLEG",CTRETRFCY))
 POIDS = MONPAR-NBSEM*WEKPAR
 Gosub SET_SEC
Endif

## Section de modulation
#92876 US2768 PAS DE MODULATION ANA POUR V7
If MODUL
#MIPEA - 2017-01-26- X3-11609- START
 Read [TIR]TIR0 = MATRI;CTR;[F:HRPEOD]PYRDAT
# Read [TIR]TIR0 = MATRI;CTR;[F:PEO]PYRDAT
#MIPEA - 2017-01-26- X3-11609- END
 If !fstat
  CTRDAT=[F:VEP]CTRDAT
  # FQ82073 - MABON 27/12/12 - Pour chaque semaine du mois de paie, on a défini la période d'activité correspondante.
  # On ne doit donc cumuler que les valeurs de la bonne période d'activité
#  TOTAL = sum([F:TIR]HOUMODDCR(1..NBSEM))-sum([F:TIR]HOUMODINC(1..NBSEM))
  For I=0 To dim([F:TIR]CTRDAT)-1
    # FQ91472 - 18/07/14 - Le critère n'est plus sur la date exacte, mais sur une fourchette de dates (STRCTRDAT et CTRDAT) pour gérer
    # la consolidation des bulletins
#    If [F:TIR]CTRDAT(I)<>[0/0/0] & [F:TIR]CTRDAT(I)=[F:VEP]CTRDAT Then
    If [F:TIR]CTRDAT(I)<>[0/0/0] & [F:TIR]CTRDAT(I)>=[F:VEP]STRCTRDAT & [F:TIR]CTRDAT(I)<=[F:VEP]CTRDAT Then
      SUMP += [F:TIR]HOUMODDCR(I)
      SUMM += [F:TIR]HOUMODINC(I)
    Endif
  Next
  TOTAL = SUMP-SUMM
  # Fin MABON
#  WEKPAR= val(func AFNC.PARAM("HOUWEKLEG",[F:CTR]ETRFCY))
  WEKPAR= val(func AFNC.PARAM("HOUWEKLEG",CTRETRFCY))
  If TOTAL & TOTAL<>NBSEM*WEKPAR
   Gosub ANA_MOD
   POIDS = TOTAL
   Gosub SET_SEC
  Endif
 Endif
Endif


## Nombre limite

For I=1 To NBSEC
 ORD(I) = I
Next I
#92876 US2768 Pas de MAXANA analytique pour V7
If LIMITSEC & NBSEC>LIMITSEC
 Sorta NBSEC TBPOI,ORD Order By -abs(TBPOI(indice+1))
 RESTE  = sum(TBPOI(LIMITSEC+1..NBSEC))
 SOMCOE = sum(TBPOI(1..LIMITSEC))
 SOMPOI = 0
 For I=1 To LIMITSEC
  AJOUT     = ar2(RESTE*(SOMPOI+TBPOI(I))/SOMCOE)-ar2(RESTE*SOMPOI/SOMCOE)
  SOMPOI   += TBPOI(I)
  TBPOI(I) += AJOUT
 Next I
 NBSEC = LIMITSEC
Endif

## Un petit spécifique ?

ACTION = "ANA" : Gosub ACTION

## Mise à jour feuille de paye

OK = 0
Filter [VEP] Where EMP=MATRI & PYRDAT<DATPAY & CTRNUM=CTR
Read [VEP]VEP0 Last
Filter [VEP]
If fstat<=2
 Read [VAN]VAN0 = MATRI;[F:VEP]PYRDAT;[F:VEP]BUL;1
 If !fstat
  OK = 1
  For AXE=1 To GOPTCANA
#FQ92876-US2768-
# Sauvegarde Axe et section
   WTABDIEPREC(AXE) = [F:VAN]DIE(AXE-1)
   SECPREC(AXE) = [F:VAN]CCE(AXE-1)
  Next AXE
 Endif
Endif
If !OK
 For AXE=1 To GOPTCANA
#FQ92876-US2768-
# Sauvegarde Axe et section
  WTABDIEPREC(AXE) = evalue([L]WORICCE+"DIE("+num$([L]AXE-1)+")")
  SECPREC(AXE) = evalue([L]WORICCE+"CCE("+num$([L]AXE-1)+")")
 Next AXE
Endif
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [VAN]
 Delete [VAN] Where EMP=MATRI & PYRDAT=DATPAY & BUL=[L]BUL
 If fstat=1
  GOK = -1 : GLOCK = "$VALANA" : Goto ROLL_TR1
 Endif
 For I=1 To NBSEC
  If TBPOI(I)<>0
   Raz [F:VAN]
   [F:VAN]EMP    = MATRI
   [F:VAN]PYRDAT = DATPAY
   [F:VAN]BUL    = [L]BUL
   [F:VAN]LIG    = I
   [F:VAN]COE    = TBPOI(I)
   For AXE=1 To GOPTCANA
    [L]OPT = [L]WINICCE([L]AXE)
    #FQ92876-US2768- MAJ des axes dans VALANA
    Read [DIE]DIE0=GDIE(AXE)
    If !fstat
     [F:VAN]DIE(AXE-1)=GDIE(AXE)
     Case OPT
     When 1 : # Conservation
#      [F:VAN]CCE(AXE-1) = SECPREC(AXE)
      [L]WAXE=find(WTABDIEPREC([L]AXE),GDIE(1..GNBDIE))
      If [L]AXE <= GNBDIE & [L]WAXE
       [F:VAN]CCE([L]WAXE-1) = SECPREC(AXE)
      Endif
     When 2 : # Annulation
      [F:VAN]CCE(AXE-1) = ""
     When 3 : # Standard=Section par défaut
      If dim(SECDEF)<0
       Local Char SECDEF(10)
#       Call PARAM([F:CTR]ETRFCY,"CCECDE",SECDEF) From ADOVAL
       Call PARAM(CTRETRFCY,"CCECDE",SECDEF) From ADOVAL
      Endif
      If SECDEF<>""
       # FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#MIPEA - 2017-01-26- X3-11609- START
       If ([F:HRCTR]CTRDAT>[L]DATPAY | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF>[L]DATPAY)) | ([F:HRCTR]XITDAT<[L]DATPAY & [F:HRCTR]XITDAT>[0/0/0])
        Filter [HRCTR] Where (CTRDAT<=[L]DATPAY | (FLGRET=2 & RETDATEFF<=[L]DATPAY)) & (XITDAT=[0/0/0] | XITDAT>=[L]DATPAY)
       # Fin MABON
        Read [HRCTR]CTR0(2)=[L]MATRI;[L]CTR
        Filter [HRCTR]
       Endif
#       If ([F:CTR]CTRDAT>[L]DATPAY | ([F:CTR]FLGRET=2 & [F:CTR]RETDATEFF>[L]DATPAY)) | ([F:CTR]XITDAT<[L]DATPAY & [F:CTR]XITDAT>[0/0/0])
#        Filter [CTR] Where (CTRDAT<=[L]DATPAY | (FLGRET=2 & RETDATEFF<=[L]DATPAY)) & (XITDAT=[0/0/0] | XITDAT>=[L]DATPAY)
#       # Fin MABON
#        Read [CTR]CTR0(2)=[L]MATRI;[L]CTR
#        Filter [CTR]
#       Endif
#MIPEA - 2017-01-26- X3-11609- END
       If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
       # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ ETRFCY
       Local Char CTRETRFCY(GLONFCY)
#MIPEA - 2017-01-26- X3-11609- START
       CTRETRFCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"ETRFCY","HRCTR")
#       CTRETRFCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"ETRFCY","CTR")
#MIPEA - 2017-01-26- X3-11609- END
       If [F:CPY]CPY<>func DIVPAYE.GETSOC(CTRETRFCY)
        Read [CPY]CPY0=func DIVPAYE.GETSOC(CTRETRFCY)
       Endif
       # Fin FQ85820
       WSAVGSOC=GSOCIETE : #FQ92876-US2768-
       GSOCIETE=[F:CPY]CPY
       Call INISEC([F:VAN]CCE(AXE-1),SECDEF,GDIE(AXE)) From SUBCDE : #FQ92876-US2768-
       GSOCIETE=WSAVGSOC
      Endif
     When 4 : # MAJ auto
      [F:VAN]CCE(AXE-1) = TBSEC(ORD(I),AXE)
     Endcase
    Endif # Endif du read GDIE
   Next AXE
   If sum([F:VAN]CCE(0..GOPTCANA-1))<>""
    Write [VAN]
    If fstat
     GOK = 0 : Call FSTA("VAN") From GLOCK : Break
    Endif
    If DETAIL
     If GTRACE<>""
#      Call ECR_TRACE(MATRI-":"-"MAJ Ana : "-sigma(0,GOPTCANA-1,[F:VAN]CCE(indcum)+" ")
#&      -num$([F:VAN]COE),0) From GESECRAN
      Call ECR_TRACE(MATRI-":"-"MAJ Ana : "-sigma(0,GOPTCANA-1,[F:VAN]DIE(indcum)+"/"+[F:VAN]CCE(indcum)+" ")
&      -num$([F:VAN]COE),0) From GESECRAN

     Endif
    Endif
   Endif
  Endif
 Next I
 If GOK<1 : Goto AB_TR1 : Endif
Commit
If !DETAIL & GTRACE<>""
#MIPEA - 2017-01-26- X3-11609- START
 Call ECR_TRACE(MATRI-":"-mess(46,10709,1),0) From GESECRAN : # Mise à jour analytique OK
# Call ECR_TRACE(MATRI-":"-mess(46,709,1),0) From GESECRAN : # Mise à jour analytique OK
#MIPEA - 2017-01-26- X3-11609- END
Endif

If GPAYE  & GOK
 #57223 : Add GNUMBUL
  Global Char GNUMBUL (GLONVCR)
  GNUMBUL=[L]BUL
  Call MAJFLGTPS (MATRI,DATPAY,CTR,4,2,[0/0/0]) From SUBVEP
  Kill GNUMBUL
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ANA_TIP
If [F:TIP]DSP<>""
 REPART = [F:TIP]DSP
Else
 REPART = ""
#FQ92876-US2768-
# Sauvegarde Axe et section
 Gosub ANA_SAV_SECTION
Endif
Return

$ANA_TIG
If [F:TIG]DSP<>""
 REPART = [F:TIG]DSP
Else
 REPART = ""
#FQ92876-US2768-
# Sauvegarde Axe et section
 Gosub ANA_SAV_SECTION
Endif
Return

$ANA_TIA
REPART = ""
#FQ92876-US2768-
# Sauvegarde Axe et section
Gosub ANA_SAV_SECTION
Return

$ANA_EMP

# (C) PROSPER 19/11/10 - Récupération du DSP d'origine
# If [F:CPT]DSP<>""
#  REPART = [F:CPT]DSP

If [L]WDSP<>""
 REPART = [L]WDSP
Else
 REPART = ""
#FQ92876-US2768-
# Sauvegarde Axe et section
 Gosub ANA_SAV_SECTION
Endif
Return

$ANA_LIS
#92876 US2768 PAS DE LISSAGE ANA POUR V7
REPART = ""
For AXE=1 To GOPTCANA
 SECTION(AXE) = ANALIS(AXE)
Next AXE
Return

$ANA_MOD
#92876 US2768 PAS DE MODULATION ANA POUR V7
REPART = ""
For AXE=1 To GOPTCANA
 SECTION(AXE) = ANAMOD(AXE)
Next AXE
Return

#FQ92876-US2675- Pour ne récuperer que les sections des axes lié à la société
$ANA_SAV_SECTION
Raz SECTION
For AXE=1 To GOPTCANA
   Read [DIE]DIE0=WTABDIE(AXE)
   If !fstat
    If [L]AXE <= GNBDIE
      [L]WAXE=find(WTABDIE([L]AXE),GDIE(1..GNBDIE))
      If [L]WAXE
         [L]SECTION([L]WAXE) = WTABCCE([L]AXE)
      Endif
    Endif
   Endif
Next AXE
Return


$SET_SEC
If REPART<>""
 SOMCOE = 0
 POITOT = POIDS
 For [DSP]DSP0 Where DSP=REPART
  SOMCOE += [F:DSP]COE
 Next
 If SOMCOE=0 : Return : Endif
 SOMPOI = 0
 For [DSP]DSP0 Where DSP=REPART
  For AXE=1 To GOPTCANA
#FQ92876-US2768-
# Sauvegarde Axe et section
    WTABDIE(AXE) = [F:DSP]DIE([L]AXE-1)
    WTABCCE(AXE) = evalue(+"[F:DSP]CCE"+num$([L]AXE))
  Next AXE
 #FQ92876-US2768-
 # Sauvegarde Axe et section
  Gosub ANA_SAV_SECTION
  POIDS = ar2(POITOT*(SOMPOI+[F:DSP]COE)/SOMCOE)-ar2(POITOT*SOMPOI/SOMCOE)
  SOMPOI += [F:DSP]COE
  Gosub MAJ_SEC
 Next
Else
 Gosub MAJ_SEC
Endif
Return

$MAJ_SEC_OLD
If POIDS=0 or sum(SECTION(1..GOPTCANA))="" : Return : Endif
CLEGRP = ""
For AXE=1 To GOPTCANA
 CLEGRP += SECTION(AXE)+"/"
Next AXE
S = find(CLEGRP,TBCLE(1..NBSEC))
If !S
 If NBSEC>=MAXSEC : Return : Endif
 NBSEC += 1
 S = NBSEC
 TBCLE(S) = CLEGRP
 For AXE=1 To GOPTCANA
  TBSEC(S,AXE) = SECTION(AXE)
 Next AXE
Endif
TBPOI(S) += POIDS
Return


#FQ92876-US2768-
$MAJ_SEC
If POIDS=0 or sum(SECTION(1..GOPTCANA))="" : Return : Endif
WOK=0
For NBGRP=1 To NBSEC
  WOK=1
  For AXE=1 To GOPTCANA
    If !find(SECTION(AXE),TBSEC(NBGRP,AXE))
     WOK=0
     Break
    Endif
  Next
  If WOK : TBPOI(NBGRP) += POIDS : Endif
Next
If !WOK
  NBSEC+=1
  For AXE=1 To GOPTCANA
     TBSEC(NBSEC,AXE)=SECTION(AXE)
  Next
  NBGRP=NBSEC
  TBPOI(NBGRP) += POIDS
  WOK=1
Endif
Return

$ACTION
If PSPE : Gosub ACTION From SPECALTPS : Endif
Return
#MIPEA - 2017-01-25- X3-11609- END

