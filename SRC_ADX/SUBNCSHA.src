##########################################################################################################
# Issue X3-92124 - 2018-06-22 by JUSYN : return changed NCS-Quantity from NCSH9 screen
$BB3_NBLIG3
# Issue X3-97893 - 2018-09-19 by JUSYN : If no modification on the quantities because of blocking do not activate Save/Cancel
If ([M:NCSH0]NCSSTA > 5) | ((PNCSDOCCHG = "1") & ([M:NCSH0]NCSSTA = 5 & func SUBNCSH.CHECK_PROGRESS_COMPLETION()))
    mkstat = 0
Else
    [M:NCSH1]NCSQTY(nolign-1) = WNCSRECENT.NCSDOCHDR([M:NCSH1]DOCLIN(nolign-1)).NCSQTY
    Affzo [M:NCSH1]NCSQTY(nolign-1)
    mkstat = 4
Endif

# End issue X3-97893
Return
# Issue X3-92124 end
# Issue X3-92174 - 2018-07-06 by JUSYN : fullmode creation NC
##########################################################################################################
$AVANT_CHOI
Local Integer INDEX
Local Integer MY_STATUS
Local Char MESSAGE(250)

If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB

    # set NC Header data
    [M:NCSH0]SITE      = [M:NCSH0]WSITE
    [M:NCSH0]NCSBPC    = [M:NCSH0]WNCSBPC
    [M:NCSH0]NCSBPS    = [M:NCSH0]WNCSBPS
    [M:NCSH0]PRODUCT   = [M:NCSH0]WITMREF
    [M:NCSH0]ECCVALMAJ = [M:NCSH0]WECCMAJ
    [M:NCSH0]ECCVALMIN = [M:NCSH0]WECCMIN

    Case [M:NCSH0]WDOCTYP
        When 1
            [M:NCSH0]NCSCATEGORY = 3 # Default: supplier category
        When 2
            [M:NCSH0]NCSCATEGORY = 2 # Default: Customer category
        When Default
            [M:NCSH0]NCSCATEGORY = 4 # Default: Internal
    Endcase

    If [M:NCSH0]WVCRLIN > 0
        [M:NCSH0]TITLE = mess([M:NCSH0]WDOCTYP,3718,1) - [M:NCSH0]WVCRNUM - num$([M:NCSH0]WVCRLIN)
    Else
        [M:NCSH0]TITLE = mess([M:NCSH0]WDOCTYP,3718,1) - [M:NCSH0]WVCRNUM
    Endif

    # Get default QA manager
    Call PARAM([M:NCSH0]SITE, "NCSQADEF", [M:NCSH2]NCSMANAGER) From ADOVAL
    # Get default Planner
    Call PARAM([M:NCSH0]SITE, "NCSPLADEF", [M:NCSH2]NCSPLANNER) From ADOVAL

    [M:NCSH0]CREUSR = GUSER

    SetInstance WNCSRECENT With [M:NCSH0]
    SetInstance WNCSRECENT With [M:NCSH1]
    SetInstance WNCSRECENT With [M:NCSH2] # X3-110459

    # X3-83486 - set customer details on Customers grid line
    If ([M:NCSH0]NCSBPC <> "")
      INDEX = fmet WNCSRECENT.ADDLINE("NCSBPCCOL", [V]CST_ALASTPOS)
      If INDEX <> [V]CST_ANOTDEFINED Then
         nolign=1
         WNCSRECENT.NCSBPCCOL(INDEX).BPCNUM = [M:NCSH0]NCSBPC
         Call SHOW_ORIGIN_CUSTOMER(INDEX, 1)
      Else
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
          GERR = 4
          GOK = 1
          Return
      Endif

      SetInstance WNCSRECENT.NCSBPCCOL(INDEX) With [M:NCSH3]10
      [M:NCSH3]NBLIG6 = nolign
      Affzo [M:NCSH3]10

    Elsif ([M:NCSH0]NCSBPS <> "") # if supplier, then write to supplier grid
      INDEX = fmet WNCSRECENT.ADDLINE("NCSBPSCOL", [V]CST_ALASTPOS)
      If INDEX <> [V]CST_ANOTDEFINED Then
         nolign=1
         WNCSRECENT.NCSBPSCOL(INDEX).BPSNUM = [M:NCSH0]NCSBPS
         Call SHOW_ORIGIN_SUPPLIER(INDEX,1)
      Else
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
          GERR = 4
          GOK = 1
          Return
      Endif

      SetInstance WNCSRECENT.NCSBPSCOL(INDEX) With [M:NCSH3]5
      [M:NCSH3]NBLIG5 = nolign
      Affzo [M:NCSH3]5

    Endif
    # X3-83486 - end

    # Document, document lines
    # Add document header
    INDEX = fmet WNCSRECENT.ADDLINE("NCSDOCHDR", [V]CST_ALASTPOS)
    If INDEX <> [V]CST_ANOTDEFINED Then
        nolign = 1
        Call SHOW_DOCUMENTS(INDEX)
    Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WNCSRECENT)
        GERR = 4
        GOK = 1
        Return
    Endif

    # Fill document header line / document link

    # [M:NCSH1]NCSID(nolign-1) =  not available yet
    [M:NCSH1]DOCTYP(nolign-1) = [M:NCSH0]WDOCTYP
    [M:NCSH1]VCRNUM(nolign-1) = [M:NCSH0]WVCRNUM
    [M:NCSH1]VCRLIN(nolign-1) = [M:NCSH0]WVCRLIN
    [M:NCSH1]DOCDAT(nolign-1) = [M:NCSH0]WDOCDAT
    [M:NCSH1]DOCQTY(nolign-1) = [M:NCSH0]WQTY
    [M:NCSH1]NCSQTY(nolign-1) = [M:NCSH0]WQTY
    [M:NCSH1]STU(nolign-1) = [M:NCSH0]WSTU   # Issue X3-104585 - stock unit
    [M:NCSH1]BPCNUM(nolign-1) = [M:NCSH0]NCSBPC
    [M:NCSH1]BPSNUM(nolign-1) = [M:NCSH0]NCSBPS
    [M:NCSH1]PJT(nolign-1)    = [M:NCSH0]WPJT
    [M:NCSH1]LINSTA(nolign-1) = 1
  # Issue X3-100238 - 2018-08-15 by JUSYN : Existing NCS record without product allows to link header and detail lines.
  #                                         If detail lines linked product information saved in document line. So here as well to be consistent.
    [M:NCSH1]ITMREF(nolign-1)    = [M:NCSH0]WITMREF
    [M:NCSH1]ECCVALMAJ(nolign-1) = [M:NCSH0]WECCMAJ
    [M:NCSH1]ECCVALMIN(nolign-1) = [M:NCSH0]WECCMIN
  # End issue X3-100238

    SetInstance WNCSRECENT.NCSDOCHDR(INDEX) With [M:NCSH1]10

    [M:NCSH1]NBLIG3 = nolign

    # Add document lines
    If [M:NCSH0]WVCRLIN > 0 and [M:NCSH0]WQTY > 0
        MY_STATUS = fmet WNCSRECENT.CREATE_DOCUMENT_LINES(INDEX, MESSAGE)
        If (MY_STATUS = CST_AFALSE)
            GMESSAGE = MESSAGE
            If GOK=0 : Return : Endif
        Endif
    Endif

    # full mode creation: as there is a document link header fields are not allowed to be changed
    Grizo [M:NCSH0]SITE
    Grizo [M:NCSH0]NCSCATEGORY
    Grizo [M:NCSH0]NCSBPC
    Grizo [M:NCSH0]NCSBPS
    Grizo [M:NCSH0]PRODUCT
    If dim([M:NCSH0]ECCVALMAJ) > 0
      Grizo [M:NCSH0]ECCVALMAJ
      Grizo [M:NCSH0]ECCVALMIN
    Endif

    Affzo [M:NCSH0]1-99
    Affzo [M:NCSH1]1-99
    Affzo [M:NCSH2]1-99 # X3-110459
    #
    GBCRMFLGNEW=0
    WFULLMODE_NAVIGATION = 1   # Issue X3-71307 - 2018-07-11 by JUSYN : fullmode creation with navigation
Endif
Return
##########################################################################################################
# Issue X3-92174 end

# Issue X3-104609 - 2018-09-06 by JUSYN : set criteria WO (for selection lists in document grid)
Subprog SET_CRITERIA_WO

[M:NCSH0]CMFGNUM = ""
If [M:NCSH1]DOCTYP(0) = 3 & [M:NCSH1]VCRNUM(0) <> ""  # Production tracking
    Local File MFGHEADTRK [MTK]
    Read [F:MTK]MTK0=[M:NCSH1]VCRNUM(0)
    If !fstat
        [M:NCSH0]CMFGNUM = [F:MTK]MFGNUM
    Endif
    LogicClose File [MTK]
    Affzo [M:NCSH0]CMFGNUM
Endif

End
# End issue X3-104609
##########################################################################################################

