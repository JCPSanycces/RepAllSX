#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
# Traitement lié à la fenêtre de complément demandes de livraison       #
#########################################################################
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
Endcase

Return

#########################################################################
# Actions sur la fenêtre de saisie                                      #
#########################################################################
$OUVRE_BOITE
Local Integer NOL
#   --> Ctrl autorisation bouton fenetre complement (on teste l'autorisation de modification)
GBIDC2="M": GFCY=[M:SOQ1]SALFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GZNUM=0:GERR = 1:GMESSAGE = mess(2,104,1): FIN=1: Return : Endif
Return
#########################################################################
$DEBUT
Local Integer NOL
# Action SAIDLIV / Fenêtre ICOMPDLIV
If GACTION = "SAIDLIV"
   NOL = nolign-1
   If [F:SOC]SOHNUM<>[M:SOQ1]SOHNUM | [F:SOC]SOPLIN<>[M:SOQ1]SOPLIN
       Read [F:SOC]SOC0 = [M:SOQ1]SOHNUM;[M:SOQ1]SOPLIN
       If fstat FIN=1 : Return Endif
   Endif
   [M] = [M:SOQ1]
   [M] = [F:SOC]    : # Récup DLVQTYCUM 
   [M]YSTOFCY    = [M:SOQ1]DSTOFCY(NOL)
   [M]YUSEPLC    = [M:SOQ1]DUSEPLC(NOL)
   [M]YSTOMGTCOD = [M:SOQ1]DSTOMGTCOD(NOL)
   [M]YBPTNUM    = [M:SOQ1]BPTNUM(NOL)
   [M]YMDL       = [M:SOQ1]MDL(NOL) 
   [M]YDAYLTI    = [M:SOQ1]DAYLTI(NOL)
   [M]YDLVPIO    = [M:SOQ1]DLVPIO(NOL)
   [M]YPCK       = [M:SOQ1]PCK(NOL)
   [M]YPCKCAP    = [M:SOQ1]PCKCAP(NOL)
Endif
Affzo [M:CPDL]1-99
If [M:SOQ1]WTLVQTY(NOL)<>0 | [M:SOQ1]ALLQTY(NOL)<>0 | [M:SOQ1]SHTQTY(NOL)<>0 | [M:SOQ1]LPRQTY(NOL)<>0 
    Diszo [M:CPDL]YSTOFCY
Endif
Return

$OK
# Action SAIDLIV / Fenêtre ICOMPDLIV
If GACTION = "SAIDLIV"
   # Recalcul date expédition si délai modifié et cadencement jour
   If [M:SOQ1]CAD(NOL) = 1 & [M]YDAYLTI <> [M:SOQ1]DAYLTI(NOL)
#      [M:SOQ1]SHIDAT(NOL) = [M:SOQ1]DEMDLVDAT(NOL) - [M]YDAYLTI
#      Call CTL_JOU([M:SOQ1]SHIDAT(NOL),[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
      Call CALC_SHIDAT([M:SOQ1]DEMDLVDAT(NOL),[M]YDAYLTI,[M]YSTOFCY,1,1,[0/0/0],[M:SOQ1]SHIDAT(NOL)) From TRTVENDAT
      Affzo [M:SOQ1]SHIDAT(NOL)
   Endif
   # Si modification du site d'expédition rechargement STOMGTCOD
   If [M]YSTOFCY<>[M:SOQ1]DSTOFCY(NOL)
       If clalev([F:ITM])= 0 Local File ITMMASTER [ITM] : Endif
       If [F:ITM]ITMREF <> [M:SOQ1]ITMREF
           Read [ITM]ITM0=[M:SOQ1]ITMREF
           If fstat Raz [F:ITM] Endif
       Endif
       [M:SOQ1]DSTOMGTCOD(NOL) = [F:ITM]STOMGTCOD
       If [F:ITM]STOMGTCOD>1
           If clalev([F:ITF])= 0 Local File ITMFACILIT [ITF] : Endif
           If [F:ITF]ITMREF <> [M:SOQ1]ITMREF | [F:ITF]STOFCY <> [M]YSTOFCY
               Read [ITF] ITF0=[M:SOQ1]ITMREF;[M]YSTOFCY
               If fstat Raz [F:ITF] : Endif
           Endif
           [M:SOQ1]DSTOMGTCOD(NOL) = [F:ITF]STOMGTCOD
       Endif
   Endif
   [M:SOQ1]UPDFLG(NOL) = 1
   [M:SOQ1]DSTOFCY(NOL)= [M]YSTOFCY
   [M:SOQ1]DUSEPLC(NOL)= [M]YUSEPLC
   [M:SOQ1]BPTNUM(NOL) = [M]YBPTNUM
   [M:SOQ1]MDL(NOL)    = [M]YMDL
   [M:SOQ1]DAYLTI(NOL) = [M]YDAYLTI
   [M:SOQ1]DLVPIO(NOL) = [M]YDLVPIO
   [M:SOQ1]PCK(NOL)    = [M]YPCK
   [M:SOQ1]PCKCAP(NOL) = [M]YPCKCAP
   mkstat = 4  
   FIN=1
Endif
Return
 
######################################################################################
## Etiquette ajoutée par le superviseur (écran COMPDLIV) 21/12/2010 15:51:23 (CPO)
######################################################################################
#CPO 63410 - pb découvert lors de la correction de cette fiche
# -- suite à la modification du code emballage, il faut réalimenter la val de la capacité
# -- tout en tenant compte de l'UV de la ligne
Subprog AM_YPCK(VALEUR)
Variable Char    VALEUR()
# Action SAIDLIV / Fenêtre ICOMPDLIV
If GACTION = "SAIDLIV"
  If VALEUR=""
    Raz [M]YPCKCAP
  Else
    Call AMPCK([M:SOQ1]ITMREF,[M]YSTOFCY,[M]SAU,VALEUR,[M]YPCKCAP) From TRTVENDIV
  Endif 
  Affzo [M]YPCKCAP
Endif

End
######################################################################################

