# Saisie des statuts autorisÃĐs pour les catÃĐgories articles version 140   TB  Juin 2002 - TRTCATEG -
# Action SAIITGISTA
#
# SÃĐlection des sous-statuts d'aprÃĻs les autorisations :
# Action SELSSTA
# ------------------------------------------------------------------------ #
# Sous-programme de dÃĐcodage d'une liste de statuts pour la transformer en formule avec des %
# Subprog DECODE_STAT(LISTE_STATUTS,FORMULE)
# -------------------------------------------------------------------------- #
# Sous-programme de remplacement des % dans la formule par la bonne variable
# Subprog CREE_FORMULE(FORM_ORIG,VARIAB,FORM_DEST)
# ------------------------------------------------------------- #
# Sous-programme qui transforme la chaÃŪne de statuts en tableau
# Subprog DECOUPE_STAT(LISTE_STATUTS,T_STA,NB)
# ------------------------------------------------------------- #
# Sous-programme qui controle le sous-statut (saisie Mvt stock)
# La catÃĐgorie [ITG] doit ÃŠtre en ligne  # type et code mouvement
# Subprog CTR_STA(SST,TYP,COD)
# --------------------------------------------------------------- #
# Sous-programme qui contrÃīle la chaÃŪne de sous-statuts
# et rajoute ÃĐventuellement les modÃĻles (M:ISTA doit ÃŠtre ouvert)
# Subprog CTR_LIST_SST(SST,AUZSTA)
# ----------------------------------------------------------------------#
# Moulinette (Tronc commun) des tables ITM et ITF pour le passage en 140
# Subprog UTITC  (Pas en AVANCE DE PHASE car incompatibilitÃĐs !)
# --------------------------------------------------------------------- #
# Moulinette de chargement de la table ITMCATEG en avance de phase 140
# Subprog UTICATEG
#########################################################################
#CHECK UNUSED_BEGIN
# Lancement de la moulinete sur ITMFACILIT / TABITMCLS ...
Call TEMPON("F") From GESECRAN
#Call OUVRE_TRACE("Moulinette sur Article site") From LECFIC
Call OUVRE_TRACE("Moulinette sur catÃĐgories") From LECFIC
Call UTICATEG
# oter les rÃĻgles sur les types qui ne sont plus selectionnalble
#Local File TABSTORUL [SRU]
#Trbegin [SRU]
#Delete [SRU] Where find(TRSTYP,7,9,10,13,14,15,16,21,22)
#Call ECR_TRACE(num$(adxdlrec)-"effacÃĐs",0) From GESECRAN
#Commit
Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN
Call LEC_TRACE From LECFIC
End
#CHECK UNUSED_END

################################################################################

$ACTION
Case ACTION
 When "OUVRE"       Gosub OUVRE
 When "DEBUT"       Gosub DEBUT
 When "OK"          Gosub OK
 When "FIN"         Raz [M:ISTA] : Kill GLIG

 When "SEL_TABLE"   Gosub SEL_TABLE
 When default
Endcase
Return

$OUVRE
If !clalev([F:TST]) Local File TABSTASTO [TST] Endif
Return

$DEBUT
Local  Integer I
Global Integer GLIG # pour exploiter la valeur 'Stat autorisÃĐs' de ITG4
GLIG = val(PARAM(1))-1 # le paramÃĻtre passÃĐ est nolign du tableau d'ITG4
# Eclater la zone paramÃĻtre en autant de sous-statuts
# VALEUR contient la chaine des sous-statuts sÃĐparÃĐs par des virgules
Raz [M:ISTA]
Call DECOUPE_STAT(VALEUR,[M:ISTA]STA,[M:ISTA]NBSTA)
# si tableau plein
If [M:ISTA]NBSTA > dim([M:ISTA]STA)
  [M:ISTA]NBSTA = dim([M:ISTA]STA)
Endif
For I = 0 To [M:ISTA]NBSTA-1
  Read [TST]TST0=[M:ISTA]STA(I)
  If fstat = 0
    # FGR 15/01/2010 : X3SUIVI60986
    #Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,[M:ISTA]STAAXX(I)) From TXTX3TEX
    Call GET_ATEXTRA("TABSTASTO","STAAXX",GLANGUE,[M:ISTA]STAAXX(I)) From TRTX3TEX
  Else
    [M:ISTA]STAAXX(I) = ""
  Endif
Next I
Affzo [M:ISTA]

#[M:ISTA]NBSTA = find("",[M:ISTA]STA) - 1
#Affzo [M:ISTA]NBSTA,STA
Return

$OK

# ÃĐlimine les statuts qui ne satisfont pas AUZSTA
If PARAM(2)=""
   Gosub TRI_STATUTS From SUBISTA
Endif
# ConcatÃĐner les statuts pour les retourner dans la zone
Raz VALEUR
For nolign = 1 To [M:ISTA]NBSTA
  VALEUR += [M:ISTA]STA(nolign-1)
  If nolign < [M:ISTA]NBSTA
    VALEUR += ","
  Endif
Next

Return

$SEL_TABLE
# sÃĐlection des statuts selon les autorisations
# PARAM(1) contient la zone alpha statuts autorisÃĐs
#          soit [F:SRU]AUZSST depuis les stocks, soit [M]AUZSST(nolign-1)

Local Char FORMULE(80)

If !clalev([F:TST]) Local File TABSTASTO [TST] Endif
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif
LLIS = PARAM(1)
Call DECODE_STAT(LLIS,FORMULE)
Call CREE_FORMULE(FORMULE,"STASTO",CRITERE)

TIT(0) = "SÃĐlection statuts"

NBCOL = 2
COL(1) = "STASTO"
Call TEXTFIC("TST",COL(1),2,TIT(1)) From OBJDIV
COL(2) = "[F:AXX]TEXTE"
Call TEXTE(8,TIT(2)) From OBJDIV
START = "STASTO"
Link [TST] With [AXX]AXX0="TABSTASTO";"STAAXX";[F:TST]STASTO;""
&          As [LNK]
Default File [LNK]
Return

# Sous-programme de dÃĐcodage d'une liste de statuts pour la transformer en formule avec des %
# ----------------------------------------------------------------------------------------- #
# (par exemple A1*,Q2*,R3*,A4*,A55)
# la longueur de la formule obtenue n'excÃĻde pas 80 caractÃĻres
#
Subprog DECODE_STAT(LISTE_STATUTS,FORMULE)
Value Char LISTE_STATUTS
Variable Char FORMULE
Local Integer J
Local Char CHA(200),CHB(200),CHC(200)

LISTE_STATUTS=vireblc(LISTE_STATUTS,4) : # PrÃĐcaution prÃĐliminaire
If LISTE_STATUTS="*"
    FORMULE="1=1" : End
Endif

J=instr(1,LISTE_STATUTS+',',',')
Repeat
  CHC=left$(LISTE_STATUTS,J-1)
  If instr(1,CHC,"*") or instr(1,CHC,"?") or instr(1,CHC,"!") or instr(1,CHC,"#")
     CHA+=string$(CHA<>"","|")+'pat(%,"'+CHC+'")'+'<>0'
  Else
     CHB+=string$(CHB="","find(%")+',"'+CHC+'"'
  Endif
  LISTE_STATUTS=right$(LISTE_STATUTS,J+1)
  J=instr(1,LISTE_STATUTS+',',',')
Until LISTE_STATUTS=""

FORMULE=CHA+string$(CHA<>"" & CHB<>"","|")+CHB+string$(CHB<>"",")<>0")

End

#
# Sous-programme de remplacement des % dans la formule par la bonne variable
# ------------------------------------------------------------------------ #
Subprog CREE_FORMULE(FORM_ORIG,VARIAB,FORM_DEST)
Value Char FORM_ORIG()
Value Char VARIAB()
Variable Char FORM_DEST()
Local Integer J
J=instr(1,FORM_ORIG,'%')
While J<>0
    FORM_DEST+=left$(FORM_ORIG,J-1)+VARIAB
    FORM_ORIG=right$(FORM_ORIG,J+1)
    J=instr(1,FORM_ORIG,'%')
Wend
FORM_DEST+=FORM_ORIG
End

# Sous-programme qui transforme la chaÃŪne de statuts en tableau
# ------------------------------------------------------------- #
Subprog DECOUPE_STAT(LISTE_STATUTS,T_STA,NB)
Value    Char     LISTE_STATUTS
Variable Char     T_STA()()
Variable Shortint NB
Local Integer J,L

LISTE_STATUTS=vireblc(LISTE_STATUTS,4) : # PrÃĐcaution prÃĐliminaire

J=instr(1,LISTE_STATUTS+',',',')
Repeat

    T_STA(L) = left$(LISTE_STATUTS,J-1)
    L += 1
    LISTE_STATUTS=right$(LISTE_STATUTS,J+1) # enlÃĻve le statut et la virgule
    J=instr(1,LISTE_STATUTS+',',',')
Until LISTE_STATUTS=""
NB = L
End

# Sous-programme qui controle le sous-statut (saisie Mvt stock)
# ------------------------------------------------------------- #
# La rÃĻgle de gestion doit ÃŠtre en ligne [F:SRU]
Subprog CTR_STA(SST,TYP,COD)
Value Char    SST()
Value Char    TYP()
Value Char    COD()
Local Char TAB_STAT(3)(20)
Local Integer I, OK
Local Shortint NB

# contrÃīler le statut par dÃĐfaut selon les sous-statuts autorisÃĐs
Call DECOUPE_STAT([F:SRU]AUZSST,TAB_STAT,NB)

For I=0 To dim(TAB_STAT)-1
  If instr(1,TAB_STAT(I),"*") or instr(1,TAB_STAT(I),"?")
& or instr(1,TAB_STAT(I),"#") or instr(1,TAB_STAT(I),"!")
    If pat(SST,TAB_STAT(I))
      OK = 1
      Break
    Endif
  Else
    If SST = TAB_STAT(I)
      OK = 1
      Break
    Endif
  Endif
Next

If OK = 0
  mkstat=2
  GMESSAGE = mess(4,196,1) #"Statut non autorisÃĐ"
Endif


If SST <> "" & [F:SRU]QLYCTLFLG = 2 & left$(SST,1) <>  "Q"
   mkstat = 2
   GMESSAGE = mess(391,199,1) # le statut doit commencer par Q car il y a une demande d analyse
Endif

$FIN_CTR_STA
End

# Sous-programme qui contrÃīle la chaÃŪne de sous-statuts
# et rajoute ÃĐventuellement les modÃĻles (M:ISTA doit ÃŠtre ouvert)
# --------------------------------------------------------------- #
Subprog CTR_LIST_SST(SST,WAUZSTA)
Variable Char    SST
Value    Integer WAUZSTA

Local Integer I, J, A, Q, R, AD, QD, RD
# Ã  la crÃĐation, charger les modÃĻles de sous-statuts correspondant
If SST = ""
 If find(WAUZSTA,1,3,5,7)
   SST += "A*"
 Endif
 If find(WAUZSTA,2,3,6,7)
   If SST <> ""
     SST += ","
   Endif
   SST += "Q*"
 Endif
 If find(WAUZSTA,4,5,6,7)
   If SST <> ""
     SST += ","
   Endif
   SST += "R*"
 Endif
Else
  # Ã  la modif, rajouter s'il n'y a pas de dÃĐtail
  Raz [M:ISTA]
  Call DECOUPE_STAT(SST,[M:ISTA]STA,[M:ISTA]NBSTA) From TRTCATEG
  # quels statuts autorise-t-on :
  If find(WAUZSTA,1,3,5,7)
    A = 1
  Endif
  If find(WAUZSTA,2,3,6,7)
    Q = 1
  Endif
  If find(WAUZSTA,4,5,6,7)
    R = 1
  Endif
  Raz I
  Raz mkstat
  While I <> [M:ISTA]NBSTA
   If left$([M:ISTA]STA(I),1) = "A"
    # > signifier qu'il y a dÃĐjÃ  du A dÃĐfini
    AD = 1
    If A = 0
     # prÃĐvenir de l'incohÃĐrence
      mkstat = 2
      GMESSAGE = mess(363,199,1) #"Saisie incohÃĐrente avec les statuts autorisÃĐs"
      Break
     Endif
   Elsif left$([M:ISTA]STA(I),1) = "Q"
    QD = 1
    If Q = 0
      mkstat = 2
      GMESSAGE = mess(363,199,1)
      Break
    Endif

   Elsif left$([M:ISTA]STA(I),1) = "R"
    RD = 1
    If R = 0
      mkstat = 2
      GMESSAGE = mess(363,199,1)
      Break
    Endif
   Else
     # interdire les jokers ou autre chose en premiÃĻre position
     # "Le statut doit commencer par A,Q,R"
     mkstat = 2
     GMESSAGE = mess(21,199,1)
     Break
   Endif
   I += 1
  Wend
  If mkstat = 2   # hcb 42725
     End          # hcb 42725
  Endif           # hcb 42725




  # si la nouvelle valeur autorise le A et qu'il n'y a pas de A..
  If A=1 & AD=0
    [M:ISTA]STA([M:ISTA]NBSTA) = "A*"
    [M:ISTA]NBSTA += 1
  Endif
  If Q=1 & QD=0
    [M:ISTA]STA([M:ISTA]NBSTA) = "Q*"
    [M:ISTA]NBSTA += 1
  Endif
  If R=1 & RD=0
    [M:ISTA]STA([M:ISTA]NBSTA) = "R*"
    [M:ISTA]NBSTA += 1
  Endif
  # remise sous forme de chaÃŪne
  Raz SST
  For I = 1 To [M:ISTA]NBSTA
    #-- ContrÃīle du sous-statuts, si sous-statut non gÃĐnÃĐrique
    #--- Bug 83419
    #If !find([M:ISTA]STA(I-1),"A*","Q*","R*")
    If !find(left$([M:ISTA]STA(I-1),1),"A","Q","R") | right$([M:ISTA]STA(I-1),len([M:ISTA]STA(I-1)))<>"*"
    #---
      Call CONTROLE("TST","!",[M:ISTA]STA(I-1),"",mkstat) From CONTOBJ
      If mkstat : Break : Endif
    Endif
    SST += [M:ISTA]STA(I-1)
    If I < [M:ISTA]NBSTA
      SST += ","
    Endif
  Next
Endif
End


###########################################################################
# UTICATEG Moulinette livrÃĐe avant la version 140        (TB - 18/07/02)  #
# reprise des catÃĐgories 130 (TCL) pour crÃĐer les catÃĐgories article v 140#
###########################################################################
#CHECK UNUSED_BEGIN
Subprog UTICATEG

Local Integer I
Local Char    ERR_TRA(120)

If filinfo(filpath("FIL","TABITMCLS","fde",""),0)  < 0
  Call ECR_TRACE("This process needs old table TABITMCLS",1) From GESECRAN
  Goto FIN_UTICATEG
Endif

#If clalev([ITG]) = 0 Local File =[F:ADS]DOSSIER+".ITMCATEG" [ITG] Endif  # pour DOSMAJ6
If clalev([ITG]) = 0 Local File ITMCATEG [ITG] Endif
#If clalev([TCL]) = 0 Local File =[F:ADS]DOSSIER+".TABITMCLS" [TCL] Endif  # pour DOSMAJ6
If clalev([TCL]) = 0 Local File TABITMCLS [TCL] Endif
#If clalev([SRU]) = 0 Local File =[F:ADS]DOSSIER+".TABSTORUL" [SRU] Endif  # pour DOSMAJ6
If clalev([SRU]) = 0 Local File TABSTORUL [SRU] Endif

Local Mask ITG4 [ITG4] # pour charger les rÃĻgles SRU en tableau

# vÃĐrifier que les SRU (paramÃĐtrage) ont ÃĐtÃĐ crÃĐÃĐs
If nbrecord([SRU]) = 0
  Call ECR_TRACE("This process needs Default stock rules (Setting menu)",1) From GESECRAN
  Goto FIN_UTICATEG
Endif

ERR_TRA = "Item Category processing for new table ITMCATEG"
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

Call DEBTRANS From GLOCK
Trbegin [ITG]

For [TCL]
    Look [F:ITG]ITG1 = [F:TCL]TCLCOD;""
    If fstat
      Raz [F:ITG]
      [F:ITG] = [F:TCL]
      # reprise d'un ÃĐventuel article modÃĻle...(dans ce cas initialiser DACPCU...) OU
      # initialisation des menus locaux
      If [F:ITG]SALFLG=0 [F:ITG]SALFLG=1 Endif # au cas oÃđ
      [F:ITG]QUAFLG = 1
      [F:ITG]DACPUUCOE = 1
      [F:ITG]DACSAUCOE = 1
      [F:ITG]NEGSTO    = 1
      [F:ITG]LOTMGTCOD = 1
      [F:ITG]SERMGTCOD = 1
      [F:ITG]TRKCOD    = 1
      [F:ITG]EXYMGTCOD = 1
      [F:ITG]BRDCOD    = 1
      [F:ITG]RCPFLG    = 1
      [F:ITG]PRQFLG    = 1
      [F:ITG]ABCCLS    = 1

      If [F:ITG]SCPFLG = 2 | [F:ITG]SCSFLG = 2
        [F:ITG]STOMGTCOD = 1 # sous-traitÃĐ et sous-traitance
        [F:ITG]STDFLG    = 1
        [F:ITG]CUNCOD    = 3
        [F:ITG]STOCOD    = 3
      Else
        [F:ITG]STOMGTCOD = 2
        [F:ITG]STDFLG    = 3 # valeurs les plus courantes
        [F:ITG]CUNCOD    = 1
        [F:ITG]STOCOD    = 1
      Endif
      # code rÃĐception forcÃĐment Ã  OUI pour art gÃĐrÃĐ en stock ou Sous-traitance
      If [F:ITG]STOMGTCOD>1 | [F:ITG]SCSFLG =2
        [F:ITG]RCPFLG    = 2
      Endif
      [F:ITG]STDCSTUPD = 1
      [F:ITG]CUTCSTUPD = 1
      [F:ITG]BUDCSTUPD = 1
      [F:ITG]SIMCSTUPD = 1
      [F:ITG]MFGSHTCOD = 1
      [F:ITG]ITMTYP    = 1
      [F:ITG]LNDFLG    = 1
      [F:ITG]CTMFLG    = 1
      [F:ITG]REOCOD    = 1
      [F:ITG]REOMGTCOD = 1
      [F:ITG]FOHUOT    = 1
      [F:ITG]PLHUOT    = 1
      [F:ITG]FRTHORUOM = 1
      [F:ITG]FIMHORUOM = 1
      [F:ITG]UPDDAT    = [0/0/0]
      [F:ITG]UPDUSR    = ""
      [F:ITG]CREDAT = date$
      [F:ITG]CREUSR = GUSER
      [F:ITG]EXPNUM = [C]EXPORT

      # charger les SRU en fonction du type de catÃĐgorie (passer par [M])
      Raz [M:ITG4] # attention contient aussi LOCMGTCOD et GLOxxx
      Raz nolign
      For [SRU] Where TCLCOD="" & STOFCY=""
        # reprendre les types concernÃĐs par le type de catÃĐgorie :
        # traiter en prioritÃĐ le type vendu
        If [F:ITG]SALFLG=2
          If find([F:SRU]TRSTYP,1,2,4,7,10,12,14,15,16,17,18)
            nolign += 1
            [M:ITG4] = [F:SRU]
          Endif
        Endif
        If [F:ITG]PURFLG  = 2
            If find([F:SRU]TRSTYP,1,2,3,7,10,11,14,15,16) & !find([F:SRU]TRSTYP,[M:ITG4]TRSTYP)
              nolign += 1
              [M:ITG4] = [F:SRU]
            Endif
        Endif
        If [F:ITG]MFGFLG  = 2
            If find([F:SRU]TRSTYP,1,2,5,6,7,10,14,15,16,19) & !find([F:SRU]TRSTYP,[M:ITG4]TRSTYP)
              nolign += 1
              [M:ITG4] = [F:SRU]
            Endif
        Endif
        If [F:ITG]PHAFLG  = 2 | [F:ITG]GENFLG  = 2 |[F:ITG]TOOFLG  = 2
            If find([F:SRU]TRSTYP,1,2,7) & !find([F:SRU]TRSTYP,[M:ITG4]TRSTYP)
              nolign += 1
              [M:ITG4] = [F:SRU]
            Endif
        Endif
      Next
      [M:ITG4]NBLOC = nolign

      # charger les intitulÃĐs d'emplacements avec ce qu'on trouve dans les rÃĻgles
      If dim([M:ITG2]LOCMGTCOD) > 0
        nolign = 0
        For I = 1 To [M:ITG4]NBLOC
         If !find([M:ITG4]LOCNUM(I-1),[M:ITG2]LOCDES)
           nolign += 1
           [M:ITG2]LOCDES(nolign-1) = [M:ITG4]LOCNUM(I-1)
         Endif
        Next
        [M:ITG2]NBINT = nolign  # et trier le tableau :
        Sorta [M:ITG2]NBINT [M:ITG2]LOCDES Order By [M:ITG2]LOCDES(indice)
      Endif
      # balancer M dans F ! puis alimenter les menus locaux prÃĐsents dans ITG4
      [F:ITG] = [M:ITG4]
      [F:ITG]GLOAAAFLG = 2 # un statut cochÃĐ au moins
      [F:ITG]GLOQQQFLG = 1
      [F:ITG]GLORRRFLG = 1
      If dim([M:ITG2]LOCMGTCOD) > 0 & [M:ITG2]NBINT > 0
        [F:ITG]LOCMGTCOD = 2
      Endif

      Write [ITG]
      If fstat
       # Trace : erreur d'ÃĐcriture sur le fichier ITMCATEG
        ERR_TRA = "Write error on ITMCATEG :"-[F:TCL]TCLCOD
        Call ECR_TRACE(ERR_TRA,1) From GESECRAN
        GOK=0
        Break
      Endif

      # ÃĐcrire les enregistrements SRU rattachÃĐs Ã  la catÃĐgorie
      # (avec site et code mvt vides)
      For nolign=1 To [M:ITG4]NBLOC
        Raz [F:SRU]
        [F:SRU] = [M:ITG4]
        [F:SRU]TCLCOD = [F:ITG]TCLCOD
        Write [SRU]
        If fstat
         # Trace : erreur d'ÃĐcriture sur le fichier TABSTORUL
          ERR_TRA = "Write error on TABSTORUL :"-[F:SRU]TCLCOD-mess([F:SRU]TRSTYP,704,1)
          Call ECR_TRACE(ERR_TRA,1) From GESECRAN
          GOK=0
          Break 2
        Endif
      Next
    Endif
Next
If GOK = 1
  Commit
Else
  Rollback
Endif

$FIN_UTICATEG
End
#CHECK UNUSED_END
