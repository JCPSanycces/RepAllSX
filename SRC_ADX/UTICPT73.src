#<AdxTL>@(#)3.0.0.0 $Revision$
End
########################################################################################
# UTICPT73   UTI process                                                 FIN module
#            Migration From UP8/UP9 to UP10
#
# When migrating to U10, GESTCA table :
#  - If, for the Financials module, for the document type 4 (No VAT declaration query/deb),
#  sequence number values are identical in Society/Leg and folder, nothing is to be done
#  - If, for the the Financials module, for the document type 4 (No VAT declaration query/deb),
#  sequence number values are different in Company and/or legislation and/or folder, we take
#  the highest sequence value between sequence number values and affect it (+ 1) to the folder level.
########################################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update Sequence Number for VAT declaration query/deb") From LECFIC
  Call MAJ_UTICPT73(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File

End
##########################################################################
Subprog MAJ_UTICPT73(DOSSIER)
Value Char DOSSIER

Local Integer ERR
Local Integer WMAXVAL
Local Char    COMPTEUR(GLONANM)   : # Sequence number that assigns the request number

Call ECR_TRACE("UTICPT73 : Start of process on : "+DOSSIER,0) From GESECRAN

If clalev([F:WTCA])=0  : Local File =DOSSIER+".TABCOUAFF" [WTCA]  : Endif  : # Sequence number assignment
If clalev([F:WAVN])=0  : Local File =DOSSIER+".AVALNUM"   [WAVN]  : Endif  : # Sequence number value


 Read [WTCA]TCA0=2;"";""
 If !fstat
   COMPTEUR= [F:WTCA]CODNUM(3)
 Endif
 If COMPTEUR=""
   COMPTEUR = "DLV"
 Endif

# Search Sequence Number in the table of allocations for the Financial Module
Call DEBTRANS From GLOCK
Trbegin [WAVN]
  WMAXVAL=0
  For [WTCA] Where MODULE=2  #--  Financial module
    # Search, in the table of Sequence number values, for the highest value for the type of document
    For [WAVN] Where CODNUM=[F:WTCA]CODNUM(3)
      If WMAXVAL = 0 or [F:WAVN]VALEUR > WMAXVAL
        WMAXVAL = [F:WAVN]VALEUR
      Endif
    Next
  Next

  Gosub UPDATE_AVN_DOSSIER

  If GOK<1
    Rollback
  Else
    Commit
  Endif

  Close Local File [WTCA]
  Close Local File [WAVN]

Call ECR_TRACE("UTICPT73 : End of process on : "+DOSSIER,0) From GESECRAN

End
#===================
$UPDATE_AVN_DOSSIER

 # Assigning the highest value at the folder level
 # Readlock[WAVN]AVN0=[F:WTCA]CODNUM(3);"";0;""
 Readlock[WAVN]AVN0=COMPTEUR;"";0;""
 If [F:WAVN]VALEUR < WMAXVAL
   [F:WAVN]VALEUR  = WMAXVAL
   If dim([F:WAVN]UPDTIM)>0
     [F:WAVN]UPDTIM    = time
   Elsif dim([F:WAVN]UPDDATTIM)>0
     [F:WAVN]UPDDATTIM = time
   Endif
   Rewrite [WAVN]
   If fstat
     Call ECR_TRACE("UTICPT73 : File AVALNUM, ERROR while update ="-num$(fstat),1) From GESECRAN
     GOK=0
   Else
     Call ECR_TRACE("UTICPT73: Sequence number "+num$(COMPTEUR)+"  processed",0) From GESECRAN
   Endif
 Endif

 Return
########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT73 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

# Check Financials module
If [F:ADS]MODULE(1)<>2 : End : Endif
Call MAJ_UTICPT73(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
# Check Financials module
If [F:ADS]MODULE(1)<>2 : End : Endif
Call MAJ_UTICPT73(APPLI)
End

