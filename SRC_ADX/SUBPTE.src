#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet PTE
#######################################################################
# SUBPTE : Transactions de saisie des ordres de sous-traitance        #
# GA 08/2006 selon SUBPTC,SUBPTR,SUBMFL,...                           #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:PTR]PURTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 1 fenêtre de saisie à partir des écrans de base SCO0  #
#                                                               SCO1  #
#                                                               SCO2  #
#                                                               SCO3  #
#                                                                     #
# Nom des écrans générés : WExyyyyyz                                  #
#                            x = type de transaction                  #
#                                1 pour appels d'offre                #
#                                2 pour demandes d'achat              #
#                                3 pour commandes std et par article  #
#                                5 pour commandes ouvertes            #
#                                6 pour réceptions                    #
#                                8 pour factures / avoirs             #
#                                9 pour ordre de sous-traitance v150  #
#                                                                     #
#                        yyyyy = nom de la transaction (PTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0 et 1 pour appels d'offre           #
#                                1 pour demandes d'achat              #
#                                1 ,2 et 3 pour commandes standards   #
#                                9 pour commandes par article         #
#                                0, 1 et 2 pour commandes ouvertes    #
#                                0, 1, 2 et 3 pour réceptions         #
#                                0, 1, 2, 3 et 4 pour factures/avoirs #
#                                0, 1, 2, 3 pour ordre de ss-traitance#
#######################################################################

Call OBJET("PTE",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="PTR"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=9
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:PTE0]PTRTYP=9
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="PURTRS" & IDENT1=num$([F:PTR]PTRTYP) & IDENT2=[F:PTR]PTRNUM
                      Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="PTR"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=9
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "FERME"       : Call IMPSCR      From ATRTX3
Endcase
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto
Local Char APPLI(30): APPLI=nomap
Local Char WMODU(2) : WMODU="E"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG
Return

#--------------------------------------------------------------#
# Ne traiter que les transactions de type 9=ordre ss-traitance #
#--------------------------------------------------------------#
$FILTRE
FILTSUP="PTRTYP=9"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
#----- Suppression de l'option "Changement de clé" -----#
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
#-----
#** Onglet Paramètres
If [M:PTE1]TRSAUTO = 1
   Gosub DISZO_TRSAUTO
Else
   Gosub ACTZO_TRSAUTO
Endif

# Issue 79579 - 2012-01-27 by MUARN : PEC sur transaction de saisie
If [M:PTE1]PICRETFLG=0 : [M:PTE1]PICRETFLG=2 : Endif

#** Onglet <Saisie>
If [M:PTE3]RCPFCYCOD=0 : [M:PTE3]RCPFCYCOD=2 : Endif : # Affiché
If [M:PTE3]RCPADDCOD=0 : [M:PTE3]RCPADDCOD=2 : Endif : # Affiché
If [M:PTE3]MFGFCYCOD=0 : [M:PTE3]MFGFCYCOD=2 : Endif : # Affiché
If [M:PTE3]INVFCYCOD=0 : [M:PTE3]INVFCYCOD=2 : Endif : # Affiché
If [M:PTE3]SCOADDCOD=0 : [M:PTE3]SCOADDCOD=1 : Endif : # Saisi

If [M:PTE3]PJTCOD   =0 : [M:PTE3]PJTCOD   =1 : Endif : # Saisi
If [M:PTE3]PIOCOD   =0 : [M:PTE3]PIOCOD   =1 : Endif : # Saisi

If [M:PTE3]LOTCOD   =0 : [M:PTE3]LOTCOD   =2 : Endif : # Affiché
If [M:PTE3]LOTSCR   =0 : [M:PTE3]LOTSCR   =2 : Endif : # Fiche
If [M:PTE3]LOCCOD   =0 : [M:PTE3]LOCCOD   =2 : Endif : # Affiché
If [M:PTE3]LOCSCR   =0 : [M:PTE3]LOCSCR   =2 : Endif : # Fiche
If [M:PTE3]STOFCYCOD=0 : [M:PTE3]STOFCYCOD=2 : Endif : # Affiché
If [M:PTE3]STOFCYSCR=0 : [M:PTE3]STOFCYSCR=3 : Endif : # Tableau
# Issue 107513/US2 GA 04/2015 : ECC Hidden fields by default
If dim([M:PTE3]ECCCOD)>0
    If [M:PTE3]ECCCOD=0
       [M:PTE3]ECCCOD=3 : [M:PTE3]ECCSCR=2
    Endif
    If [M:PTE3]ECCCOD=3  Grizo [M:PTE3]ECCSCR  Else Actzo [M:PTE3]ECCSCR  : Endif
Endif
If dim([M:PTE3]ECCCODMIN)>0
    If [M:PTE3]ECCCODMIN=0
       [M:PTE3]ECCCODMIN=3: [M:PTE3]ECCSCRMIN=2
    Endif
    If [M:PTE3]ECCCODMIN=3  Grizo [M:PTE3]ECCSCRMIN  Else Actzo [M:PTE3]ECCSCRMIN  : Endif
Endif
# End issue 107513/US2

If clalev([M:DST])
  [M:DST]CCESCR =2 : Grizo [M:DST]CCESCR  : # Mono-article  : tjs saisi en mode Fiche
  [M:DST]CCESCR2=1
  [M:DST]CCESCR3=2 : Grizo [M:DST]CCESCR3 : # Mono-opération: tjs saisi en mode Fiche
#
  Affzo [M:DST]
Endif
# GA 09/2006 [M:CDT] inutilisé: on ne gère plus les comptes sur les EO
If clalev([M:CDT])
  [M:CDT]CCESCR1=2 : Grizo [M:CDT]CCESCR1 : # Mono-article  : tjs saisi en mode Fiche
  [M:CDT]CCESCR2=1
  [M:CDT]CCESCR3=2 : Grizo [M:CDT]CCESCR3 : # Mono-opération: tjs saisi en mode Fiche
#
  [M:CDT]ACCSCR1=2 : Grizo [M:CDT]ACCSCR1 : # Mono-article  : tjs saisi en mode Fiche
  [M:CDT]ACCSCR2=1
  [M:CDT]ACCSCR3=2 : Grizo [M:CDT]ACCSCR3 : # Mono-opération: tjs saisi en mode Fiche
  Affzo [M:CDT]
Endif

# points d'entrée pour ce type de transaction
Gosub PE_PURTRS From SUBPTX
Affzo [M:PTE0]1-99
Affzo [M:PTE1]1-99
Affzo [M:PTE2]1-99
Affzo [M:PTE3]1-99
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
[M:PTE0]PTRTYP=9 : # transaction de saisie Ordre de sous-traitance
[M:PTE0]ENAFLG=2

# Issue 79579 - 2012-01-27 by MUARN : PEC sur transcaction de saisie
[M:PTE1]PICRETFLG=2

#** Onglet <Saisie>
If [M:PTE3]RCPFCYCOD=0 : [M:PTE3]RCPFCYCOD=2 : Endif : # Affiché
If [M:PTE3]RCPADDCOD=0 : [M:PTE3]RCPADDCOD=2 : Endif : # Affiché
If [M:PTE3]MFGFCYCOD=0 : [M:PTE3]MFGFCYCOD=2 : Endif : # Affiché
If [M:PTE3]INVFCYCOD=0 : [M:PTE3]INVFCYCOD=2 : Endif : # Affiché
If [M:PTE3]SCOADDCOD=0 : [M:PTE3]SCOADDCOD=1 : Endif : # Saisi

If [M:PTE3]PJTCOD   =0 : [M:PTE3]PJTCOD   =1 : Endif : # Saisi
If [M:PTE3]PIOCOD   =0 : [M:PTE3]PIOCOD   =1 : Endif : # Saisi

If [M:PTE3]LOTCOD   =0 : [M:PTE3]LOTCOD   =2 : Endif : # Affiché
If [M:PTE3]LOTSCR   =0 : [M:PTE3]LOTSCR   =2 : Endif : # Fiche
If [M:PTE3]LOCCOD   =0 : [M:PTE3]LOCCOD   =2 : Endif : # Affiché
If [M:PTE3]LOCSCR   =0 : [M:PTE3]LOCSCR   =2 : Endif : # Fiche
If [M:PTE3]STOFCYCOD=0 : [M:PTE3]STOFCYCOD=2 : Endif : # Affiché
If [M:PTE3]STOFCYSCR=0 : [M:PTE3]STOFCYSCR=3 : Endif : # Tableau
#
If clalev([M:DST])
  [M:DST]CCESCR =2 : Grizo [M:DST]CCESCR  : # Mono-article  : tjs saisi en mode Fiche
  [M:DST]CCESCR2=1
  [M:DST]CCESCR3=2 : Grizo [M:DST]CCESCR3 : # Mono-opération: tjs saisi en mode Fiche
#
  Affzo [M:DST]
Endif
# GA 09/2006 [M:CDT] inutilisé: on ne gère plus les comptes sur les EO
If clalev([M:CDT])
  [M:CDT]CCESCR1=2 : Grizo [M:CDT]CCESCR1 : # Mono-article  : tjs saisi en mode Fiche
  [M:CDT]CCESCR2=1
  [M:CDT]CCESCR3=2 : Grizo [M:CDT]CCESCR3 : # Mono-opération: tjs saisi en mode Fiche
#
  [M:CDT]ACCSCR1=2 : Grizo [M:CDT]ACCSCR1 : # Mono-article  : tjs saisi en mode Fiche
  [M:CDT]ACCSCR2=1
  [M:CDT]ACCSCR3=2 : Grizo [M:CDT]ACCSCR3 : # Mono-opération: tjs saisi en mode Fiche
  Affzo [M:CDT]
Endif
# points d'entrée pour ce type de transaction
Gosub PE_PURTRS From SUBPTX
Affzo [M:PTE0]1-99
Affzo [M:PTE1]1-99
Affzo [M:PTE2]1-99
Affzo [M:PTE3]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "ECCCOD"       # Issue 107513/US2 GA 04/2015 : ECC
       If val(CZ) = 2 & [M:PTE3]ECCCODMIN=1
           [M:PTE3]ECCCODMIN = 2
           If !GIMPORT Affzo [M:PTE3]ECCCODMIN : Endif
       Endif
       If val(CZ)=3
         [M:PTE3]ECCSCR=2
         [M:PTE3]ECCCODMIN=3
         [M:PTE3]ECCSCRMIN=2
         If !GIMPORT Affzo [M:PTE3]ECCSCR,ECCCODMIN,ECCSCRMIN : Grizo [M:PTE3]ECCSCR,ECCCODMIN,ECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [M:PTE3]ECCSCR,ECCCODMIN,ECCSCRMIN
       Endif
  When "ECCCODMIN"       # Issue 107513/US2 GA 04/2015 : ECC
       If val(CZ)=3
         [M:PTE3]ECCSCRMIN=2
         If !GIMPORT Affzo [M:PTE3]ECCSCRMIN : Grizo [M:PTE3]ECCSCRMIN : Endif
       Elsif !GIMPORT
         Actzo [M:PTE3]ECCSCRMIN
       Endif
  When Default
     # points d'entrée pour ce type de transaction
       Gosub PE_PURTRS From SUBPTX
Endcase
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
Gosub CHARG_COMPLEMENT
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
Gosub CHARG_COMPLEMENT
Return

#---------------------------#
# Chargement complémentaire #
#---------------------------#
$CHARG_COMPLEMENT
# Textes traduits
Gosub CHARGE_ATEXTRA
# points d'entrée pour ce type de transaction
Gosub PE_PURTRS      From SUBPTX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:PTE0]DESAXX,"PURTRS","DESAXX",num$([M:PTE0]PTRTYP),[M:PTE0]PTRNUM) From ATEXTRA
[F:PTR]PTRDES   =GLANGUE+"~"+[M:PTE0]DESAXX
[F:PTR]PTRTYPCAR=num$([F:PTR]PTRTYP)
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char    APPLI(30) : Endif
If dim(OK)<0    Local Integer OK    : Endif
If dim(WMODU)<0 Local Char    WMODU(2) : Endif
If APPLI="" APPLI=nomap : Endif
If WMODU="" WMODU="E"+num$([M:PTE0]PTRTYP) : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO  (GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     WOPTION(15)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK
#----- Noms fenêtres et traitement réception -----#
Local Char     WINREF1(GLONFEN)  : WINREF1="OSCO"
Local Char     NOMWIN1(GLONFEN)  : NOMWIN1="WOSCO"+[M:PTE0]PTRNUM
#----- 1er écran -----#
MFROM="SCO0"
MTO="WE"+num$([M:PTE0]PTRTYP)+[M:PTE0]PTRNUM+"0"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   OPT1=2
   Gosub PE_PURTRS From SUBPTX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

#----- 2eme écran -----#
MFROM="SCO1"
MTO="WE"+num$([M:PTE0]PTRTYP)+[M:PTE0]PTRNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
#
   If [M:PTE3]INVFCYCOD>0 TZONE(IZON)="INVFCY"
                          TMOD(IZON) =[M:PTE3]INVFCYCOD
                          IZON+=1
   Endif
   If [M:PTE3]MFGFCYCOD>0 TZONE(IZON)="MFGFCY"
                          TMOD(IZON) =[M:PTE3]MFGFCYCOD
                          IZON+=1
   Endif
   If [M:PTE3]RCPFCYCOD>0 TZONE(IZON)="PRHFCY"
                          TMOD(IZON) =[M:PTE3]RCPFCYCOD
                          IZON+=1
   Endif
   If [M:PTE3]RCPADDCOD>0 TZONE(IZON)="PRHADD"
                          TMOD(IZON) =[M:PTE3]RCPADDCOD
                          IZON+=1
                        # FQ 59521 GA 11/2009 Cacher aussi la Désignation si 3=Invisible
                          If [M:PTE3]RCPADDCOD=3
                             TZONE(IZON)="PRHADDDES"
                             TMOD(IZON) =[M:PTE3]RCPADDCOD
                             IZON+=1
                          Endif
   Endif
   If [M:PTE3]SCOADDCOD>0 TZONE(IZON)="BPAADD"
                          TMOD(IZON) =[M:PTE3]SCOADDCOD
                          IZON+=1
   Endif
   If [M:PTE3]PJTCOD>0 TZONE(IZON)="PJT"
                       TMOD(IZON) =[M:PTE3]PJTCOD
                       IZON+=1
   Endif
   If [M:PTE3]PIOCOD>0 TZONE(IZON)="PIO"
                       TMOD(IZON) =[M:PTE3]PIOCOD
                       IZON+=1
   Endif
   # GA 09/2006 [M:CDT] inutilisé: on ne gère plus les comptes sur les EO
   If clalev([M:CDT])
     If [M:CDT]FLGACCSCR1=1  : # Bloc de saisie des comptes => invisible
        TBLOC(3) = 1         : # 4ème bloc : indice 3
     Endif
     If [M:CDT]FLGCCESCR1=1  : # Bloc de saisie des axes    => invisible
        TBLOC(4) = 1         : # 5ème bloc : indice 4
     Endif
   Endif
   If clalev([M:DST])
   # Bloc de saisie des axes invisible si toutes les sections sont invisibles
     If !find(1,[M:DST]CCECOD(0..[M:DST]NBDIE)) & !find(2,[M:DST]CCECOD(0..[M:DST]NBDIE))
        TBLOC(3) = 1         : # 4ème bloc : indice 3
     Endif
   Endif
#
   OPT1=2
   Gosub PE_PURTRS From SUBPTX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

#----- 3eme écran -----#
MFROM="SCO2"
MTO="WE"+num$([M:PTE0]PTRTYP)+[M:PTE0]PTRNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
#
   If [M:PTE3]MFGFCYCOD>0 TZONE(IZON)="MFGFCY"
                          TMOD(IZON) =[M:PTE3]MFGFCYCOD
                          IZON+=1
   Endif
# GA 19/09/2008 ne pas autoriser le mode fiche dans cet écran,
# si saisie non autorisée en mode fiche voir écran [M:SCMW] - actions traitement SCOWINLIB
   If [M:PTE3]STOFCYCOD>0 TZONE(IZON)="STOFCY"
###                       TINT(IZON) =num$([M:PTE3]STOFCYSCR)
                          If [M:PTE3]STOFCYSCR=2 : # Mode fiche uniquement, donc invisible en Tableau
                             TMOD(IZON) = 3
                          Else
                             TMOD(IZON) =[M:PTE3]STOFCYCOD
                          Endif
                          IZON+=1
   Endif
   If [M:PTE3]LOTCOD>0    TZONE(IZON)="LOT"
###                       TINT(IZON) =num$([M:PTE3]LOTSCR)
                          If [M:PTE3]STOFCYSCR=2 : # Mode fiche uniquement, donc invisible en Tableau
                             TMOD(IZON) = 3
                          Else
                             TMOD(IZON) =[M:PTE3]LOTCOD
                          Endif
                          IZON+=1
   Endif
   If [M:PTE3]LOCCOD>0    TZONE(IZON)="LOC"
###                       TINT(IZON) =num$([M:PTE3]LOCSCR)
                          If [M:PTE3]STOFCYSCR=2 : # Mode fiche uniquement, donc invisible en Tableau
                             TMOD(IZON) = 3
                          Else
                             TMOD(IZON) =[M:PTE3]LOCCOD
                          Endif
                          IZON+=1
   Endif
   # Issue 107513/US2 GA 04/2015 : ECC for [M:SCO2] table SCOMAT
   If dim([M:PTE3]ECCCOD)>0
      If [M:PTE3]ECCCOD>0     TZONE(IZON)="ECCVALMAJ"
                              If [M:PTE3]ECCSCR=2 : # Hidden in table [M:SCO2], Displayed/Enter in [M:SCMW]
                                 TMOD(IZON) = 3
                              Else
                                 TMOD(IZON) =[M:PTE3]ECCCOD
                              Endif
                              IZON+=1
      Endif
      If [M:PTE3]ECCCODMIN>0  TZONE(IZON)="ECCVALMIN"
                              If [M:PTE3]ECCSCRMIN=2 : # Hidden in table [M:SCO2], Displayed/Enter in [M:SCMW]
                                 TMOD(IZON) = 3
                              Else
                                 TMOD(IZON) =[M:PTE3]ECCCODMIN
                              Endif
                              IZON+=1
      Endif
   Endif
   # End issue 107513/US2
   # GA 09/2006 [M:CDT] inutilisé: on ne gère plus les comptes sur les EO
   If clalev([M:CDT])
     # Mode de saisie des 10 comptes Fiche et/ou tableau
     If dim([M:CDT]ACCSCR2)>0 & [M:CDT]ACCSCR2 >1
       For I=0 To 9
         TZONE(IZON)="ACC"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:CDT]ACCSCR2)
         IZON+=1
       Next I
     Endif
     # Mode de saisie des 20 sections Fiche et/ou tableau
     If dim([M:CDT]CCESCR2)>0 & [M:CDT]CCESCR2 >1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:CDT]CCESCR2)
         IZON+=1
       Next I
     Endif
   Endif
   If clalev([M:DST])
     # Mode de saisie des 20 sections Fiche et/ou tableau
     If dim([M:DST]CCESCR2)>0 & [M:DST]CCESCR2 >1
       For I=0 To 19
         TZONE(IZON)="CCE"+num$(I+1)
         TMOD(IZON) =9
         TINT(IZON) =num$([M:DST]CCESCR2)
         IZON+=1
       Next I
     Endif
   Endif
   If [M:PTE3]PJTCOD>1  TZONE(IZON)="PJT"
                        TMOD(IZON) =[M:PTE3]PJTCOD
                        IZON+=1
   Endif
   If [M:PTE3]PIOCOD>1  TZONE(IZON)="PIO"
                        TMOD(IZON) =[M:PTE3]PIOCOD
                        IZON+=1
   Endif
#
   OPT1=2
   Gosub PE_PURTRS From SUBPTX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif

#----- 4eme écran -----#
MFROM="SCO3"
MTO="WE"+num$([M:PTE0]PTRTYP)+[M:PTE0]PTRNUM+"3"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:PTE3]PJTCOD>0 TZONE(IZON)="PJT"
                       TMOD(IZON) =[M:PTE3]PJTCOD
                       IZON+=1
   Endif
   If [M:PTE3]PIOCOD>0 TZONE(IZON)="PIO"
                       TMOD(IZON) =[M:PTE3]PIOCOD
                       IZON+=1
   Endif
   # GA 10/2006 délai + dates du service
   If [M:PTE3]SCOLTICOD>0 TZONE(IZON)="SCOLTI"
                       TMOD(IZON) =[M:PTE3]SCOLTICOD
                       IZON+=1
   Endif
   If [M:PTE3]OPESTRCOD>0 TZONE(IZON)="OPESTR"
                       TMOD(IZON) =[M:PTE3]OPESTRCOD
                       IZON+=1
   Endif
   If [M:PTE3]OPEENDCOD>0 TZONE(IZON)="OPEEND"
                       TMOD(IZON) =[M:PTE3]OPEENDCOD
                       IZON+=1
   Endif
   # GA 09/2006 [M:CDT] inutilisé: on ne gère plus les comptes sur les EO
   If clalev([M:CDT])
     If [M:CDT]FLGACCSCR3=1  : # Bloc de saisie des comptes => invisible
        TBLOC(3) = 1         : # 4ème bloc : indice 3
     Endif
     If [M:CDT]FLGCCESCR3=1  : # Bloc de saisie des axes    => invisible
        TBLOC(4) = 1         : # 5ème bloc : indice 4
     Endif
   Endif
   If clalev([M:DST])
   # Bloc de saisie des axes invisible si toutes les sections sont invisibles
     If !find(1,[M:DST]CCECOD3(0..[M:DST]NBDIE3)) & !find(2,[M:DST]CCECOD3(0..[M:DST]NBDIE3))
        TBLOC(3) = 1         : # 4ème bloc : indice 3
     Endif
   Endif
   OPT1=2
   Gosub PE_PURTRS From SUBPTX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif
Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression pour commandes standards ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par FUNPURTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par FUNPURTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par FUNPURTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par FUNPURTRS
#----- Suppression fenêtre si transaction non active -----#
If [M:PTE0]ENAFLG=1 Gosub TRT_SUP_FEN : Return : Endif
#----- Génération fenêtre pour commandes standards si transaction active -----#
Delete [AWI] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINDOW"-NOMWIN1 : Return
Elsif fstat GOK=0  : Call RSTA ("AWI",NOMWIN1) From GLOCK : Return
Endif
Delete [AWP] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINPAR"-NOMWIN1 : Return
Elsif fstat GOK=0  : Call RSTA ("AWP",NOMWIN1) From GLOCK : Return
Endif
Delete [AWB] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINBRO"-NOMWIN1 : Return
Elsif fstat GOK=0  : Call RSTA ("AWB",NOMWIN1) From GLOCK : Return
Endif
Delete [AWT] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINBOUT"-NOMWIN1 : Return
Elsif fstat GOK=0  : Call RSTA ("AWT",NOMWIN1) From GLOCK : Return
Endif
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = "SCO0"
  WNOMMSK="WE"+num$([M:PTE0]PTRTYP)+[M:PTE0]PTRNUM+"1" : Gosub ONGLET_INVISIBLE
  I=find("SCO1",[F:AWI]NOMMSK)-1 : If I<0 I=0 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  WNOMMSK="WE"+num$([M:PTE0]PTRTYP)+[M:PTE0]PTRNUM+"2" : Gosub ONGLET_INVISIBLE
  I=find("SCO2",[F:AWI]NOMMSK)-1 : If I<0 I=1 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  WNOMMSK="WE"+num$([M:PTE0]PTRTYP)+[M:PTE0]PTRNUM+"3" : Gosub ONGLET_INVISIBLE
  I=find("SCO3",[F:AWI]NOMMSK)-1 : If I<0 I=2 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:PTE0]ACSCOD
  If dim([F:AWI]LIBEL)>0
    [F:AWI]LIBEL   = [M:PTE0]DESAXX
  Endif
  [F:AWI]ENAFLG    = 2
  [F:AWI]MDL       = 1
  [F:AWI]TRN       = [M:PTE0]PTRNUM
  #----- Point d'entrée PURTRSWIN pour intervention sur fenêtre générée -----#
  Gosub PE_PURTRSWIN From SUBPTX
  #-----
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    #----- Point d'entrée PURTRSAWB pour intervention sur browser de fenêtre générée -----#
    Gosub PE_PURTRSAWB From SUBPTX : #VPO 13/01/11 70621
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN
If !OK  GOK=0 : Endif
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMK] CODMSK=WNOMMSK
If fstat  Raz [F:AMK]  : WFLGMSK=2 : Return : Endif
WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)=1
    Read [AMZ] CODE=WNOMMSK;[F:AMK]BASPAG(I) : If fstat  Raz [F:AMZ] : Endif
    If [F:AMZ]SAIAFF<>3  WFLGMSK=2 : Break : Endif
  Elsif [F:AMK]TYPBLOC(I)<>5
    WFLGMSK=2 : Break
  Endif
Next I
Return



######################################################################################

# ----------------------------------- #
# Particularités de l'onglet [M:CDT]  #
# Transaction PTE: saisie des EO     #
# ----------------------------------- #
$AFFZO_COATRS_PTE
  # GA 09/2006 [M:CDT] inutilisé: on ne gère plus les comptes sur les EO
  If clalev([M:CDT])<=0 Return Endif

# Chgtbk [M:CDT]10        With mess(35,0,1)-"-"-mess(5,943,1) : # Mode de saisie - Comptes
# Chgtbk [M:CDT]15        With mess(5,943,1)   : # "Comptes"
  Chgtzn [M:CDT]ACCSCR1   With mess(2,348,1)   : # "Article lancé"
  Chgtzn [M:CDT]ACCSCR2   With mess(157,197,1) : # "Matière"
  Chgtzn [M:CDT]ACCSCR3   With mess(7,438,1)   : # "Service"

# 1 et un seul plan de compte par référentiel,
# mais plusieurs référentiels peuvent utiliser le même plan de compte [F:COA]
# donc il vaut mieux lister les comptes plutôt que [F:LED]

  If dim([M:CDT]NBCOA)>0
# "Plan"  "Intitulé"  "Article lancé"  "Matière"  "Service"
    Titcol [M:CDT]NBCOA     mess(205,111,1), mess(30,109,1) ,
&                           mess(2,348,1)  ,
&                           mess(157,197,1),
&                           mess(7,438,1)

  Elsif dim([M:CDT]NBLED)>0
# "Référentiel"  "Intitulé"  "Article lancé"  "Matière"  "Service"
    Titcol [M:CDT]NBLED     mess(208,111,1), mess(30,109,1) ,
&                           mess(2,348,1)  ,
&                           mess(157,197,1),
&                           mess(7,438,1)  ,
&                           mess(205,111,1), mess(30,109,1)
  Elsif dim([M:CDT]NBLEDTYP)>0
# "Référentiel"  "Article lancé"  "Matière"  "Service"
    Titcol [M:CDT]NBLEDTYP  mess(208,111,1),
&                           mess(2,348,1)  ,
&                           mess(157,197,1),
&                           mess(7,438,1)  ,
&                           mess(205,111,1), mess(30,109,1)
  Endif
  [M:CDT]ACCSCR1=2 : Grizo [M:CDT]ACCSCR1 : # Mono-article  : tjs saisi en mode Fiche
  [M:CDT]ACCSCR3=2 : Grizo [M:CDT]ACCSCR3 : # Mono-opération: tjs saisi en mode Fiche
Return


#-------------------------------------#
# Gestion des Sections analytiques    #
#-------------------------------------#
$AFFZO_DIETRS_PTE
  # GA 09/2006 [M:CDT] inutilisé: on ne gère plus les comptes sur les EO
  If clalev([M:CDT])<=0 Return Endif

# Chgtbk [M:CDT]20        With mess(35,0,1)-"-"-mess(401,200,1) : # Mode de saisie - Axe
# Chgtbk [M:CDT]25        With mess(401,200,1) : # "AXES analytiques"
  Chgtzn [M:CDT]CCESCR1   With mess(2,348,1)   : # "Article lancé"
  Chgtzn [M:CDT]CCESCR2   With mess(157,197,1) : # "Matière"
  Chgtzn [M:CDT]CCESCR3   With mess(7,438,1)   : # "Service"
 # "Axe"  "Intitulé"  "Article lancé"  "Matière"  "Service"
  Titcol [M:CDT]NBDIE     mess(206,111,1),
&                         mess(30,109,1) ,
&                         mess(2,348,1)  ,
&                         mess(157,197,1),
&                         mess(7,438,1)
#
  [M:CDT]CCESCR1=2 : Grizo [M:CDT]CCESCR1 : # Mono-article  : tjs saisi en mode Fiche
  [M:CDT]CCESCR3=2 : Grizo [M:CDT]CCESCR3 : # Mono-opération: tjs saisi en mode Fiche
Return

########################################
Subprog VERIF_REPORT(LCOD, LRET)
Value     Char    LCOD
Variable  Integer LRET

LRET = 0
If clalev ([F:ARP]) <= 0 : Local File AREPORT  [ARP] : Endif
Filter [ARP] Where RPTCOD = LCOD
Look [ARP] First
If fstat : LRET = 1 : Endif
Filter [ARP]
End


