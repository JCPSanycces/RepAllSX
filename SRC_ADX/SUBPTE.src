########################################################################
# Pour exécution de la validation des transactions en gestion de patch #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Local Integer TYP : TYP=9
Gosub GENPATCH From FUNPURTRS
End


##########################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer TYP : TYP=9
Gosub GENDOS From FUNPURTRS
End


#-------------------------------------#
# Hard copy des écrans de paramétrage #
#-------------------------------------#
$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(4)
Local Char WABR(4)(4)
#-----
Call TEXTFIC("PURTRS","PTRNUM",2,WINT(0)) From OBJDIV
Call TEXTFIC("PURTRS","ACSCOD",2,WINT(1)) From OBJDIV
WTIT = WINT(0)+" : "+[M:PTE0]PTRNUM-[M:PTE0]DESAXX-WINT(1)+" : "+[M:PTE0]ACSCOD
WMSK(0) = "PTE1"
WMSK(1) = "PTE2"
WMSK(2) = "PTE3"
WMSK(3) = "DIESCRTRS"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
OK=0 : # Pour ne pas imprimer tout de suite !
Return


########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=6
Local Integer TYP       : TYP=9
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return


#-------------------------------------------#
# DésActivation des blocs/champs de TRSAUTO #
#-------------------------------------------#
$DISZO_TRSAUTO
Actzo [M:PTE1]10 : # Actzo [M:PTE1]25 : #  Grizo [M:PTE1]30 : # GH 17/01/13 bug 37334
Actzo [M:PTE2]
Actzo [M:PTE3]
Actzo [M:DST]   : # [M:CDT]
Return


#----------------------------------------#
# Activation des blocs/champs si TRSAUTO #
#----------------------------------------#
$ACTZO_TRSAUTO
Grizo [M:PTE1]10 : # Grizo [M:PTE1]25 : # Actzo [M:PTE1]30 : # GH 17/01/13 bug 37334
Grizo [M:PTE2]
Grizo [M:PTE3]
Grizo [M:DST]   : # [M:CDT]
Return

