GBOUT1 = mess(347,198,1)
End

Subprog C_DOCNAM(VALEUR)
Variable Char    VALEUR()
Local    Integer WRET
If [M:PTE2]DOCFLG = 1 : End : Endif
If VALEUR = "" : GMESSAGE = mess(10,123,1) : mkstat = 2 : End : Endif
Call VERIF_REPORT(VALEUR, WRET)
If WRET
    GMESSAGE = mess(23,100,1)
    mkstat   = 2
Endif
End

