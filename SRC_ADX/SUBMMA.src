########################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
#
If VALEUR <> ""
   Read [STL]STL0(2)=[M:MMA]ITMREF;VALEUR
   If fstat
      Raz [STL]
      GMESSAGE = mess(99,100,1)
      mkstat = 2
   Endif
Else 
   Raz [STL]
Endif
#
End

########################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()
#
Call CONTSTA(VALEUR) From STOLIB
#
End

########################################
Subprog S_STA(VALEUR)
Variable Char    VALEUR()
#
Call SELSTA(VALEUR) From STOLIB
#
End

