#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management SWIBVRPIH / SWIBVRBIS
######################################################################################################
# Project       : Swiss Localization
# File          : SUBBVR
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 23.12.15
######################################################################################################
# Module        : Purchase invoices (GESBIS/GESPIH)
# Description   : - ISR reference line entry
######################################################################################################
 # Updates :
 # Date       |Author   |Version|Description
 # 2016-03-08 |ANGRE    |U10    |SAM #115076: AM_BVRREFLINE: Raz [M:BIS3] when ISR reference has changed
######################################################################################################



######################################################################################
## Section automatically added (screen SWIBVRPIH) 12/23/2015 12:47:32 (UBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "OK"           : Gosub OK
 When "ABA"          : Gosub ABA
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SETBOUT"      : Gosub SETBOUT
 When Default
Endcase
Return

#*****************************************************************************************************
# OUVRE: Open files
#*****************************************************************************************************
$OUVRE
If !clalev([F:XADI])  : Local File ATABDIV    [XADI]  : Endif
If !clalev([F:XTPT])  : Local File TABPAYTERM [XTPT]  : Endif
If !clalev([F:DUD])   : Local File GACCDUDATE [DUD]   : Endif
If !clalev([F:XTVT])  : Local File TABVAT     [XTVT]  : Endif
If !clalev([F:XTRA])  : Local File TABRATVAT  [XTRA]  : Endif
If !clalev([F:XBPS])  : Local File BPSUPPLIER [XBPS]  : Endif
If !clalev([F:XCAC])  : Local File GACCCODE   [XCAC]  : Endif
If !clalev([F:XGAC])  : Local File GACCOUNT   [XGAC]  : Endif
If !clalev([F:XBPA])  : Local File BPADDRESS  [XBPA]  : Endif
If !clalev([F:XTAM])  : Local File TABPAM     [XTAM]  : Endif

# Issue X3-102547
Gosub OUVRE_ACT_CODE From SUBBIS2

Return

#*****************************************************************************************************

#26079 ABO : 11.08.2011
#*****************************************************************************************************
# OUVRE_BOITE: Load referential and analytic axis
#*****************************************************************************************************
$OUVRE_BOITE

Global Integer MASQUE
Raz MASQUE


#---- Check where we come from (GESBIS or GESPIH) ----#
Call MASQUE(MASQUE) From SWIBVRLIB4

If MASQUE = 1 and (GREP="C") and ([M:BIS3]NBLIG = 0)  # GESBIS
  Local Char    XPARAM(10)
  Local Char    CODLED(GLONLED), MESSA(250)
  Local Integer STAT : STAT = 0
  Call LECTURE("FCY",[M:BIS0]FCY,"") From CONTOBJ
  [M:BIS0]CPY = [F:FCY]LEGCPY
  Call LECTURE("CPY",[M:BIS0]CPY,"") From CONTOBJ
  Call GETSOC([M:BIS0]FCY) From DEVSUB
  [M:BIS0]CPYNAM = [F:CPY]CPYSHO
  Affzo [M:BIS0]CPY
  Affzo [M:BIS0]CPYNAM
  ## Global initialisations plans, ...
  Call INI_GLOBAL(2,[M:BIS0]CPY,STAT,MESSA) From SUBBICS
  If STAT
   GMESSAGE = MESSA
   mkstat = 2 : End
  Endif
  ## Display of columns ...
  If !GIMPORT Then
    Call AFFCOL(2) From SUBBICS
    Gosub SETCHPLST From SUBBICS
  Endif
# Issue 114426 - 2016-03-18 by RICAR : SIVSUP parameter to split in PIVSUP and GASSUP
# Issue 114426
  #--- Parameter to suppress invoices
  Call PARAM([M:BIS0]FCY,"PIVSUP",XPARAM) From ADOVAL
  GPIVSUP=val(XPARAM)
# End issue 114426
  #--- Parameter for creation of null lines
  Call PARAM([M:BIS0]FCY,"SIVNULL",XPARAM) From ADOVAL
  GSIVNULL=val(XPARAM)
  #--- tax code
  Call PARAM([M:BIS0]FCY,"EXETAX",XPARAM) From ADOVAL
  GEXETAX  = XPARAM
  #--- VAT rounding
  Call PARAM([M:BIS0]FCY,"VATRND",XPARAM) From ADOVAL
  GVATRND  = val(XPARAM)
Endif
Return
#*****************************************************************************************************

#*****************************************************************************************************
# DEBUT: when showing the window
#*****************************************************************************************************
$DEBUT

#---- initializations ----#
Gosub CHARG

Affzo  [M]1-99
Return
#*****************************************************************************************************

#*****************************************************************************************************
# OK: OK button of ISR reference line entry screen is pressed
# The ISR reference line is analyzed and the invoice is initialized with the supplier, payment
# method, account, amount, ...
#*****************************************************************************************************
$OK
If REP="M"
  Local Char BVRREFLINE(55)
  If MASQUE=1
        If [M:BIS1]STA<>3
            BVRREFLINE=[M:SWIBVR]BVRREFLINE
            If mkstat : End : Endif
            If (GREP="C" | GREP="D" | GREP="")
             Gosub SET_PIVTYP From SUBBIS
            Endif
            If !GIMPORT & GREP="" & [M:BIS0]INVTYP<>[F:TPV]INVTYP
             # different invoice types
             GMESSAGE = mess(60,119,1)
             mkstat=2 : End
            Endif
            Call OK_BVR(BVRREFLINE) From SWIBVRLIB4
            [M:BIS1]PURPRITYP=2
            Affzo [M:BIS1]PURPRITYP
            mkstat=4
        Endif
  Else
        If [M:PIH1]STA<>3
            BVRREFLINE=[M:SWIBVR]BVRREFLINE
            Call OK_BVR(BVRREFLINE) From SWIBVRLIB4
            mkstat=4
        Endif
  Endif
Endif
Return
#*****************************************************************************************************

#*****************************************************************************************************
# ABA: When canceling the entry
#*****************************************************************************************************
$ABA
Gosub CHARG
REP =""
Affzo [M]1-99
Return
#*****************************************************************************************************

#*****************************************************************************************************
# APRES_MODIF: after changing the ISR (BVR) line
#*****************************************************************************************************
$APRES_MODIF

REP="M" : # activation of abort button in the window

Return
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
# CHARG: initialisation of the screen
#-----------------------------------------------------------------------------------------------------
$CHARG
If MASQUE=1 Then
    [M:SWIBVR]BVRREFLINE = [M:BIS1]BVRREFLINE
    [M:SWIBVR]BVRBID     = [M:BIS1]BVRBID
    If [M:BIS1]STA=3
       Diszo [M:SWIBVR]BVRREFLINE
    Else
       Actzo [M:SWIBVR]BVRREFLINE
    Endif
Else
    [M:SWIBVR]BVRREFLINE = [M:PIH1]BVRREFLINE
    [M:SWIBVR]TOTAMT     = [M:PIH1]TOTATIAMT1
    [M:SWIBVR]TOTVAT     = [M:PIH1]TOTTAXAMT1
    [M:SWIBVR]BVRBID     = [M:PIH1]BVRBID
    If GREP <> "C"
       Diszo [M:SWIBVR]BVRREFLINE
       Diszo [M:SWIBVR]TOTAMT
       Diszo [M:SWIBVR]TOTVAT
    Else
       Actzo [M:SWIBVR]BVRREFLINE
       Actzo [M:SWIBVR]TOTVAT
       If len([M:SWIBVR]BVRREFLINE) > 2 and left$([M:SWIBVR]BVRREFLINE,3) = "042"
           Actzo [M:SWIBVR]TOTAMT
       Else
           Diszo [M:SWIBVR]TOTAMT
       Endif
    Endif
Endif
Return
#-----------------------------------------------------------------------------------------------------

#*****************************************************************************************************
# SETBOUT: Initialisation of buttons
#*****************************************************************************************************
$SETBOUT
If REP<>"M" : Call VIREBOUT(CHBOU,"A") From GOBJET : Endif
If MASQUE=1
    If [M:BIS1]STA=3
        Call VIREBOUT(CHBOU,"A") From GOBJET
        Call VIREBOUT(CHBOU,"O") From GOBJET
    Endif
Else
    If [M:PIH1]STA=3
        Call VIREBOUT(CHBOU,"A") From GOBJET
        Call VIREBOUT(CHBOU,"O") From GOBJET
    Endif
Endif
Gosub SET_BOUT_STD From GSAISIE
Return
#*****************************************************************************************************


#*****************************************************************************************************
# AS_BVRREFLINE: When the invoice is validated, ISR reference line may not be changed
#*****************************************************************************************************
Subprog AS_BVRREFLINE(VALEUR)
Variable Char    VALEUR()
If MASQUE=1
    If [M:BIS1]STA=3 : mkstat=2 : End : Endif
Else
    If [M:PIH1]STA=3 : mkstat=2 : End : Endif
Endif
End


#*****************************************************************************************************
# C_BVRREFLINE: Control the correctness of the ISR reference line
#*****************************************************************************************************
Subprog C_BVRREFLINE(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Call CONT_BVRREFLINE(VALEUR) From SWIBVRLIB4
Endif
End


#*****************************************************************************************************
# AM_BVRREFLINE: Extract the total amount from the ISR reference line and display it
#*****************************************************************************************************
Subprog AM_BVRREFLINE(VALEUR)
Variable Char    VALEUR()
Local Decimal AMOUNT
Local Char BVRNUM(11)
Local Integer TYPE_DTA
Local Char NUMCLEAR(5)
Local Char ACCOUNT(30)
Local Char CUR_(GLONCUR)
Local Integer OK

   If MASQUE = 1
    # SAM #115076 08.03.2016 angre
    If VALEUR <> [M:BIS1]BVRREFLINE and [M:BIS1]BVRREFLINE <> ""
      Call OUINON(mess(88,3648,1),OK) From GESECRAN #The ISR reference line was changed. The invoice will be initialized again, any previous changes will be overwritten.
      If OK<>2
        mkstat = 2
      Else
        # # SAM #115076 21.03.2016 angre raz [M:BIS1]AMTATI to make shure that the amount differs and the method SET_AMOUNT_BIS in SWIBVRLIB4 is triggered.
        Raz [M:BIS1]AMTATI
        Raz [M:BIS3]
      Endif
    Endif

  Else
    # Extraction of ISR reference line informations
    Call EXTRACT_DTA(VALEUR,TYPE_DTA,BVRNUM,AMOUNT,ACCOUNT,NUMCLEAR,CUR_) From SWIBVRLIB4
# Issue 112279 04.12.15 Bader
    If left$(VALEUR,3) = "042"
        Actzo [M:SWIBVR]TOTAMT
    Else
        Diszo [M:SWIBVR]TOTAMT
    Endif
# end issue 112279 04.12.15 Bader
   [M:SWIBVR]TOTAMT = AMOUNT
    Affzo [M:SWIBVR]TOTAMT
  Endif
End


######################################################################################

