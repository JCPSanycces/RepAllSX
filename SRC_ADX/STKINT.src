#<AdxTL>@(#)10.0.0.0 $Revision$
########################################################################
# Traitement STKINT - Librairie des composants d'interface        V140 #
#                     pour la mise à jour des stocks                   #
########################################################################
#
# ALISTOWORK     Alimentation de l'écran de travail STOWORK pour appel
#                à la mise à jour des stocks
#
# SPLIT_ENTW_LPN Splittage des STOENTW selon la capacité du contenant et
#                création des LPN lorsque les LPN sont créés à la volée
#
########################################################################

########################################################################
# ALISTOWORK     Alimentation de l'écran de travail STOWORK pour appel
#                à la mise à jour des stocks
#                L'origine des données peut être :
#                - Table STOALL    (Allocations)
#                - Ecran STOENTW   (Ecran stockage des entrées)
#                - Ecran STOSORW   (Ecran stockage des sorties)
#                - Ecran STOENTM   (Ecran modification des entrées)
#                - Ecran STOSORM   (Ecran modification des sorties)
#                - Ecran STKSHTREG (Ecran régularisation des sorties)
#                - Ecran STOCHGW   (Ecran changement de stock)
#                                   Transfert inter-site (interne)
#                                   Changement stock (Emplacement/Statut/UC)
#                                   Contrôle qualité
#                - Table CUNLISDET (Inventaires)
#                - Table STOJOU    (Mouvements de stock)
#                - Ecran QCR1      (Ecran génération demandes d'analyses)
#
########################################################################

########################################################################
# Prérequis    : La table article ITMMASTER doit être ouverte
#
#                L'écran de travail STOWORK [STW] doit être ouvert
#                L'écran d'origine des données doit être ouvert
#
########################################################################
# Paramètres E : LORI = Origine des données :
#                       1 = STOALL
#                       2 = STOENTW
#                       3 = STOSORW
#                       4 = STOENTM
#                       5 = STOSORM
#                       6 = STKSHTREG
#                       7 = STOCHGW
#                       8 = CUNLISDET
#                       9 = STOENTW (Déclaration production suite à suivi auto)
#                      10 = STOJOU  (Facture de livraisons de prêt)
#                      11 = STOALL  (Réappro emp en mode VT et spécifique pesée)
#                      12 = QCR1    (Génération demande d'analyse)
#
#                LLIG = Lien avec ligne document
#                       si LORI=2,3 ou 7   --> [M:XXX]WSTOSEQ(nolign-1)
#                       si LORI=12         --> nolign-1
#
#                LQTY = si LORI=10         --> Quantité à traiter
#                       si LORI=11 et [M:STW]VCRTYP=10
#                                          --> Quantité pesée (à traiter)
#
#            S : LQTY = si LORI=1,2,3,9,10 --> Quantité OK traitée
#                       si LORI=8          --> Total qté inventaire calculé
#                LSHT = si LORI=1,3        --> Quantité manquante traitée
#                       si LORI=8          --> Total qté inventaire compté
#                LNBR = si LORI=8          --> Nombre inventaires
#                LNBJ = si LORI=8          --> Nombre inventaires justes
#                LRET = Code retour = 0 : OK
#                                  <> 0 : Erreur
#                       Valeurs d'erreurs
#                        1 : Lien avec ligne document non renseigné
#                        2 : Emplacement destination non renseigné
#                        3 : Chrono stock origine non renseigné (retour prêt)
#                        4 : Valeur du code activité STW insuffisante
#                        5 : Le mouvement en attente à régulariser n'existe pas
#                        6 : Lot obligatoire non renseigné
#                        7 : Propriétaire du stock non renseigné
#                       11 : Article non géré en stock
#                       12 : Quantité en rupture : stock négatif interdit
#                       13 : Quantité en rupture : chgt d'emplacement impossible
#                       14 : Stock manquant à régulariser (Trf inter-sites)
#                       15 : Qte allouée > Qte comptée (Inventaires)
#                       21 : Emplacement bloqué pour inventaire
#                       22 : Emplacement en attente de rangement
#                       23 : L'emplacement n'est pas de type sous-traitant
#                       24 : L'emplacement n'est pas de type client
#                       31 : Problème en récupération de compteur lot
#                       41 : Pas de mvt de sortie (Modif récept trf inter-sites)
#                       51 : Erreur lecture article
#                       52 : Erreur lecture article-site
#                       53 : Erreur lecture lot
#                       54 : Erreur lecture stock
#                       55 : Erreur lecture emplacement
#                       56 : Erreur lecture type emplacement
#                       57 : Erreur lecture allocation
#                       58 : Erreur lecture inventaire
#                       64 : Erreur réécriture stock
#                       67 : Erreur en mise à jour allocation
#                       68 : Erreur réécriture inventaire
#                       71 : Pas de mvt sortie correspondant au trf inter-site
#                       72 : Pas de chrono stock correspondant au mvt entrée
#                       73 : Pas de mvt sortie correspondant au mvt entrée
#                       74 : Erreur fichier STOSERW                                   # hcb 110327
#                       75 : Quantité à facturer supérieure au nombre de no série à sortir  : #--- Issue 110327
#                       80 : Erreur en création des LPN
#                      >100: Erreur dans STKVALMAJ
########################################################################
# Entrée       : Ecran STOWORK [STW] (Bloc 1)
#
#                [M:STW]STOFCY    = Site stock
#                [M:STW]TRSTYP    = Type mouvement (M.704)
#                                   Si LORI=7 alors
#                                     mettre  8 si contrôle qualité
#                                     mettre 14 si inter-site
#                                     mettre  7 sinon
#                                       on alimentera [M:STW]TRSTYPLIG avec
#                                       -  7 pour chgt emplacement (+refractionnement)
#                                            ou   chgt emplacement (+chgt identifiant contenant)
#                                                 si transfert ou retour sous-traitant
#                                       -  9 pour chgt statut (+chgt emplacement +refractionnement)
#                                       - 21 pour refractionnement
#                                       - 36 pour chgt identifiant contenant (+chgt emplacement si
#                                                 ce n'est pas un transfert ou retour sous-traitant)
#                [M:STW]VCRTYP    = Type pièce (M.701)
#                [M:STW]VCRNUM    = Numéro pièce
#                [M:STW]VCRLIN    = Numero ligne pièce
#                [M:STW]ITMREF    = Article
#                [M:STW]MVTDES    = Désignation mouvement
#                [M:STW]BPRNUM    = Tiers   (Sauf si inventaire)
#                [M:STW]BPAADD    = Adresse (Si livraison) (A voir)
#                [M:STW]CUR       = Devise pièce
#                [M:STW]ENTCOD    = Code pièce auto stock
#                [M:STW]PJT       = Affaire (Sauf si inventaire)
#                [M:STW]TRSFAM    = Famille mouvement
#                [M:STW]TRSCOD    = Code mouvement
#                [M:STW]IPTDAT    = Date imputation
#                [M:STW]CCECOD    = Code section analytique stock
#                -------------------------------------------------------
#                [M:STW]CCSCOD    = Code section analytique stock
#                  - A alimenter si transfert inter-site pour le mvt de sortie
#                  Type mouvement : [M:STW]TRSTYP = 14
#                -------------------------------------------------------
#                [M:STW]TRFFCY    = Site transfert (destination)
#                  - A alimenter si inter-site
#                    Site destination si transfert inter-sites
#                                        livraison(normale,prêt,sous-traitance)
#                                        retour réception(normale,sous-traitance)
#                    Site origine     si réception(normale,sous-traitance)
#                                        retour livraison(normale,prêt,sous-traitance)
#                  Type mouvement : [M:STW]TRSTYP = 14,4,17,20,11,32,3,16,12,18,33
#                                   (si BETFCY=2)
#                -------------------------------------------------------
#                [M:STW]BETCPY    = Inter-société (1=non / 2=oui)
#                  - A alimenter si transfert inter-sites
#                                   livraison(normale,prêt,sous-traitance),
#                                   retour réception(normale,sous-traitance)
#                                   réception(normale,sous-traitance),
#                                   retour livraison(normale,prêt,sous-traitance)
#                  Type mouvement : [M:STW]TRSTYP = 14,4,17,20,11,32,3,16,12,18,33
#                                   (si BETFCY=2 & BETCPY=2)
#                -------------------------------------------------------
#                [M:STW]MISFLG    = Indicateur divers
#                  - Mettre 9 si re-contrôle de qualité pour exploiter la fiche
#                    technique associé au re-contrôle
#                #  Type mouvement : [M:STW]TRSTYP = 22
#                #  - Mettre 1 si rangement total dans plan de rangement
#                #  Type mouvement : [M:STW]TRSTYP = 22
#                #  - Mettre 1 si réception inter-site et intra-société
#                #  Type mouvement : [M:STW]TRSTYP = 3 (si BETFCY=2 et BETCPY=1)
#                #  - Mettre 1 si transfert inter-site et intra-société
#                #  Type mouvement : [M:STW]TRSTYP = 14 et ???
#                -------------------------------------------------------
#                [M:STW]LOCENT    = Emplacement destination
#                  - A alimenter si livraison(prêt,sous-traitance)
#                  Type mouvement : [M:STW]TRSTYP = 17,20
#                  - A alimenter si réappro zones de consommation
#                  Type mouvement : [M:STW]TRSTYP = 7 et [M:STW]VCRTYP = 34
#                  - A alimenter si bon préparation avec changement emplacement
#                  Type mouvement : [M:STW]TRSTYP = 7 et [M:STW]VCRTYP = 3
#                -------------------------------------------------------
#                [M:STW]VCRTYPORI = Type pièce origine (M.701)
#                [M:STW]VCRNUMORI = Numéro pièce origine
#                [M:STW]VCRLINORI = Numero ligne pièce origine
#                [M:STW]VCRSEQORI = Numero séquence pièce origine
#                  - A alimenter si sortie OF ou Ordre sous-traitance
#                  Type mouvement : [M:STW]TRSTYP = 6,29
#                  pour stockage pièce origine dans les mouvements de stock
#                  - A alimenter si demande de service
#                  Type mouvement : [M:STW]TRSTYP = 24
#                  pour stockage no demande service dans l'origine des mvts stock
#                  Attention VCRTYP et VCRTYPORI = 33 (demande de service) et
#                  VCRNUM = no consommation mais VCRNUMORI = no demande de service
#                  - A alimenter si retour réception(normale,sous-traitance)
#                                   retour livraison(prêt)
#                                   réintégration stock
#                  Type mouvement : [M:STW]TRSTYP = 11,32,18,19
#                  pour recherche prix ordre et prix valorisé du mouvement origine
#                  et stockage pièce origine dans les mouvements de stock
#                  - A alimenter si retour livraison(normale,sous-traitance)
#                  Type mouvement : [M:STW]TRSTYP = 12,33
#                  pour recherche prix ordre et prix valorisé du mouvement origine
#                  - A alimenter si réception inter-site(normale,sous-traitance)
#                  Type mouvement : [M:STW]TRSTYP = 3,16 et [M:STW]TRFFCY<>""
#                  pour recherche prix ordre et prix valorisé du mouvement origine
#                  (uniquement si intra-société)
#                  et stockage pièce origine dans les mouvements de stock
#                  - A alimenter si désassemblage d'un assemblage
#                  pour recherche prix ordre et prix valorisé du mouvement origine
#                  concernant le composé
#                  Type mouvement : [M:STW]TRSTYP = 2
#                  Type pièce     : [M:STW]VCRTYP = 32
#                  - A alimenter si facture de livraison de prêt
#                  Type mouvement : [M:STW]TRSTYP = 4 et LORI = 10
#                  pour récupérer les caractéristiques du stock à sortir
#                  - A alimenter si contrôle qualité
#                  Type mouvement : [M:STW]TRSTYP = 8
#                  pour maj pièce à l'origine du contrôle (si déclaration prod)
#                -------------------------------------------------------
#                [M:STW]ORIFCY    = Site de la pièce origine
#                  - A alimenter si retour client
#                  Type mouvement : [M:STW]TRSTYP = 12
#                  pour recherche prix ordre et prix valorisé du mouvement origine
#                -------------------------------------------------------
#                [M:STW]VCRTYPORI2= Type pièce origine (M.701)
#                [M:STW]VCRNUMORI2= Numéro pièce origine
#                [M:STW]VCRLINORI2= Numero ligne pièce origine
#                  - A alimenter si retour livraison(normale,sous-traitance)
#                  Type mouvement : [M:STW]TRSTYP = 12,33
#                  pour stockage pièce origine dans les mouvements de stock
#                  - Si inter-site et *ORI2 non renseigné, il s'agit d'un retour
#                  sur une livraison qui n'a pas été réceptionnée
#                   --> décrémentation transféré site liv et transit site rec
#                -------------------------------------------------------
#                [M:STW]PRIORDH   = Prix ordre
#                  - A alimenter si entrée diverse,déclaration production
#                                   réception(normale,sous-traitance)
#                  Type mouvement : [M:STW]TRSTYP = 1,5,3,16)
#                  - A alimenter si retour livraison(normale,prêt,sous-traitance)
#                                   réintégration de stock
#                                   sans pièce d'origine
#                  Type mouvement : [M:STW]TRSTYP = 12,18,33,19)
#                  - A alimenter si transfert inter-sites
#                  Type mouvement : [M:STW]TRSTYP = 14 (si BETCPY=2)
#                -------------------------------------------------------
#                [M:STW]PRIPUR    = Dernier prix d'achat
#                  - A alimenter si réception
#                  Type mouvement : [M:STW]TRSTYP = 3
#                -------------------------------------------------------
#                [M:STW]SEQ       = No séquence du mouvement à régulariser
#                  - A alimenter si régul mouvement en attente
#                  Origine données: LORI = 6
#                                 = No séquence de l'allocation à traiter
#                  - A alimenter si réappro emplacemt en mode terminaux portables
#                    ou changement emplacement suite à une pesée (spécifique)
#                  Origine données: LORI = 11
#                -------------------------------------------------------
#                [M:STW]STOCOU(0) = Chrono stock allocation
#                  - A alimenter si réappro emplacemt en mode terminaux portables
#                    ou changement emplacement suite à une pesée (spécifique)
#                  Origine données: LORI = 11
#                -------------------------------------------------------
#                [M:STW]PIOQTY    = Quantité à consommer en priorité
#                  - A alimenter si mouvement interne avec changement emplacement
#                  Origine données: LORI = 7
#                  Type mouvement : [M:STW]TRSTYP = 7
#                  - A alimenter à 3 si bon préparation avec changement emplacement
#                  Origine données: LORI = 1
#                  Type mouvement : [M:STW]TRSTYP = 7 et [M:STW]VCRTYP = 3
#                -------------------------------------------------------
#                [M:STW]SEQALL    = No séquence allocation à consommer
#                  - A alimenter si réapprovisionnement emplacement
#                    à partir d'une allocation détaillée où d'une rupture
#                  Origine données: LORI = 1 ou 3
#                  Type mouvement : [M:STW]TRSTYP = 25
#                  Type pièce     : [M:STW]VCRTYP = 34
#                -------------------------------------------------------
#                [M:STW]BPSFCY    = Propriétaire du stock (site ou fournisseur)
#                  - A alimenter si réception d'un article de sous-traitance
#                    venant d'un autre site (inter-société) ou d'un fournisseur
#                  Origine données: LORI = 2 ou 4
#                  Type mouvement : [M:STW]TRSTYP = 16
#                  Type pièce     : [M:STW]VCRTYP = 6
#                -------------------------------------------------------
#                [M:STW]UPDPRI    = Type de prix : 1=Calculé 2=Saisi
#                  - A alimenter si réception, entrée diverse ou assemblage pour savoir
#                    s'il est nécessaire de recalculer les FG
#
########################################################################
Subprog ALISTOWORK(LORI,LLIG,LQTY,LSHT,LNBR,LNBJ,LRET)
Value    Integer LORI
Value    Integer LLIG
Variable Decimal LQTY
Variable Decimal LSHT
Variable Integer LNBR
Variable Integer LNBJ
Variable Integer LRET

Global   Integer GNOLIG    : # nolign-1 (pour accés aux sections ana origines)

Local    Date    SAVIPTDAT : SAVIPTDAT=[M:STW]IPTDAT : # à revoir par TS !!!
Local    Integer NOL, I, J, K, L, IL, WALI, WRET
Local    Integer WVCRTYP,WVCRTYPORI
Local    Char    WVCRNUM(GLONVCR),WVCRNUMORI(GLONVCR)
Local    Integer WVCRLIN,WVCRLINORI,WVCRSEQORI
Local    Char    WMVTDES(GLONDES)
Local    Char    WLOCREF(GLONEMP)
Local    Char    WSTOFCY(GLONFCY)
Local    Char    WLOCTYP(GLONTLO)
Local    Char    WLOTCPT(GLONLOT), WLOTCOU(GLONANM)
Local    Char    WABRLOT(GLONLOT)
Local    Integer WNBSERIE
Local    Decimal WQTY, WQTA
Local    Char    WABR(8)
Local    Char    WCRIT(150), WCRIT1(250)
Local    Integer WESSAI, SVGNOLIGN, WNB
Local    Decimal LSTOCOU
Local    Decimal LWIPQTY
Local    Integer WFIRSTANA
Local    Char    SECTION
Local    Char    WCCE1(GLONCCE), WCCE2(GLONCCE), WCCE3(GLONCCE)
Local    Char    WCCE4(GLONCCE), WCCE5(GLONCCE), WCCE6(GLONCCE)
Local    Char    WCCE7(GLONCCE), WCCE8(GLONCCE), WCCE9(GLONCCE)
Local    Char    WCCE10(GLONCCE),WCCE11(GLONCCE),WCCE12(GLONCCE)
Local    Char    WCCE13(GLONCCE),WCCE14(GLONCCE),WCCE15(GLONCCE)
Local    Char    WCCE16(GLONCCE),WCCE17(GLONCCE),WCCE18(GLONCCE)
Local    Char    WCCE19(GLONCCE),WCCE20(GLONCCE)
Local    Integer ACTSTW, WMOD, WDEL
Local    Integer WNEGSTO, WLOTLU
Local    Integer INDLOT
Local    Char    WLOTLOT(GLONLOT)(120,2)
Local    Char    WBPRNUM(GLONBPR)
Local    Char    WBPAADD(GLONBPD)
Local    Char    BID              : #--- Bug 66873
Local    Integer WLOCCATDES       : #--- Issue X3-53322

SVGNOLIGN = nolign
GNOLIG    = nolign-1

# Si facture livraison de prêt, cette zone contient la qté à traiter
# Si chgt emp suite à une pesée (spécifique), elle contient la qté pesée
If LORI<>10 & (LORI<>11 | [M:STW]VCRTYP<>10)
   Raz LQTY
Endif
Raz LSHT,LNBR,LNBJ,LRET
# Lien avec ligne document non renseigné
# et origine STOENTW, STOSORW ou STOCHGW (mais pas annulation trf inter-site)
If LLIG=0 & (find(LORI,2,3) | LORI=7 & ([M:STW]TRSTYP<>14 | [M:SGW]NBLIG<>0))
   GMESSAGE = mess(375,199,1) : Gosub TRT_ERR
   LRET=1 : Goto ALISTW_FIN
Endif

# Liv prêt, s-traitance ou réappro, chgt emp (BP) et empl destination non renseigné
If (find([M:STW]TRSTYP,17,20) | (LORI=1 & find([M:STW]TRSTYP,7,25))) & [M:STW]LOCENT=""
   GMESSAGE=[M:STW]STOFCY-[M:STW]ITMREF-mess(379,199,1) : Gosub TRT_ERR
   LRET=2 : Goto ALISTW_FIN
Endif

# Réception sous-traitance et propriétaire du stock non renseigné
If [M:STW]TRSTYP=16 & [M:STW]BPSFCY=""
   GMESSAGE=[M:STW]STOFCY-[M:STW]ITMREF-mess(516,199,1) : Gosub TRT_ERR
   LRET=7 : Goto ALISTW_FIN
Endif
# Contrôle date d'imputation
Call STKCTRIPT([M:STW]IPTDAT,[M:STW]STOFCY,"1") From STKLIB
If GERR=1
   Gosub TRT_ERR
   LRET=1 : Goto ALISTW_FIN
Elsif GERR=2
   Gosub TRT_MSG
Endif

Default Mask [STW]

If !clalev([F:TCA])  Local File TABCOUAFF  [TCA]  Endif
If !clalev([F:STJ])  Local File STOJOU     [STJ]  Endif
If !clalev([F:STO])  Local File STOCK      [STO]  Endif
If !clalev([F:STL])  Local File STOLOT     [STL]  Endif
If !clalev([F:STC])  Local File STOLOC     [STC]  Endif
If !clalev([F:QLH])  Local File STOQLYH    [QLH]  Endif
If !clalev([F:TLO])  Local File TABLOCTYP  [TLO]  Endif
If !clalev([F:ITF])  Local File ITMFACILIT [ITF]  Endif
If !clalev([F:SWW])  Local File STOWIPW    [SWW]  Endif
If !clalev([F:ACV])  Local File ACTIV      [ACV]  Endif

Read [ACV]CODACT="STW"
If !fstat ACTSTW=[F:ACV]DIME Endif
If ACTSTW = 0
   GMESSAGE = mess(339,199,1)-'STW' : Gosub TRT_ERR
   LRET=4 : Goto ALISTW_FIN
Endif

WVCRTYP    = [M:STW]VCRTYP
WVCRNUM    = [M:STW]VCRNUM
WVCRLIN    = [M:STW]VCRLIN
WVCRTYPORI = [M:STW]VCRTYPORI
WVCRNUMORI = [M:STW]VCRNUMORI
WVCRLINORI = [M:STW]VCRLINORI
WVCRSEQORI = [M:STW]VCRSEQORI
WMVTDES    = [M:STW]MVTDES
WBPRNUM    = [M:STW]BPRNUM
WBPAADD    = [M:STW]BPAADD

If [F:ITM]ITMREF<>[M:STW]ITMREF
   Read [ITM]ITM0=[M:STW]ITMREF
   If fstat
      Call RSTA("ITM",[M:STW]ITMREF) From GLOCK
      GOK=0 : LRET=51 : Goto ALISTW_FIN
   Endif
Endif
If [F:ITF]ITMREF<>[M:STW]ITMREF | [F:ITF]STOFCY<>[M:STW]STOFCY
   Read [ITF]ITF0=[M:STW]ITMREF;[M:STW]STOFCY
   If fstat
      Call RSTA("ITF",[M:STW]ITMREF-[M:STW]STOFCY) From GLOCK
      GOK=0 : LRET=52 : Goto ALISTW_FIN
   Elsif [F:ITF]STOMGTCOD=1
      GMESSAGE = [M:STW]ITMREF-":"-mess(147,199,1) : Gosub TRT_ERR
      LRET=11 : Goto ALISTW_FIN
   Endif
Endif

WNEGSTO = [F:ITM]NEGSTO

#Effzo [M:STW]10
#Effzo [M:STW]15
Raz [M:STW]NBLIG
Raz [M:STW]AAAQTY, [M:STW]QQQQTY, [M:STW]RRRQTY, [M:STW]ISSAMTVAL
#--- Issue 107223 : raz des principales zones
Raz [M:STW]TRSTYPLIG, [M:STW]ITMREFLIG,[M:STW]MVTSEQ, [M:STW]MVTIND, [M:STW]CSTDAT, [M:STW]CSTTIM, [M:STW]CSTCOU           # hcb 110168
Raz [M:STW]STU, [M:STW]PCU, [M:STW]QTYSTU, [M:STW]QTYSTUACT, [M:STW]QTYPCU, [M:STW]PRIORD, [M:STW]PRIVAL, [M:STW]PRINAT
Raz [M:STW]LOT, [M:STW]SLO, [M:STW]BPSLOT, [M:STW]STA, [M:STW]LOC, [M:STW]LOCDES, [M:STW]SERNUM, [M:STW]SERNUMF, [M:STW]PALNUM, [M:STW]CTRNUM
Raz [M:STW]MAJTYP, [M:STW]MAJCOD, [M:STW]QLYCTLDEM, [M:STW]QLYCTLFLG
Raz [M:STW]LPNNUM   : #--- Issue X3-53322
#---
# hcb 110168 deb
If LORI <> 11
   Raz [M:STW]STOCOU
Endif
# hcb 110168 deb

Raz nolign

#---------------------------------------------------------------
# Types mouvements traités (TRSTYP) et règle de gestion appliqué
#---------------------------------------------------------------
#  1 = Entrée diverse                   (traité : règle  1)
#  2 = Sortie diverse                   (traité : règle  2)
#  3 = Réception fournisseur            (traité : règle  3)
#  4 = Livraison client                 (traité : règle  4)
#  5 = Déclaration production           (traité : règle  5)
#  6 = Sortie OF                        (traité : règle  6 ou 29)
#  7 = Changement emplacement           (traité : règle 26 ou 27 et 28)
#  8 = Contrôle qualité                 (traité : règle  8)
#  9 = Changement de statut             (traité : règle 26)
# 10 = Réception transfert inter-sites  (inactif)
# 11 = Retour réception                 (traité : règle 11)
# 12 = Retour livraison                 (traité : règle 12)
# 13 = Inventaires                      (traité)
# 14 = Transfert inter-sites            (traité : règle 27 et 28)
# 15 = Transfert sous-traitance         (inactif)
# 16 = Réception sous-traitance         (traité : règle 16)
# 17 = Livraison prêt                   (traité : règle 17)
# 18 = Retour livraison prêt            (traité : règle 18)
# 19 = Réintégration stock              (traité : règle 19)
# 20 = Livraison sous-traitance         (traité : règle 20)
# 21 = Refractionnement                 (traité : règle 26)
# 22 = Plan rangement                   (traité : règle mvt origine)
# 23 = Changement de valeur             (N/A)
# 24 = Demande de service               (traité : règle 24)
# 25 = Réapprovisionnement              (traité : règle 25)
# 26 = Changement de stock              (N/A)
# 27 = Sortie transfert interne         (N/A)
# 28 = Entrée transfert interne         (N/A)
# 29 = Sortie ordre sous-traitance      (traité : règle 29)
# 30 = Réception prêt                   (inactif)
# 31 = Retour réception prêt            (inactif)
# 32 = Retour réception sous-traitance  (traité : règle 32)
# 33 = Retour livraison sous-traitance  (traité : règle 33)
# 34 = Demande d'analyse                (traité)
# 35 = Régularisation valeur stock      (N/A)
# 36 = Changement identifiant contenant (traité)

#---------------------------------------------------------------
# Types de mouvements (TRSTYP) concernés en fonction de LORI
#---------------------------------------------------------------
# Origine Table  STOALL
#         Ecrans STOSORW, STOSORM, STKSHTREG
# 1,3,5,6 ou 11 --> Sorties   : Sortie diverse                (2)
#                               Livraison/Facture             (4)
#                               Sortie OF                     (6)
#                               Sortie Ordre sous-traitance  (29)
#                               Demande de services          (24)
#               --> Chg emp   : Livraison prêt               (17)
#                               Livraison sous-traitance     (20)
#                               Réapprovisionnement          (25)
#                               Chgt emplacement (origine BP) (7)
#                               Chgt emplacement (origine OF) (7)
#                                          (spécifique pesée)
#               --> Entrées - : Retour réception             (11)
#                             : Retour réception s-traitance (32)
#---------------------------------------------------------------
# Origine Ecrans STOENTW, STOENTM
# 2 ou 4        --> Entrées   : Entrée diverse                (1)
#                               Réception fournisseur         (3)
#                               Réception sous-traitance     (16)
#                               Déclaration production        (5)
#               --> Chg emp   : Retour prêt                  (18)
#                               Retour livraison s-traitance (33)
#               --> Sorties - : Retour/Avoir client          (12)
#                               Réintégration stock          (19)
#---------------------------------------------------------------
# Origine Ecran  STOENTW
# 2             --> Chg emp   : Plan de rangement            (22)
# 9             --> Entrées   : Déclaration production        (5)
#---------------------------------------------------------------
# Origine Ecran  STOCHGW
# 7             --> Chg emp   : Changement emplacement        (7)
#                             & transfert ou retour sous-traitant
#                               Contrôle qualité              (8)
#                               Changement statut             (9)
#                               Transfert inter-sites        (14)
#                               Refractionnement             (21)
#                               Chgt identifiant contenant   (36)
#---------------------------------------------------------------
# Origine Table  CUNLISDET
# 8             --> Entrées   : Inventaire                   (13)
#               --> Sorties   : Inventaire                   (13)
#---------------------------------------------------------------
# Origine Table  STOJOU
# 10            --> Sorties   : Facture livraison de prêt     (4)
#---------------------------------------------------------------
# Origine Ecran  QCR1
# 12            --> Chgt emp  : Demande d'analyse            (34)
#---------------------------------------------------------------

[M:STW]MAJCODH = "C"
Raz WFIRSTANA

GPOINT="BEFORE_STW" : Gosub ENTREE From EXEFNC
Case LORI
 When  1,11 : Gosub ORI_STOALL
 When  2, 9 : WABR = "[M:ENTW]"
              Gosub ORI_STOENTW
 When  3    : WABR = "[M:SOW]"
              Gosub ORI_STOSORW
 When  4    : WABR = "[M:ENM]"
              Gosub ORI_STOENTM
 When  5    : WABR = "[M:SOM]"
              Gosub ORI_STOSORM
 When  6    : Gosub ORI_STKSHTREG
 When  7    : Gosub ORI_STOCHGW
 When  8    : Gosub ORI_CUNLISDET
 When 10    : Gosub ORI_STOJOU
 When 12    : Gosub ORI_QCR1
Endcase

If LRET<>0 Goto ALISTW_FIN Endif

[M:STW]VCRTYP    = WVCRTYP
[M:STW]VCRNUM    = WVCRNUM
[M:STW]VCRLIN    = WVCRLIN
[M:STW]VCRTYPORI = WVCRTYPORI
[M:STW]VCRNUMORI = WVCRNUMORI
[M:STW]VCRLINORI = WVCRLINORI
[M:STW]VCRSEQORI = WVCRSEQORI
[M:STW]MVTDES    = WMVTDES
[M:STW]BPRNUM    = WBPRNUM
[M:STW]BPAADD    = WBPAADD

Gosub ALIVALWORK From STKVALMAJ
If LRET<>0 Goto ALISTW_FIN Endif

$ALISTW_FIN

nolign = SVGNOLIGN
Raz GMESSAGE

# Car elle est cassée par les inventaires
[M:STW]IPTDAT=SAVIPTDAT

End

########################################################################
# Alimentation de STOWORK à partir des allocations STOALL
########################################################################
$ORI_STOALL
Local Char   CRITERE(150)

If clalev([F:STA])=0  Local File STOALL     [STA]  Endif

# Si plan de réapprovisionnement, on filtre sur SRGNUM et SRGLIN
If WVCRTYP=34
   CRITERE = 'STOFCY=[M:STW]STOFCY & ITMREF=[M:STW]ITMREF'
   # Si réappro emplacement en mode terminaux portables,
   # on ne traite qu'une allocation à la fois
   If LORI=11
      CRITERE += '& STOCOU=[M:STW]STOCOU(0) & SEQ=[M:STW]SEQ'
   Endif
   #--- Bug 68777
   #CRITERE += '& SRGNUM=WVCRNUM & SRGLIN=WVCRLIN'
   CRITERE += '& SRGNUM=WVCRNUM & SRGLIN=WVCRLIN & ALLTYP=2'
   #---
   For [STA]STA0 Where evalue(CRITERE)
      # Si réapprovisionnement d'une allocation déjà existante, il faudra
      # la consommer en priorité
      If [F:STA]VCRNUM<>[F:STA]SRGNUM | [F:STA]VCRLIN<>[F:STA]SRGLIN
         [M:STW]PIOQTY=3
      Else
         [M:STW]PIOQTY=1
      Endif
      # Chargement d'une allocation
      Gosub CHARGE_STA_STW
      If LRET<>0 Break Endif
   Next
# Si changement emplacement suite à une pesée (spécifique)
# il n'y a qu'une allocation à traiter
Elsif WVCRTYP=10 & LORI=11
   For [STA]STA0 Where STOFCY=[M:STW]STOFCY & ITMREF=[M:STW]ITMREF &
&                      STOCOU=[M:STW]STOCOU(0) & SEQ=[M:STW]SEQ
      # Chargement d'une allocation
      Gosub CHARGE_STA_STW
      If LRET<>0 Break Endif
   Next
Else
   For [STA]STA2 Where ITMREF=[M:STW]ITMREF & VCRTYP=WVCRTYP &
&                      VCRNUM=WVCRNUM & VCRLIN=WVCRLIN
      # Chargement d'une allocation
      Gosub CHARGE_STA_STW
      If LRET<>0 Break Endif
   Next
Endif

If LRET<>0
   GOK=0 : Return
Endif

Return

########################################################################
# Chargement d'une allocation pour génération d'un mouvement de sortie
########################################################################
$CHARGE_STA_STW
# Si alloc (manquant) globale ou transfert --> pas de traitement
If find([F:STA]ALLTYP,1,3,5,6) Return Endif

# Stockage des sections analytiques (la première fois)
If WFIRSTANA=0
   For J=1 To GNBDIE
#      GAXE=J
      Call INISEC(SECTION,[M:STW]CCECOD,J) From TRTX3CPT
      Assign "WCCE"+num$(J) With SECTION
   Next J
   WFIRSTANA+=1
Endif

nolign += 1
NOL     = nolign-1

If NOL >= ACTSTW
   GMESSAGE =  mess(490,199,1) : Gosub TRT_ERR
   LRET=4 : Return
Endif

# Si alloc détaillée
If [F:STA]ALLTYP=2
   # Lecture du stock
   Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
   If fstat
      Call RSTA("STO",[F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)) From GLOCK
      LRET=54 : Return
   # Emplacement bloqué pour inventaire
   Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
      If [F:ITF]LOCMGTCOD=2
         GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
      Else
         GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
      Endif
      Gosub TRT_ERR
      LRET=21 : Return
   # Emplacement en attente de rangement
   Elsif [F:STO]LOCCAT=2
      # Contrôle que les lignes de stock en attente de rangement sont complètes
      Call CTLPLFLOC([M:STW]ITMREF,"",LRET) From STKSOR
      If LRET<>0
         GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
         GMESSAGE+="\"+mess(377,199,1)-":"
         Case LRET
          When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
          When 2 : GMESSAGE+=mess(453,197,1)
          When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
         Endcase
         Gosub TRT_ERR
         LRET=22 : Return
      Endif
   Endif

   If WMVTDES="" & [F:STA]MVTDES<>""
      WMVTDES=[F:STA]MVTDES
   Endif

   [M:STW] = [F:STA]
   [M:STW] = [F:STO]

   #--- Issue 110327
   # Si série géré en sortie ou E/S global, rechargement no série
   #If [F:ITM]SERMGTCOD=2 & [F:STA]SERNUM<>""
   If find([F:ITM]SERMGTCOD,2,4) & [F:STA]SERNUM<>""
   #---
      [M:STW]SERNUM(NOL)=[F:STA]SERNUM
   Endif

   # Lecture du lot
   Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
   If fstat
      Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
      LRET=53 : Return
   Endif
   [M:STW] = [F:STL]

   # Si réapprovisionnement sur allocation existante,
   # la quantité à traiter est dans SRGQTYSTU
   If WVCRTYP=34 & [M:STW]PIOQTY=3
      [M:STW]QTYSTU(NOL)    = [F:STA]SRGQTYSTU
      [M:STW]QTYSTUACT(NOL) = [F:STA]SRGQTYSTU
      # Si gestion en titres ou UI, calcul quantité en UA
      Case [F:ITF]STOMGTCOD
       When 3 : If [M:STW]POT(NOL)<>0
                   [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)*([M:STW]POT(NOL)/100)
                Endif
       When 4 : If [M:STW]ACT(NOL)<>0
                   [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)* [M:STW]ACT
                Endif
      Endcase
   # Si changement d'emplacement (spécifique pesée),
   # la quantité à traiter est la quantité pesée (LQTY)
   Elsif WVCRTYP=10 & LORI=11
      [M:STW]QTYSTU(NOL)    = LQTY
      [M:STW]QTYSTUACT(NOL) = LQTY
      # Si gestion en titres ou UI, calcul quantité en UA
      Case [F:ITF]STOMGTCOD
       When 3 : If [M:STW]POT(NOL)<>0
                   [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)*([M:STW]POT(NOL)/100)
                Endif
       When 4 : If [M:STW]ACT(NOL)<>0
                   [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)* [M:STW]ACT
                Endif
      Endcase
   Else
      [M:STW]QTYSTU(NOL)    = [F:STA]QTYSTU
      [M:STW]QTYSTUACT(NOL) = [F:STA]QTYSTUACT
   Endif
   [M:STW]WAIFLG(NOL) = 0
# Si alloc manquant détail --> mouvement en attente
Elsif [F:STA]ALLTYP=4
   # Stock négatif interdit
   If WNEGSTO<>2
      GMESSAGE =[F:STA]STOFCY-[F:STA]ITMREF-":"-mess(184,192,1)
      Gosub TRT_ERR
      LRET=12 : Return
   Endif

   [M:STW] = [F:STA]

   [M:STW]WAIFLG(NOL) = 1
   # Chargement emplacement rupture
   If [F:STA]LOC<>""
      WLOCREF=[F:STA]LOC
      WALI=0
      Gosub LEC_STOLOC
   Endif
Endif

# Si no série saisi (géré en sortie, E/S global ou rupture)    : #--- Issue 110327
# Alimentation du no série fin
If [M:STW]SERNUM(NOL)<>""
   WNB = [M:STW]QTYSTUACT(NOL)
   If WNB = 1
      [M:STW]SERNUMF(NOL) = [M:STW]SERNUM(NOL)
   Else
      Call PLUS_NB([M:STW]SERNUM(NOL),WNB,[M:STW]SERNUMF(NOL),WRET) From STKLIB
      If WRET<>0
         Raz [M:STW]SERNUM(NOL), [M:STW]SERNUMF(NOL)
      Endif
   Endif
Endif

[M:STW]STU(NOL)       = [F:ITM]STU
[M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
[M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
[M:STW]MAJCOD(NOL)    = "C"
Case [M:STW]TRSTYP
 When 4,24,2,6,29 : [M:STW]MAJTYP(NOL)="S"   : # Liv/Fac, Dem Serv, Sortie Div,OF,Ordre s-trait
 When 7,17,20,25  : [M:STW]MAJTYP(NOL)="C"   : # Chgt emp (BP), Liv prêt, Liv s-trait, Réappro zones conso
                    Raz [M:STW]LPNNUM(NOL)   : # Issue X3-53322 un changement d'emp impose un raz du LPN
 When 11,32       : [M:STW]MAJTYP(NOL)="E"   : # Retour fou, Retour rec s-trait
                    [M:STW]QTYSTU(NOL)    = [M:STW]QTYSTU(NOL)*(-1)
                    [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTUACT(NOL)*(-1)
Endcase

# Attention si mvt en attente, les zones QTYSTU et QTYPCU sont nulles
If [M:STW]PCUSTUCOE(NOL)=0 [M:STW]PCUSTUCOE(NOL)=1 Endif
[M:STW]QTYPCU(NOL)=[M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV

# Recherche des prix ordre et prix valorisé du mouvement origine
# si retour fournisseur (sous-traitance)
If find([M:STW]TRSTYP,11,32) &
&  [M:STW]VCRTYPORI<>0 & [M:STW]VCRNUMORI<>"" & [M:STW]VCRLINORI<>0
   Gosub RECH_STJ_PRI
Endif

# Alimentation des sections analytiques
For J=1 To GNBDIE
   Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("WCCE"+num$(J))
Next J

# Chargement emplacement destination
Case [M:STW]TRSTYP
 When 17   : WLOCREF=[M:STW]LOCENT            : # Liv prêt
             WALI=1
             Gosub LEC_STOLOC
             If LRET<>0 Return Endif
             If [F:STC]LOCCAT<>3
                GMESSAGE = [M:STW]LOCDES-":"-mess(243,192,1) : Gosub TRT_ERR
                LRET=24 : Return
             Endif
 When 20   : WLOCREF=[M:STW]LOCENT            : # Liv sous-traitance
             WALI=1
             Gosub LEC_STOLOC
             If LRET<>0 Return Endif
             If [F:STC]LOCCAT<>4
                GMESSAGE = [M:STW]LOCDES-":"-mess(244,192,1) : Gosub TRT_ERR
                LRET=23 : Return
             Endif
 When 7,25 : WLOCREF=[M:STW]LOCENT            : # Chgt emp (BP), Réappro zones de conso
             WALI=1
             Gosub LEC_STOLOC
             If LRET<>0 Return Endif
Endcase

# Si changement d'emplacement (origine BP), alimentation du no séquence
# de l'allocation pour la faire suivre sur la ligne de stock (emp destination)
If [M:STW]TRSTYP=7
   [M:STW]MVTSEQ(NOL)=[F:STA]SEQ
Endif

[M:STW]NBLIG += 1

If [F:STA]ALLTYP=2
   LQTY += abs([M:STW]QTYSTUACT(NOL))
Elsif [F:STA]ALLTYP=4
   LSHT += abs([M:STW]QTYSTUACT(NOL))
Endif

#--- Dem 60995
# Transfert zones de l'enregistrement STOALL vers l'écran STOWORK
GPOINT="STA_STW" : Gosub ENTREE From EXEFNC

#--- Bug 71421
# Si sortie d'un mvt attente avec no série géré en sortie ou en E/S global: #--- Issue 110327
# alors création d'un STW par no série pour la régularisation des mouvements
Gosub SER_STW
If LRET Return Endif
#---

# Si réapprovisionnement sur allocation existante
If WVCRTYP=34 & [M:STW]PIOQTY=3
   Raz[F:STA]SRGNUM, [F:STA]SRGLIN, [F:STA]SRGQTYSTU, [F:STA]SRGLOC
   Call REWSTA From STKLIB
   If fstat
      Call FSTA("STA") From GLOCK
      LRET=67 : Return
   Endif
# Sinon si pas changement d'emplacement (sur Bon préparation)
Elsif [M:STW]TRSTYP<>7
   # Suppression allocation
   Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[F:STA]SEQ,LRET) From STKALL
   If LRET<>0 : LRET=67 : Return : Endif
Endif

Return

########################################################################
# Alimentation de STOWORK avec l'écran de stockage des entrées STOENTW
########################################################################
$ORI_STOENTW

#--- Issue X3-53322
# Si type de mouvement <> plan de rangement
# Si article site avec gestion de contenants,
# splittage des STOENTW selon la capacité du contenant et création des LPN
If [M:STW]TRSTYP<>22
  If [F:ITF]LPNMGTCOD=2
    Call SPLIT_ENTW_LPN (LLIG)
    If GOK=0
      LRET=80 : Return
    Endif
  Endif
Endif
#---

#--- Issue 105775
If [M:STW]TRSTYP=33 & [M:STW]VCRTYPORI=4 & [M:STW]VCRNUMORI<>""
   If clalev([F:STA])=0  Local File STOALL     [STA]  Endif
   If clalev([F:SDD])=0  Local File SDELIVERYD [SDD]  Endif
   Read [SDD]SDD0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI
   If fstat Raz [F:SDD] Endif
Endif
#---

Raz WLOTCPT

# Alimentation de [STW] pour effectuer les entrées, changement d'emplacement
# ou sorties négatives
For I=0 To [M:ENTW]NBLIG-1
   # La ligne de l'écran de travail ne concerne pas cette ligne de document
   If [M:ENTW]WSTOSEQ(I)<>LLIG Goto ORI_STOENTW2 Endif

   #--- Issue 92263
   # Stockage des sections analytiques (la première fois)
   #If WFIRSTANA=0
   #   L=find(LLIG,[M:ENTW]WSTOSEQ2(0..[M:ENTW]NBLIG2-1))
   #   If L<>0
   #      For J=1 To GNBDIE
   #         Assign "WCCE"+num$(J) With evalue("[M:ENTW]CCE"+num$(J)+"(L-1)")
   #      Next J
   #   Endif
   #   For J=1 To GNBDIE
   #      If evalue("WCCE"+num$(J))=""
   #         Call INISEC(SECTION,[M:STW]CCECOD,J) From TRTX3CPT
   #         Assign "WCCE"+num$(J) With SECTION
   #      Endif
   #   Next J
   #   WFIRSTANA+=1
   #Endif
   #---

   nolign += 1
   NOL     = nolign-1

   If NOL >= ACTSTW
      GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
      LRET=4 : Break
   Endif

   #--- Issue 92263
   # Stockage des sections analytiques (la première fois)
   If WFIRSTANA=0
      Call STKINISEC (LLIG,[M:STW]CCECOD,"ENTW") From STKECR
      L=find(LLIG,[M:ENTW]WSTOSEQ2(0..[M:ENTW]NBLIG2-1))
      If L<>0
         For J=1 To GNBDIE
            Assign "WCCE"+num$(J) With evalue("[M:ENTW]CCE"+num$(J)+"(L-1)")
         Next J
      Endif
      WFIRSTANA+=1
   Endif
   #---

   # Retour de prêt,de livraison sous-traitance ou Plan de rangement
   If find([M:STW]TRSTYP,18,33,22)
      # Si chrono stock origine non renseigné
      If [M:ENTW]STOCOU(I)=0
         GMESSAGE=[M:STW]STOFCY-[M:STW]ITMREF-mess(380,199,1) : Gosub TRT_ERR
         LRET=3 : Break
      # Si emplacement destination non renseigné
      Elsif [M:ENTW]LOC(I)=""
         GMESSAGE=[M:STW]STOFCY-[M:STW]ITMREF-mess(379,199,1) : Gosub TRT_ERR
         LRET=2 : Break
      Endif
   Endif

   #--- Issue 105775
   # Si retour livraison sous-traitance, suppression des allocations
   # de l'ordre de sous-traitance pour le stock retourné
   If [M:STW]TRSTYP=33 & [M:STW]VCRTYPORI=4 & [M:STW]VCRNUMORI<>""
      If [F:SDD]VCRTYPORI=36 & [F:SDD]VCRNUMORI<>""
         WQTY=[M:ENTW]QTYSTU(I)
         WRET=0
         For [STA]STA1 Where VCRTYP=[F:SDD]VCRTYPORI & VCRNUM=[F:SDD]VCRNUMORI &
&                            VCRLIN=[F:SDD]VCRLINORI & VCRSEQ=[F:SDD]VCRSEQORI &
&                            STOCOU=[M:ENTW]STOCOU(I)
            If WQTY>=[F:STA]QTYSTU
               Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[STA]SEQ,WRET) From STKALL
               If WRET=0 WQTY-=[F:STA]QTYSTU Endif
            Else
               Call MODALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[STA]SEQ,-WQTY,WRET) From STKALL
               If WRET=0 WQTY=0 Endif
            Endif
            If WQTY<=0 Break Endif
         Next
      Endif
   Endif
   #---

   Gosub CHARGE_ENT_STW
   If LRET<>0 Break Endif

   [M:STW]NBLIG += 1

$ORI_STOENTW2
Next I

If LRET<>0
   GOK=0 : Return
Endif

Return

########################################################################
# Alimentation de STOWORK avec l'écran de stockage des sorties STOSORW
########################################################################
$ORI_STOSORW

# Alimentation de [STW] pour effectuer les sorties, changement d'emplacement
# ou entrées négatives
For I=0 To [M:SOW]NBLIG-1
   # La ligne de l'écran de travail ne concerne pas cette ligne de document
   If [M:SOW]WSTOSEQ(I)<>LLIG Goto ORI_STOSORW1 Endif

   #--- Issue 92263
   # Stockage des sections analytiques (la première fois)
   #If WFIRSTANA=0
   #   L=find(LLIG,[M:SOW]WSTOSEQ2(0..[M:SOW]NBLIG2-1))
   #   If L<>0
   #      For J=1 To GNBDIE
   #         Assign "WCCE"+num$(J) With evalue("[M:SOW]CCE"+num$(J)+"(L-1)")
   #      Next J
   #   Endif
   #   For J=1 To GNBDIE
   #      If evalue("WCCE"+num$(J))=""
   #         Call INISEC(SECTION,[M:STW]CCECOD,J) From TRTX3CPT
   #         Assign "WCCE"+num$(J) With SECTION
   #      Endif
   #   Next J
   #   WFIRSTANA+=1
   #Endif
   #---

   nolign += 1
   NOL     = nolign-1

   If NOL >= ACTSTW
      GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
      LRET=4 : Break
   Endif

   #--- Issue 92263
   # Stockage des sections analytiques (la première fois)
   If WFIRSTANA=0
      Call STKINISEC (LLIG,[M:STW]CCECOD,"SOW") From STKECR
      L=find(LLIG,[M:SOW]WSTOSEQ2(0..[M:SOW]NBLIG2-1))
      If L<>0
         For J=1 To GNBDIE
            Assign "WCCE"+num$(J) With evalue("[M:SOW]CCE"+num$(J)+"(L-1)")
         Next J
      Endif
      WFIRSTANA+=1
   Endif
   #---

   Gosub CHARGE_SOR_STW
   If LRET<>0 Break Endif

   [M:STW]NBLIG += 1

$ORI_STOSORW1
Next I

If LRET<>0
   GOK=0 : Return
Endif

Return

########################################################################
# Alimentation de STOWORK avec l'écran de modification des entrées STOENTM
########################################################################
$ORI_STOENTM

#--- PE 66999
Local Char ZONSPE  : ZONSPE="ZZZZZZZZ"
GPOINT="ALI_ZONSPE" : Gosub ENTREE From EXEFNC
#---

#--- Bug 72471
If find([M:STW]TRSTYP,12,33)
   If !clalev([F:SRD]) Local File SRETURND [SRD] Endif
   Read [SRD]SRD0 = [M:STW]VCRNUM;[M:STW]VCRLIN
   If [F:SRD]PNHNUM(NOL) <> ""
      [M:STW]VCRTYPORI2 = 8
      [M:STW]VCRNUMORI2 = [F:SRD]PNHNUM
      [M:STW]VCRLINORI2 = [F:SRD]PNDLIN
   Else
      [M:STW]VCRTYPORI2 = 0
      [M:STW]VCRNUMORI2 = ""
      [M:STW]VCRLINORI2 = 0
   Endif
Endif
#---

If !clalev([F:STJ1])  Local File STOJOU    [STJ1]  Endif

#--- Issue 110327
# Traitement des nouvelles lignes
#---------------------------------
#For I=0 To [M:ENM]NBLIG-1
#   # C'est une nouvelle ligne
#   If [M:ENM]MVTSEQ(I)=0
#      Gosub CRE_ENM_STW
#      If LRET<>0 Break Endif
#   Endif
#Next I
#If LRET<>0
#   GOK=0 : Return
#Endif
#--- End issue 110327

# Traitement des lignes modifiées ou supprimées
#-----------------------------------------------
WCRIT  = 'STOFCY=[M:STW]STOFCY & VCRTYP=WVCRTYP & VCRNUM=WVCRNUM'
WCRIT += '& VCRLIN=WVCRLIN & REGFLG<>2 & ITMREF=[M:STW]ITMREF'
# Si retour de prêt ou de livraison sous-traitance,
# c'est le mvt positif (entrée) qui est la référence
If find([M:STW]TRSTYP,18,33)
   WCRIT += '& QTYSTU>0'
Endif

For [F:STJ]STJ1 Where evalue(WCRIT)
   Raz J

   $ORI_STOENTM2
   I=find([F:STJ]MVTSEQ,[M:ENM]MVTSEQ(J..[M:ENM]NBLIG-1))
   If I<>0
      K=[M:ENM]NUMLIGLOT(I-1)
   Endif
   If I=0
      # Annulation du mouvement
      Gosub ANN_ENM_STW
      If LRET<>0 Break Endif
      [L]WDEL=1
      # Le mouvement a t-il été modifié ?
# hcb 27200 : rajout dim sur PALNUM et CTRNUM
#--- Issue 110327
# Suppression de : &   | (dim([M:ENM]SERNUM)>0 & [F:STJ]SERNUM <>[M:ENM]SERNUM(I-1))
# Ajout de       : &   | ([F:ITM]SERMGTCOD<4 & dim([M:ENM]SERNUM)>0 & [F:STJ]SERNUM<>[M:ENM]SERNUM(I-1))
#                  &   | ([F:ITM]SERMGTCOD=4 & dim([M:ENM]SERNUM)>0 & [F:STJ]SERDEB<>[M:ENM]SERNUM(I-1))
#---
   Elsif [F:STJ]IPTDAT   = [M:ENM]IPTDAT(I-1)
&     & ([F:STJ]PCU      <>[M:ENM]PCU(I-1)
&      | [F:STJ]QTYPCU   <>[M:ENM]QTYPCU(I-1)
&      | [F:STJ]PCUSTUCOE<>[M:ENM]PCUSTUCOE(I-1)
&      | [F:STJ]STA      <>[M:ENM]STA(I-1)
&      | (K<>-1 & [F:STJ]LOT   <>[M:ENM]LOT(K))
&      | (K<>-1 & [F:STJ]SLO   <>[M:ENM]SLO(K))
&      | (K<>-1 & [F:STJ]BPSLOT<>[M:ENM]BPSLOT(K))
&      | (dim([M:ENM]LOC)>0    & [F:STJ]LOC   <>[M:ENM]LOC(I-1))
&      | ([F:ITM]SERMGTCOD<4 & dim([M:ENM]SERNUM)>0 & [F:STJ]SERNUM<>[M:ENM]SERNUM(I-1))
&      | ([F:ITM]SERMGTCOD=4 & dim([M:ENM]SERNUM)>0 & [F:STJ]SERDEB<>[M:ENM]SERNUM(I-1))
&      | (dim([M:ENM]PALNUM)>0 & [F:STJ]PALNUM<>[M:ENM]PALNUM(I-1))
&      | (dim([M:ENM]CTRNUM)>0 & [F:STJ]CTRNUM<>[M:ENM]CTRNUM(I-1))
&      | (dim([M:ENM]STOFLD1)>0& [F:STJ]STOFLD1<>[M:ENM]STOFLD1(I-1))
&      | (dim([M:ENM]STOFLD2)>0& [F:STJ]STOFLD2<>[M:ENM]STOFLD2(I-1))
&      | (evalue("dim([M:ENM]"+ZONSPE+")")>0 & evalue("dim([F:STJ]"+ZONSPE+")")>0
&        & (evalue("[M:ENM]"+ZONSPE+"(I-1)")<>evalue("[F:STJ]"+ZONSPE)))) : # PE 66999
      # Annulation de l'ancien mouvement
      Gosub ANN_ENM_STW
      If LRET<>0 Break Endif
      # Création du nouveau mouvement
      I-= 1
      Gosub CRE_ENM_STW
      If LRET<>0 Break Endif
      [L]WMOD=1
   Elsif [F:STJ]IPTDAT<>[M:ENM]IPTDAT(I-1) & I<[M:ENM]NBLIG
      J = I
      Goto ORI_STOENTM2
   Else
      [L]WMOD=1
   Endif

Next

#--- Issue 110327
#If LRET<>0 Return Endif
If LRET<>0 GOK=0 : Return Endif

# Traitement des nouvelles lignes
#---------------------------------
For I=0 To [M:ENM]NBLIG-1
   # C'est une nouvelle ligne
   If [M:ENM]MVTSEQ(I)=0
      Gosub CRE_ENM_STW
      If LRET<>0 Break Endif
   Endif
Next I
If LRET<>0
   GOK=0 : Return
Endif
#--- End issue 110327

If [L]WMOD=1
   [M:STW]MAJCODH = "M"
Elsif [L]WDEL=1
   [M:STW]MAJCODH = "A"
Endif

Return

########################################################################
# Alimentation de STOWORK avec l'écran de modif des sorties STOSORM
########################################################################
$ORI_STOSORM

If !clalev([F:STJ1])  Local File STOJOU    [STJ1]  Endif

# Traitement des lignes modifiées ou supprimées
#-----------------------------------------------
WCRIT  = 'STOFCY=[M:STW]STOFCY & VCRTYP=WVCRTYP & VCRNUM=WVCRNUM'
WCRIT += '& VCRLIN=WVCRLIN & REGFLG<>2 & ITMREF=[M:STW]ITMREF'
# Si liv prêt (17) ou liv s-trait (20)
# c'est le mvt négatif (sortie) qui est la référence
If find([M:STW]TRSTYP,17,20)
   WCRIT += '& QTYSTU<0'
Endif

#--- Issue 110327
# Article avec no série en sortie ou en E/S globale --> 2 boucles
# 1- Mouvements annulés
# 2- Mouvements modifiés suivi d'un tri sur chrono stock/code maj
# pour supprimer d'abord les no série devant être recréés
# ou pour réentréer d'abord les no série devant être ressortis
#If [M:SOM]SERMGTCOD=2
If find([M:SOM]SERMGTCOD,2,4)
#---
   # 1- Mouvements annulés
   For [F:STJ]STJ1 Where evalue(WCRIT)
      Raz J
      I=find([F:STJ]MVTSEQ,[M:SOM]MVTSEQ(J..[M:SOM]NBLIG-1))
      If I=0
         # Annulation du mouvement
         Gosub ANN_SOM_STW
         If LRET<>0 Break Endif
         [L]WDEL=1
      Endif
   Next
   If LRET<>0 Return Endif

   # 2- Mouvements modifiés
   For [F:STJ]STJ1 Where evalue(WCRIT)
      Raz J
      $ORI_STOSORM1
      I=find([F:STJ]MVTSEQ,[M:SOM]MVTSEQ(J..[M:SOM]NBLIG-1))
      If I=0
         # Déjà traité
         Goto ORI_STOSORM2
      # Le mouvement maj a t-il été modifié ?
      #--- Issue 110327
      #Elsif [F:STJ]UPDCOD=2 & [F:STJ]IPTDAT=[M:SOM]IPTDAT
#&        & (abs([F:STJ]QTYSTU)<>[M:SOM]QTYSTU(I-1)
#&         | (dim([M:SOM]SERNUM)>0 & [F:STJ]SERNUM<>[M:SOM]SERNUM(I-1)))
      Elsif [F:STJ]UPDCOD=2 & [F:STJ]IPTDAT=[M:SOM]IPTDAT
         If ([M:SOM]SERMGTCOD=2
&            & (abs([F:STJ]QTYSTU)<>[M:SOM]QTYSTU(I-1)
&              | (dim([M:SOM]SERNUM)>0 & [F:STJ]SERNUM<>[M:SOM]SERNUM(I-1))))
&         | ([M:SOM]SERMGTCOD=4
&            & (abs([F:STJ]QTYSTU)<>[M:SOM]QTYSTU(I-1)
&              | (dim([M:SOM]SERNUM)>0 & [F:STJ]SERDEB<>[M:SOM]SERNUM(I-1))))
      #--- End issue 110327
            # Annulation de l'ancien mouvement
            Gosub ANN_SOM_STW
            If LRET<>0 Break Endif
            # Création du nouveau mouvement
            I-= 1
            Gosub CRE_SOM_STW
            If LRET<>0 Break Endif
            [L]WMOD=1
         #--- Issue 110327
         Endif
      # Le mouvement en attente a t-il été modifié ?
      Elsif [F:STJ]UPDCOD=1 & [F:STJ]IPTDAT=[M:SOM]IPTDAT
&        & (abs([F:STJ]QTYSTU)<>[M:SOM]QTYSTU(I-1)
&         | [F:STJ]STA        <>[M:SOM]STA(I-1)
&         | (dim([M:SOM]LOC)>0    & [F:STJ]LOC   <>[M:SOM]LOC(I-1))
&         | (dim([M:SOM]LOT)>0    & [F:STJ]LOT   <>[M:SOM]LOT(I-1))
&         | (dim([M:SOM]SLO)>0    & [F:STJ]SLO   <>[M:SOM]SLO(I-1))
&         | (dim([M:SOM]SERNUM)>0 & [F:STJ]SERNUM<>[M:SOM]SERNUM(I-1)))
         # Annulation de l'ancien mouvement
         Gosub ANN_SOM_STW
         If LRET<>0 Break Endif
         # Création du nouveau mouvement
         I-= 1
         Gosub CRE_SOM_STW
         If LRET<>0 Break Endif
         [L]WMOD=1
      Elsif [F:STJ]IPTDAT<>[M:SOM]IPTDAT & I<[M:SOM]NBLIG
         J = I
         Goto ORI_STOSORM1
      Else
         [L]WMOD=1
      Endif
      $ORI_STOSORM2
   Next
   If LRET<>0 Return Endif



# Autres cas : une seule boucle
Else
   For [F:STJ]STJ1 Where evalue(WCRIT)
      Raz J
      $ORI_STOSORM3
      I=find([F:STJ]MVTSEQ,[M:SOM]MVTSEQ(J..[M:SOM]NBLIG-1))
      If I=0
         # Annulation du mouvement
         Gosub ANN_SOM_STW
         If LRET<>0 Break Endif
         [L]WDEL=1
      # Le mouvement maj a t-il été modifié ?
      Elsif [F:STJ]UPDCOD=2 & [F:STJ]IPTDAT=[M:SOM]IPTDAT
&        & (abs([F:STJ]QTYSTU)<>[M:SOM]QTYSTU(I-1)
&         | (dim([M:SOM]SERNUM)>0 & [F:STJ]SERNUM<>[M:SOM]SERNUM(I-1)))
         # Annulation de l'ancien mouvement
         Gosub ANN_SOM_STW
         If LRET<>0 Break Endif
         # Création du nouveau mouvement
         I-= 1
         Gosub CRE_SOM_STW
         If LRET<>0 Break Endif
         [L]WMOD=1
      # Le mouvement en attente a t-il été modifié ?
      Elsif [F:STJ]UPDCOD=1 & [F:STJ]IPTDAT=[M:SOM]IPTDAT
&        & (abs([F:STJ]QTYSTU)<>[M:SOM]QTYSTU(I-1)
&         | [F:STJ]STA        <>[M:SOM]STA(I-1)
&         | (dim([M:SOM]LOC)>0    & [F:STJ]LOC   <>[M:SOM]LOC(I-1))
&         | (dim([M:SOM]LOT)>0    & [F:STJ]LOT   <>[M:SOM]LOT(I-1))
&         | (dim([M:SOM]SLO)>0    & [F:STJ]SLO   <>[M:SOM]SLO(I-1))
&         | (dim([M:SOM]SERNUM)>0 & [F:STJ]SERNUM<>[M:SOM]SERNUM(I-1)))
         # Annulation de l'ancien mouvement
         Gosub ANN_SOM_STW
         If LRET<>0 Break Endif
         # Création du nouveau mouvement
         I-= 1
         Gosub CRE_SOM_STW
         If LRET<>0 Break Endif
         [L]WMOD=1
      Elsif [F:STJ]IPTDAT<>[M:SOM]IPTDAT & I<[M:SOM]NBLIG
         J = I
         Goto ORI_STOSORM3
      Else
         [L]WMOD=1
      Endif
   Next
   If LRET<>0 Return Endif
Endif

If [M:SOM]SERMGTCOD=2 & [M:STW]NBLIG>1
   Sorta [M:STW]NBLIG [M:STW]NBLIG Order By [M:STW]STOCOU([S]indice),
&        [M:STW]MAJCOD([S]indice),[M:STW]SERNUM([S]indice)
Endif

# Traitement des nouvelles lignes
#---------------------------------

For I=0 To [M:SOM]NBLIG-1
   # C'est une nouvelle ligne
   If [M:SOM]MVTSEQ(I)=0
      Gosub CRE_SOM_STW
      If LRET<>0 Break Endif
   Endif
Next I

If LRET<>0
   GOK=0 : Return
Endif

If [L]WMOD=1
   [M:STW]MAJCODH = "M"
Elsif [L]WDEL=1
   [M:STW]MAJCODH = "A"
Endif

Return

########################################################################
# Alimentation de STOWORK avec l'écran des régularisations STKSHTREG
########################################################################
$ORI_STKSHTREG

Raz WQTY, WQTA

# Récupération des sections analytiques du mouvement en attente
Read [STJ]STJ0=[M:STW]STOFCY;1;[M:STW]ITMREF;[M:STW]IPTDAT;[M:STW]SEQ;0
If fstat
  # FGR 15/01/2010 : X3SUIVI60986
  #Call RSTA("STJ",[M:STW]STOFCY-[M:STW]ITMREF-[M:STW]IPTDAT-num$([M:STW]SEQ)) From GLOCK
  Call RSTA("STJ",[M:STW]STOFCY-[M:STW]ITMREF-num$([M:STW]IPTDAT)-num$([M:STW]SEQ)) From GLOCK
  LRET=5 : Return
Endif

For J=1 To GNBDIE
   Assign "WCCE"+num$(J) With [F:STJ]CCE(J-1)
Next J

# Traitement des mouvement à créer
For I=0 To [M:SHTR]NBLIG-1

   nolign += 1
   NOL     = nolign-1

   If NOL >= ACTSTW
      GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
      LRET=4 : Break
   Endif

   # Si pas de chrono stock, on ne fait rien
   If [M:SHTR]STOCOU(I)=0 Goto ORI_STKSHTREG1 Endif

   # Lecture du stock
   Read [STO]STO0=[M:STW]STOFCY;[M:SHTR]STOCOU(I)
   If fstat
      Call RSTA("STO",[M:STW]STOFCY-[M:STW]ITMREF-num$([M:SHTR]STOCOU(I)))
&               From GLOCK
      LRET=54 : Break
   # Emplacement bloqué pour inventaire
   Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
      If [F:ITF]LOCMGTCOD=2
          GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
      Else
          GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
      Endif
      Gosub TRT_ERR
      LRET=21 : Break
   # Emplacement en attente de rangement
   Elsif [F:STO]LOCCAT=2
      # Contrôle que les lignes de stock en attente de rangement sont complètes
      Call CTLPLFLOC([M:STW]ITMREF,"",LRET) From STKSOR
      If LRET<>0
         GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
         GMESSAGE+="\"+mess(377,199,1)-":"
         Case LRET
          When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
          When 2 : GMESSAGE+=mess(453,197,1)
          When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
         Endcase
         Gosub TRT_ERR
         LRET=22 : Break
      Endif
   Endif
   [M:STW] = [F:STO]

   # Lecture du lot
   Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
   If fstat
      Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
      LRET=53 : Break
   Endif
   [M:STW] = [F:STL]
   [M:STW]WAIFLG(NOL) = 0

   [M:STW]STU(NOL)       = [F:ITM]STU
   [M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
   [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP

   # Si no série saisi (géré en sortie ou rupture)
   # Alimentation du no série fin
   #If [M:SOW]WSERNUM(I)<>""
   #   [M:STW]SERNUM(NOL) = [M:SOW]WSERNUM(I)
   #   WNB = [M:SOW]WQTYSTUACT(I)
   #   If WNB = 1
   #      [M:STW]SERNUMF(NOL) = [M:STW]SERNUM(NOL)
   #   Else
   #      Call PLUS_NB([M:STW]SERNUM(NOL),WNB,[M:STW]SERNUMF(NOL),WRET)
   #&                     From STKLIB
   #      If WRET<>0
   #         Raz [M:STW]SERNUM(NOL), [M:STW]SERNUMF(NOL)
   #      Endif
   #   Endif
   #Endif

   [M:STW]MAJCOD(NOL)    = "C"
   Case [M:STW]TRSTYP
    When 4,24,2,6,29 : [M:STW]MAJTYP(NOL)="S"  : # Liv/Fac, Dem Serv, Sortie Div,OF,Ordre s-trait
    When 17,20       : [M:STW]MAJTYP(NOL)="C"  : # Liv prêt, Liv s-trait
                       Raz [M:STW]LPNNUM(NOL)  : # Issue X3-53322 un changement d'emp impose un raz du LPN
    When 11,32       : [M:STW]MAJTYP(NOL)="E"  : # Retour fou, Retour rec s-trait
   Endcase

   WQTY += [M:SHTR]QTYSTU(I)
   WQTA += [M:SHTR]QTYSTUACT(I)

   # Si retours fournisseur (sous-traitance) (entrée-)
   If find([M:STW]TRSTYP,11,32)
      [M:STW]QTYSTU(NOL)    = [M:SHTR]QTYSTU(I)*(-1)
      [M:STW]QTYSTUACT(NOL) = [M:SHTR]QTYSTUACT(I)*(-1)
   Else
      [M:STW]QTYSTU(NOL)    = [M:SHTR]QTYSTU(I)
      [M:STW]QTYSTUACT(NOL) = [M:SHTR]QTYSTUACT(I)
   Endif

   If [M:STW]PCUSTUCOE(NOL)=0 [M:STW]PCUSTUCOE(NOL)=1 Endif
   [M:STW]QTYPCU(NOL)=[M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
   Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV

   # Recherche des prix ordre et prix valorisé du mouvement origine
   # si retour fournisseur (sous-traitance)
   If find([M:STW]TRSTYP,11,32) &
&     [M:STW]VCRTYPORI<>0 & [M:STW]VCRNUMORI<>"" & [M:STW]VCRLINORI<>0
      Gosub RECH_STJ_PRI
   Endif

   # Alimentation des sections analytiques
   For J=1 To GNBDIE
      Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("WCCE"+num$(J))
   Next J

   # Chargement emplacement destination
   Case [M:STW]TRSTYP
    When 17 : WLOCREF=[M:STW]LOCENT            : # Liv prêt
              WALI=1
              Gosub LEC_STOLOC
              If LRET<>0 Break Endif
              If [F:STC]LOCCAT<>3
                 GMESSAGE = [M:STW]LOCDES-":"-mess(243,192,1) : Gosub TRT_ERR
                 LRET=24 : Break
              Endif
    When 20 : WLOCREF=[M:STW]LOCENT            : # Liv sous-traitance
              WALI=1
              Gosub LEC_STOLOC
              If LRET<>0 Break Endif
              If [F:STC]LOCCAT<>4
                 GMESSAGE = [M:STW]LOCDES-":"-mess(244,192,1) : Gosub TRT_ERR
                 LRET=23 : Break
              Endif
   Endcase

   #--- Bug 71421 puis 77649
   #If [M:STW]SERNUM(NOL)="" & [M:SHTR]SERSAI(I)<>""
   #   [M:STW]SERNUM(NOL)  = [M:SHTR]SERSAI(I)
   #   [M:STW]SERNUMF(NOL) = [M:SHTR]SERFSAI(I)
   #Endif
   If [M:STW]SERNUM(NOL)="" & [M:SHTR]SERSAI<>"" & [M:SHTR]QTYACT=1
      [M:STW]SERNUM(NOL)  = [M:SHTR]SERSAI
      [M:STW]SERNUMF(NOL) = [M:SHTR]SERFSAI
   #--- Bug 85863
   #Else
   Elsif [F:ITM]SERMGTCOD<3
   #---
      Raz [M:STW]SERNUM(NOL), [M:STW]SERNUMF(NOL)
   Endif
   #---

   [M:STW]NBLIG += 1

$ORI_STKSHTREG1
Next I

If LRET<>0
   GOK=0 : Return
Endif

# Chargement du mouvement en attente

Read [STJ]STJ0=[M:STW]STOFCY;1;[M:STW]ITMREF;[M:STW]IPTDAT;[M:STW]SEQ;0
If fstat
  # FGR 15/01/2010 : X3SUIVI60986
  #Call RSTA("STJ",[M:STW]STOFCY-[M:STW]ITMREF-[M:STW]IPTDAT-num$([M:STW]SEQ)) From GLOCK
  Call RSTA("STJ",[M:STW]STOFCY-[M:STW]ITMREF-num$([M:STW]IPTDAT)-num$([M:STW]SEQ)) From GLOCK
  LRET=5 : Return
Endif

nolign += 1
NOL     = nolign-1

If NOL >= ACTSTW
   GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
   LRET=4 : Return
Endif

[M:STW] = [F:STJ]

[M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
[M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
[M:STW]WAIFLG(NOL)    = 1

[M:STW]MAJCOD(NOL)    = "A"
Case [M:STW]TRSTYP
 When 4,24,2,6,29 : [M:STW]MAJTYP(NOL)="S"  : # Liv/Fac, Dem Serv, Sortie Div,OF,Ordre s-trait
 When 17,20       : [M:STW]MAJTYP(NOL)="C"  : # Liv prêt, Liv s-trait
 When 11,32       : [M:STW]MAJTYP(NOL)="E"  : # Retour fou, Retour rec s-trait
Endcase

# Si retours fournisseur (sous-traitance) (entrée-)
If find([M:STW]TRSTYP,11,32)
   [M:STW]QTYSTU(NOL)    = WQTY*(-1)
   [M:STW]QTYSTUACT(NOL) = WQTA*(-1)
Else
   [M:STW]QTYSTU(NOL)    = WQTY
   [M:STW]QTYSTUACT(NOL) = WQTA
Endif

#--- Bug 77649
If [M:STW]SERNUM(NOL)<>""
   [M:STW]SERNUMF(NOL) = [M:STW]SERNUM(NOL)
   If [M:STW]QTYSTUACT(NOL)>1
      For I=1 To [M:STW]QTYSTUACT(NOL)-1
         Call PLUS_UN([M:STW]SERNUMF(NOL),[M:STW]SERNUMF(NOL),WRET) From STKLIB
         If WRET
            Raz [M:STW]SERNUMF(NOL)
            Break
         Endif
      Next I
   Endif
Endif
#---
#--- Issue 110327
If [F:ITM]SERMGTCOD=4
  [M:STW]SERNUM(NOL) = [F:STJ]SERDEB
  [M:STW]SERNUMF(NOL)= [F:STJ]SERFIN
Endif
#---

# Alimentation des sections analytiques
For J=1 To GNBDIE
   Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("WCCE"+num$(J))
Next J

[M:STW]NBLIG += 1

Return

########################################################################
# Alimentation de STOWORK avec l'écran de changement stock STOCHGW
########################################################################
$ORI_STOCHGW

# Suppression d'un transfert inter-sites
If [M:STW]TRSTYP=14 & [M:SGW]NBLIG=0
   Gosub ANU_BETFCY
   [M:STW]MAJCODH = "A"
   Return
Endif

For I=0 To [M:SGW]NBLIG-1

   # La ligne de l'écran de travail ne concerne pas cette ligne de document
   If [M:SGW]WSTOSEQ(I)<>LLIG Goto ORI_STOCHGW1 Endif
   If [M:SGW]WSTOCOU(I)= 0    Goto ORI_STOCHGW1 Endif    # hcb 110327

   nolign += 1
   NOL     = nolign-1

   If NOL >= ACTSTW
      GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
      LRET=4 : Break
   Endif

   # Lecture du stock
   Readlock [STO]STO0=[M:STW]STOFCY;[M:SGW]WSTOCOU(I)
   If fstat
      Call RSTA("STO",[M:STW]STOFCY-[M:STW]ITMREF-num$([M:SGW]WSTOCOU(I))) From GLOCK
      LRET=54 : Break
   #--- Issue X3-53322
   Endif

   #--- Issue X3-53322
   [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
   # Alimentation type mouvement s'il ne s'agit :
   # ni d'un transfert inter-sites, ni d'un contrôle qualité.
   # Dans ce cas le type de mouvement doit être géré à la ligne avec :
   # -  9 si changement statut
   # - 36 si changement identifiant contenant (sans chgt emp de type transfert ou retour sous-traitant)
   # -  7 si changement emplacement (sans chgt de statut, sans chgt identifiant contenant sauf
   #                                 si chgt emp de type transfert ou retour sous-traitant)
   # - 21 si refractionnement (sans chgt de statut, ni chgt d'emplacement)
   If !find([M:STW]TRSTYP,8,14)
      WLOCCATDES=0
      If [M:SGW]WLOCDES(I)<>""
        Read [STC]STC0=[M:STW]STOFCY;[M:SGW]WLOCDES(I)
        If !fstat : WLOCCATDES=[F:STC]LOCCAT : Endif
      Endif
      [M:STW]TRSTYP = 7
      If [M:SGW]WSTADES(I)<>"" & [M:SGW]WSTADES(I)<>[F:STO]STA
         # Changement statut
         [M:STW]TRSTYPLIG(NOL) = 9
      Elsif [M:SGW]WLPNNUMDES(I)<>[F:STO]LPNNUM
         # Si transfert ou retour sous-traitant, le chgt emp prime sur le chgt id contenant
         If (find(WLOCCATDES,1,2) & find([F:STO]LOCCAT,3,4)) | (find(WLOCCATDES,3,4) & find([F:STO]LOCCAT,1,2))
            # Changement emplacement
            [M:STW]TRSTYPLIG(NOL) = 7
         Else
            # Changement identifiant contenant
            [M:STW]TRSTYPLIG(NOL) = 36
         Endif
      Elsif [M:SGW]WLOCDES(I)<>"" & [M:SGW]WLOCDES(I)<>[F:STO]LOC
         # Changement emplacement
         [M:STW]TRSTYPLIG(NOL) = 7
      Else
         # Refractionnement
         [M:STW]TRSTYPLIG(NOL) = 21
      Endif
   Endif
   #--- End issue X3-53322

   #--- Issue X3-53322
   # Emplacement bloqué pour inventaire
   If [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
   #Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
   #---
      If [F:ITF]LOCMGTCOD=2
          GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
      Else
          GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
      Endif
      Gosub TRT_ERR
      LRET=21 : Unlock [STO] : Break
   #--- Issue X3-53322
   Endif

   # Emplacement en attente de rangement et contrôle à réaliser
   If [F:STO]LOCCAT=2
   #Elsif [F:STO]LOCCAT=2
   #---
      # Contrôle que les lignes de stock en attente de rangement sont complètes
      Call CTLPLFLOC([M:STW]ITMREF,"",LRET) From STKSOR
      If LRET<>0
         GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
         GMESSAGE+="\"+mess(377,199,1)-":"
         Case LRET
          When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
          When 2 : GMESSAGE+=mess(453,197,1)
          When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
         Endcase
         Gosub TRT_ERR
         LRET=22 : Unlock [STO] : Break
      Endif
   Endif

   [M:STW] = [F:STO]

   # Mise à jour de la quantité en cours de traitement
   [F:STO]CUMWIPQTY -= max(0,[M:SGW]WWIPQTY(I))
   [F:STO]CUMWIPQTA -= max(0,[M:SGW]WWIPQTA(I))
   # Dans le cas où l'on serait passé en négatif
   [F:STO]CUMWIPQTY  = max(0,[F:STO]CUMWIPQTY)
   [F:STO]CUMWIPQTA  = max(0,[F:STO]CUMWIPQTA)

   # Suppression qté en cours de traitement
   Call DEL_STOWIPW([F:STO]STOCOU,[M:SGW]WQTYSTUDES(I)) From STKLIB

   Rewrite [STO]
   If fstat
      GOK=0  : Call FSTA("STO") From GLOCK
      LRET=64 : Break
   Endif
 #                                                                              hcb 110327 deb
   If [M:SGW]WSTOSEQIND(I) <> 0
      # Suppression série en cours de traitement
      Call DEL_STOSERW([F:STO]ITMREF,[M:SGW]WSERNUM(I),[M:SGW]WQTYSTUDES(I),LRET) From STKLIB
      If LRET <>0
         GOK=0
         LRET=74 : Break
      Endif
   Endif
                                                                                               # hcb 110327 fin
   # Lecture du lot
   Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
   If fstat
      Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
      LRET=53 : Break
   Endif
   [M:STW] = [F:STL]
   # Si contrôle qualité, on alimente les infos lots,
   # qui ont peut-être été modifiées lors du contrôle.
   If [M:STW]TRSTYP = 8
      J = [M:SGW]NUMLIGLOT(I)
      If J<>-1
         [M:STW]POT       (NOL) = [M:SGW]POT      (J)
         [M:STW]ACT       (NOL) = [M:SGW]ACT      (J)
         [M:STW]REFPER    (NOL) = [M:SGW]REFPER   (J)
         [M:STW]SHL       (NOL) = [M:SGW]SHL      (J)
         [M:STW]SHLDAT    (NOL) = [M:SGW]SHLDAT   (J)
         [M:STW]SHLUOM    (NOL) = [M:SGW]SHLUOM   (J)
         [M:STW]SHLLTI    (NOL) = [M:SGW]SHLLTI   (J)
         [M:STW]SHLLTIUOM (NOL) = [M:SGW]SHLLTIUOM(J)
         [M:STW]NEWLTIDAT (NOL) = [M:SGW]NEWLTIDAT(J)
         [M:STW]DLU       (NOL) = [M:SGW]DLU      (J)
         [M:STW]DLUDAT    (NOL) = [M:SGW]DLUDAT   (J)
         [M:STW]USRFLD1   (NOL) = [M:SGW]USRFLD1  (J)
         [M:STW]USRFLD2   (NOL) = [M:SGW]USRFLD2  (J)
         [M:STW]USRFLD3   (NOL) = [M:SGW]USRFLD3  (J)
         [M:STW]USRFLD4   (NOL) = [M:SGW]USRFLD4  (J)
         [M:STW]BPSLOT    (NOL) = [M:SGW]BPSLOT   (J)
      Endif
      # hcb 90247 deb
      # si date de recontrole n a pas ete saisie il faut la recalculée
      #If [M:STW]NEWLTIDAT (NOL) = [F:STL]NEWLTIDAT   # hcb c79b99
      #   [F:STL]LTIDAT = [M:STW]IPTDAT    # date controle
      #   Call CALLTI([F:ITM]EXYMGTCOD,[F:STL]LTIDAT,[F:STL]SHLLTI ,[F:STL]SHLLTIUOM,"",[M:STW]NEWLTIDAT (NOL)) From STKLIB
      #   # si date recontrole > date limite utilisation : date recontrole = date limite utilisation
      #   If [M:STW]NEWLTIDAT    (NOL) <> [31/12/2999]     # date recontrole
      #      If [M:STW]NEWLTIDAT (NOL) > [F:STL]DLUDAT
      #         [M:STW]NEWLTIDAT (NOL) = [F:STL]DLUDAT
      #      Endif
      #   Endif
      #Endif
      # hcb 90247 fin
   Endif
   [M:STW]MAJCOD(NOL) = "C"
   [M:STW]WAIFLG(NOL) = 0

   [M:STW]STU(NOL)       = [F:ITM]STU
   [M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF

   #--- Issue X3-53322 (déplacé plus haut)
   #[M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
   # Alimentation type mouvement s'il ne s'agit :
   # ni d'un transfert inter-sites, ni d'un contrôle qualité.
   # Dans ce cas le type de mouvement doit être géré à la ligne avec :
   # -  9 si changement statut
   # -  7 si changement emplacement (sans chgt de statut, ni chgt identifiant contenant)
   # - 21 si refractionnement (sans chgt de statut ni chgt d'emplacement)
   # - 36 si changement identifiant contenant
   #If !find([M:STW]TRSTYP,8,14)
   #   [M:STW]TRSTYP = 7
   #   If [M:SGW]WSTADES(I)<>"" & [M:SGW]WSTADES(I)<>[F:STO]STA
   #      # Changement statut
   #      [M:STW]TRSTYPLIG(NOL) = 9
   #   Elsif [M:SGW]WLOCDES(I)<>"" & [M:SGW]WLOCDES(I)<>[F:STO]LOC
   #      # Changement emplacement
   #      [M:STW]TRSTYPLIG(NOL) = 7
   #   Else
   #      # Refractionnement
   #      [M:STW]TRSTYPLIG(NOL) = 21
   #   Endif
   #Endif
   #--- End issue X3-53322

   # Ce cas est impossible --> mis en commentaire par TS le 02/01/2018
   # Si stock en attente de rangement et chgt de statut ou défractionnement
   #If [F:STO]LOCCAT=2 & [M:STW]TRSTYP=14 & find([M:STW]TRSTYPLIG(NOL),9,21)
   #   GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(135,184,1)
   #   Gosub TRT_ERR
   #   LRET=22 : Unlock [STO] : Break
   #Endif

   [M:STW]MAJTYP(NOL)="C"

   [M:STW]QTYSTU(NOL)    = [M:SGW]WQTYSTUDES(I)
   [M:STW]QTYSTUACT(NOL) = [M:SGW]WQTYSTUDES(I)

   #---------------------------------------------------------------------
   # Si contrôle qualité et modification du titre :
   # alimentation dans QTYSTUACTORI de la qté active origine :
   # c'est elle qui sera prise en compte dans le mvt de sortie
   # alimentation dans POTORI et ACTORI des titres ou UI origine
   # [F:STL]POT      contient l'ancien titre
   # [M:STW]POT(NOL) contient le nouveau titre
   #---------------------------------------------------------------------
   Raz [M:STW]QTYACTORI(NOL), [M:STW]POTORI(NOL), [M:STW]ACTORI(NOL)
   If [M:STW]TRSTYP=8 & J<>-1 & find([F:ITF]STOMGTCOD,3,4)
      If ([F:ITF]STOMGTCOD=3 & [F:STL]POT<>[M:STW]POT(NOL)) |
&        ([F:ITF]STOMGTCOD=4 & [F:STL]ACT<>[M:STW]ACT(NOL))
         Case [F:ITF]STOMGTCOD
          When 3 : [M:STW]QTYACTORI(NOL) = [M:SGW]WQTYSTUDES(I)*[F:STL]POT/100
          When 4 : [M:STW]QTYACTORI(NOL) = [M:SGW]WQTYSTUDES(I)*[F:STL]ACT
         Endcase
         [M:STW]POTORI(NOL) = [F:STL]POT
         [M:STW]ACTORI(NOL) = [F:STL]ACT
      Endif
   Endif
   #---------------------------------------------------------------------

   # Si gestion en titres ou UI, calcul quantité en UA
   Case [F:ITF]STOMGTCOD
    When 3 : If [M:STW]POT(NOL)<>0
                [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)*([M:STW]POT(NOL)/100)
             Endif
    When 4 : If [M:STW]ACT(NOL)<>0
                [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)* [M:STW]ACT
             Endif
   Endcase

   #--- Issue 110327
   # Si no série saisi (géré en sortie ou en E/S globale)
   If [M:SGW]WSERNUM(I)<>""
      [M:STW]SERNUM(NOL)  = [M:SGW]WSERNUM(I)
      [M:STW]SERNUMF(NOL) = [M:SGW]WSERNUMF(I)
      If [M:STW]QTYSTU(NOL)=1 [M:STW]SERNUMF(NOL)=[M:STW]SERNUM(NOL) Endif
   Endif

   # Si changement d'unité
   If [M:SGW]WPCUDES(I)<>""
      [M:STW]PCU(NOL)       = [M:SGW]WPCUDES(I)
      [M:STW]QTYPCU(NOL)    = [M:SGW]WQTYPCUDES(I)
      [M:STW]PCUSTUCOE(NOL) = [M:SGW]WCOEDES(I)
   Endif

   # Si changement de statut
   If [M:SGW]WSTADES(I)<>""
      [M:STW]STA(NOL) = [M:SGW]WSTADES(I)
   Endif
# hcb 110505 28601 deb
   # Si changement d identifiant 1
    If dim([M:SGW]WPALNUMDES(I)) > 0
#       If [M:SGW]WPALNUMDES(I)<>""                  # hcb 32302
          [M:STW]PALNUM(NOL) = [M:SGW]WPALNUMDES(I)
#       Endif                                        # hcb 32302
   Endif
   # Si changement d identifiant 2
    If dim([M:SGW]WCTRNUMDES(I)) > 0
#       If [M:SGW]WCTRNUMDES(I)<>""                  # hcb 32302
          [M:STW]CTRNUM(NOL) = [M:SGW]WCTRNUMDES(I)
#       Endif                                        # hcb 32302
   Endif
# hcb 110505 28601 fin

   #--- Issue X3-53322
   [M:STW]LPNNUM(NOL) = [M:SGW]WLPNNUMDES(I)

   # Génération demande d'analyse
   If left$([M:STW]STA(NOL),1)="Q"
      [M:STW]QLYCTLFLG(NOL) = [M:SGW]QLYCTLFLG(I)
   Else
      [M:STW]QLYCTLFLG(NOL) = 1
   Endif

   # Si transfert inter-sites
   If [M:STW]TRSTYP=14
      # Si inter-société, alimentation du prix ordre
      If [M:STW]BETCPY=2
         [M:STW]PRIORD(NOL) = [M:STW]PRIORDH
      Endif
      # Alimentation des sections analytiques (entrée)
      Call GETDEV([M:STW]TRFFCY)  From DEVSUB
      [M:STW]CUR = GLOCALDEV

      # Sauvegarde STOFCY
      WSTOFCY = [M:STW]STOFCY
      # Forçage site destination dans STOFCY pour init section
      [M:STW]STOFCY = [M:STW]TRFFCY

      For J=1 To GNBDIE
         Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("[M:SGW]CCE"+num$(J)+"(I)")
         If evalue("[M:STW]CCE"+num$(J)+"(NOL)")=""
  #          GAXE=J
            Call INISEC(SECTION,[M:STW]CCECOD,J) From TRTX3CPT
            Assign "[M:STW]CCE"+num$(J)+"(NOL)" With SECTION
         Endif
      Next J

      # Restitution STOFCY
      [M:STW]STOFCY = WSTOFCY

      # Alimentation des sections analytiques (sortie)
      Call GETDEV([M:STW]STOFCY)  From DEVSUB
      [M:STW]CUR = GLOCALDEV
      For J=1 To GNBDIE
         Assign "[M:STW]CCS"+num$(J)+"(NOL)" With evalue("[M:SGW]CCS"+num$(J)+"(I)")
         If evalue("[M:STW]CCS"+num$(J)+"(NOL)")=""
  #          GAXE=J
            Call INISEC(SECTION,[M:STW]CCSCOD,J) From TRTX3CPT
            Assign "[M:STW]CCS"+num$(J)+"(NOL)" With SECTION
         Endif
      Next J
   Endif

   # Alimentation impression étiquettes
   [M:STW]LBEFMT(NOL) = [M:SGW]WLBEFMT(I)
   [M:STW]LBENBR(NOL) = [M:SGW]WLBENBR(I)

   # Chargement emplacement destination
   [M:STW]LOCDES(NOL)    = [M:SGW]WLOCDES(I)
   [M:STW]LOCDESTYP(NOL) = [M:SGW]WLOCTYPDES(I)
   [M:STW]WRHDES(NOL)    = [M:SGW]WWRHDES(I)
   WLOCTYP = [M:STW]LOCDESTYP(NOL)
   # Si transfert inter-sites
   If [M:STW]TRSTYP=14
      WSTOFCY = [M:STW]TRFFCY
   Else
      WSTOFCY = [M:STW]STOFCY
   Endif
   WALI=1
   Gosub LEC_STOLOCTYP
   If LRET<>0 Break Endif

   # Transfert zones de l'écran STOCHGW vers l'écran STOWORK
   GPOINT="SGW_STW" : Gosub ENTREE From EXEFNC

   [M:STW]NBLIG += 1

$ORI_STOCHGW1
Next I

If LRET<>0
   GOK=0 : Return
Endif

Return

########################################################################
# Alimentation de STOWORK pour suppression transfert inter-sites
########################################################################
$ANU_BETFCY
Local Char    WFILORI(150)
Local Decimal LSTOCOU

WFILORI = 'STOFCY=[M:STW]STOFCY & VCRTYP=WVCRTYP & VCRNUM=WVCRNUM'
WFILORI+= '& VCRLIN=WVCRLIN & REGFLG<>2'
nolign  =0

# Mouvement de sortie
# alimentation des caractéristiques stock depuis site origine
Filter [STJ] Where evalue(WFILORI) Order By Key STJ0 Desc

For [STJ] Hint Key STJ1
   nolign += 1
   NOL     = nolign-1

   If NOL >= ACTSTW
      GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
      LRET=4 : Break
   Endif

   [M:STW] = [F:STJ]

   #--- Issue 110327
   If [F:ITM]SERMGTCOD=4
     [M:STW]SERNUM(NOL) = [F:STJ]SERDEB
     [M:STW]SERNUMF(NOL)= [F:STJ]SERFIN
   Endif
   #---

   [M:STW]ITMREFLIG(NOL) = [F:STJ]ITMREF
   [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP

   [M:STW]QTYSTU(NOL)    = abs([F:STJ]QTYSTU)
   [M:STW]QTYSTUACT(NOL) = abs([F:STJ]ACTQTY)
   [M:STW]QTYPCU(NOL)    = abs([F:STJ]QTYPCU)

   Raz [M:STW]WAIFLG(NOL)
   If [F:STJ]UPDCOD<>2 [M:STW]WAIFLG(NOL)=1 Endif

   [M:STW]MAJCOD(NOL)    = "A"
   [M:STW]MAJTYP(NOL)    = "C"

   # Alimentation type et catégorie emplacement
   # du mvt de sortie dans [M:STW]LOC
   WALI    = 2
   WLOCREF = [F:STJ]LOC
   Gosub LEC_STOLOC
   If LRET<>0 Break Endif
   #--- Bug 62284
   For I=1 To GNBDIE
     Assign "[M:STW]CCS"+num$(I)+"(NOL)" With [F:STJ]CCE(I-1)
   Next I
   #---
   [M:STW]NBLIG += 1

Next
Filter [STJ]

If nolign=0
   GMESSAGE = mess(143,184,1) : Gosub TRT_ERR
   LRET=71 : Goto ANU_BETFCY_FIN
Endif

WFILORI = 'STOFCY=[M:STW]TRFFCY & VCRTYP=WVCRTYP & VCRNUM=WVCRNUM'
WFILORI+= '& VCRLIN=WVCRLIN & REGFLG<>2'
nolign  =0

# Mouvement d'entrée
Filter [STJ] Where evalue(WFILORI) Order By Key STJ0 Desc

For [STJ] Hint Key STJ1
   nolign += 1
   NOL     = nolign-1

   #--- Issue X3-53322 : Ajout LPN
   # Recherche du chrono stock correspondant au mouvement d'entrée
   Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,
&              [F:STJ]BPSLOT,[F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,
&              [F:STJ]LOC,[F:STJ]PCU,[F:STJ]PCUSTUCOE,[F:STJ]SERNUM,
&              [F:STJ]QLYCTLDEM,[F:STJ]OWNER,[F:STJ]STOFLD1,[F:STJ]STOFLD2,
&              [F:STJ]LPNNUM,LSTOCOU) From STKLIB
   If LSTOCOU=0
      GMESSAGE = mess(144,184,1) : Gosub TRT_ERR
      LRET=72 : Break
   Else
      [M:STW]STOCOU(NOL)    = LSTOCOU
      #--- Bug 62284
     For I=1 To GNBDIE
       Assign "[M:STW]CCE"+num$(I)+"(NOL)" With [F:STJ]CCE(I-1)
     Next I
     #---
   Endif
Next

Filter [STJ]   # hcb 48746

$ANU_BETFCY_FIN
If LRET<>0
   GOK=0 : Return
Endif

Return

########################################################################
# Modification saisie de type 'entrée'
# Chargement pour création d'un nouveau mouvement
########################################################################
$CRE_ENM_STW

# Retour de prêt ou de livraison sous-traitance
If find([M:STW]TRSTYP,18,33)
   [M:ENM]STOCOU(I)=[M:ENM]STOCOUORI(I)
   # Si emplacement destination non renseigné
   If [M:ENM]LOC(I)=""
      GMESSAGE=[M:STW]STOFCY-[M:STW]ITMREF-mess(379,199,1) : Gosub TRT_ERR
      LRET=2 : Return
   Endif
Endif

nolign += 1
NOL     = nolign-1

If NOL >= ACTSTW
   GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
   LRET=4 : Return
Endif

# Chargement de la nouvelle ligne dans STW
#[M:STW]SERNUM(NOL) = [M:ENM]SERNUM(I)

# Stockage des sections analytiques
For J=1 To GNBDIE
   Assign "WCCE"+num$(J) With evalue("[M:ENM]CCE(J-1)")
Next J
Gosub CHARGE_ENT_STW
If LRET<>0 Return Endif

[M:STW]NBLIG += 1

Return

########################################################################
# Modification saisie de type 'entrée'
# Chargement pour suppression d'un mouvement
########################################################################
$ANN_ENM_STW
Local Decimal LSTOCOU
Local Integer Y1    # hcb 67182
Raz           Y1    # hcb 67182

nolign += 1
NOL     = nolign-1

If NOL >= ACTSTW
   GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
   LRET=4 : Return
Endif

# Si retour de prêt ou de livraison sous-traitance,
# on alimente  le mvt sortie à annuler et le [M:STW]STOCOU du mvt d'entrée
If find([M:STW]TRSTYP,18,33)
   #--- Issue X3-53322 : Ajout LPN
   # Recherche du chrono stock correspondant au mouvement d'entrée
   Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,
&              [F:STJ]BPSLOT,[F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,
&              [F:STJ]LOC,[F:STJ]PCU,[F:STJ]PCUSTUCOE,[F:STJ]SERNUM,
&              [F:STJ]QLYCTLDEM,[F:STJ]OWNER,[F:STJ]STOFLD1,[F:STJ]STOFLD2,
&              [F:STJ]LPNNUM,LSTOCOU) From STKLIB
   If LSTOCOU=0
      GMESSAGE = mess(144,184,1) : Gosub TRT_ERR
      LRET=72 : Return
   Else
      [M:STW]STOCOU(NOL) = LSTOCOU
   Endif

   # Lecture du mouvement de sortie correspond
   #--- Issue 110327 : ajout SERDEB et SERFIN
   Filter [STJ1] Where   STOFCY= [F:STJ]STOFCY
&                      & VCRTYP= [F:STJ]VCRTYP
&                      & VCRNUM= [F:STJ]VCRNUM
&                      & VCRLIN= [F:STJ]VCRLIN
&                      & ITMREF= [F:STJ]ITMREF
&                      & IPTDAT= [F:STJ]IPTDAT
&                      & LOT   = [F:STJ]LOT
&                      & SLO   = [F:STJ]SLO
&                      & SERNUM= [F:STJ]SERNUM
&                      & PALNUM= [F:STJ]PALNUM
&                      & CTRNUM= [F:STJ]CTRNUM
&                      & OWNER = [F:STJ]OWNER
&                      & STOFLD1=[F:STJ]STOFLD1
&                      & STOFLD2=[F:STJ]STOFLD2
&                      & QTYSTU=-[F:STJ]QTYSTU
&                      & REGFLG<>2
&                      & SERDEB= [F:STJ]SERDEB
&                      & SERFIN= [F:STJ]SERFIN
   Read [STJ1] STJ1 First
   If fstat
      GMESSAGE = mess(145,184,1) : Gosub TRT_ERR
      LRET=73 : Filter [STJ1] : Return
   Endif

   [M:STW] = [F:STJ1]

   #--- Issue 110327
   If [F:ITM]SERMGTCOD=4
     [M:STW]SERNUM(NOL) = [F:STJ1]SERDEB
     [M:STW]SERNUMF(NOL)= [F:STJ1]SERFIN
   Endif
   #---

   For Y1=1 To GNBDIE                                # hcb 67182
        Assign "[M:STW]CCE"+num$(Y1)+"(NOL)" With    [F:STJ1]CCE(Y1-1)
   Next
   # Pour les conserver sur les mvts de modif
   WVCRTYPORI = [M:STW]VCRTYPORI
   WVCRNUMORI = [M:STW]VCRNUMORI
   WVCRLINORI = [M:STW]VCRLINORI
   WVCRSEQORI = [M:STW]VCRSEQORI
   WMVTDES    = [M:STW]MVTDES

   [M:STW]ITMREFLIG(NOL) = [F:STJ1]ITMREF
   [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP

   [M:STW]QTYSTU(NOL)    = [F:STJ]QTYSTU
   [M:STW]QTYSTUACT(NOL) = [F:STJ]ACTQTY
   [M:STW]QTYPCU(NOL)    = [F:STJ]QTYPCU

   Raz [M:STW]WAIFLG(NOL)
   If [F:STJ]UPDCOD<>2 [M:STW]WAIFLG(NOL)=1 Endif
   [M:STW]QLYCTLFLG(NOL) = 1
   [M:STW]MAJCOD(NOL)    = "A"
   [M:STW]MAJTYP(NOL)    = "C"

   # Alimentation type et catégorie emplacement
   # du mvt sortie dans [M:STW]LOC
   WALI    = 2
   WLOCREF = [F:STJ1]LOC
   Gosub LEC_STOLOC
   If LRET<>0 Return Endif

   Filter [STJ1]

# Alimentation mvt entrée à annuler
Else
   # Cas particulier des mvts issus d'un plan de rangement
   # On modifie une entrée diverse, réception, ... mais [F:STJ]TRSTYP=22
   # Or il faut conserver le [M:STW]TRSTYP alimenté en paramètre d'origine
   GBIDI1=[M:STW]TRSTYP
   [M:STW] = [F:STJ]

   #--- Issue 110327
   If [F:ITM]SERMGTCOD=4
     [M:STW]SERNUM(NOL) = [F:STJ]SERDEB
     [M:STW]SERNUMF(NOL)= [F:STJ]SERFIN
   Endif
   #---

   For Y1=1 To GNBDIE                                                      # hcb 67182
       Assign "[M:STW]CCE"+num$(Y1)+"(NOL)" With    [F:STJ]CCE(Y1-1)
   Next

   # Pour les conserver sur les mvts de modif
   WVCRTYPORI = [M:STW]VCRTYPORI
   WVCRNUMORI = [M:STW]VCRNUMORI
   WVCRLINORI = [M:STW]VCRLINORI
   WVCRSEQORI = [M:STW]VCRSEQORI
   WMVTDES    = [M:STW]MVTDES

   [M:STW]TRSTYP=GBIDI1

   [M:STW]ITMREFLIG(NOL) = [F:STJ]ITMREF
   [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP

   # Retour/avoir client ou réintégration stock (sortie-)
   If find([M:STW]TRSTYP,12,19)
      [M:STW]QTYSTU(NOL)    = [F:STJ]QTYSTU*(-1)
      [M:STW]QTYSTUACT(NOL) = [F:STJ]ACTQTY*(-1)
      [M:STW]QTYPCU(NOL)    = [F:STJ]QTYPCU*(-1)
   Else
      [M:STW]QTYSTUACT(NOL) = [F:STJ]ACTQTY
   Endif
   Raz [M:STW]WAIFLG(NOL)
   If [F:STJ]UPDCOD<>2 [M:STW]WAIFLG(NOL)=1 Endif
   [M:STW]QLYCTLFLG(NOL) = 1
   [M:STW]MAJCOD(NOL)    = "A"
   Case [M:STW]TRSTYP
    When 1,3,5,16 : [M:STW]MAJTYP(NOL)="E" : # Ent div, Rec fou, Décl prod, Rec s-trait
    When 12,19    : [M:STW]MAJTYP(NOL)="S" : # Ret/Avo cli, Réint stock
   Endcase

   # Alimentation type et catégorie emplacement
   # du mvt entrée dans [M:STW]LOC
   WALI    = 2
   WLOCREF = [F:STJ]LOC
   Gosub LEC_STOLOC
   If LRET<>0 Return Endif

Endif

[M:STW]NBLIG += 1

Return


########################################################################
# Chargement d'une ligne STW pour génération d'un mouvement d'entrée
########################################################################
$CHARGE_ENT_STW

# Alimentation indice du tableau des compléments lots
# S'il n'y a pas de complément lot, l'indice IL vaudra -1
IL = evalue(WABR+"NUMLIGLOT(I)")

# [M:ENM] :LOTAFF,SLOAFF,BPSLOTAFF       sont dans le tableau des mvts (ind I)
#          LOT,SLO,BPSLOT,GESLOT,ACT,... sont dans le tableau des lots (ind IL)
# [M:ENTW]:LOT,SLO,BPSLOT,GESLOT,ACT,... sont dans le tableau des lots (ind IL)

If evalue(WABR+"STOCOU(I)")<>0
   # Lecture du stock
   Read [STO]STO0=[M:STW]STOFCY;evalue(WABR+"STOCOU(I)")
   If fstat
      Raz [M:STW]STOCOU(NOL)
      Call RSTA("STO",[M:STW]STOFCY-[M:STW]ITMREF-num$(evalue(WABR+"STOCOU(I)"))) From GLOCK
      LRET=54 : Return
   # Emplacement bloqué pour inventaire
   Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
      If [F:ITF]LOCMGTCOD=2
          GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
      Else
          GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
      Endif
      Gosub TRT_ERR
      LRET=21 : Return
   Else
      [M:STW] = [F:STO]
   Endif
Endif

Raz WESSAI

$ROL_TRT_LOT
If WESSAI>50
   GMESSAGE = [F:ITM]LOTCOU-":"-mess(60,199,1) : Gosub TRT_ERR
   LRET=31 : Return
Endif

Raz WLOTLU
# Si article avec gestion de lot et le complément lot existe
If [F:ITM]LOTMGTCOD>1 & IL<>-1
   # Affectation du lot si non renseigné
   #    B = Lot blanc
   #    C = Compteur lot (même lot pour toutes les lignes de stock avec C)
   #    V = Numéro pièce
   WABRLOT = evalue(WABR+"LOT(IL)")
   If evalue(WABR+"LOT(IL)")=""
      Case evalue(WABR+"GESLOT(IL)")
       When "B" : WABRLOT=""
       When "C" : If INDLOT>0
                     K=find(evalue(WABR+"BPSLOT(IL)"),WLOTLOT(0..INDLOT-1,0))
                     If K>0
                        WABRLOT = WLOTLOT(K-1,1)
                     Else
                        Gosub RECUP_LOT
                        If GOK<0
                           Goto ROL_TRT_LOT
                        Elsif LRET<>0
                           Return
                        Endif
                     Endif
                  Else
                     Gosub RECUP_LOT
                     If GOK<0
                        Goto ROL_TRT_LOT
                     Elsif LRET<>0
                        Return
                     Endif
                  Endif
                  #--- Dem 77104
                  GPE=0
                  GPOINT="COUNTER_OK" : Gosub ENTREE From EXEFNC
                  If GPE=1
                     Goto ROL_TRT_LOT
                  Endif
                  #---
       When "V" : WABRLOT = WVCRNUM
      Endcase
   Endif

   If WABRLOT<>""
      # Lecture du lot
      Read [STL]STL0=[M:STW]ITMREF;WABRLOT;evalue(WABR+"SLO(IL)")
      If !fstat
         [M:STW] = [F:STL]
         WLOTLU  = 1
      Endif
   Endif
Endif

[M:STW]WAIFLG(NOL)    = 0
[M:STW]STU(NOL)       = [F:ITM]STU
[M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
[M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP

# Le lot n'existe pas
If WLOTLU<>1
   # Si article géré en lot et le complément lot existe
   If [F:ITM]LOTMGTCOD > 1 & IL<>-1 & WLOTLU<>1
      #[M:STW]LOT(NOL)    = evalue(WABR+"LOT(IL)")
      [M:STW]LOT(NOL)    = WABRLOT
      [M:STW]SLO(NOL)    = evalue(WABR+"SLO(IL)")
      [M:STW]BPSLOT(NOL) = evalue(WABR+"BPSLOT(IL)")
   Else
      Raz [M:STW]LOT(NOL), [M:STW]SLO(NOL), [M:STW]BPSLOT(NOL)
   Endif
Elsif [F:STL]BPSLOT <> evalue(WABR+"BPSLOT(IL)")
   [M:STW]BPSLOT(NOL) = evalue(WABR+"BPSLOT(IL)")
Endif

[M:STW]STA(NOL)       = evalue(WABR+"STA(I)")

# Stock propriétaire
#--------------------
If [M:STW]OWNER(NOL)=""
   # Si réception sous-traitance
   #--- Bug 56552
   #If [M:STW]TRSTYP=16 & [M:STW]VCRTYP=6 & [M:STW]BPSFCY<>""
   If [M:STW]TRSTYP=16 & WVCRTYP=6 & [M:STW]BPSFCY<>""
   #---
      [M:STW]OWNER(NOL) = [M:STW]BPSFCY
   # Si réintégration de stock
   Elsif [M:STW]TRSTYP=19 & WABR="[M:ENTW]" & [M:ENTW]OWNER(I)<>""
      [M:STW]OWNER(NOL) = [M:ENTW]OWNER(I)
   # Sinon le propriétaire est le site de stock
   Else
      [M:STW]OWNER(NOL) = [M:STW]STOFCY
   Endif
Endif

# Alimentation type et catégorie emplacement
#-------------------------------------------
# du mvt entrée dans [M:STW]LOCDES
# si retour de prêt ou de livraison sous-traitance ou plan de rangement
If find([M:STW]TRSTYP,18,33,22)
   [M:STW]LOCDES(NOL)    = evalue(WABR+"LOC(I)")
   [M:STW]LOCDESTYP(NOL) = evalue(WABR+"LOCTYP(I)")
   If evalue("dim("+WABR+"WRH(I))")>0
      [M:STW]WRHDES(NOL) = evalue(WABR+"WRH(I)")
   Endif
   WLOCTYP               = [M:STW]LOCDESTYP(NOL)
   WSTOFCY               = [M:STW]STOFCY
   WALI=1
   Gosub LEC_STOLOCTYP
   If LRET<>0 Return Endif
# du mvt entrée dans [M:STW]LOC
# pour les pièces effectuant des entrées
Else
   If evalue("dim("+WABR+"LOC(I))")>0
      [M:STW]LOC(NOL)    = evalue(WABR+"LOC(I)")
   Endif
   If evalue("dim("+WABR+"LOCTYP(I))")>0
      [M:STW]LOCTYP(NOL) = evalue(WABR+"LOCTYP(I)")
   Endif
   If evalue("dim("+WABR+"WRH(I))")>0
      [M:STW]WRH(NOL)    = evalue(WABR+"WRH(I)")
   Endif
   WLOCTYP = [M:STW]LOCTYP(NOL)
   WSTOFCY = [M:STW]STOFCY
   WALI=0
   Gosub LEC_STOLOCTYP
   If LRET<>0 Return Endif
Endif

If evalue("dim("+WABR+"SERNUM(I))")>0
   [M:STW]SERNUM(NOL) = evalue(WABR+"SERNUM(I)")
Endif
If evalue("dim("+WABR+"SERNUMF(I))")>0
   [M:STW]SERNUMF(NOL)   = evalue(WABR+"SERNUMF(I)")
Endif
If evalue("dim("+WABR+"PALNUM(I))")>0
   [M:STW]PALNUM(NOL)    = evalue(WABR+"PALNUM(I)")
Endif
If evalue("dim("+WABR+"CTRNUM(I))")>0
   [M:STW]CTRNUM(NOL)    = evalue(WABR+"CTRNUM(I)")
Endif
If evalue("dim("+WABR+"STOFLD1(I))")>0
   [M:STW]STOFLD1(NOL)   = evalue(WABR+"STOFLD1(I)")
Endif
If evalue("dim("+WABR+"STOFLD2(I))")>0
   [M:STW]STOFLD2(NOL)   = evalue(WABR+"STOFLD2(I)")
Endif
If evalue("dim("+WABR+"QUAFLG(I))")>0   # hcb V6CQ
   If WABR="[M:ENTW]"
      [M:STW]QUAFLG(NOL) = evalue(WABR+"QUAFLG(I)")
      [M:STW]QUAFRE(NOL) = evalue(WABR+"QUAFRE(I)")
   Else
      [M:STW]QUAFLG(NOL) = evalue(WABR+"QUAFLG")
      [M:STW]QUAFRE(NOL) = evalue(WABR+"QUAFRE")
   Endif
Endif
#--- Issue X3-53322
If evalue("dim("+WABR+"LPNNUM(I))")>0
   [M:STW]LPNNUM(NOL)    = evalue(WABR+"LPNNUM(I)")
Endif
#---

# Le lot n'existe pas
If WLOTLU<>1
   # Si article avec gestion de lot et le complément lot existe
   If [F:ITM]LOTMGTCOD > 1 & IL<>-1
      [M:STW]REFPER    (NOL) = evalue(WABR+"REFPER   (IL)")
      [M:STW]SHL       (NOL) = evalue(WABR+"SHL      (IL)")
      [M:STW]SHLDAT    (NOL) = evalue(WABR+"SHLDAT   (IL)")
      [M:STW]SHLUOM    (NOL) = evalue(WABR+"SHLUOM   (IL)")
      [M:STW]SHLLTI    (NOL) = evalue(WABR+"SHLLTI   (IL)")
      [M:STW]SHLLTIUOM (NOL) = evalue(WABR+"SHLLTIUOM(IL)")
      [M:STW]NEWLTIDAT (NOL) = evalue(WABR+"NEWLTIDAT(IL)")
      [M:STW]DLU       (NOL) = evalue(WABR+"DLU      (IL)")
      [M:STW]DLUDAT    (NOL) = evalue(WABR+"DLUDAT   (IL)")
      [M:STW]POT       (NOL) = evalue(WABR+"POT      (IL)")
      [M:STW]ACT       (NOL) = evalue(WABR+"ACT      (IL)")
      [M:STW]USRFLD1   (NOL) = evalue(WABR+"USRFLD1  (IL)")
      [M:STW]USRFLD2   (NOL) = evalue(WABR+"USRFLD2  (IL)")
      [M:STW]USRFLD3   (NOL) = evalue(WABR+"USRFLD3  (IL)")
      [M:STW]USRFLD4   (NOL) = evalue(WABR+"USRFLD4  (IL)")
      [M:STW]ECCVALMAJ (NOL) = evalue(WABR+"ECCVALMAJ(IL)")
      [M:STW]ECCVALMIN (NOL) = evalue(WABR+"ECCVALMIN(IL)")
   Else
      Raz [M:STW]REFPER (NOL)
      Raz [M:STW]SHL    (NOL)
      [M:STW]SHLDAT     (NOL)    = [31/12/2999]
      [M:STW]POT        (NOL)       = 100
      [M:STW]ACT        (NOL)       = 1
      [M:STW]SHLUOM     (NOL) = 1
      Raz [M:STW]SHLLTI (NOL)
      [M:STW]SHLLTIUOM  (NOL) = 1
      [M:STW]NEWLTIDAT  (NOL) = [31/12/2999]
      Raz [M:STW]DLU    (NOL)
      [M:STW]DLUDAT     (NOL) = [31/12/2999]
      Raz [M:STW]USRFLD1(NOL)
      Raz [M:STW]USRFLD2(NOL)
      Raz [M:STW]USRFLD3(NOL)
      Raz [M:STW]USRFLD4(NOL)
      Raz [M:STW]ECCVALMAJ (NOL)
      Raz [M:STW]ECCVALMIN (NOL)
   Endif
Endif

#--- Issue 118478
# Si modif mvt stock et complément lot renseigné il faut récupérer POT et ACT de ENM
If WABR="[M:ENM]"
   If IL<>-1
      [M:STW]POT(NOL) = [M:ENM]POT(IL)
      [M:STW]ACT(NOL) = [M:ENM]ACT(IL)
   Endif
Endif
#---

#connecteur GMAO/MMS
If GACTION='MMSINT'
   [M:STW]USRFLD1   (NOL) = "MMS"
Endif

[M:STW]MAJCOD(NOL)    = "C"
Case [M:STW]TRSTYP
 When 1,3,5,16 : [M:STW]MAJTYP(NOL)="E" : # Ent div, Rec fou, Décl prod, Rec s-trait
 When 18,33,22 : [M:STW]MAJTYP(NOL)="C" : # Ret prêt, Ret liv s-trait , Plan rangement
 When 12,19    : [M:STW]MAJTYP(NOL)="S" : # Ret/Avo cli, Réint stock
Endcase

# Si no série, PCU=STU et quantité=1
#--- Issue 110327 by TS : remplacement [F:ITM]SERMGTCOD=3 par [F:ITM]SERMGTCOD>=3
If [F:ITM]SERMGTCOD>=3
   Assign WABR+"PCU(I)"       With [M:STW]STU(NOL)
   Assign WABR+"PCUSTUCOE(I)" With 1
Endif

[M:STW]PCU(NOL)       = evalue(WABR+"PCU(I)")
[M:STW]PCUSTUCOE(NOL) = evalue(WABR+"PCUSTUCOE(I)")

# Si retour/avoir client ou réintégration stock (sortie-)
If find([M:STW]TRSTYP,12,19)
   [M:STW]QTYSTU(NOL)    = evalue(WABR+"QTYSTU(I)")*(-1)
   [M:STW]QTYPCU(NOL)    = evalue(WABR+"QTYPCU(I)")*(-1)
   [M:STW]QTYSTUACT(NOL) = evalue(WABR+"QTYSTU(I)")*(-1)
Else
   [M:STW]QTYSTU(NOL)    = evalue(WABR+"QTYSTU(I)")
   [M:STW]QTYPCU(NOL)    = evalue(WABR+"QTYPCU(I)")
   [M:STW]QTYSTUACT(NOL) = evalue(WABR+"QTYSTU(I)")
Endif

# Si réintégration stock, les qtés sont stockées en UA dans [M:ENTW]
If [M:STW]TRSTYP=19 & WABR="[M:ENTW]"
   # Si gestion en titres ou UI, calcul quantité en Unité Physique
   Case [F:ITF]STOMGTCOD
    When 3 : If [M:STW]POT(NOL)<>0
                [M:STW]QTYSTU(NOL)=[M:STW]QTYSTUACT(NOL)/([M:STW]POT(NOL)/100)
             Endif
             [M:STW]QTYPCU(NOL) = [M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
             Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV
    When 4 : If [M:STW]ACT(NOL)<>0
                [M:STW]QTYSTU(NOL)=[M:STW]QTYSTUACT(NOL)/ [M:STW]ACT
             Endif
             [M:STW]QTYPCU(NOL) = [M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
             Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV
   Endcase
Else
   # Si gestion en titres ou UI, calcul quantité en UA
   Case [F:ITF]STOMGTCOD
    When 3 : If [M:STW]POT(NOL)<>0
                [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)*([M:STW]POT(NOL)/100)
             Endif
    When 4 : If [M:STW]ACT(NOL)<>0
                [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)* [M:STW]ACT
             Endif
   Endcase
Endif

# Recherche des prix ordre et prix valorisé
# Si origine des données = [M:ENTW] (saisie de type entrée)
#    Si retour livraison(normale,prêt,sous-traitance), réintégration stock,
#       réception inter-site/intra-soc(normale,sous-traitance) --> prix mvt origine
#    Sinon récupération prix ordre (peut être saisi)
# Si origine des données = [M:ENM]  (modification de type entrée)
#    Récupération des prix appliqués lors de la création (stockés en entête)
Case WABR
 When "[M:ENTW]" : If [M:STW]VCRTYPORI<>0 & [M:STW]VCRNUMORI<>"" & [M:STW]VCRLINORI<>0
&                   & ((find([M:STW]TRSTYP,3,16) & [M:STW]TRFFCY<>"" &  [M:STW]BETCPY<>2)
&                      | find([M:STW]TRSTYP,12,18,33,19))
                      Gosub RECH_STJ_PRI
                   Else
                      [M:STW]PRIORD(NOL) = [M:STW]PRIORDH
                   Endif
                   If left$([M:STW]STA(NOL),1)="Q"
                      [M:STW]QLYCTLFLG(NOL) = [M:ENTW]QLYCTLFLG(I)
                   Else
                      [M:STW]QLYCTLFLG(NOL) = 1
                   Endif

 When "[M:ENM]"  : If [M:ENM]QLYCTLDEM<>""
                      Look [QLH]QLH0=28;[M:ENM]QLYCTLDEM
                      If fstat Raz [M:ENM]QLYCTLDEM Endif
                   Endif
                   [M:STW]QLYCTLDEM(NOL) = [M:ENM]QLYCTLDEM
                   If left$([M:STW]STA(NOL),1)="Q"
                      [M:STW]QLYCTLFLG(NOL) = [M:ENM]QLYCTLFLG
                   Else
                      [M:STW]QLYCTLFLG(NOL) = 1
                   Endif
                   # Si nouvelle ligne, prix stocké en entête
                   If [M:ENM]MVTSEQ(I)=0
                      [M:STW]PRINAT(NOL) = [M:ENM]PRINATH
                      [M:STW]PRIORD(NOL) = [M:ENM]PRIORDH
                      [M:STW]PRIVAL(NOL) = [M:ENM]PRIVALH
                   # Sinon prix du mouvement modifié
                   Else
                      [M:STW]PRINAT(NOL) = [M:ENM]PRINATH
                      [M:STW]PRIORD(NOL) = [M:ENM]PRIORD(I)
                      [M:STW]PRIVAL(NOL) = [M:ENM]PRIVAL(I)
                   Endif
Endcase

# Si retour liv(normale,sous-traitance) (inter-site) issu d'un retour fournisseur
# Chargement origine (pour mvt) avec retour fournisseur car
# c'est la livraison qui a été passée en origine (pour recherche prix)
If find([M:STW]TRSTYP,12,33) &
& [M:STW]VCRTYPORI2<>0 & [M:STW]VCRNUMORI2<>"" & [M:STW]VCRLINORI2<>0
   [M:STW]VCRTYPORI = [M:STW]VCRTYPORI2
   [M:STW]VCRNUMORI = [M:STW]VCRNUMORI2
   [M:STW]VCRLINORI = [M:STW]VCRLINORI2
   [M:STW]VCRSEQORI = 0
Endif

If evalue("dim("+WABR+"CSTCOU)")>0
   [M:STW]CSTCOU(NOL) = evalue(WABR+"CSTCOU(I)")
Endif
If evalue("dim("+WABR+"CSTDAT)")>0
   [M:STW]CSTDAT(NOL) = evalue(WABR+"CSTDAT(I)")
Endif
If evalue("dim("+WABR+"CSTTIM)")>0
   [M:STW]CSTTIM(NOL) = evalue(WABR+"CSTTIM(I)")
Endif

# Alimentation des sections analytiques
For J=1 To GNBDIE
   Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("WCCE"+num$(J))
Next J

# Alimentation impression étiquettes
[M:STW]LBEFMT(NOL) = evalue(WABR+"LBEFMT(I)")
[M:STW]LBENBR(NOL) = evalue(WABR+"LBENBR(I)")

# Transfert zones de l'écran STOENTW ou STOENTM vers l'écran STOWORK
GPOINT="ENTW_STW" : Gosub ENTREE From EXEFNC

# Quantité traitée
LQTY += evalue(WABR+"QTYSTU(I)")

#--- Issue 105775
# Si retour liv(normale,sous-traitance) (inter-site) issu d'un retour fournisseur
# restitution de l'origine avec la livraison
If find([M:STW]TRSTYP,12,33) &
& [M:STW]VCRTYPORI2<>0 & [M:STW]VCRNUMORI2<>"" & [M:STW]VCRLINORI2<>0
   [M:STW]VCRTYPORI = WVCRTYPORI
   [M:STW]VCRNUMORI = WVCRNUMORI
   [M:STW]VCRLINORI = WVCRLINORI
   [M:STW]VCRSEQORI = WVCRSEQORI
Endif
#---

Return

$RECUP_LOT
If [F:ITM]LOTCOU<>""
   WLOTCOU = [F:ITM]LOTCOU
Else
   GMESSAGE = mess(141,184,1) : Gosub TRT_ERR
   LRET=6 : Return
Endif
Call NUMERO(WLOTCOU,[M:STW]STOFCY,[M:STW]IPTDAT,
&           [F:ITM]ITMREF,WLOTCPT,WRET) From SUBANM
If GOK<0
   WESSAI+=1
Elsif WRET=1
   GMESSAGE = WLOTCOU-":"-mess(29,196,1) : Gosub TRT_ERR
   LRET=31
Elsif WRET=2
   GMESSAGE = WLOTCOU-":"-mess(30,196,1) : Gosub TRT_ERR
   LRET=31
Elsif WRET<>0
   GMESSAGE = WLOTCOU-":"-mess(60,199,1) : Gosub TRT_ERR
   LRET=31
Else
   WABRLOT = WLOTCPT
   WLOTLOT(INDLOT,1) = WLOTCPT
   WLOTLOT(INDLOT,0) = evalue(WABR+"BPSLOT(IL)")
   INDLOT+=1
Endif
Return

########################################################################
# Modification saisie de type 'sortie'
# Chargement pour création d'un nouveau mouvement
########################################################################
$CRE_SOM_STW

nolign += 1
NOL     = nolign-1

If NOL >= ACTSTW
   GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
   LRET=4 : Return
Endif

# Stockage des sections analytiques
For J=1 To GNBDIE
   Assign "WCCE"+num$(J) With evalue("[M:SOM]CCE(J-1)")
Next J

Gosub CHARGE_SOR_STW
If LRET<>0 Return Endif

[M:STW]NBLIG += 1

Return


########################################################################
# Modification saisie de type 'sortie'
# Chargement pour suppression d'un mouvement
########################################################################
$ANN_SOM_STW
Local Decimal LSTOCOU
# Alimentation mvt sortie à annuler
nolign += 1
NOL     = nolign-1
Local Integer Y1    # hcb 67536
Raz           Y1    # hcb 67536

If NOL >= ACTSTW
   GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
   LRET=4 : Return
Endif

# Alimentation mvt sortie à annuler
[M:STW] = [F:STJ]

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
  [M:STW]SERNUM(NOL) = [F:STJ]SERDEB
  [M:STW]SERNUMF(NOL)= [F:STJ]SERFIN
Endif
#---

For Y1=1 To GNBDIE                                # hcb 67536
    Assign "[M:STW]CCE"+num$(Y1)+"(NOL)" With    [F:STJ]CCE(Y1-1)
Next

# Pour les conserver sur les mvts de modif
WVCRTYPORI = [M:STW]VCRTYPORI
WVCRNUMORI = [M:STW]VCRNUMORI
WVCRLINORI = [M:STW]VCRLINORI
WVCRSEQORI = [M:STW]VCRSEQORI
WMVTDES    = [M:STW]MVTDES

[M:STW]ITMREFLIG(NOL) = [F:STJ]ITMREF
[M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP

# Si retour fournisseur (sous-traitance) (entrée-)
If find([M:STW]TRSTYP,11,32)
   [M:STW]QTYSTUACT(NOL) = [F:STJ]ACTQTY
Else
   [M:STW]QTYSTU(NOL)    = [F:STJ]QTYSTU*(-1)
   [M:STW]QTYSTUACT(NOL) = [F:STJ]ACTQTY*(-1)
   [M:STW]QTYPCU(NOL)    = [F:STJ]QTYPCU*(-1)
Endif

Raz [M:STW]WAIFLG(NOL)
If [F:STJ]UPDCOD<>2 [M:STW]WAIFLG(NOL)=1 Endif
[M:STW]MAJCOD(NOL)    = "A"
Case [M:STW]TRSTYP
 When 4,24,2,6,29 : [M:STW]MAJTYP(NOL)="S"  : # Liv/Fac, Dem Serv, Sortie Div,OF,Ordre s-trait
 When 17,20       : [M:STW]MAJTYP(NOL)="C"  : # Liv prêt, Liv s-trait
 When 11,32       : [M:STW]MAJTYP(NOL)="E"  : # Retour fou, Retour rec s-trait
Endcase

# Alimentation type et catégorie emplacement
# du mvt de sortie dans [M:STW]LOC
WALI    = 2
WLOCREF = [F:STJ]LOC
Gosub LEC_STOLOC
If LRET<>0 Return Endif

# Si liv prêt ou sous-traitance, on alimente [M:STW]STOCOU du mvt d'entrée
# et ce n'est pas un mouvement en attente
If find([M:STW]TRSTYP,17,20) & [M:STW]WAIFLG(NOL)<>1
   #--- Issue 110327 : ajout SERDEB et SERFIN
   Filter [STJ1] Where   STOFCY= [F:STJ]STOFCY
&                      & VCRTYP= [F:STJ]VCRTYP
&                      & VCRNUM= [F:STJ]VCRNUM
&                      & VCRLIN= [F:STJ]VCRLIN
&                      & ITMREF= [F:STJ]ITMREF
&                      & IPTDAT= [F:STJ]IPTDAT
&                      & LOT   = [F:STJ]LOT
&                      & SLO   = [F:STJ]SLO
&                      & SERNUM= [F:STJ]SERNUM
&                      & STA   = [F:STJ]STA
&                      & PALNUM= [F:STJ]PALNUM
&                      & CTRNUM= [F:STJ]CTRNUM
&                      & STOFLD1=[F:STJ]STOFLD1
&                      & STOFLD2=[F:STJ]STOFLD2
&                      & OWNER = [F:STJ]OWNER
&                      & QTYSTU=-[F:STJ]QTYSTU
&                      & REGFLG<>2
&                      & SERDEB= [F:STJ]SERDEB
&                      & SERFIN= [F:STJ]SERFIN
   Read [STJ1] STJ1 First
   If fstat
      GMESSAGE = mess(145,184,1) : Gosub TRT_ERR
      LRET=73 : Filter [STJ1] : Return
   Endif

   #--- Issue X3-53322 : Ajout LPN
   # Recherche du chrono stock correspondant au mouvement d'entrée
   Call CLESTO([F:STJ1]STOFCY,[F:STJ1]ITMREF,[F:STJ1]LOT,[F:STJ1]SLO,
&              [F:STJ1]BPSLOT,[F:STJ1]PALNUM,[F:STJ1]CTRNUM,[F:STJ1]STA,
&              [F:STJ1]LOC,[F:STJ1]PCU,[F:STJ1]PCUSTUCOE,[F:STJ1]SERNUM,
&              [F:STJ1]QLYCTLDEM,[F:STJ1]OWNER,[F:STJ]STOFLD1,[F:STJ]STOFLD2,
&              [F:STJ]LPNNUM,LSTOCOU) From STKLIB
   If LSTOCOU=0
      GMESSAGE = mess(144,184,1) : Gosub TRT_ERR
      LRET=72 : Filter [STJ1] : Return
   Else
      [M:STW]STOCOU(NOL) = LSTOCOU
   Endif

   Filter [STJ1]
Endif

[M:STW]NBLIG += 1

Return

########################################################################
# Chargement d'une ligne STW pour génération d'un mouvement de sortie
########################################################################
$CHARGE_SOR_STW
Local Char WPJT(GLONPJT)                      # hcb X3-109444
# Si l'origine est la saisie des sorties
If WABR="[M:SOW]"
   If [M:SOW]WSTOCOU(I)<>0
      # Lecture du stock
      Readlock [STO]STO0=[M:STW]STOFCY;[M:SOW]WSTOCOU(I)
      If fstat
         Call RSTA("STO",[M:STW]STOFCY-[M:STW]ITMREF-num$([M:SOW]WSTOCOU(I))) From GLOCK
         LRET=54 : Return
      # Emplacement bloqué pour inventaire
      Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
         If [F:ITF]LOCMGTCOD=2
             GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
         Else
             GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
         Endif
         Gosub TRT_ERR
         LRET=21 : Unlock [STO] : Return
      # Emplacement en attente de rangement
      Elsif [F:STO]LOCCAT=2
         # Contrôle que les lignes de stock en attente de rangement sont complètes
         Call CTLPLFLOC([M:STW]ITMREF,"",LRET) From STKSOR
         If LRET<>0
            GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
            GMESSAGE+="\"+mess(377,199,1)-":"
            Case LRET
             When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
             When 2 : GMESSAGE+=mess(453,197,1)
             When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
            Endcase
            Gosub TRT_ERR
            LRET=22 : Unlock [STO] : Return
         Endif
      Endif
      WPJT       = [M:STW]PJT               # hcb X3-109444
      [M:STW]    = [F:STO]
      [M:STW]PJT = WPJT                     # hcb X3-109444

      # Mise à jour de la quantité en cours de traitement
      [F:STO]CUMWIPQTY -= max(0,[M:SOW]WQTYSTU(I)-[M:SOW]WALLSTU(I))
      [F:STO]CUMWIPQTA -= max(0,[M:SOW]WQTYSTUACT(I)-[M:SOW]WALLSTUACT(I))
      # Dans le cas où l'on serait passé en négatif
      [F:STO]CUMWIPQTY  = max(0,[F:STO]CUMWIPQTY)
      [F:STO]CUMWIPQTA  = max(0,[F:STO]CUMWIPQTA)

      # Suppression qté en cours de traitement
      LSTOCOU = [F:STO]STOCOU
      LWIPQTY = [M:SOW]WQTYSTU(I)-[M:SOW]WALLSTU(I)
      Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB

      Rewrite [STO]
      If fstat
         GOK =0  : Call FSTA("STO") From GLOCK
         LRET=64 : Return
      Endif

      #--- Issue 110327
      # Suppression no série en cours de traitement
      If [F:ITM]SERMGTCOD=4 & [M:SOW]WSERNUM(I)<>""
         Call DEL_STOSERW([F:STO]ITMREF,[M:SOW]WSERNUM(I),[M:SOW]WQTYSTU(I),LRET) From STKLIB
         If LRET<>0
            LRET=74
            GOK=0
         Endif
      Endif
      #---

      # Lecture du lot
      Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
      If fstat
         Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
         LRET=53 : Return
      Endif
      [M:STW] = [F:STL]
      [M:STW]WAIFLG(NOL) = 0

      # Si réapprovisionnement d'une allocation déjà existante, il faudra
      # la consommer en priorité
      If WVCRTYP=34 & [M:STW]SEQALL<>0
         [M:STW]PIOQTY=3
      Else
         [M:STW]PIOQTY=1
      Endif

   # Mouvement en attente et stock négatif interdit
   Elsif WNEGSTO<>2
      GMESSAGE =[M:STW]STOFCY-[M:STW]ITMREF-":"-mess(123,192,1) : Gosub TRT_ERR
      LRET=12 : Return
   # Mouvement en attente
   Else
      [M:STW]WAIFLG(NOL) = 1
      # Chargement zones de rupture
      [M:STW]LOT(NOL)    = [M:SOW]WLOT(I)
      [M:STW]SLO(NOL)    = [M:SOW]WSLO(I)
      [M:STW]STA(NOL)    = [M:SOW]WSTA(I)
      [M:STW]WRH(NOL)    = [M:SOW]WWRH(I)
      [M:STW]LOC(NOL)    = [M:SOW]WLOC(I)
      If [M:STW]LOC(NOL)<>""
         WLOCREF=[M:STW]LOC(NOL)
         WALI=0
         Gosub LEC_STOLOC
      Endif
      #--- TS 106217
      [M:STW]ECCVALMAJ(NOL) = [M:SOW]WECCVALMAJ(I)
   Endif

# Si l'origine est la modification des sorties
Elsif WABR="[M:SOM]"
   # Mouvement mis à jour
   If [M:SOM]WAIFLG(I)=0
      # Chrono stock existant
      If [M:SOM]STOCOU(I)<>0
         # Lecture du stock
         Read [STO]STO0=[M:STW]STOFCY;[M:SOM]STOCOU(I)
         If fstat
            Call RSTA("STO",[M:STW]STOFCY-[M:STW]ITMREF-num$([M:SOM]STOCOU(I))) From GLOCK
            LRET=54 : Return
         # Emplacement bloqué pour inventaire
         Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
            If [F:ITF]LOCMGTCOD=2
                GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
            Else
                GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
            Endif
            Gosub TRT_ERR
            LRET=21 : Return
         # Emplacement en attente de rangement
         Elsif [F:STO]LOCCAT=2
            # Contrôle que les lignes de stock en attente de rangement sont complètes
            Call CTLPLFLOC([M:STW]ITMREF,"",LRET) From STKSOR
            If LRET<>0
               GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
               GMESSAGE+="\"+mess(377,199,1)-":"
               Case LRET
                When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
                When 2 : GMESSAGE+=mess(453,197,1)
                When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
               Endcase
               Gosub TRT_ERR
               LRET=22 : Return
            Endif
         Endif
         WPJT       = [M:STW]PJT               # hcb X3-109444
         [M:STW]    = [F:STO]
         [M:STW]PJT = WPJT                     # hcb X3-109444
         # Lecture du lot
         Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
         If fstat
            Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
            LRET=53 : Return
         Endif
         [M:STW] = [F:STL]
      # Pas de chrono stock
      Else
         If dim([M:SOM]LOT)>0 [M:STW]LOT(NOL)=[M:SOM]LOT(I) Endif
         If dim([M:SOM]SLO)>0 [M:STW]SLO(NOL)=[M:SOM]SLO(I) Endif
         #--- TS 106217
         If dim([M:SOM]ECCVALMAJ)>0 [M:STW]ECCVALMAJ(NOL)=[M:SOM]ECCVALMAJ(I) Endif
         # Lecture du lot
         Read [STL]STL0=[M:STW]ITMREF;[M:STW]LOT(NOL);[M:STW]SLO(NOL)
         If !fstat
            [M:STW] = [F:STL]
         Endif
         [M:STW]STA(NOL) = [M:SOM]STA(I)
         If dim([M:SOM]WRH)>0 [M:STW]WRH(NOL)=[M:SOM]WRH(I) Endif
         If dim([M:SOM]LOC)>0 [M:STW]LOC(NOL)=[M:SOM]LOC(I) Endif
         If [M:STW]LOC(NOL)<>""
            WLOCREF=[M:STW]LOC(NOL)
            WALI=0
            Gosub LEC_STOLOC
         Endif
         #--- Bug 61477
         If dim([M:SOM]PALNUM)>0 [M:STW]PALNUM(NOL)=[M:SOM]PALNUM(I) Endif
         If dim([M:SOM]CTRNUM)>0 [M:STW]CTRNUM(NOL)=[M:SOM]CTRNUM(I) Endif
         #---
         If dim([M:SOM]STOFLD1)>0 [M:STW]STOFLD1(NOL)=[M:SOM]STOFLD1(I) Endif
         If dim([M:SOM]STOFLD2)>0 [M:STW]STOFLD2(NOL)=[M:SOM]STOFLD2(I) Endif
         [M:STW]OWNER(NOL)     = [M:SOM]OWNER(I)
         [M:STW]PCU(NOL)       = [M:SOM]XPCU(I)
         [M:STW]PCUSTUCOE(NOL) = [M:SOM]XPCUSTUCOE(I)
      Endif

      [M:STW]WAIFLG(NOL) = 0

   # Mouvement en attente et stock négatif interdit
   Elsif WNEGSTO<>2
      GMESSAGE =[M:STW]STOFCY-[M:STW]ITMREF-":"-mess(123,192,1) : Gosub TRT_ERR
      LRET=12 : Return
   # Mouvement en attente
   Else
      [M:STW]WAIFLG(NOL) = 1
      # Chargement zones de rupture
      [M:STW]STA(NOL) = [M:SOM]STA(I)
      If dim([M:SOM]LOT)>0 [M:STW]LOT(NOL)=[M:SOM]LOT(I) Endif
      If dim([M:SOM]SLO)>0 [M:STW]SLO(NOL)=[M:SOM]SLO(I) Endif
      If dim([M:SOM]WRH)>0 [M:STW]WRH(NOL)=[M:SOM]WRH(I) Endif
      If dim([M:SOM]LOC)>0 [M:STW]LOC(NOL)=[M:SOM]LOC(I) Endif
      If [M:STW]LOC(NOL)<>""
         WLOCREF=[M:STW]LOC(NOL)
         WALI=0
         Gosub LEC_STOLOC
      Endif
      #--- TS 106217
      If dim([M:SOM]ECCVALMAJ)>0 [M:STW]ECCVALMAJ(NOL)=[M:SOM]ECCVALMAJ(I) Endif
   Endif
Endif

[M:STW]STU(NOL)       = [F:ITM]STU
[M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
[M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP

# Si no série saisi (géré en sortie, E/S globale ou rupture) : #--- Issue 110327
# Alimentation du no série fin
If WABR="[M:SOW]"
   If [M:SOW]WSERNUM(I)<>""
      [M:STW]SERNUM(NOL) = [M:SOW]WSERNUM(I)
      WNB = [M:SOW]WQTYSTUACT(I)
      If WNB = 1
         [M:STW]SERNUMF(NOL) = [M:STW]SERNUM(NOL)
      Else
         Call PLUS_NB([M:STW]SERNUM(NOL),WNB,[M:STW]SERNUMF(NOL),WRET)
&                     From STKLIB
         If WRET<>0
            Raz [M:STW]SERNUM(NOL), [M:STW]SERNUMF(NOL)
         Endif
      Endif
   Endif
Else
   If dim([M:SOM]SERNUM)>0  [M:STW]SERNUM(NOL) =[M:SOM]SERNUM(I)  Endif
   If dim([M:SOM]SERNUMF)>0 [M:STW]SERNUMF(NOL)=[M:SOM]SERNUMF(I) Endif
Endif

[M:STW]MAJCOD(NOL)    = "C"
Case [M:STW]TRSTYP
 When 4,24,2,6,29 : [M:STW]MAJTYP(NOL)="S"  : # Liv/Fac, Dem Serv, Sortie Div,OF,Ordre s-trait
 When 17,20,25    : [M:STW]MAJTYP(NOL)="C"  : # Liv prêt, Liv s-trait , Réappro zones conso
                    Raz [M:STW]LPNNUM(NOL)  : # Issue X3-53322 un changement d'emp impose un raz du LPN
 When 11,32       : [M:STW]MAJTYP(NOL)="E"  : # Retour fou, Retour rec s-trait
Endcase

If WABR="[M:SOW]"
   # Si retour fournisseur (sous-traitance) (entrée-)
   If find([M:STW]TRSTYP,11,32)
      [M:STW]QTYSTU(NOL)    = [M:SOW]WQTYSTU(I)*(-1)
      [M:STW]QTYSTUACT(NOL) = [M:SOW]WQTYSTUACT(I)*(-1)
   Else
      [M:STW]QTYSTU(NOL)    = [M:SOW]WQTYSTU(I)
      [M:STW]QTYSTUACT(NOL) = [M:SOW]WQTYSTUACT(I)
   Endif
Else
   # Si retour fournisseur (sous-traitance) (entrée-)
   If find([M:STW]TRSTYP,11,32)
      [M:STW]QTYSTU(NOL)    = [M:SOM]QTYSTU(I)*(-1)
      [M:STW]QTYSTUACT(NOL) = [M:SOM]QTYSTUACT(I)*(-1)
   Else
      [M:STW]QTYSTU(NOL)    = [M:SOM]QTYSTU(I)
      [M:STW]QTYSTUACT(NOL) = [M:SOM]QTYSTUACT(I)
   Endif
Endif
# Si mvt en attente, on force à 0 la qté en US
If [M:STW]WAIFLG(NOL)=1 Raz [M:STW]QTYSTU(NOL) Endif

# Attention si mvt en attente, les zones QTYSTU et QTYPCU sont nulles
If [M:STW]PCUSTUCOE(NOL)=0 [M:STW]PCUSTUCOE(NOL)=1 Endif
[M:STW]QTYPCU(NOL)=[M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV

# Recherche des prix ordre et prix valorisé
# Si origine des données = [M:SOW] (saisie de type sortie)
#    Si retour réception(normale,sous-traitance)
#       désassemblage d'un composé --> prix mvt origine
#    Sinon prix calculés dans moteur de maj
# Si origine des données = [M:SOM] (modification de type sortie)
#    Récupération des prix appliqués lors de la création (stockés en entête)

If WABR="[M:SOW]"
   If (find([M:STW]TRSTYP,11,32) | ([M:STW]TRSTYP=2 & WVCRTYP=32)) &
&     [M:STW]VCRTYPORI<>0 & [M:STW]VCRNUMORI<>"" & [M:STW]VCRLINORI<>0
      Gosub RECH_STJ_PRI
   Endif
Else
   # Si nouvelle ligne, prix stocké en entête
   If [M:SOM]MVTSEQ(I)=0
      [M:STW]PRINAT(NOL) = [M:SOM]PRINATH
      [M:STW]PRIORD(NOL) = [M:SOM]PRIORDH
      [M:STW]PRIVAL(NOL) = [M:SOM]PRIVALH
   # Sinon prix du mouvement modifié
   Else
      [M:STW]PRINAT(NOL) = [M:SOM]PRINATH
      [M:STW]PRIORD(NOL) = [M:SOM]PRIORD(I)
      [M:STW]PRIVAL(NOL) = [M:SOM]PRIVAL(I)
   Endif
Endif

# Alimentation des sections analytiques
For J=1 To GNBDIE
   Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("WCCE"+num$(J))
Next J

# Chargement emplacement destination dans [M:STW]LOCDES
Case [M:STW]TRSTYP
 When 17 : WLOCREF=[M:STW]LOCENT            : # Liv prêt
           WALI=1
           Gosub LEC_STOLOC
           If LRET<>0 Return Endif
           If [F:STC]LOCCAT<>3
              GMESSAGE = [M:STW]LOCDES-":"-mess(243,192,1) : Gosub TRT_ERR
              LRET=24 : Return
           Endif
 When 20 : WLOCREF=[M:STW]LOCENT            : # Liv sous-traitance
           WALI=1
           Gosub LEC_STOLOC
           If LRET<>0 Return Endif
           If [F:STC]LOCCAT<>4
              GMESSAGE = [M:STW]LOCDES-":"-mess(244,192,1) : Gosub TRT_ERR
              LRET=23 : Return
           Endif
 When 25 : WLOCREF=[M:STW]LOCENT            : # Réappro zones de consommation
           WALI=1
           Gosub LEC_STOLOC
           If LRET<>0 Return Endif
Endcase

#connecteur GMAO/MMS
If GACTION='MMSINT'
   [M:STW]USRFLD1   (NOL) = "MMS"
Endif

# Transfert zones de l'écran STOSORW ou STOSORM vers l'écran STOWORK
GPOINT="SOW_STW" : Gosub ENTREE From EXEFNC

If WABR="[M:SOW]"
   If [M:STW]WAIFLG(NOL)=1
      LSHT += [M:SOW]WQTYSTUACT(I)
   Else
      LQTY += [M:SOW]WQTYSTU(I)
   Endif
Else
   If [M:STW]WAIFLG(NOL)=1
      LSHT += [M:SOM]QTYSTUACT(I)
   Else
      LQTY += [M:SOM]QTYSTU(I)
   Endif
Endif

#--- Bug 71421
# Si sortie d'un mvt en attente avec no série géré en sortie ou en E/S global: #--- Issue 110327
# et saisie alors création d'un STW par no série pour la régularisation des mvts
Gosub SER_STW
If LRET Return Endif
#---

Return

########################################################################
# Recherche des prix ordre et prix valorisé du mouvement origine
# si retour (achat/vente) ou réintégration de stock
########################################################################
$RECH_STJ_PRI
# Si réception inter-site
If [M:STW]TRSTYP=3
   WCRIT1  = 'STOFCY=[M:STW]TRFFCY'
# Si retour client
Elsif [M:STW]TRSTYP=12
   WCRIT1  = 'STOFCY=[M:STW]ORIFCY'
Else
   WCRIT1  = 'STOFCY=[M:STW]STOFCY'
Endif
WCRIT1 += '& VCRTYP=[M:STW]VCRTYPORI & VCRNUM=[M:STW]VCRNUMORI & VCRLIN=[M:STW]VCRLINORI'
WCRIT1 += '& LOT=[M:STW]LOT(NOL) & SLO=[M:STW]SLO(NOL) & UPDCOD=2'
#--- Issue 115206
If [M:STW]TRSTYP=32 : WCRIT1 += '& TRSTYP<>29' : Endif
#---

# On utilise STJ0 comme ordre de tri afin d'avoir la dernière écriture
# du mouvement qui contient la valeur régularisée.
Filter [STJ] Where evalue(WCRIT1) Order By Key STJ0
Read [STJ] First Hint Key STJ1
If !fstat
   [M:STW]PRIORD(NOL) = [F:STJ]PRIORD
   [M:STW]PRIVAL(NOL) = [F:STJ]PRIVAL
   # On force 'Prix Ordre'
   [M:STW]PRINAT(NOL) = 8
Endif
Filter [STJ]

GPOINT="CHGPRIORD" : Gosub ENTREE From EXEFNC

Return

########################################################################
# Lecture emplacement
########################################################################
$LEC_STOLOC

# Pas de gestion d'emplacement
If WLOCREF=""
   If WALI=1
      [M:STW]LOCDES(NOL)    = ""
      [M:STW]LOCDESTYP(NOL) = ""
      [M:STW]LOCDESCAT(NOL) = 1
      [M:STW]WRHDES(NOL)    = ""
   Else
      [M:STW]LOC(NOL)       = ""
      [M:STW]LOCTYP(NOL)    = ""
      [M:STW]LOCCAT(NOL)    = 1
      [M:STW]WRH(NOL)       = ""
   Endif
   Return
Endif

If [F:STC]LOC<>WLOCREF
   Read [STC]STC0=[M:STW]STOFCY;WLOCREF
   If fstat & WALI=1
      GMESSAGE = WLOCREF-":"-mess(233,192,1)-":"-[M:STW]STOFCY : Gosub TRT_ERR
      LRET=55 : Return
   Endif
Endif
If WALI=1
   # Emplacement de destination
   [M:STW]LOCDES(NOL)   =[F:STC]LOC
   [M:STW]LOCDESTYP(NOL)=[F:STC]LOCTYP
   [M:STW]LOCDESCAT(NOL)=[F:STC]LOCCAT
   [M:STW]WRHDES(NOL)   =[F:STC]WRH
Else
   # Emplacement mouvement (de rupture)
   [M:STW]LOC(NOL)      =[F:STC]LOC
   [M:STW]LOCTYP(NOL)   =[F:STC]LOCTYP
   [M:STW]LOCCAT(NOL)   =[F:STC]LOCCAT
   [M:STW]WRH(NOL)      =[F:STC]WRH
Endif
Return

########################################################################
# Lecture type emplacement
########################################################################
$LEC_STOLOCTYP

# Pas de gestion d'emplacement
If WLOCTYP=""
   If WALI=1
      [M:STW]LOCDESCAT(NOL) = 1
   Else
      [M:STW]LOCCAT(NOL)    = 1
   Endif
   Return
Endif

If [F:TLO]LOCTYP<>WLOCTYP
   Read [TLO]TLO0=WSTOFCY;WLOCTYP
   If fstat
      GMESSAGE = WLOCTYP-":"-mess(245,192,1)-":"-WSTOFCY : Gosub TRT_ERR
      LRET=56 : Return
   Endif
Endif
If WALI=1
   # Emplacement de destination
   [M:STW]LOCDESCAT(NOL)=[F:TLO]LOCCAT
Else
   # Emplacement de l'entrée
   [M:STW]LOCCAT(NOL)   = [F:TLO]LOCCAT
Endif
Return



########################################################################
# Alimentation de STOWORK à partir des inventaires CUNLISDET
########################################################################
$ORI_CUNLISDET
Local Integer L, WNEWPCUCOE

If clalev([F:CUD])=0  Local File CUNLISDET  [CUD] Endif

Raz [M:SVW]
# Sélection sur site,session,liste,détail compté,article
For [CUD]CUD1 Where [F:CUD]STOFCY    = [M:STW]STOFCY    &
&                   [F:CUD]ITMREF    = [M:STW]ITMREF    &
&                   [F:CUD]CUNLISNUM = [M:STW]VCRNUM    &
&                   [F:CUD]CUNSSSNUM = [M:STW]VCRNUMORI &
&                   [F:CUD]CUNLISSTA = 2
   Readlock [CUD] Curr
   If fstat
      Call RSTA("CUD",[F:CUD]STOFCY-[F:CUD]ITMREF-[F:CUD]CUNLISNUM) From GLOCK
      LRET=58 : Break
   Endif

   # Stockage des sections analytiques (la première fois)
   If WFIRSTANA=0
      For J=1 To GNBDIE
#         GAXE=J
         Call INISEC(SECTION,[M:STW]CCECOD,J) From TRTX3CPT
         Assign "WCCE"+num$(J) With SECTION
      Next J
      WFIRSTANA+=1
   Endif

   # Nb inventaires
   LNBR += 1
   # Quantité inventaire calculé
   LQTY += [F:CUD]QTYSTU
   # Quantité inventaire compté
   LSHT += [F:CUD]QTYSTUNEW
   # Qté compté = Qté en stock --> pas de mouvement
   If [F:CUD]QTYSTUNEW=[F:CUD]QTYSTU & [F:CUD]QTYPCUNEW=[F:CUD]QTYPCU
      # Nb inventaires justes
      LNBJ += 1
      If [F:CUD]STOCOU<>0
         # Mise à jour du stock (déverrouillage ou suppression)
         Readlock [STO]STO0=[F:CUD]STOFCY;[F:CUD]STOCOU
         If fstat
            Call RSTA("STO",[F:CUD]STOFCY-num$([F:CUD]STOCOU)) From GLOCK
            LRET=54 : Break
         Elsif [F:STO]QTYSTU=0
            Delete [STO]
            If fstat
               GOK=0  : Call FSTA("STO") From GLOCK
               LRET=64 : Break
            Endif
         Else
            [F:STO]CUNLOKFLG = 1
            [F:STO]CUNLISNUM = ""
            [F:STO]LASCUNDAT = [M:STW]IPTDAT
            Rewrite [STO]
            If fstat
               GOK=0  : Call FSTA("STO") From GLOCK
               LRET=64 : Break
            Endif
         Endif
      Endif
      Goto ORI_CUNLISDET_SUI
   Endif

   Raz WNEWPCUCOE
   # S'il ne s'agit pas d'une nouvelle ligne de stock inventoriée et
   # si le coeff calculé à partir des quantités US et UC comptées est
   # différent de celui de la ligne de stock, il faut créer deux [M:STW]
   If [F:CUD]STOCOU<>0 & [F:CUD]QTYSTUNEW<>0 & [F:CUD]QTYPCUNEW<>0 &
&     [F:CUD]PCUSTUCOE<>[F:CUD]QTYSTUNEW/[F:CUD]QTYPCUNEW
      WNEWPCUCOE = 1
   Endif

   If [F:CUD]STOCOU<>0
      Read [STO]STO0=[F:CUD]STOFCY;[F:CUD]STOCOU
      If fstat
         Call RSTA("STO",[F:CUD]STOFCY-num$([F:CUD]STOCOU)) From GLOCK
         LRET=54 : Break
      # La qté allouée est supérieure à la qte comptée
      Elsif WNEWPCUCOE<>1 & [F:STO]CUMALLQTY>[F:CUD]QTYSTUNEW
         GMESSAGE = mess(450,199,1) : Gosub TRT_ERR
         LRET=15 : Break
      Endif
   Endif

   nolign += 1
   NOL     = nolign-1

   If NOL >= ACTSTW
      GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
      LRET=4 : Break
   Endif

   # Point d'entrée debut validation apres lecture detail inventaire
   GPOINT = "VALCUD"
   Gosub  ENTREE From EXEFNC

   # Alimentation à partir de l'inventaire
   [M:STW] = [F:CUD]

   # Car elle est cassée par le trans_classe
   [M:STW]IPTDAT=SAVIPTDAT

   # Alimentation à partir du stock
   If [F:CUD]STOCOU<>0 [M:STW]=[F:STO] Endif
   # Alimentation à partir du lot
   Read [STL]STL0=[F:CUD]ITMREF;[F:CUD]LOT;[F:CUD]SLO
   If fstat
      Call RSTA("STL",[F:CUD]ITMREF-[F:CUD]LOT-[F:CUD]SLO) From GLOCK
      LRET=53 : Break
   Endif
   [M:STW] = [F:STL]

   [M:STW]STU(NOL)       = [F:ITM]STU
   [M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
   [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
   # Dans STKMAJ si inventaire, il faut alimenter [F:STJ]VCRLIN avec MVTSEQ
   [M:STW]MVTSEQ(NOL)    = [F:CUD]ITMLISNUM
   [M:STW]MAJCOD(NOL)    = "C"

   [M:STW]QLYCTLFLG(NOL) = 1

   If WNEWPCUCOE=1
      [M:STW]MAJTYP(NOL) = "S"
      [M:STW]QTYSTU(NOL) = [F:CUD]QTYSTU
      [M:STW]QTYPCU(NOL) = [F:CUD]QTYPCU
   Else
      # Qte comptée > Qte en stock
      If [F:CUD]QTYSTUNEW>[F:CUD]QTYSTU
         [M:STW]MAJTYP(NOL) = "E"
      Else
         [M:STW]MAJTYP(NOL) = "S"
      Endif
      [M:STW]QTYSTU(NOL) = abs([F:CUD]QTYSTUNEW-[F:CUD]QTYSTU)
      [M:STW]QTYPCU(NOL) = abs([F:CUD]QTYPCUNEW-[F:CUD]QTYPCU)
      If [F:CUD]STOCOU=0
         [M:STW]PCUSTUCOE(NOL) = [M:STW]QTYSTU(NOL)/[M:STW]QTYPCU(NOL)
      Endif
   Endif

#                                                                        # hcb 110327 deb
#   For J=0 To GACTMAT-1
#       [M:SVW]OMATCST(NOL*GACTMAT+J) = [F:CUD]MATCST(J)*[M:STW]QTYSTU(NOL)
#   Next
#   [M:SVW]OOVEMATTOT(NOL) = [F:CUD]OVEMATCST*[M:STW]QTYSTU(NOL)
#   [M:SVW]OMATTOT(NOL)  = sum([F:CUD]MATCST)*[M:STW]QTYSTU(NOL)
#   For J=0 To GACTMAC-1
#       [M:SVW]OMACCST(NOL*GACTMAC+J) = [F:CUD]MACCST(J)*[M:STW]QTYSTU(NOL)
#   Next
#   [M:SVW]OOVEMACTOT(NOL) = [F:CUD]OVEMACCST*[M:STW]QTYSTU(NOL)
#   [M:SVW]OMACTOT(NOL)  = sum([F:CUD]MACCST)*[M:STW]QTYSTU(NOL)
#   For J=0 To GACTLAB-1
#       [M:SVW]OLABCST(NOL*GACTLAB+J) = [F:CUD]LABCST(J)*[M:STW]QTYSTU(NOL)
#   Next
#   [M:SVW]OOVELABTOT(NOL) = [F:CUD]OVELABCST*[M:STW]QTYSTU(NOL)
#   [M:SVW]OLABTOT(NOL)  = sum([F:CUD]LABCST)*[M:STW]QTYSTU(NOL)
#   [M:SVW]OSCOTOT(NOL)  = [F:CUD]SCOCST*[M:STW]QTYSTU(NOL)
#   [M:SVW]OOVESCOTOT(NOL) = [F:CUD]OVESCOCST*[M:STW]QTYSTU(NOL)
#   [M:SVW]OINVDTA(NOL)  = [F:CUD]INVDTACST*[M:STW]QTYSTU(NOL)
#   [M:SVW]PRIORD(NOL) = [F:CUD]PRIORD
#   If GACTDECCST
#       [M:SVW]AMTORD(NOL) = [M:SVW]OMATTOT(NOL)+[M:SVW]OMACTOT(NOL)+[M:SVW]OLABTOT(NOL)
#&                         + [M:SVW]OSCOTOT(NOL)+[M:SVW]OINVDTA(NOL)
#&                         + [M:SVW]OOVEMATTOT(NOL)+[M:SVW]OOVEMACTOT(NOL)+[M:SVW]OOVELABTOT(NOL)+[M:SVW]OOVESCOTOT(NOL)
#   Else
#       [M:SVW]AMTORD(NOL)=[M:SVW]PRIORD(NOL)*[M:STW]QTYSTU(NOL)
#   Endif
#                                                                        # hcb 110327 fin

   # Calcul quantité UA
   [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)
   # Si gestion en titres ou UI
   Case [F:ITF]STOMGTCOD
    When 3 : If [F:STL]POT<>0
                [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)*([F:STL]POT/100)
             Endif
    When 4 : If [F:STL]ACT<>0
                [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)*[F:STL]ACT
             Endif
   Endcase

   # Issue 118426 - 2016-10-26 by CCC : [SVW] must contain unit price for active quantity
   If [M:STW]QTYSTU(NOL) <> [M:STW]QTYSTUACT(NOL) & [M:STW]QTYSTUACT(NOL)<>0
       [M:SVW]PRIORD     (NOL)           = [M:SVW]AMTORD   (NOL) / [M:STW]QTYSTUACT(NOL)
   Endif

   WALI=2
   WLOCREF=[F:CUD]LOC
   Gosub LEC_STOLOC
   If LRET<>0 Break Endif

   # Alimentation des sections analytiques
   For J=1 To GNBDIE
      Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("WCCE"+num$(J))
   Next J

   # Transfert zones du détail inventaire vers l'écran STOWORK
   GPOINT="CUD_STW" : Gosub ENTREE From EXEFNC

   [M:STW]NBLIG += 1

#                                                                     # hcb 110327 deb
#    si l article est suisi en serie globale il faut alimenter STOWORK avec la table CUNSERDET
   If [F:CUD]SERSEQ   <> 0
      Gosub ALI_STW_CSD From STKINV1
   Else
      Gosub ORI_CUNLISDET_SVW
   Endif
#                                                                     # hcb 110327 fin

   If WNEWPCUCOE=1
      nolign += 1
      NOL     = nolign-1
      If NOL >= ACTSTW
         GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
         LRET=4 : Break
      Endif

      L = NOL-1
      Gosub ALI_NEW_STW From STKMAJ

      [M:STW]MAJTYP(NOL)    = "E"
      [M:STW]QTYSTU(NOL)    = [F:CUD]QTYSTUNEW
      [M:STW]QTYPCU(NOL)    = [F:CUD]QTYPCUNEW
      [M:STW]PCUSTUCOE(NOL) = [F:CUD]QTYSTUNEW/[F:CUD]QTYPCUNEW
      If [F:CUD]QTYSTUNEW=[F:CUD]QTYPCUNEW
         [M:STW]PCU(NOL) = [M:STW]STU(NOL)
      Endif
      # Calcul quantité UA
      [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)
      # Si gestion en titres ou UI
      Case [F:ITF]STOMGTCOD
       When 3 : If [F:STL]POT<>0
                   [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)*([F:STL]POT/100)
                Endif
       When 4 : If [F:STL]ACT<>0
                   [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)*[F:STL]ACT
                Endif
      Endcase

      # Transfert zones du détail inventaire vers l'écran STOWORK
      GPOINT="CUD_STW" : Gosub ENTREE From EXEFNC

      [M:STW]NBLIG += 1
#                                                                        # hcb 110327 deb
      Gosub ORI_CUNLISDET_SVW
#       For J=0 To GACTMAT-1
#           [M:SVW]OMATCST(NOL*GACTMAT+J) = [F:CUD]MATCST(J)*[M:STW]QTYSTU(NOL)
#       Next
#      [M:SVW]OOVEMATTOT(NOL) = [F:CUD]OVEMATCST*[M:STW]QTYSTU(NOL)
#      [M:SVW]OMATTOT(NOL)  = sum([F:CUD]MATCST)*[M:STW]QTYSTU(NOL)
#       For J=0 To GACTMAC-1
#           [M:SVW]OMACCST(NOL*GACTMAC+J) = [F:CUD]MACCST(J)*[M:STW]QTYSTU(NOL)
#       Next
#      [M:SVW]OOVEMACTOT(NOL) = [F:CUD]OVEMACCST*[M:STW]QTYSTU(NOL)
#      [M:SVW]OMACTOT(NOL)  = sum([F:CUD]MACCST)*[M:STW]QTYSTU(NOL)
#       For J=0 To GACTLAB-1
#           [M:SVW]OLABCST(NOL*GACTLAB+J) = [F:CUD]LABCST(J)*[M:STW]QTYSTU(NOL)
#       Next
#      [M:SVW]OOVELABTOT(NOL) = [F:CUD]OVELABCST*[M:STW]QTYSTU(NOL)
#      [M:SVW]OLABTOT(NOL)  = sum([F:CUD]LABCST)*[M:STW]QTYSTU(NOL)
#      [M:SVW]OSCOTOT(NOL)  = [F:CUD]SCOCST*[M:STW]QTYSTU(NOL)
#      [M:SVW]OOVESCOTOT(NOL) = [F:CUD]OVESCOCST*[M:STW]QTYSTU(NOL)
#      [M:SVW]OINVDTA(NOL)  = [F:CUD]INVDTACST*[M:STW]QTYSTU(NOL)
#      [M:SVW]PRIORD(NOL) = [F:CUD]PRIORD
#      [M:SVW]AMTORD(NOL) = [M:SVW]OMATTOT(NOL)+[M:SVW]OMACTOT(NOL)+[M:SVW]OLABTOT(NOL)
#&                     + [M:SVW]OSCOTOT(NOL)+[M:SVW]OINVDTA(NOL)
#&                     + [M:SVW]OOVEMATTOT(NOL)+[M:SVW]OOVEMACTOT(NOL)+[M:SVW]OOVELABTOT(NOL)+[M:SVW]OOVESCOTOT(NOL)
#                                                                       # hcb 110327 fin

   Endif
   #-------------------------------

   $ORI_CUNLISDET_SUI

   # Maj flags validé et déverrouillé
   [F:CUD]CUNLISSTA = 4
   [F:CUD]CUNLOKFLG = 1
   [F:CUD]IPTDAT    = date$
   [F:CUD]UPDUSR    = GUSER
   [F:CUD]UPDDAT    = date$
   # Point d'entrée validation  detail inventaire   hcb 60894
   GPOINT = "ALLVALCUD"
   Gosub  ENTREE From EXEFNC
   Rewrite [CUD]
   If fstat
      Call FSTA("CUD") From GLOCK
      LRET=68 : Break
   Endif

Next

If LRET<>0
   GOK=0 : Return
Endif

Return

#                                                          # hcb 110327 deb
$ORI_CUNLISDET_SVW
For J=0 To GACTMAT-1
    [M:SVW]OMATCST(NOL*GACTMAT+J) = [F:CUD]MATCST(J)*[M:STW]QTYSTU  (NOL)
Next
[M:SVW]OOVEMATTOT (NOL)           = [F:CUD]OVEMATCST*[M:STW]QTYSTU  (NOL)
[M:SVW]OMATTOT    (NOL)           = sum([F:CUD]MATCST)*[M:STW]QTYSTU(NOL)
For J=0 To GACTMAC-1
    [M:SVW]OMACCST(NOL*GACTMAC+J) = [F:CUD]MACCST(J)*[M:STW]QTYSTU  (NOL)
Next
[M:SVW]OOVEMACTOT (NOL)           = [F:CUD]OVEMACCST*[M:STW]QTYSTU  (NOL)
[M:SVW]OMACTOT    (NOL)               = sum([F:CUD]MACCST)*[M:STW]QTYSTU(NOL)
For J=0 To GACTLAB-1
    [M:SVW]OLABCST(NOL*GACTLAB+J) = [F:CUD]LABCST(J)*[M:STW]QTYSTU  (NOL)
Next
[M:SVW]OOVELABTOT (NOL)           = [F:CUD]OVELABCST*[M:STW]QTYSTU  (NOL)
[M:SVW]OLABTOT    (NOL)           = sum([F:CUD]LABCST)*[M:STW]QTYSTU(NOL)
[M:SVW]OSCOTOT    (NOL)           = [F:CUD]SCOCST*[M:STW]QTYSTU     (NOL)
[M:SVW]OOVESCOTOT (NOL)           = [F:CUD]OVESCOCST*[M:STW]QTYSTU  (NOL)
[M:SVW]OINVDTA    (NOL)           = [F:CUD]INVDTACST*[M:STW]QTYSTU  (NOL)
[M:SVW]PRIORD     (NOL)           = [F:CUD]PRIORD
If GACTDECCST
  [M:SVW]AMTORD   (NOL)           = [M:SVW]OMATTOT(NOL)+[M:SVW]OMACTOT(NOL)+[M:SVW]OLABTOT(NOL)
&                                 + [M:SVW]OSCOTOT(NOL)+[M:SVW]OINVDTA(NOL)
&                                 + [M:SVW]OOVEMATTOT(NOL)+[M:SVW]OOVEMACTOT(NOL)+[M:SVW]OOVELABTOT(NOL)+[M:SVW]OOVESCOTOT(NOL)
Else
  [M:SVW]AMTORD   (NOL)           =[M:SVW]PRIORD(NOL)*[M:STW]QTYSTU(NOL)
Endif

# Issue 118426 - 2016-10-26 by CCC : [SVW] must contain unit price for active quantity
If [M:STW]QTYSTU(NOL) <> [M:STW]QTYSTUACT(NOL) & [M:STW]QTYSTUACT(NOL)<>0
    [M:SVW]PRIORD     (NOL)           = [M:SVW]AMTORD   (NOL) / [M:STW]QTYSTUACT(NOL)
Endif

Return
#                                                          # hcb 110327 fin

########################################################################
# Alimentation de STOWORK à partir des mouvements de stock STOJOU
########################################################################
$ORI_STOJOU
Local Decimal LSTOCOU
Local Decimal LQTYSVG   : LQTYSVG = LQTY
#                               hcb 73746 deb
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Char    WLOC(GLONLOC)
Local Char    WPALNUM(GLONPAL)
Local Char    WCTRNUM(GLONCTR)
Local Char    WSTA(5)
Local Char    WSERNUM(GLONSER)
Local Char    WPCU(GLONUOM)
Local Decimal WPCUSTUCOE
Local Char    WBPSLOT(GLONLOT)
Local Char    WQLYCTLDEM(GLONVCR)
Local Char    WOWNER(GLONFCY)
Local Char    WSTOFLD1(GLONSF1)
Local Char    WSTOFLD2(GLONSF2)
Local Char    WLPNNUM(GLONTPLN)       : #--- Issue X3-53322
Local Integer WLECTURE
#                               hcb 73746 fin


#--- Bug 71975
Local Decimal WQTYFAC, WQTYRET
If !clalev([F:STJ1])  Local File STOJOU    [STJ1]  Endif
#---
#--- Bug 72387
# Calcul quantité totale retournée
Local Decimal WQTYRETTOT
For [STJ1]STJ0 Where STOFCY=[M:STW]STOFCY & UPDCOD=2 & ITMREF=[M:STW]ITMREF
&                  & TRSTYP=18 & VCRTYPORI=WVCRTYPORI & VCRNUMORI=WVCRNUMORI
&                  & VCRLINORI=WVCRLINORI & REGFLG<>2 & QTYSTU<0
   WQTYRETTOT+=abs([F:STJ1]QTYSTU)
Next
#---
#                               hcb 73746 deb

Raz WLECTURE
Raz WQTYFAC
Filter [STJ] Where STOFCY=[M:STW]STOFCY & VCRTYP=WVCRTYPORI &
&                  VCRNUM=WVCRNUMORI    & VCRLIN=WVCRLINORI &
&                  REGFLG<>2 & QTYSTU>0
&            Order By Key CLE = LOT;SLO;LOC;PALNUM;CTRNUM;STA;SERNUM;PCU;PCUSTUCOE;OWNER

For [STJ]
    If WLECTURE   = 0
       WLECTURE   = 1
       WLOT       =[F:STJ]LOT
       WSLO       =[F:STJ]SLO
       WLOC       =[F:STJ]LOC
       WPALNUM    =[F:STJ]PALNUM
       WCTRNUM    =[F:STJ]CTRNUM
       WSTA       =[F:STJ]STA
       WSERNUM    =[F:STJ]SERNUM
       WPCU       =[F:STJ]PCU
       WPCUSTUCOE =[F:STJ]PCUSTUCOE
       WBPSLOT    =[F:STJ]BPSLOT
       WQLYCTLDEM =[F:STJ]QLYCTLDEM
       WOWNER     =[F:STJ]OWNER
       WSTOFLD1   =[F:STJ]STOFLD1
       WSTOFLD2   =[F:STJ]STOFLD2
       WLPNNUM    =[F:STJ]LPNNUM     : #--- Issue X3-53322
    Endif
    If WLOT      =[F:STJ]LOT         &
&      WSLO      =[F:STJ]SLO         &
&      WLOC      =[F:STJ]LOC         &
&      WPALNUM   =[F:STJ]PALNUM      &
&      WCTRNUM   =[F:STJ]CTRNUM      &
&      WSTA      =[F:STJ]STA         &
&      WSERNUM   =[F:STJ]SERNUM      &
&      WPCU      =[F:STJ]PCU         &
&      WPCUSTUCOE=[F:STJ]PCUSTUCOE   &
&      WOWNER    =[F:STJ]OWNER       &
&      WSTOFLD1  =[F:STJ]STOFLD1     &
&      WSTOFLD2  =[F:STJ]STOFLD2     &
&      WLPNNUM    =[F:STJ]LPNNUM     : #--- Issue X3-53322
       WQTYFAC  +=[F:STJ]QTYSTU
    Else

       Gosub ORI_STOJOU_TRT
       Raz WQTYFAC
       If LRET <> 0
          Break
       Endif
       Break(LQTY=0)
       WLOT       =[F:STJ]LOT
       WSLO       =[F:STJ]SLO
       WLOC       =[F:STJ]LOC
       WPALNUM    =[F:STJ]PALNUM
       WCTRNUM    =[F:STJ]CTRNUM
       WSTA       =[F:STJ]STA
       WSERNUM    =[F:STJ]SERNUM
       WPCU       =[F:STJ]PCU
       WPCUSTUCOE =[F:STJ]PCUSTUCOE
       WBPSLOT    =[F:STJ]BPSLOT
       WQLYCTLDEM =[F:STJ]QLYCTLDEM
       WOWNER     =[F:STJ]OWNER
       WSTOFLD1   =[F:STJ]STOFLD1
       WSTOFLD2   =[F:STJ]STOFLD2
       WLPNNUM    =[F:STJ]LPNNUM     : #--- Issue X3-53322
       WQTYFAC    =[F:STJ]QTYSTU
    Endif
$ORI_STOJOU_SUI
Next
Filter [STJ]
If WQTYFAC <> 0
   Gosub ORI_STOJOU_TRT
Endif
#                               hcb 73746 fin

If LQTY<>0
   LQTY = LQTYSVG - LQTY
Else
   LQTY = LQTYSVG
Endif
If LRET<>0
   GOK=0 : Return
Endif
Return

#                               hcb 73746 deb
$ORI_STOJOU_TRT
      #--- Issue X3-53322 : Ajout LPN
      # Recherche du chrono stock correspondant au mouvement
       Call CLESTO([M:STW]STOFCY,[M:STW]ITMREF,WLOT,WSLO,WBPSLOT,
&                 WPALNUM,WCTRNUM,WSTA,WLOC,WPCU,
&                 WPCUSTUCOE,WSERNUM,WQLYCTLDEM,WOWNER,WSTOFLD1,WSTOFLD2,WLPNNUM,LSTOCOU)
&      From STKLIB

       If LSTOCOU=0 Goto ORI_STOJOU_TRT_END  Endif

       Raz WQTYRET

       If WQTYRETTOT>0
   #---
          #--- Issue X3-53322 : Ajout LPN
          For [STJ1]STJ0 Where STOFCY=[M:STW]STOFCY & UPDCOD=2 & ITMREF=[M:STW]ITMREF
&                            & TRSTYP=18 & VCRTYPORI=WVCRTYPORI & VCRNUMORI=WVCRNUMORI
&                            & VCRLINORI=WVCRLINORI & REGFLG<>2 & QTYSTU<0
&                            & LOT=WLOT & SLO=WSLO & LOC=WLOC
&                            & PALNUM=WPALNUM & CTRNUM=WCTRNUM
&                            & STA=WSTA & SERNUM=WSERNUM & PCU=WPCU
&                            & PCUSTUCOE=WPCUSTUCOE & OWNER = WOWNER
&                            & STOFLD1=WSTOFLD1 & STOFLD2=WSTOFLD2 & LPNNUM=WLPNNUM
              WQTYRET+=abs([F:STJ1]QTYSTU)
          Next
      # Décrémentation quantité totale retournée
          If WQTYRETTOT>=WQTYRET
             WQTYRETTOT-=WQTYRET
          Else
      # Sinon raz quantité totale retournée (ne devrait pas arriver)
             WQTYRET-=WQTYRETTOT
             WQTYRETTOT=0
          Endif
       Endif

   # Calcul qte restant à facturer
       If WQTYFAC>WQTYRET
          WQTYFAC-=WQTYRET
   # Tout a été retourné
       Else
          WQTYFAC=0
          Goto ORI_STOJOU_TRT_END
       Endif
   #---
       nolign += 1
       NOL     = nolign-1

       If NOL >= ACTSTW
          GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
          LRET=4
          Goto ORI_STOJOU_TRT_END
       Endif

   # Lecture du stock
       Read [STO]STO0=[M:STW]STOFCY;LSTOCOU
       If fstat
          Call RSTA("STO",[M:STW]STOFCY-[M:STW]ITMREF-num$(LSTOCOU)) From GLOCK
          LRET=54
          Goto ORI_STOJOU_TRT_END
    # Emplacement bloqué pour inventaire
       Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
          If [F:ITF]LOCMGTCOD=2
              GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
          Else
              GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
          Endif
          Gosub TRT_ERR
          LRET=21
          Goto ORI_STOJOU_TRT_END
       Endif

       [M:STW] = [F:STO]

       [M:STW]QTYSTU(NOL)    = min(LQTY,[F:STO]QTYSTU,WQTYFAC)
      #---
       [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)
       LQTY -= [M:STW]QTYSTU(NOL)

   # Lecture du lot
       Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
       If fstat
          Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
          LRET=53
          Goto ORI_STOJOU_TRT_END
       Endif

       [M:STW] = [F:STL]
       [M:STW]WAIFLG(NOL) = 0

   # Si no série saisi (géré en sortie ou rupture)
   # Alimentation du no série fin
       #--- Issue 110327
       If [F:ITM]SERMGTCOD<>4
         If [M:STW]SERNUM(NOL)<>""
           WNB = [M:STW]QTYSTUACT(NOL)
           If WNB = 1
             [M:STW]SERNUMF(NOL) = [M:STW]SERNUM(NOL)
           Else
             Call PLUS_NB([M:STW]SERNUM(NOL),WNB,[M:STW]SERNUMF(NOL),WRET) From STKLIB
             If WRET<>0
               Raz [M:STW]SERNUM(NOL), [M:STW]SERNUMF(NOL)
             Endif
           Endif
         Endif
       #--- Issue 110327
       Endif

       [M:STW]STU(NOL)       = [F:ITM]STU
       [M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
       [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
       [M:STW]MAJCOD(NOL)    = "C"
       [M:STW]MAJTYP(NOL)    = "S"

       If [M:STW]PCUSTUCOE(NOL)=0 [M:STW]PCUSTUCOE(NOL)=1 Endif
       [M:STW]QTYPCU(NOL)=[M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
       Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV

   # Alimentation des sections analytiques
       #Gbn-Fq76488
       #For J=1 To GOPTCANA
       #   Assign "[M:STW]CCE"+num$(J)+"(NOL)" With evalue("[F:STJ]CCE"+num$(J))
       #Next J
       For J=1 To GNBDIE
          Assign "[M:STW]CCE"+num$(J)+"(NOL)" With [F:STJ]CCE(J-1)
       Next J

       [M:STW]NBLIG += 1

       #--- Issue 110327
       If [F:ITM]SERMGTCOD=4
         Filter [STS] Where ITMREF=[F:STO]ITMREF & [F:STO]STOCOU
&                         & SDHTYP=WVCRTYPORI & SDHNUM=WVCRNUMORI & SDDLIN=WVCRLINORI
&                     Order By Key STS3
         If rowcount([STS])<[M:STW]QTYSTU(NOL)
           LRET=75 : GMESSAGE = mess(490,199,1)
           Gosub TRT_ERR
           Filter [STS]
           Goto ORI_STOJOU_TRT_END
         Endif
         WNB  = 0
         WQTY = [M:STW]QTYSTU(NOL)
         For [STS] Where ITMREF=[F:STO]ITMREF & [F:STO]STOCOU
&                      & SDHTYP=WVCRTYPORI & SDHNUM=WVCRNUMORI & SDDLIN=WVCRLINORI
           If WNB=0
             # Premier no série de la séquence
             [M:STW]SERNUM(NOL)  = [F:STS]SERNUM
             [M:STW]SERNUMF(NOL) = [F:STS]SERNUM
             WNB  += 1
             WQTY -= 1
           Else
             # Le no série correspond-il au début d'une nouvelle séquence
             Call PLUS_UN([M:STW]SERNUMF(NOL),WSERNUM,WRET) From STKLIB
             # Le no série poursuit la séquence
             If WRET=0 & [F:STS]SERNUM=WSERNUM
               [M:STW]SERNUMF(NOL) = [F:STS]SERNUM
               WNB  += 1
               WQTY -= 1
             # Le no série débute une nouvelle séquence
             Else
               # Recalcul nouvelle quantité de la séquence
               [M:STW]QTYSTU(NOL)    = WNB
               [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)
               [M:STW]QTYPCU(NOL)    = [M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
               Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV
               # Alimentation de la nouvelle séquence
               nolign += 1
               NOL     = nolign-1
               If NOL >= ACTSTW
                 GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
                 LRET=4
                 Goto ORI_STOJOU_TRT_END
               Endif
               [M:STW] = [F:STO]
               [M:STW]QTYSTU(NOL)    = WQTY
               [M:STW]QTYSTUACT(NOL) = [M:STW]QTYSTU(NOL)
               [M:STW] = [F:STL]
               [M:STW]WAIFLG(NOL) = 0
               [M:STW]STU(NOL)       = [F:ITM]STU
               [M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
               [M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
               [M:STW]MAJCOD(NOL)    = "C"
               [M:STW]MAJTYP(NOL)    = "S"
               [M:STW]QTYPCU(NOL)=[M:STW]QTYSTU(NOL)/[M:STW]PCUSTUCOE(NOL)
               Call QTEARR([M:STW]QTYPCU(NOL),[M:STW]PCU(NOL)) From TRTDIV
               # Alimentation des sections analytiques
               For J=1 To GOPTCANA
                 Assign "[M:STW]CCE"+num$(J)+"(NOL)" With [F:STJ]CCE(J-1)
               Next J
               # Premier no série de la séquence
               [M:STW]SERNUM(NOL)  = [F:STS]SERNUM
               [M:STW]SERNUMF(NOL) = [F:STS]SERNUM
               [M:STW]NBLIG += 1
               WNB   = 1
               WQTY -= 1
             Endif
           Endif
           If WQTY<=0 : Break : Endif
         Next
         Filter [STS]
       Endif
       #--- End issue 110327

$ORI_STOJOU_TRT_END
Return
#                               hcb 73746 fin

########################################################################
# Alimentation de STOWORK à partir des demandes d'analyses de QCR1
########################################################################
$ORI_QCR1

# Lecture du stock
Readlock [STO]STO0=[M:STW]STOFCY;[M:QCR1]WSTOCOU(LLIG)
If fstat
   Call RSTA("STO",[M:STW]STOFCY-[M:STW]ITMREF-num$([M:QCR1]WSTOCOU(LLIG))) From GLOCK
   LRET=54 : Return
# Emplacement bloqué pour inventaire
Elsif [F:ITF]CUNFLG=2 & [F:STO]CUNLOKFLG=2
   If [F:ITF]LOCMGTCOD=2
      GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(175,193,1)
   Else
      GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-":"-mess(185,199,1)
   Endif
      Gosub TRT_ERR
      LRET=21 : Unlock [STO] : Return
   # Emplacement en attente de rangement
Elsif [F:STO]LOCCAT=2
   # Contrôle que les lignes de stock en attente de rangement sont complètes
   Call CTLPLFLOC([M:STW]ITMREF,"",LRET) From STKSOR
   If LRET<>0
      GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
      GMESSAGE+="\"+mess(377,199,1)-":"
      Case LRET
       When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
       When 2 : GMESSAGE+=mess(453,197,1)
       When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
      Endcase
      Gosub TRT_ERR
      LRET=22 : Unlock [STO] : Return
   Endif
Endif

nolign += 1
NOL     = nolign-1

[M:STW] = [F:STO]

# Mise à jour de la quantité en cours de traitement
[F:STO]CUMWIPQTY -= max(0,[M:QCR1]WWIPQTY(LLIG))
[F:STO]CUMWIPQTA -= max(0,[M:QCR1]WWIPQTA(LLIG))
# Dans le cas où l'on serait passé en négatif
[F:STO]CUMWIPQTY  = max(0,[F:STO]CUMWIPQTY)
[F:STO]CUMWIPQTA  = max(0,[F:STO]CUMWIPQTA)

# Suppression qté en cours de traitement
Call DEL_STOWIPW([F:STO]STOCOU,[M:QCR1]QTYSTUDES(LLIG)) From STKLIB

#                                                                                               # hcb 110327 deb
# Suppression no série en cours de traitement
If [F:ITM]SERMGTCOD=4 & [M:QCR1]SERNUM(LLIG)<>""
   Call DEL_STOSERW([F:STO]ITMREF,[M:QCR1]SERNUM(LLIG),[M:QCR1]QTYSTUDES(LLIG),LRET) From STKLIB
   If LRET<>0
      LRET=74
      GOK=0
   Else
      [M:STW]SERNUM   (NOL) = [M:QCR1]SERNUM(LLIG)
      [M:STW]SERNUMF  (NOL) = [M:QCR1]SERNUMF(LLIG)
   Endif
Endif
#                                                                                               # hcb 110327 end

Rewrite [STO]
If fstat
   GOK=0  : Call FSTA("STO") From GLOCK
   LRET=64 : Return
Endif

# Lecture du lot
Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   LRET=53 : Return
Endif
[M:STW] = [F:STL]

[M:STW]MAJCOD   (NOL) = "C"
[M:STW]WAIFLG   (NOL) = 0
[M:STW]STU      (NOL) = [F:ITM]STU
[M:STW]ITMREFLIG(NOL) = [M:STW]ITMREF
[M:STW]TRSTYPLIG(NOL) = [M:STW]TRSTYP
[M:STW]MAJTYP   (NOL) = "C"
[M:STW]QTYSTU   (NOL) = [M:QCR1]QTYSTUDES(LLIG)
[M:STW]QTYSTUACT(NOL) = [M:QCR1]QTYSTUDES(LLIG)

# Si gestion en titres ou UI, calcul quantité en UA
Case [F:ITF]STOMGTCOD
 When 3 : If [M:STW]POT(NOL)<>0
             [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)*([M:STW]POT(NOL)/100)
          Endif
 When 4 : If [M:STW]ACT(NOL)<>0
             [M:STW]QTYSTUACT(NOL)=[M:STW]QTYSTU(NOL)* [M:STW]ACT
          Endif
Endcase

# Si changement de statut
If [M:QCR1]STADES(LLIG)<>""
   [M:STW]STA(NOL) = [M:QCR1]STADES(LLIG)
Endif

# Génération demande d'analyse
If left$([M:STW]STA(NOL),1)="Q"
   [M:STW]QLYCTLFLG(NOL) = 2
Else
   [M:STW]QLYCTLFLG(NOL) = 1
Endif

# Chargement emplacement destination
If dim([M:QCR1]WRH) > 0
   [M:STW]WRHDES   (NOL) = [M:QCR1]WRH    (LLIG)
Endif
If dim([M:QCR1]LOC) > 0
   [M:STW]LOCDES   (NOL) = [M:QCR1]LOC    (LLIG)
   [M:STW]LOCDESTYP(NOL) = [M:QCR1]LOCTYP (LLIG)
Endif

WLOCTYP = [M:STW]LOCDESTYP(NOL)
WSTOFCY = [M:STW]STOFCY
WALI=1
Gosub LEC_STOLOCTYP
If LRET<>0 Return Endif

# Transfert zones de l'écran QCR1 vers l'écran STOWORK
GPOINT="QCR1_STW" : Gosub ENTREE From EXEFNC

[M:STW]NBLIG += 1

If LRET<>0
   GOK=0 : Return
Endif

Return

#--- Bug 62346
########################################################################
# Ajout d'une ligne à STOWORK
# l'entête est assumée par le programme appelant (après)
# la fiche article est en ligne
# Avec maj des quantités en cours de traitement (STOWIPW)
########################################################################
Subprog ADDSTWLIN(LMAJCOD, LMAJTYP, LSTOFCY, LSTOCOU, LQTYPCU, LQTYSTU, LSERDEB, LSERFIN, LRET) # hcb 110327
Value     Char    LMAJCOD
Value     Char    LMAJTYP
Value     Char    LSTOFCY
Value     Decimal LSTOCOU
Value     Decimal LQTYPCU
Value     Decimal LQTYSTU
Value     Char    LSERDEB            # hcb 110327
Value     Char    LSERFIN            # hcb 110327
Variable  Integer LRET

If clalev([F:SWW])=0  Local File STOWIPW [SWW]  Endif

LRET=0
# Ajout d'une ligne dans STOWORK
Call ADDSTOWORKLIN(LMAJCOD, LMAJTYP, LSTOFCY, LSTOCOU, LQTYPCU, LQTYSTU, LSERDEB, LSERFIN, LRET) # hcb 110327
If LRET>0 End Endif

#--- Maj des cumuls quantité en cours de traitement
[F:STO]CUMWIPQTY = max(0,[F:STO]CUMWIPQTY-LQTYSTU)
[F:STO]CUMWIPQTA = max(0,[F:STO]CUMWIPQTA-(LQTYSTU*[F:STL]POT/100))
Call DEL_STOWIPW([F:STO]STOCOU,LQTYSTU) From STKLIB
Rewrite [STO]
If fstat
   Call FSTA("STO") From GLOCK
   LRET=64 : End
Endif

End
#--- Fin Bug 62346

########################################################################
# Ajout d'une ligne à STOWORK
# l'entête est assumée par le programme appelant (après)
# la fiche article est en ligne
########################################################################
Subprog ADDSTOWORKLIN(LMAJCOD, LMAJTYP, LSTOFCY, LSTOCOU, LQTYPCU, LQTYSTU, LSERDEB, LSERFIN, LRET) # hcb 110327
Value     Char    LMAJCOD
Value     Char    LMAJTYP
Value     Char    LSTOFCY
Value     Decimal LSTOCOU
Value     Decimal LQTYPCU
Value     Decimal LQTYSTU
Value     Char    LSERDEB            # hcb 110327
Value     Char    LSERFIN            # hcb 110327
Variable  Integer LRET

Local     Integer ACTSTW
Local     Integer NOL : NOL = [M:STW]NBLIG

# Lecture du stock
Readlock [STO]STO0=LSTOFCY;LSTOCOU
If fstat
      Call RSTA("STO", LSTOFCY-[M:STW]ITMREF-num$(LSTOCOU)) From GLOCK
      LRET=54 : End
Endif
nolign = NOL+1

If !clalev([F:ACV])  Local File ACTIV  [ACV]  Endif
If [F:ACV]CODACT<>"STW"
   Read [ACV]CODACT="STW"
   If !fstat ACTSTW=[F:ACV]DIME Endif
Else
   ACTSTW=[F:ACV]DIME
Endif

If ACTSTW = 0
   GMESSAGE = mess(339,199,1)-'STW' : Gosub TRT_ERR
   LRET=4 : End
Elsif NOL >= ACTSTW
   GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
   LRET=4 : End
Endif

[M:STW] = [F:STO]

# Lecture du lot
Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
    Call RSTA("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
    LRET=53 : End
Endif
[M:STW] = [F:STL]

[M:STW]MAJCOD(NOL)     = LMAJCOD
[M:STW]WAIFLG(NOL)     = 0
[M:STW]STU(NOL)        = [F:ITM]STU
[M:STW]ITMREFLIG(NOL)  = [M:STW]ITMREF
[M:STW]TRSTYPLIG(NOL)  = [M:STW]TRSTYP
[M:STW]MAJTYP(NOL)     = LMAJTYP
[M:STW]QTYPCU(NOL)     = LQTYPCU
[M:STW]QTYSTU(NOL)     = LQTYSTU
[M:STW]QTYSTUACT(NOL)  = LQTYSTU * [M:STW]POT(NOL)/100
#                                                           # hcb 110327 deb
If [F:ITM]SERMGTCOD = 4
   [M:STW]SERNUM (NOL)  = LSERDEB
   [M:STW]SERNUMF(NOL)  = LSERFIN
Endif
#                                                           # hcb 110327 fin
[M:STW]NBLIG += 1

End

#--- Bug 71421
#############################################################################
# Si sortie d'un mvt attente avec no série géré en sortie ou en E/S global: #--- Issue 110327
# et saisie alors création d'un STW par no série pour la régularisation des mvts
#############################################################################
$SER_STW
# Si flux de sortie
If [M:STW]MAJTYP(NOL)="S"
   # Si no série saisi (rupture), mouvement en attente et qté > 1
   # création d'un STW par no série (pour la régularisation du mvt)
   If [M:STW]SERNUM(NOL)<>"" & [M:STW]WAIFLG(NOL)=1 & [M:STW]QTYSTUACT(NOL)>1
      WNB = [M:STW]QTYSTUACT(NOL)
      # Dimension de STW insuffisante
      If NOL+WNB > ACTSTW
         GMESSAGE = mess(490,199,1) : Gosub TRT_ERR
         LRET=4 : Return
      Endif

      [M:STW]QTYSTUACT(NOL) = 1
      [M:STW]SERNUMF(NOL)   = [M:STW]SERNUM(NOL)
      If [M:STW]QTYSTU(NOL)<>0    [M:STW]QTYSTU(NOL)=1    Endif
      If [M:STW]QTYPCU(NOL)<>0    [M:STW]QTYPCU(NOL)=1    Endif
      If [M:STW]LBENBR(NOL)<>0    [M:STW]LBENBR(NOL)=1    Endif
      If [M:STW]QTYACTORI(NOL)<>0 [M:STW]QTYACTORI(NOL)=1 Endif
      L=NOL
      WNB-=1
      While WNB>0
        Insa L+1,1,[M:STW]NBLIG+1 [M:STW]NBLIG
        [M:STW]NBLIG+=1
        [M:STW]STOCOU(L+1) = [M:STW]STOCOU(L)
        Gosub ALI_NEW_STW From STKMAJ
        [M:STW]QTYSTUACT(L+1) = 1
        Call PLUS_UN([M:STW]SERNUM(L),[M:STW]SERNUM(L+1),WRET) From STKLIB
        [M:STW]SERNUMF(L+1)   = [M:STW]SERNUM(L+1)
        nolign+=1
        L  +=1
        WNB-=1
      Wend
   Endif
Endif
Return
#---

#########################################################################
$TRT_ERR
If GTRACE<>""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
GOK=0
Return

#########################################################################
$TRT_MSG
If GTRACE<>""
  Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Else
  Call MESSAGE(GMESSAGE)     From GESECRAN
Endif
Return

#--- Issue X3-53322
########################################################################
# SPLIT_ENTW_LPN  Splittage des STOENTW selon la capacité du contenant
#                 lorsque les LPN sont créés à la volée
#                 Ce composant n'est appelé que si LORI=2
#
########################################################################

########################################################################
# Paramètres E :  LLIG = Lien avec ligne document
#                        --> [M:XXX]WSTOSEQ(nolign-1)
#
########################################################################
Subprog SPLIT_ENTW_LPN (LLIG)
Value    Integer LLIG

Local Integer I, J
Local Integer IEND
Local Integer INEXT
Local Integer ILPN
Local Integer LRET, RET
Local Integer NBLPN
Local Decimal QTYLPN
Local Decimal QTYDER
Local Char    LSERF(GLONSER)

If !clalev([F:SRU])  : Local File TABSTORUL    [SRU]  : Endif
If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
If !clalev([F:FCY])  : Local File FACILITY     [FCY]  : Endif
If !clalev([F:TCTR]) : Local File TABCONTAINER [TCTR] : Endif

Call LECSRU([M:STW]STOFCY,[F:ITM]TCLCOD,[M:STW]TRSTYP,[M:STW]TRSCOD,"",LRET) From STKLIB
If LRET<>0 : End : Endif

# Si identifiant contenant facultatif
If [F:SRU]DACCTR<>2 : End : Endif

# Gestion de la classe des LPN
Global Instance WLPN Using C_LPN

# Indice maxi à traiter dans STOENTW
IEND  = [M:ENTW]NBLIG-1
# Prochain indice à prendre -1
INEXT = [M:ENTW]NBLIG-1

For I=0 To IEND
   # La ligne de l'écran de travail ne concerne pas cette ligne de document
   If [M:ENTW]WSTOSEQ(I)<>LLIG : Goto NEXT_STOENTW : Endif
   # La ligne de l'écran de travail contient un LPNNUM
   If [M:ENTW]LPNNUM(I)<>""    : Goto NEXT_STOENTW : Endif
   # La ligne de l'écran de travail ne contient pas de contenant
   If [M:ENTW]TCTRNUM(I)=""    : Goto NEXT_STOENTW : Endif
   #--- Issue X3-53322
   If [M:ENTW]LOCTYP(I)<>[F:TLO]LOCTYP
     Read [TLO]TLO0=[M:STW]STOFCY;[M:ENTW]LOCTYP(I)
     If fstat : Goto NEXT_STOENTW : Endif
   Endif
   # Pas de LPN sur les emplacements externes
   If [F:TLO]LOCCAT>2 : Goto NEXT_STOENTW : Endif
   #---

   # Calcul du nombre de LPN nécessaires avec leurs capacités
   Call CALCUL_NBENTW ([M:ENTW]TCTRNUM(I),[M:STW]ITMREF,[M:STW]STOFCY,[M:ENTW]PCU(I),[M:ENTW]QTYPCU(I),
&                      NBLPN,QTYLPN,QTYDER) From STKLPN
   # Aucun LPN à générer : pas de capacité défini dans l'article site
   If NBLPN<1
     GMESSAGE = func AFNC.MES2(mess(527,184,1),[M:ENTW]PCU(I),[M:ENTW]TCTRNUM(I))-":"-[M:STW]ITMREF-[M:STW]STOFCY
     Gosub TRT_ERR
     GOK=0 : Break
   Endif
   #---
   # Maj des STOENTW
   #---
   #--- STOENTW origine
   # Création nouveau LPN
   Gosub INIT_LPN
   If [L]RET>=[V]CST_AERROR
     GOK=0 : Break
   Endif
   ILPN = I
   Gosub AFFECT_LPN
   Gosub INSERT_LPN
   If [L]RET>=[V]CST_AERROR
     GOK=0 : Break
   Endif

   # Si Retour de prêt, de livraison sous-traitance ou Plan de rangement
   # ne pas effacer le STOCOU
   If !find([M:STW]TRSTYP,18,33,22)
     # C'est un nouveau LPN donc forcément un nouveau STOCOU
     [M:ENTW]STOCOU(I)=0
   Endif

   If NBLPN<2 : Goto NEXT_STOENTW : Endif

   [M:ENTW]NBLPN(I)  = 1
   [M:ENTW]QTYPCU(I) = QTYLPN
   [M:ENTW]QTYSTU(I) = ([M:ENTW]QTYPCU(I)*[M:ENTW]PCUSTUCOE(I))
   Call QTEARR([M:ENTW]QTYSTU(I),[F:ITM]STU) From TRTDIV
   # Si no série début et fin, il faut splitter la tranche de no séries
   If [M:ENTW]SERNUM(I)<>"" & [M:ENTW]SERNUMF(I)<>""
     Call PLUS_NB([M:ENTW]SERNUM(I),[M:ENTW]QTYSTU(I),LSERF,LRET) From STKLIB
     [M:ENTW]SERNUMF(I) = LSERF
   Endif

   #--- Nouveaux STOENTW
   For J=2 To NBLPN
     INEXT += 1
     Gosub COPY_ENTW
     # Création nouveaux LPN
     Gosub INIT_LPN
     If [L]RET>=[V]CST_AERROR
       GOK=0 : Break
     Endif
     ILPN = INEXT
     Gosub AFFECT_LPN
     Gosub INSERT_LPN
     If [L]RET>=[V]CST_AERROR
       GOK=0 : Break
     Endif

     If J=NBLPN
       [M:ENTW]QTYPCU(INEXT) = QTYDER
     Else
       [M:ENTW]QTYPCU(INEXT) = QTYLPN
     Endif
     [M:ENTW]QTYSTU(INEXT) = ([M:ENTW]QTYPCU(INEXT)*[M:ENTW]PCUSTUCOE(INEXT))
     Call QTEARR([M:ENTW]QTYSTU(INEXT),[F:ITM]STU) From TRTDIV
     [M:ENTW]NBLPN(INEXT)  = 1
     # Si no série début et fin, il faut splitter la tranche de no séries
     If [M:ENTW]SERNUM(I)<>"" & [M:ENTW]SERNUMF(I)<>""
       Call PLUS_UN(LSERF,[M:ENTW]SERNUM(INEXT),LRET) From STKLIB
       Call PLUS_NB([M:ENTW]SERNUM(INEXT),[M:ENTW]QTYSTU(INEXT),LSERF,LRET) From STKLIB
       [M:ENTW]SERNUMF(INEXT) = LSERF
     Endif
     [M:ENTW]NBLIG += 1
   Next J
   If GOK=0 : Break : Endif

   $NEXT_STOENTW
Next I

End

$COPY_ENTW
[M:ENTW]ORILIG    (INEXT) = [M:ENTW]ORILIG   (I)
[M:ENTW]WSTOSEQ   (INEXT) = [M:ENTW]WSTOSEQ  (I)
[M:ENTW]ITMREF    (INEXT) = [M:ENTW]ITMREF   (I)
[M:ENTW]PCU       (INEXT) = [M:ENTW]PCU      (I)
[M:ENTW]PCUSTUCOE (INEXT) = [M:ENTW]PCUSTUCOE(I)
[M:ENTW]STOCOU    (INEXT) = [M:ENTW]STOCOU   (I)
[M:ENTW]STA       (INEXT) = [M:ENTW]STA      (I)
[M:ENTW]LBEFMT    (INEXT) = [M:ENTW]LBEFMT   (I)
[M:ENTW]LBENBR    (INEXT) = [M:ENTW]LBENBR   (I)
[M:ENTW]PALNUM    (INEXT) = [M:ENTW]PALNUM   (I)
[M:ENTW]CTRNUM    (INEXT) = [M:ENTW]CTRNUM   (I)
[M:ENTW]QLYCTLFLG (INEXT) = [M:ENTW]QLYCTLFLG(I)
[M:ENTW]NUMLIGLOT (INEXT) = [M:ENTW]NUMLIGLOT(I)
[M:ENTW]SAIACTFLG (INEXT) = [M:ENTW]SAIACTFLG(I)
[M:ENTW]STOFLD1   (INEXT) = [M:ENTW]STOFLD1  (I)
[M:ENTW]STOFLD2   (INEXT) = [M:ENTW]STOFLD2  (I)
[M:ENTW]LOCTYP    (INEXT) = [M:ENTW]LOCTYP   (I)
[M:ENTW]WRH       (INEXT) = [M:ENTW]WRH      (I)
[M:ENTW]LOC       (INEXT) = [M:ENTW]LOC      (I)
[M:ENTW]OWNER     (INEXT) = [M:ENTW]OWNER    (I)
[M:ENTW]STOCOUALL (INEXT) = [M:ENTW]STOCOUALL(I)
[M:ENTW]SEQALL    (INEXT) = [M:ENTW]SEQALL   (I)
[M:ENTW]STUDIS    (INEXT) = [M:ENTW]STUDIS   (I)
[M:ENTW]WLOCSEQ   (INEXT) = [M:ENTW]WLOCSEQ  (I)
[M:ENTW]QUAFLG    (INEXT) = [M:ENTW]QUAFLG   (I)
[M:ENTW]QUAFRE    (INEXT) = [M:ENTW]QUAFRE   (I)
[M:ENTW]TCTRNUM   (INEXT) = [M:ENTW]TCTRNUM  (I)
Return

$INIT_LPN
WLPN=NewInstance C_LPN AllocGroup null
[L]RET=fmet WLPN.AINIT()
If [L]RET>=[V]CST_AERROR
  Call WRITE_ERRORS(WLPN)
  FreeGroup WLPN
Endif
Return

$AFFECT_LPN
WLPN.STOFCY  = [M:STW]STOFCY
WLPN.LPNFDAT = [M:STW]IPTDAT
WLPN.LPNLDAT = [M:STW]IPTDAT
WLPN.LOC     = [M:ENTW]LOC(ILPN)
WLPN.TCTRNUM = [M:ENTW]TCTRNUM(ILPN)
WLPN.VCRTYP  = [M:STW]VCRTYP
WLPN.VCRNUM  = [M:STW]VCRNUM
Return

$INSERT_LPN
[L]RET=fmet WLPN.AINSERT()
If [L]RET>=[V]CST_AERROR
  Call WRITE_ERRORS(WLPN)
Else
  [M:ENTW]LPNNUM(ILPN) = WLPN.LPNNUM
Endif
FreeGroup WLPN
Return

#--- Ecriture des erreurs du LPN
Subprog WRITE_ERRORS(WLPN)
Variable Instance WLPN Using C_LPN
Local Integer I
Local Char WMESSAGE(250)
WMESSAGE=AVOID.ACHAR
# Head errors
WMESSAGE=func LCCLIB.MAXMSG(WLPN)
If WMESSAGE<>AVOID.ACHAR
  Call WRITE_ERROR_STACK_CLASSIC(WLPN, 0) From LCCLIB
Endif
End
#--- End issue X3-53322

