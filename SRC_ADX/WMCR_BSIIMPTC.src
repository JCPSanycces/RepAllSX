#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:46 316


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File BSIIMPTC [BSITC_]

If !SILENCE : Call TRACE("2 --> Local Instance C_BSIIMPTC") From ASYRCOM : Endif
Local Instance BSIIMPTC Using C_BSIIMPTC

If !SILENCE : Call TRACE("3 --> New Instance C_BSIIMPTC") From ASYRCOM : Endif
BSIIMPTC = NewInstance C_BSIIMPTC AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [BSITC_]BSITC0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of BSIIMPTC") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.AREAD([BSITC_]BSICODTC,[BSITC_]BAN))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("BSIIMPTC.BSICODTC ="-num$(BSIIMPTC.BSICODTC)) From ASYRCOM
 Call TRACE("BSIIMPTC.BAN ="-num$(BSIIMPTC.BAN)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(BSIIMPTC.AKEYS)
  Call TRACE("-"-num$(I)-":"-BSIIMPTC.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [BSITC_]
FreeGroup BSIIMPTC
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(BSIIMPTC,ACLE,ASTATUS,_ETAG)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _BSICODTC(10)
Local Char _BAN(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_BSICODTC = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_BAN = num$([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File BSIIMPTC [BSITC]
Default File [F:BSITC]
Read [F:BSITC]BSITC0 = [L]_BSICODTC;[L]_BAN
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:BSITC]UPDTICK)>0
 [L]_ETAG = num$([F:BSITC]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(BSIIMPTC,ACLE,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Value Char ACLE
Variable Integer ASTATUS
Local Char _BSICODTC(10)
Local Char _BAN(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_BSICODTC = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_BAN = num$([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.AREAD([L]_BSICODTC,[L]_BAN))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(BSIIMPTC,_BSICODTC,_BAN,ASTATUS)
Variable Instance BSIIMPTC Using C_BSIIMPTC
Value Char _BSICODTC
Value Char _BAN
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub AVARIABLES From WMC00BSIIMPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If BSIIMPTC.APARENT=null
 [L]A_I = BSIIMPTC.freeSnapshot
 BSIIMPTC.snapshotEnabled = 0
 BSIIMPTC.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & BSIIMPTC.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If BSIIMPTC.APARENT=null
 BSIIMPTC.snapshotEnabled = 1
 BSIIMPTC.setAccessorEnabled = 1
Endif
LogicClose File [BSITC] ,[BSITCD]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC._ACTION_PARAM("AREAD_BEFORE",[L]_BSICODTC,[L]_BAN))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:BSITC]
Read [F:BSITC]BSITC0 = [L]_BSICODTC;[L]_BAN
If fstat
[L]A_ERROR = [L]_BSICODTC+"~"+[L]_BAN
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(BSIIMPTC,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:BSITC]AUUID)>0 & [F:BSITC]AUUID=NullUuid
 [F:BSITC]AUUID = getUuid
Endif
SetInstance BSIIMPTC With [F:BSITC]
BSIIMPTC.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:BSITCD]
 [L]A_N2=0
 For [F:BSITCD]BSITCD0 Where BSICODTC=[F:BSITC]BSICODTC & BAN=[F:BSITC]BAN
  [L]A_N2 +=1
  BSIIMPTC.LINES(A_N2) = NewInstance  C_BSIITCD(BSIIMPTC.ACTX,NullUuid,[L]A_N2,BSIIMPTC,"LINES") AllocGroup BSIIMPTC
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ADDINSTANCE_BOUND)
  If dim([F:BSITCD]AUUID)>0 & [F:BSITCD]AUUID=NullUuid
   [F:BSITCD]AUUID = getUuid
  Endif
  SetInstance BSIIMPTC.LINES(A_N2) With [F:BSITCD]
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  BSIIMPTC.LINES(A_N2).ASTALIN = [V]CST_ALL
  For [AXX] Where CODFIC="BSIIMPTC" & ZONE="DESAXX" & IDENT1=BSIIMPTC.LINES(A_N2).BSICODTC & IDENT2=BSIIMPTC.LINES(A_N2).COD
   Call ASETTEXTRA(BSIIMPTC.LINES(A_N2).AXX,BSIIMPTC.LINES(A_N2).AllocGrp(),"DESAXX",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
   BSIIMPTC.LINES(A_N2).AXX(maxtab(BSIIMPTC.LINES(A_N2).AXX)).FLG = 0
  Next AXX
  If !len(fmet BSIIMPTC.LINES(A_N2).AGETTEXTRA("DESAXX"))
   Call ASETTEXTRA(BSIIMPTC.LINES(A_N2).AXX,BSIIMPTC.LINES(A_N2).AllocGrp(),"DESAXX",
& fmet BSIIMPTC.LINES(A_N2).AGETTEXTRALAN("DESAXX",BSIIMPTC.LINES(A_N2).ACTX.AFOLD.ALANGDEF),
& BSIIMPTC.LINES(A_N2).ACTX.LAN) From ASYRSUB
  Endif
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ASETATTRIBUTE("BSICODTC","$namProParent","BSICODTC"))
  [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.LINES(A_N2).ASETATTRIBUTE("BAN","$namProParent","BAN"))
 Next BSITCD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [AXX] Where CODFIC="BSIIMPTC" & ZONE="DESAXX" & IDENT1=BSIIMPTC.BSICODTC & IDENT2=""
 Call ASETTEXTRA(BSIIMPTC.AXX,BSIIMPTC.AllocGrp(),"DESAXX",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
 BSIIMPTC.AXX(maxtab(BSIIMPTC.AXX)).FLG = 0
Next AXX
If !len(fmet BSIIMPTC.AGETTEXTRA("DESAXX"))
 Call ASETTEXTRA(BSIIMPTC.AXX,BSIIMPTC.AllocGrp(),"DESAXX",
& fmet BSIIMPTC.AGETTEXTRALAN("DESAXX",BSIIMPTC.ACTX.AFOLD.ALANGDEF),
& BSIIMPTC.ACTX.LAN) From ASYRSUB
Endif

Return



