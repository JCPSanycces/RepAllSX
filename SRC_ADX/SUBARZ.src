#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet ARZ
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ARZ",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "CHANGE"      : Gosub CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

#-------------#
$LIENS
nolign = 0
For [ARG] Where CODPAR=[M]CODPAR
 nolign += 1
 [M:ARZ1] = [F:ARG]
Next ARG
[M]NBLIG = nolign
Gosub GRISE_VER
Gosub GRISE_MSK
Return

#-------------#
$GRISE_MSK
Read [ARA]ARA1(1)=[M:ARZ1]PATNAM
If !fstat & [F:ARA]TYPPAT=2 : # Masque
 Actzo [M:ARZ1]ENVMSK
Else
 [M:ARZ1]ENVMSK = 1
 Affzo [ARZ1]ENVMSK
 Grizo [ARZ1]ENVMSK
Endif
Return

#-------------#
$GRISE_VER
Read [ARA]ARA1(1)=[M:ARZ1]PATNAM
If !fstat & [F:ARA]PATNAM=[M:ARZ1]PATNAM & [F:ARA]VER>0
 [M:ARZ1]VER = [F:ARA]VER
 Affzo [ARZ1]VER
 Actzo [ARZ1]VER
Else
 [M:ARZ1]VER = 0
 Affzo [ARZ1]VER
 Grizo [ARZ1]VER
Endif
Return

#-------------#
$CREATION
For nolign=1 To [M:ARZ1]NBLIG
 [F:ARG] = [M:ARZ1]
 [F:ARG]LIG = nolign
 Write [ARG]
 If fstat
  GOK = 0 : Call FSTA("ARG") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Call MAJTEXTRA([M:ARZ1]INTIT,"AREPORTZ","INTIT",[M:ARZ1]CODPAR,"") From ATEXTRA
Return

#-------------#
$MODIF
Delete [ARG] Where CODPAR=[M:ARZ1]CODPAR
If fstat=1
 GOK=-1 : Call RSTA("ARG",[M:ARZ1]CODPAR) From GLOCK : Return
Endif
Gosub CREATION
Return

#-------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V") From GOBJET : # Validation
Endif
Return

#-------------#
$EXEBOUT
Case REP
 When "V" : Call VALIDATION(nomap,[M:ARZ1]CODPAR,0)
Endcase
Return

#-------------#
$APRES_CRE
$APRES_MOD
Call VALIDATION(nomap,[M:ARZ1]CODPAR,0)
Return

#--------------------------------------------#
$CHANGE
Update [AXX] Where CODFIC="AREPORTZ" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AREPORTZ"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#--------------------------------------------#
$ANNULE
Call SUPTEXTRA("AREPORTZ","INTIT",[L]CODE,"") From ATEXTRA
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#----------------------------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "SELFICPAT"
  # Actuce pour remplacer le SEL_LISTE par un SEL_TABLE
  Call S_TAB_CHAR(VALEUR,PARAM,"SELFICPAT","SUBARZ","") From GACTION : OK = 0
 When "SELVERPAT"
  Gosub SELVERPAT
Endcase
Return

#----------------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELFICPAT" : Gosub SELFICPAT
Endcase
Return

#----------------------------------#
$SELFICPAT
Local Char    WNAM(50)(1..GNBSEL) , WDAT(10)(1..GNBSEL) , WVER(10)(1..GNBSEL) , WTYP(15)(1..GNBSEL)
Local Char    ORDSYS(250) , BID(30) , APPLI(GLONADS) , MACHINE(80)
Local Integer NBFIC , I
If dim([L]DOSSIER)<0
 Local Char DOSSIER(GLONAMC)
Endif
If [L]DOSSIER=""
 If PARAM(1)<>""
  [L]DOSSIER = PARAM(1)
 Else
  [L]DOSSIER = nomap
 Endif
Endif
Call MACHINE([L]DOSSIER,MACHINE,[L]APPLI) From ORDSYS
If filinfo(filpath("PAT","","",[L]DOSSIER),0)<0 : OK = 0 : Return : Endif
If filinfo(filpath("FIL","AREPORTA","fde",[L]DOSSIER),0)>0
 If [L]DOSSIER=nomap
  Local File AREPORTA [ARA]
 Else
  Local File =[L]DOSSIER+".AREPORTA" [ARA]
 Endif
Endif
Local File   (Char NAM(50) , Char DAT(10) , Char VER(10) , Char TYP(15))
&     From   Variable WNAM , WDAT , WVER , WTYP As [FIC]
NBCOL = 0
For BID="[F:FIC]NAM","[F:FIC]DAT","[F:FIC]VER","[F:FIC]TYP"
 NBCOL += 1
 COL(NBCOL) = BID
 COLTYP(NBCOL) = evalue("type("+BID+")")
Next BID
ORDSYS = "lsadx -a"-[L]APPLI-"PAT"-"PAT"
Call SYSTEME2(MACHINE,ORDSYS,"",NBFIC,WNAM) From ORDSYS
NBFIC = min(NBFIC,dim(WNAM))
For I=1 To NBFIC
 WDAT(I) = func SUBADC.CNVTIM(filinfo(filpath("PAT",WNAM(I),"PAT",[L]DOSSIER),9))
 If clalev([F:ARA])>0
  Read [ARA]ARA1(1) = WNAM(I)
  If !fstat
   WVER(I) = num$([F:ARA]VER)
   WTYP(I) = mess([F:ARA]TYPPAT,7869,1)
  Endif
 Endif
Next I 
For I=NBFIC+1 To dim(WNAM)
 WNAM(I) = chr$(255)
Next I
adxmxl = NBFIC
TIT    = mess(29,143,1)  : # Liste des fichiers pattern
TIT(1) = mess(55,100,1)  : # Fichier
TIT(2) = mess(159,124,1) : # Date création
TIT(3) = mess(126,105,1) : # Version
TIT(4) = mess(36,143,1)  : # Type de pattern
Close Local File [ARA]
ORDRE = "NAM"
Default File [FIC]
Return

#----------------------------------#
$SELVERPAT
Local Char    TIT(50)(0..3) , TEXTE(30)(1..200,1..3) , TEX(10)(1..200)
Local File AREPORTA [ARA]
NBTEX = 0
FORCE = 1
For [ARA]ARA1(2) Where PATNAM=PARAM(1)
 NBTEX += 1
 TEX(NBTEX)     = num$([F:ARA]VER)
 TEXTE(NBTEX,2) = func SUBADC.CNVTIM([F:ARA]TIMSTP)
 TEXTE(NBTEX,3) = mess([F:ARA]TYPPAT,7869,1)
Next ARA
TIT    = mess(30,143,1)-PARAM(1) : # Version du fichier
TIT(1) = mess(126,105,1) : # Version
TIT(2) = mess(159,124,1) : # Date création
TIT(3) = mess(36,143,1)  : # Type de pattern
Return

#------------------------------------------------------------------#
# Pour les patches des transactions
#------------------------------------------------------------------#

Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------------#
# Pg de mise à jour globale
#------------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local File =APPLI+".AREPORTZ" [ARZ]
Local File =APPLI+".AREPORTZ" [ARZ2]
Local File =APPLI+".AWRKLNK"  [AWM]
Local File =APPLI+".AWRKTAB"  [AWK]
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".ATABIND"  [ATI]
Local File =APPLI+".AINDEX"   [ANX]
For [ARZ2]ARZ0 Where ENAFLG=2
 Call VALIDATION(APPLI,[F:ARZ2]CODPAR,1)
Next ARZ2
End

#-----------------------------------------------------------------------------#
Subprog VALIDATION(DOSSIER,CODE,SILENCE)
Value Char DOSSIER , CODE
Value Integer SILENCE
Local Char     FICSRC(GDIMFIC) , IDENT(20)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Char     CHAINE(250) , MAGIC(80) , NOMPROG(GLONADC)
Local Integer  I , J , K , L , OK

If DOSSIER="" or DOSSIER=nomap
 If clalev([F:ARZ])=0 : Local File AREPORTZ [ARZ] : Endif
 If clalev([F:AWM])=0 : Local File AWRKLNK  [AWM] : Endif
 If clalev([F:AWK])=0 : Local File AWRKTAB  [AWK] : Endif
 If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
 If clalev([F:ATI])=0 : Local File ATABIND  [ATI] : Endif
 If clalev([F:ANX])=0 : Local File AINDEX   [ANX] : Endif
Else
 If clalev([F:ARZ])=0 : Local File =DOSSIER+".AREPORTZ" [ARZ] : Endif
 If clalev([F:AWM])=0 : Local File =DOSSIER+".AWRKLNK"  [AWM] : Endif
 If clalev([F:AWK])=0 : Local File =DOSSIER+".AWRKTAB"  [AWK] : Endif
 If clalev([F:ATB])=0 : Local File =DOSSIER+".ATABLE"   [ATB] : Endif
 If clalev([F:ATI])=0 : Local File =DOSSIER+".ATABIND"  [ATI] : Endif
 If clalev([F:ANX])=0 : Local File =DOSSIER+".AINDEX"   [ANX] : Endif
Endif

Local Shortint DIME : DIME = 20
Local Char     TBLNK(GLONATB+GLONABR+1)(1..DIME) , TBCLE(GLONANX)(1..DIME)
Local Char     REFTAB(GLONATB) , ABRREF(GLONABR) , CLEREF(GLONANX)
Local Char     TBEXP(250)(1..DIME) , TBSEL(250)(1..DIME)
Local Char     REFTAB(GLONATB) , ABRREF(GLONABR) , CLEREF(GLONANX) , CLEFLD(250)
Local Integer  NBTB , TBTYP(1..DIME) , TBNBC(1..DIME)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

MAGIC   = mess(77,133,1) : # Superviseur Adonix
IDENT   = "## WM-PATCH ##"
Gosub SET_PREF

NOMPROG = PREF+CODE

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

OK = 1
Read [ARZ]ARZ0=[L]CODE
If fstat
 Call ECR_TRACE([L]CODE-":"-mess(23,100,1),1) From GESECRAN : # Fiche inexistante
 End 
Endif
Read [AWM]AWM0=[F:ARZ]MODDON
If fstat
 Call ECR_TRACE([F:ARZ]MODDON-":"-mess(7,140,1),-1) From GESECRAN : # Modèle de données inexistant
 OK = 0
Else
 Look [ATB]CODFIC=[F:AWM]TABREF 
 If fstat
  Call ECR_TRACE([F:AWM]TABREF-":"-mess(124,124,1),-1) From GESECRAN : # Table inexistante
  OK = 0
 Else
  For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & TYPTAB<1
   If [F:AWK]TABLNK<>""
    Look [ATB]CODFIC=[F:AWK]TABLNK
    If fstat
     Call ECR_TRACE([F:AWK]TABLNK-":"-mess(124,124,1),-1) From GESECRAN : # Table inexistante
     OK = 0 : Break
    Endif 
   Endif
  Next
 Endif
Endif

If !OK
 Gosub DESACTIVE
Else
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

End

#-------------------------------------------------------#
# Désactivation d'une fiche en erreur
#-------------------------------------------------------#

$DESACTIVE
If !adxlog
 Gosub TR_FICHE
Else
 Gosub MAJ_FICHE
Endif
If GOK=1
 Call ECR_TRACE([L]CODE-":"-mess(62,139,1),-1) From GESECRAN : # Fiche désactivée
Endif
Return

$TR_FICHE
GOK=1
Trbegin [ARZ]
 Gosub MAJ_FICHE
 If GOK<0 : Goto AB_TR_FICHE : Endif
Commit
Return

$AB_TR_FICHE
Rollback
Return

$MAJ_FICHE
Readlock [ARZ]ARZ0 = [L]CODE
If fstat=1
 GOK = -1 : GLOCK = "$AREPORTZ"
Else
 [F:ARZ]ENAFLG = 1
 Rewrite [ARZ]
 If fstat
  GOK = 0 : Call FSTA("ARZ") From GLOCK  
 Endif
Endif
Return

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(39,143,1)-[F:ARZ]CODPAR-'('+format$("D:",date$)-time$+')' : # Imprimante ZPL
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#------------------------------------------------------------------------------#
$ETIQ
Wrseq "#-----------------------#"
Wrseq "$OUVRE"
Wrseq "Local Integer OKSEL , ERSEL , TBOPE(0.."+num$(DIME)+")"

# Chargement des tables liées
NBTB = 0
For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & TYPTAB<1
 If [F:AWK]TABLNK<>""
  NBTB += 1
  TBLNK(NBTB) = [F:AWK]TABLNK
  TBCLE(NBTB) = [F:AWK]CLELNK
  TBEXP(NBTB) = [F:AWK]EXPLNK
  TBSEL(NBTB) = [F:AWK]EXPSEL
  TBTYP(NBTB) = [F:AWK]TYPLNK
  Gosub NBRCLE
  If [F:AWK]ABRLNK<>""
   TBLNK(NBTB) += "~"+[F:AWK]ABRLNK
  Else
   Read [ATB]CODFIC=[F:AWK]TABLNK 
   TBLNK(NBTB) += "~"+[F:ATB]ABRFIC
  Endif
 Endif 
Next

# Table principale
REFTAB = [F:AWM]TABREF
Read [ATB]CODFIC=[F:AWM]TABREF 
ABRREF = [F:ATB]ABRFIC
Read [ATI]NUMLIG(2)=[F:AWM]TABREF;1
CLEREF = [F:ATI]CODIND
CLEFLD = [F:ATI]DESCRIPT

Wrseq 'If clalev([F:'+ABRREF+'])=0 : Local File '+REFTAB+' ['+ABRREF+'] : TBOPE(0) = 1 : Endif'
If NBTB=0
 Wrseq 'Local File '+REFTAB+' [LNK_]'
Else
 For I=1 To NBTB
  K = instr(1,TBLNK(I),"~")
  Wrseq 'If clalev([F:'+right$(TBLNK(I),K+1)+'])=0 : Local File '+left$(TBLNK(I),K-1)+' ['+right$(TBLNK(I),K+1)+']';
  Wrseq ' : TBOPE('+num$(I)+') = 1 : Endif'
 Next I
Endif
Wrseq

If NBTB=0
 Wrseq "Link ["+ABRREF+"] With [LNK_]";CLEREF;"=";
 CHAINE = CLEFLD
 K = 0
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  If !K
   K = 1
  Else
   Wrseq ';';
  Endif
  If I
   Wrseq '['+ABRREF+']'+left$(CHAINE,I-1);
   CHAINE = right$(CHAINE,I+1)
  Else
   Wrseq '['+ABRREF+']'+CHAINE;
   CHAINE = ""
  Endif
 Wend
 Wrseq " As [LNK]"
Else
 Wrseq "Link ["+ABRREF+"] With"
 For I=1 To NBTB
  If I>1 : Wrseq "," : Endif 
  K = instr(1,TBLNK(I),"~")
  Wrseq "& ["+right$(TBLNK(I),K+1)+"]"+TBCLE(I);
  If TBTYP(I)=3 : # 1,1
   Wrseq "~";
  Elsif TBNBC(I)<>0
   Wrseq "("+num$(TBNBC(I))+")";
  Endif
  Wrseq "="+TBEXP(I);
 Next I 
 Wrseq
 Wrseq "& As [LNK]"
Endif
K = 0
For I=1 To dim([F:ARZ]CONDIT)
 If [F:ARZ]CONDIT(I-1)<>"" & !instr(1,[F:ARZ]CONDIT(I-1),"func")
  If !K
   K = 1
   Wrseq "& Where ";
  Else
   Wrseq "&     & ";
  Endif
  Wrseq [F:ARZ]CONDIT(I-1)
 Endif
Next I 
For I=1 To NBTB
 If TBSEL(I)<>""
  If !K
   K = 1
   Wrseq "& Where ";
  Else
   Wrseq "&     & ";
  Endif
  Wrseq TBSEL(I)
 Endif
Next I
Wrseq 'Return'
Wrseq

Wrseq "#-----------------------#"
Wrseq '$FILTRE'
Wrseq 'OKSEL = 1'
K = 0
For I=1 To dim([F:ARZ]CONDIT)
 If [F:ARZ]CONDIT(I-1)<>"" & instr(1,[F:ARZ]CONDIT(I-1),"func")
  If !K
   K = 1
   Wrseq 'ERSEL = 0'
   Wrseq 'Onerrgo ERREUR'
   Wrseq 'OKSEL = '+[F:ARZ]CONDIT(I-1)
  Else
   Wrseq 'OKSEL *= '+[F:ARZ]CONDIT(I-1)
  Endif
 Endif
Next I
If K
 Wrseq 'Onerrgo'
 Wrseq 'If ERSEL : OKSEL = 1 : Endif'
Endif
Wrseq 'Return'
Wrseq

# Close
Wrseq "#-----------------------#"
Wrseq '$FERME'
Wrseq "If TBOPE(0) : Close local File ["+ABRREF+"] : Endif"
If NBTB=0
 Wrseq 'Close local File [LNK_]'
Else
 For I=1 To NBTB
  K = instr(1,TBLNK(I),"~")
  Wrseq "If TBOPE("+num$(I)+") : Close local File ["+right$(TBLNK(I),K+1)+"] : Endif"
 Next I
Endif
Wrseq 'Return'
Wrseq

Wrseq '$ERREUR'
Wrseq 'ERSEL = errn'
Wrseq 'Resume'
Return

#--------------#
$NBRCLE
Read [ATI]CODIND = [F:AWK]TABORI;[F:AWK]TABORI
If !fstat
 CHAINE = [F:ATI]DESCRIPT
Else
 Read [ANX]ANX2 = [F:AWK]TABORI;[F:AWK]TABORI
 If !fstat
  CHAINE = [F:ANX]DESCRIPT
 Endif
Endif
If CHAINE<>""
 J = 0
 While CHAINE<>""
  J += 1
  K = instr(1,CHAINE,";")
  If K
   CHAINE = right$(CHAINE,K+1)
  Else
   CHAINE = ""
  Endif
 Wend
 CHAINE = [F:AWK]EXPLNK
 L = 0
 While CHAINE<>""
  L += 1
  K = instr(1,CHAINE,";")
  If K
   CHAINE = right$(CHAINE,K+1)
  Else
   CHAINE = ""
  Endif
 Wend
 If L<>J
  TBNBC(I) = L
 Endif
Endif
Return

#---------------------#
$SET_PREF
Local Char PREF(5)
PREF = "WMZPL"
Return

#----------------------------------------------------------------------------------#
Subprog C_PATNAM(VALEUR)
Variable Char    VALEUR()
Local Char ORDSYS(250) , COMMAND(250)
If VALEUR="" : End : Endif
If filinfo(filpath("PAT","",""),0)<0
 ORDSYS = adxmac(0)+'@ae_mkdir'-filpath("PAT","","")
 System COMMAND=ORDSYS
 If filinfo(filpath("PAT","",""),0)<0 : End : Endif
Endif
If filinfo(filpath("PAT",VALEUR,"PAT"),0)<=0
 GMESSAGE = "|"+filpath("PAT",VALEUR,"PAT")-"\:"-mess(32,143,1) : # Fichier pattern inexistant
 mkstat = 1 : End
Endif
End

Subprog S_PATNAM(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(30)(1..10)
Call S_LIS_CHAR(VALEUR,PARAM,"SELFICPAT","SUBARZ","") From GACTION
End

Subprog AM_PATNAM(VALEUR)
Variable Char    VALEUR()
[M]PATNAM = VALEUR
Gosub GRISE_VER
Gosub GRISE_MSK
End

Subprog C_VER(VALEUR)
Variable Decimal VALEUR
If [M]PATNAM="" : End : Endif
Read [ARA]ARA1=[M]PATNAM;VALEUR
If fstat
 GMESSAGE = mess(28,143,1) : # Version inexistante
 mkstat = 1 : End
Endif
End

Subprog S_VER(VALEUR)
Variable Decimal VALEUR
Local Char PARAM(30)(1..10)
PARAM(1) = [M]PATNAM
Call S_LIS_NUM(VALEUR,PARAM,"SELVERPAT","SUBARZ","") From GACTION
End

Subprog AS_CONDIT(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_HLP
End

Subprog AS_CND(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_HLP
End

Subprog AS_EXPLIG(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_HLP
End

$CHARGE_HLP
Local Char    A_AHLP(50)
Local Integer I , NBFOR
Raz [M]HLPFOR
Read [AWM]AWM0=[M]MODDON
If [F:AWM]TABREF<>""
 Read [ATB]CODFIC = [F:AWM]TABREF
 A_HLP = "[F:"+[F:ATB]ABRFIC+"]"+[F:AWM]TABREF : Gosub INC_HLP
 If [F:AWM]MODELE<>""
  For [AWK]AWK0 Where MODELE=[F:AWM]MODELE & TYPTAB<1
   If [F:AWK]ABRLNK<>""
    A_HLP = "[F:"+[F:AWK]ABRLNK+"]"+[F:AWK]TABLNK : Gosub INC_HLP
   Else
    Read [ATB]CODFIC = [F:AWK]TABLNK
    A_HLP = "[F:"+[F:ATB]ABRFIC+"]"+[ATB]CODFIC : Gosub INC_HLP
   Endif
  Next
 Endif
Endif
Return

$INC_HLP
If NBFOR<dim([M]HLPFOR) & !find(A_HLP,[M]HLPFOR(0..NBFOR+1))
 NBFOR += 1
 [M]HLPFOR(NBFOR-1) = A_HLP
Endif
Return


