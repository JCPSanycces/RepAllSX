#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Xtend: Génération fiche Action Xtend
#  Version 0001
######################################################################################
#    XMLGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     Référence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace détaillée
                         #       'CHK'   =Vérification lien interface
Value Char ELTCOD        #     Code élément
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissementLocal Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI, WNBREC
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Integer CHKFLG      : CHKFLG      = find("CHK",OPTION) 
Local Char WSTR1(250)

RET=1

Call TITOBJ("AYA","", WSTR1) From CONTOBJ
Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN 
If CHKFLG  : Call ECR_TRACE(mess(175,7900,1),0) From GESECRAN : Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTACT    [AYA1] 
 Local File ATEXTE    [ATX1] 
 Local File AYTLINES  [AYN1]
 Local File ATEXTRA   [AXX1] 
Else 
 Local File =[L]DOSORG+".AYTACT"     [AYA1]     
 Local File =[L]DOSORG+".ATEXTE"     [ATX1] 
 Local File =[L]DOSORG+".AYTLINES"   [AYN1] 
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1] 
Endif 

# Vérification interface
If CHKFLG
 If DOSORG=nomap 
  Local File AYTINT    [AYI1]
 Else
  Local File =[L]DOSORG+".AYTINT"     [AYI1] 
 Endif 
 Gosub GETWS_VAR From SUBAYIACT
Endif

Default File "[AYA1],[ATX1],[AYN1]"

#
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="ACT"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FFINALLY : Endif 
#
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN
#
For [AYA1]AYA0 Where FCYCOD=FCYORG
 WNBREC+=1
 If TRADETFLG or CHKFLG  : Call ECR_TRACE(mess(9,7910,1)-":"-[F]ACTCOD,0) From GESECRAN : Endif
 #
 XT_TY="ELMT" : XT_ID=[F]ACTCOD 
 Call LECTEXTRA(XT_VAL,"AYTACT","INTIT",[F]FCYCOD,[F]ACTCOD) From AYTUTIA    : Gosub XMLF_ADD From AYTGEN                  
 XT_TY="FLD"   : XT_ID="INTCOD"  : XT_VAL=[F]INTCOD                          : Gosub XMLF_ADD From AYTGEN

 # Vérification interface
 If CHKFLG   
    If [F]INTCOD="" : CHKFLG=2 : Goto INTCHKFLG_E : Endif
    CHKFLG=1    # Restauration suite déactivation éventuelle

    Call ECR_TRACE(space$(5)+mess(13,7910,1)-":"-[F]INTCOD,0) From GESECRAN
    Read [AYI1]AYI0=[F]FCYCOD;[F]INTCOD
    If fstat
        CHKFLG = 2 # Déactivation temporaire
        Call ECR_TRACE(mess(172,7900,1)-":"-[F]INTCOD,1) From GESECRAN
        RET=2 : Goto INTCHKFLG_E
    Endif
    If !find([F:AYI1]TYP,20,21)
        CHKFLG = 2 # Déactivation temporaire
        Call ECR_TRACE(space$(5)+mess(174,7900,1)-":"-mess([F:AYI1]TYP,7912,1),1) From GESECRAN
        RET=2 : Goto INTCHKFLG_E
    Endif

    Gosub GETWS_VAR From SUBAYIACT      # Variables pour GETWS_INF
    WS_INTTYP=[F:AYI1]TYP : WS_WSRCOD=[F:AYI1]WEBSRCCOD 
    Gosub GETWS_INF From SUBAYIACT
    If WS_RET 
        Call ECR_TRACE(space$(5)+WS_MES,1) From GESECRAN
        RET=2
        Case [F:AYI1]TYP
        When 20        # Action sous-programme utilisateur
             If (WS_RET<>2)  # Pas de trt: on vérifie quand même
                CHKFLG = 2
             Endif
        When Default
            CHKFLG = 2
        Endcase
    Endif
 Endif
 $INTCHKFLG_E

 XT_TY="FLD"   : XT_ID="ACTREFRESH" : XT_VAL=num$([F]ACTREFRESH)
                                      XT_LAB=mess([F]ACTREFRESH,1,1)           : Gosub XMLF_ADD From AYTGEN
 ## devalider FD 19062007
 #XT_TY="FLD"   : XT_ID="OPTINP"     : XT_VAL=num$([F]OPTINP)
 #                                     XT_LAB=mess([F]OPTINP,7918,1)            : Gosub XMLF_ADD From AYTGEN
 #XT_TY="FLD"   : XT_ID="OPTOUT"     : XT_VAL=num$([F]OPTOUT)
 #                                     XT_LAB=mess([F]OPTOUT,7918,1)            : Gosub XMLF_ADD From AYTGEN
 #If [F]OPTOUT=3
 #  XT_TY="FLD"   : XT_ID="FICXML"     : XT_VAL=[F]FICXML                     : Gosub XMLF_ADD From AYTGEN
 #Endif

 XT_TY="FLD"   : XT_ID="WSOACT"     : XT_VAL=num$([F]WSOACT)
                                      XT_LAB=mess([F]WSOACT,7920,1)        : Gosub XMLF_ADD From AYTGEN
 If [F]WSOACT=5
   XT_TY="FLD"   : XT_ID="WSOACTBTN"  : XT_VAL=[F]WSOACTBTN                  : Gosub XMLF_ADD From AYTGEN
   # ajout fiche 49153 menu local 7940 SB
   XT_TY="FLD"   : XT_ID="WSOTYPPAR":  XT_VAL=num$([F]WSOTYPPAR)
                                        XT_LAB=mess([F]WSOTYPPAR,7940,1)     : Gosub XMLF_ADD From AYTGEN
   #fin ajout SB
 Endif
 XT_TY="FLD"   : XT_ID="LOGMOD"     : XT_VAL=num$([F]LOGMOD)
                                      XT_LAB=mess([F]LOGMOD,1,1)             : Gosub XMLF_ADD From AYTGEN

 XT_TY="FLD"   : XT_ID="ACTTYP"     : XT_VAL=num$([F]ACTTYP)
                                      XT_LAB=mess([F]ACTTYP,7936,1)          : Gosub XMLF_ADD From AYTGEN

 # Entités Xtend à supprimer
 If [F]ENTSUPNBR<>0
  XT_TY="FLD"   : XT_ID="ENTSUPBEF"  :  XT_VAL=num$([F]ENTSUPBEF)
                                        XT_LAB=mess([F]ENTSUPBEF,1,1)        : Gosub XMLF_ADD From AYTGEN
  XT_TY="TAB"   : XT_ID="ENTSUPNBR"  :  XT_VAL="Entities to delete"                         : Gosub XMLF_ADD From AYTGEN
  For WI=0 To [F]ENTSUPNBR-1
   XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="ENTSUPCOD"  : XT_VAL=[F]ENTSUPCOD(WI)               : Gosub XMLF_ADD From AYTGEN
  Next
 Endif

 # Paramétres
 XT_TY="TAB"   : XT_ID="NUM40"    :  XT_VAL="Parameters"                 : Gosub XMLF_ADD From AYTGEN
 For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=3
&                       and LINCOD = toupper([F:AYA1]ACTCOD) and  LINTYP = 40
   XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="PARCOD"     : XT_VAL=[F]PARCOD                      : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="VALTYP"     : XT_VAL=num$([F]VALTYP)
                                       XT_LAB=mess([F]VALTYP,7925,1)         : Gosub XMLF_ADD From AYTGEN
   If [F]VALTYP=1
     XT_TY="COL"  : XT_ID="VALEUR"     : XT_VAL=[F]VALEUR                      : Gosub XMLF_ADD From AYTGEN
   Endif
 Next

 # Flux aller
 XT_TY="TAB"   : XT_ID="NUM20"    :  XT_VAL="Send stream"                 : Gosub XMLF_ADD From AYTGEN
 For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=3
&                       and LINCOD = toupper([F:AYA1]ACTCOD) and  LINTYP = 20
   XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="ENTCOD"     : XT_VAL=[F]ENTCOD                      : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="FIECOD"     : XT_VAL=[F]FIECOD                      : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="FIELNKENT"  : XT_VAL=[F]FIELNKENT                   : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="INTTYPMLT"  : XT_VAL=num$([F]INTTYPMLT)
                                       XT_LAB=mess([F]INTTYPMLT,1,1)         : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="INTFLD"     : XT_VAL=[F]INTFLD                      : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="INTFLDGRP"  : XT_VAL=[F]INTFLDGRP                   : Gosub XMLF_ADD From AYTGEN
   If [F]INTTYPMLT=1
    XT_TY="COL"  : XT_ID="INTFLDIND"  : XT_VAL=num$([F]INTFLDIND)              : Gosub XMLF_ADD From AYTGEN
   Endif

   If CHKFLG=1   # Vérification interface
       Gosub INTCHK
   Endif

 Next

 # Flux retour
 XT_TY="FLD"   : XT_ID="ACTMAPRET"     : XT_VAL=[F]ACTMAPRET               : Gosub XMLF_ADD From AYTGEN
 #
 XT_TY="TAB"   : XT_ID="NUM21"    :  XT_VAL="Received stream"              : Gosub XMLF_ADD From AYTGEN
 For [F:AYN1]AYN0 Where FCYCOD=[L]FCYORG and LINCODTYP=3
&                       and LINCOD = toupper([F:AYA1]ACTCOD) and  LINTYP = 21
   XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="ENTCOD"     : XT_VAL=[F]ENTCOD                      : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="FIECOD"     : XT_VAL=[F]FIECOD                      : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="FIELNKENT"  : XT_VAL=[F]FIELNKENT                   : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="INTTYPMLT"  : XT_VAL=num$([F]INTTYPMLT)
                                       XT_LAB=mess([F]INTTYPMLT,1,1)         : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="INTFLD"     : XT_VAL=[F]INTFLD                      : Gosub XMLF_ADD From AYTGEN
   XT_TY="COL"  : XT_ID="INTFLDGRP"  : XT_VAL=[F]INTFLDGRP                   : Gosub XMLF_ADD From AYTGEN
   If [F]INTTYPMLT=1
    XT_TY="COL"  : XT_ID="INTFLDIND"  : XT_VAL=num$([F]INTFLDIND)              : Gosub XMLF_ADD From AYTGEN

   If CHKFLG=1   # Vérification interface
       Gosub INTCHK
   Endif

   Endif
 Next
#
Next
#

$FFINALLY
Gosub XMLF_CL  From AYTGEN
Close Local File [AYA1],[ATX1],[AYN1],[AXX1]
Call ECR_TRACE(mess(146,7900,1)-num$(WNBREC),0) From GESECRAN
End

# Verification lien interface sur AYN
$INTCHK
WI=find([F]INTFLD , RUBCOD)
If WI
    If [F]INTFLDGRP<>RUBGRP(WI-1)
        Call ECR_TRACE(space$(5)+mess(66,7900,1)-":"-[F]INTFLDGRP-"/"-[F]INTFLD,1) From GESECRAN
        RET=2
    Else
        If [F]INTTYPMLT=1 and ([F]INTFLDIND <= 0 or [F]INTFLDIND > RUBDIM(WI-1))
            Call ECR_TRACE(space$(5)+mess(87,7900,1)-num$([F]INTFLDIND)-"/"-[F]INTFLD
&                    -"(1-"-num$(RUBDIM(WI-1))-")",1) From GESECRAN
            RET=2
        Endif
    Endif
Else
    Call ECR_TRACE(space$(5)+mess(68,7900,1)-":"-[F]INTFLD,1) From GESECRAN
    RET=2
Endif
Return
