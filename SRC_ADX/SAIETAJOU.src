#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("JOU",GBIDC1,GBIDC2) From GOBJET
End

Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "CAIFR"
Call SAISIE_CHAR(VALEUR,PARAM,"FETAJOU","SAIETAJOU","XWFETAJOU") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "FIR"          : Gosub SOCFIRST
 When "SUI"          : Gosub SOCSUIV
 When "PRE"          : Gosub SOCPREC
 When "LAS"          : Gosub SOCLAST
 When "ENR"          : Gosub ENREG
 When "ABA"          : Gosub ABANDON
 When "FIN"          : Gosub FIN
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return


$OUVRE
If clalev([JST])=0 : Local File GAJOUSTA [JST] : Endif
If clalev([JOU])=0 : Local File GJOURNAL [JOU] : Endif
If clalev([PER])=0 : Local File PERIOD   [PER] : Endif
Return


$DEBUT
Local Integer EXERCICE
Local Char    SOCIETE(GLONCPY), SYMBOLE(20)
Local Libelle VERROU
VERROU   = 0
EXERCICE = 1
SOCIETE  = GDEFSOC
Filter [JST] Where CPY=SOCIETE & JOU=PARAM(1) & (LEG=PARAM(2) | PARAM(2)="")
Read [JST]JST0 First
Filter [JST]
If fstat
 Filter [JST] Where JOU=PARAM(1) & (LEG=PARAM(2) | PARAM(2)="")
 Read [JST]JST0 First
 Filter [JST]
 If !fstat
  SOCIETE  = [F:JST]CPY
 Else
  GERR = 1 : GMESSAGE = mess(99,100,1) : # Pas de fiche sélectionnée
  FIN = 1
 Endif  
Endif
Gosub LECETAT
Return

$FIN
Gosub DEVERROU
Return

$DEVERROU
Unlock =SYMBOLE
Return

$LECETAT
Gosub DEVERROU
VERROU = 0
Raz [M]
[M]CPY    = SOCIETE
[M]JOU    = PARAM(1)
Read [JST]JST0 = [M]CPY;[M]JOU
If !fstat
 [M]OPGSTRDAT = [F:JST]OPGSTRDAT
 [M]OPGENDDAT = [F:JST]OPGENDDAT
Endif
Affzo
Return


$APRES_MODIF
If evalue("type([M]"+COUZON+")")=8 : # Bas de tableau
 OK = 0 : Return
Elsif !VERROU
 SYMBOLE = "JOU"+[M:JOU0]LEG+"\"+[M]JOU
 Lock =SYMBOLE With lockwait=0
 If fstat  GERR = 1 : Return 
 Else
  VERROU = 1
  REP = "M"
 Endif
Endif
Return

$SOCFIRST
# Filtre sur les sociétés ayant la même LEG que le journal ou LEG du journal est vide
Filter [JST] Where JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
Read [JST]JST0 First
Filter [JST]
If fstat
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 SOCIETE = [F:JST]CPY
 # On vérifie que l'exercice sur lequel on était existe pour cette société
 Look [JST]JST0 = SOCIETE ; [M]JOU 
 If !fstat
  Gosub LECETAT
 Else
  # Filtre sur les sociétés ayant la même LEG que le journal ou LEG du journal est vide
  Filter [JST] Where CPY=SOCIETE & JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
  Read [JST]JST0 Last
  Filter [JST]
  SOCIETE  = [F:JST]CPY
  Gosub LECETAT
 Endif
Endif
Return

$SOCPREC
Filter [JST] Where JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
Read [JST]JST0 < SOCIETE
Filter [JST]
If fstat
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 SOCIETE = [F:JST]CPY
 Look [JST]JST0 = SOCIETE ; [M]JOU 
 If !fstat
  Gosub LECETAT
 Else
  Filter [JST] Where CPY=SOCIETE & JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
  Read [JST]JST0 Last
  Filter [JST]
  SOCIETE  = [F:JST]CPY
  Gosub LECETAT
 Endif
Endif
Return

$SOCSUIV
Filter [JST] Where JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
Read [JST]JST0 > SOCIETE
Filter [JST]
If fstat
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 SOCIETE = [F:JST]CPY
 # On vérifie que l'exercice sur lequel on était existe pour cette société
 Look [JST]JST0 = SOCIETE ; [M]JOU 
 If !fstat
  Gosub LECETAT
 Else
  Filter [JST] Where CPY=SOCIETE & JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
  Read [JST]JST0 Last
  Filter [JST]
  SOCIETE  = [F:JST]CPY
  Gosub LECETAT
 Endif
Endif
Return

$SOCLAST
Filter [JST] Where JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
Read [JST]JST0 Last
Filter [JST]
If fstat
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 SOCIETE = [F:JST]CPY
 # On vérifie que l'exercice sur lequel on était existe pour cette société
 Look [JST]JST0 = SOCIETE ; [M]JOU 
 If !fstat
  Gosub LECETAT
 Else
  Filter [JST] Where CPY=SOCIETE & JOU=[M]JOU & (LEG=PARAM(2) | PARAM(2)="")
  Read [JST]JST0 Last
  Filter [JST]
  SOCIETE  = [F:JST]CPY
  Gosub LECETAT
 Endif
Endif
Return

$ABANDON
REP = ""
Gosub LECETAT
Return

$ENREG
Call DEBTRANS From GLOCK
Gosub TR_JST
If GOK<1
 OK = 0 : Return
Endif
Gosub DEVERROU
VERROU = 0
REP = ""
Return

$TR_JST
GOK=1
Trbegin [JST]
 Raz [F:JST]
 Readlock [JST]JST0 = [M]CPY;[M]JOU
 If fstat=1
  GOK=-1 : GLOCK="$GAJOUSTA" : Goto ROLL_TR_JST
 Elsif fstat
  GOK=0 : Call RSTA("JST",[M]CPY-[M]JOU) From GLOCK : Goto AB_TR_JST
 Else
  [F:JST]=[M:JST1]
  [F:JST]LEG    = PARAM(2)
  [F:JST]UPDUSR = GUSER
  [F:JST]UPDDAT = date$
  Rewrite[JST]
  If fstat
   GOK=0 : Call FSTA("JST") From GLOCK : Goto AB_TR_JST
  Endif
 Endif
Commit
Return

$ROLL_TR_JST
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_JST : Endif

$AB_TR_JST
Rollback
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran JST1) 30/01/2012 19:05:55 (CP)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If GCURLEG<>"" & GCURLEG<>[F:CPY]LEG
 # Société XXX : # Réservé à la législation
 GMESSAGE = mess(2,45,1)-":"-VALEUR+"\"+mess(62,127,1)-":"-[F:CPY]LEG 
 mkstat  = 2 : End
Endif
End


######################################################################################

