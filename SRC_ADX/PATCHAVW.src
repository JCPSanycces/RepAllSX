#<AdxTL>@(#)12.0.0.0 $Revision$
###################################################
## Intégration d'une vue
###################################################
$VUE
Local File =DOSSIER(D)+".AVIEW"     [AVW]
Local File =DOSSIER(D)+".AVIEWD"    [AVD]
Local File =DOSSIER(D)+".AVIEWC"    [AVC]
Local File =DOSSIER(D)+".AVIEWB"    [AVB]
Read [AVW]AVW0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:AVW]
 Elsif [F:AVW]CODACT>="X" & !find([F:AVW]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_AVW
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_AVW
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_AVW
 Endif
 Gosub FIN_OBJ From PATCH
Endif

$FIN_AVW
Close Local File [AVW],[AVD],[AVC],[AVB]
Return

$DEL_AVW
Trbegin [AVW]
 Delete [AVW] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AVIEW"-NOMOBJ : Return
 Endif
Commit
Local Char WDOS(GLONADS) : WDOS =  DOSSIER(D)
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Gosub PROG_DEL_AWE From SUBAVW
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AVW",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return


$TR_AVW
GOK = 1
OKOBJ = 1
Trbegin [AVW] , [AVD] , [AVC] , [AVB]
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Un bout de vue
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AVW"   : Gosub AVW1
     When "AVD"   : Gosub AVW2
     When "AVC"   : Gosub AVW3
     When "AVB"   : Gosub AVW4
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

## Effacement zones supprimées

 For [AVD]AVD1 Where CODVUE=NOMOBJ
  If !find([F:AVD]FLDVUE,ZONE(1..NBZ))
&  & ([F:AVD]FLDACT<"X" or find([F:AVD]FLDACT,ACTIV(1..NBACT)))
   Delete [AVD]
  Endif
 Next
 If ER : Goto ABORT : Endif

Commit

## Validation de la vue
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AVW",[F:AVW]CODVUE,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

Gosub SAV_OPENI From PATCH
GINFO = 0
VALID = 1
If [F:AVW]CODACT <> ""
 Read [ACV]CODACT = [F:AVW]CODACT
 If fstat | [F:ACV]FLACT<>2
  Call ECR_TRACE(NOMOBJ-":"-mess(126,133,1),0) From GESECRAN : # Vue inactive
  VALID=0
 Endif
Endif
# Dans l'appli X3 , on ne valide que les vues de module "Superviseur"
# X3-53135 01.10.2018
If [L]ISFULLMOD<>2 and ((APPLI=GDOSX3 & [F:AVW]MODULE<>1) or instr(1,GDOSX3,"@"))
 VALID = 0
Endif
If VALID
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
 Call MAJVUE(NOMOBJ,APPLI) From DOSVUE
 If dim(ISVUE)>0
  ISVUE += 1
 Endif
 Call EXISTE_ADX("","","PATCHAVWB",OKTRT) From ORDSYS
 If OKTRT>0
  ACTION = "PATCH" : Gosub ACTION From PATCHAVWB
 Endif
Endif
Gosub REST_OPENI From PATCH
Return

## En-tête vue
$AVW1
FICHIER = "AVIEW" : ABR = "AVW"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:AVW]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:AVW]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AVW]CREDAT = date$
  [F:AVW]CREUSR = GUSER
  If dim([F:AVW]CRETIM)>0 : [F:AVW]CRETIM = time  : Endif
  [F:AVW]UPDDAT  = date$
  [F:AVW]UPDUSR  = GUSER
  If dim([F:AVW]UPDTIM)>0 : [F:AVW]UPDTIM = time  : Endif
 Endif
 Write [AVW]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AVW]UPDDAT  = date$
  [F:AVW]UPDUSR  = GUSER
  If dim([F:AVW]UPDTIM)>0 : [F:AVW]UPDTIM = time  : Endif
 Endif
 Rewrite [AVW]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AVIEW"-[F:AVW]CODVUE : Return
Endif
Return

## Zones
$AVW2
NBZ += 1 : ZONE(NBZ) = IDENT
FICHIER = "AVIEWD" : ABR = "AVD"
Read [AVD]AVD1 = NOMOBJ;IDENT
If fstat
 NEWZON = 1
Elsif [F:AVD]FLDACT>="X" & !find([F:AVD]FLDACT,ACTIV(1..NBACT)) : # Zone spécifique
 Gosub FIN_FIC From PATCH
 Return
Else
 NEWZON = 0
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWZON
 Write [AVD]
Else
 Rewrite [AVD]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AVIEWD"-[F:AVD]CODVUE-[F:AVD]FLDVUE : Return
Endif
Return

## Clés
$AVW3
NBZ += 1 : ZONE(NBZ) = IDENT
FICHIER = "AVIEWC" : ABR = "AVC"
Read [AVC]AVC0 = NOMOBJ;IDENT
If fstat
 NEWZON = 1
Elsif [F:AVC]CLEACT>="X" & !find([F:AVC]CLEACT,ACTIV(1..NBACT)) : # Zone spécifique
 Gosub FIN_FIC From PATCH
 Return
Else
 NEWZON = 0
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWZON
 Write [AVC]
Else
 Rewrite [AVC]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AVIEWC"-[F:AVC]CODVUE-[F:AVC]CODCLE : Return
Endif
Return

## Clobs
$AVW4
NBZ += 1 : ZONE(NBZ) = IDENT
FICHIER = "AVIEWB" : ABR = "AVB"
Read [AVB]AVB0 = NOMOBJ;val(IDENT)
If fstat
 NEWZON = 1
Else
 NEWZON = 0
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWZON
 Write [AVB]
Else
 Rewrite [AVB]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AVIEWB"-[F:AVB]CODVUE-num$([F:AVB]TYPDBA) : Return
Endif
Return

$ABORT
Rollback
Return

