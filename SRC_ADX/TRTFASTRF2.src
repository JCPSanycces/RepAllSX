#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################
#
# TRTFASTRF2 - Traitement secondaire de TRTFASTRF
#
######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
#
# Construction du nom des étiquettes :
#
# AAAA_BBBB_CCCCCC
#
# AAAA => Nom de la table origine (MAS1 / TMP1 / TPF1
# BBBB => Etape de l'action
# CCCC => Table destination ou Action ou Objet
######################################################################
# MODIF :
# MDJ 26.01.2016 FQ 113691   Transfert secteur activité: màj base plan subvention à tort
# CBO 10.12.2015 FQ110656    Accepte des Mouvements homogènes sur éléments physiques au lieu de un seul mouvement
# MDJ 27.08.2015 FQ110515    Evt transfert massif ==> site destinataire non renseigné
# CBO 04.08.2015 FQ110028    Erreur en interface des mouvements (gestion de LCTCOD)
# CBO 17.02.2015 FQ100398/13 Liaison FXD PHY
# MDJ 09.02.2015 FQ100398    Suppression site géographique
# MDJ 26.11.2014 FQ104286    Non Maj de UPDDAT lors de transferts/soties/dépréciations en massif
# MWA 10.09.2014 FQ95754_3   Classement pour vente (Sprint 38 - US 3) Opération interdite pour un bien classé pour vente
# CBO 21.05.2014 FQ99720     gestion de sélection en annulation de transfert
# GLE 18.12.2013 FQ94515     Erreur de régularisation de TVA et de mise à jour des bases si modification des paramètres après CONTROLER
# MWA 18.10.2013 FQ92911     Annutation de transfert des biens composants
# MWA 25.07.2013 FQ78968     Gestion LASM Livraison à soi même.
# MWA 21.02.2013 FQ67615_8   Ventilation analytiques biens POOL & LVA
# GLE 03.01.2012 FQ79031     Plantage annulation de transfert analytique en massif
# MDJ 23.12.2011 FQ78581     Interdiction transfert massif sur biens sortis
# GLE 15.11.2010 FQ66894     Optimisation des flux
# MWA 20.10.2010 FQ68431     Mauvaise affectation de l'indicateur de recalcul d'un contexte
# GLE 19.05.2010 FQ64478     Correction appel à GET_DPM_RSD
# GLE 12.04.2010 FQ63281     Correction erreur "TRFTYP@abelX3.TRTFASTRF2(1157)" en annulation de transfert avec application directe
# GLE 02.02.2010 FQ57840     Ajout d'un paramètre à GET_IMPUT_GEOANA_ORI pour récupérer le type de tranfert
# GLE 02.02.2010 FQ57878     Si on fait un transfert uniquement de localisation, les biens composants avec elt. phy. ne doivent pas avoir
#                             leurs dates de transfert mises à jour
# GLE 22.12.2009 FQ61108     Incompatibilité de type dans le message de tentative d'écriture d'une clé en double
# GLE 03.12.2009 FQ60573     Suppression d'un contrôle dans le cadre du transfert d'un bien principal avec composants liés à des éléments physiques
# GLE 07.09.2009 FQ57624     Standard Edition
# GLE 22.06.2009 FQ55485     Un bien composant peut subir un transfert de localisation en unitaire
# GLE 04.06.2009 FQ55578     Affichage des messages d'erreur en interactif quand on clique sur OK
# MABO04.06.2009 FQ55401     Bien comptable et site géographique
#####################################################################

$ACTMET

 ##Infbox ACTMET

 Case ACTMET

  When "CRITMEN"            :   Gosub CRITMEN              # U  - Activation menu ou bouton
  When "SET_PRECHARGE"      :   Gosub SET_PRECHARGE        # U  - A positionner à G_OUI s'il n'y a pas de bouton sélectionné
  When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS          # M  - Définition paramétres en-tête

  When "AM_FLGCPY"          :   Gosub AM_FLGCPY            # M  - Modification société
# Actions hors sous-programmes, communes au massif et à l'unitaire

  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier

# s/p "LOCKER"

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # M  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population

# s/p "CHARGER"

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# s/p "APPLIQUE_TEMP"

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Traitement commun avant application des paramètres de l'action aux enr de la table
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale

# s/p "REPORT_MASK" Report objet principal dans les masques (unitaire uniquement)

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# s/p "APPLIQUE_DIRT" Mise à jour directe (massif uniquement)

  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fin mise à jour directe

# s/p "REPORTER"

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture de table annexes pour le report tmp -> données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # Fiche 48468 UM - Report table temporaire principale -> table de données
  When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM - Traitement de fin de report

  When Default

 Endcase

Return

#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$CRITMEN
 # Permet d'alimenter la variable CRITMEN, condition d'activation du menu

 Local Integer AUTORISE : AUTORISE=1

 Local Integer AUZGEO
  Local Integer AUZANA
 Call GET_AUZ_GEOANA(nomap,GUSER,[M:FAS0]CPY,[M:FAS0]FCY,AUZGEO,AUZANA) From TRTFASTRF
 If AUZGEO=G_NON & AUZANA=G_NON
   AUTORISE=0
 Endif

 If !AUTORISE
   CRITMEN="1=0"
 Else
   CRITMEN="1=1"
 Endif
Return

#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement de la population en unitaire PRECHARGE
$SET_PRECHARGE
 PRECHARGE=G_OUI
Return

#=====================================================================
# Massif :
$SET_GLO_MAS
 G_NOCHOI_SELALL  = G_NON   # Si aucune cpy ou fcy cochée on sélectionne tout ?
 G_NOCHOI_CONTSOC = G_OUI   # Si aucune cpy cochée, on peut sortir du tableau ?
Return

################################################################################
$AM_FLGCPY
#--------------------------------------------------------------------
# Chargement du tableau des axes analytiques gérés dans la société
#--------------------------------------------------------------------
 #???? nouveau
 Local Integer I_DIE, SVNOLIGN
 SVNOLIGN=nolign : Raz nolign
 For I_DIE=1 To [M:FPC]NBDIE
  nolign+=1
  [M:FASM]DIE(nolign-1)   = [M:FPC]DIE(I_DIE-1)
  [M:FASM]CCED(nolign-1)  = ""
 Next I_DIE
 [M:FASM]NBLIG=nolign
 Affzo [M:FASM] 30
 nolign=SVNOLIGN
Return

#=====================================================================
# Unitaire et massif : Modif de la variable contenant le critère de sélection propre à l'action
$SET_CRITACT
  # Sélection des biens qui ne sont pas des composants et qui ne sont pas sortis (Fq-78581)
  If ACTTYPGES=GTAMMAS :
    # FQ67615_8 qui ne sont pas non plus des LVA ou des POOL
    # CRITACT="CMPSTA<>GVML_SBCOMPO&(ISSDAT=[0/0/0])"
    # FQ95754_3 CRITACT="CMPSTA<>GVML_SBCOMPO&CMPSTA<>GVML_SBLVA&CMPSTA<>GVML_SBPOOL&(ISSDAT=[0/0/0])"
    CRITACT="CMPSTA<>GVML_SBCOMPO&CMPSTA<>GVML_SBLVA&CMPSTA<>GVML_SBPOOL&ISSDAT=[0/0/0]&SALCLSDAT=[0/0/0]"
  Endif
Return

# FQ99720 complète la requète en trt massif (appelé depuis les boutons CONTROLER et OK)
$SET_CRITACT_CPLTE

    Gosub SET_CRITACT

    If [M:FASM]CCLTRF = G_OUI
        CRITACT -= "and TRFDAT = [M:FASM]MVTDAT"
    Endif
Return

#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK

 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif

 # Ouverture de la table des éléments physiques
# If GPHY = G_OUI
#    If !clalev([F:PHY]) : Local File PHYELT [PHY] : Endif
# Endif

 Local Integer CCLTRF
 CCLTRF=[M:FASM]CCLTRF

 Local Integer I_CPY
 Local Integer I_CNX

 Local Char    CPYSEA
 Local Date    CPYSTRFIY(1..G300MAX)
 Local Date    CPYENDFIY(1..G300MAX)
 Local Date    CPYSTRPER(1..G300MAX)
 Local Date    CPYENDPER(1..G300MAX)
 Local Integer RETOUR

Return

#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE
 # Chargement des dates exercices et périodes de la société à rupture société
 If ((ACTTYPGES=GTAMMAS) & (CPYSEA<>[F:MAS1]CPY))
  Call GET_CPY_DAT([F:MAS1]CPY,CPYSTRFIY,CPYENDFIY,CPYSTRPER,CPYENDPER,RETOUR) From GLOBIENS
  CPYSEA=[F:MAS1]CPY
 Endif

 # Les BCO dont le type de détention est "En modèle" sont exclus. Fait ici car OWNTYP ne figure pas dans un Idx de FXDASSETS
 If ACTTYPGES=GTAMMAS & [F:MAS1]OWNTYP=GVML_TDMODEL
  GOK=0
  Return
 Endif

 #Fq-78581 Les BCO sortis ne sont pas sélectionnés
 If ACTTYPGES=GTAMMAS & [F:MAS1]ISSDAT<>[0/0/0]
  GOK=0
  Return
 Endif

 If ACTTYPGES=GTAMMAS and CCLTRF=G_NON and [F:MAS1]VATYEAFLG = G_OUI and [M:FASM]AASBUSD <> [F:MAS1]AASBUS
  # "Transfert de secteur interdit : Bien ayant déjà subi une régularisation annuelle pour l'exercice"
  GOK=0
  Return
 Endif

 # Transfert : date de transfert postérieure à date de dernier transfert ?
 If CCLTRF=G_NON

  #> Le BCO ne doit pas être sorti et le transfert doit être postérieur au dernier transfert
  If ((ACTTYPGES=GTAMMAS) & ([F:MAS1]TRFDAT<>[0/0/0]) & ([M:FASM]MVTDAT<=[F:MAS1]TRFDAT))
   GOK=0
   Return
  Endif

  If ( (ACTTYPGES=GTAMMAS) & ([F:MAS1]ISSDAT<>[0/0/0] & [M:FASM]MVTDAT>=[F:MAS1]ISSDAT) )
   GOK=0
   Return
  Endif

#  If GPHY=G_OUI & ACTTYPGES=GTAMMAS Then # Issue 110656
  If GPHY=G_OUI & ACTTYPGES=GTAMMAS and [M:FASM]ECRPHYATT <> G_OUI # Issue 110656
    # Le transfert doit être postérieur au dernier transfert des éléments physiques
    # Recherche de la date de dernier transfert la plus récente des éléments physiques rattachés au bien
    # Recherche de la dernière date de réception des éléments physiques rattachés au bien
    Local Date DATE_ELT_PHY
    Local Integer WMVT
    # Issue 110515 - 2015-08-27 by MDJ : WFCY remplacé par XFCY car WFCY déjà utilisé pour les evts
    Local Char WPHYREF(GLONPHY), XFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)
     If func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:MAS1]AASREF, 0,
&          WPHYREF, DATE_ELT_PHY, XFCY, WLCTCOD, WREN, WMVT) Then
       G_ORI_TRFDAT = "T"
     Endif
#    DATE_ELT_PHY = func TRTPHYTOOL.CTL_ELT_PHY_TRF([F:MAS1]AASREF,G_ORI_TRFDAT)
    # Pas de transfert si un élément physique est en 1ere attente de mouvement de sortie
    # FQ60573 : suppression du contrôle "pas de transfert pour les biens principaux, si la localisation de destination n'est pas renseignée et si les
    # biens composants ont des éléments physiques"
    If (DATE_ELT_PHY <> [0/0/0] & [M:FASM]MVTDAT<=DATE_ELT_PHY)
&   or func PHYELT_C_MPR._GET_PHY_WITH_ISS_FROM_FAS([F:MAS1]AASREF, WPHYREF) > 0
#&   or (func TRTPHYTOOL.CTL_ELT_PHY_SOR([F:MAS1]AASREF))

#&   or ([F:MAS1]CMPSTA=GVML_SBPRINC and [M:FASM]LCTCOD = "" and func TRTPHYTOOL.RECH_COMP_ELT_PHY([F:MAS1]AASREF) = G_OUI) Then # FQ60565
       GOK=0
       Return
    Endif
  Endif


# Transfert de secteur d'activité interdit si bien acquis dans l'exercice courant
# et date de transfert postérieure à l'exercice courant
   If (ACTTYPGES=GTAMMAS)                 &
&     ([M:FASM]AASBUSD<>"")               &
&     ([M:FASM]AASBUSD<>[F:MAS1]AASBUS)   &
&     ([M:FASM]MVTDAT>CPYENDFIY(G301CPT)) &
&     ([F:MAS1]AASIPTDAT>=CPYSTRFIY(G301CPT) & [F:MAS1]AASIPTDAT<=CPYENDFIY(G301CPT))
   GOK=0
   Return
  Endif

 Endif

 # Annulation de Transfert

 If CCLTRF=G_OUI

  If ACTTYPGES=GTAMMAS

   #> Est-ce que les imputations destinations fournies par l'utilisateur correspondent aux imputations actuelles du bien ?
   If [M:FASM]FCYD   <>"" & [F:MAS1]FCY   <>[M:FASM]FCYD    : GOK=0 : Return : Endif
   ####If [M:FASM]LCTCOD   <>"" & [F:MAS1]LOC   <>[M:FASM]LCTCOD    : GOK=0 : Return : Endif
   If [M:FASM]AASBUSD<>"" & [F:MAS1]AASBUS<>[M:FASM]AASBUSD : GOK=0 : Return : Endif
   If [M:FASM]IASCGUD<>"" & [F:MAS1]IASCGU<>[M:FASM]IASCGUD : GOK=0 : Return : Endif
   If [M:FASM]DSPD   <>"" & [F:MAS1]DSP   <>[M:FASM]DSPD    : GOK=0 : Return : Endif
   Local Integer I_AXE
   #????
   # For I_AXE=1 To GOPTCANA
   For I_AXE=1 To [M:FPC]NBDIE
    #????
    #If [M:FASM]CCED(I_AXE-1) <>"" & [F:MAS1]CCE([M:FASM]AXE(I_AXE-1)-1) <>[M:FASM]CCED(I_AXE-1) : GOK=0 : Break : Endif
    # FQ79031 : plantage en annulation massive
#    If [M:FASM]CCED(I_AXE-1) <>"" & [F:MAS1]CCE([M:FASM]DIE(I_AXE-1)-1) <>[M:FASM]CCED(I_AXE-1) : GOK=0 : Break : Endif
       If [M:FASM]CCED(I_AXE-1) <>"" & [F:MAS1]CCE(find([M:FASM]DIE(I_AXE-1),[F:MAS1]DIE)-1) <>[M:FASM]CCED(I_AXE-1) : GOK=0 : Break : Endif
   Next I_AXE
   If GOK=0
    Return
   Endif

   #> Est-ce que la date de dernier transfert est postérieure au début d'exercice pour tous les contextes gérés

   For I_CNX=1 To G300MAX
    If CPYSTRFIY(I_CNX)<>[0/0/0] & [F:MAS1]TRFDAT<CPYSTRFIY(I_CNX)
     GOK=0
     Break
    Endif
   Next I_CNX

   If GOK=0
    Return
   Endif

   #> Annulation impossible si pas d'événement permettant de retrouver la situation antérieur
   If func TRTFASTRFHIS.GET_PLN_EVE_TRF([F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,[F:MAS1]TRFDAT)
    GOK=1
   Else
    GOK=0
   Endif

   # Fiche 48468
   If GOK=0
    Return
   Endif

#   If GPHY=G_OUI Then
   If GPHY=G_OUI & ACTTYPGES=GTAMMAS and [M:FASM]ECRPHYATT <> G_OUI # Issue 110656
     # L'annulation est impossible si le transfert du bien est postérieur au dernier transfert des éléments physiques
     # Recherche de la date de dernier transfert la plus récente des éléments physiques rattachés au bien
     # Recherche de la dernière date de réception des éléments physiques rattachés au bien
     Local Date DATE_ELT_PHY
     Local Integer WMVT
    # Issue 110515 - 2015-08-27 by MDJ : WFCY remplacé par XFCY car WFCY déjà utilisé pour les evts
     Local Char WPHYREF(GLONPHY), XFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)
     If func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:MAS1]AASREF, 0,
&          WPHYREF, DATE_ELT_PHY, XFCY, WLCTCOD, WREN, WMVT) Then
       G_ORI_TRFDAT = "T"
     Endif

#     DATE_ELT_PHY = func TRTPHYTOOL.CTL_ELT_PHY_TRF([F:MAS1]AASREF,G_ORI_TRFDAT)
     # Pas d'annulation de transfert si un élément physique est en 1ere attente de mouvement de sortie
     # Annulation impossible si le site de la situation antérieur est différent de la situation antérieur des éléments physiques rattachés
     # Contrôle si le site géographique en paramètre est différent des événements des éléments physiques attachés au bien
     If (DATE_ELT_PHY <> [0/0/0] & [F:MAS1]TRFDAT<DATE_ELT_PHY)
&   or func PHYELT_C_MPR._GET_PHY_WITH_ISS_FROM_FAS([F:MAS1]AASREF, WPHYREF) > 0
#&    or (func TRTPHYTOOL.CTL_ELT_PHY_SOR([F:MAS1]AASREF))
        GOK=0
        Return
     Endif
   Endif

   If GOK=0
    Return
   Endif

   #> Annulation impossible si il y a eu une variation des valeurs d'entrée H.T.
   Local Decimal ORIACGETRNOT, ORIIASETRNOT
   Local Integer RCOD
   Call GET_ETRNOT_ORI([F:MAS1]CPY,G301CPT,[F:MAS1]FCY,[F:MAS1]AASREF,[F:MAS1]TRFDAT, ORIACGETRNOT, ORIIASETRNOT, RCOD) From TRTFASTRFHIS
   If (([F:MAS1]ACGETRNOT<>ORIACGETRNOT) | ([F:MAS1]IASETRNOT<>ORIIASETRNOT))
    GOK=0
   Else
    GOK=1
   Endif

  Endif
 Endif

Return

#=====================================================================
# Unitaire / massif : Lock des composants et/ou complémentaires
#                     des biens non exclu dans CONTROLE
#                     Alimenter RMES si un message soit apparaître
$MAS1_LOCK_AUTRE
 Local Integer LCKOK
 If [F:MAS1]CMPSTA=GVML_SBPRINC
  Filter [MAS2] Where CMP=[F:MAS1]AASREF
  For [MAS2]
   LKEY = func GLOBIENS.GET_KEY_FXDASSETS ([F:MAS2]AASREF)
   If !(LKEY="")
     LCKOK=func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:MAS2]CPY, LKEY, 0)
    If LCKOK=0
     RMES=mess(226,7773,1)-[F:MAS2]AASREF+"/"+[F:MAS2]AASDES1+"." # "Enregistrement en cours d'utilisation"
     GOK=-1
     Break
    Elsif LCKOK=1
     GOK=1
     Raz [TML]
     [F:TML]TRTNUM  = NUMACT
     [F:TML]OBJTYP  = GVML_OMBIEN
     [F:TML]OBJREF  = [F:MAS2]AASREF
     [F:TML]OBJLIN  = 0
     [F:TML]OBJCPY  = [F:MAS2]CPY
     [F:TML]OBJSYM  = LKEY
     [F:TML]OBJMAIN = G_NON
     Write [TML]
     If fstat
      Case fstat
       When 1
        RMES="TMPMASLCK"-mess(227,7773,1)  # "TMPMASLCK table verrouillée"
       When 3
        RMES=mess(129,7773,1)-[F:TML]TRTNUM+"/"+[F:TML]OBJREF  # Tentative d'écriture en double de la clé
        If ACTREFOBJ="LOF" : RMES+="/"+[F:TML]OBJLIN : Endif
        RMES-="\TMPMASLCK."       #
      Endcase
      GOK=0
      Break
     Endif
     NBOBJLCK+=1
    Elsif LCKOK=-1
     GOK=0
    Endif
   Endif
  Next
  Filter [MAS2]
 Endif

Return

#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
 Local Char TABORI
 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
Return

#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1

#=> On crèé les composants dans la table temporaire
 If [F:MAS1]CMPSTA=GVML_SBPRINC
  Filter [MAS2] Where (CMP=[F:MAS1]AASREF)
  For [MAS2]
   Raz [F:TMP1] : TABORI="[F:MAS2]" : Gosub ALIM_ENR   From TRTFASTRF
   Write [TMP1]
   Gosub TRT_RET_ALIM_TMP1 From TRTFASTRF2
   If GOK<1 : Break : Endif
  Next
  Filter [MAS2]
 Endif

#=> Si une erreur s'est produite on sort

 If GOK<1
  Return
 Endif

#=> Alimentation table temporaire par objet

 Raz [F:TMP1] : TABORI="[F:MAS1]" : Gosub ALIM_ENR   From TRTFASTRF
 Write [TMP1]
 Gosub TRT_RET_ALIM_TMP1 From TRTFASTRF2
Return

######################

$TRT_RET_ALIM_TMP1
 If fstat
  Case fstat
   When 1
    RMES="TMPMASFAS"-mess(227,7773,1)  # "TMPMASFAS table verrouillée"
    GOK=-1
   When 3
    RMES=mess(129,7773,1)-num$([F:TMP1]TRTNUM)+"/"+[F:TMP1]OBJREF # "Tentative d'écriture en double de la clé" : # FQ61108 : ajout num$ sur TRTNUM
    GOK=0
   When Default
  Endcase
  Break 1
 Else
  NBTMP+=1
 Endif
Return

#=====================================================================
# Unitaire / massif : Traitements communs avant applications des paramètres sur la table temporaire
$OUVR_APPL_TMP1

#=> Déclaration des variables nécessaires au s/p d'application des paramètres aux éléments de la table temporaire

 Local Integer CCLTRF
 Local Date    TRFDAT
 Local Char    CLASORI
 Local Char    CLASDES
 Local Char    SUFFORI
 Local Char    SUFFDES
 Local Char    SUFFIX_ZONE
 Local Integer RETOUR,I_AXE
 Local Char    FCYORI
 Local Char    LOCORI
 Local Char    AASBUSORI
 Local Char    IASCGUORI
 Local Char    DSPORI
 Local Char    CCETABORI(15)(GOPTCANA)
 Local Date    TRFDATORI
 Local Decimal PCGDEVORI
 Local Decimal IASDEVORI
 Local Decimal DEDVATRAT
 Local Decimal DEDVATRATI
 Local Integer RETOUR
 Local Integer USE_PAR_VIDE
 Local Integer IMPUT_INCH              # Indicateur d'imputations inchangée # Bug n°26442

 Local Shortint TRFTYP : # FQ57840

 Local Decimal  IVCVATAMT # FQ78968 (1)
 Local Integer  IVCVATFLG
 Local Decimal  IVCVATAMTI
 Local Integer  IVCVATFLGI
 Local Decimal  TAXCOEORI
 Local Decimal  TAXCOEFORI
 Local Decimal  REGULPCGORI
 Local Decimal  REGULIASORI
 Local Date     VATREGDATORI

#=> Initialisation des variables

 CCLTRF=[M:FASM]CCLTRF
 TRFDAT=[M:FASM]MVTDAT

 # FQ94515
 If ACTTYPGES=GTAMMAS
   If !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif
 Endif

Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1

#=> Alimentation du type d'opération (transfert ou annulation de transfert) dans la table temporaire

[F:TMP1]CCLTRF=CCLTRF

#=> Transfert

If CCLTRF=G_NON
 # Alimentation de la date de transfert
 [F:TMP1]MVTDAT=[M:FASM]MVTDAT

 # Initialisation de l'enregistrement (Pour le cas où on passe plusieurs fois par contrôler - ex modif de paramétres)

 If [F:TMP1]FCY<>[F:TMP1]FCYO       : [F:TMP1]FCY=[F:TMP1]FCYO       : Endif
 ####If [F:TMP1]LOC<>[F:TMP1]LOCO       : [F:TMP1]LOC=[F:TMP1]LOCO       : Endif
 If [F:TMP1]AASBUS<>[F:TMP1]AASBUSO : [F:TMP1]AASBUS=[F:TMP1]AASBUSO : Endif
 If [F:TMP1]IASCGU<>[F:TMP1]IASCGUO : [F:TMP1]IASCGU=[F:TMP1]IASCGUO : Endif
 If [F:TMP1]DSP<>[F:TMP1]DSPO       : [F:TMP1]DSP=[F:TMP1]DSPO       : Endif

 # FQ94515 : relecture des informations pour le calcul de la TVA en cas de modif de paramètres
 If ([F:TMP1]AASBUS<>[M:FASM]AASBUSD) and (ACTSTATUS=STA_TEMP)
  Local Char TABORI(8) : TABORI="[F:FAS]"
  If ACTTYPGES=GTAMMAS
    Read [F:FAS]FAS0=[F:TMP1]OBJREF
    If fstat
      RMES="Error reading [F:FAS]"-[F:TMP1]OBJREF-":"-num$(fstat)
      Return
    Endif
  Endif
  #> Zones nécessaires à la régul de TVA
  Gosub ALIM_ENR_TVA From TRTFASTRF
 Endif

 Local Integer I_AXE
 #????
 #For I_AXE=1 To GOPTCANA
 For I_AXE=1 To [M:FPC]NBDIE
  If [F:TMP1]CCE(I_AXE-1)<>[F:TMP1]CCEO(I_AXE-1) : [F:TMP1]CCE(I_AXE-1)=[F:TMP1]CCEO(I_AXE-1) : Endif
 Next I_AXE

 # Transfert

 CLASORI="[M:FASM]"
 CLASDES="[F:TMP1]"
 SUFFIX_ZONE="D"
 If ACTTYPGES=GTAMMAS
  USE_PAR_VIDE=G_NON
 Elsif ACTTYPGES=GTAMUNI
  USE_PAR_VIDE=G_OUI
 Endif
 Gosub TRF_CLASORI_TO_CLASDES From TRTFASTRF

 [F:TMP1]RENTRF=[M:FASM]REN

 # En unitaire, les param non obligatoires vides sont pris en compte (ex site géo vide)
 # Contrôle imputations inchangée ?
 CLASORI="[F:TMP1]" : SUFFORI="O"
 CLASDES="[M:FASM]" : SUFFDES="D"

 If ACTTYPGES=GTAMMAS
  USE_PAR_VIDE=G_NON
 Elsif ACTTYPGES=GTAMUNI
  USE_PAR_VIDE=G_OUI
 Endif

 Gosub CONTROLE_BCO_IMPUTATIONS_INCHANGEE From TRTFASTRF
 # Variable globale pour transfert imputation inchangée
 # Si on a rien changé dans le transfert de l'imputation et que l'on est en localisation multiple (typloc=2)
 # on passe le flag INPUT_INCH à G_NON car on va faire seulement des transferts de localisations sur les éléments physiques
 If GPHY = G_OUI Then
    SV_IMPUT_INCH=IMPUT_INCH
    # FQ100398/13
 Endif

 If IMPUT_INCH=G_OUI
  [F:TMP1]FLGERR=G_OUI
  [F:TMP1]MSGERR=mess(387,7773,1) # "Imputations inchangées pour ce bien"
  Return
 Endif

 CLASORI="[M:FASM]" : CLASDES="[F:TMP1]"


 # Contrôles des nouvelles affectations et imputations

 Gosub CONTROLE_BCO_IMPUTATIONS_TMP From TRTFASTRF
 If GPHY = G_OUI and ACTTYPGES=GTAMMAS Then
   #-----------------------------------------------------------------------------------------
   # Traitement des biens ayant des éléments physique avec des mvt en attente
   #-----------------------------------------------------------------------------------------
# Issue 110656
#   Local Char WPHY(GLONPHY)
#   Local Date WTRFDAT
#   Local Integer WMVT
   # Issue 110515 - 2015-08-27 by MDJ : WFCY remplacé par XFCY car WFCY déjà utilisé pour les evts
#   Local Char XFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)
#   If [M:FASM]ECRPHYATT = G_NON and func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:TMP1]OBJREF, 0,
#&         WPHY, WTRFDAT, XFCY, WLCTCOD, WREN, WMVT) Then
#     [F:TMP1]FLGERR = G_OUI
#     [F:TMP1]MSGERR = mess(75,7775,1)

    If [M:FASM]ECRPHYATT = G_NON
      Local Integer WNBR_MVT
      Local Char WLCTCOD(GLONLCT), WFCY2(GLONFCY)

      WNBR_MVT = func PHYELT_C_MPR._GET_INFOS_IDENTICAL_MVT_TRF("AASREF = '" + [F:TMP1]OBJREF + "'",
&                WLCTCOD, WFCY2)
      If WNBR_MVT <> 0
        [F:TMP1]FLGERR = G_OUI
        [F:TMP1]MSGERR = mess(230, 7775, 1)
      Endif
      # End Issue 110656
   Endif
 Endif
 # Régularisation de TVA
 [F:TMP1]REGTVAFLG=G_NON
 If [F:TMP1]AASBUS<>[F:TMP1]AASBUSO

   # Paramètres pour régul TVA
   Call GET_ELEM_REG_TVA([F:TMP1]CPY) From TRTFAS

   Gosub TRT_REGUL_TVA From TRTFASTRF
   If IASDEV | PCGDEV
    [F:TMP1]REGTVAFLG=G_OUI
    [F:TMP1]PCGDEV=PCGDEV
    [F:TMP1]IASDEV=IASDEV
    [F:TMP1]REGUL =G_REGUL
    [F:TMP1]REGULI=G_REGULI
   Endif
 Endif
Endif

#=> Annulation de Transfert

If CCLTRF=G_OUI
 If ACTTYPGES=GTAMUNI : [F:TMP1]MVTDAT=[M:FASM]TRFDAT : Endif
 If ACTTYPGES=GTAMMAS : [F:TMP1]MVTDAT=[M:FASM]MVTDAT : Endif
 # Récupération des imputations d'origine du bien
# FQ57840 FQ78968(1)
  Call GET_IMPUT_GEOANA_ORI([F:TMP1]CPY,[F:TMP1]FCY,[F:TMP1]OBJREF,[F:TMP1]MVTDAT,
&                            FCYORI,AASBUSORI,IASCGUORI,DSPORI,
&                            CCETABORI,TRFDATORI,
&                            PCGDEVORI,IASDEVORI,DEDVATRAT,DEDVATRATI,TRFTYP,
&                            IVCVATAMT,IVCVATFLG,IVCVATAMTI,IVCVATFLGI,
&                            TAXCOEORI,TAXCOEFORI,REGULPCGORI,REGULIASORI,VATREGDATORI,RETOUR) From TRTFASTRFHIS
 # Report des imputations d'origine du bien dans l'enr. de la table temporaire.
  [F:TMP1]RENTRF      = ""
  [F:TMP1]MVTDAT      = [0/0/0]
  [F:TMP1]FCY         = FCYORI
  ####[F:TMP1]LOC         = LOCORI
  [F:TMP1]AASBUS      = AASBUSORI
  [F:TMP1]IASCGU      = IASCGUORI
  [F:TMP1]DSP         = DSPORI
  Local Integer I_AXE
  For I_AXE=1 To [M:FPC]NBDIE
   [F:TMP1]CCE(I_AXE-1) = CCETABORI(I_AXE-1)
  Next I_AXE
  [F:TMP1]MVTDAT      = TRFDATORI
  [F:TMP1]PCGDEV      = PCGDEVORI
  [F:TMP1]IASDEV      = IASDEVORI
  [F:TMP1]DEDVATAMT  -= PCGDEVORI
  [F:TMP1]DEDVATAMTI -= IASDEVORI
  [F:TMP1]DEDVATRAT   = DEDVATRAT
  [F:TMP1]DEDVATRATI  = DEDVATRATI

  # FQ78968 (1)
  [F:TMP1]IVCVATAMT   = IVCVATAMT
  [F:TMP1]IVCVATFLG   = IVCVATFLG
  [F:TMP1]IVCVATAMTI  = IVCVATAMTI
  [F:TMP1]IVCVATFLGI  = IVCVATFLGI
  [F:TMP1]TAXCOE      = TAXCOEORI
  [F:TMP1]TAXCOEF     = TAXCOEFORI
  [F:TMP1]REGUL       = REGULPCGORI
  [F:TMP1]REGULI      = REGULIASORI
  Local Decimal W_DEDCOE
  Call TVA_COE_DEDUCTION ( [F:TMP1]ASJCOE, [F:TMP1]TAXCOE, [F:TMP1]ADMCOE, W_DEDCOE ) From TRTFAS
  [F:TMP1]DEDCOE  = W_DEDCOE
  Call TVA_COE_DEDUCTION ( [F:TMP1]ASJCOEF, [F:TMP1]TAXCOEF, [F:TMP1]ADMCOEF, W_DEDCOE ) From TRTFAS
  [F:TMP1]DEDCOEF = W_DEDCOE
  [F:TMP1]VATREGDAT   = VATREGDATORI

  If PCGDEVORI | IASDEVORI
   [F:TMP1]REGTVAFLG  = G_OUI
  Endif
Endif

Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK
 If [F:TMP1]FLGERR=G_NON
  Local Integer RETOUR,I_AXE

  #> FAS0

  # FQ66894 : flux a générer si transfert de site financier
  If [M:FAS0]FCY <> [F:TMP1]FCY
    Local Integer N_CNX
    For N_CNX = 1 To G300MAX
       Call MAJFLGCNXFLX("[M:FAS0]", "", N_CNX, num$(GVML_FLXNOTG)) From TRTFAS
    Next
  Endif

  Call APPL_ZONE("[M:FAS0]","FCY","[F:TMP1]","FCY",G_OUI,RETOUR) From TRTFASTRF

  #> FAS1

  [M:FAS1]AASBUS=[F:TMP1]AASBUS
  [M:FAS1]SACDES=[M:FASM]SACDES
  [M:FAS1]TAXCOE     = [F:TMP1]TAXCOE
  [M:FAS1]DEDCOE     = [F:TMP1]DEDCOE

  If GKFR = G_OUI Then : # FQ57624
    [M:FAS5]TAXCOEF    = [F:TMP1]TAXCOEF
    [M:FAS5]DEDCOEF    = [F:TMP1]DEDCOEF
    [M:FAS5]TAXCOE2    = [F:TMP1]TAXCOE
    [M:FAS5]DEDCOE2    = [F:TMP1]DEDCOE
    [M:FAS5]VATREGDAT  = [F:TMP1]VATREGDAT
    [M:FAS5]VATRSD     = [F:TMP1]VATRSD
  Endif

  [M:FAS1]IVCVATAMT  = [F:TMP1]IVCVATAMT
  [M:FAS1]IVCVATFLG  = [F:TMP1]IVCVATFLG
  [M:FAS1]DEDVATRAT  = [F:TMP1]DEDVATRAT
  [M:FAS1]DEDVATAMT  = [F:TMP1]DEDVATAMT
  [M:FAS1]DEDVATFLG  = [F:TMP1]DEDVATFLG
  [M:FAS1]ACGBSEVAL  = [M:FAS1]ACGETRNOT + [M:FAS1]IVCVATAMT - [M:FAS1]DEDVATAMT

  [M:FAS1]IVCVATAMTI = [F:TMP1]IVCVATAMTI
  [M:FAS1]IVCVATFLGI = [F:TMP1]IVCVATFLGI
  [M:FAS1]DEDVATRATI = [F:TMP1]DEDVATRATI
  [M:FAS1]DEDVATAMTI = [F:TMP1]DEDVATAMTI
  [M:FAS1]DEDVATFLGI = [F:TMP1]DEDVATFLGI
  [M:FAS1]IASBSEVAL  = [M:FAS1]IASETRNOT + [M:FAS1]IVCVATAMTI - [M:FAS1]DEDVATAMTI

  #> FAS2
  ####[M:FAS2]LOC=[F:TMP1]LOC
  [M:FAS2]IASCGU=[F:TMP1]IASCGU
  [M:FAS2]DSP=[F:TMP1]DSP
  For I_AXE=1 To [M:FPC]NBDIE
   If [M:FAS2]CCE(I_AXE-1)<>[F:TMP1]CCE(I_AXE-1)
    [M:FAS2]CCE(I_AXE-1)=[F:TMP1]CCE(I_AXE-1)
   Endif
  Next I_AXE
  [M:FAS2]TRFDAT=[F:TMP1]MVTDAT

  # Mise à jour de TAXBAS
  [M:FAS2]TAXBAS    = [M:FAS1]ACGBSEVAL

  #> FAS3 (A mettre à jour uniquement si c'est le DEPREC de la période courante qui a été modifié)

  If [F:TMP1]REGTVAFLG=G_OUI
   Local Decimal BASDPR, MTDES
   Local Char    CURBASDPR
   Local Integer STAT

   For nolign=1 To [M:FAS3]NBLIG1
     #> Quelles valeur bilan base d'amortissement
     # Issue 113691  pas de maj plan subvention si non subventionné et base = 0
     Case [M:FAS3]ORIBAS(nolign-1)
      When GVML_OBPCG
        BASDPR    = [M:FAS1]ACGBSEVAL
        CURBASDPR = [M:FAS1]ACGCUR
      When GVML_OBIAS
        BASDPR=[M:FAS1]IASBSEVAL
        CURBASDPR = [M:FAS1]IASCUR
      When GVML_OBSUB
        If [M:FAS2]INVPLN="" and [M:FAS3]DPRBAS(nolign-1) = 0
          Goto NEXT_PLN
        Endif
     Endcase
     #> Conversion dans la devise du plan si nécessaire
     If CURBASDPR<>[M:FAS3]CUR(nolign-1)
      Call CONVERT3(CURBASDPR, [M:FAS3]CUR(nolign-1), GCOUDEV,
&                  [M:FAS3]CURTYP(nolign-1), [F:TMP1]MVTDAT,
&                  BASDPR, MTDES, [M:FAS3]RATCUR(nolign-1) , STAT) From CPTSUB
     Else
      MTDES=BASDPR
     Endif
     Call GET_MNT_ARRONDI(MTDES, [M:FAS3]CUR(nolign-1), MTDES) From GLOBIENS
     If [M:FAS3]BSEVAL(nolign-1)=[M:FAS3]DPRBAS(nolign-1)
      [M:FAS3]DPRBAS(nolign-1)=MTDES
     Endif
     [M:FAS3]BSEVAL(nolign-1)=MTDES

    # Le bien est à recalculer
     [M:FAS3]DEPSTA(nolign-1)        = GVML_SCNOCAL
     # FQ68431
     [M:FAS0]FLGCNXCLC([M:FAS3]CNX(nolign-1)-1)= G_OUI
     [M:FAS0]FLGCLC                  = G_OUI

    ### CHANGEMENT DU MODE

     Local Integer I_CNX
     Local Char    PDPM
     Local Date    CNXDAT(1..5)

     Call GET_CNX_DAT([M:FAS0]CPY,[M:FAS3]CNX,CNXDAT,RETOUR) From GLOBIENS

     If [M:FASM]CCLTRF = G_OUI
       # On restaure le mode d'origine si le transfert était postérieur à l'exercice d'acquisition
       If ( GKFR = G_OUI and [M:FAS5]VATREGDAT < CNXDAT(1) )
&      or ( GKFR = G_NON and [M:FAS1]PURDAT    < CNXDAT(1) ) Then : # FQ57624
         If !clalev([WMTC]) : Local File EFASMTC [WMTC] : Endif
         Filter [WMTC] Where REF=[M:FAS0]AASREF and DPRPLN=[M:FAS3]DPRPLN(nolign-1)
         Read [WMTC]EVE0 Last
         Filter [WMTC]
         If !fstat and [F:WMTC]DPMO <> "" Then
           [M:FAS3]DPM(nolign-1)    = [F:WMTC]DPMO
         Endif
       Endif
     Elsif ( GKFR = G_OUI and [M:FAS5]VATREGDAT < CNXDAT(1) )
&       or ( GKFR = G_NON and [M:FAS1]PURDAT    < CNXDAT(1) ) Then : # FQ57624
       # Passage en mode résiduel si on est au-delà de l'exercice d'acquisition
       # FQ64478
       #PDPM = func TRTFAS.GET_DPM_RSD("", [M:FAS3]DPM(nolign-1))
       #If PDPM = ""  : PDPM = func TRTFAS.GET_DPM_RSD([M:FAS0]CPY, [M:FAS3]DPM(nolign-1)) : Endif
       Local Integer PPRATTYP
       Call GET_DPM_RSD("", [M:FAS3]DPM(nolign-1), PDPM, PPRATTYP) From TRTFAS
       If PDPM = ""  : Call GET_DPM_RSD([M:FAS0]CPY, [M:FAS3]DPM(nolign-1), PDPM, PPRATTYP) From TRTFAS : Endif
       # FIN FQ64478
       If PDPM <> "" Then
         [M:FAS3]DPM(nolign-1)    = PDPM
       Endif
     Endif
     $NEXT_PLN  # Issue 113691
   Next nolign
  Endif

  #> FAS4
  [M:FAS4]GALREFBAS = [M:FAS1]ACGBSEVAL

  #> FAS5
  If GKFR = G_OUI Then : # FQ57624
    [M:FAS5]TAXCOEF    = [F:TMP1]TAXCOEF
    [M:FAS5]DEDCOEF    = [F:TMP1]DEDCOEF
    [M:FAS5]TAXCOE2    = [F:TMP1]TAXCOE
    [M:FAS5]DEDCOE2    = [F:TMP1]DEDCOE
    [M:FAS5]VATREGDAT  = [F:TMP1]VATREGDAT
    [M:FAS5]VATRSD     = [F:TMP1]VATRSD
    # FQ78968
    If ( [M:FASM]CCLTRF = G_OUI ) Then
    If ( [F:TMP1]REGUL > 0 ) Then
        [M:FAS5]VATREGDED  -= abs([F:TMP1]REGUL)
        [M:FAS5]VATREGDEDI -= abs([F:TMP1]REGULI)
      Else
        [M:FAS5]VATREGAMT  -= abs([F:TMP1]REGUL)
        [M:FAS5]IASVATREG  -= abs([F:TMP1]REGULI)
      Endif
    Else
      If ( [F:TMP1]REGUL > 0 ) Then
      [M:FAS5]VATREGDED  += abs([F:TMP1]REGUL)
      [M:FAS5]VATREGDEDI += abs([F:TMP1]REGULI)
    Else
      [M:FAS5]VATREGAMT  += abs([F:TMP1]REGUL)
      [M:FAS5]IASVATREG  += abs([F:TMP1]REGULI)
    Endif
  Endif
  Endif

  # Maj des champs UPDx - FQ104286
  [M:FAS9]UPDUSR=GUSER
  [M:FAS9]UPDDAT=date$

  #> Mise à jour du témoin de modification
  ACTMODIF=1
 Else
  # FQ55578 : pour afficher le message d'erreur (voir TRTFASTRF $OK)
  GERR     = 1
  GMESSAGE = [F:TMP1]MSGERR
 Endif
Return

#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
  Affzo [M:FAS0]  : Affzo [M:FAS1] : Affzo [M:FAS2] : Affzo [M:FAS3] : Affzo[M:FAS4]
  If GKFR = G_OUI : Affzo [M:FAS5] : Endif : # FQ57624
Return

#=====================================================================
# Massif : Déclaration et initialisation avant traitement de la population
#          en mise à jour directe. Valable uniquement en massif.
$OUVR_APPL_DIRT

# Classe pour traiter les composants

 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif

# Ouverture des classes de travail pour la génération des événements

 If !clalev([F:FASO]) : Local File FXDASSETS [FASO] : Endif
 If !clalev([F:FASD]) : Local File FXDASSETS [FASD] : Endif
 If !clalev([F:DEPW]) : Local File DEPREC    [DEPW] : Endif
 If !clalev([F:SEA])  : Local File SECACT    [SEA]  : Endif  : # secteurs d'activité

# Société courante : rupture société pour émission en-tête trace

 Local Char    TRC_CPY

# Zone contenant la nature et la date du transfert

 If dim([V]RENTRF)<0 : Global Char RENTRF : Endif
 If dim([V]MVTDAT)<0 : Global Date MVTDAT : Endif

# Variables diverses :

 Local Char    CLASDES                 # Classe de la classe destination des mises à jour
 Local Char    CLASORI                 # Classe de la classe origine des modifications
 Local Char    SUFFORI
 Local Char    SUFFDES
 Local Char    SUFFIX_ZONE             # Suffixe éventuel de la zone origine
 Local Integer RETOUR                  # Code retour sous-programme
 Local Integer I_AXE                   # Indice d'axe analytique
 Local Char    FCYORI                  # Site financier origine
 Local Char    LOCORI                  # Localisation origine
 Local Char    AASBUSORI               # Secteur d'activité origine
 Local Char    IASCGUORI               # U.G.T. origine
 Local Char    DSPORI                  # Clé de répartition analytique origine
 Local Char    CCETABORI(15)(GOPTCANA) # Section analytiques origine
 Local Date    TRFDATORI               # Date de transfert origine
 Local Decimal PCGDEVORI               # Ecart TVA récupurée PCG
 Local Decimal IASDEVORI               # Ecart TVA récupérée IAS
 Local Decimal DEDVATRAT               # Taux de TVA récupérée origine PCG
 Local Decimal DEDVATRATI              # Taux de TVA récupérée origine IAS
 Local Integer CCLTRF                  # Transfert ou annulation de transfert
 Local Date    TRFDAT                  # Date de transfert
 Local Integer USE_PAR_VIDE            # Indique si un paramétre de valeur null doit être appliqué à la zone
 Local Integer IMPUT_INCH              # Indicateur d'imputations inchangée

 Local Shortint TRFTYP                 # Type de transfert FQ63281

 Local Decimal  IVCVATAMT              # FQ78968 (1)
 Local Integer  IVCVATFLG
 Local Decimal  IVCVATAMTI
 Local Integer  IVCVATFLGI
 Local Decimal  TAXCOEORI
 Local Decimal  TAXCOEFORI
 Local Decimal  REGULPCGORI
 Local Decimal  REGULIASORI
 Local Date     VATREGDATORI

# Variables de travail pour la génération des événements et la récupération des imputations d'origine

 Local Char    ACT_EVT                 # Type d'action à réaliser "EVT" ou "ANN"
 Local Char    WK_CPY                  # Société
 Local Char    WK_FCY                  # Site
 Local Char    WK_AASREF               # Référence BCO
 Local Date    WK_TRFDAT               # Date de transfert
 Local Char    WK_NOMZON(50)           # Nom de zone pour assign
 Local Decimal WK_MONTANT              # Montant de travail pour assign

# Variables pour la régularisation de TVA.

 Local Integer REGTVAFLG                                   # Flag indiquant qu'il y  a eu une régul de TVA

# Initialisations diverses

 CCLTRF=[M:FASM]CCLTRF

Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT
 #=> A rupture société : en-tête société dans la trace et chargement des dates des contextes
 If [F:MAS1]CPY<>TRC_CPY

  #==> Déclaration globales nécessaires à la fonction
  Call GET_ELEM_REG_TVA([F:MAS1]CPY) From TRTFAS

  Call ET_COMPTE_RENDU([F:MAS1]CPY) From TRTFASTRF
  TRC_CPY=[F:MAS1]CPY
  Gosub SET_CPY_DAT From TRTFASTRF
 Endif

 If GPHY = G_OUI and [M:FASM]ECRPHYATT = G_NON Then
# Issue 110656
#    Local Char SV_FCYD(GLONFCY), SV_LCTD(GLONLCT), WPHY(GLONPHY)
#    Local Integer WMVT
#    Local Date WTRFDAT
    # Si on a demandé à ne pas écraser les mouvements en attente, on ne traite pas le bien
    # et on met des infos dans la trace
    # Issue 110515 - 2015-08-27 by MDJ : WFCY remplacé par XFCY car WFCY déjà utilisé pour les evts

#    Local Char XFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)
#    If func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:MAS1]AASREF, 0,
#&          WPHY, WTRFDAT, XFCY, WLCTCOD, WREN, WMVT) Then
#       # écriture de la trace
#       Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,0,G_OUI,mess(75,7775,1)) From TRCPROCOM
#       Raz RMES
#       Return
#    Endif

    Local Integer WNBR_MVT
    Local Char WLCTCOD(GLONLCT), WFCY2(GLONFCY)

    WNBR_MVT = func PHYELT_C_MPR._GET_INFOS_IDENTICAL_MVT_TRF("AASREF = '" + [F:MAS1]AASREF + "'",
&              WLCTCOD, WFCY2)
    If WNBR_MVT <> 0
       Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF,0,G_OUI, mess(230, 7775, 1)) From TRCPROCOM
       Raz RMES

    Endif
    # End Issue 110656

 Endif
 # FQ100398/13

 #-> Traitement du BCO principal
 Gosub TRANSFERT_PRINC_DIRT From TRTFASTRF2

 #-> Si une erreur s'est produit on sort
 Raz RMES
 If GOK<1 : Return : Endif

 #-> Traitement des composants
 If [F:MAS1]CMPSTA=GVML_SBPRINC
  Filter [MAS2] Where (CMP=[F:MAS1]AASREF)
  For [MAS2]
   NBCPYTRT+=1
   Gosub TRANSFERT_COMP_DIRT From TRTFASTRF2
  Next
  Filter [MAS2]
 Endif
 Raz RMES

Return

######################

$TRANSFERT_PRINC_DIRT

 [F:FASO] = [F:MAS1]                                           # Sauvegarde des valeurs d'origine du bien comptable

 # Le contrôle des imputations inchangées ne doit pas se faire en annulation
 If CCLTRF=G_NON
  # Contrôle imputations inchangée ?
  CLASORI="[F:FASO]" : SUFFORI=""
  CLASDES="[M:FASM]" : SUFFDES="D"
  USE_PAR_VIDE=G_NON
  Gosub CONTROLE_BCO_IMPUTATIONS_INCHANGEE From TRTFASTRF
 # Variable globale pour transfert imputation inchangée
 # Si on a rien changé dans le transfert de l'imputation et que l'on est en localisation multiple (typloc=2)
 # on passe le flag INPUT_INCH à G_NON car on va faire seulement des transferts de localisations sur les éléments physiques
  If GPHY = G_OUI Then
    SV_IMPUT_INCH=IMPUT_INCH
    # FQ100398/13
  Endif

  If IMPUT_INCH=G_OUI
   Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,0,G_OUI,mess(387,7773,1)) From TRCPROCOM #"Imputations inchangées pour ce bien""
   Return
  Endif
 Endif

 CLASDES  ="[F:MAS1]"                                          # Classe à mettre à jour

 If CCLTRF=G_NON : Gosub REPORT_FASM_MAS_DIRT From TRTFASTRF2         : Endif #      Application des paramètres de transfert au BCO
 If CCLTRF=G_OUI : Gosub LOAD_INPUT_ORI       From TRTFASTRF2               : Endif # ou   Restauration des imputations d'origine
 [F:FASD] = [F:MAS1]                                                          # Sauvegarde des nouvelles valeurs du bien comptable
 If CCLTRF=G_NON : Gosub CONTROLE_BCO_IMPUTATIONS_DIRT From TRTFASTRF : Endif # Contrôle des nouvelles imputations et localisations

 If dim(NBR_ERREUR)>0 & NBR_ERREUR>0

  If ACTSILENCE=G_OUI
   Local Integer I_ERREUR
   G_MAJOK=G_NON
   GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
   GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
   I_OBJ+=1
   For I_ERREUR=1 To dim(GT_LIS_ERR)
    If TAB_ERREUR(I_ERREUR-1)="" : Break : Endif
    GT_LIS_ERR(I_ERREUR-1)=TAB_ERREUR(I_ERREUR-1)
   Next I_ERREUR
  Else
   Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,0,G_OUI,mess(330,7773,1)) From TRCPROCOM #"Erreur d'imputation ou de localisation sur ce bien"
  Endif

 Else

  If [F:FASO]AASBUS<>[F:FASD]AASBUS
   TRFDAT=[F:FASD]TRFDAT

   # Paramètres pour régul TVA
   Call GET_ELEM_REG_TVA([F:MAS1]CPY) From TRTFAS

   Gosub TRT_REGUL_TVA  From TRTFASTRF           # Traitement de régularisation de TVA
   If IASDEV | PCGDEV
    REGTVAFLG=G_OUI
   Else
    REGTVAFLG=G_NON
   Endif

   # FQ78968
   If ( [M:FASM]CCLTRF = G_OUI ) Then
     If ( G_REGUL > 0 ) Then
       [F:MAS1]VATREGDED  -= abs(G_REGUL)
       [F:MAS1]VATREGDEDI -= abs(G_REGULI)
     Else
       [F:MAS1]VATREGAMT  -= abs(G_REGUL)
       [F:MAS1]IASVATREG  -= abs(G_REGULI)
     Endif
   Else
   If ( G_REGUL > 0 ) Then
     [F:MAS1]VATREGDED  += abs(G_REGUL)
     [F:MAS1]VATREGDEDI += abs(G_REGULI)
   Else
     [F:MAS1]VATREGAMT  += abs(G_REGUL)
     [F:MAS1]IASVATREG  += abs(G_REGULI)
   Endif

  Endif
  Endif
  [F:FASD]=[F:MAS1]

   # FQ78968
  If ( REGTVAFLG=G_OUI or [M:FASM]CCLTRF = G_OUI ) Then
   # Absence de mise à jour de TAXBAS et GALREFBAS
   [F:MAS1]TAXBAS     = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
   [F:MAS1]GALREFBAS  = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
   [F:MAS1]FLGCLC     = G_OUI
  Endif

  # FQ66894 : flux a générer si transfert de site financier
  If [F:FASD]FCY <> [F:FASO]FCY
    Local Integer N_CNX
    For N_CNX = 1 To G300MAX
      Call MAJFLGCNXFLX("[F:MAS1]", "", N_CNX, num$(GVML_FLXNOTG)) From TRTFAS
    Next
  Endif

  Gosub TRT_RET_DIRT   From TRTFASTRF2                         # Traitement des plans et des événements
  [F:MAS1]UPDUSR=GUSER #FQ104286
  [F:MAS1]UPDDAT=date$ #FQ104286

  Rewrite [MAS1]                                               # Réecriture du BCO
  Gosub TRT_RET_REWRITE From TRTFASTRF2                        # Traitement du résultat de la réécriture

#  If GPHY = G_OUI Then
     # Recherche si tous les éléments physiques rattachés ont la même localisation pour mettre à jour celle du bien
#     [F:MAS1]LCTCOD=func TRTPHYTOOL.RECH_LOC_ELT_PHY([F:MAS1]AASREF,[F:MAS1]LCTCOD)
#     Rewrite [MAS1]                                            # Réecriture du BCO
#  Endif

 Endif

 If CCLTRF=G_NON : Kill TAB_ZONERR, TAB_ERREUR, NBR_ERREUR : Endif
Return

######################

$TRANSFERT_COMP_DIRT

 [F:FASO] = [F:MAS2]                                           # Sauvegarde des valeurs d'origine du bien comptable

 # Le contrôle des imputations inchangées ne doit pas se faire en annulation FQ92911
 If CCLTRF=G_NON
 # Contrôle imputations inchangée ?
 CLASORI="[F:FASO]" : SUFFORI=""
 CLASDES="[M:FASM]" : SUFFDES="D"
 USE_PAR_VIDE=G_NON
 Gosub CONTROLE_BCO_IMPUTATIONS_INCHANGEE From TRTFASTRF
 # Variable globale pour transfert imputation inchangée
 # Si on a rien changé dans le transfert de l'imputation et que l'on est en localisation multiple (typloc=2)
 # on passe le flag INPUT_INCH à G_NON car on va faire seulement des transferts de localisations sur les éléments physiques
 If GPHY = G_OUI and CCLTRF=G_NON Then
    SV_IMPUT_INCH=IMPUT_INCH
 Endif

 If IMPUT_INCH=G_OUI
  Call ECR_TRACE_ERREUR([F:MAS2]CPY,[F:MAS2]AASREF,0,G_OUI,mess(387,7773,1)) From TRCPROCOM #"Imputations inchangées pour ce bien""
  Return
 Endif
 Endif

 CLASDES  ="[F:MAS2]"                                          # Classe à mettre à jour

 If CCLTRF=G_NON : Gosub REPORT_FASM_MAS_DIRT From TRTFASTRF2 : Endif         #       Application des paramètres de transfert au BCO
 If CCLTRF=G_OUI : Gosub LOAD_INPUT_ORI       From TRTFASTRF2 : Endif         # ou    Restauration des imputations d'origine
 [F:FASD] = [F:MAS2]                                                          # Sauvegarde des nouvelles valeurs du bien comptable
 If CCLTRF=G_NON : Gosub CONTROLE_BCO_IMPUTATIONS_DIRT From TRTFASTRF : Endif # Contrôle des nouvelles imputations et localisations

 If dim(NBR_ERREUR)>0 & NBR_ERREUR>0

  If ACTSILENCE=G_OUI
   Local Integer I_ERREUR
   G_MAJOK=G_NON
   GT_OBJ_REF(I_OBJ)=[F:MAS2]AASREF
   GT_OBJ_DES(I_OBJ)=[F:MAS2]AASDES1
   I_OBJ+=1
   For I_ERREUR=1 To dim(GT_LIS_ERR)
    GT_LIS_ERR(I_ERREUR-1)=TAB_ERREUR(I_ERREUR-1)
   Next I_ERREUR
  Else
   Call ECR_TRACE_ERREUR([F:MAS2]CPY,[F:MAS2]AASREF,0,G_OUI,mess(330,7773,1)) From TRCPROCOM #"Erreur d'imputation ou de localisation sur ce bien"
  Endif

 Else

  If [F:FASO]AASBUS<>[F:FASD]AASBUS
   TRFDAT=[F:FASD]TRFDAT
   Gosub TRT_REGUL_TVA From TRTFASTRF                                         # Traitement de régularisation de TVA
   If IASDEV | PCGDEV
    REGTVAFLG=G_OUI
   Else
    REGTVAFLG=G_NON
   Endif

   # FQ78968
   If ( [M:FASM]CCLTRF = G_OUI ) Then
     If ( G_REGUL > 0 ) Then
       [F:MAS2]VATREGDED  -= abs(G_REGUL)
       [F:MAS2]VATREGDEDI -= abs(G_REGULI)
     Else
       [F:MAS2]VATREGAMT  -= abs(G_REGUL)
       [F:MAS2]IASVATREG  -= abs(G_REGULI)
     Endif
   Else
   If ( G_REGUL > 0 ) Then
     [F:MAS2]VATREGDED  += abs(G_REGUL)
     [F:MAS2]VATREGDEDI += abs(G_REGULI)
   Else
     [F:MAS2]VATREGAMT  += abs(G_REGUL)
     [F:MAS2]IASVATREG  += abs(G_REGULI)
   Endif

  Endif
  Endif

  [F:FASD]=[F:MAS2]

   # FQ78968
  If ( REGTVAFLG=G_OUI or [M:FASM]CCLTRF = G_OUI ) Then
   [F:MAS2]TAXBAS     = [F:MAS2]ACGETRNOT + [F:MAS2]IVCVATAMT - [F:MAS2]DEDVATAMT
   [F:MAS2]GALREFBAS  = [F:MAS2]ACGETRNOT + [F:MAS2]IVCVATAMT - [F:MAS2]DEDVATAMT
   [F:MAS2]FLGCLC     = G_OUI
  Endif

  # FQ66894 : flux a générer si transfert de site financier
  If [F:FASD]FCY <> [F:FASO]FCY
    Local Integer N_CNX
    For N_CNX = 1 To G300MAX
      Call MAJFLGCNXFLX("[F:MAS2]", "", N_CNX, num$(GVML_FLXNOTG)) From TRTFAS
    Next
  Endif

  Gosub TRT_RET_DIRT    From TRTFASTRF2                        # Traitement des plans et des événements
  [F:MAS2]UPDUSR=GUSER #FQ104286
  [F:MAS2]UPDDAT=date$ #FQ104286

  Rewrite [MAS2]                                               # Réécriture du BCO
  Gosub TRT_RET_REWRITE From TRTFASTRF2                        # Traitement du résultat de la réécriture

 Endif

 If CCLTRF=G_NON : Kill TAB_ZONERR, TAB_ERREUR, NBR_ERREUR : Endif
Return

######################

$REPORT_FASM_MAS_DIRT
 CLASORI      = "[M:FASM]"          # Classe Origine
 SUFFIX_ZONE  = "D"                 # Suffixe des zones à reporter
 USE_PAR_VIDE = G_NON               # Prise en compte des paramètres sans valeur ?
 Gosub TRF_CLASORI_TO_CLASDES From TRTFASTRF
 # Fiche 48468
 # En transfert massif, si c'est uniquement un changement de localisation, il ne faut pas mettre à jour la date de
 # transfert du bien comptable.
#FQ100398/13
 NOMZON=CLASDES+"TRFDAT" : Assign NOMZON With evalue(CLASORI+"MVTDAT")
Return

######################

$LOAD_INPUT_ORI
 WK_CPY    = evalue(CLASDES+"CPY")
 WK_FCY    = evalue(CLASDES+"FCY")
 WK_AASREF = evalue(CLASDES+"AASREF")
 WK_TRFDAT = evalue(CLASDES+"TRFDAT")

# FQ57840 FQ78968(1)
 Call GET_IMPUT_GEOANA_ORI(WK_CPY,WK_FCY,WK_AASREF,WK_TRFDAT,
&                           FCYORI,AASBUSORI,IASCGUORI,DSPORI,
&                           CCETABORI,TRFDATORI,
&                           PCGDEVORI,IASDEVORI,DEDVATRAT,DEDVATRATI,TRFTYP,
&                           IVCVATAMT,IVCVATFLG,IVCVATAMTI,IVCVATFLGI,
&                           TAXCOEORI,TAXCOEFORI,REGULPCGORI,REGULIASORI,VATREGDATORI,RETOUR) From TRTFASTRFHIS
 #-> Si erreur
 If RETOUR
  Call ECR_TRACE_ERREUR(WK_CPY,WK_AASREF,0,G_OUI,mess(331,7773,1)) From TRCPROCOM #"Annulation de transfert impossible, pas d'événement"
  Return
 Endif

 #-> Si pas d'erreur, report des imputations d'origine
 If !RETOUR
  WK_NOMZON=CLASDES+"FCY"    : Assign WK_NOMZON With FCYORI
  ####WK_NOMZON=CLASDES+"LOC"    : Assign WK_NOMZON With LOCORI
  WK_NOMZON=CLASDES+"AASBUS" : Assign WK_NOMZON With AASBUSORI
  WK_NOMZON=CLASDES+"IASCGU" : Assign WK_NOMZON With IASCGUORI
  WK_NOMZON=CLASDES+"DSP"    : Assign WK_NOMZON With DSPORI

  Local Integer I_AXE
  #????
  #For I_AXE=1 To GOPTCANA
  For I_AXE=1 To [M:FPC]NBDIE
   WK_NOMZON=CLASDES+"CCE(I_AXE-1)" : Assign WK_NOMZON With evalue("CCETABORI"+"("+num$(I_AXE-1)+")")
  Next I_AXE
  WK_NOMZON=CLASDES+"TRFDAT" : Assign WK_NOMZON With TRFDATORI
  #-> Ecart TVA récupérée, on recalcul les bonnes valeurs.
  WK_NOMZON=CLASDES+"DEDVATRAT" : Assign WK_NOMZON With DEDVATRAT
  WK_NOMZON=CLASDES+"DEDVATRATI": Assign WK_NOMZON With DEDVATRATI
  If PCGDEVORI
   WK_MONTANT = evalue(CLASDES+"DEDVATAMT")
   WK_MONTANT-= PCGDEVORI
   WK_NOMZON  = CLASDES+"DEDVATAMT"
   Assign WK_NOMZON With WK_MONTANT
  Endif
  If IASDEVORI
   WK_MONTANT = evalue(CLASDES+"DEDVATAMTI")
   WK_MONTANT-= IASDEVORI
   WK_NOMZON=CLASDES+"DEDVATAMTI"
   Assign WK_NOMZON With WK_MONTANT
  Endif
 Endif

 #FQ78968(1)
 WK_NOMZON=CLASDES+"IVCVATAMT"  : Assign WK_NOMZON With IVCVATAMT
 WK_NOMZON=CLASDES+"IVCVATFLG"  : Assign WK_NOMZON With IVCVATFLG
 WK_NOMZON=CLASDES+"IVCVATAMTI" : Assign WK_NOMZON With IVCVATAMTI
 WK_NOMZON=CLASDES+"IVCVATFLGI" : Assign WK_NOMZON With IVCVATFLGI
 WK_NOMZON=CLASDES+"TAXCOE"     : Assign WK_NOMZON With TAXCOEORI
 WK_NOMZON=CLASDES+"TAXCOEF"    : Assign WK_NOMZON With TAXCOEFORI
 If (REGULPCGORI > 0 ) Then
   WK_MONTANT  = evalue(CLASDES+"VATREGDED")
   WK_MONTANT -= abs(REGULPCGORI)
   WK_NOMZON=CLASDES+"VATREGDED"    : Assign WK_NOMZON With WK_MONTANT
 Elsif (REGULPCGORI < 0 ) Then
   WK_MONTANT  = evalue(CLASDES+"VATREGAMT")
   WK_MONTANT -= abs(REGULPCGORI)
   WK_NOMZON=CLASDES+"VATREGAMT"    : Assign WK_NOMZON With WK_MONTANT
 Endif
 If (REGULIASORI > 0 ) Then
   WK_MONTANT  = evalue(CLASDES+"VATREGDEDI")
   WK_MONTANT -= abs(REGULIASORI)
   WK_NOMZON=CLASDES+"VATREGDEDI"   : Assign WK_NOMZON With WK_MONTANT
 Elsif (REGULIASORI < 0 ) Then
   WK_MONTANT  = evalue(CLASDES+"IASVATREG")
   WK_MONTANT -= abs(REGULIASORI)
   WK_NOMZON=CLASDES+"IASVATREG"   : Assign WK_NOMZON With WK_MONTANT
 Endif
 Call TVA_COE_DEDUCTION (evalue(CLASDES+"ASJCOE"), evalue(CLASDES+"TAXCOE"), evalue(CLASDES+"ADMCOE"), WK_MONTANT ) From TRTFAS
 WK_NOMZON=CLASDES+"DEDCOE"   : Assign WK_NOMZON With WK_MONTANT
 Call TVA_COE_DEDUCTION (evalue(CLASDES+"ASJCOEF"), evalue(CLASDES+"TAXCOEF"), evalue(CLASDES+"ADMCOEF"), WK_MONTANT ) From TRTFAS
 WK_NOMZON=CLASDES+"DEDCOEF"   : Assign WK_NOMZON With WK_MONTANT
 WK_NOMZON=CLASDES+"VATREGDAT" : Assign WK_NOMZON With VATREGDATORI


Return

######################
$TRT_RET_REWRITE
 If fstat
  Case fstat
   When 1
    RMES=mess(226,7773,1)-evalue(CLASDES+"AASREF")+"/"+evalue(CLASDES+"AASDES1") # "ENREGISTREMENT en cours d'utilisation"
    GOK=-1
   When 3
    RMES=mess(129,7773,1)-evalue(CLASDES+"AASREF") # "Tentative d'écriture en double de la clé"
    GOK=0
   When Default
  Endcase
  If ACTSILENCE=G_OUI
   G_MAJOK=G_NON
   GT_OBJ_REF(I_OBJ)=evalue(CLASDES+"AASREF")
   GT_OBJ_DES(I_OBJ)=evalue(CLASDES+"AASDES1")
   I_OBJ+=1
  Else
   Call BCO_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"AASREF"),evalue(CLASDES+"AASDES1"),"") From TRTFASTRF
  Endif
 Endif
Return

######################
$TRT_RET_DIRT
  # Fiche 48468
  # Emission des infos du BCO dans le compte-rendu ou dans une globale si traitement silencieux
  # Déplacé avant TRAITE_PLAN pour afficher la trace des éléments physiques après celle du bien comptable
  If ACTSILENCE=G_OUI
   G_MAJOK=G_OUI
   GT_OBJ_REF(I_OBJ)=evalue(CLASDES+"AASREF")
   GT_OBJ_DES(I_OBJ)=evalue(CLASDES+"AASDES1")
   I_OBJ+=1
  Else
   Call BCO_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"AASREF"),evalue(CLASDES+"AASDES1"),"") From TRTFASTRF
  Endif

  # Gestion événements si on est en traitement réél
  If FLGSIM=G_NON
   #-> Evénement de transfert
   If CCLTRF=G_NON
    If RENTRF=""      : RENTRF=[M:FASM]REN : Endif
    If [V]MVTDAT=[0/0/0] : [V]MVTDAT=[M:FASM]MVTDAT : Endif
    ACT_EVT="EVT"
    WK_TRFDAT=[M:FASM]MVTDAT
    Gosub TRAITE_PLAN From TRTFASTRF
   Endif
   #-> Annulation d'événement de transfert
   If CCLTRF=G_OUI
    WK_CPY    = [F:FASO]CPY
    WK_FCY    = [F:FASO]FCY
    WK_AASREF = [F:FASO]AASREF
    WK_TRFDAT = [F:FASO]TRFDAT
    ACT_EVT="ANN"
    Gosub TRAITE_PLAN From TRTFASTRF
   Endif
  # Issue 110656
#  Elsif GPHY=G_OUI Then # Fiche 48468 simulation
#    Call ALIM_ELT_PHY_COMPTE_RENDU([F:FASO]AASREF,CLASDES,[M:FASM]ECRPHYATT,[F:FASO]CPY,[M:FASM]LCTCOD,CCLTRF) From TRTPHYTOOL
# End Issue 110656
  Endif

  # Emission des infos du BCO dans le compte-rendu ou dans une globale si traitement silencieux
  # Fiche 48468 Déplacé plus haut
  # Incrémentation du compteur de mises à jour
  NBCPYMAJ+=1
Return

#=====================================================================
$CLOS_APPL_DIRT
 If dim([V]RENTRF)>0      : Kill [V]RENTRF      : Endif
 If dim([V]MVTDAT)>0      : Kill [V]MVTDAT      : Endif

 Gosub DEL_VARIABLES_GLOBALES From TRTFASTRF

Return


#=====================================================================
$OUVR_ALIM_TABLE

# Ouverture des classes de travail pour la génération des événements

 If !clalev([F:FASO]) : Local File FXDASSETS [FASO] : Endif
 If !clalev([F:FASD]) : Local File FXDASSETS [FASD] : Endif
 If !clalev([F:DEPW]) : Local File DEPREC    [DEPW] : Endif
 If !clalev([F:SEA])  : Local File SECACT    [SEA]  : Endif  : # secteurs d'activité

# Société courante : rupture société pour émission en-tête trace

 Local Char TRC_CPY   : Raz TRC_CPY

# Zone contenant la nature et la date du transfert

 If dim([V]RENTRF)<0    : Global Char    RENTRF    : Endif
 If dim([V]MVTDAT)<0    : Global Date    MVTDAT    : Endif


# Variables diverses

 Local Char    CLASDES          # Classe de la classe destination des mises à jour
 Local Char    CLASORI          # Classe de la classe origine des modifications
 Local Char    SUFFIX_ZONE      # Suffixe éventuel de la zone origine
 Local Integer RETOUR,I_AXE
 Local Integer USE_PAR_VIDE

# Variables pour la génération des événements

 Local Char    ACT_EVT          # Type d'action à réaliser "EVT" ou "ANN"
 Local Char    WK_CPY           # Société du bien pour lequel on veut traiter l'événement
 Local Char    WK_FCY
 Local Char    WK_AASREF
 Local Date    WK_TRFDAT

# Variables pour la régularisation de TVA

 Local Date    TRFDAT
 Local Integer REGTVAFLG        # Flag indiquant qu'il y  a eu une régul de TVA

 TRFDAT=[M:FASM]MVTDAT
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE
#=> En massif, a rupture société on émet un en-tête dans la trace

 If [F:TMP1]CPY<>TRC_CPY
  If ACTTYPGES=GTAMMAS
   Call ET_COMPTE_RENDU([F:TMP1]CPY) From TRTFASTRF
  Endif
  TRC_CPY=[F:TMP1]CPY
  Gosub SET_CPY_DAT From TRTFASTRF
 Endif

#=> Transfert

If [F:TMP1]CCLTRF=G_NON
 #-> Report de l'enregistrement de TMP1 dans MAS1

  [F:FASO] = [F:MAS1]  # Sauvegarde des valeurs d'origine du bien comptable
  If ACTTYPGES=GTAMMAS and GPHY=G_OUI Then
     Local Char SUFFORI,SUFFDES
     Local Integer IMPUT_INCH              # Indicateur d'imputations inchangée # Bug n°26442

     CLASDES = "[F:TMP1]" : CLASORI = "[F:TMP1]"
     SUFFORI = "O" : SUFFDES = ""
     USE_PAR_VIDE=G_OUI                   # On n'est pas en direct donc on fait comme en modication dans le controle le blanc est considéré comme modification
     # Pour mettre à jour G_MODIF_LOC modification uniquement sur la localisation

     Gosub CONTROLE_BCO_IMPUTATIONS_INCHANGEE From TRTFASTRF
 # Variable globale pour transfert imputation inchangée
 # Si on a rien changé dans le transfert de l'imputation et que l'on est en localisation multiple (typloc=2)
 # on passe le flag INPUT_INCH à G_NON car on va faire seulement des transferts de localisations sur les éléments physiques
     SV_IMPUT_INCH=IMPUT_INCH
     # FQ100398/13
  Endif

  CLASDES      = "[F:MAS1]"
  CLASORI      = "[F:TMP1]"
  SUFFIX_ZONE  = ""
  USE_PAR_VIDE = G_OUI
  #> Report des zones relative au transfert analytique et géographique
  Gosub TRF_CLASORI_TO_CLASDES From TRTFASTRF

  # Régularisation de TVA
  [F:TMP1]REGTVAFLG=G_NON
  If [F:TMP1]AASBUS<>[F:TMP1]AASBUSO
   CLASORI = "[F:MAS1]"
   # Paramètres pour régul TVA
   Call GET_ELEM_REG_TVA([F:MAS1]CPY) From TRTFAS

   Gosub TRT_REGUL_TVA From TRTFASTRF
   If IASDEV | PCGDEV
    [F:TMP1]REGTVAFLG=G_OUI
    [F:TMP1]PCGDEV=PCGDEV
    [F:TMP1]IASDEV=IASDEV
    [F:TMP1]REGUL =G_REGUL
    [F:TMP1]REGULI=G_REGULI
   Endif
   CLASORI = "[F:TMP1]"
  Endif

  #> Report des zones relative à la régul de TVA
  If [F:TMP1]REGTVAFLG=G_OUI
   [F:MAS1]TAXCOE     = [F:TMP1]TAXCOE
   [F:MAS1]DEDCOE     = [F:TMP1]DEDCOE
   [F:MAS1]TAXCOEF    = [F:TMP1]TAXCOEF
   [F:MAS1]DEDCOEF    = [F:TMP1]DEDCOEF
   [F:MAS1]IVCVATFLG  = [F:TMP1]IVCVATFLG
   [F:MAS1]VATRSD     = [F:TMP1]VATRSD
   [F:MAS1]VATREGDAT  = [F:TMP1]VATREGDAT
   [F:MAS1]IVCVATAMT  = [F:TMP1]IVCVATAMT
   [F:MAS1]DEDVATRAT  = [F:TMP1]DEDVATRAT
   [F:MAS1]DEDVATAMT  = [F:TMP1]DEDVATAMT
   [F:MAS1]DEDVATFLG  = [F:TMP1]DEDVATFLG
   [F:MAS1]IVCVATAMTI = [F:TMP1]IVCVATAMTI
   [F:MAS1]DEDVATRATI = [F:TMP1]DEDVATRATI
   [F:MAS1]DEDVATAMTI = [F:TMP1]DEDVATAMTI
   [F:MAS1]DEDVATFLGI = [F:TMP1]DEDVATFLGI

   If ( [F:TMP1]REGUL > 0 ) Then
     [F:MAS1]VATREGDED  += abs([F:TMP1]REGUL)
     [F:MAS1]VATREGDEDI += abs([F:TMP1]REGULI)
   Else
     [F:MAS1]VATREGAMT  += abs([F:TMP1]REGUL)
     [F:MAS1]IASVATREG  += abs([F:TMP1]REGULI)
   Endif

   [F:MAS1]TAXBAS     = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
   [F:MAS1]GALREFBAS  = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
   [F:MAS1]FLGCLC     = G_OUI
  Endif

  # FQ66894
  If [F:MAS1]FCY <> [F:FASO]FCY
    Local Integer N_CNX
    For N_CNX = 1 To G300MAX
       Call MAJFLGCNXFLX("[F:MAS1]", "", N_CNX, num$(GVML_FLXNOTG)) From TRTFAS
    Next
  Endif

  #> Report de zones diverses
# FQ100398/13
 [F:MAS1]TRFDAT=[F:TMP1]MVTDAT

 [F:MAS1]UPDUSR=GUSER #FQ104286
 [F:MAS1]UPDDAT=date$ #FQ104286

  [F:FASD] = [F:MAS1]  # Sauvegarde des nouvelles valeurs du bien comptable

 #-> En massif emission de message dans le compte-rendu

  If ACTTYPGES=GTAMMAS
   If    [F:TMP1]FLGERR=G_OUI
    Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,0,G_OUI,[F:TMP1]MSGERR) From TRCPROCOM
   Elsif [F:TMP1]FLGERR=G_NON
    Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"") From TRTFASTRF
    NBCPYMAJ+=1
   Endif
  Endif

 #-> Génération des événements pour le BCO en cours

 If (((ACTTYPGES=GTAMMAS & (dim(FLGSIM)>0 & FLGSIM=G_NON)) | (ACTTYPGES=GTAMUNI)) & [F:TMP1]FLGERR=G_NON)
   If [V]RENTRF   =""      : [V]RENTRF   =[F:TMP1]RENTRF : Endif
   If [V]MVTDAT=[0/0/0]    : [V]MVTDAT   =[F:TMP1]MVTDAT : Endif
   REGTVAFLG=[F:TMP1]REGTVAFLG
   If REGTVAFLG=G_OUI
    [V]PCGDEV = [F:TMP1]PCGDEV
    [V]IASDEV = [F:TMP1]IASDEV
    [V]G_REGUL  = [F:TMP1]REGUL
    [V]G_REGULI = [F:TMP1]REGULI
   Endif
   WK_TRFDAT=[F:TMP1]MVTDAT
   ACT_EVT="EVT"
   Gosub TRAITE_PLAN From TRTFASTRF
 Endif
Endif

#=> Annulation de transfert

If [F:TMP1]CCLTRF=G_OUI
 #-> Report de l'enregistrement de TMP1 dans MAS1

 [F:FASO] = [F:MAS1]  # Sauvegarde des valeurs d'origine du bien comptable
 CLASDES      = "[F:MAS1]"
 CLASORI      = "[F:TMP1]"
 SUFFIX_ZONE  = ""
 USE_PAR_VIDE = G_OUI
 Gosub TRF_CLASORI_TO_CLASDES From TRTFASTRF

 [F:MAS1]TRFDAT     = [F:TMP1]MVTDAT
 #> Report des zones relative à la régul de TVA
 [F:MAS1]IVCVATAMT  = [F:TMP1]IVCVATAMT
 [F:MAS1]IVCVATFLG  = [F:TMP1]IVCVATFLG

 # FQ92911
 [F:MAS1]VATREGDAT  = [F:TMP1]VATREGDAT
 [F:MAS1]TAXCOE     = [F:TMP1]TAXCOE
 [F:MAS1]TAXCOEF    = [F:TMP1]TAXCOEF
 [F:MAS1]DEDCOE     = [F:TMP1]DEDCOE
 [F:MAS1]DEDCOEF    = [F:TMP1]DEDCOEF

 [F:MAS1]DEDVATRAT  = [F:TMP1]DEDVATRAT
 [F:MAS1]DEDVATAMT  = [F:TMP1]DEDVATAMT
 [F:MAS1]DEDVATFLG  = [F:TMP1]DEDVATFLG
 [F:MAS1]IVCVATAMTI = [F:TMP1]IVCVATAMTI

 # FQ92911
 If ( [F:TMP1]REGUL > 0 ) Then
   [F:MAS1]VATREGDED  -= abs([F:TMP1]REGUL)
   [F:MAS1]VATREGDEDI -= abs([F:TMP1]REGULI)
 Else
   [F:MAS1]VATREGAMT  -= abs([F:TMP1]REGUL)
   [F:MAS1]IASVATREG  -= abs([F:TMP1]REGULI)
 Endif
 [F:MAS1]IVCVATFLGI = [F:TMP1]IVCVATFLGI
 [F:MAS1]DEDVATRATI = [F:TMP1]DEDVATRATI
 [F:MAS1]DEDVATAMTI = [F:TMP1]DEDVATAMTI
 [F:MAS1]DEDVATFLGI = [F:TMP1]DEDVATFLGI
 [F:MAS1]TAXBAS     = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
 [F:MAS1]GALREFBAS  = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT

 If [F:MAS1]TAXBAS <> [F:FASO]TAXBAS
    [F:MAS1]FLGCLC = G_OUI
 Endif

 # FQ66894 : flux a générer si transfert de site financier
 If [F:MAS1]FCY <> [F:FASO]FCY
   Local Integer N_CNX
   For N_CNX = 1 To G300MAX
     Call MAJFLGCNXFLX("[F:MAS1]", "", N_CNX, num$(GVML_FLXNOTG)) From TRTFAS
   Next
 Endif

 [F:MAS1]UPDUSR=GUSER #FQ104286
 [F:MAS1]UPDDAT=date$ #FQ104286

 [F:FASD] = [F:MAS1]  # Sauvegarde des nouvelles valeurs du bien comptable

 #-> En massif emission de message dans le compte-rendu

  If ACTTYPGES=GTAMMAS
   If    [F:TMP1]FLGERR=G_OUI
    Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,0,G_OUI,[F:TMP1]MSGERR) From TRCPROCOM
   Elsif [F:TMP1]FLGERR=G_NON
    Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"") From TRTFASTRF
    NBCPYMAJ+=1
   Endif
  Endif

 #-> Génération des événements d'annulation de transfert pour le BCO en cours

 If (((ACTTYPGES=GTAMMAS & (dim(FLGSIM)>0 & FLGSIM=G_NON)) | (ACTTYPGES=GTAMUNI)) & !([F:TMP1]FLGERR=G_OUI))
  WK_CPY    = [F:MAS1]CPY
  WK_FCY    = [F:MAS1]FCY
  WK_AASREF = [F:MAS1]AASREF
  WK_TRFDAT = [F:FASO]TRFDAT
  ACT_EVT="ANN"
  Gosub TRAITE_PLAN From TRTFASTRF
 Endif
Endif

# Issue 110656
#If GPHY = G_OUI and ACTTYPGES=GTAMMAS Then
#   If dim(FLGSIM)>0 & FLGSIM=G_OUI & [F:TMP1]FLGERR=G_NON Then # massif en simulation sans erreur
#      Call ALIM_ELT_PHY_COMPTE_RENDU([F:MAS1]AASREF,CLASDES,[M:FASM]ECRPHYATT,[F:MAS1]CPY,"",[F:TMP1]CCLTRF) From TRTPHYTOOL
#   Endif
   # Recherche si tous les éléments physiques rattachés ont la même localisation pour mettre à jour celle du bien
#   [F:MAS1]LOC=func TRTPHYTOOL.RECH_LOC_ELT_PHY([F:MAS1]AASREF,[F:MAS1]LOC)
#Endif
# End Issue 110656

Return

#=====================================================================
# Fiche 48468
# $TMP1_ALIM_TABLE dans TRTFASTRF2
#=====================================================================
# Unitaire / massif : Après report du contenu de la table temporaire principale dans la table de données principale
$CLOS_ALIM_TABLE
 If dim([V]RENTRF)>0      : Kill [V]RENTRF      : Endif
 If dim([V]MVTDAT)>0      : Kill [V]MVTDAT      : Endif

 Gosub DEL_VARIABLES_GLOBALES From TRTFASTRF

Return

