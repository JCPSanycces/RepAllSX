#<AdxTL>@(#)0.0.0.0 $Revision$ Object management MIGXTC
######################################################################################
## Section automatically added (Object MIGXTC) 07/14/2017 13:28:56 (PHVEN)
######################################################################################
$ACTION
Case ACTION
  When "LIENS"       : Gosub LIENS
  When "AVANTBOUT"   : Gosub BEFORE_ACT
  When "SETBOUT"     : Gosub SETBOUT
Endcase
Return

######################################################################################

$SETBOUT
  If ([M:MIGXTC1]CMPNBR < 1)
    Call VIREBOUT(CHAINE, "a") From GOBJET
  Endif
Return

######################################################################################

$LIENS
  Call LOAD_DATA()
Return

######################################################################################

$BEFORE_ACT
  Case BOUT
    When "a" : Gosub COMPARE
    When "b" : Gosub MIGRATE
  Endcase
Return

######################################################################################

$COMPARE
  Call DO_COMPARE(0) #ONLY COMPARE WITHOUT COPYING DATA OVER TO TARGET
Return

######################################################################################

$MIGRATE
  Local Integer TOTAL_SRC

  TOTAL_SRC = sum([M:MIGXTC1]CMPSRCC)

  If (TOTAL_SRC <= 0)
    Call ECR_TRACE("There is 0 source rows to migrate, please make sure to run data compare first.", 0) From GESECRAN
  Else

    Local Integer RESULT : RESULT = 1
    Call AVERTIR("Are you sure you want to migrate (" + num$(TOTAL_SRC) + ") rows over to target folder?",RESULT) From GESECRAN

    If RESULT = 2
      Call DO_COMPARE(1)
    Endif

  Endif
Return

######################################################################################

Subprog LOAD_DATA()
  nolign = 0

  Filter [F:MIGXTM] Where MIGREFNUM=[M:MIGXTC0]MIGREFNUM & TMSTATCOD = 0 & TMINCLUDE = 2
  Link [F:MIGXTM] With [F:MIGXTCP]MIGXTCP0 = [F:MIGXTM]MIGREFNUM;[F:MIGXTM]TMNBR As [LNK]

  For [LNK]
     nolign += 1
     [M:MIGXTC1]CMPNBR += 1
     [M:MIGXTC1]TMNBR(nolign - 1) = [F:MIGXTM]TMNBR
     [M:MIGXTC1]TMMOD(nolign - 1) = [F:MIGXTM]TMMOD
     [M:MIGXTC1]TMSRCTBL(nolign - 1) = [F:MIGXTM]TMSRCTBL
     [M:MIGXTC1]TMTRGTBL(nolign - 1) = [F:MIGXTM]TMTRGTBL
     [M:MIGXTC1]CMPIDNC(nolign - 1) = [F:MIGXTCP]CMPIDNC
     [M:MIGXTC1]CMPSRCC(nolign - 1) = [F:MIGXTCP]CMPSRCC
     [M:MIGXTC1]CMPTRGC(nolign - 1) = [F:MIGXTCP]CMPTRGC
     [M:MIGXTC1]CMPIBDC(nolign - 1) = [F:MIGXTCP]CMPIBDC
     [M:MIGXTC1]CMPERR(nolign - 1) = [F:MIGXTCP]CMPERR
  Next

  Filter [F:MIGXTM]

  Affzo [M:MIGXTC1]
End

######################################################################################

Subprog DO_COMPARE(MIGRATE)
  Value Integer MIGRATE

  Local File MIGX [MIGXMAIN]
  Filter [MIGXMAIN] Where MIGREFNUM = [F:MIGXTM]MIGREFNUM
  Read [MIGXMAIN] First

  Local Char F_SRC(30) : F_SRC = [MIGXMAIN]MIGSRCFLD
  Local Char F_TRG(30) : F_TRG = [MIGXMAIN]MIGTRGFLD

  Local Integer ONLY_SRC
  Local Integer ONLY_TRG
  Local Integer BOTH_DIFF
  Local Integer IDENTICAL
  Local Integer ERR_COUNT

  Local File = F_SRC + ".ATABIND" [I_SRC]
  Local File = F_SRC + ".ATABZON" [TDEF_SRC]
  Local File = F_SRC + ".ATYPE" [DT_SRC]

  Local Char THISOPP(100) : THISOPP=""
  Local Char OPPDES(100) : OPPDES = ""
  Local Decimal PCOPP,SUBPP
  Local Integer NBOPP
  Local Integer K : K = 1
  Local Integer R : R = 1
  Local Integer TRACE : TRACE = 0

  Delete [F:MIGXTCP] Where [F:MIGXTCP]MIGREFNUM = [M:MIGXTC0]MIGREFNUM
  Raz [M:MIGXTC1]CMPNBR
  Affzo [M:MIGXTC1]
  Filter [F:MIGXTM] Where MIGREFNUM=[M:MIGXTC0]MIGREFNUM & TMSTATCOD = 0 & TMINCLUDE = 2

  NBOPP = rowcount([F:MIGXTM])
  If MIGRATE = 1
    Call OUVRE_VLC("Migrating [Only in source] data", "", "") From GESECRAN
  Else
    Call OUVRE_VLC("Comparing table data - Index Perspective - " + num$(NBOPP) + " table(s)", "", "") From GESECRAN
  Endif

  Call OUVRE_TRACE(num$([F:MIGXTM]MIGREFNUM)-"Data Compares") From LECFIC

  nolign = 0
  For [F:MIGXTM]

    Call ECR_TRACE("Comparing index values of " + num$([F:MIGXTM]TMSRCTBL), 0) From GESECRAN

    PCOPP = arr((K/NBOPP)*100, 1)
    THISOPP = "Tables: [" + num$([F:MIGXTM]TMSRCTBL) + "]"
    OPPDES = "Comparing index values..."
    Call AFF_VLC(THISOPP-"-"-OPPDES, "Overall Progress: " +  num$(PCOPP)-"%") From GESECRAN

    nolign += 1
    Local File = F_SRC + "." + [F:MIGXTM]TMSRCTBL [T_SRC]
    Local File = F_TRG + "." + [F:MIGXTM]TMTRGTBL [T_TRG]

    ONLY_SRC = 0
    ONLY_TRG = 0
    BOTH_DIFF = 0
    IDENTICAL = 0
    ERR_COUNT = 0

    Local Clbfile FILT(3) : FILT = [F:MIGXTM]TMIDXQUERY
    Local Char INDEXES(100)(1..)
    Local Integer IDX_COUNT
    Local Integer SRC_ROWS
    Local Integer TRG_ROWS

    Call SPLIT([F:MIGXTM]TMIDXVAL, "+", INDEXES, IDX_COUNT) From SUBMIGX

    SRC_ROWS = rowcount([T_SRC])
    TRG_ROWS = rowcount([T_TRG])

    R = 1

    If SRC_ROWS = 0 & TRG_ROWS = 0
      ONLY_SRC = 0
      ONLY_TRG = 0
      BOTH_DIFF = 0
      IDENTICAL = 0
      ERR_COUNT = 0
    Elsif SRC_ROWS > 0 & TRG_ROWS = 0
      ONLY_SRC = SRC_ROWS
      ONLY_TRG = 0
      BOTH_DIFF = 0
      IDENTICAL = 0
      ERR_COUNT = 0

      If MIGRATE = 1
        For [T_SRC]
          OPPDES = "Migrating record (" + num$(R) + ")"
          SUBPP = arr((R/SRC_ROWS)*100, 1)
          Call AFF_VLC(THISOPP-"-"-OPPDES, "Overall Progress: " + num$(PCOPP)-"%" - " [ Row Progress:"-num$(SUBPP)-"% ]") From GESECRAN

          [T_TRG] = [T_SRC]
          Write [T_TRG]

          R += 1
        Next
      Endif

    Elsif SRC_ROWS = 0 & TRG_ROWS > 0
      ONLY_SRC = 0
      ONLY_TRG = TRG_ROWS
      BOTH_DIFF = 0
      IDENTICAL = 0
      ERR_COUNT = 0
    Else
      For [T_SRC]

        Gosub INVOKE_CLASS_MAP

        FILT = [F:MIGXTM]TMIDXQUERY

        OPPDES = "Comparing source -> target rows (" + num$(R) + ")"
        SUBPP = arr((R/SRC_ROWS)*100, 1)
        Call AFF_VLC(THISOPP-"-"-OPPDES, "Overall Progress: " + num$(PCOPP)-"%" - " [ Row Progress:"-num$(SUBPP)-"% ]") From GESECRAN

        For I = 1 To IDX_COUNT
          FILT = func REPLACE(FILT, "#", ctrans(num$(evalue("[T_SRC]" + INDEXES(I))), "'", ""), 0)
        Next

        TRACE = 0
        Onerrgo CMPERR #try
          Filter [T_TRG] Where evalue(FILT)
          Look [T_TRG] First

          If TRACE = 0
            If fstat > 0
              ONLY_SRC += 1

              If MIGRATE = 1
                [T_TRG] = [T_SRC]
                Write [T_TRG]
              Endif
            Else
              IDENTICAL += 1
            Endif
          Else
             ERR_COUNT += 1
          Endif
        TRACE = 0 #finally

        R += 1

        If ERR_COUNT > 10
         Infbox "Too many errors encountered comparing [" + num$([F:MIGXTM]TMSRCTBL) + "]"
         Break #Break loop if too many errors occur
        Endif

      Next

      #Skip target -> source comparison when doing migration
      If MIGRATE = 0
        Filter [T_TRG]

        R = 1
        For [T_TRG]
          FILT = [F:MIGXTM]TMIDXQUERY

          OPPDES = "Comparing target -> source rows (" + num$(R) + ")"
          SUBPP = arr((R/TRG_ROWS)*100, 1)
          Call AFF_VLC(THISOPP-"-"-OPPDES, "Overall Progress: " + num$(PCOPP)-"%" - " [ Row Progress:"-num$(SUBPP)-"% ]") From GESECRAN

          For I = 1 To IDX_COUNT
            FILT = func REPLACE(FILT, "#", ctrans(num$(evalue("[T_TRG]" + INDEXES(I))), "'", ""), 0)
          Next

          TRACE = 0
          Onerrgo CMPERR #try
            Filter [T_SRC] Where evalue(FILT)
            Look [T_SRC] First

            If TRACE = 0
              If fstat > 0
                ONLY_TRG += 1
              Endif
            Else
               ERR_COUNT += 1
            Endif
          TRACE = 0 #finally

          R += 1

          If ERR_COUNT > 10
           Infbox "Too many errors encountered comparing [" + num$([F:MIGXTM]TMSRCTBL) + "]"
           Break #Break loop if too many errors occur
          Endif

        Next
      Endif
    Endif


    Close File [T_SRC]
    Close File [T_TRG]

    [F:MIGXTCP]CMPNBR = nolign
    [F:MIGXTCP]MIGREFNUM = [F:MIGXTM]MIGREFNUM
    [F:MIGXTCP]TMNBR = [F:MIGXTM]TMNBR
    [F:MIGXTCP]CMPSRCC = ONLY_SRC
    [F:MIGXTCP]CMPTRGC = ONLY_TRG
    [F:MIGXTCP]CMPIBDC = BOTH_DIFF
    [F:MIGXTCP]CMPIDNC = IDENTICAL
    [F:MIGXTCP]CMPERR = ERR_COUNT

    Write [F:MIGXTCP]
    Call ECR_TRACE("Compare done for: " + num$([F:MIGXTM]TMSRCTBL), 0) From GESECRAN

    K += 1
  Next

  If MIGRATE = 1
    Call MESSAGE("Migration completed. Please re-run compare to update comparison results.") From GESECRAN
  Else
    Call MESSAGE("Data compare completed.") From GESECRAN
  Endif

  #Close progress window
  Call FERME_VLC From GESECRAN

  #Trace File Closing Statements
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC

  Close File [MIGXMAIN]
  Filter [F:MIGXTM]
  Call LOAD_DATA()

End

######################################################################################

$INVOKE_CLASS_MAP
  If [F:MIGXTM]TMCLSMAP <> ""
    Local Integer J : J = 0
    J = filexist("","",[F:MIGXTM]TMCLSMAP)
    If J = 1
      Local Integer INVOKE_TRACE : INVOKE_TRACE = 0
      Onerrgo INVOKE_CLS_MAP_ERR #try
        Gosub CLASSMAP From =[F:MIGXTM]TMCLSMAP
        If INVOKE_TRACE = 1
          ERR_COUNT += 1
        Endif
      INVOKE_TRACE = 0 #finally
    Else
      Call ECR_TRACE("Class map file does not exist: " +  num$([F:MIGXTM]TMCLSMAP), 1) From GESECRAN
      ERR_COUNT += 1
    Endif
  Endif
Return

######################################################################################

$INVOKE_CLS_MAP_ERR
  Call ECR_TRACE("Error loading class map script: " +  num$([F:MIGXTM]TMCLSMAP), 1) From GESECRAN
  Call ECR_TRACE("Error: " + num$(errn)-errmes$(errn)-errm, 1) From GESECRAN
  INVOKE_TRACE = 1
Resume

######################################################################################

$CMPERR
  Call ECR_TRACE("Error occurred comparing index values: " +  num$([F:MIGXTM]TMSRCTBL) + " :: " + FILT, 1) From GESECRAN
  Call ECR_TRACE("Error: " + num$(errn)-errmes$(errn)-errm, 1) From GESECRAN
  TRACE = 1
Resume

######################################################################################

Funprog REPLACE(STRVAL, OLDSTR, NEWSTR, ALLOCCR)
  Variable Clbfile STRVAL
  Value Char OLDSTR
  Value Char NEWSTR
  Value Integer ALLOCCR #1 - true
  Local Clbfile RESULT(3)

  Local Integer S_IX : S_IX = 1
  Local Integer F_IX : F_IX = 1

  Repeat
    F_IX = instr(S_IX, STRVAL, OLDSTR)

    If F_IX > 0
      RESULT = seg$(STRVAL, 1, F_IX - 1) + NEWSTR + seg$(STRVAL, F_IX + len(OLDSTR), len(STRVAL))

      S_IX = (F_IX - 1 - S_IX) + len(NEWSTR) + 1

      STRVAL = RESULT

      If ALLOCCR < 1
        Break
      Endif
    Else
      RESULT = STRVAL
    Endif

  Until F_IX <= 0

End RESULT

######################################################################################

