#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque MAI5
########################################
Subprog AM_SHIMOD(VALEUR)
Variable Integer VALEUR

Local Integer IERRINF
IERRINF = 0

#GIEMATXT = 0
#GITPLSEL = 0

If VALEUR = 4
    If GINTRA
        [M:MAI5]TYPMRG = 4
    Else
        [M:MAI5]TYPMRG = 3
    Endif

    If GSZTYPSEA = "CCN"
        [M:MAI5]TPL = "MAILCCN"
        #Test si MAILCCN existe. S'il n'existe pas on crée la version standard.
        Read [MXL] MXL0 = "MAILCCN"
        If fstat
            Call CREMAILCCN(IERRINF) From SUBMXLB
            If IERRINF
                #La création du publipostage XML standard : MAILCCN a échoué.
                GMESSAGE = mess(667, 182, 2)
                GERR = 1
            Endif
        Endif
    Else
        [M:MAI5]TPL = "MAILBPR"
        #Test si MAILBPR existe. S'il n'existe pas on crée la version standard.
        Read [MXL] MXL0 = "MAILBPR"
        If fstat
            Call CREMAILBPR(IERRINF) From SUBMXLB
            If IERRINF
                #La création du publipostage XML standard : MAILBPR a échoué.
                GMESSAGE = mess(666, 182, 2)
                GERR = 1
            Endif
        Endif
    Endif
Else
    [M:MAI5]TYPMRG = 1
Endif

[M:MAI5]SHIMOD = VALEUR
Affzo [M:MAI5]SHIMOD
End

