#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# Project       : Swiss Localization
# File          : SUBPAY4SWI
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 21.05.15
######################################################################################################
# Module        : Accounting
# Description   : Swiss specific initializations for payments
######################################################################################################
 # Updates :
 # Date       |Author| Description
 # 2016-01-25 |TOGAN | PICKE label
 # 2018-07-25 |Bader | X3-99013: PICKE: support QR codes
 # 2018-08-29 |Bader | X3-104610 PICKE: try to find BID for BPR first, if not found second try with BPRPAY
######################################################################################################

$CHARGE_LIG
    If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2 Then # parameter "Swiss checks in payments" = yes?
        [M:PAY1]PAM = [F:DUD]PAM
        If !GIMPORT Then : Affzo [M:PAY1]PAM : Endif
    Endif
Return

$PICKE
If (dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2) or (dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2) Then # parameter "Swiss ISR/QR checks in payments" = yes?
    # X3-29237
    If find([F:TPY]SWIPAYTYP, 2, 3, 4) Then   # DTA/EZAG/ISO payment?
        If func SWILIB0.IS_SUPPLIER_INVOICE([F:DUD]TYP) Then
            If !clalev([F:XBID]) Then : Local File BID [XBID] : Endif
            Local Integer FOUND : Raz FOUND
            Local Char ACTBID(GLONBID)
            Local Char ACTBPR(GLONBPR)
            Local Char ACTBPRPAY(GLONBPR)

            # first step: try to find ISR bill information
            If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2
                If !clalev([F:XPIH]) Then : Local File PINVOICE [XPIH] : Endif
                #--- Read invoice ----#
                Read [F:XPIH]PIH0 = [F:DUD]NUM
                If fstat = 0 Then
                    #---- read BID with value from PINVOICE ----#
                    ACTBID = [F:PIH]BVRBID
                    ACTBPR = [F:PIH]BPR
                    ACTBPRPAY = [F:PIH]BPRPAY
                    Gosub FINDBID
                    If FOUND : Return : Endif
                Endif
            Endif
            # no ISR bill information found > try to find QR bank ID in SWIQRC
            If dim(GSWIPAYQR) > 0 and GSWIPAYQR = 2
                If !clalev([F:XQRC]) Then : Local File SWIQRC [XQRC]   : Endif
                Read [F:XQRC]SWIQRC0 = [F:DUD]NUM;6           # try to find QR bill infomation, ORIMOD=6 for supplier invoice
                If !fstat
                    #---- read BID with value from SWIQRC ----#
                    ACTBID = right$([F:XQRC]IBACOD,5)
                    ACTBPR = [F:DUD]BPR
                    ACTBPRPAY = [F:DUD]BPRPAY
                    Gosub FINDBID
                Endif
            Endif
        Endif
    Endif
Endif
Return


$FINDBID
Read [F:XBID]BID0 = 1;ACTBPR;ACTBID       # first try to find BID for supplier (manually selected)
If fstat = 0 Then
    FOUND = 1
Else
    Read [F:XBID]BID0=1;ACTBPRPAY;ACTBID  # second try to find BID for pay-to supplier (ISR)
    If fstat=0
        FOUND = 1
    Endif
Endif
If FOUND
    Gosub FILLPAY1
Endif
Return


$FILLPAY1
#---- Fill fields in screen PAY1 ----#
If dim([M:PAY1]BIDCRY) > 0    Then : [M:PAY1]BIDCRY    = [F:XBID]CRY      : Endif
If dim([M:PAY1]BID) > 0       Then : [M:PAY1]BID       = [F:XBID]BIDNUM   : Endif
If dim([M:PAY1]PAB1) > 0      Then : [M:PAY1]PAB1      = [F:XBID]PAB1     : Endif
If dim([M:PAY1]PAB2) > 0      Then : [M:PAY1]PAB2      = [F:XBID]PAB2     : Endif
If dim([M:PAY1]PAB3) > 0      Then : [M:PAY1]PAB3      = [F:XBID]PAB3     : Endif
If dim([M:PAY1]PAB4) > 0      Then : [M:PAY1]PAB4      = [F:XBID]PAB4     : Endif
If dim([M:PAY1]BICCOD) > 0    Then : [M:PAY1]BICCOD    = [F:XBID]BICCOD   : Endif
If dim([M:PAY1]MIDPAB1) > 0   Then : [M:PAY1]MIDPAB1   = [F:XBID]MIDPAB1  : Endif
If dim([M:PAY1]MIDPAB2) > 0   Then : [M:PAY1]MIDPAB2   = [F:XBID]MIDPAB2  : Endif
If dim([M:PAY1]MIDPAB3) > 0   Then : [M:PAY1]MIDPAB3   = [F:XBID]MIDPAB3  : Endif
If dim([M:PAY1]MIDPAB4) > 0   Then : [M:PAY1]MIDPAB4   = [F:XBID]MIDPAB4  : Endif
If dim([M:PAY1]MIDBICCOD) > 0 Then : [M:PAY1]MIDBICCOD = [F:PYH]MIDBICCOD : Endif
If dim([M:PAY1]MIDCRY) > 0    Then : [M:PAY1]MIDCRY    = [F:XBID]MIDCRY   : Endif
If !GIMPORT Then
    If dim([M:PAY1]BIDCRY) > 0 Then : Affzo [M:PAY1]BIDCRY : Endif
    If dim([M:PAY1]BID) > 0    Then : Affzo [M:PAY1]BID    : Endif
    If dim([M:PAY1]PAB1) > 0   Then : Affzo [M:PAY1]PAB1   : Endif
Endif
Return

