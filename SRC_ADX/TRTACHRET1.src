#<AdxTL>@(#)5.0.0.0 $Revision$
###########################################################################
# TRTACHRET1          Traitement liés aux retours            Module ACHAT #
# ----------------------------------------------------------------------- #
# Sous-programmes :                                                       #
#   - VALIDATION     : Validation d'un retour                             #
#   - RECH_SEQ       : Recherche numéro de séquence pour cde ouverte      #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement divers Call VAL_PNH)               #
#   - TRTVALPNH      : Validation d'un retour                             #
###########################################################################


#############################################
# Action TRTVALPNH : Validation d'un retour #
# ----------------------------------------- #
# Pas de paramètre                          #
#############################################
Subprog VAL_PNH
Local Integer WRET
Call VALIDATION ([M:PNH1]PNHNUM,1,[L]WRET)  From TRTACHRET1
End


######################################################
# Validation d'un retour                             #
# -------------------------------------------------- #
# Appelé par :                                       #
#  - le bouton de "Validation" (Action TRTVALPNH)    #
#       WTRT=1  Validation du retour concerné        #
#  - la fonction de validation en masse              #
#       WTRT=2  Validation d'un ensemble de retours  #
#      appelé successivement pour chacun des retours #
######################################################
Subprog VALIDATION(WRETOUR,WTRT,WRET)
Value    Char    WRETOUR
Value    Integer WTRT
Variable Integer WRET
#----- Variables locales -----#
Local Char     PARAM2(10)
Local Decimal  WQTE1, WQTE2
Local Char     WMSG(90)
Local Integer  SVGNOLIGN, I
#----- Variables locales pour le point d'entrée -----#
Local Char     NUMRET(GLONPNH)
Local Integer  LINRET, MAJFLG
Local Shortint SAVXZSNOL
Local Char     SYMBOL2(30)
#-----
If !clalev([F:POQW]) Local File PORDERQ   [POQW] : Endif
#-----
If func AFNC.ACTIV("TRSNE")
  If !clalev ([F:TPN]) : Local File TABPNHTYP [TPN] : Endif
Endif
#BRBAN 26-03-2015 #106027
If !clalev ([F:PTBPA]) : Local File BPADDRESS [PTBPA] : Endif
#-----

If !clalev([M:ORDK]) Local Mask ORDK      [ORDK] : Endif
If !clalev([M:STW])  Local Mask STOWORK    [STW] : Endif
If !clalev([M:SVW])  Local Mask STOVALWORK [SVW] : Endif
If !clalev([M:ALP])  Local Mask ALLPAR     [ALP] : Endif : # Masque paramètres allocations
If !clalev([M:SOW])  Local Mask STOSORW    [SOW] : Endif : # Masque travail sorties stock


# affectations
Gosub OPEN_MTO From MTOLINKLIB

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Local Mask POI1 [POI1]
Raz [M:POI1], [F:PNH], [F:PND]
Raz GPLISTC, GPURCMM, GPURCMMDAT, GCNTBUD, GBUDCTLPOH, WRET
GCNTBUD=1
Default Mask [POI1]
#----- Si appelé depuis le bouton "Validation", il faut ouvrir la trace -----#
If WTRT<>2
  Call OUVRE_TRACE(mess(79,197,1)) From LECFIC
  SVGNOLIGN=nolign
  Gosub FERME_FIC : # pour voir
Endif
#----- Si entête retour bloquée logiquement --> Abandon -----#
SYMBOL2="PNH"+WRETOUR
Lock=SYMBOL2
If fstat
  Call ECR_TRACE("$PRETURN"-WRETOUR-mess(10,100,1),1) From GESECRAN
  GOK=0 : SYMBOL2="" : Goto FINVAL
Endif
#-----
Call DEBTRANS From GLOCK
#----- Début de la transaction de validation -----#
$TR_VALID
GOK=1 : WRET=0
Trbegin [F:PNH]
  Readlock [F:PNH]PNH0=WRETOUR
  If fstat=1
    GOK=-1 : GLOCK="$PRETURN"                : Goto ROL_VAL
  Elsif fstat
    GOK=0  : Call RSTA("PNH",WRETOUR) From GLOCK : Goto AB_VAL
  Endif
  WMSG=mess(83,197,1)-[F:PNH]PNHNUM-mess(150,197,1)
  If WTRT<>2
    Call ECR_TRACE(WMSG,0) From GESECRAN
  Endif
  Raz WMSG

  #85785
  Local Integer PORDIGSIGN : [L]PORDIGSIGN = func PORLEGLIB.DIGSIGN("", [F:PNH]CPY)
  If [L]PORDIGSIGN = 1 & func AFNC.ACTIV("KPO") > 0

    Local Char LNUM(GLONVCR)
    Local Char WCPT(GLONANM)
    Local Char CBLOB(3)
    Local Char WABREV(3)

    If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
    Call LEC_CPY([F:PNH]CPY) From CPTLEC

    # Document type
    If [F:PNH]PNHTYP<>""

      Call LEC_TPN_LEG([F:CPY]LEG,[F:PNH]PNHTYP,WRET) From TRTLECLEG
      If WRET<>0 Raz [F:TPN] : Endif

      If [F:PNH]BETFCY <> G_YES and [F:PNH]BETCPY <> G_YES Then
        # Normal return
        WCPT = [F:TPN]CODNUMEND
      Else
        If [F:PNH]BETFCY = G_YES and [F:PNH]BETCPY <> G_YES Then
          # Intersite return
          WCPT = [F:TPN]CODNUMFCYD
        Elsif [F:PNH]BETFCY = G_YES and [F:PNH]BETCPY = G_YES Then
          # Inter company return
          WCPT = [F:TPN]CODNUMCPYD
        Endif
      Endif
    Endif

    If func PORLEGLIB.ANM_OK(WCPT, GMESSAGE) <> 1
      GOK=0 : WRET=1 : WMSG = GMESSAGE : Goto AB_VAL
    Endif

    Call NUMERO(WCPT,[F:PNH]PNHFCY,[F:PNH]RTNDAT,"",LNUM,WRET) From SUBANM

    If GOK<0 Goto ROL_VAL Endif

    If WRET <> 0 | GOK<1
      Local Char MESSA(80)
      Local Integer SAUV_STAT
      If dim(STAT)<0 : Local Integer STAT : Endif
      SAUV_STAT=STAT : STAT=WRET
      #GMESSAGE=mess(60,199,1)-"("+[F:TCA]CODNUM(13)+") : "
      GMESSAGE=mess(60,199,1)-"("+WCPT+") : "
      Gosub MESSAGE From SUBANM
      STAT=SAUV_STAT
      GMESSAGE-=MESSA : GERR=1 : WRET=1 : WMSG = GMESSAGE : GOK=0 : Goto AB_VAL
    Endif

    Gosub CTRL_CHRONOLOGIC
    If GOK=0 : WRET=1 : WMSG = GMESSAGE : Goto AB_VAL : Endif

    # Table updates with the new sequence counter
    If !clalev([F:ABB]) : Local File ABLOB     [ABB] : Endif
    If !clalev([F:ACB]) : Local File ACLOB     [ACB] : Endif
    If !clalev([F:AOX]) : Local File AOBJTXT   [AOX] : Endif
    If !clalev([F:AOM]) : Local File AOBJTXTA  [AOM] : Endif
    If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif
    If !clalev([F:PND]) : Local File PRETURD   [PND] : Endif
    If !clalev([F:STA]) : Local File STOALL    [STA] : Endif

    [L]WABREV="PNH"

    Update [AOX] Where ABREV=[L]WABREV & IDENT1=[F:PNH]PNHNUM With IDENT1=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("AOX") From GLOCK
      Goto AB_VAL
    Endif
    Update [AOM] Where ABREV=[L]WABREV & IDENT1=[F:PNH]PNHNUM With IDENT1=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("AOM") From GLOCK
      Goto AB_VAL
    Endif
    [L]CBLOB = "PJ_" : # Pour les pieces jointes
    Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[F:PNH]PNHNUM With IDENT1=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("ACB") From GLOCK
      Goto AB_VAL
    Endif
    Update [ABB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[F:PNH]PNHNUM With IDENT1=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("ABB") From GLOCK
      Goto AB_VAL
    Endif
    [L]CBLOB = "CO_" : # Pour les commentaires
    Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[F:PNH]PNHNUM With IDENT1=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("ACB") From GLOCK
      Goto AB_VAL
    Endif

    Update [STA] Where VCRTYP=8 & VCRNUM=[F:PNH]PNHNUM With VCRNUM=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("STA") From GLOCK
      Goto AB_VAL
    Endif

    Update [CAL] Where ABRFIC="PND" & VCRTYP=0 & VCRNUM=[F:PNH]PNHNUM With VCRNUM=LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("CAL") From GLOCK
      Goto AB_VAL
    Endif

    # # 78411 : Sage Exchange - Update SDH Num in table SEAUTH
    # Local Integer WRET
    # If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SDH]PTE)
    #   Call TRANSFER(4,[F:SRH]SRHNUM,4,LNUM,WRET) From SEPPLIB
    #   If WRET : Raz GOK : Goto AB_VAL : Endif
    # Endif

    Update [PND] Where PNHNUM=[F:PNH]PNHNUM With PNHNUM=[L]LNUM
    If find(fstat,1,3)
      GOK=0  : Call FSTA("PND") From GLOCK
      Goto AB_VAL
    Endif

    [F:PNH]TMPPNHNUM = [F:PNH]PNHNUM
    [F:PNH]PNHNUM = LNUM
    Rewrite [F:PNH]
    If fstat
      GOK=0 : Call FSTA("PNH") From GLOCK
      Goto AB_VAL
    Endif
    #RMA
    #Readlock [F:PNH]PNH0 = LNUM
    #If fstat=1
    #  GOK=-1 : GLOCK="$PRETURN"+WRETOUR : Goto ROL_VAL
    #Elsif fstat
    #   GOK=0  : Call RSTA("PNH",WRETOUR) From GLOCK : Goto AB_VAL
    #Endif

    If clalev([M:PNH1]) : If dim([M:PNH1]PNHNUM)>0 : [M:PNH1]PNHNUM = LNUM : Endif : Endif

  Endif

  I =1             #MAE, bg 104558
  For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM
    Read [ITM] ITM0=[F:PND]ITMREF
    If fstat
      Call RSTA("ITM","*") From GLOCK
      WMSG=mess(12,100,1)-"ITMMASTER"-[F:PND]ITMREF
      GOK=0 : WRET=1 : Break
    Endif
    Read [ITP] ITP0=[F:PND]ITMREF;[F:PNH]BPSNUM
    If fstat  Raz [F:ITP] : Endif
    If [F:PND]STOMGTCOD>1 & [F:PND]LINTYP<3
      nolign = I     #MAE, bg 104558
      Gosub REMP_STW             : If GOK<1  Break : Endif
      Call MAJ_STOCK From STKMAJ : If GOK<1  Break : Endif
    Else                                                                                     # hcb 86563
      If [F:PND]LINSTOFCY <> ""                                                              # hcb 86563
         Call STKMAJITV([F:PND]LINSTOFCY,[F:PND]ITMREF,2,[F:PND]QTYSTU,1,WRET) From STKLIB   # hcb 86563
         If WRET : GOK = 0 : Break : Endif                                                   # hcb 86563
      Endif                                                                                  # hcb 86563
    Endif
    Gosub MAJ_FIC : If GOK<1  Break : Endif
    I=I+1            #MAE, bg 104558
  Next
  If GOK=-1  Goto ROL_VAL : Endif
  If GOK=0   Goto AB_VAL  : Endif

  #----- Màj de l'indicateur "Retour validé" -----#
  [F:PNH]CFMFLG=2
  Rewrite [F:PNH]
  If fstat  GOK=0 : Call FSTA("PNH") From GLOCK : Goto AB_VAL : Endif

  #85785
  If [L]PORDIGSIGN = 1

    Gosub DIGSIGN

    If [L]WRET > 1
      If GMESSAGE <> "" : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
      Raz GMESSAGE : Goto AB_VAL
    Endif
  Endif

  If [M:POI1]NBLIG>0
    Call GENERE_CDE("",4,1) From TRTACHCDE1
  Endif
  If GOK<1
    WRET=1 : WMSG=mess(97,197,1)-[F:PND]PNHNUM : Goto AB_VAL
  Endif
Commit

If [L]PORDIGSIGN = 1
  # BRBAN 08/07/2014 SAM#93745 US2
  If [F:PNH]ATDTCODR <> ""
     If !clalev ([F:DKD]) : Local File DKSDATA [DKD] : Endif
     Read [F:DKD]DKD0 = "SAFT-PT";[F:PNH]PNHTYP;[F:PNH]PNHNUM
     If !fstat
        If [F:DKD]ATDTCOD <> ""
           Call ECR_TRACE(mess(125,7711,1),1) From GESECRAN #This document already has a transport code.
        Else
           [F:DKD]ATDTCOD    = [F:PNH]ATDTCODR
           [F:DKD]ATDTCOMSTA = "0"
           [F:DKD]ATDTINPTYP = 1
           [F:DKD]RECTYP     = [F:TPN]RECTYP
           Rewrite [F:DKD]
           If fstat
              Call ECR_TRACE(mess(126,7711,1),1) From GESECRAN #Error while saving manual code.
           Endif
        Endif
     Else
        Call ECR_TRACE(mess(127,7711,1),1) From GESECRAN #The document is not signed.
     Endif
  Else
    Local Char    ATAUT(1)
    Local Integer RETSTAT

    Call PARAM([F:PNH]PNHFCY, "AUTCOMAT", [L]ATAUT) From ADOVAL
    If [L]ATAUT = "2"
      # BRBAN 24-03-2015 #106027
      Read [F:PTBPA] BPA0=1;[F:PNH]BPSNUM;[F:PNH]BPAADD
      If fstat  Raz [F:PTBPA] : Endif
      If [F:TPN]RECTYP=1 & [F:TPN]SAFTTRNTYP=5 & [F:PTBPA]CRY='PT' & func PORLEGLIB1.CTRL_COMDAT([F:PNH]PNHFCY,[F:PNH]DPEDATR,[F:PNH]ETDR)=1
        Call SENDDTTOAT([F:PNH]PNHNUM,9,RETSTAT) From PORLEGLIB1
      Endif
    Endif
  Endif
Endif

Goto FINVAL
#----- Rollback -----#
$ROL_VAL
Rollback
Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
  Goto FINVAL
Else
  Goto TR_VALID
Endif
#----- Abandon de la transaction -----#
$AB_VAL
Rollback
If WMSG=""  WMSG=mess(18,114,1) : Endif
If WRET
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
Call ECR_TRACE([F:PND]PNHNUM-mess(123,197,1),0) From GESECRAN
#----- Fin du traitement de validation des retours -----#
$FINVAL
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Close Mask [POI1]
Filter [PNH]

#--------------------------------------------------------------------------#
# Point d'entrée MAJPNHEND pour traitement après la validation d'un retour #
# -------------------------------------------------------------------------#
# Variables utilisables par le point d'entrée                              #
#                                                                          #
# WRETOUR : Numéro du retour validé                                        #
# WTRT    : Origine de la validation                                       #
#             1 = Bouton validation                                        #
#             2 = Fonction de validation en masse                          #
# La classe [F:PNH] est disponible                                         #
#--------------------------------------------------------------------------#
GPOINT="MAJPNHEND" : Gosub ENTREE From EXEFNC
#-----
WMSG=mess(83,197,1)-[F:PNH]PNHNUM-mess(124,100,1)
Call ECR_TRACE(WMSG,0) From GESECRAN
If GOK=1
  Call WORKFLOW("F_FUNPNHTRT","","") From SUBAMSC
Endif
#----- Lecture de la trace si appel depuis le bouton "Validation" -----#
If WTRT<>2
  Call ECR_TRACE(mess(79,197,1)-mess(124,100,1),0) From GESECRAN
  Call FERME_TRACE  From LECFIC
  Call LEC_TRACE  From LECFIC
  Gosub OUV_FIC
  nolign=SVGNOLIGN
Endif
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
End

$FERME_FIC
If clalev([F:BPS])>0 : Close Local File [BPS] : Endif
If clalev([F:BPR])>0 : Close Local File [BPR] : Endif
If clalev([F:BPA])>0 : Close Local File [BPA] : Endif
If clalev([F:CPY])>0 : Close Local File [CPY] : Endif
If clalev([F:TCY])>0 : Close Local File [TCY] : Endif
If clalev([F:TCU])>0 : Close Local File [TCU] : Endif
If clalev([F:TMD])>0 : Close Local File [TMD] : Endif
If clalev([F:TST])>0 : Close Local File [TST] : Endif
If clalev([F:QLQ])>0 : Close Local File [QLQ] : Endif
If clalev([F:QLA])>0 : Close Local File [QLA] : Endif
If clalev([F:QLC])>0 : Close Local File [QLC] : Endif
If clalev([F:SRU])>0 : Close Local File [SRU] : Endif
If clalev([F:TVT])>0 : Close Local File [TVT] : Endif
If clalev([F:ADI])>0 : Close Local File [ADI] : Endif
If clalev([F:TCO])>0 : Close Local File [TCO] : Endif
If clalev([F:GAC])>0 : Close Local File [GAC] : Endif
If clalev([F:PPK])>0 : Close Local File [PPK] : Endif
Return

$OUV_FIC
If clalev([F:PND])=0 : Local File PRETURND   [PND] : Endif
If clalev([F:PTH])=0 : Local File PRECEIPT   [PTH] : Endif
If clalev([F:PTD])=0 : Local File PRECEIPTD  [PTD] : Endif
If clalev([F:POH])=0 : Local File PORDER     [POH] : Endif
If clalev([F:POQ])=0 : Local File PORDERQ    [POQ] : Endif
If clalev([F:POP])=0 : Local File PORDERP    [POP] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif
If clalev([F:MVS])=0 : Local File BPSUPPMVT  [MVS] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITP])=0 : Local File ITMBPS     [ITP] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:TMD])=0 : Local File TABMODELIV [TMD] : Endif
If clalev([F:STO])=0 : Local File STOCK      [STO] : Endif
If clalev([F:STL])=0 : Local File STOLOT     [STL] : Endif
If clalev([F:TST])=0 : Local File TABSTASTO  [TST] : Endif
If clalev([F:QLQ])=0 : Local File QLYCRDQST  [QLQ] : Endif
If clalev([F:QLA])=0 : Local File QLYCRDASW  [QLA] : Endif
If clalev([F:QLC])=0 : Local File QLYCRD     [QLC] : Endif
If clalev([F:STJ])=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:STA])=0 : Local File STOALL     [STA] : Endif
If clalev([F:STS])=0 : Local File STOSER     [STS] : Endif
If clalev([F:ITV])=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ORD])=0 : Local File ORDERS     [ORD] : Endif
If clalev([F:SRU])=0 : Local File TABSTORUL  [SRU] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:TCO])=0 : Local File TABCOEFF   [TCO] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:CAL])=0 : Local File CPTANALIN  [CAL] : Endif
If clalev([F:PPK])=0 : Local File PPRICLINK  [PPK] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

Return

#########################################################
# Remplissage de l'écran de travail pour màj des stocks #
#########################################################
$REMP_STW
Raz [M:STW]
[M:STW]STOFCY  = [F:PNH]PNHFCY
If dim([F:PND]LINCAT)>0 & [F:PND]LINCAT= 2 : # GA 09/2006
   [M:STW]TRSTYP = 32               : # Type mouvement (M.704): retour matière pour sous-traitance
   [M:STW]BPSFCY = [F:PND]LINSTOFCY : # Site propriétaire des matières pour sous-traitance
Else
   [M:STW]TRSTYP = 11               : # Type mouvement (M.704)
Endif
[M:STW]VCRTYP  = 8                  : # Type pièce (M.701)
[M:STW]VCRNUM  = [F:PNH]PNHNUM
[M:STW]VCRLIN  = [F:PND]PNDLIN
[M:STW]ITMREF  = [F:PND]ITMREF
[M:STW]MVTDES  = ""
[M:STW]BPRNUM  = [F:PNH]BPSNUM
[M:STW]CUR     = [F:PND]NETCUR
[M:STW]BPAADD  = [F:PNH]BPAADD
[M:STW]PJT     = [F:PND]PJT
[M:STW]TRSCOD  = [F:PNH]TRSCOD
[M:STW]TRSFAM  = [F:PND]TRSFAM
[M:STW]IPTDAT  = [F:PNH]RTNDAT
[M:STW]ENTCOD  = [F:PNH]ENTCOD
[M:STW]CCECOD  = "STKPRT"         : # Code paramétrage sections par défaut
[M:STW]BETCPY  = [F:PNH]BETCPY
[M:STW]TRFFCY  = [F:PND]LINSTOFCY
If [F:PND]PTHNUM<>""
  [M:STW]VCRTYPORI = 6
  [M:STW]VCRNUMORI = [F:PND]PTHNUM
  [M:STW]VCRLINORI = [F:PND]PTDLIN
Else
  Raz [M:STW]VCRTYPORI, [M:STW]VCRNUMORI, [M:STW]VCRLINORI
Endif
[M:STW]PRIORDH = 0
[M:STW]PRIPUR  = 0
[M:STW]SEQ     = 0
If GTRACE<>"" [M:STW]TRAFLG=2 Else [M:STW]TRAFLG=1 : Endif
#----- Interface pour la maj des stocks -----#
Call ALISTOWORK(1,0,WQTE1,WQTE2,GBIDI2,GBIDI3,WRET) From STKINT
If !WRET
  # Pas de contrôle pour les articles à titre car la qté en unité active n'est pas connue !
  #----- La qté à retourner est différente de la qté allouée + rupture -----#
  If !find([F:PND]STOMGTCOD,3,4) & WQTE1+WQTE2<>[F:PND]QTYSTU
    Call ECR_TRACE([F:PNH]PNHNUM-[F:PND]ITMREF+"\"+mess(264,194,1),1) From GESECRAN
    GOK=0 : Return
  Endif
Else
  GOK=0 : Return
Endif
Return


###########################################
# Màj de tous les fichiers liés au retour #
###########################################
$MAJ_FIC
Local Decimal WORDNOT, WORDATI, WTTVORD, WQTY
Local Integer WLINPOP, WDESOLDE, WTOTALRET
Local Integer OK, STAT
Local Char    SECTION(GLONCCE)
Local Char    VAT(GLONVAT)(3) : Raz VAT
Local Decimal WCLCAMT(1..7)
#----- Lecture de l'article si nécessaire -----#
If [F:ITM]ITMREF<>[F:PND]ITMREF
  Read [ITM] ITM0=[F:PND]ITMREF : If fstat  GOK=0 : Return : Endif
Endif
#-----------------------------------------------------#
# Mise à jour de la réception (sauf si retour direct) #
# --------------------------------------------------- #
# Màj des quantités retournées RTNQTYSTU et RTNQTYPUU #
#-----------------------------------------------------#
Raz WTOTALRET
If [F:PND]PTHNUM<>""
  Readlock [PTD] PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN
  If fstat=1
    GOK=-1 : GLOCK="$PRECEIPTD"-[F:PND]PTHNUM-num$([F:PND]PTDLIN)
    Return
  Elsif fstat
    GOK=0  : Call RSTA("PTD",[F:PND]PTHNUM-num$([F:PND]PTDLIN)) From GLOCK
    WRET=1 : WMSG=mess(90,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN)
    Return
  Endif
  [F:PTD]RTNQTYSTU+=[F:PND]QTYSTU
  Call PCAL_QTY([F:PTD]RTNQTYSTU,[F:PTD]STU,[F:PTD]RTNQTYPUU,[F:PTD]PUU,
&               [F:PTD]ITMREF,[F:PNH]BPSNUM,1,GBIDD1) From TRTACHQTE1
  Rewrite [PTD]
  If fstat
    GOK=0  : Call FSTA("PTD") From GLOCK
    WRET=1 : WMSG=mess(90,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN)
    Return
  Endif
  If [F:PTD]RTNQTYSTU=[F:PTD]QTYSTU  WTOTALRET=2 : Endif : # Indicateur retour total
Endif
#----------------------------#
# Mise à jour de la commande #
#----------------------------#
#If [F:ITM]SCSFLG=2 [F:PND]ORDFLG=1 : Endif
#----- Pas de réintégration si sous-traitance (à vérifier ?????) -----#
If find([F:PTD]VCRTYPORI,10,36) : [F:PND]ORDFLG=1 : Endif
If [F:PND]ORDFLG=1 | [F:PND]POHNUM=""
  Goto FIN_MAJ
Endif
#------------------------------------------------#
# Si réintégration sur la même ligne de commande #
#------------------------------------------------#
If [F:PND]ORDFLG=2
  #----- Lecture ligne commande (quantités) -----#
  Readlock [POQ] POQ0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
  If fstat=1
    GOK=-1 : GLOCK="$PORDERQ"-[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
    Return
  Elsif fstat
    GOK=0  : Call RSTA("POQ",[F:PND]POHNUM-num$([F:PND]POPLIN)) From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
    Return
  Endif
  #----- Lecture entête commande -----#
  Read [POH] POH0=[F:POQ]POHNUM
  If fstat
    GOK=0  : Call RSTA("POH",[F:PND]POHNUM) From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM
    Return
  Endif
  [F:POQ]RCPQTYSTU-=[F:PND]QTYSTU
  Call PCAL_QTY([F:POQ]RCPQTYSTU,[F:POQ]STU,[F:POQ]RCPQTYPUU,[F:POQ]PUU,
&               [F:POQ]ITMREF,[F:PNH]BPSNUM,1,GBIDD1) From TRTACHQTE1
  #----- lecture ligne commande (prix) -----#
  Read [POP] POP0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
  If fstat
    GOK=0  : Call RSTA("POP",[F:PND]POHNUM-num$([F:PND]POPLIN)) From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
    Return
  Endif
  #----- Si qté réceptionnée inférieure à qté commandée -----#
  If [F:POQ]RCPQTYSTU<[F:POQ]QTYSTU
    #----- màj de l'en commande article et fournisseur -----#
    WTTVORD=[F:POH]TTVORD
    Gosub MAJ_ITVMVS : If WRET  Return : Endif
    #----- Si ligne était soldée , on la désolde -----#
    WDESOLDE=1
    If [F:POQ]LINCLEFLG=2
      [F:POQ]LINCLEFLG=1 : WDESOLDE=2
      #----- Si ligne avait été soldée manuellement, on màj le budget pour le reliquat
      If [F:POQ]RCPCLEFLG=1
        Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,+1,2,"POQ2",3,GBIDI1) From TRTACHDIV1
      Endif
    Endif
  Endif
  Rewrite [POQ]
  If fstat
    GOK=0  : Call FSTA("POQ") From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
    Return
  Endif
  #----- Màj de l'encours -----#
  If [F:POQ]WIPNUM<>""
    Raz [M:ORDK]
    Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
    If fstat  Raz [F:ORD] : Endif
    [M:ORDK]          = [F:ORD]
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
    [M:ORDK]STOFCY    = [F:POQ]PRHFCY
    [M:ORDK]PJT       = [F:POP]PJT
    [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
    [M:ORDK]STRDAT    = [F:POQ]ORDDAT
    [M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:POQ]POHNUM
    [M:ORDK]VCRLIN    = [F:POQ]POPLIN
    [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
    [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
    [M:ORDK]CPLQTY    = [F:POQ]RCPQTYSTU
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = 1
    [M:ORDK]MRPMES    = 1
    # Issue 71276 - 2015-02-27 by SR : Versions
    If dim([M:ORDK]ECCVALMAJ)> 0
     [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
     [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
    Endif
    # End issue 71276
    #----- Chargement infos origine si erreur lecture sur l'ordre à modifier -----#
    If [F:ORD]WIPNUM=""
      [M:ORDK]ORIFCY    = [F:POQ]POHFCY
      [M:ORDK]VCRTYPORI = 0
      [M:ORDK]VCRNUMORI = ""
      [M:ORDK]VCRLINORI = 0
      [M:ORDK]VCRSEQORI = 0
    Endif
    #-----
    [M:ORDK]BOMALT    = 0
    [M:ORDK]ORI       = 1
    [M:ORDK]ABBFIL    = "POQ"
    Call WIP From TRTWIP
    If GOK<1
       WRET=1 : WMSG=mess(92,197,1)-num$([F:POQ]WIPTYP)-[F:POQ]WIPNUM-[F:POQ]ITMREF
       Return
    Endif
    # affectations v6
    Gosub MAJ_MTO_POQ From PURMTOLIB
  Endif
  #----- Màj de l'entête de commande -----#
  Readlock [POH] POH0=[F:PND]POHNUM
  If fstat=1
    GOK=-1 : GLOCK="$PORDER"-[F:PND]POHNUM
    Return
  Elsif fstat
    GOK=0  : Call RSTA("POH",[F:PND]POHNUM) From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM
    Return
  Endif
  If WDESOLDE=2  [F:POH]CLELINNBR-=1 : [F:POH]RCPLINNBR-=1 : Endif
  If [F:POQ]RCPQTYSTU=0 | WTOTALRET=2  [F:POH]RCPNBR-=1 : Endif
  [F:POH]CLEFLG=1
  If [F:POH]RCPNBR>0  [F:POH]RCPFLG=2  Else  [F:POH]RCPFLG=1 : Endif
  Rewrite [POH]
  If fstat
    GOK=0  : Call FSTA("POH") From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM
    Return
  Endif
#--------------------------------------#
# Si réintégration sur une autre ligne #
#--------------------------------------#
Elsif [F:PND]ORDFLG=3
  Readlock [POH] POH0=[F:PND]POHNUM
  If fstat=1
    GOK=-1 : GLOCK="$PORDER"-[F:PND]POHNUM
    Return
  Elsif fstat
    GOK=0  : Call RSTA("POH",[F:PND]POHNUM) From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM
    Return
  Endif
  #-----
  Read [POQ] POQ0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
  If fstat
    GOK=0  : Call RSTA("POQ",[F:PND]POHNUM-num$([F:PND]POPLIN)) From GLOCK
    WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
    Return
  Endif
  #----- Ajout de ligne sur commande classique -----#
  If [F:POH]POHTYP<>2
    Call AJOUT_LIGNE From TRTACHRET1
    If GOK<1  WRET=1 : WMSG=mess(91,197,1)-[F:PND]POHNUM : Return : Endif
    [F:POQ]EXTRCPDAT=date$
  #----- Ajout de ligne sur commande ouverte -----#
  Else
    #----- Peux t'on mettre la nouvelle DL avec la date du jour ? -----#
    Filter [POQW] Where POHNUM=[F:POQ]POHNUM
&                     & POPLIN=[F:POQ]POPLIN
&                     & EXTRCPDAT<=date$
    Read [POQW] POQ0 Last
    Filter [POQW]
    #----- Le cadencement de la DL précédente permet pas de changer la date -----#
    If fstat | [F:POQW]CAD<2
      [F:POQ]EXTRCPDAT=date$
      [F:POQ]DEMENDDAT=date$
      [F:POQ]DEMRCPDAT=date$
      [F:POQ]MON      =val(mid$([F:POQ]EXTRCPDAT,5,2))
      [F:POQ]YEA      =val(left$([F:POQ]EXTRCPDAT,4))
      [F:POQ]WEE      =week([F:POQ]EXTRCPDAT)
    Endif
    #----- Recherche du numéro de séquence -----#
    Call RECH_SEQ([F:POQ]POQSEQ)
    If [F:POQ]POQSEQ=0
      GOK=0 : WRET=1 : WMSG=mess(214,199,1)-[F:PND]POHNUM-num$([F:PND]POPLIN) : Return
    Endif
    If [F:POQ]DEMRCPDAT<date$  [F:POQ]LINSTA=2  Else  [F:POQ]LINSTA=1 : Endif
    Filter [POP] Where POHNUM=[F:POQ]POHNUM
&                    & POPLIN=[F:POQ]POPLIN
&                    & POPDAT>=[F:POQ]DEMRCPDAT
    Read [POP] POP1 First
    Filter [POP]
    If fstat
      GOK=0  : Call RSTA("POP",[F:POQ]POHNUM-num$([F:POQ]POPLIN)) From GLOCK
      WRET=1 : WMSG=mess(91,197,1)-[F:POQ]POHNUM-num$([F:POQ]POPLIN)
      Return
    Endif
    #----- Effacement de certaines zones des anciennes lignes -----#
    Raz [F:POQ]LINREVNUM,[F:POQ]RETQTYPUU,[F:POQ]RETQTYSTU,[F:POQ]RCPQTYPUU,
&       [F:POQ]RCPQTYSTU,[F:POQ]INVQTYPUU,[F:POQ]INVQTYSTU,
&       [F:POQ]WIPSTA,[F:POQ]WIPNUM,[F:POQ]LASRCPDAT,[F:POQ]LASINVDAT,
&       [F:POQ]LINRCPNBR,[F:POQ]LININVNBR,[F:POQ]INVRCPNBR,[F:POQ]FBUFLG,
&       [F:POQ]LINOCNDAT,[F:POQ]LINOCNNUM,[F:POQ]LINAMT,[F:POQ]LINATI,[F:POQ]LINATIAMT,
&       [F:POQ]PTHNUM,[F:POQ]PTDLIN,[F:POQ]SOHNUM,[F:POQ]SOPLIN,[F:POQ]SOQSEQ,
&       [F:POQ]PQHNUM,[F:POQ]PPDLIN,[F:POQ]OCNLIN,[F:POQ]OCNSEQ
    [F:POQ]LINCLEFLG=1 : [F:POQ]LININVFLG=1 : [F:POQ]LINPRNFLG=1
    [F:POQ]CMMNUM=""   : [F:POQ]RCPCLEFLG=1
    [F:POQ]WIPSTA=1
    #-----
    [F:POQ]QTYSTU=[F:PND]QTYSTU
    #----- Calcul quantité en unité d'achat -----#
    Call PCAL_QTY([F:POQ]QTYSTU,[F:POQ]STU,[F:POQ]QTYPUU,[F:POQ]PUU,
&                 [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
    #----- Calcul quantité en unité de commande -----#
    If [F:POQ]UOM=[F:POQ]STU
      [F:POQ]QTYUOM=[F:POQ]QTYSTU
    Elsif [F:POQ]UOM=[F:POQ]PUU
      [F:POQ]QTYUOM=[F:POQ]QTYPUU
    Else
      Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYUOM,[F:POQ]UOM,
&                   [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
    Endif
    #----- Si la qté en unité de commande est nulle prendre l'US -----#
    If [F:POQ]QTYUOM=0
      [F:POQ]UOM   =[F:POQ]STU
      [F:POQ]QTYUOM=[F:POQ]QTYSTU
      #----- Màj de l'indicateur d'unité et du coefficient UC-UA -----#
      If [F:POQ]UOM=[F:POQ]PUU
        [F:POQ]UOMFLG   =1
        [F:POQ]UOMPUUCOE=1
      Else
        [F:POQ]UOMFLG   =2
        Call PCAL_QTY([F:POQ]QTYUOM,[F:POQ]UOM,GBIDD1,[F:POQ]PUU,
&                     [F:POQ]ITMREF,[F:POQ]BPSNUM,1,[F:POQ]UOMPUUCOE) From TRTACHQTE1
      Endif
    Endif
    #-----
    [F:POQ]LINAMT=[F:POP]NETPRI*[F:POQ]QTYUOM
    Call ARRDEV([F:POQ]LINAMT,[F:POH]CUR) From TRTDIV
    VAT(0)=[F:POP]VAT(0) : WCLCAMT(1)=[F:POQ]CLCAMT1
    VAT(1)=[F:POP]VAT(1) : WCLCAMT(2)=[F:POQ]CLCAMT2
    VAT(2)=[F:POP]VAT(2) : WCLCAMT(3)=[F:POQ]CLCAMT3
    Call CLCTAXEMNT2([F:POQ]LINAMT,VAT,1,GSOCIETE,[F:POQ]ORDDAT,WCLCAMT,
&                    [F:POQ]LINATIAMT) From TRTX3
    Call ARRDEV([F:POQ]LINATIAMT,[F:POH]CUR) From TRTDIV
    [F:POQ]LINATI=[F:POQ]LINATIAMT
    If ([F:PND]STOMGTCOD>1 & [F:POQ]ORI<>2 & [F:PND]LINTYP<>4) | [F:PND]LINTYP=2
      Call NUMERO(GWIP,[F:POP]PRHFCY,[F:POQ]ORDDAT,"",[F:POQ]WIPNUM,STAT) From SUBANM
      If GOK<1 | STAT<>0
        WRET=1 : GOK=0 : WMSG=GWIP-mess(60,199,1) : Return
      Endif
      If [F:POH]BETFCY=2 & [F:POH]BETCPY<>2
        [F:POQ]WIPTYP=7 : [F:POQ]WIPSTA=1 : # type "TRF"
      Else
        [F:POQ]WIPTYP=2 : [F:POQ]WIPSTA=1 : # Type "POF"
      Endif
      [M:ORDK]MAJCOD    = "C"
      [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
      [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
      [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
      [M:ORDK]ITMREF    = [F:POQ]ITMREF
      [M:ORDK]ORIFCY    = [F:POQ]POHFCY
      [M:ORDK]STOFCY    = [F:POQ]PRHFCY
      [M:ORDK]PJT       = [F:POP]PJT
      [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
      [M:ORDK]STRDAT    = [F:POQ]ORDDAT
      [M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
      [M:ORDK]VCRTYP    = 14
      [M:ORDK]VCRNUM    = [F:POQ]POHNUM
      [M:ORDK]VCRLIN    = [F:POQ]POPLIN
      [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
      [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
      [M:ORDK]CPLQTY    = 0
      [M:ORDK]ALLQTY    = 0
      [M:ORDK]SHTQTY    = 0
      [M:ORDK]FMI       = 1
      [M:ORDK]MRPMES    = 1
      # Issue 71276 - 2015-02-27 by SR : Versions
      If dim([M:ORDK]ECCVALMAJ)> 0
        [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
        [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
      Endif
      # End issue 71276
      [M:ORDK]VCRTYPORI = 0
      [M:ORDK]VCRNUMORI = ""
      [M:ORDK]VCRLINORI = 0
      [M:ORDK]VCRSEQORI = 0
      [M:ORDK]BOMALT    = 0
      [M:ORDK]ORI       = 1
      [M:ORDK]ABBFIL="POC"
      Call WIP From TRTWIP
      If GOK<1
        WRET=1 : WMSG=mess(92,197,1)-num$([F:POQ]WIPTYP)-[F:POQ]WIPNUM-[F:POQ]ITMREF
        Return
      Endif
      # affectations v6
      Gosub MAJ_MTO_POQ From PURMTOLIB
    Endif
    [F:POQ]CREDAT = date$
    [F:POQ]CREUSR = GUSER
    [F:POQ]EXPNUM = [C]EXPORT
    #----- Mise à jour du budget (engagement) -----#
    Call PARAM([F:POH]POHFCY,"PURCMM",PARAM2)    From ADOVAL
    GPURCMM=val(PARAM2)
    Call PARAM([F:POH]POHFCY,"PURCMMDAT",PARAM2) From ADOVAL
    GPURCMMDAT=val(PARAM2)
    Call PARAM([F:POH]POHFCY,"BUDCTLPOH",PARAM2) From ADOVAL
    GBUDCTLPOH=val(PARAM2)
    Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,+1,2,"POQ",3,GBIDI1) From TRTACHDIV1
    If GOK<1
      WRET=1 : WMSG=mess(93,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN) : Return
    Endif
    #----- Ecriture de la ligne de commande PORDERQ -----#
    [F:POQ]CPY=GSOCIETE
    [F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&                +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
    Write [F:POQ]
    If fstat
      GOK=0  : Call FSTA("POQ") From GLOCK
      WRET=1 : WMSG=mess(91,197,1)-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
      Return
    Endif
    #----- Mise à jour de la qté en commande dans l'article-site -----#
    WTTVORD=[F:POH]TTVORD+[F:POQ]LINATIAMT
    Gosub MAJ_ITVMVS : If WRET   Return : Endif
    #----- Mise à jour de l'avance-retard des commandes ouvertes -----#
    Read [POC] POC0=[F:POH]POHNUM;[F:POQ]POPLIN
    If !fstat
      [F:POC]ORDQTYPUU += [F:POQ]QTYPUU
      [F:POC]ORDQTYSTU += [F:POQ]QTYSTU
      [F:POC]RTNQTYPUU += [F:POQ]QTYPUU
      [F:POC]RTNQTYSTU += [F:POQ]QTYSTU
      If [F:POQ]LINSTA=2
        [F:POC]EARQTY += [F:POQ]QTYPUU
      Endif
      Rewrite [F:POC]
      If fstat
        GOK=0  : Call FSTA("POC") From GLOCK
        WRET=1 : WMSG=mess(91,197,1)-[F:POH]POHNUM-num$([F:POQ]POPLIN)
        Return
      Endif
    Endif
    #--- Si pendant vente, créer la DL de vente
    If [F:POH]BETFCY=2 & [F:POH]SALFCY<>""
      Call CRE_SALLIG
      If GOK<1 | WRET=1 : Return : Endif
    Endif
    #-----
    WMSG=mess(51,197,1)-[F:POP]POHNUM+"/"+num$([F:POP]POPLIN)+"/"+num$([F:POQ]POQSEQ)-
&             mess(73,198,1)-[F:POH]BPSNUM-mess(14,195,1)-[F:POP]ITMREF
    Call ECR_TRACE(WMSG,0) From GESECRAN
  Endif
#------------------------------------------------------------#
# Création d'une nouvelle commande (Jamais pour cde ouverte) #
#------------------------------------------------------------#
Else
  [M:POI1]USR=GUSER
  nolign=[M:POI1]NBLIG+1
  If nolign=1
    [M:POI1]POHFCY=[F:PND]POHFCY
    [M:POI1]ORDDAT=date$
    GFCY = [M:POI1]POHFCY
    Call GETCPY(GFCY,"",0,"") From TRTX3CPT
    If GFINRSP="" GFINRSP=GFCY : Endif
    Call DEFRCPFCY(GFCY) From TRTACHDEF1
    Call GLOBVAR(GFCY)   From WWGLOBACH
    [M:POI1]BUY=GUSER
    [M:POI1]PRTFLG=1 : # Pas d'impression bon de commande
  Endif
  #----- Si commande d'origine existe encore, on initialise un maximum de rubriques -----#
  Read [POH] POH0=[F:PND]POHNUM
  If !fstat
    Read [POP] POP0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
    If !fstat
      Read [POQ] POQ0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
      If !fstat
        [M:POI1] = [F:POH]
        [M:POI1] = [F:POP]
        [M:POI1] = [F:POQ]
        Raz [M:POI1]RETQTYSTU(nolign-1),[M:POI1]SOHNUM(nolign-1),
&           [M:POI1]SOPLIN(nolign-1), [M:POI1]SOQSEQ(nolign-1)
        [M:POI1]ORDDAT = date$
        [M:POI1]EXTRCPDAT(nolign-1) = date$
        [M:POI1]RETRCPDAT(nolign-1) = date$
        #------ La devise est-elle toujours valide ??? -----#
        Call CONTDEV([M:POI1]CUR(nolign-1),[M:POI1]ORDDAT) From TRTDEV
        If mkstat
          Raz GMESSAGE, mkstat
          Read [BPS] BPS0=[M:POI1]BPSNUM(nolign-1)
          If fstat
            Raz [F:BPS] : WRET=1 : WMSG=[M:POI1]BPSNUM(nolign-1)-":"-mess(136,100,1)
            Return
          Endif
          Read [BPR] BPR0=[M:POI1]BPSNUM(nolign-1)
          If fstat
            Raz [F:BPR] : WRET=1 : WMSG=[M:POI1]BPSNUM(nolign-1)-":"-mess(136,100,1)
            Return
          Endif
          [M:POI1]CUR(nolign-1)=[F:BPS]CUR
          Gosub CONVERSION_LIG
        Endif
        [M:POI1]STOMGTCOD(nolign-1)=[F:PND]STOMGTCOD
        [M:POI1]QTYSTU(nolign-1)=[F:PND]QTYSTU
        #----- Calcul quantité en unité d'achat -----#
        Call PCAL_QTY([M:POI1]QTYSTU(nolign-1),[M:POI1]STU(nolign-1),
&                     [M:POI1]QTYPUU(nolign-1),[M:POI1]PUU(nolign-1),
&                     [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
        #----- Calcul quantité en unité de commande -----#
        If [M:POI1]UOM(nolign-1)=[M:POI1]STU(nolign-1)
          [M:POI1]QTYUOM(nolign-1)=[M:POI1]QTYSTU(nolign-1)
        Elsif [M:POI1]UOM(nolign-1)=[M:POI1]PUU(nolign-1)
          [M:POI1]QTYUOM(nolign-1)=[M:POI1]QTYPUU(nolign-1)
        Else
          Call PCAL_QTY([M:POI1]QTYPUU(nolign-1),[M:POI1]PUU(nolign-1),
&                       [M:POI1]QTYUOM(nolign-1),[M:POI1]UOM(nolign-1),
&                       [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
        Endif
        #----- Si la qté en unité de commande est nulle prendre l'US -----#
        If [M:POI1]QTYUOM(nolign-1)=0
          [M:POI1]UOM(nolign-1)   =[M:POI1]STU(nolign-1)
          [M:POI1]QTYUOM(nolign-1)=[M:POI1]QTYSTU(nolign-1)
          #----- Màj de l'indicateur d'unité et du coefficient UC-UA -----#
          If [M:POI1]UOM(nolign-1)=[M:POI1]PUU(nolign-1)
            [M:POI1]UOMFLG(nolign-1)   =1
            [M:POI1]UOMPUUCOE(nolign-1)=1
          Else
            [M:POI1]UOMFLG(nolign-1)   =2
            Call PCAL_QTY([M:POI1]QTYUOM(nolign-1),[M:POI1]UOM(nolign-1),
&                         GBIDD1,[M:POI1]PUU(nolign-1),[F:POQ]ITMREF,
&                         [F:POQ]BPSNUM,1,[M:POI1]UOMPUUCOE(nolign-1)) From TRTACHQTE1
          Endif
        Endif
        #-----
        [M:POI1]VAT1(nolign-1) = [F:POP]VAT(0)
        [M:POI1]VAT2(nolign-1) = [F:POP]VAT(1)
        [M:POI1]VAT3(nolign-1) = [F:POP]VAT(2)
        VAT(0)=[F:POP]VAT(0) : WCLCAMT(1)=[F:POQ]CLCAMT1
        VAT(1)=[F:POP]VAT(1) : WCLCAMT(2)=[F:POQ]CLCAMT2
        VAT(2)=[F:POP]VAT(2) : WCLCAMT(3)=[F:POQ]CLCAMT3
        Goto SUITPOI
      Endif
    Endif
  Endif
  #----- La commande n'existe plus, on remplit le masque POI1 -----#
  [M:POI1]BPSNUM   (nolign-1) = [F:PNH]BPSNUM
  [M:POI1]ITMREF   (nolign-1) = [F:PND]ITMREF
  [M:POI1]ITMDES   (nolign-1) = [F:PND]ITMDES
  [M:POI1]ITMDES1  (nolign-1) = [F:PND]ITMDES1
  [M:POI1]PRHFCY   (nolign-1) = [F:PND]PNHFCY
  [M:POI1]STOMGTCOD(nolign-1) = [F:PND]STOMGTCOD
  [M:POI1]LINTYP   (nolign-1) = [F:PND]LINTYP
  If [F:ITF]ITMREF<>[F:PND]ITMREF | [F:ITF]STOFCY<>[F:PND]PNHFCY
    Read [ITF] ITF0=[F:PND]ITMREF;[F:PND]PNHFCY : If fstat  Raz [F:PND] : Endif
  Endif
  If [F:ITF]QUAFLG>1 [M:POI1]QUAFLG(nolign-1)=2 Else [M:POI1]QUAFLG(nolign-1)=1 : Endif
  #----- Lecture article si nécessaire -----#
  If [F:ITM]ITMREF<>[M:POI1]ITMREF(nolign-1)
    Read [ITM] ITM0=[M:POI1]ITMREF(nolign-1)
    If fstat
      Raz [F:ITM] : WRET=1 : WMSG=[M:POI1]ITMREF(nolign-1)-":"-mess(136,100,1) : Return
    Endif
  Endif
  #----- Lecture article-site de commande -----#
  If [F:ITF]ITMREF<>[M:POI1]ITMREF(nolign-1) | [F:ITF]STOFCY<>[M:POI1]POHFCY
    Read [ITF] ITF0=[M:POI1]ITMREF(nolign-1);[M:POI1]POHFCY
    If fstat  Raz [F:ITF] : Endif
  Endif
  #----- Chargement code acheteur de la ligne -----#
  If [F:ITM]BUY<>"" [M:POI1]LINBUY(nolign-1)=[F:ITM]BUY : Endif
  If [F:ITF]BUY<>"" [M:POI1]LINBUY(nolign-1)=[F:ITF]BUY : Endif
  #----- Lecture article-fournisseur si nécessaire -----#
  If [F:ITP]ITMREF<>[M:POI1]ITMREF(nolign-1) | [F:ITP]BPSNUM<>[M:POI1]BPSNUM(nolign-1)
    Read [ITP] ITP0=[M:POI1]ITMREF(nolign-1);[M:POI1]BPSNUM(nolign-1)
    If fstat  Raz [F:ITP] : Endif
    If [F:ITP]QUAFLG>1
      [M:POI1]QUAFLG(nolign-1)=2
    Else
      [M:POI1]QUAFLG(nolign-1)=1
    Endif
  Endif
  #-----
  If GACTDEB=2  [M:POI1]EECINCRAT(nolign-1)=[F:ITP]EECINCRAT : Endif
  [M:POI1]ORICRY   (nolign-1) = [F:PND]ORICRY
  [M:POI1]UOM      (nolign-1) = [F:PND]UOM
  [M:POI1]QTYUOM   (nolign-1) = [F:PND]QTYUOM
  [M:POI1]STU      (nolign-1) = [F:PND]STU
  [M:POI1]QTYSTU   (nolign-1) = [F:PND]QTYSTU
  [M:POI1]PUU      (nolign-1) = [F:PND]PUU
  [M:POI1]QTYPUU   (nolign-1) = [F:PND]QTYPUU
  [M:POI1]UOMPUUCOE(nolign-1) = [F:PND]UOMPUUCOE
  [M:POI1]UOMFLG   (nolign-1) = [F:PND]UOMFLG
  #-----
  Read [BPS] BPS0=[M:POI1]BPSNUM(nolign-1)
  If fstat
    Raz [F:BPS] : WRET=1 : WMSG=[M:POI1]BPSNUM(nolign-1)-":"-mess(136,100,1) : Return
  Endif
  Read [BPR] BPR0=[M:POI1]BPSNUM(nolign-1)
  If fstat
    Raz [F:BPR] : WRET=1 : WMSG=[M:POI1]BPSNUM(nolign-1)-":"-mess(136,100,1) : Return
  Endif
  [M:POI1]CUR   (nolign-1) = [F:BPS]CUR
  [M:POI1]CHGTYP(nolign-1) = [F:BPS]CHGTYP
  Call COURSITE([M:POI1]CUR(nolign-1),GFCY,[M:POI1]CHGTYP(nolign-1),
&               [M:POI1]ORDDAT,[M:POI1]CHGCOE(nolign-1),I) From TRTDEV
  If [F:ITM]ITMREF<>[F:POP]ITMREF
    Read [ITM] ITM0=[F:POP]ITMREF : If fstat  Raz [F:ITM] : Endif
  Endif
  Call ALIVATCOD(2,[M:POI1]BPSNUM(nolign-1),[F:ITM]ITMREF,"POI1",nolign-1) From TRTX3
  [M:POI1]PJT (nolign-1) = [F:PND]PJT
  #----- Initialisation des comptes et du type d'achat -----#
  If [M:POI1]LINACC1(nolign-1)="" & [M:POI1]LINACC2(nolign-1)="" & [M:POI1]LINACC3(nolign-1)=""
    Call INIT_COMPTES_LIGNE(nolign-1) From SUBPOI
  Endif
  If [M:POI1]LINPURTYP(nolign-1)=0
    Call D_LINPURTYP([M:POI1]LINPURTYP(nolign-1)) From SUBPOI
  Endif
  #----- Initialisation des sections analytiques -----#
  For I=1 To GNBDIE
    If evalue("[M:POI1]CCE"+num$(I)+"(nolign-1)")=""
      Call INIT_CCE(SECTION,I,"POID","[M:POI1]LINACC",nolign-1) From TRTX3CPT
      Assign "[M:POI1]CCE"+num$(I)+"(nolign-1)" With SECTION
    Endif
  Next I
  #----- Chargement paramètres et libellés colonnes tarifs -----#
  If GPLISTC<>[F:BPS]PLISTC
    GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
    Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Endif
  #----- La date du besoin est la date du jour -----#
  [M:POI1]RETRCPDAT(nolign-1)=date$
  Call RECH_TARIF ("POI",nolign-1) From TRTACHTAR1
  #----- Si prix à 0, on récupère le prix unitaire du retour
  If [M:POI1]NETPRI(nolign-1)=0  [M:POI1]NETPRI(nolign-1)=[F:PND]NETPRIPUU : Endif
  #----- Si date de rcp prévue < date du besoin -----#
  If [M:POI1]EXTRCPDAT(nolign-1)<[M:POI1]RETRCPDAT(nolign-1)
    [M:POI1]EXTRCPDAT(nolign-1)=[M:POI1]RETRCPDAT(nolign-1)
  Endif
$SUITPOI
  [M:POI1]ORDFCY(nolign-1)=[M:POI1]POHFCY
  If dim([M:POI1]TSICOD1(nolign-1))>0 [M:POI1]TSICOD1(nolign-1)=[F:ITM]TSICOD(0) : Endif
  If dim([M:POI1]TSICOD2(nolign-1))>0 [M:POI1]TSICOD2(nolign-1)=[F:ITM]TSICOD(1) : Endif
  If dim([M:POI1]TSICOD3(nolign-1))>0 [M:POI1]TSICOD3(nolign-1)=[F:ITM]TSICOD(2) : Endif
  If dim([M:POI1]TSICOD4(nolign-1))>0 [M:POI1]TSICOD4(nolign-1)=[F:ITM]TSICOD(3) : Endif
  If dim([M:POI1]TSICOD5(nolign-1))>0 [M:POI1]TSICOD5(nolign-1)=[F:ITM]TSICOD(4) : Endif
  [M:POI1]LINAMT(nolign-1)=[M:POI1]NETPRI(nolign-1)*[M:POI1]QTYUOM(nolign-1)
  Call ARRDEV([M:POI1]LINAMT(nolign-1),[M:POI1]CUR(nolign-1)) From TRTDIV
  Call CLCTAXEMNT2([M:POI1]LINAMT(nolign-1),VAT,1,GSOCIETE,[M:POI1]ORDDAT,WCLCAMT,
&                  [M:POI1]LINATIAMT(nolign-1)) From TRTX3
  Call ARRDEV([M:POI1]LINATIAMT(nolign-1),[M:POI1]CUR(nolign-1)) From TRTDIV
  [M:POI1]NBLIG=nolign
Endif
$FIN_MAJ
#------------------------------------------------------------------------------#
# Point d'entrée pour mises à jour complémentaires à la validation des retours #
# ---------------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                                  #
#                                                                              #
# NUMRET  : Numéro du retour en cours de traitement                            #
# LINRET  : Ligne  du retour en cours de traitement                            #
# MAJFLG  : Indicateur de mise à jour                                          #
#           1 = Non, pas de réintégration en commande                          #
#           2 = Oui, réintégration en commande sur la même ligne               #
#           3 = Oui, réintégration en commande sur une autre ligne             #
#           4 = Oui, réintégration en commande sur une autre commande          #
# Les classes [F:PNH], [F:PND] et [F:ITM] sont disponibles                     #
# Nous sommes à l'intérieur d'une boucle For Next fichier PRETURND [PND]       #
# Nous sommes à l'intérieur d'une transaction de màj Trbegin-Commit            #
# Abandon de la transaction en positionnant le GOK à 0                         #
#------------------------------------------------------------------------------#
NUMRET=[F:PNH]PNHNUM
LINRET=[F:PND]PNDLIN
MAJFLG=[F:PND]ORDFLG
SAVXZSNOL=nolign

# BRBAN 08-07-2014 SAM#93745 US2
Local Integer PORDIGSIGN : [L]PORDIGSIGN = func PORLEGLIB.DIGSIGN("", [F:PNH]PNHFCY)

If [L]PORDIGSIGN=1
  If find([F:TPN]RECTYP,2,3,4)
    If [F:PNH]MANDOCR=''
      If GTRACE = ''
        If find([F:TPN]RECTYP,2,3)
          GMESSAGE=mess(128,7711,1) #Should fill the manual/backup document number.
        Else #4
          GMESSAGE=mess(196,7711,1) #Should fill the manual document field with the external document number.
        Endif
        GERR= 1
        GOK = 0
      Else
        If find([F:TPN]RECTYP,2,3)
          Call ECR_TRACE(mess(128,7711,1),1) From GESECRAN #Should fill the manual/backup document number.
        Else #4
          Call ECR_TRACE(mess(196,7711,1),1) From GESECRAN #Should fill the manual document field with the external document number.
        Endif
        GOK = 0
      Endif
    Endif
  Endif
Endif

If GOK<1 WRET=1 : Endif

GPOINT="MAJVALRET" : Gosub ENTREE From EXEFNC
nolign=SAVXZSNOL
If GOK<1 WRET=1 : Endif
Return


#############################################
# Mise à jour de l'en commande article-site #
#############################################
$MAJ_ITVMVS
If [F:POQ]WIPNUM<>""
  Readlock [ITV] ITV0=[F:PND]ITMREF;[F:PNH]PNHFCY
  If fstat
    GOK=0 : WRET=1 : WMSG=mess(94,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN) : Return
  Endif
  [F:ITV]ORDSTO+=[F:PND]QTYSTU
  Rewrite [ITV]
  If fstat
    GOK=0 : WRET=1 : WMSG=mess(94,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN) : Return
  Endif
Endif
#------------------------------------------#
# Mise à jour de l'en commande fournisseur #
#------------------------------------------#
If [F:POQ]QTYPUU<>0
  #----- Lecture devise commande pour arrondi -----#
  If !clalev([F:TCU])  Local File TABCUR [TCU] : Endif
  If [F:TCU]CUR<>[F:POH]CUR
    Read [TCU] TCU0=[F:POH]CUR : If fstat [F:TCU]CURRND=0.01 : Endif
  Endif
  #-----
  WQTY=min(max([F:POQ]QTYPUU-max([F:POQ]RCPQTYPUU,[F:POQ]INVQTYPUU),0),[F:PND]QTYPUU)
  WORDNOT=arr([F:POQ]LINAMT*WQTY/[F:POQ]QTYPUU,[F:TCU]CURRND)
  WORDATI=arr([F:POQ]LINATI*WQTY/[F:POQ]QTYPUU,[F:TCU]CURRND)
  Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [F:POH]POHNUM,WORDNOT,WORDATI,WTTVORD) From TRTBPMVT
  If GOK<1
    GOK=0 : WRET=1 : WMSG=mess(95,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN) : Return
  Endif
Endif
Return


#---------------------------------------------------------------------#
# Appel du S/P ventes pour création de la ligne quantité (SORDERQ) et #
# récupération du numéro de séquence ventes pour maj dans le PORDERQ  #
#---------------------------------------------------------------------#
Subprog CRE_SALLIG
If !clalev ([M:SORW])  Local Mask SORW   [SORW] : Endif : # Pour màj contrat ventes
Raz [M:SORW]
[M:SORW]MAJCOD    = "C"
[M:SORW]SOHNUM    = [F:POH]OCNNUM
[M:SORW]SALFCY    = [F:POH]SALFCY
[M:SORW]BPCORD    = [F:POH]BPCORD
[M:SORW]STOFCY    = [F:POQ]LINSTOFCY
[M:SORW]PRHFCY    = [F:POQ]PRHFCY
[M:SORW]VLYDATCON = [F:POH]ENDDAT
[M:SORW]POHNUM    = [F:POQ]POHNUM
[M:SORW]SOPLIN    = [F:POC]POPLIN
[M:SORW]ITMREF    = [F:POC]ITMREF
[M:SORW]VLYDATITM = [F:POC]ENDDAT
[M:SORW]EXTQTY    = [F:POC]EXTQTYPUU
[M:SORW]SAU       = [F:POC]PUU
[M:SORW]POPLIN    = [F:POC]POPLIN
[M:SORW]DEMDLVDAT = [F:POQ]DEMRCPDAT
[M:SORW]QTY       = [F:POQ]QTYPUU
[M:SORW]DEMSTA    = [F:POQ]WIPSTA
[M:SORW]USEPLC    = [F:POQ]USEPLC
[M:SORW]CAD       = [F:POQ]CAD
If [F:POQ]CAD=1
  [M:SORW]DLVDAY  = val(left$(num$([F:POQ]DEMRCPDAT),2))
  [M:SORW]MON     = [F:POQ]MON
  [M:SORW]YEA     = [F:POQ]YEA
Elsif [F:POQ]CAD=2
  [M:SORW]WEE     = [F:POQ]WEE
  [M:SORW]YEA     = [F:POQ]YEA
Else
  [M:SORW]MON     = [F:POQ]MON
  [M:SORW]YEA     = [F:POQ]YEA
Endif
[M:SORW]POQSEQ    = [F:POQ]POQSEQ
[M:SORW]SOQSTA    = [F:POQ]LINSTA
# 95742 : PJT en inter société/inter site : (LD:21/04/16)
# Le PJT transite uniquement en intersite
If [F:POH]BETCPY=1
    [M:SORW]PJT=[F:POC]PJT
Endif
# 95742 : PJT en inter société/inter site : (LD:21/04/16)
Call MAJ_SOQ From TRTVENMSIT
If GMESSAGE<>"" | GOK<1
  WRET=1 : End
Endif
Update [POQ] Where POHNUM=[M:SORW]POHNUM & POPLIN=[M:SORW]SOPLIN & POQSEQ=[M:SORW]POQSEQ
&             With OCNLIN=[M:SORW]SOPLIN, OCNSEQ=[M:SORW]SOQSEQ
If fstat GOK = 0 : Call FSTA("POQ") From GLOCK : GOK=0 : Return : Endif
[F:POQ]OCNLIN=[M:SORW]SOPLIN
[F:POQ]OCNSEQ=[M:SORW]SOQSEQ
End


######################################################
# Recalcul tarif ligne : Prix, remises               #
# Si nouvelle devise différente de l'ancienne devise #
######################################################
$CONVERSION_LIG
Local Decimal  MT1, MT2, DISCRGVAL(0..8)
Local Integer  I, J
I=nolign-1
Call CONVERT2([F:POH]CUR,[M:POI1]CUR(I),GLOCALDEV,[M:POI1]CHGTYP(I),[M:POI1]ORDDAT,
&             [M:POI1]GROPRI(I),MT2,GBIDI1) From TRTDEV
[M:POI1]GROPRI(I)=arr(MT2,10^-GDECPRI)
For J=1 To 9
  If evalue ("DIM([M:POI1]DISCRGVAL"+num$(J)+"(I))")>0
    If GFMTREM(J-1)="M"
      MT1=evalue ("[M:POI1]DISCRGVAL"+num$(J)+"(I)")
      Call CONVERT([F:POH]CUR,[M:POI1]CUR(I),GLOCALDEV,[M:POI1]CHGTYP(I),[M:POI1]ORDDAT,
&                  MT1,MT2,GBIDI1) From TRTDEV
      Assign "[M:POI1]DISCRGVAL"+num$(J)+"(I)" With MT2
    Endif
    DISCRGVAL(J-1)=evalue ("[M:POI1]DISCRGVAL"+num$(J)+"(I)")
  Endif
Next
If dim(GCALNETLIN)>0  GCALNETLIN=I+1        : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:POI1]" : Endif
Call CALNET(2,[F:BPS]PLISTC,[M:POI1]GROPRI(I),DISCRGVAL,[M:POI1]QTYUOM(I),
&             [M:POI1]NETPRI(I),[M:POI1]CUR) From TRTPRICE
Return


#####################################
# Ajout de ligne commande classique #
#####################################
Subprog AJOUT_LIGNE
Local Integer I
If !clalev([M:PMG])  Local Mask PURMGT [PMG] : Endif
Raz [M:PMG]
[M:PMG]MAJCOD="L"
[M:PMG]TRAFLG=2
[M:PMG]NBLIG=1
[M:PMG]ITMREF   (0)=[F:PND]ITMREF
[M:PMG]STOFCY   (0)=[F:PND]PNHFCY
[M:PMG]VCRTYP   (0)=14
[M:PMG]VCRNUM   (0)=[F:PND]POHNUM
[M:PMG]VCRLIN   (0)=[F:PND]POPLIN
[M:PMG]VCRSEQ   (0)=[F:PND]POQSEQ
[M:PMG]ENDDAT   (0)=[F:POQ]EXTRCPDAT
[M:PMG]STU      (0)=[F:PND]STU
[M:PMG]EXTSTUQTY(0)=[F:PND]QTYSTU
[M:PMG]PUU      (0)=[F:PND]PUU
[M:PMG]EXTPUUQTY(0)=[F:PND]QTYPUU
I=0 : Gosub MODIF_POH From TRTACHPOH2
End


#####################################################
# Recherche du numéro de séquence de la nouvelle DL #
# ------------------------------------------------- #
# La classe [F:POH] est chargée                     #
# La classe [F:POQ] contient la nouvelle DL à créer #
# Ce sous-programme charge WPOQSEQ                  #
#####################################################
Subprog RECH_SEQ(WPOQSEQ)
Variable Integer WPOQSEQ
#-----
Local Integer  WSEQPREC, WSEQSUIV, WDELTA
Local Integer  WSTART, WSUPPL, WFLAG
Local Integer  WDELTA_JOUR, WDELTA_SEQ
Local Date     WDATDEB1, WDATDEB2, WDATFIN2
Local Char     CLEFIC(40)
#-----
Gosub POINT_SEQDEMDLV From TRTX3 : # Point d'entrée permettant d'ajuster le pas du séquencement
#-----
Raz WSEQPREC, WSEQSUIV, WDELTA, WPOQSEQ, GMESSAGE
Raz WSTART, WSUPPL, WDATDEB1, WDATDEB2, WDATFIN2, WFLAG
#----- Lecture de la ligne article du contrat si nécessaire -----#
If [F:POC]POHNUM<>[F:POQ]POHNUM | [F:POC]POPLIN<>[F:POQ]POPLIN
  Read [POC] POC0=[F:POQ]POHNUM;[F:POQ]POPLIN : If fstat  Raz [F:POC] : Endif
Endif
#----- Recherche de la DL précédente -----#
Filter [POQW] Where POHNUM=[F:POQ]POHNUM
&                 & POPLIN=[F:POQ]POPLIN
&                 & EXTRCPDAT<=[F:POQ]DEMENDDAT
Read [POQW] POQ0 Last
Filter [POQW]
If !fstat
  WSEQPREC=[F:POQW]POQSEQ
  WSTART  =[F:POQW]POQSEQ
  WDATDEB2=[F:POQW]DEMRCPDAT
  While [F:POQW]DEMRCPDAT=WDATDEB2
    Read [POQW] POQ0 Prev
    If !fstat
      If [F:POQW]DEMRCPDAT=WDATDEB2  WSTART=[F:POQW]POQSEQ : Endif
    Else
      Raz [F:POQW]
    Endif
  Wend
Else
  WDATDEB2=min(date$-1,[F:POQ]DEMRCPDAT)
Endif
WDATDEB1=WDATDEB2
#----- Si valeur maxi pas d'insertion possible -----#
If WSEQPREC=99999999  Raz WPOQSEQ : End : Endif
#----- Recherche de la DL suivante -----#
Filter [POQW] Where POHNUM=[F:POQ]POHNUM
&                 & POPLIN=[F:POQ]POPLIN
&                 & EXTRCPDAT>[F:POQ]DEMENDDAT
Read [POQW] POQ0 First
Filter [POQW]
If !fstat
  WSEQSUIV=[F:POQW]POQSEQ
  WDATFIN2=[F:POQW]DEMRCPDAT
  #----- Si la date est identique, il faut repousser la numérotation -----#
  If [F:POQW]DEMRCPDAT=[F:POQ]DEMRCPDAT
    WSUPPL=STEP2
  Endif
  #-----
  WDELTA_JOUR=WDATFIN2-WDATDEB2
  WDELTA_SEQ =WSEQSUIV-WSEQPREC
  #----- L'intervalle dispo n'est pas suffisant pour la numérotation optimisée -----#
  If WSEQSUIV-(WSTART+WSUPPL)<WDELTA_JOUR*STEP1 | WDELTA_SEQ<STEP2*2
    #----- Toutes les DL postérieures sont-elles supprimables ? -----#
    Raz mkstat
    For [POQW] POQ0 Where POHNUM=[F:POQ]POHNUM
&                       & POPLIN=[F:POQ]POPLIN
&                       & EXTRCPDAT>[F:POQ]DEMENDDAT
&                   With Stability
      If [F:POQW]LINSTA=3 | [F:POQW]INVQTYPUU<>0 | [F:POQW]INVQTYSTU<>0
        mkstat=1 : Break
      Endif
      If [F:POH]BETFCY=2 & [F:POH]SALFCY<>""
        If !clalev ([M:SORW])  Local Mask SORW [SORW] : Endif
        Raz [M:SORW]
        [M:SORW]MAJCOD = "A"
        [M:SORW]SOHNUM = [F:POQW]LINOCNNUM
        [M:SORW]SOPLIN = [F:POQW]OCNLIN
        [M:SORW]SOQSEQ = [F:POQW]OCNSEQ
        Call CTL_MAJ_SOQ From TRTVENMSIT
        If GMESSAGE<>"" mkstat=1 : Break : Endif
      Endif
    Next
    If !mkstat
      If !clalev ([M:PSO])  Local File PREQUISO [PSO] : Endif
      WPOQSEQ=WSEQPREC-mod(WSEQPREC,STEP2)+WSUPPL
      For [POQW] POQ0 Where POHNUM=[F:POQ]POHNUM
&                         & POPLIN=[F:POQ]POPLIN
&                         & EXTRCPDAT>[F:POQ]DEMENDDAT
&                     With Stability
        CLEFIC=[F:POQW]POHNUM-num$([F:POQW]POPLIN)-num$([F:POQW]POQSEQ)
        Readlock [POQW] Curr
        If fstat=1
          GOK=-1 : GLOCK="$PORDERQ"-CLEFIC : Break
        Elsif fstat
          GOK=0  : Call RSTA("POQ",CLEFIC) From GLOCK : Break
        Endif
        WDELTA_JOUR=[F:POQW]DEMRCPDAT-WDATDEB2
        If WDELTA_JOUR>0
          WPOQSEQ =max(WSTART+(WDELTA_JOUR*STEP1),WPOQSEQ+STEP2)
          WDATDEB2=[F:POQW]DEMRCPDAT
          WSTART  =WPOQSEQ
        Else
          WPOQSEQ+=STEP2
        Endif
        #----- Mise à jour encours avec nouvelle séquence -----#
        CLEFIC=num$([F:POQW]WIPTYP)-[F:POQW]WIPNUM-[F:POQW]ITMREF
        Update [ORD] Where WIPTYP=[F:POQW]WIPTYP & WIPNUM=[F:POQW]WIPNUM & ITMREF=[F:POQW]ITMREF
&                    With  VCRSEQ=WPOQSEQ
        If fstat=1
          GLOCK="$ORDERS"-CLEFIC : GOK=-1 : Break
        Elsif fstat
          Call RSTA("ORD",CLEFIC) From GLOCK : GOK=0 : Break
        Endif
        #----- Mise à jour fichier liens demande-commande -----#
        CLEFIC=[F:POQW]POHNUM-num$([F:POQW]POPLIN)-num$([F:POQW]POQSEQ)
        Update [PSO] Where POHNUM=[F:POQW]POHNUM & POPLIN=[F:POQW]POPLIN & POQSEQ=[F:POQW]POQSEQ
&                    With  POQSEQ=WPOQSEQ
        If fstat=1
          GLOCK="$PREQUISO"-CLEFIC : GOK=-1 : Break
        Elsif fstat
          Call RSTA("PSO",CLEFIC) From GLOCK  : GOK=0 : Break
        Endif
        #----- Chargement nouvelle séquence -----#
        [F:POQW]POQSEQ=WPOQSEQ
        [F:POQW]POQLNK= mid$("00000000",1,8-len(num$([F:POQW]POPLIN)))+num$([F:POQW]POPLIN)
&                      +mid$("00000000",1,8-len(num$([F:POQW]POQSEQ)))+num$([F:POQW]POQSEQ)
        #----- Suppression ligne quantité (SORDERQ) -----#
        If [F:POH]SALFCY<>"" & [F:POQW]OCNLIN<>0
          Raz [M:SORW]
          [M:SORW]MAJCOD   = "A"
          [M:SORW]SOHNUM   = [F:POQW]LINOCNNUM
          [M:SORW]SOPLIN   = [F:POQW]OCNLIN
          [M:SORW]SOQSEQ   = [F:POQW]OCNSEQ
          Call MAJ_SOQ From TRTVENMSIT : If GOK<1  Break : Endif
          #----- Recréation ligne quantité avec nouvelle séquence (SORDERQ) -----#
          Raz [M:SORW]
          [M:SORW]MAJCOD   ="C"
          [M:SORW]SOHNUM   =[F:POH]OCNNUM
          [M:SORW]SALFCY   =[F:POH]SALFCY
          [M:SORW]BPCORD   =[F:POH]BPCORD
          [M:SORW]STOFCY   =[F:POQW]LINSTOFCY
          [M:SORW]PRHFCY   =[F:POQW]PRHFCY
          [M:SORW]VLYDATCON=[F:POH]ENDDAT
          [M:SORW]POHNUM   =[F:POH]POHNUM
          [M:SORW]SOPLIN   =[F:POQ]POPLIN
          [M:SORW]ITMREF   =[F:POQ]ITMREF
          [M:SORW]VLYDATITM=[F:POC]ENDDAT
          [M:SORW]EXTQTY   =[F:POC]EXTQTYPUU
          [M:SORW]SAU      =[F:POQ]PUU
          [M:SORW]POPLIN   =[F:POQ]POPLIN
          [M:SORW]DEMDLVDAT=[F:POQW]DEMRCPDAT
          [M:SORW]QTY      =[F:POQW]QTYPUU
          [M:SORW]DEMSTA   =[F:POQW]WIPSTA
          [M:SORW]USEPLC   =[F:POQW]USEPLC
          [M:SORW]CAD      =[F:POQW]CAD
          If [F:POQW]CAD=1
            [M:SORW]DLVDAY =val(left$(num$([F:POQW]DEMRCPDAT),2))
            [M:SORW]MON    =[F:POQW]MON
            [M:SORW]YEA    =[F:POQW]YEA
          Elsif [F:POQW]CAD=2
            [M:SORW]WEE    =[F:POQW]WEE
            [M:SORW]YEA    =[F:POQW]YEA
          Else
            [M:SORW]MON    =[F:POQW]MON
            [M:SORW]YEA    =[F:POQW]YEA
          Endif
          [M:SORW]POQSEQ   =[F:POQW]POQSEQ
          [M:SORW]SOQSTA   =[F:POQW]LINSTA
          # 95742 : PJT en inter société/inter site : (LD:21/04/16)
          # Le PJT transite uniquement en intersite
          If [F:POH]BETCPY=1
              [M:SORW]PJT=[F:POC]PJT
          Endif
          # 95742 : PJT en inter société/inter site : (LD:21/04/16)
          Call MAJ_SOQ From TRTVENMSIT : If GOK<1  Break : Endif
          [F:POQW]LINOCNNUM=[F:POH]OCNNUM
          [F:POQW]OCNLIN=[M:SORW]SOPLIN
          [F:POQW]OCNSEQ=[M:SORW]SOQSEQ
        Endif
        #----- Réécriture ligne DL avec nouvelle séquence -----#
        Rewrite [POQW]
        If fstat  GOK=0 : Call FSTA("POQ") From GLOCK : Break : Endif
        #-----
        Raz GMESSAGE
      Next
      If GOK<1  Raz WPOQSEQ : End : Endif
    Else
      Raz mkstat, GMESSAGE : WFLAG=1
    Endif
  Endif
Endif
#----- Attribution du numéro de séquence pour nouvelle ligne -----#
If !WSEQPREC & !WSEQSUIV  WPOQSEQ=1000 : End : Endif
WDELTA_JOUR=[F:POQ]DEMRCPDAT-WDATDEB1
If !WFLAG
  #----- Numérotation optimisée -----#
  If WDELTA_JOUR>0
    WPOQSEQ=max(WSTART+(WDELTA_JOUR*STEP1),WSEQPREC-mod(WSEQPREC,STEP2)+STEP2)
  Else
    WPOQSEQ=WSEQPREC-mod(WSEQPREC,STEP2)+STEP2
  Endif
Else
  #----- Numérotation minimale -----#
  WDELTA=int(WDELTA_SEQ/max(WDELTA_JOUR+1,2))
  If WDELTA=0  Raz WPOQSEQ : End : Endif
  If WDELTA_JOUR>0
    WPOQSEQ=WSEQPREC+(WDELTA_JOUR*WDELTA)
  Else
    WPOQSEQ=WSEQPREC+min(STEP2,WDELTA)
  Endif
Endif
End
######################################################################################
######################################################################################
$DIGSIGN
#85785
#signature variables
Local Char    CURTIM          : [L]CURTIM = time$
Local Date    CURDAT          : [L]CURDAT = date$
Local Char    MESSTOSIGN(250)
Local Decimal CURRAT

[L]MESSTOSIGN = format$("D:YYYY[-]MM[-]DD",[F:PNH]RTNDAT) + ";" + format$("D:YYYY[-]MM[-]DD",[L]CURDAT) + "T" + [L]CURTIM + ";" + [F:PNH]PNHTYP-[F:PNH]PNHNUM + ";" +
& ctrans(vireblc(format$("N20.2",0),4),",",".") + ";"
Call SIGNDOC_NEW ([F:PNH]PNHNUM, 9, [F:PNH]PNHTYP,[L]MESSTOSIGN,[L]WCPT,[F:PNH]RTNDAT,
&             [L]CURDAT,[L]CURTIM,[F:TPN]RECTYP,[F:TPN]SAFTTRNTYP,WRET)                           From DKSLIB

Return
######################################################################################
######################################################################################
$CTRL_CHRONOLOGIC
#85785
Local Integer SEQ
Local Char    DOCNUM(GLONVCR) : DOCNUM=[L]LNUM
If clalev([F:PNHB])=0 Local File PRETURN [F:PNHB] Endif

Repeat
 Call NUMERO_PREC(WCPT,[F:PNH]PNHFCY,[F:PNH]RTNDAT,"",[L]DOCNUM,SEQ,WRET) From SUBANM
 If WRET<>0
    GMESSAGE = WCPT-DOCNUM-mess(60,199,1) : GOK=0 : Break
 Endif
 If SEQ>=1
    Read [F:PNHB]PNH0=DOCNUM
    If !fstat
       If [F:PNHB]RTNDAT>[F:PNH]RTNDAT
          GOK=0 :GMESSAGE = mess(101,121,1)
       Endif
       SEQ=0
    Endif
 Endif
Until SEQ<=1
Close Local File [F:PNHB]
Return
######################################################################################
######################################################################################
$PNHTYP
#85785 - used also on migration tool, carefull
If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
If !clalev([F:TPN]) : Local File TABPNHTYP [TPN] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif

If [F:FCY]FCY <> GFCY : Read [F:FCY]FCY0 = GFCY : Endif
If fstat > 1 : Raz [F:FCY] : Endif

Link [TPN] With [FGR]FGR0=[F:TPN]GFY;GFCY As [KTPN]

Filter [KTPN] Where ([F:TPN]GFY="" | [FGR]FCY=GFCY) & ([F:TPN]LEG=[F:FCY]LEG | [F:TPN]LEG="" ) Order By [F:TPN]LEG Desc;[F:FGR]FCY Desc
Read [KTPN] First
If fstat=0
  WPNHTYP = [F:TPN]PNHTYP
Endif

Filter [KTPN]
If clalev([KTPN]) : Close File [KTPN] : Endif

Return
