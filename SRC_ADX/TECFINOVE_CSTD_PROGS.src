$SET_PJC_FROM_WWW
  [F:PJC]PSCQTY1 += [F:WWW]WQ1
  [F:PJC]PSCAMT1 += [F:WWW]WA1
  [F:PJC]PSCQTY2 += [F:WWW]WQ2
  [F:PJC]PSCAMT2 += [F:WWW]WA2
  [F:PJC]PSCQTY3 += [F:WWW]WQ3
  [F:PJC]PSCAMT3 += [F:WWW]WA3
  [F:PJC]PSCQTY4 += [F:WWW]WQ4
  [F:PJC]PSCAMT4 += [F:WWW]WA4
  [F:PJC]PSCQTY5 += [F:WWW]WQ5
  [F:PJC]PSCAMT5 += [F:WWW]WA5

  [F:PJC]PSCBUDQTY += [F:WWW]WBQTY
  [F:PJC]PSCBUDAMT += [F:WWW]WBAMT
  [F:PJC]PSCTOTQTY += [F:WWW]WTTQT
  [F:PJC]PSCTOTAMT += [F:WWW]WTTAM
  [F:PJC]PSCREMQTY += [F:WWW]WRQT
  [F:PJC]PSCREMAMT += [F:WWW]WRAM
  [F:PJC]PSCMARGQTY += [F:WWW]WMQT
  [F:PJC]PSCMARGAMT += [F:WWW]WMAM
  [F:PJC]PSCPCTMQTY += [F:WWW]WPQT
  [F:PJC]PSCPCTMAMT += [F:WWW]WPAM
  [F:PJC]PSCESTTOTQTY += [F:WWW]WEQT
  [F:PJC]PSCESTTOTAMT += [F:WWW]WEAM
  #------ Accu. Encours  with QTY and AMT -------------------
  # R A R Reste a realiser
  [F:PJC]PSCWIPQTY += [F:WWW]WIPQT
  [F:PJC]PSCWIPAMT += [F:WWW]WIPAM
  #------ hors depense 6 colonnes with QTY and AMT ----------
  [F:PJC]PSCFREEC6A += [F:WWW]WC6QT
  [F:PJC]PSCFREEC6B += [F:WWW]WC6AM
  [F:PJC]PSCFREEC7A += [F:WWW]WC7QT
  [F:PJC]PSCFREEC7B += [F:WWW]WC7AM
  [F:PJC]PSCFREEC8A += [F:WWW]WC8QT
  [F:PJC]PSCFREEC8B += [F:WWW]WC8AM
  [F:PJC]PSCFREEC9A += [F:WWW]WC9QT
  [F:PJC]PSCFREEC9B += [F:WWW]WC9AM
  [F:PJC]PSCFREEC10A += [F:WWW]WC10QT
  [F:PJC]PSCFREEC10B += [F:WWW]WC10AM
  #------ ratio budget
  [F:PJC]PSCMARGBUD6 += [F:WWW]WMBUD6
  [F:PJC]PSCMARGTOT6 += [F:WWW]WTBUD6
  # ---------------------------------
  If [F:PJC]PSCBUDQTY <> 0 Then
    [F:PJC]PSCPCTMQTY = ar2([F:PJC]PSCMARGQTY * 100 / [F:PJC]PSCBUDQTY)
  Endif
  If [F:PJC]PSCBUDAMT <> 0 Then
    [F:PJC]PSCPCTMAMT = ar2([F:PJC]PSCMARGAMT * 100 / [F:PJC]PSCBUDAMT)
  Endif
  # ---------------------------------
  Gosub SET_PJC_PSCPCTMBUD6_PSCPCTMTOT6
Return

###################################################################################################
$SET_PJC_PSCPCTMBUD6_PSCPCTMTOT6
  #----- PSCFREEC6B = montant from column 6 -- ratio
  If [F:PJC]PSCFREEC6B <> 0 Then
    [F:PJC]PSCPCTMBUD6 = ar2([F:PJC]PSCMARGBUD6 * 100 / [F:PJC]PSCFREEC6B)
  Endif
  If [F:PJC]PSCFREEC6B <> 0 Then
    [F:PJC]PSCPCTMTOT6 = ar2([F:PJC]PSCMARGTOT6 * 100 / [F:PJC]PSCFREEC6B)
  Endif
Return

###################################################################################################
$GET_PJC_PCCGRP_PCCGRPSOR
  # ---------------------------------
  If [F:PJC]PCCCOD <> AVOID.ACHAR Then
    Read [PJCC]PCC0=[F:PJC]PCCCOD
    If !fstat Then
      [F:PJC]PCCGRP = [F:PJCC]PCCGRP
      Read [ADI]CODE=386;[F:PJC]PCCGRP
      [F:PJC]PCCGRPSOR = [F:ADI]N1
    Endif
  Endif
  # ---------------------------------
Return

###################################################################################################
$SUM_PJCCTX_WITH_PJCCTW
  # Issue X3-22213/121247 - 2017-01-24 by FGR
  [F:PJCCTX]PSCQTY1      += [F:PJCCTW]PSCQTY1
  [F:PJCCTX]PSCAMT1      += [F:PJCCTW]PSCAMT1
  [F:PJCCTX]PSCQTY2      += [F:PJCCTW]PSCQTY2
  [F:PJCCTX]PSCAMT2      += [F:PJCCTW]PSCAMT2
  [F:PJCCTX]PSCQTY3      += [F:PJCCTW]PSCQTY3
  [F:PJCCTX]PSCAMT3      += [F:PJCCTW]PSCAMT3
  [F:PJCCTX]PSCQTY4      += [F:PJCCTW]PSCQTY4
  [F:PJCCTX]PSCAMT4      += [F:PJCCTW]PSCAMT4
  [F:PJCCTX]PSCQTY5      += [F:PJCCTW]PSCQTY5
  [F:PJCCTX]PSCAMT5      += [F:PJCCTW]PSCAMT5

  [F:PJCCTX]PSCBUDQTY    += [F:PJCCTW]PSCBUDQTY
  [F:PJCCTX]PSCBUDAMT    += [F:PJCCTW]PSCBUDAMT
  [F:PJCCTX]PSCTOTQTY    += [F:PJCCTW]PSCTOTQTY
  [F:PJCCTX]PSCTOTAMT    += [F:PJCCTW]PSCTOTAMT
  [F:PJCCTX]PSCREMQTY    += [F:PJCCTW]PSCREMQTY
  [F:PJCCTX]PSCREMAMT    += [F:PJCCTW]PSCREMAMT
  [F:PJCCTX]PSCMARGQTY   += [F:PJCCTW]PSCMARGQTY
  [F:PJCCTX]PSCMARGAMT   += [F:PJCCTW]PSCMARGAMT
  [F:PJCCTX]PSCPCTMQTY   += [F:PJCCTW]PSCPCTMQTY
  [F:PJCCTX]PSCPCTMAMT   += [F:PJCCTW]PSCPCTMAMT
  [F:PJCCTX]PSCESTTOTQTY += [F:PJCCTW]PSCESTTOTQTY
  [F:PJCCTX]PSCESTTOTAMT += [F:PJCCTW]PSCESTTOTAMT
  #------ Accu. Encours  with QTY and AMT -------------------
  # R A R Reste a realiser
  [F:PJCCTX]PSCWIPQTY    += [F:PJCCTW]PSCWIPQTY
  [F:PJCCTX]PSCWIPAMT    += [F:PJCCTW]PSCWIPAMT
  #------ hors depense 6 colonnes with QTY and AMT ----------
  [F:PJCCTX]PSCFREEC6A   += [F:PJCCTW]PSCFREEC6A
  [F:PJCCTX]PSCFREEC6B   += [F:PJCCTW]PSCFREEC6B
  [F:PJCCTX]PSCFREEC7A   += [F:PJCCTW]PSCFREEC7A
  [F:PJCCTX]PSCFREEC7B   += [F:PJCCTW]PSCFREEC7B
  [F:PJCCTX]PSCFREEC8A   += [F:PJCCTW]PSCFREEC8A
  [F:PJCCTX]PSCFREEC8B   += [F:PJCCTW]PSCFREEC8B
  [F:PJCCTX]PSCFREEC9A   += [F:PJCCTW]PSCFREEC9A
  [F:PJCCTX]PSCFREEC9B   += [F:PJCCTW]PSCFREEC9B
  [F:PJCCTX]PSCFREEC10A  += [F:PJCCTW]PSCFREEC10A
  [F:PJCCTX]PSCFREEC10B  += [F:PJCCTW]PSCFREEC10B
  #------ ratio budget
  [F:PJCCTX]PSCMARGBUD6  += [F:PJCCTW]PSCMARGBUD6
  [F:PJCCTX]PSCMARGTOT6  += [F:PJCCTW]PSCMARGTOT6
  # ---------------------------------
  If [F:PJCCTX]PSCBUDQTY <> 0 Then
    [F:PJCCTX]PSCPCTMQTY = ar2([F:PJCCTX]PSCMARGQTY * 100 / [F:PJCCTX]PSCBUDQTY)
  Endif
  If [F:PJCCTX]PSCBUDAMT <> 0 Then
    [F:PJCCTX]PSCPCTMAMT = ar2([F:PJCCTX]PSCMARGAMT * 100 / [F:PJCCTX]PSCBUDAMT)
  Endif
  # ---------------------------------
  #----- PSCFREEC6B = montant from column 6 -- ratio
  If [F:PJCCTX]PSCFREEC6B <> 0 Then
    [F:PJCCTX]PSCPCTMBUD6 = ar2([F:PJCCTX]PSCMARGBUD6 * 100 / [F:PJCCTX]PSCFREEC6B)
  Endif
  If [F:PJCCTX]PSCFREEC6B <> 0 Then
    [F:PJCCTX]PSCPCTMTOT6 = ar2([F:PJCCTX]PSCMARGTOT6 * 100 / [F:PJCCTX]PSCFREEC6B)
  Endif
  # ---------------------------------
Return

###################################################################################################
Funprog GET_DEFAULT_SHOWQTY_SHOWAMT(CTX, SGRP, ISHOWQTY, ISHOWAMT)
Value Instance CTX Using C_WMACONTEXT
Value Char SGRP
Variable Integer ISHOWQTY
Variable Integer ISHOWAMT

Local Integer IRET

  # Issue X3-107215 - 2018-10-05 by FGR
  IRET = [V]CST_AOK
  # ---------------------------
  ISHOWQTY = [V]CST_AYES
  ISHOWAMT = [V]CST_AYES
  # ---------------------------
  Local File ATABDIV[ADI]
  # ---------------------------
  Filter [ADI] Where [F:ADI]NUMTAB = 388 and [F:ADI]CODE = SGRP and [F:ADI]ENAFLG = [V]CST_AYES
  Read [ADI]First
  If !fstat Then
    ISHOWQTY = [F:ADI]N2
    ISHOWAMT = [F:ADI]N3
  Endif
  Filter [ADI]
End IRET

