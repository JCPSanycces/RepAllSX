###################################################################################################
# Classe TECFINOVE
###################################################################################################
# PROGS
###################################################################################################
Subprog COLUMN_SET_VALUES(AVALO, ANUMCOL, APSDQTY, APSDUQTY, AAMTRESULT)
Value Integer AVALO
Value Integer ANUMCOL
Value Decimal APSDQTY
Value Decimal APSDUQTY   #--- qte converti
Value Decimal AAMTRESULT

Local Decimal WPSDQTY
Local Decimal WAMTRESULT

  WPSDQTY    = APSDQTY
  WPSDUQTY   = APSDUQTY   #-- qte unite
  WAMTRESULT = AAMTRESULT
  #------------------------------------------------------------------
  If AVALO = [V]CST_ANO Then
    #--No=1=Negative valuation,  Yes=2=Positive (default)
    WPSDQTY = APSDQTY * -1
    WPSDUQTY = APSDUQTY * 1   #-- qte unite
    WAMTRESULT = AAMTRESULT * -1
  Endif
  Case ANUMCOL
    When 1
      [F:PJE]PDEQTY1 = WPSDQTY
      [F:PJE]PDEUQTY1 = WPSDUQTY
      [F:PJE]PDEAMT1 = WAMTRESULT
    When 2
      [F:PJE]PDEQTY2 = WPSDQTY
      [F:PJE]PDEUQTY2 = WPSDUQTY
      [F:PJE]PDEAMT2 = WAMTRESULT
    When 3
      [F:PJE]PDEQTY3 = WPSDQTY
      [F:PJE]PDEUQTY3 = WPSDUQTY
      [F:PJE]PDEAMT3 = WAMTRESULT
    When 4
      [F:PJE]PDEQTY4 = WPSDQTY
      [F:PJE]PDEUQTY4 = WPSDUQTY
      [F:PJE]PDEAMT4 = WAMTRESULT
    When 5
      [F:PJE]PDEQTY5 = WPSDQTY
      [F:PJE]PDEUQTY5 = WPSDUQTY
      [F:PJE]PDEAMT5 = WAMTRESULT
    When 6
      #-- 6 - 10  for hors depense  6A for qty or amt
      [F:PJE]PDEFREEC6A = WPSDQTY
      [F:PJE]PDEFREEC6B = WAMTRESULT
    When 7
      [F:PJE]PDEFREEC7A = WPSDQTY
      [F:PJE]PDEFREEC7B = WAMTRESULT
    When 8
      [F:PJE]PDEFREEC8A = WPSDQTY
      [F:PJE]PDEFREEC8B = WAMTRESULT
    When 9
      [F:PJE]PDEFREEC9A = WPSDQTY
      [F:PJE]PDEFREEC9B = WAMTRESULT
    When 10
      [F:PJE]PDEFREEC10A = WPSDQTY
      [F:PJE]PDEFREEC10B = WAMTRESULT
    When Default
      [F:PJE]PDEQTY1 = WPSDQTY
      [F:PJE]PDEUQTY1 = WPSDUQTY
      [F:PJE]PDEAMT1 = WAMTRESULT
  Endcase
End

###################################################################################################
Subprog CONVERT_QTY(CTX, IN_UOM, OUT_UOM, QTY)
Value Instance CTX Using C_WMACONTEXT
Value Char IN_UOM
Value Char OUT_UOM
Variable Decimal QTY

  If IN_UOM <> OUT_UOM and IN_UOM <> "" Then
     #-- Convertion AUNIT unite input from interface --
    Call CONVERT_QTY(ACTX, IN_UOM, OUT_UOM, QTY) From TRTX3_SYRA
  Endif
End

###################################################################################################
Funprog GET_UNIC_ID()
Local Integer IARENDRE

  IARENDRE = adxuid(2)
End IARENDRE

###################################################################################################
Funprog COL_GET_TITLE(TECFINOVE, INDEX)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Integer INDEX

Local Char SARENDRE(250)

  If TECFINOVE = null Then
    SARENDRE = mess(383,2260,1)
  Else
    If INDEX >= 1 and INDEX < 41 Then
      If TECFINOVE.TITLE(INDEX) = null Then
        SARENDRE = "*" + mess(383,2260,1) + "*"
      Else
        SARENDRE = TECFINOVE.TITLE(INDEX).TVARTIDYN
        If SARENDRE = "" Then
          TECFINOVE.TITLE(INDEX).USE = [V]CST_ANO
        Endif
      Endif
    Endif
  Endif
End SARENDRE

###################################################################################################
Funprog GET_FMT_AMT(CTX, IS_SHOW, SCUR)
Value Instance CTX Using C_WMACONTEXT  # Issue X3-70668 - 2018-01-30 by FGR
Value Integer IS_SHOW
Value Char SCUR

Local Char SARENDRE(250)
Local Char SPREFIX(1)

  Raz SPREFIX
  If IS_SHOW = [V]CST_ANO Then
    SPREFIX = "-"
  Endif
  #SARENDRE = SPREFIX + "N3zF:" + "11.2"
  #SARENDRE = SPREFIX + "N3zF:" + GDEVFMT1(max(find(SCUR, GDEVISE(1..GNBDEV)),1))        # Issue X3-70668 - 2018-01-30 by FGR
  SARENDRE = SPREFIX + "N3zF:" + fmet CTX.ACACHE.ACUR.AGETVALCHAR(SCUR, "CURFMT3")       # Issue X3-70668 - 2018-01-30 by FGR
End SARENDRE

###################################################################################################
Funprog GET_FMT_QTY(CTX, IS_SHOW, SUOM)
Value Instance CTX Using C_WMACONTEXT  # Issue X3-70668 - 2018-01-30 by FGR
Value Integer IS_SHOW
Value Char SUOM

Local Char SARENDRE(250)
Local Char SPREFIX(1)

  Raz SPREFIX
  If IS_SHOW = [V]CST_ANO Then
    SPREFIX = "-"
  Endif
  SARENDRE = SPREFIX + "N3zF:" + "15F"
  SARENDRE = SPREFIX + "N3zF:" + GUNTFMT1(max(find(SUOM, GUNITE(1..GNBUNT)),1))
End SARENDRE

###################################################################################################
Funprog GET_FMT_DYN(TECFINOVE, IINDEX, IS_SHOWCUR, SCUR, IS_SHOWUOM, SUOM)
Variable Instance TECFINOVE Using C_TECFINOVE
Value Integer IINDEX
Value Integer IS_SHOWCUR
Value Char SCUR
Value Integer IS_SHOWUOM
Value Char SUOM

Local Char SARENDRE(250)
Local Integer ITYPE
Local Integer ISHOW

  Raz SARENDRE
  If TECFINOVE = null Then
    # Issue X3-91451 - 2018-05-29 by FGR : if TECFINOVE not define, fields are hidden
    SARENDRE = func GET_FMT_AMT(GACTX, [V]CST_ANO, GDEVISE(1))
  Else
    If TECFINOVE.TITLE(IINDEX) <> null Then
      ITYPE = TECFINOVE.TITLE(IINDEX).COLTYP

      Case ITYPE
        When 1
          # Quantity
          If IS_SHOWUOM = [V]CST_ANO or SUOM = AVOID.ACHAR Then
            ISHOW = [V]CST_ANO
          Else
            ISHOW = TECFINOVE.TITLE(IINDEX).USE
          Endif
          SARENDRE = func GET_FMT_QTY(TECFINOVE.ACTX, ISHOW, SUOM) # Issue X3-70668 - 2018-01-30 by FGR : add TECFINOVE parameter
        When 2
          # Amount
          If IS_SHOWCUR = [V]CST_ANO Then
            ISHOW = [V]CST_ANO
          Else
            ISHOW = TECFINOVE.TITLE(IINDEX).USE
          Endif
          SARENDRE = func GET_FMT_AMT(TECFINOVE.ACTX, ISHOW, SCUR) # Issue X3-70668 - 2018-01-30 by FGR : add TECFINOVE parameter
      Endcase
    Endif
  Endif
End SARENDRE

###################################################################################################
$SET_PJCCTW_FROM_WWW
  [F:PJCCTW]PSCQTY1      = [F:WWW]WQ1
  [F:PJCCTW]PSCAMT1      = [F:WWW]WA1
  [F:PJCCTW]PSCQTY2      = [F:WWW]WQ2
  [F:PJCCTW]PSCAMT2      = [F:WWW]WA2
  [F:PJCCTW]PSCQTY3      = [F:WWW]WQ3
  [F:PJCCTW]PSCAMT3      = [F:WWW]WA3
  [F:PJCCTW]PSCQTY4      = [F:WWW]WQ4
  [F:PJCCTW]PSCAMT4      = [F:WWW]WA4
  [F:PJCCTW]PSCQTY5      = [F:WWW]WQ5
  [F:PJCCTW]PSCAMT5      = [F:WWW]WA5

  [F:PJCCTW]PSCBUDQTY    = [F:WWW]WBQTY
  [F:PJCCTW]PSCBUDAMT    = [F:WWW]WBAMT
  [F:PJCCTW]PSCTOTQTY    = [F:WWW]WTTQT
  [F:PJCCTW]PSCTOTAMT    = [F:WWW]WTTAM
  [F:PJCCTW]PSCREMQTY    = [F:WWW]WRQT
  [F:PJCCTW]PSCREMAMT    = [F:WWW]WRAM
  [F:PJCCTW]PSCMARGQTY   = [F:WWW]WMQT
  [F:PJCCTW]PSCMARGAMT   = [F:WWW]WMAM
  [F:PJCCTW]PSCPCTMQTY   = [F:WWW]WPQT
  [F:PJCCTW]PSCPCTMAMT   = [F:WWW]WPAM
  [F:PJCCTW]PSCESTTOTQTY = [F:WWW]WEQT
  [F:PJCCTW]PSCESTTOTAMT = [F:WWW]WEAM
  #------ Accu. Encours  with QTY and AMT -------------------
  # R A R Reste a realiser
  [F:PJCCTW]PSCWIPQTY    = [F:WWW]WIPQT
  [F:PJCCTW]PSCWIPAMT    = [F:WWW]WIPAM
  #------ hors depense 6 colonnes with QTY and AMT ----------
  [F:PJCCTW]PSCFREEC6A   = [F:WWW]WC6QT
  [F:PJCCTW]PSCFREEC6B   = [F:WWW]WC6AM
  [F:PJCCTW]PSCFREEC7A   = [F:WWW]WC7QT
  [F:PJCCTW]PSCFREEC7B   = [F:WWW]WC7AM
  [F:PJCCTW]PSCFREEC8A   = [F:WWW]WC8QT
  [F:PJCCTW]PSCFREEC8B   = [F:WWW]WC8AM
  [F:PJCCTW]PSCFREEC9A   = [F:WWW]WC9QT
  [F:PJCCTW]PSCFREEC9B   = [F:WWW]WC9AM
  [F:PJCCTW]PSCFREEC10A  = [F:WWW]WC10QT
  [F:PJCCTW]PSCFREEC10B  = [F:WWW]WC10AM
  #------ ratio budget
  [F:PJCCTW]PSCMARGBUD6  = [F:WWW]WMBUD6
  [F:PJCCTW]PSCMARGTOT6  = [F:WWW]WTBUD6
  # ---------------------------------
  If [F:PJCCTW]PSCBUDQTY <> 0 Then
    [F:PJCCTW]PSCPCTMQTY = ar2([F:PJCCTW]PSCMARGQTY * 100 / [F:PJCCTW]PSCBUDQTY)
  Endif
  If [F:PJCCTW]PSCBUDAMT <> 0 Then
    [F:PJCCTW]PSCPCTMAMT = ar2([F:PJCCTW]PSCMARGAMT * 100 / [F:PJCCTW]PSCBUDAMT)
  Endif
  # ---------------------------------
  #----- PSCFREEC6B = montant from column 6 -- ratio
  If [F:PJCCTW]PSCFREEC6B <> 0 Then
    [F:PJCCTW]PSCPCTMBUD6 = ar2([F:PJCCTW]PSCMARGBUD6 * 100 / [F:PJCCTW]PSCFREEC6B)
  Endif
  If [F:PJCCTW]PSCFREEC6B <> 0 Then
    [F:PJCCTW]PSCPCTMTOT6 = ar2([F:PJCCTW]PSCMARGTOT6 * 100 / [F:PJCCTW]PSCFREEC6B)
  Endif
  # ---------------------------------
Return

