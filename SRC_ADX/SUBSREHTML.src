#<AdxTL>@(#)10.0.0.0 $Revision$
###############################################################################################################
#
#   Génération HTML d'une Demande de service                                                 Version 140
#   Module CRM
#
###############################################################################################################
###############################################################################################################
Funprog PREPARE_SEND_EMAIL(ACTX, SSRENUM, SFROMAUS, STOEMAIL, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SSRENUM
Value Char SFROMAUS
Value Char STOEMAIL()(1..)
Variable Char SMESSAGE

Local Integer IARENDRE
Local Char SA_FROM(250)
Local Char SA_USER(250)(1..)
Local Char SCC_USER(250)(1..)
Local Char SZEMAILSUBJECT(250)
Local Clbfile BODY(4)
Local Char S_ATTACHMENTS(250)(1..)

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  IARENDRE = func PREPARE_EMAIL(ACTX, SSRENUM, "", SFROMAUS, STOEMAIL, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  If IARENDRE = [V]CST_AYES Then
    IARENDRE = func SEND_EMAIL(ACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  Endif
End IARENDRE

###############################################################################################################
Funprog PREPARE_EMAIL(ACTX, SSRENUM, IDSYTYP, SFROMAUS, STOEMAIL, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SSRENUM
Value Integer IDSYTYP
Value Char SFROMAUS
Value Char STOEMAIL()(1..)
Variable Char SA_FROM
Variable Char SA_USER()(1..)
Variable Char SCC_USER()(1..)
Variable Char SZEMAILSUBJECT
Variable Clbfile BODY
Variable Char S_ATTACHMENTS()(1..)
Variable Char SMESSAGE

Local Integer IARENDRE
Local Clbfile CLURL(2)
Local Integer IHDTDON
Local Integer IFOUND
Local Integer NI
Local Integer IERR
Local Integer ICHAPTER
Local Integer ASTATUS
Local Char SZFROM(250)
Local Char TABKEY(50)(1..10)
Local Char TABKEYVAL(50)(1..10)
Local Char TABPAR(50)(1..10)
Local Char TABPARVAL(250)(1..10)
Local Char SZFROM(250)
Local Char SZTO(250)
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)
Local Char SZAUSNAME(250)

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  Local File AUTILIS [AUS]
  Local File SERREQUEST [SRE]
  Local File BPARTNER [BPR]
  # -------------------------------------------------
  Read [AUS]CODUSR=SFROMAUS
  If fstat Then
    SMESSAGE = mess(1162,196,1) - "(" + SFROMAUS + ")"
    IARENDRE = [V]CST_ANO
    Goto END_PREPARE_EMAIL
  Else
    If [F:AUS]ADDEML = "" Then
      SMESSAGE = mess(1162,196,1) - "(" + SFROMAUS + ")"
      IARENDRE = [V]CST_ANO
      Goto END_PREPARE_EMAIL
    Endif
  Endif
  SZFROM = [F:AUS]ADDEML
  Call LECTEXTRA(SZAUSNAME, "AUTILIS", "INTUSR", [F:AUS]USR, "") From ATEXTRA
  # -------------------------------------------------
  Read [SRE]SRE0=SSRENUM
  If fstat Then
    IARENDRE = [V]CST_ANO
    SMESSAGE = mess(1164,196,1) - "(" + SSRENUM + ")"
  Else
    # ----------------------------------------
    # Constitution de sujet du message
    If [F:SRE]SREBPC = "" Then
      Call TEXTE(14603, SZEMAILSUBJECT) From OBJDIV      #Demande de service
    Else
      Read [BPR]BPR0=[F:SRE]SREBPC
      If fstat Then
        Call TEXTE(14603, SZEMAILSUBJECT) From OBJDIV    #Demande de service
      Else
        SZEMAILSUBJECT = mess(1165,196,1) - ": (" + [F:BPR]BPRNUM + ")" - [F:BPR]BPRNAM
      Endif
    Endif
    # ----------------------------------------
    # Constitution de la pièce jointe
    IARENDRE = func CREATE_PJ(ACTX, [F:SRE]SRENUM, IDSYTYP, S_ATTACHMENTS, SMESSAGE)
    If IARENDRE = [V]CST_ANO Then
      Goto END_PREPARE_EMAIL
    Endif
    # ----------------------------------------
    SA_FROM = SZFROM      # From
    Raz SA_USER           # To
    For NI = 1 To maxtab(STOEMAIL)
      If STOEMAIL(NI) <> "" Then
        SA_USER(1) = STOEMAIL(NI)
      Endif
    Next NI
    Raz SCC_USER          # Copy to
    SCC_USER(1) = SZFROM  # Je mets l'émetteur du mail en copie sinon il n'a pas trace du mail envoyé dans sa messagerie
    #
    Raz BODY              # Corps du mail
    Read [AUS]CODUSR=SFROMAUS          # Relire [AUS]. A été perdu "quelque part"
    IARENDRE = func SUBHTMMAI1.GET_TEXTE(1, GLANGUE, [F:AUS]USR, BODY, SMESSAGE)
    If IARENDRE = [V]CST_AYES Then
      Append BODY, chr$(10) + SZAUSNAME
      #
      Raz TABKEY
      Raz TABKEYVAL
      Raz TABPAR
      Raz TABPARVAL
      TABKEY(1) = "SRENUM"
      TABKEYVAL(1) = [F:SRE]SRENUM
      ASTATUS = func ASYRFNC.AGET_CLASSICURL(GACTX, [V]CST_ATRUE, "GESSRE", [V]CST_AMODIFFCT, TABKEY, TABKEYVAL, TABPAR, TABPARVAL, CLURL)
      If [L]ASTATUS = [V]CST_AOK Then
        Append BODY, chr$(10) + chr$(10) + chr$(10)
        Append BODY, CLURL
      Endif
    Endif
  Endif
$END_PREPARE_EMAIL
End IARENDRE

###############################################################################################################
Funprog CREATE_PJ(ACTX, SSRENUM, IDSYTYP, S_ATTACHMENTS, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SSRENUM
Value Integer IDSYTYP
Variable Char S_ATTACHMENTS()(1..)
Variable Char SMESSAGE

Local Integer IARENDRE
Local Char SZSCREENTYPE(10)
Local Integer IERR
Local Integer ICHAPTER
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  Local File SERREQUEST [SRE]
  Local File BPARTNER [BPR]
  # -------------------------------------------------
  Read [SRE]SRE0=SSRENUM
  If fstat Then
    IARENDRE = [V]CST_ANO
    SMESSAGE = mess(1164,196,1) - "(" + SSRENUM + ")"
  Else
    Read [BPR]BPR0=[F:SRE]SREBPC
    # -------------------------------------------------
    SZSCREENTYPE = func TRTLKP9.GET_SCREENTYPE_FROM_DSYTYP(IDSYTYP)
    # -------------------------------------------------
    # Constitution de la pièce jointe
    Call SREINHTML([F:SRE]SRENUM, 1, SZSCREENTYPE, "SRE_SREASS", SZFULLFILENAME, SZFILENAME, ICHAPTER, IERR)
    If IERR Then
      SMESSAGE = mess(IERR,ICHAPTER,1)
      IARENDRE = [V]CST_ANO
    Else
      Raz S_ATTACHMENTS     # PJ
      S_ATTACHMENTS(1) = SZFULLFILENAME
    Endif
  Endif
End IARENDRE

###############################################################################################################
Funprog SEND_EMAIL(ACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SA_FROM
Value Char SA_USER()(1..)
Value Char SCC_USER()(1..)
Value Char SZEMAILSUBJECT
Value Clbfile BODY
Value Char S_ATTACHMENTS()(1..)
Variable Char SMESSAGE

Local Integer ASTATUS
Local Integer IARENDRE

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  ASTATUS = func ASYRMAIL.ASEND_MAIL(ACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, [V]CST_ANO)
  If [L]ASTATUS <> [V]CST_AOK Then
    SMESSAGE = mess(1163,196,1)
    IARENDRE = [V]CST_ANO
  Endif
End IARENDRE

###############################################################################################################
Subprog SREINHTML(SZRECNUM, IGENERICFILENAME, SZSCREENTYPE, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZSCREENTYPE
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

Local Char SZHTMLTITLE(GLONDES)
Local Char SZSUBPROG(GLONADC)
Local Char SZAOBABREV(GLONAOB)

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif
  Gosub HTMLPART1 From CRMXML140
  Call TEXTE(14603, SZHTMLTITLE) From OBJDIV      #Demande de service
  SZSUBPROG = "SREINHTML"
  SZAOBABREV = "SRE"
  Gosub HTMLPART2 From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREHTML
  Gosub HTMLPART3 From CRMXML140
End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREHTML
  Gosub SETSREEXCEPT From CRMEXCEPT
  Gosub SETBPREXCEPT From CRMEXCEPT
  Gosub SETBPCEXCEPT From CRMEXCEPT
  Gosub SETBPAEXCEPT From CRMEXCEPT
  Gosub SETSRMEXCEPT From CRMEXCEPT
  Gosub SETSRNEXCEPT From CRMEXCEPT
  Gosub SETMACEXCEPT From CRMEXCEPT
  Gosub SETHDTEXCEPT From CRMEXCEPT
  #On extrait
  Filter [SRE] Where [F:SRE]SRENUM = SZRECNUM
  For [SRE]
    Gosub HTMLSRE From CRMEXCEPT
    #Parc concerné
    If IDISPLAYSRM Then
      Filter [SRM] Where [F:SRM]SRENUM = SZRECNUM
      For [SRM]SRM1
        Gosub HTMLSRM From CRMEXCEPT
        #Détail parc client
        If IDISPLAYBPA Then
          Gosub ADDMAC
        Endif
        #Consommations
        If IDISPLAYHDT Then
          Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT = [00/00/00]
&                   Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
          For [HDT] Hint Key HDT1
            Gosub HTMLHDT From CRMEXCEPT
          Next
          Filter [HDT]
          If IHDTDON Then
            Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT <> [00/00/00]
&                     Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
            For [HDT] Hint Key HDT1
              Gosub HTMLHDT From CRMEXCEPT
            Next
            Filter [HDT]
          Endif
        Endif
        #Composants concernés
        If IDISPLAYSRN Then
          Filter [SRN] Where [F:SRN]SRENUM = SZRECNUM and [F:SRN]MACNUM = [F:SRM]MACNUM Order By [F:SRN]CPNITM Asc
          For [SRN]
            Gosub HTMLSRN From CRMEXCEPT
            #Consommations
            If IDISPLAYHDT Then
              Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = [F:SRN]CPNITM and [F:HDT]HDTDONDAT = [00/00/00]
&                       Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
              For [HDT] Hint Key HDT1
                Gosub HTMLHDT From CRMEXCEPT
              Next
              Filter [HDT]
              If IHDTDON Then
                Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]HDTCPN = [F:SRN]CPNITM and [F:HDT]HDTDONDAT <> [00/00/00]
&                         Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
                For [HDT] Hint Key HDT1
                  Gosub HTMLHDT From CRMEXCEPT
                Next
                Filter [HDT]
              Endif
            Endif
          Next
          Filter [SRN]
        Endif
      Next
      Filter [SRM]
    Endif
    #Consommations non associées à un parc
    If IDISPLAYHDT Then
      Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = "" and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT = [00/00/00]
&                   Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
      For [HDT] Hint Key HDT1
        Gosub HTMLHDT From CRMEXCEPT
      Next
      Filter [HDT]
      If IHDTDON Then
        Filter [HDT] Where [F:HDT]SRENUM = SZRECNUM and [F:HDT]HDTMACSRE = "" and [F:HDT]HDTCPN = "" and [F:HDT]HDTDONDAT <> [00/00/00]
&                 Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
        For [HDT] Hint Key HDT1
          Gosub HTMLHDT From CRMEXCEPT
        Next
        Filter [HDT]
      Endif
    Endif
    #Tiers
    If IDISPLAYBPR Then
      Gosub ADDBPR
    Endif
    #Client
    If IDISPLAYBPC Then
      Gosub ADDBPC
    Endif
    #Adresse
    If IDISPLAYBPA Then
      Gosub ADDBPA
    Endif
  Next
  Filter [SRE]
Return

##########################################################
# Tiers
##########################################################
$ADDBPR
  Filter [BPR] Where [F:BPR]BPRNUM = [F:SRE]SREBPC
  For [BPR]
    Gosub HTMLBPR From CRMEXCEPT
  Next
  Filter [BPR]
Return

##########################################################
# Client
##########################################################
$ADDBPC
  Filter [BPC] Where [F:BPC]BPCNUM = [F:SRE]SREBPC
  For [BPC]
    Gosub HTMLBPC From CRMEXCEPT
  Next
  Filter [BPC]
Return

##########################################################
# Adresse
##########################################################
$ADDBPA
  If [F:SRE]SREBPAADD = "" Then
    Read [BPR]BPR0=[F:SRE]SREBPC
    If fstat Then
      Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:SRE]SREBPC
    Else
      Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:SRE]SREBPC and [F:BPA]BPAADD = [F:BPR]BPAADD
    Endif
  Else
    Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:SRE]SREBPC and [F:BPA]BPAADD = [F:SRE]SREBPAADD
  Endif
  For [BPA]
    Gosub HTMLBPA From CRMEXCEPT
  Next
  Filter [BPA]
Return

##########################################################
# Parc client
##########################################################
$ADDMAC
  Filter [MAC] Where [F:MAC]MACNUM = [F:SRM]MACNUM
  For [MAC]
    Gosub HTMLMAC From CRMEXCEPT
  Next
  Filter [MAC]
Return

