#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201807004
# Issue X3-101833 - 2018-08-09 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201807004(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201807004(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Char SCHAINE(250)
Local Integer NK

  Call ECR_TRACE("UTIPJM201807004: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOPAR" [ADP]
  Local File =DOSSIER + ".ADOVAL" [ADW]
  Local File =DOSSIER + ".ACTION" [ACT]
  Local File =DOSSIER + ".ACTCODPAR" [AAR]
  Local File =DOSSIER + ".ACTPAR" [ATR]
  Local File =DOSSIER + ".ADOCUMENT" [ADO]
  Local File =DOSSIER + ".ADOCCLB" [ADH]
  Local File =DOSSIER + ".ADICTRT" [ADC]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [ADP]
  # -----------------
  # PARAMETER DELETION
  SCHAINE = 'TASCLOORD'
  Delete [ADP] Where [F:ADP]PARAM = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ADOPAR, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  Delete [ADW] Where [F:ADW]PARAM = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ADOVAL, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  # -----------------
  # ACTION DELETION
  SCHAINE = 'PJMBUDAUTO'
  Delete [ACT] Where [F:ACT]ACTION = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ACTION, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  Delete [AAR] Where [F:AAR]CODPAR = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ACTCODPAR, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  Delete [ATR] Where [F:ATR]ACTION = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ACTCODPAR, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  Call EFFACE_DOC("ACT", SCHAINE) From SUBADO
  # -----------------
  # SCRIPT DICTIONARY DELETION
  SCHAINE = 'PJMBUDAUTO'
  Delete [ADC] Where [F:ADC]CODTRT = SCHAINE
  COMPTEUR += adxdlrec
  If fstat Then
    Call ECR_TRACE("File ADICTRT, Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  If filinfo(filpath("TRT", SCHAINE, "src", DOSSIER), 0) > 0 Then
   Call EFFACE(filpath("TRT", SCHAINE, "src", DOSSIER), NK) From ORDSYS
  Endif
  If filinfo(filpath("TRT", SCHAINE, "xrc", DOSSIER), 0) > 0 Then
   Call EFFACE(filpath("TRT", SCHAINE, "xrc", DOSSIER), NK) From ORDSYS
  Endif
  Call EFFACE_ADX("", DOSSIER, SCHAINE, NK) From ORDSYS
  If filinfo(filpath("TRT", SCHAINE, "adx", DOSSIER), 0) > 0 Then
   Call EFFACE(filpath("TRT", SCHAINE, "adx", DOSSIER), NK) From ORDSYS
  Endif
  Call EFFACE_DOC(func SUBADC.CODDOC(), SCHAINE) From SUBADO
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201807004 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201807004 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  #  If APPLI = GDOSX3 and GADONIX <> 2 Then
  #    End
  #  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOPAR") : End : Endif
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  #
  If filinfo(filpath("FIL","ACTION","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTION") : End : Endif
  If filinfo(filpath("FIL","ACTCODPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTCODPAR") : End : Endif
  If filinfo(filpath("FIL","ADOCUMENT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCUMENT") : End : Endif
  If filinfo(filpath("FIL","ADOCCLB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCCLB") : End : Endif
  #
  If filinfo(filpath("FIL","ADICTRT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADICTRT") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807004(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  #  If APPLI = GDOSX3 and GADONIX <> 2 Then
  #    End
  #  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOPAR") : End : Endif
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  #
  If filinfo(filpath("FIL","ACTION","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTION") : End : Endif
  If filinfo(filpath("FIL","ACTCODPAR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ACTCODPAR") : End : Endif
  If filinfo(filpath("FIL","ADOCUMENT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCUMENT") : End : Endif
  If filinfo(filpath("FIL","ADOCCLB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOCCLB") : End : Endif
  #
  If filinfo(filpath("FIL","ADICTRT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADICTRT") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807004(APPLI)
End

