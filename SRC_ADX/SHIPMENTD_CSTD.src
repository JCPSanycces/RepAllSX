#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SHIPMENTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
    When ""
      Case [L]AEVENT
         When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER  From SHIPMENTD_CSTD_EVT
         When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER  From SHIPMENTD_CSTD_EVT
      Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
   When "SOLDSHIPLINE"      : Gosub SOLDSHIPLINE      From SHIPMENTD_CMET
   When "_CALC_TOTAUX"      : Gosub _CALC_TOTAUX      From SHIPMENTD_CMET   # Issue 111256 US3
   When "_UPDQTYLIN"        : Gosub _UPDQTYLIN        From SHIPMENTD_CMET   # Issue 15350 - 2016-12-06 by MAE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
   When "SHIQTY" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub SHIQTY_PROPAGATE  From SHIPMENTD_CPRO
      Endcase
    When "PRCPQTY" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub PRCPQTY_PROPAGATE From SHIPMENTD_CPRO
      Endcase
    When "PRCPFLG" :
      Case [L]ARULE
        When "INIT"      : Gosub PRCPFLG_INIT      From SHIPMENTD_CPRO
        When "PROPAGATE" : Gosub PRCPFLG_PROPAGATE From SHIPMENTD_CPRO
      Endcase
      # Issue 111257 US 70
    When "QTYEXPFLG" :
      Case [L]ARULE
        When "INIT"      : Gosub QTYEXPFLG_INIT      From SHIPMENTD_CPRO
      Endcase
  Endcase
Return

