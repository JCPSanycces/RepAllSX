#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_MSCRNG UTI process                                  PAY Module
#                  Migration To U12 - Vnext version
#
# ==>  Update MISCELLANEOUS table ranges to the 10 000 range
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update MISCELLANEOUS table ranges to the 10 000 range") From LECFIC

  Call AMAJ_EMHRMAJ90_MSCRNG(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog AMAJ_EMHRMAJ90_MSCRNG(LDOSSIER)
Value Char LDOSSIER
Local Char DOSLEGMIG(5)
Local Char NUMTABARRAY(GLONATB)(1..)
Local Integer STAT : STAT = 1
Local Integer NBRREC, I, NBRTAB
Local Char MSG(100)
Local Char THISPROC(20) : THISPROC = "EMHRMAJ90_MSCRNG"
Local Integer   MSCARRAY(1..)
Local Integer   COUNTER

  Onerrgo CYCLECHECKERROR

#begin migration tasks
  #raise dialog box to enter the folder name
#  Call SAIDOS(LDOSSIER,"") From SAIDOS

  Call ECR_TRACE("EMHRMAJ90_MSCRNG: Update MISCELLANEOUS table ranges to the 10 000 range",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_MSCRNG: Start of process on : "+LDOSSIER,0) From GESECRAN

  #gets the folder legislation
  DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)

  #Sync the miscellaneous table entries and clear on daughter folder
  Gosub PROCESS_MISC_SYNC

  Gosub DEFINE_MISC_TABLES
  Gosub UPDATE_TABLE_REFERENCES
  Gosub UPDATE_SCREEN_REFERENCES

  Call ECR_TRACE("EMHRMAJ90_MSCRNG : End of process on : "+LDOSSIER,0) From GESECRAN

End #end migration process ###########################################################################################

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_MSCRNG: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

$PROCESS_MISC_SYNC

  If clalev([F:WADV]) = 0 : Local File = LDOSSIER+"."+"ATABTAB"  [WADV]  : Endif
  If clalev([F:WADI]) = 0 : Local File = LDOSSIER+"."+"ATABDIV"  [WADI]  : Endif
  If clalev([F:WAXX]) = 0 : Local File = LDOSSIER+"."+"ATEXTRA"  [WAXX] : Endif

  If clalev([F:R_ADV]) = 0 : Local File ATABTAB  [R_ADV]  : Endif
  If clalev([F:R_ADI]) = 0 : Local File ATABDIV  [R_ADI]  : Endif

  Local Integer TEMPLOC
  Local Char SHODES(GLONAX1)

  Filter [F:WADV]

  For [F:WADV]
    If [F:WADV]UPDFLG = 2
      TEMPLOC = [F:WADV]NUMTAB

#PEVAN - 2018-02-06 - X3-76014 - START
#      If [F:WADV]NUMTAB > 300 and [F:WADV]NUMTAB < 10000
      If [F:WADV]NUMTAB >= 300 and [F:WADV]NUMTAB < 900
#PEVAN - 2018-02-06 - X3-76014 - END
        TEMPLOC = [F:WADV]NUMTAB + 10000
      Endif

      Call ECR_TRACE(THISPROC +" : TEMPLOC (" + num$([F:WADV]NUMTAB) + ")",0) From GESECRAN

#PEVAN - 2018-02-06 - X3-76014 - START
#      Filter [F:R_ADV] Where NUMTAB = TEMPLOC and MODULE = [F:R_ADV]MODULE
      Filter [F:R_ADV] Where [F:R_ADV]NUMTAB = TEMPLOC and [F:R_ADV]MODULE = [F:WADV]MODULE
#PEVAN - 2018-02-06 - X3-76014 - END
      Read [F:R_ADV] First

      If !fstat
        Filter [F:WADI] Where [F:WADI]NUMTAB = TEMPLOC
        For [F:WADI]
          Filter [F:R_ADI] Where [F:R_ADI]NUMTAB = TEMPLOC and [F:R_ADI]CODE = [F:WADI]CODE
          Read [F:R_ADI] First

          If fstat > 0 #not found, need to add to reference folder, because it is a custom entry
            Raz [L]SHODES
            Filter [WAXX] Where CODFIC = "ATABDIV" and ZONE = "SHODES" and LANGUE = "ENG" and IDENT1 = num$(TEMPLOC) and IDENT2 = [F:WADI]CODE
            Read [WAXX] First
            If fstat=0
               Call ECR_TRACE("[F:WAXX]TEXTE: " + num$([F:WAXX]TEXTE),0) From GESECRAN
             [L]SHODES = [F:WAXX]TEXTE
            Endif

            Call ECR_TRACE(THISPROC+" : Added to miscellaneous table ("+num$([F:WADI]NUMTAB)+") a entry ["+num$([F:WADI]CODE)+" = "+num$([L]SHODES)+"]",0) From GESECRAN
            [F:R_ADI] = [F:WADI]
            Write [F:R_ADI]
          Endif
        Next
      Endif
    Endif
  Next

  Filter [F:WADV]

  Call ECR_TRACE("EMHRMAJ90_MSCRNG: Cleared miscellaneous table entries : "+LDOSSIER,0) From GESECRAN
  Delete [F:WADI] Where 1=1
  Call ECR_TRACE("EMHRMAJ90_MSCRNG: Cleared miscellaneous table definitions : "+LDOSSIER,0) From GESECRAN
  Delete [F:WADV] Where 1=1

  Close File [F:WADI]
  Close File [F:WADV]
  Close File [F:R_ADI]
  Close File [F:R_ADV]

#  Call DEBTRANS From GLOCK

Return

$DEFINE_MISC_TABLES
  I  = 0
  #301
  I += 1 :  MSCARRAY(I) = 301
  #309
  I += 1 :  MSCARRAY(I) = 309
  #329
  I += 1 :  MSCARRAY(I) = 329
  #333
  I += 1 :  MSCARRAY(I) = 333
  #334-347
  For COUNTER = 334 To 347
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #356-357
  For COUNTER = 356 To 357
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #362-368
  For COUNTER = 362 To 368
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #370-394
  For COUNTER = 370 To 394
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #396-402
  For COUNTER = 396 To 402
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #405
  I += 1 :  MSCARRAY(I) = 405
  #411
  I += 1 :  MSCARRAY(I) = 411
  #440-443
  For COUNTER = 440 To 443
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #451
  I += 1 :  MSCARRAY(I) = 451
  #453-462
  For COUNTER = 453 To 462
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #464-468
  For COUNTER = 464 To 468
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #501-506
  For COUNTER = 501 To 506
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #551-553
  For COUNTER = 551 To 553
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #560-562
  For COUNTER = 560 To 562
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #601-607
  For COUNTER = 601 To 607
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #640-641
  For COUNTER = 640 To 641
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #702-707
  For COUNTER = 702 To 707
    I += 1 :  MSCARRAY(I) = COUNTER
  Next
  #882-883
  For COUNTER = 882 To 883
    I += 1 :  MSCARRAY(I) = COUNTER
  Next

Return

$UPDATE_TABLE_REFERENCES
  If clalev([F:YTBZ]) = 0 :Local File =LDOSSIER+".ATABZON" [YTBZ] : Endif

  For COUNTER = 1 To maxtab(MSCARRAY)
    If MSCARRAY > 0
      Call ECR_TRACE("EMHRMAJ90_LMRNG: Updating ATABZON on Misc Table number : " + num$(MSCARRAY(COUNTER) + 10000),0) From GESECRAN
      For [F:YTBZ] Where left$([F:YTBZ]EXPLIEN, 3) = num$(MSCARRAY(COUNTER)) & [F:YTBZ]CODTYP = "ADI"
        [F:YTBZ]EXPLIEN = "10" + [F:YTBZ]EXPLIEN
        Rewrite [F:YTBZ]
      Next
    Endif
  Next
  Close File [F:YTBZ]
Return

$UPDATE_SCREEN_REFERENCES
  If clalev([F:YAMSKP]) = 0 :Local File =LDOSSIER+".AMSKPAR" [YAMSKP] : Endif

  For COUNTER = 1 To maxtab(MSCARRAY)
    If MSCARRAY > 0
      Call ECR_TRACE("EMHRMAJ90_LMRNG: Updating AMSKPAR on Misc Table number : " + num$(MSCARRAY(COUNTER) + 10000),0) From GESECRAN
      Update [F:YAMSKP] Where [F:YAMSKP]VALPAR = num$(MSCARRAY(COUNTER)) & [F:YAMSKP]CODPAR = "ADI" With [F:YAMSKP]VALPAR = num$(MSCARRAY(COUNTER) + 10000)
    Endif
  Next
  Close File [F:YAMSKP]
Return

$ERRHANDLE
  Call ECR_TRACE("Error: " + num$(errn)-errmes$(errn)-errm, 1) From GESECRAN
  UPD_OK = 2
Resume #to return to instruction after onerrgo exception was encountered

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
  Call AMAJ_EMHRMAJ90_MSCRNG(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
  Call AMAJ_EMHRMAJ90_MSCRNG(APPLI)
End

