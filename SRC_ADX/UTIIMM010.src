################################################################################
# MOULINETTE POUR mettre à jour les listes de sélection des objets PHY PY2 PY3 PY4 PY7 #
# FQ 55430
################################################################################

##################################################################
#Comments(1)                                                     #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIIMM010: : Immo objects Update") From LECFIC
 Call EXE_UTIIMM010(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End


###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de EXE_UTIXXX                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcémment activer  #
#      tous les modules dans ses dossiers
#                                             
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################

Subprog EXE_UTIIMM010(APPLI)
Value Char APPLI()

Call ECR_TRACE("UTIIMM010 : Process Start on : "+APPLI,0) From GESECRAN
Local Integer MOK
#### Corps de la moulinette - début
##Doit s'executer sur tous les dossiers
Call MAJ_SEL(APPLI,"PHY") From PATCHAOB
Call MAJ_SEL(APPLI,"PY2") From PATCHAOB
Call MAJ_SEL(APPLI,"PY3") From PATCHAOB
Call MAJ_SEL(APPLI,"PY7") From PATCHAOB
Call VALID("PHY",APPLI,1,MOK) From VALOBJ
Call VALID("PY2",APPLI,1,MOK) From VALOBJ
Call VALID("PY3",APPLI,1,MOK) From VALOBJ
Call VALID("PY7",APPLI,1,MOK) From VALOBJ
Call VALID("OPHY",APPLI,1,MOK) From VALWIN

Call ECR_TRACE("UTIIMM010 : Process End on : "+APPLI,0) From GESECRAN
End

###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier GX (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
Local Integer GPHY

  If APPLI=adxmother(0) : End : Endif

  # On  regarde si le module Immobilisation est à "Oui"
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(13) <> 2 : End : Endif

  # On  regarde si le code activité PHY Elements Physiques pour le dossier est à "Oui"
  If !clalev([F:ADA]) : Local File ADOSACT  [ADA] : Endif
  Read [ADA]ADA0=APPLI;"PHY"                 : # Dossier avec Eléments physiques

  If fstat Then
    GPHY = G_OUI          : # Par défaut on gère les éléments physiques
  Else
    GPHY = [F:ADA]FLACT
  Endif

  If GPHY<>G_OUI : End : Endif

# If filinfo(filpath("FIL","PHYELT","fde",APPLI),0) < 0 : End : Endif

Call EXE_UTIIMM010(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Local Integer GPHY

  If APPLI=adxmother(0) : End : Endif

  # On  regarde si le module Immobilisation est à "Oui"
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(13) <> 2 : End : Endif

  # On  regarde si le code activité PHY Elements Physiques pour le dossier est à "Oui"
  If !clalev([F:ADA]) : Local File ADOSACT  [ADA] : Endif
  Read [ADA]ADA0=APPLI;"PHY"                 : # Dossier avec Eléments physiques

  If fstat Then
    GPHY = G_OUI          : # Par défaut on gère les éléments physiques
  Else
    GPHY = [F:ADA]FLACT
  Endif

  If GPHY<>G_OUI : End : Endif

# If filinfo(filpath("FIL","PHYELT","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM010(APPLI)
End

