########################################################
$CFGAZXXX
If (func ISMSKSCE(maskcou) & evalue("VALEUR="+W_PRQ+LQST))    # Mask scénario et pas de modif (sinon APRES_MODIF du champs)
    Gosub LASTTAB
Endif
Return

########################################################
# si tabulation et dernier champs alors équivalent à Click sur OK
#        (utiliser en Apres zone ou apres modif d'un champs question)
$LASTTAB
If dim([M]QSTLSTRNG)>0
    If evalue(W_PRR+LQST+"=[M]QSTLSTRNG")
       # Infbox num$(status) Sleep 2
       If status=1 | status=2   # TAB ou sortie suite à sélection (attention petite anomalie suite PF12)
         mkstat = 3: # Simule une action
         status = GSTAOK: # Le bouton OK
       Endif
    Endif
Endif
Return

##################################################
# Ecran d'un scénario ?
Funprog ISMSKSCE(LMSK)
Value Char LMSK
Local Integer WFLG
WFLG=0
If find(left$(LMSK,3),"WUX","WUY","ZUX","ZUY") : WFLG=1 : Endif
End WFLG

