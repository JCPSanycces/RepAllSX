############################################################
# Mise a jour derniere reponse donnee
$MAJ_MEMO
If S_CFGCFG = 1 & [F:CQU]QSTTYP = 1 & clalev([M:CFA0]) <= 0
  If dim(S_SUBSCE) > 0 & S_SUBSCE = ""
    Trbegin [CME]
  Endif
  Readlock [CME]CME0=0;S_SCENUM;GUSER;S_BPRNUM;S_BPRREF;[F:CQU]QSTNUM;0
  Case fstat
    When 0 :
      Case [F:CQU]ASWTYP
        When 1 : [F:CME]VALALP = VALEUR
        When 2 : [F:CME]VALNUM = VALEUR
        When 3 : [F:CME]VALDAT = VALEUR
        When 4 : [F:CME]VALNUM = VALEUR - 1
        When 5 : # FQ 49950 stocker tous les textes dans [F:CME]CLOB
                 #[F:CME]VALALP = W_ALP
                 #If len([F:CME]VALALP)>=200 # FQ 32446 GA 11/2008
                  If dim([F:CME]CLOB)>0 & dim(W_CLB)>0
                    [F:CME]CLOB = W_CLB
                    Call CLB_TO_CHAR([F:CME]VALALP,W_PRS+[F:CME]QSTNUM) From CFGLIBD # FQ 52104 GA 02/2009
                  Else
                    [F:CME]VALALP = W_ALP
                  Endif
        When 6 : If dim([F:CME]BLOB)>0 & dim(W_BLB)>0 [F:CME]BLOB= W_BLB Endif  # FQ 50451 GA 11/2008
        When 7 : If dim([F:CME]CLOB)>0 & dim(W_CLB)>0 [F:CME]CLOB= W_CLB Endif  # FQ 50451 GA 11/2008
      Endcase
      Rewrite [CME]
      If fstat
        fstat = 0
      Endif
    When 4,5 :
      Raz [F:CME], fstat
      [F:CME]RECCOD    = 0
      [F:CME]SCENUM    = S_SCENUM
      [F:CME]CFGBPRNUM = S_BPRNUM
      [F:CME]CFGBPRREF = S_BPRREF
      [F:CME]QSTNUM    = [F:CQU]QSTNUM
      Case [F:CQU]ASWTYP
        When 1 : [F:CME]VALALP = VALEUR
        When 2 : [F:CME]VALNUM = VALEUR
        When 3 : [F:CME]VALDAT = VALEUR
        When 4 : [F:CME]VALNUM = VALEUR - 1
        When 5 : # FQ 49950 stocker tous les textes dans [F:CME]CLOB
                 #[F:CME]VALALP = W_ALP
                 #If len([F:CME]VALALP)>=200 # FQ 32446 GA 11/2008
                  If dim([F:CME]CLOB)>0 & dim(W_CLB)>0
                    [F:CME]CLOB = W_CLB
                    Call CLB_TO_CHAR([F:CME]VALALP,W_PRS+[F:CME]QSTNUM) From CFGLIBD # FQ 52104 GA 02/2009
                  Else
                    [F:CME]VALALP = W_ALP
                  Endif
        When 6 : If dim([F:CME]BLOB)>0 & dim(W_BLB)>0 [F:CME]BLOB= W_BLB Endif  # FQ 50451 GA 11/2008
        When 7 : If dim([F:CME]CLOB)>0 & dim(W_CLB)>0 [F:CME]CLOB= W_CLB Endif  # FQ 50451 GA 11/2008
      Endcase
      [F:CME]PRONUM    = adxuid(1) # Issue 92289 GA 09/2013 before 0
      [F:CME]CREUSR    = GUSER
      [F:CME]CREDAT    = date$
      Write [CME]
      If fstat
        fstat = 0
      Endif
  Endcase
  Readlock [CME]CME1=1;adxuid(1);S_SCENUM;[F:CQU]QSTNUM
  Case fstat
    When 0 :
      Case [F:CQU]ASWTYP
        When 1 : [F:CME]VALALP = VALEUR
        When 2 : [F:CME]VALNUM = VALEUR
        When 3 : [F:CME]VALDAT = VALEUR
        When 4 : [F:CME]VALNUM = VALEUR - 1
        When 5 : # FQ 49950 stocker tous les textes dans [F:CME]CLOB
                 #[F:CME]VALALP = W_ALP
                 #If len([F:CME]VALALP)>=200 # FQ 32446 GA 11/2008
                  If dim([F:CME]CLOB)>0 & dim(W_CLB)>0
                    [F:CME]CLOB = W_CLB
                    Call CLB_TO_CHAR([F:CME]VALALP,W_PRS+[F:CME]QSTNUM) From CFGLIBD # FQ 52104 GA 02/2009
                  Else
                    [F:CME]VALALP = W_ALP
                  Endif
        When 6 : If dim([F:CME]BLOB)>0 & dim(W_BLB)>0 [F:CME]BLOB= W_BLB Endif  # FQ 50451 GA 11/2008
        When 7 : If dim([F:CME]CLOB)>0 & dim(W_CLB)>0 [F:CME]CLOB= W_CLB Endif  # FQ 50451 GA 11/2008
      Endcase
      Rewrite [CME]
      If fstat
        fstat = 0
      Endif
    When 4,5 :
      Raz [F:CME], fstat
      [F:CME]RECCOD    = 1
      [F:CME]SCENUM    = S_SCENUM
      [F:CME]CFGBPRNUM = ""
      [F:CME]CFGBPRREF = ""
      [F:CME]QSTNUM    = [F:CQU]QSTNUM
      Case [F:CQU]ASWTYP
        When 1 : [F:CME]VALALP = VALEUR
        When 2 : [F:CME]VALNUM = VALEUR
        When 3 : [F:CME]VALDAT = VALEUR
        When 4 : [F:CME]VALNUM = VALEUR - 1
        When 5 : # FQ 49950 stocker tous les textes dans [F:CME]CLOB
                 #[F:CME]VALALP = W_ALP
                 #If len([F:CME]VALALP)>=200 # FQ 32446 GA 11/2008
                  If dim([F:CME]CLOB)>0 & dim(W_CLB)>0
                    [F:CME]CLOB = W_CLB
                    Call CLB_TO_CHAR([F:CME]VALALP,W_PRS+[F:CME]QSTNUM) From CFGLIBD # FQ 52104 GA 02/2009
                  Else
                    [F:CME]VALALP = W_ALP
                  Endif
        When 6 : If dim([F:CME]BLOB)>0 & dim(W_BLB)>0 [F:CME]BLOB= W_BLB Endif  # FQ 50451 GA 11/2008
        When 7 : If dim([F:CME]CLOB)>0 & dim(W_CLB)>0 [F:CME]CLOB= W_CLB Endif  # FQ 50451 GA 11/2008
      Endcase
      [F:CME]PRONUM    = adxuid(1)
      [F:CME]CREUSR    = GUSER
      [F:CME]CREDAT    = date$
      Write [CME]
      If fstat
        fstat = 0
      Endif
  Endcase
  If dim(S_SUBSCE) > 0 & S_SUBSCE = ""
    Commit
  Endif
Endif
Return
############################################################
# ACTION Contrôle reponse avec table de contrôle
Subprog CFGCTRTAB(VALEUR,LQST)
Variable Char    VALEUR
Value    Char    LQST
Local    Integer W_ERR
Local    Char    WINT(250) : WINT = evalue(W_PRX+LQST)
Local    Char    WEVA(40)
Local    Char    W_VAR(GLONAVA)  # Issue 82300 (10)
mkstat   = 2
GMESSAGE = WINT-"("+LQST+")\"+num$(VALEUR)+" : "+mess(3,188,1)
W_ERR    = 0
#
Read [CQU]CQU0=LQST
If fstat = 0
  GPOINT = "CFGCTRTAB"
  GPE    = 0
  Gosub  ENTREE From EXEFNC
  If GPE = 0
    Case [F:CQU]ASWCHA
      When 1 : VALEUR = toupper(VALEUR)
      When 2 : VALEUR = tolower(VALEUR)
    Endcase
    If [F:CQU]CODFIC <> ""
      W_VAR = W_PRS+LQST
      Gosub CTR_TABLE From WUVAR
      If !(fstat = 0 | fstat = 1)
        # Issue 98847 GA 04/2014 control with ATABDIV
        If [F:CQU]CTLTYP=6
           GMESSAGE = VALEUR-mess(90,116,1)-"("+[F:CQU]OBJET+"/"+[F:CQU]CODFIC+")"
        Else
           GMESSAGE = VALEUR-mess(90,116,1)-"("+[F:CQU]CODFIC+")"
        Endif
      Else
        If [F:CQU]FILFIC <> ""
          Read [TFO]TFO0=7;[F:CQU]FILFIC
          If fstat = 0 & evalue([F:TFO]FORFOR)
            Raz GMESSAGE
          Endif
        Else
          If S_FILTER <> ""
            Gosub CTR_FILTER From WUVAR
            If fstat = 0
              Raz GMESSAGE
            Endif
          Else
            Raz GMESSAGE
          Endif
        Endif
      Endif
    Endif
  Endif
Endif
#
If GMESSAGE = ""
  mkstat = 0
  Assign W_PRS+LQST With VALEUR
  Gosub MAJ_MEMO
Endif
End
############################################################
Subprog CFGCTRSYM(VALEUR,LLIN,LTYP,LDES,LFCY)
Variable Char     VALEUR
Value    Char     LLIN
Value    Integer  LTYP
Variable Char     LDES
Value    Char     LFCY
#
Local    Char W_FIC(GLONATB) # JAMCC Issue X3-89202 05/2018
Local    Char W_ABR(10)
If dim(GABQASW) < 0
  Global Integer GABQASW
Endif
Case LTYP
  When 1 :
    Read [CQU]CQU0=VALEUR
    If fstat | (fstat = 0 & [F:CQU]QSTTYP <> 1) | (fstat = 0 & [F:CQU]QSTORI <> 1)
      mkstat = 2
    Else
      Call GET_ATEXTRA("CFGQST","QSTAXX",GLANGUE,LDES) From TRTX3TEX
      GABQASW = [F:CQU]ASWTYP
    Endif
  When 2 :
    Read [CQU]CQU0=VALEUR
    If fstat | (fstat = 0 & [F:CQU]QSTTYP <> 2)
      mkstat = 2
    Else
      Call GET_ATEXTRA("CFGQST","QSTAXX",GLANGUE,LDES) From TRTX3TEX
      GABQASW = [F:CQU]ASWTYP
    Endif
  When 3 :
    Call CFGCTRSCE(VALEUR,LFCY)
    If dim([M:CFG0]SCENUM) > 0 & VALEUR = [M:CFG0]SCENUM
      mkstat = 2
    Endif
  When 4 :
    Read [CSE]CSE0=VALEUR
    If fstat | (fstat= 0 & [F:CSE]SELTYP <> 1)
      mkstat = 2
    Else
      Call GET_ATEXTRA("CFGSEL","SELAXX",GLANGUE,LDES) From TRTX3TEX
    Endif
  When 5 :
    Read [CSE]CSE0=VALEUR
    If fstat | (fstat= 0 & [F:CSE]SELTYP <> 2)
      mkstat = 2
    Else
      Call GET_ATEXTRA("CFGSEL","SELAXX",GLANGUE,LDES) From TRTX3TEX
    Endif
  When 6 :
    Read [ATB]CODFIC=VALEUR
    If fstat
      mkstat = 2
    Else
      Call TEXTE([F:ATB]INTITFIC,LDES) From OBJDIV
    Endif
  When 7 :
    Read [CFM]CFM0=VALEUR;1
    If fstat
      mkstat = 2
    Else
        Call GET_ATEXTRA("CFGMAC","MACAXX",GLANGUE,LDES) From TRTX3TEX
    Endif
  When 8 :
    mkstat = 2
  When 9 :
    Read [CSH]CSH0=VALEUR
    If fstat
      mkstat = 2
    Else
    # FQ 60007 GA 11/2009 avant GET_ATEXTRA # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
    # Call LECTEXTRA(LDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
      Call LECTEXTRA(LDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,"") From ATEXTRA
    Endif
  When 10 :
  When 11 :
  When 12 :
  When 24, 25, 26, 27 :
    If find(VALEUR,"CSTMAT","CSTMAC","CSTLAB","CSTSCO","CSTOVE","CSTTOT")
      mkstat = 2
    Else
      Read [CQU]CQU0=VALEUR
      If fstat | (fstat = 0 & [F:CQU]QSTTYP <> 2)
        mkstat = 2
      Else
      Call GET_ATEXTRA("CFGQST","QSTAXX",GLANGUE,LDES) From TRTX3TEX
      Endif
    Endif
  When Default :
    If find(VALEUR,"EXPNUM","CREUSR","CREDAT","UPDUSR","UPDDAT")
      mkstat = 2
    Else
      Call CONV_FIC(LTYP,W_FIC,W_ABR)
      Read [ATZ]CODZONE=W_FIC;VALEUR
      If fstat
        mkstat = 2
        Filter [ATZ] Where CODFIC = W_FIC & left$(CODZONE,len(VALEUR))=toupper(VALEUR)
&                    Order By Key CODZONE
        For [ATZ]
          VALEUR = [F:ATZ]CODZONE
          Call FLD_TXT("","",LLIN,LDES) From CFGLIB
          mkstat = 0
          Break
        Next
        Filter [ATZ]
      Else
        If find([F:ATZ]CODTYP,"AXT")
          mkstat = 2
        Else
          Call FLD_TXT("","",LLIN,LDES) From CFGLIB
        Endif
      Endif
    Endif
Endcase
If mkstat = 2
  GMESSAGE = mess(LTYP,752,1)-VALEUR+" : "+mess(3,188,1)
Endif
End
############################################################
# Contrôle valeur indice champs dimensionnes
Subprog CFGCTRIND(LVAL,LTYP,LSYM)
Variable Decimal LVAL
Value    Integer LTYP
Value    Char    LSYM
Local    Integer W_DIM
#
If LVAL = 0
  mkstat = 2
  GMESSAGE = num$(LVAL)+" : "+mess(3,188,1)
Else
  W_DIM = [F:ATZ]DIME
  If [F:ATZ]CODACT <> ""
    Read [ACV]CODACT=[F:ATZ]CODACT
    If [F:ACV]DIME <> 0
      W_DIM = [F:ACV]DIME
    Endif
  Endif
  If LVAL > W_DIM
    mkstat = 2
    GMESSAGE = num$(LVAL)+" : "+mess(3,188,1)+" (1-"+num$(W_DIM)+")"
  Endif
Endif
End
############################################################
# Tunnel sur questions / variables en saisie de formule
Subprog CFGTUNCQU(LVAL,LVAR)
Variable Char LVAL
Variable Char LVAR
#
Local    Char WSYM(GLONAVA)
Local    Char WDMY(1)
Gosub CFG_PREFIXES From CFGLIB
Call OBJET("CQU",WSYM,"") From GOBJET
If WSYM <> ""
  If LVAL = ""
    LVAL = W_PRS+WSYM
  Else
    LVAL += " "+W_PRS+WSYM
  Endif
  Gosub TAB_SYMBOLES From WUVAR
  Call CFGSETFOR(7,"","",WDMY,WDMY,LVAR) From CFGLIB
Endif
End
############################################################
Subprog CONV_FIC(LTYP,LFIC,LABR)
Value    Integer LTYP
Variable Char    LFIC
Variable Char    LABR
LFIC = ""
Case LTYP
  When 13  : LFIC = "ITMMASTER"   : LABR = "[F:ITM]"
  When 14  : LFIC = "ITMFACILIT"  : LABR = "[F:ITF]"
  When 15  : LFIC = "ITMMVT"      : LABR = "[F:ITV]"
  When 16  : LFIC = "ITMSALES"    : LABR = "[F:ITS]"
  When 17  : LFIC = "BOM"         : LABR = "[F:BOH]"
  When 18  : LFIC = "BOMD"        : LABR = "[F:BOD]"
  When 19  : LFIC = "ROUTING"     : LABR = "[F:ROH]"
  When 20  : LFIC = "ROUOPE"      : LABR = "[F:ROO]"
  When 21  : LFIC = "ITMBPC"      : LABR = "[F:ITU]"
  When 22  : LFIC = "ROUSCD"      : LABR = "[F:ROS]"
  When 23  : LFIC = "ITMCOST"     : LABR = "[F:ITC]"
  When 28  : LFIC = "ITMBPS"      : LABR = "[F:ITP]"
Endcase
End
############################################################
# LTYP  = Type de formules ( 7 pour le moment)
# LLIN  = Ligne de produit pour conversion textes
# LPAR  = Code tables autorisees
#         "I" : "ITMMASTER"+"ITMFACILIT"+"ITMMVT"+"ITMSALES"+"ITMBPC"+"ITMCOST"+"ITMBPS"
#         "B" : "BOM"+"BOMD"
#         "R" : "ROUTING"+"ROUOPE"
#         "*" : Toutes les tables
# LFIL  = Tableau des tables
# LTEX  = Tableau des textes a convertir
# LVAR  = variables locales a ajouter
#
Subprog CFGSETFOR(LTYP,LLIN,LPAR,LFIL,LTEX,LVAR)
Value    Integer LTYP
Value    Char    LLIN
Value    Char    LPAR
Variable Char    LFIL()
Variable Char    LTEX()
Variable Char    LVAR()
#
Local    Char    W_VAR(GLONAVA)  # Issue 82300 (10)
Local    Char    W_CON(40)
Local    Char    W_SRT(20)(dim(LVAR))
Local    Char    W_TXT(250)
Local    Integer W_I, W_J, W_K, W_L
#
Gosub CFG_PREFIXES
Gosub TAB_SYMBOLES From WUVAR
#
If dim(LVAR) > 0
  W_J = 0
  Raz LVAR
  For W_I = 0 To dim(W_VARLAB) -1
    If W_J < dim(LVAR)-1
      If evalue("dim("+W_PRX+mid$(W_VARLAB(W_I),3,GLONCQU)+")<0")
        W_VAR = W_PRX+mid$(W_VARLAB(W_I),3,GLONCQU)
        Gosub CRE_SYMTXT From WUVAR
      Endif
      LVAR(W_J)  = W_VARLAB(W_I)+" ,"+evalue(W_PRX+mid$(W_VARLAB(W_I),3,GLONCQU))-mid$(W_VARLAB(W_I),3,GLONCQU)-
&                  mess(val(mid$(W_VARATT(W_I),2,1)),769,1)
      W_SRT(W_J) = evalue(W_PRX+mid$(W_VARLAB(W_I),3,GLONCQU))
      W_J += 1
    Else
      Break
    Endif
  Next W_I
Endif
Sorta W_J LVAR Order By W_SRT (indice)
#
If LLIN <> ""
  If clalev([F:TLP]) = 0 : Local File TABLINCFG   [TLP] : Endif
  W_I = 0
  Read [TLP]TLP0=LLIN
  If fstat = 0
    W_K = 1
    While evalue("dim([F:TLP]CFGNUM"+num$(W_K)+")>0")
      W_L = evalue("[F:TLP]CFGNUM"+num$(W_K))
      If W_L > 1
        Call ATT_TXT(W_L,W_TXT)
        W_CON = "CFGFLDNUM"+num$(W_K)+","+W_TXT
      Endif
      W_K += 1
    Wend
    W_K = 1
    While evalue("dim([F:TLP]CFGALP"+num$(W_K)+")>0")
      W_L = evalue("[F:TLP]CFGALP"+num$(W_K))
      If W_L > 1
        Call ATT_TXT(W_L,W_TXT)
        W_CON = "CFGFLDALP"+num$(W_K)+","+W_TXT
      Endif
      W_K += 1
    Wend
  Endif
Endif
If LPAR <> ""
  Call CFGSETTBL(LPAR,LFIL) From CFGLIB
Endif
End
############################################################
$LOA_TEXCON
If W_I < dim(LTEX)-1
  LTEX(W_I) = "ITMMASTER,"+W_CON
  W_I += 1
Endif
Return
############################################################
# LPAR  = Code tables autorisees
#         "D" : ITMMASTER --> "L" ITMBPC"
#         "*" : Toutes les tables
# LFIL  = Tableau des tables
#
Subprog CFGSETTBL(LPAR,LFIL)
Value    Char    LPAR
Variable Char    LFIL()
#
Local    Char    W_F(10)
Local    Integer W_I, W_J
W_J = dim(LFIL)
# Effacement anciennes valeurs de tables
For W_I = 0 To W_J-1
  LFIL(W_I) = ""
Next W_I
#
# Chargement nouvelles valeurs de tables
W_I = 0
W_F = "BPARTNER"  : Gosub LOA_TBLNAM
If instr(1,LPAR,"*") | instr(1,LPAR,"D")
  W_F = "ITMMASTER"  : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"E")
  W_F = "ITMFACILIT" : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"F")
  W_F = "ITMMVT"     : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"G")
  W_F = "ITMSALES"   : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"H")
  W_F = "BOM"        : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"I")
  W_F = "BOMD"       : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"J")
  W_F = "ROUTING"    : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"K")
   W_F = "ROUOPE"     : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"L")
   W_F = "ITMBPC"     : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"M")
   W_F = "ROUSCD"     : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"N")
   W_F = "ITMCOST"    : Gosub LOA_TBLNAM
Endif
If instr(1,LPAR,"*") | instr(1,LPAR,"S")
   W_F = "ITMBPS"     : Gosub LOA_TBLNAM
Endif
End
############################################################
$LOA_TBLNAM
If W_I < W_J -1
  LFIL(W_I) = W_F
  W_I += 1
Endif
Return
############################################################
# Contrôle formules
# LFOR = Formule saisie
# LFIC = Zone dimensionnee contenant les tables autorisees
# LTYP = Type de symbole (menu local 752)
# LCTR = Type de formule 0 libre / 1 condition / 2 calcul
#
Subprog CFGCTRFOR(LFOR,LFIC,LTYP,LCTR)
Variable Char     LFOR
Variable Char     LFIC()
Value    Integer  LTYP
Value    Integer  LCTR
#
Local Char W_CARLAB(37)  : W_CARLAB = "ABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789"
# Si expression type message / lien table / point d'entree
If LCTR = 2
  Case LTYP
    When 6  :
      If LFOR = ""
        mkstat = 2
      Endif
      End
    When 8 :
      If LFOR = ""
        mkstat = 2
      Endif
      End
    When 11 :
      End
    When 12 :
      LFOR = vireblc(toupper(LFOR),4)
      If len(LFOR) < 3 | left$(LFOR,1) <> '"' | right$(LFOR,len(LFOR)) <> '"'
        mkstat = 2
      Else
        For W_T = 2 To len(LFOR)-1
          If !instr(1,W_CARLAB,mid$(LFOR,W_T,1))
            mkstat = 2
            Break
          Endif
        Next W_T
      Endif
      If mkstat = 2
        GMESSAGE = mess(74,188,1)
      Endif
      End
  Endcase
Endif
#
If LFOR <> ""
  Gosub CFG_CONSTANTES
  W_ALP = " "
  W_NUM = 1
  W_DAT = date$
  Local    Integer  W_I, W_J, W_K
#
  If clalev([F:ATB]) = 0 : Local File ATABLE  [ATB] : Endif
#
# Creation des tous les symboles et initialisation
  Gosub TAB_SYMBOLES From WUVAR
  For W_I = 0 To dim(W_VARLAB)-1
    W_VAR = W_VARLAB(W_I)
    Gosub CRE_SYMBOLE From WUVAR
    Gosub SET_SYMBOLE From WUVAR
  Next W_I
# Ouverture des tables
  For W_I= 0 To dim(LFIC)-1
    If LFIC(W_I) <> ""
      Gosub OUVRE_FIC
    Endif
  Next W_I
#
  Onerrgo CTR_PASBON
  W_RES = num$(evalue(LFOR))
  Onerrgo
  For W_I = 0 To dim(W_VARLAB)-1
    W_VAR = W_VARLAB(W_I)
    Gosub SUP_SYMBOLE From WUVAR
  Next W_I
  If GMESSAGE <> ""
    Call MESSAGE(GMESSAGE) From GESECRAN
    GMESSAGE = ""
  Endif
Endif
End
#
$CTR_PASBON
W_EVA    = format$("KT:80X",errm)
W_EVA    = vireblc(W_EVA,1)
GMESSAGE =  W_EVA-errmes$(errn)
Resume
End
############################################################
$OUVRE_FIC
Local Shortint WTYPE
Read [ATB]CODFIC=LFIC(W_I)
If fstat = 0
  W_ABR = "[F:"+[F:ATB]ABRFIC+"]"
  If evalue("clalev("+W_ABR+")")=0
    Local File =LFIC(W_I)
    W_K = evalue("dim([G:"+[F:ATB]ABRFIC+"]adxfname)")
    For W_J = 0 To W_K -1
    # Issue 90022 GA 06/2013 contourner bug plateforme
      If !find(evalue("[G:"+[F:ATB]ABRFIC+"]adxfname("+num$(W_J)+")"),"~W")
        W_EVA = W_ABR+evalue("[G:"+[F:ATB]ABRFIC+"]adxfname("+num$(W_J)+")")
        WTYPE = evalue("type("+W_EVA+")")
        Case WTYPE
          When 1,2,4,5,6,7,9 : Assign W_EVA With 1
          When 3             : Assign W_EVA With date$
          When Default       :
               If WTYPE>=10 & WTYPE<522 # Issue 93006 GA 11/2013
                  Assign W_EVA With ""
               Endif
        Endcase
      Endif
    Next
  Endif
Endif
Return
Return
############################################################
# Contrôle saisie scenarios
# LMSK = Masque sous forme [M:CFGX]
# LBTA = Zone bas de tableau sous forme [M:CFGX]NBLIGX
# LMSG = Message retour
#
Subprog CFG_CTRSAI(LMSK,LBTA,LMSG)
Value    Char    LMSK
Value    Char    LBTA
Variable Char    LMSG
#
Local    Integer W_I, W_J, W_K
Local    Char    W_ETYP(40) : W_ETYP = LMSK+"SYMTYP(W_I)"
Local    Char    W_ESMB(40) : W_ESMB = LMSK+"SYMNUM(W_I)"
Local    Char    W_EFOR(40) : W_EFOR = LMSK+"FORFOR(W_I)"
Local    Char    W_EABQ(40) : W_EABQ = LMSK+"ABQNUM(W_I)"
# FQ 53410 remplacé par lien
#Local    Char    W_ETXT(40) : W_ETXT = LMSK+"SYMDES(W_I)"
Local    Integer W_TYP
Local    Char    W_SMB(GLONAVA)  # Issue 82300 (10)
# Contrôle presence d'une expression formule
For W_I = 0 To evalue(LBTA)-1
  W_TYP  = evalue(W_ETYP)
  W_SMB  = evalue(W_ESMB)
  If W_TYP = 2 | W_TYP = 8 | W_TYP > 9
    If evalue(W_EFOR) = "" & evalue(W_EABQ) = ""
      If LMSG = ""
        LMSG = mess(33,188,1)
      Endif
    # FQ 53410 remplacé par lien
    #  LMSG += ("\"+mess(W_TYP,752,1)-W_SMB)-evalue(W_ETXT)
      LMSG += ("\"+mess(W_TYP,752,1)-W_SMB)-evalue(W_ESMB)
    Endif
  Endif
Next W_I
End
############################################################
# Determination  intitule symbole
# LDES = Intitule a determiner
# LTYP = Type de symbole
# LNUM = Symbole
# LLIN = Ligne de produit (pour personalisation) facultatif
#
Subprog SYM_TXT(LDES,LTYP,LNUM,LLIN)
Variable Char    LDES
Value    Integer LTYP
Value    Char    LNUM
Value    Char    LLIN
LDES = ""
Case LTYP
  When 1, 2, 24, 25, 26, 27 :
    If clalev([F:CQU]) = 0 : Local File CFGQST [CQU] : Endif
    Read [CQU]CQU0=LNUM
    If fstat = 0
      Call GET_ATEXTRA("CFGQST","QSTAXX",GLANGUE,LDES) From TRTX3TEX
    Endif
  When 3 :
    If clalev([F:CSC]) = 0 : Local File CFGSCE [CSC] : Endif
    Read [CSC]CSC0=LNUM
    If fstat = 0
      Call GET_ATEXTRA("CFGSCE","SCEAXX",GLANGUE,LDES) From TRTX3TEX
    Endif
  When 4, 5 :
    If clalev([F:CSE]) = 0 : Local File CFGSEL [CSE] : Endif
    Read [CSE]CSE0=LNUM
    If fstat = 0
      Call GET_ATEXTRA("CFGSEL","SELAXX",GLANGUE,LDES) From TRTX3TEX
    Endif
  When 6 :
    If clalev([F:ATB]) = 0 : Local File ATABLE [ATB] : Endif
    If clalev([F:ATX]) = 0 : Local File ATEXTE [ATX] : Endif
    Read [ATB]CODFIC=LNUM
    If fstat = 0
      Call TEXTE([F:ATB]INTITFIC,LDES) From OBJDIV
    Endif
  When 7 :
    If clalev([F:CFM]) = 0 : Local File CFGMAC [CFM] : Endif
    Read [CFM]CFM0=LNUM;1
    If fstat = 0
        Call GET_ATEXTRA("CFGMAC","MACAXX",GLANGUE,LDES) From TRTX3TEX
    Endif
  When 8 :
    LDES = mess(8,752,1)
  When 9 :
    If clalev([F:CSH]) = 0 : Local File CFGSHA [CSH] : Endif
    Read [CSH]CSH0=LNUM
    If fstat = 0
    # FQ 60007 GA 11/2009 avant GET_ATEXTRA # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
    # Call LECTEXTRA(LDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
      Call LECTEXTRA(LDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,"") From ATEXTRA
    Endif
  When 10 :
    LDES = ""
  When 11 :
    LDES = ""
  When 12 :
    LDES = ""
  When Default :
    If clalev([F:ATZ]) = 0 : Local File ATABZON [ATZ] : Endif
    Local Char W_FIC(GLONATB) # JAMCC Issue X3-89202 05/2018
    Local Char W_ABR(10)
    Call CONV_FIC(LTYP,W_FIC,W_ABR)
    Read [ATZ]CODZONE=W_FIC;LNUM
    If fstat = 0
      Call FLD_TXT("","",LLIN,LDES) From CFGLIB
    Endif
Endcase
End
############################################################
# Determination intitule champs avec conversion eventuelle par ligne de produit
# LTAB = Table ( "" si ATABZON deja charge)
# LZON = Champ ( "" si ATABZON deja charge)
# LLIN = Ligne de produit pour table ITMMASTER (facult)
# LTXT = Intitule retourne
Subprog FLD_TXT(LTAB,LZON,LLIN,LTXT)
Value    Char LTAB
Value    Char LZON
Value    Char LLIN
Variable Char LTXT
#
Local    Integer W_I
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:TLP]) = 0 : Local File TABLINCFG [TLP] : Endif
If LTAB <> ""
  Read [ATZ]CODZONE=LTAB;LZON
  If fstat
    LTXT = ""
    End
  Endif
Endif
Call TEXTE([F:ATZ]NOCOURT,LTXT) From OBJDIV
#
If [F:ATZ]CODFIC = "ITMMASTER" & left$([F:ATZ]CODZONE,6) = "CFGFLD" & LLIN <> ""
  If LLIN <> [F:TLP]CFGLIN
    Read [TLP]TLP0=LLIN
    If fstat
      Raz [F:TLP]
     Endif
  Endif
  Case mid$([F:ATZ]CODZONE,7,3)
    When "NUM" :
      If evalue("[F:TLP]CFGNUM"+mid$([F:ATZ]CODZONE,10,1)) <> 1
        W_I = evalue("[F:TLP]CFGNUM"+mid$([F:ATZ]CODZONE,10,1))
        Call ATT_TXT(W_I,LTXT)
      Endif
    When "ALP" :
      If evalue("[F:TLP]CFGALP"+mid$([F:ATZ]CODZONE,10,1)) <> 1
        W_I = evalue("[F:TLP]CFGALP"+mid$([F:ATZ]CODZONE,10,1))
        Call ATT_TXT(W_I,LTXT)
      Endif
  Endcase
Endif
End
############################################################
# Texte attribut ligne de produit
Subprog ATT_TXT(LATT,LTXT)
Value     Integer LATT
Variable  Char LTXT
LTXT = mess(LATT,760,1)
End
############################################################
# Chargement symboles contenus dans une expression dans un tableau
# LPAR  = Parametre 1 = questions 2 = variables 12 questions + variables
# LFOR  = Expression (dimensionnee ou pas)
# LSYM  = Tableau de rangement des symboles
# LIND  = Indice premier libre du tableau  (0..
#
# Attention les variables W_VARLAB doivent exister (TAB_SYMBOLES)
#
Subprog LOA_SYMBOLES(LPAR,LFOR,LSYM,LIND)
Value    Char     LPAR
Value    Char     LFOR()
Variable Char     LSYM()
Variable Decimal  LIND
Local    Integer  W_I
#
Local    Integer  W_J, W_K, W_L
Local    Char     W_FOR(250), W_NEXTCAR(1)     # JPJ E20134
#
Local    Integer  X_J, X_K, X_L
Local    Char     X_FOR(250), X_NEXTCAR(1)     # JPJ E20134
#
If dim(LFOR) = 1
  W_FOR = format$("KT:250X",LFOR)
  Gosub LOA_SYMBOLES_1
Else
  For W_I = 0 To dim(LFOR) -1
    W_FOR = format$("KT:250X",LFOR(W_I))
    Gosub LOA_SYMBOLES_1
  Next I
Endif
End
############################################################
$LOA_SYMBOLES_1
If W_FOR <> ""
  For W_J = 0 To Z_VARNBR-1
    W_K = instr(1,W_FOR,Z_VARLAB(W_J))
    If W_K <> 0
      W_L = find(mid$(Z_VARLAB(W_J),3,GLONCQU),LSYM(0..LIND))
      If W_L = 0 & LIND < dim(LSYM)-1
        # Vérification si pas un symbole de même racine   JPJ E20134 ->
        W_NEXTCAR=mid$(W_FOR, W_K+len(Z_VARLAB(W_J)),1)
        If not(W_NEXTCAR >= "A" & W_NEXTCAR <= "Z" | W_NEXTCAR >= "0" & W_NEXTCAR <= "9")
            Read [CQU]CQU0=mid$(Z_VARLAB(W_J),3,GLONCQU)
            If fstat = 0 & instr(1,LPAR,num$([F:CQU]QSTTYP))
              LSYM(LIND) = mid$(Z_VARLAB(W_J),3,GLONCQU)
              LIND += 1
              If [F:CQU]EVADEFVAL <> ""
                X_FOR = format$("KT:250X",[F:CQU]EVADEFVAL)
                Gosub LOA_SYMBOLES_2
              Endif
           Endif
        Endif      # JPJ E20134 <-
      Endif
      W_FOR = left$(W_FOR,W_K-1)+mid$(W_FOR,W_K+len(Z_VARLAB(W_J)),len(W_FOR))
    Endif
  Next W_J
Endif
Return
############################################################
$LOA_SYMBOLES_2
If X_FOR <> ""
  For X_J = 0 To Z_VARNBR-1
    X_K = instr(1,X_FOR,Z_VARLAB(X_J))
    If X_K <> 0
      X_L = find(mid$(Z_VARLAB(X_J),3,GLONCQU),LSYM(0..LIND))
      If X_L = 0 & LIND < dim(LSYM)-1
        # Vérification si pas un symbole de même racine   JPJ E20134 ->
        W_NEXTCAR=mid$(W_FOR, W_K+len(Z_VARLAB(W_J)),1)
        If not(W_NEXTCAR >= "A" & W_NEXTCAR <= "Z" | W_NEXTCAR >= "0" & W_NEXTCAR <= "9")
            Read [CQU]CQU0=mid$(Z_VARLAB(X_J),3,GLONCQU)
            If fstat = 0 & instr(1,LPAR,num$([F:CQU]QSTTYP))
              LSYM(LIND) = mid$(Z_VARLAB(X_J),3,GLONCQU)
              LIND += 1
              If [F:CQU]EVADEFVAL <> ""
                X_FOR = format$("KT:250X",[F:CQU1]EVADEFVAL)
                Gosub LOA_SYMBOLES_2
              Endif
            Endif
        Endif      # JPJ E20134 <-
      Endif
      X_FOR = left$(X_FOR,X_K-1)+mid$(X_FOR,X_K+len(Z_VARLAB(X_J)),len(X_FOR))
    Endif
  Next X_J
Endif
Return
############################################################
Subprog SET_VALCPT(LCPT,LFCY,LDAT,LCMP,LVAL,LRET)
Value    Char     LCPT
Value    Char     LFCY
Value    Date     LDAT
Value    Char     LCMP
Variable Char     LVAL
Variable Integer  LRET
# Rappel: la gestion de GOK est faite après les Call TRT_SYMBOLE dans LIBC avec S_UPDMOD=2
#
If clalev([F:ANM]) = 0 : Local File ACODNUM   [ANM] : Endif
If clalev([F:AVN]) = 0 : Local File AVALNUM   [AVN] : Endif
Case S_UPDMOD
  When 1, 2 :
    Call NUMERO(LCPT,LFCY,LDAT,LCMP,LVAL,LRET) From SUBANM
    If GOK = 0
        Gosub TRA_ERR From CFGLIBB    # Affichage qui déclenche le suivi en trace
    Endif
    #If GUSER="JPJ1" : Infbox "Lock SET_VALCPT - Compteur"-LCPT-"GOK"-num$(GOK) : Endif
  When Default :
    Read [ANM]ANM0=LCPT
    If fstat = 0
      LVAL = string$([F:ANM]LNG,"X")
    Else
      LVAL = string$(len(LVAL),"?")
    Endif
Endcase
End
############################################################
# Controle table autorisee
Subprog CFGCTRTBL(LVAL,LFIC)
Variable   Char LVAL
Value      Char LFIC()
#
If !find(LVAL,LFIC(0..dim(LFIC)-1))
  mkstat = 2
Endif
End
############################################################
# Chargement libellé code table de contrôle (selon langue)
# Buffer [F:TCT] Charge
# LTXT = Texte
# LFLD = Nom du champ (DESCOD .. DESCOD9)
Subprog CFGDESTCT(LTXT,LFLD)
Variable Char LTXT
Variable Char LFLD
#
Local Integer W_I
#
LTXT = [F:TCT]DESCOD
LFLD = "DESCOD"
# FQ 55365 GA 09/2009 les colonnes restent dans la table si code activité désactivé
#If dim([F:TCT]LANNBR) > 0
Local Integer WRET
Call LECACT("CFG",WRET) From TRTX3
If WRET=1 & dim([F:TCT]LANNBR) > 0
  For W_I = 0 To dim([F:TCT]LAN)-1
    If GLANGUE = [F:TCT]LAN(W_I)
      If W_I = 0
        LTXT = [F:TCT]DESCOD
      Else
        LTXT = evalue("[F:TCT]DESCOD"+num$(W_I))
        LFLD = "DESCOD"+num$(W_I)
      Endif
      Break
    Endif
  Next W_I
Endif
End
############################################################
# Chargement intitule table de contrôle code selon langue
# Buffer [F:TCT] Charge
# LTXT = Texte
Subprog CFGTITTCT(LTXT)
Variable Char LTXT
#
  Call LECTEXTRA(LTXT,"TABCTL","TCTDESAXX",[F:TCT]TCT,"") From ATEXTRA
End
