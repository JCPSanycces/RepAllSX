############################################################
# Fenetre de selection des traitements std (pour scenarios)
############################################################
$S_SELMAC
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:CFM]) = 0 : Local File CFGMAC    [CFM]  : Endif
#
TIT(0) = mess(7,752,1)
START  = "MACNUM"
NBCOL += 1 : COL(NBCOL) = "[F:CFM]MACNUM"
Call TEXTFIC("CFGMAC","MACNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("CFGMAC","MACAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:CFM]MACCOD,768,1)"
Call TEXTFIC("CFGMAC","MACCOD",2,TIT(NBCOL)) From OBJDIV
#
Link [CFM] With [AXX]AXX0="CFGMAC";"MACAXX";GLANGUE;[F:CFM]MACNUM;""
&          As [LNK]
# FQ 67955 GA 10/2010
#CRITERE = "[F:CFM]MACLIN=1&[F:CFM]MACNUM>=VALEUR"
CRITERE = '[F:CFM]MACLIN=1&[F:CFM]MACNUM>="'+num$(VALEUR)+'"'
ORDRE   = "MACNUM"
SIZLIG = 100
SIZCOL = 130
DEFPAG  = 1  # FQ 67955 GA 10/2010 pour la pagination
Default File [LNK]
Return
############################################################
# Fenetre de selection des categories de formes
############################################################
$S_SELSHA
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:CSH]) = 0 : Local File CFGSHA    [CSH]  : Endif
#
TIT(0) = mess(9,752,1)
START  = "SHACAT"
NBCOL += 1 : COL(NBCOL) = "SHACAT"
Call TEXTFIC("CFGSHA","SHACAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("CFGSHA","SHACATAXX",2,TIT(NBCOL)) From OBJDIV
#
# FQ 63171 GA 03/2010 pb s/texte associé à la Forme
#Link [CSH] With [AXX]AXX0="CFGSHA";"SHACATAXX";GLANGUE;[F:CSH]SHACAT;[F:CSH]SHANUM
Link [CSH] With [AXX]AXX0="CFGSHA";"SHACATAXX";GLANGUE;[F:CSH]SHACAT;""
&          As [LNK]

CRITERE = "[F:CSH]SHAFLG=0"
ORDRE   = ""
SIZLIG = 100
SIZCOL = 130
Default File [LNK]
Return
############################################################
# Fenetre de selection des formes ouverture automatique
# Appelé en AS_XXXX sur une F&M (Fenêtre de Questions ou non)
############################################################
$S_SELSHC
VALEUR=tolower(VALEUR) # Issue 94871 GA 12/2013 le code F&M passe en minuscules pour forcer le AM du champ
If dim(S_WINAUT) > 0
  If S_WINAUT <> 2
    OK=0      # JPJ E19458
    Return
  Endif
Else
  OK=0      # JPJ E19458
  Return
Endif
Goto S_SELSHB
############################################################
# Fenetre de selection des formes
############################################################
$S_SELSHB
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:CSH]) = 0 : Local File CFGSHA    [CSH]  : Endif
#
Local Char WSHACAT(GLONTCT) : WSHACAT = PARAM(1)
Local Char WSHANUM(GLONTCT) : WSHANUM = toupper(VALEUR)
If WSHANUM<>""
   Read [CSH]CSH0=WSHACAT;WSHANUM
Else
   Read [CSH]CSH0=WSHACAT
Endif
If fstat = 0
# FQ 60007 GA 11/2009 avant GET_ATEXTRA # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
# Call LECTEXTRA(TIT(0),"CFGSHA","SHACATAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
  Call LECTEXTRA(TIT(0),"CFGSHA","SHACATAXX",[F:CSH]SHACAT,"") From ATEXTRA
  TIT(0) = [F:CSH]SHACAT-TIT(0)
Endif

NBCOL += 1 : COL(NBCOL) = "SHANUM"
Call TEXTFIC("CFGSHA","SHANUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("CFGSHA","SHANUMAXX",2,TIT(NBCOL)) From OBJDIV
#
Link [CSH] With [AXX]AXX0="CFGSHA";"SHANUMAXX";GLANGUE;[F:CSH]SHACAT;[F:CSH]SHANUM
&          As [LNK]

EXPSTART = "[F:CSH]SHANUM>=WSHANUM"
# FQ 67955 GA 10/2010
#CRITERE  = "[F:CSH]SHACAT=WSHACAT"
CRITERE  = '[F:CSH]SHACAT="'+WSHACAT+'"'
If dim(S_CFGCFG) > 0 & S_CFGCFG > 0
  Call LOA_FILSHA([F:CSH]SHACAT,CRITERE)
Endif
ORDRE    = ""
SIZLIG   = 100
SIZCOL   = 130
DEFPAG  = 1  # FQ 67955 GA 10/2010 pour la pagination
Default File [LNK]
Return
############################################################
# Fenetre de selection des scenarios
############################################################
$S_SELSCE
Local Char W_FCY(GLONFCY) : W_FCY = PARAM(1)
$S_SELSCES
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:CSC]) = 0 : Local File CFGSCE    [CSC]  : Endif
#
TIT(0) = mess(1,188,1)
START  = "SCENUM"
NBCOL += 1 : COL(NBCOL) = "[F:CSC]SCENUM"
Call TEXTFIC("CFGSCE","SCENUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("CFGSCE","SCEAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:CSC]FCY"
Call TEXTFIC("CFGSCE","FCY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:CSC]BOMALT"
Call TEXTFIC("CFGSCE","BOMALT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:CSC]ROUALT"
Call TEXTFIC("CFGSCE","ROUALT",2,TIT(NBCOL)) From OBJDIV
#
Link [CSC] With [AXX]AXX0="CFGSCE";"SCEAXX";GLANGUE;[F:CSC]SCENUM;""
&          As [LNK]

# FQ 64217 GA 04/2010 "Erreur sur critère de sélection" "Indice incorrect"
# ce filtrage ne fonctionne plus sur l'objet CFG
### If W_FCY = ""
###    CRITERE = "[F:CSC]ENAFLG=2&[F:CSC]SCENUM>=VALEUR"
### Else
###    CRITERE = "([F:CSC]FCY=W_FCY|[F:CSC]FCY='')&[F:CSC]ENAFLG=2&[F:CSC]SCENUM>=VALEUR"
### Endif
# Issue 105345 GA 03/2015 filter on current site if already chosen
If W_FCY <> ""
    CRITERE(1)= '(FCY="'+W_FCY+'" | FCY= "")'
Endif

ORDRE  = ""
SIZLIG = 100
SIZCOL = 180
OBJET  = "CFG"     # CCC (22/06/07) Bug 41913 : Gestion des rôles
DEFPAG = 1  # FQ 67955 GA 10/2010 pour la pagination
Default File [LNK]
Return
############################################################
# Fenetre de selection des alternatives nomenclatures com.
############################################################
$S_SELNOC
Local Char    WITM(GLONITM) : WITM = PARAM(1)
Local Date    WDAT          : WDAT = PARAM(2)
Local Integer WALT(100)
Local Integer IALT
#
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO]  : Endif
If clalev([F:BOH]) = 0 : Local File BOM       [BOH]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif  # FGR 16/09/2009 : X3SUIVI57824
#
Filter [BOH] Where ITMREF    = WITM   &
&                  BOMALTTYP = 1      &
&   ([F:BOH]BOHSTRDAT = [0/0/0] | ([F:BOH]BOHSTRDAT <> [0/0/0] & [F:BOH]BOHSTRDAT <= WDAT)) &
&   ([F:BOH]BOHENDDAT = [0/0/0] | ([F:BOH]BOHENDDAT <> [0/0/0] & [F:BOH]BOHENDDAT >= WDAT))
&            Order By Key BOH0
For [BOH]
  If IALT < dim(WALT)
    WALT(IALT) = [F:BOH]BOMALT
    IALT += 1
  Else
    Break
  Endif
Next
Filter [BOH]

# FGR 16/09/2009 : X3SUIVI57824
Link [TBO] With [AXX]AXX0="TABBOMALT";"TBODESAXX";GLANGUE;num$([F:TBO]BOMALTTYP);num$([F:TBO]BOMALT) As [LNK]

TIT(0) = ""
START  = ""
NBCOL += 1 : COL(NBCOL) = "BOMALT"
Call TEXTFIC("TABBOMALT","BOMALT",2,TIT(NBCOL)) From OBJDIV

# FGR 16/09/2009 : X3SUIVI57824
#NBCOL += 1 : COL(NBCOL) = "TBODES"
#Call TEXTFIC("TABBOMALT","TBODES",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("TABBOMALT","TBODESAXX",2,TIT(NBCOL)) From OBJDIV

#
CRITERE = "find([F:TBO]BOMALT,WALT(0..IALT-1))"
ORDRE  = ""
SIZLIG = 80
SIZCOL = 130
DEFPAG = 1  # FQ 67955 GA 10/2010 pour la pagination

# FGR 16/09/2009 : X3SUIVI57824
#Default File [TBO]
Default File [LNK]
Return

############################################################
# Fenetre de selection des formules
############################################################
$S_SELFOR
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR    [TFO]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
#
TIT(0) = mess(88,198,1)
START  = "FORCOD"
NBCOL += 1 : COL(NBCOL) = "[F:TFO]FORCOD"
Call TEXTFIC("TABFOR","FORCOD",2,TIT(NBCOL)) From OBJDIV
# Issue 63311 GH 07/03/2018 - Crashed with non existent variable
#NBCOL += 1 : COL(NBCOL) = "FORDES"
#Call TEXTFIC("TABFOR","FORDES",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("TABFOR","DES",2,TIT(NBCOL)) From OBJDIV

CRITERE = "[F:TFO]FORTYP=7"
ORDRE   = ""
SIZLIG = 100
SIZCOL = 110
DEFPAG = 1  # FQ 67955 GA 10/2010 pour la pagination
Link [TFO] With [AXX]AXX0="TABFOR";"DES";GLANGUE;[F:TFO]FORNUM;[F:TFO]FORCOD
&          As [LNK]
Default File [LNK]
#Default File [TFO]
Return
############################################################
$V_SELFOR
Read [TFO]TFO0=7;[F:TFO]FORCOD
If fstat = 0
  PARAM(1) += [F:TFO]FORFOR
Endif
Return
############################################################
# Fenetre de selection des selections / options & variantes
############################################################
$S_SELSEL
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:CSE]) = 0 : Local File CFGSEL    [CSE]  : Endif
#
TIT(0) = mess(val(PARAM(1)),752,1)
START  = "SELNUM"
NBCOL += 1 : COL(NBCOL) = "[F:CSE]SELNUM"
Call TEXTFIC("CFGSEL","SELNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("CFGSEL","SELAXX",2,TIT(NBCOL)) From OBJDIV
#

Link [CSE] With [AXX]AXX0="CFGSCE";"SCEAXX";GLANGUE;[F:CSE]SELNUM;""
&          As [LNK]

# FQ 67955 GA 10/2010
Case val(PARAM(1))
  When 4 : CRITERE = '[F:CSE]SELTYP=1&SELNUM>="'+num$(VALEUR)+'"'
  When 5 : CRITERE = '[F:CSE]SELTYP=2&SELNUM>="'+num$(VALEUR)+'"'
Endcase
ORDRE   = ""
SIZLIG = 100
SIZCOL = 110
DEFPAG=1  # V6 GA 11/2008 pour que la pagination se fasse
Default File [LNK]
Return
############################################################
# Fenetre de selection des tables
############################################################
$S_SELFIC
Local Char    W_FIC(GLONATB)(1..250) # JAMCC Issue X3-89202 05/2018
Local Char    W_TXT(30)(1..250)
Local Char    W_ABR(07)(1..250)
Local Char    W_DEB(10)
Local Char    W_FILATB(250)
Local Integer W_Z
#
If clalev([F:ATB]) = 0 : Local File ATABLE    [ATB]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
#
Local File    (Char ZFIC(10), Char ZTXT(30), Char ZABR(7))
&     From    Variable W_FIC, W_TXT, W_ABR
&     As [SEL]
NBCOL = 0
Call TEXTFIC("ATABLE","INTITFIC",2,TIT(NBCOL)) From OBJDIV
#
NBCOL += 1 : COL(NBCOL) = "ZFIC"
Call TEXTFIC("ATABLE","CODFIC",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZTXT"
Call TEXTFIC("ATABLE","INTITFIC",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZABR"
Call TEXTFIC("ATABLE","ABRFIC",2,TIT(NBCOL)) From OBJDIV
#
W_Z = 1
If ( PARAM(1) = "" | TABLE="SELSYM" )        # JPJ ajout test action "SELSYM" car le filtre n'est
                                             # que pour l'action SELFIC
  Filter [ATB] Where left$(CODFIC,1) > "A" &
&                    left$(CODFIC,1) < "X" &
&                    CODFIC >= VALEUR
&              Order By Key CODFIC
Else
  W_FILATB = evalue(PARAM(1))
  Filter [ATB] Where evalue(W_FILATB)
&              Order By Key CODFIC
Endif
For [ATB]
  If W_Z <= dim(W_FIC)
    W_FIC(W_Z) = [F:ATB]CODFIC
    Call TEXTE([F:ATB]INTITFIC,W_TXT(W_Z)) From OBJDIV
    W_ABR(W_Z) = "[F:"+[F:ATB]ABRFIC+"]"
    W_Z += 1
  Else
    Break
  Endif
Next
Filter [ATB]
#
W_DEB = W_FIC(1)
# FQ 67955 GA 10/2010
#CRITERE = "ZFIC>=W_DEB"
CRITERE = 'ZFIC>="'+W_DEB+'"'
ORDRE   = "ZFIC"
START   = "ZFIC"
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 180
DEFPAG=1  # V6 GA 11/2008 pour que la pagination se fasse
Default File [SEL]
Return
############################################################
# Fenetre de selection des champs tables
############################################################
$S_SELTBL
Local Char W_FIC(GLONATB) : W_FIC = PARAM(1) # JAMCC Issue X3-89202 05/2018
Local Char W_LIN(10) : W_LIN = PARAM(2)
#
$S_SELTBLS
Local Char    W_ZON(GLONAVA)(1..250)  # Issue 82300 (10)
Local Char    W_TXT(30)(1..250)
Local Char    W_CFG(05)(1..250)
Local Char    W_DEB(10)
#
Local Integer W_I, W_J, W_K, W_L
#
If clalev([F:ATB]) = 0 : Local File ATABLE    [ATB]  : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:TLP]) = 0 : Local File TABLINCFG [TLP]  : Endif

# JPJ E19931 >  Dévalidation de la séquence car génére trop d'entrée
#                (dévalidation par ajout du $)
#If W_LIN = ""
If W_LIN = "" & W_FIC = "$ITMMASTER"

#  Local Char    W_TABNUM(5)(120)
#  Local Integer W_INT(120,12)
#  Local Integer W_IND
#  W_IND = 0
  # JPJ E19931 >    Ajout d'un dimmensionnement dynamique (1er test)
  Filter [TLP]
  Local Integer W_IND
  W_IND=nbrecord([F:TLP])
  Local Char    W_TABNUM(5)(W_IND)   # Ctrl des sources: avant W_NUM
  Local Integer W_INT(W_IND,12)
  # JPJ E19931 <
  W_IND = 0
  For [TLP]
    W_TABNUM(W_IND) = [F:TLP]CFGLIN
    W_INT(W_IND,0)  = [F:TLP]CFGNUM1
    W_INT(W_IND,1)  = [F:TLP]CFGNUM2
    W_INT(W_IND,2)  = [F:TLP]CFGNUM3
    W_INT(W_IND,3)  = [F:TLP]CFGNUM4
    W_INT(W_IND,4)  = [F:TLP]CFGNUM5
    W_INT(W_IND,5)  = [F:TLP]CFGNUM6
    W_INT(W_IND,6)  = [F:TLP]CFGALP1
    W_INT(W_IND,7)  = [F:TLP]CFGALP2
    W_INT(W_IND,8)  = [F:TLP]CFGALP3
    W_INT(W_IND,9)  = [F:TLP]CFGALP4
    W_INT(W_IND,10) = [F:TLP]CFGALP5
    W_INT(W_IND,11) = [F:TLP]CFGALP6
    W_IND += 1
  Next
  Filter [TLP]
Endif
#
If W_FIC = "$ITMMASTER"                                     # JPJ E19931
  Local File    (Char ZZON(10), Char ZCFG(05), Char ZTXT(30))
&       From Variable W_ZON,         W_CFG,         W_TXT
&       As [SEL]
Else
  Local File    (Char ZZON(10), Char ZTXT(30))
&       From Variable W_ZON,         W_TXT
&       As [SEL]
Endif
#
Read [ATB]CODFIC=W_FIC
If fstat
  Return
Endif
Call TEXTE([F:ATB]INTITFIC,TIT(0)) From OBJDIV
TIT(0) += " ("+W_FIC+")"
#
Filter [ATZ] Where CODFIC = W_FIC      &
&                  CODZONE >= VALEUR   &
&                  CODZONE <> "CREUSR" &
&                  CODZONE <> "CREDAT" &
&                  CODZONE <> "UPDUSR" &
&                  CODZONE <> "UPDDAT" &
&                  CODZONE <> "EXPNUM" &
&                  CODTYP  <> "AXT"
&            Order By Key CODZONE
W_I = 0
For [ATZ]
  Gosub FIL_TBL
  If W_L <> 0
    W_I += 1
    If W_I < dim(W_ZON)
      W_ZON(W_I) = [F:ATZ]CODZONE
      W_CFG(W_I) = ""
      Call FLD_TXT("","",W_LIN,W_TXT(W_I))
      If W_FIC = "$ITMMASTER" & W_LIN = "" & left$([F:ATZ]CODZONE,6) = "CFGFLD"     # JPJ E19931
        W_K  = val(mid$([F:ATZ]CODZONE,10,1)) - 1
        If mid$([F:ATZ]CODZONE,7,3) = "ALP"
          W_K += 6
        Endif
        For W_J = 0 To W_IND -1
          If W_INT(W_J,W_K) > 1        # 1=non affecté
            If W_I < dim(W_ZON)
              W_I += 1
              W_ZON(W_I) = [F:ATZ]CODZONE
              Call ATT_TXT(W_INT(W_J,W_K),W_TXT(W_I))
              W_CFG(W_I) = W_TABNUM(W_J)
            Endif
          Endif
        Next W_J
      Endif
    Endif
  Endif
Next
Filter [ATZ]
#
NBCOL += 1 : COL(NBCOL) = "ZZON"
Call TEXTFIC("ATABZON","CODZONE",2,TIT(NBCOL)) From OBJDIV
If W_FIC = "$ITMMASTER" & W_LIN = ""                         # JPJ E19931
  NBCOL += 1 : COL(NBCOL) = "ZCFG"
  Call TEXTFIC("ITMMASTER","CFGLIN",1,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "ZTXT"
Call TEXTFIC("ATABZON","NOCOURT",2,TIT(NBCOL)) From OBJDIV
#
W_DEB = W_ZON(1)
# FQ 67955 GA 10/2010
#CRITERE = "ZZON>=W_DEB"
CRITERE = 'ZZON>="'+W_DEB+'"'
ORDRE   = "ZZON"
START   = "ZZON"
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 150
DEFPAG=1  # V6 GA 11/2008 pour que la pagination se fasse
Default File [SEL]
Return
############################################################
# Filtrage des champs par fichier
$FIL_TBL
W_L = 1
#
Return
############################################################
# Type de symbole
$S_SELSYM
Local Integer W_COD          : W_COD = val(PARAM(1))
Local Char    W_FIC(GLONATB) : W_FIC = ""  # JAMCC Issue X3-89202 05/2018
Local Char    W_ABR(10)      : W_ABR = ""
Local Char    W_LIN(10)      : W_LIN = PARAM(2)
Local Char    W_FCY(GLONFCY) : W_FCY = PARAM(3)
#
Case W_COD
  When  1                 : Gosub S_SELQST
  When  2,24,25,26,27     : Gosub S_SELVAR
  When  3                 : Gosub S_SELSCES
  When  4,5               : Gosub S_SELSEL
  When  6                 : Gosub S_SELFIC
  When  7                 : Gosub S_SELMAC
  When  8                 :
  When  9                 : Gosub S_SELSHA
  When  Default           : Call CONV_FIC(W_COD,W_FIC,W_ABR)
                            Gosub S_SELTBLS
Endcase
Return
############################################################
# Selection sur objet
Subprog SELTAB(LVAL,LOBJ,LFCY,LQST)
Variable Char    LVAL
Value    Char    LOBJ
Value    Char    LFCY
Value    Char    LQST
Local    Char    W_VAR(GLONAVA)  # Issue 82300 (10)
S_SELTBL = 0
Read [CQU]CQU0=LQST
If fstat = 0
  If [F:CQU]CTLTYP = 3
    W_VAR = W_PRS+LQST
    Gosub SET_FILTER From WUVAR
    Case LOBJ
      When "ITF" :            # Issue 89065 GA 06/2013 code déplacé, source trop long
          Gosub SELITF From CFGLIBC1
      When "ITM" :            # Issue 89065 GA 06/2013 meilleure gestion du filtre pour les listes sur ITM
          Gosub SELITM From CFGLIBC1
      When "ATD" :            # Issue 74287 GA 03/2012 Menus locaux Objet ATD - Table AST
          Local Char PARAM(50)(1..20) , SAVACT(10),TABLE(10),SAVFLT(250)
          SAVACT = GACTION : GACTION = "SELAST"
          Call S_TAB_CHAR(LVAL,PARAM,GACTION,"CFGLIB","") From GACTION
          GACTION = SAVACT
          If LVAL <> ""
            S_SELTBL = 1
          Endif
      When "ADI" :            # Issue 81009 GA 06/2012 Liste ADI table filtrée via le SET_FILTER
          Local Char PARAM(50)(1..20) , SAVACT(10),TABLE(10),SAVFLT(250)
          SAVACT = GACTION : GACTION = "SELADI"
          PARAM(1) = ""
          PARAM(2) = LQST
          Call S_TAB_CHAR(LVAL,PARAM,GACTION,"CFGLIB","") From GACTION
          GACTION = SAVACT
          If LVAL <> ""
            S_SELTBL = 1
          Endif
      When "CAC" :            # Issue 83483 GA 07/2012 Table CAC
          Local Char PARAM(50)(1..20) , SAVACT(10),TABLE(10),SAVFLT(250)
          SAVACT = GACTION : GACTION = "SELCAC"
          Call S_TAB_CHAR(LVAL,PARAM,GACTION,"CFGLIB","") From GACTION
          GACTION = SAVACT
          If LVAL <> ""
            S_SELTBL = 1
          Endif
      When Default :
          Gosub SEL_TABLE From WUVAR
          If status <> 7
            S_SELTBL = 1
          Endif
    Endcase
    W_VAR = W_PRS+LQST
    Gosub RESET_FILTER From WUVAR
  Elsif [F:CQU]CTLTYP = 6    # FQ 72873 GA 04/2011 Type de contrôle Table diverse (alphanumérique)
    W_VAR = W_PRS+LQST
    # Issue 81009 GA 06/2012
    Local Char PARAM(50)(1..20) , SAVACT(10),TABLE(10),SAVFLT(250)
    SAVACT = GACTION : GACTION = "SELADI"
    PARAM(1) = [F:CQU]CODFIC                 # Issue 95386 GA 01/2014 code Table diverse
    PARAM(2) = ""                            # Issue 95386 GA 01/2014 code dépendances ???
    Call S_TAB_CHAR(LVAL,PARAM,GACTION,"CFGLIB","") From GACTION
    GACTION = SAVACT
    If LVAL <> ""
      S_SELTBL = 1
    Endif
  Endif
Endif
End
############################################################
# Fenetre de selection des operations standard
############################################################
$S_SELOPS
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:ROT]) = 0 : Local File ROUOPESTD [ROT]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif  # FGR 21/09/2009 : X3SUIVI57981
#
Local Char    WFCY(GLONFCY) : WFCY = PARAM(1)
Local Integer WOPE          : WOPE = VALEUR  # FQ 76734 GA 09/2011
#

# FGR 21/09/2009 : X3SUIVI57981
Link [ROT] With [AXX]AXX0="ROUOPESTD";"STDOPEDESAXX";GLANGUE;num$([F:ROT]STDOPENUM);[F:ROT]FCY As [LNK]

TIT(0) = mess(18,100,1)
START  = "STDOPENUM"
NBCOL += 1 : COL(NBCOL) = "STDOPENUM"
Call TEXTFIC("ROUOPESTD","STDOPENUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "FCY"
Call TEXTFIC("ROUOPESTD","FCY",2,TIT(NBCOL)) From OBJDIV
# FGR 21/09/2009 : X3SUIVI57981
#NBCOL += 1 : COL(NBCOL) = "STDOPEDES"
#Call TEXTFIC("ROUOPESTD","STDOPEDES",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("ROUOPESTD","STDOPEDESAXX",2,TIT(NBCOL)) From OBJDIV

#
# FQ 67955 GA 10/2010 - FQ 76734 GA 09/2011 avant ... "'+VALEUR+'"'
#CRITERE = "[F:ROT]STDOPENUM>=VALEUR"
CRITERE = '[F:ROT]STDOPENUM>='+num$(WOPE)
If PARAM(1) <> ""
  # FQ 67955 GA 10/2010
  #CRITERE += "&[F:ROT]FCY=WFCY"
  CRITERE += '&[F:ROT]FCY="'+WFCY+'"'
Endif
ORDRE   = ""
SIZLIG = 100
SIZCOL = 130
DEFPAG=1  # V6 GA 11/2008 pour que la pagination se fasse

# FGR 21/09/2009 : X3SUIVI57981
#Default File [ROT]
Default File [LNK]
Return

############################################################
# Fenetre de selection d'une devise
############################################################
$S_SELCUR
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR    [TCU]  : Endif
#
Local Integer IC, IR, IE, IZ
TIT(0) = mess(18,100,1)
START  = "CUR"
NBCOL += 1 : COL(NBCOL) = "CUR"
Call TEXTFIC("TABCUR","CUR",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "CURDES"
Call TEXTFIC("TABCUR","CURDES",2,TIT(NBCOL)) From OBJDIV
#
CRITERE = ""
ORDRE   = ""
SIZLIG  = 100
SIZCOL  = 80
DEFPAG=1  # V6 GA 11/2008 pour que la pagination se fasse
Default File [TCU]
Return
############################################################
$V_SELCUR
If dim([M:CSEL]CST) > 0
  [M:CSEL]CSTTOT = 0
  [M:CSEL]CUR    = [F:TCU]CUR
  Raz IE, IZ
  For IC = 0 To [M:CSEL]NBLIG-1
    If [M:CSEL]SELFLG(IC) = 2
      If [M:CSEL]CUR = [M:CSEL]CURORI
        [M:CSEL]CST(IC) = [M:CSEL]CSTORI(IC)
      Else
        Call CONVERT([M:CSEL]CURORI,[M:CSEL]CUR,GSYSCUR,1,date$,[M:CSEL]CSTORI(IC),[M:CSEL]CST(IC),IR)
&            From TRTDEV
        If IR <> 0
          IE = 1
          [M:CSEL]CST(IC) = 0
        Else
          If [M:CSEL]CSTORI(IC) <> 0 & [M:CSEL]CST(IC) = 0
            IZ = 1
          Endif
        Endif
      Endif
      Affzo [M:CSEL]CST(IC)
    # CCC (15/12/05) Bug 33850
      #[M:CSEL]CSTTOT += [M:CSEL]CST(IC)
      If dim([M:CSEL]QTYSAU)>0
          [M:CSEL]CSTTOT += [M:CSEL]CST(IC) * [M:CSEL]QTYSAU(IC)
      Else
          [M:CSEL]CSTTOT += [M:CSEL]CST(IC) * [M:CSEL]QTYSTU(IC)
      Endif

    Endif
  Next IC
  Affzo [M:CSEL]CUR
  Affzo [M:CSEL]CSTTOT
  If IE <> 0
    GERR     = 2
    GMESSAGE = mess(34,110,1)
  Else
    If IZ = 1
      GERR     = 2
      GMESSAGE = mess(16,114,1)
    Endif
  Endif
Endif
Return
############################################################
# Fenetre de selection reference tiers dans historique cfg
############################################################
$S_SELBRF
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:CHH]) = 0 : Local File CFGHISHEA [CHH]  : Endif
NBCOL += 1 : COL(NBCOL) = "CFGVCRNUM"
Call TEXTFIC("CFGHISHEA","CFGVCRNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "CFGBPRNUM"
Call TEXTFIC("CFGHISHEA","CFGBPRNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "CFGBPRREF"
Call TEXTFIC("CFGHISHEA","CFGBPRREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("CFGHISHEA","ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "QTYSTU"
Call TEXTFIC("CFGHISHEA","QTYSTU",2,TIT(NBCOL)) From OBJDIV

NBCOL += 1 : COL(NBCOL) = "CREDAT"
Call TEXTFIC("CFGHISHEA","CREDAT",2,TIT(NBCOL)) From OBJDIV
#
TIT(0) = TIT(3)
# FQ 67955 GA 10/2010
#CRITERE = "SCENUM=PARAM(2)&FCY=PARAM(1)&CFGBPRNUM=PARAM(3)"
CRITERE = 'SCENUM="'+PARAM(2)+'"&FCY="'+PARAM(1)+'"&CFGBPRNUM="'+PARAM(3)+'"'
START   = "CFGBPRREF"
DEFPAG=1  # V6 GA 11/2008 pour que la pagination se fasse
Default File [CHH]
Return

############################################################
# Aide sur champ X*, Y* ou Z*
$S_SELHLP
Local Integer ICRIT : ICRIT=0
If !clalev([ADZ]) : Local File ADOCFLD [ADZ] : Endif
OBJET="ADZ"
Call ADDCRIT(CRITERE,ICRIT,"","LAN=GLANGUE","&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRIT,"","(pat(MOTCLE,'X*')|pat(MOTCLE,'Y*')=1|pat(MOTCLE,'Z*')=1)","&") From GOBJSUB
Default File [ADZ]
Return

############################################################
# Fenetre de selection contenu des tables diverses
############################################################
$S_SELADI   # FQ 72873 GA 08/2011
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ADI]) = 0 : Local File ATABDIV   [ADI]  : Endif
Local Char WNUMTAB(GLONADI) : WNUMTAB = PARAM(1)
Local Char WQSTNUM(GLONQST) : WQSTNUM = PARAM(2)

If dim(S_FILTER)>0 & S_FILTER<>""
   CRITERE = S_FILTER
Endif

If WNUMTAB<>""             # Issue 95386 GA 01/2014 code Table diverse
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'NUMTAB = '+WNUMTAB,"&") From GOBJSUB
Endif

TIT(0)  = mess(75,125,1) : # Tables diverses
