OBJET   = "ADI"
#
SIZLIG = 100
SIZCOL = 200
DEFPAG=1
Return

############################################################
# Fenetre de selection Menu Local            # Issue 74287 #
############################################################
$S_SELAST
If clalev([F:AST]) = 0 : Local File APLSTD   [AST]  : Endif
#
TIT(0) = mess(1,30,1) : # Menu local
If dim([F:TFO]FORFOR)>0 & [F:TFO]FORFOR<>""
    Local Char WDES(50)
    Call LECTEXTRA(WDES,"TABFOR","DES",num$([F:TFO]FORTYP),[F:TFO]FORCOD) From ATEXTRA
    TIT(0)=mess(1,30,1)-WDES
Endif
START  = "LANNUM"
NBCOL += 1 : COL(NBCOL) = "LANNUM"
Call TEXTFIC("APLSTD","LANNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LANMES"
Call TEXTFIC("APLSTD","LANMES",2,TIT(NBCOL)) From OBJDIV
