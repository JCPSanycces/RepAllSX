#<AdxTL>@(#)8.0.0.0 $Revision$
#
# Actions Configurateur
#
############################################################
# Actions 'Traitements standard'
#
# SAICFGLIN  = Saisie champs article configurateur
# SAICFGLIN2 = Saisie champs article configurateur (par bouton)
# SAICFGPOS  = Saisie positions dans les fenetres generees
# SAICFGINP  = Entree dans le configurateur
# SAICFGINPS = Entree dans une sélection article
# SAICFGNOV  = Copie nomenclature commerciale vers fenetre options/variantes
#
############################################################
# Actions 'Saisie en fenetre'
#
# CFGASTXT   = Saisie reponses en format 'texte'
# CFGASBLB   = Saisie reponses en format 'Blob'            # FQ 50451 GA 11/2008
# CFGASCLB   = Saisie reponses en format 'Clob'            # FQ 50451 GA 11/2008
# SAICFGCMP  = Saisie info composant
# SAICFGINP  = Entree configurateur
# SAICFGINPS = Entree dans une sélection article
# SAICFGNOV  = Copie d'une nomenclature en creation formes et modeles
# SAICFGOPE  = Saisie champs operation gamme
# VISUCFG    = Cas d'emploi configurateur (V140)
# VISUCFM    = Visualisation procedure
# VISUCIT    = Visualisation champs configurateur
# VISUCQU    = Visualisation symbole
# VISUCRE    = Visualisation symboles reponses et leur contenu
# VISUCVA    = Visualisation symboles variables et leur contenu
# VISUDIC    = Visualisation champ dictionnaire
# VISUHIS    = Visualisation detail historique configuration
# VISUPIC    = Visualisation image article
# VISUPIS    = Visualisation image symbole
#
############################################################
# Actions 'Selection dans table'
#
# SELABF     = Selection abaque filtree
# SELABQ     = Selection abaque
# SELADI     = Sélection Table Diverse
# SELAST     = Sélection Menu Local
# SELBRF     = Selection tiers a partir historique configurations
# SELCAC     = Sélection Code comptable  # Issue 83483 GA 07/2012
# SELCUR     = Selection devise
# SELFIC     = selection d'une table
# SELFLD     = Selection champ dictionnaire (plus utilisee)
# SELFOR     = Selection formule
# SELMAC     = Selection procedure
# SELNOC     = Selection alternative nomenclature
# SELOPS     = Selection operation standard
# SELQST     = Selection question
# SELSCE     = Selection scenario
# SELSHA     = Selection categorie de forme
# SELSHB     = Selection forme
# SELSHC     = Selection forme ouverture automatique
# SELSYM     = Selection symbole
# SELTBL     = Selection champ table
# SELTCA     = Selection table de contrôle ouverture automatique
# SELTCO     = Selection table de contrôle
# SELTCT     = Selection contenu table de contrôle
# SELVAR     = Selection variable
# SELHLP     = Sélection aide sur champ
#
############################################################
# Actions 'Sous programmes'
#
# CFGCTRTCTA = Contrôle saisie champs alphanum. cfg avec table controle
# CFGCTRTCTN = Contrôle saisie champs numerique cfg avec table controle
# CFGCTRSHA  = Contrôle saisie forme / modele
# CFGCTRSCE  = Contrôle saisie scenario
# CFGCTRALT  = Contrôle alternatives nomencl. et gamme du scenario
# CFGCTRFCY  = Contrôle site
# CFGCTRREP  = Contrôle reponse avec automate
# CFGCTRALP  = Action contrôle reponse alphanumerique
# CFGCTRNUM  = Action contrôle reponse numerique
# CFGCTRDAT  = Action contrôle reponse date
# CFGCTRCAS  = Action contrôle reponse case a cocher
# CFGCTRTXT  = Action contrôle reponse texte
# CFGCTRTAB  = Action contrôle reponse avec table de contrôle
# CFGCTRBLB  = Action contrôle reponse Blob                    # FQ 50451 GA 11/2008
# CFGCTRCLB  = Action contrôle reponse Clob                    # FQ 50451 GA 11/2008
# CFGCTRFOR  = Contrôle formule generateur
#
# CFGASFCY   = Action avant saisie site
# CFGASALP   = Action avant saisie reponse alphanumerique
# CFGASNUM   = Action avant saisie reponse numerique
# CFGASDAT   = Action avant saisie reponse date
# CFGASCAS   = Action avant saisie reponse case a cocher
# CFGASSYM   = Action avant saisie symbole
# CFGASPAR   = Action avant saisie parametre symbole
#
# CFGAMALP   = Action apres modification reponse alphanumerique
# CFGAMNUM   = Action apres modification reponse numerique
# CFGAMDAT   = Action apres modification reponse date
# CFGAMCAS   = Action apres modification reponse case a cocher
# CFGAMLIN   = Action apres modification ligne produit (ITM1)
#
# CFGCNDNOT  = Action condition inverse
# CFGCOPLIN  = Action copie ligne precedente
# CFGCOPFOR  = Action copie formule ligne precedente
# CFGASIND   = Action avant saisie indice champs de table
# CFGGRISHA  = Action de grisage des questions formes et modeles
#
# CFGSETFOR  = Generation parametres formules
# CFGSETTBL  = Generation noms tables autorisees
# CFGCTRSYM  = Action de contrôle saisie symbole (questions, variables ou champs de tables..)
# CFGCTRIND  = Contrôle indice champs dimensionnes
# CFGTUNCQU  = Tunnel questions / variables
# CFGCTRTBL  = Contrôle table autorisee
# CFGDESTCT  = Selection designation table de contrôle
#
# CFGAPQST   = OK automatique en tabulation après la dernière question
############################################################
# Sous programmes divers du configurateur
# CONV_FIC       = Conversion nom fichier --> Numero menu local 752
# LOA_SYMBOLES   = Chargement en table des symboles utilises dans une formule
# CFG_CONSTANTES = Definition variables et constantes std
# CFG_PREFIXES   = Definition prefixes divers configurateur
# CTR_CTRSAI     = Contrôle champs obligatoires scenario
# SYM_TXT        = Determination intitule symbole
# FLD_TXT        = Determination intitule champs de table (avec personalisation champs cfg)
# ATT_TXT        = Texte attribut ligne de produit
# SET_VALCPT     = Chargement valeur compteur (Sans MAJ)
# LOA_FILTCT     = Creation filtre table de reponses
# LOA_FILSHA     = Creation filtre formes et modeles
# ACT_CFGUSR     = Activation utilisateur configurateur
# DEA_CFGUSR     = Desactivation utilisateur configurateur
############################################################
# Issue 82300 CQU 8c => 10c mid$(W_VAR,3,8) devient mid$(W_VAR,3,GLONCQU)
############################################################

############################################################
# Ctrl ouverture des fichiers et masques écrans
############################################################
$OPEN_CFG
Local Integer WRET
Call LECACT("CFG",WRET) From TRTX3
If WRET=1
   Local Mask CFGWRK [CFW]
   Gosub OPEN_FILES
Endif
Return

$OPEN_FILES
If clalev([M:VCFG]) = 0 : Local Mask VISUCFG   [VCFG] : Endif
#
If clalev([F:ATB])  = 0 : Local File ATABLE    [ATB]  : Endif
If clalev([F:ATX])  = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:CLN0]) = 0 : Local File CFGLNK    [CLN0] : Endif
If clalev([F:CLN1]) = 0 : Local File CFGLNK    [CLN1] : Endif
If clalev([F:CLN2]) = 0 : Local File CFGLNK    [CLN2] : Endif
If clalev([F:CLN3]) = 0 : Local File CFGLNK    [CLN3] : Endif
If clalev([F:CLN4]) = 0 : Local File CFGLNK    [CLN4] : Endif
If clalev([F:CQU1]) = 0 : Local File CFGQST    [CQU1] : Endif
If clalev([F:CBB])  = 0 : Local File CBLOB     [CBB]  : Endif : # GA 20/09/2007 suite 42023
If clalev([F:ADI])  = 0 : Local File ATABDIV   [ADI]  : Endif   # FQ 72873 GA 04/2011
If clalev([F:ADV])  = 0 : Local File ATABTAB   [ADV]  : Endif   # FQ 72873 GA 08/2011 Type de contrôle Table diverse (alphanumérique)
If clalev([F:AST])  = 0 : Local File APLSTD    [AST]  : Endif   # Issue 74287 GA 03/2012
Return

############################################################
# Definition constantes configurateur
############################################################
$CFG_CONSTANTES        # Attention Kill dans trt généré WUVAR par CFGLIBA
# Prefixes
Gosub CFG_PREFIXES
#
# Creation eventuelle de la variable globale contenant le nom du dossier
#
If dim(S_DOSSIER) < 0
  Global Char    S_DOSSIER(10) : S_DOSSIER = nomap
Endif
#
# Creation eventuelle de la variable globale contenant lnumero d'extension de fichier genere
#
If dim(W_EXTFIC) < 0
  Global Char    W_EXTFIC(03)
Endif
#

If clalev([F:ATX])  = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:AXX0]) = 0 : Local File ATEXTRA   [AXX0] : Endif

Local Char    W_VAR (GLONAVA)   : # Zone de travail nom symbole            # Issue 82300 (10)
Local Char    W_VARS(GLONAVA)   : # Zone de travail nom symbole            # Issue 82300 (10)
Local Char    W_ABA (20)        : # Zone de travail abaque
Local Integer W_ERR             : # Zone de travail numero d'erreur
Local Char    W_MSG (GLONAFE)   : # Zone de travail message                   - V6 avant 250
Local Char    W_LNK (120)       : # Zone de travail contrôle liens avec autres tables
Local Char    W_EVA (120)       : # Zone de travail pour evaluation
Local Char    W_MAC (10)        : # Zone de travail nom procedure
Local Char    W_ABQ (10)        : # Zone de travail nom abaque
Local Char    W_IND (GLONAVA)   : # Zone de travail abscisse abaque        # Issue 90819 GA 07/2013 avant (10)
Local Char    W_INDY(GLONAVA)   : # Zone de travail ordonnee abaque        # Issue 90819 GA 07/2013 avant (10)
Local Char    W_FOR (GLONAFE)   : # Zone de travail evaluation formule        - V6 avant 250
Local Char    W_TRA (GLONAFE)   : # Zone de travail pour trace                - V6 avant 100
Local Char    W_RES (GLONAFE)   : # Zone de travail resultat d'evaluation     - V6 avant 250
Local Char    W_ITM (GLONITM)   : # Zone de travail numero d'article
Local Char    W_ITMS(GLONITM)   : # Zone de travail numero d'article : # FQ 43622
Local Char    W_PIT (GLONITM)   : # Zone de travail compose de reference
Local Char    W_RIT (GLONITM)   : # Zone de travail article reference
Local Char    W_STU (GLONUOM)   : # Zone de travail unite de stock
Local Char    W_UOM (GLONUOM)   : # Zone de travail unite
Local Char    W_TLP (GLONTLP)   : # Zone de travail ligne de produit
Local Char    W_FIC (GLONATB)   : # Zone de travail nom table                 - V6 avant 10
Local Char    W_ABR (GLONATB)   : # Zone de travail abreviation table         - V6 avant 10
Local Char    W_FLD (80)        : # Zone de travail contenu champ
Local Char    W_FIL (250)       : # Zone de travail filtre acces tables
Local Decimal W_CST             : # Zone de travail cout
Local Decimal W_BES             : # Zone de travail besoin
Local Integer W_SEQ             : # Zone de travail numero sequence
Local Integer W_BMS             : # Zone de travail numero sequence
Local Char    W_WRH (GLONFCY)   : # Zone de travail site (creation multisite)
Local Char    W_LNW (40)        : # Zone de travail desactivation contrôles liens
Local Char    W_LNF (10)        : # Zone de travail desactivation contrôles liens
Local Char    W_LNZ (10)        : # Zone de travail desactivation contrôles liens
Local Char    W_CPT (GLONVCR)   : # Zone de travail numero piece cfg
Local Char    W_BPS (GLONBPR)   : # Zone de travail article / fournisseur
Local Integer W_COM             : # Indicateur compose cree
Local Integer W_BOH             : # Indicateur entete nomenclature cree
Local Integer W_ROH             : # Indicateur entete gamme cree
Local Integer W_TRUE            : # Indicateur vrai / faux
Local Integer W_QWI             : # Indicateur generation fenetres
Local Integer W_ITS             : # Indicateur articles selectionnes
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_DESTCT(GLONDCT) : # Intitule code table de contrôle
Else
  Local Char  W_DESTCT(30)      : # Intitule code table de contrôle
Endif
Local Char    W_FLDTCT(GLONAVA) : # Champ intitule table de contrôle       # Issue 82300 (10)
Local Integer W_TRANSFLG        : # Identifiant DEBTRANS en-cours en validation (0: premier, 1:deuxième)
Local Integer W_CSTMOD          : # Indicateur mode de calcul coût (0: aucun, 1: module controle de gestion, 2: scénario)
Local Char    W_TRASTP(250)     : # Zone de travail trace message
Local Char    W_TRAMSG(250)     : # Zone de travail trace étape
Local Integer WNO_DEFAULT_TEXT  : # Issue 107085 GA 03/2015 avoid writing default text for BOH/ROH
Local Integer WNO_UPD_SALCFG    : # Issue 107085 GA 03/2015 no update when creating a sale order
#
Local Char    W_SSC(GLONCFG)    : # Numero de sous scenario   # Issue 106724 GA 03/2015 before W_SSC(5)
Local Integer W_LEVEL           : # Niveaux de sous scenarios
Local Integer WW_COM            : # Sauvegarde indicateur compose cree
Local Integer WW_BOH            : # Sauvegarde indicateur entete nomenclature cree
Local Integer WW_ROH            : # Sauvegarde indicateur entete gamme cree
Local Integer WW_BOMALT         : # Sauvegarde alternative nomenclature scenario principal
Local Integer WW_BOMALTTYP      : # Sauvegarde type        nomenclature scenario principal
Local Integer WW_LLCTYP         : # Sauvegarde type LLC     nomenclature scenario principal
Local Integer WW_ROUALT         : # Sauvegarde alternative gamme scenario principal
Local Integer WW_BOMALTREF      : # Sauvegarde alternative nomenclature reference scenario principal
Local Integer WW_BOMALTTYPREF   : # Sauvegarde type        nomenclature reference scenario principal
Local Integer WW_LLCTYPREF      : # Sauvegarde type LLC    nomenclature reference scenario principal
Local Integer WW_ROUALTREF      : # Sauvegarde alternative gamme reference scenario principal
Local Char    WW_CURITM(GLONITM): # Sauvegarde S_CURITM
Local Char    WW_CURROU(GLONITM): # Sauvegarde S_CURROU
Local Decimal WW_ITMQTY           # Sauvegarde quantité scenario principal
#
Local Decimal W_BASQTY, W_QTYN, W_QTYNA, W_QTYB, W_QTYBA : # Pour calcul qte du lien
#
Local Char    W_ALP(250)        : # Zone de travail alphanumerique
Local Decimal W_NUM             : # Zone de travail numerique
Local Date    W_DAT             : # Zone de travail date
Local Integer W_BOO             : # Zone de travail booleens
Local Integer W_YEA             : # Zone de travail annee
Local Date    W_DTE             : # Zone de travail date
Local Date    W_DATNUL : W_DATNUL=[0/0/0]   : # Constante date [0/0/0] appels à CAL_CST en V6 GA 09/2007
#
Global Clbfile W_CLB(GLONACB)   : # Zone de travail clob         # FQ 32446 & 50451 GA 11/2008
Global Blbfile W_BLB(GLONABB)   : # Zone de travail blob         # FQ 32446 & 50451 GA 11/2008
#
Local Integer W_RET             : # Zone de travail code retour
# Indices divers
Local Integer W_I, W_J, W_K, W_L, W_M, W_N, W_O, W_P, W_Q, W_R, W_S, W_T, W_U, W_V, W_W, W_X

# FQ 49667 GA 10/2008 ligne de produit utilisée sans code activité CFG les tables sont absentes
Call LECACT("CFG",W_RET) From TRTX3
If W_RET <> 1 Return Endif

# FQ 47202 GA 04/2008 pb sur [F:CSH] => on ouvre tous les fichiers CFGxxx
# FQ 47394 GA 05/2008 ajout =S_DOSSIER+".xxx"
# FQ 49740 GA 10/2008 si et seulement si S_DOSSIER<>nomap
If dim(S_DOSSIER)>0 & S_DOSSIER<>"" & S_DOSSIER<>nomap
   If clalev([F:CSE]) = 0 : Local File =S_DOSSIER+".CFGSEL"      [CSE]  : Endif
   If clalev([F:COV]) = 0 : Local File =S_DOSSIER+".CFGOPTVAR"   [COV]  : Endif
   If clalev([F:CFM]) = 0 : Local File =S_DOSSIER+".CFGMAC"      [CFM]  : Endif
   If clalev([F:CQU]) = 0 : Local File =S_DOSSIER+".CFGQST"      [CQU]  : Endif
   If clalev([F:CAB]) = 0 : Local File =S_DOSSIER+".CFGABQ"      [CAB]  : Endif
   If clalev([F:CME]) = 0 : Local File =S_DOSSIER+".CFGMEMO"     [CME]  : Endif
   If clalev([F:CML]) = 0 : Local File =S_DOSSIER+".CFGMENLOC"   [CML]  : Endif
   If clalev([F:CSH]) = 0 : Local File =S_DOSSIER+".CFGSHA"      [CSH]  : Endif
   If clalev([F:CSC]) = 0 : Local File =S_DOSSIER+".CFGSCE"      [CSC]  : Endif
#CHECK IGNORE_BEGIN
   If GVERSION>="2.0.0"    # Issue 104077 GA 11/2014 Akira before GVERSION>="1.8.0"
      If clalev([F:CSQ]) = 0 : Local File =S_DOSSIER+".CFGSCEQST"   [CSQ]  : Endif    # FQ 64278 GA 06/2010
   Endif
#CHECK IGNORE_END
   If clalev([F:CSL]) = 0 : Local File =S_DOSSIER+".CFGSCELIN"   [CSL]  : Endif
   If clalev([F:CQU]) = 0 : Local File =S_DOSSIER+".CFGQST"      [CQU]  : Endif
   If clalev([F:CHH]) = 0 : Local File =S_DOSSIER+".CFGHISHEA"   [CHH]  : Endif
   If clalev([F:CFH]) = 0 : Local File =S_DOSSIER+".CFGHIS"      [CFH]  : Endif
   If clalev([F:CDF]) = 0 : Local File =S_DOSSIER+".CFGDEF"      [CDF]  : Endif
   If clalev([F:CBB]) = 0 : Local File =S_DOSSIER+".CBLOB"       [CBB]  : Endif    # FQ 50444 GA 11/2008
   If clalev([F:AOX]) = 0 : Local File =S_DOSSIER+".AOBJTXT"     [AOX]  : Endif    # FQ 50444 GA 11/2008
   If clalev([F:TXC]) = 0 : Local File =S_DOSSIER+".TEXCLOB"     [TXC]  : Endif    # FQ 50444 GA 11/2008
   #### Gosub TAB_SYMBOLES   From =S_DOSSIER+".WUVAR"        # FQ 56326 ne fonctionne pas dans ce contexte
Else
   If clalev([F:CSE]) = 0 : Local File CFGSEL      [CSE]  : Endif
   If clalev([F:COV]) = 0 : Local File CFGOPTVAR   [COV]  : Endif
   If clalev([F:CFM]) = 0 : Local File CFGMAC      [CFM]  : Endif
   If clalev([F:CQU]) = 0 : Local File CFGQST      [CQU]  : Endif
   If clalev([F:CAB]) = 0 : Local File CFGABQ      [CAB]  : Endif
   If clalev([F:CME]) = 0 : Local File CFGMEMO     [CME]  : Endif
   If clalev([F:CML]) = 0 : Local File CFGMENLOC   [CML]  : Endif
   If clalev([F:CSH]) = 0 : Local File CFGSHA      [CSH]  : Endif
   If clalev([F:CSC]) = 0 : Local File CFGSCE      [CSC]  : Endif
#CHECK IGNORE_BEGIN
   If GVERSION>="2.0.0"    # Issue 104077 GA 11/2014 Akira before GVERSION>="1.8.0"
      If clalev([F:CSQ]) = 0 : Local File CFGSCEQST   [CSQ]  : Endif    # FQ 64278 GA 06/2010
   Endif
#CHECK IGNORE_END
   If clalev([F:CSL]) = 0 : Local File CFGSCELIN   [CSL]  : Endif
   If clalev([F:CQU]) = 0 : Local File CFGQST      [CQU]  : Endif
   If clalev([F:CHH]) = 0 : Local File CFGHISHEA   [CHH]  : Endif
   If clalev([F:CFH]) = 0 : Local File CFGHIS      [CFH]  : Endif
   If clalev([F:CDF]) = 0 : Local File CFGDEF      [CDF]  : Endif
   If clalev([F:CBB]) = 0 : Local File CBLOB       [CBB]  : Endif    # FQ 50444 GA 11/2008
   If clalev([F:AOX]) = 0 : Local File AOBJTXT     [AOX]  : Endif    # FQ 50444 GA 11/2008
   If clalev([F:TXC]) = 0 : Local File TEXCLOB     [TXC]  : Endif    # FQ 50444 GA 11/2008
   #### Gosub TAB_SYMBOLES   From WUVAR                              # FQ 56186 & FQ 56326 supprimé FQ 74780
Endif

# ----------------------------------------------------------------------------
# Issue 90061 GA 05/2013: pour CFGLIBC1 en mode reprise ou reconfiguration
# 1=Maj si et seulement si Reactualisation demandée
# 2=Maj toutes les réponses du scénario comme en création de la configuration
# ----------------------------------------------------------------------------
Local Integer W_CFGUPD : W_CFGUPD=2 # Type de maj en reprise
Local Char  W_PAR(1)
Call PARAM("","CFGUPD",W_PAR) From ADOVAL
If W_PAR<>"" W_CFGUPD=val(W_PAR) Endif

Return
############################################################
# Definition prefixes configurateur
############################################################
$CFG_PREFIXES
Global Char    W_PRS(2) : W_PRS = "S_" : # Prefixe des symboles
Global Char    W_PRX(2) : W_PRX = "T_" : # Prefixe des intitules
Global Char    W_PRL(2) : W_PRL = "L_" : # Prefixe des designations table contrôle
Global Char    W_PRQ(2) : W_PRQ = "Q_" : # Prefixe questions ecran
Global Char    W_PRR(2) : W_PRR = "R_" : # Prefixe rang des questions dans l'ecran
Global Char    W_PRW(2) : W_PRW = "X_" : # Prefixe des sauvegardes symboles
Global Char    W_PRY(2) : W_PRY = "Y_" : # Prefixe des sauvegardes designations table contrôle
Global Char    W_PRZ(2) : W_PRZ = "Z_" : # Prefixe des intitules reponses ecrans
Return
############################################################
# Creation table de tous les symboles
$CFG_SYMBOLES
# FQ 50192 pb en validation des transactions sur dossier fille
Local Char CH_DOSSIER(20)
If dim(S_DOSSIER)>0 & S_DOSSIER<>"" & S_DOSSIER<>nomap
   # FQ 50292 CH_DOSSIER = 'S_DOSSIER+"."+'
   CH_DOSSIER = S_DOSSIER+"."
Else
   CH_DOSSIER = ""
Endif
If clalev([F:CQU0])= 0 :  Local File =CH_DOSSIER+"CFGQST"    [CQU0]  : Endif
#

If dim(S_TRAFLG)<=0    # Issue 85608 GA 11/2012
   Gosub TAB_SYMBOLES From =CH_DOSSIER+"WUVAR"
Endif

Global Char    Z_VARLAB(GLONAVA)(nbrecord([F:CQU0]))  # Issue 82300 (10)(nbrecord([F:CQU0]))
Global Char    Z_VARATT(02)(nbrecord([F:CQU0]))
Global Integer Z_VARNBR
#
Gosub CFG_PREFIXES
#
Filter [CQU0] Order By Key CQU2
For [CQU0]
  Z_VARLAB(Z_VARNBR) = W_PRS+[F:CQU0]QSTNUM
  Z_VARATT(Z_VARNBR) = num$([F:CQU0]QSTTYP)+num$([F:CQU0]ASWTYP)
  W_VAR              = W_PRX+[F:CQU0]QSTNUM
  Onerrgo CFG_SYMBOLES_ERR
  # FQ 50192 pb en validation des transactions sur dossier fille
  Gosub CRE_SYMTXT From =CH_DOSSIER+"WUVAR"
  Onerrgo
  Z_VARNBR += 1
Next
Filter [CQU0]
Return
#
$CFG_SYMBOLES_ERR
Resume
############################################################
# Affichage du champ DYNAMT de l'ecran de saisie scenario
$AFF_DYNAMT
If dim([M:CSCE]DYNAMT) > 0 & dim(S_DYNAMT) > 0 & dim(T_DYNAMT) > 0
  [M:CSCE]DYNAMT = S_DYNAMT
  If S_DYNAMT <> 0
    [M:CSCE]DYNTXT = T_DYNAMT-num$([M:CSCE]DYNAMT)-S_CUR
  Else
    [M:CSCE]DYNTXT = ""
  Endif
  If S_CPTCOP <> ""
    If S_MODITM = ""
      [M:CSCE]DYNTXT += "   "+mess(167,188,1)-S_CPTCOP
    Else
      [M:CSCE]DYNTXT += "   "+mess(168,188,1)-S_CPTCOP-S_MODITM
    Endif
  Endif
  Affzo [M:CSCE]DYNTXT
Endif
Return
############################################################
$ACTION
# Point d'entree generique actions gestion du configurateur CFG_+ACTION
# Ne pas oublier de tester GACTION dans le point d'entree
# Mettre GPE <> 0 pour inhiber l'action standard
#
Global Char GPOINT(30)
GPOINT = "CFG_"+ACTION
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE <> 0
  Return
Endif
#
Case ACTION
  When "TITRE"
    Case GACTION
      When "CFGASTXT"   : Gosub TITRE_TXT From CFGLIBD
      When "CFGASBLB"   : Gosub TITRE_BLB From CFGLIBD    # FQ 50451 GA 11/2008
      When "CFGASCLB"   : Gosub TITRE_CLB From CFGLIBD    # FQ 50451 GA 11/2008
    Endcase
  When "INIT"
    Case GACTION
      When "SAICFGLIN" :
        If dim(GTLPBOUT) > 0 & GTLPBOUT = 1
          GTLPBOUT = 0
          FIN      = 1
        Else
          Gosub INIT_LIN
        Endif
      When "SAICFGLIN2"
            Call CFGMODLIN(VALEUR)        # JPJ E23057 (protection si changement de code ligne de produit)
            Gosub INIT_LIN
      When "SAICFGPOS"  : Gosub INIT_POS From CFGLIBE
      When "VISUCIT"    : Gosub INIT_CIT
    Endcase
  When "OUVRE" :
    Case GACTION
      When "VISUCQU"   : Gosub OUVRE_CQU
      When "VISUCFM"   : Gosub OUVRE_CFM  From CFGLIBD # Issue 106915 GA 03/2015
      When "VISUCVA"   : Gosub OUVRE_CVA
      When "VISUCRE"   : Gosub OUVRE_CRE
      When "VISUCIT"   : Gosub OUVRE_CIT
      When "VISUHIS"   : Gosub OUVRE_HIS
      When "VISUPIC"   : Gosub OUVRE_PIC From CFGLIBD
      When "VISUPIS"   : Gosub OUVRE_PIS From CFGLIBD
      When "VISUDIC"   : Gosub OUVRE_DIC From CFGLIBD
      When "VISUCFG"   : Gosub OUVRE_CFG From CFGLIBD
      When "SAICFGLIN" : Gosub OUVRE_LIN
      When "SAICFGLIN2": Gosub OUVRE_LIN
      When "SAICFGCMP" : Gosub OUVRE_CMP
      When "SAICFGOPE" : Gosub OUVRE_OPE
      When "SAICFGNOV" : Gosub OUVRE_NOV
      When "SAICFGINP","SAICFGINPS" : Gosub OUVRE_INP
      When "SAICFGPOS" : Gosub OUVRE_POS From CFGLIBE
      When "CFGASTXT"  : Gosub OUVRE_TXT From CFGLIBD
      When "CFGASBLB"  : Gosub OUVRE_BLB From CFGLIBD   # FQ 50451 GA 11/2008
      When "CFGASCLB"  : Gosub OUVRE_CLB From CFGLIBD   # FQ 50451 GA 11/2008
    Endcase
  When "DEBUT" :
    Case GACTION
      When "VISUCQU"   : Gosub DEBUT_CQU
      When "VISUCFM"   : Gosub DEBUT_CFM  From CFGLIBD # Issue 106915 GA 03/2015
      When "VISUCVA"   : Gosub DEBUT_CVA
      When "VISUCRE"   : Gosub DEBUT_CRE
      When "VISUCIT"   : Gosub DEBUT_CIT
      When "VISUHIS"   : Gosub DEBUT_HIS
      When "VISUPIC"   : Gosub DEBUT_PIC From CFGLIBD
      When "VISUPIS"   : Gosub DEBUT_PIS From CFGLIBD
      When "VISUDIC"   : Gosub DEBUT_DIC From CFGLIBD
      When "VISUCFG"   : Gosub DEBUT_CFG From CFGLIBD
      When "SAICFGLIN" : Gosub DEBUT_LIN
      When "SAICFGLIN2": Gosub DEBUT_LIN
      When "SAICFGCMP" : Gosub DEBUT_CMP
      When "SAICFGOPE" : Gosub DEBUT_OPE
      When "SAICFGNOV" : Gosub DEBUT_NOV
      When "SAICFGINP" : Gosub DEBUT_INP
      When "SAICFGINPS": Gosub DEBUT_INPS
      When "SAICFGPOS" : Gosub DEBUT_POS From CFGLIBE
      When "CFGASTXT"  : Gosub DEBUT_TXT From CFGLIBD
      When "CFGASBLB"  : Gosub DEBUT_BLB From CFGLIBD   # FQ 50451 GA 11/2008
      When "CFGASCLB"  : Gosub DEBUT_CLB From CFGLIBD   # FQ 50451 GA 11/2008
    Endcase
  When "APRES_MODIF" :
    Case GACTION
      When "SAICFGINP" : Gosub APRES_MODIF_INP
    Endcase
  When "AVANT_OK"
    Case GACTION
      When "SAICFGPOS" : Gosub AVOK_POS From CFGLIBE
    Endcase
  When "AP_CHOIX"
    Case GACTION
      When "SAICFGINPS" :  If REPONSE=GSTARET : REPONSE=GSTABOU+1 : Endif  # forcer defaut
    Endcase
  When "OK" :
    Case GACTION
      When "SAICFGLIN" : Gosub OK_LIN
      When "SAICFGLIN2": Gosub OK_LIN
      When "SAICFGCMP" : Gosub OK_CMP
      When "SAICFGOPE" : Gosub OK_OPE
      When "SAICFGNOV" : Gosub OK_NOV
      When "SAICFGPOS" : Gosub OK_POS From CFGLIBE
      When "CFGASTXT"  : Gosub OK_TXT From CFGLIBD
      When "CFGASBLB"  : Gosub OK_BLB From CFGLIBD   # FQ 50451 GA 11/2008
      When "CFGASCLB"  : Gosub OK_CLB From CFGLIBD   # FQ 50451 GA 11/2008
    Endcase
  When "END" :
    Case GACTION
      When "SAICFGINP","SAICFGINPS" : Gosub END_INP
      When "SAICFGPOS" : Gosub END_POS From CFGLIBE
    Endcase
  When "SETBOUT" :
    Case GACTION
      When "VISUCQU"   : Gosub SETBOUT_CQU
      When "VISUCVA"   : Gosub SETBOUT_CVA
      When "VISUCRE"   : Gosub SETBOUT_CRE
      When "VISUCIT"   : Gosub SETBOUT_CIT
      When "VISUHIS"   : Gosub SETBOUT_HIS
      When "VISUCFG"   : Gosub SETBOUT_CFG From CFGLIBD
      When "SAICFGLIN" : Gosub SETBOUT_LIN
      When "SAICFGLIN2": Gosub SETBOUT_LIN
      When "SAICFGINP" : Gosub SETBOUT_INP
      When "SAICFGPOS" : Gosub SETBOUT_POS From CFGLIBE  # FQ 62993 GA 03/2010
    Endcase
  When "BOUTON"
    Case GACTION
      When "SAICFGLIN","SAICFGLIN2" : Gosub BOUTON_LIN
      When "SAICFGINP","SAICFGINPS" : Gosub BOUTON_INP
      When "VISUCVA"   : Gosub BOUTON_CVA
      When "VISUCRE"   : Gosub BOUTON_CRE
      When "VISUHIS"   : Gosub BOUTON_HIS
      When "VISUCFG"   : Gosub BOUTON_CFG From CFGLIBD
      When "SAICFGPOS" : Gosub BOUTON_POS From CFGLIBE
    Endcase
  When "FIN" :
    Case GACTION
      When "SAICFGLIN" : Gosub FIN_LIN
      When "SAICFGLIN2": Gosub FIN_LIN
      When "SAICFGCMP" : Gosub FIN_CMP
      When "SAICFGOPE" : Gosub FIN_OPE
      When "SAICFGINP","SAICFGINPS" : Gosub FIN_INP
      When "VISUCVA"   : Gosub FIN_CVA
      When "VISUHIS"   : Gosub FIN_HIS
      When "VISUCFG"   : Gosub FIN_CFG From CFGLIBD
      When "CFGASTXT"  : Gosub FIN_TXT From CFGLIBD
      When "CFGASBLB"  : Gosub FIN_BLB From CFGLIBD   # FQ 50451 GA 11/2008
      When "CFGASCLB"  : Gosub FIN_CLB From CFGLIBD   # FQ 50451 GA 11/2008
    Endcase
  When "FINSAI" :
    Case GACTION
      When "SAICFGLIN" : Gosub FINSAI_LIN
      When "SAICFGLIN2": Gosub FINSAI_LIN2
      When "SAICFGOPE" : Gosub FINSAI_OPE
      When "SAICFGCMP" : Gosub FINSAI_CMP
    Endcase
  When "SEL_TABLE"     : Gosub SEL_TABLE
  When "VERF_TABLE"    : Gosub VERF_TABLE
  When "SEL_LISTE"     : Gosub SEL_LISTE
  When "VERF_LISTE"    : Gosub VERF_LISTE
  When "TRT_DIV"       : Gosub TRT_DIV
  When "FIN_TABLE"     : Gosub FIN_TABLE
Endcase
Return
############################################################
# Selection table
############################################################
$SEL_TABLE
Case TABLE
  When "SELTCO" : Gosub S_SELTCO
  When "SELTCT" : Gosub S_SELTCT
  When "SELQST" : Gosub S_SELQST
  When "SELVAR" : Gosub S_SELVAR
#  When "SELABQ" : Gosub S_SELABQ
#  When "SELABF" : Gosub S_SELABF
  When "SELFOR" : Gosub S_SELFOR
  When "SELFIC" : Gosub S_SELFIC
  When "SELTBL" : Gosub S_SELTBL
  When "SELSYM" : Gosub S_SELSYM
  When "SELMAC" : Gosub S_SELMAC
  When "SELSHA" : Gosub S_SELSHA
  When "SELSHB" : Gosub S_SELSHB
  When "SELSHC" : Gosub S_SELSHC
  When "SELSCE" : Gosub S_SELSCE
  When "SELNOC" : Gosub S_SELNOC
  When "SELSEL" : Gosub S_SELNOC
  When "SELOPS" : Gosub S_SELOPS
  When "SELCUR" : Gosub S_SELCUR
  When "SELTCA" : Gosub S_SELTCA
  When "SELBRF" : Gosub S_SELBRF
  When "SELHLP" : Gosub S_SELHLP
  When "SELADI" : Gosub S_SELADI   # FQ 72873 GA 08/2011
  When "SELAST" : Gosub S_SELAST   # Issue 74287 GA 03/2012
  When "SELCAC" : Gosub S_SELCAC   # Issue 83483 GA 07/2012
Endcase
Return
############################################################
$VERF_TABLE
Case TABLE
  When "SELFOR" : Gosub V_SELFOR
  When "SELCUR" : Gosub V_SELCUR
  When "SELCAC" : Gosub V_SELCAC   # Issue 83483 GA 07/2012
Endcase
Return
############################################################
$FIN_TABLE
Case TABLE
  When "SELSHC" : VALEUR=tolower(VALEUR) # Issue 90687 GA 08/2013 le code F&M passe en minuscules pour forcer le AM du champ
Endcase
Return
############################################################
# Selections liste
############################################################
$SEL_LISTE
Case LISTE
  When Default
Endcase
Return
############################################################
$VERF_LISTE
Case LISTE
  When Default :
Endcase
Return
############################################################
# Selection traitements divers
############################################################
$TRT_DIV
Return
############################################################
# Visu symboles
############################################################
$OUVRE_CQU
If PARAM(1) = ""
  FIN = 1
Else
  If clalev([F:CQU]) = 0 : Local File CFGQST   [CQU] : Endif
  If clalev([F:TCT]) = 0 : Local File TABCTL   [TCT] : Endif
  If clalev([F:TFO]) = 0 : Local File TABFOR   [TFO] : Endif
  If clalev([F:ATB]) = 0 : Local File ATABLE   [ATB] : Endif
  If clalev([F:ATX]) = 0 : Local File ATEXTE   [ATX] : Endif
  If clalev([F:AXX]) = 0 : Local File ATEXTRA  [AXX] : Endif
Endif
Return
############################################################
$DEBUT_CQU
Raz [M:VCQU]
#
Read [CQU]CQU0=PARAM(1)
If fstat
  FIN = 1
Else
  [M:VCQU] = [F:CQU]
  Case [F:CQU]ASWTYP
    When 1 :
      [M:VCQU]STRVAL = [F:CQU]ALPSTRVAL
      [M:VCQU]ENDVAL = [F:CQU]ALPENDVAL
      [M:VCQU]DEFVAL = [F:CQU]ALPDEFVAL
    When 2,4 :
      If [F:CQU]NUMSTRVAL = 0
        [M:VCQU]STRVAL = ""
      Else
        [M:VCQU]STRVAL = num$([F:CQU]NUMSTRVAL)
      Endif
      If [F:CQU]NUMENDVAL = 0
        [M:VCQU]ENDVAL = ""
      Else
        [M:VCQU]ENDVAL = num$([F:CQU]NUMENDVAL)
      Endif
      If [F:CQU]NUMDEFVAL = 0
        [M:VCQU]DEFVAL = ""
      Else
        [M:VCQU]DEFVAL = num$([F:CQU]NUMDEFVAL)
      Endif
    When 3 :
      [M:VCQU]STRVAL = num$([F:CQU]DATSTRVAL)
      [M:VCQU]ENDVAL = num$([F:CQU]DATENDVAL)
      [M:VCQU]DEFVAL = num$([F:CQU]DATDEFVAL)
  Endcase
  # FQ 53410 Champ remplacé par lien
  #If [F:CQU]TCT <> ""
  #  Read [TCT]TCT0=[F:CQU]TCT
  #  If fstat = 0
  #    #[M:VCQU]TCTDES = [F:TCT]TCTDES  # V6 GA 03/2009 Texte traduit CRPOP
  #    Call LECTEXTRA([M:VCQU]TCTDES,"TABCTL","TCTDESAXX",[F:CQU]TCT,"") From ATEXTRA
  #  Endif
  #Endif
  # FQ 53410 Champ remplacé par lien
  #If [F:CQU]CODFIC <> ""
  #  If clalev([F:ATB]) = 0 : Local File ATABLE [ATB] : Endif
  #  Read [ATB]CODFIC=[F:CQU]CODFIC
  #  If fstat = 0
  #    Call TEXTE([F:ATB]INTITFIC,[M:VCQU]INTITFIC) From OBJDIV
  #  Endif
  #Endif
  If [F:CQU]FILFIC <> ""
    If clalev([F:TFO]) = 0 : Local File TABFOR [TFO] : Endif
    Read [TFO]TFO0=7;[F:CQU]FILFIC
    If fstat = 0
      Call LECTEXTRA([M:VCQU]FILTXT,"TABFOR","DES","7",[F:CQU]FILFIC) From ATEXTRA
    Endif
  Endif
  # Issue 85424 GA 11/2012 Image
  Read [CBB]CBB0="CQU";[F:CQU]QSTNUM;""
  If !fstat
      [M:VCQU]CQUPIC = [F:CBB]BLOB
  Endif

  Affzo [M:VCQU]
Endif
Return
############################################################
$SETBOUT_CQU
If [M:VCQU]TCT = ""
  ETABOU(GSPE1) = 0
Else
  ETABOU(GSPE1) = 1
Endif
Return
############################################################
# Visu variables
############################################################
$OUVRE_CVA
Gosub TAB_SYMBOLES   From WUVAR
Gosub CFG_CONSTANTES From CFGLIB
If clalev([F:CQU0]) = 0 : Local File CFGQST [CQU0] : Endif
Return
############################################################
$DEBUT_CVA
Raz [M:VCVA]
[M:VCVA]NBLIG = 0
Filter [CQU0] Where QSTTYP = 2
&            Order By Key CQU0
For [CQU0]
  W_EVA = W_PRS+[F:CQU0]QSTNUM
  If evalue("dim("+W_EVA+")>0")
    If [M:VCVA]NBLIG < dim([M:VCVA]VARNUM)-1
      [M:VCVA]VARNUM([M:VCVA]NBLIG) = [F:CQU0]QSTNUM
      [M:VCVA]VARTYP([M:VCVA]NBLIG) = [F:CQU0]QSTORI
      # FQ 53410 [M:VCVA]VARDES supprimé
      #Call LECTEXTRA([M:VCVA]VARDES([M:VCVA]NBLIG),"CFGQST","QSTAXX",[F:CQU0]QSTNUM,"") From ATEXTRA
      Case [F:CQU0]ASWTYP
        When 1 :
          W_J = evalue("dim("+W_EVA+")")
          [M:VCVA]VARVAL([M:VCVA]NBLIG) = evalue(W_EVA)
          If W_J > 1
            For W_K = 1 To W_J-1
              If evalue(W_EVA+"("+num$(W_K)+")<>''")
                [M:VCVA]VARVAL([M:VCVA]NBLIG) += (","+evalue(W_EVA+"("+num$(W_K)+")"))
              Else
                Break
              Endif
            Next W_K
          Endif
        When 2 :
          [M:VCVA]VARVAL([M:VCVA]NBLIG) = num$(evalue(W_EVA))
        When 3 :
          [M:VCVA]VARVAL([M:VCVA]NBLIG) = num$(evalue(W_EVA))
        When 4 :
          [M:VCVA]VARVAL([M:VCVA]NBLIG) = mess(evalue(W_EVA)+1,1,1)
        When 5 :
          [M:VCVA]VARVAL([M:VCVA]NBLIG) = evalue(W_EVA)
          Call EFF_CRLF([M:VCVA]VARVAL([M:VCVA]NBLIG)) From CFGLIBD
      Endcase
      [M:VCVA]NBLIG += 1
    Endif
  Endif
Next W_I
Sorta [M:VCVA]NBLIG [M:VCVA]NBLIG Order By [M:VCVA]VARTYP(indice), [M:VCVA]VARNUM (indice)
Affzo [M:VCVA]
Return
############################################################
$SETBOUT_CVA
Return
############################################################
$BOUTON_CVA
Call PRTSCR("VISUCVA","VCVA","",0,0) From ATRTX3
Return
############################################################
$FIN_CVA
Return
############################################################
# Visu reponses
############################################################
$OUVRE_CRE
If clalev([F:CQU0]) = 0 : Local File CFGQST  [CQU0] : Endif
If clalev([F:TCT])  = 0 : Local File TABCTL  [TCT]  : Endif
Gosub CFG_CONSTANTES
Return
############################################################
$DEBUT_CRE
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_DESTCT(GLONDCT) : # Intitule code table de contrôle
Else
  Local Char  W_DESTCT(30)  : # Intitule code table de contrôle
Endif
Local Char    W_FLDTCT(GLONAVA)  # Issue 82300 (10)  : # Champ intitule table de contrôle
Raz [M:VCRE]
[M:VCRE]NBLIG = 0
Filter [CQU0] Where QSTTYP = 1
&            Order By Key CQU0
For [CQU0]
  W_EVA = W_PRS+[F:CQU0]QSTNUM
  If evalue("dim("+W_EVA+")>0")
    If [M:VCRE]NBLIG < dim([M:VCRE]VARNUM)-1
      [M:VCRE]VARNUM([M:VCRE]NBLIG) = [F:CQU0]QSTNUM
      # FQ 53410 [M:VCRE]VARDES supprimé
      #Call LECTEXTRA([M:VCRE]VARDES([M:VCRE]NBLIG),"CFGQST","QSTAXX",[F:CQU0]QSTNUM,"") From ATEXTRA
      Case [F:CQU0]ASWTYP
        When 1 :
          [M:VCRE]VARVAL([M:VCRE]NBLIG) = evalue(W_EVA)
          If [F:CQU0]TCT <> ""
            Read [TCT]TCT1=[F:CQU0]TCT;evalue(W_EVA);0
            If fstat = 0
              Call CFGDESTCT(W_DESTCT,W_FLDTCT)
              [M:VCRE]VARVAL([M:VCRE]NBLIG) += (" ("+W_DESTCT+")")
            Endif
          Endif
          If [F:CQU0]SHACAT <> ""
            # FQ 60007 GA 11/2009 Read remplacé par LECTEXTRA puisqu'on n'utilise que le libellé
            #Read [CSH]CSH0=[F:CQU0]SHACAT;evalue(W_EVA)
            #If fstat = 0
              Call LECTEXTRA(GBIDC1,"CFGSHA","SHANUMAXX",[F:CQU0]SHACAT,evalue(W_EVA)) From ATEXTRA
              [M:VCRE]VARVAL([M:VCRE]NBLIG) += (" ("+GBIDC1+")")
            #Endif
          Endif
        When 2 :
          [M:VCRE]VARVAL([M:VCRE]NBLIG) = num$(evalue(W_EVA))
          If [F:CQU0]TCT <> ""
            Read [TCT]TCT1=[F:CQU0]TCT;"";val(num$(evalue(W_EVA)))
            If fstat = 0
              Call CFGDESTCT(W_DESTCT,W_FLDTCT)
              [M:VCRE]VARVAL([M:VCRE]NBLIG) += (" ("+W_DESTCT+")")
            Endif
          Endif
        When 3 :
          [M:VCRE]VARVAL([M:VCRE]NBLIG) = num$(evalue(W_EVA))
        When 4 :
          [M:VCRE]VARVAL([M:VCRE]NBLIG) = mess(evalue(W_EVA)+1,1,1)
        When 5 :
          [M:VCRE]VARVAL([M:VCRE]NBLIG) = evalue(W_EVA)
          Call EFF_CRLF([M:VCRE]VARVAL([M:VCRE]NBLIG)) From CFGLIBD
      Endcase
      [M:VCRE]NBLIG += 1
    Endif
  Endif
Next
Filter [CQU0]
Affzo [M:VCRE]
Return
############################################################
$SETBOUT_CRE
Return
############################################################
$BOUTON_CRE
Call PRTSCR("VISUCRE","VCRE","",0,0) From ATRTX3
Call IMPSCR                          From ATRTX3
Return
############################################################
# Visu donnee configurateur article
############################################################
$INIT_CIT
If clalev([F:ITM]) = 0 : Local File ITMMASTER   [ITM] : Endif
If clalev([F:TLP]) = 0 : Local File TABLINCFG   [TLP] : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL      [TCT] : Endif
If [F:ITM]ITMREF <> PARAM(1)
  Read [ITM]ITM0=PARAM(1)
  If fstat
    FIN = 1
    Return
  Endif
Endif
Read [TLP]TLP0=[F:ITM]CFGLIN
If fstat
  FIN = 1
  Return
Endif
BOITE ="WUL"+[F:TLP]CFGLIN
If GVERSION>"1.6.4" # Issue 79909 - X3V6p18 Differed validations may cause some trouble here
    Call ISSCREENOK (S_DOSSIER,BOITE) From INTRUTILB
Endif
Return
############################################################
$OUVRE_CIT
Local Integer I
Local Char    WTCT(GLONTCT)
Local Decimal WNUM
Local Char    WALP(250)
Return
############################################################
$DEBUT_CIT
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_DESTCT(GLONDCT) : # Intitule code table de contrôle
Else
  Local Char  W_DESTCT(30)  : # Intitule code table de contrôle
Endif
Local Char    W_FLDTCT(GLONAVA)  # Issue 82300 (10)  : # Champ intitule table de contrôle
Raz [M:CLIN]
[M:CLIN]       = [F:TLP]
[M:CLIN]       = [F:ITM]
For I = 1 To 6
  WTCT = evalue("[F:TLP]CFGNUMTCT"+num$(I))
  WALP = ""
  WNUM = evalue("[F:ITM]CFGFLDNUM"+num$(I))
  If WTCT <> "" & evalue("dim([M:CLIN]CFGTXTNUM"+num$(I)+")>0")
    Read [TCT]TCT1=WTCT;WALP;WNUM
    If fstat = 0
      Call CFGDESTCT(W_DESTCT,W_FLDTCT)
      Assign "[M:CLIN]CFGTXTNUM"+num$(I) With W_DESTCT
    Else
      Assign "[M:CLIN]CFGTXTNUM"+num$(I) With ""
    Endif
  Endif
Next I
For I = 1 To 6
  WTCT = evalue("[F:TLP]CFGALPTCT"+num$(I))
  WNUM = 0
  WALP = evalue("[F:ITM]CFGFLDALP"+num$(I))
  If WTCT <> "" &  evalue("dim([M:CLIN]CFGTXTALP"+num$(I)+")>0")
    Read [TCT]TCT1=WTCT;WALP;WNUM
    If fstat = 0
      Call CFGDESTCT(W_DESTCT,W_FLDTCT)
      Assign "[M:CLIN]CFGTXTALP"+num$(I) With W_DESTCT
    Else
      Assign "[M:CLIN]CFGTXTALP"+num$(I) With ""
    Endif
  Endif
Next I
Grizo [M:CLIN]1-99
Affzo [M:CLIN]
Return
############################################################
$SETBOUT_CIT
Return
############################################################
# Visu historique d'une configuration
############################################################
$OUVRE_HIS
If clalev([F:CSC])  = 0 : Local File CFGSCE    [CSC]  : Endif
If clalev([F:CQU])  = 0 : Local File CFGQST    [CQU]  : Endif
If clalev([F:CHH])  = 0 : Local File CFGHISHEA [CHH]  : Endif
If clalev([F:CFH])  = 0 : Local File CFGHIS    [CFH]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER [ITM1] : Endif
If clalev([F:BPR1]) = 0 : Local File BPARTNER  [BPR1] : Endif
# Lecture scenario
Read [CSC]CSC0= PARAM(1)
If fstat
  FIN = 1
  Return
Endif
# Lecture entete historique
Read [CHH]CHH1=[F:CSC]SCENUM;PARAM(2)
If fstat
  FIN = 1
  Return
Endif
Return
############################################################
$DEBUT_HIS
Raz [M:VCFH]
# lecture [BPR]
Read [BPR]BPR0=[F:CHH]CFGBPRNUM
If fstat
  Raz [F:BPR]
Endif
# Lecture [ITM1]
Read [ITM1]ITM0=[F:CHH]ITMREF
If fstat
  Raz [F:ITM1]
Endif
[M:VCFH]          = [F:CHH]
[M:VCFH]SCENUM    = [F:CSC]SCENUM
# FGR 15/01/2010 : X3SUIVI60986
#Call GET_ATEXTRA("CFGSCE","SCEAXX",GLANGUE,[M:VCFH]SCEDES) From TRTX3TEX
[M:VCFH]CFGBPRNUM = [F:BPR]BPRNUM
[M:VCFH]CFGBPRNAM = [F:BPR]BPRNAM
#[M:VCFH]ITMDES1   = [F:ITM1]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VCFH]ITMDES1, "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:VCFH]STU       = [F:ITM1]STU
If [F:CHH]CFGDELDAT <> [31/12/2999]
  [M:VCFH]CFGDELDAT = [0/0/0]
Endif
If [F:CHH]ROUNUM <> ""
  Read [ITM1]ITM0=[F:CHH]ROUNUM
  If fstat
    Raz [F:ITM1]
  Endif
  #[M:VCFH]ROUDES = [F:ITM1]ITMDES1
  #Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VCFH]ROUDES, "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  Call LECTEXTRA([M:VCFH]ROUDES,"ROUTING", "ROUDESAXX",[F:CHH]ROUNUM+"~"+num$([F:CHH]ROUALT),[F:CHH]FCY) From ATEXTRA
Endif
#
Filter [CFH] Where SCENUM    = [F:CSC]SCENUM &
&                  CFGVCRNUM = PARAM(2)
&            Order By Key CFH0
For [CFH]
  Read [CQU]CQU0=[F:CFH]SYMNUM
  If fstat = 0
    Case [F:CQU]QSTTYP
      When 1 :
        If [M:VCFH]NBLIG1 < dim([M:VCFH]QSTNUM)-1
          [M:VCFH]QSTNUM([M:VCFH]NBLIG1) = [F:CQU]QSTNUM
          # FQ 53410 remplacé par le lien
          #[M:VCFH]QSTDES([M:VCFH]NBLIG1) = [F:CQU]QSTSHO
          Case [F:CQU]ASWTYP
            When 1 : [M:VCFH]QSTVAL([M:VCFH]NBLIG1) = [F:CFH]VALALP
            When 2 : [M:VCFH]QSTVAL([M:VCFH]NBLIG1) = num$([F:CFH]VALNUM)
            When 3 : [M:VCFH]QSTVAL([M:VCFH]NBLIG1) = num$([F:CFH]VALDAT)
            When 4 : [M:VCFH]QSTVAL([M:VCFH]NBLIG1) = mess([F:CFH]VALNUM+1,1,1)
          Endcase
          [M:VCFH]NBLIG1 += 1
        Else
          Break
        Endif
      When Default :
        If [M:VCFH]NBLIG2< dim([M:VCFH]VARNUM)-1
          [M:VCFH]VARNUM([M:VCFH]NBLIG2) = [F:CQU]QSTNUM
          [M:VCFH]VARSEQ([M:VCFH]NBLIG2) = [F:CFH]SYMSEQ
          # FQ 53410 remplacé par le lien
          #[M:VCFH]VARDES([M:VCFH]NBLIG2) = [F:CQU]QSTSHO
          Case [F:CQU]ASWTYP
            When 1 : [M:VCFH]VARVAL([M:VCFH]NBLIG2) = [F:CFH]VALALP
            When 2 : [M:VCFH]VARVAL([M:VCFH]NBLIG2) = num$([F:CFH]VALNUM)
            When 3 : [M:VCFH]VARVAL([M:VCFH]NBLIG2) = num$([F:CFH]VALDAT)
            When 4 : [M:VCFH]VARVAL([M:VCFH]NBLIG2) = mess([F:CFH]VALNUM+1,1,1)
          Endcase
          [M:VCFH]NBLIG2 += 1
        Else
          Break
        Endif
      Endcase
  Endif
Next
Filter [CFH]
Affzo [M:VCFH]
Return
############################################################
$SETBOUT_HIS
Return
############################################################
$BOUTON_HIS
Call PRTSCR("CFGVHIS","VCFH","",0,0) From ATRTX3
Return
############################################################
$FIN_HIS
Return
############################################################
# saisie des donnees article de configuration
############################################################
$INIT_LIN
#If dim(GTLPBOUT) > 0
#  GTLPBOUT = 1  # bug 18744 déplacé (14/10/03)
#Endif
#
If GIMPORT | VALEUR = ""
  FIN = 1
  Return
Endif
If clalev([F:TLP]) = 0 : Local File TABLINCFG [TLP] : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT] : Endif
Read [TLP]TLP0=VALEUR
If fstat
  FIN = 1
  Return
Endif
If [F:TLP]CFGNUM1 = 1 & [F:TLP]CFGNUM2 = 1 & [F:TLP]CFGNUM3 = 1 &
&  [F:TLP]CFGNUM4 = 1 & [F:TLP]CFGNUM5 = 1 & [F:TLP]CFGNUM6 = 1 &
&  [F:TLP]CFGALP1 = 1 & [F:TLP]CFGALP2 = 1 & [F:TLP]CFGALP3 = 1 &
&  [F:TLP]CFGALP4 = 1 & [F:TLP]CFGALP5 = 1 & [F:TLP]CFGALP6 = 1
  FIN = 1
  Return
Endif
BOITE = "WUL"+VALEUR
If GVERSION>"1.6.4" # Issue 79909 - X3V6p18 Differed validations may cause some trouble here
   If dim(S_DOSSIER) < 0 # suite Issue 79909 utilisé par GESITM
      Global Char    S_DOSSIER(10) : S_DOSSIER = nomap
   Endif
   Call ISSCREENOK (S_DOSSIER,BOITE) From INTRUTILB
Endif
Return
############################################################
$OUVRE_LIN
Return
############################################################
$DEBUT_LIN
If dim(GTLPBOUT) > 0
  GTLPBOUT = 1 # bug 18744 déplacé ici car en Web on passe 2 fois dans INIT (14/10/03)
Endif
Local Integer I
Local Char    WTCT(GLONTCT)
Local Decimal WNUM
Local Char    WALP(250)
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_DESTCT(GLONDCT) : # Intitule code table de contrôle
Else
  Local Char  W_DESTCT(30)      : # Intitule code table de contrôle
Endif
Local Char    W_FLDTCT(GLONAVA)  # Issue 82300 (10)  : # Champ intitule table de contrôle
#
[M:CLIN] = [M:ITM1]
[M:CLIN] = [F:TLP]
For I = 1 To 6
  WTCT = evalue("[F:TLP]CFGNUMTCT"+num$(I))
  WALP = ""
  WNUM = evalue("[M:ITM1]CFGFLDNUM"+num$(I))
  If WTCT <> "" & evalue("dim([M:CLIN]CFGTXTNUM"+num$(I)+")>0")
    Read [TCT]TCT1=WTCT;WALP;WNUM
    If fstat = 0
      Call CFGDESTCT(W_DESTCT,W_FLDTCT)
      Assign "[M:CLIN]CFGTXTNUM"+num$(I) With W_DESTCT
    Else
      Assign "[M:CLIN]CFGTXTNUM"+num$(I) With ""
    Endif
  Endif
Next I
For I = 1 To 6
  WTCT = evalue("[F:TLP]CFGALPTCT"+num$(I))
  WNUM = 0
  WALP = evalue("[M:ITM1]CFGFLDALP"+num$(I))
  If WTCT <> "" &  evalue("dim([M:CLIN]CFGTXTALP"+num$(I)+")>0")
    Read [TCT]TCT1=WTCT;WALP;WNUM
    If fstat = 0
      Call CFGDESTCT(W_DESTCT,W_FLDTCT)
      Assign "[M:CLIN]CFGTXTALP"+num$(I) With W_DESTCT
    Else
      Assign "[M:CLIN]CFGTXTALP"+num$(I) With ""
    Endif
  Endif
Next I
Affzo [M:CLIN]
Return
############################################################
$SETBOUT_LIN
Return
############################################################
$BOUTON_LIN
Case BOUT
  When "a" :
    Effzo [M:CLIN]10
    Effzo [M:CLIN]15
Endcase
Return
############################################################
$OK_LIN
[M:ITM1] = [M:CLIN]
FIN = 1
Return
############################################################
$FINSAI_LIN
mkstat = 0
Return
############################################################
$FINSAI_LIN2
mkstat = 4
Return
############################################################
$FIN_LIN
Return
############################################################
# saisie des donnees composant
############################################################
$OUVRE_CMP
Local Integer W_I, W_J, W_K, W_L
Local Integer W_TYP
Local Char    W_ZON(GLONAVA)  # Issue 82300 (10)
Local Char    W_MSG(250)
Local Char    W_PAR(1)
#
W_I = val(PARAM(1))-1
If W_I >= 0
  Read [ITM]ITM0=[M:CFG6]ITMREF(W_I)
  If fstat
    FIN = 1
    Return
  Endif
Else
  FIN = 1
Endif
Return
############################################################
$DEBUT_CMP
Raz [M:CFGC]
[M:CFGC]SCENUMSEQ = [M:CFG6]SCENUMSEQ(W_I)
[M:CFGC]          = [F:ITM]
[M:CFGC]SYMPAR = "1278BDEGILNS"
Call PARAM([M:CFG0]FCY,"CFGADV",W_PAR) From ADOVAL
If val(W_PAR) = 2
  [M:CFGC]SYMPAR += "6C"
Endif
#
Call CFGSETFOR(7,"","DEFGHILNS",[M:CFGC]FILTAB,[M:CFG0]TEXCON,[M:CFG0]VARSUP) From CFGLIB
# Chargement masque CFGC a partir de CFGW
W_K = -1
W_L = -1
For W_J = 0 To [M:CFGW]NBLIGW-1
  If [M:CFGW]SCENUMSEQ(W_J) = [M:CFG6]SCENUMSEQ(W_I) &
&    [M:CFGW]ITMREF   (W_J) = [M:CFG6]ITMREF   (W_I)
    If W_K = -1
      W_K = W_J
    Endif
    W_L = W_J
    If [M:CFGC]NBLIGC < dim([M:CFGC]SYMTYP)-1
      [M:CFGC]SYMDIS   ([M:CFGC]NBLIGC) = [M:CFGW]SYMDIS    (W_J)
      [M:CFGC]SYMTYP   ([M:CFGC]NBLIGC) = [M:CFGW]SYMTYP    (W_J)
      [M:CFGC]SYMNUM   ([M:CFGC]NBLIGC) = [M:CFGW]SYMNUM    (W_J)
      [M:CFGC]SYMIND   ([M:CFGC]NBLIGC) = [M:CFGW]SYMIND    (W_J)
     # FQ 53410 remplacé par lien
     # [M:CFGC]SYMDES   ([M:CFGC]NBLIGC) = [M:CFGW]SYMDES    (W_J)
      If dim( [M:CFGC]SYMDES)>0 # Issue 84374 GA 09/2012
         nolign = [M:CFGC]NBLIGC+1
         Call SYM_TXT([M:CFGC]SYMDES(nolign-1),[M:CFGC]SYMTYP(nolign-1),[M:CFGC]SYMNUM(nolign-1),"") From CFGLIB
      Endif
      [M:CFGC]UPDCOD   ([M:CFGC]NBLIGC) = [M:CFGW]UPDCOD    (W_J)
      [M:CFGC]CNDFOR   ([M:CFGC]NBLIGC) = [M:CFGW]CNDFOR    (W_J)
      [M:CFGC]FORFOR   ([M:CFGC]NBLIGC) = [M:CFGW]FORFOR    (W_J)
      [M:CFGC]ABQNUM   ([M:CFGC]NBLIGC) = [M:CFGW]ABQNUM    (W_J)
      [M:CFGC]ABQVAL   ([M:CFGC]NBLIGC) = [M:CFGW]ABQVAL    (W_J)
      [M:CFGC]ABQVALY  ([M:CFGC]NBLIGC) = [M:CFGW]ABQVALY   (W_J)
      If dim([M:CFGW]SCETXT)>0
         [M:CFGC]SCETXT([M:CFGC]NBLIGC) = [M:CFGW]SCETXT    (W_J)  : # FQ 47427 GA 05/2008
      Endif
      [M:CFGC]NBLIGC += 1
    Else
      GMESSAGE = mess(34,188,1)-"CFGC"-num$(dim([M:CFGC]SYMTYP))
      GERR     = 1
      FIN      = 1
      Break
    Endif
  Endif
Next W_J
Affzo [M:CFGC]
Return
############################################################
$OK_CMP
W_MSG = ""
Call CFG_CTRSAI("[M:CFGC]","[M:CFGC]NBLIGC",W_MSG)
If W_MSG <> ""
  GMESSAGE = W_MSG
  GERR = 1
  Return
Endif
# Effacement anciennes information de ce composant dans CFGW
If W_K >= 0
  W_L = (W_L-W_K)+1
  Dela W_K,W_L,[M:CFGW]NBLIGW [M:CFGW]NBLIGW
  [M:CFGW]NBLIGW -= W_L
Endif
# Chargement nouvelles informations de ce composant dans CFGW
For W_I = 0 To [M:CFGC]NBLIGC-1
  If [M:CFGW]NBLIGW < dim([M:CFGW]SCENUMSEQ)-1
    [M:CFGW]SCENUMSEQ([M:CFGW]NBLIGW) = [M:CFGC]SCENUMSEQ
    [M:CFGW]ITMREF   ([M:CFGW]NBLIGW) = [M:CFGC]ITMREF
    [M:CFGW]SYMDIS   ([M:CFGW]NBLIGW) = [M:CFGC]SYMDIS   (W_I)
    [M:CFGW]SYMTYP   ([M:CFGW]NBLIGW) = [M:CFGC]SYMTYP   (W_I)
    [M:CFGW]SYMNUM   ([M:CFGW]NBLIGW) = [M:CFGC]SYMNUM   (W_I)
#CHECK IGNORE_BEGIN
    # FQ 53410 remplacé par lien
    # [M:CFGW]SYMDES   ([M:CFGW]NBLIGW) = [M:CFGC]SYMDES   (W_I)         # JPJ E19160
    If dim( [M:CFGW]SYMDES)>0 # Issue 84374 GA 09/2012
       Call SYM_TXT([M:CFGW]SYMDES([M:CFGW]NBLIGW),[M:CFGW]SYMTYP([M:CFGW]NBLIGW),[M:CFGW]SYMNUM([M:CFGW]NBLIGW),"") From CFGLIB
    Endif
#CHECK IGNORE_END
    [M:CFGW]SYMIND   ([M:CFGW]NBLIGW) = [M:CFGC]SYMIND   (W_I)
    [M:CFGW]UPDCOD   ([M:CFGW]NBLIGW) = [M:CFGC]UPDCOD   (W_I)
    [M:CFGW]CNDFOR   ([M:CFGW]NBLIGW) = [M:CFGC]CNDFOR   (W_I)
    [M:CFGW]FORFOR   ([M:CFGW]NBLIGW) = [M:CFGC]FORFOR   (W_I)
    [M:CFGW]ABQNUM   ([M:CFGW]NBLIGW) = [M:CFGC]ABQNUM   (W_I)
    [M:CFGW]ABQVAL   ([M:CFGW]NBLIGW) = [M:CFGC]ABQVAL   (W_I)
    [M:CFGW]ABQVALY  ([M:CFGW]NBLIGW) = [M:CFGC]ABQVALY  (W_I)
    If dim([M:CFGW]SCETXT)>0
       [M:CFGW]SCETXT([M:CFGW]NBLIGW) = [M:CFGC]SCETXT   (W_I)  : # FQ 47427 GA 05/2008
    Endif
    [M:CFGW]NBLIGW += 1
  Else
    GMESSAGE = mess(34,188,1)-"CFGW"-num$(dim([M:CFGW]SCENUMSEQ))
    GERR     = 1
    Break
  Endif
Next W_I
FIN = 1
mkstat = 4
Return
############################################################
$FIN_CMP
mkstat = 4
Return
############################################################
$FINSAI_CMP
mkstat = 4
Return
############################################################
# saisie d'un nomenclature commerciale
############################################################
$OUVRE_NOV
Return
############################################################
$DEBUT_NOV
Return
############################################################
$OK_NOV
Local Integer I
[M:CSE2]ITMREFNBR = 0
[M:CSE2]RULNBR    = 0
For I = 0 To [M:CSE3]NBLIG-1
  If [M:CSE2]ITMREFNBR < dim([M:CSE2]ITMREFSEQ)
    Read [ITM]ITM0=[M:CSE3]CPNITMREF(I)
    If fstat = 0
      [M:CSE2]ITMREFSEQ([M:CSE2]ITMREFNBR) = [M:CSE3]BOMSEQ(I)
      [M:CSE2]ITMOPVAXX([M:CSE2]ITMREFNBR) = mess([M:CSE3]CPNTYP(I),438,1)-num$([M:CSE3]BOMSEQ(I))
      [M:CSE2]ITMREFLOA([M:CSE2]ITMREFNBR) = [M:CSE3]CPNITMREF(I)
      #[M:CSE2]ITMDES1  ([M:CSE2]ITMREFNBR) = [F:ITM]ITMDES1
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CSE2]ITMDES1([M:CSE2]ITMREFNBR), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      [M:CSE2]ITMREFQTY([M:CSE2]ITMREFNBR) = 1     # JPJ E24307
      [M:CSE2]ITMREFFOR([M:CSE2]ITMREFNBR) = ""
      [M:CSE2]ITMREFCAL([M:CSE2]ITMREFNBR) = ""
      [M:CSE2]CFGLINNUM([M:CSE2]ITMREFNBR) = [F:ITM]CFGLIN
      Read [TLP]TLP0=[F:ITM]CFGLIN
      If fstat
        Raz [F:TLP]
      Endif
      Call GET_ATEXTRA("TABLINCFG","CFGLINAXX",GLANGUE,[M:CSE2]CFGLINAXX([M:CSE2]ITMREFNBR)) From TRTX3TEX
      If [M:CSE3]CPNTYP(I) = 1 |  [M:CSE3]CPNTYP(I) = 3
        If [M:CSE2]RULNBR < dim([M:CSE2]RULOPT1)
          If !find([M:CSE3]BOMSEQ(I),[M:CSE2]RULOPT1(0..[M:CSE2]RULNBR-1))
            [M:CSE2]RULOPT1   ([M:CSE2]RULNBR)  = [M:CSE2]ITMREFSEQ([M:CSE2]ITMREFNBR)
            [M:CSE2]RULOPTTXT1([M:CSE2]RULNBR)  = [M:CSE2]ITMOPVAXX([M:CSE2]ITMREFNBR)
            [M:CSE2]RUL       ([M:CSE2]RULNBR)  = 1
            [M:CSE2]RULOPT2   ([M:CSE2]RULNBR)  = 0
            [M:CSE2]RULOPTTXT2([M:CSE2]RULNBR)  = ""
            [M:CSE2]RULNBR += 1
          Endif
        Endif
      Endif
      [M:CSE2]ITMREFNBR += 1
    Endif
  Endif
Next I
Affzo [M:CSE2]
FIN = 1
Return
############################################################
# saisie des donnees operations
############################################################
$OUVRE_OPE
Local Integer W_I, W_J, W_K, W_L
Local Integer W_TYP
Local Char    W_ZON(GLONAVA)  # Issue 82300 (10)
Local Char    W_MSG(250)
Local Char    W_PAR(1)
#
W_I = val(PARAM(1))-1
Return
############################################################
$DEBUT_OPE
Raz [M:CFGO]
[M:CFGO]OPENUM    = [M:CFG8]OPENUM   (W_I)
[M:CFGO]STDOPENUM = [M:CFG8]STDOPENUM(W_I)
[M:CFGO]RPLIND    = [M:CFG8]RPLIND   (W_I)
[M:CFGO]ROODES    = [M:CFG8]ROODES   (W_I)
[M:CFGO]SYMPAR = "1278BKM"
Call PARAM([M:CFG0]FCY,"CFGADV",W_PAR) From ADOVAL
If val(W_PAR) = 2
  [M:CFGO]SYMPAR += "6C"
Endif
#
Call CFGSETFOR(7,"","JM",[M:CFGO]FILTAB,[M:CFG0]TEXCON,[M:CFG0]VARSUP) From CFGLIB
# Chargement masque CFGO a partir de CFGX
W_K = -1
W_L = -1
For W_J = 0 To [M:CFGX]NBLIGX-1
  If [M:CFGX]OPENUM   (W_J) = [M:CFG8]OPENUM   (W_I) &
&    [M:CFGX]STDOPENUM(W_J) = [M:CFG8]STDOPENUM(W_I)
    If W_K = -1
      W_K = W_J
    Endif
    W_L = W_J
    If [M:CFGO]NBLIGO < dim([M:CFGO]SYMTYP)-1
      [M:CFGO]SYMDIS   ([M:CFGO]NBLIGO) = [M:CFGX]SYMDIS    (W_J)
      [M:CFGO]SYMTYP   ([M:CFGO]NBLIGO) = [M:CFGX]SYMTYP    (W_J)
      [M:CFGO]SYMNUM   ([M:CFGO]NBLIGO) = [M:CFGX]SYMNUM    (W_J)
      [M:CFGO]SYMIND   ([M:CFGO]NBLIGO) = [M:CFGX]SYMIND    (W_J)
      # FQ 53410 remplacé par lien
      # [M:CFGO]SYMDES   ([M:CFGO]NBLIGO) = [M:CFGX]SYMDES    (W_J)
      If dim( [M:CFGO]SYMDES)>0 # Issue 84374 GA 09/2012
         nolign = [M:CFGO]NBLIGO+1
         Call SYM_TXT([M:CFGO]SYMDES(nolign-1),[M:CFGO]SYMTYP(nolign-1),[M:CFGO]SYMNUM(nolign-1),"") From CFGLIB
      Endif
      [M:CFGO]UPDCOD   ([M:CFGO]NBLIGO) = [M:CFGX]UPDCOD    (W_J)
      [M:CFGO]CNDFOR   ([M:CFGO]NBLIGO) = [M:CFGX]CNDFOR    (W_J)
      [M:CFGO]FORFOR   ([M:CFGO]NBLIGO) = [M:CFGX]FORFOR    (W_J)
      [M:CFGO]ABQNUM   ([M:CFGO]NBLIGO) = [M:CFGX]ABQNUM    (W_J)
      [M:CFGO]ABQVAL   ([M:CFGO]NBLIGO) = [M:CFGX]ABQVAL    (W_J)
      [M:CFGO]ABQVALY  ([M:CFGO]NBLIGO) = [M:CFGX]ABQVALY   (W_J)
      If dim([M:CFGO]SCETXT)>0 & dim([M:CFGX]SCETXT)>0
         [M:CFGO]SCETXT([M:CFGO]NBLIGO) = [M:CFGX]SCETXT    (W_J)  : # FQ 48843 GA 08/2008
      Endif
      [M:CFGO]NBLIGO += 1
    Else
      GMESSAGE = mess(34,188,1)-"CFGO"-num$(dim([M:CFGO]SYMTYP))
      GERR     = 1
      FIN      = 1
      Break
    Endif
  Endif
Next W_J
Affzo [M:CFGO]
Return
############################################################
$OK_OPE
W_MSG = ""
Call CFG_CTRSAI("[M:CFGO]","[M:CFGO]NBLIGO",W_MSG)
If W_MSG <> ""
  GMESSAGE = W_MSG
  GERR = 1
  Return
Endif
# Effacement anciennes information de ce composant dans CFGX
If W_K >= 0
  W_L = (W_L-W_K)+1
  Dela W_K,W_L,[M:CFGX]NBLIGX [M:CFGX]NBLIGX
  [M:CFGX]NBLIGX -= W_L
Endif
# Chargement nouvelles informations de ce composant dans CFGX
For W_I = 0 To [M:CFGO]NBLIGO-1
  If [M:CFGX]NBLIGX < dim([M:CFGX]OPENUM)-1
    [M:CFGX]OPENUM   ([M:CFGX]NBLIGX) = [M:CFGO]OPENUM
    [M:CFGX]STDOPENUM([M:CFGX]NBLIGX) = [M:CFGO]STDOPENUM
    [M:CFGX]RPLIND   ([M:CFGX]NBLIGX) = [M:CFGO]RPLIND
    [M:CFGX]SYMDIS   ([M:CFGX]NBLIGX) = [M:CFGO]SYMDIS   (W_I)
    [M:CFGX]SYMTYP   ([M:CFGX]NBLIGX) = [M:CFGO]SYMTYP   (W_I)
    [M:CFGX]SYMNUM   ([M:CFGX]NBLIGX) = [M:CFGO]SYMNUM   (W_I)
    [M:CFGX]SYMIND   ([M:CFGX]NBLIGX) = [M:CFGO]SYMIND   (W_I)
    [M:CFGX]UPDCOD   ([M:CFGX]NBLIGX) = [M:CFGO]UPDCOD   (W_I)
    [M:CFGX]CNDFOR   ([M:CFGX]NBLIGX) = [M:CFGO]CNDFOR   (W_I)
    [M:CFGX]FORFOR   ([M:CFGX]NBLIGX) = [M:CFGO]FORFOR   (W_I)
    [M:CFGX]ABQNUM   ([M:CFGX]NBLIGX) = [M:CFGO]ABQNUM   (W_I)
    [M:CFGX]ABQVAL   ([M:CFGX]NBLIGX) = [M:CFGO]ABQVAL   (W_I)
    [M:CFGX]ABQVALY  ([M:CFGX]NBLIGX) = [M:CFGO]ABQVALY  (W_I)
    If dim([M:CFGO]SCETXT)>0 & dim([M:CFGX]SCETXT)>0
       [M:CFGX]SCETXT([M:CFGX]NBLIGX) = [M:CFGO]SCETXT   (W_I)  : # FQ 48843 GA 08/2008
    Endif
    [M:CFGX]NBLIGX += 1
  Else
    GMESSAGE = mess(34,188,1)-"CFGX"-num$(dim([M:CFGX]OPENUM))
    GERR     = 1
    Break
  Endif
Next W_I
FIN = 1
mkstat = 4
Return
############################################################
$FIN_OPE
mkstat = 4
Return
############################################################
$FINSAI_OPE
mkstat = 4
Return
############################################################
# Entree configurateur
############################################################
$OUVRE_INP
Global Integer S_NOLIGN : S_NOLIGN = nolign
# Effacement variables globales configurateur si fin anormale dans appel precedent
If dim(S_CFGCFG) > 0
  Gosub SUP_GLOBALES From WUVAR
Endif
#
# FQ 50318 ne pas créer S_FCY ici
#If dim(S_FCY) < 0
#  Global Char S_FCY(GLONFCY)
#Endif
#S_FCY    = PARAM(1)
#
If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
If clalev([F:CSE]) = 0 : Local File CFGSEL   [CSE] : Endif
If clalev([F:CSC]) = 0 : Local File CFGSCE   [CSC] : Endif
If clalev([M:CFW]) = 0 : Local Mask CFGWRK   [CFW] : Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
Raz [M:CFW]
# FQ 75381 GA 08/2011 autoriser l'entrée si pas de site par défaut
If PARAM(1)<>""
   Read [FCY]FCY0=PARAM(1)
   #If fstat FIN = 1 Endif
Endif
Return
############################################################
$DEBUT_INP
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Raz [M:CFGI]
[M:CFGI]FCY    = PARAM(1)
[M:CFGI]FCYNAM = [F:FCY]FCYNAM
[M:CFGI]BPRNUM = PARAM(2)
[M:CFGI]BPRREF = PARAM(3)
[M:CFGI]IPTDAT = PARAM(4)
[M:CFGI]CFGPHA = val(PARAM(5))
[M:CFGI]SELQTY = val(PARAM(6))
[M:CFGI]SELTXT = val(PARAM(7))
Affzo [M:CFGI]
Return
############################################################
$DEBUT_INPS
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Raz [M:CFGI]
[M:CFGI]FCY    = PARAM(1)
[M:CFGI]FCYNAM = [F:FCY]FCYNAM
Affzo [M:CFGI]
Return
############################################################
$APRES_MODIF_INP
Case COUZON
  When "SELNUM" : [M:CFGI]SELNUM = CZ
  When "OPTNUM" : [M:CFGI]OPTNUM = CZ
  When "SCENUM" : [M:CFGI]SCENUM = CZ
Endcase
Return
############################################################
$SETBOUT_INP
ETABOU(GSPE1) = 0
ETABOU(GSPE2) = 0
ETABOU(GSPE3) = 0
If [M:CFGI]SELNUM <> ""
  ETABOU(GSPE1) = 1
  Return
Endif
If [M:CFGI]OPTNUM <> ""
  ETABOU(GSPE2) = 1
  Return
Endif
If [M:CFGI]SCENUM <> ""
  ETABOU(GSPE3) = 1
  Return
Endif
Return
############################################################
$BOUTON_INP
Case BOUT
  When "a" : FIN = 1
  When "b" : FIN = 1
  When "c" : FIN = 1
Endcase
Return
############################################################
$END_INP
FIN = 1
Return
############################################################
$FIN_INP
Gosub SUP_GLOBALES From WUVAR
#----- Restitution variables globales -----#
Gosub REST_GLOB    From TRTX3GLOB
GORITITCOL=1
If dim(WGCONSULT) > 0
  GCONSULT = WGCONSULT
Endif
Return
############################################################
# Fenetre de selection tables de contrôle
############################################################
$S_SELTCO
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]  : Endif
#
Local Integer WTYP : WTYP = val(PARAM(1))
TIT(0) = mess(105,188,1)
NBCOL += 1 : COL(NBCOL) = "TCT"
Call TEXTFIC("TABCTL","TCT",2,TIT(NBCOL)) From OBJDIV
#NBCOL += 1 : COL(NBCOL) = "TCTDES"       # V6 GA 03/2009 Texte traduit CRPOP
#Call TEXTFIC("TABCTL","TCTDES",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("TABCTL","TCTDESAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:TCT]TCTTYP,262,1)"
Call TEXTFIC("TABCTL","TCTTYP",2,TIT(NBCOL)) From OBJDIV
#
# V6 GA 03/2009 Texte traduit CRPOP
Link [TCT] With [AXX]AXX0="TABCTL";"TCTDESAXX";GLANGUE;[F:TCT]TCT;""
&          As [LNK]
#
START   = "TCT"
# FQ 67955 GA 10/2010
#CRITERE = "[F:TCT]TCTTYP=WTYP&[F:TCT]TCTLIN=1"
CRITERE = "[F:TCT]TCTTYP="+num$(WTYP)+"&[F:TCT]TCTLIN=1"
ORDRE   = "TCT;TCTLIN"
SIZLIG  = 100
SIZCOL  = 160
DEFPAG  = 1  # FQ 67955 GA 10/2010 pour la pagination
Default File [LNK]        # V6 GA 03/2009 Texte traduit CRPOP

Return
############################################################
# Fenetre de selection des tables de contrôle automatique
############################################################
$S_SELTCA
If dim(S_WINAUT) > 0
  If S_WINAUT <> 2
    OK=0      # JPJ E19458
    Return
  Endif
Else
  OK=0      # JPJ E19458
  Return
Endif
Goto S_SELTCT
############################################################
# Fenetre de selection contenu des tables de contrôle
############################################################
$S_SELTCT
#  Utilisé par au moins:  CFGLIN (lignes de produit)
#                         et Questions scénario, Questions pour sélections en mode autonome
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:TCT]) = 0 : Local File TABCTL    [TCT]  : Endif
#
Local Char    WTCT(GLONTCT) : WTCT = PARAM(1)
Local Char    WQST(8)       : WQST = PARAM(2)          # JPJ E19190
Local Char    WFIL(250)     : WFIL = ""
Local Char    WALPCOD(250)
Local Decimal WNUMCOD
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_DESTCT(GLONDCT) : # Intitule code table de contrôle
Else
  Local Char  W_DESTCT(30)      : # Intitule code table de contrôle
Endif
Local Char    W_FLDTCT(GLONAVA)  # Issue 82300 (10)  : # Champ intitule table de contrôle
#
Read [TCT]TCT0=WTCT
If fstat
  Raz [F:TCT]
Endif

#TIT(0) = [F:TCT]  # V6 GA 03/2009 Texte traduit CRPOP
#FQ 58475 Call LECTEXTRA(TIT(0),"TABCTL","TCTDESAXX",[F:CQU]TCT,"") From ATEXTRA
#FG 60137
Call CFGTITTCT(TIT(0))
#
Case [F:TCT]TCTTYP
  When 2 :
    WNUMCOD  = VALEUR
    EXPSTART = "[F:TCT]NUMCOD >= WNUMCOD"
    NBCOL += 1 : COL(NBCOL) = "NUMCOD"
    Call TEXTFIC("TABCTL",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  When Default :
    WALPCOD  = VALEUR
    EXPSTART = "[F:TCT]ALPCOD >= WALPCOD"
    NBCOL += 1 : COL(NBCOL) = "ALPCOD"
    Call TEXTFIC("TABCTL",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endcase
Call CFGDESTCT(W_DESTCT,W_FLDTCT)
NBCOL += 1 : COL(NBCOL) = W_FLDTCT
Call TEXTFIC("TABCTL",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#
Raz [F:TCT]
ORDRE   = "TCT;TCTLIN"
CRITERE = "[F:TCT]TCT='"+WTCT+"'"
# Si filtre sur valeurs
# If dim(S_CFGCFG) > 0 & S_CFGCFG > 0     # JPJ E19190
#  Test si filtre sur une question,       # JPJ E20726 >
#    une question     -> contexte de type scénario ou mode autonome
#    pas de question  -> contexte ligne de produit (ecran CFGLIN CLIN)
If WQST <> ""                             # JPJ E20726 <
  Call LOA_FILTCT(WTCT,WQST, WFIL)        # JPJ E19190
  If WFIL <> ""
    CRITERE += "&("+WFIL+")"
  Endif
Endif                                     # JPJ E19190, E20726
#
SIZLIG = 100
SIZCOL = 200 : # FQ 49950 avant 120
Default File [TCT]
DEFPAG=1    # CCC (04/01/06) Bug 34078
Return

############################################################
# Fenetre de selection des questions
############################################################
$S_SELQST
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:CQU]) = 0 : Local File CFGQST    [CQU]  : Endif
#
TIT(0) = mess(10,188,1)
NBCOL += 1 : COL(NBCOL) = "[F:CQU]QSTNUM"
Call TEXTFIC("CFGQST","QSTNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("CFGQST","QSTAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:CQU]ASWTYP,252,1)"
Call TEXTFIC("CFGQST","ASWTYP",2,TIT(NBCOL)) From OBJDIV
#

Link [CQU] With [AXX]AXX0="CFGQST";"QSTAXX";GLANGUE;[F:CQU]QSTNUM;""
&          As [LNK]

START   = "QSTNUM"
# FQ 67955 GA 10/2010
#CRITERE = "[F:CQU]QSTTYP=1&[F:CQU]QSTORI=1&[F:CQU]QSTNUM>=VALEUR"
CRITERE = '[F:CQU]QSTTYP=1&[F:CQU]QSTORI=1&[F:CQU]QSTNUM>="'+num$(VALEUR)+'"'
ORDRE   = "QSTNUM"
SIZLIG  = 100
SIZCOL  = 160
DEFPAG  = 1  # FQ 67955 GA 10/2010 pour la pagination
Default File [LNK]

Return
############################################################
# Fenetre de selection des variables
############################################################
$S_SELVAR
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE    [ATX]  : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:CQU]) = 0 : Local File CFGQST    [CQU]  : Endif
#
TIT(0) = mess(11,188,1)
NBCOL += 1 : COL(NBCOL) = "[F:CQU]QSTNUM"
Call TEXTFIC("CFGQST","QSTNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("CFGQST","[F:CQU]QSTAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:CQU]QSTORI,771,1)"
Call TEXTFIC("CFGQST","[F:CQU]QSTORI",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:CQU]ASWTYP,252,1)"
Call TEXTFIC("CFGQST","ASWTYP",2,TIT(NBCOL)) From OBJDIV
#
Link [CQU] With [AXX]AXX0="CFGQST";"QSTAXX";GLANGUE;[F:CQU]QSTNUM;""
&          As [LNK]

START   = "QSTNUM"
# FQ 67955 GA 10/2010
#CRITERE = '[F:CQU]QSTTYP=2&[F:CQU]QSTNUM>=VALEUR&[F:CQU]CODNUM=""'
CRITERE = '[F:CQU]QSTTYP=2&[F:CQU]QSTNUM>="'+num$(VALEUR)+'"&[F:CQU]CODNUM=""'
ORDRE   = ""
SIZLIG  = 100
SIZCOL  = 180
DEFPAG  = 1  # FQ 67955 GA 10/2010 pour la pagination
Default File [LNK]
Return
