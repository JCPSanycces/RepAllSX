Call TEXTFIC("GACCCODE","COA",2,TIT(NBCOL)) From OBJDIV
#
If dim(S_FILTER)>0 & S_FILTER<>""
   CRITERE = S_FILTER + "& TYP=1"
Else
   CRITERE = "TYP=1"
Endif
If GCOA(1)<>""
   CRITERE += '& COA="'+GCOA(1)+'"'
Endif
ORDRE  = ""
OBJET  = "CAC"     # Gestion des rôles
SIZLIG = 100
SIZCOL = 110
DEFPAG = 1
Default File [LNK]
Return
