If dim(S_FILTER)>0 & S_FILTER<>""
   CRITERE = S_FILTER + "& LANNUM>0"
Else
   CRITERE = "LANNUM>0"
Endif
ORDRE   = ""
SIZLIG = 100
SIZCOL = 110
DEFPAG = 1
Default File [AST]
Return

############################################################
# Fenetre de selection Code comptable        # Issue 83483 #
############################################################
$S_SELCAC
If clalev([F:CAC]) = 0 : Local File GACCCODE   [CAC]  : Endif
#
Call TEXTFIC("ITMMASTER","ACCCOD",2,TIT(0)) From OBJDIV
If dim([F:TFO]FORFOR)>0 & [F:TFO]FORFOR<>""
    Local Char WDES(50)
    Call LECTEXTRA(WDES,"TABFOR","DES",num$([F:TFO]FORTYP),[F:TFO]FORCOD) From ATEXTRA
    TIT(0)=mess(1,30,1)-WDES
Endif
Link [CAC] With [AXX]AXX0="GACCCODE";"DESTRA";GLANGUE;num$([F:CAC]TYP);[F:CAC]ACCCOD
&          As [LNK]

START  = "ACCCOD"
