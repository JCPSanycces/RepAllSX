############################################################
# Action apres modification ligne de produit
Subprog CFGAMLIN(LVAL)
Variable Char LVAL
Call CFGMODLIN(LVAL)         # JPJ E23057
End

############################################################
# JPJ E23057->    Gestion du chgt de la ligne de produit sur l'ecran ITM1 (appelé par CFGAMLIN et INIT de SAICFGLIN2)
Subprog CFGMODLIN(LVAL)
Variable Char LVAL
If LVAL = "" | LVAL <> [M:ITM1]CFGLIN
  Raz GTLPBOUT      # Flag double appel entre les actions SAICFGLIN (Apres_modif) et SAICFGLIN2 (bouton)
  Raz [M:ITM1]CFGFLDNUM1, CFGFLDNUM2, CFGFLDNUM3, CFGFLDNUM4, CFGFLDNUM5, CFGFLDNUM6
  Raz [M:ITM1]CFGFLDALP1, CFGFLDALP2, CFGFLDALP3, CFGFLDALP4, CFGFLDALP5, CFGFLDALP6
  #MAE, bg 77774
  If LVAL=""
      Raz [F:ITM]CFGFLDNUM1, CFGFLDNUM2, CFGFLDNUM3, CFGFLDNUM4, CFGFLDNUM5, CFGFLDNUM6
      Raz [F:ITM]CFGFLDALP1, CFGFLDALP2, CFGFLDALP3, CFGFLDALP4, CFGFLDALP5, CFGFLDALP6
  Endif
Endif
End
# JPJ E23057 <-

############################################################
# Action avant saisie du site
Subprog CFGASFCY(LFCY)
Variable Char LFCY
If LFCY = ""
  LFCY = GFCYDEF(0)
Endif
End
############################################################
# Action avant saisie indice champs de table dimensionnes
Subprog CFGASIND(LTYP,LSYM)
Value Integer LTYP
Value Char    LSYM
#
Local Char    W_FIC(GLONATB)  # JAMCC Issue X3-89202 05/2018
Local Char    W_ABR(10)
Local Integer W_DIM
#
If LTYP < 13
  mkstat = 2
  End
Endif
Call CONV_FIC(LTYP,W_FIC,W_ABR)
mkstat = 2
W_DIM  = 0
#
Read [ATZ]CODZONE=W_FIC;LSYM
If fstat = 0
  W_DIM = [F:ATZ]DIME
  If [F:ATZ]CODACT <> ""
    If clalev([F:ACV]) = 0 : Local File ACTIV : Endif
    Read [ACV]CODACT=[F:ATZ]CODACT
    If [F:ACV]DIME <> 0
      W_DIM = [F:ACV]DIME
    Endif
  Endif
Endif
If W_DIM > 1
  mkstat = 0
Endif
End
############################################################
# ACTION Avant saisie reponse alphanumerique
Subprog CFGASALP(VALEUR,LQST)
Variable Char    VALEUR()
Value    Char    LQST
#
Local    Char    W_VAR(GLONAVA)  # Issue 82300 (10)
#
If dim([M:CFP]SAIMOD) > 0 & [M:CFP]SAIMOD = 1
  Call ACT_CORRECTION(LQST) From CFGLIBB
Endif
#
S_SELTBL = 0
GPOINT = "CFGASALP"
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE = 0
  If evalue("dim("+W_PRS+LQST+")>0")
    VALEUR = evalue(W_PRS+LQST)
    If VALEUR = ""
      W_VAR = W_PRS+LQST
      Gosub SET_DEFEVA From WUVAR
    Endif
  Endif
Endif
# Desactivation saisie assitee si appui sur 'OK'
If dim(S_WINAUT) > 0 & S_WINAUT = 2 & status = GSTAOK
  S_WINAUT = 1
Endif
End
############################################################
# ACTION Avant saisie reponse numerique
Subprog CFGASNUM(VALEUR,LQST)
Variable Decimal  VALEUR()
Value    Char     LQST
#
Local    Char     W_VAR(GLONAVA)  # Issue 82300 (10)
#
If dim([M:CFP]SAIMOD) > 0 & [M:CFP]SAIMOD = 1
  Call ACT_CORRECTION(LQST) From CFGLIBB
Endif
S_SELTBL = 0
#
GPOINT = "CFGASNUM"
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE = 0
  If evalue("dim("+W_PRS+LQST+")>0")
    VALEUR = evalue(W_PRS+LQST)
    If VALEUR = 0
      W_VAR = W_PRS+LQST
      Gosub SET_DEFEVA From WUVAR
    Endif
  Endif
Endif
# Desactivation saisie assitee si appui sur 'OK'
If dim(S_WINAUT) > 0 & S_WINAUT = 2 & status = GSTAOK
  S_WINAUT = 1
Endif
End
############################################################
# ACTION Avant saisie reponse date
Subprog CFGASDAT(VALEUR,LQST)
Variable Date    VALEUR()
Value    Char    LQST
#
Local    Char    W_VAR(GLONAVA)  # Issue 82300 (10)
#
If dim([M:CFP]SAIMOD) > 0 & [M:CFP]SAIMOD = 1
  Call ACT_CORRECTION(LQST) From CFGLIBB
Endif
#
S_SELTBL = 0
GPOINT = "CFGASDAT"
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE = 0
  Read [CQU]CQU0=LQST
  If fstat = 0
    If evalue("dim("+W_PRS+LQST+")>0")
      VALEUR = evalue(W_PRS+LQST)
      If VALEUR = [0/0/0]
        W_VAR = W_PRS+LQST
        Gosub SET_DEFEVA From WUVAR
      Endif
    Endif
  Endif
Endif
# Desactivation saisie assitee si appui sur 'OK'
If dim(S_WINAUT) > 0 & S_WINAUT = 2 & status = GSTAOK
  S_WINAUT = 1
Endif
End
