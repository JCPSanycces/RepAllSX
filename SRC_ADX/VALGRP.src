#<AdxTL>@(#)12.0.0.0 $Revision$
#*X3-39795  MDJ  Manage ORIGIN and ORICOD fields in GL Entry
###############################################################################
# Identificateurs - pas de valeurs imposées
###############################################################################
Subprog VALGRP(CODE,IDENT,STAT,TMESSA)
Value    Char    CODE            : # Code groupe de pièces autos
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    TMESSA()(1..)

Local Integer CAS : CAS = 1
Goto VALPCE

###############################################################################
# Identificateurs - avec de valeurs imposées
###############################################################################
Subprog VALGRP3(CODE,IDENT,STAT,TMESSA,ZONE,VALEUR,FLAG)
Value    Char    CODE            : # Code groupe de pièces autos
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    TMESSA()(1..)
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Value    Integer FLAG(1..)
Local Integer CAS : CAS = 1
Goto VALPCE

###############################################################################
# Critère - pas de valeurs imposées
###############################################################################
Subprog VALGRP2(CODE,CRIT,STAT,TMESSA)
Value    Char    CODE            : # Code groupe de pièces autos
Value    Char    CRIT
Variable Integer STAT
Variable Char    TMESSA()(1..)
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)

Local Integer CAS : CAS = 2
Goto VALPCE


###############################################################################
# Critère - avec valeurs imposées
###############################################################################
Subprog VALGRP4(CODE,CRIT,STAT,TMESSA,ZONE,VALEUR,FLAG)
Value    Char    CODE            : # Code groupe de pièces autos
Value    Char    CRIT
Variable Integer STAT
Variable Char    TMESSA()(1..)
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Value    Integer FLAG(1..)
Local Integer CAS : CAS = 2
Goto VALPCE


$VALPCE
Local Char    PCEAUTO(GLONGAU)
Local Integer INDPCE, NBPIECE
Local Integer I, J, SPSTAT, NOLI
Local Integer I_ORI  #*X3-39795
Local Integer ERR
Local Integer NBCLE
Local Integer MAXLIG, MAXLET
Local Char    PROG(10)
Local Char    CLE(30)(1..16)
Local Char    CRITERE(250)

If clalev([F:GAU])=0  : Local File GAUTACE    [GAU] : Endif
If clalev([F:GRA])=0  : Local File GRPAUTACE  [GRA] : Endif
If clalev([F:GRM])=0  : Local File GRPACEMTC  [GRM] : Endif
If clalev([F:MGT])=0  : Local File MTCGAUTMP  [MGT] : Endif

If clalev([M:HAE0])=0 : Local Mask GACCENT0 [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1 [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2 [HAE2] : Endif

MAXLIG = dim([M:HAE2]ACC1)-1

## Variable utilisées pour le lettrage
Local Integer LETLED : # Si LETLED=1 : lettrage en devise référentiel (flagué échéance). LETLED=0 : lettrage en devise pièce
Local Integer XACCNUM(1..MAXLIG), XDUDLIG(1..MAXLIG)
Local Integer XNBLET, LET
Local Decimal XAMTIPTLED(1..MAXLIG)
Local Decimal XAMTIPTCUR(1..MAXLIG)


## Si le code n'existe pas en tant que groupe, c'est un code pièce automatique qui peut s'exécuter.
Read [GRA]GRA0 = CODE
If fstat
 Read [GAU]GAU0 = CODE
 If !fstat
  Case CAS
   When 1 : # Identificateurs
    If dim([L]ZONE)<1
     Call VALPCE(CODE,IDENT,SPSTAT,TMESSA) From CPTAUTO
    Else
     #*X3-39795
     I_ORI = find("ORICOD",ZONE(1..10))
     If I_ORI > 0
       ZONE(I_ORI)="ORICOD"  : VALEUR(I_ORI)=CODE
     Endif
     #*X3-39795 END
     Call VALPCE3(CODE,IDENT,SPSTAT,TMESSA,ZONE,VALEUR) From CPTAUTO
    Endif
   When 2 : # Critère
    If dim([L]ZONE)<1
     Call VALPCE2(CODE,CRIT,SPSTAT,TMESSA) From CPTAUTO
    Else
     #*X3-39795
     I_ORI = find("ORICOD",ZONE(1..10))
     If I_ORI > 0
       ZONE(I_ORI)="ORICOD"  : VALEUR(I_ORI)=CODE
     Endif
     #*X3-39795 END
     Call VALPCE4(CODE,CRIT,SPSTAT,TMESSA,ZONE,VALEUR) From CPTAUTO
    Endif
  Endcase
  If SPSTAT
   TMESSA(1) = [L]CODE-":"-TMESSA
   GOK = 0 : STAT = SPSTAT
  Elsif [M:HAE2]NBLIG>0
   If len(TMESSA)<=GLONVCR
    TMESSA(1) = GTYPPCE+"~"+GNUMPCE
   Else
    TMESSA(1) = TMESSA
   Endif
  Endif
  End
 Else
  MESSA = CODE : SPSTAT = 2 : Goto FIN
 Endif
Endif

Filter [GRM] Where COD = CODE
Read [GRM]GRM0 Last
MAXLET = [F:GRM]NUMORD+1
Filter [GRM]

## Variables utilisées pour la préparation du lettrage
Local Integer TNBACCNUM(1..MAXLET), TLIG(1..MAXLET)
Local Integer TACCNUM(1..MAXLET,1..MAXLIG)
Local Integer TDUDLIG(1..MAXLET,1..MAXLIG)
Local Integer TAMTIPTLED(1..MAXLET,1..MAXLIG)
Local Integer TAMTIPTCUR(1..MAXLET,1..MAXLIG)
Local Char    TCUR(GLONCUR)(1..MAXLET,1..MAXLIG)

INDPCE = 0 : NBPIECE = 0

While [F:GRA]CODACE(INDPCE)<>""
 PCEAUTO = [F:GRA]CODACE(INDPCE)

 Read [GAU]GAU0 = PCEAUTO
 If fstat : MESSA = PCEAUTO : SPSTAT = 1 : Break : Endif
 PROG = "WMGAU"+PCEAUTO

 # Lecture table déclenchante
 Onerrgo ERREUR
 If clalev([F:TB0])>0 : Close Local File [TB0] : Endif
 Local File =[F:GAU]TBL [TB0]
 Onerrgo
 If ERR : MESSA = [F:GAU]TBL : SPSTAT = 3 : Break : Endif

 Gosub CLE From =PROG


 MESSA = "" : SPSTAT = 0
 [M:HAE2]NBLIG = 0
 Case CAS
   When 1 : # Identificateurs
   If dim([L]ZONE)<1 or (dim([L]FLAG)>0 & [L]FLAG(INDPCE+1)=1)
    Call VALGRPPCE(PCEAUTO,IDENT,SPSTAT,MESSA) From CPTAUTO
   Else
     #*X3-39795
     I_ORI = find("ORICOD",ZONE(1..10))
     If I_ORI > 0
       ZONE(I_ORI)="ORICOD"  : VALEUR(I_ORI)=[F:GRA]CODACE(INDPCE)
     Endif
     #*X3-39795 END
    Call VALGRPPCE3(PCEAUTO,IDENT,SPSTAT,MESSA,ZONE,VALEUR) From CPTAUTO
   Endif
  When 2 : # Critère
   If dim([L]ZONE)<1 or (dim([L]FLAG)>0 & [L]FLAG(INDPCE+1)=1)
    Call VALGRPPCE2(PCEAUTO,CRIT,SPSTAT,MESSA) From CPTAUTO
   Else
     #*X3-39795
     I_ORI = find("ORICOD",ZONE(1..10))
     If I_ORI > 0
       ZONE(I_ORI)="ORICOD"  : VALEUR(I_ORI)=[F:GRA]CODACE(INDPCE)
     Endif
     #*X3-39795 END
    Call VALGRPPCE4(PCEAUTO,CRIT,SPSTAT,MESSA,ZONE,VALEUR) From CPTAUTO
   Endif
 Endcase

 If SPSTAT
  TMESSA(1) = [L]PCEAUTO-":"-MESSA
  GOK = 0 : STAT = SPSTAT : Break
 Elsif [M:HAE2]NBLIG>0
  NBPIECE += 1
  ## On affecte TMESSA(1)... en attendant de gérer un tableau de messages dimensionné au nb de pièces
  ## susceptibles d'être générées par la validation d'un groupe de pièce (pour le moment, la validation
  ## d'un groupe de pièces génère tjs qu'une seule pièce sauf pour les pièces de règlements mais
  ## pour lequels on ne passe pas par là...)
  #  TMESSA(1) = MESSA

  If NBPIECE<=dim(TMESSA)
   If len(MESSA)<=GLONVCR
    TMESSA(NBPIECE) = GTYPPCE+"~"+GNUMPCE
   Else
    TMESSA(NBPIECE) = MESSA
   Endif
  Else
   SPSTAT=47 : Break
  Endif

  Gosub PREPA_LETTRAGE
  If !GOK : Break : Endif
 Endif
 INDPCE += 1
Wend

If SPSTAT | GOK<1 : Goto FIN : Endif

Gosub LETTRAGE


$FIN
If SPSTAT
 STAT = SPSTAT
 Gosub MESSAGE
 TMESSA(1) = MESSA
Endif
End


$PREPA_LETTRAGE
# Préparation lettrage interne intra-groupe et hors groupe

If [F:GRM]CODACE1 = PCEAUTO & ([F:GRM]CODACE2<>"" | [F:GRM]CODACE3<>"")
 I = find([F:GRM]LIG1,[M:HAE2]LIGPCEAUTO(0..[M:HAE2]NBLIG-1))
 If I
  # A ce niveau, si TNBACCNUM([F:GRM]NUMORD)>0, cela signifie que la ligne [F:GRM]LIG2 de la pièce [F:GRM]CODACE2
  # a été générée...
  If TNBACCNUM([F:GRM]NUMORD)>0 : TLIG([F:GRM]NUMORD) = 1 : Endif
  For NOLI = I To [M:HAE2]NBLIG-1
   If [M:HAE2]LIGPCEAUTO(NOLI-1) = [F:GRM]LIG1
    TLIG([F:GRM]NUMORD) = 1
    TNBACCNUM([F:GRM]NUMORD) += 1
    TACCNUM([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [M:HAE2]ACCNUM(NOLI-1)
    TDUDLIG([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = 1
    TAMTIPTLED([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = evalue("[M:HAE2]AMT"+num$(GTYPGEN)+"("+num$(NOLI-1)+")")
    TAMTIPTCUR([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [M:HAE2]CDT(NOLI-1)+[M:HAE2]DEB(NOLI-1)
    TCUR([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [M:HAE1]CUR
   Endif
  Next
  I += 1
 Endif
Endif

## Lettrage intra-groupe
If [F:GRM]CODACE2 = PCEAUTO
 I = find([F:GRM]LIG2,[M:HAE2]LIGPCEAUTO(0..[M:HAE2]NBLIG-1))
 If I
  # A ce niveau, si TNBACCNUM([F:GRM]NUMORD)>0, cela signifie que la ligne [F:GRM]LIG1 de la pièce [F:GRM]CODACE1
  # a été générée...
  If TNBACCNUM([F:GRM]NUMORD)>0 : TLIG([F:GRM]NUMORD) = 1 : Endif
  For NOLI = I To [M:HAE2]NBLIG-1
   If [M:HAE2]LIGPCEAUTO(NOLI-1) = [F:GRM]LIG1
    TLIG([F:GRM]NUMORD) = 1
    TNBACCNUM([F:GRM]NUMORD) += 1
    TACCNUM([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [M:HAE2]ACCNUM(NOLI-1)
    TDUDLIG([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = 1
    TAMTIPTLED([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = evalue("[M:HAE2]AMT"+num$(GTYPGEN)+"("+num$(NOLI-1)+")")
    TAMTIPTCUR([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [M:HAE2]CDT(NOLI-1)+[M:HAE2]DEB(NOLI-1)
    TCUR([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [M:HAE1]CUR
   Endif
   I += 1
  Next
 Endif
Endif

## Lettrage hors groupe
If [F:GRM]CODACE1 = PCEAUTO & [F:GRM]CODACE3<>""
 ## On va chercher les accnums à lettrer dans la table MTCGAUTMP. Cela nécessite donc que la ligne de pièce AUTO
 ## [F:GRM]CODACE3/[F:GRM]LIG3 ait été flagué 'Lettrage à postériori'
 I = find([F:GRM]LIG1,[M:HAE2]LIGPCEAUTO(0..[M:HAE2]NBLIG-1))
 If I
  Gosub IDENT_CLE
  For NOLI = I To [M:HAE2]NBLIG-1
   If [M:HAE2]LIGPCEAUTO(NOLI-1) = [F:GRM]LIG1
    Filter [MGT] Where COD = [F:GRM]CODACE3 & LINNUM = [F:GRM]LIG3 & evalue(CRITERE)
    For [MGT]MGT0
     TLIG([F:GRM]NUMORD) = 1
     TNBACCNUM([F:GRM]NUMORD) += 1
     TACCNUM([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [F:MGT]ACCNUM
     TDUDLIG([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = 1
     TAMTIPTLED([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [F:MGT]AMTLED
     TAMTIPTCUR([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [F:MGT]AMTCUR
     TCUR([F:GRM]NUMORD,TNBACCNUM([F:GRM]NUMORD)) = [F:MGT]CUR
    Next
    Delete [MGT] Where COD = [F:GRM]CODACE3 & LINNUM = [F:GRM]LIG3 & evalue(CRITERE)
    If fstat=1 | fstat>5
     GOK=0 : SPSTAT = 50 : MESSA = [F:GRM]CODACE3-num$([F:GRM]LIG3)-num$(CLEA1)-num$(CLEA2) : Break
    Endif
   Endif
   I += 1
  Next
  Filter [MGT]
  If GOK<1 : Return : Endif
 Endif
Endif
Return

$IDENT_CLE
CRITERE = ""
For X=1 To NBCLE
 If CAS=1
  If [F:GAU]GRPFLG=1 | IDENT(X)<>""
   If CRITERE<>"" : CRITERE += " & " : Endif
   Case evalue("type([F:TB0]"+CLE(X)+")")
    When 1,2,4,5,6,7,8,9
     CRITERE += 'CLEA'+num$(X)+'='+IDENT(X)
    When 3
     CRITERE += 'CLEA'+num$(X)+'=['+format$(GFMD,gdat$(IDENT(X)))+']'
    When Default
     CRITERE += 'CLEA'+num$(X)+'="'+IDENT(X)+'"'
   Endcase
  Endif
 Endif
Next I
Return

$LETTRAGE
For LET = 1 To MAXLET
 If TLIG(LET) = 1 : # Lettrage interne
  XNBLET = 0 : LETLED = 0
  # 1er passe pour voir si toutes les pièces du groupe de lettrage 'LET' sont sur la même devise...
  For I=1 To TNBACCNUM(LET)
   If I=1 : DEVISE = TCUR(LET,I) : Endif
   If I>1 & !LETLED & DEVISE<>TCUR(LET,I) : LETLED = 1 : Endif
   XNBLET += 1
   XACCNUM(XNBLET) = TACCNUM(LET,I)
   XDUDLIG(XNBLET) = TDUDLIG(LET,I)
   XAMTIPTCUR(XNBLET) = TAMTIPTCUR(LET,I)
   XAMTIPTLED(XNBLET) = TAMTIPTLED(LET,I)
  Next
  Gosub LET_DIF
 Endif
Next
Return

$LET_DIF
If XNBLET>1
 # Si =1, ça veut dire qu'il y a une ligne de pièce auto qui devait intervenir dans le
 # groupe lettrage et qui n'a pas été générée
 If LETLED
  Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPTLED,1) From CPTLET
 Else
  Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPTCUR,2) From CPTLET
 Endif
Endif
Return


$MESSAGE
Case SPSTAT
 When  1 : MESSA = MESSA-":"-mess(39,114,1)           : # Pièce automatique inexistante
 When  2 : MESSA = MESSA-":"-mess(44,114,1)           : # Groupe pièces automatiques inexistant
 When  3 : MESSA = MESSA-":"-mess(4,114,1)            : # Table déclenchante inexistante
 When 47 : MESSA = MESSA-":"-mess(126,106,1)          : # Dépassement de capacité d'affichage des pièces à générer
 When 50 : MESSA = MESSA-":"-mess(46,114,1)           : # Problème suppression pré-lettrage
Endcase
Return

$ERREUR
ERR = errn
Resume




###############################################################################
# Table de liens
###############################################################################
Subprog LNKGRP(TYP,IDENT,ACCNUM,CODE,STAT,MESSA)
Value    Char    TYP             : # Type du document associé au ML2265
Value    Char    IDENT()         : # Numéro du document
Value    Integer ACCNUM()        : # Numéro unique ACCNUM associé à l'échéance du document Amont
Value    Char    CODE()          : # Code de la pièce comptable = GTYPPCE+"~"+GNUMPCE
Variable Integer STAT            : # Statut d'erreur
Variable Char    MESSA()         : # Message d'erreur

Raz STAT, MESSA
If clalev([F:TVD])=0 : Local File TRCVCRDOC [TVD] : Endif

Local Char LNKTYP(GLONGTE),LNKNUM(GLONVCR)
If !instr(1,CODE,"~") : End : Endif
LNKTYP = left$(CODE,instr(1,CODE,"~")-1)
LNKNUM = right$(CODE,len(LNKTYP)+2)
If LNKTYP="" or LNKNUM="" : End : Endif

Raz [TVD]
[F:TVD]TYPNUM = val([L]TYP)
[F:TVD]NUM    = [L]IDENT
[F:TVD]ACCNUM = [L]ACCNUM
[F:TVD]TYPVCR = [L]LNKTYP
[F:TVD]NUMVCR = [L]LNKNUM
[F:TVD]CREUSR = GUSER
[F:TVD]CREDAT = date$
[F:TVD]UPDUSR = GUSER
[F:TVD]UPDDAT = date$

Write [TVD]
If !fstat
 MESSA = [L]LNKNUM
Else
 STAT=99 : Call FSTA("TVD") From GLOCK : End
Endif
End



###############################################################################
# Zone forcée pour certaines pièces
###############################################################################
Subprog EVALGRP(TRANSAC,ZONE,VALEUR,FLG)
Value Char TRANSAC()
Value Char ZONE()
Value Char VALEUR()
Variable Integer FLG(1..)

Local Char FORMULE(250), ABREV(GLONABR)

If !clalev([F:GAG]) : Local File GAUTACEF   [GAG] : Endif
If !clalev([F:GAU]) : Local File GAUTACE    [GAU] : Endif
If !clalev([F:GRA]) : Local File GRPAUTACE  [GRA] : Endif
If !clalev([F:ATB]) : Local File ATABLE     [ATB] : Endif

# Initialisation à 1 => X3 ne prends pas en compte les zones/valeurs forcées
For I=1 To dim(FLG)
 FLG(I)=1
Next

## Si le code n'existe pas en tant que groupe, c'est un code pièce automatique qui peut s'exécuter.
Read [GRA]GRA0 = TRANSAC
If fstat
 # Si pièce automatique, les zones/valeurs sont forcés
 FLG(1)=0
Else
 INDPCE = 0
 While [F:GRA]CODACE(INDPCE)<>""
  Read [GAU]GAU0 = [F:GRA]CODACE(INDPCE)
  If !fstat
   Read [GAG]GAG0 = [F:GRA]CODACE(INDPCE);0;ZONE
   If !fstat
    FORMULE=[F:GAG]FORCLC
    If [F:GAU]TBL<>""
     Read [ATB]CODFIC = [F:GAU]TBL
     [L]ABREV = [F:ATB]ABRFIC
     Call SUBST(FORMULE,"TB0",[L]ABREV) From SUBGAU
     FORMULE = format$("KTv2:250X",FORMULE)
    Endif
    # Formule de référence identique
    # Pour cette pièce automatique, les zones/valeurs seront forcés
    If instr(1,FORMULE,VALEUR)
     FLG(INDPCE+1) = 0
    Endif
   Endif
  Endif
  INDPCE += 1
 Wend
Endif
End

