#<AdxTL>@(#)2.0.0.0 $Revision$  Consultation SMQ
Local Char PARAM(20)(1..4)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = "ACHETE-SANS-LOT"
PARAM(4) = ""
Call GCONSULT("SMQ","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz[M:SMQ1]:Transmask [M:CSMQ] To [M:SMQ1]# Issue 25606[M:SMQ1] = [M:CSMQ]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:STO])=0 : Local File STOCK      [STO] : Endif
If clalev([F:STA1])=0 : Local File STOALL     [STA1] : Endif
#
Local Char    WFIL(250)
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSMQ"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SMQ1] = [M:CSMQ]
[M:SMQ1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:SMQ1]FLG = 0
Return
############################################################
$FERME
If clalev([F:STA1]) <> 0 : Filter [STA1] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SMQ1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          #MAE, bg 79218
          #[M:SMQ1] = [F:ITM]
          [M:SMQ1]ITMREFSTR = [F:ITM]ITMREF
          [M:SMQ1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSMQ]) <> 0 & [M:CSMQ]MEMO = "STD"       # hcb 61281
  [M:SMQ1] = [M:CSMQ]
Endif

Return
############################################################
$LECTURE
# Issue 50247 - 2017-08-31 by MAE
#If [M:SMQ1]ITMREFSTR = "" | [M:SMQ1]FCY = ""
#  NBLU = 0
#  Return
#Endif
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STA1]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STA1]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SMQ2]
    WLIG = 0
    For [STA1]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STA1]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STA1]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER
If [M:SMQ1]FLG = 0
  WFIL = "1=1"
  If [M:SMQ1]VCRTYP <> 1
    WFIL += "&[F:STA1]VCRTYP=[M:SMQ1]VCRTYP-1"
  Endif
  If [M:SMQ1]VCRNUM <> ""
    WFIL += "&pat([F:STA1]VCRNUM,[M:SMQ1]VCRNUM)"
  Endif
  [M:SMQ1]FLG = 1
  Raz [M:SMQ2]
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  # Issue X3-50247 - 2017-08-29 by MAE : artile non obligatoire
  If [M]ITMREFSTR <> ""
    WFIL +="&ITMREF >= [M:SMQ1]ITMREFSTR"
  Endif
  If [M]ITMREFEND <> ""
    WFIL +="&ITMREF <= [M:SMQ1]ITMREFEND"
  Endif

#Filter [STA1] Where STOFCY  = [M]FCY          &
#&                    ITMREF >= [M]ITMREFSTR    &
#&                    ITMREF <= [M]ITMREFEND    &
#&                    (ALLTYP = 4 | ALLTYP = 5) &
#&                    evalue(WFIL)              &
#&                    evalue(WFILS)             &
#&                    evalue(WFILSPE)
#&              Order By Key STA0
#    Raz [F:STA1]
    Filter [STA1] Where STOFCY  = [M]FCY          &
&                    (ALLTYP = 4 | ALLTYP = 5) &
&                    evalue(WFIL)              &
&                    evalue(WFILS)             &
&                    evalue(WFILSPE)
&              Order By Key STA0
Endif
# End issue 50247
Return
############################################################
$LOA_LIGNE
[M:SMQ2]ITMREF   (nolign-1)    = [F:STA1]ITMREF
[M:SMQ2]ALLTYP   (nolign-1)    = [F:STA1]ALLTYP
[M:SMQ2]VCRTYP   (nolign-1)    = [F:STA1]VCRTYP
[M:SMQ2]VCRNUM   (nolign-1)    = [F:STA1]VCRNUM
[M:SMQ2]VCRLIN   (nolign-1)    = [F:STA1]VCRLIN
[M:SMQ2]VCRSEQ   (nolign-1)    = [F:STA1]VCRSEQ
[M:SMQ2]STU      (nolign-1)    = [F:ITM]STU
[M:SMQ2]QTYSTUACT(nolign-1)    = [F:STA1]QTYSTUACT
[M:SMQ2]ALLDAT   (nolign-1)    = [F:STA1]ALLDAT
[M:SMQ2]LOC      (nolign-1)    = [F:STA1]LOC              # hcb 61967
[M:SMQ2]WRH      (nolign-1)    = [F:STA1]WRH
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SMQ1]FLG = 0
End
############################################################
Subprog AP_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:SMQ1] = [F:ITM]
End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M:SMQ1]FLG = 0
End
###########################################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,3,4,5,6,9,11,35,37)
        GMENLOC(I) = 1
    Endif
Next
#--- Dem 63001
#GMENLOC(04) = 1
End
############################################################
Subprog AM_VCRTYP(VALEUR)
Variable Integer VALEUR
[M:SMQ1]FLG = 0
End
############################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:SMQ1]FLG = 0
End

#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SMQ") From SUBGTC

End


######################################################################################
## Tunnel vers pièce (écran CONSSMQ2) 02/02/2010 15:26:03 (PLI)
######################################################################################
Subprog B2_NBLIG
Local Char NUM
Local Integer NOL : NOL = nolign-1
GCONSULT = 2
NUM = num$([M:SMQ2]VCRTYP(NOL))
Case [M:SMQ2]VCRTYP(NOL)
When 2   # commande vente
    Call OBJET("SOH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 3   # préparation
    Call OBJET("PRH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 4   # livraison
    Call OBJET("SDH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 5   # Facture vente
    Call OBJET("SIH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 6   # reception
    Call OBJET("PTH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 8   # Retour fournisseur
    Call OBJET("PNH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 9   # inventaire
    Call OBJET("SNL",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 12  # suivi matiere
    Call OBJET("SRH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 13  # retour client
    Call OBJET("SRH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 15  # declaration de production
    Call OBJET("MTK",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 18  # avoir vente
    Call OBJET("SIH",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 19  # entrée diverse
    Call OBJET("SMR",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 20  # sortie diverse
    Call OBJET("SMO",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 26  # Réintégration stock (inactif)
    Call OBJET("SCS",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 28  # controle qualite
    Call OBJET("STQ",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 29  # changement de stock
    Call OBJET("SCS",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 31  # assemblage
    Call OBJET("BBY",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 32  # desassemblage
    Call OBJET("DBY",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 33  # Demande de service
    Call OBJET("SRE",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 35  # modification des lots
    Call OBJET("SLM",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
When 36  # Ordre de sous-traitance
    Call OBJET("SCO",[M:SMQ2]VCRNUM(NOL),NUM) From GOBJET
Endcase
GCONSULT = 0
End


######################################################################################
## Rajout borne articles (écran CONSSMQ1) 02/02/2010 16:12:26 (PLI)
######################################################################################
Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End

Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR
  GMESSAGE = mess(44,199,1) # La borne fin est inférieure à la borne début
  mkstat = 2
Endif
End

Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M:SMQ1]FLG = 0
End


