## Zone AFFMUT
mkstat = 0
zoncou = "AFFMUT"
indice = 0
If varinit([M]AFFMUT,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]AFFMUT,"10329","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]AFFMUT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "AFFMUT" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]AFFMUT,"10329","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "AFFMUT" : GZNUM = 46539 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]AFFMUT,"10329",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "AFFMUT" : GZNUM = 46539 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

