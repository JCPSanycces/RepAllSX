indice = 0
IMPENT = [M]SOCSTA
If varinit([M]SOCSTA,indice)=0
 IMPENT = 1
Endif
If varmode([M]SOCSTA,indice)=0
 Call INICOMBO(11707) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SOCSTA(IMPENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,11707,1))))
 Endif
 [M]SOCSTA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SOCSTA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SOCSTA(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SOCSTA" : GZNUM = 55184 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]SOCSTA = IMPENT

