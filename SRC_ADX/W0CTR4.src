## Zone NBRDP1
mkstat = 0
zoncou = "NBRDP1"
indice = 0
status = 1
zoncou = "NBRDP1"
If varmode([M]NBRDP1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDP1" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDP1
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDP1 = nolign
   status = 75
   Call SAI_NBRDP1(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

