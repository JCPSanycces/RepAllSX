##**
##* Function :
##* #*
##*
##* Input parametres
##* @param BUICOD Building code
##*
#* @param RMSG Error message
#* @param RRET True/False
#             = 0 buiding code is not used
#             = 1 buiding code is used by  at least one localization
#* @param RLCT Room where building is used
##*#*
##*
Funprog IS_BUI_USED(PBUICOD, RLCT, RMSG)
Value    Char PBUICOD
Variable Char    RLCT
Variable Char    RMSG

Local Integer    RRET

  RLCT = AVOID.ACHAR
  RMSG = AVOID.ACHAR
  RRET = [V]CST_AFALSE
  Local File PHYLCT [LCT]

  Filter [LCT] Where BUICOD = PBUICOD
     Read [LCT] First
  Filter [LCT]
  If fstat =  [V]CST_AOK
    RRET = [V]CST_ATRUE
    RLCT = [F:LCT]LCTCOD
  Endif
End RRET

