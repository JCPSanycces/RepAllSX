#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
#  SIXPPL : Migration tarifs achats intégrale --> X3                    #
# --------------------------------------------------------------------- #
#                                                                       #
# Gosub PPL_VERIF                                                       #
#   Vérifications avant traitement                                      #
#                                                                       #
# Gosub PPL_INIT                                                        #
#   Création des paramétrages de base tarifs achats                     #
#                                                                       #
# Gosub PPL_FOU                                                         #
#   Récupération des remises fournisseur                                #
#                                                                       #
# Gosub PPL_TRFFOU                                                      #
#   Récupération des tarifs fournisseurs                                #
#                                                                       #
# func CALNBENR                                                         #
#   Calcul le nombre d'enregistrements total et restant à traiter       #
#   Appelé depuis le traitement SUBSIM avec la classe [M:SIM2] chargée  #
#                                                                       #
#########################################################################


#----- Exécution manuelle de la migration -----#
Global Integer X_NB
Local  Integer WNBTAR
#-----
Gosub SI_CONTEXT From SIXFONCTION
#-----
Local File XIFOU [XFOU] Where FLGREP>1
WNBTAR=rowcount([XFOU])
Close Local File [XFOU]
#-----
Local File XITRFFOU [XTRF]
WNBTAR+=rowcount([XTRF])
Close Local File [XTRF]
#-----
SI_SIMU=2 : # Simulation de la migration !
#----- Ouverture de la trace et de la boîte de progression -----#
Call OUVRE_TRACE("SIXPPL : Process translation file from INTEGRALE to X3") From LECFIC
Call OUVRE_BOITE(SI_MES(73),WNBTAR) From GESECRAN
#-----
If !clalev([F:SPX])  Local File =SI_DOSSIER+".SIPARX3"  [SPX] : Endif
Read [SPX] SPX0 First : If fstat  Raz [F:SPX] : Endif
#-----
Call EXEC From SIXPPL 
#----- Fermeture boîte de progression et lecture trace -----#
Call FERME_BOITE From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
#-----
Kill X_NB
End


#########################################################################
# Exécution de la migration tarifs achats appelé :                      #
#   - depuis la fonction de "Lancement migration Intégrale"             #
#   - manuellement par exécution de ce traitement                       #
#########################################################################
Subprog EXEC
#-----
Local Char    WMSG(80)
Local Integer WOK
Local Integer WNBOK, WNBERR
Local Integer WTRA          : WTRA=2 : # Trace (1=Normale, 2=Détaillée)
#----- Migration des tarifs fournisseurs -----#
Call ECR_TRACE(string$(64,"-"),0)    From GESECRAN
Call ECR_TIME("SIXPPL :"-SI_MES(73)) From DOSSUB
Call ECR_TRACE(" ",0)                From GESECRAN
#-----
Onerrgo TRT_ERR
#----- Vérifications avant traitement -----#
Gosub PPL_VERIF
#-----
If WOK  Gosub PPL_INIT   : Endif
If WOK & ([F:SPX]DISCRGACH(1)<>0 | [F:SPX]DISCRGACH(3)<>0)  Gosub PPL_FOU    : Endif
If WOK  Gosub PPL_TRFFOU : Endif
#-----
If SI_SIMU=2
  WMSG="**"-mess(25,133,1)-"**" : # ** Simulation **
Else
  WMSG=""
Endif
#-----
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TIME("SIXPPL :"-SI_MES(117)-num$(WNBOK)+"/"+num$(WNBOK+WNBERR)-WMSG) From DOSSUB
Call ECR_TRACE(string$(64,"-"),0) From GESECRAN
#-----
Onerrgo
End


############################
# Si une erreur se produit #
############################
$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Raz GOK, WOK
Resume


#############################################################
#              Vérifications avant traitement               #
# --------------------------------------------------------- #
# Prérequis :                                               #
#   - Codes activité                                        #
#       "PPR" nbre de colonnes tarif (1)                    #
#       "PPL" nbre de lignes d'une fiche (100)              #
#   - Affectation compteur fiche tarif ("PPL")              #
#   - Fichier paramètre SIPARX3 [SPX]                       #
#       Société par défaut [F:SPX]CPY                       #
#       Site    par défaut [F:SPX]FCY                       #
#       Devise  par défaut [F:SPX]CUR                       #
#       Correspondance col.struct.tar.[F:SPX]DISCRGACH(0-3) #
#   - Devise dossier par défaut GSYSCUR                     #
#   - Structure tarif achat par défaut (code structure="")  #
#       Remise 1 % (article)                                #
#       Remise 2 % (fournisseur)                            #
#       Majoration 1 % (article)                            #
#       Majoration 2 % (fournisseur)                        #
#   - Motifs tarif                                          #
#       1 = Saisie manuelle                                 #
#       2 = Remise fournisseur                              #
#       3 = Tarif article                                   #
#       4 = Tarif famille article                           #
#       5 = Tarif sous-famille article                      #
#############################################################
$PPL_VERIF
#-----
Local Char    WCODACT(GLONACV)
Local Integer WERR, WNBMAX, WNBCOL, WI, WCOL
WOK=1
Raz GMESSAGE
#----- Vérification des codes activité "PPR" et "PPL" -----#
If !clalev([F:ACV])  Local File =SI_DOSSIER+".ACTIV" [ACV] : Endif
WCODACT="PPR"
Read [ACV] CODACT=WCODACT
If fstat
  WERR=1 : Gosub PPL_VERIF_ERR : Return
Elsif [F:ACV]FLACT<>2
  WERR=2 : Gosub PPL_VERIF_ERR : Return
Elsif [F:ACV]DIME<1
  WMSG=","-mess(6,199,1)-"("+num$([F:ACV]DIME)+"<1)"
  WERR=3 : Gosub PPL_VERIF_ERR : Return
Endif
WNBCOL=[F:ACV]DIME
#-----
WCODACT="PPL"
Read [ACV] CODACT=WCODACT
If fstat
  WERR=1  : Gosub PPL_VERIF_ERR : Return
Elsif [F:ACV]FLACT<>2
  WERR=2  : Gosub PPL_VERIF_ERR : Return
Elsif [F:ACV]DIME<100
  WMSG=","-mess(6,199,1)-"("+num$([F:ACV]DIME)+"<100)"
  WERR=3  : Gosub PPL_VERIF_ERR : Return
Endif
#----- Laisser 20% de lignes libres sur chaque fiche tarif -----#
WNBMAX=int([F:ACV]DIME*80/100)
#----- Vérification compteur fiche tarif achat -----#
If !clalev([F:TCA])   Local File =SI_DOSSIER+".TABCOUAFF"  [TCA]  : Endif
Read [TCA] TCA0=6
If fstat  Raz [F:TCA] : Endif
If [F:TCA]CODNUM(11)=""
  WERR=4  : Gosub PPL_VERIF_ERR : Return
Else
  GCODNUM=[F:TCA]CODNUM(11)
Endif
#----- Vérification société, site et devise issus du paramétrage -----#
If !clalev([F:CPY])   Local File =SI_DOSSIER+".COMPANY"   [CPY]  : Endif
If !clalev([F:FCY])   Local File =SI_DOSSIER+".FACILITY"  [FCY]  : Endif
If !clalev([F:TCU])   Local File =SI_DOSSIER+".TABCUR"    [TCU]  : Endif
#-----
If [F:SPX]CPY=""
  WERR=5  : Gosub PPL_VERIF_ERR : Return
Endif
Look [CPY] CPY0=[F:SPX]CPY
If fstat
  WERR=5  : Gosub PPL_VERIF_ERR : Return
Endif
#-----
If [F:SPX]FCY=""
  WERR=6  : Gosub PPL_VERIF_ERR : Return
Endif
Read [FCY] FCY0=[F:SPX]FCY
If fstat
  WERR=6  : Gosub PPL_VERIF_ERR : Return
Elsif [F:FCY]PURFLG<>2
  WERR=7  : Gosub PPL_VERIF_ERR : Return
Endif
#-----
If [F:SPX]CUR=""
  WERR=8  : Gosub PPL_VERIF_ERR : Return
Endif
Look [TCU] TCU0=[F:SPX]CUR
If fstat
  WERR=8  : Gosub PPL_VERIF_ERR : Return
Endif
#----- Vérification devise dossier -----#
If dim(GSYSCUR)<1 | GSYSCUR=""
  WERR=9  : Gosub PPL_VERIF_ERR : Return
Endif
#----- Vérification structure tarif (code tarif = "") -----#
If !clalev([F:PRS])   Local File =SI_DOSSIER+".PRICSTRUCT" [PRS]  : Endif
Read [PRS] PRS0=2;""
If fstat
  WERR=10 : Gosub PPL_VERIF_ERR : Return
Endif
#----- Vérification correspondance colonnes structure tarif achat -----#
For WI=0 To 3
  WCOL=[F:SPX]DISCRGACH(WI)
  If WCOL<0 | WCOL>WNBCOL
    WERR=12 : Gosub PPL_VERIF_ERR : Break
  Endif
  If WCOL<>0
    If !find([F:PRS]VALTYP(WCOL-1),2,3) | [F:PRS]CLCRUL(WCOL-1)<>1 | [F:PRS]NPRNOTFLG(WCOL-1)<>2
      WERR=12 : Gosub PPL_VERIF_ERR : Break
    Endif
    Case WI+1
      When 1,2 : If [F:PRS]INCDCR(WCOL-1)<>2  WERR=12 : Gosub PPL_VERIF_ERR : Break : Endif
      When 3,4 : If [F:PRS]INCDCR(WCOL-1)<>1  WERR=12 : Gosub PPL_VERIF_ERR : Break : Endif
    Endcase
  Endif
Next WI
If !WOK  Return : Endif
#----- Vérification motifs tarifs fournisseurs -----#
If !clalev([F:PPR])   Local File =SI_DOSSIER+".PPREASON"   [PPR]  : Endif
For WI=1 To 5
  Read [PPR] PPR0=WI
  If fstat
    WMSG="("+num$(WI)+"="+SI_MES(80+WI)+")"
    WERR=11 : Gosub PPL_VERIF_ERR
  Endif
Next WI
If !WOK  Return : Endif
#-----
Return


#---------------------------------------#
# Erreurs détectées par la vérification #
#---------------------------------------#
$PPL_VERIF_ERR
Case WERR
  When  1 : GMESSAGE=WCODACT-mess(8,176,1)              : # Code activité inexistant
  When  2 : GMESSAGE=WCODACT-mess(24,176,1)             : # Code activité inactif
  When  3 : GMESSAGE=WCODACT-mess(14,115,1)-WMSG        : # Code activité, valeur incorrecte
  When  4 : GMESSAGE=mess(12,535,1)+","-mess(12,114,1)  : # Fiche tarif, Compteur inexistant
  When  5 : GMESSAGE='"'+[F:SPX]CPY+'"'-mess(16,104,1)  : # "xxx" Société inexistante
  When  6 : GMESSAGE='"'+[F:SPX]FCY+'"'-mess(15,104,1)  : # "xxx" Site inexistant
  When  7 : GMESSAGE='"'+[F:SPX]FCY+'"'-mess(145,194,1) : # "xxx" Le site n'EST pas un site d'achat
  When  8 : GMESSAGE='"'+[F:SPX]CUR+'"'-mess(151,105,1) : # "xxx" Devise inexistante
  When  9 : GMESSAGE="GSYSCUR"-mess(12,116,1)           : # GSYSCUR Devise inexistante
  When 10 : GMESSAGE=SI_MES(79)                         : # Structure tarifs fournisseurs inexistante ou erronée
  When 11 : GMESSAGE=SI_MES(80)-WMSG                    : # Motif tarif inexistant
  When 12 : GMESSAGE=SI_MES(208)                        : # Correspondance structure tarifs achats erronée
Endcase
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
WOK=0
Return


###########################################################
#        Création paramétrage de base tarifs achats       #
# ------------------------------------------------------- #
# Création du paramétrage :                               #
#   - Code tarif "FOU" avec un critère                    #
#       BPSNUM Numéro fournisseur                         #
#   - Code tarif "ART" avec deux critères                 #
#       BPSNUM Numéro fournisseur                         #
#       ITMREF Référence article                          #
#   - Code tarif "FAM" avec deux critères                 #
#       BPSNUM Numéro fournisseur                         #
#       TSICOD(0) Famille article                         #
#   - Code tarif "SFAM" avec trois critères               #
#       BPSNUM Numéro fournisseur                         #
#       TSICOD(0) Famille article                         #
#       TSICOD(1) Sous-famille article                    #
# Validation des écrans et traitements gestion des tarifs #
###########################################################
$PPL_INIT
#----- Pas de création du paramétrage de base dans le cas de la simulation -----#
If SI_SIMU=2  Return : Endif
#-----
If !clalev([F:PPC])   Local File =SI_DOSSIER+".PPRICCONF"  [PPC]  : Endif
If !clalev([F:AXX])   Local File =SI_DOSSIER+".ATEXTRA"    [AXX]  : Endif
#-----
Call DEBTRANS From GLOCK
#-----
$TR_PPL_INIT
GOK=1
Trbegin [PPC]
#-----
If [F:SPX]DISCRGACH(1)<>0 | [F:SPX]DISCRGACH(3)<>0
  Gosub PPL_INIT_FOU : # Code tarif "FOU" Taux remise ou majoration fournisseur
  If WOK=0  Goto FIN_PPL_INIT : Endif
Endif
#-----
Gosub PPL_INIT_ART   : # Code tarif "ART" Tarif article par fournisseur
If WOK=0  Goto FIN_PPL_INIT : Endif
#-----
Gosub PPL_INIT_FAM   : # Code tarif "FAM" Tarif famille article par fournisseur
If WOK=0  Goto FIN_PPL_INIT : Endif
#-----
Gosub PPL_INIT_SFAM  : # Code tarif "SFAM" Tarif sous-famille article par fournisseur
If WOK=0  Goto FIN_PPL_INIT : Endif
#-----
$FIN_PPL_INIT
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#----- Validation des écrans et traitements gestion des tarifs -----#
If SI_SIMU<>2  Call GENDOS(SI_DOSSIER) From FUNPPCVAL : Endif
#-----
Return


#--------------------------------------------------------#
# Code tarif "FOU" Taux remise ou majoration fournisseur #
#--------------------------------------------------------#
$PPL_INIT_FOU
Delete [PPC] Where PLI="FOU"
If fstat
  GOK=0 : WOK=0
  WMSG=mess(12,100,1)-"PPRICCONF FOU, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Return
Endif
#-----
Raz [F:PPC]
[F:PPC]PLI         ="FOU"
Call MAJTEXTRA (SI_MES(82),"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
If dim([F:PPC]LANDESSHO)>0
  [F:PPC]LANDESSHO=GLANGUE+"~"+SI_MES(82)
Endif
[F:PPC]PIO         =50
[F:PPC]PLIENAFLG   =2
[F:PPC]PLIBPRCNR   =1
[F:PPC]PLITYP      =1
[F:PPC]PRIREN      =2
[F:PPC]PRIPRO      =1
[F:PPC]PRITYP      =1
[F:PPC]ATICNVFLG   =2
[F:PPC]PRIQTYFLG   =1
[F:PPC]UOMCNVFLG   =2
[F:PPC]CURCNVFLG   =1
[F:PPC]FOCPRO      =1
[F:PPC]COMPRO      =2
For WI=0 To min(WNBCOL-1,8) : [F:PPC]DISCRGPRO(WI)=2 : Next WI
If [F:SPX]DISCRGACH(1)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(1)-1)=1
Endif
If [F:SPX]DISCRGACH(3)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(3)-1)=1
Endif
[F:PPC]ABB(0)      ="BPS"
[F:PPC]FIL(0)      ="BPSUPPLIER"
[F:PPC]FLD(0)      ="BPSNUM"
[F:PPC]FLDTYP(0)   ="BPS"
[F:PPC]CRILEN(0)   =GLONBPS
Call CHARCRIDES("BPSUPPLIER","BPSNUM",[F:PPC]CRIDES(0)) From TRTPARAM
[F:PPC]LIEN(0)     =1
[F:PPC]CRIBPSNUM   =1
[F:PPC]CRIBPR      =1
[F:PPC]CREDAT      =date$
[F:PPC]CREUSR      =GUSER
SI_TABLE="PPRICCONF" : Gosub SI_BEFWRI From SIXFONCTION
Write [PPC]
If fstat
  GOK=0 : WOK=0
  WMSG=mess(13,100,1)-"PPRICCONF FOU,"-func SIXFONCTION.FSTATMSG(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Return
Elsif WTRA>1
  WMSG=SI_MES(86)+'"FOU"'
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Return


#------------------------------------------------#
# Code tarif "ART" Tarif article par fournisseur #
#------------------------------------------------#
$PPL_INIT_ART
Delete [PPC] Where PLI="ART"
If fstat
  GOK=0 : WOK=0
  WMSG=mess(12,100,1)-"PPRICCONF ART, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Return
Endif
#-----
Raz [F:PPC]
[F:PPC]PLI         ="ART"
Call MAJTEXTRA (SI_MES(83),"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
If dim([F:PPC]LANDESSHO)>0
  [F:PPC]LANDESSHO=GLANGUE+"~"+SI_MES(83)
Endif
[F:PPC]PIO         =50
[F:PPC]PLIENAFLG   =2
[F:PPC]PLIBPRCNR   =1
[F:PPC]PLITYP      =1
[F:PPC]PRIREN      =3
[F:PPC]PRIPRO      =2
[F:PPC]PRITYP      =1
[F:PPC]ATICNVFLG   =2
[F:PPC]PRIQTYFLG   =2
[F:PPC]UOMCNVFLG   =2
[F:PPC]CURCNVFLG   =2
[F:PPC]FOCPRO      =1
[F:PPC]COMPRO      =2
For WI=0 To min(WNBCOL-1,8) : [F:PPC]DISCRGPRO(WI)=2 : Next WI
If [F:SPX]DISCRGACH(0)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(0)-1)=1
Endif
If [F:SPX]DISCRGACH(2)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(2)-1)=1
Endif
[F:PPC]ABB(0)      ="BPS"
[F:PPC]ABB(1)      ="ITM"
[F:PPC]FIL(0)      ="BPSUPPLIER"
[F:PPC]FIL(1)      ="ITMMASTER"
[F:PPC]FLD(0)      ="BPSNUM"
[F:PPC]FLD(1)      ="ITMREF"
[F:PPC]FLDTYP(0)   ="BPS"
[F:PPC]FLDTYP(1)   ="ITM"
[F:PPC]CRILEN(0)   =GLONBPS
[F:PPC]CRILEN(1)   =GLONITM
Call CHARCRIDES("BPSUPPLIER","BPSNUM",[F:PPC]CRIDES(0)) From TRTPARAM
Call CHARCRIDES("ITMMASTER" ,"ITMREF",[F:PPC]CRIDES(1)) From TRTPARAM
[F:PPC]LIEN(0)     =1
[F:PPC]LIEN(1)     =1
[F:PPC]CRIITMNUM   =2
[F:PPC]CRIBPSNUM   =1
[F:PPC]CRIITM      =2
[F:PPC]CRIBPR      =1
[F:PPC]CREDAT      =date$
[F:PPC]CREUSR      =GUSER
SI_TABLE="PPRICCONF" : Gosub SI_BEFWRI From SIXFONCTION
Write [PPC]
If fstat
  GOK=0 : WOK=0
  WMSG=mess(13,100,1)-"PPRICCONF ART,"-func SIXFONCTION.FSTATMSG(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Return
Elsif WTRA>1
  WMSG=SI_MES(86)+'"ART"'
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Return


#--------------------------------------------------------#
# Code tarif "FAM" Tarif famille article par fournisseur #
#--------------------------------------------------------#
$PPL_INIT_FAM
Delete [PPC] Where PLI="FAM"
If fstat
  GOK=0 : WOK=0
  WMSG=mess(12,100,1)-"PPRICCONF FAM, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Return
Endif
#-----
Raz [F:PPC]
[F:PPC]PLI         ="FAM"
Call MAJTEXTRA (SI_MES(84),"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
If dim([F:PPC]LANDESSHO)>0
  [F:PPC]LANDESSHO=GLANGUE+"~"+SI_MES(84)
Endif
[F:PPC]PIO         =50
[F:PPC]PLIENAFLG   =2
[F:PPC]PLIBPRCNR   =1
[F:PPC]PLITYP      =1
[F:PPC]PRIREN      =4
[F:PPC]PRIPRO      =2
[F:PPC]PRITYP      =1
[F:PPC]ATICNVFLG   =2
[F:PPC]PRIQTYFLG   =2
[F:PPC]UOMCNVFLG   =2
[F:PPC]CURCNVFLG   =2
[F:PPC]FOCPRO      =1
[F:PPC]COMPRO      =2
For WI=0 To min(WNBCOL-1,8) : [F:PPC]DISCRGPRO(WI)=2 : Next WI
If [F:SPX]DISCRGACH(0)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(0)-1)=1
Endif
If [F:SPX]DISCRGACH(2)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(2)-1)=1
Endif
[F:PPC]ABB(0)      ="BPS"
[F:PPC]ABB(1)      ="ITM"
[F:PPC]FIL(0)      ="BPSUPPLIER"
[F:PPC]FIL(1)      ="ITMMASTER"
[F:PPC]FLD(0)      ="BPSNUM"
[F:PPC]FLD(1)      ="TSICOD"
[F:PPC]FLDTYP(0)   ="BPS"
[F:PPC]FLDTYP(1)   ="ADI"
[F:PPC]FLDTYPCPL(1)="20"
[F:PPC]CRILEN(0)   =GLONBPS
[F:PPC]CRILEN(1)   =GLONSTI
Call CHARCRIDES("BPSUPPLIER","BPSNUM",[F:PPC]CRIDES(0)) From TRTPARAM
Call CHARCRIDES("ITMMASTER" ,"TSICOD",[F:PPC]CRIDES(1)) From TRTPARAM
[F:PPC]LIEN(0)     =1
[F:PPC]LIEN(1)     =1
[F:PPC]CRIBPSNUM   =1
[F:PPC]CRIITM      =2
[F:PPC]CRIBPR      =1
[F:PPC]CREDAT      =date$
[F:PPC]CREUSR      =GUSER
SI_TABLE="PPRICCONF" : Gosub SI_BEFWRI From SIXFONCTION
Write [PPC]
If fstat
  GOK=0 : WOK=0
  WMSG=mess(13,100,1)-"PPRICCONF FAM,"-func SIXFONCTION.FSTATMSG(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Return
Elsif WTRA>1
  WMSG=SI_MES(86)+'"FAM"'
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Return


#--------------------------------------------------------------#
# Code tarif "SFAM" Tarif sous-famille article par fournisseur #
#--------------------------------------------------------------#
$PPL_INIT_SFAM
Delete [PPC] Where PLI="SFAM"
If fstat
  GOK=0 : WOK=0
  WMSG=mess(12,100,1)-"PPRICCONF SFAM, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Return
Endif
#-----
Raz [F:PPC]
[F:PPC]PLI         ="SFAM"
Call MAJTEXTRA (SI_MES(85),"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
If dim([F:PPC]LANDESSHO)>0
  [F:PPC]LANDESSHO=GLANGUE+"~"+SI_MES(85)
Endif
[F:PPC]PIO         =50
[F:PPC]PLIENAFLG   =2
[F:PPC]PLIBPRCNR   =1
[F:PPC]PLITYP      =1
[F:PPC]PRIREN      =5
[F:PPC]PRIPRO      =2
[F:PPC]PRITYP      =1
[F:PPC]ATICNVFLG   =2
[F:PPC]PRIQTYFLG   =2
[F:PPC]UOMCNVFLG   =2
[F:PPC]CURCNVFLG   =2
[F:PPC]FOCPRO      =1
[F:PPC]COMPRO      =2
For WI=0 To min(WNBCOL-1,8) : [F:PPC]DISCRGPRO(WI)=2 : Next WI
If [F:SPX]DISCRGACH(0)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(0)-1)=1
Endif
If [F:SPX]DISCRGACH(2)<>0
  [F:PPC]DISCRGPRO([F:SPX]DISCRGACH(2)-1)=1
Endif
[F:PPC]ABB(0)      ="BPS"
[F:PPC]ABB(1)      ="ITM"
[F:PPC]ABB(2)      ="ITM"
[F:PPC]FIL(0)      ="BPSUPPLIER"
[F:PPC]FIL(1)      ="ITMMASTER"
[F:PPC]FIL(2)      ="ITMMASTER"
[F:PPC]FLD(0)      ="BPSNUM"
[F:PPC]FLD(1)      ="TSICOD"
[F:PPC]FLD(2)      ="TSICOD"
[F:PPC]FLDTYP(0)   ="BPS"
[F:PPC]FLDTYP(1)   ="ADI"
[F:PPC]FLDTYP(2)   ="ADI"
[F:PPC]FLDTYPCPL(1)="20"
[F:PPC]FLDTYPCPL(2)="21"
[F:PPC]CRILEN(0)   =GLONBPS
[F:PPC]CRILEN(1)   =GLONSTI
[F:PPC]CRILEN(2)   =GLONSTI
[F:PPC]CRIIND(2)   =1
Call CHARCRIDES("BPSUPPLIER","BPSNUM",[F:PPC]CRIDES(0)) From TRTPARAM
Call CHARCRIDES("ITMMASTER" ,"TSICOD",[F:PPC]CRIDES(1)) From TRTPARAM
Call CHARCRIDES("ITMMASTER" ,"TSICOD",[F:PPC]CRIDES(2)) From TRTPARAM
[F:PPC]LIEN(0)     =1
[F:PPC]LIEN(1)     =1
[F:PPC]LIEN(2)     =1
[F:PPC]CRIBPSNUM   =1
[F:PPC]CRIITM      =2
[F:PPC]CRIBPR      =1
[F:PPC]CREDAT      =date$
[F:PPC]CREUSR      =GUSER
SI_TABLE="PPRICCONF" : Gosub SI_BEFWRI From SIXFONCTION
Write [PPC]
If fstat
  GOK=0 : WOK=0
  WMSG=mess(13,100,1)-"PPRICCONF SFAM,"-func SIXFONCTION.FSTATMSG(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  Goto FIN_PPL_INIT
Elsif WTRA>1
  WMSG=SI_MES(86)+'"SFAM"'
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Return


#######################################################
# Création des fiches tarif FOU "Remise fournisseur"  #
# --------------------------------------------------- #
# Les trois variables suivantes pourraient être       #
#    alimentées par la lecture d'un enregistrement    #
#    paramètres si le choix client devait s'avérer    #
#    nécessaire.                                      #
#                                                     #
# WRGR1    Regroupement sur une même fiche tarif      #
#       0 = Pas de regroupement                       #
#           (un fournisseur = une fiche d'une ligne)  #
#       1 = Regroupement par 1ère lettre du no fourn. #
#           (une fiche pour A, pour B ...etc)         #
#       2 = Regroupement total                        #
#           (Tous les fournisseurs en remplissant     #
#            fiche par fiche)                         #
# WDATDEB1 Date début de validité                     #
# WDATFIN1 Date fin de validité                       #
#######################################################
$PPL_FOU
#-----
Local Libelle WRGR1    : WRGR1=0 : # Regroupement (0=Pas de regroupement)
Local Date    WDATDEB1 : WDATDEB1=gdat$(1,1,year([F:SPX]STRPER))
Local Date    WDATFIN1 : WDATFIN1=gdat$(31,12,year(date$)+10)
#-----
Local Integer WNBPPF
Local Integer WNBPPL
Local Integer WNBLIG
Local Char    WCODFOU (13)
Local Char    WBPSNUM(GLONBPS)
Local Char    WPLICRD(GLONVCR)
#----- Ouverture des tables "X3" -----#
If !clalev([F:PPF])   Local File =SI_DOSSIER+".PPRICFICH"  [PPF]  : Endif
If !clalev([F:PPL])   Local File =SI_DOSSIER+".PPRICLIST"  [PPL]  : Endif
If !clalev([F:AVN])   Local File =SI_DOSSIER+".AVALNUM"    [AVN]  : Endif
If !clalev([F:ANM])   Local File =SI_DOSSIER+".ACODNUM"    [ANM]  : Endif
#----- Ouverture de la table "Intégrale Fournisseurs" -----#
If !clalev([F:XFOU])  Local File =SI_DOSSIER+".XIFOU"      [XFOU] : Endif
#-----
Call DEBTRANS From GLOCK
#----- Effacement des fiches tarifs "FOU" -----#
GOK=1
Trbegin [PPF]
Delete [PPF] Where PLI="FOU"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICFICH FOU, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#----- Effacement des lignes tarifs "FOU" -----#
GOK=1
Trbegin [PPL]
Delete [PPL] Where PLI="FOU"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICLIST FOU, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#-----
SI_SUBPRG="SIXPPL"
SI_TABLE="XIFOU"
Gosub SI_CRITSUP From SIXFONCTION
#-----
Call DEBTRANS From GLOCK
#-----
$TRT_PPL_FOU
Raz [F:PPF], [F:PPL], WNBPPF, WNBPPL, WBPSNUM, WPLICRD
Filter [XFOU] Where evalue(SI_CRITERE) & X3CLE<>"" & FLGREP>1  Order By X3CLE
For [XFOU]
  WCODFOU=[F:XFOU]CODFOU
  #----- Ne générer le tarif que si le taux de remise est différent de 0 -----#
  If ([F:SPX]DISCRGACH(1)<>0 & [F:XFOU]PRCREM>0) | ([F:SPX]DISCRGACH(3)<>0 & [F:XFOU]PRCREM<0)
    #----- Test rupture fiche -----#
    If WBPSNUM<>"" & (WNBLIG>=WNBMAX | WRGR1=0 | (WRGR1=1 & left$(WBPSNUM,1)<>left$([F:XFOU]X3CLE,1)))
      Gosub FIN_PPF_FOU
    Endif
    #----- Test nouvelle fiche tarif -----#
    If WBPSNUM=""  Gosub DEB_PPF_FOU : Endif
    #----- Chargement et écriture ligne tarif -----#
    Raz [F:PPL]
    [F:PPL]=[F:PPF]
    [F:PPL]PLILIN =WNBLIG+1
    [F:PPL]PLICRI =WBPSNUM+"~~~~~"
    [F:PPL]PLICRI1=WBPSNUM
    If [F:XFOU]PRCREM<0
      [F:PPL]DCGVAL([F:SPX]DISCRGACH(3)-1)=[F:XFOU]PRCREM : # Taux Majoration fournisseur
    Else
      [F:PPL]DCGVAL([F:SPX]DISCRGACH(1)-1)=[F:XFOU]PRCREM : # Taux Remise fournisseur
    Endif
    SI_TABLE="PPRICLIST" : Gosub SI_BEFWRI From SIXFONCTION
    Write [PPL]
    If fstat
      GOK=0
      WMSG=mess(13,100,1)-"PPRICLIST FOU"-[F:PPL]PLICRD-num$([F:PPL]PLILIN)+","-func SIXFONCTION.FSTATMSG(fstat)
      Call ECR_TRACE(WMSG,1) From GESECRAN
      WNBERR+=1
    Else
      WNBLIG+=1
    Endif
  Else
    WNBOK+=1 : # Si le taux est à zéro, on considère que le tarif est repris !
  Endif
  #----- Mise à jour indicateur de reprise sur fournisseur "Intégrale" -----#
  If WBPSNUM=""  Trbegin [XFOU] : Endif
  Update [XFOU] Where CODFOU=WCODFOU With FLGREP=3
  If fstat
    WMSG=mess(13,100,1)-"XIFOU"-WCODFOU+", fstat="+num$(fstat)
    Call ECR_TRACE(WMSG,1) From GESECRAN
    If WBPSNUM=""  Rollback : Endif
  Else
    If WBPSNUM=""
      If SI_SIMU<>2  Commit  Else  Rollback : Endif
    Endif
  Endif
  #-----
  Call AFFBOITE([F:XFOU]CODFOU) From SUBSIM
  #-----
Next
If WBPSNUM<>""  Gosub FIN_PPF_FOU : Endif
Filter [XFOU]
#----- Impression fiches créées si trace détaillées -----#
If WNBPPF>0 & WTRA>1
  #----- Création du tarif FOU (PPF=#####, PPL=#####) -----#
  WMSG=mess(89,194,1)-"FOU (PPF="+num$(WNBPPF)+",PPL="+num$(WNBPPL)+")"
  Call ECR_TRACE(WMSG,0) From GESECRAN
  #----- ##### fiche(s) créée(s) : xxxxxxxxxxxxxxx <--> xxxxxxxxxxxxxxx ----#
  WMSG=num$(WNBPPF)-SI_MES(87)
  If SI_SIMU=2
    WMSG-=": **"-mess(25,133,1)-"**"
  Else
    WMSG-=":"-WPLICRD-"<-->"-[F:PPF]PLICRD
  Endif
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#-----
Return


#----------------------------------------#
# Début d'une nouvelle fiche tarif "FOU" #
#----------------------------------------#
$DEB_PPF_FOU
#-----
GOK=1
Trbegin [PPF], [PPL], [XFOU]
#----- Chargement buffer fiche tarif -----#
Raz [F:PPF]
[F:PPF]PLI      ="FOU"
[F:PPF]PLISTRDAT=WDATDEB1
[F:PPF]PLIENDDAT=WDATFIN1
[F:PPF]CREUSR   =GUSER
[F:PPF]CREDAT   =date$
If WRGR1=0
  [F:PPF]PLICRDIDX=[F:XFOU]X3CLE
Else
  [F:PPF]PLICRDIDX="FOU"
Endif
#----- Récupération du numéro de fiche à créer -----#
Gosub NUM_PLICRD
#-----
WBPSNUM=[F:XFOU]X3CLE
Raz WNBLIG
Return


#---------------------------------#
# Fin de la fiche tarif, création #
#---------------------------------#
$FIN_PPF_FOU
#-----
If GOK=1
  [F:PPF]LINNBR=WNBLIG
  SI_TABLE="PPRICFICH" : Gosub SI_BEFWRI From SIXFONCTION
  Write [PPF]
  If fstat
    GOK=0
    WMSG=mess(13,100,1)-"PPRICFICH FOU"-[F:PPF]PLICRD+","-func SIXFONCTION.FSTATMSG(fstat)
    Call ECR_TRACE(WMSG,1) From GESECRAN
    WNBERR+=WNBLIG
  Else
    WNBPPF+=1 : WNBPPL+=WNBLIG : WNBOK+=WNBLIG
    If WPLICRD=""  WPLICRD=[F:PPF]PLICRD : Endif
  Endif
Else
  WNBERR+=WNBLIG
Endif
#-----
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#-----
Raz WBPSNUM
#-----
Return


######################################################
# Création des fiches tarif :                        #
#   - ART  "Tarif article"                           #
#   - FAM  "Tarif famille article"                   #
#   - SFAM "Tarif sous-famille article"              #
# -------------------------------------------------- #
# Les deux variables suivantes pourraient être       #
#    alimentées par la lecture d'un enregistrement   #
#    paramètres si le choix client devait s'avérer   #
#    nécessaire.                                     #
#                                                    #
# WDATDEB2 Date début de validité                    #
# WDATFIN2 Date fin de validité                      #
######################################################
$PPL_TRFFOU
#-----
Local Date    WDATDEB2 : WDATDEB2=gdat$(1,1,year([F:SPX]STRPER))
Local Date    WDATFIN2 : WDATFIN2=gdat$(31,12,year(date$)+10)
#-----
Local Integer WNBPPF
Local Integer WNBPPL
Local Integer WNBLIG
Local Char    WCODFOU (13)
Local Char    WBPSNUM (GLONBPS)
Local Char    WCODART (16)
Local Char    WITMREF (GLONITM)
Local Char    WFAM    (2)
Local Char    WTSICOD1(GLONSTI)
Local Char    WSFAM   (2)
Local Char    WTSICOD2(GLONSTI)
Local Char    WPLI    (GLONPLI)
Local Char    WPLICRD (GLONVCR)
Local Char    WCODTRF (2)  
Local Char    WCODDVS (2)
Local Decimal WQTEMIN
Local Decimal WQTEMAX
Local Char    WTEST_CODFOU(13)
Local Char    WTEST_BPSNUM(GLONBPS)
#----- Ouverture des tables "X3" -----#
If !clalev([F:PPF])   Local File =SI_DOSSIER+".PPRICFICH"  [PPF]  : Endif
If !clalev([F:PPL])   Local File =SI_DOSSIER+".PPRICLIST"  [PPL]  : Endif
If !clalev([F:AVN])   Local File =SI_DOSSIER+".AVALNUM"    [AVN]  : Endif
If !clalev([F:ANM])   Local File =SI_DOSSIER+".ACODNUM"    [ANM]  : Endif
If !clalev([F:BPS])   Local File =SI_DOSSIER+".BPSUPPLIER" [BPS]  : Endif
If !clalev([F:ITM])   Local File =SI_DOSSIER+".ITMMASTER"  [ITM]  : Endif
If !clalev([F:TUN])   Local File =SI_DOSSIER+".TABUNIT"    [TUN]  : Endif
If !clalev([F:TCU])   Local File =SI_DOSSIER+".TABCUR"     [TCU]  : Endif
#----- Ouverture des tables "Intégrale Tarif fournisseurs et articles" -----#
If !clalev([F:XTRF])  Local File =SI_DOSSIER+".XITRFFOU"   [XTRF] : Endif
If !clalev([F:XART])  Local File =SI_DOSSIER+".XIART"      [XART] : Endif
#-----
Call DEBTRANS From GLOCK
#----- Effacement des fiches tarifs "ART" -----#
GOK=1
Trbegin [PPF]
Delete [PPF] Where PLI="ART"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICFICH ART, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#----- Effacement des lignes tarifs "ART" -----#
GOK=1
Trbegin [PPL]
Delete [PPL] Where PLI="ART"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICLIST ART, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#----- Effacement des fiches tarifs "FAM" -----#
GOK=1
Trbegin [PPF]
Delete [PPF] Where PLI="FAM"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICFICH FAM, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#----- Effacement des lignes tarifs "FAM" -----#
GOK=1
Trbegin [PPL]
Delete [PPL] Where PLI="FAM"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICLIST FAM, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#----- Effacement des fiches tarifs "SFAM" -----#
GOK=1
Trbegin [PPF]
Delete [PPF] Where PLI="SFAM"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICFICH SFAM, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#----- Effacement des lignes tarifs "SFAM" -----#
GOK=1
Trbegin [PPL]
Delete [PPL] Where PLI="SFAM"
If fstat
  GOK=0
  WMSG=mess(12,100,1)-"PPRICLIST SFAM, fstat="+num$(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
Endif
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#-----
SI_SUBPRG="SIXPPL"
SI_TABLE="XITRFFOU"
Gosub SI_CRITSUP From SIXFONCTION
#-----
Call DEBTRANS From GLOCK
#-----
$TRT_PPL_TRFFOU
#----------------------------------#
# Boucle pour création tarif "ART" #
#----------------------------------#
Raz [F:PPF], [F:PPL], WNBPPF, WNBPPL, WCODFOU, WBPSNUM, WPLICRD, WTEST_CODFOU, WTEST_BPSNUM
WPLI="ART"
For [XTRF] IND0 Where evalue(SI_CRITERE) & CODART<>""
  Gosub LIG_PPL_TRFFOU
Next
If WBPSNUM<>""
  Raz [F:XTRF]
  Gosub ECR_PPL_TRFFOU        
  Gosub FIN_PPF_TRFFOU
  Gosub TRA_PPL_TRFFOU
Endif
#----------------------------------#
# Boucle pour création tarif "FAM" #
#----------------------------------#
Raz [F:PPF], [F:PPL], WNBPPF, WNBPPL, WCODFOU, WBPSNUM, WPLICRD, WTEST_CODFOU, WTEST_BPSNUM
WPLI="FAM"
For [XTRF] IND0 Where evalue(SI_CRITERE) & FAMART<>"" & SOUFAMART=""
  Gosub LIG_PPL_TRFFOU
Next
If WBPSNUM<>""
  Raz [F:XTRF]
  Gosub ECR_PPL_TRFFOU        
  Gosub FIN_PPF_TRFFOU
  Gosub TRA_PPL_TRFFOU
Endif
#-----------------------------------#
# Boucle pour création tarif "SFAM" #
#-----------------------------------#
Raz [F:PPF], [F:PPL], WNBPPF, WNBPPL, WCODFOU, WBPSNUM, WPLICRD, WTEST_CODFOU, WTEST_BPSNUM
WPLI="SFAM"
For [XTRF] IND0 Where evalue(SI_CRITERE) & SOUFAMART<>""
  Gosub LIG_PPL_TRFFOU
Next
If WBPSNUM<>""
  Raz [F:XTRF]
  Gosub ECR_PPL_TRFFOU        
  Gosub FIN_PPF_TRFFOU
  Gosub TRA_PPL_TRFFOU
Endif
#-----
Return


#---------------------------------------#
# Trace de la création des fiches tarif #
#---------------------------------------#
$TRA_PPL_TRFFOU
If WNBPPF>0 & WTRA>1
  #----- Création du tarif xxxx (PPF=#####, PPL=#####) -----#
  WMSG=mess(89,194,1)-WPLI-"(PPF="+num$(WNBPPF)+",PPL="+num$(WNBPPL)+")"
  Call ECR_TRACE(WMSG,0) From GESECRAN
  #----- ##### fiche(s) créée(s) : xxxxxxxxxxxxxxx <--> xxxxxxxxxxxxxxx ----#
  WMSG=num$(WNBPPF)-SI_MES(87)
  If SI_SIMU=2
    WMSG-=": **"-mess(25,133,1)-"**"
  Else
    WMSG-=":"-WPLICRD-"<-->"-[F:PPF]PLICRD
  Endif
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
Return


#---------------------------------------------#
# Traitement d'une ligne de tarif "Intégrale" #
#---------------------------------------------#
$LIG_PPL_TRFFOU
#----- Pour créer le tarif, il faut que le fournisseurs soit valide dans X3 -----#
If [F:XTRF]CODFOU<>WTEST_CODFOU
  WTEST_BPSNUM=func SIXFONCTION.SI_COR("XIFOU",[F:XTRF]CODFOU,"BPSUPPLIER","")
  WTEST_CODFOU=[F:XTRF]CODFOU
Endif
If WTEST_BPSNUM<>""
  #----- Ecriture ligne tarif précédente -----#
  If WBPSNUM<>""
    Gosub ECR_PPL_TRFFOU        
    #----- Test rupture fiche -----#
    If WNBLIG>=WNBMAX | WCODFOU<>[F:XTRF]CODFOU
      Gosub FIN_PPF_TRFFOU
    Endif
  Endif
  #----- Si nouvelle fiche tarif -----#
  If WBPSNUM=""  Gosub DEB_PPF_TRFFOU : Endif
  #-----
  WCODART =[F:XTRF]CODART
  If [F:XTRF]CODART<>""
    WITMREF=func SIXFONCTION.SI_COR("XIART",[F:XTRF]CODART,"ITMMASTER","")
  Else
    WITMREF=""
  Endif
  WFAM    =[F:XTRF]FAMART
  If [F:XTRF]FAMART<>""
    WTSICOD1=func SIXFONCTION.SI_COR("XIFAMART",[F:XTRF]FAMART,"20","")
  Else
    WTSICOD1=""
  Endif
  WSFAM   =[F:XTRF]SOUFAMART
  If [F:XTRF]SOUFAMART<>""
    WTSICOD2=func SIXFONCTION.SI_COR2("XISOUFMART",[F:XTRF]FAMART,[F:XTRF]SOUFAMART,"21","")
  Else
    WTSICOD2=""
  Endif
  WCODTRF =[F:XTRF]CODTRF
  WCODDVS =[F:XTRF]CODDVS
  WQTEMIN =[F:XTRF]QTEMIN
  #----- Chargement ligne tarif -----#
  Raz [F:PPL]
  [F:PPL]=[F:PPF]
  [F:PPL]PLILIN=WNBLIG+1
  Case WPLI
    When "ART"
      [F:PPL]PLICRI =WBPSNUM+"~"+WITMREF+"~~~~"
      [F:PPL]PLICRI1=WBPSNUM
      [F:PPL]PLICRI2=WITMREF
      #----- Récupération de l'unité de l'article -----#
      Read [ITM] ITM0=WITMREF : If fstat  Raz [F:ITM] : Endif
      [F:PPL]UOM=[F:ITM]STU
      #-----
    When "FAM"
      [F:PPL]PLICRI =WBPSNUM+"~"+WTSICOD1+"~~~~"
      [F:PPL]PLICRI1=WBPSNUM
      [F:PPL]PLICRI2=WTSICOD1
      #----- Récupération de l'unité du 1er article de la famille -----#
      Filter [XART] Where CODFAM=WFAM
      Read [XART] IND9 First
      If !fstat
        Read [ITM] ITM0=[F:XART]X3CLE : If fstat  Raz [F:ITM] : Endif
        [F:PPL]UOM=[F:ITM]STU
      Else
        [F:PPL]UOM=""
      Endif
      Filter [XART]
      #-----
    When "SFAM"
      [F:PPL]PLICRI =WBPSNUM+"~"+WTSICOD1+"~"+WTSICOD2+"~~~"
      [F:PPL]PLICRI1=WBPSNUM
      [F:PPL]PLICRI2=WTSICOD1
      [F:PPL]PLICRI3=WTSICOD2
      #----- Récupération de l'unité du 1er article de la famille et sous-famille -----#
      Filter [XART] Where CODFAM=WFAM & CODSOUFAM=WSFAM
      Read [XART] IND9 First
      If !fstat
        Read [ITM] ITM0=[F:XART]X3CLE : If fstat  Raz [F:ITM] : Endif
        [F:PPL]UOM=[F:ITM]STU
      Else
        [F:PPL]UOM=""
      Endif
      Filter [XART]
  Endcase
  If [F:XTRF]CODDVS<>""
    [F:PPL]CUR=func SIXFONCTION.SI_COR("XIDVS",[F:XTRF]CODDVS,"TABCUR","")
  Endif
  If [F:PPL]CUR=""
    [F:PPL]CUR=[F:SPX]CUR
  Endif
  [F:PPL]LTI   =[F:XTRF]DELLIV
  [F:PPL]MINQTY=[F:XTRF]QTEMIN
  [F:PPL]PRI   =[F:XTRF]PRXACH
  If [F:XTRF]TAUREM<0
    If [F:SPX]DISCRGACH(2)<>0
      [F:PPL]DCGVAL([F:SPX]DISCRGACH(2)-1)=[F:XTRF]TAUREM : # Taux Majoration tarif fournisseur
    Endif
  Else
    If [F:SPX]DISCRGACH(0)<>0
      [F:PPL]DCGVAL([F:SPX]DISCRGACH(0)-1)=[F:XTRF]TAUREM : # Taux Remise tarif fournisseur
    Endif
  Endif
  #----- Mise à jour indicateur de reprise sur Tarif fournisseur "Intégrale" -----#
  If [F:PPL]PLICRI1<>"" & [F:PPL]PLICRI2<>"" & [F:PPL]UOM<>""& [F:PPL]CUR<>"" 
    Update [XTRF] Where CODTRF   =WCODTRF
&                     & CODFOU   =WCODFOU
&                     & CODDVS   =WCODDVS
&                     & FAMART   =WFAM
&                     & SOUFAMART=WSFAM
&                     & CODART   =WCODART
&                     & QTEMIN   =WQTEMIN
&                  With FLGREP=2
    If fstat
      WMSG =mess(13,100,1)-"XITRFFOU"-WCODTRF-WCODFOU-WCODDVS
      WMSG-=WFAM-WSFAM-WCODART+num$(WQTEMIN)+", fstat="+num$(fstat)
      Call ECR_TRACE(WMSG,1) From GESECRAN
    Endif
  Endif
  #-----
Else
  WNBERR+=1
Endif
#-----
Call AFFBOITE([F:XTRF]CODFOU-[F:XTRF]CODART-[F:XTRF]FAMART-[F:XTRF]SOUFAMART) From SUBSIM
Return


#----------------------------#
# Ecriture de la ligne tarif #
#----------------------------#
$ECR_PPL_TRFFOU
#----- Calcul quantité maxi -----#
If WCODFOU=[F:XTRF]CODFOU    &
&  WCODDVS=[F:XTRF]CODDVS    &
&  WFAM   =[F:XTRF]FAMART    &
&  WSFAM  =[F:XTRF]SOUFAMART &
&  WCODART=[F:XTRF]CODART
  WQTEMAX=[F:XTRF]QTEMIN
Else
  WQTEMAX=1000000000
Endif
If [F:TUN]UOM<>[F:PPL]UOM
  Read [TUN] TUN0=[F:PPL]UOM : If fstat  Raz [F:TUN] : Endif
Endif
WQTEMAX-=10^-[F:TUN]UOMDEC
[F:PPL]MAXQTY=WQTEMAX
#----- La ligne tarif est-elle valide et bonne pour le Write ? -----#
Raz WMSG
If [F:PPL]PLICRI1=""  WMSG=SI_MES(88) : Endif     : # Fournisseur non renseigné
If [F:PPL]UOM=""      WMSG=SI_MES(89) : Endif     : # Unité non renseignée
If [F:PPL]CUR=""      WMSG=SI_MES(90) : Endif     : # Devise non renseignée
Case WPLI
  When "ART"
    If [F:PPL]PLICRI2=""
      WMSG ="("+WCODART+")"-SI_MES(91) : # Article non renseigné
    Endif
  When "FAM"
    If [F:PPL]PLICRI2=""
      WMSG ="("+WFAM+")"   -SI_MES(92) : # Famille article non renseignée
    Endif
  When "SFAM"
    If [F:PPL]PLICRI2=""
      WMSG ="("+WFAM+")"   -SI_MES(92) : # famille article non renseignée
    Endif
    If [F:PPL]PLICRI3=""
      WMSG="("+WSFAM+")"   -SI_MES(93) : # Sous-famille article non renseignée
    Endif
Endcase
#-----
If WMSG<>""
  If WTRA>1
    WMSG=[F:PPL]PLI-[F:PPL]PLICRD-[F:PPL]PLICRI1-[F:PPL]PLICRI2-WMSG
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
  WNBERR+=1
  Return
Endif
#-----
SI_TABLE="PPRICLIST" : Gosub SI_BEFWRI From SIXFONCTION
Write [PPL]
If fstat
  GOK=0
  WMSG=mess(13,100,1)-"PPRICLIST"-WPLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)+","-func SIXFONCTION.FSTATMSG(fstat)
  Call ECR_TRACE(WMSG,1) From GESECRAN
  WNBERR+=1
Else
  WNBLIG+=1
Endif
#-----
Return


#--------------------------------------------------------#
# Début d'une nouvelle fiche tarif "ART", "FAM" ou SFAM" #
#--------------------------------------------------------#
$DEB_PPF_TRFFOU
#-----
GOK=1
Trbegin [PPF], [PPL], [XTRF]
#----- Chargement buffer fiche tarif -----#
Raz [F:PPF]
[F:PPF]PLI      =WPLI
[F:PPF]PLISTRDAT=WDATDEB2
[F:PPF]PLIENDDAT=WDATFIN2
[F:PPF]CREUSR   =GUSER
[F:PPF]CREDAT   =date$
[F:PPF]PLICRDIDX=WPLI
#----- Récupération du numéro de fiche à créer -----#
Gosub NUM_PLICRD
#-----
WCODFOU=[F:XTRF]CODFOU
WBPSNUM=WTEST_BPSNUM
Raz WNBLIG
Return


#---------------------------------#
# Fin de la fiche tarif, création #
#---------------------------------#
$FIN_PPF_TRFFOU
#-----
If GOK=1
  [F:PPF]LINNBR=WNBLIG
  SI_TABLE="PPRICFICH" : Gosub SI_BEFWRI From SIXFONCTION
  Write [PPF]
  If fstat
     GOK=0
    WMSG=mess(13,100,1)-"PPRICFICH"-WPLI-[F:PPF]PLICRD+","-func SIXFONCTION.FSTATMSG(fstat)
    Call ECR_TRACE(WMSG,1) From GESECRAN
    WNBERR+=WNBLIG
  Else
    WNBPPF+=1 : WNBPPL+=WNBLIG : WNBOK+=WNBLIG
    If WPLICRD=""  WPLICRD=[F:PPF]PLICRD : Endif
  Endif
Else
  WNBERR+=WNBLIG
Endif
#-----
If GOK=1 & SI_SIMU<>2
  Commit
Else
  Rollback
Endif
#-----
Raz WBPSNUM
Return


#################################
# Numérotation des fiches tarif #
#################################
$NUM_PLICRD
#-----
Call NUMERO(GCODNUM,[F:SPX]FCY,[F:PPF]PLISTRDAT,[F:PPF]PLICRDIDX,[F:PPF]PLICRD,WERR) From SUBANM
If GOK<1 | WERR<>0
  GOK=0 : Call ECR_TRACE(GCODNUM-mess(60,199,1),1) From GESECRAN
  Return
Endif
#-----
Return


############################################################
# CALNBENR : Compte le nombre d'enregistrement déjà traité #
#            et le nombre d'enregistrement total à traiter #
# -------------------------------------------------------- #
# Appelé depuis le traitement SUBSIM                       #
# La clase [M:SIM2] doit être ouverte et chargée           #
# WNOL est l'indice de la ligne en cours de traitement     #
# -------------------------------------------------------- #
# En sortie :                                              #
#    [M:SIM2]NB2TRT chargé avec nbre total à traiter       #
#    LMES chargé avec "nbre traité / nbre total"           #
############################################################
Funprog CALNBENR(WNOL)
Value Integer WNOL
#-----
Local Char    LMES(30)
Local Integer WNBTAR
#----- Nombre total d'enregistrements reste à traiter -----#
Local File XIFOU [XFOU] Where FLGREP=2
WNBTAR=rowcount([XFOU])
Close Local File [XFOU]
#-----
Local File XITRFFOU [XTRF] Where FLGREP<2
WNBTAR+=rowcount([XTRF])
Close Local File [XTRF]
#-----
LMES=num$(WNBTAR)-"/"
#----- Nombre total d'enregistrements à traiter -----#
Local File XIFOU [XFOU] Where FLGREP>1
WNBTAR=rowcount([XFOU])
Close Local File [XFOU]
#-----
Local File XITRFFOU [XTRF]
WNBTAR+=rowcount([XTRF])
Close Local File [XTRF]
#-----
LMES-=num$(WNBTAR)
[M:SIM2]NB2TRT(WNOL)=WNBTAR
#-----
End LMES
