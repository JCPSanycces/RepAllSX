#<AdxTL>@(#)5.0.0.0 $Revision$
#######################################################################
# Transcoding caracters utf8 -> ascii (bank file)
#######################################################################
Subprog TRANS(STRING)
Variable Char STRING
    Local Char UTF8_CHAR(255)
    Local Char ASCII_CHAR(255)
    Local Char VALID_CHAR(255)

# SAM #95257 DNE MODIF
#
# Note: We had to change the character translation in order to be SEPA and for some time DTAUS compatible.
#       This meant a) removing German Umlaute and b) regarding the colon as a valid character even if it
#       is not valid for DTAUS for it the transcoding of texts is done for everything including ISO date and
#       time information in SEPA XML files.
#
#       For we don't know the field length we could not replace German Umlaute by 2 character (e. g. "ä" by
#       "ae") so we decided to replace them by their base character ( "Ä" --> "A" etc.).
#
    UTF8_CHAR   = "ÄÖÜß&"                                                # Umlaute to be transformed in second step
    ASCII_CHAR  = "AOUS+"                                                # Characters for transformation
    VALID_CHAR  = " .,&-/+ÄÖÜß:"                                         # Valid characters for DTAUS (incl. Umlaute)
# SAM #95257 DNE ORIG
#    ASCII_CHAR  = chr$(91)+chr$(92)+chr$(93)+chr$(126)+"+"               # characters for transformation
#    VALID_CHAR  = " .,&-/+*$%ÄÖÜß"                                       # valid characters for DTAUS (incl. Umlaute)
# SAM #95257 DNE END
    STRING = toupper(STRING)                                             # Convert into capitals

    # convert all illegal characters to blank (all except A..Z, 0..9 and elements of VALID_CHAR
    For I = 1 To len(STRING)
      If ascii(mid$(STRING,I,1)) < 65 or ascii(mid$(STRING,I,1)) > 90    # Not A..Z
        If ascii(mid$(STRING,I,1)) < 48 or ascii(mid$(STRING,I,1)) > 57  # Not 0..9
           If not instr(1,VALID_CHAR,mid$(STRING,I,1))                   # Not a valid character
              STRING = left$(STRING,I-1) + " " + right$(STRING,I+1)
           Endif
        Endif
      Endif
    Next
    STRING = ctrans(toupper(STRING), UTF8_CHAR, ASCII_CHAR)              # convert "Umlaute"
End
