#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC03   Migration de la table BPARTNER           Module TRC     #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC03") From LECFIC
  Endif
  #Call RAZ_UUMGTRTTRC03(DOSSIER)
  Call MAJ_UUMGTRTTRC03(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTTRC03(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 by TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---

##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC03",3,ERR) From TRTMIG : #3=Terminée
  End
Endif


Local Integer ERR
Local Char WNAMBPRM
Call MIGTABNAME (DOSSIER,"BPARTNER",WNAMBPRM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC03",7,ERR) From TRTMIG : #7=Erreur
End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPRM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC03",3,ERR) From TRTMIG : #3=Terminée
End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC03",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC03",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Integer  ERR, NBCOMMIT,NBLUS
# Issue 112303 - 2015-11-09 by MAE : déplacement des variables
#Local Char WTAB_BPR (100) (adxwrb)
#Local Shortint WCPT_BPR

Call ECR_TIME("UUMGTRTTRC03 tables BPR Process : Update BPR") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC03 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"BPARTNER",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif   # Fichier X3 "Vide"

If clalev([F:BPRM]) = 0 : Local File =DOSSIER+"."+WNAMBPRM   [BPRM] : Endif   # Fichier X3 renommé Avant Migration


#-----  Déclaration des variables -----#
# Issue 112303 - 2015-11-09 by MAE : déplacement des variables
Local Char WTAB_BPR (100) (adxwrb)
Local Shortint WCPT_BPR
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz STOP, CRITERE, NBCOMMIT,NBLUS

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC03" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BPR00
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:BPRM]BPRNUM>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [BPR]
GOK = 1

For [BPRM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTTRC03" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_BPR
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_BPR
  Endif
  [F:BPR] = [F:BPRM]

  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_BPR
    If GOK<1 : Break : Endif
  Endif

  # Passage en V7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_BPR
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
  #--- Issue 108760 by TS
  #If NEWMOTEUR
  #    Gosub BPR_STK : # pour stocker ref
  #    WriteB[F:BPR]
  #Else
  #    Write [F:BPR]
  #Endif
  #If fstat
  #  If NEWMOTEUR & adxwrb>1
  #    Call ECR_TRACE("File BPARTNER, Error ="-num$(fstat),1) From GESECRAN
  #    Gosub BPR_ERRTRA : # pour afficher les ref
  #  Else
  #    Call ECR_TRACE("File BPARTNER(BPRNUM)"-[F:BPR]BPRNUM+", Error ="-num$(fstat),1) From GESECRAN
  #  Endif
  #  GOK=0 : Break
  #Endif
  Gosub BPR_STK : # pour stocker ref
  WriteB[F:BPR]
  If fstat
    Call ECR_TRACE("File BPARTNER, Error ="-num$(fstat),1) From GESECRAN
    Gosub BPR_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:BPRM]BPRNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC03",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:BPR]
    If fstat
        Call ECR_TRACE("File BPARTNER, Error ="-num$(fstat),1) From GESECRAN
        Gosub BPR_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #--- Issue 108760 by TS
  #Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(2)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC03",NBMIGKEY,TABMIGKEY,NBLUS,NB+NBCOMMIT,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC03",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_BPR00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BPR]
Close Local File [BPRM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"BPARTNER",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTTRC03") From TRTMIG
Call ECR_TIME("UUMGTRTTRC03 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End
################################################
$RAZV6_BPR
Raz [F:BPR]BPRFBDMAG
Raz [F:BPR]CCNFLG
If dim([F:BPR]CRESTP)>0 Raz [F:BPR]CRESTP : Endif
Raz [F:BPR]ENAFLG
Raz [F:BPR]LEGETT
If dim([F:BPR]IDTSGL)>0 Raz [F:BPR]IDTSGL : Endif
If dim([F:BPR]UPDSTP)>0 Raz [F:BPR]UPDSTP : Endif
Return
################################################
$RAZV7_BPR
Return
################################################
$MAJV6_BPR
[F:BPR]ENAFLG=2
If [F:BPR]BPRFBDMAG = 0 Then
  [F:BPR]BPRFBDMAG = 1 # Par défaut vaut 1:NON accepte de recevoir les mailings
Endif
Return
################################################
$MAJV7_BPR
Return
################################################
$BPR_STK
Call STK (WTAB_BPR,WCPT_BPR,[F:BPR]BPRNUM) From TRTMIG
Return
##############################################################################################
$BPR_ERRTRA
Call ERRTRA (WTAB_BPR,WCPT_BPR,"File BPARTNER(REFBPR)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTTRC03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC03(APPLI)
End
#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTTRC03(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMBPRM
Call MIGTABNAME (DOSSIER,"BPARTNER",WNAMBPRM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMBPRM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"BPARTNER",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC03",ERR) From TRTMIG

End

