#<AdxTL>@(#)0.0.0.0 $Revision$ Object management PJMSNP
###################################################################################################
# Objet PJMSNP
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"                       : Gosub OUVRE
    When "LIENS"                       : Gosub LIENS
    When "RAZCRE"                      : Gosub RAZCRE
    When "RAZDUP"                      : Gosub RAZDUP     # Issue X3-78590 - 2018-03-06 by SINGC
    When "INICRE"                      : Gosub INICRE
    When "CREATION"                    : Gosub CREATION
    When "MODIF"                       : Gosub MODIF
    When "EXEBOUT"                     : Gosub EXEBOUT
    When "ANNULE"                      : Gosub ANNULE
    When "SETBOUT"                     : Gosub SETBOUT
    When "AVANTBOUT"                   : Gosub AVANTBOUT  # Issue X3-99928 - 2018-07-19 by ALMON
  Endcase
Return

###################################################################################################
$OUVRE
  # Issue X3-92786 - 2018-05-30 by FGR : BEGIN
  #If !clalev([F:PSNPH])   : Local File PJMSNPH [PSNPH]       : Endif
  #If !clalev([F:PSNPD])   : Local File PJMSNPD [PSNPD]       : Endif
  #If !clalev([F:PJMRPT])  : Local File PJMFINOVRRPT [PJMRPT] : Endif
  #If !clalev([F:PJMCTO])  : Local File PJMFINCTORPT [PJMCTO] : Endif
  Local File PJMSNPD [PSNPD]
  Local File PJMFINOVRRPT [PJMRPT]
  Local File PJMFINCTORPT [PJMCTO]
  # Issue X3-92786 - 2018-05-30 by FGR : END
Return

###################################################################################################
$LIENS
  GFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, [M:PSNP0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, GMESSAGE)
  If GMESSAGE <> AVOID.ACHAR Then
    GOK = 1
    GERR = 1
  Else
    #[M:PSNP0]UOM = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, GFCY, "HOURLYUNIT")    # Issue X3-107215 - 2018-10-08 by FGR
    Call LOAD_SNAPSHOT_LIST()
    If [M:PSNP1]NBLIG > 0 Then
      Diszo [M:PSNP0]OPPNUM
      Diszo [M:PSNP0]SNPCOD
      Diszo [M:PSNP0]SHOWGRP
      Diszo [M:PSNP0]UOM
      Diszo [M:PSNP0]CUR
    Else
      # Issue X3-78590 - 2018-03-06 by SINGC : START
      If SAVCLE1 <> AVOID.ACHAR Then
        # Coming from GESPJM
        Diszo [M:PSNP0]OPPNUM
      Else
        # Coming from GESPJMSNP
        Actzo [M:PSNP0]OPPNUM
      Endif
      # ---------------------------
      Actzo [M:PSNP0]SNPCOD
      Actzo [M:PSNP0]SHOWGRP
      Actzo [M:PSNP0]UOM
      Actzo [M:PSNP0]CUR
      # Issue X3-78590 - 2018-03-06 by SINGC : END
    Endif
  Endif
Return

###################################################################################################
$RAZCRE
  If [M:PSNP0]OPPNUM <> AVOID.ACHAR Then
    Diszo [M:PSNP0]OPPNUM
    Call LOAD_SCREEN_DEFAULT([M:PSNP0]OPPNUM)
    #Call LOAD_SNAPSHOT_LIST()                # Issue X3-78590 - 2018-03-06 by SINGC : New record doesn't have Snapshot lines
  Endif
Return

###################################################################################################
$RAZDUP
  # Issue X3-78590 - 2018-03-06 by SINGC
  Diszo [M:PSNP0]OPPNUM
  Call LOAD_SCREEN_DEFAULT([M:PSNP0]OPPNUM)
Return

###################################################################################################
$INICRE
Local Char SCPY(GLONCPY)
Local Char SFCY(GLONFCY)
Local Integer IERROR
Local Char SMESSAGE(250)
Local Integer IMANUAL
Local Char SCOMPTEUR(GLONANM)
Local Char SNUMERO(GLONVCR)
Local Integer STAT

  SCPY = func PIMPL_CSTD_PROGS.GET_CPY_VALUE(GACTX, [M:PSNP0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
  Call READ_COUNTER(GACTX, 9, 15, SCPY, SCOMPTEUR, IMANUAL, SMESSAGE, IERROR) From CRM_UTIL_SYRA
  If IERROR = [V]CST_AYES Then
    GERR = 1
    GOK = 0
    GMESSAGE = SMESSAGE
    Return
  Endif
  If SCOMPTEUR <> AVOID.ACHAR Then
    # Get the counter for the SNP
    If IMANUAL <> [V]CST_AYES or (IMANUAL = [V]CST_AYES and vireblc([M:PSNP0]SNPCOD,2) = AVOID.ACHAR) Then
      SFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, [M:PSNP0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
      Call NUMERO(SCOMPTEUR, SFCY, [M:PSNP0]SNPDTECRE, AVOID.ACHAR, SNUMERO, STAT) From SUBANM
      If GOK < 0 Then
        Return
      Endif
      If GOK > 0 and STAT = 0 Then
        [F:PSNPH]SNPCOD = SNUMERO
        [M:PSNP0]SNPCOD = SNUMERO
        Affzo [M:PSNP0]SNPCOD
      Else
        GMESSAGE = mess(60,199,1) - "(" + SCOMPTEUR + ") : "
        Gosub MESSAGE From SUBANM
        GMESSAGE -= MESSA   # MESSA is created in "Gosub MESSAGE From SUBANM"
        GERR = 1
        GOK = 0
        Return
      Endif
    Endif
  Else
    If [M:PSNP0]SNPCOD = AVOID.ACHAR Then
      GMESSAGE = mess(1,79,1)
      GERR = 1
      GOK = 0
      zonsui = "[M:PSNP0]SNPCOD"
      Return
    Endif
  Endif
Return

###################################################################################################
$CREATION
  Call MAJ_ATEXTRA_HEADER()
Return

###################################################################################################
$MODIF
Local Integer NI
Local Integer IRET
Local Clbfile BCLOB
Local Char SKEY(type([M:PSNP1]KEYEXT)-1)

  Call MAJ_ATEXTRA_HEADER()
  Filter [PSNPD] Where SNPCOD = [M:PSNP0]SNPCOD
  For [PSNPD]
    NI = find([F:PSNPD]SNPSEQ, [M:PSNP1]SNPSEQ(0..[M:PSNP1]NBLIG-1))
    If NI = 0 Then
      IRET = func PJMRPTEXT.DELETE_RPT_TABLES([F:PSNPD]KEYEXT, [M:PSNP0]SHOWGRP, [M:PSNP0]OPPNUM)
      If IRET = [V]CST_AERROR Then
        Break
      Endif
      # Issue X3-15630 - 2018-03-05 by FGR : BEGIN
      #Call SUPTEXTRA("PJMSNPD", "DDESAXX", [M:PSNP0]SNPCOD, num$([F:PSNPD]SNPSEQ(nolign-1))) From ATEXTRA
      Call SUPTEXTRA("PJMSNPD", "DDESAXX", [F:PSNPD]KEYEXT, "") From ATEXTRA
      # Issue X3-15630 - 2018-03-05 by FGR : END
      IRET = func SUBPJMCLA.UPDATE_PJMCLOB_TABLE("PJMSNP1", "CLOB", [F:PSNPD]KEYEXT, BCLOB, [V]CST_ADEL, GMESSAGE)
      If IRET = [V]CST_AERROR Then
        GERR = 1
        GOK = 0
        Break
      Endif
      Delete [PSNPD]Curr
    Else
      # Issue X3-15630 - 2018-03-05 by FGR : BEGIN
      #Call MAJTEXTRA([M:PSNP1]DDESAXX(NI-1), "PJMSNPD", "DDESAXX", [M:PSNP0]SNPCOD, num$([F:PSNPD]SNPSEQ)) From ATEXTRA
      Call MAJTEXTRA([M:PSNP1]DDESAXX(NI-1), "PJMSNPD", "DDESAXX", [M:PSNP1]KEYEXT(NI-1), "") From ATEXTRA
      # Issue X3-15630 - 2018-03-05 by FGR : END
      SKEY = [M:PSNP1]KEYEXT(NI-1)
      IRET = func SUBPJMCLA.UPDATE_PJMCLOB_TABLE("PJMSNP1", "CLOB", SKEY, [M:PSNP1]CLOB(NI-1), [M:PSNP1]ACT(NI-1), GMESSAGE)
      If IRET = [V]CST_AERROR Then
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
  Next
  Filter [PSNPD]
Return

###################################################################################################
$SETBOUT
  If GREP <> "" Then
    Call VIREBOUT(CHAINE, "1") From GOBJET
  Endif
  Gosub SET_BOUT_SPE From GSAISIE
Return

###################################################################################################
$EXEBOUT
  Case BOUT
    When "1"
      # Snapshot Extract
      Gosub RELIT From GOBJSUB
  Endcase
Return

###################################################################################################
$AVANTBOUT
  # Issue X3-99928 - 2018-07-19 by ALMON
  Case BOUT
    When "1"
      # Financial snapshot extraction
      If func SUBPJMA.GET_AUTHORIZATION("1") = [V]CST_ANO Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
  Endcase
Return

###################################################################################################
$ANNULE
  Call DELETE_DETAIL_ALL()
  If GOK < 1 Then
    Return
  Endif
Return

###################################################################################################
# Screens fields
###################################################################################################
# PJMSNP0
###################################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

  Call LOAD_SCREEN_DEFAULT(VALEUR)
End

###################################################################################################
# PJMSNP1
###################################################################################################
Subprog IB_NBLIG

  # Issue X3-99928 - 2018-07-19 by ALMON
  If GBOUT1 <> AVOID.ACHAR Then
    # 1 - Snapshot View
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("1") = [V]CST_ANO Then
      Raz GBOUT1
    Endif
  Endif
  If GBOUT2 <> AVOID.ACHAR Then
    # 2 - Snapshot Comparison
    If func SUBPJMA.GET_AUTHORIZATION_GESPJM("!") = [V]CST_ANO Then
      Raz GBOUT2
    Endif
  Endif
End

###################################################################################################
# Subroutines and functions
###################################################################################################
Subprog MAJ_ATEXTRA_HEADER()
  # Issue X3-99928 - 2018-08-22 by FGR : I don't know why it was a Gosub !
  Call MAJTEXTRA([M:PSNP0]DESAXX, "PJMSNPH", "DESAXX", [M:PSNP0]SNPCOD, "") From ATEXTRA
End

###################################################################################################
Subprog LOAD_SCREEN_DEFAULT(SOPPNUM)
Value Char SOPPNUM()

Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer IRET
Local Integer IMESSAGE
Local Char SFCY(GLONFCY)
Local Instance TECFINOVE Using C_TECFINOVE

  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  # -------------------------------------------------------
  IRET = fmet TECFINOVE._GET_DEFAULT_GRP()
  [M:PSNP0]SNPDTECRE = date$
  [M:PSNP0]OPPNUM = SOPPNUM
  #[M:PSNP0]CUR = func OPPOR_CSTD_PROGS_COM.GET_CUR_VALUE(GACTX, SOPPNUM, SMESSAGE)      # Issue X3-107215 - 2018-10-04 by FGR
  [M:PSNP0]CUR = func OPPORPJM_CSTD_PROGS.GET_CUROPP_VALUE(GACTX, SOPPNUM, SMESSAGE)     # Issue X3-107215 - 2018-10-04 by FGR
  [M:PSNP0]SHOWGRP = TECFINOVE.SHOWGRP
  [M:PSNP0]DESAXX = func PIMPL_CSTD_PROGS.GET_PIMDESAXX(GACTX, SOPPNUM) # Issue X3-81034 - 2018-03-27 by SINGC
  If SMESSAGE <> AVOID.ACHAR Then
    GMESSAGE = SMESSAGE
    GOK = 1
    GERR = 1
  Else
    SFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, SOPPNUM, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
    If SMESSAGE <> AVOID.ACHAR Then
      GMESSAGE = SMESSAGE
      GOK = 1
      GERR = 1
    Else
      [M:PSNP0]UOM = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, SFCY, "HOURLYUNIT")
      GFCY = SFCY                                                       # Issue X3-99928 - 2018-07-19 by FGR
      Affzo [M:PSNP0]1-99
    Endif
  Endif
  # -------------------------------------------------------
  FreeGroup TECFINOVE
End

###################################################################################################
Subprog LOAD_SNAPSHOT_LIST()

Local Integer NI
Local Integer IBOOL
Local Char SKEY(type([M:PSNP1]KEYEXT)-1)

  nolign = 0
  Filter [PSNPD] Where [F:PSNPD]SNPCOD = [M:PSNP0]SNPCOD Order By SNPSEQ Desc
  For [PSNPD]
    nolign += 1
    [M:PSNP1] = [F:PSNPD]
    [M:PSNP1]ACT(nolign-1) = [V]CST_ALL
    Raz [M:PSNP1]CLOB(nolign-1)
  Next
  Filter [PSNPD]
  [M:PSNP1]NBLIG = nolign
  For NI = 0 To [M:PSNP1]NBLIG-1
    SKEY = [M:PSNP1]KEYEXT(NI)
    IBOOL = func SUBPJMCLA.KEY_EXIST("PJMSNP1", "CLOB", SKEY)
    [M:PSNP1]BTCMT(NI) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GACTX, IBOOL)
  Next NI
End

###################################################################################################
Subprog DELETE_DETAIL_ALL()

Local Integer DETSUB
Local Integer IRET
Local Char SKEY(type([M:PSNP1]KEYEXT)-1)

  For DETSUB = 0 To [M:PSNP1]NBLIG-1
    IRET = func PJMRPTEXT.DELETE_RPT_TABLES([M:PSNP1]KEYEXT(DETSUB), [M:PSNP0]SHOWGRP, [M:PSNP0]OPPNUM)
    If IRET = [V]CST_AERROR Then
      Break
    Endif
    Call SUPTEXTRA("PJMSNPD", "DDESAXX", [M:PSNP0]SNPCOD, num$([M:PSNP1]SNPSEQ(DETSUB))) From ATEXTRA
    SKEY = [M:PSNP1]KEYEXT(DETSUB)
    IRET = func SUBPJMCLA.UPDATE_PJMCLOB_TABLE("PJMSNP1", "CLOB", SKEY, [M:PSNP1]CLOB(DETSUB), [V]CST_ADEL, GMESSAGE)
    If IRET = [V]CST_AERROR Then
      GERR = 1
      GOK = 0
      Break
    Endif
  Next DETSUB
  If IRET = [V]CST_AERROR Then
    End
  Endif
  #Delete
  Delete [PSNPD] Where [F:PSNPD]SNPCOD = [M:PSNP0]SNPCOD
  If fstat Then
    GOK = 0
    GMESSAGE = func AFNC.MES1(mess(1032,2260,1), [M:PSNP0]SNPCOD)
    End
  Endif
End

###################################################################################################
Funprog GET_KEYEXT_DESC(SKEYEXT)
Value Char SKEYEXT

Local Char SNPDESC(GLONDCO)

  # X3-73879 Enhancement ALMON 01-02-2018
  Raz SNPDESC
  # ---------------------------
  Local File PJMSNPD [PSNPD]
  Local File ATEXTRA [AXX]
  # ---------------------------
  Filter [PSNPD] Where [F:PSNPD]KEYEXT = SKEYEXT
  Read [PSNPD]First
  If !fstat Then
   Call LECTEXTRA(SNPDESC, "PJMSNPD", "DDESAXX", [F:PSNPD]SNPCOD, num$([F:PSNPD]SNPSEQ)) From ATEXTRA
   SNPDESC -= mess(1047,2260,1) - format$(GFMDAT,[F:PSNPD]SNPDDTECRE)
  Endif
  Filter [PSNPD]
End SNPDESC

# Issue X3-107215 - 2018-10-05 by FGR : BEGIN : Undo X3-106683 which is wrong !
###################################################################################################
Funprog GET_SNAPSHOT_HEADER(SKEYEXT, SOPPNUM, SSNPCOD, SSHOWGRP, SUOM, SCUR, SSNPDATE, SMESSAGE)
Value Char SKEYEXT
Variable Char SOPPNUM      # X3-15630 Enhancement ALMON 01-03-2018
Variable Char SSNPCOD      # X3-15630 Enhancement ALMON 01-03-2018
Variable Char SSHOWGRP
Variable Char SUOM
Variable Char SCUR
Variable Date SSNPDATE     # X3-15630  Enhancement ALMON 06-03-2018
Variable Char SMESSAGE

Local Integer IRET

  # X3-73879 Enhancement ALMON 01-02-2018
  IRET = [V]CST_AOK
  Raz SMESSAGE
  # ---------------------------
  Local File PJMSNPD [PSNPD]
  Local File PJMSNPH [PSNPH]
  # ---------------------------
  Raz SOPPNUM    # X3-15630 Enhancement ALMON/FGR 01-03-2018
  Raz SSNPCOD    # X3-15630 Enhancement ALMON/FGR 01-03-2018
  Raz SSNPDATE   # X3-15630 Enhancement ALMON/FGR 01-03-2018
  Raz SSHOWGRP
  Raz SUOM
  Raz SCUR
  # ---------------------------
  Filter [PSNPD] Where [F:PSNPD]KEYEXT = SKEYEXT
  Read [PSNPD]First
  If !fstat Then
    SSNPCOD  = [F:PSNPD]SNPCOD
    SSNPDATE = [F:PSNPD]SNPDDTECRE
    Filter [PSNPH] Where [F:PSNPH]SNPCOD = [F:PSNPD]SNPCOD
    Read [PSNPH]PSNPH0=[F:PSNPD]SNPCOD
    If !fstat Then
      SOPPNUM  = [F:PSNPH]OPPNUM
      SSHOWGRP = [F:PSNPH]SHOWGRP
      SCUR = [F:PSNPH]CUR
      SUOM = [F:PSNPH]UOM
    Else
      IRET = [V]CST_AERROR
      SMESSAGE = func AFNC.MES1(mess(1046,2260,1), SKEYEXT)
    Endif
  Else
    IRET = [V]CST_AERROR
    SMESSAGE = func AFNC.MES1(mess(1046,2260,1), SKEYEXT)
  Endif
  Filter [PSNPD]
End IRET

