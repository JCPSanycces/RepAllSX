# Supervisor
## ACLA-CLASSE ## EMPLOEXM
# 2018-11-06 07:06:11 906

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOEXM
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_NUMLIG From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_DOMEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_DESEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_DATEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_DATEXMEND From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_LEVEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_ORGEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_PLCORGEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_MENEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_CREDAT From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_CRETIM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_UPDDAT From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_UPDTIM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOEXM : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOEXM
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOEXM
Gosub LNKPRO_REFNUM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub LNKPRO_DOMEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub LNKPRO_LEVEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub LNKPRO_ORGEXM From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1EMPLOEXM : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EMPLOEXM : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



