#<AdxTL>@(#)0.0.0.0 $Revision$
# Epic: 55934
# Supplier selection - Manufacturing
# ----------------------------------
$ACTION
Case ACTION
  When "SEL_TABLE" : Case TABLE
                       When "SELMFGBPS1" : Gosub SELMFGBPS1
                       When "SELMFGBPS2" : Gosub SELMFGBPS2
                       When "SELMFGBPS3" : Gosub SELMFGBPS3
                     Endcase
Endcase
Return

# Sub SELMFGBPS1
# Supplier selection on
# 1. product-site (parameter: ITMBPSFCY = "Mandatory"), or
# 2. product (parameter: ITMBPSFCY = "Mandatory"), or
# 3. all suppliers - from object
$SELMFGBPS1
Local Char PRODUCT(GLONITM) : PRODUCT = PARAM(1)
Local Char SITE(GLONFCY)    : SITE = PARAM(2)
Local Char GP(30)
Local Integer SELTYPE : SELTYPE = 0

Call PARAM(SITE,"ITMBPSFCY",GP) From ADOVAL
If (GP = "1")
  SELTYPE = 1
Else
  Call PARAM(SITE,"ITMBPS",GP) From ADOVAL
  If (GP = "1")
    SELTYPE = 2
  Endif
Endif

If (SELTYPE = 1)
  # product-site suppliers ..

  If (clalev([F:ITPF]) = 0) : Local File ITMBPSFCY [ITPF] : Endif
  If (clalev([F:BPS]) = 0) : Local File BPSUPPLIER [BPS]  : Endif
  Link [ITPF] With [BPS]BPS0 ~= [ITPF]BPSNUM As [ITPFX]
&             Where ITMREF = PRODUCT and
&                   STOFCY = SITE and
&                  (DOUFLG = 1 or DOUFLG = 2)
  Default File [ITPFX]

  TIT(0) = mess(10,16,1) - mess(457,198,1)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "[F:ITPF]BPSNUM" : Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSNAM"  : Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSSHO"  : Call TEXTFIC("BPSUPPLIER","BPSSHO",1,TIT(NBCOL)) From OBJDIV
Elsif (SELTYPE = 2)
  # product suppliers ..

  If (clalev([F:ITP]) = 0) : Local File ITMBPS [ITP]     : Endif
  If (clalev([F:BPS]) = 0) : Local File BPSUPPLIER [BPS] : Endif
  Link [ITP] With [BPS]BPS0 ~= [ITP]BPSNUM As [ITPX]
&            Where ITMREF = PRODUCT and
&                 (DOUFLG = 1 or DOUFLG = 2)
  Default File [ITPX]

  TIT(0) = mess(10,16,1) - mess(457,198,1)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "[F:ITP]BPSNUM" : Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSNAM" : Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSSHO" : Call TEXTFIC("BPSUPPLIER","BPSSHO",1,TIT(NBCOL)) From OBJDIV
Else
  OBJET = "BPS"
Endif

Return

# Sub SELMFGBPS2
# Supplier selection on product
$SELMFGBPS2
Local Char PRODUCT(GLONITM) : PRODUCT = PARAM(1)
Local Char SITE(GLONFCY)    : SITE = PARAM(2)

# product suppliers ..

If (clalev([F:ITP]) = 0) : Local File ITMBPS [ITP]     : Endif
If (clalev([F:BPS]) = 0) : Local File BPSUPPLIER [BPS] : Endif
Link [ITP] With [BPS]BPS0 ~= [ITP]BPSNUM As [ITPX]
&          Where ITMREF = PRODUCT and
&               (DOUFLG = 1 or DOUFLG = 2)
Default File [ITPX]

TIT(0) = mess(1,3505,1)
ORDRE  = "[F:ITP]PIO;[F:ITP]BPSNUM"
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:ITP]BPSNUM"              : Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSNAM"              : Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]ITMREFBPS"           : Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]ITMDESBPS"           : Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "num$([F:ITP]PIO)"                 : Call TEXTFIC("ITMBPS","PIO",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITP]DOUFLG,516,1)"  : Call TEXTFIC("ITMBPS","DOUFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITP]DEFBPSFLG,1,1)" : Call TEXTFIC("ITMBPSFCY","DEFBPSFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]PURMINQTY"           : Call TEXTFIC("ITMBPS","PURMINQTY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]PUU"                 : Call TEXTFIC("ITMBPS","PUU",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]QLYMRK"              : Call TEXTFIC("ITMBPS","QLYMRK",1,TIT(NBCOL)) From OBJDIV

Return

# Sub SELMFGBPS3
# Supplier selection on product-site
$SELMFGBPS3
Local Char PRODUCT(GLONITM) : PRODUCT = PARAM(1)
Local Char SITE(GLONFCY)    : SITE = PARAM(2)

# product-site suppliers

If (clalev([F:ITPF]) = 0) : Local File ITMBPSFCY [ITPF] : Endif
If (clalev([F:BPS]) = 0) : Local File BPSUPPLIER [BPS]  : Endif
Link [ITPF] With [BPS]BPS0 ~= [ITPF]BPSNUM, [ITP]ITP0 ~= PRODUCT;[ITPF]BPSNUM As [ITPFX]
&           Where ITMREF = PRODUCT and
&                 STOFCY = SITE
Columns [ITPFX]([ITPF]BPSNUM,[BPS]BPSNAM,[ITP]ITMREFBPS,[ITP]ITMDESBPS,[ITPF]PIO,
&               [ITPF]DOUFLG,[ITPF]DEFBPSFLG,[ITP]PURMINQTY,[ITP]PUU,[ITP]QLYMRK)
Filter [ITPFX] Where [ITPF]DOUFLG = 1 or [ITPF]DOUFLG = 2
Default File [ITPFX]

TIT(0) = mess(2,3505,1)
ORDRE  = "[F:ITPF]PIO;[F:ITPF]BPSNUM"
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:ITPF]BPSNUM"              : Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSNAM"               : Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]ITMREFBPS"            : Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]ITMDESBPS"            : Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "num$([F:ITPF]PIO)"           : Call TEXTFIC("ITMBPS","PIO",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITPF]DOUFLG,516,1)"  : Call TEXTFIC("ITMBPS","DOUFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITPF]DEFBPSFLG,1,1)" : Call TEXTFIC("ITMBPSFCY","DEFBPSFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]PURMINQTY"            : Call TEXTFIC("ITMBPS","PURMINQTY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]PUU"                  : Call TEXTFIC("ITMBPS","PUU",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITP]QLYMRK"               : Call TEXTFIC("ITMBPS","QLYMRK",1,TIT(NBCOL)) From OBJDIV

Return

