#<AdxTL>@(#)0.0.0.0 $Revision$
# JALLIBD                                               MC 27/01/99
#
# Initialisation WORKLOAD d'un Site
# Jalonnement des OF d'un Site
#
#   séquence introduite pour test
#
#CHECK UNUSED_BEGIN
Local Date CUTSTRDAT      : CUTSTRDAT = [18/09/00]
Call IWKLFCY("INO",CUTSTRDAT,"","")
End
#CHECK UNUSED_END

#########################################################################
# Subprog IWKLFCY(LMFGFCY,LCUTSTRD,LWSTD,LWSTF)                         #
# Subprog JALFCY(LMFGFCY,LWSTD,LWSTF,LJAL)                              #    # llc 11.02 16478
# Subprog SAI_BATCH(OK,OPT)                                             #
# Subprog JALFCYB(LMFGFCY,LCUTSTRD,LWSTD,LWSTF,LJAL)                    #    # sr 04.03 modélisation
#########################################################################

# Initialisation WKL des postes d'un site
#   LMFGFCY  : Site
#   LCUTSTRD : Date début du découpage en périodes
#   LWSTD, LWSTF:    bornes poste
#
Subprog IWKLFCY(LMFGFCY,LCUTSTRD,LWSTD,LWSTF)
#
Value Char       LMFGFCY()
Variable Date    LCUTSTRD
Value Char       LWSTD
Value Char       LWSTF

#
Local Char    WWCR (GLONWCR)
Local Char    WWST (GLONWST)
Local Char    WTAB (GLONABR)
Local Char    WCLE (GLONVCR)
Local Integer WRET

If clalev([F:PJA])  = 0 : Local File PARJAL     [PJA]  : Endif
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif

# Issue 84411 GA 10/2012
If LWSTD <> "" | LWSTF <> "" End Endif

#--------- 06.07
# PE pour initialisation LCUTSTRD
GPOINT = "INITIWLCUT"
Gosub  ENTREE From EXEFNC
#---------

Trbegin ADOVAL
#   mise à jour paramètre date
If LCUTSTRD = [0/0/0] : LCUTSTRD = date$ : Endif

Readlock [PJA]PJA0=LMFGFCY
If !fstat
   [F:PJA]CUTSTRDAT = LCUTSTRD
   [F:PJA]UPDDAT = date$
   [F:PJA]UPDUSR = GUSER
   Rewrite [PJA]
Endif
If fstat : #& !GSERVEUR
   LCUTSTRD=[0/0/0] : # GH 28/08/12 bug 83499
   WTAB="PJA" : WCLE=LMFGFCY
   If fstat=1 : Goto ROLL_JALLIBD : Else Goto AB_JALLIBD : Endif
Endif
#Unlock [PJA] # GH 28/08/12 inutile : tout ce qui est locké dans une transaction n'est délocké qu'à la fin de celle-ci

# 02.06 35082 nouvelle méthode de purge
For [WKL]WKL0 Where MFGFCY=[L]LMFGFCY
    Readlock [WKL] Curr
    If fstat=1 : #& !GSERVEUR
       WTAB="WKL" : WCLE=LMFGFCY : Break
    Endif
    Delete [WKL]
Next

If WTAB<>""
   LCUTSTRD=[0/0/0] : # GH 28/08/12 bug 83499
   Goto ROLL_JALLIBD
Endif

Commit

# ----- PE WORKLOAD
GPOINT = "RSTLOAD" : Gosub ENTREE From EXEFNC

#   création WORKLOAD du site
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TWC])  = 0 : Local File TABWRKCTR  [TWC]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV])  = 0 : Local File TABUNAVAIL [TUV]  : Endif

# lecture site
Call LECTURE ("FCY",LMFGFCY,"") From CONTOBJ

# lecture indisponibilités
Read [F:TUV]UVY0=[F:FCY]UVYCOD
If fstat : Raz [F:TUV] : Endif

#   prospecte l'ensemble des postes du site
For [MWS]WST4 Where WCRFCY = [L]LMFGFCY & WSTTYP <> 3        # 10.02 Performances
  WWCR = [F:MWS]WCR
  WWST = [F:MWS]WST

  Trbegin ADOVAL
  #     initialise le poste
  Call INIWKL(LMFGFCY,WWCR,WWST,WRET) From JALLIBC
  Commit
Next

End

#########################################################################
Subprog JALFCYB(LMFGFCY,LCUTSTRD,LWSTD, LWSTF, LJAL)
Value Char       LMFGFCY()
Value Date       LCUTSTRD
Value Char       LWSTD
Value Char       LWSTF
Value Integer    LJAL

Call IWKLFCY(LMFGFCY,LCUTSTRD,LWSTD,LWSTF)
If LCUTSTRD<>[0/0/0]
   Call JALFCY(LMFGFCY,LWSTD, LWSTF, LJAL)
Endif
End

#########################################################################
# Jalonnement des OF d'un site
#   LMFGFCY  : Site
#   LWSTD, LWSTF:    bornes poste
# llc 11.02 16478
Subprog JALFCY(LMFGFCY,LWSTD, LWSTF, LJAL)
#
Value Char       LMFGFCY()
Value Char       LWSTD
Value Char       LWSTF
Value Integer    LJAL                   # llc 11.02 16478

Local    Char    WMFGNUM(GLONVCR)
Local    Integer WJAVFLG
Local    Integer WSCDFLG                # llc 11.02 16478
Local    Char    WCRITERE(100)          # GH 28/12/11 bug 78398

Local Mask JALK [JALK]

Raz [M:JALK]
[M:JALK]CODORI = 1
[M:JALK]MFGFCY = LMFGFCY
[M:JALK]CODTRS = 0

#--------- 06.07
# PE pour initialisation LCUTSTRD
GPOINT = "INITIWLJAL"
Gosub  ENTREE From EXEFNC
#---------

#   ouverture des fichiers
#
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING [SCH]  : Endif
If clalev([F:MFG1]) = 0 : Local File MFGHEAD    [MFG1] : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD    [MFG]  : Endif        # llc 10126 08.01
If clalev([F:MFO1]) = 0 : Local File MFGOPE     [MFO1] : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT     [MFM]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS [OPS]  : Endif
If clalev([F:WKL])  = 0 : Local File WORKLOAD   [WKL]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV])  = 0 : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR     [CPV]  : Endif
If clalev([F:PJA])  = 0 : Local File PARJAL     [PJA]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS     [ORD]  : Endif        # llc 11.02 16478

Read [PJA]PJA0=LMFGFCY
If !fstat : WJAVFLG = [F:PJA]AUTFRWSCD : Else : WJAVFLG = 2 : Endif


#   Jalonnement des OF fermes et planifiés du site
#   prospecte l'ensemble des OF du site

WCRITERE=""
If LWSTD<>""
   WCRITERE-= "& [F:MFO1]EXTWST >= '"+LWSTD+"'"
Endif
If LWSTF<>""
   WCRITERE-= "& [F:MFO1]EXTWST <= '"+LWSTF+"'"
Endif
If WCRITERE="" : WCRITERE="1=1"
Else           : WCRITERE=right$(WCRITERE,4)
Endif

Link [MFO1] With [MFG1]MFG0=[F:MFO1]MFGNUM As [MFX]

For [MFX]MFO0(1) Where [F:MFG1]MFGFCY = [L]LMFGFCY
&                    & [F:MFG1]MFGSTA < 3
&                    & [F:MFG1]SCDFLG > 1
&                    & find([F:MFO1]OPESTA,5,6)=0
&                    & evalue(WCRITERE)

    Trbegin ADOVAL

    WSCDFLG= [F:MFG1]SCDFLG

    # Issue X3-26728 - 2017-03-15 by CCC : If WO is optimized or being optimized => don't reschedule + warning message
    ## llc 11.02 16478
    #If (LJAL = 1 | ([F:MFG1]SCDFLG = 4 & find(LJAL,2,3)))        # llc 11.03 19214
    If LJAL = 1
&    | find(LJAL,2,3) & ([F:MFG1]SCDFLG = 4 | func AFNC.ACTIV("POPS") & [F:MFG1]OPTFLG=2)

        If find(LJAL,2,3)   # The message will be displayed only if rescheduling has been required but the WO is being optimized
            WMESS   = mess(156,197,1)-tolower(mess([F:MFG1]MFGSTA,317,1))-[F:MFG1]MFGNUM-":"-tolower(mess(122,193,1))
            Call ECR_TRACE(WMESS,-1) From GESECRAN
        Endif

        # Issue 84411 GA 10/2012
        If (LWSTD <> "" | LWSTF <> "")
          # déchargement workload
          Call WORKUNLOAD(LMFGFCY, [F:MFG1]MFGNUM, [F:MFG1]SCDFLG) From JALLIBB
        Endif

        #--------- 10.08 48569
        # PE pour intervenir sur les données de l'OF avant recalcul de la charge
        GPOINT = "CUSRELOAD"
        Gosub  ENTREE From EXEFNC
        #---------

        # chargement workload
        Call WORKLOAD(LMFGFCY, [F:MFG1]MFGNUM, [F:MFG1]SCDFLG) From JALLIBB

        #    trace
        # Ordre de fabrication ferme/planifié MFGNUM : charge réactualisée
        WMESS   = mess(156,197,1)-tolower(mess([F:MFG1]MFGSTA,317,1))-[F:MFG1]MFGNUM-":"-tolower(mess(485,197,1))
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Else

        Raz [M:JALK]                          # raz sinon CODRET peut rester actif
        #     déjalonnement
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = LMFGFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:MFG1]MFGNUM
        [M:JALK]MFGSTA = [F:MFG1]MFGSTA
        [M:JALK]CODMAJ = 3
        Call DEJALONNE From JALLIBA
        If [M:JALK]CODRET <> 0
            WMESS   = [F:MFG1]MFGNUM-"-"
            Gosub AB_JALFCY
            Goto NJAL2
        Endif

        # schedule each WO
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = LMFGFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:MFG1]MFGNUM
        [M:JALK]MFGSTA = [F:MFG1]MFGSTA
        [M:JALK]CODMAJ = 3
        [M:JALK]JAVFLG = WJAVFLG
        Call JALONNE From JALLIB
        # Issue 111414 - 2016-01-22 by CCC : change management of errors
        Case [M:JALK]CODRET
            When 0 :#    trace
                    # Work order firm/planned MFGNUM : reschedule
                    WMESS   = mess(156,197,1)-tolower(mess([F:MFG1]MFGSTA,317,1))-[F:MFG1]MFGNUM-":"-mess(346,197,1)
                    Call ECR_TRACE(WMESS,0) From GESECRAN
            When 2 : # message has been logged by scheduling process
            When Default :
                    WMESS   = [F:MFG1]MFGNUM-"-"
                    Gosub AB_JALFCY
                    Goto NJAL2
        Endcase

    Endif

    Commit
$NJAL2
Next


#   Schedule suggested WO for the site
If clalev([F:OPS1])  = 0 : Local File OPERATIONS [OPS1]  : Endif
If clalev([F:SCH1])  = 0 : Local File SCHEDULING [SCH1]  : Endif

WCRITERE=""
If LWSTD<>""
   WCRITERE-= "& [F:OPS1]EXTWST >= '"+LWSTD+"'"
Endif
If LWSTF<>""
   WCRITERE-= "& [F:OPS1]EXTWST <= '"+LWSTF+"'"
Endif
If WCRITERE="" : WCRITERE="1=1"
Else           : WCRITERE=right$(WCRITERE,4)
Endif

Link [OPS1]  With [SCH1]SCH0=[F:OPS1]MFGNUM;[F:OPS1]OPENUM;[F:OPS1]OPESPLNUM As [OPX]

For [OPX]OPS1(1) Where [F:OPS1]MFGFCY = [L]LMFGFCY
&                    & [F:OPS1]OPSSTA = 3
&                    & [F:SCH1]OPESTRDAT <> [0/0/0]
&                    & evalue(WCRITERE)

    Trbegin ADOVAL

    # llc 11.02 16478
    For [ORD]ORD3 Where STOFCY = LMFGFCY & VCRTYP = 11 & VCRNUM = [F:OPS1]MFGNUM & WIPTYP = 5 & WIPSTA = 3
        Break
    Next
    If [F:ORD]OPTFLG = 2 : WSCDFLG = 4 : Else : WSCDFLG = 2 : Endif

    If (LJAL = 1 | (WSCDFLG = 4 & find(LJAL,2,3)))            # llc 11.03 19214

        If (LWSTD <> "" | LWSTF <> "")
            # déchargement workload
            Call WORKUNLOADS(LMFGFCY, [F:OPS1]MFGNUM, WSCDFLG) From JALLIBB
        Endif

        # chargement workload
        Call WORKLOADS(LMFGFCY, [F:OPS1]MFGNUM, WSCDFLG) From JALLIBB

        #    trace
        # Ordre de fabrication suggéré MFGNUM : charge réactualisée
        WMESS   = mess(156,197,1)-tolower(mess(3,317,1))-[F:OPS1]MFGNUM-":"-tolower(mess(485,197,1))
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Else

        Raz [M:JALK]                          # raz sinon CODRET peut rester actif
        #     déjalonne chaque suggestion
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = LMFGFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:OPS1]MFGNUM
        [M:JALK]MFGSTA = [F:OPS1]OPSSTA
        If LWSTD = "" & LWSTF = ""
            [M:JALK]CODMAJ = 1
        Else
            [M:JALK]CODMAJ = 3
        Endif
        Call DEJALONNE From JALLIBA
        If [M:JALK]CODRET <> 0
            WMESS   = [F:OPS1]MFGNUM-"-"
            Gosub AB_JALFCY
            Goto NJAL3
        Endif

        #     jalonne chaque OF
        [M:JALK]CODORI = 1
        [M:JALK]MFGFCY = LMFGFCY
        [M:JALK]CODTRS = 0
        [M:JALK]MFGNUM = [F:OPS1]MFGNUM
        [M:JALK]MFGSTA = 3
        [M:JALK]CODMAJ = 3
        [M:JALK]JAVFLG = WJAVFLG
        Call JALONNE From JALLIB
        # Issue 111414 - 2016-01-22 by CCC : change management of errors
        Case [M:JALK]CODRET
            When 0 :#    trace
                    # Work order suggested MFGNUM : reschedule
                    WMESS   = mess(156,197,1)-tolower(mess([F:OPS1]OPSSTA,317,1))-[F:OPS1]MFGNUM-":"-mess(346,197,1)
                    Call ECR_TRACE(WMESS,0) From GESECRAN
            When 2 : # message has been logged by scheduling process
            When Default :
                    WMESS   = [F:OPS1]MFGNUM-"-"
                    Gosub AB_JALFCY
                    Goto NJAL3
        Endcase
    Endif

    Commit
$NJAL3
Next

#
End

############################################################
# Saisie des paramètres en batch
#   OPT : 1 = IWL, 2 = JOF, 3 = JOFS
#
Subprog SAI_BATCH(OK,OPT)
Variable Integer OK
Value    Integer OPT
#
Local Integer REPONSE
Local Integer WBOU(1..GNBBOU)
Local Integer SAVGOBJET
#
Local Dlgbox Mask [IWL4]
&   Button mess(64,123,1),mess(65,123,1)
&   With   left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
&   Coded GSTAOK , GSTAFIN
&   Titled mess(OPT,378,1)
&   As [IWL4]
#
SAVGOBJET = GOBJET
Call SAVBOUT From GESECRAN
GOBJET = 0
#
Boxact [IWL4]
[M:IWL4]PRO = OPT
Affzo  [IWL4]
Grizo  [IWL4]PRO
WBOU(GVALI) = 1
WBOU(GABAN) = 1
Call SETBOUT(WBOU) From GESECRAN
Boxinp [IWL4] Using REPONSE
Case REPONSE
  When GSTAOK  , GSTARET :
    OK = 2
  When GSTAESC , GSTAFIN :
    OK = 1
  When Default :
    OK = 1
Endcase
Boxclr [IWL4]
Call RESTBOUT From GESECRAN
GOBJET = SAVGOBJET
End

#########################################################################
#
# Enregistrement verrouillé :
#   rollback
#   écriture d'un message
#
$ROLL_JALLIBD
#
If !GSERVEUR
   GOK=0 : Call RSTA(WTAB,WCLE) From GLOCK
Endif
Rollback
End

#########################################################################
#
# fin anormale :
#   rollback
#   écriture d'un message
#
$AB_JALFCY
Rollback
WMESS -= mess(17,107,1) : # Abandon suite à erreur dans la transaction
Call ECR_TRACE(WMESS,1) From GESECRAN
Return

$AB_JALLIBD
#
If !GSERVEUR
    GOK=0 : Call RSTA(WTAB,WCLE) From GLOCK
Endif
Rollback
End

