End

$AMM_POT
Call AM_POT(zc)
If !mkstat & GOBJET
 zoncou = "POT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_POT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_POT(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "POT" : GZNUM = 22321 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZPOT)")>indice
 [M]POT(indice) = VALEUR
 Affzo ZPOT(indice)
Endif
Gosub _AFF
End

Subprog S_POT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOT"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_POT" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOT","SUBPOT","") From GACTION
 ACTION = "BS_POT" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_POT(VALEUR)
Variable Char    VALEUR()
Call OBJET("POT",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog B2_POT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B2_POT(VALEUR) From SUBCTR
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_POT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POT"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_POT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

