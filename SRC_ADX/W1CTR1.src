Subprog C_PERCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PERCOD" : GZNUM = 19019 : Endif
If !mkstat
 ## Action STD
 Call C_PERCOD(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "PERCOD" : GZNUM = 19019 : Endif
 If !mkstat
  ## Action CONTHRPEO
  Call CONTHRPEO(VALEUR) From SUBHRPEO
  If mkstat : GERR = 1 : GZONE = "PERCOD" : GZNUM = 19019 : Endif
 Endif
Endif
Gosub _AFF
End

