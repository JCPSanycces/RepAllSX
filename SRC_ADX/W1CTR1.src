End

Subprog AS_DNATYPMOD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10810) From COMBOS
## Action STD
Call AS_DNATYPMOD(VALEUR) From SUBCTR
If mkstat=2
 [M]DNATYPMOD(INDIC) = VALEUR
 Affzo DNATYPMOD(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10810,1))))
Endif
If !mkstat
 Discombo 0 From DNATYPMOD(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From DNATYPMOD(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_DNATYPMOD(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
## Action STD
Call C_DNATYPMOD(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "DNATYPMOD" : GZNUM = 48814 : Endif
Gosub _AFF
End

