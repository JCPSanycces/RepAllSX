#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:40"
A_USER  = "DOC"
A_STAMP = "20181109230340"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR1 [CTR1]
Gosub HORODAT
Local Inpbox "CTR1" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR1] As [SIM_]
Grizo [CTR1]10
Grizo [CTR1]20
Grizo [CTR1]30
Grizo [CTR1]40
Grizo [CTR1]50
Grizo [CTR1]60
Grizo [CTR1]70
Grizo [CTR1]80
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=61 : Y1(0)=1 : Y2(0)=10
X1(1)=1 : X2(1)=61 : Y1(1)=11 : Y2(1)=25
X1(2)=62 : X2(2)=123 : Y1(2)=1 : Y2(2)=5
X1(3)=124 : X2(3)=145 : Y1(3)=1 : Y2(3)=5
X1(4)=62 : X2(4)=145 : Y1(4)=6 : Y2(4)=10
X1(5)=62 : X2(5)=145 : Y1(5)=11 : Y2(5)=19
X1(6)=62 : X2(6)=145 : Y1(6)=20 : Y2(6)=25
X1(7)=1 : X2(7)=0 : Y1(7)=26 : Y2(7)=26
Return

$ON_SUICAR
Onevent INIT_AREA Call D_SUICAR(zc) From W1CTR1
Onevent BEFORE_INPUT Call AS_SUICAR(zc) From W1CTR1
Return

Subprog D_SUICAR(VALEUR)
Variable Integer VALEUR
If varinit([M]SUICAR,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_SUICAR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CLLCVT
Onevent BEFORE_INPUT Call AS_CLLCVT(zc) From W1CTR1
Onevent CONTROL Call C_CLLCVT(zc) From W1CTR1
Onevent AFTER_CHANGE Gosub AMM_CLLCVT From W1CTR1
Return

Subprog AS_CLLCVT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44763,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRCLV
Call DEFHRCLV(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLV
If mkstat=2
 [M]CLLCVT(INDIC) = VALEUR
 Affzo CLLCVT(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_CLLCVT(VALEUR) From SUBCTR
 If mkstat=2
  [M]CLLCVT(INDIC) = VALEUR
  Affzo CLLCVT(INDIC) : mkstat = 2
 Endif
 Onkey 129 Titled GBOUT1 Call B1_CLLCVT(zc) From W1CTR1
 Onkey   2 Titled GBOUTS Call S_CLLCVT(zc) From W1CTR1
 Onkey 144 Titled GBOUTP Call P_CLLCVT(zc) From W1CTR1
 Onkey 146 Titled GBOUTA Call SA_CLLCVT(zc) From W1CTR1
Endif
Gosub _AFF
End

Subprog C_CLLCVT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 47302 : Endif
If !mkstat
 ## Action CONTHRCLV
 Call CONTHRCLV(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLV
 If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 47302 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CLLCVT" : GZNUM = 47302 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CLLCVT
Call AM_CLLCVT(zc)
If !mkstat & GOBJET
 zoncou = "CLLCVT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CLLCVT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCLLCVT)")>indice
 [M]CLLCVT(indice) = VALEUR
 Affzo ZCLLCVT(indice)
Endif
Gosub _AFF
End

Subprog S_CLLCVT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCLV
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCLV"
 PARMSK(1) = GCURLEG
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCLV","SUBHRCLV","SPEHRCLV") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CLLCVT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRCLV
 Call TUNHRCLV(VALEUR,GCURLEG,GSOCIETE) From SUBHRCLV
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CLLCVT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCLV"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CLLCVT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCLV",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCLLCVT
Onevent BEFORE_AREA Gosub AV_ZCLLCVT From W1CTR1
Return

$AV_ZCLLCVT
Call LECTEXTRA(zc,"HRCLLCVT","DESAXX",num$([M]CLLCVT(indice)),"") From ATEXTRA
Gosub _AFF
Return

