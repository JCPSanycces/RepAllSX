Call CONTPLN(VALEUR) From SUBPLN
If mkstat : GERR = 1 : GZONE = "PLNTYP" : GZNUM = 46606 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "PLNTYP" : GZNUM = 46606 : Endif
 If !mkstat
  ## Action STD
  Call C_PLNTYP(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "PLNTYP" : GZNUM = 46606 : Endif
 Endif
Endif
Gosub _AFF
End

