#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque CFGWIN
############################################################
Subprog C_BLONBR(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]BLOMIN | VALEUR > [M]BLOMAX
  mkstat = 2
Endif
End
############################################################
Subprog C_LINNBR(VALEUR)
Variable Decimal VALEUR
# V6 GA 12/2007 pas de test si TYPBLOC=5 (Invisible)
#If [M]BLONBR(nolign-1) = 1 | [M]BLONBR(nolign-1) = 2
If [M]BLONBR(nolign-1) > 0 &  [M]TYPBLOC([M]BLONBR(nolign-1)-1)=5
  If VALEUR < [M]LINMIN([M]BLONBR(nolign-1)-1) | VALEUR > [M]LINMAX([M]BLONBR(nolign-1)-1)
    mkstat = 2
  Endif
Else
  If VALEUR < 1 | VALEUR > 99
    mkstat = 2
  Endif
Endif
End
############################################################
Subprog AS_INTBLO(VALEUR)
Variable Char    VALEUR()
If VALEUR = mess(149,188,1)
  mkstat = 2
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CFGWIN) 27/09/2007 15:29:07 (GA)
######################################################################################
Subprog C_LINMIN(VALEUR)
Variable Decimal VALEUR
  If VALEUR < 1 | VALEUR > [M]LINMAX(nolign-1)
    mkstat = 2
  Endif
End

Subprog C_LINMAX(VALEUR)
Variable Decimal VALEUR
# V6 GA 12/2007 si TYPBLOC=5 (Invisible)
# If nolign=3 : # Bloc 3
  If [M]TYPBLOC(nolign-1)=5
    VALEUR = 99
  Elsif VALEUR < [M]LINMIN(nolign-1) | VALEUR > 20
    mkstat = 2
  Endif
End

Subprog AS_TYPBLOC(VALEUR)
Variable Integer VALEUR
Local Integer I
# 2 valeurs possibles dans Menu 38:
For I=1 To 11 GMENLOC(I)=1 : Next
GMENLOC(2)=0                       # Liste
GMENLOC(9)=0                       # Bloc HTML Issue 96434 GA 03/2014
If nolign>1 : GMENLOC(5)=0 : Endif # Invisible
End

Subprog AM_TYPBLOC(VALEUR)
Variable Integer VALEUR
 If VALEUR=5             : # Bloc invisible: LINMIN,LINMAX,LNGLIB non saisissables
    [M]LINMIN(nolign-1)=1
    [M]LINMAX(nolign-1)=99
    [M]LNGLIB(nolign-1)=0
 Else
    [M]LINMIN(nolign-1)=1
    [M]LINMAX(nolign-1)=10
    [M]LNGLIB(nolign-1)=18
 Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CFGWIN) 03/12/2007 14:02:54 (GA)
######################################################################################
Subprog C_NBRCOL(VALEUR)
Variable Decimal VALEUR
If VALEUR < 30
   VALEUR = 30
Elsif VALEUR > 150
   VALEUR = 150
Endif
End

