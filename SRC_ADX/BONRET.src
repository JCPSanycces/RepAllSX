#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
# BONRET : Impression du bon de retour fournisseur                      #
# --------------------------------------------------------------------- #
# Chargement des paramﾃｨtres et mise ﾃ jour de l'indicateur d'impression #
#########################################################################

$ACTION
Case ACTION
  When "CONTPRT" : Gosub CONTPRT
Endcase
Return

#########################################################################

#-----------------------------------------#
# Contrﾃｴle destination (choix imprimante) #
# --------------------------------------- #
#  Prﾃｩchargement du nombre de copies      #
#  Par dﾃｩfaut provient des destinations   #
#-----------------------------------------#
$CONTPRT
#------ Prﾃｩchargement si contexte gestion de retours fournisseur -----#
If GFONCTION="GESPNH" & clalev([M:PNH1])
  If !find([M:RPT]IMPRIME,1,3,4)
  #sr 08.11 Demande 74804-uniquement s'il y a un modﾃｨle d'impression sur le tiers
    If [F:BPS]TPMCOD<>""
     [M:RPT]NBRCPY=max([M:PNH1]COPNBR,1) : # Nombre de copies
    Endif
  Else
    [M:RPT]NBRCPY=0 : # pas de copie pour prﾃｩvisu, message, fichier
    Grizo [M:RPT]NBRCPY : Affzo [M:RPT]NBRCPY #Fq73266
  Endif
Endif
#-----
Return

#########################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
#-----
Call EXEC(NBPAR,PARAMETRE)
#-----
End

#########################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
# -- BONRET2
Local Date    DATREF
#RMA * 11-07-2012 * 75916 - multicopy priting
Local Char MULCOPPAR(1)
#-----
Gosub OUVRE   : # ouverture des tables
If GERREUR  GERREUR=0 : End : Endif
#-----
Gosub DECLARE : # Dﾃｩclaration des variables globales
#-----
[L]CRITERE = "1=1"
# -- BONRET2
[L]CRITERE2 = "1=1"

#-----
For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"           : [L]ETAT     = [L]VALEUR
      When "__REQUETE"       : [L]NUMREQ   = val([L]VALEUR)
      When "sitedeb"         : [L]CRITERE -= "& PNHFCY>='"+[L]VALEUR+"'"
      When "sitefin"         : [L]CRITERE -= "& PNHFCY<='"+[L]VALEUR+"'"
      When "fournisseurdeb"  : [L]CRITERE -= "& BPSNUM>='"+[L]VALEUR+"'"
      When "fournisseurfin"  : [L]CRITERE -= "& BPSNUM<='"+[L]VALEUR+"'"
      When "retourdeb"       : [L]CRITERE -= "& PNHNUM>='"+[L]VALEUR+"'"
      When "retourfin"       : [L]CRITERE -= "& PNHNUM<='"+[L]VALEUR+"'"
      When "codimp"          : [L]CRITERE -= "& PRNFLG="+num$([L]VALEUR)
                               [L]IMPR     = val([L]VALEUR)
# -- BONRET2
      When "datedeb"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                             val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                               [L]CRITERE2 -= "& RTNDAT >=["+format$(GFMD,[L]DATREF)+']'
      When "datefin"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                             val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                               [L]CRITERE2 -= "& RTNDAT <=["+format$(GFMD,[L]DATREF)+']'
      When "comptadeb"       : [L]CRITERE2 -= "& PSTFLG >="+num$(val([L]VALEUR)+1)
      When "comptafin"       : [L]CRITERE2 -= "& PSTFLG <="+num$(val([L]VALEUR)+1)
# -- Bug 65141
#     When "valdeb"          : [L]CRITERE2 -= "& CFMFLG >="+num$(val([L]VALEUR)+1)
#     When "valfin"          : [L]CRITERE2 -= "& CFMFLG <="+num$(val([L]VALEUR)+1)

      When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
    Endcase
  Endif
Next
# Issue 89114 - 2013-04-04 by SR : etat enchaine
Look [ARM]ARM0 = [L]NUMREQ;GUSER;[F:ARP]RPTCOD;1
If !fstat
  # Enreg trouvﾃｩ, car lancement enchainﾃｩ
  # On bloque la boucle
  End
  #On laisse GOK=1 sinon l'ﾃｩtat ne sort pas
Endif

#-----
[L]CRITERE -= "& CFMFLG=2"
Filter [PNH] Where evalue([L]CRITERE) & evalue([L]CRITERE2)
Gosub TRT_PNH
End

##########################################################################

$TRT_PNH
Raz WNUMLIG, WNUMCOP
Default File [PNH]
For [PNH] PNH0
  Call DEBTRANS From GLOCK
  Raz WNUMCOP
  If [L]IMPR=1
    Gosub TR1
  Else
    Gosub TR2
  Endif
Next
Return

##########################################################################

$TR1
Trbegin [PNH] , [ARM], [TPRPT]
#----- Mise ﾃ jour table entﾃｪte retour si demande d'impression -----#
If [L]IMPR = 1
 Readlock [PNH] PNH0 Curr
 If fstat = 1 : GOK = -1 : GLOCK = "$PRETURN" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("PNH","*") From GLOCK : Goto AB_TR1
 Endif
 [F:PNH]PRNFLG = 2
 Rewrite [PNH]
 If fstat=1
  GOK=-1 : GLOCK="$PRETURN"-[F:PNH]PNHNUM
  Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("PRETURN",[F:PNH]PNHNUM) From GLOCK : Goto AB_TR1
 Endif
Endif
#----- Crﾃｩation d'un enregistrement dans la table AREPORTM -----#

#RMA * 75916
Call PARAM ([F:PNH]CPY,"MULCOPRINT",MULCOPPAR) From ADOVAL
Local Integer INBCOP
For INBCOP=1 To max(1,[M:RPT]NBRCPY)
  If MULCOPPAR="2" : WNUMCOP += 1 : Endif #RMA * 75916
  WNUMLIG += 1
  Raz [F:ARM]
  [F:ARM]USR    = GUSER
  [F:ARM]RPTCOD = [F:ARP]RPTCOD
  [F:ARM]NUMREQ = [L]NUMREQ
  [F:ARM]NUMLIG = WNUMLIG
  [F:ARM]NUMCOP = WNUMCOP
  [F:ARM]CLEA1  = [F:PNH]PNHNUM
  [F:ARM]CREDAT = date$
  Write [F:ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
Next INBCOP
#-----
# Issue 110704 - RFS
If func AFNC.ACTIV("KPO")
 Gosub ALIM_TMPPRPT
 If GOK = 0 : Goto AB_TR1 : Endif
Endif
# End issue 110704
Commit
Return

$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

#########################

$TR2
Trbegin [ARM], [TPRPT]
#----- Crﾃｩation d'un enregistrement dans la table AREPORTM -----#

#RMA * 75916
Call PARAM ([F:PNH]CPY,"MULCOPRINT",MULCOPPAR) From ADOVAL

Local Integer INBCOP, LNBCOP
If MULCOPPAR="2"
 LNBCOP=max(1,[M:RPT]NBRCPY,[F:PNH]COPNBR)
Else
 LNBCOP=max(1,[M:RPT]NBRCPY)
Endif

For INBCOP=1 To LNBCOP
  WNUMLIG += 1
  If MULCOPPAR="2" : WNUMCOP += 1 : Endif #RMA * 75916
  Raz [F:ARM]
  [F:ARM]USR    = GUSER
  [F:ARM]RPTCOD = [F:ARP]RPTCOD
  [F:ARM]NUMREQ = [L]NUMREQ
  [F:ARM]NUMLIG = WNUMLIG
  [F:ARM]NUMCOP = WNUMCOP
  [F:ARM]CLEA1  = [F:PNH]PNHNUM
  [F:ARM]CREDAT = date$
  Write [F:ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
Next INBCOP
#-----
# Issue 110704 - RFS
If func AFNC.ACTIV("KPO")
 Gosub ALIM_TMPPRPT
 If GOK = 0 : Goto AB_TR2 : Endif
Endif
# End issue 110704
Commit
Return

$ROLL_TR2
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback

Return
###########################################################################
$OUVRE

Local File PRETURN [PNH], AREPORTM [ARM]
# BRBAN 25/11/2014 - 97101
Local File TMPPRPT    [TPRPT]

Return
#########################################################################
$DECLARE

Local Char    CRITERE(255), CRITERE2(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP)
Local Integer WNUMLIG, WNUMCOP, NUMREQ, IMPR, I, J

Return
#########################################################################
$ALIM_TMPPRPT

Raz [F:TPRPT]

[F:TPRPT] = [F:ARM]
[F:TPRPT]VCRNUM = [F:PNH]PNHNUM

Write [F:TPRPT]
If fstat : GOK=0 : Call FSTA("TPRPT") From GLOCK : Endif

Return
#########################################################################

