#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du fichier ADAPIDOC
Call OBJET("ADD",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When default
Endcase
Return

Subprog CONTADP(CHAINE)
Variable Char CHAINE()
Local Integer K
CHAINE = vireblc(ctrans(CHAINE),2)
CHAINE = toupper(left$(CHAINE,1))+right$(CHAINE,2)
Repeat
 K = instr(1,CHAINE," ")
 If K
  CHAINE = left$(CHAINE,K-1)+toupper(mid$(CHAINE,K+1,1))+right$(CHAINE,K+2)
 Endif
Until K=0
End
