$PE_BEFREWITF
  GPE=0 : GPOINT = "BEFREWITF" : Gosub ENTREE From EXEFNC
Return
############################################################
$PE_BEFREWITV
  GPE=0 : GPOINT = "BEFREWITV" : Gosub ENTREE From EXEFNC
Return
############################################################
$PE_BEFREWITU
  GPE=0 : GPOINT = "BEFREWITU" : Gosub ENTREE From EXEFNC
Return
############################################################
$PE_BEFREWITP
  GPE=0 : GPOINT = "BEFREWITP" : Gosub ENTREE From EXEFNC
Return

# Issue 113260 - 2016-07-11 by STLIG : New subroutine...
######################################################################################
# Subroutine: APPLY_SYMBOLS
#             Reset/populate S_MODITM Product, BOM and Route classes and APPLY_SYMBOLS
#
$APPLY_SYMBOLS

  # Reset/populate S_MODITM Product, BOM and Route classes
  Gosub MEI_BUFFERS From CFGLIBB

  # APPLY_SYMBOLS
  For [M:CFP]PILIND=0 To [M:CFP]NBLIG-1
    If ([M:CFP]PILPHA([M:CFP]PILIND)>2)
      Break
    Endif
    If (!(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8)))
      Gosub TRT_SYMBOLE From CFGLIBC1
      If (GOK<>1 | S_ABORT | W_MSG<>"")
        Break
      Endif
    Endif
  Next [M:CFP]PILIND

Return

