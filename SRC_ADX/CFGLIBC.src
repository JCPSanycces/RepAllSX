###      Filter [ROO]
###      If GOK <> 1
###        Goto MAJ_TEXTES_FIN
###      Endif
###    Endif
###   When 1
###     GLOCK="$ROH"-[F:ITM]ITMREF-num$([F:CSC]ROUALT) : GOK=-1
###     Goto MAJ_TEXTES_FIN
###  Endcase
###Endif
$MAJ_TEXTES_FIN
Return
############################################################
# Effacement des donnees generees
$DEL_CONFIG
If S_CPTCFG = ""
  Return
Endif
Gosub CTL_PARAM_CSC From CFGLIBC1
W_TRAMSG=mess(192,188,1)-"($DEL_CONFIG)" : Gosub TRA_MSG From CFGLIBB     # suivi
Call TEMPON(mess(192,188,1)) From GESECRAN
Call DEBTRANS From GLOCK
$DEL_CONFIG1
Trbegin [ITM]
GOK = 1
# Point d'entree annulation configuration
GPOINT = "DELCONFIG"
Gosub ENTREE From EXEFNC
# Recuperation numero de configuration perdu si possible
W_ALP = ""
Call NUMERO_PREC(GCFG,S_FCY,S_IPTDAT,"",W_ALP,W_I,S_RETURN) From SUBANM
If S_RETURN = 0
  Case [F:ANM]SEQ
  When 1    # Compteur normal
    If  W_ALP = S_CPTCFG    # Pas d'autre config entre temps
      Readlock [AVN] Curr
      If fstat = 0
        [F:AVN]VALEUR -= 1
        Rewrite [AVN]
        If fstat
            GOK=0 : Call FSTACTX("AVA",W_TRASTP,"$DEL_CONFIG1") From CFGLIBD
        Endif
      Endif
    Endif
  When 3    # Compteur groupé
     Read [F:AVA]AVA0=[F:AVA1]CODNUM;[F:AVA1]SITE;[F:AVA1]PERIODE;[F:AVA1]COMP;[F:AVA1]VALEUR
     If fstat       # Protection: DEL_CONFIG peut être appelé suite à l'action FIN et
                     #   après une anomalie grave de la première étape de Validation (aucune création)
         [F:AVA] = [F:AVA1]
         Write [AVA]        # Restauration de l'enregistrement
         If fstat
            GOK=0 : Call FSTACTX("AVA",W_TRASTP,"$DEL_CONFIG1") From CFGLIBD
         Endif
     Endif
  Endcase
Endif
# Effacement articles crées et leurs nomenclatures et gammes associées
If GOK = 1
    # CCC (23/03/07) Bug 40422
    W_ITM = "" #[F:ITM1]ITMREF
    Gosub DEL_ARTICLE
    #If GOK =1  # Issue GA 98703 05/2014 déplacé dans DEL_ARTICLE, avant suppression article
    #    Gosub DEL_NOMENCL
    #    If GOK = 1
    #        Gosub DEL_GAMME
    #    Endif
    #Endif
Endif
#
If GOK = 1
  Gosub DEL_HISTORIQUE
Endif
#
Case GOK
  When -1 :
    Rollback
    W_TRAMSG=mess(179,188,1)-GLOCK : Gosub TRA_MSG From CFGLIBB        # suivi
    Call ROLL From GLOCK
    If GROLL
        GMESSAGE=W_TRAMSG                     # info trace sur lock
        Gosub TRA_ERR From CFGLIBB
        GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
        GMESSAGE+="\"+mess(236,188,1)-S_CPTCFG : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentative par utilisateur
        If GSERVEUR=0 : Call ERREUR(mess(237,188,1)-S_CPTCFG) From GESECRAN : Endif
        GMESSAGE = mess(237,188,1)
        Gosub TRA_ERR From CFGLIBB
        GERR     = 1
    Else
      Goto DEL_CONFIG1
    Endif
  When 1 :
    Raz [M:CFW]  #$$$Ligne impactée par test du 28/11/03
    Commit
  When Default :
    Raz [M:CFW]  #$$$Ligne impactée par test du 28/11/03
    Rollback
Endcase
W_TRAMSG=mess(192,188,1)-"(return of $DEL_CONFIG)" : Gosub TRA_MSG From CFGLIBB     # suivi
Call TEMPOFF From GESECRAN
#
Return
############################################################
# Suppression [ITM] [ITF] [ITV] [ITS] [ITC] [ITU] [ITP]
$DEL_ARTICLE

# Effacement article - site
If W_ITM=""
    Filter [ITF] Where CFGVCRNUM = S_CPTCFG
&                Order By Key ITF0
Else
#&                    & CFGVCRNUM = S_CPTCFG
    Filter [ITF] Where ITMREF    = W_ITM
&                Order By Key ITF0
Endif
For [ITF]
  Readlock [ITF] Curr
  Case fstat
    When 1 :
      GLOCK="$ITMFACILIT"-[F:ITF]ITMREF-[ITF]STOFCY : GOK=-1
      Break
    When 0 :
      Delete [ITF]
      If fstat
        GOK = 0
        Call FSTACTX("ITF",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
        Break
      Endif
      If [F:ITF]ITMREF<>S_MODITM # Issue 85688 GA 01/2013 sauf si reprise de config
        # Issue 89095 GA 07/2013 code déplacé dans CFGLIBC1 et complété selon SUBCFH
          Gosub DEL_ITF_SUITE From CFGLIBC1
      Endif
   When Default :
      GOK = 0
      Call FSTACTX("ITF",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
      Break
  Endcase
Next
Filter [ITF]
If GOK <> 1 : Return : Endif
# Effacement cumuls stocks
If W_ITM=""
    Filter [ITV] Where CFGVCRNUM = S_CPTCFG
&                Order By Key ITV0
Else
#&                    & CFGVCRNUM = S_CPTCFG
    Filter [ITV] Where ITMREF    = W_ITM
&                Order By Key ITV0
Endif
For [ITV]
  Readlock [ITV] Curr
  Case fstat
    When 1 :
      GLOCK="$ITMMVT"-[F:ITV]ITMREF-[ITV]STOFCY : GOK=-1
      Break
    When 0 :
      #If [F:ITV]CFGVCRNUM = S_CPTCFG
        Delete [ITV]
        If fstat
          GOK = 0
          Call FSTACTX("ITV",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
          Break
        Endif
        If [F:ITV]ITMREF<>S_MODITM # Issue 104908 GA 12/2014 sauf si reprise de config
          # FQ 73403 GA 08/2011 spécial V6: table ITMMVTHIS ITH
          Delete [ITH] Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF
          # Issue 89095 GA 06/2013
          Call DEL_AXX_FIC("ITMMVT","[F:ITV]") From CFGLIBC1
        Endif
      #Endif
    When Default :
      GOK = 0
      Call FSTACTX("ITV",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
      Break
  Endcase
Next
Filter [ITV]
If GOK <> 1 : Return : Endif
# Effacement article coûts
# FQ 48688 GA 08/2008 pas nécessaire de parcourir les sites ...
#Filter [FCY1]
#For [FCY1]
#  If W_ITM=""
#    Filter [ITC] Where STOFCY    = [F:FCY1]FCY
#                    &  CFGVCRNUM = S_CPTCFG
#  Else
#    Filter [ITC] Where STOFCY    = [F:FCY1]FCY
#                    &  CFGVCRNUM = S_CPTCFG
# FQ 76371 GA 09/2011  suppression de &  UID       = 0
  If W_ITM=""
      Filter [ITC] Where CFGVCRNUM = S_CPTCFG
&                  Order By Key ITC0
  Else
# FQ 48688 GA 08/2008 find(CFGVCRNUM,S_CPTCFG,"") - FQ 49198 Modif raz 09/2008
# FQ 75812 GA 09/2011 suite 74773: il reste encore des [F:ITC] avec CFGVCRNUM=""
#      Filter [ITC] Where CFGVCRNUM = S_CPTCFG
#&                     &  ITMREF    = W_ITM
#&                     &  UID       = 0
#&                  Order By Key ITC0
# FQ 76371 GA 09/2011  suppression de &  UID = 0
      Filter [ITC] Where ITMREF   = W_ITM
&                  Order By Key ITC0
  Endif
  For [ITC]
    # Issue 78402 GA 04/2012 suppress only when ITF was deleted
    Read [ITF]ITF1=[F:ITC]STOFCY;[F:ITC]ITMREF
    If !fstat Goto NEXT_ITC Endif

    # Issue 103969 GA 11/2014
    Gosub DEL_ITC_SUITE From CFGLIBC1
    If GOK<0 Break Endif  # Issue 104665

    # Coût
    Readlock [ITC] Curr
    Case fstat
      When 1 :
GLOCK="$ITMCOST"-[F:ITC]STOFCY+"~"+[F:ITC]ITMREF+"~"+num$([F:ITC]CSTTYP)+"~"+num$([F:ITC]ITCSEQ)
GOK=-1
        Break # Issue 104665 before: Break 2
      When 0 :
        Delete [ITC]
        If fstat
          GOK = 0
          Call FSTACTX("ITC",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
          Break # Issue 104665 before: Break 2
        Endif
      When Default :
        GOK = 0
        Call FSTACTX("ITC",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
        Break # Issue 104665 before: Break 2
    Endcase
$NEXT_ITC # Issue 78402 GA 04/2012
  Next
  Filter [ITC]
#Next
#Filter [FCY1]
#If GOK <> 1 : Return : Endif

# Effacement article vente
If W_ITM=""
    Filter [ITS] Where CFGVCRNUM = S_CPTCFG
&                Order By Key ITS0
Else
#&                    & CFGVCRNUM = S_CPTCFG
    Filter [ITS] Where ITMREF = W_ITM
&                Order By Key ITS0
Endif
For [ITS]
    Readlock [ITS] Curr
    Case fstat
      When 1 :
        GLOCK="$ITMSALES"-[F:ITS]ITMREF : GOK=-1
        Break   # FQ 69909 Ctrl des sources
      When 0 :
        #If [F:ITS]CFGVCRNUM = S_CPTCFG
          Delete [ITS]
          If fstat
            GOK = 0
            Call FSTACTX("ITS",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
            Break   # FQ 69909 Ctrl des sources
          Endif
          # Issue 89095 GA 06/2013
          Call DEL_AXX_FIC("ITMSALES","[F:ITS]") From CFGLIBC1
        #Endif
      When 4,5 :
      When Default :
        GOK = 0
        Call FSTACTX("ITS",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
        Break   # FQ 69909 Ctrl des sources
    Endcase
Next
Filter [ITS]

# Issue 86230 GA 12/2012 multi-clients: en pas filtrer sur S_BPRNUM
#&                    & BPCNUM = S_BPRNUM
# Effacement article client
If W_ITM=""
    Filter [ITU] Where CFGVCRNUM = S_CPTCFG
&                Order By Key ITU0
Else
#&                    & CFGVCRNUM = S_CPTCFG
    Filter [ITU] Where ITMREF = W_ITM
&                Order By Key ITU0
Endif
Local Shortint WITU : WITU=0 # Issue 86230 GA 02/2013 sauvegarde des références article-client
Raz S_MODBPCNUM, S_MODITMREFBPC, S_MODITMDESBPC
For [ITU]
    Readlock [ITU] Curr
    Case fstat
      When 1 :
        GLOCK="$ITMBPC"-[F:ITU]ITMREF-S_BPRNUM : GOK=-1
        Break   # FQ 69909 Ctrl des sources
      When 0 :
        #If [F:ITU]CFGVCRNUM = S_CPTCFG
          # Issue 86230 GA 02/2013 ajout S_MODBPSNUM,S_MODITMREFBPS
          If WITU<dim(S_MODBPCNUM)
            S_MODBPCNUM(WITU)    = [F:ITU]BPCNUM
            S_MODITMREFBPC(WITU) = [F:ITU]ITMREFBPC
            S_MODITMDESBPC(WITU) = [F:ITU]ITMDESBPC
            WITU+=1
          Endif
    Call ECR_DEBUG("Delete ITU="-[F:ITU]ITMREF-[F:ITU]BPCNUM-[F:ITU]ITMREFBPC) From CFGLIBC1
          Delete [ITU]
          If fstat
            GOK = 0
            Call FSTACTX("ITU",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
            Break   # FQ 69909 Ctrl des sources
          Endif
          # Issue 89095 GA 06/2013
          Call DEL_AXX_FIC("ITMBPC","[F:ITU]") From CFGLIBC1
        #Endif
      When 4,5 :
      When Default :
        GOK = 0
        Call FSTACTX("ITU",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
        Break   # FQ 69909 Ctrl des sources
    Endcase
Next
Filter [ITU]

#
# Issue 86230 GA 12/2012 multi-fournisseurs: en pas filtrer sur W_BPS
#&                    & BPSNUM = W_BPS
# Effacement article fournisseur
If W_ITM=""
    Filter [ITP] Where CFGVCRNUM = S_CPTCFG
&                Order By Key ITP0
Else
#&                    & CFGVCRNUM = S_CPTCFG
    Filter [ITP] Where ITMREF = W_ITM
&                Order By Key ITP0
Endif
Local Shortint WITP : WITP=0 # Issue 86230 GA 02/2013 sauvegarde des références article-fournisseur
Raz S_MODBPSNUM, S_MODITMREFBPS, S_MODITMDESBPS
For [ITP]
    Readlock [ITP] Curr
    Case fstat
      When 1 :
        GLOCK="$ITMBPS"-[F:ITP]ITMREF-W_BPS : GOK=-1
        Break   # FQ 69909 Ctrl des sources
      When 0 :
        #If [F:ITP]CFGVCRNUM = S_CPTCFG
          # Issue 86230 GA 02/2013 ajout S_MODBPSNUM,S_MODITMREFBPS
          If WITP<dim(S_MODBPSNUM)
            S_MODBPSNUM(WITP)    = [F:ITP]BPSNUM
            S_MODITMREFBPS(WITP) = [F:ITP]ITMREFBPS
            S_MODITMDESBPS(WITP) = [F:ITP]ITMDESBPS
            WITP+=1
          Endif
          #
    Call ECR_DEBUG("Delete ITP="-[F:ITP]ITMREF-[F:ITP]BPSNUM-[F:ITP]ITMREFBPS) From CFGLIBC1
          Delete [ITP]
          If fstat
            GOK = 0
            Call FSTACTX("ITP",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
            Break   # FQ 69909 Ctrl des sources
          Endif
          # Issue 89095 GA 06/2013
          Call DEL_AXX_FIC("ITMBPS","[F:ITP]") From CFGLIBC1
       # Endif
      When 4,5 :
      When Default :
        GOK = 0
        Call FSTACTX("ITP",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
        Break   # FQ 69909 Ctrl des sources
    Endcase
Next
Filter [ITP]


# Issue 98703 GA 05/2014 Suppression article en fin de traitement uniquement
If !GOK : Return : Endif
If W_ITM=""
    Filter [ITM] Where CFGVCRNUM = S_CPTCFG
&                Order By Key ITM0
Else
#&                    & CFGVCRNUM = S_CPTCFG
    Filter [ITM] Where ITMREF    = W_ITM
&                Order By Key ITM0
Endif
For [ITM]

    Call ECR_DEBUG("Delete ITM="-[F:ITM]ITMREF) From CFGLIBC1
    # Issue 98703 GA 05/2014 Suppression toutes nomenclatures/gammes avant suppression article
    W_ITM=[F:ITM]ITMREF
    # Issue 102652 GA 01/2015 don't loose existing BOM's those are not updated !
    If GOK & ([F:CSC]CMPFLG=2 | left$([F:ITM]ITMREF,1)="_" | GFONCTION="FUNCFGPUR")
      #Read [BOH]BOH0=S_MODITM;[F:CSC]BOMALT;[F:CSC]BOMALTTYP # Issue 89191 ajout BOMALTTYP
      #If fstat=0 & [F:BOH]CFGVCRNUM <> ""
      #   S_CPTCFG= [F:BOH]CFGVCRNUM         # FQ 43622 GA 11/2007 parfois différent de [F:ITM]CFGVCRNUM ?
      #Endif
      Gosub DEL_NOMENCL
    Endif
    # Issue 102652 GA 01/2015 don't loose existing ROU's those are not updated !
    If GOK & ([F:CSC]ROUFLG=2 | left$([F:ITM]ITMREF,1)="_" | GFONCTION="FUNCFGPUR")
      Gosub DEL_GAMME
    Endif

    # Issue 89095 GA 07/2013 code déplacé dans CFGLIBC1 et complété selon SUBCFH
    Gosub DEL_ITM_SUITE From CFGLIBC1

    # Issue 98703 GA 05/2014
    Gosub VERF_DELITM  From CFGLIBC1
    If GOK
      Readlock [ITM]ITM0=[F:ITM]ITMREF
      Case fstat
        When 1
          GLOCK="$ITMMASTER"-[F:ITM]ITMREF : GOK=-1
          Break   # FQ 69909 Ctrl des sources
        When 0 :
          #If [F:ITM]CFGVCRNUM = S_CPTCFG
            Delete [ITM]
            If fstat
              GOK = 0
              Call FSTACTX("ITM",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD
              Break   # FQ 69909 Ctrl des sources
            Endif
          #Endif
        When 4,5 :
        When Default :
          GOK = 0
          Call FSTACTX("ITM",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD
          Break   # FQ 69909 Ctrl des sources
      Endcase
    Endif
Next
Filter [ITM]

Return
############################################################
# Suppression [BOH] [BOD]
$DEL_NOMENCL
If W_ITM=""
# Issue 89191 GA 04/2013
#&                    & BOMALT = [F:CSC]BOMALT
#&                    & BOMALTTYP = [F:CSC]BOMALTTYP
    Filter [BOH] Where CFGVCRNUM = S_CPTCFG
&                Order By Key BOH0
Else
# Issue 89191 GA 04/2013
#&                    & BOMALT = [F:CSC]BOMALT
#&                    & BOMALTTYP = [F:CSC]BOMALTTYP
#&                    & CFGVCRNUM = S_CPTCFG
    Filter [BOH] Where ITMREF = W_ITM
&                Order By Key BOH0
Endif
For [BOH]
    Call ECR_DEBUG("Delete BOH="-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-num$([F:BOH]BOMALTTYP)) From CFGLIBC1
    Readlock [BOH] Curr
    Case fstat
      When 1 :
        GLOCK="$BOM"-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-num$([F:BOH]BOMALTTYP) : GOK=-1
        Break   # FQ 69909 Ctrl des sources
      When 0 :
        #If [F:BOH]CFGVCRNUM = S_CPTCFG
          Delete [BOH]
          If fstat
            GOK = 0
            Call FSTACTX("BOH",W_TRASTP,"$DEL_NOMENCL") From CFGLIBD  # From GLOCK
            Break   # FQ 69909 Ctrl des sources
          Endif
          # Issue 89095 GA 06/2013
          Call DEL_AXX_FIC("BOM","[F:BOH]") From CFGLIBC1
          # Recalcul code plus bas niveau compose
          # FQ 43622 avant [F:BOD]BOMALT
          Call LLCUPD([F:BOH]ITMREF,[F:BOH]BOMALT,[F:BOH]BOMALTTYP,"-") From LLCLIB
          # Effacement des liens [BOD]
          Filter [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALT = [F:BOH]BOMALT & BOMALTTYP = [F:BOH]BOMALTTYP
&                      Order By Key BOD0
          For [BOD] With Lock
           Call ECR_DEBUG("Delete BOD="-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-num$([F:BOH]BOMALTTYP)-[F:BOD]CPNITMREF) From CFGLIBC1
           Case fstat
              When 1 :
                GLOCK="$BOD"-[F:BOH]ITMREF-num$([F:BOH]BOMALT)-num$([F:BOD]BOMSEQ)-[F:BOD]CPNITMREF : GOK=-1
                Break   # FQ 69909 Ctrl des sources
              When 0 :
                Delete [BOD]
                If fstat
                  GOK = 0
                  Call FSTACTX("BOD",W_TRASTP,"$DEL_NOMENCL") From CFGLIBD  # From GLOCK
                  Break   # FQ 69909 Ctrl des sources
                Endif
                # Issue 89095 GA 06/2013
                Call DEL_AXX_FIC("BOMD","[F:BOD]") From CFGLIBC1
               # Recalcul code plus bas niveau composant
                Call LLCUPD([F:BOD]CPNITMREF,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,"-") From LLCLIB
              When Default :
                GOK = 0
                Call FSTACTX("BOD",W_TRASTP,"$DEL_NOMENCL") From CFGLIBD  # From GLOCK
                Break   # FQ 69909 Ctrl des sources
            Endcase
          Next
          Filter [BOD]
        #Endif

      # Article nomenclature
        Filter [ITB] Where ITMREF = [F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT Order By Key ITB0
        For [ITB]
          Readlock [ITB] Curr
          Case fstat
            When 1 :
              GOK = -1
              Break
            When 0 :
              Delete [ITB]
              If fstat
                GOK = 0
                Call FSTA("ITB") From GLOCK
                Break
              Endif
              Call ECR_DEBUG("Delete ITB="-[F:ITB]ITMREF) From CFGLIBC1
            When Default :
              GOK = 0
              Call FSTA("ITB") From GLOCK
              Break
          Endcase
        Next
        Filter [ITB]

    Endcase
    Filter [BOH]
Next
Return
############################################################
# Suppression [ROH] [ROO] [ROS]
$DEL_GAMME
# Issue 98703 GA 05/2014 purge quel que soit le paramétrage du scénario
#If [F:CSC]ROUFLG = 2
    If W_ITM=""
# Issue 89191 GA 04/2013
#&                        & FCY       = S_FCY
#&                        & ROUALT    = [F:CSC]ROUALT
        Filter [ROH] Where CFGVCRNUM = S_CPTCFG
&                    Order By Key ROH0
    Else
# Issue 89191 GA 04/2013
#&                        & FCY       = S_FCY
#&                        & ROUALT    = [F:CSC]ROUALT
#&                        & CFGVCRNUM = S_CPTCFG
        Filter [ROH] Where ITMREF    = W_ITM
&                    Order By Key ROH0
    Endif
    For [ROH]
      Readlock [ROH] Curr
      Case fstat
        When 1 :
          GLOCK="$ROUTING"-[F:ROH]ITMREF-num$([F:CSC]ROUALT) : GOK=-1
          Break   # FQ 69909 Ctrl des sources
        When 0 :
          #If [F:ROH]CFGVCRNUM = S_CPTCFG
            Delete [ROH]
            If fstat
              GOK = 0
              Call FSTACTX("ROH",W_TRASTP,"$DEL_GAMME") From CFGLIBD  # From GLOCK
              Break   # FQ 69909 Ctrl des sources
            Endif
          # Issue 89095 GA 06/2013
            Call DEL_AXX_FIC("ROUTING","[F:ROH]") From CFGLIBC1

          # FQ 75666 GA 08/2011 Modif faite par Bordeaux Ko Remplacer [F:CSC]FCY par S_FCY
          # Issue 89095 & 89191 suite GA 06/2013 tous sites et alternatives
          #Filter [ROO] Where FCY = S_FCY & ITMREF=[F:ROH]ITMREF & ROUALT = [F:CSC]ROUALT
            Filter [ROO] Where FCY = [F:ROH]FCY & ITMREF=[F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                        Order By Key ROO0
            For [ROO] With Lock
              Case fstat
                When 1 :
                  GLOCK="$ROUOPE"-[F:ROH]ITMREF-num$([F:CSC]ROUALT)-num$(OPENUM)-num$(RPLIND) : GOK=-1
                  Break   # FQ 69909 Ctrl des sources
                When 0 :
                  Delete [ROO]
                  If fstat
                    GOK = 0
                    Call FSTACTX("ROO",W_TRASTP,"$DEL_GAMME") From CFGLIBD  # From GLOCK
                    Break   # FQ 69909 Ctrl des sources
                  Endif
                 # Issue 89095 GA 06/2013
                  Call DEL_AXX_FIC("ROUOPE","[F:ROO]") From CFGLIBC1
               When Default :
                  GOK = 0
                  Call FSTACTX("ROO",W_TRASTP,"$DEL_GAMME") From CFGLIBD  # From GLOCK
                  Break   # FQ 69909 Ctrl des sources
              Endcase
            Next
            Filter [ROO]
    #
          # FQ 75666 GA 08/2011 Modif faite par Bordeaux Ko Remplacer [F:CSC]FCY par S_FCY
          # Issue 89095 & 89191 suite GA 06/2013 tous sites et alternatives
          #  Delete [ROS] Where FCY = S_FCY & ITMREF=[F:ROH]ITMREF & ROUALT = [F:CSC]ROUALT
            Filter [ROS] Where FCY = [F:ROH]FCY & ITMREF=[F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                        Order By Key ROS0
            For [ROS] With Lock
              Case fstat
                When 1 :
                  GLOCK="$ROUSCD"-[F:ROH]ITMREF-num$([F:CSC]ROUALT)-num$(OPENUM)-num$(RPLIND) : GOK=-1
                  Break   # FQ 69909 Ctrl des sources
                When 0 :
                  Delete [ROS]
                  If fstat
                    GOK = 0
                    Call FSTACTX("ROS",W_TRASTP,"$DEL_GAMME") From CFGLIBD  # From GLOCK
                    Break   # FQ 69909 Ctrl des sources
                  Endif
                 # Issue 89095 GA 06/2013
                  Call DEL_AXX_FIC("ROUSCD","[F:ROS]") From CFGLIBC1
               When Default :
                  GOK = 0
                  Call FSTACTX("ROS",W_TRASTP,"$DEL_GAMME") From CFGLIBD  # From GLOCK
                  Break   # FQ 69909 Ctrl des sources
              Endcase
            Next
            Filter [ROS]
          #Endif
      Endcase
    Next
    Filter [ROH]
#Endif
Return
############################################################
# Effacement enregistrements historiques
$DEL_HISTORIQUE
Delete [CHH] Where  SCENUM = [F:CSC]SCENUM & CFGVCRNUM = S_CPTCFG
If fstat = 1
  GLOCK="$CFGHISHEA"-S_CPTCFG : GOK=-1
Else
  fstat = 0
  Delete [CFH] Where  SCENUM = [F:CSC]SCENUM & CFGVCRNUM = S_CPTCFG
  If fstat = 1
GLOCK="$CFGHIS"-[F:CSC]SCENUM-S_CPTCFG-[CFH]SYMNUM-num$([CFH]SYMSEQ) : GOK=-1
  Endif
Endif
Return
############################################################
# Sous programme de gestion des texte traductibles (AXT)
Subprog TRT_TYPAXT(LFIC)
Value Char    LFIC
Local Char    W_EVA(40)
Local Char    W_ABR(10)
Local Char    W_VAL(250)        # FQ 54725 GA 24/04/2009 pour TCGULF avant 80
Local Char    W_CR1(GLONID1)
Local Char    W_CR2(GLONID2)
Local Integer W_I, W_J
#
If !adxlog : Trbegin [AXX] : Endif     # JPJ Trbegin/Commit $Upd_Textes

For W_I = 0 To dim(W_FICAXF)-1
  If W_FICAXF(W_I) = LFIC
    W_J     = find(LFIC,W_FICNAM)
    W_ABR   = W_FICABR(W_J-1)
    If evalue("dim("+W_ABR+W_FICAXZ(W_I)+")")>0 # Issue 84700 GA 11/2012
      W_VAL = evalue(W_ABR+W_FICAXZ(W_I))
      If W_VAL <> ""
        If W_FICAX1(W_I) = ""
          W_CR1   = ""
        Else
          W_CR1   = evalue(W_ABR+W_FICAX1(W_I))
        Endif
        If W_FICAX2(W_I) = ""
          W_CR2 = ""
        Else
          W_CR2   = evalue(W_ABR+W_FICAX2(W_I))
        Endif

        Call MAJTEXTRA(W_VAL,LFIC,W_FICAXN(W_I),W_CR1,W_CR2) From ATEXTRA

      Endif
    Else
       # Issue 84700 GA 11/2012 Champ xxxAXX n'existe pas dans le buffer [F]
       If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2
       W_VAL = ""
       Gosub UPD_AXX_FROM_ASW From CFGLIBC1
    Endif
  Elsif W_FICAXF(W_I)="" | GOK<>1 Break
  Endif
Next W_I
If !adxlog      # JPJ Trbegin/Commit $Upd_Textes
    If GOK = 1
      Commit
    Else
      Rollback
    Endif
Endif
End
############################################################
# Sous programme de creation ou duplication des textes rtf (TEX et TXC)
Subprog CRE_TYPTEX(LFIC)
Value Char LFIC
Local Char    W_EVA(40)    # Contient le Fichier/Champs devant recevoir le code TEX ou TXC  (ex: '[F:ITM]MFGTEX')
Local Char    W_ABR(10)    # Nota: ce champs contient soit le code à dupliquer, soit 'XX__...' si texte configurateur
Local Integer W_MOD
Local Char    W_TEX(250)
#Local Char    W_NEW(250)
Local Char    W_CLE(60)
Local Integer W_I, W_J, W_K
# Balayage des champs a texte pour la table specifiee
For W_I = 0 To dim(W_FICTEF)-1
  If W_FICTEF(W_I) = LFIC
    W_J     = find(LFIC,W_FICNAM)
    W_ABR   = W_FICABR(W_J-1)
    W_EVA   = W_ABR+W_FICTEZ(W_I)
    W_TEX   = evalue(W_EVA)
    W_MOD   = W_FICTEM(W_I)
# Texte cree par le scenario ?
    If left$(W_TEX,4) = "XX__"
      Read [CFT]CFT0=adxuid(1);0;LFIC;W_FICTEZ(W_I);W_TEX
      If fstat = 0
        W_TEX = ""
        If W_FICTET="TXC"                                         # JPJ TEX->TXC
            If dim([F:CFT]CLOB)<0
               Call CRE_TEXTXC(seg$(W_ABR,4,6),W_TEX,[F:CFT]TXT,W_K) From CFGLIBD
            Else
             # FQ 32446 GA 11/2008
               Call CRE_TEXCLB(seg$(W_ABR,4,6),W_TEX,[F:CFT]CLOB,W_K) From CFGLIBD
            Endif
            If W_K = 1    # Ok
              Assign W_EVA With W_TEX
              W_TRAMSG= space$(3)+mess(221,188,1)-W_TEX-"("-W_EVA-"TXC)" : Gosub TRA_MSG From CFGLIBB
            Else
               Break
            Endif
        Else                     # Conservation de l'ancien mode (TEX)
            Call CRE_TEXTE(W_MOD,W_TEX,[F:CFT]TXT,W_K) From CFGLIBD
            If W_K = 0
               Assign W_EVA With W_TEX
               W_TRAMSG= space$(3)+mess(221,188,1)-W_TEX-"("-W_EVA-"TEX)" : Gosub TRA_MSG From CFGLIBB
            Else
               GOK=0 : Break
            Endif
        Endif
      Endif
    Else
      If W_TEX <> ""
        If W_FICTET="TXC"                                         # JPJ TEX->TXC
            Call DUP_CLOB(seg$(W_ABR,4,6), W_TEX, W_K) From TRTX3TEX
            If W_K=1          # Ok
                If W_TEX <> ""   # W_TEX non vide
                    Assign W_EVA With W_TEX
                    W_TRAMSG= space$(3)+mess(220,188,1)-W_TEX-"("-W_EVA-"/TXC)" : Gosub TRA_MSG From CFGLIBB
                Else             # W_TEX vide (texte à dupliquer non trouvé) -> pas d'erreur
                     Assign W_EVA With W_TEX
                Endif
            Else
               GOK=0 : Break
            Endif
# FQ 48390 cas impossible ?
#        Else                     # Conservation de l'ancien mode (TEX)
#            If W_MOD <> 0
#              Call TEX(W_MOD,"","","","",W_TEX,"D",W_K) From TRTX3TEX
#              If W_K <> 99
#                If W_TEX <> ""
#                    Assign W_EVA With W_TEX
#                    W_TRAMSG= space$(3)+mess(220,188,1)-W_TEX-"("-W_EVA-"/TEX)" : Gosub TRA_MSG From CFGLIBB
#                Else             # W_TEX vide (texte à dupliquer non trouvé) -> pas d'erreur
#                    Assign W_EVA With W_TEX
#                Endif
#              Else
#                GOK=0 : Break
#              Endif
#            Endif
        Endif
      Endif
    Endif
  Endif
Next W_I

End
############################################################
# Sous programme de test existence d'un article equivalent selon
# les regles definies par la ligne de produit de l'article de reference
# Classe [F:ITM] contient l'article a creer
# LLIN = ligne de produit de l'article de reference
# LRET = 0 Article non trouve
#        1 Article trouve (classe [ITM1] chargee)
Subprog EXI_ARTICLE(LLIN,LRET)
Value    Char    LLIN
Variable Integer LRET
#
Local    Char    W_FIL0(10)
Local    Char    W_FIL1(250) : W_FIL1 = "1=1" # FQ 77813 GA 11/2011 avant "[F:ITM1]ITMREF=[F:ITM]ITMREF"
Local    Char    W_FIL2(250) : W_FIL2 = "1=1"
Local    Char    W_FIL3(250) : W_FIL3 = "1=1"
Local    Char    W_CRIT_SPE1(250) : W_CRIT_SPE1="1=1" # FQ 73925 GA 05/2011
Local    Char    W_CRIT_SPE2(250) : W_CRIT_SPE2="1=1" # FQ 73925 GA 05/2011
Local    Char    W_CRIT_SPE3(250) : W_CRIT_SPE3="1=1" # FQ 73925 GA 05/2011
Local    Char    W_CRIT_SPE (250) : W_CRIT_SPE ="1=1" # Issue 82927 GA 06/2012
Local    Integer I_CPT    : # FQ 43622 avant W_CPT déjà définie par ailleurs en Char
#
Raz I_CPT, LRET
#
Read [TLP]TLP0=LLIN
If fstat = 0
  If [F:TLP]ITMFLDNBR <> 0
    For W_I = 0 To [F:TLP]ITMFLDNBR-1
      If [F:TLP]INDFLD(W_I) < 2
        W_FIL0 = ""
      Else
        W_FIL0 = "("+num$([F:TLP]INDFLD(W_I)-1)+")"
      Endif
      Case W_I
        When 0,1,2,3,4 :
          W_FIL1 += "& [F:ITM1]"+[F:TLP]ITMFLD(W_I)+W_FIL0+"=[F:ITM]"+[F:TLP]ITMFLD(W_I)+W_FIL0
        When 5,6,7,8,9 :
          W_FIL2 += "& [F:ITM1]"+[F:TLP]ITMFLD(W_I)+W_FIL0+"=[F:ITM]"+[F:TLP]ITMFLD(W_I)+W_FIL0
        When 10,11,12,13,14 :
          W_FIL3 += "& [F:ITM1]"+[F:TLP]ITMFLD(W_I)+W_FIL0+"=[F:ITM]"+[F:TLP]ITMFLD(W_I)+W_FIL0
        When Default :
          # FQ 73925 GA 05/2011 problème si [F:TLP]ITMFLDNBR a été augmenté
          Gosub ADD_CRIT_SPE
      Endcase
    Next W_I
  Elsif W_FIL1 = ""    # FQ 77813 on ne trouvera aucune équiv
    W_FIL1 = "[F:ITM1]ITMREF=[F:ITM]ITMREF"
    [F:TLP]SEAKEY = 1
  Endif
Endif

# Issue 92792 GA 09/2013 GPE permet de remplacer totalement le Filter
# Issue 82927 GA 06/2012
# Point d'entree critères de sélection des équivalences sur [F:ITM]
# Utiliser W_CRIT_SPE et/ou compléter W_CRIT_SPE1,2,3
GPE=0 : GPOINT = "LOA_CITM"
Gosub ENTREE From EXEFNC
If !GPE
  If [F:TLP]SEAKEY=0 [F:TLP]SEAKEY = 1 Endif
#
  Case [F:TLP]SEAKEY
  When 1 :
    Filter [ITM1] Where evalue(W_FIL1) & evalue(W_FIL2) & evalue(W_FIL3)
&                     & evalue(W_CRIT_SPE1) & evalue(W_CRIT_SPE2) & evalue(W_CRIT_SPE3) & evalue(W_CRIT_SPE)
&                 Order By Key ITM0
  When 2 :
    Filter [ITM1] Where evalue(W_FIL1) & evalue(W_FIL2) & evalue(W_FIL3)
&                     & evalue(W_CRIT_SPE1) & evalue(W_CRIT_SPE2) & evalue(W_CRIT_SPE3) & evalue(W_CRIT_SPE)
&                 Order By Key ITM1
  When 3 :
    Filter [ITM1] Where evalue(W_FIL1) & evalue(W_FIL2) & evalue(W_FIL3)
&                     & evalue(W_CRIT_SPE1) & evalue(W_CRIT_SPE2) & evalue(W_CRIT_SPE3) & evalue(W_CRIT_SPE)
&                 Order By Key ITM2
  When 4 :
    Filter [ITM1] Where evalue(W_FIL1) & evalue(W_FIL2) & evalue(W_FIL3)
&                     & evalue(W_CRIT_SPE1) & evalue(W_CRIT_SPE2) & evalue(W_CRIT_SPE3) & evalue(W_CRIT_SPE)
&                 Order By Key ITM3
  When 5 :   # Issue 92792 GA 09/2013
    Filter [ITM1] Where evalue(W_FIL1) & evalue(W_FIL2) & evalue(W_FIL3)
&                     & evalue(W_CRIT_SPE1) & evalue(W_CRIT_SPE2) & evalue(W_CRIT_SPE3) & evalue(W_CRIT_SPE)
&                 Order By Key ITM4
  When Default :
  # Issue 80853 vu lors des tests Cofel
    Filter [ITM1] Where evalue(W_FIL1) & evalue(W_FIL2) & evalue(W_FIL3)
&                     & evalue(W_CRIT_SPE1) & evalue(W_CRIT_SPE2) & evalue(W_CRIT_SPE3) & evalue(W_CRIT_SPE)
#&                 Order By Key reckey  # Issue 92792 GA 09/2013
  Endcase
Else
  Local Char W_TRAMSG(250)
  W_TRAMSG="Entry point LOA_CITM: Filter replaced by specific treatment"
  Gosub TRA_MSG From CFGLIBB
  W_TRAMSG=""
Endif # GPE

#
Raz [F:ITM1]
Raz I_CPT
For [ITM1]
  Gosub PE_CTL_ITM_EQUIV From CFGLIBB # Issue 82927 GA 06/2012
  Case GPE
    When 1 : # next ITM1
    When 2 : Break
    When Default :
      I_CPT += 1
      If I_CPT > 1
        Break
      Endif
  Endcase
Next
If I_CPT = 0
  Raz [ITM1]
  LRET = 1
Else
# Si un seul article equivalent sortie sinon fenetre de choix sauf en WEB et automate
# CCC (20/04/07) DM 41021 : ouvrir la fenêtre d'équivalence même s'il n'y a qu'un seul équivalent
#  If I_CPT = 1 | GINTRA | S_AUTCFG <> 0
# GA 11/04/2008 FQ 46903 option pour conserver le mode de fonctionnement initial
#    ajout d'un code 4=Recherche [équivalence] avec sélection automatique [si une seule ligne]
#  If GINTRA | S_AUTCFG <> 0
  If GINTRA | S_AUTCFG <> 0 | (I_CPT = 1 & [F:CSC]SEAPARITM=4 )
    Read [ITM1] First
    If fstat
      Raz [F:ITM1]
      LRET = 1
    Else
      LRET = 0
    Endif
    Gosub PE_CTL_ITM_EQUIV From CFGLIBB # Issue 82927 GA 06/2012
    Case GPE
      When 1 : # next ITM1
      When 2 : LRET = 1
      When Default :
    Endcase
  Else
    If !GINTRA
      # CCC (19/04/07) Bug 41021 : la classe ITM peut être modifiée par l'action SAICFGEQU via des tunnels
      Local File ITMMASTER [ITMS]
      [F:ITMS]=[F:ITM]
      Local Char DMY(1)
      If GVERSION>"1.6.4"
         Call ISSCREENOK (nomap,"CFGPIL") From INTRUTILB  # Issue 80297
      Endif
      Call B1_DMY(DMY) From W1CFGPIL
#      Local Char PARAM(50)(1..20) , SAVACT(10)                         # <MG> 03/07/03
#      SAVACT = GACTION : GACTION = "SAICFGEQU"                         # <MG> 03/07/03
#      Call SAISIE_CHAR(DMY,PARAM,"ICFGEQU","CFGLIBB","") From GSAISIE  # <MG> 03/07/03
#      GACTION = SAVACT                                                 # <MG> 03/07/03
      LRET = S_RETURN
      [F:ITM]=[F:ITMS]
    Endif
  Endif
Endif
Filter [ITM1]
End

# FQ 73925 GA 05/2011 problème si [F:TLP]ITMFLDNBR a été augmenté en spécifique
$ADD_CRIT_SPE
If len(W_CRIT_SPE1)<200
  W_CRIT_SPE1 += "& [F:ITM1]"+[F:TLP]ITMFLD(W_I)+W_FIL0+"=[F:ITM]"+[F:TLP]ITMFLD(W_I)+W_FIL0
Elsif len(W_CRIT_SPE2)<200
  W_CRIT_SPE2 += "& [F:ITM1]"+[F:TLP]ITMFLD(W_I)+W_FIL0+"=[F:ITM]"+[F:TLP]ITMFLD(W_I)+W_FIL0
Elsif len(W_CRIT_SPE3)<200
  W_CRIT_SPE3 += "& [F:ITM1]"+[F:TLP]ITMFLD(W_I)+W_FIL0+"=[F:ITM]"+[F:TLP]ITMFLD(W_I)+W_FIL0
Endif
Return

############################################################
$OUVRE_CFGREC
If clalev([F:CSC])  = 0 : Local File CFGSCE    [CSC]  : Endif
If clalev([F:CQU])  = 0 : Local File CFGQST    [CQU]  : Endif
If clalev([F:CHH])  = 0 : Local File CFGHISHEA [CHH]  : Endif
If clalev([F:CFH])  = 0 : Local File CFGHIS    [CFH]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER [ITM1] : Endif
If clalev([F:BPR1]) = 0 : Local File BPARTNER  [BPR1] : Endif
#
If [F:CSC]SCENUM<>PARAM(1) # Issue 89191 GA 04/2013
  Read [CSC]CSC0= PARAM(1)
  If fstat
    FIN = 1
    Return
  Endif
Endif
S_MODITM = ""
Return
############################################################
$DEBUT_CFGREC
Raz [M:CFGH]
[M:CFGH]SCENUM = [F:CSC]SCENUM
[M:CFGH]SCEDES = [F:CSC]SCEDES
#
Link [CFH] With  [CQU]CQU0=[F:CFH]SYMNUM
&          As    [LNK]
&          Where [F:CFH]SCENUM = [F:CSC]SCENUM
&              & [F:CFH]SYMSEQ = 0
&              & [F:CQU]SEAFLG=2
&          Order By Key CFH2
For [LNK]CFH2(3)
    Case [F:CQU]QSTTYP
      When 1 :
        If !find([F:CQU]QSTNUM,[M:CFGH]QSTNUM(0..[M:CFGH]NBLIG1-1))
          If [M:CFGH]NBLIG1 < dim([M:CFGH]QSTNUM)-1
            [M:CFGH]QSTNUM([M:CFGH]NBLIG1) = [F:CQU]QSTNUM
            # FQ 53410 remplacé par le lien
            #[M:CFGH]QSTDES([M:CFGH]NBLIG1) = [F:CQU]QSTSHO
            [M:CFGH]QSTNAT([M:CFGH]NBLIG1) = [F:CQU]ASWTYP
            [M:CFGH]NBLIG1 += 1
            W_VAR = W_PRX+[F:CQU]QSTNUM
            Gosub CRE_SYMTXT From WUVAR
           Else
            Break
          Endif
        Endif
      When 2 :
        If !find([F:CQU]QSTNUM,[M:CFGH]VARNUM(0..[M:CFGH]NBLIG2-1))
          If [M:CFGH]NBLIG2< dim([M:CFGH]VARNUM)-1
            [M:CFGH]VARNUM([M:CFGH]NBLIG2) = [F:CQU]QSTNUM
            [M:CFGH]VARDIM([M:CFGH]NBLIG2) = [F:CQU]QSTDIM
            # FQ 53410 remplacé par le lien
            #[M:CFGH]VARDES([M:CFGH]NBLIG2) = [F:CQU]QSTSHO
            [M:CFGH]VARNAT([M:CFGH]NBLIG2) = [F:CQU]ASWTYP
            [M:CFGH]NBLIG2 += 1
            W_VAR = W_PRX+[F:CQU]QSTNUM
            Gosub CRE_SYMTXT From WUVAR
          Else
            Break
          Endif
        Endif
    Endcase
Next
Filter [CFH]
# Prechargement des reponses saisies si on a deja saisi des reponses
For W_I = 0 To [M:CFGH]NBLIG1-1
  If evalue("dim("+W_PRS+[M:CFGH]QSTNUM(W_I)+")>0")
    If S_QSTFLG <> 0 | (S_QSTFLG = 0 & find([M:CFGH]QSTNUM(W_I),"BPRNUM","BPRREF"))
      [M:CFGH]QSTCND(W_I) = 2
      Case [M:CFGH]QSTNAT(W_I)
        When 1 :
          [M:CFGH]QSTVALALP(W_I) = evalue(W_PRS+[M:CFGH]QSTNUM(W_I))
          [M:CFGH]QSTVAL   (W_I) = [M:CFGH]QSTVALALP(W_I)
        When 2 :
          [M:CFGH]QSTVALNUM(W_I) = evalue(W_PRS+[M:CFGH]QSTNUM(W_I))
          [M:CFGH]QSTVAL   (W_I) = num$([M:CFGH]QSTVALNUM(W_I))
        When 3 :
          [M:CFGH]QSTVALDAT(W_I) = evalue(W_PRS+[M:CFGH]QSTNUM(W_I))
          [M:CFGH]QSTVAL   (W_I) = format$("DfZz:"+GFMDAT,[M:CFGH]QSTVALDAT(W_I))
        When 4 :
          [M:CFGH]QSTVALNUM(W_I) = evalue(W_PRS+[M:CFGH]QSTNUM(W_I))
          [M:CFGH]QSTVAL   (W_I) = num$([M:CFGH]QSTVALNUM(W_I))
      Endcase
    Endif
  Endif
Next W_I
# Prechargement des variables tiers et reference tiers
# Seulement Numero tiers et reference tiers si aucune reponse saisie
For W_I = 0 To [M:CFGH]NBLIG2-1
  If evalue("dim("+W_PRS+[M:CFGH]VARNUM(W_I)+")>0")
    If S_QSTFLG <> 0 | (S_QSTFLG = 0 & find([M:CFGH]VARNUM(W_I),"BPRNUM","BPRREF"))
      [M:CFGH]VARCND(W_I) = 2
      Case [M:CFGH]VARNAT(W_I)
        When 1 :
          [M:CFGH]VARVALALP(W_I) = evalue(W_PRS+[M:CFGH]VARNUM(W_I))
          [M:CFGH]VARVAL   (W_I) = [M:CFGH]VARVALALP(W_I)
        When 2 :
          [M:CFGH]VARVALNUM(W_I) = evalue(W_PRS+[M:CFGH]VARNUM(W_I))
          [M:CFGH]VARVAL   (W_I) = num$([M:CFGH]VARVALNUM(W_I))
        When 3 :
          [M:CFGH]VARVALDAT(W_I) = evalue(W_PRS+[M:CFGH]VARNUM(W_I))
          [M:CFGH]VARVAL   (W_I) = format$("DfZz:"+GFMDAT,[M:CFGH]VARVALDAT(W_I))
        When 4 :
          [M:CFGH]VARVALNUM(W_I) = evalue(W_PRS+[M:CFGH]VARNUM(W_I))
          [M:CFGH]VARVAL   (W_I) = num$([M:CFGH]VARVALNUM(W_I))
      Endcase
    Endif
  Endif
Next W_I
Affzo [M:CFGH]
Return
############################################################
$SETBOUT_CFGREC
# CCC 41021
If [M:CFGH]NBLIG3 = 0
    Call VIREBOUT(CHMEN,"c") From GOBJET
Endif
If [M:CFGH]NBLIG3 = 0 | dim(GVENCFG) <= 0 | GVENCFG = 0
    Call VIREBOUT(CHMEN,"f") From GOBJET
Endif
Return

############################################################
# CCC 41021
$AVBOUT_CFGREC
    Case BOUT
        When "f"
            Read [ITM1]ITM0=[M:CFGH]ITMREF(nolign-1)
            If fstat
                GMESSAGE=mess(25,192,1)-":"-[M:CFGH]ITMREF(nolign-1)
                GERR=1
                Return
            Endif
            FIN=1
            FOK=1
            S_SELITM=[M:CFGH]ITMREF(nolign-1)
    Endcase
Return

############################################################
$BOUTON_CFGREC
Case BOUT
  When "a" : Gosub REC_CFGREC
  When "b" : Gosub EFF_CFGREC
  When "c" : Gosub SEL_CFGREC
  When "d" : Gosub IMP_CFGREC
  When "e" : Gosub MOD_CFGREC
Endcase
Return
############################################################
$IMP_CFGREC
Call PRTSCR("CFGHIS","CFH","",0,0) From ATRTX3
Return
############################################################
$REC_CFGREC
Gosub CFG_CONSTANTES From CFGLIB
Effzo [M:CFGH]20
Local Char REQ(250)([M:CFGH]NBLIG1+[M:CFGH]NBLIG2+2)
Raz REQ
# -----------------------------------------------------------
# FQ 53403 GA 09/2009 constitution d'une requête dynamique
# -----------------------------------------------------------
  W_J = 0                     # Compter nb critères pris en compte
  REQ(0) =" SELECT CFGVCRNUM_0"
  REQ(0)+=" From  CFGHISHEA CHH"
  REQ(0)+=" Where SCENUM_0 ='"+[M:CFGH]SCENUM+"'"
  For W_I = 0 To [M:CFGH]NBLIG1-1
    If [M:CFGH]QSTCND(W_I) <> 1
      W_J += 1
      Call GEN_CNDSQL(1,[M:CFGH]QSTNAT(W_I),[M:CFGH]QSTCND(W_I),W_I,W_EVA) From CFGLIBD
      If W_EVA<>""
         REQ(W_J) =" AND EXISTS(SELECT 'x' FROM CFGHIS CFH "
         REQ(W_J)+=" Where CHH.SCENUM_0=CFH.SCENUM_0 AND CHH.CFGVCRNUM_0=CFH.CFGVCRNUM_0"
         REQ(W_J)+=  " AND CFH.SYMNUM_0='"+[M:CFGH]QSTNUM(W_I)+"'"
         REQ(W_J)+=  " AND "+W_EVA +")"
      Endif
    Endif
  Next W_I
#
  If W_J = 0
    For W_I = 0 To [M:CFGH]NBLIG2-1
      If [M:CFGH]VARCND(W_I) <> 1
        W_J += 1
        Call GEN_CNDSQL(2,[M:CFGH]VARNAT(W_I),[M:CFGH]VARCND(W_I),W_I,W_EVA) From CFGLIBD
        If [M:CFGH]VARDIM(W_I) > 1
        Else
          If W_EVA<>""
             REQ(W_J) =" AND EXISTS(SELECT 'x' FROM CFGHIS CFH "
             REQ(W_J)+=" Where CHH.SCENUM_0=CFH.SCENUM_0 AND CHH.CFGVCRNUM_0=CFH.CFGVCRNUM_0"
             REQ(W_J)+=  " AND CFH.SYMNUM_0='"+[M:CFGH]VARNUM(W_I)+"'"
             REQ(W_J)+=  " AND "+W_EVA +")"
          Endif
        Endif
      Endif
    Next W_I
  Endif

If W_J=0
# Pas de critères: on propose tout
  Filter [CHH] Where SCENUM = [M:CFGH]SCENUM
&              Order By Key CHH1
  For [CHH]
    Gosub REC_CFGREC_ADDCHH
  Next
  Filter [CHH]
Else
  REQ(W_J+1) =" ORDER BY CFGVCRNUM_0"
  # FQ 53403 GA 09/2009 exécution d'une requête dynamique
  For (Char CFGVCRNUM(GLONVCR)) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    Read [F:CHH]CHH0 = [SQLX]CFGVCRNUM
    If fstat Raz [F:CHH] : Break : Endif
    Gosub REC_CFGREC_ADDCHH
  Next
Endif

Affzo [M:CFGH]20
If [M:CFGH]NBLIG3 = 0
  GMESSAGE = mess(63,188,1)
Else
  If W_J = 0
    GMESSAGE = num$([M:CFGH]NBLIG3)-mess(62,188,1)-mess(67,188,1)
  Else
    GMESSAGE = num$([M:CFGH]NBLIG3)-mess(62,188,1)-"("+mess(66,188,1)+num$(W_J)+")"
  Endif
Endif
GERR = 2
Return
#
$REC_CFGREC_ERR
Raz W_ALP, W_NUM, W_DAT
Resume

$REC_CFGREC_ADDCHH
If [M:CFGH]NBLIG3 < dim([M:CFGH]CFGVCRNUM)-1
  [M:CFGH]CFGVCRNUM([M:CFGH]NBLIG3) = [F:CHH]CFGVCRNUM
  [M:CFGH]CFGBPRNUM([M:CFGH]NBLIG3) = [F:CHH]CFGBPRNUM
  [M:CFGH]CFGBPRREF([M:CFGH]NBLIG3) = [F:CHH]CFGBPRREF
  [M:CFGH]FCY      ([M:CFGH]NBLIG3) = [F:CHH]FCY
  [M:CFGH]CREUSR   ([M:CFGH]NBLIG3) = [F:CHH]CREUSR
  [M:CFGH]CREDAT   ([M:CFGH]NBLIG3) = [F:CHH]CREDAT
  Read [BPR1]BPR0=[F:CHH]CFGBPRNUM
  If fstat
    Raz [F:BPR1]
  Endif
  [M:CFGH]CFGBPRNAM([M:CFGH]NBLIG3) = [F:BPR1]BPRNAM
  Read [ITM1]ITM0=[F:CHH]ITMREF
  If fstat
    Raz [F:ITM1]
  Endif
  [M:CFGH]ITMREF   ([M:CFGH]NBLIG3) = [F:CHH]ITMREF
  [M:CFGH]BOMALT   ([M:CFGH]NBLIG3) = [F:CHH]BOMALT
  [M:CFGH]BOMALTTYP([M:CFGH]NBLIG3) = [F:CHH]BOMALTTYP : # GA 09/2007 pour la V6
  #[M:CFGH]ITMDES1  ([M:CFGH]NBLIG3) = [F:ITM1]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:CFGH]ITMDES1([M:CFGH]NBLIG3), "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  [M:CFGH]STU      ([M:CFGH]NBLIG3) = [F:ITM1]STU
  [M:CFGH]QTYSTU   ([M:CFGH]NBLIG3) = [F:CHH]QTYSTU
  [M:CFGH]ROUNUM   ([M:CFGH]NBLIG3) = [F:CHH]ROUNUM
  [M:CFGH]ROUALT   ([M:CFGH]NBLIG3) = [F:CHH]ROUALT
  [M:CFGH]ITMCRE   ([M:CFGH]NBLIG3) = [F:CHH]ITMCRE
  [M:CFGH]CPNCRE   ([M:CFGH]NBLIG3) = [F:CHH]CPNCRE
  [M:CFGH]ROUCRE   ([M:CFGH]NBLIG3) = [F:CHH]ROUCRE
  [M:CFGH]NBLIG3 += 1
Endif
Return

############################################################
# Effacement des selections
$EFF_CFGREC
For W_I = 0 To [M:CFGH]NBLIG1-1
  [M:CFGH]QSTCND   (W_I) = 1
  [M:CFGH]QSTVAL   (W_I) = ""
  [M:CFGH]QSTVALALP(W_I) = ""
  [M:CFGH]QSTVALNUM(W_I) = 0
  [M:CFGH]QSTVALDAT(W_I) = [0/0/0]
Next W_I
#
For W_I = 0 To [M:CFGH]NBLIG2-1
  [M:CFGH]VARCND   (W_I) = 1
  [M:CFGH]VARVAL   (W_I) = ""
  [M:CFGH]VARVALALP(W_I) = ""
  [M:CFGH]VARVALNUM(W_I) = 0
  [M:CFGH]VARVALDAT(W_I) = [0/0/0]
Next W_I
#
[M:CFGH]NBLIG3 = 0
Affzo [M:CFGH]

Return


############################################################
# Si selection report des valeurs dans les reponses deja donnees
$SEL_CFGREC
If dim(S_CPTCOP) > 0
  S_CPTCOP = [M:CFGH]CFGVCRNUM(nolign-1)
  If W_INDRNG <> 0
    For W_I = 0 To W_INDRNG-1
      W_VAR = W_VARRNG(W_I)
      If evalue("dim("+W_VAR+")>0")
        Gosub SET_DEFAUT From WUVAR
        # Issue 112120 - 2016-03-11 by STLIG : Specify specific scenario responses mask.
        Call ASS_SYMBOLE("[M:CSCE]",W_VAR) From WUVAR
      Endif
    Next W_I
  Endif
Endif
If clalev([M:CSCE]) > 0
  Gosub AFF_DYNAMT From CFGLIB
  Affzo [M:CSCE]
Endif
#
S_MEMO   = 1
GMESSAGE = mess(166,188,1)-S_CPTCOP-":"-mess(64,188,1)
GERR     = 2
FIN      = 1
Return
############################################################
# Si selection report des valeurs dans les reponses deja donnees
$MOD_CFGREC
Read [ITM1]ITM0=[M:CFGH]ITMREF(nolign-1)
If fstat = 0
  If dim(S_CPTCOP) > 0
    S_CPTCOP = [M:CFGH]CFGVCRNUM(nolign-1)
    If W_INDRNG <> 0
      For W_I = 0 To W_INDRNG-1
        W_VAR = W_VARRNG(W_I)
        If evalue("dim("+W_VAR+")>0")
          Gosub SET_DEFAUT From WUVAR
          # Issue 112120 - 2016-03-11 by STLIG : Specify specific scenario responses mask.
          Call ASS_SYMBOLE("[M:CSCE]",W_VAR) From WUVAR
        Endif
      Next W_I
    Endif
  Endif
  S_BPRNUM = [M:CFGH]CFGBPRNUM(nolign-1)
  S_BPRREF = [M:CFGH]CFGBPRREF(nolign-1)
  S_MODITM = [M:CFGH]ITMREF   (nolign-1)
  S_MEMO   = 1
  GMESSAGE = mess(163,188,1)-S_MODITM-"("-[M:CFGH]CFGBPRNUM(nolign-1)+" / "+
&            [M:CFGH]CFGBPRREF(nolign-1)+")\"+mess(166,188,1)-S_CPTCOP
  GERR     = 2
  If clalev([M:CSCE]) > 0
    [M:CSCE]BPRNUM = S_BPRNUM
    [M:CSCE]BPRREF = S_BPRREF
    Gosub AFF_DYNAMT From CFGLIB
    Affzo [M:CSCE]
  Endif
  #
Else
  GMESSAGE = mess(166,188,1)-S_CPTCOP-":"-[M:CFGH]ITMREF(nolign-1)-mess(164,188,1)
  GERR     = 1
Endif
FIN      = 1
Return
############################################################
$END_CFGREC
If dim(S_CPTCOP) > 0
  S_CPTCOP = ""
Endif
Return
############################################################
# Action SAICFGRECM
############################################################
$OUVRE_CFGRECM
If clalev([F:CSC])  = 0 : Local File CFGSCE    [CSC]  : Endif
If clalev([F:CQU])  = 0 : Local File CFGQST    [CQU]  : Endif
If clalev([F:CHH])  = 0 : Local File CFGHISHEA [CHH]  : Endif
If clalev([F:CFH])  = 0 : Local File CFGHIS    [CFH]  : Endif
If clalev([F:ITM1]) = 0 : Local File ITMMASTER [ITM1] : Endif
If clalev([F:BPR1]) = 0 : Local File BPARTNER  [BPR1] : Endif
#
If [F:CSC]SCENUM<>PARAM(1) # Issue 89191 GA 04/2013
  Read [CSC]CSC0= PARAM(1)
  If fstat
    FIN = 1
    Return
  Endif
Endif
S_MODITM = ""
Return
############################################################
$DEBUT_CFGRECM
Gosub CFG_CONSTANTES From CFGLIB
Raz [M:CFGH]
[M:CFGH]SCENUM    = [F:CSC]SCENUM
[M:CFGH]SCEDES    = [F:CSC]SCEDES
[M:CFGH]BPRNUM    = PARAM(3)
[M:CFGH]BPRREF    = PARAM(4)
[M:CFGH]ITMREFSEL = PARAM(5)
Gosub REC_CFGRECM
If [M:CFGH]NBLIG3 = 0
  GMESSAGE = mess(63,188,1)
  GERR = 2
Endif
Return
############################################################
$REC_CFGRECM
Effzo [M:CFGH]15
W_FIL = "SCENUM=[m:CFGH]SCENUM"
If [M:CFGH]BPRNUM <> ""
  W_FIL += "&CFGBPRNUM=[M:CFGH]BPRNUM"
Endif
If [M:CFGH]BPRREF <> ""
  W_FIL += "&CFGBPRREF=[M:CFGH]BPRREF"
Endif
If [M:CFGH]ITMREFSEL <> ""
  W_FIL += "&ITMREF=[M:CFGH]ITMREFSEL"
Endif
#
Filter [CHH] Where evalue(W_FIL)
&            Order By Key CHH1
For [CHH]
  If [M:CFGH]NBLIG3 < dim([M:CFGH]CFGVCRNUM)-1
    [M:CFGH]CFGVCRNUM([M:CFGH]NBLIG3) = [F:CHH]CFGVCRNUM
    [M:CFGH]CFGBPRNUM([M:CFGH]NBLIG3) = [F:CHH]CFGBPRNUM
    [M:CFGH]CFGBPRREF([M:CFGH]NBLIG3) = [F:CHH]CFGBPRREF
    [M:CFGH]FCY      ([M:CFGH]NBLIG3) = [F:CHH]FCY
    [M:CFGH]CREUSR   ([M:CFGH]NBLIG3) = [F:CHH]CREUSR
    [M:CFGH]CREDAT   ([M:CFGH]NBLIG3) = [F:CHH]CREDAT
    Read [BPR1]BPR0=[F:CHH]CFGBPRNUM
    If fstat
      Raz [F:BPR1]
    Endif
    [M:CFGH]CFGBPRNAM([M:CFGH]NBLIG3) = [F:BPR1]BPRNAM
    Read [ITM1]ITM0=[F:CHH]ITMREF
    If fstat
      Raz [F:ITM1]
    Endif
    [M:CFGH]ITMREF   ([M:CFGH]NBLIG3) = [F:CHH]ITMREF
    [M:CFGH]BOMALT   ([M:CFGH]NBLIG3) = [F:CHH]BOMALT
    [M:CFGH]BOMALTTYP([M:CFGH]NBLIG3) = [F:CHH]BOMALTTYP : # GA 09/2007 pour la V6
    #[M:CFGH]ITMDES1  ([M:CFGH]NBLIG3) = [F:ITM1]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:CFGH]ITMDES1([M:CFGH]NBLIG3), "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:CFGH]STU      ([M:CFGH]NBLIG3) = [F:ITM1]STU
    [M:CFGH]QTYSTU   ([M:CFGH]NBLIG3) = [F:CHH]QTYSTU
    [M:CFGH]ROUNUM   ([M:CFGH]NBLIG3) = [F:CHH]ROUNUM
    [M:CFGH]ROUALT   ([M:CFGH]NBLIG3) = [F:CHH]ROUALT
    [M:CFGH]ITMCRE   ([M:CFGH]NBLIG3) = [F:CHH]ITMCRE
    [M:CFGH]CPNCRE   ([M:CFGH]NBLIG3) = [F:CHH]CPNCRE
    [M:CFGH]ROUCRE   ([M:CFGH]NBLIG3) = [F:CHH]ROUCRE
    [M:CFGH]NBLIG3 += 1
  Endif
Next
Filter [CHH]
Affzo [M:CFGH]
Return
############################################################
$SETBOUT_CFGRECM
If [M:CFGH]NBLIG3 <> 0
  ETABOU(GSPE3) = 1
Else
  ETABOU(GSPE3) = 0
Endif
Return
############################################################
$BOUTON_CFGRECM
Case BOUT
  When "a" : Gosub REC_CFGRECM
  When "b" : Gosub SEL_CFGRECM
  When "c" : Gosub IMP_CFGRECM
Endcase
Return
############################################################
$IMP_CFGRECM
Call PRTSCR("CFGHISM","CFH","",0,0) From ATRTX3
Return
############################################################
# Si selection report des valeurs dans les reponses deja donnees
$SEL_CFGRECM
# Issue 90596 GA 06/2013 ne pas planter en erreur si rien n'a été sélectionné
If nolign<1 Return Endif
Read [ITM1]ITM0=[M:CFGH]ITMREF(nolign-1)
If fstat = 0
  If dim(S_CPTCOP) > 0
    S_CPTCOP = [M:CFGH]CFGVCRNUM(nolign-1)
    If W_INDRNG <> 0
      For W_I = 0 To W_INDRNG-1
        W_VAR = W_VARRNG(W_I)
        If evalue("dim("+W_VAR+")>0")
          Gosub SET_DEFAUT From WUVAR
          # Issue 112120 - 2016-03-11 by STLIG : Specify specific scenario responses mask.
          Call ASS_SYMBOLE("[M:CSCE]",W_VAR) From WUVAR
        Endif
      Next W_I
    Endif
  Endif
  S_BPRNUM = [M:CFGH]CFGBPRNUM(nolign-1)
  S_BPRREF = [M:CFGH]CFGBPRREF(nolign-1)
  S_MODITM = [M:CFGH]ITMREF   (nolign-1)
  S_MEMO   = 1
  GMESSAGE = mess(163,188,1)-S_MODITM-"("-[M:CFGH]CFGBPRNUM(nolign-1)+" / "+
&            [M:CFGH]CFGBPRREF(nolign-1)+")\"+mess(166,188,1)-S_CPTCOP
  GERR     = 2
  If clalev([M:CSCE]) > 0
    [M:CSCE]BPRNUM = S_BPRNUM
    [M:CSCE]BPRREF = S_BPRREF
    Gosub AFF_DYNAMT From CFGLIB
    Affzo [M:CSCE]
  Endif
  #
Else
  GMESSAGE = mess(166,188,1)-S_CPTCOP-":"-[M:CFGH]ITMREF(nolign-1)-mess(164,188,1)
  GERR     = 1
Endif
FIN      = 1
Return
############################################################
$END_CFGRECM
If dim(S_CPTCOP) > 0
  S_CPTCOP = ""
Endif
Return
############################################################
# Action SAICFGSCS Reponses sous scenarios
############################################################
$INIT_CFGSCS
BOITE    = "WUY"+S_SCENUM
# Issue 80297
If GVERSION>"1.6.4"
   Call ISSCREENOK (S_DOSSIER,BOITE) From INTRUTILB
Endif
Return
############################################################
$TITRE_CFGSCS
TIT = mess(1,188,1)-[F:CSC]SCENUM-[F:CSC]SCEDES
Return
############################################################
$OUVRE_CFGSCS
Local Integer W_RET
Return
############################################################
$DEBUT_CFGSCS
[M:CSSC] = [M:CSCE]
Grizo [M:CSSC]

#CHECK IGNORE_BEGIN
# Issue 79886 GA 03/2012 raz de cette modif # FGR 15/01/2010 : X3SUIVI60986
[M:CSSC]QSTLSTRNG=0        # dernière question en-cours
#[M:CSCE]QSTLSTRNG=0        # dernière question en-cours
#CHECK IGNORE_END

For W_I = 0 To [M:CFP]SAIIND-1
  W_VAR = [M:CFP]SAIQST(W_I)
  If evalue("dim([M:CSSC]"+W_PRQ+mid$(W_VAR,3,GLONCQU)+")>0")
    If evalue("dim("+W_VAR+")>0")
      Call ASS_SYMBOLE("[M:CSSC]",W_VAR) From WUVAR
      Gosub AFF_SYMBOLE From WUVAR
    Endif
    Gosub ACT_SYMBOLE From WUVAR
    If !find(W_VAR,W_VARRNG(0..W_INDRNG))
      W_VARRNG(W_INDRNG) = W_VAR
      W_INDRNG += 1
    Endif
    # Gestion QSTLSTRNG (dernière question en-cours)
    W_J=evalue(W_PRR+mid$(W_VAR,3,GLONCQU))
#CHECK IGNORE_BEGIN
    # Issue 79886 GA 03/2012 raz de cette modif # FGR 15/01/2010 : X3SUIVI60986
    If [M:CSSC]QSTLSTRNG < W_J : [M:CSSC]QSTLSTRNG = W_J : Endif
    #If [M:CSCE]QSTLSTRNG < W_J : [M:CSCE]QSTLSTRNG = W_J : Endif
#CHECK IGNORE_END
  Endif
Next W_I
Affzo [M:CSSC]
Raz [M:CFP]SAIIND
Raz [M:CFP]SAIQST
Return
############################################################
$SETBOUT_CFGSCS
ETABOU(GSPE1) = 0
ETABOU(GSPE2) = 0
ETABOU(GSPE5) = 0
ETABOU(GSPE6) = 0
ETABOU(GSPE7) = 0
Return
############################################################
$OK_CFGSCS
[M:CSCE] = [M:CSSC]
Return
############################################################
$END_CFGSCS
W_RET = 1
Call AVERTIR(mess(51,100,1),W_RET) From GESECRAN
If W_RET = 1
  FIN = 0
Else
  FIN     = 1
  S_ABORT = 1
Endif
Return

############################################################
# FQ 45799 GA 02/2008 ctrl validité de la référence
$CTRL_ITMREF
# FQ 65803 GA 06/2010
#If  instr(1,[F:ITM]ITMREF," ")>0
#& | instr(1,[F:ITM]ITMREF,";")>0
#& | instr(2,[F:ITM]ITMREF,"_")>0   : # "_" autorisé en 1er caractère pour n° temporaire
Local Char WCHRES(GLONITM)
Local Char WCH(GLONITM)
WCH=[F:ITM]ITMREF
WCHRES=format$("KV4:"+num$(min(len(WCH),GLONITM))+"c",WCH)
If WCH<>WCHRES
  GMESSAGE = mess(61,188,1)-"["+[F:ITM]ITMREF+"]"
  GOK = 0 : GERR = 2
Endif
Return

