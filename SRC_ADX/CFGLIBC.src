#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################
# ACTIONS 'Traitement standard'
#
# SAICFGSCS    : Saisie reponses sous scenarios
# SAICFGVAL    : Validation d'un scenario
#
# CFGLIBC Version: 0011
############################################################
# Actions 'Saisie fenetre'
#
# SAICFG       : Execution scenario en autonome
# SAICFGREC    : Recherche historique
# SAICFGRECM   : Recherche historique simple
############################################################
# Issue 82300 CQU 8c => 10c mid$(W_VAR,3,8) devient mid$(W_VAR,3,GLONCQU)
############################################################
# Traitement selections
$ACTION
# Point d'entree generique actions gestion du configurateur CFG_+ACTION
# Ne pas oublier de tester GACTION dans le point d'entree
# Mettre GPE <> 0 pour inhiber l'action standard
#
Global Char GPOINT(30)
GPOINT = "CFG_"+ACTION
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE <> 0
  Return
Endif
#
Case ACTION
  When "INIT" :
    Case GACTION
      When "SAICFGVAL"    : Gosub INIT_CFGVAL
      When "SAICFGSCS"    : Gosub INIT_CFGSCS
    Endcase
  When "TITRE"
    Case GACTION
      When "SAICFGSCS"    : Gosub TITRE_CFGSCS
    Endcase
  When "OUVRE" :
    Case GACTION
      When "SAICFG"       : Gosub OUVRE_CFG
      When "SAICFGVAL"    : Gosub OUVRE_CFGVAL
      When "SAICFGREC"    : Gosub OUVRE_CFGREC
      When "SAICFGRECM"   : Gosub OUVRE_CFGRECM
      When "SAICFGSCS"    : Gosub OUVRE_CFGSCS
    Endcase
  When "DEBUT" :
    Case GACTION
      When "SAICFG"       : Gosub DEBUT_CFG
      When "SAICFGVAL"    : Gosub DEBUT_CFGVAL
      When "SAICFGREC"    : Gosub DEBUT_CFGREC
      When "SAICFGRECM"   : Gosub DEBUT_CFGRECM
      When "SAICFGSCS"    : Gosub DEBUT_CFGSCS
    Endcase
  When "OK" :
    Case GACTION
      When "SAICFG"       : Gosub OK_CFG
      When "SAICFGVAL"    : Gosub OK_CFGVAL
      When "SAICFGSCS"    : Gosub OK_CFGSCS
     Endcase
  When "EDI" :
    Case GACTION
      When "SAICFGVAL"    : Gosub EDI_CFGVAL
                            Call IMPSCR From ATRTX3
                            ACT=""      # JPJ E18018 - Eviter l'édition par le std (via report1)
    Endcase
  When "END" :
    Case GACTION
      When "SAICFG"       : Gosub END_CFG
      When "SAICFGVAL"    : Gosub END_CFGVAL
      When "SAICFGSCS"    : Gosub END_CFGSCS
      When "SAICFGREC"    : Gosub END_CFGREC
      When "SAICFGRECM"   : Gosub END_CFGRECM
    Endcase
  When "SETBOUT" :
    Case GACTION
      When "SAICFG"       : Gosub SETBOUT_CFG
      When "SAICFGVAL"    : Gosub SETBOUT_CFGVAL
      When "SAICFGREC"    : Gosub SETBOUT_CFGREC
      When "SAICFGRECM"   : Gosub SETBOUT_CFGRECM
      When "SAICFGSCS"    : Gosub SETBOUT_CFGSCS
    Endcase
  When "AVANT_BOUTON" :    # CCC 41021
    Case  GACTION
      When "SAICFGREC"    : Gosub AVBOUT_CFGREC
    Endcase
  When "BOUTON" :
    Case  GACTION
      When "SAICFG"       : Gosub BOUTON_CFG
      When "SAICFGVAL"    : Gosub BOUTON_CFGVAL
      When "SAICFGREC"    : Gosub BOUTON_CFGREC
      When "SAICFGRECM"   : Gosub BOUTON_CFGRECM
    Endcase
  When "FIN" :
    Case GACTION
      When "SAICFG"       : Gosub FIN_CFG
      When "SAICFGVAL"    : Gosub FIN_CFGVAL
    Endcase
Endcase
Return
############################################################
# Action SAICFG Execution d'un scenario en autonome
############################################################
$OUVRE_CFG
# Effacement variables globales configurateur si fin anormale dans appel precedent
If dim(S_CFGCFG) > 0
  Gosub SUP_GLOBALES From WUVAR
Endif
If clalev([F:CSC]) = 0 : Local File CFGSCE    [CSC] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY  [FCY] : Endif
#
If clalev([M:CFW]) = 0 : Local Mask CFGWRK     [CFW] : Endif
If clalev([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
Raz [M:CFW]
Return
############################################################
$DEBUT_CFG
Gosub CFG_CONSTANTES From CFGLIB
Gosub CHARGE_PARAM_SAICFG From CFGLIBC1 # Issue 82989 GA 06/2012 source trop long

Affzo [M:CFGF]
Setmok [M:CFGF] With 0     # JPJ E26322
Return
############################################################
$SETBOUT_CFG
# Pour version 122
If [M:CFGF]SCENUM = ""
  ETABOU(GSPE1) = 0
Else
  ETABOU(GSPE1) = 1
Endif
Return
############################################################
$BOUTON_CFG
Return
############################################################
$OK_CFG
FIN = 0
Return
############################################################
$END_CFG
Raz [M:CFGF]
Return
############################################################
$FIN_CFG
Raz [M:CFGF]
Return
############################################################
############################################################
# Validation d'un scenario
############################################################
$INIT_CFGVAL
Local Integer WRET         # JPJ E21934 - Protection par symbole logique
Local Char WMSG(250)
Call LOCK_CFGSYM(WRET,WMSG) From SUBCFG
If WRET : FIN=1 : Endif    # JPJ E21934 <-

If [F:CSC]VALDSY = 2
  If clalev([M:CFV0]) = 0 : Local Mask CFGVAL0 [CFV0] : Endif
  If clalev([M:CFV1]) = 0 : Local Mask CFGVAL1 [CFV1] : Endif
  If clalev([M:CFV2]) = 0 : Local Mask CFGVAL2 [CFV2] : Endif
  If clalev([M:CFV3]) = 0 : Local Mask CFGVAL3 [CFV3] : Endif
  If clalev([M:CFV4]) = 0 : Local Mask CFGVAL4 [CFV4] : Endif
  If clalev([M:CFV9]) = 0 : Local Mask CFGVAL9 [CFV9] : Endif
  Gosub OUVRE_CFGVAL
  Gosub DEBUT_CFGVAL
  # W_I = 2        JPJ: le but étant d'éviter un affichage pour gagner un OK,
  #                    la question suivante est supprimée
  # Call OUINON(mess(175,188,1),W_I) From GESECRAN
  #If W_I = 1
  #  Gosub END_CFGVAL
  #Else
    Gosub GENERATION_CFGVAL
    Call UNLOCK_CFGSYM() From SUBCFG        # JPJ E21934 - Protection par symbole logique
  # FQ 47501 GA 05/2008 supprimer la config générée si on est en mode Test scénario
    If GFONCTION="GESCFG"   Gosub END_CFGVAL Endif
  #Endif
  BOITE = ""
  FIN   = 1
Else
  W_J = 0
  For W_I = 0 To [M:CFW]NBLIG-1
    If [M:CFW]WRKPHA(W_I) = 1
      Read [ITM]ITM0=[M:CFW]WRKITMREF(W_I)
      If fstat = 0
        If W_J < dim(S_ITMSEL)-1
          W_J = 1
          Break
        Endif
      Endif
    Endif
  Next W_I
  If W_J = 0
    BOITE = "ICFGVAL"
  Else
    BOITE = "ICFGVALS"
  Endif
Endif
# Point d'entree initialisation validation scenario
GPOINT = "INIVAL"
Gosub ENTREE From EXEFNC
Return
############################################################
$OUVRE_CFGVAL
Local Integer WRET         # JPJ E21934
Local Char WMSG(250)
Return
############################################################
$DEBUT_CFGVAL
W_TRASTP=mess(189,188,1)-"($DEBUT_CFGVAL)" : Gosub TRA_STEP From CFGLIBB     # Validation : Début de la procédure
Gosub CFG_CONSTANTES From CFGLIB
#
Local Char    W_UND(10)       : W_UND = "__________"
Local Char    W_LEV(30)
Local Char    W_BOMITM(30)(dim(S_CMPSEL))
Local Char    W_BOMCPN(30)(dim(S_CMPSEL))
Local Integer W_BOMSEQ    (dim(S_CMPSEL))
Local Integer W_BOMLEV    (dim(S_CMPSEL))
Local Decimal W_BOMQTY    (dim(S_CMPSEL))
Local Integer W_GCONSULT      : W_GCONSULT = GCONSULT
#
S_UPDMOD = 1
# Mode calcul cout
W_CSTMOD=0    # aucun
If find([F:CSC]CSTCOD, 5,6,9) : W_CSTMOD=1 : Endif    # Module Controle de gestion
If find([F:CSC]CSTCOD, 3,7,8) : W_CSTMOD=2 : Endif    # Scénario

# Issue 107692 - 2015-06-26 by GA Kill replaced by Raz + new variable G_CFGRNG
# Issue 106132 & 106915 GA 03/2015
If dim(G_CFGWIN)>0 Raz G_CFGWIN Endif
If dim(G_CFGRNG)>0 Raz G_CFGRNG Endif

# Chargement composes selectionnes
W_TRASTP=mess(201,188,1) : Gosub TRA_STEP From CFGLIBB     # Validation: Composés sélectionnés
Raz S_ITMSEL
Raz [M:CFV0]
Raz [M:CFV1]
Raz [M:CFV2]
Raz [M:CFV3]
Raz [M:CFV4]
Raz [M:CFV9]

[M:CFV0]          = [F:CSC]
[M:CFV0]          = [F:FCY]
[M:CFV0]BPRNUM    = [F:BPR]BPRNUM
[M:CFV0]BPRNAM    = [F:BPR]BPRNAM(0)
[M:CFV0]BPRREF    = S_BPRREF
[M:CFV1]ROUALTALP = num$([F:CSC]ROUALT)
[M:CFV3]MAXLTI    = 0
GCONSULT          = 1
W_J   = 0
W_ITS = 0
For W_I = 0 To [M:CFW]NBLIG-1
  If [M:CFW]WRKPHA(W_I) = 1
    Read [ITM]ITM0=[M:CFW]WRKITMREF(W_I)
    If fstat = 0
      If W_J < dim(S_ITMSEL)-1
        S_ITMSEL(W_J) = [M:CFW]WRKITMREF(W_I)
        W_J  += 1
        W_ITS = 1
      Endif
      If [M:CFV1]NBLIG1 < dim([M:CFV1]ITMREF)-1
        [M:CFV1]ITMREF ([M:CFV1]NBLIG1) = [F:ITM]ITMREF
        #[M:CFV1]ITMDES1([M:CFV1]NBLIG1) = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFV1]ITMDES1([M:CFV1]NBLIG1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [M:CFV1]ITMNEW ([M:CFV1]NBLIG1) = 1
        [M:CFV1]STU    ([M:CFV1]NBLIG1) = [F:ITM]STU
        [M:CFV1]TCLCOD ([M:CFV1]NBLIG1) = [F:ITM]TCLCOD
        [M:CFV1]CFGLIN ([M:CFV1]NBLIG1) = [F:ITM]CFGLIN
        W_BES = [M:CFW]WRKQTYSTU(W_I)
        Call RNDQTY([F:ITM]STU,W_BES)
        [M:CFV1]QTYSTU ([M:CFV1]NBLIG1) = W_BES
        [M:CFV1]CSTTYP([M:CFV1]NBLIG1) = 1    # Init: pas de calcul
        # Calcul coût des composées sélectionnés - sans les modes 1(aucun)  et 8(Eva formule) (JPJ)
        If find([F:CSC]CSTCOD, 3,5,6,7,9)
            Call CAL_CST(0,[F:CSC]CSTCOD,S_FCY,[F:ITM]ITMREF,S_IPTDAT,S_CUR,W_CST,W_RET) From CFGLIBD
            Call UPDFLD_CSTTYP([F:CSC]CSTCOD,[M:CFV1]CSTTYP([M:CFV1]NBLIG1),W_RET, W_CST ) From CFGLIBD     # maj ecran  (JPJ)
            [M:CFV1]CST    ([M:CFV1]NBLIG1) = W_CST
            [M:CFV1]CSTTOT ([M:CFV1]NBLIG1) = W_CST*W_BES
            S_CSTTOT += (W_CST*W_BES)
        Endif
        [M:CFV1]REFITM ([M:CFV1]NBLIG1) = [F:ITM]CFGITMREF
        W_BMS = 0
        W_LEV = ""
        Gosub LOA_STOCK
        [M:CFV1]NBLIG1 += 1
      Endif
    Endif
  Endif
Next W_I
#
# Si selections effectuees ou parametre pas de creation de compose : fin de scenario
If W_ITS > 0 | [F:CSC]ITMFLG <> 2
  Goto DEBUT_CFGVAL40
Endif

############################################################
Call DEBTRANS From GLOCK     # JPJ E21919 (déplacement pt de reprise)
$DEBUT_CFGVAL00_REP          #  point de reprise suite GOK=-1
GOK      = 1                  # JPJ E21919    Repositionnement de variables suite à GOK=-1
GERR=0  : GMESSAGE=""         # JPJ E21557
W_ERR=0 : W_MSG=""            # JPJ E21557
FIN=0                         # JPJ E21557
W_TRANSFLG=0                 # Flag de gestion identifiant le DEBTRANS
S_UPDMOD=2                   # S_UPDMOD=1 a été remplacé car MEI_VARIABLES peut faire une maj base (compteur)
S_ABORT=0
Trbegin [ITM] #Trbegin déplacer pour la même raison
############################################################
# Mise en mode mise a jour et en fin de saisie
# Traitement Phase 1 : Onglet début du scénario
W_TRASTP=mess(202,188,1) : Gosub TRA_STEP From CFGLIBB     # Validation: Paramètres composé
Gosub MEI_VARIABLES From CFGLIBB
If GOK<1 : Goto DEBUT_CFGVAL_FIN : Endif
#
S_PHASE = 1
S_SEQ   = 0
S_LIN   = 0
Raz [M:CFP]PILSTR
For [M:CFP]PILIND = 0 To [M:CFP]NBLIG-1
  If [M:CFP]PILPHA([M:CFP]PILIND) > 1
    [M:CFP]PILSTR = [M:CFP]PILIND
    Break
  Endif
  If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
    Gosub TRT_SYMBOLE From CFGLIBC1
    If (GOK<>1 | S_ABORT | W_MSG <> "")
      Break
    Endif
  Endif
Next [M:CFP]PILIND
If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
If W_MSG <> ""
  GMESSAGE = W_MSG
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto DEBUT_CFGVAL_FIN
Endif
# Traitement phase 2 Creation compose
W_TRASTP=mess(203,188,1) : Gosub TRA_STEP From CFGLIBB     # Validation: Création composé
S_PHASE = 2
S_SEQ   = 0
S_LIN   = 0
Gosub MEI_BUFFERS From CFGLIBB
If [F:ITM]ITMREF = ""
  GMESSAGE = mess(51,188,1)
  GERR     = 2
  Goto DEBUT_CFGVAL_FIN
Endif
# Issue Xxxxx GA 06/2015 no update on ECC product
If func AFNC.ACTIV("ECC") & func ECCLIB.NBRCPN([F:ITM]ITMREF)
  GMESSAGE = mess(244,188,1)
  GERR     = 2
  Goto DEBUT_CFGVAL_FIN
Endif
If S_ITMQTY = 0
  S_ITMQTY = 1
Else
  Call RNDQTY([F:ITM]STU,S_ITMQTY)
Endif

############################################################
# Debut transaction de creation des donnees
$DEBUT_CFGVAL05
# Issue 107085 GA 03/2015 # New EP to change WNO_UPD_SALCFG &
If dim(WNO_UPD_SALCFG)>0   WNO_UPD_SALCFG=0   Endif
If dim(WNO_DEFAULT_TEXT)>0 WNO_DEFAULT_TEXT=0 Endif
GPOINT = "INICFGVAL" : Gosub ENTREE From EXEFNC
#
W_TRASTP=mess(203,188,1)-"("-mess(188,188,1)-"$DEBUT_CFGVAL05)" : Gosub TRA_STEP From CFGLIBB     # suivi
S_LEVEL  = 0
S_ABORT  = 0
S_SUBSCE = ""
Gosub INI_CPTCFG  # Issue 98480 GA 04/2014 new CFGVCRNUM
# Sauvegardes
W_ITM = [F:ITM]ITMREF
W_TLP = [F:ITM]CFGLIN
Gosub CTL_PARAM_CSC From CFGLIBC1
#
For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
  If [M:CFP]PILPHA([M:CFP]PILIND) > 2
    [M:CFP]PILSTR = [M:CFP]PILIND
    Break
  Endif
# Mise a etat initial buffer
  If [M:CFP]PILPHA([M:CFP]PILIND) <> [M:CFP]PILPHA([M:CFP]PILIND-1) |
&    [M:CFP]PILSEQ([M:CFP]PILIND) <> [M:CFP]PILSEQ([M:CFP]PILIND-1)
    S_PHASE = [M:CFP]PILPHA([M:CFP]PILIND)
    S_SEQ   = [M:CFP]PILSEQ([M:CFP]PILIND)
    S_LIN   = [M:CFP]PILLIN([M:CFP]PILIND)
    Gosub MEI_BUFFERS From CFGLIBB
  Endif
  If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
    Gosub TRT_SYMBOLE From CFGLIBC1
    If (GOK<>1 | S_ABORT | W_MSG <> "")
      Break
    Endif
  Endif
Next [M:CFP]PILIND
#
If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
If W_MSG <> ""
  GMESSAGE = W_MSG
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto DEBUT_CFGVAL_FIN
Endif
#
# Recherche article selon equivalences definies dans la ligne de produit
Read [ITG]ITG0=S_FCY;[F:ITM]TCLCOD
If fstat
  Read [ITG]ITG0="";[F:ITM]TCLCOD
  If fstat
    GMESSAGE = [F:ITM]ITMREF-[F:ITM]TCLCOD-mess(60,188,1)
    Gosub TRA_ERR From CFGLIBB
    GERR     = 1
    FIN      = 1
    Goto DEBUT_CFGVAL_FIN
  Endif
Endif
W_SSC = ""
# Compose de reference
W_RIT = [F:CSC]PARITM
If S_RPAR <> ""
  W_RIT = S_RPAR
Endif
#
Raz S_ITMSEL, S_CURITM        # S_ITMSEL et S_CURITM : le composé courant
W_COM=1                       # W_COM 0: article existant 1: article créé par le configurateur
#
# CCC 41021
If dim(S_SELITM)>0 & S_SELITM<>"" & S_SELITM<>W_RIT
    # FQ 46098 GA 02/2008 S_SELITM contient la réf du composé choisi, mais [F:ITM1] a pu changer
    If S_SELITM<>[F:ITM1]ITMREF
       Read [F:ITM1]ITM0=S_SELITM
       If fstat
          GMESSAGE = S_SELITM-mess(54,188,1)
          Gosub TRA_ERR From CFGLIBB
          GERR     = 1
          FIN      = 1
          Goto DEBUT_CFGVAL_FIN
       Endif
    Endif
    [F:ITM] = [F:ITM1]
    W_COM=0        # Article sélectionné
    S_CURITM=[F:ITM]ITMREF
    Gosub UPD_ARTICLE From CFGLIBC1
    #Goto DEBUT_CFGVAL30 # Issue 90585 GA 06/2013 avant DEBUT_CFGVAL38
    Goto DEBUT_CFGVAL20  # Issue 96588 GA 02/2014 avant DEBUT_CFGVAL30
Endif

# Issue 89191 GA 04/2013
If dim(S_MODITM)>0 & S_MODITM<>""
    If S_MODITM<>[F:ITM1]ITMREF
       Read [F:ITM1]ITM0=S_MODITM
       If fstat
          GMESSAGE = S_MODITM-mess(54,188,1)
          Gosub TRA_ERR From CFGLIBB
          GERR     = 1
          FIN      = 1
          Goto DEBUT_CFGVAL_FIN
       Endif
    Endif
# Issue 112120 - 2016-03-11 by STLIG : Don't re-read product records -
# Overwrites already populated scenario responses.
#    [F:ITM] = [F:ITM1]
    W_COM=0        # Article sélectionné
    Gosub UPD_ARTICLE From CFGLIBC1
    #Goto DEBUT_CFGVAL30 # Issue 90585 GA 06/2013 avant DEBUT_CFGVAL38
    Goto DEBUT_CFGVAL20  # Issue 96588 GA 02/2014 avant DEBUT_CFGVAL30
Endif

Case [F:CSC]SEAPARITM
  When 1 :                                         # Pas de recherche
      Read [ITM1]ITM0=[F:ITM]ITMREF
      If fstat
        Gosub ECR_ARTICLE : If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
      Elsif dim(GVENCFG) > 0 & GVENCFG>0 & dim(WNO_UPD_SALCFG)>0 & WNO_UPD_SALCFG>0
      # Issue 107085 GA 03/2015 no update when creating a sale order
      Else
        # Issue 85211 GA 11/2012 "Référence article existante: voulez-vous effectuer une mise à jour ?"
        Local    Integer  WRET : WRET = 2
        #If !GBATCH & !GSERVEUR                  # Issue 90061 GA 06/2013 reconfiguration en mode batch
        If !GBATCH & !GSERVEUR & S_AUTCFG <> 1   # Issue 90061 GA 08/2013 reconfiguration via automate
            Call OUINON([F:ITM]ITMREF-mess(172,187,1),WRET) From GESECRAN
        Endif
        If WRET=1
         # Issue 104938 GA 01/2015
         # GMESSAGE = [F:ITM]ITMREF-mess(172,187,1)-mess(WRET,1,1) : Gosub TRA_ERR From CFGLIBB
         # GERR = 1 : FIN = 1 : Goto DEBUT_CFGVAL_FIN
          # Issue 106493 GA 05/2015 no creation when generating a sale order and no equivalence
          If dim(GVENCFG)>0 & GVENCFG>0
             W_COM=0 : S_UPDMOD=1
             S_CURITM    = [F:ITM]ITMREF
             S_ITMSEL(0) = S_CURITM
             If [F:CSC]ROUALT>0
                Read [ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY
                If !fstat S_CURROU = S_CURITM Endif
             Endif
             Goto DEBUT_CFGVAL35
          Else
            # Issue 104938 GA 01/2015
            # GMESSAGE = [F:ITM]ITMREF-mess(172,187,1)-mess(WRET,1,1) : Gosub TRA_ERR From CFGLIBB
            # GERR = 1 : FIN = 1 : Goto DEBUT_CFGVAL_FIN
            Raz [F:ITM]ITMREF
            Gosub ECR_ARTICLE : If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
          Endif
        Else
          W_COM=0        # Issue 85211 GA 11/2012 # Article sélectionné
          S_MODITM=[F:ITM]ITMREF          # Issue 89191 GA 05/2013 S_MODITM et S_CURITM comme si on avait repris une config
          W_TRAMSG= mess(75,188,1)+" ("+S_MODITM+")" : Gosub TRA_MSG From CFGLIBB        # Un composé <=> a été sélectionné
          S_CURITM="_"+[F:ITM]ITMREF

          # Issue 113260 - 2016-07-11 by STLIG :
          # Call subroutine to re-APPLY_SYMBOLS to scenario selected S_MODITM product
          Gosub APPLY_SYMBOLS
          If (GOK<>1)
            Goto DEBUT_CFGVAL_FIN
          Endif
          If (W_MSG<>"")
            GMESSAGE=W_MSG
            Gosub TRA_ERR From CFGLIBB
            GERR=1
            FIN=1
            Goto DEBUT_CFGVAL_FIN
          Endif

          Gosub UPD_ARTICLE From CFGLIBC1
          #Goto DEBUT_CFGVAL30 # Issue 90585 GA 06/2013 avant DEBUT_CFGVAL38
          Goto DEBUT_CFGVAL20  # Issue 96588 GA 02/2014 avant DEBUT_CFGVAL30
        Endif
      Endif
  When 2,4 :                                      # Recherche équivalence FQ 46903 GA 11/04/2008
    Call EXI_ARTICLE([F:ITM]CFGLIN,W_RET)
    # Issue 99554 GA 08/2014 If W_RET <> 0 |
    If W_RET <> 0 &
&      ([F:ITM]ITMREF = W_ITM & [F:ITG]ITMREFCOU = "") |
&      ([F:ITM]ITMREF = ""    & [F:ITG]ITMREFCOU = "")
        GMESSAGE = [F:ITM]ITMREF-mess(54,188,1)
        Gosub TRA_ERR From CFGLIBB
        GERR = 1 : FIN = 1 : Goto DEBUT_CFGVAL_FIN
    Elsif [F:ITM1]ITMREF<>"" # Issue 102801 GA 10/2014 only when a equivalence was choosen
        [F:ITM] = [F:ITM1]
    Endif
    # Issue 99554 & 100086 GA 05/2014 check if it's a reconfiguration
    Read [ITM1]ITM0=[F:ITM]ITMREF
    If fstat
      Gosub ECR_ARTICLE : If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
    Elsif dim(GVENCFG) > 0 & GVENCFG>0 & dim(WNO_UPD_SALCFG)>0 & WNO_UPD_SALCFG>0
    # Issue 107085 GA 03/2015 no update when creating a sale order
    Else
      Local    Integer  WRET : WRET = 2
      If !GBATCH & !GSERVEUR & S_AUTCFG <> 1   # Issue 90061 GA 08/2013 reconfiguration via automate
          Call OUINON([F:ITM]ITMREF-mess(172,187,1),WRET) From GESECRAN
      Endif
      If WRET=1
          # Issue 106493 GA 05/2015 no creation when generating a sale order and no equivalence
          If dim(GVENCFG)>0 & GVENCFG>0
             W_COM=0 : S_UPDMOD=1
             S_ITMSEL(0) = [F:ITM]ITMREF
             S_CURITM    = [F:ITM]ITMREF
             If [F:CSC]ROUALT>0
                Read [ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY
                If !fstat S_CURROU = S_CURITM Endif
             Endif
             Goto DEBUT_CFGVAL35
         Else
            # Issue 104938 GA 01/2015
            # GMESSAGE = [F:ITM]ITMREF-mess(172,187,1)-mess(WRET,1,1) : Gosub TRA_ERR From CFGLIBB
            # GERR = 1 : FIN = 1 : Goto DEBUT_CFGVAL_FIN
           Raz [F:ITM]ITMREF
           Gosub ECR_ARTICLE : If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
         Endif
      Else
        W_COM=0        # Issue 85211 GA 11/2012 # Article sélectionné
        S_MODITM=[F:ITM]ITMREF          # Issue 89191 GA 05/2013 S_MODITM et S_CURITM comme si on avait repris une config
        W_TRAMSG= mess(75,188,1)+" ("+S_MODITM+")" : Gosub TRA_MSG From CFGLIBB        # Un composé <=> a été sélectionné
        S_CURITM="_"+[F:ITM]ITMREF
        Gosub UPD_ARTICLE From CFGLIBC1
        Goto DEBUT_CFGVAL20  # Issue 96588 GA 02/2014 avant DEBUT_CFGVAL30
      Endif
   Endif
  When 3 :                                                       # Créer tj
    If ([F:ITM]ITMREF = W_ITM & [F:ITG]ITMREFCOU = "") |
&      ([F:ITM]ITMREF = ""    & [F:ITG]ITMREFCOU = "")
      GMESSAGE = [F:ITM]ITMREF-mess(54,188,1)
      Gosub TRA_ERR From CFGLIBB
      GERR = 1 : FIN = 1 : Goto DEBUT_CFGVAL_FIN
    Else
      Read [ITM1]ITM0=[F:ITM]ITMREF
      If fstat = 0
        GMESSAGE = mess(61,188,1)-"["+[F:ITM]ITMREF+"]"      # Le paramétrage ne permet pas de créer un nouvel article
        Gosub TRA_ERR From CFGLIBB
        GERR = 1 : FIN = 1 : Goto DEBUT_CFGVAL_FIN
      Else
        Gosub ECR_ARTICLE : If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
      Endif
    Endif
Endcase
#
If GOK <> 1
  Gosub TRA_ERR From CFGLIBB
  GERR = 1
  Goto DEBUT_CFGVAL_FIN
Endif
############################################################
$DEBUT_CFGVAL08
# Chargement du compose
S_ITMSEL(0)   = [F:ITM]ITMREF
S_CURITM      = [F:ITM]ITMREF
############################################################
# Controle article n'a pas de nomenclature
W_BOH = 0
W_SEQ = 0
Gosub CTL_PARAM_CSC From CFGLIBC1

W_TRASTP=mess(200,188,1)-"($DEBUT_CFGVAL08)" : Gosub TRA_STEP From CFGLIBB     # Affichage composé

Read [BOH]BOH0=[F:ITM]ITMREF;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
# nota: Sur un article en reprise config, cela fonctionne car on travaille temporairement sur
#       le nouvel article.
If fstat = 0
  # FQ 43622 GA 11/2007
  # en modif d'un article [sans reprise de config] et si le scénario le prévoit,
  # il faut aussi mettre à jour la nomenclature
  If [F:CSC]CMPFLG=2 & [F:BOH]CFGVCRNUM<>""  # forcer la maj auto de la nomenclature
    W_ITMS   = W_ITM :  W_CPTS   = S_CPTCFG : # sauvegarde des valeurs courantes
    W_ITM    = [F:ITM]ITMREF
    S_CPTCFG = [F:BOH]CFGVCRNUM
    Gosub DEL_NOMENCL
    W_ITM    = W_ITMS :  S_CPTCFG = W_CPTS  : # restauration des valeurs courantes
  Else
    Goto DEBUT_CFGVAL10
  Endif
  # FIN - FQ 43622 GA 11/2007
Endif
#
# Issue 89191 code déplacé pour appel depuis CFGLIBC1
Gosub CREATE_BOM
If (GOK <> 1 | GERR=1) : Goto DEBUT_CFGVAL_FIN : Endif
#
If W_MSG <> ""
  GMESSAGE = W_MSG
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto DEBUT_CFGVAL_FIN
Endif
############################################################
# Traitement gamme operatoire
$DEBUT_CFGVAL10
W_TRASTP=mess(186,188,1)-"($DEBUT_CFGVAL10)" : Gosub TRA_STEP From CFGLIBB     # suivi
Gosub CTL_PARAM_CSC From CFGLIBC1
S_CURROU = ""
W_ROH    = 0
If [F:CSC]ROUFLG <>  2
  Goto DEBUT_CFGVAL30
Endif
Read [ITM]ITM0=S_CURITM
If fstat = 0
  W_UOM = [F:ITM]STU
Else
  W_UOM = ""
Endif
Read [ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY   : # Beryl Site en fin de clé primaire
If fstat = 0
  S_CURROU = S_CURITM
  Goto DEBUT_CFGVAL30
Endif
#
# Issue 89191 code déplacé pour appel depuis CFGLIBC1
Gosub CREATE_ROUTING
If (GOK <> 1 | GERR=1) : Goto DEBUT_CFGVAL_FIN : Endif
#
If W_MSG <> ""
  GMESSAGE = W_MSG
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto DEBUT_CFGVAL_FIN
Endif
# Fin de traitement des operations

$DEBUT_CFGVAL20
If [F:CSC]ROUFLG <>  2
  Goto DEBUT_CFGVAL30
Endif
# Si des parametres jalonnement existent        : contrôle jalonnement
# Si des parametres jalonnement n'existent pas  : generation jalonnement par defaut si incorrect
If W_ROH <> 0
  If [M:CFP]PILSCD <> 0
    Gosub CTR_JALONNEMENT
    If GOK <> 1
      Goto DEBUT_CFGVAL_FIN
    Endif
    If W_MSG <> ""
      # Issue 84828 GA 11/2012 pas de message si batch ou PE programmé
      GPE=0 : GPOINT = "DELMESS" : Gosub ENTREE From EXEFNC
      If !GPE & !GBATCH
          # Non géré comme erreur bloquante donc message
          GMESSAGE = [F:ROH]ITMREF-num$([F:ROH]ROUALT)-W_MSG
          Call MESSAGE(GMESSAGE) From GESECRAN                # MESSAGE et non pas ERREUR car avertissement à l'utilisateur
      Endif
      W_TRAMSG= GMESSAGE : Gosub TRA_MSG From CFGLIBB
#      Call ERREUR(GMESSAGE) From GESECRAN        # Note: L'écriture d'un message provoque l'ouverture de la trace
#      Gosub TRA_ERR From CFGLIBB        # Visible dans la trace et attire l'attention
      GMESSAGE = ""                    # non bloquant pour trt superviseur
      W_MSG    = ""                    # non bloquant pour le configurateur
    Endif
  Else
    Gosub ECR_JALONNEMENT
    If GOK <> 1
      Goto DEBUT_CFGVAL_FIN
    Endif
  Endif
  Affzo [M:ROU3] # Issue 84828 GA 11/2012
Endif
############################################################
$DEBUT_CFGVAL30
W_MSG="" : GOK=1 : GERR=0
# Traitement des sous scenarios
Gosub TRT_SUBSCE From CFGLIBC1
If W_MSG <> ""   # Issue 94492 GA 11/2013
  GMESSAGE = "TRT_SUBSCE:"-W_MSG
  Gosub TRA_ERR From CFGLIBB
  Goto DEBUT_CFGVAL_FIN
Endif
If S_ABORT | GOK <> 1 | GERR<>0 | W_MSG <>""
  GERR     = 1
  FIN      = 1
  Goto DEBUT_CFGVAL_FIN
Endif
############################################################
# Chargement des composants a l'affichage
$DEBUT_CFGVAL35
W_TRASTP=mess(184,188,1)-"($DEBUT_CFGVAL35)" : Gosub TRA_STEP From CFGLIBB     # suivi
Gosub CTL_PARAM_CSC From CFGLIBC1

[M:CFV1]NBLIG2  = 0
[M:CFV3]NBLIG   = 1        # Pour réserver une place au composé
W_J             = 0
#
Read [ITM]ITM0=S_CURITM
If fstat = 0
  Read [BOH]BOH0=S_CURITM;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
  If fstat = 0
    # FGR 01/10/2009 : X3SUIVI57935
    #[M:CFV1]BOMDES    = [F:BOH]BOMDES
    Call LECTEXTRA([M:CFV1]BOMDES,"BOM","BOMDESAXX",[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$([F:BOH]BOMALTTYP)) From ATEXTRA
    [M:CFV1]USESTA    = [F:BOH]USESTA
    [M:CFV1]BOHSTRDAT = [F:BOH]BOHSTRDAT
    [M:CFV1]BOHENDDAT = [F:BOH]BOHENDDAT
    [M:CFV1]BASQTY    = [F:BOH]BASQTY
    [M:CFV1]QTYCOD    = [F:BOH]QTYCOD
    If [F:CSC]BOMDSY = 1    # Pas d'affichage multi-niveaux
      Call EXPLODE_BOM(1,[F:ITM]ITMREF,[F:CSC]BOMALT,[F:CSC]BOMALTTYP,S_IPTDAT,S_ITMQTY,W_BOMITM,W_BOMCPN,W_BOMSEQ,W_BOMLEV,
&                      W_BOMQTY,W_RET) From CFGLIBD
    Else                    # Avec affichage multi-niveaux
      Call EXPLODE_BOM(0,[F:ITM]ITMREF,[F:CSC]BOMALT,[F:CSC]BOMALTTYP,S_IPTDAT,S_ITMQTY,W_BOMITM,W_BOMCPN,W_BOMSEQ,W_BOMLEV,
&                      W_BOMQTY,W_RET) From CFGLIBD
    Endif
    # Recherche du premier indice libre dans S_CMPSEL car déjà chargée par les sous-scénarios
     For W_J = 0 To  dim(S_CMPSEL)-1
        If S_CMPSEL(W_J) = ""
          Break
        Endif
     Next W_J
    # Affichage
    For W_K = 0 To dim(W_BOMITM)-1
      If W_BOMITM(W_K) <> ""
        Read [BOD]BOD0=W_BOMITM(W_K);[F:CSC]BOMALT;W_BOMSEQ(W_K);W_BOMCPN(W_K);[F:CSC]BOMALTTYP
        If fstat = 0
          # Ajout composants du 1er niveau
          If W_BOMLEV(W_K) = 1 & W_J < dim(S_CMPSEL)-1
            S_CMPSEL(W_J) = [F:BOD]CPNITMREF
            W_J += 1
          Endif
          If [M:CFV1]NBLIG2 < dim([M:CFV1]BOMSEQ)-1
            Read [ITM]ITM0=[F:BOD]CPNITMREF
            If fstat = 0
              If W_BOMLEV(W_K) > 0
                If W_BOMLEV(W_K) < 10
                  [M:CFV1]BOMLEV  ([M:CFV1]NBLIG2) = left$(W_UND,W_BOMLEV(W_K)-1)+num$(W_BOMLEV(W_K))
                Else
                  [M:CFV1]BOMLEV  ([M:CFV1]NBLIG2) = left$(W_UND,8)+num$(W_BOMLEV(W_K))
                Endif
              Else
                [M:CFV1]BOMLEV  ([M:CFV1]NBLIG2) = ""
              Endif
              [M:CFV1]BOMSEQ    ([M:CFV1]NBLIG2) = [F:BOD]BOMSEQ
              [M:CFV1]CPNITMREF ([M:CFV1]NBLIG2) = [F:BOD]CPNITMREF
              [M:CFV1]PARITM    ([M:CFV1]NBLIG2) = [F:BOD]ITMREF
              #[M:CFV1]CPNITMDES1([M:CFV1]NBLIG2) = [F:ITM]ITMDES1
              Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFV1]CPNITMDES1([M:CFV1]NBLIG2), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
              If [F:ITM]CFGVCRNUM = S_CPTCFG
                [M:CFV1]CPNNEW ([M:CFV1]NBLIG2) = 2
              Else
                [M:CFV1]CPNNEW ([M:CFV1]NBLIG2) = 1
              Endif
              [M:CFV1]CPNSTU    ([M:CFV1]NBLIG2) = [F:ITM]STU
              [M:CFV1]CPNTCLCOD ([M:CFV1]NBLIG2) = [F:ITM]TCLCOD
              [M:CFV1]CPNCFGLIN ([M:CFV1]NBLIG2) = [F:ITM]CFGLIN
              [M:CFV1]LIKQTYCOD ([M:CFV1]NBLIG2) = [F:BOD]LIKQTYCOD
              [M:CFV1]LIKQTY    ([M:CFV1]NBLIG2) = [F:BOD]LIKQTY
              [M:CFV1]CPNREFITM ([M:CFV1]NBLIG2) = [F:ITM]CFGITMREF
              W_BES = W_BOMQTY(W_K)
              Call RNDQTY([F:ITM]STU,W_BES)
              [M:CFV1]LIKQTYCLC ([M:CFV1]NBLIG2) = W_BES     # Pour calcul Controle de gestion en fin de validation (JPJ)
              W_BMS = [F:BOD]BOMSEQ
              W_LEV = [M:CFV1]BOMLEV ([M:CFV1]NBLIG2)
              # Chargement mask CFV3
              Gosub LOA_STOCK
              # Coûts -
                Case W_CSTMOD
                  When 1 :  # coûts traités par le calcul controle de gestion
                    W_CST=0     #  nota: l'affichage est géré en fin de ce calcul
                  When 2 :   # Prix de base, Derniers prix, Formules (mode configurateur)
                    # Calcul normal (niveau 1 et pas article configurateur)
                    If ([F:ITM]CFGVCRNUM <> S_CPTCFG & W_BOMLEV(W_K) = 1 )
                      # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                        Call CAL_CST(1,[F:CSC]CSTCOD,S_FCY,[F:ITM]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                    Else  # Recherche coût issu d'un sous-scénario
                        Call CAL_BYSUBSCE(W_BOMLEV(W_K)-1,[BOD]ITMREF,[F:BOD]CPNITMREF,[F:BOD]BOMSEQ,W_CST,W_RET) From CFGLIBD
                    Endif
                    Call UPDFLD_CSTTYP([F:CSC]CSTCOD,[M:CFV1]CPNCSTTYP([M:CFV1]NBLIG2),W_RET, W_CST ) From CFGLIBD     # maj ecran  (JPJ)
                  When Default
                    [M:CFV1]CPNCSTTYP([M:CFV1]NBLIG2) = 1    # pas de calcul
                    W_CST=0
              Endcase
              [M:CFV1]CPNCST    ([M:CFV1]NBLIG2) = W_CST        # Affichage
              [M:CFV1]CPNCSTTOT ([M:CFV1]NBLIG2) = (W_CST*W_BES)
              # Ajouts des composants du niveau 1
              If W_BOMLEV(W_K) = 1
                   S_CSTMAT += (W_CST*W_BES)
                   S_CSTTOT += (W_CST*W_BES)
              Endif
              #
              [M:CFV1]NBLIG2 += 1
            Endif
          Endif
        Endif
      Else
        Break
      Endif
    Next W_K

    # Calcul LLC pour utiliser la fonction 'Calcul' du module Contrôle de gestion
    # Non nécessaire dans les autres cas car recalculer en génération
    # FQ 75675 GA erreur Write ITB si pas de BOMALT au niveau du scénario
    ### If W_CSTMOD=1
    ###     GMESSAGE=mess(177,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi "Calcul code de plus bas niveau"
    ###     Gosub WRITE_ITB From LLCLIB
    ### Endif
    If W_CSTMOD=1 & [F:CSC]BOMALT>0
        GMESSAGE=mess(177,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi "Calcul code de plus bas niveau"

        Gosub MAJ_ALLITB From CFGLIBD    # préparation ITB
        If GOK = 1
            GNIV=0    # niveau de départ
            Call LLCUPD(S_CURITM,[F:CSC]BOMALT,[F:CSC]BOMALTTYP,"+") From LLCLIB
            If GOK=-1
                Goto DEBUT_CFGVAL_FIN
            Elsif GOK=0
                GMESSAGE=mess(178,188,1) : Gosub TRA_ERR From CFGLIBB
                GERR=1 : FIN=1 : Goto DEBUT_CFGVAL_FIN
            Endif
        Elsif GOK=-1
            Goto DEBUT_CFGVAL_FIN
        Else
            GMESSAGE=mess(178,188,1) : Gosub TRA_ERR From CFGLIBB
            GERR=1 : FIN=1 : Goto DEBUT_CFGVAL_FIN
        Endif
    Endif
  Endif
Endif
# Chargement operations a l'affichage
W_TRASTP=mess(204,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi
If [F:CSC]ROUFLG = 2 & S_CURROU <> ""
  Read [ROH]ROH0=S_CURROU;[F:CSC]ROUALT;S_FCY   : # Beryl Site en fin de clé primaire
  If fstat
    Raz [F:ROH]
  Endif
  [M:CFV2]NBLIG1 = 0
  [M:CFV2] = [F:ROH]
  Read [ITM1]ITM0=[F:ROH]ITMREF
  If fstat = 0
    #[M:CFV2]ITMDES1 = [F:ITM1]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:CFV2]ITMDES1, "[F:ITM1]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Filter [ROO] Where FCY    = [F:ROH]FCY    &
&                      ITMREF = [F:ROH]ITMREF &
&                      ROUALT = [F:ROH]ROUALT
&                Order By Key ROO0
    For [ROO]
      If [M:CFV2]NBLIG1 < dim([M:CFV2]OPENUM)-1
        [M:CFV2]NBLIG1 += 1
        nolign   = [M:CFV2]NBLIG1
        [M:CFV2] = [F:ROO]
        [M:CFV2]CSTMAC(nolign-1) = 0
        [M:CFV2]CSTLAB(nolign-1) = 0
        [M:CFV2]CSTSCO(nolign-1) = 0
        If [F:CSC]CSTCOD = 8 & [F:ROO]WST <> ""
          Read [MWS]WST0=[F:ROO]WST;S_FCY
          If fstat = 0
            W_CST = 0
            Case [F:MWS]WSTTYP
              When 1 :
              # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                Call CAL_CST(2,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                [M:CFV2]CSTMAC(nolign-1) += W_CST
                S_CSTMAC += W_CST
                S_CSTTOT += W_CST
              When 2 :
              # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                Call CAL_CST(3,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                [M:CFV2]CSTLAB(nolign-1) += W_CST
                S_CSTLAB += W_CST
                S_CSTTOT += W_CST
            Endcase
          Endif
        Endif
        If [F:CSC]CSTCOD = 8 & [F:ROO]LABWST <> ""
          Read [MWS]WST0=[F:ROO]LABWST;S_FCY
          If fstat = 0
            W_CST = 0
            Case [F:MWS]WSTTYP
              When 1 :
              # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                Call CAL_CST(2,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                [M:CFV2]CSTMAC(nolign-1) += W_CST
                S_CSTMAC += W_CST
                S_CSTTOT += W_CST
              When 2 :
              # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                Call CAL_CST(3,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                [M:CFV2]CSTLAB(nolign-1) += W_CST
                S_CSTLAB += W_CST
                S_CSTTOT += W_CST
            Endcase
          Endif
        Endif
        If [F:CSC]CSTCOD = 8 & [F:ROO]SCOWST <> "" & [F:ROO]SCOCOD = 2
          Read [MWS]WST0=[F:ROO]SCOWST;S_FCY
          If fstat = 0
            W_CST = 0
          # FQ 58525 GA 10/2009 # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
          # Call CAL_CST(4,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CUR,W_RET) From CFGLIBD
            Call CAL_CST(4,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
            [M:CFV2]CSTSCO(nolign-1) += W_CST
            S_CSTSCO += W_CST
            S_CSTTOT += W_CST
          Endif
        Endif
      Else
        Break
      Endif
    Next
    Filter [ROO]
  Endif
Endif
# Arrondi zones de coûts
S_CSTMAT = arr(S_CSTMAT,10^-GDECPRI)
S_CSTMAC = arr(S_CSTMAC,10^-GDECPRI)
S_CSTLAB = arr(S_CSTLAB,10^-GDECPRI)
S_CSTSCO = arr(S_CSTSCO,10^-GDECPRI)
S_CSTOVE = arr(S_CSTOVE,10^-GDECPRI)
S_CSTTOT = arr(S_CSTTOT,10^-GDECPRI)
#
############################################################
# Gestion dans le cas d'un calcul des coûts par module Contrôle de gestion
If  W_CSTMOD=1
    W_TRASTP=mess(205,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi
    # Préparation compose cree (pour permettre un affichage mini si pb)
    Read [ITM]ITM0=S_CURITM
    # Chargement ecran resultat
    [M:CFV1]NBLIG1 = 0
    [M:CFV1]ITMREF ([M:CFV1]NBLIG1) = [F:ITM]ITMREF
    #[M:CFV1]ITMDES1([M:CFV1]NBLIG1) = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFV1]ITMDES1([M:CFV1]NBLIG1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    If [F:ITM]CFGVCRNUM = S_CPTCFG
      [M:CFV1]ITMNEW ([M:CFV1]NBLIG1) = 2
    Else
      [M:CFV1]ITMNEW ([M:CFV1]NBLIG1) = 1
    Endif
    [M:CFV1]STU    ([M:CFV1]NBLIG1) = [F:ITM]STU
    [M:CFV1]TCLCOD ([M:CFV1]NBLIG1) = [F:ITM]TCLCOD
    [M:CFV1]CFGLIN ([M:CFV1]NBLIG1) = [F:ITM]CFGLIN
    [M:CFV1]QTYSTU ([M:CFV1]NBLIG1) = S_ITMQTY
    [M:CFV1]REFITM ([M:CFV1]NBLIG1) = [F:ITM]CFGITMREF
    [M:CFV1]NBLIG1 += 1
    #
    GMESSAGE=mess(194,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi
    W_TRAMSG=mess(195,188,1)-"GOK:"-num$(GOK)-"GERR:"-num$(GERR)-"S_ABORT:"-num$(S_ABORT)
&         -"W_COM:"-num$(W_COM)-"W_TRANSFLG:"-num$(W_TRANSFLG) : Gosub TRA_MSG From CFGLIBB     # suivi

    # Normallement à ce niveau GOK=-1 ne devrait pas exister mais protection
    # If GUSER="JPJ1" : GOK=-1 : GLOCK="$ITMMASTER-mon blocage" : GMESSAGE=GLOCK : Gosub TRA_ERR From CFGLIBB : Infbox("BLOCAGE test") : Endif

    Case GOK
    When -1 :
        Rollback
        W_TRAMSG=mess(179,188,1)-"("-GLOCK-")"    # sauv. info trace sur lock (Roll: raz Glock)
        Call ROLL     From GLOCK
        If GROLL
            GMESSAGE=W_TRAMSG                         # info trace sur lock
            Gosub TRA_ERR From CFGLIBB
            GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
            GMESSAGE+="\"+mess(236,188,1) : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentative par utilisateur
            Goto DEBUT_CFGVAL_END                     # End
        Else
            W_TRAMSG=mess(182,188,1)   # info trace - nelle tentative
            Gosub TRA_MSG From CFGLIBB
            GOK=1
            #
            Gosub LOA_PILE From CFGLIBB        # Rechargement (JPJ)
            Raz [M:CFP]PILSTR                  # Restauration pile dans la phase de création de compôsé
            For [M:CFP]PILIND = 0 To [M:CFP]NBLIG-1
                If [M:CFP]PILPHA([M:CFP]PILIND) > 1
                [M:CFP]PILSTR = [M:CFP]PILIND
                Break
                Endif
            Next
            Goto DEBUT_CFGVAL00_REP
        Endif
    When 1 :
         #  Faire le commit et l'appel des coûts uniquement si
         #      - pas d'erreur configurateur
         #      - pas d'abandon utilisateur sur un écran de questions sous-scénario
         #      - un composé est créé
         If GERR = 1 | S_ABORT | W_COM=0
            If adxlog Rollback Endif
            W_TRAMSG="  RollBack" : Gosub TRA_MSG From CFGLIBB
            Goto DEBUT_CFGVAL_END                     # End
         Else
            Commit
            W_TRAMSG="  Commit" : Gosub TRA_MSG From CFGLIBB
            #  Calcul
            # - - - - - - - -
                Gosub LOA_CSTMSK   # Chargement onglet coût
                If S_AUTCFG = 0 & [F:CSC]VALDSY <> 2    # Pour permettre de patienter et de commencer à voir des résultats
                    Affzo [CFV4]
                    Affzo [CFV1]
                Endif
                Call CFG_CSTSTD() From CFGLIBD    # Appel du calcul des coûts du module Contrôle de gestion
                For W_L=0 To [M:CFV4]NBLIG-1
                    If W_L=0 : W_TRAMSG=" ."-mess(218,188,1) : Gosub TRA_MSG From CFGLIBB : Endif
                    W_TRAMSG=" . ."-[M:CFV4]ERRCOD(W_L)-[M:CFV4]ERRTXT(W_L) : Gosub TRA_MSG From CFGLIBB
                Next
                If GOK=1
                    If sum([M:CFV4]ERRCOD(0..[M:CFV4]NBLIG))=""    # pas d'erreur grave
                        W_TRAMSG=mess(194,188,1)-"OK"
                    Else
                        W_TRAMSG=mess(219,188,1)
                        Call MESSAGE(W_TRAMSG) From GESECRAN    # info utilisateur
                    Endif
                    Gosub TRA_MSG From CFGLIBB
                    Call DEBTRANS From GLOCK   # Pour les mises à jour qui suivent
                    W_TRANSFLG=1        # Flag de gestion identifiant le DEBTRANS
                Else
                    GMESSAGE=mess(196,188,1)
                    Call ERREUR(GMESSAGE) From GESECRAN
                    Gosub TRA_ERR From CFGLIBB
                    Gosub DEL_CONFIG          # Anomalie: suppression des données générées par la 1er transaction
                    Goto DEBUT_CFGVAL_END     # Pb technique dans le calcul des coûts
                Endif
            # - - - - - - - -
         Endif
        #
    When Default :
        Rollback
        W_TRAMSG="  RollBack" : Gosub TRA_MSG From CFGLIBB
        Goto DEBUT_CFGVAL_END                     # End
    Endcase
Endif

############################################################
# Chargement du compose cree
# Traitement reactualisation du compose si nouvel article
$DEBUT_REAITM
If S_CURITM = "" & S_MODITM<>""  # Issue 104508 GA 12/2014 diagnostic JSO: à valider
   S_CURITM = S_MODITM
Endif
W_TRASTP=mess(206,188,1)-"($DEBUT_REAITM)"-S_CURITM : Gosub TRA_STEP From CFGLIBB     # suivi
If W_TRANSFLG=1 : Trbegin [ITM] : Endif     # Structures en plusieurs transactions
#
Read [ITM]ITM0=S_CURITM
If fstat = 0
  If [F:ITM]CFGVCRNUM = S_CPTCFG
    W_COM = 1
  Endif
  If W_COM = 1
    Raz [M:CFP]PILSTR
    W_I = 0
#
    For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
      If [M:CFP]PILPHA([M:CFP]PILIND) = 2 & [M:CFP]PILCOD([M:CFP]PILIND) = 7
        W_I = 1
      Break
      Endif
    Next [M:CFP]PILIND
    If W_I <> 0
      Gosub REA_COMPOSE
      If W_MSG <> ""
        GMESSAGE = W_MSG
        Gosub TRA_ERR From CFGLIBB
        GERR = 1
        Goto DEBUT_CFGVAL_FIN
      Endif
      If GOK <> 1
       Goto DEBUT_CFGVAL_FIN
      Endif
    Endif
  Endif
Endif

############################################################
$DEBUT_CFGVAL38
If GOK<>1 : Goto DEBUT_CFGVAL_FIN : Endif
W_TRASTP=mess(200,188,1)-"($DEBUT_CFGVAL38)" : Gosub TRA_STEP From CFGLIBB     # Affichage composé
Gosub CTL_PARAM_CSC From CFGLIBC1
# Chargement ecran resultat
[M:CFV1]NBLIG1 = 0
If [F:ITM]ITMREF<>S_CURITM    # Issue 89191 GA 04/2013
   Read [ITM]ITM0=S_CURITM
Endif
[M:CFV1]ITMREF ([M:CFV1]NBLIG1) = [F:ITM]ITMREF

# Issue 113260 - 2016-07-12 by STLIG : Committed translation records do not reflect any description change
[M:CFV1]ITMDES1([M:CFV1]NBLIG1) = [F:ITM]ITMDES1
#Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFV1]ITMDES1([M:CFV1]NBLIG1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189

If [F:ITM]CFGVCRNUM = S_CPTCFG
  [M:CFV1]ITMNEW ([M:CFV1]NBLIG1) = 2
Else
  [M:CFV1]ITMNEW ([M:CFV1]NBLIG1) = 1
  # Affichage écran articles generiques
  If S_GENDES1 <> ""
    [M:CFV1]ITMDES1([M:CFV1]NBLIG1) = S_GENDES1
  Endif
Endif
[M:CFV1]STU    ([M:CFV1]NBLIG1) = [F:ITM]STU
[M:CFV1]TCLCOD ([M:CFV1]NBLIG1) = [F:ITM]TCLCOD
[M:CFV1]CFGLIN ([M:CFV1]NBLIG1) = [F:ITM]CFGLIN
[M:CFV1]QTYSTU ([M:CFV1]NBLIG1) = S_ITMQTY
[M:CFV1]REFITM ([M:CFV1]NBLIG1) = [F:ITM]CFGITMREF
# Prix de base     # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
Call CAL_CST(0,3,S_FCY,[F:ITM]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
If W_RET=0
    [M:CFV1]BASPRI ([M:CFV1]NBLIG1) = W_CST
    [M:CFV1]PRITOT  ([M:CFV1]NBLIG1) = arr(W_CST * S_ITMQTY,10^-GDECPRI)
Endif
# Couts
[M:CFV1]CSTTYP([M:CFV1]NBLIG1)=1
#  1   Coûts calculés par configurateur avec un Article créé par le configurateur
If W_CSTMOD=2 & W_COM=1
        If S_ITMQTY > 0
          [M:CFV1]CST  ([M:CFV1]NBLIG1) = arr(S_CSTTOT/S_ITMQTY,10^-GDECPRI)
        Endif
        [M:CFV1]CSTTOT([M:CFV1]NBLIG1)  = S_CSTTOT
        W_RET=0 : W_CST=S_CSTTOT   # cout calculé (entete)
        [M:CFV1]CSTTYP([M:CFV1]NBLIG1)=6     # maj ecran  (JPJ)
        If S_CSTTOT=0 : [M:CFV1]CSTTYP([M:CFV1]NBLIG1)=7 : Endif
Endif
#  2   Mise à jour résultats coût contrôle de gestion dans les écrans
#     avec un Article créé par le configurateur
If W_CSTMOD=1  & W_COM=1
    Gosub CFG_CSTSTDGET From CFGLIBD
Endif
#  3   Coût pour Article composé issu d'une sélection d'équivalence
If W_COM=0
    # Données prises sur fichiers (non possible en mode 8 )
    If find(W_CSTMOD,1,2) & [F:CSC]CSTCOD<>8
        # Raz W_NUM
        # If W_CSTMOD=1    # Cout controle de gestion
        #     Call RECH_NOCOUT(S_FCY,S_IPTDAT,W_NUM) From TRTCOST        # Recherche de l'année de l'exercice
        # Endif
        Call CAL_CST(0,[F:CSC]CSTCOD,S_FCY,[F:ITM]ITMREF,S_IPTDAT,S_CUR,W_CST,W_RET) From CFGLIBD
        If W_RET<>99
            [M:CFV1]CST ([M:CFV1]NBLIG1) = W_CST
            [M:CFV1]CSTTOT  ([M:CFV1]NBLIG1) = arr(W_CST * S_ITMQTY,10^-GDECPRI)
            [M:CFV1]CSTTYP([M:CFV1]NBLIG1)=2   # Sur article
            If W_RET = 10 : [M:CFV1]CSTTYP([M:CFV1]NBLIG1)= 3 : Endif    # Sur article de référence
            If W_CST=0 : [M:CFV1]CSTTYP([M:CFV1]NBLIG1)=4 : Endif
        Endif
    Endif
Endif
[M:CFV1]NBLIG1 += 1
# Chargement onglet stock ligne 1 pour compose
W_I           = [M:CFV3]NBLIG
[M:CFV3]NBLIG = 0
W_BES = S_ITMQTY
W_BMS = 0
W_LEV = "0"
Gosub LOA_STOCK
[M:CFV3]NBLIG = W_I
#
############################################################
# Chargement valeurs reponses et variables
$DEBUT_CFGVAL40
W_TRASTP=mess(207,188,1)-"($DEBUT_CFGVAL40)" : Gosub TRA_STEP From CFGLIBB     # Affichage
For W_I = 0 To dim(W_VARLAB)-1
  W_VAR = W_VARLAB(W_I)
  If evalue("dim("+W_VAR+")>0")
    Read [CQU]CQU0=mid$(W_VAR,3,GLONCQU)
    If fstat = 0
      Case [F:CQU]QSTTYP
        When 1 :
          If [M:CFV9]NBLIG1 < dim([M:CFV9]QSTNUM)-1
            [M:CFV9]QSTNUM([M:CFV9]NBLIG1) = [F:CQU]QSTNUM
            # FQ 53410 remplacé par le lien
            #[M:CFV9]QSTDES([M:CFV9]NBLIG1) = [F:CQU]QSTDES
            Case [F:CQU]ASWTYP
              When 1 :
                W_J = evalue("dim("+W_VAR+")")
                [M:CFV9]QSTVAL([M:CFV9]NBLIG1) = evalue(W_VAR)
                If [F:CQU]TCT <> ""
                  Read [TCT]TCT1=[F:CQU]TCT;evalue(W_VAR);0
                  If fstat = 0
                    Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
                    [M:CFV9]QSTVAL([M:CFV9]NBLIG1) += (" ("+W_DESTCT+")")
                  Endif
                Endif
                If [F:CQU]SHACAT <> ""
                  Read [CSH]CSH0=[F:CQU]SHACAT;evalue(W_VAR)
                  If fstat = 0
                   # FQ 60007 GA 11/2009 avant [F:CSH]SHANUMDES
                    Call LECTEXTRA(GBIDC1,"CFGSHA","SHANUMAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
                    [M:CFV9]QSTVAL([M:CFV9]NBLIG1) += (" ("+GBIDC1+")")
                  Endif
                Endif
              When 2 :
                [M:CFV9]QSTVAL([M:CFV9]NBLIG1) = num$(evalue(W_VAR))
                If [F:CQU]TCT <> ""
                  Read [TCT]TCT1=[F:CQU]TCT;"";val(num$(evalue(W_VAR)))
                  If fstat = 0
                    Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
                    [M:CFV9]QSTVAL([M:CFV9]NBLIG1) += (" ("+W_DESTCT+")")
                  Endif
                Endif
              When 3 :
                [M:CFV9]QSTVAL([M:CFV9]NBLIG1) = num$(evalue(W_VAR))
              When 4 :
                [M:CFV9]QSTVAL([M:CFV9]NBLIG1) = mess(val(num$(evalue(W_VAR)))+1,1,1)
              When 5 :
                [M:CFV9]QSTVAL([M:CFV9]NBLIG1) = evalue(W_VAR)
                Call EFF_CRLF([M:CFV9]QSTVAL([M:CFV9]NBLIG1)) From CFGLIBD
            Endcase
            [M:CFV9]NBLIG1 += 1
          Endif
        When 2, 3 :
          If [M:CFV9]NBLIG2 < dim([M:CFV9]VARNUM)-1
            [M:CFV9]VARNUM([M:CFV9]NBLIG2) = [F:CQU]QSTNUM
            [M:CFV9]VARTYP([M:CFV9]NBLIG2) = [F:CQU]QSTORI
            # FQ 53410 remplacé par le lien
            #[M:CFV9]VARDES([M:CFV9]NBLIG2) = [F:CQU]QSTDES
            Case [F:CQU]ASWTYP
              When 1 :
                W_J = evalue("dim("+W_VAR+")")
                [M:CFV9]VARVAL([M:CFV9]NBLIG2) = evalue(W_VAR)
                If W_J > 1
                  For W_K = 1 To W_J-1
                    If evalue(W_VAR+"("+num$(W_K)+")<>''")
                      [M:CFV9]VARVAL([M:CFV9]NBLIG2) += (","+evalue(W_VAR+"("+num$(W_K)+")"))
                    Else
                      Break
                    Endif
                  Next W_K
                Endif
                If [F:CQU]TCT <> ""
                  Read [TCT]TCT1=[F:CQU]TCT;evalue(W_VAR);0
                  If fstat = 0
                    Call CFGDESTCT(GBIDC1,W_FLDTCT) From CFGLIB
                    [M:CFV9]VARVAL([M:CFV9]NBLIG2) += (" ("+GBIDC1+")")
                  Endif
                Endif
                If [F:CQU]SHACAT <> ""
                  Read [CSH]CSH0=[F:CQU]SHACAT;evalue(W_VAR)
                  If fstat = 0
                   # FQ 60007 GA 11/2009 avant [F:CSH]SHANUMDES
                    Call LECTEXTRA(GBIDC1,"CFGSHA","SHANUMAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
                    [M:CFV9]VARVAL([M:CFV9]NBLIG2) += (" ("+GBIDC1+")")
                  Endif
                Endif
              When 2 :
                [M:CFV9]VARVAL([M:CFV9]NBLIG2) = num$(evalue(W_VAR))
                If [F:CQU]TCT <> ""
                  Read [TCT]TCT1=[F:CQU]TCT;"";val(num$(evalue(W_VAR)))
                  If fstat = 0
                    Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
                    [M:CFV9]VARVAL([M:CFV9]NBLIG2) += (" ("+W_DESTCT+")")
                  Endif
                Endif
              When 3 :
                [M:CFV9]VARVAL([M:CFV9]NBLIG2) = num$(evalue(W_VAR))
              When 4 :
              # Issue 78899 GA 08/2012 il manquait ajout de +1 sur les valeurs de booléen
                [M:CFV9]VARVAL([M:CFV9]NBLIG2) = mess(val(num$(evalue(W_VAR)))+1,1,1)
              When 5 :
                [M:CFV9]VARVAL([M:CFV9]NBLIG2) = evalue(W_VAR)
                Call EFF_CRLF( [M:CFV9]VARVAL([M:CFV9]NBLIG2)) From CFGLIBD
             Endcase
            [M:CFV9]NBLIG2 += 1
          Endif
      Endcase
    Endif
  Endif
Next W_I
Sorta [M:CFV9]NBLIG2 [M:CFV9]NBLIG2 Order By [M:CFV9]VARTYP(indice), [M:CFV9]VARNUM (indice)
# Ecriture historique configuration sauf si variable NOHIS <> 0
If dim(S_NOHIS) < 0 | S_NOHIS = 0
# Issue 96688 GA 03/2014 déplacé dans CFGLIBC1 car trop d'instructions
  Gosub ECR_HISTORIQUE From CFGLIBC1
Endif
############################################################
# Fin de validation
$DEBUT_CFGVAL_FIN
#
W_TRASTP=mess(183,188,1)-"($DEBUT_CFGVAL_FIN)" : Gosub TRA_STEP From CFGLIBB
#  Mise à jour
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
If S_UPDMOD = 2 # Nota: faux si selection composé
    # Traitement du commit
    W_TRAMSG=mess(195,188,1)-"GOK:"-num$(GOK)-"GERR:"-num$(GERR)-"S_ABORT:"-num$(S_ABORT)
&         -"W_COM:"-num$(W_COM)-"W_TRANSFLG:"-num$(W_TRANSFLG) : Gosub TRA_MSG From CFGLIBB     # suivi
    Case GOK
    When -1 :
        Rollback
        W_TRAMSG=mess(179,188,1)-"("-GLOCK-")"    # sauv. info trace sur lock (Roll: raz Glock)
        Call ROLL     From GLOCK
        If GROLL
            GMESSAGE=W_TRAMSG                     # info trace sur lock
            Gosub TRA_ERR From CFGLIBB
            GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
            GMESSAGE+="\"+mess(236,188,1) : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentative par utilisateur
            Gosub TRA_ERR From CFGLIBB : GMESSAGE=""
            If W_TRANSFLG = 1       # Après Debtrans de la réactualisation
                Gosub DEL_CONFIG    # Anomalie: suppression des données générées par la 1er transaction
            Endif
            Goto DEBUT_CFGVAL_END
        Else
            W_TRAMSG=mess(182,188,1)   # info trace - nelle tentative
            Gosub TRA_MSG From CFGLIBB
            GOK=1
            #
            If W_TRANSFLG = 0       # Après Debtrans en début scénario
                Gosub LOA_PILE From CFGLIBB        # Rechargement (JPJ)
                Raz [M:CFP]PILSTR                  # Restauration pile dans la phase de création de compôsé
                For [M:CFP]PILIND = 0 To [M:CFP]NBLIG-1
                    If [M:CFP]PILPHA([M:CFP]PILIND) > 1
                    [M:CFP]PILSTR = [M:CFP]PILIND
                    Break
                    Endif
                Next
                Goto DEBUT_CFGVAL00_REP
            Else    # Après Debtrans en réactualisation du composé
                # Restauration pile faite dans la fonction
                Goto DEBUT_REAITM
            Endif
        Endif
    When 1 :
         #  Faire le commit uniquement si
         #           - pas d'erreur configurateur
         #           - pas d'abandon utilisateur sur un écran de questions sous-scénario
         #           - un composé est créé
         If GERR = 1 | S_ABORT         # Erreur ou abandon utilisateur
            If adxlog Rollback Endif
            W_TRAMSG="  RollBack" : Gosub TRA_MSG From CFGLIBB
            If W_TRANSFLG = 1           # Après Debtrans de la réactualisation
                Gosub DEL_CONFIG        # Anomalie: suppression des données générées par la 1er transaction
            Endif
            Goto DEBUT_CFGVAL_END
         Elsif W_COM=0              # Composé équivalent
            If adxlog Rollback Endif
            W_TRAMSG="  RollBack" : Gosub TRA_MSG From CFGLIBB
            If W_TRANSFLG = 1           # Après Debtrans de la réactualisation (ne doit pas se produire)
                Gosub DEL_CONFIG        # Suppression des données générées par la 1er transaction
            Else
                Gosub DEL_HISTORIQUE # ????????????
            Endif
         Else
            Commit
            W_TRAMSG="  Commit" : Gosub TRA_MSG From CFGLIBB
         Endif
    When Default :
        Rollback
        W_TRAMSG="  RollBack" : Gosub TRA_MSG From CFGLIBB
        If W_TRANSFLG = 1           # Après Debtrans de la réactualisation
            Gosub DEL_CONFIG        # Anomalie: suppression des données générées par la 1er transaction
        Endif
        Goto DEBUT_CFGVAL_END
    Endcase
Else
  # Issue 108228 GA 05/2015 suite Issue 106493
    If adxlog Rollback Endif
Endif
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#
If (GOK <> 1 | GERR <> 0 ) : Goto DEBUT_CFGVAL_END : Endif
#
If W_COM <> 0
  [M:CFV0]ITMFLG = 2
Else
  [M:CFV0]ITMFLG = 1
Endif
If W_BOH <> 0
  [M:CFV0]CPNFLG = 2
Else
  [M:CFV0]CPNFLG = 1
Endif
If W_ROH <> 0
  [M:CFV0]ROUFLG = 2
Else
  [M:CFV0]ROUFLG = 1
Endif
#
If W_COM = 0 & S_UPDMOD = 2
  GMESSAGE = mess(75,188,1)+" ("+S_CURITM+")"        # Un composé <=> a été sélectionné
  GERR     = 2    # Message
Else
  If S_MODITM <> "" & S_ITMSEL(0) <> S_MODITM        # Le composé affiché a une référence provisoire
                                                     # \Cette réference sera remplacée après génération par :
    GMESSAGE = mess(165,188,1)-S_MODITM
    GERR     = 2
  Endif
Endif
$DEBUT_CFGVAL_END
If S_AUTCFG = 0 & [F:CSC]VALDSY <> 2
  Affzo [M:CFV0]
  Affzo [M:CFV1]
  Affzo [M:CFV2]
  Affzo [M:CFV3]
  Affzo [M:CFV4]
  Affzo [M:CFV9]
  Call UNLOCK_CFGSYM() From SUBCFG        # JPJ E21934 - Protection par symbole logique
Endif
W_TRASTP=mess(183,188,1)-"(return of $DEBUT_CFGVAL_FIN)" : Gosub TRA_STEP From CFGLIBB
W_TRASTP=""    # RAZ contexte
Return

############################################################
$SETBOUT_CFGVAL
ETABOU(GSPE1) = 1
ETABOU(GSPE2) = 1
ETABOU(GSPE3) = 1
ETABOU(GSPE4) = 1
ETABOU(GSPE5) = 1
ETABOU(GSPE6) = 1
ETABOU(GSPE7) = 1
#
If S_ABORT
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 0
  ETABOU(GSPE3) = 0
  ETABOU(GSPE4) = 0
  ETABOU(GSPE5) = 0
  ETABOU(GSPE6) = 0
  ETABOU(GSPE7) = 0
Else
  If GOK <> 1
    ETABOU(GSPE4) = 0
  Else
    ETABOU(GSPE4) = 1
  Endif
  If [M:CFV2]NBLIG1 > 0
    ETABOU(GSPE5) = 1
  Else
    ETABOU(GSPE5) = 0
  Endif
  If [M:CFV4]STOFCY = ""
    ETABOU(GSPE6) = 0
  Else
    ETABOU(GSPE6) = 1
  Endif
  ETABOU(GSPE3) = 1
  ETABOU(GEDIT) = 1
Endif
# Désactivation bouton 'Generation' en mode test depuis gestion scénarios
If GFONCTION = "GESCFG"
  ETABOU(GSPE4) = 0
Endif
Return
############################################################
$BOUTON_CFGVAL
Case BOUT
  When "c" : Gosub EDI_CFGVAL
             Call IMPSCR From ATRTX3
  When "d" :
    Call LOCK_CFGSYM(WRET,WMSG) From SUBCFG        # JPJ E21934 - Protection par symbole logique
    If !WRET
       Gosub GENERATION_CFGVAL
       Call UNLOCK_CFGSYM() From SUBCFG
    Endif
  When "f" :
Endcase
Return
############################################################
$OK_CFGVAL
#
Return
############################################################
$END_CFGVAL
If [F:CSC]VALDSY <> 2
  W_RET = 1
  Call AVERTIR(mess(51,100,1),W_RET) From GESECRAN
  If W_RET = 1
    FIN = 0
    Return
  Endif
Endif
#
If S_UPDMOD = 2
    Call LOCK_CFGSYM(WRET,WMSG) From SUBCFG        # JPJ E21934 - Protection par symbole logique
    If !WRET
       Gosub DEL_CONFIG
       Call UNLOCK_CFGSYM() From SUBCFG
    Else
        FIN = 0
        Return
    Endif
Endif
# Pas de message en mode 'test'
If GFONCTION <> "GESCFG"
#  GMESSAGE = mess(53,188,1)        JPJ: Il s'agit d'une action utilisateur et donc
#  Gosub TRA_ERR From CFGLIBB       il n'est pas nécessaire de la considérer comme une erreur (pas de trace)
#  GERR = 1
  W_TRAMSG=mess(53,188,1)
  Gosub TRA_MSG From CFGLIBB
  GMESSAGE = mess(53,188,1)
  GERR = 2
Endif
GCONSULT = W_GCONSULT
FIN  = 1
#$$$Ligne impactée par test du 28/11/03 Call OUINON("Correction ?",S_RETURN) From GESECRAN
Return
############################################################
$FIN_CFGVAL
Call IMPSCR From ATRTX3
Return
###################################:         # ##            ######
# Chargem        standard
$LOA_CSTMSK
Local Decimal LEXE, LPER
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
Read [ITM]ITM0 = S_ITMSEL(0)
If fstat = 0
  Read [ITF]ITF0=[F:ITM]ITMREF;S_FCY
  If fstat = 0
#    Raz [F:ITC]
#    Filter [ITC] Where STOFCY = S_FCY         &
#&                      ITMREF = [F:ITM]ITMREF &
#&                      CSTTYP = 1             &
#&                      CSTSEQ = 0
#    Read [ITC] Last
#    If fstat = 0
      [M:CFV4]STOFCY    = S_FCY
      [M:CFV4]ITMREF    = [F:ITM]ITMREF
      #[M:CFV4]ITMDES1   = [F:ITM]ITMDES1
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFV4]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      [M:CFV4]STU       = [F:ITM]STU
      Case [F:CSC]CSTCOD
        When 5        # Std
            [M:CFV4]CSTTYP    = 1
            W_ALP="STD"
        When 6        # Actualisé
            [M:CFV4]CSTTYP    = 2
            W_ALP="CUT"
        When 9        # Budget
            [M:CFV4]CSTTYP    = 3
            W_ALP="BUD"
      Endcase
      [M:CFV4]SLTMATCST = evalue("GCLC"+W_ALP+"MAT")
      [M:CFV4]VLTCCERAT = evalue("GCLC"+W_ALP+"RAT")
      [M:CFV4]SLTOVECOL = evalue("GOVECOL"+W_ALP)
      [M:CFV4]TOUS      = 1
      Call GETDEV(S_FCY) From DEVSUB    #--> renseigne GTYPGEN
      Call GETPER(S_FCY,GTYPGEN,S_IPTDAT,LEXE,LPER) From CPTSUB
      Read [FIY]FIY0=[F:PER]CPY;GTYPGEN;LEXE             # FQ 60141 GA 01/2010 il manquait GTYPGEN
      [M:CFV4]FIYNUM    = LEXE                           # FQ 60141 GA 01/2010 stocker FIYNUM
      [M:CFV4]ITCSTRDAT = [F:FIY]FIYSTR
      [M:CFV4]ITCENDDAT = [F:FIY]FIYEND
      [M:CFV4]CLCQTY    = S_ITMQTY     # JPJ On prend la quantité du composé et non pas du lot économique [F:ITF]REOMINQTY
      [M:CFV4]ROUALT    = [F:CSC]ROUALT
      [M:CFV4]BOMALT    = [F:CSC]BOMALT
      [M:CFV4]BOMALTTYP = [F:CSC]BOMALTTYP : # GA 09/2007 pour la V6
      If dim(S_CSTBOM)>0 & S_CSTBOM=1  # FQ 49639 GA 10/2008 ne pas descendre la nomenclature
         [M:CFV4]DESCEND   = 1
      Else
         [M:CFV4]DESCEND   = 2
      Endif
      [M:CFV4]ITCDAT    = date$
      [M:CFV4]MAJ       = 3            # FQ 49639 à modifier par la suite: utiliser le calcul différé ?
      [M:CFV4]CUR       = GLOCALDEV
  Endif
Endif
Return
############################################################
Subprog RNDQTY(LUOM,LQTY)
Value    Char    LUOM
Variable Decimal LQTY
Read [TUN]TUN0=LUOM
If fstat = 0
  LQTY = arr(LQTY,10^-[F:TUN]UOMDEC)
Else
  LQTY = arr(LQTY,1)
Endif
End
############################################################
# Chargement onglet stock (compose et composants)
#    mask CFV3
$LOA_STOCK
If [M:CFV3]NBLIG < dim([M:CFV3]ITMREF)-1
  [M:CFV3]NBLIG += 1
  nolign = [M:CFV3]NBLIG
  Read [ITV]ITV0=[F:ITM]ITMREF;S_FCY
  If fstat
    Raz [F:ITV]
  Endif
  [M:CFV3]        = [F:ITV]
  [M:CFV3]BOMLEV(nolign-1)  = W_LEV
  [M:CFV3]ITMREF (nolign-1) = [F:ITM]ITMREF
  #[M:CFV3]ITMDES1(nolign-1) = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFV3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  [M:CFV3]STU    (nolign-1) = [F:ITM]STU
  [M:CFV3]REQQTY (nolign-1) = W_BES
  [M:CFV3]BOMSEQ (nolign-1) = W_BMS

  # JPJ STOCKLIB -> STKLIB ->
  Read [ITG]ITG0=S_FCY;[F:ITM]TCLCOD
  If fstat
      Read [ITG]ITG0="";[F:ITM]TCLCOD
      If fstat
        Raz [F:ITG] # FQ 62100 avant Raz [F:ITV] # GA 08/2011 idem V5
      Endif
  Endif

  #  Call STODISTOT("",[M:CFV3]AVASTO(nolign-1)) From STOCKLIB
  If ([F:ITM]ITMREF <> "" | [F:ITG]TCLCOD <> "")        # ITV et ITG existent
    Call STODISTOT("",1,1,"",[M:CFV3]TOTSTO(nolign-1)) From STKLIB    # Empl: internes + externes ; tous statuts
    Call STODISTOT("",7,7,"",[M:CFV3]AVASTO(nolign-1)) From STKLIB    # Empl: internes + attente rgt ; statut A
  Else
    [M:CFV3]AVASTO(nolign-1)=0
  Endif
  # JPJ STOCKLIB -> STKLIB <-

  If W_BES >  [M:CFV3]AVASTO(nolign-1)
    [M:CFV3]SHTQTY(nolign-1) = W_BES - [M:CFV3]AVASTO(nolign-1)
  Else
    [M:CFV3]SHTQTY(nolign-1) = 0
  Endif
  Read [ITF]ITF0=[F:ITM]ITMREF;S_FCY
  If fstat
    [M:CFV3]OFS    (nolign-1) = [F:ITM]OFS
  Else
    [M:CFV3]MFGLTI (nolign-1) = [F:ITF]MFGLTI
    [M:CFV3]OFS    (nolign-1) = [F:ITF]OFS
  Endif
  If nolign > 1
    If  [M:CFV3]OFS(nolign-1) > [M:CFV3]MAXLTI
      [M:CFV3]MAXLTI = [M:CFV3]OFS(nolign-1)
    Endif
    If  [M:CFV3]MFGLTI(nolign-1) > [M:CFV3]MAXLTI
      [M:CFV3]MAXLTI = [M:CFV3]MFGLTI(nolign-1)
    Endif
  Endif

  # FQ 61200 GA 01/2010 ajout PE zones complémentaires
  GPOINT = "LOA_CFV3"
  Gosub ENTREE From EXEFNC
Endif
Return
############################################################
# Issue 98480 GA 04/2014
# Some variables have to be initialized also
# when reconfiguring an existing product from Sales module
$INI_CPTCFG
# Compteur general configurateur
S_CPTCFG = ""     # JPJ E21557
Call NUMERO(GCFG,S_FCY,S_IPTDAT,"",S_CPTCFG,S_RETURN) From SUBANM
If S_RETURN <>  0
    # JPJ E21557 ->
    If GOK<>-1    # pas de message sur readlock
        Gosub TRA_ERR From CFGLIBB    # Affichage qui déclenche le suivi en trace
    Endif
    #  Call NUM_ERR(S_RETURN,GMESSAGE) From CFGLIBE    # Mise en forme
    GERR     = 1
    FIN      = 1
    Goto DEBUT_CFGVAL_FIN
Endif
# Sauvegardes
[F:AVA1]=[F:AVA]    # Sauvegarde pour abandon
Return
############################################################
# Traitement des enregistrements de la pile jusqu'a [F:CFP]PILREC
# L'appel doit tester GOK en retour
$SKIP_PILE
For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
  If [M:CFP]PILPHA([M:CFP]PILIND) > [M:CFP]PILREC
    [M:CFP]PILSTR = [M:CFP]PILIND
    Break
  Endif
# Mise a etat initial buffer
  If [M:CFP]PILIND = [M:CFP]PILSTR                                  |
&    [M:CFP]PILPHA([M:CFP]PILIND) <> [M:CFP]PILPHA([M:CFP]PILIND-1) |
&    [M:CFP]PILSEQ([M:CFP]PILIND) <> [M:CFP]PILSEQ([M:CFP]PILIND-1)
    S_PHASE = [M:CFP]PILPHA([M:CFP]PILIND)
    S_SEQ   = [M:CFP]PILSEQ([M:CFP]PILIND)
    S_LIN   = [M:CFP]PILLIN([M:CFP]PILIND)
    Gosub MEI_BUFFERS From CFGLIBB
  Endif
  If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
    Gosub TRT_SYMBOLE From CFGLIBC1
    If (GOK<>1 | S_ABORT | W_MSG <> "")
      Break
    Endif
  Endif
Next [M:CFP]PILIND
Return
############################################################
$EDI_CFGVAL
Local Char WMSK(10)(6)
Local Char WABR(06)(6)

WMSK(0) = "CFGVAL0"
WABR(0) = "CFV0"
If dim([M:CFV1]DMYA) > 0
  WMSK(1) = "CFGVAL1A"
  WABR(1) = "CFV1"
Else
  WMSK(1) = "CFGVAL1"
  WABR(1) = "CFV1"
Endif
If [F:CSC]ROUFLG=2    # gamme
    WMSK(2) = "CFGVAL2"
    WABR(2) = "CFV2"
Endif
WMSK(3) = "CFGVAL3"
WABR(3) = "CFV3"
If W_CSTMOD=1        # Module Controle de gestion
    WMSK(4) = "CFGVAL4"
    WABR(4) = "CFV4"
Endif
WMSK(5) = "CFGVAL9"
WABR(5) = "CFV9"

# Trbegin [ITM]   En 140, fait dans ATRTX3
Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
# Commit
Return

#############################################################
$GENERATION_CFGVAL
# Rappel W_ITS<>0 si un ou plusieurs composés sélectionnés par l'utilisateur
#        W_COM=0  si le configurateur a pris un article équivalent
#        S_MODITM<> ""    si reprise de configuration, contient le code de l'article à reconfigurer
#
W_TRASTP=mess(190,188,1)-"($GENERATION_CFGVAL)" : Gosub TRA_STEP From CFGLIBB

W_TRAMSG= "S_UPDMOD:"-num$(S_UPDMOD)-"GOK:"-num$(GOK)-"W_COM:"-num$(W_COM)-"S_MODITM:"-S_MODITM-"S_CPTCFG:"-S_CPTCFG
Gosub TRA_MSG From CFGLIBB

If S_UPDMOD = 2        # Mode mise à jour - Le configurateur est entré en mode mise à jour
                       #   Nota: il a pu utiliser un article équivalent
  If GOK <> 1 : Goto $GENERATION_CFGVAL_ERROR : Endif

  If S_MODITM <> ""   # Reprise de configuration
    Gosub TRT_MODITM
    If GOK <> 1 : Goto $GENERATION_CFGVAL_ERROR : Endif
  Endif

  # pas de sélection composé et sélection composé par équivalence (cf doc evol 130/140)
  If W_ITS = 0 & W_COM=0 & (S_GENDES1 <> "" | S_GENDES2 <> "" | S_GENDES3 <> "")
      Gosub MAJ_GENERIQUE
      If GOK <> 1 : Goto $GENERATION_CFGVAL_ERROR : Endif
  Endif


  If W_COM=1    # article créé

        W_TRAMSG = mess(199,188,1)-"("+S_CURITM+")"     # Article créé ou mise à jour par le configurateur
        Gosub TRA_MSG From CFGLIBB

        Gosub MAJ_STATUT    # statut article
        If GOK <> 1 : Goto $GENERATION_CFGVAL_ERROR : Endif

        # FQ 75675 GA erreur Write ITB si pas de BOMALT au niveau du scénario
        If [F:CSC]BOMALT>0
          Gosub MAJ_LLC From CFGLIBC1      # Codes de plus bas niveau
          If GOK=0 | GOK=-1 # Considerer comme non bloquant
              W_TRAMSG=mess(178,188,1)-mess(177,188,1)-"GOK:"-num$(GOK)  : Gosub TRA_MSG From CFGLIBB
              GOK=1
          Endif
        Endif

        Gosub UPD_TEXTES        # Textes AXX, TEX, TXC
        If GOK <> 1 : Goto $GENERATION_CFGVAL_ERROR : Endif

        If dim(GVENCFG) > 0 & GVENCFG <> 0
          Gosub MAJ_VENTES
          If S_SALTXT <> 0
            Gosub MAJ_TXTVEN From CFGLIBB
          Endif
        Endif

        GPOINT = "DELMEMO"      # Memo
        GPE    = 0
        Gosub ENTREE From EXEFNC
        If GPE = 0
          Gosub DEL_MEMO
        Endif

        GMESSAGE = mess(52,188,1)-S_CPTCFG       # Config terminé avec succès \ Donnée générée avec N° config
        If [F:CSC]VALDSY = 2 & [M:CFV1]NBLIG1 > 0
            GMESSAGE += "\"+[M:CFV1]ITMREF(0)-[M:CFV1]ITMDES1(0)
        Endif
        W_TRAMSG=GMESSAGE : Gosub TRA_MSG From CFGLIBB
        # FQ 47501 GA 05/2008 pas de message si on est en test d'un scénario
        If GFONCTION<>"GESCFG"
           GERR = 2        # pour avoir le message à l'écran
        Endif

        # Workflow creation des donnees
        Call WORKFLOW("F_FUNCFG","","") From SUBAMSC

    Else    # Article équivalent

        # Issue 84700 GA 11/2012
        Gosub UPD_TEXTES        # Textes AXX, TEX, TXC
        If GOK <> 1 : Goto $GENERATION_CFGVAL_ERROR : Endif

        If dim(GVENCFG) > 0 & GVENCFG <> 0
          Gosub MAJ_VENTES
          If S_SALTXT <> 0
            Gosub MAJ_TXTVEN From CFGLIBB
          Endif
        Endif
        W_TRAMSG=mess(75,188,1)-"("+S_CURITM+")"    # Un composé <=> a été sélectionné
        Gosub TRA_MSG From CFGLIBB
        # FQ 47501 GA 05/2008 pas de message si on est en test d'un scénario
        If GFONCTION<>"GESCFG"
           GERR = 2  # Indique le code retour (pour GENCFG ou en BATCH)
        Endif
        If dim(S_AUTCFG) > 0 & S_AUTCFG > 0                    # mode automate ou batch
            GMESSAGE=W_TRAMSG
        Elsif dim(GVENCFG) > 0 & GVENCFG <> 0                  # mode vente
            GMESSAGE=""  # vide pour éviter un message redondant avec la validation
        Else                                                   # scenario en TP
            GMESSAGE=""
        Endif
    Endif

Else        # Sélection de composés par l'utilisateur
    If dim(GVENCFG) > 0 & GVENCFG <> 0
          Gosub MAJ_VENTES        # Permet d'executer le PE CFGUPDSAL
          If S_SALTXT <> 0
            Gosub MAJ_TXTVEN From CFGLIBB
          Endif
    Endif

    W_TRAMSG = mess(241,188,1)                     # Sélection de composés par l'utilisateur
    Gosub TRA_MSG From CFGLIBB
    # FQ 47501 GA 05/2008 pas de message si on est en test d'un scénario
    If GFONCTION<>"GESCFG"
       GERR = 2  # Indique le code retour (pour GENCFG ou en BATCH)
    Endif
    If dim(S_AUTCFG) > 0 & S_AUTCFG > 0                    # mode automate ou batch
        GMESSAGE=W_TRAMSG
    Elsif dim(GVENCFG) > 0 & GVENCFG <> 0                  # mode vente
        GMESSAGE=""  # vide pour éviter un message redondant avec la validation
    Else                                                   # scenario en TP
        GMESSAGE=""
    Endif
Endif

$GENERATION_CFGVAL_END    # Fin
# Appel ventes
If dim(GVENCFG) > 0 & GVENCFG <> 0
  W_TRAMSG=mess(208,188,1) : Gosub TRA_MSG From CFGLIBB
  Call GENCFG From TRTVENCFG
Endif
W_TRASTP=mess(190,188,1)-"(return of $GENERATION_CFGVAL)" : Gosub TRA_STEP From CFGLIBB
W_TRASTP=""    # RAZ contexte
FIN = 1
Return
#############################################################
# Erreur: Arrêt Génération
$GENERATION_CFGVAL_ERROR
Gosub DEL_CONFIG                 # Ecrase GOK
GMESSAGE = mess(53,188,1)        # Configuration abandonnée
Gosub TRA_ERR From CFGLIBB
GERR = 1
Goto $GENERATION_CFGVAL_END

#############################################################
# Modification du numero article par numero selectionne
$TRT_MODITM
Gosub CTL_PARAM_CSC From CFGLIBC1
W_TRAMSG= mess(197,188,1)-S_MODITM-"($TRT_MODITM)" : Gosub TRA_MSG From CFGLIBB
Call DEBTRANS From GLOCK     # JPJ E-Gestion Lock

$TRT_MODITM_DEB

Trbegin [ITM]
W_CPT    = S_CPTCFG
# S_CPTCFG = S_CPTCOP                 # JPJ E19035
Readlock [ITM]ITM0=S_MODITM
Case fstat
 When 0
  W_ITM    = [F:ITM]ITMREF
  S_CPTCFG = [F:ITM]CFGVCRNUM         # JPJ E19035
  Gosub DEL_ARTICLE
  #If GOK =1  # Issue 98703 GA 05/2014 déplacé dans DEL_ARTICLE, avant suppression article
  #    Gosub DEL_NOMENCL
  #    If GOK = 1
  #        Gosub DEL_GAMME
  #    Endif
  #Endif
  If GOK = 1
    S_CPTCFG = W_CPT
    # Issue 103539 GA 10/2014 too many lines in CFGLIBC
    Gosub MOD_ITMREF From CFGLIBC1
  Endif
 When 1       # JPJ E-Gestion Lock
   GLOCK="$ITMMASTER"-S_MODITM : GOK=-1
 When Default
   Call RSTACTX("ITM",S_MODITM,W_TRASTP,"$TRT_MODITM") From CFGLIBD
   GOK=0
Endcase

S_CPTCFG = W_CPT
Case GOK
  When 1 :
    [M:CFV1]ITMREF(0) = S_MODITM
    [M:CFV3]ITMREF(0) = S_MODITM
    S_ITMSEL(0) = S_MODITM
    S_CURITM    = S_MODITM
    S_CURROU    = S_MODITM
    Commit
  When -1 :
    Rollback
    W_TRAMSG=mess(179,188,1)-GLOCK : Gosub TRA_MSG From CFGLIBB        # suivi
    Call ROLL From GLOCK     # JPJ E-Gestion Lock
    If !GROLL
        GOK=1 : Goto TRT_MODITM_DEB
    Else
        GMESSAGE=W_TRAMSG                     # info trace sur lock
        Gosub TRA_ERR From CFGLIBB
        GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
        GMESSAGE+="\"+mess(236,188,1) : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentative par utilisateur
    Endif
  When Default :
    Rollback
Endcase
Return

#############################################################
# Effacement memorisation des reponses si scenario valide
$DEL_MEMO
Trbegin [CME]
If S_PURMEM = 0
  Delete [CME] Where RECCOD    = 0
&                 &  SCENUM    = S_SCENUM
&                 &  CFGBPRNUM = S_BPRNUM
&                 &  CFGBPRREF = S_BPRREF
Else
  W_DTE = date$-S_PURMEM
  Delete [CME] Where RECCOD    = 0        &
&                    SCENUM    = S_SCENUM &
&                    CREDAT    < W_DTE
Endif
Commit
Return
#############################################################
# Transfert des designations generiques sur compose principal
$MAJ_GENERIQUE
If S_ITMSEL(0) <> ""
  Call DEBTRANS From GLOCK     # JPJ E-Gestion Lock
  $MAJ_GENERIQUE_DEB

  W_TRAMSG= mess(198,188,1)-S_MODITM-"($MAJ_GENERIQUE)" : Gosub TRA_MSG From CFGLIBB
  Trbegin [ITM]
  Readlock [ITM]ITM0=S_ITMSEL(0)
  Case fstat
  When 0
      If [F:ITM]CFGVCRNUM <> S_CPTCFG
        # GA 02/2012 appels à MAJTEXTRA avant le rewrite + tester présence des champs
        If S_GENDES1 <> ""
           If dim([F:ITM]ITMDES1)>0 [F:ITM]ITMDES1 = S_GENDES1 Endif
           Call MAJTEXTRA (S_GENDES1,"ITMMASTER","DES1AXX",[F:ITM]ITMREF,"") From ATEXTRA
        Endif
        If S_GENDES2 <> ""
           If dim([F:ITM]ITMDES2)>0 [F:ITM]ITMDES2 = S_GENDES2 Endif
           Call MAJTEXTRA (S_GENDES2,"ITMMASTER","DES2AXX",[F:ITM]ITMREF,"") From ATEXTRA
        Endif
        If S_GENDES3 <> ""
           If dim([F:ITM]ITMDES3)>0 [F:ITM]ITMDES3 = S_GENDES3 Endif
           Call MAJTEXTRA (S_GENDES3,"ITMMASTER","DES3AXX",[F:ITM]ITMREF,"") From ATEXTRA
        Endif
      Endif
      Rewrite [ITM]
      If fstat
          Call FSTACTX("ITM",W_TRASTP,"$MAJ_GENERIQUE") From CFGLIBD
          GOK=0
      Endif
  When 1
    GLOCK="$ITMMASTER"-S_ITMSEL(0) : GOK=-1     # JPJ E-Gestion Lock
  When Default
    Call RSTACTX("ITM",S_ITMSEL(0),W_TRASTP,"$MAJ_GENERIQUE") From CFGLIBD
    GOK=0
  Endcase

  Case GOK
  When 1
    Commit
  When -1 :
    Rollback
    W_TRAMSG=mess(179,188,1)-GLOCK : Gosub TRA_MSG From CFGLIBB        # suivi
    Call ROLL From GLOCK     # JPJ E-Gestion Lock
    If !GROLL
        GOK=1 : Goto MAJ_GENERIQUE_DEB
    Else
        GMESSAGE=W_TRAMSG                     # info trace sur lock
        Gosub TRA_ERR From CFGLIBB
        GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
        GMESSAGE+="\"+mess(236,188,1) : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentaive par utilisateur
    Endif
  When Default
    Rollback
  Endcase
Endif
Return
#############################################################
# Transformation du statut article "Non utilisable" en "Actif"
# Si incident les articles ne seront pas modifies
$MAJ_STATUT
Call DEBTRANS From GLOCK     # JPJ E-Gestion Lock
$MAJ_STATUT_DEB

Trbegin [ITM]
For W_I = 0 To dim(S_ITMSEL)-1
  If S_ITMSEL(W_I) = ""
    Break
  Else
    Readlock [ITM]ITM0=S_ITMSEL(W_I)
    Case fstat
    When 0
      If [F:ITM]CFGVCRNUM = S_CPTCFG & [F:ITM]ITMSTA = 6
        [F:ITM]ITMSTA = 1
        Rewrite [ITM]
        If fstat
            Call FSTACTX("ITM",W_TRASTP,"$MAJ_STATUT") From CFGLIBD
            GOK=0
        Endif
      Endif
    When 1
GLOCK="$ITMMASTER"-S_ITMSEL(W_I) : GOK=-1
    When Default
        Call RSTACTX("ITM",S_ITMSEL(W_I),W_TRASTP,"$MAJ_STATUT") From CFGLIBD
        GOK=0
    Endcase
    If GOK <> 1 : Goto MAJ_STATUT_END : Endif
  Endif
Next W_I
#
For W_I = 0 To dim(S_CMPSEL)-1
 If S_CMPSEL(W_I) = ""
    Break
  Else
    Readlock [ITM]ITM0=S_CMPSEL(W_I)
    Case fstat
    When 0
      If [F:ITM]CFGVCRNUM = S_CPTCFG & [F:ITM]ITMSTA = 6
        [F:ITM]ITMSTA = 1
        Rewrite [ITM]
        If fstat
            Call FSTACTX("ITM",W_TRASTP,"$MAJ_STATUT") From CFGLIBD
            GOK=0
        Endif
      Endif
    When 1
        GLOCK="$ITMMASTER"-S_CMPSEL(W_I) : GOK=-1
    When Default
        Call RSTACTX("ITM",S_CMPSEL(W_I),W_TRASTP,"$MAJ_STATUT") From CFGLIBD
        GOK=0
    Endcase
    If GOK <> 1 : Break : Endif
  Endif
Next W_I
If GOK <> 1 : Goto MAJ_STATUT_END : Endif

$MAJ_STATUT_END
Case GOK
When 1
    Commit
  When -1 :
    Rollback
    W_TRAMSG=mess(179,188,1)-GLOCK : Gosub TRA_MSG From CFGLIBB        # suivi
    Call ROLL From GLOCK     # JPJ E-Gestion Lock
    If !GROLL
        GOK=1 : Goto MAJ_STATUT_DEB
    Else
        GMESSAGE=W_TRAMSG                     # info trace sur lock
        Gosub TRA_ERR From CFGLIBB
        GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
        GMESSAGE+="\"+mess(236,188,1) : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentaive par utilisateur
    Endif
When Default
    Rollback
Endcase
Return


#############################################################
$MAJ_VENTES
# Chargement article cree pour retour sp
#    nota: le prix affiché par la commande ou le devis provient de la rubrqiue BASPRI (Article vente)
#            (il s'agit du fonctionnement par défaut de la recherche tarif)
W_TRAMSG=mess(209,188,1) : Gosub TRA_MSG From CFGLIBB
[M:CFW]WRKBOMALT = [F:CSC]BOMALT
[M:CFW]WRKALTTYP = [F:CSC]BOMALTTYP : # GA 09/2007 pour la V6
[M:CFW]WRKROUALT = [F:CSC]ROUALT
#
# Composé
[M:CFW]NBLIG = 0
W_I          = 0
GPOINT = "CFGUPDSAL"
GPE    = 0
Gosub ENTREE From EXEFNC
If GPE = 0
  [M:CFW]WRKPHA   ([M:CFW]NBLIG)   = 0
  If W_ITS=0 : [M:CFW]WRKSELNUM([M:CFW]NBLIG)   = "" : Endif    #CCC (30/05/05) Bug 30288: si wrkselnum="" => les ventes ne prennent que le 1er
  [M:CFW]WRKSEQ   ([M:CFW]NBLIG)   = 0
  [M:CFW]WRKITMREF([M:CFW]NBLIG)   = [M:CFV1]ITMREF(W_I)
  [M:CFW]WRKSTU   ([M:CFW]NBLIG)   = [M:CFV1]STU(W_I)
  [M:CFW]WRKQTYSTU([M:CFW]NBLIG)   = [M:CFV1]QTYSTU(W_I)
  [M:CFW]WRKSAU   ([M:CFW]NBLIG)   = ""
  [M:CFW]WRKQTYSAU([M:CFW]NBLIG)   = 0
  [M:CFW]WRKCST   ([M:CFW]NBLIG)   = 0
  [M:CFW]NBLIG += 1
Endif

# Composants de 1er niveaux (boucle à partir de 1)
For W_I = 1 To [M:CFV3]NBLIG-1
  If [M:CFW]NBLIG < dim([M:CFW]WRKPHA)-1
    If ([M:CFV3]BOMLEV(W_I) <="1")      # JPJ E22823 - niv 1 uniquement
        GPOINT = "CFGUPDSAL"
        GPE    = 0
        Gosub ENTREE From EXEFNC
        If GPE = 0
          [M:CFW]WRKPHA   ([M:CFW]NBLIG) = 0
          If W_ITS=0 : [M:CFW]WRKSELNUM([M:CFW]NBLIG) = "" : Endif    # Pour cohérence avec la 1ère ligne
          [M:CFW]WRKSEQ   ([M:CFW]NBLIG) = [M:CFV3]BOMSEQ(W_I)
          [M:CFW]WRKITMREF([M:CFW]NBLIG) = [M:CFV3]ITMREF(W_I)
          [M:CFW]WRKSTU   ([M:CFW]NBLIG) = [M:CFV3]STU(W_I)
          [M:CFW]WRKQTYSTU([M:CFW]NBLIG) = [M:CFV3]REQQTY(W_I)
          [M:CFW]WRKSAU   ([M:CFW]NBLIG) = ""
          [M:CFW]WRKQTYSAU([M:CFW]NBLIG) = 0
          [M:CFW]WRKCST   ([M:CFW]NBLIG) = 0
          [M:CFW]NBLIG += 1
        Endif
    Endif         # JPJ E22823
  Else
    Break
  Endif
Next W_I
Return
#############################################################
# Routine de creation des enregistrements ITM
$ECR_ARTICLE   ## En retour test de GOK
# Ecriture article maitre avec attribution automatique du numero d'article eventuelle
# Issue 100086 GA 05/2014 except when reconfiguration
#If [F:ITG]ITMREFCOU <> ""
If [F:ITG]ITMREFCOU <> "" & S_MODITM=""
  Call NUMERO([F:ITG]ITMREFCOU,S_FCY,S_IPTDAT,"",[F:ITM]ITMREF,W_RET) From SUBANM
  If W_RET <> 0
    GMESSAGE = mess(57,188,1)-[F:ITG]ITMREFCOU+"/"+GMESSAGE
    If GOK<>-1    # pas de message sur readlock
        Gosub TRA_ERR From CFGLIBB    # Affichage qui déclenche le suivi en trace
    Endif
    # GOK = 0   postionné par le call
    Return
  Else
# GA ajout d'une trace si [F:ITM]ITMREF remplacé par compteur associé à la catégorie
    W_TRAMSG=mess(184,100,1)-[F:ITG]ITMREFCOU-":"-[F:ITM]ITMREF-"($ECR_ARTICLE)" : Gosub TRA_MSG From CFGLIBB
  Endif
Elsif [F:ITM]ITMREF = "" & [F:ITG]ITMREFCOU = ""  # Issue 102801 GA 10/2014
  GMESSAGE = mess(54,188,1)                    #Réf. composé incorrecte
  Gosub TRA_ERR From CFGLIBB
  GERR = 1 : FIN = 1 : GOK = 0
  Return
Endif
#
# FQ 45799 ctrl validité de la référence article
Gosub CTRL_ITMREF
If GOK <> 1
   Gosub TRA_ERR From CFGLIBB    # Affichage qui déclenche le suivi en trace
   Return
Endif
#
[F:ITM]PURFLG=[F:ITG]PURFLG
[F:ITM]MFGFLG=[F:ITG]MFGFLG
[F:ITM]SCPFLG=[F:ITG]SCPFLG
[F:ITM]SCSFLG=[F:ITG]SCSFLG
[F:ITM]PHAFLG=[F:ITG]PHAFLG
[F:ITM]GENFLG=[F:ITG]GENFLG
[F:ITM]TOOFLG=[F:ITG]TOOFLG
[F:ITM]DLVFLG=[F:ITG]DLVFLG
[F:ITM]INTFLG=[F:ITG]INTFLG

If [F:ITM]STOMGTCOD = 1
  [F:ITM]STDFLG    = 1
  [F:ITM]LOTMGTCOD = 1
  [F:ITM]SERMGTCOD = 1
  [F:ITM]NEGSTO    = 1
  [F:ITM]STOCRD    = ""
  [F:ITM]EXYMGTCOD = 1
Endif
If [F:ITM]EXYMGTCOD = 1
  [F:ITM]EXYSTA    = ""
  [F:ITM]NEWLTISTA = ""
  [F:ITM]SHL       = 0
  [F:ITM]SHLUOM    = 1
  [F:ITM]SHLLTI    = 0
  [F:ITM]SHLLTIUOM = 1
  [F:ITM]DLU       = 1
Endif
If [F:ITM]STOMGTCOD <> 3
  [F:ITM]DEFPOT    = 0
Endif
#If [F:ITM]STOMGTCOD <> 4  # choix UI pas géré
#  [F:ITM]DEFACT    = 0
#Endif
#
[F:ITM]CFGVCRNUM = S_CPTCFG
[F:ITM]CFGBPRNUM = S_BPRNUM
[F:ITM]CFGBPRREF = S_BPRREF
If S_PURDAT = [0/0/0]
  [F:ITM]CFGDELDAT = [31/12/2999]
Else
  [F:ITM]CFGDELDAT = S_PURDAT
Endif
If [F:ITM]ITMSTA < 2
  [F:ITM]ITMSTA    = 6 : # Cree en "non utilisable"
Endif
[F:ITM]CFGITMREF = W_ITM
If S_MODITM="" | [F:ITM]CREUSR=""    # Issue 92890 GA 09/2013 pb en reprise/reconfiguration
  [F:ITM]EXPNUM    = [C]EXPORT
  [F:ITM]CREUSR    = GUSER
  [F:ITM]CREDAT    = date$
  [F:ITM]UPDUSR    = ""
  [F:ITM]UPDDAT    = [0/0/0]
Else
  [F:ITM]UPDUSR    = GUSER
  [F:ITM]UPDDAT    = date$
Endif
Gosub PE_BEFWRIITM
Write [ITM]
If fstat = 0
  If W_SSC <> ""
    Gosub ECR_SUBSCE
  Endif
  Gosub ECR_ART_ITFITV
  If GOK <> 1 Return Endif
  Gosub ECR_ART_ITS
  If GOK <> 1 Return Endif
  #If S_MODITM<>""    # Issue 96443 GA 03/2014 insérer ligne courante
    Gosub ECR_ART_ITU
    If GOK <> 1 Return Endif
    Gosub ECR_ART_ITP
    If GOK <> 1 Return Endif
  #Endif
  Gosub ECR_ART_ALL_ITU     From CFGLIBC1 # Issue 82300 GA 06/2012
  If GOK <> 1 Return Endif
  Gosub ECR_ART_ALL_ITP     From CFGLIBC1 # Issue 82300 GA 06/2012
  If GOK <> 1 Return Endif
  Gosub ECR_ART_BLB            # FQ 50444 GA 11/2008
  If GOK <> 1 Return Endif
  Gosub ECR_ART_CLB            # FQ 50444 GA 11/2008
  If GOK <> 1 Return Endif
  Gosub ECR_ART_AOX            # FQ 50444 GA 11/2008
  If GOK <> 1 Return Endif
Endif
Return
############################################################
# Issue 82983 GA 06/2012 compléter si Article-Site inexistant
$UPD_ARTICLE
Read [ITF]ITF0=[F:ITM]ITMREF;S_FCY
If fstat
   Gosub UPD_ARTICLE From CFGLIBC1
Endif
Return
############################################################
# Ecriture article site ITF ITV ITC
$ECR_ART_ITFITV
# Ecriture article site
# Issue 89746 GA 07/2013 déplacé dans MEI_BUFFERS(CFGLIBB)
#If S_MODITM=""
#   [F:ITF] = [F:ITM]
#Else
   [F:ITF]ITMREF = [F:ITM]ITMREF
#Endif
# Issue 93704 GA 10/2013
#If [F:ITF]CREUSR <> ""  # Issue 89191 GA 04/2013
If [F:ITM]STOMGTCOD=2 | [F:ITF]CREUSR <> "" | S_MODITM<>""
  Read [FCY1]FCY0=S_FCY
  If fstat = 0 & [F:FCY1]WRHFLG = 2
    [F:ITF]STOFCY     = S_FCY
    Gosub ECR_ART_ITF : If GOK<>1 : Goto ECR_ART_ITFITV_FIN : Endif
  Endif

# Ecriture multisite selon parametre ou selon presence variables "FCYITF1 .. FCYITF9"
  If [F:CSC]FCYFLG = 2 | S_MODITM<>""
    Gosub ECR_ART_ALL_ITF From CFGLIBC1
    If GOK = 0
      Goto ECR_ART_ITFITV_FIN
    Endif
  Else
    [F:ITF1] = [F:ITF]
    For W_V = 1 To 9
      If evalue("dim(S_FCYITF"+num$(W_V)+")>0")
        W_WRH = evalue("S_FCYITF"+num$(W_V))
        W_WRH = toupper(W_WRH)
        If W_WRH <> S_FCY
          Read [FCY1]FCY0=W_WRH
          If fstat = 0 & [F:FCY1]WRHFLG = 2
            [F:ITF]           = [F:ITF1]
            [F:ITF]STOFCY     = [F:FCY1]FCY
            Gosub ECR_ART_ITF : If GOK<>1 : Break : Endif
          Endif
        Endif
      Endif
    Next W_V
    If GOK<>1 : Goto ECR_ART_ITFITV_FIN : Endif
  Endif
  # Issue 89191 GA 04/2013 pas de vérif !
  #Read [ITF]ITF0=[F:ITM]ITMREF;S_FCY
  #If fstat
  #  Call FSTACTX("ITF",W_TRASTP,"$ECR_ART_ITFITV") From CFGLIBD  # From GLOCK
  #  GOK = 0
  #Endif
Elsif [F:CSC]FCYFLG = 2

  [F:ITF]STOFCY = S_FCY
 # FQ 47177 V6 on ajoute aussi Article-Site sur le site courant
  Gosub ECR_ART_ITF : If GOK<>1 : Goto ECR_ART_ITFITV_FIN : Endif

  # CCC (06/04/05) Bug 29482 - Si le paramétrage est en mode multi-sites, on essaye
  # de traiter les autres sites même si l'article-site n'existe pas sur le site en-cours.
  Gosub ECR_ART_ALL_ITF From CFGLIBC1
  If GOK = 0
     Goto ECR_ART_ITFITV_FIN
  Endif
Else
  Call ECR_DEBUG("Aucune Insertion demandée dans ITF/ITV/ITC="-[F:ITM]ITMREF-S_FCY) From CFGLIBC1
Endif
$ECR_ART_ITFITV_FIN
Return
############################################################
# Ecriture Article-Site (d'après [F:ITF] site courant de l'article référence W_RIT)
# FQ 47177 Extrait de ECR_ART_ITFITV
$ECR_ART_ITF
# Issue 89746 GA 07/2013 à faire uniquement si rien trouvé
If [F:ITF]STOMGTCOD=0
   [F:ITF] = [F:ITM]    # Issue 80442 GA 03/2012 Some informations fails (from [F:ITG])
   If [F:ITF]STOFCY=S_FCY | [F:CSC]FCYFLG = 2
      # Article-Site de référence sur le site courant ?
       If clalev([F:ITF1])= 0 : Local File ITMFACILIT     [ITF1]: Endif
       Read [ITF1]=W_RIT;[F:ITF]STOFCY
       If !fstat
         [F:ITF]=[F:ITF1]
         [F:ITF]ITMREF=[F:ITM]ITMREF
       Endif
       [F:ITF]CREUSR    = GUSER
       [F:ITF]CREDAT    = date$
    Endif
    # Issue 89191 GA 06/2012 maj selon réponses du scénario
    If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2
    WCRE=2 : Gosub UPD_ITF_FROM_ASW From CFGLIBC1
Endif
#
If [F:ITF]LOCMGTCOD = 1
  If clalev([F:ACV]) = 0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT='NDL'
  If fstat = 0
    For W_V = 0 To [F:ACV]DIME-1
      If dim([F:ITF]LOCNUM) > 0
        Raz [F:ITF]LOCNUM   (W_V)
        Raz [F:ITF]DEFLOCTYP(W_V)
        Raz [F:ITF]DEFLOC   (W_V)
      Endif
    Next W_V
  Endif
Endif
If S_MODITM=""      # Issue 89191 GA 04/2013
  [F:ITF]SAFSTOCLC  = 0
  [F:ITF]REOTSDCLC  = 0
  [F:ITF]REOMINCLC  = 0
  [F:ITF]MAXSTOCLC  = 0
  [F:ITF]MONPROYEA  = 0
  [F:ITF]MONPROMON  = 0
  [F:ITF]YEAPROYEA  = 0
  [F:ITF]CUNFLG     = 1
  [F:ITF]CUNLISNUM  = ""
  # Issue 100257 GA 05/2014 change CFGVCRNUM on updated lines only
  [F:ITF]CFGVCRNUM  = S_CPTCFG
  [F:ITF]EXPNUM     = [C]EXPORT
  [F:ITF]CREUSR     = GUSER
  [F:ITF]CREDAT     = date$
  [F:ITF]UPDUSR     = ""
  [F:ITF]UPDDAT     = [0/0/0]
Else
  # Issue 100257 GA 05/2014 change CFGVCRNUM on updated lines only
  If [F:ITF]STOFCY=S_FCY | [F:CSC]FCYFLG = 2
     [F:ITF]CFGVCRNUM  = S_CPTCFG
  Endif
  [F:ITF]UPDUSR     = GUSER
  [F:ITF]UPDDAT     = date$
Endif
If [F:ITF]STOMGTCOD < 2 # Issue 89191 GA 04/2013
  [F:ITF]CUNCOD=3
  [F:ITF]STOCOD=3
  [F:ITF]PCKSTKFLG=1
  [F:ITF]NQA          = 12
  [F:ITF]SMPMOD       = 3
  [F:ITF]GENLEVINS    = 4
Endif

If [F:ITF]REOFCY    ="" [F:ITF]REOFCY    =[F:ITG]REOFCY    Endif # Site réapprovisionnement
If [F:ITF]REOMGTCOD =0  [F:ITF]REOMGTCOD =[F:ITG]REOMGTCOD Endif # Mode réapprovisionnement
If [F:ITF]REOMINQTY =0  [F:ITF]REOMINQTY =[F:ITG]REOMINQTY Endif # Lot économique
If [F:ITF]REOPER    =0  [F:ITF]REOPER    =[F:ITG]REOPER    Endif # Périodicité réaprovisionnement
If [F:ITF]REOPOL    ="" [F:ITF]REOPOL    =[F:ITG]REOPOL    Endif # Politique réapprovisionnement
If [F:ITF]REOTSD    =0  [F:ITF]REOTSD    =[F:ITG]REOTSD    Endif # Seuil de réapprovisionnement

If [F:ITF]STOCOD=0     [F:ITF]STOCOD=[F:ITG]STOCOD Endif
If [F:ITF]QUAFLG=0     [F:ITF]QUAFLG=[F:ITG]QUAFLG Endif
If [F:ITF]QLYCRD=""    [F:ITF]QLYCRD=[F:ITG]QLYCRD Endif
If [F:ITF]ABCCLS=0     [F:ITF]ABCCLS=[F:ITG]ABCCLS Endif
If [F:ITF]CUNCOD=0     [F:ITF]CUNCOD=[F:ITG]CUNCOD Endif

If [F:ITF]SMPTYP=0     [F:ITF]SMPTYP    = 1     Endif
If [F:ITF]PCKSTKFLG=0  [F:ITF]PCKSTKFLG = 1     Endif
If [F:ITF]NQA=0        [F:ITF]NQA       = 12    Endif
If [F:ITF]SMPMOD=0     [F:ITF]SMPMOD    = 3     Endif
If [F:ITF]GENLEVINS=0  [F:ITF]GENLEVINS = 4     Endif

#---------------#
# Lot technique #
#---------------#
Local Integer WLOT
If [F:ITF]MFGLOTQTY <> 0
  WLOT = [F:ITF]REOMINQTY / [F:ITF]MFGLOTQTY
  If mod([F:ITF]REOMINQTY,[F:ITF]MFGLOTQTY) <> 0
    #GMESSAGE = mess(219,199,1)
    [F:ITF]MFGLOTQTY = [F:ITF]REOMINQTY
  Endif
Else
  [F:ITF]MFGLOTQTY = [F:ITF]REOMINQTY
Endif

# Issue 100257 GA 05/2014 see upper
#[F:ITF]CFGVCRNUM  = S_CPTCFG
#[F:ITF]EXPNUM     = [C]EXPORT
# Issue 92890 GA 09/2013 cf + haut
#[F:ITF]CREUSR     = GUSER
#[F:ITF]CREDAT     = date$
#[F:ITF]UPDUSR     = ""
#[F:ITF]UPDDAT     = [0/0/0]
Gosub PE_BEFWRIITF
Call CHKITF From WUVAR
Write [ITF]
Case fstat
   When 0, 3 : # pas d'erreur en clé dupliquée
   When Default :
     GOK = 0
     Call FSTACTX("ITF",W_TRASTP,"$ECR_ART_ITF") From CFGLIBD
     Goto ECR_ART_ITF_FIN
Endcase

Call ECR_DEBUG("Insert ITF: "-[F:ITF]ITMREF-num$([F:ITF]STOFCY)) From CFGLIBC1
Gosub ECR_ART_ITV : If GOK<>1 : Return : Endif
Gosub ECR_ART_ITC : If GOK<>1 : Return : Endif  : # FQ 47114

$ECR_ART_ITF_FIN
Return
############################################################
# Ecriture cumul article site
$ECR_ART_ITV
If [F:ITM]STOMGTCOD <= 1 Goto ECR_ART_ITV_FIN Endif
# FQ 50437 GA 11/2008 recopier les [F:ITV] existants en cas de maj
Raz [F:ITV]
If S_MODITM<>""
   Read [ITV]ITV0 = S_MODITM;[F:ITF]STOFCY
   If fstat : Raz [F:ITV] : Goto ECR_ART_ITV_NEW Endif
   [F:ITV]ITMREF    = [F:ITF]ITMREF
   [F:ITV]CFGVCRNUM = [F:ITF]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
   [F:ITV]UPDUSR    = GUSER
   [F:ITV]UPDDAT    = date$
   Write [F:ITV]
   Case fstat
     When 0, 3 : # pas d'erreur en clé dupliquée
     When Default :
       GOK = 0
       Call FSTACTX("ITV",W_TRASTP,"$ECR_ART_ITV(copy)") From CFGLIBD
       Goto ECR_ART_ITV_FIN
   Endcase
Else
$ECR_ART_ITV_NEW
  [F:ITV]ITMREF    = [F:ITF]ITMREF
  [F:ITV]STOFCY    = [F:ITF]STOFCY
  [F:ITV]CFGVCRNUM = [F:ITF]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
  [F:ITV]EXPNUM    = [C]EXPORT
  If [F:ITV]NEXCUNDAT = [0/0/0]
    W_RET = [F:ITF]CUNCOD
    Call CAL_NEXINV([F:ITV]STOFCY,[F:ITM]TCLCOD,S_IPTDAT,W_RET) From STKINV
  Endif
  [F:ITV]CREUSR    = GUSER
  [F:ITV]CREDAT    = date$
  [F:ITV]UPDUSR    = ""
  [F:ITV]UPDDAT    = [0/0/0]
  Gosub PE_BEFWRIITV
  Write [ITV]
  Case fstat
    When 0, 3 : # pas d'erreur en clé dupliquée
    When Default :
         GOK = 0
         Call FSTACTX("ITS",W_TRASTP,"$ECR_ART_ITV") From CFGLIBD  # From GLOCK
  Endcase
Endif
$ECR_ART_ITV_FIN
Return
############################################################
# Ecriture article coûts
$ECR_ART_ITC
Local Integer WFIYNUM,WCSTTYP,WITCSEQ
If !clalev([F:ITCX]) : Local File ITMCOST     [ITCX]  : Endif
# Issue 103969 GA 12/2014
#If find([F:ITC]CSTTYP,1,2,3)         # & [F:ITC]CSTTYP = 1
If find([F:ITC]CSTTYP,1,2,3) & (find([F:ITF]STOFCY,S_FCY,[F:ITC]STOFCY) | [F:CSC]CSTCOD>1)
    [F:ITC]CFGVCRNUM = [F:ITF]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
    [F:ITC]ITMREF    = [F:ITF]ITMREF
    [F:ITC]STOFCY    = [F:ITF]STOFCY
    [F:ITC]UID       = 0       # Issue 103969 GA 11/2014 adxuid(1)        # FQ 48688 ????
    If [F:ITC]ITCDAT =[0/0/0] [F:ITC]ITCDAT=date$    Endif
    If [F:ITC]ITCSEQ =0       [F:ITC]ITCSEQ=1        Endif      # 1er pour l'article configuré
    If [F:ITC]FIYNUM =0        # Issue 103814 GA 11/2014
        Local Decimal WEXE, WPER
        If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
        If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
        Call GETDEV([F:ITF]STOFCY) From DEVSUB    #--> renseigne GTYPGEN
        Call GETPER([F:ITF]STOFCY,GTYPGEN,[F:ITC]ITCDAT,WEXE,WPER) From CPTSUB
        Read [FIY]FIY0=[F:PER]CPY;GTYPGEN;WEXE
        [F:ITC]FIYNUM    = WEXE
        [F:ITC]ITCSTRDAT = [F:ITC]ITCDAT   # Issue 103969 GA 11/2014 [F:FIY]FIYSTR
        [F:ITC]ITCENDDAT = [F:FIY]FIYEND
    Endif
    WFIYNUM=[F:ITC]FIYNUM # Issue 103814 GA 11/2014
    WCSTTYP=[F:ITC]CSTTYP # Issue 103814 GA 11/2014
    WITCSEQ=[F:ITC]ITCSEQ # Issue 103814 GA 11/2014
    Gosub COPY_ITC        # Issue 103969 & 103814 GA 11/2014
    Gosub COPY_ITC_SUITE  # Issue 103969 GA 11/2014

    # Issue 78402 GA 03/2012 Ctrl si la clé existe déjà
    While !fstat          # Issue 103814 GA 11/2014 loop
      Read [ITCX]ITC0=[F:ITF]STOFCY;[F:ITF]ITMREF;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ITC]UID  # V6
      If !fstat [F:ITC]ITCSEQ+=1 Endif
    Wend
  Call ECR_DEBUG("Insert ITC: BOMSEQ="-num$(S_SEQ)-[F:ITC]ITMREF-num$([F:ITC]FIYNUM)
&                -num$([F:ITC]ITCSTRDAT)-num$([F:ITC]ITCENDDAT)-"ITCSEQ="-num$([F:ITC]ITCSEQ)) From CFGLIBC1
    [F:ITC]EXPNUM    = [C]EXPORT
    If S_MODITM=""      # Issue 103969 GA 12/2014
      [F:ITC]CREUSR    = GUSER
      [F:ITC]CREDAT    = date$
      [F:ITC]UPDUSR    = ""
      [F:ITC]UPDDAT    = [0/0/0]
    Else
      [F:ITC]UPDUSR    = GUSER
      [F:ITC]UPDDAT    = date$
    Endif
    GPOINT = "BEFWRIITC" : GPE=1 : Gosub ENTREE From EXEFNC
    Write [ITC]
    Case fstat
       When 0, 3 : # pas d'erreur en clé dupliquée
       When Default :
         GOK = 0
         Call FSTACTX("ITC",W_TRASTP,"$ECR_ART_ITC") From CFGLIBD
         Goto ECR_ART_ITC_FIN
    Endcase
    # Ecriture enregistrement cout standard obligatoire (ITC est de type actualisé ou budget)
    If [F:ITC]CSTTYP<>1
        [F:ICS]CFGVCRNUM = [F:ITF]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
        [F:ICS]ITMREF    = [F:ITF]ITMREF
        [F:ICS]STOFCY    = [F:ITF]STOFCY
        [F:ICS]CSTTYP    = 1  # 1=std
        [F:ICS]CSTSEQ    = 0
        [F:ICS]EXPNUM    = [C]EXPORT
        [F:ICS]CREUSR    = GUSER
        [F:ICS]CREDAT    = date$
        [F:ICS]UPDUSR    = ""
        [F:ICS]UPDDAT    = [0/0/0]
        Write [ICS]
        Case fstat
           When 0, 3 : # pas d'erreur en clé dupliquée
           When Default :
             GOK = 0
             Call FSTACTX("ICS",W_TRASTP,"$ECR_ART_ICS") From CFGLIBD
             Goto ECR_ART_ITC_FIN
        Endcase
    Endif
Elsif [F:CSC]CSTCOD=1 & S_MODITM<>"" # Issue 103969 GA 01/2015
    WFIYNUM=0
    WCSTTYP=0
    WITCSEQ=0
    Gosub COPY_ITC
    Gosub COPY_ITC_SUITE
Else
  Call ECR_DEBUG("ECR_ART_ITC: no row ITC for: BOMSEQ="-num$(S_SEQ)-[F:ITF]STOFCY-[F:ITF]ITMREF) From CFGLIBC1
Endif
$ECR_ART_ITC_FIN
Return
############################################################
$COPY_ITC
# Issue 107014 GA 03/2015 performances V5: don't update current selected [F:ITCX]
# FQ 49837 GA 10/2008 recopier les [F:ITCX] existants en cas de maj, pour chaque site concerné
#If S_MODITM<>""
If S_MODITM<>"" & S_MODITM<>[F:ITF]ITMREF
  # Issue 103814 GA 11/2014 add & (FIYNUM<>WFIYNUM | CSTTYP<>WCSTTYP)
  # FQ 60141 GA 01/2010 remplacement de YEA par FIYNUM pour la V6
  # Issue 79173 GA 06/2012 supression du lock et copie de tous les FIYNUM
  # For [F:ITCX] Where ITMREF=S_MODITM & STOFCY=[F:ITF]STOFCY & FIYNUM<>[M:CFV4]FIYNUM With Lock
   For [F:ITCX] Where ITMREF=S_MODITM & STOFCY=[F:ITF]STOFCY & (FIYNUM<>WFIYNUM | CSTTYP<>WCSTTYP | ITCSEQ<>WITCSEQ)
      [F:ITCX]ITMREF    = [F:ITF]ITMREF
      [F:ITCX]CFGVCRNUM = [F:ITF]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
      # Issue 78402 suite GA 02/2012
      GPOINT = "BEFWRIITC" : GPE=2 : Gosub ENTREE From EXEFNC
      Write [F:ITCX]
      Case fstat
        When 0 , 3 : # pas d'erreur en clé dupliquée
        When Default :
          GOK = 0
          Call FSTACTX("ITCX",W_TRASTP,"$ECR_ART_ITC(copy)"-S_MODITM) From CFGLIBD
          Goto ECR_ART_ITC_FIN
      Endcase
   Next
  Call ECR_DEBUG("COPY_ITC: S_MODITM ITC: BOMSEQ="-num$(S_SEQ)-[F:ITCX]ITMREF-"ITCSEQ="-num$([F:ITCX]ITCSEQ)) From CFGLIBC1
Endif

# Issue 107014 GA 03/2015 performances: don't update current selected [F:ITCX]
#If W_RIT<>""  # Issue 79173 GA 06/2012 copie cout std des composants de reference
If W_RIT<>"" & W_RIT<>[F:ITF]ITMREF
  # Issue 103814 GA 11/2014 add & (FIYNUM<>WFIYNUM | CSTTYP<>WCSTTYP)
   For [F:ITCX] Where ITMREF=W_RIT & STOFCY=[F:ITF]STOFCY  & CSTTYP=1 & (FIYNUM<>WFIYNUM | CSTTYP<>WCSTTYP)
      [F:ITCX]ITMREF    = [F:ITF]ITMREF
      [F:ITCX]CFGVCRNUM = [F:ITF]CFGVCRNUM
      GPOINT = "BEFWRIITC" : GPE=3 : Gosub ENTREE From EXEFNC
      Write [F:ITCX]
      Case fstat
        When 0 , 3 : # pas d'erreur en clé dupliquée
        When Default :
          GOK = 0
          Call FSTACTX("ITCX",W_TRASTP,"$ECR_ART_ITC(copy)"-W_RIT) From CFGLIBD
          Goto ECR_ART_ITC_FIN
      Endcase
   Next
  Call ECR_DEBUG("COPY_ITC: W_RIT ITC: BOMSEQ="-num$(S_SEQ)-[F:ITCX]ITMREF-"ITCSEQ="-num$([F:ITCX]ITCSEQ)) From CFGLIBC1
Endif
Return
############################################################
$COPY_ITC_SUITE                   # Issue 103969 GA 11/2014
If S_MODITM="" Return Endif
GPE=0
If S_AUTCFG
  Call ECR_DEBUG("COPY_ITC_SUITE: No copy: BOMSEQ="-num$(S_SEQ)-[F:ITF]ITMREF) From CFGLIBC1
Elsif S_MODITM<>[F:ITF]ITMREF : # Issue 113520 GH 19/05/2016 - performance optimization
  # Tables ICN, ICC, IWC,SMI

  # ICN0 : STOFCY+ITMREF+CSTTYP-ITCSEQ+OVENAT+UID        Détail natures - Coûts
  For [ICN] Where STOFCY=[F:ITF]STOFCY & ITMREF=S_MODITM
    [F:ICN]ITMREF=[F:ITF]ITMREF
    #[F:ICN]ITCSEQ=[F:ITC]ITCSEQ
    [F:ICN]UPDUSR= GUSER
    [F:ICN]UPDDAT= date$
    Write [F:ICN]
    Case fstat
      When 0 , 3 : # pas d'erreur en clé dupliquée
      When Default :
        GOK = 0
        Call FSTACTX("ICN",W_TRASTP,"$COPY_ITC_SUITE"-S_MODITM) From CFGLIBD
        Goto COPY_ITC_SUITE_FIN
    Endcase
  Call ECR_DEBUG("Insert ICN: BOMSEQ="-num$(S_SEQ)-[F:ICN]ITMREF-"ITCSEQ="-num$([F:ICN]ITCSEQ)) From CFGLIBC1
  Next

  # ICC0 : STOFCY+ITMREF+CSTTYP-ITCSEQ+MATREF+CPNTYP+UID Articles - Coûts temporaire
  For [ICC] Where STOFCY=[F:ITF]STOFCY & ITMREF=S_MODITM & CSTTYP=[F:ITC]CSTTYP
    [F:ICC]ITMREF=[F:ITF]ITMREF
    #[F:ICC]ITCSEQ=[F:ITC]ITCSEQ
    [F:ICC]UPDUSR= GUSER
    [F:ICC]UPDDAT= date$
    Write [F:ICC]
    Case fstat
      When 0 , 3 : # pas d'erreur en clé dupliquée
      When Default :
        GOK = 0
        Call FSTACTX("ICC",W_TRASTP,"$COPY_ITC_SUITE"-S_MODITM) From CFGLIBD
        Goto COPY_ITC_SUITE_FIN
    Endcase
    Call ECR_DEBUG("Insert ICC: BOMSEQ="-num$(S_SEQ)-[F:ICC]ITMREF-"ITCSEQ="-num$([F:ICC]ITCSEQ)) From CFGLIBC1
  Next

  # IWC0 : STOFCY+ITMREF+CSTTYP-ITCSEQ+WST+SCOITMREF+UID Articles - Coûts temporaire
  For [IWC] Where STOFCY=[F:ITF]STOFCY & ITMREF=S_MODITM
    [F:IWC]ITMREF=[F:ITF]ITMREF
    #[F:IWC]ITCSEQ=[F:ITC]ITCSEQ
    [F:IWC]UPDUSR= GUSER
    [F:IWC]UPDDAT= date$
    Write [F:IWC]
    Case fstat
      When 0 , 3 : # pas d'erreur en clé dupliquée
      When Default :
        GOK = 0
        Call FSTACTX("IWC",W_TRASTP,"$COPY_ITC_SUITE"-S_MODITM) From CFGLIBD
        Goto COPY_ITC_SUITE_FIN
    Endcase
    Call ECR_DEBUG("Insert IWC: BOMSEQ="-num$(S_SEQ)-[F:IWC]ITMREF-"ITCSEQ="-num$([F:IWC]ITCSEQ)) From CFGLIBC1
  Next

  # SMI0 : ITCSTRDAT+ITMREF+STOFCY+CSTTYP
  If !clalev([F:SMI]) Local File STKMVTITC [SMI] Endif
  For [SMI] Where STOFCY=[F:ITF]STOFCY & ITMREF=S_MODITM
    [F:SMI]ITMREF=[F:ITF]ITMREF
    #[F:SMI]ITCSEQ=[F:ITC]ITCSEQ
    #[F:SMI]UPDUSR= GUSER # Issue 104804 fields doesn't exist
    #[F:SMI]UPDDAT= date$ # Issue 104804 fields doesn't exist
    Write [F:SMI]
    Case fstat
      When 0 , 3 : # pas d'erreur en clé dupliquée
      When Default :
        GOK = 0
        Call FSTACTX("SMI",W_TRASTP,"$COPY_ITC_SUITE"-S_MODITM) From CFGLIBD
        Goto COPY_ITC_SUITE_FIN
    Endcase
    Call ECR_DEBUG("Insert SMI: BOMSEQ="-num$(S_SEQ)-[F:SMI]ITMREF-"ITCSEQ="-num$([F:SMI]ITCSEQ)) From CFGLIBC1
  Next
Endif
$COPY_ITC_SUITE_FIN
Return

############################################################
# Ecriture article ventes
$ECR_ART_ITS
If [F:ITS]CREUSR <> "" & [F:ITG]SALFLG = 2
  [F:ITS]ITMREF    = [F:ITM]ITMREF
  #[F:ITS]ITMDES1   = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:ITS]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189 : FGR 02/07/2009 : X3SUIVI56270 : Ca doit rester
  [F:ITS]CFGVCRNUM = [F:ITM]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
  [F:ITS]EXPNUM    = [C]EXPORT
  [F:ITS]CREUSR    = GUSER
  [F:ITS]CREDAT    = date$
  [F:ITS]UPDUSR    = ""
  [F:ITS]UPDDAT    = [0/0/0]
  Gosub PE_BEFWRIITS
  If !GPE
    Write [ITS]
    Case fstat
      When 0, 3 : # pas d'erreur en clé dupliquée
      When Default :
           GOK = 0
           Call FSTACTX("ITS",W_TRASTP,"$ECR_ART_ITS") From CFGLIBD  # From GLOCK
    Endcase
  Endif
Endif
Return

############################################################
$ECR_ART_ITU
# Ecriture article client si client existe
If [F:ITU]BPCNUM <> "" & [F:ITM]SALFLG=2
  Read [BPC]BPC0=[F:ITU]BPCNUM
  If fstat = 0
    [F:ITU]ITMREF    = [F:ITM]ITMREF
    [F:ITU]CFGVCRNUM = [F:ITM]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
    Gosub WRITE_ITU From CFGLIBC1
  Endif
  GOK=1 # Issue 98937 GA 04/2014
Endif
Return
############################################################
$ECR_ART_ITP
# Ecriture article fournisseur si fournisseur existe
If [F:ITP]BPSNUM <> "" & [F:ITM]PURFLG=2
  Read [BPS]BPS0=[F:ITP]BPSNUM
  If fstat = 0
    W_BPS            = [F:ITP]BPSNUM
    [F:ITP]ITMREF    = [F:ITM]ITMREF
    [F:ITP]CFGVCRNUM = [F:ITM]CFGVCRNUM     # Issue 78402 04/2012 éviter la perte lors du Delete (avant S_CPTCFG)
    Gosub WRITE_ITP From CFGLIBC1        # Issue 89191 GA 04/2013 source trop long, code déplacé, seul le PE reste ici
  Endif
  GOK=1 # Issue 98937 GA 04/2014
Endif
Return
############################################################
# FQ 50444 GA 11/2008
# => stocké dans la table CBLOB (avec réf article)
$ECR_ART_BLB

# FQ 66981 GA 09/2010 code revu
Local Char WIDENT1 (GLONDES) : Raz WIDENT1
Local Char WIDENT2 (GLONDES) : WIDENT2=[F:CBB]IDENT2
# Issue 104804 GA 12/2014 condition suppressed
#Delete [F:CBB] Where CODBLB="ITM" & IDENT1 = [F:ITM]ITMREF & IDENT2 = WIDENT2

If [F:CBB]CODBLB="ITM"    # on a chargé un blob (article de réf par exemple)

   # Issue 104804 GA 12/2014
   Delete [F:CBB] Where CODBLB="ITM" & IDENT1 = [F:ITM]ITMREF & IDENT2 = WIDENT2
   [F:CBB]IDENT1 = [F:ITM]ITMREF
   [F:CBB]CREUSR = GUSER
   [F:CBB]CREDAT = date$
   [F:CBB]CRETIM = time$

   GPOINT = "BEFWRICBB"
   Gosub ENTREE From EXEFNC
   Write [CBB]
   If fstat
     GOK = 0
     Call FSTACTX("CBB",W_TRASTP,"$ECR_ART_BLB") From CFGLIBD  # From GLOCK
   Endif
Endif
If S_MODITM <> "" WIDENT1=S_MODITM Else WIDENT1=W_RIT Endif
If WIDENT1<>""
  # copie des image/doc associés à l'article de référence ou article maj
   Filter [CBB] Where CODBLB="ITM" & IDENT1 = WIDENT1
   For [CBB]
       [F:CBB]IDENT1 = [F:ITM]ITMREF
       [F:CBB]CREUSR = GUSER
       [F:CBB]CREDAT = date$
       [F:CBB]CRETIM = time$

       GPOINT = "BEFWRICBB"
       Gosub ENTREE From EXEFNC
       Write [CBB]
       Case fstat
         When 0, 3 : # Issue 104804 GA 12/2014 no dupkey error
         When Default :
              GOK = 0
              Call FSTACTX("CBB",W_TRASTP,"$ECR_ART_BLB") From CFGLIBD  # From GLOCK
       Endcase
    Next
Endif
Return
############################################################
# FQ 50444 GA 11/2008 éléments piece(s) jointe(s)
# => stocké dans la table AOBJTXT (avec réf article)
$ECR_ART_AOX
# FQ 66981 GA 09/2010 code revu
Local Char WIDENT1 (GLONDES) : WIDENT1=""
Local Char WIDENT2 (GLONDES) : WIDENT2=[F:AOX]IDENT2
Local Char WIDENT3 (GLONDES) : WIDENT3=[F:AOX]IDENT3
#Delete [F:AOX] Where ABREV="ITM" & IDENT1 = [F:ITM]ITMREF & IDENT2 = WIDENT2 & IDENT3 = WIDENT3
If [F:AOX]ABREV="ITM"    # on a lu/modifié une PJ

   Delete [F:AOX] Where ABREV="ITM" & IDENT1 = [F:ITM]ITMREF & IDENT2 = WIDENT2 & IDENT3 = WIDENT3

   [F:AOX]IDENT1     = [F:ITM]ITMREF
   #[F:AOX]CREUSR     = GUSER
   #[F:AOX]CREDAT     = date$
   GPOINT = "BEFWRIAOX"
   Gosub ENTREE From EXEFNC
   Write [AOX]
   If fstat
      GOK = 0
      Call FSTACTX("AOX",W_TRASTP,"$ECR_ART_AOX") From CFGLIBD  # From GLOCK
   Endif
Endif
If S_MODITM <> "" WIDENT1=S_MODITM Else WIDENT1=W_RIT Endif
If WIDENT1<>""
  # FQ 66981 si reprise de configuration: copie des autres PJ associées à l'article maj
   Filter [AOX] Where ABREV="ITM" & IDENT1 = WIDENT1 & (IDENT2 <> WIDENT2 | IDENT3 <> WIDENT3)
   For [AOX]
       [F:AOX]IDENT1     = [F:ITM]ITMREF
       #[F:AOX]CREUSR     = GUSER
       #[F:AOX]CREDAT     = date$
       GPOINT = "BEFWRIAOX"
       Gosub ENTREE From EXEFNC
       Write [AOX]
       Case fstat
         When 0, 3 : # Issue 104804 GA 12/2014 no dupkey error
         When Default :
              GOK = 0
              Call FSTACTX("AOX",W_TRASTP,"$ECR_ART_AOX") From CFGLIBD  # From GLOCK
       Endcase
   Next
   Filter [AOX]
Endif
Return
############################################################
# FQ 50444 GA 11/2008 ajout d'un élément Clob
# => stocké dans la table TEXCLOB (avec numéro unique)
$ECR_ART_CLB
Return
############################################################
# Pointage sous scenarios dans fichier de travail
$ECR_SUBSCE
Raz [CFT]
[F:CFT]PRONUM    = adxuid(1)
[F:CFT]RECCOD    = S_LEVEL+1
[F:CFT]CODFIC    = [F:CSC]SCENUM
[F:CFT]CODZON    = W_SSC
[F:CFT]CLE       = format$("N0:8#",S_SEQ)+[F:ITM]ITMREF
[F:CFT]CLE1      = S_CURITM         # composé
[F:CFT]CREUSR     = GUSER
[F:CFT]CREDAT     = date$
Write [CFT]
If fstat
  GOK = 0
  Call FSTACTX("CFT",W_TRASTP,"$ECR_SUBSCE") From CFGLIBD
Endif
Return
############################################################
# Ecriture entete nomenclature [BOH]
$ECR_BOH
[F:BOH]ITMREF    = S_CURITM
If [F:BOH]BOMALT=0
   [F:BOH]BOMALT    = [F:CSC]BOMALT
   [F:BOH]BOMALTTYP = [F:CSC]BOMALTTYP
Endif
# Texte Maj si et seulement si alternative courante
If [F:BOH]BOMALT=[F:CSC]BOMALT
   Gosub ECR_BOH_TEX From CFGLIBC1 # Issue 89191 source trop long
Endif
# Issue 89191 GA 06/2012 maj selon réponses du scénario
#If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2
#WCRE=2 : Gosub UPD_BOH_FROM_ASW From CFGLIBC1

Case [F:BOH]QTYCOD
  When 1 :    [F:BOH]BASQTY = 1
  When 2 :    [F:BOH]BASQTY = 100
  When 3 :    [F:BOH]BASQTY = 1000
  When 4 :    [F:BOH]BASQTY = 100
  When Default :    If [F:BOH]BASQTY = 0 [F:BOH]BASQTY = 1 Endif
Endcase
Local Char W_CODKEY1(250)   # Issue 89095 GA 06/2013
Call FIND_LNK("BOM","[F:BOH]","BOMDESAXX","CLECUR1",W_CODKEY1) From CFGLIBC1
If W_CODKEY1<>""
   [F:BOH]IDENT1 = evalue(W_CODKEY1)
Else
   [F:BOH]IDENT1 = [F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)  # Issue 89191
Endif
[F:BOH]CFGVCRNUM = S_CPTCFG
If S_MODITM="" | [F:BOH]CREUSR=""    # Issue 92890 GA 09/2013 pb en reprise/reconfiguration
  [F:BOH]EXPNUM    = [C]EXPORT
  [F:BOH]CREUSR    = GUSER
  [F:BOH]CREDAT    = date$
  [F:BOH]UPDUSR    = ""
  [F:BOH]UPDDAT    = [0/0/0]
Else
  [F:BOH]UPDUSR    = GUSER
  [F:BOH]UPDDAT    = date$
Endif
# Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
Call CRE_TYPTEX("BOM")
GPOINT = "BEFWRIBOH" : Gosub ENTREE From EXEFNC
Write [BOH]
If fstat
  GOK = 0
  Call FSTACTX("BOH",W_TRASTP,"$ECR_BOH") From CFGLIBD  # From GLOCK
  Return
Endif
#
Return
############################################################
# Ecriture detail nomenclature (le buffer doit etre precharge)
$ECR_BOD
[F:BOH]ITMREF    = [F:BOH]ITMREF
[F:BOD]BOMALT    = [F:BOH]BOMALT
[F:BOD]BOMALTTYP = [F:BOH]BOMALTTYP
If [F:BOD]BOMSTUCOE=0 [F:BOD]BOMSTUCOE=1 Endif
#
If    [F:BOD]BOMQTY=0       # Calcul qté lien en UO
      [F:BOD]BOMQTY = arr([F:BOD]LIKQTY / [F:BOD]BOMSTUCOE,0.000001)
Elsif [F:BOD]LIKQTY=0    # Calcul qté lien en US
      [F:BOD]LIKQTY = arr([F:BOD]BOMQTY * [F:BOD]BOMSTUCOE,0.000001)
Endif
#
If [F:BOD]LIKQTY <> 0
  If [F:BOD]ITMREF <> [F:BOD]CPNITMREF
    [F:BOD]CREUSR    = GUSER
    [F:BOD]CREDAT    = date$
    # Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
    Call CRE_TYPTEX("BOMD")
    GPOINT = "BEFWRIBOD" : Gosub ENTREE From EXEFNC
    Write [BOD]
    If fstat
      GOK = 0 :  Call FSTACTX("BOD",W_TRASTP,"$ECR_BOD") From CFGLIBD  # From GLOCK
    Endif
  Else
    W_MSG = mess(154,188,1)+"\("+[F:BOD]ITMREF-num$([F:BOD]BOMSEQ)-[F:BOD]CPNITMREF+")"
  Endif
Else
  # GA 07/2012 Message d'information
  # Composant de nomenclature : Quantité lien nomenclature
    W_TRAMSG= mess(203,190,1)+"\("+[F:BOD]ITMREF-num$([F:BOD]BOMSEQ)-[F:BOD]CPNITMREF+") :"-mess(26,200,1)-num$([F:BOD]LIKQTY)
    Gosub TRA_MSG From CFGLIBB
Endif
Return
############################################################
$CREATE_BOM                                  # Issue 89191 #
# Issue 89191 GA 05/2013 pour comportement des UPD_xxx_FROM_ASW
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2
Local Char SAV_CURITM(GLONITM) : SAV_CURITM=S_CURITM       # Issue 89191
Local Char SAV_MODITM(GLONITM) : SAV_MODITM=S_MODITM       # Issue 89191
#S_MODITM = ""                                              # Issue 89191
Gosub CTL_PARAM_CSC From CFGLIBC1

# Creation des composants selectionnes
W_TRASTP=mess(187,188,1)-"($CREATE_BOM)" : Gosub TRA_STEP From CFGLIBB     # suivi

[F:BOH]ITMREF    = S_CURITM
[F:BOH]BOMALT    = [F:CSC]BOMALT
[F:BOH]BOMALTTYP = [F:CSC]BOMALTTYP

For W_I = 0 To [M:CFW]NBLIG-1
  If [M:CFW]WRKPHA(W_I) = 3 & [M:CFW]WRKQTYSTU(W_I) <> 0
    Read [ITM]ITM0=[M:CFW]WRKITMREF(W_I)
    If fstat = 0
      If W_BOH = 0
        Gosub ECR_BOH
        If GOK <> 1 : Break : Endif
        W_BOH = 1
      Endif
      Raz [F:BOD]
      Gosub INI_BOD From WUVAR
      [F:BOD]ITMREF    = S_CURITM
      If [M:CFW]WRKSEQ(W_I) = 0
        W_SEQ += GBOMSTE
        [F:BOD]BOMSEQ  = W_SEQ
      Else
        [F:BOD]BOMSEQ  = [M:CFW]WRKSEQ(W_I)
      Endif
      [F:BOD]CPNITMREF = [M:CFW]WRKITMREF(W_I)
      [F:BOD]LIKQTY    = [M:CFW]WRKQTYSTU(W_I)
      If dim([F:BOD]CSTFLG) > 0
        [F:BOD]CSTFLG = 2
      Endif
      [F:BOD]PICPRN    = 2
      [F:BOD]BOMSTRDAT = [F:BOH]BOHSTRDAT
      [F:BOD]BOMENDDAT = [F:BOH]BOHENDDAT
      # JPJ E24280    - Gestion UOM (industrie du process-Code activité UML) ->
      #    Valeurs par défaut
      [F:BOD]BOMUOM=[M:CFW]WRKSTU(W_I)
      # Issue 84696 GA 02/2013
      If [F:BOD]BOMSTUCOE = 0 [F:BOD]BOMSTUCOE=1 Endif
      If [F:BOD]LIKQTY<>0 [F:BOD]BOMQTY=[F:BOD]LIKQTY * [F:BOD]BOMSTUCOE Endif
      Gosub ECR_BOD
      If GOK <> 1 : Break : Endif
    Endif
  Endif
Next W_I
#
If GOK <> 1 : Goto CREATE_BOM_FIN : Endif
#
# Creation des composants
#
# Deroulement de la pile jusqu'aux enregistrement composants
[M:CFP]PILREC = 4
Gosub SKIP_PILE

If GOK <> 1 : Goto CREATE_BOM_FIN : Endif
Filter [CSL] Where SCENUM    = [F:CSC]SCENUM &
&                  SCENUMTYP = 5             &
&                  SYMTYP    = 0
&            Order By Key CSL0
For [CSL]
  If [F:CSL]CNDFORLIN = "" | num$(evalue([F:CSL]CNDFORLIN)) = "1"
    S_PHASE = [F:CSL]SCENUMTYP
    S_SEQ   = [F:CSL]SCENUMSEQ
    S_LIN   = [F:CSL]SCENUMLIN
    Gosub MEI_BUFFERS From CFGLIBB
    W_ITM = [F:ITM]ITMREF
    W_TLP = [F:ITM]CFGLIN
    For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
      If [M:CFP]PILPHA([M:CFP]PILIND)             <> S_PHASE |
&        [M:CFP]PILSEQ([M:CFP]PILIND)             <> S_SEQ   |
&        mid$([M:CFP]PILKEY([M:CFP]PILIND),13,20) <> [F:CSL]ITMREF
        [M:CFP]PILSTR = [M:CFP]PILIND
        Gosub TRT_COMPOSANT
        If (GOK <> 1 | GERR=1) : Break 2 : Endif
        Break
      Else
        If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
          Gosub TRT_SYMBOLE From CFGLIBC1
          If (GOK<>1 | S_ABORT | W_MSG <> "")
            Break
          Endif
        Endif
      Endif
    Next
  Else
    While  [M:CFP]PILPHA([M:CFP]PILIND)             =  [F:CSL]SCENUMTYP &
&          [M:CFP]PILSEQ([M:CFP]PILIND)             =  [F:CSL]SCENUMSEQ &
&          mid$([M:CFP]PILKEY([M:CFP]PILIND),13,20) =  [F:CSL]ITMREF
      [M:CFP]PILIND += 1
    Wend
   [M:CFP]PILSTR = [M:CFP]PILIND
  Endif
Next
Filter [CSL]
$CREATE_BOM_FIN
S_CURITM=SAV_CURITM       # Issue 89191
S_MODITM=SAV_MODITM       # Issue 89191
Return
############################################################
# Traitement composant
$TRT_COMPOSANT
Local Shortint W_UPDCPN : W_UPDCPN=0 # Issue 103969 GA 11/2014
W_TRASTP=mess(233,188,1)-"($TRT_COMPOSANT)"-[F:ITM]ITMREF-[F:ITM]TCLCOD : Gosub TRA_STEP From CFGLIBB     # suivi

Local Char SAV_CURITM(GLONITM)
Local Char SAV_MODITM(GLONITM)
SAV_CURITM=S_CURITM
SAV_MODITM=S_MODITM

Read [ITG]ITG0=S_FCY;[F:ITM]TCLCOD
If fstat
  Read [ITG]ITG0="";[F:ITM]TCLCOD
#    If GUSER="JPJ1" & S_SUBSCE<>""
#        Read [ITG]ITG0=S_FCY;"RRR"+[F:ITM]TCLCOD
#        Infbox (num$(fstat))
#    Endif
  If fstat
    GMESSAGE = [F:ITM]ITMREF-[F:ITM]TCLCOD-mess(60,188,1)
    Gosub TRA_ERR From CFGLIBB
    GERR     = 1
    FIN      = 1
    Goto TRT_COMPOSANT_FIN
  Endif
Endif
W_SSC = [F:CSL]SUBSCENUM

# Composant de reference
W_RIT = [F:CSL]ITMREF
If evalue("dim("+W_PRS+"RCMP"+num$(S_SEQ)+")>0&type("+W_PRS+"RCMP"+num$(S_SEQ)+")>10")
  W_RIT = evalue(W_PRS+"RCMP"+num$(S_SEQ))
  # Issue 89191 GA 04/2013 si la valeur de W_PRS+"RCMP"+num$(S_SEQ)="", conserver la réf initiale
  If W_RIT=""
     W_RIT = [F:CSL]ITMREF
  Else
     Call ECR_DEBUG("TRT_COMPOSANT: composant"-[F:CSL]ITMREF-"remplacé par"-W_RIT) From CFGLIBC1
  Endif
Endif
#
Case [F:CSL]SEAITMREF
  When 1 :
    If [F:ITM]ITMREF = "" & [F:ITG]ITMREFCOU = ""
      GMESSAGE = num$([F:BOD]BOMSEQ)-[F:ITM]ITMREF-mess(71,188,1)
      Gosub TRA_ERR From CFGLIBB
      GERR = 1 : FIN = 1 : Goto TRT_COMPOSANT_FIN
    Else
      Read [ITM1]ITM0=[F:ITM]ITMREF
      If fstat
        Gosub ECR_ARTICLE : If GOK<>1 : Goto TRT_COMPOSANT_FIN : Endif
      Else
        W_UPDCPN=1 # Issue 103969 GA 11/2014
      Endif
    Endif
  When 2,4 :   # FQ 47393 suite FQ 46903 GA 05/2008
    Call EXI_ARTICLE([F:ITM]CFGLIN,W_RET)
    If W_RET <> 0
      If ([F:ITM]ITMREF = W_ITM & [F:ITG]ITMREFCOU = "") |
&        ([F:ITM]ITMREF = ""    & [F:ITG]ITMREFCOU = "")
        GMESSAGE =  num$([F:BOD]BOMSEQ)-[F:ITM]ITMREF-mess(71,188,1)
        Gosub TRA_ERR From CFGLIBB
        GERR = 1 : FIN = 1 : Goto TRT_COMPOSANT_FIN
      Else
        Gosub ECR_ARTICLE : If GOK<>1 : Goto TRT_COMPOSANT_FIN : Endif
      Endif
    Else
      [F:ITM] = [F:ITM1]
      W_UPDCPN=1 # Issue 103969 GA 11/2014
    Endif
  When 3 :
    If ([F:ITM]ITMREF = W_ITM & [F:ITG]ITMREFCOU = "") |
&      ([F:ITM]ITMREF = ""    & [F:ITG]ITMREFCOU = "")
      GMESSAGE =  num$([F:BOD]BOMSEQ)-[F:ITM]ITMREF-mess(71,188,1)
      Gosub TRA_ERR From CFGLIBB
      GERR = 1 : FIN = 1 : Goto TRT_COMPOSANT_FIN
    Else
      Read [ITM1]ITM0=[F:ITM]ITMREF
      If fstat = 0
        GMESSAGE = mess(61,188,1)-"["+[F:ITM]ITMREF+"]"
        Gosub TRA_ERR From CFGLIBB
        GERR = 1 : FIN = 1 : Goto TRT_COMPOSANT_FIN
      Else
        Gosub ECR_ARTICLE : If GOK<>1 : Goto TRT_COMPOSANT_FIN : Endif
      Endif
    Endif
Endcase

# Ecriture entete nomenclature
If W_BOH = 0
  Gosub ECR_BOH
  If GOK<>1 : Goto TRT_COMPOSANT_FIN : Endif
  W_BOH = 1
Endif


# Ecriture detail nomenclature
[F:BOD]ITMREF    = S_CURITM
[F:BOD]CPNITMREF = [F:ITM]ITMREF
#
Gosub ECR_BOD
#
If W_UPDCPN   # Issue 103814 & 103969 GA 11/2014 add ITF, ITC, etc ...
  S_MODITM=[F:ITM]ITMREF
  W_ITM=[F:ITM]ITMREF
  Gosub LEC_ITM From CFGLIBB
  Call ECR_DEBUG("Update existing component ITF="-[F:ITF]ITMREF-[F:ITF]STOFCY) From CFGLIBC1
  #
  # Issue 106875 GA 03/2015 variables for this component already evaluated
  #Gosub UPD_VAR_FROM_ASW From CFGLIBC1

  Gosub UPD_ITM_FROM_ASW From CFGLIBC1
  Gosub UPD_ITF_FROM_ASW From CFGLIBC1
  Gosub UPD_ITC_FROM_ASW From CFGLIBC1
  Gosub ECR_ART_ITF
  If GOK <> 1 Goto TRT_COMPOSANT_FIN Endif

  Gosub UPD_ITS_FROM_ASW From CFGLIBC1
  Gosub ECR_ART_ITS
  If GOK <> 1 Goto TRT_COMPOSANT_FIN Endif

  Gosub UPD_ITU_FROM_ASW From CFGLIBC1
  Gosub ECR_ART_ITU
  If GOK <> 1 Goto TRT_COMPOSANT_FIN Endif

  Gosub UPD_ITP_FROM_ASW From CFGLIBC1
  Gosub ECR_ART_ITP
  If GOK <> 1 Goto TRT_COMPOSANT_FIN Endif

  #Gosub ECR_ART_BLB
  #Gosub ECR_ART_CLB
  #Gosub ECR_ART_AOX

Endif
#
$TRT_COMPOSANT_FIN
S_CURITM=SAV_CURITM
S_MODITM=SAV_MODITM
Return
############################################################
# Reactualisation du compose
# Securite pas de reactu du numero d'article si compteur auto
# Nota: W_ERR<>"" (erreur en-cours) est piégé par l'appel à cettte fct
#idem GOK
$REA_COMPOSE
# Issue 85230 GA 10/2012 pour comportement des UPD_ITx_FROM_ASW
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=1
S_PHASE=2 : S_SEQ=0
#
Raz W_MSG, W_ERR
Read [ITM]ITM0=S_CURITM
If fstat = 0
  Read [ITG]ITG0=S_FCY;[F:ITM]TCLCOD
  If fstat
    Read [ITG]ITG0="";[F:ITM]TCLCOD
    If fstat
      Raz [F:ITG]
    Endif
  Endif
  # Mise en ligne table ITC
  Call CAL_CST(0,[F:CSC]CSTCOD,S_FCY,[F:ITM]ITMREF,S_IPTDAT,S_CUR,W_CST,W_RET) From CFGLIBD
  If W_RET=99
        Raz[ITC]
  Endif
  W_TRAMSG= mess(163,188,1)-S_CURITM-"($REA_COMPOSE)" : Gosub TRA_MSG From CFGLIBB
  Gosub UPD_ITM_FROM_ASW From CFGLIBC1 # Issue 85230 GA 10/2012
  If (W_ERR = 0 & GOK=1)
    Gosub PE_BEFREWITM
    Rewrite [ITM]
    Case fstat
     When 0 :
     When 1 :
       GLOCK="$ITMMASTER"-[F:ITM]ITMREF : GOK=-1
       Goto REA_COMPOSE_FIN
     When Default :
      Call FSTACTX("ITM",W_TRASTP,"$REA_COMPOSE") From CFGLIBD
      GOK=0 : Goto REA_COMPOSE_FIN
    Endcase
  Else
    Goto REA_COMPOSE_FIN
  Endif
# reactualisation article ventes [ITS] si existe
  Read [ITS]ITS0=[F:ITM]ITMREF
  If fstat = 0
    Gosub UPD_ITS_FROM_ASW From CFGLIBC1 # Issue 85230 GA 10/2012
    If (W_ERR = 0 & GOK=1)
      Gosub PE_BEFREWITS
      Rewrite [ITS]
  Case fstat
       When 0 :
       When 1 :
    GLOCK="$ITMSALES"-[F:ITM]ITMREF : GOK=-1
    Goto REA_COMPOSE_FIN
   When Default :
        Call FSTACTX("ITS",W_TRASTP,"$REA_COMPOSE") From CFGLIBD
        GOK=0 : Goto REA_COMPOSE_FIN
   Endcase
    Else
  Goto REA_COMPOSE_FIN
    Endif
  Endif
Else
  GOK = 0
  Call FSTACTX("ITM",W_TRASTP,"$REA_COMPOSE") From CFGLIBD  # From GLOCK
Endif

# Reactualisation article client [ITU] si existe
  Filter [ITU] Where ITMREF    = [F:ITM]ITMREF &
&                    CFGVCRNUM = S_CPTCFG
&              Order By Key ITU0
  For [ITU]
    Gosub UPD_ITU_FROM_ASW From CFGLIBC1 # Issue 85230 GA 10/2012
    #GPOINT = "BEFREWITU" : Gosub ENTREE From EXEFNC
    Gosub REWRITE_ITU From CFGLIBC1   # Issue 89191 GA 04/2013 avant Rewrite + Case fstat
    #Break# un seul ITU
  Next
  Filter [ITU]
  If (GOK <> 1 | W_ERR <> 0) : Goto DEBUT_CFGVAL_FIN : Endif

# Reactualisation article fournisseur [ITP] si existe
  Filter [ITP] Where ITMREF    = [F:ITM]ITMREF &
&                    CFGVCRNUM = S_CPTCFG
&              Order By Key ITP0
  For [ITP]
    Gosub UPD_ITP_FROM_ASW From CFGLIBC1 # Issue 85230 GA 10/2012
    #GPOINT = "BEFREWITP" : Gosub ENTREE From EXEFNC
    Gosub REWRITE_ITP From CFGLIBC1   # Issue 89191 GA 04/2013 avant Rewrite + Case fstat
    #Break# un seul
  Next
  Filter [ITP]
  If (GOK <> 1 | W_ERR <> 0) : Goto DEBUT_CFGVAL_FIN : Endif

# Reactualisation article coût [ITC] si existe
  # CCC (30/03/06) Bug 35577 : Si évaluation de formule => on écrit le coût standard
  If [F:CSC]CSTCOD=8
    W_M=1
  Else
    W_M=find([F:CSC]CSTCOD,5,6,9)    # 1: std, 2: actualisé, 3: budget
  Endif

  # Issue 85230 GA 10/2012 maj de tous les ITC avec les données du scénario
  Filter [ITC] Where ITMREF    = [F:ITM]ITMREF &
&                   (STOFCY   = S_FCY | [F:CSC]FCYFLG=2)  &
&                    CFGVCRNUM = S_CPTCFG      &
&                    CSTTYP    = W_M           &
&                    UID       = 0
&              Order By Key ITC0
  # Issue 85230 GA 10/2012 il va falloir boucler ...
  #Read [ITC]ITC0 First
  #If fstat = 0
  For [ITC]
    Gosub UPD_ITC_FROM_ASW From CFGLIBC1
    If (W_ERR = 0 & GOK=1)
      GPOINT = "BEFREWITC" :  Gosub ENTREE From EXEFNC
      Rewrite [ITC]
      Case fstat
        When 0 :
        When 1 :
        GLOCK="$ITMCOST"-[F:ITC]STOFCY+"~"+[F:ITC]ITMREF+"~"+num$([F:ITC]CSTTYP)+"~"+num$([F:ITC]ITCSEQ)
        GOK=-1
        Goto REA_COMPOSE_FIN
        When Default :
        Call FSTACTX("ITC",W_TRASTP,"$REA_COMPOSE") From CFGLIBD
        GOK=0 : Goto REA_COMPOSE_FIN
      Endcase
    Else
      Goto REA_COMPOSE_FIN
    Endif
  Next         # Issue 85230 GA 10/2012 boucle ...
  Filter [ITC] # FQ 49837 GA 10/2008 déplacé en fin du Endif

  # Reactualisation article site [ITF] si existe - GA 09/2007 FQ 41599
  # Issue 85230 GA 10/2012 maj de tous les ITF avec les données du scénario
  Filter [ITF] Where ITMREF    = [F:ITM]ITMREF &
&                    (STOFCY   = S_FCY | [F:CSC]FCYFLG = 2)  &
&                    CFGVCRNUM = S_CPTCFG
&              Order By Key ITF0
  For [ITF]
    Gosub UPD_ITF_FROM_ASW From CFGLIBC1 # Issue 85230 GA 10/2012
    GPOINT = "BEFREWITF" : Gosub ENTREE From EXEFNC
    Rewrite [ITF]
    Case fstat
     When 0 :
     When 1 :
      # FGR 15/01/2010 : X3SUIVI60986
      #GLOCK="$ITMBPS"-[F:ITF]ITMREF+"~"+[F:ITF]BPSNUM : GOK=-1
      GLOCK="$ITMFACILIT"-[F:ITF]ITMREF+"~"+[F:ITF]STOFCY : GOK=-1
      Break
     When Default :
      Call FSTACTX("ITF",W_TRASTP,"$REA_COMPOSE") From CFGLIBD
      GOK=0 : Break
    Endcase
    #Break# un seul
  Next
  Filter [ITF]
  If (GOK <> 1 | W_ERR <> 0) : Goto DEBUT_CFGVAL_FIN : Endif

$REA_COMPOSE_FIN
Filter [ITC]
Filter [ITF]
Filter [ITP]
Filter [ITU]
Filter [ITS]

Return
############################################################
$CREATE_ROUTING                              # Issue 89191 #
# Issue 89191 GA 05/2013 pour comportement des UPD_xxx_FROM_ASW
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2
Local Char SAV_CURITM(GLONITM) : SAV_CURITM=S_CURITM       # Issue 89191
Local Char SAV_MODITM(GLONITM) : SAV_MODITM=S_MODITM       # Issue 89191
#S_MODITM = ""                                              # Issue 89191
Gosub CTL_PARAM_CSC From CFGLIBC1

W_TRASTP=mess(186,188,1)-"($CREATE_ROUTING)" : Call ECR_DEBUG(W_TRASTP) From CFGLIBC1

[F:ROH]ROUALT = [F:CSC]ROUALT
[F:ROH]ITMREF = S_CURITM
[F:ROH]FCY    = S_FCY              : # GA V6 ajout FCY 12/2007

# Deroulement de la pile jusqu'aux enregistrements operations
[M:CFP]PILREC = 7
Gosub SKIP_PILE

If GOK <> 1 : Goto CREATE_ROUTING_FIN : Endif
# Traitement des operations
Filter [CSL] Where SCENUM    = [F:CSC]SCENUM &
&                  SCENUMTYP = 8             &
&                  SYMTYP    = 0
&            Order By Key CSL0
For [CSL]
  If [F:CSL]CNDFORLIN = "" | num$(evalue([F:CSL]CNDFORLIN)) = "1"
    S_PHASE = [F:CSL]SCENUMTYP
    S_SEQ   = [F:CSL]SCENUMSEQ
    S_LIN   = [F:CSL]SCENUMLIN
    S_OPS   = [F:CSL]STDOPENUM
    Gosub MEI_BUFFERS From CFGLIBB

    For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
      If [M:CFP]PILPHA([M:CFP]PILIND)                <> S_PHASE |
&        [M:CFP]PILSEQ([M:CFP]PILIND)                <> S_SEQ   |
&        val(mid$([M:CFP]PILKEY([M:CFP]PILIND),9,4)) <> S_OPS
        [M:CFP]PILSTR = [M:CFP]PILIND
        Gosub TRT_OPERATION
        If (GOK <> 1 | GERR=1) : Break 2 : Endif
        Break
      Else
        If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
            Gosub TRT_SYMBOLE From CFGLIBC1
            If (GOK<>1 | S_ABORT | W_MSG <> "")
              Break
            Endif
        Endif
      Endif
    Next
  Else
    While  [M:CFP]PILPHA([M:CFP]PILIND)                =  [F:CSL]SCENUMTYP &
&          [M:CFP]PILSEQ([M:CFP]PILIND)                =  [F:CSL]SCENUMSEQ &
&          val(mid$([M:CFP]PILKEY([M:CFP]PILIND),9,4)) =  [F:CSL]STDOPENUM
      [M:CFP]PILIND += 1
    Wend
    [M:CFP]PILSTR = [M:CFP]PILIND
  Endif
Next
Filter [CSL]
$CREATE_ROUTING_FIN
S_CURITM=SAV_CURITM       # Issue 89191
S_MODITM=SAV_MODITM       # Issue 89191
Return
############################################################
# Ecriture operation si enregistrement de reference trouve
# et si au moins un temps defini
$TRT_OPERATION
# Issue 93690 GA 10/2013 Control standard operation
If [F:ROO]STDOPENUM<>S_OPS
   [F:ROO]STDOPENUM=S_OPS
Endif
If [F:ROO]ITMREF <> ""
  If !([F:ROO]PRPTIM = 0 &
&      [F:ROO]SETTIM = 0 &
&      [F:ROO]OPETIM = 0 &
&      [F:ROO]CAD    = 0 &
&      [F:ROO]WAITIM = 0 &
&      [F:ROO]PSPTIM = 0 &
&      [F:ROO]SCOCOD <> 2)
    If W_ROH = 0
      Gosub ECR_ROH
      If GOK<>1 : Goto TRT_OPERATION_FIN : Endif
      W_ROH = 1
    Endif
    Gosub ECR_ROO
    If GOK<>1 Goto TRT_OPERATION_FIN Endif
# Ecriture jalonnement si un parametrage existe
    If [M:CFP]PILSCD <> 0
       Gosub ECR_ROS
       If GOK<>1 Goto TRT_OPERATION_FIN Endif
    Endif
  Endif
Endif
$TRT_OPERATION_FIN
Return
############################################################
# Ecriture entete gamme [ROH]
$ECR_ROH
[F:ROH]ITMREF    = S_CURITM
If [F:ROH]ROUALT=0
   [F:ROH]ROUALT    = [F:CSC]ROUALT
   [F:ROH]FCY       = S_FCY
Endif
# Texte Maj si et seulement si gamme courante
If [F:ROH]ROUALT=[F:CSC]ROUALT
   Gosub ECR_ROH_TEX From CFGLIBC1 # Issue 89191 source trop long
Endif
# Issue 89191 GA 06/2012 maj selon réponses du scénario
#If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2
#WCRE=2 : Gosub UPD_ROH_FROM_ASW From CFGLIBC1

If [F:ROH]CFMFLG= 0 # Issue 99033 GA 04/2014 only if null
   [F:ROH]CFMFLG= 1
Endif
Local Char W_CODKEY1(250)   # Issue 89095 GA 06/2013
Call FIND_LNK("ROUTING","[F:ROH]","ROUDESAXX","CLECUR1",W_CODKEY1) From CFGLIBC1
If W_CODKEY1<>""
   [F:ROH]IDENT1 = evalue(W_CODKEY1)
Else
   [F:ROH]IDENT1 = [F:ROH]ITMREF + "~" + num$([F:ROH]ROUALT) # Issue 89191
Endif
[F:ROH]CFGVCRNUM = S_CPTCFG
If S_MODITM="" | [F:ROH]CREUSR=""    # Issue 92890 GA 09/2013 pb en reprise/reconfiguration
  [F:ROH]EXPNUM    = [C]EXPORT
  [F:ROH]CREUSR    = GUSER
  [F:ROH]CREDAT    = date$
  [F:ROH]UPDUSR    = ""
  [F:ROH]UPDDAT    = [0/0/0]
Else
  [F:ROH]UPDUSR    = GUSER
  [F:ROH]UPDDAT    = date$
Endif
# Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
Call CRE_TYPTEX("ROUTING")
GPOINT = "BEFWRIROH" : Gosub ENTREE From EXEFNC
Write [ROH]
If fstat
  GOK = 0
  Call RSTACTX("ROH",[F:ROH]ITMREF-num$([F:ROH]ROUALT),W_TRASTP,"$ECR_ROH") From CFGLIBD
  Return
Endif
S_CURROU = [F:ROH]ITMREF
#
Return
############################################################
# Ecriture opération gamme [ROO]
$ECR_ROO
[F:ROO]ITMREF = [F:ROH]ITMREF
[F:ROO]ROUALT = [F:ROH]ROUALT
[F:ROO]FCY    = [F:ROH]FCY
If [F:ROO]OPESTUCOE = 0
   [F:ROO]OPESTUCOE = 1
Endif
If [F:ROO]OPEUOM = ""
   [F:ROO]OPEUOM = W_UOM
Endif
[F:ROO]CREUSR    = GUSER
[F:ROO]CREDAT    = date$
If [F:ROO]BASQTY = 0 & [F:ROO]ROOTIMCOD=1
   [F:ROO]BASQTY = 1
Endif
# Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
Call CRE_TYPTEX("ROUOPE")
GPOINT = "BEFWRIROO" : Gosub ENTREE From EXEFNC
Write [ROO]
If fstat
  GOK = 0
  Call FSTACTX("ROO",W_TRASTP,"$TRT_OPERATION") From CFGLIBD  # From GLOCK
Endif
Return
############################################################
# Ecriture jalonnement gamme [ROS]
$ECR_ROS
[F:ROS]ITMREF = [F:ROH]ITMREF
[F:ROS]ROUALT = [F:ROH]ROUALT
[F:ROO]FCY    = [F:ROH]FCY
[F:ROS]OPENUM = [F:ROO]OPENUM
[F:ROS]CREUSR    = GUSER
[F:ROS]CREDAT    = date$
# Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
Call CRE_TYPTEX("ROUSCD")
GPOINT = "BEFWRIROS" : Gosub ENTREE From EXEFNC
Write [ROS]
If fstat
  GOK = 0
  Call FSTACTX("ROS",W_TRASTP,"$TRT_OPERATION") From CFGLIBD  # From GLOCK
Endif
Return
############################################################
# Reprise du jalonnement de la gamme de reference
# Si jalonnement incorrect
# generation d'un jalonnement par defaut (successeur et derniere operation = etape production)
$CTR_JALONNEMENT
If clalev([M:ROU3]) = 0 : Local Mask ROU3 [ROU3] : Endif
Raz [M:ROU3]
#
# FQ 75666 GA 08/2011 Modif faite par Bordeaux Ko Remplacer [F:CSC]FCY par S_FCY
Filter [ROS] Where FCY    = S_FCY    &
&                  ITMREF = S_CURITM      &
&                  ROUALT = [F:CSC]ROUALT
&            Order By Key ROS0
For [ROS]
  If [M:ROU3]BASTAB < dim([M:ROU3]OPENUM)-1
    [M:ROU3]BASTAB += 1
    nolign = [M:ROU3]BASTAB
    [M:ROU3] = [F:ROS]
  Endif
Next
Filter [ROS]
# Issue 84828 GA 11/2012
# Generation jalonnement pour operations std
For nolign = 0 To [M:ROU3]BASTAB-1
  If [M:ROU3]OPENUM(nolign) = [M:ROU3]NEXOPENUM(nolign)
    W_O = find(0,[M:ROU3]NEXOPENUM(0..[M:ROU3]BASTAB-1))
    If W_O = 0
      [M:ROU3]NEXOPENUM(nolign) = 0
    Else
      [M:ROU3]NEXOPENUM(W_O-1)  = [M:ROU3]OPENUM(nolign)
      [M:ROU3]NEXOPENUM(nolign) = 0
    Endif
  Endif
Next nolign
# Issue 84828 GA 11/2012
# Forcage une operation de production si necessaire la derniere
If !find(2,[M:ROU3]MFGMST(0..[M:ROU3]BASTAB-1)) & [M:ROU3]BASTAB > 0
  [M:ROU3]MFGMST([M:ROU3]BASTAB-1) = 2
Endif
# Contrôle jalonnement
Call CTRJAL(W_RET,W_MSG) From CFGLIBD
# Issue 96588 GA 02/2014 compléter le jalonnement si nécessaire
#If W_RET = 2
#  Gosub VAL_GAMME
#Endif
If W_RET <> 2
  GPE=0 : GPOINT = "DELMESS" : Gosub ENTREE From EXEFNC
  If !GPE    # Non géré comme erreur bloquante donc message
    W_TRAMSG = [F:ROH]ITMREF-num$([F:ROH]ROUALT)-W_MSG-"\"-mess(222,188,1)    # 222: 'jalonnement par défaut de la gamme
    Call MESSAGE(W_TRAMSG) From GESECRAN                # MESSAGE et non pas ERREUR car avertissement à l'utilisateur
    Gosub TRA_MSG From CFGLIBB                          # Trace en interactif
  Endif
  W_MSG    = ""                    # RAZ car le cfg utilise cette variable comme test bloquant
  Gosub GEN_JALDEF
Endif
Gosub UPD_ROUSCD
Gosub VAL_GAMME
Return
############################################################
$VAL_GAMME
Readlock [ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY   : # Beryl Site en fin de clé primaire
If fstat = 0
  [F:ROH]CFMFLG    = 2
  Rewrite [ROH]
  If fstat
    GOK = 0
    Call FSTACTX("ROH",W_TRASTP,"$VAL_GAMME") From CFGLIBD  # From GLOCK
  Endif
Else
  Call ECR_DEBUG("VAL_GAMME: routing not found") From CFGLIBC1
Endif
Return
############################################################
# Pour compatibilite avec version anterieures sans parametrage du jalonnement
# Reprise du jalonnement de la gamme de reference
# Si jalonnement incorrect
# generation d'un jalonnement par defaut (successeur et derniere operation = etape production)
$ECR_JALONNEMENT
If clalev([M:ROU3]) = 0 : Local Mask ROU3 [ROU3] : Endif
Raz [M:ROU3]
#
# FQ 75666 GA 08/2011 Modif faite par Bordeaux Ko Remplacer [F:CSC]FCY par S_FCY
Filter [ROO] Where FCY    = S_FCY    &
&                  ITMREF = S_CURITM      &
&                  ROUALT = [F:CSC]ROUALT
&            Order By Key ROO0
For [ROO]
# FQ 75666 GA 08/2011 Modif faite par Bordeaux Ko Remplacer [F:CSC]FCY par S_FCY
  Read [ROS]ROS0=S_FCY;[F:CSC]ROUREF;[F:CSC]ROUALTREF;[F:ROO]OPENUM
  If fstat = 0
    If [M:ROU3]BASTAB < dim([M:ROU3]OPENUM)-1
      [M:ROU3]BASTAB += 1
      nolign = [M:ROU3]BASTAB
      [M:ROU3] = [F:ROS]
    Endif
  Else
    If [M:ROU3]BASTAB < dim([M:ROU3]OPENUM)-1
      [M:ROU3]BASTAB += 1
      nolign = [M:ROU3]BASTAB
      [M:ROU3]OPENUM   (nolign-1) = [F:ROO]OPENUM
      [M:ROU3]NEXOPENUM(nolign-1) = [F:ROO]OPENUM
      [M:ROU3]DACMST   (nolign-1) = 2
      [M:ROU3]SCDCOD   (nolign-1) = 1
      [M:ROU3]MFGMST   (nolign-1) = 1
    Endif
  Endif
Next
Filter [ROO]
# Generation jalonnement pour operations std
For nolign = 0 To [M:ROU3]BASTAB-1
  If [M:ROU3]OPENUM(nolign) = [M:ROU3]NEXOPENUM(nolign)
    W_O = find(0,[M:ROU3]NEXOPENUM(0..[M:ROU3]BASTAB-1))
    If W_O = 0
      [M:ROU3]NEXOPENUM(nolign) = 0
    Else
      [M:ROU3]NEXOPENUM(W_O-1)  = [M:ROU3]OPENUM(nolign)
      [M:ROU3]NEXOPENUM(nolign) = 0
    Endif
  Endif
Next nolign
# Forcage une operation de production si necessaire la derniere
If !find(2,[M:ROU3]MFGMST(0..[M:ROU3]BASTAB-1)) & [M:ROU3]BASTAB > 0
  [M:ROU3]MFGMST([M:ROU3]BASTAB-1) = 2
Endif
# Contrôle jalonnement
Call CTRJAL(W_RET,W_MSG) From CFGLIBD
If W_RET <> 2
  # FQ 76390 GA 09/2011
  GPE=0 : GPOINT = "DELMESS" : Gosub ENTREE From EXEFNC
  If !GPE
    # Non géré comme erreur bloquante donc message
    W_TRAMSG = [F:ROH]ITMREF-num$([F:ROH]ROUALT)-W_MSG-"\"-mess(222,188,1)    # 222: 'jalonnement par défaut de la gamme
    Call MESSAGE(W_TRAMSG) From GESECRAN                # MESSAGE et non pas ERREUR car avertissement à l'utilisateur
    Gosub TRA_MSG From CFGLIBB                          # Trace en interactif
  Endif
  W_MSG    = ""                    # RAZ car le cfg utilise cette variable comme test bloquant
  Gosub GEN_JALDEF
Endif
Gosub ECR_ROUSCD
Gosub VAL_GAMME
Return
############################################################
# Generation d'un jalonnement par defaut
$GEN_JALDEF
Raz [M:ROU3]
# FQ 75666 GA 08/2011 Modif faite par Bordeaux Ko Remplacer [F:CSC]FCY par S_FCY
Filter [ROO] Where FCY    = S_FCY    &
&                  ITMREF = S_CURITM      &
&                  ROUALT = [F:CSC]ROUALT
&            Order By Key ROO0
For [ROO]
  If [M:ROU3]BASTAB < dim([M:ROU3]OPENUM)-1
    [M:ROU3]OPENUM   ([M:ROU3]BASTAB) = [F:ROO]OPENUM
    [M:ROU3]DACMST   ([M:ROU3]BASTAB) = 2
    [M:ROU3]SCDCOD   ([M:ROU3]BASTAB) = 1
    [M:ROU3]BASTAB += 1
  Endif
Next
Filter [ROO]  # FQ 63278 GA 03/2010
For nolign = 0 To [M:ROU3]BASTAB - 1
  If nolign < [M:ROU3]BASTAB - 1
    [M:ROU3]NEXOPENUM(nolign) = [M:ROU3]OPENUM(nolign+1)
    [M:ROU3]MFGMST   (nolign) = 1
  Else
    [M:ROU3]MFGMST   (nolign) = 2
  Endif
Next nolign
Return
############################################################
$ECR_ROUSCD
For nolign = 1 To [M:ROU3]BASTAB
  Raz [F:ROS]
  [F:ROS]       = [M:ROU3]
  If dim([F:ROS]FCY) > 0         : # GA 12/2007 FQ 45009 site ajouté en V6 - clé primaire
     [F:ROS]FCY = S_FCY
  Endif
  [F:ROS]ITMREF = S_CURITM
  [F:ROS]ROUALT = [F:CSC]ROUALT
  [F:ROS]EXPNUM = [C]EXPORT
  [F:ROS]CREDAT = date$
  [F:ROS]CREUSR = GUSER
  GPOINT = "BEFWRIROS" : Gosub ENTREE From EXEFNC
  Write [ROS]
  If fstat
    GOK = 0
    Call FSTACTX("ROS",W_TRASTP,"$ECR_ROUSCD") From CFGLIBD  # From GLOCK
    Break
  Endif
Next nolign
Return
############################################################
$UPD_ROUSCD
For nolign = 1 To [M:ROU3]BASTAB
  Read [F:ROS]ROS0=S_FCY;S_CURITM;[F:CSC]ROUALT;[M:ROU3]OPENUM(nolign-1)
  [F:ROS]NEXOPENUM = [M:ROU3]NEXOPENUM(nolign-1)
  [F:ROS]UPDDAT = date$
  [F:ROS]UPDUSR = GUSER
  Rewrite [ROS]
  If fstat
    GOK = 0
    Call FSTACTX("ROS",W_TRASTP,"$ECR_ROUSCD") From CFGLIBD  # From GLOCK
    Break
  Endif
Next nolign
Return

############################################################
# Relecture articles crees pour mise a jour des textes
$UPD_TEXTES
# Issue 107085 GA 03/2015 no update when creating a sale order
If dim(GVENCFG) > 0 & GVENCFG>0 & dim(WNO_UPD_SALCFG)>0 & WNO_UPD_SALCFG>0 Return Endif

# JPJ Trbegin/Commit $Upd_Textes ->
Call DEBTRANS From GLOCK

$UPD_TEXTES_DEB
Trbegin [ITM]
# JPJ Trbegin/Commit $Upd_Textes  <-

For W_I = 0 To dim(S_ITMSEL)-1
  If S_ITMSEL(W_I) = ""
    Break
  Else
    Readlock [ITM]ITM0=S_ITMSEL(W_I)
    Case fstat
     When 0
      #If [F:ITM]CFGVCRNUM = S_CPTCFG
        Gosub MAJ_TEXTES : If GOK<>1 : Break : Endif
      #Endif
 When 1
        GLOCK="$ITMMASTER"-S_ITMSEL(W_I) : GOK=-1 : Break
 When Default
        Call RSTACTX("ITM",S_ITMSEL(W_I),W_TRASTP,"$TITI") From CFGLIBD
        GOK=0 : Break
Endcase
  Endif
Next W_I
If GOK<> 1 : Goto $UPD_TEXTES_END : Endif
For W_I = 0 To dim(S_CMPSEL)-1
  If S_CMPSEL(W_I) = ""
    Break
  Else
    If W_I = 0 | (W_I > 0 & !find(S_CMPSEL(W_I),S_CMPSEL(0..W_I-1)))
      Readlock [ITM]ITM0=S_CMPSEL(W_I)
      Case fstat
       When 0
        #If [F:ITM]CFGVCRNUM = S_CPTCFG
          Gosub MAJ_TEXTES : If GOK<>1 : Break : Endif
        #Endif
       When 1
          GLOCK="$ITMMASTER"-S_CMPSEL(W_I) : GOK=-1 : Break
   When Default
          Call RSTACTX("ITM",S_CMPSEL(W_I),W_TRASTP,"$TITI") From CFGLIBD
          GOK=0 : Break
   Endcase
    Endif
  Endif
Next W_I

$UPD_TEXTES_END
# JPJ Trbegin/Commit $Upd_Textes
Case GOK
When 1
    Commit
When -1
    Rollback
    W_TRAMSG=mess(179,188,1)-GLOCK : Gosub TRA_MSG From CFGLIBB        # suivi
    Call ROLL From GLOCK     # JPJ E-Gestion Lock
    If !GROLL
        GOK=1 : #### Goto UPD_TEXTES_DEB  #### risque de boucler !!!!
    Else
        GMESSAGE=W_TRAMSG                     # info trace sur lock
        Gosub TRA_ERR From CFGLIBB
        GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
        GMESSAGE+="\"+mess(236,188,1) : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentaive par utilisateur
    Endif
#    Rollback
#    If mod(GNBROL+1,GROLLBACK)=0         # suivi message de GLOCK
#        GMESSAGE=mess(20,100,1)-GLOCK : Gosub TRA_ERR From CFGLIBB
#    Else    # Essai système: message car pas d'intervention utilisateur
#        W_TRAMSG=mess(20,100,1)-GLOCK : Gosub TRA_MSG From CFGLIBB
#    Endif
#    Call ROLL From GLOCK
#    If !GROLL
#      GOK=1 : Goto $UPD_TEXTES_DEB
#    Endif
When Default
    Rollback
Endcase
Return
############################################################
$MAJ_TEXTES
Gosub CTL_PARAM_CSC From CFGLIBC1
W_TRAMSG=mess(193,188,1)-[F:ITM]ITMREF-"($MAJ_TEXTES)" : Gosub TRA_MSG From CFGLIBB     # suivi
# Readlock fait dans UPD_TEXTES
If [F:ITM]CFGVCRNUM = S_CPTCFG
  Call TRT_TYPAXT("ITMMASTER") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
  Call CRE_TYPTEX("ITMMASTER") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
  Rewrite [ITM]
  If fstat
    GOK = 0
    Call FSTACTX("ITM",W_TRASTP,"$MAJ_TEXTES") From CFGLIBD
    Goto MAJ_TEXTES_FIN
  Endif
Endif
#
Readlock [ITS]ITS0=[F:ITM]ITMREF# si existe
Case fstat
 When 0
  If [F:ITS]CFGVCRNUM = S_CPTCFG
    Call TRT_TYPAXT("ITMSALES") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
    Call CRE_TYPTEX("ITMSALES") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
    Rewrite [ITS]
    If fstat
      GOK = 0
      Call FSTACTX("ITS",W_TRASTP,"$MAJ_TEXTES") From CFGLIBD
      Goto MAJ_TEXTES_FIN
    Endif
  Endif
 When 1
   GLOCK="$ITMSALES"-[F:ITM]ITMREF : GOK=-1
   Goto MAJ_TEXTES_FIN
Endcase
#
# Issue 89191 GA 04/2013
#Readlock [ITU]ITU0=[F:ITM]ITMREF;S_BPRNUM# si existe
#  Case fstat
#   When 0
#     If [F:ITU]CFGVCRNUM = S_CPTCFG
#      Call TRT_TYPAXT("ITMBPC") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
#      Call CRE_TYPTEX("ITMBPC") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
#      Rewrite [ITU]
#      If fstat
#        GOK = 0
#        Call FSTACTX("ITU",W_TRASTP,"$MAJ_TEXTES") From CFGLIBD  # From GLOCK
#        Goto MAJ_TEXTES_FIN
#      Endif
#   When 1
#     GLOCK="$ITMBPC"-[F:ITM]ITMREF-S_BPRNUM : GOK=-1
#     Goto MAJ_TEXTES_FIN
#  Endcase
Filter [F:ITU] Where ITMREF=[F:ITM]ITMREF & CFGVCRNUM = S_CPTCFG
For [F:ITU] With Lock
    Call TRT_TYPAXT("ITMBPC") : If GOK<> 1 : Break : Endif
    Call CRE_TYPTEX("ITMBPC") : If GOK<> 1 : Break : Endif
    Rewrite [ITU]
    If fstat
      GOK = 0
      Call FSTACTX("ITU",W_TRASTP,"$MAJ_TEXTES") From CFGLIBD  # From GLOCK
      Break
    Endif
Next
Filter [F:ITU]
If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
#
# Issue 89191 GA 04/2013
#Readlock [ITP]ITP0=[F:ITM]ITMREF;W_BPS# si existe
#Case fstat
# When 0
#  If [F:ITP]CFGVCRNUM = S_CPTCFG
#    Call TRT_TYPAXT("ITMBPS") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
#    Call CRE_TYPTEX("ITMBPS") : If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
#    Rewrite [ITP]
#    If fstat
#      GOK = 0
#      Call FSTACTX("ITP",W_TRASTP,"$MAJ_TEXTES") From CFGLIBD  # From GLOCK
#      Goto MAJ_TEXTES_FIN
#    Endif
#  Endif
# When 1
#   GLOCK="$ITMBPS"-[F:ITM]ITMREF-W_BPS : GOK=-1
#   Goto MAJ_TEXTES_FIN
#Endcase
Filter [F:ITP] Where ITMREF=[F:ITM]ITMREF & CFGVCRNUM = S_CPTCFG
For [F:ITP] With Lock
    Call TRT_TYPAXT("ITMBPS") : If GOK<> 1 : Break : Endif
    Call CRE_TYPTEX("ITMBPS") : If GOK<> 1 : Break : Endif
    Rewrite [ITP]
    If fstat
      GOK = 0
      Call FSTACTX("ITP",W_TRASTP,"$MAJ_TEXTES") From CFGLIBD  # From GLOCK
      Break
    Endif
Next
Filter [F:ITP]
If GOK<> 1 : Goto MAJ_TEXTES_FIN : Endif
