#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ADC",GBIDC1,GBIDC2) From GOBJET
End

#---------------------------------------------------#
# Rajout des traitements adx inexistant dans ADC
#---------------------------------------------------#

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
Local Mask ADCX [DIA]
Local Integer I , OK
Local Decimal TAILLE , PROPRIO
Local Date    DATMOD
Local Char    HREMOD(10) , IDUSR(50) , ORDRE(250)
Gosub CHARGE_USR From SUBADC
ORDRE = adxmac(0)+'@lsadx -a '+nomap-' TRT adx'
Local File (TRT(GLONADC)) From System ORDRE As [TRT_]
Raz [M:DIA]
For [TRT_]
 OK = ([TRT_]TRT<"W")
 OK *= (left$([TRT_]TRT,3)<>"SPE" & left$([TRT_]TRT,3)<>"SPV")
 OK *= (!find(right$([TRT_]TRT,len([TRT_]TRT)-2),"STD","SPE","SPV") or !find(left$([TRT_]TRT,4),"CNSX","CNSY","CNSZ"))
 OK *= (left$([TRT_]TRT,3)<>"CNS" or right$([TRT_]TRT,len([TRT_]TRT)-2)<>"SPE")
 OK *= (left$([TRT_]TRT,3)<>"CNS" or right$([TRT_]TRT,len([TRT_]TRT)-2)<>"SPV")
 #OK += (GPRODUIT=-1 & [TRT_]TRT<>"" & left$([TRT_]TRT,1)<>"W")
 If OK
  Read [ADC]ADC0 = [TRT_]TRT
  If fstat
   [M]NBLIG += 1
   [M]CODTRT([M]NBLIG-1) = [TRT_]TRT
   Call INFOADX([TRT_]TRT,PROPRIO,TAILLE,DATMOD,HREMOD,OK) From SUBADC
   Gosub USER From SUBADC
   [M]USR([M]NBLIG-1)    = IDUSR
   Call INFO_ADX("","",[TRT_]TRT,20,[M]DES([M]NBLIG-1)) From ORDSYS
   Case GPRODUIT
    When -1 : [M]MODULE([M]NBLIG-1) = 1 : # Superviseur
    When 0  : [M]MODULE([M]NBLIG-1) = 9 : # Tronc commun
    When 1  : [M]MODULE([M]NBLIG-1) = 2 : # Géode GX
    When 2  : [M]MODULE([M]NBLIG-1) = 2 : # Paie
    When 3  : [M]MODULE([M]NBLIG-1) = 5 : # Immobilisations
   Endcase
   If [M]NBLIG>=dim([M]CODTRT) : Break : Endif
  Endif
 Endif
Next TRT_
Affzo
Return

$EXEC
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [ADC]
 For nolign=1 To [M]NBLIG
  Read [ADC]ADC0 = [M]CODTRT(nolign-1)
  If fstat
   Call MAJDICTRT([M]CODTRT(nolign-1),"",[M]DES(nolign-1),[M]MODULE(nolign-1),[M]CODACT(nolign-1)) From SUBADC
   If GOK<>1 : Break : Endif 
  Endif
 Next nolign
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return
