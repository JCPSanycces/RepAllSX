#<AdxTL>@(#)0.0.0.0 $Revision$

#Handling all events for EMPLOJNTESS_CSTD
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                      : Gosub AINIT
      When "AINSERT_CONTROL_AFTER"      : Gosub AINSERT_CONTROL_AFTER
    Endcase
Endcase
Return


$AINIT
this.REFNUM = fmet this.ACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
Gosub SET_LIGNUM

Return

$AINSERT_CONTROL_AFTER
#Set the line number
Gosub SET_LIGNUM
Return

$SET_LIGNUM
If this.NUMLIG <> 0 : Return: Endif
Local Integer MAXLIGNUM, I
For I = 1 To maxtab(this.APARENT.EMPLOJNTESS)
  If this.APARENT.EMPLOJNTESS(I).NUMLIG > MAXLIGNUM
    MAXLIGNUM = this.APARENT.EMPLOJNTESS(I).NUMLIG
  Endif
Next

MAXLIGNUM+=1
this.NUMLIG = MAXLIGNUM
Return


$AINSERT_AUPDATE_AFTER

#Write the data for all the EMPESSXXX classes to workflow
#Using activity codes - Check all classes and pass to workflow function in ESS_WRKFLOW_FUNC
#Manage call with activity codes
#---------------------All legislations------------------------------------------------------------#
Gosub PASS_CLASSES_WORKFLOW_EMPLOJNTESS

Return


$PASS_CLASSES_WORKFLOW_EMPLOJNTESS
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..

#Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
ALPKEY(0) = this.REFNUM

#Specify function variables
MAIN_CLASSCOD = "EMPLOJNT"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPLOJNTESS" #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPLOCHDESS
#If this.EMPLOIDESS <> null
  #Getting paramater values
  #CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  CTABLE  = "EMPLOJNT"
  CABR    = "JNT"

  If this.EMPLOJNTESS <> null
    For COLLECTION_IND = 1 To maxtab(this.EMPLOJNTESS)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPLOJNTESS(COLLECTION_IND) <> null
        #Specify the keys needed for workflow (ALPKEY,INTKEY,DATKEY)
        INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
        If this.EMPLOJNTESS(COLLECTION_IND).TCH_JNTSTA = "T"
          If this.EMPLOJNTESS(COLLECTION_IND).ASTALIN = [V]CST_ADEL
            WRK = "D"
          Else
            WRK = "M"
          Endif
        Endif

        #New lines created by the user
        If this.EMPLOJNTESS(COLLECTION_IND).TCH_JNTSTA <> "T"
          If this.EMPLOJNTESS(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPLOJNTESS(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif
        If WRK <> ""
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKJNT(WRK,this,THISUSR,this.EMPLOJNTESS(COLLECTION_IND),this.EMPLOJNTESS(COLLECTION_IND),
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
#Endif
Return

$EMPLOJNTESS_ADDLINE_BEFORE
ASTATUS=fmet this.ASETERROR("","HERE",[V]CST_AINFO)
this.REFNUM = this.APARENT.REFNUM
this.NUMLIG = 1 + max(this.APARENT.EMPLOJNTESS(1..maxtab(this.APARENT.EMPLOJNTESS)).NUMLIG)
Return

