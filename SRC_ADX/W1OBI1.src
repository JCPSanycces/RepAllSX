#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque OBI1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:32"
A_USER  = "DOC"
A_STAMP = "20181109230532"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
   If [M:OBI1]CPYFMT<>""
    Chgfmt CPY With [M:OBI1]CPYFMT
   Else
    Chgfmt CPY With "-K:1X"
   Endif
   If [M:OBI1]FCYFMT<>""
    Chgfmt FCY With [M:OBI1]FCYFMT
   Else
    Chgfmt FCY With "-K:1X"
   Endif
   If [M:OBI1]SRVFMT<>""
    Chgfmt SRV With [M:OBI1]SRVFMT
   Else
    Chgfmt SRV With "-K:1X"
   Endif
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask OBI1 [OBI1]
Gosub HORODAT
Local Inpbox "OBI1" From GFONCTION At A_STAMP With A_WINDPREV Mask [OBI1] As [SIM_]
Grizo [OBI1]10
Grizo [OBI1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [OBI1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=112 : Y1(1)=3 : Y2(1)=28
Return

$ON_LVL
Onevent AFTER_CHANGE Gosub AMM_LVL From W1OBI1
Onevent INIT_AREA Call D_LVL(zc) From W1OBI1
Onevent BEFORE_INPUT Call AS_LVL(zc) From W1OBI1
Onevent CONTROL Call C_LVL(zc) From W1OBI1
Return

Subprog D_LVL(VALEUR)
Variable Integer VALEUR
If varinit([M]LVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LVL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_LVL(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LVL" : GZNUM = 5230 : Endif
Gosub _AFF
End

$AMM_LVL
Call AM_LVL(zc)
If !mkstat & GOBJET
 zoncou = "LVL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LVL(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_LVL(VALEUR) From SUBOBI
If mkstat : GERR = 1 : GZONE = "LVL" : GZNUM = 5230 : Endif
Gosub _AFF
End

$ON_CPY
Onevent CONTROL Call C_CPY(zc) From W1OBI1
Onevent BEFORE_INPUT Call AS_CPY(zc) From W1OBI1
Onevent BEFORE_AREA Gosub AV_CPY From W1OBI1
Return

$AV_CPY
If [M:OBI1]CPYFMT<>""
 Chgfmt [M]CPY(indice) With [M:OBI1]CPYFMT
Else
 Chgfmt [M]CPY(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3529,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CPY(zc) From W1OBI1
Onkey   2 Titled GBOUTS Call S_CPY(zc) From W1OBI1
Onkey 144 Titled GBOUTP Call P_CPY(zc) From W1OBI1
Onkey 146 Titled GBOUTA Call SA_CPY(zc) From W1OBI1
Gosub _AFF
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
If !mkstat
 ## Action ACONTCPY
 Call CONTSOC(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("CPY","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CPY"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CPY(VALEUR)
Variable Char    VALEUR()
Call OBJET("CPY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_FCY
Onevent CONTROL Call C_FCY(zc) From W1OBI1
Onevent BEFORE_INPUT Call AS_FCY(zc) From W1OBI1
Onevent BEFORE_AREA Gosub AV_FCY From W1OBI1
Return

$AV_FCY
If [M:OBI1]FCYFMT<>""
 Chgfmt [M]FCY(indice) With [M:OBI1]FCYFMT
Else
 Chgfmt [M]FCY(indice) With "-K:1X"
Endif
Gosub _AFF
