$ON_SRV
Onevent BEFORE_INPUT Call AS_SRV(zc) From W1OBI1
Onevent CONTROL Call C_SRV(zc) From W1OBI1
Onevent BEFORE_AREA Gosub AV_SRV From W1OBI1
Return

$AV_SRV
If [M:OBI1]SRVFMT<>""
 Chgfmt [M]SRV(indice) With [M:OBI1]SRVFMT
Else
 Chgfmt [M]SRV(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_SRV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(17693,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SRV(zc) From W1OBI1
Onkey   2 Titled GBOUTS Call S_SRV(zc) From W1OBI1
Onkey 144 Titled GBOUTP Call P_SRV(zc) From W1OBI1
Onkey 146 Titled GBOUTA Call SA_SRV(zc) From W1OBI1
Gosub _AFF
End

Subprog C_SRV(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("SRV","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
Endif
Gosub _AFF
End

Subprog S_SRV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSRV
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSRV"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELSRV","SUBSRV","SPESRV") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SRV(VALEUR)
Variable Char    VALEUR()
Call OBJET("SRV",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_SRV(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "SRV"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SRV(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("SRV",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_LIEN
Onevent BEFORE_AREA Gosub AV_LIEN From W1OBI1
Return

$AV_LIEN
## Action STD
Call AV_LIEN(zc) From SUBOBI
Gosub _AFF
Return

$ON_CRI
Onevent INIT_AREA Call D_CRI(zc) From W1OBI1
Onevent CONTROL Call C_CRI(zc) From W1OBI1
Onevent BEFORE_INPUT Call AS_CRI(zc) From W1OBI1
Onevent AFTER_CHANGE Gosub AMM_CRI From W1OBI1
Return

Subprog D_CRI(VALEUR)
Variable Char    VALEUR()
If varinit([M]CRI,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10582","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_CRI(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10582") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CRI(zc) From W1OBI1
Onkey   2 Titled GBOUTS Call S_CRI(zc) From W1OBI1
Onkey 144 Titled GBOUTP Call P_CRI(zc) From W1OBI1
Onkey 146 Titled GBOUTA Call SA_CRI(zc) From W1OBI1
If VALEUR="" : Call INIADI(VALEUR,"10582") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_CRI(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"10582","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"10582",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
  If !mkstat
   ## Action STD
   Call C_CRI(VALEUR) From SUBOBI
   If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 2680 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CRI
Call AM_CRI(zc)
If !mkstat & GOBJET
 zoncou = "CRI" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CRI(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCRI)")>indice
 [M]CRI(indice) = VALEUR
 Affzo ZCRI(indice)
Endif
Gosub _AFF
End

Subprog S_CRI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10582"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CRI(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10582") From GOBJET
Gosub _AFF
End

Subprog SA_CRI(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10582"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CRI(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10582"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCRI
Onevent BEFORE_AREA Gosub AV_ZCRI From W1OBI1
Return

$AV_ZCRI
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10582",num$([M]CRI(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_OBJ
Onevent CONTROL Call C_OBJ(zc) From W1OBI1
Return

Subprog C_OBJ(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$ON_SNS
Onevent INIT_AREA Call D_SNS(zc) From W1OBI1
Onevent BEFORE_INPUT Call AS_SNS(zc) From W1OBI1
Return

Subprog D_SNS(VALEUR)
Variable Integer VALEUR
If varinit([M]SNS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SNS(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


