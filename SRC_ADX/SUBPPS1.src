#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# SUBPPS1 : Affichage de la situation de DA des AOF         HN  20/10/02 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p           #
# d'affichage "SITUATION_DA" et ne sert qu'à gérer le masque et l'action #
# écran "PPSDPQH [PPS1]".                                                #
##########################################################################
$ACTION
#######################################################################
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# ------------------------------------------------------------------- #
# VISUPSHPQH : Fenêtre visu des DA d'un AOF                           #
#######################################################################
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "VISUPSDPQD"  : Gosub OUV_VISUPSDPQD  
  Endcase       
 When "TITRE"
  #---------------------#
  # Titre de la fenêtre #
  #---------------------#
  Case GACTION
   When "VISUPSDPQD" : TIT=mess(206,195,1)
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "VISUPSDPQD" : Gosub DEB_VISUPSDPQD 
  Endcase
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
 When "FINSAI"
  Case GACTION
   When "VISUPSDPQD" : Gosub FINSAI_VISUPSDPQD
  Endcase
Endcase
Return

##########################################################################
# Action sur champ                                                       #
##########################################################################

Subprog IB_NBLIG
#-------------------------------------#
# Avant zone : Activation bouton "DA" #
#-------------------------------------#
Raz GBOUT1
If nolign>[M:PPS1]NBLIG & [M:PPS1]NBLIG>0
  nolign=[M:PPS1]NBLIG
Endif
If [M:PPS1]PSHNUM(nolign-1)<>"" & GFONC1<>"GESPSH"
  GBOUT1=mess(61,198,1)-[M:PPS1]PSHNUM(nolign-1)
Endif
End

#############################################################################
# SITUATION_LIG_DA  : S/P d'affichage des DA d'un ligne cde     HN 31/03/00 #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUPSDPQD
#----- Variables locales -----#
Local Shortint NOL        : NOL=(nolign-1)
Local Shortint SAVGNOLIGN, I
SAVNOLIGN=nolign
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUPSDPQD
Raz [M:PPS1]
Call TEMPON("O") From GESECRAN
#----- Chargement des zones dans le masque -----#
[M:PPS1]PQHNUM=[M:PQH1]PQHNUM
[M:PPS1]PQDLIN=[M:PQH1]PQDLIN(NOL)
[M:PPS1]ITMREF=[M:PQH1]ITMREF(NOL)
[M:PPS1]ITMDES=[M:PQH1]ITMDES(NOL)
[M:PPS1]QTYPUU=[M:PQH1]QTYPUU(NOL)
[M:PPS1]PUU   =[M:PQH1]PUU(NOL)
#----- Chargement des DA de la ligne de AOF -----#
Raz I
For [PWO] PWO0 Where PRONUM=adxuid(2)
&                  & CODFNC="PQH"
&                  & LINNUM=[M:PQH1]PQHLIN(NOL)
&                  & QTYSTU<>0
  [M:PPS1]PSHNUM(I) =[F:PWO]WIPNUM
  [M:PPS1]PSDLIN(I) =[F:PWO]PSDLIN
  [M:PPS1]WQTYPUU(I)=[F:PWO]QTYPUU
  [M:PPS1]WPUU(I)   =[F:PWO]PUU
  [M:PPS1]WQTYSTU(I)=[F:PWO]QTYSTU
  [M:PPS1]WSTU(I)   =[F:PWO]STU
  I+=1 : [M:PPS1]NBLIG=I
  If I>dim([M:PPS1]PSHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif

Next
#----- Affichage foreground -----# 
Affzo [PPS1]1-99
Call TEMPOFF From GESECRAN
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUPSDPQD
nolign=SAVNOLIGN
Return

