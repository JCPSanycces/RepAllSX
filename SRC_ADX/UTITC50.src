#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################################################
# UTITC50                                                  Module Tronc commun                         #
# Suppression des paramètres obsolètes                                                                 #
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
Local Char PARNAM(30)
Local File ADOSSIER  [ADS]

Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITC50: parameter deletion") From LECFIC

 Call MAJ_UTITC50(APPLI)

 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End
#####################################################################################################
Subprog MAJ_UTITC50(APPLI)
Value Char APPLI
Local Integer STAT, N

Call ECR_TRACE("UTITC50: Process Start on: "+APPLI,0) From GESECRAN

Local File =APPLI+".ADOPAR"    [ADP]
Local File =APPLI+".ADOVAL"    [ADW]
Local File =APPLI+".AGLOBVAR"  [AGB]

If GVERSION<"1.8.0"
  Call DEL_ADP_AGP(APPLI,"MTOTRSNUM")
Endif

Call ECR_TRACE("UTITC50: Process End on: "+APPLI,0) From GESECRAN
End

#####################################################################################################
Subprog DEL_ADP_AGP(APPLI,PARNAM)  # Suppression d'un paramètre PARNAM et de sa variable globale
Value Char APPLI
Value Char PARNAM
#####################################################################################################
Local Integer STAT, N

Call ECR_TRACE("UTITC50: Process Start on: "+APPLI,0) From GESECRAN
Trbegin [ADP]
 Filter [AGB] Where CODVAR="G"+[L]PARNAM
 For [AGB]
   Delete [AGB] Curr
   Call ECR_TRACE(mess(499,196,1)-"AGLOBVAR : "+[F:AGB]CODVAR,0) From GESECRAN
 Next
 Filter [ADP] Where PARAM=[L]PARNAM
 For [ADP]
  Delete [ADP] Curr
  If fstat
   # Erreur d'effacement
   GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOPAR : "+[L]PARNAM,-1) From GESECRAN : Goto AB_UTITC50
  Else
   # Suppression enregistrements
   Call ECR_TRACE(mess(499,196,1)-"ADOPAR : "+[F:ADP]CHAPITRE-[F:ADP]PARAM,0) From GESECRAN
   For [ADW] Where PARAM=[L]PARNAM
    Readlock [ADW] Curr
    If fstat
     # Erreur d'effacement
     GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOVAL : "+[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM,-1) From GESECRAN : Goto AB_UTITC50
    Else
     Delete [ADW] Curr
     # Suppression
     Call ECR_TRACE(mess(53,123,1)-[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM, 0) From GESECRAN
    Endif
   Next
  Endif
 Next
 Filter [ADP]
 Commit
End

$AB_UTITC50
Rollback
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITC50(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITC50(APPLI)
End
