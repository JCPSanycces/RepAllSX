#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# ACTION - Mask management PTELABPOS
# Issue X3-66497 - 2018-06-04 by SINGC
###################################################################################################
$ACTION
  Case ACTION
    When "INIT_DIA"          : Gosub INIT_DIA
  Endcase
Return

###################################################################################################
# ACTION
###################################################################################################
$INIT_DIA
  Gosub DECLARE_FILES
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
  Call LOAD_SCREEN_DEFAULT()
  Call LECMEMO("STD","[M:DIA]","exp") From GMEMO
Return

###################################################################################################
$DECLARE_FILES
  Local File PJMAUS     [PAUS]
  Local File PJMTIMEMPH [PTEH]
  Local File PJMTIMEMP  [PTE]
  Local File COMPANY    [CPY]
  Local File FACILITY   [FCY]
  Local File GRPCUR     [GCU]
  Local File GACCENTRY  [HAE]
  Local File GACCENTRYD [DAE]
  Local File GACCENTRYA [DAA]
  Local File GACCDUDATE [DUD]
  Local File GJOURNAL   [JOU]
  Local File GTYPACCENT [GTE]
  Local File GACCOUNT   [GAC]
  Local File GCOA       [COA]
Return

###################################################################################################
# Screens fields
###################################################################################################
# PTELABPOS
###################################################################################################
Subprog AV_INI(VALEUR)
Variable Decimal VALEUR

  Call INI_SCREEN()
End

###################################################################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Grizo [M:DIA]CPY
    [M:DIA]ALLFCY = [V]CST_AYES
    Affzo [M:DIA]ALLFCY
    Grizo [M:DIA]ALLFCY
    Actzo [M:DIA]LEG
    GSOCIETE = AVOID.ACHAR
    GCURLEG = AVOID.ACHAR
    GCURFCY = AVOID.ACHAR
  Else
    Actzo [M:DIA]CPY
    Grizo [M:DIA]LEG
    Actzo [M:DIA]ALLFCY
  Endif
  #--------------------------------
  Effzo [M:DIA]CPY
  Effzo [M:DIA]LEG
  Effzo [M:DIA]FCY
  Grizo [M:DIA]FCY
  Effzo [M:DIA]TYPPCE
  Effzo [M:DIA]JOU
End

###################################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

Local Integer NI

  GSOCIETE = VALEUR
  GCURLEG = [F:CPY]LEG
  [M:DIA]LEG = [F:CPY]LEG
  Affzo [M:DIA]LEG
  Effzo [M:DIA]FCY
  Raz GCURFCY
  GCURFCY = fmet GACTX.ACACHE.ACPY.AGETVALCHAR(VALEUR, "MAIFCY")
  If [M:DIA]ALLFCY = [V]CST_ANO Then
    [M:DIA]FCY = GCURFCY
    Affzo [M:DIA]FCY
  Endif
  #--------------------------------
  Effzo [M:DIA]TYPPCE
  Effzo [M:DIA]JOU
End

###################################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

  GCURLEG = VALEUR
End

###################################################################################################
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Effzo [M:DIA]FCY
    Grizo [M:DIA]FCY
  Else
    Actzo [M:DIA]FCY
    [M:DIA]FCY = GCURFCY
    Affzo [M:DIA]FCY
  Endif
  #--------------------------------
  Effzo [M:DIA]TYPPCE
  Effzo [M:DIA]JOU
End

###################################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  GCURFCY = VALEUR
  Effzo [M:DIA]TYPPCE
  Effzo [M:DIA]JOU
End

###################################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  If GUSRFCY(1) <> "\" and !find(VALEUR,GUSRFCY(1..GNBAUZ)) Then
    GMESSAGE = VALEUR - ":" - mess(2,104,1)
    mkstat = 2
    End
  Endif
  #--------------------------------
  If [F:FCY]LEGCPY <> [M:DIA]CPY Then
    GMESSAGE = func AFNC.MES2(mess(1069,2260,1), VALEUR, [M:DIA]CPY)
    mkstat = 2
    End
  Endif
End

###################################################################################################
Subprog AM_ALLCLB(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Effzo [M:DIA]CLBSTR
    Effzo [M:DIA]CLBEND
    Grizo [M:DIA]CLBSTR
    Grizo [M:DIA]CLBEND
  Else
    Actzo [M:DIA]CLBSTR
    Actzo [M:DIA]CLBEND
  Endif
End

###################################################################################################
Subprog AM_CLBSTR(VALEUR)
Variable Char    VALEUR()

  If [M:DIA]CLBEND = AVOID.ACHAR or [M:DIA]CLBEND < VALEUR Then
    [M:DIA]CLBEND = VALEUR
    Affzo [M:DIA]CLBEND
  Endif
End

###################################################################################################
Subprog C_CLBEND(VALEUR)
Variable Char    VALEUR()

  If VALEUR < [M:DIA]CLBSTR Then
    GMESSAGE = func AFNC.MES1(mess(44,199,1), VALEUR)
    mkstat = 2
    End
  Endif
End

###################################################################################################
Subprog AM_ALLCUR(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES Then
    Effzo [M:DIA]GRPCUR
    Effzo [M:DIA]CUR
    Grizo [M:DIA]GRPCUR
    Grizo [M:DIA]CUR
  Else
    Actzo [M:DIA]GRPCUR
    If [M:DIA]GRPCUR <> AVOID.ACHAR Then
      Effzo [M:DIA]GRPCUR
      Grizo [M:DIA]CUR
    Else
      Actzo [M:DIA]CUR
    Endif
  Endif
End

###################################################################################################
Subprog AM_GRPCUR(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> AVOID.ACHAR Then
    Effzo [M:DIA]CUR
    Grizo [M:DIA]CUR
  Else
    Actzo [M:DIA]CUR
  Endif
End

###################################################################################################
Subprog AM_DATSTR(VALEUR)
Variable Date    VALEUR

  If [M:DIA]DATEND = AVOID.ADATE or [M:DIA]DATEND < VALEUR Then
    [M:DIA]DATEND = VALEUR
    Affzo [M:DIA]DATEND
  Endif
End

###################################################################################################
Subprog C_DATEND(VALEUR)
Variable Date    VALEUR

  If VALEUR < [M:DIA]DATSTR Then
    GMESSAGE = func AFNC.MES1(mess(30,2260,1), format$(GFMDAT,VALEUR))
    mkstat= 2
    End
  Endif
End

###################################################################################################
Subprog AM_GENECR(VALEUR)
Variable Integer VALEUR

  If VALEUR <> [V]CST_AYES Then
   Grizo [M:DIA]CAT
   Grizo [M:DIA]STA
   Grizo [M:DIA]TYPPCE
   Grizo [M:DIA]JOU
   Grizo [M:DIA]ACCDAT
   [M:DIA]LOGFILE = [V]CST_AYES
   Affzo [M:DIA]LOGFILE
   Grizo [M:DIA]LOGFILE
  Else
    Actzo [M:DIA]CAT
    Actzo [M:DIA]STA
    Actzo [M:DIA]TYPPCE
    Actzo [M:DIA]JOU
    Actzo [M:DIA]ACCDAT
    Actzo [M:DIA]LOGFILE
  Endif
End

###################################################################################################
Subprog AM_CAT(VALEUR)
Variable Integer VALEUR

  If VALEUR <> 1 Then
    Grizo [M:DIA]STA
  Else
    Actzo [M:DIA]STA
  Endif
End

###################################################################################################
Subprog AM_STA(VALEUR)
Variable Integer VALEUR

  If [M:DIA]CPY <> AVOID.ACHAR Then
    If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [M:DIA]CPY, "FRADGI") = [V]CST_AYES Then
      VALEUR = 2
      mkstat = 2
      End
    Endif
  Endif
End

###################################################################################################
Subprog AM_TYPPCE(VALEUR)
Variable Char    VALEUR()

  If VALEUR = AVOID.ACHAR Then
    If [M:DIA]FCY <> AVOID.ACHAR Then
      VALEUR = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, [M:DIA]FCY, "TYPACC")
    Elsif [M:DIA]CPY <> AVOID.ACHAR Then
      VALEUR = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY, [M:DIA]CPY, "TYPACC")
    Elsif [M:DIA]LEG <> AVOID.ACHAR Then
      VALEUR = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVLEG, GCURLEG, "TYPACC")
    Endif
    # -----------------------------
    [M:DIA]TYPPCE = VALEUR
    Affzo [M:DIA]TYPPCE
  Endif
  # -----------------------------
  If VALEUR <> AVOID.ACHAR Then
    Read [GTE]GTE0=VALEUR;[M:DIA]LEG
    If fstat Then
      Read [GTE]GTE0=VALEUR;""
    Endif
    # -----------------------------
    Call CONTEXE([F:GTE]ACS) From CPTSUB
    If mkstat Then
      End
    Endif
    # -----------------------------
    If ([M:DIA]CAT = 2 or [M:DIA]CAT = 3) and [F:GTE]VCRSIM <> [V]CST_AYES Then
      GMESSAGE = mess(32,107,1)
      mkstat = 2
      End
    Elsif [F:GTE]COU = AVOID.ACHAR Then
      GMESSAGE = mess(31,107,1)
      mkstat = 2
      End
    Endif
    # -----------------------------
    [M:DIA]JOU = [F:GTE]DEFJOU
    Affzo [M:DIA]JOU
  Endif
End

###################################################################################################
Subprog AM_JOU(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> AVOID.ACHAR Then
    Read [JOU]JOU0=VALEUR;[M:DIA]LEG
    If fstat Then
      Read [JOU]JOU0 = VALEUR;""
    Endif
    # -----------------------------
    Call CONTEXE([F:JOU]ACS) From CPTSUB
    If mkstat Then
      End
    Endif
    # -----------------------------
    If [M:DIA]CPY <> AVOID.ACHAR and [F:JOU]FCY <> AVOID.ACHAR Then
      Call VERSOC([F:JOU]FCY,[M:DIA]CPY,[M:DIA]FCY,VALEUR) From CFYSUB
      If mkstat Then
        End
      Endif
    Endif
    # -----------------------------
    If [M:DIA]TYPPCE <> AVOID.ACHAR Then
      Read [GTE]GTE0=[M:DIA]TYPPCE;[M:DIA]LEG
      If fstat Then
        Read [GTE]GTE0=[M:DIA]TYPPCE;""
      Endif
      # -----------------------------
      If [F:GTE]AUZJOU([F:JOU]TYP-1) <> 2 Then
        GMESSAGE = mess(51,106,1)
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

###################################################################################################
# Subroutines
###################################################################################################
Subprog LOAD_SCREEN_DEFAULT()

  [M:DIA]ALLCPY = [V]CST_AYES
  # -----------------------------
  [M:DIA]ALLFCY = [V]CST_AYES
  # -----------------------------
  [M:DIA]ALLCLB = [V]CST_ANO
  [M:DIA]CLBSTR = GUSER
  [M:DIA]CLBEND = GUSER
  # -----------------------------
  [M:DIA]ALLCUR = [V]CST_AYES
  # -----------------------------
  [M:DIA]TIMCLB = [V]CST_ANO
  [M:DIA]GENECR = [V]CST_ANO
  [M:DIA]ACCDAT = date$
  [M:DIA]LOGFILE = [V]CST_AYES
  Affzo [M:DIA]1-99
End

###################################################################################################
Subprog INI_SCREEN()

  If GUSRFCY(1) <> "\" and GNBAUZ <> GNBSITE Then
    Diszo [M:DIA]ALLCPY
    Actzo [M:DIA]CPY
    Actzo [M:DIA]ALLFCY
    Effzo [M:DIA]LEG
    Diszo [M:DIA]LEG
  Endif
  # -----------------------------
  If [M:DIA]ALLCPY = [V]CST_AYES Then
    Effzo [M:DIA]CPY
    Effzo [M:DIA]FCY
    Grizo [M:DIA]CPY
    Grizo [M:DIA]FCY
    Grizo [M:DIA]ALLFCY
  Else
    Actzo [M:DIA]CPY
    Actzo [M:DIA]ALLFCY
    If [M:DIA]ALLCPY = [V]CST_AYES Then
      Effzo [M:DIA]FCY
      Grizo [M:DIA]FCY
    Else
      Actzo [M:DIA]FCY
    Endif
  Endif
  # -----------------------------
  If [M:DIA]ALLCLB = [V]CST_AYES Then
    Effzo [M:DIA]CLBSTR
    Grizo [M:DIA]CLBSTR
    Effzo [M:DIA]CLBEND
    Grizo [M:DIA]CLBEND
  Else
    Actzo [M:DIA]CLBSTR
    Actzo [M:DIA]CLBEND
  Endif
  # -----------------------------
  If [M:DIA]ALLCUR = [V]CST_AYES Then
    Effzo [M:DIA]GRPCUR
    Grizo [M:DIA]GRPCUR
    Effzo [M:DIA]CUR
    Grizo [M:DIA]CUR
  Else
    Actzo [M:DIA]GRPCUR
    If [M:DIA]GRPCUR <> AVOID.ACHAR Then
      Effzo [M:DIA]CUR
      Grizo [M:DIA]CUR
    Else
      Actzo [M:DIA]CUR
    Endif
  Endif
  # -----------------------------
  If [M:DIA]GENECR = [V]CST_ANO Then
    Grizo [M:DIA]CAT
    Grizo [M:DIA]STA
    Grizo [M:DIA]TYPPCE
    Grizo [M:DIA]JOU
  Else
    Actzo [M:DIA]CAT
    Actzo [M:DIA]STA
    Actzo [M:DIA]TYPPCE
    Actzo [M:DIA]JOU
  Endif
  # -----------------------------
  If [M:DIA]ACCDAT <> AVOID.ADATE Then
    Grizo [M:DIA]ACCDAT
  Else
    Actzo [M:DIA]ACCDAT
  Endif
  # -----------------------------
  If [M:DIA]GENECR <> [V]CST_AYES Then
    Grizo [M:DIA]LOGFILE
  Else
    Actzo [M:DIA]LOGFILE
  Endif
End

