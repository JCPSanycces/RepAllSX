#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des interlocuteurss                             Module CRM 2 avril 2010
##########################################################################################################
#
# UPDAIN    : Sous-programme de mise à jour d'un interlocuteur.
# FGR 02/04/2010 : X3SUIVI63506
##########################################################################################################
Subprog TEST
Local Char SZAINNUM
Local Integer LERRCOD

  GSYNCOUTLOOK = 1
  SZAINNUM = "000000000000014"
  Call UPDAIN("SUBAINCM", 2, 2, SZAINNUM, LERRCOD)
  GSYNCOUTLOOK = 0
End

##########################################################################################################
Subprog UPDAIN(SZUPDAINTRT, ITRACE, ILEC_TRACE, SZAINNUM, LERRCOD)
Value Char  SZUPDAINTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Value Char SZAINNUM
Variable Integer LERRCOD

Global Char GSZUPDAINTRT(GLONADC)
Global Integer GIUPDAINTRACE

Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG

  IBOPENTRACE = 0
  GSZUPDAINTRT = SZUPDAINTRT
  GIUPDAINTRACE = ITRACE
  If GSZUPDAINTRT = "" Then
    GSZUPDAINTRT = "SUBAINCM"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Modification d'interlocuteur démarré à partir du contexte :+ GSZUPDAINTRT
      Call OUVRE_TRACE (mess(642,177,1) - GSZUPDAINTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif
  If ITRACE Then
    #Modification d'interlocuteur +" : "+ SZAINNUM
    Call ECR_TRACE(mess(643,177,1) - ":" - SZAINNUM,0)From GESECRAN
  Endif

#--- variables
Local Integer OK, SAVGIMPORT
Local Char ACTION(20), ABREV(GLONABR)
Local Char SAVGABREV(GLONABR)

  #--- declaration et chargement des variables objet
  ABREV = "AIN"
  SAVGABREV = GABREV
  GABREV = ABREV
  Gosub DEFVAR From GOBJET    # FGR 07/06/2010 : X3SUIVI64666 A faire juste après GABREV
  #
  SAVFONC = GFONCTION
  GFONCTION = "GES" + ABREV
  #Gosub DEFVAR From GOBJET   # FGR 07/06/2010 : X3SUIVI64666 là on perd SAVFONC !
  SAVGIMPORT = GIMPORT
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK = 1
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION = "AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If !clalev([M:AIN0]) : Local Mask AIN0 [AIN0] : Endif
  If !clalev([M:AIN1]) : Local Mask AIN1 [AIN1] : Endif
  If !clalev([M:AIN2]) : Local Mask AIN2 [AIN2] : Endif
  If !clalev([M:AIN3]) : Local Mask AIN3 [AIN3] : Endif
  Raz [M:AIN0], [M:AIN1], [M:AIN2], [M:AIN3]
  #--- ouverture des tables necessaires
  Local File BPCUSTOMER [BPC]  # FGR 23/04/2010 : X3SUIVI64234
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  Gosub OUVRE From WOAIN
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  WINPROG = "WGOAIN"
  GREP = "M"
  Read [AIN]AIN0=SZAINNUM
  If fstat <> 0 Then
    LERRCOD = 4
    #Erreur lors de la lecture de l'interlocuteur +" : "+SZAINNUM
    Call ECR_TRACE(mess(644,177,1) - ":" - SZAINNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  [M:AIN0] = [F:AIN]
  [M:AIN1] = [F:AIN]
  [M:AIN2] = [F:AIN]
  [M:AIN3] = [F:AIN]
  Default Mask [AIN0]
  Default Mask [AIN1]
  Default Mask [AIN2]
  Default Mask [AIN3]
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=LIENS",0) From GESECRAN
  Endif
  ACTION = "LIENS" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR LIENS",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #------------------------------------------------------------------------
  # FGR 27/03/2015 : X3SUIVI107276 (début)
  ACTION = "AVANT_CHOI" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_CHOI",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  # FGR 27/03/2015 : X3SUIVI107276 (fin)
  #------------------------------------------------------------------------
  #--- chargement des masques de objet
  If ITRACE > 1 Then
    Call ECR_TRACE("MASK",0) From GESECRAN
  Endif
   # chargement masques enregistrement entête tache
  Default Mask [AIN0]
  Call SAIMSK("AIN","IMP_ZONE","SUBAINCM") From W0AIN0
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK AIN0 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [AIN1]
  Call SAIMSK("AIN","IMP_ZONE","SUBAINCM") From W0AIN1
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK AIN1 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [AIN2]
  Call SAIMSK("AIN","IMP_ZONE","SUBAINCM") From W0AIN2
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK AIN2 mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  Default Mask [AIN3]
  Call SAIMSK("CNT","IMP_TAB","SUBAINCM") From W0AIN3
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  MARSK AIN3(IMP_TAB) mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 2
    Gosub ONERROR
    End
  Endif
  #
  OK = 1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERIF_MOD",0) From GESECRAN
  Endif
  ACTION = "VERIF_MOD" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERIF_MOD",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  Read [AIN]AIN0=SZAINNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture de l'interlocuteur - ":" - SZAINNUM
    Call ECR_TRACE(mess(644,177,1) - SZAINNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Readlock [AIN]Curr
  If fstat <> 0 Then
    LERRCOD = 4
    #Impossible de locker l'interlocteur - ":" - SZAINNUM
    Call ECR_TRACE(mess(645,177,1) - ":" - SZAINNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  #Raz [F:AIN]  # FGR 04/06/2010 : X3SUIVI64666 : Pas de RAZ on est en modification
  Default File [F:AIN]
  [F:AIN] = [M:AIN0]
  [F:AIN] = [M:AIN1]
  [F:AIN] = [M:AIN2]
  [F:AIN] = [M:AIN3]
  [F:AIN]UPDUSR = GUSER
  [F:AIN]UPDDAT = date$
  If ITRACE > 1 Then
    #Réécriture [F:AIN]  -  CNTNUM=+[F:AIN]CNTNUM
    Call ECR_TRACE(mess(646,177,1) - [F:AIN]CNTNUM,0) From GESECRAN
  Endif
  GOK = 1
  #
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=INIMOD",0) From GESECRAN
  Endif
  ACTION = "INIMOD" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR INIMOD",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [AIN]
  Endif
  Rewrite [F:AIN]
  If fstat Then
    Call ECR_TRACE("  ERROR Rewrite [F:AIN] fstat="+num$(fstat),1) From GESECRAN
    LERRCOD = 9
    GOK = 0
    Call FSTA("AIN") From GLOCK
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=MODIF",0) From GESECRAN
  Endif
  ACTION = "MODIF" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR MODIF",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If IBDEBTRANSFLG = 0 Then
    Commit
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=APRES_MOD",0) From GESECRAN
  Endif
  ACTION = "APRES_MOD" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR APRES_MOD",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  ACTION = "FERME" : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC
  # FGR 06/04/2011 : X3SUIVI72587 : Restauration Gestion des autorisations
  Call AUTORIS From EXEFNC
  Kill GSZUPDAINTRT
  Kill GIUPDAINTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC
    Endif
  Endif
End

##########################################################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If evalue ("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1 Then
    SZVALBEFORE = num$(evalue("[M]"+IMPZON))
  Endif
  If GIUPDAINTRACE > 1 Then
    Call ECR_TRACE("ACTION =" - ACTION - "IMPZON=" + IMPZON - "XOK=" + num$(XOK),0) From GESECRAN
    If IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE
      Call ECR_TRACE("    " -  mess(369,177,1) - ":" -  SZVALBEFORE,0) From GESECRAN
    Endif
  Endif
  Case ACTION
    When "IMP_ZONE"
      Gosub AIN_SET_HEA_INFO From =GSZUPDAINTRT
    When "IMP_TAB"
      Gosub AIN_SET_DET_INFO From =GSZUPDAINTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER =num$(evalue ("[M]"+IMPZON))
    If SZVALAFTER <> SZVALBEFORE Then
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  If GIUPDAINTRACE > 1 Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    " - mess(370,177,1) - ":" -  SZVALAFTER,0) From GESECRAN
    Endif
  Endif
Return

##########################################################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      Rollback
    Endif
  Endif
  # FGR 20/07/2010 (début)
  If dim(GAINMESSAGE) < 0 Then
    Global Char GAINMESSAGE(type(GMESSAGE)-10)

    GAINMESSAGE = "AIN~" - GMESSIMP
  Endif
  # FGR 20/07/2010 (fin)
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC
  Kill GSZUPDAINTRT
  Kill GIUPDAINTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC
    Endif
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la modification d'un interlocuteur.
#############################################################################
# Note FGR : Vide ici. Cas particulier. Permet de passer en modification sur l'objet
#            pour déclencer tout ce qui se passe à l'enregistrement (CONTACTCRM...).
#            Mais la mise à jour est déjà faite.
#            Sert notamment sur TRTBPA.CRECNT
$AIN_SET_HEA_INFO
  #Case IMPZON
  #  When "xxx"
  #  When Default
  #Endcase
Return

#############################################################################
$AIN_SET_DET_INFO
  #Case IMPZON
  #   When "xxx"
  #  When Default
  #Endcase
Return
