# open the selection of BG
$BG_SELBI
Raz T_CODF1
Raz T_LAB
GACTION = "SELOBJET" : T_CODF1=CODF
Call SELECT("AIT","T",T_CODF1,"") From SELOBJ
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
If T_CODF1<>""
 Read[AIT]AIT0=T_CODF1
 If fstat=0
  CLOBD+="<Code>"+T_CODF1+"</Code>"
  Call LECTEXTRA(T_LAB,"AITRLNK","INTIT",T_CODF1,"") From ATEXTRA
  Call MODVAL(T_LAB) From INTRUTILA
  CLOBD+="<Label>"+T_LAB+"</Label>"
  CLOBD+="<NbStates>"+num$([F:AIT]NBRVAL+1)+"</NbStates>"
 Endif
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return

# return the value/state/tooltip of a BG
$BG_GETVALUE
Raz T_VAL
Raz T_STA
Raz T_TIP
OK = 1

Call GET_VALUE(CODF, T_VAL, T_STA, T_TIP, OK, MESSAG(1)) From SUBAIT
If !OK : GRAV(1)=3 : Goto ENDTR : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
CLOBD+="<Code>"+CODF+"</Code>"
CLOBD+="<Value>"+num$(T_VAL)+"</Value>"
CLOBD+="<State>"+num$(T_STA)+"</State>"
CLOBD+="<Tip>"+T_TIP+"</Tip>"
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
Return

# open the filtered selection
$BG_OPENFUNC
OK = 1
Call OPEN_FUNC(CODF, OK, MESSAG(1)) From SUBAIT
If !OK : GRAV(1)=3 : Endif # ??? Goto ENDTR
Return

# check if a given BG code is valid and return the title
$BG_CONTBI
Raz T_LAB
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
Read[AIT]AIT0=CODF
If fstat<>0
MESSAG(1)=mess(296,123,1) : GRAV(1)=3 : OK=0 : Goto ENDTR : # Indicateur inexistant
Endif
CLOBD+="<Code>"+CODF+"</Code>"
Call LECTEXTRA(T_LAB,"AITRLNK","INTIT",CODF,"") From ATEXTRA
Call MODVAL(T_LAB) From INTRUTILA
CLOBD+="<Label>"+T_LAB+"</Label>"
CLOBD+="<NbStates>"+num$([F:AIT]NBRVAL+1)+"</NbStates>"
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
