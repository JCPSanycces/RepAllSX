#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("APR",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "RAZCRE" : Gosub RAZCRE
 When "LIENS" : Gosub LIENS
 When "SETBOUT" : Gosub SETBOUT
 When "EXEBOUT" : Gosub EXEBOUT
 When "FIN_ACTION" : Gosub FIN_ACTION
 When "STYLE" : Gosub STYLE
 When "DEGRISE" : Gosub DEGRISE
 When "CREATION" : Gosub CREATION
 When "MODIF" : Gosub MODIF
 When "AV_ANNULE" : Gosub AVANNULE
 When "ANNULE" : Gosub ANNULE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "APRES_CRE" : Gosub CRE_DOC : Gosub MAJ_ACLOB
 When "APRES_MOD" : Gosub MAJ_DOC : Gosub MAJ_ACLOB
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"  : Gosub INICRE
 When "RAZDUP"  : Gosub RAZDUP
 When "AFFMASK" : Gosub AFFMASK
 When "AP_ANNULE"   : Gosub AP_ANNULE
Endcase
Return

#-----------------------#
$AFFMASK
If dim([M:APR0]CODLEG)>0
 If !func AFNC.ACTIV("LEG")
  Chgfmt [M:APR0]CODLEG With "-K:"+num$(GLONADI)+"B"
  If dim([M:APR0]ZCODLEG)>0
   Chgfmt [M:APR0]ZCODLEG With "-K:"+num$(type([M:APR0]ZCODLEG)-10)+"X"
  Endif
 Endif
Endif
Return

#-----------------------#
$CRE_DOC
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("APR",[M]CODPRO+"_"+[M]CODLEG,"C") From AGENLIBA
Return

#-----------------------#
$MAJ_DOC
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("APR",[M]CODPRO+"_"+[M]CODLEG,"M") From AGENLIBA
Return

#-----------------------#
$RAZDUP
If dim([M:APR0]CODLEG)>0 & !func AFNC.ACTIV("LEG")
 [M:APR0]CODLEG = GDOSLEG
Endif
Return

#--------------------------------#
$INICRE
If !func AFNC.ACTIV("LEG")
 [F:APR]CODLEG = GDOSLEG
Endif
Return

#----------------------#
$APRES_MODIF
Case zoncou
 When "APROC" : # mb 12.3.14 bug 96692
  If !VERROU & !find(REP,"C","D")
   Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
   RELIT=9 : Gosub RELIT From GOBJACT : RELIT=0
   zc = [M]APROC
   OK = -1 : # Pour ne pas rentrer en modification
  Endif
Endcase
Return

#########################################################
## Pour les patches des transactions
#########################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#########################################################
Subprog PATCHMOD(APPLI,CODE)
Value Char APPLI
Value Char CODE

Local Char WCODPRO(250)
Local Char WCODLEG(250)
Local Integer ERR,I
I = instr(1,CODE,"~")
If I>0
 WCODLEG = left$(CODE,I-1)
 WCODPRO = right$(CODE,I+1)
 ERR=func ARECOPRO.GENE_SYRA_JSON(APPLI,WCODPRO,WCODLEG)
Else
 ERR =1
Endif
If ERR
 Call ECR_TRACE(mess(6,123,1)-mess(138,127,1)-WCODPRO+"~"+WCODLEG,0) From GESECRAN
Endif
End

#----------------------------------------------------------------------------#
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer ERR
Local File =APPLI+".APROCESSUS"  [APR_]
For [APR_]APR1
  ERR=func ARECOPRO.GENE_SYRA_JSON(APPLI,[APR_]CODPRO,[APR_]CODLEG)
  If ERR
   Call ECR_TRACE(mess(6,123,1)-mess(138,127,1)-[APR_]CODLEG+"~"+[APR_]CODPRO,0) From GESECRAN
  Endif
Next
Close Local File [APR_]
End

#######################################
$MAJ_ACLOB
  Local Integer ERRJS
  ERRJS=func ARECOPRO.GENE_SYRA_JSON(nomap,[APR]CODPRO,[APR]CODLEG)
Return

#######################################
$CREATION
$MODIF
Local Integer ERRTP

Call TRANSLATEPR([M]CODPRO,[M]CODLEG,[M]LANGDESC1,[M:APR3]CLOB,ERRTP)
If [M]LANGDESC1=GLANGUE
  Call MAJTEXTRA([M]INTIT1,"APROCESSUS","INTIT1",[M]CODPRO,"") From ATEXTRA
  # JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
  Call ECRIRE_DOC("APR",[M]CODPRO+"_"+[M]CODLEG,[M]TEXTE,[M]INTIT1,[M]MODULE,[M]CODACT) From SUBADO
Endif
If GREP="D"
  Local Integer ERR
  Call DUPTEXTRA("APROCESSUS","INTIT1",CLECUR1,"","APROCESSUS","INTIT1",[M]CODPRO,"") From ATEXTRA
  Call DUPLICTEXPR(CLECUR1,CLECUR2,[M]CODPRO,[M]CODLEG,ERR)
Endif


Return

#######################################


$AVANNULE
#   Bug 77268      CC  25/10/2011
If [M]CODLEG<>""
# On vérifie qu'il en existe au moins un autre
  If clalev([F:APR1])=0 : Local File =APPLI+".APROCESSUS" [APR1] : Endif
  Filter [APR1] Where CODPRO=[M]CODPRO
  Local Integer NBP
  For [APR1]
    NBP+=1
  Next
  If NBP>1 : Return : Endif
Endif
If clalev([F:APO])=0 : Local File =APPLI+".APROMEN"    [APO] : Endif
Local Integer IG
For [APO]
  For IG=0 To [F:APO]NBPROC
    If [F:APO]PROCESSUS(IG)=[M]CODPRO
      GOK=0
# Suppression impossible. Processus utilisé dans le menu
      GMESSAGE=mess(222,124,1)-[F:APO]CODMEN
      Break 2
    Endif
  Next IG
Next
Return


$ANNULE
# on ne supprime l'intitulé dans AXX que si il ne reste aucun processus de même code
If clalev([F:APR1])=0 : Local File =APPLI+".APROCESSUS" [APR1] : Endif
Local Integer REST
Filter [APR1] Where CODPRO=[M]CODPRO
For [APR1]
 If [F:APR1]CODLEG<>[M]CODLEG : REST=1 : Break 1 : Endif
Next
Filter [APR1]
If REST=0
 Delete [AXX] Where CODFIC="APROCESSUS" & ZONE="INTIT1" & IDENT1=[L]CODE
 If fstat=1 | fstat>5
  GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK
 Endif
Endif
Call DELETETPR([M]CODPRO,[M]CODLEG)
Call EFFACE_DOC("APR",[M]CODPRO+"_"+[M]CODLEG) From SUBADO
Return

#----------------------------------------------------------------------------#
$AP_ANNULE
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("APR",[L]SUPP+"_"+[L]CODE,"A") From AGENLIBA
Return

#######################################
# Pour éviter de perdre la saisie du clob
# Aztuze pour rendre l'écran invalide après duplication
$FIN_ACTION
If REPONSE<>GSTACRE : Return : Endif
$DEGRISE
# Aztuze pour rendre l'écran invalide après création ou modif
$STYLE
# Aztuze pour rendre l'écran invalide après la lecture
#Setmok [M] With 0
Return

#######################################
$RAZCRE
If dim([M:APR0]CODLEG)>0 & !func AFNC.ACTIV("LEG")
 [M:APR0]CODLEG = GDOSLEG
Endif
# mettre à vide le flash
Raz [M:APR3]CLOB
Gosub CHARGFLASH
Return

#######################################
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2a") From GOBJET : # Validation, Copie, Import
Else
 If [M:APR1]TYPEP=2 : Call VIREBOUT(CHAINE,"a") From GOBJET : Endif
Endif
Return

#######################################
$EXEBOUT
Case REP
 When "a" : Gosub IMPPROC
 When "V" :
  If !GSERVEUR
    Call OUVRE_BOITE(mess(138,127,1),0) From GESECRAN
  Endif
  Local Integer ERRJS
  ERRJS=func ARECOPRO.GENE_SYRA_JSON(nomap,[M]CODPRO,[M]CODLEG)
  If !GSERVEUR
    Call FERME_BOITE From GESECRAN
  Endif
Endcase
Return

#######################################
$IMPPROC
Local Char FICCLI(250),REPSRV(250),BF1(250),RETOUR(250)
Local Integer STAT
REPSRV=filpath("tmp","","")
Askui RETOUR="" With "UIAsk="+chr$(1)+"AskPutFile",
& "UILocalFileName="+chr$(1)+FICCLI,
& "UILocalFileExts="+chr$(1)+"txt",
& "UIRemoteFileName="+chr$(1)+GUSER+"proc.txt",
& "UIRemotePath="+chr$(1)+REPSRV,
& "UIRemoteOverWrite="+chr$(1)+"1"
STAT = val(RETOUR)
fstat=0
If STAT=1
 REPSRV=filpath("tmp",GUSER+"proc","txt")
 Openi REPSRV,0 Using [PRO_]
 # If fstat=0
 Raz [M:APR3]CLOB
 While fstat=0
  Rdseq BF1 Using [PRO_]
  [M:APR3]CLOB+=BF1
 Wend
 Openi Using [PRO_]
 Affzo [M:APR3]CLOB
 Gosub CHARGFLASH
Endif
Return

#######################################
$LIENS
If [M:APR0]LANGDESC1=""
 [M:APR0]LANGDESC1=GLANGUE : Affzo [M:APR0]LANGDESC1
Endif
Local Integer OJK
Call LECTURE_DOC("APR",[M]CODPRO+"_"+[M]CODLEG,[M]TEXTE,OJK) From SUBADO
If [M]TYPEP<>2
 Gosub CHARGFLASH
Else
 # mettre à vide le flash
 Raz [M:APR3]CLOB
 Gosub CHARGFLASH
 Diszo [M:APR2]APROC
Endif
Return

#######################################
$CHARGFLASH
Local Char LANG1 : LANG1=[M:APR0]LANGDESC1
$CHARGFLASH1
Call CREPRTEXT([M:APR0]CODPRO,[M:APR0]CODLEG,LANG1,[M:APR3]CLOB)
[M:APR2]APROC='<X3PORTAL>'+'<Data>'+'<Page><![CDATA['
[M:APR2]APROC+=[M:APR3]CLOB
[M:APR2]APROC+=']]></Page>'+'</Data>'+'<Technical>'+'<VisCmp Type="FPADT">'
[M:APR2]APROC+='</VisCmp>'+'<UserLang>'+LANG1+'</UserLang>'+'</Technical>'
[M:APR2]APROC+='<Messages>'+'</Messages>'+'</X3PORTAL>'
Affzo [M:APR2]APROC
Actzo [M:APR2]APROC
Return

#######################################
Subprog CLOBEXP(CODEC,CLOBOUT)
Value Char CODEC : # Code du processus; code métier; menu à afficher
Variable Clbfile CLOBOUT() : # Résultat
Local Char LEGISL,CODE
Local Integer IP1
Local Integer MONOLEG
# On donne le processus par défaut dans la législation de l'utilisateur
# Si il n'existe pas dans cette législation, on le donne en législation ""
# sinon on renvoie "vide"
If clalev([F:APR1])=0 : Local File APROCESSUS [APR1] : Endif
If dim(GLEGFIL)>0 : LEGISL=GLEGFIL : Endif
If LEGISL=""
 MONOLEG = 0
 If clalev([F:ACV])>0
  Read [ACV]CODACT="LEG"
  If fstat or [F:ACV]FLACT<>2
   MONOLEG = 1
  Endif
 Endif
 If MONOLEG
  LEGISL = GDOSLEG(1)
 Endif
Endif
CODE=CODEC
IP1=instr(1,CODEC,";")
If IP1<>0 : CODE=left$(CODEC,IP1-1) : Endif

Read [APR1]APR1=LEGISL;CODE
If fstat=0
 Call CLOBEXPLANG(CODEC,LEGISL,GLANGUE,CLOBOUT)
Else
 Read [APR1]APR1="";CODE
 If fstat=0
  LEGISL=""
  Call CLOBEXPLANG(CODEC,LEGISL,GLANGUE,CLOBOUT)
 Else
  Raz CLOBOUT
 Endif
Endif
End

# -----------------------------------------------------------------------------------------
Subprog CLOBEXPLANG(CODEC,LEGISL,LANGD,CLOBOUT)
Value Char CODEC : # Code du processus; code métier; menu à afficher
Value Char LEGISL : # Code législation
Value Char LANGD : # Langue de travail
Variable Clbfile CLOBOUT() : # Résultat
Local Char CODE,MENMET,LANGDE
Local Clbfile CLBNAV(5)
Local Integer IP1,IP2
CODE=CODEC
LANGDE=LANGD
If LANGDE="" : LANGDE=GLANGUE : Endif
IP1=instr(1,CODEC,";")
If IP1<>0
CODE=left$(CODEC,IP1-1)
IP2=instr(IP1+1,CODEC,";")
If IP2=0 : IP2=len(CODEC)+1 : Endif
If IP2<>0 : MENMET=mid$(CODEC,IP1+1,IP2-IP1-1) : Endif
Endif
Raz CLOBOUT
If MENMET<>"" : Call MENMET(MENMET,LANGDE,CLBNAV) From SUBAPO : Endif
If clalev([F:APR])=0 : Local File APROCESSUS [APR] : Endif
Read [APR]APR1=LEGISL;CODE
If fstat<>0 : Gosub PROCVIDE : End : Endif
Call CREPRTEXT(CODE,LEGISL,LANGDE,[F:APR]CLOB)
CLOBOUT+='<X3PORTAL>'+'<Data>'+'<Page><![CDATA['
CLOBOUT+=[F:APR]CLOB
CLOBOUT+=']]></Page>'
If CLBNAV<>""
CLOBOUT+='<MainNavig><![CDATA['+CLBNAV+']]></MainNavig>'
Endif
#CLOBOUT+='</Data>'+'<Technical>'+'<VisCmp Type="FPADT">'
CLOBOUT+='</Data>'+'<Technical>'+'<VisCmp Type="FPADP">' : # Player
CLOBOUT+='</VisCmp>'+'<UserLang>'+LANGDE+'</UserLang>'+'</Technical>'
CLOBOUT+='<Messages>'+'</Messages>'+'</X3PORTAL>'
End
$PROCVIDE
CLOBOUT+='<X3PORTAL>'+'<Data>'+'<Page>'
CLOBOUT+='<![CDATA[{"acts":{},"layersArr":[{"xpropsArr":[],"alpha":100,"visible":true,"lock":false,"id":0}'
CLOBOUT+=',{"xpropsArr":[],"alpha":100,"visible":true,"lock":false,"id":1}],"reachedGroupNum":0,"contentSize"'
CLOBOUT+=':{"xheight":75000,"xwidth":75000},"docDims":{"xheight":640,"xwidth":860,"xtop":0,"xleft":0},"currentLayerId":1}]]>'
CLOBOUT+='</Page></Data>'+'<Technical>'+'<VisCmp Type="FPADP">' : # Player
CLOBOUT+='</VisCmp>'+'<UserLang>'+LANGDE+'</UserLang>'+'</Technical>'
CLOBOUT+='<Messages>'+'</Messages>'+'</X3PORTAL>'
Return
