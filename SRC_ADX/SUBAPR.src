######################################################################################
#
# Interaction avec les processus
#
Subprog AINTERFL(TYPI1,CODF,TRANS,CLOBD,MESSAG,GRAV,OK)
Value Char TYPI1
Value Char CODF
Value Char TRANS
Variable Clbfile CLOBD()
Variable Char MESSAG()(1..)
Variable Integer GRAV(1..)
Variable Integer OK
# CLOBD : contient le clob de description des paramètres (spécifique à chaque interaction flash)
# MESSAG : contient le texte des messages à afficher (0 à 5)
# GRAV : contient la gravité des messages 1=info, 2=avertissement, 3=bloquant
# OK=1 si pas de pb, 0 sinon
# TYPI1 : fxselLinkToFunc --> Sélection fonction
# fxselLinkToTrans --> Sélection transaction
# fxcontrolFunc --> Contrôle fonction ou fonction+variante
# CODF : code fonction (optionnel)
# TRANS : code transaction (optionnel)
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
# Exigence 73847
If clalev([F:AIT])=0 : Local File AITRLNK [AIT] : Endif
Local Char T_CODF1
Local Char T_LAB(30)
Local Char T_FON(30)
Local Char T_SEL(100)
Local Char T_CNT(100)
Local Integer T_VAL
Local Integer T_STA
Local Char T_TIP(100)
# End Exigence 73847
Local Char LIBF1(30),AKEY(100)

If left$(MESSAG,4)="KEY:"
  AKEY=right$(MESSAG,5)
  Raz MESSAG(1),GRAV(1)
Endif
Local Integer NB

Case toupper(TYPI1)
When "FXSELLINKTOFUNC" : Gosub SELFUNC
When "FXSELLINKTOFIELD" : Gosub SELFIELD
When "FXSELLINKTOTRANS" : Gosub SELTRANS
When "FXSELLINKTOPROC" : Gosub SELPROC
When "FXSELLINKTOBO" : Gosub SELBO
When "FXSELLINKTOREPORT" : Gosub SELREP
When "FXSELLINKTOREQ" : Gosub SELREQ
When "FXSELLINKTOSTA" : Gosub SELSTA
When "FXSELLINKTOCONSULTCODE" : Gosub SELCONS
When "FXSELLINKTOCONSULTSCREEN" : Gosub SELSCR
When "FXCONTROLPROC" : Gosub CONTPROC
When "FXCONTROLBO" : Gosub CONTBO
When "FXCONTROLFUNC" : Gosub CONTFUNC
When "FXCONTROLFIELD" : Gosub CONTFIELD
When "FXCONTROLREQ" : Gosub CONTREQ
When "FXCONTROLSTA" : Gosub CONTSTA
When "FXCONTROLREPORT" : Gosub CONTREPORT
When "FXCONTROLCONSULT" : Gosub CONTCONS
When "FXCONTROLCONSULTSCREEN" : Gosub CONTCONSSCR
When "FXDOLINKTOPROC" : Gosub LTOPROC
When "FXDOLINKTOBO" : Gosub LTOBO
When "FXDOLINKTOFUNC" : Gosub LTOFUNC
When "FXDOLINKTOREQ" : Gosub LTOREQ
When "FXDOLINKTOSTA" : Gosub LTOSTA
When "FXDOLINKTOREPORT" : Gosub LTOREPORT
When "FXDOLINKTOCONSULT","FXDOLINKTOCONSULTCODE" : Gosub LTOCONSULT
When "FXDOOPENFILE" : Gosub DOOPENFILE
# Exigence 73847 - add fonctions for BG(Business gauge)
When "FXSELBI" : Gosub BG_SELBI
When "FXCONTROLBI" : Gosub BG_CONTBI
When "FXDOBIGETVALUE" : Gosub BG_GETVALUE
When "FXDOBILINK" : Gosub BG_OPENFUNC
# End Exigence 73847
When Default : OK=0 : CLOBD=""
Endcase
End
# Appel d'un autre processus

$LTOPROC
Call CLOBEXP(CODF,CLOBD)
Return

$LTOREQ
Local Char PARAM(10)(1..3) , VALEUR(250)
PARAM(1) = CODF
PARAM(2) = "2"
PARAM(3) = "1"

# Bug 63609 : tiens compte de la requête recalculée ou pas
If clalev([F:ALH])=0 : Local File ALISTEH [ALH] : Endif
Read[ALH]ALH0=CODF
If fstat=0
  If [F:ALH]ALLUSR>0 : PARAM(3)=num$([F:ALH]ALLUSR) : Endif
Endif

Local Char SAVFONC : SAVFONC=GFONCTION
If dim(GFONC1)>0 and GFONC1<>""
  Local Char SAVGFONC1
  SAVGFONC1 = GFONC1
  Raz GFONC1
Endif
GFONCTION="EXEALH"
Call TRAITE_CHAR(VALEUR,PARAM,"ALISTE","SUBALH2","ALISTE",6,"SPEALH") From GTRAITE
GFONCTION=SAVFONC
If dim(GFONC1)>0 and dim(SAVGFONC1)>0 :   GFONC1=SAVGFONC1 : Endif
Return


$DOOPENFILE
Local Char URL(200),RETOUR(200)
IT1=instr(1,CLOBD,"<CODE")
If IT1=0 : Return : Endif
IT2=instr(IT1,CLOBD,">")
IT3=instr(IT2,CLOBD,"</")
If IT2>0 and IT3>IT2
  URL=mid$(CLOBD,IT2+1,IT3-IT2-1)
Endif
#Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
#&                         "UILOCALDIR="+ chr$(1) +"FullPath",
#&                         "UILocalFile="+ chr$(1) +"<\\michelp4d\public\temp\CALLUI.htm>"

If GBROWS=0
 Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                         "UILocalDir="+ chr$(1) +"FullPath",
&                         "UILocalFile="+ chr$(1) +URL
Else
 #URL="file:"+URL
 Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                         "UILocalDir="+ chr$(1) +"file",
&                         "UILocalFile="+ chr$(1) +URL
Endif

Return

$LTOBO
Local Char PARAM(10)(1..3) , VALEUR(250)
PARAM(1) = CODF
PARAM(2) = ""
PARAM(3) = ""
Local Char SAVFONC : SAVFONC=GFONCTION
GFONCTION="ABIIMP"
If GPILNAV<=1
 GPILNAV += 1
 GNAVIG(GPILNAV) = GFONCTION
Endif
If dim(GFONC1)>0 and GFONC1<>""
  Local Char SAVGFONC1
  SAVGFONC1 = GFONC1
  Raz GFONC1
Endif
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIIMP","ABIIMP",4,"") From GTRAITE
GFONCTION=SAVFONC
If dim(GFONC1)>0 and dim(SAVGFONC1)>0 :   GFONC1=SAVGFONC1 : Endif
Return

$LTOSTA
Local Char PARAM(80)(1..20)
PARAM(1)=CODF
Local Char SAVFONC : SAVFONC=GFONCTION
#GFONCTION="CONSSTA"
GFONCTION="APTLREQ" : GREPORT2=""
If GPILNAV<=1
 GPILNAV += 1
 GNAVIG(GPILNAV) = GFONCTION
Endif
If dim(GFONC1)>0 and GFONC1<>""
  Local Char SAVGFONC1
  SAVGFONC1 = GFONC1
  Raz GFONC1
Endif
Call CONSULT_CHAR(GBIDC1,"STA",PARAM) From GCONSULT
GFONCTION=SAVFONC
If dim(GFONC1)>0 and dim(SAVGFONC1)>0 :   GFONC1=SAVGFONC1 : Endif
Return

$LTOFUNC
If dim(GFONC1)>0 and GFONC1<>""
  Local Char SAVGFONC1
  SAVGFONC1 = GFONC1
  Raz GFONC1
Endif
If AKEY=""
  Call EXEFNC(CODF,TRANS) From EXEFNC
Else
  Call EXEFNCK(CODF,TRANS,AKEY) From EXEFNC
Endif
If dim(GFONC1)>0 and dim(SAVGFONC1)>0 :   GFONC1=SAVGFONC1 : Endif
Return

$LTOREPORT
Local Char PARAM(20)(1..3) , VALP1(30)
PARAM(1) = CODF
Local Char SAVFONC : SAVFONC=GFONCTION
GFONCTION="AIMP"
If GPILNAV<=1
 GPILNAV += 1
 GNAVIG(GPILNAV) = GFONCTION
Endif
If dim(GFONC1)>0 and GFONC1<>""
  Local Char SAVGFONC1
  SAVGFONC1 = GFONC1
  Raz GFONC1
Endif
Call TRAITE_CHAR(VALP1,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
GFONCTION=SAVFONC
If dim(GFONC1)>0 and dim(SAVGFONC1)>0 :   GFONC1=SAVGFONC1 : Endif
Return

$LTOCONSULT
Local Char PARAM(80)(1..20)
Local Char SAVFONC : SAVFONC=GFONCTION
GFONCTION="APTLREQ" : GREPORT2=""
If GPILNAV<=1
 GPILNAV += 1
 GNAVIG(GPILNAV) = GFONCTION
Endif
If dim(GFONC1)>0 and GFONC1<>""
  Local Char SAVGFONC1
  SAVGFONC1 = GFONC1
  Raz GFONC1
Endif
Call CONSULT_CHAR(GBIDC1,CODF,PARAM) From GCONSULT
GFONCTION=SAVFONC
