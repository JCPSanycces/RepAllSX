#-------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File APROCESSUS [APR1]
 Local File ATEXTRA [AXX1]
 Local File APROCTEXTE [AXP1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB [ADH1]
Else
 Local File =[M]DOSORG+".APROCESSUS" [APR1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
 Local File =[M]DOSORG+".APROCTEXTE" [AXP1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB" [ADH1]
Endif
If [M]DOSDES=nomap
 Local File APROCESSUS [APR2]
 Local File ATEXTRA [AXX2]
 Local File APROCTEXTE [AXP2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB [ADH2]
Else
 Local File =[M]DOSDES+".APROCESSUS" [APR2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
 Local File =[M]DOSDES+".APROCTEXTE" [AXP2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB" [ADH2]
Endif
OK = 1
Local Char    DOSLEG(30)(1..30)
Local Integer NBLEG
Local Integer MONOLEG
Call SETLEG([M]DOSDES,DOSLEG,NBLEG) From DOSCONT
MONOLEG = !func AFNC.ACVDOSACT([M]DOSDES,"LEG")
If GTRACE=""
 If MONOLEG
  If (TABLE2="" or TABLE2=DOSLEG)
   Read [APR2]APR1 = DOSLEG;TABLE
   If !fstat
    # Fiche déjà existante
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Else
   # Législation non gérée par le dossier
   Call ERREUR(TABLE2-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
   OK = 0
  Endif
 Else
  If TABLE2<>"" & !find(TABLE2,DOSLEG(1..NBLEG))
   # Législation non gérée par le dossier
   Call ERREUR(TABLE2-":"-mess(67,127,1)-[M]DOSDES) From GESECRAN
   OK = 0
  Else
   Read [APR2]APR1 = TABLE2;TABLE
   If !fstat
    OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
    If OK<>2 : OK = 0 : Endif
   Endif
  Endif
 Endif
Endif
If OK
 Gosub OUVDOS From ATEXTRA
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [APR1], [APR2], [AXX1], [AXX2], [AXP1], [AXP2]
Close Local File [ADO1], [ADH1], [ADO2], [ADH2]
Return

$TR_COP
GOK = 1
Trbegin [APR2],[AXP2]
 Read [APR1]APR1 = TABLE2;TABLE
 If !fstat
  If [F:APR1]CODLEG="" or find([F:APR1]CODLEG,DOSLEG(1..NBLEG))
   Readlock [APR2]APR1 = TABLE2;TABLE
   If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".APROCESSUS" : Goto ROLL_TR_COP
   Else
    If MONOLEG & [F:APR1]CODLEG=""
     Readlock [APR2]APR1= DOSLEG(1);TABLE
     If fstat=1
      GOK=-1 : GLOCK = "$"+[M]DOSDES+".APROCESSUS" : Goto ROLL_TR_COP
     Elsif fstat
      [F:APR2]=[F:APR1]
      [F:APR2]CODLEG = DOSLEG(1)
      If dim([F:APR2]UPDUSR)>0 : [F:APR2]UPDUSR = GUSER : Endif
      If dim([F:APR2]UPDDAT)>0 : [F:APR2]UPDDAT = date$ : Endif
      If dim([F:APR2]UPDTIM)>0 : [F:APR2]UPDTIM = time : Endif
      Call COPTEXTRA("APROCESSUS","INTIT1",TABLE,"") From ATEXTRA
      If GOK<0 : Goto ROLL_TR_COP
      Elsif !GOK : Goto AB_TR_COP
      Endif
      Write [APR2]
      If fstat
       GOK=0 : Call FSTA("APR2") From GLOCK : Goto AB_TR_COP
      Endif
     Else
      [F:APR2]=[F:APR1]
      [F:APR2]CODLEG = DOSLEG(1)
      If dim([F:APR2]UPDUSR)>0 : [F:APR2]UPDUSR = GUSER : Endif
      If dim([F:APR2]UPDDAT)>0 : [F:APR2]UPDDAT = date$ : Endif
      If dim([F:APR2]UPDTIM)>0 : [F:APR2]UPDTIM = time : Endif
      Call COPTEXTRA("APROCESSUS","INTIT1",TABLE,"") From ATEXTRA
      If GOK<0 : Goto ROLL_TR_COP
      Elsif !GOK : Goto AB_TR_COP
      Endif
      Rewrite [APR2]
      If fstat
       GOK=0 : Call FSTA("APR2") From GLOCK : Goto AB_TR_COP
      Endif
     Endif
     Call COPTEXAPR(TABLE,TABLE2,TABLE,DOSLEG(1))
     If GOK<0 : Goto ROLL_TR_COP
     Elsif !GOK : Goto AB_TR_COP
     Endif
    Else
     If fstat
      [F:APR2]=[F:APR1]
      If dim([F:APR2]UPDUSR)>0 : [F:APR2]UPDUSR = GUSER : Endif
      If dim([F:APR2]UPDDAT)>0 : [F:APR2]UPDDAT = date$ : Endif
      If dim([F:APR2]UPDTIM)>0 : [F:APR2]UPDTIM = time : Endif
      Call COPTEXTRA("APROCESSUS","INTIT1",TABLE,"") From ATEXTRA
      If GOK<0 : Goto ROLL_TR_COP
      Elsif !GOK : Goto AB_TR_COP
      Endif
      Write [APR2]
      If fstat
       GOK=0 : Call FSTA("APR2") From GLOCK : Goto AB_TR_COP
      Endif
     Else
      [F:APR2]=[F:APR1]
      If dim([F:APR2]UPDUSR)>0 : [F:APR2]UPDUSR = GUSER : Endif
      If dim([F:APR2]UPDDAT)>0 : [F:APR2]UPDDAT = date$ : Endif
      If dim([F:APR2]UPDTIM)>0 : [F:APR2]UPDTIM = time : Endif
      Call COPTEXTRA("APROCESSUS","INTIT1",TABLE,"") From ATEXTRA
      If GOK<0 : Goto ROLL_TR_COP
      Elsif !GOK : Goto AB_TR_COP
      Endif
      Rewrite [APR2]
      If fstat
       GOK=0 : Call FSTA("APR2") From GLOCK : Goto AB_TR_COP
      Endif
     Endif
     Call COPTEXAPR(TABLE,TABLE2,TABLE,TABLE2)
     If GOK<0 : Goto ROLL_TR_COP
     Elsif !GOK : Goto AB_TR_COP
     Endif
     Call COPIE_DOC("APR",TABLE+"_"+TABLE2,[M]DOSORG,[M]DOSDES) From SUBADO
     If GOK<0 : Goto ROLL_TR_COP
     Elsif !GOK : Goto AB_TR_COP
     Endif
    Endif
   Endif
  Endif
 Endif
Commit
Return

# Copie des textes
Subprog COPTEXAPR(TABLE,TABLE2,NEWTAB,NEWTAB2)
Value Char TABLE , TABLE2, NEWTAB, NEWTAB2
Filter [AXP1] Where CODPRO=TABLE and CODLEG=TABLE2
For [AXP1]
 Read [AXP2]AXP0 = NEWTAB;NEWTAB2;[F:AXP1]LANG;[F:AXP1]UNIQIDP
 If fstat=0
  [F:AXP2]=[F:AXP1]
  [F:AXP2]CODPRO=NEWTAB
  [F:AXP2]CODLEG=NEWTAB2
  If dim([F:APR2]UPDUSR)>0 : [F:APR2]UPDUSR = GUSER : Endif
  If dim([F:APR2]UPDDAT)>0 : [F:APR2]UPDDAT = date$ : Endif
  If dim([F:APR2]UPDTIM)>0 : [F:APR2]UPDTIM = time : Endif
  Rewrite [AXP2]
 Else
  [F:AXP2]=[F:AXP1]
  [F:AXP2]CODPRO=NEWTAB
  [F:AXP2]CODLEG=NEWTAB2
  If dim([F:AXP2]UPDUSR)>0 : [F:AXP2]UPDUSR = GUSER : Endif
  If dim([F:AXP2]CRETIM)>0 : [F:AXP2]CRETIM = time : Endif
  If dim([F:AXP2]CREDAT)>0 : [F:AXP2]CREDAT = date$ : Endif
  Write [AXP2]
 Endif
Next
Filter [AXP1]
End

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

$SELTRANS
# On recherche l'objet à partir de la fonction
# On recherche les fenêtres qui présentent cet objet
Local Char ABREV,PROGOBJ,LIBF1(30),ACTION
Local Integer IT,NBT
Read [AFC]CODEXT=CODF
If fstat<>0 : MESSAG(1)=mess(162,123,1) : GRAV(1)=3 : OK=0 : Return : Endif : # Fonction inexistante
IT=find("OBJET",[F:AFC]CODPAR(0..19))
# Variable paramètre inexistante
If IT=0
  #106762 If [F:AFC]VALEUR(0)<>"#"
  If find("#",[F:AFC]VALEUR(0..[F:AFC]NBVAR-1))=0
    MESSAG(1)=mess(232,123,1) : GRAV(1)=3 : OK=0
  Else
    OK=1
  Endif
  Return
Endif
ABREV=[F:AFC]VALPAR(IT-1)
If left$(ABREV,1)="'" or left$(ABREV,1)='"' : ABREV=right$(ABREV,2) : Endif
If right$(ABREV,len(ABREV))="'" or right$(ABREV,len(ABREV))='"' : ABREV=left$(ABREV,len(ABREV)-1) : Endif
# On vérifie si il existe plusieurs fenêtres pour cet objet
For [AWI]AWI1 Where OBJ=ABREV & ENAFLG=2 & MDL<>2
NBT+=1
Next
If NBT<=1 and CODF<>"GESGAC" and CODF<>"GESCCE":
  #106762 If [F:AFC]VALEUR(0)<>"#"
  If find("#",[F:AFC]VALEUR(0..[F:AFC]NBVAR-1))=0
    MESSAG(1)=mess(22,7837,1) : GRAV(1)=1 : OK=0
  Else
    OK=1
  Endif
  Return
Endif
PROGOBJ = "WO"+ABREV
If CODF<>"GESGAC" and CODF<>"GESCCE"
Gosub SAI_VARIANTE From GOBJET
Else
If CODF="GESGAC"
Local Integer NBLEG,ILEG
Local Char TBLEG(20)(1..200)
Local Char LEG(20),TIT(100)
TIT=mess(172,105,1) : # "plan comptable"
If clalev([F:COA])=0 : Local File GCOA [COA] : Endif
For [COA]
NBLEG+=1 : TBLEG(NBLEG)=[F:COA]COA
Next
Elsif CODF="GESCCE"
Local Integer NBLEG,ILEG
Local Char TBLEG(20)(1..200)
Local Char LEG(20),TIT(100)
TIT=mess(667,200,1) : # "axe analytique"
If clalev([F:DIE])=0 : Local File GDIE [DIE] : Endif
For [DIE]
NBLEG+=1 : TBLEG(NBLEG)=[F:DIE]DIE
Next
Endif
Call SAITEX(NBLEG,TBLEG,ILEG,TIT) From GESECRAN
If ILEG<>0 : LEG=TBLEG(ILEG+1) : Endif
Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
If CODF<>"GESGAC" and CODF<>"GESCCE"
If GFLAG<>""
CLOBD+="<Code>"+GFLAG+"</Code>"
Call TITTRN(GFLAG,LIBF1) From =PROGOBJ
CLOBD+="<Label>"+LIBF1+"</Label>"
Endif
Else
If LEG<>""
CLOBD+="<Code>"+LEG+"</Code>"
CLOBD+="<Label>"+"</Label>"
Endif
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
$CONTFIELD
If clalev([F:ADZ])=0 : Local File ADOCFLD [ADZ] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
If CODF<>""
Read[ADZ]ADZ0=GLANGUE;CODF
If fstat=0
CLOBD+="<Code>"+[F:ADZ]MOTCLE+"</Code>"
Else
MESSAG(1)=mess(84,141,1) : # Code inexistant
GRAV(1)=3
OK=0
Endif
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
$CONTFUNC
Local Char ABREV,PROGOBJ,LIBF1(30)
Local Integer IT,TROUV,NBT
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
Read[AFC]CODINT=CODF
If fstat<>0
MESSAG(1)=mess(162,123,1) : GRAV(1)=3 : OK=0 : Goto ENDTR : # Fonction inexistante
Endif
CLOBD+="<Code>"+CODF+"</Code>"
LIBF1=""
Call TEXTE([F:AFC]NOM,LIBF1) From OBJDIV
Call MODVAL(LIBF1) From INTRUTILA
CLOBD+="<Label>"+LIBF1+"</Label>"
If TRANS="" : Goto ENDCONTF : Endif
IT=find("OBJET",[F:AFC]CODPAR(0..19))
# Variable paramètre inexistante
If IT=0
  #106762 If [F:AFC]VALEUR(0)<>"#"
  If find("#",[F:AFC]VALEUR(0..[F:AFC]NBVAR-1))=0
    MESSAG(1)=mess(232,123,1) : GRAV(1)=3 : OK=0
  Else
    OK=1
  Endif
Goto ENDTR
Endif
If CODF<>"GESGAC" and CODF<>"GESCCE"
ABREV=[F:AFC]VALPAR(IT-1)
If left$(ABREV,1)="'" or left$(ABREV,1)='"' : ABREV=right$(ABREV,2) : Endif
If right$(ABREV,len(ABREV))="'" or right$(ABREV,len(ABREV))='"' : ABREV=left$(ABREV,len(ABREV)-1) : Endif
For [AWI]AWI1 Where OBJ=ABREV & ENAFLG=2 & MDL<>2
If [F:AWI]TRN=TRANS : TROUV=1 : Break 1 : Endif
NBT+=1
Next
CLOBD+="<Trans>"+TRANS+"</Trans>"
#106762 If TROUV=0 and CODF<>"GESGAC" and CODF<>"GESCCE" and [F:AFC]VALEUR(0)<>"#"
If TROUV=0 and CODF<>"GESGAC" and CODF<>"GESCCE" and find("#",[F:AFC]VALEUR(0..[F:AFC]NBVAR-1))=0
If NBT>1
MESSAG(1)=mess(40,114,1) : GRAV(1)=3 : OK=0 : Goto ENDTR : # Code transaction inexistant
Else
MESSAG(1)=mess(22,7837,1) : GRAV(1)=3 : OK=0 : Goto ENDTR : # Cette fonction n'a pas de variante
Endif
Elsif CODF="GESGAC"
If clalev([F:COA])=0 : Local File GCOA [COA] : Endif
Read [COA]COA0 = TRANS
If fstat
MESSAG(1)=mess(110,102,1) : GRAV(1)=3 : OK=0 : Goto ENDTR : # Plan de compte inexistant
Endif
Elsif CODF="GESCCE"
If clalev([F:DIE])=0 : Local File GDIE [DIE] : Endif
Read [DIR]DIE0 = TRANS
If fstat
MESSAG(1)=mess(80,103,1) : GRAV(1)=3 : OK=0 : Goto ENDTR : # Axe inexistant
Endif
Endif
Endif
$ENDCONTF
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
$CONTREQ
If clalev([F:ALH])=0 : Local File ALISTEH [ALH] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
If CODF<>""
Read[ALH]ALH0=CODF
If fstat=0
CLOBD+="<Code>"+[F:ALH]COD+"</Code>"
LIBF1=""
Call LECTEXTRA(LIBF1,"ALISTEH","INTIT",CODF,"") From ATEXTRA
Call MODVAL(LIBF1) From INTRUTILA
CLOBD+="<Label>"+LIBF1+"</Label>"
Else
MESSAG(1)=mess(30,134,1) : # Requête inexistante
GRAV(1)=3
OK=0
Endif
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
$CONTBO
If clalev([F:ABO])=0 : Local File ABIREPORT [ABO] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
If CODF<>""
Read[ABO]ABO0=CODF
If fstat=0
CLOBD+="<Code>"+[F:ABO]COD+"</Code>"
LIBF1=""
Call TEXTE([F:ABO]DES,LIBF1) From OBJDIV
Call MODVAL(LIBF1) From INTRUTILA
CLOBD+="<Label>"+LIBF1+"</Label>"
Else
MESSAG(1)=mess(163,123,1) : # Etat inexistant
GRAV(1)=3
OK=0
Endif
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
$CONTSTA
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
If CODF<>""
Read[PS2]PS20=CODF
If fstat=0
CLOBD+="<Code>"+[F:PS2]COD+"</Code>"
LIBF1=""
Call LECTEXTRA(LIBF1,"PARSTA2","INTIT",CODF,"") From ATEXTRA
Call MODVAL(LIBF1) From INTRUTILA
CLOBD+="<Label>"+LIBF1+"</Label>"
Else
MESSAG(1)=mess(54,127,1) : # Statistique inexistante
GRAV(1)=3
OK=0
Endif
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
$CONTPROC
If clalev([F:APR])=0 : Local File APROCESSUS [APR] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
Read[APR]APR0=CODF
If fstat<>0 or [F:APR]TYPEP<>1
MESSAG(1)=mess(52,127,1) : # Processus inexistant
GRAV(1)=3
OK=0
Else
CLOBD+="<Code>"+[F:APR]CODPRO+"</Code>"
# Call TEXTE([F:APR]INTIT,LIBF1) From OBJDIV
Call LECTEXTRA(LIBF1,"APROCESSUS","INTIT1",CODF,"") From ATEXTRA
Call MODVAL(LIBF1) From INTRUTILA
CLOBD+="<Label>"+LIBF1+"</Label>"
OK=1
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
Return
$CONTREPORT
If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
Read[ARP]ARP0=CODF
If fstat<>0
MESSAG(1)=mess(163,123,1) : # Etat inexistant
GRAV(1)=3
OK=0
Else
CLOBD+="<Code>"+CODF+"</Code>"
Call TEXTE([F:ARP]RPTDES,LIBF1) From OBJDIV
CLOBD+="<Label>"+LIBF1+"</Label>"
OK=1
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
Return
$CONTCONS
If clalev([F:ACN])=0 : Local File ACONSULT [ACN] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
Read[ACN]ACN0=CODF
If fstat<>0
MESSAG(1)=mess(149,115,1) : # Consultation inexistante
GRAV(1)=3
OK=0
Else
CLOBD+="<Code>"+[F:ACN]COD+"</Code>"
Call TEXTE([F:ACN]LIBEL,LIBF1) From OBJDIV
CLOBD+="<Label>"+LIBF1+"</Label>"
OK=1
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
OK=1
Return
$CONTCONSSCR
If clalev([F:GTC])=0 : Local File GTABACC [GTC] : Endif
CLOBD="<X3PORTAL>"
CLOBD+="<Data>"
CLOBD+="<Result>"
Read[GTC]GTC0=CODF;TRANS
If fstat<>0
MESSAG(1)=mess(72,123,1) : # Consultation inexistante
GRAV(1)=3
OK=0
Else
CLOBD+="<Code>"+CODF1+"</Code>"
LIBF1=""
Call LECTEXTRA(LIBF1,"GTABACC","INTIT",CODF,CODF1) From ATEXTRA
Call MODVAL(LIBF1) From INTRUTILA
CLOBD+="<Label>"+LIBF1+"</Label>"
OK=1
Endif
CLOBD+="</Result>"
CLOBD+="</Data>"
CLOBD+="</X3PORTAL>"
Return
$ENDTR
CLOBD="<X3PORTAL>"
CLOBD+="</X3PORTAL>"
Return
