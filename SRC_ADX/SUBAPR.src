######################################################################################
Subprog TRANSLATEPR(CODE,LEGISL,LANGO,CLBPR,ERR)
Value Char CODE
Value Char LEGISL
Value Char LANGO
Value Clbfile CLBPR
Variable Integer ERR
ERR=0
Local Char LANGORI : LANGORI=LANGO
If LANGORI="" : LANGORI=GLANGUE : Endif
Local File APROCESSUS [APR]
Local File APROCTEXTE [AXP]
Local Clbfile CLBF(5)
Gosub RECHTXT
If ERR<>0 : End : Endif
# Mise jour table des textes
Local Integer TFLAG(1..500),MAJEC
If adxlog=0
Trbegin [AXP] : MAJEC=1
Endif
Local Char ABFIC : ABFIC="AXP"
Filter [AXP] Where CODPRO=CODE and CODLEG=LEGISL and LANG=LANGO
For [AXP]
    IND=find([F:AXP]UNIQIDP,UNIQUEID(1..ITXT))
    If IND=0
        Delete [AXP]
    Else
        TFLAG(IND)=1
        CLBF=mid$(CLBPR,TDEB(IND),TFIN(IND)-TDEB(IND)+1)
        If CLBF<>[F:AXP]CLBTEXT
            [F:AXP]CLBTEXT=CLBF
            Gosub INIMOD From GOBJSUB
            Rewrite [AXP]
        Endif
    Endif
Next
Filter [AXP]
For I=1 To ITXT
    If TFLAG(I)=0
        [F:AXP]CODPRO=CODE
        [F:AXP]CODLEG=LEGISL
        [F:AXP]UNIQIDP=UNIQUEID(I)
        [F:AXP]LANG=LANGORI
        [F:AXP]CLBTEXT=mid$(CLBPR,TDEB(I),TFIN(I)-TDEB(I)+1)
        Gosub INICRE From GOBJSUB
        Write [AXP]
    Endif
Next I
If MAJEC=1 : Commit : Endif
End

$RECHTXT
Local Integer DEB,DEBUN,DEBU1,FIN,FINP,FINUN,ITXT,IUNIQ,IND,TDEB(1..500),TFIN(1..500)
Local Char UNIQUEID(30)(1..500),UNIQ1
DEB=1
While DEB<>0
 DEB=instr(DEB,CLBPR,'"xtext":"<TEXTFORMAT')
#            ----   Nouvel algorithme : on cherche uniqueid qui suit et ensuite on revient en arriere
#                                       pour chercher soit </TEXTFORMAT>" soit </P>"
 If DEB<>0
   DEBUN=instr(DEB,CLBPR,'uniqueID":')
   FIN=0 : FINP=0
   If DEBUN<>0
     FIN=instr(DEB+1,CLBPR,'</TEXTFORMAT>"')
     If FIN=0 or FIN>DEBUN
       FINP=1
       FIN=instr(DEB+1,CLBPR,'</P>"')
     Endif
     If FIN>DEBUN : FIN=0 : Endif
   Endif
   If FIN<>0
     ITXT+=1
     TDEB(ITXT)=DEB+9
     If FINP=0
       TFIN(ITXT)=FIN+12
     Else
       TFIN(ITXT)=FIN+3
     Endif
     FINUN=instr(DEBUN,CLBPR,'"}')
     UNIQUEID(ITXT)=mid$(CLBPR,DEBUN+11,FINUN-DEBUN-11)
   Endif
   DEB=DEBUN
 Endif
Wend
Return


$VISUTXT
Local Clbfile CFF(5)
Local Integer I
For I=1 To ITXT
    CFF=mid$(CLBPR,TDEB(I),TFIN(I)-TDEB(I)+1)
    Infbox("TEXTE "+num$(I)-UNIQUEID(I))
    For J=1 To 1+(len(CFF)-1)/200
        Infbox(mid$(CFF,1+(J-1)*200,200))
    Next J
Next I
Return

# -----------------------------------------------------------------------

Subprog DUPLICTEXPR(CODE,LEGISL,NEWPRO,NEWLEG,ERR)
Value Char CODE
Value Char LEGISL
Value Char NEWPRO
Value Char NEWLEG
Value Char LANGO
Variable Integer ERR
ERR=0

Local File APROCESSUS [APR]
Local File APROCTEXTE [AXP]
Local File APROCTEXTE [AXP1]
Read [APR]APR1=LEGISL;CODE
If fstat<>0 : ERR=1 : End : Endif

Local Char ABFIC : ABFIC="AXP"

Filter [AXP1] Where CODPRO=CODE and CODLEG=LEGISL
For [AXP1]
  [F:AXP]=[F:AXP1]
  [F:AXP]CODPRO=NEWPRO
  [F:AXP]CODLEG=NEWLEG
  Gosub INICRE From GOBJSUB
  Write [AXP]
Next
Filter [AXP1]
End

# -----------------------------------------------------------------------
Subprog DELETETPR(CODE,LEGISL)
Value Char CODE
Value Char LEGISL
If clalev([F:AXP])=0 : Local File APROCTEXTE [AXP] : Endif
Delete [AXP] Where CODPRO=CODE and CODLEG=LEGISL
End
# -----------------------------------------------------------------------
Subprog CREPRTEXT(CODE,LEGISL,LANG1,CLBPR)
Value Char CODE
Value Char LEGISL
Value Char LANG1
Variable Clbfile CLBPR
# On insère les textes dans les bonnes langues dans le processus
Local File APROCTEXTE [AXP]
Local Integer I,ERR,DELTAL,IND
Gosub RECHTXT
If ERR<>0 or ITXT=0 : End : Endif
Local Clbfile CLBP(10)  : # CLBF(5) -inutile-
CLBP=CLBPR
Local Integer IREPTXT(1..ITXT)
Filter [AXP] Where CODPRO=CODE and CODLEG=LEGISL and LANG=LANG1
For [AXP]
    IND=find([F:AXP]UNIQIDP,UNIQUEID(1..ITXT))
    If IND<>0
        IREPTXT(IND)=1
        CLBP=left$(CLBP,TDEB(IND)-1)+[F:AXP]CLBTEXT+right$(CLBP,TFIN(IND)+1)
        # on décale les positions pour tenir compte des différences de longueur
        DELTAL=len([F:AXP]CLBTEXT)-(TFIN(IND)-TDEB(IND)+1)
        If DELTAL<>0 : Gosub MOVEPOS : Endif
    Endif
Next
Filter [AXP]

# Si on n'a pas trouvé les textes dans la langue de connexion on les cherche en FRA
# sinon on laisse ce qu'il y a  (.... cher pour pas grand chose)
For IND=1 To ITXT
 If IREPTXT(IND)=0
    Read [AXP]AXP0=CODE;LEGISL;GLANDEF;UNIQUEID(IND)
    If fstat=0
      CLBP=left$(CLBP,TDEB(IND)-1)+[F:AXP]CLBTEXT+right$(CLBP,TFIN(IND)+1)
      DELTAL=len([F:AXP]CLBTEXT)-(TFIN(IND)-TDEB(IND)+1)
      If DELTAL<>0 : Gosub MOVEPOS : Endif
    Elsif fstat<>0 and GLANDEF<>"FRA"
      Read [AXP]AXP0=CODE;LEGISL;"FRA";UNIQUEID(IND)
      If fstat=0
        CLBP=left$(CLBP,TDEB(IND)-1)+[F:AXP]CLBTEXT+right$(CLBP,TFIN(IND)+1)
        DELTAL=len([F:AXP]CLBTEXT)-(TFIN(IND)-TDEB(IND)+1)
        If DELTAL<>0 : Gosub MOVEPOS : Endif
      Endif
    Endif
  Endif
Next J

CLBPR=CLBP
End
$MOVEPOS
For I=1 To ITXT
If TDEB(I)>=TDEB(IND)
TDEB(I)+=DELTAL
TFIN(I)+=DELTAL
Endif
Next I
Return
