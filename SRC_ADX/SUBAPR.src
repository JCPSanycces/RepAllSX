Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran APR2) 17/10/2007 14:40:35 (CCORA)
######################################################################################
Subprog AM_APROC(VALEUR)
Variable Clbfile VALEUR
[M:APR3]CLOB=VALEUR
# On recherche les chaines de caractere &sgxa que l'on remplace par \"
Local Integer D1 : D1=1
D1=instr(D1,[M:APR3]CLOB,"&sgxa")
While D1<>0
[M:APR3]CLOB=left$([M:APR3]CLOB,D1-1)+'\"'+right$([M:APR3]CLOB,D1+5)
D1=instr(D1,[M:APR3]CLOB,"&sgxa")
Wend
End
