#<AdxTL>@(#)9.0.0.0 $Revision$
##############################################################################
## Revalidation des objets avec table contenant le type de donnéés AGF
##############################################################################
Call OUVRE_TRACE("Update AOB") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local Integer K , OK
Local File =DOSSIER+".ATABZON" [ATZX] , =DOSSIER+".AOBJET" [AOBX]
For [AOBX] Where NOMFIC<>""
 K = 0
 For [ATZX] Where CODFIC=[F:AOBX]NOMFIC & (CODTYP="AGF" or CODTYP="AGC")
  K = 1 : Break
 Next ATZX
 If K
  Call ECR_TRACE("Update"-[F:AOBX]ABREV,0) From GESECRAN
  Call VALID([F:AOBX]ABREV,DOSSIER,1,OK) From VALOBJ
 Endif
Next AOBX
Close Local File
Return
