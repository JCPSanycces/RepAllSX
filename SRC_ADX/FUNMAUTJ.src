#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTJALL  : Action jalonnement automatique               #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return

#########################################################################
$INIT
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

#########################################################################
$INIT_DIA
# titre de la boîte 
TIT = mess(128,195,1)
Raz [M:DIA] 
#
[M:DIA]MFGFCY = GFCY
Return

#########################################################################
$CONTROLE
TIT=" "
TMP=1
Return

#########################################################################
$EXEC

If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call PRTSCR("MAUTJAL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call ECR_TRACE(" ",0) From GESECRAN 
Endif

If [M:DIA]ENDDAT = [0/0/0] : [M:DIA]ENDDAT = date$ + GSCHEDHOR : Endif    # llc 08.02 15423 # 15942 11.02 MM

# préparation des critères de filtre
Gosub SEL_OF

# traitement des OF
Gosub TRT_OF

Return

#########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace 
    Call FERME_TRACE From LECFIC
    # aucun jalonnement effectue ou lecture trace
    If !NBOF 
         GERR = 2 : GMESSAGE = mess(88,193,1)
    Endif
    # lecture trace
Endif
Return

########################################################################
$OUVRE
Local Integer  OK
Local Integer  NBOF
Local Integer  WNBOF
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char    CUSFLT(255)
#
Local Char     FORMULE1(255)
#
Local Char     WMESS(150)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WITMREF
Local Char     WSTOFCY (GLONFCY)
Local Char     WVCRNUM
Local Date     WSTRDAT
Local Integer  WSTA

Gosub CHARG_PARAM

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:TWD])  = 0 : Local File TABWEEDIA   [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MFP])  = 0 : Local File MFGPRN      [MFP]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:WKL])  = 0 : Local File WORKLOAD    [WKL]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV]) = 0  : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV]) = 0  : Local File CAPVAR     [CPV]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif 

# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask JALK    [JALK]

Return

########################################################################
# Préparation du filtre sur la table encours (WOx)                     #
########################################################################
$SEL_OF
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

If [M:DIA]WOSFLG = 2
    CRITERE  = "WIPSTA=3"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOPFLG = 2
    CRITERE  = "WIPSTA=2"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOFFLG = 2
    CRITERE  = "WIPSTA=1"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

CRITERE = "ENDDAT<=[M:DIA]ENDDAT"
Gosub LOAD_CRITERE2

CRITERE = "WIPTYP=5"
Gosub LOAD_CRITERE2

CRITERE  = "STOFCY = [M:DIA]MFGFCY"                     # site de production
Gosub LOAD_CRITERE2

CRITERE = "PIO >= [M:DIA]MFGPIODEB"
Gosub LOAD_CRITERE2   

CRITERE = "PIO <= [M:DIA]MFGPIOFIN"
Gosub LOAD_CRITERE2   

If [M:DIA]MFGNUMDEB <> ""                               # borne début OF
   CRITERE = "VCRNUM >= [M:DIA]MFGNUMDEB"
   Gosub LOAD_CRITERE2   
Endif
If [M:DIA]MFGNUMFIN <> ""                               # borne fin   OF       
   CRITERE = "VCRNUM <= [M:DIA]MFGNUMFIN"
   Gosub LOAD_CRITERE2
Endif

# affaire
If [M:DIA]PJTDEB <> ""
   CRITERE = "PJT >= [M:DIA]PJTDEB"                     # borne début affaire  
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]PJTFIN <> ""
   CRITERE = "PJT <= [M:DIA]PJTFIN"                     # borne fin   affaire  
   Gosub LOAD_CRITERE2
Endif

# destinataire
If [M:DIA]BPCNUMDEB <> ""
   CRITERE = "BPRNUM >= [M:DIA]BPCNUMDEB"               # borne début destin.  
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]BPCNUMFIN <> ""
   CRITERE = "BPRNUM <= [M:DIA]BPCNUMFIN"               # borne fin   destin.  
   Gosub LOAD_CRITERE2
Endif

# no commande
If [M:DIA]VCRNUMDEB <> ""
   CRITERE = "VCRNUMORI >= [M:DIA]VCRNUMDEB"            # borne début n° commande
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]VCRNUMFIN <> ""
   CRITERE = "VCRNUMORI <= [M:DIA]VCRNUMFIN"            # borne fin   n° commande
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""
   CRITERE = "ITMREF >= [M:DIA]ITMREFDEB"               # borne début article lancé
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]ITMREFFIN <> ""
   CRITERE = "ITMREF <= [M:DIA]ITMREFFIN"               # borne fin   matière
   Gosub LOAD_CRITERE2
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif


Return  

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

Return


############################################################
$LOAD_CRITERE
If len(CRITERE1)=0 
    CRITERE1 += "("
Else 
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE  
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE  
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return



#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_OF
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT  
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
#

If CRITERE2 <> ""
    Filter [ORD] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&                      Order By Key ORD0
Else
    Filter [ORD] Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1)
&                      Order By Key ORD0
Endif
# boucle de lecture 
For  [ORD]
      WITMREF = [F:ORD]ITMREF
      WSTOFCY = [F:ORD]STOFCY
      WVCRNUM = [F:ORD]VCRNUM
      WSTRDAT = [F:ORD]STRDAT
      WSTA    = [F:ORD]WIPSTA
      If find([F:ORD]WIPSTA,1,2) 
          Gosub SEL_OFCOMPL 
          If OK = 1 : Goto NXT2 : Endif
      Else
          Gosub SEL_OFSCOMPL
          If OK = 1 : Goto NXT2 : Endif
      Endif
      #
      Gosub TRTJAL
$NXT2
Next 
#
Filter [ORD]
#
Return

#-----------------------------------------------------------------------#
# Sélections complémentaires                                            #
#-----------------------------------------------------------------------#
$SEL_OFCOMPL

OK=1
# lecture article
If [F:ITM]ITMREF <> WITMREF
    Read [ITM]ITM0=WITMREF
    If fstat : Raz [F:ITM] : Return : Endif
Endif

# lecture article/site
If [F:ITF]ITMREF <> WITMREF | [F:ITF]STOFCY <> WSTOFCY
    Read [ITF]ITF0=WITMREF;WSTOFCY
    If fstat : Raz [F:ITF] : fstat = 0 : Return : Endif
Endif

# lecture enregistrement entête OF
If [F:MFG]MFGNUM <> WVCRNUM
    Read [MFG]MFG0=WVCRNUM
    If fstat : Raz [F:MFG] : fstat = 0 : Return : Endif
Endif

#
If !find([F:MFG]MFGMOD,1,3) : Return : Endif
If [M:DIA]REJFLG = 1 & [F:MFG]SCDFLG <> 1 : Return : Endif
If [M:DIA]REJFLG = 2 & [F:MFG]SCDFLG <> 3 : Return : Endif
If find([F:MFG]SCDFLG,2,4)    : Return : Endif
If [F:MFG]MFGTRKFLG > 4 : Return : Endif
If [F:MFG]CFMFLG <> 2
    WMESS   = mess(156,197,1)+" "+mess(WSTA,317,1)+" "+WVCRNUM+" "+mess(182,197,1)
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Return
Endif

#
OK=2
# FQ 68265 GA 11/2010
GPOINT = "CUSSELCOMP" : Gosub ENTREE From EXEFNC
Return

#-----------------------------------------------------------------------#
# Sélections complémentaires                                            #
#-----------------------------------------------------------------------#
$SEL_OFSCOMPL
OK=1
For [SCH]SCH0 Where MFGNUM = WVCRNUM
    If find([M:DIA]REJFLG,1,3) & [F:SCH]OPESTRDAT <> [0/0/0] : Break : Endif
    OK=2
    Break
Next
Return

#-----------------------------------------------------------------------#
# Traitement jalonnement                                                #
#-----------------------------------------------------------------------#
$TRTJAL
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJJAL
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Jalonnement                                                           #
#-----------------------------------------------------------------------#
$MAJJAL
#
WMESS   = mess(156,197,1)+" "+mess(WSTA,317,1)+" "+WVCRNUM+" "+mess(176,197,1)
#
Raz [M:JALK]
#Trbegin [MFG]
    [M:JALK]CODORI = 1
    [M:JALK]CODMAJ = 0
    [M:JALK]CODTRS = 3 : # [M:JALK]CODTRS=0
    [M:JALK]MFGFCY = WSTOFCY
    [M:JALK]MFGNUM = WVCRNUM
    [M:JALK]MFGSTA = WSTA
    If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
        Read [PJA]PJA0=[M:JALK]MFGFCY
        If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
    Endif
    Call JALONNE From JALLIB 
    If [M:JALK]CODRET <> 0
       Return # Goto AB_TRTJAL
    Endif
    # traces
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Raz WMESS, WMESS1, WMESS2
    NBOF += 1
#Commit
Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat 
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN 
    OK = 0
    fstat = 0            # llc 11.02    16587
Endif 
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

$ROL_TRTJAL
Rollback
Call ROLL From GLOCK
If GROLL 
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJJAL : Endif 
Return

$AB_TRTJAL
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
fstat = 0            # llc 11.02 16587
Return

######################################################################## 
$CHARG_PARAM 
#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

########################################
Subprog AM_MFGPIODEB(VALEUR)
Variable Integer VALEUR
[M:DIA]MFGPIOFIN = VALEUR
End

########################################
Subprog C_MFGPIOFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M:DIA]MFGPIODEB : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_ITMREFFIN(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog B1_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog AS_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End

########################################
Subprog B1_BPCNUMFIN(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog AS_BPCNUMFIN(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End

########################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]PJTFIN = VALEUR : Endif
End

########################################
Subprog AM_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPCNUMFIN = VALEUR : Endif
End


########################################
Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]VCRNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

########################################
Subprog C_WOFFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]WOSFLG = 1 & 
&  [M:DIA]WOPFLG = 1 &
&  VALEUR = 1
    mkstat = 2
    GERR = 1 : GMESSAGE = mess(359,199,1) # une case au moins doit être cochée !
Endif
End

##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK) 
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..) 
Variable Integer OK 
 
Gosub OUVRE

#
Local Char    WIN (GLONFEN)
WIN="DAUTJALL" 
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT

End  
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End


########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                     # mm 12.02
    GFCY=VALEUR                       # mm 12.02
    Gosub CHARG_PARAM
    [M:DIA]ENDDAT = date$+ GSCHEDHOR  # mm 12.02
Endif                                 # mm 12.02

End

########################################
Subprog AS_WOSFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]REJFLG = 2 : mkstat = 2 : Endif
End



######################################################################################
## Etiquette ajoutée par le superviseur (écran MAUTJAL) 01/02/2006 10:05:30 (LLCX)
######################################################################################
Subprog AS_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M]BPCNUMDEB <> "" : [M]ORDFILTER += "&BPRNUM>=[M]BPCNUMDEB" : Endif
If [M]BPCNUMFIN <> "" : [M]ORDFILTER += "&BPRNUM<=[M]BPCNUMFIN" : Endif
If [M]PJTDEB    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTDEB"       : Endif
If [M]PJTFIN    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTFIN"       : Endif
End

Subprog AS_VCRNUMFIN(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M]BPCNUMDEB <> "" : [M]ORDFILTER += "&BPRNUM>=[M]BPCNUMDEB" : Endif
If [M]BPCNUMFIN <> "" : [M]ORDFILTER += "&BPRNUM<=[M]BPCNUMFIN" : Endif
If [M]PJTDEB    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTDEB"       : Endif
If [M]PJTFIN    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTFIN"       : Endif
End


######################################################################################

