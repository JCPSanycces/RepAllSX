Variable Char    VALEUR()
If [M:SMP1]LOCTYPDES(nolign-1)<>VALEUR
   Call RAZLOC([M:SMP1]LOCDES(nolign-1),[M:SMP1]WLOCSEQ(nolign-1)) From STKACT
Endif
