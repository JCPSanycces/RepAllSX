#<AdxTL>@(#)3.0.0.0 $Revision$
#####################################################################
# Action     SAISTOSMP1 : Saisie du détail echantillonnage          #
# Fenêtre    ISTOSMP1                                               #
# Ecran      STOSMP1                                                #
# Traitement supplémentaire :                                       #
#####################################################################
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "TITRE"       : Gosub TIT_TRT
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "DEBUT"       : Gosub DEBUT
    When "AVANT_MEN"   : Gosub AVANT_MEN
    When "AVANT_BOUTON":
        Case BOUT
            When "E"   : Gosub AVANT_ENR
        Endcase
    When "BOUTON" :
        Case BOUT
            When "E"   : Gosub ENR
            When "A"   : Gosub ABANDON
        Endcase
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "END"         : Gosub ACTEND
    When "FINSAI"      : Gosub FINSAI
    When "SETBOUT"     : Gosub SETBOUT
    When "OK"          : Gosub OK
    When Default       :
Endcase

Return

$OK
#------------------------------#
# Apres exécution du bouton OK #
#------------------------------#
mkstat=4
Return

$APRES_MODIF
#-------------#
# Après modif #
#-------------#
REP="M"
Return

$SET_NOL
Local Integer NOL
NOL = nolign-1
Return

$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","8",GSTQNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GSTQNUM-":"-TIT
Return

##################################################
$OUVRE

Local Integer SAVCONS : SAVCONS=GCONSULT
If !GOUVENT
   FIN = 1
   Return
Endif
If dim(GMAJLIGDOC)<=0
   Global Integer GMAJLIGDOC
Endif
Raz GMAJLIGDOC
Local Integer LLIGDOC   : LLIGDOC = val(PARAM(1))
Local Decimal W_QTE
Local Integer J
GOUVENT = 1    # Pour pouvoir ouvrir le complément lot
# Initialisation de GOUVLOT (valable pour tout le document)
GOUVLOT = 30    # Modif des rubriques utilisateur
If [F:ITM]EXYMGTCOD>1
   GOUVLOT += 128
Endif
Return

##################################################
$OUVRE_BOITE

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif

# ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
BOITE = "WQSMP"+GSTQNUM+"D"

GBOITE = BOITE
Call NOMTRTWIN(BOITE,WINPROG) From MSKDIV

Gosub FORMAT_INV From STKLIB
Gosub FORMAT_INV_CHG From STKLIB                                      # hcb 110327

Return

##################################################
$SETBOUT
If [M:SMP1]QLYCRD = ""
   Call VIREBOUT(CHMEN,"Of") From GOBJET
Endif
If REP<>"M"
   Call VIREBOUT(CHMEN,"E,A") From GOBJET
Endif
If [M:STQ1]VALFLG=2 | [M:STQ1]WSTJQTY([M:SMP]LLIGDOC)=[M:STQ1]QTYSTU([M:SMP]LLIGDOC)
   Call VIREBOUT(CHMEN,"E,A") From GOBJET
Endif
Return

##################################################
$DEBUT
Local Integer I
Local Integer LRET
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Raz [M:SMP1]
# Ne pas déplacer le Diszo (fait avant l'actzo de iptdat)
Diszo [M:SMP1]5-15
Call TEXTE(3569,[M:SMP1]TOTLIG) From OBJDIV
Call TEXTE(8094,[M:SMP1]TOTPEC) From OBJDIV

[M:SMP1]           = [M:SMP]

# effzo pour effacer le tableau
# le tableau est chargé par les stojou si il y a deja eu un enregistrement de l echantillonnage
#    sinon il est chaegé par la ligne du SMP
Effzo [M:SMP1]20

[M:SMP1]VCRLIN     = [M:SMP]VCRLIN(LLIGDOC)

If dim([M:SMP1]LOT)>0
   [M:SMP1]LOT     = [M:SMP]LOT(LLIGDOC)
   [L]WLOT         = [M:SMP1]LOT
Endif
If dim([M:SMP1]SLO)>0
   [M:SMP1]SLO     = [M:SMP]SLO(LLIGDOC)
   [L]WSLO         = [M:SMP1]SLO
Endif
If dim([M:SMP1]LOCTYP)>0
   [M:SMP1]LOCTYP  = [M:SMP]LOCTYP(LLIGDOC)
   [M:SMP1]LOC     = [M:SMP]LOC(LLIGDOC)
Endif
[M:SMP1]STA        = [M:SMP]STA(LLIGDOC)

# si l echantuillon est R alors seul le R est permis sinon A R
[M:SMP1]WAUZSST = "A*,R*"
If left$([M:SMP]STASMP,1) = "R"
   [M:SMP1]WAUZSST = "R*"
Endif

If dim([M:SMP1]WRH)>0
   [M:SMP1]WRH     = [M:SMP]WRH      (LLIGDOC)
Endif
If dim([M:SMP1]PALNUM)>0
   [M:SMP1]PALNUM  = [M:SMP]PALNUM   (LLIGDOC)
Endif
If dim([M:SMP1]CTRNUM)>0
   [M:SMP1]CTRNUM  = [M:SMP]CTRNUM   (LLIGDOC)
Endif

[M:SMP1]OWNER      = [M:SMP]OWNER
[M:SMP1]QTYPCU     = [M:SMP]QTYPCU   (LLIGDOC)
[M:SMP1]PCU        = [M:SMP]PCU      (LLIGDOC)
[M:SMP1]PCUSTUCOE  = [M:SMP]PCUSTUCOE(LLIGDOC)
[M:SMP1]QTYSTU     = [M:SMP]QTYSTU   (LLIGDOC)

[M:SMP1]COEUCUS = "1"-[M:SMP1]PCU-"="-num$([M:SMP1]PCUSTUCOE)-[M:SMP1]STU

If [M:STQ1]VALFLG=2
   Call POSTABLE2([M:SMP1]STOFCY, [M:SMP1]ITMREF, [L]WLOT, [L]WSLO, LRET) From TRTSTOQUAB
Else
   Call POSTABLE([M:SMP1]STOFCY, [M:SMP1]ITMREF, [L]WLOT, [L]WSLO, LRET) From SUBSCSB
   If LRET
      FIN = 1
      Return
   Endif
Endif


Raz [M:SMP1]WSTJFLG
# chargement du tableau  par les stojou si il y a deja eu un enregistrement de l echantillonnage
Gosub LOAD_FROM_STJ_SMP1 From TRTSTOSMPB
# chargement du tableau  par les details deja saisis
Gosub LOAD_FROM_SGW_SMP1 From TRTSTOSMPB

If [M:SMP1]NBLIG=0 & dim([M:SMP1]IPTDAT)>0
   [M:SMP1]IPTDAT = date$
   Actzo [M:SMP1]IPTDAT
#  pas eu de stojou : chargement du tableau par la ligne du SMP
   [M:SMP1]PCUDES    (0)       = [M:SMP]PCUDES   (LLIGDOC)
   [M:SMP1]QTYPCUDES (0)       = [M:SMP]QTYPCUDES(LLIGDOC)
   [M:SMP1]COEDES    (0)       = [M:SMP]COEDES   (LLIGDOC)
   [M:SMP1]QTYSTUDES (0)       = [M:SMP]QTYSTUDES(LLIGDOC)
   [M:SMP1]STADES    (0)       = [M:SMP]STADES   (LLIGDOC)
   If dim([M:SMP1]WRHDES)>0
      [M:SMP1]WRHDES    (0)    = [M:SMP]WRHDES   (LLIGDOC)
   Endif
   If dim([M:SMP1]LPNNUMDES)>0                                                                # hcb X3-77043
      [M:SMP1]LPNNUMDES (0)    = [M:SMP]LPNNUMDES(LLIGDOC)                                    # hcb X3-77043
   Endif                                                                                      # hcb X3-77043
   If dim([M:SMP1]LOCDES)>0
      [M:SMP1]LOCTYPDES (0)    = [M:SMP]LOCTYPDES(LLIGDOC)
      [M:SMP1]LOCDES    (0)    = [M:SMP]LOCDES   (LLIGDOC)
   Endif
   If dim([M:SMP1]SERNUM)>0
      [M:SMP1]SERNUM    (0)    = [M:SMP]SERNUM   (LLIGDOC)
   Endif
   [M:SMP1]LBENBR    (0)       = [M:SMP]LBENBR   (LLIGDOC)
   [M:SMP1]LBEFMT    (0)       = [M:SMP]LBEFMT   (LLIGDOC)
   [M:SMP1]NBLIG=1
Endif
If dim([M:SMP1]PCUDES)>0
   Diszo [M:SMP1]PCUDES
   Actzo [M:SMP1]PCUDES
Endif
If dim([M:SMP1]QTYPCUDES)>0
   Diszo [M:SMP1]QTYPCUDES
   Actzo [M:SMP1]QTYPCUDES
Endif
If dim([M:SMP1]COEDES)>0
   Diszo [M:SMP1]COEDES
   Actzo [M:SMP1]COEDES
Endif
If dim([M:SMP1]STADES)>0
   Diszo [M:SMP1]STADES
   Actzo [M:SMP1]STADES
Endif
If dim([M:SMP1]LOCDES)>0
   Diszo [M:SMP1]LOCDES
   Actzo [M:SMP1]LOCDES
Endif
If dim([M:SMP1]WRHDES)>0
   Diszo [M:SMP1]WRHDES
   Actzo [M:SMP1]WRHDES
Endif
If dim([M:SMP1]LPNNUMDES)>0                                                                   # hcb X3-77043
   Diszo [M:SMP1]LPNNUMDES                                                                    # hcb X3-77043
   Actzo [M:SMP1]LPNNUMDES                                                                    # hcb X3-77043
Endif                                                                                         # hcb X3-77043
If dim([M:SMP1]LOCTYPDES)>0
   Diszo [M:SMP1]LOCTYPDES
   Actzo [M:SMP1]LOCTYPDES
Endif
If dim([M:SMP1]LBEFMT)>0
   Diszo [M:SMP1]LBEFMT
   Actzo [M:SMP1]LBEFMT
Endif
If dim([M:SMP1]LBENBR)>0
   Diszo [M:SMP1]LBENBR
   Actzo [M:SMP1]LBENBR
Endif
LNBLIG = [M:SMP1]NBLIG


# calcul de la qty refusée saisie total - la ligne en cours
[M:SMP1]QTYSMPREFO =  sum([M:SMP]QTYSMPREFLIG)
[M:SMP1]QTYSMPREFO -= [M:SMP]QTYSMPREFLIG(LLIGDOC)

# calcul de la qty refusée saisie total et qte saisie de la ligne
Gosub MAJ_PECQTY    From TRTSTOSMPB

GPOINT="MAJ_SMP1" : Gosub ENTREE From EXEFNC
# Si toute la quantité a déjà changé de statut  et que des stojou existent(STJ) => on grise tout
If [M:SMP1]NBLIG=LNBLIG & [M:SMP1]PECQTYSTU=[M:SMP1]QTYSTU & [M:SMP1]WSTJFLG (0) <> 0
    Diszo [M:SMP1]20
Endif
#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
If GWRHACT = 2
   If [M]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[M]STOFCY
   Endif
   If [F:FCY]WRHGES <> 2
      Grizo [M:SMP1]WRHDES
   Endif
Endif

#-------- Pour afficher les colonnes correctement même s'il n'y a pas de ligne -------#
If [M:SMP1]NBLIG=0
   [M:SMP1]NBLIG=1
   Affzo [M:SMP1]1-99
   [M:SMP1]NBLIG=0
Endif

Local Integer WDISZO
Raz WDISZO
Read [ACC]CODACC=GUSER;[F:ITF]QUAACS
If fstat | [F:ACC]MODIF<>2
    WDISZO = 2
Endif
# pas de modifications si :
#      - Controle validé
#      - pas acces utilisateur
#      - Gconsult = 2 "Bouton 8 -Infos échantillonage-"
If [M:STQ1]VALFLG=2 | WDISZO = 2  | GCONSULT
   Diszo [M:SMP1]
Endif
mkstat = 4
Affzo [M:SMP1]1-99
Return

#############################################################
$AVANT_MEN
# Si toute la quantité a déjà changé de statut (STJ) => on grise tout
If [M:SMP1]NBLIG=LNBLIG & [M:SMP1]PECQTYSTU=[M:SMP1]QTYSTU
  GCONSULT=1
Endif
Return

#############################################################
$AVANT_ENR
Local Integer  LRET
Local Shortint WRET
Local Integer  LLIG
Local Integer  J
Local Char     MES(255)
Local Integer  LNBNEWLIG

LNBNEWLIG = sigma(0,[M:SMP1]NBLIG-1,[M:SMP1]WSTJFLG(indcum)<>1)
If LNBNEWLIG=0
   Return
Endif

Raz FOK

#------------------------------------------------------------------------------#
# Vérification que toutes les lignes saisies peuvent être entrées dans STOCHGW #
#------------------------------------------------------------------------------#
If [M:SGW]NBLIG+[M:SMP1]NBLIG > dim([M:SGW]WSTOSEQ)
    Call ERREUR(mess(36,184,1)+"\"+mess(353,199,1)) From GESECRAN
    Return
Endif

# controle quantité qualifiée

If [M:SMP1]QTYSTU <> [M:SMP1]PECQTYSTU
   Call ERREUR(mess(370,184,1)) From GESECRAN  # La quantité traitée est differente
   FOK= 0
   Return
Endif

#--------------------------------#
# controle saisie lignes         #
#--------------------------------#
LRET = 0
For LLIG = 0 To [M:SMP1]NBLIG-1
    If [M:SMP1]QTYPCUDES(LLIG) <> 0
       Call CTRLIG("SMP1",LLIG, LRET) From SUBSCSB
       If LRET > 0
          MES  = mess(93,100,1)+":"+num$(LLIG+1)+"\"
          If LRET=256
             MES += mess(67,184,1)+"\"        # Ligne stock en inventaire
          Else
             MES += mess(7,111,1) +":\"
             If mod(LRET ,2)>=1
                MES += mess(23,197,1)+"\"    # Unités
             Endif
             If mod(LRET ,4)>=2
                MES += mess(9,184,1)+"\"     # Quantité doit être >0
             Endif
             If mod(LRET ,8)>=4
                MES += mess(398,198,1)+"\"   # Coeff
             Endif
             If mod(LRET ,16)>=8
                MES += mess(24,197,1)+"\"    # Statut
             Endif
             If mod(LRET ,32)>=16 | mod(LRET ,64)>=32
                MES += mess(2,181,1)+"\"     # Emplacement / Type Emplacement
             Endif
             If mod(LRET ,128)>=64
                MES += mess(47,197,1)        # N° de série non saisi
             Endif
#                                                                                       # hcb 110327 deb
            If mod(LRET ,1024)>=512
                MES += mess(246,199,1)        # # Le nb de no série ne correspond pas à la qté à traiter
            Endif
#                                                                                       # hcb 110327 end

          Endif
       Endif
    Endif
    If LRET : Break : Endif
#                                                                                             # hcb X3-77043 deb
# controle meme emplacement pour chaque contenant
    If [F:ITF]LPNMGTCOD = 2 & [F:SRT]CHGEMPCOD = 2 & [M:SMP1]LPNNUMDES(LLIG) <> ""
#--- Contrôle du mono-emplacement par LPN
       K=sigma(LLIG+1,[M:SMP1]NBLIG-1,1*([M:SMP1]LPNNUMDES(indcum)=[M:SMP1]LPNNUMDES(LLIG) & [M:SMP1]WSTJFLG(indcum)=0))
       L=sigma(LLIG+1,[M:SMP1]NBLIG-1,1*([M:SMP1]LPNNUMDES(indcum)=[M:SMP1]LPNNUMDES(LLIG) & [M:SMP1]WSTJFLG(indcum)=0
&                & [M:SMP1]LOCDES(indcum)=[M:SMP1]LOCDES(LLIG)))
       If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:SMP1]LPNNUMDES(LLIG),[M:SMP1]LOCDES(LLIG))) From GESECRAN
          GERR=1
          Break
       Endif
    Endif
#                                                                                             # hcb X3-77043 fin

Next
If GERR = 1                                                                                   # hcb X3-77043
   Return                                                                                     # hcb X3-77043
Endif                                                                                         # hcb X3-77043

If LRET
    Call ERREUR(MES) From GESECRAN  # Ligne incomplete
    FOK= 0
    Return
Endif

FOK=1

Return

##################################################
$ENR
Local Integer LRET
Local Integer LSEQ
Local Decimal LQTYSTU
Local Char    LPCU(GLONUOM)
Local Decimal LCOEF
Local Char    LSTA(GLONSTA)
Local Char    LLOCTYP(GLONTLO)
Local Char    LLOC(GLONLOC)
Local Char    LWRH(GLONWRH)
Local Char    LSER(GLONSER), LSERF(GLONSER)
Local Integer LQLYFLG
Local Date    LDAT
Local Decimal LAAA, LRRR
If LNBNEWLIG <> 0
   # si une saisie detail existe il ne faut pas supprimer stochgw
    If !find(1,[M:STQ1]WSTOFLG(0..[M:STQ1]NBLIG-1)) & [M:SMP1]WSTOFLG = 0                     # hcb 110327
       Call DELSTOCHGW("STQ1", [M:SMP1]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB
   Else
   # mais supprimer le detail pour wstoseq et wstocou
       Call DELSTOCHGW([M:SMP1]STOFCY, [M:SMP1]WSTOSEQ,[M:SMP1]WSTOCOU, 0, LRET) From TRTSTOSMPB
       [M:SMP1]WSTOFLG = 0                                                                   # hcb 110327
   Endif
   LSEQ = [M:SMP1]WSTOSEQ
   I = find(0,[M:SMP1]WSTJFLG(0..[M:SMP1]NBLIG-1))-1
   If I>=0
      Call FILLCHGW("SMP1", I, [M:SMP1]NBLIG-I, LSEQ, [M:SMP1]STOFCY, LRET, LQTYSTU) From SUBSCSB
      # La ligne chargée n'est pas correcte
      If LRET<>0 | GERR=2
         LRET=99
      Endif
      If LQTYSTU=0
         Call ERREUR(mess(367,199,1)) From GESECRAN    # Pas de stock disponible
      Elsif LQTYSTU<[M:SMP1]PECQTYSTU-sigma(0,[M:SMP1]NBLIG-1,[M:SMP1]QTYSTUDES(indcum)*[M:SMP1]WSTJFLG(indcum))
         Call MESSAGE( mess(275,198,1)-":"-num$(LQTYSTU)-"/"-num$([M:SMP1]PECQTYSTU) ) From GESECRAN
      Endif
   Endif
   Call RECSGW_SMP ((LLIGDOC),[M:SMP1]WSTOSEQ,[M:SMP1]WSTOCOU,"") From TRTSTOSMPB
   [M:SMP]IPTDAT          = [M:SMP1]IPTDAT
   Affzo [M:SMP]IPTDAT


   If dim([M:SMP]LPNNUMDES) >0 & [M:SMP]LPNNUMDES(LLIGDOC) <> ""                              # hcb X3-77043
      Diszo [M:SMP]LPNNUMDES (LLIGDOC)                                                        # hcb X3-77043
    Endif                                                                                     # hcb X3-77043

   If dim([M:SMP]LOCTYPDES) >0 & [M:SMP]LOCTYPDES(LLIGDOC) <> ""
      Diszo [M:SMP]LOCTYPDES (LLIGDOC)
      Diszo [M:SMP]LOCDES    (LLIGDOC)
      If dim([M:SMP]WRHDES) > 0
         Diszo [M:SMP]WRHDES (LLIGDOC)
      Endif
   Endif
   [M:SMP]MODFLG(LLIGDOC) = 2
Endif
# calcul qte refusée saisie de la ligne SMP
Local Integer I
[M:SMP]QTYSMPREFLIG(LLIGDOC) = sigma (I=0,max([M:SMP1]NBLIG-1,nolign-1),[M:SMP1]QTYSTUDES(I)*(left$([M:SMP1]STADES(I),1)= "R"))
[M:SMP]QTYSMPREFS = sum([M:SMP]QTYSMPREFLIG)   # affichage qty R saisie
Affzo [M:SMP]QTYSMPREFS
FIN=1
If LNBNEWLIG>0
    GMAJLIGDOC=1
    mkstat=4
Endif

Return


##################################################
$ABANDON
Gosub ANNULE
Raz [M:SMP1]
Raz REP
Gosub DEBUT
Return

##########################################################################
$ANNULE
Local Integer  I
Local Integer  LRET
Local Shortint WRET

    For I=0 To [M:SMP1]NBLIG-1
       If [M:SMP1]WLOCSEQ(I)<>0 & dim([M:SMP1]LOCDES)>0
        Call STKDELRES([M:SMP1]WLOCSEQ(I), [M:SMP1]STOFCY, [M:SMP1]LOCDES(I), LRET) From STKLOC
       Endif
    Next

    I=find([M:SMP1]WSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
    While I>0 & I<dim([M:SGW]WSTOSEQ) & [M:SGW]WSTOSEQ(I)=[M:SMP1]WSTOSEQ
        If [M:SGW]WLOCDES(I) = [M:SMP1]LOC
            Call STKVALEMP([M:SGW]WLOCSEQ(I),
&                      [M:SMP1]TRSTYP,[M:SMP1]TRSCOD,
&                      [M:SMP1]STOFCY,[M:SMP1]ITMREF,
&                      [M:SGW]WPCUDES(I),
&                      [M:SMP1]QTYPCU,[M:SGW]WQTYPCUDES(I),
&                      [M:SGW]WSTADES(I),[M:SGW]WLOCTYPDES(I),
&                      [M:SGW]WLOCDES(I),"",WRET,GBIDD1,"","") From STKLOC
        Else
            Call STKCTREMP([M:SGW]WLOCSEQ(I),
&                      [M:SMP1]TRSTYP,[M:SMP1]TRSCOD,
&                      [M:SMP1]STOFCY,[M:SMP1]ITMREF,
&                      [M:SGW]WPCUDES(I),
&                      [M:SGW]WQTYPCUDES(I),
&                      [M:SGW]WSTADES(I),[M:SGW]WLOCTYPDES(I),
&                      [M:SGW]WLOCDES(I),"",1,WRET,GBIDD1,"","",
&                      "") From STKLOC
        Endif

        I += 1
    Wend
Return

##########################################################################
$ACTEND
    Gosub ANNULE
    Raz REP                                                                               # hcb X3-77043
Return

##########################################################################
$FINSAI
GCONSULT=SAVCONS
Return
##########################################################################
Subprog C_NBLIG
Local Integer I
Local Integer LRET
Gosub SET_NOL

Case status
    When 73, 82:

        If [M:SMP1]PECQTYSTU=[M:SMP1]QTYSTU
            mkstat=2
        Elsif [M:SGW]NBLIG+[M:SMP1]NBLIG+1>=dim([M:SGW]WSTOSEQ)
            mkstat=2
            GMESSAGE=mess(36,184,1)
        Endif

    # annulation d une ligne
    When 65 :
        If [M:SMP1]WSTJFLG(nolign-1)=0 & [M:SMP1]WLOCSEQ(nolign-1)<>0 & dim([M:SMP1]LOCDES)>0
            Call STKDELRES([M:SMP1]WLOCSEQ(nolign-1), [M:SMP1]STOFCY, [M:SMP1]LOCDES(nolign-1), LRET) From STKLOC
            [M:SMP1]QTYSTUDES(nolign-1) = 0
            Gosub MAJ_PECQTY From TRTSTOSMPB
        Else
            mkstat=2
        Endif

    # annulation d'un groupe de lignes
    When 68,83 :
        If [M:SMP1]WSTJFLG(nolign-1)=0
            For I=nolign-1 To nolign1
               If [M:SMP1]WLOCSEQ(I)<>0 & dim([M:SMP1]LOCDES)>0
                 Call STKDELRES([M:SMP1]WLOCSEQ(I), [M:SMP1]STOFCY, [M:SMP1]LOCDES(I), LRET) From STKLOC
               Endif
               [M:SMP1]QTYSTUDES(I) = 0
            Next
            Gosub MAJ_PECQTY From TRTSTOSMPB
        Else
            mkstat=2
        Endif
Endcase

End

##########################################################################
Subprog AVANT_NBLIG
Local Integer LRET
Local Char    WWRH(GLONWRH)
 #   If [M:SMP1]LOCDES(nolign-1)  = ""                                # hcb 110327
 If [M:SMP1]STADES(nolign-1)  = ""                                    # hcb 110327
    If nolign-1=0
       [M:SMP1]PCUDES(nolign-1)    = [M:SMP1]PCU
       [M:SMP1]COEDES(nolign-1)    = [M:SMP1]PCUSTUCOE
       [M:SMP1]STADES(nolign-1)    = [M:SMP]STASMP
       If dim ([M:SMP1]WRHDES)> 0
          [M:SMP1]WRHDES(nolign-1) = [M:SMP1]WRH
       Endif
       If dim ([M:SMP1]LPNNUMDES)> 0                                                          # hcb X3-77043
          [M:SMP1]LPNNUMDES(nolign-1) = [M:SMP1]LPNNUM                                        # hcb X3-77043
       Endif                                                                                  # hcb X3-77043
       If [M:SMP1]STADES(nolign-1)<>"" & [F:ITF]LOCMGTCOD=2
          If [F:ITF]ITMREF<>[M:SMP1]ITMREF | [F:ITF]STOFCY<>[M:SMP1]STOFCY
             Read [ITF]ITF0 = [M:SMP1]ITMREF; [M:SMP1]STOFCY
             If fstat : Raz [F:ITF] : Endif
          Endif
          If dim([M:SMP1]WRH) > 0
             WWRH=[M:SMP1]WRH
          Else
             WWRH=""
          Endif
          Call STKCTRTLO([M:SMP1]WLOCSEQ(nolign-1),[M:SMP1]TRSTYP,[M:SMP1]TRSCOD,[M:SMP1]STOFCY,[M:SMP1]ITMREF
&                       ,[M:SMP1]PCUDES(nolign-1),[M:SMP1]QTYPCUDES(nolign-1),[M:SMP1]STADES(nolign-1)
&                       ,0,[M:SMP1]LOCTYP,mkstat,"QU","",WWRH) From STKLOC
          If !mkstat & [M:SMP1]LOC<>""
             Call STKCTREMP([M:SMP1]WLOCSEQ(nolign-1),[M:SMP1]TRSTYP,[M:SMP1]TRSCOD,[M:SMP1]STOFCY
&                          ,[M:SMP1]ITMREF,[M:SMP1]PCUDES(nolign-1),[M:SMP1]QTYPCUDES(nolign-1),[M:SMP1]STADES(nolign-1)
&                          ,[M:SMP1]LOCTYP,[M:SMP1]LOC,"",0,mkstat,GBIDD1,"QU","",WWRH) From STKLOC
             If !mkstat
                [M:SMP1]LOCTYPDES(nolign-1)=[M:SMP1]LOCTYP
                [M:SMP1]LOCDES(nolign-1)   =[M:SMP1]LOC
                If dim ([M:SMP1]WRHDES)> 0
                   [M:SMP1]WRHDES(nolign-1)=[M:SMP1]WRH
                Endif
             Endif
          Endif
       Endif
            #---
    Else
       [M:SMP1]PCUDES(nolign-1)    = [M:SMP1]PCUDES(nolign-2)
       [M:SMP1]COEDES(nolign-1)    = [M:SMP1]COEDES(nolign-2)
       [M:SMP1]LBENBR(nolign-1)    = [M:SMP1]LBENBR(nolign-2)
       [M:SMP1]LBEFMT(nolign-1)    = [M:SMP1]LBEFMT(nolign-2)
       [M:SMP1]STADES(nolign-1)    = [M:SMP]STASMP

# calcul du reste à saisir

       If [M:SMP1]PECQTYPCU < [M:SMP1]QTYPCU
          If [M:SMP1]PCUDES(nolign-1) = [M:SMP1]STU
             [M:SMP1]QTYPCUDES(nolign-1) =  ([M:SMP1]QTYPCU-[M:SMP1]PECQTYPCU)*[M:SMP1]PCUSTUCOE
             Call QTEARR([M:SMP1]QTYPCUDES(nolign-1),[M:SMP1]STU) From TRTDIV
          Else
             [M:SMP1]QTYPCUDES(nolign-1)=  ([M:SMP1]QTYPCU-[M:SMP1]PECQTYPCU)*[M:SMP1]PCUSTUCOE /[M:SMP1]COEDES(nolign-1)
             Call QTEARR([M:SMP1]QTYPCUDES(nolign-1),[M:SMP1]PCUDES(nolign-1)) From TRTDIV
          Endif
       Endif

 #   Endif                                                                                    # hcb X3-77043
       If dim ([M:SMP1]LPNNUMDES)> 0                                                          # hcb X3-77043
          [M:SMP1]LPNNUMDES(nolign-1) = [M:SMP1]LPNNUMDES(nolign-2)                           # hcb X3-77043
       Endif
       If [F:ITF]LOCMGTCOD=2
          Call STKWLOCSEQ("SMP1", nolign-1, LRET) From STKECR
          If nolign>1
             [M:SMP1]LOCTYPDES(nolign-1) = [M:SMP1]LOCTYPDES(nolign-2)
             [M:SMP1]LOCDES   (nolign-1) = [M:SMP1]LOCDES   (nolign-2)
             If dim([M:SMP1]WRHDES) > 0
                [M:SMP1]WRHDES(nolign-1) = [M:SMP1]WRHDES   (nolign-2)
             Endif
          Endif
          If sigma(0,[M:SMP1]NBLIG-1,[M:SMP1]WSTJFLG(indcum)=0)=0
             Call STKMODREMP([M:SMP1]WLOCSEQ(nolign-1),
&                            [M:SMP1]STOFCY,
&                            [M:SMP1]ITMREF,
&                            [M:SMP1]PCU,
&                            [M:SMP1]QTYPCU-[M:SMP1]PECQTYPCU,
&                            [M:SMP1]STA,
&                            [M:SMP1]LOC,
&                            "",mkstat,"") From STKLOC
          Endif
       Endif
    Endif                                                                                     # hcb X3-77043
    Actzo [M:SMP1]PCUDES   (nolign-1)
    Actzo [M:SMP1]QTYPCUDES(nolign-1)
    If dim([M:SMP1]STADES  (nolign-1))>0
       Actzo [M:SMP1]STADES(nolign-1)
    Endif
    If dim([M:SMP1]WRHDES  (nolign-1))>0
       Actzo [M:SMP1]WRHDES(nolign-1)
    Endif
    If dim([M:SMP1]LPNNUMDES  (nolign-1))>0                                                   # hcb X3-77043
       Actzo [M:SMP1]LPNNUMDES(nolign-1)                                                      # hcb X3-77043
    Endif                                                                                     # hcb X3-77043
    If dim([M:SMP1]LOCDES  (nolign-1))>0
       Actzo [M:SMP1]LOCTYPDES(nolign-1)
       Actzo [M:SMP1]LOCDES(nolign-1)
    Endif
Endif
#                                                                                         # hcb x3-77043 deb
If dim([M:SMP1]LPNNUMDES) > 0
    If [M:SMP1]LPNNUMDES                (nolign-1)<>""
       Read [LPN]LPN0=[M:SMP1]LPNNUMDES (nolign-1)
       If !fstat & [F:LPN]LOC<>""
           Diszo [M:SMP1]LOCDES         (nolign-1)
           Diszo [M:SMP1]LOCTYPDES      (nolign-1)
       Endif
    Endif
Endif
#                                                                                         # hcb x3-77043 fin




End

##########################################################################
Subprog APRES_NBLIG
Local Integer     LRET
Local Shortint    WRET
Local Char        LSLO(GLONSLO)
Local Decimal     WOVF
Local Libelle LNOTPCU
Local Libelle LNOTCOE
Local Libelle LNOTSTA
Local Libelle LNOTLOC
Local Libelle LNOTLOF
Local Libelle LNOTLOT
Local Libelle LNOTSLO
Local Libelle LNOTSER
Local Libelle LNOTPAL
Local Libelle LNOTCTR
Local Integer LDUP
Local Integer I

Gosub SET_NOL
Gosub MAJ_PECQTY    From TRTSTOSMPB

If [M:SMP1]WLOCSEQ(NOL)=0 | [M:SMP1]WLOCSEQ(NOL)=100000
    Call STKDELRES(100000,"","",LRET) From STKLOC
    [M:SMP1]WLOCSEQ(NOL)=0
Endif
If adxgtb=1 | find(status,65,68,83)
    If [F:ITF]LOCMGTCOD=2 & dim([M:SMP1]LOC) & [M:SMP1]WLOCSEQ(NOL)<>100000
        # Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
        If [M:SGW]WLOCSEQCUR>100000 & [M:SGW]WLOCSEQCUR<>99999999
          [M:SGW]WLOCSEQCUR -= 100000
        Endif
        If [M:SGW]WLOCSEQCUR<>0
            Call STKDELRES([M:SGW]WLOCSEQCUR, [M:SMP1]STOFCY, "", LRET) From STKLOC
            [M:SGW]WLOCSEQCUR = 99999999
        Endif
        If [M:SMP1]WLOCSEQ(NOL)>0
            # Recréer les réservations
            Call STKCTREMP([M:SMP1]WLOCSEQ(NOL),
&                          [M:SMP1]TRSTYP,
&                          [M:SMP1]TRSCOD,
&                          [M:SMP1]STOFCY,
&                          [M:SMP1]ITMREF,
&                          [M:SMP1]PCUDES(NOL),
&                          [M:SMP1]QTYPCUDES(NOL),
&                          [M:SMP1]STADES(NOL),
&                          [M:SMP1]LOCTYPDES(NOL),
&                          [M:SMP1]LOCDES(NOL),
&                          "",0,WRET,WOVF,"","","") From STKLOC
        Endif
    Endif
    End
Endif

# Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
If [M:SMP1]WLOCSEQ(NOL)>100000
    [M:SMP1]WLOCSEQ(NOL) -= 100000
Endif
If [M:SMP1]WLOCSEQ(NOL)<>0 & dim([M:SMP1]LOCDES)>0
    Call STKDELRES([M:SMP1]WLOCSEQ(NOL), [M:SMP1]STOFCY, [M:SMP1]LOCDES(NOL), LRET) From STKLOC
    If !LRET
        Call STKCTREMP([M:SMP1]WLOCSEQ(NOL),  [M:SMP1]TRSTYP, [M:SMP1]TRSCOD, [M:SMP1]STOFCY,
&                      [M:SMP1]ITMREF, [M:SMP1]PCUDES(NOL), [M:SMP1]QTYPCUDES(NOL), [M:SMP1]STADES(NOL),
&                      [M:SMP1]LOCTYPDES(NOL), [M:SMP1]LOCDES(NOL), "", 1, mkstat, WOVF, "", "", "")
&                      From STKLOC
        [M:SGW]WLOCSEQCUR = 99999999
    Endif
Endif
#                                                                 # hcb 110327 deb

If [F:ITM]SERMGTCOD = 4
   Local Integer LSEQIND
   Call WSTOSEQIND ("SMP1",NOL+1, LSEQIND, LRET) From SUBSCSB
   If LRET
      End
   Endif
   [M:SMP1]WSTOSEQIND(NOL) = LSEQIND
Endif

#                                                                 # hcb 110327 end

End


##########################################################################
Subprog C_PCUDES(VALEUR)
Variable Char    VALEUR()
    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal LCOE
    Gosub SET_NOL
    Call CTLUOM ([M:SMP1]ITMREF,3,"", VALEUR,LCOE, LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif

    If LMODIF=2
        Actzo [M:SMP1]COEDES(NOL)
    Else
        Diszo [M:SMP1]COEDES(NOL)
    Endif
    If VALEUR<>[M:SMP1]PCUDES(NOL)
        [M:SMP1]COEDES(NOL) = LCOE
    Endif
    [M:SMP1]QTYSTUDES(NOL) = [M:SMP1]QTYPCUDES(NOL) * [M:SMP1]COEDES(NOL)
    Affzo [M:SMP1]COEDES(NOL),QTYSTUDES(NOL)
    Gosub MAJ_PECQTY From TRTSTOSMPB
End

##########################################################################
Subprog C_QTYPCUDES(VALEUR)
Variable Decimal VALEUR

    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal WCOEF

    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    If [F:SRT]SRTTYP<>8 | [F:SRT]SRTNUM<>GSTQNUM
       Read [SRT]SRT0=8;GSTQNUM : If fstat  Raz [F:SRT] : Endif
    Endif
    Gosub SET_NOL

    If VALEUR = 0
        mkstat = 2
        End
    Endif

    If [F:SRT]UOMSAIFLG=2
        WCOEF = [M:SMP1]COEDES(NOL)
        Call CTLUOM([M:SMP1]ITMREF,3,"", [M:SMP1]PCUDES(NOL),WCOEF, LUSCAV, LFMT, LMODIF) From STKACT
        If LMODIF<>2
            Call CTRNEWQTY( NOL, VALEUR, [M:SMP1]COEDES(NOL) )  From TRTSTOSMPB
            If mkstat=2
                End
            Endif
            Diszo [M:SMP1]COEDES(NOL)
        Else
            Actzo [M:SMP1]COEDES(NOL)
        Endif
    Else
        Call CTRNEWQTY( NOL, VALEUR, [M:SMP1]COEDES(NOL) )  From TRTSTOSMPB
        If mkstat=2
            End
        Endif
    Endif
    [M:SMP1]QTYSTUDES(NOL) = VALEUR * [M:SMP1]COEDES(NOL)
    Affzo [M:SMP1]QTYSTUDES(NOL)

    Gosub MAJ_PECQTY From TRTSTOSMPB

End

##########################################################################
Subprog C_COEDES(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL

    If VALEUR = 0
        mkstat=2
    Endif

    Call CTRNEWQTY( NOL, [M:SMP1]QTYPCUDES(NOL), VALEUR ) From TRTSTOSMPB
    If mkstat=2
        End
    Endif
    [M:SMP1]QTYSTUDES(NOL) = [M:SMP1]QTYPCUDES(NOL) * VALEUR
    Affzo QTYSTUDES(NOL)
    Gosub MAJ_PECQTY From TRTSTOSMPB

End


Subprog AM_STADES(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Local Char     WWRH(GLONWRH)
If [M:SMP1]STA = VALEUR
    mkstat = 2
   GMESSAGE=mess(83,123,1)
Endif

#-- Si article géré en emplacement , on essaie
#-- d'initialiser avec l'emplacement d'origine, on fait les contrôles
#-- Si contrôle non ok on raz
If [F:ITF]ITMREF<>[M:SMP1]ITMREF | [F:ITF]STOFCY<>[M:SMP1]STOFCY
  Read [ITF]ITF0 = [M:SMP1]ITMREF; [M:SMP1]STOFCY
  If fstat : Raz [F:ITF] : Endif
Endif
If [F:ITF]LOCMGTCOD=2
  If dim([M:SMP1]WRH) > 0
    WWRH=[M:SMP1]WRH
  Else
    WWRH=""
  Endif

  Call STKCTRTLO([M:SMP1]WLOCSEQ(NOL),[M:SMP1]TRSTYP,[M:SMP1]TRSCOD,[M:SMP1]STOFCY,[M:SMP1]ITMREF
&               ,[M:SMP1]PCUDES(NOL),[M:SMP1]QTYPCUDES(NOL),VALEUR
&               ,0,[M:SMP1]LOCTYP,mkstat,"QU","",WWRH) From STKLOC
  If mkstat
    GMESSAGE =VALEUR-":"-mess(213,184,1)-[M:SMP1]LOCTYP-[M:SMP1]LOC
#    GMESSAGE+="\"+mess(214,184,1)
  Elsif [M:SMP1]LOC<>""
    Call STKCTREMP([M:SMP1]WLOCSEQ(NOL),[M:SMP1]TRSTYP,[M:SMP1]TRSCOD,[M:SMP1]STOFCY
&                 ,[M:SMP1]ITMREF,[M:SMP1]PCUDES(NOL),[M:SMP1]QTYPCUDES(NOL),VALEUR
&                 ,[M:SMP1]LOCTYP,[M:SMP1]LOC,"",0,mkstat,GBIDD1,"QU","",WWRH) From STKLOC
    If !mkstat
       [M:SMP1]LOCTYPDES(NOL)=[M:SMP1]LOCTYP
       [M:SMP1]LOCDES(NOL)   =[M:SMP1]LOC
       If dim ([M:SMP1]WRHDES)> 0
          [M:SMP1]WRHDES(NOL)   =[M:SMP1]WRH
       Endif
       If dim ([M:SMP1]LPNNUMDES)> 0                                                          # hcb X3-77043
          [M:SMP1]LPNNUMDES(NOL)   =[M:SMP1]LPNNUM                                            # hcb X3-77043
       Endif                                                                                  # hcb X3-77043
    Else
       GMESSAGE =VALEUR-":"-mess(213,184,1)-[M:SMP1]LOCTYP-[M:SMP1]LOC
#       GMESSAGE+="\"+mess(214,184,1)
    Endif
  Endif
Endif
[M:SMP1]STADES(NOL) = VALEUR
Gosub MAJ_QTYSMPREFS From TRTSTOSMPB

End

Subprog AS_WRHDES(VALEUR)
Variable Char    VALEUR()
If GWRHACT = 2
   If [M]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[M]STOFCY
   Endif
   If [F:FCY]WRHGES<>2
      mkstat = 2
   Endif
Endif
End

Subprog C_WRHDES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF;VALEUR
  If fstat
     GMESSAGE=[M]ITMREF-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

Subprog AM_WRHDES(VALEUR)
Variable Char    VALEUR()
If [M:SMP1]WRHDES(nolign-1)<>""
   Raz [M:SMP1]LOCDES(nolign-1), [M:SMP1]LOCTYPDES(nolign-1)
Endif
End

Subprog AS_LBEFMT(VALEUR)
Variable Char    VALEUR()
If [M:SMP1]LBENBR(nolign-1) = 0
   mkstat = 2
Endif
End
Subprog AS_LBENBR(VALEUR)
Variable Decimal VALEUR
If [M:SMP1]STADES(nolign-1) = ""
   mkstat = 2
Endif
End
Subprog C_LBENBR(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
   Diszo [M:SMP1]LBEFMT(nolign-1)
   Raz   [M:SMP1]LBEFMT(nolign-1)
   Affzo [M:SMP1]LBEFMT(nolign-1)
Else
   Actzo [M:SMP1]LBEFMT(nolign-1)
Endif
End

