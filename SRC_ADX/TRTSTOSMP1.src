######################################################################################

#                                                                              # hcb 110327 deb
Subprog IB_NBLIG
# No séries concernés
GBOUT1 = mess(655,199,1) # No séries concernés
# pas de saisie des series concernés si :
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
Local Integer WOUI
WOUI = 2
If [F:ITF]LOCMGTCOD = 2
   If  [M:SMP1]LOCTYPDES(nolign-1) <> "" & [M:SMP1]LOCDES(nolign-1) <> ""
       WOUI = 2
   Else
       Raz WOUI
   Endif
Endif

If  [F:ITM]SERMGTCOD <> 4 | [M:SMP1]WSTOCOU = 0 | [M:SMP1]QTYPCUDES (nolign-1)= 0
& | [M:SMP1]STADES (nolign-1) = "" | WOUI = 0
    Raz GBOUT1
Endif

End

Subprog B1_NBLIG
Local Integer LRET
Local Integer LSEQ
Local Decimal LQTYSTU
Gosub SET_NOL

GOUVCHGS = 2
If [M:SMP1]WSTJFLG(NOL) <> 0
   GOUVCHGS = 9
   End
Endif

If [M:SMP1]WSTOSEQIND(NOL) = 0
   Local Integer LSEQIND
   Call WSTOSEQIND ("SMP1",NOL+1, LSEQIND, LRET) From SUBSCSB
   If LRET
      End
   Endif
   [M:SMP1]WSTOSEQIND(NOL) = LSEQIND
Endif
Call DELSTOCHGW([M:SMP1]STOFCY, [M:SMP1]WSTOSEQ,[M:SMP1]WSTOCOU, 0, LRET) From TRTSTOSMPB
LSEQ = [M:SMP1]WSTOSEQ
I = find(0,[M:SMP1]WSTJFLG(0..[M:SMP1]NBLIG-1))-1
If I>=0
   Call FILLCHGW("SMP1", I, [M:SMP1]NBLIG-I, LSEQ, [M:SMP1]STOFCY, LRET, LQTYSTU) From SUBSCSB
Endif

End

Subprog AM_QTYPCUDES(VALEUR)
Variable Decimal VALEUR
If [F:ITM]SERMGTCOD = 4 & dim([M:SMP1]SERNUM) > 0
   Raz   [M:SMP1]SERNUM (nolign-1)
   Raz   [M:SMP1]SERNUMF(nolign-1)
   Affzo [M:SMP1]SERNUM (nolign-1)
   Affzo [M:SMP1]SERNUMF(nolign-1)
Endif
End

#                                                                              # hcb 110327 end


#                                                                                         # hcb X3-77043 deb
Subprog C_LPNNUMDES(VALEUR)
Variable Char    VALEUR()
Local Shortint W_K

#If  [M:SMP1]LPNNUM <> "" & VALEUR = ""
#    GMESSAGE=mess(513,184,1)
#    mkstat=2
#Endif
If VALEUR <> "" & [F:LPN]LOC <> ""
   Read  [STC]STC0=[M:SMP1]STOFCY;[F:LPN]LOC
   If !fstat
      Call STKCTRSTA([M:SMP1]STADES(nolign-1),[F:STC]AUZSST,0,1,0,W_K) From STKACT
      If W_K <> 0
         GMESSAGE += [F:LPN]LOC-mess(832,196,1)-"("+[M:SMP1]STADES(nolign-1)+")"
         mkstat=2
      Endif
  Endif
Endif



End
Subprog AS_LPNNUMDES(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M:SMP1]LPNNUM <> ""
   VALEUR                      = [M:SMP1]LPNNUM
   [M:SMP1]LOCTYPDES(nolign-1) = [M:SMP1]LOCTYP
   [M:SMP1]LOCDES   (nolign-1) = [M:SMP1]LOC
Endif




End

Subprog AS_LOCTYPDES(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
   VALEUR                      = [M:SMP1]LOCTYP
   [M:SMP1]LOCDES   (nolign-1) = [M:SMP1]LOC
Endif
End
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()
If [F:ITF]LPNMGTCOD = 2 & dim([M:SMP1]LPNNUMDES) > 0 & [M:SMP1]LPNNUMDES(nolign-1) <> ""
   If find([F:STC]LOCCAT,3,4)
      GMESSAGE = mess(241,184,1)  # Emplacement non autorise
      mkstat = 2
      End
   Endif
Endif
End
#                                                                                         # hcb X3-77043 fin

