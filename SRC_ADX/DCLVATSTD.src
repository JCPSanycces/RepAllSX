#<AdxTL>@(#)1.0.0.0 $Revision$
# Issue X3-74646 - 2018-02-05 by FHA : UK VAT Vat Box management

Local Char    VALPAR(250)(1..20)
Local Char VALEUR(10)
GFONCTION ="DCLVATSWI"
Call S_AFF_CHAR(VALEUR,VALPAR,"","DCLVATSTD","XYDCLVATSTD") From GACTION

$ACTION
Case ACTION
 When "TRT_DIV"     : Gosub TRT_DIV
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
If GBATCH=1 | GSERVEUR=1 : Gosub CALL_BATCH : Endif
Return

$TRT_DIV
Call EXEC
Return

$CALL_BATCH
## YYFIN_110215_US3
Case PARAM(1)
 When "SWI", "OTH"        : Gosub ACTION From DCLVATOTH     :# Issue X3-74646   "BRI" switched to the DCLVATBOX action
 When "FRA", "BRI"        : Gosub ACTION From DCLVATBOX     :# Issue X3-74646   "BRI" switched to the DCLVATBOX action
 #When "FRA", "BRI", "SWI", "OTH" : Gosub ACTION From DCLVATFRA  ##YYFIN_105609
 ## End YYFIN_110215_US3
 When "SPA"               : Gosub ACTION From DCLVATSPA
 When "BEL"               : Gosub ACTION From DCLVATBEL
Endcase
Return

Subprog EXEC
Local Char    ACTCUR(GLONACT) , ACTSUI(GLONACT) , FCTCUR(GLONAFC)
Local Char    VALPAR(250)(1..20)
Local Char    CODTRT(GLONADC) , SPETRT(GLONADC)
Local Char    PARAM1(GLONACN) , PARAM2(GLONFEN) , PARAM4(GLONFEN) , PARAM5(10)
Local Integer PARAM3 , TYPACT , NOPAR , TYPVAL , K

If clalev([F:ACT])=0 : Local File ACTION    [ACT] : Endif
If clalev([F:ATR])=0 : Local File ACTPAR    [ATR] : Endif
If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif

## the action name = the function name
ACTCUR = GFONCTION
Case GFONCTION
  When "DCLVATPOR1" : ACTCUR = "GOBJET"
  When "DCLVATPOR2" : ACTCUR = "GOBJET"
  When "DCLVATPOR3" : ACTCUR = "GOBJET"
  When "DCLVATPOR4" : ACTCUR = "GOBJET"
  When "DCLVATGER3" : ACTCUR = "GOBJET"  # 2012-05-16 : X3SUIVI82140 DNE : Line added.
  When "DCLVATGER4" : ACTCUR = "GOBJET"  # 2012-05-23 : X3SUIVI82140 ANGRE : Line added.
  When "DCLVATGER5" : ACTCUR = "GOBJET"  # 2012-06-26 : X3SUIVI82140 DNE : Line added.
  When "DCLVATAUT3" : ACTCUR = "GOBJET"  # 2012-09-03 : X3SUIVI82140 DNE : Line added.
  When "DCLVATAUT4" : ACTCUR = "GOBJET"  # 2012-10-17 : X3SUIVI82140 DNE : Line added.
  When "DCLVATAUT5" : ACTCUR = "GOBJET"  # 2012-09-03 : X3SUIVI82140 DNE : Line added.
  When "DCLVATSWI2" : ACTCUR = "GOBJET"
Endcase
Read [ACT]ACTION = ACTCUR
If [F:AFC]CODINT<>GFONCTION
 Read [AFC]CODINT = GFONCTION
Endif

$TR_ACTION
If ACTCUR<>""
 GACTION = [F:ACT]ACTION
 FCTCUR  = [F:AFC]CODINT
 ACTSUI  = [F:ACT]ACTSUI
 TYPACT  = [F:ACT]TYP
 CODTRT  = [F:ACT]CODTRT
 SPETRT  = [F:ACT]SPETRT
 PARAM1  = [F:ACT]PARAM1
 PARAM2  = [F:ACT]PARAM2
 PARAM3  = [F:ACT]PARAM3
 PARAM4  = [F:ACT]PARAM4
 PARAM5  = [F:ACT]PARAM5

 # Initialization of the action parameters

 If [F:ACT]TYPACT=2 & [F:ACT]NBPAR>0
  Read [ATR]NOPAR = [F:ACT]ACTION;1
  Case [F:ATR]TYPPAR
   When 1   : TYPVAL = 1 : Local Char    VALEUR(250)
   When 2,5 : TYPVAL = 2 : Local Integer VALEUR
   When 3   : TYPVAL = 3 : Local Decimal VALEUR
   When 4   : TYPVAL = 4 : Local Date    VALEUR
   When 6   : TYPVAL = 6 : Local Clbfile VALEUR
   When 7   : TYPVAL = 7 : Local Blbfile VALEUR
  Endcase
 Else
  TYPVAL = 1 : Local Char VALEUR(250)
 Endif
 Raz VALPAR
 NOPAR = 0
 For I=1 To [F:ACT]NBPAR
  If (I>1 or [F:ACT]TYPACT<>2)
   NOPAR += 1
   Read [ATR]NOPAR = [F:ACT]ACTION;I
   K = find([F:ATR]CODPAR,[F:AFC]CODPAR(0..dim([F:AFC]CODPAR)-1))
   If K & [F:AFC]VALPAR(K-1)<>""
    Onerrgo EVAL
    Case [F:ATR]TYPPAR
     When 1,4,6
      VALPAR(NOPAR) = evalue([F:AFC]VALPAR(K-1))
     When Default
      VALPAR(NOPAR) = num$(evalue([F:AFC]VALPAR(K-1)))
    Endcase
    Onerrgo
   Else
    VALPAR(NOPAR) = ""
   Endif
  Endif
 Next I
 Close Local File [AFC] , [ACT] , [ATR]

 # To execute the action
 # To allow the navigation taking account the variant even if "tunnel"
 Global Integer GNAVEXEFNC : GNAVEXEFNC=1
 Case TYPACT
  When 1 : # Object management
   Case TYPVAL
    When 1   : Call OBJET_CHAR(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 2,5 : Call OBJET_LIB(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 3   : Call OBJET_NUM(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 4   : Call OBJET_DAT(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 6   : Call OBJET_CLOB(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
    When 7   : Call OBJET_BLOB(VALEUR,VALPAR(1),VALPAR(2)) From GOBJET
   Endcase
  When 2 : # Inquiry
   If GHISTO : GCONSULT = 0 : Endif
   Call GCONSULT(PARAM1,GFLAG,VALPAR) From GCONSULT
  When 3 : # Standard processing
   If PARAM3=5 or PARAM3=6
    Case TYPVAL
     When 1   : Call TRAITE_CHAR(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 2,5 : Call TRAITE_LIB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 3   : Call TRAITE_NUM(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 4   : Call TRAITE_DAT(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 6   : Call TRAITE_CLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
     When 7   : Call TRAITE_BLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM5,PARAM3,SPETRT) From GTRAITE
    Endcase
   Else
    Case TYPVAL
     When 1   : Call TRAITE_CHAR(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 2,5 : Call TRAITE_LIB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 3   : Call TRAITE_NUM(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 4   : Call TRAITE_DAT(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 6   : Call TRAITE_CLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
     When 7   : Call TRAITE_BLOB(VALEUR,VALPAR,PARAM2,CODTRT,PARAM4,PARAM3,SPETRT) From GTRAITE
    Endcase
   Endif
  When 4 : # Window entry
   Case TYPVAL
    When 1   : Call SAISIE_CHAR(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 2,5 : Call SAISIE_LIB(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 3   : Call SAISIE_NUM(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 4   : Call SAISIE_DAT(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 6   : Call SAISIE_CLOB(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
    When 7   : Call SAISIE_BLOB(VALEUR,VALPAR,PARAM2,CODTRT,SPETRT) From GSAISIE
   Endcase
  When 5 : # Selction from list
   Case TYPVAL
    When 1   : Call S_LIS_CHAR(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 2,5 : Call S_LIS_LIB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 3   : Call S_LIS_NUM(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 4   : Call S_LIS_DAT(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 6   : Call S_LIS_CLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 7   : Call S_LIS_BLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
   Endcase
  When 6 : # Selection from table
   Case TYPVAL
    When 1   : Call S_TAB_CHAR(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 2,5 : Call S_TAB_LIB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 3   : Call S_TAB_NUM(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 4   : Call S_TAB_DAT(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 6   : Call S_TAB_CLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 7   : Call S_TAB_BLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
   Endcase
  When 7 : # Miscellaneous display
   Case TYPVAL
    When 1   : Call S_AFF_CHAR(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 2,5 : Call S_AFF_LIB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 3   : Call S_AFF_NUM(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 4   : Call S_AFF_DAT(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 6   : Call S_AFF_CLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
    When 7   : Call S_AFF_BLOB(VALEUR,VALPAR,PARAM5,CODTRT,SPETRT) From GACTION
   Endcase
 Endcase

 # Update of the parameters passed by address (if linked action)

 If ACTSUI<>""
  If clalev([F:ACT])=0 : Local File ACTION    [ACT] : Endif
  If clalev([F:ATR])=0 : Local File ACTPAR    [ATR] : Endif
  If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
  Read [ACT]ACTION = ACTCUR
  Read [AFC]CODINT = FCTCUR
  NOPAR = 0
  For I=1 To [F:ACT]NBPAR
   If (I>1 or [F:ACT]TYPACT<>2)
    NOPAR += 1
    Read [ATR]NOPAR = [F:ACT]ACTION;I
    If [F:ATR]ADRVAL=1
     K = find([F:ATR]CODPAR,[F:AFC]CODPAR(0..dim([F:AFC]CODPAR)-1))
     If K & [F:AFC]VALPAR(K-1)<>""
      Onerrgo EVAL
      Case [F:ATR]TYPPAR
       When 1,4,6
        Assign [F:AFC]VALPAR(K-1) With VALPAR(NOPAR)
       When Default
        Assign [F:AFC]VALPAR(K-1) With val(VALPAR(NOPAR))
      Endcase
      Onerrgo
     Endif
    Endif
   Endif
  Next I
  ACTCUR = ACTSUI
  Goto TR_ACTION
 Endif
Endif
End

$EVAL
Resume


#-------------------------------------------------------------------------#
#--- Common Company selection for Taxes declaration's functions ----------#
#-------------------------------------------------------------------------#

$SEL_LISTE
Case LISTE
 When "SCPYLEGVAT"  : Gosub S_SELCPYLEGVAT
Endcase
Return

$S_SELCPYLEGVAT
Local Libelle LEDTYPGEN, LEDTYPANA
Local Char CODLED(GLONLED), DEVLED(GLONCUR)
Local Integer MAXDIM,OK
MAXDIM=max(nbrecord([CPY]))
Local Char TEXTE(GLONDES)(1..MAXDIM,1..3)
Local Char TEX(GLONDES)(1..MAXDIM)
TIT = mess(2,45,11) :# Company
TIT(1)=mess(2,45,1) :# Company
TIT(2)=mess(30,109,1) :# Title
TIT(3)=mess(218,107,1) :# Legislation
For [CPY]CPY0 Where CPYLEGFLG=2
 Call CTLLEGVAT([F:CPY]CPY,PARAM(1),OK)
 If OK
  NBTEX += 1
  TEX(NBTEX)   = [F:CPY]CPY
  TEXTE(NBTEX,1) = [F:CPY]CPY
  TEXTE(NBTEX,2) = [F:CPY]CPYNAM
  TEXTE(NBTEX,3) = [F:CPY]LEG
 Endif
Next
Return

#-------------------------------------------------------------------------#
#---------- Common subprogs for Taxes declaration's functions ------------#
#-------------------------------------------------------------------------#

#Finance 71253 Sprint 1 US2
#Go/NoGo for functions of taxes declarations
Subprog CTLLEGVAT(CPY,LEG,OK)
Value Char CPY()
Value Char LEG()
Variable Integer OK
#
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
#
Local Char LEGVAT(GLONADI+3)
#
OK=0
LEGVAT = LEG+"VAT"
Call LEC_CPY(CPY) From CPTLEC
# Local tax parameter + matching legislation
# Paramètre TVA Local + Legislation correspondante
If func AFNC.PARAM(LEGVAT,CPY)="2"
 OK=1
Endif
End

#Control on CPY field
Subprog CTLCPYLEGVAT(CPY,LEG)
Value Char CPY()
Value Char LEG()
If CPY<>""
 If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
 Local Char LEGVAT(GLONADI+3)
 LEGVAT = LEG+"VAT"
 Call LEC_CPY(CPY) From CPTLEC
 If func AFNC.PARAM(LEGVAT,CPY)<>"2" :#| [F:CPY]LEG<>LEG
  #Fonction non implémentée pour cette société
  GMESSAGE=mess(231,107,1) :#-LEG
  mkstat=2
 Endif
Endif
End

